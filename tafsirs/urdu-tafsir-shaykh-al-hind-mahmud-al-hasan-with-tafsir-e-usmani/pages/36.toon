tafsir[83]{c,v,t}:
  36,1,"یٰس ۔"
  36,2,"قسم ہے اس پکے قرآن کی"
  36,3,"تو تحقیق ہے بھیجے ہوؤں میں سے"
  36,4,"اوپر سیدھی راہ کے{1}"
  36,5,"اتارا زبردست رحم  والے نے{1}"
  36,6,"تاکہ تو ڈرائے ایک قوم کو کہ ڈر نہیں سنا انکے باپ دادوں نے سو ان کو خبر نہیں"
  36,7,"ثابت ہو چکی ہے بات ان میں بہتوں پر سو وہ نہ مانیں گے[[آنحضرت صلی اللہ علیہ وسلم کا فریضہ انذار:یعنی بہت کٹھن کام آپ کے سپرد ہوا ہے کہ اس قوم (عرب) کو آپ قرآن کے ذریعہ سے ہوشیار و بیدار کریں جس کے پاس صدیوں سے کوئی جگانے والا نہیں بھیجا تھا۔ وہ جاہل و غافل قوم جسے نہ خد اکی خبر نہ آخرت کی، نہ ماضی سے عبرت نہ مستقبل کی فکر، نہ مبداء پر نظر نہ منتہا پر ، نیک و بد کی تمیز نہ بھلے برے کا شعور اس کو اتنی ممتد جہالت و غفلت کی اندھیریوں سے نکال کر رشدوہدایت کی صاف سڑک پر لا کھڑا کرنا کوئی معمولی اور سہل کام نہیں ہے بلاشبہ آپ پوری قوت اور زور شور کےساتھ ان کو اس غفلت و جہالت کے خوفناک نتائج اور بھیانک مستقبل سے ڈرا کر فلاح و بہبود کے اعلیٰ مدارج پر پہنچانے کی کو شش کریں گے تاکہ یہ قوم اپنی اعلیٰ کامیابی سے تمام عالم کے لئے کامیابی کا دروازہ کھول دے۔ لیکن بہت افراد وہ ملیں گے جو کسی قسم کی نصیحت پر کان دھرنے والے نہیں۔ اسی لئے ان پر شیطان پوری طرح مسلط ہو جاتا ہے جو ان کی حماقتوں اور شرارتوں کو ان کی نگاہ میں خوشنما کر کے دکھلاتا اور اگلے پچھلے سب احوال کو خواہ کتنے ہی گندے ہوں، خوبصورت بنا کر ظاہر کرتا ہے۔ آخر یہ لوگ دوسری زندگی سے بالکل منکر ہو کر اپنی فانی خواہشات ہی کو قبلہ مقصود ٹھہرا لیتے ہیں۔ اس وقت ایک طرف سے شیطان کی بات وَ لَاُغۡوِیَنَّہُمۡ  اَجۡمَعِیۡنَ ۔ اِلَّا عِبَادَکَ  مِنۡہُمُ  الۡمُخۡلَصِیۡنَ (الحجر۔۳۹،۴۰) (مخلصین کے سوا میں سب کو بہکا کر رہوں گا) سچی ہوتی ہے۔ اور دوسری طرف حق تعالیٰ کا قول لَاَمۡلَـَٔنَّ جَہَنَّمَ مِنۡکَ وَ مِمَّنۡ تَبِعَکَ مِنۡہُمۡ  اَجۡمَعِیۡنَ (ص۔۸۵) (تجھ سے اور تیرے پیرووں سے دوزخ کو بھر دوں گا) ثابت اور چسپاں ہو جاتا ہے باقی علم الہٰی میں تو ازل سے ثابت ہے کہ فلاں قوم کے فلاں فلاں افراد اپنی بدتمیزی اور لاپروائی سے شیطان کے اغواء میں پھنس کر عذاب الہٰی کے مستحق ہوں گے۔ ایسے لوگوں کے راہ پر آنے اور ماننے کی کیا توقع ہو سکتی ہے۔ پس آپ کو سلسلہ انذار و اصلاح میں اگر ایسے ہمت شکن واقعات کا مقابلہ کرنا پڑے تو ملول و غمگین نہ ہوں اپنا فرض ادا کئے جائیں اور نتیجہ کو خدا کے سپرد کر دیں۔ تقریر بالا کو سمجھنے کے لئے یہ آیات پیش نظر رکھئے۔ (ا) وَ مَنۡ یَّعۡشُ عَنۡ ذِکۡرِ الرَّحۡمٰنِ نُقَیِّضۡ لَہٗ  شَیۡطٰنًا  فَہُوَ  لَہٗ  قَرِیۡنٌ۔ وَ اِنَّہُمۡ  لَیَصُدُّوۡنَہُمۡ عَنِ السَّبِیۡلِ وَ یَحۡسَبُوۡنَ  اَنَّہُمۡ  مُّہۡتَدُوۡنَ (زخرف۔۳۶،۳۷) 
شیطان کن لوگوں پر مسلط ہوتا ہے:
معلوم ہوا کہ شیطان ابتداءً کسی پر مسلط نہیں کیا جاتا۔ بلکہ اندھا بن کر نصیحت سے اعراض کرتے رہنے کا اثر یہ ہوتا ہے کہ کر شیطان مسلط ہوجائے۔ جیسے ہاتھ پاؤں سے  مدت تک کام نہ لے تو وہ عضو بیکار کر دیا جاتا ہے۔ قال تعالیٰ فَلَمَّا  زَاغُوۡۤا اَزَاغَ  اللّٰہُ قُلُوۡبَہُمۡ (الصف۔۵) وَ نُقَلِّبُ اَفۡـِٕدَتَہُمۡ وَ اَبۡصَارَہُمۡ کَمَا لَمۡ یُؤۡمِنُوۡا بِہٖۤ  اَوَّلَ مَرَّۃٍ  وَّ نَذَرُہُمۡ فِیۡ طُغۡیَانِہِمۡ یَعۡمَہُوۡن (انعام۔۱۱۰) (ب) وَ قَیَّضۡنَا لَہُمۡ قُرَنَآءَ فَزَیَّنُوۡا لَہُمۡ مَّا بَیۡنَ  اَیۡدِیۡہِمۡ وَ مَا خَلۡفَہُمۡ وَ حَقَّ عَلَیۡہِمُ  الۡقَوۡلُ فِیۡۤ  اُمَمٍ (حم السجدہ۔۲۵) تسلط کے بعد شیطان یہ کام کرتا ہے جس کا نتیجہ حَقَّ عَلَیْھِمُ الْقَوْلُ ہے۔ (ج) وَ الَّذِیۡ  قَالَ  لِوَالِدَیۡہِ  اُفٍّ لَّکُمَاۤ اَتَعِدٰنِنِیۡۤ   اَنۡ  اُخۡرَجَ وَ قَدۡ خَلَتِ الۡقُرُوۡنُ مِنۡ  قَبۡلِیۡ ۚ وَ ہُمَا یَسۡتَغِیۡثٰنِ اللّٰہَ وَیۡلَکَ اٰمِنۡ ٭ۖ اِنَّ  وَعۡدَ اللّٰہِ  حَقٌّ ۚۖ فَیَقُوۡلُ مَا ہٰذَاۤ  اِلَّاۤ  اَسَاطِیۡرُ  الۡاَوَّلِیۡنَ۔ اُولٰٓئِکَ  الَّذِیۡنَ حَقَّ عَلَیۡہِمُ  الۡقَوۡلُ فِیۡۤ اُمَمٍ (الاحقاف۔۱۷،۱۸) ان آیات سے معلوم ہوا کہ لفظ حَقَّ الْقَوْلُ ان لوگوں پر صادق آتا ہے جو موت کے بعد کسی دوسری زندگی کا یقین ہی نہیں رکھتے  نہ برائی کو برائی سمجھتے ہیں۔ بلکہ اغوائے شیطانی سے اپنی بدیوں کو نیکی اور گمراہی کو ہدایت تصور کر لیتے ہیں۔ کیسے ہی معقول دلائل سنائیے اور کھلے کھلے نشان دکھلائیے، سبکو جھٹلاتےرہیں اور فضول حجتیں نکالتے رہیں بظاہر ہادیوں اور پیغمبروں کی بات کی طرف کان جھکائیں مگر ایک حرف سمجھنے کی کوشش نہ کریں محض ہوا و ہوس کو اپنا معبود ٹھہرا لیں نہ عقل سے کام لیں نہ آنکھوں سے۔
کن لوگوں کے دلوں پر مہر لگتی ہے؟
یہ ہی لوگ ہیں جن کے اعراض و عناد کے نتیجہ میں آخر کار اللہ تعالیٰ دلوں پرمہر کر دیتا ہے کہ ان میں خیر کے گھنسے کی پھر ذرا گنجائش نہیں رہتی ۔ جیسے کوئی شخص اپنے اوپر روشنی کے سب دروازے بند کر لے تو اللہ تعالیٰ اس کو اندھیرے میں چھوڑ دیتا ہے۔ یا ایک بیمار دوا پینے کی قسم کھا لے، طبیب سے دشمنی کرے اور ہر قسم کی بد پرہیزی پر تیار ہو جائے تو اللہ اس کے مرض کو مہلک بنا دیتا ہے اور مایوسی کے درجہ میں پہنچا دیتا ہے۔ فرماتے ہیں تِلۡکَ الۡقُرٰی نَقُصُّ عَلَیۡکَ مِنۡ اَنۡۢبَآئِہَا ۚ  وَ لَقَدۡ جَآءَتۡہُمۡ رُسُلُہُمۡ بِالۡبَیِّنٰتِ ۚ فَمَا کَانُوۡا لِیُؤۡمِنُوۡا بِمَا کَذَّبُوۡا مِنۡ قَبۡلُ ؕ کَذٰلِکَ یَطۡبَعُ اللّٰہُ عَلٰی قُلُوۡبِ  الۡکٰفِرِیۡنَ (اعراف۔۱۰۱) ثُمَّ بَعَثۡنَا مِنۡۢ بَعۡدِہٖ رُسُلًا اِلٰی قَوۡمِہِمۡ فَجَآءُوۡہُمۡ بِالۡبَیِّنٰتِ فَمَا کَانُوۡا لِیُؤۡمِنُوۡا بِمَا کَذَّبُوۡا بِہٖ  مِنۡ  قَبۡلُ ؕ کَذٰلِکَ نَطۡبَعُ عَلٰی قُلُوۡبِ الۡمُعۡتَدِیۡنَ (یونس۔۷۴) وَ لَقَدۡ ضَرَبۡنَا لِلنَّاسِ فِیۡ ہٰذَا الۡقُرۡاٰنِ مِنۡ کُلِّ مَثَلٍ ؕ وَ لَئِنۡ جِئۡتَہُمۡ بِاٰیَۃٍ لَّیَقُوۡلَنَّ  الَّذِیۡنَ کَفَرُوۡۤا اِنۡ  اَنۡتُمۡ  اِلَّا مُبۡطِلُوۡنَ۔ کَذٰلِکَ یَطۡبَعُ اللّٰہُ عَلٰی قُلُوۡبِ الَّذِیۡنَ لَا  یَعۡلَمُوۡنَ فَاصۡبِرۡ  اِنَّ وَعۡدَ اللّٰہِ  حَقٌّ (روم۔۵۸،۵۹،۶۰)  کَذٰلِکَ یُضِلُّ اللّٰہُ مَنۡ ہُوَ  مُسۡرِفٌ مُّرۡتَابُۨ۔ الَّذِیۡنَ یُجَادِلُوۡنَ فِیۡۤ  اٰیٰتِ اللّٰہِ بِغَیۡرِ سُلۡطٰنٍ اَتٰہُمۡ ؕ کَبُرَ مَقۡتًا عِنۡدَ اللّٰہِ وَ عِنۡدَ الَّذِیۡنَ اٰمَنُوۡا ؕ کَذٰلِکَ یَطۡبَعُ اللّٰہُ  عَلٰی کُلِّ  قَلۡبِ مُتَکَبِّرٍ  جَبَّارٍ (مومن۔۳۴،۳۵) وَ مِنۡہُمۡ  مَّنۡ یَّسۡتَمِعُ  اِلَیۡکَ ۚ حَتّٰۤی  اِذَا خَرَجُوۡا مِنۡ عِنۡدِکَ قَالُوۡا لِلَّذِیۡنَ اُوۡتُوا الۡعِلۡمَ  مَاذَا  قَالَ  اٰنِفًا ۟ اُولٰٓئِکَ الَّذِیۡنَ طَبَعَ اللّٰہُ  عَلٰی قُلُوۡبِہِمۡ  (محمد۔۱۶) بَلۡ طَبَعَ اللّٰہُ عَلَیۡہَا بِکُفۡرِہِمۡ فَلَا یُؤۡمِنُوۡنَ  اِلَّا قَلِیۡلًا (نساء۔۱۵۵) کَلَّا بَلۡ ٜ رَانَ عَلٰی قُلُوۡبِہِمۡ مَّا کَانُوۡا یَکۡسِبُوۡنَ (مطففین۔۱۴) اَفَرَءَیۡتَ مَنِ اتَّخَذَ  اِلٰـہَہٗ  ہَوٰىہُ وَ اَضَلَّہُ  اللّٰہُ  عَلٰی  عِلۡمٍ  وَّ خَتَمَ عَلٰی سَمۡعِہٖ وَ قَلۡبِہٖ وَ جَعَلَ عَلٰی بَصَرِہٖ  غِشٰوَۃً ؕ فَمَنۡ یَّہۡدِیۡہِ  مِنۡۢ  بَعۡدِ اللّٰہِ (الجاثیہ۔۲۳) وَ لَقَدۡ ذَرَاۡنَا لِجَہَنَّمَ کَثِیۡرًا مِّنَ الۡجِنِّ وَ الۡاِنۡسِ ۫ۖ  لَہُمۡ قُلُوۡبٌ لَّا یَفۡقَہُوۡنَ بِہَا ۫ وَ لَہُمۡ اَعۡیُنٌ لَّا یُبۡصِرُوۡنَ بِہَا ۫ وَ لَہُمۡ اٰذَانٌ لَّا یَسۡمَعُوۡنَ بِہَا ؕ اُولٰٓئِکَ کَالۡاَنۡعَامِ بَلۡ ہُمۡ اَضَلُّ ؕ اُولٰٓئِکَ ہُمُ الۡغٰفِلُوۡنَ (اعراف۔۱۷۹) یُحَرِّفُوۡنَ الۡکَلِمَ مِنۡۢ بَعۡدِ مَوَاضِعِہٖ ۚ یَقُوۡلُوۡنَ اِنۡ اُوۡتِیۡتُمۡ ہٰذَا فَخُذُوۡہُ وَ اِنۡ لَّمۡ تُؤۡتَوۡہُ فَاحۡذَرُوۡا ؕ وَ مَنۡ یُّرِدِ اللّٰہُ فِتۡنَتَہٗ فَلَنۡ تَمۡلِکَ لَہٗ  مِنَ اللّٰہِ  شَیۡئًا ؕ اُولٰٓئِکَ الَّذِیۡنَ لَمۡ یُرِدِ اللّٰہُ اَنۡ یُّطَہِّرَ قُلُوۡبَہُمۡ  (المائدہ۔۴۱)۔]]"
  36,8,"ہم نے ڈالے ہیں انکی گردنوں میں طوق سو  وہ ہیں ٹھوڑیوں تک پھر انکے سر  اُلل (ابھر) رہے ہیں{1}"
  36,9,"اور بنائی ہم نے ان کے آگے دیوار اور پیچھے دیوار پھر اوپر سے ڈھانک دیا سو ان کو کچھ نہیں سوجھتا{1}"
  36,10,"اور برابر ہے ان کو تو ڈرائے یا نہ ڈرائے  یقین نہیں کریں گے{1}"
  36,11,"تو ڈر سناتے اسکو جو چلے سمجھائے پر اور ڈرے رحمٰن سے بن دیکھے سو  اسکو خوشخبری دے معافی کی اور عزت کے ثواب کی{1}"
  36,12,"ہم تو ہیں جو زندہ کرتے ہیں مردوں کو{1} اور لکھتے ہیں جو آگے بھیج چکے اور جو نشان انکے  پیچھے رہے{2} اور ہر چیز گن لی ہے ہم نے ایک کھلی اصل میں{3}"
  36,13,"اور بیان کر انکے  واسطے ایک مثل اس گاؤں کے لوگوں کی{1} جبکہ آئے اس میں بھیجے ہوئے{2}"
  36,14,"جب بھیجے  ہم نے انکی طرف دو تو ان کو کو جھٹلایا پھر ہم نے قوت دی تیسرے سے تب کہا انہوں نے ہم تمہاری طرف آئے ہیں بھیجے ہوئے{1}"
  36,15,"وہ بولے تم تو یہی انسان ہو جیسے ہم اور رحمٰن نے کچھ نہیں اتارا تم سارے جھوٹ کہتے ہو{1}"
  36,16,"کہا ہمارا رب جانتا ہے ہم بیشک تمہاری طرف بھیجے ہوئے آئے ہیں{1}"
  36,17,"اور ہمارا ذمہ یہی ہے پیغام پہنچا دینا کھول کر{1}"
  36,18,"بولے ہم نے نامبارک دیکھا تم کو اگر تم باز نہ رہو گے تو ہم تم کو سنگسار کریں گے اور تم کو پہچے گا ہمارے ہاتھ سے عذاب دردناک{1}"
  36,19,"کہنے لگے تمہاری نا مبارکی تمہارے ساتھ ہے کیا اتنی بات پر کہ تم کو سمجھایا کوئی نہیں پرتم لوگ کہ حد پر نہیں رہتے{1}"
  36,20,"اور آیا شہر کے پرلے سرے سے ایک مرد دوڑتا ہوا{1} بولا اے قوم چلو راہ پر بھیجے ہوؤں کی"
  36,21,"چلو راہ پر ایسے شخص کی جو تم سے بدلا نہیں چاہتے اور وہ ٹھیک رستہ پر ہیں{1}"
  36,22,"اور مجھ کو کیا ہوا کہ میں بندگی نہ کروں اسکی جس نے مجھ کو بنایا{1} اور اسی کی طرف سب پھر جاؤ گے{2}"
  36,23,"بھلا میں پکڑوں اس کے سوائے اوروں کو پوجنا کہ اگر مجھ پر چاہے رحمٰن تکلیف تو کچھ کام نہ آئے مجھ کو ان کی سفارش اور نہ وہ مجھ کو چھڑائیں"
  36,24,"تو تو میں بھٹکتا رہوں صریح{1}"
  36,25,"میں یقین لایا تمہارے رب پر مجھ سے سن لو{1}"
  36,26,"حکم ہوا چلا جا بہشت میں{1} بولا کسی طرح میری قوم معلوم کر لیں"
  36,27,"کہ کس بنا پر بخشا مجھ کو میرے رب نے اور کیا مجھ کو عزت والوں میں{1}"
  36,28,"اور اتاری نہیں ہم نے اس کی قوم پر اس کے پیچھے کوئ فوج آسمان سے اور ہم فوج  نہیں اتارا کرتے"
  36,29,"بس یہی تھی ایک چنگھاڑ پھر اسی دم سب بجھ گئے{1}"
  36,30,"کیا افسوس ہے بندوں پر کوئی رسول نہیں آیا ان کے پاس جس سے ٹھٹھا نہیں کرتے"
  36,31,"کیا نہیں دیکھتے کتنی غارت کر چکے ہم ان سے پہلے جماعتیں کہ وہ انکے پاس پھر کر نہیں آئیں گی{1}"
  36,32,"اور ان سب میں کوئی نہیں جو اکھٹے ہو کر نہ آئیں ہمارے پس پکڑے ہوئے {1}"
  36,33,"اور ایک نشانی ہے انکے واسطے زمین مردہ اسکو ہم نے زندہ کر دیا اور نکالا اس میں سے اناج سو اسی میں سے کھاتے ہیں"
  36,34,"اور بنائے ہم نے اس میں باغ کھجور کے اور انگور کے اور بہا دیے اس میں بعضے چشمے"
  36,35,"کہ کھائیں اسکے میووں سے{1} اور اس کو بنایا نہیں انکے ہاتھوں نے پھر کیوں شکر نہیں کرتے{2}"
  36,36,"پاک ذات ہے جس نے بنائے جوڑے سب چیز کے اس قسم سے جو اگتا ہے زمین میں اور خود ان میں سے اور ان چیزوں میں کہ جن کی انکو خبر نہیں{1}"
  36,37,"اور ایک نشانی ہے انکے واسطے رات کھینچ لیتے ہیں ہم اس پر سے دن کو پھر تبہی یہ رہ جاتے ہیں اندھیرے میں"
  36,38,"اور سورج چلا جاتا ہے اپنے ٹھہرے ہوئے رستہ پر{1} یہ سادھا ہے اس زبردست باخبر نے{2}"
  36,39,"اور چاند کو ہم نے بانٹ دی ہیں منزلیں یہاں تک کہ پھر آ رہا ہے جیسے ٹہنی پرانی{1}"
  36,40,"نہ سورج سے ہو کہ پکڑ لے چاند کو اور نہ رات آگے بڑھے دن سے اور ہر کوئی ایک چکر میں پیرتے ہیں{1}"
  36,41,"اور ایک نشانی ہے انکے واسطے کہ ہم نے اٹھا لیا ان کی نسل کو اس بھری ہوئی کشتی میں"
  36,42,"اور بنا دیا ہم نے انکے واسطے کشتی جیسی چیزوں کو جس پر سوار ہوتے ہیں{1}"
  36,43,"اور اگر ہم چاہیں تو انکو  ڈبا دیں پھر کوئی نہ پہنچےانکی فریاد کو اور نہ وہ چھڑائے جائیں"
  36,44,"مگر ہم اپنی مہربانی سے اور انکا کام چلانے کو ایک وقت تک{1}"
  36,45,"اور جب کہیے ان کو بچو اس سے جو تمہارے سامنے آتا ہے اور جو پیچھے چھوڑتے ہو شاید تم پر رحم ہو"
  36,46,"اور کوئی حکم نہیں پہنچتا انکو اپنے رب کے حکموں سے جس کو وہ ٹلاتے نہ ہوں{1}"
  36,47,"اور جب کہیے ان کو خرچ کرو کچھ اللہ کا دیا کہتے ہیں منکر ایمان والوں کو ہم کیوں کھلائیں ایسے کو کہ اللہ چاہتا تو اس کو کھلا دیتا[[کفار کا استہزاء:یعنی اور احکام الہٰی تو کیا مانتے، فقیروں مسکینوں پر خرچ کرنا تو ان کے نزدیک بھی کار ثواب ہے لیکن یہ ہی مسلم بات جب پیغمبر اور مومنین کی طرف سے کہی جاتی ہے تو نہایت بھونڈے طریقہ سے تمسخر کے ساتھ یہ کہہ کر اس کا انکار کر دیتے ہیں کہ جنہیں خود اللہ میاں نے کھانے کو نہیں دیا ہم انہیں کیوں کھلائیں۔ ہم تو اللہ کی مشیت کے خلاف کرنا نہیں چاہتے اگر  اس کی مشیت ہوتی تو ان کو فقیر و محتاج اور ہمیں غنی و تونگر نہ بناتا۔
فقرو غنا کی حکمت:
خیال کرو اس حماقت اور بے حیائی کا کیا ٹھکانہ ہے کیا خدا کسی کو دینا چاہے تو اس کی یہ ہی ایک صورت ہے کہ خود بلاواسطہ رزق اس کے ہاتھ پررکھ دے۔ اگر وسائط سے دلانا بھی اس کی مشیت سے ہے تو تم نے یہ فیصلہ کیسے کر لیا کہ اللہ ان کو روٹی دینا نہیں چاہتا یہ تو اس کاا متحان ہے کہ اغنیاء کو فقراء کی اعانت پر مامور فرمایا اور ان کے توسط سے رزق پہنچانے کا سامان کیا جو اس امتحان میں ناکامیاب رہا اسے اپنی بدبختی اور شقاوت پر رونا چاہئیے۔ (تنبیہ) بعض سلف کے اقوال سے معلوم ہوتا ہے کہ یہ آیات بعض زنادقہ کے حق میں ہیں۔  اس صورت میں ان کے اس قول کو تمسخر پر حمل نہ کیا جائے گا بلکہ حقیقت پر رکھیں گے۔]] تم لوگ تو بالکل بہک رہے ہو صریح{1}"
  36,48,"اور کہتے ہیں کب ہو گا یہ وعدہ اگر تم سچے ہو{1}"
  36,49,"یہ تو راہ دیکھتے ہیں ایک چنگھاڑ کی جو ان کو آ پکڑے گی جب آپس میں جھگڑ رہے ہوں گے"
  36,50,"پھر نہ کر سکیں گے کہ کچھ کہہ ہی مریں  اور نہ اپنے گھر کو پھر کر جا سکیں گے{1}"
  36,51,"اور پھونکی جائے صور پھر تبہی وہ قبروں سے اپنے رب کی پھیل پڑیں گے{1}"
  36,52,"کہیں گے اے خرابی ہماری کس نے اٹھا دیا ہم کو ہماری نیند کی جگہ سے{1} یہ وہ ہے جو وعدہ کیا تھا رحمٰن نے اور سچ کہا تھا پیغمبروں نے{2}"
  36,53,"بس ایک چنگھاڑ ہو گی پھر اسی دم وہ سارے ہمارے پاس پکڑے چلے آئیں گے{1}"
  36,54,"پھر آج کے دن ظلم نہ ہوگا کسی جی پر ذرا اور  وہی بدلہ پاؤ گے جو کرتے تھے{1}"
  36,55,"تحقیق بہشت کے لوگ آج ایک مشغلہ میں ہیں باتیں کرتے"
  36,56,"وہ اور ان کی عورتیں سایوں میں تختوں پر بیٹھے ہیں تکیہ لگائے"
  36,57,"انکے لئے وہاں ہے میوہ اور انکے لئے ہے جو کچھ مانگیں{1}"
  36,58,"سلام بولنا ہے رب مہربان سے{1}"
  36,59,"اور تم الگ ہو جاؤ آج  اے گناہگارو{1}"
  36,60,"میں نے  نہ کہہ رکھا تھا تم کو اے آدم کی اولاد کہ نہ پوجیو شیطان کو  وہ کھلا دشمن ہے تمہارا"
  36,61,"اور یہ کہ پوجو مجھ کو یہ راہ ہے سیدھی{1}"
  36,62,"اور وہ  بہکا لے گیا تم میں سے بہت خلقت کو پھر کیا تم کو سمجھ نہ تھی"
  36,63,"یہ دوزخ ہے جس کا تم کو وعدہ تھا"
  36,64,"جا پڑو اس میں آج کے دن بدلا اپنے کفر کا{1}"
  36,65,"آج ہم مہر لگا دیں گے ان کے منہ پر اور بولیں گے ہم سے ان کے ہاتھ اور بتلائیں گے ان کے پاؤں جو کچھ وہ کماتے تھے{1}"
  36,66,"اور اگر ہم چاہیں مٹا دیں ان کی آنکھیں پھر دوڑیں رستہ پانے کو پھر کہاں سے سوجھے"
  36,67,"اور اگر ہم چاہیں صورت مسخ کر دیں انکی جہاں کی تہاں پھر نہ آگے چل سکیں اور نہ وہ الٹے پھر سکیں{1}"
  36,68,"اور جس کو ہم بوڑھا کریں اوندھا کریں اس کی پیدائش میں پھر کیا ان کو سمجھ نہیں{1}"
  36,69,"اور ہم نے نہیں سکھایا اسکو شعر کہنا اور یہ اس کے لائق نہیں یہ تو خالص نصیحت ہے اورقرآن ہے صاف{1}"
  36,70,"تاکہ ڈر سنائے اس کو جس میں جان ہو اور ثابت ہو الزام منکروں پر{1}"
  36,71,"کیا اور نہیں دیکھتے وہ کہ ہم نے بنا دیے انکے واسطے اپنے ہاتھوں کی بنائی چیزوں سے چوپائے پھر وہ انکے مالک ہیں{1}"
  36,72,"اور عاجز کر دیا انکو انکے آگے پھر ان میں کوئی ہے انکی سواری اور کسی کو کھاتے ہیں"
  36,73,"اور انکے واسطے چارپایوں میں فائدے ہیں اور پینے کے گھاٹ پھر کیوں شکر نہیں کرتے{1}"
  36,74,"اور پکڑتے ہیں اللہ کے سوائے اور حاکم کہ شاید ان کی مدد کریں"
  36,75,"نہ کر سکیں گے ان کی مدد اور یہ انکی فوج ہو کر پکڑ آئیں گے{1}"
  36,76,"اب تو غمگین مت ہو انکی بات سے ہم جانتے ہیں جو وہ چھپاتے ہیں اور جو ظاہر کرتے ہیں{1}"
  36,77,"کیا دیکھتا نہیں انسان کہ ہم نے اس کو بنایا ایک قطرہ سے پھر تبہی وہ ہو گیا جھگڑنے بولنے والا{1}"
  36,78,"اور بٹھلاتا ہے ہم پر ایک مثل اور بھول گیا اپنی پیدائش کہنے لگا کون زندہ کرے گا ہڈیوں کو جب کھوکھری ہو گئیں{1}"
  36,79,"تو کہہ ان کو زندہ کرے گا جس نے بنایا انکو پہلی بار اور وہ سب بنانا جانتا ہے{1}"
  36,80,"جس نے بنا دی تم کو سبز درخت سے آگ پھر اب تم اس سے سلگاتے ہو{1}"
  36,81,"کیا جس نے بنائے آسمان اور زمین نہیں بنا سکتا ان جیسے کیوں نہیں اور وہی ہے اصل بنانے والا سب کچھ جاننے والا{1}"
  36,82,"اسکا حکم یہی ہے کہ جب کرنا چاہے کسی چیز کو تو کہے اس کو ہو وہ اسی وقت ہو جائے{1}"
  36,83,"سو پاک ہے وہ ذات جس کے ہاتھ ہے حکومت ہر چیز کی اور اسی کی طرف پھر کر چلے جاؤ گے[[اللہ ہی حاکم مطلق ہے:یعنی وہ اعلیٰ ترین ہستی جس کے ہاتھ میں فی الحال بھی اوپر سے نیچے تک تمام مخلوقات کی زمام حکومت ہے اور آئندہ بھی اسی کی طر ف سب کو لوٹ کر جانا ہے۔ پاک ہے عجز و سفہ اور ہر قسم کے عیب و نقص سے۔
تم سورۂ یٰسٓ وللہ الحمد والمنۃ۔]]"
