quran[26]{c,v,t}:
  53,1,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿والنجم إذا هوى﴾</span></span>: الواو واو القسم، والنجم مقسم به مجرور بالكسرة، والجار والمجرور متعلقان بفعل محذوف تقديره أقسم، وإذا ظرف للزمان المستقبل مجرد من معنى الشرط في محل نصب متعلق بالفعل المقدر، أي أقسم بالنجم وقت هويه، فالظرف مستعار للحال، وجملة القسم لا محل لها من الإعراب، لأنها ابتدائية، وهوى فعل ماض والفاعل مستتر تقديره هو، والجملة في محل جر مضاف إليه.</p></div>"
  53,2,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ما ضل صاحبكم وما غوى﴾</span></span>: الجملة لا محل لها من الإعراب، لأنها جواب القسم، وضل صاحبكم فعل وفاعل، وما غوى عطف على ما ضل.</p></div>"
  53,3,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وما ينطق عن الهوى﴾</span></span>: الواو عاطفة، وما نافية، وينطق فعل مضارع، وفاعله هو، وعن الهوى جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿ينطق﴾</span></span>، فعن للمجاوزة على بابها، وقيل: إنها بمعنى الباء، والجار والمجرور متعلقان بمحذوف حال.</p></div>"
  53,4,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إن هو إلا وحي يوحى﴾</span></span>: إن نافية، وهو مبتدأ، وإلا أداة حصر، ووحي خبر هو، وجملة يوحى صفة لوحي.</p></div>"
  53,5,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿علمه شديد القوى﴾</span></span>: الجملة صفة ثانية لـ<span class="hlt"><span class="qpc-hafs">﴿وحي﴾</span></span>، وعلمه فعل ومفعول به، وشديد القوى فاعل علمه.</p></div>"
  53,6,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ذو مرة فاستوى﴾</span></span>: ذو مرة صفة لشديد القوى، والفاء عاطفة، واستوى فعل وفاعل مقدر.</p></div>"
  53,7,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وهو بالأفق الأعلى﴾</span></span>: الواو حالية، وهو مبتدأ، وبالأفق خبر، والأعلى صفة للأفق، والجملة في موضع الحال.</p></div>"
  53,8,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ثم دنا فتدلى﴾</span></span>: ثم حرف عطف للتراخي، ودنا فعل، وفاعله مقدر تقديره هو. فتدلى عطف على دنا.</p></div>"
  53,9,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فكان قاب قوسين أو أدنى﴾</span></span>: الفاء عاطفة، وكان فعل ماض ناقص، واسمها المستتر، وقاب قوسين خبرها، وأو حرف عطف، أو للإجابة، وأدنى عطف على قاب.</p></div>"
  53,10,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فأوحى﴾</span></span>: الفاء عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿أوحى﴾</span></span> فعل ماض، والفاعل مستتر تقديره: <span class="hlt"><span class="qpc-hafs">﴿هو﴾</span></span> يعود على الله تعالى، وجملة <span class="hlt"><span class="qpc-hafs">﴿أوحى إلى عبده ما أوحى﴾</span></span> معطوفة على جملة <span class="hlt"><span class="qpc-hafs">﴿كان﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿إلى عبده﴾</span></span>: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أوحى﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> موصولة في محل نصب مفعول به، أو: مصدرية، وهي مع مدخولها في تأويل مصدر منصوب على أنه مفعول به، أو مفعول مطلق.</p><p><span class="hlt"><span class="qpc-hafs">﴿أوحى﴾</span></span>: فعل ماض، والفاعل مستتر تقديره: <span class="hlt"><span class="qpc-hafs">﴿هو﴾</span></span> يعود على جبريل عليه السلام، وجملة <span class="hlt"><span class="qpc-hafs">﴿أوحى﴾</span></span> صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> لا محل لها من الإعراب.</p></div>"
  53,11,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ما كذب الفؤاد ما رأى﴾</span></span>: ما نافية، وكذب الفؤاد فعل وفاعل، وما موصولة مفعول به، لأن كذب فعل يتعدى إلى مفعول، وقيل: لا يتعدى، فيكون نصب ما على إسقاط الخافض، أي: فيما رآه، وقيل: إن كذب قد يتعدى إلى اثنين. أو ما مصدرية، وهي مع مدخولها في موضع نصب، لأنه مفعول كذب.</p></div>"
  53,12,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿أفتمارونه﴾</span></span>: الهمزة للاستفهام الإنكاري، وتمارونه: فعل وفاعل ومفعول به. وجملة <span class="hlt"><span class="qpc-hafs">﴿تمارونه﴾</span></span> معطوفة على جملة استئنافية مقدرة أي: أتنكرون قوله فتمارونه.</p><p><span class="hlt"><span class="qpc-hafs">﴿على﴾</span></span>: حرف جر مبني.</p><p><span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span>: اسم موصول مجرور، والجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تمارونه﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿يرى﴾</span></span>: فعل مضارع والفاعل مستتر. وجملة <span class="hlt"><span class="qpc-hafs">﴿يرى﴾</span></span> صلة الموصول لا محل لها من الإعراب. أو <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> مصدرية، تؤول مع ما بعدها بمصدر مجرور بـ<span class="hlt"><span class="qpc-hafs">﴿على﴾</span></span>، والجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تمارونه﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿يرى﴾</span></span> صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> المصدرية لا محل لها من الإعراب.</p></div>"
  53,13,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ولقد﴾</span></span>: الواو للحال، واللام جواب للقسم المحذوف، وقد حرف تحقيق.</p><p><span class="hlt"><span class="qpc-hafs">﴿رآه﴾</span></span>: فعل ماض، والفاعل مستتر، والهاء مفعول به.</p><p><span class="hlt"><span class="qpc-hafs">﴿نزلة﴾</span></span>: ظرف زمان، أي: مرة أخرى، لأن مصدر النزلة بمثابة المرة منها، أو: حال نصبت نصب المصدر الواقع موقع الحال، أي: رآه نازلا نزلة أخرى، أو نائب عن المفعول المطلق، لأنه صفة المصدر أي: رؤية نزلة أخرى.</p><p><span class="hlt"><span class="qpc-hafs">﴿أخرى﴾</span></span>: نعت لـ<span class="hlt"><span class="qpc-hafs">﴿نزلة﴾</span></span> منصوب بالفتحة المقدرة على الألف.</p></div>"
  53,14,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿عند سدرة المنتهى﴾</span></span>: الظرف متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿رآه﴾</span></span>، أو حال من الفاعل، أو المفعول، أو منهما معًا، وسدرة مضاف إليه، والمنتهى مضاف إليه.</p></div>"
  53,15,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿عندها جنة المأوى﴾</span></span>: الظرف متعلق بمحذوف خبر مقدم، وجنة المأوى مبتدأ مؤخر، والجملة حال من سدرة المنتهى.</p></div>"
  53,16,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إذ يغشى السدرة ما يغشى﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿إذ﴾</span></span> ظرف متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿رآه﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿يغشى السدرة﴾</span></span> في محل جر بإضافة الظرف إليها، و<span class="hlt"><span class="qpc-hafs">﴿السدرة﴾</span></span> مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> اسم موصول في محل رفع فاعل، وجملة <span class="hlt"><span class="qpc-hafs">﴿يغشى﴾</span></span> الثانية صلة الموصول لا محل لها من الإعراب.</p></div>"
  53,17,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ما زاغ البصر وما طغى﴾</span></span>: ما نافية، وزاغ البصر فعل ماض وفاعل، وما طغى عطف على ما زاغ.</p></div>"
  53,18,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿لقد رأى من آيات ربه الكبرى﴾</span></span>: اللام جواب للقسم المحذوف، وقد حرف تحقيق، ورأى فعل ماضٍ، وفاعله مستتر، ومن آيات ربه حال مقدمة على المفعول، والكبرى مفعول رأى، أو <span class="hlt"><span class="qpc-hafs">﴿الكبرى﴾</span></span> صفة <span class="hlt"><span class="qpc-hafs">﴿آيات ربه﴾</span></span>، ويكون المرئي محذوفًا.</p></div>"
  53,19,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿أفرأيتم اللات والعزى﴾</span></span>: الهمزة للاستفهام الإنكاري، والفاء حرف عطف لترتيب الرؤية، ورأيتم فعل وفاعل واللات مفعوله، والعزى معطوف على اللات.</p></div>"
  53,20,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ومناة الثالثة الأخرى﴾</span></span>: مناة معطوف على اللات، والثالثة الأخرى صفتان، الأولى صفة للتين قبلها، والثانية صفة ذم للثالثة. والمفعول الثاني محذوف تقديره: كيف هي عاجزة؟ والجملة لا محل لها من الإعراب عطفًا على استئناف مقدر، أي: أعرفتم عظمة الله وقدرته فرأيتم اللات .. كيف هي عاجزة؟</p></div>"
  53,21,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ألكم الذكر وله الأنثى﴾</span></span>: الهمزة للاستفهام الإنكاري أيضًا، ولكم خبر مقدم، والذكر مبتدأ مؤخر، وله الأنثى معطوفة لا محل لها من الإعراب.</p></div>"
  53,22,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿تلك إذا قسمة ضيزى﴾</span></span>: تلك اسم إشارة مبتدأ، وإذًا بمعنى الجواب والجزاء، وقسمة خبر، وضيزى صفة لقسمة، والجملة استئناف بياني لا محل لها من الإعراب.</p></div>"
  53,23,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إن هي إلا أسماء سميتموها أنتم وآباؤكم ما أنزل الله بها من سلطان﴾</span></span>: إن نافية، وهي مبتدأ، وإلا أداة حصر، وأسماء خبر هي، وسميتموها فعل وفاعل ومفعول به ثانٍ، والأول محذوف تقديره: أصنامًا، وأنتم تأكيد للفاعل ليصح عطف <span class="hlt"><span class="qpc-hafs">﴿وآباؤكم﴾</span></span> عليه، وجملة سميتموها صفة لـ<span class="hlt"><span class="qpc-hafs">﴿أسماء﴾</span></span>، وكذلك جملة ما أنزل، وما نافية، وأنزل الله فعل وفاعل، وبها حال، لأنه كان في الأصل صفة لـ<span class="hlt"><span class="qpc-hafs">﴿سلطان﴾</span></span>، ومن حرف جر صلة، وسلطان مجرور لفظًا منصوب محلا على أنه مفعول به.</p><p><span class="hlt"><span class="qpc-hafs">﴿إن يتبعون إلا الظن وما تهوى الأنفس﴾</span></span>: إن نافية، ويتبعون فعل مضارع مرفوع بثبوت النون، والواو فاعل، وإلا أداة حصر، والظن مفعول يتبعون، والواو حرف عطف، وما موصول معطوف على الظن، ولك أن تجعلها مصدرية.</p><p><span class="hlt"><span class="qpc-hafs">﴿ولقد جاءهم من ربهم الهدى﴾</span></span>: الواو حالية، أو اعتراضية، واللام: جواب للقسم المحذوف، وقد: حرف تحقيق. وجاءهم: فعل ماضٍ، ومفعول به مقدم. ومن ربهم: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿جاءهم﴾</span></span>. والهدى: فاعل جاءهم. وجملة <span class="hlt"><span class="qpc-hafs">﴿ولقد جاءهم...﴾</span></span>: إما حالية من فاعل يتبعون، أو اعتراضية لا محل لها من الإعراب، لأن قوله: <span class="hlt"><span class="qpc-hafs">﴿أم للإنسان...﴾</span></span> متصل بقوله: <span class="hlt"><span class="qpc-hafs">﴿وما تهوى الأنفس﴾</span></span>.</p></div>"
  53,24,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿أم للإنسان ما تمنى﴾</span></span>: أم: منقطعة بمعنى: بل وهمزة الاستفهام الإنكاري، و<span class="hlt"><span class="qpc-hafs">﴿للإنسان﴾</span></span> جار ومجرور متعلقان بمحذوف خبر مقدم، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> مبتدأ مؤخر، وجملة <span class="hlt"><span class="qpc-hafs">﴿تمنى﴾</span></span> صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> لا محل لها من الإعراب.</p></div>"
  53,25,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فلله الآخرة والأولى﴾</span></span>: الفاء عاطفة على مقدر مفهوم من معنى أم، أي: ليس الأمر كذلك، ولله خبر مقدم، والآخرة مبتدأ مؤخر، والأولى عطف على الآخرة.</p></div>"
  53,26,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وكم﴾</span></span>: الواو عاطفة، وكم خبرية في محل رفع مبتدأ.</p><p><span class="hlt"><span class="qpc-hafs">﴿من ملك﴾</span></span>: في محل نصب تمييز كم الخبرية.</p><p><span class="hlt"><span class="qpc-hafs">﴿في السماوات﴾</span></span>: جار ومجرور متعلقان بمحذوف صفة لملك.</p><p><span class="hlt"><span class="qpc-hafs">﴿لا﴾</span></span>: لا نافية.</p><p><span class="hlt"><span class="qpc-hafs">﴿تغني﴾</span></span>: فعل مضارع.</p><p><span class="hlt"><span class="qpc-hafs">﴿شفاعتهم﴾</span></span>: فاعل مرفوع، والضمير مضاف إليه، وجملة <span class="hlt"><span class="qpc-hafs">﴿لا تغني شفاعتهم﴾</span></span> خبر.</p><p><span class="hlt"><span class="qpc-hafs">﴿شيئًا﴾</span></span>: مفعول تغني، أو نائب عن المفعول المطلق، أي شيئًا من الإغناء.</p><p><span class="hlt"><span class="qpc-hafs">﴿إلا﴾</span></span>: أداة حصر.</p><p><span class="hlt"><span class="qpc-hafs">﴿من بعد﴾</span></span>: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تغني﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿أن يأذن الله﴾</span></span>: أن وما في حيزها في تأويل مصدر مجرور بالإضافة لبعد، والله: لفظ الجلالة فاعل <span class="hlt"><span class="qpc-hafs">﴿يأذن﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿لمن﴾</span></span>: اللام حرف جر، و<span class="hlt"><span class="qpc-hafs">﴿مَن﴾</span></span> اسم موصول مبني في محل جر.</p><p><span class="hlt"><span class="qpc-hafs">﴿يشاء﴾</span></span>: فعل مضارع، والفاعل مستتر، وجملة <span class="hlt"><span class="qpc-hafs">﴿يشاء﴾</span></span> صلة الموصول لا محل لها من الإعراب.</p><p><span class="hlt"><span class="qpc-hafs">﴿ويرضى﴾</span></span>: الواو عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿يرضى﴾</span></span> فعل مضارع، والفاعل مستتر.</p></div>"