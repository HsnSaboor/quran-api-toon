quran[15]{c,v,t}:
  36,13,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿واضرب لهم مثلا أصحاب القرية إذ جاءها المرسلون﴾</span></span>: كلام مستأنف لا محل له من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿اضرب﴾</span></span>: فعل أمر بمعنى اجعل، و<span class="hlt"><span class="qpc-hafs">﴿لهم﴾</span></span>: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿اضرب﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿مثلا﴾</span></span>: مفعول به ثان لـ<span class="hlt"><span class="qpc-hafs">﴿اضرب﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿أصحاب﴾</span></span>: مفعول به أول، أو <span class="hlt"><span class="qpc-hafs">﴿اضرب﴾</span></span> بمعنى اذكر، و<span class="hlt"><span class="qpc-hafs">﴿مثلا﴾</span></span> مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿أصحاب﴾</span></span> بدل على حذف مضاف، أي: مثَلَ أصحاب، و<span class="hlt"><span class="qpc-hafs">﴿القرية﴾</span></span>: مضاف إليه، و<span class="hlt"><span class="qpc-hafs">﴿إذ﴾</span></span>: اسم مبني على السكون في محل نصب بدل اشتمال من <span class="hlt"><span class="qpc-hafs">﴿أصحاب القرية﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿جاءها﴾</span></span>: فعل ماض، و<span class="hlt"><span class="qpc-hafs">﴿ها﴾</span></span> ضمير في محل نصب مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿المرسلون﴾</span></span>: فاعل، وجملة <span class="hlt"><span class="qpc-hafs">﴿جاءها المرسلون﴾</span></span> في محل جر بإضافة الظرف إليها.</p></div>"
  36,14,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إذ أرسلنا إليهم اثنين﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿إذ﴾</span></span>: اسم مبني على السكون في محل نصب بدل من <span class="hlt"><span class="qpc-hafs">﴿إذ﴾</span></span> التي في الآية السابقة، و<span class="hlt"><span class="qpc-hafs">﴿أرسلنا﴾</span></span>: فعل ماض و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> فاعل، و<span class="hlt"><span class="qpc-hafs">﴿إليهم﴾</span></span>: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أرسلنا﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿اثنين﴾</span></span>: مفعول به لـ<span class="hlt"><span class="qpc-hafs">﴿أرسلنا﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿أرسلنا﴾</span></span> في محل جر بالإضافة.</p><p><span class="hlt"><span class="qpc-hafs">﴿فكذبوهما﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿فكذبوهما﴾</span></span>: الفاء عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿كذبوهما﴾</span></span> فعل ماض وفاعل ومفعول به، وجملة <span class="hlt"><span class="qpc-hafs">﴿كذبوهما﴾</span></span> معطوفة على جملة <span class="hlt"><span class="qpc-hafs">﴿أرسلنا﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿فعززنا بثالث﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿فعززنا﴾</span></span>: الفاء عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿عززنا﴾</span></span> فعل ماض و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> فاعل، و<span class="hlt"><span class="qpc-hafs">﴿بثالث﴾</span></span>: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿عززنا﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿عززنا﴾</span></span> معطوفة على سابقتها.</p><p><span class="hlt"><span class="qpc-hafs">﴿فقالوا إنا إليكم مرسلون﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿فقالوا﴾</span></span>: الفاء عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿قالوا﴾</span></span> فعل ماض وواو الجماعة فاعل، و<span class="hlt"><span class="qpc-hafs">﴿إنا﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span> حرف ناسخ و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> اسمها، و<span class="hlt"><span class="qpc-hafs">﴿إليكم﴾</span></span>: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿مرسلون﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿مرسلون﴾</span></span> خبر إن، وجملة <span class="hlt"><span class="qpc-hafs">﴿إنا إليكم مرسلون﴾</span></span> مقول القول، وجملة <span class="hlt"><span class="qpc-hafs">﴿قالوا...﴾</span></span> معطوفة على جملة <span class="hlt"><span class="qpc-hafs">﴿عززنا﴾</span></span>.</p></div>"
  36,15,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قالوا ما أنتم إلا بشر مثلنا﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿قالوا﴾</span></span>: فعل ماض وواو الجماعة فاعل، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span>: نافية، و<span class="hlt"><span class="qpc-hafs">﴿أنتم﴾</span></span>: مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿إلا﴾</span></span>: أداة حصر، و<span class="hlt"><span class="qpc-hafs">﴿بشر﴾</span></span>: خبر أنتم، و<span class="hlt"><span class="qpc-hafs">﴿مثلنا﴾</span></span>: صفة لـ<span class="hlt"><span class="qpc-hafs">﴿بشر﴾</span></span>، وضمير المتكلمين <span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> مضاف إليه، وجملة <span class="hlt"><span class="qpc-hafs">﴿ما أنتم...﴾</span></span> مقول القول في محل نصب.</p><p><span class="hlt"><span class="qpc-hafs">﴿وما أنزل الرحمن من شيء﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿وما﴾</span></span>: الواو عاطفة و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> نافية، و<span class="hlt"><span class="qpc-hafs">﴿أنزل﴾</span></span>: فعل ماض، و<span class="hlt"><span class="qpc-hafs">﴿الرحمن﴾</span></span>: فاعل، و<span class="hlt"><span class="qpc-hafs">﴿من﴾</span></span>: حرف جر صلة، و<span class="hlt"><span class="qpc-hafs">﴿شيء﴾</span></span>: مجرور لفظًا بـ<span class="hlt"><span class="qpc-hafs">﴿من﴾</span></span> منصوب محلا على أنه مفعول أنزل، وجملة <span class="hlt"><span class="qpc-hafs">﴿ما أنزل﴾</span></span> معطوفة على مقول القول في محل نصب.</p><p><span class="hlt"><span class="qpc-hafs">﴿إن أنتم إلا تكذبون﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span>: نافية، و<span class="hlt"><span class="qpc-hafs">﴿أنتم﴾</span></span>: مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿إلا﴾</span></span>: أداة حصر، و<span class="hlt"><span class="qpc-hafs">﴿تكذبون﴾</span></span>: فعل مضارع وواو الجماعة فاعل، وجملة <span class="hlt"><span class="qpc-hafs">﴿تكذبون﴾</span></span> خبر، وجملة <span class="hlt"><span class="qpc-hafs">﴿إن أنتم إلا تكذبون﴾</span></span> مستأنفة في حيز القول لا محل لها من الإعراب.</p></div>"
  36,16,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قالوا ربنا يعلم إنا إليكم لمرسلون﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿قالوا﴾</span></span>: فعل ماض وواو الجماعة فاعل، و<span class="hlt"><span class="qpc-hafs">﴿ربنا﴾</span></span>: مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿يعلم﴾</span></span>: فعل مضارع، وفاعل يعلم مستتر تقديره هو، و<span class="hlt"><span class="qpc-hafs">﴿إنا﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span> حرف ناسخ و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> اسمها، و<span class="hlt"><span class="qpc-hafs">﴿إليكم﴾</span></span>: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿مرسلون﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿لمرسلون﴾</span></span>: اللام المزحلقة، و<span class="hlt"><span class="qpc-hafs">﴿مرسلون﴾</span></span> خبر إن، وجملة <span class="hlt"><span class="qpc-hafs">﴿إنا إليكم لمرسلون﴾</span></span> سدت مسد مفعولي يعلم، وجملة <span class="hlt"><span class="qpc-hafs">﴿يعلم﴾</span></span> خبر المبتدأ، وجملة <span class="hlt"><span class="qpc-hafs">﴿ربنا يعلم...﴾</span></span> مقول القول في محل نصب.</p></div>"
  36,17,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وما علينا إلا البلاغ المبين﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿وما﴾</span></span>: الواو عاطفة و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> نافية، و<span class="hlt"><span class="qpc-hafs">﴿علينا﴾</span></span>: جار ومجرور متعلقان بمحذوف خبر مقدم، و<span class="hlt"><span class="qpc-hafs">﴿إلا﴾</span></span>: أداة حصر، و<span class="hlt"><span class="qpc-hafs">﴿البلاغ﴾</span></span>: مبتدأ مؤخر، و<span class="hlt"><span class="qpc-hafs">﴿المبين﴾</span></span>: صفة، والجملة معطوفة على جملة <span class="hlt"><span class="qpc-hafs">﴿ربنا يعلم...﴾</span></span>.</p></div>"
  36,18,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قالوا إنا تطيرنا بكم﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿قالوا﴾</span></span>: فعل ماض وواو الجماعة فاعل، و<span class="hlt"><span class="qpc-hafs">﴿إنا﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span> حرف ناسخ و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> اسمها، تطيرنا: فعل ماض و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> فاعل، و<span class="hlt"><span class="qpc-hafs">﴿بكم﴾</span></span>: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تطيرنا﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿تطيرنا﴾</span></span> خبر إن.</p><p><span class="hlt"><span class="qpc-hafs">﴿لئن لم تنتهوا لنرجمنكم﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿لئن﴾</span></span>: اللام موطئة للقسم و<span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span> شرطية، و<span class="hlt"><span class="qpc-hafs">﴿لم﴾</span></span>: حرف نفي وقلب وجزم، و<span class="hlt"><span class="qpc-hafs">﴿تنتهوا﴾</span></span>: فعل مضارع مجزوم بلم، وواو الجماعة فاعل، و<span class="hlt"><span class="qpc-hafs">﴿لنرجمنكم﴾</span></span>: اللام واقعة في جواب القسم، و<span class="hlt"><span class="qpc-hafs">﴿نرجمنكم﴾</span></span> فعل مضارع مبني على الفتح لاتصاله بنون التوكيد، والفاعل مستتر تقديره نحن، والكاف مفعول به، والميم علامة الجمع، وجملة <span class="hlt"><span class="qpc-hafs">﴿لنرجمنكم﴾</span></span> لا محل لها من الإعراب، لأنها جواب القسم، وجواب الشرط محذوف دل عليه جواب القسم.</p><p><span class="hlt"><span class="qpc-hafs">﴿وليمسنكم منا عذاب أليم﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿وليمسنكم﴾</span></span>: الواو عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿يمسنكم﴾</span></span> فعل مضارع مبني على الفتح لاتصاله بنون التوكيد، والكاف مفعول به، والميم علامة الجمع، و<span class="hlt"><span class="qpc-hafs">﴿منا﴾</span></span>: جار ومجرور متعلقان بمحذوف حال من <span class="hlt"><span class="qpc-hafs">﴿عذاب﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿عذاب﴾</span></span>: فاعل، و<span class="hlt"><span class="qpc-hafs">﴿أليم﴾</span></span>: صفة لـ<span class="hlt"><span class="qpc-hafs">﴿عذاب﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿ليمسنكم﴾</span></span> معطوفة على جواب القسم.</p></div>"
  36,19,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قالوا طائركم معكم﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿قالوا﴾</span></span>: فعل ماض وواو الجماعة فاعل، و<span class="hlt"><span class="qpc-hafs">﴿طائركم﴾</span></span>: مبتدأ، والضمير المتصل مضاف إليه، و<span class="hlt"><span class="qpc-hafs">﴿معكم﴾</span></span>: ظرف متعلق بمحذوف خبر المبتدأ، والضمير المتصل مضاف إليه، وجملة <span class="hlt"><span class="qpc-hafs">﴿طائركم معكم...﴾</span></span> مقول القول.</p><p><span class="hlt"><span class="qpc-hafs">﴿أئن ذكرتم﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿أئن﴾</span></span>: الهمزة للاستفهام الإنكاري و<span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span> شرطية، و<span class="hlt"><span class="qpc-hafs">﴿ذكرتم﴾</span></span>: فعل ماض مبني لما لم يُسَمَّ فاعله في محل جزم فعل الشرط، والتاء نائب فاعل، والميم علامة الجمع، وجواب الشرط محذوف والتقدير: أئن ذكرتم تطيَّرتم أو توعدتم بالرجم والتعذيب، وجملة الشرط مستأنفة في حيز القول لا محل لها من الإعراب.</p><p><span class="hlt"><span class="qpc-hafs">﴿بل أنتم قوم مسرفون﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿بل﴾</span></span>: حرف إضراب، و<span class="hlt"><span class="qpc-hafs">﴿أنتم﴾</span></span>: مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿قوم﴾</span></span>: خبر، و<span class="hlt"><span class="qpc-hafs">﴿مسرفون﴾</span></span>: صفة، والجملة مستأنفة في حيز القول لا محل لها من الإعراب.</p></div>"
  36,20,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وجاء من أقصى المدينة رجل يسعى﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿وجاء﴾</span></span>: الواو عاطفة أو استئنافية، و<span class="hlt"><span class="qpc-hafs">﴿جاء﴾</span></span> فعل ماض، و<span class="hlt"><span class="qpc-hafs">﴿من أقصى﴾</span></span>: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿جاء﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿المدينة﴾</span></span>: مضاف إليه، و<span class="hlt"><span class="qpc-hafs">﴿رجل﴾</span></span>: فاعل جاء، و<span class="hlt"><span class="qpc-hafs">﴿يسعى﴾</span></span>: فعل مضارع وفاعله مستتر تقديره هو، وجملة <span class="hlt"><span class="qpc-hafs">﴿يسعى﴾</span></span> صفة لـ<span class="hlt"><span class="qpc-hafs">﴿رجل﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿وجاء من أقصى...﴾</span></span> معطوفة، أو مستأنفة لا محل لها من الإعراب.</p><p><span class="hlt"><span class="qpc-hafs">﴿قال يا قوم اتبعوا المرسلين﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿قال﴾</span></span>: فعل ماض وفاعله مستتر تقديره هو، و<span class="hlt"><span class="qpc-hafs">﴿يا﴾</span></span>: حرف نداء، و<span class="hlt"><span class="qpc-hafs">﴿قوم﴾</span></span> منادى منصوب بفتحة مقدرة لأنه مضاف لياء المتكلم المحذوفة، و<span class="hlt"><span class="qpc-hafs">﴿اتبعوا﴾</span></span>: فعل أمر وواو الجماعة فاعل، و<span class="hlt"><span class="qpc-hafs">﴿المرسلين﴾</span></span>: مفعول اتبعوا، وجملة النداء <span class="hlt"><span class="qpc-hafs">﴿يا قوم...﴾</span></span> مقول القول، وجملة <span class="hlt"><span class="qpc-hafs">﴿اتبعوا المرسلين﴾</span></span> جواب النداء.</p></div>"
  36,21,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿اتبعوا من لا يسألكم أجرا﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿اتبعوا﴾</span></span>: فعل أمر وواو الجماعة فاعل، و<span class="hlt"><span class="qpc-hafs">﴿من﴾</span></span>: اسم موصول في محل نصب مفعول اتبعوا، و<span class="hlt"><span class="qpc-hafs">﴿لا﴾</span></span>: نافية، و<span class="hlt"><span class="qpc-hafs">﴿يسألكم﴾</span></span>: فعل مضارع، والفاعل مستتر تقديره هو، والكاف مفعول به أول، والميم علامة الجمع، و<span class="hlt"><span class="qpc-hafs">﴿أجرًا﴾</span></span>: مفعول به ثان، وجملة <span class="hlt"><span class="qpc-hafs">﴿لا يسألكم أجرا﴾</span></span> صلة <span class="hlt"><span class="qpc-hafs">﴿مَن﴾</span></span> لا محل لها من الإعراب. وجملة <span class="hlt"><span class="qpc-hafs">﴿اتبعوا من لا يسألكم﴾</span></span> بدل من جملة <span class="hlt"><span class="qpc-hafs">﴿اتبعوا المرسلين﴾</span></span> أو تأكيد.</p><p><span class="hlt"><span class="qpc-hafs">﴿وهم مهتدون﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿وهم﴾</span></span>: الواو عاطفة أو حالية، و<span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿مهتدون﴾</span></span>: خبر، والجملة معطوفة على جملة <span class="hlt"><span class="qpc-hafs">﴿لا يسألكم أجرا﴾</span></span> لا محل لها من الإعراب، أو في محل نصب على الحال.</p></div>"
  36,22,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وما لي لا أعبد الذي فطرني﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿وما﴾</span></span>: الواو عاطفة و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> اسم استفهام في محل رفع مبتدأ وهو استفهام إنكاري، و<span class="hlt"><span class="qpc-hafs">﴿لي﴾</span></span> جار ومجرور متعلقان بمحذوف خبر <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> الاستفهامية، و<span class="hlt"><span class="qpc-hafs">﴿لا﴾</span></span>: نافية، و<span class="hlt"><span class="qpc-hafs">﴿أعبد﴾</span></span>: فعل مضارع، والفاعل مستتر تقديره أنا، و<span class="hlt"><span class="qpc-hafs">﴿الذي﴾</span></span>: اسم موصول في محل نصب مفعول أعبد، و<span class="hlt"><span class="qpc-hafs">﴿فطرني﴾</span></span>: فعل ماض، والفاعل مستتر تقديره هو يعود على الاسم الموصول، وياء المتكلم مفعول به، وجملة <span class="hlt"><span class="qpc-hafs">﴿فطرني﴾</span></span> صلة الذي لا محل لها من الإعراب. وجملة <span class="hlt"><span class="qpc-hafs">﴿لا أعبد...﴾</span></span> حالية، وجملة <span class="hlt"><span class="qpc-hafs">﴿ما لي لا أعبد...﴾</span></span> معطوفة على جملة <span class="hlt"><span class="qpc-hafs">﴿اتبعوا﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿وإليه ترجعون﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿وإليه﴾</span></span>: الواو عاطفة أو حالية، والجار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿ترجعون﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿ترجعون﴾</span></span>: فعل مضارع مبني لما لم يُسَمَّ فاعله، وواو الجماعة نائب فاعل، والجملة معطوفة على جملة <span class="hlt"><span class="qpc-hafs">﴿فطرني﴾</span></span> لا محل لها من الإعراب، أو حالية.</p></div>"
  36,23,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿أأتخذ من دونه آلهة﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿أأتخذ﴾</span></span>: الهمزة للاستفهام الإنكاري أو بمعنى النفي، و<span class="hlt"><span class="qpc-hafs">﴿أتخذ﴾</span></span>: فعل مضارع، وفاعله مستتر تقديره أنا، و<span class="hlt"><span class="qpc-hafs">﴿من دونه﴾</span></span>: جار ومجرور متعلقان بمفعول به ثان لـ<span class="hlt"><span class="qpc-hafs">﴿أتخذ﴾</span></span> والهاء مضاف إليه، و<span class="hlt"><span class="qpc-hafs">﴿آلهة﴾</span></span>: مفعول به أول.</p><p><span class="hlt"><span class="qpc-hafs">﴿إن يردن الرحمن بضر لا تغن عني شفاعتهم شيئا ولا ينقذون﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span>: شرطية، و<span class="hlt"><span class="qpc-hafs">﴿يردنِ﴾</span></span>: فعل الشرط مضارع مجزوم بالسكون، والنون للوقاية، والياء المحذوفة لاتباع خط المصحف مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿الرحمن﴾</span></span>: فاعل، و<span class="hlt"><span class="qpc-hafs">﴿بضر﴾</span></span>: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يردن﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿لا﴾</span></span>: نافية لا عمل لها، و<span class="hlt"><span class="qpc-hafs">﴿تغن﴾</span></span>: فعل مضارع مجزوم في جواب الشرط، و<span class="hlt"><span class="qpc-hafs">﴿عني﴾</span></span>: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تغن﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿شفاعتهم﴾</span></span>: فاعل مرفوع، والضمير المتصل مضاف إليه، و<span class="hlt"><span class="qpc-hafs">﴿شيئًا﴾</span></span>: نائب عن المفعول المطلق، أو مفعول به، وقوله: <span class="hlt"><span class="qpc-hafs">﴿لا تغن عني شفاعتهم شيئا﴾</span></span> جواب الشرط، <span class="hlt"><span class="qpc-hafs">﴿ولا ينقذون﴾</span></span>: عطف على <span class="hlt"><span class="qpc-hafs">﴿لا تغن﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿ينقذون﴾</span></span>: فعل مضارع مجزوم، وواو الجماعة فاعل، والنون للوقاية، وياء المتكلم المحذوفة مفعول به، وجملة الشرط صفة لـ<span class="hlt"><span class="qpc-hafs">﴿آلهة﴾</span></span> أو استئنافية لا محل لها من الإعراب.</p></div>"
  36,24,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إني إذا لفي ضلال مبين﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿إني﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span> حرف ناسخ، وياء المتكلم اسمها، و<span class="hlt"><span class="qpc-hafs">﴿إذًا﴾</span></span>: حرف جواب لا عمل له، و<span class="hlt"><span class="qpc-hafs">﴿لفي ضلال﴾</span></span>: اللام المزحلقة، و<span class="hlt"><span class="qpc-hafs">﴿في ضلال﴾</span></span> جار ومجرور متعلقان بمحذوف خبر إن، و<span class="hlt"><span class="qpc-hafs">﴿مبين﴾</span></span>: صفة لـ<span class="hlt"><span class="qpc-hafs">﴿ضلال﴾</span></span>، والجملة مستأنفة في حيز القول لا محل لها من الإعراب.</p></div>"
  36,25,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إني آمنت بربكم فاسمعون﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿إني﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span> حرف ناسخ، وياء المتكلم اسمها، و<span class="hlt"><span class="qpc-hafs">﴿آمنت﴾</span></span>: فعل ماض، والتاء فاعل، و<span class="hlt"><span class="qpc-hafs">﴿بربكم﴾</span></span>: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿آمنت﴾</span></span> والضمير المتصل مضاف إليه، وجملة <span class="hlt"><span class="qpc-hafs">﴿آمنت بربكم﴾</span></span> خبر إن، <span class="hlt"><span class="qpc-hafs">﴿فاسمعونِ﴾</span></span>: الفاء تفريعية، و<span class="hlt"><span class="qpc-hafs">﴿اسمعون﴾</span></span> فعل أمر مبني على حذف النون، وواو الجماعة فاعل، والنون للوقاية، والياء المحذوفة مفعول به، وجملة <span class="hlt"><span class="qpc-hafs">﴿اسمعون﴾</span></span> معطوفة على جملة <span class="hlt"><span class="qpc-hafs">﴿آمنت﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿إني آمنت...﴾</span></span> مستأنفة في حيز القول لا محل لها من الإعراب.</p></div>"
  36,26,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قيل ادخل الجنة﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿قيل﴾</span></span>: فعل ماض مبني لما لم يُسَمَّ فاعله، و<span class="hlt"><span class="qpc-hafs">﴿ادخل﴾</span></span>: فعل أمر والفاعل مستتر تقديره أنت، و<span class="hlt"><span class="qpc-hafs">﴿الجنة﴾</span></span>: مفعول به، وجملة <span class="hlt"><span class="qpc-hafs">﴿ادخل الجنة﴾</span></span> مقول القول في محل رفع نائب فاعل، والجملة مستأنفة لا محل لها من الإعراب.</p><p><span class="hlt"><span class="qpc-hafs">﴿قال يا ليت قومي يعلمون﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿قال﴾</span></span>: فعل ماض، والفاعل مستتر تقديره هو، و<span class="hlt"><span class="qpc-hafs">﴿يا﴾</span></span>: حرف تنبيه، أو حرف نداء والمنادى محذوف، و<span class="hlt"><span class="qpc-hafs">﴿ليت﴾</span></span>: حرف ناسخ يفيد التمني، و<span class="hlt"><span class="qpc-hafs">﴿قومي﴾</span></span>: اسم ليت منصوب بفتحة مقدرة، وياء المتكلم مضاف إليه، و<span class="hlt"><span class="qpc-hafs">﴿يعلمون﴾</span></span>: فعل مضارع وواو الجماعة فاعل، وجملة <span class="hlt"><span class="qpc-hafs">﴿يعلمون﴾</span></span> خبر ليت، وجملة <span class="hlt"><span class="qpc-hafs">﴿يا ليت قومي يعلمون﴾</span></span> مقول القول في محل نصب، وجملة <span class="hlt"><span class="qpc-hafs">﴿قال يا ليت...﴾</span></span> مستأنفة لا محل لها من الإعراب.</p></div>"
  36,27,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿بما غفر لي ربي وجعلني من المكرمين﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿بما﴾</span></span>: الباء حرف جر، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> اسم موصول في محل جر، أي: يعلمون بالذي غفره لي ربي من الذنوب، أو <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> مصدرية، والمصدر المؤول من <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> المصدرية والفعل <span class="hlt"><span class="qpc-hafs">﴿غفر﴾</span></span> مجرور بالباء، أي: يعلمون بغفران ربي لي، والجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يعلمون﴾</span></span>. و<span class="hlt"><span class="qpc-hafs">﴿غفر﴾</span></span>: فعل ماض. و<span class="hlt"><span class="qpc-hafs">﴿لي﴾</span></span>: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿غفر﴾</span></span>. و<span class="hlt"><span class="qpc-hafs">﴿ربي﴾</span></span>: فاعل مرفوع بضمة مقدرة على ما قبل ياء المتكلم، وياء المتكلم مضاف إليه. وجملة <span class="hlt"><span class="qpc-hafs">﴿غفر لي ربي﴾</span></span> صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> لا محل لها من الإعراب. <span class="hlt"><span class="qpc-hafs">﴿وجعلني﴾</span></span>: الواو عاطفة، <span class="hlt"><span class="qpc-hafs">﴿وجعلني﴾</span></span> فعل ماض، والفاعل مستتر تقديره هو، والنون للوقاية، وياء المتكلم مفعول به أول، و<span class="hlt"><span class="qpc-hafs">﴿من المكرمين﴾</span></span>: جار ومجرور متعلقان بمحذوف مفعول به ثان، وجملة <span class="hlt"><span class="qpc-hafs">﴿جعلني من المكرمين﴾</span></span> معطوفة على جملة <span class="hlt"><span class="qpc-hafs">﴿غفر لي ربي﴾</span></span>.</p></div>"