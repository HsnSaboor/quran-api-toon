quran[27]{c,v,t}:
  37,127,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فكذبوه﴾</span></span>: الفاء عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿كذبوه﴾</span></span> فعل ماض، والواو فاعل، والهاء مفعول به.</p><p><span class="hlt"><span class="qpc-hafs">﴿فإنهم لمحضرون﴾</span></span>: الفاء الفصيحة، و<span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span> حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> اسمها، واللام المزحلقة، و<span class="hlt"><span class="qpc-hafs">﴿محضرون﴾</span></span> خبر إن.</p></div>"
  37,128,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إلا عباد الله المخلصين﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿إلا﴾</span></span> أداة استثناء، و<span class="hlt"><span class="qpc-hafs">﴿عباد الله﴾</span></span> استثناء متصل من فاعل <span class="hlt"><span class="qpc-hafs">﴿فكذبوه﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿المخلصين﴾</span></span> نعت لـ<span class="hlt"><span class="qpc-hafs">﴿عباد الله﴾</span></span>.</p></div>"
  37,129,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وتركنا عليه في الآخرين﴾</span></span>: الواو عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿تركنا﴾</span></span> فعل ماض، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> فاعل، و<span class="hlt"><span class="qpc-hafs">﴿عليه﴾</span></span> جار ومجرور متعلقان بمحذوف صفة للمفعول المحذوف، أي: ثناء كائنًا عليه، و<span class="hlt"><span class="qpc-hafs">﴿في الآخرين﴾</span></span> جار ومجرور متعلقان بمحذوف مفعول به ثان لـ<span class="hlt"><span class="qpc-hafs">﴿تركنا﴾</span></span>.</p></div>"
  37,130,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿سلام على إل ياسين﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿سلام﴾</span></span> مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿على إل ياسين﴾</span></span> جار ومجرور متعلقان بمحذوف خبر، وجملة <span class="hlt"><span class="qpc-hafs">﴿سلام على إل ياسين﴾</span></span> مقول قول محذوف، أي: يقال له هذا في الآخرين.</p></div>"
  37,131,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إنا كذلك نجزي المحسنين﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span> حرف ناسخ و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> اسمها، و<span class="hlt"><span class="qpc-hafs">﴿كذلك﴾</span></span>: الكاف: اسم بمعنى مثل مبني على الفتح في محل نصب صفة لمصدر محذوف مقدم على عامله، أي: جزاءً مثلَ ذلك نجزي المحسنين، وذلك: <span class="hlt"><span class="qpc-hafs">﴿ذا﴾</span></span> اسم إشارة في محل جر مضاف إليه، واللام للبعد، والكاف حرف خطاب، و<span class="hlt"><span class="qpc-hafs">﴿نجزي﴾</span></span> فعل مضارع، والفاعل مستتر تقديره نحن، و<span class="hlt"><span class="qpc-hafs">﴿المحسنين﴾</span></span> مفعول به، وجملة <span class="hlt"><span class="qpc-hafs">﴿نجزي المحسنين﴾</span></span> خبر <span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span>.</p></div>"
  37,132,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إنه من عبادنا المؤمنين﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span> حرف ناسخ، والهاء اسمها، و<span class="hlt"><span class="qpc-hafs">﴿من عبادنا﴾</span></span> جار ومجرور متعلقان بمحذوف خبر، و<span class="hlt"><span class="qpc-hafs">﴿المؤمنين﴾</span></span> صفة، والجملة تعليلية لا محل لها من الإعراب.</p></div>"
  37,133,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وإن لوطا لمن المرسلين﴾</span></span>: الواو عاطفة أو استئنافية، و<span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span> حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿لوطا﴾</span></span> اسمها، واللام المزحلقة، و<span class="hlt"><span class="qpc-hafs">﴿من المرسلين﴾</span></span> جار ومجرور متعلقان بمحذوف خبر <span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿وإن لوطا...﴾</span></span> معطوفة، أو مستأنفة لا محل لها من الإعراب.</p></div>"
  37,134,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إذ نجيناه وأهله أجمعين﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿إذ﴾</span></span> اسم مبني على السكون في محل نصب مفعول به لفعل محذوف تقديره: اذكر، و<span class="hlt"><span class="qpc-hafs">﴿نجيناه﴾</span></span> فعل ماض، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> فاعل، والهاء مفعول به، وجملة <span class="hlt"><span class="qpc-hafs">﴿نجيناه﴾</span></span> في محل جر بالإضافة، و<span class="hlt"><span class="qpc-hafs">﴿أهله﴾</span></span> عطف على الهاء، و<span class="hlt"><span class="qpc-hafs">﴿أجمعين﴾</span></span> تأكيد.</p></div>"
  37,135,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إلا عجوزا في الغابرين﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿إلا﴾</span></span> أداة استثناء، و<span class="hlt"><span class="qpc-hafs">﴿عجوزًا﴾</span></span> مستثنى منصوب، و<span class="hlt"><span class="qpc-hafs">﴿في الغابرين﴾</span></span> جار ومجرور متعلقان بمحذوف صفة.</p></div>"
  37,136,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ثم دمرنا الآخرين﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿ثم﴾</span></span> حرف عطف للترتيب مع التراخي، و<span class="hlt"><span class="qpc-hafs">﴿دمرنا﴾</span></span> فعل ماض، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> فاعل، و<span class="hlt"><span class="qpc-hafs">﴿الآخرين﴾</span></span> مفعول به.</p></div>"
  37,137,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وإنكم لتمرون عليهم مصبحين﴾</span></span>: الواو عاطفة، أو حالية، و<span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span> حرف ناسخ، والكاف اسمها، واللام المزحلقة، و<span class="hlt"><span class="qpc-hafs">﴿تمرون﴾</span></span> فعل مضارع، والواو فاعل، و<span class="hlt"><span class="qpc-hafs">﴿عليهم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تمرون﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿مصبحين﴾</span></span> حال.</p></div>"
  37,138,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وبالليل﴾</span></span>: الواو عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿بالليل﴾</span></span> جار ومجرور متعلقان بمحذوف عطف على <span class="hlt"><span class="qpc-hafs">﴿مصبحين﴾</span></span>، فهو حال أخرى، والباء للملابسة.</p><p><span class="hlt"><span class="qpc-hafs">﴿أفلا تعقلون﴾</span></span>: الهمزة داخلة على مقدر عطف عليه قوله: فلا تعقلون، والتقدير: تشاهدون ذلك فلا تعقلون، أي: تعتبرون به، و<span class="hlt"><span class="qpc-hafs">﴿لا﴾</span></span> نافية، و<span class="hlt"><span class="qpc-hafs">﴿تعقلون﴾</span></span> فعل مضارع مرفوع، والواو فاعل.</p></div>"
  37,139,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وإن يونس لمن المرسلين﴾</span></span>: الواو عاطفة، أو استئنافية، و<span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span> حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿يونس﴾</span></span> اسمها، واللام المزحلقة، و<span class="hlt"><span class="qpc-hafs">﴿من المرسلين﴾</span></span> جار ومجرور متعلقان بمحذوف خبر <span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿وإن يونس...﴾</span></span> مستأنفة لا محل لها من الإعراب.</p></div>"
  37,140,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إذ أبق إلى الفلك المشحون﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿إذ﴾</span></span> ظرف متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿المرسلين﴾</span></span>، أي: هو من المرسلين حتى في هذه الحالة، و<span class="hlt"><span class="qpc-hafs">﴿أبق﴾</span></span> فعل ماض، والفاعل مستتر، وجملة <span class="hlt"><span class="qpc-hafs">﴿أبق﴾</span></span> في محل جر بالإضافة، و<span class="hlt"><span class="qpc-hafs">﴿إلى الفلك﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أبق﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿المشحون﴾</span></span> نعت.</p></div>"
  37,141,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فساهم فكان من المدحضين﴾</span></span>: الفاء عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿ساهم﴾</span></span> فعل ماض، وفاعله ضمير مستتر تقديره: هو، <span class="hlt"><span class="qpc-hafs">﴿فكان﴾</span></span> عطف على <span class="hlt"><span class="qpc-hafs">﴿فساهم﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿كان﴾</span></span> فعل ماض ناقص ناسخ، واسمها مستتر تقديره: هو، و<span class="hlt"><span class="qpc-hafs">﴿من المدحضين﴾</span></span> جار ومجرور متعلقان بمحذوف خبر كان.</p></div>"
  37,142,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فالتقمه الحوت وهو مليم﴾</span></span>: الفاء عاطفة على محذوف يدرك من سياق الكلام، أي: فألقوه في البحر فالتقمه الحوت، وقيل: فألقى نفسه في الماء. و<span class="hlt"><span class="qpc-hafs">﴿التقمه﴾</span></span> فعل ماض، والهاء مفعول به مقدم، و<span class="hlt"><span class="qpc-hafs">﴿الحوت﴾</span></span> فاعل مؤخر، والواو للحال، و<span class="hlt"><span class="qpc-hafs">﴿هو﴾</span></span> مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿مليم﴾</span></span> خبر، والجملة في محل نصب حال.</p></div>"
  37,143,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فلولا أنه كان من المسبحين﴾</span></span>: الفاء عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿لولا﴾</span></span> حرف امتناع لوجود، و<span class="hlt"><span class="qpc-hafs">﴿أن﴾</span></span> حرف ناسخ، والهاء اسمها، و<span class="hlt"><span class="qpc-hafs">﴿كان﴾</span></span> فعل ماض ناقص، واسم <span class="hlt"><span class="qpc-hafs">﴿كان﴾</span></span> مستتر تقديره: هو، و<span class="hlt"><span class="qpc-hafs">﴿من المسبحين﴾</span></span> جار ومجرور متعلقان بمحذوف خبر <span class="hlt"><span class="qpc-hafs">﴿كان﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿كان﴾</span></span> خبر <span class="hlt"><span class="qpc-hafs">﴿أن﴾</span></span>، وأن وما في حيزها مبتدأ، والخبر محذوف وجوبًا.</p></div>"
  37,144,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿للبث في بطنه إلى يوم يبعثون﴾</span></span>: اللام واقعة في جواب لولا، و<span class="hlt"><span class="qpc-hafs">﴿لبث﴾</span></span> فعل ماض، والفاعل ضمير مستتر تقديره: هو، و<span class="hlt"><span class="qpc-hafs">﴿في بطنه﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿لبث﴾</span></span>، أو بمحذوف حال، أي: مستقرًا، و<span class="hlt"><span class="qpc-hafs">﴿إلى يوم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿لبث﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿يبعثون﴾</span></span> في محل جر مضاف إليه، و<span class="hlt"><span class="qpc-hafs">﴿يبعثون﴾</span></span> فعل مضارع مبني لما لم يسمَّ فاعله، والواو نائب فاعل.</p></div>"
  37,145,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فنبذناه بالعراء﴾</span></span>: الفاء عاطفة على محذوف، أي: أمرنا الحوت بنبذه فنبذناه، و<span class="hlt"><span class="qpc-hafs">﴿نبذناه﴾</span></span> فعل ماض، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> فاعل، والهاء مفعول به.</p><p><span class="hlt"><span class="qpc-hafs">﴿وهو سقيم﴾</span></span>: الواو حالية، و<span class="hlt"><span class="qpc-hafs">﴿هو﴾</span></span> مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿سقيم﴾</span></span> خبر.</p></div>"
  37,146,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وأنبتنا عليه شجرة من يقطين﴾</span></span>: الواو عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿أنبتنا﴾</span></span> عطف على <span class="hlt"><span class="qpc-hafs">﴿فنبذناه﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿أنبتنا﴾</span></span> فعل ماض، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> فاعل، و<span class="hlt"><span class="qpc-hafs">﴿عليه﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أنبتنا﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿شجرة﴾</span></span> مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿من يقطين﴾</span></span> جار ومجرور متعلقان بمحذوف نعت لـ<span class="hlt"><span class="qpc-hafs">﴿شجرة﴾</span></span>.</p></div>"
  37,147,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وأرسلناه إلى مائة ألف أو يزيدون﴾</span></span>: الواو حرف عطف، و<span class="hlt"><span class="qpc-hafs">﴿أرسلناه﴾</span></span> فعل ماض، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> فاعل، والهاء مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿إلى مائة ألف﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أرسلناه﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿أو﴾</span></span> حرف عطف، و<span class="hlt"><span class="qpc-hafs">﴿يزيدون﴾</span></span> فعل مضارع مرفوع.</p></div>"
  37,148,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فآمنوا فمتعناهم إلى حين﴾</span></span>: الفاء عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿آمنوا﴾</span></span> فعل ماض مبني على الضم، والواو فاعل، والفاء عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿متعناهم﴾</span></span> فعل ماض، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> فاعل، و<span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿إلى حين﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿متعناهم﴾</span></span>.</p></div>"
  37,149,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فاستفتهم ألربك البنات ولهم البنون﴾</span></span>: الفاء حرف عطف، و<span class="hlt"><span class="qpc-hafs">﴿استفتهم﴾</span></span> فعل أمر، والفاعل مستتر تقديره: أنت، و<span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> مفعول به، والهمزة للاستفهام الإنكاري، و<span class="hlt"><span class="qpc-hafs">﴿لربك﴾</span></span> جار ومجرور متعلقان بمحذوف خبر مقدم، و<span class="hlt"><span class="qpc-hafs">﴿البنات﴾</span></span> مبتدأ مؤخر، والواو حرف عطف، و<span class="hlt"><span class="qpc-hafs">﴿لهم﴾</span></span> جار ومجرور متعلقان بمحذوف خبر مقدم، و<span class="hlt"><span class="qpc-hafs">﴿البنون﴾</span></span> مبتدأ مؤخر.</p></div>"
  37,150,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿أم خلقنا الملائكة إناثا وهم شاهدون﴾</span></span>: أم حرف عطف، و<span class="hlt"><span class="qpc-hafs">﴿خلقنا﴾</span></span> فعل ماض، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> فاعل، و<span class="hlt"><span class="qpc-hafs">﴿الملائكة﴾</span></span> مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿إناثًا﴾</span></span> حال، والواو للحال، و<span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿شاهدون﴾</span></span> خبر، والجملة نصب على الحال.</p></div>"
  37,151,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ألا إنهم من إفكهم ليقولون﴾</span></span>: كلام مستأنف لا محل له من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿ألا﴾</span></span> أداة تنبيه، و<span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span> حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> اسمها، و<span class="hlt"><span class="qpc-hafs">﴿من إفكهم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يقولون﴾</span></span>، واللام المزحلقة، وجملة <span class="hlt"><span class="qpc-hafs">﴿يقولون﴾</span></span> خبر <span class="hlt"><span class="qpc-hafs">﴿إنهم﴾</span></span>، ويقولون فعل مضارع مرفوع، والواو فاعل.</p></div>"
  37,152,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ولد الله وإنهم لكاذبون﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿ولد﴾</span></span> فعل فعل ماض، و<span class="hlt"><span class="qpc-hafs">﴿الله﴾</span></span> فاعل، والجملة مقول قولهم، والواو للحال، و<span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span> حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> اسمها، واللام المزحلقة، و<span class="hlt"><span class="qpc-hafs">﴿كاذبون﴾</span></span> خبرها.</p></div>"
  37,153,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿أصطفى البنات على البنين﴾</span></span>: الهمزة المفتوحة للاستفهام الإنكاري، و<span class="hlt"><span class="qpc-hafs">﴿اصطفى﴾</span></span> فعل ماض، والفاعل مستتر تقديره: هو، يعود على الله، و<span class="hlt"><span class="qpc-hafs">﴿البنات﴾</span></span> مفعول به منصوب بالكسرة، و<span class="hlt"><span class="qpc-hafs">﴿على البنين﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿اصطفى﴾</span></span>.</p></div>"