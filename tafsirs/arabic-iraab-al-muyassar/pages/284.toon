quran[10]{c,v,t}:
  17,18,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿من كان يريد العاجلة عجلنا له فيها ما نشاء لمن نريد﴾</span></span>: من شرطية مبتدأ، وكان فعل ماض ناقص ناسخ في محل جزم فعل الشرط، وجملة <span class="hlt"><span class="qpc-hafs">﴿يريد العاجلة﴾</span></span> خبر كان، و<span class="hlt"><span class="qpc-hafs">﴿عجلنا﴾</span></span> فعل وفاعل، وهو في محل جزم جواب الشرط، و<span class="hlt"><span class="qpc-hafs">﴿له﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿عجلنا﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿فيها﴾</span></span> جار ومجرور متعلقان بمحذوف حال، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> موصول مفعول به، وجملة نشاء صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> لا محل لها من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿لمن﴾</span></span> الجار والمجرور بدل من <span class="hlt"><span class="qpc-hafs">﴿له﴾</span></span> بإعادة العامل، وجملة <span class="hlt"><span class="qpc-hafs">﴿نريد﴾</span></span> صلة <span class="hlt"><span class="qpc-hafs">﴿من﴾</span></span> لا محل لها من الإعراب، ومفعول نريد محذوف، أي: لمن نريد تعجيله، وفعل الشرط وجوابه خبر <span class="hlt"><span class="qpc-hafs">﴿مَن﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿ثم جعلنا له جهنم يصلاها مذموما مدحورا﴾</span></span>: ثم حرف عطف للتراخي، وجعلنا فعل وفاعل، و<span class="hlt"><span class="qpc-hafs">﴿له﴾</span></span> جار ومجرور متعلقان بمحذوف مفعول جعلنا الثاني، وجهنم مفعول جعلنا الأول، وجملة <span class="hlt"><span class="qpc-hafs">﴿يصلاها﴾</span></span> حال من الضمير في <span class="hlt"><span class="qpc-hafs">﴿له﴾</span></span>، ومذمومًا حال من الضمير في <span class="hlt"><span class="qpc-hafs">﴿يصلاها﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿مدحورًا﴾</span></span> حال أيضا.</p></div>"
  17,19,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ومن أراد الآخرة وسعى لها سعيها﴾</span></span>: الواو عاطفة، والجملة معطوفة على سابقتها، و<span class="hlt"><span class="qpc-hafs">﴿سعى لها﴾</span></span> عطف على <span class="hlt"><span class="qpc-hafs">﴿أراد﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿سعيها﴾</span></span> مفعول مطلق، وقيل: مفعول به لأن المعنى: وعمل لها عملها.</p><p><span class="hlt"><span class="qpc-hafs">﴿وهو مؤمن﴾</span></span>: الواو حالية، و<span class="hlt"><span class="qpc-hafs">﴿هو﴾</span></span> مبتدأ، ومؤمن خبر، والجملة نصب على الحال من الضمير في <span class="hlt"><span class="qpc-hafs">﴿سعى﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿فأولئك كان سعيهم مشكورا﴾</span></span>: الفاء رابطة لجواب مَن، وأولئك اسم إشارة مبتدأ، وكان فعل ماض ناقص ناسخ، وسعيهم اسمها، ومشكورا خبرها، والجملة خبر أولئك، وجملة <span class="hlt"><span class="qpc-hafs">﴿أولئك كان...﴾</span></span> إلخ في محل جزم جواب الشرط.</p></div>"
  17,20,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿كلا نمد هؤلاء وهؤلاء من عطاء ربك﴾</span></span>: كلًّا مفعول به مقدم لـ<span class="hlt"><span class="qpc-hafs">﴿نمد﴾</span></span>، وفاعل <span class="hlt"><span class="qpc-hafs">﴿نمد﴾</span></span> مستتر تقديره: نحن، وهؤلاء بدل من <span class="hlt"><span class="qpc-hafs">﴿كلًّا﴾</span></span>، وهؤلاء عطف على هؤلاء الأولى، و<span class="hlt"><span class="qpc-hafs">﴿من عطاء ربك﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿نمد﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿وما كان عطاء ربك محظورا﴾</span></span>: الواو عاطفة، أو حالية، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> نافية، وكان فعل ماض ناقص ناسخ، وعطاء اسمها، ومحظورا خبرها.</p></div>"
  17,21,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿انظر كيف فضلنا بعضهم على بعض﴾</span></span>: انظر فعل أمر، والفاعل مستتر، وكيف اسم استفهام في محل نصب على الحال، وفضلنا فعل وفاعل، وبعضهم مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿على بعض﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿فضلنا﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿وللآخرة أكبر درجات وأكبر تفضيلا﴾</span></span>: الواو للحال، واللام للابتداء، والآخرة مبتدأ، وأكبر خبر، ودرجات تمييز نصب بالكسرة، لأنه جمع مؤنث سالم، وأكبر عطف على أكبر الأولى، وتفضيلًا تمييز.</p></div>"
  17,22,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿لا تجعل مع الله إلها آخر فتقعد مذموما مخذولا﴾</span></span>: لا ناهية، وتجعل فعل مضارع مجزوم بلا الناهية، وفاعله ضمير مستتر تقديره: أنت، و<span class="hlt"><span class="qpc-hafs">﴿مع الله﴾</span></span> ظرف متعلق بمحذوف مفعول تجعل الثاني، وإلهًا مفعول تجعل الأول، وآخر صفة، <span class="hlt"><span class="qpc-hafs">﴿فتقعد﴾</span></span> الفاء فاء السببية، وتقعد فعل مضارع منصوب بأن مضمرة بعد فاء السببية، والمصدر المؤول من أن والفعل معطوف على مصدر مفهوم من الكلام السابق، أي: لا يكن منك جَعْلٌ فقعودٌ. والفاعل مستتر تقديره: أنت، ومذمومًا حال، ومخذولًا حال ثانية.</p></div>"
  17,23,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وقضى ربك ألا تعبدوا إلا إياه وبالوالدين إحسانا﴾</span></span>: الواو استئنافية، والجملة مستأنفة لا محل لها من الإعراب، وقضى ربك فعل وفاعل، و<span class="hlt"><span class="qpc-hafs">﴿ألّا﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿أن﴾</span></span> مصدرية و<span class="hlt"><span class="qpc-hafs">﴿لا﴾</span></span> نافية، و<span class="hlt"><span class="qpc-hafs">﴿تعبدوا﴾</span></span> مضارع منصوب بـ<span class="hlt"><span class="qpc-hafs">﴿أن﴾</span></span> وعلامة نصبه حذف النون، والواو فاعل، والمصدر المؤول من <span class="hlt"><span class="qpc-hafs">﴿أن﴾</span></span> المصدرية وما دخلت عليه منصوب بنزع الخافض، والجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿قضى﴾</span></span>. وجملة <span class="hlt"><span class="qpc-hafs">﴿لا تعبدوا﴾</span></span> صلة <span class="hlt"><span class="qpc-hafs">﴿أن﴾</span></span> المصدرية لا محل لها من الإعراب. أو <span class="hlt"><span class="qpc-hafs">﴿أن﴾</span></span> تفسيرية، لتضمن <span class="hlt"><span class="qpc-hafs">﴿قضى﴾</span></span> معنى قال، والجملة بعدها تفسيرية لا محل لها من الإعراب. و<span class="hlt"><span class="qpc-hafs">﴿لا﴾</span></span> ناهية، و<span class="hlt"><span class="qpc-hafs">﴿تعبدوا﴾</span></span> مضارع مجزوم بـ<span class="hlt"><span class="qpc-hafs">﴿لا﴾</span></span> وعلامة جزمه حذف النون، والواو فاعل. و<span class="hlt"><span class="qpc-hafs">﴿إلا﴾</span></span> أداة حصر، و<span class="hlt"><span class="qpc-hafs">﴿إياه﴾</span></span> مفعول، و<span class="hlt"><span class="qpc-hafs">﴿بالوالدين﴾</span></span> جار ومجرور متعلقان بفعل محذوف تقديره: وأحسنوا، و<span class="hlt"><span class="qpc-hafs">﴿إحسانًا﴾</span></span> مفعول مطلق لفعل محذوف.</p><p><span class="hlt"><span class="qpc-hafs">﴿إما يبلغن عندك الكبر أحدهما أو كلاهما﴾</span></span>: إن شرطية، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> للتأكيد، ويبلغن فعل مضارع مبني على الفتح لاتصاله بنون التوكيد الثقيلة في محل جزم فعل الشرط، و<span class="hlt"><span class="qpc-hafs">﴿عندك﴾</span></span> ظرف متعلق بمحذوف حال، وأحدهما فاعل <span class="hlt"><span class="qpc-hafs">﴿يبلغن﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿أو﴾</span></span> حرف عطف، و<span class="hlt"><span class="qpc-hafs">﴿كلاهما﴾</span></span> عطف على <span class="hlt"><span class="qpc-hafs">﴿أحدهما﴾</span></span> وعلامة رفعه الألف، لأنه ملحق بالمثنى.</p><p><span class="hlt"><span class="qpc-hafs">﴿فلا تقل لهما أف ولا تنهرهما وقل لهما قولا كريما﴾</span></span>: الفاء رابطة للجواب، و<span class="hlt"><span class="qpc-hafs">﴿لا﴾</span></span> ناهية، و<span class="hlt"><span class="qpc-hafs">﴿تقل﴾</span></span> فعل مضارع مجزوم بـ<span class="hlt"><span class="qpc-hafs">﴿لا﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿لهما﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تقل﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿أف﴾</span></span> اسم فعل مضارع بمعنى التضجر، وفاعله مستتر تقديره: أنا، والجملة مقول القول، <span class="hlt"><span class="qpc-hafs">﴿ولا تنهرهما﴾</span></span> عطف على <span class="hlt"><span class="qpc-hafs">﴿لا تقل لهما﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿قل﴾</span></span> فعل أمر، وفاعله مستتر تقديره: أنت، و<span class="hlt"><span class="qpc-hafs">﴿لهما﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿قل﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿قولًا﴾</span></span> مفعول به، أو مفعول مطلق منصوب بالفتحة، و<span class="hlt"><span class="qpc-hafs">﴿كريمًا﴾</span></span> صفة.</p></div>"
  17,24,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿واخفض لهما جناح الذل من الرحمة﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿واخفض لهما﴾</span></span> عطف على <span class="hlt"><span class="qpc-hafs">﴿وقل لهما﴾</span></span>، وجناح الذل مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿من الرحمة﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿اخفض﴾</span></span>، أو متعلقان بمحذوف حال.</p><p><span class="hlt"><span class="qpc-hafs">﴿وقل رب ارحمهما كما ربياني صغيرا﴾</span></span>: الواو عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿قل﴾</span></span> عطف على ما تقدم، و<span class="hlt"><span class="qpc-hafs">﴿رب﴾</span></span> منادى مضاف لياء المتكلم محذوف منه حرف النداء، و<span class="hlt"><span class="qpc-hafs">﴿ارحمهما﴾</span></span> فعل دعاء، و<span class="hlt"><span class="qpc-hafs">﴿كما﴾</span></span> الكاف اسم بمعنى مثل مبني على الفتح في محل نصب صفة لمصدر محذوف، أي: ارحمهما رحمة مثل تربيتهما لي، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> مصدرية، و<span class="hlt"><span class="qpc-hafs">﴿ربياني﴾</span></span> فعل ماض، وألف الاثنين فاعل، والنون للوقاية، والياء مفعول به، والمصدر المؤول من <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> والفعل مضاف إليه، وصغيرًا حال من الياء.</p></div>"
  17,25,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ربكم أعلم بما في نفوسكم﴾</span></span>: ربكم مبتدأ، وأعلم خبر، و<span class="hlt"><span class="qpc-hafs">﴿بما﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أعلم﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿في نفوسكم﴾</span></span> جار ومجرور متعلقان بمحذوف صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> لا محل لها من الإعراب.</p><p><span class="hlt"><span class="qpc-hafs">﴿إن تكونوا صالحين فإنه كان للأوابين غفورا﴾</span></span>: الجملة حالية، وإن شرطية، وتكونوا فعل مضارع ناقص ناسخ وهو فعل الشرط، والواو اسمها، وصالحين خبرها، والفاء رابطة للجواب، وإن حرف ناسخ، والهاء اسمها، وجملة <span class="hlt"><span class="qpc-hafs">﴿كان﴾</span></span> خبرها، وللأوابين جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿غفورًا﴾</span></span>، وغفورًا خبر كان.</p></div>"
  17,26,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وآت ذا القربى حقه والمسكين وابن السبيل ولا تبذر تبذيرا﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿آت﴾</span></span> فعل أمر، وفاعل مستتر تقديره: أنت، و<span class="hlt"><span class="qpc-hafs">﴿ذا القربى﴾</span></span> مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿حقه﴾</span></span> مفعول به ثان، والمسكين وابن السبيل عطف على <span class="hlt"><span class="qpc-hafs">﴿ذا القربى﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿لا﴾</span></span> ناهية، وتبذر فعل مضارع مجزوم بـ<span class="hlt"><span class="qpc-hafs">﴿لا﴾</span></span>، وتبذيرًا مفعول مطلق.</p></div>"
  17,27,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إن المبذرين كانوا إخوان الشياطين﴾</span></span>: إن حرف ناسخ، والمبذرين اسمها، وكانوا فعل ماض ناقص ناسخ، والواو اسمها، وإخوان الشياطين خبر كان، وجملة كانوا خبر إن.</p><p><span class="hlt"><span class="qpc-hafs">﴿وكان الشيطان لربه كفورا﴾</span></span>: الواو عاطفة، أو حالية، وكان فعل ماض ناقص ناسخ، والشيطان اسمها، و<span class="hlt"><span class="qpc-hafs">﴿لربه﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿كفورًا﴾</span></span>، وكفورًا خبر كان، ولا بد من تقدير مضاف، أي: لنعم ربه وآلائه.</p></div>"