quran[20]{c,v,t}:
  44,40,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إن يوم الفصل ميقاتهم أجمعين﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span> حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿يوم﴾</span></span> اسمها، و<span class="hlt"><span class="qpc-hafs">﴿الفصل﴾</span></span> مضاف إليه، و<span class="hlt"><span class="qpc-hafs">﴿ميقاتهم﴾</span></span> خبر إن، و<span class="hlt"><span class="qpc-hafs">﴿أجمعين﴾</span></span> تأكيد للضمير، أي: للناس جميعًا.</p></div>"
  44,41,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿يوم لا يغني مولى عن مولى شيئا﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿يوم﴾</span></span> بدل من <span class="hlt"><span class="qpc-hafs">﴿يوم الفصل﴾</span></span>، أو ظرف لما دل عليه الفصل، أي: يفصل بينهم يوم لا يغني، و<span class="hlt"><span class="qpc-hafs">﴿لا﴾</span></span> نافية، و<span class="hlt"><span class="qpc-hafs">﴿يغني﴾</span></span> فعل مضارع مرفوع، و<span class="hlt"><span class="qpc-hafs">﴿مولى﴾</span></span> فاعل، و<span class="hlt"><span class="qpc-hafs">﴿عن مولى﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يغني﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿شيئًا﴾</span></span> مفعول به، أو نائب عن المفعول المطلق، أي: إغناء قليلا أو كثيرا، وجملة <span class="hlt"><span class="qpc-hafs">﴿لا يغني﴾</span></span> في محل جر بإضافة الظرف إليها.</p><p><span class="hlt"><span class="qpc-hafs">﴿ولا هم ينصرون﴾</span></span>: الواو حرف عطف، و<span class="hlt"><span class="qpc-hafs">﴿لا﴾</span></span> نافية، و<span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿ينصرون﴾</span></span> فعل مضارع مبني لما لم يسمَّ فاعله، والواو نائب فاعل، وجملة <span class="hlt"><span class="qpc-hafs">﴿ينصرون﴾</span></span> خبر.</p></div>"
  44,42,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إلا من رحم الله﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿إلا﴾</span></span> أداة حصر، و<span class="hlt"><span class="qpc-hafs">﴿مَن﴾</span></span> في محل رفع بدل من الواو في <span class="hlt"><span class="qpc-hafs">﴿ينصرون﴾</span></span>، أو منصوب على الاستثناء، أي: ولكن من رحم الله لا ينالهم ما يحتاجون فيه إلى من ينفعهم من المخلوقين، أو الاستثناء متصل تقديره: لا يغني قريب عن قريب إلا المؤمنين، وجملة <span class="hlt"><span class="qpc-hafs">﴿رحم الله﴾</span></span> فعل وفاعل صلة الموصول.</p><p><span class="hlt"><span class="qpc-hafs">﴿إنه هو العزيز الرحيم﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span> حرف ناسخ، والهاء اسمها، و<span class="hlt"><span class="qpc-hafs">﴿هو﴾</span></span> مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿العزيز الرحيم﴾</span></span> خبران لـ<span class="hlt"><span class="qpc-hafs">﴿هو﴾</span></span>، والجملة خبر إن، أو <span class="hlt"><span class="qpc-hafs">﴿هو﴾</span></span> ضمير فصل، و<span class="hlt"><span class="qpc-hafs">﴿العزيز الرحيم﴾</span></span> خبران لـ<span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span>.</p></div>"
  44,43,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إن شجرة الزقوم﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span> حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿شجرة﴾</span></span> اسمها، و<span class="hlt"><span class="qpc-hafs">﴿الزقوم﴾</span></span> مضاف إليه.</p></div>"
  44,44,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿طعام الأثيم﴾</span></span>: خبر المبتدأ في الآية السابقة.</p></div>"
  44,45,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿كالمهل يغلي في البطون﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿كالمهل﴾</span></span> الكاف اسم بمعنى مثل مبني على الفتح في محل نصب خبر ثان لـ<span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿المهل﴾</span></span> مضاف إليه، و<span class="hlt"><span class="qpc-hafs">﴿يغلي﴾</span></span> فعل مضارع مرفوع، والفاعل مستتر تقديره: هو، وجملة <span class="hlt"><span class="qpc-hafs">﴿يغلي﴾</span></span> حال من <span class="hlt"><span class="qpc-hafs">﴿الزقوم﴾</span></span>، أو من <span class="hlt"><span class="qpc-hafs">﴿طعام الأثيم﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿في البطون﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يغلي﴾</span></span>.</p></div>"
  44,46,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿كغلي الحميم﴾</span></span>: الكاف اسم بمعنى مثل مبني على الفتح في محل نصب صفة لمصدر محذوف، أي: تغلي غليانًا مثل غليان الحميم، و<span class="hlt"><span class="qpc-hafs">﴿غلي﴾</span></span> مضاف إليه، و<span class="hlt"><span class="qpc-hafs">﴿الحميم﴾</span></span> مضاف إليه.</p></div>"
  44,47,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿خذوه﴾</span></span>: فعل أمر مبني على حذف النون، والواو فاعله، والهاء مفعوله، والجملة مقول قول محذوف.</p><p><span class="hlt"><span class="qpc-hafs">﴿فاعتلوه﴾</span></span>: فعل أمر عطف على <span class="hlt"><span class="qpc-hafs">﴿خذوه﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿إلى سواء الجحيم﴾</span></span>: الجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿اعتلوه﴾</span></span>.</p></div>"
  44,48,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ثم صبوا﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿ثم﴾</span></span> حرف عطف للترتيب مع التراخي، و<span class="hlt"><span class="qpc-hafs">﴿صبوا﴾</span></span> فعل أمر، والواو فاعل.</p><p><span class="hlt"><span class="qpc-hafs">﴿فوق رأسه من عذاب الحميم﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿فوق رأسه﴾</span></span> ظرف متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿صبوا﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿من﴾</span></span> حرف صلة، و<span class="hlt"><span class="qpc-hafs">﴿عذاب الحميم﴾</span></span> مجرور لفظا منصوب محلا مفعول به.</p></div>"
  44,49,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ذق إنك أنت العزيز الكريم﴾</span></span>: الجملة مقول قول محذوف، أي: ويقال له: ذق، و<span class="hlt"><span class="qpc-hafs">﴿ذق﴾</span></span> فعل أمر، وفاعله مستتر تقديره: أنت، و<span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span> حرف ناسخ، والكاف اسمها، و<span class="hlt"><span class="qpc-hafs">﴿أنت﴾</span></span> مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿العزيز الكريم﴾</span></span> خبران لـ<span class="hlt"><span class="qpc-hafs">﴿أنت﴾</span></span>، والجملة الاسمية خبر <span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span>، أو <span class="hlt"><span class="qpc-hafs">﴿أنت﴾</span></span> ضمير فصل، و<span class="hlt"><span class="qpc-hafs">﴿العزيز الكريم﴾</span></span> خبران لـ<span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿إنك أنت العزيز الكريم﴾</span></span> تعليلية.</p></div>"
  44,50,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إن هذا ما كنتم به تمترون﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span> حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿هذا﴾</span></span> اسمها، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> خبرها، وكنتم فعل ماض ناقص ناسخ، والتاء اسمها، و<span class="hlt"><span class="qpc-hafs">﴿به﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تمترون﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿تمترون﴾</span></span> فعل مضارع والواو فاعل، وجملة <span class="hlt"><span class="qpc-hafs">﴿تمترون﴾</span></span> خبر <span class="hlt"><span class="qpc-hafs">﴿كنتم﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿كنتم﴾</span></span> صلة الموصول لا محل لها من الإعراب.</p></div>"
  44,51,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إن المتقين في مقام أمين﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span> حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿المتقين﴾</span></span> اسمها، و<span class="hlt"><span class="qpc-hafs">﴿في مقام﴾</span></span> جار ومجرور متعلقان بمحذوف خبرها، و<span class="hlt"><span class="qpc-hafs">﴿أمين﴾</span></span> نعت لـ<span class="hlt"><span class="qpc-hafs">﴿مقام﴾</span></span>.</p></div>"
  44,52,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿في جنات وعيون﴾</span></span>: الجار والمجرور بدل من <span class="hlt"><span class="qpc-hafs">﴿في مقام﴾</span></span> بإعادة الجار.</p></div>"
  44,53,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿يلبسون من سندس وإستبرق متقابلين﴾</span></span>: الجملة خبر ثان لـ<span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿يلبسون﴾</span></span> فعل مضارع مرفوع، والواو فاعل، و<span class="hlt"><span class="qpc-hafs">﴿من سندس﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يلبسون﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿متقابلين﴾</span></span> حال من الضمير في <span class="hlt"><span class="qpc-hafs">﴿يلبسون﴾</span></span>.</p></div>"
  44,54,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿كذلك وزوجناهم بحور عين﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿كذلك﴾</span></span> جار ومجرور متعلقان بمحذوف خبر لمبتدأ محذوف، أي: الأمر كذلك، وهذه الجملة اعتراضية بين المعطوف والمعطوف عليه، لا محل لها من الإعراب، جيء بها للتقرير، و<span class="hlt"><span class="qpc-hafs">﴿زوجناهم﴾</span></span> فعل ماض وفاعل ومفعول به، عطف على <span class="hlt"><span class="qpc-hafs">﴿يلبسون﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿بحور﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿زوجناهم﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿عين﴾</span></span> نعت لـ<span class="hlt"><span class="qpc-hafs">﴿حور﴾</span></span>.</p></div>"
  44,55,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿يدعون فيها بكل فاكهة آمنين﴾</span></span>: الجملة حال من الهاء في <span class="hlt"><span class="qpc-hafs">﴿زوجناهم﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿يدعون﴾</span></span> فعل مضارع مرفوع بثبوت النون، والواو فاعل، و<span class="hlt"><span class="qpc-hafs">﴿فيها﴾</span></span> جار ومجرور متعلقان بمحذوف حال، و<span class="hlt"><span class="qpc-hafs">﴿بكل﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يدعون﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿آمنين﴾</span></span> حال، أي: لا يخافون من مغبة أكلها.</p></div>"
  44,56,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿لا يذوقون فيها الموت إلا الموتة الأولى﴾</span></span>: الجملة حال من الضمير في <span class="hlt"><span class="qpc-hafs">﴿آمنين﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿لا﴾</span></span> نافية، و<span class="hlt"><span class="qpc-hafs">﴿يذوقون﴾</span></span> فعل مضارع مرفوع بثبوت النون، والواو فاعل، و<span class="hlt"><span class="qpc-hafs">﴿فيها﴾</span></span> جار ومجرور متعلقان بمحذوف حال، و<span class="hlt"><span class="qpc-hafs">﴿الموت﴾</span></span> مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿إلا﴾</span></span> أداة استثناء، و<span class="hlt"><span class="qpc-hafs">﴿الموتة﴾</span></span> مستثنى من <span class="hlt"><span class="qpc-hafs">﴿الموت﴾</span></span> على أنه استثناء منقطع، و<span class="hlt"><span class="qpc-hafs">﴿الأولى﴾</span></span> صفة.</p><p><span class="hlt"><span class="qpc-hafs">﴿ووقاهم عذاب الجحيم﴾</span></span>: الواو عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿وقاهم﴾</span></span> فعل ماض، والفاعل مستتر يعود على الله، و<span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿عذاب الجحيم﴾</span></span> مفعول به ثان.</p></div>"
  44,57,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فضلا﴾</span></span>: نائب مفعول مطلق، أي: تفضَّل فَضْلا وهو اسم مصدر، أو: مفعول من أجله.</p><p><span class="hlt"><span class="qpc-hafs">﴿من ربك﴾</span></span>: جار ومجرور متعلقان بمحذوف صفة لـ<span class="hlt"><span class="qpc-hafs">﴿فضلًا﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿ذلك﴾</span></span>: مبتدأ.</p><p><span class="hlt"><span class="qpc-hafs">﴿هو﴾</span></span>: ضمير فصل.</p><p><span class="hlt"><span class="qpc-hafs">﴿الفوز﴾</span></span>: خبر.</p><p><span class="hlt"><span class="qpc-hafs">﴿العظيم﴾</span></span>: نعت للفوز، أو <span class="hlt"><span class="qpc-hafs">﴿هو﴾</span></span> مبتدأ ثان، و<span class="hlt"><span class="qpc-hafs">﴿الفوز﴾</span></span> خبره، والجملة الاسمية خبر <span class="hlt"><span class="qpc-hafs">﴿ذلك﴾</span></span>.</p></div>"
  44,58,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فإنما يسرناه بلسانك﴾</span></span>: الفاء الفصيحة، و<span class="hlt"><span class="qpc-hafs">﴿إنما﴾</span></span> كافة ومكفوفة، و<span class="hlt"><span class="qpc-hafs">﴿يسرناه﴾</span></span> فعل ماض، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> فاعل، والهاء مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿بلسانك﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يسرناه﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿لعلهم يتذكرون﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿لعل﴾</span></span> حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> اسمها، و<span class="hlt"><span class="qpc-hafs">﴿يتذكرون﴾</span></span> فعل مضارع مرفوع، والواو فاعل، وجملة <span class="hlt"><span class="qpc-hafs">﴿يتذكرون﴾</span></span> خبر <span class="hlt"><span class="qpc-hafs">﴿لعل﴾</span></span>.</p></div>"
  44,59,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فارتقب إنهم مرتقبون﴾</span></span>: الفاء الفصيحة، و<span class="hlt"><span class="qpc-hafs">﴿ارتقب﴾</span></span> فعل أمر، وفاعله مستتر تقديره: أنت، ومفعوله محذوف تقديره: هلاكهم، و<span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span> حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> اسمها، و<span class="hlt"><span class="qpc-hafs">﴿مرتقبون﴾</span></span> خبرها، ومفعول <span class="hlt"><span class="qpc-hafs">﴿مرتقبون﴾</span></span> محذوف أيضًا تقديره: هلاكك، وجملة <span class="hlt"><span class="qpc-hafs">﴿إنهم مرتقبون﴾</span></span> تعليلية للأمر بالانتظار.</p></div>"