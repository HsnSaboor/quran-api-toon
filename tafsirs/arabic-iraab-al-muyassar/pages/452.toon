quran[29]{c,v,t}:
  37,154,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ما لكم﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> اسم استفهام في محل رفع مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿لكم﴾</span></span> جار ومجرور متعلقان بمحذوف خبر، والتقدير: ما ثبت واستقر لكم، وهو استفهام إنكاري، والجملة مستأنفة لا محل لها من الإعراب.</p><p><span class="hlt"><span class="qpc-hafs">﴿كيف تحكمون﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿كيف﴾</span></span> اسم استفهام في محل نصب على الحال، وهو استفهام إنكار وتعجيب من حكمهم، و<span class="hlt"><span class="qpc-hafs">﴿تحكمون﴾</span></span> فعل مضارع، وواو الجماعة فاعل، والجملة مستأنفة لا محل لها من الإعراب.</p></div>"
  37,155,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿أفلا تذكرون﴾</span></span>: الهمزة للاستفهام الإنكاري، والفاء عاطفة على محذوف مفهوم من السياق، أي: أعميتم عن الحقائق وضللتم عن الشواهد، و<span class="hlt"><span class="qpc-hafs">﴿لا﴾</span></span> نافية، و<span class="hlt"><span class="qpc-hafs">﴿تذكرون﴾</span></span> فعل مضارع مرفوع، والواو فاعل.</p></div>"
  37,156,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿أم لكم سلطان مبين﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿أم﴾</span></span> حرف عطف للإضراب الانتقالي، و<span class="hlt"><span class="qpc-hafs">﴿لكم﴾</span></span> جار ومجرور متعلقان بمحذوف خبر مقدم، و<span class="hlt"><span class="qpc-hafs">﴿سلطان﴾</span></span> مبتدأ مؤخر، و<span class="hlt"><span class="qpc-hafs">﴿مبين﴾</span></span> نعت لـ<span class="hlt"><span class="qpc-hafs">﴿سلطان﴾</span></span>.</p></div>"
  37,157,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فأتوا بكتابكم إن كنتم صادقين﴾</span></span>: الفاء الفصيحة، و<span class="hlt"><span class="qpc-hafs">﴿ائتوا﴾</span></span> فعل أمر مبني على حذف النون، والواو فاعل، و<span class="hlt"><span class="qpc-hafs">﴿بكتابكم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿ائتوا﴾</span></span>، وإن شرطية، و<span class="hlt"><span class="qpc-hafs">﴿كنتم﴾</span></span> فعل ماض ناقص ناسخ، والتاء اسمها، و<span class="hlt"><span class="qpc-hafs">﴿صادقين﴾</span></span> خبرها، وجواب الشرط محذوف دل عليه ما قبله.</p></div>"
  37,158,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وجعلوا بينه وبين الجنة نسبا﴾</span></span>: الواو استئنافية، و<span class="hlt"><span class="qpc-hafs">﴿جعلوا﴾</span></span> فعل ماض، والواو فاعل، و<span class="hlt"><span class="qpc-hafs">﴿بينه﴾</span></span> ظرف متعلق بمحذوف مفعول به ثان لـ<span class="hlt"><span class="qpc-hafs">﴿جعلوا﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿بين الجنة﴾</span></span> عطف، و<span class="hlt"><span class="qpc-hafs">﴿نسبًا﴾</span></span> مفعول <span class="hlt"><span class="qpc-hafs">﴿جعلوا﴾</span></span> الأول، وجملة <span class="hlt"><span class="qpc-hafs">﴿وجعلوا...﴾</span></span> مستأنفة لا محل لها من الإعراب.</p><p><span class="hlt"><span class="qpc-hafs">﴿ولقد علمت الجنة إنهم لمحضرون﴾</span></span>: الواو حالية، واللام جواب للقسم المحذوف، و<span class="hlt"><span class="qpc-hafs">﴿قد﴾</span></span> حرف تحقيق، و<span class="hlt"><span class="qpc-hafs">﴿علمت﴾</span></span> فعل ماض، و<span class="hlt"><span class="qpc-hafs">﴿الجنة﴾</span></span> فاعل، و<span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span> حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> اسمها، واللام المزحلقة، و<span class="hlt"><span class="qpc-hafs">﴿محضرون﴾</span></span> خبرها، وإن وما في حيزها سدت مسد مفعولي <span class="hlt"><span class="qpc-hafs">﴿علمت﴾</span></span>.</p></div>"
  37,159,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿سبحان الله عما يصفون﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿سبحان﴾</span></span>: نائب مفعول مطلق منصوب بفعل محذوف. ولفظ الجلالة: مضاف إليه. و<span class="hlt"><span class="qpc-hafs">﴿عما﴾</span></span>: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿سبحان﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿يصفون﴾</span></span>: فعل مضارع، والواو فاعل، وجملة <span class="hlt"><span class="qpc-hafs">﴿يصفون﴾</span></span> صلة الموصول لا محل لها من الإعراب. والعائد محذوف. وجملة <span class="hlt"><span class="qpc-hafs">﴿سبحان الله...﴾</span></span> اعتراضية، لا محل لها من الإعراب.</p></div>"
  37,160,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إلا عباد الله المخلصين﴾</span></span>:  <span class="hlt"><span class="qpc-hafs">﴿إلا﴾</span></span> أداة استثناء بمعنى لكن، و<span class="hlt"><span class="qpc-hafs">﴿عباد الله﴾</span></span> مستثنى من الواو في <span class="hlt"><span class="qpc-hafs">﴿تجزون﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿المخلصين﴾</span></span> صفة لـ<span class="hlt"><span class="qpc-hafs">﴿عباد الله﴾</span></span>.</p></div>"
  37,161,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فإنكم وما تعبدون﴾</span></span>: الفاء تعليلية، و<span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span> حرف ناسخ والكاف اسمها، والواو واو المعية، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> موصولة مفعول معه، و<span class="hlt"><span class="qpc-hafs">﴿تعبدون﴾</span></span> فعل مضارع مرفوع، والواو فاعل، وجملة <span class="hlt"><span class="qpc-hafs">﴿تعبدون﴾</span></span> صلة الموصول لا محل لها من الإعراب، أو <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> معطوفة على اسم إن، وخبر إن جملة <span class="hlt"><span class="qpc-hafs">﴿ما أنتم﴾</span></span> في الآية التالية.</p></div>"
  37,162,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ما أنتم عليه بفاتنين﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> نافية حجازية تعمل عمل ليس، و<span class="hlt"><span class="qpc-hafs">﴿أنتم﴾</span></span> اسم ما، و<span class="hlt"><span class="qpc-hafs">﴿عليه﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿فاتنين﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿بفاتنين﴾</span></span>: الباء حرف جر صلة، و<span class="hlt"><span class="qpc-hafs">﴿فاتنين﴾</span></span> خبر <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> الحجازية منصوب محلا مجرور بالباء لفظًا، وجملة <span class="hlt"><span class="qpc-hafs">﴿ما أنتم...﴾</span></span> خبر <span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span> في الآية السابقة.</p></div>"
  37,163,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إلا من هو صال الجحيم﴾</span></span>: إلا أداة حصر، و<span class="hlt"><span class="qpc-hafs">﴿من﴾</span></span> مفعول فاتنين، والاستثناء مفرغ، أو مفعول فاتنين محذوف، أي أحدًا، فتكون إلا أداة استثناء، و<span class="hlt"><span class="qpc-hafs">﴿مَن﴾</span></span> مستثنى من المفعول المحذوف، و<span class="hlt"><span class="qpc-hafs">﴿هو﴾</span></span> مبتدأ، وصال خبر مرفوع بالضمة المقدرة على الياء المحذوفة لالتقاء الساكنين، والجحيم مضاف إليه، وجملة <span class="hlt"><span class="qpc-hafs">﴿هو صال الجحيم﴾</span></span> صلة الموصول لا محل لها من الإعراب.</p></div>"
  37,164,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وما منا إلا له مقام معلوم﴾</span></span>: الواو استئنافية، وما نافية، ومنا خبر مقدم، والمبتدأ محذوف، أقيمت صفته مقامه، والتقدير: وما منا أحد إلا له مقام معلوم، أو منا صفة لمحذوف هو المبتدأ، والخبر جملة <span class="hlt"><span class="qpc-hafs">﴿إلا له مقام معلوم﴾</span></span> وإلا أداة حصر، وله خبر مقدم، ومقام مبتدأ مؤخر، ومعلوم صفة، وجملة <span class="hlt"><span class="qpc-hafs">﴿وما منا إلا...﴾</span></span> مستأنفة لا محل لها من الإعراب.</p></div>"
  37,165,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وإنا لنحن الصافون﴾</span></span>: الواو عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span> حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> اسمها، واللام المزحلقة، و<span class="hlt"><span class="qpc-hafs">﴿نحن﴾</span></span> مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿الصافون﴾</span></span> خبر <span class="hlt"><span class="qpc-hafs">﴿نحن﴾</span></span>، والجملة الاسمية خبر <span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span>، أو <span class="hlt"><span class="qpc-hafs">﴿نحن﴾</span></span> ضمير فصل، و<span class="hlt"><span class="qpc-hafs">﴿الصافون﴾</span></span> خبر <span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span>، ومفعول <span class="hlt"><span class="qpc-hafs">﴿الصافون﴾</span></span> محذوف، أي: نصف أقدامنا.</p></div>"
  37,166,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وإنا لنحن المسبحون﴾</span></span>: الواو عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span> حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> اسمها، واللام المزحلقة، و<span class="hlt"><span class="qpc-hafs">﴿نحن﴾</span></span> مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿المسبحون﴾</span></span> خبر <span class="hlt"><span class="qpc-hafs">﴿نحن﴾</span></span>، والجملة الاسمية خبر <span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span>، أو <span class="hlt"><span class="qpc-hafs">﴿نحن﴾</span></span> ضمير فصل، و<span class="hlt"><span class="qpc-hafs">﴿المسبحون﴾</span></span> خبر <span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span>.</p></div>"
  37,167,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وإن كانوا ليقولون﴾</span></span>: الواو عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span> مخففة من الثقيلة مهملة، و<span class="hlt"><span class="qpc-hafs">﴿كانوا﴾</span></span> فعل ماض ناقص ناسخ، والواو اسمها، واللام الفارقة، و<span class="hlt"><span class="qpc-hafs">﴿يقولون﴾</span></span> فعل مضارع مرفوع، والواو فاعل، وجملة <span class="hlt"><span class="qpc-hafs">﴿يقولون﴾</span></span> خبر <span class="hlt"><span class="qpc-hafs">﴿كانوا﴾</span></span>.</p></div>"
  37,168,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿لو أن عندنا ذكرا من الأولين﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿لو﴾</span></span> شرطية، و<span class="hlt"><span class="qpc-hafs">﴿أن﴾</span></span> حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿عندنا﴾</span></span> ظرف متعلق بمحذوف خبر <span class="hlt"><span class="qpc-hafs">﴿أن﴾</span></span> المقدم، و<span class="hlt"><span class="qpc-hafs">﴿ذكرا﴾</span></span> اسم أن، وأن وما في حيزها فاعل لفعل محذوف، أي: ثبت، و<span class="hlt"><span class="qpc-hafs">﴿من الأولين﴾</span></span> جار ومجرور متعلقان بمحذوف نعت لـ<span class="hlt"><span class="qpc-hafs">﴿ذكرًا﴾</span></span>.</p></div>"
  37,169,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿لكنا عباد الله المخلصين﴾</span></span>: اللام واقعة في جواب <span class="hlt"><span class="qpc-hafs">﴿لو﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿كنا﴾</span></span> فعل ماض ناقص، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> اسمها، و<span class="hlt"><span class="qpc-hafs">﴿عباد الله﴾</span></span> خبرها، والجملة لا محل لها من الإعراب، لأنها جواب شرط غير جازم، و<span class="hlt"><span class="qpc-hafs">﴿المخلصين﴾</span></span> نعت لـ<span class="hlt"><span class="qpc-hafs">﴿عباد الله﴾</span></span>.</p></div>"
  37,170,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فكفروا به فسوف يعلمون﴾</span></span>: الفاء الفصيحة، و<span class="hlt"><span class="qpc-hafs">﴿كفروا﴾</span></span> فعل ماض، والواو فاعل، و<span class="hlt"><span class="qpc-hafs">﴿به﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿كفروا﴾</span></span>، والفاء عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿سوف﴾</span></span> حرف استقبال، و<span class="hlt"><span class="qpc-hafs">﴿يعلمون﴾</span></span> فعل مضارع مرفوع، والواو فاعل.</p></div>"
  37,171,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ولقد سبقت كلمتنا لعبادنا المرسلين﴾</span></span>: كلام مستأنف لا محل له من الإعراب، واللام جواب للقسم المحذوف، و<span class="hlt"><span class="qpc-hafs">﴿قد﴾</span></span> حرف تحقيق، و<span class="hlt"><span class="qpc-hafs">﴿سبقت﴾</span></span> فعل ماض، و<span class="hlt"><span class="qpc-hafs">﴿كلمتنا﴾</span></span> فاعل، و<span class="hlt"><span class="qpc-hafs">﴿لعبادنا﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿سبقت﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿المرسلين﴾</span></span> نعت لـ<span class="hlt"><span class="qpc-hafs">﴿عبادنا﴾</span></span>.</p></div>"
  37,172,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إنهم لهم المنصورون﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span> حرف ناسخ و<span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> اسمها، واللام المزحلقة، و<span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿المنصورون﴾</span></span> خبر <span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span>، والجملة خبر <span class="hlt"><span class="qpc-hafs">﴿إنهم﴾</span></span>، أو <span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> ضمير فصل، و<span class="hlt"><span class="qpc-hafs">﴿المنصورون﴾</span></span> خبر إن.</p></div>"
  37,173,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وإن جندنا لهم الغالبون﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span> حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿جندنا﴾</span></span> اسمها، واللام المزحلقة، و<span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿الغالبون﴾</span></span> خبر <span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span>، والجملة خبر <span class="hlt"><span class="qpc-hafs">﴿إنهم﴾</span></span>، أو <span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> ضمير فصل، و<span class="hlt"><span class="qpc-hafs">﴿الغالبون﴾</span></span> خبر <span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span>.</p></div>"
  37,174,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فتول عنهم حتى حين﴾</span></span>: الفاء الفصيحة، و<span class="hlt"><span class="qpc-hafs">﴿تول﴾</span></span> فعل أمر مبني على حذف حرف العلة، والفاعل ضمير مستتر تقديره: أنت، و<span class="hlt"><span class="qpc-hafs">﴿عنهم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تول﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿حتى﴾</span></span> حرف غاية وجر، و<span class="hlt"><span class="qpc-hafs">﴿حين﴾</span></span> اسم مجرور بـ<span class="hlt"><span class="qpc-hafs">﴿حتى﴾</span></span>، والجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تول﴾</span></span>.</p></div>"
  37,175,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وأبصرهم فسوف يبصرون﴾</span></span>: الواو عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿أبصرهم﴾</span></span> فعل أمر، والفاعل مستتر، و<span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> مفعول به، والفاء رابطة لجواب الطلب، و<span class="hlt"><span class="qpc-hafs">﴿سوف﴾</span></span> حرف استقبال، و<span class="hlt"><span class="qpc-hafs">﴿يبصرون﴾</span></span> فعل مضارع مرفوع، والواو فاعل، والمفعول به محذوف، أي: ما يحيق بهم جزاء كفرهم.</p></div>"
  37,176,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿أفبعذابنا يستعجلون﴾</span></span>: الهمزة للاستفهام، والفاء عاطفة على محذوف يقدر بحسب المقام، و<span class="hlt"><span class="qpc-hafs">﴿بعذابنا﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يستعجلون﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿يستعجلون﴾</span></span> فعل مضارع مرفوع، والواو فاعل.</p></div>"
  37,177,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فإذا نزل بساحتهم فساء صباح المنذرين﴾</span></span>: الفاء عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿إذا﴾</span></span> ظرف مستقبل متضمن معنى الشرط، و<span class="hlt"><span class="qpc-hafs">﴿نزل﴾</span></span> فعل ماض، وفاعله ضمير مستتر تقديره: هو، أي: العذاب، و<span class="hlt"><span class="qpc-hafs">﴿بساحتهم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿نزل﴾</span></span>، والفاء رابطة لجواب <span class="hlt"><span class="qpc-hafs">﴿إذا﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿ساء﴾</span></span> فعل جامد لإنشاء الذم، و<span class="hlt"><span class="qpc-hafs">﴿صباح المنذرين﴾</span></span> فاعل، والمخصوص بالذم محذوف تقديره: صباحهم، وقيل: ضمير <span class="hlt"><span class="qpc-hafs">﴿ساء﴾</span></span> يعود على المخصوص، والتمييز محذوف، و<span class="hlt"><span class="qpc-hafs">﴿صباح المنذرين﴾</span></span> مخصوص بالذم وليس فاعلا.</p></div>"
  37,178,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وتول عنهم حتى حين﴾</span></span>: عطف على ما تقدم، و<span class="hlt"><span class="qpc-hafs">﴿تول﴾</span></span> فعل أمر مبني على حذف حرف العلة، والفاعل ضمير مستتر تقديره: أنت، و<span class="hlt"><span class="qpc-hafs">﴿عنهم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تول﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿حتى﴾</span></span> حرف غاية وجر، و<span class="hlt"><span class="qpc-hafs">﴿حين﴾</span></span> اسم مجرور بـ<span class="hlt"><span class="qpc-hafs">﴿حتى﴾</span></span>، والجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تول﴾</span></span>.</p></div>"
  37,179,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وأبصر فسوف يبصرون﴾</span></span>: الواو عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿أبصر﴾</span></span> فعل أمر، والفاعل مستتر، والمفعول به مستتر أيضا، والفاء رابطة لجواب الطلب، و<span class="hlt"><span class="qpc-hafs">﴿سوف﴾</span></span> حرف استقبال، و<span class="hlt"><span class="qpc-hafs">﴿يبصرون﴾</span></span> فعل مضارع، والواو فاعل، والمفعول به محذوف، أي: ما يحيق بهم جزاء كفرهم.</p></div>"
  37,180,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿سبحان ربك رب العزة عما يصفون﴾</span></span>: سبحان: نائب مفعول مطلق منصوب بفعل محذوف، وربك: مضاف إليه، و<span class="hlt"><span class="qpc-hafs">﴿رب العزة﴾</span></span> بدل، و<span class="hlt"><span class="qpc-hafs">﴿عما﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿سبحان﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿يصفون﴾</span></span> فعل مضارع مرفوع، والواو فاعل، وجملة <span class="hlt"><span class="qpc-hafs">﴿يصفون﴾</span></span> صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> لا محل لها من الإعراب.</p></div>"
  37,181,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وسلام على المرسلين﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿سلام﴾</span></span> مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿على المرسلين﴾</span></span> جار ومجرور متعلقان بمحذوف خبر.</p></div>"
  37,182,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿والحمد لله رب العالمين﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿الحمد﴾</span></span> مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿لله﴾</span></span> جار ومجرور متعلقان بمحذوف خبر، و<span class="hlt"><span class="qpc-hafs">﴿رب العالمين﴾</span></span> بدل، أو صفة.</p></div>"