quran[14]{c,v,t}:
  19,12,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿يا يحيى خذ الكتاب بقوة﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿يا﴾</span></span> أداة نداء، و<span class="hlt"><span class="qpc-hafs">﴿يحيى﴾</span></span> منادى مفرد علم، و<span class="hlt"><span class="qpc-hafs">﴿خذ الكتاب﴾</span></span> فعل أمر وفاعل مستتر ومفعول به، و<span class="hlt"><span class="qpc-hafs">﴿بقوة﴾</span></span> جار ومجرور متعلقان بمحذوف حال من فاعل خذ، والباء للملابسة، أي: حال كونك متلبسًا بقوة واجتهاد.</p><p><span class="hlt"><span class="qpc-hafs">﴿وآتيناه الحكم صبيا﴾</span></span>: الواو استئنافية، والجملة بعدها مستأنفة لا محل لها من الإعراب، وآتيناه فعل وفاعل ومفعول به أول، والحكم مفعول به ثان، وصبيًّا حال من الهاء.</p></div>"
  19,13,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وحنانا من لدنا وزكاة وكان تقيا﴾</span></span>: الواو عاطفة، وحنانًا عطف على الحكم، أي: وآتيناه حنانًا، وقيل: مفعول مطلق لفعل محذوف، و<span class="hlt"><span class="qpc-hafs">﴿من لدنا﴾</span></span> جار ومجرور متعلقان بمحذوف صفة لـ<span class="hlt"><span class="qpc-hafs">﴿حنانًا﴾</span></span>، وزكاة عطف على <span class="hlt"><span class="qpc-hafs">﴿حنانًا﴾</span></span>، وكان تقيًا عطف على آتيناه، وكان فعل ماض ناقص، واسمها ضمير مستتر تقديره: هو، وتقيًّا خبر كان منصوب.</p></div>"
  19,14,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وبرا بوالديه ولم يكن جبارا عصيا﴾</span></span>: الواو عاطفة، وبرًّا عطف على <span class="hlt"><span class="qpc-hafs">﴿تقيًّا﴾</span></span>، وبوالديه جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿برًّا﴾</span></span>، ولم يكن عطف على: وكان تقيًّا، واسم يكن مستتر تقديره: هو، وجبارًا خبرها، وعصيًّا نعت.</p></div>"
  19,15,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وسلام عليه يوم ولد ويوم يموت ويوم يبعث حيا﴾</span></span>: الواو استئنافية، وسلام مبتدأ، وساغ الابتداء به مع أنه نكرة لتضمنه الدعاء، وعليه جار ومجرور متعلقان بمحذوف خبر، ويوم ظرف متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿سلام﴾</span></span>، وجملة ولد مضاف إليه، وجملة <span class="hlt"><span class="qpc-hafs">﴿وسلام عليه يوم ولد﴾</span></span> مستأنفة لا محل لها من الإعراب، وما بعده عطف عليه، و<span class="hlt"><span class="qpc-hafs">﴿حيًّا﴾</span></span> حال.</p></div>"
  19,16,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿واذكر في الكتاب مريم إذ انتبذت﴾</span></span>: الواو استئنافية، واذكر فعل أمر وفاعل مستتر تقديره: أنت، وفي الكتاب جار ومجرور متعلقان باذكر، ومريم مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿إذ﴾</span></span> ظرف للزمن الماضي متعلق بمضاف محذوف والتقدير: واذكر خبر مريم أو نبأ مريم، فالظرف متعلق بذلك الخبر أو النبأ. أو <span class="hlt"><span class="qpc-hafs">﴿إذ﴾</span></span> اسم مبني على السكون في محل نصب بدل اشتمال من مريم، والمعنى: اذكر وقت انتباذها، وجملة <span class="hlt"><span class="qpc-hafs">﴿انتبذت﴾</span></span> في محل جر مضاف إليه، ومن أهلها حال، ومكانًا ظرف متعلق بانتبذت، أي: في مكان، أو مفعول به على أن معنى انتبذت: أتت، وشرقيًّا نعت، وجملة <span class="hlt"><span class="qpc-hafs">﴿واذكر في الكتاب مريم﴾</span></span> مستأنفة لا محل لها من الإعراب.</p></div>"
  19,17,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فاتخذت من دونهم حجابا فأرسلنا إليها روحنا فتمثل لها بشرا سويا﴾</span></span>: الفاء عاطفة، واتخذت فعل ماض وفاعل مستتر، ومن دونهم جار ومجرور متعلقان بمحذوف مفعول به ثان، وحجابًا مفعول به أول، <span class="hlt"><span class="qpc-hafs">﴿فأرسلنا﴾</span></span> عطف على <span class="hlt"><span class="qpc-hafs">﴿فاتخذت﴾</span></span>، وإليها جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أرسلنا﴾</span></span>، وروحنا مفعول به، فتمثل عطف أيضًا، و<span class="hlt"><span class="qpc-hafs">﴿لها﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تمثل﴾</span></span>، وبشرًا حال، وسويًّا نعت، وسوغ وقوع الحال جامدة وصفها.</p></div>"
  19,18,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قالت إني أعوذ بالرحمن منك إن كنت تقيا﴾</span></span>: إن حرف ناسخ، والياء ضمير مبني في محل نصب اسم إن، وجملة أعوذ خبر إن، والجملة مقول القول، وبالرحمن جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أعوذ﴾</span></span>، ومنك جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أعوذ﴾</span></span> أيضًا، وإن حرف شرط جازم وكنت فعل ماض ناقص، والتاء ضمير مبني في محل رفع اسم كان، وتقيًّا خبر كان منصوب، وجواب الشرط محذوف.</p></div>"
  19,19,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قال إنما أنا رسول ربك لأهب لك غلاما زكيا﴾</span></span>: إنما كافة ومكفوفة، وأنا مبتدأ، ورسول خبر، و<span class="hlt"><span class="qpc-hafs">﴿ربك﴾</span></span> مضاف إليه، واللام للتعليل، وأهب فعل مضارع منصوب بأن مضمرة بعد اللام، والمصدر المؤول من أن والفعل مجرور باللام، والجار والمجرور متعلقان برسول أو بفعل محذوف تقديره: أرسلني، و<span class="hlt"><span class="qpc-hafs">﴿لك﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أهب﴾</span></span>، وغلامًا مفعول به، وزكيًّا صفة.</p></div>"
  19,20,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قالت أنى يكون لي غلام ولم يمسسني بشر ولم أك بغيا﴾</span></span>: أنى اسم استفهام في محل نصب على الظرفية المكانية، وهو متعلق بالاستقرار في خبر يكون. <span class="hlt"><span class="qpc-hafs">﴿ولم يمسسني﴾</span></span>: الواو حالية، ولم حرف نفي وقلب وجزم، ويمسسني مضارع مجزوم بلم، والياء مفعول به، وبشر فاعل. <span class="hlt"><span class="qpc-hafs">﴿ولم أك بغيًّا﴾</span></span>: لم حرف نفي وقلب وجزم، وأك مضارع مجزوم، وعلامة جزمه السكون على النون المحذوفة للتخفيف، واسم أك مستتر، وبغيًّا خبرها.</p></div>"
  19,21,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قال كذلك قال ربك هو علي هين﴾</span></span>: كذلك جار ومجرور متعلقان بمحذوف خبر لمبتدأ محذوف، وقال ربك فعل وفاعل، و<span class="hlt"><span class="qpc-hafs">﴿هو﴾</span></span> مبتدأ، وعلي جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿هين﴾</span></span>، وهين خبر هو.</p><p><span class="hlt"><span class="qpc-hafs">﴿ولنجعله آية للناس ورحمة منا وكان أمرا مقضيا﴾</span></span>: لنجعله تعليل معلله محذوف، أي: فعلنا ذلك. أو هو معطوف على مضمر، أي: لنبين به قدرتنا ولنجعله آية. وآية مفعول به ثان لـ<span class="hlt"><span class="qpc-hafs">﴿نجعله﴾</span></span>، وللناس جار ومجرور متعلقان بمحذوف صفة لآية، ورحمة منا عطف على آية. <span class="hlt"><span class="qpc-hafs">﴿وكان أمرًا مقضيًّا﴾</span></span> كان فعل ماض ناقص، واسمها ضمير مستتر، وأمرا خبر كان منصوب، ومقضيًّا صفة.</p></div>"
  19,22,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فحملته فانتبذت به مكانا قصيا﴾</span></span>: الفاء عاطفة على محذوف، تقديره: فنفخ جبريل في جيب درعها فحملته، فانتبذت عطف على فحملته، و<span class="hlt"><span class="qpc-hafs">﴿به﴾</span></span> جار ومجرور متعلقان بمحذوف في موضع نصب على الحال، و<span class="hlt"><span class="qpc-hafs">﴿مكانًا﴾</span></span> ظرف مكان متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿انتبذ﴾</span></span>، أو مفعول به، وقصيًّا صفة.</p></div>"
  19,23,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فأجاءها المخاض إلى جذع النخلة﴾</span></span>: الفاء عاطفة، وأجاءها فعل ماض، ومفعول به مقدم، والمخاض فاعل مؤخر، و<span class="hlt"><span class="qpc-hafs">﴿إلى جذع﴾</span></span> جار ومجرور متعلقان بمحذوف حال، والنخلة مضاف إليه.</p><p><span class="hlt"><span class="qpc-hafs">﴿قالت يا ليتني مت قبل هذا وكنت نسيا منسيا﴾</span></span>: يا حرف نداء، والمنادى محذوف، أو حرف تنبيه، وليت حرف ناسخ، والياء ضمير مبني في محل نصب اسم ليت، وجملة مت خبر ليت، وهي فعل وفاعل، والظرف منصوب وهو متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿مت﴾</span></span>، وهذا مضاف إليه. <span class="hlt"><span class="qpc-hafs">﴿وكنت﴾</span></span>: الواو عاطفة، وكان فعل ماض ناقص، والتاء ضمير مبني في محل رفع اسم كان، ونسيًا خبر كان منصوب، ومنسيًّا نعت، أو تأكيد لـ<span class="hlt"><span class="qpc-hafs">﴿نسيًا﴾</span></span>، لأنه بمعناه.</p></div>"
  19,24,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فناداها من تحتها ألا تحزني﴾</span></span>: الفاء: عاطفة، وناداها: فعل، ومفعول به، وفاعل مستتر يعود على المَلَك أو عيسى. و<span class="hlt"><span class="qpc-hafs">﴿من تحتها﴾</span></span>: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿ناداها﴾</span></span>، أو بمحذوف حال من الفاعل. وأن تفسيرية، والجملة بعدها تفسيرية لا محل لها من الإعراب. ولا ناهية، وتحزني مجزوم بلا. وقيل: <span class="hlt"><span class="qpc-hafs">﴿أن﴾</span></span> مصدرية، وتحزني منصوب بها، ولا نافية، وأن وما بعدها نصب بنزع الخافض المتعلق بالنداء. وجملة <span class="hlt"><span class="qpc-hafs">﴿لا تحزني﴾</span></span> صلة <span class="hlt"><span class="qpc-hafs">﴿أن﴾</span></span> المصدرية لا محل لها من الإعراب.</p><p><span class="hlt"><span class="qpc-hafs">﴿قد جعل ربك تحتك سريا﴾</span></span>: قد حرف تحقيق، و<span class="hlt"><span class="qpc-hafs">﴿جعل ربك﴾</span></span> فعل وفاعل، وتحتك ظرف متعلق بمحذوف هو المفعول الثاني لجعل، وسريًّا هو المفعول الأول.</p></div>"
  19,25,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وهزي إليك بجذع النخلة تساقط عليك رطبا جنيا﴾</span></span>: الواو عاطفة، وهزي فعل أمر مبني على حذف حرف العلة، والياء هي الفاعل، وإليك جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿هزي﴾</span></span>. <span class="hlt"><span class="qpc-hafs">﴿بجذع النخلة﴾</span></span>: الباء صلة وجذع النخلة مفعول، وتساقط مجزوم في جواب الطلب، وعليك جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تساقط﴾</span></span>، ورطبًا مفعول به، وجنيًّا صفة.</p></div>"