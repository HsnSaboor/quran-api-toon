quran[25]{c,v,t}:
  20,13,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وأنا اخترتك فاستمع لما يوحى﴾</span></span>: الواو عاطفة، وأنا مبتدأ، وجملة اخترتك من الفعل والفاعل والمفعول به خبر، فاستمع: الفاء عاطفة، واستمع فعل أمر، والفاعل مستتر تقديره: أنت، ولما جار ومجرور متعلقان باستمع، وجملة يوحى صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> لا محل لها من الإعراب، ويوحى بالبناء لما لم يسمَّ فاعله.</p></div>"
  20,14,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إنني أنا الله لا إله إلا أنا فاعبدني وأقم الصلاة لذكري﴾</span></span>: الجملة بدل من <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> في <span class="hlt"><span class="qpc-hafs">﴿لما يوحى﴾</span></span>، وإن حرف ناسخ، والياء ضمير مبني في محل نصب اسم إن، وأنا تأكيد للضمير، أو مبتدأ، والله خبر إن، أو خبر أنا، والجملة خبر إن، وجملة <span class="hlt"><span class="qpc-hafs">﴿لا إله إلا أنا﴾</span></span> خبر ثان، فاعبدني: الفاء الفصيحة، واعبدني فعل أمر، وفاعل مستتر، والنون للوقاية، والياء مفعول، وأقم الصلاة عطف على اعبدني، ولذكرى جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أقم﴾</span></span>، وهو مصدر مضاف لمفعوله، أي: لتذكرني فيها، وقيل: المصدر مضاف للفاعل، أي: لذكري إياك.</p></div>"
  20,15,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إن الساعة آتية أكاد أخفيها لتجزى كل نفس بما تسعى﴾</span></span>: إن: حرف ناسخ، والساعة: اسم إن منصوب، آتية: خبر إن مرفوع، وأكاد: فعل مضارع ناقص من أفعال المقاربة، واسمها مستتر تقديره: أنا، وجملة <span class="hlt"><span class="qpc-hafs">﴿أخفيها﴾</span></span>: خبر أكاد، ولتجزى: اللام للتعليل، وتجزى فعل مضارع منصوب بأن مضمرة، والمصدر المؤول من أن والفعل مجرور باللام، والجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أخفيها﴾</span></span> أو بـ<span class="hlt"><span class="qpc-hafs">﴿آتية﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿أكاد أخفيها﴾</span></span>: اعتراضية بينهما لا محل لها من الإعراب، وقيل: إن جملة <span class="hlt"><span class="qpc-hafs">﴿أكاد أخفيها﴾</span></span> في محل رفع خبر ثان لـ<span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span>، وقيل: إنها في محل نصب حال من <span class="hlt"><span class="qpc-hafs">﴿الساعة﴾</span></span>. وكل: نائب فاعل، ونفس: مضاف إليه، وبما: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تجزى﴾</span></span>، وجملة تسعى صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> لا محل لها من الإعراب، وقيل: ما مصدرية، أي: بجزاء سعيها، على حذف مضاف.</p></div>"
  20,16,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فلا يصدنك عنها من لا يؤمن بها واتبع هواه فتردى﴾</span></span>: الفاء الفصيحة، ولا ناهية، ويصدنك فعل مضارع مبني على الفتح لاتصاله بنون التوكيد، وهو في محل جزم بلا الناهية، والكاف مفعول به، وعنها جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يصدنك﴾</span></span>، ومَن فاعل، وجملة لا يؤمن صلة <span class="hlt"><span class="qpc-hafs">﴿من﴾</span></span> لا محل لها من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿بها﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يؤمن﴾</span></span>، واتبع هواه فعل، وفاعل مستتر، ومفعول به، فتردى: الفاء فاء السببية، وتردى فعل مضارع منصوب بأن مضمرة بعد الفاء بفتحة مقدرة على الألف، والمصدر المؤول من أن والفعل معطوف على مصدر مُتَصَيَّد من الكلام السابق، أي: لا يكن صَدٌّ فَتَرَدٍّ.</p></div>"
  20,17,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وما تلك بيمينك يا موسى﴾</span></span>: الواو عاطفة، وما اسم استفهام للتقرير مبتدأ، وتلك خبره، وبـ<span class="hlt"><span class="qpc-hafs">﴿يمينك﴾</span></span> جار ومجرور متعلقان بمحذوف حال، وهي تشبه قوله تعالى: <span class="hlt"><span class="qpc-hafs">﴿وهذا بعلي شيخا﴾</span></span>، والعامل في الحال المقدرة اسم الإشارة، ويا موسى نداء.</p></div>"
  20,18,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قال هي عصاي أتوكأ عليها وأهش بها على غنمي﴾</span></span>: هي مبتدأ، وعصاي خبره، وجملة أتوكأ عليها حالية، وقيل: مستأنفة لا محل لها من الإعراب، وأهش بها على غنمي عطف على أتوكأ عليها، و<span class="hlt"><span class="qpc-hafs">﴿بها﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أهش﴾</span></span>، وكذلك على غنمي.</p><p><span class="hlt"><span class="qpc-hafs">﴿ولي فيها مآرب أخرى﴾</span></span>: الواو عاطفة، ولي خبر مقدم، وفيها حال، ومآرب مبتدأ مؤخر، وأخرى صفة لمآرب.</p></div>"
  20,19,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قال ألقها يا موسى﴾</span></span>: جملة ألقها مقول القول، ويا موسى نداء.</p></div>"
  20,20,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فألقاها فإذا هي حية تسعى﴾</span></span>: ألقاها فعل وفاعل ومفعول به، والفاء عاطفة، وإذا للمفاجأة، و<span class="hlt"><span class="qpc-hafs">﴿هي﴾</span></span> مبتدأ، وحية خبر، وجملة تسعى حال، أو خبر ثان.</p></div>"
  20,21,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قال خذها ولا تخف سنعيدها سيرتها الأولى﴾</span></span>: جملة خذها مقول القول، والواو حرف عطف، ولا ناهية، وتخف فعل مضارع مجزوم بلا الناهية، والسين حرف استقبال، ونعيدها فعل مضارع، والفاعل مستتر تقديره: نحن، وسيرتها منصوب بنزع الخافض، أي: إلى سيرتها، وقيل: هي ظرف، وقيل: بدل اشتمال من ضمير المفعول، وقيل: نصبت  بفعل مضمر، أي: تسير سيرتها الأولى، والأولى صفة.</p></div>"
  20,22,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿واضمم يدك إلى جناحك تخرج بيضاء من غير سوء آية أخرى﴾</span></span>: الواو عاطفة، واضمم عطف على ألقها، ويدك مفعول به، والفاعل مستتر تقديره: أنت، وإلى جناحك جار ومجرور متعلقان باضمم، وتخرج جزم في جواب الطلب، وبيضاء حال، ومن غير سوء جار ومجرور متعلقان ببيضاء لما فيها من معنى الفعل، أو متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تخرج﴾</span></span>، وآية حال ثانية من فاعل تخرج أيضًا، وقيل: نصبت بإضمار، نحو: خذ أو دونك، وأخرى صفة لآية.</p></div>"
  20,23,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿لنريك من آياتنا الكبرى﴾</span></span>: اللام للتعليل، ونريك فعل مضارع منصوب بأن مضمرة بعد اللام، وهو تعليل لمحذوف متعلق به، أي: أمرناك بما ذكرنا لنريك بها، أي: بيدك، والمصدر المؤول من أن والفعل مجرور باللام، والجار والمجرور متعلقان بفعل محذوف تقديره: جعلناها، و<span class="hlt"><span class="qpc-hafs">﴿من آياتنا﴾</span></span> جار ومجرور متعلقان بمحذوف على أنه حال من <span class="hlt"><span class="qpc-hafs">﴿الكبرى﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿الكبرى﴾</span></span> على هذا مفعول ثان لـ<span class="hlt"><span class="qpc-hafs">﴿نريك﴾</span></span>، أو صفة للمفعول الثاني على الأصح، والتقدير: لنريك الآية الكبرى من آياتنا، أي: حال كونها من آياتنا.</p></div>"
  20,24,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿اذهب إلى فرعون إنه طغى﴾</span></span>: اذهب فعل أمر، والفاعل مستتر تقديره: أنت، وإلى فرعون جار ومجرور متعلقان باذهب، وإن حرف ناسخ، والهاء اسمها، وجملة طغى خبرها، وجملة إنه طغى تعليلية لا محل لها من الإعراب.</p></div>"
  20,25,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قال رب اشرح لي صدري﴾</span></span>: قال فعل ماض، وفاعله مستتر تقديره: هو، ورب منادى مضاف لياء المتكلم المحذوفة، واشرح فعل دعاء، ولي جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿اشرح﴾</span></span>، وصدري مفعول به.</p></div>"
  20,26,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ويسر لي أمري﴾</span></span>: الواو عاطفة، ويسِّر فعل دعاء مبني على السكون، والفاعل مستتر تقديره أنت، وأمري مفعول به، والياء مضاف إليه.</p></div>"
  20,27,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿واحلل عقدة من لساني﴾</span></span>: الواو عاطفة، واحلل فعل دعاء مبني على السكون، والفاعل مستتر تقديره أنت، وعقدة مفعول به، ومن لساني جار ومجرور متعلقان بمحذوف صفة لعقدة، كأنه قيل: عقدة من عقد لساني.</p></div>"
  20,28,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿يفقهوا قولي﴾</span></span>: يفقهوا فعل مضارع مجزوم في جواب الطلب، والواو فاعل، وقولي مفعول به.</p></div>"
  20,29,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿واجعل لي وزيرا من أهلي﴾</span></span>: الواو عاطفة، واجعل فعل دعاء، وفاعله مستتر تقديره: أنت، ولي جار ومجرور متعلقان بمحذوف مفعول ثان، ووزيرًا مفعول به أول، ومن أهلي جار ومجرور متعلقان بمحذوف صفة لـ<span class="hlt"><span class="qpc-hafs">﴿وزيرًا﴾</span></span>.</p></div>"
  20,30,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿هارون أخي﴾</span></span>: هارون بدل من <span class="hlt"><span class="qpc-hafs">﴿وزيرًا﴾</span></span>، وأخي بدل من هارون، أو وزيرًا مفعول ثان، وهارون مفعول أول، ولي جار ومجرور متعلقان بمحذوف حال، أو بنفس الجعل، ومن أهلي صفة، أو <span class="hlt"><span class="qpc-hafs">﴿وزيرًا﴾</span></span> هو المفعول الأول، ومن أهلي هو الثاني.</p></div>"
  20,31,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿اشدد به أزري﴾</span></span>: اشدد فعل دعاء، وفاعله ضمير مستتر تقديره: أنت، و<span class="hlt"><span class="qpc-hafs">﴿به﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿اشدد﴾</span></span>، وأزري مفعول به.</p></div>"
  20,32,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وأشركه في أمري﴾</span></span>: الواو عاطفة، وأشركه عطف على اشدد، والهاء مفعول به، وفي أمري جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أشركه﴾</span></span>.</p></div>"
  20,33,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿كي نسبحك كثيرا﴾</span></span>: كي حرف مصدري ونصب واستقبال، ونسبحك فعل مضارع منصوب بـ<span class="hlt"><span class="qpc-hafs">﴿كي﴾</span></span>، وفاعل نسبحك ضمير مستتر تقديره: نحن، وكثيرًا صفة لمصدر محذوف فهو نائب مفعول مطلق، أي: نسبحك تسبيحًا كثيرًا، أو صفة لظرف زمان محذوف، أي: نسبحك وقتًا كثيرًا.</p></div>"
  20,34,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ونذكرك كثيرا﴾</span></span>: الواو عاطفة، ونذكرك فعل مضارع معطوف على نسبحك منصوب، وفاعل نذكرك ضمير مستتر تقديره: نحن، وكثيرًا صفة لمصدر محذوف فهو نائب مفعول مطلق، أي: نذكرك ذكرًا كثيرًا، أو صفة لظرف زمان محذوف، أي: نذكرك وقتًا كثيرًا.</p></div>"
  20,35,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إنك كنت بنا بصيرا﴾</span></span>: إن حرف ناسخ، والكاف اسمها، وجملة كنت خبر إن، والتاء اسم كان، وبنا جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿بصيرًا﴾</span></span>، وبصيرًا خبر كان منصوب.</p></div>"
  20,36,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قال قد أوتيت سؤلك يا موسى﴾</span></span>: جملة قد أوتيت مقول القول، وأوتيت فعل ماض مبني لما لم يسمَّ فاعله، والتاء نائب فاعل، وسؤلك مفعول به ثان لأوتيت.</p></div>"
  20,37,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ولقد مننا عليك مرة أخرى﴾</span></span>: الواو استئنافية، والجملة بعدها مستأنفة لا محل لها من الإعراب، واللام جواب للقسم المحذوف، وقد حرف تحقيق، ومننا فعل وفاعل، وعليك جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿مننا﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿مرة﴾</span></span> ظرف، أو نائب عن المفعول المطلق، لأنه عدده، وأخرى صفة لمرة.</p></div>"