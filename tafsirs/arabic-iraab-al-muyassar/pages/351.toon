quran[10]{c,v,t}:
  24,11,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إن الذين جاءوا بالإفك عصبة منكم﴾</span></span>: إن حرف ناسخ، والذين اسم موصول مبني في محل نصب اسم إن، وجملة جاءوا صلة الموصول لا محل لها من الإعراب، وبالإفك جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿جاءوا﴾</span></span>، وعصبة خبر إن، ومنكم جار ومجرور متعلقان بمحذوف صفة لعصبة.</p><p><span class="hlt"><span class="qpc-hafs">﴿لا تحسبوه شرا لكم بل هو خير لكم﴾</span></span>: جملة لا تحسبوه مستأنفة لا محل لها من الإعراب، ولا جازمة، وتحسبوه مضارع مجزوم، والواو فاعل، والهاء مفعول به أول، وشرًّا مفعول به ثان، و<span class="hlt"><span class="qpc-hafs">﴿لكم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿شرًا﴾</span></span>، وبل حرف عطف وإضراب، و<span class="hlt"><span class="qpc-hafs">﴿هو﴾</span></span> مبتدأ، وخير خبر، و<span class="hlt"><span class="qpc-hafs">﴿لكم﴾</span></span> جار ومجرور متعلقان بخير.</p><p><span class="hlt"><span class="qpc-hafs">﴿لكل امرئ منهم ما اكتسب من الإثم﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿لكل﴾</span></span> جار ومجرور متعلقان بمحذوف خبر مقدم، وامرئ مضاف إليه، و<span class="hlt"><span class="qpc-hafs">﴿منهم﴾</span></span> جار ومجرور متعلقان بمحذوف صفة لـ<span class="hlt"><span class="qpc-hafs">﴿امرئ﴾</span></span>، وما اسم موصول مبتدأ مؤخر، وجملة اكتسب صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> لا محل لها من الإعراب، ومن الإثم جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿اكتسب﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿والذي تولى كبره منهم له عذاب عظيم﴾</span></span>: الواو استئنافية، والذي مبتدأ، وجملة تولى كبره صلة الذي لا محل لها من الإعراب، ومنهم جار ومجرور متعلقان بمحذوف حال، و<span class="hlt"><span class="qpc-hafs">﴿له﴾</span></span> خبر مقدم، و<span class="hlt"><span class="qpc-hafs">﴿عذاب﴾</span></span> مبتدأ مؤخر، وعظيم صفة لعذاب، والجملة خبر الذي، وجملة <span class="hlt"><span class="qpc-hafs">﴿والذي تولى...﴾</span></span> مستأنفة لا محل لها من الإعراب.</p></div>"
  24,12,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿لولا إذ سمعتموه ظن المؤمنون والمؤمنات بأنفسهم خيرا﴾</span></span>: لولا حرف تحضيض متضمن معنى الزجر والتوبيخ، وإذ ظرف لما مضى من الزمن متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿ظن﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿سمعتموه﴾</span></span> في محل جر بإضافة الظرف إليها، و<span class="hlt"><span class="qpc-hafs">﴿ظن المؤمنون﴾</span></span> فعل وفاعل، والمؤمنات عطف، وبأنفسهم جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿خيرًا﴾</span></span>، وخيرًا مفعول به ثان.</p><p><span class="hlt"><span class="qpc-hafs">﴿وقالوا هذا إفك مبين﴾</span></span>: الواو عاطفة، وقالوا عطف على ظن، وهذا مبتدأ، وإفك خبر، ومبين صفة، والجملة الاسمية مقول القول.</p></div>"
  24,13,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿لولا جاءوا عليه بأربعة شهداء فإذ لم يأتوا بالشهداء﴾</span></span>: لولا حرف تحضيض، وجاءوا فعل وفاعل، وعليه جار ومجرور متعلقان بشهداء، وبأربعة جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿جاءوا﴾</span></span>، وشهداء مضاف إليه. <span class="hlt"><span class="qpc-hafs">﴿فإذ﴾</span></span>: الفاء عاطفة، وإذ ظرف لما مضى من الزمن متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿الكاذبون﴾</span></span>، ولم حرف نفي وقلب وجزم، ويأتوا فعل مضارع مجزوم بلم، والجملة في محل جر بإضافة الظرف إليها،  بالشهداء جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يأتوا﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿فأولئك عند الله هم الكاذبون﴾</span></span>: الفاء رابطة، وأولئك مبتدأ، وعند الله ظرف متعلق بمحذوف حال، و<span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> مبتدأ ثان، أو ضمير فصل، والكاذبون خبر أولئك أو خبر <span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span>، والجملة خبر أولئك.</p></div>"
  24,14,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ولولا فضل الله عليكم ورحمته في الدنيا والآخرة﴾</span></span>: الواو عاطفة، ولولا حرف امتناع لوجود، و<span class="hlt"><span class="qpc-hafs">﴿فضل الله﴾</span></span> مبتدأ، ولفظ الجلالة مضاف إليه، والخبر محذوف وجوبا، و<span class="hlt"><span class="qpc-hafs">﴿عليكم﴾</span></span> جار ومجرور متعلقان بفضل، ورحمته عطف على فضل، و<span class="hlt"><span class="qpc-hafs">﴿في الدنيا﴾</span></span> جار ومجرور متعلقان بمحذوف حال، والآخرة عطف على الدنيا.</p><p><span class="hlt"><span class="qpc-hafs">﴿لمسكم في ما أفضتم فيه عذاب عظيم﴾</span></span>: اللام واقعة في جواب لولا، ومسكم فعل ومفعول به، والجملة لا محل لها من الإعراب، لأنها جواب شرط غير جازم، و<span class="hlt"><span class="qpc-hafs">﴿في ما﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿مسكم﴾</span></span>، وجملة أفضتم فيه صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> لا محل لها من الإعراب، وقيل: ما مصدرية، أي: لمسكم بسبب إفاضتكم وخوضكم في الإفك. و<span class="hlt"><span class="qpc-hafs">﴿فيه﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أفضتم﴾</span></span>، وعذاب فاعل، وعظيم صفة.</p></div>"
  24,15,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إذ تلقونه بألسنتكم وتقولون بأفواهكم ما ليس لكم به علم﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿إذ﴾</span></span> ظرف متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿مسكم﴾</span></span> أو بـ<span class="hlt"><span class="qpc-hafs">﴿أفضتم﴾</span></span>، وتلقونه فعل مضارع حذفت إحدى تاءيه، وهو مرفوع وعلامة رفعه ثبوت النون، والواو فاعل، والهاء مفعول به، والجملة في محل جر بإضافة الظرف إليها، وبألسنتكم جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تلقونه﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿تقولون﴾</span></span> عطف على <span class="hlt"><span class="qpc-hafs">﴿تلقونه﴾</span></span>، وبأفواهكم جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تقولون﴾</span></span>، وما مفعول تقولون، وجملة <span class="hlt"><span class="qpc-hafs">﴿ليس﴾</span></span> صلة الموصول لا محل لها من الإعراب، وليس فعل ماض ناقص، و<span class="hlt"><span class="qpc-hafs">﴿لكم﴾</span></span> جار ومجرور متعلقان بمحذوف خبرها المقدم، و<span class="hlt"><span class="qpc-hafs">﴿به﴾</span></span> جار ومجرور متعلقان بعلم، وعلم اسم ليس المؤخر.</p><p><span class="hlt"><span class="qpc-hafs">﴿وتحسبونه هينا وهو عند الله عظيم﴾</span></span>: الواو عاطفة، وتحسبونه فعل مضارع وفاعل ومفعول به أول، وهينًا مفعول به ثان، والواو للحال، وهو مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿عند الله﴾</span></span> ظرف منصوب متعلق بالخبر <span class="hlt"><span class="qpc-hafs">﴿عظيم﴾</span></span>، ولفظ الجلالة مضاف إليه، وعظيم خبر هو، والجملة حالية.</p></div>"
  24,16,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ولولا إذ سمعتموه قلتم ما يكون لنا أن نتكلم بهذا﴾</span></span>: لولا حرف تحضيض وتوبيخ، وإذ ظرف زمان متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿قلتم﴾</span></span>، وجملة سمعتموه في محل جر مضاف إليه، وجملة قلتم لا محل لها من الإعراب، لأنها ابتدائية، وما نافية، ويكون فعل مضارع ناقص، و<span class="hlt"><span class="qpc-hafs">﴿لنا﴾</span></span> جار ومجرور متعلقان بمحذوف خبرها المقدم، وأن وما في حيزها اسمها المؤخر، وبهذا جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿نتكلم﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿سبحانك هذا بهتان عظيم﴾</span></span>: هذا مبتدأ، وبهتان خبر، وعظيم صفة، وسبحانك: نائب مفعول مطلق منصوب بفعل محذوف، والكاف مضاف إليه.</p></div>"
  24,17,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿يعظكم الله أن تعودوا لمثله أبدا إن كنتم مؤمنين﴾</span></span>: يعظكم فعل مضارع ومفعول به، ولفظ الجلالة فاعل، وأن وما في حيزها نصب بنزع الخافض، لأنه ضمن معنى فعل متعد بـ<span class="hlt"><span class="qpc-hafs">﴿عن﴾</span></span>، ولمثله جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تعودوا﴾</span></span>، وأبدًا ظرف زمان متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿تعودوا﴾</span></span> أيضًا، وقيل: لا تضمين في معنى يعظكم، وأن وما بعدها مفعول لأجله على حذف مضاف، أي: كراهة أن تعودوا، وإن شرطية، وكنتم: كان فعل ماض ناقص، والتاء اسمها، ومؤمنين خبرها، وجواب الشرط محذوف، أي: إن كنتم مؤمنين فلا تعودوا لمثله.</p></div>"
  24,18,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ويبين الله لكم الآيات والله عليم حكيم﴾</span></span>: الواو عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿يبين الله﴾</span></span> فعل وفاعل، و<span class="hlt"><span class="qpc-hafs">﴿لكم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يبين﴾</span></span>، والآيات مفعول به، والله مبتدأ، وعليم حكيم خبران للفظ الجلالة.</p></div>"
  24,19,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إن الذين يحبون أن تشيع الفاحشة في الذين آمنوا﴾</span></span>: جملة مستأنفة لا محل لها من الإعراب، وإن حرف ناسخ، والذين اسم موصول مبني في محل نصب اسم إن، وجملة يحبون صلة الذين لا محل لها من الإعراب، وأن وما في حيزها مفعول يحبون، والفاحشة فاعل، و<span class="hlt"><span class="qpc-hafs">﴿في الذين آمنوا﴾</span></span> الجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تشيع﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿لهم عذاب أليم في الدنيا والآخرة والله يعلم وأنتم لا تعلمون﴾</span></span>: لهم جار ومجرور متعلقان بمحذوف خبر مقدم، وعذاب مبتدأ مؤخر، والجملة الاسمية خبر إن، وأليم صفة، وفي الدنيا والآخرة جار ومجرور متعلقان بمحذوف صفة ثانية، والله مبتدأ، وجملة يعلم خبر، وأنتم مبتدأ، وجملة لا تعلمون خبر.</p></div>"
  24,20,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ولولا فضل الله عليكم ورحمته وأن الله رءوف رحيم﴾</span></span>: لولا امتناعية، و<span class="hlt"><span class="qpc-hafs">﴿فضل الله عليكم﴾</span></span> مبتدأ محذوف الخبر وجوبًا، ولفظ الجلالة مضاف إليه، و<span class="hlt"><span class="qpc-hafs">﴿عليكم﴾</span></span> جار ومجرور متعلقان بفضل، ورحمته عطف على فضل، و<span class="hlt"><span class="qpc-hafs">﴿أن الله رءوف رحيم﴾</span></span> عطف على فضل، وجواب لولا محذوف، أي: لعاجلكم بالعقوبة.</p></div>"