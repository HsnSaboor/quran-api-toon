quran[10]{c,v,t}:
  30,6,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وعد الله لا يخلف الله وعده ولكن أكثر الناس لا يعلمون﴾</span></span>: وعد: مفعول مطلق عامله مقدر، والتقدير: وعدهم الله ذلك وعدًا، ولا: نافية، و<span class="hlt"><span class="qpc-hafs">﴿يخلف الله وعده﴾</span></span>: فعل وفاعل ومفعول به، والضمير مضاف إليه، والواو: حالية، و<span class="hlt"><span class="qpc-hafs">﴿لكنَّ أكثر﴾</span></span>: لكن حرف ناسخ، وأكثر اسمها، والناس: مضاف إليه، وجملة <span class="hlt"><span class="qpc-hafs">﴿لا يعلمون﴾</span></span>: خبر لكِنَّ.</p></div>"
  30,7,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿يعلمون ظاهرا من الحياة الدنيا وهم عن الآخرة هم غافلون﴾</span></span>: يعلمون ظاهرا: فعل وفاعل ومفعول به، من الحياة الدنيا: جار ومجرور ونعت، وجملة <span class="hlt"><span class="qpc-hafs">﴿يعلمون﴾</span></span> مستأنفة لا محل لها من الإعراب، وهم: مبتدأ، وعن الآخرة: جار ومجرور متعلقان بغافلون، و<span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> الثانية: تأكيد لـ<span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> الأولى، وغافلون: خبر <span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> الأولى. أو <span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> الثانية مبتدأ و<span class="hlt"><span class="qpc-hafs">﴿غافلون﴾</span></span> خبرا لـ<span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> الثانية، وجملة <span class="hlt"><span class="qpc-hafs">﴿هم غافلون﴾</span></span> خبرا لـ<span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> الأولى.</p></div>"
  30,8,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿أولم يتفكروا في أنفسهم ما خلق الله السماوات والأرض وما بينهما إلا بالحق وأجل مسمى﴾</span></span>: الهمزة: للاستفهام الإنكاري، والواو: عاطفة على مقدر يقتضيه السياق، ولم: حرف نفي وقلب وجزم، ويتفكروا: فعل مضارع مجزوم بـ<span class="hlt"><span class="qpc-hafs">﴿لم﴾</span></span>، وواو الجماعة: فاعل، وفي أنفسهم: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يتفكروا﴾</span></span>. وما: نافية، وخلق الله السماوات: فعل وفاعل ومفعول به، والواو عاطفة، وما: اسم موصول مفعول به. بينهما: ظرف متعلق بمحذوف صلة الموصول، وجملة الصلة لا محل لها من الإعراب. والضمير مضاف إليه، وإلا: أداة حصر، وبالحق: جار ومجرور متعلقان بحال محذوف من فاعل خلق، وأجل: عطف على الحق، ومسمى: نعت لأجل.</p><p><span class="hlt"><span class="qpc-hafs">﴿وإن كثيرا من الناس بلقاء ربهم لكافرون﴾</span></span>: الواو حالية، وإن حرف ناسخ، وكثيرا اسمها، ومن الناس: جار ومجرور متعلقان بنعت لكثيرًا، وبلقاء: جار ومجرور متعلقان بكافرون، وربهم: مضاف إليه، واللام: المزحلقة، وكافرون: خبر إن.</p></div>"
  30,9,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿أولم يسيروا في الأرض فينظروا كيف كان عاقبة الذين من قبلهم﴾</span></span>: الهمزة للاستفهام الإنكاري، والواو: عاطفة على مقدر يقتضيه السياق، أي: أقعدوا في أماكنهم ولم يسيروا. ولم: حرف نفي وقلب وجزم، ويسيروا: فعل مضارع مجزوم بلم، والواو: فاعل، وفي الأرض: جار ومجرور متعلقان بيسيروا، فينظروا: الفاء عاطفة على يسيروا، أو الفاء سببية، وينظروا: فعل مضارع منصوب بأن مضمرة بعد الفاء، والمصدر المؤول من <span class="hlt"><span class="qpc-hafs">﴿أن﴾</span></span> المضمرة والفعلِ معطوف على مصدر مأخوذ من الكلام السابق تقديره: أولم يكن سير فنظر؟ وكيف: اسم استفهام في محل نصب خبر مقدم لكان، وعاقبة: اسمها، والذين: مضاف إليه، ومن قبلهم: جار ومجرور متعلقان بمحذوف صلة الذين، وجملة الصلة لا محل لها من الإعراب. والهاء مضاف إليه.</p><p><span class="hlt"><span class="qpc-hafs">﴿كانوا أشد منهم قوة وأثاروا الأرض وعمروها أكثر مما عمروها﴾</span></span>: كان فعل ماض ناقص، وواو الجماعة اسمها، وأشد: خبرها، ومنهم: جار ومجرور متعلقان بأشد، وقوة: تمييز، وأثاروا الأرض: فعل وفاعل ومفعول به، وجملة <span class="hlt"><span class="qpc-hafs">﴿أثاروا﴾</span></span> معطوفة على جملة <span class="hlt"><span class="qpc-hafs">﴿كانوا...﴾</span></span>. وعمروها: فعل وفاعل ومفعول به والواو عطفت الجملة على ما قبلها، وأكثر: نعت لمصدر محذوف، أي: عمارة أكثر، ومما: جار ومجرور متعلقان بأكثر، وما: مصدرية مؤولة مع ما بعدها بمصدر مجرور بمن.</p><p><span class="hlt"><span class="qpc-hafs">﴿وجاءتهم رسلهم بالبينات فما كان الله ليظلمهم ولكن كانوا أنفسهم يظلمون﴾</span></span>: الواو حالية، وجاءتهم رسلهم: فعل ومفعول به وفاعل، وبالبينات: جار ومجرور متعلقان بجاءتهم، والفاء: عاطفة، وما: نافية، كان الله: كان فعل ماض ناقص، ولفظ الجلالة اسمها، واللام: لام الجحود، ويظلمهم: فعل مضارع منصوب بأن مضمرة بعد لام الجحود، والجار والمجرور متعلقان بخبر كان المقدر، ولكن: الواو حالية، ولكن: حرف استدراك مهمل، وكانوا: فعل ماض ناقص، والواو: اسمها، وأنفسهم: مفعول مقدم ليظلمون، ويظلمون: فعل وفاعل والجملة خبر كانوا.</p></div>"
  30,10,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ثم كان عاقبة الذين أساءوا السوءى﴾</span></span>: ثم عاطفة، وكان: فعل ماض ناقص، وعاقبة: خبر كان المقدم، والذين: مضاف إليه، وجملة أساءوا: صلة الموصول لا محل لها من الإعراب. والسوأى: اسم كان.</p><p><span class="hlt"><span class="qpc-hafs">﴿أن كذبوا بآيات الله وكانوا بها يستهزئون﴾</span></span>: أن حرف مصدري ونصب، وكذبوا: فعل ماض منصوب بأن، والواو فاعل، والمصدر المؤول من <span class="hlt"><span class="qpc-hafs">﴿أن كذبوا﴾</span></span> منصوب بإسقاط الخافض، بآيات الله: جار ومجرور متعلقان بكذبوا، ولفظ الجلالة مضاف إليه، وكانوا: فعل ماض ناقص، وواو الجماعة اسمها، وبها: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يستهزئون﴾</span></span>، وجملة يستهزئون: خبر كان.</p></div>"
  30,11,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿الله يبدأ الخلق ثم يعيده ثم إليه ترجعون﴾</span></span>: لفظ الجلالة: مبتدأ، ويبدأ الخلق: فعل وفاعل مستتر تقديره هو ومفعول به والجملة خبر المبتدأ، وثم حرف عطف، وجملة <span class="hlt"><span class="qpc-hafs">﴿يعيده﴾</span></span> معطوفة على جملة <span class="hlt"><span class="qpc-hafs">﴿يبدأ...﴾</span></span>.</p></div>"
  30,12,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ويوم تقوم الساعة يبلس المجرمون﴾</span></span>: يوم ظرف متعلق بيبلس، وتقوم الساعة: فعل وفاعل، وجملة <span class="hlt"><span class="qpc-hafs">﴿تقوم...﴾</span></span> في محل جر بإضافة الظرف إليها، ويبلس المجرمون: فعل وفاعل.</p></div>"
  30,13,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ولم يكن لهم من شركائهم شفعاء وكانوا بشركائهم كافرين﴾</span></span>: الواو عاطفة، ولم: حرف نفي وقلب وجزم، ويكن: فعل مضارع ناقص مجزوم بلم، ولهم: خبر يكن المقدم، ومن شركائهم: جار ومجرور متعلقان بحال من شفعاء، وشفعاء: اسم يكن، وكانوا: كان فعل ماض ناقص، وواو الجماعة اسمها، وبشركائهم: جار ومجرور متعلقان بكافرين، وكافرين: خبر كانوا.</p></div>"
  30,14,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ويوم تقوم الساعة يومئذ يتفرقون﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿يوم﴾</span></span> ظرف زمان متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿يتفرقون﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿تقوم الساعة﴾</span></span> فعل وفاعل، وجملة <span class="hlt"><span class="qpc-hafs">﴿تقوم الساعة﴾</span></span> في محل جر بإضافة الظرف إليها، ويومئذ: يوم: ظرف زمان متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿يتفرقون﴾</span></span> وهو تأكيد للظرف السابق أو بدل منه، وإذٍ: اسم مبني على السكون المقدر لاشتغال المحل بتنوين العوض في محل جر مضاف إليه، والتنوين عوض عن جملة، والتقدير: يوم إذ تقوم الساعة. ويتفرقون: فعل وفاعل.</p></div>"
  30,15,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فأما الذين آمنوا وعملوا الصالحات فهم في روضة يحبرون﴾</span></span>: الفاء تفريعية، وأما: حرف شرط وتفصيل، والذين: مبتدأ، وآمنوا: فعل وفاعل وجملة <span class="hlt"><span class="qpc-hafs">﴿آمنوا﴾</span></span> صلة الموصول لا محل لها من الإعراب. والواو عاطفة، وعملوا الصالحات: فعل وفاعل ومفعول به والجملة عطف على جملة الصلة قبلها لا محل لها من الإعراب. والفاء: في جواب الشرط، وهم: مبتدأ، وفي روضة: جار ومجرور متعلقان بيحبرون، وجملة يحبرون: خبر <span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span>، والجملة خبر الذين.</p></div>"