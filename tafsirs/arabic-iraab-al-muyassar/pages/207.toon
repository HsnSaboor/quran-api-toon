quran[7]{c,v,t}:
  9,123,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿يا أيها الذين آمنوا﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿يا﴾</span></span> حرف نداء، أي: منادى نكرة مقصودة مبني على الضم في محل نصب، وها للتنبيه، والذين صفة لـ<span class="hlt"><span class="qpc-hafs">﴿أي﴾</span></span>، آمنوا: فعل وفاعل، وجملة آمنوا صلة الذين لا محل لها من الإعراب.</p><p><span class="hlt"><span class="qpc-hafs">﴿قاتلوا الذين يلونكم من الكفار﴾</span></span>: قاتلوا فعل أمر وفاعل، والذين مفعول به، وجملة يلونكم صلة الذين لا محل لها من الإعراب، ومن الكفار جار ومجرور متعلقان بمحذوف حال.</p><p><span class="hlt"><span class="qpc-hafs">﴿وليجدوا فيكم غلظة واعلموا أن الله مع المتقين﴾</span></span>: الواو عاطفة، واللام لام الأمر، ويجدوا فعل مضارع مجزوم بلام الأمر، والواو فاعل، وفيكم جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يجدوا﴾</span></span>، وغلظة مفعول به، واعلموا عطف على الأمر السابق، وأن وما في حيزها سدت مسد مفعولي اعلموا، وأن حرف ناسخ، ولفظ الجلالة اسمها، و<span class="hlt"><span class="qpc-hafs">﴿مع المتقين﴾</span></span> ظرف متعلق بمحذوف خبرها.</p></div>"
  9,124,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وإذا ما أنزلت سورة﴾</span></span>: الواو استئنافية، وإذا ظرف مستقبل متضمن معنى الشرط، وما صلة، وجملة أنزلت مضاف إليها، وسورة نائب فاعل.</p><p><span class="hlt"><span class="qpc-hafs">﴿فمنهم من يقول أيكم زادته هذه إيمانا﴾</span></span>: الفاء رابطة، و<span class="hlt"><span class="qpc-hafs">﴿منهم﴾</span></span> جار ومجرور متعلقان بمحذوف خبر مقدم، و<span class="hlt"><span class="qpc-hafs">﴿مَن﴾</span></span> مبتدأ مؤخر وهي اسم موصول، أو نكرة تامة موصوفة بجملة يقول، أي: فريق يقول، وجملة يقول صلة <span class="hlt"><span class="qpc-hafs">﴿مَن﴾</span></span> لا محل لها من الإعراب، وأيكم مبتدأ، وجملة زادته خبر، والهاء مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿هذه﴾</span></span> فاعل، وإيمانًا مفعول به ثان، وجملة <span class="hlt"><span class="qpc-hafs">﴿وإذا ما أنزلت...﴾</span></span> مستأنفة لا محل لها من الإعراب.</p><p><span class="hlt"><span class="qpc-hafs">﴿فأما الذين آمنوا فزادتهم إيمانا وهم يستبشرون﴾</span></span>: الفاء تفريعية، و<span class="hlt"><span class="qpc-hafs">﴿أما﴾</span></span> حرف شرط وتفصيل، والذين مبتدأ، وجملة آمنوا صلة الذين لا محل لها من الإعراب، والفاء رابطة، وزادتهم فعل وفاعل مستتر ومفعول به، والجملة في محل رفع خبر <span class="hlt"><span class="qpc-hafs">﴿الذين﴾</span></span>، وإيمانًا مفعول به ثان أو تمييز.</p></div>"
  9,125,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وأما الذين في قلوبهم مرض فزادتهم رجسا إلى رجسهم﴾</span></span>: أما عطف على <span class="hlt"><span class="qpc-hafs">﴿أما﴾</span></span> في الآية السابقة، والذين مبتدأ، وفي قلوبهم جار ومجرور متعلقان بمحذوف خبر مقدم، ومرض مبتدأ مؤخر، والجملة صلة الذين لا محل لها من الإعراب، <span class="hlt"><span class="qpc-hafs">﴿فزادتهم﴾</span></span> الفاء رابطة، وجملة زادتهم خبر الذين، ورجسًا مفعول به ثان، وإلى رجسهم جار ومجرور متعلقان بمحذوف صفة، أي: مضمومًا إلى رجسهم.</p><p><span class="hlt"><span class="qpc-hafs">﴿وماتوا وهم كافرون﴾</span></span>: عطف على زادتهم، والواو للحال، وجملة <span class="hlt"><span class="qpc-hafs">﴿هم كافرون﴾</span></span> من المبتدأ والخبر حالية.</p></div>"
  9,126,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿أولا يرون أنهم يفتنون في كل عام مرة أو مرتين﴾</span></span>: الهمزة للاستفهام الإنكاري التوبيخي، والواو عاطفة على مقدر، ويرون فعل مضارع وفاعل، وأن وما في حيزها سدت مسد مفعولي فعل الرؤية القلبي، وجملة يفتنون خبر إن، وفي كل عام جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يفتنون﴾</span></span>، ومرة نائب مفعول مطلق، لأنه عدده، وأو حرف عطف، و<span class="hlt"><span class="qpc-hafs">﴿مرتين﴾</span></span> عطف على <span class="hlt"><span class="qpc-hafs">﴿مرة﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿ثم لا يتوبون ولا هم يذكرون﴾</span></span>: ثم حرف عطف وتراخ، وجملة لا يتوبون عطف على يفتنون، والواو حرف عطف، و<span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> مبتدأ، وجملة يذكرون خبر.</p></div>"
  9,127,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وإذا ما أنزلت سورة نظر بعضهم إلى بعض﴾</span></span>: عطف على ما تقدم، وجملة نظر بعضهم جواب <span class="hlt"><span class="qpc-hafs">﴿إذا﴾</span></span> لا محل لها من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿إلى بعض﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿نظر﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿هل يراكم من أحد﴾</span></span>: الجملة في محل نصب، مقول قول محذوف، أي: قائلين، وجملة القول نصب على الحال، ويراكم فعل مضارع ومفعول به، ومن حرف صلة، وأحد فاعل محلاًّ.</p><p><span class="hlt"><span class="qpc-hafs">﴿ثم انصرفوا صرف الله قلوبهم بأنهم قوم لا يفقهون﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿ثم انصرفوا﴾</span></span> عطف على <span class="hlt"><span class="qpc-hafs">﴿نظر بعضهم﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿صرف الله قلوبهم﴾</span></span> يصح أن تكون إخبارية حالية، أو إنشائية دعائية، فتكون لا محل لها من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿بأنهم﴾</span></span> متعلقان بصرف، والباء للسببية، و<span class="hlt"><span class="qpc-hafs">﴿أن﴾</span></span> حرف ناسخ، والهاء اسمها، وجملة <span class="hlt"><span class="qpc-hafs">﴿لا يفقهون﴾</span></span> خبرها.</p></div>"
  9,128,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿لقد جاءكم رسول من أنفسكم﴾</span></span>: اللام جواب للقسم المحذوف، وقد حرف تحقيق، وجاءكم رسول فعل ومفعول به وفاعل، و<span class="hlt"><span class="qpc-hafs">﴿من أنفسكم﴾</span></span> جار ومجرور متعلقان بمحذوف صفة.</p><p><span class="hlt"><span class="qpc-hafs">﴿عزيز عليه ما عنتم حريص عليكم بالمؤمنين رءوف رحيم﴾</span></span>: عزيز صفة ثانية لرسول، و<span class="hlt"><span class="qpc-hafs">﴿عليه﴾</span></span> جار ومجرور متعلقان بعزيز، وما مصدرية، أو موصولة، أو عزيز خبر مقدم، و<span class="hlt"><span class="qpc-hafs">﴿ما عنتم﴾</span></span> في تأويل مصدر مبتدأ مؤخر، والجملة صفة لـ<span class="hlt"><span class="qpc-hafs">﴿رسول﴾</span></span>، وحريص صفة، و<span class="hlt"><span class="qpc-hafs">﴿عليكم﴾</span></span> جار ومجرور متعلقان بحريص، وبالمؤمنين متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿رءوف﴾</span></span>، ورءوف رحيم صفتان لـ<span class="hlt"><span class="qpc-hafs">﴿رسول﴾</span></span>.</p></div>"
  9,129,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فإن تولوا فقل حسبي الله﴾</span></span>: الفاء عاطفة، وتولوا فعل وفاعل في محل جزم فعل الشرط، والفاء رابطة، وحسبي خبر مقدم، و<span class="hlt"><span class="qpc-hafs">﴿الله﴾</span></span> مبتدأ مؤخر، والجملة مقول القول.</p><p><span class="hlt"><span class="qpc-hafs">﴿لا﴾</span></span>: نافية للجنس.</p><p><span class="hlt"><span class="qpc-hafs">﴿إله﴾</span></span>: اسمها مبني على الفتح في محل نصب.</p><p><span class="hlt"><span class="qpc-hafs">﴿إلا﴾</span></span>: أداة حصر.</p><p><span class="hlt"><span class="qpc-hafs">﴿هو﴾</span></span>: بدل من محل لا واسمها، لأن محلها الرفع على الابتداء، أو بدل من الضمير المستكن في الخبر المحذوف. جملة <span class="hlt"><span class="qpc-hafs">﴿لا إله إلا هو﴾</span></span> حالية.</p><p><span class="hlt"><span class="qpc-hafs">﴿عليه توكلت وهو رب العرش العظيم﴾</span></span>: عليه جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿توكلت﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿هو﴾</span></span> مبتدأ، ورب العرش خبر، والعظيم صفة للعرش.</p></div>"