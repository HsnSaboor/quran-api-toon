quran[25]{c,v,t}:
  76,26,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ومن الليل﴾</span></span>: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿اسجد﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿فاسجد﴾</span></span>: فعل أمر، وفاعله مستتر، تقديره: أنت.</p><p><span class="hlt"><span class="qpc-hafs">﴿له﴾</span></span>: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿اسجد﴾</span></span> أيضا.</p><p><span class="hlt"><span class="qpc-hafs">﴿وسبحه﴾</span></span>: فعل أمر وفاعله مستتر ومفعول به.</p><p><span class="hlt"><span class="qpc-hafs">﴿ليلا﴾</span></span>: ظرف متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿سبحه﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿طويلا﴾</span></span>: نعت.</p></div>"
  76,27,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span>: حرف ناسخ.</p><p><span class="hlt"><span class="qpc-hafs">﴿هؤلاء﴾</span></span>: اسم إن.</p><p><span class="hlt"><span class="qpc-hafs">﴿يحبون﴾</span></span>: فعل مضارع، وفاعل.</p><p><span class="hlt"><span class="qpc-hafs">﴿العاجلة﴾</span></span>: مفعول به، والجملة خبر إن.</p><p><span class="hlt"><span class="qpc-hafs">﴿ويذرون﴾</span></span>: الواو عاطفة، ويذرون فعل مضارع، وفاعل، والجملة عطف على ما قبلها.</p><p><span class="hlt"><span class="qpc-hafs">﴿وراءهم﴾</span></span>: ظرف مكان متعلق بمحذوف حال من المفعول مقدم عليه.</p><p><span class="hlt"><span class="qpc-hafs">﴿يوما﴾</span></span>: مفعول به.</p><p><span class="hlt"><span class="qpc-hafs">﴿ثقيلا﴾</span></span>: نعت.</p></div>"
  76,28,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿نحن﴾</span></span>: مبتدأ.</p><p><span class="hlt"><span class="qpc-hafs">﴿خلقناهم﴾</span></span>: فعل ماض وفاعل ومفعول به، والجملة خبر.</p><p><span class="hlt"><span class="qpc-hafs">﴿وشددنا﴾</span></span>: فعل ماض وفاعل.</p><p><span class="hlt"><span class="qpc-hafs">﴿أسرهم﴾</span></span>: مفعول به، والهاء مضاف إليه.</p></div>"
  76,29,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span>: حرف ناسخ.</p><p><span class="hlt"><span class="qpc-hafs">﴿هذه﴾</span></span>: اسم إن.</p><p><span class="hlt"><span class="qpc-hafs">﴿تذكرة﴾</span></span>: خبر إن.</p><p><span class="hlt"><span class="qpc-hafs">﴿فمن﴾</span></span>: الفاء عاطفة، ومن شرطية مبتدأ.</p><p><span class="hlt"><span class="qpc-hafs">﴿شاء﴾</span></span>: فعل ماضٍ في محل جزم فعل الشرط.</p><p><span class="hlt"><span class="qpc-hafs">﴿اتخذ﴾</span></span>: فعل ماضٍ في محل جزم جواب الشرط.</p><p><span class="hlt"><span class="qpc-hafs">﴿إلى ربه﴾</span></span>: جار ومجرور متعلقان بمحذوف مفعول به ثانٍ.</p><p><span class="hlt"><span class="qpc-hafs">﴿سبيلا﴾</span></span>: مفعول اتخذ الأول.</p></div>"
  76,30,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وما﴾</span></span>: الواو عاطفة، وما نافية.</p><p><span class="hlt"><span class="qpc-hafs">﴿تشاءون﴾</span></span>: فعل مضارع مرفوع، والواو فاعل، والمفعول به محذوف.</p><p><span class="hlt"><span class="qpc-hafs">﴿إلا﴾</span></span>: أداة حصر.</p><p><span class="hlt"><span class="qpc-hafs">﴿أن﴾</span></span>: مصدرية.</p><p><span class="hlt"><span class="qpc-hafs">﴿يشاء﴾</span></span>: فعل مضارع منصوب، والمصدر المؤول منصوب على الظرفية.</p><p><span class="hlt"><span class="qpc-hafs">﴿الله﴾</span></span>: فاعل.</p><p><span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span>: حرف ناسخ.</p><p><span class="hlt"><span class="qpc-hafs">﴿الله﴾</span></span>: لفظ الجلالة اسم إن.</p><p><span class="hlt"><span class="qpc-hafs">﴿كان﴾</span></span>: فعل ماض ناسخ.</p><p><span class="hlt"><span class="qpc-hafs">﴿عليما حكيما﴾</span></span>: خبران لـ<span class="hlt"><span class="qpc-hafs">﴿كان﴾</span></span>، وجملة كان خبر إن.</p></div>"
  76,31,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿يدخل﴾</span></span>: فعل مضارع مرفوع، وفاعله هو، والجملة الحالية من الله.</p><p><span class="hlt"><span class="qpc-hafs">﴿من﴾</span></span>: مفعول به.</p><p><span class="hlt"><span class="qpc-hafs">﴿يشاء﴾</span></span>: فعل مضارع، وفاعل مستتر، وجملة <span class="hlt"><span class="qpc-hafs">﴿يشاء﴾</span></span> صلة <span class="hlt"><span class="qpc-hafs">﴿مَن﴾</span></span> لا محل لها من الإعراب.</p><p><span class="hlt"><span class="qpc-hafs">﴿في رحمته﴾</span></span>: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يدخل﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿والظالمين﴾</span></span>: الواو عاطفة، والظالمين منصوب بفعل مقدّر يفسِّره ما بعده.</p><p><span class="hlt"><span class="qpc-hafs">﴿أعد﴾</span></span>: فعل ماضٍ، وفاعل مستتر.</p><p><span class="hlt"><span class="qpc-hafs">﴿لهم﴾</span></span>: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أعدّ﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿عذابا﴾</span></span>: مفعول به.</p><p><span class="hlt"><span class="qpc-hafs">﴿أليما﴾</span></span>: نعت.</p></div>"
  77,1,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿والمرسلات﴾</span></span>: الواو حرف قسم وجر، والمرسلات اسم مجرور بواو القسم وعلامة جره الكسرة، والجار والمجرور متعلقان بفعل محذوف تقديره: أُقسم.</p><p><span class="hlt"><span class="qpc-hafs">﴿عرفا﴾</span></span>: مصدر في موضع الحال من الضمير في المرسلات منصوب بالفتحة، أي: متتابعة، أو: نائب عن المفعول المطلق، أي: والمرسلات إرسالا، أو: مفعول لأجله منصوب، والعرف بمعنى المعروف، أي أرسلت للإحسان والمعروف، وقيل: أن <span class="hlt"><span class="qpc-hafs">﴿عرفا﴾</span></span> منصوب بنزع الخافض، أي: بالعرف، وجملة القسم ابتدائية لا محل لها من الإعراب.</p></div>"
  77,2,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فالعاصفات﴾</span></span>: الفاء عاطفة للتعقيب، والعاصفات معطوف على <span class="hlt"><span class="qpc-hafs">﴿المرسلات﴾</span></span> مجرور بالكسرة.</p><p><span class="hlt"><span class="qpc-hafs">﴿عصفا﴾</span></span>: مفعول مطلق منصوب بالفتحة.</p></div>"
  77,3,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿والناشرات﴾</span></span>: الواو حرف جر وقسم، والناشرات اسم مجرور بواو القسم وعلامة جره الكسرة، والجار والمجرور متعلقان بفعل محذوف تقديره: أُقسم. أو: الواو حرف عطف، والناشرات معطوف على العاصفات مجرور بالكسرة.</p><p><span class="hlt"><span class="qpc-hafs">﴿نشرا﴾</span></span>: مفعول مطلق منصوب بالفتحة، وعلى جعل الواو في <span class="hlt"><span class="qpc-hafs">﴿والناشرات﴾</span></span> للقسم تكون الجملة مستأنفة لا محل لها من الإعراب.</p></div>"
  77,4,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فالفارقات﴾</span></span>: الفاء عاطفة للتعقيب، والفارقات معطوف على <span class="hlt"><span class="qpc-hafs">﴿الناشرات﴾</span></span> مجرور بالكسرة.</p><p><span class="hlt"><span class="qpc-hafs">﴿فرقا﴾</span></span>: مفعول مطلق منصوب بالفتحة.</p></div>"
  77,5,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فالملقيات﴾</span></span>: الفاء عاطفة للتعقيب، والملقيات معطوف على <span class="hlt"><span class="qpc-hafs">﴿الفارقات﴾</span></span> مجرور بالكسرة.</p><p><span class="hlt"><span class="qpc-hafs">﴿ذكرا﴾</span></span>: مفعول به لـ<span class="hlt"><span class="qpc-hafs">﴿الملقيات﴾</span></span> منصوب بالفتحة.</p></div>"
  77,6,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿عذرا﴾</span></span>: مفعول لأجله منصوب بالفتحة، أو بدل من <span class="hlt"><span class="qpc-hafs">﴿ذكرا﴾</span></span>، أو حال من <span class="hlt"><span class="qpc-hafs">﴿الملقيات﴾</span></span>، أي: معذرين أو منذرين.</p><p><span class="hlt"><span class="qpc-hafs">﴿أو﴾</span></span>: حرف عطف.</p><p><span class="hlt"><span class="qpc-hafs">﴿نذرا﴾</span></span>: معطوف على <span class="hlt"><span class="qpc-hafs">﴿عذرا﴾</span></span> منصوب بالفتحة.</p></div>"
  77,7,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إنما﴾</span></span>: إن حرف ناسخ مبني على الفتح لا محل له من الإعراب، وما اسم موصول مبني على السكون في محل نصب اسم إن.</p><p><span class="hlt"><span class="qpc-hafs">﴿توعدون﴾</span></span>: فعل مضارع مرفوع وعلامة رفعه ثبوت النون، لأنه من الأفعال الخمسة، وهو مبني لما لم يسمَّ فاعله، وواو الجماعة ضمير مبني على السكون في محل رفع نائب فاعل، والعائد محذوف، أي: إن الذي توعدونه، وجملة توعدون صلة الموصول لا محل لها من الإعراب.</p><p><span class="hlt"><span class="qpc-hafs">﴿لواقع﴾</span></span>: اللام المزحلقة، وواقع خبر إن مرفوع بالضمة، والجملة لا محل لها من الإعراب، لأنها جواب القسم.</p></div>"
  77,8,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فإذا﴾</span></span>: الفاء استئنافية، وإذا ظرف لما يستقبل من الزمن متضمن معنى الشرط خافض لشرطه منصوب بجوابه.</p><p><span class="hlt"><span class="qpc-hafs">﴿النجوم﴾</span></span>: نائب فاعل مرفوع بالضمة لفعل محذوف يدل عليه الفعل المذكور بعده، تقديره: طُمسَت. والجملة من الفعل المحذوف ونائب الفاعل في محل جر بإضافة الظرف إليها.</p><p><span class="hlt"><span class="qpc-hafs">﴿طمست﴾</span></span>: فعل ماضٍ مبني على الفتح، وهو مبني لما لم يسمَّ فاعله، ونائب الفاعل مستتر تقديره هي، وجملة <span class="hlt"><span class="qpc-hafs">﴿طمست﴾</span></span> تفسيرية لا محل لها من الإعراب، وجملة <span class="hlt"><span class="qpc-hafs">﴿فإذا النجوم طمست﴾</span></span> مستأنفة لا محل لها من الإعراب.</p></div>"
  77,9,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وإذا﴾</span></span>: الواو حرف عطف، وإذا ظرف لما يستقبل من الزمن متضمن معنى الشرط خافض لشرطه منصوب بجوابه.</p><p><span class="hlt"><span class="qpc-hafs">﴿السماء﴾</span></span>: نائب فاعل مرفوع بالضمة لفعل محذوف يدل عليه الفعل المذكور بعده، تقديره: فُرجت. والجملة من الفعل المحذوف ونائب الفاعل في محل جر بإضافة الظرف إليها.</p><p><span class="hlt"><span class="qpc-hafs">﴿فرجت﴾</span></span>: فعل ماض مبني على الفتح، وهو مبني لما لم يسمَّ فاعله، ونائب الفاعل مستتر تقديره هي، وجملة <span class="hlt"><span class="qpc-hafs">﴿فرجت﴾</span></span> تفسيرية لا محل لها من الإعراب.</p></div>"
  77,10,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وإذا﴾</span></span>: الواو حرف عطف، وإذا ظرف لما يستقبل من الزمن متضمن معنى الشرط خافض لشرطه منصوب بجوابه.</p><p><span class="hlt"><span class="qpc-hafs">﴿الجبال﴾</span></span>: نائب فاعل مرفوع بالضمة لفعل محذوف يدل عليه الفعل المذكور بعده تقديره: نُسفت. والجملة من الفعل المحذوف ونائب الفاعل في محل جر بإضافة الظرف إليها.</p><p><span class="hlt"><span class="qpc-hafs">﴿نسفت﴾</span></span>: فعل ماض مبني على الفتح، وهو مبني لما لم يسمَّ فاعله، ونائب الفاعل مستتر تقديره هي، وجملة <span class="hlt"><span class="qpc-hafs">﴿نسفت﴾</span></span> تفسيرية لا محل لها من الإعراب.</p></div>"
  77,11,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وإذا﴾</span></span>: الواو حرف عطف، وإذا ظرف لما يستقبل من الزمن متضمن معنى الشرط خافض لشرطه منصوب بجوابه.</p><p><span class="hlt"><span class="qpc-hafs">﴿الرسل﴾</span></span>: نائب فاعل مرفوع بالضمة لفعل محذوف يدل عليه الفعل المذكور بعده تقديره: أقتت. والجملة من الفعل المحذوف ونائب الفاعل في محل جر بإضافة الظرف إليها.</p><p><span class="hlt"><span class="qpc-hafs">﴿أقتت﴾</span></span>: فعل ماض مبني على الفتح، وهو مبني لما لم يسمَّ فاعله، ونائب الفاعل مستتر تقديره هي، وجملة <span class="hlt"><span class="qpc-hafs">﴿أقتت﴾</span></span> تفسيرية لا محل لها من الإعراب.</p><p>وجواب الشرط محذوف تقديره: وقع ما توعدون، أو الجواب هو <span class="hlt"><span class="qpc-hafs">﴿لأي يوم أجلت﴾</span></span> على إضمار القول، أي: <span class="hlt"><span class="qpc-hafs">﴿يقال لأي يوم أجلت﴾</span></span>، فالفعل في الحقيقة هو الجواب.</p></div>"
  77,12,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿لأي﴾</span></span>: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أجلت﴾</span></span>، وأيّ مضاف.</p><p><span class="hlt"><span class="qpc-hafs">﴿يوم﴾</span></span>: مضاف إليه مجرور بالكسرة.</p><p><span class="hlt"><span class="qpc-hafs">﴿أجلت﴾</span></span>: فعل ماض مبني على الفتح، وهو مبني لما لم يسمَّ فاعله، ونائب الفاعل مستتر تقديره هي، والجملة مقول قول محذوف في محل نصب على الحال من الضمير المستتر في <span class="hlt"><span class="qpc-hafs">﴿أقتت﴾</span></span>، أي: يقال: لأي يوم أجلت، أو لا محل لها من الإعراب إذا جُعلت جواب إذا.</p></div>"
  77,13,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ليوم﴾</span></span>: جار ومجرور متعلقان بفعل محذوف تقديره <span class="hlt"><span class="qpc-hafs">﴿أُجِّلت﴾</span></span>، أي: أجلت ليوم الفصل، أو: بدل من <span class="hlt"><span class="qpc-hafs">﴿لأي يوم﴾</span></span>، ويوم مضاف.</p><p><span class="hlt"><span class="qpc-hafs">﴿الفصل﴾</span></span>: مضاف إليه مجرور بالكسرة.</p></div>"
  77,14,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وما﴾</span></span>: الواو استئنافية، وما اسم استفهام مبني على السكون في محل رفع مبتدأ.</p><p><span class="hlt"><span class="qpc-hafs">﴿أدراك﴾</span></span>: فعل ماضٍ مبني على الفتح المقدر على الألف، والفاعل مستتر تقديره هو يعود على <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span>، والكاف ضمير المخاطب مبني على الفتح في محل نصب مفعول به أول، وجملة <span class="hlt"><span class="qpc-hafs">﴿أدراك﴾</span></span> في محل رفع خبر المبتدأ <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span>: اسم استفهام مبني على السكون في محل رفع مبتدأ.</p><p><span class="hlt"><span class="qpc-hafs">﴿يوم﴾</span></span>: خبر <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> الثانية مرفوع بالضمة.</p><p><span class="hlt"><span class="qpc-hafs">﴿الفصل﴾</span></span>: مضاف إليه مجرور بالكسرة، وجملة <span class="hlt"><span class="qpc-hafs">﴿ما يوم الفصل﴾</span></span> من المبتدأ والخبر في محل نصب سدت مسد المفعولين الثاني والثالث لـ<span class="hlt"><span class="qpc-hafs">﴿أدراك﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿وما أدراك ...﴾</span></span> مستأنفة لا محل لها من الإعراب.</p></div>"
  77,15,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ويل﴾</span></span>: مبتدأ مرفوع بالضمة.</p><p><span class="hlt"><span class="qpc-hafs">﴿يومئذ﴾</span></span>: يوم: ظرف زمان منصوب بالفتحة متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿ويل﴾</span></span> أو بمحذوف صفة لـ<span class="hlt"><span class="qpc-hafs">﴿ويل﴾</span></span>، ويوم مضاف، وإذٍ: اسم مبني على السكون المقدر لاشتغال المحل بتنوين العوض في محل جر مضاف إليه، والتنوين عوض عن جملة محذوفة والتقدير: يوم إذ يفصل بين الخلائق.</p><p><span class="hlt"><span class="qpc-hafs">﴿للمكذبين﴾</span></span>: اللام حرف جر، والمكذبين اسم مجرور باللام وعلامة جره الياء، لأنه جمع مذكر سالم، والجار والمجرور متعلقان بمحذوف خبر <span class="hlt"><span class="qpc-hafs">﴿ويل﴾</span></span>، والجملة مستأنفة لا محل لها من الإعراب.</p></div>"
  77,16,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ألم﴾</span></span>: الهمزة للاستفهام التقريري، ولم حرف نفي وقلب وجزم.</p><p><span class="hlt"><span class="qpc-hafs">﴿نهلك﴾</span></span>: فعل مضارع مجزوم بـ<span class="hlt"><span class="qpc-hafs">﴿لم﴾</span></span> وعلامة جزمه السكون، وحرِّكت الكاف بالكسر لالتقاء الساكنين، وفاعله مستتر تقديره <span class="hlt"><span class="qpc-hafs">﴿نحن﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿الأولين﴾</span></span>: مفعول به منصوب بالياء، لأنه جمع مذكر سالم، والجملة مستأنفة لا محل لها من الإعراب.</p></div>"
  77,17,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ثم﴾</span></span>: حرف عطف للترتيب مع التراخي، أو استئناف.</p><p><span class="hlt"><span class="qpc-hafs">﴿نتبعهم﴾</span></span>: فعل مضارع مرفوع بالضمة، وفاعله مستتر تقديره نحن، والهاء ضمير مبني على الضم في محل نصب مفعول به أول، والميم علامة الجمع.</p><p><span class="hlt"><span class="qpc-hafs">﴿الآخرين﴾</span></span>: مفعول به ثانٍ منصوب بالياء، لأنه جمع مذكر سالم، والجملة معطوفة على جملة <span class="hlt"><span class="qpc-hafs">﴿ألم نهلك...﴾</span></span>، أو مستأنفة، وهي على كلا الوجهين لا محل لها من الإعراب.</p></div>"
  77,18,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿كذلك﴾</span></span>: جار ومجرور متعلقان بمصدر محذوف، أي: مثل ذلك الفعل نفعل.</p><p><span class="hlt"><span class="qpc-hafs">﴿نفعل﴾</span></span>: فعل مضارع مرفوع بالضمة، وفاعله مستتر تقديره <span class="hlt"><span class="qpc-hafs">﴿نحن﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿بالمجرمين﴾</span></span>: الباء حرف جر، والمجرمين اسم مجرور بالباء وعلامة جره الياء، لأنه جمع مذكر سالم والجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿نفعل﴾</span></span>، والجملة مستأنفة لا محل لها من الإعراب.</p></div>"
  77,19,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ويل﴾</span></span>: مبتدأ مرفوع بالضمة.</p><p><span class="hlt"><span class="qpc-hafs">﴿يومئذ﴾</span></span>: يوم: ظرف زمان منصوب بالفتحة متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿ويل﴾</span></span> أو بمحذوف صفة لـ<span class="hlt"><span class="qpc-hafs">﴿ويل﴾</span></span>، ويوم مضاف، وإذٍ: اسم مبني على السكون المقدر لاشتغال المحل بتنوين العوض في محل جر مضاف إليه، والتنوين عوض عن جملة محذوفة والتقدير: يوم إذ يفصل بين الخلائق.</p><p><span class="hlt"><span class="qpc-hafs">﴿للمكذبين﴾</span></span>: اللام حرف جر، والمكذبين اسم مجرور باللام وعلامة جره الياء، لأنه جمع مذكر سالم، والجار والمجرور متعلقان بمحذوف خبر <span class="hlt"><span class="qpc-hafs">﴿ويل﴾</span></span>، والجملة مستأنفة لا محل لها من الإعراب.</p></div>"