quran[8]{c,v,t}:
  3,158,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ولئن متم أو قتلتم﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿ولئن﴾</span></span> الواو عاطفة، واللام موطئة للقسم المقدر، وإن شرطية، و<span class="hlt"><span class="qpc-hafs">﴿متم﴾</span></span> فعل ماض في محل جزم لأنه فعل الشرط، والتاء فاعل، والميم علامة الجمع، و<span class="hlt"><span class="qpc-hafs">﴿أو﴾</span></span> حرف عطف، و<span class="hlt"><span class="qpc-hafs">﴿قتلتم﴾</span></span> فعل ماض مبني لما لم يسمَّ فاعله، والتاء نائب فاعل، والميم علامة الجمع.</p><p><span class="hlt"><span class="qpc-hafs">﴿لإلى الله تحشرون﴾</span></span>: اللام ومدخولها جواب القسم، وجواب الشرط محذوف لدلالة جواب القسم عليه ووفائه بمعناه، <span class="hlt"><span class="qpc-hafs">﴿وإلى الله﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تحشرون﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿تحشرون﴾</span></span> فعل مضارع مبني لما لم يسمَّ فاعله، وواو الجماعة نائب فاعل.</p></div>"
  3,159,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فبما رحمة من الله لنت لهم﴾</span></span>: الفاء استئنافية، والكلام بعدها مستأنف لا محل له من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿بما رحمة﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿لنت﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> صلة للتوكيد، ومن الله: جار ومجرور متعلقان بمحذوف صفة لرحمة، ولنت فعل ماض مبني على السكون، والتاء فاعل، ولهم: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿لنت﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿ولو كنت فظا غليظ القلب لانفضوا من حولك﴾</span></span>: الواو عاطفة على محذوف مقدر، أي: لنت ولو لم تكن لينًا، و<span class="hlt"><span class="qpc-hafs">﴿لو﴾</span></span> شرطية، وكنت: فعل ماض ناقص ناسخ، والتاء اسمها، و<span class="hlt"><span class="qpc-hafs">﴿فظًّا﴾</span></span> خبرها، ولانفضوا: اللام واقعة في جواب <span class="hlt"><span class="qpc-hafs">﴿لو﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿انفضوا﴾</span></span> فعل وفاعل، والجملة لا محل لها من الإعراب، لأنها جواب شرط غير جازم، ومن حولك: جار ومجرور متعلقان بانفضوا.</p><p><span class="hlt"><span class="qpc-hafs">﴿فاعف عنهم واستغفر لهم﴾</span></span>: الفاء هي الفصيحة، و<span class="hlt"><span class="qpc-hafs">﴿اعف﴾</span></span> فعل أمر مبني على حذف حرف العلة، وفاعله: أنت، وعنهم: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿اعف﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿واستغفر﴾</span></span> عطف على <span class="hlt"><span class="qpc-hafs">﴿اعف﴾</span></span>، ولهم: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿استغفر﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿وشاورهم في الأمر﴾</span></span>: عطف أيضًا، و<span class="hlt"><span class="qpc-hafs">﴿في الأمر﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿شاورهم﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿فإذا عزمت فتوكل على الله﴾</span></span>: الفاء عاطفة، أو استئنافية والجملة بعدها مستأنفة لا محل لها من الإعراب، وإذا ظرف لما يستقبل من الزمن، وجملة <span class="hlt"><span class="qpc-hafs">﴿عزمت﴾</span></span> في محل جر بالإضافة، و<span class="hlt"><span class="qpc-hafs">﴿فتوكل﴾</span></span> الفاء رابطة لجواب إذا، و<span class="hlt"><span class="qpc-hafs">﴿توكل﴾</span></span> فعل أمر، والجملة لا محل لها من الإعراب، لأنها جواب شرط غير جازم، و<span class="hlt"><span class="qpc-hafs">﴿على الله﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿توكل﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿إن الله يحب المتوكلين﴾</span></span>: الجملة تعليلية لا محل لها من الإعراب، وإن حرف ناسخ، ولفظ الجلالة اسمها، وجملة <span class="hlt"><span class="qpc-hafs">﴿يحب المتوكلين﴾</span></span> خبرها.</p></div>"
  3,160,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إن ينصركم الله فلا غالب لكم﴾</span></span>: كلام مستأنف لا محل له من الإعراب، وإن شرطية، وينصركم فعل الشرط، والكاف ضمير متصل في محل نصب مفعول به، ولفظ الجلالة فاعل، فلا: الفاء رابطة لجواب الشرط، و<span class="hlt"><span class="qpc-hafs">﴿لا﴾</span></span> نافية للجنس تعمل عمل إن، و<span class="hlt"><span class="qpc-hafs">﴿غالب﴾</span></span> اسمها المبني على الفتح، وجملة <span class="hlt"><span class="qpc-hafs">﴿فلا غالب لكم﴾</span></span> في محل جزم جواب الشرط، و<span class="hlt"><span class="qpc-hafs">﴿لكم﴾</span></span> جار ومجرور متعلقان بمحذوف خبرها.</p><p><span class="hlt"><span class="qpc-hafs">﴿وإن يخذلكم فمن ذا الذي ينصركم من بعده﴾</span></span>: الواو عاطفة، وإن شرطية، و<span class="hlt"><span class="qpc-hafs">﴿يخذلكم﴾</span></span> فعل الشرط، و<span class="hlt"><span class="qpc-hafs">﴿فمن﴾</span></span> الفاء رابطة لجواب الشرط، و<span class="hlt"><span class="qpc-hafs">﴿من﴾</span></span> اسم استفهام إنكاري في محل رفع مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿ذا﴾</span></span> اسم إشارة في محل رفع خبر <span class="hlt"><span class="qpc-hafs">﴿من﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿الذي﴾</span></span> اسم موصول في محل رفع بدل من اسم الإشارة، و<span class="hlt"><span class="qpc-hafs">﴿من بعده﴾</span></span> جار ومجرور متعلقان بمحذوف حال، وجملة <span class="hlt"><span class="qpc-hafs">﴿فمن﴾</span></span> الاسمية في محل جزم جواب الشرط، وجملة ينصركم صلة <span class="hlt"><span class="qpc-hafs">﴿الذي﴾</span></span> لا محل لها من الإعراب.</p><p><span class="hlt"><span class="qpc-hafs">﴿وعلى الله فليتوكل المؤمنون﴾</span></span>: الواو عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿على الله﴾</span></span> جار ومجرور متعلقان بيتوكل، والفاء لتأكيد الاستئناف، واللام لام الأمر، ويتوكل فعل مضارع مجزوم باللام، والمؤمنون فاعل.</p></div>"
  3,161,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وما كان لنبي أن يغل﴾</span></span>: الواو استئنافية، والكلام بعدها مستأنف لا محل له من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> نافية، و<span class="hlt"><span class="qpc-hafs">﴿كان﴾</span></span> فعل ماض ناقص مبني على الفتح، و<span class="hlt"><span class="qpc-hafs">﴿لنبي﴾</span></span> جار ومجرور متعلقان بمحذوف خبر مقدم، والمصدر المؤول من <span class="hlt"><span class="qpc-hafs">﴿أن يغل﴾</span></span> اسمها المؤخر.</p><p><span class="hlt"><span class="qpc-hafs">﴿ومن يغلل يأت بما غل يوم القيامة﴾</span></span>: الواو استئنافية، والكلام بعدها مستأنف لا محل له من الإعراب. و<span class="hlt"><span class="qpc-hafs">﴿من﴾</span></span> اسم شرط جازم مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿يغلل﴾</span></span> فعل الشرط، و<span class="hlt"><span class="qpc-hafs">﴿يأت﴾</span></span> جوابه، و<span class="hlt"><span class="qpc-hafs">﴿بما﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يأت﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿غل﴾</span></span> صلة الموصول لا محل لها من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿يوم القيامة﴾</span></span> ظرف زمان متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿يأت﴾</span></span> أيضًا، وجملة فعل الشرط وجوابه خبر <span class="hlt"><span class="qpc-hafs">﴿من﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿ثم توفى كل نفس ما كسبت﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿ثم﴾</span></span> حرف عطف للترتيب مع التراخي، و<span class="hlt"><span class="qpc-hafs">﴿توفى﴾</span></span> فعل مضارع مبني لما لم يسمَّ فاعله معطوفة على الجملة الشرطية، و<span class="hlt"><span class="qpc-hafs">﴿كل نفس﴾</span></span> نائب فاعل، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> اسم موصول في محل نصب مفعول به ثان، وجملة <span class="hlt"><span class="qpc-hafs">﴿كسبت﴾</span></span> صلة الموصول لا محل لها من الإعراب.</p><p><span class="hlt"><span class="qpc-hafs">﴿وهم لا يظلمون﴾</span></span>: الواو استئنافية، أو حالية، و<span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> مبتدأ، وجملة لا يظلمون خبر <span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span>، والجملة استئنافية لا محل لها من الإعراب، أو حالية.</p></div>"
  3,162,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿أفمن اتبع رضوان الله﴾</span></span>: الهمزة للاستفهام الإنكاري، والفاء عاطفة على محذوف، و<span class="hlt"><span class="qpc-hafs">﴿من﴾</span></span> اسم موصول مبتدأ، وجملة <span class="hlt"><span class="qpc-hafs">﴿اتبع﴾</span></span> صلة الموصول لا محل لها من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿رضوان الله﴾</span></span> مفعول به لـ<span class="hlt"><span class="qpc-hafs">﴿اتبع﴾</span></span>، والجملة معطوفة على المحذوف.</p><p><span class="hlt"><span class="qpc-hafs">﴿كمن باء بسخط من الله﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿كمن﴾</span></span> الكاف: اسم بمعنى مثل مبني على الفتح في محل رفع خبر المبتدأ، ومَن: اسم موصول في محل جر مضاف إليه، وجملة <span class="hlt"><span class="qpc-hafs">﴿باء﴾</span></span> صلة الموصول لا محل لها من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿بسخط﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿باء﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿من الله﴾</span></span> جار ومجرور متعلقان بمحذوف صفة.</p><p><span class="hlt"><span class="qpc-hafs">﴿ومأواه جهنم وبئس المصير﴾</span></span>: الواو حرف عطف، و<span class="hlt"><span class="qpc-hafs">﴿مأواه﴾</span></span> مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿جهنم﴾</span></span> خبره، والجملة لا محل لها من الإعراب، عطف على الصلة، <span class="hlt"><span class="qpc-hafs">﴿وبئس﴾</span></span> الواو عاطفة أيضًا، و<span class="hlt"><span class="qpc-hafs">﴿بئس﴾</span></span> فعل ماض جامد لإنشاء الذم، و<span class="hlt"><span class="qpc-hafs">﴿المصير﴾</span></span> فاعل، والمخصوص بالذم محذوف، أي: جهنم.</p></div>"
  3,163,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿هم درجات عند الله﴾</span></span>: كلام مستأنف لا محل له من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿درجات﴾</span></span> خبر، و<span class="hlt"><span class="qpc-hafs">﴿عند الله﴾</span></span> ظرف متعلق بمحذوف صفة لدرجات.</p><p><span class="hlt"><span class="qpc-hafs">﴿والله بصير بما يعملون﴾</span></span>: الواو استئنافية، ولفظ الجلالة مبتدأ، وبصير خبر، و<span class="hlt"><span class="qpc-hafs">﴿بما﴾</span></span> جار ومجرور متعلقان ببصير، وجملة <span class="hlt"><span class="qpc-hafs">﴿يعملون﴾</span></span> صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> لا محل لها من الإعراب، وجملة <span class="hlt"><span class="qpc-hafs">﴿والله بصير﴾</span></span> مستأنفة لا محل لها من الإعراب.</p></div>"
  3,164,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿لقد من الله على المؤمنين﴾</span></span>: اللام جواب لقسم محذوف، و<span class="hlt"><span class="qpc-hafs">﴿قد﴾</span></span> حرف تحقيق، و<span class="hlt"><span class="qpc-hafs">﴿من الله﴾</span></span> فعل وفاعل، و<span class="hlt"><span class="qpc-hafs">﴿على المؤمنين﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿من﴾</span></span>، والكلام مستأنف لا محل له من الإعراب.</p><p><span class="hlt"><span class="qpc-hafs">﴿إذ بعث فيهم رسولا من أنفسهم﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿إذ﴾</span></span> ظرف لما مضى من الزمن متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿مَنَّ﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿بعث﴾</span></span> في محل جر بالإضافة، و<span class="hlt"><span class="qpc-hafs">﴿فيهم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿بعث﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿رسولًا﴾</span></span> مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿من أنفسهم﴾</span></span> جار ومجرور متعلقان بمحذوف صفة لـ<span class="hlt"><span class="qpc-hafs">﴿رسولًا﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿يتلو عليهم آياته﴾</span></span>: الجملة صفة ثانية لـ<span class="hlt"><span class="qpc-hafs">﴿رسولًا﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿عليهم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يتلو﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿ويزكيهم ويعلمهم الكتاب والحكمة﴾</span></span>: الجملتان معطوفتان على <span class="hlt"><span class="qpc-hafs">﴿يتلو﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿الكتاب﴾</span></span> مفعول به ثان لـ<span class="hlt"><span class="qpc-hafs">﴿يعلمهم﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿الحكمة﴾</span></span> عطف على <span class="hlt"><span class="qpc-hafs">﴿الكتاب﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿وإن كانوا من قبل لفي ضلال مبين﴾</span></span>: الواو حالية، و<span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span> مخففة من الثقيلة مهملة لا عمل لها، وكانوا فعل ماض ناقص ناسخ، والواو اسمها، و<span class="hlt"><span class="qpc-hafs">﴿من قبل﴾</span></span> جار ومجرور متعلقان بمحذوف حال، و<span class="hlt"><span class="qpc-hafs">﴿قبل﴾</span></span> ظرف مبني على الضم في محل جر بـ<span class="hlt"><span class="qpc-hafs">﴿من﴾</span></span>، ولفي اللام هي الفارقة، و<span class="hlt"><span class="qpc-hafs">﴿في ضلال﴾</span></span> جار ومجرور متعلقان بمحذوف خبر كان، و<span class="hlt"><span class="qpc-hafs">﴿مبين﴾</span></span> نعت.</p></div>"
  3,165,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿أولما أصابتكم مصيبة﴾</span></span>: الهمزة للاستفهام الإنكاري والتقريع، والواو عاطفة على ما تقدم من قصة أحد، ولما ظرفية حينية، متعلقة بـ<span class="hlt"><span class="qpc-hafs">﴿قلتم﴾</span></span>، أو رابطة فهي حرف، و<span class="hlt"><span class="qpc-hafs">﴿أصابتكم﴾</span></span> فعل ماض ومفعول به، ومصيبة فاعل.</p><p><span class="hlt"><span class="qpc-hafs">﴿قد أصبتم مثليها﴾</span></span>: الجملة صفة لمصيبة، وقد حرف تحقيق، وأصبتم فعل وفاعل، ومثليها مفعول به.</p><p><span class="hlt"><span class="qpc-hafs">﴿قلتم أنى هذا﴾</span></span>: جملة <span class="hlt"><span class="qpc-hafs">﴿قلتم﴾</span></span> لا محل لها من الإعراب، لأنها جواب شرط غير جازم، و<span class="hlt"><span class="qpc-hafs">﴿أنى﴾</span></span> اسم استفهام خبر مقدم، وهذا مبتدأ مؤخر، والجملة الاسمية في محل نصب مقول القول.</p><p><span class="hlt"><span class="qpc-hafs">﴿قل هو من عند أنفسكم﴾</span></span>: جملة القول مقول للقول، و<span class="hlt"><span class="qpc-hafs">﴿هو﴾</span></span> مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿من عند أنفسكم﴾</span></span> جار ومجرور متعلقان بمحذوف خبر.</p><p><span class="hlt"><span class="qpc-hafs">﴿إن الله على كل شيء قدير﴾</span></span>: إن حرف ناسخ، ولفظ الجلالة اسمها، وقدير خبرها، و<span class="hlt"><span class="qpc-hafs">﴿على كل شيء﴾</span></span> جار ومجرور متعلقان بقدير، والجملة تعليلية لا محل لها من الإعراب.</p></div>"