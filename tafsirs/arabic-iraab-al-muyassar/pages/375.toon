quran[23]{c,v,t}:
  26,184,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿واتقوا الذي خلقكم والجبلة الأولين﴾</span></span>: الواو عاطفة، واتقوا فعل أمر، والواو فاعل، والذي مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿خلقكم﴾</span></span> فعل ماض، والفاعل ضمير مستتر تقديره: هو، والكاف مفعول به، وجملة خلقكم صلة الموصول لا محل لها من الإعراب. والجبلة عطف على <span class="hlt"><span class="qpc-hafs">﴿الذي﴾</span></span>، والأولين صفة للجبلة.</p></div>"
  26,185,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قالوا إنما أنت من المسحرين﴾</span></span>: قالوا فعل ماض، والواو فاعل، و<span class="hlt"><span class="qpc-hafs">﴿إنما﴾</span></span> كافة ومكفوفة، وأنت مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿من المسحرين﴾</span></span> جار ومجرور متعلقان بمحذوف خبر، والجملة مقول القول.</p></div>"
  26,186,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وما أنت إلا بشر مثلنا﴾</span></span>: الواو عاطفة، وما نافية، وأنت مبتدأ، وإلا أداة حصر، وبشر خبر، ومثلنا نعت لبشر.</p><p><span class="hlt"><span class="qpc-hafs">﴿وإن نظنك لمن الكاذبين﴾</span></span>: الواو حرف عطف، وإن مخففة من الثقيلة مهملة، ونظنك فعل مضارع مرفوع، والفاعل مستتر تقديره: نحن، والكاف مفعول به، واللام الفارقة، و<span class="hlt"><span class="qpc-hafs">﴿من الكاذبين﴾</span></span> جار ومجرور متعلقان بمحذوف مفعول به ثان لـ<span class="hlt"><span class="qpc-hafs">﴿نظنك﴾</span></span>.</p></div>"
  26,187,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فأسقط علينا كسفا من السماء إن كنت من الصادقين﴾</span></span>: الفاء الفصيحة، وأسقط فعل أمر، و<span class="hlt"><span class="qpc-hafs">﴿علينا﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أسقط﴾</span></span>، وكسفًا مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿من السماء﴾</span></span> جار ومجرور متعلقان بمحذوف صفة لـ<span class="hlt"><span class="qpc-hafs">﴿كسفًا﴾</span></span>، وإن شرطية، وكنت فعل ماض ناقص في محل جزم فعل الشرط، والتاء اسمها، و<span class="hlt"><span class="qpc-hafs">﴿من الصادقين﴾</span></span> جار ومجرور متعلقان بمحذوف خبرها، وجواب الشرط محذوف دل عليه ما قبله، أي: فأسقط علينا.</p></div>"
  26,188,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قال ربي أعلم بما تعملون﴾</span></span>: قال فعل ماض، و<span class="hlt"><span class="qpc-hafs">﴿ربي﴾</span></span> مبتدأ، وأعلم خبر، والجملة مقول القول، و<span class="hlt"><span class="qpc-hafs">﴿بما﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أعلم﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿تعملون﴾</span></span> فعل مضارع مرفوع، والواو فاعل، وجملة <span class="hlt"><span class="qpc-hafs">﴿تعملون﴾</span></span> صلة الموصول لا محل لها من الإعراب.</p></div>"
  26,189,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فكذبوه فأخذهم عذاب يوم الظلة﴾</span></span>: الفاء عاطفة، وكذبوه فعل ماض، والواو فاعل، والهاء مفعول به، فأخذهم فعل ماض، والهاء مفعول به، وعذاب يوم الظلة فاعل.</p><p><span class="hlt"><span class="qpc-hafs">﴿إنه كان عذاب يوم عظيم﴾</span></span>: إن حرف ناسخ، والهاء اسمها، وجملة كان خبرها، واسم كان ضمير مستتر تقديره: هو، وعذاب خبر كان، ويوم مضاف إليه، وعظيم صفة.</p></div>"
  26,190,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إن في ذلك لآية﴾</span></span>: إن حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿في ذلك﴾</span></span> جار ومجرور متعلقان بمحذوف خبرها المقدم، واللام المزحلقة، وآية اسمها المؤخر.</p><p><span class="hlt"><span class="qpc-hafs">﴿وما كان أكثرهم مؤمنين﴾</span></span>: الواو حالية، وما نافية، وكان فعل ماض ناقص ناسخ، وأكثرهم اسم كان، ومؤمنين خبرها.</p></div>"
  26,191,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وإن ربك لهو العزيز الرحيم﴾</span></span>: الواو استئنافية، والجملة بعدها مستأنفة لا محل لها من الإعراب، وإن حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿ربك﴾</span></span> اسمها، واللام المزحلقة، و<span class="hlt"><span class="qpc-hafs">﴿هو﴾</span></span> ضمير فصل، والعزيز خبر إن، والرحيم خبر ثان، أو <span class="hlt"><span class="qpc-hafs">﴿هو﴾</span></span> مبتدأ، والعزيز خبر <span class="hlt"><span class="qpc-hafs">﴿هو﴾</span></span>، والرحيم خبر ثان، والجملة خبر إن.</p></div>"
  26,192,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وإنه لتنزيل رب العالمين﴾</span></span>: الواو استئنافية، والجملة بعدها مستأنفة لا محل لها من الإعراب، والضمير يعود على القرآن، وإن حرف ناسخ، والهاء اسمها، واللام المزحلقة، و<span class="hlt"><span class="qpc-hafs">﴿تنزيل رب العالمين﴾</span></span> خبرها.</p></div>"
  26,193,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿نزل به الروح الأمين﴾</span></span>: نزل فعل ماض، و<span class="hlt"><span class="qpc-hafs">﴿به﴾</span></span> جار ومجرور متعلقان بمحذوف حال، أي: متلبسًا به، فالباء للملابسة، والروح فاعل، والأمين صفة، والجملة صفة لتنزيل.</p></div>"
  26,194,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿على قلبك لتكون من المنذرين﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿على قلبك﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿نزل﴾</span></span>، واللام للتعليل، و<span class="hlt"><span class="qpc-hafs">﴿تكون﴾</span></span> فعل مضارع ناقص منصوب بأن مضمرة بعد اللام، والمصدر المؤول من أن والفعل مجرور باللام، والجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿نزل﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿من المنذرين﴾</span></span> جار ومجرور متعلقان بمحذوف خبر <span class="hlt"><span class="qpc-hafs">﴿تكون﴾</span></span>.</p></div>"
  26,195,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿بلسان عربي مبين﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿بلسان﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿المنذرين﴾</span></span>، أو بدل من قوله: <span class="hlt"><span class="qpc-hafs">﴿به﴾</span></span> بإعادة العامل، أي: نزل بلسان عربي، وعربي صفة، ومبين صفة ثانية.</p></div>"
  26,196,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وإنه لفي زبر الأولين﴾</span></span>: عطف على ما تقدم، وإن حرف ناسخ، والهاء اسمها، واللام المزحلقة، و<span class="hlt"><span class="qpc-hafs">﴿في زبر الأولين﴾</span></span> جار ومجرور متعلقان بمحذوف خبر إن.</p></div>"
  26,197,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿أولم يكن لهم آية أن يعلمه علماء بني إسرائيل﴾</span></span>: الهمزة للاستفهام، والواو عاطفة على مقدر، ولم حرف نفي وقلب وجزم، و<span class="hlt"><span class="qpc-hafs">﴿يكن﴾</span></span> فعل مضارع ناقص مجزوم بـ<span class="hlt"><span class="qpc-hafs">﴿لم﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿لهم﴾</span></span> جار ومجرور متعلقان بمحذوف حال، لأنه كان في الأصل صفة لـ<span class="hlt"><span class="qpc-hafs">﴿آية﴾</span></span> وتقدم عليها، وآية خبر يكن المقدم، و<span class="hlt"><span class="qpc-hafs">﴿أن يعلمه﴾</span></span> في تأويل مصدر اسم يكن، وعلماء بني إسرائيل فاعل يعلمه.</p></div>"
  26,198,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ولو نزلناه على بعض الأعجمين﴾</span></span>: الواو عاطفة، ولو شرطية امتناعية، ونزلناه فعل ماض، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> فاعل، والهاء مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿على بعض الأعجمين﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿نزلناه﴾</span></span>.</p></div>"
  26,199,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فقرأه عليهم﴾</span></span>: الفاء عاطفة، وقرأه فعل ماض، وفاعل مستتر يعود على <span class="hlt"><span class="qpc-hafs">﴿بعض الأعجمين﴾</span></span>، والهاء مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿عليهم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿قرأه﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿ما كانوا به مؤمنين﴾</span></span>: ما نافية، وكانوا فعل ماض ناقص ناسخ، والواو اسمها، و<span class="hlt"><span class="qpc-hafs">﴿به﴾</span></span> جار ومجرور متعلقان بمؤمنين، و<span class="hlt"><span class="qpc-hafs">﴿مؤمنين﴾</span></span> خبر كانوا، وجملة <span class="hlt"><span class="qpc-hafs">﴿ما كانوا به مؤمنين﴾</span></span> لا محل لها من الإعراب، لأنها جواب شرط غير جازم.</p></div>"
  26,200,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿كذلك سلكناه في قلوب المجرمين﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿كذلك﴾</span></span> الكاف اسم بمعنى مثل مبني على الفتح في محل نصب نعت لمصدر مقدر مؤكد لفعل محذوف، وتقدير الكلام: سلكناه سلكًا مثل هذا السلك البديع المذكور، أي: أدخلنا القرآن في قلوب المجرمين ففهموا معانيه وعرفوا فصاحته. و<span class="hlt"><span class="qpc-hafs">﴿ذلك﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿ذا﴾</span></span> اسم إشارة في محل جر مضاف إليه، واللام للبعد، والكاف حرف خطاب، و<span class="hlt"><span class="qpc-hafs">﴿سلكناه﴾</span></span> فعل ماض، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> فاعل، والهاء مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿في قلوب المجرمين﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿سلكناه﴾</span></span>.</p></div>"
  26,201,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿لا يؤمنون به حتى يروا العذاب الأليم﴾</span></span>: الجملة مستأنفة لا محل لها من الإعراب، أو حالية من الهاء في <span class="hlt"><span class="qpc-hafs">﴿سلكناه﴾</span></span>، أو حال من المجرمين، ولا نافية، ويؤمنون فعل مضارع مرفوع، والواو فاعل، و<span class="hlt"><span class="qpc-hafs">﴿به﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يؤمنون﴾</span></span>، وحتى حرف غاية وجر، ويروا فعل مضارع منصوب بأن مضمرة بعد حتى، والمصدر المؤول من أن والفعل مجرور بـ<span class="hlt"><span class="qpc-hafs">﴿حتى﴾</span></span>، والجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يؤمنون﴾</span></span>، والواو في <span class="hlt"><span class="qpc-hafs">﴿يروا﴾</span></span> فاعل، والعذاب مفعول به، والأليم صفة.</p></div>"
  26,202,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فيأتيهم بغتة﴾</span></span>: الفاء حرف للتعقيب، ويأتيهم فعل مضارع مرفوع، وهو معطوف على يروا، والفاعل مستتر تقديره: هو، والهاء مفعول به، وبغتة حال.</p><p><span class="hlt"><span class="qpc-hafs">﴿وهم لا يشعرون﴾</span></span>: الواو حالية، و<span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> مبتدأ، وجملة لا يشعرون خبر، والجملة الاسمية في محل نصب حال.</p></div>"
  26,203,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فيقولوا هل نحن منظرون﴾</span></span>: الفاء عاطفة، ويقولوا فعل مضارع منصوب عطف على يأتيهم، والواو فاعل، وهل حرف استفهام معناه التحسر، ونحن مبتدأ، ومنظرون خبر، والجملة مقول القول.</p></div>"
  26,204,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿أفبعذابنا يستعجلون﴾</span></span>: الهمزة للاستفهام، والفاء عاطفة على مقدر يقتضيه المقام، والتقدير: أيغفلون عن ذلك مع تحققه وتقرره فيستعجلون؟ والجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يستعجلون﴾</span></span>، ويستعجلون فعل مضارع مرفوع، والواو فاعل.</p></div>"
  26,205,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿أفرأيت إن متعناهم سنين﴾</span></span>: الهمزة للاستفهام، والفاء استئنافية، والجملة بعدها مستأنفة لا محل لها من الإعراب، وقيل الفاء عاطفة، والجملة معطوفة على <span class="hlt"><span class="qpc-hafs">﴿يقولوا﴾</span></span>، ورأيت: فعل ماض، والتاء: فاعل رأيت، وإن شرطية، ومتعناهم: فعل ماض، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> فاعل، والهاء: مفعول به، وسنين: ظرف منصوب بالياء متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿متعناهم﴾</span></span>، وجواب الشرط محذوف دل عليه ما سد مسد مفعولي <span class="hlt"><span class="qpc-hafs">﴿رأيت﴾</span></span>، وهو قوله تعالى: <span class="hlt"><span class="qpc-hafs">﴿ما أغنى عنهم ما كانوا يمتعون﴾</span></span> الآتي بعد. والجملة الشرطية بتمامها لا محل لها من الإعراب، لأنها اعتراضية.</p></div>"
  26,206,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ثم جاءهم ما كانوا يوعدون﴾</span></span>: ثم حرف عطف، وجاءهم فعل ماض، والهاء مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> فاعل جاءهم، وجملة <span class="hlt"><span class="qpc-hafs">﴿كانوا﴾</span></span> صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> لا محل لها من الإعراب. والواو اسم كان، ويوعدون فعل مضارع مبني لما لم يسمَّ فاعله، والواو نائب فاعل، وجملة يوعدون خبر <span class="hlt"><span class="qpc-hafs">﴿كانوا﴾</span></span>.</p></div>"