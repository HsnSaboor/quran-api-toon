quran[10]{c,v,t}:
  10,79,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وقال فرعون ائتوني بكل ساحر عليم﴾</span></span>: الواو عاطفة، وقال فرعون فعل وفاعل، وائتوني فعل أمر وفاعل ومفعول به، و<span class="hlt"><span class="qpc-hafs">﴿بكل﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿ائتوني﴾</span></span>، وساحر مضاف إليه، وعليم صفة.</p></div>"
  10,80,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فلما جاء السحرة قال لهم موسى ألقوا ما أنتم ملقون﴾</span></span>: الفاء عاطفة على محذوف، أي: فأتوا بالسحرة، وجملة <span class="hlt"><span class="qpc-hafs">﴿قال لهم موسى﴾</span></span> لا محل لها من الإعراب، وألقوا فعل أمر وفاعل، وما اسم موصول مفعول به، وأنتم مبتدأ، وملقون خبر، والجملة الاسمية صلة الموصول لا محل لها من الإعراب، وجملة ألقوا مقول القول.</p></div>"
  10,81,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فلما ألقوا قال موسى ما جئتم به السحر﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> اسم موصول مبتدأ، وجملة جئتم به صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> لا محل لها من الإعراب، والسحر خبر.</p><p><span class="hlt"><span class="qpc-hafs">﴿إن الله سيبطله﴾</span></span>: إن حرف ناسخ، ولفظ الجلالة اسمها، وجملة سيبطله خبرها.</p><p><span class="hlt"><span class="qpc-hafs">﴿إن الله لا يصلح عمل المفسدين﴾</span></span>: إن حرف ناسخ، ولفظ الجلالة اسمها، وجملة لا يصلح خبرها، وإن للتعليل، وعمل المفسدين مفعول به.</p></div>"
  10,82,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ويحق الله الحق بكلماته ولو كره المجرمون﴾</span></span>: الواو عاطفة، ويحق الله فعل وفاعل، والحق مفعول به، وبكلماته جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يحق﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿ولو﴾</span></span> الواو حالية، و<span class="hlt"><span class="qpc-hafs">﴿لو﴾</span></span> وصلية، وكره المجرمون فعل وفاعل.</p></div>"
  10,83,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فما آمن لموسى إلا ذرية من قومه﴾</span></span>: الفاء عاطفة، وما نافية، وآمن فعل ماض، ولموسى جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿آمن﴾</span></span>، وإلا أداة حصر، وذرية فاعل، ومن قومه صفة.</p><p><span class="hlt"><span class="qpc-hafs">﴿على خوف من فرعون وملئهم أن يفتنهم﴾</span></span>: على بمعنى مع، وهي مع مجرورها في محل نصب على الحال، ومن فرعون جار ومجرور متعلقان بخوف، وملئهم عطف على فرعون، وإنما أعاد الضمير إليه جمعًا، لأنه بمعنى آل فرعون، و<span class="hlt"><span class="qpc-hafs">﴿أن يفتنهم﴾</span></span>: أن وما في حيزها بدل اشتمال من فرعون، أي: على خوف من فتنة فرعون، أو مفعول لأجله بعد حذف اللام.</p><p><span class="hlt"><span class="qpc-hafs">﴿وإن فرعون لعال في الأرض﴾</span></span>: الواو اعتراضية، وإن حرف ناسخ، وفرعون اسمها، واللام المزحلقة، وعال خبر إن مرفوع وعلامة رفعه الضمة المقدرة على الياء المحذوفة، وفي الأرض جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿عال﴾</span></span>. وجملة <span class="hlt"><span class="qpc-hafs">﴿إن فرعون...﴾</span></span> اعتراضية، لا محل لها من الإعراب.</p><p><span class="hlt"><span class="qpc-hafs">﴿وإنه لمن المسرفين﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿وإنه﴾</span></span> الواو عاطفة، وإن حرف ناسخ، والهاء اسمها، واللام المزحلقة، و<span class="hlt"><span class="qpc-hafs">﴿من المسرفين﴾</span></span> جار ومجرور متعلقان بمحذوف خبر إن. وجملة <span class="hlt"><span class="qpc-hafs">﴿إنه لمن المسرفين﴾</span></span> معطوفة على الاعتراضية.</p></div>"
  10,84,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وقال موسى يا قوم إن كنتم آمنتم بالله فعليه توكلوا إن كنتم مسلمين﴾</span></span>: يا قوم: يا حرف نداء، وقوم منادى مضاف لياء المتكلم، وإن شرطية، وكنتم في محل جزم فعل الشرط، والتاء اسم كان، وجملة آمنتم خبر كنتم، وبالله جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿آمنتم﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿فعليه﴾</span></span> الفاء رابطة لجواب الشرط، وعليه جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿توكلوا﴾</span></span>، وتوكلوا فعل أمر وفاعل، وإن شرطية، و<span class="hlt"><span class="qpc-hafs">﴿كنتم﴾</span></span> فعل ماض ناقص ناسخ، والتاء اسمها، ومسلمين خبرها، وجواب الشرط محذوف.</p></div>"
  10,85,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فقالوا على الله توكلنا﴾</span></span>: الفاء للعطف، وقالوا فعل وفاعل، وعلى الله جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿توكلنا﴾</span></span>، وتوكلنا فعل وفاعل.</p><p><span class="hlt"><span class="qpc-hafs">﴿ربنا لا تجعلنا فتنة للقوم الظالمين﴾</span></span>: ربنا منادى مضاف، وحرف النداء محذوف، ولا طلبية للدعاء، وتجعلنا فعل مضارع مجزوم بلا، ونا مفعول به أول، وفتنة مفعول به ثان، و<span class="hlt"><span class="qpc-hafs">﴿للقوم﴾</span></span> صفة، والظالمين صفة للقوم.</p></div>"
  10,86,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ونجنا برحمتك من القوم الكافرين﴾</span></span>: الواو عاطفة، ونج فعل طلب مبني على حذف حرف العلة، ونا مفعول به، وبرحمتك جار ومجرور متعلقان بمحذوف حال، ومن القوم جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿نجنا﴾</span></span>، والكافرين صفة لـ<span class="hlt"><span class="qpc-hafs">﴿القوم﴾</span></span>.</p></div>"
  10,87,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وأوحينا إلى موسى وأخيه أن تبوآ لقومكما بمصر بيوتا﴾</span></span>: الواو استئنافية، والجملة بعدها مستأنفة لا محل لها من الإعراب، وأوحينا فعل وفاعل، وإلى موسى جار ومجرور متعلقان بأوحينا، وأخيه عطف على موسى. و<span class="hlt"><span class="qpc-hafs">﴿أن﴾</span></span>: تفسيرية، لأن الوحي فيه معنى القول دون حروفه، والجملة بعدها تفسيرية لا محل لها من الإعراب. أو <span class="hlt"><span class="qpc-hafs">﴿أن﴾</span></span> مصدرية وهي مع ما دخلت عليه في تأويل مصدر منصوب بنزع الخافض، والجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أوحى﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿تبوآ﴾</span></span> صلة <span class="hlt"><span class="qpc-hafs">﴿أن﴾</span></span> المصدرية لا محل لها من الإعراب. ولقومكما جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تبوآ﴾</span></span>، وباعتبارها مفعولًا ثانيًا، و<span class="hlt"><span class="qpc-hafs">﴿بمصر﴾</span></span> جار ومجرور متعلقان بمحذوف حال، و<span class="hlt"><span class="qpc-hafs">﴿بيوتًا﴾</span></span> مفعول <span class="hlt"><span class="qpc-hafs">﴿تبوآ﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿واجعلوا بيوتكم قبلة وأقيموا الصلاة وبشر المؤمنين﴾</span></span>: الواو عاطفة، واجعلوا عطف على تبوآ، وبيوتكم مفعول <span class="hlt"><span class="qpc-hafs">﴿اجعلوا﴾</span></span> الأول، و<span class="hlt"><span class="qpc-hafs">﴿قبلة﴾</span></span> مفعول <span class="hlt"><span class="qpc-hafs">﴿اجعلوا﴾</span></span> الثاني، و<span class="hlt"><span class="qpc-hafs">﴿أقيموا الصلاة﴾</span></span> فعل أمر وفاعل ومفعول به، وبشر المؤمنين عطف أيضًا.</p></div>"
  10,88,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وقال موسى ربنا إنك آتيت فرعون وملأه زينة وأموالا في الحياة الدنيا﴾</span></span>: قال موسى فعل وفاعل، وربنا منادى مضاف حذف منه حرف النداء، وإن حرف ناسخ، والكاف اسمها، وجملة آتيت خبر إن، وفرعون مفعول به، وملأه عطف على فرعون، وزينة مفعول به ثان، وأموالًا عطف على زينة، و<span class="hlt"><span class="qpc-hafs">﴿في الحياة الدنيا﴾</span></span> جار ومجرور متعلقان بمحذوف صفة لزينة.</p><p><span class="hlt"><span class="qpc-hafs">﴿ربنا ليضلوا عن سبيلك﴾</span></span>: ربنا منادى مضاف، واللام لام الصيرورة والعاقبة، أي: آتيتهم النعم المذكورة ليشكروها ويتبعوا سبيلك، فكان عاقبة أمرهم أنهم كفروها وضلوا عن سبيلك، أو اللام لام العلة، والمعنى: أنك آتيتهم ما آتيتهم لتستدرجهم، وقيل:  اللام للدعاء عليهم بأن يبقوا على ما هم عليه من الضلال، وعن سبيلك جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يضلوا﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿ربنا اطمس على أموالهم واشدد على قلوبهم﴾</span></span>: اطمس فعل دعاء، وفاعله: أنت، وعلى قلوبهم جار ومجرور متعلقان باطمس، <span class="hlt"><span class="qpc-hafs">﴿واشدد على قلوبهم﴾</span></span> عطف على <span class="hlt"><span class="qpc-hafs">﴿اطمس على أموالهم﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿فلا يؤمنوا حتى يروا العذاب الأليم﴾</span></span>: يؤمنوا: منصوب بأن مضمرة بعد فاء السببية العاطفة، والمصدر المؤول من أن والفعل معطوف على مصدر مفهوم من الدعاء السابق تقديره: <span class="hlt"><span class="qpc-hafs">﴿ليكن منك شد على قلوبهم فعدم إيمان منهم﴾</span></span>. أو بالعطف على قوله: <span class="hlt"><span class="qpc-hafs">﴿ليضلوا﴾</span></span>، وجملة: <span class="hlt"><span class="qpc-hafs">﴿ربنا اطمس على أموالهم واشد على قلوبهم﴾</span></span> اعتراضية لا محل لها من الإعراب، أو أن المصدر المؤول مجزوم باعتباره جوابا للدعاء. وحتى: حرف غاية وجر، ويروا مضارع منصوب بأن مضمرة بعد حتى، والمصدر المؤول من أن والفعل مجرور، والجار والمجرور متعلقان باشدد، والواو فاعل، والعذاب مفعول به، والأليم صفة.</p></div>"