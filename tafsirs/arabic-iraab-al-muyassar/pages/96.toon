quran[8]{c,v,t}:
  4,106,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿واستغفر الله﴾</span></span>: عطف على ما تقدم، والواو عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿استغفر الله﴾</span></span> فعل ومفعول به، والفاعل أنت.</p><p><span class="hlt"><span class="qpc-hafs">﴿إن الله كان غفورا رحيما﴾</span></span>: إن حرف ناسخ، ولفظ الجلالة اسمها، وكان فعل ماض ناقص ناسخ، واسمها مستتر تقديره: هو، وغفورا خبر <span class="hlt"><span class="qpc-hafs">﴿كان﴾</span></span> الأول، ورحيما خبرها الثاني، وجملة <span class="hlt"><span class="qpc-hafs">﴿كان غفورا رحيما﴾</span></span> خبر إن.</p></div>"
  4,107,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ولا تجادل عن الذين يختانون أنفسهم﴾</span></span>: الواو عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿لا﴾</span></span> ناهية، وتجادل فعل مضارع مجزوم بلا، والفاعل: أنت، وعن الذين جار ومجرور متعلقان بتجادل، وجملة <span class="hlt"><span class="qpc-hafs">﴿يختانون أنفسهم﴾</span></span> لا محل لها من الإعراب، لأنها صلة الموصول.</p><p><span class="hlt"><span class="qpc-hafs">﴿إن الله لا يحب من كان خوانا أثيما﴾</span></span>: تعليل للنهي، وإن حرف ناسخ، ولفظ الجلالة اسمها، وجملة <span class="hlt"><span class="qpc-hafs">﴿لا يحب﴾</span></span> خبرها، و<span class="hlt"><span class="qpc-hafs">﴿مَن﴾</span></span> اسم موصول مفعول به، وجملة <span class="hlt"><span class="qpc-hafs">﴿كان﴾</span></span> صلة الموصول لا محل لها من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿خوانًا﴾</span></span> خبر كان، وأثيمًا صفة، أو هما خبران لـ<span class="hlt"><span class="qpc-hafs">﴿كان﴾</span></span>.</p></div>"
  4,108,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿يستخفون من الناس ولا يستخفون من الله﴾</span></span>: الجملة مستأنفة لا محل لها من الإعراب، أو حالية من <span class="hlt"><span class="qpc-hafs">﴿مَن﴾</span></span> على أنها موصولة، وجملة <span class="hlt"><span class="qpc-hafs">﴿ولا يستخفون من الله﴾</span></span> عطف على الأولى.</p><p><span class="hlt"><span class="qpc-hafs">﴿وهو معهم﴾</span></span>: الواو حالية، وهو مبتدأ، والظرف <span class="hlt"><span class="qpc-hafs">﴿معهم﴾</span></span> متعلق بمحذوف خبر، والجملة حالية.</p><p><span class="hlt"><span class="qpc-hafs">﴿إذ يبيتون ما لا يرضى من القول﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿إذ﴾</span></span> ظرف متعلق بالخبر المحذوف الذي تعلق به <span class="hlt"><span class="qpc-hafs">﴿معهم﴾</span></span> وقيل: متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿يستخفون﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿يبيتون﴾</span></span> في محل جر بالإضافة، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> اسم موصول مفعول به، وجملة <span class="hlt"><span class="qpc-hafs">﴿لا يرضى﴾</span></span> صلة الموصول لا محل لها من الإعراب، ومن القول جار ومجرور متعلقان بمحذوف حال.</p><p><span class="hlt"><span class="qpc-hafs">﴿وكان الله بما يعملون محيطا﴾</span></span>: الواو عاطفة، أو الواو استئنافية والجملة بعدها مستأنفة لا محل لها من الإعراب، وكان فعل ماض ناقص ناسخ، ولفظ الجلالة اسمها، ومحيطًا خبرها، و<span class="hlt"><span class="qpc-hafs">﴿بما يعملون﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿محيطًا﴾</span></span>.</p></div>"
  4,109,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ها أنتم هؤلاء جادلتم عنهم في الحياة الدنيا﴾</span></span>: كلام مستأنف لا محل له من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿ها﴾</span></span> للتنبيه، <span class="hlt"><span class="qpc-hafs">﴿أنتم﴾</span></span>: مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿هؤلاء﴾</span></span>: خبره، وجملة <span class="hlt"><span class="qpc-hafs">﴿جادلتم﴾</span></span>: في محل رفع خبر ثان، أو نصب حال. أو <span class="hlt"><span class="qpc-hafs">﴿أنتم﴾</span></span>: مبتدأ، وجملة <span class="hlt"><span class="qpc-hafs">﴿جادلتم﴾</span></span>: خبر، و<span class="hlt"><span class="qpc-hafs">﴿هؤلاء﴾</span></span>: منادى محذوف منه حرف النداء، وجملة النداء اعتراضية لا محل لها من الإعراب. وعنهم: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿جادلتم﴾</span></span>، وفي الحياة: جار ومجرور متعلقان بمحذوف حال، والدنيا صفة.</p><p><span class="hlt"><span class="qpc-hafs">﴿فمن يجادل الله عنهم يوم القيامة﴾</span></span>: الفاء عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿من﴾</span></span> اسم استفهام إنكاري مبتدأ، وجملة <span class="hlt"><span class="qpc-hafs">﴿يجادل الله﴾</span></span> خبر، وعنهم جار ومجرور متعلقان بيجادل، ويوم القيامة ظرف متعلق بمحذوف حال.</p><p><span class="hlt"><span class="qpc-hafs">﴿أم من يكون عليهم وكيلا﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿أم﴾</span></span> حرف عطف، و<span class="hlt"><span class="qpc-hafs">﴿من﴾</span></span> اسم استفهام مبتدأ، ويكون فعل مضارع ناقص، واسمها ضمير مستتر تقديره: هو، يعود على <span class="hlt"><span class="qpc-hafs">﴿مَن﴾</span></span>، والجملة في محل رفع خبر <span class="hlt"><span class="qpc-hafs">﴿مَن﴾</span></span>، وعليهم جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿وكيلًا﴾</span></span>، ووكيلًا خبر يكون.</p></div>"
  4,110,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ومن يعمل سوءا أو يظلم نفسه﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿من﴾</span></span> اسم شرط جازم مبتدأ، ويعمل فعل مضارع فعل الشرط، والفاعل: هو، وسوءًا مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿أو﴾</span></span> حرف عطف، ويظلم نفسه عطف على يعمل، ونفسه مفعول به.</p><p><span class="hlt"><span class="qpc-hafs">﴿ثم يستغفر الله يجد الله غفورا رحيما﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿ثم﴾</span></span> حرف عطف، و<span class="hlt"><span class="qpc-hafs">﴿يستغفر الله﴾</span></span> عطف على ما تقدم، و<span class="hlt"><span class="qpc-hafs">﴿يجد الله﴾</span></span> جواب الشرط، وفعل الشرط وجوابه خبر <span class="hlt"><span class="qpc-hafs">﴿مَن﴾</span></span>، وغفورًا مفعول به ثان، ورحيمًا صفة، وجملة <span class="hlt"><span class="qpc-hafs">﴿ومن يعمل...﴾</span></span> مستأنفة لا محل لها من الإعراب.</p></div>"
  4,111,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ومن يكسب إثما فإنما يكسبه على نفسه﴾</span></span>: عطف على ما تقدم، و<span class="hlt"><span class="qpc-hafs">﴿من﴾</span></span> اسم شرط جازم مبتدأ، ويكسب فعل مضارع فعل الشرط، والفاعل: هو، وإثما مفعول به، وجملة <span class="hlt"><span class="qpc-hafs">﴿فإنما﴾</span></span> جواب الشرط، وفعل الشرط وجوابه خبر <span class="hlt"><span class="qpc-hafs">﴿من﴾</span></span>، وعلى نفسه جار ومجرور متعلقان بيكسبه.</p><p><span class="hlt"><span class="qpc-hafs">﴿وكان الله عليما حكيما﴾</span></span>: الواو استئنافية، وكان فعل ماض ناقص ناسخ، ولفظ الجلالة اسمها، وعليمًا حكيمًا خبراها.</p></div>"
  4,112,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ومن يكسب خطيئة أو إثما﴾</span></span>: عطف على ما تقدم، و<span class="hlt"><span class="qpc-hafs">﴿مَن﴾</span></span> اسم شرط جازم مبتدأ، ويكسب فعل مضارع فعل الشرط، والفاعل: هو، وخطيئة مفعول به، أو إثما عطف على خطيئة.</p><p><span class="hlt"><span class="qpc-hafs">﴿ثم يرم به بريئا﴾</span></span>: عطف على يكسب، ووحد الضمير تغليبًا للإثم، و<span class="hlt"><span class="qpc-hafs">﴿به﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يرمِ﴾</span></span>، وبريئًا مفعول به.</p><p><span class="hlt"><span class="qpc-hafs">﴿فقد احتمل بهتانا وإثما مبينا﴾</span></span>: الجملة في محل جزم جواب الشرط، وفعل الشرط وجوابه خبر <span class="hlt"><span class="qpc-hafs">﴿مَن﴾</span></span>.</p></div>"
  4,113,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ولولا فضل الله عليك ورحمته﴾</span></span>: الواو عاطفة، أو استئنافية، و<span class="hlt"><span class="qpc-hafs">﴿لولا﴾</span></span> حرف امتناع لوجود متضمن معنى الشرط، و<span class="hlt"><span class="qpc-hafs">﴿فضل الله﴾</span></span> مبتدأ محذوف الخبر، وعليك جار ومجرور متعلقان بفضل، ورحمته عطف على فضل.</p><p><span class="hlt"><span class="qpc-hafs">﴿لهمت طائفة منهم أن يضلوك﴾</span></span>: اللام واقعة في جواب <span class="hlt"><span class="qpc-hafs">﴿لولا﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿همت طائفة﴾</span></span> لا محل لها من الإعراب، لأنها جواب شرط غير جازم، والمصدر المؤول من <span class="hlt"><span class="qpc-hafs">﴿أن يضلوك﴾</span></span> منصوب بنزع الخافض، والجار والمجرور متعلقان بهمت، أي: همَّت بإضلالك. وجملة <span class="hlt"><span class="qpc-hafs">﴿ولولا فضل الله...﴾</span></span> معطوفة، أو مستأنفة لا محل لها من الإعراب.</p><p><span class="hlt"><span class="qpc-hafs">﴿وما يضلون إلا أنفسهم﴾</span></span>: الواو حالية، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> نافية، ويضلون فعل مضارع مرفوع، وعلامة رفعه ثبوت النون، و<span class="hlt"><span class="qpc-hafs">﴿إلا﴾</span></span> أداة حصر، وأنفسهم مفعول يضلون، والجملة في محل نصب على الحال.</p><p><span class="hlt"><span class="qpc-hafs">﴿وما يضرونك من شيء﴾</span></span>: الواو عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> نافية، ويضرونك فعل مضارع وفاعل ومفعول به، وهو معطوف على يضلون، و<span class="hlt"><span class="qpc-hafs">﴿من﴾</span></span> حرف جر صلة، وشيء نائب عن المفعول المطلق مجرور لفظًا منصوب محلا، أي: شيئًا من الضرر.</p><p><span class="hlt"><span class="qpc-hafs">﴿وأنزل الله عليك الكتاب والحكمة﴾</span></span>: الواو استئنافية، والجملة مستأنفة لا محل لها من الإعراب، فيها معنى العلة لما تقدم، والكتاب مفعول به، والحكمة عطف على الكتاب.</p><p><span class="hlt"><span class="qpc-hafs">﴿وعلمك ما لم تكن تعلم﴾</span></span>: عطف على ما تقدم، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> اسم موصول مفعول علمك الثاني، وجملة <span class="hlt"><span class="qpc-hafs">﴿لم تكن﴾</span></span> صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> لا محل لها من الإعراب، وجملة <span class="hlt"><span class="qpc-hafs">﴿تعلم﴾</span></span> خبر تكن.</p><p><span class="hlt"><span class="qpc-hafs">﴿وكان فضل الله عليك عظيما﴾</span></span>: عطف أيضًا، وكان فعل ماض ناقص، و<span class="hlt"><span class="qpc-hafs">﴿فضل الله﴾</span></span> اسمها، وعظيمًا خبرها، وعليك جار ومجرور متعلقان بفضل.</p></div>"