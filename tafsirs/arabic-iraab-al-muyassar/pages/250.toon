quran[8]{c,v,t}:
  13,6,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ويستعجلونك بالسيئة قبل الحسنة﴾</span></span>: الواو عاطفة، ويستعجلونك فعل وفاعل ومفعول به، و<span class="hlt"><span class="qpc-hafs">﴿بالسيئة﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يستعجلونك﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿وقد خلت من قبلهم المثلات﴾</span></span>: الواو للحال، وقد حرف تحقيق، وخلت فعل ماض مبني على الفتح المقدر على الألف المحذوفة لالتقاء الساكنين، و<span class="hlt"><span class="qpc-hafs">﴿من قبلهم﴾</span></span> جار ومجرور متعلقان بخلت، والمثلات فاعل خلت.</p><p><span class="hlt"><span class="qpc-hafs">﴿وإن ربك لذو مغفرة للناس على ظلمهم﴾</span></span>: الواو للحال أيضًا، وإن حرف ناسخ، وربك اسمها، واللام المزحلقة، وذو مغفرة خبر إن، و<span class="hlt"><span class="qpc-hafs">﴿للناس﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿مغفرة﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿على ظلمهم﴾</span></span> حال من الناس، والمعنى: ظالمين لأنفسهم.</p><p><span class="hlt"><span class="qpc-hafs">﴿وإن ربك لشديد العقاب﴾</span></span>: الواو عاطفة، وإن حرف ناسخ، وربك اسمها، واللام المزحلقة، وشديد العقاب خبرها.</p></div>"
  13,7,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ويقول الذين كفروا لولا أنزل عليه آية من ربه﴾</span></span>: الواو استئنافية، والجملة بعدها مستأنفة لا محل لها من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿يقول الذين﴾</span></span> فعل وفاعل، وجملة كفروا صلة الذين لا محل لها من الإعراب، ولولا حرف تحضيض بمعنى هلا، وأنزل فعل ماض مبني لما لم يسمَّ فاعله، و<span class="hlt"><span class="qpc-hafs">﴿عليه﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أنزل﴾</span></span>، وآية نائب فاعل، و<span class="hlt"><span class="qpc-hafs">﴿من ربه﴾</span></span> جار ومجرور متعلقان بمحذوف صفة لآية.</p><p><span class="hlt"><span class="qpc-hafs">﴿إنما أنت منذر ولكل قوم هاد﴾</span></span>: إنما كافة ومكفوفة، وأنت مبتدأ، ومنذر خبر، و<span class="hlt"><span class="qpc-hafs">﴿لكل﴾</span></span> جار ومجرور متعلقان بمحذوف خبر مقدم، وقوم مضاف إليه، وهاد مبتدأ مؤخر، وجملة <span class="hlt"><span class="qpc-hafs">﴿إنما نت منذر﴾</span></span> مستأنفة لا محل لها من الإعراب.</p></div>"
  13,8,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿الله يعلم ما تحمل كل أنثى﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿الله﴾</span></span> مبتدأ، وجملة يعلم خبر، وفاعل يعلم مستتر تقديره: هو، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> موصولة في محل نصب مفعول يعلم، وجملة <span class="hlt"><span class="qpc-hafs">﴿تحمل كل أنثى﴾</span></span> صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> لا محل لها من الإعراب، والعائد محذوف، أي: تحمله، أو <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> مصدرية وهي مع مدخولها مفعول يعلم، فالجملة بعدها لا محل لها من الإعراب ولا حاجة إلى العائد، أو <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> استفهامية، إما مبتدأ، وجملة <span class="hlt"><span class="qpc-hafs">﴿تحمل﴾</span></span> خبر، وإما مفعول مقدم لـ<span class="hlt"><span class="qpc-hafs">﴿تحمل﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿وما تغيض الأرحام وما تزداد﴾</span></span>: عطف على الجملة السابقة.</p><p><span class="hlt"><span class="qpc-hafs">﴿وكل شيء عنده بمقدار﴾</span></span>: كل مبتدأ، وشيء مضاف إليه، و<span class="hlt"><span class="qpc-hafs">﴿عنده﴾</span></span> ظرف متعلق بمحذوف صفة لشيء، أو لكل، و<span class="hlt"><span class="qpc-hafs">﴿بمقدار﴾</span></span> خبر.</p></div>"
  13,9,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿عالم الغيب والشهادة الكبير المتعال﴾</span></span>: عالم الغيب خبر لمبتدأ محذوف، أي: هو، والغيب مضاف إليه، والشهادة عطف، والكبير خبر ثان للمبتدأ المحذوف، والمتعال خبر ثالث.</p></div>"
  13,10,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿سواء منكم من أسر القول ومن جهر به﴾</span></span>: سواء خبر مقدم، و<span class="hlt"><span class="qpc-hafs">﴿منكم﴾</span></span> جار ومجرور متعلقان بمحذوف حال من ضميره، و<span class="hlt"><span class="qpc-hafs">﴿مَن﴾</span></span> موصول مبتدأ مؤخر، أو <span class="hlt"><span class="qpc-hafs">﴿سواء﴾</span></span> مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿منكم﴾</span></span> جار ومجرور متعلقان بمحذوف صفة، و<span class="hlt"><span class="qpc-hafs">﴿مَن﴾</span></span> خبر، وجملة أسر القول صلة <span class="hlt"><span class="qpc-hafs">﴿مَن﴾</span></span> لا محل لها من الإعراب، أي: أخفاه في نفسه، <span class="hlt"><span class="qpc-hafs">﴿ومن جهر به﴾</span></span> عطف على <span class="hlt"><span class="qpc-hafs">﴿من أسر القول﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿ومن هو مستخف بالليل وسارب بالنهار﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿ومَن﴾</span></span> عطف على <span class="hlt"><span class="qpc-hafs">﴿مَن﴾</span></span> السابقة، و<span class="hlt"><span class="qpc-hafs">﴿هو﴾</span></span> مبتدأ، ومستخف خبر، والجملة الاسمية صلة <span class="hlt"><span class="qpc-hafs">﴿مَن﴾</span></span> لا محل لها من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿بالليل﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿مستخف﴾</span></span>، وسارب عطف على مستخف، و<span class="hlt"><span class="qpc-hafs">﴿بالنهار﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿سارب﴾</span></span>.</p></div>"
  13,11,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿له معقبات من بين يديه ومن خلفه يحفظونه من أمر الله﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿له﴾</span></span> جار ومجرور متعلقان بمحذوف خبر مقدم، ومعقبات مبتدأ مؤخر، و<span class="hlt"><span class="qpc-hafs">﴿من بين يديه﴾</span></span> جار ومجرور متعلقان بمحذوف صفة لمعقبات، أو متعلقان بمعقبات نفسها، و<span class="hlt"><span class="qpc-hafs">﴿من خلفه﴾</span></span> عطف على <span class="hlt"><span class="qpc-hafs">﴿من بين يديه﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿يحفظونه﴾</span></span> صفة لمعقبات أيضًا، و<span class="hlt"><span class="qpc-hafs">﴿من أمر الله﴾</span></span> متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يحفظونه﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿إن الله لا يغير ما بقوم حتى يغيروا ما بأنفسهم﴾</span></span>: إن حرف ناسخ، ولفظ الجلالة اسمها، وجملة <span class="hlt"><span class="qpc-hafs">﴿لا يغير﴾</span></span> خبرها، وفاعل <span class="hlt"><span class="qpc-hafs">﴿يغير﴾</span></span> عائد على <span class="hlt"><span class="qpc-hafs">﴿الله﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> موصول مفعول <span class="hlt"><span class="qpc-hafs">﴿يغير﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿بقوم﴾</span></span> جار ومجرور متعلقان بمحذوف صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span>، وجملة الصلة لا محل لها من الإعراب، وحتى حرف غاية وجر، ويغيروا فعل مضارع منصوب بأن مضمرة بعد حتى، والمصدر المؤول من <span class="hlt"><span class="qpc-hafs">﴿أن﴾</span></span> والفعل مجرور بحتى، والجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يغير﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿بأنفسهم﴾</span></span> جار ومجرور متعلقان بمحذوف صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span>، وجملة الصلة لا محل لها من الإعراب.</p><p><span class="hlt"><span class="qpc-hafs">﴿وإذا أراد الله بقوم سوءا فلا مرد له﴾</span></span>: الواو عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿إذا﴾</span></span> ظرف لما يستقبل من الزمان خافض لشرطه منصوب بجوابه، وجملة <span class="hlt"><span class="qpc-hafs">﴿أراد الله﴾</span></span> مضاف إليها، و<span class="hlt"><span class="qpc-hafs">﴿بقوم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أراد﴾</span></span>، والفاء رابطة، ولا نافية للجنس، و<span class="hlt"><span class="qpc-hafs">﴿مرد﴾</span></span> اسمها، و<span class="hlt"><span class="qpc-hafs">﴿له﴾</span></span> جار ومجرور متعلقان بمحذوف خبرها.</p><p><span class="hlt"><span class="qpc-hafs">﴿وما لهم من دونه من وال﴾</span></span>: الواو عاطفة، وما نافية، و<span class="hlt"><span class="qpc-hafs">﴿لهم﴾</span></span> جار ومجرور متعلقان بمحذوف خبر مقدم، و<span class="hlt"><span class="qpc-hafs">﴿من دونه﴾</span></span> جار ومجرور متعلقان بمحذوف حال، و<span class="hlt"><span class="qpc-hafs">﴿من﴾</span></span> صلة، ووال مجرور لفظًا مرفوع محلًّا، لأنه مبتدأ مؤخر.</p></div>"
  13,12,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿هو الذي يريكم البرق خوفا وطمعا وينشئ السحاب الثقال﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿هو﴾</span></span> مبتدأ، والذي خبره، ويريكم البرق فعل مضارع وفاعل مستتر ومفعولاه، والجملة صلة الذي لا محل لها من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿خوفًا وطمعًا﴾</span></span> منصوبان على المصدرية، أي: لتخافوا خوفًا ولتطمعوا طمعًا، أو حالان من الكاف في <span class="hlt"><span class="qpc-hafs">﴿يريكم﴾</span></span>، أي: حال كونكم خائفين وطامعين، أو من البرق، والتقدير: يريكم البرق ذا خوف وذا طمع، أو جعل البرق في نفسه خوفا وطمعا على المبالغة، أو مفعولان لأجلهما، وينشئ السحاب عطف، والسحاب مفعول به، والثقال صفة للسحاب.</p></div>"
  13,13,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ويسبح الرعد بحمده والملائكة من خيفته﴾</span></span>: عطف على ما تقدم، ويسبح الرعد فعل مضارع وفاعل، و<span class="hlt"><span class="qpc-hafs">﴿بحمده﴾</span></span> جار ومجرور متعلقان بمحذوف حال، والملائكة عطف على الرعد، <span class="hlt"><span class="qpc-hafs">﴿من خيفته﴾</span></span> جار ومجرور متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿يسبح﴾</span></span>، أو متعلقان بمحذوف منصوب حال من الملائكة، أي: هائبين وخائفين.</p><p><span class="hlt"><span class="qpc-hafs">﴿ويرسل الصواعق فيصيب بها من يشاء﴾</span></span>: الواو عاطفة، ويرسل الصواعق عطف على ما تقدم، فيصيب عطف أيضًا، و<span class="hlt"><span class="qpc-hafs">﴿بها﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يصيب﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿مَن﴾</span></span> مفعول به لـ<span class="hlt"><span class="qpc-hafs">﴿يصيب﴾</span></span>، وجملة يشاء صلة <span class="hlt"><span class="qpc-hafs">﴿مَن﴾</span></span> لا محل لها من الإعراب.</p><p><span class="hlt"><span class="qpc-hafs">﴿وهم يجادلون في الله﴾</span></span>: الواو استئنافية والجملة بعدها مستأنفة لا محل لها من الإعراب، أو الواو حالية والجملة بعدها في محل نصب حال، و<span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> مبتدأ، وجملة يجادلون خبر، و<span class="hlt"><span class="qpc-hafs">﴿في الله﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يجادلون﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿وهو شديد المحال﴾</span></span>: الواو حالية، و<span class="hlt"><span class="qpc-hafs">﴿هو﴾</span></span> مبتدأ، وشديد المحال خبره، والجملة حالية.</p></div>"