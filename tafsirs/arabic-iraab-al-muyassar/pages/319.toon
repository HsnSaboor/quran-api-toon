quran[15]{c,v,t}:
  20,99,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿كذلك نقص عليك من أنباء ما قد سبق وقد آتيناك من لدنا ذكرا﴾</span></span>: الكاف اسم بمعنى مثل مبني على الفتح في محل نصب صفة لمصدر محذوف لـ<span class="hlt"><span class="qpc-hafs">﴿نقص﴾</span></span>، أي: نقص عليك قصصا مثل ذلك القصص، و<span class="hlt"><span class="qpc-hafs">﴿ذلك﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿ذا﴾</span></span> اسم إشارة في محل جر مضاف إليه، واللام للبعد، والكاف حرف خطاب، ونقص فعل مضارع فاعله مستتر تقديره: نحن، و<span class="hlt"><span class="qpc-hafs">﴿عليك﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿نقص﴾</span></span>، ومن أنباء جار ومجرور متعلقان بمحذوف مفعول به لنقص، وما مضاف إليه، وجملة <span class="hlt"><span class="qpc-hafs">﴿قد سبق﴾</span></span> صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> لا محل لها من الإعراب، <span class="hlt"><span class="qpc-hafs">﴿وقد﴾</span></span> الواو عاطفة، وقد حرف تحقيق، و<span class="hlt"><span class="qpc-hafs">﴿آتيناك﴾</span></span> فعل ماض، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> فاعل، والكاف مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿من لدنا﴾</span></span> جار ومجرور متعلقان بمحذوف حال، لأنه كان صفة لـ<span class="hlt"><span class="qpc-hafs">﴿ذكرًا﴾</span></span>، وذكرًا مفعول به ثان.</p></div>"
  20,100,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿من أعرض عنه فإنه يحمل يوم القيامة وزرا﴾</span></span>: من شرطية في محل رفع مبتدأ، وأعرض فعل ماض في محل جزم فعل الشرط، وفاعله ضمير مستتر تقديره: هو، وعنه جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أعرض﴾</span></span>، والفاء رابطة، وإن حرف ناسخ، والهاء اسمها، وجملة يحمل خبرها، والفاعل مستتر تقديره: هو، ويوم القيامة ظرف متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿يحمل﴾</span></span>، ووزرًا مفعول به، وجملة من أعرض في محل نصب نعت لـ<span class="hlt"><span class="qpc-hafs">﴿ذكرًا﴾</span></span>.</p></div>"
  20,101,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿خالدين فيه وساء لهم يوم القيامة حملا﴾</span></span>: خالدين حال، وفيه جار ومجرور متعلقان بخالدين، والضمير يعود للوزر، وساء: الواو حالية، أو عاطفة، وساء فعل ماض من أفعال الذم، وفاعله مستتر مميز بنكرة، وهي <span class="hlt"><span class="qpc-hafs">﴿حملًا﴾</span></span>، والمخصوص بالذم محذوف تقديره: وزرهم، و<span class="hlt"><span class="qpc-hafs">﴿لهم﴾</span></span> جار ومجرور متعلقان بقول مقدر، أي: يقال لهم هذا الكلام، وقيل: هي كاللام في <span class="hlt"><span class="qpc-hafs">﴿هيت لك﴾</span></span>، أي: لمجرد البيان، ويوم القيامة ظرف متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿ساء﴾</span></span>، وحملًا تمييز.</p></div>"
  20,102,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿يوم ينفخ في الصور ونحشر المجرمين يومئذ زرقا﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿يوم﴾</span></span> ظرف بدل من يوم القيامة، وجملة ينفخ مضاف إليه، وينفخ فعل مضارع بالبناء لما لم يسمَّ فاعله، و<span class="hlt"><span class="qpc-hafs">﴿في الصور﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿ينفخ﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿نحشر﴾</span></span> الواو عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿نحشر﴾</span></span> فعل مضارع، وفاعله مستتر تقديره: نحن، والمجرمين مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿يومئذ﴾</span></span> يوم: ظرف متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿نحشر﴾</span></span>، وإذٍ: اسم مبني على السكون المقدر لاشتغال المحل بتنوين العوض في محل جر مضاف إليه، والتنوين عوض عن جملة محذوفة والتقدير: ونحشر المجرمين يوم إذ ينفخ في الصور، وزرقًا حال من المجرمين.</p></div>"
  20,103,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿يتخافتون بينهم إن لبثتم إلا عشرا﴾</span></span>: الجملة حال من المجرمين، أو مستأنفة لا محل لها من الإعراب، ويتخافتون فعل مضارع مرفوع بثبوت النون، لأنه من الأفعال الخمسة، والواو فاعل، وبينهم ظرف متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿يتخافتون﴾</span></span>، وإن لبثتم جملة منصوبة بقول دل عليه يتخافتون، والقول نصب على الحال، أي: قائلين في السر، وإن نافية، ولبثتم فعل وفاعل، وإلا أداة حصر، وعشرًا ظرف زمان .</p></div>"
  20,104,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿نحن أعلم بما يقولون إذ يقول أمثلهم طريقة إن لبثتم إلا يوما﴾</span></span>: نحن مبتدأ، وأعلم خبر، وبما جار ومجرور متعلقان بأعلم، وجملة يقولون صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> لا محل لها من الإعراب، وإذ ظرف متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿أعلم﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿يقول﴾</span></span> في محل جر مضاف إليه، وأمثلهم فاعل، وطريقة تمييز، وإن نافية، ولبثتم فعل وفاعل، وإلا أداة حصر، ويومًا ظرف متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿لبثتم﴾</span></span>.</p></div>"
  20,105,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ويسألونك عن الجبال فقل ينسفها ربي نسفا﴾</span></span>: الواو للاستئناف، ويسألونك فعل مضارع مرفوع بثبوت النون، والواو فاعل، والكاف مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿عن الجبال﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يسألونك﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿ويسألونك عن الجبال﴾</span></span> مستأنفة لا محل لها من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿فقل﴾</span></span> الفاء عاطفة، وقل فعل أمر، وفاعله مستتر تقديره: أنت، وجملة ينسفها مقول القول، و<span class="hlt"><span class="qpc-hafs">﴿ها﴾</span></span> مفعول به مقدم، وربي فاعل مؤخر، ونسفًا مفعول مطلق.</p></div>"
  20,106,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فيذرها قاعا صفصفا﴾</span></span>: الفاء عاطفة، ويذرها فعل مضارع، والفاعل مستتر تقديره: هو، أي: الله تعالى، و<span class="hlt"><span class="qpc-hafs">﴿ها﴾</span></span> مفعول به، وقاعًا حال من الضمير المنصوب، أو مفعول به ثان، لتضمين يذر معنى التصيير، وصفصفًا حال ثانية، أو بدل من المفعول الثاني، وقيل: صفة له.</p></div>"
  20,107,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿لا ترى فيها عوجا ولا أمتا﴾</span></span>: الجملة حال ثالثة، أو حال أولى، ولا نافية، وترى فعل مضارع، وفاعله مستتر تقديره: أنت، وفيها جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿ترى﴾</span></span>، وعوجًا مفعول به، ولا أمتًا عطف.</p></div>"
  20,108,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿يومئذ يتبعون الداعي لا عوج له﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿يومئذ﴾</span></span> يوم: ظرف زمان متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿يتبعون﴾</span></span>، أو بدل من <span class="hlt"><span class="qpc-hafs">﴿يوم القيامة﴾</span></span> المتقدم، وإذٍ: اسم مبني على السكون المقدر لاشتغال المحل بتنوين العوض في محل جر مضاف إليه، والتنوين عوض عن جملة محذوفة، و<span class="hlt"><span class="qpc-hafs">﴿يتبعون الداعي﴾</span></span> فعل مضارع وفاعل ومفعول به، ولا نافية للجنس، وعوج اسمها مبني على الفتح، و<span class="hlt"><span class="qpc-hafs">﴿له﴾</span></span> جار ومجرور متعلقان بمحذوف خبر لا، وجملة <span class="hlt"><span class="qpc-hafs">﴿لا عوج له﴾</span></span> حال من الداعي، أو صفة لمصدر محذوف، أي: يتبعونه اتباعًا لا عوج له، أو مستأنفة لا محل لها من الإعراب.</p><p><span class="hlt"><span class="qpc-hafs">﴿وخشعت الأصوات للرحمن فلا تسمع إلا همسا﴾</span></span>: الواو عاطفة، وخشعت الأصوات فعل وفاعل، و<span class="hlt"><span class="qpc-hafs">﴿للرحمن﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿خشعت﴾</span></span>، والفاء عاطفة، ولا نافية، وتسمع فعل مضارع، وفاعله مستتر تقديره: هو، وإلا أداة حصر، وهمسًا مفعول به.</p></div>"
  20,109,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿يومئذ لا تنفع الشفاعة إلا من أذن له الرحمن ورضي له قولا﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿يومئذ﴾</span></span> يوم: ظرف متعلق بالفعل المنفي <span class="hlt"><span class="qpc-hafs">﴿تنفع﴾</span></span>، وإذٍ: اسم مبني على السكون المقدر لاشتغال المحل بتنوين العوض في محل جر مضاف إليه، والتنوين عوض عن جملة محذوفة، ولا نافية، وتنفع الشفاعة فعل مضارع وفاعل، وإلا أداة حصر، ومن مفعول لـ<span class="hlt"><span class="qpc-hafs">﴿تنفع﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿أذن له الرحمن﴾</span></span> صلة <span class="hlt"><span class="qpc-hafs">﴿من﴾</span></span> لا محل لها من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿رضي له قولًا﴾</span></span> عطف على أذن له، وقيل: النصب على المفعولية.</p></div>"
  20,110,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿يعلم ما بين أيديهم وما خلفهم ولا يحيطون به علما﴾</span></span>: يعلم فعل مضارع مرفوع، وفاعله مستتر تقديره: هو، وما مفعول به، وبين ظرف متعلق بمحذوف صلة الموصول، وجملة الصلة لا محل لها من الإعراب، وأيديهم مضاف إليه، وجملة <span class="hlt"><span class="qpc-hafs">﴿يعلم ما...﴾</span></span> مستأنفة لا محل لها من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿ما خلفهم﴾</span></span> عطف على <span class="hlt"><span class="qpc-hafs">﴿ما بين أيديهم﴾</span></span>، ولا يحيطون الواو عاطفة، أو حالية، ويحيطون فعل مضارع مرفوع بثبوت النون، و<span class="hlt"><span class="qpc-hafs">﴿به﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يحيطون﴾</span></span>، وعلمًا مفعول به.</p></div>"
  20,111,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وعنت الوجوه للحي القيوم وقد خاب من حمل ظلما﴾</span></span>: الواو استئنافية، وعنت الوجوه فعل وفاعل، وجملة <span class="hlt"><span class="qpc-hafs">﴿وعنت الوجوه﴾</span></span> مستأنفة لا محل لها من الإعراب، وللحي جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿عنت﴾</span></span>، والقيوم صفة، والواو حالية، وجملة وقد خاب حالية، ومن فاعل خاب، وجملة حمل ظلمًا صلة <span class="hlt"><span class="qpc-hafs">﴿من﴾</span></span> لا محل لها من الإعراب.</p></div>"
  20,112,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ومن يعمل من الصالحات وهو مؤمن فلا يخاف ظلما ولا هضما﴾</span></span>: الواو عاطفة على وقد خاب، ومن شرطية مبتدأ، ويعمل فعل الشرط، ومن الصالحات جار ومجرور متعلقان بمحذوف صفة لمفعول به محذوف، أي: أعمالًا، والواو حالية، و<span class="hlt"><span class="qpc-hafs">﴿هو﴾</span></span> مبتدأ، ومؤمن خبر، والفاء رابطة لجواب الشرط، ولا نافية، ويخاف فعل مضارع، وفاعله مستتر تقديره: هو، وظلمًا مفعول به، ولا هضمًا عطف على <span class="hlt"><span class="qpc-hafs">﴿ظلمًا﴾</span></span>، وجملة لا يخاف خبر لمبتدأ محذوف، والتقدير: فهو لا يخاف، وجملة فهو لا يخاف في محل جزم جواب الشرط، وفعل الشرط وجوابه خبر من.</p></div>"
  20,113,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وكذلك أنزلناه قرآنا عربيا﴾</span></span>: الواو عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿كذلك﴾</span></span> الكاف اسم بمعنى مثل مبني على الفتح في محل نصب صفة لمصدر محذوف لـ<span class="hlt"><span class="qpc-hafs">﴿أنزلناه﴾</span></span>، أي: مثل ذلك الإنزال أنزلناه، و<span class="hlt"><span class="qpc-hafs">﴿ذلك﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿ذا﴾</span></span> اسم إشارة في محل جر مضاف إليه، واللام للبعد، والكاف حرف خطاب، و<span class="hlt"><span class="qpc-hafs">﴿أنزلناه﴾</span></span> فعل ماض، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> فاعل، والهاء مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿قرآنًا﴾</span></span> حال، و<span class="hlt"><span class="qpc-hafs">﴿عربيًّا﴾</span></span> صفة.</p><p><span class="hlt"><span class="qpc-hafs">﴿وصرفنا فيه من الوعيد لعلهم يتقون أو يحدث لهم ذكرا﴾</span></span>: الواو عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿صرفنا﴾</span></span> فعل وفاعل، و<span class="hlt"><span class="qpc-hafs">﴿فيه﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿صرفنا﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿من الوعيد﴾</span></span> جار ومجرور متعلقان بمحذوف صفة لمفعول محذوف، أي: صرفنا وعيدًا من الوعيد، ولعل حرف ناسخ يفيد الترجي، و<span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> اسمها، وجملة يتقون خبرها، وأو حرف عطف، ويحدث عطف على يتقون، و<span class="hlt"><span class="qpc-hafs">﴿لهم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يحدث﴾</span></span>، وذكرًا مفعول به، وفاعل يحدث هو، أي: القرآن.</p></div>"