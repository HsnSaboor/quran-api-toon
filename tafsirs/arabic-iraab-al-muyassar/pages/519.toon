quran[20]{c,v,t}:
  50,16,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ولقد خلقنا الإنسان﴾</span></span>: الواو استئنافية، واللام جواب للقسم المحذوف، وقد حرف تحقيق، وخلقنا الإنسان فعل ماض وفاعل ومفعول به.</p><p><span class="hlt"><span class="qpc-hafs">﴿ونعلم ما توسوس به نفسه﴾</span></span>: الواو للحال بتقدير: نحن، وجملة <span class="hlt"><span class="qpc-hafs">﴿نعلم﴾</span></span> خبر مبتدأ مقدر، والجملة الاسمية في محل نصب على الحال المقدرة، أو الواو استئنافية، والجملة مستأنفة لا محل لها من الإعراب، وما مفعول به، وجملة <span class="hlt"><span class="qpc-hafs">﴿توسوس﴾</span></span> صلة الموصول لا محل لها من الإعراب، أو أن <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> مصدرية، والتقدير: ونعلم وسوسة نفسه له، و<span class="hlt"><span class="qpc-hafs">﴿به﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿توسوس﴾</span></span>، ونفسه فاعل.</p><p><span class="hlt"><span class="qpc-hafs">﴿ونحن أقرب إليه من حبل الوريد﴾</span></span>: نحن: الواو عاطفة، ونحن مبتدأ، وأقرب خبر، وإليها جار ومجرور متعلقان بأقرب، ومن حبل الوريد جار ومجرور متعلقان بأقرب أيضًا.</p></div>"
  50,17,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إذ يتلقى المتلقيان عن اليمين وعن الشمال قعيد﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿إذ﴾</span></span> ظرف متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿أقرب﴾</span></span> في الآية السابقة، أو اسم مبني على السكون في محل نصب مفعول به لفعل محذوف تقديره: اذكر، وجملة <span class="hlt"><span class="qpc-hafs">﴿يتلقى﴾</span></span> في محل جر مضاف إليه، و<span class="hlt"><span class="qpc-hafs">﴿المتلقيان﴾</span></span> فاعل، و<span class="hlt"><span class="qpc-hafs">﴿عن اليمين﴾</span></span> خبر مقدم، <span class="hlt"><span class="qpc-hafs">﴿وعن الشمال﴾</span></span> عطف على <span class="hlt"><span class="qpc-hafs">﴿عن اليمين﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿قعيد﴾</span></span> مبتدأ مؤخر، والجملة الاسمية في محل نصب على الحال من المتلقيان.</p></div>"
  50,18,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ما يلفظ من قول إلا لديه رقيب عتيد﴾</span></span>: ما نافية، ويلفظ فعل مضارع، وفاعله ضمير مستتر تقديره: هو، يعود على الإنسان، ومن حرف جر صلة، وقول مجرور لفظًا منصوب محلا على أنه مفعول يلفظ، وإلا أداة حصر، ولديه ظرف مكان متعلق بمحذوف خبر مقدم، ورقيب مبتدأ مؤخر، وعتيد نعت مرفوع، والجملة في محل نصب حال من فاعل <span class="hlt"><span class="qpc-hafs">﴿يلفظ﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿ما يلفظ...﴾</span></span> لا محل لها من الإعراب، لأنها استئناف بياني.</p></div>"
  50,19,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وجاءت سكرة الموت بالحق ذلك ما كنت منه تحيد﴾</span></span>: كلام مستأنف لا محل له من الإعراب، وجاءت سكرة الموت فعل وفاعل، وبالحق حال، أي: حال كونها متلبسة بالحق، فالباء للملابسة، وقيل: هي للتعدية، وذلك مبتدأ، وما خبر، وكان فعل ماض ناقص، والتاء اسمها، ومنه جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تحيد﴾</span></span>، وجملة تحيد خبر كان، وجملة <span class="hlt"><span class="qpc-hafs">﴿كنت﴾</span></span> صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> لا محل لها من الإعراب. وجملة ذلك ما كنت مقول قول محذوف.</p></div>"
  50,20,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ونفخ في الصور ذلك يوم الوعيد﴾</span></span>: عطف على <span class="hlt"><span class="qpc-hafs">﴿وجاءت سكرة الموت﴾</span></span>، ونفخ فعل ماض مبني لما لم يسمَّ فاعله، وفي الصور جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿نفخ﴾</span></span>، وذلك مبتدأ، ويوم الوعيد خبره، والإشارة إلى مصدر نفخ.</p></div>"
  50,21,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وجاءت كل نفس معها سائق وشهيد﴾</span></span>: الواو عاطفة، وجاءت كل نفس فعل وفاعل، ومعها ظرف مكان متعلق بمحذوف خبر مقدم، وسائق مبتدأ مؤخر، وشهيد عطف على سائق، والجملة الاسمية في محل رفع صفة لكل، أو في محل نصب صفة لها، أي: معها من يسوقها، ويشد عليها، ولك أن تجعلها حالية.</p></div>"
  50,22,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿لقد كنت في غفلة من هذا فكشفنا عنك غطاءك فبصرك اليوم حديد﴾</span></span>: الجملة مقول قول محذوف، أي: يقال لكل نفس، واللام جواب للقسم المحذوف، وقد حرف تحقيق، وكان فعل ماض ناقص، والتاء اسمها، وفي غفلة جار ومجرور متعلقان بمحذوف خبر كان، و<span class="hlt"><span class="qpc-hafs">﴿من هذا﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿غفلة﴾</span></span>، والفاء حرف عطف، وكشفنا فعل وفاعل، وعنك جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿كشفنا﴾</span></span>، وغطاءك مفعول به، والفاء عاطفة، وبصرك مبتدأ، واليوم ظرف متعلق بمحذوف حال، وحديد خبر بصرك.</p></div>"
  50,23,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وقال قرينه هذا ما لدي عتيد﴾</span></span>: الواو عاطفة، وقال قرينه فعل وفاعل، وهذا مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> موصول بدل من <span class="hlt"><span class="qpc-hafs">﴿هذا﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿لدي﴾</span></span> ظرف متعلق بمحذوف صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span>، وجملة الصلة لا محل لها من الإعراب. وعتيد خبر <span class="hlt"><span class="qpc-hafs">﴿هذا﴾</span></span>.</p></div>"
  50,24,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ألقيا في جهنم كل كفار عنيد﴾</span></span>: الجملة مقول قول محذوف، أي: يقال: ألقيا، وألقيا فعل أمر مبني على حذف النون لاتصاله بألف الاثنين، وفي جهنم جار ومجرور متعلقان بألقيا، وكل كفار مفعول به، وعنيد صفة لكفار.</p></div>"
  50,25,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿مناع للخير معتد مريب﴾</span></span>: مناع نعت ثانٍ لكفار، وللخير الجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿مناع﴾</span></span>، ومعتد نعت آخر لكفار مجرور بكسرة مقدرة على الياء المحذوفة لالتقاء الساكنين، ومريب: نعت آخر.</p></div>"
  50,26,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿الذي جعل مع الله إلها آخر﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿الذي﴾</span></span> بدل من <span class="hlt"><span class="qpc-hafs">﴿كل﴾</span></span>، أو من <span class="hlt"><span class="qpc-hafs">﴿كفار﴾</span></span>، أو منصوب على الذم، أو مبتدأ والخبر جملة <span class="hlt"><span class="qpc-hafs">﴿فألقياه﴾</span></span>. جملة <span class="hlt"><span class="qpc-hafs">﴿جعل﴾</span></span> صلة الموصول لا محل لها من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿مع الله﴾</span></span> ظرف متعلق بمحذوف مفعول به ثانٍ، و<span class="hlt"><span class="qpc-hafs">﴿إلهًا آخر﴾</span></span> مفعول به أول.</p><p><span class="hlt"><span class="qpc-hafs">﴿فألقياه في العذاب الشديد﴾</span></span>: الفاء رابطة لشبه الموصول بالشرط في العموم، وألقياه: فعل أمر وفاعل ومفعول به، والجملة خبر الذي إذا جعلت خبرًا، وفي العذاب: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿ألقياه﴾</span></span>، والشديد نعت لـ<span class="hlt"><span class="qpc-hafs">﴿العذاب﴾</span></span>.</p></div>"
  50,27,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قال قرينه ربنا ما أطغيته ولكن كان في ضلال بعيد﴾</span></span>: قال قرينه فعل وفاعل، وربنا منادى مضاف، وما نافية، وأطغيته فعل وفاعل ومفعول به، ولكن حرف استدراك مهمل، لأنه خفف، وكان فعل ماض ناقص، واسمها مستتر تقديره: هو، وفي ضلال: جار ومجرور متعلقان بمحذوف خبر كان، وبعيد صفة لضلال، وجملة <span class="hlt"><span class="qpc-hafs">﴿قال قرينه﴾</span></span> مستأنفة لا محل لها من الإعراب.</p></div>"
  50,28,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قال لا تختصموا لدي وقد قدمت إليكم بالوعيد﴾</span></span>: قال فعل ماض مبني على الفتح والفاعل مستتر تقديره هو، ولا ناهية، وتختصموا فعل مضارع مجزوم، والجملة مقول القول، ولدي ظرف متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿تختصموا﴾</span></span>، والواو للحال، وقد حرف تحقيق، وقدمت فعل وفاعل، وإليكم: جار ومجرور متعلقان بقدمت، والباء في بالوعيد حرف صلة، أو يقع الفعل على جملة قوله: <span class="hlt"><span class="qpc-hafs">﴿ما يبدل القول﴾</span></span>، ويكون بالوعيد حالًا، أي: قدمت إليكم هذا متلبسًا بالوعيد مقترنًا به، أو قدمته إليكم موعدًا لكم به.</p></div>"
  50,29,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ما يبدل القول لدي وما أنا بظلام للعبيد﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> نافية، و<span class="hlt"><span class="qpc-hafs">﴿يبدل﴾</span></span> فعل مضارع مبني لما لم يسمَّ فاعله، و<span class="hlt"><span class="qpc-hafs">﴿القول﴾</span></span> نائب فاعل، و<span class="hlt"><span class="qpc-hafs">﴿لدي﴾</span></span> ظرف متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿يبدل﴾</span></span>، والواو حرف عطف، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> نافية حجازية تعمل عمل ليس، و<span class="hlt"><span class="qpc-hafs">﴿أنا﴾</span></span> اسم ما، و<span class="hlt"><span class="qpc-hafs">﴿بظلام﴾</span></span> الباء: حرف جر صلة، وظلام: خبر <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> الحجازية منصوب محلا مجرور بالباء لفظًا، وللعبيد: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿ظلام﴾</span></span>.</p></div>"
  50,30,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿يوم نقول لجهنم هل امتلأت﴾</span></span>: يوم ظرف زمان منصوب متعلق بظلام، نقول مضارع مرفوع والفاعل نحن، ولجهنم جار ومجرور بفتحة للعلمية والتأنيث متعلقان بنقول. هل للاستفهام، امتلأت ماض مبني على السكون والتاء فاعل.</p><p><span class="hlt"><span class="qpc-hafs">﴿وتقول هل من مزيد﴾</span></span>: الواو عاطفة وتقول مضارع مرفوع والفاعل هي، هل للاستفهام من: حرف جر صلة، ومزيد مجرور لفظًا مرفوع محلا مبتدأ مؤخر خبره محذوف أي هناك، وجملة نقول في محل جر مضاف إليه، وهل امتلأت في محل نصب مقول نقول، وتقول في محل جر معطوفة على نقول، وهل من مزيد في محل نصب مقول تقول.</p></div>"
  50,31,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وأزلفت الجنة﴾</span></span>: الواو حرف عطف، وأزلفت فعل ماض مبني لما لم يسمَّ فاعله، والجنة نائب فاعل.</p><p><span class="hlt"><span class="qpc-hafs">﴿للمتقين﴾</span></span>: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أزلفت﴾</span></span> .</p><p><span class="hlt"><span class="qpc-hafs">﴿غير بعيد﴾</span></span>: منصوب على الظرفية لقيامه مقام الظرف، لأنه صفته، أي: مكانًا غير بعيد، وقيل: منصوب على الحال.</p></div>"
  50,32,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿هذا ما توعدون لكل أواب حفيظ﴾</span></span>: هذا: مبتدأ، وما: خبره، وجملة <span class="hlt"><span class="qpc-hafs">﴿توعدون﴾</span></span>: صلة الموصول لا محل لها من الإعراب، ولكل: جار ومجرور بدل من قوله: <span class="hlt"><span class="qpc-hafs">﴿للمتقين﴾</span></span> بإعادة العامل، وجملة <span class="hlt"><span class="qpc-hafs">﴿هذا ما توعدون﴾</span></span>: اعتراضية فصل بها بين البدل والمبدل منه، لا محل لها من الإعراب، أو منصوبة بقول مضمر، والقول المضمر منصوب على الحال، أي: مقولا لهم... .</p></div>"
  50,33,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿من خشي الرحمن بالغيب﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿من﴾</span></span> اسم موصول بدل من <span class="hlt"><span class="qpc-hafs">﴿كل﴾</span></span>، أو خبر لمبتدأ محذوف، أي: هم من خشي، أو مبتدأ خبره جملة <span class="hlt"><span class="qpc-hafs">﴿ادخلوها بسلام﴾</span></span>. وجملة <span class="hlt"><span class="qpc-hafs">﴿خشي الرحمن﴾</span></span> صلة الموصول لا محل لها من الإعراب. وبالغيب: جار ومجرور متعلقان بمحذوف حال من <span class="hlt"><span class="qpc-hafs">﴿الرحمن﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿وجاء بقلب منيب﴾</span></span>: الواو عاطفة وجاء فعل ماض والفاعل مستتر تقديره هو، وبقلب: جار ومجرور في محل نصب حال من فاعل <span class="hlt"><span class="qpc-hafs">﴿جاء﴾</span></span>، ومنيب نعت مجرور، والجملة لا محل لها من الإعراب عطفًا بالواو على جملة الصلة.</p></div>"
  50,34,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ادخلوها بسلام﴾</span></span>: الجملة مقول القول محذوف كما تقدم، وادخلوها فعل وفاعل ومفعول به، وبسلام حال من الفاعل، أي: سالمين من كل مخوفة، فهي حال مقارنة.</p><p><span class="hlt"><span class="qpc-hafs">﴿ذلك يوم الخلود﴾</span></span>: ذلك مبتدأ، ويوم الخلود خبر.</p></div>"
  50,35,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿لهم ما يشاءون فيها﴾</span></span>: لهم جار ومجرور متعلقان بمحذوف خبر مقدم، وما موصولة مبنية على السكون في محل رفع مبتدأ مؤخر، وجملة يشاءون صلة الموصول لا محل لها من الإعراب، وفيها جار ومجرور متعلقان بمحذوف حال من الموصول، أو متعلقان بيشاءون.</p><p><span class="hlt"><span class="qpc-hafs">﴿ولدينا مزيد﴾</span></span>: لدينا ظرف متعلق بمحذوف خبر مقدم، ومزيد مبتدأ مؤخر.</p></div>"