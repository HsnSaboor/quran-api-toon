quran[13]{c,v,t}:
  36,71,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿أولم يروا أنا خلقنا لهم مما عملت أيدينا أنعاما﴾</span></span>: الهمزة للاستفهام التقريري، وأصلها: وألم يروا، وتقدم الاستفهام للصدارة، أو الواو عاطفة على محذوف يقتضيه السياق، والتقدير: ألم يتفكروا ولم يروا، و<span class="hlt"><span class="qpc-hafs">﴿لم﴾</span></span> حرف نفي وقلب وجزم، و<span class="hlt"><span class="qpc-hafs">﴿يروا﴾</span></span> فعل مضارع مجزوم بـ<span class="hlt"><span class="qpc-hafs">﴿لم﴾</span></span>، والواو فاعل، والرؤية علمية، و<span class="hlt"><span class="qpc-hafs">﴿أنا﴾</span></span> أن حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> اسمها، وجملة <span class="hlt"><span class="qpc-hafs">﴿خلقنا﴾</span></span> خبرها، وهي فعل وفاعل، وأن وما في حيزها سدت مسد مفعولي <span class="hlt"><span class="qpc-hafs">﴿يروا﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿لهم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿خلقنا﴾</span></span>، أي: لأجلهم وانتفاعهم، و<span class="hlt"><span class="qpc-hafs">﴿مما﴾</span></span> جار ومجرور متعلقان بمحذوف حال، وجملة <span class="hlt"><span class="qpc-hafs">﴿عملت﴾</span></span> صلة الموصول لا محل لها من الإعراب. والعائد محذوف، أي: عملته، و<span class="hlt"><span class="qpc-hafs">﴿أيدينا﴾</span></span> فاعل، و<span class="hlt"><span class="qpc-hafs">﴿أنعامًا﴾</span></span> مفعول <span class="hlt"><span class="qpc-hafs">﴿خلقنا﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿فهم لها مالكون﴾</span></span>: الفاء عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿لها﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿مالكون﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿مالكون﴾</span></span> خبر <span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span>.</p></div>"
  36,72,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وذللناها لهم فمنها ركوبهم ومنها يأكلون﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿ذللناها﴾</span></span> فعل ماض وفاعل ومفعول، و<span class="hlt"><span class="qpc-hafs">﴿لهم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿ذللناها﴾</span></span>، والفاء للتفريع، و<span class="hlt"><span class="qpc-hafs">﴿منها﴾</span></span> جار ومجرور متعلقان بمحذوف خبر مقدم، و<span class="hlt"><span class="qpc-hafs">﴿ركوبهم﴾</span></span> مبتدأ مؤخر، و<span class="hlt"><span class="qpc-hafs">﴿منها﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يأكلون﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿يأكلون﴾</span></span> فعل مضارع مرفوع، والواو فاعل.</p></div>"
  36,73,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ولهم فيها منافع ومشارب﴾</span></span>: الواو عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿لهم﴾</span></span> جار ومجرور متعلقان بمحذوف خبر مقدم، و<span class="hlt"><span class="qpc-hafs">﴿فيها﴾</span></span> جار ومجرور متعلقان بمحذوف حال، و<span class="hlt"><span class="qpc-hafs">﴿منافع﴾</span></span> مبتدأ مؤخر، و<span class="hlt"><span class="qpc-hafs">﴿مشارب﴾</span></span> عطف على <span class="hlt"><span class="qpc-hafs">﴿منافع﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿أفلا يشكرون﴾</span></span>: الهمزة للاستفهام الإنكاري، والفاء عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿لا﴾</span></span> نافية، و<span class="hlt"><span class="qpc-hafs">﴿يشكرون﴾</span></span> فعل مضارع، والواو فاعل.</p></div>"
  36,74,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿واتخذوا من دون الله آلهة﴾</span></span>: الواو عاطفة على مقدر يستدعيه السياق، أي: ما فعلوا الشكر، و<span class="hlt"><span class="qpc-hafs">﴿اتخذوا﴾</span></span> فعل أمر وفاعل، و<span class="hlt"><span class="qpc-hafs">﴿من دون الله﴾</span></span> جار ومجرور متعلقان بمحذوف مفعول ثان لـ<span class="hlt"><span class="qpc-hafs">﴿اتخذوا﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿آلهة﴾</span></span> مفعوله الأول.</p><p><span class="hlt"><span class="qpc-hafs">﴿لعلهم ينصرون﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿لعل﴾</span></span> حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> اسمها، وجملة <span class="hlt"><span class="qpc-hafs">﴿ينصرون﴾</span></span> خبرها، والواو نائب فاعل، وجملة الرجاء حالية، أي: حال كونهم راجين النصر من آلهتهم.</p></div>"
  36,75,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿لا يستطيعون نصرهم وهم لهم جند محضرون﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿لا﴾</span></span> نافية، و<span class="hlt"><span class="qpc-hafs">﴿يستطيعون﴾</span></span> فعل مضارع وفاعل، و<span class="hlt"><span class="qpc-hafs">﴿نصرهم﴾</span></span> مفعول به، والواو للحال، و<span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿لهم﴾</span></span> جار ومجرور متعلقان بمحذوف حال من <span class="hlt"><span class="qpc-hafs">﴿جند﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿جند﴾</span></span> خبر <span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿محضرون﴾</span></span> خبر ثان لـ<span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span>، أو نعت لـ<span class="hlt"><span class="qpc-hafs">﴿جند﴾</span></span>.</p></div>"
  36,76,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فلا يحزنك قولهم إنا نعلم ما يسرون وما يعلنون﴾</span></span>: الفاء الفصيحة، و<span class="hlt"><span class="qpc-hafs">﴿لا﴾</span></span> ناهية، و<span class="hlt"><span class="qpc-hafs">﴿يحزنك﴾</span></span> فعل مضارع مجزوم بـ<span class="hlt"><span class="qpc-hafs">﴿لا﴾</span></span>، والكاف مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿قولهم﴾</span></span> فاعل، و<span class="hlt"><span class="qpc-hafs">﴿إنا﴾</span></span> إن حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> اسمها، وجملة <span class="hlt"><span class="qpc-hafs">﴿نعلم﴾</span></span> خبرها، والفاعل مستتر تقديره: نحن، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> موصولة مفعول به، أي: الذي يسرونه، أو مصدرية، أي: إسرارهم، وجملة <span class="hlt"><span class="qpc-hafs">﴿يسرون﴾</span></span> لا محل لها من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿ما يعلنون﴾</span></span> عطف على <span class="hlt"><span class="qpc-hafs">﴿ما يسرون﴾</span></span>.</p></div>"
  36,77,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿أولم ير الإنسان أنا خلقناه من نطفة فإذا هو خصيم مبين﴾</span></span>: كلام مستأنف لا محل له من الإعراب، والهمزة للاستفهام الإنكاري التعجبي، والواو عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿لم﴾</span></span> حرف نفي وقلب وجزم، و<span class="hlt"><span class="qpc-hafs">﴿ير﴾</span></span> فعل مضارع مجزوم بـ<span class="hlt"><span class="qpc-hafs">﴿لم﴾</span></span> وعلامة جزمه حذف حرف العلة، و<span class="hlt"><span class="qpc-hafs">﴿الإنسان﴾</span></span> فاعل، و<span class="hlt"><span class="qpc-hafs">﴿أنا﴾</span></span>: أن حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> اسمها، وجملة <span class="hlt"><span class="qpc-hafs">﴿خلقناه﴾</span></span> خبرها، وأن وما في حيزها سدت مسد مفعولي <span class="hlt"><span class="qpc-hafs">﴿ير﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿خلقناه﴾</span></span> فعل وفاعل ومفعول به، و<span class="hlt"><span class="qpc-hafs">﴿من نطفة﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿خلقناه﴾</span></span>، والفاء حرف عطف، و<span class="hlt"><span class="qpc-hafs">﴿إذا﴾</span></span> فجائية، و<span class="hlt"><span class="qpc-hafs">﴿هو﴾</span></span> مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿خصيم﴾</span></span> خبر، و<span class="hlt"><span class="qpc-hafs">﴿مبين﴾</span></span> صفة، وجملة <span class="hlt"><span class="qpc-hafs">﴿إذا هو خصيم مبين﴾</span></span> عطف على جملة <span class="hlt"><span class="qpc-hafs">﴿لم ير الإنسان﴾</span></span> داخلة معها في حيز الإنكار والتعجب.</p></div>"
  36,78,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وضرب لنا مثلا ونسي خلقه﴾</span></span>: الواو عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿ضرب﴾</span></span> فعل ماض، وفاعله مستتر تقديره: هو، و<span class="hlt"><span class="qpc-hafs">﴿لنا﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿ضرب﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿مثلًا﴾</span></span> مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿نسي﴾</span></span> عطف على <span class="hlt"><span class="qpc-hafs">﴿ضرب﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿خلقه﴾</span></span> مفعول به، أو الواو للحال بتقدير: قد، أي: وقد نسي خلقه.</p><p><span class="hlt"><span class="qpc-hafs">﴿قال من يحي العظام وهي رميم﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿مَن﴾</span></span> اسم استفهام مبتدأ، وجملة <span class="hlt"><span class="qpc-hafs">﴿يحيي العظام﴾</span></span> خبر، والواو حالية، و<span class="hlt"><span class="qpc-hafs">﴿هي﴾</span></span> مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿رميم﴾</span></span> خبر، والجملة في موضع نصب على الحال.</p></div>"
  36,79,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قل يحييها الذي أنشأها أول مرة﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿يحييها﴾</span></span> فعل مضارع ومفعول به، وجملة <span class="hlt"><span class="qpc-hafs">﴿يحييها﴾</span></span> مقول القول، و<span class="hlt"><span class="qpc-hafs">﴿الذي﴾</span></span> فاعل، وجملة <span class="hlt"><span class="qpc-hafs">﴿أنشأها﴾</span></span> صلة الموصول لا محل لها من الإعراب. و<span class="hlt"><span class="qpc-hafs">﴿أول مرة﴾</span></span> نصب على الظرف متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿أنشأها﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿وهو بكل خلق عليم﴾</span></span>: الواو استئنافية أو حالية، و<span class="hlt"><span class="qpc-hafs">﴿هو﴾</span></span> مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿بكل﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿عليم﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿عليم﴾</span></span> خبر <span class="hlt"><span class="qpc-hafs">﴿هو﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿وهو بكل...﴾</span></span> مستأنفة لا محل لها من الإعراب، أو في محل نصب حال.</p></div>"
  36,80,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿الذي جعل لكم من الشجر الأخضر نارا﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿الذي﴾</span></span> بدل من الذي الآنفة الذكر، وجملة <span class="hlt"><span class="qpc-hafs">﴿جعل﴾</span></span> صلة الموصول لا محل لها من الإعراب. و<span class="hlt"><span class="qpc-hafs">﴿لكم﴾</span></span> جار ومجرور متعلقان بمحذوف مفعول ثان، و<span class="hlt"><span class="qpc-hafs">﴿من الشجر الأخضر﴾</span></span> جار ومجرور متعلقان بمحذوف حال، و<span class="hlt"><span class="qpc-hafs">﴿نارًا﴾</span></span> مفعول <span class="hlt"><span class="qpc-hafs">﴿جعل﴾</span></span> الأول.</p><p><span class="hlt"><span class="qpc-hafs">﴿فإذا أنتم منه توقدون﴾</span></span>: الفاء عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿إذا﴾</span></span> فجائية، و<span class="hlt"><span class="qpc-hafs">﴿أنتم﴾</span></span> مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿منه﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿توقدون﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿توقدون﴾</span></span> خبر <span class="hlt"><span class="qpc-hafs">﴿أنتم﴾</span></span>.</p></div>"
  36,81,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿أوليس الذي خلق السماوات والأرض بقادر على أن يخلق مثلهم﴾</span></span>: الهمزة للاستفهام الإنكاري، والواو للعطف على مقدر يقتضيه المقام، و<span class="hlt"><span class="qpc-hafs">﴿ليس﴾</span></span> فعل ماض ناقص ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿الذي﴾</span></span> اسمها، وجملة <span class="hlt"><span class="qpc-hafs">﴿خلق...﴾</span></span> صلة الموصول لا محل لها من الإعراب. والباء حرف جر صلة، و<span class="hlt"><span class="qpc-hafs">﴿قادر﴾</span></span> مجرور لفظًا منصوب محلا على أنه خبر ليس، و<span class="hlt"><span class="qpc-hafs">﴿على﴾</span></span> حرف جر، و<span class="hlt"><span class="qpc-hafs">﴿أن﴾</span></span> وما في حيزها في محل جر بـ<span class="hlt"><span class="qpc-hafs">﴿على﴾</span></span>، والجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿قادر﴾</span></span>، والفاعل مستتر تقديره: هو، و<span class="hlt"><span class="qpc-hafs">﴿مثلهم﴾</span></span> مفعول به.</p><p><span class="hlt"><span class="qpc-hafs">﴿بلى﴾</span></span>: حرف جواب لإبطال النفي، أي: بلى هو قادر على ذلك.</p><p><span class="hlt"><span class="qpc-hafs">﴿وهو الخلاق العليم﴾</span></span>: الواو عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿هو﴾</span></span> مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿الخلاق﴾</span></span> خبر، و<span class="hlt"><span class="qpc-hafs">﴿العليم﴾</span></span> خبر ثان.</p></div>"
  36,82,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إنما أمره إذا أراد شيئا أن يقول له كن فيكون﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿إنما﴾</span></span> كافة ومكفوفة، و<span class="hlt"><span class="qpc-hafs">﴿أمره﴾</span></span> مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿إذا﴾</span></span> ظرف مستقبل، وجملة <span class="hlt"><span class="qpc-hafs">﴿أراد﴾</span></span> مضاف إليه، وهي فعل ماض، والفاعل مستتر، و<span class="hlt"><span class="qpc-hafs">﴿شيئًا﴾</span></span> مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿أن﴾</span></span> مصدرية، و<span class="hlt"><span class="qpc-hafs">﴿يقول﴾</span></span> فعل مضارع منصوب بـ<span class="hlt"><span class="qpc-hafs">﴿أن﴾</span></span>، وأن وما في حيزها خبر المبتدأ <span class="hlt"><span class="qpc-hafs">﴿أمره﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿له﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يقول﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿كن﴾</span></span> مقول القول، وهو فعل أمر تام، وفاعله مستتر تقديره: أنت، والفاء عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿يكون﴾</span></span> فعل مضارع مرفوع، والفاعل مستتر، والفعل وفاعله جملة في محل رفع خبر لمبتدأ محذوف، والجملة عطف على <span class="hlt"><span class="qpc-hafs">﴿أمره﴾</span></span>.</p></div>"
  36,83,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فسبحان الذي بيده ملكوت كل شيء﴾</span></span>: الفاء الفصيحة، و<span class="hlt"><span class="qpc-hafs">﴿سبحان﴾</span></span> نائب مفعول مطلق منصوب بفعل محذوف، و<span class="hlt"><span class="qpc-hafs">﴿الذي﴾</span></span> مضاف إليه، و<span class="hlt"><span class="qpc-hafs">﴿بيده﴾</span></span> جار ومجرور متعلقان بمحذوف خبر مقدم، و<span class="hlt"><span class="qpc-hafs">﴿ملكوت كل شيء﴾</span></span> مبتدأ مؤخر، وجملة <span class="hlt"><span class="qpc-hafs">﴿بيده ملكوت كل شيء﴾</span></span> صلة الموصول لا محل لها من الإعراب.</p><p><span class="hlt"><span class="qpc-hafs">﴿وإليه ترجعون﴾</span></span>: الواو عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿إليه﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿ترجعون﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿ترجعون﴾</span></span> فعل مضارع مبني لما لم يسمَّ فاعله، والواو نائب فاعل.</p></div>"