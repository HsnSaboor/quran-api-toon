quran[22]{c,v,t}:
  54,28,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ونبئهم أن الماء قسمة بينهم كل شرب محتضر﴾</span></span>: الواو عاطفة، ونبئهم فعل أمر وفاعل مستتر تقديره: أنت، والهاء مفعول أول، وأن وما في حيزها في موضع المفعول الثاني والثالث، لأن نبأ تنصب ثلاثة مفاعيل، وأن حرف ناسخ، والماء اسمها، وقسمة خبرها، وبينهم ظرف متعلق بمحذوف صفة قسمة، أو بقسمة، لأنها بمعنى مقسومة، وكل مبتدأ، وشرب مضاف إليه، ومحتضر خبر كل.</p></div>"
  54,29,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فنادوا صاحبهم فتعاطى فعقر﴾</span></span>: الفاء عاطفة، ونادوا فعل ماض وفاعل، والمعطوف عليه محذوف، أي: فتمادوا على ذلك، والأحسن أن تكون الفصيحة، وصاحبهم مفعول به، فتعاطى عطف على فنادوا، فعقر عطف على تعاطى.</p></div>"
  54,30,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فكيف كان عذابي ونذر﴾</span></span>: الفاء الفصيحة، وكيف اسم استفهام في محل نصب خبر كان المقدم، وكان عذابي: كان حرف ناسخ، وعذاب اسمها، والياء مضاف إليه، ونذر معطوف على عذابي مرفوع بالضمة المقدرة على ما قبل ياء المتكلم المحذوفة، والياء في محل جر مضاف إليه، والجملة لا محل لها من الإعراب، لأنها استئنافية.</p></div>"
  54,31,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إنا أرسلنا عليهم صيحة واحدة فكانوا كهشيم المحتظر﴾</span></span>: إن حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> اسمها، وجملة أرسلنا خبرها، وعليهم جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أرسلنا﴾</span></span>، وصيحة مفعول به، وواحدة صفة، فكانوا عطف على أرسلنا، والواو اسم كان، و<span class="hlt"><span class="qpc-hafs">﴿كهشيم﴾</span></span> الكاف اسم بمعنى مثل مبني على الفتح في محل نصب خبر كان، و<span class="hlt"><span class="qpc-hafs">﴿هشيم﴾</span></span> مضاف إليه، والمحتظر مضاف إليه.</p></div>"
  54,32,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ولقد يسرنا القرآن للذكر﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿ولقد﴾</span></span> الواو: استئنافية، واللام: واقعة في جواب قسم مقدر، وقد: حرف تحقيق، و<span class="hlt"><span class="qpc-hafs">﴿يسرنا﴾</span></span> فعل ماضٍ و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> فاعل، و<span class="hlt"><span class="qpc-hafs">﴿القرآن﴾</span></span> مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿للذكر﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يسرنا﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿لقد يسرنا﴾</span></span> لا محل لها من الإعراب لأنها جواب القسم المقدر، وجملة القسم المقدر مستأنفة لا محل لها من الإعراب.</p><p><span class="hlt"><span class="qpc-hafs">﴿فهل من مدكر﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿فهل﴾</span></span> الفاء: عاطفة، وهل: حرف استفهام، و<span class="hlt"><span class="qpc-hafs">﴿من﴾</span></span> حرف جر صلة، و<span class="hlt"><span class="qpc-hafs">﴿مدكر﴾</span></span> مبتدأ مرفوع محلا  مجرور بـ<span class="hlt"><span class="qpc-hafs">﴿من﴾</span></span> لفظًا، وخبره محذوف تقديره: موجود.</p></div>"
  54,33,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿كذبت قوم لوط بالنذر﴾</span></span>: فعل ماضٍ وفاعل، وبالنذر جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿كذبت﴾</span></span>.</p></div>"
  54,34,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إنا أرسلنا عليهم حاصبا إلا آل لوط نجيناهم بسحر﴾</span></span>: إن حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> اسمها، وجملة أرسلنا خبرها، وعليهم جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أرسلنا﴾</span></span>، وحاصبًا مفعول به، وإلا أداة استثناء، وآل لوط مستثنى بإلا، وفي هذا الاستثناء وجهان أحدهما: أنه متصل، ويكون المعنى أنه أرسل الحاصب على الجميع إلا أهله، فإنه لم يرسل عليهم، والثاني: أنه منقطع، ويكون المعنى أنه لم يرسل على آل لوط، والوجه هو الأول، ونجيناهم فعل وفاعل، وبسحر جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿نجيناهم﴾</span></span>.</p></div>"
  54,35,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿نعمة من عندنا كذلك نجزي من شكر﴾</span></span>: نعمة نائب مفعول مطلق لأنه اسم مصدر، والتقدير: أنعمنا على لوط ومن معه نعمة، أو: مفعول لأجله، و<span class="hlt"><span class="qpc-hafs">﴿من عندنا﴾</span></span> جار ومجرور متعلقان بمحذوف صفة لنعمة، و<span class="hlt"><span class="qpc-hafs">﴿كذلك﴾</span></span> الكاف اسم بمعنى مثل مبني على الفتح في محل نصب صفة لمصدر محذوف، و<span class="hlt"><span class="qpc-hafs">﴿ذلك﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿ذا﴾</span></span> اسم إشارة في محل جر مضاف إليه، واللام للبعد، والكاف حرف خطاب، ونجزي فعل مضارع مرفوع، ومن موصول مفعول به، وجملة شكر صلة الموصول لا محل لها من الإعراب.</p></div>"
  54,36,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ولقد أنذرهم بطشتنا فتماروا بالنذر﴾</span></span>: الواو استئنافية، واللام جواب للقسم المحذوف، وقد حرف تحقيق، وأنذرهم فعل وفاعل مستتر، ومفعول به أول، وبطشتنا مفعول به ثانٍ، أو هو منصوب بنزع الخافض قولان، والفاء حرف عطف، وتماروا فعل ماض، والواو فاعل، وبالنذر جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تماروا﴾</span></span>.</p></div>"
  54,37,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ولقد راودوه عن ضيفه فطمسنا أعينهم﴾</span></span>: الجملة عطف على الجملة السابقة، والواو حرف عطف، واللام جواب للقسم المحذوف، وقد حرف تحقيق، و<span class="hlt"><span class="qpc-hafs">﴿راودوه﴾</span></span> فعل ماض، والواو فاعل، والهاء مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿عن ضيفه﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿راودوه﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿فطمسنا﴾</span></span> فعل ماض معطوف على <span class="hlt"><span class="qpc-hafs">﴿راودوه﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> فاعل، و<span class="hlt"><span class="qpc-hafs">﴿أعينهم﴾</span></span> مفعول به، والفاء عاطفة، ومعطوفها محذوف، أي: فقلنا لهم.</p><p><span class="hlt"><span class="qpc-hafs">﴿فذوقوا عذابي ونذر﴾</span></span>: الفاء في جواب الشرط المقدر، و<span class="hlt"><span class="qpc-hafs">﴿ذوقوا﴾</span></span> فعل الأمر مبني على حذف النون، والواو في محل رفع فاعل، و<span class="hlt"><span class="qpc-hafs">﴿عذابي﴾</span></span> مفعول به منصوب بفتحة مقدرة على ما قبل ياء المتكلم، والياء في محل جر مضاف إليه، ونذر: مثل <span class="hlt"><span class="qpc-hafs">﴿عذابي﴾</span></span>، والياء المحذوفة في محل جر مضاف إليه، والجملة في محل جزم جواب الشرط المقدر، أي: إن أصررتم على الكفر فذوقوا، والجملة الشرطية كلها في محل نصب مقول القول.</p></div>"
  54,38,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ولقد صبحهم بكرة عذاب مستقر﴾</span></span>: عطف أيضًا، وبكرة ظرف متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿صبحهم﴾</span></span>، أي: من غير يوم معين، وعذاب فاعل، ومستقر نعت لعذاب، أي: لا يزول عنهم.</p></div>"
  54,39,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فذوقوا عذابي ونذر﴾</span></span>: الفاء في جواب الشرط المقدر، وفعل الأمر مبني على حذف النون، والواو في محل رفع فاعل، وعذابي مفعول به منصوب بفتحة مقدرة عل ما قبل ياء المتكلم، والياء في محل جر مضاف إليه، ونذر: مثل عذابي، والياء المحذوفة في محل جر مضاف إليه، والجملة في محل جزم جواب الشرط المقدر، أي: إن أصررتم على الكفر فذوقوا، والجملة الشرطية كلها في محل نصب مقول القول.</p></div>"
  54,40,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ولقد يسرنا القرآن للذكر﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿ولقد﴾</span></span> الواو: استئنافية، واللام: واقعة في جواب قسم مقدر، وقد: حرف تحقيق، و<span class="hlt"><span class="qpc-hafs">﴿يسرنا﴾</span></span> فعل ماضٍ و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> فاعل، و<span class="hlt"><span class="qpc-hafs">﴿القرآن﴾</span></span> مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿للذكر﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يسرنا﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿لقد يسرنا﴾</span></span> لا محل لها من الإعراب لأنها جواب القسم المقدر، وجملة القسم المقدر مستأنفة لا محل لها من الإعراب.</p><p><span class="hlt"><span class="qpc-hafs">﴿فهل من مدكر﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿فهل﴾</span></span> الفاء: عاطفة، وهل: حرف استفهام، و<span class="hlt"><span class="qpc-hafs">﴿من﴾</span></span> حرف جر صلة، و<span class="hlt"><span class="qpc-hafs">﴿مدكر﴾</span></span> مبتدأ مرفوع محلا  مجرور بـ<span class="hlt"><span class="qpc-hafs">﴿من﴾</span></span> لفظًا، وخبره محذوف تقديره: موجود.</p></div>"
  54,41,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ولقد جاء آل فرعون النذر﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿ولقد﴾</span></span> الواو: استئنافية، واللام: واقعة في جواب قسم مقدر، وقد: حرف تحقيق، و<span class="hlt"><span class="qpc-hafs">﴿جاء﴾</span></span> فعل ماضٍ و<span class="hlt"><span class="qpc-hafs">﴿آل﴾</span></span> مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿فرعون﴾</span></span> مضاف إليه مجرور بالفتحة لأنه ممنوع من الصرف، و<span class="hlt"><span class="qpc-hafs">﴿النذر﴾</span></span> فاعل مرفوع بالضمة، وجملة <span class="hlt"><span class="qpc-hafs">﴿لقد جاء﴾</span></span> لا محل لها من الإعراب لأنها جواب القسم المقدر، وجملة القسم المقدر مستأنفة لا محل لها من الإعراب.</p></div>"
  54,42,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿كذبوا بآياتنا كلها فأخذناهم أخذ عزيز مقتدر﴾</span></span>: كلام مستأنف لا محل له من الإعراب، وكذبوا ماضٍ مبني على الضم والواو فاعل، وبآياتنا جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿كذبوا﴾</span></span>، وكلها تأكيد لآياتنا، فأخذناهم: الفاء عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿أخذناهم﴾</span></span> فعل وفاعل ومفعول به، وأخذ: مفعول مطلق، وعزيز: مضاف إليه، ومقتدر: صفة لعزيز، والإضافة من إضافة المصدر لفاعله.</p></div>"
  54,43,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿أكفاركم خير من أولئكم﴾</span></span>: أكفاركم: الهمزة للاستفهام الإنكاري، الذي هو بمعنى النفي، وكفاركم مبتدأ، وخير خبر، ومن أوليائكم جار ومجرور متعلقان بخير.</p><p><span class="hlt"><span class="qpc-hafs">﴿أم لكم براءة في الزبر﴾</span></span>: أم: منقطعة بمعنى: بل وهمزة الاستفهام الإنكاري، والتقدير: بل ألكم براءة ...؟ و<span class="hlt"><span class="qpc-hafs">﴿لكم﴾</span></span> جار ومجرور متعلقان بمحذوف خبر مقدم، وبراءة مبتدأ مؤخر، و<span class="hlt"><span class="qpc-hafs">﴿في الزبر﴾</span></span> جار ومجرور متعلقان بمحذوف نعت لبراءة.</p></div>"
  54,44,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿أم يقولون نحن جميع منتصر﴾</span></span>: أم: منقطعة بمعنى: بل وهمزة الاستفهام، أو بمعنى: بل، فقط، و<span class="hlt"><span class="qpc-hafs">﴿يقولون﴾</span></span> فعل مضارع مرفوع، والواو فاعل، ونحن مبتدأ، وجميع خبر، ومنتصر نعت لجميع، لأنه بمعنى جمع، والجملة مقول القول، وإنما وحد منتصر للفظ بـ<span class="hlt"><span class="qpc-hafs">﴿جميع﴾</span></span>، فإنه واحد في اللفظ، وإن كان اسمًا للجماعة كالرهط والجيش.</p></div>"
  54,45,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿سيهزم الجمع ويولون الدبر﴾</span></span>: السين حرف استقبال، ويهزم فعل مضارع مبني لما لم يسمَّ فاعله، والجمع نائب فاعل، ويولون عطف على سيهزم، والدبر مفعول به.</p></div>"
  54,46,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿بل الساعة موعدهم والساعة أدهى وأمر﴾</span></span>: بل حرف إضراب وعطف، والساعة مبتدأ، وموعدهم خبر، والواو حرف عطف، والساعة مبتدأ، وأدهى خبر، وأمر عطف على الساعة، ولك أن تجعل الواو للحال.</p></div>"
  54,47,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إن المجرمين في ضلال وسعر﴾</span></span>: إن حرف ناسخ، والمجرمين اسمها، وفي ضلال جار ومجرور متعلقان بمحذوف خبرها، وسعر معطوف بالواو مجرور بالكسرة، والجملة لا محل لها من الإعراب، لأنها استئنافية.</p></div>"
  54,48,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿يوم يسحبون في النار على وجوههم﴾</span></span>: يوم الظرف متعلق بقول محذوف، أي: يقال لهم يوم يسحبون، وجملة يسحبون في محل جر بإضافة الظرف إليها، وفي النار جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يسحبون﴾</span></span>، وعلى وجوههم جار ومجرور متعلقان بمحذوف حال.</p><p><span class="hlt"><span class="qpc-hafs">﴿ذوقوا مس سقر﴾</span></span>: ذوقوا فعل أمر مبني على حذف النون، والواو فاعل، والجملة مقول القول المقدر، ومس مفعول به، وسقر مضاف إليه، وهي علم لجهنم، ولذلك منعت من الصرف، لأنها علم مؤنث.</p></div>"
  54,49,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إنا كل شيء خلقناه بقدر﴾</span></span>: إن حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> اسمها، وكل شيء نصب على الاشتغال بفعل محذوف يدل عليه ما بعده، أي: إنا خلقنا كل شيء خلقناه، وجملة الفعل المحذوف في محل رفع خبر إن، وجملة خلقناه مُفسِّرة لا محل لها من الإعراب، وبقدر جار ومجرور متعلقان بمحذوف حال من كل، أي: مقدرًا محكمًا مرتبًا.</p></div>"