quran[27]{c,v,t}:
  37,25,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ما لكم لا تناصرون﴾</span></span>: الجملة مقول قول محذوف، أي: ويقال توبيخًا لهم، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> اسم استفهام مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿لكم﴾</span></span> جار ومجرور متعلقان بمحذوف خبر، و<span class="hlt"><span class="qpc-hafs">﴿لا﴾</span></span> نافية، و<span class="hlt"><span class="qpc-hafs">﴿تناصرون﴾</span></span> فعل مضارع مرفوع بثبوت النون، والواو فاعل، وجملة <span class="hlt"><span class="qpc-hafs">﴿لا تناصرون﴾</span></span> حالية.</p></div>"
  37,26,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿بل هم اليوم مستسلمون﴾</span></span>: بل حرف إضراب، و<span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿اليوم﴾</span></span> ظرف متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿مستسلمون﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿مستسلمون﴾</span></span> خبر <span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span>.</p></div>"
  37,27,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وأقبل بعضهم على بعض يتساءلون﴾</span></span>: الواو استئنافية، و<span class="hlt"><span class="qpc-hafs">﴿أقبل﴾</span></span> فعل ماض، و<span class="hlt"><span class="qpc-hafs">﴿بعضهم﴾</span></span> فاعل، و<span class="hlt"><span class="qpc-hafs">﴿على بعض﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أقبل﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿يتساءلون﴾</span></span> فعل مضارع، والواو فاعل، وجملة <span class="hlt"><span class="qpc-hafs">﴿يتساءلون﴾</span></span> حالية، وجملة <span class="hlt"><span class="qpc-hafs">﴿وأقبل بعضهم على بعض﴾</span></span> مستأنفة لا محل لها من الإعراب.</p></div>"
  37,28,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قالوا إنكم كنتم تأتوننا عن اليمين﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿قالوا﴾</span></span> فعل وفاعل، و<span class="hlt"><span class="qpc-hafs">﴿إنكم﴾</span></span> إن حرف ناسخ، والكاف اسمها، و<span class="hlt"><span class="qpc-hafs">﴿كنتم﴾</span></span>: كان فعل ماض ناقص، والتاء اسمها، وجملة تأتوننا خبرها، و<span class="hlt"><span class="qpc-hafs">﴿تأتوننا﴾</span></span> فعل مضارع، والواو فاعل، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> مفعول به، وجملة <span class="hlt"><span class="qpc-hafs">﴿كنتم﴾</span></span> خبر إن، و<span class="hlt"><span class="qpc-hafs">﴿عن اليمين﴾</span></span> جار ومجرور متعلقان بمحذوف حال من فاعل <span class="hlt"><span class="qpc-hafs">﴿تأتوننا﴾</span></span>.</p></div>"
  37,29,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قالوا بل لم تكونوا مؤمنين﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿قالوا﴾</span></span> فعل وفاعل، و<span class="hlt"><span class="qpc-hafs">﴿بل﴾</span></span> إضراب إبطالي، و<span class="hlt"><span class="qpc-hafs">﴿لم﴾</span></span> حرف نفي وقلب وجزم، و<span class="hlt"><span class="qpc-hafs">﴿تكونوا﴾</span></span> فعل مضارع مجزوم بـ<span class="hlt"><span class="qpc-hafs">﴿لم﴾</span></span>، والواو اسمها، ومؤمنين خبرها.</p></div>"
  37,30,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وما كان لنا عليكم من سلطان﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> نافية، و<span class="hlt"><span class="qpc-hafs">﴿كان﴾</span></span> فعل ماض ناقص ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿لنا﴾</span></span> جار ومجرور متعلقان بمحذوف خبرها المقدم، و<span class="hlt"><span class="qpc-hafs">﴿عليكم﴾</span></span> جار ومجرور متعلقان بمحذوف حال، و<span class="hlt"><span class="qpc-hafs">﴿من﴾</span></span> حرف جر صلة، و<span class="hlt"><span class="qpc-hafs">﴿سلطان﴾</span></span> مجرور لفظًا اسم كان محلا.</p><p><span class="hlt"><span class="qpc-hafs">﴿بل كنتم قوما طاغين﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿بل﴾</span></span> إضراب إبطالي أيضًا، و<span class="hlt"><span class="qpc-hafs">﴿كنتم﴾</span></span>: كان فعل ماض ناقص، والتاء اسمها، و<span class="hlt"><span class="qpc-hafs">﴿قومًا﴾</span></span> خبرها، و<span class="hlt"><span class="qpc-hafs">﴿طاغين﴾</span></span> نعت لـ<span class="hlt"><span class="qpc-hafs">﴿قومًا﴾</span></span>.</p></div>"
  37,31,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فحق علينا قول ربنا إنا لذائقون﴾</span></span>: الفاء حرف عطف، و<span class="hlt"><span class="qpc-hafs">﴿حق﴾</span></span> فعل ماض، و<span class="hlt"><span class="qpc-hafs">﴿علينا﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿حق﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿قول ربنا﴾</span></span> فاعل، و<span class="hlt"><span class="qpc-hafs">﴿إنا﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span> حرف ناسخ و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> اسمها، واللام المزحلقة، و<span class="hlt"><span class="qpc-hafs">﴿ذائقون﴾</span></span> خبرها، والجملة الاسمية تعليل لما تقدم، ومفعول <span class="hlt"><span class="qpc-hafs">﴿ذائقون﴾</span></span> محذوف، أي: العذاب، والفاعل مستتر تقديره: نحن.</p></div>"
  37,32,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فأغويناكم إنا كنا غاوين﴾</span></span>: الفاء عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿أغويناكم﴾</span></span> فعل ماض، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> فاعل، والكاف مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿إنا﴾</span></span> إن حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> اسمها، و<span class="hlt"><span class="qpc-hafs">﴿كنا﴾</span></span> كان فعل ماض ناقص ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> اسمها، و<span class="hlt"><span class="qpc-hafs">﴿غاوين﴾</span></span> خبرها، وجملة <span class="hlt"><span class="qpc-hafs">﴿كنا﴾</span></span> خبر إن.</p></div>"
  37,33,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فإنهم يومئذ في العذاب مشتركون﴾</span></span>: الفاء الفصيحة، و<span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span> حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> اسمها، و<span class="hlt"><span class="qpc-hafs">﴿يومئذ﴾</span></span> يوم: ظرف زمان متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿مشتركون﴾</span></span>، وإذٍ: اسم مبني على السكون المقدر لاشتغال المحل بتنوين العوض في محل جر مضاف إليه، والتنوين عوض عن جملة والتقدير: يوم إذ يتساءلون، و<span class="hlt"><span class="qpc-hafs">﴿في العذاب﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿مشتركون﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿مشتركون﴾</span></span> خبر <span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span>.</p></div>"
  37,34,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إنا كذلك نفعل بالمجرمين﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span> حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> اسمها، و<span class="hlt"><span class="qpc-hafs">﴿كذلك﴾</span></span> الكاف اسم بمعنى مثل مبني على الفتح في محل نصب صفة لمصدر محذوف مقدم على عامله، و<span class="hlt"><span class="qpc-hafs">﴿ذلك﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿ذا﴾</span></span> اسم إشارة في محل جر مضاف إليه، واللام للبعد، والكاف حرف خطاب، و<span class="hlt"><span class="qpc-hafs">﴿نفعل﴾</span></span> فعل مضارع، والفاعل مستتر، وجملة <span class="hlt"><span class="qpc-hafs">﴿نفعل﴾</span></span> خبر <span class="hlt"><span class="qpc-hafs">﴿إنا﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿بالمجرمين﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿نفعل﴾</span></span>.</p></div>"
  37,35,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إنهم كانوا إذا قيل لهم لا إله إلا الله يستكبرون﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span> حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> اسمها، و<span class="hlt"><span class="qpc-hafs">﴿كان﴾</span></span> فعل ماض ناقص ناسخ، والواو اسمها، وجملة <span class="hlt"><span class="qpc-hafs">﴿كانوا﴾</span></span> خبر إن، و<span class="hlt"><span class="qpc-hafs">﴿إذا﴾</span></span> ظرف مستقبل متضمن معنى الشرط، وقيل فعل ماض مبني لما لم يسم فاعله، ونائب الفاعل مستتر تقديره: هو، وجملة <span class="hlt"><span class="qpc-hafs">﴿قيل﴾</span></span> في محل جر بالإضافة، و<span class="hlt"><span class="qpc-hafs">﴿لهم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿قيل﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿لا﴾</span></span> نافية للجنس، و<span class="hlt"><span class="qpc-hafs">﴿إله﴾</span></span> اسمها المبني على الفتح، و<span class="hlt"><span class="qpc-hafs">﴿إلا﴾</span></span> أداة حصر، و<span class="hlt"><span class="qpc-hafs">﴿الله﴾</span></span> بدل من محل <span class="hlt"><span class="qpc-hafs">﴿لا﴾</span></span> واسمها، وجملة <span class="hlt"><span class="qpc-hafs">﴿لا إله إلا الله﴾</span></span> مقول قول محذوف، أي: قولوا: لا إله إلا الله، و<span class="hlt"><span class="qpc-hafs">﴿يستكبرون﴾</span></span> فعل مضارع مرفوع، والواو فاعل، وجملة <span class="hlt"><span class="qpc-hafs">﴿يستكبرون﴾</span></span> خبر <span class="hlt"><span class="qpc-hafs">﴿كانوا﴾</span></span>، وجواب <span class="hlt"><span class="qpc-hafs">﴿إذا﴾</span></span> محذوف دل عليه ما قبله.</p></div>"
  37,36,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ويقولون أئنا لتاركوا آلهتنا لشاعر مجنون﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿يقولون﴾</span></span> عطف على <span class="hlt"><span class="qpc-hafs">﴿يستكبرون﴾</span></span>، والهمزة للاستفهام الإنكاري، و<span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span> حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> اسمها، واللام المزحلقة، و<span class="hlt"><span class="qpc-hafs">﴿تاركو﴾</span></span> خبر <span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿لشاعر﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تاركو﴾</span></span>، أي: لأجل شاعر، و<span class="hlt"><span class="qpc-hafs">﴿مجنون﴾</span></span> صفة.</p></div>"
  37,37,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿بل جاء بالحق وصدق المرسلين﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿بل﴾</span></span> إضراب إبطالي، و<span class="hlt"><span class="qpc-hafs">﴿جاء﴾</span></span> فعل ماض، والفاعل مستتر، و<span class="hlt"><span class="qpc-hafs">﴿بالحق﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿جاء﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿صدق﴾</span></span> فعل ماض، والفاعل مستتر، و<span class="hlt"><span class="qpc-hafs">﴿المرسلين﴾</span></span> مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿صدق المرسلين﴾</span></span> عطف على <span class="hlt"><span class="qpc-hafs">﴿جاء بالحق﴾</span></span>.</p></div>"
  37,38,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إنكم لذائقو العذاب الأليم﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span> حرف ناسخ، والكاف اسمها، واللام المزحلقة، و<span class="hlt"><span class="qpc-hafs">﴿ذائقو﴾</span></span> خبر <span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span>، والعذاب مضاف إليه، و<span class="hlt"><span class="qpc-hafs">﴿الأليم﴾</span></span> صفة.</p></div>"
  37,39,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وما تجزون إلا ما كنتم تعملون﴾</span></span>: الواو عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> نافية، و<span class="hlt"><span class="qpc-hafs">﴿تجزون﴾</span></span> فعل مضارع مبني لما لم يسمَّ فاعله، والواو نائب فاعل، و<span class="hlt"><span class="qpc-hafs">﴿إلا﴾</span></span> أداة حصر، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> مفعول به ثان، وهو على حذف مضاف، أي: جزاء ما، و<span class="hlt"><span class="qpc-hafs">﴿كنتم﴾</span></span> فعل ماض ناقص، والتاء اسمها، وجملة <span class="hlt"><span class="qpc-hafs">﴿تعملون﴾</span></span> خبرها، و<span class="hlt"><span class="qpc-hafs">﴿تعملون﴾</span></span> فعل مضارع مرفوع، والواو فاعل، وجملة <span class="hlt"><span class="qpc-hafs">﴿كنتم تعملون﴾</span></span> صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> لا محل لها من الإعراب.</p></div>"
  37,40,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إلا عباد الله المخلصين﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿إلا﴾</span></span> أداة استثناء بمعنى لكن، لأن الاستثناء منقطع، و<span class="hlt"><span class="qpc-hafs">﴿عباد الله﴾</span></span> مستثنى من الواو في <span class="hlt"><span class="qpc-hafs">﴿تجزون﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿المخلصين﴾</span></span> صفة لـ<span class="hlt"><span class="qpc-hafs">﴿عباد الله﴾</span></span>.</p></div>"
  37,41,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿أولئك لهم رزق معلوم﴾</span></span>: كلام مستأنف لا محل له من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿أولئك﴾</span></span> مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿لهم﴾</span></span> جار ومجرور متعلقان بمحذوف خبر مقدم، و<span class="hlt"><span class="qpc-hafs">﴿رزق﴾</span></span> مبتدأ مؤخر، و<span class="hlt"><span class="qpc-hafs">﴿معلوم﴾</span></span> صفة لـ<span class="hlt"><span class="qpc-hafs">﴿رزق﴾</span></span>، ونائب الفاعل مستتر، وجملة <span class="hlt"><span class="qpc-hafs">﴿لهم رزق معلوم﴾</span></span> خبر المبتدأ الأول <span class="hlt"><span class="qpc-hafs">﴿أولئك﴾</span></span>.</p></div>"
  37,42,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فواكه وهم مكرمون﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿فواكه﴾</span></span> بدل، أو عطف بيان لـ<span class="hlt"><span class="qpc-hafs">﴿رزق﴾</span></span>، والواو عاطفة، أو حالية، و<span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿مكرمون﴾</span></span> خبر.</p></div>"
  37,43,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿في جنات النعيم﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿في جنات﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿مكرمون﴾</span></span>، أو متعلقان بمحذوف خبر ثان لـ<span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> في الآية السابقة، أو متعلقان بمحذوف حال.</p></div>"
  37,44,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿على سرر متقابلين﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿على سرر﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿متقابلين﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿متقابلين﴾</span></span> حال، أو <span class="hlt"><span class="qpc-hafs">﴿على سرر﴾</span></span> جار ومجرور متعلقان بمحذوف حال أيضا.</p></div>"
  37,45,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿يطاف عليهم بكأس من معين﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿يطاف﴾</span></span> فعل مضارع مبني لما لم يسمّ فاعله، و<span class="hlt"><span class="qpc-hafs">﴿عليهم﴾</span></span> جار ومجرور متعلقان بمحذوف نائب فاعل، و<span class="hlt"><span class="qpc-hafs">﴿بكأس﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يطاف﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿من معين﴾</span></span> جار ومجرور متعلقان بمحذوف صفة لـ<span class="hlt"><span class="qpc-hafs">﴿كأس﴾</span></span>، والجملة صفة لـ<span class="hlt"><span class="qpc-hafs">﴿مكرمون﴾</span></span>، أو حال من الضمير في <span class="hlt"><span class="qpc-hafs">﴿متقابلين﴾</span></span>، أو جملة مستأنفة لا محل لها من الإعراب.</p></div>"
  37,46,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿بيضاء لذة للشاربين﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿بيضاء﴾</span></span> صفة ثانية لـ<span class="hlt"><span class="qpc-hafs">﴿كأس﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿لذة﴾</span></span> صفة ثالثة لـ<span class="hlt"><span class="qpc-hafs">﴿كأس﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿للشاربين﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿لذة﴾</span></span>.</p></div>"
  37,47,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿لا فيها غول﴾</span></span>: الجملة صفة رابعة لـ<span class="hlt"><span class="qpc-hafs">﴿كأس﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿لا﴾</span></span> نافية، و<span class="hlt"><span class="qpc-hafs">﴿فيها﴾</span></span> جار ومجرور متعلقان بمحذوف خبر مقدم، و<span class="hlt"><span class="qpc-hafs">﴿غول﴾</span></span> مبتدأ مؤخر.</p><p><span class="hlt"><span class="qpc-hafs">﴿ولا هم عنها ينزفون﴾</span></span>: الواو عاطفة، <span class="hlt"><span class="qpc-hafs">﴿لا﴾</span></span> نافية، و<span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿عنها﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿ينزفون﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿ينزفون﴾</span></span> فعل مضارع مبني لما لم يسمَّ فاعله، والواو نائب فاعل، وجملة <span class="hlt"><span class="qpc-hafs">﴿ينزفون﴾</span></span> خبر <span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span>.</p></div>"
  37,48,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وعندهم قاصرات الطرف عين﴾</span></span>: الواو عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿عندهم﴾</span></span> ظرف متعلق بمحذوف خبر مقدم، و<span class="hlt"><span class="qpc-hafs">﴿قاصرات الطرف﴾</span></span> مبتدأ مؤخر، و<span class="hlt"><span class="qpc-hafs">﴿الطرف﴾</span></span> مضاف إليه مرفوع المحل على اعتبار أن <span class="hlt"><span class="qpc-hafs">﴿قاصرات﴾</span></span> صفة مشبهة، أو منصوب المحل على اعتبار أن <span class="hlt"><span class="qpc-hafs">﴿قاصرات﴾</span></span> اسم فاعل، و<span class="hlt"><span class="qpc-hafs">﴿عين﴾</span></span> صفة لـ<span class="hlt"><span class="qpc-hafs">﴿قاصرات الطرف﴾</span></span>.</p></div>"
  37,49,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿كأنهن بيض مكنون﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿كأن﴾</span></span> حرف للتشبيه والنصب، و<span class="hlt"><span class="qpc-hafs">﴿هن﴾</span></span> اسمها، و<span class="hlt"><span class="qpc-hafs">﴿بيض﴾</span></span> خبرها، و<span class="hlt"><span class="qpc-hafs">﴿مكنون﴾</span></span> صفة لـ<span class="hlt"><span class="qpc-hafs">﴿بيض﴾</span></span>، والجملة صفة ثانية لـ<span class="hlt"><span class="qpc-hafs">﴿قاصرات﴾</span></span>.</p></div>"
  37,50,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فأقبل بعضهم على بعض يتساءلون﴾</span></span>: الفاء عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿أقبل بعضهم﴾</span></span> فعل وفاعل، و<span class="hlt"><span class="qpc-hafs">﴿على بعض﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أقبل﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿يتساءلون﴾</span></span> فعل مضارع مرفوع، والواو فاعل، وجملة <span class="hlt"><span class="qpc-hafs">﴿يتساءلون﴾</span></span> حالية، وجملة <span class="hlt"><span class="qpc-hafs">﴿أقبل بعضهم﴾</span></span> معطوفة على <span class="hlt"><span class="qpc-hafs">﴿يطاف عليهم﴾</span></span>.</p></div>"
  37,51,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قال قائل منهم إني كان لي قرين﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿قال قائل﴾</span></span> فعل وفاعل، و<span class="hlt"><span class="qpc-hafs">﴿منهم﴾</span></span> جار ومجرور متعلقان بمحذوف صفة لـ<span class="hlt"><span class="qpc-hafs">﴿قائل﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿إني﴾</span></span> إن حرف ناسخ، والياء اسمها، و<span class="hlt"><span class="qpc-hafs">﴿كان﴾</span></span> فعل ماض ناقص ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿لي﴾</span></span> جار ومجرور متعلقان بمحذوف خبر <span class="hlt"><span class="qpc-hafs">﴿كان﴾</span></span> مقدم، و<span class="hlt"><span class="qpc-hafs">﴿قرين﴾</span></span> اسمها مؤخر، وجملة <span class="hlt"><span class="qpc-hafs">﴿كان﴾</span></span> خبر إن، وجملة إن واسمها وخبرها مقول القول.</p></div>"