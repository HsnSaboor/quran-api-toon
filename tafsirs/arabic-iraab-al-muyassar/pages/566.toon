quran[18]{c,v,t}:
  68,43,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿خاشعة﴾</span></span>: حال من ضمير يدعون.</p><p><span class="hlt"><span class="qpc-hafs">﴿أبصارهم﴾</span></span>: فاعل خاشعة، والضمير في محل جر بالإضافة.</p><p><span class="hlt"><span class="qpc-hafs">﴿ترهقهم﴾</span></span>: حال ثانية، وترهقهم فعل مضارع، والضمير مفعول به مقدّم.</p><p><span class="hlt"><span class="qpc-hafs">﴿ذلّة﴾</span></span>: فاعل مؤخر.</p><p><span class="hlt"><span class="qpc-hafs">﴿وقد﴾</span></span>: الواو حالية، وقد حرف تحقيق.</p><p><span class="hlt"><span class="qpc-hafs">﴿كانوا﴾</span></span>: فعل ماضٍ ناقص، والواو اسمها.</p><p><span class="hlt"><span class="qpc-hafs">﴿يدعون﴾</span></span>: فعل والواو فاعل، والجملة خبر كانوا.</p><p><span class="hlt"><span class="qpc-hafs">﴿إلى السجود﴾</span></span>: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يدعون﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿وهم﴾</span></span>: الواو حالية، وهم مبتدأ.</p><p><span class="hlt"><span class="qpc-hafs">﴿سالمون﴾</span></span>: خبر مرفوع بالواو.</p></div>"
  68,44,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فذرني﴾</span></span>: الفاء عاطفة، أو فصيحة، لأنها جواب شرط مقدّر، والتقدير: إذا كانت أحوالهم كذلك فذرني، وذر: فعل أمر، وفاعله مستتر، والياء في محل نصب مفعول به.</p><p><span class="hlt"><span class="qpc-hafs">﴿ومن﴾</span></span>: الواو حرف عطف، ومن عطف على الياء، أو الواو للمعية، ومن في محل نصب مفعول معه، والأول أرجح.</p><p><span class="hlt"><span class="qpc-hafs">﴿يكذب﴾</span></span>: فعل مضارع، والفاعل مستتر، وجملة <span class="hlt"><span class="qpc-hafs">﴿يكذب﴾</span></span> صلة الموصول لا محل لها من الإعراب.</p><p><span class="hlt"><span class="qpc-hafs">﴿بهذا﴾</span></span>: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يكذب﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿الحديث﴾</span></span>: بدل من اسم الإشارة.</p><p><span class="hlt"><span class="qpc-hafs">﴿سنستدرجهم﴾</span></span>: كلام مستأنف لا محل له من الإعراب، والسين للاستقبال، ونستدرجهم: فعل مضارع وفاعل مستتر، والضمير مفعول به.</p><p><span class="hlt"><span class="qpc-hafs">﴿من﴾</span></span>: حرف جر مبني لا محل له من الإعراب.</p><p><span class="hlt"><span class="qpc-hafs">﴿حيث﴾</span></span>: ظرف مبني على الضم في محل جر بمن، والجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿نستدرجهم﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿لا﴾</span></span>: نافية.</p><p><span class="hlt"><span class="qpc-hafs">﴿يعلمون﴾</span></span>: فعل مضارع مرفوع بثبوت النون، وجملة لا يعلمون في محل جر بإضافة الظرف إليها.</p></div>"
  68,45,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وأملي﴾</span></span>: الواو عاطفة، وأملي فعل مضارع، وفاعله مستتر.</p><p><span class="hlt"><span class="qpc-hafs">﴿لهم﴾</span></span>: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أملي﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span>: حرف ناسخ.</p><p><span class="hlt"><span class="qpc-hafs">﴿كيدي﴾</span></span>: اسم إن منصوب بالفتحة المقدرة منع من ظهورها اشتغال المحل بحركة المناسبة لياء المتكلم، وياء المتكلم مضاف إليه.</p><p><span class="hlt"><span class="qpc-hafs">﴿متين﴾</span></span>: خبر إن مرفوع بالضمة الظاهرة، والجملة بمثابة التعليل للإملاء.</p></div>"
  68,46,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿أم﴾</span></span>: عطف على ما تقدم، و<span class="hlt"><span class="qpc-hafs">﴿أم﴾</span></span> حرف عطف للإضراب الانتقالي.</p><p><span class="hlt"><span class="qpc-hafs">﴿تسألهم﴾</span></span>: فعل مضارع، وفاعل مستتر، ومفعول به أول.</p><p><span class="hlt"><span class="qpc-hafs">﴿أجرًا﴾</span></span>: مفعول به ثانٍ.</p><p><span class="hlt"><span class="qpc-hafs">﴿فهم﴾</span></span>: الفاء عاطفة، وهم مبتدأ.</p><p><span class="hlt"><span class="qpc-hafs">﴿من مغرم﴾</span></span>: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿مثقلون﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿مثقلون﴾</span></span>: خبر مرفوع بالواو.</p></div>"
  68,47,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿أم﴾</span></span>: عطف على ما تقدم، و<span class="hlt"><span class="qpc-hafs">﴿أم﴾</span></span> حرف عطف للإضراب الانتقالي.</p><p><span class="hlt"><span class="qpc-hafs">﴿عندهم﴾</span></span>: ظرف متعلق بمحذوف خبر مقدّم، والضمير مضاف إليه.</p><p><span class="hlt"><span class="qpc-hafs">﴿الغيب﴾</span></span>: مبتدأ مؤخر.</p><p><span class="hlt"><span class="qpc-hafs">﴿فهم﴾</span></span>: الفاء عاطفة، وهم مبتدأ.</p><p><span class="hlt"><span class="qpc-hafs">﴿يكتبون﴾</span></span>: فعل وفاعل، والجملة خبر.</p></div>"
  68,48,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فاصبر﴾</span></span>: الفاء الفصيحة، واصبر فعل أمر، وفاعله مستتر، تقديره: أنت.</p><p><span class="hlt"><span class="qpc-hafs">﴿لحكم﴾</span></span>: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿اصبر﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿ربك﴾</span></span>: مضاف إليه.</p><p><span class="hlt"><span class="qpc-hafs">﴿ولا﴾</span></span>: الواو حرف عطف، ولا ناهية.</p><p><span class="hlt"><span class="qpc-hafs">﴿تكن﴾</span></span>: فعل مضارع مجزوم بلا، واسمها مستتر، تقديره: أنت.</p><p><span class="hlt"><span class="qpc-hafs">﴿كصاحب﴾</span></span>: الكاف: اسم بمعنى مثل مبني على الفتح في محل نصب خبر تكن، وصاحب: مضاف إليه.</p><p><span class="hlt"><span class="qpc-hafs">﴿الحوت﴾</span></span>: مضاف إليه.</p><p><span class="hlt"><span class="qpc-hafs">﴿إذ﴾</span></span>: ظرف متعلق بمضاف محذوف والتقدير: ولا يكن حالك مثل حال صاحب الحوت وقت ندائه.</p><p><span class="hlt"><span class="qpc-hafs">﴿نادى﴾</span></span>: فعل ماضٍ والفاعل مستتر، والجملة في محل جر بإضافة الظرف إليها.</p><p><span class="hlt"><span class="qpc-hafs">﴿وهو﴾</span></span>: الواو حالية، وهو مبتدأ.</p><p><span class="hlt"><span class="qpc-hafs">﴿مكظوم﴾</span></span>: خبر، والجملة حال من ضمير نادى.</p></div>"
  68,49,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿لولا﴾</span></span>: حرف امتناع لوجود متضمن معنى الشرط.</p><p><span class="hlt"><span class="qpc-hafs">﴿أن﴾</span></span>: حرف مصدري ونصب.</p><p><span class="hlt"><span class="qpc-hafs">﴿تداركه﴾</span></span>: فعل ماضٍ، والهاء مفعول به.</p><p><span class="hlt"><span class="qpc-hafs">﴿نعمة﴾</span></span>: فاعل، وذُكِّر الفعل، لأن تأنيث النعمة غير حقيقي.</p><p><span class="hlt"><span class="qpc-hafs">﴿من ربه﴾</span></span>: جار ومجرور متعلقان بمحذوف نعت لـ<span class="hlt"><span class="qpc-hafs">﴿نعمة﴾</span></span>، وأن وما في حيِّزها في موضع رفع مبتدأ خبره محذوف وجوبًا.</p><p><span class="hlt"><span class="qpc-hafs">﴿لنبذ﴾</span></span>: اللام واقعة في جواب لولا، ونبذ فعل ماضٍ مبني لما لم يسمَّ فاعله، ونائب الفاعل مستتر، تقديره: هو.</p><p><span class="hlt"><span class="qpc-hafs">﴿بالعراء﴾</span></span>: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿نبذ﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿وهو﴾</span></span>: الواو حالية، وهو مبتدأ.</p><p><span class="hlt"><span class="qpc-hafs">﴿مذموم﴾</span></span>: خبر، والجملة حال من ضمير نبذ.</p></div>"
  68,50,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فاجتباه﴾</span></span>: الفاء عاطفة على مقدّر، أي: فأدركته نعمة من ربه فاجتباه، واجتباه فعل ماضٍ والضمير مفعول به.</p><p><span class="hlt"><span class="qpc-hafs">﴿ربه﴾</span></span>: فاعل مرفوع، والهاء مضاف إليه.</p><p><span class="hlt"><span class="qpc-hafs">﴿فجعله﴾</span></span>: عطف على <span class="hlt"><span class="qpc-hafs">﴿فاجتباه﴾</span></span>، والهاء مفعول به أول.</p><p><span class="hlt"><span class="qpc-hafs">﴿من الصالحين﴾</span></span>: جار ومجرور متعلقان بمحذوف مفعول ثانٍ لجعل.</p></div>"
  68,51,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وإن﴾</span></span>: الواو استئنافية، والجملة بعدها مستأنفة لا محل لها من الإعراب، وإن مخففة من الثقيلة مهملة.</p><p><span class="hlt"><span class="qpc-hafs">﴿يكاد﴾</span></span>: فعل مضارع ناقص من أفعال المقاربة.</p><p><span class="hlt"><span class="qpc-hafs">﴿الذين﴾</span></span>: اسم موصول في محل رفع اسم يكاد.</p><p><span class="hlt"><span class="qpc-hafs">﴿كفروا﴾</span></span>: فعل ماضٍ، وواو الجماعة فاعل، وجملة <span class="hlt"><span class="qpc-hafs">﴿كفروا﴾</span></span> صلة الموصول لا محل لها من الإعراب.</p><p><span class="hlt"><span class="qpc-hafs">﴿ليزلقونك﴾</span></span>: اللام الفارقة، ويزلقونك فعل مضارع مرفوع بثبوت النون، والواو فاعل، والكاف مفعول به، وجملة <span class="hlt"><span class="qpc-hafs">﴿يزلقونك﴾</span></span> في محل نصب خبر يكاد.</p><p><span class="hlt"><span class="qpc-hafs">﴿بأبصارهم﴾</span></span>: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يزلقونك﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿لما﴾</span></span>: رابطة، أو حينية ظرفية.</p><p><span class="hlt"><span class="qpc-hafs">﴿سمعوا﴾</span></span>: فعل ماضٍ والواو فاعل.</p><p><span class="hlt"><span class="qpc-hafs">﴿الذكر﴾</span></span>: مفعول به، وجواب لما محذوف للدلالة عليه، أي: لما سمعوا الذكر كادوا يزلقونك.</p><p><span class="hlt"><span class="qpc-hafs">﴿ويقولون﴾</span></span>: الواو عاطفة، ويقولون عطف على يزلقونك.</p><p><span class="hlt"><span class="qpc-hafs">﴿إنه﴾</span></span>: إن حرف ناسخ، والهاء اسمها.</p><p><span class="hlt"><span class="qpc-hafs">﴿لمجنون﴾</span></span>: اللام المزحلقة، ومجنون خبر إن، والجملة مقول قولهم.</p></div>"
  68,52,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وما﴾</span></span>: الواو حالية، وما نافية مهملة، لانتقاء النفي بإلا.</p><p><span class="hlt"><span class="qpc-hafs">﴿هو﴾</span></span>: مبتدأ.</p><p><span class="hlt"><span class="qpc-hafs">﴿إلا﴾</span></span>: أداة حصر.</p><p><span class="hlt"><span class="qpc-hafs">﴿ذكر﴾</span></span>: خبر هو.</p><p><span class="hlt"><span class="qpc-hafs">﴿للعالمين﴾</span></span>: جار ومجرور متعلقان بمحذوف نعت لـ<span class="hlt"><span class="qpc-hafs">﴿ذكر﴾</span></span>.</p></div>"
  69,1,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿الحاقة﴾</span></span>: الحاقة مبتدأ وما بعده خبره، أو هو خبر لمبتدأ محذوف.</p></div>"
  69,2,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span>: ما اسم استفهام مبني على السكون في محل رفع مبتدأ.</p><p><span class="hlt"><span class="qpc-hafs">﴿الحاقة﴾</span></span>: خبر المبتدأ. والجملة الاسمية خبر الحاقة، والرابط هو إعادة المبتدأ بلفظه. وجملة <span class="hlt"><span class="qpc-hafs">﴿الحاقة ما الحاقة﴾</span></span> ابتدائية.</p></div>"
  69,3,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وما﴾</span></span>: الواو عاطفة، أو اعتراضية. و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> اسم استفهام في محل رفع مبتدأ.</p><p><span class="hlt"><span class="qpc-hafs">﴿أدراك﴾</span></span>: فعل ماضٍ، والكاف مفعول به، والفاعل مستتر، والجملة خبر ما.</p><p><span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span>: الثانية اسم استفهام أيضا في محل رفع مبتدأ.</p><p><span class="hlt"><span class="qpc-hafs">﴿الحاقة﴾</span></span>: خبر، وجملة <span class="hlt"><span class="qpc-hafs">﴿ما الحاقة﴾</span></span> في محل نصب سدت مسد المفعولين الثاني والثالث للفعل <span class="hlt"><span class="qpc-hafs">﴿أدراك﴾</span></span>، لأن أدرى ينصب ثلاثة مفاعيل. وجملة <span class="hlt"><span class="qpc-hafs">﴿ما أدراك ما الحاقة﴾</span></span> معطوفة على الجملة السابقة، أو اعتراضية لا محل لها من الإعراب.</p></div>"
  69,4,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿كذبت﴾</span></span>: كلام مستأنف لا محل له من الإعراب، وكذبت فعل ماضٍ.</p><p><span class="hlt"><span class="qpc-hafs">﴿ثمود﴾</span></span>: فاعل.</p><p><span class="hlt"><span class="qpc-hafs">﴿وعاد﴾</span></span>: عطف على ثمود.</p><p><span class="hlt"><span class="qpc-hafs">﴿بالقارعة﴾</span></span>: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿كذبت﴾</span></span>.</p></div>"
  69,5,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فأما﴾</span></span>: الفاء عاطفة، وأما حرف شرط وتفصيل.</p><p><span class="hlt"><span class="qpc-hafs">﴿ثمود﴾</span></span>: مبتدأ.</p><p><span class="hlt"><span class="qpc-hafs">﴿فأهلكوا﴾</span></span>: الفاء رابطة لجواب أما، وأهلكوا فعل ماضٍ مبني لما لم يسمَّ فاعله، والواو نائب فاعل.</p><p><span class="hlt"><span class="qpc-hafs">﴿بالطاغية﴾</span></span>: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أهلكوا﴾</span></span>، والجملة خبر ثمود.</p></div>"
  69,6,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وأما﴾</span></span>: الواو عاطفة، وأما حرف شرط وتفصيل.</p><p><span class="hlt"><span class="qpc-hafs">﴿عاد﴾</span></span>: مبتدأ.</p><p><span class="hlt"><span class="qpc-hafs">﴿فأهلكوا﴾</span></span>: الفاء رابطة لجواب <span class="hlt"><span class="qpc-hafs">﴿أما﴾</span></span>، وأهلكوا فعل ماضٍ مبني لما لم يسمَّ فاعله، والواو نائب فاعل.</p><p><span class="hlt"><span class="qpc-hafs">﴿بريح﴾</span></span>: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أهلكوا﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿فأهلكوا﴾</span></span> خبر عاد.</p><p><span class="hlt"><span class="qpc-hafs">﴿صرصر﴾</span></span>: صفة لـ<span class="hlt"><span class="qpc-hafs">﴿ريح﴾</span></span> مجرورة بالكسرة.</p><p><span class="hlt"><span class="qpc-hafs">﴿عاتية﴾</span></span>: صفة لـ<span class="hlt"><span class="qpc-hafs">﴿ريح﴾</span></span> أيضًا.</p></div>"
  69,7,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿سخرها﴾</span></span>: فعل ماضٍ ومفعول به، والفاعل مستتر يعود على الله، والجملة صفة ثالثة لـ<span class="hlt"><span class="qpc-hafs">﴿ريح﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿عليهم﴾</span></span>: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿سخرها﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿سبع﴾</span></span>: نصب على الظرفية الزمانية.</p><p><span class="hlt"><span class="qpc-hafs">﴿ليال﴾</span></span>: مضاف إليه.</p><p><span class="hlt"><span class="qpc-hafs">﴿وثمانية﴾</span></span>: عطف على سبع ليال.</p><p><span class="hlt"><span class="qpc-hafs">﴿أيام﴾</span></span>: مضاف إليه.</p><p><span class="hlt"><span class="qpc-hafs">﴿حسوما﴾</span></span>: نعت لسبع ليال وثمانية أيام، أو مصدر منصوب بفعل من لفظه، أي: تحسمهم حسوما، أو حال من مفعول سخرها، أي: ذات حسوم، أو مفعول لأجله.</p><p><span class="hlt"><span class="qpc-hafs">﴿فترى﴾</span></span>: الفاء عاطفة، وترى القوم فعل مضارع، وفاعل مستتر.</p><p><span class="hlt"><span class="qpc-hafs">﴿القوم﴾</span></span>: مفعول به.</p><p><span class="hlt"><span class="qpc-hafs">﴿فيها﴾</span></span>: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿ترى﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿صرعى﴾</span></span>: حال، لأن الرؤية هنا بصرية.</p><p><span class="hlt"><span class="qpc-hafs">﴿كأنهم﴾</span></span>: كأن حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> اسمها.</p><p><span class="hlt"><span class="qpc-hafs">﴿أعجاز﴾</span></span>: خبر كأن مرفوع.</p><p><span class="hlt"><span class="qpc-hafs">﴿نخل﴾</span></span>: مضاف إليه.</p><p><span class="hlt"><span class="qpc-hafs">﴿خاوية﴾</span></span>: نعت لـ<span class="hlt"><span class="qpc-hafs">﴿نخل﴾</span></span> مجرور، وجملة <span class="hlt"><span class="qpc-hafs">﴿كأنهم...﴾</span></span> حال من القوم، أو مستأنفة لا محل لها من الإعراب.</p></div>"
  69,8,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فهل﴾</span></span>: الفاء عاطفة، وهل حرف استفهام.</p><p><span class="hlt"><span class="qpc-hafs">﴿ترى﴾</span></span>: فعل مضارع مرفوع، وفاعله مستتر تقديره: أنت.</p><p><span class="hlt"><span class="qpc-hafs">﴿لهم﴾</span></span>: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿ترى﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿من﴾</span></span>: حرف جر صلة.</p><p><span class="hlt"><span class="qpc-hafs">﴿باقية﴾</span></span>: مجرور لفظًا منصوب محلا، لأنه مفعول ترى.</p></div>"