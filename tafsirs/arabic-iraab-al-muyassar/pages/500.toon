quran[9]{c,v,t}:
  45,14,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قل للذين آمنوا يغفروا للذين لا يرجون أيام الله﴾</span></span>: قل: فعل أمر، وفاعله مستتر تقديره أنت، وللذين: اللام حرف جر، والذين اسم موصول في محل جر، والجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿قل﴾</span></span>، وآمنوا: فعل ماض، وواو الجماعة فاعل، وجملة <span class="hlt"><span class="qpc-hafs">﴿آمنوا﴾</span></span> صلة الموصول لا محل لها من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿يغفروا﴾</span></span>: فعل مضارع مجزوم بلام أمر مقدرة، وجاز حذف اللام لدلالة <span class="hlt"><span class="qpc-hafs">﴿قُل﴾</span></span> على الأمر، وواو الجماعة فاعل.</p><p>أو: <span class="hlt"><span class="qpc-hafs">﴿يغفروا﴾</span></span> فعل مضارع مجزوم على أنه جواب الأمر <span class="hlt"><span class="qpc-hafs">﴿قُل﴾</span></span>، ومقول القول محذوف، والتقدير: قل للذين آمنوا اغفروا يغفروا.</p><p>أو: <span class="hlt"><span class="qpc-hafs">﴿يغفروا﴾</span></span> فعل مضارع صُرِف عن الأمر إلى الخبر، ومعناه <span class="hlt"><span class="qpc-hafs">﴿اغفروا﴾</span></span>، وبُنِي لوقوعه موقع المبني فحذفت نونه.</p><p>وللذين: اللام حرف جر، والذين اسم موصول في محل جر، والجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يغفروا﴾</span></span>، ولا: نافية، ويرجون: فعل مضارع، وواو الجماعة فاعل، وأيام: مفعول يرجون، ولفظ الجلالة: مضاف إليه، وجملة <span class="hlt"><span class="qpc-hafs">﴿لا يرجون﴾</span></span> صلة الموصول لا محل لها من الإعراب.</p><p><span class="hlt"><span class="qpc-hafs">﴿ليجزي قوما بما كانوا يكسبون﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿ليجزي﴾</span></span>: اللام للتعليل، ويجزي فعل مضارع منصوب بأن مضمرة بعد لام التعليل، والفاعل مستتر تقديره هو يعود على الله، والمصدر المؤول من <span class="hlt"><span class="qpc-hafs">﴿أن﴾</span></span> المضمرة والفعلِ مجرورٌ باللام، والجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿قل﴾</span></span>، وقومًا: مفعول به. و<span class="hlt"><span class="qpc-hafs">﴿بما﴾</span></span>: الباء: حرف جر، وما: اسم موصول مبني في محل جر، والجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يجزي﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿كانوا يكسبون﴾</span></span> صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> لا محل لها من الإعراب. أو <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> مصدرية، وهي وما دخلت عليه في تأويل مصدر مجرور بالباء، والجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يجزي﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿كانوا﴾</span></span>: كان فعل ماض ناقص، وواو الجماعة اسمها، ويكسبون: فعل مضارع، وواو الجماعة: فاعل، وجملة <span class="hlt"><span class="qpc-hafs">﴿يكسبون﴾</span></span> خبر كان.</p></div>"
  45,15,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿من عمل صالحا فلنفسه ومن أساء فعليها ثم إلى ربكم ترجعون﴾</span></span>: من: شرطية في محل رفع مبتدأ، والجملة مستأنفة لا محل لها من الإعراب، وعمل: فعل ماض في محل جزم فعل الشرط، والفاعل مستتر، وصالحًا: مفعول به لـ<span class="hlt"><span class="qpc-hafs">﴿عمل﴾</span></span>، أو نائب عن المفعول المطلق، لأنه صفة المصدر، أي: عمل عملًا صالحًا. والفاء: واقعة في جواب الشرط، ولنفسه: جار ومجرور في محل رفع خبر لمبتدأ محدوف تقديره: عمله، والهاء: ضمير مبني في محل جر مضاف إليه، والجملة في محل جزم جواب الشرط، و<span class="hlt"><span class="qpc-hafs">﴿من أساء﴾</span></span> عطف على الجملة السابقة، مماثلة لها في الإعراب، وثم: حرف عطف، وإلى ربكم: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿ترجعون﴾</span></span>، والكاف: مضاف إليه، وترجعون: فعل مضارع، والواو فاعل.</p></div>"
  45,16,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ولقد آتينا بني إسرائيل الكتاب والحكم والنبوة﴾</span></span>: الواو استئنافية، واللام: جواب للقسم المحذوف، وقد: حرف تحقيق، وآتينا: فعل وفاعل، وبني: مفعول به أول، وإسرائيل: مضاف إليه، والكتاب: مفعول به ثان، وجملة <span class="hlt"><span class="qpc-hafs">﴿ولقد آتينا...﴾</span></span> مستأنفة لا محل لها من الإعراب، <span class="hlt"><span class="qpc-hafs">﴿والحكم والنبوة﴾</span></span>: معطوفان منصوبان بالفتحة.</p><p><span class="hlt"><span class="qpc-hafs">﴿ورزقناهم من الطيبات وفضلناهم على العالمين﴾</span></span>: الواو عاطفة، ورزقناهم: فعل، وفاعل، ومفعول به، ومن الطيبات: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿رزقناهم﴾</span></span>، وفضلناهم: فعل، وفاعل، ومفعول به، وعلى العالمين: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿فضلنا﴾</span></span>.</p></div>"
  45,17,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وآتيناهم بينات من الأمر﴾</span></span>: الواو عاطفة، وآتيناهم: فعل، وفاعل، ومفعول به أول، وبينات: مفعول به ثان، وعلامة نصبه الكسرة، لأنه جمع مؤنث سالم، ومن الأمر: جار ومجرور متعلقان بمحذوف صفة لبينات.</p><p><span class="hlt"><span class="qpc-hafs">﴿فما اختلفوا إلا من بعد ما جاءهم العلم بغيا بينهم﴾</span></span>: الفاء عاطفة، وما نافية، واختلفوا: فعل وفاعل، وإلا: أداة حصر، ومن بعد: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿اختلفوا﴾</span></span>، وما: مصدرية مؤولة مع ما بعدها بمصدر مجرور بالإضافة، و<span class="hlt"><span class="qpc-hafs">﴿جاءهم العلم﴾</span></span>: فعل، والهاء مفعول به مقدم، والعلم فاعل مؤخَّر، وبغيًا: مفعول من أجله، وبينهم: ظرف متعلق بمحذوف صفة لـ<span class="hlt"><span class="qpc-hafs">﴿بغيًا﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿إن ربك يقضي بينهم يوم القيامة فيما كانوا فيه يختلفون﴾</span></span>: إن حرف ناسخ، ورب اسمها، والكاف مضاف إليه، ويقضي: فعل مضارع، والفاعل مستتر، وجملة <span class="hlt"><span class="qpc-hafs">﴿يقضي﴾</span></span>: خبر كان، وبينهم: ظرف متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿يقضي﴾</span></span>، ويوم: ظرف متعلق بمحذوف حال، والقيامة: مضاف إليه، وفيما: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يقضي﴾</span></span> أيضًا، وجملة <span class="hlt"><span class="qpc-hafs">﴿كانوا﴾</span></span>: صلة الموصول لا محل لها من الإعراب، وكان فعل ماض ناقص، وواو الجماعة اسمها، وجملة <span class="hlt"><span class="qpc-hafs">﴿يختلفون﴾</span></span>: خبر كان، وفيه جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يختلفون﴾</span></span>، ويختلفون: فعل مضارع، والواو: فاعل.</p></div>"
  45,18,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ثم جعلناك على شريعة من الأمر فاتبعها﴾</span></span>: ثم: حرف عطف، وجعلناك: فعل وفاعل ومفعول به أول، وعلى شريعة: جار ومجرور متعلقان بمحذوف مفعول ثان، ومن الأمر: جار ومجرور متعلقان بمحذوف نعت لشريعة، والفاء عاطفة، واتبعها: فعل أمر، وفاعل، ومفعول به.</p><p><span class="hlt"><span class="qpc-hafs">﴿ولا تتبع أهواء الذين لا يعلمون﴾</span></span>: الواو حرف عطف، ولا ناهية، وتتبع: فعل مضارع مجزوم بلا الناهية، والفاعل مستتر، وأهواء: مفعول به، والذين: مضاف إليه، ولا نافية، ويعلمون: فعل مضارع، والواو فاعل، وجملة <span class="hlt"><span class="qpc-hafs">﴿لا يعلمون﴾</span></span>: صفة.</p></div>"
  45,19,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إنهم لن يغنوا عنك من الله شيئا﴾</span></span>: الجملة تعليلية، وإن حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> اسمها، وجملة <span class="hlt"><span class="qpc-hafs">﴿لن يغنوا﴾</span></span>: خبرها، ولن: حرف نفي ونصب، ويغنوا: فعل مضارع منصوب، والواو: فاعل، وعنك: الجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يغنوا﴾</span></span>، ومن الله: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يغنوا﴾</span></span> أيضًا، وشيئًا: مفعول به.</p><p><span class="hlt"><span class="qpc-hafs">﴿وإن الظالمين بعضهم أولياء بعض والله ولي المتقين﴾</span></span>: الواو عاطفة، وإن حرف ناسخ، والظالمين اسمها، وبعضهم: مبتدأ، والهاء: مضاف إليه، وأولياء: خبر، وبعض: مضاف إليه، والجملة الاسمية خبر إن، والله: مبتدأ، وولي: خبر، والمتقين: مضاف إليه.</p></div>"
  45,20,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿هذا بصائر للناس وهدى ورحمة لقوم يوقنون﴾</span></span>: هذا: مبتدأ، وبصائر: خبره، وللناس: جار ومجرور متعلقان بمحذوف صفة لـ<span class="hlt"><span class="qpc-hafs">﴿بصائر﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿وهدى ورحمة﴾</span></span>: معطوفان مرفوعان، ولقوم: جار ومجرور متعلقان بمحذوف نعت، وجملة <span class="hlt"><span class="qpc-hafs">﴿يوقنون﴾</span></span>: نعت لقوم، ويوقنون: فعل مضارع، والواو: فاعل، والجملة كلها مستأنفة لا محل لها من الإعراب.</p></div>"
  45,21,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿أم حسب الذين اجترحوا السيئات أن نجعلهم كالذين آمنوا وعملوا الصالحات﴾</span></span>: أم: منقطعة بمعنى: بل والهمزة، أي: بل أحسب ...؟ و<span class="hlt"><span class="qpc-hafs">﴿حسب﴾</span></span> فعل ماض، والذين: فاعله، واجترحوا: فعل ماض، والواو: فاعل، وجملة <span class="hlt"><span class="qpc-hafs">﴿اجترحوا﴾</span></span>: صلة الموصول لا محل لها من الإعراب، وأن وما في حيزها في تأويل مصدر سدت مسد مفعولي حسب، وأن: حرف مصدري ونصب، ونجعلهم: فعل مضارع، وفاعله مستتر تقديره: نحن، والهاء مفعول نجعل الأول، وكالذين: الكاف اسم بمعنى مثل مبني على الفتح في محل نصب مفعول ثان، أي: أن نجعلهم مثل الذين آمنوا، و<span class="hlt"><span class="qpc-hafs">﴿الذين﴾</span></span> مضاف إليه، وآمنوا: فعل ماض، والواو: فاعل، وجملة <span class="hlt"><span class="qpc-hafs">﴿آمنوا﴾</span></span>: صلة الموصول لا محل لها من الإعراب، والواو عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿عملوا الصالحات﴾</span></span>: فعل ماض، وفاعل، ومفعول به.</p><p><span class="hlt"><span class="qpc-hafs">﴿سواء محياهم ومماتهم﴾</span></span>: سواء: حال، ومحياهم: فاعل بـ<span class="hlt"><span class="qpc-hafs">﴿سواء﴾</span></span>، والهاء: ضمير مبني في محل جر مضاف إليه. <span class="hlt"><span class="qpc-hafs">﴿ومماتهم﴾</span></span> عطف على <span class="hlt"><span class="qpc-hafs">﴿محياهم﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿ساء ما يحكمون﴾</span></span>: الجملة مستأنفة لا محل لها من الإعراب. و<span class="hlt"><span class="qpc-hafs">﴿ساء﴾</span></span> فعل ماض جامد لإنشاء الذم مبني على الفتح، والفاعل ضمير مستتر وجوبا تقديره: <span class="hlt"><span class="qpc-hafs">﴿هو﴾</span></span> عائد على حسبانهم الباطل. و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span>: نكرة موصوفة في محل نصب تمييز لفاعل <span class="hlt"><span class="qpc-hafs">﴿ساء﴾</span></span>، والمخصوص بالذم محذوف، أي: حكمهم. وجملة <span class="hlt"><span class="qpc-hafs">﴿يحكمون﴾</span></span> في محل نصب نعت لـ<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span>، والتقدير: ساء حكمًا يحكمونه.</p><p>أو <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> اسم موصول بمعنى الذي في محل رفع فاعل لـ<span class="hlt"><span class="qpc-hafs">﴿ساء﴾</span></span>، والمخصوص بالذم محذوف، أي: حكمهم. وجملة <span class="hlt"><span class="qpc-hafs">﴿يحكمون﴾</span></span> صلة الموصول لا محل لها من الإعراب.</p><p>أو <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> مصدرية. وجملة <span class="hlt"><span class="qpc-hafs">﴿يحكمون﴾</span></span> صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> المصدرية لا محل لها من الإعراب. والمصدر المؤول من <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> وما دخلت عليه فاعل <span class="hlt"><span class="qpc-hafs">﴿ساء﴾</span></span>، والتقدير: ساء حكمهم. والمخصوص بالذم محذوف.</p></div>"
  45,22,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وخلق الله السماوات والأرض بالحق﴾</span></span>: الواو استئنافية، و<span class="hlt"><span class="qpc-hafs">﴿خلق الله السماوات﴾</span></span>: فعل، وفاعل، ومفعول به، والأرض: عطف على السماوات، وجملة <span class="hlt"><span class="qpc-hafs">﴿وخلق الله...﴾</span></span> مستأنفة لا محل لها من الإعراب، وبالحق: جار ومجرور متعلقان بمحذوف حال من الفاعل أو المفعول.</p><p><span class="hlt"><span class="qpc-hafs">﴿ولتجزى كل نفس بما كسبت وهم لا يظلمون﴾</span></span>: الواو عاطفة، واللام للتعليل، وتجزى فعل مضارع مبني لما لم يسمَّ فاعله منصوب بأن مقدرة بعد لام التعليل، والمصدر المؤول من <span class="hlt"><span class="qpc-hafs">﴿أن﴾</span></span> والفعل مجرور باللام، والجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿خلق﴾</span></span>، وكل: نائب فاعل مرفوع، ونفس: مضاف إليه، و<span class="hlt"><span class="qpc-hafs">﴿بما﴾</span></span>: الباء: حرف جر، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> اسم موصول في محل جر، والجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تجزى﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿كسبت﴾</span></span>: صلة الموصول لا محل لها من الإعراب، أو <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> مصدرية، وهي وما بعدها في تأويل مصدر مجرور بالباء، والجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تجزى﴾</span></span>، وكسبت: فعل ماض، والفاعل مستتر، والواو للحال، وهم: مبتدأ، ولا نافية، ويظلمون: فعل مضارع، والواو: فاعل، وجملة <span class="hlt"><span class="qpc-hafs">﴿لا يظلمون﴾</span></span>: خبر، والجملة في محل نصب على الحال.</p></div>"