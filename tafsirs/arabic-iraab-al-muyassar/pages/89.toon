quran[9]{c,v,t}:
  4,66,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ولو أنا كتبنا عليهم أن اقتلوا أنفسكم﴾</span></span>: الواو استئنافية، و<span class="hlt"><span class="qpc-hafs">﴿لو﴾</span></span> شرطية، وأن وما في حيزها فاعل لفعل محذوف، أي: لو ثبتت كتابتنا، وأن حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> اسمها، وجملة <span class="hlt"><span class="qpc-hafs">﴿كتبنا﴾</span></span> خبرها، وعليهم جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿كتبنا﴾</span></span>. و<span class="hlt"><span class="qpc-hafs">﴿أن﴾</span></span>: مصدرية. والمصدر المؤول من <span class="hlt"><span class="qpc-hafs">﴿أن اقتلوا﴾</span></span> مفعول <span class="hlt"><span class="qpc-hafs">﴿كتبنا﴾</span></span>. أو <span class="hlt"><span class="qpc-hafs">﴿أن﴾</span></span> تفسيرية والجملة بعدها تفسيرية لا محل لها من الإعراب. واقتلوا: فعل أمر، والواو فاعل. وأنفسكم مفعول به.</p><p><span class="hlt"><span class="qpc-hafs">﴿أو اخرجوا من دياركم﴾</span></span>: عطف على اقتلوا أنفسكم، ومن دياركم جار ومجرور متعلقان باخرجوا.</p><p><span class="hlt"><span class="qpc-hafs">﴿ما فعلوه إلا قليل منهم﴾</span></span>: الجملة لا محل لها من الإعراب، لأنها جواب شرط غير جازم، والضمير في <span class="hlt"><span class="qpc-hafs">﴿فعلوه﴾</span></span> يعود إلى أحد الأمرين، أو للمكتوب عليهم، و<span class="hlt"><span class="qpc-hafs">﴿إلا﴾</span></span> أداة حصر، أو بدل من الواو في <span class="hlt"><span class="qpc-hafs">﴿فعلوه﴾</span></span>، لأنه استثناء من كلام تام غير موجب، ومنهم جار ومجرور متعلقان بمحذوف صفة لقليل. وجملة <span class="hlt"><span class="qpc-hafs">﴿ولو أنا كتبنا...﴾</span></span> مستأنفة لا محل لها من الإعراب.</p><p><span class="hlt"><span class="qpc-hafs">﴿ولو أنهم فعلوا ما يوعظون به﴾</span></span>: عطف على ما تقدم، و<span class="hlt"><span class="qpc-hafs">﴿لو﴾</span></span> شرطية، وأنهم: أن حرف ناسخ، والهاء اسمها، والميم علامة الجمع، وفعلوا: فعل ماض مبني على الضم، وواو الجماعة فاعل، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> اسم موصول مفعول به، وجملة <span class="hlt"><span class="qpc-hafs">﴿يوعظون به﴾</span></span> صلة الموصول لا محل لها من الإعراب، وجملة <span class="hlt"><span class="qpc-hafs">﴿فعلوا﴾</span></span> في محل رفع خبر أن، والمصدر المؤول من أن واسمها وخبرها فاعل لفعل مقدر، أي: ولو ثبت فِعْلُهم ما يوعظون به.</p><p><span class="hlt"><span class="qpc-hafs">﴿لكان خيرا لهم وأشد تثبيتا﴾</span></span>: اللام واقعة في جواب <span class="hlt"><span class="qpc-hafs">﴿لو﴾</span></span>، وكان فعل ماض ناقص ناسخ، واسمها مستتر، وخيرًا خبرها، وأشد عطف على <span class="hlt"><span class="qpc-hafs">﴿خيرًا﴾</span></span>، وتثبيتًا تمييز.</p></div>"
  4,67,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وإذا لآتيناهم من لدنا أجرا عظيما﴾</span></span>: الواو عاطفة، وإذًا حرف جواب وجزاء مهمل، لأنه وقع بعد أحد العاطفين، وهما الواو والفاء، وهو جواب لسؤال مقدَّر، كأنه قيل: وماذا يكون لهم بعد التثبيت؟ فقيل: وإذًا لو ثبتوا لآتيناهم، واللام جواب <span class="hlt"><span class="qpc-hafs">﴿لو﴾</span></span> المقدرة، وآتيناهم فعل وفاعل ومفعول به، و<span class="hlt"><span class="qpc-hafs">﴿من لدنا﴾</span></span> جار ومجرور متعلقان بآتيناهم، وأجرًا مفعول به، وعظيمًا صفة.</p></div>"
  4,68,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ولهديناهم صراطا مستقيما﴾</span></span>: عطف أيضًا، وصراطًا مفعول به ثان، أو منصوب بنزع الخافض، ومستقيمًا صفة.</p></div>"
  4,69,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ومن يطع الله والرسول﴾</span></span>: كلام مستأنف لا محل له من الإعراب، ومن شرطية في محل رفع مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿يطع الله﴾</span></span> فعل الشرط، والرسولَ عطف على لفظ الجلالة.</p><p><span class="hlt"><span class="qpc-hafs">﴿فأولئك مع الذين أنعم الله عليهم من النبيين والصديقين والشهداء والصالحين﴾</span></span>: الفاء رابطة لجواب الشرط، وأولئك مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿مع﴾</span></span> ظرف مكان متعلق بمحذوف خبر، والذين اسم موصول مضاف إليه، والجملة المقترنة بالفاء في محل جزم جواب الشرط، وجملة <span class="hlt"><span class="qpc-hafs">﴿أنعم الله عليهم﴾</span></span> صلة الموصول لا محل لها من الإعراب، ومن النبيين جار ومجرور متعلقان بمحذوف حال، وما بعده عطف على النَّبيِّين.</p><p><span class="hlt"><span class="qpc-hafs">﴿وحسن أولئك رفيقا﴾</span></span>: الواو عاطفة، وحسن فعل ماض تضمن معنى المدح والتعجب، وأولئك اسم إشارة فاعل، ورفيقًا تمييز، أو حال.</p></div>"
  4,70,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ذلك الفضل من الله وكفى بالله عليما﴾</span></span>: اسم الإشارة مبتدأ، والفضل بدل منه، و<span class="hlt"><span class="qpc-hafs">﴿من الله﴾</span></span> جار ومجرور متعلقان بمحذوف خبر، أو الفضل خبر، و<span class="hlt"><span class="qpc-hafs">﴿من الله﴾</span></span> جار ومجرور متعلقان بمحذوف حال، وجملة <span class="hlt"><span class="qpc-hafs">﴿ذلك الفضل من الله﴾</span></span> استئنافية لا محل لها من الإعراب، وكفى فعل ماض، والباء حرف صلة، ولفظ الجلالة فاعل محلًا مجرور لفظًا، وعليمًا تمييز أو حال، وجملة <span class="hlt"><span class="qpc-hafs">﴿وكفى بالله عليما﴾</span></span> مستأنفة لا محل لها من الإعراب.</p></div>"
  4,71,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿يا أيها الذين آمنوا خذوا حذركم فانفروا ثبات أو انفروا جميعا﴾</span></span>: كلام مستأنف لا محل له من الإعراب، ويا حرف نداء، وأي منادى نكرة مقصودة مبني على الضم في محل نصب، وها للتنبيه، والذين صفة لـ<span class="hlt"><span class="qpc-hafs">﴿أي﴾</span></span>، وآمنوا فعل وفاعل، وجملة <span class="hlt"><span class="qpc-hafs">﴿آمنوا﴾</span></span> صلة الذين لا محل لها من الإعراب، وخذوا فعل أمر مبني على حذف النون، لأن مضارعه من الأفعال الخمسة، والواو فاعل، وحذركم مفعول به، والفاء عاطفة، وانفروا عطف على خذوا، أي: بادروهم قبل أن يبادروكم، وثبات حال، وعلامة نصبه الكسرة، لأنه جمع مؤنث سالم، <span class="hlt"><span class="qpc-hafs">﴿أو انفروا﴾</span></span> عطف على <span class="hlt"><span class="qpc-hafs">﴿انفروا﴾</span></span> الأول، وجميعًا حال.</p></div>"
  4,72,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وإن منكم لمن ليبطئن﴾</span></span>: الواو استئنافية، والكلام بعدها مستأنف لا محل له من الإعراب، وإن حرف ناسخ، ومنكم جار ومجرور متعلقان بمحذوف خبر مقدم، و<span class="hlt"><span class="qpc-hafs">﴿لمن﴾</span></span> اللام المزحلقة، وفائدتها التأكيد، و<span class="hlt"><span class="qpc-hafs">﴿مَن﴾</span></span> اسم موصول في محل نصب اسمها المؤخر، و<span class="hlt"><span class="qpc-hafs">﴿ليبطئن﴾</span></span> اللام جواب قسم محذوف، وتقدير الكلام: وإن منكم لمن أقسم ليبطئن، وجملة جواب القسم لا محل لها من الإعراب، وجملة القسم والجواب صلة الموصول لا محل لها من الإعراب، ويبطئن قد يكون لازمًا، وقد يكون متعديًا، والمفعول محذوف، أي: ليبطئنّ غيره.</p><p><span class="hlt"><span class="qpc-hafs">﴿فإن أصابتكم مصيبة قال قد أنعم الله علي﴾</span></span>: الفاء استئنافية، وإن شرطية، وأصابتكم فعل ماض في محل جزم فعل الشرط، ومصيبة فاعل، وجملة <span class="hlt"><span class="qpc-hafs">﴿قال﴾</span></span> في محل جزم جواب الشرط، وجملة <span class="hlt"><span class="qpc-hafs">﴿قد أنعم الله علي﴾</span></span> في محل نصب مقول القول.</p><p><span class="hlt"><span class="qpc-hafs">﴿إذ لم أكن معهم شهيدا﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿إذ﴾</span></span> ظرف لما مضى من الزمن متعلق بأنعم، و<span class="hlt"><span class="qpc-hafs">﴿لم﴾</span></span> حرف نفي وقلب وجزم، وأكن فعل مضارع ناقص، واسمها مستتر تقديره: أنا، ومعهم ظرف مكان متعلق بمحذوف حال، وشهيدًا خبر أكن، وجملة <span class="hlt"><span class="qpc-hafs">﴿فإن أصابتكم مصيبة...﴾</span></span> مستأنفة لا محل لها من الإعراب.</p></div>"
  4,73,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ولئن أصابكم فضل من الله﴾</span></span>: الواو عاطفة على قوله: <span class="hlt"><span class="qpc-hafs">﴿فإن أصابتكم مصيبة﴾</span></span>، واللام موطئة للقسم، وإن شرطية، وأصابكم فعل ماض في محل جزم فعل الشرط، والكاف مفعول به، وفضل فاعل، و<span class="hlt"><span class="qpc-hafs">﴿من الله﴾</span></span> جار ومجرور متعلقان بمحذوف صفة.</p><p><span class="hlt"><span class="qpc-hafs">﴿ليقولن كأن لم تكن بينكم وبينه مودة﴾</span></span>: اللام جواب القسم، ويقولنّ: فعل مضارع مبني على الفتح، لاتصاله بنون التوكيد الثقيلة، والجملة لا محل لها من الإعراب، لأنها جواب القسم لتقدمه، وكأن: مخففة من الثقيلة، واسمها ضمير الشأن، وجملة <span class="hlt"><span class="qpc-hafs">﴿لم تكن...﴾</span></span> خبرها، وجملة <span class="hlt"><span class="qpc-hafs">﴿كأن﴾</span></span> وما في حيزها: اعتراضية بين القول ومقوله لا محل لها من الإعراب، أو حالية من فاعل يقولن. وبينكم ظرف متعلق بمحذوف خبر <span class="hlt"><span class="qpc-hafs">﴿تكن﴾</span></span> المقدم، وبينهم عطف عليه، ومودة اسم <span class="hlt"><span class="qpc-hafs">﴿تكن﴾</span></span> المؤخر.</p><p><span class="hlt"><span class="qpc-hafs">﴿يا ليتني كنت معهم فأفوز فوزا عظيما﴾</span></span>: الجملة مقول القول، و<span class="hlt"><span class="qpc-hafs">﴿يا﴾</span></span> حرف نداء، والمنادى محذوف، أو هي لمجرد التنبيه، و<span class="hlt"><span class="qpc-hafs">﴿ليت﴾</span></span> حرف ناسخ، والنون للوقاية، والياء اسمها، وجملة <span class="hlt"><span class="qpc-hafs">﴿كنت﴾</span></span> خبر ليت، وكان فعل ماض ناقص ناسخ، والتاء اسمها، ومعهم ظرف مكان متعلق بمحذوف خبر <span class="hlt"><span class="qpc-hafs">﴿كان﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿فأفوز﴾</span></span> الفاء هي السببية، وأفوز فعل مضارع منصوب بأن مضمرة بعد الفاء، وأن والفعل في تأويل مصدر معطوف على مصدر مفهوم من الكلام السابق أي: ثمة تمنّ لوجودي ففوز. وفوزًا مفعول مطلق، وعظيمًا صفة.</p></div>"
  4,74,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فليقاتل في سبيل الله الذين يشرون الحياة الدنيا بالآخرة﴾</span></span>: الفاء هي الفصيحة، أي: إذا علمتم هذا كله فليقاتل. واللام لام الأمر، ويقاتل فعل مضارع مجزوم بلام الأمر، و<span class="hlt"><span class="qpc-hafs">﴿في سبيل الله﴾</span></span> جار ومجرور متعلقان بيقاتل، والذين اسم موصول فاعل، وجملة <span class="hlt"><span class="qpc-hafs">﴿يشرون الحياة الدنيا﴾</span></span> صلة الموصول لا محل لها من الإعراب، وبالآخرة جار ومجرور متعلقان بيشرون، والجملة لا محل لها من الإعراب، لأنها جواب شرط غير جازم.</p><p><span class="hlt"><span class="qpc-hafs">﴿ومن يقاتل في سبيل الله﴾</span></span>: الواو استئنافية، ومَن اسم شرط جازم مبتدأ، ويقاتل فعل الشرط، و<span class="hlt"><span class="qpc-hafs">﴿في سبيل الله﴾</span></span> جار ومجرور متعلقان بيقاتل.</p><p><span class="hlt"><span class="qpc-hafs">﴿فيقتل أو يغلب فسوف نؤتيه أجرا عظيما﴾</span></span>: الفاء عاطفة، ويقتل بالبناء لما لم يسمَّ فاعله معطوف على يقاتل، ونائب الفاعل مستتر تقديره: هو، أو يغلب: أو حرف عطف، ويغلب بالبناء للفاعل معطوف أيضًا، والفاعل مستتر تقديره: هو، فسوف: الفاء رابطة لجواب الشرط، ونؤتيه فعل مضارع، وفاعله مستتر، والهاء مفعول به أول، وأجرًا مفعول به ثان، وعظيمًا صفة، والجملة في محل جزم جواب الشرط، وفعل الشرط وجوابه خبر <span class="hlt"><span class="qpc-hafs">﴿من﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿ومن يقاتل...﴾</span></span> مستأنفة لا محل لها من الإعراب.</p></div>"