quran[13]{c,v,t}:
  27,64,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿أمن يبدأ الخلق ثم يعيده ومن يرزقكم من السماء والأرض﴾</span></span>: أم: منقطعة بمعنى بل، ومَن مبتدأ، وجملة يبدأ الخلق صلة الموصول لا محل لها من الإعراب. وخبر من محذوف، و<span class="hlt"><span class="qpc-hafs">﴿ثم يعيده﴾</span></span> عطف على جملة الصلة، والضمير في محل نصب مفعول به، وجملة و<span class="hlt"><span class="qpc-hafs">﴿من يرزقكم﴾</span></span> عطف.</p><p><span class="hlt"><span class="qpc-hafs">﴿أإله مع الله قل هاتوا برهانكم إن كنتم صادقين﴾</span></span>: الهمزة للاستفهام، و<span class="hlt"><span class="qpc-hafs">﴿إله﴾</span></span> مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿مع الله﴾</span></span> ظرف متعلق بمحذوف خبر، وإن شرطية، وجوابها محذوف، تقديره: <span class="hlt"><span class="qpc-hafs">﴿فهاتوا برهانكم﴾</span></span>.</p></div>"
  27,65,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قل لا يعلم من في السماوات والأرض الغيب إلا الله وما يشعرون أيان يبعثون﴾</span></span>: الجملة مستأنفة لا محل لها من الإعراب، ولا نافية، ويعلم فعل مضارع، ومَن اسم موصول فاعل يعلم، و<span class="hlt"><span class="qpc-hafs">﴿في السماوات والأرض﴾</span></span> جار ومجرور متعلقان بمحذوف صلة <span class="hlt"><span class="qpc-hafs">﴿مَن﴾</span></span> لا محل لها من الإعراب. والغيب مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿إلا﴾</span></span> أداة استثناء بمعنى لكن إشارة إلى أن الاستثناء منقطع، ولفظ الجلالة بدل من الاسم الموصول مرفوع بالضمة أي: لا يعلم أحد الغيب إلا الله، والواو عاطفة، وما نافية، ويشعرون فعل مضارع وفاعل، وأيان اسم استفهام بمعنى في محل نصب على الظرفية متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿يبعثون﴾</span></span>، ومعلقة لـ<span class="hlt"><span class="qpc-hafs">﴿يشعرون﴾</span></span> عن نصب المفعول به، فالجملة المؤلفة من <span class="hlt"><span class="qpc-hafs">﴿أيان﴾</span></span> وما بعدها في محل نصب مفعول به.</p></div>"
  27,66,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿بل ادارك علمهم في الآخرة بل هم في شك منها بل هم منها عمون﴾</span></span>: بل حرف إضراب، وقيل: هي بمعنى هل، و<span class="hlt"><span class="qpc-hafs">﴿ادارك﴾</span></span> فعل ماض، وعلمهم فاعل، وفي الآخرة جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿ادارك﴾</span></span>، أو بـ<span class="hlt"><span class="qpc-hafs">﴿علمهم﴾</span></span>، وبل حرف إضراب، و<span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> مبتدأ، ومنها جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿عمون﴾</span></span>، وعمون خبر.</p></div>"
  27,67,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وقال الذين كفروا أئذا كنا ترابا وآباؤنا أئنا لمخرجون﴾</span></span>: الواو للعطف، و<span class="hlt"><span class="qpc-hafs">﴿قال الذين﴾</span></span> فعل وفاعل، وجملة كفروا صلة الذين لا محل لها من الإعراب. والهمزة للاستفهام، وإذا ظرف مستقبل، متضمن معنى الشرط، وجملة كنا في محل جر بإضافة الظرف إليها، وكان فعل ماض ناقص، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> اسمها، وترابًا خبرها، وآباؤنا عطف على اسم كان، والهمزة للاستفهام، وإن حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> اسمها، واللام المزحلقة، ومخرجون خبر إن، والجملة تأكيد للجملة الأولى.</p></div>"
  27,68,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿لقد وعدنا هذا نحن وآباؤنا من قبل إن هذا إلا أساطير الأولين﴾</span></span>: اللام جواب للقسم المحذوف، وقد حرف تحقيق، ووعدنا فعل ماض مبني لما لم يسمَّ فاعله، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> نائب فاعل، وهذا مفعول به ثان لـ<span class="hlt"><span class="qpc-hafs">﴿وعدنا﴾</span></span>، ونحن تأكيد لـ<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span>، وآباؤنا عطف على الضمير البارز في وعدنا، ومن قبل جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿وعدنا﴾</span></span>، والظرف مبني على الضم لانقطاعه عن الإضافة لفظًا لا معنى، وإن نافية، وهذا مبتدأ، وإلا أداة حصر، وأساطير خبر هذا، والأولين مضاف إليه.</p></div>"
  27,69,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قل سيروا في الأرض فانظروا كيف كان عاقبة المجرمين﴾</span></span>: سيروا فعل أمر، وفي الأرض جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿سيروا﴾</span></span>، فانظروا عطف على سيروا، وكيف اسم استفهام في محل نصب خبر كان المقدم، وعاقبة المجرمين اسم كان المؤخر.</p></div>"
  27,70,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ولا تحزن عليهم ولا تكن في ضيق مما يمكرون﴾</span></span>: الواو عاطفة على قل، ولا ناهية، وتحزن فعل مضارع مجزوم بلا، وفاعله مستتر، تقديره: أنت، و<span class="hlt"><span class="qpc-hafs">﴿عليهم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تحزن﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿ولا تكن﴾</span></span> عطف على لا تحزن، واسم تكن مستتر تقديره: أنت، و<span class="hlt"><span class="qpc-hafs">﴿في ضيق﴾</span></span> خبر، ومما جار ومجرور متعلقان بمحذوف صفة لـ<span class="hlt"><span class="qpc-hafs">﴿ضيق﴾</span></span>، وجملة يمكرون صلة الموصول لا محل لها من الإعراب.</p></div>"
  27,71,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ويقولون متى هذا الوعد إن كنتم صادقين﴾</span></span>: الواو استئنافية، والجملة بعدها مستأنفة لا محل لها من الإعراب، ويقولون فعل مضارع وفاعل، ومتى اسم استفهام في محل نصب على الظرفية الزمانية، وهو متعلق بمحذوف خبر مقدم، وهذا مبتدأ مؤخر، والوعد بدل، وإن شرطية، وكنتم فعل الشرط، وكان فعل ماض ناقص، والتاء اسمها، وصادقين خبرها، وجواب الشرط محذوف دل عليه ما قبله.</p></div>"
  27,72,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قل عسى أن يكون ردف لكم بعض الذي تستعجلون﴾</span></span>: عسى فعل ماض جامد من أفعال الرجاء، واسمها مستتر تقديره: هو، والمصدر المؤول من <span class="hlt"><span class="qpc-hafs">﴿أن يكون﴾</span></span> خبرها، واسم يكون مستتر تقديره: هو، و<span class="hlt"><span class="qpc-hafs">﴿ردف﴾</span></span> فعل ماض، و<span class="hlt"><span class="qpc-hafs">﴿بعض﴾</span></span> فاعل، و<span class="hlt"><span class="qpc-hafs">﴿الذي﴾</span></span> مضاف إليه، وجملة تستعجلون صلة الموصول لا محل لها من الإعراب. وجملة <span class="hlt"><span class="qpc-hafs">﴿ردف﴾</span></span> خبر يكون.</p></div>"
  27,73,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وإن ربك لذو فضل على الناس﴾</span></span>: الواو استئنافية، وإن حرف ناسخ، وربك اسمها، واللام المزحلقة، و<span class="hlt"><span class="qpc-hafs">﴿ذو فضل﴾</span></span> خبرها، و<span class="hlt"><span class="qpc-hafs">﴿على الناس﴾</span></span> جار ومجرور متعلقان بفضل، أو صفة له، وجملة <span class="hlt"><span class="qpc-hafs">﴿وإن ربك...﴾</span></span> مستأنفة لا محل لها من الإعراب.</p><p><span class="hlt"><span class="qpc-hafs">﴿ولكن أكثرهم لا يشكرون﴾</span></span>: الواو حالية، ولكن حرف استدراك ونصب، وأكثرهم اسمها، وجملة لا يشكرون خبرها.</p></div>"
  27,74,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وإن ربك ليعلم ما تكن صدورهم وما يعلنون﴾</span></span>: الواو عاطفة، وإن حرف ناسخ، وربك اسمها، واللام المزحلقة، وجملة يعلم خبر إن، وما مفعول به، وجملة <span class="hlt"><span class="qpc-hafs">﴿تكن صدروهم﴾</span></span> صلة الموصول لا محل لها من الإعراب. والعائد محذوف، <span class="hlt"><span class="qpc-hafs">﴿وما يعلنون﴾</span></span> عطف على <span class="hlt"><span class="qpc-hafs">﴿ما تكن﴾</span></span>.</p></div>"
  27,75,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وما من غائبة في السماء والأرض إلا في كتاب مبين﴾</span></span>: الواو عاطفة، وما نافية، ومن حرف صلة، وغائبة مجرور لفظًا، مرفوع محلًّا على أنه مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿في السماء والأرض﴾</span></span> جار ومجرور متعلقان بمحذوف صفة لغائبة، وإلا أداة حصر، و<span class="hlt"><span class="qpc-hafs">﴿في كتاب﴾</span></span> جار ومجرور متعلقان بمحذوف خبر غائبة، ومبين صفة.</p></div>"
  27,76,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إن هذا القرآن يقص على بني إسرائيل أكثر الذي هم فيه يختلفون﴾</span></span>: الجملة مستأنفة لا محل لها من الإعراب، وإن حرف ناسخ، وهذا اسمها، والقرآن بدل من اسم الإشارة، وجملة <span class="hlt"><span class="qpc-hafs">﴿يقص﴾</span></span> خبر إن، و<span class="hlt"><span class="qpc-hafs">﴿على بني إسرائيل﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يقص﴾</span></span>، وأكثر مفعول به، والذي: مضاف إليه. وهم: ضمير مبني في محل رفع مبتدأ. وفيه: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يختلفون﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿يختلفون﴾</span></span> في محل رفع خبر للمبتدأ. وجملة <span class="hlt"><span class="qpc-hafs">﴿هم فيه يختلفون﴾</span></span> صلة <span class="hlt"><span class="qpc-hafs">﴿الذي﴾</span></span> لا محل لها من الإعراب.</p></div>"