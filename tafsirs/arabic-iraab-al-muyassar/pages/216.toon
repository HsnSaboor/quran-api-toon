quran[9]{c,v,t}:
  10,62,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ألا إن أولياء الله لا خوف عليهم﴾</span></span>: ألا حرف تنبيه، و<span class="hlt"><span class="qpc-hafs">﴿إن أولياء الله لا خوف عليهم﴾</span></span>: إن حرف ناسخ، وأولياء اسمها، ولا نافية، خوف مبتدأ وساغ الابتداء به وهو نكرة لنفيه، و<span class="hlt"><span class="qpc-hafs">﴿عليهم﴾</span></span> جار ومجرور متعلقان بمحذوف خبر، وجملة <span class="hlt"><span class="qpc-hafs">﴿لا خوف عليهم﴾</span></span> في محل رفع خبر إن.</p><p><span class="hlt"><span class="qpc-hafs">﴿ولا هم يحزنون﴾</span></span>: الواو حرف عطف، ولا نافية، وهم مبتدأ، ويحزنون: فعل مضارع مرفوع بثبوت النون وواو الجماعة فاعل وجملة <span class="hlt"><span class="qpc-hafs">﴿يحزنون﴾</span></span> في محل رفع خبر المبتدأ <span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span>.</p></div>"
  10,63,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿الذين آمنوا وكانوا يتقون﴾</span></span>: الذين منصوب على أنه صفة <span class="hlt"><span class="qpc-hafs">﴿أولياء الله﴾</span></span>، أو  خبر لمبتدأ محذوف، أي: هم الذين آمنوا، أو مبتدأ، والخبر جملة <span class="hlt"><span class="qpc-hafs">﴿لهم البشرى﴾</span></span> الآتية، وجملة آمنوا صلة الذين لا محل لها من الإعراب، وكانوا يتقون عطف على الصلة، وجملة يتقون خبر كان.</p></div>"
  10,64,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿لهم البشرى في الحياة الدنيا﴾</span></span>: لهم خبر مقدم، والبشرى مبتدأ مؤخر، وفي الحياة جار ومجرور متعلقان بمحذوف حال من البشرى، والعامل في الحال الاستقرار في <span class="hlt"><span class="qpc-hafs">﴿لهم﴾</span></span>، والدنيا صفة لـ<span class="hlt"><span class="qpc-hafs">﴿الحياة﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿لهم البشرى﴾</span></span> مستأنفة لا محل لها من الإعراب، أو في محل رفع خبر إذا جعلت <span class="hlt"><span class="qpc-hafs">﴿الذين﴾</span></span> في الآية السابقة مبتدأ.</p><p><span class="hlt"><span class="qpc-hafs">﴿وفي الآخرة﴾</span></span>: الواو عاطفة، وفي الآخرة عطف على <span class="hlt"><span class="qpc-hafs">﴿في الحياة الدنيا﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿لا تبديل لكلمات الله﴾</span></span>: لا نافية للجنس، وتبديل اسمها، و<span class="hlt"><span class="qpc-hafs">﴿لكلمات﴾</span></span>: جار ومجرور متعلقان بمحذوف خبر <span class="hlt"><span class="qpc-hafs">﴿لا﴾</span></span>. وجملة <span class="hlt"><span class="qpc-hafs">﴿لا تبديل...﴾</span></span> استئنافية، لا محل لها من الإعراب.</p><p><span class="hlt"><span class="qpc-hafs">﴿ذلك هو الفوز العظيم﴾</span></span>: ذلك مبتدأ، وهو مبتدأ ثان، الفوز خبر <span class="hlt"><span class="qpc-hafs">﴿هو﴾</span></span>، والجملة خبر ذلك، والعظيم صفة الفوز. وجملة <span class="hlt"><span class="qpc-hafs">﴿ذلك هو...﴾</span></span> استئنافية، لا محل لها من الإعراب.</p></div>"
  10,65,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ولا يحزنك قولهم إن العزة لله جميعا هو السميع العليم﴾</span></span>: الواو حرف عطف، ولا ناهية، ويحزنك فعل مضارع مجزوم بلا، والكاف مفعول به، وقولهم فاعل، وإن حرف ناسخ، والعزة اسمها، و<span class="hlt"><span class="qpc-hafs">﴿لله﴾</span></span> خبر إن، وجميعًا حال من العزة، أو توكيد، و<span class="hlt"><span class="qpc-hafs">﴿هو﴾</span></span> مبتدأ، والسميع خبره الأول، والعليم خبره الثاني.</p></div>"
  10,66,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ألا إن لله من في السماوات ومن في الأرض﴾</span></span>: ألا حرف تنبيه، وإن حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿لله﴾</span></span> خبرها المقدم، ومَن اسمها المؤخر، وفي السماوات صلة مَن  لا محل لها من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿من في الأرض﴾</span></span> عطف على <span class="hlt"><span class="qpc-hafs">﴿من في السماوات﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿وما يتبع الذين يدعون من دون الله شركاء﴾</span></span>: ما نافية، و<span class="hlt"><span class="qpc-hafs">﴿يتبع الذين﴾</span></span> فعل مضارع وفاعل، وجملة يدعون صلة الذين لا محل لها من الإعراب، ومن دون الله حال من شركاء لتقدمه عليه، وشركاء مفعول به لـ<span class="hlt"><span class="qpc-hafs">﴿يتبع﴾</span></span>، ومفعول يدعون محذوف لفهم المعنى، والتقدير: وما يتبع الذين يدعون من دون الله آلهة شركاء، أو <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> استفهامية منصوبة بما بعدها، أي: ما يتبع؟ أو <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> موصولة معطوفة على من، كأنه يقول: ولله ما يتبعه الذين يدعون من دون الله شركاء، أي: وله شركاؤهم، أو <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> الموصولة هذه في محل رفع بالابتداء، والخبر محذوف، تقديره: والذي يتبعه المشركون باطل.</p><p><span class="hlt"><span class="qpc-hafs">﴿إن يتبعون إلا الظن﴾</span></span>: إن نافية، ويتبعون فعل وفاعل، وإلا أداة حصر، والظن مفعول به.</p><p><span class="hlt"><span class="qpc-hafs">﴿وإن هم إلا يخرصون﴾</span></span>: إن نافية أيضًا، و<span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> مبتدأ، وإلا أداة حصر، وجملة يخرصون خبر <span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span>.</p></div>"
  10,67,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿هو الذي جعل لكم الليل لتسكنوا فيه والنهار مبصرا﴾</span></span>: هو مبتدأ، والذي خبر، وجملة جعل صلة الموصول لا محل لها من الإعراب، <span class="hlt"><span class="qpc-hafs">﴿لكم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿جعل﴾</span></span>، والليل مفعول به، <span class="hlt"><span class="qpc-hafs">﴿لتسكنوا﴾</span></span> اللام للتعليل، وتسكنوا منصوب بأن مضمرة، والمصدر المؤول من أن والفعل مجرور باللام، والجار والمجرور إما متعلقان بمحذوف مفعول لأجله، أو مفعول به ثان، و<span class="hlt"><span class="qpc-hafs">﴿فيه﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تسكنوا﴾</span></span>، والنهار عطف على الليل، ومبصرًا حال، أو مفعول به ثان إذا كانت <span class="hlt"><span class="qpc-hafs">﴿جعل﴾</span></span> بمعنى التصيير فتتعدى لمفعولين.</p><p><span class="hlt"><span class="qpc-hafs">﴿إن في ذلك لآيات لقوم يسمعون﴾</span></span>: إن حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿في ذلك﴾</span></span> جار ومجرور متعلقان بمحذوف خبر مقدم لـ<span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span>، واللام المزحلقة، وآيات اسم إن المؤخر، و<span class="hlt"><span class="qpc-hafs">﴿لقوم﴾</span></span> جار ومجرور متعلقان بمحذوف صفة لآيات، وجملة يسمعون صفة لـ<span class="hlt"><span class="qpc-hafs">﴿قوم﴾</span></span>.</p></div>"
  10,68,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قالوا اتخذ الله ولدا سبحانه﴾</span></span>: قالوا فعل وفاعل، واتخذ الله ولدًا فعل وفاعل ومفعول به، والجملة مقول القول، وسبحانه: نائب مفعول مطلق منصوب بفعل محذوف، والهاء مضاف إليه.</p><p><span class="hlt"><span class="qpc-hafs">﴿هو الغني له ما في السماوات وما في الأرض﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿هو﴾</span></span> مبتدأ، والغني خبره، وله خبر مقدم، وما مبتدأ مؤخر، وفي السماوات صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> لا محل لها من الإعراب، وما في الأرض عطف على ما في السماوات.</p><p><span class="hlt"><span class="qpc-hafs">﴿إن عندكم من سلطان بهذا﴾</span></span>: إن نافية، وعندكم ظرف متعلق بمحذوف خبر مقدم، ومن حرف صلة، وسلطان مبتدأ مؤخر مرفوع محلاًّ مجرور لفظًا، و<span class="hlt"><span class="qpc-hafs">﴿بهذا﴾</span></span> صفة لـ<span class="hlt"><span class="qpc-hafs">﴿سلطان﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿أتقولون على الله ما لا تعلمون﴾</span></span>: الهمزة للاستفهام الإنكاري، وتقولون فعل مضارع وفاعل، وعلى الله جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تقولون﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> مفعول به، وجملة لا تعلمون صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> لا محل لها من الإعراب.</p></div>"
  10,69,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قل إن الذين يفترون على الله الكذب لا يفلحون﴾</span></span>: قل فعل أمر، وفاعله تقديره: أنت، <span class="hlt"><span class="qpc-hafs">﴿إن الذين﴾</span></span>: إن حرف ناسخ، والذين اسمها، وجملة يفترون صلة الذين لا محل لها من الإعراب، وعلى الله جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يفترون﴾</span></span>، والكذب مفعول به، وجملة لا يفلحون خبر إن.</p></div>"
  10,70,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿متاع في الدنيا ثم إلينا مرجعهم ثم نذيقهم العذاب الشديد بما كانوا يكفرون﴾</span></span>: متاع خبر لمبتدأ محذوف، أي: ذاك، أو: هو، <span class="hlt"><span class="qpc-hafs">﴿في الدنيا﴾</span></span> صفة، أو <span class="hlt"><span class="qpc-hafs">﴿متاع﴾</span></span> مبتدأ، وخبره محذوف، والتقدير: لهم متاع، وثم حرف عطف وتراخ، وإلينا خبر مقدم، ومرجعهم مبتدأ مؤخر، ثم حرف عطف، ونذيقهم فعل وفاعل مستتر ومفعول به أول، والعذاب مفعول به ثان، والشديد صفة، و<span class="hlt"><span class="qpc-hafs">﴿بما﴾</span></span> الباء حرف جر للسببية، وما مصدرية، أي: بسبب كونهم كافرين، والجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿نذيقهم﴾</span></span>.</p></div>"