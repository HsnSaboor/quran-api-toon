quran[8]{c,v,t}:
  28,6,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ونمكن لهم في الأرض ونري فرعون وهامان وجنودهما منهم ما كانوا يحذرون﴾</span></span>: الواو عاطفة، ونمكن: عطف على نجعل، وفاعله مستتر، ولهم: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿نمكن﴾</span></span>، وفي الأرض: جار ومجرور متعلقان بمحذوف حال، ونري: عطف أيضًا، وفرعون: مفعول به، وهامان: عطف على فرعون، وجنودهما: عطف على فرعون وهامان، ومنهم: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿نري﴾</span></span>، وما: مفعول به ثان لنري، وجملة كانوا: صلة الموصول لا محل لها من الإعراب. وكان فعل ماض ناقص، وواو الجماعة اسمها، وجملة يحذرون: خبر كان.</p></div>"
  28,7,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وأوحينا إلى أم موسى أن أرضعيه﴾</span></span>: الواو عاطفة، وجملة <span class="hlt"><span class="qpc-hafs">﴿أوحينا﴾</span></span>: عطف على قوله: <span class="hlt"><span class="qpc-hafs">﴿نريد...﴾</span></span>، أو الواو استئنافية، والجملة بعدها مستأنفة لا محل لها من الإعراب. وأوحينا: فعل وفاعل، وإلى أم موسى: الجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أوحينا﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿أن﴾</span></span>: تفسيرية، لأن الوحي فيه معنى القول دون حروفه، والجملة بعدها تفسيرية لا محل لها من الإعراب. أو <span class="hlt"><span class="qpc-hafs">﴿أن﴾</span></span> مصدرية وهي مع ما دخلت عليه في تأويل مصدر منصوب بنزع الخافض، والجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أوحينا﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿أرضعيه﴾</span></span> صلة <span class="hlt"><span class="qpc-hafs">﴿أن﴾</span></span> المصدرية لا محل لها من الإعراب. وأرضعيه: فعل أمر وفاعل ومفعول به.</p><p><span class="hlt"><span class="qpc-hafs">﴿فإذا خفت عليه فألقيه في اليم﴾</span></span>: الفاء رابطة، وخفت: فعل وفاعل، وعليه: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿خفت﴾</span></span>، فألقيه: الفاء رابطة، وألقيه فعل أمر مبني على حذف النون، والياء فاعل، والهاء مفعول به، وفي اليم: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿ألقيه﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿ولا تخافي ولا تحزني إنا رادوه إليك وجاعلوه من المرسلين﴾</span></span>: الواو عاطفة، ولا: ناهية، وتخافي: فعل مضارع مجزوم بلا، ولا تحزني: عطف على لا تخافي، وجملة <span class="hlt"><span class="qpc-hafs">﴿إنا رادوه﴾</span></span>: تعليل للأمر، والنهي، وإن حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> اسمها، ورادوه خبرها، وإليك: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿رادوه﴾</span></span>، وجاعلوه: عطف على رادوه، وقد أضيف اسم الفاعل إلى مفعوله الأول، ومن المرسلين: جار ومجرور متعلقان بمحذوف مفعول ثان.</p></div>"
  28,8,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فالتقطه آل فرعون ليكون لهم عدوا وحزنا﴾</span></span>: الفاء الفصيحة، والتقطه: فعل ماض، ومفعول به مقدم، وآل: فاعل مؤخر، وفرعون: مضاف إليه، وليكون: اللام للعاقبة، وقيل: للتعليل، ويكون: فعل مضارع منصوب بأن مضمرة بعد اللام، والمصدر المؤول من أن والفعل مجرور باللام، والجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿التقطه﴾</span></span>، واسم يكون مستتر تقديره: هو، ولهم: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يكون﴾</span></span>، وعدوًّا: خبر يكون، وحزنًا: عطف على <span class="hlt"><span class="qpc-hafs">﴿عدوًّا﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿إن فرعون وهامان وجنودهما كانوا خاطئين﴾</span></span>: إن حرف ناسخ، وفرعون اسمها، <span class="hlt"><span class="qpc-hafs">﴿وهامان وجنودهما﴾</span></span>: عطف على فرعون، وجملة كانوا: خبر إن، وكان فعل ماض ناقص، وواو الجماعة اسمها، وخاطئين: خبرها.</p></div>"
  28,9,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وقالت امرأت فرعون قرت عين لي ولك﴾</span></span>: الواو عاطفة، وقالت: عطف على <span class="hlt"><span class="qpc-hafs">﴿فالتقطه آل فرعون﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿امرأة فرعون﴾</span></span>: فاعل، ومضاف إليه، وقرة عين: خبر لمبتدأ محذوف، أي: هو قرة عين، ولي: جار ومجرور متعلقان بمحذوف صفتان لقرة، ولك: عطف على <span class="hlt"><span class="qpc-hafs">﴿لي﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿لا تقتلوه عسى أن ينفعنا أو نتخذه ولدا وهم لا يشعرون﴾</span></span>: لا ناهية، وتقتلوه: فعل مضارع مجزوم بلا، والواو فاعل، والهاء مفعول به، وعسى: فعل ماض من أفعال الرجاء، واسمها مستتر تقديره: هو، والمصدر المؤول من <span class="hlt"><span class="qpc-hafs">﴿أن ينفعنا﴾</span></span> خبر عسى منصوب، أو نتخذه: عطف على ينفعنا، والهاء مفعول به أول، وولدًا: مفعول به ثان، وهم: الواو حالية، و<span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> مبتدأ، وجملة لا يشعرون: خبر، والجملة حال من <span class="hlt"><span class="qpc-hafs">﴿آل فرعون﴾</span></span>.</p></div>"
  28,10,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وأصبح فؤاد أم موسى فارغا﴾</span></span>: الواو استئنافية، وأصبح: فعل ماض ناقص، وفؤاد: اسمها، وأم موسى: مضاف إليه، وفارغًا: خبرها، وجملة <span class="hlt"><span class="qpc-hafs">﴿وأصبح فؤاد...﴾</span></span> مستأنفة لا محل لها من الإعراب.</p><p><span class="hlt"><span class="qpc-hafs">﴿إن كادت لتبدي به لولا أن ربطنا على قلبها لتكون من المؤمنين﴾</span></span>: إن مخففة من الثقيلة مهملة، وكادت: فعل ماض من أفعال المقاربة، واسمها مستتر، واللام الفارقة، وجملة تبدي: خبر كاد، وبه: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تبدي﴾</span></span>، ولولا: حرف امتناع لوجود، وأن: مصدرية، وهي مع مدخولها في تأويل مصدر مبتدأ محذوف الخبر، أي: لولا ربطنا على قلبها حاصل، وعلى قلبها: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿ربطنا﴾</span></span>، وجواب لولا محذوف، أي: لأبدت به، ولتكون: اللام للتعليل، وتكون فعل مضارع ناقص منصوب بأن مضمرة بعد اللام، والمصدر المؤول من أن والفعل مجرور باللام، والجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿ربطنا﴾</span></span> أيضًا، ومن المؤمنين: جار ومجرور متعلقان بمحذوف خبر تكون.</p></div>"
  28,11,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وقالت لأخته قصيه فبصرت به عن جنب وهم لا يشعرون﴾</span></span>: الواو عاطفة، وقالت: فعل ماض، وفاعل مستتر تقديره: هي، أي: أم موسى، ولأخته: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿قالت﴾</span></span>، وقصيه: فعل أمر مبني على حذف النون، والياء فاعل، والهاء مفعول به، فبصرت: الفاء عاطفة على محذوف، وبه: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿بصرت﴾</span></span>، وعن جنب: جار ومجرور متعلقان بمحذوف حال من فاعل بصرت، أي: بصرت به مستخفية كائنة عن جنب، أو من الضمير في به، أي: بعيدًا، والواو حالية، و<span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> مبتدأ، وجملة لا يشعرون: خبر.</p></div>"
  28,12,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وحرمنا عليه المراضع من قبل فقالت هل أدلكم على أهل بيت يكفلونه لكم وهم له ناصحون﴾</span></span>: الواو استئنافية، وحرمنا: فعل وفاعل، وعليه: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿حرمنا﴾</span></span>، والمراضع: مفعول به، وجملة <span class="hlt"><span class="qpc-hafs">﴿وحرمنا عليه المراضع﴾</span></span> مستأنفة لا محل لها من الإعراب، ومن قبل: جار ومجرور متعلقان بمحذوف حال، أو متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿حرمنا﴾</span></span>، فقالت: الفاء الفصيحة، وهل: حرف استفهام، وأدلكم: فعل مضارع، والفاعل مستتر تقديره: أنا، والكاف مفعول به، وعلى أهل بيت: الجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أدلكم﴾</span></span>، وجملة يكفلونه: صفة لـ<span class="hlt"><span class="qpc-hafs">﴿أهل بيت﴾</span></span>، ولكم: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يكفلونه﴾</span></span>، والواو حالية، و<span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿له﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿ناصحون﴾</span></span>، وناصحون: خبر.</p></div>"
  28,13,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فرددناه إلى أمه كي تقر عينها ولا تحزن﴾</span></span>: الفاء عاطفة، ورددناه فعل وفاعل ومفعول به، وإلى أمه: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿رددناه﴾</span></span>، وكي: حرف مصدري ونصب، وتقر: فعل مضارع منصوب بـ<span class="hlt"><span class="qpc-hafs">﴿كي﴾</span></span>، والمصدر المؤول من كي والفعل في محل جر باللام المحذوفة، والجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿رددناه﴾</span></span>، ولا تحزن: عطف على تقر.</p><p><span class="hlt"><span class="qpc-hafs">﴿ولتعلم أن وعد الله حق ولكن أكثرهم لا يعلمون﴾</span></span>: الواو عاطفة، واللام للتعليل، وتعلم: فعل مضارع منصوب بأن مضمرة بعد اللام، وأن وما بعدها سدت مسد مفعولي تعلم، وأن حرف ناسخ، ووعد اسمها، وحق: خبرها، والواو حالية، ولكن أكثرهم: لكن حرف ناسخ، وأكثر اسمها، و<span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> مضاف إليه، وجملة لا يعلمون: خبرها.</p></div>"