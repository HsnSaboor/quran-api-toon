quran[10]{c,v,t}:
  20,126,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قال كذلك أتتك آياتنا فنسيتها وكذلك اليوم تنسى﴾</span></span>: قال فعل ماض، و<span class="hlt"><span class="qpc-hafs">﴿كذلك﴾</span></span> الكاف الكاف اسم بمعنى مثل مبني على الفتح في محل نصب صفة لمصدر محذوف، أي: أتتك إتيانًا مثل ذلك الإتيان، أو في محل رفع خبر لمبتدأ محذوف، أي: الأمر كذلك، و<span class="hlt"><span class="qpc-hafs">﴿ذلك﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿ذا﴾</span></span> اسم إشارة في محل جر مضاف إليه، واللام للبعد، والكاف حرف خطاب، و<span class="hlt"><span class="qpc-hafs">﴿أتتك آياتنا﴾</span></span> فعل ومفعول به مقدم وفاعل مؤخر، فنسيتها: الفاء عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿نسيتها﴾</span></span> فعل وفاعل ومفعول به، و<span class="hlt"><span class="qpc-hafs">﴿كذلك﴾</span></span> الكاف اسم بمعنى مثل مبني على الفتح في محل نصب صفة لمصدر محذوف، و<span class="hlt"><span class="qpc-hafs">﴿ذلك﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿ذا﴾</span></span> اسم إشارة في محل جر مضاف إليه، واللام للبعد، والكاف حرف خطاب، واليوم ظرف متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿تنسى﴾</span></span>.</p></div>"
  20,127,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وكذلك نجزي من أسرف ولم يؤمن بآيات ربه ولعذاب الآخرة أشد وأبقى﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿كذلك﴾</span></span> الكاف: اسم بمعنى مثل مبني على الفتح في محل نصب صفة لمصدر محذوف، والتقدير: جزاءً مثلَ ذلك نجزي، وذلك: <span class="hlt"><span class="qpc-hafs">﴿ذا﴾</span></span> اسم إشارة في محل جر مضاف إليه، واللام للبعد، والكاف حرف خطاب، و<span class="hlt"><span class="qpc-hafs">﴿نجزي﴾</span></span> فعل مضارع والفاعل مستتر تقديره نحن، و<span class="hlt"><span class="qpc-hafs">﴿من﴾</span></span> اسم موصول مفعول به، وجملة <span class="hlt"><span class="qpc-hafs">﴿أسرف﴾</span></span> صلة <span class="hlt"><span class="qpc-hafs">﴿من﴾</span></span> لا محل لها من الإعراب، <span class="hlt"><span class="qpc-hafs">﴿ولم يؤمن﴾</span></span> عطف على أسرف، فهو داخل في حيز الصلة، و<span class="hlt"><span class="qpc-hafs">﴿بآيات﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يؤمن﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿ربه﴾</span></span> مضاف إليه، <span class="hlt"><span class="qpc-hafs">﴿ولعذاب﴾</span></span>: الواو حالية، أو عاطفة، واللام للابتداء، وعذاب مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿الآخرة﴾</span></span> مضاف إليه، و<span class="hlt"><span class="qpc-hafs">﴿أشد﴾</span></span> خبر، <span class="hlt"><span class="qpc-hafs">﴿وأبقى﴾</span></span> عطف على أشد.</p></div>"
  20,128,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿أفلم يهد لهم كم أهلكنا قبلهم من القرون يمشون في مساكنهم﴾</span></span>: الهمزة للاستفهام، وهي داخلة، على محذوف عطف عليه بالفاء، والتقدير: أغفلوا فلم يتبين لهم، وفاعل يهد المصدر المفهوم من أهلكنا، أي: أفلم يتبين لهم إهلاكنا، أو ضمير عائد على الله تعالى، أي: يبين الله، و<span class="hlt"><span class="qpc-hafs">﴿لهم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يهد﴾</span></span>، وكم خبرية مفعول مقدم لأهلكنا، ومن القرون جار ومجرور متعلقان بمحذوف نعت لتمييز كم الخبرية، أي: كم قرن من القرون، وجملة يمشون في مساكنهم حال من مفعول أهلكنا، أو من الضمير في لهم، وفي مساكنهم جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يمشون﴾</span></span>، والضمير يعود على المهلَكين.</p><p><span class="hlt"><span class="qpc-hafs">﴿إن في ذلك لآيات لأولي النهى﴾</span></span>: إن وخبرها المقدم، واللام المزحلقة، وآيات اسمها المؤخر، ولأولي جار ومجرور متعلقان بمحذوف صفة لآيات، والنهى مضاف إليه.</p></div>"
  20,129,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ولولا كلمة سبقت من ربك لكان لزاما وأجل مسمى﴾</span></span>: الواو استئنافية، والجملة بعدها مستأنفة لا محل لها من الإعراب، ولولا حرف امتناع لوجود، وكلمة مبتدأ محذوف الخبر، وجملة <span class="hlt"><span class="qpc-hafs">﴿سبقت من ربك﴾</span></span> صفة لـ<span class="hlt"><span class="qpc-hafs">﴿كلمة﴾</span></span>، ومن ربك جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿سبقت﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿لكان﴾</span></span> اللام واقعة في جواب لولا، وكان فعل ماض ناقص، واسمها ضمير مستتر تقديره: هو، يعود على الإهلاك، ولزامًا خبرها، وأجل مسمى عطف على كلمة، أو على الضمير المستتر في <span class="hlt"><span class="qpc-hafs">﴿كان﴾</span></span>، أي: لكان الإهلاك العاجل وأجل مسمى لازمين لهم كما كانا لازمين لعاد وثمود.</p></div>"
  20,130,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فاصبر على ما يقولون وسبح بحمد ربك قبل طلوع الشمس وقبل غروبها﴾</span></span>: الفاء الفصيحة، واصبر فعل أمر، وفاعله مستتر تقديره: أنت، و<span class="hlt"><span class="qpc-hafs">﴿على ما﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿اصبر﴾</span></span>، وجملة يقولون صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span>  لا محل لها من الإعراب، وسبح عطف على اصبر، وبحمد ربك في موضع نصب على الحال، أي: وأنت حامد لربك على أن وفقك للتسبيح، وأعانك عليه، وقبل ظرف متعلق بسبح، وطلوع الشمس مضاف، وقبل غروبها عطف على قبل طلوع الشمس.</p></div>"
  20,131,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ولا تمدن عينيك إلى ما متعنا به أزواجا منهم زهرة الحياة الدنيا لنفتنهم فيه﴾</span></span>: الواو عاطفة، ولا ناهية، وتمدن فعل مضارع مبني على الفتح لاتصاله بنون التوكيد، وهو في محل جزم بـ<span class="hlt"><span class="qpc-hafs">﴿لا﴾</span></span>، وفاعله ضمير مستتر تقديره: أنت، وعينيك مفعول به، وإلى ما: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تمدن﴾</span></span>، وجملة متعنا صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> لا محل لها من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿به﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿متعنا﴾</span></span>، والهاء هي العائد، وأزواجًا مفعول متعنا، ومنهم جار ومجرور متعلقان بمحذوف صفة، أو نصب على الحال من هاء الضمير، ومنهم جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿متعنا﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿زهرة الحياة الدنيا﴾</span></span> فيها أقوال:</p><p>١ -  مفعول ثان إذا أعربنا <span class="hlt"><span class="qpc-hafs">﴿أزواجًا﴾</span></span> هو المفعول الأول، لأن معنى <span class="hlt"><span class="qpc-hafs">﴿متعنا﴾</span></span>: أعطينا.</p><p>٢ -  منصوبة على الحال من <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> الموصولة.</p><p>٣ - منصوبة على البدلية من <span class="hlt"><span class="qpc-hafs">﴿أزواجًا﴾</span></span> على المبالغة.</p><p>٤ - منصوبة بفعل مضمر دل عليه <span class="hlt"><span class="qpc-hafs">﴿متعنا﴾</span></span>، تقديره: جعلنا لهم زهرة.</p><p>٥ - منصوبة على الذم، أي: أذم زهرة الحياة الدنيا.</p><p>٦ - منصوبة على الاختصاص.</p><p>٧ - منصوبة على البدلية من محل <span class="hlt"><span class="qpc-hafs">﴿به﴾</span></span>.</p><p>٨ - منصوبة على الحال من الضمير في <span class="hlt"><span class="qpc-hafs">﴿به﴾</span></span>.</p><p>٩ - منصوبة على التمييز لـ<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> أو للهاء في <span class="hlt"><span class="qpc-hafs">﴿به﴾</span></span>.</p><p>و<span class="hlt"><span class="qpc-hafs">﴿لنفتنهم﴾</span></span> اللام للتعليل، ونفتنهم مضارع منصوب بأن مضمرة بعد لام التعليل، والمصدر المؤول من أن والفعل مجرور باللام، والجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿متعنا﴾</span></span>، والهاء مفعول به، وفيه متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿نفتنهم﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿ورزق ربك خير وأبقى﴾</span></span>: الواو للحال، ورزق مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿ربك﴾</span></span> مضاف إليه، و<span class="hlt"><span class="qpc-hafs">﴿خير﴾</span></span> خبر، وأبقى عطف على خير.</p></div>"
  20,132,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وأمر أهلك بالصلاة واصطبر عليها لا نسألك رزقا﴾</span></span>: الواو استئنافية، أو عاطفة، وفعل الأمر مبني على السكون، وفاعله مستتر تقديره: أنت، وأهلك مفعول به، وبالصلاة جار ومجرور متعلقان بفعل الأمر، وجملة <span class="hlt"><span class="qpc-hafs">﴿وأمر أهلك بالصلاة﴾</span></span> معطوفة، أو مستأنفة لا محل لها من الإعراب، واصطبر فعل أمر، وفاعله مستتر، وتقديره: أنت، وعليها جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿اصطبر﴾</span></span>، وجملة لا نسألك استئنافية، ونسألك فعل مضارع، وفاعل مستتر، ومفعول به، ورزقًا مفعول به ثان.</p><p><span class="hlt"><span class="qpc-hafs">﴿نحن نرزقك والعاقبة للتقوى﴾</span></span>: نحن مبتدأ، وجملة نرزقك خبر، والعاقبة مبتدأ، وللتقوى جار ومجرور متعلقان بمحذوف خبر، وهاتان الجملتان مستأنفتان أيضًا لا محل لهما من الإعراب.</p></div>"
  20,133,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وقالوا لولا يأتينا بآية من ربه أولم تأتهم بينة ما في الصحف الأولى﴾</span></span>: لولا حرف تحضيض، أي: هلا، ويأتينا فعل، وفاعل مستتر، ومفعول به، وبآياته جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يأتينا﴾</span></span>، ومن ربه جار ومجرور متعلقان بمحذوف صفة لآية، أولم الهمزة للاستفهام، والواو عاطفة على مقدر يقتضيه السياق، والتقدير: ألم تأتهم البينات تترى، ولم تأتهم بصورة خاصة بينة ما في الصحف الأولى، وبينة فاعل لـ<span class="hlt"><span class="qpc-hafs">﴿تأتهم﴾</span></span>، وما موصول مضاف إليه، وفي الصحف جار ومجرور متعلقان بمحذوف صلة الموصول، وجملة الصلة لا محل لها من الإعراب، والأولى صفة للصحف.</p></div>"
  20,134,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ولو أنا أهلكناهم بعذاب من قبله لقالوا ربنا لولا أرسلت إلينا رسولا﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿لو﴾</span></span> شرطية، وأن حرف ناسخ مصدري، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> ضمير في محل نصب اسم أن، وأهلكناهم فعل وفاعل ومفعول به، و<span class="hlt"><span class="qpc-hafs">﴿أنّا﴾</span></span> وما بعدها فاعل لفعل محذوف تقديره ثبت، والجملة مستأنفة لا محل لها من الإعراب، وبعذاب جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أهلكناهم﴾</span></span>، ومن قبله صفة لعذاب، لقالوا: جواب لو، والجملة لا محل لها من الإعراب، وربنا منادى مضاف محذوف منه حرف النداء، ولولا حرف تحضيض، وأرسلت فعل وفاعل، وإلينا جار ومجرور متعلقان  بـ<span class="hlt"><span class="qpc-hafs">﴿أرسلت﴾</span></span>، ورسولًا مفعول به، والجملة مقول القول.</p><p><span class="hlt"><span class="qpc-hafs">﴿فنتبع آياتك من قبل أن نذل ونخزى﴾</span></span>: فنتبع الفاء هي السببية، ونتبع منصوب أن مضمرة في جواب التحضيض، والمصدر المؤول من أن والفعل معطوف على مصدر متصيَّد من الكلام السابق أي: لولا إرسال منك فاتباع منا. والفاعل مستتر تقديره: نحن، وآياتك مفعول به منصوب بالكسرة، لأنه جمع مؤنث سالم، و<span class="hlt"><span class="qpc-hafs">﴿من قبل﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿نتبع﴾</span></span>، وأن وما بعدها في تأويل مصدر مضاف إليه، و<span class="hlt"><span class="qpc-hafs">﴿نخزى﴾</span></span> عطف على <span class="hlt"><span class="qpc-hafs">﴿نذل﴾</span></span>.</p></div>"
  20,135,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قل كل متربص فتربصوا فستعلمون من أصحاب الصراط السوي ومن اهتدى﴾</span></span>: كل مبتدأ، ومتربص خبر، والجملة مقول القول، والفاء الفصيحة، وتربصوا فعل أمر، فستعلمون الفاء استئنافية، والسين حرف استقبال، وتعلمون فعل مضارع مرفوع بثبوت النون، والواو فاعل، و<span class="hlt"><span class="qpc-hafs">﴿مَن﴾</span></span> اسم استفهام مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿أصحاب الصراط السوي﴾</span></span> خبر، وجملة <span class="hlt"><span class="qpc-hafs">﴿فستعلمون مَن...﴾</span></span> مستأنفة لا محل لها من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿من اهتدى﴾</span></span> عطف على من أصحاب، وجملة <span class="hlt"><span class="qpc-hafs">﴿من أصحاب﴾</span></span> مفعول <span class="hlt"><span class="qpc-hafs">﴿تعلمون﴾</span></span> المعلقة عن العمل، أو <span class="hlt"><span class="qpc-hafs">﴿من﴾</span></span> موصولة مفعول <span class="hlt"><span class="qpc-hafs">﴿تعلمون﴾</span></span>، وأصحاب الصراط خبر لمبتدأ محذوف، أي: هم أصحاب.</p></div>"