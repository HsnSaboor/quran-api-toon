quran[15]{c,v,t}:
  19,96,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إن الذين آمنوا وعملوا الصالحات سيجعل لهم الرحمن ودا﴾</span></span>: إن حرف ناسخ، والذين اسم موصول مبني في محل نصب اسم إن، وجملة آمنوا صلة الذين لا محل لها من الإعراب، وجملة عملوا الصالحات عطف على آمنوا، وجملة سيجعل خبر إن، و<span class="hlt"><span class="qpc-hafs">﴿لهم﴾</span></span>: جار ومجرور متعلقان بمحذوف مفعول يجعل الثاني، والرحمن فاعل، وودًّا مفعول يجعل الأول.</p></div>"
  19,97,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فإنما يسرناه بلسانك لتبشر به المتقين وتنذر به قوما لدا﴾</span></span>: الفاء الفصيحة، وإنما كافة ومكفوفة، ويسرناه فعل ماض، وفاعل، ومفعول به، وبلسانك جار ومجرور متعلقان بمحذوف حال، أي: جاريًا، لتبشر اللام للتعليل، وتبشر فعل مضارع منصوب بأن مضمرة بعد لام التعليل، والمصدر المؤول من أن والفعل مجرور باللام، والجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يسرناه﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿به﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تبشر﴾</span></span>، والمتقين مفعول به، وتنذر معطوف، و<span class="hlt"><span class="qpc-hafs">﴿به﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تنذر﴾</span></span>، وقومًا مفعول به، ولدًّا صفة.</p></div>"
  19,98,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وكم أهلكنا قبلهم من قرن﴾</span></span>: كم خبرية مفعول مقدم لأهلكنا، وقبلهم ظرف متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿أهلكنا﴾</span></span>، ومن قرن تمييز.</p><p><span class="hlt"><span class="qpc-hafs">﴿هل تحس منهم من أحد أو تسمع لهم ركزا﴾</span></span>: هل حرف للاستفهام، وتحس فعل مضارع، وفاعله مستتر تقديره: أنت، ومنهم حال، لأنه كان صفة لأحد، ومن حرف صلة، وأحد مجرور بمن لفظًا، مفعول به منصوب محلًّا، أو حرف عطف، وتسمع عطف على تحس، و<span class="hlt"><span class="qpc-hafs">﴿لهم﴾</span></span>: جار ومجرور متعلقان بمحذوف حال، وركزًا مفعول به.</p></div>"
  20,1,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿طه﴾</span></span>: تقدم الكلام على الحروف المقطعة في أول سورة البقرة.</p></div>"
  20,2,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ما أنزلنا عليك القرآن لتشقى﴾</span></span>: ما نافية، وأنزلنا فعل وفاعل، وعليك جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أنزلنا﴾</span></span>، والقرآن مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿لتشقى﴾</span></span> اللام للتعليل، وتشقى فعل مضارع منصوب بأن مضمرة بعد اللام، والمصدر المؤول من <span class="hlt"><span class="qpc-hafs">﴿أن﴾</span></span> والفعل مجرور باللام، والجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أنزلنا﴾</span></span>.</p></div>"
  20,3,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إلا تذكرة لمن يخشى﴾</span></span>: إلا أداة حصر، وتذكرة مفعول لأجه، والاستثناء منقطع، وقيل: تذكرة مصدر في موضع الحال.</p></div>"
  20,4,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿تنزيلا﴾</span></span>: مفعول مطلق لفعل محذوف وجوبا، تقديره: نزلناه تنزيلًا، وقيل: بدل من تذكرة إذا جعل حالا، وقيل: منصوب على المدح والاختصاص، وقيل: منصوب بـ<span class="hlt"><span class="qpc-hafs">﴿يخشى﴾</span></span> مفعولًا به، أي: أنزله الله تذكرة لمن يخشى تنزيل الله.</p><p><span class="hlt"><span class="qpc-hafs">﴿ممن﴾</span></span>: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تنزيلًا﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿خلق الأرض﴾</span></span>: فعل ماض والفاعل مستتر، ومفعول به.</p><p><span class="hlt"><span class="qpc-hafs">﴿والسماوات﴾</span></span>: معطوف على <span class="hlt"><span class="qpc-hafs">﴿الأرض﴾</span></span> منصوب. وجملة خلق الأرض والسماوات صلة <span class="hlt"><span class="qpc-hafs">﴿من﴾</span></span> لا محل لها من الإعراب.</p><p><span class="hlt"><span class="qpc-hafs">﴿العلا﴾</span></span>: صفة.</p></div>"
  20,5,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿الرحمن على العرش استوى﴾</span></span>: الرحمن خبر لمبتدأ محذوف تقديره: هو، أو مبتدأ، وعلى العرش جار ومجرور متعلقان باستوى، وجملة استوى خبر ثان لـ<span class="hlt"><span class="qpc-hafs">﴿هو﴾</span></span> ا لمقدرة، أو خبر الرحمن.</p></div>"
  20,6,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿له ما في السماوات وما في الأرض وما بينهما وما تحت الثرى﴾</span></span>: له خبر مقدم، وما مبتدأ مؤخر، و<span class="hlt"><span class="qpc-hafs">﴿في السماوات﴾</span></span> جار ومجرور متعلقان بمحذوف صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span>، وجملة الصلة لا محل لها من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿ما في الأرض﴾</span></span> عطف على ما في السماوات، وما بينهما عطف كذلك، وما عطف على ما، وتحت الثرى ظرف متعلق بمحذوف صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span>، وجملة الصلة لا محل لها من الإعراب.</p></div>"
  20,7,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وإن تجهر بالقول فإنه يعلم السر وأخفى﴾</span></span>: الواو استئنافية، والجملة بعدها مستأنفة لا محل لها من الإعراب، وإن شرطية، وتجهر فعل الشرط، وفاعله مستتر تقديره: أنت، وبالقول جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تجهر﴾</span></span>، فإنه: الفاء رابطة لأن الجواب جملة اسمية، وإن حرف ناسخ، والهاء ضمير مبني في محل نصب اسم إن، وجملة يعلم السر خبر إن، وأخفى اسم تفضيل  عطف على السر، أي: أخفى منه، وقيل: فعل ماض، أي: وأخفى الله من عباده غيبه.</p></div>"
  20,8,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿الله﴾</span></span>: مبتدأ.</p><p><span class="hlt"><span class="qpc-hafs">﴿لا﴾</span></span>: نافية للجنس.</p><p><span class="hlt"><span class="qpc-hafs">﴿إله﴾</span></span>: اسمها مبني على الفتح في محل نصب.</p><p><span class="hlt"><span class="qpc-hafs">﴿إلا﴾</span></span>: أداة حصر.</p><p><span class="hlt"><span class="qpc-hafs">﴿هو﴾</span></span>: بدل من محل لا واسمها، لأن محلها الرفع على الابتداء، أو بدل من الضمير المستكن في الخبر المحذوف. وجملة <span class="hlt"><span class="qpc-hafs">﴿لا إله إلا هو﴾</span></span> خبر.</p><p><span class="hlt"><span class="qpc-hafs">﴿له الأسماء الحسنى﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿له﴾</span></span>: جار ومجرور متعلقان بمحذوف خبر مقدم، والأسماء مبتدأ مؤخر، والحسنى صفة للأسماء، والجملة خبر ثان.</p></div>"
  20,9,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وهل أتاك حديث موسى﴾</span></span>: الواو للاستئناف، والجملة بعدها مستأنفة لا محل لها من الإعراب، وأتاك فعل ومفعول به، وحديث موسى فاعل، والاستفهام للتقرير.</p></div>"
  20,10,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إذ رأى نارا فقال لأهله امكثوا إني آنست نارا﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿إذ﴾</span></span> ظرف للزمن الماضي متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿حديث﴾</span></span> في الآية السابقة، وجملة <span class="hlt"><span class="qpc-hafs">﴿رأى﴾</span></span> في محل جر مضاف إليه، ونارًا مفعول به، فقال عطف على رأى، ولأهله جار ومجرور متعلقان بقال، وجملة امكثوا مقول القول، وجملة إني تعليل للأمر بالمكوث، وإن حرف ناسخ، والياء ضمير مبني في محل نصب اسم إن، وجملة آنست خبر إن، ونارًا مفعول به.</p><p><span class="hlt"><span class="qpc-hafs">﴿لعلي آتيكم منها بقبس أو أجد على النار هدى﴾</span></span>: لعل حرف ناسخ، والياء ضمير مبني في محل نصب اسم لعل، وجملة آتيكم خبر لعل، ومنها جار ومجرور متعلقان بمحذوف حال، لأنه كان في الأصل صفة للقبس، <span class="hlt"><span class="qpc-hafs">﴿أو﴾</span></span> حرف عطف، وأجد معطوف على آتيكم، وفاعل أجد مستتر تقديره: أنا، وعلى النار جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أجد﴾</span></span>، وهدى مفعول به.</p></div>"
  20,11,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فلما أتاها نودي يا موسى﴾</span></span>: الفاء عاطفة على محذوف، والتقدير: فيمَّمَ شطر النار، ولما ظرفية حينية، أو رابطة، وأتاها فعل، وفاعل مستتر، ومفعول به، وجملة نودي لا محل لها من الإعراب، لأنها جواب شرط غير جازم، ويا موسى حرف نداء ومنادى.</p></div>"
  20,12,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إني أنا ربك فاخلع نعليك إنك بالواد المقدس طوى﴾</span></span>: إن حرف ناسخ، والياء ضمير مبني في محل نصب اسم إن، وأنا تأكيد للضمير، أو مبتدأ، وربك خبر إن منصوب والكاف ضمير مبني في محل جر مضاف إليه، أو خبر أنا، والجملة خبر إن، والأول أولى، فاخلع الفاء الفصيحة، واخلع فعل أمر، وفاعل مستتر، ونعليك مفعول به، وجملة إنك تعليل للخلع، وإن حرف ناسخ، والكاف ضمير مبني في محل نصب اسم إن، وبالوادي جار ومجرور متعلقان بمحذوف خبر إن، والمقدس صفة، وطوى بدل أو عطف بيان.</p></div>"