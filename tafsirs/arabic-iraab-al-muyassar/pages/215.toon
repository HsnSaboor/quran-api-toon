quran[8]{c,v,t}:
  10,54,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ولو أن لكل نفس ظلمت ما في الأرض لافتدت به﴾</span></span>: الواو استئنافية، والجملة بعدها مستأنفة لا محل لها من الإعراب، ولو شرطية امتناعية، وأن حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿لكل﴾</span></span> خبر أن المقدم، ونفس مضاف إليه، وجملة ظلمت صفة لنفس، وما اسم موصول في محل نصب اسم أن، وأن وما في حيزها فاعل لفعل محذوف، أي: لو ثبت ذلك، و<span class="hlt"><span class="qpc-hafs">﴿في الأرض﴾</span></span> صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> لا محل لها من الإعراب، واللام واقعة في جواب لو، وافتدت به جملة فعلية لا محل لها من الإعراب، لأنها جواب شرط غير جازم.</p><p><span class="hlt"><span class="qpc-hafs">﴿وأسروا الندامة لما رأوا العذاب﴾</span></span>: الواو عاطفة، وأسروا الندامة فعل وفاعل ومفعول به، ولما رابطة، أو حينية، وجملة رأوا مضاف إليها، والواو فاعل، والعذاب مفعول به.</p><p><span class="hlt"><span class="qpc-hafs">﴿وقضي بينهم بالقسط﴾</span></span>: الكلام مستأنف لا محل له من الإعراب، أو معطوف، وقضي فعل ماض بالبناء لما لم يسمَّ فاعله، ونائب الفاعل مستتر، وبينهم ظرف متعلق بقضي، وبالقسط حال.</p><p><span class="hlt"><span class="qpc-hafs">﴿وهم لا يظلمون﴾</span></span>: الواو عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> مبتدأ، وجملة لا يظلمون خبر.</p></div>"
  10,55,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ألا إن لله ما في السماوات والأرض﴾</span></span>: ألا أداة تنبيه، واستفتاح، ولله خبر إن المقدم، وما اسمها المؤخر، وفي السماوات والأرض صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> لا محل لها من الإعراب.</p><p><span class="hlt"><span class="qpc-hafs">﴿ألا إن وعد الله حق﴾</span></span>: ألا تأكيد لـ<span class="hlt"><span class="qpc-hafs">﴿ألا﴾</span></span> الأولى، وإن واسهما، وحق خبرها.</p><p><span class="hlt"><span class="qpc-hafs">﴿ولكن أكثرهم لا يعلمون﴾</span></span>: الواو حالية والجملة بعدها في محل نصب حال، أو استئنافية والجملة بعدها مستأنفة لا محل لها من الإعراب، ولكن حرف ناسخ، وأكثرهم اسمها، وجملة لا يعلمون خبرها.</p></div>"
  10,56,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿هو يحيي ويميت وإليه ترجعون﴾</span></span>: هو مبتدأ، وجملة يحيي خبر، وجملة يميت عطف، وإليه جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿ترجعون﴾</span></span>.</p></div>"
  10,57,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿يا أيها الناس﴾</span></span>: يا حرف نداء للمتوسط، وأي منادى نكرة مقصودة مبني على الضم في محل نصب، وها للتنبيه، والناس صفة لـ<span class="hlt"><span class="qpc-hafs">﴿أي﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿قد جاءتكم موعظة من ربكم﴾</span></span>: قد حرف تحقيق، وجاءتكم موعظة فعل ومفعول به وفاعل، ومن ربكم صفة لموعظة، و<span class="hlt"><span class="qpc-hafs">﴿من﴾</span></span> للتبعيض، أو متعلقة بـ<span class="hlt"><span class="qpc-hafs">﴿جاءتكم﴾</span></span> فتكون للابتداء.</p><p><span class="hlt"><span class="qpc-hafs">﴿وشفاء لما في الصدور وهدى ورحمة للمؤمنين﴾</span></span>: الواو عاطفة، وشفاء عطف على موعظة، و<span class="hlt"><span class="qpc-hafs">﴿لما في الصدور﴾</span></span> جار ومجرور متعلقان بمحذوف صفة لشفاء، أو اللام حرف صلة، وما اسم موصول مفعول به، وفي الصدور صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> لا محل لها من الإعراب، وهدى ورحمة معطوفان أيضًا، وللمؤمنين صفة.</p></div>"
  10,58,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قل بفضل الله وبرحمته فبذلك فليفرحوا هو خير مما يجمعون﴾</span></span>: الجار والمجرور متعلقان بمحذوف، وأصل الكلام: ليفرحوا بفضل الله وبرحمته فبذلك، والفاء لإفادة معنى السببية، أي: بفضل الله وبرحمته فليفرحوا، والفاء الأولى جزائية، والثانية للسببية، <span class="hlt"><span class="qpc-hafs">﴿فبذلك﴾</span></span> الفاء عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿بذلك﴾</span></span> عطف على <span class="hlt"><span class="qpc-hafs">﴿بفضل الله﴾</span></span>، وقيل: الفاء الداخلة على <span class="hlt"><span class="qpc-hafs">﴿بذلك﴾</span></span> صلة، و<span class="hlt"><span class="qpc-hafs">﴿بذلك﴾</span></span> بدل من <span class="hlt"><span class="qpc-hafs">﴿بفضل﴾</span></span>، أما الفاء الداخلة على <span class="hlt"><span class="qpc-hafs">﴿فليفرحوا﴾</span></span> فهي الفصيحة، لأنها داخلة لمعنى الشرط، كأنه قيل: إن فرحوا بشيء فليخصوها بالفرح، و<span class="hlt"><span class="qpc-hafs">﴿هو﴾</span></span> مبتدأ، وخير خبر، و<span class="hlt"><span class="qpc-hafs">﴿مما﴾</span></span> جار ومجرور متعلقان بخير، ويجمعون صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> لا محل لها من الإعراب.</p></div>"
  10,59,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قل أرأيتم ما أنزل الله لكم من رزق﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿أرأيتم﴾</span></span> الهمزة للاستفهام، ورأى فعل ماض مبني على السكون، والتاء فاعل، <span class="hlt"><span class="qpc-hafs">﴿ما أنزل الله﴾</span></span> ما اسم موصول مفعول لـ<span class="hlt"><span class="qpc-hafs">﴿أرأيتم﴾</span></span>، أو لـ<span class="hlt"><span class="qpc-hafs">﴿أنزل﴾</span></span>، وجملة أنزل صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> لا محل لها من الإعراب، والعائد محذوف، أي: أنزله الله، أو ما استفهامية في محل نصب بـ<span class="hlt"><span class="qpc-hafs">﴿أنزل﴾</span></span>، وهي حينئذ معلقة لـ<span class="hlt"><span class="qpc-hafs">﴿أرأيتم﴾</span></span> عن العمل، أو ما استفهامية في محل رفع بالابتداء، وجملة <span class="hlt"><span class="qpc-hafs">﴿آلله أذن لكم﴾</span></span> خبر، ولكم جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أنزل﴾</span></span>، ومن رزق حال.</p><p><span class="hlt"><span class="qpc-hafs">﴿فجعلتم منه حراما وحلالا قل آلله أذن لكم أم على الله تفترون﴾</span></span>: فجعلتم عطف على أنزل، وجعلتم فعل وفاعل، و<span class="hlt"><span class="qpc-hafs">﴿منه﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿جعلتم﴾</span></span>، وحرامًا مفعول جعلتم، وحلالًا عطف، <span class="hlt"><span class="qpc-hafs">﴿آلله﴾</span></span> الهمزة للاستفهام الإنكاري، و<span class="hlt"><span class="qpc-hafs">﴿الله﴾</span></span> مبتدأ، وجملة أذن خبره، ولكم جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أذن﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿أم﴾</span></span> منقطعة بمعنى: بل والهمزة، والتقدير: بل أتفترون على الله؟ والاستفهام للإنكار، أو متصلة، والتقدير: أي الأمرين وقع، إذن الله لكم في ذلك أم افتراؤكم عليه؟ ولعل اتصالها أظهر، و<span class="hlt"><span class="qpc-hafs">﴿على الله﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يفترون﴾</span></span>.</p></div>"
  10,60,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وما ظن الذين يفترون على الله الكذب يوم القيامة﴾</span></span>: الواو عاطفة، وما استفهامية مبتدأ، وظن خبرها، والذين مضاف إليه، وجملة يفترون صلة الذين لا محل لها من الإعراب، وعلى الله جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يفترون﴾</span></span>، والكذب مفعول به، ويوم القيامة ظرف متعلق بالظن، فمفعولا الظن سدت مسدهما أن المقدرة وما بعدها.</p><p><span class="hlt"><span class="qpc-hafs">﴿إن الله لذو فضل على الناس ولكن أكثرهم لا يشكرون﴾</span></span>: إن حرف ناسخ، ولفظ الجلالة اسمها، واللام المزحلقة، وذو فضل خبرها، وعلى الناس جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿فضل﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿ولكن﴾</span></span> الواو حالية والجملة بعدها في محل نصب، أو استئنافية والجملة بعدها مستأنفة لا محل لها من الإعراب، ولكن حرف ناسخ، وأكثرهم اسمها، وجملة لا يشكرون خبرها.</p></div>"
  10,61,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وما تكون في شأن وما تتلو منه من قرآن﴾</span></span>: الواو عاطفة، وما نافية، وتكون فعل مضارع ناقص ناسخ، واسم تكون مستتر تقديره أنت، و<span class="hlt"><span class="qpc-hafs">﴿في شأن﴾</span></span> خبر تكون، <span class="hlt"><span class="qpc-hafs">﴿وما﴾</span></span> الواو عاطفة، وما نافية، وتتلو فعل مضارع، وفاعله مستتر تقديره: أنت، ومنه جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تتلو﴾</span></span>، والضمير يعود إلى القرآن، أو إلى الشأن، فتكون من تعليلية، أي: من أجل الشأن الذي كنت مسترسلًا فيه، ومن حرف صلة، وقرآن مفعول به محلاّ.</p><p><span class="hlt"><span class="qpc-hafs">﴿ولا تعملون من عمل إلا كنا عليكم شهودا إذ تفيضون فيه﴾</span></span>: الواو عاطفة، ولا تعملون عطف على ما تقدم، و<span class="hlt"><span class="qpc-hafs">﴿من﴾</span></span> حرف صلة، و<span class="hlt"><span class="qpc-hafs">﴿عمل﴾</span></span> مجرور لفظا مفعول به محلا، أو مفعول مطلق، وإلا أداة حصر، و<span class="hlt"><span class="qpc-hafs">﴿كنا﴾</span></span> فعل ماض ناقص ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> اسم كا، وعليكم جار ومجرور متعلقان بقوله: <span class="hlt"><span class="qpc-hafs">﴿شهودًا﴾</span></span>، أي: شاهدين، وشهودًا خبر كنا، و<span class="hlt"><span class="qpc-hafs">﴿إذ﴾</span></span> ظرف لما مضى متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿شهودًا﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿تفيضون﴾</span></span> في محل جر بإضافة الظرف إليها، وفيه جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تفيضون﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿وما يعزب عن ربك من مثقال ذرة في الأرض ولا في السماء﴾</span></span>: الواو حرف عطف، وما نافية، وعن ربك جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يعزب﴾</span></span>، ومن حرف صلة، ومثقال ذرة فاعل يعزب محلاًّ، و<span class="hlt"><span class="qpc-hafs">﴿في الأرض﴾</span></span> جار ومجرور متعلقان بمحذوف حال من <span class="hlt"><span class="qpc-hafs">﴿مثقال ذرة﴾</span></span>، أو صفة، ولا في السماء عطف.</p><p><span class="hlt"><span class="qpc-hafs">﴿ولا أصغر من ذلك ولا أكبر إلا في كتاب مبين﴾</span></span>: الواو استئنافية، والجملة بعدها مستأنفة لا محل لها من الإعراب، ولا نافية للجنس، وأصغر اسمها، و<span class="hlt"><span class="qpc-hafs">﴿من ذلك﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أصغر﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿ولا أكبر﴾</span></span> عطف على <span class="hlt"><span class="qpc-hafs">﴿ولا أصغر﴾</span></span>، وإلا أداة حصر، و<span class="hlt"><span class="qpc-hafs">﴿في كتاب مبين﴾</span></span> خبر <span class="hlt"><span class="qpc-hafs">﴿لا﴾</span></span>، ومبين صفة لـ<span class="hlt"><span class="qpc-hafs">﴿كتاب﴾</span></span>.</p></div>"