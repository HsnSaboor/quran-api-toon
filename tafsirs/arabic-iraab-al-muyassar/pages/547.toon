quran[7]{c,v,t}:
  59,10,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿والذين جاءوا من بعدهم يقولون ربنا اغفر لنا ولإخواننا الذين سبقونا بالإيمان﴾</span></span>: الذين مبتدأ، وجملة <span class="hlt"><span class="qpc-hafs">﴿جاؤوا﴾</span></span> صلة الموصول لا محل لها من الإعراب. ومن بعدهم جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿جاءوا﴾</span></span>، وجملة يقولون خبر الذين، وربنا منادى مضاف، واغفر فعل دعاء، وفاعله مستتر تقديره: أنت، والجملة مقول القول، ولإخواننا عطف على لنا، والذين نعت لإخواننا، وجملة <span class="hlt"><span class="qpc-hafs">﴿سبقونا﴾</span></span> صلة الذين لا محل لها من الإعراب. وبالإيمان جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿سبقونا﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿ولا تجعل في قلوبنا غلا للذين آمنوا﴾</span></span>: الواو عاطفة، ولا طلبية، وتجعل فعل مضارع مجزوم بـ<span class="hlt"><span class="qpc-hafs">﴿لا﴾</span></span>، وفي قلوبنا في موضع المفعول الثاني لتجعل، وغلًّا مفعولها الأول، وللذين نعت لـ<span class="hlt"><span class="qpc-hafs">﴿غلًّا﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿ربنا إنك رءوف رحيم﴾</span></span>: ربنا منادى مضاف، وإن حرف ناسخ، والكاف اسمها، ورؤوف خبر إن الأول، ورحيم خبرها الثاني.</p></div>"
  59,11,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ألم تر إلى الذين نافقوا يقولون لإخوانهم الذين كفروا من أهل الكتاب﴾</span></span>: كلام مستأنف لا محل له من الإعراب، والهمزة للاستفهام التقريري، ولم حرف نفي وقلب وجزم، وتر فعل مضارع مجزوم بـ<span class="hlt"><span class="qpc-hafs">﴿لم﴾</span></span>، وعلامة جزمه حذف حرف العلة، والفاعل ضمير مستتر تقديره: أنت، وإلى الذين جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تر﴾</span></span>، وجملة نافقوا صلة الموصول لا محل لها من الإعراب، وجملة <span class="hlt"><span class="qpc-hafs">﴿يقولون﴾</span></span> مستأنفة لبيان المتعجب منه لا محل لها من الإعراب، ولإخوانهم جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يقولون﴾</span></span>، والذين نعت لإخوانهم، وجملة كفروا صلة الذين لا محل لها من الإعراب. ومن أهل الكتاب حال.</p><p><span class="hlt"><span class="qpc-hafs">﴿لئن أخرجتم لنخرجن معكم ولا نطيع فيكم أحدا أبدا﴾</span></span>: الجملة مقول قول قولهم، واللام موطئة للقسم، وإن شرطية، وأخرجتم فعل ماضٍ مبني لما لم يسمَّ فاعله في محل جزم فعل الشرط، والتاء نائب فاعل، واللام جواب القسم أيضًا، ونخرجن فعل مضارع مبني على الفتح لاتصاله بنون التوكيد الثقيلة، والجملة لا محل لها من الإعراب، لأنها جواب القسم، وجواب إن الشرطية محذوف، ومعكم ظرف متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿نخرجن﴾</span></span>، والواو حرف عطف، ولا نافية، ونطيع فعل مضارع مرفوع، لأنه معطوف على جملة <span class="hlt"><span class="qpc-hafs">﴿لئن أخرجتم﴾</span></span>، وكذلك قوله: وإن قوتلتم، فمقول قولهم ثلاث جمل، وفيكم جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿نطيع﴾</span></span> على حذف مضاف، وأحدًا مفعول به، وأبدًا ظرف للنفي متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿نطيع﴾</span></span> أيضًا.</p><p><span class="hlt"><span class="qpc-hafs">﴿وإن قوتلتم لننصرنكم﴾</span></span>: الواو عاطفة، وإن شرطية، حذفت قبلها اللام الموطئة للقسم، وقوتلتم فعل ماضٍ مبني لما لم يسمَّ فاعله في محل جزم فعل الشرط، واللام واقعة في جواب القسم، وننصرنكم فعل مضارع مبني على الفتح لاتصاله بنون التوكيد الثقيلة، وجواب إن محذوف، والجملة لا محل لها من الإعراب، لأنها جواب القسم.</p><p><span class="hlt"><span class="qpc-hafs">﴿والله يشهد إنهم لكاذبون﴾</span></span>: الله مبتدأ، وجملة يشهد خبر، وإن حرف ناسخ، وكسرت همزتها لوقوع اللام المزحلقة في خبرها، والهاء اسمها، وكاذبون خبرها.</p></div>"
  59,12,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿لئن أخرجوا لا يخرجون معهم﴾</span></span>: اللام موطئة للقسم، وإن شرطية، وأخرجوا فعل مضارع مبني لما لم يسمَّ فاعله، والواو نائب فاعل، وهو في محل جزم فعل الشرط، وجواب إن محذوف دل عليه جواب القسم، وهو جملة لا يخرجون، ومعهم ظرف متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿يخرجون﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿ولئن قوتلوا لا ينصرونهم﴾</span></span>: عطف على ما تقدم، واللام موطئة للقسم، وإن شرطية، وقوتلوا فعل مضارع مبني لما لم يسمَّ فاعله، والواو نائب فاعل، وهو في محل جزم فعل الشرط، وجواب إن محذوف دل عليه جواب القسم، وهو جملة لا ينصرونهم.</p><p><span class="hlt"><span class="qpc-hafs">﴿ولئن نصروهم ليولن الأدبار ثم لا ينصرون﴾</span></span>: عطف أيضًا، وقوله ليولن: اللام جواب القسم، ويولن فعل مضارع مرفوع، وعلامة رفعه ثبوت النون المحذوفة لتوالي الأمثال، والواو المحذوفة لالتقاء الساكنين فاعل، والأدبار مفعول به، وثم حرف عطف، ولا نافية، وينصرون فعل مضارع معطوف على يولن مرفوع مثله، والضمائر عائدة على اليهود، أو على المنافقين.</p></div>"
  59,13,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿لأنتم أشد رهبة في صدورهم من الله﴾</span></span>: اللام لام الابتداء، وأنتم مبتدأ، وأشد خبر، ورهبة تمييز، وفي صدورهم جار ومجرور متعلقان بمحذوف حال من الضمير المستكن في أشد، ومن الله جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿رهبة﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿ذلك بأنهم قوم لا يفقهون﴾</span></span>: ذلك مبتدأ، وبأنهم خبر، وأن حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> اسمها، وقوم خبرها، وجملة لا يفقهون نعت لـ<span class="hlt"><span class="qpc-hafs">﴿قوم﴾</span></span>.</p></div>"
  59,14,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿لا يقاتلونكم جميعا إلا في قرى محصنة أو من وراء جدر﴾</span></span>: لا نافية، ويقاتلونكم فعل مضارع مرفوع وفاعل ومفعول به، وجميعًا حال، وإلا أداة حصر، وفي قرى جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يقاتلونكم﴾</span></span>، والضمير يعود لليهود، ومحصنة نعت لـ<span class="hlt"><span class="qpc-hafs">﴿قرى﴾</span></span>، وأو حرف عطف، ومن وراء عطف على <span class="hlt"><span class="qpc-hafs">﴿في قرى﴾</span></span>، وجدر مضاف إليه.</p><p><span class="hlt"><span class="qpc-hafs">﴿بأسهم بينهم شديد تحسبهم جميعًا وقلوبهم شتى﴾</span></span>: الجملة مستأنفة لبيان حالهم ولا محل لها من الإعراب، وبأسهم مبتدأ، وبينهم ظرف متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿شديد﴾</span></span>، وشديد خبر، وجملة <span class="hlt"><span class="qpc-hafs">﴿تحسبهم...﴾</span></span> استئنافية  لا محل لها من الإعراب أيضًا، وتحسبهم فعل مضارع، والفاعل مستتر تقديره: أنت، والهاء مفعول به أول، وجميعًا مفعول به ثان، والواو حالية، وقلوبهم مبتدأ، وشتى خبره، والجملة حالية.</p><p><span class="hlt"><span class="qpc-hafs">﴿ذلك بأنهم قوم لا يعقلون﴾</span></span>: ذلك مبتدأ، وبأنهم جار ومجرور متعلقان بمحذوف خبر، وأن حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> اسمها، وقوم خبرها، وجملة لا يعقلون نعت لـ<span class="hlt"><span class="qpc-hafs">﴿قوم﴾</span></span>.</p></div>"
  59,15,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿كمثل الذين من قبلهم قريبا ذاقوا وبال أمرهم﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿كمثل﴾</span></span> الكاف اسم بمعنى مثل مبني على الفتح في محل رفع خبر لمبتدأ محذوف تقديره: مَثَلُهم مِثْلُ مَثَل الذين، و<span class="hlt"><span class="qpc-hafs">﴿مثل﴾</span></span> مضاف إليه، والذين مضاف إليه، و<span class="hlt"><span class="qpc-hafs">﴿من قبلهم﴾</span></span> جار ومجرور متعلقان بمحذوف صلة الذين، وجملة الصلة لا محل لها من الإعراب. وقريبًا ظرف متعلق بالاستقرار المحذوف الذي يتعلق به من قبلهم، ولك أن تعلقه بـ<span class="hlt"><span class="qpc-hafs">﴿ذاقوا﴾</span></span>، وعلقه البعض بمضاف مقدر، وذاقوا فعل وفاعل، ووبال أمرهم مفعول.</p><p><span class="hlt"><span class="qpc-hafs">﴿ولهم عذاب أليم﴾</span></span>: الواو استئنافية، ولهم خبر مقدم، وعذاب مبتدأ مؤخر، وعظيم نعت، والجملة  مستأنفة لا محل لها من الإعراب.</p></div>"
  59,16,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿كمثل الشيطان إذ قال للإنسان اكفر﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿كمثل﴾</span></span> الكاف اسم بمعنى مثل مبني على الفتح في محل رفع خبر لمبتدأ محذوف، أي: مَثَلُهم مِثْلُ مَثَل الشيطان، و<span class="hlt"><span class="qpc-hafs">﴿مَثَل﴾</span></span> مضاف إليه، و<span class="hlt"><span class="qpc-hafs">﴿إذ﴾</span></span> ظرف لما مضى من الزمن متعلق بمحذوف حال من الشيطان، وجملة <span class="hlt"><span class="qpc-hafs">﴿قال﴾</span></span> في محل جر بإضافة الظرف إليها، وللإنسان جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿قال﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿اكفر﴾</span></span> مقول القول.</p><p><span class="hlt"><span class="qpc-hafs">﴿فلما كفر قال إني بريء منك﴾</span></span>: الفاء عاطفة على محذوف، أي: فكفر، ولما ظرفية حينية، أو رابطة متضمنة معنى الشرط، وجملة كفر في محل جر بإضافة الظرف إليها، وجملة قال لا محل لها من الإعراب، لأنها جواب شرط غير جازم، وإن حرف ناسخ، والياء اسمها، وبريء خبرها، ومنك جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿بريء﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿إني أخاف الله رب العالمين﴾</span></span>: الجملة تعليل كاذب لبراءته منه، وإلا فهو لا يخاف الله، وإن حرف ناسخ، والياء اسمها، وجملة أخاف الله خبرها، ورب العالمين بدل من لفظ الجلالة، أو نعت له.</p></div>"