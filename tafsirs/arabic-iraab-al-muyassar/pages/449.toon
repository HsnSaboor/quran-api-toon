quran[26]{c,v,t}:
  37,77,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وجعلنا ذريته هم الباقين﴾</span></span>: الواو عاطفة، وجعلنا عطف على نجيناه، وذريته مفعول به، وهم ضمير فصل لا محل له من الإعراب، والباقين مفعول جعلنا الثاني.</p></div>"
  37,78,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وتركنا عليه في الآخرين﴾</span></span>: الواو عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿تركنا﴾</span></span> فعل ماض، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> فاعل، و<span class="hlt"><span class="qpc-hafs">﴿عليه﴾</span></span> جار ومجرور متعلقان بمحذوف صفة للمفعول المحذوف، أي: ثناء كائنًا عليه، و<span class="hlt"><span class="qpc-hafs">﴿في الآخرين﴾</span></span> جار ومجرور متعلقان بمحذوف مفعول به ثان لـ<span class="hlt"><span class="qpc-hafs">﴿تركنا﴾</span></span>.</p></div>"
  37,79,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿سلام على نوح في العالمين﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿سلام﴾</span></span> مبتدأ. و<span class="hlt"><span class="qpc-hafs">﴿على نوح﴾</span></span> جار ومجرور متعلقان بمحذوف خبر. و<span class="hlt"><span class="qpc-hafs">﴿في العالمين﴾</span></span> جار ومجرور متعلقان بالخبر المحذوف. وجملة <span class="hlt"><span class="qpc-hafs">﴿سلام على نوح في العالمين﴾</span></span> تفسيرية لـ<span class="hlt"><span class="qpc-hafs">﴿تركنا﴾</span></span>، لا محل لها من الإعراب.</p></div>"
  37,80,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إنا كذلك نجزي المحسنين﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿إنّا﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span> حرف ناسخ و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> اسمها، و<span class="hlt"><span class="qpc-hafs">﴿كذلك﴾</span></span>: الكاف: اسم بمعنى مثل مبني على الفتح في محل نصب صفة لمصدر محذوف مقدم على عامله، أي: جزاءً مثلَ ذلك نجزي المحسنين، وذلك: <span class="hlt"><span class="qpc-hafs">﴿ذا﴾</span></span> اسم إشارة في محل جر مضاف إليه، واللام للبعد، والكاف حرف خطاب، و<span class="hlt"><span class="qpc-hafs">﴿نجزي﴾</span></span> فعل مضارع، والفاعل مستتر تقديره نحن، و<span class="hlt"><span class="qpc-hafs">﴿المحسنين﴾</span></span> مفعول به، وجملة <span class="hlt"><span class="qpc-hafs">﴿نجزي﴾</span></span> خبر <span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span>.</p></div>"
  37,81,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إنه من عبادنا المؤمنين﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span> حرف ناسخ، والهاء اسمها، و<span class="hlt"><span class="qpc-hafs">﴿من عبادنا﴾</span></span> جار ومجرور متعلقان بمحذوف خبرها، و<span class="hlt"><span class="qpc-hafs">﴿المؤمنين﴾</span></span> نعت لـ<span class="hlt"><span class="qpc-hafs">﴿عبادنا﴾</span></span>.</p></div>"
  37,82,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ثم أغرقنا الآخرين﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿ثم﴾</span></span> حرف عطف للتراخي، و<span class="hlt"><span class="qpc-hafs">﴿أغرقنا﴾</span></span> فعل ماض، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> فاعل، و<span class="hlt"><span class="qpc-hafs">﴿الآخرين﴾</span></span> مفعول به.</p></div>"
  37,83,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وإن من شيعته لإبراهيم﴾</span></span>: الواو عاطفة، أو استئنافية، و<span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span> حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿من شيعته﴾</span></span> جار ومجرور متعلقان بمحذوف خبرها المقدم، واللام المزحلقة، و<span class="hlt"><span class="qpc-hafs">﴿إبراهيم﴾</span></span> اسمها المؤخر، وجملة <span class="hlt"><span class="qpc-hafs">﴿وإن من شيعته...﴾</span></span> معطوفة، أو مستأنفة لا محل لها من الإعراب.</p></div>"
  37,84,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إذ جاء ربه بقلب سليم﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿إذ﴾</span></span> اسم مبني على السكون في محل نصب مفعول به لفعل محذوف تقديره: اذكر، وجملة <span class="hlt"><span class="qpc-hafs">﴿جاء﴾</span></span> في محل جر بالإضافة، و<span class="hlt"><span class="qpc-hafs">﴿جاء﴾</span></span> فعل ماض، والفاعل مستتر تقديره: هو، يعود على إبراهيم، و<span class="hlt"><span class="qpc-hafs">﴿ربه﴾</span></span> مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿بقلب﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿جاء﴾</span></span>، وسليم صفة.</p></div>"
  37,85,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إذ قال لأبيه وقومه﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿إذ﴾</span></span> اسم مبني على السكون في محل نصب بدل من <span class="hlt"><span class="qpc-hafs">﴿إذ﴾</span></span> في الآية السابقة، أو ظرف متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿سليم﴾</span></span>، أو بـ<span class="hlt"><span class="qpc-hafs">﴿جاء﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿قال﴾</span></span> في محل جر بالإضافة، و<span class="hlt"><span class="qpc-hafs">﴿قال﴾</span></span> فعل ماض، والفاعل ضمير مستتر تقديره: هو، و<span class="hlt"><span class="qpc-hafs">﴿لأبيه﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿قال﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿ماذا تعبدون﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿ذا﴾</span></span> اسم موصول خبر، وجملة <span class="hlt"><span class="qpc-hafs">﴿تعبدون﴾</span></span> صلة الموصول لا محل لها من الإعراب. أو <span class="hlt"><span class="qpc-hafs">﴿ماذا﴾</span></span> اسم استفهام في محل نصب مفعول مقدم لـ<span class="hlt"><span class="qpc-hafs">﴿تعبدون﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿تعبدون﴾</span></span> فعل مضارع مرفوع، والواو فاعل، وجملة <span class="hlt"><span class="qpc-hafs">﴿ماذا تعبدون﴾</span></span> مقول القول.</p></div>"
  37,86,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿أئفكا آلهة دون الله تريدون﴾</span></span>: الهمزة للاستفهام الإنكاري التوبيخي، و<span class="hlt"><span class="qpc-hafs">﴿إفكًا﴾</span></span> مفعول من أجله، أي: أتريدون آلهة دون الله إفكًا، و<span class="hlt"><span class="qpc-hafs">﴿آلهة﴾</span></span> مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿دون الله﴾</span></span> ظرف متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿تريدون﴾</span></span>، أو <span class="hlt"><span class="qpc-hafs">﴿إفكا﴾</span></span> مفعول به بـ<span class="hlt"><span class="qpc-hafs">﴿تريدون﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿آلهة﴾</span></span> بدل منه، أو<span class="hlt"><span class="qpc-hafs">﴿إفكا﴾</span></span> حال من فاعل <span class="hlt"><span class="qpc-hafs">﴿تريدون﴾</span></span>، أي: أتريدون آلهة آفكين، أو: ذوي إفك، و<span class="hlt"><span class="qpc-hafs">﴿تريدون﴾</span></span> فعل مضارع مرفوع والواو فاعل.</p></div>"
  37,87,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فما ظنكم برب العالمين﴾</span></span>: الفاء عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> اسم استفهام للإنكار والتوبيخ في محل رفع مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿ظنكم﴾</span></span> خبره، و<span class="hlt"><span class="qpc-hafs">﴿برب العالمين﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿ظنكم﴾</span></span>.</p></div>"
  37,88,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فنظر نظرة في النجوم﴾</span></span>: الفاء عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿نظر﴾</span></span> فعل ماض، وفاعله مستتر تقديره: هو، و<span class="hlt"><span class="qpc-hafs">﴿نظرة﴾</span></span> نائب عن المفعول المطلق منصوب، و<span class="hlt"><span class="qpc-hafs">﴿في النجوم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿نظر﴾</span></span>، قيل: الكلام على حذف مضاف، أي: في علم النجوم.</p></div>"
  37,89,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فقال إني سقيم﴾</span></span>: الفاء عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿قال﴾</span></span> فعل ماض، والفاعل مستتر، و<span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span> حرف ناسخ، والياء اسمها، و<span class="hlt"><span class="qpc-hafs">﴿سقيم﴾</span></span> خبرها، وإن وما في حيزها في محل نصب مقول القول.</p></div>"
  37,90,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فتولوا عنه مدبرين﴾</span></span>: الفاء عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿تولوا﴾</span></span> فعل ماض، والواو فاعل، و<span class="hlt"><span class="qpc-hafs">﴿عنه﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تولوا﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿مدبرين﴾</span></span> حال من الواو في <span class="hlt"><span class="qpc-hafs">﴿تولوا﴾</span></span>.</p></div>"
  37,91,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فراغ إلى آلهتهم فقال ألا تأكلون﴾</span></span>: الفاء عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿راغ﴾</span></span> فعل ماض، والفاعل مستتر، و<span class="hlt"><span class="qpc-hafs">﴿إلى آلهتهم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿راغ﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿فقال﴾</span></span> عطف على <span class="hlt"><span class="qpc-hafs">﴿راغ﴾</span></span>، والهمزة للاستفهام، ولا نافية، و<span class="hlt"><span class="qpc-hafs">﴿تأكلون﴾</span></span> فعل مضارع مرفوع، والواو فاعل، وجملة الاستفهام مقول القول.</p></div>"
  37,92,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ما لكم لا تنطقون﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> اسم استفهام مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿لكم﴾</span></span> جار ومجرور متعلقان بمحذوف خبر، و<span class="hlt"><span class="qpc-hafs">﴿لا﴾</span></span> نافية، و<span class="hlt"><span class="qpc-hafs">﴿تنطقون﴾</span></span> فعل مضارع مرفوع، والواو فاعل، وجملة <span class="hlt"><span class="qpc-hafs">﴿لا تنطقون﴾</span></span> في محل نصب على الحال، وجملة <span class="hlt"><span class="qpc-hafs">﴿ما لكم﴾</span></span> مقول قول محذوف، والتقدير: فلم ينطقوا فقال: ما لكم لا تنطقون.</p></div>"
  37,93,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فراغ عليهم ضربا باليمين﴾</span></span>: الفاء عاطفة على محذوف تقديره: فلم يجيبوا فراغ، و<span class="hlt"><span class="qpc-hafs">﴿عليهم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿راغ﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿ضربًا﴾</span></span> مصدر واقع موقع الحال، أي: فراغ عليهم ضاربًا، أو مفعول مطلق لفعل مقدر، أي: يضرب ضربًا، وجملة <span class="hlt"><span class="qpc-hafs">﴿يضرب ضربًا﴾</span></span> في محل نصب على الحال، و<span class="hlt"><span class="qpc-hafs">﴿باليمين﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿ضربًا﴾</span></span> أو بعامله.</p></div>"
  37,94,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فأقبلوا إليه يزفون﴾</span></span>: الفاء عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿أقبلوا﴾</span></span> فعل ماض، والواو فاعل، و<span class="hlt"><span class="qpc-hafs">﴿إليه﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أقبلوا﴾</span></span>، أو بـ<span class="hlt"><span class="qpc-hafs">﴿يزفون﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿يزفون﴾</span></span> في محل نصب على الحال من فاعل <span class="hlt"><span class="qpc-hafs">﴿أقبلوا﴾</span></span>.</p></div>"
  37,95,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قال أتعبدون ما تنحتون﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿قال﴾</span></span> فعل ماض، وفاعله مستتر تقديره: هو، والهمزة للاستفهام الإنكاري التوبيخي، و<span class="hlt"><span class="qpc-hafs">﴿تعبدون﴾</span></span> فعل مضارع مرفوع، والواو فاعل، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> مفعول به، وجملة <span class="hlt"><span class="qpc-hafs">﴿تنحتون﴾</span></span> صلة الموصول لا محل لها من الإعراب. والعائد محذوف، أو <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> مصدرية، أي: نحتكم، أو نكرة موصوفة، أي: منحوتكم، وقيل: استفهامية للتوبيخ، أي: وأي شيء تعملون؟</p></div>"
  37,96,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿والله خلقكم﴾</span></span>: الواو حالية، أو استئنافية، و<span class="hlt"><span class="qpc-hafs">﴿الله﴾</span></span> مبتدأ، وجملة <span class="hlt"><span class="qpc-hafs">﴿خلقكم﴾</span></span> خبر، وهي فعل ماض، والفاعل مستتر، والكاف مفعول به. وجملة <span class="hlt"><span class="qpc-hafs">﴿والله خلقكم﴾</span></span> في محل نصب حال، أو مستأنفة لا محل لها من الإعراب.</p><p><span class="hlt"><span class="qpc-hafs">﴿وما تعملون﴾</span></span>: الواو عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> موصولة، أو مصدرية، وقيل: هي استفهامية للتوبيخ، أي: وأي شيء تعملون؟ وقيل: هي نافية، أي: العمل في الحقيقة ليس لكم فأنتم لا تعملون شيئًا، و<span class="hlt"><span class="qpc-hafs">﴿تعملون﴾</span></span> فعل مضارع مرفوع، والواو فاعل.</p></div>"
  37,97,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قالوا ابنوا له بنيانا فألقوه في الجحيم﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿قالوا﴾</span></span> فعل ماض، والواو فاعل، و<span class="hlt"><span class="qpc-hafs">﴿ابنوا﴾</span></span> فعل أمر، والواو فاعل، والجملة مقول القول، و<span class="hlt"><span class="qpc-hafs">﴿له﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿ابنوا﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿بنيانًا﴾</span></span> مفعول به، <span class="hlt"><span class="qpc-hafs">﴿فألقوه﴾</span></span> عطف على <span class="hlt"><span class="qpc-hafs">﴿ابنوا﴾</span></span>، وهو فعل أمر، والواو فاعل، والهاء مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿في الجحيم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿ألقوه﴾</span></span>.</p></div>"
  37,98,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فأرادوا به كيدا فجعلناهم الأسفلين﴾</span></span>: الفاء عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿أرادوا﴾</span></span> فعل ماض، والواو فاعل، و<span class="hlt"><span class="qpc-hafs">﴿به﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أرادوا﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿كيدًا﴾</span></span> مفعول به، <span class="hlt"><span class="qpc-hafs">﴿فجعلناهم﴾</span></span> عطف على <span class="hlt"><span class="qpc-hafs">﴿فأرادوا﴾</span></span>، وهو فعل ماض، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> فاعل، و<span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> مفعول به أول، و<span class="hlt"><span class="qpc-hafs">﴿الأسفلين﴾</span></span> مفعول به ثان.</p></div>"
  37,99,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وقال إني ذاهب إلى ربي سيهدين﴾</span></span>: الواو عاطفة على محذوف تقديره: فخرج من النار سالمًا، وقال...، و<span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span> حرف ناسخ، والياء اسمها، و<span class="hlt"><span class="qpc-hafs">﴿ذاهب﴾</span></span> خبرها، و<span class="hlt"><span class="qpc-hafs">﴿إلى ربي﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿ذاهب﴾</span></span>، والسين حرف استقبال، و<span class="hlt"><span class="qpc-hafs">﴿يهدين﴾</span></span> فعل مضارع مرفوع بضمة مقدرة على الياء، والنون للوقاية، وياء الضمير المحذوفة لرعاية الفواصل مفعول به، أي: سيهديني.</p></div>"
  37,100,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿رب هب لي من الصالحين﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿رب﴾</span></span> منادى مضاف إلى ياء المتكلم المحذوفة، و<span class="hlt"><span class="qpc-hafs">﴿هب﴾</span></span> فعل دعاء مبني على السكون، وفاعله ضمير مستتر تقديره: أنت، و<span class="hlt"><span class="qpc-hafs">﴿لي﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿هب﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿من الصالحين﴾</span></span> جار ومجرور متعلقان بمحذوف صفة لمفعول به محذوف، أي: ولدًا من الصالحين.</p></div>"
  37,101,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فبشرناه بغلام حليم﴾</span></span>: الفاء عاطفة على محذوف تقديره: فاستجبنا له، و<span class="hlt"><span class="qpc-hafs">﴿بشرناه﴾</span></span> فعل ماض، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> فاعل، والهاء مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿بغلام﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿بشرناه﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿حليم﴾</span></span> صفة.</p></div>"
  37,102,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فلما بلغ معه السعي﴾</span></span>: الفاء استئنافية، و<span class="hlt"><span class="qpc-hafs">﴿لما﴾</span></span> حينية، أو رابطة، و<span class="hlt"><span class="qpc-hafs">﴿بلغ﴾</span></span> فعل ماض، وفاعله مستتر تقديره: هو، و<span class="hlt"><span class="qpc-hafs">﴿معه﴾</span></span> ظرف متعلق بمحذوف حال، و<span class="hlt"><span class="qpc-hafs">﴿السعي﴾</span></span> مفعول به.</p><p><span class="hlt"><span class="qpc-hafs">﴿قال يا بني إني أرى في المنام﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿قال﴾</span></span> فعل ماض، والفاعل مستتر، وجملة <span class="hlt"><span class="qpc-hafs">﴿قال﴾</span></span> لا محل لها من الإعراب، لأنها جواب <span class="hlt"><span class="qpc-hafs">﴿لما﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿يا﴾</span></span> حرف نداء، و<span class="hlt"><span class="qpc-hafs">﴿بني﴾</span></span> منادى مضاف لياء المتكلم، و<span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span> حرف ناسخ، والياء اسمها، وأرى فعل مضارع، والفاعل مستتر، وجملة <span class="hlt"><span class="qpc-hafs">﴿أرى﴾</span></span> خبر <span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿في المنام﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أرى﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿أني أذبحك فانظر ماذا ترى﴾</span></span>: أن حرف ناسخ، والياء اسمها، و<span class="hlt"><span class="qpc-hafs">﴿أذبحك﴾</span></span> فعل مضارع، والفاعل مستتر، والكاف مفعول به، وجملة <span class="hlt"><span class="qpc-hafs">﴿أذبحك﴾</span></span> خبر أن، و<span class="hlt"><span class="qpc-hafs">﴿أني أذبحك﴾</span></span> سدت مسد مفعول <span class="hlt"><span class="qpc-hafs">﴿أرى﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿فانظر﴾</span></span> الفاء الفصيحة، و<span class="hlt"><span class="qpc-hafs">﴿انظر﴾</span></span> فعل أمر مبني على السكون، وفاعله مستتر وجوبًا تقديره: أنت، و<span class="hlt"><span class="qpc-hafs">﴿ماذا﴾</span></span> استفهامية منصوبة بـ<span class="hlt"><span class="qpc-hafs">﴿ترى﴾</span></span>، أو <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> استفهامية مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿ذا﴾</span></span> موصولة خبر، أو <span class="hlt"><span class="qpc-hafs">﴿ماذا﴾</span></span> بمعنى الذي، فهي معمول لـ<span class="hlt"><span class="qpc-hafs">﴿انظر﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿ترى﴾</span></span> فعل مضارع مرفوع. وجملة <span class="hlt"><span class="qpc-hafs">﴿فلما بلغ معه...﴾</span></span> مستأنفة لا محل لها من الإعراب.</p><p><span class="hlt"><span class="qpc-hafs">﴿قال يا أبت افعل ما تؤمر ستجدني إن شاء الله من الصابرين﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿يا﴾</span></span> حرف نداء، و<span class="hlt"><span class="qpc-hafs">﴿أبت﴾</span></span> منادى مضاف إلى ياء المتكلم المعوض عنها بالتاء، والتاء في محل جر، لأن المعوض عنه كذلك، و<span class="hlt"><span class="qpc-hafs">﴿افعل﴾</span></span> فعل أمر، وفاعله مستتر تقديره: أنت، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> اسم موصول مفعول <span class="hlt"><span class="qpc-hafs">﴿افعل﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿تؤمر﴾</span></span> صلة الموصول لا محل لها من الإعراب. والعائد محذوف تقديره: ما تؤمر به، أو <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> مصدرية، أي: أمرك، على إضافة المصدر للمفعول، والسين حرف استقبال، و<span class="hlt"><span class="qpc-hafs">﴿تجدني﴾</span></span> فعل مضارع مرفوع، والنون للوقاية، والفاعل ضمير مستتر تقديره: أنت، والياء مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿من الصابرين﴾</span></span> جار ومجرور متعلقان بمحذوف مفعول ثان.</p></div>"