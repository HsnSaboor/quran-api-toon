quran[28]{c,v,t}:
  69,35,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فليس﴾</span></span>: الفاء الفصيحة، وليس فعل ماضٍ ناقص.</p><p><span class="hlt"><span class="qpc-hafs">﴿له﴾</span></span>: جار ومجرور متعلقان بمحذوف خبر مقدم.</p><p><span class="hlt"><span class="qpc-hafs">﴿اليوم﴾</span></span>: ظرف متعلق بمحذوف حال، أو متعلق بما في الخبر من معنى الاستقرار.</p><p><span class="hlt"><span class="qpc-hafs">﴿ههنا﴾</span></span>: ها للتنبيه، وهنا اسم إشارة في محل نصب على الظرفية متعلق بما تعلق به اليوم أيضًا.</p><p><span class="hlt"><span class="qpc-hafs">﴿حميم﴾</span></span>: اسم ليس.</p></div>"
  69,36,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ولا﴾</span></span>: الواو حرف عطف، ولا نافية.</p><p><span class="hlt"><span class="qpc-hafs">﴿طعام﴾</span></span>: عطف على حميم.</p><p><span class="hlt"><span class="qpc-hafs">﴿إلا﴾</span></span>: أداة حصر.</p><p><span class="hlt"><span class="qpc-hafs">﴿من غسلين﴾</span></span>: جار ومجرور متعلقان بمحذوف نعت لـ<span class="hlt"><span class="qpc-hafs">﴿طعام﴾</span></span>.</p></div>"
  69,37,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿لا﴾</span></span>: نافية.</p><p><span class="hlt"><span class="qpc-hafs">﴿يأكله﴾</span></span>: فعل مضارع، والهاء مفعول به مقدم.</p><p><span class="hlt"><span class="qpc-hafs">﴿إلا﴾</span></span>: أداة حصر.</p><p><span class="hlt"><span class="qpc-hafs">﴿الخاطئون﴾</span></span>: فاعل ليأكله مرفوع بالواو.</p></div>"
  69,38,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فلا﴾</span></span>: الفاء استئنافية، ولا صلة.</p><p><span class="hlt"><span class="qpc-hafs">﴿أُقسم﴾</span></span>: فعل مضارع، وفاعله مستتر تقديره: أنا.</p><p><span class="hlt"><span class="qpc-hafs">﴿بما﴾</span></span>: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أقسم﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿تبصرون﴾</span></span>: فعل مضارع مرفوع بثبوت النون، والواو فاعل، وجملة <span class="hlt"><span class="qpc-hafs">﴿تبصرون﴾</span></span> صلة الموصول لا محل لها من الإعراب. وجملة <span class="hlt"><span class="qpc-hafs">﴿فلا أقسم﴾</span></span> مستأنفة لا محل لها من الإعراب.</p></div>"
  69,39,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وما﴾</span></span>: الواو عاطفة، وما موصولة معطوفة على <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> السابقة في محل جر.</p><p><span class="hlt"><span class="qpc-hafs">﴿لا﴾</span></span>: نافية.</p><p><span class="hlt"><span class="qpc-hafs">﴿تبصرون﴾</span></span>: فعل مضارع، والواو فاعل، وجملة <span class="hlt"><span class="qpc-hafs">﴿لا تبصرون﴾</span></span> صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> لا محل لها من الإعراب.</p></div>"
  69,40,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إنه﴾</span></span>: إن حرف ناسخ، والهاء اسمها.</p><p><span class="hlt"><span class="qpc-hafs">﴿لقول﴾</span></span>: اللام المزحلقة، وقول خبر إن.</p><p><span class="hlt"><span class="qpc-hafs">﴿رسول﴾</span></span>: مضاف إليه.</p><p><span class="hlt"><span class="qpc-hafs">﴿كريم﴾</span></span>: صفة لـ<span class="hlt"><span class="qpc-hafs">﴿رسول﴾</span></span>، والجملة لا محل لها من الإعراب، لأنها جواب القسم.</p></div>"
  69,41,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وما﴾</span></span>: الواو عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> نافية حجازية تعمل عمل ليس.</p><p><span class="hlt"><span class="qpc-hafs">﴿هو﴾</span></span>: اسم ما.</p><p><span class="hlt"><span class="qpc-hafs">﴿بقول﴾</span></span>: الباء: حرف جر صلة، و<span class="hlt"><span class="qpc-hafs">﴿قول﴾</span></span> خبر <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> الحجازية منصوب محلا مجرور بالباء لفظًا.</p><p><span class="hlt"><span class="qpc-hafs">﴿شاعر﴾</span></span>: مضاف إليه.</p><p><span class="hlt"><span class="qpc-hafs">﴿قليلا﴾</span></span>: نائب عن المفعول المطلق، لأنه صفة المصدر المحذوف، أي: تؤمنون إيمانا قليلا.</p><p><span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span>: صلة لتأكيد القلة.</p><p><span class="hlt"><span class="qpc-hafs">﴿تؤمنون﴾</span></span>: فعل وفاعل. وجملة <span class="hlt"><span class="qpc-hafs">﴿تؤمنون﴾</span></span> اعتراضية لا محل لها من الإعراب.</p></div>"
  69,42,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ولا﴾</span></span>: الواو عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿لا﴾</span></span> صلة لتأكيد النفي.</p><p><span class="hlt"><span class="qpc-hafs">﴿بقول كاهن﴾</span></span>: معطوف على <span class="hlt"><span class="qpc-hafs">﴿بقول شاعر﴾</span></span>، وكاهن: مضاف إليه.</p><p><span class="hlt"><span class="qpc-hafs">﴿قليلا﴾</span></span>: نائب عن المفعول المطلق، لأنه صفة المصدر المحذوف، أي: تتذكرون تذكرًا قليلا.</p><p><span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span>: صلة لتأكيد القلة.</p><p><span class="hlt"><span class="qpc-hafs">﴿تذكرون﴾</span></span>: فعل وفاعل. وجملة <span class="hlt"><span class="qpc-hafs">﴿تذكرون﴾</span></span> اعتراضية لا محل لها من الإعراب.</p></div>"
  69,43,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿تنزيل﴾</span></span>: خبر لمبتدأ محذوف، أي: هو تنزيل.</p><p><span class="hlt"><span class="qpc-hafs">﴿من رب﴾</span></span>: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تنزيل﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿العالمين﴾</span></span>: مضاف إليه.</p></div>"
  69,44,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ولو﴾</span></span>: الواو عاطفة، ولو شرطية.</p><p><span class="hlt"><span class="qpc-hafs">﴿تقوَّل﴾</span></span>: فعل ماضٍ، وفاعله مستتر.</p><p><span class="hlt"><span class="qpc-hafs">﴿علينا﴾</span></span>: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تقول﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿بعض﴾</span></span>: نائب عن المفعول المطلق.</p><p><span class="hlt"><span class="qpc-hafs">﴿الأقاويل﴾</span></span>: مضاف إليه.</p></div>"
  69,45,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿لأخذنا﴾</span></span>: اللام واقعة في جواب <span class="hlt"><span class="qpc-hafs">﴿لو﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿أخذنا﴾</span></span> فعل ماض، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> فاعل.</p><p><span class="hlt"><span class="qpc-hafs">﴿منه﴾</span></span>: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أخذ﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿باليمين﴾</span></span>: جار ومجرور متعلقان بمحذوف حال، والجملة لا محل لها من الإعراب، جواب شرط غير جازم.</p></div>"
  69,46,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ثم﴾</span></span>: حرف عطف للترتيب مع التراخي.</p><p><span class="hlt"><span class="qpc-hafs">﴿لقطعنا﴾</span></span>: عطف على لـ<span class="hlt"><span class="qpc-hafs">﴿أخذنا﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿منه﴾</span></span>: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿قطعنا﴾</span></span>، أو بمحذوف حال.</p><p><span class="hlt"><span class="qpc-hafs">﴿الوتين﴾</span></span>: مفعول به منصوب وعلامة نصبه الفتحة الظاهرة.</p></div>"
  69,47,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فما﴾</span></span>: الفاء عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> نافية حجازية تعمل عمل ليس.</p><p><span class="hlt"><span class="qpc-hafs">﴿منكم﴾</span></span>: جار ومجرور متعلقان بمحذوف حال من <span class="hlt"><span class="qpc-hafs">﴿أحد﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿من﴾</span></span>: حرف جر صلة.</p><p><span class="hlt"><span class="qpc-hafs">﴿أحد﴾</span></span>: اسم <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> مرفوع محلا مجرور بـ<span class="hlt"><span class="qpc-hafs">﴿من﴾</span></span> لفظًا.</p><p><span class="hlt"><span class="qpc-hafs">﴿عنه﴾</span></span>: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿حاجزين﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿حاجزين﴾</span></span>: خبر <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> الحجازية منصوب.</p></div>"
  69,48,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وإنه﴾</span></span>: الواو عاطفة، وإن حرف ناسخ، والهاء ضمير مبني في محل نصب اسم إن، والكلام معطوف على جواب القسم السابق، فهو من جملة المقسوم به.</p><p><span class="hlt"><span class="qpc-hafs">﴿لتذكرة﴾</span></span>: اللام: المزحلقة، وتذكرة خبر إن.</p><p><span class="hlt"><span class="qpc-hafs">﴿للمتقين﴾</span></span>: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تذكرة﴾</span></span>.</p></div>"
  69,49,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وإنا﴾</span></span>: عطف أيضًا، وإن و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> اسم إن.</p><p><span class="hlt"><span class="qpc-hafs">﴿لنعلم﴾</span></span>: اللام المزحلقة، ونعلم فعل مضارع والفاعل مستتر، وجملة نعلم خبر إن.</p><p><span class="hlt"><span class="qpc-hafs">﴿أن﴾</span></span>: حرف ناسخ ينصب الاسم ويرفع الخبر، وأن وما بعدها سدت مسد مفعولي نعلم.</p><p><span class="hlt"><span class="qpc-hafs">﴿منكم﴾</span></span>: جار ومجرور متعلقان بمحذوف خبر أن المقدم.</p><p><span class="hlt"><span class="qpc-hafs">﴿مكذبين﴾</span></span>: اسم أن المؤخر.</p></div>"
  69,50,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وإنه﴾</span></span>: الواو عاطفة، وإن حرف ناسخ، والهاء ضمير مبني في محل نصب اسم إن.</p><p><span class="hlt"><span class="qpc-hafs">﴿لحسرة﴾</span></span>: اللام: المزحلقة، وحسرة خبر إن.</p><p><span class="hlt"><span class="qpc-hafs">﴿على الكافرين﴾</span></span>: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تذكرة﴾</span></span>، أو نعت لـ<span class="hlt"><span class="qpc-hafs">﴿حسرة﴾</span></span>.</p></div>"
  69,51,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وإنه﴾</span></span>: الواو عاطفة، وإن حرف ناسخ، والهاء ضمير مبني في محل نصب اسم إن.</p><p><span class="hlt"><span class="qpc-hafs">﴿لحق﴾</span></span>: اللام: المزحلقة، وحق خبر إن.</p><p><span class="hlt"><span class="qpc-hafs">﴿اليقين﴾</span></span>: مضاف إليه.</p></div>"
  69,52,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فسبح﴾</span></span>: الفاء الفصيحة، وسبّح فعل أمر.</p><p><span class="hlt"><span class="qpc-hafs">﴿باسم﴾</span></span>: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿سبح﴾</span></span>، أو الباء صلة.</p><p><span class="hlt"><span class="qpc-hafs">﴿ربك﴾</span></span>: مضاف إليه.</p><p><span class="hlt"><span class="qpc-hafs">﴿العظيم﴾</span></span>: نعت لـ<span class="hlt"><span class="qpc-hafs">﴿ربك﴾</span></span>.</p></div>"
  70,1,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿سأل﴾</span></span>: فعل ماضٍ مبني على الفتح، متضمن معنى دعا، ولذلك عدّي تعديته.</p><p><span class="hlt"><span class="qpc-hafs">﴿سائل﴾</span></span>: فاعل مرفوع.</p><p><span class="hlt"><span class="qpc-hafs">﴿بعذاب﴾</span></span>: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿سأل﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿واقع﴾</span></span>: نعت مجرور.</p></div>"
  70,2,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿للكافرين﴾</span></span>: الجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿واقع﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿ليس﴾</span></span>: فعل ماضٍ ناقص.</p><p><span class="hlt"><span class="qpc-hafs">﴿له﴾</span></span>: جار ومجرور متعلقان بمحذوف خبر ليس المقدم.</p><p><span class="hlt"><span class="qpc-hafs">﴿دافع﴾</span></span>: اسم ليس المؤخر، وجملة <span class="hlt"><span class="qpc-hafs">﴿ليس له دافع﴾</span></span> في محل جر نعت لـ<span class="hlt"><span class="qpc-hafs">﴿عذاب﴾</span></span>.</p></div>"
  70,3,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿من الله﴾</span></span>: من حرف جر ولفظ الجلالة اسم مجرور والجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿واقع﴾</span></span>، أو متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿دافع﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿ذي﴾</span></span>: نعت للفظ الجلالة مجرور بالياء، لأنه اسم من الأسماء الخمسة.</p><p><span class="hlt"><span class="qpc-hafs">﴿المعارج﴾</span></span>: مضاف إليه.</p></div>"
  70,4,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿تعرج﴾</span></span>: كلام مستأنف لا محل له من الإعراب، وتعرج فعل مضارع مرفوع.</p><p><span class="hlt"><span class="qpc-hafs">﴿الملائكة﴾</span></span>: فاعل مرفوع.</p><p><span class="hlt"><span class="qpc-hafs">﴿والروح﴾</span></span>: عطف على الملائكة.</p><p><span class="hlt"><span class="qpc-hafs">﴿إليه﴾</span></span>: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تعرج﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿في يوم﴾</span></span>: جار ومجرور متعلقان بمحذوف دلّ عليه واقع، أي: يقع العذاب بهم في يوم القيامة.</p><p><span class="hlt"><span class="qpc-hafs">﴿كان﴾</span></span>: فعل ماض ناقص.</p><p><span class="hlt"><span class="qpc-hafs">﴿مقداره﴾</span></span>: اسم كان، والهاء مضاف إليه.</p><p><span class="hlt"><span class="qpc-hafs">﴿خمسين﴾</span></span>: خبر كان منصوب بالياء، لأنه ملحق بجمع المذكر السالم.</p><p><span class="hlt"><span class="qpc-hafs">﴿ألف﴾</span></span>: تمييز خمسين.</p><p><span class="hlt"><span class="qpc-hafs">﴿سنة﴾</span></span>: مضاف إليه.</p></div>"
  70,5,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فاصبر﴾</span></span>: الفاء الفصيحة، واصبر فعل أمر، وفاعله مستتر تقديره: أنت.</p><p><span class="hlt"><span class="qpc-hafs">﴿صبرًا﴾</span></span>: مفعول مطلق.</p><p><span class="hlt"><span class="qpc-hafs">﴿جميلا﴾</span></span>: نعت.</p></div>"
  70,6,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إنهم﴾</span></span>: إن حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> اسمها.</p><p><span class="hlt"><span class="qpc-hafs">﴿يرونه﴾</span></span>: فعل مضارع مرفوع بثبوت النون، والواو فاعل، وجملة يرونه خبر إن.</p><p><span class="hlt"><span class="qpc-hafs">﴿بعيدًا﴾</span></span>: مفعول به ثانٍ، لأن الرؤية علمية، والجملة تعليلية لا محل لها من الإعراب.</p></div>"
  70,7,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ونراه﴾</span></span>: الواو عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿نراه﴾</span></span> فعل مضارع مرفوع بالضمة المقدرة على الألف للتعذر، والفاعل مستتر، والهاء مفعول به.</p><p><span class="hlt"><span class="qpc-hafs">﴿قريبًا﴾</span></span>: مفعول به ثانٍ، لأن الرؤية علمية.</p></div>"
  70,8,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿يوم﴾</span></span>: ظرف زمان منصوب متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿قريبًا﴾</span></span>، أو بمحذوف يدل عليه <span class="hlt"><span class="qpc-hafs">﴿واقع﴾</span></span>، أي: يقع يوم تكون.</p><p><span class="hlt"><span class="qpc-hafs">﴿تكون﴾</span></span>: فعل مضارع ناقص مرفوع، وجملة <span class="hlt"><span class="qpc-hafs">﴿تكون﴾</span></span> في محل جر بإضافة الظرف إليها.</p><p><span class="hlt"><span class="qpc-hafs">﴿السماء﴾</span></span>: اسم تكون مرفوع.</p><p><span class="hlt"><span class="qpc-hafs">﴿كالمهل﴾</span></span>: الكاف اسم بمعنى مثل مبني على الفتح في محل نصب خبر تكون، و<span class="hlt"><span class="qpc-hafs">﴿المهل﴾</span></span> مضاف إليه.</p></div>"
  70,9,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وتكون﴾</span></span>: الواو عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿تكون﴾</span></span> فعل مضارع ناقص مرفوع، وجملة <span class="hlt"><span class="qpc-hafs">﴿تكون﴾</span></span> في محل جر عطفًا على الجملة السابقة.</p><p><span class="hlt"><span class="qpc-hafs">﴿الجبال﴾</span></span>: اسم <span class="hlt"><span class="qpc-hafs">﴿تكون﴾</span></span> مرفوع.</p><p><span class="hlt"><span class="qpc-hafs">﴿كالعهن﴾</span></span>: الكاف اسم بمعنى مثل مبني على الفتح في محل نصب خبر <span class="hlt"><span class="qpc-hafs">﴿تكون﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿العهن﴾</span></span> مضاف إليه.</p></div>"
  70,10,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ولا﴾</span></span>: الواو عاطفة، ولا نافية.</p><p><span class="hlt"><span class="qpc-hafs">﴿يسأل﴾</span></span>: فعل مضارع مرفوع.</p><p><span class="hlt"><span class="qpc-hafs">﴿حميم﴾</span></span>: فاعل مرفوع بالضمة.</p><p><span class="hlt"><span class="qpc-hafs">﴿حميما﴾</span></span>: مفعول يسأل الأول، والمفعول الثاني محذوف، والتقدير: شفاعته، ونصره، وقيل: حميما منصوب بنزع الخافض، ويسأل لا حاجة لها إلى مفعول.</p></div>"