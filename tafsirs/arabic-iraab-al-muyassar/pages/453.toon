quran[16]{c,v,t}:
  38,1,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ص﴾</span></span>: تقدم الكلام على الحروف المقطعة في أول سورة البقرة.</p><p><span class="hlt"><span class="qpc-hafs">﴿والقرآن ذي الذكر﴾</span></span>: الواو: حرف قسم، والقرآن: مجرور بواو القسم، والجار والمجرور متعلقان بفعل القسم المحذوف، وجواب القسم محذوف على الأرجح تقديره: <span class="hlt"><span class="qpc-hafs">﴿إنه لمعجز﴾</span></span> أو <span class="hlt"><span class="qpc-hafs">﴿لقد جاءكم الحق﴾</span></span>، وذي: نعت للقرآن، والذكر: مضاف إليه.</p></div>"
  38,2,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿بل الذين كفروا في عزة وشقاق﴾</span></span>: بل: حرف عطف وإضراب انتقالي، والذين: اسم موصول مبني في محل رفع مبتدأ، وجملة <span class="hlt"><span class="qpc-hafs">﴿كفروا﴾</span></span>: صلة الموصول لا محل لها من الإعراب. وكفر: فعل ماض، والواو: فاعل، و<span class="hlt"><span class="qpc-hafs">﴿في عزة﴾</span></span>: جار ومجرور متعلقان بمحذوف خبر، <span class="hlt"><span class="qpc-hafs">﴿وشقاق﴾</span></span>: عطف على عزة.</p></div>"
  38,3,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿كم أهلكنا من قبلهم من قرن فنادوا ولات حين مناص﴾</span></span>: كم: خبرية في محل نصب مفعول مقدم لـ<span class="hlt"><span class="qpc-hafs">﴿أهلكنا﴾</span></span>، وأهلكنا: فعل، وفاعل، و<span class="hlt"><span class="qpc-hafs">﴿من قبلهم﴾</span></span>: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أهلكنا﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿من قرن﴾</span></span>: تمييز كم الخبرية. <span class="hlt"><span class="qpc-hafs">﴿فنادوا﴾</span></span>: الفاء عاطفة، ونادوا: فعل ماض، والواو: فاعل. <span class="hlt"><span class="qpc-hafs">﴿ولات﴾</span></span>: الواو حالية، و<span class="hlt"><span class="qpc-hafs">﴿لات﴾</span></span>: حرف مشبه بـ<span class="hlt"><span class="qpc-hafs">﴿ليس﴾</span></span>، واسمها محذوف تقديره: <span class="hlt"><span class="qpc-hafs">﴿الحين﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿حين﴾</span></span>: خبرها، و<span class="hlt"><span class="qpc-hafs">﴿مناص﴾</span></span>: مضاف إليه.</p></div>"
  38,4,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وعجبوا أن جاءهم منذر منهم وقال الكافرون هذا ساحر كذاب﴾</span></span>: الواو عاطفة، وعجبوا: فعل ماض، والواو فاعل، وأن: مصدرية، وهي مع ما في حيزها مصدر منصوب بنزع الخافض، أي: عجبوا من مجيء منذر، و<span class="hlt"><span class="qpc-hafs">﴿منذر﴾</span></span>: فاعل مؤخر، و<span class="hlt"><span class="qpc-hafs">﴿منهم﴾</span></span>: جار ومجرور متعلقان بمحذوف نعت لمنذر، والواو: حرف عطف، و<span class="hlt"><span class="qpc-hafs">﴿قال الكافرون﴾</span></span>: فعل، وفاعل، و<span class="hlt"><span class="qpc-hafs">﴿هذا﴾</span></span>: مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿ساحر﴾</span></span>: خبر، و<span class="hlt"><span class="qpc-hafs">﴿كذاب﴾</span></span>: نعت لساحر.</p></div>"
  38,5,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿أجعل الآلهة إلها واحدا إن هذا لشيء عجاب﴾</span></span>: الهمزة للاستفهام، وجعل: فعل ماض، وفاعله مستتر تقديره هو، والآلهة: مفعول به أول، و<span class="hlt"><span class="qpc-hafs">﴿إلهًا﴾</span></span>: مفعول به ثان، و<span class="hlt"><span class="qpc-hafs">﴿واحدًا﴾</span></span>: صفة، و<span class="hlt"><span class="qpc-hafs">﴿إن هذا لشيء﴾</span></span>: إن حرف ناسخ، وهذا اسمها، واللام المزحلقة، و<span class="hlt"><span class="qpc-hafs">﴿شيء﴾</span></span>: خبرها، و<span class="hlt"><span class="qpc-hafs">﴿عجاب﴾</span></span>: صفة لشيء.</p></div>"
  38,6,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وانطلق الملأ منهم أن امشوا واصبروا على آلهتكم﴾</span></span>: الواو: عاطفة. والجملة بعدها معطوفة على <span class="hlt"><span class="qpc-hafs">﴿قال الكافرون﴾</span></span>. و<span class="hlt"><span class="qpc-hafs">﴿انطلق الملأ﴾</span></span>: فعل ماض، وفاعل. و<span class="hlt"><span class="qpc-hafs">﴿منهم﴾</span></span>: جار ومجرور متعلقان بمحذوف حال. و<span class="hlt"><span class="qpc-hafs">﴿أن﴾</span></span>: تفسيرية، والجملة بعدها تفسيرية لـ<span class="hlt"><span class="qpc-hafs">﴿انطلق﴾</span></span>، لأنه متضمن معنى القول، لا محل لها من الإعراب. <span class="hlt"><span class="qpc-hafs">﴿واصبروا﴾</span></span> عطف على امشوا. و<span class="hlt"><span class="qpc-hafs">﴿على آلهتكم﴾</span></span>: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿اصبروا﴾</span></span> على حذف مضاف، أي: على عبادتها.</p><p><span class="hlt"><span class="qpc-hafs">﴿إن هذا لشيء يراد﴾</span></span>: الجملة تعليل للأمر بالصبر، وإن حرف ناسخ، وهذا اسمها، واللام المزحلقة، وشيء: خبرها، وجملة <span class="hlt"><span class="qpc-hafs">﴿يراد﴾</span></span> صفة لشيء.</p></div>"
  38,7,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ما سمعنا بهذا في الملة الآخرة إن هذا إلا اختلاق﴾</span></span>: ما: نافية، وسمعنا: فعل، وفاعل، و<span class="hlt"><span class="qpc-hafs">﴿بهذا﴾</span></span>: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿سمعنا﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿في الملة﴾</span></span>: جار ومجرور متعلقان بمحذوف حال من هذا، والآخرة: نعت، وإن: نافية، وهذا: مبتدأ، وإلا: أداة حصر، واختلاق: خبر هذا.</p></div>"
  38,8,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿أؤنزل عليه الذكر من بيننا﴾</span></span>: الهمزة للاستفهام، و<span class="hlt"><span class="qpc-hafs">﴿أنزل﴾</span></span>: فعل ماض مبني لما لم يسمَّ فاعله، و<span class="hlt"><span class="qpc-hafs">﴿عليه﴾</span></span>: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أنزل﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿الذكر﴾</span></span>: نائب فاعل، و<span class="hlt"><span class="qpc-hafs">﴿من بيننا﴾</span></span>: جار ومجرور متعلقان بمحذوف حال.</p><p><span class="hlt"><span class="qpc-hafs">﴿بل هم في شك من ذكري بل لما يذوقوا عذاب﴾</span></span>: بل: حرف إضراب انتقالي عن مقدر، فكأنه قال: <span class="hlt"><span class="qpc-hafs">﴿إنكارهم للذكر ليس عن علم، بل هم في شك منه﴾</span></span>. وهم: مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿في شك﴾</span></span>: جار ومجرور متعلقان بمحذوف خبر، و<span class="hlt"><span class="qpc-hafs">﴿من ذكري﴾</span></span>: جار ومجرور متعلقان بمحذوف نعت لـ<span class="hlt"><span class="qpc-hafs">﴿شك﴾</span></span>. و<span class="hlt"><span class="qpc-hafs">﴿بل﴾</span></span>: إضراب انتقالي أيضًا، و<span class="hlt"><span class="qpc-hafs">﴿لما﴾</span></span>: حرف نفي وجزم، ويذوقوا: فعل مضارع مجزوم بـ<span class="hlt"><span class="qpc-hafs">﴿لما﴾</span></span>، والواو فاعل، وعذاب: مفعول به، وعلامة نصبه فتحة مقدرة على ما قبل ياء المتكلم المحذوفة لمراعاة الفواصل.</p></div>"
  38,9,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿أم عندهم خزائن رحمة ربك العزيز الوهاب﴾</span></span>: أم: حرف عطف بمعنى بل، فهي منقطعة بمعنى: بل وهمزة الاستفهام، والاستفهام للإنكار والتوبيخ، و<span class="hlt"><span class="qpc-hafs">﴿عندهم﴾</span></span> ظرف متعلق بمحذوف خبر مقدم، و<span class="hlt"><span class="qpc-hafs">﴿خزائن﴾</span></span>: مبتدأ مؤخر، و<span class="hlt"><span class="qpc-hafs">﴿رحمة﴾</span></span>: مضاف إليه، و<span class="hlt"><span class="qpc-hafs">﴿ربك﴾</span></span>: مضاف إليه، والكاف: ضمير مبني في محل جر مضاف إليه، و<span class="hlt"><span class="qpc-hafs">﴿العزيز الوهاب﴾</span></span>: صفتان لـ<span class="hlt"><span class="qpc-hafs">﴿ربك﴾</span></span>.</p></div>"
  38,10,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿أم لهم ملك السماوات والأرض وما بينهما﴾</span></span>: أم: حرف عطف بمعنى بل، و<span class="hlt"><span class="qpc-hafs">﴿لهم﴾</span></span>: جار ومجرور متعلقان بمحذوف خبر مقدم، و<span class="hlt"><span class="qpc-hafs">﴿ملك﴾</span></span>: مبتدأ مؤخر، و<span class="hlt"><span class="qpc-hafs">﴿السماوات﴾</span></span>: مضاف إليه، والأرض: معطوف مجرور، <span class="hlt"><span class="qpc-hafs">﴿وما﴾</span></span>: عطف على السماوات، و بينهما: ظرف متعلق بمحذوف صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span>، وجملة الصلة لا محل لها من الإعراب.</p><p><span class="hlt"><span class="qpc-hafs">﴿فليرتقوا في الأسباب﴾</span></span>: الفاء الفصيحة، واللام لام الأمر، ويرتقوا: فعل مضارع مجزوم بلام الأمر، و<span class="hlt"><span class="qpc-hafs">﴿في الأسباب﴾</span></span>: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يرتقوا﴾</span></span>.</p></div>"
  38,11,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿جند ما هنالك مهزوم من الأحزاب﴾</span></span>: جند: خبر لمبتدأ محذوف، أي: <span class="hlt"><span class="qpc-hafs">﴿هم جند﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span>: نكرة تامة نعت لـ<span class="hlt"><span class="qpc-hafs">﴿جند﴾</span></span> على سبيل التحقير، أي: هم جند حقير، أو أن <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> صلة. و<span class="hlt"><span class="qpc-hafs">﴿هنالك﴾</span></span>: اسم إشارة في محل نصب على الظرفية المكانية، متعلق بمحذوف نعت لـ<span class="hlt"><span class="qpc-hafs">﴿جند﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿مهزوم﴾</span></span>: نعت ثالث لجند. و<span class="hlt"><span class="qpc-hafs">﴿من الأحزاب﴾</span></span>: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿مهزوم﴾</span></span>، أو متعلقان بمحذوف نعت لـ<span class="hlt"><span class="qpc-hafs">﴿جند﴾</span></span>.</p></div>"
  38,12,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿كذبت قبلهم قوم نوح وعاد وفرعون ذو الأوتاد﴾</span></span>: كلام مستأنف لا محل له من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿كذبت﴾</span></span>: فعل ماض، و<span class="hlt"><span class="qpc-hafs">﴿قبلهم﴾</span></span>: ظرف متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿كذبت﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿قوم﴾</span></span>: فاعل، و<span class="hlt"><span class="qpc-hafs">﴿نوح﴾</span></span>: مضاف إليه، و<span class="hlt"><span class="qpc-hafs">﴿عاد﴾</span></span>: عطف على قوم نوح، و<span class="hlt"><span class="qpc-hafs">﴿فرعون﴾</span></span>: عطف أيضًا، و<span class="hlt"><span class="qpc-hafs">﴿ذو﴾</span></span>: نعت مرفوع بالواو، لأنه من الأسماء الستة، والأوتاد: مضاف إليه مجرور.</p></div>"
  38,13,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وثمود وقوم لوط وأصحاب الأيكة أولئك الأحزاب﴾</span></span>: الواو عاطفة،وثمود: معطوف مرفوع، <span class="hlt"><span class="qpc-hafs">﴿وقوم﴾</span></span>: عطف أيضا، و<span class="hlt"><span class="qpc-hafs">﴿لوط﴾</span></span>: مضاف إليه، <span class="hlt"><span class="qpc-hafs">﴿وأصحاب الأيكة﴾</span></span>: عطف أيضا، و<span class="hlt"><span class="qpc-hafs">﴿أولئك﴾</span></span>: اسم الإشارة مبتدأ، والأحزاب: خبر.</p></div>"
  38,14,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إن كل إلا كذب الرسل فحق عقاب﴾</span></span>: إن نافية لا عمل لها، وكل: مبتدأ، وإلا أداة حصر، وجملة <span class="hlt"><span class="qpc-hafs">﴿كذب الرسل﴾</span></span>: خبر كل، <span class="hlt"><span class="qpc-hafs">﴿فحق﴾</span></span>: الفاء حرف عطف، وحق فعل ماض، وعقاب: فاعله مرفوع، وعلامة رفعه الضمة المقدرة على ما قبل ياء المتكلم المحذوفة لمراعاة الفواصل.</p></div>"
  38,15,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وما ينظر هؤلاء إلا صيحة واحدة ما لها من فواق﴾</span></span>: الواو استئنافية، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span>: نافية، و<span class="hlt"><span class="qpc-hafs">﴿ينظر﴾</span></span>: فعل مضارع، و<span class="hlt"><span class="qpc-hafs">﴿هؤلاء﴾</span></span>: اسم إشارة مبني على الكسر في محل رفع فاعل، و<span class="hlt"><span class="qpc-hafs">﴿إلا﴾</span></span>: أداة حصر، و<span class="hlt"><span class="qpc-hafs">﴿صيحة﴾</span></span>: مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿واحدة﴾</span></span>: صفة لـ<span class="hlt"><span class="qpc-hafs">﴿صيحة﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿وما ينظر هؤلاء...﴾</span></span> مستأنفة لا محل لها من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span>: نافية، و<span class="hlt"><span class="qpc-hafs">﴿لها﴾</span></span>: جار ومجرور متعلقان بمحذوف خبر مقدم، و<span class="hlt"><span class="qpc-hafs">﴿من﴾</span></span>: حرف جر صلة، وفواق: اسم مجرور لفظًا مرفوع محلا على أنه مبتدأ مؤخر.</p></div>"
  38,16,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وقالوا ربنا عجل لنا قطنا قبل يوم الحساب﴾</span></span>: كلام مستأنف لا محل له من الإعراب، وقالوا: فعل وفاعل، وربنا: منادى مضاف محذوف منه حرف النداء، وعجل: فعل دعاء، وفاعله مستتر وجوبًا تقديره أنت، ولنا: جار ومجرور متعلقان به، وقطنا: مفعول به، وقبل: ظرف متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿عجل﴾</span></span> أيضًا، أو بمحذوف حال، ويوم: مضاف إليه وهو مضاف، والحساب: مضاف إليه.</p></div>"