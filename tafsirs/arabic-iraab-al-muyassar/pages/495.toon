quran[16]{c,v,t}:
  43,74,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إن المجرمين في عذاب جهنم خالدون﴾</span></span>: إن المجرمين: إن: حرف ناسخ، والمجرمين: اسم إن، وفي عذاب: جار ومجرور متعلقان بمحذوف خبر أول، أو متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿خالدون﴾</span></span>، وجهنم: مضاف إليه، وخالدون: خبر ثان.</p></div>"
  43,75,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿لا يفتر عنهم وهم فيه مبلسون﴾</span></span>: الجملة حالية، ولا: نافية، ويفتر: فعل مضارع مبني لما لم يسمَّ فاعله، ونائب فاعل مستتر تقديره: هو، أي: العذاب، وعنهم: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يفتر﴾</span></span>، والواو: للحال، وهم: مبتدأ، وفيه: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿مبلسون﴾</span></span>، ومبلسون: خبر <span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿وهم فيه مبلسون﴾</span></span> حال ثانية.</p></div>"
  43,76,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وما ظلمناهم ولكن كانوا هم الظالمين﴾</span></span>: الواو: عاطفة، وما: نافية، وظلمناهم: فعل ماض وفاعل ومفعول به، والواو: حالية، ولكن: مخففة مهملة، وكانوا: كان فعل ماض ناقص، وواو الجماعة اسمها، وهم: ضمير فصل لا محل له من الإعراب، أو هو توكيد للواو، والظالمين: خبر <span class="hlt"><span class="qpc-hafs">﴿كان﴾</span></span>.</p></div>"
  43,77,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ونادوا يا مالك ليقض علينا ربك﴾</span></span>: الواو: عاطفة، ونادوا: فعل ماض وفاعل، وعُبر بالماضي عن المضارع إيذانًا بحقيقة وقوعه، فهو من باب <span class="hlt"><span class="qpc-hafs">﴿أتى أمر الله﴾</span></span>، ويا: للنداء، ومالك: منادى مفرد علم مضموم في محل نصب، واللام: لام الطلب غرضها الدعاء، ويقض: فعل مضارع مجزوم بلام الطلب، وعلينا: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يقض﴾</span></span>، أي: ليمتنا، وربك: فاعل.</p><p><span class="hlt"><span class="qpc-hafs">﴿قال إنكم ماكثون﴾</span></span>: قال: فعل ماض، والفاعل ضمير مستتر تقديره هو، وإن:حرف ناسخ، والكاف: اسم إن، والميم: علامة الجمع، وماكثون: خبر إن، وجملة <span class="hlt"><span class="qpc-hafs">﴿إنكم ماكثون﴾</span></span> في موضع نصب مقول القول.</p></div>"
  43,78,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿لقد جئناكم بالحق ولكن أكثركم للحق كارهون﴾</span></span>: اللام: جواب للقسم المحذوف، وقد: حرف تحقيق، وجئناكم: فعل وفاعل ومفعول به، وبالحق: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿جئناكم﴾</span></span>، والواو: حالية، ولكن: حرف ناسخ، وأكثركم: اسم لكن، والكاف مضاف إليه، وللحق: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿كارهون﴾</span></span>، وكارهون: خبر لكن.</p></div>"
  43,79,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿أم أبرموا أمرا فإنا مبرمون﴾</span></span> أم: منقطعة بمعنى: بل وهمزة الاستفهام الإنكاري، وأبرموا: فعل ماض وفاعل، وأمرًا: مفعول به، والفاء: عاطفة، وإن: حرف ناسخ، ونا: اسم إن، ومبرمون: خبر إن.</p></div>"
  43,80,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿أم يحسبون أنا لا نسمع سرهم ونجواهم﴾</span></span>: أم: منقطعة بمعنى: بل وهمزة الاستفهام، ويحسبون: فعل مضارع مرفوع، والواو فاعل، وأن وما بعدها سدت مسد مفعولي يحسبون، وجملة <span class="hlt"><span class="qpc-hafs">﴿لا نسمع﴾</span></span> خبر <span class="hlt"><span class="qpc-hafs">﴿أنا﴾</span></span>، وسرهم: مفعول <span class="hlt"><span class="qpc-hafs">﴿نسمع﴾</span></span>، ونجواهم: عطف على <span class="hlt"><span class="qpc-hafs">﴿سرهم﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿بلى ورسلنا لديهم يكتبون﴾</span></span>: بلى: حرف جواب لإبطال النفي، أي: بلى نحن نسمع سرهم ونجواهم. والواو: للحال، ورسلنا: مبتدأ، ولديهم: ظرف متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿يكتبون﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿يكتبون﴾</span></span> خبر <span class="hlt"><span class="qpc-hafs">﴿رسلنا﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿ورسلنا...﴾</span></span> حالية.</p></div>"
  43,81,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قل إن كان للرحمن ولد فأنا أول العابدين﴾</span></span>: قل: فعل أمر، وفاعله مستتر تقديره أنت، وإن: شرطية، وكان: فعل ماض ناقص، وللرحمن: جار ومجرور متعلقان بمحذوف خبر كان مقدم، وولد: اسم كان مؤخر، والفاء: رابطة لجواب الشرط، وأنا: مبتدأ، وأول العابدين: خبر.</p></div>"
  43,82,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿سبحان رب السماوات والأرض رب العرش عما يصفون﴾</span></span>: سبحان: نائب مفعول مطلق منصوب بفعل محذوف، ورب السماوات والأرض: مضاف إليه، ورب العرش: بدل من <span class="hlt"><span class="qpc-hafs">﴿رب﴾</span></span> الأولى، وعما: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿سبحان﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿يصفون﴾</span></span> صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> لا محل لها من الإعراب.</p></div>"
  43,83,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فذرهم يخوضوا ويلعبوا حتى يلاقوا يومهم الذي يوعدون﴾</span></span>: الفاء: الفصيحة، وذرهم: فعل وفاعل مستتر ومفعول به، ويخوضوا: جواب الطلب، ولذلك جُزم، ويلعبوا: عطف على <span class="hlt"><span class="qpc-hafs">﴿يخوضوا﴾</span></span>، وحتى: حرف غاية وجر، ويلاقوا: فعل مضارع منصوب بأن مضمرة بعد <span class="hlt"><span class="qpc-hafs">﴿حتى﴾</span></span>، والواو: فاعل، والمصدر المؤول من أن والفعل مجرور بـ<span class="hlt"><span class="qpc-hafs">﴿حتى﴾</span></span>، والجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿ذرهم﴾</span></span>، ويومهم: مفعول به، والذي: صفة، وجملة <span class="hlt"><span class="qpc-hafs">﴿يوعدون﴾</span></span> صلة الموصول لا محل لها من الإعراب، ويوعدون: فعل مضارع مبني لما لم يسمَّ فاعله، والواو: نائب فاعل.</p></div>"
  43,84,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وهو الذي في السماء إله وفي الأرض إله وهو الحكيم العليم﴾</span></span>: الواو: استئنافية، وهو: مبتدأ، والذي: خبره، وفي السماء: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿إله﴾</span></span>، لأنه بمعنى معبود، وإله: خبر لمبتدأ محذوف تقديره: هو، والجملة صلة <span class="hlt"><span class="qpc-hafs">﴿الذي﴾</span></span> لا محل لها من الإعراب. وفي الأرض إله: عطف على قوله: <span class="hlt"><span class="qpc-hafs">﴿في السماء إله﴾</span></span>، وهو: مبتدأ، والحكيم العليم: خبران.</p></div>"
  43,85,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وتبارك الذي له ملك السماوات والأرض وما بينهما﴾</span></span>: الواو: عاطفة، وتبارك: فعل ماض، والذي: فاعله، وله: جار ومجرور متعلقان بمحذوف خبر مقدم، وملك: مبتدأ مؤخر. والسماوات: مضاف إليه. وجملة <span class="hlt"><span class="qpc-hafs">﴿له ملك السماوات﴾</span></span> صلة الموصول لا محل لها من الإعراب. وما: عطف على <span class="hlt"><span class="qpc-hafs">﴿السماوات والأرض﴾</span></span>، والظرف متعلق بمحذوف هو صلة.</p><p><span class="hlt"><span class="qpc-hafs">﴿وعنده علم الساعة وإليه ترجعون﴾</span></span>: الواو: عاطفة، وعنده: ظرف متعلق بمحذوف خبر مقدم، وعلم الساعة: مبتدأ مؤخر، وإليه: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿ترجعون﴾</span></span>، وترجعون: فعل مضارع مبني لما لم يسمَّ فاعله، والواو نائب فاعل.</p></div>"
  43,86,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ولا يملك الذين يدعون من دونه الشفاعة﴾</span></span>: الواو: عاطفة، ولا: نافية، ويملك: فعل مضارع، والذين: فاعل، وجملة <span class="hlt"><span class="qpc-hafs">﴿يدعون﴾</span></span> صلة الموصول، ومن دونه: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يدعون﴾</span></span>، والشفاعة: مفعول <span class="hlt"><span class="qpc-hafs">﴿يملك﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿إلا من شهد بالحق وهم يعلمون﴾</span></span>: إلا: أداة حصر، ومَن: مستثنى من <span class="hlt"><span class="qpc-hafs">﴿الذين﴾</span></span>، والاستثناء متصل لاندراج الملائكة والمسيح وعزير فيما يعبدونه، والمعنى: إلا من شهد بالحق كعزير والمسيح والملائكة فإنهم يملكون الشفاعة بتمليك الله إياهم لها. وجملة <span class="hlt"><span class="qpc-hafs">﴿شهد بالحق﴾</span></span> صلة مَن، <span class="hlt"><span class="qpc-hafs">﴿وهم﴾</span></span>: الواو حالية أو عاطفة، وهم: مبتدأ، وجملة <span class="hlt"><span class="qpc-hafs">﴿يعلمون﴾</span></span> خبر.</p></div>"
  43,87,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ولئن سألتهم من خلقهم ليقولن الله فأنى يؤفكون﴾</span></span>: الواو: عاطفة، واللام: موطئة للقسم، وإن: شرطية، وسألتهم: فعل ماض، وفاعل ومفعول به، وهو في محل جزم فعل الشرط، ومَن: اسم استفهام في محل رفع مبتدأ، وجملة <span class="hlt"><span class="qpc-hafs">﴿خلقهم﴾</span></span> خبر مَن، وجملة الاستفهام المعلقة في محل نصب مفعول به ثان لـ<span class="hlt"><span class="qpc-hafs">﴿سألتهم﴾</span></span>، وليقولن: اللام: جواب القسم، وجواب الشرط محذوف، ويقولن: فعل مضارع مرفوع بثبوت النون المحذوفة، لتوالي الأمثال، والواو المحذوفة لالتقاء الساكنين فاعل، والنون المشددة: نون التوكيد الثقيلة، والله: فاعل بفعل محذوف دل عليه موصول الاستفهام، والتقدير: خلقنا الله، وقيل: مبتدأ، والفاء: عاطفة، وأنى: اسم استفهام بمعنى كيف في محل نصب على الحال، ويؤفكون: فعل مضارع مبني لما لم يسمَّ فاعله، والواو: نائب فاعل.</p></div>"
  43,88,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وقيله يا رب﴾</span></span>: الواو: للقسم، وقيله: أي <span class="hlt"><span class="qpc-hafs">﴿قوله﴾</span></span> مجرور بواو القسم، والجار والمجرور متعلقان بفعل محذوف، تقديره: أقسم، والجواب إما محذوف، أي: لأفعلن بهم ما أريد، وإما مذكور، وهو قوله: <span class="hlt"><span class="qpc-hafs">﴿إن هؤلاء قوم لا يؤمنون﴾</span></span>: كأنه قيل: وأُقسم بقيله يا رب، وإن: حرف ناسخ، وهؤلاء: اسم إن، وقوم: خبر إن، وجملة <span class="hlt"><span class="qpc-hafs">﴿لا يؤمنون﴾</span></span> نعت لقوم.</p></div>"
  43,89,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فاصفح عنهم وقل سلام فسوف يعلمون﴾</span></span>: الفاء: الفصيحة، واصفح: فعل أمر وفاعله مستتر تقديره: أنت، وعنهم: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿اصفح﴾</span></span>، وقل: عطف على <span class="hlt"><span class="qpc-hafs">﴿فاصفح﴾</span></span>، وسلام: خبر لمبتدأ محذوف، أي: الأمر سلام، فسوف: الفاء: عاطفة، وسوف: حرف للاستقبال، ويعلمون: فعل مضارع مرفوع، وعلامة رفعه ثبوت النون، والواو: فاعل، والمفعول به محذوف للتفخيم، أي: مغبةَ أمرهم.</p></div>"