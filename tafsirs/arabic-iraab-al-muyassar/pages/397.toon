quran[8]{c,v,t}:
  29,7,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿والذين آمنوا وعملوا الصالحات لنكفرن عنهم سيئاتهم﴾</span></span>: الواو عاطفة، والذين مبتدأ، وجملة آمنوا صلة الموصول لا محل لها من الإعراب. <span class="hlt"><span class="qpc-hafs">﴿وعملوا الصالحات﴾</span></span> عطف على آمنوا، واللام واقعة في جواب قسم مقدر، ونكفرن فعل مضارع مبني على الفتح، والفاعل مستتر، والجملة خبر <span class="hlt"><span class="qpc-hafs">﴿الذين﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿عنهم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿نكفرن﴾</span></span>، وسيئاتهم مفعول به.</p><p><span class="hlt"><span class="qpc-hafs">﴿ولنجزينهم أحسن الذي كانوا يعملون﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿ولنجزينهم﴾</span></span> عطف على <span class="hlt"><span class="qpc-hafs">﴿لنكفرن﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿أحسن﴾</span></span> مفعول به ثان، و<span class="hlt"><span class="qpc-hafs">﴿الذي﴾</span></span> مضاف إليه، وجملة كانوا صلة الموصول لا محل لها من الإعراب. وجملة <span class="hlt"><span class="qpc-hafs">﴿يعملون﴾</span></span> خبر كانوا.</p></div>"
  29,8,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ووصينا الإنسان بوالديه حسنا﴾</span></span>: الواو استئنافية، و<span class="hlt"><span class="qpc-hafs">﴿وصينا﴾</span></span> فعل وفاعل، والإنسان مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿بوالديه﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿وصينا﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿حسنا﴾</span></span> نائب عن المفعول المطلق وقد ناب عن المصدر، على تقدير حذف مضاف، أي: إيصاء ذا حسن، وجملة <span class="hlt"><span class="qpc-hafs">﴿ووصينا الإنسان...﴾</span></span> مستأنفة لا محل لها من الإعراب.</p><p><span class="hlt"><span class="qpc-hafs">﴿وإن جاهداك لتشرك بي ما ليس لك به علم فلا تطعهما﴾</span></span>: الواو عاطفة، وإن شرطية، وجاهداك فعل ماض في محل جزم فعل الشرط، الألف فاعل، والكاف مفعول به، ولتشرك اللام لام التعليل، وتشرك فعل مضارع منصوب بأن مضمرة بعد لام التعليل، والفاعل مستتر، والمصدر المؤول من أن والفعل مجرور باللام، والجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿جاهداك﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿بي﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تشرك﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> اسم موصول مفعول به لـ<span class="hlt"><span class="qpc-hafs">﴿تشرك﴾</span></span>، وليس فعل ماض ناقص، و<span class="hlt"><span class="qpc-hafs">﴿لك﴾</span></span> جار ومجرور متعلقان بمحذوف خبر مقدم لـ<span class="hlt"><span class="qpc-hafs">﴿ليس﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿به﴾</span></span> جار ومجرور متعلقان بمحذوف حال من <span class="hlt"><span class="qpc-hafs">﴿عِلْم﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿عِلْم﴾</span></span> اسم ليس مؤخر، وجملة <span class="hlt"><span class="qpc-hafs">﴿ليس لك به علم﴾</span></span> صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> لا محل لها من الإعراب. <span class="hlt"><span class="qpc-hafs">﴿فلا﴾</span></span> الفاء رابطة لجواب الشرط، لأن الجواب جملة، ولا ناهية، و<span class="hlt"><span class="qpc-hafs">﴿تطعهما﴾</span></span> فعل مضارع مجزوم بلا، والفاعل مستتر، والهاء ضمير مبني في محل نصب مفعول به، والميم والألف حرفان دالان على التثنية، والجملة المقترنة بالفاء في محل جزم جواب إن.</p><p><span class="hlt"><span class="qpc-hafs">﴿إلي مرجعكم فأنبئكم بما كنتم تعملون﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿إليَّ﴾</span></span> جار ومجرور متعلقان بمحذوف خبر مقدم، و<span class="hlt"><span class="qpc-hafs">﴿مرجعكم﴾</span></span> مبتدأ مؤخر، والفاء حرف عطف، و<span class="hlt"><span class="qpc-hafs">﴿أنبئكم﴾</span></span> فعل مضارع، وفاعله مستتر تقديره: أنا، والكاف ضمير مبني في محل نصب مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿بما﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أنبئكم﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿كنتم﴾</span></span> صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> لا محل لها من الإعراب. وجملة <span class="hlt"><span class="qpc-hafs">﴿تعملون﴾</span></span> خبر كنتم.</p></div>"
  29,9,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿والذين آمنوا وعملوا الصالحات لندخلنهم في الصالحين﴾</span></span>: الواو عاطفة، والذين مبتدأ، وجملة آمنوا صلة الموصول لا محل لها من الإعراب. <span class="hlt"><span class="qpc-hafs">﴿وعملوا الصالحات﴾</span></span> عطف على آمنوا، واللام واقعة في جواب قسم مقدر، وندخلن فعل مضارع مبني على الفتح، وفاعله مستتر، تقديره: نحن، والهاء مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿في الصالحين﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿ندخلنهم﴾</span></span>.</p></div>"
  29,10,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ومن الناس من يقول آمنا بالله﴾</span></span>: الواو استئنافية، و<span class="hlt"><span class="qpc-hafs">﴿من الناس﴾</span></span> جار ومجرور متعلقان بمحذوف خبر مقدم، و<span class="hlt"><span class="qpc-hafs">﴿مَن﴾</span></span>: اسم موصول في محل رفع مبتدأ مؤخر، وجملة <span class="hlt"><span class="qpc-hafs">﴿يقول ...﴾</span></span> صلة الموصول لا محل لها من الإعراب. وجملة <span class="hlt"><span class="qpc-hafs">﴿آمنا﴾</span></span> مقول القول، و<span class="hlt"><span class="qpc-hafs">﴿بالله﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿آمنا﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿ومن الناس...﴾</span></span> مستأنفة لا محل لها من الإعراب.</p><p><span class="hlt"><span class="qpc-hafs">﴿فإذا أوذي في الله جعل فتنة الناس كعذاب الله﴾</span></span>: الفاء حرف عطف، وإذا ظرف مستقبل متضمن معنى الشرط، و<span class="hlt"><span class="qpc-hafs">﴿في الله﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أوذي﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿أوذي﴾</span></span> في محل جر بإضافة الظرف إليها، وجملة <span class="hlt"><span class="qpc-hafs">﴿جعل﴾</span></span> لا محل لها من الإعراب، لأنها جواب إذا، و<span class="hlt"><span class="qpc-hafs">﴿فتنة﴾</span></span> مفعول جعل الأول، والناس مضاف إليه، و<span class="hlt"><span class="qpc-hafs">﴿كعذاب﴾</span></span>: الكاف اسم بمعنى مثل مبني على الفتح في محل نصب مفعول ثان، و<span class="hlt"><span class="qpc-hafs">﴿عذاب﴾</span></span> مضاف إليه، ولفظ الجلالة مضاف إليه.</p><p><span class="hlt"><span class="qpc-hafs">﴿ولئن جاء نصر من ربك ليقولن إنا كنا معكم﴾</span></span>: الواو عاطفة، واللام موطئة للقسم، وإن حرف شرط جازم، و<span class="hlt"><span class="qpc-hafs">﴿جاء﴾</span></span> فعل ماض في محل جزم فعل الشرط، ونصر فاعل، و<span class="hlt"><span class="qpc-hafs">﴿من ربك﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿جاء﴾</span></span>، أو بمحذوف صفة لـ<span class="hlt"><span class="qpc-hafs">﴿نصر﴾</span></span>. <span class="hlt"><span class="qpc-hafs">﴿ليقولن﴾</span></span>: اللام واقعة في جواب القسم، ويقولن: فعل مضارع مرفوع بثبوت النون المحذوفة لتوالي الأمثال، وواو الجماعة المحذوفة لالتقاء الساكنين فاعل، وجملة <span class="hlt"><span class="qpc-hafs">﴿إنا كنا معكم﴾</span></span> مقول القول، وإن حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> اسمها، وجملة <span class="hlt"><span class="qpc-hafs">﴿كنا﴾</span></span> خبرها، و<span class="hlt"><span class="qpc-hafs">﴿معكم﴾</span></span> ظرف متعلق بمحذوف خبر <span class="hlt"><span class="qpc-hafs">﴿كان﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿أوليس الله بأعلم بما في صدور العالمين﴾</span></span>: الهمزة للاستفهام، والواو عاطفة على محذوف يقتضيه السياق، و<span class="hlt"><span class="qpc-hafs">﴿ليس﴾</span></span> فعل ماض ناقص، ولفظ الجلالة اسمها، والباء حرف صلة، وأعلم مجرور لفظًا، منصوب محلًّا على أنه خبر ليس، و<span class="hlt"><span class="qpc-hafs">﴿بما﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أعلم﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿في صدور العالمين﴾</span></span> الجار والمجرور متعلقان بمحذوف صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> وجملة الصلة لا محل لها من الإعراب. والعالمين مضاف إليه.</p></div>"
  29,11,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وليعلمن الله الذين آمنوا وليعلمن المنافقين﴾</span></span>: الواو عاطفة، واللام واقعة في جواب قسم مقدر، و<span class="hlt"><span class="qpc-hafs">﴿يعلمن﴾</span></span> فعل مضارع مبني على الفتح، ولفظ الجلالة فاعل، و<span class="hlt"><span class="qpc-hafs">﴿الذين﴾</span></span> مفعول به، وجملة <span class="hlt"><span class="qpc-hafs">﴿آمنوا﴾</span></span> صلة الموصول لا محل لها من الإعراب. <span class="hlt"><span class="qpc-hafs">﴿وليعلمن المنافقين﴾</span></span> عطف على <span class="hlt"><span class="qpc-hafs">﴿وليعلمن الله الذين آمنوا﴾</span></span>.</p></div>"
  29,12,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وقال الذين كفروا للذين آمنوا اتبعوا سبيلنا ولنحمل خطاياكم﴾</span></span>: الواو استئنافية، و<span class="hlt"><span class="qpc-hafs">﴿قال الذين﴾</span></span> فعل وفاعل، وجملة <span class="hlt"><span class="qpc-hafs">﴿كفروا﴾</span></span> صلة  الموصول لا محل لها من الإعراب.و<span class="hlt"><span class="qpc-hafs">﴿للذين﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿قال﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿آمنوا﴾</span></span> صلة الموصول لا محل لها من الإعراب. وجملة <span class="hlt"><span class="qpc-hafs">﴿اتبعوا﴾</span></span> مقول القول، واتبعوا: فعل وفاعل، و<span class="hlt"><span class="qpc-hafs">﴿سبيلنا﴾</span></span> مفعول، وجملة <span class="hlt"><span class="qpc-hafs">﴿وقال الذين كفروا...﴾</span></span> مستأنفة لا محل لها من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿لنحمل﴾</span></span> الواو عاطفة، واللام لام الأمر، ونحمل فعل مضارع مجزوم بلام الأمر، وخطاياكم مفعول به.</p><p><span class="hlt"><span class="qpc-hafs">﴿وما هم بحاملين من خطاياهم من شيء إنهم لكاذبون﴾</span></span>: الواو حالية، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> نافية حجازية تعمل عمل ليس، و<span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> اسم ما، و<span class="hlt"><span class="qpc-hafs">﴿بحاملين﴾</span></span>: الباء حرف جر صلة، و<span class="hlt"><span class="qpc-hafs">﴿حاملين﴾</span></span> خبر <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> الحجازية منصوب محلا مجرور بالباء لفظًا، و<span class="hlt"><span class="qpc-hafs">﴿من خطاياهم﴾</span></span> جار ومجرور متعلقان بمحذوف حال، لأنه كان في الأصل صفة لشيء، وتقدم عليه، ومن حرف صلة، وشيء مجرور لفظًا، منصوب محلًّا، لأنه مفعول حاملين، وجملة <span class="hlt"><span class="qpc-hafs">﴿إنهم لكاذبون﴾</span></span> تعليل، وإن حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> اسمها، واللام المزحلقة، و<span class="hlt"><span class="qpc-hafs">﴿كاذبون﴾</span></span> خبرها.</p></div>"
  29,13,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وليحملن أثقالهم وأثقالا مع أثقالهم﴾</span></span>: الواو عاطفة، واللام واقعة في جواب قسم مقدر، و<span class="hlt"><span class="qpc-hafs">﴿يحملن﴾</span></span> فعل مضارع مرفوع بثبوت النون المحذوفة لتوالي الأمثال، وواو الجماعة المحذوفة لالتقاء الساكنين فاعل، و<span class="hlt"><span class="qpc-hafs">﴿أثقالهم﴾</span></span> مفعول به، <span class="hlt"><span class="qpc-hafs">﴿وأثقالًا﴾</span></span> عطف على أثقالهم، و<span class="hlt"><span class="qpc-hafs">﴿مع﴾</span></span> ظرف متعلق بمحذوف صفة لـ<span class="hlt"><span class="qpc-hafs">﴿أثقالًا﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿أثقالهم﴾</span></span> مضاف إليه.</p><p><span class="hlt"><span class="qpc-hafs">﴿وليسألن يوم القيامة عما كانوا يفترون﴾</span></span>: الواو عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿يسألن﴾</span></span> عطف على يحملن، و<span class="hlt"><span class="qpc-hafs">﴿يوم القيامة﴾</span></span> ظرف متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿يسألن﴾</span></span>، والقيامة مضاف إليه، و<span class="hlt"><span class="qpc-hafs">﴿عما﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يسألن﴾</span></span> أيضًا، وجملة <span class="hlt"><span class="qpc-hafs">﴿كانوا﴾</span></span> صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> لا محل لها من الإعراب. وكان فعل ماض ناقص، وواو الجماعة اسمها، وجملة <span class="hlt"><span class="qpc-hafs">﴿يفترون﴾</span></span> خبر كان.</p></div>"
  29,14,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ولقد أرسلنا نوحا إلى قومه فلبث فيهم ألف سنة إلا خمسين عاما﴾</span></span>: الواو استئنافية، واللام جواب للقسم المحذوف، وقد حرف تحقيق، و<span class="hlt"><span class="qpc-hafs">﴿أرسلنا﴾</span></span> فعل وفاعل، و<span class="hlt"><span class="qpc-hafs">﴿نوحًا﴾</span></span> مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿إلى قومه﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أرسلنا﴾</span></span>. وجملة <span class="hlt"><span class="qpc-hafs">﴿ولقد أرسلنا نوحا﴾</span></span> مستأنفة لا محل لها من الإعراب، <span class="hlt"><span class="qpc-hafs">﴿فلبث﴾</span></span>: الفاء عاطفة، ولبث فعل ماض، وفاعله مستتر، و<span class="hlt"><span class="qpc-hafs">﴿فيهم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿لبث﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿ألف سنة﴾</span></span> نصب على الظرف، وهو متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿لبث﴾</span></span> أيضًا، وإلا أداة استثناء، و<span class="hlt"><span class="qpc-hafs">﴿خمسين﴾</span></span> منصوب على الاستثناء، و<span class="hlt"><span class="qpc-hafs">﴿عامًا﴾</span></span> تمييز.</p><p><span class="hlt"><span class="qpc-hafs">﴿فأخذهم الطوفان وهم ظالمون﴾</span></span>: الفاء عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿أخذهم الطوفان﴾</span></span> فعل: ومفعول به مقدم، وفاعل مؤخر، والواو حالية، و<span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> مبتدأ، وظالمون خبر.</p></div>"