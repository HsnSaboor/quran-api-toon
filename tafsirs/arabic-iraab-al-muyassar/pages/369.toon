quran[21]{c,v,t}:
  26,40,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿لعلنا نتبع السحرة إن كانوا هم الغالبين﴾</span></span>: الجملة في محل نصب حال، ولعل حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> اسمها، وجملة <span class="hlt"><span class="qpc-hafs">﴿نتبع﴾</span></span> خبرها، والسحرة مفعول به، وإن شرطية، و<span class="hlt"><span class="qpc-hafs">﴿كانوا﴾</span></span>: كان فعل ماض ناقص، وهو فعل الشرط، وواو الجماعة اسمها، و<span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> ضمير فصل، والغالبين خبر كان.</p></div>"
  26,41,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فلما جاء السحرة قالوا لفرعون أئن لنا لأجرا إن كنا نحن الغالبين﴾</span></span>: الفاء عاطفة، ولما حينية ظرفية، أو رابطة، وجاء السحرة فعل وفاعل، وجملة <span class="hlt"><span class="qpc-hafs">﴿قالوا﴾</span></span> لا محل لها من الإعراب، لأنها جواب شرط غير جازم، و<span class="hlt"><span class="qpc-hafs">﴿لفرعون﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿قالوا﴾</span></span>، والهمزة للاستفهام، وإن حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿لنا﴾</span></span> جار ومجرور متعلقان بمحذوف خبرها المقدم، وأجرًا اسمها المؤخر، وإن شرطية، و<span class="hlt"><span class="qpc-hafs">﴿كنا﴾</span></span>: كان فعل ماض ناقص، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> اسمها، وهو فعل الشرط، و<span class="hlt"><span class="qpc-hafs">﴿نحن﴾</span></span> ضمير فصل، والغالبين خبر <span class="hlt"><span class="qpc-hafs">﴿كان﴾</span></span>، وجواب الشرط محذوف دل عليه ما قبله.</p></div>"
  26,42,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قال نعم وإنكم إذا لمن المقربين﴾</span></span>: قال فعل ماض، <span class="hlt"><span class="qpc-hafs">﴿نعم﴾</span></span> حرف جواب، أي: لكم الأجر، وإنكم عطف، وإن حرف ناسخ، والكاف اسمها، و<span class="hlt"><span class="qpc-hafs">﴿إذًا﴾</span></span> حرف جواب وجزاء، واللام المزحلقة، و<span class="hlt"><span class="qpc-hafs">﴿من المقربين﴾</span></span> جار ومجرور متعلقان بمحذوف خبر إن.</p></div>"
  26,43,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قال لهم موسى ألقوا ما أنتم ملقون﴾</span></span>: قال لهم موسى فعل وفاعل، و<span class="hlt"><span class="qpc-hafs">﴿لهم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿قال﴾</span></span>، وجملة ألقوا مقول القول، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> اسم موصول في محل نصب مفعول به، وجملة <span class="hlt"><span class="qpc-hafs">﴿أنتم ملقون﴾</span></span> صلة الموصول لا محل لها من الإعراب، وأنتم مبتدأ، وملقون خبر.</p></div>"
  26,44,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فألقوا حبالهم وعصيهم وقالوا بعزة فرعون إنا لنحن الغالبون﴾</span></span>: الفاء عاطفة، وألقوا فعل وفاعل، وحبالهم مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿عصيهم﴾</span></span> عطف على حبالهم، و<span class="hlt"><span class="qpc-hafs">﴿قالوا﴾</span></span> عطف على فألقوا، و<span class="hlt"><span class="qpc-hafs">﴿بعزة﴾</span></span> الباء حرف قسم وجر، وعزة مجرور بالباء، والجار والمجرور متعلقان بفعل محذوف، وتقديره: نقسم، و<span class="hlt"><span class="qpc-hafs">﴿إنا﴾</span></span>: إن حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> اسمها، واللام المزحلقة، ونحن ضمير فصل، والغالبون خبر إن، أو <span class="hlt"><span class="qpc-hafs">﴿نحن﴾</span></span> مبتدأ، والغالبون خبر <span class="hlt"><span class="qpc-hafs">﴿نحن﴾</span></span>، والجملة خبر إن.</p></div>"
  26,45,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فألقى موسى عصاه فإذا هي تلقف ما يأفكون﴾</span></span>: الفاء عاطفة، وألقى موسى عصاه فعل وفاعل ومفعول به، <span class="hlt"><span class="qpc-hafs">﴿فإذا﴾</span></span> الفاء عاطفة، وإذا فجائية، و<span class="hlt"><span class="qpc-hafs">﴿هي﴾</span></span> مبتدأ، وجملة تلقف خبر، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> مفعول به، وجملة يأفكون صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> لا محل لها من الإعراب.</p></div>"
  26,46,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فألقي السحرة ساجدين﴾</span></span>: الفاء عاطفة، وألقي فعل ماض مبني لما لم يسمَّ فاعله، والسحرة نائب فاعل، وساجدين حال.</p></div>"
  26,47,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قالوا آمنا برب العالمين﴾</span></span>: قالوا فعل ماض، والواو فاعل، وجملة آمنا من الفعل والفاعل مقول القول، و<span class="hlt"><span class="qpc-hafs">﴿برب العالمين﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿آمنا﴾</span></span>، وجملة القول بدل اشتمال من <span class="hlt"><span class="qpc-hafs">﴿ألقي﴾</span></span>، أو حالية بتقدير: قد.</p></div>"
  26,48,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿رب موسى وهارون﴾</span></span>: رب بدل من رب العالمين، أو عطف بيان، وموسى مضاف إليه، وهارون معطوف.</p></div>"
  26,49,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قال آمنتم له قبل أن آذن لكم﴾</span></span>: قال فعل ماض، وجملة آمنتم مقول القول، و<span class="hlt"><span class="qpc-hafs">﴿له﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿آمنتم﴾</span></span>، والظرف متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿آمنتم﴾</span></span>، وأن وما في حيزها في محل جر بالإضافة، و<span class="hlt"><span class="qpc-hafs">﴿لكم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿آذن﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿إنه لكبيركم الذي علمكم السحر فلسوف تعلمون﴾</span></span>: إن حرف ناسخ، والهاء اسمها، واللام المزحلقة، وكبيركم خبر إن، والذي صفة، وجملة علمكم صلة الموصول لا محل لها من الإعراب، والكاف مفعول به أول، والسحر مفعول به ثان، <span class="hlt"><span class="qpc-hafs">﴿فلسوف﴾</span></span> الفاء الفصيحة، واللام واقعة في جواب قسم مقدر، وسوف حرف استقبال، وتعلمون فعل مضارع وفاعل، والمفعول محذوف.</p><p><span class="hlt"><span class="qpc-hafs">﴿لأقطعن أيديكم وأرجلكم من خلاف ولأصلبنكم أجمعين﴾</span></span>: اللام واقعة في جواب قسم مقدر. وأقطعن: فعل مضارع مبني على الفتح لاتصاله بنون التوكيد الثقيلة، والفاعل ضمير مستتر تقديره: أنا. وأيديكم: مفعول به. وأرجلكم: عطف على أيديكم. و<span class="hlt"><span class="qpc-hafs">﴿من خلاف﴾</span></span> جار ومجرور متعلقان بمحذوف حال. ولأصلبنكم: عطف على لأقطعن. وأجمعين: تأكيد للكاف.</p></div>"
  26,50,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قالوا لا ضير إنا إلى ربنا منقلبون﴾</span></span>: قالوا فعل ماض، والواو فاعل، ولا نافية للجنس، و<span class="hlt"><span class="qpc-hafs">﴿ضير﴾</span></span> اسمها المبني على الفتح، وخبرها محذوف، أي: لا ضير علينا، وجملة <span class="hlt"><span class="qpc-hafs">﴿إنا﴾</span></span> تعليل، وإن حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> اسمها، و<span class="hlt"><span class="qpc-hafs">﴿إلى ربنا﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿منقلبون﴾</span></span>، ومنقلبون خبر إن.</p></div>"
  26,51,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إنا نطمع أن يغفر لنا ربنا خطايانا﴾</span></span>: إن حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> اسمها، وجملة نطمع خبرها، والفاعل مستتر تقديره: نحن، وأن وما في حيزها نصب بنزع الخافض، أي: في غفران خطايانا، أو على تضمين <span class="hlt"><span class="qpc-hafs">﴿نطمع﴾</span></span> معنى نرجو، و<span class="hlt"><span class="qpc-hafs">﴿أن﴾</span></span> وما في حيزها في محل نصب على المفعولية، و<span class="hlt"><span class="qpc-hafs">﴿ربنا﴾</span></span> فاعل يغفر، وخطايانا مفعول به.</p><p><span class="hlt"><span class="qpc-hafs">﴿أن كنا أول المؤمنين﴾</span></span>: المصدر المؤول من <span class="hlt"><span class="qpc-hafs">﴿أن كنا﴾</span></span> منصوب بنزع الخافض، أي: لأن كنا، و<span class="hlt"><span class="qpc-hafs">﴿كنا﴾</span></span> فعل ماض ناقص، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> اسمها، وأول المؤمنين خبرها.</p></div>"
  26,52,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وأوحينا إلى موسى أن أسر بعبادي إنكم متبعون﴾</span></span>: الواو استئنافية، والجملة بعدها مستأنفة لا محل لها من الإعراب، وأوحينا فعل وفاعل، وإلى موسى: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أوحينا﴾</span></span>. <span class="hlt"><span class="qpc-hafs">﴿أن﴾</span></span>: تفسيرية، لأن الوحي فيه معنى القول دون حروفه، والجملة بعدها تفسيرية لا محل لها من الإعراب. أو <span class="hlt"><span class="qpc-hafs">﴿أن﴾</span></span> مصدرية وهي مع ما دخلت عليه في تأويل مصدر منصوب بنزع الخافض، والجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أوحى﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿أسر﴾</span></span> صلة <span class="hlt"><span class="qpc-hafs">﴿أن﴾</span></span> المصدرية لا محل لها من الإعراب. وأسر: فعل أمر مبني على حذف حرف العلة، والفاعل مستتر. وبعبادي: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أسر﴾</span></span>، أو متعلقان بمحذوف حال، أي: مصحوبًا بعبادي، و<span class="hlt"><span class="qpc-hafs">﴿إنكم متبعون﴾</span></span>: إن واسمها، وخبرها. وجملة <span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span> تعليلة مستأنفة لا محل لها من الإعراب.</p></div>"
  26,53,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فأرسل فرعون في المدائن حاشرين﴾</span></span>: الفاء عاطفة، وأرسل فرعون فعل وفاعل، و<span class="hlt"><span class="qpc-hafs">﴿في المدائن﴾</span></span> جار ومجرور متعلقان بمحذوف حال، وحاشرين مفعول به.</p></div>"
  26,54,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إن هؤلاء لشرذمة قليلون﴾</span></span>: الجملة مقول قول محذوف منصوب على الحال، أي: قائلًا، وإن حرف ناسخ، وهؤلاء اسمها، واللام المزحلقة، وشرذمة خبرها، وقليلون صفة.</p></div>"
  26,55,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وإنهم لنا لغائظون﴾</span></span>: الواو عاطفة، أو حالية، وإن حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> اسمها، و<span class="hlt"><span class="qpc-hafs">﴿لنا﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿غائظون﴾</span></span>، واللام المزحلقة، وغائظون خبر إن.</p></div>"
  26,56,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وإنا لجميع حاذرون﴾</span></span>: الواو عاطفة، أو حالية، وإن حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> اسمها، واللام المزحلقة، وجميع خبر أول، وحاذرون خبر ثان.</p></div>"
  26,57,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فأخرجناهم من جنات وعيون﴾</span></span>: الفاء استئنافية، والجملة بعدها مستأنفة لا محل لها من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿أخرجناهم﴾</span></span> فعل وفاعل ومفعول به، و<span class="hlt"><span class="qpc-hafs">﴿من جنات وعيون﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أخرجناهم﴾</span></span>.</p></div>"
  26,58,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وكنوز ومقام كريم﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿وكنوز ومقام﴾</span></span> عطف على <span class="hlt"><span class="qpc-hafs">﴿جنات وعيون﴾</span></span>، وكريم صفة.</p></div>"
  26,59,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿كذلك وأورثناها بني إسرائيل﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿كذلك﴾</span></span>: الكاف اسم بمعنى مثل مبني على الفتح في محل نصب نعت لمصدر محذوف، أي: أخرجناهم مثل ذلك الإخراج، و<span class="hlt"><span class="qpc-hafs">﴿ذلك﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿ذا﴾</span></span> اسم إشارة في محل جر مضاف إليه، واللام للبعد، والكاف حرف خطاب، و<span class="hlt"><span class="qpc-hafs">﴿أورثناها﴾</span></span> الواو عاطفة، أو اعتراضية، وأورثناها: فعل وفاعل ومفعول به أول، وبني: مفعول به ثان، وإسرائيل: مضاف إليه، وجملة <span class="hlt"><span class="qpc-hafs">﴿أورثناها...﴾</span></span>: معطوفة على <span class="hlt"><span class="qpc-hafs">﴿أخرجناهم﴾</span></span>، أو اعتراضية لا محل لها من الإعراب.</p></div>"
  26,60,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فأتبعوهم مشرقين﴾</span></span>: الفاء عاطفة، وأتبعوهم فعل ماض وفاعل ومفعول به ثان، ومشرقين حال.</p></div>"