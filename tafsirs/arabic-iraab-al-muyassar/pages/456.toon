quran[19]{c,v,t}:
  38,43,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ووهبنا له أهله ومثلهم معهم رحمة منا وذكرى لأولي الألباب﴾</span></span>: الواو عاطفة، ووهبنا: فعل، وفاعل، وله: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿وهبنا﴾</span></span>، وأهله: مفعول به، والهاء: مضاف إليه، ومثلهم: عطف على أهله، <span class="hlt"><span class="qpc-hafs">﴿معهم﴾</span></span>: ظرف متعلق بمحذوف حال، أي: كائنًا معهم، ورحمة: مفعول لأجله، ومنا: جار ومجرور متعلقان بمحذوف صفة لرحمة، وذكرى: عطف على رحمة، ولأولي: جار ومجرور متعلقان بمحذوف نعت لذكرى، والألباب: مضاف إليه.</p></div>"
  38,44,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وخذ بيدك ضغثا فاضرب به ولا تحنث﴾</span></span>: الواو عاطفة، وخذ: فعل أمر والفاعل مستتر، وبيدك: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿خذ﴾</span></span>، وضغثًا: مفعول به، فاضرب: عطف على خذ، وبه: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿اضرب﴾</span></span>، والمفعول محذوف، أي امرأتك، ولا تحنث: الواو عاطفة، ولا ناهية، وتحنث: فعل مضارع مجزوم بلا.</p><p><span class="hlt"><span class="qpc-hafs">﴿إنا وجدناه صابرا نعم العبد إنه أواب﴾</span></span>: إن حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> اسمها، وجملة <span class="hlt"><span class="qpc-hafs">﴿وجدناه﴾</span></span> خبرها، ووجد فعل ماض، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> فاعل، والهاء مفعول به أول، وصابرًا مفعول به ثان، و<span class="hlt"><span class="qpc-hafs">﴿نعم العبد﴾</span></span>: فعل، وفاعل، والمخصوص بالمدح محذوف للعلم به، أي هو، و<span class="hlt"><span class="qpc-hafs">﴿إنه أواب﴾</span></span>: إن حرف ناسخ، والهاء اسمها، وأواب خبرها، والجملة تعليل لمدحه.</p></div>"
  38,45,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿واذكر عبادنا إبراهيم وإسحاق ويعقوب أولي الأيدي والأبصار﴾</span></span>: الواو عاطفة، اذكر: فعل أمر، وفاعله مستتر تقديره أنت، وعبادنا: مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span>: مضاف إليه، وإبراهيم: بدل، أو عطف بيان، <span class="hlt"><span class="qpc-hafs">﴿وإسحاق ويعقوب﴾</span></span>: عطف على إبراهيم، وأولي: مفعول به، والأيدي: مضاف إليه، والأبصار: عطف على الأيدي.</p></div>"
  38,46,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إنا أخلصناهم بخالصة ذكرى الدار﴾</span></span>: الجملة تعليلية، وإن حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> اسمها، وجملة <span class="hlt"><span class="qpc-hafs">﴿أخلصناهم﴾</span></span>: خبر إن، وبخالصة: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أخلصناهم﴾</span></span>، وبخالصة: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أخلصناهم﴾</span></span>، وذكرى: بدل من خالصة، والدار:مضاف إليه، وإضافة ذكرى إلى الدار من إضافة المصدر إلى المفعول، أي ذكرهم الدار الآخرة.</p></div>"
  38,47,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وإنهم عندنا لمن المصطفين الأخيار﴾</span></span>: الواو عاطفة، وإن حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> اسمها، وعندنا: ظرف متعلق بمحذوف حال، واللام المزحلقة، و<span class="hlt"><span class="qpc-hafs">﴿من المصطفين﴾</span></span>: جار ومجرور متعلقان بمحذوف خبر إن، والأخيار: صفة.</p></div>"
  38,48,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿واذكر إسماعيل واليسع وذا الكفل وكل من الأخيار﴾</span></span>: الواو عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿اذكر إسماعيل﴾</span></span>: فعل، وفاعل مستتر، ومفعول به، <span class="hlt"><span class="qpc-hafs">﴿واليسع وذا الكفل﴾</span></span>: معطوفان على إسماعيل، وكل: مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿من الأخيار﴾</span></span>: جار ومجرور متعلقان بمحذوف خبر.</p></div>"
  38,49,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿هذا ذكر وإن للمتقين لحسن مآب﴾</span></span>: كلام مستأنف لا محل له من الإعراب، وهذا: مبتدأ، وذكر: خبر، وإن: الواو استئنافية، وإن حرف ناسخ، وللمتقين: جار ومجرور متعلقان بمحذوف خبر إن المقدم، واللام المزحلقة، وحسن: اسم إن المؤخر، ومآب: مضاف إليه، وجملة <span class="hlt"><span class="qpc-hafs">﴿وإن للمتقين...﴾</span></span> مستأنفة لا محل لها من الإعراب.</p></div>"
  38,50,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿جنات عدن مفتحة لهم الأبواب﴾</span></span>: جنات: بدل، أو عطف بيان لحسن مآب، وعدن: مضاف إليه، ومفتحة: حال من جنات عدن، والعامل فيها ما في المتقين من معنى الفعل، ولهم: جار ومجرور متعلقان بمفتحة، والأبواب: نائب فاعل لمفتحة، لأنه اسم مفعول، أو بدل من الضمير في مفتحة، وهو ضمير الجنات.</p></div>"
  38,51,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿متكئين فيها يدعون فيها بفاكهة كثيرة وشراب﴾</span></span>: متكئين: حال من الهاء في لهم، والعامل فيها مفتحة، وفيها: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿متكئين﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿يدعون﴾</span></span>: مستأنفة لا محل لها من الإعراب، أو حالية، وفيها: جار ومجرور متعلقان بمحذوف حال من فاعل يدعون، أي: مستقرين فيها، وبفاكهة: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يدعون﴾</span></span>، وكثيرة: صفة، وشراب: عطف على فاكهة.</p></div>"
  38,52,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وعندهم قاصرات الطرف أتراب﴾</span></span>: الواو عاطفة، والظرف متعلق بمحذوف خبر مقدم، و<span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span>: ضمير مبني في محل جر مضاف إليه، وقاصرات: مبتدأ مؤخر، والطرف: مضاف إليه، وأتراب: صفة لقاصرات.</p></div>"
  38,53,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿هذا ما توعدون ليوم الحساب﴾</span></span>: هذا: اسم الإشارة مبتدأ، وما: خبر، وجملة <span class="hlt"><span class="qpc-hafs">﴿توعدون﴾</span></span> صلة الموصول لا محل لها من الإعراب. وليوم: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿توعدون﴾</span></span>، واللام للتعليل، أي: لأجل يوم الحساب، والحساب: مضاف إليه.</p></div>"
  38,54,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إن هذا لرزقنا ما له من نفاد﴾</span></span>: إن: حرف ناسخ، وهذا: اسمها، واللام المزحلقة، ورزقنا: خبر إن، وما: نافية، وله: جار ومجرور متعلقان بمحذوف خبر مقدم، ومن: حرف جر صلة، ونفاد: مبتدأ مؤخر مرفوع محلا مجرور بـ<span class="hlt"><span class="qpc-hafs">﴿من﴾</span></span> لفظًا.</p></div>"
  38,55,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿هذا وإن للطاغين لشر مآب﴾</span></span>: هذا: مبتدأ محذوف الخبر، أي: هذا كما ذكر، أو خبر لمبتدأ محذوف، أي: الأمر هذا، والكلام مستأنف لا محل له من الإعراب، والواو عاطفة، وإن: حرف ناسخ، وللطاغين: جار ومجرور متعلقان بمحذوف خبر إن المقدم، واللام المزحلقة، وشر: اسم إن المؤخر، ومآب: مضاف إليه.</p></div>"
  38,56,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿جهنم يصلونها فبئس المهاد﴾</span></span>: بدل من شر مآب، أو عطف بيان له، وجملة يصلونها حالية، وهو فعل مضارع، والواو فاعل، و<span class="hlt"><span class="qpc-hafs">﴿ها﴾</span></span> مفعول به، أو: جهنم مفعول محذوف دل عليه يصلونها، والفاء الفصيحة، أي: إن أردت أن تعلم حقيقة جهنم فهي بئس المهاد، وبئس فعل جامد لإنشاء الذم، والمهاد فاعل، والمخصوص بالذم محذوف تقديره: هي.</p></div>"
  38,57,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿هذا فليذوقوه حميم وغساق﴾</span></span>: هذا: مبتدأ. والفاء اعتراضية. واللام: لام الأمر. ويذوقوه: فعل مضارع مجزوم بلام الأمر. والواو: فاعل. والهاء: مفعول به. وجملة <span class="hlt"><span class="qpc-hafs">﴿فليذوقوه﴾</span></span> اعتراضية لا محل لها من الإعراب. وحميم: خبر المبتدأ. وغساق: معطوف مرفوع.</p></div>"
  38,58,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وآخر من شكله أزواج﴾</span></span>: الواو عاطفة، وآخر: عطف على <span class="hlt"><span class="qpc-hafs">﴿حميم وغساق﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿من شكله﴾</span></span>: جار ومجرور متعلقان بمحذوف نعت لآخر، وأزواج: خبر لمبتدأ محذوف، أي: هي أزواج.</p></div>"
  38,59,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿هذا فوج مقتحم معكم لا مرحبا بهم إنهم صالو النار﴾</span></span>: الجملة مقول قول محذوف، وهذا: مبتدأ، وفوج: خبر، ومقتحم: صفة لفوج، ومعكم: ظرف متعلق بمحذوف صفة ثانية لفوج، أو حال من الضمير في فوج، ولا نافية، ومرحبًا: منصوب على المصدر، و<span class="hlt"><span class="qpc-hafs">﴿بهم﴾</span></span>: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿مرحبًا﴾</span></span>، والجملة المنفية مستأنفة لا محل لها من الإعراب، أو حالية، وإن حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> اسمها، و<span class="hlt"><span class="qpc-hafs">﴿صالو﴾</span></span>: خبرها، وحذفت النون للإضافة، والنار: مضاف إليه.</p></div>"
  38,60,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قالوا بل أنتم لا مرحبا بكم أنتم قدمتموه لنا فبئس القرار﴾</span></span>: قالوا: فعل، وفاعل، وبل: حرف إضراب، وأنتم: مبتدأ، وخبره محذوف تقديره: أحق بالقول، ولا نافية، ومرحبًا: منصوب على المصدر، و<span class="hlt"><span class="qpc-hafs">﴿بكم﴾</span></span>: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿مرحبًا﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿قالوا بل أنتم...﴾</span></span> استئنافية لا محل لها من الإعراب، وأنتم: مبتدأ، وجملة <span class="hlt"><span class="qpc-hafs">﴿قدمتموه﴾</span></span> خبر، وقدمتموه: فعل ماض، والتاء فاعل، والميم علامة جمع الذكور، والواو لإشباع ضمة الميم، والهاء مفعول به، ولنا: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿قدَّم﴾</span></span>، فبئس: الفاء عاطفة، وبئس: فعل ماض جامد لإنشاء الذم، والقرار: فاعل، والمخصوص بالذم محذوف، أي: النار.</p></div>"
  38,61,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قالوا ربنا من قدم لنا هذا فزده عذابا ضعفا في النار﴾</span></span>: قالوا: فعل، وفاعل، وربنا: منادى مضاف محذوف منه حرف النداء، ومن: اسم موصول مبتدأ، وجملة <span class="hlt"><span class="qpc-hafs">﴿قدم﴾</span></span> خبر، وقدم: فعل ماض، والفاعل مستتر، ولنا: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿قدم﴾</span></span>، وهذا: مفعول به، والفاء رابطة لما في الموصول من رائحة الشرط، وجملة <span class="hlt"><span class="qpc-hafs">﴿فزده﴾</span></span>: خبر، وفعل الدعاء مبني على السكون، والفاعل مستتر تقديره: أنت، والهاء: في محل نصب مفعول به أول، وعذابًا: مفعول به ثان، وضعفًا: نعت لعذاب، أي مضاعفًا، وفي النار: جار ومجرور متعلقان بمحذوف حال من الهاء، أي فزده كائنًا في النار، أو نعت ثان لعذاب.</p></div>"