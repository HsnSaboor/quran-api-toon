quran[7]{c,v,t}:
  16,73,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ويعبدون من دون الله ما لا يملك لهم رزقا من السماوات والأرض﴾</span></span>: الواو عاطفة، ويعبدون فعل مضارع وفاعل، و<span class="hlt"><span class="qpc-hafs">﴿من دون الله﴾</span></span> جار ومجرور متعلقان بمحذوف حال، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> مفعول به، وجملة <span class="hlt"><span class="qpc-hafs">﴿لا يملك﴾</span></span> صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> لا محل لها من الإعراب، ورزقًا مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿من السماوات والأرض﴾</span></span> جار ومجرور متعلقان بمحذوف صفة لـ<span class="hlt"><span class="qpc-hafs">﴿رزقًا﴾</span></span>، أو متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿رزقًا﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿شيئا ولا يستطيعون﴾</span></span>: شيئًا مفعول به لـ<span class="hlt"><span class="qpc-hafs">﴿رزقًا﴾</span></span>، أو بدل منه بمعنى: قليلًا، وجملة <span class="hlt"><span class="qpc-hafs">﴿ولا يستطيعون﴾</span></span> عطف على صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> لا محل لها من الإعراب، أو مستأنفة لا محل لها من الإعراب، والواو عائدة على <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span>، والمراد بها آلهتهم.</p></div>"
  16,74,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فلا تضربوا لله الأمثال﴾</span></span>: الفاء استئنافية، والجملة بعدها مستأنفة لا محل لها من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿لا﴾</span></span> ناهية، و<span class="hlt"><span class="qpc-hafs">﴿تضربوا﴾</span></span> فعل مضارع مجزوم، والواو فاعل، و<span class="hlt"><span class="qpc-hafs">﴿لله﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تضربوا﴾</span></span>، والأمثال مفعول به.</p><p><span class="hlt"><span class="qpc-hafs">﴿إن الله يعلم﴾</span></span>: إن حرف ناسخ، ولفظ الجلالة اسمها، وجملة يعلم خبر، والجملة تعليلية.</p><p><span class="hlt"><span class="qpc-hafs">﴿وأنتم لا تعلمون﴾</span></span>: الواو حالية، وأنتم مبتدأ، وجملة لا تعلمون خبر.</p></div>"
  16,75,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ضرب الله مثلا عبدا مملوكا لا يقدر على شيء﴾</span></span>: جملة مستأنفة لا محل لها من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿ضرب الله مثلًا﴾</span></span> فعل وفاعل ومفعول به، و<span class="hlt"><span class="qpc-hafs">﴿عبدًا﴾</span></span> بدل من <span class="hlt"><span class="qpc-hafs">﴿مثلًا﴾</span></span>، ومملوكًا صفة، وجملة <span class="hlt"><span class="qpc-hafs">﴿لا يقدر على شيء﴾</span></span> صفة ثانية، و<span class="hlt"><span class="qpc-hafs">﴿على شيء﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يقدر﴾</span></span>، أي: من التصرفات.</p><p><span class="hlt"><span class="qpc-hafs">﴿ومن رزقناه منا رزقا حسنا﴾</span></span>: الواو عاطفة، ومن عطف على <span class="hlt"><span class="qpc-hafs">﴿عبدًا مملوكًا﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿مَن﴾</span></span> اسم موصول، أو نكرة موصوفة، كأنه قيل: وحرًّا رزقناه ليطابق عبدًا، وجملة <span class="hlt"><span class="qpc-hafs">﴿رزقناه﴾</span></span> صلة على الأول لا محل لها من الإعراب، وصفة على الثاني، ونا فاعل، والهاء مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿منا﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿رزقناه﴾</span></span>، ورزقًا مفعول به ثان، أو مفعول مطلق منصوب، وحسنًا صفة لـ<span class="hlt"><span class="qpc-hafs">﴿رزقًا﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿فهو ينفق منه سرا وجهرا هل يستوون﴾</span></span>: الفاء عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿هو﴾</span></span> مبتدأ، وجملة ينفق خبر، و<span class="hlt"><span class="qpc-hafs">﴿منه﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿ينفق﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿سرا﴾</span></span> نائب مفعول مطلق، أي: إنفاقا سرا، أو منصوب على الحال، أي: مُسِرًّا. و<span class="hlt"><span class="qpc-hafs">﴿جهرا﴾</span></span> معطوف على <span class="hlt"><span class="qpc-hafs">﴿سرا﴾</span></span> منصوب. و<span class="hlt"><span class="qpc-hafs">﴿هل﴾</span></span> حرف استفهام للنفي. و<span class="hlt"><span class="qpc-hafs">﴿يستوون﴾</span></span> فعل مضارع مرفوع بثبوت النون لأنه من الأفعال الخمسة، والواو ضمير مبني في رفع فاعل.</p><p><span class="hlt"><span class="qpc-hafs">﴿الحمد لله بل أكثرهم لا يعلمون﴾</span></span>: الحمد مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿لله﴾</span></span> جار ومجرور متعلقان بمحذوف خبر، وبل حرف إضراب، وأكثرهم مبتدأ، وجملة <span class="hlt"><span class="qpc-hafs">﴿لا يعلمون﴾</span></span> خبر.</p></div>"
  16,76,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وضرب الله مثلا رجلين﴾</span></span>: الواو عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿ضرب الله مثلًا﴾</span></span> فعل وفاعل ومفعول به، ورجلين بدل من <span class="hlt"><span class="qpc-hafs">﴿مثلًا﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿أحدهما أبكم لا يقدر على شيء﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿أحدهما﴾</span></span> مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿أبكم﴾</span></span> خبره، وجملة <span class="hlt"><span class="qpc-hafs">﴿لا يقدر على شيء﴾</span></span> صفة <span class="hlt"><span class="qpc-hafs">﴿أبكم﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿وهو كلٌّ على مولاه﴾</span></span>: الواو حالية، و<span class="hlt"><span class="qpc-hafs">﴿هو﴾</span></span> مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿كلٌّ﴾</span></span> خبره، و<span class="hlt"><span class="qpc-hafs">﴿على مولاه﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿كلٌّ﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿أينما يوجهه لا يأت بخير﴾</span></span>: أينما اسم شرط جازم في محل نصب على الظرفية المكانية متعلق بفعل الشرط، وقيل: بجوابه، ولا نافية، و<span class="hlt"><span class="qpc-hafs">﴿يأت﴾</span></span> جواب الشرط، و<span class="hlt"><span class="qpc-hafs">﴿بخير﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يأت﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿هل يستوي هو ومن يأمر بالعدل وهو على صراط مستقيم﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿هل﴾</span></span> حرف استفهام معناه النفي، ويستوي فعل مضارع، و<span class="hlt"><span class="qpc-hafs">﴿هو﴾</span></span> تأكيد للفاعل المستتر، و<span class="hlt"><span class="qpc-hafs">﴿مَن﴾</span></span> عطف على الفاعل المستتر في <span class="hlt"><span class="qpc-hafs">﴿يستوي﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿هو﴾</span></span> مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿على صراط مستقيم﴾</span></span> جار ومجرور متعلقان بمحذوف خبره، والجملة الاسمية صلة <span class="hlt"><span class="qpc-hafs">﴿مَن﴾</span></span> لا محل لها من الإعراب.</p></div>"
  16,77,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ولله غيب السماوات والأرض وما أمر الساعة إلا كلمح البصر أو هو أقرب﴾</span></span>: الواو استئنافية، و<span class="hlt"><span class="qpc-hafs">﴿لله﴾</span></span> جار ومجرور متعلقان بمحذوف خبر مقدم، وغيب السماوات والأرض مبتدأ مؤخر، وجملة <span class="hlt"><span class="qpc-hafs">﴿ولله غيب السماوات والأرض﴾</span></span> مستأنفة لا محل لها من الإعراب، والواو عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> نافية، وأمر مبتدأ، والساعة مضاف إليه، وإلا أداة حصر، و<span class="hlt"><span class="qpc-hafs">﴿كلمح البصر﴾</span></span> الكاف اسم بمعنى مثل مبني على الفتح في محل رفع خبر، و<span class="hlt"><span class="qpc-hafs">﴿لمح﴾</span></span> مضاف إليه، و<span class="hlt"><span class="qpc-hafs">﴿البصر﴾</span></span> مضاف إليه، و<span class="hlt"><span class="qpc-hafs">﴿أو﴾</span></span> حرف عطف، و<span class="hlt"><span class="qpc-hafs">﴿هو﴾</span></span> مبتدأ، وأقرب خبره.</p><p><span class="hlt"><span class="qpc-hafs">﴿إن الله على كل شيء قدير﴾</span></span>: إن حرف ناسخ، ولفظ الجلالة اسمها، و<span class="hlt"><span class="qpc-hafs">﴿على كل شيء﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿قدير﴾</span></span>، وقدير خبر إن.</p></div>"
  16,78,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿والله أخرجكم من بطون أمهاتكم﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿الله﴾</span></span> مبتدأ، وجملة أخرجكم خبر، و<span class="hlt"><span class="qpc-hafs">﴿من بطون أمهاتكم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أخرجكم﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿لا تعلمون شيئا﴾</span></span>: الجملة في محل نصب على الحال من الكاف، أي: غير عالمين شيئًا، و<span class="hlt"><span class="qpc-hafs">﴿شيئًا﴾</span></span> مفعول به.</p><p><span class="hlt"><span class="qpc-hafs">﴿وجعل لكم السمع والأبصار والأفئدة لعلكم تشكرون﴾</span></span>: الواو عاطفة، وجعل عطف على أخرجكم، والفاعل مستتر تقديره: هو، و<span class="hlt"><span class="qpc-hafs">﴿لكم﴾</span></span> جار ومجرور متعلقان بمحذوف مفعول ثان لجعل، والسمع مفعوله الأول، والأبصار والأفئدة عطف عليه، ولعل حرف ناسخ، والكاف اسمها، وجملة تشكرون خبرها.</p></div>"
  16,79,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ألم يروا إلى الطير مسخرات في جو السماء﴾</span></span>: الهمزة للاستفهام التقريري، ولم حرف نفي وقلب وجزم، ويروا فعل مضارع مجزوم بلم، والواو فاعل، و<span class="hlt"><span class="qpc-hafs">﴿إلى الطير﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يروا﴾</span></span>، ومسخرات حال، و<span class="hlt"><span class="qpc-hafs">﴿في جو السماء﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿مسخرات﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿ما يمسكهن إلا الله﴾</span></span>: الجملة حالية، وما نافية، ويمسكهن فعل، وفاعل مستتر، ومفعول به، وإلا أداة حصر، و<span class="hlt"><span class="qpc-hafs">﴿الله﴾</span></span> فاعل.</p><p><span class="hlt"><span class="qpc-hafs">﴿إن في ذلك لآيات لقوم يؤمنون﴾</span></span>: إن وخبرها المقدم، واللام المزحلقة، وآيات اسمها المؤخر، و<span class="hlt"><span class="qpc-hafs">﴿لقوم﴾</span></span> جار ومجرور متعلقان بمحذوف صفة لـ<span class="hlt"><span class="qpc-hafs">﴿آيات﴾</span></span>، وجملة يؤمنون صفة لقوم.</p></div>"