quran[8]{c,v,t}:
  28,14,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ولما بلغ أشده واستوى آتيناه حكما وعلما وكذلك نجزي المحسنين﴾</span></span>: الواو استئنافية، ولما: حينية، أو رابطة، وبلغ: فعل ماض، وفاعله مستتر تقديره: هو، وأشده: مفعول به، واستوى: عطف على بلغ، وجملة آتيناه: لا محل لها من الإعراب، لأنها جواب شرط غير جازم، وآتيناه: فعل ماض وفاعل ومفعول به أول، وحكمًا: مفعول به ثان، وعلمًا: عطف على <span class="hlt"><span class="qpc-hafs">﴿حكمًا﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿ولما بلغ...﴾</span></span> مستأنفة لا محل لها من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿كذلك﴾</span></span>: الكاف: اسم بمعنى مثل مبني على الفتح في محل نصب صفة لمصدر محذوف مقدم على عامله، أي: وجزاءً مثلَ ذلك نجزي المحسنين، وذلك: <span class="hlt"><span class="qpc-hafs">﴿ذا﴾</span></span> اسم إشارة في محل جر مضاف إليه، واللام للبعد، والكاف حرف خطاب، و<span class="hlt"><span class="qpc-hafs">﴿نجزي﴾</span></span> فعل مضارع، والفاعل مستتر تقديره نحن، و<span class="hlt"><span class="qpc-hafs">﴿المحسنين﴾</span></span> مفعول به.</p></div>"
  28,15,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ودخل المدينة على حين غفلة من أهلها﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿ودخل المدينة﴾</span></span>: عطف على محذوف، ودخل المدينة: فعل وفاعل مستتر، ومفعول على السعة، وعلى حين غفلة: جار ومجرور متعلقان بمحذوف حال من المدينة، أومن فاعل دخل، أي: مختلسًا، ومن أهلها: جار ومجرور متعلقان بمحذوف صفة لغفلة.</p><p><span class="hlt"><span class="qpc-hafs">﴿فوجد فيها رجلين يقتتلان هذا من شيعته وهذا من عدوه﴾</span></span>: فوجد: عطف على دخل، وفيها: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿وجد﴾</span></span>، ورجلين: مفعول به، وجملة يقتتلان: صفة لرجلين، وهذا: مبتدأ، ومن شيعته: جار ومجرور متعلقان بمحذوف خبر، والجملة صفة ثانية لرجلين، وقيل حال، <span class="hlt"><span class="qpc-hafs">﴿وهذا من عدوه﴾</span></span>: عطف عليها.</p><p><span class="hlt"><span class="qpc-hafs">﴿فاستغاثه الذي من شيعته على الذي من عدوه﴾</span></span>: الفاء عاطفة، واستغاثه: فعل ماض ومفعول به، والذي: فاعل، ومن شيعته: جار ومجرور متعلقان بمحذوف صلة وجملة الصلة لا محل لها من الإعراب.</p><p><span class="hlt"><span class="qpc-hafs">﴿فوكزه موسى فقضى عليه قال هذا من عمل الشيطان إنه عدو مضل مبين﴾</span></span>: فوكزه: عطف أيضًا، وموسى: فاعل، فقضى عليه: عطف على فوكزه، وقال: فعل ماض، والجملة مستأنفة لا محل لها من الإعراب، وهذا: مبتدأ، ومن عمل الشيطان: خبر، والجملة مقول القول، وجملة إنه عدو: تعليل، وإن حرف ناسخ، والهاء اسمها، وعدو خبرها، ومضل: صفة، ومبين: صفة ثانية.</p></div>"
  28,16,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قال رب إني ظلمت نفسي فاغفر لي فغفر له إنه هو الغفور الرحيم﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿رب﴾</span></span>: منادى مضاف إلى ياء المتكلم المحذوفة، وإن حرف ناسخ، والياء اسمها، وجملة <span class="hlt"><span class="qpc-hafs">﴿ظلمت نفسي﴾</span></span>: خبر إن، فاغفر لي: الفاء عاطفة، واغفر فعل دعاء، ولي: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿اغفر﴾</span></span>، فغفر له: عطف، وإن حرف ناسخ، والهاء اسمها، و<span class="hlt"><span class="qpc-hafs">﴿هو﴾</span></span>: ضمير فصل، والغفور: خبر، والرحيم: خبر ثان، أو <span class="hlt"><span class="qpc-hafs">﴿هو﴾</span></span>: مبتدأ، والغفور الرحيم: خبران له، والجملة خبر إن.</p></div>"
  28,17,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قال رب بما أنعمت علي فلن أكون ظهيرا للمجرمين﴾</span></span>: بما: الباء حرف قسم وجر، وجواب القسم محذوف، تقديره: أقسم بإنعامك علي بالمغفرة لأتوبن، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> مصدرية، والمصدر المؤول مجرور بباء القسم، والفاء عاطفة على الجواب المحذوف، ولن: حرف نفي ونصب واستقبال، وأكون: فعل مضارع ناقص، واسمها مستتر تقديره: أنا، وظهيرًا: خبرها، وللمجرمين: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿ظهيرًا﴾</span></span>، وقيل: الباء ومدخولها متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿اعصمني﴾</span></span> المقدر، والفاء في <span class="hlt"><span class="qpc-hafs">﴿فلن أكون﴾</span></span>، هي الفصيحة، لأنها جواب شرط مقدر.</p></div>"
  28,18,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فأصبح في المدينة خائفا يترقب﴾</span></span>: الفاء عاطفة، وأصبح: فعل ماض ناقص، اسمها مستتر، تقديره: هو، وفي المدينة: جار ومجرور متعلقان بمحذوف حال، وخائفًا: خبر أصبح، أو في المدينة: جار ومجرور متعلقان بمحذوف خبر أصبح، وخائفًا: حال، أو أن الفعل <span class="hlt"><span class="qpc-hafs">﴿أصبح﴾</span></span> تام وفاعله مستتر، وفي المدينة جار ومجرور متعلقان به، وخائفًا حال، وجملة يترقب: حال ثانية، أو خبر ثان، أو حال من الضمير في <span class="hlt"><span class="qpc-hafs">﴿خائفًا﴾</span></span>، مفعول يترقب محذوف، أي: يترقب المكروه.</p><p><span class="hlt"><span class="qpc-hafs">﴿فإذا الذي استنصره بالأمس يستصرخه﴾</span></span>: الفاء عاطفة، وإذا: فجائية، والذي: مبتدأ، وجملة استنصره: صلة الموصول لا محل لها من الإعراب. وبالأمس: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿استنصر﴾</span></span>، وجملة يستصرخه: خبر الذي، ومتعلق يستصرخه محذوف، أي: على قبطي آخر.</p><p><span class="hlt"><span class="qpc-hafs">﴿قال له موسى إنك لغوي مبين﴾</span></span>: قال: فعل ماض، و<span class="hlt"><span class="qpc-hafs">﴿له﴾</span></span>: جار ومجرور متعلقان به، وموسى: فاعل، وإنك: إن حرف ناسخ، والكاف اسمها، واللام المزحلقة، وغوي مبين: خبران لـ<span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span>.</p></div>"
  28,19,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فلما أن أراد أن يبطش بالذي هو عدو لهما﴾</span></span>: الفاء عاطفة، ولما: حينية، أو رابطة، وأن: صلة، وأراد: فعل ماض، وأن وما بعده في تأويل مصدر مفعول أراد، وبالذي: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يبطش﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿هو﴾</span></span>: مبتدأ، وعدو: خبر، ولهما: جار ومجرور متعلقان بمحذوف صفة، وجملة <span class="hlt"><span class="qpc-hafs">﴿هو عدو لهما﴾</span></span> صلة الذي لا محل لها من الإعراب.</p><p><span class="hlt"><span class="qpc-hafs">﴿قال يا موسى أتريد أن تقتلني كما قتلت نفسا بالأمس﴾</span></span>: قال: فعل ماض، وفاعله مستتر، أتريد: الهمزة للاستفهام، وتريد فعل مضارع مرفوع، وأن وما في حيزها مفعول تريد، و<span class="hlt"><span class="qpc-hafs">﴿كما﴾</span></span> الكاف اسم بمعنى مثل مبني على الفتح في محل نصب نعت لمفعول مطلق محذوف، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> مصدرية مؤولة مع ما بعدها بمصدر مضاف إليه، والتقدير: تقتلني قتلا مثلَ قتلك نفسًا بالأمس، و<span class="hlt"><span class="qpc-hafs">﴿قتلت﴾</span></span> فعل وفاعل، ونفسًا مفعول به، وبالأمس: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿قتلت﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿قتلت﴾</span></span> صلة الموصول الحرفي <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> لا محل لها من الإعراب.</p><p><span class="hlt"><span class="qpc-hafs">﴿إن تريد إلا أن تكون جبارا في الأرض وما تريد أن تكون من المصلحين﴾</span></span>: إن نافية، وتريد: فعل مضارع مرفوع، وفاعله مستتر تقديره: أنت، وإلا: أداة حصر، وأن وما بعدها في تأويل مصدر مفعول تريد، وجبارًا: خبر تكون، وفي الأرض: جار ومجرور متعلقان بمحذوف صفة لـ<span class="hlt"><span class="qpc-hafs">﴿جبارًا﴾</span></span>، وما نافية، وتريد: فعل مضارع مرفوع، وفاعله مستتر تقديره: أنت، وأن وما بعدها في تأويل مصدر مفعول تريد، و<span class="hlt"><span class="qpc-hafs">﴿من المصلحين﴾</span></span> جار ومجرور متعلقان بمحذوف خبر تكون.</p></div>"
  28,20,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وجاء رجل من أقصى المدينة يسعى﴾</span></span>: الواو عاطفة على محذوف، وجاء رجل: فعل وفاعل، ومن أقصى المدينة: الجار والمجرور متعلقان بمحذوف صفة لرجل، وجملة يسعى: صفة ثانية، أو حال، أو من أقصى المدينة: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿جاء﴾</span></span>، وجملة يسعى: صفة فقط.</p><p><span class="hlt"><span class="qpc-hafs">﴿قال يا موسى إن الملأ يأتمرون بك ليقتلوك فاخرج إني لك من الناصحين﴾</span></span>: إن الملأ: إن حرف ناسخ، والملأ اسمها، وجملة يأتمرون: خبر إن، وبك: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يأتمرون﴾</span></span>، وليقتلوك: اللام تعليلية، ويقتلوك فعل مضارع منصوب بأن مضمرة بعدها، والمصدر المؤول من أن والفعل مجرور باللام، والجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يأتمرون﴾</span></span>، فاخرج: الفاء الفصيحة، أي: إن سمعت نصيحتي فاخرج، وإني: إن حرف ناسخ، والياء اسمها، ولك: جار ومجرور متعلقان بمحذوف حال، وقيل: متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿الناصحين﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿من الناصحين﴾</span></span>: جار ومجرور متعلقان بمحذوف خبر إن.</p></div>"
  28,21,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فخرج منها خائفا يترقب قال رب نجني من القوم الظالمين﴾</span></span>: الفاء عاطفة على محذوف، ومنها: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿خرج﴾</span></span>، وخائفًا: حال، وجملة يترقب: حال ثانية، ومفعول يترقب محذوف، أي: الشر، أو لحوقهم به، وقيل: يترقب غوث الله، ورب: منادى، ونجني: فعل دعاء، والياء مفعول به، ومن القوم: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿نجني﴾</span></span>، والظالمين: صفة.</p></div>"