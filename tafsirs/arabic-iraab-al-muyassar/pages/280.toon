quran[8]{c,v,t}:
  16,111,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿يوم تأتي كل نفس تجادل عن نفسها﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿يوم﴾</span></span> مفعول به لفعل محذوف تقديره: اذكر، وجملة <span class="hlt"><span class="qpc-hafs">﴿تأتي﴾</span></span> في محل جر مضاف إليه، و<span class="hlt"><span class="qpc-hafs">﴿كل نفس﴾</span></span> فاعل تأتي، وجملة <span class="hlt"><span class="qpc-hafs">﴿تجادل﴾</span></span> حال، و<span class="hlt"><span class="qpc-hafs">﴿عن نفسها﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تجادل﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿وتوفى كل نفس ما عملت وهم لا يظلمون﴾</span></span>: الواو عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿توفى﴾</span></span> عطف على <span class="hlt"><span class="qpc-hafs">﴿تجادل﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿كل نفس﴾</span></span> نائب فاعل، و<span class="hlt"><span class="qpc-hafs">﴿ما عملت﴾</span></span> مفعول <span class="hlt"><span class="qpc-hafs">﴿توفى﴾</span></span> الثاني، <span class="hlt"><span class="qpc-hafs">﴿وهم﴾</span></span> الواو حالية، أو عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> مبتدأ، وجملة <span class="hlt"><span class="qpc-hafs">﴿لا يظلمون﴾</span></span> خبر.</p></div>"
  16,112,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وضرب الله مثلا قرية﴾</span></span>: الواو استئنافية، والجملة بعدها مستأنفة لا محل لها من الإعراب، وضرب الله مثلًا فعل وفاعل ومفعول به، وقرية بدل من <span class="hlt"><span class="qpc-hafs">﴿مثلًا﴾</span></span>، أي: جعل القرية الموسومة بهذه السمات مثلًا لكل قوم أنعم الله عليهم فأبطرتهم النعمة فكفروا.</p><p><span class="hlt"><span class="qpc-hafs">﴿كانت آمنة مطمئنة يأتيها رزقها رغدا من كل مكان﴾</span></span>: كانت فعل ماض ناقص ناسخ، واسمها مستتر، وآمنة خبرها، ومطمئنة خبر ثان، وجملة <span class="hlt"><span class="qpc-hafs">﴿كانت﴾</span></span> صفة لقرية، يأتيها فعل مضارع، ومفعول به مقدم، ورزقها فاعل مؤخر، وجملة <span class="hlt"><span class="qpc-hafs">﴿يأتيها﴾</span></span> خبر ثالث، و<span class="hlt"><span class="qpc-hafs">﴿رغدًا﴾</span></span> حال من رزقها، أو نائب مفعول مطلق، أي: إتيانًا رغدا. و<span class="hlt"><span class="qpc-hafs">﴿من كل مكان﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يأتيها﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿فكفرت بأنعم الله فأذاقها الله لباس الجوع والخوف بما كانوا يصنعون﴾</span></span>: الفاء عاطفة، وكفرت فعل ماض، والفاعل مستتر يعود على القرية، و<span class="hlt"><span class="qpc-hafs">﴿بأنعم الله﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿كفرت﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿فأذاقها﴾</span></span> الفاء عاطفة للتعقيب، و<span class="hlt"><span class="qpc-hafs">﴿أذاقها﴾</span></span> فعل، ومفعول به مقدم، وفاعل مؤخر، ولباس الجوع والخوف مفعول ثان، والباء حرف جر للسببية، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> مصدرية، أو موصولة، والعائد محذوف، أي: بسبب صنعهم، أو بسبب الذي كانوا يصنعونه، و<span class="hlt"><span class="qpc-hafs">﴿كانوا﴾</span></span> فعل ماض ناقص ناسخ، والواو اسمها، وجملة يصنعون خبرها.</p></div>"
  16,113,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ولقد جاءهم رسول منهم فكذبوه﴾</span></span>: الواو عاطفة، واللام واقعة في جواب قسم مقدر، وقد حرف تحقيق، وجاءهم رسول فعل ماض ومفعول به مقدم وفاعل مؤخر، و<span class="hlt"><span class="qpc-hafs">﴿منهم﴾</span></span> جار ومجرور متعلقان بمحذوف صفة لرسول، <span class="hlt"><span class="qpc-hafs">﴿فكذبوه﴾</span></span> الفاء حرف عطف، وكذبوه فعل ماض وفاعل ومفعول به.</p><p><span class="hlt"><span class="qpc-hafs">﴿فأخذهم العذاب وهم ظالمون﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿فأخذهم﴾</span></span> عطف على <span class="hlt"><span class="qpc-hafs">﴿فكذبوه﴾</span></span>، والعذاب فاعل، والواو حالية، و<span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> مبتدأ، وظالمون خبر، والجملة حالية.</p></div>"
  16,114,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فكلوا مما رزقكم الله حلالا طيبا﴾</span></span>: الفاء الفصيحة، و<span class="hlt"><span class="qpc-hafs">﴿مما﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿كلوا﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿رزقكم﴾</span></span> صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> لا محل لها من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿حلالًا﴾</span></span> حال، أو مفعول به لـ<span class="hlt"><span class="qpc-hafs">﴿كلوا﴾</span></span>، وطيبًا صفة.</p><p><span class="hlt"><span class="qpc-hafs">﴿واشكروا نعمت الله إن كنتم إياه تعبدون﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿واشكروا نعمة الله﴾</span></span> فعل أمر وفاعل ومفعول به، وإن شرطية، وكنتم فعل الشرط، وكنتم فعل ماض ناقص ناسخ، والتاء اسمها، و<span class="hlt"><span class="qpc-hafs">﴿إياه﴾</span></span> مفعول مقدم لـ<span class="hlt"><span class="qpc-hafs">﴿تعبدون﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿تعبدون﴾</span></span> خبر <span class="hlt"><span class="qpc-hafs">﴿كنتم﴾</span></span>.</p></div>"
  16,115,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إنما حرم عليكم الميتة والدم ولحم الخنزير وما أهل لغير الله به﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿إنما﴾</span></span> كافة ومكفوفة، و<span class="hlt"><span class="qpc-hafs">﴿حرم﴾</span></span> فعل وفاعل مستتر، و<span class="hlt"><span class="qpc-hafs">﴿عليكم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿حرم﴾</span></span>، والميتة مفعول به، والدم ولحم الخنزير عطف على الميتة، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> عطف أيضًا، وجملة <span class="hlt"><span class="qpc-hafs">﴿أهل﴾</span></span> صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> لا محل لها من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿لغير الله﴾</span></span> جار ومجرور متعلقان بمحذوف حال، و<span class="hlt"><span class="qpc-hafs">﴿به﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أهل﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿فمن اضطر غير باغ ولا عاد﴾</span></span>: الفاء تفريعية، ومن اسم شرط جازم في محل رفع مبتدأ، واضطر فعل ماض مبني لما لم يُسَمَّ فاعله في محل جزم فعل الشرط، ونائب الفاعل مستتر يعود على <span class="hlt"><span class="qpc-hafs">﴿مَن﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿غير باغ﴾</span></span> حال، و<span class="hlt"><span class="qpc-hafs">﴿لا عاد﴾</span></span> عطف على <span class="hlt"><span class="qpc-hafs">﴿باغ﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿فإن الله غفور رحيم﴾</span></span>: الفاء رابطة، وإن حرف ناسخ، ولفظ الجلالة اسمها، وغفور خبرها الأول، ورحيم خبرها الثاني، والجملة في محل جزم جواب الشرط.</p></div>"
  16,116,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ولا تقولوا لما تصف ألسنتكم الكذب﴾</span></span>: لا ناهية، وتقولوا مضارع مجزم بـ<span class="hlt"><span class="qpc-hafs">﴿لا﴾</span></span>، والواو فاعل، و<span class="hlt"><span class="qpc-hafs">﴿لما تصف﴾</span></span> اللام حرف جر، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> مصدرية، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> مع مدخولها في محل جر باللام، والجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تقولوا﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿ألسنتكم﴾</span></span> فاعل <span class="hlt"><span class="qpc-hafs">﴿تصف﴾</span></span>، والكذب مفعول <span class="hlt"><span class="qpc-hafs">﴿تصف﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿هذا حلال﴾</span></span> مقول القول، <span class="hlt"><span class="qpc-hafs">﴿وهذا حرام﴾</span></span> عطف على <span class="hlt"><span class="qpc-hafs">﴿هذا حلال﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿لتفتروا﴾</span></span> بدل من قوله: <span class="hlt"><span class="qpc-hafs">﴿لما تصف﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿على الله﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تفتروا﴾</span></span>، والكذب مفعول به لـ<span class="hlt"><span class="qpc-hafs">﴿تفتروا﴾</span></span>، أو لـ<span class="hlt"><span class="qpc-hafs">﴿تقولوا﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿هذا حلال﴾</span></span> بدل منه، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> موصولة، أي: ولا تقولوا الكذب لما تصفه ألسنتكم فتقولوا: هذا حرام وهذا حلال، وقيل: إن <span class="hlt"><span class="qpc-hafs">﴿الكذب﴾</span></span> بدل من مفعول <span class="hlt"><span class="qpc-hafs">﴿تصف﴾</span></span> المحذوف، أي: لما تصفه.</p><p><span class="hlt"><span class="qpc-hafs">﴿إن الذين يفترون على الله الكذب لا يفلحون﴾</span></span>: إن حرف ناسخ، والذين اسمها، وجملة يفترون صلة الذين لا محل لها من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿على الله﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يفترون﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿الكذب﴾</span></span> مفعول <span class="hlt"><span class="qpc-hafs">﴿يفترون﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿لا يفلحون﴾</span></span> خبر إن.</p></div>"
  16,117,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿متاع قليل ولهم عذاب أليم﴾</span></span>: متاع خبر لمبتدأ محذوف، أي: ذلك العمل الذي هو ديدنهم متاع قليل الفائدة، أو مبتدأ محذوف الخبر، أي: لهم متاع، و<span class="hlt"><span class="qpc-hafs">﴿قليل﴾</span></span> صفة <span class="hlt"><span class="qpc-hafs">﴿متاع﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿لهم﴾</span></span> جار ومجرور متعلقان بمحذوف خبر مقدم، و<span class="hlt"><span class="qpc-hafs">﴿عذاب﴾</span></span> مبتدأ مؤخر، و<span class="hlt"><span class="qpc-hafs">﴿أليم﴾</span></span> صفة <span class="hlt"><span class="qpc-hafs">﴿عذاب﴾</span></span>.</p></div>"
  16,118,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وعلى الذين هادوا حرمنا ما قصصنا عليك من قبل﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿وعلى الذين﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿حرمنا﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿هادوا﴾</span></span> صلة <span class="hlt"><span class="qpc-hafs">﴿الذين﴾</span></span> لا محل لها من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> مفعول به، وجملة <span class="hlt"><span class="qpc-hafs">﴿قصصنا﴾</span></span> صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> لا محل لها من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿عليك﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿قصصنا﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿من قبل﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿حرمنا﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿وما ظلمناهم ولكن كانوا أنفسهم يظلمون﴾</span></span>: الواو عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> نافية، و<span class="hlt"><span class="qpc-hafs">﴿ظلمناهم﴾</span></span> فعل وفاعل ومفعول به، والواو حالية، و<span class="hlt"><span class="qpc-hafs">﴿لكن﴾</span></span> مخففة مهملة فهي حرف استدراك، و<span class="hlt"><span class="qpc-hafs">﴿كانوا﴾</span></span> فعل ماض ناقص ناسخ، والواو اسمها، و<span class="hlt"><span class="qpc-hafs">﴿أنفسهم﴾</span></span> مفعول مقدم لـ<span class="hlt"><span class="qpc-hafs">﴿يظلمون﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿يظلمون﴾</span></span> خبر <span class="hlt"><span class="qpc-hafs">﴿كانوا﴾</span></span>.</p></div>"