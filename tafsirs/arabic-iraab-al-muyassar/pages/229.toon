quran[9]{c,v,t}:
  11,63,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قال يا قوم أرأيتم إن كنت على بينة من ربي﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿أرأيتم﴾</span></span> الهمزة للاستفهام، ورأى فعل ماض مبني على السكون، والتاء فاعل، وإن شرطية، وكنت فعل الشرط، والتاء اسم كان، وعلى بينة خبر كان، ومن ربي صفة لبينة.</p><p><span class="hlt"><span class="qpc-hafs">﴿وآتاني منه رحمة فمن ينصرني من الله إن عصيته﴾</span></span>: الواو عاطفة، وآتاني عطف على كنت، والياء مفعول به أول، ومنه حال، ورحمة مفعول به ثان، والفاء رابطة لجواب الشرط، ومن اسم استفهام مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿ينصرني﴾</span></span> فعل مضارع وفاعل مستتر ومفعول به، والجملة خبر، وجملة <span class="hlt"><span class="qpc-hafs">﴿فمن ينصرني﴾</span></span> جواب إن، وإن الثانية شرطية، وعصيته فعلها، وجوابها محذوف دل عليه جواب الأولى، أي: فمن ينصرني، والاستفهام هنا معناه النفي، فكأنه قال: فلا ناصر لي من الله إن عصيته.</p><p><span class="hlt"><span class="qpc-hafs">﴿فما تزيدونني غير تخسير﴾</span></span>: الفاء عاطفة، وما نافية، وتزيدونني فعل مضارع وفاعل ومفعول به، وغير مفعول ثان لـ<span class="hlt"><span class="qpc-hafs">﴿تزيدونني﴾</span></span>.</p></div>"
  11,64,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ويا قوم هذه ناقة الله لكم آية﴾</span></span>: الواو عاطفة، وهذه مبتدأ، وناقة الله خبر، ولكم حال، لأنه كان في الأصل صفة لـ<span class="hlt"><span class="qpc-hafs">﴿آية﴾</span></span>، وآية حال من ناقة الله، والعامل فيها ما دل عليه اسم الإشارة من معنى الفعل.</p><p><span class="hlt"><span class="qpc-hafs">﴿فذروها تأكل في أرض الله﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿فذروها﴾</span></span> الفاء عاطفة، وذروها فعل أمر ومفعول به، وتأكل جواب الطلب مجزوم، وفي أرض الله جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تأكل﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿ولا تمسوها بسوء فيأخذكم عذاب قريب﴾</span></span>: الواو عاطفة، ولا تمسوها عطف على ما تقدم، ولا ناهية، وتمسوها مجزوم بلا، والواو فاعل، و<span class="hlt"><span class="qpc-hafs">﴿ها﴾</span></span> مفعول به، وبسوء جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تمسوها﴾</span></span>، والفاء فاء السببية، والكاف مفعول به، وعذاب فاعل، وقريب صفة.</p></div>"
  11,65,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فعقروها فقال تمتعوا في داركم ثلاثة أيام﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿فعقروها﴾</span></span> الفاء عاطفة، وعقروها فعل ماض وفاعل ومفعول به، <span class="hlt"><span class="qpc-hafs">﴿فقال﴾</span></span> عطف على عقروها، وجملة تمتعوا من فعل الأمر والفاعل مقول القول، وفي داركم حال، وثلاثة أيام ظرف متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿تمتعوا﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿ذلك وعد غير مكذوب﴾</span></span>: اسم الإشارة مبتدأ، ووعد خبر، وغير مكذوب صفته.</p></div>"
  11,66,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فلما جاء أمرنا نجينا صالحا والذين آمنوا معه﴾</span></span>: الفاء عاطفة، ولما حينية أو رابطة، وجاء أمرنا فعل وفاعل، ونجينا صالحًا فعل وفاعل ومفعول به، والجملة لا محل لها من الإعراب، والذين عطف على <span class="hlt"><span class="qpc-hafs">﴿صالحًا﴾</span></span>، وجملة آمنوا صلة الذين لا محل لها من الإعراب، ومعه ظرف مكان متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿آمنوا﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿برحمة منا ومن خزي يومئذ﴾</span></span>: برحمة حال، أي: متلبسين برحمة، ومنا صفة، ومن خزي جار ومجرور متعلقان بمحذوف دل عليه ما قبله، أي: ونجيناهم من خزي، و<span class="hlt"><span class="qpc-hafs">﴿يومئذ﴾</span></span> يوم: مضاف إليه، وإذٍ: اسم مبني على السكون المقدر لاشتغال المحل بتنوين العوض في محل جر مضاف إليه، والتنوين عوض عن جملة محذوفة والتقدير: يوم إذ جاء أمرنا.</p><p><span class="hlt"><span class="qpc-hafs">﴿إن ربك هو القوي العزيز﴾</span></span>: إن حرف ناسخ، وربك اسمها، و<span class="hlt"><span class="qpc-hafs">﴿هو﴾</span></span> ضمير فصل أو مبتدأ، والقوي العزيز خبران لـ<span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span>، أو لـ<span class="hlt"><span class="qpc-hafs">﴿هو﴾</span></span>، والجملة خبر إن.</p></div>"
  11,67,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وأخذ الذين ظلموا الصيحة فأصبحوا في ديارهم جاثمين﴾</span></span>: الواو عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿أخذ﴾</span></span> فعل ماض، والذين مفعول به، وجملة ظلموا صلة الذين لا محل لها من الإعراب، والصيحة فاعل، فأصبحوا عطف على أخذ، والواو اسم أصبح، وجاثمين خبرها، وفي ديارهم جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿جاثمين﴾</span></span>.</p></div>"
  11,68,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿كأن لم يغنوا فيها﴾</span></span>: كأن مخففة من الثقيلة، واسمها مستتر، أي: كأنهم، وجملة لم يغنوا خبرها، و<span class="hlt"><span class="qpc-hafs">﴿فيها﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يغنوا﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿ألا إن ثمود كفروا ربهم﴾</span></span>: ألا أداة تنبيه، وإن حرف ناسخ، وثمود اسمها، وكفروا فعل وفاعل، وربهم منصوب بنزع الخافض، أو نصبه على المفعولية بتضمين كفروا معنى جحدوا.</p><p><span class="hlt"><span class="qpc-hafs">﴿ألا بعدًا لثمود﴾</span></span>: ألا أداة تنبيه تأكيد للأولى، بعدًا منصوب على المصدر بفعل مقدر، أي: وقيل: بعدوا بعدًا، فهو مصدر بمعنى الدعاء عليهم، و<span class="hlt"><span class="qpc-hafs">﴿لثمود﴾</span></span> جار ومجرور.</p></div>"
  11,69,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ولقد جاءت رسلنا إبراهيم بالبشرى﴾</span></span>: اللام جواب للقسم المحذوف، وقد حرف تحقيق، وجاءت رسلنا فعل وفاعل، وإبراهيم مفعول به، وبالبشرى جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿جاءت﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿قالوا﴾</span></span>: فعل وفاعل.</p><p><span class="hlt"><span class="qpc-hafs">﴿سلامًا﴾</span></span>: مفعول به، أو نائب مفعول مطلق أي: نسلِّم سلاما.</p><p><span class="hlt"><span class="qpc-hafs">﴿قال﴾</span></span>: فعل ماض، وفاعله مستتر تقديره: هو.</p><p><span class="hlt"><span class="qpc-hafs">﴿سلام﴾</span></span>: مبتدأ، ساغ الابتداء به مع أنه نكرة لتضمنه معنى الدعاء، والخبر محذوف تقديره: سلام عليكم.</p><p><span class="hlt"><span class="qpc-hafs">﴿فما لبث أن جاء بعجل حنيذ﴾</span></span>: الفاء عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿ما لبث﴾</span></span> ما نافية، ولبث فعل ماض، فاعله أن وما في حيزها، أي: مجيئه، أو الفاعل مستتر، تقديره: إبراهيم، وإن وما في حيزها خبره، والتقدير: فلبثه أو الذي لبثه قدر مجيئه.</p></div>"
  11,70,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فلما رأى أيديهم لا تصل إليه نكرهم وأوجس منهم خيفة﴾</span></span>: الفاء عاطفة على محذوف، والتقدير: فقربه إليهم فلم يمدوا أيديهم فقال: ألا تأكلون؟ <span class="hlt"><span class="qpc-hafs">﴿فلما رأى أيديهم﴾</span></span> الرؤية هنا بصرية، وأيديهم مفعول به، وجملة لا تصل إليه حالية، وجملة <span class="hlt"><span class="qpc-hafs">﴿نكرهم﴾</span></span> لا محل لها من الإعراب، لأنها جواب <span class="hlt"><span class="qpc-hafs">﴿لما﴾</span></span>، وأوجس منهم عطف على نكرهم، وخيفة مفعول به، ومنهم حال، لأنه كان صفة لـ<span class="hlt"><span class="qpc-hafs">﴿خيفة﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿قالوا لا تخف إنا أرسلنا إلى قوم لوط﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿لا تخف﴾</span></span> لا ناهية، وتخف مجزوم بها، وإن حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> اسمها، وجملة أرسلنا خبرها، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> نائب فاعل، وإلى قوم لوط جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أرسلنا﴾</span></span>.</p></div>"
  11,71,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وامرأته قائمة فضحكت فبشرناها بإسحاق ومن وراء إسحاق يعقوب﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿وامرأته﴾</span></span> الواو حالية، أو الواو استئنافية والجملة بعدها مستأنفة لا محل لها من الإعراب، وامرأته مبتدأ، وقائمة خبر، فضحكت فعل ماض، وفاعله: هي، فبشرناها عطف أيضًا، وهو فعل وفاعل ومفعول به، وبإسحاق جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿بشرناها﴾</span></span>، ومن وراء إسحاق خبر مقدم، ويعقوب مبتدأ مؤخر.</p></div>"