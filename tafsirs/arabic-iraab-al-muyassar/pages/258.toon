quran[6]{c,v,t}:
  14,19,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ألم تر أن الله خلق السماوات والأرض بالحق﴾</span></span>: الهمزة للاستفهام التقريري، ولم حرف نفي وقلب وجزم، و<span class="hlt"><span class="qpc-hafs">﴿تر﴾</span></span> فعل مضارع مجزوم بـ<span class="hlt"><span class="qpc-hafs">﴿لم﴾</span></span>، وأن وما في حيزها سدت مسد مفعولي <span class="hlt"><span class="qpc-hafs">﴿تر﴾</span></span>، والسماوات مفعول خلق، و<span class="hlt"><span class="qpc-hafs">﴿بالحق﴾</span></span> جار ومجرور متعلقان بخلق، والباء للسببية، أو متعلقان بمحذوف حال، والباء للمصاحبة.</p><p><span class="hlt"><span class="qpc-hafs">﴿إن يشأ يذهبكم ويأت بخلق جديد﴾</span></span>: إن شرطية، ويشأ فعل الشرط، و<span class="hlt"><span class="qpc-hafs">﴿يذهبكم﴾</span></span> جواب الشرط، والكاف مفعول به، ويأت عطف على يذهبكم، و<span class="hlt"><span class="qpc-hafs">﴿بخلق﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يأت﴾</span></span>، وجديد صفة.</p></div>"
  14,20,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وما ذلك على الله بعزيز﴾</span></span>: الواو: عاطفة أو حالية، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> نافية حجازية تعمل عمل ليس، و<span class="hlt"><span class="qpc-hafs">﴿ذلك﴾</span></span> اسم ما، و<span class="hlt"><span class="qpc-hafs">﴿على الله﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿عزيز﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿بعزيز﴾</span></span>: الباء حرف جر صلة، و<span class="hlt"><span class="qpc-hafs">﴿عزيز﴾</span></span> خبر <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> الحجازية منصوب محلا مجرور بالباء لفظًا.</p></div>"
  14,21,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وبرزوا لله جميعا﴾</span></span>: الواو استئنافية، والجملة مستأنفة لا محل لها من الإعراب، وبرزوا فعل وفاعل، و<span class="hlt"><span class="qpc-hafs">﴿لله﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿برزوا﴾</span></span>، وجميعًا حال.</p><p><span class="hlt"><span class="qpc-hafs">﴿فقال الضعفاء للذين استكبروا﴾</span></span>: الفاء عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿قال الضعفاء﴾</span></span> فعل وفاعل، و<span class="hlt"><span class="qpc-hafs">﴿للذين﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿قال﴾</span></span>، وجملة استكبروا صلة الذين لا محل لها من الإعراب.</p><p><span class="hlt"><span class="qpc-hafs">﴿إنا كنا لكم تبعا﴾</span></span>: إنّا: <span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span> حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> اسمها، وجملة <span class="hlt"><span class="qpc-hafs">﴿إنا﴾</span></span> مقول القول، وكنا فعل ماض ناقص ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> اسمها، وجملة <span class="hlt"><span class="qpc-hafs">﴿كنا﴾</span></span> خبر إن، و<span class="hlt"><span class="qpc-hafs">﴿لكم﴾</span></span> جار ومجرور متعلقان بمحذوف حال، وتبعًا خبر كنا.</p><p><span class="hlt"><span class="qpc-hafs">﴿فهل أنتم مغنون عنا من عذاب الله من شيء﴾</span></span>: الفاء عاطفة، وهل حرف استفهام، وأنتم مبتدأ، ومغنون خبر، و<span class="hlt"><span class="qpc-hafs">﴿عنا﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿مغنون﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿من عذاب الله﴾</span></span> جار ومجرور متعلقان بمحذوف حال، و<span class="hlt"><span class="qpc-hafs">﴿مِن﴾</span></span> الثانية صلة، وشيء مفعول به محلا مجرور بمن لفظا.</p><p><span class="hlt"><span class="qpc-hafs">﴿قالوا لو هدانا الله لهديناكم سواء علينا أجزعنا أم صبرنا﴾</span></span>: قالوا فعل وفاعل، ولو حرف امتناع، و<span class="hlt"><span class="qpc-hafs">﴿هدانا الله﴾</span></span> فعل ومفعول به وفاعل، <span class="hlt"><span class="qpc-hafs">﴿لهديناكم﴾</span></span> اللام واقعة في جواب الشرط، وهديناكم فعل وفاعل ومفعول به، <span class="hlt"><span class="qpc-hafs">﴿سواء﴾</span></span> خبر مقدم، و<span class="hlt"><span class="qpc-hafs">﴿أجزعنا﴾</span></span> مبتدأ مؤخر، لأنه في تأويل مصدر، لأن الهمزة للتسوية والفعل بعدها يؤول بمصدر، وأم حرف عطف متصلة، وصبرنا عطف على جزعنا.</p><p><span class="hlt"><span class="qpc-hafs">﴿ما لنا من محيص﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> نافية، و<span class="hlt"><span class="qpc-hafs">﴿لنا﴾</span></span> جار ومجرور متعلقان بمحذوف خبر مقدم، و<span class="hlt"><span class="qpc-hafs">﴿مِن﴾</span></span> حرف جر صلة، و<span class="hlt"><span class="qpc-hafs">﴿محيص﴾</span></span> مبتدأ مؤخر مرفوع محلا مجرور بـ<span class="hlt"><span class="qpc-hafs">﴿مِن﴾</span></span> لفظًا.</p></div>"
  14,22,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وقال الشيطان لما قضي الأمر﴾</span></span>: الواو عاطفة، وقال الشيطان فعل وفاعل، ولما ظرفية حينية، أو رابطة، و<span class="hlt"><span class="qpc-hafs">﴿قضي الأمر﴾</span></span> فعل ونائب فاعل، والجملة في محل جر بإضافة الظرف إليها، أو لا محل لها من الإعراب.</p><p><span class="hlt"><span class="qpc-hafs">﴿إن الله وعدكم وعد الحق﴾</span></span>: إن حرف ناسخ، ولفظ الجلالة اسمها، وجملة <span class="hlt"><span class="qpc-hafs">﴿وعدكم﴾</span></span> خبرها، و<span class="hlt"><span class="qpc-hafs">﴿وعد﴾</span></span> مفعول مطلق، والحق مضاف إليه، وجملة <span class="hlt"><span class="qpc-hafs">﴿إن الله﴾</span></span> مقول القول.</p><p><span class="hlt"><span class="qpc-hafs">﴿ووعدتكم فأخلفتكم﴾</span></span>: الواو عاطفة، ووعدتكم عطف على وعدكم، فأخلفتكم فعل وفاعل ومفعول به وهو عطف على وعدتكم.</p><p><span class="hlt"><span class="qpc-hafs">﴿وما كان لي عليكم من سلطان إلا أن دعوتكم فاستجبتم لي﴾</span></span>: الواو عاطفة، وما نافية، وكان فعل ماض ناقص ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿لي﴾</span></span> جار ومجرور متعلقان بمحذوف خبرها المقدم، و<span class="hlt"><span class="qpc-hafs">﴿عليكم﴾</span></span> جار ومجرور متعلقان بمحذوف حال، لأنه كان في الأصل صفة لسلطان، ومن حرف جر، وسلطان مجرور لفظًا واسم كان محلا، وإلا أداة استثناء، وأن وما في حيزها مستثنى، فاستجبتم عطف على دعوتكم، و<span class="hlt"><span class="qpc-hafs">﴿لي﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿استجبتم﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿فلا تلوموني ولوموا أنفسكم﴾</span></span>: الفاء الفصيحة، كأنه قيل: إن علمتم أنكم أسرعتم في إجابتي فأنتم الملومون، ولا ناهية، وتلوموني مضارع مجزوم بلا الناهية، والواو فاعل، والنون للوقاية، والياء مفعول به، ولوموا فعل أمر وفاعل، وأنفسكم مفعول به.</p><p><span class="hlt"><span class="qpc-hafs">﴿ما أنا بمصرخكم وما أنتم بمصرخي﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> نافية حجازية تعمل عمل ليس، و<span class="hlt"><span class="qpc-hafs">﴿أنا﴾</span></span> اسم ما، و<span class="hlt"><span class="qpc-hafs">﴿بمصرخكم﴾</span></span>: الباء حرف جر صلة، و<span class="hlt"><span class="qpc-hafs">﴿مصرخكم﴾</span></span> خبر <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> الحجازية منصوب محلا مجرور بالباء لفظًا، <span class="hlt"><span class="qpc-hafs">﴿وما أنتم بمصرخي﴾</span></span> عطف على مثيلتها.</p><p><span class="hlt"><span class="qpc-hafs">﴿إني كفرت بما أشركتمون من قبل﴾</span></span>: إن حرف ناسخ، والياء اسمها، وجملة كفرت خبرها، والباء حرف جر، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> مصدرية مؤولة مع <span class="hlt"><span class="qpc-hafs">﴿أشركتموني﴾</span></span> بمصدر مجرور بالباء، والجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿كفرت﴾</span></span>، أي: كفرت بإشراككم إياي، وقيل: موصولة، والياء مفعول <span class="hlt"><span class="qpc-hafs">﴿أشركتموني﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿من قبل﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أشركتموني﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿إن الظالمين لهم عذاب أليم﴾</span></span>: إن حرف ناسخ، والظالمين اسمها، و<span class="hlt"><span class="qpc-hafs">﴿لهم﴾</span></span> جار ومجرور متعلقان بمحذوف خبر مقدم، وعذاب مبتدأ مؤخر، وأليم صفة، والجملة الاسمية خبر إن.</p></div>"
  14,23,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وأدخل الذين آمنوا وعملوا الصالحات جنات تجري من تحتها الأنهار خالدين فيها﴾</span></span>: الواو استئنافية، والجملة بعدها مستأنفة لا محل لها من الإعراب، وأدخل فعل ماض مبني لما لم يسمَّ فاعله، والذين نائب فاعل، وجملة آمنوا صلة الذين لا محل لها من الإعراب، وعملوا فعل وفاعل وجملة <span class="hlt"><span class="qpc-hafs">﴿عملوا﴾</span></span> عطف على آمنوا، والصالحات مفعول به، وجنات مفعول به ثان على السعة، وجملة <span class="hlt"><span class="qpc-hafs">﴿تجري من تحتها الأنهار﴾</span></span> صفة لـ<span class="hlt"><span class="qpc-hafs">﴿جنات﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿بإذن ربهم تحيتهم فيها سلام﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿بإذن﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أدخل﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿ربهم﴾</span></span> مضاف إليه، وتحيتهم مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿فيها﴾</span></span> جار ومجرور متعلقان بمحذوف حال، وسلام خبر <span class="hlt"><span class="qpc-hafs">﴿تحيتهم﴾</span></span>.</p></div>"
  14,24,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ألم تر كيف ضرب الله مثلا﴾</span></span>: الهمزة للاستفهام التقريري، ولم حرف نفي وقلب وجزم، و<span class="hlt"><span class="qpc-hafs">﴿تر﴾</span></span> مضارع مجزوم بـ<span class="hlt"><span class="qpc-hafs">﴿لم﴾</span></span>، وفاعله مستتر تقديره: أنت، وكيف اسم استفهام في محل نصب على الحال من مفعول ضرب، و<span class="hlt"><span class="qpc-hafs">﴿ضرب الله مثلًا﴾</span></span> فعل وفاعل ومفعول به.</p><p><span class="hlt"><span class="qpc-hafs">﴿كلمة طيبة كشجرة طيبة﴾</span></span>: كلمة بدل من <span class="hlt"><span class="qpc-hafs">﴿مثلًا﴾</span></span> أو مفعول به ثان بتضمين ضرب معنى جعل، و<span class="hlt"><span class="qpc-hafs">﴿كشجرة﴾</span></span> الكاف: اسم بمعنى مثل مبني على الفتح في محل رفع خبر لمبتدأ محذوف، أي: هي مثلُ شجرةٍ طيبة، وشجرة: مضاف إليه، و<span class="hlt"><span class="qpc-hafs">﴿طيبة﴾</span></span> صفة لشجرة.</p><p><span class="hlt"><span class="qpc-hafs">﴿أصلها ثابت وفرعها في السماء﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿أصلها﴾</span></span> مبتدأ، وثابت خبرها، والجملة صفة ثانية لشجرة، و<span class="hlt"><span class="qpc-hafs">﴿فرعها في السماء﴾</span></span> عطف على <span class="hlt"><span class="qpc-hafs">﴿أصلها ثابت﴾</span></span>.</p></div>"