quran[8]{c,v,t}:
  29,31,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ولما جاءت رسلنا إبراهيم بالبشرى قالوا إنا مهلكو أهل هذه القرية﴾</span></span>: الواو عاطفة على محذوف، ولما ظرفية حينية، أو رابطة، و<span class="hlt"><span class="qpc-hafs">﴿جاءت رسلنا إبراهيم﴾</span></span> فعل، وفاعل، ومفعول به، وبالبشرى: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿جاءت﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿قالوا﴾</span></span> لا محل لها من الإعراب، لأنها جواب شرط غير جازم، وجملة <span class="hlt"><span class="qpc-hafs">﴿إنا﴾</span></span> مقول القول، وإن حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> اسمها، و<span class="hlt"><span class="qpc-hafs">﴿مهلكو﴾</span></span> خبرها، و<span class="hlt"><span class="qpc-hafs">﴿أهل هذه﴾</span></span> مضافين، والقرية بدل من هذه.</p><p><span class="hlt"><span class="qpc-hafs">﴿إن أهلها كانوا ظالمين﴾</span></span>: الجملة لا محل لها من الإعراب، لأنها تعليل، وإن حرف ناسخ، وأهلها اسم إن، وجملة كانوا خبرها، وظالمين خبر كان.</p></div>"
  29,32,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قال إن فيها لوطا قالوا نحن أعلم بمن فيها﴾</span></span>: إن حرف ناسخ، وفيها: جار ومجرور متعلقان بمحذوف خبر إن المقدم، و<span class="hlt"><span class="qpc-hafs">﴿لوطًا﴾</span></span> اسمها المؤخر، و<span class="hlt"><span class="qpc-hafs">﴿قالوا﴾</span></span> فعل، وفاعل، ونحن مبتدأ، وأعلم خبر، وبمن جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أعلم﴾</span></span>، وفيها جار ومجرور متعلقان بمحذوف صلة <span class="hlt"><span class="qpc-hafs">﴿من﴾</span></span> وجملة الصلة لا محل لها من الإعراب.</p><p><span class="hlt"><span class="qpc-hafs">﴿لننجينه وأهله إلا امرأته كانت من الغابرين﴾</span></span>: اللام واقعة في جواب قسم مقدر، وننجينه فعل مضارع مبني على الفتح، وفاعله مستتر، تقديره: نحن، والهاء: مفعول به، وأهله عطف على الهاء، أو مفعول معه، وإلا أداة استثناء، وامرأته مستثنى، وجملة كانت حالية، وكانت فعل ماض ناقص، واسمها مستتر، ومن الغابرين: جار ومجرور متعلقان بمحذوف خبر <span class="hlt"><span class="qpc-hafs">﴿كانت﴾</span></span>.</p></div>"
  29,33,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ولما أن جاءت رسلنا لوطا سيء بهم وضاق بهم ذرعا﴾</span></span>: الواو: استئنافية، ولما: ظرفية حينية، وأن: صلة، وجاءت: فعل ماض، ورسلنا: فاعل، ولوطًا: مفعول به، وجملة <span class="hlt"><span class="qpc-hafs">﴿سيء بهم﴾</span></span> لا محل لها من الإعراب لأنها جواب <span class="hlt"><span class="qpc-hafs">﴿لَمّا﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿سيء﴾</span></span> فعل ماض مبني لما لم يسمَّ فاعله، ونائب الفاعل ضمير مستتر تقديره هو يعود على لوط، و<span class="hlt"><span class="qpc-hafs">﴿بهم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿سيء﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿ضاق بهم﴾</span></span> عطف على جملة <span class="hlt"><span class="qpc-hafs">﴿سيء بهم﴾</span></span>، وذرعًا: تمييز محول عن الفاعل، أي: ضاق ذرعُه بهم.</p><p><span class="hlt"><span class="qpc-hafs">﴿وقالوا لا تخف ولا تحزن إنا منجوك وأهلك إلا امرأتك كانت من الغابرين﴾</span></span>: الواو: عاطفة، وقالوا: فعل وفاعل، وجملة <span class="hlt"><span class="qpc-hafs">﴿وقالوا لا تخف﴾</span></span> معطوفة عل جملة <span class="hlt"><span class="qpc-hafs">﴿سيء بهم﴾</span></span>، وإنا: إن حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> اسمها، و<span class="hlt"><span class="qpc-hafs">﴿منجوك﴾</span></span> خبرها، والكاف في <span class="hlt"><span class="qpc-hafs">﴿منجوك﴾</span></span> في موضع جر بالإضافة، وأهلك مفعول به منصوب بفعل محذوف، أي: وننجي أهلك، وإلا: أداة استثناء، وامرأتك: مستثنى، وجملة <span class="hlt"><span class="qpc-hafs">﴿كانت من الغابرين﴾</span></span> حالية، وكانت: فعل ماض ناقص، واسمها مستتر، ومن الغابرين: جار ومجرور متعلقان بمحذوف خبر <span class="hlt"><span class="qpc-hafs">﴿كانت﴾</span></span>.</p></div>"
  29,34,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إنا منزلون على أهل هذه القرية رجزا من السماء بما كانوا يفسقون﴾</span></span>: إن حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> اسمها، ومنزلون خبرها، و<span class="hlt"><span class="qpc-hafs">﴿على أهل هذه القرية﴾</span></span> الجار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿منزلون﴾</span></span>، وهذه: مضاف إليه، والقرية بدل مجرور، ورجزًا مفعول به لـ<span class="hlt"><span class="qpc-hafs">﴿منزلون﴾</span></span>، لأنه اسم فاعل، و<span class="hlt"><span class="qpc-hafs">﴿من السماء﴾</span></span> صفة لـ<span class="hlt"><span class="qpc-hafs">﴿رجزًا﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿بما﴾</span></span> الباء سببية، وما مصدرية، أي: بسبب فسقهم، والمصدر المؤول مجرور بالباء، والجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿منزلون﴾</span></span>، وكانوا فعل ماض ناقص، وواو الجماعة اسمها، وجملة يفسقون خبرها.</p></div>"
  29,35,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ولقد تركنا منها آية بينة لقوم يعقلون﴾</span></span>: الواو عاطفة، واللام واقعة في جواب قسم مقدر، وقد حرف تحقيق، وتركنا فعل، وفاعل، و<span class="hlt"><span class="qpc-hafs">﴿منها﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تركنا﴾</span></span>، أو هو المفعول الثاني لها، وآية مفعولها الأول، وبينة صفة، و<span class="hlt"><span class="qpc-hafs">﴿لقوم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿بينة﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿يعقلون﴾</span></span> صفة لقوم.</p></div>"
  29,36,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وإلى مدين أخاهم شعيبا فقال يا قوم اعبدوا الله وارجوا اليوم الآخر﴾</span></span>: الواو عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿إلى مدين﴾</span></span> جار ومجرور متعلقان بمحذوف، أي: وأرسلنا إلى مدين شعيبًا، و<span class="hlt"><span class="qpc-hafs">﴿أخاهم﴾</span></span> مفعول به، وشعيبًا بدل، أو عطف بيان، والفاء عاطفة، وقال فعل ماض، وفاعله مستتر، تقديره: هو، ويا حرف نداء، وقوم منادى مضاف إلى ياء المتكلم المحذوفة، و<span class="hlt"><span class="qpc-hafs">﴿اعبدوا الله﴾</span></span> فعل أمر، وفاعل، ومفعول به، و<span class="hlt"><span class="qpc-hafs">﴿ارجوا﴾</span></span> عطف على اعبدوا، واليوم: مفعول به، والآخر: صفة لليوم.</p><p><span class="hlt"><span class="qpc-hafs">﴿ولا تعثوا في الأرض مفسدين﴾</span></span>: الواو عاطفة، ولا ناهية، وتعثوا فعل مضارع مجزوم بلا الناهية، والواو فاعل، و<span class="hlt"><span class="qpc-hafs">﴿في الأرض﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تعثوا﴾</span></span>، ومفسدين حال.</p></div>"
  29,37,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فكذبوه فأخذتهم الرجفة فأصبحوا في دارهم جاثمين﴾</span></span>: الفاء عاطفة، وكذبوه فعل ماض، وفاعل، ومفعول به، فأخذتهم الفاء عاطفة، وأخذتهم فعل ماض، ومفعول به مقدم، والرجفة فاعل مؤخر، <span class="hlt"><span class="qpc-hafs">﴿فأصبحوا﴾</span></span> عطف على <span class="hlt"><span class="qpc-hafs">﴿فأخذتهم﴾</span></span>، والواو اسم أصبح، و<span class="hlt"><span class="qpc-hafs">﴿في دارهم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿جاثمين﴾</span></span>، وجاثمين خبر أصبحوا.</p></div>"
  29,38,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وعادا وثمود وقد تبين لكم من مساكنهم﴾</span></span>: الواو عاطفة، وعادًا مفعول به لفعل محذوف معطوف على ما قبله، أي: وأهلكنا عادًا، وثمود عطف على <span class="hlt"><span class="qpc-hafs">﴿عادًا﴾</span></span>، والواو عاطفة، وقد حرف تحقيق، وتبين فعل ماض، وفاعل مستتر، و<span class="hlt"><span class="qpc-hafs">﴿من مساكنهم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تبين﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿وزين لهم الشيطان أعمالهم فصدهم عن السبيل وكانوا مستبصرين﴾</span></span>: الواو عاطفة، وزين فعل ماض، و<span class="hlt"><span class="qpc-hafs">﴿لهم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿زين﴾</span></span>، والشيطان فاعل، وأعمالهم مفعول به، <span class="hlt"><span class="qpc-hafs">﴿فصدهم﴾</span></span> عطف على زين، و<span class="hlt"><span class="qpc-hafs">﴿عن السبيل﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿صدهم﴾</span></span>، والواو حالية، وكانوا فعل ماض ناقص، والواو اسمها، ومستبصرين خبرها.</p></div>"