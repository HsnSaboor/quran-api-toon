quran[7]{c,v,t}:
  11,82,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فلما جاء أمرنا جعلنا عاليها سافلها﴾</span></span>: لما ظرفية حينية، أو رابطة، وجاء أمرنا فعل وفاعل، وجملة جعلنا جواب <span class="hlt"><span class="qpc-hafs">﴿لما﴾</span></span>، ونا فاعل، وعاليها مفعول <span class="hlt"><span class="qpc-hafs">﴿جعلنا﴾</span></span> الأول، وسافلها مفعول <span class="hlt"><span class="qpc-hafs">﴿جعلنا﴾</span></span> الثاني.</p><p><span class="hlt"><span class="qpc-hafs">﴿وأمطرنا عليها حجارة من سجيل منضود﴾</span></span>: الواو عاطفة، وأمطرنا عطف على جعلنا، وعليها جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أمطرنا﴾</span></span>، وحجارة مفعول به، ومن سجيل صفة لـ<span class="hlt"><span class="qpc-hafs">﴿حجارة﴾</span></span>، ومنضود صفة لـ<span class="hlt"><span class="qpc-hafs">﴿سجيل﴾</span></span>.</p></div>"
  11,83,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿مسومة عند ربك﴾</span></span>: مسومة صفة ثانية لحجارة، وعند ربك الظرف متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿مسومة﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿وما هي من الظالمين ببعيد﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> نافية حجازية تعمل عمل ليس، و<span class="hlt"><span class="qpc-hafs">﴿هي﴾</span></span> اسم ما، و<span class="hlt"><span class="qpc-hafs">﴿من الظالمين﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿بعيد﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿ببعيد﴾</span></span>: الباء حرف جر صلة، و<span class="hlt"><span class="qpc-hafs">﴿بعيد﴾</span></span> خبر <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> الحجازية منصوب محلا مجرور بالباء لفظًا.</p></div>"
  11,84,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وإلى مدين أخاهم شعيبا﴾</span></span>: عطف على القصة السابقة، والمعطوف محذوف، أي: وأرسلنا إلى مدين، فيكون من عطف الجمل لا من عطف المفردات، لطول الفصل، وأخاهم مفعول لأرسلنا المحذوفة، وشعيبا بدل أو عطف بيان.</p><p><span class="hlt"><span class="qpc-hafs">﴿قال يا قوم اعبدوا الله ما لكم من إله غيره﴾</span></span>: اعبدوا الله فعل أمر وفاعل ومفعول به، وما نافية، ولكم خبر مقدم، ومن حرف صلة، وإله مجرور لفظًا مرفوع محلاًّ، لأنه مبتدأ مؤخر، وغيره صفة لإله على المحل.</p><p><span class="hlt"><span class="qpc-hafs">﴿ولا تنقصوا المكيال والميزان إني أراكم بخير﴾</span></span>: الواو عاطفة، ولا ناهية، وتنقصوا فعل مضارع مجزوم بلا، والواو فاعل، والمكيال مفعول به، والميزان عطف على المكيال، وإن حرف ناسخ، والياء اسمها، وجملة أراكم خبرها، وجملة إني أراكم تعليلية للنهي.</p><p><span class="hlt"><span class="qpc-hafs">﴿وإني أخاف عليكم عذاب يوم محيط﴾</span></span>: الواو عاطفة، وإن حرف ناسخ، والياء اسمها، وجملة أخاف عليكم خبرها، وعذاب مفعول به، ويوم مضاف إليه، ومحيط صفة.</p></div>"
  11,85,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ويا قوم أوفوا المكيال والميزان بالقسط﴾</span></span>: أوفوا فعل أمر، والواو فاعل، والمكيال مفعول به، والميزان عطف عليه، وبالقسط حال، أي: عادلين.</p><p><span class="hlt"><span class="qpc-hafs">﴿ولا تبخسوا الناس أشياءهم ولا تعثوا في الأرض مفسدين﴾</span></span>: الواو عاطفة، ولا ناهية، وتبخسوا مضارع مجزوم بلا، والواو فاعل، والناس مفعول به، وأشياءهم مفعول به ثان، أي: لا تنقصوهم أموالهم، ولا تعثوا في الأرض مفسدين عطف أيضًا، ومفسدين حال.</p></div>"
  11,86,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿بقية الله خير لكم إن كنتم مؤمنين﴾</span></span>: بقية الله مبتدأ، وخير خبر، ولكم جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿خير﴾</span></span>، وإن شرطية، وكنتم فعل الشرط، ومؤمنين خبر كنتم، والجواب محذوف، أي: فبقية الله خير.</p><p><span class="hlt"><span class="qpc-hafs">﴿وما أنا عليكم بحفيظ﴾</span></span>: الواو عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> نافية حجازية تعمل عمل ليس، و<span class="hlt"><span class="qpc-hafs">﴿أنا﴾</span></span> اسم ما، و<span class="hlt"><span class="qpc-hafs">﴿عليكم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿حفيظ﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿بحفيظ﴾</span></span>: الباء حرف جر صلة، و<span class="hlt"><span class="qpc-hafs">﴿حفيظ﴾</span></span> خبر <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> الحجازية منصوب محلا مجرور بالباء لفظًا.</p></div>"
  11,87,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قالوا يا شعيب أصلاتك تأمرك أن نترك ما يعبد آباؤنا﴾</span></span>: الهمزة للاستفهام، وصلاتك مبتدأ، وجملة تأمرك خبر، وأن مصدرية، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> وما في حيزها منصوب بنزع الخافض، والجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تأمرك﴾</span></span>، أي: تأمرك بترك، وما موصولة، أو مصدرية مفعول به لـ<span class="hlt"><span class="qpc-hafs">﴿نترك﴾</span></span>، وجملة يعبد لا محل لها من الإعراب على الحالين، وآباؤنا فاعل.</p><p><span class="hlt"><span class="qpc-hafs">﴿أو أن نفعل في أموالنا ما نشاء﴾</span></span>: أو حرف عطف، والمصدر المؤول من <span class="hlt"><span class="qpc-hafs">﴿أن نفعل﴾</span></span> معطوف على <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> في حالتيها، أي: هل تأمرك بتكليفك لنا ترك ما يعبد آباؤنا، وترك أن نفعل في أموالنا ما نشاء؟ <span class="hlt"><span class="qpc-hafs">﴿إنك لأنت الحليم الرشيد﴾</span></span>: إن حرف ناسخ، والكاف اسمها، واللام المزحلقة، وأنت مبتدأ، والحليم الرشيد خبراه، والجملة خبر إنك.</p></div>"
  11,88,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قال يا قوم أرأيتم إن كنت على بينة من ربي ورزقني منه رزقا حسنا﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿أرأيتم﴾</span></span> الهمزة للاستفهام، ورأى فعل ماض مبني على السكون، والتاء فاعل، و<span class="hlt"><span class="qpc-hafs">﴿كنت﴾</span></span> كنت فعل ماض ناقص ناسخ، والتاء اسمها، وهي فعل الشرط، و<span class="hlt"><span class="qpc-hafs">﴿على بينة﴾</span></span> جار ومجرور متعلقان بمحذوف خبر كنت، و<span class="hlt"><span class="qpc-hafs">﴿من ربي﴾</span></span> جار ومجرور متعلقان بمحذوف صفة لـ<span class="hlt"><span class="qpc-hafs">﴿بينة﴾</span></span>، وجواب الشرط محذوف يدل عليه المفعول الثاني المحذوف، و<span class="hlt"><span class="qpc-hafs">﴿رزقني﴾</span></span> فعل وفاعل مستتر وياء المتكلم ضمير مبني في محل نصب مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿رزقًا﴾</span></span> مفعول به ثان، أو مفعول مطلق منصوب، و<span class="hlt"><span class="qpc-hafs">﴿حسنًا﴾</span></span> صفة.</p><p><span class="hlt"><span class="qpc-hafs">﴿وما أريد أن أخالفكم إلى ما أنهاكم عنه﴾</span></span>: ما نافية، وأريد فعل مضارع فاعله مستتر، تقديره: أنا، وأن وما في حيزها مفعول أريد، و<span class="hlt"><span class="qpc-hafs">﴿إلى ما﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أخالفكم﴾</span></span>، وجملة أنهاكم عنه صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> لا محل لها من الإعراب.</p><p><span class="hlt"><span class="qpc-hafs">﴿إن أريد إلا الإصلاح ما استطعت﴾</span></span>: إن نافية، وأريد فعل مضارع فاعله مستتر تقديره: أنا، وإلا أداة حصر، والإصلاح مفعول به، وما ظرفية زمانية متعلقة بـ<span class="hlt"><span class="qpc-hafs">﴿أريد﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿وما توفيقي إلا بالله عليه توكلت وإليه أنيب﴾</span></span>: ما نافية، وتوفيقي مبتدأ، وإلا أداة حصر، و<span class="hlt"><span class="qpc-hafs">﴿الله﴾</span></span> خبر، وعليه جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿توكلت﴾</span></span>، وإليه جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أنيب﴾</span></span>، والجملتان حاليتان.</p></div>"