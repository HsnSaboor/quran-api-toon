quran[8]{c,v,t}:
  5,24,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قالوا يا موسى إنا لن ندخلها أبدا ما داموا فيها﴾</span></span>: كلام مستأنف لا محل له من الإعراب، وقالوا: فعل وفاعل، وجملة النداء وما بعدها في محل نصب مقول قولهم، وإن حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> اسمها، وجملة <span class="hlt"><span class="qpc-hafs">﴿لن ندخلها﴾</span></span> خبر، وأبدًا ظرف زمان متعلق بداخلها، و<span class="hlt"><span class="qpc-hafs">﴿ما داموا﴾</span></span> ما مصدرية ظرفية، وداموا هي دام الناقصة، والواو اسمها، و<span class="hlt"><span class="qpc-hafs">﴿فيها﴾</span></span> جار ومجرور متعلقان بمحذوف خبرها، وهذا الظرف بدل مطابق من <span class="hlt"><span class="qpc-hafs">﴿أبدًا﴾</span></span>، أو بدل كل من كل، أو بدل بعض من كل.</p><p><span class="hlt"><span class="qpc-hafs">﴿فاذهب أنت وربك فقاتلا﴾</span></span>: الفاء الفصيحة، و<span class="hlt"><span class="qpc-hafs">﴿اذهب﴾</span></span> فعل أمر، وفاعله مستتر تقديره: أنت، وأنت تأكيد للفاعل المستتر، وربك عطف على الفاعل المستتر في <span class="hlt"><span class="qpc-hafs">﴿اذهب﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿فقاتلا﴾</span></span> عطف على <span class="hlt"><span class="qpc-hafs">﴿اذهب﴾</span></span>، والألف فاعل قاتل.</p><p><span class="hlt"><span class="qpc-hafs">﴿إنا ههنا قاعدون﴾</span></span>: الجملة استئنافية لا محل لها من الإعراب، وإن حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> اسمها، وها للتنبيه، و<span class="hlt"><span class="qpc-hafs">﴿هنا﴾</span></span> اسم إشارة في محل نصب على الظرفية المكانية، والظرف متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿قاعدون﴾</span></span>، وقاعدون خبر إن.</p></div>"
  5,25,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قال رب إني لا أملك إلا نفسي وأخي﴾</span></span>: الجملة مستأنفة لا محل لها من الإعراب، وقال فعل ماض، والفاعل هو، ورب منادى مضاف إلى ياء المتكلم المحذوفة، وإن حرف ناسخ، والياء اسمها، والجملة مقول القول، وجملة لا أملك خبر إن، وإلا أداة حصر، ونفسي مفعول به، وأخي مرفوع على أنه عطف على الضمير المستتر في <span class="hlt"><span class="qpc-hafs">﴿أملك﴾</span></span>، أو عطف على محل إن واسمها، أو مبتدأ حذف خبره، والتقدير: وأخي لا يملك إلا نفسه، أو منصوب على أنه معطوف على اسم إنّ، أو معطوف على <span class="hlt"><span class="qpc-hafs">﴿نفسي﴾</span></span>، أو مجرور على أنه معطوف على الياء في <span class="hlt"><span class="qpc-hafs">﴿نفسي﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿فافرق بيننا وبين القوم الفاسقين﴾</span></span>: الفاء استئنافية، وافرق فعل دعاء، وبيننا ظرف متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿افرق﴾</span></span>، وبين القوم الفاسقين عطف على <span class="hlt"><span class="qpc-hafs">﴿بيننا﴾</span></span>، والجملة مستأنفة لا محل لها من الإعراب.</p></div>"
  5,26,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قال فإنها محرمة عليهم أربعين سنة يتيهون في الأرض﴾</span></span>: الجملة مستأنفة لا محل لها من الإعراب، وفاعل <span class="hlt"><span class="qpc-hafs">﴿قال﴾</span></span> مستتر تقديره: الله تعالى، والفاء صلة، وإن حرف ناسخ، والهاء اسمها، ومحرمة خبرها، وعليهم جار ومجرور متعلقان بمحرمة، وأربعين ظرف زمان متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿يتيهون﴾</span></span>، أو بمحرمة، وسنة تمييز، وجملة <span class="hlt"><span class="qpc-hafs">﴿فإنها محرمة﴾</span></span> مقول القول، وجملة <span class="hlt"><span class="qpc-hafs">﴿يتيهون في الأرض﴾</span></span> حالية، أي: حالة كونهم تائهين ضاربين في متاهات الأرض، ومناكب الصحاري، تتخبطهم الحسرة، وتتعاورهم الحيرة <span class="hlt"><span class="qpc-hafs">﴿فلا تأس على القوم الفاسقين﴾</span></span>: الفاء الفصيحة، أي: إذا عرفت هذا فلا تحزن، ولا ناهية، وتأس فعل مضارع مجزوم بلا الناهية، وعلامة جزمه حذف حرف العلة، وعلى القوم جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تأس﴾</span></span>، والفاسقين صفة لـ<span class="hlt"><span class="qpc-hafs">﴿القوم﴾</span></span>.</p></div>"
  5,27,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿واتل عليهم نبأ ابني آدم بالحق﴾</span></span>: الجملة معطوفة على الفعل المقدر في قوله: <span class="hlt"><span class="qpc-hafs">﴿وإذ قال موسى لقومه﴾</span></span>، أي: اذكر يا محمد لقومك واتل عليهم.</p><p><span class="hlt"><span class="qpc-hafs">﴿إذ قربا قربانا فتقبل من أحدهما ولم يتقبل من الآخر﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿إذ﴾</span></span> ظرف لما مضى من الزمن متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿نبأ﴾</span></span>، أو اسم مبني على السكون في محل نصب بدل من <span class="hlt"><span class="qpc-hafs">﴿نبأ﴾</span></span> على تقدير حذف مضاف، أي: واتل عليهم النبأَ نبأَ ذلك الوقت، وجملة <span class="hlt"><span class="qpc-hafs">﴿قرّبا﴾</span></span> في محل جر بالإضافة، وقربا فعل وفاعل، وقربانًا مفعول به، <span class="hlt"><span class="qpc-hafs">﴿فتقبل﴾</span></span> الفاء عاطفة، وتقبل فعل ماض مبني لما لم يسمَّ فاعله، ونائب الفاعل مستتر تقديره هو يعود على <span class="hlt"><span class="qpc-hafs">﴿قربانًا﴾</span></span>، ومن أحدهما جار ومجرور متعلقان بتقبل، <span class="hlt"><span class="qpc-hafs">﴿ولم يتقبل من الآخر﴾</span></span> عطف على تقبل.</p><p><span class="hlt"><span class="qpc-hafs">﴿قال لأقتلنك قال إنما يتقبل الله من المتقين﴾</span></span>: جملة لأقتلنك في محل نصب مقول القول، واللام واقعة في جواب قسم مقدر، وأقتلنك فعل مضارع مبني على الفتح لوجوب توكيده بالنون الثقيلة، والكاف مفعول به، وإنما كافة ومكفوفة، وجملة إنما يتقبل الله من المتقين مقول القول.</p></div>"
  5,28,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿لئن بسطت إلي يدك لتقتلني ما أنا بباسط يدي إليك لأقتلك﴾</span></span>: اللام موطئة للقسم، وإن شرطية، وبسطت فعل ماض في محل جزم فعل الشرط، والتاء فاعل، وإليَّ جار ومجرور متعلقان ببسطت، ويدك مفعول به، والجملة مستأنفة لا محل لها من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿لتقتلني﴾</span></span> اللام لام التعليل، وتقتلني فعل مضارع منصوب بأن مضمرة بعد لام التعليل، والنون للوقاية، والياء مفعول به، والجار والمجرور متعلقان ببسطت، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> نافية حجازية تعمل عمل ليس، و<span class="hlt"><span class="qpc-hafs">﴿أنا﴾</span></span> اسم ما، و<span class="hlt"><span class="qpc-hafs">﴿بباسط﴾</span></span>: الباء حرف جر صلة، و<span class="hlt"><span class="qpc-hafs">﴿باسط﴾</span></span> خبر <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> الحجازية منصوب محلا مجرور بالباء لفظًا، و<span class="hlt"><span class="qpc-hafs">﴿يدي﴾</span></span> مفعول به لباسط لأنه اسم فاعل، و<span class="hlt"><span class="qpc-hafs">﴿إليك﴾</span></span> جار ومجرور متعلقان بباسط، و<span class="hlt"><span class="qpc-hafs">﴿لأقتلك﴾</span></span> اللام لام التعليل، وأقتلك فعل مضارع منصوب بأن مضمرة بعد لام التعليل، والجملة جواب القسم لتقدمه على الشرط، وجواب الشرط محذوف لدلالة جواب القسم عليه.</p><p><span class="hlt"><span class="qpc-hafs">﴿إني أخاف الله رب العالمين﴾</span></span>: الجملة تعليلية، وإن حرف ناسخ، والياء اسمها، وجملة أخاف الله خبرها، ورب العالمين بدل من <span class="hlt"><span class="qpc-hafs">﴿الله﴾</span></span>، أو صفة.</p></div>"
  5,29,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إني أريد أن تبوء بإثمي وإثمك فتكون من أصحاب النار﴾</span></span>: الجملة تعليل ثان لامتناعه عن المقاتلة بعد التعليل الأول، وإن حرف ناسخ، والياء اسمها، وجملة أريد خبرها، والفاعل مستتر تقديره أنا، وأن تبوء مصدر مئوّل في محل نصب مفعول به لـ<span class="hlt"><span class="qpc-hafs">﴿أريد﴾</span></span>، وبإثمي جار ومجرور متعلقان بمحذوف حال من فاعل تبوء، أي: ترجع حاملًا له، أو ملابسًا له، <span class="hlt"><span class="qpc-hafs">﴿فتكون﴾</span></span> الفاء عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿تكون﴾</span></span> فعل مضارع ناقص معطوف على <span class="hlt"><span class="qpc-hafs">﴿تبوء﴾</span></span> منصوب، واسمها: أنت، و<span class="hlt"><span class="qpc-hafs">﴿من أصحاب النار﴾</span></span> جار ومجرور متعلقان بمحذوف خبر تكون.</p><p><span class="hlt"><span class="qpc-hafs">﴿وذلك جزاء الظالمين﴾</span></span>: الواو استئنافية، وذلك اسم إشارة في محل رفع مبتدأ، وجزاء الظالمين خبر، والجملة مستأنفة لا محل لها من الإعراب.</p></div>"
  5,30,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فطوعت له نفسه قتل أخيه فقتله فأصبح من الخاسرين﴾</span></span>: الفاء عاطفة، وطوعت فعل ماض، وله جار ومجرور متعلقان بطوعت، ونفسه فاعل، وقتل أخيه مفعول به، فقتله عطف أيضًا، فأصبح عطف أيضًا، واسمها ضمير مستتر تقديره: هو، و<span class="hlt"><span class="qpc-hafs">﴿من الخاسرين﴾</span></span> جار ومجرور متعلقان بمحذوف خبرها.</p></div>"
  5,31,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فبعث الله غرابا يبحث في الأرض﴾</span></span>: الفاء عاطفة، وبعث فعل ماض، و<span class="hlt"><span class="qpc-hafs">﴿الله﴾</span></span> فاعل، وغرابًا مفعول به، وجملة يبحث في الأرض في محل نصب صفة لـ<span class="hlt"><span class="qpc-hafs">﴿غرابًا﴾</span></span>، وفي الأرض جار ومجرور متعلقان بيبحث.</p><p><span class="hlt"><span class="qpc-hafs">﴿ليريه كيف يواري سوءة أخيه﴾</span></span>: اللام للتعليل، ويريه فعل مضارع منصوب بأن مضمرة بعد لام التعليل، والهاء مفعول به، وكيف: اسم استفهام في محل نصب على الحال، واللام للتعليل، و<span class="hlt"><span class="qpc-hafs">﴿يريه﴾</span></span> فعل مضارع منصوب بأن مضمرة، والمصدر المؤول من أن المضمرة و<span class="hlt"><span class="qpc-hafs">﴿يريه﴾</span></span> مجرور باللام، والجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿بعث﴾</span></span> أي: بعثه لإراءته، فالضمير المستتر في الفعل <span class="hlt"><span class="qpc-hafs">﴿يريه﴾</span></span> يعود لله، أو بيبحث، فالضمير المستتر يعود للغراب أي: يبحث لإراءته، وجملة الاستفهام معلقة للرؤية البصرية، فهي في محل نصب مفعول به ثان سادَّة مسده.</p><p><span class="hlt"><span class="qpc-hafs">﴿قال يا ويلتى﴾</span></span>: الجملة مستأنفة لا محل لها من الإعراب، وقال: فعل ماض، والفاعل مستتر. ويا: حرف نداء وتحسر وندبة، و<span class="hlt"><span class="qpc-hafs">﴿ويلتا﴾</span></span>: منادى منصوب بفتحة مقدرة على ما قبل ياء المتكلم المنقلبة ألفا.</p><p><span class="hlt"><span class="qpc-hafs">﴿أعجزت أن أكون مثل هذا الغراب﴾</span></span>: الهمزة للاستفهام والتعجب، وعجزت فعل وفاعل، والجملة مندرجة في مقول القول، وأن حرف مصدري ونصب، وأكون فعل مضارع ناقص منصوب بأن، والمصدر المؤول من <span class="hlt"><span class="qpc-hafs">﴿أن أكون﴾</span></span> منصوب بنزع الخافض، والجار والمجرور متعلقان بعجزت، أي: أعجزت عن كوني، واسم أكون ضمير مستتر تقديره: أنا، ومثل خبر أكون، وهذا اسم إشارة مضاف إليه، والغراب بدل من اسم الإشارة.</p><p><span class="hlt"><span class="qpc-hafs">﴿فأواري سوءة أخي فأصبح من النادمين﴾</span></span>: الفاء عاطفة، وأواري فعل مضارع معطوف على <span class="hlt"><span class="qpc-hafs">﴿أكون﴾</span></span>، أو فعل مضارع منصوب بأن مضمرة بعد فاء السببية، وسوءة أخي مفعول به، <span class="hlt"><span class="qpc-hafs">﴿فأصبح﴾</span></span> الفاء عاطفة، وأصبح فعل ماض ناقص، واسمها ضمير مستتر تقديره: هو، ومن النادمين خبرها.</p></div>"