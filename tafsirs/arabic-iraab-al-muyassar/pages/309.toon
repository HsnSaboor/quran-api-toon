quran[13]{c,v,t}:
  19,52,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وناديناه من جانب الطور الأيمن وقربناه نجيا﴾</span></span>: الواو عاطفة، وناديناه عطف على ما سبق، وهو فعل وفاعل ومفعول به، ومن جانب جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿نادينا﴾</span></span>، والطور مضاف إليه، والأيمن صفة لجانب، وقربناه عطف على ناديناه، و<span class="hlt"><span class="qpc-hafs">﴿نجيًّا﴾</span></span> حال من أحد الضميرين في ناديناه أو قربناه.</p></div>"
  19,53,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ووهبنا له من رحمتنا أخاه هارون نبيا﴾</span></span>: الواو عاطفة، ووهبنا عطف أيضًا، و<span class="hlt"><span class="qpc-hafs">﴿له﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿وهبنا﴾</span></span>، ومن رحمتنا جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿وهبنا﴾</span></span> أيضًا، ومن للتبعيض، أي: بعض رحمتنا، أو: للتعليل، أي: من أجل رحمتنا، وأخاه مفعول به لـ<span class="hlt"><span class="qpc-hafs">﴿وهبنا﴾</span></span>، وهارون بدل، ونبيًّا حال.</p></div>"
  19,54,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿واذكر في الكتاب إسماعيل﴾</span></span>: الواو استئنافية، والجملة بعدها مستأنفة لا محل لها من الإعراب، واذكر فعل أمر، والفاعل مستتر تقديره: أنت، وفي الكتاب جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿اذكر﴾</span></span>، وإسماعيل مفعول به.</p><p><span class="hlt"><span class="qpc-hafs">﴿إنه كان صادق الوعد﴾</span></span>: إن حرف ناسخ، والهاء ضمير مبني في محل نصب اسم إن، وجملة <span class="hlt"><span class="qpc-hafs">﴿كان صادق الوعد﴾</span></span> خبر إن، وجملة <span class="hlt"><span class="qpc-hafs">﴿إنه كان...﴾</span></span> تعليلة، وكان فعل ماض ناقص، واسمها مستتر، وصادق خبر كان منصوب، والوعد مضاف إليه.</p><p><span class="hlt"><span class="qpc-hafs">﴿وكان رسولا نبيا﴾</span></span>: عطف على كان الأولى.</p></div>"
  19,55,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وكان يأمر أهله بالصلاة والزكاة وكان عند ربه مرضيا﴾</span></span>: جملة يأمر خبر كان، وأهله مفعول به، وبالصلاة جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يأمر﴾</span></span>، وكان فعل ماض ناقص، واسمها مستتر تقديره هو، و<span class="hlt"><span class="qpc-hafs">﴿عند ربه﴾</span></span> ظرف متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿مرضيًّا﴾</span></span>، ومرضيًّا خبر كان منصوب.</p></div>"
  19,56,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿واذكر في الكتاب إدريس﴾</span></span>: الواو استئنافية، والجملة بعدها مستأنفة لا محل لها من الإعراب، واذكر فعل أمر، وفاعل مستتر تقديره: أنت، وفي الكتاب جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿اذكر﴾</span></span>، وإدريس مفعول به.</p><p><span class="hlt"><span class="qpc-hafs">﴿إنه كان صديقا نبيا﴾</span></span>: إن حرف ناسخ، والهاء ضمير مبني في محل نصب اسم إن، وجملة كان خبر إن.</p></div>"
  19,57,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ورفعناه مكانا عليا﴾</span></span>: رفعناه فعل وفاعل ومفعول به، ومكانًا ظرف متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿رفعناه﴾</span></span>، وعليًّا صفة.</p></div>"
  19,58,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿أولئك الذين أنعم الله عليهم من النبيين من ذرية آدم﴾</span></span>: أولئك مبتدأ، والذين خبر، أو بدل من اسم الإشارة، وجملة <span class="hlt"><span class="qpc-hafs">﴿أنعم الله عليهم﴾</span></span> صلة الذين لا محل لها من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿من النبيين﴾</span></span> جار ومجرور متعلقان بمحذوف حال، و<span class="hlt"><span class="qpc-hafs">﴿من ذرية آدم﴾</span></span> بدل بإعادة الجار، والجار والمجرور متعلقان بحال من الضمير في عليهم.</p><p><span class="hlt"><span class="qpc-hafs">﴿وممن حملنا مع نوح ومن ذرية إبراهيم وإسرائيل وممن هدينا واجتبينا﴾</span></span>: عطف على ما تقدم.</p><p><span class="hlt"><span class="qpc-hafs">﴿إذا تتلى عليهم آيات الرحمن خروا سجدا وبكيا﴾</span></span>: جملة <span class="hlt"><span class="qpc-hafs">﴿إذا تتلى...﴾</span></span> وجوابها استئنافية لا محل لها من الإعراب إذا أعربت <span class="hlt"><span class="qpc-hafs">﴿الذين﴾</span></span> خبرًا، أما إذا أعربتها بدلًا فجملة <span class="hlt"><span class="qpc-hafs">﴿إذا تتلى﴾</span></span> خبر، وجملة <span class="hlt"><span class="qpc-hafs">﴿خروا﴾</span></span> لا محل لها من الإعراب، لأنها جواب إذا، والواو في خروا فاعل، وسجدًا حال من الفاعل، وبكيًّا عطف على <span class="hlt"><span class="qpc-hafs">﴿سجدًا﴾</span></span>.</p></div>"
  19,59,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فخلف من بعدهم خلف أضاعوا الصلاة واتبعوا الشهوات فسوف يلقون غيا﴾</span></span>: الفاء عاطفة وخلف فعل ماض، ومن بعدهم حال، وخلف فاعل، وجملة <span class="hlt"><span class="qpc-hafs">﴿أضاعوا الصلاة﴾</span></span> صفة لخلف، <span class="hlt"><span class="qpc-hafs">﴿واتبعوا الشهوات﴾</span></span> عطف على <span class="hlt"><span class="qpc-hafs">﴿أضاعوا الصلاة﴾</span></span>، والفاء الفصيحة، وسوف حرف استقبال، ويلقون فعل مضارع وفاعل، وغيًّا مفعول به.</p></div>"
  19,60,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إلا من تاب وآمن وعمل صالحا فأولئك يدخلون الجنة ولا يظلمون شيئا﴾</span></span>: إلا أداة استثناء، و<span class="hlt"><span class="qpc-hafs">﴿من﴾</span></span> مستثنى منصوب، وجملة تاب صلة <span class="hlt"><span class="qpc-hafs">﴿من﴾</span></span> لا محل لها من الإعراب، وآمن عطف على تاب، وعمل عطف أيضًا، وصالحًا مفعول به لـ<span class="hlt"><span class="qpc-hafs">﴿عمل﴾</span></span>، أو نائب عن المفعول المطلق، لأنه صفة المصدر، أي: عمل عملًا صالحًا. فأولئك الفاء الفصيحة، وأولئك مبتدأ، وجملة يدخلون خبر، والجنة مفعول به على السعة، ولا يظلمون عطف على يدخلون، وشيئًا نائب عن المفعول المطلق، أو مفعول ثان بتضمين يظلمون معنى ينقصون.</p></div>"
  19,61,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿جنات عدن التي وعد الرحمن عباده بالغيب﴾</span></span>: جنات بدل من الجنة، وعدن مضاف إليه، والتي صفة لجنات عدن، وجملة وعد صلة <span class="hlt"><span class="qpc-hafs">﴿التي﴾</span></span> لا محل لها من الإعراب، والرحمن فاعل وعد، وعباده مفعول به، وبالغيب حال من عباده، أو حال من ضمير الجنة، وهو الضمير العائد على الموصول، أي: وعدها، وهم غائبون عنها لا يرونها.</p></div>"
  19,62,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿لا يسمعون فيها لغوا إلا سلاما ولهم رزقهم فيها بكرة وعشيا﴾</span></span>: الجملة حال من جنات عدن، ولا نافية، ويسمعون فعل مضارع، والواو فاعل، وفيها جار ومجرور متعلقان بمحذوف حال، أي: حالة كونهم في ا لجنة، ولغوًا مفعول به، وإلا أداة حصر، وسلامًا بدل من <span class="hlt"><span class="qpc-hafs">﴿لغوًا﴾</span></span>، أو مستثنى منقطع، و<span class="hlt"><span class="qpc-hafs">﴿لهم﴾</span></span> جار ومجرور متعلقان بمحذوف خبر مقدم، ورزقهم مبتدأ مؤخر، وفيها جار ومجرور متعلقان بمحذوف حال، وبكرة ظرف متعلق بمعنى الاستقرار المستكن في الخبر المقدم، وعشيًّا عطف على بكرة.</p></div>"
  19,63,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿تلك الجنة التي نورث من عبادنا من كان تقيا﴾</span></span>: اسم الإشارة مبتدأ، والجنة خبر، والتي صفة للجنة، وجملة نورث صلة <span class="hlt"><span class="qpc-hafs">﴿التي﴾</span></span> لا محل لها من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿مَن﴾</span></span> اسم موصول مفعول نورث، وجملة كان صلة <span class="hlt"><span class="qpc-hafs">﴿من﴾</span></span> لا محل لها من الإعراب، واسم كان مستتر تقديره: هو، وتقيًّا خبر كان.</p></div>"
  19,64,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وما نتنزل إلا بأمر ربك﴾</span></span>: الواو استئنافية، والجملة بعدها مستأنفة لا محل لها من الإعراب، وما نافية، ونتنزل فعل مضارع مرفوع، وفاعله مستتر تقديره: نحن، و<span class="hlt"><span class="qpc-hafs">﴿إلا بأمر ربك﴾</span></span> استثناء من أعم الأحوال، فإلا أداة حصر، وبأمر جار ومجرور متعلقان بمحذوف حال.</p><p><span class="hlt"><span class="qpc-hafs">﴿وما كان ربك نسيا﴾</span></span>: الواو حرف عطف، وما نافية، وكان فعل ماض ناقص، وربك اسم كان مرفوع، ونسيا خبر كان منصوب.</p></div>"