quran[9]{c,v,t}:
  17,67,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وإذا مسكم الضر في البحر ضل من تدعون إلا إياه﴾</span></span>: الواو عاطفة، وإذا ظرف مستقبل متضمن معنى الشرط، وجملة مسكم مضاف إليه، والكاف مفعول به، والضر فاعل، و<span class="hlt"><span class="qpc-hafs">﴿في البحر﴾</span></span> جار ومجرور متعلقان بمحذوف حال، أي: حالة كونكم في البحر، وجملة ضل لا محل لها من الإعراب، لأنها جواب شرط غير جازم، و<span class="hlt"><span class="qpc-hafs">﴿مَن﴾</span></span> فاعل <span class="hlt"><span class="qpc-hafs">﴿ضل﴾</span></span>، وجملة تدعون صلة <span class="hlt"><span class="qpc-hafs">﴿من﴾</span></span> لا محل لها من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿إلا إياه﴾</span></span> استثناء متصل، وقيل: منقطع، أي: ضل من تدعونه من الآلهة عن إغاثتكم، ولكن الله وحده هو الذي ترجونه وحده.</p><p><span class="hlt"><span class="qpc-hafs">﴿فلما نجاكم إلى البر أعرضتم وكان الإنسان كفورا﴾</span></span>: لما أداة شرط غير جازمة، ونجاكم فعل ماض ومفعول به، وهو فعل الشرط، وفاعله مستتر تقديره: هو، و<span class="hlt"><span class="qpc-hafs">﴿إلى البر﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿نجاكم﴾</span></span>، وأعرضتم جواب الشرط، وكان فعل ماض ناقص ناسخ، والإنسان اسمها، وكفورا خبرها.</p></div>"
  17,68,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿أفأمنتم أن يخسف بكم جانب البر﴾</span></span>: الهمزة للاستفهام الإنكاري، والفاء عاطفة على محذوف تقديره: أنجوتم فأمنتم فحملتكم نجاتكم على الإعراض؟ وأمنتم فعل وفاعل، و<span class="hlt"><span class="qpc-hafs">﴿أن يخسف﴾</span></span> في تأويل مصدر منصوب بنزع الخافض، أي: من أن يخسف، والجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أمنتم﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿بكم﴾</span></span> جار ومجرور متعلقان بمحذوف حال، أي: مصحوبًا بكم، فالباء للمصاحبة، أو الجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يخسف﴾</span></span>، والباء للسببية، و<span class="hlt"><span class="qpc-hafs">﴿جانب البر﴾</span></span> مفعول يخسف.</p><p><span class="hlt"><span class="qpc-hafs">﴿أو يرسل عليكم حاصبا﴾</span></span>: أو حرف عطف، ويرسل عطف على يخسف، و<span class="hlt"><span class="qpc-hafs">﴿عليكم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يرسل﴾</span></span>، وحاصبًا مفعول به.</p><p><span class="hlt"><span class="qpc-hafs">﴿ثم لا تجدوا لكم وكيلا﴾</span></span>: ثم حرف عطف للتراخي، ولا نافية، وتجدوا عطف على يرسل أيضًا، و<span class="hlt"><span class="qpc-hafs">﴿لكم﴾</span></span> جار ومجرور متعلقان بمحذوف حال، لأنه كان في الأصل صفة لـ<span class="hlt"><span class="qpc-hafs">﴿وكيلًا﴾</span></span> وتقدمت عليه، ووكيلًا مفعول به.</p></div>"
  17,69,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿أم أمنتم أن يعيدكم فيه تارة أخرى﴾</span></span>: أم حرف عطف، وأمنتم فعل وفاعل، والمصدر المؤول من أن والفعل في <span class="hlt"><span class="qpc-hafs">﴿أن يعيدكم﴾</span></span> منصوب بنزع الخافض، والجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أمنتم﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿فيه﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يعيدكم﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿تارة﴾</span></span> ظرف متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿يعيدكم﴾</span></span> أيضًا، وأخرى صفة.</p><p><span class="hlt"><span class="qpc-hafs">﴿فيرسل عليكم قاصفا من الريح فيغرقكم بما كفرتم﴾</span></span>: الفاء عاطفة، ويرسل عطف على أن يعيدكم، و<span class="hlt"><span class="qpc-hafs">﴿عليكم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يرسل﴾</span></span>، وقاصفًا مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿من الريح﴾</span></span> جار ومجرور متعلقان بمحذوف صفة، والفاء حرف عطف، ويغرقكم عطف على يرسل، و<span class="hlt"><span class="qpc-hafs">﴿بما﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يغرقكم﴾</span></span>، وما مصدرية، أي: بسبب كفركم.</p><p><span class="hlt"><span class="qpc-hafs">﴿ثم لا تجدوا لكم علينا به تبيعا﴾</span></span>: ثم حرف عطف، ولا تجدوا عطف على يغرقكم، و<span class="hlt"><span class="qpc-hafs">﴿لكم﴾</span></span> جار ومجرور متعلقان بمحذوف حال، لأنه كان في الأصل صفة لـ<span class="hlt"><span class="qpc-hafs">﴿تبيعًا﴾</span></span> وتقدمت عليه، و<span class="hlt"><span class="qpc-hafs">﴿علينا﴾</span></span> جار ومجرور متعلقان بمحذوف حال أيضًا، و<span class="hlt"><span class="qpc-hafs">﴿به﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تبيعًا﴾</span></span>، وقيل: <span class="hlt"><span class="qpc-hafs">﴿علينا﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تبيعا﴾</span></span>.</p></div>"
  17,70,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ولقد كرمنا بني آدم وحملناهم في البر والبحر﴾</span></span>: الواو استئنافية، والجملة بعدها مستأنفة لا محل لها من الإعراب، واللام جواب للقسم المحذوف، وقد حرف تحقيق، وكرمنا فعل وفاعل، وبني آدم مفعول به، وحملناهم فعل وفاعل ومفعول به، عطف على كرمنا، <span class="hlt"><span class="qpc-hafs">﴿في البر والبحر﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿حملناهم﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿ورزقناهم من الطيبات وفضلناهم على كثير ممن خلقنا تفضيلا﴾</span></span>: الواو عاطفة، ورزقناهم فعل وفاعل ومفعول به، عطف على كرمنا، و<span class="hlt"><span class="qpc-hafs">﴿من الطيبات﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿رزقناهم﴾</span></span>، وفضلناهم عطف على كرمنا، و<span class="hlt"><span class="qpc-hafs">﴿على كثير﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿فضلناهم﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿ممن خلقنا﴾</span></span> جار ومجرور متعلقان بمحذوف صفة لـ<span class="hlt"><span class="qpc-hafs">﴿كثير﴾</span></span>، وجملة خلقنا صلة <span class="hlt"><span class="qpc-hafs">﴿من﴾</span></span> لا محل لها من الإعراب، وتفضيلًا مفعول مطلق.</p></div>"
  17,71,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿يوم ندعو كل أناس بإمامهم﴾</span></span>: الظرف متعلق بمحذوف تقديره: اذكر، وندعو فعل مضارع، والفاعل مستتر تقديره: نحن، وكل أناس مفعول به، وجملة ندعو مضاف إليه، و<span class="hlt"><span class="qpc-hafs">﴿بإمامهم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿ندعو﴾</span></span>، أو متعلقان بمحذوف حال، أي: موسومين ومعروفين بإمامهم.</p><p><span class="hlt"><span class="qpc-hafs">﴿فمن أوتي كتابه بيمينه﴾</span></span>: الفاء عاطفة، ومن شرطية، أو موصولة في محل رفع مبتدأ، وأوتي فعل ماض مبني لما لم يسمَّ فاعله، ونائب الفاعل مستتر، وكتابه مفعول به ثان، وبيمينه جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أوتي﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿فأولئك يقرءون كتابهم﴾</span></span>: الفاء رابطة، وأولئك مبتدأ، وجملة يقرءون خبر، وكتابهم مفعول به، وجملة أولئك جواب الشرط، أو خبر الموصول.</p><p><span class="hlt"><span class="qpc-hafs">﴿ولا يظلمون فتيلا﴾</span></span>: الواو حرف عطف، ولا نافية، و<span class="hlt"><span class="qpc-hafs">﴿يظلمون﴾</span></span> فعل مضارع مبني لما لم يسمَّ فاعله، والواو نائب فاعل، و<span class="hlt"><span class="qpc-hafs">﴿فتيلا﴾</span></span> نائب عن المفعول المطلق، أي: ظلمًا قدر الفتيل.</p></div>"
  17,72,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ومن كان في هذه أعمى﴾</span></span>: الواو عاطفة، ومن شرطية، أو موصولة، وكان فعل ماض ناقص ناسخ، واسمها ضمير مستتر يعود على <span class="hlt"><span class="qpc-hafs">﴿مَن﴾</span></span>، أو على ضمير الشأن، وأعمى خبر كان، و<span class="hlt"><span class="qpc-hafs">﴿في هذه﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿كان﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿فهو في الآخرة أعمى وأضل سبيلا﴾</span></span>: الفاء رابطة، و<span class="hlt"><span class="qpc-hafs">﴿هو﴾</span></span> مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿في الآخرة﴾</span></span> جار ومجرور متعلقان بمحذوف حال، وأعمى خبر، وأضل عطف على أعمى، وسبيلًا تمييز.</p></div>"
  17,73,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وإن كادوا ليفتنونك عن الذي أوحينا إليك لتفتري علينا غيره﴾</span></span>: الواو استئنافية، والجملة بعدها مستأنفة لا محل لها من الإعراب، وإن مخففة من الثقيلة مهملة، وكادوا فعل ماض ناقص من أفعال المقاربة، والواو اسمها، واللام الفارقة، وجملة <span class="hlt"><span class="qpc-hafs">﴿يفتنونك﴾</span></span> خبر كادوا، و<span class="hlt"><span class="qpc-hafs">﴿عن الذي﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يفتنونك﴾</span></span>، وجملة أوحينا صلة الذي لا محل لها من الإعراب، وإليك جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أوحينا﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿لتفتري﴾</span></span> اللام لام التعليل، وتفتري مضارع منصوب بأن مضمرة بعد لام التعليل، و<span class="hlt"><span class="qpc-hafs">﴿علينا﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تفتري﴾</span></span>، والفاعل مستتر تقديره: أنت، وغيره مفعول به.</p><p><span class="hlt"><span class="qpc-hafs">﴿وإذا لاتخذوك خليلا﴾</span></span>: الواو عاطفة، وإذًا حرف جزاء وجواب يقدر بـ<span class="hlt"><span class="qpc-hafs">﴿لو﴾</span></span> الشرطية، أي: ولو اتبعت مرادهم، واللام واقعة في جواب الشرط المقدر بـ<span class="hlt"><span class="qpc-hafs">﴿لو﴾</span></span>، والكاف مفعول به أول، وخليلًا مفعول به ثان.</p></div>"
  17,74,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ولولا أن ثبتناك لقد كدت تركن إليهم شيئا قليلا﴾</span></span>: لولا حرف امتناع لوجود، وأن وما في حيزها مبتدأ محذوف الخبر، واللام جواب لولا، وقد حرف تحقيق، وكدت فعل ماض من أفعال المقاربة، والتاء اسمها، وجملة تركن خبرها، و<span class="hlt"><span class="qpc-hafs">﴿إليهم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تركن﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿شيئا﴾</span></span> نائب عن المفعول المطلق، لأنه بمعنى الركون، أي: شيئًا قليلًا من الركون.</p></div>"
  17,75,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إذا لأذقناك ضعف الحياة وضعف الممات ثم لا تجد لك علينا نصيرا﴾</span></span>: إذًا حرف جواب وجزاء يقدر بـ<span class="hlt"><span class="qpc-hafs">﴿لو﴾</span></span> الشرطية، أي: ولو اتبعت مرادهم،  واللام واقعة في جواب الشرط المقدر بـ<span class="hlt"><span class="qpc-hafs">﴿لو﴾</span></span>، وأذقناك فعل وفاعل ومفعول به، وضعف مفعول ثان، والحياة مضاف إليه، ولا بد من تقدير محذوف، أي: ضعف عذاب الحياة، وضعف عذاب الممات، وثم حرف عطف وتراخ، ولا نافية، وتجد فعل مضارع، وفاعله مستتر تقديره: أنت، ولك جار ومجرور متعلقان بتجد، وعلينا جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿نصيرًا﴾</span></span>، ونصيرًا مفعول به.</p></div>"