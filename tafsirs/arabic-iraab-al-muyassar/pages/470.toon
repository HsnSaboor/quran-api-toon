quran[8]{c,v,t}:
  40,26,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وقال فرعون ذروني أقتل موسى﴾</span></span>: الواو عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿قال فرعون﴾</span></span> فعل ماض وفاعل، و<span class="hlt"><span class="qpc-hafs">﴿ذروني﴾</span></span> فعل أمر، والواو فاعل، والياء مفعول به، والجملة مقول القول، و<span class="hlt"><span class="qpc-hafs">﴿أقتل﴾</span></span> فعل مضارع مجزوم، لأنه جواب الطلب، والفاعل مستتر تقديره: أنا، يعود على القائل.</p><p><span class="hlt"><span class="qpc-hafs">﴿وليدع ربه﴾</span></span>: الواو عاطفة، واللام لام الأمر، و<span class="hlt"><span class="qpc-hafs">﴿يدع﴾</span></span> فعل مضارع مجزوم بلام الأمر، والفاعل مستتر، و<span class="hlt"><span class="qpc-hafs">﴿ربه﴾</span></span> مفعول به.</p><p><span class="hlt"><span class="qpc-hafs">﴿إني أخاف أن يبدل دينكم﴾</span></span>: الجملة تعليلية، و<span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span> حرف ناسخ، والياء اسمها، و<span class="hlt"><span class="qpc-hafs">﴿أخاف﴾</span></span> فعل مضارع مرفوع، و<span class="hlt"><span class="qpc-hafs">﴿أن﴾</span></span> حرف مصدري ونصب، و<span class="hlt"><span class="qpc-hafs">﴿يبدل﴾</span></span> فعل مضارع منصوب بـ<span class="hlt"><span class="qpc-hafs">﴿أن﴾</span></span>، والفاعل مستتر، و<span class="hlt"><span class="qpc-hafs">﴿دينكم﴾</span></span> مفعول به.</p><p><span class="hlt"><span class="qpc-hafs">﴿أو أن يظهر في الأرض الفساد﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿أو﴾</span></span> حرف عطف، و<span class="hlt"><span class="qpc-hafs">﴿أن يظهر﴾</span></span> عطف على <span class="hlt"><span class="qpc-hafs">﴿أن يبدل﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿في الأرض﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يظهر﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿الفساد﴾</span></span> مفعول <span class="hlt"><span class="qpc-hafs">﴿يظهر﴾</span></span>.</p></div>"
  40,27,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وقال موسى إني عذت بربي وربكم من كل متكبر لا يؤمن بيوم الحساب﴾</span></span>: الواو عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿قال﴾</span></span> فعل ماض، و<span class="hlt"><span class="qpc-hafs">﴿موسى﴾</span></span> فاعل، و<span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span> حرف ناسخ، والياء اسمها، و<span class="hlt"><span class="qpc-hafs">﴿عذت﴾</span></span> فعل ماض، والتاء فاعل، وجملة <span class="hlt"><span class="qpc-hafs">﴿عذت﴾</span></span> خبر إن، والجملة مقول القول، و<span class="hlt"><span class="qpc-hafs">﴿من كل متكبر﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿عذت﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿لا يؤمن﴾</span></span> نعت لـ<span class="hlt"><span class="qpc-hafs">﴿متكبر﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿بيوم الحساب﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يؤمن﴾</span></span>.</p></div>"
  40,28,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وقال رجل مؤمن من آل فرعون يكتم إيمانه﴾</span></span>: كلام مستأنف لا محل له من الإعراب. و<span class="hlt"><span class="qpc-hafs">﴿قال رجل﴾</span></span> فعل ماض، وفاعل، و<span class="hlt"><span class="qpc-hafs">﴿مؤمن﴾</span></span> نعت لـ<span class="hlt"><span class="qpc-hafs">﴿رجل﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿من آل فرعون﴾</span></span> جار ومجرور متعلقان بمحذوف نعت ثان إن كان الرجل قبطيًّا، والتقدير: وقال رجل مؤمن منسوب من آل فرعون، وإن كان الرجل إسرائيليًّا فالجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يكتم﴾</span></span> في موضع المفعول الثاني لـ<span class="hlt"><span class="qpc-hafs">﴿يكتم﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿يكتم إيمانه﴾</span></span> صفة ثالثة لـ<span class="hlt"><span class="qpc-hafs">﴿رجل﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿أتقتلون رجلًا أن يقول ربي الله﴾</span></span>: الهمزة للاستفهام الإنكاري، و<span class="hlt"><span class="qpc-hafs">﴿تقتلون﴾</span></span> فعل مضارع مرفوع بثبوت النون، والواو فاعل، و<span class="hlt"><span class="qpc-hafs">﴿رجلًا﴾</span></span> مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿أن﴾</span></span> حرف مصدري ونصب، و<span class="hlt"><span class="qpc-hafs">﴿يقول﴾</span></span> فعل مضارع منصوب، وأن ما في حيزها في محل نصب مفعول لأجله، أي: لأجل هذا القول من غير روية وتدبر وتأمل، وقيل: ظرف على تقدير مضاف، أي: وقت أن يقول، و<span class="hlt"><span class="qpc-hafs">﴿ربي﴾</span></span> مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿الله﴾</span></span> خبره، أو بالعكس، والجملة مقول القول.</p><p><span class="hlt"><span class="qpc-hafs">﴿وقد جاءكم بالبينات من ربكم﴾</span></span>: الواو حالية، و<span class="hlt"><span class="qpc-hafs">﴿قد﴾</span></span> حرف تحقيق، و<span class="hlt"><span class="qpc-hafs">﴿جاءكم﴾</span></span> فعل ماض، والفاعل مستتر تقديره: هو، والكاف مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿بالبينات﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿جاءكم﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿من ربكم﴾</span></span> جار ومجرور متعلقان بمحذوف حال.</p><p><span class="hlt"><span class="qpc-hafs">﴿وإن يك كاذبًا فعليه كذبه وإن يك صادقًا يصبكم بعض الذي يعدكم﴾</span></span>: الواو عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span> شرطية، و<span class="hlt"><span class="qpc-hafs">﴿يك﴾</span></span> فعل الشرط مجزوم وعلامة جزمه السكون المقدر على النون المحذوفة للتخفيف، وهي فعل مضارع ناقص ناسخ، واسمها ضمير مستتر تقديره: هو، و<span class="hlt"><span class="qpc-hafs">﴿كاذبًا﴾</span></span> خبرها، <span class="hlt"><span class="qpc-hafs">﴿فعليه﴾</span></span> الفاء رابطة لجواب الشرط، و<span class="hlt"><span class="qpc-hafs">﴿عليه﴾</span></span> جار ومجرور متعلقان بمحذوف خبر مقدم، و<span class="hlt"><span class="qpc-hafs">﴿كذبه﴾</span></span> مبتدأ مؤخر، والجملة الاسمية في محل جزم جواب الشرط، وجملة <span class="hlt"><span class="qpc-hafs">﴿إن يك صادقًا يصبكم بعض الذي يعدكم﴾</span></span> عطف على الجملة السابقة، و<span class="hlt"><span class="qpc-hafs">﴿يصبكم﴾</span></span> فعل مضارع مجزوم في جواب الشرط، والكاف مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿بعض﴾</span></span> فاعل <span class="hlt"><span class="qpc-hafs">﴿يصبكم﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿يعدكم﴾</span></span> صلة الموصول لا محل لها من الإعراب.</p><p><span class="hlt"><span class="qpc-hafs">﴿إن الله لا يهدي من هو مسرف كذاب﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span> حرف ناسخ، ولفظ الجلالة اسمها، و<span class="hlt"><span class="qpc-hafs">﴿لا﴾</span></span> نافية، و<span class="hlt"><span class="qpc-hafs">﴿يهدي﴾</span></span> فعل مضارع، والفاعل مستتر، و<span class="hlt"><span class="qpc-hafs">﴿مَن﴾</span></span> مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿هو﴾</span></span> مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿مسرف﴾</span></span> خبر، و<span class="hlt"><span class="qpc-hafs">﴿كذاب﴾</span></span> خبر ثان، وجملة <span class="hlt"><span class="qpc-hafs">﴿هو مسرف﴾</span></span> صلة <span class="hlt"><span class="qpc-hafs">﴿مَن﴾</span></span> لا محل لها من الإعراب. وجملة <span class="hlt"><span class="qpc-hafs">﴿لا يهدي من...﴾</span></span> خبر إن.</p></div>"
  40,29,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿يا قوم لكم الملك اليوم ظاهرين في الأرض﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿يا﴾</span></span> حرف نداء، و<span class="hlt"><span class="qpc-hafs">﴿قوم﴾</span></span> منادى مضاف لياء المتكلم المحذوفة، و<span class="hlt"><span class="qpc-hafs">﴿لكم﴾</span></span> جار ومجرور متعلقان بمحذوف خبر مقدم، و<span class="hlt"><span class="qpc-hafs">﴿الملك﴾</span></span> مبتدأ مؤخر، و<span class="hlt"><span class="qpc-hafs">﴿اليوم﴾</span></span> ظرف متعلق بما تعلق به الخبر، و<span class="hlt"><span class="qpc-hafs">﴿ظاهرين﴾</span></span> حال من الضمير في <span class="hlt"><span class="qpc-hafs">﴿لكم﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿في الأرض﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿ظاهرين﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿فمن ينصرنا من بأس الله إن جاءنا﴾</span></span>: الفاء الفصيحة، و<span class="hlt"><span class="qpc-hafs">﴿من﴾</span></span> اسم استفهام مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿ينصرنا﴾</span></span> فعل مضارع مرفوع، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> مفعول به، والفاعل مستتر، وجملة <span class="hlt"><span class="qpc-hafs">﴿ينصرنا﴾</span></span> خبر، و<span class="hlt"><span class="qpc-hafs">﴿من بأس الله﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿ينصرنا﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span> شرطية، و<span class="hlt"><span class="qpc-hafs">﴿جاءنا﴾</span></span> فعل ماض مبني على الفتح في محل جزم فعل الشرط، والجواب محذوف دل عليه ما قبله، أي: فمن ينصرنا، وفاعل <span class="hlt"><span class="qpc-hafs">﴿جاءنا﴾</span></span> يعود على <span class="hlt"><span class="qpc-hafs">﴿بأس الله﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿قال فرعون ما أريكم إلا ما أرى﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿قال فرعون﴾</span></span> فعل وفاعل، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> نافية، و<span class="hlt"><span class="qpc-hafs">﴿أريكم﴾</span></span> فعل مضارع، وفاعله مستتر تقديره: أنا، والكاف مفعول به أول، و<span class="hlt"><span class="qpc-hafs">﴿إلا﴾</span></span> أداة حصر، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> اسم موصول مفعول ثان لـ<span class="hlt"><span class="qpc-hafs">﴿أريكم﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿أرى﴾</span></span> صلة الموصول لا محل لها من الإعراب.</p><p><span class="hlt"><span class="qpc-hafs">﴿وما أهديكم إلا سبيل الرشاد﴾</span></span>: عطف على ما تقدم، و<span class="hlt"><span class="qpc-hafs">﴿سبيل الرشاد﴾</span></span> مفعول ثان لـ<span class="hlt"><span class="qpc-hafs">﴿أهديكم﴾</span></span>، أو نصب بنزع الخافض.</p></div>"
  40,30,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وقال الذي آمن يا قوم إني أخاف عليكم مثل يوم الأحزاب﴾</span></span>: الواو عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿قال﴾</span></span> فعل ماض، و<span class="hlt"><span class="qpc-hafs">﴿الذي﴾</span></span> فاعل، و<span class="hlt"><span class="qpc-hafs">﴿آمن﴾</span></span> فعل ماض، وجملة <span class="hlt"><span class="qpc-hafs">﴿آمن﴾</span></span> صلة الموصول لا محل لها من الإعراب. و<span class="hlt"><span class="qpc-hafs">﴿يا﴾</span></span> حرف نداء، و<span class="hlt"><span class="qpc-hafs">﴿قوم﴾</span></span> منادى مضاف لياء المتكلم المحذوفة، و<span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span> حرف ناسخ، والياء اسمها، وجملة <span class="hlt"><span class="qpc-hafs">﴿أخاف﴾</span></span> خبر، و<span class="hlt"><span class="qpc-hafs">﴿عليكم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أخاف﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿مثل﴾</span></span> مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿يوم الأحزاب﴾</span></span> مضاف إليه.</p></div>"
  40,31,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿مثل دأب قوم نوح وعاد وثمود والذين من بعدهم﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿مثل﴾</span></span> عطف بيان، أو بدل لـ<span class="hlt"><span class="qpc-hafs">﴿مثل﴾</span></span> في الآية السابقة، و<span class="hlt"><span class="qpc-hafs">﴿دأب﴾</span></span> مضاف إليه، ولا بد من تقدير مضاف محذوف، أي: مثل جزاء وعادة من كفر قبلكم من تعذيبهم في الدنيا، <span class="hlt"><span class="qpc-hafs">﴿وعاد وثمود والذين من بعدهم﴾</span></span> عطف على ما سبق، و<span class="hlt"><span class="qpc-hafs">﴿من بعدهم﴾</span></span> جار ومجرور متعلقان بمحذوف صلة الموصول. وجملة الصلة لا محل لها من الإعراب.</p><p><span class="hlt"><span class="qpc-hafs">﴿وما الله يريد ظلما للعباد﴾</span></span>: الواو عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> نافية حجازية تعمل عمل ليس، ولفظ الجلالة اسم ما، وجملة <span class="hlt"><span class="qpc-hafs">﴿يريد﴾</span></span> خبر ما، أو <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> نافية غير عاملة، ولفظ الجلالة مبتدأ، وجملة <span class="hlt"><span class="qpc-hafs">﴿يريد﴾</span></span> خبر المبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿ظلمًا﴾</span></span> مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿للعباد﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿ظلمًا﴾</span></span>.</p></div>"
  40,32,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ويا قوم إني أخاف عليكم يوم التناد﴾</span></span>: عطف على <span class="hlt"><span class="qpc-hafs">﴿إني أخاف﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿يا﴾</span></span> حرف نداء، و<span class="hlt"><span class="qpc-hafs">﴿قوم﴾</span></span> منادى مضاف لياء المتكلم المحذوفة، و<span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span> حرف ناسخ، والياء اسمها، وجملة <span class="hlt"><span class="qpc-hafs">﴿أخاف﴾</span></span> خبر، و<span class="hlt"><span class="qpc-hafs">﴿عليكم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أخاف﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿يوم التناد﴾</span></span> مفعول <span class="hlt"><span class="qpc-hafs">﴿أخاف﴾</span></span>.</p></div>"
  40,33,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿يوم تولون مدبرين ما لكم من الله من عاصم﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿يوم﴾</span></span> بدل من يوم الأول، وجملة <span class="hlt"><span class="qpc-hafs">﴿تولون﴾</span></span> في محل جر بإضافة الظرف إليها، و<span class="hlt"><span class="qpc-hafs">﴿مدبرين﴾</span></span> حال، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> نافية، و<span class="hlt"><span class="qpc-hafs">﴿لكم﴾</span></span> جار ومجرور متعلقان بمحذوف خبر مقدم، و<span class="hlt"><span class="qpc-hafs">﴿من الله﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿عاصم﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿من عاصم﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿من﴾</span></span> حرف جر صلة، و<span class="hlt"><span class="qpc-hafs">﴿عاصم﴾</span></span> مبتدأ مؤخر مرفوع محلا مجرور بـ<span class="hlt"><span class="qpc-hafs">﴿مِن﴾</span></span> لفظًا، وجملة <span class="hlt"><span class="qpc-hafs">﴿ما لكم من الله من عاصم﴾</span></span> في محل نصب على الحال.</p><p><span class="hlt"><span class="qpc-hafs">﴿ومن يضلل الله فما له من هاد﴾</span></span>: الواو استئنافية، و<span class="hlt"><span class="qpc-hafs">﴿مَن﴾</span></span> اسم شرط جازم في محل نصب مفعول مقدم لـ<span class="hlt"><span class="qpc-hafs">﴿يضلل﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿الله﴾</span></span> فاعل، والفاء رابطة، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> نافية، و<span class="hlt"><span class="qpc-hafs">﴿له﴾</span></span> جار ومجرور متعلقان بمحذوف خبر مقدم، و<span class="hlt"><span class="qpc-hafs">﴿مِن﴾</span></span> حرف جر صلة، و<span class="hlt"><span class="qpc-hafs">﴿هاد﴾</span></span> اسم مجرور لفظًا مرفوع محلا على أنه مبتدأ مؤخر، وجملة <span class="hlt"><span class="qpc-hafs">﴿ومن يضلل...﴾</span></span> مستأنفة لا محل لها من الإعراب.</p></div>"