quran[25]{c,v,t}:
  37,52,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿يقول أئنك لمن المصدقين﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿يقول﴾</span></span> فعل مضارع مرفوع، والفاعل مستتر تقديره: هو، والهمزة للاستفهام الإنكاري، و<span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span> حرف ناسخ، والكاف اسمها، واللام المزحلقة، و<span class="hlt"><span class="qpc-hafs">﴿من المصدقين﴾</span></span> جار ومجرور متعلقان بمحذوف خبر إن، والجملة مقول القول، وجملة <span class="hlt"><span class="qpc-hafs">﴿يقول﴾</span></span> صفة لـ<span class="hlt"><span class="qpc-hafs">﴿قرين﴾</span></span>.</p></div>"
  37,53,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿أئذا متنا وكنا ترابا وعظاما﴾</span></span>: الهمزة للاستفهام الإنكاري، و<span class="hlt"><span class="qpc-hafs">﴿إذا﴾</span></span> ظرف مستقبل متضمن معنى الشرط، و<span class="hlt"><span class="qpc-hafs">﴿متنا﴾</span></span> فعل ماض، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> فاعل، وجملة <span class="hlt"><span class="qpc-hafs">﴿متنا﴾</span></span> في محل جر بإضافة الظرف إليها، و<span class="hlt"><span class="qpc-hafs">﴿كنا﴾</span></span> فعل ماض ناقص، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> اسمها، و<span class="hlt"><span class="qpc-hafs">﴿ترابًا﴾</span></span> خبرها، و<span class="hlt"><span class="qpc-hafs">﴿عظامًا﴾</span></span> عطف على <span class="hlt"><span class="qpc-hafs">﴿ترابًا﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿أئنا لمدينون﴾</span></span>: الهمزة للاستفهام، و<span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span> حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> اسمها، واللام المزحلقة، و<span class="hlt"><span class="qpc-hafs">﴿مدينون﴾</span></span> خبر إن.</p></div>"
  37,54,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قال هل أنتم مطلعون﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿قال﴾</span></span> فعل ماض ناقص، والفاعل ضمير مستتر تقديره: هو، و<span class="hlt"><span class="qpc-hafs">﴿هل﴾</span></span> حرف استفهام، و<span class="hlt"><span class="qpc-hafs">﴿أنتم﴾</span></span> مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿مطلعون﴾</span></span> خبر.</p></div>"
  37,55,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فاطلع فرآه في سواء الجحيم﴾</span></span>: الفاء عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿اطلع﴾</span></span> فعل ماض، وفاعله ضمير مستتر تقديره: هو، <span class="hlt"><span class="qpc-hafs">﴿فرآه﴾</span></span> الفاء عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿رآه﴾</span></span> فعل ماض، والفاعل مستتر، والهاء مفعول به، أي: رأى قرينه، و<span class="hlt"><span class="qpc-hafs">﴿في سواء الجحيم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿رآه﴾</span></span>، أو متعلقان بمحذوف حال، أي: مرتطمًا في وسط جهنم.</p></div>"
  37,56,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قال تالله إن كدت لتردين﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿قال﴾</span></span> فعل ماض، والفاعل مستتر، و<span class="hlt"><span class="qpc-hafs">﴿تالله﴾</span></span> التاء حرف قسم وجر، ولفظ الجلالة مجرور، والجار والمجرور متعلقان بفعل محذوف تقديره: أقسم، و<span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span> مخففة من الثقيلة مهملة، و<span class="hlt"><span class="qpc-hafs">﴿كدت﴾</span></span> من أفعال المقاربة، والتاء اسمها، واللام هي الفارقة، و<span class="hlt"><span class="qpc-hafs">﴿تردين﴾</span></span> فعل مضارع مرفوع، وفاعله ضمير مستتر تقديره: أنت، والنون للوقاية، والياء المحذوفة تخفيفا مفعول به، وجملة <span class="hlt"><span class="qpc-hafs">﴿لتردين﴾</span></span> خبر <span class="hlt"><span class="qpc-hafs">﴿كدت﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿إن كدت﴾</span></span> جواب القسم لا محل لها من الإعراب.</p></div>"
  37,57,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ولولا نعمة ربي لكنت من المحضرين﴾</span></span>: الواو عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿لولا﴾</span></span> حرف امتناع لوجود، و<span class="hlt"><span class="qpc-hafs">﴿نعمة﴾</span></span> مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿ربي﴾</span></span> مضاف إليه، وخبر المبتدأ محذوف وجوبًا، والتقدير: موجودة، <span class="hlt"><span class="qpc-hafs">﴿لكنت﴾</span></span> اللام واقعة في جواب <span class="hlt"><span class="qpc-hafs">﴿لولا﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿كنت﴾</span></span> فعل ماض ناقص ناسخ، والتاء اسمها، و<span class="hlt"><span class="qpc-hafs">﴿من المحضرين﴾</span></span> جار ومجرور متعلقان بمحذوف خبر كان، أي: من الذين أحضروا العذاب.</p></div>"
  37,58,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿أفما نحن بميتين﴾</span></span>: الهمزة للاستفهام، والفاء عاطفة على محذوف تقديره: أنحن مخلدون منعمون فما نحن بميتين؟ و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> نافية حجازية تعمل عمل ليس، و<span class="hlt"><span class="qpc-hafs">﴿نحن﴾</span></span> اسم ما، و<span class="hlt"><span class="qpc-hafs">﴿بميتين﴾</span></span>: الباء حرف جر صلة، و<span class="hlt"><span class="qpc-hafs">﴿ميتين﴾</span></span> خبر <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> الحجازية منصوب محلا مجرور بالباء لفظًا.</p></div>"
  37,59,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إلا موتتنا الأولى وما نحن بمعذبين﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿إلا﴾</span></span> أداة حصر، والاستثناء منقطع و<span class="hlt"><span class="qpc-hafs">﴿موتتنا﴾</span></span> مستثنى بـ<span class="hlt"><span class="qpc-hafs">﴿إلا﴾</span></span> منصوب، أو أن الاستثناء مفرغ و<span class="hlt"><span class="qpc-hafs">﴿موتتنا﴾</span></span> مفعول مطلق منصوب، و<span class="hlt"><span class="qpc-hafs">﴿الأولى﴾</span></span> صفة، والواو حرف عطف، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> نافية حجازية تعمل عمل ليس، و<span class="hlt"><span class="qpc-hafs">﴿نحن﴾</span></span> اسم ما، و<span class="hlt"><span class="qpc-hafs">﴿بمعذبين﴾</span></span>: الباء حرف جر صلة، و<span class="hlt"><span class="qpc-hafs">﴿معذبين﴾</span></span> خبر <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> الحجازية منصوب محلا مجرور بالباء لفظًا.</p></div>"
  37,60,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إن هذا لهو الفوز العظيم﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span> حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿هذا﴾</span></span> اسمها، واللام المزحلقة، و<span class="hlt"><span class="qpc-hafs">﴿هو﴾</span></span> مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿الفوز﴾</span></span> خبر <span class="hlt"><span class="qpc-hafs">﴿هو﴾</span></span>، والجملة خبر إن، أو <span class="hlt"><span class="qpc-hafs">﴿هو﴾</span></span> ضمير فصل، و<span class="hlt"><span class="qpc-hafs">﴿الفوز﴾</span></span> خبر إن، و<span class="hlt"><span class="qpc-hafs">﴿العظيم﴾</span></span> صفة لـ<span class="hlt"><span class="qpc-hafs">﴿الفوز﴾</span></span>.</p></div>"
  37,61,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿لمثل هذا فليعمل العاملون﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿لمثل﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يعمل﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿هذا﴾</span></span> مضاف إليه، والفاء الفصيحة، واللام لام الأمر، و<span class="hlt"><span class="qpc-hafs">﴿يعمل﴾</span></span> فعل مضارع مجزوم بلام الأمر، و<span class="hlt"><span class="qpc-hafs">﴿العاملون﴾</span></span> فاعل.</p></div>"
  37,62,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿أذلك خير نزلا أم شجرة الزقوم﴾</span></span>: الجملة مقول قول محذوف، والهمزة للاستفهام الإنكاري التوبيخي، و<span class="hlt"><span class="qpc-hafs">﴿ذلك﴾</span></span> مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿خير﴾</span></span> خبر، و<span class="hlt"><span class="qpc-hafs">﴿نزلًا﴾</span></span> تمييز لـ<span class="hlt"><span class="qpc-hafs">﴿خير﴾</span></span>، وقيل: حال، و<span class="hlt"><span class="qpc-hafs">﴿أم﴾</span></span> حرف عطف، و<span class="hlt"><span class="qpc-hafs">﴿شجرة الزقوم﴾</span></span> عطف على <span class="hlt"><span class="qpc-hafs">﴿ذلك﴾</span></span>.</p></div>"
  37,63,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إنا جعلناها فتنة للظالمين﴾</span></span>:  <span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span> حرف ناسخ و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> اسمها، وجملة <span class="hlt"><span class="qpc-hafs">﴿جعلنا﴾</span></span> خبر، و<span class="hlt"><span class="qpc-hafs">﴿جعلناها﴾</span></span> فعل ماض، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> فاعل، والهاء مفعول به أول، و<span class="hlt"><span class="qpc-hafs">﴿فتنة﴾</span></span> مفعول به ثان، و<span class="hlt"><span class="qpc-hafs">﴿للظالمين﴾</span></span> جار ومجرور متعلقان بمحذوف صفة لـ<span class="hlt"><span class="qpc-hafs">﴿فتنة﴾</span></span>.</p></div>"
  37,64,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إنها شجرة تخرج في أصل الجحيم﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span> حرف ناسخ، والهاء اسمها، و<span class="hlt"><span class="qpc-hafs">﴿شجرة﴾</span></span> خبرها، وجملة <span class="hlt"><span class="qpc-hafs">﴿تخرج﴾</span></span> صفة لـ<span class="hlt"><span class="qpc-hafs">﴿شجرة﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿في أصل الجحيم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تخرج﴾</span></span>.</p></div>"
  37,65,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿طلعها كأنه رؤوس الشياطين﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿طلعها﴾</span></span> مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿كأن﴾</span></span> حرف تشبيه ونصب، والهاء اسمها، و<span class="hlt"><span class="qpc-hafs">﴿رؤوس﴾</span></span> خبرها، وجملة <span class="hlt"><span class="qpc-hafs">﴿كأن﴾</span></span> خبر المبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿الشياطين﴾</span></span> مضاف إليه.</p></div>"
  37,66,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فإنهم لآكلون منها فمالئون منها البطون﴾</span></span>: الفاء عطف، و<span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span> حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> اسمها، واللام المزحلقة، و<span class="hlt"><span class="qpc-hafs">﴿آكلون﴾</span></span> خبر <span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿منها﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿آكلون﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿فمالئون﴾</span></span> الفاء عاطفة للترتيب مع التعقيب، و<span class="hlt"><span class="qpc-hafs">﴿مالئون﴾</span></span> معطوف على <span class="hlt"><span class="qpc-hafs">﴿آكلون﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿منها﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿مالئون﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿البطون﴾</span></span> مفعول <span class="hlt"><span class="qpc-hafs">﴿مالئون﴾</span></span>.</p></div>"
  37,67,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ثم إن لهم عليها لشوبا من حميم﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿ثم﴾</span></span> حرف عطف للترتيب مع التراخي، و<span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span> حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿لهم﴾</span></span> جار ومجرور متعلقان بمحذوف خبرها المقدم، و<span class="hlt"><span class="qpc-hafs">﴿عليها﴾</span></span> جار ومجرور متعلقان بمحذوف حال، واللام المزحلقة، و<span class="hlt"><span class="qpc-hafs">﴿شوبًا﴾</span></span> اسمها المؤخر، و<span class="hlt"><span class="qpc-hafs">﴿من حميم﴾</span></span> جار ومجرور متعلقان بمحذوف صفة لـ<span class="hlt"><span class="qpc-hafs">﴿شوبًا﴾</span></span>.</p></div>"
  37,68,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ثم إن مرجعهم لإلى الجحيم﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿ثم﴾</span></span> حرف عطف للترتيب مع التراخي، و<span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span> حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿مرجعهم﴾</span></span> اسمها، واللام المزحلقة، و<span class="hlt"><span class="qpc-hafs">﴿إلى الجحيم﴾</span></span> جار ومجرور متعلقان بمحذوف خبر إن.</p></div>"
  37,69,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إنهم ألفوا آباءهم ضالين﴾</span></span>: الجملة تعليل لما سبق من ابتلائهم بأفانين العذاب، وإن حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> اسمها، وألفوا فعل ماض، والواو فاعل، و<span class="hlt"><span class="qpc-hafs">﴿آباءهم﴾</span></span> مفعول أول، و<span class="hlt"><span class="qpc-hafs">﴿ضالين﴾</span></span> مفعول ثان، وجملة <span class="hlt"><span class="qpc-hafs">﴿ألفوا﴾</span></span> إن.</p></div>"
  37,70,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فهم على آثارهم يهرعون﴾</span></span>: الفاء تعليلية، و<span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿على آثارهم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يهرعون﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿يهرعون﴾</span></span> خبر المبتدأ <span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span>.</p></div>"
  37,71,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ولقد ضل قبلهم أكثر الأولين﴾</span></span>: اللام جواب للقسم المحذوف، و<span class="hlt"><span class="qpc-hafs">﴿قد﴾</span></span> حرف تحقيق، و<span class="hlt"><span class="qpc-hafs">﴿ضل﴾</span></span> فعل ماض مبني على الفتح، و<span class="hlt"><span class="qpc-hafs">﴿قبلهم﴾</span></span> ظرف متعلق بمحذوف حال، و<span class="hlt"><span class="qpc-hafs">﴿أكثر الأولين﴾</span></span> فاعل.</p></div>"
  37,72,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ولقد أرسلنا فيهم منذرين﴾</span></span>: الواو عاطفة، واللام جواب للقسم المحذوف، و<span class="hlt"><span class="qpc-hafs">﴿قد﴾</span></span> حرف تحقيق، و<span class="hlt"><span class="qpc-hafs">﴿أرسلنا﴾</span></span> فعل ماض، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> فاعل، و<span class="hlt"><span class="qpc-hafs">﴿فيهم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أرسلنا﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿منذرين﴾</span></span> مفعول به.</p></div>"
  37,73,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فانظر كيف كان عاقبة المنذرين﴾</span></span>: الفاء الفصيحة، و<span class="hlt"><span class="qpc-hafs">﴿انظر﴾</span></span> فعل أمر، وفاعله مستتر تقديره: أنت، و<span class="hlt"><span class="qpc-hafs">﴿كيف﴾</span></span> اسم استفهام في محل نصب خبر <span class="hlt"><span class="qpc-hafs">﴿كان﴾</span></span> المقدم، و<span class="hlt"><span class="qpc-hafs">﴿كان﴾</span></span> فعل ماض ناقص ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿عاقبة﴾</span></span> اسمها المؤخر، و<span class="hlt"><span class="qpc-hafs">﴿المنذرين﴾</span></span> مفعول به.</p></div>"
  37,74,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إلا عباد الله المخلصين﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿إلا﴾</span></span> أداة استثناء بمعنى لكن، و<span class="hlt"><span class="qpc-hafs">﴿عباد الله﴾</span></span> مستثنى منصوب، و<span class="hlt"><span class="qpc-hafs">﴿المخلصين﴾</span></span> صفة لـ<span class="hlt"><span class="qpc-hafs">﴿عباد﴾</span></span>.</p></div>"
  37,75,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ولقد نادانا نوح﴾</span></span>: كلام مستأنف لا محل له من الإعراب، واللام جواب للقسم المحذوف، و<span class="hlt"><span class="qpc-hafs">﴿قد﴾</span></span> حرف تحقيق، و<span class="hlt"><span class="qpc-hafs">﴿نادانا نوح﴾</span></span> فعل ماض، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> مفعول به مقدم، و<span class="hlt"><span class="qpc-hafs">﴿نوح﴾</span></span> فاعل مؤخر.</p><p><span class="hlt"><span class="qpc-hafs">﴿فلنعم المجيبون﴾</span></span>: الفاء عاطفة، واللام جواب قسم محذوف، وجواب كل من القسمين محذوف، لدلالة السياق عليه، و<span class="hlt"><span class="qpc-hafs">﴿نعم﴾</span></span> فعل ماض جامد لإنشاء المدح، و<span class="hlt"><span class="qpc-hafs">﴿المجيبون﴾</span></span> فاعل <span class="hlt"><span class="qpc-hafs">﴿نعم﴾</span></span>، والمخصوص بالمدح محذوف تقديره: نحن.</p></div>"
  37,76,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ونجيناه وأهله من الكرب العظيم﴾</span></span>: الواو عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿نجيناه﴾</span></span> فعل ماض، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> فاعل، والهاء مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿أهله﴾</span></span> عطف على الهاء، أو مفعول معه، و<span class="hlt"><span class="qpc-hafs">﴿من الكرب﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿نجيناه﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿العظيم﴾</span></span> نعت للكرب.</p></div>"