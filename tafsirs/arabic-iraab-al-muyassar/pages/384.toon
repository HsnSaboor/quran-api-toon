quran[12]{c,v,t}:
  27,77,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وإنه لهدى ورحمة للمؤمنين﴾</span></span>: عطف على ما تقدم، وإن حرف ناسخ، والهاء اسمها، واللام المزحلقة، وهدى خبرها، ورحمة عطف على هدى، وللمؤمنين جار ومجرور متعلقان برحمة.</p></div>"
  27,78,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إن ربك يقضي بينهم بحكمه وهو العزيز العليم﴾</span></span>: إن حرف ناسخ، وربك اسمها، وجملة <span class="hlt"><span class="qpc-hafs">﴿يقضي﴾</span></span> خبرها، والظرف متعلق بمحذوف حال، وبحكمه جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يقضي﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿هو﴾</span></span> مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿العزيز﴾</span></span> خبر أول، و<span class="hlt"><span class="qpc-hafs">﴿العليم﴾</span></span> خبر ثان.</p></div>"
  27,79,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فتوكل على الله إنك على الحق المبين﴾</span></span>: الفاء الفصيحة، وتوكل فعل أمر، وفاعله مستتر تقديره: أنت، و<span class="hlt"><span class="qpc-hafs">﴿على الله﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿توكل﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿إنك على الحق المبين﴾</span></span> لا محل لها من الإعراب، لأنها تعليل، وإن حرف ناسخ، والكاف اسمها، وعلى الحق جار ومجرور متعلقان بمحذوف خبر إن، والمبين صفة.</p></div>"
  27,80,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إنك لا تسمع الموتى ولا تسمع الصم الدعاء إذا ولوا مدبرين﴾</span></span>: إن حرف ناسخ، والكاف اسمها، وجملة <span class="hlt"><span class="qpc-hafs">﴿لا تُسمع﴾</span></span> خبر أن، والموتى مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿لا تسمع﴾</span></span> الصم عطف على سابقتها، والصم مفعول به أول، والدعاء مفعول به ثان، وإذا ظرف مستقبل متضمن معنى الشرط، وجملة <span class="hlt"><span class="qpc-hafs">﴿ولوا﴾</span></span> مجرورة بإضافة الظرف إليها، ومدبرين حال.</p></div>"
  27,81,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وما أنت بهادي العمي عن ضلالتهم﴾</span></span>: الواو عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> نافية حجازية تعمل عمل ليس، و<span class="hlt"><span class="qpc-hafs">﴿أنت﴾</span></span> اسم ما، و<span class="hlt"><span class="qpc-hafs">﴿بهادي﴾</span></span>: الباء حرف جر صلة، و<span class="hlt"><span class="qpc-hafs">﴿هادي﴾</span></span> خبر <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> الحجازية منصوب محلا مجرور بالباء لفظًا، و<span class="hlt"><span class="qpc-hafs">﴿العمي﴾</span></span> مضاف إليه، و<span class="hlt"><span class="qpc-hafs">﴿عن ضلالتهم﴾</span></span> جار ومجرور متعلقان بهادي، وعُدِّيَ بعن لتضمنه معنى تصرفهم.</p><p><span class="hlt"><span class="qpc-hafs">﴿إن تسمع إلا من يؤمن بآياتنا فهم مسلمون﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span> نافية، و<span class="hlt"><span class="qpc-hafs">﴿تسمع﴾</span></span> فعل مضارع، وفاعله مستتر تقديره: أنت، و<span class="hlt"><span class="qpc-hafs">﴿إلا﴾</span></span> أداة حصر، و<span class="hlt"><span class="qpc-hafs">﴿من﴾</span></span> اسم موصول في محل نصب مفعول به، وجملة <span class="hlt"><span class="qpc-hafs">﴿يؤمن﴾</span></span> صلة الموصول لا محل لها من الإعراب. و<span class="hlt"><span class="qpc-hafs">﴿بآياتنا﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يؤمن﴾</span></span>، والفاء الفصيحة، و<span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿مسلمون﴾</span></span> خبر.</p></div>"
  27,82,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وإذا وقع القول عليهم أخرجنا لهم دابة من الأرض﴾</span></span>: الواو استئنافية، والجملة بعدها مستأنفة لا محل لها من الإعراب، وإذا ظرف مستقبل متضمن معنى الشرط، وجملة <span class="hlt"><span class="qpc-hafs">﴿وقع القول﴾</span></span> في محل جر بإضافة الظرف إليها، و<span class="hlt"><span class="qpc-hafs">﴿القول﴾</span></span> فاعل وقع، و<span class="hlt"><span class="qpc-hafs">﴿عليهم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿وقع﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿أخرجنا﴾</span></span> لا محل لها من الإعراب، لأنها جواب شرط غير جازم، و<span class="hlt"><span class="qpc-hafs">﴿لهم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أخرجنا﴾</span></span>، ودابة مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿من الأرض﴾</span></span> جار ومجرور متعلقان بمحذوف صفة لدابة.</p><p><span class="hlt"><span class="qpc-hafs">﴿تكلمهم أن الناس كانوا بآياتنا لا يوقنون﴾</span></span>: جملة تكلمهم صفة ثانية لدابة، أو حال منها، لأنها وصفت، وأن حرف ناسخ، والناس اسمها، وجملة كانوا خبر أن، والجملة في تأويل مصدر منصوب على نزع الخافض، أي: بأن الناس، والجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تكلمهم﴾</span></span>، وكان فعل ماض ناقص، وواو الجماعة اسمها، وبآياتنا جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يوقنون﴾</span></span>، ولا نافية، وجملة <span class="hlt"><span class="qpc-hafs">﴿لا يوقنون﴾</span></span> خبر كانوا.</p></div>"
  27,83,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ويوم نحشر من كل أمة فوجا ممن يكذب بآياتنا فهم يوزعون﴾</span></span>: الواو استئنافية، و<span class="hlt"><span class="qpc-hafs">﴿يوم﴾</span></span> مفعول به لفعل محذوف تقديره: اذكر، وجملة <span class="hlt"><span class="qpc-hafs">﴿نحشر﴾</span></span> في محل جر مضاف إليه، و<span class="hlt"><span class="qpc-hafs">﴿من كل أمة﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿نحشر﴾</span></span> و<span class="hlt"><span class="qpc-hafs">﴿من﴾</span></span> هنا للتبعيض، وفوجًا مفعول به، وممن جار ومجرور متعلقان بمحذوف صفة لـ<span class="hlt"><span class="qpc-hafs">﴿فوجًا﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿يكذب﴾</span></span> صلة <span class="hlt"><span class="qpc-hafs">﴿من﴾</span></span> لا محل لها من الإعراب. و<span class="hlt"><span class="qpc-hafs">﴿بآياتنا﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يكذب﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿ويوم نحشر...﴾</span></span> مستأنفة لا محل لها من الإعراب، والفاء عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> مبتدأ، وجملة يوزعون خبر.</p></div>"
  27,84,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿حتى إذا جاءوا قال أكذبتم بآياتي ولم تحيطوا بها علما أماذا كنتم تعملون﴾</span></span>: حتى حرف غاية، وإذا ظرف مستقبل متضمن معنى الشرط، وجملة <span class="hlt"><span class="qpc-hafs">﴿جاءوا﴾</span></span> في محل جر بإضافة الظرف إليها، ومتعلق جاءوا محذوف، أي: إلى مكان الحساب، وقال فعل ماض، وفاعله مستتر، يعود على الله تعالى. <span class="hlt"><span class="qpc-hafs">﴿أكذبتم﴾</span></span>: الهمزة للاستفهام، وكذبتم فعل وفاعل، و<span class="hlt"><span class="qpc-hafs">﴿بآياتي﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿كذبتم﴾</span></span>. <span class="hlt"><span class="qpc-hafs">﴿ولم﴾</span></span>: الواو حالية، ولم حرف نفي وقلب وجزم، و<span class="hlt"><span class="qpc-hafs">﴿تحيطوا﴾</span></span> فعل مضارع مجزوم بلم، و<span class="hlt"><span class="qpc-hafs">﴿بها﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تحيطوا﴾</span></span>، وعلمًا تمييز، وجملة <span class="hlt"><span class="qpc-hafs">﴿ولم تحيطوا ...﴾</span></span> حالية، وأم حرف عطف، وهي منقطعة تقدر بـ<span class="hlt"><span class="qpc-hafs">﴿بل﴾</span></span> فقط، وما اسم استفهام مبتدأ، وذا اسم موصول خبر، أو <span class="hlt"><span class="qpc-hafs">﴿ماذا﴾</span></span> كلها اسم استفهام في محل نصب مفعول مقدم لـ<span class="hlt"><span class="qpc-hafs">﴿تعملون﴾</span></span>، وكنتم: كان فعل ماض ناقص، والتاء اسمها، وجملة تعملون خبرها.</p></div>"
  27,85,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ووقع القول عليهم بما ظلموا فهم لا ينطقون﴾</span></span>: الواو عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿وقع القول﴾</span></span> فعل وفاعل، و<span class="hlt"><span class="qpc-hafs">﴿عليهم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿وقع﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿بما ظلموا﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿وقع﴾</span></span> أيضًا، أي: بسبب ظلمهم، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> مصدرية، والفاء عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> مبتدأ، وجملة <span class="hlt"><span class="qpc-hafs">﴿لا ينطقون﴾</span></span> خبر.</p></div>"
  27,86,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ألم يروا أنا جعلنا الليل ليسكنوا فيه والنهار مبصرا إن في ذلك لآيات لقوم يؤمنون﴾</span></span>: الهمزة للاستفهام التقريري، والإنكاري، ولم حرف نفي وقلب وجزم، ويروا فعل مضارع مجزوم بلم، والرؤية هنا قلبية لا بصرية، وأن وما بعدها سدت مسد مفعولي يروا، وأن حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> اسمها، وجملة <span class="hlt"><span class="qpc-hafs">﴿جعلنا﴾</span></span> خبرها، و<span class="hlt"><span class="qpc-hafs">﴿الليل﴾</span></span> مفعول جعلنا، ومفعول جعل الثاني محذوف تقديره: مظلما، واللام للتعليل، ويسكنوا فعل مضارع منصوب بأن مضمرة بعد لام التعليل، وعلامة نصبه حذف النون، والواو فاعل، والمصدر المؤول من أن والفعل مجرور باللام، والجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿جعلنا﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿فيه﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يسكنوا﴾</span></span>. <span class="hlt"><span class="qpc-hafs">﴿والنهار﴾</span></span> الواو عاطفة، والنهار مفعول به أول لفعل محذوف دل عليه المذكور تقديره: جعلنا، و<span class="hlt"><span class="qpc-hafs">﴿مبصرًا﴾</span></span> مفعول به ثان للفعل المحذوف، وإن حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿في ذلك﴾</span></span> جار ومجرور متعلقان بمحذوف خبر إن المقدم، واللام المزحلقة، وآيات اسمها المؤخر، و<span class="hlt"><span class="qpc-hafs">﴿لقوم﴾</span></span> جار ومجرور متعلقان بمحذوف صفة، وجملة يؤمنون صفة لـ<span class="hlt"><span class="qpc-hafs">﴿قوم﴾</span></span>.</p></div>"
  27,87,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ويوم ينفخ في الصور ففزع من في السماوات ومن في الأرض﴾</span></span>: الواو عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿يوم﴾</span></span> معطوف على <span class="hlt"><span class="qpc-hafs">﴿يوم﴾</span></span> السابق في قوله تعالى <span class="hlt"><span class="qpc-hafs">﴿ويوم نحشر﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿ينفخ﴾</span></span> في محل جر مضاف إليه، ونائب الفاعل مستتر، وتقديره: هو، و<span class="hlt"><span class="qpc-hafs">﴿في الصور﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿ينفخ﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿ففزع﴾</span></span> عطف على <span class="hlt"><span class="qpc-hafs">﴿ينفخ﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿مَن﴾</span></span> فاعل فزع، و<span class="hlt"><span class="qpc-hafs">﴿في السماوات﴾</span></span> الجار والمجرور متعلقان بمحذوف صلة الموصول، وجملة الصلة لا محل لها من الإعراب. <span class="hlt"><span class="qpc-hafs">﴿ومن في الأرض﴾</span></span> عطف على <span class="hlt"><span class="qpc-hafs">﴿من في السماوات﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿إلا من شاء الله وكل أتوه داخرين﴾</span></span>: إلا أداة استثناء، و<span class="hlt"><span class="qpc-hafs">﴿من﴾</span></span> مستثنى، وجملة <span class="hlt"><span class="qpc-hafs">﴿شاء الله﴾</span></span> صلة الموصول لا محل لها من الإعراب. <span class="hlt"><span class="qpc-hafs">﴿وكل﴾</span></span>: الواو للحال، أو عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿كل﴾</span></span> مبتدأ، وجملة <span class="hlt"><span class="qpc-hafs">﴿أتوه﴾</span></span> خبر، و<span class="hlt"><span class="qpc-hafs">﴿داخرين﴾</span></span> حال.</p></div>"
  27,88,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وترى الجبال تحسبها جامدة وهي تمر مر السحاب﴾</span></span>: الواو حرف عطف، و<span class="hlt"><span class="qpc-hafs">﴿ترى الجبال﴾</span></span> فعل مضارع مرفوع، وفاعل مستتر تقديره: أنت، ومفعول به، وجملة <span class="hlt"><span class="qpc-hafs">﴿تحسبها﴾</span></span> حال من الجبال، و<span class="hlt"><span class="qpc-hafs">﴿ها﴾</span></span> مفعول تحسبها الأول، و<span class="hlt"><span class="qpc-hafs">﴿جامدة﴾</span></span> مفعول تحسبها الثاني. <span class="hlt"><span class="qpc-hafs">﴿وهي﴾</span></span>: الواو حالية، و<span class="hlt"><span class="qpc-hafs">﴿هي﴾</span></span> مبتدأ، وجملة <span class="hlt"><span class="qpc-hafs">﴿تمر﴾</span></span> خبر، والجملة حال من الضمير المستتر في <span class="hlt"><span class="qpc-hafs">﴿جامدة﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿مر﴾</span></span> مفعول مطلق منصوب، و<span class="hlt"><span class="qpc-hafs">﴿السحاب﴾</span></span> مضاف إليه.</p><p><span class="hlt"><span class="qpc-hafs">﴿صنع الله الذي أتقن كل شيء إنه خبير بما تفعلون﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿صُنْعَ﴾</span></span> مفعول مطلق لفعل محذوف مؤكد لمضمون الجملة قبله والتقدير: صنع الله ذلك صنعا، وأضيف المصدر إلى فاعله. و<span class="hlt"><span class="qpc-hafs">﴿الذي﴾</span></span> في محل جر صفة لـ<span class="hlt"><span class="qpc-hafs">﴿لفظ الجلالة﴾</span></span>. وجملة <span class="hlt"><span class="qpc-hafs">﴿أتقن﴾</span></span> صلة الموصول لا محل لها من الإعراب. و<span class="hlt"><span class="qpc-hafs">﴿كل شيء﴾</span></span> مفعول أتقن. وإن حرف ناسخ، والهاء اسمها. وخبير خبرها. و<span class="hlt"><span class="qpc-hafs">﴿بما﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿خبير﴾</span></span>. وجملة <span class="hlt"><span class="qpc-hafs">﴿تفعلون﴾</span></span> صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> لا محل لها من الإعراب.</p></div>"