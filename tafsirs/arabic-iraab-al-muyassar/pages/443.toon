quran[14]{c,v,t}:
  36,41,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وآية لهم أنا حملنا ذريتهم في الفلك المشحون﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿آية﴾</span></span> خبر مقدم، و<span class="hlt"><span class="qpc-hafs">﴿لهم﴾</span></span> جار ومجرور متعلقان بمحذوف صفة، وأن حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> اسمها، وأن وما في حيزها مبتدأ مؤخر، وجملة <span class="hlt"><span class="qpc-hafs">﴿حملنا﴾</span></span> خبرها، و<span class="hlt"><span class="qpc-hafs">﴿حملنا﴾</span></span> فعل وفاعل، و<span class="hlt"><span class="qpc-hafs">﴿ذريتهم﴾</span></span> مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿في الفلك﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿حملنا﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿المشحون﴾</span></span> صفة.</p></div>"
  36,42,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وخلقنا لهم من مثله ما يركبون﴾</span></span>: الواو عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿خلقنا﴾</span></span> فعل وفاعل، و<span class="hlt"><span class="qpc-hafs">﴿لهم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿خلقنا﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿من مثله﴾</span></span> جار ومجرور متعلقان بمحذوف حال من المفعول المؤخر وهو <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿يركبون﴾</span></span> صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> لا محل لها من الإعراب. والضمير في <span class="hlt"><span class="qpc-hafs">﴿مثله﴾</span></span> يعود على الفلك.</p></div>"
  36,43,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وإن نشأ نغرقهم﴾</span></span>: الواو عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span> شرطية، و<span class="hlt"><span class="qpc-hafs">﴿نشأ﴾</span></span> فعل الشرط، وفاعله مستتر تقديره: نحن، و<span class="hlt"><span class="qpc-hafs">﴿نغرقهم﴾</span></span> فعل مضارع جواب الشرط، والفاعل مستتر، و<span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> مفعول به.</p><p><span class="hlt"><span class="qpc-hafs">﴿فلا صريخ لهم﴾</span></span>: الفاء عاطفة، أو استئنافية، ولا نافية للجنس، و<span class="hlt"><span class="qpc-hafs">﴿صريخ﴾</span></span> اسمها مبني على الفتح، و<span class="hlt"><span class="qpc-hafs">﴿لهم﴾</span></span> جار ومجرور متعلقان بمحذوف خبرها. وجملة <span class="hlt"><span class="qpc-hafs">﴿فلا صريخ لهم﴾</span></span> معطوفة، أو مستأنفة لا محل لها من الإعراب.</p><p><span class="hlt"><span class="qpc-hafs">﴿ولا هم ينقذون﴾</span></span>: الواو عاطفة، ولا نافية، و<span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> مبتدأ، وجملة <span class="hlt"><span class="qpc-hafs">﴿ينقذون﴾</span></span> خبر، وينقذون فعل مضارع مرفوع بثبوت النون مبني لما لم يسم فاعله، والواو نائب فاعل.</p></div>"
  36,44,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إلا رحمة منا ومتاعا إلى حين﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿إلا﴾</span></span> أداة حصر، و<span class="hlt"><span class="qpc-hafs">﴿رحمة﴾</span></span> مفعول لأجله، أو مفعول مطلق لفعل محذوف، أو منصوب بنزع الخافض، و<span class="hlt"><span class="qpc-hafs">﴿متاعًا﴾</span></span> عطف على <span class="hlt"><span class="qpc-hafs">﴿رحمة﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿إلى حين﴾</span></span> جار ومجرور متعلقان بمحذوف صفة.</p></div>"
  36,45,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وإذا قيل لهم اتقوا ما بين أيديكم وما خلفكم﴾</span></span>: كلام مستأنف لا محل له من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿إذا﴾</span></span> ظرف مستقبل متضمن معنى الشرط، وجملة <span class="hlt"><span class="qpc-hafs">﴿قيل﴾</span></span> في محل جر بإضافة الظرف إليها، و<span class="hlt"><span class="qpc-hafs">﴿لهم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿قيل﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿اتقوا﴾</span></span> مقول القول، و<span class="hlt"><span class="qpc-hafs">﴿اتقوا﴾</span></span> فعل أمر، والواو فاعل، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿بين﴾</span></span> ظرف متعلق بمحذوف صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span>، وجملة الصلة لا محل لها من الإعراب. و<span class="hlt"><span class="qpc-hafs">﴿أيديكم﴾</span></span> مضاف إليه، و<span class="hlt"><span class="qpc-hafs">﴿ما خلفكم﴾</span></span> عطف على <span class="hlt"><span class="qpc-hafs">﴿ما بين أيديكم﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿لعلكم ترحمون﴾</span></span>: لعل حرف ناسخ للترجي، و<span class="hlt"><span class="qpc-hafs">﴿كم﴾</span></span> اسمها، وجملة <span class="hlt"><span class="qpc-hafs">﴿ترحمون﴾</span></span> خبرها، و<span class="hlt"><span class="qpc-hafs">﴿ترحمون﴾</span></span> فعل مضارع مرفوع بثبوت النون مبني لما لم يسم فاعله، والواو نائب فاعل، وجواب <span class="hlt"><span class="qpc-hafs">﴿إذا﴾</span></span> محذوف، والتقدير: أعرضوا وأشاحوا.</p></div>"
  36,46,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وما تأتيهم من آية من آيات ربهم إلا كانوا عنها معرضين﴾</span></span>: الواو عاطفة، وما نافية، وتأتيهم فعل مضارع ومفعول به، ومن حرف جر صلة، وآية مجرور لفظًا مرفوع محلًّا على أنه فاعل، ومن آيات ربهم صفة، ومعنى <span class="hlt"><span class="qpc-hafs">﴿من﴾</span></span> التبعيض، وإلا أداة حصر، وجملة <span class="hlt"><span class="qpc-hafs">﴿كانوا عنها معرضين﴾</span></span> في محل نصب حال، وكان فعل ماض ناقص، وواو الجماعة اسمها، و<span class="hlt"><span class="qpc-hafs">﴿عنها﴾</span></span> جار ومجرور متعلقان بمعرضين، ومعرضين خبرها.</p></div>"
  36,47,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وإذا قيل لهم أنفقوا مما رزقكم الله﴾</span></span>: عطف على ما تقدم، و<span class="hlt"><span class="qpc-hafs">﴿إذا﴾</span></span> ظرف مستقبل متضمن معنى الشرط، وجملة <span class="hlt"><span class="qpc-hafs">﴿قيل﴾</span></span> في محل جر بالإضافة، وجملة <span class="hlt"><span class="qpc-hafs">﴿أنفقوا﴾</span></span> مقول القول، و<span class="hlt"><span class="qpc-hafs">﴿مما﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أنفقوا﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿رزقكم الله﴾</span></span> فعل ماض، ومفعول به مقدم، ولفظ الجلالة: فاعل مؤخر. وجملة <span class="hlt"><span class="qpc-hafs">﴿رزقكم الله﴾</span></span> صلة الموصول لا محل لها من الإعراب.</p><p><span class="hlt"><span class="qpc-hafs">﴿قال الذين كفروا للذين آمنوا﴾</span></span>: جملة <span class="hlt"><span class="qpc-hafs">﴿قال﴾</span></span> لا محل لها من الإعراب، لأنها جواب شرط غير جازم، و<span class="hlt"><span class="qpc-hafs">﴿الذين﴾</span></span> فاعل، وجملة <span class="hlt"><span class="qpc-hafs">﴿كفروا﴾</span></span> فعل وفاعل، وهي صلة الموصول لا محل لها من الإعراب. و<span class="hlt"><span class="qpc-hafs">﴿للذين﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿قال﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿آمنوا﴾</span></span> صلة الموصول لا محل لها من الإعراب.</p><p><span class="hlt"><span class="qpc-hafs">﴿أنطعم من لو يشاء الله أطعمه﴾</span></span>: الهمزة للاستفهام، و<span class="hlt"><span class="qpc-hafs">﴿نطعم﴾</span></span> فعل مضارع، وفاعله مستتر تقديره: نحن، و<span class="hlt"><span class="qpc-hafs">﴿مَن﴾</span></span> مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿لو﴾</span></span> شرطية، و<span class="hlt"><span class="qpc-hafs">﴿يشاء الله﴾</span></span> فعل مضارع وفاعل، وجملة <span class="hlt"><span class="qpc-hafs">﴿أطعمه﴾</span></span> لا محل لها من الإعراب، وجملة <span class="hlt"><span class="qpc-hafs">﴿لو يشاء الله أطعمه﴾</span></span> صلة <span class="hlt"><span class="qpc-hafs">﴿مَن﴾</span></span> لا محل لها من الإعراب.</p><p><span class="hlt"><span class="qpc-hafs">﴿إن أنتم إلا في ضلال مبين﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span> نافية، و<span class="hlt"><span class="qpc-hafs">﴿أنتم﴾</span></span> مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿إلا﴾</span></span> أداة حصر، و<span class="hlt"><span class="qpc-hafs">﴿في ضلال﴾</span></span> جار ومجرور متعلقان بمحذوف خبر <span class="hlt"><span class="qpc-hafs">﴿أنتم﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿مبين﴾</span></span> صفة.</p></div>"
  36,48,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ويقولون متى هذا الوعد﴾</span></span>: كلام مستأنف لا محل له من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿يقولون﴾</span></span> فعل مضارع وفاعل، و<span class="hlt"><span class="qpc-hafs">﴿متى﴾</span></span> اسم استفهام في محل نصب على الظرفية، والظرف متعلق بمحذوف خبر مقدم، و<span class="hlt"><span class="qpc-hafs">﴿هذا﴾</span></span> مبتدأ مؤخر، و<span class="hlt"><span class="qpc-hafs">﴿الوعد﴾</span></span> بدل من اسم الإشارة.</p><p><span class="hlt"><span class="qpc-hafs">﴿إن كنتم صادقين﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span> شرطية، وكان فعل ماض ناقص، والتاء اسمها، وصادقين خبرها، وجواب الشرط محذوف لدلالة ما قبله عليه، أي: فمتى هذا الوعد؟</p></div>"
  36,49,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ما ينظرون إلا صيحة واحدة تأخذهم﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> نافية، و<span class="hlt"><span class="qpc-hafs">﴿ينظرون﴾</span></span> فعل مضارع وفاعل، و<span class="hlt"><span class="qpc-hafs">﴿إلا﴾</span></span> أداة حصر، و<span class="hlt"><span class="qpc-hafs">﴿صيحة﴾</span></span> مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿واحدة﴾</span></span> صفة، وجملة <span class="hlt"><span class="qpc-hafs">﴿تأخذهم﴾</span></span> صفة ثانية، أو جملة حالية.</p><p><span class="hlt"><span class="qpc-hafs">﴿وهم يخصمون﴾</span></span>: الواو حالية، و<span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> ضمير منفصل مبتدأ، وجملة <span class="hlt"><span class="qpc-hafs">﴿يخصمون﴾</span></span> خبر، والجملة نصب على الحال.</p></div>"
  36,50,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فلا يستطيعون توصية ولا إلى أهلهم يرجعون﴾</span></span>: الفاء عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿لا﴾</span></span> نافية، و<span class="hlt"><span class="qpc-hafs">﴿يستطيعون﴾</span></span> فعل مضارع وفاعل، و<span class="hlt"><span class="qpc-hafs">﴿توصية﴾</span></span> مفعول به، والواو عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿لا﴾</span></span> نافية، و<span class="hlt"><span class="qpc-hafs">﴿إلى أهلهم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يرجعون﴾</span></span>، والجملة معطوفة على <span class="hlt"><span class="qpc-hafs">﴿فلا يستطيعون﴾</span></span> .</p></div>"
  36,51,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ونفخ في الصور فإذا هم من الأجداث إلى ربهم ينسلون﴾</span></span>: كلام مستأنف لا محل له من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿نفخ﴾</span></span> فعل ماض مبني لما لم يسمَّ فاعله، ونائب الفاعل مستتر تقديره: هو، و<span class="hlt"><span class="qpc-hafs">﴿في الصور﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿نفخ﴾</span></span>، والفاء حرف عطف، و<span class="hlt"><span class="qpc-hafs">﴿إذا﴾</span></span> الفجائية، و<span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿من الأجداث﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿ينسلون﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿إلى ربهم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿ينسلون﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿ينسلون﴾</span></span> خبر <span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span>.</p></div>"
  36,52,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قالوا يا ويلنا من بعثنا من مرقدنا﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿قالوا﴾</span></span> فعل وفاعل، و<span class="hlt"><span class="qpc-hafs">﴿يا﴾</span></span> حرف تنبيه، أو حرف نداء، والمنادى محذوف، و<span class="hlt"><span class="qpc-hafs">﴿ويلنا﴾</span></span> منادى مضاف منصوب، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> مضاف إليه. و<span class="hlt"><span class="qpc-hafs">﴿مَن﴾</span></span> اسم استفهام في محل رفع مبتدأ. وجملة <span class="hlt"><span class="qpc-hafs">﴿بعثنا﴾</span></span> خبر، وهي فعل ماض، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> مفعول به، والفاعل مستتر، و<span class="hlt"><span class="qpc-hafs">﴿من مرقدنا﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿بعثنا﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿هذا ما وعد الرحمن وصدق المرسلون﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿هذا﴾</span></span> مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> اسم موصول خبر، وجملة <span class="hlt"><span class="qpc-hafs">﴿وعد الرحمن﴾</span></span> فعل وفاعل، والمفعول محذوف، أي: وعدنا، أو <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> مصدرية، وهي مع مدخولها خبر <span class="hlt"><span class="qpc-hafs">﴿هذا﴾</span></span>، أو <span class="hlt"><span class="qpc-hafs">﴿هذا﴾</span></span> نعت لـ<span class="hlt"><span class="qpc-hafs">﴿مرقدنا﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿ما وعد﴾</span></span> في تأويل مصدر مبتدأ محذوف الخبر، والتقدير: وعد الرحمن حق، أو خبر لمبتدأ محذوف، والتقدير: هذا وعد الرحمن، و<span class="hlt"><span class="qpc-hafs">﴿صدق المرسلون﴾</span></span> فعل وفاعل.</p></div>"
  36,53,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إن كانت إلا صيحة واحدة فإذا هم جميع لدينا محضرون﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span> نافية، و<span class="hlt"><span class="qpc-hafs">﴿كانت﴾</span></span> فعل ماض ناقص ناسخ، واسمها مستتر تقديره: الصيحة، و<span class="hlt"><span class="qpc-hafs">﴿إلا﴾</span></span> أداة حصر، و<span class="hlt"><span class="qpc-hafs">﴿صيحة﴾</span></span> خبر <span class="hlt"><span class="qpc-hafs">﴿كانت﴾</span></span>، والفاء حرف عطف، و<span class="hlt"><span class="qpc-hafs">﴿إذا﴾</span></span> الفجائية، و<span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿جميع﴾</span></span> خبر، و<span class="hlt"><span class="qpc-hafs">﴿لدينا﴾</span></span> ظرف متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿محضرون﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿محضرون﴾</span></span> خبر ثان، أو صفة لـ<span class="hlt"><span class="qpc-hafs">﴿جميع﴾</span></span>.</p></div>"
  36,54,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فاليوم لا تظلم نفس شيئا ولا تجزون إلا ما كنتم تعملون﴾</span></span>: الفاء استئنافية، و<span class="hlt"><span class="qpc-hafs">﴿اليوم﴾</span></span> ظرف متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿تظلم﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿لا﴾</span></span> نافية، و<span class="hlt"><span class="qpc-hafs">﴿تظلم﴾</span></span> فعل مضارع مبني لما لم يسمَّ فاعله، و<span class="hlt"><span class="qpc-hafs">﴿نفس﴾</span></span> نائب فاعل، و<span class="hlt"><span class="qpc-hafs">﴿شيئًا﴾</span></span> نائب عن المفعول المطلق، وجملة <span class="hlt"><span class="qpc-hafs">﴿فاليوم لا تظلم...﴾</span></span> مستأنفة لا محل لها من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿لا تجزون﴾</span></span> عطف على <span class="hlt"><span class="qpc-hafs">﴿لا تظلم﴾</span></span> على طريق الالتفات، و<span class="hlt"><span class="qpc-hafs">﴿إلا﴾</span></span> أداة حصر، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> مفعول به ثان لـ<span class="hlt"><span class="qpc-hafs">﴿تجزون﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿كنتم﴾</span></span> كان فعل ناقص ناسخ، والتاء اسمها، وجملة <span class="hlt"><span class="qpc-hafs">﴿تعملون﴾</span></span> خبر <span class="hlt"><span class="qpc-hafs">﴿كنتم﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿كنتم﴾</span></span> صلة الموصول لا محل لها من الإعراب.</p></div>"