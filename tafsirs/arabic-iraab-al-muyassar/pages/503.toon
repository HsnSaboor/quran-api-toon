quran[9]{c,v,t}:
  46,6,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وإذا حشر الناس كانوا لهم أعداء وكانوا بعبادتهم كافرين﴾</span></span>: الواو حرف عطف، وإذا ظرف مستقبل متضمن معنى الشرط، وجملة حشر الناس في محل جر بإضافة الظرف إليها، والناس نائب فاعل، وجملة كانوا لا محل لها من الإعراب، لأنها جواب شرط لأنها جواب غير جازم، وكان فعل ماض ناقص، وواو الجماعة اسمها، ولهم حال، وأعداء خبر كان، وكانوا عطف على وكانوا الأولى، وبعبادتهم: الجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿كافرين﴾</span></span>، والهاء مضاف إليه من إضافة المصدر إلى مفعوله، أي: بكونهم معبودين، وكافرين خبر كان.</p></div>"
  46,7,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وإذا تتلى عليهم آياتنا بينات قال الذين كفروا للحق لما جاءهم هذا سحر مبين﴾</span></span>: الواو عاطفة، وإذا تتلى عليهم آياتنا عطف على ما تقدم، وبينات حال، وجملة قال الذين كفروا جواب إذا لا محل لها من الإعراب، وللحق: الجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿قالوا﴾</span></span>، وقيل: اللام في للحق لام الصلة أي لأجل الحق، ولما ظرفية حينية، أو رابطة، وجاءهم فعل ومفعول به وفاعل مستتر، وهذا مبتدأ، وسحر خبر، ومبين نعت، والجملة مقول قولهم.</p></div>"
  46,8,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿أم يقولون افتراه قل إن افتريته فلا تملكون لي من الله شيئا﴾</span></span>: أم عاطفة منقطعة فهي بمعنى: بل وهمزة الاستفهام، والتقدير: بل أيقولون افتراه، والهمزة للاستفهام الإنكاري، أو <span class="hlt"><span class="qpc-hafs">﴿أم﴾</span></span> متصلة، وحينئذ فلا بد من تقدير جملة ليصح التعادل، والتقدير: أيقرون به أم يقولون: افتراه، وجملة افتراه مقول القول. وقل فعل أمر، وفاعله مستتر تقديره: أنت، وإن شرطية، وافتريته فعل وفاعل ومفعول به، والفاء رابطة لجواب الشرط، ولا نافية، وتملكون فعل مضارع مرفوع بثبوت النون، والواو فاعله، ولي جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تملكون﴾</span></span>، ومن الله حال، لأنه كان في الأصل صفة، وتقدم على موصوفه، وشيئًا مفعول به.</p><p><span class="hlt"><span class="qpc-hafs">﴿هو أعلم بما تفيضون فيه﴾</span></span>: الجملة حالية، وهو مبتدأ، وأعلم خبر، وبما: الجار والمجرور متعلقان بأعلم، وجملة <span class="hlt"><span class="qpc-hafs">﴿تفيضون﴾</span></span> صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> لا محل لها من الإعراب.</p><p><span class="hlt"><span class="qpc-hafs">﴿كفى به شهيدًا بيني وبينكم وهو الغفور الرحيم﴾</span></span>: كفى فعل ماضٍ، والباء حرف جر صلة، والهاء ضمير مجرور لفظًا في موضع رفع بالفاعلية، وشهيدًا تمييز، وبيني ظرف متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿شهيدًا﴾</span></span>، وبينكم ظرف معطوف على مثله، والواو عاطفة، وهو مبتدأ، والغفور الرحيم خبران له.</p></div>"
  46,9,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قل ما كنت بدعا من الرسل وما أدري ما يفعل﴾</span></span>: قل فعل أمر، وفاعله مستتر تقديره: أنت، وما نافية، وكان فعل ماض ناقص، والتاء اسمها، وبدعًا خبرها، ومن الرسل نعت لـ<span class="hlt"><span class="qpc-hafs">﴿بدعًا﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> عطف على <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> النافية الأولى، و<span class="hlt"><span class="qpc-hafs">﴿أدري﴾</span></span> فعل مضارع مرفوع، وفاعله مستتر تقديره: نحن، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> اسم استفهام في محل رفع مبتدأ، وجملة <span class="hlt"><span class="qpc-hafs">﴿يفعل﴾</span></span> بالبناء لما لم يسمَّ فاعله خبرها، وهي معلقة لـ<span class="hlt"><span class="qpc-hafs">﴿أدري﴾</span></span> عن العمل سادة مسد مفعوليها.</p><p><span class="hlt"><span class="qpc-hafs">﴿بي﴾</span></span>: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يفعل﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿ولا بكم﴾</span></span>: عطف عليه. وقيل: و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> في قوله: <span class="hlt"><span class="qpc-hafs">﴿ما يفعل﴾</span></span> موصولة منصوبة، أو استفهامية مرفوعة.</p><p><span class="hlt"><span class="qpc-hafs">﴿إن أتبع إلا ما يوحى إلي وما أنا إلا نذير مبين﴾</span></span>: إن نافية، وأتبع فعل مضارع مرفوع، وفاعله مستتر تقديره: أنا، وإلا أداة حصر، وما مفعول أتبع، وجملة يوحي إليّ صلة، والواو حرف عطف، وما نافية، وأنا مبتدأ، وإلا أداة حصر، ونذير خبر، ومبين نعت.</p></div>"
  46,10,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قل أرأيتم إن كان من عند الله وكفرتم به﴾</span></span>: جملة أرأيتم مقول القول، ومفعولا أرأيتم محذوفان، تقديرهما: أرأيتم حالكم إن كان كذا ألستم ظالمين، وجواب الشرط محذوف أيضًا تقديره: فقد ظلمتم، والتقدير: ألستم ظالمين، وقيل: جواب الشرط <span class="hlt"><span class="qpc-hafs">﴿فآمن واستكبرتم﴾</span></span>، وقيل: هو محذوف تقديره: فمن المحق منا ومن المبطل؟ وقيل: فمن أضل؟ واسم كان ضمير مستتر تقديره: هو، ومن عند الله خبرها، وكفرتم: الواو عاطفة، وجملة كفرتم عطف على فعل الشرط، وقيل: حالية، وبه: الجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿كفرتم﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿وشهد شاهد من بني إسرائيل على مثله﴾</span></span>: الواو: عاطفة، وشهد شاهد فعل وفاعل، ومن بني إسرائيل صفة لشاهد، وعلى مثله: جار ومجرور متعلقان بشهد، والضمير يعود إلى القرآن.</p><p><span class="hlt"><span class="qpc-hafs">﴿فآمن واستكبرتم إن الله لا يهدي القوم الظالمين﴾</span></span>: الفاء عاطفة، وآمن فعل وفاعل مستتر تقديره: هو، أي: الشاهد، واستكبرتم عطف على فآمن، وإن حرف ناسخ، ولفظ الجلالة اسمها، وجملة لا يهدي القوم الظالمين خبر إن.</p></div>"
  46,11,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وقال الذين كفروا للذين آمنوا لو كان خيرا ما سبقونا إليه﴾</span></span>: الواو عاطفة، وقال الذين فعل وفاعل، وجملة كفروا صلة الموصول لا محل لها من الإعراب، وللذين: جار ومجرور متعلقان بقال، وجملة آمنوا صلة الموصول لا محل لها من الإعراب، ولو شرطية، وكان فعل ماض ناقص، واسمها مستتر يعود على ما جاء به محمد، وخيرًا خبرها، وما نافية، وسبقونا فعل وفاعل ومفعول به، وإليه: جار ومجرور متعلقان بسبقونا، والجملة مقول القول، وجملة ما سبقونا إليه لا محل لها من الإعراب، لأنها جواب شرط غير جازم.</p><p><span class="hlt"><span class="qpc-hafs">﴿وإذ لم يهتدوا به فسيقولون هذا إفك قديم﴾</span></span>: الواو عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿إذ﴾</span></span> ظرف للزمن الماضي متعلق بمحذوف تقديره: ظهر عنادهم، وتسبب عنه قوله <span class="hlt"><span class="qpc-hafs">﴿فسيقولون﴾</span></span>. وقيل: <span class="hlt"><span class="qpc-hafs">﴿إذ﴾</span></span> ظرف فيه معنى الشرط متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿سيقولون﴾</span></span> وهو الجواب، وقيل: إن <span class="hlt"><span class="qpc-hafs">﴿إذ﴾</span></span> ههنا للتعليل. و<span class="hlt"><span class="qpc-hafs">﴿لم﴾</span></span> حرف نفي وقلب وجزم، و<span class="hlt"><span class="qpc-hafs">﴿يهتدوا﴾</span></span> فعل مضارع مجزوم بـ<span class="hlt"><span class="qpc-hafs">﴿لم﴾</span></span> وعلامة جزمه حذف النون، وواو الجماعة فاعل. <span class="hlt"><span class="qpc-hafs">﴿فسيقولون﴾</span></span> الفاء عاطفة، وجملة <span class="hlt"><span class="qpc-hafs">﴿سيقولون﴾</span></span> معطوفة على الجملة المقدرة <span class="hlt"><span class="qpc-hafs">﴿ظهر عنادهم﴾</span></span>، أو الفاء في جواب شرط <span class="hlt"><span class="qpc-hafs">﴿إذ﴾</span></span> إذا كانت <span class="hlt"><span class="qpc-hafs">﴿إذ﴾</span></span> شرطية، وإذا كانت تعليلية فالفاء للتفريع على جملة <span class="hlt"><span class="qpc-hafs">﴿وإذ لم يهتدوا﴾</span></span>، والسين حرف استقبال، ويقولون فعل مضارع مرفوع وفاعل، و<span class="hlt"><span class="qpc-hafs">﴿هذا﴾</span></span> مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿إفك﴾</span></span> خبر، و<span class="hlt"><span class="qpc-hafs">﴿قديم﴾</span></span> صفة، والجملة الاسمية <span class="hlt"><span class="qpc-hafs">﴿هذا إفك قديم﴾</span></span> في محل نصب مقول القول.</p></div>"
  46,12,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ومن قبله كتاب موسى إمامًا ورحمة﴾</span></span>: الواو استئنافية، ومن قبله جار ومجرور متعلقان بمحذوف خبر مقدم، وكتاب موسى مبتدأ مؤخر، وإمامًا ورحمة حالان من كتاب موسى، وجملة <span class="hlt"><span class="qpc-hafs">﴿ومن قبله...﴾</span></span> مستأنفة لا محل لها من الإعراب.</p><p><span class="hlt"><span class="qpc-hafs">﴿وهذا كتاب مصدق لسانا عربيا لينذر الذين ظلموا وبشرى للمحسنين﴾</span></span>: الواو عاطفة، وهذا مبتدأ، وكتاب خبر، ومصدق صفة، ولسانًا حال من الضمير في مصدق، أو من كتاب، والعامل فيه معنى الإشارة، وقيل: مفعول به لمصدق، وعلى هذا تكون الإشارة إلى غير القرآن، وقيل: هو منصوب بنزع الخافض، أي: بلسان عربي، واللام للتعليل، وينذر فعل مضارع منصوب بأن مضمرة بعد لام التعليل، والمصدر المؤول من أن والفعل مجرور باللام، والجار والمجرور متعلقان بمصدق، أو هو المصدر المؤول مفعول لأجله، والذين مفعول به، وجملة ظلموا صلة الموصول لا محل لها من الإعراب، وبشرى عطف على محل <span class="hlt"><span class="qpc-hafs">﴿لينذر﴾</span></span> إن كان مفعولًا لأجله، أو خبر لمبتدأ محذوف، أي: وهو بشرى، وللمحسنين نعت لبشرى.</p></div>"
  46,13,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إن الذين قالوا ربنا الله ثم استقاموا﴾</span></span>: إن حرف ناسخ، والذين اسمها، وجملة قالوا صلة الموصول لا محل لها من الإعراب، وربنا مبتدأ، والله خبر، أو العكس، وثم حرف عطف، وجملة استقاموا عطف على جملة قالوا.</p><p><span class="hlt"><span class="qpc-hafs">﴿فلا خوف عليهم ولا هم يحزنون﴾</span></span>: الفاء صلة في خبر إن، لما في الموصول من معنى الشرط، ولا نافية، وخوف مبتدأ ساغ الابتداء به وهو نكرة لتقدم النفي، وعليهم جار ومجرور متعلقان بمحذوف خبر المبتدأ، وجملة <span class="hlt"><span class="qpc-hafs">﴿فلا خوف عليهم﴾</span></span> في محل رفع خبر إن، <span class="hlt"><span class="qpc-hafs">﴿ولا﴾</span></span>: الواو عاطفة و<span class="hlt"><span class="qpc-hafs">﴿لا﴾</span></span> نافية، وهم: مبتدأ. ويحزنون: فعل مضارع مرفوع بثبوت النون وواو الجماعة فاعل وجملة <span class="hlt"><span class="qpc-hafs">﴿يحزنون﴾</span></span> في محل رفع خبر المبتدأ <span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span>.</p></div>"
  46,14,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿أولئك أصحاب الجنة خالدين فيها جزاء بما كانوا يعملون﴾</span></span>: أولئك مبتدأ، وأصحاب الجنة خبره، و<span class="hlt"><span class="qpc-hafs">﴿خالدين فيها﴾</span></span> حال، و<span class="hlt"><span class="qpc-hafs">﴿جزاء﴾</span></span> مفعول لأجله، أي: لأجل الجزاء، أو مفعول مطلق لفعل محذوف، أي: يجزون جزاء، وقيل: حال، وبما: الجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿جزاء﴾</span></span>، وما موصولة، أو مصدرية، وكان فعل ماض ناقص، وواو الجماعة اسمها، وجملة يعملون خبرها، والجملة خبر ثان لـ<span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span>.</p></div>"