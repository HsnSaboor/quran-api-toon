quran[8]{c,v,t}:
  4,114,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿لا خير في كثير من نجواهم﴾</span></span>: كلام مستأنف لا محل له من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿لا﴾</span></span> نافية للجنس، وخير اسمها المبني على الفتح، وفي كثير جار ومجرور متعلقان بمحذوف خبرها، ومن نجواهم جار ومجرور متعلقان بمحذوف صفة لكثير.</p><p><span class="hlt"><span class="qpc-hafs">﴿إلا من أمر بصدقة أو معروف أو إصلاح بين الناس﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿إلا﴾</span></span> أداة حصر، و<span class="hlt"><span class="qpc-hafs">﴿من﴾</span></span> اسم موصول بدل من <span class="hlt"><span class="qpc-hafs">﴿كثير﴾</span></span>، أو من <span class="hlt"><span class="qpc-hafs">﴿نجوى﴾</span></span>، أو نصب على الاستثناء المنقطع، أي: لكن من أمر بصدقة ففي نجواه خير كثير، وبصدقة جار ومجرور متعلقان بأمر، وما بعدها معطوف عليها، وبين الناس ظرف مكان متعلق بإصلاح.</p><p><span class="hlt"><span class="qpc-hafs">﴿ومن يفعل ذلك ابتغاء مرضات الله﴾</span></span>: الواو استئنافية، و<span class="hlt"><span class="qpc-hafs">﴿من﴾</span></span> اسم شرط جازم في محل رفع مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿يفعل﴾</span></span> فعل الشرط، وذلك مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿ابتغاء مرضاة الله﴾</span></span> مفعول لأجله.</p><p><span class="hlt"><span class="qpc-hafs">﴿فسوف نؤتيه أجرا عظيما﴾</span></span>: الفاء رابطة للجواب، وسوف حرف استقبال، ونؤتيه فعل مضارع ومفعول به أول، وأجرًا مفعول به ثان، والفاعل مستتر تقديره <span class="hlt"><span class="qpc-hafs">﴿نحن﴾</span></span>، وعظيمًا صفة، والجملة المقترنة بالفاء في محل جزم جواب الشرط، وفعل الشرط وجوابه خبر <span class="hlt"><span class="qpc-hafs">﴿من﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿ومن يفعل ذلك...﴾</span></span> مستأنفة لا محل لها من الإعراب.</p></div>"
  4,115,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ومن يشاقق الرسول من بعد ما تبين له الهدى﴾</span></span>: كلام مستأنف لا محل له من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿من﴾</span></span> اسم شرط جازم في محل رفع مبتدأ، يشاقق فعل مضارع فعل الشرط، والرسول مفعول به، ومن بعد جار ومجرور متعلقان بيشاقق، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> مصدرية وهي مع <span class="hlt"><span class="qpc-hafs">﴿تبين﴾</span></span> في تأويل مصدر مجرور بالإضافة، و<span class="hlt"><span class="qpc-hafs">﴿له﴾</span></span> جار ومجرور متعلقان بتبين، والهدى فاعل.</p><p><span class="hlt"><span class="qpc-hafs">﴿ويتبع غير سبيل المؤمنين﴾</span></span>: عطف على يشاقق، و<span class="hlt"><span class="qpc-hafs">﴿غير سبيل المؤمنين﴾</span></span> مفعول به.</p><p><span class="hlt"><span class="qpc-hafs">﴿نوله ما تولى﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿نوله﴾</span></span> جواب الشرط، والهاء مفعوله الأول، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> اسم موصول مفعوله الثاني، وجملة <span class="hlt"><span class="qpc-hafs">﴿تولى﴾</span></span> صلة الموصول لا محل لها من الإعراب، وجملة فعل الشرط وجوابه في محل رفع خبر <span class="hlt"><span class="qpc-hafs">﴿مَن﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿ونصله جهنم وساءت مصيرا﴾</span></span>: عطف على <span class="hlt"><span class="qpc-hafs">﴿نوله﴾</span></span>، وجهنم مفعول به ثان لنصله، ومصيرًا نصب على التمييز، والمخصوص بالذم محذوف، أي: جهنم.</p></div>"
  4,116,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إن الله لا يغفر أن يشرك به﴾</span></span>: كلام مستأنف لا محل له من الإعراب، وإن حرف ناسخ، ولفظ الجلالة اسمها، وجملة <span class="hlt"><span class="qpc-hafs">﴿لا يغفر﴾</span></span> خبرها، والمصدر المؤول من <span class="hlt"><span class="qpc-hafs">﴿أن﴾</span></span> وما في حيزها مفعول يغفر، و<span class="hlt"><span class="qpc-hafs">﴿به﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يشرك﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿ويغفر ما دون ذلك لمن يشاء﴾</span></span>: الواو عاطفة، ويغفر فعل مضارع، والفاعل: هو، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> اسم موصول مفعول به، ودون ذلك ظرف متعلق بمحذوف صلة الموصول، والجملة لا محل لها من الإعراب، لأنها صلة الموصول، ولمن يشاء جار ومجرور متعلقان بيغفر، وجملة <span class="hlt"><span class="qpc-hafs">﴿يشاء﴾</span></span> صلة الموصول لا محل لها من الإعراب.</p><p><span class="hlt"><span class="qpc-hafs">﴿ومن يشرك بالله﴾</span></span>: الواو حرف عطف، و<span class="hlt"><span class="qpc-hafs">﴿من﴾</span></span> اسم شرط جازم مبتدأ، ويشرك فعل الشرط، والجار والمجرور متعلقان بيشرك.</p><p><span class="hlt"><span class="qpc-hafs">﴿فقد ضل ضلالا بعيدا﴾</span></span>: الفاء رابطة، والجملة في محل جزم جواب الشرط، وضلالًا مفعول مطلق، وبعيدًا صفة، وجملة الشرط والجواب خبر <span class="hlt"><span class="qpc-hafs">﴿من﴾</span></span>.</p></div>"
  4,117,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إن يدعون من دونه إلا إناثا﴾</span></span>: الجملة تعليلية لا محل لها من الإعراب، وإن نافية، ويدعون فعل مضارع وفاعل، ومن دونه جار ومجرور متعلقان بيدعون، و<span class="hlt"><span class="qpc-hafs">﴿إلا﴾</span></span> أداة حصر، وإناثًا مفعول به، أو صفة لمفعول به محذوف، أي: أصنامًا مؤنثة.</p><p><span class="hlt"><span class="qpc-hafs">﴿وإن يدعون إلا شيطانا مريدا﴾</span></span>: الواو عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span> نافية، ويدعون فعل وفاعل، و<span class="hlt"><span class="qpc-hafs">﴿إلا﴾</span></span> أداة حصر، شيطانًا مفعول به، ومريدًا صفة.</p></div>"
  4,118,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿لعنه الله وقال لأتخذن من عبادك نصيبا مفروضا﴾</span></span>: الجملة لا محل لها من الإعراب، لأنها دعائية، أو مستأنفة، أو صفة لـ<span class="hlt"><span class="qpc-hafs">﴿شيطانًا﴾</span></span> في الآية السابقة، و<span class="hlt"><span class="qpc-hafs">﴿لعنه الله﴾</span></span> فعل ومفعول به وفاعل، <span class="hlt"><span class="qpc-hafs">﴿وقال﴾</span></span> الواو استئنافية، أو حالية بتقدير <span class="hlt"><span class="qpc-hafs">﴿قد﴾</span></span>، وجملة القسم مقول القول، واللام جواب قسم محذوف، وأتخذن فعل مضارع مبني على الفتح، لاتصاله بنون التوكيد الثقيلة، وجملة أتخذن لا محل لها من الإعراب، لأنها جواب قسم محذوف، ومن عبادك جار ومجرور متعلقان بأتخذن، ونصيبًا مفعول به، ومفروضًا صفة، وجملة <span class="hlt"><span class="qpc-hafs">﴿وقال لأتخذن...﴾</span></span> مستأنفة لا محل لها من الإعراب، أو حالية.</p></div>"
  4,119,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ولأضلنهم ولأمنينهم ولآمرنهم﴾</span></span>: الجمل الثلاث معطوفات على أتخذن.</p><p><span class="hlt"><span class="qpc-hafs">﴿فليبتكن آذان الأنعام﴾</span></span>: الفاء عاطفة، وآذان الأنعام مفعول به.</p><p><span class="hlt"><span class="qpc-hafs">﴿ولآمرنهم فليغيرن خلق الله﴾</span></span>: عطف أيضًا، و<span class="hlt"><span class="qpc-hafs">﴿خلق الله﴾</span></span> مفعول به.</p><p><span class="hlt"><span class="qpc-hafs">﴿ومن يتخذ الشيطان وليا من دون الله﴾</span></span>: الواو استئنافية، و<span class="hlt"><span class="qpc-hafs">﴿من﴾</span></span> اسم شرط جازم مبتدأ، ويتخذ فعل الشرط، والشيطان مفعول به أول، ووليًّا مفعول به ثان، ومن دون الله جار ومجرور متعلقان بمحذوف صفة لـ<span class="hlt"><span class="qpc-hafs">﴿وليًّا﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿فقد خسر خسرانا مبينا﴾</span></span>: الفاء رابطة، و<span class="hlt"><span class="qpc-hafs">﴿قد﴾</span></span> حرف تحقيق، وخسرانًا مفعول مطلق، ومبينًا صفة، والجملة في محل جزم جواب الشرط، وفعل الشرط وجوابه خبر <span class="hlt"><span class="qpc-hafs">﴿مَن﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿ومن يتخذ...﴾</span></span> مستأنفة لا محل لها من الإعراب.</p></div>"
  4,120,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿يعدهم ويمنيهم وما يعدهم الشيطان إلا غرورا﴾</span></span>: الجملة مستأنفة لا محل لها من الإعراب، ومفعولا يعدهم ويمنيهم محذوفان للعلم بهما، <span class="hlt"><span class="qpc-hafs">﴿وما﴾</span></span> الواو حالية، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> نافية، ويعدهم الشيطان فعل ومفعول به وفاعل، و<span class="hlt"><span class="qpc-hafs">﴿إلا﴾</span></span> أداة حصر، وغرورًا مفعول ثانٍ لـ<span class="hlt"><span class="qpc-hafs">﴿يعدهم﴾</span></span>، أو مفعول لأجله، أو نائب عن المفعول المطلق لأنه صفة له، أي: وعدًا ذا غرور.</p></div>"
  4,121,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿أولئك مأواهم جهنم﴾</span></span>: أولئك مبتدأ، ومأواهم مبتدأ ثان، وجهنم خبر مأواهم، والجملة الاسمية خبر أولئك، وجملة <span class="hlt"><span class="qpc-hafs">﴿أولئك مأواهم جهنم﴾</span></span> مستأنفة لا محل لها من الإعراب.</p><p><span class="hlt"><span class="qpc-hafs">﴿ولا يجدون عنها محيصا﴾</span></span>: الواو عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿لا﴾</span></span> نافية، ويجدون فعل مضارع وفاعل، ومحيصًا مفعول به، وعنها جار ومجرور متعلقان بمحذوف حال، لأن المصدر لا يعمل فيما قبله.</p></div>"