quran[7]{c,v,t}:
  29,39,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وقارون وفرعون وهامان ولقد جاءهم موسى بالبينات فاستكبروا في الأرض وما كانوا سابقين﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿وقارون وفرعون وهامان﴾</span></span> معطوف على عاد، والواو عاطفة، واللام واقعة في جواب قسم مقدر، وقد حرف تحقيق، و<span class="hlt"><span class="qpc-hafs">﴿جاءهم﴾</span></span> فعل، ومفعول به مقدم، وموسى فاعل، و<span class="hlt"><span class="qpc-hafs">﴿بالبينات﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿جاءهم﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿فاستكبروا﴾</span></span> عطف على <span class="hlt"><span class="qpc-hafs">﴿جاءهم﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿في الأرض﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿استكبروا﴾</span></span>، والواو حالية، وما نافية. <span class="hlt"><span class="qpc-hafs">﴿كانوا﴾</span></span>: كان فعل ماض ناقص، وواو الجماعة اسمها، وسابقين خبرها.</p></div>"
  29,40,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فكلا أخذنا بذنبه فمنهم من أرسلنا عليه حاصبا﴾</span></span>: الفاء الفصيحة، وكلًّا: مفعول مقدم لـ<span class="hlt"><span class="qpc-hafs">﴿أخذنا﴾</span></span>، وأخذنا: فعل، وفاعل. <span class="hlt"><span class="qpc-hafs">﴿فمنهم﴾</span></span>: الفاء عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿منهم﴾</span></span> جار ومجرور متعلقان بمحذوف خبر مقدم، ومن مبتدأ مؤخر، وهي نكرة موصوفة، و<span class="hlt"><span class="qpc-hafs">﴿أرسلنا﴾</span></span> صفة، وعليه جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أرسلنا﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿حاصبًا﴾</span></span> مفعول أرسلنا.</p><p><span class="hlt"><span class="qpc-hafs">﴿ومنهم من أخذته الصيحة ومنهم من خسفنا به الأرض ومنهم من أغرقنا﴾</span></span>: الواو عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿منهم﴾</span></span> جار ومجرور متعلقان بمحذوف خبر مقدم، ومن مبتدأ مؤخر، وجملة <span class="hlt"><span class="qpc-hafs">﴿أخذته الصيحة﴾</span></span> صفة، <span class="hlt"><span class="qpc-hafs">﴿ومنهم من خسفنا به الأرض ومنهم من أغرقنا﴾</span></span> الجملتان معطوفتان على الجملة السابقة.</p><p><span class="hlt"><span class="qpc-hafs">﴿وما كان الله ليظلمهم ولكن كانوا أنفسهم يظلمون﴾</span></span>: الواو عاطفة، وما نافية، و<span class="hlt"><span class="qpc-hafs">﴿كان الله﴾</span></span> كان فعل ماض ناقص، ولفظ الجلالة اسمها، واللام لام الجحود، و<span class="hlt"><span class="qpc-hafs">﴿يظلمهم﴾</span></span> منصوب بأن مضمرة وجوبًا بعد لام الجحود، والمصدر المؤول من أن والفعل مجرور باللام، والجار والمجرور متعلقان بمحذوف خبر كان، والواو حالية، و<span class="hlt"><span class="qpc-hafs">﴿لكن﴾</span></span> مخففة مهملة. <span class="hlt"><span class="qpc-hafs">﴿كانوا﴾</span></span>: كان فعل ماض ناقص، وواو الجماعة اسمها، و<span class="hlt"><span class="qpc-hafs">﴿أنفسهم﴾</span></span> مفعول مقدم، وجملة <span class="hlt"><span class="qpc-hafs">﴿يظلمون﴾</span></span> خبر كانوا.</p></div>"
  29,41,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿مثل الذين اتخذوا من دون الله أولياء كمثل العنكبوت اتخذت بيتا وإن أوهن البيوت لبيت العنكبوت﴾</span></span>: مثل مبتدأ، والذين مضاف إليه، وجملة <span class="hlt"><span class="qpc-hafs">﴿اتخذوا﴾</span></span> صلة الموصول لا محل لها من الإعراب. وهي فعل، وفاعل، و<span class="hlt"><span class="qpc-hafs">﴿من دون الله﴾</span></span> الجار والمجرور متعلقان بمحذوف حال، وأولياء مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿كمثل﴾</span></span> الكاف اسم بمعنى مثل مبني على الفتح في محل رفع خبر، و<span class="hlt"><span class="qpc-hafs">﴿مَثل﴾</span></span> مضاف إليه، و<span class="hlt"><span class="qpc-hafs">﴿العنكبوت﴾</span></span> مضاف إليه، وجملة <span class="hlt"><span class="qpc-hafs">﴿اتخذت بيتًا﴾</span></span> حالية، <span class="hlt"><span class="qpc-hafs">﴿وإن أوهن البيوت﴾</span></span>: الواو حالية، وإن اسمها، و<span class="hlt"><span class="qpc-hafs">﴿البيوت﴾</span></span> مضاف إليه، واللام المزحلقة، و<span class="hlt"><span class="qpc-hafs">﴿بيت﴾</span></span> خبر إن، والعنكبوت: مضاف إليه.</p><p><span class="hlt"><span class="qpc-hafs">﴿لو كانوا يعلمون﴾</span></span>: لو شرطية، وكان فعل ماض ناقص، وواو الجماعة اسمها، وجملة <span class="hlt"><span class="qpc-hafs">﴿يعلمون﴾</span></span> خبرها، وجواب لو محذوف تقديره: لما عبدوها.</p></div>"
  29,42,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إن الله يعلم ما يدعون من دونه من شيء وهو العزيز الحكيم﴾</span></span>: الجملة تعليل لما قبلها، وإن حرف ناسخ، ولفظ الجلالة اسمها، وجملة يعلم خبرها، وما اسم موصول مفعول يعلم، وجملة <span class="hlt"><span class="qpc-hafs">﴿يدعون﴾</span></span> صلة الموصول لا محل لها من الإعراب. والعائد محذوف، و<span class="hlt"><span class="qpc-hafs">﴿من دونه﴾</span></span> جار ومجرور متعلقان بمحذوف حال، و<span class="hlt"><span class="qpc-hafs">﴿من شيء﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يدعون﴾</span></span>، وقيل: ما نافية، و<span class="hlt"><span class="qpc-hafs">﴿من شيء﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿من﴾</span></span> حرف جر صلة، وشيء مجرور لفظا منصوب محلا على أنه مفعول يدعون، وجملة <span class="hlt"><span class="qpc-hafs">﴿ما يدعون﴾</span></span> في محل نصب مفعول يعلم، و<span class="hlt"><span class="qpc-hafs">﴿هو﴾</span></span> مبتدأ، والعزيز خبر أول، والحكيم خبر ثان.</p></div>"
  29,43,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وتلك الأمثال نضربها للناس وما يعقلها إلا العالمون﴾</span></span>: الواو عاطفة، وتلك مبتدأ، والأمثال بدل، وجملة <span class="hlt"><span class="qpc-hafs">﴿نضربها للناس﴾</span></span> خبر، و<span class="hlt"><span class="qpc-hafs">﴿للناس﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿نضربها﴾</span></span>، أو الأمثال خبر، وجملة <span class="hlt"><span class="qpc-hafs">﴿نضربها﴾</span></span> حال، أو خبر ثان، والواو حالية، وما نافية، و<span class="hlt"><span class="qpc-hafs">﴿يعقلها﴾</span></span> فعل مضارع، ومفعول به، وإلا أداة حصر، والعالمون فاعل يعقلها.</p></div>"
  29,44,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿خلق الله السماوات والأرض بالحق إن في ذلك لآية للمؤمنين﴾</span></span>: كلام مستأنف لا محل له من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿خلق الله السماوات﴾</span></span> فعل، وفاعل، ومفعول به، <span class="hlt"><span class="qpc-hafs">﴿والأرض﴾</span></span> عطف على السماوات، و<span class="hlt"><span class="qpc-hafs">﴿بالحق﴾</span></span> جار ومجرور متعلقان بمحذوف حال، والباء للملابسة، وإن حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿في ذلك﴾</span></span> جار ومجرور متعلقان بمحذوف خبر إن المقدم، واللام المزحلقة، وآية اسم إن المؤخر، و<span class="hlt"><span class="qpc-hafs">﴿للمؤمنين﴾</span></span> جار ومجرور متعلقان بمحذوف صفة لآية.</p></div>"
  29,45,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿اتل ما أوحي إليك من الكتاب وأقم الصلاة﴾</span></span>: اتل: فعل أمر مبني على حذف حرف العلة، وفاعله مستتر تقديره: أنت، أي: يا محمد، وما: مفعول به، وجملة <span class="hlt"><span class="qpc-hafs">﴿أوحي﴾</span></span> صلة الموصول لا محل لها من الإعراب. وإليك: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أوحي﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿من الكتاب﴾</span></span>: جار ومجرور متعلقان بمحذوف حال، وأقم: فعل أمر معطوف على اتل، والفاعل: مستتر تقديره أنت أيضًا، والصلاة: مفعول به.</p><p><span class="hlt"><span class="qpc-hafs">﴿إن الصلاة تنهى عن الفحشاء والمنكر ولذكر الله أكبر والله يعلم ما تصنعون﴾</span></span>: إن حرف ناسخ، والصلاة اسمها، وجملة <span class="hlt"><span class="qpc-hafs">﴿تنهى عن الفحشاء والمنكر﴾</span></span>: خبرها، والواو: استئنافية، واللام لام الابتداء، و<span class="hlt"><span class="qpc-hafs">﴿ذكر الله﴾</span></span>: مبتدأ، ولفظ الجلالة: مضاف إليه، و<span class="hlt"><span class="qpc-hafs">﴿أكبر﴾</span></span>: خبر، وجملة <span class="hlt"><span class="qpc-hafs">﴿ولذكر الله أكبر﴾</span></span> مستأنفة لا محل لها من الإعراب، <span class="hlt"><span class="qpc-hafs">﴿والله﴾</span></span>: الواو عاطفة، ولفظ الجلالة مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿يعلم﴾</span></span>: فعل وفاعله ضمير مستتر تقديره هو والجملة في محل رفع خبر، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span>: اسم موصول مفعول به، وجملة <span class="hlt"><span class="qpc-hafs">﴿تصنعون﴾</span></span>: صلة الموصول لا محل لها من الإعراب.</p></div>"