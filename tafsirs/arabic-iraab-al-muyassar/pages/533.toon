quran[27]{c,v,t}:
  55,41,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿يعرف المجرمون بسيماهم﴾</span></span>: يعرف فعل مضارع مبني لما لم يسمَّ فاعله، والمجرمون نائب فاعل، وبسيماهم جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يعرف﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿فيؤخذ بالنواصي والأقدام﴾</span></span>: الفاء عاطفة، ويؤخذ فعل مضارع مبني لما لم يسمَّ فاعله، وبالنواصي هو نائب الفاعل، ويؤخذ متعد، ومع ذلك تعدى بالباء، لأنه ضمن معنى يُسحب.</p></div>"
  55,42,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فبأي آلاء ربكما تكذبان﴾</span></span>: الفاء الفصيحة، وبأي جار ومجرور متعلقان بتكذبان، وآلاء مضاف إليه، وربكما مضاف إليه، وتكذبان فعل مضارع مرفوع بثبوت النون، وألف التثنية فاعل، والخطاب للثقلين الإنس والجن.</p></div>"
  55,43,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿هذه جهنم التي يكذب بها المجرمون﴾</span></span>: هذه مبتدأ، وجهنم خبر، والتي صفة، وجملة يكذب بها المجرمون صلة الموصول لا محل لها من الإعراب.</p></div>"
  55,44,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿يطوفون بينها وبين حميم آن﴾</span></span>: الجملة حال من المجرمين، أو مستأنفة لا محل لها من الإعراب، ويطوفون فعل مضارع مرفوع، والواو فاعل، والظرف متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿يطوفون﴾</span></span>، وبين عطف على الظرف الأول، وآنٍ نعت لـ<span class="hlt"><span class="qpc-hafs">﴿حميم﴾</span></span>، وهو منقوص، فالكسرة مقدرة على الياء المحذوفة لالتقاء الساكنين.</p></div>"
  55,45,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فبأي آلاء ربكما تكذبان﴾</span></span>: الفاء الفصيحة، وبأي جار ومجرور متعلقان بتكذبان، وآلاء مضاف إليه، وربكما مضاف إليه، وتكذبان فعل مضارع مرفوع بثبوت النون، وألف التثنية فاعل، والخطاب للثقلين الإنس والجن.</p></div>"
  55,46,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ولمن خاف مقام ربه جنتان﴾</span></span>: الواو عاطفة، ولمن خبر مقدم، وجملة خاف صلة <span class="hlt"><span class="qpc-hafs">﴿من﴾</span></span> لا محل لها من الإعراب. ومقام مفعول به، وهو اسم مكان، أو مصدر ميميّ، وربه مضاف إليه وهو مضاف، والهاء ضمير مبني في محل جر مضاف إليه، وجنتان مبتدأ مؤخر.</p></div>"
  55,47,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فبأي آلاء ربكما تكذبان﴾</span></span>: الفاء الفصيحة، وبأي جار ومجرور متعلقان بتكذبان، وآلاء مضاف إليه، وربكما مضاف إليه، وتكذبان فعل مضارع مرفوع بثبوت النون، وألف التثنية فاعل، والخطاب للثقلين الإنس والجن.</p></div>"
  55,48,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ذواتا أفنان﴾</span></span>: ذواتا صفة لـ<span class="hlt"><span class="qpc-hafs">﴿جنتان﴾</span></span>، وأفنان مضاف إليه.</p></div>"
  55,49,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فبأي آلاء ربكما تكذبان﴾</span></span>: الفاء الفصيحة، وبأي جار ومجرور متعلقان بتكذبان، وآلاء مضاف إليه، وربكما مضاف إليه، وتكذبان فعل مضارع مرفوع بثبوت النون، وألف التثنية فاعل، والخطاب للثقلين الإنس والجن.</p></div>"
  55,50,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فيهما عينان تجريان﴾</span></span>: فيهما خبر مقدم، وعينان مبتدأ مؤخر، وجملة تجريان نعت عينان.</p></div>"
  55,51,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فبأي آلاء ربكما تكذبان﴾</span></span>: الفاء الفصيحة، وبأي جار ومجرور متعلقان بتكذبان، وآلاء مضاف إليه، وربكما مضاف إليه، وتكذبان فعل مضارع مرفوع بثبوت النون، وألف التثنية فاعل، والخطاب للثقلين الإنس والجن.</p></div>"
  55,52,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فيهما من كل فاكهة زوجان﴾</span></span>: فيهما خبر مقدم، ومن كل فاكهة حال، لأنه كان في الأصل صفة لزوجان، وزوجان مبتدأ مؤخر.</p></div>"
  55,53,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فبأي آلاء ربكما تكذبان﴾</span></span>: الفاء الفصيحة، وبأي جار ومجرور متعلقان بتكذبان، وآلاء مضاف إليه، وربكما مضاف إليه، وتكذبان فعل مضارع مرفوع بثبوت النون، وألف التثنية فاعل، والخطاب للثقلين الإنس والجن.</p></div>"
  55,54,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿متكئين على فرش بطائنها من إستبرق وجنى الجنتين دان﴾</span></span>: متكئين منصوب على المدح بفعل محذوف، أو حال من قوله: ولمن خاف، وقيل: العامل محذوف، أي: يتنعمون متكئين، وعلى فرش جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿متكئين﴾</span></span>، وبطائنها مبتدأ، ومن إستبرق خبر، والجملة صفة لـ<span class="hlt"><span class="qpc-hafs">﴿فرش﴾</span></span>، والواو حالية، أو عاطفة، وجنى مبتدأ والجنتين مضاف إليه، ودانٍ خبر، وعلامة رفعه الضمة المقدرة على الياء المحذوفة لالتقاء الساكنين.</p></div>"
  55,55,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فبأي آلاء ربكما تكذبان﴾</span></span>: الفاء الفصيحة، وبأي جار ومجرور متعلقان بتكذبان، وآلاء مضاف إليه، وربكما مضاف إليه، وتكذبان فعل مضارع مرفوع بثبوت النون، وألف التثنية فاعل، والخطاب للثقلين الإنس والجن.</p></div>"
  55,56,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فيهن قاصرات الطرف لم يطمثهن إنس قبلهم ولا جان﴾</span></span>: فيهن خبر مقدم، وقاصرات الطرف مبتدأ مؤخر ولم حرف نفي وقلب وجزم، ويطمثهن فعل مضارع مجزوم بلم، وجملة <span class="hlt"><span class="qpc-hafs">﴿يطمثهن﴾</span></span> صفة لـ<span class="hlt"><span class="qpc-hafs">﴿قاصرات الطرف﴾</span></span>، لأن الإضافة لفظية فلا تتعرف، أو حالية، لأن النكرة قد تخصصت بالإضافة، وإنس فاعل، وقبلهم ظرف زمان متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿يطمثهن﴾</span></span>، ولا جان: عطف على إنس.</p></div>"
  55,57,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فبأي آلاء ربكما تكذبان﴾</span></span>: الفاء الفصيحة، وبأي جار ومجرور متعلقان بتكذبان، وآلاء مضاف إليه، وربكما مضاف إليه، وتكذبان فعل مضارع مرفوع بثبوت النون، وألف التثنية فاعل، والخطاب للثقلين الإنس والجن.</p></div>"
  55,58,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿كأنهن الياقوت والمرجان﴾</span></span>: الجملة نعت لـ<span class="hlt"><span class="qpc-hafs">﴿قاصرات الطرف﴾</span></span>، أو حال منها، وكأن حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿هن﴾</span></span> اسمها، والياقوت خبرها، والمرجان عطف على الياقوت.</p></div>"
  55,59,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فبأي آلاء ربكما تكذبان﴾</span></span>: الفاء الفصيحة، وبأي جار ومجرور متعلقان بتكذبان، وآلاء مضاف إليه، وربكما مضاف إليه، وتكذبان فعل مضارع مرفوع بثبوت النون، وألف التثنية فاعل، والخطاب للثقلين الإنس والجن.</p></div>"
  55,60,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿هل جزاء الإحسان إلا الإحسان﴾</span></span>: هل حرف استفهام معناه: الجحد والنفي، وجزاء مبتدأ، والإحسان مضاف إليه، وإلا أداة حصر، والإحسان خبر جزاء.</p></div>"
  55,61,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فبأي آلاء ربكما تكذبان﴾</span></span>: الفاء الفصيحة، وبأي جار ومجرور متعلقان بتكذبان، وآلاء مضاف إليه، وربكما مضاف إليه، وتكذبان فعل مضارع مرفوع بثبوت النون، وألف التثنية فاعل، والخطاب للثقلين الإنس والجن.</p></div>"
  55,62,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ومن دونهما جنتان﴾</span></span>: من دونهما خبر مقدم، وجنتان مبتدأ مؤخر.</p></div>"
  55,63,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فبأي آلاء ربكما تكذبان﴾</span></span>: الفاء الفصيحة، وبأي جار ومجرور متعلقان بتكذبان، وآلاء مضاف إليه، وربكما مضاف إليه، وتكذبان فعل مضارع مرفوع بثبوت النون، وألف التثنية فاعل، والخطاب للثقلين الإنس والجن.</p></div>"
  55,64,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿مدهامتان﴾</span></span>: نعت جنتان.</p></div>"
  55,65,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فبأي آلاء ربكما تكذبان﴾</span></span>: الفاء الفصيحة، وبأي جار ومجرور متعلقان بتكذبان، وآلاء مضاف إليه، وربكما مضاف إليه، وتكذبان فعل مضارع مرفوع بثبوت النون، وألف التثنية فاعل، والخطاب للثقلين الإنس والجن.</p></div>"
  55,66,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فيهما عينان نضاختان﴾</span></span>: الجملة نعت ثانٍ لـ<span class="hlt"><span class="qpc-hafs">﴿جنتان﴾</span></span>، وفيهما خبر مقدم، وعينان مبتدأ مؤخر، ونضاختان نعت <span class="hlt"><span class="qpc-hafs">﴿عينان﴾</span></span>.</p></div>"
  55,67,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فبأي آلاء ربكما تكذبان﴾</span></span>: الفاء الفصيحة، وبأي جار ومجرور متعلقان بتكذبان، وآلاء مضاف إليه، وربكما مضاف إليه، وتكذبان فعل مضارع مرفوع بثبوت النون، وألف التثنية فاعل، والخطاب للثقلين الإنس والجن.</p></div>"