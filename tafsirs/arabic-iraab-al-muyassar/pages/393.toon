quran[11]{c,v,t}:
  28,60,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وما أوتيتم من شيء فمتاع الحياة الدنيا وزينتها﴾</span></span>: الواو عاطفة، أو استئنافية، والجملة بعدها معطوفة، أو مستأنفة لا محل لها من الإعراب، وما اسم شرط جازم في محل رفع مبتدأ، وأوتيتم: فعل ماض مبني لما لم يسمَّ فاعله، وهو في محل جزم فعل الشرط، والتاء نائب فاعل، و<span class="hlt"><span class="qpc-hafs">﴿من شيء﴾</span></span> جار ومجرور متعلقان بمحذوف  حال مبينة لـ<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span>، والفاء رابطة للجواب، ومتاع خبر لمبتدأ محذوف، والحياة مضاف إليه، والدنيا صفة، وزينتها: عطف على متاع، والجملة في محل جزم جواب الشرط، والفعل والجواب خبر ما.</p><p><span class="hlt"><span class="qpc-hafs">﴿وما عند الله خير وأبقى أفلا تعقلون﴾</span></span>: الواو حالية، وما اسم موصول مبتدأ، وعند: ظرف متعلق بمحذوف صلة وجملة الصلة لا محل لها من الإعراب. ولفظ الجلالة مضاف إليه، وخير خبر، وأبقى عطف على خير، والهمزة للاستفهام، والفاء عاطفة على محذوف يقتضيه السياق، ولا نافية، وتعقلون فعل مضارع مرفوع، والواو في محل رفع فاعل.</p></div>"
  28,61,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿أفمن وعدناه وعدا حسنا فهو لاقيه كمن متعناه متاع الحياة الدنيا ثم هو يوم القيامة من المحضرين﴾</span></span>: الهمزة للاستفهام، والفاء عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿مَن﴾</span></span> اسم موصول مبتدأ، وجملة <span class="hlt"><span class="qpc-hafs">﴿وعدناه﴾</span></span> صلة الموصول لا محل لها من الإعراب. و<span class="hlt"><span class="qpc-hafs">﴿وعدناه﴾</span></span> فعل وفاعل ومفعول به، و<span class="hlt"><span class="qpc-hafs">﴿وعدًا﴾</span></span> مفعول مطلق، وحسنًا صفة، والفاء عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿هو﴾</span></span> مبتدأ، ولاقيه: خبر، <span class="hlt"><span class="qpc-hafs">﴿كمن﴾</span></span> الكاف اسم بمعنى مثل مبني على الفتح في محل رفع خبر المبتدأ <span class="hlt"><span class="qpc-hafs">﴿مَن﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿مَن﴾</span></span> في محل جر مضاف إليه، وجملة <span class="hlt"><span class="qpc-hafs">﴿متعناه﴾</span></span> صلة <span class="hlt"><span class="qpc-hafs">﴿مَن﴾</span></span> لا محل لها من الإعراب. و<span class="hlt"><span class="qpc-hafs">﴿متاع﴾</span></span> نائب عن المفعول المطلق، لأنه اسم مصدر، و<span class="hlt"><span class="qpc-hafs">﴿الحياة﴾</span></span> مضاف إليه، و<span class="hlt"><span class="qpc-hafs">﴿الدنيا﴾</span></span> صفة للحياة، وثم حرف عطف، و<span class="hlt"><span class="qpc-hafs">﴿هو﴾</span></span> مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿يوم القيامة﴾</span></span> الظرف متعلق بالمحضرين، والقيامة مضاف إليه، و<span class="hlt"><span class="qpc-hafs">﴿من المحضرين﴾</span></span> جار ومجرور متعلقان بمحذوف خبر <span class="hlt"><span class="qpc-hafs">﴿هو﴾</span></span>.</p></div>"
  28,62,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ويوم يناديهم فيقول أين شركائي الذين كنتم تزعمون﴾</span></span>: الواو استئنافية، و<span class="hlt"><span class="qpc-hafs">﴿يوم﴾</span></span> مفعول به لفعل محذوف تقديره: اذكر، وجملة <span class="hlt"><span class="qpc-hafs">﴿يناديهم﴾</span></span> في محل جر مضاف إليه، والفاعل مستتر، والهاء مفعول به، <span class="hlt"><span class="qpc-hafs">﴿فيقول﴾</span></span>: عطف على يناديهم. و<span class="hlt"><span class="qpc-hafs">﴿أين﴾</span></span> اسم استفهام في محل نصب على الظرفية المكانية، وهو متعلق بمحذوف خبر مقدم، وشركائي مبتدأ مؤخر، والذين صفة لـ<span class="hlt"><span class="qpc-hafs">﴿شركائي﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿كنتم﴾</span></span> صلة الذين لا محل لها من الإعراب. وكان فعل ماض ناقص، والتاء اسمها، وجملة <span class="hlt"><span class="qpc-hafs">﴿تزعمون﴾</span></span> خبرها، ومفعولا تزعمون محذوفان، تقديرهما: <span class="hlt"><span class="qpc-hafs">﴿تزعمونهم شركائي﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿أين شركائي﴾</span></span> مقول القول.</p></div>"
  28,63,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قال الذين حق عليهم القول ربنا هؤلاء الذين أغوينا أغويناهم كما غوينا﴾</span></span>: كلام مستأنف لا محل له من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿قال الذين﴾</span></span> فعل، وفاعل، وجملة <span class="hlt"><span class="qpc-hafs">﴿حق عليهم ...﴾</span></span> صلة الموصول لا محل لها من الإعراب. و<span class="hlt"><span class="qpc-hafs">﴿القول﴾</span></span> فاعل، وربنا: منادى مضاف محذوف منه حرف النداء، وهؤلاء: مبتدأ، والذين: اسم موصول في محل رفع خبر المبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿أغوينا﴾</span></span> فعل ماض و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> فاعل، وجملة <span class="hlt"><span class="qpc-hafs">﴿أغوينا﴾</span></span> صلة الموصول لا محل لها من الإعراب والعائد محذوف، أي: هؤلاء الذين أغويناهم. و<span class="hlt"><span class="qpc-hafs">﴿أغويناهم﴾</span></span>: فعل ماض، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> فاعل، والهاء مفعول به، والميم علامة الجمع، و<span class="hlt"><span class="qpc-hafs">﴿كما﴾</span></span> الكاف اسم بمعنى مثل مبني على الفتح في محل نصب نعت لمصدر محذوف ذلك المصدر لمطاوع الفعل المذكور، وتقدير الكلام: أغويناهم فغَوَوا غَيًّا مثلَ غَيِّنا، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> مصدرية، و<span class="hlt"><span class="qpc-hafs">﴿غوينا﴾</span></span> فعل ماض، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> فاعل، وجملة <span class="hlt"><span class="qpc-hafs">﴿غوينا﴾</span></span> صلة الموصول الحرفي <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span>، والمصدر المؤول من <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> المصدرية وما دخلت عليه مضاف إليه، وجملة <span class="hlt"><span class="qpc-hafs">﴿أغويناهم كما غوينا﴾</span></span> مستأنفة لا محل لها من الإعراب.</p><p><span class="hlt"><span class="qpc-hafs">﴿تبرأنا إليك ما كانوا إيانا يعبدون﴾</span></span>: الجملة استئنافية لا محل لها من الإعراب. و<span class="hlt"><span class="qpc-hafs">﴿تبرأنا﴾</span></span> فعل ماض، وفاعل، وإليك: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تبرأنا﴾</span></span>، وما نافية، وكان فعل ماض ناقص، وواو الجماعة اسمها، وإيانا: مفعول مقدم لـ<span class="hlt"><span class="qpc-hafs">﴿يعبدون﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿يعبدون﴾</span></span> خبر كانوا.</p></div>"
  28,64,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وقيل ادعوا شركاءكم فدعوهم فلم يستجيبوا لهم﴾</span></span>: الواو عاطفة، وقيل فعل ماض مبني لما لم يسمَّ فاعله، ونائب الفاعل مستتر، تقديره: هذا القول، وادعوا فعل أمر، وفاعله، وشركاءكم: مفعول به، فدعوهم: الفاء عاطفة، ودعوهم فعل ماض وفاعل ومفعول به، والفاء عاطفة، ويستجيبوا: فعل مضارع مجزوم بلم، والواو فاعل، و<span class="hlt"><span class="qpc-hafs">﴿لهم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يستجيبوا﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿ورأوا العذاب لو أنهم كانوا يهتدون﴾</span></span>: الواو عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿رأوا العذاب﴾</span></span> فعل ماض، وفاعل، ومفعول به، و<span class="hlt"><span class="qpc-hafs">﴿لو﴾</span></span> شرطية، وأن وما بعدها فاعل لفعل محذوف، أي: لو ثبت كونهم مهتدين في الدنيا لما رأوا العذاب في الآخرة. و<span class="hlt"><span class="qpc-hafs">﴿أن﴾</span></span> حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> اسمها، وجملة كانوا خبرها، وكان فعل ماض ناقص، وواو الجماعة اسمها، وجملة يهتدون خبرها.</p></div>"
  28,65,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ويوم يناديهم فيقول ماذا أجبتم المرسلين﴾</span></span>: الواو عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿يوم﴾</span></span> معطوف على <span class="hlt"><span class="qpc-hafs">﴿يوم﴾</span></span> في قوله تعالى <span class="hlt"><span class="qpc-hafs">﴿ويوم يناديهم فيقول أين شركائي﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿يناديهم﴾</span></span> في محل جر مضاف إليه، والفاعل مستتر، والهاء مفعول به، <span class="hlt"><span class="qpc-hafs">﴿فيقول﴾</span></span>: عطف على يناديهم، وماذا اسم استفهام في محل نصب على نزع الخافض، وأجبتم فعل ماض، والتاء في محل رفع فاعل، والمرسلين مفعول به لـ<span class="hlt"><span class="qpc-hafs">﴿أجبتم﴾</span></span>.</p></div>"
  28,66,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فعميت عليهم الأنباء يومئذ فهم لا يتساءلون﴾</span></span>: الفاء عاطفة، وعميت فعل ماض، والأنباء فاعل، وعليهم جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿عميت﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿يومئذ﴾</span></span> يوم: ظرف زمان متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿عميت﴾</span></span>، وإذٍ: اسم مبني على السكون المقدر لاشتغال المحل بتنوين العوض في محل جر مضاف إليه، والتنوين عوض عن جملة محذوفة والتقدير: يوم إذ يناديهم فيقول ماذا أجبتم المرسلين. <span class="hlt"><span class="qpc-hafs">﴿فهم﴾</span></span>: الفاء عاطفة، وهم: مبتدأ، وجملة <span class="hlt"><span class="qpc-hafs">﴿لا يتساءلون﴾</span></span>: خبر.</p></div>"
  28,67,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فأما من تاب وآمن وعمل صالحا فعسى أن يكون من المفلحين﴾</span></span>: الفاء استئنافية، وأما: حرف شرط وتفصيل، و<span class="hlt"><span class="qpc-hafs">﴿مَن﴾</span></span>: اسم موصول مبتدأ، وجملة <span class="hlt"><span class="qpc-hafs">﴿تاب﴾</span></span> صلة الموصول لا محل لها من الإعراب. و<span class="hlt"><span class="qpc-hafs">﴿عمل﴾</span></span>: فعل وفاعل مستتر، و<span class="hlt"><span class="qpc-hafs">﴿صالحًا﴾</span></span> مفعول به لـ<span class="hlt"><span class="qpc-hafs">﴿عمل﴾</span></span>، أو نائب عن المفعول المطلق، لأنه صفة المصدر، أي: عمل عملًا صالحًا. والفاء رابطة، وعسى فعل ماض جامد من أفعال الرجاء، واسمها مستتر، تقديره: هو، وأن وما في حيزها خبرها، و<span class="hlt"><span class="qpc-hafs">﴿من المفلحين﴾</span></span> جار ومجرور متعلقان بمحذوف خبر يكون، وجملة <span class="hlt"><span class="qpc-hafs">﴿فأما من تاب...﴾</span></span> مستأنفة لا محل لها من الإعراب.</p></div>"
  28,68,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وربك يخلق ما يشاء ويختار ما كان لهم الخيرة سبحان الله وتعالى عما يشركون﴾</span></span>: الواو استئنافية، و<span class="hlt"><span class="qpc-hafs">﴿ربك﴾</span></span> مبتدأ، وجملة <span class="hlt"><span class="qpc-hafs">﴿يخلق﴾</span></span> خبر، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿يشاء﴾</span></span> صلة الموصول لا محل لها من الإعراب. <span class="hlt"><span class="qpc-hafs">﴿ويختار﴾</span></span> عطف على يخلق، وجملة <span class="hlt"><span class="qpc-hafs">﴿وربك يخلق...﴾</span></span> مستأنفة لا محل لها من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> نافية، و<span class="hlt"><span class="qpc-hafs">﴿كان﴾</span></span> فعل ماض ناقص، و<span class="hlt"><span class="qpc-hafs">﴿لهم﴾</span></span> جار ومجرور متعلقان بمحذوف خبر كان المقدم، و<span class="hlt"><span class="qpc-hafs">﴿الخيرة﴾</span></span> اسمها المؤخر، و<span class="hlt"><span class="qpc-hafs">﴿سبحان﴾</span></span> نائب مفعول مطلق منصوب بفعل محذوف، ولفظ الجلالة مضاف إليه. <span class="hlt"><span class="qpc-hafs">﴿وتعالى﴾</span></span>: الواو عاطفة، وتعالى فعل ماض، وفاعله مستتر، و<span class="hlt"><span class="qpc-hafs">﴿عما﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تعالى﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿يشركون﴾</span></span> صلة الموصول لا محل لها من الإعراب.</p></div>"
  28,69,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وربك يعلم ما تكن صدورهم وما يعلنون﴾</span></span>: الواو عاطفة، ورب مبتدأ، والكاف مضاف إليه، وجملة يعلم خبر، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> مفعول به، وجملة <span class="hlt"><span class="qpc-hafs">﴿تُكِنُّ﴾</span></span> صلة الموصول لا محل لها من الإعراب. وصدورهم فاعل، <span class="hlt"><span class="qpc-hafs">﴿وما﴾</span></span> عطف على <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> الأولى، وجملة <span class="hlt"><span class="qpc-hafs">﴿يعلنون﴾</span></span> صلة الموصول لا محل لها من الإعراب.</p></div>"
  28,70,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وهو الله﴾</span></span>: الواو عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿هو﴾</span></span> مبتدأ، والله خبر.</p><p><span class="hlt"><span class="qpc-hafs">﴿لا﴾</span></span>: نافية للجنس.</p><p><span class="hlt"><span class="qpc-hafs">﴿إله﴾</span></span>: اسمها مبني على الفتح في محل نصب.</p><p><span class="hlt"><span class="qpc-hafs">﴿إلا﴾</span></span>: أداة حصر.</p><p><span class="hlt"><span class="qpc-hafs">﴿هو﴾</span></span>: بدل من محل لا واسمها، لأن محلها الرفع على الابتداء، أو بدل من الضمير المستكن في الخبر المحذوف. وجملة <span class="hlt"><span class="qpc-hafs">﴿لا إله إلا هو﴾</span></span> خبر ثان.</p><p><span class="hlt"><span class="qpc-hafs">﴿له الحمد في الأولى والآخرة وله الحكم وإليه ترجعون﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿له﴾</span></span> جار ومجرور متعلقان بمحذوف خبر مقدم، والحمد مبتدأ مؤخر، والجملة خبر ثالث، و<span class="hlt"><span class="qpc-hafs">﴿في الأولى﴾</span></span> جار ومجرور متعلقان بمحذوف حال، و<span class="hlt"><span class="qpc-hafs">﴿الآخرة﴾</span></span> عطف على الأولى، <span class="hlt"><span class="qpc-hafs">﴿وله الحكم﴾</span></span> عطف على <span class="hlt"><span class="qpc-hafs">﴿له الحمد﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿إليه﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿ترجعون﴾</span></span>، وترجعون فعل مضارع مبني لما لم يسمَّ فاعله مرفوع، والواو نائب فاعل.</p></div>"