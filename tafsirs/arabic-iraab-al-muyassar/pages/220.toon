quran[9]{c,v,t}:
  10,98,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فلولا كانت قرية آمنت﴾</span></span>: الفاء استئنافية والجملة بعدها مستأنفة لا محل لها من الإعراب، ولولا تحضيضية، وكانت قرية فعل وفاعل، لأن <span class="hlt"><span class="qpc-hafs">﴿كان﴾</span></span> هنا تامة، وجملة آمنت صفة لقرية.</p><p><span class="hlt"><span class="qpc-hafs">﴿فنفعها إيمانها إلا قوم يونس﴾</span></span>: الفاء عاطفة، ونفعها معطوف على الصفة عطف المسبب على السبب، وإيمانها فاعل نفعها، والجملة قد تقوم مقام الصفة للنكرة، و<span class="hlt"><span class="qpc-hafs">﴿إلا قوم يونس﴾</span></span> استثناء متصل، ويونس مضاف إليه ممنوع من الصرف للعلمية والعجمية.</p><p><span class="hlt"><span class="qpc-hafs">﴿لما آمنوا كشفنا عنهم عذاب الخزي في الحياة الدنيا ومتعناهم إلى حين﴾</span></span>: لما حينية، أو رابطة، وآمنوا فعل وفاعل، وجملة كشفنا لا محل لها من الإعراب، وعنهم جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿كشفنا﴾</span></span>، وعذاب الخزي مفعول به، وفي الحياة جار ومجرور متعلقان بمحذوف حال، والدنيا صفة، ومتعناهم عطف على <span class="hlt"><span class="qpc-hafs">﴿كشفنا﴾</span></span>، وإلى حين جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿متعناهم﴾</span></span>.</p></div>"
  10,99,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ولو شاء ربك لآمن من في الأرض كلهم جميعا﴾</span></span>: الواو استئنافية، والجملة بعدها مستأنفة لا محل لها من الإعراب، ولو شرطية، وشاء ربك فعل وفاعل لـ<span class="hlt"><span class="qpc-hafs">﴿آمن﴾</span></span>، واللام واقعة في جواب <span class="hlt"><span class="qpc-hafs">﴿لو﴾</span></span>، وجملة آمن لا محل لها من الإعراب، لأنها جواب شرط غير جازم، و<span class="hlt"><span class="qpc-hafs">﴿مَن﴾</span></span> فاعل آمن، وفي الأرض متعلقان بمحذوف صلة <span class="hlt"><span class="qpc-hafs">﴿من﴾</span></span>، وجملة الصلة لا محل لها من الإعراب، وكلهم توكيد لـ<span class="hlt"><span class="qpc-hafs">﴿من﴾</span></span>، وجميعًا نصب على الحال من <span class="hlt"><span class="qpc-hafs">﴿مَن﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿أفأنت تكره الناس حتى يكونوا مؤمنين﴾</span></span>: الهمزة للاستفهام، والفاء عاطفة، وأنت مبتدأ، والجملة بعده خبر، والهمزة مقدمة على العاطف، أو ثَم جملة محذوفة، وحتى حرف تعليل وجر، ويكونوا منصوب بأن مضمرة بعد حتى، والمصدر المؤول من أن والفعل مجرور بحتى، والجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تكره﴾</span></span>، ومؤمنين خبر يكونوا.</p></div>"
  10,100,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وما كان لنفس أن تؤمن إلا بإذن الله﴾</span></span>: الواو عاطفة، وما نافية، وكان فعل ماض ناقص ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿لنفس﴾</span></span> خبرها المقدم، وأن المصدرية، وما في حيزها اسمها المؤخر، وإلا أداة حصر، وبإذن الله جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تؤمن﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿ويجعل الرجس على الذين لا يعقلون﴾</span></span>: الواو عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿يجعل﴾</span></span> معطوفة على مقدر، كأنه قيل: فيأذن لبعضهم في الإيمان، ويجعل مضارع، والرجس مفعوله، وعلى الذين جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يجعل﴾</span></span>، وجملة لا يعقلون صلة الذين لا محل لها من الإعراب.</p></div>"
  10,101,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قل انظروا ماذا في السماوات والأرض﴾</span></span>: قل فعل أمر، وجملة انظروا مقول القول، و<span class="hlt"><span class="qpc-hafs">﴿ماذا﴾</span></span> ما استفهامية مبتدأ، وذا اسم موصول خبر، والجملة في محل نصب لتعليق العامل وهو <span class="hlt"><span class="qpc-hafs">﴿انظروا﴾</span></span> بالاستفهام، والجار والمجرور متعلقان بمحذوف هو الصلة للموصول، أي: ما الذي استقر في السماوات والأرض، وجملة الصلة لا محل لها من الإعراب، أو <span class="hlt"><span class="qpc-hafs">﴿ماذا﴾</span></span> بتمامها استفهام في محل رفع مبتدأ، وفي السماوات خبره.</p><p><span class="hlt"><span class="qpc-hafs">﴿وما تغني الآيات والنذر عن قوم لا يؤمنون﴾</span></span>: الواو اعتراضية. وما: نافية، أو اسم استفهام مبني على السكون في محل نصب نائب مفعول مطلق. وتغني: فعل مضارع مرفوع بضمة مقدرة على الياء للثقل. والآيات: فاعل. والنذر: عطف على <span class="hlt"><span class="qpc-hafs">﴿الآيات﴾</span></span>. عن قوم: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تغني﴾</span></span>. ولا: نافية. ويؤمنون: فعل مضارع مرفوع بثبوت النون، والواو فاعل. وجملة <span class="hlt"><span class="qpc-hafs">﴿لا يؤمنون﴾</span></span>: في محل جر نعت لـ<span class="hlt"><span class="qpc-hafs">﴿قوم﴾</span></span>. وجملة <span class="hlt"><span class="qpc-hafs">﴿ما تغني...﴾</span></span> اعتراضي تذييلي للجملة السابقة، لا محل لها من الإعراب.</p></div>"
  10,102,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فهل ينتظرون إلا مثل أيام الذين خلوا من قبلهم﴾</span></span>: الفاء استئنافية، والجملة بعدها مستأنفة لا محل لها من الإعراب، وهل حرف استفهام، وينتظرون فعل مضارع مرفوع بثبوت النون، والواو فاعل، وإلا أداة حصر، ومثل مفعول ينتظرون، وأيام مضاف إليه، والذين مضاف إليه، وجملة خلوا صلة الذين لا محل لها من الإعراب، ومن قبلهم جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿خلوا﴾</span></span>، أو بمحذوف حال.</p><p><span class="hlt"><span class="qpc-hafs">﴿قل فانتظروا﴾</span></span>: قل فعل أمر، والفاء الفصيحة، وانتظروا فعل أمر مبني على حذف النون. والواو فاعل.</p><p><span class="hlt"><span class="qpc-hafs">﴿إني معكم من المنتظرين﴾</span></span>: إن حرف ناسخ، والياء اسمها، و<span class="hlt"><span class="qpc-hafs">﴿من المنتظرين﴾</span></span> جار ومجرور متعلقان بمحذوف خبرها، والظرف متعلق بمحذوف حال.</p></div>"
  10,103,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ثم ننجي رسلنا والذين آمنوا﴾</span></span>: ثم حرف عطف للترتيب والتراخي، وننجي فعل مضارع، وفاعله مستتر تقديره: نحن، والجملة عطف على كلام محذوف، تقديره: نهلك الأمم، ثم ننجي رسلنا على حكاية الأحوال الماضية، ورسلنا مفعول به، والذين عطف على رسلنا، وجملة آمنوا صلة الذين لا محل لها من الإعراب.</p><p><span class="hlt"><span class="qpc-hafs">﴿كذلك حقا علينا ننج المؤمنين﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿كذلك﴾</span></span> الكاف: اسم بمعنى مثل مبني على الفتح في محل نصب صفة لمصدر محذوف، والتقدير: إنجاءً مثلَ ذلك الإنجاء ننجي المؤمنين، وذلك: <span class="hlt"><span class="qpc-hafs">﴿ذا﴾</span></span> اسم إشارة في محل جر مضاف إليه، واللام للبعد، والكاف حرف خطاب، و<span class="hlt"><span class="qpc-hafs">﴿حقا﴾</span></span> مفعول مطلق لفعل محذوف مؤكد لمضمون الجملة والتقدير: حق ذلك حقا. و<span class="hlt"><span class="qpc-hafs">﴿علينا﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿حقا﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿حقًا علينا﴾</span></span> اعتراضية لا محل لها من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿ننجي﴾</span></span> فعل مضارع والفاعل مستتر تقديره نحن، و<span class="hlt"><span class="qpc-hafs">﴿المؤمنين﴾</span></span> مفعول به.</p></div>"
  10,104,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قل يا أيها الناس إن كنتم في شك من ديني﴾</span></span>: قل فعل أمر، و<span class="hlt"><span class="qpc-hafs">﴿يا أيها الناس﴾</span></span>: يا حرف نداء، وأي منادى نكرة مقصودة مبني على الضم في محل نصب، وها للتنبيه، والناس صفة لـ<span class="hlt"><span class="qpc-hafs">﴿أي﴾</span></span>، وإن شرطية، وكنتم فعل ماض ناقص ناسخ فعل الشرط، والتاء اسمها، و<span class="hlt"><span class="qpc-hafs">﴿في شك﴾</span></span> جار ومجرور متعلقان بمحذوف خبرها، و<span class="hlt"><span class="qpc-hafs">﴿من ديني﴾</span></span> جار ومجرور متعلقان بمحذوف صفة لـ<span class="hlt"><span class="qpc-hafs">﴿شك﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿فلا أعبد الذين تعبدون من دون الله﴾</span></span>: الفاء رابطة لجواب الشرط، ولا نافية، وأعبد فعل مضارع فاعله: أنا، والذين مفعول أعبد، وجملة <span class="hlt"><span class="qpc-hafs">﴿تعبدون﴾</span></span> صلة الذين لا محل لها من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿من دون الله﴾</span></span> حال.</p><p><span class="hlt"><span class="qpc-hafs">﴿ولكن أعبد الله الذي يتوفاكم﴾</span></span>: الواو عاطفة، ولكن حرف استدراك لا عمل لها، وأعبد فعل مضارع، وفاعله مستتر تقديره: أنا، ولفظ الجلالة مفعوله، والذي صفة، وجملة يتوفاكم صلة الذي لا محل لها من الإعراب.</p><p><span class="hlt"><span class="qpc-hafs">﴿وأمرت أن أكون من المؤمنين﴾</span></span>: الواو عاطفة، وأمرت فعل ماض مبني لما لم يسمَّ فاعله، والتاء نائب فاعل، وأن وما في حيزها في موضع نصب بنزع الخافض، أي: بأن أكون، والجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أمرت﴾</span></span>، واسم أكون مستتر تقديره: أنا، و<span class="hlt"><span class="qpc-hafs">﴿من المؤمنين﴾</span></span> جار ومجرور متعلقان بمحذوف خبر أكون.</p></div>"
  10,105,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وأن أقم وجهك للدين حنيفا﴾</span></span>: الواو عاطفة، وأن وما في حيزها عطف على ما قبلها، كأنه قيل: وقيل لي: وأقم، و<span class="hlt"><span class="qpc-hafs">﴿أقم﴾</span></span> فعل أمر، ووجهك مفعول به، وللدين جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أقم﴾</span></span>، وحنيفًا حال من الدين، أو من الوجه.</p><p><span class="hlt"><span class="qpc-hafs">﴿ولا تكونن من المشركين﴾</span></span>: الواو عاطفة، ولا ناهية، وتكونن فعل مضارع مبني لاتصاله بنون التوكيد في محل جزم بـ<span class="hlt"><span class="qpc-hafs">﴿لا﴾</span></span>، واسم تكونن مستتر تقديره: أنت، ومن المشركين خبرها.</p></div>"
  10,106,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ولا تدع من دون الله ما لا ينفعك ولا يضرك﴾</span></span>: الواو عاطفة، ولا ناهية، وتدع مضارع مجزوم بلا، والفاعل: أنت، ومن دون الله حال، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> موصول مفعول به، وجملة لا ينفعك صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> لا محل لها من الإعراب، وجملة <span class="hlt"><span class="qpc-hafs">﴿ولا يضرك﴾</span></span> عطف على <span class="hlt"><span class="qpc-hafs">﴿لا ينفعك﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿فإن فعلت فإنك إذا من الظالمين﴾</span></span>: الفاء عاطفة، وإن شرطية، وفعلت في محل جزم فعل الشرط، والفاء رابطة، وإن حرف ناسخ، والكاف اسمها، وإذًا حرف جواب وجزاء مهمل، و<span class="hlt"><span class="qpc-hafs">﴿من الظالمين﴾</span></span> جار ومجرور متعلقان بمحذوف خبر إن.</p></div>"