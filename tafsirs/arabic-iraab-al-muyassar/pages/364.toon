quran[12]{c,v,t}:
  25,44,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿أم تحسب أن أكثرهم يسمعون أو يعقلون﴾</span></span>: أم: حرف عطف، وهي منقطعة بمعنى: بل وهمزة الاستفهام، والتقدير: بل أتحسب ...، والاستفهام للإنكار، وأن وما في حيزها سدت مسد مفعولي تحسب، وجملة يسمعون خبر أن، و<span class="hlt"><span class="qpc-hafs">﴿أو﴾</span></span> حرف عطف، ويعقلون عطف على يسمعون.</p><p><span class="hlt"><span class="qpc-hafs">﴿إن هم إلا كالأنعام بل هم أضل سبيلا﴾</span></span>: إن نافية، و<span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> مبتدأ، وإلا أداة حصر، <span class="hlt"><span class="qpc-hafs">﴿كالأنعام﴾</span></span> الكاف اسم بمعنى مثل مبني على الفتح في محل رفع خبر <span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿الأنعام﴾</span></span> مضاف إليه، <span class="hlt"><span class="qpc-hafs">﴿بل﴾</span></span> حرف عطف وإضراب، و<span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> مبتدأ، وأضل خبره، وسبيلًا تمييز.</p></div>"
  25,45,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ألم تر إلى ربك كيف مد الظل ولو شاء لجعله ساكنا﴾</span></span>: الهمزة للاستفهام، ولم حرف نفي وقلب وجزم، و<span class="hlt"><span class="qpc-hafs">﴿تر﴾</span></span> فعل مضارع مجزوم بـ<span class="hlt"><span class="qpc-hafs">﴿لم﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿إلى ربك﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تر﴾</span></span>، وكيف اسم استفهام في محل نصب على الحال، وجملة مد الظل مستأنفة لا محل لها من الإعراب، وقيل: الرؤية قلبية، والمعنى: ألم تعلم، وقد علقت <span class="hlt"><span class="qpc-hafs">﴿كيف﴾</span></span> <span class="hlt"><span class="qpc-hafs">﴿تر﴾</span></span> عن العمل، فجملة مد الظل في محل نصب مفعول به، <span class="hlt"><span class="qpc-hafs">﴿ولو﴾</span></span> الواو حالية، ولو شرطية، وشاء فعل ماض، والفاعل مستتر، واللام واقعة في جواب لو، وجملة جعله لا محل لها من الإعراب، لأنها جواب شرط غير جازم، والهاء مفعول جعل الأول، وساكنًا مفعوله الثاني.</p><p><span class="hlt"><span class="qpc-hafs">﴿ثم جعلنا الشمس عليه دليلا﴾</span></span>: ثم عطف، وجعلنا فعل وفاعل، والشمس مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿عليه﴾</span></span> جار ومجرور متعلقان بمحذوف حال، أو جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿دليلا﴾</span></span>، ودليلًا مفعول به ثان.</p></div>"
  25,46,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ثم قبضناه إلينا قبضا يسيرا﴾</span></span>: ثم حرف عطف، وقبضناه فعل وفاعل ومفعول به، و<span class="hlt"><span class="qpc-hafs">﴿إلينا﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿قبضناه﴾</span></span>، وقبضًا مفعول مطلق، ويسيرًا صفة.</p></div>"
  25,47,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وهو الذي جعل لكم الليل لباسا والنوم سباتا وجعل النهار نشورا﴾</span></span>: الواو عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿هو﴾</span></span> مبتدأ، والذي خبره، وجملة جعل صلة الذي لا محل لها من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿لكم﴾</span></span> جار ومجرور متعلقان بمحذوف حال، لأنه كان في الأصل صفة لـ<span class="hlt"><span class="qpc-hafs">﴿لباسًا﴾</span></span>، والليل مفعول جعل الأول، ولباسًا مفعوله الثاني، والنوم سباتًا عطف على ما تقدم، و<span class="hlt"><span class="qpc-hafs">﴿جعل النهار نشورًا﴾</span></span> عطف أيضًا.</p></div>"
  25,48,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وهو الذي أرسل الرياح بشرا بين يدي رحمته﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿هو﴾</span></span> مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿الذي﴾</span></span> خبر، و<span class="hlt"><span class="qpc-hafs">﴿أرسل الرياح﴾</span></span> فعل ومفعول به، والفاعل مستتر، وجملة <span class="hlt"><span class="qpc-hafs">﴿أرسل﴾</span></span> صلة الذي لا محل لها من الإعراب، وبشرًا حال، و<span class="hlt"><span class="qpc-hafs">﴿بين﴾</span></span> ظرف متعلق بمحذوف صفة لـ<span class="hlt"><span class="qpc-hafs">﴿بشرًا﴾</span></span>، ويدي رحمته مضاف إليه.</p><p><span class="hlt"><span class="qpc-hafs">﴿وأنزلنا من السماء ماء طهورا﴾</span></span>: عطف على ما تقدم، و<span class="hlt"><span class="qpc-hafs">﴿أنزلنا﴾</span></span> فعل وفاعل، و<span class="hlt"><span class="qpc-hafs">﴿من السماء﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أنزلنا﴾</span></span>، وماء مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿طهورا﴾</span></span> صفة.</p></div>"
  25,49,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿لنحيي به بلدة ميتا ونسقيه مما خلقنا أنعاما وأناسي كثيرا﴾</span></span>: لام التعليل حرف جر، والجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أنزلنا﴾</span></span> لبيان العلة في إنزاله، و<span class="hlt"><span class="qpc-hafs">﴿به﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿نحيي﴾</span></span>، وبلدة مفعول به، وميتًا صفة لبلدة، ونسقيه عطف على نحيي، و<span class="hlt"><span class="qpc-hafs">﴿مما﴾</span></span> متعلقان بمحذوف حال، وأنعامًا مفعول به ثان لـ<span class="hlt"><span class="qpc-hafs">﴿نسقيه﴾</span></span>، وأناسي كثيرًا عطف على <span class="hlt"><span class="qpc-hafs">﴿أنعامًا﴾</span></span>.</p></div>"
  25,50,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ولقد صرفناه بينهم ليذكروا﴾</span></span>: عطف على ما تقدم، واللام جواب للقسم المحذوف، وقد حرف تحقيق، وصرفناه فعل، وفاعل، ومفعول به، والضمير يعود على الماء، أو على القول الذي مر فيه ذكر إنشاء السحاب وإنزال القطر، و<span class="hlt"><span class="qpc-hafs">﴿بينهم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿صرفناه﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿ليذكروا﴾</span></span> اللام للتعليل، ويذكروا فعل مضارع منصوب بأن مضمرة بعد اللام، والمصدر المؤول من أن والفعل مجرور باللام، والجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿صرفناه﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿فأبى أكثر الناس إلا كفورا﴾</span></span>: الفاء عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿أبى أكثر﴾</span></span> فعل وفاعل، والجملة عطف على ما تقدم، وإلا أداة حصر، وكفورًا مفعول به.</p></div>"
  25,51,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ولو شئنا لبعثنا في كل قرية نذيرا﴾</span></span>: الواو عاطفة، ولو شرطية، وشئنا فعل وفاعل، ومفعول المشيئة محذوف، واللام واقعة في جواب <span class="hlt"><span class="qpc-hafs">﴿لو﴾</span></span>، وجملة بعثنا لا محل لها من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿في كل قرية﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿بعثنا﴾</span></span>، ونذيرًا مفعول به.</p></div>"
  25,52,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فلا تطع الكافرين وجاهدهم به جهادا كبيرا﴾</span></span>: الفاء الفصيحة، ولا ناهية، وتطع مجزوم بـ<span class="hlt"><span class="qpc-hafs">﴿لا﴾</span></span>، والفاعل مستتر تقديره: أنت، والكافرين مفعول به، وجاهدهم فعل أمر، وفاعل مستتر، ومفعول به، و<span class="hlt"><span class="qpc-hafs">﴿به﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿جاهدهم﴾</span></span>، والضمير للقرآن، وجهادًا مفعول مطلق، وكبيرًا صفة.</p></div>"
  25,53,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وهو الذي مرج البحرين هذا عذب فرات وهذا ملح أجاج﴾</span></span>: الواو عاطفة، والكلام معطوف على ما تقدم، و<span class="hlt"><span class="qpc-hafs">﴿هو﴾</span></span> مبتدأ، والذي خبره، وجملة <span class="hlt"><span class="qpc-hafs">﴿مرج البحرين﴾</span></span> صلة الذي لا محل لها من الإعراب، وجملة <span class="hlt"><span class="qpc-hafs">﴿هذا عذب﴾</span></span> استئنافية لا محل لها من الإعراب، أو مقول لقول محذوف في موضع الحال، أي: مقولًا فيهما، و<span class="hlt"><span class="qpc-hafs">﴿هذا﴾</span></span> مبتدأ، وعذب خبره، وفرات خبر ثان، و<span class="hlt"><span class="qpc-hafs">﴿هذا ملح أجاج﴾</span></span> عطف على ما تقدم.</p><p><span class="hlt"><span class="qpc-hafs">﴿وجعل بينهما برزخا وحجرا محجورا﴾</span></span>: عطف على <span class="hlt"><span class="qpc-hafs">﴿مرج﴾</span></span> داخل في حيز الصلة، وجعل فعل ماض، وفاعله ضمير مستتر، تقديره: هو، و<span class="hlt"><span class="qpc-hafs">﴿بينهما﴾</span></span> ظرف متعلق بمحذوف في موضع المفعول الثاني لجعل، وبرزخًا مفعول به أول، وحجرًا محجورًا عطف على <span class="hlt"><span class="qpc-hafs">﴿برزخًا﴾</span></span>، وقيل: منصوبان بقول مقدر.</p></div>"
  25,54,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وهو الذي خلق من الماء بشرا فجعله نسبا وصهرا﴾</span></span>: عطف على ما تقدم، و<span class="hlt"><span class="qpc-hafs">﴿من الماء﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿خلق﴾</span></span>، وبشرًا مفعول به، <span class="hlt"><span class="qpc-hafs">﴿فجعله﴾</span></span> الفاء عاطفة، وجعله فعل، وفاعل مستتر، ومفعول به أول، ونسبًا مفعول به ثان، وصهرًا عطف على <span class="hlt"><span class="qpc-hafs">﴿نسبًا﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿وكان ربك قديرا﴾</span></span>: الواو استئنافية، والجملة بعدها مستأنفة لا محل لها من الإعراب، كان فعل ماض ناقص ناسخ، وربك اسمها، وقديرًا خبرها.</p></div>"
  25,55,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ويعبدون من دون الله ما لا ينفعهم ولا يضرهم﴾</span></span>: الواو استئنافية، والجملة بعدها مستأنفة لا محل لها من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿من دون الله﴾</span></span> جار ومجرور متعلقان بمحذوف حال، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> مفعول به، وجملة لا ينفعهم صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> لا محل لها من الإعراب، وجملة ولا يضرهم عطف على جملة <span class="hlt"><span class="qpc-hafs">﴿لا ينفعهم﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿وكان الكافر على ربه ظهيرا﴾</span></span>: الواو عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿كان الكافر﴾</span></span> كان فعل ماض ناقص، والكافر اسم كان، و<span class="hlt"><span class="qpc-hafs">﴿على ربه﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿ظهيرًا﴾</span></span>، وظهيرًا خبر كان.</p></div>"