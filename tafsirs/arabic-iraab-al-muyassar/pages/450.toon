quran[24]{c,v,t}:
  37,103,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فلما أسلما وتله للجبين﴾</span></span>: الفاء عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿لما﴾</span></span> حينية أو رابطة، و<span class="hlt"><span class="qpc-hafs">﴿أسلما﴾</span></span> فعل ماض، والألف فاعل، <span class="hlt"><span class="qpc-hafs">﴿وتله﴾</span></span> الواو عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿تله﴾</span></span> فعل ماض، والفاعل مستتر تقديره: هو، أي: إبراهيم، والهاء مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿للجبين﴾</span></span> جار ومجرور متعلقان بمحذوف حال، وجواب <span class="hlt"><span class="qpc-hafs">﴿لما﴾</span></span> محذوف تقديره: ظهر صبرهما، أو: أجزلنا لهما أجرهما.</p></div>"
  37,104,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وناديناه أن يا إبراهيم﴾</span></span>: الواو عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿ناديناه﴾</span></span> فعل ماض، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> فاعل، والهاء مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿أن﴾</span></span> تفسيرية، لأن النداء فيه معنى القول دون حروفه، والجملة بعدها تفسيرية لا محل لها من الإعراب. و<span class="hlt"><span class="qpc-hafs">﴿يا﴾</span></span> حرف نداء، و<span class="hlt"><span class="qpc-hafs">﴿إبراهيم﴾</span></span> منادى مفرد علم مبني على الضم.</p></div>"
  37,105,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قد صدقت الرؤيا﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿قد﴾</span></span> حرف تحقيق، و<span class="hlt"><span class="qpc-hafs">﴿صدقت﴾</span></span> فعل ماض، والتاء فاعل، و<span class="hlt"><span class="qpc-hafs">﴿الرؤيا﴾</span></span> مفعول به.</p><p><span class="hlt"><span class="qpc-hafs">﴿إنا كذلك نجزي المحسنين﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿إنّا﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span> حرف ناسخ و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> اسمها، و<span class="hlt"><span class="qpc-hafs">﴿كذلك﴾</span></span>: الكاف: اسم بمعنى مثل مبني على الفتح في محل نصب صفة لمصدر محذوف مقدم على عامله، أي: جزاءً مثلَ ذلك نجزي المحسنين، وذلك: <span class="hlt"><span class="qpc-hafs">﴿ذا﴾</span></span> اسم إشارة في محل جر مضاف إليه، واللام للبعد، والكاف حرف خطاب، و<span class="hlt"><span class="qpc-hafs">﴿نجزي﴾</span></span> فعل مضارع، والفاعل مستتر تقديره: نحن، و<span class="hlt"><span class="qpc-hafs">﴿المحسنين﴾</span></span> مفعول به، وجملة <span class="hlt"><span class="qpc-hafs">﴿نجزي المحسنين﴾</span></span> خبر <span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span>.</p></div>"
  37,106,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إن هذا لهو البلاء المبين﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span> حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿هذا﴾</span></span> اسمها، واللام المزحلقة، و<span class="hlt"><span class="qpc-hafs">﴿هو﴾</span></span> مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿البلاء﴾</span></span> خبر <span class="hlt"><span class="qpc-hafs">﴿هو﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿لهو البلاء المبين﴾</span></span> خبر <span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span>، أو <span class="hlt"><span class="qpc-hafs">﴿هو﴾</span></span> ضمير فصل، و<span class="hlt"><span class="qpc-hafs">﴿البلاء﴾</span></span> خبر <span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿المبين﴾</span></span> نعت للبلاء.</p></div>"
  37,107,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وفديناه بذبح عظيم﴾</span></span>: الواو عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿فديناه﴾</span></span> فعل ماض، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> فاعل، والهاء مفعول به، والجملة معطوفة على <span class="hlt"><span class="qpc-hafs">﴿ناديناه﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿بذبح﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿فديناه﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿عظيم﴾</span></span> صفة لـ<span class="hlt"><span class="qpc-hafs">﴿ذبح﴾</span></span>.</p></div>"
  37,108,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وتركنا عليه في الآخرين﴾</span></span>: الواو عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿تركنا﴾</span></span> فعل ماض، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> فاعل، و<span class="hlt"><span class="qpc-hafs">﴿عليه﴾</span></span> جار ومجرور متعلقان بمحذوف صفة للمفعول المحذوف، أي: ثناء كائنًا عليه، و<span class="hlt"><span class="qpc-hafs">﴿في الآخرين﴾</span></span> جار ومجرور متعلقان بمحذوف مفعول به ثان لـ<span class="hlt"><span class="qpc-hafs">﴿تركنا﴾</span></span>.</p></div>"
  37,109,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿سلام على إبراهيم﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿سلام﴾</span></span> مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿على إبراهيم﴾</span></span> جار ومجرور متعلقان بمحذوف خبر، وجملة <span class="hlt"><span class="qpc-hafs">﴿سلام على إبراهيم﴾</span></span> مقول قول محذوف، أي: يقال له هذا في الآخرين.</p></div>"
  37,110,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿كذلك نجزي المحسنين﴾</span></span>:  <span class="hlt"><span class="qpc-hafs">﴿كذلك﴾</span></span>: الكاف: اسم بمعنى مثل مبني على الفتح في محل نصب صفة لمصدر محذوف مقدم على عامله، أي: جزاءً مثلَ ذلك نجزي المحسنين، وذلك: <span class="hlt"><span class="qpc-hafs">﴿ذا﴾</span></span> اسم إشارة في محل جر مضاف إليه، واللام للبعد، والكاف حرف خطاب، و<span class="hlt"><span class="qpc-hafs">﴿نجزي﴾</span></span> فعل مضارع، والفاعل مستتر تقديره: نحن، و<span class="hlt"><span class="qpc-hafs">﴿المحسنين﴾</span></span> مفعول به.</p></div>"
  37,111,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إنه من عبادنا المؤمنين﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span> حرف ناسخ، والهاء اسمها، و<span class="hlt"><span class="qpc-hafs">﴿من عبادنا﴾</span></span> جار ومجرور متعلقان بمحذوف خبر، و<span class="hlt"><span class="qpc-hafs">﴿المؤمنين﴾</span></span> صفة، والجملة تعليلية لا محل لها من الإعراب.</p></div>"
  37,112,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وبشرناه بإسحاق نبيا من الصالحين﴾</span></span>: الواو حرف عطف، و<span class="hlt"><span class="qpc-hafs">﴿بشرناه﴾</span></span> فعل ماض، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> فاعل، والهاء مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿بإسحاق﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿بشرناه﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿نبيا﴾</span></span> حال من <span class="hlt"><span class="qpc-hafs">﴿إسحاق﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿من الصالحين﴾</span></span> جار ومجرور متعلقان بمحذوف صفة لـ<span class="hlt"><span class="qpc-hafs">﴿نبيا﴾</span></span>، أو حال ثانية.</p></div>"
  37,113,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وباركنا عليه وعلى إسحاق﴾</span></span>: الواو عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿باركنا﴾</span></span> عطف على ما تقدم، وهو فعل ماض، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> فاعل، و<span class="hlt"><span class="qpc-hafs">﴿عليه﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿باركنا﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿على إسحاق﴾</span></span> عطف على <span class="hlt"><span class="qpc-hafs">﴿عليه﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿ومن ذريتهما محسن وظالم لنفسه مبين﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿من ذريتهما﴾</span></span> جار ومجرور متعلقان بمحذوف خبر مقدم، و<span class="hlt"><span class="qpc-hafs">﴿محسن﴾</span></span> مبتدأ مؤخر، و<span class="hlt"><span class="qpc-hafs">﴿ظالم﴾</span></span> عطف على <span class="hlt"><span class="qpc-hafs">﴿محسن﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿لنفسه﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿ظالم﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿مبين﴾</span></span> صفة لـ<span class="hlt"><span class="qpc-hafs">﴿ظالم﴾</span></span>.</p></div>"
  37,114,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ولقد مننا على موسى وهارون﴾</span></span>: كلام مستأنف لا محل له من الإعراب، أو الواو عاطفة على ما سبق، واللام جواب للقسم المحذوف، و<span class="hlt"><span class="qpc-hafs">﴿قد﴾</span></span> حرف تحقيق، و<span class="hlt"><span class="qpc-hafs">﴿مننا﴾</span></span> فعل ماض، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> فاعل، و<span class="hlt"><span class="qpc-hafs">﴿على موسى وهارون﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿مننا﴾</span></span>.</p></div>"
  37,115,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ونجيناهما وقومهما من الكرب العظيم﴾</span></span>: الواو عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿نجيناهما﴾</span></span> عطف على <span class="hlt"><span class="qpc-hafs">﴿مننا﴾</span></span>، وهو فعل ماض، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> فاعل، و<span class="hlt"><span class="qpc-hafs">﴿هما﴾</span></span> مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿قومهما﴾</span></span> مفعول معه، أو معطوف على الضمير في <span class="hlt"><span class="qpc-hafs">﴿نجيناهما﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿من الكرب﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿نجيناهما﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿العظيم﴾</span></span> صفة لـ<span class="hlt"><span class="qpc-hafs">﴿الكرب﴾</span></span>.</p></div>"
  37,116,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ونصرناهم فكانوا هم الغالبين﴾</span></span>: عطف على ما تقدم، و<span class="hlt"><span class="qpc-hafs">﴿نصرناهم﴾</span></span> فعل ماض، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> فاعل، و<span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> مفعول به، <span class="hlt"><span class="qpc-hafs">﴿فكانوا﴾</span></span> الفاء عاطفة، وكان فعل ماض ناقص، والواو اسمها، و<span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> ضمير فصل لا محل له من الإعراب، وقيل: تأكيد للواو، أو بدل منها، و<span class="hlt"><span class="qpc-hafs">﴿الغالبين﴾</span></span> خبر <span class="hlt"><span class="qpc-hafs">﴿كانوا﴾</span></span>.</p></div>"
  37,117,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وآتيناهما الكتاب المستبين﴾</span></span>: عطف على ما تقدم، <span class="hlt"><span class="qpc-hafs">﴿آتيناهما﴾</span></span> فعل ماض، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> فاعل، و<span class="hlt"><span class="qpc-hafs">﴿هما﴾</span></span> مفعول به أول، و<span class="hlt"><span class="qpc-hafs">﴿الكتاب﴾</span></span> مفعول به ثان، و<span class="hlt"><span class="qpc-hafs">﴿المستبين﴾</span></span> نعت للكتاب.</p></div>"
  37,118,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وهديناهما الصراط المستقيم﴾</span></span>: عطف على ما تقدم، <span class="hlt"><span class="qpc-hafs">﴿وهديناهما﴾</span></span> فعل ماض، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> فاعل، و<span class="hlt"><span class="qpc-hafs">﴿هما﴾</span></span> مفعول به أول، و<span class="hlt"><span class="qpc-hafs">﴿الصراط﴾</span></span> مفعول به ثان، أو منصوب بنزع الخافض، و<span class="hlt"><span class="qpc-hafs">﴿المستقيم﴾</span></span> نعت للصراط.</p></div>"
  37,119,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وتركنا عليهما في الآخرين﴾</span></span>: الواو عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿تركنا﴾</span></span> فعل ماض، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> فاعل، و<span class="hlt"><span class="qpc-hafs">﴿عليهما﴾</span></span> جار ومجرور متعلقان بمحذوف صفة للمفعول المحذوف، أي: ثناء كائنًا عليهما، و<span class="hlt"><span class="qpc-hafs">﴿في الآخرين﴾</span></span> جار ومجرور متعلقان بمحذوف مفعول به ثان لـ<span class="hlt"><span class="qpc-hafs">﴿تركنا﴾</span></span>.</p></div>"
  37,120,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿سلام على موسى وهارون﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿سلام﴾</span></span> مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿على موسى وهارون﴾</span></span> جار ومجرور متعلقان بمحذوف خبر.</p></div>"
  37,121,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إنا كذلك نجزي المحسنين﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿إنّا﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span> حرف ناسخ و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> اسمها، و<span class="hlt"><span class="qpc-hafs">﴿كذلك﴾</span></span>: الكاف: اسم بمعنى مثل مبني على الفتح في محل نصب صفة لمصدر محذوف مقدم على عامله، أي: جزاءً مثلَ ذلك نجزي المحسنين، وذلك: <span class="hlt"><span class="qpc-hafs">﴿ذا﴾</span></span> اسم إشارة في محل جر مضاف إليه، واللام للبعد، والكاف حرف خطاب، و<span class="hlt"><span class="qpc-hafs">﴿نجزي﴾</span></span> فعل مضارع، والفاعل مستتر تقديره: نحن، و<span class="hlt"><span class="qpc-hafs">﴿المحسنين﴾</span></span> مفعول به، وجملة <span class="hlt"><span class="qpc-hafs">﴿نجزي المحسنين﴾</span></span> خبر <span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span>.</p></div>"
  37,122,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إنهما من عبادنا المؤمنين﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span> حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿هما﴾</span></span> اسمها، و<span class="hlt"><span class="qpc-hafs">﴿من عبادنا﴾</span></span> جار ومجرور متعلقان بمحذوف خبر إن، و<span class="hlt"><span class="qpc-hafs">﴿المؤمنين﴾</span></span> نعت.</p></div>"
  37,123,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وإن إلياس لمن المرسلين﴾</span></span>: الواو عاطفة أو استئنافية، و<span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span> حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿إلياس﴾</span></span> اسمها، واللام المزحلقة، و<span class="hlt"><span class="qpc-hafs">﴿من المرسلين﴾</span></span> جار ومجرور متعلقان بمحذوف خبر <span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿وإن إلياس...﴾</span></span> معطوفة، أو مستأنفة لا محل لها من الإعراب.</p></div>"
  37,124,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إذ قال لقومه ألا تتقون﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿إذ﴾</span></span> اسم مبني على السكون في محل نصب مفعول به لفعل محذوف تقديره: اذكر، وقيل: ظرف متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿المرسلين﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿قال﴾</span></span> فعل ماض، والفاعل مستتر، وجملة <span class="hlt"><span class="qpc-hafs">﴿قال﴾</span></span> في محل جر بالإضافة، و<span class="hlt"><span class="qpc-hafs">﴿لقومه﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿قال﴾</span></span>، والهمزة للاستفهام، و<span class="hlt"><span class="qpc-hafs">﴿لا﴾</span></span> نافية، و<span class="hlt"><span class="qpc-hafs">﴿تتقون﴾</span></span> فعل مضارع مرفوع، والواو فاعل، والجملة مقول القول.</p></div>"
  37,125,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿أتدعون بعلا﴾</span></span>: الهمزة للاستفهام الإنكاري، و<span class="hlt"><span class="qpc-hafs">﴿تدعون﴾</span></span> فعل مضارع مرفوع بثبوت النون، والواو فاعل، و<span class="hlt"><span class="qpc-hafs">﴿بعلًا﴾</span></span> مفعول به.</p><p><span class="hlt"><span class="qpc-hafs">﴿وتذرون أحسن الخالقين﴾</span></span>: الواو عاطفة، والجملة عطف على <span class="hlt"><span class="qpc-hafs">﴿تدعون﴾</span></span>، أو الواو حالية، والجملة في محل نصب على الحال، و<span class="hlt"><span class="qpc-hafs">﴿تذرون﴾</span></span> فعل مضارع مرفوع، والواو فاعل، و<span class="hlt"><span class="qpc-hafs">﴿أحسن الخالقين﴾</span></span> مفعول به.</p></div>"
  37,126,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿الله ربكم ورب آبائكم الأولين﴾</span></span>: لفظ الجلالة بدل من <span class="hlt"><span class="qpc-hafs">﴿أحسن الخالقين﴾</span></span> منصوب، و<span class="hlt"><span class="qpc-hafs">﴿ربكم﴾</span></span> بدل من <span class="hlt"><span class="qpc-hafs">﴿الله﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿ورب آبائكم الأولين﴾</span></span> عطف.</p></div>"