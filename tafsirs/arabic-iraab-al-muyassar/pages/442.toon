quran[13]{c,v,t}:
  36,28,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وما أنزلنا على قومه من بعده من جند من السماء﴾</span></span>: كلام مستأنف لا محل له من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> نافية، و<span class="hlt"><span class="qpc-hafs">﴿أنزلنا﴾</span></span> فعل وفاعل، و<span class="hlt"><span class="qpc-hafs">﴿عليهم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أنزلنا﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿من بعده﴾</span></span> جار ومجرور متعلقان بمحذوف حال، ومن حرف جر صلة، وجند مجرور لفظًا منصوب محلًّا على أنه مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿من السماء﴾</span></span> جار ومجرور متعلقان بمحذوف صفة لـ<span class="hlt"><span class="qpc-hafs">﴿جند﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿وما كنا منزلين﴾</span></span>: الواو عاطفة، وما نافية، وكان فعل ماض ناقص ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> اسمها، ومنزلين خبرها.</p></div>"
  36,29,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إن كانت إلا صيحة واحدة﴾</span></span>: إن نافية، وكانت فعل ماض ناقص ناسخ، واسمها ضمير مستتر، و<span class="hlt"><span class="qpc-hafs">﴿صيحة﴾</span></span> خبر كانت منصوب، و<span class="hlt"><span class="qpc-hafs">﴿واحدة﴾</span></span> صفة، والتقدير: ما كانت الصيحة إلا صيحة واحدة.</p><p><span class="hlt"><span class="qpc-hafs">﴿فإذا هم خامدون﴾</span></span>: الفاء عاطفة، وإذا فجائية، و<span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿خامدون﴾</span></span> خبر.</p></div>"
  36,30,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿يا حسرة على العباد﴾</span></span>: يا حرف نداء، وحسرة منادى شبيه بالمضاف منصوب، أو منادى نكرة مقصودة، وإنما نصبت لأنها وصفت بالجار والمجرور، أو المنادى محذوف، وحسرة مصدر، أي: أتحسر حسرة، ويكون النداء هنا مجازيا، أي: يا حسرة احضري فهذا أوانك.</p><p><span class="hlt"><span class="qpc-hafs">﴿ما يأتيهم من رسول إلا كانوا به يستهزئون﴾</span></span>: كلام مستأنف لا محل له من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> نافية، و<span class="hlt"><span class="qpc-hafs">﴿يأتيهم﴾</span></span> فعل مضارع، و<span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> مفعول به، ومن حرف جر صلة، ورسول مجرور بـ<span class="hlt"><span class="qpc-hafs">﴿من﴾</span></span> لفظًا مرفوع محلا على أنه فاعل، وإلا أداة حصر، و<span class="hlt"><span class="qpc-hafs">﴿كانوا﴾</span></span> كان فعل ماض ناقص ناسخ، والواو اسمها، و<span class="hlt"><span class="qpc-hafs">﴿به﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يستهزئون﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿يستهزئون﴾</span></span> فعل مضارع مرفوع، والواو فاعل، والجملة في محل نصب خبر كانوا، وجملة <span class="hlt"><span class="qpc-hafs">﴿كانوا﴾</span></span> في محل نصب على الحال من الفاعل في <span class="hlt"><span class="qpc-hafs">﴿يأتيهم﴾</span></span> أو من المفعول.</p></div>"
  36,31,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ألم يروا كم أهلكنا قبلهم من القرون﴾</span></span>: الهمزة للاستفهام التقريري، و<span class="hlt"><span class="qpc-hafs">﴿لم﴾</span></span> حرف نفي وقلب وجزم، و<span class="hlt"><span class="qpc-hafs">﴿يروا﴾</span></span> فعل مضارع مجزوم بـ<span class="hlt"><span class="qpc-hafs">﴿لم﴾</span></span>، والواو فاعل، والرؤية قلبية علمية، و<span class="hlt"><span class="qpc-hafs">﴿كم﴾</span></span> خبرية في محل نصب مفعول مقدم لـ<span class="hlt"><span class="qpc-hafs">﴿أهلكنا﴾</span></span>، وأهلكنا فعل ماض، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> فاعل، والجملة في محل نصب مفعول <span class="hlt"><span class="qpc-hafs">﴿يروا﴾</span></span>، أو <span class="hlt"><span class="qpc-hafs">﴿كم﴾</span></span> استفهامية، و<span class="hlt"><span class="qpc-hafs">﴿قبلهم﴾</span></span> ظرف متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿أهلكنا﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿من القرون﴾</span></span> جار ومجرور متعلقان بمحذوف حال.</p><p><span class="hlt"><span class="qpc-hafs">﴿أنهم إليهم لا يرجعون﴾</span></span>: أن حرف ناسخ، وهم اسمها، وأن وما في حيزها بدل من معنى <span class="hlt"><span class="qpc-hafs">﴿كم أهلكنا﴾</span></span>، والتقدير: ألم يروا كثرة إهلاكنا القرون من قبلهم كونهم غير راجعين إليهم، أو المصدر المؤول معمول لفعل محذوف دل عليه السياق، والمعنى: وقضينا وحكمنا أنهم إليهم لا يرجعون، و<span class="hlt"><span class="qpc-hafs">﴿إليهم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يرجعون﴾</span></span>، ولا نافية، و<span class="hlt"><span class="qpc-hafs">﴿يرجعون﴾</span></span> فعل مضارع مرفوع، والواو فاعل، وجملة <span class="hlt"><span class="qpc-hafs">﴿يرجعون﴾</span></span> خبر إن.</p></div>"
  36,32,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وإن كل لما جميع لدينا محضرون﴾</span></span>: الواو عاطفة، وإن نافية، و<span class="hlt"><span class="qpc-hafs">﴿كل﴾</span></span> مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿لما﴾</span></span> حرف بمعنى إلا، و<span class="hlt"><span class="qpc-hafs">﴿جميع﴾</span></span> خبر <span class="hlt"><span class="qpc-hafs">﴿كل﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿لدينا﴾</span></span> ظرف متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿جميع﴾</span></span>، أو بـ<span class="hlt"><span class="qpc-hafs">﴿محضرون﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿محضرون﴾</span></span> خبر ثان، أو نعت لـ<span class="hlt"><span class="qpc-hafs">﴿جميع﴾</span></span>.</p></div>"
  36,33,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وآية لهم الأرض الميتة أحييناها﴾</span></span>: كلام مستأنف لا محل له من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿آية﴾</span></span> خبر مقدم، و<span class="hlt"><span class="qpc-hafs">﴿لهم﴾</span></span> جار ومجرور متعلقان بمحذوف صفة، و<span class="hlt"><span class="qpc-hafs">﴿الأرض﴾</span></span> مبتدأ مؤخر، و<span class="hlt"><span class="qpc-hafs">﴿أحييناها﴾</span></span> فعل ماض، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> فاعل، والهاء مفعول به، وجملة <span class="hlt"><span class="qpc-hafs">﴿أحييناها﴾</span></span> حالية، أو مستأنفة لا محل لها من الإعراب.</p><p><span class="hlt"><span class="qpc-hafs">﴿وأخرجنا منها حبا فمنه يأكلون﴾</span></span>: عطف على <span class="hlt"><span class="qpc-hafs">﴿أحييناها﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿أخرجنا﴾</span></span> فعل ماض، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> فاعل، و<span class="hlt"><span class="qpc-hafs">﴿منها﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أخرجنا﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿حبًّا﴾</span></span> مفعول به، والفاء استئنافية، و<span class="hlt"><span class="qpc-hafs">﴿منه﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يأكلون﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿يأكلون﴾</span></span> فعل مضارع، والواو فاعل، وجملة <span class="hlt"><span class="qpc-hafs">﴿فمنه يأكلون﴾</span></span> مستأنفة لا محل لها من الإعراب.</p></div>"
  36,34,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وجعلنا فيها جنات من نخيل وأعناب وفجرنا فيها من العيون﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿وجعلنا﴾</span></span> فعل وفاعل، والجملة عطف على <span class="hlt"><span class="qpc-hafs">﴿أحييناها﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿فيها﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿جعلنا﴾</span></span>، أو متعلقان بمحذوف مفعول به ثان لـ<span class="hlt"><span class="qpc-hafs">﴿جعلنا﴾</span></span>، وجنات مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿من نخيل﴾</span></span> جار ومجرور متعلقان بمحذوف صفة لـ<span class="hlt"><span class="qpc-hafs">﴿جنات﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿أعناب﴾</span></span> عطف على <span class="hlt"><span class="qpc-hafs">﴿نخيل﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿فجرنا﴾</span></span> عطف، وهو فعل ماض و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> فاعل، و<span class="hlt"><span class="qpc-hafs">﴿فيها﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿فجرنا﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿من العيون﴾</span></span> جار ومجرور متعلقان بمحذوف صفة لمفعول <span class="hlt"><span class="qpc-hafs">﴿فجرنا﴾</span></span> المحذوف، أي: ينابيع كائنة من العيون، فـ<span class="hlt"><span class="qpc-hafs">﴿من﴾</span></span> للتبعيض.</p></div>"
  36,35,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ليأكلوا من ثمره وما عملته أيديهم﴾</span></span>: تعليل لما تقدم، و<span class="hlt"><span class="qpc-hafs">﴿ليأكلوا﴾</span></span> اللام لام التعليل، و<span class="hlt"><span class="qpc-hafs">﴿يأكلوا﴾</span></span> فعل مضارع منصوب بأن مضمرة بعد اللام، وعلامة النصب حذف النون، والواو فاعل، والمصدر المؤول من أن والفعل مجرور بلام التعليل، والجار والمجرور من اللام والمصدر متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿جعلنا﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿من ثمره﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يأكلوا﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> اسم موصول مبني في محل جر عطفا على <span class="hlt"><span class="qpc-hafs">﴿ثمره﴾</span></span>. و<span class="hlt"><span class="qpc-hafs">﴿عملته﴾</span></span> فعل ماض والهاء مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿أيديهم﴾</span></span> فاعل، وجملة <span class="hlt"><span class="qpc-hafs">﴿عملته﴾</span></span> صلة الموصول لا محل لها من الإعراب. أو <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> نكرة موصوفة عطف على <span class="hlt"><span class="qpc-hafs">﴿من ثمره﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿عملته أيديهم﴾</span></span> صفة، أو <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> مصدرية، أي: ومن عمل أيديهم، أو <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> نافية.</p><p><span class="hlt"><span class="qpc-hafs">﴿أفلا يشكرون﴾</span></span>: الهمزة للاستفهام الإنكاري، والفاء عاطفة على محذوف يقتضيه السياق، أي: أيرون هذه النعم ويستمتعون بها فلا يشكرونها، و<span class="hlt"><span class="qpc-hafs">﴿لا﴾</span></span> نافية، و<span class="hlt"><span class="qpc-hafs">﴿يشكرون﴾</span></span> فعل مضارع مرفوع، والواو فاعل، والمفعول به محذوف.</p></div>"
  36,36,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿سبحان الذي خلق الأزواج كلها مما تنبت الأرض﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿سبحان﴾</span></span> نائب مفعول مطلق منصوب بفعل محذوف، والجملة مستأنفة لا محل لها من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿الذي﴾</span></span> مضاف إليه، و<span class="hlt"><span class="qpc-hafs">﴿خلق﴾</span></span> فعل ماض، والفاعل مستتر، و<span class="hlt"><span class="qpc-hafs">﴿الأزواج﴾</span></span> مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿كلها﴾</span></span> تأكيد، وجملة <span class="hlt"><span class="qpc-hafs">﴿خلق﴾</span></span> صلة الموصول لا محل لها من الإعراب. و<span class="hlt"><span class="qpc-hafs">﴿مما﴾</span></span> جار ومجرور متعلقان بمحذوف حال، وجملة <span class="hlt"><span class="qpc-hafs">﴿تنبت الأرض﴾</span></span> صلة الموصول لا محل لها من الإعراب. و<span class="hlt"><span class="qpc-hafs">﴿تنبت﴾</span></span>: فعل مضارع. و<span class="hlt"><span class="qpc-hafs">﴿الأرض﴾</span></span>: فاعل مرفوع بالضمة.</p><p><span class="hlt"><span class="qpc-hafs">﴿ومن أنفسهم ومما لا يعلمون﴾</span></span>: عطف على قوله: <span class="hlt"><span class="qpc-hafs">﴿مما تنبت الأرض﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿ومن أنفسهم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿خلق﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿ومما لا يعلمون﴾</span></span> عطف على ما سبق.</p></div>"
  36,37,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وآية لهم الليل نسلخ منه النهار﴾</span></span>: الواو عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿آية﴾</span></span> خبر مقدم، و<span class="hlt"><span class="qpc-hafs">﴿لهم﴾</span></span> جار ومجرور متعلقان بمحذوف صفة، و<span class="hlt"><span class="qpc-hafs">﴿الليل﴾</span></span> مبتدأ مؤخر، وجملة <span class="hlt"><span class="qpc-hafs">﴿نسلخ﴾</span></span> حالية، و<span class="hlt"><span class="qpc-hafs">﴿منه﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿نسلخ﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿النهار﴾</span></span> مفعول به.</p><p><span class="hlt"><span class="qpc-hafs">﴿فإذا هم مظلمون﴾</span></span>: الفاء عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿إذا﴾</span></span> فجائية، و<span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿مظلمون﴾</span></span> خبر.</p></div>"
  36,38,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿والشمس تجري لمستقر لها﴾</span></span>: الشمس مبتدأ، وجملة <span class="hlt"><span class="qpc-hafs">﴿تجري﴾</span></span> خبر، وهي فعل مضارع، والفاعل مستتر، و<span class="hlt"><span class="qpc-hafs">﴿لمستقر﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تجري﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿لها﴾</span></span> جار ومجرور متعلقان بمحذوف صفة.</p><p><span class="hlt"><span class="qpc-hafs">﴿ذلك تقدير العزيز العليم﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿ذلك﴾</span></span> مبتدأ، والإشارة إلى جريها، و<span class="hlt"><span class="qpc-hafs">﴿تقدير﴾</span></span> خبره، و<span class="hlt"><span class="qpc-hafs">﴿العزيز﴾</span></span> مضاف إليه، و<span class="hlt"><span class="qpc-hafs">﴿العليم﴾</span></span> صفة لـ<span class="hlt"><span class="qpc-hafs">﴿العزيز﴾</span></span>.</p></div>"
  36,39,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿والقمر قدرناه منازل حتى عاد كالعرجون القديم﴾</span></span>: الواو عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿القمر﴾</span></span> مفعول به لفعل محذوف يدل عليه الفعل المذكور بعده، فهو منصوب على الاشتغال. و<span class="hlt"><span class="qpc-hafs">﴿قدرناه﴾</span></span> فعل ماض، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> فاعل، والهاء مفعول به. وهي جملة <span class="hlt"><span class="qpc-hafs">﴿قدرناه﴾</span></span> تفسيرية لا محل لها من الإعرب. و<span class="hlt"><span class="qpc-hafs">﴿منازل﴾</span></span> حال بتقدير حذف مضاف، أي: ذا منازل، أو مفعول ثان لـ<span class="hlt"><span class="qpc-hafs">﴿قدرناه﴾</span></span>، أي: صيرناه منازل، أو ظرف، أي: قدرنا سيره في منازل، و<span class="hlt"><span class="qpc-hafs">﴿حتى﴾</span></span> حرف غاية وجر، و<span class="hlt"><span class="qpc-hafs">﴿عاد﴾</span></span> فعل ماض، وفاعله مستتر تقديره: هو، أي: القمر، أو <span class="hlt"><span class="qpc-hafs">﴿عاد﴾</span></span> فعل ناقص، والاسم مستتر، وكالعرجون الكاف اسم بمعنى مثل مبني على الفتح في محل رفع خبر <span class="hlt"><span class="qpc-hafs">﴿عاد﴾</span></span>، أو <span class="hlt"><span class="qpc-hafs">﴿عاد﴾</span></span> تامة، والكاف اسم بمعنى مثل مبني على الفتح في محل نصب حال، و<span class="hlt"><span class="qpc-hafs">﴿العرجون﴾</span></span> مضاف إليه، و<span class="hlt"><span class="qpc-hafs">﴿القديم﴾</span></span> صفة لـ<span class="hlt"><span class="qpc-hafs">﴿العرجون﴾</span></span>.</p></div>"
  36,40,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿لا الشمس ينبغي لها أن تدرك القمر﴾</span></span>: لا نافية، و<span class="hlt"><span class="qpc-hafs">﴿الشمس﴾</span></span> مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿ينبغي﴾</span></span> فعل مضارع، والفاعل مستتر تقديره: هي، وجملة <span class="hlt"><span class="qpc-hafs">﴿ينبغي﴾</span></span> خبر، و<span class="hlt"><span class="qpc-hafs">﴿لها﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿ينبغي﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿أن﴾</span></span> وما في حيزها فاعل <span class="hlt"><span class="qpc-hafs">﴿ينبغي﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿القمر﴾</span></span> مفعول به.</p><p><span class="hlt"><span class="qpc-hafs">﴿ولا الليل سابق النهار﴾</span></span>: عطف على ما تقدم، و<span class="hlt"><span class="qpc-hafs">﴿الليل﴾</span></span> مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿سابق﴾</span></span> خبر، و<span class="hlt"><span class="qpc-hafs">﴿النهار﴾</span></span> مضاف إليه.</p><p><span class="hlt"><span class="qpc-hafs">﴿وكل في فلك يسبحون﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿كل﴾</span></span> مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿في فلك﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يسبحون﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿يسبحون﴾</span></span> فعل مضارع، والواو فاعل، وجملة <span class="hlt"><span class="qpc-hafs">﴿يسبحون﴾</span></span> خبر.</p></div>"