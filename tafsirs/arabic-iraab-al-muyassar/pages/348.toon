quran[15]{c,v,t}:
  23,90,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿بل أتيناهم بالحق وإنهم لكاذبون﴾</span></span>: بل حرف إضراب وعطف، وأتيناهم فعل وفاعل ومفعول به، وبالحق حال، والواو حالية، وإن حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> اسمها، واللام المزحلقة، وكاذبون خبر إن.</p></div>"
  23,91,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ما اتخذ الله من ولد وما كان معه من إله﴾</span></span>: ما نافية، واتخذ الله فعل وفاعل، ومن حرف جر صلة، وولد مجرور لفظًا منصوب محلًّا لأنه مفعول به، والواو عاطفة، وما نافية، وكان فعل ماض ناقص، ومعه ظرف مكان متعلق بمحذوف خبر مقدم، ومن حرف جر صلة، و<span class="hlt"><span class="qpc-hafs">﴿إله﴾</span></span> مجرور لفظًا مرفوع محلًّا لأنه اسم كان.</p><p><span class="hlt"><span class="qpc-hafs">﴿إذا لذهب كل إله بما خلق﴾</span></span>: إذًا حرف جواب وجزاء مهمل، واللام واقعة في جواب الشرط <span class="hlt"><span class="qpc-hafs">﴿لو﴾</span></span> المقدر، وذهب كل فعل وفاعل، وإله مضاف إليه، والجملة لا محل لها من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿بما﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿ذهب﴾</span></span>، وجملة خلق صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> لا محل لها من الإعراب.</p><p><span class="hlt"><span class="qpc-hafs">﴿ولعلا بعضهم على بعض﴾</span></span>: عطف على ما تقدم.</p><p><span class="hlt"><span class="qpc-hafs">﴿سبحان الله عما يصفون﴾</span></span>: سبحان: نائب مفعول مطلق منصوب بفعل محذوف، ولفظ الجلالة مضاف إليه، و<span class="hlt"><span class="qpc-hafs">﴿عما﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿سبحان﴾</span></span>، وجملة يصفون صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> لا محل لها من الإعراب. أو <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> مصدرية، وهي وما بعدها في تأويل مصدر مجرور، والجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿سبحان﴾</span></span>.</p></div>"
  23,92,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿عالم الغيب والشهادة﴾</span></span>: عالم الغيب مجرور على البدلية من لفظ الجلالة، أو صفة له.</p><p><span class="hlt"><span class="qpc-hafs">﴿فتعالى عما يشركون﴾</span></span>: الفاء عاطفة، وتعالى فعل والفاعل مستتر، و<span class="hlt"><span class="qpc-hafs">﴿عما﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تعالى﴾</span></span>، وجملة يشركون صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> لا محل لها من الإعراب.</p></div>"
  23,93,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قل رب إما تريني ما يوعدون﴾</span></span>: رب منادى مضاف إلى ياء المتكلم المحذوفة، و<span class="hlt"><span class="qpc-hafs">﴿إما﴾</span></span> ادغمت إن الشرطية بما الصلة، وتريني فعل مضارع مبني على الفتح لاتصاله بنون التوكيد الثقيلة وهو في محل جزم فعل الشرط، والنون للوقاية، والياء مفعول به، وما مفعول به ثان، وجملة يوعدون صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> لا محل لها من الإعراب، والعائد محذوف، أي: يوعدون به من العذاب.</p></div>"
  23,94,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿رب فلا تجعلني في القوم الظالمين﴾</span></span>: رب منادى مضاف إلى ياء المتكلم المحذوفة، والفاء رابطة، ولا طلبية، وتجعلني فعل مضارع مجزوم بلا، والنون للوقاية، والياء مفعول به أول، و<span class="hlt"><span class="qpc-hafs">﴿في القوم﴾</span></span> جار ومجرور متعلقان بمحذوف مفعول به ثان، والظالمين صفة، والجملة في محل جزم جواب الشرط مقترنة بالفاء.</p></div>"
  23,95,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وإنا على أن نريك ما نعدهم لقادرون﴾</span></span>: الواو عاطفة، وإن حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> اسمها، و<span class="hlt"><span class="qpc-hafs">﴿على أن نريك﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿قادرون﴾</span></span>، وأن حرف مصدري ونصب، ونري مضارع منصوب بأن، والفاعل مستتر تقديره: نحن، والكاف مفعول به أول، وما مفعول به ثان، و<span class="hlt"><span class="qpc-hafs">﴿نعدهم﴾</span></span> فعل وفاعل مستتر ومفعول به، والجملة صلة الموصول لا محل لها من الإعراب، واللام المزحلقة، وهي لام الابتداء، وقادرون خبر إن.</p></div>"
  23,96,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ادفع بالتي هي أحسن السيئة نحن أعلم بما يصفون﴾</span></span>: كلام مستأنف لا محل له من الإعراب، وادفع فعل أمر، وفاعله مستتر تقديره: أنت، و<span class="hlt"><span class="qpc-hafs">﴿بالتي﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿ادفع﴾</span></span>، والتي نعت لمحذوف، أي: الخصلة، و<span class="hlt"><span class="qpc-hafs">﴿هي أحسن﴾</span></span> مبتدأ وخبر، وجملة <span class="hlt"><span class="qpc-hafs">﴿هي أحسن﴾</span></span> صلة <span class="hlt"><span class="qpc-hafs">﴿التي﴾</span></span> لا محل لها من الإعراب. والسيئة مفعول به، ونحن مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿أعلم﴾</span></span> خبر جملة، وجملة <span class="hlt"><span class="qpc-hafs">﴿نحن أعلم﴾</span></span> حالية، و<span class="hlt"><span class="qpc-hafs">﴿بما﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أعلم﴾</span></span>، وجملة يصفون صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> لا محل لها من الإعراب، أو ما مصدرية، أي: بوصفهم لك وسوء ذكرهم.</p></div>"
  23,97,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وقل رب أعوذ بك من همزات الشياطين﴾</span></span>: الواو استئنافية، والجملة بعدها مستأنفة لا محل لها من الإعراب، أو الواو عاطفة على ما تقدم، ورب منادى مضاف إلى ياء المتكلم المحذوفة، وأعوذ فعل مضارع، والفاعل مستتر تقديره: أنا، وبك جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أعوذ﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿من همزات﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أعوذ﴾</span></span>، والشياطين مضاف إليه، وجملة <span class="hlt"><span class="qpc-hafs">﴿رب أعوذ بك﴾</span></span> في محل نصب مقول القول.</p></div>"
  23,98,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وأعوذ بك رب أن يحضرون﴾</span></span>: عطف على ما تقدم، وأعوذ فعل مضارع، وفاعل مستتر تقديره: أنا، وبك جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أعوذ﴾</span></span>، ورب منادى مضاف إلى ياء المتكلم المحذوفة، وأن حرف مصدري ونصب، ويحضرون منصوب بأن وعلامة نصبه حذف النون، والنون للوقاية، والواو فاعل، وياء المتكلم المحذوفة في محل نصب مفعول به.</p></div>"
  23,99,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿حتى إذا جاء أحدهم الموت قال رب ارجعون﴾</span></span>: حتى حرف ابتداء، وإذا ظرف مستقبل متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿قال﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿جاء﴾</span></span> في محل جر مضاف إليه، وأحدهم مفعول به مقدم، والموت فاعل مؤخر، وجملة <span class="hlt"><span class="qpc-hafs">﴿قال﴾</span></span> لا محل لها من الإعراب، ورب منادى مضاف إلى ياء المتكلم المحذوفة، و<span class="hlt"><span class="qpc-hafs">﴿ارجعون﴾</span></span> فعل دعاء مبني على حذف النون، وواو الجماعة فاعل، والنون للوقاية، والياء المحذوفة لرسم لمصحف مفعول به.</p></div>"
  23,100,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿لعلي أعمل صالحا فيما تركت﴾</span></span>: لعل حرف ناسخ، والياء اسمها، وجملة <span class="hlt"><span class="qpc-hafs">﴿أعمل﴾</span></span> خبرها، وصالحا مفعول به لـ<span class="hlt"><span class="qpc-hafs">﴿أعمل﴾</span></span>، أو نائب عن المفعول المطلق، لأنه صفة المصدر، أي: عمل عملًا صالحًا. و<span class="hlt"><span class="qpc-hafs">﴿فيما﴾</span></span> جار ومجرور متعلقان بمحذوف صفة لـ<span class="hlt"><span class="qpc-hafs">﴿صالحا﴾</span></span>، أو متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أعمل﴾</span></span>، وجملة تركت صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> لا محل لها من الإعراب.</p><p><span class="hlt"><span class="qpc-hafs">﴿كلا إنها كلمة هو قائلها﴾</span></span>: كلا حرف ردع وزجر، وإن حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿ها﴾</span></span> اسمها، و<span class="hlt"><span class="qpc-hafs">﴿كلمة﴾</span></span> خبرها، و<span class="hlt"><span class="qpc-hafs">﴿هو﴾</span></span> مبتدأ، وقائلها خبر، والجملة الاسمية صفة لـ<span class="hlt"><span class="qpc-hafs">﴿كلمة﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿ومن ورائهم برزخ إلى يوم يبعثون﴾</span></span>: الواو عاطفة، أو حالية، و<span class="hlt"><span class="qpc-hafs">﴿من ورائهم﴾</span></span> جار ومجرور متعلقان بمحذوف خبر مقدم، وبرزخ مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿إلى يوم﴾</span></span> جار ومجرور متعلقان بمحذوف صفة لبرزخ، وجملة يبعثون في محل جر مضاف إليه.</p></div>"
  23,101,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فإذا نفخ في الصور فلا أنساب بينهم يومئذ ولا يتساءلون﴾</span></span>: الفاء استئنافية، والجملة بعدها مستأنفة لا محل لها من الإعراب، وإذا ظرف زمان للمستقبل، وجملة نفخ في محل جر مضاف إليه، و<span class="hlt"><span class="qpc-hafs">﴿في الصور﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿نفخ﴾</span></span>، والفاء رابطة لجواب إذا، ولا نافية للجنس، و<span class="hlt"><span class="qpc-hafs">﴿أنساب﴾</span></span> اسمها مبني على الفتح، و<span class="hlt"><span class="qpc-hafs">﴿بينهم﴾</span></span> ظرف متعلق بمحذوف خبر لا، و<span class="hlt"><span class="qpc-hafs">﴿يومئذ﴾</span></span>: يوم: ظرف زمان متعلق بالخبر المحذوف الذي تعلق به <span class="hlt"><span class="qpc-hafs">﴿بينهم﴾</span></span>، وإذٍ: اسم مبني على السكون المقدر لاشتغال المحل بتنوين العوض في محل جر مضاف إليه، والتنوين عوض عن جملة محذوفة، والتقدير: يوم إذ ينفخ في الصور. <span class="hlt"><span class="qpc-hafs">﴿ولا يتساءلون﴾</span></span> عطف على ما سبق، ويتساءلون فعل مضارع وفاعل.</p></div>"
  23,102,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فمن ثقلت موازينه﴾</span></span>: الفاء للتفريع، والجملة معطوفة، أو مستأنفة لا محل لها من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿من﴾</span></span> الشرطية مبتدأ، وثقلت فعل الشرط، وموازينه فاعل، والجملة في محل رفع خبر.</p><p><span class="hlt"><span class="qpc-hafs">﴿فأولئك هم المفلحون﴾</span></span>: الفاء رابطة للجواب، وأولئك مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> مبتدأ ثان، والمفلحون خبر <span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span>، والجملة خبر أولئك، أو <span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> ضمير فصل، والمفلحون خبر أولئك، وجملة <span class="hlt"><span class="qpc-hafs">﴿أولئك ...﴾</span></span> في محل جزم جواب الشرط.</p></div>"
  23,103,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ومن خفت موازينه﴾</span></span>: الواو عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿من﴾</span></span> شرطية مبتدأ، وخفت فعل الشرط، وموازينه فاعل، والجملة في محل رفع خبر.</p><p><span class="hlt"><span class="qpc-hafs">﴿فأولئك الذين خسروا أنفسهم في جهنم خالدون﴾</span></span>: الفاء رابطة للجواب، وأولئك مبتدأ، والذين خبر، و<span class="hlt"><span class="qpc-hafs">﴿خسروا أنفسهم﴾</span></span> فعل وفاعل ومفعول به، وجملة خسروا صلة الذين لا محل لها من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿في جهنم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿خالدون﴾</span></span>، وخالدون خبر لمبتدأ محذوف، أو خبر بعد خبر لأولئك.</p></div>"
  23,104,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿تلفح وجوههم النار﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿تلفح﴾</span></span> فعل مضارع مرفوع، و<span class="hlt"><span class="qpc-hafs">﴿وجوههم﴾</span></span> مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿النار﴾</span></span> فاعل، والجملة في محل نصب حال من الضمير في <span class="hlt"><span class="qpc-hafs">﴿خالدون﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿وهم فيها كالحون﴾</span></span>: الواو عاطفة، أو حالية، و<span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿فيها﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿كالحون﴾</span></span>، أو بمحذوف حال من <span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span>، وكالحون خبر.</p></div>"