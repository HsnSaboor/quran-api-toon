quran[24]{c,v,t}:
  37,1,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿والصافات صفا﴾</span></span>: الواو حرف قسم وجر، و<span class="hlt"><span class="qpc-hafs">﴿الصافات﴾</span></span> مجرور بواو القسم، والجار والمجرور متعلقان بفعل محذوف تقديره: أقسم، و<span class="hlt"><span class="qpc-hafs">﴿صفًا﴾</span></span> مفعول مطلق مؤكد.</p></div>"
  37,2,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فالزاجرات زجرا﴾</span></span>: الفاء حرف عطف، و<span class="hlt"><span class="qpc-hafs">﴿الزاجرات﴾</span></span> عطف على الصافات، و<span class="hlt"><span class="qpc-hafs">﴿زجرا﴾</span></span> مفعول مطلق.</p></div>"
  37,3,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فالتاليات ذكرا﴾</span></span>: الفاء عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿التاليات﴾</span></span> معطوفة على المقسم به في الآيات السابقة، و<span class="hlt"><span class="qpc-hafs">﴿ذكرًا﴾</span></span> نائب عن المفعول المطلق، لأنها في معنى التاليات، أو مفعول به لـ<span class="hlt"><span class="qpc-hafs">﴿التاليات﴾</span></span>.</p></div>"
  37,4,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إن إلهكم لواحد﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span> حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿إلهكم﴾</span></span> اسمها، واللام المزحلقة، و<span class="hlt"><span class="qpc-hafs">﴿واحد﴾</span></span> خبرها، والجملة لا محل لها من الإعراب، لأنها جواب القسم.</p></div>"
  37,5,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿رب السماوات والأرض وما بينهما ورب المشارق﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿رب السماوات﴾</span></span> بدل من <span class="hlt"><span class="qpc-hafs">﴿واحد﴾</span></span>، أو خبر ثان، أو خبر لمبتدأ محذوف، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> عطف على <span class="hlt"><span class="qpc-hafs">﴿السماوات﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿بينهما﴾</span></span> ظرف متعلق بمحذوف صلة الموصول، وجملة الصلة لا محل لها من الإعراب. و<span class="hlt"><span class="qpc-hafs">﴿رب المشارق﴾</span></span> عطف على <span class="hlt"><span class="qpc-hafs">﴿رب السماوات﴾</span></span>.</p></div>"
  37,6,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إنا زينا السماء الدنيا بزينة الكواكب﴾</span></span>: كلام مستأنف لا محل له من الإعراب، وإن حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> اسمها، و<span class="hlt"><span class="qpc-hafs">﴿زينا﴾</span></span> فعل ماض، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> فاعل، و<span class="hlt"><span class="qpc-hafs">﴿السماء﴾</span></span> مفعول به، وجملة <span class="hlt"><span class="qpc-hafs">﴿زينا﴾</span></span> خبر إن، و<span class="hlt"><span class="qpc-hafs">﴿الدنيا﴾</span></span> صفة، و<span class="hlt"><span class="qpc-hafs">﴿بزينة﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿زينا﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿الكواكب﴾</span></span> عطف بيان، أو بدل لـ<span class="hlt"><span class="qpc-hafs">﴿زينة﴾</span></span>.</p></div>"
  37,7,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وحفظا من كل شيطان مارد﴾</span></span>: الواو عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿حفظا﴾</span></span> مفعول مطلق لفعل محذوف و التقدير: حفظناها حفظًا، و<span class="hlt"><span class="qpc-hafs">﴿من كل شيطان﴾</span></span> جار ومجرور متعلقان بالفعل المحذوف، <span class="hlt"><span class="qpc-hafs">﴿مارد﴾</span></span> صفة لـ<span class="hlt"><span class="qpc-hafs">﴿شيطان﴾</span></span>.</p></div>"
  37,8,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿لا يسمعون إلى الملأ الأعلى ويقذفون من كل جانب﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿لا﴾</span></span> نافية، و<span class="hlt"><span class="qpc-hafs">﴿يسمعون﴾</span></span> فعل مضارع مرفوع، وعلامة رفعه ثبوت النون، والواو فاعل، و<span class="hlt"><span class="qpc-hafs">﴿إلى الملأ الأعلى﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يسمعون﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿الأعلى﴾</span></span> صفة للملأ، و<span class="hlt"><span class="qpc-hafs">﴿يقذفون﴾</span></span> الواو عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿يقذفون﴾</span></span> فعل مضارع مبني لما لم يسمَّ فاعله، والواو نائب فاعل، و<span class="hlt"><span class="qpc-hafs">﴿من كل جانب﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يقذفون﴾</span></span>.</p></div>"
  37,9,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿دحورا ولهم عذاب واصب﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿دحورًا﴾</span></span> مفعول من أجله، أي: يقذفون للدحور، أو حال، أي: مدحورين، أو نائب عن المفعول المطلق، لأنه بمعنى المصدر، والواو عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿لهم﴾</span></span> جار ومجرور متعلقان بمحذوف خبر مقدم، و<span class="hlt"><span class="qpc-hafs">﴿عذاب﴾</span></span> مبتدأ مؤخر، و<span class="hlt"><span class="qpc-hafs">﴿واصب﴾</span></span> نعت لعذاب.</p></div>"
  37,10,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إلا من خطف الخطفة فأتبعه شهاب ثاقب﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿إلا﴾</span></span> أداة حصر واستثناء، و<span class="hlt"><span class="qpc-hafs">﴿مَن﴾</span></span> في محل رفع بدل من الواو في <span class="hlt"><span class="qpc-hafs">﴿يسمعون﴾</span></span>، أو في محل نصب على الاستثناء، و<span class="hlt"><span class="qpc-hafs">﴿خطف﴾</span></span> فعل ماض، والفاعل مستتر تقديره: هو، و<span class="hlt"><span class="qpc-hafs">﴿الخطفة﴾</span></span> نائب عن المفعول المطلق منصوب، <span class="hlt"><span class="qpc-hafs">﴿فأتبعه﴾</span></span> الفاء عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿أتبعه﴾</span></span> فعل ماض، والهاء مفعول به مقدم، و<span class="hlt"><span class="qpc-hafs">﴿شهاب﴾</span></span> فاعل مؤخر، و<span class="hlt"><span class="qpc-hafs">﴿ثاقب﴾</span></span> نعت لـ<span class="hlt"><span class="qpc-hafs">﴿شهاب﴾</span></span>.</p></div>"
  37,11,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فاستفتهم أهم أشد خلقا أم من خلقنا﴾</span></span>: الفاء الفصيحة، و<span class="hlt"><span class="qpc-hafs">﴿استفتهم﴾</span></span> فعل أمر مبني على حذف حرف العلة، والفاعل مستتر وجوبًا، تقديره: أنت، والهاء مفعول به، والهمزة للاستفهام، و<span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿أشد﴾</span></span> خبر، و<span class="hlt"><span class="qpc-hafs">﴿خلقًا﴾</span></span> تمييز، و<span class="hlt"><span class="qpc-hafs">﴿أم﴾</span></span> حرف عطف، وهي متصلة، <span class="hlt"><span class="qpc-hafs">﴿من﴾</span></span> معطوفة على <span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿خلقنا﴾</span></span> فعل و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> فاعل، وهي صلة الموصول لا محل لها من الإعراب.</p><p><span class="hlt"><span class="qpc-hafs">﴿إنا خلقناهم من طين لازب﴾</span></span>: إن حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> اسمها، و<span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> مفعول به، وجملة <span class="hlt"><span class="qpc-hafs">﴿خلقناهم﴾</span></span> خبر إن، و<span class="hlt"><span class="qpc-hafs">﴿من طين﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿خلقناهم﴾</span></span>، ولازب نعت لـ<span class="hlt"><span class="qpc-hafs">﴿طين﴾</span></span>.</p></div>"
  37,12,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿بل عجبت ويسخرون﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿بل﴾</span></span> حرف للإضراب الانتقالي، و<span class="hlt"><span class="qpc-hafs">﴿عجبت﴾</span></span> فعل ماض، والتاء فاعل، والمتعلق محذوف، أي: من قدرة الله على هذه الخلائق العظيمة، <span class="hlt"><span class="qpc-hafs">﴿ويسخرون﴾</span></span> الواو حالية، و<span class="hlt"><span class="qpc-hafs">﴿يسخرون﴾</span></span> فعل مضارع، والواو فاعل، وجملة <span class="hlt"><span class="qpc-hafs">﴿يسخرون﴾</span></span> خبر لمبتدأ محذوف، أي: وهم يسخرون، والجملة منصوبة على الحال.</p></div>"
  37,13,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وإذا ذكروا لا يذكرون﴾</span></span>: الواو عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿إذا﴾</span></span> ظرف مستقبل متضمن معنى الشرط، وجملة <span class="hlt"><span class="qpc-hafs">﴿ذكروا﴾</span></span> في محل جر بإضافة الظرف إليها، و<span class="hlt"><span class="qpc-hafs">﴿ذكروا﴾</span></span> فعل ماض مبني لما لم يسمَّ فاعله، والواو نائب فاعل، و<span class="hlt"><span class="qpc-hafs">﴿لا﴾</span></span> نافية، و<span class="hlt"><span class="qpc-hafs">﴿يذكرون﴾</span></span> فعل مضارع مرفوع، والواو فاعل، وجملة <span class="hlt"><span class="qpc-hafs">﴿لا يذكرون﴾</span></span> لا محل لها من الإعراب، لأنها جواب شرط غير جازم.</p></div>"
  37,14,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وإذا رأوا آية يستسخرون﴾</span></span>: الواو عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿إذا﴾</span></span> ظرف مستقبل متضمن معنى الشرط، و<span class="hlt"><span class="qpc-hafs">﴿رأوا آية﴾</span></span> فعل، وفاعل، ومفعول به، وجملة <span class="hlt"><span class="qpc-hafs">﴿رأوا﴾</span></span> في محل جر بإضافة الظرف إليها، و<span class="hlt"><span class="qpc-hafs">﴿يستسخرون﴾</span></span> فعل مضارع مرفوع بثبوت النون، والواو فاعل، وجملة <span class="hlt"><span class="qpc-hafs">﴿يستسخرون﴾</span></span> لا محل لها من الإعراب، لأنها جواب شرط غير جازم.</p></div>"
  37,15,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وقالوا إن هذا إلا سحر مبين﴾</span></span>: الواو عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿قالوا﴾</span></span> فعل ماض، والواو فاعل، و<span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span> نافية، و<span class="hlt"><span class="qpc-hafs">﴿هذا﴾</span></span> مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿إلا﴾</span></span> أداة حصر، و<span class="hlt"><span class="qpc-hafs">﴿سحر﴾</span></span> خبر <span class="hlt"><span class="qpc-hafs">﴿هذا﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿مبين﴾</span></span> نعت، والجملة مقول القول.</p></div>"
  37,16,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿أئذا متنا وكنا ترابا وعظاما أئنا لمبعوثون﴾</span></span>: الجملة مقول قول محذوف أيضًا، أي: وقالوا منكرين للبعث، والهمزة للاستفهام الإنكاري، و<span class="hlt"><span class="qpc-hafs">﴿إذا﴾</span></span> ظرف مستقبل متضمن معنى الشرط، وجملة <span class="hlt"><span class="qpc-hafs">﴿متنا﴾</span></span> في محل جر بإضافة الظرف إليها، وهي فعل ماض و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> فاعل، و<span class="hlt"><span class="qpc-hafs">﴿كنا﴾</span></span> فعل ماض ناقص ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> اسمها، و<span class="hlt"><span class="qpc-hafs">﴿ترابًا﴾</span></span> خبرها، و<span class="hlt"><span class="qpc-hafs">﴿عظامًا﴾</span></span> عطف على <span class="hlt"><span class="qpc-hafs">﴿ترابًا﴾</span></span>، والهمزة للاستفهام الإنكاري أيضًا، و<span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span> حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> اسمها، واللام المزحلقة، و<span class="hlt"><span class="qpc-hafs">﴿مبعوثون﴾</span></span> خبرها.</p></div>"
  37,17,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿أوآباؤنا الأولون﴾</span></span>: الهمزة للاستفهام، والواو حرف عطف، و<span class="hlt"><span class="qpc-hafs">﴿آباؤنا﴾</span></span> معطوف على محل إن واسمها، أو على الضمير في <span class="hlt"><span class="qpc-hafs">﴿مبعوثون﴾</span></span>، أو <span class="hlt"><span class="qpc-hafs">﴿آباؤنا﴾</span></span> مبتدأ محذوف الخبر، والتقدير: أوآباؤنا يبعثون أيضًا، و<span class="hlt"><span class="qpc-hafs">﴿الأولون﴾</span></span> صفة.</p></div>"
  37,18,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قل نعم وأنتم داخرون﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿قل﴾</span></span> فعل أمر، وفاعله ضمير مستتر تقديره: أنت، و<span class="hlt"><span class="qpc-hafs">﴿نعم﴾</span></span> حرف جواب، والواو للحال، و<span class="hlt"><span class="qpc-hafs">﴿أنتم﴾</span></span> مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿داخرون﴾</span></span> خبر، وجملة <span class="hlt"><span class="qpc-hafs">﴿وأنتم داخرون﴾</span></span> منصوبة على الحال، والعامل فيها <span class="hlt"><span class="qpc-hafs">﴿نعم﴾</span></span> بالنظر لمعناها، أي: نعم تبعثون داخرين.</p></div>"
  37,19,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فإنما هي زجرة واحدة فإذا هم ينظرون﴾</span></span>: الفاء الفصيحة، و<span class="hlt"><span class="qpc-hafs">﴿إنما﴾</span></span> كافة ومكفوفة، و<span class="hlt"><span class="qpc-hafs">﴿هي﴾</span></span> مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿زجرة﴾</span></span> خبر، و<span class="hlt"><span class="qpc-hafs">﴿واحدة﴾</span></span> صفة، والفاء عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿إذا﴾</span></span> فجائية، و<span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿ينظرون﴾</span></span> فعل مضارع مرفوع، والواو فاعل، وجملة <span class="hlt"><span class="qpc-hafs">﴿ينظرون﴾</span></span> خبر، وهي فعل مضارع، والواو فاعل.</p></div>"
  37,20,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وقالوا يا ويلنا﴾</span></span>: الواو استئنافية، و<span class="hlt"><span class="qpc-hafs">﴿قالوا﴾</span></span> فعل ماض، والواو فاعل، و<span class="hlt"><span class="qpc-hafs">﴿يا﴾</span></span> حرف تنبيه، أو المنادى محذوف، و<span class="hlt"><span class="qpc-hafs">﴿ويلنا﴾</span></span> منادى مضاف منصوب. وجملة <span class="hlt"><span class="qpc-hafs">﴿وقالوا يا ويلنا﴾</span></span> مستأنفة لا محل لها من الإعراب.</p><p><span class="hlt"><span class="qpc-hafs">﴿هذا يوم الدين﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿هذا﴾</span></span> مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿يوم الدين﴾</span></span> خبر.</p></div>"
  37,21,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿هذا يوم الفصل الذي كنتم به تكذبون﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿هذا﴾</span></span> مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿يوم الفصل﴾</span></span> خبر، و<span class="hlt"><span class="qpc-hafs">﴿الذي﴾</span></span> صفة لـ<span class="hlt"><span class="qpc-hafs">﴿يوم﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿كنتم﴾</span></span>: كان فعل ماض ناقص، والتاء اسمها، و<span class="hlt"><span class="qpc-hafs">﴿به﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تكذبون﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿تكذبون﴾</span></span> فعل مضارع مرفوع، والواو فاعل، وجملة <span class="hlt"><span class="qpc-hafs">﴿تكذبون﴾</span></span> خبر <span class="hlt"><span class="qpc-hafs">﴿كان﴾</span></span>، والجملة مستأنفة لا محل لها من الإعراب، أو الجملة من تتمة مقولهم، وقوله: <span class="hlt"><span class="qpc-hafs">﴿تكذبون﴾</span></span> التفات من التكلم إلى الخطاب.</p></div>"
  37,22,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿احشروا الذين ظلموا وأزواجهم وما كانوا يعبدون﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿احشروا﴾</span></span> فعل أمر مبني على حذف النون، والواو فاعل، و<span class="hlt"><span class="qpc-hafs">﴿الذين﴾</span></span> مفعول به. وظلموا: فعل ماض، والواو فاعل. وجملة <span class="hlt"><span class="qpc-hafs">﴿ظلموا﴾</span></span> صلة الموصول لا محل لها من الإعراب. و<span class="hlt"><span class="qpc-hafs">﴿أزواجهم﴾</span></span> عطف على الموصول، أو مفعول معه، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> اسم موصول معطوف أيضًا، أو مفعول معه، وكانوا كان فعل ناقص ناسخ، والواو اسمها، وجملة <span class="hlt"><span class="qpc-hafs">﴿يعبدون﴾</span></span> خبرها، وهي فعل مضارع مرفوع، والواو فاعل.</p></div>"
  37,23,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿من دون الله فاهدوهم إلى صراط الجحيم﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿من دون الله﴾</span></span> جار ومجرور متعلقان بمحذوف حال، والفاء عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿اهدوهم﴾</span></span> فعل أمر، والواو فاعل، و<span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿إلى صراط الجحيم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿اهدوهم﴾</span></span>.</p></div>"
  37,24,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وقفوهم إنهم مسئولون﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿قفوهم﴾</span></span> عطف على ما تقدم، وهو فعل أمر مبني على حذف النون، والواو فاعل، و<span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿إنهم﴾</span></span> إن حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> اسمها، و<span class="hlt"><span class="qpc-hafs">﴿مسئولون﴾</span></span> خبرها، والجملة تعليل للأمر.</p></div>"