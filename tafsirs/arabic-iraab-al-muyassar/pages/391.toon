quran[7]{c,v,t}:
  28,44,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وما كنت بجانب الغربي إذ قضينا إلى موسى الأمر وما كنت من الشاهدين﴾</span></span>: الواو عاطفة، أو استئنافية، وما نافية، وكنتَ: كان فعل ماض ناقص، والتاء اسمها، و<span class="hlt"><span class="qpc-hafs">﴿بجانب﴾</span></span> جار ومجرور متعلقان بمحذوف خبر <span class="hlt"><span class="qpc-hafs">﴿كان﴾</span></span>، والغربي: مضاف إليه مجرور بالكسرة، وإذ: ظرف لما مضى متعلق بالخبر المحذوف الذي تعلق به الجار والمجرور، وقضينا: فعل وفاعل، وجملة قضينا مجرورة بإضافة الظرف إليها، والأمر: مفعول به، والواو: حرف عطف، وجملة <span class="hlt"><span class="qpc-hafs">﴿وما كنت...﴾</span></span> معطوفة، مستأنفة لا محل لها من الإعراب، وما: نافية، وكنت: كان فعل ماض ناقص، والتاء اسمها، ومن الشاهدين: جار ومجرور متعلقان بمحذوف خبر كنت.</p></div>"
  28,45,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ولكنا أنشأنا قرونا فتطاول عليهم العمر﴾</span></span>: الواو عاطفة، ولكن حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> اسمها، وجملة أنشأنا خبرها، ونا فاعل، وقرونًا مفعول به، فتطاول عطف على أنشأنا، و<span class="hlt"><span class="qpc-hafs">﴿عليهم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تطاول﴾</span></span>، والعمر فاعل.</p><p><span class="hlt"><span class="qpc-hafs">﴿وما كنت ثاويا في أهل مدين تتلو عليهم آياتنا ولكنا كنا مرسلين﴾</span></span>: الواو عاطفة، وما نافية، وكنت: كان فعل ماض ناقص، والتاء اسمها، وثاويًا خبرها، و<span class="hlt"><span class="qpc-hafs">﴿في أهل﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿ثاويًا﴾</span></span>، ومدين: مضاف إليه، وجملة <span class="hlt"><span class="qpc-hafs">﴿تتلو﴾</span></span> في موضع نصب خبر ثان لكنت، أو حال من الضمير في <span class="hlt"><span class="qpc-hafs">﴿ثاويًا﴾</span></span>، ولكنا الواو حالية، أو عاطفة، ولكن حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> اسمها، وجملة كنا خبرها، وكان فعل ماض ناقص، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> اسمها، ومرسلين خبرها.</p></div>"
  28,46,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وما كنت بجانب الطور إذ نادينا ولكن رحمة من ربك﴾</span></span>: الواو عاطفة، وما نافية، وكان فعل ماض ناقص، والتاء اسمها، و<span class="hlt"><span class="qpc-hafs">﴿بجانب﴾</span></span> جار ومجرور متعلقان بمحذوف خبر كنت، والطور مضاف إليه، و<span class="hlt"><span class="qpc-hafs">﴿إذ﴾</span></span> ظرف لما مضى متعلق بخبر <span class="hlt"><span class="qpc-hafs">﴿كنت﴾</span></span> المحذوف الذي تعلق به الجار والمجرور، وجملة <span class="hlt"><span class="qpc-hafs">﴿نادينا﴾</span></span> في محل جر بإضافة الظرف إليها، <span class="hlt"><span class="qpc-hafs">﴿ولكن﴾</span></span> الواو عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿لكن﴾</span></span> حرف استدراك مهمل، و<span class="hlt"><span class="qpc-hafs">﴿رحمة﴾</span></span> مفعول لأجله، و<span class="hlt"><span class="qpc-hafs">﴿من ربك﴾</span></span> جار ومجرور متعلقان بمحذوف صفة لـ<span class="hlt"><span class="qpc-hafs">﴿رحمة﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿لتنذر قوما ما أتاهم من نذير من قبلك لعلهم يتذكرون﴾</span></span>: لتنذر اللام للتعليل، وتنذر فعل مضارع منصوب بأن مضمرة بعد لام التعليل، والمصدر المؤول من أن والفعل مجرور باللام، والجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أرسلناك﴾</span></span> المحذوفة، وقومًا: مفعول به، وجملة <span class="hlt"><span class="qpc-hafs">﴿ما أتاهم﴾</span></span> صفة لـ<span class="hlt"><span class="qpc-hafs">﴿قومًا﴾</span></span>، وما نافية، وأتاهم فعل ماض، ومفعول به، ومن حرف جر صلة، ونذير مجرور لفظًا، مرفوع محلًّا على أنه فاعل، ومن قبلك: جار ومجرور متعلقان بمحذوف صفة لنذير، ولعل حرف ناسخ للترجي، و<span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> اسمها، وجملة يتذكرون خبرها.</p></div>"
  28,47,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ولولا أن تصيبهم مصيبة بما قدمت أيديهم﴾</span></span>: الواو عاطفة، ولولا حرف امتناع لوجود، وأن وما في حيزها مبتدأ خبره محذوف، وجوابها محذوف، تقديره: لما أرسلنا رسولًا، ومصيبة فاعل، وبما: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تصيبهم﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿قدمت﴾</span></span> صلة الموصول لا محل لها من الإعراب.</p><p><span class="hlt"><span class="qpc-hafs">﴿فيقولوا ربنا لولا أرسلت إلينا رسولا فنتبع آياتك ونكون من المؤمنين﴾</span></span>: الفاء عاطفة، ويقولوا عطف على أن تصيبهم، وربنا منادى مضاف، ولولا تحضيضية بمعنى هلا، و<span class="hlt"><span class="qpc-hafs">﴿أرسلت﴾</span></span> فعل وفاعل، وإلينا: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أرسلت﴾</span></span>، ورسولًا مفعول به، فنتبع الفاء فاء السببية، ونتبع فعل مضارع منصوب بأن مضمرة بعد فاء السببية، والمصدر المؤول من أن والفعل معطوف على مصدر مأخوذ من الكلام السابق أي: هلا ثمة إرسال فاتباع الآيات. وفاعل نتبع مستتر، تقديره: نحن، وآياتك: مفعول به، ونكون: عطف على نتبع، واسم نكون ضمير مستتر، تقديره: نحن، و<span class="hlt"><span class="qpc-hafs">﴿من المؤمنين﴾</span></span> جار ومجرور متعلقان بمحذوف خبر.</p></div>"
  28,48,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فلما جاءهم الحق من عندنا قالوا لولا أوتي مثل ما أوتي موسى﴾</span></span>: الفاء عاطفة، ولما حينية، أو رابطة، و<span class="hlt"><span class="qpc-hafs">﴿جاءهم الحق﴾</span></span>: فعل ماض، ومفعول به مقدم، وفاعل مؤخر، ومن عندنا: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿جاءهم﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿قالوا﴾</span></span> لا محل لها من الإعراب، لأنها جواب لما، ولولا حرف تحضيض، و<span class="hlt"><span class="qpc-hafs">﴿أوتي﴾</span></span> فعل ماض، ونائب الفاعل مستتر، تقديره: هو، و<span class="hlt"><span class="qpc-hafs">﴿مثل﴾</span></span> مفعول به ثان، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> اسم موصول مضاف إليه، وجملة <span class="hlt"><span class="qpc-hafs">﴿أوتي﴾</span></span> صلة الموصول لا محل لها من الإعراب. وموسى: نائب فاعل.</p><p><span class="hlt"><span class="qpc-hafs">﴿أولم يكفروا بما أوتي موسى من قبل﴾</span></span>: الهمزة للاستفهام، والواو عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿لم﴾</span></span> حرف نفي وقلب وجزم، ويكفروا: فعل مضارع مجزوم بلم، وبما: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يكفروا﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿أوتي موسى﴾</span></span> صلة الموصول لا محل لها من الإعراب. ومن قبل: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يكفروا﴾</span></span>، أو بـ<span class="hlt"><span class="qpc-hafs">﴿أوتي﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿قالوا سحران تظاهرا وقالوا إنا بكل كافرون﴾</span></span>: جملة استئنافية لا محل لها من الإعراب. وسحران: خبر لمبتدأ محذوف، أي: هما ساحران. والجملة من المبتدأ والخبر في محل نصب مقول القول. وجملة تظاهرا نعت لـ<span class="hlt"><span class="qpc-hafs">﴿سحران﴾</span></span>، وقالوا: الواو عاطفة، وقالوا: فعل ماض، والواو ضمير مبني في محل رفع فاعل، وإنا: إن حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> اسمها، وبكل: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿كافرون﴾</span></span>، وكافرون خبر إن، والجملة مقول القول.</p></div>"
  28,49,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قل فأتوا بكتاب من عند الله هو أهدى منهما أتبعه إن كنتم صادقين﴾</span></span>: قل فعل أمر، وفاعله مستتر، تقديره: أنت، والفاء واقعة في جواب شرط مقدر، وفعل الأمر مبني على حذف النون، والواو في محل رفع فاعل، وبكتاب: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿فأتوا﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿من عند﴾</span></span> جار ومجرور متعلقان بمحذوف صفة، ولفظ الجلالة مضاف إليه، و<span class="hlt"><span class="qpc-hafs">﴿هو﴾</span></span>: مبتدأ، وأهدى: خبر، ومنهما: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أهدى﴾</span></span>، والجملة صفة ثانية لكتاب، و<span class="hlt"><span class="qpc-hafs">﴿أتبعه﴾</span></span>: فعل مضارع مجزوم، لأنه جواب الأمر، والفاعل مستتر، والهاء مفعول به، وإن شرطية، و<span class="hlt"><span class="qpc-hafs">﴿كنتم﴾</span></span>: فعل ماض ناقص في محل جزم فعل الشرط، والتاء اسمها، وصادقين خبرها، وجواب الشرط محذوف، دل عليه ما قبله، أي: فأتوا.</p></div>"
  28,50,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فإن لم يستجيبوا لك فاعلم أنما يتبعون أهواءهم﴾</span></span>: الفاء عاطفة، وإن شرطية، ولم حرف نفي وقلب وجزم، ويستجيبوا فعل مضارع مجزوم بلم، والواو فاعل، ولك: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يستجيبوا﴾</span></span>، والفاء رابطة لجواب الشرط، واعلم فعل أمر، وأنما كافة ومكفوفة، ويتبعون: فعل مضارع مرفوع، والواو في محل رفع فاعل، وأهواءهم مفعول به، وأنما وما في حيزها سدت مسد مفعولي اعلم.</p><p><span class="hlt"><span class="qpc-hafs">﴿ومن أضل ممن اتبع هواه بغير هدى من الله إن الله لا يهدي القوم الظالمين﴾</span></span>: الواو عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿مَن﴾</span></span> اسم استفهام معناه النفي والإنكار في محل رفع مبتدأ، وأضل خبره، وممن: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أضل﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿اتبع هواه﴾</span></span> صلة <span class="hlt"><span class="qpc-hafs">﴿مَن﴾</span></span> لا محل لها من الإعراب. و<span class="hlt"><span class="qpc-hafs">﴿بغير هدى﴾</span></span> جار ومجرور متعلقان بمحذوف حال، و<span class="hlt"><span class="qpc-hafs">﴿من الله﴾</span></span> جار ومجرور متعلقان بمحذوف صفة لـ<span class="hlt"><span class="qpc-hafs">﴿هدى﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿إن الله﴾</span></span> تعليل لما تقدم، وإن حرف ناسخ، ولفظ الجلالة اسمها، وجملة <span class="hlt"><span class="qpc-hafs">﴿لا يهدي القوم الظالمين﴾</span></span> خبرها.</p></div>"