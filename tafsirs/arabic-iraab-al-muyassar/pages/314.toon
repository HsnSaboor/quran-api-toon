quran[14]{c,v,t}:
  20,38,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إذ أوحينا إلى أمك ما يوحى﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿إذ﴾</span></span> ظرف للزمن الماضي متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿مننا﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿أوحينا﴾</span></span> في محل جر مضاف إليه، وإلى أمك جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أوحينا﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> مصدرية مؤولة مع ما بعدها بمصدر مفعول مطلق، أو موصولة فهي مفعول به، وجملة <span class="hlt"><span class="qpc-hafs">﴿يوحى﴾</span></span> صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> لا محل لها من الإعراب.</p></div>"
  20,39,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿أن اقذفيه في التابوت﴾</span></span>: أن تفسيرية، والجملة بعدها تفسيرية لا محل لها من الإعراب. واقذفيه فعل أمر، وفاعل، ومفعول به، وفي التابوت جار ومجرور متعلقان باقذفيه.</p><p><span class="hlt"><span class="qpc-hafs">﴿فاقذفيه في اليم﴾</span></span>: عطف على <span class="hlt"><span class="qpc-hafs">﴿اقذفيه في التابوت﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿فليلقه اليم بالساحل﴾</span></span>: الفاء عاطفة، واللام لام الأمر، ويلقه فعل مضارع مجزوم بلام الأمر، وعلامة جزمه حذف حرف العلة، والهاء مفعول به، واليم فاعل، وهذا أمر معناه الخبر، وبالساحل جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يلقه﴾</span></span>، أو بمحذوف حال، أي: متلبسًا به.</p><p><span class="hlt"><span class="qpc-hafs">﴿يأخذه عدو لي وعدو له﴾</span></span>: يأخذه جواب الطلب، والهاء مفعول، وعدو فاعل، ولي صفة، <span class="hlt"><span class="qpc-hafs">﴿وعدو له﴾</span></span> عطف على <span class="hlt"><span class="qpc-hafs">﴿عدو لي﴾</span></span> .</p><p><span class="hlt"><span class="qpc-hafs">﴿وألقيت عليك محبة مني ولتصنع على عيني﴾</span></span>: الواو حرف عطف، وألقيت فعل وفاعل، وعليك جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿ألقيت﴾</span></span>، ومحبة مفعول به، ومني صفة لمحبة، أو متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿ألقيت﴾</span></span>، ولتصنع: عطف على محذوف، أي: ليحبك الناس، ولتصنع: اللام للتعليل، وتصنع فعل مضارع مبني لما لم يسمَّ فاعله، منصوب بأن مضمرة بعد اللام، والمصدر المؤول من أن والفعل مجرور باللام، والجار والمجرور متعلقان بمضمر تقديره: ولتصنع فعلتُ ذلك، و<span class="hlt"><span class="qpc-hafs">﴿على عيني﴾</span></span> جار ومجرور متعلقان بمحذوف حال.</p></div>"
  20,40,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إذ تمشي أختك فتقول هل أدلكم على من يكفله﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿إذ﴾</span></span> ظرف متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿ألقيت﴾</span></span>، أو بـ<span class="hlt"><span class="qpc-hafs">﴿تصنع﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿تمشي﴾</span></span> في محل جر مضاف إليه، وأختك فاعل، فتقول: عطف على تمشي، وهل حرف استفهام، وأدلكم فعل مضارع، وفاعله مستتر تقديره: أنا، والكاف مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿على من﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أدلكم﴾</span></span>، وجملة يكفله صلة <span class="hlt"><span class="qpc-hafs">﴿من﴾</span></span> لا محل لها من الإعراب.</p><p><span class="hlt"><span class="qpc-hafs">﴿فرجعناك إلى أمك كي تقر عينها ولا تحزن﴾</span></span>: الفاء عاطفة على محذوف تقديره: فأجيبت إلى طلبها، ورجعناك فعل، وفاعل، ومفعول به، و<span class="hlt"><span class="qpc-hafs">﴿إلى أمك﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿رجعناك﴾</span></span>، وكي حرف ناصب، وتَقَر منصوب بـ<span class="hlt"><span class="qpc-hafs">﴿كي﴾</span></span>، وعينها فاعل، ولا تحزن عطف على <span class="hlt"><span class="qpc-hafs">﴿كي تقر﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿وقتلت نفسا فنجيناك من الغم وفتناك فتونا﴾</span></span>: الواو استئنافية، وقتلت فعل وفاعل، ونفسًا مفعول قتل، وجملة <span class="hlt"><span class="qpc-hafs">﴿وقتلت نفسا﴾</span></span> مستأنفة لا محل لها من الإعراب، فنجيناك: الفاء عاطفة، ونجيناك فعل، وفاعل، ومفعول به، ومن الغم جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿نجيناك﴾</span></span>، وفتناك فعل، وفاعل، ومفعول به، وفتونًا مفعول مطلق.</p><p><span class="hlt"><span class="qpc-hafs">﴿فلبثت سنين في أهل مدين ثم جئت على قدر يا موسى﴾</span></span>: الفاء عاطفة، ولبثت فعل وفاعل، وسنين ظرف زمان متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿لبثت﴾</span></span>، وفي أهل مدين جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿لبثت﴾</span></span>، ومدين مضاف إليه، ممنوع من الصرف للعملية والتأنيث، ثم حرف عطف، وجئت فعل وفاعل، وعلى قدر جار ومجرور متعلقان بمحذوف حال.</p></div>"
  20,41,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿واصطنعتك لنفسي﴾</span></span>: فعل ماض، وفاعل، ومفعول به، ولنفسي جار ومجرور متعلقان بالفعل.</p></div>"
  20,42,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿اذهب أنت وأخوك بآياتي ولا تنيا في ذكري﴾</span></span>: اذهب فعل أمر، وفاعله مستتر تقديره: أنت، وأنت ضمير منفصل تأكيد للضمير المستتر، وأخوك عطف على الضمير المرفوع، وعلامة رفعه الواو، والكاف مضاف إليه، وبآياتي  الباء للمصاحبة وبآياتي جار ومجرور متعلقان بمحذوف حال، أي: مصحوبين بآياتي، والواو حرف عطف، ولا ناهية، وتنيا فعل مضارع مجزوم بلا الناهية، والألف فاعل، وفي ذكري جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تنيا﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿في﴾</span></span> على حقيقتها من الظرفية، وقيل: <span class="hlt"><span class="qpc-hafs">﴿في﴾</span></span> هنا بمعنى عن، أي: عن عبادتي.</p></div>"
  20,43,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿اذهبا إلى فرعون إنه طغى﴾</span></span>: اذهبا فعل وفاعل، وإلى فرعون جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿اذهبا﴾</span></span>، وإن حرف ناسخ، والهاء اسمها، وجملة طغى خبرها.</p></div>"
  20,44,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فقولا له قولا لينا لعله يتذكر أو يخشى﴾</span></span>: الفاء عاطفة، وقولا فعل أمر وفاعل، و<span class="hlt"><span class="qpc-hafs">﴿له﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿قولا﴾</span></span>، وقولًا مفعول به، أو مفعول مطلق منصوب بالفتحة. ولينًا صفة، ولعل حرف ناسخ، والهاء اسمها، وجملة يتذكر خبرها، أو حرف عطف، ويخشى عطف على يتذكر.</p></div>"
  20,45,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قالا ربنا إننا نخاف أن يفرط علينا أو أن يطغى﴾</span></span>: قالا فعل ماض وفاعل، وربنا منادى مضاف، وإن حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> اسمها، وجملة نخاف خبر إن، وأن وما في حيزها مفعول نخاف، وعلينا جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يفرط﴾</span></span>، أو حرف عطف، <span class="hlt"><span class="qpc-hafs">﴿أن يطغى﴾</span></span> عطف على <span class="hlt"><span class="qpc-hafs">﴿أن يفرط﴾</span></span>.</p></div>"
  20,46,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قال لا تخافا إنني معكما أسمع وأرى﴾</span></span>: لا ناهية، وتخافا فعل مضارع مجزوم بلا، والألف فاعل، وجملة لا تخافا مقول القول، وجملة إنني معكما تعليلية، وإن حرف ناسخ، والياء اسمها، والظرف متعلق بمحذوف خبرها، وجملة أسمع خبر ثان، أو حالية، وأرى عطف على أسمع.</p></div>"
  20,47,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فأتياه فقولا إنا رسولا ربك﴾</span></span>: فأتياه: الفاء هي الفصيحة، وأتياه فعل أمر، وفاعل، ومفعول به، فقولا عطف على فأتياه، وإن حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> اسمها، ورسولا خبرها، وربك مضاف إليه.</p><p><span class="hlt"><span class="qpc-hafs">﴿فأرسل معنا بني إسرائيل ولا تعذبهم﴾</span></span>: الفاء هي الفصيحة، وأرسل فعل أمر، والفاعل مستتر تقديره: أنت، ومعنا ظرف مكان متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿أرسل﴾</span></span>، وبني إسرائيل مفعول به، ولا تعذبهم: لا ناهية، وتعذبهم مجزوم بلا، والهاء مفعول به.</p><p><span class="hlt"><span class="qpc-hafs">﴿قد جئناك بآية من ربك﴾</span></span>: قد حرف تحقيق، وجئناك فعل ماض، وفاعل، ومفعول به، وبآية جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿جئناك﴾</span></span>، ومن ربك صفة لآية، وجملة <span class="hlt"><span class="qpc-hafs">﴿قد جئناك...﴾</span></span> مستأنفة لا محل لها من الإعراب.</p><p><span class="hlt"><span class="qpc-hafs">﴿والسلام على من اتبع الهدى﴾</span></span>: الواو استئنافية، والسلام مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿على من اتبع الهدى﴾</span></span> الجار والمجرور متعلقان بمحذوف خبر، والجملة مستأنفة لا محل لها من الإعراب.</p></div>"
  20,48,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إنا قد أوحي إلينا أن العذاب على من كذب وتولى﴾</span></span>: إن حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> اسمها، وجملة قد أوحي خبرها، وإلينا جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أوحي﴾</span></span>، وأن وما في حيزها في تأويل مصدر نائب فاعل لـ<span class="hlt"><span class="qpc-hafs">﴿أوحي﴾</span></span>، وأن حرف ناسخ، والعذاب اسم أن، و<span class="hlt"><span class="qpc-hafs">﴿على من﴾</span></span> جار ومجرور متعلقان بمحذوف خبر أن، وجملة كذب صلة <span class="hlt"><span class="qpc-hafs">﴿من﴾</span></span> لا محل لها من الإعراب، وتولى عطف على كذب.</p></div>"
  20,49,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قال فمن ربكما يا موسى﴾</span></span>: الفاء عاطفة على مقدر، أي: فأتياه وقالا جميع ما ذكر، و<span class="hlt"><span class="qpc-hafs">﴿مَن﴾</span></span> اسم استفهام مبتدأ، وربكما خبر، والجملة مقول القول.</p></div>"
  20,50,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قال ربنا الذي أعطى كل شيء خلقه ثم هدى﴾</span></span>: ربنا مبتدأ، والذي خبره، وجملة أعطى صلة الذي لا محل لها من الإعراب، وكل شيء مفعول به أول، وخلقه مفعول به ثان، وقيل: خلقه أول مفعولي أعطى، وكل شيء ثانيهما، ثم هدى عطف على أعطى.</p></div>"
  20,51,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قال فما بال القرون الأولى﴾</span></span>: الفاء عاطفة، وما استفهام مبتدأ، وبال خبر، والقرون مضاف إليه، والأولى صفة.</p></div>"