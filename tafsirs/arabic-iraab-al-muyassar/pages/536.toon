quran[26]{c,v,t}:
  56,51,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ثم إنكم أيها الضالون المكذبون﴾</span></span>: ثم حرف عطف للترتيب مع التراخي، داخل في حيز القول، وإن حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿كم﴾</span></span> اسمها، و<span class="hlt"><span class="qpc-hafs">﴿أي﴾</span></span> منادى نكرة مقصودة، والضالون صفة لـ<span class="hlt"><span class="qpc-hafs">﴿أي﴾</span></span>، والمكذبون نعت لـ<span class="hlt"><span class="qpc-hafs">﴿الضالون﴾</span></span>.</p></div>"
  56,52,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿لآكلون من شجر من زقوم﴾</span></span>: اللام المزحلقة، وآكلون خبر إنكم، ومن شجر جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿آكلون﴾</span></span>، ومن زقوم بدل من قوله من شجر، أو عطف بيان، أو نعت.</p></div>"
  56,53,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فمالئون منها البطون﴾</span></span>: الفاء حرف عطف، ومالئون معطوف على <span class="hlt"><span class="qpc-hafs">﴿آكلون﴾</span></span>، ومنها جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿مالئون﴾</span></span>، والبطون مفعول لاسم الفاعل.</p></div>"
  56,54,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فشاربون عليه من الحميم﴾</span></span>: الفاء حرف عطف، وشاربون معطوف على <span class="hlt"><span class="qpc-hafs">﴿آكلون﴾</span></span>، وعليه جار ومجرور متعلقان بمحذوف حال، ومن الحميم جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿شاربون﴾</span></span>.</p></div>"
  56,55,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فشاربون شرب الهيم﴾</span></span>: الفاء حرف عطف، وشاربون عطف على ما تقدم، وشرب مفعول مطلق، والهيم مضاف إليه.</p></div>"
  56,56,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿هذا نزلهم يوم الدين﴾</span></span>: هذا مبتدأ، ونزلهم خبر، ويوم الدين الظرف متعلق بمحذوف حال.</p></div>"
  56,57,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿نحن خلقناكم فلولا تصدقون﴾</span></span>: نحن مبتدأ، وجملة خلقناكم خبر، والفاء حرف عطف، ولولا حرف تحضيض، وتصدقون فعل مضارع مرفوع، والواو فاعله.</p></div>"
  56,58,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿أفرأيتم ما تمنون﴾</span></span>: الهمزة للاستفهام الإنكاري، والفاء عاطفة، ورأيتم فعل ماضٍ وفاعله، وما اسم موصول بمعنى الذي مفعول رأيتم الأول، وجملة تمنون صلة الموصول لا محل لها من الإعراب.</p></div>"
  56,59,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿أأنتم تخلقونه أم نحن الخالقون﴾</span></span>: الهمزة للاستفهام، وضمير الخطاب في محل رفع مبتدأ، وتخلقون: فعل مضارع مرفوع بثبوت النون والواو في محل رفع فاعل، والهاء ضمير في محل نصب مفعول به، والجملة الاسمية في محل نصب مفعول ثانٍ للفعل رأيتم، و<span class="hlt"><span class="qpc-hafs">﴿أم﴾</span></span>: قيل أنها منقطعة لأن ما بعدها جملة، فالمعنى: <span class="hlt"><span class="qpc-hafs">﴿بل أنحن الخالقون﴾</span></span> على أن الاستفهام للتقرير، وقيل: إنها متصلة، ونحن ضمير في محل رفع مبتدأ، والخالقون خبر مرفوع بالواو، والجملة لا محل لها من الإعراب، لأنها استئنافية.</p></div>"
  56,60,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿نحن قدرنا بينكم الموت وما نحن بمسبوقين﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿نحن﴾</span></span>: مبتدأ. وجملة <span class="hlt"><span class="qpc-hafs">﴿قدرنا﴾</span></span>: خبر. و<span class="hlt"><span class="qpc-hafs">﴿قدرنا﴾</span></span>: فعل وفاعل. و<span class="hlt"><span class="qpc-hafs">﴿بينكم﴾</span></span>: ظرف متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿قدرنا﴾</span></span>، والضمير المتصل مضاف إليه. و<span class="hlt"><span class="qpc-hafs">﴿الموت﴾</span></span>: مفعول به. <span class="hlt"><span class="qpc-hafs">﴿وما﴾</span></span>: الواو عاطفة، أو اعتراضية. و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span>: نافية حجازية تعمل عمل ليس. و<span class="hlt"><span class="qpc-hafs">﴿نحن﴾</span></span>: اسم ما. و<span class="hlt"><span class="qpc-hafs">﴿بمسبوقين﴾</span></span>: الباء حرف جر صلة، و<span class="hlt"><span class="qpc-hafs">﴿مسبوقين﴾</span></span> خبر <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> الحجازية منصوب محلا مجرور بالباء لفظًا. وجملة <span class="hlt"><span class="qpc-hafs">﴿ما نحن بمسبوقين﴾</span></span>: معطوفة على الاستئنافية قبلها، أو اعتراضية، وعلى كلا الوجهين لا محل لها من الإعراب.</p></div>"
  56,61,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿على أن نبدل أمثالكم وننشئكم في ما لا تعلمون﴾</span></span>: على: حرف جر، و<span class="hlt"><span class="qpc-hafs">﴿أن نبدل﴾</span></span>: في تأويل مصدر مجرور بـ<span class="hlt"><span class="qpc-hafs">﴿على﴾</span></span>، والجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿مسبوقين﴾</span></span>، أو متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿قدرنا بينكم﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿وما نحن بمسبوقين﴾</span></span>: اعتراضية. <span class="hlt"><span class="qpc-hafs">﴿وننشئكم﴾</span></span>: عطف على <span class="hlt"><span class="qpc-hafs">﴿نبدل﴾</span></span>، وفيما: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿ننشئكم﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿لا تعلمون﴾</span></span>: صلة الموصول لا محل لها من الإعراب.</p></div>"
  56,62,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ولقد علمتم النشأة الأولى فلولا تذكرون﴾</span></span>: الواو استئنافية، واللام واقعة في جواب قسم مقدر، وقد حرف تحقيق، وعلمتم فعل وفاعل، والنشأة مفعول به، والأولى نعت، وجملة <span class="hlt"><span class="qpc-hafs">﴿لقد علمتم...﴾</span></span> لا محل لها من الإعراب لأنها جواب القسم المقدر، وجملة القسم المقدر مستأنفة لا محل لها من الإعراب. فلولا: الفاء عاطفة، ولولا حرف تحضيض، وتذكرون فعل مضارع وفاعل.</p></div>"
  56,63,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿أفرأيتم ما تحرثون﴾</span></span>: الهمزة للاستفهام، والفاء استئنافية، والجملة بعدها مستأنفة لا محل لها من الإعراب، رأيتم فعل ماضٍ وفاعله، وما اسم موصول في محل نصب مفعول به، وتحرثون فعل مضارع مرفوع بثبوت النون، والواو في محل رفع فاعل، وجملة <span class="hlt"><span class="qpc-hafs">﴿تحرثون﴾</span></span> لا محل لها من الإعراب، لأنها صلة الموصول.</p></div>"
  56,64,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿أأنتم تزرعونه أم نحن الزارعون﴾</span></span>: الهمزة للاستفهام، وضمير الخطاب في محل رفع مبتدأ، وتزرعونه فعل مضارع مرفوع بثبوت النون والواو في محل رفع فاعل، والهاء ضمير في محل نصب مفعول به، والجملة الاسمية في محل نصب مفعول ثانٍ للفعل رأيتم، و<span class="hlt"><span class="qpc-hafs">﴿أم﴾</span></span>: قيل أنها منقطعة لأن ما بعدها جملة، فالمعنى: <span class="hlt"><span class="qpc-hafs">﴿بل أنحن الزارعون﴾</span></span> على أن الاستفهام للتقرير، وقيل: إنها متصلة، ونحن ضمير في محل رفع مبتدأ، والزارعون خبر مرفوع بالواو، والجملة لا محل لها من الإعراب، لأنها استئنافية.</p></div>"
  56,65,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿لو نشاء لجعلناه حطاما﴾</span></span>: لو شرطية، ونشاء فعل مضارع، وفاعله مستتر تقديره: نحن، واللام واقعة في جواب لو، وجعلناه فعل وفاعل ومفعول به، وحطامًا مفعول جعل الثاني، والجملة لا محل لها من الإعراب، لأنها جواب شرط غير جازم.</p><p><span class="hlt"><span class="qpc-hafs">﴿فظلتم تفكهون﴾</span></span>: ظلتم فعل ماضٍ ناقص، والتاء اسمها، وجملة تفكهون خبرها، وتفكهون فعل مضارع حُذفت منه إحدى تاءيه.</p></div>"
  56,66,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إنا لمغرمون﴾</span></span>: إن حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> اسمها، واللام المزحلقة، ومغرمون خبرها، وجملة إن واسمها وخبرها مقول قول محذوف في محل نصب على الحال تقديره: فظللتم تفكهون، قائلين: إنا لمغرمون.</p></div>"
  56,67,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿بل نحن محرومون﴾</span></span>: بل حرف إضراب وعطف، ونحن مبتدأ، ومحرومون خبر، والجملة معطوفة على سابقتها.</p></div>"
  56,68,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿أفرأيتم الماء الذي تشربون﴾</span></span>: الهمزة للاستفهام، والفاء استئنافية، والجملة بعدها مستأنفة لا محل لها من الإعراب، رأيتم فعل ماضٍ وفاعله، والماء مفعول به، والذي صفة للماء، وجملة <span class="hlt"><span class="qpc-hafs">﴿تشربون﴾</span></span> صلة الموصول لا محل لها من الإعراب، والعائد محذوف.</p></div>"
  56,69,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿أأنتم أنزلتموه من المزن أم نحن المنزلون﴾</span></span>: الهمزة للاستفهام، وضمير الخطاب في محل رفع مبتدأ، وأنزلتموه فعل وفاعل والواو للإشباع والهاء مفعول به، ومن المزن جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أنزلتموه﴾</span></span> في محل نصب مفعول ثانٍ لـ<span class="hlt"><span class="qpc-hafs">﴿رأيتم﴾</span></span>، وأنزلتموه في محل رفع خبر أنتم، و<span class="hlt"><span class="qpc-hafs">﴿أم﴾</span></span>: قيل أنها منقطعة لأن ما بعدها جملة، فالمعنى: <span class="hlt"><span class="qpc-hafs">﴿بل أنحن المنزلون﴾</span></span> على أن الاستفهام للتقرير، وقيل: إنها متصلة، ونحن ضمير في محل رفع مبتدأ، والمنزلون خبر مرفوع بالواو، والجملة لا محل لها من الإعراب، لأنها استئنافية.</p></div>"
  56,70,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿لو نشاء جعلناه أجاجا فلولا تشكرون﴾</span></span>: لو: حرف امتناع لامتناع، ونشاء: فعل مضارع مرفوع والفاعل نحن، وجعلناه: فعل ماض، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> فاعل، والهاء مفعول به أول، وأجاجًا: مفعول به ثان، وجملة <span class="hlt"><span class="qpc-hafs">﴿جعلناه﴾</span></span> لا محل لها من الإعراب لأنها جواب شرط غير جازم، وجملة الشرط <span class="hlt"><span class="qpc-hafs">﴿لو نشاء جعلناه أجاجا﴾</span></span> مستأنفة لا محل لها من الإعراب. فلولا: الفاء عاطفة، ولولا للتحضيض، وتشكرون: فعل مضارع مرفوع بثبوت النون وواو الجماعة في محل رفع فاعل.</p></div>"
  56,71,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿أفرأيتم النار التي تورون﴾</span></span>: الهمزة للاستفهام، والفاء استئنافية، والجملة بعدها مستأنفة لا محل لها من الإعراب، رأيتم فعل ماضٍ وفاعله، والنار مفعول به، والتي صفة للنار، وجملة <span class="hlt"><span class="qpc-hafs">﴿تورون﴾</span></span> صلة الموصول لا محل لها من الإعراب، والعائد محذوف.</p></div>"
  56,72,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿أأنتم أنشأتم شجرتها﴾</span></span>: الهمزة للاستفهام، وضمير الخطاب في محل رفع مبتدأ، وأنشأتم فعل ماضٍ وفاعل، وشجرة مفعول به وها مضاف إليه مجرور.</p><p><span class="hlt"><span class="qpc-hafs">﴿أم نحن المنشئون﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿أم﴾</span></span>: قيل أنها منقطعة لأن ما بعدها جملة، فالمعنى: <span class="hlt"><span class="qpc-hafs">﴿بل أنحن المنشئون﴾</span></span> على أن الاستفهام للتقرير، وقيل: إنها متصلة، ونحن ضمير في محل رفع مبتدأ، والمنشئون خبر مرفوع بالواو، والجملة لا محل لها من الإعراب، لأنها استئنافية.</p></div>"
  56,73,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿نحن جعلناها تذكرة ومتاعا للمقوين﴾</span></span>: نحن مبتدأ، وجملة جعلناها خبر، وتذكرة مفعول به ثانٍ، ومتاعًا عطف على تذكرة، وللمقوين جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿متاعًا﴾</span></span>، أو صفة له.</p></div>"
  56,74,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فسبح باسم ربك العظيم﴾</span></span>: الفاء الفصيحة، وسبح فعل أمر، وفاعله: أنت، وباسم جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿سبح﴾</span></span>، أو بمحذوف حال، أي متبرِّكًا، وقيل: اسم مقحم، والعظيم صفة لـ<span class="hlt"><span class="qpc-hafs">﴿ربك﴾</span></span>.</p></div>"
  56,75,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فلا أقسم بمواقع النجوم﴾</span></span>: الفاء استئنافية، والجملة بعدها مستأنفة لا محل لها من الإعراب، ولا صلة، وقيل: نافية، والمنفي محذوف، وقيل: هي لام الابتداء، دخلت على جملة من مبتدأ وخبر، وهي: أنا أقسم، كقولك: لزيد منطلق، ثم حذف المبتدأ، فاتصلت اللام بخبره، تقديره: فلأقسم باللام فقط. وقيل: هي لام أشبعت فتحتها، فتولدت منها ألف، وأقسم فعل مضارع مرفوع، وفاعله مستتر تقديره: أنا، وبمواقع النجوم جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أقسم﴾</span></span>.</p></div>"
  56,76,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وإنه لقسم لو تعلمون عظيم﴾</span></span>: الواو اعتراضية. وإن: حرف ناسخ، والهاء: اسمها. واللام: المزحلقة، وقسم: خبرها. و<span class="hlt"><span class="qpc-hafs">﴿لو﴾</span></span>: شرطية. وتعلمون: فعل مضارع مرفوع. وعظيم: صفة لـ<span class="hlt"><span class="qpc-hafs">﴿قسم﴾</span></span>. وجملة <span class="hlt"><span class="qpc-hafs">﴿لو تعلمون﴾</span></span>: اعتراضية بين الموصوف وصفته، لا محل لها من الإعراب. وجملة: <span class="hlt"><span class="qpc-hafs">﴿إنه لقسم لو تعلمون عظيم﴾</span></span> اعتراضية بين القسم وجوابه، لا محل لها من الإعراب. وجواب لو محذوف، والتقدير: لو كنتم من ذوي العلم لعلمتم.</p></div>"