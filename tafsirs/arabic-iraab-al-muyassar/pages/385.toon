quran[10]{c,v,t}:
  27,89,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿من جاء بالحسنة فله خير منها وهم من فزع يومئذ آمنون﴾</span></span>: كلام مستأنف لا محل له من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿مَن﴾</span></span> اسم شرط جازم مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿بالحسنة﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿جاء﴾</span></span> أو بمحذوف حال من فاعل جاء فتكون الباء للملابسة، أي: جاء متلبسًا بها، والفاء رابطة لجواب الشرط، و<span class="hlt"><span class="qpc-hafs">﴿له﴾</span></span> جار ومجرور متعلقان بمحذوف خبر مقدم، و<span class="hlt"><span class="qpc-hafs">﴿خير﴾</span></span> مبتدأ مؤخر، و<span class="hlt"><span class="qpc-hafs">﴿منها﴾</span></span> جار ومجرور متعلقان بمحذوف صفة لـ<span class="hlt"><span class="qpc-hafs">﴿خير﴾</span></span>، أو متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿خير﴾</span></span> على أنه اسم تفضيل، و<span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> مبتدأ، ومن فزع جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿آمنون﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿يومئذ﴾</span></span> يوم: ظرف زمان متعلق بمحذوف صفة لـ<span class="hlt"><span class="qpc-hafs">﴿فزع﴾</span></span>، أي: فزع كائن يومئذ، وإذٍ: اسم مبني على السكون المقدر لاشتغال المحل بتنوين العوض في محل جر مضاف إليه، والتنوين عوض عن جملة محذوفة، أي: يوم إذ جاء بالحسنة، أو يوم إذ يُنفَخ في الصور. و<span class="hlt"><span class="qpc-hafs">﴿آمنون﴾</span></span> خبر المبتدأ <span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span>.</p></div>"
  27,90,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ومن جاء بالسيئة فكبت وجوههم في النار هل تجزون إلا ما كنتم تعملون﴾</span></span>: الواو عاطفة، ومن شرطية، و<span class="hlt"><span class="qpc-hafs">﴿جاء بالسيئة﴾</span></span> فعل الشرط، والفاء رابطة داخلة على <span class="hlt"><span class="qpc-hafs">﴿قد﴾</span></span> محذوفة، أي: قد كبت، ليصح اقتران الجواب بها، وكبت فعل ماض مبني لما لم يسمَّ فاعله، و<span class="hlt"><span class="qpc-hafs">﴿وجوههم﴾</span></span> نائب فاعل، و<span class="hlt"><span class="qpc-hafs">﴿في النار﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿كبت﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿فكبت﴾</span></span> في محل جزم جواب الشرط، و<span class="hlt"><span class="qpc-hafs">﴿هل﴾</span></span> حرف استفهام، وتجزون فعل مضارع مبني لما لم يسمَّ فاعله مرفوع بثبوت النون، والواو نائب فاعل، والجملة حال، أي: فكبت وجوههم مقولًا لهم: هل تجزون، وإلا أداة حصر، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> مفعول به ثان لـ<span class="hlt"><span class="qpc-hafs">﴿تجزون﴾</span></span>، وجملة كنتم صلة الموصول لا محل لها من الإعراب. وكان فعل ماض ناقص، والتاء اسمها، وجملة تعملون خبرها.</p></div>"
  27,91,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إنما أمرت أن أعبد رب هذه البلدة الذي حرمها﴾</span></span>: الجملة مقول قول محذوف، أي: قل لهم: إنما أمرت، وإنما كافة ومكفوفة، وأمرت فعل ماض مبني لما لم يسمَّ فاعله، والتاء نائب فاعل، و<span class="hlt"><span class="qpc-hafs">﴿أن أعبد﴾</span></span> في تأويل مصدر منصوب بنزع الخافض، والجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أمرت﴾</span></span>، ورب مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿هذه﴾</span></span> مضاف إليه، والبلدة: بدل من اسم الإشارة، والذي: نعت لـ<span class="hlt"><span class="qpc-hafs">﴿رب هذه البلدة﴾</span></span>، وجملة حرمها: صلة الموصول لا محل لها من الإعراب.</p><p><span class="hlt"><span class="qpc-hafs">﴿وله كل شيء وأمرت أن أكون من المسلمين﴾</span></span>: الواو للحال، و<span class="hlt"><span class="qpc-hafs">﴿له﴾</span></span>: خبر مقدم، وكل: مبتدأ مؤخر، وشيء: مضاف إليه، وأمرت: فعل ماض مبني لما لم يسمَّ فاعله، والتاء نائب فاعل، وأن أكون: في تأويل مصدر منصوب بنزع الخافض، والجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أمرت﴾</span></span>، ومن المسلمين: جار ومجرور متعلقان بمحذوف خبر أكون.</p></div>"
  27,92,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وأن أتلو القرآن فمن اهتدى فإنما يهتدي لنفسه﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿وأن أتلو﴾</span></span>: عطف على أن أكون، أي: وأمرت بأن أتلو، والقرآن: مفعول به، فمن: الفاء تفريعية، ومن: شرطية مبتدأ، واهتدى: فعل ماض في محل جزم فعل الشرط، والفاء رابطة، وإنما: كافة ومكفوفة، ويهتدي: فعل مضارع، وفاعله مستتر، تقديره: هو، ولنفسه: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يهتدي﴾</span></span>، وجملة الشرط والجواب خبر المبتدأ.</p><p><span class="hlt"><span class="qpc-hafs">﴿ومن ضل فقل إنما أنا من المنذرين﴾</span></span>: معطوفة على سابقتها، ومن: شرطية مبتدأ، وضل: فعل ماض في محل جزم فعل الشرط، والفاء رابطة، وقل: فعل أمر والفاعل مستتر تقديره: أنت، إنما: كافة ومكفوفة، وأنا: مبتدأ، من المنذرين: جار ومجرور متعلقان بمحذوف خبر، والجملة مقول القول، وجملة الشرط والجواب خبر المبتدأ.</p></div>"
  27,93,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وقل الحمد لله سيريكم آياته فتعرفونها وما ربك بغافل عما تعملون﴾</span></span>: الواو عاطفة، وقل: فعل أمر، والفاعل مستتر تقديره: أنت، والحمد: مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿لله﴾</span></span>: جار ومجرور متعلقان بمحذوف خبر، والجملة مقول القول، وسيريكم: السين حرف استقبال، ويريكم فعل مضارع، والكاف مفعول به أول، وآياته: مفعول به ثان، والجملة من تتمة مقول القول منتظمة في سلكه، فتعرفونها: الفاء عاطفة، وتعرفونها: فعل مضارع وفاعل ومفعول به، والواو حرف عطف، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> نافية حجازية تعمل عمل ليس، و<span class="hlt"><span class="qpc-hafs">﴿ربك﴾</span></span> اسم ما، و<span class="hlt"><span class="qpc-hafs">﴿بغافل﴾</span></span> الباء حرف جر صلة، وغافل: مجرور لفظًا منصوب محلًّا على أنه خبر <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> الحجازية، و<span class="hlt"><span class="qpc-hafs">﴿عما﴾</span></span> عن حرف جر، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> اسم موصول في محل جر، أي: عن الذي تعملونه، أو <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> مصدرية والمصدر المؤول من <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> والفعل <span class="hlt"><span class="qpc-hafs">﴿تعملون﴾</span></span> مجرور بـ<span class="hlt"><span class="qpc-hafs">﴿عن﴾</span></span>، أي: عن عملكم، والجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿غافل﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿تعملون﴾</span></span> صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> لا محل لها من الإعراب.</p></div>"
  28,1,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿طسم﴾</span></span>: تقدم الكلام على الحروف المقطعة في أول سورة البقرة.</p></div>"
  28,2,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿تلك آيات الكتاب المبين﴾</span></span>: تلك: مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿آيات الكتاب المبين﴾</span></span>: خبر، ومضاف إليه، وصفة.</p></div>"
  28,3,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿نتلو عليك من نبأ موسى وفرعون بالحق لقوم يؤمنون﴾</span></span>: نتلو: فعل مضارع مرفوع، وفاعل مستتر تقديره: نحن، وعليك: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿نتلو﴾</span></span>، ومن نبأ: جار ومجرور متعلقان بمحذوف صفة لمفعول به محذوف، أي: شيئًا محكيًّا من قصة موسى وفرعون. وفيه حذف الموصوف، وإقامة الصفة مقامه، وبالحق: جار ومجرور متعلقان بمحذوف حال من فاعل نتلو، أي: حال كوننا متلبسين بالحق والصدق، أو من المفعول، أي: حال كونه متلبسًا بالحق والصدق، ولقوم جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿نتلو﴾</span></span>، فهو بمثابة التعليل له، أي: لأجل قوم، وجملة يؤمنون: صفة لقوم.</p></div>"
  28,4,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إن فرعون علا في الأرض وجعل أهلها شيعا﴾</span></span>: كلام مستأنف لا محل له من الإعراب. وإن: حرف ناسخ. وفرعون اسمها، وجملة علا: خبرها، وفاعل علا ضمير مستتر، وفي الأرض: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿علا﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿وجعل أهلها﴾</span></span>: فعل وفاعل مستتر ومفعول به أول، وشيعًا: مفعول به ثان.</p><p><span class="hlt"><span class="qpc-hafs">﴿يستضعف طائفة منهم يذبح أبناءهم ويستحيي نساءهم إنه كان من المفسدين﴾</span></span>: جملة يستضعف: حالية من فاعل جعل، وفاعل يستضعف مستتر، وطائفة: مفعول به، ومنهم: جار ومجرور متعلقان بمحذوف صفة لطائفة، ويذبح: بدل اشتمال من يستضعف، وأبناءهم: مفعول يذبح، <span class="hlt"><span class="qpc-hafs">﴿ويستحيي نساءهم﴾</span></span>: عطف على يذبح أبناءهم، وجملة <span class="hlt"><span class="qpc-hafs">﴿إنه﴾</span></span> تعليل، وإن حرف ناسخ، والهاء اسمها، وجملة كان خبرها، واسم كان مستتر تقديره: هو، و<span class="hlt"><span class="qpc-hafs">﴿من المفسدين﴾</span></span>: جار ومجرور متعلقان بمحذوف خبر كان.</p></div>"
  28,5,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ونريد أن نمن على الذين استضعفوا في الأرض﴾</span></span>: الواو عاطفة، أو حالية. وأن وما في حيزها مفعول نريد، وعلى الذين: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿نمن﴾</span></span>، وجملة استضعفوا: صلة الموصول لا محل لها من الإعراب. وفي الأرض: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿استضعفوا﴾</span></span>، أو بمحذوف حال، أي: حالة كونهم على الأرض. وجملة <span class="hlt"><span class="qpc-hafs">﴿نريد﴾</span></span> معطوفة على جملة <span class="hlt"><span class="qpc-hafs">﴿إن فرعون﴾</span></span>، أو حالية من يستضعف، أي: يستضعفهم فرعون، ونحن نريد أن نمن عليهم.</p><p><span class="hlt"><span class="qpc-hafs">﴿ونجعلهم أئمة ونجعلهم الوارثين﴾</span></span>: الواو عاطفة، ونجعلهم: عطف على نمن، والهاء مفعول به أول، وأئمة: مفعول به ثان، ونجعلهم الوارثين: عطف على نجعلهم أئمة.</p></div>"