quran[9]{c,v,t}:
  28,51,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ولقد وصلنا لهم القول لعلهم يتذكرون﴾</span></span>: الواو استئنافية، أو عاطفة، واللام جواب للقسم المحذوف، وقد حرف تحقيق، ووصلنا فعل ماض، مبني على السكون، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span>: ضمير متصل في محل رفع فاعل، ولهم: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿وصلنا﴾</span></span>، والقول: مفعول به، وجملة <span class="hlt"><span class="qpc-hafs">﴿ولقد وصلنا...﴾</span></span> مستأنفة لا محل لها من الإعراب، أو معطوفة، ولعل حرف ناسخ للترجي، و<span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> اسمها، وجملة <span class="hlt"><span class="qpc-hafs">﴿يتذكرون﴾</span></span> خبر لعل.</p></div>"
  28,52,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿الذين آتيناهم الكتاب من قبله هم به يؤمنون﴾</span></span>: الذين اسم موصول مبتدأ، وجملة آتيناهم صلة الموصول لا محل لها من الإعراب. و<span class="hlt"><span class="qpc-hafs">﴿آتيناهم﴾</span></span>: فعل وفاعل ومفعول به أول، والكتاب مفعول به ثان، ومن قبله: جار ومجرور متعلقان بمحذوف حال، و<span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> مبتدأ ثان، و<span class="hlt"><span class="qpc-hafs">﴿به﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يؤمنون﴾</span></span>، وجملة يؤمنون خبر <span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿هم به يؤمنون﴾</span></span> خبر الذين.</p></div>"
  28,53,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وإذا يتلى عليهم قالوا آمنا به﴾</span></span>: الواو عاطفة، وإذا ظرف مستقبل متضمن معنى الشرط، وجملة يتلى في محل جر بإضافة الظرف إليها، ويتلى: فعل مضارع مبني لما لم يسمَّ فاعله، وعليهم: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يتلى﴾</span></span>، ونائب الفاعل مستتر تقديره هو، يعود على القرآن، وجملة <span class="hlt"><span class="qpc-hafs">﴿قالوا﴾</span></span> لا محل لها من الإعراب، لأنها جواب شرط غير جازم، وجملة <span class="hlt"><span class="qpc-hafs">﴿آمنا﴾</span></span> مقول القول، و<span class="hlt"><span class="qpc-hafs">﴿به﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿آمنا﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿إنه الحق من ربنا إنا كنا من قبله مسلمين﴾</span></span>: كلام مستأنف لا محل له من الإعراب، وإن حرف ناسخ، والهاء اسمها، والحق خبر إن، ومن ربنا: جار ومجرور متعلقان بمحذوف حال. <span class="hlt"><span class="qpc-hafs">﴿إنا كنا ...﴾</span></span>: الجملة مستأنفة لا محل لها من الإعراب، وإن حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> اسمها، وجملة <span class="hlt"><span class="qpc-hafs">﴿كنا﴾</span></span> خبرها، ومن قبله: جار ومجرور متعلقان بمحذوف حال، ومسلمين خبر <span class="hlt"><span class="qpc-hafs">﴿كان﴾</span></span>.</p></div>"
  28,54,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿أولئك يؤتون أجرهم مرتين بما صبروا﴾</span></span>: أولئك مبتدأ، وجملة يؤتون خبر، ويؤتون: فعل مضارع مبني لما لم يسمَّ فاعله، والواو نائب فاعل، وأجرهم مفعول به ثان، ومرتين: نائب مفعول مطلق منصوب بالياء، وقد ناب عن المصدر لأنه عدده، و<span class="hlt"><span class="qpc-hafs">﴿بما صبروا﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يؤتون﴾</span></span>، والباء حرف جر للسببية، وما مصدرية، أي: بسبب صبرهم.</p><p><span class="hlt"><span class="qpc-hafs">﴿ويدرءون بالحسنة السيئة ومما رزقناهم ينفقون﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿ويدرءون﴾</span></span> عطف على <span class="hlt"><span class="qpc-hafs">﴿يؤتون﴾</span></span>، والواو في <span class="hlt"><span class="qpc-hafs">﴿يدرءون﴾</span></span> في محل رفع فاعل، وبالحسنة: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يدرءون﴾</span></span>، والسيئة مفعول به، ومما: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿ينفقون﴾</span></span>، وجملة رزقناهم صلة الموصول لا محل لها من الإعراب. و<span class="hlt"><span class="qpc-hafs">﴿ينفقون﴾</span></span> عطف على يدرءون.</p></div>"
  28,55,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وإذا سمعوا اللغو أعرضوا عنه وقالوا لنا أعمالنا ولكم أعمالكم﴾</span></span>: الواو عاطفة، وإذا ظرف مستقبل متضمن معنى الشرط، وجملة سمعوا مجرورة بإضافة الظرف إليها، واللغو مفعول به، وجملة أعرضوا لا محل لها من الإعراب، وعنه: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أعرضوا﴾</span></span>، وقالوا: عطف على أعرضوا، و<span class="hlt"><span class="qpc-hafs">﴿لنا﴾</span></span>: جار ومجرور متعلقان بمحذوف خبر مقدم، وأعمالنا: مبتدأ مؤخر. <span class="hlt"><span class="qpc-hafs">﴿ولكم أعمالكم﴾</span></span>: عطف على ما تقدم.</p><p><span class="hlt"><span class="qpc-hafs">﴿سلام عليكم لا نبتغي الجاهلين﴾</span></span>: سلام مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿عليكم﴾</span></span> جار ومجرور متعلقان بمحذوف خبر، وجملة <span class="hlt"><span class="qpc-hafs">﴿لا نبتغي الجاهلين﴾</span></span> حالية، ولا نافية، ونبتغي فعل مضارع والفاعل مستتر، تقديره: نحن، والجاهلين مفعول به.</p></div>"
  28,56,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إنك لا تهدي من أحببت ولكن الله يهدي من يشاء وهو أعلم بالمهتدين﴾</span></span>: كلام مستأنف لا محل له من الإعراب، وإن حرف ناسخ، والكاف اسمها، وجملة <span class="hlt"><span class="qpc-hafs">﴿لا تهدي﴾</span></span> خبرها، والفاعل مستتر، تقديره: أنت، ومَن مفعول به، وجملة أحببت صلة الموصول لا محل لها من الإعراب. <span class="hlt"><span class="qpc-hafs">﴿ولكن الله﴾</span></span>: الواو عاطفة، أو حالية، ولكن حرف ناسخ، والكاف اسمها، وجملة <span class="hlt"><span class="qpc-hafs">﴿يهدي﴾</span></span> خبرها، و<span class="hlt"><span class="qpc-hafs">﴿مَن﴾</span></span> مفعول به، وجملة <span class="hlt"><span class="qpc-hafs">﴿يشاء﴾</span></span> صلة الموصول لا محل لها من الإعراب. و<span class="hlt"><span class="qpc-hafs">﴿هو﴾</span></span> مبتدأ، وأعلم خبر، وبالمهتدين جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أعلم﴾</span></span>.</p></div>"
  28,57,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وقالوا إن نتبع الهدى معك نتخطف من أرضنا﴾</span></span>: الواو حرف عطف، وقالوا: فعل ماض، والواو في محل رفع فاعل، وإن شرطية، ونتبع فعل الشرط مجزوم، وفاعله مستتر، تقديره: نحن، والهدى مفعول به، ومعك ظرف متعلق بمحذوف حال، ونتخطف جواب الشرط، وهو فعل مضارع مبني لما لم يسمَّ فاعله، ونائب الفاعل مستتر، تقديره: نحن، ومن أرضنا جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿نتخطف﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿أولم نمكن لهم حرما آمنا يجبى إليه ثمرات كل شيء رزقا من لدنا ولكن أكثرهم لا يعلمون﴾</span></span>: الهمزة للاستفهام، والواو عاطفة على محذوف يقتضيه السياق، ولم حرف نفي وقلب وجزم، ونمكن فعل مضارع مجزوم بلم، والفاعل مستتر، تقديره: نحن، و<span class="hlt"><span class="qpc-hafs">﴿لهم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿نمكن﴾</span></span>، وحرمًا مفعول به، وآمنًا: صفة، وجملة <span class="hlt"><span class="qpc-hafs">﴿يجبى﴾</span></span> صفة ثانية لـ<span class="hlt"><span class="qpc-hafs">﴿حرمًا﴾</span></span>، وإليه: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يجبى﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿ثمرات﴾</span></span> نائب فاعل، و<span class="hlt"><span class="qpc-hafs">﴿كل شيء﴾</span></span>: كل مضاف إليه، وشيء مضاف إليه أيضا، ورزقًا: نائب عن المفعول المطلق لقوله يجبى، لأن معنى الجباية والرزق بمعنى واحد، وقيل: مفعول لأجله، وقيل: حال من الثمرات لتخصصها بالإضافة، و<span class="hlt"><span class="qpc-hafs">﴿من لدنا﴾</span></span> جار ومجرور متعلقان بمحذوف صفة لـ<span class="hlt"><span class="qpc-hafs">﴿رزقًا﴾</span></span>. <span class="hlt"><span class="qpc-hafs">﴿ولكن أكثرهم﴾</span></span>: الواو عاطفة، ولكن حرف ناسخ، وأكثرهم اسمها، وجملة <span class="hlt"><span class="qpc-hafs">﴿لا يعلمون﴾</span></span> خبرها.</p></div>"
  28,58,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وكم أهلكنا من قرية بطرت معيشتها﴾</span></span>: الواو استئنافية، وكم خبرية مفعول مقدم لـ<span class="hlt"><span class="qpc-hafs">﴿أهلكنا﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿من قرية﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أهلكنا﴾</span></span> وهو تمييز كم الخبرية، وجملة <span class="hlt"><span class="qpc-hafs">﴿بطرت﴾</span></span> صفة لقرية، ومعيشتها: مفعول به على تضمين بطرت معنى فعل متعد، أي: كفرت معيشتها، وجملة <span class="hlt"><span class="qpc-hafs">﴿وكم أهلكنا...﴾</span></span> مستأنفة لا محل لها من الإعراب.</p><p><span class="hlt"><span class="qpc-hafs">﴿فتلك مساكنهم لم تسكن من بعدهم إلا قليلا وكنا نحن الوارثين﴾</span></span>: فتلك الفاء عاطفة، وتلك مبتدأ، ومساكنهم خبر، وجملة <span class="hlt"><span class="qpc-hafs">﴿لم تسكن﴾</span></span> خبر ثان، أو حال، والعامل فيها معنى الإشارة، وإلا أداة حصر، وقليلًا ظرف، أي: إلا وقتًا قليلًا، فالاستثناء من الظرف، أو نائب عن المفعول المطلق، أي: لم تسكن من ضروب السكن إلا سكنًا قليلا، فالاستثناء من المصدر، والواو عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿كنا﴾</span></span>: كان فعل ماض ناقص، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> اسمها، ونحن ضمير فصل، أو توكيد لاسم كان، والوارثين خبر كان.</p></div>"
  28,59,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وما كان ربك مهلك القرى حتى يبعث في أمها رسولا يتلو عليهم آياتنا﴾</span></span>: كلام مستأنف لا محل له من الإعراب، وما نافية، و<span class="hlt"><span class="qpc-hafs">﴿كان ربك﴾</span></span> كان فعل ماض ناقص، وربك اسمها، ومهلك خبرها، والقرى مضاف إليه، و<span class="hlt"><span class="qpc-hafs">﴿حتى﴾</span></span> حرف تعليل وجر، ويبعث: فعل مضارع منصوب بأن مضمرة بعد حتى، والفاعل مستتر يعود على الله، والمصدر المؤول من أن والفعل مجرور بـ<span class="hlt"><span class="qpc-hafs">﴿حتى﴾</span></span>، والجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿مهلك﴾</span></span>، وفي أمها جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يبعث﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿رسولًا﴾</span></span> مفعول به، وجملة <span class="hlt"><span class="qpc-hafs">﴿يتلو﴾</span></span> صفة لـ<span class="hlt"><span class="qpc-hafs">﴿رسولًا﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿عليهم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يتلو﴾</span></span>، وآياتنا مفعول به.</p><p><span class="hlt"><span class="qpc-hafs">﴿وما كنا مهلكي القرى إلا وأهلها ظالمون﴾</span></span>: الواو عاطفة، وما نافية، وكان فعل ماض ناقص، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> اسمها، و<span class="hlt"><span class="qpc-hafs">﴿مهلكي﴾</span></span> خبرها، والقرى مضاف إليه، وإلا أداة حصر، والواو حالية، وأهلها مبتدأ، وظالمون خبر، والجملة حالية، والاستثناء مفرغ من أعم الأحوال أي: وما كنا مهلكين لأهل القرى بعد ما بعثنا في أمها رسولًا يدعوهم إلى الحق ويرشدهم إليه في حال من الأحوال إلا حال كونهم ظالمين بتكذيب رسولنا والكفر بآياتنا.</p></div>"