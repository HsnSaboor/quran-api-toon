quran[8]{c,v,t}:
  27,56,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فما كان جواب قومه إلا أن قالوا أخرجوا آل لوط من قريتكم إنهم أناس يتطهرون﴾</span></span>: الفاء عاطفة، وما نافية، وكان فعل ماض ناقص، و<span class="hlt"><span class="qpc-hafs">﴿جواب قومه﴾</span></span> خبر كان المقدم، وإلا أداة حصر، والمصدر المؤول من <span class="hlt"><span class="qpc-hafs">﴿أن قالوا﴾</span></span> اسم كان المؤخر، وجملة أخرجوا مقول القول، وهي فعل أمر وفاعل، و<span class="hlt"><span class="qpc-hafs">﴿آل لوط﴾</span></span> مفعول به، ومضاف إليه، و<span class="hlt"><span class="qpc-hafs">﴿من قريتكم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أخرجوا﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿إنهم﴾</span></span> تعليل لإخراجهم، وإن حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> اسمها، وأناس خبرها، وجملة يتطهرون صفة.</p></div>"
  27,57,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فأنجيناه وأهله إلا امرأته قدرناها من الغابرين﴾</span></span>: الفاء عاطفة على مقدر محذوف يفهم من السياق، و<span class="hlt"><span class="qpc-hafs">﴿أنجيناه﴾</span></span> فعل ماض وفاعل ومفعول به، وأهله عطف على الهاء، أو مفعول معه، وإلا أداة استثناء، و<span class="hlt"><span class="qpc-hafs">﴿امرأته﴾</span></span> مستثنى، وجملة <span class="hlt"><span class="qpc-hafs">﴿قدرناها﴾</span></span> استئنافية لا محل لها من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿قدرناها﴾</span></span> فعل ماض وفاعل ومفعول به، و<span class="hlt"><span class="qpc-hafs">﴿من الغابرين﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿قدرناها﴾</span></span>.</p></div>"
  27,58,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وأمطرنا عليهم مطرا فساء مطر المنذرين﴾</span></span>: الواو عاطفة، وأمطرنا فعل وفاعل، و<span class="hlt"><span class="qpc-hafs">﴿عليهم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أمطرنا﴾</span></span>، ومطرًا مفعول به، <span class="hlt"><span class="qpc-hafs">﴿فساء﴾</span></span> الفاء عاطفة، وساء فعل ماض للذم، و<span class="hlt"><span class="qpc-hafs">﴿مطر المنذرين﴾</span></span> فاعل، ومضاف إليه.</p></div>"
  27,59,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قل الحمد لله وسلام على عباده الذين اصطفى﴾</span></span>: كلام مستأنف لا محل له من الإعراب، والحمد مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿لله﴾</span></span> جار ومجرور متعلقان بمحذوف خبر، وسلام مبتدأ سوغ الابتداء به ما فيه من معنى الدعاء، وعلى عباده جار ومجرور متعلقان بمحذوف خبر، والذين صفة لعباده، وجملة اصطفى صلة الموصول لا محل لها من الإعراب. والعائد محذوف، أي اصطفاهم.</p><p><span class="hlt"><span class="qpc-hafs">﴿آلله خير أما يشركون﴾</span></span>: الهمزة للاستفهام، والله مبتدأ، وخير خبر، وأم عاطفة، وما اسم موصول، وجملة يشركون صلة الموصول لا محل لها من الإعراب.</p></div>"
  27,60,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿أمن خلق السماوات والأرض وأنزل لكم من السماء ماء فأنبتنا به حدائق ذات بهجة﴾</span></span>: أم: منقطعة بمعنى بل، ومن مبتدأ، وجملة <span class="hlt"><span class="qpc-hafs">﴿خلق السماوات والأرض﴾</span></span> صلة الموصول لا محل لها من الإعراب. وخبر من محذوف تقديره: <span class="hlt"><span class="qpc-hafs">﴿خير أم ما يشركون﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿أنزل﴾</span></span> عطف على خلق، و<span class="hlt"><span class="qpc-hafs">﴿لكم﴾</span></span> جار ومجرور متعلقان بمحذوف حال، ومن السماء جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أنزل﴾</span></span>، وماء مفعول به، والفاء عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿أنبتنا﴾</span></span> عطف على ما تقدم، و<span class="hlt"><span class="qpc-hafs">﴿به﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أنبتنا﴾</span></span>، وحدائق مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿ذات بهجة﴾</span></span> صفة لحدائق.</p><p><span class="hlt"><span class="qpc-hafs">﴿ما كان لكم أن تنبتوا شجرها﴾</span></span>: الجملة نعت ثان لحدائق، أو حال منها، وما نافية، وكان فعل ماض ناقص، و<span class="hlt"><span class="qpc-hafs">﴿لكم﴾</span></span> جار ومجرور متعلقان بمحذوف خبر كان المقدم، وأن وما في حيزها اسمها المؤخر، و<span class="hlt"><span class="qpc-hafs">﴿تنبتوا﴾</span></span> فعل مضارع منصوب بأن، والواو فاعل، وشجرها مفعول.</p><p><span class="hlt"><span class="qpc-hafs">﴿أإله مع الله بل هم قوم يعدلون﴾</span></span>: الهمزة للاستفهام، و<span class="hlt"><span class="qpc-hafs">﴿إله﴾</span></span> مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿مع الله﴾</span></span> ظرف مكان منصوب متعلق بمحذوف خبر، وبل حرف إضراب، و<span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> مبتدأ، وقوم خبر، وجملة يعدلون صفة.</p></div>"
  27,61,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿أمن جعل الأرض قرارا وجعل خلالها أنهارا﴾</span></span>: أم: منقطعة بمعنى بل، ومن مبتدأ، وجملة <span class="hlt"><span class="qpc-hafs">﴿جعل الأرض﴾</span></span> صلة الموصول لا محل لها من الإعراب. وخبر من محذوف، وقرارًا مفعول جعل الثاني، <span class="hlt"><span class="qpc-hafs">﴿وجعل خلالها أنهارًا﴾</span></span> عطف على الجملة الأولى، و<span class="hlt"><span class="qpc-hafs">﴿خلالها﴾</span></span> ظرف لـ<span class="hlt"><span class="qpc-hafs">﴿جعل﴾</span></span>، بمعنى خلق المتعدية لواحد، أو متعلق بمحذوف المفعول الثاني لـ<span class="hlt"><span class="qpc-hafs">﴿جعل﴾</span></span>، على أنها بمعنى صير، وعلى الوجه الأول يكون <span class="hlt"><span class="qpc-hafs">﴿قرارًا﴾</span></span> حالًا.</p><p><span class="hlt"><span class="qpc-hafs">﴿وجعل لها رواسي﴾</span></span>: جملة معطوفة.</p><p><span class="hlt"><span class="qpc-hafs">﴿وجعل بين البحرين حاجزا﴾</span></span>: الجملة معطوفة على ما تقدم، وجعل فعل ماض، و<span class="hlt"><span class="qpc-hafs">﴿بين البحرين﴾</span></span> ظرف متعلق بمحذوف مفعول جعل الثاني، وحاجزا مفعول جعل الأول.</p><p><span class="hlt"><span class="qpc-hafs">﴿أإله مع الله بل أكثرهم لا يعلمون﴾</span></span>: الهمزة للاستفهام، و<span class="hlt"><span class="qpc-hafs">﴿إله﴾</span></span> مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿مع الله﴾</span></span> ظرف متعلق بمحذوف خبر، وبل حرف إضراب، وأكثرهم مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿لا يعلمون﴾</span></span> خبر.</p></div>"
  27,62,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿أمن يجيب المضطر إذا دعاه ويكشف السوء﴾</span></span>: أم: منقطعة بمعنى بل، ومن مبتدأ، وجملة <span class="hlt"><span class="qpc-hafs">﴿يجيب المضطر﴾</span></span> صلة الموصول لا محل لها من الإعراب. وخبر مَن محذوف، وجملة <span class="hlt"><span class="qpc-hafs">﴿دعاه﴾</span></span> في محل جر بإضافة الظرف إليها، ويكشف السوء عطف على ما قبلها.</p><p><span class="hlt"><span class="qpc-hafs">﴿ويجعلكم خلفاء الأرض﴾</span></span>: عطف على الجملة الأولى، ويجعلكم فعل مضارع ومفعول به أول، والفاعل ضمير مستتر تقديره: هو، وخلفاء: مفعول به ثان، والأرض مضاف إليه.</p><p><span class="hlt"><span class="qpc-hafs">﴿أإله مع الله﴾</span></span>: الهمزة للاستفهام، و<span class="hlt"><span class="qpc-hafs">﴿إله﴾</span></span> مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿مع الله﴾</span></span> ظرف متعلق بمحذوف خبر.</p><p><span class="hlt"><span class="qpc-hafs">﴿قليلا﴾</span></span>: نائب عن المفعول المطلق، لأنه صفة المصدر المحذوف، أي: تتذكرون تذكرا قليلا.</p><p><span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span>: صلة لتأكيد القلة.</p><p><span class="hlt"><span class="qpc-hafs">﴿تذكرون﴾</span></span>: فعل مضارع مرفوع وعلامة رفعه ثبوت النون، والواو فاعل، وجملة <span class="hlt"><span class="qpc-hafs">﴿قليلا ما تذكرون﴾</span></span> مستأنفة لا محل لها من الإعراب.</p></div>"
  27,63,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿أمن يهديكم في ظلمات البر والبحر﴾</span></span>: أم: منقطعة بمعنى بل، ومَن مبتدأ، وجملة يهديكم صلة الموصول لا محل لها من الإعراب، وخبر من محذوف، و<span class="hlt"><span class="qpc-hafs">﴿في ظلمات البر والبحر﴾</span></span> الجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يهديكم﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿ومن يرسل الرياح بشرا بين يدي رحمته أإله مع الله تعالى الله عما يشركون﴾</span></span>: عطف على ما سبق، ويرسل فعل مضارع والفاعل مستتر تقديره: أنت، والرياح مفعول به، وبشرا حال، وبين ظرف منصوب متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿بشرا﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿يدي رحمته﴾</span></span> مضاف إليه، والهمزة للاستفهام، و<span class="hlt"><span class="qpc-hafs">﴿إله﴾</span></span> مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿مع الله﴾</span></span> ظرف متعلق بمحذوف خبر، وتعالى فعل ماض، ولفظ الجلالة فاعل، عن حرف جر، وما حرف مصدري، والمصدر المؤول من <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> والفعل بعدها مجرور بـ<span class="hlt"><span class="qpc-hafs">﴿عن﴾</span></span>، والجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تعالى﴾</span></span>.</p></div>"