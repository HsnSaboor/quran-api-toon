quran[11]{c,v,t}:
  20,77,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ولقد أوحينا إلى موسى أن أسر بعبادي﴾</span></span>: الواو عاطفة، أو استئنافية، واللام جواب للقسم المحذوف، وقد حرف تحقيق. وأوحينا فعل وفاعل، وإلى موسى جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أوحينا﴾</span></span>. و<span class="hlt"><span class="qpc-hafs">﴿أن﴾</span></span>: تفسيرية، لأن الوحي فيه معنى القول دون حروفه، والجملة بعدها تفسيرية لا محل لها من الإعراب. أو <span class="hlt"><span class="qpc-hafs">﴿أن﴾</span></span> مصدرية، وهي مع ما دخلت عليه في تأويل مصدر منصوب بنزع الخافض، والجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أوحى﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿أسر﴾</span></span> صلة <span class="hlt"><span class="qpc-hafs">﴿أن﴾</span></span> المصدرية لا محل لها من الإعراب. وأسر فعل أمر مبني على حذف حرف العلة، والفاعل مستتر. وبعبادي: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أسر﴾</span></span>. وجملة <span class="hlt"><span class="qpc-hafs">﴿ولقد أوحينا...﴾</span></span> معطوفة، أو مستأنفة لا محل لها من الإعراب.</p><p><span class="hlt"><span class="qpc-hafs">﴿فاضرب لهم طريقا في البحر يبسا لا تخاف دركا ولا تخشى﴾</span></span>: فاضرب عطف على أسر، أي: اجعل، و<span class="hlt"><span class="qpc-hafs">﴿لهم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿اضرب﴾</span></span>، قائم مقام المفعول الثاني، وطريقًا مفعول به أول، وفي البحر جار ومجرور متعلقان بمحذوف صفة، ويبسًا صفة ثانية، وهو وصف لما يؤول إليه، أو مصدر وصف به مبالغة، وجملة لا تخاف حالية من فاعل اضرب، أي: اضرب غير خائف، أو صفة لـ<span class="hlt"><span class="qpc-hafs">﴿طريقًا﴾</span></span>، والعائد محذوف، أي: لا تخاف فيه، أو هي جملة مستأنفة لا محل لها من الإعراب، ولا نافية، وتخاف فعل مضارع مرفوع، وفاعله أنت، ودركًا مفعول به، وجملة ولا تخشى عطف على لا تخاف.</p></div>"
  20,78,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فأتبعهم فرعون بجنوده فغشيهم من اليم ما غشيهم﴾</span></span>: الفاء عاطفة، وأتبعهم فعل ماض متعد لاثنين حذف ثانيهما، والتقدير: فأتبعهم فرعون عقابه، والهاء هي المفعول الأول، وقيل: الباء صلة في المفعول الثاني، والتقدير: فأتبعهم فرعون جنوده، وقيل: هو بمعنى تبع، يتعدى لواحد، و<span class="hlt"><span class="qpc-hafs">﴿بجنوده﴾</span></span> جار ومجرور متعلقان بمحذوف حال، فغشيهم: الفاء عاطفة، وغشيهم فعل ماض، والهاء مفعول، وما فاعل، وجملة غشيهم صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> لا محل لها من الإعراب.</p></div>"
  20,79,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وأضل فرعون قومه وما هدى﴾</span></span>: الواو عاطفة، وأضل فعل ماض، وفرعون فاعل، وقومه مفعول به، وجملة وما هدى عطف على أضل.</p></div>"
  20,80,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿يا بني إسرائيل قد أنجيناكم من عدوكم﴾</span></span>: يا حرف نداء، وبني إسرائيل منادى مضاف، وقد حرف تحقيق، وأنجيناكم فعل ماض، وفاعل، ومفعول به، ومن عدوكم جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أنجيناكم﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿وواعدناكم جانب الطور الأيمن ونزلنا عليكم المن والسلوى﴾</span></span>: الواو عاطفة، وواعدناكم عطف على أنجيناكم، وواعدناكم فعل، وفاعل، ومفعول به أول، وجانب الطور مفعول به ثان، على تقدير مضاف محذوف، أي: إتيان جانب، والأيمن صفة لجانب، ونزلنا عطف على ما قبله، و<span class="hlt"><span class="qpc-hafs">﴿عليكم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿نزلنا﴾</span></span>، والمن مفعول به، والسلوى عطف على المن.</p></div>"
  20,81,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿كلوا من طيبات ما رزقناكم ولا تطغوا فيه فيحل عليكم غضبي﴾</span></span>: كلوا فعل أمر مبني على حذف النون، والواو فاعل، ومن طيبات جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿كلوا﴾</span></span>، وما مضاف إليه، وجملة رزقناكم صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> لا محل لها من الإعراب، ولا تطغوا: الواو عاطفة، ولا ناهية، وتطغوا فعل مضارع مجزوم بلا الناهية، والواو فاعل، وفيه جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تطغوا﴾</span></span>، فيحل: الفاء السببية، و<span class="hlt"><span class="qpc-hafs">﴿يحل﴾</span></span> فعل مضارع منصوب بأن مضمرة، والمصدر المؤول من أن والفعل معطوف على مصدر متصيَّد من الكلام السابق، أي: لا يكن طغيان فحلول غضبي. و<span class="hlt"><span class="qpc-hafs">﴿عليكم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يحل﴾</span></span>، وغضبي فاعل، وقيل: هو معطوف.</p><p><span class="hlt"><span class="qpc-hafs">﴿ومن يحلل عليه غضبي فقد هوى﴾</span></span>: الواو عاطفة، ومن شرطية مبتدأ، ويحلل فعل الشرط، و<span class="hlt"><span class="qpc-hafs">﴿عليه﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يحلل﴾</span></span>، وغضبي فاعل يحلل، والفاء: رابطة لجواب الشرط، وقد حرف تحقيق، وهوى فعل ماض، أي: هلك، والجملة في محل جزم جواب الشرط، وفعل الشرط وجوابه خبر مَن.</p></div>"
  20,82,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وإني لغفار لمن تاب وآمن وعمل صالحا ثم اهتدى﴾</span></span>: الواو عاطفة، وإن حرف ناسخ، والياء ضمير مبني في محل نصب اسم إن، واللام المزحلقة، وغفار خبر إن مرفوع، ولمن جار ومجرور متعلقان بغفار، وجملة تاب صلة <span class="hlt"><span class="qpc-hafs">﴿من﴾</span></span> لا محل لها من الإعراب، وآمن وعمل عطف، وصالحًا مفعول به لـ<span class="hlt"><span class="qpc-hafs">﴿عمل﴾</span></span>، أو نائب عن المفعول المطلق، لأنه صفة المصدر، أي: عمل عملًا صالحًا، ثم اهتدى عطف.</p></div>"
  20,83,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وما أعجلك عن قومك يا موسى﴾</span></span>: ما اسم استفهام مبتدأ، وأعجل فعل ماض، وفاعل مستتر تقديره: هو، يعود على ما، والكاف مفعول به، والجملة خبر ما، وعن قومك جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أعجلك﴾</span></span>.</p></div>"
  20,84,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قال هم أولاء على أثري وعجلت إليك رب لترضى﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> مبتدأ، وأولاء خبر، وعلى أثري جار ومجرور متعلقان بمحذوف خبر ثان، أو حال، وعجلت فعل وفاعل، والواو حالية بتقدير: قد، أو عاطفة، وإليك جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿عجلت﴾</span></span>، ورب منادى مضاف إلى ياء المتكلم المحذوفة، وحرف النداء محذوف، ولترضى اللام للتعليل، وترضى فعل مضارع منصوب بأن مضمرة بعد لام التعليل، والمصدر المؤول من أن والفعل مجرور باللام، والجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿عجلت﴾</span></span> أيضًا.</p></div>"
  20,85,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قال فإنا قد فتنا قومك من بعدك وأضلهم السامري﴾</span></span>: قال فعل ماض، وفاعله مستتر يعود على الله، والفاء الفصيحة، وإن حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> اسمها، وجملة قد فتنا خبرها، وهي فعل وفاعل، وقومك مفعول به، وأضلهم السامري فعل، ومفعول به مقدم، وفاعل مؤخر.</p></div>"
  20,86,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فرجع موسى إلى قومه غضبان أسفا﴾</span></span>: الفاء للتعقيب، ورجع فعل ماض، وموسى فاعل، وإلى قومه جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿رجع﴾</span></span>، وغضبان أسفًا حالان.</p><p><span class="hlt"><span class="qpc-hafs">﴿قال يا قوم ألم يعدكم ربكم وعدا حسنا﴾</span></span>: يا حرف نداء، وقوم منادى مضاف إلى ياء المتكلم المحذوفة، ألم الهمزة للاستفهام، ويعدكم فعل مضارع مجزوم بلم، والكاف مفعول به، وربكم فاعل، ووعدًا مفعول مطلق، وحسنًا صفة.</p><p><span class="hlt"><span class="qpc-hafs">﴿أفطال عليكم العهد أم أردتم أن يحل عليكم غضب من ربكم فأخلفتم موعدي﴾</span></span>: الهمزة للاستفهام، والفاء حرف عطف على محذوف، وطال فعل ماض، و<span class="hlt"><span class="qpc-hafs">﴿عليكم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿طال﴾</span></span>، والعهد فاعل، وأم حرف عطف معادل للهمزة، وأردتم فعل وفاعل، وأن وما في حيزها مفعول أردتم، و<span class="hlt"><span class="qpc-hafs">﴿عليكم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يحل﴾</span></span>، وغضب فاعل يحل، ومن ربكم جار ومجرور متعلقان بمحذوف صفة لغضب، فأخلفتم الفاء حرف عطف، وأخلفتم عطف على أردتم، وموعدي مفعول أخلفتم.</p></div>"
  20,87,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قالوا ما أخلفنا موعدك بملكنا﴾</span></span>: قالوا فعل وفاعل، وما نافية، وأخلفنا فعل وفاعل، وموعدك مفعول به، وبملكنا جار ومجرور متعلقان بمحذوف جار ومجرور متعلقان بمحذوف حال، أي: حال كوننا مالكين أمرنا.</p><p><span class="hlt"><span class="qpc-hafs">﴿ولكنا حملنا أوزارا من زينة القوم﴾</span></span>: الواو عاطفة، ولكن حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> اسمها، وحملنا فعل ماض بالبناء لما لم يسمَّ فاعله، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> نائب فاعل، وأوزارًا مفعول به ثان، و<span class="hlt"><span class="qpc-hafs">﴿من زينة القوم﴾</span></span> الجار والمجرور متعلقان بمحذوف صفة، وجملة <span class="hlt"><span class="qpc-hafs">﴿حملنا﴾</span></span> خبر لكن.</p><p><span class="hlt"><span class="qpc-hafs">﴿فقذفناها فكذلك ألقى السامري﴾</span></span>: الفاء عاطفة، وقذفناها فعل، وفاعل، ومفعول به، وهو معطوف على محذوف،  فكذلك الفاء حرف عطف، و<span class="hlt"><span class="qpc-hafs">﴿كذلك﴾</span></span> الكاف اسم بمعنى مثل مبني على الفتح في محل نصب صفة بمصدر محذوف، و<span class="hlt"><span class="qpc-hafs">﴿ذلك﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿ذا﴾</span></span> اسم إشارة في محل جر مضاف إليه، واللام للبعد، والكاف حرف خطاب، وألقى السامري فعل وفاعل.</p></div>"