quran[20]{c,v,t}:
  26,20,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قال فعلتها إذا﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿قال﴾</span></span> فعل ماض، و<span class="hlt"><span class="qpc-hafs">﴿فعلتها﴾</span></span> فعل ماض، والتاء فاعل، والهاء مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿إذًا﴾</span></span> حرف جزاء بمثابة الجواب.</p><p><span class="hlt"><span class="qpc-hafs">﴿وأنا من الضالين﴾</span></span>: الواو واو الحال، وأنا مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿من﴾</span></span> حرف جر، والضالين اسم مجرور، والجار والمجرور متعلقان بمحذوف خبر، وجملة <span class="hlt"><span class="qpc-hafs">﴿أنا من الضالين﴾</span></span> جملة حالية.</p></div>"
  26,21,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ففررت منكم لما خفتكم فوهب لي ربي حكما وجعلني من المرسلين﴾</span></span>: الفاء عاطفة، وفررت فعل وفاعل، و<span class="hlt"><span class="qpc-hafs">﴿منكم﴾</span></span> من حرف جر، والكاف ضمير في محل جر، والجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿فررت﴾</span></span>، ولما حينية، أو رابطة، و<span class="hlt"><span class="qpc-hafs">﴿خفتكم﴾</span></span> فعل وفاعل ومفعول، وجملة <span class="hlt"><span class="qpc-hafs">﴿خفتكم﴾</span></span> مضاف إليه، فوهب عطف على ففررت، و<span class="hlt"><span class="qpc-hafs">﴿لي﴾</span></span> اللام حرف جر، والياء ضمير مبني في محل جر، والجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿وهب﴾</span></span>، وربي فاعل، وحكمًا مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿جعلني من المرسلين﴾</span></span> عطف على ما تقدم.</p></div>"
  26,22,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وتلك نعمة تمنها علي أن عبدت بني إسرائيل﴾</span></span>: تلك مبتدأ، ونعمة خبر، وجملة <span class="hlt"><span class="qpc-hafs">﴿تمنها﴾</span></span> صفة لنعمة، و<span class="hlt"><span class="qpc-hafs">﴿علي﴾</span></span> على حرف جر، والياء ضمير في محل جر، والجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تمنها﴾</span></span>، وأن وما في حيزها عطف بيان لـ<span class="hlt"><span class="qpc-hafs">﴿تلك﴾</span></span>، أو بدل من <span class="hlt"><span class="qpc-hafs">﴿نعمة﴾</span></span>، أو في محل نصب على أنه مفعول لأجله، وتمنها فعل مضارع، والفاعل ضمير مستتر تقديره: أنت، والهاء منصوب بنزع الخافض، أي: تمن بها، و<span class="hlt"><span class="qpc-hafs">﴿عبدت﴾</span></span> فعل ماض، والتاء فاعل، و<span class="hlt"><span class="qpc-hafs">﴿بني إسرائيل﴾</span></span> مفعول به منصوب بالياء.</p></div>"
  26,23,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قال فرعون وما رب العالمين﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿قال فرعون﴾</span></span> فعل وفاعل، والواو عاطفة، <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> اسم استفهام مبتدأ، ورب العالمين خبره.</p></div>"
  26,24,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قال رب السماوات والأرض وما بينهما إن كنتم موقنين﴾</span></span>: قال فعل ماض، <span class="hlt"><span class="qpc-hafs">﴿رب﴾</span></span> خبر لمبتدأ محذوف، وما عطف على <span class="hlt"><span class="qpc-hafs">﴿السماوات والأرض﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿بينهما﴾</span></span> ظرف متعلق بمحذوف صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span>، وجملة الصلة لا محل لها من الإعراب، وإن شرطية، و<span class="hlt"><span class="qpc-hafs">﴿كنتم﴾</span></span>: كان فعل ماض ناقص في محل جزم فعل الشرط، والتاء اسمها، وموقنين خبرها، وجواب إن محذوف، أي: إن كنتم ممن يرجى منهم النظر الصحيح والاعتبار السليم نفعكم هذا الجواب.</p></div>"
  26,25,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قال لمن حوله ألا تستمعون﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿قال﴾</span></span> فعل ماض، والفاعل مستتر تقديره: هو، و<span class="hlt"><span class="qpc-hafs">﴿لمن﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿قال﴾</span></span>، وحوله: ظرف متعلق بمحذوف صلة الموصول، وجملة الصلة لا محل لها من الإعراب. والهمزة للاستفهام، ولا نافية، وتستمعون فعل مضارع وفاعله.</p></div>"
  26,26,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قال ربكم ورب آبائكم الأولين﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿قال﴾</span></span> فعل ماض والفاعل مستتر تقديره: هو، و<span class="hlt"><span class="qpc-hafs">﴿ربكم﴾</span></span> خبر لمبتدأ محذوف، أي: هو، ورب آبائكم عطف على ربكم، والأولين صفة لآبائكم.</p></div>"
  26,27,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قال إن رسولكم الذي أرسل إليكم لمجنون﴾</span></span>: قال فعل ماض، وإن حرف ناسخ، ورسول اسمها، والكاف مضاف إليه. والذي: صفة. وجملة <span class="hlt"><span class="qpc-hafs">﴿أرسل إليكم﴾</span></span>: صلة للموصول لا محل لها من الإعراب، واللام المزحلقة، ومجنون خبر إن، وجملة إن رسولكم مقول القول.</p></div>"
  26,28,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قال رب المشرق والمغرب وما بينهما إن كنتم تعقلون﴾</span></span>: قال فعل ماض، <span class="hlt"><span class="qpc-hafs">﴿رب﴾</span></span> مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿المشرق﴾</span></span> مضاف إليه، و<span class="hlt"><span class="qpc-hafs">﴿المغرب﴾</span></span> معطوف على المشرق، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> عطف أيضا، و<span class="hlt"><span class="qpc-hafs">﴿بينهما﴾</span></span> ظرف متعلق بمحذوف صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span>، وجملة الصلة لا محل لها من الإعراب. <span class="hlt"><span class="qpc-hafs">﴿إن كنتم تعقلون﴾</span></span> شرط، وجوابه محذوف.</p></div>"
  26,29,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قال لئن اتخذت إلها غيري لأجعلنك من المسجونين﴾</span></span>: قال فعل ماض، <span class="hlt"><span class="qpc-hafs">﴿لئن﴾</span></span> اللام موطئة للقسم، وإن شرطية، واتخذت فعل ماض وفاعل، والفعل في محل جزم فعل الشرط، وإلهًا مفعول به، وغيري صفة، واللام جواب القسم، وجواب الشرط محذوف دل عليه جواب القسم، وأجعلنك فعل مضارع مبني على الفتح، لاتصاله بنون التوكيد الثقيلة، والفاعل ضمير مستتر تقديره: أنا، و<span class="hlt"><span class="qpc-hafs">﴿من المسجونين﴾</span></span> جار ومجرور متعلقان بمحذوف مفعول ثان.</p></div>"
  26,30,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قال أولو جئتك بشيء مبين﴾</span></span>: قال فعل ماض، الهمزة للاستفهام، والواو للحال، ولو شرطية، وجئتك فعل ماض وفاعل ومفعول به، و<span class="hlt"><span class="qpc-hafs">﴿بشيء﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿جئتك﴾</span></span>، ومبين صفة لشيء.</p></div>"
  26,31,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قال فأت به إن كنت من الصادقين﴾</span></span>: قال فعل ماض، <span class="hlt"><span class="qpc-hafs">﴿فائت﴾</span></span> الفاء الفصيحة، و<span class="hlt"><span class="qpc-hafs">﴿به﴾</span></span> جار ومجرور متعلقان بقوله: <span class="hlt"><span class="qpc-hafs">﴿فائت﴾</span></span>، وإن شرطية، و<span class="hlt"><span class="qpc-hafs">﴿كنت﴾</span></span> فعل الشرط، وكان فعل ماض ناقص، والتاء اسمها، و<span class="hlt"><span class="qpc-hafs">﴿من الصادقين﴾</span></span> جار ومجرور متعلقان بمحذوف خبر كان، وجواب الشرط محذوف دل عليه ما قبله.</p></div>"
  26,32,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فألقى عصاه فإذا هي ثعبان مبين﴾</span></span>: الفاء عاطفة، وألقى فعل ماض، وفاعله مستتر تقديره: هو، وعصاه مفعول به، <span class="hlt"><span class="qpc-hafs">﴿فإذا﴾</span></span> الفاء عاطفة، وإذا فجائية وهي ظرف، أو حرف، و<span class="hlt"><span class="qpc-hafs">﴿هي﴾</span></span> مبتدأ، وثعبان خبر، ومبين صفة.</p></div>"
  26,33,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ونزع يده فإذا هي بيضاء للناظرين﴾</span></span>: الجملة معطوفة على سابقتها، ونزع فعل ماض، وفاعله مستتر تقديره: هو، و<span class="hlt"><span class="qpc-hafs">﴿يده﴾</span></span> مفعول به، <span class="hlt"><span class="qpc-hafs">﴿فإذا﴾</span></span> الفاء عاطفة، وإذا فجائية وهي ظرف، أو حرف، و<span class="hlt"><span class="qpc-hafs">﴿هي﴾</span></span> مبتدأ، وبيضاء خبر، و<span class="hlt"><span class="qpc-hafs">﴿للناظرين﴾</span></span> جار ومجرور متعلقان بمحذوف صفة.</p></div>"
  26,34,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قال للملأ حوله إن هذا لساحر عليم﴾</span></span>: قال فعل ماض، والواو فاعل، <span class="hlt"><span class="qpc-hafs">﴿للملأ﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿قال﴾</span></span>، وحوله ظرف متعلق بمحذوف حال، وإن حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿هذا﴾</span></span> اسمها، واللام المزحلقة، وساحر خبر، وعليم خبر ثان، وجملة <span class="hlt"><span class="qpc-hafs">﴿إن هذا لساحر...﴾</span></span> مقول القول في محل نصب.</p></div>"
  26,35,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿يريد أن يخرجكم من أرضكم بسحره﴾</span></span>: الجملة صفة لـ<span class="hlt"><span class="qpc-hafs">﴿ساحر﴾</span></span>، وأن وما في حيزها مفعول يريد، و<span class="hlt"><span class="qpc-hafs">﴿من أرضكم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يخرجكم﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿بسحره﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يخرجكم﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿فماذا تأمرون﴾</span></span>: الفاء عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿ماذا﴾</span></span> في محل نصب على أنه مفعول ثان لتأمرون بحذف الجار، والمفعول الأول محذوف، والتقدير: بأي شيء تأمرونني؟ وجملة <span class="hlt"><span class="qpc-hafs">﴿تأمرون﴾</span></span> معطوفة على مقول القول. أو: <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> اسم استفهام مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿ذا﴾</span></span> اسم موصول في محل رفع خبر، وجملة <span class="hlt"><span class="qpc-hafs">﴿تأمرون﴾</span></span> صلة الموصول لا محل لها من الإعراب، والعائد محذوف والتقدير: فما الذي تأمروننيه؟ وجملة <span class="hlt"><span class="qpc-hafs">﴿ماذا تأمرون﴾</span></span> معطوفة على مقول القول.</p></div>"
  26,36,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قالوا أرجه وأخاه وابعث في المدائن حاشرين﴾</span></span>: قالوا فعل وفاعل، وأرجه فعل أمر، والهاء مفعول به، وأخاه عطف على الهاء، أو مفعول معه، وابعث عطف على أرجه، و<span class="hlt"><span class="qpc-hafs">﴿في المدائن﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿ابعث﴾</span></span>، وحاشرين صفة لمفعول به محذوف، أي: جنودا يحشرون السحرة ويجمعونهم.</p></div>"
  26,37,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿يأتوك بكل سحار عليم﴾</span></span>: يأتوك فعل مضارع مجزوم، لأنه جواب الأمر، والواو فاعل، والكاف مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿بكل سحار﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يأتوك﴾</span></span>، وعليم صفة لـ<span class="hlt"><span class="qpc-hafs">﴿سحار﴾</span></span>.</p></div>"
  26,38,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فجمع السحرة لميقات يوم معلوم﴾</span></span>: الفاء عاطفة على مقدر، وجمع فعل ماض مبني لما لم يسمَّ فاعله، والسحرة نائب فاعل، و<span class="hlt"><span class="qpc-hafs">﴿لميقات﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿جمع﴾</span></span>، ويوم مضاف إليه، ومعلوم صفة.</p></div>"
  26,39,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وقيل للناس هل أنتم مجتمعون﴾</span></span>: الواو عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿قيل﴾</span></span> معطوف على ما تقدم، <span class="hlt"><span class="qpc-hafs">﴿للناس﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿قيل﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿هل﴾</span></span> حرف استفهام، وأنتم مبتدأ، ومجتمعون خبر، والجملة مقول القول.</p></div>"