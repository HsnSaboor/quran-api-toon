quran[10]{c,v,t}:
  7,121,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قالوا آمنا برب العالمين﴾</span></span>: الجملة مستأنفة لا محل لها من الإعراب، أو حالية، أي: ألقوا حال كونهم ساجدين قائلين، وجملة آمنا في محل نصب مقول القول، وبرب العالمين جار ومجرور متعلقان بآمنا.</p></div>"
  7,122,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿رب﴾</span></span>: بدل من رب العالمين، أو نعت له.</p><p><span class="hlt"><span class="qpc-hafs">﴿موسى﴾</span></span>: مضاف إليه.</p><p><span class="hlt"><span class="qpc-hafs">﴿وهارون﴾</span></span>: معطوف على موسى مجرور.</p></div>"
  7,123,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قال فرعون آمنتم﴾</span></span>: الجملة استئنافية لا محل لها من الإعراب، وجملة <span class="hlt"><span class="qpc-hafs">﴿آمنتم﴾</span></span> في محل نصب مقول القول، وهي بهمزة واحدة وبعدها الألف التي هي فاء الكلمة.</p><p><span class="hlt"><span class="qpc-hafs">﴿به﴾</span></span>: جار ومجرور متعلقان بآمنتم.</p><p><span class="hlt"><span class="qpc-hafs">﴿قبل أن﴾</span></span>: ظرف زمان متعلق بآمنتم أيضًا، وأن وما في حيزها مصدر مضاف.</p><p><span class="hlt"><span class="qpc-hafs">﴿آذن﴾</span></span>: أصله أأذن وهو فعل مضارع منصوب بأن، والهمزة الأولى هي همزة المتكلم التي تدخل على المضارع، والثانية قلبت ألفًا لوقوعها ساكنة بعد همزة أخرى.</p><p><span class="hlt"><span class="qpc-hafs">﴿لكم﴾</span></span>: جار ومجرور متعلقان بآذن، وجملة آمنتم في محل نصب مقول قوله.</p><p><span class="hlt"><span class="qpc-hafs">﴿إن هذا لمكر مكرتموه﴾</span></span>: كلام مستأنف لا محل له من الإعراب، وإن حرف ناسخ، وهذا اسمها، واللام المزحلقة، ومكر خبرها، وجملة <span class="hlt"><span class="qpc-hafs">﴿مكرتموه﴾</span></span> صفة لمكر.</p><p><span class="hlt"><span class="qpc-hafs">﴿في المدينة﴾</span></span>: جار ومجرور متعلقان بمكرتموه.</p><p><span class="hlt"><span class="qpc-hafs">﴿لتخرجوا منها﴾</span></span>: اللام للتعليل، وتخرجوا فعل مضارع منصوب بأن مضمرة بعد لام التعليل وأن والفعل في تأويل مصدر مجرور باللام، الجار والمجرور متعلقان بمكرتموه، ومنها جار ومجرور متعلقان بتخرجوا.</p><p><span class="hlt"><span class="qpc-hafs">﴿أهلها﴾</span></span>: مفعول به.</p><p><span class="hlt"><span class="qpc-hafs">﴿فسوف تعلمون﴾</span></span>: الفاء الفصيحة، وسوف حرف استقبال، وتعلمون فعل مضارع وفاعل، ومفعوله محذوف للعلم به، أي: تعلمون ما يحل بكم من قوارع العذاب.</p></div>"
  7,124,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿لأقطعن أيديكم﴾</span></span>: اللام: واقعة في جواب قسم مقدر. وأقطعن: فعل مضارع مبني على الفتح. وجملة <span class="hlt"><span class="qpc-hafs">﴿أقطعن﴾</span></span> جواب قسم مقدر، لا محل لها من الإعراب. وأيديكم: مفعول به.</p><p><span class="hlt"><span class="qpc-hafs">﴿وأرجلكم﴾</span></span>: عطف على أيديكم.</p><p><span class="hlt"><span class="qpc-hafs">﴿من خلاف﴾</span></span>: جار ومجرور متعلقان بمحذوف حال، أي: مختلفة، أو <span class="hlt"><span class="qpc-hafs">﴿من﴾</span></span> للتعليل، فيتعلق الجار والمجرور بنفس الفعل.</p><p><span class="hlt"><span class="qpc-hafs">﴿ثم لأصلبنكم أجمعين﴾</span></span>: ثم حرف عطف وتراخ، ولأصلبنكم عطف على لأقطعن، وأجمعين تأكيد للكاف.</p></div>"
  7,125,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قالوا إنا﴾</span></span>: كلام مستأنف لا محل له من الإعراب، وقالوا فعل وفاعل، وإن حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> اسمها، وإن وما بعدها مقول القول.</p><p><span class="hlt"><span class="qpc-hafs">﴿إلى ربنا﴾</span></span>: متعلقان بمنقلبون.</p><p><span class="hlt"><span class="qpc-hafs">﴿منقلبون﴾</span></span>: خبر إن.</p></div>"
  7,126,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وما تنقم﴾</span></span>: الواو عاطفة، وما نافية، وتنقم فعل مضارع، وفاعله مستتر تقديره أنت.</p><p><span class="hlt"><span class="qpc-hafs">﴿منا﴾</span></span>: جار ومجرور متعلقان بتنقم.</p><p><span class="hlt"><span class="qpc-hafs">﴿إلا﴾</span></span>: أداة حصر.</p><p><span class="hlt"><span class="qpc-hafs">﴿أن آمنا﴾</span></span>: أن مصدرية، وهي مع مدخولها مصدر مفعول تنقم، أو المصدر مفعول من أجله، فهو استثناء مفرَّغ على كل حال.</p><p><span class="hlt"><span class="qpc-hafs">﴿بآيات﴾</span></span>: جار ومجرور متعلقان بآمنا.</p><p><span class="hlt"><span class="qpc-hafs">﴿ربنا﴾</span></span>: مضاف إليه.</p><p><span class="hlt"><span class="qpc-hafs">﴿لما جاءتنا﴾</span></span>: لما رابطة، أو حينية، وجملة <span class="hlt"><span class="qpc-hafs">﴿جاءتنا﴾</span></span> لا محل لها من الإعراب، أو في محل جر بالإضافة.</p><p><span class="hlt"><span class="qpc-hafs">﴿ربنا أفرغ﴾</span></span>: كلام مستأنف لا محل له من الإعراب، وربنا منادى مضاف، وأفرغ فعل دعاء.</p><p><span class="hlt"><span class="qpc-hafs">﴿علينا﴾</span></span>: جار ومجرور متعلقان بأفرغ.</p><p><span class="hlt"><span class="qpc-hafs">﴿صبرًا﴾</span></span>: مفعول به.</p><p><span class="hlt"><span class="qpc-hafs">﴿وتوفنا﴾</span></span>: عطف على أفرغ.</p><p><span class="hlt"><span class="qpc-hafs">﴿مسلمين﴾</span></span>: حال، وجواب <span class="hlt"><span class="qpc-hafs">﴿لما﴾</span></span> محذوف تقديره: لما جاءتنا آمنا بها من غير تردد. وجملة الجواب لا محل لها من الإعراب على كل حال.</p></div>"
  7,127,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وقال الملأ من قوم فرعون﴾</span></span>: الواو استئنافية، أو عاطفة، وقال الملأ فعل وفاعل، ومن قوم فرعون جار ومجرور متعلقان بمحذوف حال من الملأ.</p><p><span class="hlt"><span class="qpc-hafs">﴿أتذر موسى وقومه ليفسدوا في الأرض ويذرك﴾</span></span>: الاستفهام إنكاري، وتذر فعل مضارع، وفاعله مستتر، والجملة مقول القول، وموسى مفعول به، وقومه عطف على موسى، واللام للتعليل، ويفسدوا فعل مضارع منصوب بأن مضمرة بعد لام التعليل، وأن المضمرة والفعل في تأويل مصدر مجرور باللام، والجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تذر﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿في الأرض﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يفسدوا﴾</span></span>، ويذرك: معطوف على يفسدوا منصوب مثله، أو الواو للمعية، و<span class="hlt"><span class="qpc-hafs">﴿يذرك﴾</span></span> منصوب بأن مضمرة بعد الواو في جواب الاستفهام، والكاف مفعول به.</p><p><span class="hlt"><span class="qpc-hafs">﴿وآلهتك﴾</span></span>: عطف على الضمير أو المفعول معه. وجملة <span class="hlt"><span class="qpc-hafs">﴿وقال الملأ...﴾</span></span> مستأنفة لا محل لها من الإعراب، أو معطوفة.</p><p><span class="hlt"><span class="qpc-hafs">﴿قال سنقتل أبناءهم﴾</span></span>: جملة القول مستأنفة لا محل لها من الإعراب، وجملة <span class="hlt"><span class="qpc-hafs">﴿سنقتل﴾</span></span> نصبت  على أنها مقول قوله، وأبناءهم مفعول به.</p><p><span class="hlt"><span class="qpc-hafs">﴿ونستحيي نساءهم﴾</span></span>: عطف.</p><p><span class="hlt"><span class="qpc-hafs">﴿وإنا فوقهم قاهرون﴾</span></span>: الواو عاطفة، أو حالية، وإن حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> اسمها، وقاهرون خبرها، والظرف متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿قاهرون﴾</span></span>، أو بمحذوف حال.</p></div>"
  7,128,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قال موسى لقومه استعينوا بالله﴾</span></span>: جملة مستأنفة لا محل لها من الإعراب، وجملة <span class="hlt"><span class="qpc-hafs">﴿استعينوا﴾</span></span> في محل نصب مقول القول.</p><p><span class="hlt"><span class="qpc-hafs">﴿واصبروا إن الأرض لله يورثها من يشاء﴾</span></span>: عطف على استعينوا، وإن حرف ناسخ، والأرض اسمها، ولله جار ومجرور متعلقان بمحذوف خبرها، والجملة لا محل لها من الإعراب، لأنها تعليلية، وجملة يورثها في محل نصب على الحال من لفظ الجلالة، أو خبر بعد خبر لإن، ومن اسم موصول مفعول به ثان ليورثها.</p><p><span class="hlt"><span class="qpc-hafs">﴿من عباده﴾</span></span>: جار ومجرور.</p><p><span class="hlt"><span class="qpc-hafs">﴿والعاقبة للمتقين﴾</span></span>: الواو استئنافية، والعاقبة مبتدأ، وللمتقين جار ومجرور متعلقان بمحذوف خبر، والجملة مستأنفة لا محل لها من الإعراب.</p></div>"
  7,129,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قالوا أوذينا من قبل أن تأتينا ومن بعد ما جئتنا﴾</span></span>: كلام مستأنف لا محل له من الإعراب، ومن قبل جار ومجرور متعلقان بأوذينا، وأن وما في حيزها في تأويل مصدر مجرور بالإضافة، أي: من قبل إتيانك، ومن بعد عطف على من قبل، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> مصدرية مؤولة مع ما بعدها بمصدر مجرور بالإضافة، أي: من بعد مجيئك.</p><p><span class="hlt"><span class="qpc-hafs">﴿قال عسى ربكم أن يهلك عدوكم﴾</span></span>: جملة مستأنفة لا محل لها من الإعراب، وعسى فعل ماض من أفعال الرجاء، وربكم اسمها، والمصدر المؤول من <span class="hlt"><span class="qpc-hafs">﴿أن يهلك﴾</span></span> خبرها، وعدوكم مفعول به.</p><p><span class="hlt"><span class="qpc-hafs">﴿ويستخلفكم في الأرض﴾</span></span>: عطف على ما تقدم.</p><p><span class="hlt"><span class="qpc-hafs">﴿فينظر كيف تعملون﴾</span></span>: الفاء عاطفة للتعقيب، و<span class="hlt"><span class="qpc-hafs">﴿ينظر﴾</span></span> عطف على يستخلفكم، وكيف استفهام في محل نصب حال من فاعل تعملون، و<span class="hlt"><span class="qpc-hafs">﴿تعملون﴾</span></span> فعل مضارع مرفوع بثبوت النون، وواو الجماعة فاعل، وجملة <span class="hlt"><span class="qpc-hafs">﴿كيف تعملون﴾</span></span> في محل نصب مفعول به لـ<span class="hlt"><span class="qpc-hafs">﴿ينظر﴾</span></span>.</p></div>"
  7,130,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ولقد أخذنا آل فرعون بالسنين﴾</span></span>: الواو استئنافية، والجملة بعدها مستأنفة لا محل لها من الإعراب، واللام جواب قسم محذوف، وقد حرف تحقيق، وأخذنا فعل وفاعل، وآل فرعون مفعول به، وبالسنين جار ومجرور متعلقان بأخذنا.</p><p><span class="hlt"><span class="qpc-hafs">﴿ونقص من الثمرات لعلهم يذكرون﴾</span></span>: الواو عاطفة، ونقص عطف على السنين، ومن الثمرات جار ومجرور متعلقان بنقص، وجملة قالوا لا محل لها من الإعراب، لأنها جواب شرط غير جازم، ولنا جار ومجرور متعلقان بمحذوف خبر مقدم، وهذه اسم إشارة في محل رفع مبتدأ مؤخر، والجملة الاسمية في محل نصب مقول قولهم.</p></div>"