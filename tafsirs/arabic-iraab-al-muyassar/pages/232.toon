quran[9]{c,v,t}:
  11,89,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ويا قوم لا يجرمنكم شقاقي أن يصيبكم مثل ما أصاب قوم نوح﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿لا يجرمنكم﴾</span></span> لا ناهية، ويجرمنكم فعل مضارع مبني على الفتح لاتصاله بنون التوكيد الثقيلة وهو في موضع جزم بلا، والكاف مفعوله الأول، وشقاقي فاعل، وأن وما في حيزها مفعول يجرمنكم الثاني، والكاف مفعول يصيبكم، ومثل فاعل يصيبكم، وما مضاف إليه، أي: مثل الذي، وجملة أصاب صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> لا محل لها من الإعراب، وقوم نوح مفعول به.</p><p><span class="hlt"><span class="qpc-hafs">﴿أو قوم هود أو قوم صالح﴾</span></span>: أو قوم هود عطف على قوم نوح، وكذلك قوم صالح.</p><p><span class="hlt"><span class="qpc-hafs">﴿وما قوم لوط منكم ببعيد﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> نافية حجازية تعمل عمل ليس، و<span class="hlt"><span class="qpc-hafs">﴿قوم﴾</span></span> اسم ما، و<span class="hlt"><span class="qpc-hafs">﴿لوط﴾</span></span> مضاف إليه، و<span class="hlt"><span class="qpc-hafs">﴿منكم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿بعيد﴾</span></span>،، و<span class="hlt"><span class="qpc-hafs">﴿ببعيد﴾</span></span>: الباء حرف جر صلة، و<span class="hlt"><span class="qpc-hafs">﴿بعيد﴾</span></span> خبر <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> الحجازية منصوب محلا مجرور بالباء لفظًا.</p></div>"
  11,90,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿واستغفروا ربكم ثم توبوا إليه﴾</span></span>: الواو استئنافية، والجملة بعدها مستأنفة لا محل لها من الإعراب، واستغفروا ربكم فعل أمر وفاعل ومفعول به، ثم توبوا إليه عطف على استغفروا.</p><p><span class="hlt"><span class="qpc-hafs">﴿إن ربي رحيم ودود﴾</span></span>: إن حرف ناسخ، وربي اسمها، ورحيم ودود خبراها.</p></div>"
  11,91,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قالوا يا شعيب ما نفقه كثيرا مما تقول﴾</span></span>: ما نافية، ونفقه فعل مضارع، وفاعله مستتر تقديره: نحن، وكثيرًا مفعول به، ومما صفة لـ<span class="hlt"><span class="qpc-hafs">﴿كثيرًا﴾</span></span>، وجملة تقول صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> لا محل لها من الإعراب.</p><p><span class="hlt"><span class="qpc-hafs">﴿وإنا لنراك فينا ضعيفا﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿إنا﴾</span></span> إن حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> اسمها، واللام المزحلقة، وجملة نراك خبر إن، والكاف مفعول به، وفينا حال، وضعيفًا مفعول به ثان.</p><p><span class="hlt"><span class="qpc-hafs">﴿ولولا رهطك لرجمناك﴾</span></span>: لولا حرف امتناع لوجود، ورهطك مبتدأ محذوف الخبر، واللام رابطة لجواب لولا، وجملة رجمناك لا محل لها من الإعراب.</p><p><span class="hlt"><span class="qpc-hafs">﴿وما أنت علينا بعزيز﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> نافية حجازية تعمل عمل ليس، و<span class="hlt"><span class="qpc-hafs">﴿أنت﴾</span></span> اسم ما، و<span class="hlt"><span class="qpc-hafs">﴿علينا﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿عزيز﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿بعزيز﴾</span></span> الباء: حرف جر صلة، وعزيز: خبر <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> الحجازية منصوب محلا مجرور بالباء لفظًا.</p></div>"
  11,92,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قال يا قوم أرهطي أعز عليكم من الله﴾</span></span>: الهمزة للاستفهام الإنكاري التوبيخي، ورهطي مبتدأ، وأعز خبر، و<span class="hlt"><span class="qpc-hafs">﴿عليكم﴾</span></span> و<span class="hlt"><span class="qpc-hafs">﴿من الله﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أعز﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿واتخذتموه وراءكم ظهريا﴾</span></span>: الواو حالية بتقدير قد، أي: والحال أنكم اتخذتموه وراءكم، واتخذ متعدى لاثنين أولهما الهاء والثاني ظهريًّا، و<span class="hlt"><span class="qpc-hafs">﴿وراءكم﴾</span></span> ظرف متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿اتخذتموه﴾</span></span>، أو حال من ظهريًّا، أو اتخذ يتعدى لواحد، والهاء مفعوله، وظهريًّا حال، والواو في اتخذتموه لإشباع ضمة الميم.</p><p><span class="hlt"><span class="qpc-hafs">﴿إن ربي بما تعملون محيط﴾</span></span>: إن حرف ناسخ، وربي اسمها، و<span class="hlt"><span class="qpc-hafs">﴿بما﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿محيط﴾</span></span>، وجملة تعملون صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> لا محل لها من الإعراب، ومحيط خبر إن.</p></div>"
  11,93,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ويا قوم اعملوا على مكانتكم إني عامل﴾</span></span>: اعملوا فعل أمر وفاعل، وعلى مكانتكم حال، أي: حال كونكم موصوفين بالمكانة العالية والقدرة البعيدة، وإن حرف ناسخ، والياء اسمها، وعامل خبرها.</p><p><span class="hlt"><span class="qpc-hafs">﴿سوف تعلمون من يأتيه عذاب يخزيه ومن هو كاذب﴾</span></span>: سوف حرف استقبال، وتعلمون فعل مضارع مرفوع بثبوت النون، والجملة استئناف بياني لا محل لها من الإعراب، ومن اسم موصول مفعول به لـ<span class="hlt"><span class="qpc-hafs">﴿تعلمون﴾</span></span>، وجملة يأتيه صلة <span class="hlt"><span class="qpc-hafs">﴿مَن﴾</span></span> لا محل لها من الإعراب، والهاء مفعول يأتي، وعذاب فاعل يأتي، وجملة يخزيه صفة لـ<span class="hlt"><span class="qpc-hafs">﴿عذاب﴾</span></span>، ومن اسم موصول عطف على الأولى، و<span class="hlt"><span class="qpc-hafs">﴿هو﴾</span></span> مبتدأ، وكاذب خبر، وجملة <span class="hlt"><span class="qpc-hafs">﴿هو كاذب﴾</span></span> صلة <span class="hlt"><span class="qpc-hafs">﴿مَن﴾</span></span> لا محل لها من الإعراب.</p><p><span class="hlt"><span class="qpc-hafs">﴿وارتقبوا إني معكم رقيب﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿وارتقبوا﴾</span></span> عطف على المعنى، وارتقبوا فعل أمر وفاعل، وإن حرف ناسخ، والياء اسمها، ومعكم ظرف متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿رقيب﴾</span></span>، ورقيب خبر إن.</p></div>"
  11,94,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ولما جاء أمرنا نجينا شعيبا والذين آمنوا معه برحمة منا﴾</span></span>: لما ظرفية حينية متعلقة بـ<span class="hlt"><span class="qpc-hafs">﴿نجينا﴾</span></span>، أو رابطة، وجاء أمرنا فعل وفاعل، ونجينا شعيبا فعل وفاعل ومفعول به، والذين عطف على <span class="hlt"><span class="qpc-hafs">﴿شعيبا﴾</span></span>، وجملة آمنوا صلة الذين لا محل لها من الإعراب، ومعه ظرف مكان متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿آمنوا﴾</span></span>، وبرحمة جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿نجينا﴾</span></span>، ومنا صفة لرحمة.</p><p><span class="hlt"><span class="qpc-hafs">﴿وأخذت الذين ظلموا الصيحة﴾</span></span>: الذين مفعول مقدم لـ<span class="hlt"><span class="qpc-hafs">﴿أخذت﴾</span></span>، وجملة ظلموا صلة الموصول لا محل لها من الإعراب، والصيحة فاعل أخذت.</p><p><span class="hlt"><span class="qpc-hafs">﴿فأصبحوا في ديارهم جاثمين﴾</span></span>: أصبحوا فعل ماض ناقص ناسخ، والواو اسمها، وجاثمين خبرها، وفي ديارهم جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿جاثمين﴾</span></span>.</p></div>"
  11,95,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿كأن لم يغنوا فيها ألا بعدا لمدين كما بعدت ثمود﴾</span></span>: كأن مخففة، واسمها محذوف، وجملة <span class="hlt"><span class="qpc-hafs">﴿لم يغنوا﴾</span></span> خبرها، وفيها جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يغنوا﴾</span></span>، وألا أداة تنبيه، و<span class="hlt"><span class="qpc-hafs">﴿بعدا﴾</span></span> مفعول مطلق لفعل محذوف أي: بعدوا بعدا، فهو مصدر بمعنى الدعاء عليهم. و<span class="hlt"><span class="qpc-hafs">﴿لمدين﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿بعدا﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿كما﴾</span></span> الكاف: اسم بمعنى مثل مبني على الفتح في محل نصب صفة لـ<span class="hlt"><span class="qpc-hafs">﴿بعدًا﴾</span></span>، أي: بعدًا لمدين مثلَ بعدِ ثمود، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> مصدرية، و<span class="hlt"><span class="qpc-hafs">﴿بعدت ثمود﴾</span></span> فعل وفاعل، وجملة <span class="hlt"><span class="qpc-hafs">﴿بعدت﴾</span></span> صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> المصدرية لا محل لها من الإعراب، والمصدر المؤول من <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> المصدرية والفعل <span class="hlt"><span class="qpc-hafs">﴿بعدت﴾</span></span> مضاف إليه.</p></div>"
  11,96,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ولقد أرسلنا موسى بآياتنا وسلطان مبين﴾</span></span>: بآياتنا حال، أي: حال كونه متلبسًا بآياتنا، وسلطان عطف على <span class="hlt"><span class="qpc-hafs">﴿آياتنا﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿مبين﴾</span></span> صفة.</p></div>"
  11,97,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إلى فرعون وملئه فاتبعوا أمر فرعون﴾</span></span>: إلى فرعون جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أرسلنا﴾</span></span>، وملئه عطف على فرعون، فاتبعوا عطف على أرسلنا، والواو فاعل، وأمر فرعون مفعول به.</p><p><span class="hlt"><span class="qpc-hafs">﴿وما أمر فرعون برشيد﴾</span></span>: الواو حالية، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> نافية حجازية تعمل عمل ليس، و<span class="hlt"><span class="qpc-hafs">﴿أمر﴾</span></span> اسم ما، و<span class="hlt"><span class="qpc-hafs">﴿فرعون﴾</span></span> مضاف إليه، و<span class="hlt"><span class="qpc-hafs">﴿برشيد﴾</span></span> الباء حرف جر صلة، و<span class="hlt"><span class="qpc-hafs">﴿رشيد﴾</span></span> خبر <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> الحجازية منصوب محلا مجرور بالباء لفظًا.</p></div>"