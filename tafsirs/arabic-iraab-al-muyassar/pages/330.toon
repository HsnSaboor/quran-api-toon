quran[11]{c,v,t}:
  21,91,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿والتي أحصنت فرجها فنفخنا فيها من روحنا وجعلناها وابنها آية للعالمين﴾</span></span>: الواو استئنافية، والتي: اسم موصول في محل نصب مفعول به لفعل محذوف تقديره: اذكر، وجملة <span class="hlt"><span class="qpc-hafs">﴿أحصنت فرجها﴾</span></span> صلة <span class="hlt"><span class="qpc-hafs">﴿التي﴾</span></span> لا محل لها من الإعراب، فنفخنا: عطف على أحصنت، وفيها جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿نفخنا﴾</span></span>، ومن روحنا جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿نفخنا﴾</span></span> أيضًا. أو <span class="hlt"><span class="qpc-hafs">﴿التي﴾</span></span> مبتدأ، والخبر محذوف، أي: وفيما يتلى عليكم التي أحصنت ...، وجعلناها فعل وفاعل ومفعول به، وابنها معطوف على مفعول جعلناها أو مفعول معه، وآية مفعول به ثان، وللعالمين صفة لآية.</p></div>"
  21,92,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إن هذه أمتكم أمة واحدة﴾</span></span>: إن حرف ناسخ، وهذه اسم إن، وأمتكم خبر إن، و<span class="hlt"><span class="qpc-hafs">﴿أمةً﴾</span></span> حال لازمة وقيل: بدل من هذه، وواحدة صفة.</p><p><span class="hlt"><span class="qpc-hafs">﴿وأنا ربكم فاعبدون﴾</span></span>: الواو عاطفة، وأنا مبتدأ، وربكم خبر. فاعبدون: الفاء الفصيحة، واعبدون فعل أمر وفاعل، وياء المتكلم المحذوفة لرسم المصحف مفعول به.</p></div>"
  21,93,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وتقطعوا أمرهم بينهم﴾</span></span>: الواو عاطفة، وتقطعوا فعل ماض وفاعله، وأمرهم منصوب بنزع الخافض، أي: في أمرهم، أو <span class="hlt"><span class="qpc-hafs">﴿تقطعوا﴾</span></span> بمعنى: قطعوا، و<span class="hlt"><span class="qpc-hafs">﴿أمرهم﴾</span></span> مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿بينهم﴾</span></span> ظرف متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿تقطعوا﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿كل إلينا راجعون﴾</span></span>: كل مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿إلينا﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿راجعون﴾</span></span>، وراجعون خبر، والجملة استئنافية لا محل لها من الإعراب.</p></div>"
  21,94,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فمن يعمل من الصالحات وهو مؤمن فلا كفران لسعيه﴾</span></span>: الفاء استئنافية، والجملة بعدها مستأنفة لا محل لها من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿مَن﴾</span></span> اسم شرط جازم في محل رفع مبتدأ، ويعمل فعل الشرط، ومن الصالحات جار ومجرور متعلقان بمحذوف صفة لمفعول به محذوف أي: عملًا صالحًا، والواو حالية، و<span class="hlt"><span class="qpc-hafs">﴿هو﴾</span></span> مبتدأ، مؤمن خبر، والفاء رابطة، ولا نافية للجنس، وكفران اسمها، و<span class="hlt"><span class="qpc-hafs">﴿لسعيه﴾</span></span> جار ومجرور متعلقان بمحذوف خبر.</p><p><span class="hlt"><span class="qpc-hafs">﴿وإنا له كاتبون﴾</span></span>: الواو استئنافية أو حالية، وإن حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> اسمها، وكاتبون خبرها، و<span class="hlt"><span class="qpc-hafs">﴿له﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿كاتبون﴾</span></span>، والجملة مستأنفة لا محل لها من الإعراب، أو في محل نصب حال.</p></div>"
  21,95,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وحرام على قرية أهلكناها أنهم لا يرجعون﴾</span></span>: الواو عاطفة من عطف الجمل، أو الواو استئنافية والجملة بعدها مستأنفة لا محل لها من الإعراب، وحرام خبر مقدم، وعلى قرية جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿حرام﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿أهلكناها﴾</span></span> صفة لـ<span class="hlt"><span class="qpc-hafs">﴿قرية﴾</span></span>، وأنهم: أن حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> اسمها، وجملة <span class="hlt"><span class="qpc-hafs">﴿لا يرجعون﴾</span></span> خبر أن، والمصدر المؤول من <span class="hlt"><span class="qpc-hafs">﴿أنهم لا يرجعون﴾</span></span> مبتدأ مؤخر.</p></div>"
  21,96,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿حتى إذا فتحت يأجوج ومأجوج﴾</span></span>: حتى حرف ابتداء، وإذا ظرف لما يستقبل من الزمن، والجواب الذي تتعلق به إذا محذوف تقديره: قالوا يا ويلنا. أو جواب إذا هو <span class="hlt"><span class="qpc-hafs">﴿فإذا هي شاخصة ...﴾</span></span>، وفتحت فعل ماض مبني لما لم يسمَّ فاعله، ويأجوج ومأجوج نائب فاعل، ولا بد من تقدير مضاف وهو سدهما.</p><p><span class="hlt"><span class="qpc-hafs">﴿وهم من كل حدب ينسلون﴾</span></span>: الواو للحال، و<span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> مبتدأ، وخبره جملة ينسلون، ومن كل حدب جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿ينسلون﴾</span></span>.</p></div>"
  21,97,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿واقترب الوعد الحق فإذا هي شاخصة أبصار الذين كفروا﴾</span></span>: الواو عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿اقترب الوعد﴾</span></span> فعل وفاعل، والحق صفة للوعد، والفاء رابطة، وإذا الفجائية، و<span class="hlt"><span class="qpc-hafs">﴿هي﴾</span></span> مبتدأ، وشاخصة خبر، وأبصار فاعل شاخصة، و<span class="hlt"><span class="qpc-hafs">﴿الذين﴾</span></span> اسم موصول في محل جر مضاف إليه، وجملة <span class="hlt"><span class="qpc-hafs">﴿كفروا﴾</span></span> صلة الموصول لا محل لها من الإعراب.</p><p><span class="hlt"><span class="qpc-hafs">﴿يا ويلنا قد كنا في غفلة من هذا بل كنا ظالمين﴾</span></span>: يا حرف نداء، و<span class="hlt"><span class="qpc-hafs">﴿ويلنا﴾</span></span> منادى مضاف منصوب، والضمير في محل جر مضاف إليه. و<span class="hlt"><span class="qpc-hafs">﴿قد﴾</span></span> حرف تحقيق، و<span class="hlt"><span class="qpc-hafs">﴿كنا﴾</span></span> كان فعل ماض ناقص، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> اسمها، و<span class="hlt"><span class="qpc-hafs">﴿في غفلة﴾</span></span> جار ومجرور متعلقان بمحذوف خبرها، ومن هذا جار ومجرور متعلقان بغفلة، و<span class="hlt"><span class="qpc-hafs">﴿بل﴾</span></span> حرف إضراب، وكنا: كان فعل ماض ناقص، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> اسمها، وظالمين خبرها.</p></div>"
  21,98,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إنكم وما تعبدون من دون الله حصب جهنم أنتم لها واردون﴾</span></span>: إنكم: إن حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿كم﴾</span></span> اسمها، والجملة ابتدائية، وما عطف على الكاف، وجملة <span class="hlt"><span class="qpc-hafs">﴿تعبدون﴾</span></span> صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> لا محل لها من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿من دون الله﴾</span></span> جار ومجرور متعلقان بمحذوف حال، وحصب جهنم خبر إنكم، وجملة <span class="hlt"><span class="qpc-hafs">﴿أنتم لها واردون﴾</span></span> جملة اسمية من مبتدأ وخبر في محل رفع بدل من <span class="hlt"><span class="qpc-hafs">﴿حصب جهنم﴾</span></span>.</p></div>"
  21,99,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿لو كان هؤلاء آلهة ما وردوها﴾</span></span>: لو شرطية امتناعية، وكان فعل ماض ناقص، وهؤلاء اسمها، وآلهة خبر كان، وجملة <span class="hlt"><span class="qpc-hafs">﴿ما وردوها﴾</span></span> لا محل لها من الإعراب، لأنها جواب لو.</p><p><span class="hlt"><span class="qpc-hafs">﴿وكل فيها خالدون﴾</span></span>: الواو للحال، وكل مبتدأ، وفيها جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿خالدون﴾</span></span>، وخالدون خبر.</p></div>"
  21,100,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿لهم فيها زفير وهم فيها لا يسمعون﴾</span></span>: لهم جار ومجرور متعلقان بمحذوف خبر مقدم، وفيها حال، وزفير مبتدأ مؤخر، والواو عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> مبتدأ، وفيها جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يسمعون﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿لا يسمعون﴾</span></span> خبر <span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span>.</p></div>"
  21,101,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إن الذين سبقت لهم منا الحسنى أولئك عنها مبعدون﴾</span></span>: إن حرف ناسخ، والذين اسمها، وجملة <span class="hlt"><span class="qpc-hafs">﴿سبقت﴾</span></span> صلة الذين لا محل لها من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿لهم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿سبقت﴾</span></span>، ومنا جار ومجرور متعلقان بمحذوف حال، والحسنى فاعل، وأولئك مبتدأ، وعنها جار ومجرور متعلقان بمبعدون، ومبعدون خبر أولئك، وجملة <span class="hlt"><span class="qpc-hafs">﴿أولئك عنها مبعدون﴾</span></span> خبر إن.</p></div>"