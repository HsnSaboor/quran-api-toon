quran[9]{c,v,t}:
  11,54,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إن نقول إلا اعتراك بعض آلهتنا بسوء﴾</span></span>: إن نافية، ونقول فعل مضارع، وفاعله مستتر، تقديره: نحن، وإلا أداة حصر، وجملة اعتراك معمول لـ<span class="hlt"><span class="qpc-hafs">﴿نقول﴾</span></span>، أي: منصوبة بمصدر محذوف، وذلك المصدر منصوب بـ<span class="hlt"><span class="qpc-hafs">﴿نقول﴾</span></span>، أي: إلا قولنا: اعتراك، والكاف مفعول به، وبعض آلهتنا فاعل، وبسوء جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿اعتراك﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿قال إني أشهد الله واشهدوا أني بريء مما تشركون﴾</span></span>: إن حرف ناسخ، والياء اسمها، وجملة اشهدوا فعل أمر، وأن المفتوحة الهمزة وما في حيزها معمول لـ<span class="hlt"><span class="qpc-hafs">﴿اشهدوا﴾</span></span>، أو لـ<span class="hlt"><span class="qpc-hafs">﴿أشهد الله﴾</span></span>، وأن حرف ناسخ، والياء اسمها، وبريء خبرها، ومما جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿بريء﴾</span></span>، وجملة تشركون صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> لا محل لها من الإعراب، أو <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> مصدرية، أي: من إشراككم.</p></div>"
  11,55,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿من دونه فكيدوني جميعا ثم لا تنظرون﴾</span></span>: من دونه حال، <span class="hlt"><span class="qpc-hafs">﴿فكيدوني﴾</span></span> الفاء الفصيحة، وكيدوني فعل أمر مبني على حذف النون، والواو فاعل، والنون للوقاية، والياء مفعول به، وجميعًا حال، ثم حرف عطف، ولا ناهية، وتنظرون فعل مضارع مجزوم بلا، والواو فاعل، والياء المحذوفة للتخفيف مفعول به.</p></div>"
  11,56,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إني توكلت على الله ربي وربكم﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿إني﴾</span></span> إن حرف ناسخ، والياء اسمها، وجملة توكلت خبرها، وعلى الله جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿توكلت﴾</span></span>، وربي بدل، أو صفة، وربكم عطف على ربي.</p><p><span class="hlt"><span class="qpc-hafs">﴿ما من دابة إلا هو آخذ بناصيتها﴾</span></span>: ما نافية، ومن حرف صلة، ودابة مبتدأ، وساغ الابتداء بالنكرة لسبقها بالنفي، وإلا أداة حصر، و<span class="hlt"><span class="qpc-hafs">﴿هو﴾</span></span> مبتدأ، وآخذ خبر، وبناصيتها جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿آخذ﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿إن ربي على صراط مستقيم﴾</span></span>: إن حرف ناسخ، وربي اسمها، و<span class="hlt"><span class="qpc-hafs">﴿على صراط﴾</span></span> جار ومجرور متعلقان بمحذوف خبرها، ومستقيم صفة.</p></div>"
  11,57,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فإن تولوا فقد أبلغتكم ما أرسلت به إليكم﴾</span></span>: الفاء عاطفة، وإن شرطية، وتولوا فعل مضارع حذفت منه إحدى التاءين، والأصل: تتولوا، وهو فعل الشرط مجزوم بحذف النون، والواو فاعل، والفاء رابطة، وقد حرف تحقيق، وأبلغتكم فعل وفاعل ومفعول به، وما مفعول به ثان، وجملة أرسلت صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> لا محل لها من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿به﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أرسلت﴾</span></span>، وإليكم حال.</p><p><span class="hlt"><span class="qpc-hafs">﴿ويستخلف ربي قوما غيركم ولا تضرونه شيئا﴾</span></span>: كلام مستأنف لا محل له من الإعراب، وربي فاعل، وقومًا مفعول به، وغيركم صفة لـ<span class="hlt"><span class="qpc-hafs">﴿قومًا﴾</span></span>، ولا تضرونه عطف على يستخلف، وشيئًا نائب عن المفعول المطلق، أي: شيئًا من الضرر.</p><p><span class="hlt"><span class="qpc-hafs">﴿إن ربي على كل شيء حفيظ﴾</span></span>: إن حرف ناسخ، وربي اسمها، وعلى كل شيء جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿حفيظ﴾</span></span>، وحفيظ خبر إن.</p></div>"
  11,58,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ولما جاء أمرنا نجينا هودا والذين آمنوا معه برحمة منا﴾</span></span>: الواو استئنافية، والجملة مستأنفة لا محل لها من الإعراب، ولما ظرفية حينية متعلقة بـ<span class="hlt"><span class="qpc-hafs">﴿نجينا﴾</span></span>، أو رابطة، وجاء أمرنا فعل وفاعل، ونجينا هودًا فعل وفاعل ومفعول به، والذين عطف على هود، وجملة آمنوا صلة الذين لا محل لها من الإعراب، ومعه ظرف مكان متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿آمنوا﴾</span></span>، وبرحمة جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿نجينا﴾</span></span>، ومنا جار ومجرور متعلقان بمحذوف صفة لرحمة.</p><p><span class="hlt"><span class="qpc-hafs">﴿ونجيناهم من عذاب غليظ﴾</span></span>: الواو عاطفة، ونجيناهم فعل وفاعل ومفعول به، ومن عذاب جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿نجيناهم﴾</span></span>، وغليظ صفة لعذاب.</p></div>"
  11,59,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وتلك عاد جحدوا بآيات ربهم وعصوا رسله﴾</span></span>: الواو استئنافية، والجملة بعدها مستأنفة لا محل لها من الإعراب، وتلك مبتدأ، وعاد بدل أو عطف بيان، وجملة جحدوا خبر <span class="hlt"><span class="qpc-hafs">﴿تلك﴾</span></span>، أو <span class="hlt"><span class="qpc-hafs">﴿تلك عاد﴾</span></span> مبتدأ وخبر، والجملة بعدها مستأنفة لا محل لها من الإعراب، وبآيات جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿جحدوا﴾</span></span>، وربهم مضاف، وعصوا رسله فعل وفاعل ومفعول به.</p><p><span class="hlt"><span class="qpc-hafs">﴿واتبعوا أمر كل جبار عنيد﴾</span></span>: الواو عاطفة، واتبعوا عطف على <span class="hlt"><span class="qpc-hafs">﴿جحدوا﴾</span></span>، وأمر مفعول به، وكل مضاف إليه، وجبار مضاف إليه، وعنيد صفة لـ<span class="hlt"><span class="qpc-hafs">﴿جبار﴾</span></span>.</p></div>"
  11,60,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وأتبعوا في هذه الدنيا لعنة ويوم القيامة﴾</span></span>: الواو عاطفة، وأتبعوا عطف على ما تقدم، وهو فعل ماض مبني لما لم يسمَّ فاعله، والواو نائب فاعل، و<span class="hlt"><span class="qpc-hafs">﴿في هذه﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أتبعوا﴾</span></span>، والدنيا بدل من اسم الإشارة، ولعنة مفعول به ثان، و<span class="hlt"><span class="qpc-hafs">﴿يوم﴾</span></span> ظرف متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿أتبعوا﴾</span></span> فهو معطوف على شبه الجملة <span class="hlt"><span class="qpc-hafs">﴿في هذه﴾</span></span>، والقيامة مضاف إليه.</p><p><span class="hlt"><span class="qpc-hafs">﴿ألا إن عادا كفروا ربهم﴾</span></span>: ألا أداة تنبيه، وإن حرف ناسخ، وعادا اسمها، وكفروا فعل وفاعل، وربهم منصوب بنزع الخافض، أو منصوب على المفعولية بتضمين كفروا معنى جحدوا، وجملة كفروا خبر إن.</p><p><span class="hlt"><span class="qpc-hafs">﴿ألا بعدا لعاد قوم هود﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿ألا﴾</span></span> أداة تنبيه تأكيد للأولى، و<span class="hlt"><span class="qpc-hafs">﴿بعدا﴾</span></span> مفعول مطلق لفعل محذوف أي: بعدوا بعدا، فهو مصدر بمعنى الدعاء عليهم، و<span class="hlt"><span class="qpc-hafs">﴿لعاد﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿بعدا﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿قوم﴾</span></span> بدل أو عطف بيان، و<span class="hlt"><span class="qpc-hafs">﴿هود﴾</span></span> مضاف إليه.</p></div>"
  11,61,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وإلى ثمود أخاهم صالحا﴾</span></span>: عطف على القصة السابقة، والمعطوف محذوف، أي: وأرسلنا إلى ثمود، فيكون من عطف الجمل لا من عطف المفردات، لطول الفصل، وأخاهم مفعول لأرسلنا المحذوفة، وصالحا بدل أو عطف بيان.</p><p><span class="hlt"><span class="qpc-hafs">﴿قال يا قوم اعبدوا الله ما لكم من إله غيره﴾</span></span>: اعبدوا الله فعل أمر وفاعل ومفعول به، وما نافية، ولكم خبر مقدم، ومن حرف صلة، وإله مجرور لفظًا مرفوع محلاًّ،، لأنه مبتدأ مؤخر، وغيره صفة لإله على المحل.</p><p><span class="hlt"><span class="qpc-hafs">﴿هو أنشأكم من الأرض واستعمركم فيها﴾</span></span>: هو مبتدأ، وجملة أنشأكم خبر، ومن الأرض جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أنشأكم﴾</span></span>، واستعمركم فيها عطف على أنشأكم.</p><p><span class="hlt"><span class="qpc-hafs">﴿فاستغفروه ثم توبوا إليه﴾</span></span>: الفاء الفصيحة، واستغفروه فعل أمر وفاعل ومفعول به، ثم حرف عطف، وتوبوا إليه عطف على استغفروه.</p><p><span class="hlt"><span class="qpc-hafs">﴿إن ربي قريب مجيب﴾</span></span>: إن حرف ناسخ، وربي اسمها، وقريب مجيب خبراها.</p></div>"
  11,62,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قالوا يا صالح قد كنت فينا مرجوا قبل هذا﴾</span></span>: قد حرف تحقيق، وكنت فعل ماض ناقص ناسخ، والتاء اسمها، ومرجوًّا خبرها، و<span class="hlt"><span class="qpc-hafs">﴿فينا﴾</span></span> جار ومجرور متعلقان بمحذوف حال، و<span class="hlt"><span class="qpc-hafs">﴿قبل﴾</span></span> ظرف متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿مرجوًّا﴾</span></span>، وهذا مضاف إليه.</p><p><span class="hlt"><span class="qpc-hafs">﴿أتنهانا أن نعبد ما يعبد آباؤنا﴾</span></span>: الهمزة للاستفهام الإنكاري، وتنهانا فعل مضارع وفاعل مستتر ومفعول به، وأن وما في حيزها في تأويل مصدر منصوب بنزع الخافض، والجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تنهانا﴾</span></span>، وآباؤنا فاعل يعبد.</p><p><span class="hlt"><span class="qpc-hafs">﴿وإننا لفي شك مما تدعونا إليه مريب﴾</span></span>: الواو استئنافية، والجملة بعدها مستأنفة لا محل لها من الإعراب، وإن حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> اسمها، واللام المزحلقة، و<span class="hlt"><span class="qpc-hafs">﴿في شك﴾</span></span> جار ومجرور متعلقان بمحذوف خبر <span class="hlt"><span class="qpc-hafs">﴿إننا﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿مما﴾</span></span> جار ومجرور متعلقان بمحذوف صفة لـ<span class="hlt"><span class="qpc-hafs">﴿شك﴾</span></span>، وجملة تدعونا صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> لا محل لها من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> مفعول تدعو، وإليه جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تدعو﴾</span></span>، ومريب صفة لـ<span class="hlt"><span class="qpc-hafs">﴿شك﴾</span></span>.</p></div>"