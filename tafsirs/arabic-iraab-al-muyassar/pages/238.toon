quran[8]{c,v,t}:
  12,23,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وراودته التي هو في بيتها عن نفسه وغلقت الأبواب وقالت هيت لك﴾</span></span>: جمل معطوفة، <span class="hlt"><span class="qpc-hafs">﴿وراودته التي﴾</span></span> فعل ومفعول به وفاعل، و<span class="hlt"><span class="qpc-hafs">﴿هو في بيتها﴾</span></span> صلة <span class="hlt"><span class="qpc-hafs">﴿التي﴾</span></span> لا محل لها من الإعراب، <span class="hlt"><span class="qpc-hafs">﴿عن نفسه﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿راودته﴾</span></span>، وغلقت الأبواب معطوفة على راودته، وقالت معطوفة أيضا، و<span class="hlt"><span class="qpc-hafs">﴿هيت﴾</span></span> اسم فعل ماض مبني على الفتح بمعنى: تهيأت، أو اسم فعل أمر بمعنى: أقبل، والفاعل مستتر تقديره: أنت، و<span class="hlt"><span class="qpc-hafs">﴿لك﴾</span></span> جار ومجرور متعلقان بمحذوف أي: أقول.</p><p><span class="hlt"><span class="qpc-hafs">﴿قال معاذ الله إنه ربي أحسن مثواي﴾</span></span>: معاذ الله نصب على المصدر، أي: أعوذ بالله معاذًا، و<span class="hlt"><span class="qpc-hafs">﴿إنه﴾</span></span> إن حرف ناسخ، والهاء اسمها، وربي خبرها.</p><p><span class="hlt"><span class="qpc-hafs">﴿إنه لا يفلح الظالمون﴾</span></span>: إن حرف ناسخ، والهاء اسمها، وجملة <span class="hlt"><span class="qpc-hafs">﴿لا يفلح الظالمون﴾</span></span> خبرها، والضمير يعود للشأن هنا.</p></div>"
  12,24,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ولقد همت به وهم بها لولا أن رأى برهان ربه﴾</span></span>: اللام جواب للقسم المحذوف، وقد حرف تحقيق، وهمت فعل ماض، والفاعل مستتر تقديره: هي، و<span class="hlt"><span class="qpc-hafs">﴿به﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿همت﴾</span></span>، وهمّ فعل ماض، وفاعله: هو، و<span class="hlt"><span class="qpc-hafs">﴿بها﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿همّ﴾</span></span>، ولولا حرف امتناع لوجود، وأن وما في حيزها مبتدأ محذوف الخبر، أي: لولا رؤيته برهان ربه ماثلا أمامه، وجواب لولا محذوف، أي: لواقعها.</p><p><span class="hlt"><span class="qpc-hafs">﴿كذلك لنصرف عنه السوء والفحشاء﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿كذلك﴾</span></span> الكاف: اسم بمعنى مثل مبني على الفتح في محل نصب صفة لمصدر محذوف، والتقدير: ثبتناه تثبيتًا مثلَ ذلك التثبيت، أو أريناه برهان ربه إراءً مثلَ ذلك الإراء لنصرف عنه السوء، وذلك: <span class="hlt"><span class="qpc-hafs">﴿ذا﴾</span></span> اسم إشارة في محل جر مضاف إليه، واللام للبعد، والكاف حرف خطاب. و<span class="hlt"><span class="qpc-hafs">﴿لنصرف﴾</span></span> اللام للتعليل، ونصرف: فعل مضارع منصوب بأن مضمرة بعد اللام، والفاعل مستتر تقديره: نحن، والمصدر المؤول من <span class="hlt"><span class="qpc-hafs">﴿أن﴾</span></span> المضمرة والفعلِ مجرور باللام، واللام ومجرورها متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿ثبتناه﴾</span></span> أو <span class="hlt"><span class="qpc-hafs">﴿أريناه﴾</span></span> المقدر، و<span class="hlt"><span class="qpc-hafs">﴿السوء﴾</span></span> مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿الفحشاء﴾</span></span> عطف على السوء.</p><p><span class="hlt"><span class="qpc-hafs">﴿إنه من عبادنا المخلصين﴾</span></span>: إن حرف ناسخ، والهاء اسمها، و<span class="hlt"><span class="qpc-hafs">﴿من عبادنا﴾</span></span> جار ومجرور متعلقان بمحذوف خبر، والمخلصين صفة لـ<span class="hlt"><span class="qpc-hafs">﴿عبادنا﴾</span></span>.</p></div>"
  12,25,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿واستبقا الباب وقدت قميصه من دبر﴾</span></span>: الواو عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿استبقا﴾</span></span> فعل ماض، والألف فاعل، والباب منصوب بنزع الخافض، و<span class="hlt"><span class="qpc-hafs">﴿قدّت قميصه﴾</span></span> قدّ فعل ماض، وفاعله: هي، وقميصه مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿من دبر﴾</span></span> جار ومجرور متعلقان بمحذوف حال، أو <span class="hlt"><span class="qpc-hafs">﴿قدت﴾</span></span> معطوف على <span class="hlt"><span class="qpc-hafs">﴿واستبقا﴾</span></span>، أو حال، أي: وقد قدت.</p><p><span class="hlt"><span class="qpc-hafs">﴿وألفيا سيدها لدا الباب﴾</span></span>: الواو عاطفة، وألفيا عطف على ما تقدم، والألف فاعل، وسيدها مفعول به، ولدى ظرف في محل نصب مفعول به ثان.</p><p><span class="hlt"><span class="qpc-hafs">﴿قالت ما جزاء من أراد بأهلك سوءا إلا أن يسجن أو عذاب أليم﴾</span></span>: ما اسم استفهام مبتدأ، وجزاء خبر، و<span class="hlt"><span class="qpc-hafs">﴿مَن﴾</span></span> مضاف إليه، وجملة أراد صلة <span class="hlt"><span class="qpc-hafs">﴿مَن﴾</span></span> لا محل لها من الإعراب، وبـ<span class="hlt"><span class="qpc-hafs">﴿أهلك﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أراد﴾</span></span>، وسوءًا مفعول به، وإلا أداة حصر، والمصدر المؤول من أن وما في حيزها بدل من جزاء، أي: إلا السجن، أو <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> نافية، وجزاء مبتدأ، والمصدر المؤول من <span class="hlt"><span class="qpc-hafs">﴿أن يسجن﴾</span></span> خبره، و<span class="hlt"><span class="qpc-hafs">﴿أو﴾</span></span> حرف عطف، وعذاب عطف على المصدر المؤول، وأليم صفة، و<span class="hlt"><span class="qpc-hafs">﴿مَن﴾</span></span> اسم موصول، وجملة <span class="hlt"><span class="qpc-hafs">﴿أراد﴾</span></span> صلة <span class="hlt"><span class="qpc-hafs">﴿مَن﴾</span></span> لا محل لها من الإعراب، أو نكرة موصوفة وجملة <span class="hlt"><span class="qpc-hafs">﴿أراد﴾</span></span> صفة لـ<span class="hlt"><span class="qpc-hafs">﴿مَن﴾</span></span>.</p></div>"
  12,26,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قال هي راودتني عن نفسي﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿قال﴾</span></span> فعل ماض، وفاعله مستتر، و<span class="hlt"><span class="qpc-hafs">﴿هي﴾</span></span> مبتدأ، وجملة راودتني خبر، وعن نفسي جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿راودتني﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿وشهد شاهد من أهلها﴾</span></span>: الواو عاطفة، وشهد شاهد فعل وفاعل، و<span class="hlt"><span class="qpc-hafs">﴿من أهلها﴾</span></span> جار ومجرور متعلقان بمحذوف صفة <span class="hlt"><span class="qpc-hafs">﴿شاهد﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿إن كان قميصه قد من قبل فصدقت وهو من الكاذبين﴾</span></span>: الشرط مقول قول محذوف، أي: فقال، وإن شرطية، و<span class="hlt"><span class="qpc-hafs">﴿كان قميصه﴾</span></span> كان فعل ماض ناقص ناسخ، وقميصه اسمها، وجملة <span class="hlt"><span class="qpc-hafs">﴿قدّ﴾</span></span> خبر، و<span class="hlt"><span class="qpc-hafs">﴿من قبل﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿قدّ﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿فصدقت﴾</span></span> الفاء رابطة، وصدقت فعل ماض، والجملة جواب الشرط، أي: فقد ظهر صدقها، <span class="hlt"><span class="qpc-hafs">﴿وهو﴾</span></span> الواو حالية، و<span class="hlt"><span class="qpc-hafs">﴿هو﴾</span></span> مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿من الكاذبين﴾</span></span> جار ومجرور متعلقان بمحذوف خبر.</p></div>"
  12,27,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وإن كان قميصه قد من دبر فكذبت وهو من الصادقين﴾</span></span>: عطف على الجملة الأولى، والشرط مقول قول محذوف، أي: وقال، وإن شرطية، و<span class="hlt"><span class="qpc-hafs">﴿كان قميصه﴾</span></span> كان فعل ماض ناقص ناسخ، وقميصه اسمها، وجملة <span class="hlt"><span class="qpc-hafs">﴿قدّ﴾</span></span> خبر، و<span class="hlt"><span class="qpc-hafs">﴿من دبر﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿قدّ﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿فكذبت﴾</span></span> الفاء رابطة، وكذبت فعل ماض، والجملة جواب الشرط، أي: فقد ظهر كذبها، <span class="hlt"><span class="qpc-hafs">﴿وهو﴾</span></span> الواو حالية، و<span class="hlt"><span class="qpc-hafs">﴿هو﴾</span></span> مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿من الصادقين﴾</span></span> جار ومجرور متعلقان بمحذوف خبر.</p></div>"
  12,28,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فلما رأى قميصه قد من دبر قال إنه من كيدكن﴾</span></span>: الفاء عاطفة، ولما حينية، أو رابطة، ورأى قميصه فعل وفاعل مستتر ومفعول، وجملة <span class="hlt"><span class="qpc-hafs">﴿قد من دبر﴾</span></span> حالية، و<span class="hlt"><span class="qpc-hafs">﴿قال﴾</span></span> جواب لما، وإن حرف ناسخ، والهاء اسمها، و<span class="hlt"><span class="qpc-hafs">﴿من كيدكن﴾</span></span> جار ومجرور متعلقان بمحذوف خبرها.</p><p><span class="hlt"><span class="qpc-hafs">﴿إن كيدكن عظيم﴾</span></span>: إن حرف ناسخ، وكيدكن اسمها، وعظيم خبرها.</p></div>"
  12,29,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿يوسف أعرض عن هذا واستغفري لذنبك﴾</span></span>: يوسف منادى محذوف منه حرف النداء، وأعرض فعل أمر، وفاعله مستتر تقديره: أنت، و<span class="hlt"><span class="qpc-hafs">﴿عن هذا﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أعرض﴾</span></span>، واستغفري فعل أمر، والياء فاعله، و<span class="hlt"><span class="qpc-hafs">﴿لذنبك﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿استغفري﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿إنك كنت من الخاطئين﴾</span></span>: إن حرف ناسخ، والكاف اسمها، وكنت فعل ماض ناقص ناسخ، والتاء اسمها، و<span class="hlt"><span class="qpc-hafs">﴿من الخاطئين﴾</span></span> جار ومجرور متعلقان بمحذوف خبرها، وجملة <span class="hlt"><span class="qpc-hafs">﴿كنت﴾</span></span> خبر إن.</p></div>"
  12,30,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وقال نسوة في المدينة﴾</span></span>: الواو عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿قال نسوة﴾</span></span> فعل وفاعل، و<span class="hlt"><span class="qpc-hafs">﴿في المدينة﴾</span></span> جار ومجرور متعلقان بمحذوف صفة لـ<span class="hlt"><span class="qpc-hafs">﴿نسوة﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿امرأت العزيز تراود فتاها عن نفسه قد شغفها حبا إنا لنراها في ضلال مبين﴾</span></span>: امرأة العزيز مبتدأ، وجملة تراود خبر، وفتاها مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿عن نفسه﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تراود﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿قد﴾</span></span> حرف تحقيق، وشغفها فعل وفاعل مستتر ومفعول به، وحبًّا تمييز محول عن الفاعل، وجملة <span class="hlt"><span class="qpc-hafs">﴿قد شغفها﴾</span></span> حال من فاعل تراود، أو من مفعوله، أو خبر ثان لـ<span class="hlt"><span class="qpc-hafs">﴿امرأة﴾</span></span>.</p></div>"