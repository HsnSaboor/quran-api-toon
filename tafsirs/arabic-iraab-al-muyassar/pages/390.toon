quran[8]{c,v,t}:
  28,36,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فلما جاءهم موسى بآياتنا بينات قالوا ما هذا إلا سحر مفترى﴾</span></span>: الفاء عاطفة على محذوف، ولما ظرفية حينية، أو رابطة، و<span class="hlt"><span class="qpc-hafs">﴿جاءهم موسى﴾</span></span> فعل ومفعول وفاعل، وبآياتنا جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿جاءهم﴾</span></span>، أو بمحذوف حال، وبينات حال، وجملة قالوا جواب لما، وما نافية، وهذا مبتدأ، وإلا أداة حصر، وسحر خبر، ومفترى صفة.</p><p><span class="hlt"><span class="qpc-hafs">﴿وما سمعنا بهذا في آبائنا الأولين﴾</span></span>: الواو عاطفة، وما نافية، وسمعنا: فعل وفاعل، وبهذا: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿سمعنا﴾</span></span>، وفي آبائنا: جار ومجرور متعلقان بمحذوف حال من <span class="hlt"><span class="qpc-hafs">﴿هذا﴾</span></span>، والأولين: نعت لـ<span class="hlt"><span class="qpc-hafs">﴿آبائنا﴾</span></span>.</p></div>"
  28,37,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وقال موسى ربي أعلم بمن جاء بالهدى من عنده﴾</span></span>: ربي مبتدأ، وأعلم خبره، وبمن جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أعلم﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿جاء بالهدى﴾</span></span> صلة <span class="hlt"><span class="qpc-hafs">﴿مَن﴾</span></span> لا محل لها من الإعراب. و<span class="hlt"><span class="qpc-hafs">﴿من عنده﴾</span></span> جار ومجرور متعلقان بمحذوف حال.</p><p><span class="hlt"><span class="qpc-hafs">﴿ومن تكون له عاقبة الدار إنه لا يفلح الظالمون﴾</span></span>: الواو عاطفة، ومَن: عطف على مَن الأولى، وتكون: فعل مضارع ناقص، و<span class="hlt"><span class="qpc-hafs">﴿له﴾</span></span> جار ومجرور متعلقان بمحذوف خبر تكون المقدم، و<span class="hlt"><span class="qpc-hafs">﴿عاقبة الدار﴾</span></span> اسمها المؤخر، وإن حرف ناسخ، والهاء اسمها، وجملة <span class="hlt"><span class="qpc-hafs">﴿لا يفلح الظالمون﴾</span></span> خبرها.</p></div>"
  28,38,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وقال فرعون يا أيها الملأ ما علمت لكم من إله غيري﴾</span></span>: الواو عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿قال فرعون﴾</span></span> فعل ماض وفاعل مرفوع، ويا حرف نداء، و<span class="hlt"><span class="qpc-hafs">﴿أي﴾</span></span> منادى نكرة مقصودة بني على الضم في محل نصب، و<span class="hlt"><span class="qpc-hafs">﴿ها﴾</span></span> للتنبيه، والملأ صفة لـ<span class="hlt"><span class="qpc-hafs">﴿أي﴾</span></span>، وما نافية، و<span class="hlt"><span class="qpc-hafs">﴿علمت﴾</span></span> فعل وفاعل، ولكم: جار ومجرور متعلقان بمحذوف حال، ومن حرف صلة، و<span class="hlt"><span class="qpc-hafs">﴿إله﴾</span></span> مجرور لفظًا بمن، منصوب محلًّا، لأنه مفعول به، وغيري صفة لـ<span class="hlt"><span class="qpc-hafs">﴿إله﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿فأوقد لي يا هامان على الطين فاجعل لي صرحا﴾</span></span>: الفاء الفصيحة، وأوقد فعل أمر، وفاعله مستتر، تقديره: أنت، و<span class="hlt"><span class="qpc-hafs">﴿لي﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أوقد﴾</span></span>، ويا حرف نداء، و<span class="hlt"><span class="qpc-hafs">﴿هامان﴾</span></span> منادى مفرد علم، و<span class="hlt"><span class="qpc-hafs">﴿على الطين﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أوقد﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿فاجعل﴾</span></span> عطف على <span class="hlt"><span class="qpc-hafs">﴿أوقد﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿لي﴾</span></span> جار ومجرور متعلقان بمحذوف مفعول ثان لـ<span class="hlt"><span class="qpc-hafs">﴿اجعل﴾</span></span>، وصرحًا: مفعول أول.</p><p><span class="hlt"><span class="qpc-hafs">﴿لعلي أطلع إلى إله موسى وإني لأظنه من الكاذبين﴾</span></span>: لعل حرف ناسخ للترجي، والياء اسمها، وجملة <span class="hlt"><span class="qpc-hafs">﴿أطلع﴾</span></span> خبرها، و<span class="hlt"><span class="qpc-hafs">﴿إلى إله موسى﴾</span></span> الجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أطلع﴾</span></span>، وإني الواو عاطفة، وإن حرف ناسخ، والياء اسمها، واللام المزحلقة، وجملة أظنه خبرها، والهاء مفعول به أول، و<span class="hlt"><span class="qpc-hafs">﴿من الكاذبين﴾</span></span> جار ومجرور متعلقان بمحذوف مفعول ثان.</p></div>"
  28,39,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿واستكبر هو وجنوده في الأرض بغير الحق﴾</span></span>: الواو عاطفة، واستكبر فعل ماض، و<span class="hlt"><span class="qpc-hafs">﴿هو﴾</span></span> فاعل استكبر لأن استتار الضمير في الغائب جائز الظهور، أو توكيد للفاعل المستتر، وجنوده عطف على هو، وفي الأرض جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿استكبر﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿بغير الحق﴾</span></span> الجار والمجرور متعلقان بمحذوف حال من فاعل استكبر، أي: متلبسين بغير الحق.</p><p><span class="hlt"><span class="qpc-hafs">﴿وظنوا أنهم إلينا لا يرجعون﴾</span></span>: الواو عاطفة، وظنوا عطف على استكبر، وأن وما يليها سدت مسد مفعولي ظنوا، وإلينا: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يرجعون﴾</span></span>، ولا نافية، وجملة <span class="hlt"><span class="qpc-hafs">﴿لا يرجعون﴾</span></span> خبر أن.</p></div>"
  28,40,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فأخذناه وجنوده فنبذناهم في اليم فانظر كيف كان عاقبة الظالمين﴾</span></span>: الفاء عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿أخذناه﴾</span></span> فعل وفاعل ومفعول به، وجنوده: عطف على الهاء في أخذناه، أو مفعول معه، فنبذناهم: عطف على فأخذناه، وفي اليم: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿نبذناهم﴾</span></span>، فانظر: الفاء الفصيحة، وانظر فعل أمر، وكيف خبر مقدم لكان، وعاقبة الظالمين: اسمها المؤخر، ومضاف إليه.</p></div>"
  28,41,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وجعلناهم أئمة يدعون إلى النار ويوم القيامة لا ينصرون﴾</span></span>: الواو عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿جعلناهم﴾</span></span> فعل وفاعل ومفعول به أول، وأئمة مفعول به ثان، وجملة يدعون صفة لأئمة، و<span class="hlt"><span class="qpc-hafs">﴿إلى النار﴾</span></span>: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يدعون﴾</span></span>. <span class="hlt"><span class="qpc-hafs">﴿ويوم القيامة﴾</span></span>: الواو عاطفة، ويوم: ظرف متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿ينصرون﴾</span></span>، ولا نافية، وينصرون فعل مضارع مبني لما لم يسمَّ فاعله، والواو ضمير مبني في محل رفع نائب فاعل.</p></div>"
  28,42,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وأتبعناهم في هذه الدنيا لعنة﴾</span></span>: الواو عاطفة، وأتبعناهم فعل وفاعل ومفعول به، و<span class="hlt"><span class="qpc-hafs">﴿في هذه﴾</span></span> جار ومجرور متعلقان بمحذوف حال، والدنيا بدل من <span class="hlt"><span class="qpc-hafs">﴿هذه﴾</span></span>، ولعنة مفعول به ثان.</p><p><span class="hlt"><span class="qpc-hafs">﴿ويوم القيامة هم من المقبوحين﴾</span></span>: الواو عاطفة، ويوم ظرف زمان منصوب متعلق بفعل محذوف يدل عليه السياق، وتقديره: قُبحوا، ويصح تعليقه باسم المفعول <span class="hlt"><span class="qpc-hafs">﴿المقبوحين﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿من المقبوحين﴾</span></span> جار ومجرور متعلقان بمحذوف خبر.</p></div>"
  28,43,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ولقد آتينا موسى الكتاب من بعد ما أهلكنا القرون الأولى﴾</span></span>: الواو استئنافية، واللام جواب للقسم المحذوف، وقد حرف تحقيق، وآتينا: فعل وفاعل، وموسى: مفعول به أول، الكتاب: مفعول به ثان، وجملة <span class="hlt"><span class="qpc-hafs">﴿ولقد آتينا موسى...﴾</span></span> مستأنفة لا محل لها من الإعراب، ومن بعد: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿آتينا﴾</span></span>، وما مصدرية، وأهلكنا: فعل وفاعل، والقرون: مفعول به، والأولى: صفة.</p><p><span class="hlt"><span class="qpc-hafs">﴿بصائر للناس وهدى ورحمة لعلهم يتذكرون﴾</span></span>: بصائر: حال من الكتاب، على تقدير مضاف، أي: ذا بصائر، أو على المبالغة، أو مفعول لأجله، وللناس: جار ومجرور متعلقان بمحذوف نعت لبصائر، <span class="hlt"><span class="qpc-hafs">﴿وهدى ورحمة﴾</span></span> عطف على بصائر، ولعلهم يتذكرون: لعل حرف ناسخ للترجي، و<span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> اسمها، وجملة يتذكرون خبرها.</p></div>"