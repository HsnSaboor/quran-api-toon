quran[10]{c,v,t}:
  22,6,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ذلك بأن الله هو الحق﴾</span></span>: ذلك مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿بأن الله هو الحق﴾</span></span> الباء حرف جر، و<span class="hlt"><span class="qpc-hafs">﴿أن الله﴾</span></span>: أن حرف ناسخ، ولفظ الجلالة اسمها، و<span class="hlt"><span class="qpc-hafs">﴿هو﴾</span></span> مبتدأ، والحق خبر، والمبتدأ وخبره <span class="hlt"><span class="qpc-hafs">﴿هو الحق﴾</span></span> خبر أن في محل رفع، والجار والمجرور متعلقان بخبر المبتدأ ذلك.</p><p><span class="hlt"><span class="qpc-hafs">﴿وأنه يحيي الموتى﴾</span></span>: الواو عاطفة، وأنه عطف على بأن، و<span class="hlt"><span class="qpc-hafs">﴿أنه﴾</span></span>: أن حرف ناسخ، والهاء اسمها، وجملة <span class="hlt"><span class="qpc-hafs">﴿يحيي الموتى﴾</span></span> خبرها.</p><p><span class="hlt"><span class="qpc-hafs">﴿وأنه على كل شيء قدير﴾</span></span>: الواو عاطفة، وأنه: أن حرف ناسخ، والهاء اسمها، و<span class="hlt"><span class="qpc-hafs">﴿على كل شيء﴾</span></span>: جار ومجرور ومضاف إليه، والجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿قدير﴾</span></span>، وقدير خبر أن.</p></div>"
  22,7,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وأن الساعة آتية لا ريب فيها﴾</span></span>: الواو عاطفة، وأن الساعة خبر لمبتدأ محذوف، أي: والأمر أن الساعة. وأن الساعة: أن حرف ناسخ، والساعة اسمها، و<span class="hlt"><span class="qpc-hafs">﴿آتية﴾</span></span> خبرها، ولا نافية للجنس، وريب اسم لا، وفيها جار ومجرور متعلقان بمحذوف خبر لا، والجملة حالية أو خبر ثان لأن.</p><p><span class="hlt"><span class="qpc-hafs">﴿وأن الله يبعث من في القبور﴾</span></span>: الواو عاطفة، وأن حرف ناسخ، ولفظ الجلالة اسمها، وجملة <span class="hlt"><span class="qpc-hafs">﴿يبعث﴾</span></span> خبرها، ومن مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿في القبور﴾</span></span> جار ومجرور متعلقان بمحذوف صلة <span class="hlt"><span class="qpc-hafs">﴿من﴾</span></span>، وجملة الصلة لا محل لها من الإعراب.</p></div>"
  22,8,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ومن الناس من يجادل في الله بغير علم ولا هدى ولا كتاب منير﴾</span></span>: الواو استئنافية، ومن الناس: خبر مقدم، ومن: اسم موصول في محل رفع مبتدأ مؤخر، وجملة <span class="hlt"><span class="qpc-hafs">﴿يجادل﴾</span></span> صلة الموصول لا محل لها من الإعراب، وفي الله جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يجادل﴾</span></span> على حذف مضاف، أي: قدرته، وصفاته، ودينه، و<span class="hlt"><span class="qpc-hafs">﴿بغير﴾</span></span> جار ومجرور متعلقان بمحذوف حال من ضمير الفاعل المستتر في يجادل، أي: يجادل جاهلا، و<span class="hlt"><span class="qpc-hafs">﴿علم﴾</span></span> مضاف إليه، وجملة <span class="hlt"><span class="qpc-hafs">﴿ومن الناس...﴾</span></span> مستأنفة لا محل لها من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿لا هدى﴾</span></span>: عطف على علم، و<span class="hlt"><span class="qpc-hafs">﴿لا كتاب﴾</span></span>: عطف أيضًا، ومنير صفة لكتاب.</p></div>"
  22,9,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ثاني عطفه ليضل عن سبيل الله﴾</span></span>: ثاني حال من فاعل يجادل، وعطفه مضاف إليه، و<span class="hlt"><span class="qpc-hafs">﴿ليضل﴾</span></span>: اللام للتعليل أو للعاقبة والصيرورة، ويضل فعل مضارع منصوب بأن مضمرة بعد اللام، والمصدر المؤول من أن والفعل مجرور باللام، والجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يجادل﴾</span></span>، والفاعل مستتر تقديره هو، و<span class="hlt"><span class="qpc-hafs">﴿عن سبيل الله﴾</span></span> الجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يضل﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿له في الدنيا خزي ونذيقه يوم القيامة عذاب الحريق﴾</span></span>: له خبر مقدم، و<span class="hlt"><span class="qpc-hafs">﴿في الدنيا﴾</span></span> جار ومجرور متعلقان بمحذوف حال، لأنه كان صفة لخزي وتقدم، و<span class="hlt"><span class="qpc-hafs">﴿خزي﴾</span></span> مبتدأ مؤخر. ونذيقه: الواو عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿نذيقه﴾</span></span> فعل وفاعل مستتر ومفعول به، و<span class="hlt"><span class="qpc-hafs">﴿يوم القيامة﴾</span></span> ظرف متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿نذيقه﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿عذاب الحريق﴾</span></span> مفعول به ثان، وجملة <span class="hlt"><span class="qpc-hafs">﴿له في الدنيا ...﴾</span></span> حالية.</p></div>"
  22,10,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ذلك بما قدمت يداك وأن الله ليس بظلام للعبيد﴾</span></span>: ذلك مبتدأ، وبما خبر، وقدمت صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> لا محل لها من الإعراب، ويداك فاعل، وأن الله: أن حرف ناسخ، ولفظ الجلالة اسمها، <span class="hlt"><span class="qpc-hafs">﴿ليس بظلام للعبيد﴾</span></span>: اسم ليس مستتر تقديره هو، والباء حرف جر صلة، وظلام اسم مجرور لفظًا منصوب محلا خبر ليس، وللعبيد جار ومجرور متعلقان بظلام، وجملة <span class="hlt"><span class="qpc-hafs">﴿ليس بظلام للعبيد﴾</span></span> خبر أن، وجملة <span class="hlt"><span class="qpc-hafs">﴿وأنّ الله ...﴾</span></span> عطف على <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> المجرورة فهي في محل جر، وجملة <span class="hlt"><span class="qpc-hafs">﴿ذلك بما قدمت يداك﴾</span></span> مقول قول محذوف، وجملة القول حالية.</p></div>"
  22,11,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ومن الناس من يعبد الله على حرف﴾</span></span>: الواو عاطفة أو استئنافية، ومن الناس خبر مقدم، و<span class="hlt"><span class="qpc-hafs">﴿مَن﴾</span></span> اسم موصول في محل رفع مبتدأ مؤخر، وجملة <span class="hlt"><span class="qpc-hafs">﴿يعبد الله﴾</span></span> صلة الموصول لا محل لها من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿على حرف﴾</span></span> جار ومجرور متعلقان بمحذوف حال من فاعل يعبد، أي: مضطربًا، والجملة معطوفة، مستأنفة لا محل لها من الإعراب.</p><p><span class="hlt"><span class="qpc-hafs">﴿فإن أصابه خير اطمأن به وإن أصابته فتنة انقلب على وجهه خسر الدنيا والآخرة﴾</span></span>: فإن: الفاء عاطفة، وإن شرطية، وأصابه فعل ماض في محل جزم فعل الشرط، والهاء مفعول به، وخير فاعل، واطمأن فعل ماض في محل جزم جواب الشرط، و<span class="hlt"><span class="qpc-hafs">﴿به﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿اطمأن﴾</span></span>، وإن: معطوفة على إن الأولى، وأصابته فعل ماض في محل جزم فعل الشرط والتاء حرف تأنيث والهاء مفعول به، وفتنة فاعل، وانقلب جواب الشرط، و<span class="hlt"><span class="qpc-hafs">﴿على وجهه﴾</span></span> جار ومجرور متعلقان بمحذوف حال، وجملة <span class="hlt"><span class="qpc-hafs">﴿خسر الدنيا والآخرة﴾</span></span> حال أيضًا من فاعل انقلب، والدنيا مفعول خسر، والآخرة عطف على الدنيا.</p><p><span class="hlt"><span class="qpc-hafs">﴿ذلك هو الخسران المبين﴾</span></span>: ذلك مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿هو﴾</span></span> مبتدأ ثان، والخسران خبر هو، وجملة <span class="hlt"><span class="qpc-hafs">﴿هو الخسران﴾</span></span> خبر ذلك، أو <span class="hlt"><span class="qpc-hafs">﴿هو﴾</span></span> ضمير فصل و<span class="hlt"><span class="qpc-hafs">﴿الخسران﴾</span></span> خبر ذلك، والمبين نعت لـ<span class="hlt"><span class="qpc-hafs">﴿الخسران﴾</span></span>، والجملة مستأنفة لا محل لها من الإعراب.</p></div>"
  22,12,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿يدعو من دون الله ما لا يضره وما لا ينفعه﴾</span></span>: الجملة مستأنفة لا محل لها من الإعراب، ويدعو فعل مضارع، وفاعله ضمير مستتر تقديره هو، و<span class="hlt"><span class="qpc-hafs">﴿من دون الله﴾</span></span>: الجار والمجرور متعلقان بمحذوف حال، وما: اسم موصول مفعول به، ولا نافية، وجملة <span class="hlt"><span class="qpc-hafs">﴿لا يضره﴾</span></span> صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> لا محل لها من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿ما لا ينفعه﴾</span></span>: عطف على الجملة السابقة.</p><p><span class="hlt"><span class="qpc-hafs">﴿ذلك هو الضلال البعيد﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿ذلك﴾</span></span> مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿هو﴾</span></span> مبتدأ ثان، و<span class="hlt"><span class="qpc-hafs">﴿الضلال﴾</span></span> خبر <span class="hlt"><span class="qpc-hafs">﴿هو﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿هو الضلال﴾</span></span> خبر <span class="hlt"><span class="qpc-hafs">﴿ذلك﴾</span></span>، أو <span class="hlt"><span class="qpc-hafs">﴿هو﴾</span></span> ضمير فصل، و<span class="hlt"><span class="qpc-hafs">﴿الضلال﴾</span></span> خبر <span class="hlt"><span class="qpc-hafs">﴿ذلك﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿البعيد﴾</span></span> نعت للضلال، والجملة مستأنفة لا محل لها من الإعراب.</p></div>"
  22,13,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿يدعو لمن ضره أقرب من نفعه لبئس المولى ولبئس العشير﴾</span></span>: الجملة بدل من جملة يدعو السابقة لا محل لها من الإعراب، ويدعو فعل مضارع، واللام للابتداء، أو واقعة في جواب القسم، ومَن اسم موصول مبتدأ، والفعل يدعو من أفعال القلوب متضمنة معنى يزعم، والخبر محذوف تقديره: <span class="hlt"><span class="qpc-hafs">﴿آلهة﴾</span></span>، وضره مبتدأ ثان، و<span class="hlt"><span class="qpc-hafs">﴿أقرب﴾</span></span> خبر ضره، ومن نفعه جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أقرب﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿ضره أقرب من نفعه﴾</span></span> صلة <span class="hlt"><span class="qpc-hafs">﴿مَن﴾</span></span> لا محل لها من الإعراب، وجملة <span class="hlt"><span class="qpc-hafs">﴿لمن ضره أقرب من نفعه﴾</span></span> في محل نصب على المفعول به لأن لام الابتداء معلقة لها عن العمل. و<span class="hlt"><span class="qpc-hafs">﴿بئس﴾</span></span> فعل ماض جامد لإنشاء الذم، والمولى فاعل، والمخصوص بالذم محذوف تقديره: هو، ولبئس العشير معطوف على قوله: <span class="hlt"><span class="qpc-hafs">﴿لبئس المولى﴾</span></span>.</p></div>"
  22,14,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إن الله يدخل الذين آمنوا وعملوا الصالحات جنات تجري من تحتها الأنهار﴾</span></span>: الجملة مستأنفة لا محل لها من الإعراب، إن الله: إن حرف ناسخ، ولفظ الجلالة اسمها، وجملة <span class="hlt"><span class="qpc-hafs">﴿يدخل﴾</span></span> خبر إن، والذين مفعول به، وجملة <span class="hlt"><span class="qpc-hafs">﴿آمنوا﴾</span></span> صلة الموصول لا محل لها من الإعراب، وجملة <span class="hlt"><span class="qpc-hafs">﴿عملوا الصالحات﴾</span></span> عطف على آمنوا، وجنات مفعول به ثان على السعة أو نصب بنزع الخافض، وجملة <span class="hlt"><span class="qpc-hafs">﴿تجري من تحتها النهار﴾</span></span> صفة لجنات.</p><p><span class="hlt"><span class="qpc-hafs">﴿إن الله يفعل ما يريد﴾</span></span>: جملة مستأنفة لا محل لها من الإعراب، وهي  لتعليل ما تقدم. إن الله: إن حرف ناسخ، ولفظ الجلالة اسمها، وجملة <span class="hlt"><span class="qpc-hafs">﴿يفعل﴾</span></span> خبر إن، وفاعل يفعل مستتر تقديره هو، وما مفعول به، وجملة <span class="hlt"><span class="qpc-hafs">﴿يريد﴾</span></span> صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> لا محل لها من الإعراب.</p></div>"
  22,15,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿من كان يظن أن لن ينصره الله في الدنيا والآخرة﴾</span></span>: من: شرطية في محل رفع مبتدأ. وكان: فعل ماض ناقص، واسم كان مستتر يعود على <span class="hlt"><span class="qpc-hafs">﴿من﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿يظن﴾</span></span> خبر كان، وأن مخففة من الثقيلة، واسمها ضمير الشأن محذوف، وجملة <span class="hlt"><span class="qpc-hafs">﴿لن ينصره الله﴾</span></span> خبر أن، وأن وما بعدها سدت مسد مفعولي يظن، و<span class="hlt"><span class="qpc-hafs">﴿في الدنيا﴾</span></span>: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿ينصره﴾</span></span>، والآخرة عطف على الدنيا.</p><p><span class="hlt"><span class="qpc-hafs">﴿فليمدد بسبب إلى السماء ثم ليقطع فلينظر هل يذهبن كيده ما يغيظ﴾</span></span>: الفاء رابطة لجواب الشرط، واللام لام الأمر، ويمدد فعل مضارع مجزوم بلام الأمر، والفاعل مستتر تقديره هو، وبسبب جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يمدد﴾</span></span>، وإلى السماء جار ومجرور متعلقان بمحذوف صفة لسبب. <span class="hlt"><span class="qpc-hafs">﴿ثم ليقطع﴾</span></span>: عطف على فليمدد، و<span class="hlt"><span class="qpc-hafs">﴿هل﴾</span></span> حرف استفهام، ويذهبن فعل مضارع مبني على الفتح، وكيده فاعل، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> مفعول يذهبن، وجملة <span class="hlt"><span class="qpc-hafs">﴿يغيظ﴾</span></span> صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> لا محل لها من الإعراب، وجملة <span class="hlt"><span class="qpc-hafs">﴿هل يذهبن﴾</span></span> في موضع نصب بـ<span class="hlt"><span class="qpc-hafs">﴿ينظر﴾</span></span>.</p></div>"