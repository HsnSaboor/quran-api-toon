quran[13]{c,v,t}:
  20,52,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قال علمها عند ربي في كتاب لا يضل ربي ولا ينسى﴾</span></span>: علمها مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿عند ربي﴾</span></span> الظرف متعلق بمحذوف خبر، و<span class="hlt"><span class="qpc-hafs">﴿في كتاب﴾</span></span> جار ومجرور متعلقان بمحذوف حال، أو متعلقان بمحذوف الخبر، و<span class="hlt"><span class="qpc-hafs">﴿عند ربي﴾</span></span> ظرف متعلق بمحذوف حال، أو هما متعلقان بمحذوفان خبران، أو هما متعلقان بمحذوف خبر واحد، وجملة لا يضل مستأنفة لا محل لها من الإعراب، وقيل: صفة لكتاب، والعائد محذوف تقديره: في كتاب لا يضله ربي، أو: لا يضل حفظه ربي، وربي فاعل يضل، ولا ينسى، عطف على لا يضل.</p></div>"
  20,53,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿الذي جعل لكم الأرض مهدا وسلك لكم فيها سبلا﴾</span></span>: الذي خبر لمبتدأ محذوف، أي: هو، وجملة جعل صلة الذي لا محل لها من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿لكم﴾</span></span> جار ومجرور متعلقان بمحذوف حال لأنه كان صفة لـ<span class="hlt"><span class="qpc-hafs">﴿مهدًا﴾</span></span> ثم تقدم عليه، والأرض مفعول به أول، ومهدًا مفعول به ثان، وسلك فعل ماض، والفاعل مستتر تقديره: هو، و<span class="hlt"><span class="qpc-hafs">﴿لكم﴾</span></span> جار ومجرور متعلقان بمحذوف حال، لأنه كان صفة لـ<span class="hlt"><span class="qpc-hafs">﴿سبلًا﴾</span></span>، وفيها جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿سلك﴾</span></span>، وسبلًا مفعول به.</p><p><span class="hlt"><span class="qpc-hafs">﴿وأنزل من السماء ماء فأخرجنا به أزواجا من نبات شتى﴾</span></span>: الواو عاطفة، وأنزل عطف على ما تقدم، ومن السماء جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أنزل﴾</span></span>، وماء مفعول به، فأخرجنا: الفاء عاطفة، وأخرجنا فعل وفاعل، و<span class="hlt"><span class="qpc-hafs">﴿به﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أخرجنا﴾</span></span>، وأزواجًا مفعول به، ومن نبات جار ومجرور متعلقان بمحذوف صفة لـ<span class="hlt"><span class="qpc-hafs">﴿أزواجًا﴾</span></span>، وشتى صفة لـ<span class="hlt"><span class="qpc-hafs">﴿أزواجًا﴾</span></span>، أو حال منه، لأنه وصف، وقيل: صفة للنبات.</p></div>"
  20,54,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿كلوا وارعوا أنعامكم إن في ذلك لآيات لأولي النهى﴾</span></span>: كلوا فعل أمر وفاعل، والجملة معمولة لحال محذوفة، أي: قائلين، وارعوا عطف على كلوا، وأنعامكم مفعول به لارعوا، وإن حرف ناسخ، وفي ذلك خبر إن المقدم، ولآيات اللام المزحلقة، وآيات اسم إن المؤخر، ولأولي النهى صفة لآيات، والنهى مضاف إليه.</p></div>"
  20,55,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿منها خلقناكم وفيها نعيدكم ومنها نخرجكم تارة أخرى﴾</span></span>: منها جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿خلقناكم﴾</span></span>، وفيها جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿نعيدكم﴾</span></span>، ومنها جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿نخرجكم﴾</span></span>، وتارة ظرف متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿نخرجكم﴾</span></span>، وأخرى صفة لتارة.</p></div>"
  20,56,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ولقد أريناه آياتنا كلها فكذب وأبى﴾</span></span>: اللام جواب لقسم محذوف، وقد حرف تحقيق، وأريناه فعل ماض، ونا ضمير متصل في محل رفع فاعل، والهاء مفعول به أول، وآياتنا مفعول به ثان، وكلها تأكيد لآياتنا، فكذب وأبى عطف على أريناه.</p></div>"
  20,57,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قال أجئتنا لتخرجنا من أرضنا بسحرك يا موسى﴾</span></span>: قال فعل ماض، وفاعله مستتر تقديره: هو، أي: فرعون، وجملة أجئتنا مقول القول، والهمزة للاستفهام الإنكاري، وجئتنا فعل، وفاعل، ومفعول به، ولتخرجنا اللام للتعليل، وتخرج فعل مضارع منصوب بأن مضمرة بعد لام التعليل، ونا مفعول به، والمصدر المؤول من أن والفعل مجرور باللام، والجار والمجرور متعلقان بجئتنا، و<span class="hlt"><span class="qpc-hafs">﴿من أرضنا﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تخرجنا﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿بسحرك﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تخرجنا﴾</span></span>.</p></div>"
  20,58,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فلنأتينك بسحر مثله فاجعل بيننا وبينك موعدا لا نخلفه نحن ولا أنت مكانا سوى﴾</span></span>: الفاء الفصيحة، واللام جواب قسم محذوف تقديره: والله لنأتينك، وبسحر جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿نأتينك﴾</span></span>، أو بمحذوف حال، ومثله صفة لسحر، فاجعل: الفاء عاطفة، واجعل فعل أمر، وفاعله أنت، وبيننا ظرف متعلق بمحذوف مفعول به ثان، وبينك معطف، وموعدًا مصدر ميمي مفعول به أول، وجملة لا نخلفه صفة لـ<span class="hlt"><span class="qpc-hafs">﴿موعدًا﴾</span></span>، ونحن تأكيد للضمير في نخلفه، والواو عاطفة، ولا نافية، وأنت عطف على الضمير في نخلفه، ومكانًا بدل من <span class="hlt"><span class="qpc-hafs">﴿موعدًا﴾</span></span> بتقدير مضاف إليه، أي: مكان موعد، أو منصوب بنزع الخافض، أي: في مكان، أو منصوب بالمصدر، وهو موعد. وسوى صفة، أي: وسطًا.</p></div>"
  20,59,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قال موعدكم يوم الزينة وأن يحشر الناس ضحى﴾</span></span>: موعدكم مبتدأ، ويوم الزينة الظرف متعلق بمحذوف خبر، وأن وما بعدها عطف على يوم الزينة، إما على اليوم فيكون محل المصدر الرفع، وإما على الزينة، فيكون محله الجر، والناس نائب فاعل، وضحى ظرف متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿يحشر﴾</span></span>.</p></div>"
  20,60,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فتولى فرعون فجمع كيده ثم أتى﴾</span></span>: الفاء عاطفة، وتولى فعل ماض، وفرعون فاعل، فجمع عطف على فتولى، وكيده مفعول به، على تقدير مضاف محذوف، أي: ذوي كيده، وهم السحرة، ثم حرف عطف، وأتى عطف على جمع.</p></div>"
  20,61,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قال لهم موسى ويلكم لا تفتروا على الله كذبا﴾</span></span>: قال فعل ماض، و<span class="hlt"><span class="qpc-hafs">﴿لهم﴾</span></span> جار ومجرور متعلقان به، وموسى فاعل، وويلكم مفعول لفعل محذوف على سبيل الردع، أي: ألزمكم الله ويلكم، ولا ناهية، وتفتروا فعل مضارع مجزوم بلا، وعلى الله جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تفتروا﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿كذبا﴾</span></span> مفعول به للفعل <span class="hlt"><span class="qpc-hafs">﴿لا تفتروا﴾</span></span>، أي: لا تختلقوا كذبا، أو مفعول لأجله، أي: لا تفتروا لأجل الكذب.</p><p><span class="hlt"><span class="qpc-hafs">﴿فيسحتكم بعذاب وقد خاب من افترى﴾</span></span>: الفاء: فاء السببية، و<span class="hlt"><span class="qpc-hafs">﴿يسحتكم﴾</span></span> مضارع منصوب بأن مضمرة، والمصدر المؤول من أن والفعل معطوف على مصدر مُتصيَّد من الكلام السابق، أي: لا يكن افتراءٌ فسحتٌ. و<span class="hlt"><span class="qpc-hafs">﴿بعذاب﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يسحتكم﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿وقد﴾</span></span> الواو حالية، وقد حرف تحقيق، و<span class="hlt"><span class="qpc-hafs">﴿خاب﴾</span></span> فعل ماض، و<span class="hlt"><span class="qpc-hafs">﴿مَن﴾</span></span> فاعل، وجملة افترى صلة <span class="hlt"><span class="qpc-hafs">﴿من﴾</span></span> لا محل لها من الإعراب.</p></div>"
  20,62,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فتنازعوا أمرهم بينهم وأسروا النجوى﴾</span></span>: الفاء عاطفة، وتنازعوا فعل ماض مبني على الضم لاتصاله بواو لجماعة، والواو فاعل، وأمرهم مفعول به، أو منصوب بنزع الخافض، وبينهم ظرف متعلق بمحذوف حال، وأسروا عطف على تنازعوا، والنجوى مفعول به.</p></div>"
  20,63,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قالوا إن هذان لساحران يريدان أن يخرجاكم من أرضكم بسحرهما ويذهبا بطريقتكم المثلى﴾</span></span>: إن مخففة من الثقيلة، واسمها ضمير الشأن محذوف، وهذان اسم إشارة للمثنى في محل رفع مبتدأ، واللام الفارقة، وساحران خبر <span class="hlt"><span class="qpc-hafs">﴿هذان﴾</span></span>، وجملة يريدان صفة لـ<span class="hlt"><span class="qpc-hafs">﴿ساحران﴾</span></span>، وأن وما في حيزها مفعول يريدان، ومن أرضكم جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يخرجاكم﴾</span></span>، وبسحرهما جار ومجرور متعلقان بمحذوف حال، أي: متلبسين بسحرهما، ويذهبا عطف على يخرجاكم، وبطريقتكم جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يذهبا﴾</span></span>، والمثلى صفة لطريقتكم، وجملة <span class="hlt"><span class="qpc-hafs">﴿هذان...﴾</span></span> في محل رفع خبر إن المخففة.</p></div>"
  20,64,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فأجمعوا كيدكم ثم ائتوا صفا﴾</span></span>: الفاء الفصيحة، وأجمعوا: فعل أمر مبني على حذف النون، والواو فاعل، وكيدكم: مفعول به إذا اعتُبرتْ <span class="hlt"><span class="qpc-hafs">﴿أجمعوا﴾</span></span> متعدية، أو منصوب بنزع الخافض إذا اعتُبرتْ لازمة، <span class="hlt"><span class="qpc-hafs">﴿ثم ائتوا﴾</span></span>: عطف على <span class="hlt"><span class="qpc-hafs">﴿أجمعوا﴾</span></span>، وصفًّا: حال أي: ائتوا مصطفين، وقيل: هو مفعول به أي: ائتوا قوما صفا.</p><p><span class="hlt"><span class="qpc-hafs">﴿وقد أفلح اليوم من استعلى﴾</span></span>: الواو اعتراضية، أو استئنافية. وقد: حرف تحقيق. وأفلح: فعل ماض. واليوم: ظرف متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿أفلح﴾</span></span>. ومن: فاعل أفلح. وجملة <span class="hlt"><span class="qpc-hafs">﴿استعلى﴾</span></span>: صلة <span class="hlt"><span class="qpc-hafs">﴿من﴾</span></span> لا محل لها من الإعراب. وجملة <span class="hlt"><span class="qpc-hafs">﴿وقد أفلح...﴾</span></span>: اعتراضية، أو استئنافية، وعلى كلا الوجهين لا محل لها من الإعراب.</p></div>"