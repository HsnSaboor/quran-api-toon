quran[19]{c,v,t}:
  73,1,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿يا﴾</span></span>: حرف نداء.</p><p><span class="hlt"><span class="qpc-hafs">﴿أيها﴾</span></span>: منادى مبني على الضم، لأنه نكرة مقصودة، وها للتنبيه.</p><p><span class="hlt"><span class="qpc-hafs">﴿المزمل﴾</span></span>: صفة لـ<span class="hlt"><span class="qpc-hafs">﴿أي﴾</span></span>.</p></div>"
  73,2,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قم﴾</span></span>: فعل أمر، وفاعله مستتر تقديره: أنت.</p><p><span class="hlt"><span class="qpc-hafs">﴿الليل﴾</span></span>: ظرف لـ<span class="hlt"><span class="qpc-hafs">﴿قم﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿إلا﴾</span></span>: أداة استثناء.</p><p><span class="hlt"><span class="qpc-hafs">﴿قليلا﴾</span></span>: مستثنى منصوب.</p></div>"
  73,3,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿نصفه﴾</span></span>: بدل من الليل، أو من <span class="hlt"><span class="qpc-hafs">﴿قليلا﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿أو﴾</span></span>: حرف عطف.</p><p><span class="hlt"><span class="qpc-hafs">﴿انقص﴾</span></span>: فعل أمر، وفاعله مستتر تقديره: أنت.</p><p><span class="hlt"><span class="qpc-hafs">﴿منه﴾</span></span>: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿انقص﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿قليلا﴾</span></span>: مفعول به منصوب.</p></div>"
  73,4,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿أو﴾</span></span>: أو عاطفة للتخيير.</p><p><span class="hlt"><span class="qpc-hafs">﴿زد﴾</span></span>: فعل أمر، وفاعله مستتر تقديره: أنت.</p><p><span class="hlt"><span class="qpc-hafs">﴿عليه﴾</span></span>: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿زد﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿ورتل﴾</span></span>: الواو عاطفة، ورتل فعل أمر، وفاعله مستتر تقديره: أنت.</p><p><span class="hlt"><span class="qpc-hafs">﴿القرآن﴾</span></span>: مفعول به منصوب.</p><p><span class="hlt"><span class="qpc-hafs">﴿ترتيلا﴾</span></span>: مفعول مطلق.</p></div>"
  73,5,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إنا﴾</span></span>: إن حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> اسمها.</p><p><span class="hlt"><span class="qpc-hafs">﴿سنلقي﴾</span></span>: السين حرف استقبال، ونلقي فعل مضارع مرفوع بضمة مقدرة للثقل، والفاعل مستتر، تقديره: نحن، والجملة خبر إن.</p><p><span class="hlt"><span class="qpc-hafs">﴿عليك﴾</span></span>: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿نلقي﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿قولا﴾</span></span>: مفعول به منصوب.</p><p><span class="hlt"><span class="qpc-hafs">﴿ثقيلا﴾</span></span>: نعت منصوب، والجملة استئنافية لا محل لها من الإعراب.</p></div>"
  73,6,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span>: حرف ناسخ.</p><p><span class="hlt"><span class="qpc-hafs">﴿ناشئة﴾</span></span>: اسم إن منصوب، وهو مضاف.</p><p><span class="hlt"><span class="qpc-hafs">﴿الليل﴾</span></span>: مضاف إليه مجرور.</p><p><span class="hlt"><span class="qpc-hafs">﴿هي﴾</span></span>: ضمير فصل.</p><p><span class="hlt"><span class="qpc-hafs">﴿أشد﴾</span></span>: خبر إن مرفوع.</p><p><span class="hlt"><span class="qpc-hafs">﴿وطئا﴾</span></span>: تمييز منصوب.</p><p><span class="hlt"><span class="qpc-hafs">﴿وأقوم﴾</span></span>: عطف على أشد.</p><p><span class="hlt"><span class="qpc-hafs">﴿قيلا﴾</span></span>: تمييز منصوب.</p></div>"
  73,7,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span>: حرف ناسخ.</p><p><span class="hlt"><span class="qpc-hafs">﴿لك﴾</span></span>: جار ومجرور متعلقان بخبر إن المقدّم.</p><p><span class="hlt"><span class="qpc-hafs">﴿في النهار﴾</span></span>: جار ومجرور متعلقان بمحذوف حال من <span class="hlt"><span class="qpc-hafs">﴿سبحا﴾</span></span>، لأنه كان في الأصل صفة لـ<span class="hlt"><span class="qpc-hafs">﴿سبحا﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿سبحا﴾</span></span>: اسم إن المؤخر.</p><p><span class="hlt"><span class="qpc-hafs">﴿طويلا﴾</span></span>: نعت منصوب.</p></div>"
  73,8,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿واذكر﴾</span></span>: الواو عاطفة، واذكر فعل أمر، وفاعله مستتر تقديره: أنت.</p><p><span class="hlt"><span class="qpc-hafs">﴿اسم﴾</span></span>: مفعول به منصوب، وهو مضاف.</p><p><span class="hlt"><span class="qpc-hafs">﴿ربك﴾</span></span>: مضاف إليه.</p><p><span class="hlt"><span class="qpc-hafs">﴿وتبتل﴾</span></span>: فعل أمر، وفاعله مستتر تقديره: أنت.</p><p><span class="hlt"><span class="qpc-hafs">﴿إليه﴾</span></span>: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تبتل﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿تبتيلا﴾</span></span>: نائب عن المفعول المطلق، لأن المصدر: <span class="hlt"><span class="qpc-hafs">﴿تبتُّلًا﴾</span></span>.</p></div>"
  73,9,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿رب﴾</span></span>: خبر لمبتدأ محذوف، أي: هو رب، وهو مضاف.</p><p><span class="hlt"><span class="qpc-hafs">﴿المشرق﴾</span></span>: مضاف إليه مجرور.</p><p><span class="hlt"><span class="qpc-hafs">﴿والمغرب﴾</span></span>: الواو عاطفة، والمغرب معطوف مجرور بالكسرة، والجملة تعليلية لا محل لها من الإعراب، أو حال من <span class="hlt"><span class="qpc-hafs">﴿ربك﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿لا﴾</span></span>: نافية للجنس.</p><p><span class="hlt"><span class="qpc-hafs">﴿إله﴾</span></span>: اسمها مبني على الفتح في محل نصب.</p><p><span class="hlt"><span class="qpc-hafs">﴿إلا﴾</span></span>: أداة حصر.</p><p><span class="hlt"><span class="qpc-hafs">﴿هو﴾</span></span>: بدل من محل لا واسمها، لأن محلها الرفع على الابتداء، أو بدل من الضمير المستكن في الخبر المحذوف. وجملة <span class="hlt"><span class="qpc-hafs">﴿لا إله إلا هو﴾</span></span> في محل رفع خبر ثانٍ للمبتدأ المقدر.</p><p><span class="hlt"><span class="qpc-hafs">﴿فاتخذه﴾</span></span>: الفاء الفصيحة، واتخذ فعل أمر مبني على السكون، والفاعل مستتر، تقديره: أنت، والهاء مفعول به أول.</p><p><span class="hlt"><span class="qpc-hafs">﴿وكيلا﴾</span></span>: مفعول به ثان.</p></div>"
  73,10,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿واصبر﴾</span></span>: عطف على ما تقدم، واصبر فعل أمر، وفاعله مستتر تقديره: أنت.</p><p><span class="hlt"><span class="qpc-hafs">﴿على ما﴾</span></span>:  جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿اصبر﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿يقولون﴾</span></span>: فعل مضارع مرفوع، وعلامة رفعه ثبوت النون، والواو فاعل.</p><p><span class="hlt"><span class="qpc-hafs">﴿واهجرهم﴾</span></span>: عطف على ما تقدم، واهجر فعل أمر، وفاعله مستتر تقديره: أنت، والهاء مفعول به.</p><p><span class="hlt"><span class="qpc-hafs">﴿هجرا﴾</span></span>: مفعول مطلق.</p><p><span class="hlt"><span class="qpc-hafs">﴿جميلا﴾</span></span>: نعت منصوب.</p></div>"
  73,11,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وذرني﴾</span></span>: عطف على ما تقدم، وذر فعل أمر، وفاعله مستتر تقديره: أنت، والنون للوقاية، والياء مفعول به.</p><p><span class="hlt"><span class="qpc-hafs">﴿والمكذبين﴾</span></span>: الواو عاطفة، والمكذبين معطوف منصوب بالياء.</p><p><span class="hlt"><span class="qpc-hafs">﴿أولي﴾</span></span>: نعت منصوب بالياء، لأنه ملحق بجمع المذكر السالم، وهو مضاف.</p><p><span class="hlt"><span class="qpc-hafs">﴿النعمة﴾</span></span>: مضاف إليه مجرور بالكسرة.</p><p><span class="hlt"><span class="qpc-hafs">﴿ومهلهم﴾</span></span>: فعل أمر مبني على السكون، وفاعل مستتر، تقديره: أنت، والهاء مفعول به.</p><p><span class="hlt"><span class="qpc-hafs">﴿قليلا﴾</span></span>: نعت لمصدر محذوف، أو ظرف، أي: قليلا من الزمن.</p></div>"
  73,12,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span>: حرف ناسخ.</p><p><span class="hlt"><span class="qpc-hafs">﴿لدينا﴾</span></span>: لدى ظرف متعلق بمحذوف خبر إن المقدم، وهو مضاف، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> مضاف إليه.</p><p><span class="hlt"><span class="qpc-hafs">﴿أنكالا﴾</span></span>: اسم إن المؤخر.</p><p><span class="hlt"><span class="qpc-hafs">﴿وجحيما﴾</span></span>: عطف على <span class="hlt"><span class="qpc-hafs">﴿أنكالا﴾</span></span>.</p></div>"
  73,13,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وطعاما﴾</span></span>: معطوف على <span class="hlt"><span class="qpc-hafs">﴿أنكالا﴾</span></span>، منصوب.</p><p><span class="hlt"><span class="qpc-hafs">﴿ذا﴾</span></span>: نعت لـ<span class="hlt"><span class="qpc-hafs">﴿طعاما﴾</span></span> منصوب بالألف، لأنه من الأسماء الستة، وهو مضاف.</p><p><span class="hlt"><span class="qpc-hafs">﴿غصة﴾</span></span>: مضاف إليه مجرور.</p><p><span class="hlt"><span class="qpc-hafs">﴿وعذابا﴾</span></span>: معطوف على <span class="hlt"><span class="qpc-hafs">﴿طعاما﴾</span></span>، منصوب.</p><p><span class="hlt"><span class="qpc-hafs">﴿أليما﴾</span></span>: نعت لـ<span class="hlt"><span class="qpc-hafs">﴿عذابا﴾</span></span> منصوب بالفتحة.</p></div>"
  73,14,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿يوم﴾</span></span>: ظرف متعلق بالاستقرار الذي تعلق به <span class="hlt"><span class="qpc-hafs">﴿لدينا﴾</span></span>، أو بمحذوف نعت لـ<span class="hlt"><span class="qpc-hafs">﴿عذابا﴾</span></span>، وهو مضاف.</p><p><span class="hlt"><span class="qpc-hafs">﴿ترجف﴾</span></span>: فعل مضارع مرفوع، والجملة في محل جر مضاف إليه.</p><p><span class="hlt"><span class="qpc-hafs">﴿الأرض﴾</span></span>: فاعل ترجف مرفوع.</p><p><span class="hlt"><span class="qpc-hafs">﴿والجبال﴾</span></span>: الواو عاطفة، الجبال معطوف على الأرض.</p><p><span class="hlt"><span class="qpc-hafs">﴿وكانت﴾</span></span>: الواو عاطفة، وكان فعل ماض ناسخ، والتاء للتأنيث.</p><p><span class="hlt"><span class="qpc-hafs">﴿الجبال﴾</span></span>: اسم كان مرفوع.</p><p><span class="hlt"><span class="qpc-hafs">﴿كثيبا﴾</span></span>: خبر كان منصوب.</p><p><span class="hlt"><span class="qpc-hafs">﴿مهيلا﴾</span></span>: نعت لـ<span class="hlt"><span class="qpc-hafs">﴿كثيبا﴾</span></span> منصوب.</p></div>"
  73,15,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إنا﴾</span></span>: كلام مستأنف لا محل له من الإعراب، وإن حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> اسمها.</p><p><span class="hlt"><span class="qpc-hafs">﴿أرسلنا﴾</span></span>: فعل ماضٍ مبني على السكون، لاتصاله بـ<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> الفاعلين، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> فاعل.</p><p><span class="hlt"><span class="qpc-hafs">﴿إليكم﴾</span></span>: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أرسلنا﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿رسولا﴾</span></span>: مفعول به منصوب.</p><p><span class="hlt"><span class="qpc-hafs">﴿شاهدا﴾</span></span>: نعت لـ<span class="hlt"><span class="qpc-hafs">﴿رسولا﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿عليكم﴾</span></span>: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿شاهدا﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿كما﴾</span></span>: الكاف اسم بمعنى مثل مبني على الفتح في محل نصب صفة لمصدر محذوف، وما مصدرية.</p><p><span class="hlt"><span class="qpc-hafs">﴿أرسلنا﴾</span></span>: فعل ماضٍ مبني على السكون، لاتصاله بـ<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> الفاعلين، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> فاعل، والمصدر المؤول من <span class="hlt"><span class="qpc-hafs">﴿ما أرسلنا﴾</span></span> مضاف إليه.</p><p><span class="hlt"><span class="qpc-hafs">﴿إلى فرعون﴾</span></span>: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أرسلنا﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿رسولا﴾</span></span>: مفعول به.</p></div>"
  73,16,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فعصى﴾</span></span>: الفاء عاطفة، وعصى فعل ماضٍ.</p><p><span class="hlt"><span class="qpc-hafs">﴿فرعون﴾</span></span>: فاعل مرفوع بالضمة.</p><p><span class="hlt"><span class="qpc-hafs">﴿الرسول﴾</span></span>: مفعول به منصوب.</p><p><span class="hlt"><span class="qpc-hafs">﴿فأخذناه﴾</span></span>: عطف على <span class="hlt"><span class="qpc-hafs">﴿فعصى﴾</span></span>، وهو فعل ماضٍ، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> فاعل، والهاء مفعول به.</p><p><span class="hlt"><span class="qpc-hafs">﴿أخذا﴾</span></span>: مفعول مطلق.</p><p><span class="hlt"><span class="qpc-hafs">﴿وبيلا﴾</span></span>: نعت لـ<span class="hlt"><span class="qpc-hafs">﴿أخذا﴾</span></span> منصوب.</p></div>"
  73,17,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فكيف﴾</span></span>: الفاء عاطفة، وكيف استفهام في محل نصب على الحال.</p><p><span class="hlt"><span class="qpc-hafs">﴿تتقون﴾</span></span>: فعل مضارع مرفوع، والواو فاعل.</p><p><span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span>: شرطية.</p><p><span class="hlt"><span class="qpc-hafs">﴿كفرتم﴾</span></span>: فعل ماضٍ، في محل جزم فعل الشرط، والتاء فاعل.</p><p><span class="hlt"><span class="qpc-hafs">﴿يوما﴾</span></span>: مفعول <span class="hlt"><span class="qpc-hafs">﴿تتقون﴾</span></span> منصوب، أو منصوب بنزع الخافض، أي: إن كفرتم بيوم القيامة.</p><p><span class="hlt"><span class="qpc-hafs">﴿يجعل﴾</span></span>: فعل مضارع مرفوع، والفاعل مستتر، تقديره: هو، يعود على <span class="hlt"><span class="qpc-hafs">﴿يوما﴾</span></span>، وجملة يجعل صفة لـ<span class="hlt"><span class="qpc-hafs">﴿يوما﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿الولدان﴾</span></span>: مفعول به أول.</p><p><span class="hlt"><span class="qpc-hafs">﴿شيبا﴾</span></span>: مفعول به ثانٍ.</p></div>"
  73,18,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿السماء﴾</span></span>: السماء مبتدأ مرفوع.</p><p><span class="hlt"><span class="qpc-hafs">﴿منفطر﴾</span></span>: خبر المبتدأ مرفوع، والجملة صفة ثانية لـ<span class="hlt"><span class="qpc-hafs">﴿يوما﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿به﴾</span></span>: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿منفطر﴾</span></span>، والباء للاستعانة، وقيل: سببية، وقيل: إنها بمعنى في.</p><p><span class="hlt"><span class="qpc-hafs">﴿كان﴾</span></span>: فعل ماضٍ ناقص.</p><p><span class="hlt"><span class="qpc-hafs">﴿وعده﴾</span></span>: اسم كان مرفوع، وهو مضاف، والهاء مضاف إليه.</p><p><span class="hlt"><span class="qpc-hafs">﴿مفعولا﴾</span></span>: خبر كان منصوب.</p></div>"
  73,19,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span>: حرف ناسخ.</p><p><span class="hlt"><span class="qpc-hafs">﴿هذه﴾</span></span>: اسم إشارة مبني في محل نصب اسم إن.</p><p><span class="hlt"><span class="qpc-hafs">﴿تذكرة﴾</span></span>: خبر إن مرفوع.</p><p><span class="hlt"><span class="qpc-hafs">﴿فمن﴾</span></span>: الفاء عاطفة، ومن شرطية مبتدأ.</p><p><span class="hlt"><span class="qpc-hafs">﴿شاء﴾</span></span>: شاء فعل ماضٍ في محل جزم فعل الشرط، والفاعل مستتر، تقديره: هو، ومفعول شاء محذوف تقديره: فمَن شاء النجاة.</p><p><span class="hlt"><span class="qpc-hafs">﴿اتخذ﴾</span></span>: فعل ماضٍ في محل جزم جواب الشرط، والفاعل مستتر، تقديره: هو، وفعل الشرط وجوابه خبر <span class="hlt"><span class="qpc-hafs">﴿من﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿إلى ربه﴾</span></span>: جار ومجرور متعلقان بمحذوف حال، لأنه كان في الأصل صفة لـ<span class="hlt"><span class="qpc-hafs">﴿سبيلا﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿سبيلا﴾</span></span>: مفعول <span class="hlt"><span class="qpc-hafs">﴿اتخذ﴾</span></span> منصوب.</p></div>"