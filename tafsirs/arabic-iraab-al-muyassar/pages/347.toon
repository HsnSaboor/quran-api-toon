quran[15]{c,v,t}:
  23,75,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ولو رحمناهم وكشفنا ما بهم من ضر للجوا في طغيانهم يعمهون﴾</span></span>: الواو استئنافية، والجملة بعدها مستأنفة لا محل لها من الإعراب، ولو شرطية، و<span class="hlt"><span class="qpc-hafs">﴿رحمناهم﴾</span></span> فعل وفاعل ومفعول به، وكشفنا عطف على رحمناهم، وما مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿بهم﴾</span></span> جار ومجرور متعلقان بمحذوف صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span>، وجملة الصلة لا محل لها من الإعراب، ومن ضر جار ومجرور متعلقان بمحذوف حال، <span class="hlt"><span class="qpc-hafs">﴿لَلَجوا﴾</span></span> اللام رابطة لجواب لو، وجملة لجوا لا محل لها من الإعراب لأنها جواب شرط غير جازم، وفي طغيانهم جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يعمهون﴾</span></span>، وجملة يعمهون حالية.</p></div>"
  23,76,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ولقد أخذناهم بالعذاب فما استكانوا لربهم وما يتضرعون﴾</span></span>: الواو عاطفة، واللام جواب للقسم المحذوف، وقد حرف تحقيق، وأخذناهم فعل وفاعل ومفعول به، وبالعذاب جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أخذناهم﴾</span></span>، فما استكانوا عطف على أخذناهم، وما نافية، واستكانوا فعل وفاعل، ولربهم جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿استكانوا﴾</span></span>، والواو حرف عطف، وما نافية، ويتضرعون فعل مضارع وفاعل.</p></div>"
  23,77,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿حتى إذا فتحنا عليهم بابا ذا عذاب شديد إذا هم فيه مبلسون﴾</span></span>: حتى حرف للابتداء، وإذا شرطية ظرفية متعلقة بـ<span class="hlt"><span class="qpc-hafs">﴿مبلسون﴾</span></span>، وجملة فتحنا في محل جر بإضافة الظرف إليها، و<span class="hlt"><span class="qpc-hafs">﴿عليهم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿فتحنا﴾</span></span>، وبابًا مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿ذا عذاب﴾</span></span> صفة لـ<span class="hlt"><span class="qpc-hafs">﴿بابًا﴾</span></span>، وإذا الثانية حرف مفاجأة قائمة مقام فاء الجزاء في الربط، والجملة بعدها جواب إذا الأولى، و<span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> مبتدأ، وفيه جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿مبلسون﴾</span></span>، ومبلسون خبر <span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span>.</p></div>"
  23,78,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وهو الذي أنشأ لكم السمع والأبصار والأفئدة﴾</span></span>: الواو استئنافية، والجملة بعدها مستأنفة لا محل لها من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿هو﴾</span></span> مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿الذي﴾</span></span> اسم موصول في محل رفع خبر، وجملة أنشأ صلة الذي لا محل لها من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿لكم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أنشأ﴾</span></span>، والسمع مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿الأبصار والأفئدة﴾</span></span> عطف عليه.</p><p><span class="hlt"><span class="qpc-hafs">﴿قليلا﴾</span></span>: نائب عن المفعول المطلق، لأنه صفة المصدر المحذوف، أي: تشكرون شكرا قليلا.</p><p><span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span>: صلة لتأكيد القلة.</p><p><span class="hlt"><span class="qpc-hafs">﴿تشكرون﴾</span></span>: فعل مضارع مرفوع وعلامة رفعه ثبوت النون، والواو فاعل، وجملة <span class="hlt"><span class="qpc-hafs">﴿قليلا ما تشكرون﴾</span></span> مستأنفة لا محل لها من الإعراب.</p></div>"
  23,79,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وهو الذي ذرأكم في الأرض وإليه تحشرون﴾</span></span>: الواو عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿هو﴾</span></span> مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿الذي﴾</span></span> اسم موصول في محل رفع خبر، و<span class="hlt"><span class="qpc-hafs">﴿ذرأكم﴾</span></span> فعل ماض وفاعل مستتر ومفعول به، وجملة <span class="hlt"><span class="qpc-hafs">﴿ذرأكم﴾</span></span> صلة الذي لا محل لها من الإعراب. و<span class="hlt"><span class="qpc-hafs">﴿في الأرض﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿ذرأ﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿إليه﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تحشرون﴾</span></span>، وتحشرون فعل مضارع وفاعل وجملة و<span class="hlt"><span class="qpc-hafs">﴿إليه تحشرون﴾</span></span> معطوفة على ذرأكم، وجملة <span class="hlt"><span class="qpc-hafs">﴿وهو الذي ذرأكم﴾</span></span> معطوفة على الجملة المستأنفة <span class="hlt"><span class="qpc-hafs">﴿وهو الذي أنشأ لكم السمع...﴾</span></span> لا محل لها من الإعراب.</p></div>"
  23,80,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وهو الذي يحيي ويميت وله اختلاف الليل والنهار﴾</span></span>: الواو عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿هو﴾</span></span> مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿الذي﴾</span></span> اسم موصول في محل رفع خبر، وجملة <span class="hlt"><span class="qpc-hafs">﴿يحيي﴾</span></span> صلة الذي لا محل لها من الإعراب، وجملة <span class="hlt"><span class="qpc-hafs">﴿يميت﴾</span></span> معطوفة على جملة الصلة <span class="hlt"><span class="qpc-hafs">﴿يحيي﴾</span></span> فلا محل لها من الإعراب، <span class="hlt"><span class="qpc-hafs">﴿وله﴾</span></span>: الواو عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿له﴾</span></span> جار ومجرور متعلقان بمحذوف خبر مقدم، واختلاف مبتدأ مؤخر، والليل مضاف إليه، والنهار معطوف مجرور، وجملة <span class="hlt"><span class="qpc-hafs">﴿له اختلاف الليل والنهار﴾</span></span> معطوفة على جملة الصلة <span class="hlt"><span class="qpc-hafs">﴿يحيي﴾</span></span> فلا محل لها من الإعراب، وجملة <span class="hlt"><span class="qpc-hafs">﴿وهو الذي يحيي...﴾</span></span> معطوفة على الجملة المستأنفة <span class="hlt"><span class="qpc-hafs">﴿وهو الذي أنشأ لكم السمع...﴾</span></span> لا محل لها من الإعراب.</p><p><span class="hlt"><span class="qpc-hafs">﴿أفلا تعقلون﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿أفلا﴾</span></span>: الهمزة: للاستفهام، والفاء: عاطفة على مستأنف مقدر، أي: ألا تتفكرون فلا تعقلون، أو أتتفكرون فلا تعقلون، ولا: نافية، و<span class="hlt"><span class="qpc-hafs">﴿تعقلون﴾</span></span> فعل مضارع وواو الجماعة فاعل.</p></div>"
  23,81,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿بل قالوا مثل ما قال الأولون﴾</span></span>: بل حرف إضراب، وقالوا فعل وفاعل، ومثل صفة لمصدر محذوف، أي: قولًا مثل قول الأولين، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> مصدرية مؤولة مع ما بعدها بمصدر مضاف إليه، والأولون فاعل.</p></div>"
  23,82,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قالوا أئذا متنا وكنا ترابا وعظاما أئنا لمبعوثون﴾</span></span>: الجملة بدل من الجملة قبلها، أي: مستأنفة لا محل لها من الإعراب، والهمزة للاستفهام، وإذا ظرف مستقبل متضمن معنى الشرط، وجملة متنا في محل جر بإضافة إذا إليها، وكنا عطف على متنا، وكان فعل ماض ناقص، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> اسمها، وترابا خبرها، وعظاما عطف على <span class="hlt"><span class="qpc-hafs">﴿ترابًا﴾</span></span>، والهمزة للاستفهام أيضا، وإن حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> اسمها، واللام المزحلقة، ومبعوثون خبرها.</p></div>"
  23,83,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿لقد وعدنا نحن وآباؤنا هذا من قبل﴾</span></span>: اللام جواب للقسم المحذوف، ووعد فعل ماض مبني لما لم يسمَّ فاعله، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> نائب فاعل، ونحن تأكيد للضمير، وآباؤنا معطوف على الضمير المتصل، وهذا في محل نصب مفعول به ثان، ومن قبل جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿وعدنا﴾</span></span>، أو بمحذوف صفة لقوله: <span class="hlt"><span class="qpc-hafs">﴿آباؤنا﴾</span></span> أي: الكائنون من قبل.</p><p><span class="hlt"><span class="qpc-hafs">﴿إن هذا إلا أساطير الأولين﴾</span></span>: إن نافية، وهذا مبتدأ، وإلا أداة حصر، وأساطير الأولين خبر هذا.</p></div>"
  23,84,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قل لمن الأرض ومن فيها﴾</span></span>: قل فعل أمر، وفاعله مستتر تقديره: أنت، والجملة استئنافية لا محل لها من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿لمن﴾</span></span> اللام حرف جر، ومن استفهامية، والجار والمجرور متعلقان بمحذوف خبر مقدم، والأرض مبتدأ مؤخر، ومن موصولة عطف على الأرض، و<span class="hlt"><span class="qpc-hafs">﴿فيها﴾</span></span> جار ومجرور متعلقان بمحذوف صلة <span class="hlt"><span class="qpc-hafs">﴿من﴾</span></span>، وجملة الصلة لا محل لها من الإعراب.</p><p><span class="hlt"><span class="qpc-hafs">﴿إن كنتم تعلمون﴾</span></span>: إن شرطية، و<span class="hlt"><span class="qpc-hafs">﴿كنتم﴾</span></span> كان فعل ماض ناقص، والتاء اسمها، وجملة تعلمون خبرها، وكنتم فعل الشرط، والجواب محذوف، أي: فأخبروني بخالقهما.</p></div>"
  23,85,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿سيقولون لله قل أفلا تذكرون﴾</span></span>: الجملة مستأنفة لا محل لها من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿لله﴾</span></span> جار ومجرور متعلقان بمحذوف خبر لمبتدأ محذوف تقديره: هي، والجملة مقول القول، وقل فعل أمر، والهمزة للاستفهام، والفاء عاطفة على محذوف، ولا نافية، وتذكرون فعل مضارع.</p></div>"
  23,86,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قل من رب السماوات السبع ورب العرش العظيم﴾</span></span>: قل فعل أمر والفاعل مستتر، و<span class="hlt"><span class="qpc-hafs">﴿مَن﴾</span></span> اسم استفهام مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿رب﴾</span></span> خبره، والسماوات مضاف إليه، والسبع نعت للسماوات، و<span class="hlt"><span class="qpc-hafs">﴿رب العرش العظيم﴾</span></span> عطف عليه.</p></div>"
  23,87,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿سيقولون لله قل أفلا تتقون﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿لله﴾</span></span> جار ومجرور متعلقان بمحذوف خبر لمبتدأ محذوف، والتقدير: قل: من له السماوات السبع؟ و<span class="hlt"><span class="qpc-hafs">﴿قل﴾</span></span> فعل أمر، والهمزة للاستفهام، والفاء عاطفة على محذوف، ولا نافية، وتتقون فعل مضارع.</p></div>"
  23,88,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قل من بيده ملكوت كل شيء﴾</span></span>: من اسم استفهام مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿بيده﴾</span></span> جار ومجرور متعلقان بمحذوف خبر مقدم، وملكوت مبتدأ مؤخر، وكل شيء مضاف إليه، والجملة خبر من.</p><p><span class="hlt"><span class="qpc-hafs">﴿وهو يجير ولا يجار عليه﴾</span></span>: الواو عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿هو﴾</span></span> في محل رفع مبتدأ، وجملة <span class="hlt"><span class="qpc-hafs">﴿يجير﴾</span></span> في محل رفع خبر، وجملة <span class="hlt"><span class="qpc-hafs">﴿يجار﴾</span></span> عطف على <span class="hlt"><span class="qpc-hafs">﴿يجير﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿إن كنتم تعلمون﴾</span></span>: إن شرطية، و<span class="hlt"><span class="qpc-hafs">﴿كنتم﴾</span></span> كان فعل ماض ناقص، والتاء اسمها، وجملة تعلمون خبرها، وكنتم فعل الشرط، والجواب محذوف، أي: إن كنتم تعلمون فأخبروني.</p></div>"
  23,89,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿سيقولون لله﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿لله﴾</span></span> جار ومجرور متعلقان بمحذوف خبر لمبتدأ محذوف، والتقدير: قل من له ملكوت كل شيء؟ <span class="hlt"><span class="qpc-hafs">﴿قل فأنى تسحرون﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿فأنى﴾</span></span> الفاء الفصيحة، وأنى اسم استفهام بمعنى كيف في محل نصب على الحال، وتسحرون فعل مضارع مبني لما لم يسمَّ فاعله، والواو نائب فاعل، وجملة فأنى تسحرون في محل نصب مقول القول.</p></div>"