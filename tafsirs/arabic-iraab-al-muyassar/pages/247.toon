quran[8]{c,v,t}:
  12,96,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فلما أن جاء البشير ألقاه على وجهه فارتد بصيرا﴾</span></span>: لما ظرفية حينية، أو رابطة، وأن صلة، و<span class="hlt"><span class="qpc-hafs">﴿جاء البشير﴾</span></span> فعل وفاعل، وجملة ألقاه لا محل لها من الإعراب، والهاء مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿على وجهه﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿ألقاه﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿فارتد﴾</span></span> الفاء عاطفة، وارتد فعل ماض فاعله مستتر تقديره: هو، و<span class="hlt"><span class="qpc-hafs">﴿بصيرًا﴾</span></span> حال، أو <span class="hlt"><span class="qpc-hafs">﴿ارتد﴾</span></span> فعل ماض ناقص يعمل عمل <span class="hlt"><span class="qpc-hafs">﴿صار﴾</span></span>، وبصيرًا خبرها.</p><p><span class="hlt"><span class="qpc-hafs">﴿قال ألم أقل لكم إني أعلم من الله ما لا تعلمون﴾</span></span>: الهمزة للاستفهام التقريري، ولم حرف نفي وقلب وجزم، و<span class="hlt"><span class="qpc-hafs">﴿أقل﴾</span></span> مضارع مجزوم بـ<span class="hlt"><span class="qpc-hafs">﴿لم﴾</span></span>، والفاعل مستتر تقديره: أنا، و<span class="hlt"><span class="qpc-hafs">﴿لكم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أقل﴾</span></span>، وإن حرف ناسخ، والياء اسمها، وجملة أعلم خبرها، و<span class="hlt"><span class="qpc-hafs">﴿من الله﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أعلم﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> موصول مفعول به، وجملة لا تعلمون صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> لا محل لها من الإعراب.</p></div>"
  12,97,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قالوا يا أبانا استغفر لنا ذنوبنا إنا كنا خاطئين﴾</span></span>: يا أبانا منادى مضاف، واستغفر فعل أمر، وفاعله مستتر تقديره: أنت، و<span class="hlt"><span class="qpc-hafs">﴿لنا﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿استغفر﴾</span></span>، وذنوبنا مفعول به، وإن حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> اسمها، وجملة <span class="hlt"><span class="qpc-hafs">﴿كنا خاطئين﴾</span></span> خبر إن، وكنا فعل ماض ناقص ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> اسمها، وخاطئين خبرها.</p></div>"
  12,98,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قال سوف أستغفر لكم ربي﴾</span></span>: جملة سوف أستغفر مقول القول، و<span class="hlt"><span class="qpc-hafs">﴿لكم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أستغفر﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿ربي﴾</span></span> مفعول به.</p><p><span class="hlt"><span class="qpc-hafs">﴿إنه هو الغفور الرحيم﴾</span></span>: إن حرف ناسخ، والهاء اسمها، و<span class="hlt"><span class="qpc-hafs">﴿هو﴾</span></span> مبتدأ، والغفور الرحيم خبران لـ<span class="hlt"><span class="qpc-hafs">﴿هو﴾</span></span>، والجملة الاسمية خبر إن، أو <span class="hlt"><span class="qpc-hafs">﴿هو﴾</span></span> ضمير فصل، والغفور الرحيم خبران لـ<span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span>.</p></div>"
  12,99,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فلما دخلوا على يوسف آوى إليه أبويه﴾</span></span>: عطف على محذوف، ودخلوا فعل وفاعل، و<span class="hlt"><span class="qpc-hafs">﴿على يوسف﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿دخلوا﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿آوى﴾</span></span> لا محل لها من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿إليه﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿آوى﴾</span></span>، وأبويه مفعول به.</p><p><span class="hlt"><span class="qpc-hafs">﴿وقال ادخلوا مصر إن شاء الله آمنين﴾</span></span>: الواو عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿ادخلوا مصر﴾</span></span> فعل وفاعل ومفعول به، وإن شرطية، وشاء فعل الشرط، والجواب محذوف لدلالة الكلام عليه، وجملة الشرط <span class="hlt"><span class="qpc-hafs">﴿إن شاء الله﴾</span></span>: اعتراضية بين الحال وصاحبها لا محل لها من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿آمنين﴾</span></span> حال من الواو في <span class="hlt"><span class="qpc-hafs">﴿ادخلوا﴾</span></span>.</p></div>"
  12,100,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ورفع أبويه على العرش وخروا له سجدا﴾</span></span>: الواو عاطفة، ورفع أبويه فعل وفاعل مستتر ومفعول به، و<span class="hlt"><span class="qpc-hafs">﴿على العرش﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿رفع﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿خروا﴾</span></span> فعل وفاعل، و<span class="hlt"><span class="qpc-hafs">﴿له﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿خروا﴾</span></span>، وسجدًا حال.</p><p><span class="hlt"><span class="qpc-hafs">﴿وقال يا أبت هذا تأويل رؤياي من قبل﴾</span></span>: يا حرف نداء، و<span class="hlt"><span class="qpc-hafs">﴿أبت﴾</span></span> منادى مضاف إلى ياء المتكلم المحذوفة، و<span class="hlt"><span class="qpc-hafs">﴿هذا﴾</span></span> مبتدأ، وتأويل خبر، ورؤياي مضاف إليه، و<span class="hlt"><span class="qpc-hafs">﴿من قبل﴾</span></span> جار ومجرور متعلقان بمحذوف حال.</p><p><span class="hlt"><span class="qpc-hafs">﴿قد جعلها ربي حقا﴾</span></span>: قد حرف تحقيق، وجعلها ربي فعل ومفعول به وفاعل، وحقًّا مفعول ثان، والجملة حال مقدرة أو مقارنة.</p><p><span class="hlt"><span class="qpc-hafs">﴿وقد أحسن بي إذ أخرجني من السجن﴾</span></span>: الواو عاطفة، وقد حرف تحقيق، وأحسن فعل ماض، و<span class="hlt"><span class="qpc-hafs">﴿بي﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أحسن﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿إذ﴾</span></span> ظرف زمان متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿أحسن﴾</span></span> أيضًا، وجملة أخرجني في محل جر مضاف إليه، والفاعل مستتر، والياء مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿من السجن﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أخرجني﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿وجاء بكم من البدو من بعد أن نزغ الشيطان بيني وبين إخوتي﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿بكم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿جاء﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿من البدو﴾</span></span> جار ومجرور متعلقان به أيضًا، و<span class="hlt"><span class="qpc-hafs">﴿من بعد﴾</span></span> جار ومجرور متعلقان بمحذوف حال، وأن وما في حيزها مصدر مجرور بإضافة الظرف إليه، والشيطان فاعل نزغ، و<span class="hlt"><span class="qpc-hafs">﴿بيني﴾</span></span> ظرف متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿نزغ﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿بين﴾</span></span> عطف على الظرف الأول، ومضاف إلى <span class="hlt"><span class="qpc-hafs">﴿إخوتي﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿إن ربي لطيف لما يشاء﴾</span></span>: إن حرف ناسخ، وربي اسمها، ولطيف خبرها، و<span class="hlt"><span class="qpc-hafs">﴿لما﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿لطيف﴾</span></span>، وجملة يشاء صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> لا محل لها من الإعراب.</p><p><span class="hlt"><span class="qpc-hafs">﴿إنه هو العليم الحكيم﴾</span></span>: إن حرف ناسخ، والهاء اسمها، و<span class="hlt"><span class="qpc-hafs">﴿هو﴾</span></span> ضمير فصل، والعليم الحكيم خبران لـ<span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span>، أو <span class="hlt"><span class="qpc-hafs">﴿هو﴾</span></span> مبتدأ، والعليم الحكيم خبران لـ<span class="hlt"><span class="qpc-hafs">﴿هو﴾</span></span>، والجملة الاسمية خبر <span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span>.</p></div>"
  12,101,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿رب قد آتيتني من الملك وعلمتني من تأويل الأحاديث﴾</span></span>: رب منادى مضاف لياء المتكلم المحذوفة، وحرف النداء محذوف، وقد حرف تحقيق، و<span class="hlt"><span class="qpc-hafs">﴿آتيتني﴾</span></span> فعل وفاعل ومفعول به، و<span class="hlt"><span class="qpc-hafs">﴿من الملك﴾</span></span> من تبعيضية، وهي ومجرورها متعلقان بمحذوف صفة لمفعول به محذوف، أي: آتيتني شيئًا عظيمًا من الملك، وقيل: تبيينية فتتعلق بـ<span class="hlt"><span class="qpc-hafs">﴿آتيتني﴾</span></span>، وعلمتني عطف على آتيتني، و<span class="hlt"><span class="qpc-hafs">﴿من تأويل الأحاديث﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿علمتني﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿فاطر السماوات والأرض﴾</span></span>:  نعت لـ<span class="hlt"><span class="qpc-hafs">﴿رب﴾</span></span>، أو بدل منه، أو منادى، وحرف النداء محذوف، والسماوات مضاف إليه.</p><p><span class="hlt"><span class="qpc-hafs">﴿أنت وليي في الدنيا والآخرة﴾</span></span>: أنت مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿وليي﴾</span></span> خبر، و<span class="hlt"><span class="qpc-hafs">﴿في الدنيا﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿وليي﴾</span></span>، والآخرة عطف على الدنيا.</p><p><span class="hlt"><span class="qpc-hafs">﴿توفني مسلما وألحقني بالصالحين﴾</span></span>: فعل دعاء، والنون للوقاية، والياء مفعول به، ومسلمًا حال، وألحقني عطف على توفني، و<span class="hlt"><span class="qpc-hafs">﴿بالصالحين﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿ألحقني﴾</span></span>.</p></div>"
  12,102,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ذلك من أنباء الغيب نوحيه إليك﴾</span></span>: ذلك اسم إشارة في محل رفع مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿من أنباء الغيب﴾</span></span> جار ومجرور متعلقان بمحذوف خبره، وجملة نوحيه إليك حال، أو خبر ثان.</p><p><span class="hlt"><span class="qpc-hafs">﴿وما كنت لديهم إذ أجمعوا أمرهم وهم يمكرون﴾</span></span>: الواو عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿كنت﴾</span></span> فعل ماض ناقص ناسخ، والتاء اسمها، و<span class="hlt"><span class="qpc-hafs">﴿لديهم﴾</span></span> ظرف مكان متعلق بمحذوف خبر كنت، و<span class="hlt"><span class="qpc-hafs">﴿إذ﴾</span></span> ظرف زمان متعلق بالخبر المحذوف الذي تعلق به <span class="hlt"><span class="qpc-hafs">﴿لديهم﴾</span></span>، وجملة أجمعوا في محل جر بإضافة الظرف إليها، والواو للحال، و<span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> مبتدأ، وجملة يمكرون خبر، والجملة حالية.</p></div>"
  12,103,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وما أكثر الناس ولو حرصت بمؤمنين﴾</span></span>: الواو عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> نافية حجازية تعمل عمل ليس، و<span class="hlt"><span class="qpc-hafs">﴿أكثر﴾</span></span> اسم ما، و<span class="hlt"><span class="qpc-hafs">﴿الناس﴾</span></span> مضاف إليه، <span class="hlt"><span class="qpc-hafs">﴿ولو﴾</span></span>: الواو اعتراضية، و<span class="hlt"><span class="qpc-hafs">﴿لو﴾</span></span> شرطية، و<span class="hlt"><span class="qpc-hafs">﴿حرصت﴾</span></span> فعل وفاعل، وجواب <span class="hlt"><span class="qpc-hafs">﴿لو﴾</span></span> محذوف دل عليه ما قبله أي: ولو حرصت على إيمان أكثر الناس فما هم بمؤمنين، وجملة <span class="hlt"><span class="qpc-hafs">﴿ولو حرصت﴾</span></span> اعتراضية بين <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> الحجازية وخبرها، لا محل لها من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿بمؤمنين﴾</span></span>: الباء حرف جر صلة، و<span class="hlt"><span class="qpc-hafs">﴿مؤمنين﴾</span></span> خبر <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> الحجازية منصوب محلا مجرور بالباء لفظًا.</p></div>"