quran[9]{c,v,t}:
  27,36,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فلما جاء سليمان قال أتمدونن بمال﴾</span></span>: الفاء عاطفة على محذوف، ولما ظرفية حينية، أو رابطة متضمنة معنى الشرط، و<span class="hlt"><span class="qpc-hafs">﴿جاء سليمان﴾</span></span> فعل ماض، والفاعل مستتر تقديره: هو، أي: الرسول، وسليمان مفعول به، وجملة <span class="hlt"><span class="qpc-hafs">﴿قال﴾</span></span> لا محل لها من الإعراب، والهمزة للاستفهام، وتمدونن فعل مضارع مرفوع وعلامة رفعه ثبوت النون، والواو فاعل، والنون للوقاية، والياء المحذوفة مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿بمال﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تمدونن﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿فما آتاني الله خير مما آتاكم﴾</span></span>: الفاء حرف تعليل لما تقدم من إنكاره عليهم، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> اسم موصول مبتدأ، وجملة آتاني صلة الموصول لا محل لها من الإعراب. و<span class="hlt"><span class="qpc-hafs">﴿آتاني الله﴾</span></span> فعل ماض ومفعول به مقدم، ولفظ الجلالة فاعل مؤخر، و<span class="hlt"><span class="qpc-hafs">﴿خير﴾</span></span> خبر <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿بل أنتم بهديتكم تفرحون﴾</span></span>: بل حرف إضراب، وأنتم مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿بهديتكم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تفرحون﴾</span></span>، وجملة تفرحون خبر.</p></div>"
  27,37,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ارجع إليهم فلنأتينهم بجنود لا قبل لهم بها﴾</span></span>: ارجع فعل أمر، وفاعله مستتر، تقديره: أنت، و<span class="hlt"><span class="qpc-hafs">﴿إليهم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿ارجع﴾</span></span>، والفاء استئنافية، والجملة بعدها مستأنفة لا محل لها من الإعراب، واللام واقعة في جواب قسم مقدر، و<span class="hlt"><span class="qpc-hafs">﴿نأتينهم﴾</span></span> فعل مضارع مبني على الفتح لاتصاله بنون التوكيد الثقيلة، والفاعل مستتر تقديره: نحن، والهاء مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿بجنود﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿نأتينهم﴾</span></span>، ولا نافية للجنس، و<span class="hlt"><span class="qpc-hafs">﴿قبل﴾</span></span> اسم لا مبني على الفتح، و<span class="hlt"><span class="qpc-hafs">﴿لهم﴾</span></span> جار ومجرور متعلقان بمحذوف خبرها، و<span class="hlt"><span class="qpc-hafs">﴿بها﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿قبل﴾</span></span>، لتضمنه معنى المصدر.</p><p><span class="hlt"><span class="qpc-hafs">﴿ولنخرجنهم منها أذلة وهم صاغرون﴾</span></span>: الواو عاطفة، ولنخرجنهم عطف على فلنأتينهم، و<span class="hlt"><span class="qpc-hafs">﴿منها﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿نخرجنهم﴾</span></span>، والضمير يعود إلى سبأ، و<span class="hlt"><span class="qpc-hafs">﴿أذلة﴾</span></span> حال، <span class="hlt"><span class="qpc-hafs">﴿وهم﴾</span></span> الواو حالية، و<span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> مبتدأ، وصاغرون خبر، والجملة حال ثانية من الهاء في <span class="hlt"><span class="qpc-hafs">﴿لنخرجنهم﴾</span></span>.</p></div>"
  27,38,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قال يا أيها الملأ أيكم يأتيني بعرشها قبل أن يأتوني مسلمين﴾</span></span>: قال فعل ماض، والفاعل مستتر، و<span class="hlt"><span class="qpc-hafs">﴿أيكم﴾</span></span> مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿ويأتيني﴾</span></span> فعل مضارع مرفوع، والفاعل مستتر، والياء مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿بعرشها﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يأتيني﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿يأتيني بعرشها﴾</span></span> خبر، و<span class="hlt"><span class="qpc-hafs">﴿قبل﴾</span></span> ظرف متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿يأتيني﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿أن يأتوني﴾</span></span> أن مصدرية، ويأتوني فعل مضارع منصوب، والواو فاعل، والياء مفعول به، والمصدر المؤول من أن وما في حيزها مضاف إليه، ومسلمين حال.</p></div>"
  27,39,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قال عفريت من الجن أنا آتيك به قبل أن تقوم من مقامك﴾</span></span>: قال فعل ماض، وعفريت فاعل، و<span class="hlt"><span class="qpc-hafs">﴿من الجن﴾</span></span> جار ومجرور متعلقان بمحذوف صفة، وأنا مبتدأ، وجملة <span class="hlt"><span class="qpc-hafs">﴿آتيك به﴾</span></span> خبر، و<span class="hlt"><span class="qpc-hafs">﴿قبل﴾</span></span> ظرف متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿آتيك﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿من مقامك﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تقوم﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿وإني عليه لقوي أمين﴾</span></span>: الواو عاطفة، وإن حرف ناسخ، والياء اسمها، و<span class="hlt"><span class="qpc-hafs">﴿عليه﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿قوي﴾</span></span>، واللام المزحلقة، وقوي خبر إن، وأمين خبر ثان.</p></div>"
  27,40,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قال الذي عنده علم من الكتاب﴾</span></span>: قال فعل ماض، والذي فاعل، و<span class="hlt"><span class="qpc-hafs">﴿عنده﴾</span></span> ظرف متعلق بمحذوف خبر مقدم، وعلم مبتدأ مؤخر، و<span class="hlt"><span class="qpc-hafs">﴿من الكتاب﴾</span></span> جار ومجرور متعلقان بمحذوف صفة لـ<span class="hlt"><span class="qpc-hafs">﴿علم﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿عنده علم﴾</span></span> صلة الموصول لا محل لها من الإعراب.</p><p><span class="hlt"><span class="qpc-hafs">﴿أنا آتيك به قبل أن يرتد إليك طرفك﴾</span></span>: أنا مبتدأ، وجملة آتيك به خبر، والجملة مقول القول، و<span class="hlt"><span class="qpc-hafs">﴿قبل﴾</span></span> ظرف متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿آتيك﴾</span></span>، وأن وما في حيزها في محل جر مضاف إليه، وطرفك فاعل يرتد.</p><p><span class="hlt"><span class="qpc-hafs">﴿فلما رآه مستقرا عنده قال هذا من فضل ربي﴾</span></span>: الفاء عاطفة على محذوف يقدر بحسب المقام، ولما ظرف بمعنى حين، أو رابطة، ورآه فعل ماض، والفاعل مستتر، والهاء مفعول به، ومستقرًّا حال، لأن الرؤية بصرية، و<span class="hlt"><span class="qpc-hafs">﴿عنده﴾</span></span> ظرف متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿مستقرًّا﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿قال﴾</span></span> لا محل لها من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿هذا﴾</span></span> مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿من فضل ربي﴾</span></span> جار ومجرور متعلقان بمحذوف خبر.</p><p><span class="hlt"><span class="qpc-hafs">﴿ليبلوني أأشكر أم أكفر﴾</span></span>: اللام للتعليل، ويبلوني فعل مضارع منصوب بأن مضمرة بعد لام التعليل، والمصدر المؤول من أن والفعل مجرور باللام، والجار والمجرور متعلقان بالمصدر <span class="hlt"><span class="qpc-hafs">﴿فضل﴾</span></span>، وفاعل يبلوني مستتر يعود على <span class="hlt"><span class="qpc-hafs">﴿ربي﴾</span></span>، والياء مفعول، و<span class="hlt"><span class="qpc-hafs">﴿أأشكر﴾</span></span> الهمزة للاستفهام، وأشكر فعل مضارع، وفاعله مستتر تقديره: أنا، وجملة <span class="hlt"><span class="qpc-hafs">﴿أأشكر﴾</span></span> بدل من الياء في <span class="hlt"><span class="qpc-hafs">﴿يبلوني﴾</span></span> فهو بمثابة المفعول به، و<span class="hlt"><span class="qpc-hafs">﴿أم أكفر﴾</span></span> عطف على أأشكر.</p><p><span class="hlt"><span class="qpc-hafs">﴿ومن شكر فإنما يشكر لنفسه﴾</span></span>: الواو استئنافية، والجملة بعدها مستأنفة لا محل لها من الإعراب، ومَن شرطية مبتدأ، وشكر فعل ماض في محل جزم فعل الشرط، والفاء رابطة، وإن حرف ناسخ، وما مصدرية، وإن وما بعدها في تأويل مصدر اسم إن، أي: فإن ثواب شكره، و<span class="hlt"><span class="qpc-hafs">﴿لنفسه﴾</span></span> جار ومجرور متعلقان بمحذوف خبر، وفعل الشرط وجوابه خبر مَن.</p><p><span class="hlt"><span class="qpc-hafs">﴿ومن كفر فإن ربي غني كريم﴾</span></span>: جملة معطوفة، ومَن شرطية مبتدأ، وكفر فعل ماض في محل جزم فعل الشرط، والفاء رابطة، وإن حرف ناسخ، وربي اسمها، وغني كريم خبران لـ<span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span>، وفعل الشرط وجوابه خبر مَن.</p></div>"
  27,41,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قال نكروا لها عرشها ننظر أتهتدي أم تكون من الذين لا يهتدون﴾</span></span>: نكروا فعل أمر، والواو فاعل، و<span class="hlt"><span class="qpc-hafs">﴿لها﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿نكروا﴾</span></span>، وعرشها مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿ننظر﴾</span></span> فعل مضارع مجزوم، لأنه جواب الأمر، وجملة <span class="hlt"><span class="qpc-hafs">﴿أتهتدي﴾</span></span> في محل نصب على المفعولية، وأم حرف عطف، و<span class="hlt"><span class="qpc-hafs">﴿تكون﴾</span></span> فعل مضارع ناقص ناسخ معطوف على <span class="hlt"><span class="qpc-hafs">﴿أتهتدي﴾</span></span>، واسمها مستتر تقديره: هي، و<span class="hlt"><span class="qpc-hafs">﴿من الذين﴾</span></span> جار ومجرور متعلقان بمحذوف خبر <span class="hlt"><span class="qpc-hafs">﴿تكون﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿لا يهتدون﴾</span></span> صلة الموصول لا محل لها من الإعراب.</p></div>"
  27,42,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فلما جاءت قيل أهكذا عرشك قالت كأنه هو﴾</span></span>: الفاء عاطفة على محذوف، ولما ظرفية حينية، أو رابطة متضمنة معنى الشرط، و<span class="hlt"><span class="qpc-hafs">﴿جاءت﴾</span></span> فعل ماض، والفاعل مستتر تقديره: هي، <span class="hlt"><span class="qpc-hafs">﴿قيل﴾</span></span> فعل ماض مبني لما لم يسمَّ فاعله، <span class="hlt"><span class="qpc-hafs">﴿أهكذا﴾</span></span> الهمزة للاستفهام، و<span class="hlt"><span class="qpc-hafs">﴿ها﴾</span></span> للتنبيه، الكاف اسم بمعنى مثل مبني على الفتح في محل رفع خبر مقدم، و<span class="hlt"><span class="qpc-hafs">﴿ذا﴾</span></span> اسم إشارة في محل جر مضاف إليه، وعرشك مبتدأ مؤخر، <span class="hlt"><span class="qpc-hafs">﴿قالت﴾</span></span> فعل ماض، والفاعل مستتر تقديره: هي، و<span class="hlt"><span class="qpc-hafs">﴿كأنه هو﴾</span></span> كأن حرف ناسخ، والهاء اسمها، والضمير <span class="hlt"><span class="qpc-hafs">﴿هو﴾</span></span> خبرها.</p><p><span class="hlt"><span class="qpc-hafs">﴿وأوتينا العلم من قبلها وكنا مسلمين﴾</span></span>: الواو عاطفة على كلام محذوف، و<span class="hlt"><span class="qpc-hafs">﴿أوتينا﴾</span></span> فعل ماض مبني لما لم يسمَّ فاعله، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> نائب فاعل يعود على سليمان، وقيل: على بلقيس، والعلم مفعول أوتينا الثاني، و<span class="hlt"><span class="qpc-hafs">﴿من قبلها﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أوتينا﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿وكنا﴾</span></span> الواو عاطفة، وكان فعل ماض ناقص، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> اسمها، ومسلمين خبرها.</p></div>"
  27,43,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وصدها ما كانت تعبد من دون الله﴾</span></span>: الواو استئنافية، والجملة بعدها مستأنفة لا محل لها من الإعراب، وصدها فعل ماض، والهاء مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> موصول فاعل، وجملة <span class="hlt"><span class="qpc-hafs">﴿كانت﴾</span></span> صلة الموصول لا محل لها من الإعراب. واسم كانت مستتر تقديره: هي، وجملة <span class="hlt"><span class="qpc-hafs">﴿تعبد﴾</span></span> خبرها، و<span class="hlt"><span class="qpc-hafs">﴿من دون الله﴾</span></span> جار ومجرور متعلقان بمحذوف حال، أو <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> مصدرية، أي: وصدها عبادة الشمس عن الإسلام.</p><p><span class="hlt"><span class="qpc-hafs">﴿إنها كانت من قوم كافرين﴾</span></span>: إن حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿ها﴾</span></span> اسمها، وجملة كانت خبرها، وجملة <span class="hlt"><span class="qpc-hafs">﴿إنها﴾</span></span> تعليل، وكانت فعل ماض ناسخ، واسمها مستتر تقديره: هي، و<span class="hlt"><span class="qpc-hafs">﴿من قوم﴾</span></span> جار ومجرور متعلقان بمحذوف خبرها، وكافرين صفة.</p></div>"
  27,44,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قيل لها ادخلي الصرح﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿قيل﴾</span></span> فعل ماض مبني لما لم يسمَّ فاعله، والجملة مستأنفة لا محل لها من الإعراب، وجملة <span class="hlt"><span class="qpc-hafs">﴿ادخلي الصرح﴾</span></span> فعل وفاعل ومفعول به، وهي مقول القول، والصرح مفعول به على السعة.</p><p><span class="hlt"><span class="qpc-hafs">﴿فلما رأته حسبته لجة وكشفت عن ساقيها﴾</span></span>: الفاء عاطفة على محذوف، أي: فدخلته، لما حينية، أو رابطة، وجملة <span class="hlt"><span class="qpc-hafs">﴿حسبته﴾</span></span> لا محل لها من الإعراب، وهي فعل ماض، والهاء مفعول به أول، ولجة مفعول به ثان، و<span class="hlt"><span class="qpc-hafs">﴿كشفت عن ساقيها﴾</span></span> عطف على حسبته.</p><p><span class="hlt"><span class="qpc-hafs">﴿قال إنه صرح ممرد من قوارير﴾</span></span>: قال فعل ماض، <span class="hlt"><span class="qpc-hafs">﴿إنه﴾</span></span>: إن حرف ناسخ، والهاء اسمها، وصرح خبرها، وممرد صفة، و<span class="hlt"><span class="qpc-hafs">﴿من قوارير﴾</span></span> جار ومجرور متعلقان بمحذوف صفة ثانية.</p><p><span class="hlt"><span class="qpc-hafs">﴿قالت رب إني ظلمت نفسي وأسلمت مع سليمان لله رب العالمين﴾</span></span>: رب منادى مضاف محذوف منه حرف النداء، وإن حرف ناسخ، والياء اسمها، وجملة <span class="hlt"><span class="qpc-hafs">﴿ظلمت نفسي﴾</span></span> خبرها، وهي فعل وفاعل ومفعول به، وأسلمت عطف على ظلمت، و<span class="hlt"><span class="qpc-hafs">﴿مع﴾</span></span> ظرف مكان متعلق بمحذوف حال، أي: كائنة مع سليمان، و<span class="hlt"><span class="qpc-hafs">﴿لله﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أسلمت﴾</span></span>، ورب العالمين بدل من لفظ الجلالة، أو صفة له.</p></div>"