quran[22]{c,v,t}:
  54,50,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وما أمرنا إلا واحدة كلمح بالبصر﴾</span></span>: الواو عاطفة، وما نافية، وأمرنا مبتدأ، وإلا أداة حصر، وواحدة خبر أمرنا، وكلمح جار ومجرور متعلقان بمحذوف حال من متعلق الأمر، وهو الشيء المأمور بالوجود، أي: حال كونه يوجد سريعًا، وبالبصر جار ومجرور متعلقان بلمح.</p></div>"
  54,51,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ولقد أهلكنا أشياعكم﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿ولقد﴾</span></span> الواو: استئنافية، واللام: واقعة في جواب قسم مقدر، وقد: حرف تحقيق، و<span class="hlt"><span class="qpc-hafs">﴿أهلكنا﴾</span></span> فعل وفاعل، و<span class="hlt"><span class="qpc-hafs">﴿أشياعكم﴾</span></span> مفعول به، وضمير الخطاب في محل جر مضاف إليه، وجملة <span class="hlt"><span class="qpc-hafs">﴿لقد أهلكنا﴾</span></span> لا محل لها من الإعراب لأنها جواب القسم المقدر، وجملة القسم المقدر مستأنفة لا محل لها من الإعراب.</p><p><span class="hlt"><span class="qpc-hafs">﴿فهل من مدكر﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿فهل﴾</span></span> الفاء: عاطفة، وهل: حرف استفهام، و<span class="hlt"><span class="qpc-hafs">﴿من﴾</span></span> حرف جر صلة، و<span class="hlt"><span class="qpc-hafs">﴿مدكر﴾</span></span> مجرور لفظًا مرفوع محلا على أنه مبتدأ، وخبره محذوف تقديره: موجود.</p></div>"
  54,52,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وكل شيء فعلوه في الزبر﴾</span></span>: الواو عاطفة، وكل مبتدأ، وشيء مضاف إليه، وجملة فعلوه صفة، وفي الزبر خبر.</p></div>"
  54,53,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وكل صغير وكبير مستطر﴾</span></span>: الواو عاطفة، وكل مبتدأ، وصغير مضاف إليه مجرور بالكسرة، وكبير معطوف بالواو مجرور بالكسرة، ومستطر خبر مرفوع بالضمة، والجملة لا محل لها من الإعراب عطفًا على سابقتها.</p></div>"
  54,54,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إن المتقين في جنات ونهر﴾</span></span>: إن حرف ناسخ، والمتقين اسمها، وفي جنات جار ومجرور متعلقان بمحذوف خبرها، ونهر عطفت على جنات.</p></div>"
  54,55,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿في مقعد صدق﴾</span></span>: الجار والمجرور بدل بعض من كل من قوله: في جنات، لأن المقعد بعض الجنات، ولك أن تعلقه بمحذوف على أنه خبر ثانٍ لإن.</p><p><span class="hlt"><span class="qpc-hafs">﴿عند مليك﴾</span></span>: ظرف متعلق بمحذوف صفة لجنات، أو لمقعد، وقيل: هو خبر ثان ٍأو ثالث لإن، ومليك صيغة مبالغة.</p><p><span class="hlt"><span class="qpc-hafs">﴿مقتدر﴾</span></span>: نعت، والجملة لا محل لها من الإعراب، لأنها استئنافية.</p></div>"
  55,1,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿الرحمن﴾</span></span>: الرحمن مبتدأ، وقيل: الرحمن خبر لمبتدأ محذوف، أي: الله الرحمن، أو مبتدأ خبره محذوف، أي: الرحمن ربنا.</p></div>"
  55,2,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿علم القرآن﴾</span></span>: جملة علم القرآن خبر، وعلم يتعدى إلى مفعولين حذف أولهما لشموله، أي: علم من يتعلم، وهذا أولى من تخصيص المفعول الأول المحذوف بواحد معين.</p></div>"
  55,3,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿خلق الإنسان﴾</span></span>: فعل ماضٍ، وفاعل مستتر، ومفعول به والألف واللام في الإنسان للجنس.</p></div>"
  55,4,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿علمه البيان﴾</span></span>: فعل ماضٍ، وفاعل مستتر، ومفعولاه.</p></div>"
  55,5,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿الشمس والقمر بحسبان﴾</span></span>: الشمس مبتدأ، والقمر عطف عليه، وبحسبان خبر الشمس.</p></div>"
  55,6,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿والنجم والشجر يسجدان﴾</span></span>: عطف على ما تقدم، وجملة يسجدان خبر النجم.</p></div>"
  55,7,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿والسماء رفعها ووضع الميزان﴾</span></span>: الواو عاطفة، والسماء مفعول به بفعل محذوف يدل عليه المذكور. وجملة رفعها تفسيرية لا محل لها من الإعراب. <span class="hlt"><span class="qpc-hafs">﴿ووضع الميزان﴾</span></span>: فعل، وفاعل مستتر، ومفعول به.</p></div>"
  55,8,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ألا تطغوا في الميزان﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿أن﴾</span></span> مصدرية، ولا نافية، وتطغوا فعل مضارع منصوب بأن المصدرية، وأن وما بعدها في تأويل منصوب بلام العلة مقدرة، والجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿وضع﴾</span></span>. وجملة <span class="hlt"><span class="qpc-hafs">﴿لا تطغوا﴾</span></span> صلة <span class="hlt"><span class="qpc-hafs">﴿أن﴾</span></span> المصدرية لا محل لها من الإعراب. أو <span class="hlt"><span class="qpc-hafs">﴿أن﴾</span></span> تفسيرية، والجملة بعدها تفسيرية لا محل لها من الإعراب. ولا ناهية. وتطغوا مجزوم بـ<span class="hlt"><span class="qpc-hafs">﴿لا﴾</span></span>.</p></div>"
  55,9,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وأقيموا الوزن بالقسط ولا تخسروا الميزان﴾</span></span>: الواو حرف عطف، وأقيموا فعل أمر مبني على حذف النون، والواو فاعل، والوزن مفعول به، وبالقسط حال، أي: افعلوه مستقيمًا بالعدل، والواو حرف عطف، ولا ناهية، وتخسروا فعل مضارع مجزوم بلا، والواو فاعل، والميزان مفعول به.</p></div>"
  55,10,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿والأرض وضعها للأنام﴾</span></span>: الواو حرف عطف. والأرض: مفعول به لفعل محذوف يدل عليه الفعل المذكور بعده. وجملة <span class="hlt"><span class="qpc-hafs">﴿وضعها﴾</span></span> تفسيرية لا محل لها من الإعراب. وللأنام: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿وضعها﴾</span></span>.</p></div>"
  55,11,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فيها فاكهة والنخل ذات الأكمام﴾</span></span>: فيها خبر مقدم، وفاكهة مبتدأ مؤخر، والنخل عطف على فاكهة، وذات الأكمام صفة للنخل، والجملة في محل نصب على الحال من الأرض.</p></div>"
  55,12,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿والحب ذو العصف والريحان﴾</span></span>: الحب معطوف على فاكهة مرفوع، وذو نعت للحب مرفوع بالواو، لأنه من الأسماء الستة، والعصف مضاف إليه، والريحان معطوف على فاكهة مرفوع.</p></div>"
  55,13,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فبأي آلاء ربكما تكذبان﴾</span></span>: الفاء الفصيحة، وبأي جار ومجرور متعلقان بتكذبان، وآلاء مضاف إليه، وربكما مضاف إليه، وتكذبان فعل مضارع مرفوع بثبوت النون، وألف التثنية فاعل، والخطاب للثقلين الإنس والجن.</p></div>"
  55,14,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿خلق الإنسان من صلصال كالفخار﴾</span></span>: كلام مستأنف لا محل له من الإعراب، وخلق فعل ماضٍ، وفاعله مستتر يعود على الله تعالى، والإنسان مفعول به، ومن صلصال جار ومجرور متعلقان بخلق، و<span class="hlt"><span class="qpc-hafs">﴿كالفخار﴾</span></span> الكاف اسم بمعنى مثل مبني على الفتح في محل جر صفة لصلصال، و<span class="hlt"><span class="qpc-hafs">﴿الفخار﴾</span></span> مضاف إليه.</p></div>"
  55,15,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وخلق الجان من مارج من نار﴾</span></span>: عطف على ما تقدم، ومن مارج جار ومجرور متعلقان بخلق، ومن لابتداء الغاية، ومن نار صفة لمارج، ومن للبيان، أو للتبعيض.</p></div>"
  55,16,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فبأي آلاء ربكما تكذبان﴾</span></span>: الفاء الفصيحة، وبأي جار ومجرور متعلقان بتكذبان، وآلاء مضاف إليه، وربكما مضاف إليه، وتكذبان فعل مضارع مرفوع بثبوت النون، وألف التثنية فاعل، والخطاب للثقلين الإنس والجن.</p></div>"