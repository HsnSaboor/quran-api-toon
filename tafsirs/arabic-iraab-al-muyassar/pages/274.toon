quran[8]{c,v,t}:
  16,65,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿والله أنزل من السماء ماء فأحيا به الأرض بعد موتها﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿الله﴾</span></span> مبتدأ، وجملة أنزل خبر، و<span class="hlt"><span class="qpc-hafs">﴿من السماء﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أنزل﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿ماء﴾</span></span> مفعول به، فأحيا عطف على أنزل، و<span class="hlt"><span class="qpc-hafs">﴿به﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أحيا﴾</span></span>، والأرض مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿بعد موتها﴾</span></span> الظرف متعلق بمحذوف حال.</p><p><span class="hlt"><span class="qpc-hafs">﴿إن في ذلك لآية لقوم يسمعون﴾</span></span>: إن وخبرها المقدم، واللام المزحلقة، وآية اسم إن، و<span class="hlt"><span class="qpc-hafs">﴿لقوم﴾</span></span> جار ومجرور متعلقان بمحذوف صفة لـ<span class="hlt"><span class="qpc-hafs">﴿آية﴾</span></span>، وجملة يسمعون صفة لقوم.</p></div>"
  16,66,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وإن لكم في الأنعام لعبرة﴾</span></span>: الواو عاطفة، وإن حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿لكم﴾</span></span> جار ومجرور متعلقان بمحذوف خبر مقدم، و<span class="hlt"><span class="qpc-hafs">﴿في الأنعام﴾</span></span> جار ومجرور متعلقان بمحذوف حال، واللام المزحلقة، وعبرة اسم إن المؤخر.</p><p><span class="hlt"><span class="qpc-hafs">﴿نسقيكم مما في بطونه من بين فرث ودم لبنا خالصا سائغا للشاربين﴾</span></span>: نسقيكم: فعل وفاعل مستتر ومفعول به. و<span class="hlt"><span class="qpc-hafs">﴿مما﴾</span></span>: جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿نسقيكم﴾</span></span>. و<span class="hlt"><span class="qpc-hafs">﴿في بطونه﴾</span></span>: جار ومجرور متعلقان بمحذوف صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> لا محل لها من الإعراب، وجملة <span class="hlt"><span class="qpc-hafs">﴿نسقيكم﴾</span></span> استئنافية لا محل لها من الإعراب. و<span class="hlt"><span class="qpc-hafs">﴿من بين فرث ودم﴾</span></span> حال، لأنه كان في الأصل صفة لقوله: لبنًا، وقدم عليه، أو حال من <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> التي قبله، و<span class="hlt"><span class="qpc-hafs">﴿لبنًا﴾</span></span> مفعول ثان لـ<span class="hlt"><span class="qpc-hafs">﴿نسقيكم﴾</span></span>، وسائغًا صفة، و<span class="hlt"><span class="qpc-hafs">﴿للشاربين﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿سائغًا﴾</span></span>.</p></div>"
  16,67,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ومن ثمرات النخيل والأعناب تتخذون منه سكرا ورزقا حسنا﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿ومن ثمرات النخيل﴾</span></span> جار ومجرور متعلقان بمحذوف خبر مقدم، وجملة <span class="hlt"><span class="qpc-hafs">﴿تتخذون﴾</span></span> صفة لموصوف محذوف هو المبتدأ المؤخر، أي: ثمر كانوا يتخذون منه سكرًا ورزقًا حسنًا، وقيل: <span class="hlt"><span class="qpc-hafs">﴿من ثمرات﴾</span></span> جار ومجرور متعلق بمحذوف دل عليه <span class="hlt"><span class="qpc-hafs">﴿نسقيكم﴾</span></span>، أي: نسقيكم من عصير النخيل والأعناب، وجملة <span class="hlt"><span class="qpc-hafs">﴿تتخذون﴾</span></span> حال. وقيل: متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تتخذون﴾</span></span>، وكررت <span class="hlt"><span class="qpc-hafs">﴿من﴾</span></span> للتوكيد، وقيل: تتعلق بـ<span class="hlt"><span class="qpc-hafs">﴿نسقيكم﴾</span></span>، فيكون معطوفًا على <span class="hlt"><span class="qpc-hafs">﴿مما في بطونه﴾</span></span>، وقيل: معطوف على الأنعام، أي: ومن ثمرات النخيل والأعناب عبرة، ثم بين العبرة بقوله: تتخذون، والضمير في <span class="hlt"><span class="qpc-hafs">﴿منه﴾</span></span> يعود على العصير المقدر، وسكرًا مفعول تتخذون، ورزقًا عطف على <span class="hlt"><span class="qpc-hafs">﴿سكرًا﴾</span></span>، وحسنًا صفة.</p><p><span class="hlt"><span class="qpc-hafs">﴿إن في ذلك لآية لقوم يعقلون﴾</span></span>: إن وخبرها المقدم، واللام المزحلقة، وآية اسمها المؤخر، وجملة يعقلون صفة لقوم.</p></div>"
  16,68,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وأوحى ربك إلى النحل أن اتخذي من الجبال بيوتا ومن الشجر ومما يعرشون﴾</span></span>: الواو عاطفة على ما قبلها، أو مستأنفة لا محل لها من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿أوحى ربك﴾</span></span> فعل وفاعل، و<span class="hlt"><span class="qpc-hafs">﴿إلى النحل﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أوحى﴾</span></span>. و<span class="hlt"><span class="qpc-hafs">﴿أن﴾</span></span>: تفسيرية، لأن الوحي فيه معنى القول دون حروفه، والجملة بعدها تفسيرية لا محل لها من الإعراب. أو <span class="hlt"><span class="qpc-hafs">﴿أن﴾</span></span> مصدرية وهي مع ما دخلت عليه في تأويل مصدر منصوب بنزع الخافض، والجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أوحى﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿اتخذي﴾</span></span> صلة <span class="hlt"><span class="qpc-hafs">﴿أن﴾</span></span> المصدرية لا محل لها من الإعراب. و<span class="hlt"><span class="qpc-hafs">﴿من الجبال﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿اتخذي﴾</span></span>، فمن للتبعيض، و<span class="hlt"><span class="qpc-hafs">﴿بيوتًا﴾</span></span> مفعول <span class="hlt"><span class="qpc-hafs">﴿اتخذي﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿من الشجر﴾</span></span> عطف على <span class="hlt"><span class="qpc-hafs">﴿من الجبال﴾</span></span>، وكذلك <span class="hlt"><span class="qpc-hafs">﴿مما يعرشون﴾</span></span>.</p></div>"
  16,69,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ثم كلي من كل الثمرات فاسلكي سبل ربك ذللا﴾</span></span>: ثم حرف عطف للتراخي، و<span class="hlt"><span class="qpc-hafs">﴿كلي﴾</span></span> فعل أمر وفاعل، و<span class="hlt"><span class="qpc-hafs">﴿من كل الثمرات﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿كلي﴾</span></span>، <span class="hlt"><span class="qpc-hafs">﴿فاسلكي﴾</span></span> الفاء عاطفة، واسلكي عطف على <span class="hlt"><span class="qpc-hafs">﴿كلي﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿سبل ربك﴾</span></span> مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿ذللًا﴾</span></span> حال من السبل، أو من فاعل <span class="hlt"><span class="qpc-hafs">﴿اسلكي﴾</span></span>، أي: وأنت منقادة لما أمرت به.</p><p><span class="hlt"><span class="qpc-hafs">﴿يخرج من بطونها شراب مختلف ألوانه فيه شفاء للناس﴾</span></span>: يخرج فعل مضارع، و<span class="hlt"><span class="qpc-hafs">﴿من بطونها﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يخرج﴾</span></span>، وشراب فاعل يخرج، و<span class="hlt"><span class="qpc-hafs">﴿مختلف﴾</span></span> صفة لشراب، و<span class="hlt"><span class="qpc-hafs">﴿ألوانه﴾</span></span> فاعل <span class="hlt"><span class="qpc-hafs">﴿مختلف﴾</span></span> لأنه اسم فاعل يعمل عمل الفعل، و<span class="hlt"><span class="qpc-hafs">﴿فيه﴾</span></span> جار ومجرور متعلقان بمحذوف خبر مقدم، وشفاء مبتدأ مؤخر، و<span class="hlt"><span class="qpc-hafs">﴿للناس﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿شفاء﴾</span></span>، والجملة صفة ثانية لشراب.</p><p><span class="hlt"><span class="qpc-hafs">﴿إن في ذلك لآية لقوم يتفكرون﴾</span></span>: إن وخبرها المقدم، واللام المزحلقة، وآية اسمها المؤخر، وجملة يتفكرون صفة لقوم.</p></div>"
  16,70,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿والله خلقكم ثم يتوفاكم ومنكم من يرد إلى أرذل العمر﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿الله﴾</span></span> مبتدأ، وجملة <span class="hlt"><span class="qpc-hafs">﴿خلقكم﴾</span></span> خبر، <span class="hlt"><span class="qpc-hafs">﴿ثم﴾</span></span> حرف عطف للتراخي، <span class="hlt"><span class="qpc-hafs">﴿ومنكم﴾</span></span> الواو حرف عطف، و<span class="hlt"><span class="qpc-hafs">﴿منكم﴾</span></span> جار ومجرور متعلقان بمحذوف خبر مقدم، وهو معطوف على مقدر، أي: فمنكم من يبقى محتفظًا بقوة جسمه وعقله ومنكم، و<span class="hlt"><span class="qpc-hafs">﴿مَن﴾</span></span> مبتدأ مؤخر، وجملة يرد صلة <span class="hlt"><span class="qpc-hafs">﴿من﴾</span></span> لا محل لها من الإعراب، ونائب الفاعل مستتر تقديره: هو، و<span class="hlt"><span class="qpc-hafs">﴿إلى أرذل العمر﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يرد﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿لكي لا يعلم بعد علم شيئا إن الله عليم قدير﴾</span></span>: اللام لام التعليل، و<span class="hlt"><span class="qpc-hafs">﴿كي﴾</span></span> حرف مصدري ونصب، ولا نافية، ويعلم منصوب بـ<span class="hlt"><span class="qpc-hafs">﴿كي﴾</span></span>، واللام ومدخولها متعلقة بـ<span class="hlt"><span class="qpc-hafs">﴿يرد﴾</span></span>، أو اللام للصيرورة، أي: فكانت عاقبته أنه رجع إلى حال الطفولة في النسيان وعدم الإدراك، و<span class="hlt"><span class="qpc-hafs">﴿بعد علم﴾</span></span> ظرف متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿يعلم﴾</span></span>، وشيئًا مفعول به ليعلم، وقيل: <span class="hlt"><span class="qpc-hafs">﴿شيئًا﴾</span></span> منصوبة بالعلم، وإن حرف ناسخ، ولفظ الجلالة اسمها، وعليم خبرها الأول، وقدير خبرها الثاني.</p></div>"
  16,71,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿والله فضل بعضكم على بعض في الرزق﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿الله﴾</span></span> مبتدأ، وجملة <span class="hlt"><span class="qpc-hafs">﴿فضل﴾</span></span> خبر، وبعضكم مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿على بعض﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿فضل﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿في الرزق﴾</span></span> جار ومجرور متعلقان بمحذوف حال، أي: حالة كونكم مرزوقين فمنكم غني ومنكم فقير.</p><p><span class="hlt"><span class="qpc-hafs">﴿فما الذين فضلوا برادي رزقهم على ما ملكت أيمانهم﴾</span></span>: الفاء عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> نافية حجازية تعمل عمل ليس، و<span class="hlt"><span class="qpc-hafs">﴿الذين﴾</span></span> اسم ما، وجملة <span class="hlt"><span class="qpc-hafs">﴿فضلوا﴾</span></span> صلة الذين لا محل لها من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿برادي﴾</span></span>: الباء حرف جر صلة، و<span class="hlt"><span class="qpc-hafs">﴿رادي﴾</span></span> خبر <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> الحجازية منصوب محلا مجرور بالباء لفظًا، و<span class="hlt"><span class="qpc-hafs">﴿رزقهم﴾</span></span> مضاف إليه من إضافة المصدر إلى مفعوله، و<span class="hlt"><span class="qpc-hafs">﴿على ما﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿رادي﴾</span></span>، وملكت أيمانهم صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> لا محل لها من الإعراب.</p><p><span class="hlt"><span class="qpc-hafs">﴿فهم فيه سواء﴾</span></span>: الفاء عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿فيه﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿سواء﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿سواء﴾</span></span> خبر <span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿أفبنعمة الله يجحدون﴾</span></span>: استفهام إنكار وتوبيخ، والفاء عاطفة على مقدر، أي: يشركون به فيجحدون نعمته، و<span class="hlt"><span class="qpc-hafs">﴿بنعمة الله﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يجحدون﴾</span></span>، لأنه متضمن معنى الكفران.</p></div>"
  16,72,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿والله جعل لكم من أنفسكم أزواجا﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿الله﴾</span></span> مبتدأ، وجملة <span class="hlt"><span class="qpc-hafs">﴿جعل﴾</span></span> خبر، و<span class="hlt"><span class="qpc-hafs">﴿لكم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿جعل﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿من أنفسكم﴾</span></span> جار ومجرور متعلقان بمحذوف حال، وأزواجًا مفعول جعل.</p><p><span class="hlt"><span class="qpc-hafs">﴿وجعل لكم من أزواجكم بنين وحفدة﴾</span></span>: عطف على ما تقدم، و<span class="hlt"><span class="qpc-hafs">﴿من أزواجكم﴾</span></span> جار ومجرور متعلقان بمحذوف حال، وبنين مفعول جعل، وحفدة عطف على بنين.</p><p><span class="hlt"><span class="qpc-hafs">﴿ورزقكم من الطيبات أفبالباطل يؤمنون وبنعمت الله هم يكفرون﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿ورزقكم﴾</span></span> فعل ماض، وفاعل مستتر، ومفعول به، و<span class="hlt"><span class="qpc-hafs">﴿من الطيبات﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿رزقكم﴾</span></span>، والهمزة للاستفهام الإنكاري التوبيخي، والفاء عاطفة على مقدر، أي: يكفرون بالله فيؤمنون بالباطل، و<span class="hlt"><span class="qpc-hafs">﴿بنعمة الله﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يكفرون﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> مبتدأ، وجملة يكفرون خبر.</p></div>"