quran[16]{c,v,t}:
  36,55,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إن أصحاب الجنة اليوم في شغل فاكهون﴾</span></span>: كلام مستأنف لا محل له من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span> حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿أصحاب﴾</span></span> اسمها، و<span class="hlt"><span class="qpc-hafs">﴿اليوم﴾</span></span> ظرف متعلق بمحذوف حال، و<span class="hlt"><span class="qpc-hafs">﴿في شغل﴾</span></span> جار ومجرور متعلقان بمحذوف خبر إن الثاني، و<span class="hlt"><span class="qpc-hafs">﴿فاكهون﴾</span></span> خبرها الأول. أو <span class="hlt"><span class="qpc-hafs">﴿في شغل﴾</span></span> جار ومجرور متعلقان بمحذوف خبر إن الأول، و<span class="hlt"><span class="qpc-hafs">﴿فاكهون﴾</span></span> خبرها الثاني. أو <span class="hlt"><span class="qpc-hafs">﴿في شغل﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿فاكهون﴾</span></span>، أو في محل نصب على الحال.</p></div>"
  36,56,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿هم وأزواجهم في ظلال على الأرائك متكئون﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿أزواجهم﴾</span></span> عطف على <span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿في ظلال﴾</span></span> جار ومجرور متعلقان بمحذوف خبر، و<span class="hlt"><span class="qpc-hafs">﴿على الأرائك﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿متكئون﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿متكئون﴾</span></span> خبر ثان لـ<span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span>، أو <span class="hlt"><span class="qpc-hafs">﴿وفي ظلال﴾</span></span> جار ومجرور متعلقان بمحذوف حال، و<span class="hlt"><span class="qpc-hafs">﴿متكئون﴾</span></span> خبر.</p></div>"
  36,57,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿لهم فيها فاكهة﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿لهم﴾</span></span> جار ومجرور متعلقان بمحذوف خبر مقدم، و<span class="hlt"><span class="qpc-hafs">﴿فيها﴾</span></span> جار ومجرور متعلقان بمحذوف حال، و<span class="hlt"><span class="qpc-hafs">﴿فاكهة﴾</span></span> مبتدأ مؤخر.</p><p><span class="hlt"><span class="qpc-hafs">﴿ولهم ما يدعون﴾</span></span>: الواو عاطفة. و<span class="hlt"><span class="qpc-hafs">﴿لهم﴾</span></span> جار ومجرور متعلقان بمحذوف خبر مقدم. و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span>: موصولة في محل رفع مبتدأ مؤخر. و<span class="hlt"><span class="qpc-hafs">﴿يدعون﴾</span></span> فعل مضارع مرفوع، والواو فاعل، وجملة <span class="hlt"><span class="qpc-hafs">﴿يدعون﴾</span></span> صلة الموصول لا محل لها من الإعراب، وجملة <span class="hlt"><span class="qpc-hafs">﴿لهم ما يدعون﴾</span></span> معطوفة على الجملة السابقة. أو <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> مصدرية، والمصدر المؤول من <span class="hlt"><span class="qpc-hafs">﴿ما يدعون﴾</span></span> مبتدأ مؤخر. أو <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> نكرة موصوفة في محل رفع مبتدأ مؤخر، وجملة <span class="hlt"><span class="qpc-hafs">﴿يدعون﴾</span></span> صفة ما.</p></div>"
  36,58,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿سلام﴾</span></span>: خبر لمبتدأ محذوف، والتقدير: هو سلام.</p><p><span class="hlt"><span class="qpc-hafs">﴿قولا﴾</span></span>: مفعول مطلق منصوب بالفتحة لفعل محذوف، وهو مع عامله صفة لـ<span class="hlt"><span class="qpc-hafs">﴿سلام﴾</span></span>، أي: سلام يقال لهم قولا.</p><p><span class="hlt"><span class="qpc-hafs">﴿من رب﴾</span></span>: جار ومجرور متعلقان بمحذوف صفة لـ<span class="hlt"><span class="qpc-hafs">﴿قولًا﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿رحيم﴾</span></span> صفة لـ<span class="hlt"><span class="qpc-hafs">﴿رب﴾</span></span>.</p><p>أو:</p><p><span class="hlt"><span class="qpc-hafs">﴿سلام﴾</span></span>: مبتدأ.</p><p><span class="hlt"><span class="qpc-hafs">﴿قولا﴾</span></span>: مفعول مطلق، وهو مصدر مؤكِّد لمضمون الجملة عامله مقدر، وهو مع عامله جملة معترضة.</p><p><span class="hlt"><span class="qpc-hafs">﴿من رب﴾</span></span> جار ومجرور متعلقان بمحذوف خبر المبتدأ <span class="hlt"><span class="qpc-hafs">﴿سلام﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿رحيم﴾</span></span> صفة لـ<span class="hlt"><span class="qpc-hafs">﴿رب﴾</span></span>.</p><p>والجملة الاسمية استئناف بياني فلا محل لها من الإعراب.</p></div>"
  36,59,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وامتازوا اليوم أيها المجرمون﴾</span></span>: الجملة مقول لقول محذوف، أي: ويقول لهم الله، و<span class="hlt"><span class="qpc-hafs">﴿امتازوا﴾</span></span> فعل أمر مبني على حذف النون، والواو فاعل، و<span class="hlt"><span class="qpc-hafs">﴿اليوم﴾</span></span> ظرف متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿امتازوا﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿أي﴾</span></span> منادى نكرة مقصودة محذوف منه حرف النداء، و<span class="hlt"><span class="qpc-hafs">﴿ها﴾</span></span> للتنبيه، و<span class="hlt"><span class="qpc-hafs">﴿المجرمون﴾</span></span> صفة لـ<span class="hlt"><span class="qpc-hafs">﴿أي﴾</span></span>.</p></div>"
  36,60,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ألم أعهد إليكم يا بني آدم﴾</span></span>: جملة منتظمة في سلك المقول لهم، والهمزة للاستفهام المتضمن هذه المعاني، و<span class="hlt"><span class="qpc-hafs">﴿لم﴾</span></span> حرف نفي وقلب وجزم، و<span class="hlt"><span class="qpc-hafs">﴿أعهد﴾</span></span> فعل مضارع مجزوم بـ<span class="hlt"><span class="qpc-hafs">﴿لم﴾</span></span>، وفاعله ضمير مستتر تقديره: أنا، و<span class="hlt"><span class="qpc-hafs">﴿إليكم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أعهد﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿يا﴾</span></span> حرف نداء، و<span class="hlt"><span class="qpc-hafs">﴿بني﴾</span></span> منادى مضاف، و<span class="hlt"><span class="qpc-hafs">﴿آدم﴾</span></span> مضاف إليه.</p><p><span class="hlt"><span class="qpc-hafs">﴿أن لا تعبدوا الشيطان﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿أن﴾</span></span>: تفسيرية. و<span class="hlt"><span class="qpc-hafs">﴿لا﴾</span></span>: ناهية. و<span class="hlt"><span class="qpc-hafs">﴿تعبدوا﴾</span></span>: فعل مضارع مجزوم بـ<span class="hlt"><span class="qpc-hafs">﴿لا﴾</span></span> الناهية، والواو فاعل. و<span class="hlt"><span class="qpc-hafs">﴿الشيطان﴾</span></span>: مفعول به. أو <span class="hlt"><span class="qpc-hafs">﴿أن﴾</span></span> مصدرية، وهي ومدخولها في تأويل مصدر منصوب بنزع الخافض، أي: ألم أعهد إليكم بترك عبادة الشيطان، وجملة <span class="hlt"><span class="qpc-hafs">﴿لا تعبدوا الشيطان﴾</span></span> صلة <span class="hlt"><span class="qpc-hafs">﴿أن﴾</span></span> المصدرية لا محل لها من الإعراب.</p><p><span class="hlt"><span class="qpc-hafs">﴿إنه لكم عدو مبين﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿إن﴾</span></span> حرف ناسخ، والهاء اسمها، و<span class="hlt"><span class="qpc-hafs">﴿لكم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿عدوّ﴾</span></span>، أو بمحذوف حال، و<span class="hlt"><span class="qpc-hafs">﴿عدو﴾</span></span> خبر إن، و<span class="hlt"><span class="qpc-hafs">﴿مبين﴾</span></span> صفة، والجملة تعليلية للنهي لا محل لها من الإعراب.</p></div>"
  36,61,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وأن اعبدوني هذا صراط مستقيم﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿أن اعبدوني﴾</span></span> عطف على <span class="hlt"><span class="qpc-hafs">﴿أن لا تعبدوا﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿اعبدوني﴾</span></span> فعل أمر، والواو فاعل، والياء مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿هذا﴾</span></span> مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿صراط﴾</span></span> خبر، و<span class="hlt"><span class="qpc-hafs">﴿مستقيم﴾</span></span> صفة، والجملة تعليلية للأمر.</p></div>"
  36,62,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ولقد أضل منكم جبلا كثيرا﴾</span></span>: كلام مستأنف لا محل له من الإعراب، واللام جواب للقسم المحذوف، و<span class="hlt"><span class="qpc-hafs">﴿قد﴾</span></span> حرف تحقيق، و<span class="hlt"><span class="qpc-hafs">﴿أضل﴾</span></span> فعل ماض، وفاعله مستتر تقديره: هو، و<span class="hlt"><span class="qpc-hafs">﴿منكم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أضل﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿جبلًّا﴾</span></span> مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿كثيرًا﴾</span></span> صفة.</p><p><span class="hlt"><span class="qpc-hafs">﴿أفلم تكونوا تعقلون﴾</span></span>: الهمزة للاستفهام الإنكاري، والفاء عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿لم﴾</span></span> حرف نفي وقلب وجزم، و<span class="hlt"><span class="qpc-hafs">﴿تكونوا﴾</span></span> فعل مضارع ناقص مجزوم بـ<span class="hlt"><span class="qpc-hafs">﴿لم﴾</span></span>، والواو اسمها، وجملة <span class="hlt"><span class="qpc-hafs">﴿تعقلون﴾</span></span> خبرها.</p></div>"
  36,63,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿هذه جهنم التي كنتم توعدون﴾</span></span>: كلام مستأنف لا محل له من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿هذه﴾</span></span> مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿جهنم﴾</span></span> خبر، و<span class="hlt"><span class="qpc-hafs">﴿التي﴾</span></span> صفة، وجملة <span class="hlt"><span class="qpc-hafs">﴿كنتم﴾</span></span> صلة الموصول لا محل لها من الإعراب. والتاء اسم كان، وجملة <span class="hlt"><span class="qpc-hafs">﴿توعدون﴾</span></span> خبرها.</p></div>"
  36,64,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿اصلوها اليوم بما كنتم تكفرون﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿اصلوها﴾</span></span> فعل أمر، والواو فاعل، والهاء مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿اليوم﴾</span></span> ظرف متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿اصلوها﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿بما﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿اصلوها﴾</span></span>، والباء للسببية، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> مصدرية، أي: بسبب كفركم، و<span class="hlt"><span class="qpc-hafs">﴿كنتم﴾</span></span> كان فعل ناقص ناسخ، والتاء اسمها، وجملة <span class="hlt"><span class="qpc-hafs">﴿تكفرون﴾</span></span> خبرها، وجملة <span class="hlt"><span class="qpc-hafs">﴿كنتم تكفرون﴾</span></span> لا محل لها من الإعراب.</p></div>"
  36,65,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿اليوم نختم على أفواههم﴾</span></span>: اليوم ظرف زمان متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿نختم﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿نختم﴾</span></span> فعل مضارع مرفوع، وفاعله مستتر تقديره: نحن، و<span class="hlt"><span class="qpc-hafs">﴿على أفواههم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿نختم﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿وتكلمنا أيديهم وتشهد أرجلهم بما كانوا يكسبون﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿تكلمنا﴾</span></span> فعل مضارع، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> مفعول به مقدم، و<span class="hlt"><span class="qpc-hafs">﴿أيديهم﴾</span></span> فاعل مؤخر، و<span class="hlt"><span class="qpc-hafs">﴿تشهد أرجلهم﴾</span></span> عطف على <span class="hlt"><span class="qpc-hafs">﴿تكلمنا أيديهم﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿بما﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿تكلمنا﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> مصدرية، أو موصولة، و<span class="hlt"><span class="qpc-hafs">﴿كانوا﴾</span></span>: كان فعل ماض ناقص، وواو الجماعة اسمها، وجملة <span class="hlt"><span class="qpc-hafs">﴿يكسبون﴾</span></span> خبرها.</p></div>"
  36,66,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ولو نشاء لطمسنا على أعينهم﴾</span></span>: الواو عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿لو﴾</span></span> شرطية، و<span class="hlt"><span class="qpc-hafs">﴿نشاء﴾</span></span> فعل مضارع، والفاعل مستتر، والمفعول به محذوف، أي: لو نشاء طمسها، واللام واقعة في جواب <span class="hlt"><span class="qpc-hafs">﴿لو﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿طمسنا﴾</span></span> لا محل لها من الإعراب، وهي فعل ماض، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> فاعل، و<span class="hlt"><span class="qpc-hafs">﴿على أعينهم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿طمسنا﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿فاستبقوا الصراط﴾</span></span>: الفاء عاطفة، واستبقوا فعل وفاعل، والجملة عطف على <span class="hlt"><span class="qpc-hafs">﴿لطمسنا﴾</span></span>، والصراط منصوب على نزع الخافض، والأصل: فاستبقوا إلى الصراط، أو مفعول به، وتضمين فاستبقوا معنى: ابتدروا.</p><p><span class="hlt"><span class="qpc-hafs">﴿فأنى يبصرون﴾</span></span>: الفاء عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿أنى﴾</span></span> اسم استفهام بمعنى كيف في محل نصب على الحال، و<span class="hlt"><span class="qpc-hafs">﴿يبصرون﴾</span></span> فعل مضارع وفاعل، والاستفهام هنا معناه النفي، أي: لا يبصرون.</p></div>"
  36,67,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ولو نشاء لمسخناهم على مكانتهم﴾</span></span>: الواو عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿لو﴾</span></span> شرطية، و<span class="hlt"><span class="qpc-hafs">﴿نشاء﴾</span></span> فعل مضارع، وفاعله مستتر تقديره: نحن، ومفعول <span class="hlt"><span class="qpc-hafs">﴿نشاء﴾</span></span> محذوف، أي: لو نشاء مسخهم، واللام واقعة في جواب <span class="hlt"><span class="qpc-hafs">﴿لو﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿مسخناهم﴾</span></span> لا محل لها من الإعراب، وهي فعل ماض، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> فاعل، والهاء مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿على مكانتهم﴾</span></span> جار ومجرور متعلقان بمحذوف حال، أي: لمسخناهم على حالتهم.</p><p><span class="hlt"><span class="qpc-hafs">﴿فما استطاعوا مضيا ولا يرجعون﴾</span></span>: الفاء عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> نافية، و<span class="hlt"><span class="qpc-hafs">﴿استطاعوا﴾</span></span> فعل وفاعل، و<span class="hlt"><span class="qpc-hafs">﴿مضيًّا﴾</span></span> مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿لا يرجعون﴾</span></span> عطف.</p></div>"
  36,68,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ومن نعمره ننكسه في الخلق أفلا يعقلون﴾</span></span>: كلام مستأنف لا محل له من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿مَن﴾</span></span> اسم شرط جازم، و<span class="hlt"><span class="qpc-hafs">﴿نعمره﴾</span></span> فعل الشرط، والفاعل مستتر تقديره: نحن، والهاء مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿ننكسه﴾</span></span> جواب الشرط، والفاعل مستتر تقديره: نحن، والهاء مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿في الخلق﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿ننكسه﴾</span></span>، أو بمحذوف حال، والهمزة للاستفهام الإنكاري، والفاء عاطفة على محذوف يقتضيه السياق، و<span class="hlt"><span class="qpc-hafs">﴿لا﴾</span></span> نافية، و<span class="hlt"><span class="qpc-hafs">﴿يعقلون﴾</span></span> فعل مضارع مرفوع والواو فاعل.</p></div>"
  36,69,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وما علمناه الشعر وما ينبغي له﴾</span></span>: كلام مستأنف لا محل له من الإعراب، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> نافية، و<span class="hlt"><span class="qpc-hafs">﴿علمناه﴾</span></span> فعل ماض وفاعل ومفعول به، و<span class="hlt"><span class="qpc-hafs">﴿الشعر﴾</span></span> مفعول به ثان، و<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> عطف، و<span class="hlt"><span class="qpc-hafs">﴿ينبغي﴾</span></span> فعل مضارع معطوف على <span class="hlt"><span class="qpc-hafs">﴿علمناه﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿له﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿ينبغي﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿إن هو إلا ذكر وقرآن مبين﴾</span></span>: إن نافية، و<span class="hlt"><span class="qpc-hafs">﴿هو﴾</span></span> مبتدأ، وإلا أداة حصر، و<span class="hlt"><span class="qpc-hafs">﴿ذكر﴾</span></span> خبر، و<span class="hlt"><span class="qpc-hafs">﴿قرآن﴾</span></span> عطف على <span class="hlt"><span class="qpc-hafs">﴿ذكر﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿مبين﴾</span></span> صفة.</p></div>"
  36,70,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿لينذر من كان حيا ويحق القول على الكافرين﴾</span></span>: اللام للتعليل، و<span class="hlt"><span class="qpc-hafs">﴿ينذر﴾</span></span> فعل مضارع منصوب بأن مضمرة بعد اللام، والمصدر المؤول من أن والفعل مجرور باللام، والجار والمجرور متعلقان بمحذوف تدل عليه قرينة الكلام، أي: أنزل عليه لينذر، و<span class="hlt"><span class="qpc-hafs">﴿مَن﴾</span></span> مفعول به، وجملة <span class="hlt"><span class="qpc-hafs">﴿كان﴾</span></span> صلة الموصول لا محل لها من الإعراب. واسم كان ضمير مستتر تقديره: هو، و<span class="hlt"><span class="qpc-hafs">﴿حيًّا﴾</span></span> خبرها، و<span class="hlt"><span class="qpc-hafs">﴿يحق﴾</span></span> عطف على <span class="hlt"><span class="qpc-hafs">﴿لينذر﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿القول﴾</span></span> فاعل، و<span class="hlt"><span class="qpc-hafs">﴿على الكافرين﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يحق﴾</span></span>.</p></div>"