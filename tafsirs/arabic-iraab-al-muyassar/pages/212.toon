quran[8]{c,v,t}:
  10,26,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿للذين أحسنوا الحسنى وزيادة﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿للذين﴾</span></span> جار ومجرور متعلقان بمحذوف خبر مقدم، وجملة أحسنوا صلة الذين لا محل لها من الإعراب، والحسنى مبتدأ مؤخر، <span class="hlt"><span class="qpc-hafs">﴿وزيادة﴾</span></span> عطف على الحسنى.</p><p><span class="hlt"><span class="qpc-hafs">﴿ولا يرهق وجوههم قتر ولا ذلة﴾</span></span>: الواو مستأنفة، والجملة بعدها استئنافية لا محل لها من الإعراب، أو الواو عاطفة، وجملة يرهق وجوههم معطوفة على الحسنى، ولا بد حينئذ من تقدير <span class="hlt"><span class="qpc-hafs">﴿أن﴾</span></span>، فإن شئت نصبت، وإن شئت رفعت، ولا نافية، ويرهق وجوههم فعل مضارع ومفعول به، و<span class="hlt"><span class="qpc-hafs">﴿قتر﴾</span></span> فاعل، <span class="hlt"><span class="qpc-hafs">﴿ولا ذلة﴾</span></span> عطف على قتر.</p><p><span class="hlt"><span class="qpc-hafs">﴿أولئك أصحاب الجنة هم فيها خالدون﴾</span></span>: أولئك مبتدأ، وأصحاب خبر، والجنة مضاف إليه، و<span class="hlt"><span class="qpc-hafs">﴿هم﴾</span></span> مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿فيها﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿خالدون﴾</span></span>، وخالدون خبر، والجملة حالية.</p></div>"
  10,27,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿والذين كسبوا السيئات جزاء سيئة بمثلها﴾</span></span>: الواو عاطفة، والذين معطوفة نسقًا على الذين الأولى، أي: للذين أحسنوا الحسنى، وللذين كسبوا السيئات جزاء سيئة بمثلها، فيتعادل التقسيم، وهذا أفضل الوجوه، أو الواو استئنافية والجملة بعدها مستأنفة لا محل لها من الإعراب، والذين مبتدأ، خبره <span class="hlt"><span class="qpc-hafs">﴿جزاء سيئة بمثلها﴾</span></span>، وكسبوا السيئات: الجملة من الفعل والفاعل والمفعول به صلة الموصول لا محل لها من الإعراب، وجزاء مبتدأ ثان، وسيئة مضاف إليه، و<span class="hlt"><span class="qpc-hafs">﴿بمثلها﴾</span></span> جار ومجرور متعلقان بمحذوف خبر <span class="hlt"><span class="qpc-hafs">﴿جزاء﴾</span></span>، أي: مقدر بمثلها.</p><p><span class="hlt"><span class="qpc-hafs">﴿وترهقهم ذلة﴾</span></span>: الواو مستأنفة، والجملة مستأنفة لا محل لها من الإعراب، وقيل: هذه الجملة عطف على كسبوا، وقيل: الواو حالية، وجملة <span class="hlt"><span class="qpc-hafs">﴿ترهقهم ذلة﴾</span></span> حالية، وترهقهم فعل مضارع مرفوع، والهاء مفعول به، وذلة فاعل مرفوع.</p><p><span class="hlt"><span class="qpc-hafs">﴿ما لهم من الله من عاصم﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> نافية، و<span class="hlt"><span class="qpc-hafs">﴿لهم﴾</span></span> جار ومجرور متعلقان بمحذوف خبر مقدم، و<span class="hlt"><span class="qpc-hafs">﴿من الله﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿عاصم﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿من عاصم﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿من﴾</span></span> حرف جر صلة، و<span class="hlt"><span class="qpc-hafs">﴿عاصم﴾</span></span> مبتدأ مؤخر مرفوع محلا مجرور بـ<span class="hlt"><span class="qpc-hafs">﴿مِن﴾</span></span> لفظًا.</p><p><span class="hlt"><span class="qpc-hafs">﴿كأنما أغشيت وجوههم قطعا من الليل مظلما﴾</span></span>: الجملة مستأنفة لا محل لها من الإعراب، وكأنما كافة ومكفوفة، وأغشيت فعل ماض مبني لما لم يسمَّ فاعله، ووجوههم نائب فاعل، وقطعًا مفعول به ثان، و<span class="hlt"><span class="qpc-hafs">﴿من الليل﴾</span></span> جار ومجرور متعلقان بمحذوف صفة لـ<span class="hlt"><span class="qpc-hafs">﴿قطعا﴾</span></span>، ومظلمًا حال من الليل، والعامل فيه إما <span class="hlt"><span class="qpc-hafs">﴿أغشيت﴾</span></span>، وإما أن يكون معنى الفعل في قوله: من الليل.</p><p><span class="hlt"><span class="qpc-hafs">﴿أولئك أصحاب النار هم فيها خالدون﴾</span></span>: الجملة مستأنفة لا محل لها من الإعراب، وأولئك مبتدأ، وأصحاب النار خبر، وهم فيها خالدون جملة اسمية حالية منهم.</p></div>"
  10,28,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ويوم نحشرهم جميعا﴾</span></span>: الظرف متعلق بمحذوف مفهوم من الآية السابقة، أي: نفعل ذلك كله يوم نحشرهم، وجملة نحشرهم مضاف إليها، وجميعًا نصب على الحال.</p><p><span class="hlt"><span class="qpc-hafs">﴿ثم نقول للذين أشركوا مكانكم أنتم وشركاؤكم﴾</span></span>: ثم حرف عطف وتراخ، و<span class="hlt"><span class="qpc-hafs">﴿نقول﴾</span></span> معطوف على متعلق الظرف، أي: نفعل ذلك كله ثم نقول، أو معطوف على نحشرهم، و<span class="hlt"><span class="qpc-hafs">﴿للذين﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿نقول﴾</span></span>، وجملة أشركوا صلة الذين لا محل لها من الإعراب، ومكانكم اسم فعل أمر معناه: الزموا، وأنتم ضمير منفصل في محل رفع تأكيد للضمير في مكانكم، وشركاؤكم عطف عليه.</p><p><span class="hlt"><span class="qpc-hafs">﴿فزيلنا بينهم وقال شركاؤهم ما كنتم إيانا تعبدون﴾</span></span>: الفاء استئنافية، وزيلنا فعل وفاعل، و<span class="hlt"><span class="qpc-hafs">﴿بينهم﴾</span></span> ظرف متعلق بزيلنا، وجملة <span class="hlt"><span class="qpc-hafs">﴿فزيلنا بينهم﴾</span></span> مستأنفة لا محل لها من الإعراب. و<span class="hlt"><span class="qpc-hafs">﴿قال شركاؤهم﴾</span></span> فعل وفاعل، وما نافية، و<span class="hlt"><span class="qpc-hafs">﴿كنتم﴾</span></span> فعل ماض ناقص ناسخ، والتاء اسمها، وإيانا ضمير منفصل مفعول مقدم لتعبدون، وجملة تعبدون نصب خبر كنتم.</p></div>"
  10,29,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فكفى بالله شهيدا بيننا وبينكم﴾</span></span>: الفاء استئنافية، والجملة بعدها مستأنفة لا محل لها من الإعراب، وكفى فعل ماض، والباء حرف صلة، و<span class="hlt"><span class="qpc-hafs">﴿الله﴾</span></span> فاعل محلاًّ، وشهيدًا: منصوب على التمييز، أو على الحال، فإن كان الاسم جامدًا فالنصب على التمييز.</p><p><span class="hlt"><span class="qpc-hafs">﴿إن كنا عن عبادتكم لغافلين﴾</span></span>: إن مخففة من الثقيلة، واسمها ضمير محذوف، أي: إننا، وكنا فعل ماض ناقص ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> اسمها، و<span class="hlt"><span class="qpc-hafs">﴿عن عبادتكم﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿غافلين﴾</span></span>، واللام الفارقة، وهي التي أبعدت إن النافية، وغافلين خبر كنا، وجملة <span class="hlt"><span class="qpc-hafs">﴿كنا...﴾</span></span> في محل رفع خبر إن.</p></div>"
  10,30,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿هنالك تبلو كل نفس ما أسلفت﴾</span></span>: هنالك اسم إشارة في محل نصب على الظرفية المكانية، وهو متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿تبلو﴾</span></span>، واللام للبعد، والكاف للخطاب، وتبلو كل نفس مضارع وفاعل، وما اسم موصول مفعول به، وجملة أسلفت صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> لا محل لها من الإعراب.</p><p><span class="hlt"><span class="qpc-hafs">﴿وردوا إلى الله مولاهم الحق﴾</span></span>: الواو عاطفة، وردوا فعل ماض مبني لما لم يسمَّ فاعله، والواو نائب فاعل، و<span class="hlt"><span class="qpc-hafs">﴿إلى الله﴾</span></span> جار ومجرور متعلقان بردوا، ومولاهم صفة، أو بدل من <span class="hlt"><span class="qpc-hafs">﴿الله﴾</span></span>، والحق صفة، لأنهم كانوا يتولون ما ليس لربوبيته حقيقة.</p><p><span class="hlt"><span class="qpc-hafs">﴿وضل عنهم ما كانوا يفترون﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿وضل﴾</span></span> الواو عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿ضل﴾</span></span> معطوف على ردوا، و<span class="hlt"><span class="qpc-hafs">﴿عنهم﴾</span></span> جار ومجرور متعلقان بضل، وما اسم موصول فاعل، و<span class="hlt"><span class="qpc-hafs">﴿كانوا﴾</span></span> فعل ماض ناقص ناسخ، والواو اسمها، وجملة كانوا يفترون صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> لا محل لها من الإعراب، وجملة يفترون خبر كانوا.</p></div>"
  10,31,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قل من يرزقكم من السماء والأرض﴾</span></span>: قل فعل أمر مبني على السكون، <span class="hlt"><span class="qpc-hafs">﴿مَن﴾</span></span> اسم استفهام مبتدأ، وجملة يرزقكم خبر، و<span class="hlt"><span class="qpc-hafs">﴿من السماء﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يرزقكم﴾</span></span>، والأرض عطف على السماء.</p><p><span class="hlt"><span class="qpc-hafs">﴿أمن يملك السمع والأبصار﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿أمَّن﴾</span></span> أم: منقطعة بمعنى بل للإضراب الانتقالي من استفهام إلى آخر، لأنها ليست مسبوقة بهمزة استفهام ولا تسوية، ومَن اسم استفهام مبتدأ، وجملة يملك خبر، والسمع مفعول به، والأبصار عطف على السمع.</p><p><span class="hlt"><span class="qpc-hafs">﴿ومن يخرج الحي من الميت ويخرج الميت من الحي ومن يدبر الأمر﴾</span></span>: الواو عاطفة، ومَن اسم استفهام مبتدأ، <span class="hlt"><span class="qpc-hafs">﴿يخرج الحي﴾</span></span> فعل مضارع، والفاعل مستتر، والحي مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿من الميت﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يخرج﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿يخرج الحي من الميت﴾</span></span> خبر مَن، و<span class="hlt"><span class="qpc-hafs">﴿يخرج الميت﴾</span></span> فعل مضارع، والفاعل مستتر، والميت مفعول به، و<span class="hlt"><span class="qpc-hafs">﴿من الحي﴾</span></span> جار ومجرور متعلقان بالفعل <span class="hlt"><span class="qpc-hafs">﴿يخرج﴾</span></span> الثاني، وجملة <span class="hlt"><span class="qpc-hafs">﴿يخرج الميت من الحي﴾</span></span> معطوفة على <span class="hlt"><span class="qpc-hafs">﴿يخرج الحي من الميت﴾</span></span>. <span class="hlt"><span class="qpc-hafs">﴿ومَن﴾</span></span> الواو عاطفة، ومَن اسم استفهام مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿يدبر﴾</span></span> فعل مضارع، والفاعل مستتر تقديره هو، و<span class="hlt"><span class="qpc-hafs">﴿الأمر﴾</span></span> مفعول به، وجملة <span class="hlt"><span class="qpc-hafs">﴿يدبر الأمر﴾</span></span> خبر مَن.</p><p><span class="hlt"><span class="qpc-hafs">﴿فسيقولون الله﴾</span></span>: الفاء في جواب شرط مقدر، أي: إن سألتهم فسيقولون، ويقولون فعل وفاعل، و<span class="hlt"><span class="qpc-hafs">﴿الله﴾</span></span> خبر لمبتدأ محذوف، أي: هو الله، أو مبتدأ والخبر محذوف، والتقدير: الله يفعل هذه الأشياء كلها، والجملة من المبتدأ والخبر مقول القول.</p><p><span class="hlt"><span class="qpc-hafs">﴿فقل أفلا تتقون﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿فقل﴾</span></span> الفاء عاطفة، وقل فعل أمر، والفاعل مستتر تقديره أنت، وجملة <span class="hlt"><span class="qpc-hafs">﴿قل﴾</span></span> معطوفة على <span class="hlt"><span class="qpc-hafs">﴿قل﴾</span></span> الأولى، و<span class="hlt"><span class="qpc-hafs">﴿أفلا﴾</span></span> الهمزة للاستفهام، والفاء عاطفة على مقدر، أي: أتعلمون ذلك فلا تتقون، و<span class="hlt"><span class="qpc-hafs">﴿لا﴾</span></span> نافية، و<span class="hlt"><span class="qpc-hafs">﴿تتقون﴾</span></span> فعل مضارع وواو الجماعة فاعل.</p></div>"
  10,32,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فذلكم الله ربكم الحق﴾</span></span>: الفاء عاطفة، وذلك مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿الله﴾</span></span> خبر، وربكم بدل من الله، أو صفة، والحق صفة لـ<span class="hlt"><span class="qpc-hafs">﴿ربكم﴾</span></span>، أو <span class="hlt"><span class="qpc-hafs">﴿الله﴾</span></span> مبتدأ ثان، وربكم خبره، والجملة خبر اسم الإشارة.</p><p><span class="hlt"><span class="qpc-hafs">﴿فماذا بعد الحق إلا الضلال فأنى تصرفون﴾</span></span>: الفاء عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿ماذا﴾</span></span> اسم استفهام في محل رفع مبتدأ، أو  ذا موصول خبر لـ<span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> الاستفهامية، و<span class="hlt"><span class="qpc-hafs">﴿بعد﴾</span></span> ظرف متعلق بمحذوف حال، وإلا أداة حصر، والضلال بدل من ذا، والاستفهام بمعنى النفي أيضًا، والفاء عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿أنى﴾</span></span> اسم استفهام بمعنى كيف في محل نصب حال من فاعل تصرفون، وتصرفون بالبناء لما لم يسمَّ فاعله فعل مضارع، والواو نائب فاعل.</p></div>"
  10,33,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿كذلك حقت كلمت ربك على الذين فسقوا أنهم لا يؤمنون﴾</span></span>: <span class="hlt"><span class="qpc-hafs">﴿كذلك﴾</span></span> الكاف: اسم بمعنى مثل مبني على الفتح في محل نصب صفة لمصدر محذوف، والتقدير: حقًا مثلَ ذلك حقت كلمة ربك، وذلك: <span class="hlt"><span class="qpc-hafs">﴿ذا﴾</span></span> اسم إشارة في محل جر مضاف إليه، واللام للبعد، والكاف حرف خطاب، والإشارة بـ<span class="hlt"><span class="qpc-hafs">﴿ذلك﴾</span></span> إلى صرفهم عن الحق بعد الإقرار به في قوله: <span class="hlt"><span class="qpc-hafs">﴿فسيقولون الله﴾</span></span>، وقيل: الإشارة إلى الحق. <span class="hlt"><span class="qpc-hafs">﴿وحقت كلمة ربك﴾</span></span> فعل وفاعل، و<span class="hlt"><span class="qpc-hafs">﴿على الذين﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿حقت﴾</span></span>، وجملة <span class="hlt"><span class="qpc-hafs">﴿فسقوا﴾</span></span> صلة الموصول لا محل لها من الإعراب، وأن وما في حيزها بدل من <span class="hlt"><span class="qpc-hafs">﴿كلمة ربك﴾</span></span>، أي: حق عليهم انتفاء الإيمان، وجملة <span class="hlt"><span class="qpc-hafs">﴿لا يؤمنون﴾</span></span> خبر أن.</p></div>"