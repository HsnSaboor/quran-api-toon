quran[12]{c,v,t}:
  20,65,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قالوا يا موسى إما أن تلقي وإما أن نكون أول من ألقى﴾</span></span>: إما حرف شرط وتفصيل، وأن وما بعدها في تأويل مصدر منصوب بفعل محذوف، تقديره: اختر أحد الأمرين، أو مرفوع بأنه خبر مبتدأ محذوف تقديره: الأمر إلقاؤك، أو مبتدأ والخبر محذوف، والتقدير: إلقاؤك أول، <span class="hlt"><span class="qpc-hafs">﴿وإما أن نكون﴾</span></span> عطف على ما تقدم، واسم نكون مضمر تقديره: نحن، وأول خبرها، ومن مضاف إليه، وجملة ألقى صلة <span class="hlt"><span class="qpc-hafs">﴿من﴾</span></span> لا محل لها من الإعراب. أو أن وما في حيزها في محل نصب بفعل مضمر، أي: اختر إلقاءك أولًا، أو إلقاءنا.</p></div>"
  20,66,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قال بل ألقوا فإذا حبالهم وعصيهم يخيل إليه من سحرهم أنها تسعى﴾</span></span>: بل حرف إضراب وعطف، وألقوا فعل أمر مبني على حذف النون، والواو فاعل، فإذا الفاء عاطفة على محذوف تقديره: فألقوا، وإذا للمفاجأة، والجملة ابتدائية، وحبالهم مبتدأ، وعصيهم عطف عليه، وجملة يخيل إليه خبر حبالهم، ومن سحرهم جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يخيل﴾</span></span>، وأنها: أن حرف ناسخ، والهاء اسمها، وجملة تسعى خبر أن، وأن وما بعدها في تأويل مصدر نائب فاعل ليخيل، أي: يخيل إليه سعيها.</p></div>"
  20,67,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فأوجس في نفسه خيفة موسى﴾</span></span>: الفاء عاطفة، وأوجس فعل ماض، وفي نفسه جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أوجس﴾</span></span>، وخيفة مفعول به، وموسى فاعل.</p></div>"
  20,68,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قلنا لا تخف إنك أنت الأعلى﴾</span></span>: قلنا: فعل وفاعل، وجملة لا تخف مقول القول، ولا ناهية، وتخف فعل مضارع مجزوم بلا الناهية، والفاعل مستتر تقديره: أنت، وجملة <span class="hlt"><span class="qpc-hafs">﴿إنك...﴾</span></span> مستأنفة لا محل لها من الإعراب، وإن حرف ناسخ، والكاف اسمها، وأنت تأكيد، أو ضمير فصل، أو مبتدأ، والأعلى خبر إن، أو خبر أنت، والجملة خبر إن.</p></div>"
  20,69,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وألق ما في يمينك تلقف ما صنعوا﴾</span></span>: الواو عاطفة، وألق الواو عاطفة، وألق فعل أمر مبني على حذف حرف العلة، والفاعل مستتر تقديره: أنت، وما مفعول به، وفي يمينك جار ومجرور متعلقان بمحذوف صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span>، وجملة الصلة لا محل لها من الإعراب، وتلقف جواب الطلب مجزوم وعلامة جزمه السكون، وفاعل تلقف ضمير مستتر تقديره: هي، وما مفعول به، وجملة صنعوا صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> لا محل لها من الإعراب.</p><p><span class="hlt"><span class="qpc-hafs">﴿إنما صنعوا كيد ساحر ولا يفلح الساحر حيث أتى﴾</span></span>: تعليل لقوله تلقف، وإن حرف ناسخ، وما اسم موصول مبني في محل نصب اسم إن، وجملة صنعوا صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> لا محل لها من الإعراب، وكيد ساحر خبر إن، وما إما موصولة أو موصوفة أو مصدرية أي إن الذي صنعوه أو إن شيئًا صنعوه أو إن صنعهم، والإعراب واحد، ولا الواو عاطفة، ولا نافية، ويفلح الساحر فعل مضارع وفاعل، وحيث ظرف مكان مبني على الضم متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿يفلح﴾</span></span>، وجملة أتى مضاف إليه.</p></div>"
  20,70,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فألقي السحرة سجدا قالوا آمنا برب هارون وموسى﴾</span></span>: الفاء عاطفة، وألقي فعل ماض مبني لما لم يسمَّ فاعله، والسحرة نائب فاعل، وسجدًا حال من السحرة، قالوا فعل وفاعل، وجملة آمنا مقول القول، وهو فعل وفاعل، و<span class="hlt"><span class="qpc-hafs">﴿برب﴾</span></span> الجار والمجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿آمنا﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿هارون﴾</span></span> مضاف إليه، وموسى معطوف مجرور.</p></div>"
  20,71,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قال آمنتم له قبل أن آذن لكم﴾</span></span>: جملة آمنتم مقول القول، وآمنتم: الهمزة للاستفهام والتقريع والتوبيخ، حذفت الهمزة الأولى، وسهلت الثانية، وهو فعل ماض وفاعل، و<span class="hlt"><span class="qpc-hafs">﴿له﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿آمنتم﴾</span></span>، و<span class="hlt"><span class="qpc-hafs">﴿قبل﴾</span></span> ظرف متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿آمنتم﴾</span></span> أيضًا، والمصدر المؤول من <span class="hlt"><span class="qpc-hafs">﴿أن آذن لكم﴾</span></span> مضاف إليه.</p><p><span class="hlt"><span class="qpc-hafs">﴿إنه لكبيركم الذي علمكم السحر﴾</span></span>: إن حرف ناسخ، والهاء اسمها، واللام المزحلقة، وكبيرهم خبرها، والذي صفة، وجملة <span class="hlt"><span class="qpc-hafs">﴿علمكم السحر﴾</span></span> صلة الذي لا محل لها من الإعراب، والسحر مفعول به ثان لعلمكم.</p><p><span class="hlt"><span class="qpc-hafs">﴿فلأقطعن أيديكم وأرجلكم من خلاف﴾</span></span>: الفاء الفصيحة، واللام واقعة في جواب القسم، وأقطعن فعل مضارع مبني على الفتح لاتصاله بنون التوكيد الثقيلة، والفاعل مستتر تقديره: أنا، وأيديكم مفعول به، وأرجلكم عطف على أيديكم، ومن خلاف جار ومجرور متعلقان بمحذوف حال بمعنى مختلفة، ومِن حرف لابتداء الغاية المكانية.</p><p><span class="hlt"><span class="qpc-hafs">﴿ولأصلبنكم في جذوع النخل﴾</span></span>: الواو حرف عطف، ولأصلبنكم عطف على لأقطعن، وفي الظرفية، والظرف متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿أصلبنكم﴾</span></span>.</p><p><span class="hlt"><span class="qpc-hafs">﴿ولتعلمن أينا أشد عذابا وأبقى﴾</span></span>: الواو عاطفة، ولتعلمن عطف على لأصلبنكم، و<span class="hlt"><span class="qpc-hafs">﴿أينا﴾</span></span> استفهامية مبتدأ، وأشد خبر، الجملة في محل نصب سدت مسد مفعولي تعلمن، أو أي موصولة، وهي المفعول به لتعلمن، وحذف صدر صلتها، وأشد خبر لمبتدأ محذوف تقديره: هو، وجملة أشد صلة الموصول لا محل لها من الإعراب، وأبقى عطف على أشد.</p></div>"
  20,72,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قالوا لن نؤثرك على ما جاءنا من البينات والذي فطرنا﴾</span></span>: لن حرف نفي ونصب واستقبال، ونؤثرك مضارع منصوب بلن، والكاف مفعول به، والفاعل مستتر تقديره: نحن، والجملة مقول قولهم، و<span class="hlt"><span class="qpc-hafs">﴿على ما﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿نؤثرك﴾</span></span>، وجملة جاءنا صلة، ومن البينات جار ومجرور متعلقان بمحذوف حال، والذي عطف على ما، أو الواو للقسم، والذي مجرور بواو القسم، أي: مقسم به، وهو الله تعالى، وفطرنا صلة، والجار والمجرور متعلقان بفعل محذوف تقديره: أقسم، وجواب القسم محذوف تقديره: لا نؤثرك على الذي جاءنا من الحق.</p><p><span class="hlt"><span class="qpc-hafs">﴿فاقض ما أنت قاض إنما تقضي هذه الحياة الدنيا﴾</span></span>: الفاء الفصيحة، واقض فعل أمر مبني على حذف حرف العلة، وفاعله ضمير مستتر تقديره: أنت، وما مفعول به، وأنت مبتدأ، وقاض خبر مرفوع، وعلامة رفعه الضمة المقدرة للثقل على الياء المحذوفة لالتقاء الساكنين، وجملة أنت قاض صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> لا محل لها من الإعراب، والعائد محذوف، أي: قاضيه، وإنما كافة ومكفوفة، وتقضي فعل مضارع، والفاعل مستتر تقديره أنت، ومفعول تقضي محذوف تقديره: مأربك، وهذه ظرف، والحياة بدل، والدنيا صفة، والظرف متعلق بـ<span class="hlt"><span class="qpc-hafs">﴿تقضي﴾</span></span>، وقيل: ما موصولة أو مصدرية، وهي اسم إن، والخبر هو الظرف، أو هذه الحياة الدنيا مفعول به على السعة.</p></div>"
  20,73,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إنا آمنا بربنا ليغفر لنا خطايانا وما أكرهتنا عليه من السحر والله خير وأبقى﴾</span></span>: إن حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿نا﴾</span></span> اسمها، وجملة آمنا خبرها، وبربنا جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿آمنا﴾</span></span>، واللام للتعليل، ويغفر فعل مضارع منصوب بأن مضمرة بعد لام التعليل، والمصدر المؤول من أن والفعل مجرور باللام، والجار والمجرور متعلقان بآمنا، و<span class="hlt"><span class="qpc-hafs">﴿لنا﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يغفر﴾</span></span>، وما عطف على خطايانا، وقيل: الواو ابتدائية، وما مبتدأ، وجملة أكرهتنا صلة <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> لا محل لها من الإعراب، والخبر محذوف، أي: مرفوع عنا، و<span class="hlt"><span class="qpc-hafs">﴿عليه﴾</span></span> جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿أكرهتنا﴾</span></span>، ومن السحر حال، والله مبتدأ، وخير خبر، وأبقى عطف على خير.</p></div>"
  20,74,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إنه من يأت ربه مجرما فإن له جهنم لا يموت فيها ولا يحيا﴾</span></span>: إن حرف ناسخ، والهاء اسمها، و<span class="hlt"><span class="qpc-hafs">﴿مَن﴾</span></span> اسم شرط جازم في محل رفع مبتدأ، ويأت فعل الشرط وعلامة جزمه حذف حرف العلة، وفاعل يأت مستتر تقديره: هو، وربه مفعول به، والهاء مضاف إليه، ومجرمًا حال من فاعل يأت، فإن الفاء رابطة لجواب الشرط، وإن حرف ناسخ، و<span class="hlt"><span class="qpc-hafs">﴿له﴾</span></span> جار ومجرور متعلقان بمحذوف خبر إن المقدم، وجهنم اسمها المتأخر، وجملة لا يموت فيها حالية من الهاء في له، أو من جهنم، وفيها جار ومجرور متعلقان بـ<span class="hlt"><span class="qpc-hafs">﴿يموت﴾</span></span>، ولا يحيا عطف على لا يموت.</p></div>"
  20,75,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ومن يأته مؤمنا قد عمل الصالحات فأولئك لهم الدرجات العلا﴾</span></span>: الواو عاطفة، و<span class="hlt"><span class="qpc-hafs">﴿مَن﴾</span></span> اسم شرط جازم في محل رفع مبتدأ، ويأت فعل الشرط، وعلامة جزمه حذف حرف العلة، وفاعل يأت مستتر تقديره: هو، والهاء مفعول به، ومؤمنًا حال من فاعل يأت، وجملة <span class="hlt"><span class="qpc-hafs">﴿قد عمل الصالحات﴾</span></span> صفة لـ<span class="hlt"><span class="qpc-hafs">﴿مؤمنًا﴾</span></span>، فأولئك الفاء رابطة، وأولئك اسم إشارة مبتدأ، و<span class="hlt"><span class="qpc-hafs">﴿لهم﴾</span></span> جار ومجرور متعلقان بمحذوف خبر مقدم، والدرجات مبتدأ مؤخر، والجملة الاسمية خبر أولئك، وجملة فأولئك في محل جزم جواب الشرط، وفعل الشرط وجوابه خبر من، والعلى صفة للدرجات.</p></div>"
  20,76,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿جنات عدن تجري من تحتها الأنهار خالدين فيها وذلك جزاء من تزكى﴾</span></span>: جنات عدن بدل من الدرجات العلى، أو خبر لمبتدأ محذوف، وجملة تجري من تحتها الأنهار صفة لجنات، وخالدين فيها حال من <span class="hlt"><span class="qpc-hafs">﴿من﴾</span></span>، وفيها جار ومجرور متعلقان بخالدين، وذلك مبتدأ، وجزاء خبر، ومن مضاف إليه، وجملة تزكى صلة <span class="hlt"><span class="qpc-hafs">﴿من﴾</span></span> لا محل لها من الإعراب.</p></div>"