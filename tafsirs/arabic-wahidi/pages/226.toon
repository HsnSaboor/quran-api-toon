quran[8]{c,v,t}:
  11,38,"<div class=ar lang=ar><p>وقوله: <span class="qpc-hafs">﴿إن تسخروا منا﴾</span> أَيْ: لما يرون من صنعه الفلك <span class="qpc-hafs">﴿فإنا نسخر منكم﴾</span> ونعجب من غفلتكم عمَّا قد أظلَّكم من العذاب</p></div>"
  11,39,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فسوف تعلمون مَنْ يأتيه عذابٌ يخزيه﴾</span> أَيْ: فسوف تعلمون مَنْ أخسر عاقبةً</p></div>"
  11,40,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿حتى إذا جاء أمرنا﴾</span> بعذابهم وهلاكهم <span class="qpc-hafs">﴿وفار التنور﴾</span> بالماء يعني: تنُّور الخابز وكان ذلك علامةً لنوح عليه السَّلام فركب السَّفينة <span class="qpc-hafs">﴿قلنا احمل فيها﴾</span> في الفلك <span class="qpc-hafs">﴿من كلّ زوجين﴾</span> من كلِّ شيءٍ له زوج <span class="qpc-hafs">﴿اثنين﴾</span> ذكراً وأنثى <span class="qpc-hafs">﴿وأهلك﴾</span> واحمل أهلك يعني: ولده وعياله <span class="qpc-hafs">﴿إِلا مَنْ سَبَقَ عَلَيْهِ القول﴾</span> يعني: مَنْ كان في علم الله أنَّه يغرق بكفره وهو امرأته واغلة وابنه كنعان <span class="qpc-hafs">﴿وَمَنْ آمَنَ﴾</span> واحمل مَنْ صدَّقك <span class="qpc-hafs">﴿وما آمن معه إلاَّ قليل﴾</span> ثمانون إنساناً</p></div>"
  11,41,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَقَالَ﴾</span> نوحٌ لقومه الذين أُمر بحملهم: <span class="qpc-hafs">﴿ارْكَبُوا﴾</span> يعني: الماء <span class="qpc-hafs">﴿فيها﴾</span> في الفلك <span class="qpc-hafs">﴿بسم الله مجريها ومرساها﴾</span> يريد: تجري باسم الله وترسي باسم الله فكان إذا أراد أن تجري السفينة قال: بسم الله فجرت وإذا أراد أن ترسي قال: بسم الله فَرَسَتْ أَيْ: ثبتت <span class="qpc-hafs">﴿إن ربي لغفور﴾</span> لأصحاب السَّفينة <span class="qpc-hafs">﴿رحيم﴾</span> بهم</p></div>"
  11,42,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وهي تجري بهم في موج﴾</span> جمع موجةٍ وهي ما يرتفع من الماء <span class="qpc-hafs">﴿كالجبال﴾</span> في العِظَم <span class="qpc-hafs">﴿ونادى نوح ابنه﴾</span> كنعان وكان كافراً <span class="qpc-hafs">﴿وكان في معزل﴾</span> من السَّفينة أَيْ: في ناحيةٍ بعيدة عنها</p></div>"
  11,43,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿قال سآوي إلى جبل﴾</span> أنضمُّ إلى جبلٍ <span class="qpc-hafs">﴿يعصمني﴾</span> يمنعني <span class="qpc-hafs">﴿من الماء﴾</span> فلا أغرق <span class="qpc-hafs">﴿قال﴾</span> نوح: <span class="qpc-hafs">﴿لا عَاصِمَ الْيَوْمَ مِنْ أَمْرِ اللَّهِ﴾</span> لا مانع اليوم من عذاب الله <span class="qpc-hafs">﴿إِلا من رحم﴾</span> لكن من رحم الله فإنَّه معصوم <span class="qpc-hafs">﴿وحال بينهما﴾</span> بين ابن نوحٍ وبين الجبل <span class="qpc-hafs">﴿الموج﴾</span> ما ارتفع من الماء</p></div>"
  11,44,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وقيل يا أرض ابلعي ماءك﴾</span> اشربي ماءك <span class="qpc-hafs">﴿ويا سماء أقلعي﴾</span> أمسكي عن إنزال الماء <span class="qpc-hafs">﴿وغيض الماء﴾</span> نقص <span class="qpc-hafs">﴿وَقُضِيَ الأَمْرُ﴾</span> أُهلك قوم نوحٍ وفُرِغ من ذلك <span class="qpc-hafs">﴿واستوت﴾</span> السَّفينة <span class="qpc-hafs">﴿على الجودي﴾</span> وهو جبل بالجزيرة <span class="qpc-hafs">﴿وقيل بعداً﴾</span> من رحمة الله <span class="qpc-hafs">﴿للقوم الظالمين﴾</span> المتَّخذين من دون الله آلهاً</p></div>"
  11,45,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَنَادَى نُوحٌ رَبَّهُ فَقَالَ رَبِّ إِنَّ ابْنِي﴾</span> كنعان <span class="qpc-hafs">﴿من أهلي وإنَّ وعدك الحق﴾</span> وعدتني أن تنجيني وأهلي أَيْ: فأنجه من الغرق <span class="qpc-hafs">﴿وأنت أحكم الحاكمين﴾</span> أعدل العادلين</p></div>"