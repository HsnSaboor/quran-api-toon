quran[8]{c,v,t}:
  2,127,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وإذ يرفع إبراهيم القواعد﴾</span> أصول الأساس <span class="qpc-hafs">﴿من البيت وإسماعيل﴾</span> ويقولان: <span class="qpc-hafs">﴿ربنا تقبلْ منَّا﴾</span> تقرُّبنا إليك ببناء هذا البيت <span class="qpc-hafs">﴿إنك أنت السميع﴾</span> لدعائنا <span class="qpc-hafs">﴿العليمُ﴾</span> بما في قلوبنا</p></div>"
  2,128,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ربنا واجعلنا مسلمين لك﴾</span> مطيعي مُنقادين لحكمك <span class="qpc-hafs">﴿ومن ذريتنا أمة﴾</span> جماعةً <span class="qpc-hafs">﴿مسلمة لك﴾</span> وهم المهاجرون والأنصار والتَّابعون بإحسان <span class="qpc-hafs">﴿وأرنا مناسكنا﴾</span> عرّفنا مُتَعبَّداتنا</p></div>"
  2,129,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ربنا وابعث فيهم﴾</span> في الأمَّة المسلمة <span class="qpc-hafs">﴿رسولاً منهم﴾</span> يريد: محمدا ﷺ <span class="qpc-hafs">﴿يتلو عليهم آياتك ويعلمهم الكتاب والحكمة﴾</span> أَي: القرآن <span class="qpc-hafs">﴿ويزكيهم﴾</span> ويُطهِّرهم من الشِّرك <span class="qpc-hafs">﴿إنك أنت العزيز﴾</span> الغالب القويُّ الذي لا يعجزه شيءٌ ومضى تفسير الحكيم</p></div>"
  2,130,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ومَنْ يرغب عن ملة إبراهيم﴾</span> أَيْ: وما يرغب عنها ولا يتركها <span class="qpc-hafs">﴿إلاَّ مَنْ سفه نفسه﴾</span> أَيْ: جهلها بأَنْ لم يعلم أنَّها مخلوقةٌ لله تعالى يجب عليها عبادة خالقها <span class="qpc-hafs">﴿ولقد اصطفيناه في الدُّنيا﴾</span> اخترناه للرِّسالة <span class="qpc-hafs">﴿وإنه في الآخرة لمن الصالحين﴾</span> أَيْ: من الأنبياء</p></div>"
  2,131,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿إذ قال له ربه أسلم﴾</span> أخلص دينك لله سبحانه بالتَّوحيد وقيل: أسلم نفسك إلى الله <span class="qpc-hafs">﴿قال أسلمت﴾</span> بقلبي ولساني وجوارحي <span class="qpc-hafs">﴿لرب العالمين﴾</span></p></div>"
  2,132,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ووصَّى بها﴾</span> أَيْ: أمر بالملَّة وقيل: بكلمة الإِخلاص <span class="qpc-hafs">﴿إبراهيم بنيه ويعقوب يا بنيَّ﴾</span> أراد: أَنْ يَا بَنِيَّ <span class="qpc-hafs">﴿إِنَّ اللَّهَ اصْطَفَى لَكُمُ الدِّينَ﴾</span> أَي: الإِسلام دين الحَنيِفيَّة <span class="qpc-hafs">﴿فلا تموتن إلا وأنتم مسلمون﴾</span> أي: الزموا الإِسلام حتى إذا أدرككم الموت صادفكم عليه</p></div>"
  2,133,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أم كنتم شهداء﴾</span> ترك الكلام الأوَّل وعاد إلى مُخاطبة اليهود المعنى: بل أكنتم شهداء أَيْ: حضوراً <span class="qpc-hafs">﴿إذ حضر يعقوب الموت﴾</span> وذلك أنَّ اليهود قالت النبي ﷺ: ألستَ تعلم أنَّ يعقوب يوم مات أوصى بنيه باليهوديَّة؟ فأكذبهم الله تعالى وقال: أكنتم حاضرين وصيته <span class="qpc-hafs">﴿إِذْ قَالَ لِبَنِيهِ مَا تَعْبُدُونَ مِنْ بَعْدِي﴾</span></p></div>"
  2,134,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿تِلْكَ أُمَّةٌ﴾</span> يعني: إبراهيم وبنيه ويعقوب وبنيه <span class="qpc-hafs">﴿قد خلت﴾</span> قد مضت <span class="qpc-hafs">﴿لَهَا مَا كَسَبَتْ﴾</span> من العمل <span class="qpc-hafs">﴿ولكم﴾</span> يا معشر اليهود <span class="qpc-hafs">﴿ما كسبتم﴾</span> أَيْ: حسابهم عليهم وإنَّما تُسألون عن أعمالكم</p></div>"