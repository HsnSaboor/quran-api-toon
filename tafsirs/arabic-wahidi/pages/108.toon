quran[4]{c,v,t}:
  5,6,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يا أيها الذين آمنوا إذا قمتم إلى الصلاة﴾</span> أَيْ: إذا أردتم القيام إليها <span class="qpc-hafs">﴿فاغسلوا وجوهكم وأيديكم إلى المرافق﴾</span> يعني: مع المرفقين <span class="qpc-hafs">﴿وامسحوا برؤوسكم وأرجلكم إلى الكعبين﴾</span> وهما النَّاشزان من جانبي القدم <span class="qpc-hafs">﴿وإن كنتم جنباً فاطَّهَروا﴾</span> فاغتسلوا <span class="qpc-hafs">﴿وإن كنتم مرضى﴾</span> مفسَّرٌ في سورة النساء إلى قوله: <span class="qpc-hafs">﴿مَا يُرِيدُ الله ليجعل عليكم من حرج﴾</span> من ضيقٍ في الدِّين ولكنْ جعله واسعاً بالرُّخصة في التَّيمُّم <span class="qpc-hafs">﴿ولكن يريد ليطهركم﴾</span> من الأحداث والجنابات والذُّنوب لأنَّ الوضوء يكفِّر الذُّنوب <span class="qpc-hafs">﴿وليتم نعمته عليكم﴾</span> ببيان الشَّرائع و <span class="qpc-hafs">﴿لعلكم تشكرون﴾</span> نعمتي فتطيعوا أمري</p></div>"
  5,7,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿واذكروا نعمة الله عليكم﴾</span> بلإسلام <span class="qpc-hafs">﴿وميثاقه الذي واثقكم به﴾</span> يعني: حين بايعوا رسول الله ﷺ على السَّمع والطَّاعة في كلِّ ما أمر ونهى وهو قوله: <span class="qpc-hafs">﴿إذ قلتم﴾</span> حين قُلْتُمْ <span class="qpc-hafs">﴿سَمِعْنَا وَأَطَعْنَا وَاتَّقُوا اللَّهَ إِنَّ اللَّهَ عليم بذات الصدور﴾</span> بخفيَّات القلوب</p></div>"
  5,8,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿يا أيها الذين آمنوا كونوا قوَّامين لله﴾</span> تقومون لله بكلِّ حقٍّ يلزمكم القيام به <span class="qpc-hafs">﴿شُهَدَاءَ بِالْقِسْطِ﴾</span> تشهدون بالعدل <span class="qpc-hafs">﴿وَلا يَجْرِمَنَّكُمْ شَنَآنُ قوم﴾</span> لا يحملنَّكم بغض قوم على ترك العدل <span class="qpc-hafs">﴿اعدلوا﴾</span> في الوليِّ والعدوِّ <span class="qpc-hafs">﴿هو﴾</span> أَيْ: العدل <span class="qpc-hafs">﴿أقرب للتقوى﴾</span> أَيْ: لاتِّقاء النار</p></div>"
  5,9,""