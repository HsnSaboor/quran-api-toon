tafsir[10]{c,v,t}:
11,118," <q>﴿وَلَوْ شَاءَ رَبُّكَ لَجَعَلَ النَّاسَ أُمَّةً وَاحِدَةً﴾</q> مسلمين كلَّهم <q>﴿ولا يزالون مختلفين﴾</q> في الأديان "
11,119," <q>﴿إِلا مَنْ رَحِمَ رَبُّكَ﴾</q> يعني: أهل الحقِّ <q>﴿ولذلك خلقهم﴾</q> أَيْ: خلق أهل الاختلاف للاختلاف وأهل الرَّحمة للرَّحمة "
11,120," <q>﴿وكلاًّ نقصُّ عليك﴾</q> أَيْ: كلَّ الذي تحتاج إليه <q>﴿من أنباء الرسل﴾</q> نقصُّ عليك <q>﴿ما نثبت به فؤادك﴾</q> ليزيدك يقيناً <q>﴿وجاءك في هذه﴾</q> أَيْ: في هذه السُّورة <q>﴿الحق﴾</q> يعني: ما ذُكر من أقاصيص الأنبياء ومواعظهم وذكر السَّعادة والشَّقاوة وهذا تشريفٌ لهذه السُّورة لأنَّ غيرها من السُّور قد جاء فيها الحقُّ <q>﴿وموعظة وذكرى للمؤمنين﴾</q> يتَّعظون إذا سمعوا هذه السُّورة وما نزل بالأمم لمَّا كذَّبوا أنبياءهم "
11,121," <q>﴿وَقُلْ لِلَّذِينَ لا يُؤْمِنُونَ اعْمَلُوا عَلَى مَكَانَتِكُمْ﴾</q> أمر تهديد أَيْ: اعملوا ما أنتم عاملون "
11,122," <q>﴿وَانْتَظِرُوا﴾</q> ما يعدكم الشَّيطان <q>﴿إِنَّا مُنْتَظِرُونَ﴾</q> ما يعدنا ربُّنا من النَّصر "
11,123," <q>﴿ولله غيب السماوات وَالأَرْضِ﴾</q> أَيْ: علم ما غاب عن العباد فيهما <q>﴿وَإِلَيْهِ يُرْجَعُ الأَمْرُ كُلُّهُ﴾</q> في المعاد حتى لا يكون لأحدٍ سواه أمرٌ <q>﴿وَمَا رَبُّكَ بِغَافِلٍ عَمَّا تَعْمَلُونَ﴾</q> أَيْ: إنَّه يجزي المحسن بإحسانه والمسيء بإساءَته "
12,1," <q>﴿الر﴾</q> أنا الله الرَّحمن <q>﴿تلك﴾</q> هذه <q>﴿آيات الكتاب المبين﴾</q> للحلال والحرام والأحكام يعني: القرآن "
12,2," <q>﴿إنا أنزلناه﴾</q> يعني: الكتاب <q>﴿قرآنا عربيا﴾</q> بلغة العرب <q>﴿لعلكم تعقلون﴾</q> كي تفهموا "
12,3," <q>﴿نحن نقصُّ عليك أحسن القصص﴾</q> نبيِّن لك أحسن البيان <q>﴿بما أوحينا﴾</q> بإيماننا <q>﴿إليك هذا القرآن وإن كنت من قبله لمن الغافلين﴾</q> وما كنتَ من قبل أن يُوحى إليك إلاَّ من الغافلين "
12,4," <q>﴿إذ قال﴾</q> اذكر إِذْ قَالَ <q>﴿يُوسُفُ لأَبِيهِ يَا أَبَتِ إِنِّي رَأَيْتُ أَحَدَ عَشَرَ كَوْكَبًا وَالشَّمْسَ وَالْقَمَرَ رَأَيْتُهُمْ﴾</q> الآية رأى يوسف عليه السَّلام هذه الرُّؤيا فلمَّا قصَّها على أبيه أشفق عليه من حسد إخوته له فقال: "
