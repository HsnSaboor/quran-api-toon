quran[10]{c,v,t}:
  11,118,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَلَوْ شَاءَ رَبُّكَ لَجَعَلَ النَّاسَ أُمَّةً وَاحِدَةً﴾</span> مسلمين كلَّهم <span class="qpc-hafs">﴿ولا يزالون مختلفين﴾</span> في الأديان</p></div>"
  11,119,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿إِلا مَنْ رَحِمَ رَبُّكَ﴾</span> يعني: أهل الحقِّ <span class="qpc-hafs">﴿ولذلك خلقهم﴾</span> أَيْ: خلق أهل الاختلاف للاختلاف وأهل الرَّحمة للرَّحمة</p></div>"
  11,120,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وكلاًّ نقصُّ عليك﴾</span> أَيْ: كلَّ الذي تحتاج إليه <span class="qpc-hafs">﴿من أنباء الرسل﴾</span> نقصُّ عليك <span class="qpc-hafs">﴿ما نثبت به فؤادك﴾</span> ليزيدك يقيناً <span class="qpc-hafs">﴿وجاءك في هذه﴾</span> أَيْ: في هذه السُّورة <span class="qpc-hafs">﴿الحق﴾</span> يعني: ما ذُكر من أقاصيص الأنبياء ومواعظهم وذكر السَّعادة والشَّقاوة وهذا تشريفٌ لهذه السُّورة لأنَّ غيرها من السُّور قد جاء فيها الحقُّ <span class="qpc-hafs">﴿وموعظة وذكرى للمؤمنين﴾</span> يتَّعظون إذا سمعوا هذه السُّورة وما نزل بالأمم لمَّا كذَّبوا أنبياءهم</p></div>"
  11,121,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَقُلْ لِلَّذِينَ لا يُؤْمِنُونَ اعْمَلُوا عَلَى مَكَانَتِكُمْ﴾</span> أمر تهديد أَيْ: اعملوا ما أنتم عاملون</p></div>"
  11,122,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَانْتَظِرُوا﴾</span> ما يعدكم الشَّيطان <span class="qpc-hafs">﴿إِنَّا مُنْتَظِرُونَ﴾</span> ما يعدنا ربُّنا من النَّصر</p></div>"
  11,123,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ولله غيب السماوات وَالأَرْضِ﴾</span> أَيْ: علم ما غاب عن العباد فيهما <span class="qpc-hafs">﴿وَإِلَيْهِ يُرْجَعُ الأَمْرُ كُلُّهُ﴾</span> في المعاد حتى لا يكون لأحدٍ سواه أمرٌ <span class="qpc-hafs">﴿وَمَا رَبُّكَ بِغَافِلٍ عَمَّا تَعْمَلُونَ﴾</span> أَيْ: إنَّه يجزي المحسن بإحسانه والمسيء بإساءَته</p></div>"
  12,1,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿الر﴾</span> أنا الله الرَّحمن <span class="qpc-hafs">﴿تلك﴾</span> هذه <span class="qpc-hafs">﴿آيات الكتاب المبين﴾</span> للحلال والحرام والأحكام يعني: القرآن</p></div>"
  12,2,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿إنا أنزلناه﴾</span> يعني: الكتاب <span class="qpc-hafs">﴿قرآنا عربيا﴾</span> بلغة العرب <span class="qpc-hafs">﴿لعلكم تعقلون﴾</span> كي تفهموا</p></div>"
  12,3,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿نحن نقصُّ عليك أحسن القصص﴾</span> نبيِّن لك أحسن البيان <span class="qpc-hafs">﴿بما أوحينا﴾</span> بإيماننا <span class="qpc-hafs">﴿إليك هذا القرآن وإن كنت من قبله لمن الغافلين﴾</span> وما كنتَ من قبل أن يُوحى إليك إلاَّ من الغافلين</p></div>"
  12,4,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿إذ قال﴾</span> اذكر إِذْ قَالَ <span class="qpc-hafs">﴿يُوسُفُ لأَبِيهِ يَا أَبَتِ إِنِّي رَأَيْتُ أَحَدَ عَشَرَ كَوْكَبًا وَالشَّمْسَ وَالْقَمَرَ رَأَيْتُهُمْ﴾</span> الآية رأى يوسف عليه السَّلام هذه الرُّؤيا فلمَّا قصَّها على أبيه أشفق عليه من حسد إخوته له فقال:</p></div>"