quran[7]{c,v,t}:
  9,55,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فلا تعجبك أموالهم ولا أولادهم﴾</span> لا تستحسن ما أنعمنا عليهم من الأموال الكثيرة والأولاد <span class="qpc-hafs">﴿إِنَّمَا يُرِيدُ اللَّهُ لِيُعَذِّبَهُمْ بِهَا فِي الْحَيَاةِ الدنيا﴾</span> يعني: بالمصائب فيها فهي لهم عذابٌ وللمؤمن أجر <span class="qpc-hafs">﴿وتزهق أنفسهم﴾</span> وتخرج أرواحهم <span class="qpc-hafs">﴿وهم﴾</span> على الكفر</p></div>"
  9,56,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ويحلفون بالله إنهم لمنكم﴾</span> أَيْ: إنَّهم مؤمنون وليسوا مؤمنين <span class="qpc-hafs">﴿ولكنهم قوم يفرقون﴾</span> يخافون فيحلفون تقيَّةً لكم</p></div>"
  9,57,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لو يجدون ملجأً﴾</span> مهرباً <span class="qpc-hafs">﴿أو مغارات﴾</span> سراديب <span class="qpc-hafs">﴿أو مدخلاً﴾</span> وجهاً يدخلونه <span class="qpc-hafs">﴿لوَلَّوا إليه﴾</span> لرجعوا إليه <span class="qpc-hafs">﴿وهم يجمحون﴾</span> يُسرعون إسراعاً لا يردُّ وجوهَهم شيءٌ أَيْ: لو أمكنهم الفرار من بين المسلمين بأيِّ وجهٍ كان لفروا لوم يُقيموا بينهم</p></div>"
  9,58,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ومنهم﴾</span> ومن المنافقون <span class="qpc-hafs">﴿من يلمزك﴾</span> يعيبك وطعن عليك <span class="qpc-hafs">﴿في﴾</span> أمر <span class="qpc-hafs">﴿الصدقات﴾</span> يقول: إنَّما يعطيها محمَّد مَنْ أحبَّ فإنْ أكثرت لهم من ذلك فرحوا وإنْ أعطيتهم قليلاً سخطوا ثمَّ ذكر في الآية الثَّانية أنَّهم لو رضوا بذلك وتوكَّلوا على الله لكان خيراً لهم وهو قوله:</p></div>"
  9,59,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَلَوْ أَنَّهُمْ رَضُوا مَا آتَاهُمُ اللَّهُ وَرَسُولُهُ وَقَالُوا حَسْبُنَا اللَّهُ سَيُؤْتِينَا اللَّهُ مِنْ فَضْلِهِ ورسوله إنا إلى الله راغبون﴾</span> ثمَّ بيَّن لمن الصَّدقات فقال:</p></div>"
  9,60,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿إنما الصدقات للفقراء﴾</span> وهم المُتعفِّفون عن السُّؤال <span class="qpc-hafs">﴿والمساكين﴾</span> الذين يسألون ويطوفون على النَّاس <span class="qpc-hafs">﴿والعاملين عليها﴾</span> السُّعاة لجباية الصَّدَقة <span class="qpc-hafs">﴿والمؤلفة قلوبهم﴾</span> كانوا قوماً من أشراف العرب استألفهم رسول الله ﷺ ليردُّوا عنه قومهم ويُعينوه على عدوِّه <span class="qpc-hafs">﴿وفي الرقاب﴾</span> المكاتبين <span class="qpc-hafs">﴿والغارمين﴾</span> أهل الدِّيْن <span class="qpc-hafs">﴿وفي سبيل الله﴾</span> الغزاة والمرابطون <span class="qpc-hafs">﴿وابن السبيل﴾</span> المنقطع في سفره <span class="qpc-hafs">﴿فريضة من الله﴾</span> افترضها الله على الأغنياء في أموالهم</p></div>"
  9,61,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ومنهم الذين يؤذون النبيَّ﴾</span> بنقل حديثه وعيبه <span class="qpc-hafs">﴿ويقولون هو أذنٌ﴾</span> أنَّهم قالوا فيما بينهم: نقول ما شئنا ثمَّ نأتيه فَنَحْلِفُ له فيصدِّقنا لأنَّه أُذنٌ والأُذن: الذي يسمع كلَّ ما يُقال له فقال الله تعالى <span class="qpc-hafs">﴿قُلْ أُذُنُ خَيْرٍ لَكُمْ﴾</span> أَيْ: مستمعُ خيرٍ وصلاح لا مستمع شرٍّ وفسادٍ ثمَّ أَكَّد هذا وبيَّنه فقال: <span class="qpc-hafs">﴿يؤمن بالله﴾</span> أَيْ: يسمع ما ينزله الله عليه فيصدِّق به <span class="qpc-hafs">﴿ويؤمن للمؤمنين﴾</span> ويصدِّق المؤمنين فيما يخبرونه لا الكافرين <span class="qpc-hafs">﴿وَرَحْمَةٌ لِلَّذِينَ آمَنُوا مِنْكُمْ﴾</span> أَيْ: وهو رحمةٌ لأنَّه كان سبب إيمانهم</p></div>"