quran[9]{c,v,t}:
  10,62,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ألا إنَّ أولياء الله﴾</span> هم الذين تولَّى الله سبحانه هداهم</p></div>"
  10,63,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿الذين آمنوا﴾</span> صدَّقوا النبيَّ <span class="qpc-hafs">﴿وكانوا يتقون﴾</span> خافوا مقامهم بين يدي الله سبحانه</p></div>"
  10,64,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿لهم البشرى في الحياة الدنيا﴾</span> عند الموت تأتيهم الملائكة بالبشرى من الله <span class="qpc-hafs">﴿وفي الآخرة﴾</span> يُبشَّرون بثواب الله وجنَّته <span class="qpc-hafs">﴿لا تبديل لكلمات الله﴾</span> لا خلف لمواعيده</p></div>"
  10,65,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ولا يحزنك قولهم﴾</span> تكذيبهم إيَّاك <span class="qpc-hafs">﴿إنَّ العزة لله﴾</span> القوَّة لله والقدرة لله <span class="qpc-hafs">﴿جميعاً﴾</span> وهو ناصرك <span class="qpc-hafs">﴿وهو السميع﴾</span> يسمع قولهم <span class="qpc-hafs">﴿العليم﴾</span> بما في ضميركم فيجازيهم بما يقتضيه حالهم</p></div>"
  10,66,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ألاَّ إن لله مَنْ في السماوات ومَنْ في الأرض﴾</span> يعني: يفعل بهم وفيهم ما يشاء <span class="qpc-hafs">﴿وَمَا يَتَّبِعُ الَّذِينَ يَدْعُونَ مِنْ دُونِ اللَّهِ شُرَكَاءَ﴾</span> أيْ: ليسوا يتَّبعون شركاء على الحقيقة لأنَّهم يعدُّونها شركاء شفعاء لهم وليست على ما يظنُّون <span class="qpc-hafs">﴿إِنْ يتبعون إلا الظن﴾</span> ما يتَّبعون إلاَّ ظنَّهم أنَّها تشفع لهم <span class="qpc-hafs">﴿وإن هم إلا يخرصون﴾</span> يقولون ما لا يكون</p></div>"
  10,67,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿هُوَ الَّذِي جَعَلَ لَكُمُ اللَّيْلَ لِتَسْكُنُوا فِيهِ والنهار مُبْصِرًا﴾</span> مُضيئاً لتهتدوا به في حوائجكم <span class="qpc-hafs">﴿إِنَّ في ذلك لآيات لقومٍ يسمعون﴾</span> سَمعَ اعتبار</p></div>"
  10,68,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿قالوا اتخذ الله ولدا﴾</span> يعني: قولهم: الملائكة بنات الله <span class="qpc-hafs">﴿سبحانه﴾</span> تنزيهاً له عمل قالوه <span class="qpc-hafs">﴿هو الغنيُّ﴾</span> أن يكون له زوجةٌ أو ولدٌ <span class="qpc-hafs">﴿إِنْ عِنْدَكُمْ مِنْ سُلْطَانٍ بِهَذَا﴾</span> ما عندكم من حجة بهذا</p></div>"
  10,69,"<div class=ar lang=ar></div>"
  10,70,"<div class=ar lang=ar><p>وقوله: <span class="qpc-hafs">﴿متاع في الدنيا﴾</span> أيْ: لهم متاعٌ في الدُّنيا يتمتَّعون به أيَّاماً يسيراً</p></div>"