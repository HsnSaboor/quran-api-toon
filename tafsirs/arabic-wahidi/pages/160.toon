quran[8]{c,v,t}:
  7,74,"<div class=ar lang=ar><p>وقوله: <span class="qpc-hafs">﴿وبوَّأكم في الأرض﴾</span> أَيْ: أسكنكم وجعل لكم فيها مساكن <span class="qpc-hafs">﴿تتخذون من سهولها قصوراً﴾</span> تبنون القصور بكلِّ موضعٍ <span class="qpc-hafs">﴿وَتَنْحِتُونَ الْجِبَالَ بُيُوتًا﴾</span> يريد: بيوتاً في الجبال تُشققونها وكانوا يسكنونها شتاءً ويسكنون القصور بالصَّيف</p></div>"
  7,75,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿قال الملأ﴾</span> وهم الأشراف <span class="qpc-hafs">﴿الَّذِينَ اسْتَكْبَرُوا مِنْ قَوْمِهِ﴾</span> عن عبادة الله <span class="qpc-hafs">﴿للذين استضعفوا﴾</span> يريد المساكين <span class="qpc-hafs">﴿لِمَنْ آمَنَ مِنْهُمْ﴾</span> بدلٌ من قوله: <span class="qpc-hafs">﴿للذين استضعفوا﴾</span> لأنَّهم المؤمنون</p></div>"
  7,76,""
  7,77,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فعقروا الناقة﴾</span> نحروها <span class="qpc-hafs">﴿وعتوا عن أمر ربهم﴾</span> عصوا الله وتركوا أمره في النَّاقة <span class="qpc-hafs">﴿وقالوا يَا صَالِحُ ائْتِنَا بِمَا تَعِدُنَا﴾</span> من العذاب</p></div>"
  7,78,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فأخذتهم الرجفة﴾</span> وهي الزَّلزلة الشَّديدة <span class="qpc-hafs">﴿فأصبحوا في دارهم﴾</span> بلدهم <span class="qpc-hafs">﴿جاثمين﴾</span> خامدين مَيِّتين</p></div>"
  7,79,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فتولى عنهم﴾</span> أعرض عنهم صالحٌ بعد نزول العذاب بهم <span class="qpc-hafs">﴿وَقَالَ يَا قَوْمِ لَقَدْ أَبْلَغْتُكُمْ رِسَالَةَ رَبِّي ونصحت لكم﴾</span> خوَّفتكم عقاب الله وهذا كما خاطب رسول الله ﷺ قتلى بدر</p></div>"
  7,80,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ولوطاً﴾</span> وأرسلنا لوطاً أَيْ: واذكر لوطاً <span class="qpc-hafs">﴿إِذْ قَالَ لِقَوْمِهِ أَتَأْتُونَ الْفَاحِشَةَ﴾</span> يعني: إتيان الذُّكور <span class="qpc-hafs">﴿مَا سَبَقَكُمْ بِهَا مِنْ أَحَدٍ مِنَ الْعَالَمِينَ﴾</span> قالوا: ما نزا ذَكَرٌ على ذَكَرٍ حتى كان قوم لوطٍ</p></div>"
  7,81,""