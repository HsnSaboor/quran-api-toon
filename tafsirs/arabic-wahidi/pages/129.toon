quran[10]{c,v,t}:
  6,9,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ولو جعلناه ملكاً﴾</span> أيْ: ولو جعلنا الرَّسول الذي ينزل عليهم ليشهدوا له بالرِّسالة مَلَكاً كما يطلبون <span class="qpc-hafs">﴿لجعلناه رجلاً﴾</span> لأنَّهم لا يستطيعون أن يروا المَلَك في صورته لأنَّ أعين الخلق تحار عن رؤية الملائكة ولذلك كان جبريل عليه السَّلام يأتي رسول الله ﷺ في صورة دحية الكلبيِّ <span class="qpc-hafs">﴿وللبسنا عليهم ما يلبسون﴾</span> ولخلطنا عليهم ما يخلطون على أنفسهم حتى يشكُّوا فلا يدروا أمَلَكٌ هو أم آدميٌّ أَيْ: فإنَّما طلبوا حال لبسٍ لا حال بيانٍ ثمَّ عزَّى الله نبيَّه عليه السَّلام بقوله:</p></div>"
  6,10,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ولقد استهزئ برسل من قبلك﴾</span> وكُذِّبوا ونُسبوا إلى السّحر <span class="qpc-hafs">﴿فحاق﴾</span> فحلَّ ونزل <span class="qpc-hafs">﴿بالذين سخروا﴾</span> من الرُّسل <span class="qpc-hafs">﴿ما كانوا به يستهزئون﴾</span> من العذاب وينكرون وقوعه</p></div>"
  6,11,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿قل﴾</span> لهم يا محمد: <span class="qpc-hafs">﴿سيروا في الأرض﴾</span> سافروا في الأرض <span class="qpc-hafs">﴿ثم انظروا﴾</span> فاعتبروا <span class="qpc-hafs">﴿كيف كان عاقبة﴾</span> مُكذِّبي الرُّسل يعني: إذا سافروا رأوا آثار الأمم الخالية المهلكة يحذِّرهم مثلَ ما وقع بهم</p></div>"
  6,12,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿قل لمن ما في السماوات والأرض﴾</span> فإن أجابوك وإلاَّ <span class="qpc-hafs">﴿قل لله كتب على نفسه الرحمة﴾</span> أوجب على نفسه الرَّحمة وهذا تلطُّفٌ في الاستدعاء إلى الإنابة <span class="qpc-hafs">﴿ليجمعنكم﴾</span> أي: والله ليجمعنكم <span class="qpc-hafs">﴿إلى يوم القيامة﴾</span> أَيْ: ليضمنَّكم إلى هذا اليوم الذي أنكرتموه وليجمعنَّ بينكم وبينه ثمَّ ابتدأ فقال: <span class="qpc-hafs">﴿الذين خسروا أنفسهم﴾</span> أهلكوها بالشِّرك <span class="qpc-hafs">﴿فَهُمْ لا يُؤْمِنُونَ﴾</span></p></div>"
  6,13,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وله ما سكن في الليل والنهار﴾</span> أَيْ: ما حلَّ فيهما واشتملا عليه يعني: جميع المخلوقات</p></div>"
  6,14,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿قل أغير الله أتخذ وليا فاطر السماوات والأرض﴾</span> خالقهما ابتداءً <span class="qpc-hafs">﴿وهو يطعم ولا يطعم﴾</span> يَرزق ولا يرزق</p></div>"
  6,15,"<div class=ar lang=ar></div>"
  6,16,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿من يصرف عنه﴾</span> أَي: العذاب <span class="qpc-hafs">﴿يومئذ﴾</span> يوم القيامة <span class="qpc-hafs">﴿فقد رحمه﴾</span> فقد أوجب الله له الرَّحمة لا محالة</p></div>"
  6,17,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وإن يمسسك الله بضر﴾</span> أيْ: إنْ جعل الضُّرَّ وهو المرض والفقر يمسُّك</p></div>"
  6,18,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وهو القاهر﴾</span> القادر الذي لا يعجزه شيء <span class="qpc-hafs">﴿فوق عباده﴾</span> أَيْ: إنَّ قهره قد استعلى عليهم فهم تحت التَّسخير</p></div>"