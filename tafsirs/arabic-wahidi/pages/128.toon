quran[8]{c,v,t}:
  6,1,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿الحمد لله الذي خلق السماوات والأرض وجعل الظلمات والنور﴾</span> وخلق اللَّيل والنَّهار <span class="qpc-hafs">﴿ثمًّ الذين كفروا﴾</span> بعد قيام الدَّليل على وحدانيَّته بما ذكر من خلقه <span class="qpc-hafs">﴿بربهم يعدلون﴾</span> الحجارةَ والأصنام فيعبدونها معه 0</p></div>"
  6,2,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿هو الذي خلقكم من طين﴾</span> يعني: آدم أبا البشر <span class="qpc-hafs">﴿ثُمَّ قَضَى أَجَلا﴾</span> يعني: أجل الحياة إلى الموت <span class="qpc-hafs">﴿وأجل مسمى عنده﴾</span> من الممات إلى البعث <span class="qpc-hafs">﴿ثم أنتم﴾</span> أيُّها المشركون بعد هذا <span class="qpc-hafs">﴿تمترون﴾</span> تشكُّون وتكذِّبون بالبعث يريد إنَّ الذي ابتدأ الخلق قادرٌ على إعادته</p></div>"
  6,3,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وهو الله﴾</span> أَي: المعبود المعظَّم المتفرِّد بالتَّدبير <span class="qpc-hafs">﴿في السماوات وفي الأرض﴾</span></p></div>"
  6,4,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَمَا تَأْتِيهِمْ مِنْ آيَةٍ مِنْ آيَاتِ رَبِّهِمْ﴾</span> الدَّالَّة على وحدانيَّته كما ذكر من خلق آدم وخلق اللَّيل والنَّهار <span class="qpc-hafs">﴿إلاَّ كانوا عنها معرضين﴾</span> تاركين التًّفكُّر فيها</p></div>"
  6,5,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فقد كذبوا﴾</span> يعني: مشركي أهل مكة <span class="qpc-hafs">﴿بالحق لما جاءهم﴾</span> يعني: القرآن <span class="qpc-hafs">﴿فَسَوْفَ يَأْتِيهِمْ أَنْبَاءُ مَا كَانُوا بِهِ يَسْتَهْزِئُونَ﴾</span> أَيْ: أخبار استهزائهم وجزاؤه</p></div>"
  6,6,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ألم يروا﴾</span> يعني: هؤلاء الكفَّار <span class="qpc-hafs">﴿كم أهلكنا من قبلهم من قرن﴾</span> من جيلٍ وأمَّةٍ <span class="qpc-hafs">﴿مَكَّنَّاهُمْ فِي الأَرْضِ مَا لَمْ نُمَكِّنْ لَكُمْ﴾</span> أعطيناهم من المال والعبيد والأنعام ما لم نُعطكم <span class="qpc-hafs">﴿وأرسلنا السماء﴾</span> المطر <span class="qpc-hafs">﴿عليهم مدراراً﴾</span> كثير الدَّرِّ وهو إقباله ونزوله بكثرة <span class="qpc-hafs">﴿فأهلكناهم بذنوبهم﴾</span> بكفرهم <span class="qpc-hafs">﴿وأنشأنا﴾</span> أوجدنا <span class="qpc-hafs">﴿من بعدهم قرناً آخرين﴾</span> وهذا احتجاجٌ على منكري البعث</p></div>"
  6,7,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ولو نزلنا عليك﴾</span> قال مشركو مكَّة: لن نؤمن لك حتى تأتينا بكتاب من السَّماء جملةً واحدة معاينة فقال الله: <span class="qpc-hafs">﴿ولو نزلنا عليك كتاباً﴾</span> أَيْ: مكتوباً <span class="qpc-hafs">﴿في قرطاس﴾</span> يعني: الصَّحيفة <span class="qpc-hafs">﴿فلمسوه بأيديهم﴾</span> فعاينوا ذلك مُعاينةً ومسُّوه بأيديهم <span class="qpc-hafs">﴿لَقَالَ الَّذِينَ كَفَرُوا إِنْ هَذَا إِلا سِحْرٌ مُبِينٌ﴾</span> أخبر الله تعالى أنَّهم يدفعون الدَّليل حتى لو رأوا الكتاب ينزل من السَّماء لقالوا: سحر</p></div>"
  6,8,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وقالوا: لولا أنزل عليه ملك﴾</span> طلبوا ملكاً يرونه يشهد له بالرِّسالة فقال الله عز وجل: <span class="qpc-hafs">﴿وَلَوْ أَنْزَلْنَا مَلَكًا لَقُضِيَ الأَمْرُ﴾</span> لأُهلكوا بعذاب الاستئصال كسُنَّة مَنْ قبلهم ممَّن طلبوا الآيات فلم يؤمنوا <span class="qpc-hafs">﴿ثم لا ينظرون﴾</span> لا يُمهلون لتوبةٍ ولا لغير ذلك</p></div>"