tafsir[22]{c,v,t}:
  38,62,"﴿وقالُوا﴾ أيْ كُفّار مَكَّة وهُمْ فِي النّار ﴿ما لَنا لا نَرى رِجالًا كُنّا نَعُدّهُمْ﴾ فِي الدُّنْيا"
  38,63,"﴿أتَّخَذْناهُمْ سُخْرِيًّا﴾ بِضَمِّ السِّين وكَسْرها: كُنّا نَسْخَر بِهِمْ فِي الدُّنْيا والياء لِلنَّسَبِ: أيْ أمَفْقُودُونَ هُمْ ﴿أمْ زاغَتْ﴾ مالَتْ ﴿عَنْهُمُ الأَبْصار﴾ فَلَمْ تَرَهُمْ وهُمْ فُقَراء المُسْلِمِينَ كَعَمّارٍ وبِلال وصُهَيْب وسَلْمان"
  38,64,"﴿إنّ ذَلِكَ لَحَقّ﴾ واجِب وُقُوعه وهُوَ تَخاصُم أهْل النّار ﴿تَخاصُم أهْل النّار﴾ كَما تَقَدَّمَ"
  38,65,"﴿قُلْ﴾ يا مُحَمَّد لِكُفّارِ مَكَّة ﴿إنّما أنا مُنْذِر﴾ مُخَوِّف بِالنّارِ ﴿وما مِن إلَه إلّا اللَّه الواحِد القَهّار﴾ لِخَلْقِهِ"
  38,66,"﴿رَبّ السَّمَوات والأَرْض وما بَيْنهما العَزِيز﴾ الغالِب عَلى أمْره ﴿الغَفّار﴾ لِأَوْلِيائِهِ"
  38,67,"﴿قُلْ﴾ لَهُمْ"
  38,68,"﴿أنْتُمْ عَنْهُ مُعْرِضُونَ﴾ أيْ مُعْرِضُونَ عَنْ القُرْآن الَّذِي أنْبَأْتُكُمْ بِهِ وجِئْتُكُمْ فِيهِ بِما لا يُعْلَم إلّا بِوَحْيٍ"
  38,69,"﴿ما كانَ لِي مِن عِلْم بِالمَلَإ الأَعْلى﴾ أيْ المَلائِكَة ﴿إذْ يَخْتَصِمُونَ﴾ فِي شَأْن آدَم حِين قالَ تَعالى: ﴿إنِّي جاعِل فِي الأَرْض خَلِيفَة﴾ إلَخْ"
  38,70,"﴿إنْ﴾ ما ﴿يُوحى إلَيَّ إلّا أنَّما أنا﴾ أيْ أنِّي ﴿نَذِير مُبِين﴾ بَيِّن الإنْذار"
  38,71,"﴿إذْ قالَ رَبّك لِلْمَلائِكَةِ إنِّي خالِق بَشَرًا مِن طِين﴾ هُوَ آدَم"
  38,72,"﴿فَإذا سَوَّيْته﴾ أتْمَمْته ﴿ونَفَخْت﴾ أجْرَيْت ﴿فِيهِ مِن رُوحِي﴾ فَصارَ حَيًّا وإضافَة الرُّوح إلَيْهِ تَشْرِيف لِآدَم والرُّوح جِسْم لَطِيف يَحْيا بِهِ الإنْسان بِنُفُوذِهِ فِيهِ ﴿فَقَعُوا لَهُ ساجِدِينَ﴾ سُجُود تَحِيَّة بِالِانْحِناءِ"
  38,73,"﴿فَسَجَدَ المَلائِكَة كُلّهمْ أجْمَعُونَ﴾ فِيهِ تَأْكِيدانِ"
  38,74,"﴿إلّا إبْلِيس﴾ هُوَ أبُو الجِنّ كانَ بَيْن المَلائِكَة ﴿اسْتَكْبَرَ وكانَ مِن الكافِرِينَ﴾ فِي عِلْم اللَّه تَعالى"
  38,75,"﴿قالَ يا إبْلِيس ما مَنَعَك أنْ تَسْجُد لِما خَلَقْت بِيَدَيّ﴾ أيْ تَوَلَّيْت خَلْقه وهَذا تَشْرِيف لِآدَم فَإنَّ كُلّ مَخْلُوق تَوَلّى اللَّه خَلْقه ﴿أسْتَكْبَرْت﴾ الآن عَنْ السُّجُود اسْتِفْهام لِلتَّوْبِيخِ ﴿أمْ كُنْت مِنَ العالِينَ﴾ المُتَكَبِّرِينَ فَتَكَبَّرْت عَنْ السُّجُود لِكَوْنِك مِنهُمْ"
  38,76,""
  38,77,"﴿قالَ فاخْرُجْ مِنها﴾ أيْ مِن الجَنَّة وقِيلَ مِن السَّماوات ﴿فَإنَّك رَجِيم﴾ مَطْرُود"
  38,78,"﴿وإنَّ عَلَيْك لَعْنَتِي إلى يَوْم الدِّين﴾ الجَزاء"
  38,79,"﴿قالَ رَبِّي فَأَنْظِرْنِي إلى يَوْم يُبْعَثُونَ﴾ أيْ إلى يَوْم يُبْعَث النّاس"
  38,80,""
  38,81,"﴿إلى يَوْم الوَقْت المَعْلُوم﴾ وقْت النَّفْخَة الأُولى"
  38,82,""
  38,83,"﴿إلّا عِبادك مِنهُمْ المُخْلَصِينَ﴾ أيْ المُؤْمِنِينَ"