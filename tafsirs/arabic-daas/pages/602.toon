quran[14]{c,v,t}:
  106,1,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿لِإِيلافِ﴾</span></span> الجار والمجرور متعلقان بالفعل المتأخر ليعبدوا <span class="hlt"><span class="qpc-hafs">﴿قُرَيْشٍ﴾</span></span> مضاف إليه.</p></div>"
  106,2,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إِيلافِهِمْ﴾</span></span> بدل مما قبله <span class="hlt"><span class="qpc-hafs">﴿رِحْلَةَ﴾</span></span> مفعول به للمصدر <span class="hlt"><span class="qpc-hafs">﴿الشِّتاءِ﴾</span></span> مضاف إليه <span class="hlt"><span class="qpc-hafs">﴿وَالصَّيْفِ﴾</span></span> معطوف على الشتاء.</p></div>"
  106,3,"<div class=ar lang=ar><p>َلْيَعْبُدُوا»</p><p>الفاء الفصيحة ومضارع مجزوم باللام والواو فاعلهَ بَّ هذَا»</p><p>مفعول به مضاف إلى اسم الإشارةلْبَيْتِ»</p><p>بدل من اسم الإشارة والجملة جواب شرط مقدر لا محل لها.</p></div>"
  106,4,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿الَّذِي﴾</span></span> اسم موصول بدل من رب <span class="hlt"><span class="qpc-hafs">﴿أَطْعَمَهُمْ﴾</span></span> ماض ومفعوله والفاعل مستتر والجملة صلة <span class="hlt"><span class="qpc-hafs">﴿مِنْ جُوعٍ﴾</span></span> متعلقان بالفعل <span class="hlt"><span class="qpc-hafs">﴿وَآمَنَهُمْ مِنْ خَوْفٍ﴾</span></span> معطوف على ما قبله.</p></div>"
  107,1,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿أَرَأَيْتَ﴾</span></span> الهمزة حرف استفهام وماض وفاعله <span class="hlt"><span class="qpc-hafs">﴿الَّذِي﴾</span></span> مفعول به والجملة ابتدائية لا محل لها <span class="hlt"><span class="qpc-hafs">﴿يُكَذِّبُ﴾</span></span> مضارع فاعله مستتر <span class="hlt"><span class="qpc-hafs">﴿بِالدِّينِ﴾</span></span> متعلقان بالفعل والجملة صلة.</p></div>"
  107,2,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فَذلِكَ﴾</span></span> الفاء الفصيحة واسم الإشارة مبتدأ <span class="hlt"><span class="qpc-hafs">﴿الَّذِي﴾</span></span> خبره والجملة جواب شرط مقدر لا محل لها.</p><p><span class="hlt"><span class="qpc-hafs">﴿يَدُعُّ﴾</span></span> مضارع فاعله مستتر <span class="hlt"><span class="qpc-hafs">﴿الْيَتِيمَ﴾</span></span> مفعول به والجملة صلة.</p></div>"
  107,3,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وَلا﴾</span></span> الواو حرف عطف <span class="hlt"><span class="qpc-hafs">﴿لا﴾</span></span> نافية <span class="hlt"><span class="qpc-hafs">﴿يَحُضُّ﴾</span></span> مضارع فاعله مستتر <span class="hlt"><span class="qpc-hafs">﴿عَلى طَعامِ﴾</span></span> متعلقان بالفعل <span class="hlt"><span class="qpc-hafs">﴿الْمِسْكِينِ﴾</span></span> مضاف إليه. والجملة معطوفة على ما قبلها.</p></div>"
  107,4,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فَوَيْلٌ﴾</span></span> الفاء للسببية <span class="hlt"><span class="qpc-hafs">﴿ويل﴾</span></span> مبتدأ <span class="hlt"><span class="qpc-hafs">﴿لِلْمُصَلِّينَ﴾</span></span> خبر المبتدأ.</p></div>"
  107,5,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿الَّذِينَ﴾</span></span> صفة المصلين <span class="hlt"><span class="qpc-hafs">﴿هُمْ﴾</span></span> مبتدأ <span class="hlt"><span class="qpc-hafs">﴿عَنْ صَلاتِهِمْ﴾</span></span> متعلقان بالخبر <span class="hlt"><span class="qpc-hafs">﴿ساهُونَ﴾</span></span> خبر والجملة صلة.</p></div>"
  107,6,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿الَّذِينَ﴾</span></span> بدل من الذين السابقة <span class="hlt"><span class="qpc-hafs">﴿هُمْ﴾</span></span> مبتدأ <span class="hlt"><span class="qpc-hafs">﴿يُراؤُنَ﴾</span></span> مضارع مرفوع والواو فاعله والجملة الفعلية خبر المبتدأ والجملة الاسمية صلة.</p></div>"
  107,7,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وَيَمْنَعُونَ﴾</span></span> مضارع وفاعله والمفعول الأول محذوف تقديره الناس <span class="hlt"><span class="qpc-hafs">﴿الْماعُونَ﴾</span></span> مفعول به ثان والجملة معطوفة على ما قبلها.</p></div>"
  108,1,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إِنَّا﴾</span></span> إن واسمها <span class="hlt"><span class="qpc-hafs">﴿أَعْطَيْناكَ﴾</span></span> ماض وفاعله ومفعوله الأول <span class="hlt"><span class="qpc-hafs">﴿الْكَوْثَرَ﴾</span></span> مفعول به ثان والجملة الفعلية خبر إن والجملة الاسمية ابتدائية لا محل لها.</p></div>"
  108,2,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فَصَلِّ﴾</span></span> الفاء حرف عطف وأمر مبني على حذف حرف العلة والفاعل مستتر <span class="hlt"><span class="qpc-hafs">﴿لِرَبِّكَ﴾</span></span> متعلقان بالفعل والجملة معطوفة على ما قبلها <span class="hlt"><span class="qpc-hafs">﴿وَانْحَرْ﴾</span></span> معطوف على ما قبله.</p></div>"
  108,3,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إِنَّ شانِئَكَ﴾</span></span> إن واسمها <span class="hlt"><span class="qpc-hafs">﴿هُوَ﴾</span></span> ضمير فصل <span class="hlt"><span class="qpc-hafs">﴿الْأَبْتَرُ﴾</span></span> خبر إن والجملة الاسمية مستأنفة لا محل لها.</p></div>"