tafsir[30]{c,v,t}:
  87,16,"

<q>﴿بَلْ﴾</q> حرف عطف <q>﴿تُؤْثِرُونَ﴾</q> مضارع مرفوع والواو فاعله <q>﴿الْحَياةَ﴾</q> مفعول به <q>﴿الدُّنْيا﴾</q> صفة.

"
  87,17,"

<q>﴿وَالْآخِرَةُ خَيْرٌ﴾</q> الواو حالية ومبتدأ وخبره والجملة حال وأبقى معطوف على خبر.

"
  87,18,"

<q>﴿إِنَّ هذا﴾</q> إن واسمها <q>﴿لَفِي الصُّحُفِ﴾</q> اللام المزحلقة وفي الصحف خبر إن <q>﴿الْأُولى﴾</q> صفة والجملة مستأنفة لا محل لها.

"
  87,19,"

<q>﴿صُحُفِ﴾</q> بدل من الصحف <q>﴿إِبْراهِيمَ﴾</q> مضاف إليه <q>﴿وَمُوسى﴾</q> معطوف على إبراهيم.

"
  88,1,"

<q>﴿هَلْ﴾</q> حرف استفهام <q>﴿أَتاكَ﴾</q> ماض ومفعوله <q>﴿حَدِيثُ الْغاشِيَةِ﴾</q> فاعل مؤخر مضاف إلى الغاشية والجملة ابتدائية لا محل لها.

"
  88,2,"

<q>﴿وُجُوهٌ﴾</q> مبتدأ <q>﴿يَوْمَئِذٍ﴾</q> ظرف زمان مضاف إلى مثله <q>﴿خاشِعَةٌ﴾</q> خبر المبتدأ والجملة مستأنفة.

"
  88,3,"

<q>﴿عامِلَةٌ ناصِبَةٌ﴾</q> خبران آخران لوجوه.

"
  88,4,"

<q>﴿تَصْلى﴾</q> مضارع فاعله مستتر <q>﴿ناراً﴾</q> مفعول به <q>﴿حامِيَةً﴾</q> صفة والجملة خبر آخر لوجوه.

"
  88,5,"

<q>﴿تُسْقى﴾</q> مضارع مبني للمجهول ونائب الفاعل مستتر <q>﴿مِنْ عَيْنٍ﴾</q> متعلقان بالفعل <q>﴿آنِيَةٍ﴾</q> صفة والجملة صفة ثانية لنار.

"
  88,6,"

<q>﴿لَيْسَ﴾</q> ماض ناقص <q>﴿لَهُمْ﴾</q> خبر ليس المقدم <q>﴿طَعامٌ﴾</q> اسمها المؤخر <q>﴿إِلَّا﴾</q> حرف حصر <q>﴿مِنْ ضَرِيعٍ﴾</q> متعلقان بمحذوف صفة طعام والجملة مستأنفة لا محل لها.

"
  88,7,"

<q>﴿لا﴾</q> نافية <q>﴿يُسْمِنُ﴾</q> مضارع فاعله مستتر والجملة صفة ضريع <q>﴿وَلا يُغْنِي﴾</q> معطوف على ما قبله <q>﴿مِنْ جُوعٍ﴾</q> متعلقان بالفعل.

"
  88,8,"

سبق إعراب مثيلها.

"
  88,9,"

<q>﴿لِسَعْيِها﴾</q> جار ومجرور متعلقان بما بعدهما <q>﴿راضِيَةٌ﴾</q> خبر ثان لوجوه.

"
  88,10,"

<q>﴿فِي جَنَّةٍ﴾</q> جار ومجرور متعلقان بمحذوف خبر آخر لوجوه <q>﴿عالِيَةٍ﴾</q> صفة جنة.

"
  88,11,"

<q>﴿لا﴾</q> نافية <q>﴿تَسْمَعُ﴾</q> مضارع فاعله مستتر <q>﴿فِيها﴾</q> متعلقان بالفعل <q>﴿لاغِيَةً﴾</q> مفعول به والجملة صفة لجنة.

"
  88,12,"

<q>﴿فِيها﴾</q> خبر مقدم <q>﴿عَيْنٌ﴾</q> مبتدأ مؤخر. <q>﴿جارِيَةٌ﴾</q> صفة عين والجملة صفة ثالثة لجنة.

"
  88,13,"

إعرابها كسابقتها.

"
  88,14,"

<q>﴿وَأَكْوابٌ﴾</q> معطوف على سرر <q>﴿مَوْضُوعَةٌ﴾</q> صفة أكواب.

"
  88,15,"

معطوفة على ما قبلها.

"
  88,16,"

معطوفة على ما قبلها أيضا.

"
  88,17,"

<q>﴿أَفَلا﴾</q> الهمزة للاستفهام والفاء حرف عطف ولا نافية <q>﴿يَنْظُرُونَ﴾</q> مضارع مرفوع بثبوت النون والواو فاعله والجملة معطوفة على جملة محذوفة <q>﴿إِلَى الْإِبِلِ﴾</q> متعلقان بالفعل <q>﴿كَيْفَ﴾</q> اسم استفهام في محل نصب حال <q>﴿خُلِقَتْ﴾</q> ماض مبني للمجهول ونائب الفاعل مستتر والجملة بدل اشتمال من الإبل.

"
  88,18,"

معطوفة على ما قبلها.

"
  88,19,"88:18"
  88,20,"

معطوفة أيضا.

"
  88,21,"

<q>﴿فَذَكِّرْ﴾</q> الفاء الفصيحة وأمر فاعله مستتر والجملة جواب شرط مقدر لا محل لها <q>﴿إِنَّما﴾</q> كافة ومكفوفة <q>﴿أَنْتَ مُذَكِّرٌ﴾</q> مبتدأ وخبره والجملة تعليل.

<q>﴿لَسْتَ﴾</q> ماض ناقص واسمه <q>﴿عَلَيْهِمْ﴾</q> متعلقان بما بعدهما <q>﴿بِمُصَيْطِرٍ﴾</q> الباء حرف جر زائد <q>﴿مصيطر﴾</q> مجرور لفظا منصوب محلا خبر ليس والجملة تعليل.

"
  88,22,"88:21"
  88,23,"

<q>﴿إِلَّا﴾</q> حرف استثناء <q>﴿مَنْ﴾</q> اسم موصول مستثنى <q>﴿تَوَلَّى﴾</q> ماض فاعله مستتر والجملة صلة من <q>﴿وَكَفَرَ﴾</q> معطوف على تولى.

"
  88,24,"

<q>﴿فَيُعَذِّبُهُ﴾</q> الفاء واقعة في جواب الشرط لما في الموصول من معنى الشرط ومضارع ومفعوله <q>﴿اللَّهُ﴾</q> لفظ الجلالة فاعله <q>﴿الْعَذابَ﴾</q> مفعول مطلق <q>﴿الْأَكْبَرَ﴾</q> صفة والجملة الفعلية خبر لمبتدأ محذوف.

"
  88,25,"

<q>﴿إِنَّ﴾</q> حرف مشبه بالفعل <q>﴿إِلَيْنا﴾</q> خبر إن المقدم <q>﴿إِيابَهُمْ﴾</q> اسمها المؤخر والجملة تعليل لا محل لها.

"
  88,26,"

معطوفة على ما قبلها والإعراب واضح.

"
