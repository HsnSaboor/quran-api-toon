quran[30]{c,v,t}:
  87,16,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿بَلْ﴾</span></span> حرف عطف <span class="hlt"><span class="qpc-hafs">﴿تُؤْثِرُونَ﴾</span></span> مضارع مرفوع والواو فاعله <span class="hlt"><span class="qpc-hafs">﴿الْحَياةَ﴾</span></span> مفعول به <span class="hlt"><span class="qpc-hafs">﴿الدُّنْيا﴾</span></span> صفة.</p></div>"
  87,17,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وَالْآخِرَةُ خَيْرٌ﴾</span></span> الواو حالية ومبتدأ وخبره والجملة حال وأبقى معطوف على خبر.</p></div>"
  87,18,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إِنَّ هذا﴾</span></span> إن واسمها <span class="hlt"><span class="qpc-hafs">﴿لَفِي الصُّحُفِ﴾</span></span> اللام المزحلقة وفي الصحف خبر إن <span class="hlt"><span class="qpc-hafs">﴿الْأُولى﴾</span></span> صفة والجملة مستأنفة لا محل لها.</p></div>"
  87,19,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿صُحُفِ﴾</span></span> بدل من الصحف <span class="hlt"><span class="qpc-hafs">﴿إِبْراهِيمَ﴾</span></span> مضاف إليه <span class="hlt"><span class="qpc-hafs">﴿وَمُوسى﴾</span></span> معطوف على إبراهيم.</p></div>"
  88,1,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿هَلْ﴾</span></span> حرف استفهام <span class="hlt"><span class="qpc-hafs">﴿أَتاكَ﴾</span></span> ماض ومفعوله <span class="hlt"><span class="qpc-hafs">﴿حَدِيثُ الْغاشِيَةِ﴾</span></span> فاعل مؤخر مضاف إلى الغاشية والجملة ابتدائية لا محل لها.</p></div>"
  88,2,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وُجُوهٌ﴾</span></span> مبتدأ <span class="hlt"><span class="qpc-hafs">﴿يَوْمَئِذٍ﴾</span></span> ظرف زمان مضاف إلى مثله <span class="hlt"><span class="qpc-hafs">﴿خاشِعَةٌ﴾</span></span> خبر المبتدأ والجملة مستأنفة.</p></div>"
  88,3,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿عامِلَةٌ ناصِبَةٌ﴾</span></span> خبران آخران لوجوه.</p></div>"
  88,4,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿تَصْلى﴾</span></span> مضارع فاعله مستتر <span class="hlt"><span class="qpc-hafs">﴿ناراً﴾</span></span> مفعول به <span class="hlt"><span class="qpc-hafs">﴿حامِيَةً﴾</span></span> صفة والجملة خبر آخر لوجوه.</p></div>"
  88,5,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿تُسْقى﴾</span></span> مضارع مبني للمجهول ونائب الفاعل مستتر <span class="hlt"><span class="qpc-hafs">﴿مِنْ عَيْنٍ﴾</span></span> متعلقان بالفعل <span class="hlt"><span class="qpc-hafs">﴿آنِيَةٍ﴾</span></span> صفة والجملة صفة ثانية لنار.</p></div>"
  88,6,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿لَيْسَ﴾</span></span> ماض ناقص <span class="hlt"><span class="qpc-hafs">﴿لَهُمْ﴾</span></span> خبر ليس المقدم <span class="hlt"><span class="qpc-hafs">﴿طَعامٌ﴾</span></span> اسمها المؤخر <span class="hlt"><span class="qpc-hafs">﴿إِلَّا﴾</span></span> حرف حصر <span class="hlt"><span class="qpc-hafs">﴿مِنْ ضَرِيعٍ﴾</span></span> متعلقان بمحذوف صفة طعام والجملة مستأنفة لا محل لها.</p></div>"
  88,7,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿لا﴾</span></span> نافية <span class="hlt"><span class="qpc-hafs">﴿يُسْمِنُ﴾</span></span> مضارع فاعله مستتر والجملة صفة ضريع <span class="hlt"><span class="qpc-hafs">﴿وَلا يُغْنِي﴾</span></span> معطوف على ما قبله <span class="hlt"><span class="qpc-hafs">﴿مِنْ جُوعٍ﴾</span></span> متعلقان بالفعل.</p></div>"
  88,8,"<div class=ar lang=ar><p>سبق إعراب مثيلها.</p></div>"
  88,9,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿لِسَعْيِها﴾</span></span> جار ومجرور متعلقان بما بعدهما <span class="hlt"><span class="qpc-hafs">﴿راضِيَةٌ﴾</span></span> خبر ثان لوجوه.</p></div>"
  88,10,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فِي جَنَّةٍ﴾</span></span> جار ومجرور متعلقان بمحذوف خبر آخر لوجوه <span class="hlt"><span class="qpc-hafs">﴿عالِيَةٍ﴾</span></span> صفة جنة.</p></div>"
  88,11,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿لا﴾</span></span> نافية <span class="hlt"><span class="qpc-hafs">﴿تَسْمَعُ﴾</span></span> مضارع فاعله مستتر <span class="hlt"><span class="qpc-hafs">﴿فِيها﴾</span></span> متعلقان بالفعل <span class="hlt"><span class="qpc-hafs">﴿لاغِيَةً﴾</span></span> مفعول به والجملة صفة لجنة.</p></div>"
  88,12,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فِيها﴾</span></span> خبر مقدم <span class="hlt"><span class="qpc-hafs">﴿عَيْنٌ﴾</span></span> مبتدأ مؤخر. <span class="hlt"><span class="qpc-hafs">﴿جارِيَةٌ﴾</span></span> صفة عين والجملة صفة ثالثة لجنة.</p></div>"
  88,13,"<div class=ar lang=ar><p>إعرابها كسابقتها.</p></div>"
  88,14,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وَأَكْوابٌ﴾</span></span> معطوف على سرر <span class="hlt"><span class="qpc-hafs">﴿مَوْضُوعَةٌ﴾</span></span> صفة أكواب.</p></div>"
  88,15,"<div class=ar lang=ar><p>معطوفة على ما قبلها.</p></div>"
  88,16,"<div class=ar lang=ar><p>معطوفة على ما قبلها أيضا.</p></div>"
  88,17,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿أَفَلا﴾</span></span> الهمزة للاستفهام والفاء حرف عطف ولا نافية <span class="hlt"><span class="qpc-hafs">﴿يَنْظُرُونَ﴾</span></span> مضارع مرفوع بثبوت النون والواو فاعله والجملة معطوفة على جملة محذوفة <span class="hlt"><span class="qpc-hafs">﴿إِلَى الْإِبِلِ﴾</span></span> متعلقان بالفعل <span class="hlt"><span class="qpc-hafs">﴿كَيْفَ﴾</span></span> اسم استفهام في محل نصب حال <span class="hlt"><span class="qpc-hafs">﴿خُلِقَتْ﴾</span></span> ماض مبني للمجهول ونائب الفاعل مستتر والجملة بدل اشتمال من الإبل.</p></div>"
  88,18,"<div class=ar lang=ar><p>معطوفة على ما قبلها.</p></div>"
  88,19,"88:18"
  88,20,"<div class=ar lang=ar><p>معطوفة أيضا.</p></div>"
  88,21,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فَذَكِّرْ﴾</span></span> الفاء الفصيحة وأمر فاعله مستتر والجملة جواب شرط مقدر لا محل لها <span class="hlt"><span class="qpc-hafs">﴿إِنَّما﴾</span></span> كافة ومكفوفة <span class="hlt"><span class="qpc-hafs">﴿أَنْتَ مُذَكِّرٌ﴾</span></span> مبتدأ وخبره والجملة تعليل.</p><p><span class="hlt"><span class="qpc-hafs">﴿لَسْتَ﴾</span></span> ماض ناقص واسمه <span class="hlt"><span class="qpc-hafs">﴿عَلَيْهِمْ﴾</span></span> متعلقان بما بعدهما <span class="hlt"><span class="qpc-hafs">﴿بِمُصَيْطِرٍ﴾</span></span> الباء حرف جر زائد <span class="hlt"><span class="qpc-hafs">﴿مصيطر﴾</span></span> مجرور لفظا منصوب محلا خبر ليس والجملة تعليل.</p></div>"
  88,22,"88:21"
  88,23,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إِلَّا﴾</span></span> حرف استثناء <span class="hlt"><span class="qpc-hafs">﴿مَنْ﴾</span></span> اسم موصول مستثنى <span class="hlt"><span class="qpc-hafs">﴿تَوَلَّى﴾</span></span> ماض فاعله مستتر والجملة صلة من <span class="hlt"><span class="qpc-hafs">﴿وَكَفَرَ﴾</span></span> معطوف على تولى.</p></div>"
  88,24,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فَيُعَذِّبُهُ﴾</span></span> الفاء واقعة في جواب الشرط لما في الموصول من معنى الشرط ومضارع ومفعوله <span class="hlt"><span class="qpc-hafs">﴿اللَّهُ﴾</span></span> لفظ الجلالة فاعله <span class="hlt"><span class="qpc-hafs">﴿الْعَذابَ﴾</span></span> مفعول مطلق <span class="hlt"><span class="qpc-hafs">﴿الْأَكْبَرَ﴾</span></span> صفة والجملة الفعلية خبر لمبتدأ محذوف.</p></div>"
  88,25,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إِنَّ﴾</span></span> حرف مشبه بالفعل <span class="hlt"><span class="qpc-hafs">﴿إِلَيْنا﴾</span></span> خبر إن المقدم <span class="hlt"><span class="qpc-hafs">﴿إِيابَهُمْ﴾</span></span> اسمها المؤخر والجملة تعليل لا محل لها.</p></div>"
  88,26,"<div class=ar lang=ar><p>معطوفة على ما قبلها والإعراب واضح.</p></div>"