tafsir[25]{c,v,t}:
  82,1,"

سبق إعراب مثل هذه الآيات في سورة التكوير.

"
  82,2,"82:1"
  82,3,"82:1"
  82,4,"82:1"
  82,5,"82:1"
  82,6,"

<q>﴿يا﴾</q> حرف نداء و <q>﴿أَيُّهَا﴾</q> منادى مبني على الضم و <q>﴿ها﴾</q> حرف تنبيه و <q>﴿الْإِنْسانُ﴾</q> بدل و <q>﴿ما﴾</q> اسم استفهام مبتدأ و <q>﴿غَرَّكَ﴾</q> ماض ومفعوله والفاعل مستتر والجملة خبر ما و <q>﴿بِرَبِّكَ﴾</q> متعلقان بالفعل و <q>﴿الْكَرِيمِ﴾</q> صفة.

"
  82,7,"

<q>﴿الَّذِي﴾</q> صفة ثانية لربك و <q>﴿خَلَقَكَ﴾</q> ماض ومفعوله والجملة صلة و <q>﴿فَسَوَّاكَ﴾</q> معطوف على خلقك و <q>﴿فَعَدَلَكَ﴾</q> معطوف أيضا.

"
  82,8,"

<q>﴿فِي أَيِّ﴾</q> متعلقان بركبك و <q>﴿صُورَةٍ﴾</q> مضاف إليه و <q>﴿ما﴾</q> زائدة <q>﴿شاءَ﴾</q> ماض فاعله مستتر والجملة صفة صورة و <q>﴿رَكَّبَكَ﴾</q> ماض ومفعوله والفاعل مستتر والجملة حال.

"
  82,9,"

<q>﴿كَلَّا﴾</q> حرف ردع وزجر و <q>﴿بَلْ﴾</q> حرف إضراب انتقالي <q>﴿تُكَذِّبُونَ﴾</q> مضارع مرفوع والواو فاعله و <q>﴿بِالدِّينِ﴾</q> متعلقان بالفعل، والجملة مستأنفة لا محل لها.

"
  82,10,"

<q>﴿وَإِنَّ﴾</q> الواو حالية وإن حرف مشبه بالفعل و <q>﴿عَلَيْكُمْ﴾</q> متعلقان بمحذوف خبر إن المقدم <q>﴿لَحافِظِينَ﴾</q> اللام المزحلقة و <q>﴿حافظين﴾</q> اسم إن المؤخر والجملة حال.

"
  82,11,"

صفتان لحافظين.

"
  82,12,"

<q>﴿يَعْلَمُونَ﴾</q> مضارع وفاعله و <q>﴿ما﴾</q> مفعول به والجملة حال و <q>﴿تَفْعَلُونَ﴾</q> مضارع وفاعله والجملة صلة.

"
  82,13,"

<q>﴿إِنَّ الْأَبْرارَ﴾</q> إن واسمها <q>﴿لَفِي﴾</q> اللام المزحلقة و <q>﴿في نَعِيمٍ﴾</q> متعلقان بمحذوف خبر إن والجملة مستأنفة لا محل لها

"
  82,14,"

معطوفة على ما قبلها والإعراب واضح.

"
  82,15,"

<q>﴿يَصْلَوْنَها﴾</q> مضارع وفاعله ومفعوله والجملة حال و <q>﴿يَوْمَ الدِّينِ﴾</q> ظرف زمان مضاف إلى الدين.

"
  82,16,"

<q>﴿وَما﴾</q> الواو حالية و <q>﴿ما﴾</q> حجازية تعمل عمل ليس و <q>﴿هُمْ﴾</q> اسمها و <q>﴿عَنْها﴾</q> متعلقان بما بعدها و <q>﴿بِغائِبِينَ﴾</q> مجرور لفظا منصوب محلا خبر ما والجملة حال.

"
  82,17,"

<q>﴿وَما﴾</q> الواو حرف استئناف و <q>﴿ما﴾</q> اسم استفهام مبتدأ <q>﴿أَدْراكَ﴾</q> ماض ومفعوله والفاعل مستتر والجملة الفعلية خبر ما والجملة الاسمية مستأنفة و <q>﴿ما يَوْمُ﴾</q> مبتدأ وخبره و <q>﴿الدِّينِ﴾</q> مضاف إليه والجملة سدت مسد مفعول أدراك الثاني.

"
  82,18,"

معطوفة على ما قبلها والإعراب واحد.

"
  82,19,"

<q>﴿يَوْمَ﴾</q> مفعول به لفعل محذوف و <q>﴿لا﴾</q> نافية <q>﴿تَمْلِكُ نَفْسٌ﴾</q> مضارع وفاعله و <q>﴿لِنَفْسٍ﴾</q> متعلقان بالفعل و <q>﴿شَيْئاً﴾</q> مفعول به والجملة في محل جر بالإضافة. <q>﴿وَالْأَمْرُ﴾</q> الواو حرف استئناف و <q>﴿الْأَمْرُ﴾</q> مبتدأ و <q>﴿يَوْمَئِذٍ﴾</q> ظرف زمان مضاف إلى مثله متعلق بمحذوف خبر المبتدأ و <q>﴿لِلَّهِ﴾</q> متعلقان بالخبر المحذوف والجملة الاسمية مستأنفة.

"
  83,1,"

<q>﴿وَيْلٌ﴾</q> مبتدأ مرفوع و <q>﴿لِلْمُطَفِّفِينَ﴾</q> متعلقان بمحذوف خبر المبتدأ والجملة ابتدائية لا محل لها.

"
  83,2,"

<q>﴿الَّذِينَ﴾</q> بدل من المطففين و <q>﴿إِذَا﴾</q> ظرفية شرطية غير جازمة <q>﴿اكْتالُوا﴾</q> ماض وفاعله والجملة في محل جر بالإضافة و <q>﴿عَلَى النَّاسِ﴾</q> متعلقان بما قبلهما <q>﴿يَسْتَوْفُونَ﴾</q> مضارع مرفوع والواو فاعله والجملة جواب الشرط لا محل لها.

"
  83,3,"

<q>﴿وَإِذا﴾</q> معطوفة على إذا الأولى <q>﴿كالُوهُمْ﴾</q> ماض وفاعله ومفعوله والجملة في محل جر بالإضافة <q>﴿أَوْ﴾</q> حرف عطف <q>﴿وَزَنُوهُمْ﴾</q> معطوف على كالوهم. <q>﴿يُخْسِرُونَ﴾</q> مضارع مرفوع والواو فاعله والجملة جواب الشرط لا محل لها.

"
  83,4,"

<q>﴿أَلا﴾</q> الهمزة حرف استفهام و <q>﴿لا﴾</q> نافية و <q>﴿يَظُنُّ﴾</q> مضارع مرفوع و <q>﴿أُولئِكَ﴾</q> فاعل <q>﴿أَنَّهُمْ مَبْعُوثُونَ﴾</q> أن واسمها وخبرها. والمصدر المؤول من أن وما بعدها سد مسد مفعولي يظن.

"
  83,5,"

<q>﴿لِيَوْمٍ﴾</q> متعلقان بمبعوثون و <q>﴿عَظِيمٍ﴾</q> صفة.

"
  83,6,"

<q>﴿يَوْمَ﴾</q> ظرف زمان <q>﴿يَقُومُ النَّاسُ﴾</q> مضارع وفاعله والجملة في محل جر بالإضافة و <q>﴿لِرَبِّ﴾</q> متعلقان بالفعل و <q>﴿الْعالَمِينَ﴾</q> مضاف إليه.

"
