tafsir[28]{c,v,t}:
  83,7,"

<q>﴿كَلَّا﴾</q> حرف ردع وزجر <q>﴿إِنَّ كِتابَ﴾</q> إن واسمها المضاف إلى <q>﴿الفُجَّارِ﴾</q> مضاف إليه <q>﴿لَفِي﴾</q> اللام المزحلقة و <q>﴿في سِجِّينٍ﴾</q> خبر إن والجملة مستأنفة لا محل لها.

"
  83,8,"

<q>﴿وَما﴾</q> الواو حرف استئناف و <q>﴿ما﴾</q> اسم استفهام مبتدأ <q>﴿أَدْراكَ﴾</q> ماض ومفعوله والفاعل مستتر والجملة خبر المبتدأ والجملة الاسمية مستأنفة و <q>﴿ما سِجِّينٌ﴾</q> مبتدأ وخبره والجملة سدت مسد المفعول الثاني لأدراك.

"
  83,9,"

<q>﴿كِتابٌ﴾</q> بدل من سجين و <q>﴿مَرْقُومٌ﴾</q> صفة كتاب.

"
  83,10,"

<q>﴿وَيْلٌ﴾</q> مبتدأ و <q>﴿يَوْمَئِذٍ﴾</q> ظرف زمان مضاف إلى مثله و <q>﴿لِلْمُكَذِّبِينَ﴾</q> خبر المبتدأ والجملة مستأنفة لا محل لها.

"
  83,11,"

<q>﴿الَّذِينَ﴾</q> صفة المكذبين و <q>﴿يُكَذِّبُونَ﴾</q> مضارع وفاعله والجملة صلة الذين و <q>﴿بِيَوْمِ﴾</q> متعلقان بالفعل و <q>﴿الدِّينِ﴾</q> مضاف إليه.

"
  83,12,"

<q>﴿وَما﴾</q> الواو حالية و <q>﴿ما﴾</q> نافية <q>﴿يُكَذِّبُ﴾</q> مضارع مرفوع و <q>﴿بِهِ﴾</q> متعلقان بالفعل و <q>﴿إِلَّا﴾</q> حرف حصر و <q>﴿كُلُّ﴾</q> فاعل مضاف إلى <q>﴿مُعْتَدٍ﴾</q> و <q>﴿أَثِيمٍ﴾</q> صفة والجملة حال.

"
  83,13,"

<q>﴿إِذا﴾</q> ظرفية شرطية غير جازمة و <q>﴿تُتْلى﴾</q> مضارع مبني للمجهول و <q>﴿عَلَيْهِ﴾</q> متعلقان بالفعل و <q>﴿آياتُنا﴾</q> نائب فاعل والجملة في محل جر بالإضافة. <q>﴿قالَ﴾</q> ماض فاعله مستتر والجملة جواب الشرط لا محل لها و <q>﴿أَساطِيرُ﴾</q> خبر لمبتدأ محذوف و <q>﴿الْأَوَّلِينَ﴾</q> مضاف إليه والجملة الاسمية مقول القول.

"
  83,14,"

<q>﴿كَلَّا﴾</q> حرف ردع وزجر و <q>﴿بَلْ﴾</q> حرف انتقال وإضراب <q>﴿رانَ﴾</q> ماض مبني على الفتح و <q>﴿عَلى قُلُوبِهِمْ﴾</q> متعلقان بالفعل و <q>﴿ما﴾</q> فاعل ران والجملة مستأنفة لا محل لها <q>﴿كانُوا﴾</q> ماض ناقص والواو اسمه <q>﴿يَكْسِبُونَ﴾</q> مضارع مرفوع والواو فاعله والجملة خبر كان وجملة كانوا.. صلة ما.

"
  83,15,"

<q>﴿كَلَّا﴾</q> حرف ردع وزجر <q>﴿إِنَّهُمْ﴾</q> إن واسمها و <q>﴿عَنْ رَبِّهِمْ﴾</q> متعلقان بالخبر <q>﴿يَوْمَئِذٍ﴾</q> ظرف زمان مضاف إلى مثله والجملة مستأنفة لا محل لها <q>﴿لَمَحْجُوبُونَ﴾</q> خبر واللام المزحلقة.

"
  83,16,"

<q>﴿ثُمَّ﴾</q> حرف عطف <q>﴿إِنَّهُمْ﴾</q> إن واسمها واللام المزحلقة و <q>﴿صالوا﴾</q> خبر إن المرفوع بالواو وحذفت النون للإضافة و <q>﴿الْجَحِيمِ﴾</q> مضاف إليه والجملة معطوفة على ما قبلها.

"
  83,17,"

<q>﴿ثُمَّ﴾</q> حرف عطف <q>﴿يُقالُ﴾</q> مضارع مبني للمجهول ونائب الفاعل مستتر والجملة معطوفة على ما قبلها و <q>﴿هذَا الَّذِي﴾</q> مبتدأ وخبره <q>﴿كُنْتُمْ﴾</q> كان واسمها و <q>﴿بِهِ﴾</q> متعلقان بما بعدهما والجملة صلة و <q>﴿تُكَذِّبُونَ﴾</q> مضارع مرفوع وفاعله والجملة خبر كنتم.

"
  83,18,"

<q>﴿كَلَّا﴾</q> حرف ردع وزجر <q>﴿إِنَّ كِتابَ﴾</q> إن واسمها المضاف إلى <q>﴿الْأَبْرارِ﴾</q> مضاف إليه <q>﴿لَفِي﴾</q> اللام المزحلقة و <q>﴿في عِلِّيِّينَ﴾</q> خبر إن والجملة مستأنفة.

"
  83,19,"

كإعراب الآية رقم- 8-.

"
  83,20,"

كإعراب الآية رقم- 9- ومرقوم صفة لكتاب.

"
  83,21,"

<q>﴿يَشْهَدُهُ﴾</q> مضارع ومفعوله و <q>﴿الْمُقَرَّبُونَ﴾</q> فاعل والجملة صفة ثانية لكتاب.

"
  83,22,"

<q>﴿إِنَّ الْأَبْرارَ﴾</q> إن واسمها <q>﴿لَفِي﴾</q> اللام المزحلقة و <q>﴿في نَعِيمٍ﴾</q> خبر إن والجملة مستأنفة.

"
  83,23,"

<q>﴿عَلَى الْأَرائِكِ﴾</q> الجار والمجرور متعلقان بما بعدهما و <q>﴿يَنْظُرُونَ﴾</q> مضارع وفاعله والجملة حال.

"
  83,24,"

<q>﴿تَعْرِفُ﴾</q> مضارع فاعله مستتر و <q>﴿فِي وُجُوهِهِمْ﴾</q> متعلقان بالفعل و <q>﴿نَضْرَةَ﴾</q> مفعول به مضاف إلى <q>﴿النَّعِيمِ﴾</q> والجملة مستأنفة لا محل لها.

"
  83,25,"

<q>﴿يُسْقَوْنَ﴾</q> مضارع مبني للمجهول والواو نائب فاعل و <q>﴿مِنْ رَحِيقٍ﴾</q> متعلقان بالفعل و <q>﴿مَخْتُومٍ﴾</q> صفة والجملة مستأنفة.

"
  83,26,"

<q>﴿خِتامُهُ مِسْكٌ﴾</q> مبتدأ وخبره والجملة صفة ثانية لرحيق، <q>﴿وَفِي﴾</q> الواو حرف استئناف و <q>﴿فِي ذلِكَ﴾</q> متعلقان بما بعدهما <q>﴿فَلْيَتَنافَسِ﴾</q> الفاء حرف عطف ومضارع مجزوم بلام الأمر و <q>﴿الْمُتَنافِسُونَ﴾</q> فاعل والجملة معطوفة على ما قبلها.

"
  83,27,"

<q>﴿وَمِزاجُهُ﴾</q> الواو حرف عطف ومبتدأ و <q>﴿مِنْ تَسْنِيمٍ﴾</q> خبره والجملة معطوفة على ما قبلها.

"
  83,28,"

<q>﴿عَيْناً﴾</q> مفعول به لفعل محذوف تقديره أمدح <q>﴿يَشْرَبُ﴾</q> مضارع مرفوع و <q>﴿بِهَا﴾</q> متعلقان بالفعل و <q>﴿الْمُقَرَّبُونَ﴾</q> فاعل مؤخر والجملة صفة عينا.

"
  83,29,"

<q>﴿إِنَّ الَّذِينَ﴾</q> إن واسمها و <q>﴿أَجْرَمُوا﴾</q> ماض وفاعله والجملة صلة الذين <q>﴿كانُوا﴾</q> كان واسمها والجملة خبر إن وجملة إن الذين.. مستأنفة و <q>﴿مِنَ الَّذِينَ﴾</q> متعلقان بيضحكون و <q>﴿آمَنُوا﴾</q> ماض وفاعله والجملة صلة الذين و <q>﴿يَضْحَكُونَ﴾</q> مضارع وفاعله والجملة خبر كانوا.

"
  83,30,"

<q>﴿وَإِذا﴾</q>

الواو حرف عطف <q>﴿إِذا﴾</q>

ظرفية شرطية غير جازمة <q>﴿مَرُّوا﴾</q>

ماض وفاعله و <q>﴿بِهِمْ﴾</q>

متعلقان بالفعل والجملة في محل جر بالإضافة. <q>﴿يَتَغامَزُونَ﴾</q>

مضارع مرفوع والواو فاعله والجملة جواب الشرط لا محل لها.

"
  83,31,"

<q>﴿وَإِذَا﴾</q> الواو حرف عطف <q>﴿إِذَا﴾</q> ظرفية شرطية غير جازمة <q>﴿انْقَلَبُوا﴾</q> ماض وفاعله و <q>﴿إِلى أَهْلِهِمُ﴾</q> متعلقان بما قبلهما والجملة في محل جر بالإضافة و <q>﴿انْقَلَبُوا﴾</q> ماض وفاعله والجملة جواب الشرط لا محل لها و <q>﴿فَكِهِينَ﴾</q> حال.

"
  83,32,"

<q>﴿وَإِذا﴾</q> الواو حرف عطف <q>﴿إِذا﴾</q> ظرفية شرطية غير جازمة <q>﴿رَأَوْهُمْ﴾</q> ماض وفاعله ومفعوله والجملة في محل جر بالإضافة و <q>﴿قالُوا﴾</q> ماض وفاعله والجملة جواب الشرط لا محل لها <q>﴿إِنَّ هؤُلاءِ لَضالُّونَ﴾</q> إن واسمها واللام المزحلقة و <q>﴿لَضالُّونَ﴾</q> خبر إن والجملة مقول القول.

"
  83,33,"

<q>﴿وَما﴾</q> الواو حالية <q>﴿ما﴾</q> نافية <q>﴿أُرْسِلُوا﴾</q> ماض مبني للمجهول والواو نائب فاعل و <q>﴿عَلَيْهِمْ﴾</q> متعلقان بالفعل و <q>﴿حافِظِينَ﴾</q> حال والجملة حال.

"
  83,34,"

<q>﴿فَالْيَوْمَ﴾</q> الفاء حرف استئناف و <q>﴿اليوم﴾</q> ظرف زمان و <q>﴿الَّذِينَ﴾</q> مبتدأ <q>﴿آمَنُوا﴾</q> ماض وفاعله والجملة صلة و <q>﴿مِنَ الْكُفَّارِ﴾</q> متعلقان بما بعدهما <q>﴿يَضْحَكُونَ﴾</q> مضارع مرفوع والواو فاعله والجملة الفعلية خبر المبتدأ والجملة الاسمية مستأنفة لا محل لها.

"
