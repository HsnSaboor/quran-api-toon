quran[28]{c,v,t}:
  83,7,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿كَلَّا﴾</span></span> حرف ردع وزجر <span class="hlt"><span class="qpc-hafs">﴿إِنَّ كِتابَ﴾</span></span> إن واسمها المضاف إلى <span class="hlt"><span class="qpc-hafs">﴿الفُجَّارِ﴾</span></span> مضاف إليه <span class="hlt"><span class="qpc-hafs">﴿لَفِي﴾</span></span> اللام المزحلقة و <span class="hlt"><span class="qpc-hafs">﴿في سِجِّينٍ﴾</span></span> خبر إن والجملة مستأنفة لا محل لها.</p></div>"
  83,8,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وَما﴾</span></span> الواو حرف استئناف و <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> اسم استفهام مبتدأ <span class="hlt"><span class="qpc-hafs">﴿أَدْراكَ﴾</span></span> ماض ومفعوله والفاعل مستتر والجملة خبر المبتدأ والجملة الاسمية مستأنفة و <span class="hlt"><span class="qpc-hafs">﴿ما سِجِّينٌ﴾</span></span> مبتدأ وخبره والجملة سدت مسد المفعول الثاني لأدراك.</p></div>"
  83,9,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿كِتابٌ﴾</span></span> بدل من سجين و <span class="hlt"><span class="qpc-hafs">﴿مَرْقُومٌ﴾</span></span> صفة كتاب.</p></div>"
  83,10,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وَيْلٌ﴾</span></span> مبتدأ و <span class="hlt"><span class="qpc-hafs">﴿يَوْمَئِذٍ﴾</span></span> ظرف زمان مضاف إلى مثله و <span class="hlt"><span class="qpc-hafs">﴿لِلْمُكَذِّبِينَ﴾</span></span> خبر المبتدأ والجملة مستأنفة لا محل لها.</p></div>"
  83,11,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿الَّذِينَ﴾</span></span> صفة المكذبين و <span class="hlt"><span class="qpc-hafs">﴿يُكَذِّبُونَ﴾</span></span> مضارع وفاعله والجملة صلة الذين و <span class="hlt"><span class="qpc-hafs">﴿بِيَوْمِ﴾</span></span> متعلقان بالفعل و <span class="hlt"><span class="qpc-hafs">﴿الدِّينِ﴾</span></span> مضاف إليه.</p></div>"
  83,12,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وَما﴾</span></span> الواو حالية و <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> نافية <span class="hlt"><span class="qpc-hafs">﴿يُكَذِّبُ﴾</span></span> مضارع مرفوع و <span class="hlt"><span class="qpc-hafs">﴿بِهِ﴾</span></span> متعلقان بالفعل و <span class="hlt"><span class="qpc-hafs">﴿إِلَّا﴾</span></span> حرف حصر و <span class="hlt"><span class="qpc-hafs">﴿كُلُّ﴾</span></span> فاعل مضاف إلى <span class="hlt"><span class="qpc-hafs">﴿مُعْتَدٍ﴾</span></span> و <span class="hlt"><span class="qpc-hafs">﴿أَثِيمٍ﴾</span></span> صفة والجملة حال.</p></div>"
  83,13,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إِذا﴾</span></span> ظرفية شرطية غير جازمة و <span class="hlt"><span class="qpc-hafs">﴿تُتْلى﴾</span></span> مضارع مبني للمجهول و <span class="hlt"><span class="qpc-hafs">﴿عَلَيْهِ﴾</span></span> متعلقان بالفعل و <span class="hlt"><span class="qpc-hafs">﴿آياتُنا﴾</span></span> نائب فاعل والجملة في محل جر بالإضافة. <span class="hlt"><span class="qpc-hafs">﴿قالَ﴾</span></span> ماض فاعله مستتر والجملة جواب الشرط لا محل لها و <span class="hlt"><span class="qpc-hafs">﴿أَساطِيرُ﴾</span></span> خبر لمبتدأ محذوف و <span class="hlt"><span class="qpc-hafs">﴿الْأَوَّلِينَ﴾</span></span> مضاف إليه والجملة الاسمية مقول القول.</p></div>"
  83,14,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿كَلَّا﴾</span></span> حرف ردع وزجر و <span class="hlt"><span class="qpc-hafs">﴿بَلْ﴾</span></span> حرف انتقال وإضراب <span class="hlt"><span class="qpc-hafs">﴿رانَ﴾</span></span> ماض مبني على الفتح و <span class="hlt"><span class="qpc-hafs">﴿عَلى قُلُوبِهِمْ﴾</span></span> متعلقان بالفعل و <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> فاعل ران والجملة مستأنفة لا محل لها <span class="hlt"><span class="qpc-hafs">﴿كانُوا﴾</span></span> ماض ناقص والواو اسمه <span class="hlt"><span class="qpc-hafs">﴿يَكْسِبُونَ﴾</span></span> مضارع مرفوع والواو فاعله والجملة خبر كان وجملة كانوا.. صلة ما.</p></div>"
  83,15,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿كَلَّا﴾</span></span> حرف ردع وزجر <span class="hlt"><span class="qpc-hafs">﴿إِنَّهُمْ﴾</span></span> إن واسمها و <span class="hlt"><span class="qpc-hafs">﴿عَنْ رَبِّهِمْ﴾</span></span> متعلقان بالخبر <span class="hlt"><span class="qpc-hafs">﴿يَوْمَئِذٍ﴾</span></span> ظرف زمان مضاف إلى مثله والجملة مستأنفة لا محل لها <span class="hlt"><span class="qpc-hafs">﴿لَمَحْجُوبُونَ﴾</span></span> خبر واللام المزحلقة.</p></div>"
  83,16,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ثُمَّ﴾</span></span> حرف عطف <span class="hlt"><span class="qpc-hafs">﴿إِنَّهُمْ﴾</span></span> إن واسمها واللام المزحلقة و <span class="hlt"><span class="qpc-hafs">﴿صالوا﴾</span></span> خبر إن المرفوع بالواو وحذفت النون للإضافة و <span class="hlt"><span class="qpc-hafs">﴿الْجَحِيمِ﴾</span></span> مضاف إليه والجملة معطوفة على ما قبلها.</p></div>"
  83,17,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ثُمَّ﴾</span></span> حرف عطف <span class="hlt"><span class="qpc-hafs">﴿يُقالُ﴾</span></span> مضارع مبني للمجهول ونائب الفاعل مستتر والجملة معطوفة على ما قبلها و <span class="hlt"><span class="qpc-hafs">﴿هذَا الَّذِي﴾</span></span> مبتدأ وخبره <span class="hlt"><span class="qpc-hafs">﴿كُنْتُمْ﴾</span></span> كان واسمها و <span class="hlt"><span class="qpc-hafs">﴿بِهِ﴾</span></span> متعلقان بما بعدهما والجملة صلة و <span class="hlt"><span class="qpc-hafs">﴿تُكَذِّبُونَ﴾</span></span> مضارع مرفوع وفاعله والجملة خبر كنتم.</p></div>"
  83,18,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿كَلَّا﴾</span></span> حرف ردع وزجر <span class="hlt"><span class="qpc-hafs">﴿إِنَّ كِتابَ﴾</span></span> إن واسمها المضاف إلى <span class="hlt"><span class="qpc-hafs">﴿الْأَبْرارِ﴾</span></span> مضاف إليه <span class="hlt"><span class="qpc-hafs">﴿لَفِي﴾</span></span> اللام المزحلقة و <span class="hlt"><span class="qpc-hafs">﴿في عِلِّيِّينَ﴾</span></span> خبر إن والجملة مستأنفة.</p></div>"
  83,19,"<div class=ar lang=ar><p>كإعراب الآية رقم- 8-.</p></div>"
  83,20,"<div class=ar lang=ar><p>كإعراب الآية رقم- 9- ومرقوم صفة لكتاب.</p></div>"
  83,21,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿يَشْهَدُهُ﴾</span></span> مضارع ومفعوله و <span class="hlt"><span class="qpc-hafs">﴿الْمُقَرَّبُونَ﴾</span></span> فاعل والجملة صفة ثانية لكتاب.</p></div>"
  83,22,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إِنَّ الْأَبْرارَ﴾</span></span> إن واسمها <span class="hlt"><span class="qpc-hafs">﴿لَفِي﴾</span></span> اللام المزحلقة و <span class="hlt"><span class="qpc-hafs">﴿في نَعِيمٍ﴾</span></span> خبر إن والجملة مستأنفة.</p></div>"
  83,23,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿عَلَى الْأَرائِكِ﴾</span></span> الجار والمجرور متعلقان بما بعدهما و <span class="hlt"><span class="qpc-hafs">﴿يَنْظُرُونَ﴾</span></span> مضارع وفاعله والجملة حال.</p></div>"
  83,24,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿تَعْرِفُ﴾</span></span> مضارع فاعله مستتر و <span class="hlt"><span class="qpc-hafs">﴿فِي وُجُوهِهِمْ﴾</span></span> متعلقان بالفعل و <span class="hlt"><span class="qpc-hafs">﴿نَضْرَةَ﴾</span></span> مفعول به مضاف إلى <span class="hlt"><span class="qpc-hafs">﴿النَّعِيمِ﴾</span></span> والجملة مستأنفة لا محل لها.</p></div>"
  83,25,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿يُسْقَوْنَ﴾</span></span> مضارع مبني للمجهول والواو نائب فاعل و <span class="hlt"><span class="qpc-hafs">﴿مِنْ رَحِيقٍ﴾</span></span> متعلقان بالفعل و <span class="hlt"><span class="qpc-hafs">﴿مَخْتُومٍ﴾</span></span> صفة والجملة مستأنفة.</p></div>"
  83,26,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿خِتامُهُ مِسْكٌ﴾</span></span> مبتدأ وخبره والجملة صفة ثانية لرحيق، <span class="hlt"><span class="qpc-hafs">﴿وَفِي﴾</span></span> الواو حرف استئناف و <span class="hlt"><span class="qpc-hafs">﴿فِي ذلِكَ﴾</span></span> متعلقان بما بعدهما <span class="hlt"><span class="qpc-hafs">﴿فَلْيَتَنافَسِ﴾</span></span> الفاء حرف عطف ومضارع مجزوم بلام الأمر و <span class="hlt"><span class="qpc-hafs">﴿الْمُتَنافِسُونَ﴾</span></span> فاعل والجملة معطوفة على ما قبلها.</p></div>"
  83,27,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وَمِزاجُهُ﴾</span></span> الواو حرف عطف ومبتدأ و <span class="hlt"><span class="qpc-hafs">﴿مِنْ تَسْنِيمٍ﴾</span></span> خبره والجملة معطوفة على ما قبلها.</p></div>"
  83,28,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿عَيْناً﴾</span></span> مفعول به لفعل محذوف تقديره أمدح <span class="hlt"><span class="qpc-hafs">﴿يَشْرَبُ﴾</span></span> مضارع مرفوع و <span class="hlt"><span class="qpc-hafs">﴿بِهَا﴾</span></span> متعلقان بالفعل و <span class="hlt"><span class="qpc-hafs">﴿الْمُقَرَّبُونَ﴾</span></span> فاعل مؤخر والجملة صفة عينا.</p></div>"
  83,29,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إِنَّ الَّذِينَ﴾</span></span> إن واسمها و <span class="hlt"><span class="qpc-hafs">﴿أَجْرَمُوا﴾</span></span> ماض وفاعله والجملة صلة الذين <span class="hlt"><span class="qpc-hafs">﴿كانُوا﴾</span></span> كان واسمها والجملة خبر إن وجملة إن الذين.. مستأنفة و <span class="hlt"><span class="qpc-hafs">﴿مِنَ الَّذِينَ﴾</span></span> متعلقان بيضحكون و <span class="hlt"><span class="qpc-hafs">﴿آمَنُوا﴾</span></span> ماض وفاعله والجملة صلة الذين و <span class="hlt"><span class="qpc-hafs">﴿يَضْحَكُونَ﴾</span></span> مضارع وفاعله والجملة خبر كانوا.</p></div>"
  83,30,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وَإِذا﴾</span></span></p><p>الواو حرف عطف <span class="hlt"><span class="qpc-hafs">﴿إِذا﴾</span></span></p><p>ظرفية شرطية غير جازمة <span class="hlt"><span class="qpc-hafs">﴿مَرُّوا﴾</span></span></p><p>ماض وفاعله و <span class="hlt"><span class="qpc-hafs">﴿بِهِمْ﴾</span></span></p><p>متعلقان بالفعل والجملة في محل جر بالإضافة. <span class="hlt"><span class="qpc-hafs">﴿يَتَغامَزُونَ﴾</span></span></p><p>مضارع مرفوع والواو فاعله والجملة جواب الشرط لا محل لها.</p></div>"
  83,31,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وَإِذَا﴾</span></span> الواو حرف عطف <span class="hlt"><span class="qpc-hafs">﴿إِذَا﴾</span></span> ظرفية شرطية غير جازمة <span class="hlt"><span class="qpc-hafs">﴿انْقَلَبُوا﴾</span></span> ماض وفاعله و <span class="hlt"><span class="qpc-hafs">﴿إِلى أَهْلِهِمُ﴾</span></span> متعلقان بما قبلهما والجملة في محل جر بالإضافة و <span class="hlt"><span class="qpc-hafs">﴿انْقَلَبُوا﴾</span></span> ماض وفاعله والجملة جواب الشرط لا محل لها و <span class="hlt"><span class="qpc-hafs">﴿فَكِهِينَ﴾</span></span> حال.</p></div>"
  83,32,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وَإِذا﴾</span></span> الواو حرف عطف <span class="hlt"><span class="qpc-hafs">﴿إِذا﴾</span></span> ظرفية شرطية غير جازمة <span class="hlt"><span class="qpc-hafs">﴿رَأَوْهُمْ﴾</span></span> ماض وفاعله ومفعوله والجملة في محل جر بالإضافة و <span class="hlt"><span class="qpc-hafs">﴿قالُوا﴾</span></span> ماض وفاعله والجملة جواب الشرط لا محل لها <span class="hlt"><span class="qpc-hafs">﴿إِنَّ هؤُلاءِ لَضالُّونَ﴾</span></span> إن واسمها واللام المزحلقة و <span class="hlt"><span class="qpc-hafs">﴿لَضالُّونَ﴾</span></span> خبر إن والجملة مقول القول.</p></div>"
  83,33,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وَما﴾</span></span> الواو حالية <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> نافية <span class="hlt"><span class="qpc-hafs">﴿أُرْسِلُوا﴾</span></span> ماض مبني للمجهول والواو نائب فاعل و <span class="hlt"><span class="qpc-hafs">﴿عَلَيْهِمْ﴾</span></span> متعلقان بالفعل و <span class="hlt"><span class="qpc-hafs">﴿حافِظِينَ﴾</span></span> حال والجملة حال.</p></div>"
  83,34,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فَالْيَوْمَ﴾</span></span> الفاء حرف استئناف و <span class="hlt"><span class="qpc-hafs">﴿اليوم﴾</span></span> ظرف زمان و <span class="hlt"><span class="qpc-hafs">﴿الَّذِينَ﴾</span></span> مبتدأ <span class="hlt"><span class="qpc-hafs">﴿آمَنُوا﴾</span></span> ماض وفاعله والجملة صلة و <span class="hlt"><span class="qpc-hafs">﴿مِنَ الْكُفَّارِ﴾</span></span> متعلقان بما بعدهما <span class="hlt"><span class="qpc-hafs">﴿يَضْحَكُونَ﴾</span></span> مضارع مرفوع والواو فاعله والجملة الفعلية خبر المبتدأ والجملة الاسمية مستأنفة لا محل لها.</p></div>"