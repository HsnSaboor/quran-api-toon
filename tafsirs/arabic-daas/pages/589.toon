quran[27]{c,v,t}:
  83,35,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿عَلَى الْأَرائِكِ﴾</span></span> الجار والمجرور متعلقان بما بعدهما <span class="hlt"><span class="qpc-hafs">﴿يَنْظُرُونَ﴾</span></span> الجملة حال.</p></div>"
  83,36,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿هَلْ﴾</span></span> حرف استفهام <span class="hlt"><span class="qpc-hafs">﴿ثُوِّبَ﴾</span></span> ماض مبني للمجهول و <span class="hlt"><span class="qpc-hafs">﴿الْكُفَّارُ﴾</span></span> نائب فاعل والجملة مقول قول محذوف و <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> مفعول به <span class="hlt"><span class="qpc-hafs">﴿كانُوا﴾</span></span> كان واسمها <span class="hlt"><span class="qpc-hafs">﴿يَفْعَلُونَ﴾</span></span> مضارع مرفوع والواو فاعله والجملة خبر كانوا وجملة كانوا صلة ما.</p></div>"
  84,1,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إِذَا﴾</span></span> ظرفية شرطية غير جازمة <span class="hlt"><span class="qpc-hafs">﴿السَّماءُ﴾</span></span> فاعل لفعل محذوف يفسره المذكور بعده <span class="hlt"><span class="qpc-hafs">﴿انْشَقَّتْ﴾</span></span> ماض فاعله مستتر والجملة مفسرة والجملة المقدرة في محل جر بالإضافة.</p></div>"
  84,2,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وَأَذِنَتْ﴾</span></span> ماض فاعله مستتر والجملة معطوفة على ما قبلها <span class="hlt"><span class="qpc-hafs">﴿لِرَبِّها﴾</span></span> متعلقان بالفعل <span class="hlt"><span class="qpc-hafs">﴿وَحُقَّتْ﴾</span></span> ماض مبني للمجهول ونائب الفاعل مستتر والجملة معطوفة على ما قبلها.</p></div>"
  84,3,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وَإِذَا﴾</span></span> الواو حرف عطف والكلام معطوف على ما قبله وإعرابه واضح.</p></div>"
  84,4,"<div class=ar lang=ar><p>الجملة معطوفة على ما قبلها.</p></div>"
  84,5,"<div class=ar lang=ar><p>سبق إعرابها.</p></div>"
  84,6,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿يا أَيُّهَا﴾</span></span> يا حرف نداء ومنادى مبني على الضم <span class="hlt"><span class="qpc-hafs">﴿الْإِنْسانُ﴾</span></span> بدل <span class="hlt"><span class="qpc-hafs">﴿إِنَّكَ﴾</span></span> إن واسمها <span class="hlt"><span class="qpc-hafs">﴿كادِحٌ﴾</span></span> خبرها والجملتان الاسمية والندائية ابتدائيتان لا محل لهما <span class="hlt"><span class="qpc-hafs">﴿إِلى رَبِّكَ﴾</span></span> متعلقان بكادح <span class="hlt"><span class="qpc-hafs">﴿كَدْحاً﴾</span></span> مفعول مطلق <span class="hlt"><span class="qpc-hafs">﴿فَمُلاقِيهِ﴾</span></span> الفاء حرف عطف <span class="hlt"><span class="qpc-hafs">﴿ملاقيه﴾</span></span> معطوف على كادح.</p></div>"
  84,7,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فَأَمَّا﴾</span></span> الفاء حرف استئناف <span class="hlt"><span class="qpc-hafs">﴿أما﴾</span></span> حرف شرط وتفصيل <span class="hlt"><span class="qpc-hafs">﴿مَنْ﴾</span></span> اسم موصول مبتدأ <span class="hlt"><span class="qpc-hafs">﴿أُوتِيَ﴾</span></span> ماض مبني للمجهول ونائب الفاعل مستتر والجملة صلة من <span class="hlt"><span class="qpc-hafs">﴿كِتابَهُ﴾</span></span> مفعول به ثان <span class="hlt"><span class="qpc-hafs">﴿بِيَمِينِهِ﴾</span></span> متعلقان بالفعل.</p></div>"
  84,8,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فَسَوْفَ﴾</span></span> الفاء واقعة في جواب الشرط <span class="hlt"><span class="qpc-hafs">﴿سوف﴾</span></span> للاستقبال <span class="hlt"><span class="qpc-hafs">﴿يُحاسَبُ﴾</span></span> مضارع مبني للمجهول ونائب الفاعل مستتر <span class="hlt"><span class="qpc-hafs">﴿حِساباً﴾</span></span> مفعول مطلق <span class="hlt"><span class="qpc-hafs">﴿يَسِيراً﴾</span></span> صفة والجملة الفعلية خبر من.</p></div>"
  84,9,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وَيَنْقَلِبُ﴾</span></span> مضارع فاعله مستتر <span class="hlt"><span class="qpc-hafs">﴿إِلى أَهْلِهِ﴾</span></span> متعلقان بالفعل <span class="hlt"><span class="qpc-hafs">﴿مَسْرُوراً﴾</span></span> حال والجملة معطوفة على ما قبلها.</p></div>"
  84,10,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وَأَمَّا﴾</span></span> الواو حرف عطف <span class="hlt"><span class="qpc-hafs">﴿أَمَّا مَنْ أُوتِيَ﴾</span></span> سبق إعرابه <span class="hlt"><span class="qpc-hafs">﴿كِتابَهُ﴾</span></span> مفعول به ثان <span class="hlt"><span class="qpc-hafs">﴿وَراءَ﴾</span></span> منصوب بنزع الخافض <span class="hlt"><span class="qpc-hafs">﴿ظَهْرِهِ﴾</span></span> مضاف إليه <span class="hlt"><span class="qpc-hafs">﴿فَسَوْفَ﴾</span></span> الفاء رابطة <span class="hlt"><span class="qpc-hafs">﴿سوف يَدْعُوا﴾</span></span> سوف للاستقبال ومضارع فاعله مستتر والجملة خبر من <span class="hlt"><span class="qpc-hafs">﴿ثُبُوراً﴾</span></span> مفعول به.</p></div>"
  84,11,"84:10"
  84,12,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وَيَصْلى﴾</span></span> مضارع فاعله مستتر <span class="hlt"><span class="qpc-hafs">﴿سَعِيراً﴾</span></span> مفعول به والجملة معطوفة على ما قبلها.</p></div>"
  84,13,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إِنَّهُ﴾</span></span> إن واسمها <span class="hlt"><span class="qpc-hafs">﴿كانَ﴾</span></span> ماض ناقص اسمه مستتر <span class="hlt"><span class="qpc-hafs">﴿فِي أَهْلِهِ﴾</span></span> متعلقان بما بعدهما <span class="hlt"><span class="qpc-hafs">﴿مَسْرُوراً﴾</span></span> خبر كان والجملة الفعلية خبر إن والجملة الاسمية مستأنفة لا محل لها.</p></div>"
  84,14,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إِنَّهُ﴾</span></span> إن واسمها <span class="hlt"><span class="qpc-hafs">﴿ظَنَّ﴾</span></span> ماض فاعله مستتر والجملة خبر إن والجملة الاسمية بدل من سابقتها <span class="hlt"><span class="qpc-hafs">﴿أَنْ﴾</span></span> مخففة من الثقيلة واسمها ضمير الشأن محذوف <span class="hlt"><span class="qpc-hafs">﴿لَنْ يَحُورَ﴾</span></span> مضارع منصوب بلن والجملة الفعلية خبر أن المخففة والمصدر المؤول من أن وما بعدها سد مسد مفعولي ظن.</p></div>"
  84,15,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿بَلى﴾</span></span> حرف جواب <span class="hlt"><span class="qpc-hafs">﴿إِنَّ رَبَّهُ﴾</span></span> إن واسمها <span class="hlt"><span class="qpc-hafs">﴿كانَ﴾</span></span> ماض ناقص اسمه مستتر <span class="hlt"><span class="qpc-hafs">﴿بِهِ﴾</span></span> متعلقان بما بعدهما <span class="hlt"><span class="qpc-hafs">﴿بَصِيراً﴾</span></span> خبر كان والجملة الفعلية خبر إن والجملة الاسمية جواب قسم مقدر.</p></div>"
  84,16,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فَلا﴾</span></span> الفاء حرف استئناف <span class="hlt"><span class="qpc-hafs">﴿لا﴾</span></span> زائدة <span class="hlt"><span class="qpc-hafs">﴿أُقْسِمُ﴾</span></span> مضارع فاعله مستتر <span class="hlt"><span class="qpc-hafs">﴿بِالشَّفَقِ﴾</span></span> متعلقان بالفعل والجملة مستأنفة لا محل لها.</p></div>"
  84,17,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وَاللَّيْلِ﴾</span></span> معطوف على الشفق <span class="hlt"><span class="qpc-hafs">﴿وَما﴾</span></span> اسم موصول معطوف على الليل <span class="hlt"><span class="qpc-hafs">﴿وَسَقَ﴾</span></span> ماض فاعله مستتر والجملة صلة ما.</p></div>"
  84,18,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وَالْقَمَرِ﴾</span></span> معطوف على ما قبله <span class="hlt"><span class="qpc-hafs">﴿إِذَا﴾</span></span> ظرف زمان <span class="hlt"><span class="qpc-hafs">﴿اتَّسَقَ﴾</span></span> ماض فاعله مستتر والجملة في محل جر بالإضافة.</p></div>"
  84,19,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿لَتَرْكَبُنَّ﴾</span></span> اللام واقعة في جواب القسم ومضارع مرفوع بثبوت النون المحذوفة لتوالي الأمثال والواو المحذوفة لالتقاء الساكنين فاعل والنون المذكورة للتوكيد <span class="hlt"><span class="qpc-hafs">﴿طَبَقاً﴾</span></span> مفعول به <span class="hlt"><span class="qpc-hafs">﴿عَنْ طَبَقٍ﴾</span></span> متعلقان بمحذوف صفة طبقا.</p></div>"
  84,20,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فَما﴾</span></span> الفاء حرف استئناف <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> اسم استفهام مبتدأ <span class="hlt"><span class="qpc-hafs">﴿لَهُمْ﴾</span></span> خبر المبتدأ والجملة الاسمية مستأنفة <span class="hlt"><span class="qpc-hafs">﴿لا﴾</span></span> نافية <span class="hlt"><span class="qpc-hafs">﴿يُؤْمِنُونَ﴾</span></span> مضارع مرفوع والواو فاعله والجملة الفعلية حال.</p></div>"
  84,21,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وَإِذا﴾</span></span> الواو حرف عطف <span class="hlt"><span class="qpc-hafs">﴿إِذا﴾</span></span> ظرفية شرطية غير جازمة <span class="hlt"><span class="qpc-hafs">﴿قُرِئَ﴾</span></span> ماض مبني للمجهول <span class="hlt"><span class="qpc-hafs">﴿عَلَيْهِمُ﴾</span></span> متعلقان بالفعل <span class="hlt"><span class="qpc-hafs">﴿الْقُرْآنُ﴾</span></span> نائب فاعل والجملة في محل جر بالإضافة <span class="hlt"><span class="qpc-hafs">﴿لا﴾</span></span> نافية <span class="hlt"><span class="qpc-hafs">﴿يَسْجُدُونَ﴾</span></span> مضارع مرفوع والواو فاعله والجملة جواب الشرط لا محل لها. وجملة إذا.. معطوفة على ما قبلها.</p></div>"
  84,22,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿بَلِ﴾</span></span> حرف إضراب وانتقال <span class="hlt"><span class="qpc-hafs">﴿الَّذِينَ﴾</span></span> اسم موصول مبتدأ <span class="hlt"><span class="qpc-hafs">﴿كَفَرُوا﴾</span></span> ماض وفاعله والجملة صلة <span class="hlt"><span class="qpc-hafs">﴿يُكَذِّبُونَ﴾</span></span> مضارع مرفوع بثبوت النون والواو فاعله والجملة خبر المبتدأ والجملة الاسمية مستأنفة لا محل لها.</p></div>"
  84,23,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وَاللَّهُ أَعْلَمُ﴾</span></span> مبتدأ وخبره والجملة معطوفة على ما قبلها <span class="hlt"><span class="qpc-hafs">﴿بِما﴾</span></span> متعلقان بما قبلهما <span class="hlt"><span class="qpc-hafs">﴿يُوعُونَ﴾</span></span> مضارع مرفوع بثبوت النون والواو فاعله، معنى يوعون: يجمعون في صحفهم الذنوب، والجملة صلة ما.</p></div>"
  84,24,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فَبَشِّرْهُمْ﴾</span></span> الفاء الفصيحة وأمر ومفعوله والفاعل مستتر <span class="hlt"><span class="qpc-hafs">﴿بِعَذابٍ﴾</span></span> متعلقان بالفعل <span class="hlt"><span class="qpc-hafs">﴿أَلِيمٍ﴾</span></span> صفة والجملة جواب شرط مقدر لا محل لها.</p></div>"
  84,25,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إِلَّا﴾</span></span> حرف استثناء <span class="hlt"><span class="qpc-hafs">﴿الَّذِينَ﴾</span></span> مستثنى منصوب <span class="hlt"><span class="qpc-hafs">﴿آمَنُوا﴾</span></span> ماض وفاعله والجملة صلة <span class="hlt"><span class="qpc-hafs">﴿وَعَمِلُوا﴾</span></span> معطوف على آمنوا <span class="hlt"><span class="qpc-hafs">﴿الصَّالِحاتِ﴾</span></span> مفعول به <span class="hlt"><span class="qpc-hafs">﴿لَهُمْ أَجْرٌ﴾</span></span> خبر مقدم ومبتدأ مؤخر <span class="hlt"><span class="qpc-hafs">﴿غَيْرُ مَمْنُونٍ﴾</span></span> صفة مضاف إلى ممنون والجملة مستأنفة.</p></div>"