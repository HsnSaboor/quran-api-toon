quran[15]{c,v,t}:
  112,1,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قُلْ﴾</span></span> أمر فاعله مستتر والجملة ابتدائية لا محل لها <span class="hlt"><span class="qpc-hafs">﴿هُوَ﴾</span></span> ضمير الشأن مبتدأ <span class="hlt"><span class="qpc-hafs">﴿اللَّهُ أَحَدٌ﴾</span></span> مبتدأ وخبره والجملة خبر هو وجملة هو.. مقول القول.</p></div>"
  112,2,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿اللَّهُ الصَّمَدُ﴾</span></span> مبتدأ وخبره والجملة مستأنفة لا محل لها.</p></div>"
  112,3,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿لَمْ يَلِدْ﴾</span></span> مضارع مجزوم بلم والفاعل مستتر والجملة مستأنفة لا محل لها <span class="hlt"><span class="qpc-hafs">﴿وَلَمْ يُولَدْ﴾</span></span> الواو حرف عطف ومضارع مبني للمجهول مجزوم بلم ونائب الفاعل مستتر والجملة معطوفة على ما قبلها.</p></div>"
  112,4,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وَلَمْ يَكُنْ﴾</span></span> الواو حرف عطف ومضارع ناقص مجزوم بلم <span class="hlt"><span class="qpc-hafs">﴿لَهُ﴾</span></span> متعلقان بكفوا <span class="hlt"><span class="qpc-hafs">﴿كُفُواً﴾</span></span> خبر يكن مقدم <span class="hlt"><span class="qpc-hafs">﴿أَحَدٌ﴾</span></span> اسمه المؤخر. والجملة معطوفة على ما قبلها.</p></div>"
  113,1,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قُلْ﴾</span></span> أمر فاعله مستتر والجملة ابتدائية لا محل لها. <span class="hlt"><span class="qpc-hafs">﴿أَعُوذُ﴾</span></span> مضارع فاعله مستتر <span class="hlt"><span class="qpc-hafs">﴿بِرَبِّ﴾</span></span> متعلقان بالفعل <span class="hlt"><span class="qpc-hafs">﴿الْفَلَقِ﴾</span></span> مضاف إليه والجملة مقول القول.</p></div>"
  113,2,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿مِنْ شَرِّ﴾</span></span> الجار والمجرور متعلقان بأعوذ <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> اسم موصول مضاف إليه <span class="hlt"><span class="qpc-hafs">﴿خَلَقَ﴾</span></span> ماض فاعله مستتر والجملة صلة</p></div>"
  113,3,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وَمِنْ شَرِّ﴾</span></span> معطوفان على ما قبلهما <span class="hlt"><span class="qpc-hafs">﴿غاسِقٍ﴾</span></span> مضاف إليه <span class="hlt"><span class="qpc-hafs">﴿إِذا﴾</span></span> ظرف زمان <span class="hlt"><span class="qpc-hafs">﴿وَقَبَ﴾</span></span> ماض فاعله مستتر والجملة في محل جر بالإضافة.</p></div>"
  113,4,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وَمِنْ شَرِّ النَّفَّاثاتِ﴾</span></span> معطوف على ما قبله <span class="hlt"><span class="qpc-hafs">﴿فِي الْعُقَدِ﴾</span></span> متعلقان بما قبلهما.</p></div>"
  113,5,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وَمِنْ شَرِّ حاسِدٍ﴾</span></span> معطوف على ما قبله <span class="hlt"><span class="qpc-hafs">﴿إِذا﴾</span></span> ظرف زمان <span class="hlt"><span class="qpc-hafs">﴿حَسَدَ﴾</span></span> ماض فاعله مستتر والجملة في محل جر بالإضافة.</p></div>"
  114,1,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قُلْ﴾</span></span> أمر فاعله مستتر والجملة ابتدائية لا محل لها <span class="hlt"><span class="qpc-hafs">﴿أَعُوذُ﴾</span></span> مضارع فاعله مستتر <span class="hlt"><span class="qpc-hafs">﴿بِرَبِّ﴾</span></span> متعلقان بالفعل <span class="hlt"><span class="qpc-hafs">﴿النَّاسِ﴾</span></span> مضاف إليه والجملة مقول القول.</p></div>"
  114,2,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿مَلِكِ﴾</span></span> بدل من رب <span class="hlt"><span class="qpc-hafs">﴿النَّاسِ﴾</span></span> مضاف إليه.</p></div>"
  114,3,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إِلهِ﴾</span></span> بدل من رب <span class="hlt"><span class="qpc-hafs">﴿النَّاسِ﴾</span></span> مضاف إليه.</p></div>"
  114,4,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿مِنْ شَرِّ﴾</span></span> الجار والمجرور متعلقان بأعوذ <span class="hlt"><span class="qpc-hafs">﴿الْوَسْواسِ﴾</span></span> مضاف إليه <span class="hlt"><span class="qpc-hafs">﴿الْخَنَّاسِ﴾</span></span> بدل من الوسواس.</p></div>"
  114,5,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿الَّذِي﴾</span></span> اسم موصول صفة الوسواس <span class="hlt"><span class="qpc-hafs">﴿يُوَسْوِسُ﴾</span></span> مضارع فاعله مستتر والجملة صلة <span class="hlt"><span class="qpc-hafs">﴿فِي صُدُورِ﴾</span></span> متعلقان بالفعل <span class="hlt"><span class="qpc-hafs">﴿النَّاسِ﴾</span></span> مضاف إليه.</p></div>"
  114,6,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿مِنَ الْجِنَّةِ﴾</span></span> الجار والمجرور متعلقان بمحذوف حال من فاعل يوسوس <span class="hlt"><span class="qpc-hafs">﴿وَالنَّاسِ﴾</span></span> معطوف على الجنة.</p><p>تم بعون الله تعالى هذا الكتاب والحمد لله رب العالمين.</p></div>"