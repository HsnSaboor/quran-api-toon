quran[32]{c,v,t}:
  86,1,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وَالسَّماءِ﴾</span></span> جار ومجرور متعلقان بفعل محذوف تقديره أقسم <span class="hlt"><span class="qpc-hafs">﴿وَالطَّارِقِ﴾</span></span> معطوف على السماء.</p></div>"
  86,2,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وَما﴾</span></span> الواو حرف عطف <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> اسم استفهام مبتدأ <span class="hlt"><span class="qpc-hafs">﴿أَدْراكَ﴾</span></span> ماض ومفعوله والفاعل مستتر والجملة الفعلية خبر المبتدأ وجملة ما أدراك.. معطوفة على ما قبلها <span class="hlt"><span class="qpc-hafs">﴿مَا الطَّارِقُ﴾</span></span> مبتدأ وخبره والجملة سدت مسد مفعول أدراك الثاني.</p></div>"
  86,3,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿النَّجْمُ﴾</span></span> خبر لمبتدأ محذوف تقديره هو <span class="hlt"><span class="qpc-hafs">﴿الثَّاقِبُ﴾</span></span> صفة والجملة الاسمية حال.</p></div>"
  86,4,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إِنْ﴾</span></span> حرف نفي <span class="hlt"><span class="qpc-hafs">﴿كُلُّ نَفْسٍ﴾</span></span> مبتدأ مضاف إلى نفس <span class="hlt"><span class="qpc-hafs">﴿لَمَّا﴾</span></span> حرف حصر <span class="hlt"><span class="qpc-hafs">﴿عَلَيْها حافِظٌ﴾</span></span> خبر مقدم ومبتدأ مؤخر والجملة الاسمية خبر كل وجملة إن.. جواب القسم لا محل لها.</p></div>"
  86,5,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فَلْيَنْظُرِ﴾</span></span> الفاء حرف استئناف ومضارع مجزوم بلام الأمر <span class="hlt"><span class="qpc-hafs">﴿الْإِنْسانُ﴾</span></span> فاعل والجملة مستأنفة <span class="hlt"><span class="qpc-hafs">﴿مِمَّ﴾</span></span> متعلقان بما بعدهما <span class="hlt"><span class="qpc-hafs">﴿خُلِقَ﴾</span></span> ماض مبني للمجهول ونائب الفاعل مستتر والجملة مفعول به.</p></div>"
  86,6,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿خُلِقَ﴾</span></span> ماض مبني للمجهول ونائب الفاعل مستتر <span class="hlt"><span class="qpc-hafs">﴿مِنْ ماءٍ﴾</span></span> متعلقان بالفعل <span class="hlt"><span class="qpc-hafs">﴿دافِقٍ﴾</span></span> صفة ماء والجملة مستأنفة.</p></div>"
  86,7,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿يَخْرُجُ﴾</span></span> مضارع فاعله مستتر والجملة صفة ثانية لماء <span class="hlt"><span class="qpc-hafs">﴿مِنْ بَيْنِ﴾</span></span> متعلقان بالفعل <span class="hlt"><span class="qpc-hafs">﴿الصُّلْبِ﴾</span></span> مضاف إليه <span class="hlt"><span class="qpc-hafs">﴿وَالتَّرائِبِ﴾</span></span> معطوف عليه.</p></div>"
  86,8,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إِنَّهُ﴾</span></span> إن واسمها <span class="hlt"><span class="qpc-hafs">﴿عَلى رَجْعِهِ﴾</span></span> متعلقان بما بعدهما <span class="hlt"><span class="qpc-hafs">﴿لَقادِرٌ﴾</span></span> اللام المزحلقة وقادر خبر إن والجملة الاسمية تعليلية لا محل لها.</p></div>"
  86,9,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿يَوْمَ﴾</span></span> ظرف زمان <span class="hlt"><span class="qpc-hafs">﴿تُبْلَى﴾</span></span> مضارع مبني للمجهول <span class="hlt"><span class="qpc-hafs">﴿السَّرائِرُ﴾</span></span> نائب فاعل، والجملة في محل جر بالإضافة.</p></div>"
  86,10,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فَما﴾</span></span> الفاء حرف عطف <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> نافية <span class="hlt"><span class="qpc-hafs">﴿لَهُ﴾</span></span> خبر مقدم <span class="hlt"><span class="qpc-hafs">﴿مِنْ﴾</span></span> حرف جر زائد <span class="hlt"><span class="qpc-hafs">﴿قُوَّةٍ﴾</span></span> مجرور لفظا مرفوع محلا مبتدأ مؤخر والجملة معطوفة على ما قبلها، <span class="hlt"><span class="qpc-hafs">﴿وَلا﴾</span></span> الواو حرف عطف <span class="hlt"><span class="qpc-hafs">﴿لا﴾</span></span> نافية <span class="hlt"><span class="qpc-hafs">﴿ناصِرٍ﴾</span></span> معطوف على ما قبله.</p></div>"
  86,11,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وَالسَّماءِ﴾</span></span> جار ومجرور متعلقان بفعل محذوف تقديره أقسم <span class="hlt"><span class="qpc-hafs">﴿ذاتِ﴾</span></span> صفة السماء <span class="hlt"><span class="qpc-hafs">﴿الرَّجْعِ﴾</span></span> مضاف إليه.</p></div>"
  86,12,"<div class=ar lang=ar><p>الجملة معطوفة على ما قبلها والإعراب واحد.</p></div>"
  86,13,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إِنَّهُ﴾</span></span> إن واسمها <span class="hlt"><span class="qpc-hafs">﴿لَقَوْلٌ﴾</span></span> اللام المزحلقة <span class="hlt"><span class="qpc-hafs">﴿قول﴾</span></span> خبرها <span class="hlt"><span class="qpc-hafs">﴿فَصْلٌ﴾</span></span> صفة والجملة جواب القسم لا محل لها.</p></div>"
  86,14,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وَما﴾</span></span> الواو حرف عطف <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> نافية حجازية تعمل عمل ليس <span class="hlt"><span class="qpc-hafs">﴿هُوَ﴾</span></span> اسمها <span class="hlt"><span class="qpc-hafs">﴿بِالْهَزْلِ﴾</span></span> الباء حرف جر زائد <span class="hlt"><span class="qpc-hafs">﴿الهزل﴾</span></span> مجرور لفظا منصوب محلا خبر ما والجملة معطوفة على ما قبلها.</p></div>"
  86,15,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إِنَّهُمْ﴾</span></span> إن واسمها <span class="hlt"><span class="qpc-hafs">﴿يَكِيدُونَ﴾</span></span> مضارع مرفوع والواو فاعله والجملة الفعلية خبر إن <span class="hlt"><span class="qpc-hafs">﴿كَيْداً﴾</span></span> مفعول مطلق والجملة الاسمية مستأنفة لا محل لها.</p></div>"
  86,16,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وَأَكِيدُ﴾</span></span> مضارع فاعله مستتر <span class="hlt"><span class="qpc-hafs">﴿كَيْداً﴾</span></span> مفعول مطلق والجملة معطوفة على ما قبلها.</p></div>"
  86,17,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فَمَهِّلِ﴾</span></span> الفاء الفصيحة وأمر فاعله مستتر <span class="hlt"><span class="qpc-hafs">﴿الْكافِرِينَ﴾</span></span> مفعول به والجملة جواب شرط لا محل لها <span class="hlt"><span class="qpc-hafs">﴿أَمْهِلْهُمْ﴾</span></span> أمر ومفعوله والفاعل مستتر <span class="hlt"><span class="qpc-hafs">﴿رُوَيْداً﴾</span></span> صفة مفعول مطلق محذوف والجملة توكيد لما قبلها.</p></div>"
  87,1,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿سَبِّحِ﴾</span></span> أمر فاعله مستتر <span class="hlt"><span class="qpc-hafs">﴿اسْمَ رَبِّكَ﴾</span></span> اسم مفعول به مضاف إلى ربك <span class="hlt"><span class="qpc-hafs">﴿الْأَعْلَى﴾</span></span> صفة ربك والجملة ابتدائية لا محل لها.</p></div>"
  87,2,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿الَّذِي﴾</span></span> صفة ثانية لربك <span class="hlt"><span class="qpc-hafs">﴿خَلَقَ﴾</span></span> ماض فاعله مستتر والجملة صلة <span class="hlt"><span class="qpc-hafs">﴿فَسَوَّى﴾</span></span> معطوف على خلق.</p></div>"
  87,3,"<div class=ar lang=ar><p>الجملة معطوفة على ما قبلها.</p></div>"
  87,4,"<div class=ar lang=ar><p>الجملة معطوفة على ما قبلها أيضا.</p></div>"
  87,5,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فَجَعَلَهُ﴾</span></span> ماض ومفعوله الأول والفاعل مستتر <span class="hlt"><span class="qpc-hafs">﴿غُثاءً﴾</span></span> مفعول به ثان <span class="hlt"><span class="qpc-hafs">﴿أَحْوى﴾</span></span> حال من المرعى والجملة معطوفة على ما قبلها.</p></div>"
  87,6,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿سَنُقْرِئُكَ﴾</span></span> السين للاستقبال ومضارع ومفعوله والفاعل مستتر والجملة مستأنفة <span class="hlt"><span class="qpc-hafs">﴿فَلا تَنْسى﴾</span></span> الفاء حرف تعليل ولا نافية ومضارع فاعله مستتر.</p></div>"
  87,7,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إِلَّا﴾</span></span> حرف استثناء <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> اسم موصول في محل نصب على الاستثناء <span class="hlt"><span class="qpc-hafs">﴿شاءَ اللَّهُ﴾</span></span> ماض ولفظ الجلالة فاعله والجملة صلة <span class="hlt"><span class="qpc-hafs">﴿إِنَّهُ﴾</span></span> إن واسمها <span class="hlt"><span class="qpc-hafs">﴿يَعْلَمُ﴾</span></span> مضارع فاعله مستتر <span class="hlt"><span class="qpc-hafs">﴿الْجَهْرَ﴾</span></span> مفعول به والجملة الفعلية خبر إن والجملة الاسمية تعليلية لا محل لها. <span class="hlt"><span class="qpc-hafs">﴿وَما﴾</span></span> اسم موصول معطوف على الجهر <span class="hlt"><span class="qpc-hafs">﴿يَخْفى﴾</span></span> مضارع فاعله مستتر والجملة صلة.</p></div>"
  87,8,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وَنُيَسِّرُكَ﴾</span></span> مضارع ومفعوله والفاعل مستتر <span class="hlt"><span class="qpc-hafs">﴿لِلْيُسْرى﴾</span></span> متعلقان بالفعل، والجملة معطوفة على ما قبلها.</p></div>"
  87,9,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فَذَكِّرْ﴾</span></span> الفاء الفصيحة وأمر فاعله مستتر والجملة جواب شرط مقدر لا محل لها <span class="hlt"><span class="qpc-hafs">﴿إِنْ﴾</span></span> حرف شرط جازم <span class="hlt"><span class="qpc-hafs">﴿نَفَعَتِ﴾</span></span> ماض في محل جزم فعل الشرط <span class="hlt"><span class="qpc-hafs">﴿الذِّكْرى﴾</span></span> فاعل والجملة ابتدائية لا محل لها.</p></div>"
  87,10,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿سَيَذَّكَّرُ﴾</span></span> السين للاستقبال ومضارع مرفوع <span class="hlt"><span class="qpc-hafs">﴿مَنْ﴾</span></span> اسم موصول فاعله والجملة مستأنفة <span class="hlt"><span class="qpc-hafs">﴿يَخْشى﴾</span></span> مضارع فاعله مستتر والجملة صلة.</p></div>"
  87,11,"<div class=ar lang=ar><p>َ يَتَجَنَّبُهَا»</p><p>مضارع ومفعوله لْأَشْقَى»</p><p>فاعل والجملة معطوفة على ما قبلها.</p></div>"
  87,12,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿الَّذِي﴾</span></span> اسم موصول صفة الأشقى <span class="hlt"><span class="qpc-hafs">﴿يَصْلَى﴾</span></span> مضارع فاعله مستتر <span class="hlt"><span class="qpc-hafs">﴿النَّارَ﴾</span></span> مفعول به <span class="hlt"><span class="qpc-hafs">﴿الْكُبْرى﴾</span></span> صفة النار والجملة صلة.</p></div>"
  87,13,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ثُمَّ﴾</span></span> حرف عطف <span class="hlt"><span class="qpc-hafs">﴿لا﴾</span></span> نافية <span class="hlt"><span class="qpc-hafs">﴿يَمُوتُ﴾</span></span> مضارع فاعله مستتر والجملة معطوفة على ما قبلها <span class="hlt"><span class="qpc-hafs">﴿فِيها﴾</span></span> متعلقان بالفعل <span class="hlt"><span class="qpc-hafs">﴿وَلا﴾</span></span> الواو حرف عطف <span class="hlt"><span class="qpc-hafs">﴿وَلا﴾</span></span> نافية <span class="hlt"><span class="qpc-hafs">﴿يَحْيى﴾</span></span> معطوف على يموت.</p></div>"
  87,14,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قَدْ﴾</span></span> حرف تحقيق <span class="hlt"><span class="qpc-hafs">﴿أَفْلَحَ﴾</span></span> ماض <span class="hlt"><span class="qpc-hafs">﴿مَنْ﴾</span></span> فاعله والجملة مستأنفة <span class="hlt"><span class="qpc-hafs">﴿تَزَكَّى﴾</span></span> ماض فاعله مستتر والجملة صلة.</p></div>"
  87,15,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وَذَكَرَ﴾</span></span> ماض فاعله مستتر <span class="hlt"><span class="qpc-hafs">﴿اسْمَ رَبِّهِ﴾</span></span> مفعول به مضاف إلى ربه والجملة معطوفة على ما قبلها <span class="hlt"><span class="qpc-hafs">﴿فَصَلَّى﴾</span></span> الفاء حرف عطف وصلى معطوف على ذكر.</p></div>"