quran[24]{c,v,t}:
  55,17,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿رَبُّ﴾</span></span> خبر لمبتدأ محذوف مضاف إلى المشرقين <span class="hlt"><span class="qpc-hafs">﴿الْمَشْرِقَيْنِ﴾</span></span> مضاف إليه <span class="hlt"><span class="qpc-hafs">﴿وَرَبُّ الْمَغْرِبَيْنِ﴾</span></span> معطوف على ما قبله والجملة استئنافية لا محل لها.</p></div>"
  55,18,"<div class=ar lang=ar><p>انظر الآية- 13-.</p></div>"
  55,19,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿مَرَجَ الْبَحْرَيْنِ﴾</span></span> ماض ومفعوله والفاعل مستتر والجملة استئنافية <span class="hlt"><span class="qpc-hafs">﴿يَلْتَقِيانِ﴾</span></span> مضارع مرفوع والألف فاعله والجملة حال.</p></div>"
  55,20,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿بَيْنَهُما بَرْزَخٌ﴾</span></span> خبر مقدم ومبتدأ مؤخر والجملة استئنافية لا محل لها <span class="hlt"><span class="qpc-hafs">﴿لا﴾</span></span> نافية و <span class="hlt"><span class="qpc-hafs">﴿يَبْغِيانِ﴾</span></span> مضارع مرفوع والألف فاعله والجملة حال.</p></div>"
  55,21,"<div class=ar lang=ar><p>انظر الآية- 13-.</p></div>"
  55,22,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿يَخْرُجُ﴾</span></span> مضارع مرفوع <span class="hlt"><span class="qpc-hafs">﴿مِنْهُمَا﴾</span></span> متعلقان بالفعل <span class="hlt"><span class="qpc-hafs">﴿اللُّؤْلُؤُ﴾</span></span> فاعل مرفوع <span class="hlt"><span class="qpc-hafs">﴿وَالْمَرْجانُ﴾</span></span> معطوف على اللؤلؤ والجملة استئنافية لا محل لها.</p></div>"
  55,23,"<div class=ar lang=ar><p>انظر الآية- 13-.</p></div>"
  55,24,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وَلَهُ﴾</span></span> خبر مقدم <span class="hlt"><span class="qpc-hafs">﴿الْجَوارِ﴾</span></span> مبتدأ مؤخر مرفوع بالضمة المقدرة على الياء المحذوفة والجملة الاسمية استئنافية لا محل لها <span class="hlt"><span class="qpc-hafs">﴿الْمُنْشَآتُ﴾</span></span> صفة الجوار <span class="hlt"><span class="qpc-hafs">﴿فِي الْبَحْرِ﴾</span></span> متعلقان بالمنشئات <span class="hlt"><span class="qpc-hafs">﴿كَالْأَعْلامِ﴾</span></span> متعلقان بمحذوف حال.</p></div>"
  55,25,"<div class=ar lang=ar><p>انظر الآية- 13-.</p></div>"
  55,26,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿كُلُّ مَنْ﴾</span></span> مبتدأ مضاف إلى اسم الموصول واسم الموصول مضاف إليه و <span class="hlt"><span class="qpc-hafs">﴿عَلَيْها﴾</span></span> متعلقان بمحذوف صلة الموصول <span class="hlt"><span class="qpc-hafs">﴿فانٍ﴾</span></span> خبر المبتدأ مرفوع بالضمة على الياء المحذوفة وهو اسم منقوص والجملة استئنافية لا محل لها.</p></div>"
  55,27,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وَيَبْقى وَجْهُ﴾</span></span> مضارع وفاعله <span class="hlt"><span class="qpc-hafs">﴿رَبِّكَ﴾</span></span> مضاف إليه <span class="hlt"><span class="qpc-hafs">﴿ذُو﴾</span></span> صفة وجه مضاف <span class="hlt"><span class="qpc-hafs">﴿الْجَلالِ﴾</span></span> مضاف إليه <span class="hlt"><span class="qpc-hafs">﴿وَالْإِكْرامِ﴾</span></span> معطوف على الجلال والجملة معطوفة على ما قبلها.</p></div>"
  55,28,"<div class=ar lang=ar><p>انظر الآية- 13-.</p></div>"
  55,29,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿يَسْئَلُهُ﴾</span></span> مضارع ومفعوله <span class="hlt"><span class="qpc-hafs">﴿مَنْ﴾</span></span> فاعله <span class="hlt"><span class="qpc-hafs">﴿فِي السَّماواتِ﴾</span></span> متعلقان بمحذوف صلة الموصول <span class="hlt"><span class="qpc-hafs">﴿وَالْأَرْضِ﴾</span></span> معطوف على السموات والجملة استئنافية لا محل لها. <span class="hlt"><span class="qpc-hafs">﴿كُلَّ﴾</span></span> ظرف مضاف <span class="hlt"><span class="qpc-hafs">﴿يَوْمٍ﴾</span></span> مضاف إليه <span class="hlt"><span class="qpc-hafs">﴿هُوَ﴾</span></span> مبتدأ <span class="hlt"><span class="qpc-hafs">﴿فِي شَأْنٍ﴾</span></span> خبر.</p></div>"
  55,30,"<div class=ar lang=ar><p>انظر الآية- 13-.</p></div>"
  55,31,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿سَنَفْرُغُ﴾</span></span> السين للاستقبال ومضارع فاعله مستتر والجملة استئنافية لا محل لها <span class="hlt"><span class="qpc-hafs">﴿لَكُمْ﴾</span></span> متعلقان بالفعل <span class="hlt"><span class="qpc-hafs">﴿أَيُّهَ﴾</span></span> منادى نكرة مقصودة <span class="hlt"><span class="qpc-hafs">﴿الثَّقَلانِ﴾</span></span> بدل وجملة النداء استئنافية لا محل لها.</p></div>"
  55,32,"<div class=ar lang=ar><p>انظر الآية- 13-.</p></div>"
  55,33,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿يا مَعْشَرَ﴾</span></span> منادى مضاف <span class="hlt"><span class="qpc-hafs">﴿الْجِنِّ﴾</span></span> مضاف إليه <span class="hlt"><span class="qpc-hafs">﴿وَالْإِنْسِ﴾</span></span> معطوف عليه والجملة استئنافية لا محل لها <span class="hlt"><span class="qpc-hafs">﴿إِنِ اسْتَطَعْتُمْ﴾</span></span> إن حرف شرط وماض في محل جزم فعل الشرط والتاء فاعله والجملة ابتدائية لا محل لها <span class="hlt"><span class="qpc-hafs">﴿أَنْ تَنْفُذُوا﴾</span></span> مضارع منصوب بأن وعلامة نصبه حذف النون والواو فاعله والمصدر المؤول من أن وما بعدها في محل نصب مفعول به لاستطعتم <span class="hlt"><span class="qpc-hafs">﴿مِنْ أَقْطارِ﴾</span></span> متعلقان بالفعل <span class="hlt"><span class="qpc-hafs">﴿السَّماواتِ﴾</span></span> مضاف إليه <span class="hlt"><span class="qpc-hafs">﴿وَالْأَرْضِ﴾</span></span> معطوف على السموات <span class="hlt"><span class="qpc-hafs">﴿فَانْفُذُوا﴾</span></span> الفاء واقعة في جواب الشرط وأمر وفاعله والجملة في محل جزم جواب الشرط <span class="hlt"><span class="qpc-hafs">﴿لا﴾</span></span> نافية <span class="hlt"><span class="qpc-hafs">﴿تَنْفُذُونَ﴾</span></span> مضارع مرفوع والواو فاعله والجملة استئنافية لا محل لها <span class="hlt"><span class="qpc-hafs">﴿إِلَّا﴾</span></span> حرف حصر <span class="hlt"><span class="qpc-hafs">﴿بِسُلْطانٍ﴾</span></span> متعلقان بالفعل.</p></div>"
  55,34,"<div class=ar lang=ar><p>سبق إعرابها.</p></div>"
  55,35,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿يُرْسَلُ﴾</span></span> مضارع مبني للمجهول <span class="hlt"><span class="qpc-hafs">﴿عَلَيْكُما﴾</span></span> متعلقان بالفعل <span class="hlt"><span class="qpc-hafs">﴿شُواظٌ﴾</span></span> نائب فاعل والجملة استئنافية لا محل لها <span class="hlt"><span class="qpc-hafs">﴿مِنْ نارٍ﴾</span></span> صفة شواظ <span class="hlt"><span class="qpc-hafs">﴿وَنُحاسٌ﴾</span></span> معطوف على شواظ <span class="hlt"><span class="qpc-hafs">﴿فَلا﴾</span></span> الفاء حرف عطف ولا نافية <span class="hlt"><span class="qpc-hafs">﴿تَنْتَصِرانِ﴾</span></span> مضارع مرفوع والألف فاعله والجملة معطوفة على ما قبلها.</p></div>"
  55,36,"<div class=ar lang=ar><p>سبق إعرابها.</p></div>"
  55,37,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فَإِذَا﴾</span></span> الفاء حرف استئناف وإذا ظرفية شرطية غير جازمة <span class="hlt"><span class="qpc-hafs">﴿انْشَقَّتِ السَّماءُ﴾</span></span> ماض وفاعله والجملة في محل جر بالإضافة <span class="hlt"><span class="qpc-hafs">﴿فَكانَتْ﴾</span></span> الفاء حرف عطف وماض ناقص اسمه مستتر <span class="hlt"><span class="qpc-hafs">﴿وَرْدَةً﴾</span></span> خبره والجملة معطوفة على ما قبلها <span class="hlt"><span class="qpc-hafs">﴿كَالدِّهانِ﴾</span></span> صفة وردة.</p></div>"
  55,38,"<div class=ar lang=ar><p>سبق إعرابها.</p></div>"
  55,39,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فَيَوْمَئِذٍ﴾</span></span> الفاء واقعة في جواب الشرط ويومئذ ظرف زمان مضاف إلى إذ <span class="hlt"><span class="qpc-hafs">﴿لا﴾</span></span> نافية <span class="hlt"><span class="qpc-hafs">﴿يُسْئَلُ﴾</span></span> مضارع مبني للمجهول <span class="hlt"><span class="qpc-hafs">﴿عَنْ ذَنْبِهِ﴾</span></span> متعلقان بالفعل <span class="hlt"><span class="qpc-hafs">﴿إِنْسٌ﴾</span></span> نائب فاعل والجملة الفعلية جواب الشرط <span class="hlt"><span class="qpc-hafs">﴿وَلا جَانٌّ﴾</span></span> معطوف على إنس.</p></div>"
  55,40,"<div class=ar lang=ar><p>سبق إعرابها.</p></div>"