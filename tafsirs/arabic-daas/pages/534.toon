quran[27]{c,v,t}:
  55,68,"

<q>﴿فِيهِما﴾</q> خبر مقدم <q>﴿فاكِهَةٌ﴾</q> مبتدأ مؤخر <q>﴿وَنَخْلٌ وَرُمَّانٌ﴾</q> معطوفان على ما قبلهما والجملة استئنافية لا محل لها.

"
  55,69,"

سبق إعرابها.

"
  55,70,"

<q>﴿فِيهِنَّ﴾</q> خبر مقدم <q>﴿خَيْراتٌ﴾</q> مبتدأ مؤخر <q>﴿حِسانٌ﴾</q> صفة خيرات والجملة استئنافية لا محل لها.

"
  55,71,"

سبق إعرابها.

"
  55,72,"

<q>﴿حُورٌ﴾</q> بدل من خيرات <q>﴿مَقْصُوراتٌ﴾</q> صفة حور <q>﴿فِي الْخِيامِ﴾</q> متعلقان بمقصورات والجملة استئنافية لا محل لها.

"
  55,73,"

تقدم إعرابها.

"
  55,74,"

انظر الآية- 56-.

"
  55,75,"

سبق إعرابها.

"
  55,76,"

<q>﴿مُتَّكِئِينَ﴾</q> حال <q>﴿عَلى رَفْرَفٍ﴾</q> متعلقان بما قبلهما <q>﴿خُضْرٍ﴾</q> صفة رفرف <q>﴿وَعَبْقَرِيٍّ﴾</q> معطوف على رفرف <q>﴿حِسانٍ﴾</q> صفة عبقري.

"
  55,77,"

سبق إعرابها.

"
  55,78,"

<q>﴿تَبارَكَ اسْمُ﴾</q> ماض وفاعله <q>﴿رَبِّكَ﴾</q> مضاف إليه <q>﴿ذِي﴾</q> صفة ربك مضاف <q>﴿الْجَلالِ﴾</q> مضاف إليه <q>﴿وَالْإِكْرامِ﴾</q> معطوف على الجلال والجملة استئنافية لا محل لها.

"
  56,1,"

<q>﴿إِذا﴾</q> ظرفية شرطية غير جازمة <q>﴿وَقَعَتِ الْواقِعَةُ﴾</q> ماض وفاعله والجملة في محل جر بالإضافة.

"
  56,2,"

<q>﴿لَيْسَ﴾</q> ماض ناقص <q>﴿لِوَقْعَتِها﴾</q> خبر ليس المقدم <q>﴿كاذِبَةٌ﴾</q> اسمها المؤخر والجملة جواب الشرط لا محل لها.

"
  56,3,"

<q>﴿خافِضَةٌ﴾</q> خبر لمبتدأ محذوف <q>﴿رافِعَةٌ﴾</q> خبر ثان والجملة حالية.

"
  56,4,"

<q>﴿إِذا﴾</q> بدل من سابقتها <q>﴿رُجَّتِ﴾</q> ماض مبني للمجهول <q>﴿الْأَرْضُ﴾</q> نائب فاعل <q>﴿رَجًّا﴾</q> مفعول مطلق والجملة في محل جر بالإضافة.

"
  56,5,"

إعرابها مثل سابقتها وهي معطوفة عليها.

"
  56,6,"

<q>﴿فَكانَتْ﴾</q> كان واسمها مستتر <q>﴿هَباءً﴾</q> خبرها <q>﴿مُنْبَثًّا﴾</q> صفة هباء والجملة معطوفة على ما قبلها.

"
  56,7,"

<q>﴿وَكُنْتُمْ﴾</q> كان واسمها <q>﴿أَزْواجاً﴾</q> خبرها <q>﴿ثَلاثَةً﴾</q> صفة أزواجا والجملة معطوفة على ما قبلها.

"
  56,8,"

<q>﴿فَأَصْحابُ﴾</q> الفاء حرف استئناف وأصحاب مبتدأ مضاف إلى الميمنة <q>﴿الْمَيْمَنَةِ﴾</q> مضاف إليه <q>﴿ما﴾</q> استفهامية مبتدأ ثان وأصحاب خبر ما مضاف <q>﴿الْمَيْمَنَةِ﴾</q> مضاف إليه والجملة خبر أصحاب وجملة أصحاب.. استئنافية لا محل لها.

"
  56,9,"

إعرابها مثل سابقتها وهي معطوفة عليها.

"
  56,10,"

مبتدأ وخبره والجملة معطوفة على ما قبلها.

"
  56,11,"

<q>﴿أُولئِكَ الْمُقَرَّبُونَ﴾</q> مبتدأ وخبر والجملة خبر ثان للسابقون.

"
  56,12,"

<q>﴿فِي جَنَّاتِ﴾</q> خبر ثان لأولئك <q>﴿النَّعِيمِ﴾</q> مضاف إليه.

"
  56,13,"

<q>﴿ثُلَّةٌ﴾</q> خبر لمبتدأ محذوف <q>﴿مِنَ الْأَوَّلِينَ﴾</q> صفة ثلة.

"
  56,14,"

<q>﴿وَقَلِيلٌ﴾</q> معطوف على ثلة <q>﴿مِنَ الْآخِرِينَ﴾</q> متعلقان بقليل.

"
  56,15,"

<q>﴿عَلى سُرُرٍ﴾</q> صفة ثانية لثلة <q>﴿مَوْضُونَةٍ﴾</q> صفة سرر.

"
  56,16,"

<q>﴿مُتَّكِئِينَ﴾</q> حال و <q>﴿عَلَيْها﴾</q> متعلقان بما قبلهما <q>﴿مُتَقابِلِينَ﴾</q> حال ثانية.

"
