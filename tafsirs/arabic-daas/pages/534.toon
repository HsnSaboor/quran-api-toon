quran[27]{c,v,t}:
  55,68,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فِيهِما﴾</span></span> خبر مقدم <span class="hlt"><span class="qpc-hafs">﴿فاكِهَةٌ﴾</span></span> مبتدأ مؤخر <span class="hlt"><span class="qpc-hafs">﴿وَنَخْلٌ وَرُمَّانٌ﴾</span></span> معطوفان على ما قبلهما والجملة استئنافية لا محل لها.</p></div>"
  55,69,"<div class=ar lang=ar><p>سبق إعرابها.</p></div>"
  55,70,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فِيهِنَّ﴾</span></span> خبر مقدم <span class="hlt"><span class="qpc-hafs">﴿خَيْراتٌ﴾</span></span> مبتدأ مؤخر <span class="hlt"><span class="qpc-hafs">﴿حِسانٌ﴾</span></span> صفة خيرات والجملة استئنافية لا محل لها.</p></div>"
  55,71,"<div class=ar lang=ar><p>سبق إعرابها.</p></div>"
  55,72,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿حُورٌ﴾</span></span> بدل من خيرات <span class="hlt"><span class="qpc-hafs">﴿مَقْصُوراتٌ﴾</span></span> صفة حور <span class="hlt"><span class="qpc-hafs">﴿فِي الْخِيامِ﴾</span></span> متعلقان بمقصورات والجملة استئنافية لا محل لها.</p></div>"
  55,73,"<div class=ar lang=ar><p>تقدم إعرابها.</p></div>"
  55,74,"<div class=ar lang=ar><p>انظر الآية- 56-.</p></div>"
  55,75,"<div class=ar lang=ar><p>سبق إعرابها.</p></div>"
  55,76,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿مُتَّكِئِينَ﴾</span></span> حال <span class="hlt"><span class="qpc-hafs">﴿عَلى رَفْرَفٍ﴾</span></span> متعلقان بما قبلهما <span class="hlt"><span class="qpc-hafs">﴿خُضْرٍ﴾</span></span> صفة رفرف <span class="hlt"><span class="qpc-hafs">﴿وَعَبْقَرِيٍّ﴾</span></span> معطوف على رفرف <span class="hlt"><span class="qpc-hafs">﴿حِسانٍ﴾</span></span> صفة عبقري.</p></div>"
  55,77,"<div class=ar lang=ar><p>سبق إعرابها.</p></div>"
  55,78,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿تَبارَكَ اسْمُ﴾</span></span> ماض وفاعله <span class="hlt"><span class="qpc-hafs">﴿رَبِّكَ﴾</span></span> مضاف إليه <span class="hlt"><span class="qpc-hafs">﴿ذِي﴾</span></span> صفة ربك مضاف <span class="hlt"><span class="qpc-hafs">﴿الْجَلالِ﴾</span></span> مضاف إليه <span class="hlt"><span class="qpc-hafs">﴿وَالْإِكْرامِ﴾</span></span> معطوف على الجلال والجملة استئنافية لا محل لها.</p></div>"
  56,1,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إِذا﴾</span></span> ظرفية شرطية غير جازمة <span class="hlt"><span class="qpc-hafs">﴿وَقَعَتِ الْواقِعَةُ﴾</span></span> ماض وفاعله والجملة في محل جر بالإضافة.</p></div>"
  56,2,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿لَيْسَ﴾</span></span> ماض ناقص <span class="hlt"><span class="qpc-hafs">﴿لِوَقْعَتِها﴾</span></span> خبر ليس المقدم <span class="hlt"><span class="qpc-hafs">﴿كاذِبَةٌ﴾</span></span> اسمها المؤخر والجملة جواب الشرط لا محل لها.</p></div>"
  56,3,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿خافِضَةٌ﴾</span></span> خبر لمبتدأ محذوف <span class="hlt"><span class="qpc-hafs">﴿رافِعَةٌ﴾</span></span> خبر ثان والجملة حالية.</p></div>"
  56,4,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إِذا﴾</span></span> بدل من سابقتها <span class="hlt"><span class="qpc-hafs">﴿رُجَّتِ﴾</span></span> ماض مبني للمجهول <span class="hlt"><span class="qpc-hafs">﴿الْأَرْضُ﴾</span></span> نائب فاعل <span class="hlt"><span class="qpc-hafs">﴿رَجًّا﴾</span></span> مفعول مطلق والجملة في محل جر بالإضافة.</p></div>"
  56,5,"<div class=ar lang=ar><p>إعرابها مثل سابقتها وهي معطوفة عليها.</p></div>"
  56,6,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فَكانَتْ﴾</span></span> كان واسمها مستتر <span class="hlt"><span class="qpc-hafs">﴿هَباءً﴾</span></span> خبرها <span class="hlt"><span class="qpc-hafs">﴿مُنْبَثًّا﴾</span></span> صفة هباء والجملة معطوفة على ما قبلها.</p></div>"
  56,7,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وَكُنْتُمْ﴾</span></span> كان واسمها <span class="hlt"><span class="qpc-hafs">﴿أَزْواجاً﴾</span></span> خبرها <span class="hlt"><span class="qpc-hafs">﴿ثَلاثَةً﴾</span></span> صفة أزواجا والجملة معطوفة على ما قبلها.</p></div>"
  56,8,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فَأَصْحابُ﴾</span></span> الفاء حرف استئناف وأصحاب مبتدأ مضاف إلى الميمنة <span class="hlt"><span class="qpc-hafs">﴿الْمَيْمَنَةِ﴾</span></span> مضاف إليه <span class="hlt"><span class="qpc-hafs">﴿ما﴾</span></span> استفهامية مبتدأ ثان وأصحاب خبر ما مضاف <span class="hlt"><span class="qpc-hafs">﴿الْمَيْمَنَةِ﴾</span></span> مضاف إليه والجملة خبر أصحاب وجملة أصحاب.. استئنافية لا محل لها.</p></div>"
  56,9,"<div class=ar lang=ar><p>إعرابها مثل سابقتها وهي معطوفة عليها.</p></div>"
  56,10,"<div class=ar lang=ar><p>مبتدأ وخبره والجملة معطوفة على ما قبلها.</p></div>"
  56,11,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿أُولئِكَ الْمُقَرَّبُونَ﴾</span></span> مبتدأ وخبر والجملة خبر ثان للسابقون.</p></div>"
  56,12,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فِي جَنَّاتِ﴾</span></span> خبر ثان لأولئك <span class="hlt"><span class="qpc-hafs">﴿النَّعِيمِ﴾</span></span> مضاف إليه.</p></div>"
  56,13,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ثُلَّةٌ﴾</span></span> خبر لمبتدأ محذوف <span class="hlt"><span class="qpc-hafs">﴿مِنَ الْأَوَّلِينَ﴾</span></span> صفة ثلة.</p></div>"
  56,14,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وَقَلِيلٌ﴾</span></span> معطوف على ثلة <span class="hlt"><span class="qpc-hafs">﴿مِنَ الْآخِرِينَ﴾</span></span> متعلقان بقليل.</p></div>"
  56,15,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿عَلى سُرُرٍ﴾</span></span> صفة ثانية لثلة <span class="hlt"><span class="qpc-hafs">﴿مَوْضُونَةٍ﴾</span></span> صفة سرر.</p></div>"
  56,16,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿مُتَّكِئِينَ﴾</span></span> حال و <span class="hlt"><span class="qpc-hafs">﴿عَلَيْها﴾</span></span> متعلقان بما قبلهما <span class="hlt"><span class="qpc-hafs">﴿مُتَقابِلِينَ﴾</span></span> حال ثانية.</p></div>"