quran[34]{c,v,t}:
  56,17,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿يَطُوفُ﴾</span></span> مضارع <span class="hlt"><span class="qpc-hafs">﴿عَلَيْهِمْ﴾</span></span> متعلقان بالفعل <span class="hlt"><span class="qpc-hafs">﴿وِلْدانٌ﴾</span></span> فاعل <span class="hlt"><span class="qpc-hafs">﴿مُخَلَّدُونَ﴾</span></span> صفة والجملة حال.</p></div>"
  56,18,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿بِأَكْوابٍ﴾</span></span> متعلقان بيطوف <span class="hlt"><span class="qpc-hafs">﴿وَأَبارِيقَ﴾</span></span> معطوف على أكواب <span class="hlt"><span class="qpc-hafs">﴿وَكَأْسٍ﴾</span></span> معطوف على ما قبله <span class="hlt"><span class="qpc-hafs">﴿مِنْ مَعِينٍ﴾</span></span> صفة كأس.</p></div>"
  56,19,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿لا﴾</span></span> نافية <span class="hlt"><span class="qpc-hafs">﴿يُصَدَّعُونَ﴾</span></span> مضارع مبني للمجهول مرفوع والواو نائب فاعل <span class="hlt"><span class="qpc-hafs">﴿عَنْها﴾</span></span> متعلقان بالفعل والجملة حالية <span class="hlt"><span class="qpc-hafs">﴿وَلا﴾</span></span> نافية <span class="hlt"><span class="qpc-hafs">﴿يُنْزِفُونَ﴾</span></span> مضارع مرفوع والواو فاعله والجملة معطوفة على ما قبلها.</p></div>"
  56,20,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وَفاكِهَةٍ﴾</span></span> معطوف على ما قبله <span class="hlt"><span class="qpc-hafs">﴿مِمَّا﴾</span></span> صفة فاكهة <span class="hlt"><span class="qpc-hafs">﴿يَتَخَيَّرُونَ﴾</span></span> مضارع مرفوع والواو فاعله والجملة صلة ما.</p></div>"
  56,21,"<div class=ar lang=ar><p>الآية معطوفة على ما قبلها.</p></div>"
  56,22,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وَحُورٌ﴾</span></span> معطوف على ولدان <span class="hlt"><span class="qpc-hafs">﴿عِينٌ﴾</span></span> صفة حور.</p></div>"
  56,23,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿كَأَمْثالِ﴾</span></span> صفة ثانية لحور <span class="hlt"><span class="qpc-hafs">﴿اللُّؤْلُؤِ﴾</span></span> مضاف إليه <span class="hlt"><span class="qpc-hafs">﴿الْمَكْنُونِ﴾</span></span> صفة اللؤلؤ.</p></div>"
  56,24,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿جَزاءً﴾</span></span> مفعول لأجله <span class="hlt"><span class="qpc-hafs">﴿بِما﴾</span></span> متعلقان بجزاء <span class="hlt"><span class="qpc-hafs">﴿كانُوا﴾</span></span> كان واسمها والجملة صلة ما <span class="hlt"><span class="qpc-hafs">﴿يَعْمَلُونَ﴾</span></span> مضارع مرفوع والواو فاعله والجملة خبر كانوا.</p></div>"
  56,25,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿لا﴾</span></span> نافية <span class="hlt"><span class="qpc-hafs">﴿يَسْمَعُونَ﴾</span></span> مضارع مرفوع والواو فاعله والجملة حال <span class="hlt"><span class="qpc-hafs">﴿فِيها﴾</span></span> متعلقان بالفعل <span class="hlt"><span class="qpc-hafs">﴿لَغْواً﴾</span></span> مفعول به <span class="hlt"><span class="qpc-hafs">﴿وَلا﴾</span></span> الواو حرف عطف ولا نافية <span class="hlt"><span class="qpc-hafs">﴿تَأْثِيماً﴾</span></span> معطوف على لغوا.</p></div>"
  56,26,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إِلَّا﴾</span></span> أداة استثناء <span class="hlt"><span class="qpc-hafs">﴿قِيلًا﴾</span></span> مستثنى بإلا منصوب <span class="hlt"><span class="qpc-hafs">﴿سَلاماً﴾</span></span> بدل من قيلا <span class="hlt"><span class="qpc-hafs">﴿سَلاماً﴾</span></span> توكيد.</p></div>"
  56,27,"<div class=ar lang=ar><p>مماثل لإعراب الآية رقم- 8-.</p></div>"
  56,28,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فِي سِدْرٍ﴾</span></span> خبر ثان لأصحاب <span class="hlt"><span class="qpc-hafs">﴿مَخْضُودٍ﴾</span></span> صفة سدر.</p></div>"
  56,29,"<div class=ar lang=ar><p>معطوف على ما قبله.</p></div>"
  56,30,"56:29"
  56,31,"56:29"
  56,32,"56:29"
  56,33,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿لا﴾</span></span> نافية <span class="hlt"><span class="qpc-hafs">﴿مَقْطُوعَةٍ﴾</span></span> صفة ثانية لفاكهة <span class="hlt"><span class="qpc-hafs">﴿وَلا﴾</span></span> الواو حرف عطف ولا نافية <span class="hlt"><span class="qpc-hafs">﴿مَمْنُوعَةٍ﴾</span></span> معطوف على مقطوعة.</p></div>"
  56,34,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فُرُشٍ﴾</span></span> معطوف على ما قبله <span class="hlt"><span class="qpc-hafs">﴿مَرْفُوعَةٍ﴾</span></span> صفة فرش.</p></div>"
  56,35,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إِنَّا﴾</span></span> إن واسمها <span class="hlt"><span class="qpc-hafs">﴿أَنْشَأْناهُنَّ﴾</span></span> ماض وفاعله ومفعوله والجملة خبر إن <span class="hlt"><span class="qpc-hafs">﴿إِنْشاءً﴾</span></span> مفعول مطلق والجملة الاسمية استئنافية لا محل لها.</p></div>"
  56,36,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فَجَعَلْناهُنَّ﴾</span></span> ماض وفاعله ومفعوله الأول <span class="hlt"><span class="qpc-hafs">﴿أَبْكاراً﴾</span></span> مفعوله الثاني والجملة معطوفة على ما قبلها.</p></div>"
  56,37,"<div class=ar lang=ar><p>صفتان لأبكارا.</p></div>"
  56,38,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿لِأَصْحابِ﴾</span></span> جار ومجرور متعلقان بجعلناهن <span class="hlt"><span class="qpc-hafs">﴿الْيَمِينِ﴾</span></span> مضاف إليه.</p></div>"
  56,39,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿ثُلَّةٌ﴾</span></span> خبر لمبتدأ محذوف <span class="hlt"><span class="qpc-hafs">﴿مِنَ الْأَوَّلِينَ﴾</span></span> صفة ثلة والجملة صفة أصحاب.</p></div>"
  56,40,"<div class=ar lang=ar><p>معطوف على ما قبله.</p></div>"
  56,41,"<div class=ar lang=ar><p>سبق إعراب نظيرها في الآية- 8-.</p></div>"
  56,42,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿فِي سَمُومٍ﴾</span></span> خبر ثان لأصحاب الشمال <span class="hlt"><span class="qpc-hafs">﴿وَحَمِيمٍ﴾</span></span> معطوف على سموم.</p></div>"
  56,43,"<div class=ar lang=ar><p>معطوف على ما قبله.</p></div>"
  56,44,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿لا﴾</span></span> نافية <span class="hlt"><span class="qpc-hafs">﴿بارِدٍ﴾</span></span> صفة ظل <span class="hlt"><span class="qpc-hafs">﴿وَلا كَرِيمٍ﴾</span></span> معطوف على ما قبله.</p></div>"
  56,45,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿إِنَّهُمْ﴾</span></span> إن واسمها <span class="hlt"><span class="qpc-hafs">﴿كانُوا﴾</span></span> كان واسمها <span class="hlt"><span class="qpc-hafs">﴿قَبْلَ﴾</span></span> ظرف زمان <span class="hlt"><span class="qpc-hafs">﴿ذلِكَ﴾</span></span> مضاف إليه <span class="hlt"><span class="qpc-hafs">﴿مُتْرَفِينَ﴾</span></span> خبر كانوا وجملة كانوا.. خبر إنهم والجملة الاسمية تعليل.</p></div>"
  56,46,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وَكانُوا﴾</span></span> كان واسمها <span class="hlt"><span class="qpc-hafs">﴿يُصِرُّونَ﴾</span></span> مضارع مرفوع والواو فاعله والجملة خبر كانوا <span class="hlt"><span class="qpc-hafs">﴿عَلَى الْحِنْثِ﴾</span></span> متعلقان بالفعل <span class="hlt"><span class="qpc-hafs">﴿الْعَظِيمِ﴾</span></span> صفة الحنث وجملة كانوا.. معطوفة على ما قبلها.</p></div>"
  56,47,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿وَكانُوا﴾</span></span> كان واسمها <span class="hlt"><span class="qpc-hafs">﴿يَقُولُونَ﴾</span></span> مضارع مرفوع والواو فاعله والجملة خبر كانوا وجملة كانوا..</p><p>معطوفة على ما قبلها <span class="hlt"><span class="qpc-hafs">﴿أَإِذا﴾</span></span> الهمزة حرف استفهام وإذا ظرفية شرطية غير جازمة <span class="hlt"><span class="qpc-hafs">﴿مِتْنا﴾</span></span> ماض وفاعله والجملة في محل جر بالإضافة <span class="hlt"><span class="qpc-hafs">﴿وَكُنَّا﴾</span></span> كان واسمها <span class="hlt"><span class="qpc-hafs">﴿تُراباً﴾</span></span> خبرها والجملة معطوفة على ما قبلها <span class="hlt"><span class="qpc-hafs">﴿وَعِظاماً﴾</span></span> معطوف على ترابا <span class="hlt"><span class="qpc-hafs">﴿أَإِنَّا﴾</span></span> الهمزة حرف استفهام وإن واسمها <span class="hlt"><span class="qpc-hafs">﴿لَمَبْعُوثُونَ﴾</span></span> اللام المزحلقة ومبعوثون خبرها والجملة الاسمية مؤكدة لما قبلها.</p></div>"
  56,48,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿أَوَآباؤُنَا﴾</span></span> الهمزة حرف استفهام والواو حرف عطف وآباؤنا معطوف على ضمير مستتر في لمبعوثون <span class="hlt"><span class="qpc-hafs">﴿الْأَوَّلُونَ﴾</span></span> صفة.</p></div>"
  56,49,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿قُلْ﴾</span></span> أمر فاعله مستتر <span class="hlt"><span class="qpc-hafs">﴿إِنَّ الْأَوَّلِينَ﴾</span></span> إن واسمها <span class="hlt"><span class="qpc-hafs">﴿وَالْآخِرِينَ﴾</span></span> معطوف على الأولين.</p></div>"
  56,50,"<div class=ar lang=ar><p><span class="hlt"><span class="qpc-hafs">﴿لَمَجْمُوعُونَ﴾</span></span> اللام المزحلقة ومجموعون خبر إن مرفوع بالواو والجملة الاسمية مقول القول وجملة قل.. استئنافية لا محل لها <span class="hlt"><span class="qpc-hafs">﴿إِلى مِيقاتِ﴾</span></span> متعلقان بمجموعون <span class="hlt"><span class="qpc-hafs">﴿يَوْمٍ﴾</span></span> مضاف إليه <span class="hlt"><span class="qpc-hafs">﴿مَعْلُومٍ﴾</span></span> صفة يوم.</p></div>"