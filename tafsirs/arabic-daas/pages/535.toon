quran[34]{c,v,t}:
  56,17,"

<q>﴿يَطُوفُ﴾</q> مضارع <q>﴿عَلَيْهِمْ﴾</q> متعلقان بالفعل <q>﴿وِلْدانٌ﴾</q> فاعل <q>﴿مُخَلَّدُونَ﴾</q> صفة والجملة حال.

"
  56,18,"

<q>﴿بِأَكْوابٍ﴾</q> متعلقان بيطوف <q>﴿وَأَبارِيقَ﴾</q> معطوف على أكواب <q>﴿وَكَأْسٍ﴾</q> معطوف على ما قبله <q>﴿مِنْ مَعِينٍ﴾</q> صفة كأس.

"
  56,19,"

<q>﴿لا﴾</q> نافية <q>﴿يُصَدَّعُونَ﴾</q> مضارع مبني للمجهول مرفوع والواو نائب فاعل <q>﴿عَنْها﴾</q> متعلقان بالفعل والجملة حالية <q>﴿وَلا﴾</q> نافية <q>﴿يُنْزِفُونَ﴾</q> مضارع مرفوع والواو فاعله والجملة معطوفة على ما قبلها.

"
  56,20,"

<q>﴿وَفاكِهَةٍ﴾</q> معطوف على ما قبله <q>﴿مِمَّا﴾</q> صفة فاكهة <q>﴿يَتَخَيَّرُونَ﴾</q> مضارع مرفوع والواو فاعله والجملة صلة ما.

"
  56,21,"

الآية معطوفة على ما قبلها.

"
  56,22,"

<q>﴿وَحُورٌ﴾</q> معطوف على ولدان <q>﴿عِينٌ﴾</q> صفة حور.

"
  56,23,"

<q>﴿كَأَمْثالِ﴾</q> صفة ثانية لحور <q>﴿اللُّؤْلُؤِ﴾</q> مضاف إليه <q>﴿الْمَكْنُونِ﴾</q> صفة اللؤلؤ.

"
  56,24,"

<q>﴿جَزاءً﴾</q> مفعول لأجله <q>﴿بِما﴾</q> متعلقان بجزاء <q>﴿كانُوا﴾</q> كان واسمها والجملة صلة ما <q>﴿يَعْمَلُونَ﴾</q> مضارع مرفوع والواو فاعله والجملة خبر كانوا.

"
  56,25,"

<q>﴿لا﴾</q> نافية <q>﴿يَسْمَعُونَ﴾</q> مضارع مرفوع والواو فاعله والجملة حال <q>﴿فِيها﴾</q> متعلقان بالفعل <q>﴿لَغْواً﴾</q> مفعول به <q>﴿وَلا﴾</q> الواو حرف عطف ولا نافية <q>﴿تَأْثِيماً﴾</q> معطوف على لغوا.

"
  56,26,"

<q>﴿إِلَّا﴾</q> أداة استثناء <q>﴿قِيلًا﴾</q> مستثنى بإلا منصوب <q>﴿سَلاماً﴾</q> بدل من قيلا <q>﴿سَلاماً﴾</q> توكيد.

"
  56,27,"

مماثل لإعراب الآية رقم- 8-.

"
  56,28,"

<q>﴿فِي سِدْرٍ﴾</q> خبر ثان لأصحاب <q>﴿مَخْضُودٍ﴾</q> صفة سدر.

"
  56,29,"

معطوف على ما قبله.

"
  56,30,"56:29"
  56,31,"56:29"
  56,32,"56:29"
  56,33,"

<q>﴿لا﴾</q> نافية <q>﴿مَقْطُوعَةٍ﴾</q> صفة ثانية لفاكهة <q>﴿وَلا﴾</q> الواو حرف عطف ولا نافية <q>﴿مَمْنُوعَةٍ﴾</q> معطوف على مقطوعة.

"
  56,34,"

<q>﴿فُرُشٍ﴾</q> معطوف على ما قبله <q>﴿مَرْفُوعَةٍ﴾</q> صفة فرش.

"
  56,35,"

<q>﴿إِنَّا﴾</q> إن واسمها <q>﴿أَنْشَأْناهُنَّ﴾</q> ماض وفاعله ومفعوله والجملة خبر إن <q>﴿إِنْشاءً﴾</q> مفعول مطلق والجملة الاسمية استئنافية لا محل لها.

"
  56,36,"

<q>﴿فَجَعَلْناهُنَّ﴾</q> ماض وفاعله ومفعوله الأول <q>﴿أَبْكاراً﴾</q> مفعوله الثاني والجملة معطوفة على ما قبلها.

"
  56,37,"

صفتان لأبكارا.

"
  56,38,"

<q>﴿لِأَصْحابِ﴾</q> جار ومجرور متعلقان بجعلناهن <q>﴿الْيَمِينِ﴾</q> مضاف إليه.

"
  56,39,"

<q>﴿ثُلَّةٌ﴾</q> خبر لمبتدأ محذوف <q>﴿مِنَ الْأَوَّلِينَ﴾</q> صفة ثلة والجملة صفة أصحاب.

"
  56,40,"

معطوف على ما قبله.

"
  56,41,"

سبق إعراب نظيرها في الآية- 8-.

"
  56,42,"

<q>﴿فِي سَمُومٍ﴾</q> خبر ثان لأصحاب الشمال <q>﴿وَحَمِيمٍ﴾</q> معطوف على سموم.

"
  56,43,"

معطوف على ما قبله.

"
  56,44,"

<q>﴿لا﴾</q> نافية <q>﴿بارِدٍ﴾</q> صفة ظل <q>﴿وَلا كَرِيمٍ﴾</q> معطوف على ما قبله.

"
  56,45,"

<q>﴿إِنَّهُمْ﴾</q> إن واسمها <q>﴿كانُوا﴾</q> كان واسمها <q>﴿قَبْلَ﴾</q> ظرف زمان <q>﴿ذلِكَ﴾</q> مضاف إليه <q>﴿مُتْرَفِينَ﴾</q> خبر كانوا وجملة كانوا.. خبر إنهم والجملة الاسمية تعليل.

"
  56,46,"

<q>﴿وَكانُوا﴾</q> كان واسمها <q>﴿يُصِرُّونَ﴾</q> مضارع مرفوع والواو فاعله والجملة خبر كانوا <q>﴿عَلَى الْحِنْثِ﴾</q> متعلقان بالفعل <q>﴿الْعَظِيمِ﴾</q> صفة الحنث وجملة كانوا.. معطوفة على ما قبلها.

"
  56,47,"

<q>﴿وَكانُوا﴾</q> كان واسمها <q>﴿يَقُولُونَ﴾</q> مضارع مرفوع والواو فاعله والجملة خبر كانوا وجملة كانوا..

معطوفة على ما قبلها <q>﴿أَإِذا﴾</q> الهمزة حرف استفهام وإذا ظرفية شرطية غير جازمة <q>﴿مِتْنا﴾</q> ماض وفاعله والجملة في محل جر بالإضافة <q>﴿وَكُنَّا﴾</q> كان واسمها <q>﴿تُراباً﴾</q> خبرها والجملة معطوفة على ما قبلها <q>﴿وَعِظاماً﴾</q> معطوف على ترابا <q>﴿أَإِنَّا﴾</q> الهمزة حرف استفهام وإن واسمها <q>﴿لَمَبْعُوثُونَ﴾</q> اللام المزحلقة ومبعوثون خبرها والجملة الاسمية مؤكدة لما قبلها.

"
  56,48,"

<q>﴿أَوَآباؤُنَا﴾</q> الهمزة حرف استفهام والواو حرف عطف وآباؤنا معطوف على ضمير مستتر في لمبعوثون <q>﴿الْأَوَّلُونَ﴾</q> صفة.

"
  56,49,"

<q>﴿قُلْ﴾</q> أمر فاعله مستتر <q>﴿إِنَّ الْأَوَّلِينَ﴾</q> إن واسمها <q>﴿وَالْآخِرِينَ﴾</q> معطوف على الأولين.

"
  56,50,"

<q>﴿لَمَجْمُوعُونَ﴾</q> اللام المزحلقة ومجموعون خبر إن مرفوع بالواو والجملة الاسمية مقول القول وجملة قل.. استئنافية لا محل لها <q>﴿إِلى مِيقاتِ﴾</q> متعلقان بمجموعون <q>﴿يَوْمٍ﴾</q> مضاف إليه <q>﴿مَعْلُومٍ﴾</q> صفة يوم.

"
