quran[13]{c,v,t}:
  43,61,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَإِنَّهُ لَعِلْمٌ لِّلسَّاعَةِ﴾</span> الضمير لعيسى وقيل لمحمد ﷺ وقيل للقرآن، فأما على القول بأنه لعيسى أو لمحمد فالمعنى أنه شرط من أشراط الساعة، يوجب العلم بها فسمى الشرط علماً لحصول العلم به، ولذلك قرأ ابن عباس لعَلَم بفتح العين واللام: أي علامة وأما على القول بأنه للقرآن: فالمعنى أنه يعلمكم بالساعة.</p></div>"
  43,62,"<div class=ar lang=ar></div>"
  43,63,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَلأُبَيِّنَ لَكُم بَعْضَ ٱلَّذِي تَخْتَلِفُونَ فِيهِ فَٱتَّقُواْ﴾</span> إنما بيّن البعض دون الكل، لأن الأنبياء إنما يبينون أمور الدين لا الدنيا، وقيل: بعض بمعنى كل هذا ضعيف.</p></div>"
  43,64,"<div class=ar lang=ar></div>"
  43,65,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَٱخْتَلَفَ ٱلأَحْزَابُ﴾</span> ذكر في مريم <span class="qpc-hafs">﴿هَلْ يَنظُرُونَ إِلاَّ ٱلسَّاعَةَ﴾</span> أي ينتظرون، والضمير لقريش أو للأحزاب <span class="qpc-hafs">﴿ٱلأَخِلاَّءُ يَوْمَئِذٍ بَعْضُهُمْ لِبَعْضٍ عَدُوٌّ إِلاَّ ٱلْمُتَّقِينَ﴾</span> <span class="qpc-hafs">﴿ٱلأَخِلاَّءُ﴾</span>: جمع خليل وهو الصديق، وإنما يعادي الخليل خليلَه يومَ القيامة، لأن الضرر دخل عليه من صحبته، ولذلك استثنى المتقين، لأن النفع دخل على بعضهم من بعض <span class="qpc-hafs">﴿يٰعِبَادِ لاَ﴾</span> الآية. تقديره: يقول الله يوم القيامة للمتقين يا عبادي، لا خوف عليكم اليوم ولا أنتم تحزنون.</p></div>"
  43,66,"43:65"
  43,67,"43:65"
  43,68,"43:65"
  43,69,"<div class=ar lang=ar></div>"
  43,70,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿تُحْبَرُونَ﴾</span> أي تنعمون وتسرون.</p></div>"
  43,71,"<div class=ar lang=ar></div>"
  43,72,"43:71"
  43,73,"43:71"