quran[24]{c,v,t}:
  53,45,"<div class=ar lang=ar></div>"
  53,46,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿مِن نُّطْفَةٍ﴾</span> يعني المني <span class="qpc-hafs">﴿إِذَا تُمْنَىٰ﴾</span> من قولك: أمنى الرجل إذا خرج منه المنيّ <span class="qpc-hafs">﴿ٱلنَّشْأَةَ ٱلأُخْرَىٰ﴾</span> يعني الإعادة للحشر <span class="qpc-hafs">﴿وَأَقْنَىٰ﴾</span> يعني أكسب عباده المال، وهو من قنية المال وهو كسبه وإدخاره وقيل: معنى <span class="qpc-hafs">﴿أَقْنَىٰ﴾</span>: أفقر وهذا لا تقتضيه اللغة، وقيل: معناه أرضى وقيل: قنع عبده <span class="qpc-hafs">﴿ٱلشِّعْرَىٰ﴾</span> نجم في السماء، وتسمى كلب الجبار وهما شعريان وهما: الغميصاء والعبور. وخصها بالذكر دون سائر النجوم لأن بعض العرب كان يعبدها.</p></div>"
  53,47,"53:46"
  53,48,"53:46"
  53,49,"53:46"
  53,50,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿عَاداً ٱلأُولَىٰ﴾</span> وصفها بالأولى لأنها كانت في قديم الزمان، فهي الأولى بالإضافة إلى الأمم المتأخرة، وقيل: إنما سميت أولى لأن ثم عاداً أخرى متأخرة وهذا لا يصح، وقرأ نافع عادَ لولى بإدغام تنوين عاد في لام الأولى بحذف الهمزة، ونقل حركتها إلى اللام وضعّف المزني والمبرد هذه القراءة وهَمَزَ قالون الأولى دون وَرْشَ وقرأ الباقون على الأصل بكسر تنوين عادا وإسكان لام الأولى <span class="qpc-hafs">﴿وَثَمُودَ فَمَآ أَبْقَىٰ﴾</span> أي ما أبقى منهم أحداً، وقيل: ما أبقى عليهم: <span class="qpc-hafs">﴿وَٱلْمُؤْتَفِكَةَ أَهْوَىٰ * فَغَشَّاهَا مَا غَشَّىٰ﴾</span> هي مدينة قوم لوط، ومعنى أهوى طرحها من علو إلى أسفل، وفي قوله: ما غشى تعظيم للأمر.</p></div>"
  53,51,"53:50"
  53,52,"53:50"
  53,53,"53:50"
  53,54,"53:50"
  53,55,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَبِأَيِّ آلاۤءِ رَبِّكَ تَتَمَارَىٰ﴾</span> هذا مخاطبة للإنسان على الاطلاق معناه: بأي نعم ربك تشك.</p></div>"
  53,56,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿هَـٰذَا نَذِيرٌ مِّنَ ٱلنُّذُرِ ٱلأُوْلَىٰ﴾</span> يعني القرآن أو النبي ﷺ، ومعنى من النذر الأولى من نوعها وصفتها.</p></div>"
  53,57,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَزِفَتِ ٱلآزِفَةُ﴾</span> أي قربت القيامة.</p></div>"
  53,58,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿كَاشِفَةٌ﴾</span> يحتمل لفظه ثلاثة أوجه: أن يكون مصدراً كالعافية، أي ليس لها كشف وأن يكون بمعنى كاشف والتاء للمبالغة كعلامة، وأن يكون صفة لمحذوف تقديره: نفس كاشفة أو جماعة كاشفة ويحتمل معناه وجهين: أحدهما أن يكون من الكشف بمعنى: الإزالة أي ليس لها من يزيلها إذا وقعت والآخر أن يكون بمعنى الاطلاع؛ أي ليس لها من يعلم وقتها إلا الله.</p></div>"
  53,59,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿أَفَمِنْ هَـٰذَا ٱلْحَدِيثِ تَعْجَبُونَ﴾</span> الإشارة إلى القرآن وتعجبهم منه إنكاره.</p></div>"
  53,60,"<div class=ar lang=ar></div>"
  53,61,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَأَنتُمْ سَامِدُونَ﴾</span> أي لاعبون لاهون، وقيل: غافلون مفرطون.</p></div>"
  53,62,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَٱسْجُدُواْ لِلَّهِ وَٱعْبُدُواْ﴾</span> هذا موضع سجدة عند الشافعي وغيره، وقد قال ابن مسعود قرأها رسول الله ﷺ فسجد وسجد كل من كان معه.</p></div>"
  54,1,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿ٱقْتَرَبَتِ ٱلسَّاعَةُ﴾</span> أي قربت القيامة، ومعنى قربها أنها بقي لها من الزمان [شيء] قليل بالنسبة إلى ما مضى، ولذلك قال رسول الله ﷺ: بعثت أنا والساعة كهاتين، وأشار بالسبابة والوسطى.</p><p><span class="qpc-hafs">﴿وَٱنشَقَّ ٱلْقَمَرُ﴾</span> هذا إخبار بما جرى في زمان رسول الله ﷺ، وذلك أن قريشاً سألته آية فأراهم انشقاق القمر. فقال ﷺ: اشهدوا، وقال ابن مسعود: انشق القمر فرأيته فرقتين فرقة وراء الجبل وأخرى دونه، وقيل: معنى انشق القمر أنه ينشق يوم القيامة، وهذا قول باطل تردّه الأحاديث الصحيحة الواردة بانشقاق القمر، وقد اتفقت الأمة على وقوع ذلك على تفسير الآية بذلك إلا من لا يعتبر قوله: <span class="qpc-hafs">﴿وَإِن يَرَوْاْ آيَةً يُعْرِضُواْ وَيَقُولُواْ سِحْرٌ مُّسْتَمِرٌّ﴾</span> هذه الضمائر لقريش والآية المشار إليها انشقاق القمر وعند ذلك قالت قريش: سحر محمد القمر ومعنى مستمر: دائم ـ وقيل: معناه ذاهب يزول عن قريب ـ وقيل: شديد وهو على هذا المعنى من المرة وهي القوة: <span class="qpc-hafs">﴿وَكُلُّ أَمْرٍ مُّسْتَقِرٌّ﴾</span> أي كل شيء لا بد له من غاية، فالحق يحق والباطل يبطل.</p></div>"
  54,2,"54:1"
  54,3,"54:1"
  54,4,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَلَقَدْ جَآءَهُم مِّنَ ٱلأَنبَآءِ مَا فِيهِ مُزْدَجَرٌ﴾</span> الأنباء هنا، يراد بها ما ورد في القرآن من القصص والبراهين والمواعظ، ومزدجر اسم مصدر بمعنى الازدجار أو اسم موضع بمعنى أنه مظنة أن يزدجر به.</p></div>"
  54,5,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿حِكْمَةٌ بَالِغَةٌ﴾</span> بدل من ما فيه أو خبر ابتداء مضمر <span class="qpc-hafs">﴿فَمَا تُغْنِ ٱلنُّذُرُ﴾</span> يحتمل أن تكون ما نافية أو استفهامية لمعنى الاستبعاد والإنكار.</p></div>"
  54,6,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَتَوَلَّ عَنْهُمْ﴾</span> أي أعرض عنهم لعلمك أن الإنذار لا ينفعهم.</p><p><span class="qpc-hafs">﴿يَوْمَ يَدْعُ ٱلدَّاعِ إِلَىٰ شَيْءٍ نُّكُرٍ﴾</span> العامل في يوم مضمر تقديره: اذكر أو قوله: <span class="qpc-hafs">﴿يَخْرُجُونَ﴾</span> بعد ذلك، وليس العامل فيه <span class="qpc-hafs">﴿تَوَلَّ عَنْهُمْ﴾</span> فيوقف عليه وقيل: المعنى <span class="qpc-hafs">﴿تَوَلَّ عَنْهُمْ﴾</span> أي يوم يدع الداع والأول أظهر وأشهر. والداعي جبريل أو إسرافيل إذ ينفخ في الصور، والشيء النكر الشديد الفظيع. وأصله من الإنكار. أي: هو منكور لأنه لم ير قط مثله، والمراد به يوم القيامة <span class="qpc-hafs">﴿خُشَّعاً أَبْصَارُهُمْ﴾</span> كناية عن الذلة وانتصب خشعاً على الحال من الضمير في <span class="qpc-hafs">﴿يَخْرُجُونَ﴾</span> <span class="qpc-hafs">﴿يَخْرُجُونَ مِنَ ٱلأَجْدَاثِ﴾</span> أي من القبور <span class="qpc-hafs">﴿كَأَنَّهُمْ جَرَادٌ مُّنتَشِرٌ﴾</span> شبَّههم بالجراد في خروجهم من الأرض، فكأنه استدلال على البعث كالاستدلال بخروج النبات. وقيل: إنما شبههم بالجراد في كثرتهم، وأن بعضهم يموج في بعض.</p></div>"