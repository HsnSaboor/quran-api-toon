quran[26]{c,v,t}:
  37,77,"[ <span class="arabic uthmani">وَجَعَلْنَا ذُرِّيَّتَهُ هُمُ الْبَاقِينَ (٧٧)</span> ] وه‌ نه‌وه‌كانیمان هێشته‌وه‌ ئه‌وانه‌ی كه‌ باوه‌ڕیان پێی هێنابوو له‌ناو كه‌شتیه‌كه‌دا ئه‌وان مانه‌وه‌ به‌ڵام خێزان و منداڵی خۆی ئه‌وانه‌ی كه‌ كافر بوون نقوم بوون."
  37,78,"[ <span class="arabic uthmani">وَتَرَكْنَا عَلَيْهِ فِي الْآخِرِينَ (٧٨)</span> ] وه‌ تا ڕۆژی قیامه‌تیش نه‌وه‌یان مایه‌وه‌، یان به‌ باشه‌ باس ده‌كرێت."
  37,79,"[ <span class="arabic uthmani">سَلَامٌ عَلَى نُوحٍ فِي الْعَالَمِينَ (٧٩)</span> ] هه‌موو ئوممه‌تان له‌ هه‌موو جیهاندا سڵاو له‌ نوح - <span class="saw">صلی الله علیه وسلم</span> - ده‌كه‌ن."
  37,80,"[ <span class="arabic uthmani">إِنَّا كَذَلِكَ نَجْزِي الْمُحْسِنِينَ (٨٠)</span> ] ئێمه‌ به‌م شێوازه‌ پاداشتی چاكه‌كاران ئه‌ده‌ینه‌وه‌ كه‌ له‌ پاش خۆیشى به‌ چاكه‌ باس ده‌كرێت."
  37,81,"[ <span class="arabic uthmani">إِنَّهُ مِنْ عِبَادِنَا الْمُؤْمِنِينَ (٨١)</span> ] كه‌ نوحیش - <span class="saw">صلی الله علیه وسلم</span> - له‌ به‌نده‌ باوه‌ڕداره‌ یه‌كخواپه‌رسته‌كانی ئێمه‌ بوو."
  37,82,"[ <span class="arabic uthmani">ثُمَّ أَغْرَقْنَا الْآخَرِينَ (٨٢)</span> ] پاشان ئه‌وانه‌ی تر كه‌ ئیمانیان پێ نه‌هێنابوو هه‌موومان نوقم كردن له‌ناو ئاوه‌كه‌دا وه‌ له‌ناومان بردن."
  37,83,"{به‌سه‌رهاتى ئیبراهیم پێغه‌مبه‌ر - <span class="saw">صلی الله علیه وسلم</span> - و قه‌ومه‌كه‌ى}
 [ <span class="arabic uthmani">وَإِنَّ مِنْ شِيعَتِهِ لَإِبْرَاهِيمَ (٨٣)</span> ] وه‌ ئیبراهیمش - <span class="saw">صلی الله علیه وسلم</span> - له‌سه‌ر دین و په‌یڕه‌و و رێبازه‌كه‌ی نوح - <span class="saw">صلی الله علیه وسلم</span> - بووه‌ له‌ ته‌وحیدو یه‌كخواپه‌رستی و ئیمان هێنان و كرده‌وه‌ى چاك."
  37,84,"[ <span class="arabic uthmani">إِذْ جَاءَ رَبَّهُ بِقَلْبٍ سَلِيمٍ (٨٤)</span> ] كاتێك هات بۆ لای په‌روه‌ردگاری به‌ دڵێكی ساغ و سه‌لیمه‌وه‌ كه‌ پڕ بوو له‌ (لا إله إلا الله) و یه‌قین، وه‌ پارێزراو بووه‌ له‌ شیرك و گومان، وه‌ له‌به‌ر خوا ئامۆژگاری خه‌ڵكی كردووه‌."
  37,85,"[ <span class="arabic uthmani">إِذْ قَالَ لِأَبِيهِ وَقَوْمِهِ مَاذَا تَعْبُدُونَ (٨٥)</span> ] كاتێك كه‌ به‌رهه‌ڵستى له‌ باوكی و قه‌ومه‌كه‌ی كرد كه‌ بت په‌رست بوون پێى وتن: ئایا ئێوه‌ عیباده‌ت بۆ چ شتێك ئه‌كه‌ن و چ شتێك ئه‌په‌رستن."
  37,86,"[ <span class="arabic uthmani">أَئِفْكًا آلِهَةً دُونَ اللَّهِ تُرِيدُونَ (٨٦)</span> ] ئایا جگه‌ له‌ زاتی پیرۆزی (الله) درۆتان هه‌ڵبه‌ستووه‌و عیباده‌ت بۆ جگه‌ له‌ خواى گه‌وره‌ ئه‌كه‌ن."
  37,87,"[ <span class="arabic uthmani">فَمَا ظَنُّكُمْ بِرَبِّ الْعَالَمِينَ (٨٧)</span> ] ئه‌ی ئێوه‌ گومانتان چیه‌ به‌ په‌روه‌ردگارى هه‌موو جیهان كاتێك رووبه‌ڕووی ببنه‌وه‌ چیتان به‌سه‌ر بێنێ كه‌ ئێوه‌ عیباده‌تی جگه‌ له‌و ئه‌كه‌ن، واته‌: چاوه‌ڕوانى سزاى سه‌خت و هه‌میشه‌یى ئاگرى دۆزه‌خ بن."
  37,88,"[ <span class="arabic uthmani">فَنَظَرَ نَظْرَةً فِي النُّجُومِ (٨٨)</span> ] تێڕوانینێك ته‌ماشای ئه‌ستێره‌كانی كردو بیرى كرده‌وه‌."
  37,89,"[ <span class="arabic uthmani">فَقَالَ إِنِّي سَقِيمٌ (٨٩)</span> ] كاتێك ئه‌وان جه‌ژنیان هه‌بوو وتیان ئه‌چینه‌ ده‌ره‌وه‌ى شار بۆ ئاهه‌نگ گێڕان تۆیش له‌گه‌ڵماندا وه‌ره‌، ئیبراهیم - <span class="saw">صلی الله علیه وسلم</span> - وتی: من نه‌خۆشم، یاخود نه‌خۆشی تاعونم هه‌یه‌ بۆ ئه‌وه‌ى ئه‌وان وازى لێبێنن و له‌ ترسى تووش بوون لێى دوور بكه‌ونه‌وه‌، یاخود واته‌: من لاوازم، یاخود مه‌به‌ستى نه‌خۆشى مردن بوو له‌ داهاتوودا، یاخود دڵم نه‌خۆشه‌ له‌و بتانه‌ى كه‌ ئێوه‌ ده‌یانپه‌رستن، پێغه‌مبه‌ر - <span class="saw">صلی الله علیه وسلم</span> - ده‌فه‌رمێت: (ئیبراهیم - <span class="saw">صلی الله علیه وسلم</span> - ته‌نها سێ جار ناڕاستى وتووه‌: دووانیان له‌به‌ر خوا بوو كه‌ وتى: نه‌خۆشم، وه‌ بته‌كانى شكاند وتى: بته‌ گه‌وره‌كه‌ شكاندوونى، وه‌ جارێكیش بۆ پاراستنى ساره‌ى خێزانى بوو له‌ ده‌ستى پاشاكه‌ كه‌ وتى: خوشكمه‌) و مه‌به‌ستى خوشكى دینى بوو"
  37,90,"[ <span class="arabic uthmani">فَتَوَلَّوْا عَنْهُ مُدْبِرِينَ (٩٠)</span> ] بۆیه‌ ئه‌وانیش وازیان لێ هێناو پشتیان تێكردو ڕۆیشتن بۆ چه‌ژن و ئاهه‌نگ گێڕانیان."
  37,91,"[ <span class="arabic uthmani">فَرَاغَ إِلَى آلِهَتِهِمْ</span> ] كاتێك كه‌ كه‌س دیار نه‌ما ئه‌میش به‌ خێرایى و نهێنى ڕۆیشت بۆ لای خواكانیان [ <span class="arabic uthmani">فَقَالَ أَلَا تَأْكُلُونَ (٩١)</span> ] خواردنێكی زۆریان بۆ دانرابوو ئه‌میش وه‌كو گاڵته‌پێكردن و سووكایه‌تی پێكردن پێی وتن ئایا ئێوه‌ له‌م خواردنانه‌ ناخۆن؟"
  37,92,"[ <span class="arabic uthmani">مَا لَكُمْ لَا تَنْطِقُونَ (٩٢)</span> ] ئه‌وه‌ چیتانه‌ بۆ قسه‌ ناكه‌ن؟"
  37,93,"{ئیبراهیم پێغه‌مبه‌ر - <span class="saw">صلی الله علیه وسلم</span> - بته‌كان ده‌شكێنێت}
 [ <span class="arabic uthmani">فَرَاغَ عَلَيْهِمْ ضَرْبًا بِالْيَمِينِ (٩٣)</span> ] به‌ ده‌ستی ڕاستی له‌به‌ر ئه‌وه‌ی به‌هێزتره‌ لێی دان و كه‌وته‌ شكاندنی بته‌كان."
  37,94,"[ <span class="arabic uthmani">فَأَقْبَلُوا إِلَيْهِ يَزِفُّونَ (٩٤)</span> ] دوای ئه‌وه‌ی كه‌ گه‌ڕانه‌وه‌و زانیان چی كردووه‌ به‌ بته‌كانیان به‌خێرایی هاتن بۆ لای (له‌ سووره‌تى ئه‌نبیاء ئه‌م چیرۆكه‌ به‌ درێژتر باسكراوه‌)."
  37,95,"[ <span class="arabic uthmani">قَالَ أَتَعْبُدُونَ مَا تَنْحِتُونَ (٩٥)</span> ] ئه‌میش پێی وتن ئایا ئێوه‌ عیباده‌ت بۆ هه‌ندێك بت ئه‌كه‌ن كه‌ به‌ ده‌ستی خۆتان هه‌ڵیئه‌كۆڵن و دایئه‌تاشن."
  37,96,"[ <span class="arabic uthmani">وَاللَّهُ خَلَقَكُمْ وَمَا تَعْمَلُونَ (٩٦)</span> ] له‌ كاتێكدا خوای گه‌وره‌ ئێوه‌و كرده‌وه‌كانیشی دروست كردوون، له‌به‌ر ئه‌وه‌ی هه‌ر خوای گه‌وره‌ دروستكاره."
  37,97,"{هه‌وڵى سوتاندنى ئیبراهیم پێغه‌مبه‌ر - <span class="saw">صلی الله علیه وسلم</span> - ده‌درێت}
 [ <span class="arabic uthmani">قَالُوا ابْنُوا لَهُ بُنْيَانًا فَأَلْقُوهُ فِي الْجَحِيمِ (٩٧)</span> ] ئه‌وانیش وتیان: خانوو خه‌نده‌قێكى گه‌وره‌ی بۆ دروست بكه‌ن وه‌ ئاگرێكی گه‌وره‌ی تیا بكه‌نه‌وه‌ وه‌ له‌ دووره‌وه‌ هه‌ڵی بده‌نه‌ ناویه‌وه‌ له‌به‌ر ئه‌وه‌ی ئاگره‌كه‌ یه‌كجار گه‌وره‌ بوو نه‌یانئه‌توانی لێی نزیك ببنه‌وه‌و هه‌ڵی بده‌نه‌ ناوی، بۆیه‌ له‌ دووره‌وه‌ به‌ مه‌نجه‌نیق هه‌ڵیاندایه‌ ناوى"
  37,98,"[ <span class="arabic uthmani">فَأَرَادُوا بِهِ كَيْدًا فَجَعَلْنَاهُمُ الْأَسْفَلِينَ (٩٨)</span> ] ئه‌وان نه‌خشه‌و پیلانیان دانا به‌ڵام ئێمه‌ ئه‌وانمان ژێر خست و هیچیان بۆ نه‌كرا، وه‌ ئاگره‌كه‌ ساردو سه‌لامه‌ت بوو ئیبراهیم - <span class="saw">صلی الله علیه وسلم</span> - لێی هاته‌ ده‌ره‌وه‌."
  37,99,"[ <span class="arabic uthmani">وَقَالَ إِنِّي ذَاهِبٌ إِلَى رَبِّي سَيَهْدِينِ (٩٩)</span> ] وه‌ وتی: من ئه‌ڕۆم كۆچ ئه‌كه‌م بۆ لای په‌روه‌ردگار به‌ڵكو خوای گه‌وره‌ هیدایه‌تم بدات و ڕێنماییم بكات له‌ شوێنێك بتوانم عیباده‌تی بكه‌م."
  37,100,"[ <span class="arabic uthmani">رَبِّ هَبْ لِي مِنَ الصَّالِحِينَ (١٠٠)</span> ] ئه‌ی په‌روه‌ردگار له‌ جیاتى هۆزو نه‌ته‌وه‌كه‌م كه‌ به‌جێم هێشتن منداڵی صاڵحم پێ ببه‌خشه‌ یارمه‌تیده‌رم بێت له‌سه‌ر گوێڕایه‌ڵى و عیباده‌تى تۆ."
  37,101,"[ <span class="arabic uthmani">فَبَشَّرْنَاهُ بِغُلَامٍ حَلِيمٍ (١٠١)</span> ] منداڵێكمان پێی به‌خشی كه‌ ئیسماعیل - <span class="saw">صلی الله علیه وسلم</span> - بوو كه‌ دواتر منداڵێكی حه‌لیم و هێمن و ئارام و له‌سه‌رخۆ بوو، ئارامى گرت و رازى بوو كه‌ باوكى سه‌ری ببڕێت، وه‌ یه‌كه‌م منداڵى بوو، وه‌ له‌ ئیسحاق - <span class="saw">صلی الله علیه وسلم</span> - گه‌وره‌تر بوو."
  37,102,"{ئیبراهیم پێغه‌مبه‌ر - <span class="saw">صلی الله علیه وسلم</span> - له‌ خه‌ودا ئیسماعیلى كوڕى - <span class="saw">صلی الله علیه وسلم</span> - سه‌رده‌بڕێت}
 [ <span class="arabic uthmani">فَلَمَّا بَلَغَ مَعَهُ السَّعْيَ قَالَ يَا بُنَيَّ إِنِّي أَرَى فِي الْمَنَامِ أَنِّي أَذْبَحُكَ فَانْظُرْ مَاذَا تَرَى</span> ] كاتێك كه‌ ئیسماعیل - <span class="saw">صلی الله علیه وسلم</span> - پێ گه‌یشت وه‌ له‌گه‌ڵیدا ئه‌هات و ئه‌ڕۆیشت ئیبراهیم - <span class="saw">صلی الله علیه وسلم</span> - وتی: ئه‌ی كوڕی خۆم من له‌ خه‌ودا ئه‌بینم كه‌ سه‌رت ئه‌بڕم تۆیش ته‌ماشا بكه‌ بزانه‌ بۆچوونت چیه‌و وه‌ڵامت چیه‌؟ (له‌به‌ر ئه‌وه‌ی خه‌وی پێغه‌مبه‌ران وه‌حیه‌و له‌لایه‌ن خوای گه‌وره‌وه‌یه‌) [ <span class="arabic uthmani">قَالَ يَا أَبَتِ افْعَلْ مَا تُؤْمَرُ</span> ] ئه‌ویش به‌ بێ دوودڵى فه‌رمووی: ئه‌ی باوكی خۆم ئه‌وه‌ی فه‌رمانت پێكراوه‌ له‌لایه‌ن خوای گه‌وره‌وه‌ جێبه‌جێی بكه‌ [ <span class="arabic uthmani">سَتَجِدُنِي إِنْ شَاءَ اللَّهُ مِنَ الصَّابِرِينَ (١٠٢)</span> ] (إن شاء الله) ئه‌بینی من له‌ ئارامگرانم و ئارام ئه‌گرم له‌سه‌ر فه‌رمانی خوای گه‌وره‌و سه‌رم ببڕه‌."