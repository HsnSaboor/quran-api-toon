quran[28]{c,v,t}:
  26,84,"[ <span class="arabic uthmani">وَاجْعَلْ لِي لِسَانَ صِدْقٍ فِي الْآخِرِينَ (٨٤)</span> ] وه‌ زمانێكی ڕاستگۆم پێ ببه‌خشه‌ له‌ دونیادا كه‌ ئه‌وانه‌ی دوای خۆم دێن به‌ باشه‌ باسم بكه‌ن و له‌ چاكه‌دا شوێنم بكه‌ون."
  26,85,"[ <span class="arabic uthmani">وَاجْعَلْنِي مِنْ وَرَثَةِ جَنَّةِ النَّعِيمِ (٨٥)</span> ] وه‌ له‌ قیامه‌تدا بمكه‌ به‌ میراتگری به‌هه‌شتێك كه‌ پڕ له‌ نازو نیعمه‌ته‌."
  26,86,"[ <span class="arabic uthmani">وَاغْفِرْ لِأَبِي</span> ] وه‌ له‌ باوكم خۆشبه‌ [ <span class="arabic uthmani">إِنَّهُ كَانَ مِنَ الضَّالِّينَ (٨٦)</span> ] له‌به‌ر ئه‌وه‌ی كه‌سێكی گومڕا بووه‌، سه‌ره‌تا نه‌یزانی كه‌ باوكی له‌سه‌ر كوفر ئه‌مرێ، به‌ڵام دواتر كه‌ زانی باوكی دوژمنی خوای گه‌وره‌یه‌ له‌م شته‌ په‌شیمان بووه‌وه‌و به‌ڕائه‌تی لێ كرد، (دروست نیه‌ داواى لێخۆشبوون بۆ كافران و موشریكان بكرێت ئه‌گه‌ر دایك و باوكیش بن)."
  26,87,"[ <span class="arabic uthmani">وَلَا تُخْزِنِي يَوْمَ يُبْعَثُونَ (٨٧)</span> ] ئه‌ی په‌روه‌ردگار ئابڕووم مه‌به‌و سه‌رشۆڕم مه‌كه‌ له‌ ڕۆژی قیامه‌تدا كه‌ خه‌ڵكی زیندوو ئه‌كه‌یته‌وه‌، واته‌: له‌پێش چاوم باوكم مه‌خه‌ره‌ ئاگری دۆزه‌خه‌وه‌، پێغه‌مبه‌رى خوا - <span class="saw">صلی الله علیه وسلم</span> -  ده‌فه‌رمێت: (له‌ رۆژى قیامه‌ت ئیبراهیم - <span class="saw">صلی الله علیه وسلم</span> -  باوكى ده‌بینێت رووى ره‌ش و ته‌پوتۆزاویه‌و ده‌فه‌رمووێت: ئه‌ى باوكه‌ نه‌مووت سه‌رپێچیم مه‌كه‌و شوێنم بكه‌وه‌، ئه‌ویش ده‌ڵێت: ئه‌مڕۆ سه‌رپێچیت ناكه‌م، ئیبراهیم - <span class="saw">صلی الله علیه وسلم</span> -  ده‌فه‌رمووێت: ئه‌ى په‌روه‌ردگار تۆ به‌ڵێنت پێدام كه‌ سه‌رشۆڕم نه‌كه‌یت له‌ رۆژى قیامه‌ت، چ سه‌رشۆڕییه‌ك له‌مه‌ خراپتره‌ كه‌ باوكم بخه‌یته‌ ناو ئاگرى دۆزه‌خ؟ خواى گه‌وره‌ ده‌فه‌رمێت: من به‌هه‌شتم له‌ كافران حه‌رام كردووه‌، پاشان خوای گه‌وره‌ باوكی ئه‌كاته‌ كه‌متیارێكى نێرو فڕێ ئه‌درێته‌ دۆزه‌خه‌وه‌)، وه‌كو له‌ بوخاری و موسلیمدا هاتووه‌."
  26,88,"[ <span class="arabic uthmani">يَوْمَ لَا يَنْفَعُ مَالٌ وَلَا بَنُونَ (٨٨)</span> ] له‌ ڕۆژێك كه‌ رۆژى قیامه‌ته‌ هیچ شتێك سوودی نیه‌ نه‌ ماڵ و سه‌روه‌ت و سامان نه‌ منداڵ سوود به‌ هیچ كه‌سێك ناگه‌یه‌نێت و له‌ سزاى خواى گه‌وره‌ رزگارى ناكات."
  26,89,"[ <span class="arabic uthmani">إِلَّا مَنْ أَتَى اللَّهَ بِقَلْبٍ سَلِيمٍ (٨٩)</span> ] ئیلا ئه‌گه‌ر كه‌سێك بگاته‌ خوای گه‌وره‌ به‌ دڵێكی پاكه‌وه‌ كه‌ پڕ بێت له‌ ته‌وحیدو سوننه‌ت دوور بێت له‌ شیرك و بیدعه‌، وه‌ دڵێك پاك بێت له‌ تاوان و سه‌رپێچى كه‌ دڵی مرۆڤی ئیمانداره‌."
  26,90,"[ <span class="arabic uthmani">وَأُزْلِفَتِ الْجَنَّةُ لِلْمُتَّقِينَ (٩٠)</span> ] وه‌ به‌هه‌شت نزیك ئه‌كرێته‌وه‌و ده‌ڕازێنرێته‌وه‌ بۆ ئه‌و كه‌سانه‌ی كه‌ ته‌قوای خوای گه‌وره‌یان كردووه‌."
  26,91,"[ <span class="arabic uthmani">وَبُرِّزَتِ الْجَحِيمُ لِلْغَاوِينَ (٩١)</span> ] وه‌ دۆزه‌خیش ده‌ر ئه‌كه‌وێت بۆ ئه‌و كه‌سانه‌ی كه‌ گومڕاو خراپه‌كار بوونه‌."
  26,92,"[ <span class="arabic uthmani">وَقِيلَ لَهُمْ أَيْنَ مَا كُنْتُمْ تَعْبُدُونَ (٩٢)</span> ] وه‌ پێیان ئه‌ووترێ ئێوه‌ چیتان ئه‌په‌رست له‌ دونیا؟"
  26,93,"[ <span class="arabic uthmani">مِنْ دُونِ اللَّهِ</span> ] جگه‌ له‌ خوای گه‌وره‌ [ <span class="arabic uthmani">هَلْ يَنْصُرُونَكُمْ أَوْ يَنْتَصِرُونَ (٩٣)</span> ] ئایا ئه‌وانه‌ توانایان هه‌یه‌ ئێوه‌ سه‌ربخه‌ن؟ یان ئه‌توانن خۆیان سه‌ربخه‌ن؟"
  26,94,"[ <span class="arabic uthmani">فَكُبْكِبُوا فِيهَا هُمْ وَالْغَاوُونَ (٩٤)</span> ] هه‌موویان فڕێ ئه‌درێنه‌ دۆزه‌خه‌وه‌ په‌رستراو و په‌رسته‌ر."
  26,95,"[ <span class="arabic uthmani">وَجُنُودُ إِبْلِيسَ أَجْمَعُونَ (٩٥)</span> ] وه‌ سه‌ربازانی ئیبلیسیش به‌ جن و مرۆڤه‌وه‌ هه‌موویان فڕێ ئه‌درێنه‌ ئاگری دۆزه‌خه‌وه‌."
  26,96,"{مشتومڕی نێوان سەركردەكان‌و شوێنكەوتوانیان لەناو ئاگری دۆزەخ}
 [ <span class="arabic uthmani">قَالُوا وَهُمْ فِيهَا يَخْتَصِمُونَ (٩٦)</span> ] ئه‌وان هه‌موویان له‌ناو دۆزه‌خدا ده‌مه‌قاڵێ ئه‌كه‌ن و ئه‌ڵێن:"
  26,97,"[ <span class="arabic uthmani">تَاللَّهِ إِنْ كُنَّا لَفِي ضَلَالٍ مُبِينٍ (٩٧)</span> ] ژێرده‌سته‌كان به‌ سه‌ركرده‌و گه‌وره‌كانیان ئه‌ڵێن: سوێند به‌ خوای گه‌وره‌ ئێمه‌ له‌ گومڕاییه‌كی زۆر ئاشكرادا بووین."
  26,98,"[ <span class="arabic uthmani">إِذْ نُسَوِّيكُمْ بِرَبِّ الْعَالَمِينَ (٩٨)</span> ] كاتێك ئێوه‌مان یه‌كسان كرد به‌ په‌روه‌ردگاری هه‌موو جیهان و جگه‌ له‌ خوای گه‌وره‌ ئێوه‌مان په‌رست."
  26,99,"[ <span class="arabic uthmani">وَمَا أَضَلَّنَا إِلَّا الْمُجْرِمُونَ (٩٩)</span> ] وه‌ هیچ كه‌سێك ئێمه‌ی گومڕا نه‌كرد ته‌نها ئه‌م تاوانبارانه‌ نه‌بێ له‌ جن و مرۆڤ."
  26,100,"[ <span class="arabic uthmani">فَمَا لَنَا مِنْ شَافِعِينَ (١٠٠)</span> ] وه‌ ئێستا كه‌سێك نیه‌ كه‌ تكامان بۆ بكات هه‌روه‌كو چۆن باوه‌ڕداران به‌ ئیزنی خوا كه‌سانێك تكایان بۆ ئه‌كات."
  26,101,"[ <span class="arabic uthmani">وَلَا صَدِيقٍ حَمِيمٍ (١٠١)</span> ] وه‌ هیچ هاوڕێیه‌كی خۆشه‌ویست و نزیكمان نیه‌ كه‌ ڕزگارمان بكات."
  26,102,"[ <span class="arabic uthmani">فَلَوْ أَنَّ لَنَا كَرَّةً فَنَكُونَ مِنَ الْمُؤْمِنِينَ (١٠٢)</span> ] ئای ئه‌گه‌ر جارێكی تر بگه‌ڕاینایه‌ته‌وه‌ بۆ دونیا ئه‌وا ده‌بوایه‌ له‌ باوه‌ڕداران بووینایه‌و شوێن ئێوه‌ نه‌كه‌وتینایه‌ (خواى گه‌وره‌ ده‌زانێت درۆ ده‌كه‌ن ئه‌گه‌ر بگه‌ڕێنه‌وه‌ بۆ دونیایش هه‌ر تاوان و خراپه‌ ده‌كه‌ن)."
  26,103,"[ <span class="arabic uthmani">إِنَّ فِي ذَلِكَ لَآيَةً</span> ] به‌ دڵنیایى ئه‌و شتانه‌ی كه‌ باسكرا هه‌مووی به‌ڵگه‌و نیشانه‌یه‌ له‌سه‌ر تاك و ته‌نهایى و تواناو ده‌سه‌ڵاتی خوای گه‌وره‌ [ <span class="arabic uthmani">وَمَا كَانَ أَكْثَرُهُمْ مُؤْمِنِينَ (١٠٣)</span> ] هه‌ر چه‌نده‌ زۆربه‌ی زۆریان ئیمانیان نه‌هێنا."
  26,104,"[ <span class="arabic uthmani">وَإِنَّ رَبَّكَ لَهُوَ الْعَزِيزُ الرَّحِيمُ (١٠٤)</span> ] وه‌ به‌ دڵنیایى په‌روه‌ردگارت زۆر به‌ عیززه‌ت و باڵاده‌سته‌ وه‌ زۆر به‌ڕه‌حم و سۆزو به‌زه‌ییه‌."
  26,105,"{گفتوگۆی نێوان نوح پێغەمبەر - <span class="saw">صلی الله علیه وسلم</span> - و قەومەكەی}
 [ <span class="arabic uthmani">كَذَّبَتْ قَوْمُ نُوحٍ الْمُرْسَلِينَ (١٠٥)</span> ] قه‌ومی نوح سه‌رجه‌م پێغه‌مبه‌رانیان به‌درۆ زانی، (كه‌ باوه‌ڕیان به‌ پێغه‌مبه‌ره‌كه‌ی خۆیان نه‌بوو وه‌ك ئه‌وه‌ وایه‌ هه‌موو پێغه‌مبه‌رانیان به‌درۆ زانیبێت)."
  26,106,"[ <span class="arabic uthmani">إِذْ قَالَ لَهُمْ أَخُوهُمْ نُوحٌ أَلَا تَتَّقُونَ (١٠٦)</span> ] كاتێك نوح - <span class="saw">صلی الله علیه وسلم</span> -  (له‌به‌ر ئه‌وه‌ی له‌ هۆزو نه‌ته‌وه‌ی خۆیان بوو خوای گه‌وره‌ به‌ برا ناوی ئه‌بات) پێی وتن: ئایا بۆ ته‌قوای خوای گه‌وره‌ ناكه‌ن و واز له‌ په‌رستنی ئه‌و بتانه‌ ناهێنن و شوێن من ناكه‌ون."
  26,107,"[ <span class="arabic uthmani">إِنِّي لَكُمْ رَسُولٌ أَمِينٌ (١٠٧)</span> ] له‌به‌ر ئه‌وه‌ی به‌دڵنیایى من پێغه‌مبه‌رێكی ئه‌مینم بۆ ئێوه‌و ئه‌مینم له‌وه‌ی كه‌ پێتانی ڕائه‌گه‌یه‌نم له‌لایه‌ن خواى گه‌وره‌وه‌و هیچى لێ زیادو كه‌م ناكه‌م."
  26,108,"[ <span class="arabic uthmani">فَاتَّقُوا اللَّهَ وَأَطِيعُونِ (١٠٨)</span> ] وه‌ ئێوه‌ ته‌قواى خوای گه‌وره‌ بكه‌ن وه‌ گوێڕایه‌ڵى منیش بكه‌ن."
  26,109,"[ <span class="arabic uthmani">وَمَا أَسْأَلُكُمْ عَلَيْهِ مِنْ أَجْرٍ</span> ] وه‌ من له‌م شته‌دا داوای هیچ ئه‌جرو پاداشت و پاره‌یه‌ك له‌ ئێوه‌ ناكه‌م [ <span class="arabic uthmani">إِنْ أَجْرِيَ إِلَّا عَلَى رَبِّ الْعَالَمِينَ (١٠٩)</span> ] به‌ڵكو ئه‌جرو پاداشتی من ته‌نها له‌لای خوای گه‌وره‌یه‌و ئه‌و ئه‌جرو پاداشتم ئه‌داته‌وه‌ له‌سه‌ر گه‌یاندنی دینه‌كه‌ی."
  26,110,"[ <span class="arabic uthmani">فَاتَّقُوا اللَّهَ وَأَطِيعُونِ (١١٠)</span> ] وه‌ ئێوه‌ ته‌قوای خوای گه‌وره‌ بكه‌ن وه‌ گوێڕایه‌ڵى من بكه‌ن."
  26,111,"[ <span class="arabic uthmani">قَالُوا أَنُؤْمِنُ لَكَ وَاتَّبَعَكَ الْأَرْذَلُونَ (١١١)</span> ] وتیان: ئایا ئێمه‌ ئیمان به‌ تۆ بێنین له‌ كاتێكدا كه‌سانێكی نزم و فه‌قیرو هه‌ژار دوای تۆ كه‌وتوونه‌؟ له‌گه‌ڵ ئه‌واندا ئیمان به‌ تۆ بێنین؟"