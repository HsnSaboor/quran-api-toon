quran[29]{c,v,t}:
  37,154,"[ <span class="arabic uthmani">مَا لَكُمْ كَيْفَ تَحْكُمُونَ (١٥٤)</span> ] ئه‌وه‌ چیتانه‌و چۆن بڕیارێكه‌ بۆ خوای گه‌وره‌ی ئه‌ده‌ن."
  37,155,"[ <span class="arabic uthmani">أَفَلَا تَذَكَّرُونَ (١٥٥)</span> ] ئه‌وه‌ بۆ بیر ناكه‌نه‌وه‌و په‌ندو ئامۆژگاری وه‌رناگرن له‌سه‌ر پووچه‌ڵی و به‌تاڵی ئه‌و قسه‌یه‌ی خۆتان."
  37,156,"[ <span class="arabic uthmani">أَمْ لَكُمْ سُلْطَانٌ مُبِينٌ (١٥٦)</span> ] یاخود به‌ڵگه‌یه‌كی ڕوون و ئاشكراتان هه‌یه‌ له‌سه‌ر ئه‌م قسانه‌ی كه‌ ئێوه‌ ئه‌یكه‌ن."
  37,157,"[ <span class="arabic uthmani">فَأْتُوا بِكِتَابِكُمْ إِنْ كُنْتُمْ صَادِقِينَ (١٥٧)</span> ] ئه‌گه‌ر به‌ڵگه‌یه‌ك و كتابێكى ئاسمانیتان هه‌یه‌ ئه‌م شتانه‌ی تیا نووسراوه‌ته‌وه‌ بیهێنن ئه‌گه‌ر ئێوه‌ ڕاستگۆن."
  37,158,"[ <span class="arabic uthmani">وَجَعَلُوا بَيْنَهُ وَبَيْنَ الْجِنَّةِ نَسَبًا</span> ]  ئه‌یانووت: خوای گه‌وره‌ له‌گه‌ڵ جنیه‌كاندا نه‌سه‌ب له‌ نێوانیاندا هه‌یه‌ (وَالْعِيَاذُ بِالله) ئه‌یانووت: ژن و ژنخوازی له‌ نێوانیاندا هه‌یه‌ خوای گه‌وره‌ داوای جنی كردووه‌ جنیان داوه‌ته‌وه‌ خوای گه‌وره‌و مه‌لائیكه‌تیش له‌و بووه‌ (وَالْعِيَاذُ بِالله) [ <span class="arabic uthmani">وَلَقَدْ عَلِمَتِ الْجِنَّةُ إِنَّهُمْ لَمُحْضَرُونَ (١٥٨)</span> ] له‌ كاتێكدا كه‌ جنیه‌ كافره‌كانیش ئه‌زانن ئاماده‌ی ئاگری دۆزه‌خ و سزای خوای گه‌وره‌ ئه‌بن له‌سه‌ر ئه‌م درۆ هه‌ڵبه‌ستنانه‌."
  37,159,"[ <span class="arabic uthmani">سُبْحَانَ اللَّهِ عَمَّا يَصِفُونَ (١٥٩)</span> ] پاك و مونه‌ززه‌هی بۆ خوای گه‌وره‌ له‌و وه‌سفانه‌ی كه‌ ئه‌وان ئه‌یده‌نه‌ پاڵ خوای گه‌وره‌ كه‌ خوای گه‌وره‌ پاك و بێگه‌رده‌ له‌وه‌ی كه‌ خێزان یان منداڵی هه‌بێت."
  37,160,"[ <span class="arabic uthmani">إِلَّا عِبَادَ اللَّهِ الْمُخْلَصِينَ (١٦٠)</span> ] ته‌نها به‌نده‌ دڵسۆزه‌كانی خوای گه‌وره‌ ئاماده‌ی سزای خوای گه‌وره‌ نابن، یاخود ئه‌و وه‌سفانه‌ ناده‌نه‌ پاڵ خوای گه‌وره‌ به‌ڵكو به‌تاك و ته‌نها خوای گه‌وره‌ ئه‌په‌رستن و خوای گه‌وره‌ به‌ پاك ڕائه‌گرن له‌ هه‌موو وه‌سفێك كه‌ شایانى خواى گه‌وره‌ نه‌بێت."
  37,161,"[ <span class="arabic uthmani">فَإِنَّكُمْ وَمَا تَعْبُدُونَ (١٦١)</span> ] ئێوه‌ خۆتان و خواكانتان."
  37,162,"[ <span class="arabic uthmani">مَا أَنْتُمْ عَلَيْهِ بِفَاتِنِينَ (١٦٢)</span> ] ناتوانن كه‌س گومڕا بكه‌ن و كه‌س شوێنتان ناكه‌وێت."
  37,163,"[ <span class="arabic uthmani">إِلَّا مَنْ هُوَ صَالِ الْجَحِيمِ (١٦٣)</span> ] ته‌نها مه‌گه‌ر كه‌سێك خۆی به‌رده‌وام بێ له‌سه‌ر كوفرو خۆی بیه‌وێ بچێته‌ دۆزه‌خه‌وه‌و دۆزه‌خ هه‌ڵبژێرێ."
  37,164,"[ <span class="arabic uthmani">وَمَا مِنَّا إِلَّا لَهُ مَقَامٌ مَعْلُومٌ (١٦٤)</span> ] فریشته‌كان ئه‌ڵێن: وه‌ هیچ كه‌سێك له‌ ئێمه‌ نیه‌ ته‌نها شوێنی دیاریكراوی خۆمان هه‌یه‌ له‌ ئاسماندا خوای گه‌وره‌ى لێ ده‌په‌رستین و ئه‌و شوێنه‌ تێناپه‌ڕێنین."
  37,165,"[ <span class="arabic uthmani">وَإِنَّا لَنَحْنُ الصَّافُّونَ (١٦٥)</span> ] وه‌ ئێمه‌ هه‌موومان پۆل پۆل ڕاوه‌ستاوین له‌ ئاسمان عیباده‌تی خوای گه‌وره‌ ئه‌كه‌ین هه‌روه‌كو چۆن باوه‌ڕدارانیش له‌ نوێژه‌كاندا پۆل پۆل ڕائه‌وه‌ستن و عیباده‌تی خوای گه‌وره‌ ئه‌كه‌ن."
  37,166,"[ <span class="arabic uthmani">وَإِنَّا لَنَحْنُ الْمُسَبِّحُونَ (١٦٦)</span> ] وه‌ ئێمه‌ ته‌سبیحات و نوێژو عیباده‌ت و زیكری خوای گه‌وره‌ ئه‌كه‌ین، واته‌: ئێمه‌ كچی خوای گه‌وره‌ نین به‌ڵكو به‌نده‌ی ملكه‌چ و گوێڕایه‌ڵى خوای گه‌وره‌ین."
  37,167,"[ <span class="arabic uthmani">وَإِنْ كَانُوا لَيَقُولُونَ (١٦٧)</span> ] هه‌ر چه‌نده‌ موشریكان ئه‌یانووت:"
  37,168,"[ <span class="arabic uthmani">لَوْ أَنَّ عِنْدَنَا ذِكْرًا مِنَ الْأَوَّلِينَ (١٦٨)</span> ] ئه‌گه‌ر كتابێكمان هه‌بوایه‌ وه‌ك ئه‌وه‌ی بۆ ئوممه‌تانی پێشتر هاتووه‌ وه‌ك ته‌ورات و ئینجیل."
  37,169,"[ <span class="arabic uthmani">لَكُنَّا عِبَادَ اللَّهِ الْمُخْلَصِينَ (١٦٩)</span> ] ئه‌وه‌ ئێمه‌ش ئه‌بووینه‌ به‌نده‌ی دڵسۆزی خوای گه‌وره‌و به‌ دڵسۆزی عیباده‌تی خوای گه‌وره‌مان ئه‌كردو كوفرمان نه‌ئه‌كرد."
  37,170,"[ <span class="arabic uthmani">فَكَفَرُوا بِهِ</span> ] به‌ڵام كاتێك كه‌ كتابیان بۆ هات له‌لایه‌ن خوای گه‌وره‌وه‌ كه‌ قورئان بوو ئه‌وان كوفریان پێ كرد [ <span class="arabic uthmani">فَسَوْفَ يَعْلَمُونَ (١٧٠)</span> ] ئه‌وه‌ له‌ داهاتوودا سه‌ره‌نجامی كوفره‌كه‌یان ئه‌زانن كه‌ خوای گه‌وره‌ چۆن سزایان ئه‌دات."
  37,171,"[ <span class="arabic uthmani">وَلَقَدْ سَبَقَتْ كَلِمَتُنَا لِعِبَادِنَا الْمُرْسَلِينَ (١٧١)</span> ] خوای گه‌وره‌ ئه‌فه‌رمووێ: وه‌ به‌ دڵنیایى پێشتریش ئێمه‌ وشه‌و قسه‌ى خۆمان پێش خستووه‌ بۆ به‌نده‌ نێردراوه‌كانی خۆمان بۆ پێغه‌مبه‌ران كه‌ ئه‌بێ ئه‌وان سه‌ركه‌ون."
  37,172,"[ <span class="arabic uthmani">إِنَّهُمْ لَهُمُ الْمَنْصُورُونَ (١٧٢)</span> ] ئه‌مانن كه‌ سه‌رئه‌كه‌ون به‌سه‌ر دوژمنه‌كانیاندا وه‌ زاڵ ئه‌بن."
  37,173,"[ <span class="arabic uthmani">وَإِنَّ جُنْدَنَا لَهُمُ الْغَالِبُونَ (١٧٣)</span> ] وه‌ سه‌ربازه‌كانی ئێمه‌ ئه‌وانیش سه‌ركه‌وتوون وه‌ زاڵن به‌سه‌ر كافران و بێباوه‌ڕاندا."
  37,174,"[ <span class="arabic uthmani">فَتَوَلَّ عَنْهُمْ حَتَّى حِينٍ (١٧٤)</span> ] ئه‌ی محمد - <span class="saw">صلی الله علیه وسلم</span> - پشتیان تێ بكه‌و ئارام بگره‌ له‌سه‌ر ئازاریان تا كاتی دیاریكراویان دێت كه‌ خوای گه‌وره‌ له‌ناویان ئه‌بات."
  37,175,"[ <span class="arabic uthmani">وَأَبْصِرْهُمْ</span> ] وه‌ كاتێك كه‌ سزای خوای گه‌وره‌ دێت به‌ كوشتن و به‌ دیل گرتن، یان له‌ رۆژى قیامه‌ت تۆ ته‌ماشایان بكه‌ [ <span class="arabic uthmani">فَسَوْفَ يُبْصِرُونَ (١٧٥)</span> ] ئه‌وانیش به‌ چاوی خۆیان ئه‌و شته‌ ئه‌بینن و ته‌ماشای ئه‌كه‌ن به‌ڵام سوودیان پێ ناگه‌یه‌نێت."
  37,176,"[ <span class="arabic uthmani">أَفَبِعَذَابِنَا يَسْتَعْجِلُونَ (١٧٦)</span> ] ئایا ئه‌وان په‌له‌ی سزای ئێمه‌ ئه‌كه‌ن و داوای سزای ئێمه‌ ئه‌كه‌ن و ئه‌ڵێن: كه‌ی سزای خوا دێت."
  37,177,"[ <span class="arabic uthmani">فَإِذَا نَزَلَ بِسَاحَتِهِمْ</span> ] كاتێك سزای ئێمه‌ دائه‌به‌زێ بۆ گۆڕه‌پان و ماڵ و شوێنی ئه‌وان له‌ كاتی جه‌نگدا [ <span class="arabic uthmani">فَسَاءَ صَبَاحُ الْمُنْذَرِينَ (١٧٧)</span> ] ئه‌وه‌ خراپترین به‌یانیه‌ بۆ ئه‌و كه‌سانه‌ی كه‌ ئاگادار كراونه‌ته‌وه‌ كه‌ تیایدا تێكئه‌شكێن."
  37,178,"[ <span class="arabic uthmani">وَتَوَلَّ عَنْهُمْ</span> ] ئه‌ی محمد - <span class="saw">صلی الله علیه وسلم</span> - وه‌ تۆ پشتیان تێ بكه‌ [ <span class="arabic uthmani">حَتَّى حِينٍ (١٧٨)</span> ] تا كاتی دیاریكراویان كه‌ خوای گه‌وره‌ سزایان ئه‌دات و تێكیانئه‌شكێنێ."
  37,179,"[ <span class="arabic uthmani">وَأَبْصِرْ</span> ] وه‌ تۆ ته‌ماشا بكه‌ كاتێك كه‌ تێكئه‌شكێن و ئه‌كوژرێن له‌ جه‌نگى به‌در [ <span class="arabic uthmani">فَسَوْفَ يُبْصِرُونَ (١٧٩)</span> ] وه‌ خۆیشیان به‌ چاوی خۆیان ئه‌و شته‌ ئه‌بینن به‌ڵام سوودیان پێ ناگه‌یه‌نێ."
  37,180,"[ <span class="arabic uthmani">سُبْحَانَ رَبِّكَ رَبِّ الْعِزَّةِ عَمَّا يَصِفُونَ (١٨٠)</span> ] پاك و مونه‌ززه‌هی بۆ په‌روه‌ردگارت ئه‌و په‌روه‌ردگاره‌ی كه‌ به‌ عیززه‌ته‌ له‌ هه‌موو ئه‌و وه‌سفه‌ ناشیرینانه‌ی كه‌ كافران و موشریكان ئه‌یده‌نه‌ پاڵ خوای گه‌وره‌."
  37,181,"[ <span class="arabic uthmani">وَسَلَامٌ عَلَى الْمُرْسَلِينَ (١٨١)</span> ] وه‌ سڵاوی خوای گه‌وره‌ له‌سه‌ر پێغه‌مبه‌ران و نێردراوانی خوای گه‌وره‌ بێت له‌ دونیاو قیامه‌تدا."
  37,182,"[ <span class="arabic uthmani">وَالْحَمْدُ لِلَّهِ رَبِّ الْعَالَمِينَ (١٨٢)</span> ] وه‌ حه‌مدو سه‌ناو ستایش بۆ په‌روه‌ردگاری هه‌موو جیهان له‌سه‌ر هه‌موو نیعمه‌ته‌كانی له‌سه‌رخستنی پێغه‌مبه‌ران و تێكشكاندنی كافران، والله أعلم."