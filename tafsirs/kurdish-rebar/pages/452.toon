tafsir[29]{c,v,t}:
37,154,"[ <q>مَا لَكُمْ كَيْفَ تَحْكُمُونَ (١٥٤)</q> ] ئهوه چیتانهو چۆن بڕیارێكه بۆ خوای گهورهی ئهدهن."
37,155,"[ <q>أَفَلَا تَذَكَّرُونَ (١٥٥)</q> ] ئهوه بۆ بیر ناكهنهوهو پهندو ئامۆژگاری وهرناگرن لهسهر پووچهڵی و بهتاڵی ئهو قسهیهی خۆتان."
37,156,"[ <q>أَمْ لَكُمْ سُلْطَانٌ مُبِينٌ (١٥٦)</q> ] یاخود بهڵگهیهكی ڕوون و ئاشكراتان ههیه لهسهر ئهم قسانهی كه ئێوه ئهیكهن."
37,157,"[ <q>فَأْتُوا بِكِتَابِكُمْ إِنْ كُنْتُمْ صَادِقِينَ (١٥٧)</q> ] ئهگهر بهڵگهیهك و كتابێكى ئاسمانیتان ههیه ئهم شتانهی تیا نووسراوهتهوه بیهێنن ئهگهر ئێوه ڕاستگۆن."
37,158,"[ <q>وَجَعَلُوا بَيْنَهُ وَبَيْنَ الْجِنَّةِ نَسَبًا</q> ] ئهیانووت: خوای گهوره لهگهڵ جنیهكاندا نهسهب له نێوانیاندا ههیه (وَالْعِيَاذُ بِالله) ئهیانووت: ژن و ژنخوازی له نێوانیاندا ههیه خوای گهوره داوای جنی كردووه جنیان داوهتهوه خوای گهورهو مهلائیكهتیش لهو بووه (وَالْعِيَاذُ بِالله) [ <q>وَلَقَدْ عَلِمَتِ الْجِنَّةُ إِنَّهُمْ لَمُحْضَرُونَ (١٥٨)</q> ] له كاتێكدا كه جنیه كافرهكانیش ئهزانن ئامادهی ئاگری دۆزهخ و سزای خوای گهوره ئهبن لهسهر ئهم درۆ ههڵبهستنانه."
37,159,"[ <q>سُبْحَانَ اللَّهِ عَمَّا يَصِفُونَ (١٥٩)</q> ] پاك و مونهززههی بۆ خوای گهوره لهو وهسفانهی كه ئهوان ئهیدهنه پاڵ خوای گهوره كه خوای گهوره پاك و بێگهرده لهوهی كه خێزان یان منداڵی ههبێت."
37,160,"[ <q>إِلَّا عِبَادَ اللَّهِ الْمُخْلَصِينَ (١٦٠)</q> ] تهنها بهنده دڵسۆزهكانی خوای گهوره ئامادهی سزای خوای گهوره نابن، یاخود ئهو وهسفانه نادهنه پاڵ خوای گهوره بهڵكو بهتاك و تهنها خوای گهوره ئهپهرستن و خوای گهوره به پاك ڕائهگرن له ههموو وهسفێك كه شایانى خواى گهوره نهبێت."
37,161,"[ <q>فَإِنَّكُمْ وَمَا تَعْبُدُونَ (١٦١)</q> ] ئێوه خۆتان و خواكانتان."
37,162,"[ <q>مَا أَنْتُمْ عَلَيْهِ بِفَاتِنِينَ (١٦٢)</q> ] ناتوانن كهس گومڕا بكهن و كهس شوێنتان ناكهوێت."
37,163,"[ <q>إِلَّا مَنْ هُوَ صَالِ الْجَحِيمِ (١٦٣)</q> ] تهنها مهگهر كهسێك خۆی بهردهوام بێ لهسهر كوفرو خۆی بیهوێ بچێته دۆزهخهوهو دۆزهخ ههڵبژێرێ."
37,164,"[ <q>وَمَا مِنَّا إِلَّا لَهُ مَقَامٌ مَعْلُومٌ (١٦٤)</q> ] فریشتهكان ئهڵێن: وه هیچ كهسێك له ئێمه نیه تهنها شوێنی دیاریكراوی خۆمان ههیه له ئاسماندا خوای گهورهى لێ دهپهرستین و ئهو شوێنه تێناپهڕێنین."
37,165,"[ <q>وَإِنَّا لَنَحْنُ الصَّافُّونَ (١٦٥)</q> ] وه ئێمه ههموومان پۆل پۆل ڕاوهستاوین له ئاسمان عیبادهتی خوای گهوره ئهكهین ههروهكو چۆن باوهڕدارانیش له نوێژهكاندا پۆل پۆل ڕائهوهستن و عیبادهتی خوای گهوره ئهكهن."
37,166,"[ <q>وَإِنَّا لَنَحْنُ الْمُسَبِّحُونَ (١٦٦)</q> ] وه ئێمه تهسبیحات و نوێژو عیبادهت و زیكری خوای گهوره ئهكهین، واته: ئێمه كچی خوای گهوره نین بهڵكو بهندهی ملكهچ و گوێڕایهڵى خوای گهورهین."
37,167,"[ <q>وَإِنْ كَانُوا لَيَقُولُونَ (١٦٧)</q> ] ههر چهنده موشریكان ئهیانووت:"
37,168,"[ <q>لَوْ أَنَّ عِنْدَنَا ذِكْرًا مِنَ الْأَوَّلِينَ (١٦٨)</q> ] ئهگهر كتابێكمان ههبوایه وهك ئهوهی بۆ ئوممهتانی پێشتر هاتووه وهك تهورات و ئینجیل."
37,169,"[ <q>لَكُنَّا عِبَادَ اللَّهِ الْمُخْلَصِينَ (١٦٩)</q> ] ئهوه ئێمهش ئهبووینه بهندهی دڵسۆزی خوای گهورهو به دڵسۆزی عیبادهتی خوای گهورهمان ئهكردو كوفرمان نهئهكرد."
37,170,"[ <q>فَكَفَرُوا بِهِ</q> ] بهڵام كاتێك كه كتابیان بۆ هات لهلایهن خوای گهورهوه كه قورئان بوو ئهوان كوفریان پێ كرد [ <q>فَسَوْفَ يَعْلَمُونَ (١٧٠)</q> ] ئهوه له داهاتوودا سهرهنجامی كوفرهكهیان ئهزانن كه خوای گهوره چۆن سزایان ئهدات."
37,171,"[ <q>وَلَقَدْ سَبَقَتْ كَلِمَتُنَا لِعِبَادِنَا الْمُرْسَلِينَ (١٧١)</q> ] خوای گهوره ئهفهرمووێ: وه به دڵنیایى پێشتریش ئێمه وشهو قسهى خۆمان پێش خستووه بۆ بهنده نێردراوهكانی خۆمان بۆ پێغهمبهران كه ئهبێ ئهوان سهركهون."
37,172,"[ <q>إِنَّهُمْ لَهُمُ الْمَنْصُورُونَ (١٧٢)</q> ] ئهمانن كه سهرئهكهون بهسهر دوژمنهكانیاندا وه زاڵ ئهبن."
37,173,"[ <q>وَإِنَّ جُنْدَنَا لَهُمُ الْغَالِبُونَ (١٧٣)</q> ] وه سهربازهكانی ئێمه ئهوانیش سهركهوتوون وه زاڵن بهسهر كافران و بێباوهڕاندا."
37,174,"[ <q>فَتَوَلَّ عَنْهُمْ حَتَّى حِينٍ (١٧٤)</q> ] ئهی محمد - صلی الله علیه وسلم - پشتیان تێ بكهو ئارام بگره لهسهر ئازاریان تا كاتی دیاریكراویان دێت كه خوای گهوره لهناویان ئهبات."
37,175,"[ <q>وَأَبْصِرْهُمْ</q> ] وه كاتێك كه سزای خوای گهوره دێت به كوشتن و به دیل گرتن، یان له رۆژى قیامهت تۆ تهماشایان بكه [ <q>فَسَوْفَ يُبْصِرُونَ (١٧٥)</q> ] ئهوانیش به چاوی خۆیان ئهو شته ئهبینن و تهماشای ئهكهن بهڵام سوودیان پێ ناگهیهنێت."
37,176,"[ <q>أَفَبِعَذَابِنَا يَسْتَعْجِلُونَ (١٧٦)</q> ] ئایا ئهوان پهلهی سزای ئێمه ئهكهن و داوای سزای ئێمه ئهكهن و ئهڵێن: كهی سزای خوا دێت."
37,177,"[ <q>فَإِذَا نَزَلَ بِسَاحَتِهِمْ</q> ] كاتێك سزای ئێمه دائهبهزێ بۆ گۆڕهپان و ماڵ و شوێنی ئهوان له كاتی جهنگدا [ <q>فَسَاءَ صَبَاحُ الْمُنْذَرِينَ (١٧٧)</q> ] ئهوه خراپترین بهیانیه بۆ ئهو كهسانهی كه ئاگادار كراونهتهوه كه تیایدا تێكئهشكێن."
37,178,"[ <q>وَتَوَلَّ عَنْهُمْ</q> ] ئهی محمد - صلی الله علیه وسلم - وه تۆ پشتیان تێ بكه [ <q>حَتَّى حِينٍ (١٧٨)</q> ] تا كاتی دیاریكراویان كه خوای گهوره سزایان ئهدات و تێكیانئهشكێنێ."
37,179,"[ <q>وَأَبْصِرْ</q> ] وه تۆ تهماشا بكه كاتێك كه تێكئهشكێن و ئهكوژرێن له جهنگى بهدر [ <q>فَسَوْفَ يُبْصِرُونَ (١٧٩)</q> ] وه خۆیشیان به چاوی خۆیان ئهو شته ئهبینن بهڵام سوودیان پێ ناگهیهنێ."
37,180,"[ <q>سُبْحَانَ رَبِّكَ رَبِّ الْعِزَّةِ عَمَّا يَصِفُونَ (١٨٠)</q> ] پاك و مونهززههی بۆ پهروهردگارت ئهو پهروهردگارهی كه به عیززهته له ههموو ئهو وهسفه ناشیرینانهی كه كافران و موشریكان ئهیدهنه پاڵ خوای گهوره."
37,181,"[ <q>وَسَلَامٌ عَلَى الْمُرْسَلِينَ (١٨١)</q> ] وه سڵاوی خوای گهوره لهسهر پێغهمبهران و نێردراوانی خوای گهوره بێت له دونیاو قیامهتدا."
37,182,"[ <q>وَالْحَمْدُ لِلَّهِ رَبِّ الْعَالَمِينَ (١٨٢)</q> ] وه حهمدو سهناو ستایش بۆ پهروهردگاری ههموو جیهان لهسهر ههموو نیعمهتهكانی لهسهرخستنی پێغهمبهران و تێكشكاندنی كافران، والله أعلم."
