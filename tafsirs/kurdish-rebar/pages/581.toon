quran[31]{c,v,t}:
  77,20,"[ <span class="arabic uthmani">أَلَمْ نَخْلُقْكُمْ مِنْ مَاءٍ مَهِينٍ (٢٠)</span> ] ئایا ئێوه‌مان دروست نه‌كردووه‌ له‌ ئاوێكی بێ ڕێز، مرۆڤ له‌ دڵۆپه‌ ئاوێك دروست بووه‌ كه‌ مه‌نی یه‌."
  77,21,"[ <span class="arabic uthmani">فَجَعَلْنَاهُ فِي قَرَارٍ مَكِينٍ (٢١)</span> ] ئه‌و ئاوه‌ له‌ شوێنێكی پارێزراو دانراوه‌ كه‌ ناو ڕه‌حمی ئافره‌ته‌."
  77,22,"[ <span class="arabic uthmani">إِلَى قَدَرٍ مَعْلُومٍ (٢٢)</span> ] تا كاتی دیاریكراوی خۆی كه‌ ماوه‌ی حه‌مله‌، لای كه‌مه‌كه‌ی شه‌ش مانگه‌و لای زۆره‌كه‌ی نۆ مانگه‌."
  77,23,"[ <span class="arabic uthmani">فَقَدَرْنَا فَنِعْمَ الْقَادِرُونَ (٢٣)</span> ] ئێمه‌ ئه‌ندامه‌كانی له‌شی مرۆڤمان ڕێكخستووه‌و ته‌قدیرمان كردووه‌، وه‌ باشترین ته‌قدیركار خوای گه‌وره‌یه‌."
  77,24,"[ <span class="arabic uthmani">وَيْلٌ يَوْمَئِذٍ لِلْمُكَذِّبِينَ (٢٤)</span> ] هه‌ڕه‌شه‌ی سه‌خت و ئاگری دۆزه‌خ بۆ ئه‌و كه‌سانه‌ی كه‌ ڕۆژی زیندوو بوونه‌وه‌ به‌درۆ ئه‌زانن."
  77,25,"[ <span class="arabic uthmani">أَلَمْ نَجْعَلِ الْأَرْضَ كِفَاتًا (٢٥)</span> ] ئایا زه‌ویمان وا لێ نه‌كردووه‌ كه‌ بتانگرێته‌ خۆی و كۆتان بكاته‌وه‌."
  77,26,"[ <span class="arabic uthmani">أَحْيَاءً وَأَمْوَاتًا (٢٦)</span> ] به‌ زیندووێتی و به‌ مردووێتی، سه‌ر زه‌وی بۆ زیندووه‌كانه‌و له‌سه‌ری ئه‌ژین، ناویشى بۆ مردووه‌كانه‌و له‌ناو گۆڕدان."
  77,27,"[ <span class="arabic uthmani">وَجَعَلْنَا فِيهَا رَوَاسِيَ شَامِخَاتٍ</span> ] وه‌ له‌ناو زه‌ویشدا ئه‌و شاخانه‌مان داناوه‌ وه‌كو سنگ و مێخ داكوتاوه‌ بۆ ئه‌وه‌ی زه‌وی نه‌هه‌ژێت و نه‌جوولێت و نه‌له‌رزێت [ <span class="arabic uthmani">وَأَسْقَيْنَاكُمْ مَاءً فُرَاتًا (٢٧)</span> ] وه‌ ئاوێكی سازگاریشمان پێ به‌خشیوون."
  77,28,"[ <span class="arabic uthmani">وَيْلٌ يَوْمَئِذٍ لِلْمُكَذِّبِينَ (٢٨)</span> ] هه‌ڕه‌شه‌ی سه‌خت و ئاگری دۆزه‌خ بۆ ئه‌و كه‌سانه‌ی كه‌ باوه‌ڕیان به‌ زیندوو بوونه‌وه‌و ڕۆژی دوایی نیه‌."
  77,29,"[ <span class="arabic uthmani">انْطَلِقُوا إِلَى مَا كُنْتُمْ بِهِ تُكَذِّبُونَ (٢٩)</span> ] له‌ رۆژى قیامه‌ت به‌ كافران ئه‌ووترێ: بڕۆن بۆ ئه‌و شوێنه‌ی كه‌ ئێوه‌ له‌ دونیا به‌درۆتان ئه‌زانی، واته‌: بڕۆن بۆ ناو ئاگری دۆزه‌خ كه‌ ئه‌تانووت دۆزه‌خ نیه‌و زیندوو بوونه‌وه‌ نیه‌و قیامه‌ت نیه‌."
  77,30,"{سزاى دۆزه‌خییه‌كان}
 [ <span class="arabic uthmani">انْطَلِقُوا إِلَى ظِلٍّ ذِي ثَلَاثِ شُعَبٍ (٣٠)</span> ] بڕۆن به‌ره‌و سێبه‌رێك له‌ ئاگری دۆزه‌خ كه‌ له‌ سه‌ختى و گه‌وره‌ییدا سێ لقی لێ بۆته‌وه‌، ئه‌و ئاگره‌ دووكه‌ڵه‌كه‌ی بووه‌ به‌ سێبه‌ر بۆیان."
  77,31,"[ <span class="arabic uthmani">لَا ظَلِيلٍ</span> ] به‌ڵام سێبه‌رێكه‌ وه‌كو سێبه‌ری دونیا نیه‌ كه‌ فێنك بێ، وه‌ وایش نیه‌ كه‌ گه‌رمی ئاگری جه‌هه‌ننه‌میان لێ بگه‌ڕێنێته‌وه‌ [ <span class="arabic uthmani">وَلَا يُغْنِي مِنَ اللَّهَبِ (٣١)</span> ] وه‌ هیچ سوودێكی نیه‌ له‌ گڕو بڵێسه‌ی ئاگری دۆزه‌خ."
  77,32,"[ <span class="arabic uthmani">إِنَّهَا تَرْمِي بِشَرَرٍ كَالْقَصْرِ (٣٢)</span> ] ئه‌و ئاگری دۆزه‌خه‌ پریشك فڕێ ئه‌دات هه‌ر پریشكێكی به‌ئه‌ندازه‌ى كۆشكێك گه‌وره‌یه‌، یاخود به‌ئه‌ندازه‌ى قه‌ڵایه‌ك گه‌وره‌یه‌، یاخود به‌ئه‌ندازه‌ى دارێك كه‌ سێ گه‌ز بێ ئه‌وه‌نده‌ گه‌وره‌یه‌ (په‌نا به‌خوای گه‌وره‌)."
  77,33,"[ <span class="arabic uthmani">كَأَنَّهُ جِمَالَتٌ صُفْرٌ (٣٣)</span> ] هه‌ر پریشكێكی به‌ئه‌ندازه‌ى حوشترێكی ڕه‌شه‌، كه‌ حوشتری ڕه‌ش تێكه‌ڵی زه‌رد ئه‌بێ پێی ئه‌ووترێ: (صُفْرٌ) یاخود به‌ئه‌ندازه‌ى حه‌بلی كه‌شتی كه‌ به‌قه‌ده‌ر ناو قه‌دی مرۆڤێك ئه‌ستووره‌، هه‌ر پریشكێكی ئه‌وه‌نده‌ گه‌وره‌یه."
  77,34,"‌[ <span class="arabic uthmani">وَيْلٌ يَوْمَئِذٍ لِلْمُكَذِّبِينَ (٣٤)</span> ] هه‌ڕه‌شه‌ی سه‌خت و ئاگری دۆزه‌خ و سزای خوای گه‌وره‌ له‌و ڕۆژه‌دا بۆ ئه‌و كه‌سانه‌ی كه‌ باوه‌ڕیان به‌ ڕۆژی دوایی نیه‌."
  77,35,"[ <span class="arabic uthmani">هَذَا يَوْمُ لَا يَنْطِقُونَ (٣٥)</span> ] ئه‌مه‌ ڕۆژێكه‌ له‌ ساحه‌ی مه‌حشه‌ردا كه‌ كافران و بێباوه‌ڕان هیچ قسه‌ ناكه‌ن، وه‌ ڕێگه‌یان پێ نادرێ كه‌ قسه‌ بكه‌ن."
  77,36,"[ <span class="arabic uthmani">وَلَا يُؤْذَنُ لَهُمْ فَيَعْتَذِرُونَ (٣٦)</span> ] وه‌ ڕێگه‌یان پێ نادرێ كه‌ عوزرو بیانوو بهێننه‌وه‌، چونكه‌ هیچ بیانوویه‌كیان نیه‌و به‌ڵگه‌یان به‌سه‌ردا جێگیر كراوه‌."
  77,37,"[ <span class="arabic uthmani">وَيْلٌ يَوْمَئِذٍ لِلْمُكَذِّبِينَ (٣٧)</span> ] هه‌ڕه‌شه‌ی سه‌خت و سزای ئاگری دۆزه‌خ له‌و ڕۆژه‌دا بۆ ئه‌و كه‌سانه‌ی كه‌ ئه‌و ڕۆژه‌یان به‌درۆ زانیوه‌."
  77,38,"[ <span class="arabic uthmani">هَذَا يَوْمُ الْفَصْلِ جَمَعْنَاكُمْ وَالْأَوَّلِينَ (٣٨)</span> ] ئه‌مه‌ ڕۆژی یه‌كلا بوونه‌وه‌و یه‌كلایی كردنه‌وه‌و جیاكردنه‌وه‌یه‌ كه‌ ئێوه‌و سه‌ره‌تاكان و كۆتاییه‌كانمان هه‌ر هه‌مووی تیادا كۆكردۆته‌وه‌ له‌ یه‌ك شوێنێكدا."
  77,39,"[ <span class="arabic uthmani">فَإِنْ كَانَ لَكُمْ كَيْدٌ فَكِيدُونِ (٣٩)</span> ] ئه‌گه‌ر هه‌ر نه‌خشه‌و پیلان و فێڵێكتان هه‌یه‌ بۆ ئه‌وه‌ی كه‌ خۆتان ڕزگار بكه‌ن فه‌رموو بیكه‌ن، به‌ڵام كه‌س تواناو ده‌سه‌ڵاتی نیه‌."
  77,40,"[ <span class="arabic uthmani">وَيْلٌ يَوْمَئِذٍ لِلْمُكَذِّبِينَ (٤٠)</span> ] هه‌ڕه‌شه‌ی سه‌خت و سزای ئاگری دۆزه‌خ له‌و ڕۆژه‌دا بۆ ئه‌و كه‌سانه‌ی كه‌ باوه‌ڕیان به‌و ڕۆژه‌ نه‌بووه‌و به‌درۆیان زانیوه‌."
  77,41,"{پاداشتى موتته‌قى و خۆپارێزان له‌ به‌هه‌شتدا}
 [ <span class="arabic uthmani">إِنَّ الْمُتَّقِينَ فِي ظِلَالٍ وَعُيُونٍ (٤١)</span> ] به‌ڵام ئه‌و كه‌سانه‌ی كه‌ ته‌قوای خوای گه‌وره‌یان كردووه‌و خۆیان له‌ تاوان پاراستووه‌ له‌ ترسی خوای گه‌وره‌ ئه‌مانه‌ له‌ سێبه‌ری دارو كۆشكه‌كانی به‌هه‌شتدان، وه‌ سه‌رچاوه‌ی ئاوی سازگاریان له‌ به‌هه‌شته‌وه‌ بۆ ده‌رئه‌چێ."
  77,42,"[ <span class="arabic uthmani">وَفَوَاكِهَ مِمَّا يَشْتَهُونَ (٤٢)</span> ] وه‌ جۆره‌ها میوه‌ كه‌ حه‌زو ئاره‌زووی بكه‌ن بۆیان دێت و پێیان ئه‌به‌خشرێ."
  77,43,"[ <span class="arabic uthmani">كُلُوا وَاشْرَبُوا هَنِيئًا بِمَا كُنْتُمْ تَعْمَلُونَ (٤٣)</span> ] پێیان ئه‌ووترێ بخۆن و بخۆنه‌وه‌ نۆشی گیانتان بێ ئه‌مه‌ به‌هۆی ئه‌و كرده‌وه‌ چاكانه‌یه‌ كه‌ له‌ دونیادا ئه‌نجامتاندا."
  77,44,"[ <span class="arabic uthmani">إِنَّا كَذَلِكَ نَجْزِي الْمُحْسِنِينَ (٤٤)</span> ] ئێمه‌ به‌م شێوازه‌ پاداشتی چاكه‌كاران ئه‌ده‌ینه‌وه‌ به‌ به‌هه‌شت."
  77,45,"[ <span class="arabic uthmani">وَيْلٌ يَوْمَئِذٍ لِلْمُكَذِّبِينَ (٤٥)</span> ] هه‌ڕه‌شه‌ی سه‌خت و ئاگری دۆزه‌خ له‌و ڕۆژه‌دا بۆ ئه‌و كه‌سانه‌ی كه‌ ڕۆژی قیامه‌تیان به‌درۆ زانیوه‌و باوه‌ڕیان پێی نه‌بووه‌."
  77,46,"[ <span class="arabic uthmani">كُلُوا وَتَمَتَّعُوا قَلِيلًا إِنَّكُمْ مُجْرِمُونَ (٤٦)</span> ] به‌ كافران و بێباوه‌ڕان ئه‌ووترێ: له‌ دونیادا بخۆن و  كه‌مێك ڕابوێرن له‌به‌ر ئه‌وه‌ی ژیانی دونیا كه‌مه‌، به‌ڵام دواتر ئه‌ی سته‌مكاران و تاوانباران ئه‌گه‌ڕێنه‌وه‌ بۆ سزای خوای گه‌وره‌."
  77,47,"[ <span class="arabic uthmani">وَيْلٌ يَوْمَئِذٍ لِلْمُكَذِّبِينَ (٤٧)</span> ] هه‌ڕه‌شه‌ی سه‌خت و سزای قورس له‌و ڕۆژه‌دا بۆ ئه‌و كه‌سانه‌ی كه‌ باوه‌ڕیان به‌ ڕۆژی دوایی و زیندوو بوونه‌وه‌ نه‌بووه‌."
  77,48,"[ <span class="arabic uthmani">وَإِذَا قِيلَ لَهُمُ ارْكَعُوا لَا يَرْكَعُونَ (٤٨)</span> ] وه‌ كاتێك پێیان بووترایه‌ نوێژ بكه‌ن و ڕكوع به‌رن له‌گه‌ڵ نوێژخوێنانداو نوێژی جه‌ماعه‌ت بكه‌ن ئه‌وان نه‌ئه‌ڕۆیشتن، یاخود وتراوه‌: له‌ ڕۆژی قیامه‌ت كه‌ بانگ ئه‌كرێن بۆ ئه‌وه‌ی سوجده‌ به‌رن مونافیقان پشتیان ناچه‌مێته‌وه."
  77,49,"[ <span class="arabic uthmani">وَيْلٌ يَوْمَئِذٍ لِلْمُكَذِّبِينَ (٤٩)</span> ] هه‌ڕه‌شه‌ی سه‌خت و سزای قورس له‌و ڕۆژه‌دا بۆ ئه‌و كه‌سانه‌ی كه‌ ئه‌و ڕۆژه‌یان به‌درۆ زانیوه‌و باوه‌ڕیان پێی نه‌كردووه‌."
  77,50,"[ <span class="arabic uthmani">فَبِأَيِّ حَدِيثٍ بَعْدَهُ يُؤْمِنُونَ (٥٠)</span> ] ئه‌گه‌ر باوه‌ڕ به‌ قورئانی پیرۆز نه‌كه‌ن ئیتر له‌ پاش قورئان باوه‌ڕ به‌ چ قسه‌و چ فه‌رمووده‌یه‌كی تر ئه‌كه‌ن، (ئه‌م ئایه‌ته‌ به‌ڵگه‌یه‌ له‌سه‌ر ئه‌وه‌ى كه‌ قورئان فه‌رمووده‌و فه‌رمایشت و كه‌لامی خوای گه‌وره‌یه‌)، والله أعلم."