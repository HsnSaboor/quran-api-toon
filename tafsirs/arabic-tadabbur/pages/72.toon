tafsir[8]{c,v,t}:
  3,166,"

الوقفات التدبرية

١- <q>﴿وَمَآ أَصَٰبَكُمْ يَوْمَ ٱلْتَقَى ٱلْجَمْعَانِ فَبِإِذْنِ ٱللَّهِ﴾</q>

أخبر أن ما أصابهم يوم التقى الجمعان -جمع المسلمين وجمع المشركين في أحد- من القتل والهزيمة أنه بإذنه وقضائه وقدره، لا مرد له، ولا بد من وقوعه، والأمر القدري إذا نفذ لم يبق إلا التسليم له، وأنه قدَّره لحكم عظيمة، وفوائد جسيمة، وأنه ليتبين بذلك المؤمن من المنافق. [السعدي: ١٥٦]

السؤال: استفاد المسلمون فائدة من الهزيمة في أُحد، فما هي؟

٢- <q>﴿ٱلَّذِينَ قَالُوا۟ لِإِخْوَٰنِهِمْ وَقَعَدُوا۟ لَوْ أَطَاعُونَا مَا قُتِلُوا۟ ۗ قُلْ فَٱدْرَءُوا۟ عَنْ أَنفُسِكُمُ ٱلْمَوْتَ إِن كُنتُمْ صَٰدِقِينَ ﴿﴾</q>

<q>﴿لو أطاعونا﴾</q> يريد في ألا يخرجوا إلى قريش. وقوله: <q>﴿وقعدوا﴾</q> أي: قالوا هذا القول وقعدوا بأنفسهم عن الجهاد، فرد الله عليهم بقوله: <q>﴿قل فادرؤوا﴾</q> أي: قل لهم يا محمد: إن صدقتم فادفعوا الموت عن أنفسكم. و«الدرء»: الدفع؛ بين بهذا أن الحذر لا ينفع من القدر، وأن المقتول يقتل بأجله، وما علم الله وأخبر به كائن لا محالة. [القرطبي: ٥/٤٠٥]

السؤال: هل للجهاد أثر في توقيت وفاة الإنسان؟

٣- <q>﴿وَلَا تَحْسَبَنَّ ٱلَّذِينَ قُتِلُوا۟ فِى سَبِيلِ ٱللَّهِ أَمْوَٰتًۢا ۚ بَلْ أَحْيَآءٌ عِندَ رَبِّهِمْ يُرْزَقُونَ﴾</q>

<q>﴿بل أحياء﴾</q> إعلام بأن حال الشهداء حال الأحياء من التمتع بأرزاق الجنة، بخلاف سائر الأموات من المؤمنين؛ فإنهم لا يتمتعون بالأرزاق حتى يدخلوا الجنة يوم القيامة. [ابن جزي: ١/١٦٦]

السؤال: ما وجه كون الشهداء أحياء بعد أن قُتِلوا؟

٤- <q>﴿وَلَا تَحْسَبَنَّ ٱلَّذِينَ قُتِلُوا۟ فِى سَبِيلِ ٱللَّهِ أَمْوَٰتًۢا ۚ بَلْ أَحْيَآءٌ عِندَ رَبِّهِمْ يُرْزَقُونَ﴾</q>

ولفظ: <q>﴿عند ربهم﴾</q> يقتضي علو درجتهم، وقربهم من ربهم، <q>﴿يرزقون﴾</q> من أنواع النعيم الذي لا يعلم وصفه إلا من أنعم به عليهم، ومع هذا <q>﴿فرحين بما آتاهم الله من فضله﴾</q> أي: مغتبطين بذلك، قد قرت به عيونهم، وفرحت به نفوسهم؛ وذلك لحسنه وكثرته، وعظمته، وكمال اللذة في الوصول إليه، وعدم المنغص، فجمع الله لهم بين نعيم البدن بالرزق ونعيم القلب والروح بالفرح بما آتاهم من فضله، فتم لهم النعيم والسرور. [السعدي: ١٥٦]

السؤال: يجمع الله للشهيد بين نعيم البدن ونعيم القلب والروح, وضح ذلك؟

٥- <q>﴿فَرِحِينَ بِمَآ ءَاتَىٰهُمُ ٱللَّهُ مِن فَضْلِهِۦ وَيَسْتَبْشِرُونَ بِٱلَّذِينَ لَمْ يَلْحَقُوا۟ بِهِم مِّنْ خَلْفِهِمْ أَلَّا خَوْفٌ عَلَيْهِمْ وَلَا هُمْ يَحْزَنُونَ﴾</q>

لم يفت منهم إلا حياة الكدر التي لا مطمع لأحد في بقائها -وإن طال المدى- وبقيت لهم حياة الصفاء؛ التي لا انفكاك لها، ولا آخر لنعيمها، فلا فتنة تنالهم، ولا حزن يعتريهم، ولا دهش يلم بهم في وقت الحشر، ولا غيره. [البقاعي: ٢/١٨٠]

السؤال: ما حال الذين يقتلون في سبيل الله؟

٦- <q>﴿وَيَسْتَبْشِرُونَ بِٱلَّذِينَ لَمْ يَلْحَقُوا۟ بِهِم مِّنْ خَلْفِهِمْ أَلَّا خَوْفٌ عَلَيْهِمْ وَلَا هُمْ يَحْزَنُونَ﴾</q>

من إخوانهم الذين تركوهم أحياء في الدنيا على مناهج الإيمان والجهاد؛ لعلمهم أنهم إذا استشهدوا ولحقوا بهم، ونالوا من الكرامة ما نالوا؛ فهم لذلك مستبشرون. [البغوي: ١/٤٤٨]

السؤال: لماذا يستبشر الشهداء لحال إخوانهم في الدنيا؟

٧- <q>﴿ٱلَّذِينَ قَالَ لَهُمُ ٱلنَّاسُ إِنَّ ٱلنَّاسَ قَدْ جَمَعُوا۟ لَكُمْ فَٱخْشَوْهُمْ فَزَادَهُمْ إِيمَٰنًا وَقَالُوا۟ حَسْبُنَا ٱللَّهُ وَنِعْمَ ٱلْوَكِيلُ﴾</q>

<q>﴿حسبنا الله ونعم الوكيل﴾</q> كلمة يدفع بها ما يخاف ويكره, وهي التي قالها إبراهيم- عليه السلام- حين ألقي في النار، ومعنى «حسبنا الله»: كافينا وحده؛ فلا نخاف غيره، ومعنى: «ونعم الوكيل»: ثناء على الله، وأنه خير من يتوكل العبد عليه، ويلجأ إليه. <q>﴿فانقلبوا﴾</q> أي: رجعوا بنعمة السلامة، وفضل الأجر. [ابن جزي: ١/١٦٧]

السؤال: ما معنى قول <q>﴿حسبنا الله ونعم الوكيل﴾</q>؟

التوجيهات

١- تيقن أن كل الأحداث التي تحصل في العالم سبق بها علم الله تعالى، ولا تحدث إلا بإذنه، وأن لها حكماً عظيمة، <q>﴿وَمَآ أَصَٰبَكُمْ يَوْمَ ٱلْتَقَى ٱلْجَمْعَانِ فَبِإِذْنِ ٱللَّهِ وَلِيَعْلَمَ ٱلْمُؤْمِنِينَ﴾</q>

٢- احذر المثبطين عن الخير، المقبلين على الدنيا، الراغبين في مصالحهم الخاصة، <q>﴿ٱلَّذِينَ قَالُوا۟ لِإِخْوَٰنِهِمْ وَقَعَدُوا۟ لَوْ أَطَاعُونَا مَا قُتِلُوا۟﴾</q>

٣- لا خوف ينال المؤمن الصالح إذا مات، ولا حزن يصيبه، <q>﴿فَرِحِينَ بِمَآ ءَاتَىٰهُمُ ٱللَّهُ مِن فَضْلِهِۦ وَيَسْتَبْشِرُونَ بِٱلَّذِينَ لَمْ يَلْحَقُوا۟ بِهِم مِّنْ خَلْفِهِمْ أَلَّا خَوْفٌ عَلَيْهِمْ وَلَا هُمْ يَحْزَنُونَ﴾</q>

العمل بالآيات

١- إذا قرأت أو سمعت في نشرات الأخبار عن مصيبة حلت بمسلمين فقل: «لا حول ولا قوة إلا بالله»، <q>﴿وَمَآ أَصَٰبَكُمْ يَوْمَ ٱلْتَقَى ٱلْجَمْعَانِ فَبِإِذْنِ ٱللَّهِ وَلِيَعْلَمَ ٱلْمُؤْمِنِينَ﴾</q>

٢- اقرأ كتاباً، أو استمع إلى محاضرة عن فضل الشهادة في سبيل الله، <q>﴿وَلَا تَحْسَبَنَّ ٱلَّذِينَ قُتِلُوا۟ فِى سَبِيلِ ٱللَّهِ أَمْوَٰتًۢا ۚ بَلْ أَحْيَآءٌ عِندَ رَبِّهِمْ يُرْزَقُونَ﴾</q>

٣- حدد ثلاثا من الشبهات التي تثار على الدعاة أو المجاهدين، ورد عليها من خلال آيات القرآن، <q>﴿ٱلَّذِينَ قَالُوا۟ لِإِخْوَٰنِهِمْ وَقَعَدُوا۟ لَوْ أَطَاعُونَا مَا قُتِلُوا۟ ۗ قُلْ فَٱدْرَءُوا۟ عَنْ أَنفُسِكُمُ ٱلْمَوْتَ إِن كُنتُمْ صَٰدِقِينَ﴾</q>

معاني الكلمات

<q>﴿الْقَرْحُ﴾</q> الْجِرَاحُ، وَالأَلَمُ.

<q>﴿حَسْبُنَا﴾</q> كَافِينَا.

