tafsir[13]{c,v,t}:
  27,64,"

الوقفات التدبرية

١- <q>﴿قُل لَّا يَعْلَمُ مَن فِى ٱلسَّمَٰوَٰتِ وَٱلْأَرْضِ ٱلْغَيْبَ إِلَّا ٱللَّهُ ۚ وَمَا يَشْعُرُونَ أَيَّانَ يُبْعَثُونَ﴾</q>

لما أبطلت الآيات السابقة إلهية أصنام المشركين بالأدلة المتظاهرة فانقطع دابر عقيدة الإشراك، ثني عنان الإبطال إلى أثر من آثار الشرك؛ وهو ادعاء علم الغيب بالكهانة، وإخبار الجن. [ابن عاشور:٢٠/١٩]

السؤال: أبطلت الآيات الكريمة أثراً من آثار الشرك، فما هو؟

٢- <q>﴿بَلِ ٱدَّٰرَكَ عِلْمُهُمْ فِى ٱلْءَاخِرَةِ ۚ بَلْ هُمْ فِى شَكٍّ مِّنْهَا ۖ بَلْ هُم مِّنْهَا عَمُونَ﴾</q>

فانتقل في الإخبار عن أحوال هؤلاء المكذبين بالإخبار أنهم لا يدرون متى وقت الآخرة، ثم الإخبار بضعف علمهم فيها، ثم الإخبار بأنه شك، ثم الإخبار بأنه عمى، ثم الإخبار بإنكارهم لذلك، واستبعادهم وقوعه، أي: وبسبب هذه الأحوال ترحَّل خوف الآخرة من قلوبهم، فأقدموا على معاصي الله، وسهل عليهم تكذيب الحق، والتصديق بالباطل، واستحلوا الشهوات على القيام بالعبادات؛ فخسروا دنياهم وأخراهم. [السعدي:٦٠٩]

السؤال: ما السبب الذي جعل الكفار مقدمين على أنواع المعاصي، ومتجرئين عليها؟

٣- <q>﴿قُلْ سِيرُوا۟ فِى ٱلْأَرْضِ فَٱنظُرُوا۟ كَيْفَ كَانَ عَٰقِبَةُ ٱلْمُجْرِمِينَ﴾</q>

ثم وعظهم تعالى بحال من كذب من الأمم، فأمر نبيه أن يأمرهم بالسير والتطلع على حال مجرمي الأمم، وبالحذر أن يصيبهم مثل ما أصاب أولئك. [ابن عطية:٤/٢٦٩]

السؤال: ما الفائدة من قراءة سير المجرمين وتاريخهم؟

٤- <q>﴿وَلَا تَحْزَنْ عَلَيْهِمْ وَلَا تَكُن فِى ضَيْقٍ مِّمَّا يَمْكُرُونَ﴾</q>

كانت الرحمة غالبة على النبي- صلى الله عليه وسلم- والشفقة على الأمة من خلاله، فلما أُنذر المكذبون بهذا الوعيد؛ تحركت الشفقة في نفس الرسول- عليه الصلاة والسلام- فربط الله على قلبه بهذا التشجيع أن لا يحزن عليهم إذا أصابهم ما أنذروا به. [ابن عاشور:٢٠/٢٦]

السؤال: كيف دلت الآية على رحمته ﷺ بالخلق؟

٥- <q>﴿قُلْ عَسَىٰٓ أَن يَكُونَ رَدِفَ لَكُم بَعْضُ ٱلَّذِى تَسْتَعْجِلُونَ (٧٢) وَإِنَّ رَبَّكَ لَذُو فَضْلٍ عَلَى ٱلنَّاسِ وَلَٰكِنَّ أَكْثَرَهُمْ لَا يَشْكُرُونَ﴾</q>

وهذا خبر خاص بالنبي ﷺ تنبيهاً على أن تأخير الوعيد أثر من آثار رحمة الله؛ لأن أزمنة التأخير أزمنة إمهال، فهم فيها بنعمة. [ابن عاشور:٢٠/٢٨]

السؤال: تأخير العذاب أثر من آثار رحمة الله تعالى، بين ذلك.

٦- <q>﴿وَإِنَّ رَبَّكَ لَيَعْلَمُ مَا تُكِنُّ صُدُورُهُمْ وَمَا يُعْلِنُونَ﴾</q>

وفي الآية إيذان بأن لهم قبائح غير ما حكي عنهم، وتقديم الاكتنان ليظهر المراد من استواء الخفي والظاهر في علمه جل وعلا، أو لأن مضمرات الصدور سبب لما يظهر على الجوارح. [الألوسي:١٠/٢٢٨]

السؤال: ما فائدة تقديم علم ما تكنه صدورهم على ما يعلنون؟ وكيف تستدل من الآية على أهمية أعمال القلوب؟

٧- <q>﴿إِنَّ هَٰذَا ٱلْقُرْءَانَ يَقُصُّ عَلَىٰ بَنِىٓ إِسْرَٰٓءِيلَ أَكْثَرَ ٱلَّذِى هُمْ فِيهِ يَخْتَلِفُونَ﴾</q>

والمعنى: إن هذا القرآن يبين لهم ما اختلفوا فيه لو أخذوا به. [القرطبي:١٦/٢٠٤]

السؤال: إذا اختلفنا في أمر من الأمور فأين نجد المخرج؟

التوجيهات

١- علم الغيب خاص بالله تعالى، فمن ادعى أنه يعلم غيبا فقد كذب, <q>﴿قُل لَّا يَعْلَمُ مَن فِى ٱلسَّمَٰوَٰتِ وَٱلْأَرْضِ ٱلْغَيْبَ إِلَّا ٱللَّهُ ۚ وَمَا يَشْعُرُونَ أَيَّانَ يُبْعَثُونَ﴾</q>

٢- عدم التصديق باليوم الآخر يجعل العبد متجرئاً على المعاصي, <q>﴿وَقَالَ ٱلَّذِينَ كَفَرُوٓا۟ أَءِذَا كُنَّا تُرَٰبًا وَءَابَآؤُنَآ أَئِنَّا لَمُخْرَجُونَ (٦٧) لَقَدْ وُعِدْنَا هَٰذَا نَحْنُ وَءَابَآؤُنَا مِن قَبْلُ إِنْ هَٰذَآ إِلَّآ أَسَٰطِيرُ ٱلْأَوَّلِينَ﴾</q>

٣- اتباع هدي القرآن فيه العصمة من الاختلاف والفرقة, <q>﴿إِنَّ هَٰذَا ٱلْقُرْءَانَ يَقُصُّ عَلَىٰ بَنِىٓ إِسْرَٰٓءِيلَ أَكْثَرَ ٱلَّذِى هُمْ فِيهِ يَخْتَلِفُونَ﴾</q>

العمل بالآيات

١- انصح من يبحثون عن الغيب من خلال النجوم أو المشعوذين, <q>﴿قُل لَّا يَعْلَمُ مَن فِى ٱلسَّمَٰوَٰتِ وَٱلْأَرْضِ ٱلْغَيْبَ إِلَّا ٱللَّهُ ۚ وَمَا يَشْعُرُونَ أَيَّانَ يُبْعَثُونَ﴾</q>

٢- اقرأ وتأمل في مصارع الظالمين، <q>﴿قُلْ سِيرُوا۟ فِى ٱلْأَرْضِ فَٱنظُرُوا۟ كَيْفَ كَانَ عَٰقِبَةُ ٱلْمُجْرِمِينَ﴾</q>

٣- تذكر خمسا من أكبر نعم الله عليك، ثم اشكر الله تعالى عليها, <q>﴿﴾</q> وَإِنَّ رَبَّكَ لَذُو فَضْلٍ عَلَى ٱلنَّاسِ وَلَٰكِنَّ أَكْثَرَهُمْ لَا يَشْكُرُونَ﴾

معاني الكلمات

<q>﴿وَمَا يَشْعُرُونَ﴾</q> مَا يَعْلَمُونَ.

<q>﴿أَيَّانَ﴾</q> مَتَى؟

<q>﴿ادَّارَكَ﴾</q> تَكَامَلَ أَوِ انْتَهَى عِلْمُهُمْ وَعَجَزَ عَنْ مَعْرِفَةِ وَقْتِهَا.

<q>﴿عَمُونَ﴾</q> عَمِيَتْ بَصَائِرُهُمْ عَنْهَا.

<q>﴿أَسَاطِيرُ الأَوَّلِينَ﴾</q> مَا سَطَّرَ القُدَمَاءُ مِنَ الأَكَاذِيبِ.

<q>﴿رَدِفَ لَكُمْ﴾</q> اقْتَرَبَ لَكُمْ.

<q>﴿تُكِنُّ﴾</q> تُخْفِي.

<q>﴿غَائِبَةٍ﴾</q> شَيْءٍ غَائِبٍ عَنِ الأَبْصَارِ.

<q>﴿كِتَابٍ مُبِينٍ﴾</q> هُوَ: اللَّوْحُ المَحْفُوظُ.

