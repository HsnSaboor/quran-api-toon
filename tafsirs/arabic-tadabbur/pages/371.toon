tafsir[28]{c,v,t}:
  26,84,"

الوقفات التدبرية

١- <q>﴿وَٱجْعَل لِّى لِسَانَ صِدْقٍ فِى ٱلْءَاخِرِينَ﴾</q>

<q>﴿لسان صدق في الآخرين﴾</q>: هو الثناء، وخلد المكانة بإجماع من المفسرين. [ابن عطية:٤/٢٣٥]

السؤال: ما المراد بلسان الصدق؟

٢- <q>﴿يَوْمَ لَا يَنفَعُ مَالٌ وَلَا بَنُونَ (٨٨) إِلَّا مَنْ أَتَى ٱللَّهَ بِقَلْبٍ سَلِيمٍ﴾</q>

والمعنى على هذا أن المال لا ينفع إلا من أنفقه في طاعة الله. [ابن جزي:٢/١١٩]

السؤال: متى يكون المال نافعاً للعبد يوم القيامة؟

٣- <q>﴿إِلَّا مَنْ أَتَى ٱللَّهَ بِقَلْبٍ سَلِيمٍ﴾</q>

وخص القلب بالذكر؛ لأنه الذي إذا سلم سلمت الجوارح، وإذا فسد فسدت سائر الجوارح. [القرطبي:١٦/٤٤]

السؤال: لم خص الله تعالى القلب بالذكر؟

٤- <q>﴿وَجُنُودُ إِبْلِيسَ أَجْمَعُونَ﴾</q>

<q>﴿وجُنُودُ إِبْلِيسَ﴾</q>: نسله، وكل من يتبعه؛ لأنهم جند له وأعوان. [ابن عطية:٤/٢٣٦]

السؤال: متى يصير الإنسان من جنود إبليس؟

٥- <q>﴿فَمَا لَنَا مِن شَٰفِعِينَ (١٠٠) وَلَا صَدِيقٍ حَمِيمٍ﴾</q>

قال قتادة: يعلمون والله أن الصديق إذا كان صالحاً نفع، وأن الحميم إذا كان صالحاً شفع. [ابن كثير:٣/٣٢٩]

السؤال: كيف تَحُثُّ هذه الآية على اتخاذ الصديق الصالح؟

٦- <q>﴿إِذْ قَالَ لَهُمْ أَخُوهُمْ نُوحٌ﴾</q>

<q>﴿إذ قال لهم أخوهم﴾</q> في النسب <q>﴿نوح﴾</q>، وإنما ابتعث الله الرسل من نسب من أرسل إليهم لئلا يشمئزوا من الانقياد له، ولأنهم يعرفون حقيقته؛ فلا يحتاجون أن يبحثوا عنه. [السعدي:٥٩٤]

السؤال: لماذا بعث الله الرسلَ من أنساب قومهم؟

٧- <q>﴿قَالُوٓا۟ أَنُؤْمِنُ لَكَ وَٱتَّبَعَكَ ٱلْأَرْذَلُونَ﴾</q>

بهذا يعرف تكبرهم عن الحق، وجهلهم بالحقائق؛ فإنهم لو كان قصدهم الحق لقالوا -إن كان عندهم إشكال وشك في دعوته-: بَيِّن لنا صحة ما جئت به بالطرق الموصلة إلى ذلك. [السعدي:٥٩٤]

السؤال: كيف تدل الآية على تكبرهم عن الحق؟

التوجيهات

١- راقب قلبك، وأصلح من شأنه؛ فلن ينجو إلا من أتى الله بقلب سليم، <q>﴿يَوْمَ لَا يَنفَعُ مَالٌ وَلَا بَنُونَ (٨٨) إِلَّا مَنْ أَتَى ٱللَّهَ بِقَلْبٍ سَلِيمٍ﴾</q>

٢- احذر سبل الغاوين الذين يضلون الناس؛ فقد جعل الله الجحيم مأوى لهم، <q>﴿وَبُرِّزَتِ ٱلْجَحِيمُ لِلْغَاوِينَ﴾</q>

٣- احرص على اتخاذ الرفقة الصالحة؛ فإنهم بعد إذن الله قد ينفعونك بالشفاعة في الآخرة، <q>﴿فَمَا لَنَا مِن شَٰفِعِينَ (١٠٠) وَلَا صَدِيقٍ حَمِيمٍ﴾</q>

العمل بالآيات

١- ادع لوالديك بالمغفرة والرحمة, <q>﴿وَٱغْفِرْ لِأَبِىٓ إِنَّهُۥ كَانَ مِنَ ٱلضَّآلِّينَ﴾</q>

٢- صادق من تقربك صداقته إلى الله تعالى، <q>﴿وَلَا صَدِيقٍ حَمِيمٍ﴾</q>

٣- علم أحداً من المسلمين سورة من سور القرآن الكريم ابتغاء وجه الله, <q>﴿وَمَآ أَسْـَٔلُكُمْ عَلَيْهِ مِنْ أَجْرٍ ۖ إِنْ أَجْرِىَ إِلَّا عَلَىٰ رَبِّ ٱلْعَٰلَمِينَ﴾</q>

معاني الكلمات

<q>﴿لِسَانَ صِدْقٍ﴾</q> ثَنَاءً حَسَنًا.

<q>﴿الآخَرِينَ﴾</q> مَنْ يَأْتُونَ بَعْدِي إِلَى يَوْمِ القِيَامَةِ.

<q>﴿سَلِيمٍ﴾</q> سَالِمٍ مِنَ الشِّرْكِ وَالنِّفَاقِ وَالضَّغِينَةِ.

<q>﴿وَأُزْلِفَتِ﴾</q> قُرِّبَتْ.

<q>﴿وَبُرِّزَتِ﴾</q> أُظْهِرَتْ.

<q>﴿فَكُبْكِبُوا﴾</q> فَجُمِعُوا، وَأُلْقُوا.

<q>﴿حَمِيمٍ﴾</q> مُشْفِقٍ يَهْتَمُّ بِأَمْرِنَا.

<q>﴿كَرَّةً﴾</q> رَجْعَةً إِلَى الدُّنْيَا.

<q>﴿الأَرْذَلُونَ﴾</q> السَّفَلَةُ مِنَ النَّاسِ.

