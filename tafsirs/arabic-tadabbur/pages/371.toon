quran[28]{c,v,t}:
  26,84,"<div class=ar lang=ar><h3>الوقفات التدبرية</h3><p>١- <span class="qpc-hafs">﴿وَٱجْعَل لِّى لِسَانَ صِدْقٍ فِى ٱلْءَاخِرِينَ﴾</span></p><p><span class="qpc-hafs">﴿لسان صدق في الآخرين﴾</span>: هو الثناء، وخلد المكانة بإجماع من المفسرين. [ابن عطية:٤/٢٣٥]</p><p>السؤال: ما المراد بلسان الصدق؟</p><p>٢- <span class="qpc-hafs">﴿يَوْمَ لَا يَنفَعُ مَالٌ وَلَا بَنُونَ (٨٨) إِلَّا مَنْ أَتَى ٱللَّهَ بِقَلْبٍ سَلِيمٍ﴾</span></p><p>والمعنى على هذا أن المال لا ينفع إلا من أنفقه في طاعة الله. [ابن جزي:٢/١١٩]</p><p>السؤال: متى يكون المال نافعاً للعبد يوم القيامة؟</p><p>٣- <span class="qpc-hafs">﴿إِلَّا مَنْ أَتَى ٱللَّهَ بِقَلْبٍ سَلِيمٍ﴾</span></p><p>وخص القلب بالذكر؛ لأنه الذي إذا سلم سلمت الجوارح، وإذا فسد فسدت سائر الجوارح. [القرطبي:١٦/٤٤]</p><p>السؤال: لم خص الله تعالى القلب بالذكر؟</p><p>٤- <span class="qpc-hafs">﴿وَجُنُودُ إِبْلِيسَ أَجْمَعُونَ﴾</span></p><p><span class="qpc-hafs">﴿وجُنُودُ إِبْلِيسَ﴾</span>: نسله، وكل من يتبعه؛ لأنهم جند له وأعوان. [ابن عطية:٤/٢٣٦]</p><p>السؤال: متى يصير الإنسان من جنود إبليس؟</p><p>٥- <span class="qpc-hafs">﴿فَمَا لَنَا مِن شَٰفِعِينَ (١٠٠) وَلَا صَدِيقٍ حَمِيمٍ﴾</span></p><p>قال قتادة: يعلمون والله أن الصديق إذا كان صالحاً نفع، وأن الحميم إذا كان صالحاً شفع. [ابن كثير:٣/٣٢٩]</p><p>السؤال: كيف تَحُثُّ هذه الآية على اتخاذ الصديق الصالح؟</p><p>٦- <span class="qpc-hafs">﴿إِذْ قَالَ لَهُمْ أَخُوهُمْ نُوحٌ﴾</span></p><p><span class="qpc-hafs">﴿إذ قال لهم أخوهم﴾</span> في النسب <span class="qpc-hafs">﴿نوح﴾</span>، وإنما ابتعث الله الرسل من نسب من أرسل إليهم لئلا يشمئزوا من الانقياد له، ولأنهم يعرفون حقيقته؛ فلا يحتاجون أن يبحثوا عنه. [السعدي:٥٩٤]</p><p>السؤال: لماذا بعث الله الرسلَ من أنساب قومهم؟</p><p>٧- <span class="qpc-hafs">﴿قَالُوٓا۟ أَنُؤْمِنُ لَكَ وَٱتَّبَعَكَ ٱلْأَرْذَلُونَ﴾</span></p><p>بهذا يعرف تكبرهم عن الحق، وجهلهم بالحقائق؛ فإنهم لو كان قصدهم الحق لقالوا -إن كان عندهم إشكال وشك في دعوته-: بَيِّن لنا صحة ما جئت به بالطرق الموصلة إلى ذلك. [السعدي:٥٩٤]</p><p>السؤال: كيف تدل الآية على تكبرهم عن الحق؟</p><h3>التوجيهات</h3><p>١- راقب قلبك، وأصلح من شأنه؛ فلن ينجو إلا من أتى الله بقلب سليم، <span class="qpc-hafs">﴿يَوْمَ لَا يَنفَعُ مَالٌ وَلَا بَنُونَ (٨٨) إِلَّا مَنْ أَتَى ٱللَّهَ بِقَلْبٍ سَلِيمٍ﴾</span></p><p>٢- احذر سبل الغاوين الذين يضلون الناس؛ فقد جعل الله الجحيم مأوى لهم، <span class="qpc-hafs">﴿وَبُرِّزَتِ ٱلْجَحِيمُ لِلْغَاوِينَ﴾</span></p><p>٣- احرص على اتخاذ الرفقة الصالحة؛ فإنهم بعد إذن الله قد ينفعونك بالشفاعة في الآخرة، <span class="qpc-hafs">﴿فَمَا لَنَا مِن شَٰفِعِينَ (١٠٠) وَلَا صَدِيقٍ حَمِيمٍ﴾</span></p><h3>العمل بالآيات</h3><p>١- ادع لوالديك بالمغفرة والرحمة, <span class="qpc-hafs">﴿وَٱغْفِرْ لِأَبِىٓ إِنَّهُۥ كَانَ مِنَ ٱلضَّآلِّينَ﴾</span></p><p>٢- صادق من تقربك صداقته إلى الله تعالى، <span class="qpc-hafs">﴿وَلَا صَدِيقٍ حَمِيمٍ﴾</span></p><p>٣- علم أحداً من المسلمين سورة من سور القرآن الكريم ابتغاء وجه الله, <span class="qpc-hafs">﴿وَمَآ أَسْـَٔلُكُمْ عَلَيْهِ مِنْ أَجْرٍ ۖ إِنْ أَجْرِىَ إِلَّا عَلَىٰ رَبِّ ٱلْعَٰلَمِينَ﴾</span></p><h3>معاني الكلمات</h3><p><span class="qpc-hafs">﴿لِسَانَ صِدْقٍ﴾</span> ثَنَاءً حَسَنًا.</p><p><span class="qpc-hafs">﴿الآخَرِينَ﴾</span> مَنْ يَأْتُونَ بَعْدِي إِلَى يَوْمِ القِيَامَةِ.</p><p><span class="qpc-hafs">﴿سَلِيمٍ﴾</span> سَالِمٍ مِنَ الشِّرْكِ وَالنِّفَاقِ وَالضَّغِينَةِ.</p><p><span class="qpc-hafs">﴿وَأُزْلِفَتِ﴾</span> قُرِّبَتْ.</p><p><span class="qpc-hafs">﴿وَبُرِّزَتِ﴾</span> أُظْهِرَتْ.</p><p><span class="qpc-hafs">﴿فَكُبْكِبُوا﴾</span> فَجُمِعُوا، وَأُلْقُوا.</p><p><span class="qpc-hafs">﴿حَمِيمٍ﴾</span> مُشْفِقٍ يَهْتَمُّ بِأَمْرِنَا.</p><p><span class="qpc-hafs">﴿كَرَّةً﴾</span> رَجْعَةً إِلَى الدُّنْيَا.</p><p><span class="qpc-hafs">﴿الأَرْذَلُونَ﴾</span> السَّفَلَةُ مِنَ النَّاسِ.</p></div>"
