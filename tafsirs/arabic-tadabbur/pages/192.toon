quran[5]{c,v,t}:
  9,32,"<div class=ar lang=ar><h3>الوقفات التدبرية</h3><p>١- <span class="qpc-hafs">﴿يُرِيدُونَ أَن يُطْفِـُٔوا۟ نُورَ ٱللَّهِ بِأَفْوَٰهِهِمْ وَيَأْبَى ٱللَّهُ إِلَّآ أَن يُتِمَّ نُورَهُۥ وَلَوْ كَرِهَ ٱلْكَٰفِرُونَ﴾</span></p><p>إضافة النور إلى اسم الجلالة إشارة إلى أن محاولة إطفائه عبث، وأن أصحاب تلك المحاولة لا يبلغون مرادهم. [ابن عاشور:١٠/١٧٢]</p><p>السؤال: ما فائدة إضافة النور إلى الله تعالى؟</p><p>٢- <span class="qpc-hafs">﴿هُوَ ٱلَّذِىٓ أَرْسَلَ رَسُولَهُۥ بِٱلْهُدَىٰ وَدِينِ ٱلْحَقِّ لِيُظْهِرَهُۥ عَلَى ٱلدِّينِ كُلِّهِۦ وَلَوْ كَرِهَ ٱلْمُشْرِكُونَ﴾</span></p><p>وإظهاره: جعله أعلى الأديان وأقواها؛ حتى يعم المشارق والمغارب. [ابن جزي:١/٣٥٦]</p><p>السؤال: ماذا تقول لمن أصابه اليأس من انتصار أهل الإسلام من خلال هذه الآية؟</p><p>٣- <span class="qpc-hafs">﴿يَٰٓأَيُّهَا ٱلَّذِينَ ءَامَنُوٓا۟ إِنَّ كَثِيرًا مِّنَ ٱلْأَحْبَارِ وَٱلرُّهْبَانِ لَيَأْكُلُونَ أَمْوَٰلَ ٱلنَّاسِ بِٱلْبَٰطِلِ وَيَصُدُّونَ عَن سَبِيلِ ٱللَّهِ﴾</span></p><p>والمقصود: التحذير من علماء السوء، وعباد الضلال؛ كما قال سفيان بن عيينة: من فسد من علمائنا كان فيه شبه من اليهود، ومن فسد من عبادنا كان فيه شبه من النصارى. [ابن كثير:٢/٣٣٥]</p><p>السؤال: ما المقصود من التحذير من حال الأحبار والرهبان؟</p><p>٤- <span class="qpc-hafs">﴿يَٰٓأَيُّهَا ٱلَّذِينَ ءَامَنُوٓا۟ إِنَّ كَثِيرًا مِّنَ ٱلْأَحْبَارِ وَٱلرُّهْبَانِ لَيَأْكُلُونَ أَمْوَٰلَ ٱلنَّاسِ بِٱلْبَٰطِلِ وَيَصُدُّونَ عَن سَبِيلِ ٱللَّهِ ۗ وَٱلَّذِينَ يَكْنِزُونَ ٱلذَّهَبَ وَٱلْفِضَّةَ وَلَا يُنفِقُونَهَا فِى سَبِيلِ ٱللَّهِ فَبَشِّرْهُم بِعَذَابٍ أَلِيمٍ﴾</span></p><p>فإن الناس عالةٌ على العلماء، وعلى العباد، وعلى أرباب الأموال، فإذا فسدت أحوال هؤلاء فسدت أحوال الناس. [ابن كثير:٢/٣٣٥]</p><p>السؤال: لِمَ خص الله الأحبار وهم العلماء، والرهبان وهم العباد، والأغنياء بالتحذير؟</p><p>٥- <span class="qpc-hafs">﴿وَٱلَّذِينَ يَكْنِزُونَ ٱلذَّهَبَ وَٱلْفِضَّةَ وَلَا يُنفِقُونَهَا فِى سَبِيلِ ٱللَّهِ فَبَشِّرْهُم بِعَذَابٍ أَلِيمٍ (٣٤) يَوْمَ يُحْمَىٰ عَلَيْهَا فِى نَارِ جَهَنَّمَ فَتُكْوَىٰ بِهَا جِبَاهُهُمْ وَجُنُوبُهُمْ وَظُهُورُهُمْ ۖ هَٰذَا مَا كَنَزْتُمْ لِأَنفُسِكُمْ فَذُوقُوا۟ مَا كُنتُمْ تَكْنِزُونَ﴾</span></p><p>يُقال: من أحب شيئاً وقَدَّمَه على طاعة الله عُذِّبَ به، وهؤلاء لما كان جمع هذه الأموال آثر عندهم من رضا الله عنهم عذبوا بها ... هذه الأموال لما كانت أعز الأموال على أربابها كانت أضر الأشياء عليهم في الدار الآخرة. [ابن كثير:٢/٣٣٦]</p><p>السؤال: من أحب شيئاً وقَدَّمَه على طاعة الله عُذِّبَ به، وضح ذلك من خلال الآية.</p><p>٦- <span class="qpc-hafs">﴿إِنَّ عِدَّةَ ٱلشُّهُورِ عِندَ ٱللَّهِ ٱثْنَا عَشَرَ شَهْرًا فِى كِتَٰبِ ٱللَّهِ يَوْمَ خَلَقَ ٱلسَّمَٰوَٰتِ وَٱلْأَرْضَ مِنْهَآ أَرْبَعَةٌ حُرُمٌ﴾</span></p><p>هذه الآية تدل على أن الواجب تعليق الأحكام من العبادات وغيرها؛ إنما يكون بالشهور والسنين التي تعرفها العرب دون الشهور التي تعتبرها العجم، والروم، والقبط. [القرطبي:١٠/١٩٧]</p><p>السؤال: كثرت الدعوة لترك الشهور العربية، والاعتياض عنها بالشهور الأجنبية، فما التوجيه القرآني في ذلك؟</p><p>٧- <span class="qpc-hafs">﴿وَقَٰتِلُوا۟ ٱلْمُشْرِكِينَ كَآفَّةً كَمَا يُقَٰتِلُونَكُمْ كَآفَّةً ۚ وَٱعْلَمُوٓا۟ أَنَّ ٱللَّهَ مَعَ ٱلْمُتَّقِينَ﴾</span></p><p><span class="qpc-hafs">﴿واعلموا أن الله مع المتقين﴾</span> فلتحرصوا على استعمال تقوى الله في سركم وعلنكم، والقيام بطاعته، خصوصاً عند قتال الكفار؛ فإنه في هذه الحال ربما ترك المؤمن العمل بالتقوى في معاملة الكفار الأعداء المحاربين. [السعدي:٣٣٦]</p><p>السؤال: لماذا أُمِرَ بالتقوى بعد الأمر بمقاتلة الكفار؟</p><h3>التوجيهات</h3><p>١- بيان عداء قادة اليهود والنصارى للإسلام، وتعاونهم على إفساده، وإفساد أهله، <span class="qpc-hafs">﴿يُرِيدُونَ أَن يُطْفِـُٔوا۟ نُورَ ٱللَّهِ بِأَفْوَٰهِهِمْ وَيَأْبَى ٱللَّهُ إِلَّآ أَن يُتِمَّ نُورَهُۥ وَلَوْ كَرِهَ ٱلْكَٰفِرُونَ﴾</span></p><p>٢- بشرى للمسلمين بأن الإسلام سيصبح هو الدين الذي يعبد الله به في الأرض لا غيره، <span class="qpc-hafs">﴿هُوَ ٱلَّذِىٓ أَرْسَلَ رَسُولَهُۥ بِٱلْهُدَىٰ وَدِينِ ٱلْحَقِّ لِيُظْهِرَهُۥ عَلَى ٱلدِّينِ كُلِّهِۦ وَلَوْ كَرِهَ ٱلْمُشْرِكُونَ﴾</span></p><p>٣- انظر كيف يكون المال جحيماً على أصحابه يوم القيامة إذا لم يؤدوا الزكاة الواجبة، <span class="qpc-hafs">﴿يَوْمَ يُحْمَىٰ عَلَيْهَا فِى نَارِ جَهَنَّمَ فَتُكْوَىٰ بِهَا جِبَاهُهُمْ وَجُنُوبُهُمْ وَظُهُورُهُمْ ۖ هَٰذَا مَا كَنَزْتُمْ لِأَنفُسِكُمْ فَذُوقُوا۟ مَا كُنتُمْ تَكْنِزُونَ﴾</span></p><h3>العمل بالآيات</h3><p>١- راجع زكاة أموالك، وتصدق بصدقة مستحبة، <span class="qpc-hafs">﴿وَٱلَّذِينَ يَكْنِزُونَ ٱلذَّهَبَ وَٱلْفِضَّةَ وَلَا يُنفِقُونَهَا فِى سَبِيلِ ٱللَّهِ فَبَشِّرْهُم بِعَذَابٍ أَلِيمٍ﴾</span></p><p>٢- من أقوى أسباب انتشار الشرك والبدع: الأموال التي تدفع لأئمتها المضلين، <span class="qpc-hafs">﴿يَٰٓأَيُّهَا ٱلَّذِينَ ءَامَنُوٓا۟ إِنَّ كَثِيرًا مِّنَ ٱلْأَحْبَارِ وَٱلرُّهْبَانِ لَيَأْكُلُونَ أَمْوَٰلَ ٱلنَّاسِ بِٱلْبَٰطِلِ﴾</span></p><p>٣- ابدأ من اليوم بإظهار الأشهر الهجرية في تعاملاتك قدر استطاعتك؛ فهي المقدمة عند الله، وهي من مظاهر الدين الإسلامي، <span class="qpc-hafs">﴿إِنَّ عِدَّةَ ٱلشُّهُورِ عِندَ ٱللَّهِ ٱثْنَا عَشَرَ شَهْرًا فِى كِتَٰبِ ٱللَّهِ يَوْمَ خَلَقَ ٱلسَّمَٰوَٰتِ وَٱلْأَرْضَ مِنْهَآ أَرْبَعَةٌ حُرُمٌ﴾</span></p><h3>معاني الكلمات</h3><p><span class="qpc-hafs">﴿لِيُظْهِرَهُ﴾</span> لِيُعْلِيَهُ.</p><p><span class="qpc-hafs">﴿لَيَأْكُلُونَ﴾</span> لَيَأْخُذُونَ.</p><p><span class="qpc-hafs">﴿يَكْنِزُونَ﴾</span> لاَ يُؤَدُّونَ الزَّكَاةَ.</p><p><span class="qpc-hafs">﴿كِتَابِ اللَّهِ﴾</span> اللَّوْحِ المَحْفُوظِ.</p><p><span class="qpc-hafs">﴿أَرْبَعَةٌ حُرُمٌ﴾</span> حَرَّمَ اللهُ فِيهَا القِتَالَ، وَهِيَ: ذُو القَعْدَةِ، وَذُو الحِجَّةِ، وَالمُحَرَّمُ، وَرَجَبٌ.</p></div>"
  9,33,"9:32"
  9,34,"9:32"
  9,35,"9:32"
  9,36,"9:32"