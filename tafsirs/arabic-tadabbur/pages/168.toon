quran[6]{c,v,t}:
  7,144,"

الوقفات التدبرية

١- <q>﴿قَالَ يَٰمُوسَىٰٓ إِنِّى ٱصْطَفَيْتُكَ عَلَى ٱلنَّاسِ﴾</q>

يذكر تعالى أنه خاطب موسى بأنه اصطفاه على عالمي زمانه برسالاته وكلامه، ولا شك أن محمداً -صلى الله عليه وسلم- سيد ولد آدم من الأولين والآخرين، ولهذا اختصه الله بأن جعله خاتم الأنبياء والمرسلين؛ الذي تستمر شريعته إلى قيام الساعة، وأتباعه أكثر من أتباع الأنبياء كلهم. [ابن كثير:٢/٢٣٦]

السؤال: هل تدل الآية على تفضيل موسى على نبينا عليهما الصلاة والسلام؟

٢- <q>﴿قَالَ يَٰمُوسَىٰٓ إِنِّى ٱصْطَفَيْتُكَ عَلَى ٱلنَّاسِ بِرِسَٰلَٰتِى وَبِكَلَٰمِى﴾</q>

فلما منعه الله من رؤيته بعد ما كان متشوقاً إليها، أعطاه خيراً كثيراً. [السعدي:٣٠٢]

السؤال: إذا حَرَم الله الصادقَ خيراً عوضه بخير آخر، كيف تستنبط هذه القاعدة من هذه الآية؟

٣- <q>﴿فَخُذْهَا بِقُوَّةٍ وَأْمُرْ قَوْمَكَ يَأْخُذُوا۟ بِأَحْسَنِهَا ۚ سَأُو۟رِيكُمْ دَارَ ٱلْفَٰسِقِينَ﴾</q>

<q>﴿فخذها بقوة﴾</q> أي: بجد واجتهاد، وقيل: بقوة القلب، وصحة العزيمة؛ لأنه إذا أخذه بضعف النية؛ أداه إلى الفتور. [البغوي:٢/١٥٢]

السؤال: بماذا أُمرنا في أخذ الوحي وتلقيه؟

٤- <q>﴿فَخُذْهَا بِقُوَّةٍ وَأْمُرْ قَوْمَكَ يَأْخُذُوا۟ بِأَحْسَنِهَا ۚ سَأُو۟رِيكُمْ دَارَ ٱلْفَٰسِقِينَ﴾</q>

فدل على أن فيما أنزل حسن وأحسن. [ابن تيمية:٣/١٩٨]

السؤال: التقرب إلى الله سبحانه باتباع الوحي على درجات، وضح ذلك من الآية؟

٥- <q>﴿سَأَصْرِفُ عَنْ ءَايَٰتِىَ ٱلَّذِينَ يَتَكَبَّرُونَ فِى ٱلْأَرْضِ بِغَيْرِ ٱلْحَقِّ وَإِن يَرَوْا۟ كُلَّ ءَايَةٍ لَّا يُؤْمِنُوا۟ بِهَا وَإِن يَرَوْا۟ سَبِيلَ ٱلرُّشْدِ لَا يَتَّخِذُوهُ سَبِيلًا﴾</q>

قال ابن عباس: «يريد: الذين يتجبرون على عبادي، ويحاربون أوليائي حتى لا يؤمنوا بي»؛ يعني: سأصرفهم عن قبول آياتي، والتصديق بها؛ عوقبوا بحرمان الهداية لعنادهم للحق؛ كقوله: <q>﴿فلما زاغوا أزاغ الله قلوبهم﴾</q> [الصف: ٥]. [البغوي:٢/١٥٢]

السؤال: ما أشد عقوبات المتكبرين؟

٦- <q>﴿سَأَصْرِفُ عَنْ ءَايَٰتِىَ ٱلَّذِينَ يَتَكَبَّرُونَ فِى ٱلْأَرْضِ بِغَيْرِ ٱلْحَقِّ﴾</q>

قال بعض السلف: لا ينال العلم حيي ولا مستكبر، وقال آخر: من لم يصبر على ذُلِّ التعلم ساعة بقي في ذُلِّ الجهل أبداً. [ابن كثير:٢/٢٣٧]

السؤال: في هذه الآية بعض الآداب المتعلقة بطالب العلم، اذكر شيئاً منها.

٧- <q>﴿سَأَصْرِفُ عَنْ ءَايَٰتِىَ ٱلَّذِينَ يَتَكَبَّرُونَ فِى ٱلْأَرْضِ بِغَيْرِ ٱلْحَقِّ﴾</q>

إذا كان المصحفُ الذي كُتِب فيه طاهرًا لا يمسُّه إلاّ البدن الطاهر، فالمعاني التي هي باطنُ القرآن لا يمسُّها إلاّ القلوبُ المطهرة، وأما القلوب المنجسة لا تمسُّ حقائقَه، فهذا معنىً صحيح؛ قال تعالى: <q>﴿سأصرف عن آياتي الذين يتكبرون في الأرض بغير الحق﴾</q>. قال بعض السلف: أَمنَعُ قلوبَهم فهمَ القرآن. [ابن تيمية:٣/١٩٨]

السؤال: من خطورة التكبر أنه يؤدي إلى عدم فهم القرآن الكريم، بين ذلك؟

التوجيهات

١- من أقوى عوامل الصرف عن فهم آيات الله: الكبر، <q>﴿سَأَصْرِفُ عَنْ ءَايَٰتِىَ ٱلَّذِينَ يَتَكَبَّرُونَ فِى ٱلْأَرْضِ بِغَيْرِ ٱلْحَقِّ﴾</q>

٢- تقبيح الغباء والجمود، وعدم تفكر الإنسان في حاله وواقعه وما حوله، <q>﴿أَلَمْ يَرَوْا۟ أَنَّهُۥ لَا يُكَلِّمُهُمْ وَلَا يَهْدِيهِمْ سَبِيلًا ۘ ٱتَّخَذُوهُ وَكَانُوا۟ ظَٰلِمِينَ﴾</q>

٣- إذا أراد الله بعبده خيراً ألهمه التوبة بعد المعصية، فندم واستغفر، <q>﴿وَلَمَّا سُقِطَ فِىٓ أَيْدِيهِمْ وَرَأَوْا۟ أَنَّهُمْ قَدْ ضَلُّوا۟ قَالُوا۟ لَئِن لَّمْ يَرْحَمْنَا رَبُّنَا وَيَغْفِرْ لَنَا لَنَكُونَنَّ مِنَ ٱلْخَٰسِرِينَ﴾</q>

العمل بالآيات

١- اتبع اليوم وسيلة جديدة تزيد من جديتك في أخذ كتاب الله؛ مثل العزم على العمل بما قرأت، وشكر الله على تحبيب كتاب الله لك، <q>﴿فَخُذْهَا بِقُوَّةٍ وَأْمُرْ قَوْمَكَ يَأْخُذُوا۟ بِأَحْسَنِهَا﴾</q>

٢- تذكر خمسًا من نعم الله عليك، ثم اشكر الله تعالى عليها، <q>﴿وَكُن مِّنَ ٱلشَّٰكِرِينَ﴾</q>

٣- استعذ بالله تعالى أن يصرف قلبك عن ذكره وفهم كتابه, <q>﴿سَأَصْرِفُ عَنْ ءَايَٰتِىَ ٱلَّذِينَ يَتَكَبَّرُونَ فِى ٱلْأَرْضِ بِغَيْرِ ٱلْحَقِّ﴾</q>

معاني الكلمات

<q>﴿الأَلْوَاحِ﴾</q> أَلْوَاحِ التَّوْرَاةِ.

<q>﴿حَبِطَتْ﴾</q> بَطَلَتْ.

<q>﴿حُلِيِّهِمْ﴾</q> ذَهَبِهِمْ.

<q>﴿خُوَارٌ﴾</q> صَوْتٌ يُسْمَعُ؛ كَصَوْتِ الْبَقَرِ.

<q>﴿سُقِطَ فِي أَيْدِيهِمْ﴾</q> نَدِمُوا.

