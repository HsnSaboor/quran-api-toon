tafsir[5]{c,v,t}:
  33,31,"

الوقفات التدبرية

١- <q>﴿۞ وَمَن يَقْنُتْ مِنكُنَّ لِلَّهِ وَرَسُولِهِۦ وَتَعْمَلْ صَٰلِحًا نُّؤْتِهَآ أَجْرَهَا مَرَّتَيْنِ وَأَعْتَدْنَا لَهَا رِزْقًا كَرِيمًا﴾</q>

في إضافة الأجر إلى ضميرها إشارة إلى تعظيم ذلك الأجر بأنه يناسب مقامها، وإلى تشريفها بأنها مستحقة ذلك الأجر. ومضاعفة الأجر لهن على الطاعات كرامة لقدرهنّ. [ابن عاشور:٢٢/٥]

السؤال: بين منزلة أزواج النبي صلى الله عليه وسلم من خلال الآية الكريمة.

٢- <q>﴿يَٰنِسَآءَ ٱلنَّبِىِّ لَسْتُنَّ كَأَحَدٍ مِّنَ ٱلنِّسَآءِ ۚ إِنِ ٱتَّقَيْتُنَّ﴾</q>

فضلهن الله على النساء بشرط التقوى، وقد حصل لهن التقوى فحصل التفضيل على جميع النساء، إلا أنه يخرج من هذا العموم: فاطمة بنت رسول الله صلى الله عليه وسلم، ومريم بنت عمران، وآسية امرأة فرعون؛ لشهادة رسول الله صلى الله عليه وسلم لكل واحدة منهن بأنها سيدة نساء عالمها. [ابن جزي: ٢/١٨٨]

السؤال: ما قدر أمهات المؤمنين بين النساء؟

٣- <q>﴿فَلَا تَخْضَعْنَ بِٱلْقَوْلِ فَيَطْمَعَ ٱلَّذِى فِى قَلْبِهِۦ مَرَضٌ﴾</q>

مريض القلب، الذي لا يتحمل ما يتحمل الصحيح، ولا يصبر على ما يصبر عليه؛ فأدنى سبب يوجد يدعوه إلى الحرام يجيب دعوته ولا يتعاصى عليه. [السعدي:٦٦٤]

السؤال: لماذا خص القلب المريض بالذكر؟

٤- <q>﴿وَقُلْنَ قَوْلًا مَّعْرُوفًا﴾</q>

لما نهاهن عن الخضوع في القول فربما تُوهِّم أنهن مأمورات بإغلاظ القول، دفع هذا بقوله: <q>﴿وقلن قولاً معروفاً﴾</q> أي: غير غليظ ولا جاف، كما أنه ليس بليِّن خاضع. [السعدي:٦٦٤]

السؤال: لماذا ختم الآية بهذه الجملة<q>﴿وقلن قولاً معروفاً﴾</q> ؟

٥- <q>﴿وَقَرْنَ فِى بُيُوتِكُنَّ﴾</q>

قيل لسودة رضي الله عنها: لم لا تخرجين؟ فقالت: أمرنا الله بأن نقرّ في بيوتنا، وكانت عائشة إذا قرأت هذه الآية تبكي على خروجها أيام الجمل. [ابن جزي: ٢/١٨٨]

السؤال: كيف امتثلت أمهات المؤمنين لهذه الآية؟

٦- <q>﴿إِنَّمَا يُرِيدُ ٱللَّهُ لِيُذْهِبَ عَنكُمُ ٱلرِّجْسَ أَهْلَ ٱلْبَيْتِ﴾</q>

وهذا نص في دخول أزواج النبي ﷺ في أهل البيت هاهنا؛ لأنهن سبب نزول هذه الآية، وسبب النزول داخل فيه قولاً واحداً. [ابن كثير:٣/٤٦٥]

السؤال: رأي الشيعة في آل البيت؟

٧- <q>﴿وَٱلصَّٰٓئِمِينَ وَٱلصَّٰٓئِمَٰتِ وَٱلْحَٰفِظِينَ فُرُوجَهُمْ وَٱلْحَٰفِظَٰتِ﴾</q>

لما كان الصوم من أكبر العون على كسر الشهوة ... ناسب أن يذكر بعده <q>﴿والحافظين فروجهم والحافظات﴾</q>. [ابن كثير:٣/٤٦٩]

السؤال: لماذا ذكر حفظ الفروج بعد الصيام؟

التوجيهات

١- خطورة خضوع النساء في القول، <q>﴿فَلَا تَخْضَعْنَ بِٱلْقَوْلِ فَيَطْمَعَ ٱلَّذِى فِى قَلْبِهِۦ﴾</q>

٢- حرمة التبرج، وأنه من علامات الجاهلية، <q>﴿وَقَرْنَ فِى بُيُوتِكُنَّ وَلَا تَبَرَّجْنَ تَبَرُّجَ ٱلْجَٰهِلِيَّةِ ٱلْأُولَىٰ﴾</q>

٣- قراءة القرآن والأدعية المأثورة في البيوت تحصنها ومن فيها من شياطين الأنس والجن، <q>﴿وَٱذْكُرْنَ مَا يُتْلَىٰ فِى بُيُوتِكُنَّ مِنْ ءَايَٰتِ ٱللَّهِ وَٱلْحِكْمَةِ﴾</q>

العمل بالآيات

١- ذكر أخواتك بعدم الخضوع بالقول عند الحاجة لمخاطبة الرجال غير المحارم، أو الرد على الهاتف،<q>﴿فَلَا تَخْضَعْنَ بِٱلْقَوْلِ فَيَطْمَعَ ٱلَّذِى فِى قَلْبِهِۦ مَرَضٌ وَقُلْنَ قَوْلًا مَّعْرُوفًا﴾</q>

٢- أرسل رسالة عن أهمية قرار المرأة في بيتها، وخاصة في هذا الزمن،<q>﴿وَقَرْنَ فِى بُيُوتِكُنَّ﴾</q>

٣- احرص أن يكون لك في بيتك ورد دائم من كتاب الله، وأحاديث من سنة رسول الله صلى الله عليه وسلم، <q>﴿وَٱذْكُرْنَ مَا يُتْلَىٰ فِى بُيُوتِكُنَّ مِنْ ءَايَٰتِ ٱللَّهِ وَٱلْحِكْمَةِ ۚ إِنَّ ٱللَّهَ كَانَ لَطِيفًا خَبِيرًا﴾</q>

معاني الكلمات

<q>﴿يَقْنُتْ مِنْكُنَّ﴾</q> تُطِعْ مِنْكُنَّ اللهَ وَرَسُولَهُ.

<q>﴿وَأَعْتَدْنَا﴾</q> أَعْدَدْنَا.

<q>﴿اتَّقَيْتُنَّ﴾</q> خِفْتُنَّ اللهَ.

<q>﴿فَلاَ تَخْضَعْنَ بِالْقَوْلِ﴾</q> فَلاَ تَتَحَدَّثْنَ مَعَ الأَجَانِبِ بِصَوْتٍ لَيِّنٍ.

<q>﴿مَرَضٌ﴾</q> شَهْوَةٌ، وَمَيْلٌ إِلَى النِّسَاءِ.

<q>﴿قَوْلاً مَعْرُوفًا﴾</q> قَوْلاً بَعِيدًا عَنِ الرِّيبَةِ.

<q>﴿وَقَرْنَ﴾</q> الْزَمْنَ.

<q>﴿وَلاَ تَبَرَّجْنَ﴾</q> لاَ تُظْهِرْنَ مَحَاسِنَكُنَّ.

<q>﴿الْجَاهِلِيَّةِ الأُولَى﴾</q> الَّتِي قَبْلَ الإِسْلاَمِ.

<q>﴿الرِّجْسَ﴾</q> الأَذَى، وَالسُّوءَ، وَالإِثْمَ.

<q>﴿وَالْحِكْمَةِ﴾</q> أَحَادِيثِ الرَّسُولِ صلّى الله عليه وسلّم.

<q>﴿وَالْقَانِتِينَ﴾</q> المُطِيعِينَ، الخَاضِعِينَ للهِ.

<q>﴿وَالْخَاشِعِينَ﴾</q> الخَائِفِينَ مِنَ اللهِ، المُتَوَاضِعِينَ.

<q>﴿وَالْحَافِظِينَ فُرُوجَهُمْ﴾</q> أَيْ: عَنِ الزِّنَى، وَمُقَدِّمَاتِهِ، وَعَنْ كَشْفِ العَوْرَةِ ومَسِّهَا لِمَنْ لاَ يَحِلُّ لَهُمْ.

"
  33,32,"33:31"
  33,33,"33:31"
  33,34,"33:31"
  33,35,"33:31"
