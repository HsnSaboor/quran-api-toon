tafsir[11]{c,v,t}:
  17,28,"

الوقفات التدبرية

١- <q>﴿وَإِمَّا تُعْرِضَنَّ عَنْهُمُ ٱبْتِغَآءَ رَحْمَةٍ مِّن رَّبِّكَ تَرْجُوهَا فَقُل لَّهُمْ قَوْلًا مَّيْسُورًا﴾</q>

<q>﴿ولا تجعل يدك مغلولة إلى عنقك﴾</q>: استعارة في معنى غاية البخل؛ كأن البخيل حبست يده عن الإعطاء، وشدت إلى عنقه. <q>﴿ولا تبسطها كل البسط﴾</q>: استعارة في معنى غاية الجود. فنهى الله عن الطرفين وأمر بالتوسط بينهما؛ كقوله: <q>﴿والذين إذا أنفقوا لم يسرفوا ولم يقتروا وكان بين ذلك قواماً﴾</q> [الفرقان: ٦٧]. [ابن جزي:١/٤٨٦]

السؤال: جعل الله هذه الشريعة وسطاً, مثل لذلك بمثال.

٢- <q>﴿إِنَّ رَبَّكَ يَبْسُطُ ٱلرِّزْقَ لِمَن يَشَآءُ وَيَقْدِرُ ۚ إِنَّهُۥ كَانَ بِعِبَادِهِۦ خَبِيرًۢا بَصِيرًا﴾</q>

أي: خبير بصير بمن يستحق الغنى، ومن يستحق الفقر؛ فإن من العباد من لا يصلحه إلا الفقر، ولو غني لفسد عليه دينه، وإن من العباد لمن لا يصلحه إلا الغنى، ولو افتقر لفسد عليه دينه، وقد يكون الغنى في حق بعض الناس استدراجاً، والفقر عقوبةً. عياذاً بالله من هذا وهذا. [ابن كثير:٣/٣٧]

السؤال: ما وجه ختم هذه الآية بوصفي الخبير والبصير؟

٣- <q>﴿وَلَا تَقْتُلُوٓا۟ أَوْلَٰدَكُمْ خَشْيَةَ إِمْلَٰقٍ﴾</q>

هذه الآية الكريمة دالة على أن الله تعالى أرحم بعباده من الوالد بولده. [ابن كثير:٣/٣٧]

السؤال: من أرحم بِكَ؟ ربُّك، أم والداك؟ ولماذا؟

٤- <q>﴿وَلَا تَقْرَبُوا۟ ٱلزِّنَىٰٓ﴾</q>

والنهي عن قربانه أبلغ من النهي عن مجرد فعله؛ لأن ذلك يشمل النهي عن جميع مقدماته ودواعيه؛ فإن من حام حول الحمى يوشك أن يقع فيه، خصوصاً هذا الأمر الذي في كثير من النفوس أقوى داعٍ إليه. [السعدي:٤٥٧]

السؤال: ما الفرق بين <q>﴿ولا تقربوا الزنى﴾</q> و«لا تفعلوا الزنا»؟ وأيهما أبلغ وأشد في النهي؟

٥- <q>﴿وَلَا تَقْرَبُوا۟ ٱلزِّنَىٰٓ ۖ إِنَّهُۥ كَانَ فَٰحِشَةً﴾</q>

ووصف الله الزنا وقبَّحه بأنه كان فاحشة أي: إثماً يستفحش في الشرع، والعقل، والفطر؛ لتضمنه التجرؤ على الحرمة في حق الله، وحق المرأة، وحق أهلها، أو زوجها، وإفساد الفراش، واختلاط الأنساب، وغير ذلك من المفاسد. [السعدي:٤٥٧]

السؤال: ما الأسباب التي جعلت الزنا يستحق الوصف بكونه فاحشة؟

٦- <q>﴿وَلَا تَقْفُ مَا لَيْسَ لَكَ بِهِۦ عِلْمٌ ۚ إِنَّ ٱلسَّمْعَ وَٱلْبَصَرَ وَٱلْفُؤَادَ كُلُّ أُو۟لَٰٓئِكَ كَانَ عَنْهُ مَسْـُٔولًا﴾</q>

وهذا أدب خُلقي عظيم، وهو أيضاً إصلاح عقلي جليل؛ يعلم الأمة التفرقة بين مراتب الخواطر العقلية؛ بحيث لا يختلط عندها المعلوم، والمظنون، والموهوم. [ابن عاشور:١٥/١٠١]

السؤال: أرشدت الآية الكريمة إلى أدب خلقي، واصطلاح عقلي، بين ذلك.

٧- <q>﴿وَلَا تَمْشِ فِى ٱلْأَرْضِ مَرَحًا ۖ إِنَّكَ لَن تَخْرِقَ ٱلْأَرْضَ وَلَن تَبْلُغَ ٱلْجِبَالَ طُولًا﴾</q>

أي: مقدرتك لا تبلغ هذا المبلغ، بل أنت عبد ذليل، محاط بك من تحتك، ومن فوقك، والمحاط محصور ضعيف، فلا يليق بك التكبر. [القرطبي:١٣/٨٣]

السؤال: لماذا لا يليق بالعبد الضعيف التكبر؟

التوجيهات

١- ابتعد عن الخطوات التي تؤدي بك إلى الوقوع في الفواحش والمعاصي؛ فإن من حام حول الحمى يوشك أن يقع فيه، <q>﴿وَلَا تَقْرَبُوا۟ ٱلزِّنَىٰٓ﴾</q>

٢- أنت مسؤول يوم القيامة عن العهود والعقود التي عقدتها مع الله، أو مع خلقه؛ فاحرص على الوفاء بها، <q>﴿ۖ إِنَّ ٱلْعَهْدَ كَانَ مَسْـُٔولًا﴾</q>

٣- هذه الجوارح أنت مسؤول عنها أمام الله تعالى ولا يعرف قيمتها إلا من فقدها، فاستعملها في الطاعة، <q>﴿إِنَّ ٱلسَّمْعَ وَٱلْبَصَرَ وَٱلْفُؤَادَ كُلُّ أُو۟لَٰٓئِكَ كَانَ عَنْهُ مَسْـُٔولًا﴾</q>

العمل بالآيات

١- حدد سببا يذكرك المعصية وابتعد عنه، <q>﴿وَلَا تَقْرَبُوا۟ ٱلزِّنَىٰٓ ۖ إِنَّهُۥ كَانَ فَٰحِشَةً وَسَآءَ سَبِيلًا﴾</q>

٢- اكفل يتيما، أو أسهِم في كفالتة عن طريق إحدى المؤسسات الخيرية, <q>﴿وَلَا تَقْرَبُوا۟ مَالَ ٱلْيَتِيمِ إِلَّا بِٱلَّتِى هِىَ أَحْسَنُ حَتَّىٰ يَبْلُغَ أَشُدَّهُۥ﴾</q>

٣- قل: لا أعلم، لا أدري، وعود لسانك هذه الكلمة فيما لا تعرفه، <q>﴿وَلَا تَقْفُ مَا لَيْسَ لَكَ بِهِۦ عِلْمٌ ۚ إِنَّ ٱلسَّمْعَ وَٱلْبَصَرَ وَٱلْفُؤَادَ كُلُّ أُو۟لَٰٓئِكَ كَانَ عَنْهُ مَسْـُٔولًا﴾</q>

معاني الكلمات

<q>﴿مَلُومًا﴾</q> يَلُومُكَ النَّاسُ، وَيَذُمُّونَكَ.

<q>﴿مَحْسُورًا﴾</q> فَارِغَ اليَدِ نَادِمًا، عَلَى تَبْذِيرِكَ.

<q>﴿وَيَقْدِرُ﴾</q> يُضَيِّقُ.

<q>﴿إِمْلاقٍ﴾</q> فَقْرٍ.

<q>﴿خِطْأً﴾</q> ذَنْبًا.

<q>﴿سَبِيلاً﴾</q> طَرِيقًا.

<q>﴿لِوَلِيِّهِ﴾</q> مَنْ تَوَلَّى أَمْرَ القَتِيلِ مِنْ وَارِثٍ، أَوْ حَاكِمٍ.

<q>﴿سُلْطَاناً﴾</q> حُجَّةً.

<q>﴿الْيَتِيمِ﴾</q> مَنْ مَاتَ أَبُوهُ قَبْلَ البُلُوغِ.

<q>﴿بِالْقِسْطَاسِ الْمُسْتَقِيمِ﴾</q> بِالمِيزَانِ السَّوِيِّ.

<q>﴿تَأْوِيلاً﴾</q> عَاقِبَةً عِنْدَ اللهِ فِي الآخِرَةِ.

<q>﴿وَلا تَقْفُ﴾</q> لا تَتْبَعْ.

<q>﴿مَرَحًا﴾</q> مُخْتالاً، مُتَكَبِّرًا.

