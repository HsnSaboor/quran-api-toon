quran[11]{c,v,t}:
  17,28,"<div class=ar lang=ar><h3>الوقفات التدبرية</h3><p>١- <span class="qpc-hafs">﴿وَإِمَّا تُعْرِضَنَّ عَنْهُمُ ٱبْتِغَآءَ رَحْمَةٍ مِّن رَّبِّكَ تَرْجُوهَا فَقُل لَّهُمْ قَوْلًا مَّيْسُورًا﴾</span></p><p><span class="qpc-hafs">﴿ولا تجعل يدك مغلولة إلى عنقك﴾</span>: استعارة في معنى غاية البخل؛ كأن البخيل حبست يده عن الإعطاء، وشدت إلى عنقه. <span class="qpc-hafs">﴿ولا تبسطها كل البسط﴾</span>: استعارة في معنى غاية الجود. فنهى الله عن الطرفين وأمر بالتوسط بينهما؛ كقوله: <span class="qpc-hafs">﴿والذين إذا أنفقوا لم يسرفوا ولم يقتروا وكان بين ذلك قواماً﴾</span> [الفرقان: ٦٧]. [ابن جزي:١/٤٨٦]</p><p>السؤال: جعل الله هذه الشريعة وسطاً, مثل لذلك بمثال.</p><p>٢- <span class="qpc-hafs">﴿إِنَّ رَبَّكَ يَبْسُطُ ٱلرِّزْقَ لِمَن يَشَآءُ وَيَقْدِرُ ۚ إِنَّهُۥ كَانَ بِعِبَادِهِۦ خَبِيرًۢا بَصِيرًا﴾</span></p><p>أي: خبير بصير بمن يستحق الغنى، ومن يستحق الفقر؛ فإن من العباد من لا يصلحه إلا الفقر، ولو غني لفسد عليه دينه، وإن من العباد لمن لا يصلحه إلا الغنى، ولو افتقر لفسد عليه دينه، وقد يكون الغنى في حق بعض الناس استدراجاً، والفقر عقوبةً. عياذاً بالله من هذا وهذا. [ابن كثير:٣/٣٧]</p><p>السؤال: ما وجه ختم هذه الآية بوصفي الخبير والبصير؟</p><p>٣- <span class="qpc-hafs">﴿وَلَا تَقْتُلُوٓا۟ أَوْلَٰدَكُمْ خَشْيَةَ إِمْلَٰقٍ﴾</span></p><p>هذه الآية الكريمة دالة على أن الله تعالى أرحم بعباده من الوالد بولده. [ابن كثير:٣/٣٧]</p><p>السؤال: من أرحم بِكَ؟ ربُّك، أم والداك؟ ولماذا؟</p><p>٤- <span class="qpc-hafs">﴿وَلَا تَقْرَبُوا۟ ٱلزِّنَىٰٓ﴾</span></p><p>والنهي عن قربانه أبلغ من النهي عن مجرد فعله؛ لأن ذلك يشمل النهي عن جميع مقدماته ودواعيه؛ فإن من حام حول الحمى يوشك أن يقع فيه، خصوصاً هذا الأمر الذي في كثير من النفوس أقوى داعٍ إليه. [السعدي:٤٥٧]</p><p>السؤال: ما الفرق بين <span class="qpc-hafs">﴿ولا تقربوا الزنى﴾</span> و«لا تفعلوا الزنا»؟ وأيهما أبلغ وأشد في النهي؟</p><p>٥- <span class="qpc-hafs">﴿وَلَا تَقْرَبُوا۟ ٱلزِّنَىٰٓ ۖ إِنَّهُۥ كَانَ فَٰحِشَةً﴾</span></p><p>ووصف الله الزنا وقبَّحه بأنه كان فاحشة أي: إثماً يستفحش في الشرع، والعقل، والفطر؛ لتضمنه التجرؤ على الحرمة في حق الله، وحق المرأة، وحق أهلها، أو زوجها، وإفساد الفراش، واختلاط الأنساب، وغير ذلك من المفاسد. [السعدي:٤٥٧]</p><p>السؤال: ما الأسباب التي جعلت الزنا يستحق الوصف بكونه فاحشة؟</p><p>٦- <span class="qpc-hafs">﴿وَلَا تَقْفُ مَا لَيْسَ لَكَ بِهِۦ عِلْمٌ ۚ إِنَّ ٱلسَّمْعَ وَٱلْبَصَرَ وَٱلْفُؤَادَ كُلُّ أُو۟لَٰٓئِكَ كَانَ عَنْهُ مَسْـُٔولًا﴾</span></p><p>وهذا أدب خُلقي عظيم، وهو أيضاً إصلاح عقلي جليل؛ يعلم الأمة التفرقة بين مراتب الخواطر العقلية؛ بحيث لا يختلط عندها المعلوم، والمظنون، والموهوم. [ابن عاشور:١٥/١٠١]</p><p>السؤال: أرشدت الآية الكريمة إلى أدب خلقي، واصطلاح عقلي، بين ذلك.</p><p>٧- <span class="qpc-hafs">﴿وَلَا تَمْشِ فِى ٱلْأَرْضِ مَرَحًا ۖ إِنَّكَ لَن تَخْرِقَ ٱلْأَرْضَ وَلَن تَبْلُغَ ٱلْجِبَالَ طُولًا﴾</span></p><p>أي: مقدرتك لا تبلغ هذا المبلغ، بل أنت عبد ذليل، محاط بك من تحتك، ومن فوقك، والمحاط محصور ضعيف، فلا يليق بك التكبر. [القرطبي:١٣/٨٣]</p><p>السؤال: لماذا لا يليق بالعبد الضعيف التكبر؟</p><h3>التوجيهات</h3><p>١- ابتعد عن الخطوات التي تؤدي بك إلى الوقوع في الفواحش والمعاصي؛ فإن من حام حول الحمى يوشك أن يقع فيه، <span class="qpc-hafs">﴿وَلَا تَقْرَبُوا۟ ٱلزِّنَىٰٓ﴾</span></p><p>٢- أنت مسؤول يوم القيامة عن العهود والعقود التي عقدتها مع الله، أو مع خلقه؛ فاحرص على الوفاء بها، <span class="qpc-hafs">﴿ۖ إِنَّ ٱلْعَهْدَ كَانَ مَسْـُٔولًا﴾</span></p><p>٣- هذه الجوارح أنت مسؤول عنها أمام الله تعالى ولا يعرف قيمتها إلا من فقدها، فاستعملها في الطاعة، <span class="qpc-hafs">﴿إِنَّ ٱلسَّمْعَ وَٱلْبَصَرَ وَٱلْفُؤَادَ كُلُّ أُو۟لَٰٓئِكَ كَانَ عَنْهُ مَسْـُٔولًا﴾</span></p><h3>العمل بالآيات</h3><p>١- حدد سببا يذكرك المعصية وابتعد عنه، <span class="qpc-hafs">﴿وَلَا تَقْرَبُوا۟ ٱلزِّنَىٰٓ ۖ إِنَّهُۥ كَانَ فَٰحِشَةً وَسَآءَ سَبِيلًا﴾</span></p><p>٢- اكفل يتيما، أو أسهِم في كفالتة عن طريق إحدى المؤسسات الخيرية, <span class="qpc-hafs">﴿وَلَا تَقْرَبُوا۟ مَالَ ٱلْيَتِيمِ إِلَّا بِٱلَّتِى هِىَ أَحْسَنُ حَتَّىٰ يَبْلُغَ أَشُدَّهُۥ﴾</span></p><p>٣- قل: لا أعلم، لا أدري، وعود لسانك هذه الكلمة فيما لا تعرفه، <span class="qpc-hafs">﴿وَلَا تَقْفُ مَا لَيْسَ لَكَ بِهِۦ عِلْمٌ ۚ إِنَّ ٱلسَّمْعَ وَٱلْبَصَرَ وَٱلْفُؤَادَ كُلُّ أُو۟لَٰٓئِكَ كَانَ عَنْهُ مَسْـُٔولًا﴾</span></p><h3>معاني الكلمات</h3><p><span class="qpc-hafs">﴿مَلُومًا﴾</span> يَلُومُكَ النَّاسُ، وَيَذُمُّونَكَ.</p><p><span class="qpc-hafs">﴿مَحْسُورًا﴾</span> فَارِغَ اليَدِ نَادِمًا، عَلَى تَبْذِيرِكَ.</p><p><span class="qpc-hafs">﴿وَيَقْدِرُ﴾</span> يُضَيِّقُ.</p><p><span class="qpc-hafs">﴿إِمْلاقٍ﴾</span> فَقْرٍ.</p><p><span class="qpc-hafs">﴿خِطْأً﴾</span> ذَنْبًا.</p><p><span class="qpc-hafs">﴿سَبِيلاً﴾</span> طَرِيقًا.</p><p><span class="qpc-hafs">﴿لِوَلِيِّهِ﴾</span> مَنْ تَوَلَّى أَمْرَ القَتِيلِ مِنْ وَارِثٍ، أَوْ حَاكِمٍ.</p><p><span class="qpc-hafs">﴿سُلْطَاناً﴾</span> حُجَّةً.</p><p><span class="qpc-hafs">﴿الْيَتِيمِ﴾</span> مَنْ مَاتَ أَبُوهُ قَبْلَ البُلُوغِ.</p><p><span class="qpc-hafs">﴿بِالْقِسْطَاسِ الْمُسْتَقِيمِ﴾</span> بِالمِيزَانِ السَّوِيِّ.</p><p><span class="qpc-hafs">﴿تَأْوِيلاً﴾</span> عَاقِبَةً عِنْدَ اللهِ فِي الآخِرَةِ.</p><p><span class="qpc-hafs">﴿وَلا تَقْفُ﴾</span> لا تَتْبَعْ.</p><p><span class="qpc-hafs">﴿مَرَحًا﴾</span> مُخْتالاً، مُتَكَبِّرًا.</p></div>"
