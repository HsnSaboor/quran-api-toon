quran[21]{c,v,t}:
  26,40,"

الوقفات التدبرية

١- <q>﴿قَالَ لَهُم مُّوسَىٰٓ أَلْقُوا۟ مَآ أَنتُم مُّلْقُونَ﴾</q>

لم يبادر موسى بإلقاء عصاه أولاً لأن المسألة مسألة علم لا مسألة حرب؛ ففي الحرب تنفع المبادرة بافتكاك زمام المعركة، وأما في العلم فيحسن تقديم الخصم، فإذا أظهر ما عنده كر عليه بالحجج والبراهين فأبطله، وظهر الحق وانتصر على الباطل، هذا الأسلوب الذي اتبع موسى بإلهام من ربه تعالى. [الجزائري:٣/٦٤٩]

السؤال: لماذا لم يبادر موسى- عليه السلام- بإلقاء عصاه قبل السحرة؟

٢- <q>﴿فَأَلْقَوْا۟ حِبَالَهُمْ وَعِصِيَّهُمْ وَقَالُوا۟ بِعِزَّةِ فِرْعَوْنَ إِنَّا لَنَحْنُ ٱلْغَٰلِبُونَ﴾</q>

<q>﴿وقالوا﴾</q> مقسمين <q>﴿بعزة فرعون﴾</q> فكل من حلف بغير الله -كأن يقول: وحياة فلان، وحق رأسه، ونحو ذلك- فهو تابع لهذه الجاهلية. [البقاعي:١٤/٣٢- ٣٣]

السؤال: الحلف بغير الله يدل على تسوية المقسَم به مع الله في التعظيم، وضح ذلك.

٣- <q>﴿فَأَلْقَوْا۟ حِبَالَهُمْ وَعِصِيَّهُمْ وَقَالُوا۟ بِعِزَّةِ فِرْعَوْنَ إِنَّا لَنَحْنُ ٱلْغَٰلِبُونَ﴾</q>

وأرادوا بذلك إلقاء الخوف في نفس موسى؛ ليكون ما سيلقيه في نوبته عن خور نفس؛ لأنهم يعلمون أن العزيمة من أكبر أسباب نجاح السحر، وتأثيره على الناظرين. [ابن عاشور:١٩/١٢٧]

السؤال: لماذا قال السحرة <q>﴿إنا لنحن الغالبون﴾</q>؟

٤- <q>﴿إِنَّهُۥ لَكَبِيرُكُمُ ٱلَّذِى عَلَّمَكُمُ ٱلسِّحْرَ﴾</q>

هذه مكابرة يعلم كل أحد بطلانها؛ فإنهم لم يجتمعوا بموسى قبل ذلك اليوم، فكيف يكون كبيرهم الذي أفادهم صناعة السحر؟! هذا لا يقوله عاقل. [ابن كثير:٣/٣٢٤]

السؤال: تدل الآية على عِظَم معاندة فرعون، بيِّن ذلك.

٥- <q>﴿قَالُوا۟ لَا ضَيْرَ﴾</q>

قال السحرة- حين وجدوا حلاوة الإيمان وذاقوا لذته- لا ضير، أي: لا نبالي بما توعدتنا به. [السعدي:٥٩٢]

السؤال: لماذا لم يتأثَّر السحرة بتهديدات فرعون؟

٦- <q>﴿إِنَّا نَطْمَعُ أَن يَغْفِرَ لَنَا رَبُّنَا خَطَٰيَٰنَآ أَن كُنَّآ أَوَّلَ ٱلْمُؤْمِنِينَ﴾</q>

وعبروا بالطمع إشارة إلى أن جميع أسباب السعادة منه تعالى؛ فكأنه لا سبب منهم أصلاً. [البقاعي:١٤/٣٦]

السؤال: ماذا يفيد التعبير بالطمع في المغفرة؟

٧- <q>﴿وَإِنَّا لَجَمِيعٌ حَٰذِرُونَ﴾</q>

والمعنى: أن الحَذَر من شيمته وعادته؛ فكذلك يجب أن تكون الأمة معه في ذلك؛ أي: إنا من عادتنا التيقظ للحوادث، والحَذرُ مما عسى أن يكون لها من سيّء العواقب. وهذا أصل عظيم من أصول السياسة، وهو سدّ ذرائع الفساد، ولو كان احتمالُ إفضائها إلى الفساد ضعيفاً. [ابن عاشور:١٩/١٣١]

السؤال: دلت الآية الكريمة على أصل عظيم من أصول السياسة بين ذلك.

التوجيهات

١- من ابتغى العزة في غير دين الله أذله الله, <q>﴿وَقَالُوا۟ بِعِزَّةِ فِرْعَوْنَ إِنَّا لَنَحْنُ ٱلْغَٰلِبُونَ﴾</q>

٢- ما ينال الصالحين من تهديدات الجبابرة فهو وسيلة للوصول إلى الدرجات العالية في الدنيا والآخرة، <q>﴿قَالُوا۟ لَا ضَيْرَ﴾</q>

٣- ما أهون الخلق على الله إذا هم عصوه؛ بينما فرعون ملكٌ بطرٌ يدَّعي الربوبية إذا به غريقٌ في اليم، <q>﴿فَأَخْرَجْنَٰهُم مِّن جَنَّٰتٍ وَعُيُونٍ (٥٧) وَكُنُوزٍ وَمَقَامٍ كَرِيمٍ﴾</q>

العمل بالآيات

١- أدِّ عملاً دعويًا، واحتسب ما تجده من التعب والأذى في سبيل الله, <q>﴿إِنَّا نَطْمَعُ أَن يَغْفِرَ لَنَا رَبُّنَا خَطَٰيَٰنَآ أَن كُنَّآ أَوَّلَ ٱلْمُؤْمِنِينَ﴾</q>

٢- ادع الله تعالى أن يغفر لك ذنبك، ويثبتك على الإيمان, <q>﴿إِنَّا نَطْمَعُ أَن يَغْفِرَ لَنَا رَبُّنَا خَطَٰيَٰنَآ أَن كُنَّآ أَوَّلَ ٱلْمُؤْمِنِينَ﴾</q>

٣- اكتب مواضع حفظ الله سبحانه وتأييده ونصره لنبيه موسى عليه السلام في هذه السورة الكريمة، <q>﴿فَأَلْقَىٰ مُوسَىٰ عَصَاهُ فَإِذَا هِىَ تَلْقَفُ مَا يَأْفِكُونَ﴾</q>

معاني الكلمات

<q>﴿بِعِزَّةِ فِرْعَوْنَ﴾</q> أَقْسَمُوا بِعِزَّتِهِ، وَقُوَّتِهِ.

<q>﴿تَلْقَفُ﴾</q> تَبْتَلِعُ بِسُرْعَةٍ.

<q>﴿مَا يَأْفِكُونَ﴾</q> مَا يَفْعَلُونَهُ مِنَ الكَذِبِ وَالتَّزْوِيرِ.

<q>﴿مِنْ خِلاَفٍ﴾</q> بِقَطْعِ اليَدِ اليُمْنَى وَالرِّجْلِ اليُسْرَى، أَوْ عَكْسَ ذَلِكَ.

<q>﴿لاَ ضَيْرَ﴾</q> لاَ ضَرَرَ.

<q>﴿مُنْقَلِبُونَ﴾</q> رَاجِعُونَ.

<q>﴿حَاشِرِينَ﴾</q> جَامِعِينَ لِلْجَيْشِ مِنَ المَدَائِنِ.

<q>﴿لَشِرْذِمَةٌ﴾</q> لطَائِفَةٌ حَقِيرَةٌ.

<q>﴿وَكُنُوزٍ﴾</q> خَزَائِنِ الأَمْوَالِ.

<q>﴿وَمَقَامٍ كَرِيمٍ﴾</q> مَنَازِلَ حِسَانٍ.

<q>﴿مُشْرِقِينَ﴾</q> وَقْتَ شُرُوقِ الشَّمْسِ.

