quran[21]{c,v,t}:
  26,40,"<div class=ar lang=ar><h3>الوقفات التدبرية</h3><p>١- <span class="qpc-hafs">﴿قَالَ لَهُم مُّوسَىٰٓ أَلْقُوا۟ مَآ أَنتُم مُّلْقُونَ﴾</span></p><p>لم يبادر موسى بإلقاء عصاه أولاً لأن المسألة مسألة علم لا مسألة حرب؛ ففي الحرب تنفع المبادرة بافتكاك زمام المعركة، وأما في العلم فيحسن تقديم الخصم، فإذا أظهر ما عنده كر عليه بالحجج والبراهين فأبطله، وظهر الحق وانتصر على الباطل، هذا الأسلوب الذي اتبع موسى بإلهام من ربه تعالى. [الجزائري:٣/٦٤٩]</p><p>السؤال: لماذا لم يبادر موسى- عليه السلام- بإلقاء عصاه قبل السحرة؟</p><p>٢- <span class="qpc-hafs">﴿فَأَلْقَوْا۟ حِبَالَهُمْ وَعِصِيَّهُمْ وَقَالُوا۟ بِعِزَّةِ فِرْعَوْنَ إِنَّا لَنَحْنُ ٱلْغَٰلِبُونَ﴾</span></p><p><span class="qpc-hafs">﴿وقالوا﴾</span> مقسمين <span class="qpc-hafs">﴿بعزة فرعون﴾</span> فكل من حلف بغير الله -كأن يقول: وحياة فلان، وحق رأسه، ونحو ذلك- فهو تابع لهذه الجاهلية. [البقاعي:١٤/٣٢- ٣٣]</p><p>السؤال: الحلف بغير الله يدل على تسوية المقسَم به مع الله في التعظيم، وضح ذلك.</p><p>٣- <span class="qpc-hafs">﴿فَأَلْقَوْا۟ حِبَالَهُمْ وَعِصِيَّهُمْ وَقَالُوا۟ بِعِزَّةِ فِرْعَوْنَ إِنَّا لَنَحْنُ ٱلْغَٰلِبُونَ﴾</span></p><p>وأرادوا بذلك إلقاء الخوف في نفس موسى؛ ليكون ما سيلقيه في نوبته عن خور نفس؛ لأنهم يعلمون أن العزيمة من أكبر أسباب نجاح السحر، وتأثيره على الناظرين. [ابن عاشور:١٩/١٢٧]</p><p>السؤال: لماذا قال السحرة <span class="qpc-hafs">﴿إنا لنحن الغالبون﴾</span>؟</p><p>٤- <span class="qpc-hafs">﴿إِنَّهُۥ لَكَبِيرُكُمُ ٱلَّذِى عَلَّمَكُمُ ٱلسِّحْرَ﴾</span></p><p>هذه مكابرة يعلم كل أحد بطلانها؛ فإنهم لم يجتمعوا بموسى قبل ذلك اليوم، فكيف يكون كبيرهم الذي أفادهم صناعة السحر؟! هذا لا يقوله عاقل. [ابن كثير:٣/٣٢٤]</p><p>السؤال: تدل الآية على عِظَم معاندة فرعون، بيِّن ذلك.</p><p>٥- <span class="qpc-hafs">﴿قَالُوا۟ لَا ضَيْرَ﴾</span></p><p>قال السحرة- حين وجدوا حلاوة الإيمان وذاقوا لذته- لا ضير، أي: لا نبالي بما توعدتنا به. [السعدي:٥٩٢]</p><p>السؤال: لماذا لم يتأثَّر السحرة بتهديدات فرعون؟</p><p>٦- <span class="qpc-hafs">﴿إِنَّا نَطْمَعُ أَن يَغْفِرَ لَنَا رَبُّنَا خَطَٰيَٰنَآ أَن كُنَّآ أَوَّلَ ٱلْمُؤْمِنِينَ﴾</span></p><p>وعبروا بالطمع إشارة إلى أن جميع أسباب السعادة منه تعالى؛ فكأنه لا سبب منهم أصلاً. [البقاعي:١٤/٣٦]</p><p>السؤال: ماذا يفيد التعبير بالطمع في المغفرة؟</p><p>٧- <span class="qpc-hafs">﴿وَإِنَّا لَجَمِيعٌ حَٰذِرُونَ﴾</span></p><p>والمعنى: أن الحَذَر من شيمته وعادته؛ فكذلك يجب أن تكون الأمة معه في ذلك؛ أي: إنا من عادتنا التيقظ للحوادث، والحَذرُ مما عسى أن يكون لها من سيّء العواقب. وهذا أصل عظيم من أصول السياسة، وهو سدّ ذرائع الفساد، ولو كان احتمالُ إفضائها إلى الفساد ضعيفاً. [ابن عاشور:١٩/١٣١]</p><p>السؤال: دلت الآية الكريمة على أصل عظيم من أصول السياسة بين ذلك.</p><h3>التوجيهات</h3><p>١- من ابتغى العزة في غير دين الله أذله الله, <span class="qpc-hafs">﴿وَقَالُوا۟ بِعِزَّةِ فِرْعَوْنَ إِنَّا لَنَحْنُ ٱلْغَٰلِبُونَ﴾</span></p><p>٢- ما ينال الصالحين من تهديدات الجبابرة فهو وسيلة للوصول إلى الدرجات العالية في الدنيا والآخرة، <span class="qpc-hafs">﴿قَالُوا۟ لَا ضَيْرَ﴾</span></p><p>٣- ما أهون الخلق على الله إذا هم عصوه؛ بينما فرعون ملكٌ بطرٌ يدَّعي الربوبية إذا به غريقٌ في اليم، <span class="qpc-hafs">﴿فَأَخْرَجْنَٰهُم مِّن جَنَّٰتٍ وَعُيُونٍ (٥٧) وَكُنُوزٍ وَمَقَامٍ كَرِيمٍ﴾</span></p><h3>العمل بالآيات</h3><p>١- أدِّ عملاً دعويًا، واحتسب ما تجده من التعب والأذى في سبيل الله, <span class="qpc-hafs">﴿إِنَّا نَطْمَعُ أَن يَغْفِرَ لَنَا رَبُّنَا خَطَٰيَٰنَآ أَن كُنَّآ أَوَّلَ ٱلْمُؤْمِنِينَ﴾</span></p><p>٢- ادع الله تعالى أن يغفر لك ذنبك، ويثبتك على الإيمان, <span class="qpc-hafs">﴿إِنَّا نَطْمَعُ أَن يَغْفِرَ لَنَا رَبُّنَا خَطَٰيَٰنَآ أَن كُنَّآ أَوَّلَ ٱلْمُؤْمِنِينَ﴾</span></p><p>٣- اكتب مواضع حفظ الله سبحانه وتأييده ونصره لنبيه موسى عليه السلام في هذه السورة الكريمة، <span class="qpc-hafs">﴿فَأَلْقَىٰ مُوسَىٰ عَصَاهُ فَإِذَا هِىَ تَلْقَفُ مَا يَأْفِكُونَ﴾</span></p><h3>معاني الكلمات</h3><p><span class="qpc-hafs">﴿بِعِزَّةِ فِرْعَوْنَ﴾</span> أَقْسَمُوا بِعِزَّتِهِ، وَقُوَّتِهِ.</p><p><span class="qpc-hafs">﴿تَلْقَفُ﴾</span> تَبْتَلِعُ بِسُرْعَةٍ.</p><p><span class="qpc-hafs">﴿مَا يَأْفِكُونَ﴾</span> مَا يَفْعَلُونَهُ مِنَ الكَذِبِ وَالتَّزْوِيرِ.</p><p><span class="qpc-hafs">﴿مِنْ خِلاَفٍ﴾</span> بِقَطْعِ اليَدِ اليُمْنَى وَالرِّجْلِ اليُسْرَى، أَوْ عَكْسَ ذَلِكَ.</p><p><span class="qpc-hafs">﴿لاَ ضَيْرَ﴾</span> لاَ ضَرَرَ.</p><p><span class="qpc-hafs">﴿مُنْقَلِبُونَ﴾</span> رَاجِعُونَ.</p><p><span class="qpc-hafs">﴿حَاشِرِينَ﴾</span> جَامِعِينَ لِلْجَيْشِ مِنَ المَدَائِنِ.</p><p><span class="qpc-hafs">﴿لَشِرْذِمَةٌ﴾</span> لطَائِفَةٌ حَقِيرَةٌ.</p><p><span class="qpc-hafs">﴿وَكُنُوزٍ﴾</span> خَزَائِنِ الأَمْوَالِ.</p><p><span class="qpc-hafs">﴿وَمَقَامٍ كَرِيمٍ﴾</span> مَنَازِلَ حِسَانٍ.</p><p><span class="qpc-hafs">﴿مُشْرِقِينَ﴾</span> وَقْتَ شُرُوقِ الشَّمْسِ.</p></div>"
