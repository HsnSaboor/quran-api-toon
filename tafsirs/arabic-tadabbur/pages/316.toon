tafsir[12]{c,v,t}:
  20,65,"

الوقفات التدبرية

١- <q>﴿قَالُوا۟ يَٰمُوسَىٰٓ إِمَّآ أَن تُلْقِىَ وَإِمَّآ أَن نَّكُونَ أَوَّلَ مَنْ أَلْقَىٰ (٦٥) قَالَ بَلْ أَلْقُوا۟ ۖ فَإِذَا حِبَالُهُمْ وَعِصِيُّهُمْ يُخَيَّلُ إِلَيْهِ مِن سِحْرِهِمْ أَنَّهَا تَسْعَىٰ﴾</q>

خيروه، موهمين أنهم على جزم من ظهورهم عليه بأي حالة كانت. [السعدي:٥٠٨]

السؤال: ثقة أهل الباطل بأنفسهم لا تزعزع ثقة المؤمن بربه، وضح ذلك من خلال الآية.

٢- <q>﴿فَأَوْجَسَ فِى نَفْسِهِۦ خِيفَةً مُّوسَىٰ﴾</q>

كما هو مقتضى الطبيعة البشرية، وإلا فهو جازم بوعد الله ونصره. [السعدي:٥٠٨]

السؤال: ما سبب الخوف الذي وقع من موسى؟ وهل كان شاكاً في وعد الله؟

٣- <q>﴿وَلَا يُفْلِحُ ٱلسَّاحِرُ حَيْثُ﴾</q>

يعم نفي جميع أنواع الفلاح عن الساحر، وأكد ذلك بالتعميم في الأمكنة بقوله: <q>﴿حيث أتى﴾</q>، وذلك دليل على كفره؛ لأن الفلاح لا ينفى بالكلية نفيا عاما إلا عمن لا خير فيه؛ وهو الكافر. [الشنقيطي:٤/٣٩]

السؤال: ما وجه نفي الفلاح عن الساحر؟

٤- <q>﴿قَالَ ءَامَنتُمْ لَهُۥ قَبْلَ أَنْ ءَاذَنَ لَكُمْ ۖ إِنَّهُۥ لَكَبِيرُكُمُ ٱلَّذِى عَلَّمَكُمُ ٱلسِّحْرَ ۖ فَلَأُقَطِّعَنَّ أَيْدِيَكُمْ وَأَرْجُلَكُم مِّنْ خِلَٰفٍ وَلَأُصَلِّبَنَّكُمْ فِى جُذُوعِ ٱلنَّخْلِ وَلَتَعْلَمُنَّ أَيُّنَآ أَشَدُّ عَذَابًا وَأَبْقَىٰ﴾</q>

ولما رأى فرعون إيمان السحرة تغيّظ ورام عقابهم، ولكنه علم أنّ العقاب على الإيمان بموسى بعد أن فتح باب المناظرة معه نكث لأصول المناظرة، فاختلق -للتشفّي من الذين آمنوا- علّة إعلانهم الإيمان قبل استئذانِ فرعون، فعدّ ذلك جرأة عليه. [ابن عاشور:١٦/٢٦٣]

السؤال: من صفات المغلوب اختلاق الأعذار الواهية، بيِّن ذلك من الآيات الكريمة.

٥- <q>﴿قَالُوا۟ لَن نُّؤْثِرَكَ عَلَىٰ مَا جَآءَنَا مِنَ ٱلْبَيِّنَٰتِ وَٱلَّذِى فَطَرَنَا ۖ فَٱقْضِ مَآ أَنتَ قَاضٍ ۖ إِنَّمَا تَقْضِى هَٰذِهِ ٱلْحَيَوٰةَ ٱلدُّنْيَآ﴾</q>

أظهروا استخفافهم بوعيده وبتعذيبه؛ إذ أصبحوا أهل إيمان ويقين، وكذلك شأن المؤمنين بالرسل إذا أشرقت عليهم أنوار الرسالة؛ فسرعان ما يكون انقلابهم عن جهالة الكفر وقساوته إلى حكمة الإيمان وثباته. [ابن عاشور:١٦/٢٦٦]

السؤال: بين حال المؤمنين إذا أشرقت عليهم أنوار الرسالة.

٦- <q>﴿قَالُوا۟ لَن نُّؤْثِرَكَ عَلَىٰ مَا جَآءَنَا مِنَ ٱلْبَيِّنَٰتِ وَٱلَّذِى فَطَرَنَا ۖ فَٱقْضِ مَآ أَنتَ قَاضٍ ۖ إِنَّمَا تَقْضِى هَٰذِهِ ٱلْحَيَوٰةَ ٱلدُّنْيَآ﴾</q>

وفي هذا الكلام من السحرة دليل على أنه ينبغي للعاقل أن يوازن بين لذات الدنيا ولذات الآخرة، وبين عذاب الدنيا وعذاب الآخرة. [السعدي:٥٠٩]

السؤال: إذا واجهتك لذة من لذات الدنيا المحرمة؛ فإن هذه الآية تدلك على طريقة تتخلص بها من هذه الشهوة، بيِّن ذلك.

٧- <q>﴿إِنَّهُۥ مَن يَأْتِ رَبَّهُۥ مُجْرِمًا فَإِنَّ لَهُۥ جَهَنَّمَ لَا يَمُوتُ فِيهَا وَلَا يَحْيَىٰ﴾</q>

فلا ينتفع بحياته، ولا يستريح بموته، وقيل: نفس الكافر معلقة في حنجرته، كما أخبر الله تعالى عنه، فلا يموت بفراقها، ولا يحيا باستقرارها. [القرطبي:١٤/١٠٧]

السؤال: بين شدة عذاب الله تعالى للكافر في كونه بين الحياة والموت.

التوجيهات

١- من علامة ضعف عقول الطغـاة توعـد أهل الحق بالقوة والبطش، <q>﴿فَلَأُقَطِّعَنَّ أَيْدِيَكُمْ وَأَرْجُلَكُم مِّنْ خِلَٰفٍ وَلَأُصَلِّبَنَّكُمْ فِى جُذُوعِ ٱلنَّخْلِ وَلَتَعْلَمُنَّ أَيُّنَآ أَشَدُّ عَذَابًا وَأَبْقَىٰ﴾</q>

٢- إذا واجه الداعية تهديدا أو بطشا قارن بينه وبين ما ينتظره في الآخرة؛ فهان علية وصبر، <q>﴿قَالُوا۟ لَن نُّؤْثِرَكَ عَلَىٰ مَا جَآءَنَا مِنَ ٱلْبَيِّنَٰتِ وَٱلَّذِى فَطَرَنَا ۖ فَٱقْضِ مَآ أَنتَ قَاضٍ ۖ إِنَّمَا تَقْضِى هَٰذِهِ ٱلْحَيَوٰةَ ٱلدُّنْيَآ﴾</q>

٣- كلما اشتد الابتلاء قرب الفرج، <q>﴿فَٱقْضِ مَآ أَنتَ قَاضٍ ۖ إِنَّمَا تَقْضِى هَٰذِهِ ٱلْحَيَوٰةَ ٱلدُّنْيَآ﴾</q>

العمل بالآيات

١- أرسل رسالة تحذر فيها من السحر وأهله، <q>﴿ۖ وَلَا يُفْلِحُ ٱلسَّاحِرُ حَيْثُ أَتَىٰ﴾</q>

٢- قل: «اللهم يا مقلب القلوب ثبت قلبي على دينك», <q>﴿قَالُوا۟ لَن نُّؤْثِرَكَ عَلَىٰ مَا جَآءَنَا مِنَ ٱلْبَيِّنَٰتِ وَٱلَّذِى فَطَرَنَا﴾</q>

٣- أرسل رسالة تبشر فيها أنه ليس كل ما يهدد به الطغاة يقع؛ لأن الحكم لله أولا وآخرا، <q>﴿فَلَأُقَطِّعَنَّ أَيْدِيَكُمْ وَأَرْجُلَكُم مِّنْ خِلَٰفٍ وَلَأُصَلِّبَنَّكُمْ فِى جُذُوعِ ٱلنَّخْلِ وَلَتَعْلَمُنَّ أَيُّنَآ أَشَدُّ عَذَابًا وَأَبْقَىٰ﴾</q>

معاني الكلمات

<q>﴿فَأَوْجَسَ﴾</q> فَشَعَرَ، وَأَحَسَّ فِي نَفْسِهِ.

<q>﴿تَلْقَفْ﴾</q> تَبْتَلِعْ.

<q>﴿مِنْ خِلاَفٍ﴾</q> مُخَالِفًا بَيْنَ الأَيْدِي وَالأَرْجُلِ، فَيَقْطَعُ يَدًا مِنْ جِهَةٍ، وَرِجْلاً مِنْ جِهَةٍ أُخْرَى.

<q>﴿نُؤْثِرَكَ﴾</q> نُفَضِّلَكَ.

<q>﴿فَطَرَنَا﴾</q> خَلَقَنَا وَأَبْدَعَنَا.

<q>﴿فَاقْضِ﴾</q> فَافْعَلْ وَاحْكُمْ.

<q>﴿لاَ يَمُوتُ فِيهَا وَلاَ يَحْيَا﴾</q> لاَ يَمُوتُ فِيهَا؛ فَيَسْتَرِيحَ، وَلاَ يَحْيَا حَيَاةً يَهْنَأُ بِهَا.

