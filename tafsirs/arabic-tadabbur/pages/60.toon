quran[6]{c,v,t}:
  3,78,"

الوقفات التدبرية

١- <q>﴿وَإِنَّ مِنْهُمْ لَفَرِيقًا يَلْوُۥنَ أَلْسِنَتَهُم بِٱلْكِتَٰبِ لِتَحْسَبُوهُ مِنَ ٱلْكِتَٰبِ وَمَا هُوَ مِنَ ٱلْكِتَٰبِ وَيَقُولُونَ هُوَ مِنْ عِندِ ٱللَّهِ﴾</q>

وذلك أن المقصود من الكتاب: حفظ ألفاظه، وعدم تغييرها، وفهم المراد منها وإفهامه. وهؤلاء عكسوا القضية، وأفهموا غير المراد من الكتاب؛ إما تعريضاًً، وإما تصريحاًً. [السعدي: ١٣٦]

السؤال: بينت الآية نوعاًً من التحريف والتلاعب بكتاب الله، وضح ذلك.

٢- <q>﴿وَإِنَّ مِنْهُمْ لَفَرِيقًا يَلْوُۥنَ أَلْسِنَتَهُم بِٱلْكِتَٰبِ لِتَحْسَبُوهُ مِنَ ٱلْكِتَٰبِ وَمَا هُوَ مِنَ ٱلْكِتَٰبِ وَيَقُولُونَ هُوَ مِنْ عِندِ ٱللَّهِ وَمَا هُوَ مِنْ عِندِ ٱللَّهِ وَيَقُولُونَ عَلَى ٱللَّهِ ٱلْكَذِبَ وَهُمْ يَعْلَمُونَ﴾</q>

وجيء بالمضارع في هاته الأفعال: يلوون، ويقولون؛ للدلالة على تجدد ذلك، وأنه دأبهم. [ابن عاشور: ٣/٢٩٢]

السؤال: لماذا جاءت الأفعال بصيغة المضارع في الآية الكريمة؟

٣- <q>﴿وَإِنَّ مِنْهُمْ لَفَرِيقًا يَلْوُۥنَ أَلْسِنَتَهُم بِٱلْكِتَٰبِ لِتَحْسَبُوهُ مِنَ ٱلْكِتَٰبِ وَمَا هُوَ مِنَ ٱلْكِتَٰبِ﴾</q>

والتحريف قد فسر بتحريف التنزيل، وبتحريف التأويل، فأما تحريف التأويل فكثير جدا، وقد ابتليت به طوائف من هذه الأمة، وأما تحريف التنزيل فقد وقع في كثير من الناس؛ يحرفون ألفاظ الرسول، ويروون الحديث بروايات منكرة. [ابن تيمية: ٢/٨٦]

السؤال: تحريف الوحي على قسمين، فما هما؟

٤- <q>﴿وَلَٰكِن كُونُوا۟ رَبَّٰنِيِّۦنَ بِمَا كُنتُمْ تُعَلِّمُونَ ٱلْكِتَٰبَ وَبِمَا كُنتُمْ تَدْرُسُونَ﴾</q>

أي: تابعين طريق الرب، منسوبين إليه بكمال العلم المزين بالعمل؛ فإن الرباني هو الشديد التمسك بدين الله سبحانه وتعالى وطاعته. [البقاعي: ٢/١١٨]

السؤال: ما صفات الربانيين؟

٥- <q>﴿وَلَٰكِن كُونُوا۟ رَبَّٰنِيِّۦنَ بِمَا كُنتُمْ تُعَلِّمُونَ ٱلْكِتَٰبَ وَبِمَا كُنتُمْ تَدْرُسُونَ﴾</q>

<q>﴿ربانيين﴾</q>: قال سعيد بن جبير: العالم الذي يعمل بعلمه ... وقيل: الربانيون فوق الأحبار، والأحبار: العلماء. والربانيون: الذين جمعوا مع العلم البصارة بسياسة الناس.. [البغوي: ١/٣٧٥]

السؤال: كيف تكون عالماًً ربانياًً؟

٦- <q>﴿وَلَٰكِن كُونُوا۟ رَبَّٰنِيِّۦنَ بِمَا كُنتُمْ تُعَلِّمُونَ ٱلْكِتَٰبَ وَبِمَا كُنتُمْ تَدْرُسُو﴾</q>

فإن فائدة الدرس: العلم, وفائدة العلم: العمل, ومنه الحث على الخير، والمراقبة للخالق. [البقاعي: ٢/١١٨]

السؤال: ما فائدة الدروس وطلب العلم؟

٧- <q>﴿وَإِذْ أَخَذَ ٱللَّهُ مِيثَٰقَ ٱلنَّبِيِّۦنَ لَمَآ ءَاتَيْتُكُم مِّن كِتَٰبٍ وَحِكْمَةٍ ثُمَّ جَآءَكُمْ رَسُولٌ مُّصَدِّقٌ لِّمَا مَعَكُمْ لَتُؤْمِنُنَّ بِهِۦ وَلَتَنصُرُنَّهُۥ ۚ قَالَ ءَأَقْرَرْتُمْ وَأَخَذْتُمْ عَلَىٰ ذَٰلِكُمْ إِصْرِى ۖ قَالُوٓا۟ أَقْرَرْنَا ۚ قَالَ فَٱشْهَدُوا۟ وَأَنَا۠ مَعَكُم مِّنَ ٱلشَّٰهِدِينَ﴾</q>

وروي عن غير واحد من السلف- علي وابن عباس وغيرهما- قالوا: لم يبعث الله نبيا من عهد نوح إلا أخذ عليه الميثاق: لئن بعث محمد وهو حي ليؤمنن به، ولينصرنه، وأمره أن يأخذ الميثاق على أمته: لئن بعث محمد -وهم أحياء- ليؤمنن به، ولينصرنه. [ابن تيمية: ٢/٨٨]

السؤال: بين منزلة النبي محمد صلى الله عليه وسلم؟

التوجيهات

١- جرأة اليهود على الكذب على الله، وعلى الناس، <q>﴿وَيَقُولُونَ هُوَ مِنْ عِندِ ٱللَّهِ وَمَا هُوَ مِنْ عِندِ ٱللَّهِ وَيَقُولُونَ عَلَى ٱللَّهِ ٱلْكَذِبَ وَهُمْ يَعْلَمُونَ﴾</q>

٢- على الداعية وطالب العلم أن يتذكر دائما أنه إنما يدعو لله، لا لنفسه، <q>﴿مَا كَانَ لِبَشَرٍ أَن يُؤْتِيَهُ ٱللَّهُ ٱلْكِتَٰبَ وَٱلْحُكْمَ وَٱلنُّبُوَّةَ ثُمَّ يَقُولَ لِلنَّاسِ كُونُوا۟ عِبَادًا لِّى مِن دُونِ ٱللَّهِ﴾</q>

٣- على العالم والداعية أن يبدأ بتعليم صغار العلم قبل كباره، والعمل بما يعلم، <q>﴿وَلَٰكِن كُونُوا۟ رَبَّٰنِيِّۦنَ بِمَا كُنتُمْ تُعَلِّمُونَ ٱلْكِتَٰبَ وَبِمَا كُنتُمْ تَدْرُسُونَ﴾</q>

العمل بالآيات

١- علِّم أحداً ممن حولك صفة الوضوء، ثم الصلاة؛ فذلك من تربية الناس على صغار العلم قبل كباره، <q>﴿وَلَٰكِن كُونُوا۟ رَبَّٰنِيِّۦنَ بِمَا كُنتُمْ تُعَلِّمُونَ ٱلْكِتَٰبَ وَبِمَا كُنتُمْ تَدْرُسُونَ﴾</q>

٢- حدد مسألة تعلمتها، واعمل بها حتى تسير على خطى الربانيين، <q>﴿وَلَٰكِن كُونُوا۟ رَبَّٰنِيِّۦنَ بِمَا كُنتُمْ تُعَلِّمُونَ ٱلْكِتَٰبَ وَبِمَا كُنتُمْ تَدْرُسُونَ﴾</q>

٣- ساهم بمشروع تنصر به دين الله تعالى، <q>﴿وَإِذْ أَخَذَ ٱللَّهُ مِيثَٰقَ ٱلنَّبِيِّۦنَ لَمَآ ءَاتَيْتُكُم مِّن كِتَٰبٍ وَحِكْمَةٍ ثُمَّ جَآءَكُمْ رَسُولٌ مُّصَدِّقٌ لِّمَا مَعَكُمْ لَتُؤْمِنُنَّ بِهِۦ وَلَتَنصُرُنَّهُۥ﴾</q>

معاني الكلمات

<q>﴿يَلْوُونَ﴾</q> يُحَرِّفُونَ الْكَلاَمَ عَنْ مَوَاضِعِهِ.

<q>﴿رَبَّانِّيِّينَ﴾</q> حُكَمَاءَ، فُقَهَاءَ، مُعَلِّمِينَ.

<q>﴿إِصْرِي﴾</q> عَهْدِي.

