tafsir[10]{c,v,t}:
  20,126,"

الوقفات التدبرية

١- <q>﴿قَالَ كَذَٰلِكَ أَتَتْكَ ءَايَٰتُنَا فَنَسِيتَهَا ۖ وَكَذَٰلِكَ ٱلْيَوْمَ تُنسَىٰ﴾</q>

النسيان في هذه الآية بمعنى: الترك. ولا مدخل للذهول في هذا الموضع، و<q>﴿تُنسى﴾</q> بمعنى: تترك في العذاب. [ابن عطية:٤/٦٩]

السؤال: ما المراد بالنسيان في الآية؟

٢- <q>﴿وَلَعَذَابُ ٱلْءَاخِرَةِ أَشَدُّ وَأَبْقَىٰٓ﴾</q>

لكونه لا ينقطع، بخلاف عذاب الدنيا فإنه منقطع، فالواجب الخوف والحذر من عذاب الآخرة. [السعدي:٥١٦]

السؤال: المسلم قد يواجه صعوبات ومتاعب في حياته، فكيف يفيد من هذه الآية في تهوين هذه المصاعب عليه؟

٣- <q>﴿فَٱصْبِرْ عَلَىٰ مَا يَقُولُونَ وَسَبِّحْ بِحَمْدِ رَبِّكَ قَبْلَ طُلُوعِ ٱلشَّمْسِ وَقَبْلَ غُرُوبِهَا ۖ وَمِنْ ءَانَآئِ ٱلَّيْلِ فَسَبِّحْ وَأَطْرَافَ ٱلنَّهَارِ لَعَلَّكَ تَرْضَىٰ﴾</q>

وأمره بأن يقبل على مزاولة تزكية نفسه وتزكية أهله بالصلاة، والإعراض عما متع الله الكفّار برفاهية العيش، ووعده بأن العاقبة للمتقين. [ابن عاشور:١٦/٣٣٧]

السؤال: ينبغي للمؤمن عند انتشار أذى المشركين الإقبال على تزكية نفسه وتقويتها بالعبادات للصمود أمام أذاهم، بين ذلك من الآية.

٤- <q>﴿وَلَا تَمُدَّنَّ عَيْنَيْكَ إِلَىٰ مَا مَتَّعْنَا بِهِۦٓ أَزْوَٰجًا مِّنْهُمْ زَهْرَةَ ٱلْحَيَوٰةِ ٱلدُّنْيَا لِنَفْتِنَهُمْ فِيهِ ۚ وَرِزْقُ رَبِّكَ خَيْرٌ وَأَبْقَىٰ﴾</q>

وفي هذه الآية إشارة إلى أن العبد إذا رأى من نفسه طموحاً إلى زينة الدنيا، وإقبالاً عليها، أن يذكرها ما أمامها من رزق ربه، وأن يوازن بين هذا وهذا. [السعدي:٥١٧]

السؤال: تَمُرُّ على المسلم لحظاتٌ يشتهي فيها أن يكون من المنعمين المترفين في هذه الحياة الدنيا، فكيف يتعامل مع هذه اللحظات؟

٥- <q>﴿وَأْمُرْ أَهْلَكَ بِٱلصَّلَوٰةِ وَٱصْطَبِرْ عَلَيْهَا﴾</q>

والأمر بالشيء أمرٌ بجميع ما لا يتم إلا به، فيكون أمراً بتعليمهم ما يصلح الصلاة، ويفسدها، ويكملها ... فإن العبد إذا أقام صلاته على الوجه المأمور به؛ كان لما سواها من دينه أحفظ وأقوم، وإذا ضيعها كان لما سواها أضيع. [السعدي:٥١٧]

السؤال: كيف يكون أمر الأهل وغيرهم بالصلاة؟ ولماذا خصت الصلاة بالأمر بها والاصطبار عليها دون سائر العبادات؟

٦- <q>﴿وَأْمُرْ أَهْلَكَ بِٱلصَّلَوٰةِ وَٱصْطَبِرْ عَلَيْهَا ۖ لَا نَسْـَٔلُكَ رِزْقًا ۖ نَّحْنُ نَرْزُقُكَ ۗ وَٱلْعَٰقِبَةُ لِلتَّقْوَىٰ﴾</q>

<q>﴿لا نسألك رزقاً﴾</q> أي: لا نسألك أن ترزق نفسك ولا أهلك؛ فتفرغ أنت وأهلك للصلاة، فنحن نرزقك، وكان بعض السلف إذا أصاب أهله خصاصة قال: قوموا فصلوا؛ بهذا أمركم الله، ويتلو هذه الآية. [ابن جزي:٢/٢٩]

السؤال: تضمنت هذه الآية منفعة عظيمة وثمرة من ثمار الصلاة, فما هي؟

٧- <q>﴿وَأْمُرْ أَهْلَكَ بِٱلصَّلَوٰةِ وَٱصْطَبِرْ عَلَيْهَا ۖ لَا نَسْـَٔلُكَ رِزْقًا ۖ نَّحْنُ نَرْزُقُكَ ۗ وَٱلْعَٰقِبَةُ لِلتَّقْوَىٰ﴾</q>

أي: لا نسألك أن ترزق نفسك وإياهم، وتشتغل عن الصلاة بسبب الرزق، بل نحن نتكفل برزقك وإياهم، فكان عليه الصلاة والسلام إذا نزل بأهله ضيق أمرهم بالصلاة. [القرطبي:١٤/١٦٥]

السؤال: هل الانشغال بطلب الرزق عذر لتأخير الصلاة؟ وماذا تقول لمن ينشغل بعمله وقت الصلاة؟

التوجيهات

١- ليقتد الداعية بصبر النبي محمد ﷺ على أذى المدعوين, <q>﴿فَٱصْبِرْ عَلَىٰ مَا يَقُولُونَ﴾</q>

٢- إذا أوذيت فاحرص على كثرة التسبيح؛ خاصة بعد الفجر وقبيل المغرب؛ فإنه سببٌ لراحة القلب، <q>﴿فَٱصْبِرْ عَلَىٰ مَا يَقُولُونَ وَسَبِّحْ بِحَمْدِ رَبِّكَ قَبْلَ طُلُوعِ ٱلشَّمْسِ وَقَبْلَ غُرُوبِهَا ۖ وَمِنْ ءَانَآئِ ٱلَّيْلِ فَسَبِّحْ وَأَطْرَافَ ٱلنَّهَارِ لَعَلَّكَ تَرْضَىٰ﴾</q>

٣- إذا رأيت من زاده الله في زينة الدنيا عليك فلا تمدن عينيك إليه، وتذكر ما زادك الله في الدين عليه، <q>﴿وَلَا تَمُدَّنَّ عَيْنَيْكَ إِلَىٰ مَا مَتَّعْنَا بِهِۦٓ أَزْوَٰجًا مِّنْهُمْ زَهْرَةَ ٱلْحَيَوٰةِ ٱلدُّنْيَا لِنَفْتِنَهُمْ فِيهِ ۚ وَرِزْقُ رَبِّكَ خَيْرٌ وَأَبْقَىٰ﴾</q>

العمل بالآيات

١- اجعل لك ورداً لمراجعة ما حفظت من القرآن، ولا تنسه، <q>﴿قَالَ كَذَٰلِكَ أَتَتْكَ ءَايَٰتُنَا فَنَسِيتَهَا ۖ وَكَذَٰلِكَ ٱلْيَوْمَ تُنسَىٰ﴾</q>

٢- قل أذكار الصباح قبل طلوع الشمس، وأذكار المساء قبل غروبها، ولا تنسَ أن تسبح الله في بقية ليلك ونهارك، <q>﴿وَسَبِّحْ بِحَمْدِ رَبِّكَ قَبْلَ طُلُوعِ ٱلشَّمْسِ وَقَبْلَ غُرُوبِهَا ۖ وَمِنْ ءَانَآئِ ٱلَّيْلِ فَسَبِّحْ وَأَطْرَافَ ٱلنَّهَارِ لَعَلَّكَ تَرْضَىٰ﴾</q>

٣- مُرْ إخوانك وأهل بيتك بأداء الصلاة في وقتها, <q>﴿وَأْمُرْ أَهْلَكَ بِٱلصَّلَوٰةِ وَٱصْطَبِرْ عَلَيْهَا ۖ لَا نَسْـَٔلُكَ رِزْقًا ۖ نَّحْنُ نَرْزُقُكَ ۗ وَٱلْعَٰقِبَةُ لِلتَّقْوَىٰ﴾</q>

معاني الكلمات

<q>﴿فَنَسِيتَهَا﴾</q> أَعْرَضْتَ عَنْهَا.

<q>﴿الْقُرُونِ﴾</q> الأُمَمِ المُكَذِّبَةِ.

<q>﴿لِأُوْلِي النُّهَى﴾</q> لِذَوِي العُقُولِ.

<q>﴿لَكَانَ لِزَامًا﴾</q> لَكَانَ الهَلاَكُ عَاجِلاً لاَزِمًا.

<q>﴿آنَاءِ﴾</q> سَاعَاتِ.

<q>﴿وَلاَ تَمُدَّنَّ﴾</q> لاَ تَنْظُرْ، وَلاَ تَلْتَفِتْ وَتُعْجَبْ.

<q>﴿أَزْوَاجًا﴾</q> أَصْنَافًا مِنَ المُشْرِكِينَ.

<q>﴿لَوْلاَ﴾</q> هَلاَّ.

<q>﴿مُتَرَبِّصٌ﴾</q> مُنْتَظِرٌ.

<q>﴿السَّوِيِّ﴾</q> المُسْتَقِيمِ.

