quran[8]{c,v,t}:
  41,47,"<div class=ar lang=ar><h3>الوقفات التدبرية</h3><p>١- <span class="qpc-hafs">﴿لَّا يَسْـَٔمُ ٱلْإِنسَٰنُ مِن دُعَآءِ ٱلْخَيْرِ وَإِن مَّسَّهُ ٱلشَّرُّ فَيَـُٔوسٌ قَنُوطٌ﴾</span></p><p>هذا إخبار عن طبيعة الإنسان من حيث هو، وعدم صبره وجَلَدِه؛ لا على الخير ولا على الشر، إلا مَن نقله الله من هذه الحال إلى حال الكمال. [السعدي:٧٥٢]</p><p>السؤال: أنت ضعيف ببدنك وقلبك، بيِّن هذا من خلال الآية، وبيِّن كيفية العلاج.</p><p>٢- <span class="qpc-hafs">﴿لَّا يَسْـَٔمُ ٱلْإِنسَٰنُ مِن دُعَآءِ ٱلْخَيْرِ وَإِن مَّسَّهُ ٱلشَّرُّ فَيَـُٔوسٌ قَنُوطٌ (٤٩) وَلَئِنْ أَذَقْنَٰهُ رَحْمَةً مِّنَّا مِنۢ بَعْدِ ضَرَّآءَ مَسَّتْهُ لَيَقُولَنَّ هَٰذَا لِى وَمَآ أَظُنُّ ٱلسَّاعَةَ قَآئِمَةً وَلَئِن رُّجِعْتُ إِلَىٰ رَبِّىٓ إِنَّ لِى عِندَهُۥ لَلْحُسْنَىٰ﴾</span></p><p>وصف الإنسان بأقبح صفتين: إن مسه الشر صار إلى حال القانط ووجم وجوم الآيس، فإذا مسه الخير نسي أن الله هو المنعم عليه المفضل بما أعطاه، فبطر وظن أنه هو المستحق لذلك، ثم أضاف إلى ذلك تكذيبه بالبعث فقال: <span class="qpc-hafs">﴿وما أظن الساعة قائمة﴾</span>، ثم أضاف إلى ذلك ظنه الكاذب أنه إن بُعِث كان له عند الله الحسنى، فلم يدع هذا للجهل والغرور موضعًا. [ابن القيم:٢/٤٢٠]</p><p>السؤال: ما الصفتان القبيحتان اللتان يتصف بهما المرء حال تعرضه للشر والخير؟</p><p>٣- <span class="qpc-hafs">﴿وَإِذَآ أَنْعَمْنَا عَلَى ٱلْإِنسَٰنِ أَعْرَضَ وَنَـَٔا بِجَانِبِهِۦ وَإِذَا مَسَّهُ ٱلشَّرُّ فَذُو دُعَآءٍ عَرِيضٍ﴾</span></p><p><span class="qpc-hafs">﴿فذو دعاء عريض﴾</span> أي: كثير جداً؛ لعدم صبره، فلا صبر في الضراء، ولا شكر في الرخاء، إلا مَنْ هداه الله ومَنَّ عليه. [السعدي:٧٥٢]</p><p>السؤال: ما هي الحال التي يجب أن يكون عليها المؤمن في السراء أو في الضراء؟</p><p>٤- <span class="qpc-hafs">﴿وَإِذَآ أَنْعَمْنَا عَلَى ٱلْإِنسَٰنِ أَعْرَضَ وَنَـَٔا بِجَانِبِهِۦ وَإِذَا مَسَّهُ ٱلشَّرُّ فَذُو دُعَآءٍ عَرِيضٍ﴾</span></p><p>وعدل عن إسناد إصابة الشر إلى الله تعليماً للأدب مع الله؛ كما قال إبراهيم: <span class="qpc-hafs">﴿الذي خلقني فهو يهدين﴾</span> الخ . ثم قال: <span class="qpc-hafs">﴿وإذا مرضت فهو يشفين﴾</span> [الشعراء: ٧٨- ٨٠]، فلم يقل: «وإذا أمرضني». وفي ذلك سرّ: وهو أن النعم والخير مسخّران للإنسان في أصل وضع خلقته؛ فهما الغالبان عليه لأنّهما من مظاهر ناموس بقاء النوع. وأمّا الشرور والأضرار فإن معظمها ينجرّ إلى الإنسان بسوء تصرفه وبتعرضه إلى ما حذرته منه الشرائع والحكماء الملهمون فقلما يقع فيهما الإنسان إلا بعلمه وجُرأته. [ابن عاشور:٢٥/١٥]</p><p>السؤال: لماذا عدلت الآية الكريمة عن إسناد إصابة الشر إلى الله تعالى؟ وكيف يصل الشر إلى الإنسان غالباً؟</p><p>٥- <span class="qpc-hafs">﴿سَنُرِيهِمْ ءَايَٰتِنَا فِى ٱلْءَافَاقِ وَفِىٓ أَنفُسِهِمْ حَتَّىٰ يَتَبَيَّنَ لَهُمْ أَنَّهُ ٱلْحَقُّ﴾</span></p><p>أي: أن القرآن حق؛ فأخبر أنه لا بد أن يريهم من آياته المشهودة ما يبين لهم أن آياته المتلوة حق. [ابن القيم:٢/٤٢٠]</p><p>السؤال: آيات الله في الكون والنفس دالة على صحة القرآن، وضح ذلك من خلال الآية.</p><p>٦- <span class="qpc-hafs">﴿سَنُرِيهِمْ ءَايَٰتِنَا فِى ٱلْءَافَاقِ وَفِىٓ أَنفُسِهِمْ حَتَّىٰ يَتَبَيَّنَ لَهُمْ أَنَّهُ ٱلْحَقُّ﴾</span></p><p>فـي هذه الآية طرف من الإعجاز بالإخبار عن الغيب إذ أخبرتْ بالوعد بحصول النصر له ولدينه؛ وذلك بما يسَّر الله لرسوله صلى الله عليه وسلم ولخلفائه مِن بعده في آفاق الدّنيا والمشرق والمغرب عامة وفي بَاحة العرب خاصة من الفتوح وثباتها وانطباع الأمم بها ما لم تتيسر أمْثالها لأحد من ملوك الأرض والقياصرة والأكاسرة على قلة المسلمين... والتاريخ شاهد بأن ما تهيأ للمسلمين من عجائب الانتشار والسلطان على الأمم أمر خارق للعادة، فيتبين أن دين الإسلام هو الحق وأن المسلمين كلما تمسكوا بعرى الإسلام لقوا من نصر الله أمرا عجيبا؛ يشهد بذلك السابق واللاحق. [ابن عاشور: ٢٥/١٨]</p><p>السؤال: في الآية الكريمة إعجاز غيبي، بيِّنه.</p><p>٧- <span class="qpc-hafs">﴿أَلَآ إِنَّهُمْ فِى مِرْيَةٍ مِّن لِّقَآءِ رَبِّهِمْ﴾</span></p><p>إن عمر بن عبد العزيز رضي الله عنه صعد المنبر فحمد الله وأثنى عليه، ثم قال: أما بعد أيها الناس، فإني لم أجمعكم لأمر أحدثه فيكم، ولكن فكرت في هذا الأمر الذي أنتم إليه صائرون، فعلمت أن المصدق بهذا الأمر أحمق، والمكذب به هالك، ثم نزل. ومعنى قوله رضي الله عنه: <span class="qpc-hafs">﴿إن المصدق به أحمق﴾</span> أي: لأنه لا يعمل له عمل مثله، ولا يحذر منه، ولا يخاف من هوله، وهو مع ذلك مصدق به، موقن بوقوعه، وهو مع ذلك يتمادى في لعبه وغفلته وشهواته وذنوبه، فهو أحمق بهذا الاعتبار، والأحمق في اللغة ضعيف العقل. [ابن كثير:٤/١٠٧]</p><p>السؤال: بعض الذين يصدقون بيوم القيامة ينبئ حالهم بأنهم في مرية وشك منه، بَيِّن ذلك.</p><h3>التوجيهات</h3><p>١- في يوم القيامة يفترق كل داع عمن كان يدعوه، ويتبرأ كلٌ من الآخر، <span class="qpc-hafs">﴿وَضَلَّ عَنْهُم مَّا كَانُوا۟ يَدْعُونَ مِن قَبْلُ﴾</span></p><p>٢- ضعف الإنسان حتى في عقله وتصوراته، <span class="qpc-hafs">﴿وَإِذَآ أَنْعَمْنَا عَلَى ٱلْإِنسَٰنِ أَعْرَضَ وَنَـَٔا بِجَانِبِهِۦ وَإِذَا مَسَّهُ ٱلشَّرُّ فَذُو دُعَآءٍ عَرِيضٍ﴾</span></p><p>٣- الإنسان بلا إيمان من أضل المخلوقات، <span class="qpc-hafs">﴿مَنْ أَضَلُّ مِمَّنْ هُوَ فِى شِقَاقٍۭ بَعِيدٍ﴾</span></p><h3>العمل بالآيات</h3><p>١- سل الله من واسع رزقه وأن يعلمك علما نافعا، <span class="qpc-hafs">﴿وَمَا تَخْرُجُ مِن ثَمَرَٰتٍ مِّنْ أَكْمَامِهَا وَمَا تَحْمِلُ مِنْ أُنثَىٰ وَلَا تَضَعُ إِلَّا بِعِلْمِهِۦ﴾</span></p><p>٢- اقرأ بعض الآيات والأحاديث المتعلقة بالساعة، <span class="qpc-hafs">﴿۞ إِلَيْهِ يُرَدُّ عِلْمُ ٱلسَّاعَةِ ۚ وَمَا تَخْرُجُ مِن ثَمَرَٰتٍ مِّنْ أَكْمَامِهَا وَمَا تَحْمِلُ مِنْ أُنثَىٰ وَلَا تَضَعُ إِلَّا بِعِلْمِهِۦ﴾</span></p><p>٣- ادع الله بتفريج همك، <span class="qpc-hafs">﴿وَإِن مَّسَّهُ ٱلشَّرُّ فَيَـُٔوسٌ قَنُوطٌ﴾</span></p><h3>معاني الكلمات</h3><p><span class="qpc-hafs">﴿أَكْمَامِهَا﴾</span> أَوْعِيَتِهَا.</p><p><span class="qpc-hafs">﴿آذَنَّاكَ﴾</span> أَعْلَمْنَاكَ.</p><p><span class="qpc-hafs">﴿وَضَلَّ﴾</span> ذَهَبَ، وَغَابَ.</p><p><span class="qpc-hafs">﴿وَظَنُّوا﴾</span> أَيْقَنُوا.</p><p><span class="qpc-hafs">﴿مَحِيصٍ﴾</span> مَلَجَإٍ، وَمَهْرَبٍ.</p><p><span class="qpc-hafs">﴿لاَ يَسْأَمُ﴾</span> لاَ يَمَلُّ.</p><p><span class="qpc-hafs">﴿مِنْ دُعَاءِ الْخَيْرِ﴾</span> طَلَبِ الزِّيَادَةِ فِي الدُّنْيَا.</p><p><span class="qpc-hafs">﴿الشَّرُّ﴾</span> الفَقْرُ، وَالمَرَضُ، وَالخَوْفُ.</p><p><span class="qpc-hafs">﴿وَمَا أَظُنُّ﴾</span> مَا أَعْتَقِدُ.</p><p><span class="qpc-hafs">﴿غَلِيظٍ﴾</span> شَدِيدٍ.</p><p><span class="qpc-hafs">﴿وَنَأَى بِجَانِبِهِ﴾</span> تَبَاعَدَ عَنْ شُكْرِ النِّعْمَةِ، وَاتِّبَاعِ الحَقِّ؛ تَكَبُّرًا.</p><p><span class="qpc-hafs">﴿فَذُو دُعَاءٍ عَرِيضٍ﴾</span> صَاحِبُ دُعَاءٍ بِكَشْفِ الضُّرِّ كَثِيرٍ.</p><p><span class="qpc-hafs">﴿أَرَأَيْتُمْ﴾</span> أَخْبِرُونِي.</p><p><span class="qpc-hafs">﴿مَنْ أَضَلُّ﴾</span> لاَ أَحَدَ أَضَلُّ.</p><p><span class="qpc-hafs">﴿شِقَاقٍ بَعِيدٍ﴾</span> خِلاَفٍ بَعِيدٍ عَنِ الحَقِّ.</p><p><span class="qpc-hafs">﴿الآفَاقِ﴾</span> أَقْطَارِ السَّمَاوَاتِ، وَالأَرْضِ.</p><p><span class="qpc-hafs">﴿أَنَّهُ الْحَقُّ﴾</span> أَنَّ القُرْآنَ حَقٌّ لاَ رَيْبَ فِيهِ.</p><p><span class="qpc-hafs">﴿أَوَلَمْ يَكْفِ بِرَبِّكَ﴾</span> أَلاَ يَكْفِيهِمْ دَلاَلَةً عَلَى أَنَّ القُرْآنَ حَقٌّ: شَهَادَةُ اللهِ لَهُ بِذَلِكَ؟!</p><p><span class="qpc-hafs">﴿مِرْيَةٍ﴾</span> شَكٍّ عَظِيمٍ.</p></div>"
