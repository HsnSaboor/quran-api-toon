quran[7]{c,v,t}:
  7,131,"<div class=ar lang=ar><h3>الوقفات التدبرية</h3><p>١- <span class="qpc-hafs">﴿فَإِذَا جَآءَتْهُمُ ٱلْحَسَنَةُ قَالُوا۟ لَنَا هَٰذِهِۦ﴾</span></p><p>أي: نحن مستحقون لها، فلم يشكروا الله عليها. [السعدي:٣٠١]</p><p>السؤال: ما حال الكفار مع نعم الله عز وجل؟</p><p>٢- <span class="qpc-hafs">﴿فَإِذَا جَآءَتْهُمُ ٱلْحَسَنَةُ قَالُوا۟ لَنَا هَٰذِهِۦ ۖ وَإِن تُصِبْهُمْ سَيِّئَةٌ يَطَّيَّرُوا۟ بِمُوسَىٰ وَمَن مَّعَهُۥٓ ۗ أَلَآ إِنَّمَا طَٰٓئِرُهُمْ عِندَ ٱللَّهِ وَلَٰكِنَّ أَكْثَرَهُمْ لَا يَعْلَمُونَ﴾</span></p><p><span class="qpc-hafs">﴿ولكن أكثرهم لا يعلمون﴾</span> أن ما لحقهم من القحط والشدائد إنما هو من عند الله - عز وجل- بذنوبهم. [القرطبي:٩/٣٠٨]</p><p>السؤال: هل يدرك أكثر الناس سبب نزول العقوبات والمحن بهم؟</p><p>٣- <span class="qpc-hafs">﴿فَأَرْسَلْنَا عَلَيْهِمُ ٱلطُّوفَانَ وَٱلْجَرَادَ وَٱلْقُمَّلَ وَٱلضَّفَادِعَ وَٱلدَّمَ ءَايَٰتٍ مُّفَصَّلَٰتٍ فَٱسْتَكْبَرُوا۟ وَكَانُوا۟ قَوْمًا مُّجْرِمِينَ﴾</span></p><p>وسمى الله هاته آيات لأنها دلائل على صدق موسى؛ لاقترانها بالتحدي، ولأنها دلائل على غضب الله عليهم. [ابن عاشور:٩/٧٠]</p><p>السؤال: لماذا سمى الله تعالى الأمور المذكورة في الآية الكريمة آيات؟</p><p>٤- <span class="qpc-hafs">﴿فَٱنتَقَمْنَا مِنْهُمْ فَأَغْرَقْنَٰهُمْ فِى ٱلْيَمِّ بِأَنَّهُمْ كَذَّبُوا۟ بِـَٔايَٰتِنَا وَكَانُوا۟ عَنْهَا غَٰفِلِينَ﴾</span></p><p><span class="qpc-hafs">﴿وكانوا عنها﴾</span>:...عن الآيات؛ أي: لم يعتبروا بها حتى صاروا كالغافلين عنها. [القرطبي:٩/٣١٥]</p><p>السؤال: ما حقيقة الغفلة؟</p><p>٥- <span class="qpc-hafs">﴿ٱنتَقَمْنَا مِنْهُمْ فَأَغْرَقْنَٰهُمْ فِى ٱلْيَمِّ بِأَنَّهُمْ كَذَّبُوا۟ بِـَٔايَٰتِنَا وَكَانُوا۟ عَنْهَا غَٰفِلِينَ﴾</span></p><p>أي: أغرقناهم جزاء على تكذيبهم بالآيات, والغفلة: ذهول الذهن عن تذكر شيء... وأريد بها التغافل عن عمد؛ وهو الإعراض عن التفكر في الآيات، وإباية النظر في دلالتها على صدق موسى. [ابن عاشور:٩/٧٥]</p><p>السؤال: ما الغفلة التي وقع فيها قوم فرعون؟</p><p>٦- <span class="qpc-hafs">﴿وَأَوْرَثْنَا ٱلْقَوْمَ ٱلَّذِينَ كَانُوا۟ يُسْتَضْعَفُونَ مَشَٰرِقَ ٱلْأَرْضِ وَمَغَٰرِبَهَا ٱلَّتِى بَٰرَكْنَا فِيهَا﴾</span></p><p>قد أخبر الله بأنه بارك في أرض الشام في آيات: منها قوله: <span class="qpc-hafs">﴿وأورثنا القوم الذين كانوا يستضعفون مشارق الأرض ومغاربها التي باركنا فيها﴾</span>. [ابن تيمية:٣/١٩٤]</p><p>السؤال: هذه الآية الكريمة دليل على بركة أرض الشام، بين ذلك؟</p><p>٧- <span class="qpc-hafs">﴿وَتَمَّتْ كَلِمَتُ رَبِّكَ ٱلْحُسْنَىٰ عَلَىٰ بَنِىٓ إِسْرَٰٓءِيلَ بِمَا صَبَرُوا۟﴾</span></p><p>يعني: بتمامها نفاذ ما وعدهم به من النصر على فرعون، وإهلاكه. [ابن تيمية:٣/١٩٤]</p><p>السؤال: ما معنى تمام كلمة الله تعالى المذكور في الآية الكريمة؟</p><h3>التوجيهات</h3><p>١- على الإنسان أن يشكر الله تعالى على نِعَمه، ويعلم أنه لا فضل له فيها، بل هي محض فضل الله تعالى، <span class="qpc-hafs">﴿فَإِذَا جَآءَتْهُمُ ٱلْحَسَنَةُ قَالُوا۟ لَنَا هَٰذِهِۦ﴾</span></p><p>٢- من أكثر ما يضر ابن آدم: المكابرة والمعاندة، <span class="qpc-hafs">﴿وَقَالُوا۟ مَهْمَا تَأْتِنَا بِهِۦ مِنْ ءَايَةٍ لِّتَسْحَرَنَا بِهَا فَمَا نَحْنُ لَكَ بِمُؤْمِنِينَ﴾</span></p><p>٣- احذر الغفلة عن آيات الله تعالى؛ فإنها سبب لنزول العقوبة والعذاب، <span class="qpc-hafs">﴿فَٱنتَقَمْنَا مِنْهُمْ فَأَغْرَقْنَٰهُمْ فِى ٱلْيَمِّ بِأَنَّهُمْ كَذَّبُوا۟ بِـَٔايَٰتِنَا وَكَانُوا۟ عَنْهَا غَٰفِلِينَ﴾</span></p><h3>العمل بالآيات</h3><p>١- أرسل رسالة، أو الق كلمة تحذر فيها المجتمع من معاداة أولياء الله تعالى ودينهم، وقبول الله دعاءهم عليهم، <span class="qpc-hafs">﴿وَلَمَّا وَقَعَ عَلَيْهِمُ ٱلرِّجْزُ قَالُوا۟ يَٰمُوسَى ٱدْعُ لَنَا رَبَّكَ بِمَا عَهِدَ عِندَكَ ۖ لَئِن كَشَفْتَ عَنَّا ٱلرِّجْزَ لَنُؤْمِنَنَّ لَكَ﴾</span></p><p>٢- تذكر ثلاثة مواضع نصر الله فيها المؤمنين المستضعفين على عدوهم القوي، <span class="qpc-hafs">﴿وَأَوْرَثْنَا ٱلْقَوْمَ ٱلَّذِينَ كَانُوا۟ يُسْتَضْعَفُونَ مَشَٰرِقَ ٱلْأَرْضِ وَمَغَٰرِبَهَا ٱلَّتِى بَٰرَكْنَا فِيهَا ۖ وَتَمَّتْ كَلِمَتُ رَبِّكَ ٱلْحُسْنَىٰ عَلَىٰ بَنِىٓ إِسْرَٰٓءِيلَ بِمَا صَبَرُوا۟﴾</span></p><p>٣- تذكر ثلاث مصائب حديثة حلت بالمجتمع بسبب المجاهرة بالذنوب، وترك الأمر بالمعرف والنهي عن المنكر، <span class="qpc-hafs">﴿فَٱنتَقَمْنَا مِنْهُمْ فَأَغْرَقْنَٰهُمْ فِى ٱلْيَمِّ بِأَنَّهُمْ كَذَّبُوا۟ بِـَٔايَٰتِنَا وَكَانُوا۟ عَنْهَا غَٰفِلِينَ﴾</span></p><h3>معاني الكلمات</h3><p><span class="qpc-hafs">﴿الْحَسَنَةُ﴾</span> الْخَصْبُ، وَالرِّزْقُ.</p><p><span class="qpc-hafs">﴿سَيِّئَةٌ﴾</span> قَحْطٌ، وَجَدْبٌ.</p><p><span class="qpc-hafs">﴿يَطَّيَّرُوا﴾</span> يَتَشَاءَمُوا.</p><p><span class="qpc-hafs">﴿طَائِرُهُمْ عِنْدَ اللَّهِ﴾</span> مَا أَصَابَهُمْ مِنَ الْقَحْطِ بِقَدَرِ اللهِ.</p><p><span class="qpc-hafs">﴿الطُّوفَانَ﴾</span> السَّيْلَ الْجَارِفَ الَّذِي أَغْرَقَ زُرُوعَهُمْ.</p><p><span class="qpc-hafs">﴿وَالْجَرَادَ﴾</span> الَّذِي أَكَلَ زَرْعَهُمْ، وَأَشْيَاءَهُمْ.</p><p><span class="qpc-hafs">﴿وَالْقُمَّلَ﴾</span> الَّذِي يُفْسِدُ الثِّمَارَ، وَيَقْضِي عَلَى الْحَيَوَانِ وَالنَّبَاتِ.</p><p><span class="qpc-hafs">﴿وَالضَّفَادِعَ﴾</span> الَّتِي مَلَأَتْ آنِيَتَهُمْ، وَمَضَاجِعَهُمْ.</p><p><span class="qpc-hafs">﴿وَالدَّمَ﴾</span> الَّذِي اخْتَلَطَ بِمِيَاهِهِمْ.</p><p><span class="qpc-hafs">﴿مُفَصَّلاَتٍ﴾</span> مُبَيَّنَاتٍ.</p><p><span class="qpc-hafs">﴿الرِّجْزُ﴾</span> الْعَذَابُ.</p><p><span class="qpc-hafs">﴿عَهِدَ﴾</span> أَوْحَى.</p><p><span class="qpc-hafs">﴿يَنْكُثُونَ﴾</span> يَنقُضُونَ عَهْدَهُمْ.</p><p><span class="qpc-hafs">﴿الْيَمِّ﴾</span> الْبَحْرِ.</p><p><span class="qpc-hafs">﴿مَشَارِقَ الأَرْضَ وَمَغَارِبَهَا﴾</span> بِلاَدَ الشَّامِ.</p><p><span class="qpc-hafs">﴿يَعْرِشُونَ﴾</span> يَرْفَعُونَ مِنَ الْبِنَاءِ.</p></div>"
