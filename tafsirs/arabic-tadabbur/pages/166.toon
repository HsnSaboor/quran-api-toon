quran[7]{c,v,t}:
  7,131,"

الوقفات التدبرية

١- <q>﴿فَإِذَا جَآءَتْهُمُ ٱلْحَسَنَةُ قَالُوا۟ لَنَا هَٰذِهِۦ﴾</q>

أي: نحن مستحقون لها، فلم يشكروا الله عليها. [السعدي:٣٠١]

السؤال: ما حال الكفار مع نعم الله عز وجل؟

٢- <q>﴿فَإِذَا جَآءَتْهُمُ ٱلْحَسَنَةُ قَالُوا۟ لَنَا هَٰذِهِۦ ۖ وَإِن تُصِبْهُمْ سَيِّئَةٌ يَطَّيَّرُوا۟ بِمُوسَىٰ وَمَن مَّعَهُۥٓ ۗ أَلَآ إِنَّمَا طَٰٓئِرُهُمْ عِندَ ٱللَّهِ وَلَٰكِنَّ أَكْثَرَهُمْ لَا يَعْلَمُونَ﴾</q>

<q>﴿ولكن أكثرهم لا يعلمون﴾</q> أن ما لحقهم من القحط والشدائد إنما هو من عند الله - عز وجل- بذنوبهم. [القرطبي:٩/٣٠٨]

السؤال: هل يدرك أكثر الناس سبب نزول العقوبات والمحن بهم؟

٣- <q>﴿فَأَرْسَلْنَا عَلَيْهِمُ ٱلطُّوفَانَ وَٱلْجَرَادَ وَٱلْقُمَّلَ وَٱلضَّفَادِعَ وَٱلدَّمَ ءَايَٰتٍ مُّفَصَّلَٰتٍ فَٱسْتَكْبَرُوا۟ وَكَانُوا۟ قَوْمًا مُّجْرِمِينَ﴾</q>

وسمى الله هاته آيات لأنها دلائل على صدق موسى؛ لاقترانها بالتحدي، ولأنها دلائل على غضب الله عليهم. [ابن عاشور:٩/٧٠]

السؤال: لماذا سمى الله تعالى الأمور المذكورة في الآية الكريمة آيات؟

٤- <q>﴿فَٱنتَقَمْنَا مِنْهُمْ فَأَغْرَقْنَٰهُمْ فِى ٱلْيَمِّ بِأَنَّهُمْ كَذَّبُوا۟ بِـَٔايَٰتِنَا وَكَانُوا۟ عَنْهَا غَٰفِلِينَ﴾</q>

<q>﴿وكانوا عنها﴾</q>:...عن الآيات؛ أي: لم يعتبروا بها حتى صاروا كالغافلين عنها. [القرطبي:٩/٣١٥]

السؤال: ما حقيقة الغفلة؟

٥- <q>﴿ٱنتَقَمْنَا مِنْهُمْ فَأَغْرَقْنَٰهُمْ فِى ٱلْيَمِّ بِأَنَّهُمْ كَذَّبُوا۟ بِـَٔايَٰتِنَا وَكَانُوا۟ عَنْهَا غَٰفِلِينَ﴾</q>

أي: أغرقناهم جزاء على تكذيبهم بالآيات, والغفلة: ذهول الذهن عن تذكر شيء... وأريد بها التغافل عن عمد؛ وهو الإعراض عن التفكر في الآيات، وإباية النظر في دلالتها على صدق موسى. [ابن عاشور:٩/٧٥]

السؤال: ما الغفلة التي وقع فيها قوم فرعون؟

٦- <q>﴿وَأَوْرَثْنَا ٱلْقَوْمَ ٱلَّذِينَ كَانُوا۟ يُسْتَضْعَفُونَ مَشَٰرِقَ ٱلْأَرْضِ وَمَغَٰرِبَهَا ٱلَّتِى بَٰرَكْنَا فِيهَا﴾</q>

قد أخبر الله بأنه بارك في أرض الشام في آيات: منها قوله: <q>﴿وأورثنا القوم الذين كانوا يستضعفون مشارق الأرض ومغاربها التي باركنا فيها﴾</q>. [ابن تيمية:٣/١٩٤]

السؤال: هذه الآية الكريمة دليل على بركة أرض الشام، بين ذلك؟

٧- <q>﴿وَتَمَّتْ كَلِمَتُ رَبِّكَ ٱلْحُسْنَىٰ عَلَىٰ بَنِىٓ إِسْرَٰٓءِيلَ بِمَا صَبَرُوا۟﴾</q>

يعني: بتمامها نفاذ ما وعدهم به من النصر على فرعون، وإهلاكه. [ابن تيمية:٣/١٩٤]

السؤال: ما معنى تمام كلمة الله تعالى المذكور في الآية الكريمة؟

التوجيهات

١- على الإنسان أن يشكر الله تعالى على نِعَمه، ويعلم أنه لا فضل له فيها، بل هي محض فضل الله تعالى، <q>﴿فَإِذَا جَآءَتْهُمُ ٱلْحَسَنَةُ قَالُوا۟ لَنَا هَٰذِهِۦ﴾</q>

٢- من أكثر ما يضر ابن آدم: المكابرة والمعاندة، <q>﴿وَقَالُوا۟ مَهْمَا تَأْتِنَا بِهِۦ مِنْ ءَايَةٍ لِّتَسْحَرَنَا بِهَا فَمَا نَحْنُ لَكَ بِمُؤْمِنِينَ﴾</q>

٣- احذر الغفلة عن آيات الله تعالى؛ فإنها سبب لنزول العقوبة والعذاب، <q>﴿فَٱنتَقَمْنَا مِنْهُمْ فَأَغْرَقْنَٰهُمْ فِى ٱلْيَمِّ بِأَنَّهُمْ كَذَّبُوا۟ بِـَٔايَٰتِنَا وَكَانُوا۟ عَنْهَا غَٰفِلِينَ﴾</q>

العمل بالآيات

١- أرسل رسالة، أو الق كلمة تحذر فيها المجتمع من معاداة أولياء الله تعالى ودينهم، وقبول الله دعاءهم عليهم، <q>﴿وَلَمَّا وَقَعَ عَلَيْهِمُ ٱلرِّجْزُ قَالُوا۟ يَٰمُوسَى ٱدْعُ لَنَا رَبَّكَ بِمَا عَهِدَ عِندَكَ ۖ لَئِن كَشَفْتَ عَنَّا ٱلرِّجْزَ لَنُؤْمِنَنَّ لَكَ﴾</q>

٢- تذكر ثلاثة مواضع نصر الله فيها المؤمنين المستضعفين على عدوهم القوي، <q>﴿وَأَوْرَثْنَا ٱلْقَوْمَ ٱلَّذِينَ كَانُوا۟ يُسْتَضْعَفُونَ مَشَٰرِقَ ٱلْأَرْضِ وَمَغَٰرِبَهَا ٱلَّتِى بَٰرَكْنَا فِيهَا ۖ وَتَمَّتْ كَلِمَتُ رَبِّكَ ٱلْحُسْنَىٰ عَلَىٰ بَنِىٓ إِسْرَٰٓءِيلَ بِمَا صَبَرُوا۟﴾</q>

٣- تذكر ثلاث مصائب حديثة حلت بالمجتمع بسبب المجاهرة بالذنوب، وترك الأمر بالمعرف والنهي عن المنكر، <q>﴿فَٱنتَقَمْنَا مِنْهُمْ فَأَغْرَقْنَٰهُمْ فِى ٱلْيَمِّ بِأَنَّهُمْ كَذَّبُوا۟ بِـَٔايَٰتِنَا وَكَانُوا۟ عَنْهَا غَٰفِلِينَ﴾</q>

معاني الكلمات

<q>﴿الْحَسَنَةُ﴾</q> الْخَصْبُ، وَالرِّزْقُ.

<q>﴿سَيِّئَةٌ﴾</q> قَحْطٌ، وَجَدْبٌ.

<q>﴿يَطَّيَّرُوا﴾</q> يَتَشَاءَمُوا.

<q>﴿طَائِرُهُمْ عِنْدَ اللَّهِ﴾</q> مَا أَصَابَهُمْ مِنَ الْقَحْطِ بِقَدَرِ اللهِ.

<q>﴿الطُّوفَانَ﴾</q> السَّيْلَ الْجَارِفَ الَّذِي أَغْرَقَ زُرُوعَهُمْ.

<q>﴿وَالْجَرَادَ﴾</q> الَّذِي أَكَلَ زَرْعَهُمْ، وَأَشْيَاءَهُمْ.

<q>﴿وَالْقُمَّلَ﴾</q> الَّذِي يُفْسِدُ الثِّمَارَ، وَيَقْضِي عَلَى الْحَيَوَانِ وَالنَّبَاتِ.

<q>﴿وَالضَّفَادِعَ﴾</q> الَّتِي مَلَأَتْ آنِيَتَهُمْ، وَمَضَاجِعَهُمْ.

<q>﴿وَالدَّمَ﴾</q> الَّذِي اخْتَلَطَ بِمِيَاهِهِمْ.

<q>﴿مُفَصَّلاَتٍ﴾</q> مُبَيَّنَاتٍ.

<q>﴿الرِّجْزُ﴾</q> الْعَذَابُ.

<q>﴿عَهِدَ﴾</q> أَوْحَى.

<q>﴿يَنْكُثُونَ﴾</q> يَنقُضُونَ عَهْدَهُمْ.

<q>﴿الْيَمِّ﴾</q> الْبَحْرِ.

<q>﴿مَشَارِقَ الأَرْضَ وَمَغَارِبَهَا﴾</q> بِلاَدَ الشَّامِ.

<q>﴿يَعْرِشُونَ﴾</q> يَرْفَعُونَ مِنَ الْبِنَاءِ.

