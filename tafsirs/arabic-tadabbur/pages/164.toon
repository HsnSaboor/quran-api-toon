quran[16]{c,v,t}:
  7,105,"<div class=ar lang=ar><h3>الوقفات التدبرية</h3><p>١- <span class="qpc-hafs">﴿فَأَلْقَىٰ عَصَاهُ فَإِذَا هِىَ ثُعْبَانٌ مُّبِينٌ (١٠٧) وَنَزَعَ يَدَهُۥ فَإِذَا هِىَ بَيْضَآءُ لِلنَّٰظِرِينَ(١٠٨) قَالَ ٱلْمَلَأُ مِن قَوْمِ فِرْعَوْنَ إِنَّ هَٰذَا لَسَٰحِرٌ عَلِيمٌ﴾</span></p><p><span class="qpc-hafs">﴿فألقى﴾</span> موسى <span class="qpc-hafs">﴿عصاه﴾</span> في الأرض <span class="qpc-hafs">﴿فإذا هي ثعبان مبين﴾</span> أي: حية ظاهرة تسعى، وهم يشاهدونها. <span class="qpc-hafs">﴿ونزع يده﴾</span> من جيبه <span class="qpc-hafs">﴿فإذا هي بيضاء للناظرين﴾</span> من غير سوء، فهاتان آيتان كبيرتان دالتان على صحة ما جاء به موسى وصدقه، وأنه رسول رب العالمين، ولكن الذين لا يؤمنون لو جاءتهم كل آية لا يؤمنون حتى يروا العذاب الأليم. [السعدي:١/٢٩٩]</p><p>السؤال: هل تحصل الهداية بمجرد العقل، أم هي منة من الله؟ وضح ذلك من الآيات.</p><p>٢- <span class="qpc-hafs">﴿قَالُوٓا۟ أَرْجِهْ وَأَخَاهُ وَأَرْسِلْ فِى ٱلْمَدَآئِنِ حَٰشِرِينَ(١١١) يَأْتُوكَ بِكُلِّ سَٰحِرٍ عَلِيمٍ﴾</span></p><p>والشأن أن يكون ملأ فرعون عقلاء أهل سياسة، فعلموا أن أمر دعوة موسى لا يكاد يخفى، وأن فرعون إن سجنه أو عاند تحقق الناس أن حجة موسى غلبت، فصار ذلك ذريعة للشك في دين فرعون، فرأوا أن يلاينوا موسى، وطمعوا أن يوجد في سحرة مصر من يدافع آيات موسى، فتكون الحجة عليه ظاهرة للناس. [ابن عاشور:٩/٤٤]</p><p>السؤال: لماذا لم يقترح ملأ فرعون عليه أن يسجن موسى عليه السلام؟</p><p>٣- <span class="qpc-hafs">﴿وَجَآءَ ٱلسَّحَرَةُ فِرْعَوْنَ قَالُوٓا۟ إِنَّ لَنَا لَأَجْرًا إِن كُنَّا نَحْنُ ٱلْغَٰلِبِينَ﴾</span></p><p><span class="qpc-hafs">﴿قالوا﴾</span> لفرعون <span class="qpc-hafs">﴿إن لنا لأجرًاً﴾</span> أي: جُعلا ومالا. [البغوي:٢/١٣٥]</p><p>السؤال: كيف بينت الآية أن من أهم صفات دعاة الضلال الحرص على الدنيا؟</p><p>٤- <span class="qpc-hafs">﴿وَجَآءَ ٱلسَّحَرَةُ فِرْعَوْنَ قَالُوٓا۟ إِنَّ لَنَا لَأَجْرًا إِن كُنَّا نَحْنُ ٱلْغَٰلِبِينَ (١١٣) قَالَ نَعَمْ وَإِنَّكُمْ لَمِنَ ٱلْمُقَرَّبِي﴾</span></p><p>قال فرعون للسحرة، إذ قالوا له: إن لنا عندك ثوابًا إن نحن غلبنا موسى؟ قال: نعم، لكم ذلك، وإنكم لممن أقرِّبه وأدْنيه مني. [الطبري:١٣/٢٦]</p><p>السؤال: في الآية إشارة لحرص الطغاة على تقريب أئمة الضلال واستشارتهم ، وضح ذلك؟</p><p>٥- <span class="qpc-hafs">﴿قَالُوا۟ يَٰمُوسَىٰٓ إِمَّآ أَن تُلْقِىَ وَإِمَّآ أَن نَّكُونَ نَحْنُ ٱلْمُلْقِينَ (١١٥) قَالَ أَلْقُوا۟﴾</span></p><p>قيل: الحكمة في هذا -والله أعلم- ليرى الناس صنيعَهم، ويتأملوه، فإذا فرغوا من بهرجهم ومحالهم؛ جاءهم الحق الواضح الجلي بعد التطلب له، والانتظار منهم لمجيئه، فيكون أوقع في النفوس، وكذا كان. [ابن كثير:٢/٢٢٧]</p><p>السؤال: ما الحكمة في تفضيل موسى أن يلقي السحرة عصيهم قبله؟</p><p>٦- <span class="qpc-hafs">﴿قَالُوا۟ يَٰمُوسَىٰٓ إِمَّآ أَن تُلْقِىَ وَإِمَّآ أَن نَّكُونَ نَحْنُ ٱلْمُلْقِينَ (١١٥) قَالَ أَلْقُوا۟ ۖ فَلَمَّآ أَلْقَوْا۟ سَحَرُوٓا۟ أَعْيُنَ ٱلنَّاسِ وَٱسْتَرْهَبُوهُمْ وَجَآءُو بِسِحْرٍ عَظِيمٍ﴾</span></p><p>تأدبوا مع موسى -عليه السلام- فكان ذلك سبب إيمانهم . [القرطبي:٩/٢٩٦]</p><p>السؤال: من خلال الآية: بين ثمرة الأدب مع العلماء والصالحين؟</p><p>٧- <span class="qpc-hafs">﴿وَأُلْقِىَ ٱلسَّحَرَةُ سَٰجِدِينَ﴾</span></p><p>وأعظم من تبين له الحق العظيم: أهل الصنف والسحر، الذين يعرفون من أنواع السحر وجزئياته ما لا يعرفه غيرهم، فعرفوا أن هذه آية عظيمة من آيات الله، لا يدان لأحد بها. [السعدي:٣٠٠]</p><p>السؤال: لماذا كان السحرة أسرع الناس إيماناً في هذه الحادثة؟</p><h3>التوجيهات</h3><p>١- جهل المجتمع بالحق يؤد ي إلى سهولة الكذب عليهم، <span class="qpc-hafs">﴿قَالَ ٱلْمَلَأُ مِن قَوْمِ فِرْعَوْنَ إِنَّ هَٰذَا لَسَٰحِرٌ عَلِيمٌ﴾</span></p><p>٢- مكر الملأ وكذبهم إذ اتهموا موسى بأنه يريد الملك، وهو إنما أراد تعبيد الناس لله وحده، <span class="qpc-hafs">﴿يُرِيدُ أَن يُخْرِجَكُم مِّنْ أَرْضِكُمْ ۖ فَمَاذَا تَأْمُرُونَ﴾</span></p><p>٣- مهما فشا الباطل وارتفع، واغتر به المتعجلون، فإن للحق يوما يظهر فيه ويعلو، <span class="qpc-hafs">﴿فَغُلِبُوا۟ هُنَالِكَ وَٱنقَلَبُوا۟ صَٰغِرِينَ (١١٩) وَأُلْقِىَ ٱلسَّحَرَةُ سَٰجِدِينَ﴾</span></p><h3>العمل بالآيات</h3><p>١- اعمل مشروعًا أو عملاً قوليًا أو ماليًا تدافع به عن مظلومين، وتساعد فيه مضطهدين، <span class="qpc-hafs">﴿فَأَرْسِلْ مَعِىَ بَنِىٓ إِسْرَٰٓءِيلَ﴾</span></p><p>٢- سل الله تعالى أن يستخدمك في طاعته، وأن تكون من أنصار الحق, <span class="qpc-hafs">﴿وَأَوْحَيْنَآ إِلَىٰ مُوسَىٰٓ أَنْ أَلْقِ عَصَاكَ ۖ فَإِذَا هِىَ تَلْقَفُ مَا يَأْفِكُونَ (١١٧) فَوَقَعَ ٱلْحَقُّ وَبَطَلَ مَا كَانُوا۟ يَعْمَلُونَ﴾</span></p><p>٣- انشر مقطعاً مرئياً، أو محاضرة تبيّن خطورة السحر<span class="qpc-hafs">﴿فَوَقَعَ ٱلْحَقُّ وَبَطَلَ مَا كَانُوا۟ يَعْمَلُونَ﴾</span></p><h3>معاني الكلمات</h3><p><span class="qpc-hafs">﴿حَقِيقٌ﴾</span> جَدِيرٌ.</p><p><span class="qpc-hafs">﴿ثُعْبَانٌ مُبِينٌ﴾</span> حَيَّةٌ عَظِيمَةٌ.</p><p><span class="qpc-hafs">﴿وَنَزَعَ يَدَهُ﴾</span> نَزَعَهَا مِنْ جَيْبِهِ، أَوْ جَنَاحِهِ.</p><p><span class="qpc-hafs">﴿أَرْجِهْ﴾</span> أَخِّرْهُ.</p><p><span class="qpc-hafs">﴿وَاسْتَرْهَبُوهُمْ﴾</span> خَوَّفُوهُمْ، وَأَرْهَبُوهُمْ.</p><p><span class="qpc-hafs">﴿وَانْقَلَبُوا﴾</span> انْصَرَفُوا.</p><p><span class="qpc-hafs">﴿صَاغِرِينَ﴾</span> أَذِلاَّءَ، مَقْهُورِينَ.</p></div>"
