tafsir[16]{c,v,t}:
  7,105,"

الوقفات التدبرية

١- <q>﴿فَأَلْقَىٰ عَصَاهُ فَإِذَا هِىَ ثُعْبَانٌ مُّبِينٌ (١٠٧) وَنَزَعَ يَدَهُۥ فَإِذَا هِىَ بَيْضَآءُ لِلنَّٰظِرِينَ(١٠٨) قَالَ ٱلْمَلَأُ مِن قَوْمِ فِرْعَوْنَ إِنَّ هَٰذَا لَسَٰحِرٌ عَلِيمٌ﴾</q>

<q>﴿فألقى﴾</q> موسى <q>﴿عصاه﴾</q> في الأرض <q>﴿فإذا هي ثعبان مبين﴾</q> أي: حية ظاهرة تسعى، وهم يشاهدونها. <q>﴿ونزع يده﴾</q> من جيبه <q>﴿فإذا هي بيضاء للناظرين﴾</q> من غير سوء، فهاتان آيتان كبيرتان دالتان على صحة ما جاء به موسى وصدقه، وأنه رسول رب العالمين، ولكن الذين لا يؤمنون لو جاءتهم كل آية لا يؤمنون حتى يروا العذاب الأليم. [السعدي:١/٢٩٩]

السؤال: هل تحصل الهداية بمجرد العقل، أم هي منة من الله؟ وضح ذلك من الآيات.

٢- <q>﴿قَالُوٓا۟ أَرْجِهْ وَأَخَاهُ وَأَرْسِلْ فِى ٱلْمَدَآئِنِ حَٰشِرِينَ(١١١) يَأْتُوكَ بِكُلِّ سَٰحِرٍ عَلِيمٍ﴾</q>

والشأن أن يكون ملأ فرعون عقلاء أهل سياسة، فعلموا أن أمر دعوة موسى لا يكاد يخفى، وأن فرعون إن سجنه أو عاند تحقق الناس أن حجة موسى غلبت، فصار ذلك ذريعة للشك في دين فرعون، فرأوا أن يلاينوا موسى، وطمعوا أن يوجد في سحرة مصر من يدافع آيات موسى، فتكون الحجة عليه ظاهرة للناس. [ابن عاشور:٩/٤٤]

السؤال: لماذا لم يقترح ملأ فرعون عليه أن يسجن موسى عليه السلام؟

٣- <q>﴿وَجَآءَ ٱلسَّحَرَةُ فِرْعَوْنَ قَالُوٓا۟ إِنَّ لَنَا لَأَجْرًا إِن كُنَّا نَحْنُ ٱلْغَٰلِبِينَ﴾</q>

<q>﴿قالوا﴾</q> لفرعون <q>﴿إن لنا لأجرًاً﴾</q> أي: جُعلا ومالا. [البغوي:٢/١٣٥]

السؤال: كيف بينت الآية أن من أهم صفات دعاة الضلال الحرص على الدنيا؟

٤- <q>﴿وَجَآءَ ٱلسَّحَرَةُ فِرْعَوْنَ قَالُوٓا۟ إِنَّ لَنَا لَأَجْرًا إِن كُنَّا نَحْنُ ٱلْغَٰلِبِينَ (١١٣) قَالَ نَعَمْ وَإِنَّكُمْ لَمِنَ ٱلْمُقَرَّبِي﴾</q>

قال فرعون للسحرة، إذ قالوا له: إن لنا عندك ثوابًا إن نحن غلبنا موسى؟ قال: نعم، لكم ذلك، وإنكم لممن أقرِّبه وأدْنيه مني. [الطبري:١٣/٢٦]

السؤال: في الآية إشارة لحرص الطغاة على تقريب أئمة الضلال واستشارتهم ، وضح ذلك؟

٥- <q>﴿قَالُوا۟ يَٰمُوسَىٰٓ إِمَّآ أَن تُلْقِىَ وَإِمَّآ أَن نَّكُونَ نَحْنُ ٱلْمُلْقِينَ (١١٥) قَالَ أَلْقُوا۟﴾</q>

قيل: الحكمة في هذا -والله أعلم- ليرى الناس صنيعَهم، ويتأملوه، فإذا فرغوا من بهرجهم ومحالهم؛ جاءهم الحق الواضح الجلي بعد التطلب له، والانتظار منهم لمجيئه، فيكون أوقع في النفوس، وكذا كان. [ابن كثير:٢/٢٢٧]

السؤال: ما الحكمة في تفضيل موسى أن يلقي السحرة عصيهم قبله؟

٦- <q>﴿قَالُوا۟ يَٰمُوسَىٰٓ إِمَّآ أَن تُلْقِىَ وَإِمَّآ أَن نَّكُونَ نَحْنُ ٱلْمُلْقِينَ (١١٥) قَالَ أَلْقُوا۟ ۖ فَلَمَّآ أَلْقَوْا۟ سَحَرُوٓا۟ أَعْيُنَ ٱلنَّاسِ وَٱسْتَرْهَبُوهُمْ وَجَآءُو بِسِحْرٍ عَظِيمٍ﴾</q>

تأدبوا مع موسى -عليه السلام- فكان ذلك سبب إيمانهم . [القرطبي:٩/٢٩٦]

السؤال: من خلال الآية: بين ثمرة الأدب مع العلماء والصالحين؟

٧- <q>﴿وَأُلْقِىَ ٱلسَّحَرَةُ سَٰجِدِينَ﴾</q>

وأعظم من تبين له الحق العظيم: أهل الصنف والسحر، الذين يعرفون من أنواع السحر وجزئياته ما لا يعرفه غيرهم، فعرفوا أن هذه آية عظيمة من آيات الله، لا يدان لأحد بها. [السعدي:٣٠٠]

السؤال: لماذا كان السحرة أسرع الناس إيماناً في هذه الحادثة؟

التوجيهات

١- جهل المجتمع بالحق يؤد ي إلى سهولة الكذب عليهم، <q>﴿قَالَ ٱلْمَلَأُ مِن قَوْمِ فِرْعَوْنَ إِنَّ هَٰذَا لَسَٰحِرٌ عَلِيمٌ﴾</q>

٢- مكر الملأ وكذبهم إذ اتهموا موسى بأنه يريد الملك، وهو إنما أراد تعبيد الناس لله وحده، <q>﴿يُرِيدُ أَن يُخْرِجَكُم مِّنْ أَرْضِكُمْ ۖ فَمَاذَا تَأْمُرُونَ﴾</q>

٣- مهما فشا الباطل وارتفع، واغتر به المتعجلون، فإن للحق يوما يظهر فيه ويعلو، <q>﴿فَغُلِبُوا۟ هُنَالِكَ وَٱنقَلَبُوا۟ صَٰغِرِينَ (١١٩) وَأُلْقِىَ ٱلسَّحَرَةُ سَٰجِدِينَ﴾</q>

العمل بالآيات

١- اعمل مشروعًا أو عملاً قوليًا أو ماليًا تدافع به عن مظلومين، وتساعد فيه مضطهدين، <q>﴿فَأَرْسِلْ مَعِىَ بَنِىٓ إِسْرَٰٓءِيلَ﴾</q>

٢- سل الله تعالى أن يستخدمك في طاعته، وأن تكون من أنصار الحق, <q>﴿وَأَوْحَيْنَآ إِلَىٰ مُوسَىٰٓ أَنْ أَلْقِ عَصَاكَ ۖ فَإِذَا هِىَ تَلْقَفُ مَا يَأْفِكُونَ (١١٧) فَوَقَعَ ٱلْحَقُّ وَبَطَلَ مَا كَانُوا۟ يَعْمَلُونَ﴾</q>

٣- انشر مقطعاً مرئياً، أو محاضرة تبيّن خطورة السحر<q>﴿فَوَقَعَ ٱلْحَقُّ وَبَطَلَ مَا كَانُوا۟ يَعْمَلُونَ﴾</q>

معاني الكلمات

<q>﴿حَقِيقٌ﴾</q> جَدِيرٌ.

<q>﴿ثُعْبَانٌ مُبِينٌ﴾</q> حَيَّةٌ عَظِيمَةٌ.

<q>﴿وَنَزَعَ يَدَهُ﴾</q> نَزَعَهَا مِنْ جَيْبِهِ، أَوْ جَنَاحِهِ.

<q>﴿أَرْجِهْ﴾</q> أَخِّرْهُ.

<q>﴿وَاسْتَرْهَبُوهُمْ﴾</q> خَوَّفُوهُمْ، وَأَرْهَبُوهُمْ.

<q>﴿وَانْقَلَبُوا﴾</q> انْصَرَفُوا.

<q>﴿صَاغِرِينَ﴾</q> أَذِلاَّءَ، مَقْهُورِينَ.

