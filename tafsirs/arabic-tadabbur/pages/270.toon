quran[8]{c,v,t}:
  16,27,"

الوقفات التدبرية

١- <q>﴿ۚ قَالَ ٱلَّذِينَ أُوتُوا۟ ٱلْعِلْمَ إِنَّ ٱلْخِزْىَ ٱلْيَوْمَ وَٱلسُّوٓءَ عَلَى ٱلْكَٰفِرِينَ﴾</q>

في هذا فضيلة لأهل العلم، وأنهم الناطقون بالحق في هذه الدنيا، ويوم يقوم الأشهاد، وأن لقولهم اعتباراً عند الله وعند خلقه. [السعدي:٤٣٩]

السؤال: ما فضيلة أهل العلم المذكورة في الآية؟

٢- <q>﴿فَأَلْقَوُا۟ ٱلسَّلَمَ مَا كُنَّا نَعْمَلُ مِن سُوٓءٍۭ ۚ بَلَىٰٓ إِنَّ ٱللَّهَ عَلِيمٌۢ بِمَا كُنتُمْ تَعْمَلُونَ﴾</q>

وهذا في بعض مواقف القيامة: ينكرون ما كانوا عليه في الدنيا ظناً أنه ينفعهم، فإذا شهدت عليهم جوارحهم، وتبين ما كانوا عليه أقروا واعترفوا؛ ولهذا لا يدخلون النار حتى يعترفوا بذنوبهم. [السعدي:٤٣٩]

السؤال: كيف تجمع بين إنكار المشركين لأعمالهم يوم القيامة واعترافهم بها؟

٣- <q>﴿فَٱدْخُلُوٓا۟ أَبْوَٰبَ جَهَنَّمَ﴾</q>

كُلُّ أهل عملٍ يدخلون من الباب اللائق بحالهم. [السعدي:٤٣٩]

السؤال: أبواب جهنم سبعة، فمن أيِّ باب يدخل أهل النار؟

٤- <q>﴿فَٱدْخُلُوٓا۟ أَبْوَٰبَ جَهَنَّمَ خَٰلِدِينَ فِيهَا ۖ فَلَبِئْسَ مَثْوَى ٱلْمُتَكَبِّرِينَ﴾</q>

وهم يدخلون جهنم من يوم مماتهم بأرواحهم، وينال أجسادهم في قبورها من حرها وسمومها، فإذا كان يوم القيامة سلكت أرواحهم في أجسادهم، وخلدت في نار جهنم. [ابن كثير:٢/٥٤٨]

السؤال: يمر الكافر بعد مماته بمرحلتين من العذاب، ما هما؟

٥- <q>﴿وَقِيلَ لِلَّذِينَ ٱتَّقَوْا۟ مَاذَآ أَنزَلَ رَبُّكُمْ ۚ قَالُوا۟ خَيْرًا ۗ لِّلَّذِينَ أَحْسَنُوا۟ فِى هَٰذِهِ ٱلدُّنْيَا حَسَنَةٌ ۚ وَلَدَارُ ٱلْءَاخِرَةِ خَيْرٌ ۚ وَلَنِعْمَ دَارُ ٱلْمُتَّقِينَ﴾</q>

وحسنة الدّنيا هي الحياة الطيّبة وما فتح الله لهم من زهرة الدنيا مع نعمة الإيمان. [ابن عاشور:١٤/١٤٢]

السؤال: ما حسنة الدنيا الواردة في الآية الكريمة؟

٦- <q>﴿جَنَّٰتُ عَدْنٍ يَدْخُلُونَهَا تَجْرِى مِن تَحْتِهَا ٱلْأَنْهَٰرُ ۖ لَهُمْ فِيهَا مَا يَشَآءُونَ ۚ كَذَٰلِكَ يَجْزِى ٱللَّهُ ٱلْمُتَّقِينَ﴾</q>

وذكر بعضهم أن تقديم <q>﴿فيها﴾</q> للحصر, و <q>﴿ما﴾</q> للعموم بقرينة المقام؛ فيُفيدُ أن الإنسان لا يجد جميع ما يريده إلا في الجنة, فتأمَّلهُ. [الألوسي:١٤/٥٠٠]

السؤال: كيف ينظر المؤمن إلى ما فاته من نعيم الدنيا وكمال زينتها؟

٧- <q>﴿ٱلَّذِينَ تَتَوَفَّىٰهُمُ ٱلْمَلَٰٓئِكَةُ طَيِّبِينَ﴾</q>

طابت قلوبهم بمعرفة الله ومحبته، وألسنتهم بذكره والثناء عليه، وجوارحهم بطاعته والإقبال عليه. [السعدي:٤٣٩]

السؤال: كيف تجعل نفسك طَيِّبَةً عند الموت؟

التوجيهات

١- من تلاعب الشيطان بالعقول الضعيفة أن الالتزام بالوحي يعني التخلف ، <q>﴿وَإِذَا قِيلَ لَهُم مَّاذَآ أَنزَلَ رَبُّكُمْ ۙ قَالُوٓا۟ أَسَٰطِيرُ ٱلْأَوَّلِينَ﴾</q>

٢- يشهَد العلماء الربانيون يوم القيامة على صنيع أهل الدنيا؛ فعليك بمتابعتهم في الدنيا في معرفة ما يحبه الله ويرضاه، <q>﴿ۚ قَالَ ٱلَّذِينَ أُوتُوا۟ ٱلْعِلْمَ إِنَّ ٱلْخِزْىَ ٱلْيَوْمَ وَٱلسُّوٓءَ عَلَى ٱلْكَٰفِرِينَ﴾</q>

٣- احذر السخـرية، أو الاستـهزاء بالدعاة إلى الله، والعلماء المصلحين، <q>﴿فَأَصَابَهُمْ سَيِّـَٔاتُ مَا عَمِلُوا۟ وَحَاقَ بِهِم مَّا كَانُوا۟ بِهِۦ يَسْتَهْزِءُونَ﴾</q>

العمل بالآيات

١- لاتهجر طلب العلم واحضر اليوم درسا، أو اسمع محاضرة، أو اقرأ كتابا؛ فإن الله تعالى يرفع أهل العلم في الدنيا والآخرة، <q>﴿ۚ قَالَ ٱلَّذِينَ أُوتُوا۟ ٱلْعِلْمَ إِنَّ ٱلْخِزْىَ ٱلْيَوْمَ وَٱلسُّوٓءَ عَلَى ٱلْكَٰفِرِينَ﴾</q>

٢- حدد عدة أعمال ثبت أن الله ادخل أصحابها بسببها الجنة، وابدأ اليوم بواحد منها، <q>﴿ٱلَّذِينَ تَتَوَفَّىٰهُمُ ٱلْمَلَٰٓئِكَةُ طَيِّبِينَ ۙ يَقُولُونَ سَلَٰمٌ عَلَيْكُمُ ٱدْخُلُوا۟ ٱلْجَنَّةَ بِمَا كُنتُمْ تَعْمَلُونَ﴾</q>

٣- سل الله تعالى حسن الخاتمة, <q>﴿ٱلَّذِينَ تَتَوَفَّىٰهُمُ ٱلْمَلَٰٓئِكَةُ طَيِّبِينَ ۙ يَقُولُونَ سَلَٰمٌ عَلَيْكُمُ ٱدْخُلُوا۟ ٱلْجَنَّةَ بِمَا كُنتُمْ تَعْمَلُونَ﴾</q>

معاني الكلمات

<q>﴿يُخْزِيهِمْ﴾</q> يَفْضَحُهُمْ، وَيُذِلُّهُمْ بِالعَذَابِ.

<q>﴿تُشَآقَّونَ فِيهِمْ﴾</q> تُحَارِبُونَ، وَتُجَادِلُونَ الأَنْبِيَاءَ لأِجْلِهِمْ.

<q>﴿فَأَلْقَوُا السَّلَمَ﴾</q> فَاسْتَسْلَمُوا لأِمْرِ اللهِ.

<q>﴿مَثْوَى﴾</q> مَقَرُّ.

<q>﴿يَنْظُرُونَ﴾</q> يَنْتَظِرُونَ.

<q>﴿وَحَاقَ﴾</q> وَأَحَاطَ.

