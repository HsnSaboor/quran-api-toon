quran[8]{c,v,t}:
  16,27,"<div class=ar lang=ar><h3>الوقفات التدبرية</h3><p>١- <span class="qpc-hafs">﴿ۚ قَالَ ٱلَّذِينَ أُوتُوا۟ ٱلْعِلْمَ إِنَّ ٱلْخِزْىَ ٱلْيَوْمَ وَٱلسُّوٓءَ عَلَى ٱلْكَٰفِرِينَ﴾</span></p><p>في هذا فضيلة لأهل العلم، وأنهم الناطقون بالحق في هذه الدنيا، ويوم يقوم الأشهاد، وأن لقولهم اعتباراً عند الله وعند خلقه. [السعدي:٤٣٩]</p><p>السؤال: ما فضيلة أهل العلم المذكورة في الآية؟</p><p>٢- <span class="qpc-hafs">﴿فَأَلْقَوُا۟ ٱلسَّلَمَ مَا كُنَّا نَعْمَلُ مِن سُوٓءٍۭ ۚ بَلَىٰٓ إِنَّ ٱللَّهَ عَلِيمٌۢ بِمَا كُنتُمْ تَعْمَلُونَ﴾</span></p><p>وهذا في بعض مواقف القيامة: ينكرون ما كانوا عليه في الدنيا ظناً أنه ينفعهم، فإذا شهدت عليهم جوارحهم، وتبين ما كانوا عليه أقروا واعترفوا؛ ولهذا لا يدخلون النار حتى يعترفوا بذنوبهم. [السعدي:٤٣٩]</p><p>السؤال: كيف تجمع بين إنكار المشركين لأعمالهم يوم القيامة واعترافهم بها؟</p><p>٣- <span class="qpc-hafs">﴿فَٱدْخُلُوٓا۟ أَبْوَٰبَ جَهَنَّمَ﴾</span></p><p>كُلُّ أهل عملٍ يدخلون من الباب اللائق بحالهم. [السعدي:٤٣٩]</p><p>السؤال: أبواب جهنم سبعة، فمن أيِّ باب يدخل أهل النار؟</p><p>٤- <span class="qpc-hafs">﴿فَٱدْخُلُوٓا۟ أَبْوَٰبَ جَهَنَّمَ خَٰلِدِينَ فِيهَا ۖ فَلَبِئْسَ مَثْوَى ٱلْمُتَكَبِّرِينَ﴾</span></p><p>وهم يدخلون جهنم من يوم مماتهم بأرواحهم، وينال أجسادهم في قبورها من حرها وسمومها، فإذا كان يوم القيامة سلكت أرواحهم في أجسادهم، وخلدت في نار جهنم. [ابن كثير:٢/٥٤٨]</p><p>السؤال: يمر الكافر بعد مماته بمرحلتين من العذاب، ما هما؟</p><p>٥- <span class="qpc-hafs">﴿وَقِيلَ لِلَّذِينَ ٱتَّقَوْا۟ مَاذَآ أَنزَلَ رَبُّكُمْ ۚ قَالُوا۟ خَيْرًا ۗ لِّلَّذِينَ أَحْسَنُوا۟ فِى هَٰذِهِ ٱلدُّنْيَا حَسَنَةٌ ۚ وَلَدَارُ ٱلْءَاخِرَةِ خَيْرٌ ۚ وَلَنِعْمَ دَارُ ٱلْمُتَّقِينَ﴾</span></p><p>وحسنة الدّنيا هي الحياة الطيّبة وما فتح الله لهم من زهرة الدنيا مع نعمة الإيمان. [ابن عاشور:١٤/١٤٢]</p><p>السؤال: ما حسنة الدنيا الواردة في الآية الكريمة؟</p><p>٦- <span class="qpc-hafs">﴿جَنَّٰتُ عَدْنٍ يَدْخُلُونَهَا تَجْرِى مِن تَحْتِهَا ٱلْأَنْهَٰرُ ۖ لَهُمْ فِيهَا مَا يَشَآءُونَ ۚ كَذَٰلِكَ يَجْزِى ٱللَّهُ ٱلْمُتَّقِينَ﴾</span></p><p>وذكر بعضهم أن تقديم <span class="qpc-hafs">﴿فيها﴾</span> للحصر, و <span class="qpc-hafs">﴿ما﴾</span> للعموم بقرينة المقام؛ فيُفيدُ أن الإنسان لا يجد جميع ما يريده إلا في الجنة, فتأمَّلهُ. [الألوسي:١٤/٥٠٠]</p><p>السؤال: كيف ينظر المؤمن إلى ما فاته من نعيم الدنيا وكمال زينتها؟</p><p>٧- <span class="qpc-hafs">﴿ٱلَّذِينَ تَتَوَفَّىٰهُمُ ٱلْمَلَٰٓئِكَةُ طَيِّبِينَ﴾</span></p><p>طابت قلوبهم بمعرفة الله ومحبته، وألسنتهم بذكره والثناء عليه، وجوارحهم بطاعته والإقبال عليه. [السعدي:٤٣٩]</p><p>السؤال: كيف تجعل نفسك طَيِّبَةً عند الموت؟</p><h3>التوجيهات</h3><p>١- من تلاعب الشيطان بالعقول الضعيفة أن الالتزام بالوحي يعني التخلف ، <span class="qpc-hafs">﴿وَإِذَا قِيلَ لَهُم مَّاذَآ أَنزَلَ رَبُّكُمْ ۙ قَالُوٓا۟ أَسَٰطِيرُ ٱلْأَوَّلِينَ﴾</span></p><p>٢- يشهَد العلماء الربانيون يوم القيامة على صنيع أهل الدنيا؛ فعليك بمتابعتهم في الدنيا في معرفة ما يحبه الله ويرضاه، <span class="qpc-hafs">﴿ۚ قَالَ ٱلَّذِينَ أُوتُوا۟ ٱلْعِلْمَ إِنَّ ٱلْخِزْىَ ٱلْيَوْمَ وَٱلسُّوٓءَ عَلَى ٱلْكَٰفِرِينَ﴾</span></p><p>٣- احذر السخـرية، أو الاستـهزاء بالدعاة إلى الله، والعلماء المصلحين، <span class="qpc-hafs">﴿فَأَصَابَهُمْ سَيِّـَٔاتُ مَا عَمِلُوا۟ وَحَاقَ بِهِم مَّا كَانُوا۟ بِهِۦ يَسْتَهْزِءُونَ﴾</span></p><h3>العمل بالآيات</h3><p>١- لاتهجر طلب العلم واحضر اليوم درسا، أو اسمع محاضرة، أو اقرأ كتابا؛ فإن الله تعالى يرفع أهل العلم في الدنيا والآخرة، <span class="qpc-hafs">﴿ۚ قَالَ ٱلَّذِينَ أُوتُوا۟ ٱلْعِلْمَ إِنَّ ٱلْخِزْىَ ٱلْيَوْمَ وَٱلسُّوٓءَ عَلَى ٱلْكَٰفِرِينَ﴾</span></p><p>٢- حدد عدة أعمال ثبت أن الله ادخل أصحابها بسببها الجنة، وابدأ اليوم بواحد منها، <span class="qpc-hafs">﴿ٱلَّذِينَ تَتَوَفَّىٰهُمُ ٱلْمَلَٰٓئِكَةُ طَيِّبِينَ ۙ يَقُولُونَ سَلَٰمٌ عَلَيْكُمُ ٱدْخُلُوا۟ ٱلْجَنَّةَ بِمَا كُنتُمْ تَعْمَلُونَ﴾</span></p><p>٣- سل الله تعالى حسن الخاتمة, <span class="qpc-hafs">﴿ٱلَّذِينَ تَتَوَفَّىٰهُمُ ٱلْمَلَٰٓئِكَةُ طَيِّبِينَ ۙ يَقُولُونَ سَلَٰمٌ عَلَيْكُمُ ٱدْخُلُوا۟ ٱلْجَنَّةَ بِمَا كُنتُمْ تَعْمَلُونَ﴾</span></p><h3>معاني الكلمات</h3><p><span class="qpc-hafs">﴿يُخْزِيهِمْ﴾</span> يَفْضَحُهُمْ، وَيُذِلُّهُمْ بِالعَذَابِ.</p><p><span class="qpc-hafs">﴿تُشَآقَّونَ فِيهِمْ﴾</span> تُحَارِبُونَ، وَتُجَادِلُونَ الأَنْبِيَاءَ لأِجْلِهِمْ.</p><p><span class="qpc-hafs">﴿فَأَلْقَوُا السَّلَمَ﴾</span> فَاسْتَسْلَمُوا لأِمْرِ اللهِ.</p><p><span class="qpc-hafs">﴿مَثْوَى﴾</span> مَقَرُّ.</p><p><span class="qpc-hafs">﴿يَنْظُرُونَ﴾</span> يَنْتَظِرُونَ.</p><p><span class="qpc-hafs">﴿وَحَاقَ﴾</span> وَأَحَاطَ.</p></div>"
