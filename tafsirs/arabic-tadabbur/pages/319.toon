quran[15]{c,v,t}:
  20,99,"<div class=ar lang=ar><h3>الوقفات التدبرية</h3><p>١- <span class="qpc-hafs">﴿كَذَٰلِكَ نَقُصُّ عَلَيْكَ مِنْ أَنۢبَآءِ مَا قَدْ سَبَقَ ۚ وَقَدْ ءَاتَيْنَٰكَ مِن لَّدُنَّا ذِكْرًا﴾</span></p><p>ما يقص من أخبار الأمم ليس المقصود به قطْع حصة الزمان، ولا إيناس السامعين بالحديث، إنما المقصود منه العبرة، والتذكرة، وإيقاظ لبصائر المشركين من العرب إلى موضع الاعتبار من هذه القصة. [ابن عاشور:١٦/٣٠٢]</p><p>السؤال: ما المقصود من قصص الأمم في القرآن الكريم؟</p><p>٢- <span class="qpc-hafs">﴿وَقَدْ ءَاتَيْنَٰكَ مِن لَّدُنَّا ذِكْرًا﴾</span></p><p>وهو هذا القرآن الكريم؛ ذكر للأخبار السابقة واللاحقة، وذكر يتذكر به ما لله تعالى من الأسماء والصفات الكاملة، ويتذكر به أحكام الأمر والنهي، وأحكام الجزاء. [السعدي:٥١٢]</p><p>السؤال: لماذا سمي القرآن ذكراً؟</p><p>٣- <span class="qpc-hafs">﴿يَتَخَٰفَتُونَ بَيْنَهُمْ إِن لَّبِثْتُمْ إِلَّا عَشْرًا (١٠٣) نَّحْنُ أَعْلَمُ بِمَا يَقُولُونَ إِذْ يَقُولُ أَمْثَلُهُمْ طَرِيقَةً إِن لَّبِثْتُمْ إِلَّا يَوْمًا﴾</span></p><p>أي: يقول بعضهم لبعض في السرّ: إن لبثتم في الدنيا إلا عشر ليال؛ وذلك لاستقلالهم مدّة الدنيا. وقيل: يعنون لبثهم في القبور. <span class="qpc-hafs">﴿يقول أمثلهم طريقة إن لبثتم إلا يوما﴾</span> أي: يقول أعلمهم بالأمور؛ فالإضافة إليهم. <span class="qpc-hafs">﴿إن لبثتم إلا يوماً﴾</span>: واحداً؛ فاستقل المدّة أشد مما استقلها غيره. [ابن جزي:٢/٢٤]</p><p>السؤال: كيف دلّت هذه الآية على حقارة الدنيا؟</p><p>٤- <span class="qpc-hafs">﴿يَتَخَٰفَتُونَ بَيْنَهُمْ إِن لَّبِثْتُمْ إِلَّا عَشْرًا (١٠٣) نَّحْنُ أَعْلَمُ بِمَا يَقُولُونَ إِذْ يَقُولُ أَمْثَلُهُمْ طَرِيقَةً إِن لَّبِثْتُمْ إِلَّا يَوْمًا﴾</span></p><p>والمقصود من هذا: الندم العظيم؛ كيف ضيعوا الأوقات القصيرة، وقطعوها ساهين لاهين، معرضين عما ينفعهم، مقبلين على ما يضرهم، فها قد حضر الجزاء، وحق الوعيد، فلم يبق إلا الندم، والدعاء بالويل والثبور. [السعدي:٥١٣]</p><p>السؤال: ما الذي يفيده الإنسان من هذا الإخبار عن المجرمين؟</p><p>٥- <span class="qpc-hafs">﴿وَعَنَتِ ٱلْوُجُوهُ لِلْحَىِّ ٱلْقَيُّومِ ۖ وَقَدْ خَابَ مَنْ حَمَلَ ظُلْمًا﴾</span></p><p>وكنى عن الناس بالوجوه؛ لأن آثار الذل إنما تتبين في الوجه. [القرطبي:١٤/١٤٢]</p><p>السؤال: ما السبب في التعبير بالوجوه في الآية؟</p><p>٦- <span class="qpc-hafs">﴿وَمَن يَعْمَلْ مِنَ ٱلصَّٰلِحَٰتِ وَهُوَ مُؤْمِنٌ فَلَا يَخَافُ ظُلْمًا وَلَا هَضْمًا﴾</span></p><p>لأن العمل لا يقبل من غير إيمان. [القرطبي:١٤/١٤٣]</p><p>السؤال: بين منزلة الإيمان في قبول الأعمال الصالحة.</p><p>٧- <span class="qpc-hafs">﴿وَكَذَٰلِكَ أَنزَلْنَٰهُ قُرْءَانًا عَرَبِيًّا وَصَرَّفْنَا فِيهِ مِنَ ٱلْوَعِيدِ لَعَلَّهُمْ يَتَّقُونَ أَوْ يُحْدِثُ لَهُمْ ذِكْرًا﴾</span></p><p>وهذا وصف يفيد المدح؛ لأنّ اللغة العربية أبلغ اللّغات، وأحسنها فصاحة وانسجاماً. [ابن عاشور:١٦/٣١٤]</p><p>السؤال: ما الذي يفيده وصف القرآن بـكونه عربياً؟</p><h3>التوجيهات</h3><p>١- أقبل على القرآن الكريم تعلماً، وتعليماً، وعملاً؛ ففيه النجاة، <span class="qpc-hafs">﴿وَقَدْ ءَاتَيْنَٰكَ مِن لَّدُنَّا ذِكْرًا (٩٩) مَّنْ أَعْرَضَ عَنْهُ فَإِنَّهُۥ يَحْمِلُ يَوْمَ ٱلْقِيَٰمَةِ وِزْرًا﴾</span></p><p>٢- تذكر يوم سكون الأصوات بين يدي الله تعالى، حتى لا يسمع إلا الهمس من عظم ما هم فيه من الهول، <span class="qpc-hafs">﴿يَوْمَئِذٍ يَتَّبِعُونَ ٱلدَّاعِىَ لَا عِوَجَ لَهُۥ ۖ وَخَشَعَتِ ٱلْأَصْوَاتُ لِلرَّحْمَٰنِ فَلَا تَسْمَعُ إِلَّا هَمْسًا﴾</span></p><p>٣- تذكر أن الشفاعة عند الله لا تنفع إلا بإذن الله للشافع، ورضاه عن المشفوع له، <span class="qpc-hafs">﴿يَوْمَئِذٍ لَّا تَنفَعُ ٱلشَّفَٰعَةُ إِلَّا مَنْ أَذِنَ لَهُ ٱلرَّحْمَٰنُ وَرَضِىَ لَهُۥ قَوْلًا﴾</span></p><h3>العمل بالآيات</h3><p>١- اقرأ قصة من قصص الأمم السابقة، تجد فيها العبرة والعظة، <span class="qpc-hafs">﴿كَذَٰلِكَ نَقُصُّ عَلَيْكَ مِنْ أَنۢبَآءِ مَا قَدْ سَبَقَ ۚ وَقَدْ ءَاتَيْنَٰكَ مِن لَّدُنَّا ذِكْرًا﴾</span></p><p>٢- اقرأ سورة من سور القرآن الكريم متأملا موضوعها العام، <span class="qpc-hafs">﴿وَقَدْ ءَاتَيْنَٰكَ مِن لَّدُنَّا ذِكْرًا (٩٩) مَّنْ أَعْرَضَ عَنْهُ فَإِنَّهُۥ يَحْمِلُ يَوْمَ ٱلْقِيَٰمَةِ وِزْرًا﴾</span></p><p>٣- قل: اللهم إني أسألك شفاعة نبيك محمد ﷺ يوم القيامة، <span class="qpc-hafs">﴿يَوْمَئِذٍ لَّا تَنفَعُ ٱلشَّفَٰعَةُ إِلَّا مَنْ أَذِنَ لَهُ ٱلرَّحْمَٰنُ وَرَضِىَ لَهُۥ قَوْلًا﴾</span></p><h3>معاني الكلمات</h3><p><span class="qpc-hafs">﴿مِنْ لَدُنَّا﴾</span> مِنْ عِنْدِنَا.</p><p><span class="qpc-hafs">﴿وِزْرًا﴾</span> إِثْمًا عَظِيمًا.</p><p><span class="qpc-hafs">﴿الصُّورِ﴾</span> القَرْنِ الَّذِي يَنْفُخُ فِيهِ إِسْرَافِيلُ عليه السلام.</p><p><span class="qpc-hafs">﴿وَنَحْشُرُ﴾</span> نَسُوقُ.</p><p><span class="qpc-hafs">﴿زُرْقًا﴾</span> زُرْقَ العُيُونِ مَعَ سَوَادِ وُجُوهِهِمْ.</p><p><span class="qpc-hafs">﴿يَتَخَافَتُونَ﴾</span> يَتَسَارُّونَ، وَيَتَهَامَسُونَ.</p><p><span class="qpc-hafs">﴿أَمْثَلُهُمْ طَرِيقَةً﴾</span> أَعْلَمُهُمْ، وَأَوْفَاهُمْ عَقْلاً.</p><p><span class="qpc-hafs">﴿يَنْسِفُهَا﴾</span> يُزِيلُهَا عَنْ أَمَاكِنِهَا.</p><p><span class="qpc-hafs">﴿نَسْفًا﴾</span> يَجْعَلُهَا هَبَاءً مُنْبَثًّا.</p><p><span class="qpc-hafs">﴿فَيَذَرُهَا﴾</span> فَيَتْرُكُهَا.</p><p><span class="qpc-hafs">﴿قَاعًا﴾</span> أَرْضًا مَلْسَاءَ لاَ نَبَاتَ بِهَا.</p><p><span class="qpc-hafs">﴿صَفْصَفًا﴾</span> مُسْتَوِيَةً.</p><p><span class="qpc-hafs">﴿عِوَجًا﴾</span> انْخِفَاضًا.</p><p><span class="qpc-hafs">﴿وَلاَ أَمْتًا﴾</span> ارْتِفَاعًا.</p><p><span class="qpc-hafs">﴿لاَ عِوَجَ لَهُ﴾</span> لاَ مَحِيدَ عَنْ دَعْوَةِ الدَّاعِي.</p><p><span class="qpc-hafs">﴿وَخَشَعَتِ﴾</span> سَكَنَتْ خُضُوعًا.</p><p><span class="qpc-hafs">﴿وَعَنَتِ﴾</span> خَضَعَتْ، وَذَلَّتْ.</p><p><span class="qpc-hafs">﴿الْقَيُّومِ﴾</span> القَائِمِ عَلَى شُؤُونِ خَلْقِهِ.</p><p><span class="qpc-hafs">﴿ظُلْمًا﴾</span> زِيَادَةً فِي سَيِّئَاتِهِ.</p><p><span class="qpc-hafs">﴿هَضْمًا﴾</span> نَقْصًا مِنْ حَسَنَاتِهِ.</p><p><span class="qpc-hafs">﴿وَصَرَّفْنَا﴾</span> فَصَّلْنَا فِيهِ أَنْوَاعًا مِنَ الوَعِيدِ.</p><p><span class="qpc-hafs">﴿ذِكْرًا﴾</span> تَذْكِرَةً، وَعِظَةً.</p></div>"
