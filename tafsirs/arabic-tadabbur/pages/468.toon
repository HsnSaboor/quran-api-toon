tafsir[9]{c,v,t}:
  40,8,"

الوقفات التدبرية

١- <q>﴿رَبَّنَا وَأَدْخِلْهُمْ جَنَّٰتِ عَدْنٍ ٱلَّتِى وَعَدتَّهُمْ وَمَن صَلَحَ مِنْ ءَابَآئِهِمْ وَأَزْوَٰجِهِمْ وَذُرِّيَّٰتِهِمْ ۚ إِنَّكَ أَنتَ ٱلْعَزِيزُ ٱلْحَكِيمُ﴾</q>

وتضمن ذلك أن المقارن من زوج وولد وصاحب يسعد بقرينه، ويكون اتصاله به سبباً لخير يحصل له، خارج عن عمله وسبب عمله، كما كانت الملائكة تدعو للمؤمنين ولمن صلح من آبائهم وأزواجهم وذرياتهم. [السعدي:٧٣٣]

السؤال: في هذه الآية حثٌّ على مصاحبة الصالحين، وضح ذلك.

٢- <q>﴿رَبَّنَا وَأَدْخِلْهُمْ جَنَّٰتِ عَدْنٍ ٱلَّتِى وَعَدتَّهُمْ وَمَن صَلَحَ مِنْ ءَابَآئِهِمْ وَأَزْوَٰجِهِمْ وَذُرِّيَّٰتِهِمْ﴾</q>

أي: اجمع بينهم وبينهم؛ لتقر بذلك أعينهم بالاجتماع في منازل متجاورة. [ابن كثير: ٤/٧٤]

السؤال: لماذا خص الآباء والأزواج والذريات بالذكر؟

٣- <q>﴿إِنَّكَ أَنتَ ٱلْعَزِيزُ ٱلْحَكِيمُ﴾</q>

<q>﴿العزيز﴾</q>: القاهر لكل شيء؛ فبعزتك تغفر ذنوبهم، وتكشف عنهم المحذور، وتوصلهم بها إلى كل خير. <q>﴿الحكيم﴾</q>: الذي يضع الأشياء مواضعها؛ فلا نسألك يا ربنا أمراً تقتضي حكمتك خلافه، بل من حكمتك التي أخبرت بها على ألسنة رسلك، واقتضاها فضلك: المغفرة للمؤمنين. [السعدي:٧٣٢]

السؤال: ما وجه ختم دعائهم بهاتين الصفتين: <q>﴿العزيز الحكيم﴾</q>؟

٤- <q>﴿إِنَّ ٱلَّذِينَ كَفَرُوا۟ يُنَادَوْنَ لَمَقْتُ ٱللَّهِ أَكْبَرُ مِن مَّقْتِكُمْ أَنفُسَكُمْ إِذْ تُدْعَوْنَ إِلَى ٱلْإِيمَٰنِ فَتَكْفُرُونَ﴾</q>

المقت: البغض الذي يوجبه ذنب أو عيب، وهذه الحال تكون للكفار عند دخولهم النار؛ فإنهم إذا دخلوها مقتوا أنفسهم؛ أي: مقت بعضهم بعضاً، ويحتمل أن يمقت كل واحد منهم نفسه، فتناديهم الملائكة، وتقول لهم: مقت الله لكم في الدنيا على كفركم أكبر من مقتكم أنفسكم اليوم. [ابن جزي:٢/٢٧٧]

السؤال: كيف يمقت الكفار أنفسهم في النار؟

٥- <q>﴿قَالُوا۟ رَبَّنَآ أَمَتَّنَا ٱثْنَتَيْنِ وَأَحْيَيْتَنَا ٱثْنَتَيْنِ فَٱعْتَرَفْنَا بِذُنُوبِنَا فَهَلْ إِلَىٰ خُرُوجٍ مِّن سَبِيلٍ﴾</q>

<q>﴿أمتنا اثنتين وأحييتنا اثنتين﴾</q>: إقرار بالبعث على أكمل الوجوه، طمعاً منهم أن يخرجوا عن المقت الذي مقتهم الله؛ إذ كانوا يدعون إلى الإسلام فيكفرون... فإن قيل: كيف يكون قولهم: <q>﴿أمتنا اثنتين وأحييتنا اثنتين﴾</q> سبباً لاعترافهم بالذنوب؟ فالجواب أنهم كانوا كافرين بالبعث، فلمّا رأوا الإماتة والإحياء قد تكرر عليهم، علموا أن الله قادر على البعث؛ فاعترفوا بذنوبهم؛ وهي إنكار البعث، وما أوجب لهم إنكاره من المعاصي؛ فإن من لم يؤمن بالآخرة لا يبالي بالوقوع في المعاصي. [ابن جزي:٢/٢٧٨]

السؤال: فساد الاعتقاد سبب للوقوع في المعاصي, بين ذلك من الآية.

٦- <q>﴿رَفِيعُ ٱلدَّرَجَٰتِ ذُو ٱلْعَرْشِ يُلْقِى ٱلرُّوحَ مِنْ أَمْرِهِۦ عَلَىٰ مَن يَشَآءُ مِنْ عِبَادِهِۦ﴾</q>

<q>﴿يلقي الروح﴾</q>: ينزل الوحي؛ سماه روحا لأنه تحيا القلوب به. [البغوي:٤/٣٨. ]

السؤال: لمَ سُمي الوحي روحاً؟

٧- <q>﴿يُلْقِى ٱلرُّوحَ مِنْ أَمْرِهِۦ عَلَىٰ مَن يَشَآءُ مِنْ عِبَادِهِۦ لِيُنذِرَ يَوْمَ ٱلتَّلَاقِ﴾</q>

<q>﴿يوم التلاق﴾</q> يعني: يوم القيامة؛ وسمي بذلك لأن الخلائق يلتقون فيه، وقيل: لأنه يلتقي فيه أهل السموات والأرض، وقيل: لأنه يلتقي الخلق مع ربهم. [ابن جزي:٢/٢٧٨]

السؤال: ما يوم التلاق؟ ولم سمي بهذا الاسم؟

التوجيهات

١- ١. قال سعيد بن جبير: إن المؤمن إذا دخل الجنة سأل عن أبيه وابنه وأخيه، أين هم؟ فيقال: إنهم لم يبلغوا طبقتك في العمل. فيقول: إني إنما عملت لي ولهم، فيلحقون به في الدرجة. ثم تلا سعيد بن جبير هذه الآية: <q>﴿رَبَّنَا وَأَدْخِلْهُمْ جَنَّٰتِ عَدْنٍ ٱلَّتِى وَعَدتَّهُمْ وَمَن صَلَحَ مِنْ ءَابَآئِهِمْ وَأَزْوَٰجِهِمْ وَذُرِّيَّٰتِهِمْ ۚ إِنَّكَ أَنتَ ٱلْعَزِيزُ ٱلْحَكِيمُ﴾</q>

٢- اعلم أن أجلّ رحمةٍ ينالها العبد أن يقيه الله تعالى من تبعة السيئات، <q>﴿وَقِهِمُ ٱلسَّيِّـَٔاتِ ۚ وَمَن تَقِ ٱلسَّيِّـَٔاتِ يَوْمَئِذٍ فَقَدْ رَحِمْتَهُۥ﴾</q>

٣- إذا عملت ما يرضي الله تعالى، وسخط عليك الكفار فلا عليك من سخطهم، <q>﴿فَٱدْعُوا۟ ٱللَّهَ مُخْلِصِينَ لَهُ ٱلدِّينَ وَلَوْ كَرِهَ ٱلْكَٰفِرُونَ﴾</q>

العمل بالآيات

١- مُرْ إخوانك وأهلك بالصلاة؛ رجاء أن يكونوا معك في الجنة، <q>﴿رَبَّنَا وَأَدْخِلْهُمْ جَنَّٰتِ عَدْنٍ ٱلَّتِى وَعَدتَّهُمْ وَمَن صَلَحَ مِنْ ءَابَآئِهِمْ وَأَزْوَٰجِهِمْ وَذُرِّيَّٰتِهِمْ ۚ إِنَّكَ أَنتَ ٱلْعَزِيزُ ٱلْحَكِيمُ﴾</q>

٢- ادعُ لغيرك من المؤمنين كما تدعو لنفسك اقتداء بالملائكة، <q>﴿رَبَّنَا وَأَدْخِلْهُمْ جَنَّٰتِ عَدْنٍ ٱلَّتِى وَعَدتَّهُمْ﴾</q>

٣- حدد بعض ذنوبك وعيوبك، ثم سل الله التوبة قبل أن تعترف في الآخرة، ولا ينفعك ذلك، <q>﴿فَٱعْتَرَفْنَا بِذُنُوبِنَا فَهَلْ إِلَىٰ خُرُوجٍ مِّن سَبِيلٍ﴾</q>

معاني الكلمات

<q>﴿وَقِهِمُ السَّيِّئَاتِ﴾</q> اصْرِفْ عَنْهُمْ سُوءَ عَاقِبَةِ سَيِّئَاتِهِمْ.

<q>﴿يُنَادَوْنَ﴾</q> يَدْعُوهُمْ خَزَنَةُ جَهَنَّمَ.

<q>﴿لَمَقْتُ اللَّهِ﴾</q> المَقْتُ: البُغْضُ الشَّدِيدُ.

<q>﴿أَمَتَّنَا اثْنَتَيْنِ﴾</q> مَرَّةً قَبْلَ نَفْخِ الأَرْوَاحِ فِي الأَجِنَّةِ، وَمَرَّةً حِينَ انْقَضَى أَجَلُنَا.

<q>﴿وَأَحْيَيْتَنَا اثْنَتَيْنِ﴾</q> مَرَّةً فِي الدُّنْيَا، وَمَرَّةً فِي الآخِرَةِ.

<q>﴿سَبِيلٍ﴾</q> طَرِيقٍ نَخْرُجُ بِهِ مِنَ النَّارِ.

<q>﴿رِزْقًا﴾</q> مَطَرًا تُرْزَقُونَ بِهِ.

<q>﴿يُنِيبُ﴾</q> يَرْجِعُ إِلَى طَاعَةِ اللهِ.

<q>﴿رَفِيعُ الدَّرَجَاتِ﴾</q> ارْتَفَعَتْ دَرَجَاتُهُ ارْتِفَاعًا بَايَنَ بِهِ مَخْلُوقَاتِهِ، وَارْتَفَعَ بِهِ قَدْرُهُ.

<q>﴿يُلْقِي الرُّوحَ﴾</q> يُنْزِلُ الوَحْيَ.

<q>﴿يَوْمَ التَّلاَقِ﴾</q> اليَوْمَ الَّذِي يَلْتَقِي فِيهِ الأَوَّلُونَ وَالآخِرُونَ.

<q>﴿بَارِزُونَ﴾</q> ظَاهِرُونَ أَمَامَ رَبِّهِمْ.

