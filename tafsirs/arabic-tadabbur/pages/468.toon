quran[9]{c,v,t}:
  40,8,"<div class=ar lang=ar><h3>الوقفات التدبرية</h3><p>١- <span class="qpc-hafs">﴿رَبَّنَا وَأَدْخِلْهُمْ جَنَّٰتِ عَدْنٍ ٱلَّتِى وَعَدتَّهُمْ وَمَن صَلَحَ مِنْ ءَابَآئِهِمْ وَأَزْوَٰجِهِمْ وَذُرِّيَّٰتِهِمْ ۚ إِنَّكَ أَنتَ ٱلْعَزِيزُ ٱلْحَكِيمُ﴾</span></p><p>وتضمن ذلك أن المقارن من زوج وولد وصاحب يسعد بقرينه، ويكون اتصاله به سبباً لخير يحصل له، خارج عن عمله وسبب عمله، كما كانت الملائكة تدعو للمؤمنين ولمن صلح من آبائهم وأزواجهم وذرياتهم. [السعدي:٧٣٣]</p><p>السؤال: في هذه الآية حثٌّ على مصاحبة الصالحين، وضح ذلك.</p><p>٢- <span class="qpc-hafs">﴿رَبَّنَا وَأَدْخِلْهُمْ جَنَّٰتِ عَدْنٍ ٱلَّتِى وَعَدتَّهُمْ وَمَن صَلَحَ مِنْ ءَابَآئِهِمْ وَأَزْوَٰجِهِمْ وَذُرِّيَّٰتِهِمْ﴾</span></p><p>أي: اجمع بينهم وبينهم؛ لتقر بذلك أعينهم بالاجتماع في منازل متجاورة. [ابن كثير: ٤/٧٤]</p><p>السؤال: لماذا خص الآباء والأزواج والذريات بالذكر؟</p><p>٣- <span class="qpc-hafs">﴿إِنَّكَ أَنتَ ٱلْعَزِيزُ ٱلْحَكِيمُ﴾</span></p><p><span class="qpc-hafs">﴿العزيز﴾</span>: القاهر لكل شيء؛ فبعزتك تغفر ذنوبهم، وتكشف عنهم المحذور، وتوصلهم بها إلى كل خير. <span class="qpc-hafs">﴿الحكيم﴾</span>: الذي يضع الأشياء مواضعها؛ فلا نسألك يا ربنا أمراً تقتضي حكمتك خلافه، بل من حكمتك التي أخبرت بها على ألسنة رسلك، واقتضاها فضلك: المغفرة للمؤمنين. [السعدي:٧٣٢]</p><p>السؤال: ما وجه ختم دعائهم بهاتين الصفتين: <span class="qpc-hafs">﴿العزيز الحكيم﴾</span>؟</p><p>٤- <span class="qpc-hafs">﴿إِنَّ ٱلَّذِينَ كَفَرُوا۟ يُنَادَوْنَ لَمَقْتُ ٱللَّهِ أَكْبَرُ مِن مَّقْتِكُمْ أَنفُسَكُمْ إِذْ تُدْعَوْنَ إِلَى ٱلْإِيمَٰنِ فَتَكْفُرُونَ﴾</span></p><p>المقت: البغض الذي يوجبه ذنب أو عيب، وهذه الحال تكون للكفار عند دخولهم النار؛ فإنهم إذا دخلوها مقتوا أنفسهم؛ أي: مقت بعضهم بعضاً، ويحتمل أن يمقت كل واحد منهم نفسه، فتناديهم الملائكة، وتقول لهم: مقت الله لكم في الدنيا على كفركم أكبر من مقتكم أنفسكم اليوم. [ابن جزي:٢/٢٧٧]</p><p>السؤال: كيف يمقت الكفار أنفسهم في النار؟</p><p>٥- <span class="qpc-hafs">﴿قَالُوا۟ رَبَّنَآ أَمَتَّنَا ٱثْنَتَيْنِ وَأَحْيَيْتَنَا ٱثْنَتَيْنِ فَٱعْتَرَفْنَا بِذُنُوبِنَا فَهَلْ إِلَىٰ خُرُوجٍ مِّن سَبِيلٍ﴾</span></p><p><span class="qpc-hafs">﴿أمتنا اثنتين وأحييتنا اثنتين﴾</span>: إقرار بالبعث على أكمل الوجوه، طمعاً منهم أن يخرجوا عن المقت الذي مقتهم الله؛ إذ كانوا يدعون إلى الإسلام فيكفرون... فإن قيل: كيف يكون قولهم: <span class="qpc-hafs">﴿أمتنا اثنتين وأحييتنا اثنتين﴾</span> سبباً لاعترافهم بالذنوب؟ فالجواب أنهم كانوا كافرين بالبعث، فلمّا رأوا الإماتة والإحياء قد تكرر عليهم، علموا أن الله قادر على البعث؛ فاعترفوا بذنوبهم؛ وهي إنكار البعث، وما أوجب لهم إنكاره من المعاصي؛ فإن من لم يؤمن بالآخرة لا يبالي بالوقوع في المعاصي. [ابن جزي:٢/٢٧٨]</p><p>السؤال: فساد الاعتقاد سبب للوقوع في المعاصي, بين ذلك من الآية.</p><p>٦- <span class="qpc-hafs">﴿رَفِيعُ ٱلدَّرَجَٰتِ ذُو ٱلْعَرْشِ يُلْقِى ٱلرُّوحَ مِنْ أَمْرِهِۦ عَلَىٰ مَن يَشَآءُ مِنْ عِبَادِهِۦ﴾</span></p><p><span class="qpc-hafs">﴿يلقي الروح﴾</span>: ينزل الوحي؛ سماه روحا لأنه تحيا القلوب به. [البغوي:٤/٣٨. ]</p><p>السؤال: لمَ سُمي الوحي روحاً؟</p><p>٧- <span class="qpc-hafs">﴿يُلْقِى ٱلرُّوحَ مِنْ أَمْرِهِۦ عَلَىٰ مَن يَشَآءُ مِنْ عِبَادِهِۦ لِيُنذِرَ يَوْمَ ٱلتَّلَاقِ﴾</span></p><p><span class="qpc-hafs">﴿يوم التلاق﴾</span> يعني: يوم القيامة؛ وسمي بذلك لأن الخلائق يلتقون فيه، وقيل: لأنه يلتقي فيه أهل السموات والأرض، وقيل: لأنه يلتقي الخلق مع ربهم. [ابن جزي:٢/٢٧٨]</p><p>السؤال: ما يوم التلاق؟ ولم سمي بهذا الاسم؟</p><h3>التوجيهات</h3><p>١- ١.	قال سعيد بن جبير: إن المؤمن إذا دخل الجنة سأل عن أبيه وابنه وأخيه، أين هم؟ فيقال: إنهم لم يبلغوا طبقتك في العمل. فيقول: إني إنما عملت لي ولهم، فيلحقون به في الدرجة. ثم تلا سعيد بن جبير هذه الآية: <span class="qpc-hafs">﴿رَبَّنَا وَأَدْخِلْهُمْ جَنَّٰتِ عَدْنٍ ٱلَّتِى وَعَدتَّهُمْ وَمَن صَلَحَ مِنْ ءَابَآئِهِمْ وَأَزْوَٰجِهِمْ وَذُرِّيَّٰتِهِمْ ۚ إِنَّكَ أَنتَ ٱلْعَزِيزُ ٱلْحَكِيمُ﴾</span></p><p>٢- اعلم أن أجلّ رحمةٍ ينالها العبد أن يقيه الله تعالى من تبعة السيئات، <span class="qpc-hafs">﴿وَقِهِمُ ٱلسَّيِّـَٔاتِ ۚ وَمَن تَقِ ٱلسَّيِّـَٔاتِ يَوْمَئِذٍ فَقَدْ رَحِمْتَهُۥ﴾</span></p><p>٣- إذا عملت ما يرضي الله تعالى، وسخط عليك الكفار فلا عليك من سخطهم، <span class="qpc-hafs">﴿فَٱدْعُوا۟ ٱللَّهَ مُخْلِصِينَ لَهُ ٱلدِّينَ وَلَوْ كَرِهَ ٱلْكَٰفِرُونَ﴾</span></p><h3>العمل بالآيات</h3><p>١- مُرْ إخوانك وأهلك بالصلاة؛ رجاء أن يكونوا معك في الجنة، <span class="qpc-hafs">﴿رَبَّنَا وَأَدْخِلْهُمْ جَنَّٰتِ عَدْنٍ ٱلَّتِى وَعَدتَّهُمْ وَمَن صَلَحَ مِنْ ءَابَآئِهِمْ وَأَزْوَٰجِهِمْ وَذُرِّيَّٰتِهِمْ ۚ إِنَّكَ أَنتَ ٱلْعَزِيزُ ٱلْحَكِيمُ﴾</span></p><p>٢- ادعُ لغيرك من المؤمنين كما تدعو لنفسك اقتداء بالملائكة، <span class="qpc-hafs">﴿رَبَّنَا وَأَدْخِلْهُمْ جَنَّٰتِ عَدْنٍ ٱلَّتِى وَعَدتَّهُمْ﴾</span></p><p>٣- حدد بعض ذنوبك وعيوبك، ثم سل الله التوبة قبل أن تعترف في الآخرة، ولا ينفعك ذلك، <span class="qpc-hafs">﴿فَٱعْتَرَفْنَا بِذُنُوبِنَا فَهَلْ إِلَىٰ خُرُوجٍ مِّن سَبِيلٍ﴾</span></p><h3>معاني الكلمات</h3><p><span class="qpc-hafs">﴿وَقِهِمُ السَّيِّئَاتِ﴾</span> اصْرِفْ عَنْهُمْ سُوءَ عَاقِبَةِ سَيِّئَاتِهِمْ.</p><p><span class="qpc-hafs">﴿يُنَادَوْنَ﴾</span> يَدْعُوهُمْ خَزَنَةُ جَهَنَّمَ.</p><p><span class="qpc-hafs">﴿لَمَقْتُ اللَّهِ﴾</span> المَقْتُ: البُغْضُ الشَّدِيدُ.</p><p><span class="qpc-hafs">﴿أَمَتَّنَا اثْنَتَيْنِ﴾</span> مَرَّةً قَبْلَ نَفْخِ الأَرْوَاحِ فِي الأَجِنَّةِ، وَمَرَّةً حِينَ انْقَضَى أَجَلُنَا.</p><p><span class="qpc-hafs">﴿وَأَحْيَيْتَنَا اثْنَتَيْنِ﴾</span> مَرَّةً فِي الدُّنْيَا، وَمَرَّةً فِي الآخِرَةِ.</p><p><span class="qpc-hafs">﴿سَبِيلٍ﴾</span> طَرِيقٍ نَخْرُجُ بِهِ مِنَ النَّارِ.</p><p><span class="qpc-hafs">﴿رِزْقًا﴾</span> مَطَرًا تُرْزَقُونَ بِهِ.</p><p><span class="qpc-hafs">﴿يُنِيبُ﴾</span> يَرْجِعُ إِلَى طَاعَةِ اللهِ.</p><p><span class="qpc-hafs">﴿رَفِيعُ الدَّرَجَاتِ﴾</span> ارْتَفَعَتْ دَرَجَاتُهُ ارْتِفَاعًا بَايَنَ بِهِ مَخْلُوقَاتِهِ، وَارْتَفَعَ بِهِ قَدْرُهُ.</p><p><span class="qpc-hafs">﴿يُلْقِي الرُّوحَ﴾</span> يُنْزِلُ الوَحْيَ.</p><p><span class="qpc-hafs">﴿يَوْمَ التَّلاَقِ﴾</span> اليَوْمَ الَّذِي يَلْتَقِي فِيهِ الأَوَّلُونَ وَالآخِرُونَ.</p><p><span class="qpc-hafs">﴿بَارِزُونَ﴾</span> ظَاهِرُونَ أَمَامَ رَبِّهِمْ.</p></div>"
