quran[9]{c,v,t}:
  16,94,"<div class=ar lang=ar><h3>الوقفات التدبرية</h3><p>١- <span class="qpc-hafs">﴿مَا عِندَكُمْ يَنفَدُ ۖ وَمَا عِندَ ٱللَّهِ بَاقٍ﴾</span></p><p>فآثروا ما يبقى على ما يفنى؛ فإن الذي عندكم -ولو كثر جداً- لا بد أن ينفد ويفنى، وما عند الله باق ببقائه، لا يفنى ولا يزول، فليس بعاقل من آثر الفاني الخسيس على الباقي النفيس ... وفي هذا الحث والترغيب على الزهد في الدنيا، خصوصاً الزهد المتعين، وهو الزهد فيما يكون ضرراً على العبد. [السعدي:٤٤٨-٤٤٩]</p><p>السؤال: ما الذي يفيده المسلم العاقل من هذه الآية؟</p><p>٢- <span class="qpc-hafs">﴿مَنْ عَمِلَ صَٰلِحًا مِّن ذَكَرٍ أَوْ أُنثَىٰ وَهُوَ مُؤْمِنٌ فَلَنُحْيِيَنَّهُۥ حَيَوٰةً طَيِّبَةً﴾</span></p><p>فإن الإيمان شرط في صحة الأعمال الصالحة وقبولها، بل لا تسمى أعمالاً صالحة إلا بالإيمان، والإيمان مقتضٍ لها؛ فإنه التصديق الجازم المثمر لأعمال الجوارح من الواجبات والمستحبات. [السعدي:٤٤٩]</p><p>السؤال: لماذا قَيَّد الله الأعمال الصالحة بالإيمان في هذه الآية؟</p><p>٣- <span class="qpc-hafs">﴿مَنْ عَمِلَ صَٰلِحًا مِّن ذَكَرٍ أَوْ أُنثَىٰ وَهُوَ مُؤْمِنٌ فَلَنُحْيِيَنَّهُۥ حَيَوٰةً طَيِّبَةً ۖ وَلَنَجْزِيَنَّهُمْ أَجْرَهُم بِأَحْسَنِ مَا كَانُوا۟ يَعْمَلُونَ﴾</span></p><p>ربط السعادة مع إصلاح العمل. [ابن تيمية:٤/١٧٦]</p><p>السؤال: رُبطت الحياة الطيبة في الآية بأمرين، ما هما؟</p><p>٤- <span class="qpc-hafs">﴿فَإِذَا قَرَأْتَ ٱلْقُرْءَانَ فَٱسْتَعِذْ بِٱللَّهِ مِنَ ٱلشَّيْطَٰنِ ٱلرَّجِيمِ﴾</span></p><p>المعنى في الاستعاذة عند ابتداء القراءة: لئلا يلبس على القارئ قراءته، ويخلط عليه، ويمنعه من التدبر والتفكر. [ابن كثير:٢/٥٦٦]</p><p>السؤال: ذُكِرَ في هذه الآية وسيلة ناجعة من وسائل تدبر القرآن الكريم، فما هي؟</p><p>٥- <span class="qpc-hafs">﴿إِنَّهُۥ لَيْسَ لَهُۥ سُلْطَٰنٌ عَلَى ٱلَّذِينَ ءَامَنُوا۟ وَعَلَىٰ رَبِّهِمْ يَتَوَكَّلُونَ﴾</span></p><p>أي: ليس له عليهم سبيل، ولا يقدر على إضلالهم. [ابن جزي:١/٤٧٣]</p><p>السؤال: ما الصفات التي ينبغي الاتصاف بها؛ حتى لا يكون للشيطان عليك سبيل؟</p><p>٦- <span class="qpc-hafs">﴿إِنَّهُۥ لَيْسَ لَهُۥ سُلْطَٰنٌ عَلَى ٱلَّذِينَ ءَامَنُوا۟ وَعَلَىٰ رَبِّهِمْ يَتَوَكَّلُونَ﴾</span></p><p>قال الثوري: ليس له عليهم سلطان أن يوقعهم في ذنب لا يتوبون منه. [ابن كثير:٢/٥٦٦]</p><p>السؤال: ما السلطان المنفي عن إبليس على الذين آمنوا؟</p><p>٧- <span class="qpc-hafs">﴿إِنَّهُۥ لَيْسَ لَهُۥ سُلْطَٰنٌ عَلَى ٱلَّذِينَ ءَامَنُوا۟ وَعَلَىٰ رَبِّهِمْ يَتَوَكَّلُونَ﴾</span></p><p>فنَفي سلطان الشيطان مشروط بالأمرين: الإيمان، والتوكّل. [ابن عاشور:١٤/٢٧٨]</p><p>السؤال: ما الذي يمنع تسلط الشيطان على الإنسان؟</p><h3>التوجيهات</h3><p>١- من فضل الله على الصابر أنه يوم القيامة ينظر إلى أفضل عمل عمله ويجعل من أهله، ولو لم يفعله إلا مرة واحدة في عمره، <span class="qpc-hafs">﴿وَلَنَجْزِيَنَّ ٱلَّذِينَ صَبَرُوٓا۟ أَجْرَهُم بِأَحْسَنِ مَا كَانُوا۟ يَعْمَلُونَ﴾</span></p><p>٢- الإيمان والتوكل على الله سبحانه وتعالى سببان للحماية من شرور إبليس ووساوسه، <span class="qpc-hafs">﴿إِنَّهُۥ لَيْسَ لَهُۥ سُلْطَٰنٌ عَلَى ٱلَّذِينَ ءَامَنُوا۟ وَعَلَىٰ رَبِّهِمْ يَتَوَكَّلُونَ﴾</span></p><p>٣- المداومة على قراءة القرآن من أسباب الثبات على دين الله,<span class="qpc-hafs">﴿قُلْ نَزَّلَهُۥ رُوحُ ٱلْقُدُسِ مِن رَّبِّكَ بِٱلْحَقِّ لِيُثَبِّتَ ٱلَّذِينَ ءَامَنُوا۟ وَهُدًى وَبُشْرَىٰ لِلْمُسْلِمِينَ﴾</span></p><h3>العمل بالآيات</h3><p>١- تصدق بصدقة ترجو نفعها وبركتها في الدنيا ويوم القيامة، <span class="qpc-hafs">﴿مَا عِندَكُمْ يَنفَدُ ۖ وَمَا عِندَ ٱللَّهِ بَاقٍ﴾</span></p><p>٢- استعذ بالله من الشيطان الرجيم عند قراءتك للقرآن, خاصة عند قراءة الفاتحة في الصلاة، <span class="qpc-hafs">﴿فَإِذَا قَرَأْتَ ٱلْقُرْءَانَ فَٱسْتَعِذْ بِٱللَّهِ مِنَ ٱلشَّيْطَٰنِ ٱلرَّجِيمِ﴾</span></p><p>٣- سل الله تعالى أن يجعلك من عباده الذين ليس للشيطان عليهم سلطان، <span class="qpc-hafs">﴿إِنَّهُۥ لَيْسَ لَهُۥ سُلْطَٰنٌ عَلَى ٱلَّذِينَ ءَامَنُوا۟ وَعَلَىٰ رَبِّهِمْ يَتَوَكَّلُونَ﴾</span></p><h3>معاني الكلمات</h3><p><span class="qpc-hafs">﴿يَنْفَدُ﴾</span> يَذْهَبُ وَيَفْنَى.</p><p><span class="qpc-hafs">﴿الرَّجِيمِ﴾</span> المَطْرُودِ مِنْ رَحْمَةِ اللهِ.</p><p><span class="qpc-hafs">﴿سُلْطَانٌ﴾</span> تَسَلُّطٌ.</p><p><span class="qpc-hafs">﴿يَتَوَلَّوْنَهُ﴾</span> يَتَّخِذُونَهُ وَلِيًّا مُطَاعًا.</p><p><span class="qpc-hafs">﴿مُفْتَرٍ﴾</span> كَاذِبٌ، مُخْتَلِقٌ عَلَى اللهِ.</p><p><span class="qpc-hafs">﴿رُوحُ الْقُدُسِ﴾</span> الرُّوحُ المُطَهَّرُ: جِبْرِيلُ عليه السلام.</p></div>"
