tafsir[9]{c,v,t}:
  16,94,"

الوقفات التدبرية

١- <q>﴿مَا عِندَكُمْ يَنفَدُ ۖ وَمَا عِندَ ٱللَّهِ بَاقٍ﴾</q>

فآثروا ما يبقى على ما يفنى؛ فإن الذي عندكم -ولو كثر جداً- لا بد أن ينفد ويفنى، وما عند الله باق ببقائه، لا يفنى ولا يزول، فليس بعاقل من آثر الفاني الخسيس على الباقي النفيس ... وفي هذا الحث والترغيب على الزهد في الدنيا، خصوصاً الزهد المتعين، وهو الزهد فيما يكون ضرراً على العبد. [السعدي:٤٤٨-٤٤٩]

السؤال: ما الذي يفيده المسلم العاقل من هذه الآية؟

٢- <q>﴿مَنْ عَمِلَ صَٰلِحًا مِّن ذَكَرٍ أَوْ أُنثَىٰ وَهُوَ مُؤْمِنٌ فَلَنُحْيِيَنَّهُۥ حَيَوٰةً طَيِّبَةً﴾</q>

فإن الإيمان شرط في صحة الأعمال الصالحة وقبولها، بل لا تسمى أعمالاً صالحة إلا بالإيمان، والإيمان مقتضٍ لها؛ فإنه التصديق الجازم المثمر لأعمال الجوارح من الواجبات والمستحبات. [السعدي:٤٤٩]

السؤال: لماذا قَيَّد الله الأعمال الصالحة بالإيمان في هذه الآية؟

٣- <q>﴿مَنْ عَمِلَ صَٰلِحًا مِّن ذَكَرٍ أَوْ أُنثَىٰ وَهُوَ مُؤْمِنٌ فَلَنُحْيِيَنَّهُۥ حَيَوٰةً طَيِّبَةً ۖ وَلَنَجْزِيَنَّهُمْ أَجْرَهُم بِأَحْسَنِ مَا كَانُوا۟ يَعْمَلُونَ﴾</q>

ربط السعادة مع إصلاح العمل. [ابن تيمية:٤/١٧٦]

السؤال: رُبطت الحياة الطيبة في الآية بأمرين، ما هما؟

٤- <q>﴿فَإِذَا قَرَأْتَ ٱلْقُرْءَانَ فَٱسْتَعِذْ بِٱللَّهِ مِنَ ٱلشَّيْطَٰنِ ٱلرَّجِيمِ﴾</q>

المعنى في الاستعاذة عند ابتداء القراءة: لئلا يلبس على القارئ قراءته، ويخلط عليه، ويمنعه من التدبر والتفكر. [ابن كثير:٢/٥٦٦]

السؤال: ذُكِرَ في هذه الآية وسيلة ناجعة من وسائل تدبر القرآن الكريم، فما هي؟

٥- <q>﴿إِنَّهُۥ لَيْسَ لَهُۥ سُلْطَٰنٌ عَلَى ٱلَّذِينَ ءَامَنُوا۟ وَعَلَىٰ رَبِّهِمْ يَتَوَكَّلُونَ﴾</q>

أي: ليس له عليهم سبيل، ولا يقدر على إضلالهم. [ابن جزي:١/٤٧٣]

السؤال: ما الصفات التي ينبغي الاتصاف بها؛ حتى لا يكون للشيطان عليك سبيل؟

٦- <q>﴿إِنَّهُۥ لَيْسَ لَهُۥ سُلْطَٰنٌ عَلَى ٱلَّذِينَ ءَامَنُوا۟ وَعَلَىٰ رَبِّهِمْ يَتَوَكَّلُونَ﴾</q>

قال الثوري: ليس له عليهم سلطان أن يوقعهم في ذنب لا يتوبون منه. [ابن كثير:٢/٥٦٦]

السؤال: ما السلطان المنفي عن إبليس على الذين آمنوا؟

٧- <q>﴿إِنَّهُۥ لَيْسَ لَهُۥ سُلْطَٰنٌ عَلَى ٱلَّذِينَ ءَامَنُوا۟ وَعَلَىٰ رَبِّهِمْ يَتَوَكَّلُونَ﴾</q>

فنَفي سلطان الشيطان مشروط بالأمرين: الإيمان، والتوكّل. [ابن عاشور:١٤/٢٧٨]

السؤال: ما الذي يمنع تسلط الشيطان على الإنسان؟

التوجيهات

١- من فضل الله على الصابر أنه يوم القيامة ينظر إلى أفضل عمل عمله ويجعل من أهله، ولو لم يفعله إلا مرة واحدة في عمره، <q>﴿وَلَنَجْزِيَنَّ ٱلَّذِينَ صَبَرُوٓا۟ أَجْرَهُم بِأَحْسَنِ مَا كَانُوا۟ يَعْمَلُونَ﴾</q>

٢- الإيمان والتوكل على الله سبحانه وتعالى سببان للحماية من شرور إبليس ووساوسه، <q>﴿إِنَّهُۥ لَيْسَ لَهُۥ سُلْطَٰنٌ عَلَى ٱلَّذِينَ ءَامَنُوا۟ وَعَلَىٰ رَبِّهِمْ يَتَوَكَّلُونَ﴾</q>

٣- المداومة على قراءة القرآن من أسباب الثبات على دين الله,<q>﴿قُلْ نَزَّلَهُۥ رُوحُ ٱلْقُدُسِ مِن رَّبِّكَ بِٱلْحَقِّ لِيُثَبِّتَ ٱلَّذِينَ ءَامَنُوا۟ وَهُدًى وَبُشْرَىٰ لِلْمُسْلِمِينَ﴾</q>

العمل بالآيات

١- تصدق بصدقة ترجو نفعها وبركتها في الدنيا ويوم القيامة، <q>﴿مَا عِندَكُمْ يَنفَدُ ۖ وَمَا عِندَ ٱللَّهِ بَاقٍ﴾</q>

٢- استعذ بالله من الشيطان الرجيم عند قراءتك للقرآن, خاصة عند قراءة الفاتحة في الصلاة، <q>﴿فَإِذَا قَرَأْتَ ٱلْقُرْءَانَ فَٱسْتَعِذْ بِٱللَّهِ مِنَ ٱلشَّيْطَٰنِ ٱلرَّجِيمِ﴾</q>

٣- سل الله تعالى أن يجعلك من عباده الذين ليس للشيطان عليهم سلطان، <q>﴿إِنَّهُۥ لَيْسَ لَهُۥ سُلْطَٰنٌ عَلَى ٱلَّذِينَ ءَامَنُوا۟ وَعَلَىٰ رَبِّهِمْ يَتَوَكَّلُونَ﴾</q>

معاني الكلمات

<q>﴿يَنْفَدُ﴾</q> يَذْهَبُ وَيَفْنَى.

<q>﴿الرَّجِيمِ﴾</q> المَطْرُودِ مِنْ رَحْمَةِ اللهِ.

<q>﴿سُلْطَانٌ﴾</q> تَسَلُّطٌ.

<q>﴿يَتَوَلَّوْنَهُ﴾</q> يَتَّخِذُونَهُ وَلِيًّا مُطَاعًا.

<q>﴿مُفْتَرٍ﴾</q> كَاذِبٌ، مُخْتَلِقٌ عَلَى اللهِ.

<q>﴿رُوحُ الْقُدُسِ﴾</q> الرُّوحُ المُطَهَّرُ: جِبْرِيلُ عليه السلام.

