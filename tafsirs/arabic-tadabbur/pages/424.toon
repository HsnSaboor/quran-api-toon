quran[7]{c,v,t}:
  33,44,"<div class=ar lang=ar><h3>الوقفات التدبرية</h3><p>١- <span class="qpc-hafs">﴿يَٰٓأَيُّهَا ٱلنَّبِىُّ إِنَّآ أَرْسَلْنَٰكَ شَٰهِدًا وَمُبَشِّرًا وَنَذِيرًا (٤٥) وَدَاعِيًا إِلَى ٱللَّهِ بِإِذْنِهِۦ وَسِرَاجًا مُّنِيرًا﴾</span></p><p>هذه الأشياء التي وصف الله بها رسوله محمداً ﷺ هي المقصود من رسالته، وزبدتها، وأصولها التي اختص بها. [السعدي:٦٦٧]</p><p>السؤال: لماذا ذكرت هذه الأشياء الخمسة في وصف نبينا دون غيرها؟</p><p>٢- <span class="qpc-hafs">﴿يَٰٓأَيُّهَا ٱلنَّبِىُّ إِنَّآ أَرْسَلْنَٰكَ شَٰهِدًا وَمُبَشِّرًا وَنَذِيرًا﴾</span></p><p>وقدمت البِشارة على النِذارة لأن النبي ﷺ غلب عليه التبشير؛ لأنه رحمة للعالمين، ولكثرة عدد المؤمنين في أمته. [ابن عاشور:٢٢/٥٣]</p><p>السؤال: لماذا قدمت البشارة على النذارة في وصفه صلى الله عليه وسلم في الآية؟</p><p>٣- <span class="qpc-hafs">﴿وَدَاعِيًا إِلَى ٱللَّهِ﴾</span></p><p>إخلاص الدعوة إلى الله، لا إلى نفسه وتعظيمها، كما قد يعرض ذلك لكثير من النفوس في هذا المقام. [السعدي:٦٦٨]</p><p>السؤال: قد يحصل زلل من الدعاة في شأن الإخلاص، وضِّح ذلك من خلال الآية؟</p><p>٤- <span class="qpc-hafs">﴿وَبَشِّرِ ٱلْمُؤْمِنِينَ بِأَنَّ لَهُم مِّنَ ٱللَّهِ فَضْلًا كَبِيرًا﴾</span></p><p>قال ابن عطية : قال لنا أبي: هذه من أرجى آية عندي في كتاب الله تعالى؛ لأن الله عز وجل قد أمر نبيه أن يبشر المؤمنين بأن لهم عنده فضلا كبيرا، وقد بين تعالى الفضل الكبير في قوله تعالى: <span class="qpc-hafs">﴿والذين آمنوا وعملوا الصالحات في روضات الجنات لهم ما يشاءون عند ربهم ذلك هو الفضل الكبير﴾</span> [الشورى: ٢٢]. [القرطبي:١٦/١٧٣]</p><p>السؤال: بين كيف عد بعض العلماء هذه الآية من أرجى الآيات؟</p><p>٥- <span class="qpc-hafs">﴿وَلَا تُطِعِ ٱلْكَٰفِرِينَ وَٱلْمُنَٰفِقِينَ وَدَعْ أَذَىٰهُمْ﴾</span></p><p>فإن ذلك جالب لهم، وداعٍ إلى قبول الإسلام، وإلى كفِّ كثير من أذيتهم له ولأهله. [السعدي:٦٦٨]</p><p>السؤال: لماذا نهى الله عن أذية الكافرين والمنافقين؟</p><p>٦- <span class="qpc-hafs">﴿وَلَا تُطِعِ ٱلْكَٰفِرِينَ وَٱلْمُنَٰفِقِينَ وَدَعْ أَذَىٰهُمْ﴾</span></p><p>أي: لا تطعهم فيما يشيرون عليك من المداهنة في الدين ولا تمالئهم. [القرطبي:١٦/١٧٣]</p><p>السؤال: يريد الكافرون والمنافقون من الداعية أمرا معينا، فما هو؟</p><p>٧- <span class="qpc-hafs">﴿يَٰٓأَيُّهَا ٱلَّذِينَ ءَامَنُوٓا۟ إِذَا نَكَحْتُمُ ٱلْمُؤْمِنَٰتِ ثُمَّ طَلَّقْتُمُوهُنَّ مِن قَبْلِ أَن تَمَسُّوهُنَّ فَمَا لَكُمْ عَلَيْهِنَّ مِنْ عِدَّةٍ تَعْتَدُّونَهَا ۖ فَمَتِّعُوهُنَّ وَسَرِّحُوهُنَّ سَرَاحًا جَمِيلًا﴾</span></p><p>وأمرهم بتمتيعهن بهذه الحالة بشيء من متاع الدنيا الذي يكون فيه جبر لخواطرهن لأجل فراقهن. [السعدي:٦٦٨]</p><p>السؤال: ما الحكمة من تشريع التمتيع هنا؟</p><h3>التوجيهات</h3><p>١- عظم مكانة النبي ﷺ ومنزلته وفضله على سائر الخلق<span class="qpc-hafs">﴿يَٰٓأَيُّهَا ٱلنَّبِىُّ إِنَّآ أَرْسَلْنَٰكَ شَٰهِدًا وَمُبَشِّرًا وَنَذِيرًا (٤٥) وَدَاعِيًا إِلَى ٱللَّهِ بِإِذْنِهِۦ وَسِرَاجًا مُّنِيرًا﴾</span></p><p>٢- مشروعية الدعوة إلى الله إذا كان الداعي متأهلا بالعلم والحلم، <span class="qpc-hafs">﴿يَٰٓأَيُّهَا ٱلنَّبِىُّ إِنَّآ أَرْسَلْنَٰكَ شَٰهِدًا وَمُبَشِّرًا وَنَذِيرًا﴾</span></p><p>٣- حرمة طاعة الكافرين والمنافقين والفجرة والظالمين فيما يتنافى مع مرضاة الله تعالى, <span class="qpc-hafs">﴿وَلَا تُطِعِ ٱلْكَٰفِرِينَ وَٱلْمُنَٰفِقِينَ وَدَعْ أَذَىٰهُمْ وَتَوَكَّلْ عَلَى ٱللَّهِ ۚ وَكَفَىٰ بِٱللَّهِ وَكِيلًا﴾</span></p><h3>العمل بالآيات</h3><p>١- ألق السلام بتواضع على من هو دونك في السن أو المنزلة، عسى أن يكون سبباً في سلام الله عليك يوم القيامة، <span class="qpc-hafs">﴿تَحِيَّتُهُمْ يَوْمَ يَلْقَوْنَهُۥ سَلَٰمٌ ۚ وَأَعَدَّ لَهُمْ أَجْرًا كَرِيمًا﴾</span></p><p>٢- سل الله أن يرزقك الإخلاص، وأن يجنبك الرياء في دعوتك وأمرك بالمعروف ونهيك عن المنكر، <span class="qpc-hafs">﴿وَدَاعِيًا إِلَى ٱللَّهِ بِإِذْنِهِۦ﴾</span></p><p>٣- بشّر إخوةً لك بما أعده الله لهم من الفضل العظيم لصبرهم على عبادة الله وعلى أقدار الله، <span class="qpc-hafs">﴿وَبَشِّرِ ٱلْمُؤْمِنِينَ بِأَنَّ لَهُم مِّنَ ٱللَّهِ فَضْلًا كَبِيرًا﴾</span></p><h3>معاني الكلمات</h3><p><span class="qpc-hafs">﴿تَمَسُّوهُنَّ﴾</span> تَدْخُلُوا بِهِنَّ، وَتُجَامِعُوهُنَّ.</p><p><span class="qpc-hafs">﴿عِدَّةٍ﴾</span> مُدَّةٍ تَنْتَظِرُ فِيهَا المَرْأَةُ.</p><p><span class="qpc-hafs">﴿تَعْتَدُّونَهَا﴾</span> تُحْصُونَهَا عَلَيْهِنَّ.</p><p><span class="qpc-hafs">﴿فَمَتِّعُوهُنَّ﴾</span> أَعْطُوهُنَّ مِنْ أَمْوَالِكُمْ مَا يَتَمَتَّعْنَ بِهِ بِحَسَبِ وُسْعِكُمْ؛ جَبْرًا لِخَوَاطِرِهِنَّ.</p><p><span class="qpc-hafs">﴿وَسَرِّحُوهُنَّ﴾</span> طَلِّقُوهُنَّ.</p><p><span class="qpc-hafs">﴿جَمِيلاً﴾</span> بِلاَ أَذًى، أَوْ ضَرَرٍ.</p><p><span class="qpc-hafs">﴿وَمَا مَلَكَتْ يَمِينُكَ﴾</span> الإِمَاءَ الَّتِي تَكُونُ مِلْكًا خَالِصًا لَكَ.</p><p><span class="qpc-hafs">﴿أَفَاءَ اللَّهُ عَلَيْكَ﴾</span> أَنْعَمَ بِهِ عَلَيْكَ بِالجِهَادِ.</p><p><span class="qpc-hafs">﴿خَالِصَةً لَكَ﴾</span> خَاصَّةً بِكَ.</p><p><span class="qpc-hafs">﴿حَرَجٌ﴾</span> ضِيقٌ.</p></div>"
