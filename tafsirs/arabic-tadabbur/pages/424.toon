tafsir[7]{c,v,t}:
  33,44,"

الوقفات التدبرية

١- <q>﴿يَٰٓأَيُّهَا ٱلنَّبِىُّ إِنَّآ أَرْسَلْنَٰكَ شَٰهِدًا وَمُبَشِّرًا وَنَذِيرًا (٤٥) وَدَاعِيًا إِلَى ٱللَّهِ بِإِذْنِهِۦ وَسِرَاجًا مُّنِيرًا﴾</q>

هذه الأشياء التي وصف الله بها رسوله محمداً ﷺ هي المقصود من رسالته، وزبدتها، وأصولها التي اختص بها. [السعدي:٦٦٧]

السؤال: لماذا ذكرت هذه الأشياء الخمسة في وصف نبينا دون غيرها؟

٢- <q>﴿يَٰٓأَيُّهَا ٱلنَّبِىُّ إِنَّآ أَرْسَلْنَٰكَ شَٰهِدًا وَمُبَشِّرًا وَنَذِيرًا﴾</q>

وقدمت البِشارة على النِذارة لأن النبي ﷺ غلب عليه التبشير؛ لأنه رحمة للعالمين، ولكثرة عدد المؤمنين في أمته. [ابن عاشور:٢٢/٥٣]

السؤال: لماذا قدمت البشارة على النذارة في وصفه صلى الله عليه وسلم في الآية؟

٣- <q>﴿وَدَاعِيًا إِلَى ٱللَّهِ﴾</q>

إخلاص الدعوة إلى الله، لا إلى نفسه وتعظيمها، كما قد يعرض ذلك لكثير من النفوس في هذا المقام. [السعدي:٦٦٨]

السؤال: قد يحصل زلل من الدعاة في شأن الإخلاص، وضِّح ذلك من خلال الآية؟

٤- <q>﴿وَبَشِّرِ ٱلْمُؤْمِنِينَ بِأَنَّ لَهُم مِّنَ ٱللَّهِ فَضْلًا كَبِيرًا﴾</q>

قال ابن عطية : قال لنا أبي: هذه من أرجى آية عندي في كتاب الله تعالى؛ لأن الله عز وجل قد أمر نبيه أن يبشر المؤمنين بأن لهم عنده فضلا كبيرا، وقد بين تعالى الفضل الكبير في قوله تعالى: <q>﴿والذين آمنوا وعملوا الصالحات في روضات الجنات لهم ما يشاءون عند ربهم ذلك هو الفضل الكبير﴾</q> [الشورى: ٢٢]. [القرطبي:١٦/١٧٣]

السؤال: بين كيف عد بعض العلماء هذه الآية من أرجى الآيات؟

٥- <q>﴿وَلَا تُطِعِ ٱلْكَٰفِرِينَ وَٱلْمُنَٰفِقِينَ وَدَعْ أَذَىٰهُمْ﴾</q>

فإن ذلك جالب لهم، وداعٍ إلى قبول الإسلام، وإلى كفِّ كثير من أذيتهم له ولأهله. [السعدي:٦٦٨]

السؤال: لماذا نهى الله عن أذية الكافرين والمنافقين؟

٦- <q>﴿وَلَا تُطِعِ ٱلْكَٰفِرِينَ وَٱلْمُنَٰفِقِينَ وَدَعْ أَذَىٰهُمْ﴾</q>

أي: لا تطعهم فيما يشيرون عليك من المداهنة في الدين ولا تمالئهم. [القرطبي:١٦/١٧٣]

السؤال: يريد الكافرون والمنافقون من الداعية أمرا معينا، فما هو؟

٧- <q>﴿يَٰٓأَيُّهَا ٱلَّذِينَ ءَامَنُوٓا۟ إِذَا نَكَحْتُمُ ٱلْمُؤْمِنَٰتِ ثُمَّ طَلَّقْتُمُوهُنَّ مِن قَبْلِ أَن تَمَسُّوهُنَّ فَمَا لَكُمْ عَلَيْهِنَّ مِنْ عِدَّةٍ تَعْتَدُّونَهَا ۖ فَمَتِّعُوهُنَّ وَسَرِّحُوهُنَّ سَرَاحًا جَمِيلًا﴾</q>

وأمرهم بتمتيعهن بهذه الحالة بشيء من متاع الدنيا الذي يكون فيه جبر لخواطرهن لأجل فراقهن. [السعدي:٦٦٨]

السؤال: ما الحكمة من تشريع التمتيع هنا؟

التوجيهات

١- عظم مكانة النبي ﷺ ومنزلته وفضله على سائر الخلق<q>﴿يَٰٓأَيُّهَا ٱلنَّبِىُّ إِنَّآ أَرْسَلْنَٰكَ شَٰهِدًا وَمُبَشِّرًا وَنَذِيرًا (٤٥) وَدَاعِيًا إِلَى ٱللَّهِ بِإِذْنِهِۦ وَسِرَاجًا مُّنِيرًا﴾</q>

٢- مشروعية الدعوة إلى الله إذا كان الداعي متأهلا بالعلم والحلم، <q>﴿يَٰٓأَيُّهَا ٱلنَّبِىُّ إِنَّآ أَرْسَلْنَٰكَ شَٰهِدًا وَمُبَشِّرًا وَنَذِيرًا﴾</q>

٣- حرمة طاعة الكافرين والمنافقين والفجرة والظالمين فيما يتنافى مع مرضاة الله تعالى, <q>﴿وَلَا تُطِعِ ٱلْكَٰفِرِينَ وَٱلْمُنَٰفِقِينَ وَدَعْ أَذَىٰهُمْ وَتَوَكَّلْ عَلَى ٱللَّهِ ۚ وَكَفَىٰ بِٱللَّهِ وَكِيلًا﴾</q>

العمل بالآيات

١- ألق السلام بتواضع على من هو دونك في السن أو المنزلة، عسى أن يكون سبباً في سلام الله عليك يوم القيامة، <q>﴿تَحِيَّتُهُمْ يَوْمَ يَلْقَوْنَهُۥ سَلَٰمٌ ۚ وَأَعَدَّ لَهُمْ أَجْرًا كَرِيمًا﴾</q>

٢- سل الله أن يرزقك الإخلاص، وأن يجنبك الرياء في دعوتك وأمرك بالمعروف ونهيك عن المنكر، <q>﴿وَدَاعِيًا إِلَى ٱللَّهِ بِإِذْنِهِۦ﴾</q>

٣- بشّر إخوةً لك بما أعده الله لهم من الفضل العظيم لصبرهم على عبادة الله وعلى أقدار الله، <q>﴿وَبَشِّرِ ٱلْمُؤْمِنِينَ بِأَنَّ لَهُم مِّنَ ٱللَّهِ فَضْلًا كَبِيرًا﴾</q>

معاني الكلمات

<q>﴿تَمَسُّوهُنَّ﴾</q> تَدْخُلُوا بِهِنَّ، وَتُجَامِعُوهُنَّ.

<q>﴿عِدَّةٍ﴾</q> مُدَّةٍ تَنْتَظِرُ فِيهَا المَرْأَةُ.

<q>﴿تَعْتَدُّونَهَا﴾</q> تُحْصُونَهَا عَلَيْهِنَّ.

<q>﴿فَمَتِّعُوهُنَّ﴾</q> أَعْطُوهُنَّ مِنْ أَمْوَالِكُمْ مَا يَتَمَتَّعْنَ بِهِ بِحَسَبِ وُسْعِكُمْ؛ جَبْرًا لِخَوَاطِرِهِنَّ.

<q>﴿وَسَرِّحُوهُنَّ﴾</q> طَلِّقُوهُنَّ.

<q>﴿جَمِيلاً﴾</q> بِلاَ أَذًى، أَوْ ضَرَرٍ.

<q>﴿وَمَا مَلَكَتْ يَمِينُكَ﴾</q> الإِمَاءَ الَّتِي تَكُونُ مِلْكًا خَالِصًا لَكَ.

<q>﴿أَفَاءَ اللَّهُ عَلَيْكَ﴾</q> أَنْعَمَ بِهِ عَلَيْكَ بِالجِهَادِ.

<q>﴿خَالِصَةً لَكَ﴾</q> خَاصَّةً بِكَ.

<q>﴿حَرَجٌ﴾</q> ضِيقٌ.

