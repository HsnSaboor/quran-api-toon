tafsir[5]{c,v,t}:
  22,1,"

الوقفات التدبرية

١- <q>﴿يَٰٓأَيُّهَا ٱلنَّاسُ ٱتَّقُوا۟ رَبَّكُمْ﴾</q>

يخاطب الله الناس كافة بأن يتقوا ربهم؛ الذي رباهم بالنعم الظاهرة والباطنة، فحقيق بهم أن يتقوه، بترك الشرك والفسوق والعصيان، ويمتثلوا أوامره مهما استطاعوا. [السعدي:٥٣٢]

السؤال: لماذا خُصَّ ذكر الرب هنا دون سائر أسماء الله وصفاته؟

٢- <q>﴿مِ يَٰٓأَيُّهَا ٱلنَّاسُ ٱتَّقُوا۟ رَبَّكُمْ ۚ إِنَّ زَلْزَلَةَ ٱلسَّاعَةِ شَىْءٌ عَظِيمٌ (١) يَوْمَ تَرَوْنَهَا تَذْهَلُ كُلُّ مُرْضِعَةٍ عَمَّآ أَرْضَعَتْ وَتَضَعُ كُلُّ ذَاتِ حَمْلٍ حَمْلَهَا وَتَرَى ٱلنَّاسَ سُكَٰرَىٰ وَمَا هُم بِسُكَٰرَىٰ وَلَٰكِنَّ عَذَابَ ٱللَّهِ شَدِيدٌ﴾</q>

فائدة ذكر هول ذلك اليوم: التحريض على التأهب له، والاستعداد بالعمل الصالح. [القرطبي: ١٤/٣١١]

السؤال: ما فائدة ذكر أهوال القيامة؟

٣- <q>﴿يَوْمَ تَرَوْنَهَا تَذْهَلُ كُلُّ مُرْضِعَةٍ﴾</q>

مع أنها مجبولة على شدة محبتها لولدها، خصوصاً في هذه الحال التي لا يعيش إلا بها. [السعدي:٥٣٣]

السؤال: لماذا خُصَّت المرضعة بالذكر هنا؟

٤- <q>﴿يَوْمَ تَرَوْنَهَا تَذْهَلُ كُلُّ مُرْضِعَةٍ عَمَّآ أَرْضَعَتْ﴾</q>

إنما لم يقل مرضع؛ لأن المرضعة هي التي في حال الإرضاع ملقمة ثديها للصبي، والمرضع التي شأنها أن ترضع وإن لم تباشر الإرضاع في حال وصفها به، فقال: <q>﴿مرضعة﴾</q> ليكون ذلك أعظم في الذهول؛ إذ تنزع ثديها من فم الصبي حينئذ. [ابن جزي:٢/ ٤٨ ]

السؤال: ما الوجه البلاغي في الوصف بــِ <q>﴿مرضعة﴾</q> دون «مرضع»؟

٥- <q>﴿وَتَرَى ٱلنَّاسَ سُكَٰرَىٰ وَمَا هُم بِسُكَٰرَىٰ وَلَٰكِنَّ عَذَابَ ٱللَّهِ شَدِيدٌ﴾</q>

تشبيه بالسكارى من شدّة الغمّ . [ابن جزي:٢/٤٩. ]

السؤال: لم شبههم بالسكارى مع كونهم ليسوا كذلك؟

٦- <q>﴿وَمِنَ ٱلنَّاسِ مَن يُجَٰدِلُ فِى ٱللَّهِ بِغَيْرِ عِلْمٍ وَيَتَّبِعُ كُلَّ شَيْطَٰنٍ مَّرِيدٍ﴾</q>

قال الفخر الرازي في تفسيره: هذه الآية بمفهومها تدل على جواز المجادلة الحقة; لأن تخصيص المجادلة مع عدم العلم بالدلائل يدل على أن المجادلة مع العلم جائزة، فالمجادلة الباطلة هي المراد من قوله: <q>﴿ما ضربوه لك إلا جدلا﴾</q> [الزخرف: ٥٨]، والمجادلة الحقة هي المراد من قوله: <q>﴿وجادلهم بالتي هي أحسن﴾</q> [النحل: ١٢٥] أ.هـ منه. [الشنقيطي:٤/٢٦٣]

السؤال: الجدال نوعان فما هما؟ وما الجائز منهما؟

٧- <q>﴿وَمِنَ ٱلنَّاسِ مَن يُجَٰدِلُ فِى ٱللَّهِ بِغَيْرِ عِلْمٍ وَيَتَّبِعُ كُلَّ شَيْطَٰنٍ مَّرِيدٍ﴾</q>

هذه حال الضال المتبع لمن يضله، فلم يحتج إلى تفصيل، فبين أنه يجادل بغير علم، ويتبع كل شيطان مريد؛ كتب على ذلك الشيطان أنه من تولاه فأنه يضله ويهديه إلى عذاب السعير، وهذه حال مقلد أئمة الضلال بين أهل الكتاب وأهل البدع؛ فإنهم يجادلون في الله بغير علم، ويتبعون من شياطين الجن والإنس من يضلهم. [ابن تيمية:٤/٤٠١]

السؤال: بين خطورة تقليد أئمة الضلال.

التوجيهات

١- تقرير عقيدة البعث والجزاء بذكر أحوالهما وأهوالهما، <q>﴿يَٰٓأَيُّهَا ٱلنَّاسُ ٱتَّقُوا۟ رَبَّكُمْ ۚ إِنَّ زَلْزَلَةَ ٱلسَّاعَةِ شَىْءٌ عَظِيمٌ﴾</q>

٢- حرمة الكلام في شرع الله بغير علم من وحي إلهي، أو كلام نبوي صحيح، <q>﴿وَمِنَ ٱلنَّاسِ مَن يُجَٰدِلُ فِى ٱللَّهِ بِغَيْرِ عِلْمٍ وَيَتَّبِعُ كُلَّ شَيْطَٰنٍ مَّرِيدٍ﴾</q>

٣- موالاة الشياطين وأتباعهم تفضى إلى الضلالة ودخول جهنم وعذاب السعير، <q>﴿كُتِبَ عَلَيْهِ أَنَّهُۥ مَن تَوَلَّاهُ فَأَنَّهُۥ يُضِلُّهُۥ وَيَهْدِيهِ إِلَىٰ عَذَابِ ٱلسَّعِيرِ﴾</q>

العمل بالآيات

١- سَل الله تعالى الأمن يوم الفزع، ثم قل: «اللهم إني أسألك الهدى، والتقى، والعفاف، والغنى»، <q>﴿يَٰٓأَيُّهَا ٱلنَّاسُ ٱتَّقُوا۟ رَبَّكُمْ ۚ إِنَّ زَلْزَلَةَ ٱلسَّاعَةِ شَىْءٌ عَظِيمٌ﴾</q>

٢- ألق كلمة، أو أرسل رسالةً تبين فيها خطر الجدال في الدين بغير علم, <q>﴿وَمِنَ ٱلنَّاسِ مَن يُجَٰدِلُ فِى ٱللَّهِ بِغَيْرِ عِلْمٍ وَيَتَّبِعُ كُلَّ شَيْطَٰنٍ مَّرِيدٍ﴾</q>

٣- استعذ بالله من أن ترد إلى أرذل العمر, <q>﴿وَمِنكُم مَّن يُرَدُّ إِلَىٰٓ أَرْذَلِ ٱلْعُمُرِ لِكَيْلَا يَعْلَمَ مِنۢ بَعْدِ عِلْمٍ شَيْـًٔا﴾</q>

معاني الكلمات

<q>﴿إِنَّ زَلْزَلَةَ السَّاعَةِ﴾</q> أَهْوَالَ القِيَامَةِ، وَاضْطِرَابَ الأَرْضِ يَوْمَهَا.

<q>﴿تَذْهَلُ﴾</q> تَغْفُلُ، وَتَنْشَغِلُ.

<q>﴿مُرْضِعَةٍ﴾</q> الَّتِي أَلْقَمَتْ وَلِيدَهَا ثَدْيَهَا.

<q>﴿مَرِيدٍ﴾</q> مُتَمَرِّدٍ.

<q>﴿تَوَلاَّهُ﴾</q> اتَّخَذَهُ وَلِيًّا وَتَبِعَهُ.

<q>﴿رَيْبٍ﴾</q> شَكٍّ.

<q>﴿عَلَقَةٍ﴾</q> دَمٍ أَحْمَرَ غَلِيظٍ تَعَلَّقَ فِي الرَّحِمِ.

<q>﴿مُضْغَةٍ﴾</q> قِطْعَةِ لَحْمٍ صَغِيرَةٍ قَدْرَ مَا يُمْضَغُ.

<q>﴿مُخَلَّقَةٍ﴾</q> تَامَّةِ الخَلْقِ.

<q>﴿أَشُدَّكُمْ﴾</q> وَقْتَ شَبَابِكُمْ، وَاكْتِمَالِ قُوَّتِكُمْ.

<q>﴿أَرْذَلِ الْعُمُرِ﴾</q> سِنِّ الهَرَمِ، وَضَعْفِ العَقْلِ.

<q>﴿هَامِدَةً﴾</q> يَابِسَةً مَيِّتَةً.

<q>﴿اهْتَزَّتْ﴾</q> تَحَرَّكَتْ بِالنَّبَاتِ.

<q>﴿وَرَبَتْ﴾</q> اِرْتَفَعَتْ، وَزَادَتْ لاِرْتِوَائِهَا.

<q>﴿زَوْجٍ﴾</q> مِنْ كُلِّ نَوْعٍ مِنْ أَنْوَاعِ النَّبَاتِ.

<q>﴿بَهِيجٍ﴾</q> حَسَنٍ يَسُرُّ النَّاظِرِينَ.

"
  22,2,"22:1"
  22,3,"22:1"
  22,4,"22:1"
  22,5,"22:1"
