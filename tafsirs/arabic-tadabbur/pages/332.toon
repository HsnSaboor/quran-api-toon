quran[5]{c,v,t}:
  22,1,"<div class=ar lang=ar><h3>الوقفات التدبرية</h3><p>١- <span class="qpc-hafs">﴿يَٰٓأَيُّهَا ٱلنَّاسُ ٱتَّقُوا۟ رَبَّكُمْ﴾</span></p><p>يخاطب الله الناس كافة بأن يتقوا ربهم؛ الذي رباهم بالنعم الظاهرة والباطنة، فحقيق بهم أن يتقوه، بترك الشرك والفسوق والعصيان، ويمتثلوا أوامره مهما استطاعوا. [السعدي:٥٣٢]</p><p>السؤال: لماذا خُصَّ ذكر الرب هنا دون سائر أسماء الله وصفاته؟</p><p>٢- <span class="qpc-hafs">﴿مِ يَٰٓأَيُّهَا ٱلنَّاسُ ٱتَّقُوا۟ رَبَّكُمْ ۚ إِنَّ زَلْزَلَةَ ٱلسَّاعَةِ شَىْءٌ عَظِيمٌ (١) يَوْمَ تَرَوْنَهَا تَذْهَلُ كُلُّ مُرْضِعَةٍ عَمَّآ أَرْضَعَتْ وَتَضَعُ كُلُّ ذَاتِ حَمْلٍ حَمْلَهَا وَتَرَى ٱلنَّاسَ سُكَٰرَىٰ وَمَا هُم بِسُكَٰرَىٰ وَلَٰكِنَّ عَذَابَ ٱللَّهِ شَدِيدٌ﴾</span></p><p>فائدة ذكر هول ذلك اليوم: التحريض على التأهب له، والاستعداد بالعمل الصالح. [القرطبي: ١٤/٣١١]</p><p>السؤال: ما فائدة ذكر أهوال القيامة؟</p><p>٣- <span class="qpc-hafs">﴿يَوْمَ تَرَوْنَهَا تَذْهَلُ كُلُّ مُرْضِعَةٍ﴾</span></p><p>مع أنها مجبولة على شدة محبتها لولدها، خصوصاً في هذه الحال التي لا يعيش إلا بها. [السعدي:٥٣٣]</p><p>السؤال: لماذا خُصَّت المرضعة بالذكر هنا؟</p><p>٤- <span class="qpc-hafs">﴿يَوْمَ تَرَوْنَهَا تَذْهَلُ كُلُّ مُرْضِعَةٍ عَمَّآ أَرْضَعَتْ﴾</span></p><p>إنما لم يقل مرضع؛ لأن المرضعة هي التي في حال الإرضاع ملقمة ثديها للصبي، والمرضع التي شأنها أن ترضع وإن لم تباشر الإرضاع في حال وصفها به، فقال: <span class="qpc-hafs">﴿مرضعة﴾</span> ليكون ذلك أعظم في الذهول؛ إذ تنزع ثديها من فم الصبي حينئذ. [ابن جزي:٢/ ٤٨ ]</p><p>السؤال: ما الوجه البلاغي في الوصف بــِ <span class="qpc-hafs">﴿مرضعة﴾</span> دون «مرضع»؟</p><p>٥- <span class="qpc-hafs">﴿وَتَرَى ٱلنَّاسَ سُكَٰرَىٰ وَمَا هُم بِسُكَٰرَىٰ وَلَٰكِنَّ عَذَابَ ٱللَّهِ شَدِيدٌ﴾</span></p><p>تشبيه بالسكارى من شدّة الغمّ . [ابن جزي:٢/٤٩. ]</p><p>السؤال: لم شبههم بالسكارى مع كونهم ليسوا كذلك؟</p><p>٦- <span class="qpc-hafs">﴿وَمِنَ ٱلنَّاسِ مَن يُجَٰدِلُ فِى ٱللَّهِ بِغَيْرِ عِلْمٍ وَيَتَّبِعُ كُلَّ شَيْطَٰنٍ مَّرِيدٍ﴾</span></p><p>قال الفخر الرازي في تفسيره: هذه الآية بمفهومها تدل على جواز المجادلة الحقة; لأن تخصيص المجادلة مع عدم العلم بالدلائل يدل على أن المجادلة مع العلم جائزة، فالمجادلة الباطلة هي المراد من قوله: <span class="qpc-hafs">﴿ما ضربوه لك إلا جدلا﴾</span> [الزخرف: ٥٨]، والمجادلة الحقة هي المراد من قوله: <span class="qpc-hafs">﴿وجادلهم بالتي هي أحسن﴾</span> [النحل: ١٢٥] أ.هـ منه. [الشنقيطي:٤/٢٦٣]</p><p>السؤال: الجدال نوعان فما هما؟ وما الجائز منهما؟</p><p>٧- <span class="qpc-hafs">﴿وَمِنَ ٱلنَّاسِ مَن يُجَٰدِلُ فِى ٱللَّهِ بِغَيْرِ عِلْمٍ وَيَتَّبِعُ كُلَّ شَيْطَٰنٍ مَّرِيدٍ﴾</span></p><p>هذه حال الضال المتبع لمن يضله، فلم يحتج إلى تفصيل، فبين أنه يجادل بغير علم، ويتبع كل شيطان مريد؛ كتب على ذلك الشيطان أنه من تولاه فأنه يضله ويهديه إلى عذاب السعير، وهذه حال مقلد أئمة الضلال بين أهل الكتاب وأهل البدع؛ فإنهم يجادلون في الله بغير علم، ويتبعون من شياطين الجن والإنس من يضلهم. [ابن تيمية:٤/٤٠١]</p><p>السؤال: بين خطورة تقليد أئمة الضلال.</p><h3>التوجيهات</h3><p>١- تقرير عقيدة البعث والجزاء بذكر أحوالهما وأهوالهما، <span class="qpc-hafs">﴿يَٰٓأَيُّهَا ٱلنَّاسُ ٱتَّقُوا۟ رَبَّكُمْ ۚ إِنَّ زَلْزَلَةَ ٱلسَّاعَةِ شَىْءٌ عَظِيمٌ﴾</span></p><p>٢- حرمة الكلام في شرع الله بغير علم من وحي إلهي، أو كلام نبوي صحيح، <span class="qpc-hafs">﴿وَمِنَ ٱلنَّاسِ مَن يُجَٰدِلُ فِى ٱللَّهِ بِغَيْرِ عِلْمٍ وَيَتَّبِعُ كُلَّ شَيْطَٰنٍ مَّرِيدٍ﴾</span></p><p>٣- موالاة الشياطين وأتباعهم تفضى إلى الضلالة ودخول جهنم وعذاب السعير، <span class="qpc-hafs">﴿كُتِبَ عَلَيْهِ أَنَّهُۥ مَن تَوَلَّاهُ فَأَنَّهُۥ يُضِلُّهُۥ وَيَهْدِيهِ إِلَىٰ عَذَابِ ٱلسَّعِيرِ﴾</span></p><h3>العمل بالآيات</h3><p>١- سَل الله تعالى الأمن يوم الفزع، ثم قل: «اللهم إني أسألك الهدى، والتقى، والعفاف، والغنى»، <span class="qpc-hafs">﴿يَٰٓأَيُّهَا ٱلنَّاسُ ٱتَّقُوا۟ رَبَّكُمْ ۚ إِنَّ زَلْزَلَةَ ٱلسَّاعَةِ شَىْءٌ عَظِيمٌ﴾</span></p><p>٢- ألق كلمة، أو أرسل رسالةً تبين فيها خطر الجدال في الدين بغير علم, <span class="qpc-hafs">﴿وَمِنَ ٱلنَّاسِ مَن يُجَٰدِلُ فِى ٱللَّهِ بِغَيْرِ عِلْمٍ وَيَتَّبِعُ كُلَّ شَيْطَٰنٍ مَّرِيدٍ﴾</span></p><p>٣- استعذ بالله من أن ترد إلى أرذل العمر, <span class="qpc-hafs">﴿وَمِنكُم مَّن يُرَدُّ إِلَىٰٓ أَرْذَلِ ٱلْعُمُرِ لِكَيْلَا يَعْلَمَ مِنۢ بَعْدِ عِلْمٍ شَيْـًٔا﴾</span></p><h3>معاني الكلمات</h3><p><span class="qpc-hafs">﴿إِنَّ زَلْزَلَةَ السَّاعَةِ﴾</span> أَهْوَالَ القِيَامَةِ، وَاضْطِرَابَ الأَرْضِ يَوْمَهَا.</p><p><span class="qpc-hafs">﴿تَذْهَلُ﴾</span> تَغْفُلُ، وَتَنْشَغِلُ.</p><p><span class="qpc-hafs">﴿مُرْضِعَةٍ﴾</span> الَّتِي أَلْقَمَتْ وَلِيدَهَا ثَدْيَهَا.</p><p><span class="qpc-hafs">﴿مَرِيدٍ﴾</span> مُتَمَرِّدٍ.</p><p><span class="qpc-hafs">﴿تَوَلاَّهُ﴾</span> اتَّخَذَهُ وَلِيًّا وَتَبِعَهُ.</p><p><span class="qpc-hafs">﴿رَيْبٍ﴾</span> شَكٍّ.</p><p><span class="qpc-hafs">﴿عَلَقَةٍ﴾</span> دَمٍ أَحْمَرَ غَلِيظٍ تَعَلَّقَ فِي الرَّحِمِ.</p><p><span class="qpc-hafs">﴿مُضْغَةٍ﴾</span> قِطْعَةِ لَحْمٍ صَغِيرَةٍ قَدْرَ مَا يُمْضَغُ.</p><p><span class="qpc-hafs">﴿مُخَلَّقَةٍ﴾</span> تَامَّةِ الخَلْقِ.</p><p><span class="qpc-hafs">﴿أَشُدَّكُمْ﴾</span> وَقْتَ شَبَابِكُمْ، وَاكْتِمَالِ قُوَّتِكُمْ.</p><p><span class="qpc-hafs">﴿أَرْذَلِ الْعُمُرِ﴾</span> سِنِّ الهَرَمِ، وَضَعْفِ العَقْلِ.</p><p><span class="qpc-hafs">﴿هَامِدَةً﴾</span> يَابِسَةً مَيِّتَةً.</p><p><span class="qpc-hafs">﴿اهْتَزَّتْ﴾</span> تَحَرَّكَتْ بِالنَّبَاتِ.</p><p><span class="qpc-hafs">﴿وَرَبَتْ﴾</span> اِرْتَفَعَتْ، وَزَادَتْ لاِرْتِوَائِهَا.</p><p><span class="qpc-hafs">﴿زَوْجٍ﴾</span> مِنْ كُلِّ نَوْعٍ مِنْ أَنْوَاعِ النَّبَاتِ.</p><p><span class="qpc-hafs">﴿بَهِيجٍ﴾</span> حَسَنٍ يَسُرُّ النَّاظِرِينَ.</p></div>"
  22,2,"22:1"
  22,3,"22:1"
  22,4,"22:1"
  22,5,"22:1"