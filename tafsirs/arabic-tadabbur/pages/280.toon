tafsir[8]{c,v,t}:
  16,111,"

الوقفات التدبرية

١- <q>﴿يَوْمَ تَأْتِى كُلُّ نَفْسٍ تُجَٰدِلُ عَن نَّفْسِهَا وَتُوَفَّىٰ كُلُّ نَفْسٍ مَّا عَمِلَتْ وَهُمْ لَا يُظْلَمُونَ﴾</q>

<q>﴿يوم تأتي كل نفس تجادل عن نفسها﴾</q>: تخاصم، وتحتج عَن نَفْسِها بما أسلفت من خير وشر، مشتغلاً بها، لا تتفرغ إلى غيرها. [البغوي:٢/٦٤١]

السؤال: متى ينشغل العبد بنفسه ولا يتفرغ لعيوب الآخرين؟

٢- <q>﴿وَضَرَبَ ٱللَّهُ مَثَلًا قَرْيَةً كَانَتْ ءَامِنَةً مُّطْمَئِنَّةً يَأْتِيهَا رِزْقُهَا رَغَدًا مِّن كُلِّ مَكَانٍ فَكَفَرَتْ بِأَنْعُمِ ٱللَّهِ فَأَذَٰقَهَا ٱللَّهُ لِبَاسَ ٱلْجُوعِ وَٱلْخَوْفِ بِمَا كَانُوا۟ يَصْنَعُونَ﴾</q>

وقدم الأمن على الطمأنينة؛ إذ لا تحصل الطمأنينة بدونه، كما أن الخوف يسبّب الانزعاج، والقلق. [ابن عاشور:١٤/٣٠٥]

السؤال: لماذا قدم الأمن على الطمأنينة في الآية الكريمة؟

٣- <q>﴿وَضَرَبَ ٱللَّهُ مَثَلًا قَرْيَةً كَانَتْ ءَامِنَةً مُّطْمَئِنَّةً يَأْتِيهَا رِزْقُهَا رَغَدًا مِّن كُلِّ مَكَانٍ فَكَفَرَتْ بِأَنْعُمِ ٱللَّهِ فَأَذَٰقَهَا ٱللَّهُ لِبَاسَ ٱلْجُوعِ وَٱلْخَوْفِ بِمَا كَانُوا۟ يَصْنَعُونَ﴾</q>

سماه لباساً لأنه يظهر عليهم من الهزال، وشحوبة اللون، وسوء الحال ما هو كاللباس. [القرطبي:١٢/٤٥٢]

السؤال: لمَ سمى الله تعالى الجوع والخوف النازل بالأمم الهالكة لباساً؟

٤- <q>﴿وَضَرَبَ ٱللَّهُ مَثَلًا قَرْيَةً كَانَتْ ءَامِنَةً مُّطْمَئِنَّةً يَأْتِيهَا رِزْقُهَا رَغَدًا مِّن كُلِّ مَكَانٍ فَكَفَرَتْ بِأَنْعُمِ ٱللَّهِ فَأَذَٰقَهَا ٱللَّهُ لِبَاسَ ٱلْجُوعِ وَٱلْخَوْفِ بِمَا كَانُوا۟ يَصْنَعُونَ﴾</q>

جعلهم مثَلاً وعظة لمن يأتي بمثل ما أتوا به من إنكار نعمة الله. [ابن عاشور:١٤/٣٠٣]

السؤال: كيف تكون القرى المهلكة مثلا وعظة لغيرها؟

٥- <q>﴿إِنَّمَا حَرَّمَ عَلَيْكُمُ ٱلْمَيْتَةَ وَٱلدَّمَ وَلَحْمَ ٱلْخِنزِيرِ وَمَآ أُهِلَّ لِغَيْرِ ٱللَّهِ بِهِۦ﴾</q>

فالله تعالى ما حرَّم علينا إلا الخبيثات، تفضلاً منه، وصيانة عن كل مستقذر. [السعدي:٤٥١]

السؤال: ما علّة التحريم في الأطعمة المحرمة؟

٦- <q>﴿وَلَا تَقُولُوا۟ لِمَا تَصِفُ أَلْسِنَتُكُمُ ٱلْكَذِبَ هَٰذَا حَلَٰلٌ وَهَٰذَا حَرَامٌ لِّتَفْتَرُوا۟ عَلَى ٱللَّهِ ٱلْكَذِبَ ۚ إِنَّ ٱلَّذِينَ يَفْتَرُونَ عَلَى ٱللَّهِ ٱلْكَذِبَ لَا يُفْلِحُونَ﴾</q>

ويدخل في هذا كل من ابتدع بدعة ليس له فيها مستند شرعي. [ابن كثير:٢/٥٧٠]

السؤال: كيف تدل الآية على تحريم البِدَعِ في الدين؟

٧- <q>﴿وَلَا تَقُولُوا۟ لِمَا تَصِفُ أَلْسِنَتُكُمُ ٱلْكَذِبَ هَٰذَا حَلَٰلٌ وَهَٰذَا حَرَامٌ لِّتَفْتَرُوا۟ عَلَى ٱللَّهِ ٱلْكَذِبَ ۚ إِنَّ ٱلَّذِينَ يَفْتَرُونَ عَلَى ٱللَّهِ ٱلْكَذِبَ لَا يُفْلِحُونَ﴾</q>

هذه الآية مخاطبة للعرب الذين أحلوا أشياء، وحرموا أشياء؛ كالبحيرة وغيرها مما ذكر في سورة المائدة والأنعام، ثم يدخل فيها كل من قال: هذا حلال، وهذا حرام بغير علم. [ابن جزي:١/٤٧٦]

السؤال: بين الأصناف الذين يدخلون في هذه الآية؟

التوجيهات

١- تعـلم اللـغة العـربية عبـادة؛ لأنـها تـوصل إلى فــهم القرآن الكريم، <q>﴿وَضَرَبَ ٱللَّهُ مَثَلًا قَرْيَةً كَانَتْ ءَامِنَةً مُّطْمَئِنَّةً يَأْتِيهَا رِزْقُهَا رَغَدًا مِّن كُلِّ مَكَانٍ فَكَفَرَتْ بِأَنْعُمِ ٱللَّهِ فَأَذَٰقَهَا ٱللَّهُ لِبَاسَ ٱلْجُوعِ وَٱلْخَوْفِ بِمَا كَانُوا۟ يَصْنَعُونَ﴾</q>

٢- الاستسلام للنفس في تتبع الملذات الدنيوية سببٌ للانحراف، <q>﴿إِنَّمَا حَرَّمَ عَلَيْكُمُ ٱلْمَيْتَةَ وَٱلدَّمَ وَلَحْمَ ٱلْخِنزِيرِ وَمَآ أُهِلَّ لِغَيْرِ ٱللَّهِ بِهِۦ﴾</q>

٣- من علامات الغفلة: عدم تتبع المواعظ والذكر ومحاولة الانتفاع بها، <q>﴿وَلَقَدْ جَآءَهُمْ رَسُولٌ مِّنْهُمْ فَكَذَّبُوهُ فَأَخَذَهُمُ ٱلْعَذَابُ وَهُمْ ظَٰلِمُونَ﴾</q>

العمل بالآيات

١- شارك في بعض المواقع الالكترونية، أو برامج الاتصال للدفاع عن الدين وأهله، <q>﴿يَوْمَ تَأْتِى كُلُّ نَفْسٍ تُجَٰدِلُ عَن نَّفْسِهَا﴾</q>

٢- زُر المقبرة، وتذكر أول ليلة لك في القبر، <q>﴿وَضَرَبَ ٱللَّهُ مَثَلًا قَرْيَةً كَانَتْ ءَامِنَةً مُّطْمَئِنَّةً يَأْتِيهَا رِزْقُهَا رَغَدًا مِّن كُلِّ مَكَانٍ فَكَفَرَتْ بِأَنْعُمِ ٱللَّهِ فَأَذَٰقَهَا ٱللَّهُ لِبَاسَ ٱلْجُوعِ وَٱلْخَوْفِ بِمَا كَانُوا۟ يَصْنَعُونَ﴾</q>

٣- استخرج ثلاث فوائد من الآية: <q>﴿فَكُلُوا۟ مِمَّا رَزَقَكُمُ ٱللَّهُ حَلَٰلًا طَيِّبًا وَٱشْكُرُوا۟ نِعْمَتَ ٱللَّهِ إِن كُنتُمْ إِيَّاهُ تَعْبُدُونَ﴾</q>

معاني الكلمات

<q>﴿وَتُوَفَّى﴾</q> تُعْطَى الجَزَاءَ وَافِيًا.

<q>﴿رَغَدًا﴾</q> هَنِيئًا سَهْلاً.

<q>﴿الْمَيْتَةَ﴾</q> مَا مَاتَ بِغَيْرِ تَذْكِيَةٍ شَرْعِيَّةٍ.

<q>﴿وَالدَّمَ﴾</q> هُوَ الدَّمُ المَسْفُوحُ مِنَ الذَّبِيحَةِ عِنْدَ الذَّبْحِ.

<q>﴿أُهِلَّ لِغَيْرِ اللَّهِ بِهِ﴾</q> ذُكِرَ عِنْدَ الذَبْحِ اسْمُ غَيْرِ اللهِ.

<q>﴿غَيْرَ بَاغٍ﴾</q> غَيْرَ مُرِيدٍ وَلا طَالِبٍ لِلْمُحَرَّمِ.

<q>﴿وَلا عَادٍ﴾</q> وغَيْرَ مُتَجَاوِزٍ حَدَّ الضَّرُورَةٍ مِمَّا يَسُدُّ الرَّمَقَ.

<q>﴿لِتَفْتَرُوا﴾</q> لِتَخْتَلِقُوا.

