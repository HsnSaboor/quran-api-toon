quran[16]{c,v,t}:
  15,16,"<div class=ar lang=ar><h3>الوقفات التدبرية</h3><p>١- <span class="qpc-hafs">﴿وَلَقَدْ جَعَلْنَا فِى ٱلسَّمَآءِ بُرُوجًا وَزَيَّنَّٰهَا لِلنَّٰظِرِينَ﴾</span></p><p>وهذا مما يدعو الناظرين إلى التأمل فيها، والنظر في معانيها، والاستدلال بها على باريها. [السعدي:٤٣٠]</p><p>السؤال: النجوم والبروج التي في السماء كيف تزيد في إيمان المؤمن؟</p><p>٢- <span class="qpc-hafs">﴿وَٱلْأَرْضَ مَدَدْنَٰهَا﴾</span></p><p>أي: وسعناها سَعَةً يتمكن الآدميون والحيوانات كلها على الامتداد بأرجائها، والتناول من أرزاقها، والسكون في نواحيها. [السعدي:٤٣٠]</p><p>السؤال: من إساءة الظن بالله أن يعتقد الإنسان أن أرزاق الأرض لن تكفي الناس في المستقبل، وضح هذا من الآية .</p><p>٣- <span class="qpc-hafs">﴿وَلَقَدْ عَلِمْنَا ٱلْمُسْتَقْدِمِينَ مِنكُمْ وَلَقَدْ عَلِمْنَا ٱلْمُسْتَـْٔخِرِينَ (٢٤) وَإِنَّ رَبَّكَ هُوَ يَحْشُرُهُمْ ۚ إِنَّهُۥ حَكِيمٌ عَلِيمٌ﴾</span></p><p><span class="qpc-hafs">﴿ولقد علمنا المستقدمين منكم﴾</span> يعني: الأولين والآخرين من الناس، وذكر ذلك على وجه الاستدلال على الحشر الذي ذكر بعد ذلك في قوله: <span class="qpc-hafs">﴿وإن ربك هو يحشرهم إنه حكيم عليم﴾</span>؛ لأنه إذا أحاط بهم علماً لم تصعب عليه إعادتهم وحشرهم. [ابن جزي:١/٤٥١]</p><p>السؤال: ما مناسبة مجيء قوله تعالى: <span class="qpc-hafs">﴿وإن ربك هو يحشرهم﴾</span> بعد قوله: <span class="qpc-hafs">﴿ولقد علمنا المستقدمين منكم﴾</span>؟</p><p>٤- <span class="qpc-hafs">﴿وَلَقَدْ خَلَقْنَا ٱلْإِنسَٰنَ مِن صَلْصَٰلٍ مِّنْ حَمَإٍ مَّسْنُونٍ (٢٦) وَٱلْجَآنَّ خَلَقْنَٰهُ مِن قَبْلُ مِن نَّارِ ٱلسَّمُومِ﴾</span></p><p>والمقصود من الآية: التنبيه على شرف آدم عليه السلام وطيب عنصره. [ابن كثير:٢/٥٣١]</p><p>السؤال: لماذا قُرِنَ بين خلق الإنسان وخلق الجان؟</p><p>٥- <span class="qpc-hafs">﴿فَإِذَا سَوَّيْتُهُۥ وَنَفَخْتُ فِيهِ مِن رُّوحِى فَقَعُوا۟ لَهُۥ سَٰجِدِينَ﴾</span></p><p>وأمر الملائكة السجود لا ينافي تحريم السجود في الإسلام لغير الله من وجوه: أحدها: أن ذلك المنع لسدّ ذريعة الإشراك، والملائكة معصومون من تطرّق ذلك إليهم. وثانيها: أن شريعة الإسلام امتازت بنهاية مبالغ الحق والصلاح، فجاءت بما لم تجئ به الشرائع السالفة؛ لأن الله أراد بلوغ أتباعها أوج الكمال في المدارك. وثالثها: أن هذا إخبار عن أحوال العالم العلوي، و لا تقاس أحكامه على تكاليف عالم الدنيا. [ابن عاشور:١٤/٤٥]</p><p>السؤال: أمر الملائكة بالسجود لا ينافي تحريم السجود لغير الله تعالى في الإسلام من وجوه، اذكرها.</p><p>٦- <span class="qpc-hafs">﴿فَإِذَا سَوَّيْتُهُۥ وَنَفَخْتُ فِيهِ مِن رُّوحِى فَقَعُوا۟ لَهُۥ سَٰجِدِينَ﴾</span></p><p>وإن كان مخلوقا من طين فقد حصل له بنفخ الروح المقدسة فيه ما شرف به؛ فلهذا قال: <span class="qpc-hafs">﴿فإذا سويته ونفخت فيه من روحي فقعوا له ساجدين﴾</span>، فعلق السجود بأن ينفخ فيه من روحه، فالموجب للتفضيل هذا المعنى الشريف الذي ليس لإبليس مثله. [ابن تيمية:٤/١٢٥]</p><p>السؤال: بين وجه تكريم آدم- عليه السلام- على غيره من خلال الآية.</p><p>٧- <span class="qpc-hafs">﴿فَسَجَدَ ٱلْمَلَٰٓئِكَةُ كُلُّهُمْ أَجْمَعُونَ (٣٠) إِلَّآ إِبْلِيسَ أَبَىٰٓ أَن يَكُونَ مَعَ ٱلسَّٰجِدِينَ﴾</span></p><p>يذكر تعالى نعمته وإحسانه على أبينا آدم عليه السلام، وما جرى من عدوه إبليس، وفي ضمن ذلك التحذير لنا من شره وفتنته. [السعدي:٤٣١. ]</p><p>السؤال: ما المقصد من تفصيل قصة خلق آدم وموقف إبليس؟</p><h3>التوجيهات</h3><p>١- تأمل في الكواكب ونجوم السماء؛ فإن الله قد جعلها آية وزينة للناظرين، <span class="qpc-hafs">﴿وَلَقَدْ جَعَلْنَا فِى ٱلسَّمَآءِ بُرُوجًا وَزَيَّنَّٰهَا لِلنَّٰظِرِينَ﴾</span></p><p>٢- تأمل في الأرض وانبساطها، وما فيها من أرزاق، <span class="qpc-hafs">﴿وَٱلْأَرْضَ مَدَدْنَٰهَا وَأَلْقَيْنَا فِيهَا رَوَٰسِىَ وَأَنۢبَتْنَا فِيهَا مِن كُلِّ شَىْءٍ مَّوْزُونٍ﴾</span></p><p>٣- لا تحزن على قلة رزقك؛ فإن الله أعلم بمصلحتك منك، وارض بما قدره الله لك، <span class="qpc-hafs">﴿ۥ وَمَا نُنَزِّلُهُۥٓ إِلَّا بِقَدَرٍ مَّعْلُومٍ﴾</span></p><h3>العمل بالآيات</h3><p>١- تصدّق على محتاج, أو لمؤسسة تطوعية, ولا تخش من ذي العرش إقلالاً, <span class="qpc-hafs">﴿وَإِن مِّن شَىْءٍ إِلَّا عِندَنَا خَزَآئِنُهُۥ وَمَا نُنَزِّلُهُۥٓ إِلَّا بِقَدَرٍ مَّعْلُومٍ﴾</span></p><p>٢- اسبق غيرك إلى عبـادة من العبادات؛ فإن المتقدم أسبق إلى الجنة، <span class="qpc-hafs">﴿وَلَقَدْ عَلِمْنَا ٱلْمُسْتَقْدِمِينَ مِنكُمْ وَلَقَدْ عَلِمْنَا ٱلْمُسْتَـْٔخِرِينَ﴾</span></p><p>٣- اقرأ قصة آدم وإبليس من كتب التفسير، ثم تأمل النقاط التي استغلها ابليس في التأثير على آدم, <span class="qpc-hafs">﴿وَإِذْ قَالَ رَبُّكَ لِلْمَلَٰٓئِكَةِ إِنِّى خَٰلِقٌۢ بَشَرًا مِّن صَلْصَٰلٍ مِّنْ حَمَإٍ مَّسْنُونٍ﴾</span></p><h3>معاني الكلمات</h3><p><span class="qpc-hafs">﴿بُرُوجًا﴾</span> مَنَازِلَ لِلْكَوَاكِبِ تَنْزِلُ فِيهَا.</p><p><span class="qpc-hafs">﴿رَجِيمٍ﴾</span> مَطْرُودٍ مِنْ رَحْمَةِ اللهِ.</p><p><span class="qpc-hafs">﴿اسْتَرَقَ﴾</span> اخْتَلَسَ الوَحْيَ مِنَ السَّمَاءِ الدُّنْيَا.</p><p><span class="qpc-hafs">﴿فَأَتْبَعَهُ﴾</span> فَأَدْرَكَهُ.</p><p><span class="qpc-hafs">﴿شِهَابٌ﴾</span> كَوْكَبٌ مُضِيءٌ مُحْرِقٌ.</p><p><span class="qpc-hafs">﴿رَوَاسِيَ﴾</span> رَاسِيَةً تُثَبِّتُهَا.</p><p><span class="qpc-hafs">﴿مَعَايِشَ﴾</span> مَا تَعِيشُونَ بِهِ مِنْ مَعَادِنَ، وَحِجَارَةٍ، وَنَبَاتٍ.</p><p><span class="qpc-hafs">﴿لَوَاقِحَ﴾</span> تَلْقَحُ السَّحَابَ؛ فَيَمْتَلِئُ بِالمَاءِ.</p><p><span class="qpc-hafs">﴿صَلْصَالٍ﴾</span> طِينٍ يَابِسٍ يُسْمَعُ لَهُ صَوْتٌ إِذَا نُقِرَ.</p><p><span class="qpc-hafs">﴿حَمَإٍ﴾</span> طِينٍ أَسْوَدَ.</p><p><span class="qpc-hafs">﴿مَسْنُونٍ﴾</span> مُتَغَيِّرٍ لَوْنُهُ وَرِيحُهُ.</p><p><span class="qpc-hafs">﴿نَارِ السَّمُومِ﴾</span> نَارٍ شَدِيدَةِ الحَرَارَةِ لاَ دُخَانَ لَهَا.</p></div>"
