tafsir[16]{c,v,t}:
  15,16,"

الوقفات التدبرية

١- <q>﴿وَلَقَدْ جَعَلْنَا فِى ٱلسَّمَآءِ بُرُوجًا وَزَيَّنَّٰهَا لِلنَّٰظِرِينَ﴾</q>

وهذا مما يدعو الناظرين إلى التأمل فيها، والنظر في معانيها، والاستدلال بها على باريها. [السعدي:٤٣٠]

السؤال: النجوم والبروج التي في السماء كيف تزيد في إيمان المؤمن؟

٢- <q>﴿وَٱلْأَرْضَ مَدَدْنَٰهَا﴾</q>

أي: وسعناها سَعَةً يتمكن الآدميون والحيوانات كلها على الامتداد بأرجائها، والتناول من أرزاقها، والسكون في نواحيها. [السعدي:٤٣٠]

السؤال: من إساءة الظن بالله أن يعتقد الإنسان أن أرزاق الأرض لن تكفي الناس في المستقبل، وضح هذا من الآية .

٣- <q>﴿وَلَقَدْ عَلِمْنَا ٱلْمُسْتَقْدِمِينَ مِنكُمْ وَلَقَدْ عَلِمْنَا ٱلْمُسْتَـْٔخِرِينَ (٢٤) وَإِنَّ رَبَّكَ هُوَ يَحْشُرُهُمْ ۚ إِنَّهُۥ حَكِيمٌ عَلِيمٌ﴾</q>

<q>﴿ولقد علمنا المستقدمين منكم﴾</q> يعني: الأولين والآخرين من الناس، وذكر ذلك على وجه الاستدلال على الحشر الذي ذكر بعد ذلك في قوله: <q>﴿وإن ربك هو يحشرهم إنه حكيم عليم﴾</q>؛ لأنه إذا أحاط بهم علماً لم تصعب عليه إعادتهم وحشرهم. [ابن جزي:١/٤٥١]

السؤال: ما مناسبة مجيء قوله تعالى: <q>﴿وإن ربك هو يحشرهم﴾</q> بعد قوله: <q>﴿ولقد علمنا المستقدمين منكم﴾</q>؟

٤- <q>﴿وَلَقَدْ خَلَقْنَا ٱلْإِنسَٰنَ مِن صَلْصَٰلٍ مِّنْ حَمَإٍ مَّسْنُونٍ (٢٦) وَٱلْجَآنَّ خَلَقْنَٰهُ مِن قَبْلُ مِن نَّارِ ٱلسَّمُومِ﴾</q>

والمقصود من الآية: التنبيه على شرف آدم عليه السلام وطيب عنصره. [ابن كثير:٢/٥٣١]

السؤال: لماذا قُرِنَ بين خلق الإنسان وخلق الجان؟

٥- <q>﴿فَإِذَا سَوَّيْتُهُۥ وَنَفَخْتُ فِيهِ مِن رُّوحِى فَقَعُوا۟ لَهُۥ سَٰجِدِينَ﴾</q>

وأمر الملائكة السجود لا ينافي تحريم السجود في الإسلام لغير الله من وجوه: أحدها: أن ذلك المنع لسدّ ذريعة الإشراك، والملائكة معصومون من تطرّق ذلك إليهم. وثانيها: أن شريعة الإسلام امتازت بنهاية مبالغ الحق والصلاح، فجاءت بما لم تجئ به الشرائع السالفة؛ لأن الله أراد بلوغ أتباعها أوج الكمال في المدارك. وثالثها: أن هذا إخبار عن أحوال العالم العلوي، و لا تقاس أحكامه على تكاليف عالم الدنيا. [ابن عاشور:١٤/٤٥]

السؤال: أمر الملائكة بالسجود لا ينافي تحريم السجود لغير الله تعالى في الإسلام من وجوه، اذكرها.

٦- <q>﴿فَإِذَا سَوَّيْتُهُۥ وَنَفَخْتُ فِيهِ مِن رُّوحِى فَقَعُوا۟ لَهُۥ سَٰجِدِينَ﴾</q>

وإن كان مخلوقا من طين فقد حصل له بنفخ الروح المقدسة فيه ما شرف به؛ فلهذا قال: <q>﴿فإذا سويته ونفخت فيه من روحي فقعوا له ساجدين﴾</q>، فعلق السجود بأن ينفخ فيه من روحه، فالموجب للتفضيل هذا المعنى الشريف الذي ليس لإبليس مثله. [ابن تيمية:٤/١٢٥]

السؤال: بين وجه تكريم آدم- عليه السلام- على غيره من خلال الآية.

٧- <q>﴿فَسَجَدَ ٱلْمَلَٰٓئِكَةُ كُلُّهُمْ أَجْمَعُونَ (٣٠) إِلَّآ إِبْلِيسَ أَبَىٰٓ أَن يَكُونَ مَعَ ٱلسَّٰجِدِينَ﴾</q>

يذكر تعالى نعمته وإحسانه على أبينا آدم عليه السلام، وما جرى من عدوه إبليس، وفي ضمن ذلك التحذير لنا من شره وفتنته. [السعدي:٤٣١. ]

السؤال: ما المقصد من تفصيل قصة خلق آدم وموقف إبليس؟

التوجيهات

١- تأمل في الكواكب ونجوم السماء؛ فإن الله قد جعلها آية وزينة للناظرين، <q>﴿وَلَقَدْ جَعَلْنَا فِى ٱلسَّمَآءِ بُرُوجًا وَزَيَّنَّٰهَا لِلنَّٰظِرِينَ﴾</q>

٢- تأمل في الأرض وانبساطها، وما فيها من أرزاق، <q>﴿وَٱلْأَرْضَ مَدَدْنَٰهَا وَأَلْقَيْنَا فِيهَا رَوَٰسِىَ وَأَنۢبَتْنَا فِيهَا مِن كُلِّ شَىْءٍ مَّوْزُونٍ﴾</q>

٣- لا تحزن على قلة رزقك؛ فإن الله أعلم بمصلحتك منك، وارض بما قدره الله لك، <q>﴿ۥ وَمَا نُنَزِّلُهُۥٓ إِلَّا بِقَدَرٍ مَّعْلُومٍ﴾</q>

العمل بالآيات

١- تصدّق على محتاج, أو لمؤسسة تطوعية, ولا تخش من ذي العرش إقلالاً, <q>﴿وَإِن مِّن شَىْءٍ إِلَّا عِندَنَا خَزَآئِنُهُۥ وَمَا نُنَزِّلُهُۥٓ إِلَّا بِقَدَرٍ مَّعْلُومٍ﴾</q>

٢- اسبق غيرك إلى عبـادة من العبادات؛ فإن المتقدم أسبق إلى الجنة، <q>﴿وَلَقَدْ عَلِمْنَا ٱلْمُسْتَقْدِمِينَ مِنكُمْ وَلَقَدْ عَلِمْنَا ٱلْمُسْتَـْٔخِرِينَ﴾</q>

٣- اقرأ قصة آدم وإبليس من كتب التفسير، ثم تأمل النقاط التي استغلها ابليس في التأثير على آدم, <q>﴿وَإِذْ قَالَ رَبُّكَ لِلْمَلَٰٓئِكَةِ إِنِّى خَٰلِقٌۢ بَشَرًا مِّن صَلْصَٰلٍ مِّنْ حَمَإٍ مَّسْنُونٍ﴾</q>

معاني الكلمات

<q>﴿بُرُوجًا﴾</q> مَنَازِلَ لِلْكَوَاكِبِ تَنْزِلُ فِيهَا.

<q>﴿رَجِيمٍ﴾</q> مَطْرُودٍ مِنْ رَحْمَةِ اللهِ.

<q>﴿اسْتَرَقَ﴾</q> اخْتَلَسَ الوَحْيَ مِنَ السَّمَاءِ الدُّنْيَا.

<q>﴿فَأَتْبَعَهُ﴾</q> فَأَدْرَكَهُ.

<q>﴿شِهَابٌ﴾</q> كَوْكَبٌ مُضِيءٌ مُحْرِقٌ.

<q>﴿رَوَاسِيَ﴾</q> رَاسِيَةً تُثَبِّتُهَا.

<q>﴿مَعَايِشَ﴾</q> مَا تَعِيشُونَ بِهِ مِنْ مَعَادِنَ، وَحِجَارَةٍ، وَنَبَاتٍ.

<q>﴿لَوَاقِحَ﴾</q> تَلْقَحُ السَّحَابَ؛ فَيَمْتَلِئُ بِالمَاءِ.

<q>﴿صَلْصَالٍ﴾</q> طِينٍ يَابِسٍ يُسْمَعُ لَهُ صَوْتٌ إِذَا نُقِرَ.

<q>﴿حَمَإٍ﴾</q> طِينٍ أَسْوَدَ.

<q>﴿مَسْنُونٍ﴾</q> مُتَغَيِّرٍ لَوْنُهُ وَرِيحُهُ.

<q>﴿نَارِ السَّمُومِ﴾</q> نَارٍ شَدِيدَةِ الحَرَارَةِ لاَ دُخَانَ لَهَا.

