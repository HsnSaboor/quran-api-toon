quran[4]{c,v,t}:
  7,156,"<div class=ar lang=ar><h3>الوقفات التدبرية</h3><p>١- <span class="qpc-hafs">﴿وَرَحْمَتِى وَسِعَتْ كُلَّ شَىْءٍ﴾</span></p><p>عمت كل شيء؛ قال الحسن وقتادة: وسعت رحمته في الدنيا البر والفاجر، وهي يوم القيامة للمتقين خاصة. [البغوي:٢/١٥٧]</p><p>السؤال: رحمة الله لمن تكون في الدنيا؟ ولمن تكون في الآخر؟</p><p>٢- <span class="qpc-hafs">﴿ۚ فَسَأَكْتُبُهَا لِلَّذِينَ يَتَّقُونَ وَيُؤْتُونَ ٱلزَّكَوٰةَ وَٱلَّذِينَ هُم بِـَٔايَٰتِنَا يُؤْمِنُونَ﴾</span></p><p>أي: يؤمنون بجميع الكتب والأنبياء، وليس ذلك لغير هذه الأمّة. [ابن جزي:١/٣١٩]</p><p>السؤال: لم كانت هذه الآية بشارة لهذه الأمة دون غيرها؟</p><p>٣- <span class="qpc-hafs">﴿وَٱلَّذِينَ هُم بِـَٔايَٰتِنَا يُؤْمِنُونَ﴾</span></p><p>ومن تمام الإيمان بآيات الله: معرفة معناها، والعمل بمقتضاها، ومن ذلك: اتباع النبي-صلى الله عليه وسلم- ظاهراً وباطناً، في أصول الدين وفروعه. [السعدي:٣٠٥]</p><p>السؤال: ما علامات الإيمان بآيات الله؟</p><p>٤- <span class="qpc-hafs">﴿ٱلَّذِينَ يَتَّبِعُونَ ٱلرَّسُولَ ٱلنَّبِىَّ ٱلْأُمِّىَّ ٱلَّذِى يَجِدُونَهُۥ مَكْتُوبًا عِندَهُمْ﴾</span></p><p>فإن أميته لم تكن من جهة فقد العلم والقراءة عن ظهر قلب؛ فإنه إمام الأئمة في هذا، وإنما كان من جهة أنه لا يكتب ولا يقرأ مكتوبا. [ابن تيمية:٣/٢١٠]</p><p>السؤال: من أي جهة كانت أمية النبي صلى الله عليه وسلم؟</p><p>٥- <span class="qpc-hafs">﴿وَيَضَعُ عَنْهُمْ إِصْرَهُمْ وَٱلْأَغْلَٰلَ ٱلَّتِى كَانَتْ عَلَيْهِمْ﴾</span></p><p>الإصر: الثقل ... فإن بني إسرائيل قد كان أخذ عليهم عهداً أن يقوموا بأعمال ثقال؛ فوضع عنهم بمحمد ﷺ ذلك العهد، وثقل تلك الأعمال؛ كغسل البول، وتحليل الغنائم، ومجالسة الحائض، ومؤاكلتها. [القرطبي:٩/٣٥٦]</p><p>السؤال: بين عظيم رحمة الله تعالى بهذه الأمة حيث وضع عنها الآصار والأثقال؟</p><p>٦- <span class="qpc-hafs">﴿فَٱلَّذِينَ ءَامَنُوا۟ بِهِۦ وَعَزَّرُوهُ وَنَصَرُوهُ وَٱتَّبَعُوا۟ ٱلنُّورَ ٱلَّذِىٓ أُنزِلَ مَعَهُۥٓ ۙ أُو۟لَٰٓئِكَ هُمُ ٱلْمُفْلِحُونَ﴾</span></p><p><span class="qpc-hafs">﴿فالذين آمنوا به﴾</span> أي: بمحمد ﷺ، <span class="qpc-hafs">﴿وعزروه﴾</span>: وقَّروه، <span class="qpc-hafs">﴿ونصروه﴾</span>: على الأعداء، <span class="qpc-hafs">﴿واتبعوا النور الذي أنزل معه﴾</span>: يعني: القرآن، <span class="qpc-hafs">﴿أولئك هم المفلحون﴾</span>. [البغوي:٢/٣١٥٩. ]</p><p>السؤال: ما صفات المفلحين في كتاب الله تعالى؟</p><p>٧- <span class="qpc-hafs">﴿وَمِن قَوْمِ مُوسَىٰٓ أُمَّةٌ يَهْدُونَ بِٱلْحَقِّ وَبِهِۦ يَعْدِلُونَ﴾</span></p><p>وكأن الإتيان بهذه الآية الكريمة فيه نوع احتراز مما تقدم؛ فإنه تعالى ذكر فيما تقدم جملةً من معايب بني إسرائيل المنافية للكمال، المناقضة للهداية، فرُبَّمَا توهم متوهم أن هذا يعم جميعَهم، فذكر تعالى أن منهم طائفةً مستقيمة، هاديةً مَهْدِيَّةً. [السعدي:٣٠٦]</p><p>السؤال: ما وجه الإتيان بمدح طائفة من قوم موسى في سياق الآيات التي تذمهم؟</p><h3>التوجيهات</h3><p>١- تقوى الله، وأداء الزكاة والصدقات سبب لحصول الرحمة، <span class="qpc-hafs">﴿فَسَأَكْتُبُهَا لِلَّذِينَ يَتَّقُونَ وَيُؤْتُونَ ٱلزَّكَوٰةَ وَٱلَّذِينَ هُم بِـَٔايَٰتِنَا يُؤْمِنُونَ﴾</span></p><p>٢- ما أحله الله لك فهو الطيب المناسب لك، وما حرمه عيك ففيه المفاسد العاجلة والآجلة، <span class="qpc-hafs">﴿وَيُحِلُّ لَهُمُ ٱلطَّيِّبَٰتِ وَيُحَرِّمُ عَلَيْهِمُ ٱلْخَبَٰٓئِثَ﴾</span></p><p>٣- من أراد الهداية العامة والخاصة، العاجلة والآجلة، فليلزم اتباع الحبيب ﷺ بالأدلة الصحيحة، <span class="qpc-hafs">﴿وَٱتَّبِعُوهُ لَعَلَّكُمْ تَهْتَدُونَ﴾</span></p><h3>العمل بالآيات</h3><p>١- اقرأ كتابا، أو مقالا تتعرف فيه على شمائل النبي ﷺ وصفاته, <span class="qpc-hafs">﴿ٱلَّذِينَ يَتَّبِعُونَ ٱلرَّسُولَ ٱلنَّبِىَّ ٱلْأُمِّىَّ ٱلَّذِى يَجِدُونَهُۥ مَكْتُوبًا عِندَهُمْ فِى ٱلتَّوْرَىٰةِ وَٱلْإِنجِيلِ﴾</span></p><p>٢- تذكر سنة كنت غافلا عنها من سنن النبي ﷺ، وطبقها, <span class="qpc-hafs">﴿ٱلَّذِينَ يَتَّبِعُونَ ٱلرَّسُولَ ٱلنَّبِىَّ ٱلْأُمِّىَّ﴾</span></p><p>٣- درب نفسك اليوم على الأمر بالمعروف والنهي عن المنكر، ولو على صديقك أو أحد من أهلك، <span class="qpc-hafs">﴿يَأْمُرُهُم بِٱلْمَعْرُوفِ وَيَنْهَىٰهُمْ عَنِ ٱلْمُنكَرِ﴾</span></p><h3>معاني الكلمات</h3><p><span class="qpc-hafs">﴿هُدْنَا﴾</span> رَجَعْنَا تَائِبِينَ إِلَيْكَ.</p><p><span class="qpc-hafs">﴿الأُمِّيَّ﴾</span> الَّذِي لاَ يَقْرَأُ، وَلاَ يَكْتُبُ.</p><p><span class="qpc-hafs">﴿إِصْرَهُمْ﴾</span> مَا كُلِّفُوهُ مِنَ الأَعْمَالِ الشَّاقَّةِ.</p><p><span class="qpc-hafs">﴿وَعَزَّرُوهُ﴾</span> وَقَّرُوهُ، وَعَظَّمُوهُ.</p></div>"
  7,157,"7:156"
  7,158,"7:156"
  7,159,"7:156"