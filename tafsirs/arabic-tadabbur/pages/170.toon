quran[4]{c,v,t}:
  7,156,"

الوقفات التدبرية

١- <q>﴿وَرَحْمَتِى وَسِعَتْ كُلَّ شَىْءٍ﴾</q>

عمت كل شيء؛ قال الحسن وقتادة: وسعت رحمته في الدنيا البر والفاجر، وهي يوم القيامة للمتقين خاصة. [البغوي:٢/١٥٧]

السؤال: رحمة الله لمن تكون في الدنيا؟ ولمن تكون في الآخر؟

٢- <q>﴿ۚ فَسَأَكْتُبُهَا لِلَّذِينَ يَتَّقُونَ وَيُؤْتُونَ ٱلزَّكَوٰةَ وَٱلَّذِينَ هُم بِـَٔايَٰتِنَا يُؤْمِنُونَ﴾</q>

أي: يؤمنون بجميع الكتب والأنبياء، وليس ذلك لغير هذه الأمّة. [ابن جزي:١/٣١٩]

السؤال: لم كانت هذه الآية بشارة لهذه الأمة دون غيرها؟

٣- <q>﴿وَٱلَّذِينَ هُم بِـَٔايَٰتِنَا يُؤْمِنُونَ﴾</q>

ومن تمام الإيمان بآيات الله: معرفة معناها، والعمل بمقتضاها، ومن ذلك: اتباع النبي-صلى الله عليه وسلم- ظاهراً وباطناً، في أصول الدين وفروعه. [السعدي:٣٠٥]

السؤال: ما علامات الإيمان بآيات الله؟

٤- <q>﴿ٱلَّذِينَ يَتَّبِعُونَ ٱلرَّسُولَ ٱلنَّبِىَّ ٱلْأُمِّىَّ ٱلَّذِى يَجِدُونَهُۥ مَكْتُوبًا عِندَهُمْ﴾</q>

فإن أميته لم تكن من جهة فقد العلم والقراءة عن ظهر قلب؛ فإنه إمام الأئمة في هذا، وإنما كان من جهة أنه لا يكتب ولا يقرأ مكتوبا. [ابن تيمية:٣/٢١٠]

السؤال: من أي جهة كانت أمية النبي صلى الله عليه وسلم؟

٥- <q>﴿وَيَضَعُ عَنْهُمْ إِصْرَهُمْ وَٱلْأَغْلَٰلَ ٱلَّتِى كَانَتْ عَلَيْهِمْ﴾</q>

الإصر: الثقل ... فإن بني إسرائيل قد كان أخذ عليهم عهداً أن يقوموا بأعمال ثقال؛ فوضع عنهم بمحمد ﷺ ذلك العهد، وثقل تلك الأعمال؛ كغسل البول، وتحليل الغنائم، ومجالسة الحائض، ومؤاكلتها. [القرطبي:٩/٣٥٦]

السؤال: بين عظيم رحمة الله تعالى بهذه الأمة حيث وضع عنها الآصار والأثقال؟

٦- <q>﴿فَٱلَّذِينَ ءَامَنُوا۟ بِهِۦ وَعَزَّرُوهُ وَنَصَرُوهُ وَٱتَّبَعُوا۟ ٱلنُّورَ ٱلَّذِىٓ أُنزِلَ مَعَهُۥٓ ۙ أُو۟لَٰٓئِكَ هُمُ ٱلْمُفْلِحُونَ﴾</q>

<q>﴿فالذين آمنوا به﴾</q> أي: بمحمد ﷺ، <q>﴿وعزروه﴾</q>: وقَّروه، <q>﴿ونصروه﴾</q>: على الأعداء، <q>﴿واتبعوا النور الذي أنزل معه﴾</q>: يعني: القرآن، <q>﴿أولئك هم المفلحون﴾</q>. [البغوي:٢/٣١٥٩. ]

السؤال: ما صفات المفلحين في كتاب الله تعالى؟

٧- <q>﴿وَمِن قَوْمِ مُوسَىٰٓ أُمَّةٌ يَهْدُونَ بِٱلْحَقِّ وَبِهِۦ يَعْدِلُونَ﴾</q>

وكأن الإتيان بهذه الآية الكريمة فيه نوع احتراز مما تقدم؛ فإنه تعالى ذكر فيما تقدم جملةً من معايب بني إسرائيل المنافية للكمال، المناقضة للهداية، فرُبَّمَا توهم متوهم أن هذا يعم جميعَهم، فذكر تعالى أن منهم طائفةً مستقيمة، هاديةً مَهْدِيَّةً. [السعدي:٣٠٦]

السؤال: ما وجه الإتيان بمدح طائفة من قوم موسى في سياق الآيات التي تذمهم؟

التوجيهات

١- تقوى الله، وأداء الزكاة والصدقات سبب لحصول الرحمة، <q>﴿فَسَأَكْتُبُهَا لِلَّذِينَ يَتَّقُونَ وَيُؤْتُونَ ٱلزَّكَوٰةَ وَٱلَّذِينَ هُم بِـَٔايَٰتِنَا يُؤْمِنُونَ﴾</q>

٢- ما أحله الله لك فهو الطيب المناسب لك، وما حرمه عيك ففيه المفاسد العاجلة والآجلة، <q>﴿وَيُحِلُّ لَهُمُ ٱلطَّيِّبَٰتِ وَيُحَرِّمُ عَلَيْهِمُ ٱلْخَبَٰٓئِثَ﴾</q>

٣- من أراد الهداية العامة والخاصة، العاجلة والآجلة، فليلزم اتباع الحبيب ﷺ بالأدلة الصحيحة، <q>﴿وَٱتَّبِعُوهُ لَعَلَّكُمْ تَهْتَدُونَ﴾</q>

العمل بالآيات

١- اقرأ كتابا، أو مقالا تتعرف فيه على شمائل النبي ﷺ وصفاته, <q>﴿ٱلَّذِينَ يَتَّبِعُونَ ٱلرَّسُولَ ٱلنَّبِىَّ ٱلْأُمِّىَّ ٱلَّذِى يَجِدُونَهُۥ مَكْتُوبًا عِندَهُمْ فِى ٱلتَّوْرَىٰةِ وَٱلْإِنجِيلِ﴾</q>

٢- تذكر سنة كنت غافلا عنها من سنن النبي ﷺ، وطبقها, <q>﴿ٱلَّذِينَ يَتَّبِعُونَ ٱلرَّسُولَ ٱلنَّبِىَّ ٱلْأُمِّىَّ﴾</q>

٣- درب نفسك اليوم على الأمر بالمعروف والنهي عن المنكر، ولو على صديقك أو أحد من أهلك، <q>﴿يَأْمُرُهُم بِٱلْمَعْرُوفِ وَيَنْهَىٰهُمْ عَنِ ٱلْمُنكَرِ﴾</q>

معاني الكلمات

<q>﴿هُدْنَا﴾</q> رَجَعْنَا تَائِبِينَ إِلَيْكَ.

<q>﴿الأُمِّيَّ﴾</q> الَّذِي لاَ يَقْرَأُ، وَلاَ يَكْتُبُ.

<q>﴿إِصْرَهُمْ﴾</q> مَا كُلِّفُوهُ مِنَ الأَعْمَالِ الشَّاقَّةِ.

<q>﴿وَعَزَّرُوهُ﴾</q> وَقَّرُوهُ، وَعَظَّمُوهُ.

