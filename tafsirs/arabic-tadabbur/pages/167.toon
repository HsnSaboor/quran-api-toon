quran[6]{c,v,t}:
  7,138,"

الوقفات التدبرية

١- <q>﴿وَجَٰوَزْنَا بِبَنِىٓ إِسْرَٰٓءِيلَ ٱلْبَحْرَ فَأَتَوْا۟ عَلَىٰ قَوْمٍ يَعْكُفُونَ عَلَىٰٓ أَصْنَامٍ لَّهُمْ ۚ قَالُوا۟ يَٰمُوسَى ٱجْعَل لَّنَآ إِلَٰهًا كَمَا لَهُمْ ءَالِهَةٌ ۚ قَالَ إِنَّكُمْ قَوْمٌ تَجْهَلُونَ﴾</q>

<q>﴿إِنَّكُم قَومٌ تَجهَلُونَ﴾</q>: وأي جهل أعظم من جهل من جهل ربه وخالقه، وأراد أن يسوِّي به غيره ممن لا يملك نفعا ولا ضرا، ولا موتا ولا حياة ولا نشورًا؟! [السعدي:٣٠٢]

السؤال: ما أعظم الجهل؟ ولماذا؟

٢- <q>﴿قَالُوا۟ يَٰمُوسَى ٱجْعَل لَّنَآ إِلَٰهًا كَمَا لَهُمْ ءَالِهَةٌ ۚ قَالَ إِنَّكُمْ قَوْمٌ تَجْهَلُونَ﴾</q>

وكان وصف موسى إياهم بالجهالة مؤكَّدًا؛ لما دلت عليه الجملة الاسمية من كون الجهالة صفة ثابتة فيهم، وراسخة من نفوسهم، ولولا ذلك لكان لهم في بادي النظر زاجر عن مثل هذا السؤال. [ابن عاشور:٩/٨٢]

السؤال: كيف دلت الآية الكريمة على أن الجهل قد يوصل إلى الشرك؟

٣- <q>﴿قَالَ أَغَيْرَ ٱللَّهِ أَبْغِيكُمْ إِلَٰهًا وَهُوَ فَضَّلَكُمْ عَلَى ٱلْعَٰلَمِينَ﴾</q>

والمراد بالعالمين: أمم عصرهم. وتفضيلهم عليهم بأنهم ذرية رسول وأنبياء، وبأن منهم رسلا وأنبياء، وبأن الله هداهم إلى التوحيد والخلاص من دين فرعون بعد أن تخبطوا فيه، وبأنه جعلهم أحرارا بعد أن كانوا عبيدا، وساقهم إلى امتلاك أرض مباركة، وأيدهم بنصره وآياته، وبعث فيهم رسولا ليقيم لهم الشريعة، وهذه الفضائل لم تجتمع لأمة غيرهم يومئذ. [ابن عاشور:٩/٨٤]

السؤال: ما المراد بالعالمين في الآية الكريمة؟ وبما فضل الله تعالى بني إسرائيل على العالمين؟

٤- <q>﴿وَقَالَ مُوسَىٰ لِأَخِيهِ هَٰرُونَ ٱخْلُفْنِى فِى قَوْمِى وَأَصْلِحْ وَلَا تَتَّبِعْ سَبِيلَ ٱلْمُفْسِدِينَ﴾</q>

ولما ذهب موسى إلى ميقات ربه قال لهارون موصيا له على بني إسرائيل من حرصه عليهم وشفقته: <q>﴿اخلفني في قومي﴾</q> أي: كن خليفتي فيهم، واعمل فيهم بما كنت أعمل، <q>﴿وأصلح﴾</q> أي: اتبع طريق الصلاح، <q>﴿ولا تتبع سبيل المفسدين﴾</q>: وهم الذين يعملون بالمعاصي. [السعدي:٣٠٢]

السؤال: الأنبياء أكثر الناس شفقة وحرصاً على أقوامهم، وضِّح ذلك من خلال الآية؟

٥- <q>﴿وَقَالَ مُوسَىٰ لِأَخِيهِ هَٰرُونَ ٱخْلُفْنِى فِى قَوْمِى وَأَصْلِحْ وَلَا تَتَّبِعْ سَبِيلَ ٱلْمُفْسِدِينَ﴾</q>

استخلف موسى على بني إسرائيل أخاه هارون، ووصَّاه بالإصلاح وعدم الإفساد، هذا تنبيه وتذكير، وإلا فهارون-عليه السلام- نبي شريف كريم على الله، له وجاهة وجلالة. [ابن كثير:٢/٢٣٤]

السؤال: كل الصالحين بحاجة إلى التذكير حتى الأنبياء -عليهم السلام- وضح ذلك؟

٦- <q>﴿وَلَٰكِنِ ٱنظُرْ إِلَى ٱلْجَبَلِ فَإِنِ ٱسْتَقَرَّ مَكَانَهُۥ فَسَوْفَ تَرَىٰنِى ۚ فَلَمَّا تَجَلَّىٰ رَبُّهُۥ لِلْجَبَلِ جَعَلَهُۥ دَكًّا وَخَرَّ مُوسَىٰ صَعِقًا﴾</q>

فإنه أكبر منك، وأشد خلقا، <q>﴿فلما تجلى ربه للجبل﴾</q> فنظر إلى الجبل لا يتمالك، وأقبل الجبل فدك على أوله، ورأى موسى ما يصنع الجبل؛ فخر صعقا. [ابن كثير:٢/٢٣٥]

السؤال: بينت الآية شيئا من عظمة الله، وضح ذلك؟

٧- <q>﴿ۚ فَلَمَّآ أَفَاقَ قَالَ سُبْحَٰنَكَ تُبْتُ إِلَيْكَ وَأَنَا۠ أَوَّلُ ٱلْمُؤْمِنِينَ﴾</q>

قيل: قال على جهة الإنابة إلى الله والخشوع له عند ظهور الآيات، وأجمعت الأمة على أن هذه التوبة ما كانت عن معصية؛ فإن الأنبياء معصومون. [القرطبي:١٠/٤٣٩]

السؤال: هل الاستغفار لا يكون إلا من معصية؟

التوجيهات

١- أشد الجهل: الجهل بالتوحيد، <q>﴿وَجَٰوَزْنَا بِبَنِىٓ إِسْرَٰٓءِيلَ ٱلْبَحْرَ فَأَتَوْا۟ عَلَىٰ قَوْمٍ يَعْكُفُونَ عَلَىٰٓ أَصْنَامٍ لَّهُمْ ۚ قَالُوا۟ يَٰمُوسَى ٱجْعَل لَّنَآ إِلَٰهًا كَمَا لَهُمْ ءَالِهَةٌ ۚ قَالَ إِنَّكُمْ قَوْمٌ تَجْهَلُونَ﴾</q>

٢- المحافظة على المواعيد أمر محبوب للشارع، مرغب فيه، وهو من سمات الصادقين، <q>﴿وَوَٰعَدْنَا مُوسَىٰ ثَلَٰثِينَ لَيْلَةً وَأَتْمَمْنَٰهَا بِعَشْرٍ فَتَمَّ مِيقَٰتُ رَبِّهِۦٓ أَرْبَعِينَ لَيْلَةً﴾</q>

٣- الإصلاح من سبل الأنبياء، فكن على نهج الأنبياء، ولا تتبع سبيل المفسدين، <q>﴿ۚ وَقَالَ مُوسَىٰ لِأَخِيهِ هَٰرُونَ ٱخْلُفْنِى فِى قَوْمِى وَأَصْلِحْ وَلَا تَتَّبِعْ سَبِيلَ ٱلْمُفْسِدِينَ﴾</q>

العمل بالآيات

١- ألق درسًا، أو أرسل رسالة عن خطر الشرك بالله، وأثره في بطلان العمل, <q>﴿إِنَّ هَٰٓؤُلَآءِ مُتَبَّرٌ مَّا هُمْ فِيهِ وَبَٰطِلٌ مَّا كَانُوا۟ يَعْمَلُونَ﴾</q>

٢- استخدم وسيلة حكيمة في تعليم من يقع في نوع من الشرك ووجِّهْهُ للحق. <q>﴿إِنَّ هَٰٓؤُلَآءِ مُتَبَّرٌ مَّا هُمْ فِيهِ وَبَٰطِلٌ مَّا كَانُوا۟ يَعْمَلُونَ﴾</q>

٣- قل: «سبحان الله وبحمده سبحان الله العظيم» مائة مرة، <q>﴿قَالَ سُبْحَٰنَكَ تُبْتُ إِلَيْكَ﴾</q>

معاني الكلمات

<q>﴿وَجَاوَزْنَا﴾</q> عَبَرْنَا.

<q>﴿يَعْكُفُونَ﴾</q> يُقِيمُونَ عَابِدِينَ.

<q>﴿إِلَهًا﴾</q> صَنَمًا.

<q>﴿مُتَبَّرٌ﴾</q> مُهْلَكٌ.

<q>﴿يَسُومُونَكُمْ﴾</q> يُذِيقُونَكُمْ، وَيُكَلِّفُونَكُمْ.

<q>﴿لِمِيقَاتِنَا﴾</q> فِي الوَقْتِ الَّذِي وَاعَدْنَاهُ فِيهِ.

<q>﴿صَعِقًا﴾</q> مَغْشِيًّا عَلَيْهِ.

