quran[12]{c,v,t}:
  20,114,"

الوقفات التدبرية

١- <q>﴿فَتَعَٰلَى ٱللَّهُ ٱلْمَلِكُ ٱلْحَقُّ﴾</q>

وفي وصفه بالحق إيماء إلى أن مُلك غيره من الـمُتَسَمِّين بالملوك لا يخلو من نقص. [ابن عاشور:١٦/٣١٥]

السؤال: بين باختصار ثلاثة فروق بين ملك الله وملك ملوك الدنيا.

٢- <q>﴿وَلَا تَعْجَلْ بِٱلْقُرْءَانِ مِن قَبْلِ أَن يُقْضَىٰٓ إِلَيْكَ وَحْيُهُۥ ۖ وَقُل رَّبِّ زِدْنِى عِلْمًا﴾</q>

ويؤخذ من هذه الآية الكريمة: الأدب في تلقي العلم، وأن المستمع للعلم ينبغي له أن يتأنَّى ويصبر حتى يفرغ المعلم من كلامه المتصل بعضه ببعض، فإذا فرغ منه سأل إن كان عنده سؤال، ولا يبادر بالسؤال وقطع كلام مُلْقِي العلم؛ فإنه سبب للحرمان. [السعدي:٥١٤. ]

السؤال: ما الأدب الذي يستقيه طالب العلم من هذه الآية؟

٣- <q>﴿وَقُل رَّبِّ زِدْنِى عِلْمًا﴾</q>

كان ابن مسعود- رضي الله عنه- إذا قرأ هذه الآية قال: اللهم زدني علماً وإيماناً ويقيناً. [البغوي:٣/١٤٢]

السؤال: كيف نتدبر هذه الآية ونعمل بها؟

٤- <q>﴿إِنَّ لَكَ أَلَّا تَجُوعَ فِيهَا وَلَا تَعْرَىٰ (١١٨) وَأَنَّكَ لَا تَظْمَؤُا۟ فِيهَا وَلَا تَضْحَىٰ﴾</q>

في قوله: <q>﴿إن لك ألا تجوع فيها ولا تعرى﴾</q>، وقرن بين انتفاء الظمأ وألم الجسم في قوله:وقد قُرن بين انتفاء الجوع واللباس <q>﴿وأنك لا تظمأ فيها ولا تضحى﴾</q> لمناسبة بين الجوع والعَرى في أن الجوع خلوّ باطن الجسم عما يقيه تألمه؛ وذلك هو الطعام، وأن العري خلوّ ظاهر الجسم عما يقيه تألمه، وهو لفح الحر، وقرص البرد. ولمناسبة بين الظمأ وبين حرارة الشمس في أن الأول ألم حرارة الباطن، والثاني ألم حرارة الظاهر. [ابن عاشور:١٦/٣٢٢]

السؤال: لماذا قرن الجوع بالعري، والظمأ بالضحى في الآيات الكريمة؟

٥- <q>﴿فَمَنِ ٱتَّبَعَ هُدَاىَ فَلَا يَضِلُّ وَلَا يَشْقَىٰ﴾</q>

قال ابن عباس رضي الله عنهما: «ضمن الله تعالى لمن قرأ القرآن وعمل به ألا يضل في الدنيا، ولا يشقى في الآخرة»، وتلا الآية. [القرطبي ١٤/١٥٦]

السؤال: هل يكفي حفظ القرآن للهداية في الدنيا، والنجاة في الآخرة ؟

٦- <q>﴿وَمَنْ أَعْرَضَ عَن ذِكْرِى فَإِنَّ لَهُۥ مَعِيشَةً ضَنكًا﴾</q>

فلا طمأنينة له، ولا انشراح لصدره، بل صدره ضيق حرج لضلاله، وإن تنعم ظاهره، ولبس ما شاء، وأكل ما شاء، وسكن حيث شاء؛ فإن قلبه ما لم يخلص إلى اليقين والهدى فهو في قلق، وحيرة، وشك، فلا يزال في ريبة يتردد، فهذا من ضنك المعيشة. []

السؤال: هل نعيم الظاهر دليل على سعادة الباطن؟ وضح ذلك من الآية.

٧- <q>﴿وَلَا تَعْجَلْ بِٱلْقُرْءَانِ مِن قَبْلِ أَن يُقْضَىٰٓ إِلَيْكَ وَحْيُهُۥ ۖ وَقُل رَّبِّ زِدْنِى عِلْمًا﴾</q>

لما كانت عجلته- صلى الله عليه وسلم- على تَلَقُّف الوحي ومبادرته إليه تدل على محبته التامة للعلم، وحرصه عليه؛ أمره الله تعالى أن يسأله زيادة العلم. [السعدي: ٥١٤]

السؤال: في الآية وسيلة مهمة للحصول على العلم النافع، فما هي؟

التوجيهات

١- من مداخل ابليس على بني آدم: عدم القناعة بالرزق، والتشبث بطول البقاء، <q>﴿قَالَ يَٰٓـَٔادَمُ هَلْ أَدُلُّكَ عَلَىٰ شَجَرَةِ ٱلْخُلْدِ وَمُلْكٍ لَّا يَبْلَىٰ﴾</q>

٢- احــرص على معـرفة سـيـرة مـن نصحك قبـل أن تقبـل نصيحتــه، <q>﴿فَوَسْوَسَ إِلَيْهِ ٱلشَّيْطَٰنُ قَالَ يَٰٓـَٔادَمُ هَلْ أَدُلُّكَ عَلَىٰ شَجَرَةِ ٱلْخُلْدِ وَمُلْكٍ لَّا يَبْلَىٰ﴾</q>

٣- الحياة مع القرآن سبب لسعادة الدنيا والآخرة، والإعراض عنه سبب لشقاوة الدنيا والآخرة، <q>﴿فَمَنِ ٱتَّبَعَ هُدَاىَ فَلَا يَضِلُّ وَلَا يَشْقَىٰ (١٢٣) وَمَنْ أَعْرَضَ عَن ذِكْرِى فَإِنَّ لَهُۥ مَعِيشَةً ضَنكًا وَنَحْشُرُهُۥ يَوْمَ ٱلْقِيَٰمَةِ أَعْمَىٰ﴾</q>

العمل بالآيات

١- أكثر من الدعاء بزيادة العلم، <q>﴿رَّبِّ زِدْنِى عِلْمًا﴾</q>

٢- استعذ بالله من الشيطان الرجيم، وعوّذ أهلك وأولادك منه, <q>﴿فَقُلْنَا يَٰٓـَٔادَمُ إِنَّ هَٰذَا عَدُوٌّ لَّكَ وَلِزَوْجِكَ فَلَا يُخْرِجَنَّكُمَا مِنَ ٱلْجَنَّةِ فَتَشْقَىٰٓ﴾</q>

٣- تذكر ذنبا كبيرا فعلته، وأكثر من الاستغفار والإلحاح في ذلك؛ لعله يكون سببا في اجتباء ربك لك, <q>﴿وَعَصَىٰٓ ءَادَمُ رَبَّهُۥ فَغَوَىٰ (١٢١) ثُمَّ ٱجْتَبَٰهُ رَبُّهُۥ فَتَابَ عَلَيْهِ وَهَدَىٰ﴾</q>

معاني الكلمات

<q>﴿فَتَعَالَى﴾</q> فَتَنَزَّهَ، وَارْتَفَعَ، وَتَقَدَّسَ عَنْ كُلِّ نَقْصٍ.

<q>﴿عَهِدْنَا﴾</q> وَصَّيْنَا.

<q>﴿عَزْمًا﴾</q> حِفْظًا لِمَا أُمِرَ بِهِ.

<q>﴿وَلاَ تَعْرَى﴾</q> لاَ يُصِيبُكَ العُرْيُ.

<q>﴿وَلاَ تَضْحَى﴾</q> لاَ يُصِيبُكَ حَرُّ الشَّمْسِ.

<q>﴿لاَ يَبْلَى﴾</q> لاَ يَنْقَضِي، وَلاَ يَنْقَطِعُ.

<q>﴿سُوْآتُهُمَا﴾</q> عَوْرَاتُهُمَا.

<q>﴿وَطَفِقَا﴾</q> أَخَذَا.

<q>﴿يَخْصِفَانِ﴾</q> يُلْصِقَانِ.

<q>﴿اجْتَبَاهُ﴾</q> اصْطَفَاهُ.

<q>﴿ضَنكًا﴾</q> ضَيِّقَةً شَاقَّةً.

