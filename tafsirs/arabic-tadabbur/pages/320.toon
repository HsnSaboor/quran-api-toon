quran[12]{c,v,t}:
  20,114,"<div class=ar lang=ar><h3>الوقفات التدبرية</h3><p>١- <span class="qpc-hafs">﴿فَتَعَٰلَى ٱللَّهُ ٱلْمَلِكُ ٱلْحَقُّ﴾</span></p><p>وفي وصفه بالحق إيماء إلى أن مُلك غيره من الـمُتَسَمِّين بالملوك لا يخلو من نقص. [ابن عاشور:١٦/٣١٥]</p><p>السؤال: بين باختصار ثلاثة فروق بين ملك الله وملك ملوك الدنيا.</p><p>٢- <span class="qpc-hafs">﴿وَلَا تَعْجَلْ بِٱلْقُرْءَانِ مِن قَبْلِ أَن يُقْضَىٰٓ إِلَيْكَ وَحْيُهُۥ ۖ وَقُل رَّبِّ زِدْنِى عِلْمًا﴾</span></p><p>ويؤخذ من هذه الآية الكريمة: الأدب في تلقي العلم، وأن المستمع للعلم ينبغي له أن يتأنَّى ويصبر حتى يفرغ المعلم من كلامه المتصل بعضه ببعض، فإذا فرغ منه سأل إن كان عنده سؤال، ولا يبادر بالسؤال وقطع كلام مُلْقِي العلم؛ فإنه سبب للحرمان. [السعدي:٥١٤. ]</p><p>السؤال: ما الأدب الذي يستقيه طالب العلم من هذه الآية؟</p><p>٣- <span class="qpc-hafs">﴿وَقُل رَّبِّ زِدْنِى عِلْمًا﴾</span></p><p>كان ابن مسعود- رضي الله عنه- إذا قرأ هذه الآية قال: اللهم زدني علماً وإيماناً ويقيناً. [البغوي:٣/١٤٢]</p><p>السؤال: كيف نتدبر هذه الآية ونعمل بها؟</p><p>٤- <span class="qpc-hafs">﴿إِنَّ لَكَ أَلَّا تَجُوعَ فِيهَا وَلَا تَعْرَىٰ (١١٨) وَأَنَّكَ لَا تَظْمَؤُا۟ فِيهَا وَلَا تَضْحَىٰ﴾</span></p><p>في قوله: <span class="qpc-hafs">﴿إن لك ألا تجوع فيها ولا تعرى﴾</span>، وقرن بين انتفاء الظمأ وألم الجسم في قوله:وقد قُرن بين انتفاء الجوع واللباس <span class="qpc-hafs">﴿وأنك لا تظمأ فيها ولا تضحى﴾</span> لمناسبة بين الجوع والعَرى في أن الجوع خلوّ باطن الجسم عما يقيه تألمه؛ وذلك هو الطعام، وأن العري خلوّ ظاهر الجسم عما يقيه تألمه، وهو لفح الحر، وقرص البرد. ولمناسبة بين الظمأ وبين حرارة الشمس في أن الأول ألم حرارة الباطن، والثاني ألم حرارة الظاهر. [ابن عاشور:١٦/٣٢٢]</p><p>السؤال: لماذا قرن الجوع بالعري، والظمأ بالضحى في الآيات الكريمة؟</p><p>٥- <span class="qpc-hafs">﴿فَمَنِ ٱتَّبَعَ هُدَاىَ فَلَا يَضِلُّ وَلَا يَشْقَىٰ﴾</span></p><p>قال ابن عباس رضي الله عنهما: «ضمن الله تعالى لمن قرأ القرآن وعمل به ألا يضل في الدنيا، ولا يشقى في الآخرة»، وتلا الآية. [القرطبي ١٤/١٥٦]</p><p>السؤال: هل يكفي حفظ القرآن للهداية في الدنيا، والنجاة في الآخرة ؟</p><p>٦- <span class="qpc-hafs">﴿وَمَنْ أَعْرَضَ عَن ذِكْرِى فَإِنَّ لَهُۥ مَعِيشَةً ضَنكًا﴾</span></p><p>فلا طمأنينة له، ولا انشراح لصدره، بل صدره ضيق حرج لضلاله، وإن تنعم ظاهره، ولبس ما شاء، وأكل ما شاء، وسكن حيث شاء؛ فإن قلبه ما لم يخلص إلى اليقين والهدى فهو في قلق، وحيرة، وشك، فلا يزال في ريبة يتردد، فهذا من ضنك المعيشة. []</p><p>السؤال: هل نعيم الظاهر دليل على سعادة الباطن؟ وضح ذلك من الآية.</p><p>٧- <span class="qpc-hafs">﴿وَلَا تَعْجَلْ بِٱلْقُرْءَانِ مِن قَبْلِ أَن يُقْضَىٰٓ إِلَيْكَ وَحْيُهُۥ ۖ وَقُل رَّبِّ زِدْنِى عِلْمًا﴾</span></p><p>لما كانت عجلته- صلى الله عليه وسلم- على تَلَقُّف الوحي ومبادرته إليه تدل على محبته التامة للعلم، وحرصه عليه؛ أمره الله تعالى أن يسأله زيادة العلم. [السعدي: ٥١٤]</p><p>السؤال: في الآية وسيلة مهمة للحصول على العلم النافع، فما هي؟</p><h3>التوجيهات</h3><p>١- من مداخل ابليس على بني آدم: عدم القناعة بالرزق، والتشبث بطول البقاء، <span class="qpc-hafs">﴿قَالَ يَٰٓـَٔادَمُ هَلْ أَدُلُّكَ عَلَىٰ شَجَرَةِ ٱلْخُلْدِ وَمُلْكٍ لَّا يَبْلَىٰ﴾</span></p><p>٢- احــرص على معـرفة سـيـرة مـن نصحك قبـل أن تقبـل نصيحتــه، <span class="qpc-hafs">﴿فَوَسْوَسَ إِلَيْهِ ٱلشَّيْطَٰنُ قَالَ يَٰٓـَٔادَمُ هَلْ أَدُلُّكَ عَلَىٰ شَجَرَةِ ٱلْخُلْدِ وَمُلْكٍ لَّا يَبْلَىٰ﴾</span></p><p>٣- الحياة مع القرآن سبب لسعادة الدنيا والآخرة، والإعراض عنه سبب لشقاوة الدنيا والآخرة، <span class="qpc-hafs">﴿فَمَنِ ٱتَّبَعَ هُدَاىَ فَلَا يَضِلُّ وَلَا يَشْقَىٰ (١٢٣) وَمَنْ أَعْرَضَ عَن ذِكْرِى فَإِنَّ لَهُۥ مَعِيشَةً ضَنكًا وَنَحْشُرُهُۥ يَوْمَ ٱلْقِيَٰمَةِ أَعْمَىٰ﴾</span></p><h3>العمل بالآيات</h3><p>١- أكثر من الدعاء بزيادة العلم، <span class="qpc-hafs">﴿رَّبِّ زِدْنِى عِلْمًا﴾</span></p><p>٢- استعذ بالله من الشيطان الرجيم، وعوّذ أهلك وأولادك منه, <span class="qpc-hafs">﴿فَقُلْنَا يَٰٓـَٔادَمُ إِنَّ هَٰذَا عَدُوٌّ لَّكَ وَلِزَوْجِكَ فَلَا يُخْرِجَنَّكُمَا مِنَ ٱلْجَنَّةِ فَتَشْقَىٰٓ﴾</span></p><p>٣- تذكر ذنبا كبيرا فعلته، وأكثر من الاستغفار والإلحاح في ذلك؛ لعله يكون سببا في اجتباء ربك لك, <span class="qpc-hafs">﴿وَعَصَىٰٓ ءَادَمُ رَبَّهُۥ فَغَوَىٰ (١٢١) ثُمَّ ٱجْتَبَٰهُ رَبُّهُۥ فَتَابَ عَلَيْهِ وَهَدَىٰ﴾</span></p><h3>معاني الكلمات</h3><p><span class="qpc-hafs">﴿فَتَعَالَى﴾</span> فَتَنَزَّهَ، وَارْتَفَعَ، وَتَقَدَّسَ عَنْ كُلِّ نَقْصٍ.</p><p><span class="qpc-hafs">﴿عَهِدْنَا﴾</span> وَصَّيْنَا.</p><p><span class="qpc-hafs">﴿عَزْمًا﴾</span> حِفْظًا لِمَا أُمِرَ بِهِ.</p><p><span class="qpc-hafs">﴿وَلاَ تَعْرَى﴾</span> لاَ يُصِيبُكَ العُرْيُ.</p><p><span class="qpc-hafs">﴿وَلاَ تَضْحَى﴾</span> لاَ يُصِيبُكَ حَرُّ الشَّمْسِ.</p><p><span class="qpc-hafs">﴿لاَ يَبْلَى﴾</span> لاَ يَنْقَضِي، وَلاَ يَنْقَطِعُ.</p><p><span class="qpc-hafs">﴿سُوْآتُهُمَا﴾</span> عَوْرَاتُهُمَا.</p><p><span class="qpc-hafs">﴿وَطَفِقَا﴾</span> أَخَذَا.</p><p><span class="qpc-hafs">﴿يَخْصِفَانِ﴾</span> يُلْصِقَانِ.</p><p><span class="qpc-hafs">﴿اجْتَبَاهُ﴾</span> اصْطَفَاهُ.</p><p><span class="qpc-hafs">﴿ضَنكًا﴾</span> ضَيِّقَةً شَاقَّةً.</p></div>"
