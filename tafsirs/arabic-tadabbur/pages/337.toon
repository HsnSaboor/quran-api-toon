quran[8]{c,v,t}:
  22,39,"<div class=ar lang=ar><h3>الوقفات التدبرية</h3><p>١- <span class="qpc-hafs">﴿ٱلَّذِينَ أُخْرِجُوا۟ مِن دِيَٰرِهِم بِغَيْرِ حَقٍّ إِلَّآ أَن يَقُولُوا۟ رَبُّنَا ٱللَّهُ﴾</span></p><p>وهذا يدل على حكمة الجهاد، وأن المقصود منه إقامة دين الله، وذبُّ الكفار المؤذين للمؤمنين. [السعدي:٥٣٩]</p><p>السؤال: أشارت الآية إلى حكمة من حكم مشروعية الجهاد، وضح ذلك.</p><p>٢- <span class="qpc-hafs">﴿وَلَوْلَا دَفْعُ ٱللَّهِ ٱلنَّاسَ بَعْضَهُم بِبَعْضٍ لَّهُدِّمَتْ صَوَٰمِعُ وَبِيَعٌ وَصَلَوَٰتٌ وَمَسَٰجِدُ يُذْكَرُ فِيهَا ٱسْمُ ٱللَّهِ كَثِيرًا﴾</span></p><p>الآية تقوية للإذن في القتال، وإظهار للمصلحة التي فيه؛ كأنه يقول: لولا القتال والجهاد لاستولى الكفار على المسلمين وذهب الدين. [ابن جزي:٢/٥٩]</p><p>السؤال: في الجهاد حكمة عظيمة في بقاء الدين, وضح ذلك.</p><p>٣- <span class="qpc-hafs">﴿ۗ وَلَوْلَا دَفْعُ ٱللَّهِ ٱلنَّاسَ بَعْضَهُم بِبَعْضٍ لَّهُدِّمَتْ صَوَٰمِعُ وَبِيَعٌ وَصَلَوَٰتٌ وَمَسَٰجِدُ﴾</span></p><p>ودل ذلك على أن البلدان التي حصلت فيها الطمأنينة بعبادة الله، وعمرت مساجدها، وأقيمت فيها شعائر الدين كلها من فضائل المجاهدين، وببركتهم دفع الله عنها الكافرين. [السعدي:٥٣٩]</p><p>السؤال: للمجاهدين أفضال على المسلمين، بيِّن ذلك.</p><p>٤- <span class="qpc-hafs">﴿وَلَوْلَا دَفْعُ ٱللَّهِ ٱلنَّاسَ بَعْضَهُم بِبَعْضٍ لَّهُدِّمَتْ صَوَٰمِعُ وَبِيَعٌ وَصَلَوَٰتٌ وَمَسَٰجِدُ يُذْكَرُ فِيهَا ٱسْمُ ٱللَّهِ كَثِيرًا﴾</span></p><p>ومعاني هذه الأسماء هي في الأمم التي لها كتاب على قديم الدهر، ولم يذكر في هذه المجوس، ولا أهل الإشراك؛ لأن هؤلاء ليس لهم ما تجب حمايته، ولا يوجد ذكر الله إلا عند أهل الشرائع. [ابن عطية:٤/١٢٥]</p><p>السؤال: ما وجه عدم ذكر معابد المجوس والمشركين في الآية؟</p><p>٥- <span class="qpc-hafs">﴿وَلَيَنصُرَنَّ ٱللَّهُ مَن يَنصُرُهُۥٓ﴾</span></p><p>أي: من ينصر دينه وأولياءه، وهو وعد تضمن الحض على القتال. [ابن جزي:٢/٥٩]</p><p>السؤال: ما شرط تحقيق النصر؟</p><p>٦- <span class="qpc-hafs">﴿ٱلَّذِينَ إِن مَّكَّنَّٰهُمْ فِى ٱلْأَرْضِ أَقَامُوا۟ ٱلصَّلَوٰةَ وَءَاتَوُا۟ ٱلزَّكَوٰةَ وَأَمَرُوا۟ بِٱلْمَعْرُوفِ وَنَهَوْا۟ عَنِ ٱلْمُنكَرِ ۗ وَلِلَّهِ عَٰقِبَةُ ٱلْأُمُورِ﴾</span></p><p>فمن قام بهذه الأمور نصره الله على عدوه. [ابن تيمية: ٤/٤٣٤]</p><p>السؤال: ما واجب المجاهدين عند تمكينهم في الأرض؟</p><p>٧- <span class="qpc-hafs">﴿فَإِنَّهَا لَا تَعْمَى ٱلْأَبْصَٰرُ وَلَٰكِن تَعْمَى ٱلْقُلُوبُ ٱلَّتِى فِى ٱلصُّدُورِ﴾</span></p><p>معناه: أن العمى الضار هو عمى القلب، فأما عمى البصر فليس بضار في أمر الدين. [البغوي:١٤/٢٢٤]</p><p>السؤال: ما العمى الضار الذي يوجب هلاك الإنسان؟</p><h3>التوجيهات</h3><p>١- وعد من الله سبحانه أن نصره يتنزل على من نصر دينه، ورفع شرعه، <span class="qpc-hafs">﴿وَلَيَنصُرَنَّ ٱللَّهُ مَن يَنصُرُهُۥٓ﴾</span></p><p>٢- إن الله ليملي للظالمين حتى إذا أخذهم لم يفلتهم، <span class="qpc-hafs">﴿فَكَأَيِّن مِّن قَرْيَةٍ أَهْلَكْنَٰهَا وَهِىَ ظَالِمَةٌ فَهِىَ خَاوِيَةٌ عَلَىٰ عُرُوشِهَا﴾</span></p><p>٣- العبرة بالبصيرة القلبية لا بالبصر؛ فكم من أعمى هو أبصر للحقائق من ذي بصر، <span class="qpc-hafs">﴿فَإِنَّهَا لَا تَعْمَى ٱلْأَبْصَٰرُ وَلَٰكِن تَعْمَى ٱلْقُلُوبُ ٱلَّتِى فِى ٱلصُّدُورِ﴾</span></p><h3>العمل بالآيات</h3><p>١- ادعُ لإخوانك المستضعفين من المسلمين في أرجاء المعمورة, <span class="qpc-hafs">﴿أُذِنَ لِلَّذِينَ يُقَٰتَلُونَ بِأَنَّهُمْ ظُلِمُوا۟ ۚ وَإِنَّ ٱللَّهَ عَلَىٰ نَصْرِهِمْ لَقَدِيرٌ﴾</span></p><p>٢- حافظ على إقامة الصلاة, وحث من حولك عليها، <span class="qpc-hafs">﴿ٱلَّذِينَ إِن مَّكَّنَّٰهُمْ فِى ٱلْأَرْضِ أَقَامُوا۟ ٱلصَّلَوٰةَ﴾</span></p><p>٣- أنكر بحكمة ما تراه من منكرات بين زملائك وفي حيك, <span class="qpc-hafs">﴿وَأَمَرُوا۟ بِٱلْمَعْرُوفِ وَنَهَوْا۟ عَنِ ٱلْمُنكَرِ﴾</span></p><h3>معاني الكلمات</h3><p><span class="qpc-hafs">﴿صَوَامِعُ﴾</span> مَعَابِدُ رُهْبَانِ النَّصَارَى.</p><p><span class="qpc-hafs">﴿وَبِيَعٌ﴾</span> كَنَائِسُ النَّصَارَى.</p><p><span class="qpc-hafs">﴿وَصَلَوَاتٌ﴾</span> مَعَابِدُ اليَهُودِ.</p><p><span class="qpc-hafs">﴿وَمَسَاجِدُ﴾</span> مَعَابِدُ المُسْلِمِينَ.</p><p><span class="qpc-hafs">﴿فَأَمْلَيْتُ﴾</span> فَأَمْهَلْتُ وَلَمْ أُعَاجِلْ بِالعُقُوبَةِ.</p><p><span class="qpc-hafs">﴿نَكِيرِ﴾</span> إِنْكَارِي عَلَيْهِمْ كُفْرَهُمْ بِالعَذَابِ وَالهَلاَكِ.</p><p><span class="qpc-hafs">﴿فَكَأَيِّنْ مِنْ قَرْيَةٍ﴾</span> فَكَثِيرٌ مِنَ القُرَى.</p><p><span class="qpc-hafs">﴿خَاوِيَةٌ عَلَى عُرُوشِهَا﴾</span> مُتَهَدِّمَةٌ قَدْ سَقَطَتْ حِيطَانُهَا عَلَى سُقُوفِهَا.</p><p><span class="qpc-hafs">﴿وَقَصْرٍ مَشِيدٍ﴾</span> مَرْفُوعِ البُنْيَانِ مُزَخْرَفٍ قَدْ خَلاَ مِنْ سَاكِنِيهِ.</p></div>"
