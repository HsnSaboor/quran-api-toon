tafsir[8]{c,v,t}:
  22,39,"

الوقفات التدبرية

١- <q>﴿ٱلَّذِينَ أُخْرِجُوا۟ مِن دِيَٰرِهِم بِغَيْرِ حَقٍّ إِلَّآ أَن يَقُولُوا۟ رَبُّنَا ٱللَّهُ﴾</q>

وهذا يدل على حكمة الجهاد، وأن المقصود منه إقامة دين الله، وذبُّ الكفار المؤذين للمؤمنين. [السعدي:٥٣٩]

السؤال: أشارت الآية إلى حكمة من حكم مشروعية الجهاد، وضح ذلك.

٢- <q>﴿وَلَوْلَا دَفْعُ ٱللَّهِ ٱلنَّاسَ بَعْضَهُم بِبَعْضٍ لَّهُدِّمَتْ صَوَٰمِعُ وَبِيَعٌ وَصَلَوَٰتٌ وَمَسَٰجِدُ يُذْكَرُ فِيهَا ٱسْمُ ٱللَّهِ كَثِيرًا﴾</q>

الآية تقوية للإذن في القتال، وإظهار للمصلحة التي فيه؛ كأنه يقول: لولا القتال والجهاد لاستولى الكفار على المسلمين وذهب الدين. [ابن جزي:٢/٥٩]

السؤال: في الجهاد حكمة عظيمة في بقاء الدين, وضح ذلك.

٣- <q>﴿ۗ وَلَوْلَا دَفْعُ ٱللَّهِ ٱلنَّاسَ بَعْضَهُم بِبَعْضٍ لَّهُدِّمَتْ صَوَٰمِعُ وَبِيَعٌ وَصَلَوَٰتٌ وَمَسَٰجِدُ﴾</q>

ودل ذلك على أن البلدان التي حصلت فيها الطمأنينة بعبادة الله، وعمرت مساجدها، وأقيمت فيها شعائر الدين كلها من فضائل المجاهدين، وببركتهم دفع الله عنها الكافرين. [السعدي:٥٣٩]

السؤال: للمجاهدين أفضال على المسلمين، بيِّن ذلك.

٤- <q>﴿وَلَوْلَا دَفْعُ ٱللَّهِ ٱلنَّاسَ بَعْضَهُم بِبَعْضٍ لَّهُدِّمَتْ صَوَٰمِعُ وَبِيَعٌ وَصَلَوَٰتٌ وَمَسَٰجِدُ يُذْكَرُ فِيهَا ٱسْمُ ٱللَّهِ كَثِيرًا﴾</q>

ومعاني هذه الأسماء هي في الأمم التي لها كتاب على قديم الدهر، ولم يذكر في هذه المجوس، ولا أهل الإشراك؛ لأن هؤلاء ليس لهم ما تجب حمايته، ولا يوجد ذكر الله إلا عند أهل الشرائع. [ابن عطية:٤/١٢٥]

السؤال: ما وجه عدم ذكر معابد المجوس والمشركين في الآية؟

٥- <q>﴿وَلَيَنصُرَنَّ ٱللَّهُ مَن يَنصُرُهُۥٓ﴾</q>

أي: من ينصر دينه وأولياءه، وهو وعد تضمن الحض على القتال. [ابن جزي:٢/٥٩]

السؤال: ما شرط تحقيق النصر؟

٦- <q>﴿ٱلَّذِينَ إِن مَّكَّنَّٰهُمْ فِى ٱلْأَرْضِ أَقَامُوا۟ ٱلصَّلَوٰةَ وَءَاتَوُا۟ ٱلزَّكَوٰةَ وَأَمَرُوا۟ بِٱلْمَعْرُوفِ وَنَهَوْا۟ عَنِ ٱلْمُنكَرِ ۗ وَلِلَّهِ عَٰقِبَةُ ٱلْأُمُورِ﴾</q>

فمن قام بهذه الأمور نصره الله على عدوه. [ابن تيمية: ٤/٤٣٤]

السؤال: ما واجب المجاهدين عند تمكينهم في الأرض؟

٧- <q>﴿فَإِنَّهَا لَا تَعْمَى ٱلْأَبْصَٰرُ وَلَٰكِن تَعْمَى ٱلْقُلُوبُ ٱلَّتِى فِى ٱلصُّدُورِ﴾</q>

معناه: أن العمى الضار هو عمى القلب، فأما عمى البصر فليس بضار في أمر الدين. [البغوي:١٤/٢٢٤]

السؤال: ما العمى الضار الذي يوجب هلاك الإنسان؟

التوجيهات

١- وعد من الله سبحانه أن نصره يتنزل على من نصر دينه، ورفع شرعه، <q>﴿وَلَيَنصُرَنَّ ٱللَّهُ مَن يَنصُرُهُۥٓ﴾</q>

٢- إن الله ليملي للظالمين حتى إذا أخذهم لم يفلتهم، <q>﴿فَكَأَيِّن مِّن قَرْيَةٍ أَهْلَكْنَٰهَا وَهِىَ ظَالِمَةٌ فَهِىَ خَاوِيَةٌ عَلَىٰ عُرُوشِهَا﴾</q>

٣- العبرة بالبصيرة القلبية لا بالبصر؛ فكم من أعمى هو أبصر للحقائق من ذي بصر، <q>﴿فَإِنَّهَا لَا تَعْمَى ٱلْأَبْصَٰرُ وَلَٰكِن تَعْمَى ٱلْقُلُوبُ ٱلَّتِى فِى ٱلصُّدُورِ﴾</q>

العمل بالآيات

١- ادعُ لإخوانك المستضعفين من المسلمين في أرجاء المعمورة, <q>﴿أُذِنَ لِلَّذِينَ يُقَٰتَلُونَ بِأَنَّهُمْ ظُلِمُوا۟ ۚ وَإِنَّ ٱللَّهَ عَلَىٰ نَصْرِهِمْ لَقَدِيرٌ﴾</q>

٢- حافظ على إقامة الصلاة, وحث من حولك عليها، <q>﴿ٱلَّذِينَ إِن مَّكَّنَّٰهُمْ فِى ٱلْأَرْضِ أَقَامُوا۟ ٱلصَّلَوٰةَ﴾</q>

٣- أنكر بحكمة ما تراه من منكرات بين زملائك وفي حيك, <q>﴿وَأَمَرُوا۟ بِٱلْمَعْرُوفِ وَنَهَوْا۟ عَنِ ٱلْمُنكَرِ﴾</q>

معاني الكلمات

<q>﴿صَوَامِعُ﴾</q> مَعَابِدُ رُهْبَانِ النَّصَارَى.

<q>﴿وَبِيَعٌ﴾</q> كَنَائِسُ النَّصَارَى.

<q>﴿وَصَلَوَاتٌ﴾</q> مَعَابِدُ اليَهُودِ.

<q>﴿وَمَسَاجِدُ﴾</q> مَعَابِدُ المُسْلِمِينَ.

<q>﴿فَأَمْلَيْتُ﴾</q> فَأَمْهَلْتُ وَلَمْ أُعَاجِلْ بِالعُقُوبَةِ.

<q>﴿نَكِيرِ﴾</q> إِنْكَارِي عَلَيْهِمْ كُفْرَهُمْ بِالعَذَابِ وَالهَلاَكِ.

<q>﴿فَكَأَيِّنْ مِنْ قَرْيَةٍ﴾</q> فَكَثِيرٌ مِنَ القُرَى.

<q>﴿خَاوِيَةٌ عَلَى عُرُوشِهَا﴾</q> مُتَهَدِّمَةٌ قَدْ سَقَطَتْ حِيطَانُهَا عَلَى سُقُوفِهَا.

<q>﴿وَقَصْرٍ مَشِيدٍ﴾</q> مَرْفُوعِ البُنْيَانِ مُزَخْرَفٍ قَدْ خَلاَ مِنْ سَاكِنِيهِ.

