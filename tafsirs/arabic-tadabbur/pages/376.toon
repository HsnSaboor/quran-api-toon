quran[21]{c,v,t}:
  26,207,"

الوقفات التدبرية

١- <q>﴿مَآ أَغْنَىٰ عَنْهُم مَّا كَانُوا۟ يُمَتَّعُونَ﴾</q>

يقول تعالى ذكره: ثم جاءهم العذاب الذي كانوا يوعدون على كفرهم بآياتنا، وتكذيبهم رسولنا. <q>﴿ما أغنى عنهم﴾</q> يقول: أي شيء أغنى عنهم التأخير الذي أخرنا في آجالهم، والمتاع الذي متعناهم به من الحياة، إذ لم يتوبوا؟! ... هل زادهم تمتيعنا إياهم ذلك إلا خبالا؟! وهل نفعهم شيئا؟! بل ضرهم بازديادهم من الآثام، واكتسابهم من الإجرام ما لو لم يمتعوا لم يكتسبوه. [الطبري:١٩/٤٠٢]

السؤال: طول العمر بدون عمل صالح هلاك وعذاب، بين ذلك.

٢- <q>﴿فَلَا تَدْعُ مَعَ ٱللَّهِ إِلَٰهًا ءَاخَرَ فَتَكُونَ مِنَ ٱلْمُعَذَّبِينَ﴾</q>

خوطب به النبي ﷺ مع استحالة صدور المنهي عنه عليه الصلاة والسلام تهييجا وحثا لازدياد الإخلاص؛ فهو كناية عن: «أخلص في التوحيد حتى لا ترى معه عز وجل سواه». وفيه لطف لسائر المكلفين ببيان أن الإشراك من القبح والسوء بحيث ينهى عنه من لم يمكن صدوره عنه، فكيف بمن عداه. [الألوسي:١٠/١٣١]

السؤال: ما فائدة مخاطبة النبي ﷺ بالنهي عن الشرك مع استحالة صدوره عنه؟

٣- <q>﴿وَأَنذِرْ عَشِيرَتَكَ ٱلْأَقْرَبِينَ﴾</q>

وهذا لا ينافي أمره بإنذار جميع الناس؛ كما إذا أُمِرَ الإنسانُ بعموم الإحسان، ثم قيل: «أحسن إلى قرابتك» فيكون هذا خصوصاً دالاً على التأكيد، وزيادة الحق. [السعدي:٥٩٩]

السؤال: هل يفهم من هذه الآية أن دعوة النبي ﷺ خاصة بقومه؟

٤- <q>﴿وَٱخْفِضْ جَنَاحَكَ لِمَنِ ٱتَّبَعَكَ مِنَ ٱلْمُؤْمِنِينَ (٢١٥) فَإِنْ عَصَوْكَ فَقُلْ إِنِّى بَرِىٓءٌ مِّمَّا تَعْمَلُونَ﴾</q>

<q>﴿فإن عصوك﴾</q>... هذا لدفع احتراز وهم من يتوهم أن قوله: <q>﴿واخفض جناحك لمن اتبعك من المؤمنين﴾</q> يقتضي الرضاء بجميع ما يصدر منهم ما داموا مؤمنين، فدفع هذا بهذا. [السعدي:٥٩٩]

السؤال: لماذا عَقّب قوله: <q>﴿فإن عصوك﴾</q> بعد قوله: <q>﴿واخفض جناحك لمن اتبعك من المؤمنين﴾</q>؟

٥- <q>﴿وَتَقَلُّبَكَ فِى ٱلسَّٰجِدِينَ﴾</q>

معناه: يرى صلاتك مع المصلين؛ ففي ذلك إشارة إلى الصلاة مع الجماعة. [ابن جزي:٢/١٢٤]

السؤال: كيف دلّت هذه الآية على صلاة الجماعة؟

٦- <q>﴿يُلْقُونَ ٱلسَّمْعَ وَأَكْثَرُهُمْ كَٰذِبُونَ﴾</q>

<q>﴿يلقون﴾</q>: بمعنى: يلقون المسموع، والضمير يحتمل أيضاً على هذا أن يكون للشياطين؛ لأنهم يلقون الكلام إلى الكهان، أو يكون للكهان؛ لأنهم يلقون الكلام إلى الناس، <q>﴿وأكثرهم كاذبون﴾</q> يعني: الشياطين، أو الكهان لأنهم يكذبون فيما يخبرون به عن الشياطين. [ابن جزي:٢/١٢٥]

السؤال: من أين جاء كذب الكهنة والعرافين؟

٧- <q>﴿أَلَمْ تَرَ أَنَّهُمْ فِى كُلِّ وَادٍ يَهِيمُونَ﴾</q>

يقول: في كل لغو يخوضون، ولا يتبعون سنن الحق؛ لأن من اتبع الحق، وعلم أنه يكتب عليه ما يقوله تثبت ولم يكن هائما يذهب على وجهه لا يبالى ما قال. [القرطبي:١٦/٩٥]

السؤال: ما تقول فيمن يخوض مع كل خائض، ويتكلم بما شاء، ولا يتبع الحق؟

التوجيهات

١- من مات يدعو غير الله فهو مع المعذبين, <q>﴿فَلَا تَدْعُ مَعَ ٱللَّهِ إِلَٰهًا ءَاخَرَ فَتَكُونَ مِنَ ٱلْمُعَذَّبِينَ﴾</q>

٢- لا نجاح للداعية إلا بالحلم، والتواضع، ولين الجانب، <q>﴿وَٱخْفِضْ جَنَاحَكَ لِمَنِ ٱتَّبَعَكَ مِنَ ٱلْمُؤْمِنِينَ﴾</q>

٣- احذر الظلم وتذكر سوء عاقبة أهله، وتأمل في حال من حولك ممن طغا وتجبر؛ كيف قصمهم الله تعالى، <q>﴿ۗ وَسَيَعْلَمُ ٱلَّذِينَ ظَلَمُوٓا۟ أَىَّ مُنقَلَبٍ يَنقَلِبُونَ﴾</q>

العمل بالآيات

١- تعاون مع بعض أقاربك في عمل برنامج دعوي تفيد فيه أقاربك بكلمة طيبة، وهدية محببة، <q>﴿وَأَنذِرْ عَشِيرَتَكَ ٱلْأَقْرَبِينَ﴾</q>

٢- قم الليل، وأطل السجود, <q>﴿ٱلَّذِى يَرَىٰكَ حِينَ تَقُومُ (٢١٨) وَتَقَلُّبَكَ فِى ٱلسَّٰجِدِينَ﴾</q>

٣- اذكر الله تعالى بالأذكار المطلقة والمقيدة؛ مثل قول: <q>﴿سبحان الله وبحمده﴾</q> مائة مرة, والاستغفار سبعين مرة، <q>﴿وَذَكَرُوا۟ ٱللَّهَ كَثِيرًا﴾</q>

معاني الكلمات

<q>﴿السَّمْعِ﴾</q> اسْتِمَاعِ القُرْآنِ مِنَ السَّمَاءِ.

<q>﴿لَمَعْزُولُونَ﴾</q> لَمَحْجُوبُونَ مَرْجُومُونَ بِالشُّهُبِ.

<q>﴿وَاخْفِضْ جَنَاحَكَ﴾</q> أَلِنْ جَانِبَكَ وَكَلامَكَ تَوَاضُعًا.

<q>﴿حِينَ تَقُومُ﴾</q> تُصَلِّي اللَّيْلَ وَحْدَكَ.

<q>﴿أَفَّاكٍ﴾</q> كَذَّابٍ.

<q>﴿أَثِيمٍ﴾</q> كَثِيرِ الآثَامِ.

<q>﴿يُلْقُونَ السَّمْعَ﴾</q> تُلْقِي الشَّيَاطِينُ إِلَى الكُهَّانِ مَا يَسْتَرِقُونَ مِنَ المَلَأِ الأَعْلَى.

<q>﴿وَادٍ﴾</q> فَنٍّ مِنْ فُنُونِ البَاطِلِ، وَالكَذِبِ.

<q>﴿يَهِيمُونَ﴾</q> يَخُوضُونَ.

<q>﴿مُنْقَلَبٍ﴾</q> مَرْجِعٍ.

