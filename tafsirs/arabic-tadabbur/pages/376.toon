quran[21]{c,v,t}:
  26,207,"<div class=ar lang=ar><h3>الوقفات التدبرية</h3><p>١- <span class="qpc-hafs">﴿مَآ أَغْنَىٰ عَنْهُم مَّا كَانُوا۟ يُمَتَّعُونَ﴾</span></p><p>يقول تعالى ذكره: ثم جاءهم العذاب الذي كانوا يوعدون على كفرهم بآياتنا، وتكذيبهم رسولنا. <span class="qpc-hafs">﴿ما أغنى عنهم﴾</span> يقول: أي شيء أغنى عنهم التأخير الذي أخرنا في آجالهم، والمتاع الذي متعناهم به من الحياة، إذ لم يتوبوا؟! ... هل زادهم تمتيعنا إياهم ذلك إلا خبالا؟! وهل نفعهم شيئا؟! بل ضرهم بازديادهم من الآثام، واكتسابهم من الإجرام ما لو لم يمتعوا لم يكتسبوه. [الطبري:١٩/٤٠٢]</p><p>السؤال: طول العمر بدون عمل صالح هلاك وعذاب، بين ذلك.</p><p>٢- <span class="qpc-hafs">﴿فَلَا تَدْعُ مَعَ ٱللَّهِ إِلَٰهًا ءَاخَرَ فَتَكُونَ مِنَ ٱلْمُعَذَّبِينَ﴾</span></p><p>خوطب به النبي ﷺ مع استحالة صدور المنهي عنه عليه الصلاة والسلام تهييجا وحثا لازدياد الإخلاص؛ فهو كناية عن: «أخلص في التوحيد حتى لا ترى معه عز وجل سواه». وفيه لطف لسائر المكلفين ببيان أن الإشراك من القبح والسوء بحيث ينهى عنه من لم يمكن صدوره عنه، فكيف بمن عداه. [الألوسي:١٠/١٣١]</p><p>السؤال: ما فائدة مخاطبة النبي ﷺ بالنهي عن الشرك مع استحالة صدوره عنه؟</p><p>٣- <span class="qpc-hafs">﴿وَأَنذِرْ عَشِيرَتَكَ ٱلْأَقْرَبِينَ﴾</span></p><p>وهذا لا ينافي أمره بإنذار جميع الناس؛ كما إذا أُمِرَ الإنسانُ بعموم الإحسان، ثم قيل: «أحسن إلى قرابتك» فيكون هذا خصوصاً دالاً على التأكيد، وزيادة الحق. [السعدي:٥٩٩]</p><p>السؤال: هل يفهم من هذه الآية أن دعوة النبي ﷺ خاصة بقومه؟</p><p>٤- <span class="qpc-hafs">﴿وَٱخْفِضْ جَنَاحَكَ لِمَنِ ٱتَّبَعَكَ مِنَ ٱلْمُؤْمِنِينَ (٢١٥) فَإِنْ عَصَوْكَ فَقُلْ إِنِّى بَرِىٓءٌ مِّمَّا تَعْمَلُونَ﴾</span></p><p><span class="qpc-hafs">﴿فإن عصوك﴾</span>... هذا لدفع احتراز وهم من يتوهم أن قوله: <span class="qpc-hafs">﴿واخفض جناحك لمن اتبعك من المؤمنين﴾</span> يقتضي الرضاء بجميع ما يصدر منهم ما داموا مؤمنين، فدفع هذا بهذا. [السعدي:٥٩٩]</p><p>السؤال: لماذا عَقّب قوله: <span class="qpc-hafs">﴿فإن عصوك﴾</span> بعد قوله: <span class="qpc-hafs">﴿واخفض جناحك لمن اتبعك من المؤمنين﴾</span>؟</p><p>٥- <span class="qpc-hafs">﴿وَتَقَلُّبَكَ فِى ٱلسَّٰجِدِينَ﴾</span></p><p>معناه: يرى صلاتك مع المصلين؛ ففي ذلك إشارة إلى الصلاة مع الجماعة. [ابن جزي:٢/١٢٤]</p><p>السؤال: كيف دلّت هذه الآية على صلاة الجماعة؟</p><p>٦- <span class="qpc-hafs">﴿يُلْقُونَ ٱلسَّمْعَ وَأَكْثَرُهُمْ كَٰذِبُونَ﴾</span></p><p><span class="qpc-hafs">﴿يلقون﴾</span>: بمعنى: يلقون المسموع، والضمير يحتمل أيضاً على هذا أن يكون للشياطين؛ لأنهم يلقون الكلام إلى الكهان، أو يكون للكهان؛ لأنهم يلقون الكلام إلى الناس، <span class="qpc-hafs">﴿وأكثرهم كاذبون﴾</span> يعني: الشياطين، أو الكهان لأنهم يكذبون فيما يخبرون به عن الشياطين. [ابن جزي:٢/١٢٥]</p><p>السؤال: من أين جاء كذب الكهنة والعرافين؟</p><p>٧- <span class="qpc-hafs">﴿أَلَمْ تَرَ أَنَّهُمْ فِى كُلِّ وَادٍ يَهِيمُونَ﴾</span></p><p>يقول: في كل لغو يخوضون، ولا يتبعون سنن الحق؛ لأن من اتبع الحق، وعلم أنه يكتب عليه ما يقوله تثبت ولم يكن هائما يذهب على وجهه لا يبالى ما قال. [القرطبي:١٦/٩٥]</p><p>السؤال: ما تقول فيمن يخوض مع كل خائض، ويتكلم بما شاء، ولا يتبع الحق؟</p><h3>التوجيهات</h3><p>١- من مات يدعو غير الله فهو مع المعذبين, <span class="qpc-hafs">﴿فَلَا تَدْعُ مَعَ ٱللَّهِ إِلَٰهًا ءَاخَرَ فَتَكُونَ مِنَ ٱلْمُعَذَّبِينَ﴾</span></p><p>٢- لا نجاح للداعية إلا بالحلم، والتواضع، ولين الجانب، <span class="qpc-hafs">﴿وَٱخْفِضْ جَنَاحَكَ لِمَنِ ٱتَّبَعَكَ مِنَ ٱلْمُؤْمِنِينَ﴾</span></p><p>٣- احذر الظلم وتذكر سوء عاقبة أهله، وتأمل في حال من حولك ممن طغا وتجبر؛ كيف قصمهم الله تعالى، <span class="qpc-hafs">﴿ۗ وَسَيَعْلَمُ ٱلَّذِينَ ظَلَمُوٓا۟ أَىَّ مُنقَلَبٍ يَنقَلِبُونَ﴾</span></p><h3>العمل بالآيات</h3><p>١- تعاون مع بعض أقاربك في عمل برنامج دعوي تفيد فيه أقاربك بكلمة طيبة، وهدية محببة، <span class="qpc-hafs">﴿وَأَنذِرْ عَشِيرَتَكَ ٱلْأَقْرَبِينَ﴾</span></p><p>٢- قم الليل، وأطل السجود, <span class="qpc-hafs">﴿ٱلَّذِى يَرَىٰكَ حِينَ تَقُومُ (٢١٨) وَتَقَلُّبَكَ فِى ٱلسَّٰجِدِينَ﴾</span></p><p>٣- اذكر الله تعالى بالأذكار المطلقة والمقيدة؛ مثل قول: <span class="qpc-hafs">﴿سبحان الله وبحمده﴾</span> مائة مرة, والاستغفار سبعين مرة، <span class="qpc-hafs">﴿وَذَكَرُوا۟ ٱللَّهَ كَثِيرًا﴾</span></p><h3>معاني الكلمات</h3><p><span class="qpc-hafs">﴿السَّمْعِ﴾</span> اسْتِمَاعِ القُرْآنِ مِنَ السَّمَاءِ.</p><p><span class="qpc-hafs">﴿لَمَعْزُولُونَ﴾</span> لَمَحْجُوبُونَ مَرْجُومُونَ بِالشُّهُبِ.</p><p><span class="qpc-hafs">﴿وَاخْفِضْ جَنَاحَكَ﴾</span> أَلِنْ جَانِبَكَ وَكَلامَكَ تَوَاضُعًا.</p><p><span class="qpc-hafs">﴿حِينَ تَقُومُ﴾</span> تُصَلِّي اللَّيْلَ وَحْدَكَ.</p><p><span class="qpc-hafs">﴿أَفَّاكٍ﴾</span> كَذَّابٍ.</p><p><span class="qpc-hafs">﴿أَثِيمٍ﴾</span> كَثِيرِ الآثَامِ.</p><p><span class="qpc-hafs">﴿يُلْقُونَ السَّمْعَ﴾</span> تُلْقِي الشَّيَاطِينُ إِلَى الكُهَّانِ مَا يَسْتَرِقُونَ مِنَ المَلَأِ الأَعْلَى.</p><p><span class="qpc-hafs">﴿وَادٍ﴾</span> فَنٍّ مِنْ فُنُونِ البَاطِلِ، وَالكَذِبِ.</p><p><span class="qpc-hafs">﴿يَهِيمُونَ﴾</span> يَخُوضُونَ.</p><p><span class="qpc-hafs">﴿مُنْقَلَبٍ﴾</span> مَرْجِعٍ.</p></div>"
