quran[8]{c,v,t}:
  28,6,"<div class=ar lang=ar><h3>الوقفات التدبرية</h3><p>١- <span class="qpc-hafs">﴿وَأَوْحَيْنَآ إِلَىٰٓ أُمِّ مُوسَىٰٓ أَنْ أَرْضِعِيهِ ۖ فَإِذَا خِفْتِ عَلَيْهِ فَأَلْقِيهِ فِى ٱلْيَمِّ وَلَا تَخَافِى وَلَا تَحْزَنِىٓ ۖ إِنَّا رَآدُّوهُ إِلَيْكِ وَجَاعِلُوهُ مِنَ ٱلْمُرْسَلِينَ﴾</span></p><p>فبين أنه يلهم المؤمنين الإيمان وما ينفعهم؛ وذلك إيحاء إليهم وإن لم يكونوا أنبياء. [ابن تيمية:٥/٧٠]</p><p>السؤال: بينت الآية الكريمة فضل الله تعالى على المؤمنين، بين ذلك؟</p><p>٢- <span class="qpc-hafs">﴿وَأَوْحَيْنَآ إِلَىٰٓ أُمِّ مُوسَىٰٓ أَنْ أَرْضِعِيهِ ۖ فَإِذَا خِفْتِ عَلَيْهِ فَأَلْقِيهِ فِى ٱلْيَمِّ وَلَا تَخَافِى وَلَا تَحْزَنِ﴾</span> إلى قوله تعالى: <span class="qpc-hafs">﴿وَقَالَتْ لِأُخْتِهِۦ قُصِّيهِ﴾</span></p><p>إن العبد ولو عرف أن القضاء والقدر ووعد الله نافذ لا بد منه فإنه لا يهمل فعل الأسباب التي أُمِرَ بها، ولا يكون ذلك منافياً لإيمانه بخبر الله؛ فإن الله قد وعد أم موسى أن يرده عليها، ومع ذلك اجتهدت في رده، وأرسلت أخته لتقصه وتطلبه. [السعدي:٦١٩]</p><p>السؤال: إرسال أم موسى أخته لتنظر ماذا حصل في أمره، هل ينافي الإيمان بوعد الله سبحانه وتعالى؟</p><p>٣- <span class="qpc-hafs">﴿وَقَالَتِ ٱمْرَأَتُ فِرْعَوْنَ قُرَّتُ عَيْنٍ لِّى وَلَكَ ۖ لَا تَقْتُلُوهُ عَسَىٰٓ أَن يَنفَعَنَآ أَوْ نَتَّخِذَهُۥ وَلَدًا وَهُمْ لَا يَشْعُرُونَ﴾</span></p><p>وإنما أمرها الله بإرضاعه لتقوى بُنيته بلبان أمه؛ فإنه أسعد بالطفل في أول عمره من لبان غيرها، وليكون له من الرضاعة الأخيرة- قبل إلقائه في اليمّ- قوت يشد بنيته فيما بين قذفه في اليم وبين التقاط آل فرعون إياه، وإيصاله إلى بيت فرعون. [ابن عاشور:٢٠/٧٣]</p><p>السؤال: لماذا أمرت أم موسى بإرضاعه قبل إلقائه في البحر؟</p><p>٤- <span class="qpc-hafs">﴿عَسَىٰٓ أَن يَنفَعَنَآ أَوْ نَتَّخِذَهُۥ وَلَدًا﴾</span></p><p>فقَدَّر الله تعالى أنه نفع امرأة فرعون التي قالت تلك المقالة؛ فإنه لما صار قرة عين لها، وأحبته حباً شديداً، فلم يزل لها بمنْزلة الولد الشفيق حتى كبر، ونبأه الله وأرسله، فبادرت إلى الإسلام والإيمان به، رضي الله عنها وأرضاها. [السعدي:٦١٢]</p><p>السؤال: هل انتفعت امرأة فرعون من شفقتها على موسى؟</p><p>٥- <span class="qpc-hafs">﴿وَأَصْبَحَ فُؤَادُ أُمِّ مُوسَىٰ فَٰرِغًا ۖ إِن كَادَتْ لَتُبْدِى بِهِۦ لَوْلَآ أَن رَّبَطْنَا عَلَىٰ قَلْبِهَا لِتَكُونَ مِنَ ٱلْمُؤْمِنِينَ﴾</span></p><p>فإن العبد إذا أصابته مصيبة فصبر وثبت ازداد بذلك إيمانه، ودل ذلك على أن استمرار الجزع مع العبد دليل على ضعف إيمانه. [السعدي:٦١٣]</p><p>السؤال: ما علاقة الجزع بزيادة الإيمان ونقصانه؟</p><p>٦- <span class="qpc-hafs">﴿وَأَصْبَحَ فُؤَادُ أُمِّ مُوسَىٰ فَٰرِغًا ۖ إِن كَادَتْ لَتُبْدِى بِهِۦ لَوْلَآ أَن رَّبَطْنَا عَلَىٰ قَلْبِهَا لِتَكُونَ مِنَ ٱلْمُؤْمِنِينَ﴾</span></p><p>قيل: فارغا من كل شيء إلا من ذكر موسى. [ابن تيمية:١٠/٢١٩]</p><p>السؤال: حب الأم لأولادها عظيم، بين ذلك من خلال الآية.</p><p>٧- <span class="qpc-hafs">﴿وَقَالَتِ ٱمْرَأَتُ فِرْعَوْنَ قُرَّتُ عَيْنٍ لِّى وَلَكَ ۖ لَا تَقْتُلُوهُ عَسَىٰٓ أَن يَنفَعَنَآ أَوْ نَتَّخِذَهُۥ وَلَدًا وَهُمْ لَا يَشْعُرُونَ﴾</span></p><p>وجود الصالحين من بين المفسدين يخفف من لأواء فساد المفسدين؛ فإن وجود امرأة فرعون كان سبباً في صد فرعون عن قتل الطفل؛ مع أنه تحقق أنه إسرائيلي. [ابن عاشور:٢٠/٨٦]</p><p>السؤال: وجود الصالحين بين المفسدين يخفف من الفساد، بين ذلك؟</p><h3>التوجيهات</h3><p>١- التمكين في الأرض يحتاج إلى صبر، وإعداد، وبذل جهد, <span class="qpc-hafs">﴿وَنُمَكِّنَ لَهُمْ فِى ٱلْأَرْضِ وَنُرِىَ فِرْعَوْنَ وَهَٰمَٰنَ وَجُنُودَهُمَا مِنْهُم مَّا كَانُوا۟ يَحْذَرُونَ﴾</span></p><p>٢- قد تأتي المنح مع المحن؛ فإن الله تعالى يَعِدُ أم موسى في لحظة كربتها بالفرج مع فضل عظيم، وهو جعل ابنها نبيا مرسلا، <span class="qpc-hafs">﴿وَلَا تَخَافِى وَلَا تَحْزَنِىٓ ۖ إِنَّا رَآدُّوهُ إِلَيْكِ وَجَاعِلُوهُ مِنَ ٱلْمُرْسَلِينَ﴾</span></p><p>٣- الصبر عند المصائب منة من الله تعالى، فاسأل الله إياها، <span class="qpc-hafs">﴿لَوْلَآ أَن رَّبَطْنَا عَلَىٰ قَلْبِهَا لِتَكُونَ مِنَ ٱلْمُؤْمِنِينَ﴾</span></p><h3>العمل بالآيات</h3><p>١- وجه رسالة إلى أسرة ظلم أحد أفرادها وبشرهم بهذه الآية: <span class="qpc-hafs">﴿وَلَا تَحْزَنِىٓ ۖ إِنَّا رَآدُّوهُ إِلَيْكِ وَجَاعِلُوهُ مِنَ ٱلْمُرْسَلِينَ﴾</span></p><p>٢- سل الله تعالى أن يجعل زوجتك وذريتك قرة عين لك, <span class="qpc-hafs">﴿وَقَالَتِ ٱمْرَأَتُ فِرْعَوْنَ قُرَّتُ عَيْنٍ لِّى وَلَكَ ۖ لَا تَقْتُلُوهُ عَسَىٰٓ أَن يَنفَعَنَآ أَوْ نَتَّخِذَهُۥ وَلَدًا﴾</span></p><p>٣- ادع الله تعالى أن يربط على قلبك، ويثبتك في السراء والضراء, <span class="qpc-hafs">﴿لَوْلَآ أَن رَّبَطْنَا عَلَىٰ قَلْبِهَا لِتَكُونَ مِنَ ٱلْمُؤْمِنِينَ﴾</span></p><h3>معاني الكلمات</h3><p><span class="qpc-hafs">﴿الْيَمِّ﴾</span> النَّهْرِ، وَهُوَ نَهْرُ النِّيلِ.</p><p><span class="qpc-hafs">﴿خَاطِئِينَ﴾</span> آثِمِينَ.</p><p><span class="qpc-hafs">﴿قُرَّةُ عَيْنٍ لِي﴾</span> مَصْدَرُ سُرُورٍ لِي.</p><p><span class="qpc-hafs">﴿فَارِغًا﴾</span> خَالِيًا مِنْ كُلِّ شَيْءٍ إِلاَّ هَمَّ مُوسَى عليه السلام.</p><p><span class="qpc-hafs">﴿لَتُبْدِي بِهِ﴾</span> فَتُصَرِّحُ بِأَنَّهُ ابْنُهَا.</p><p><span class="qpc-hafs">﴿قُصِّيهِ﴾</span> تَتَبَّعِي أَثَرَهُ.</p><p><span class="qpc-hafs">﴿عَنْ جُنُبٍ﴾</span> عَنْ بُعْدٍ.</p><p><span class="qpc-hafs">﴿يَكْفُلُونَهُ لَكُمْ﴾</span> يَقُومُونَ بِتَرْبِيَتِهِ وَإِرْضَاعِهِ.</p></div>"
