quran[8]{c,v,t}:
  28,6,"

الوقفات التدبرية

١- <q>﴿وَأَوْحَيْنَآ إِلَىٰٓ أُمِّ مُوسَىٰٓ أَنْ أَرْضِعِيهِ ۖ فَإِذَا خِفْتِ عَلَيْهِ فَأَلْقِيهِ فِى ٱلْيَمِّ وَلَا تَخَافِى وَلَا تَحْزَنِىٓ ۖ إِنَّا رَآدُّوهُ إِلَيْكِ وَجَاعِلُوهُ مِنَ ٱلْمُرْسَلِينَ﴾</q>

فبين أنه يلهم المؤمنين الإيمان وما ينفعهم؛ وذلك إيحاء إليهم وإن لم يكونوا أنبياء. [ابن تيمية:٥/٧٠]

السؤال: بينت الآية الكريمة فضل الله تعالى على المؤمنين، بين ذلك؟

٢- <q>﴿وَأَوْحَيْنَآ إِلَىٰٓ أُمِّ مُوسَىٰٓ أَنْ أَرْضِعِيهِ ۖ فَإِذَا خِفْتِ عَلَيْهِ فَأَلْقِيهِ فِى ٱلْيَمِّ وَلَا تَخَافِى وَلَا تَحْزَنِ﴾</q> إلى قوله تعالى: <q>﴿وَقَالَتْ لِأُخْتِهِۦ قُصِّيهِ﴾</q>

إن العبد ولو عرف أن القضاء والقدر ووعد الله نافذ لا بد منه فإنه لا يهمل فعل الأسباب التي أُمِرَ بها، ولا يكون ذلك منافياً لإيمانه بخبر الله؛ فإن الله قد وعد أم موسى أن يرده عليها، ومع ذلك اجتهدت في رده، وأرسلت أخته لتقصه وتطلبه. [السعدي:٦١٩]

السؤال: إرسال أم موسى أخته لتنظر ماذا حصل في أمره، هل ينافي الإيمان بوعد الله سبحانه وتعالى؟

٣- <q>﴿وَقَالَتِ ٱمْرَأَتُ فِرْعَوْنَ قُرَّتُ عَيْنٍ لِّى وَلَكَ ۖ لَا تَقْتُلُوهُ عَسَىٰٓ أَن يَنفَعَنَآ أَوْ نَتَّخِذَهُۥ وَلَدًا وَهُمْ لَا يَشْعُرُونَ﴾</q>

وإنما أمرها الله بإرضاعه لتقوى بُنيته بلبان أمه؛ فإنه أسعد بالطفل في أول عمره من لبان غيرها، وليكون له من الرضاعة الأخيرة- قبل إلقائه في اليمّ- قوت يشد بنيته فيما بين قذفه في اليم وبين التقاط آل فرعون إياه، وإيصاله إلى بيت فرعون. [ابن عاشور:٢٠/٧٣]

السؤال: لماذا أمرت أم موسى بإرضاعه قبل إلقائه في البحر؟

٤- <q>﴿عَسَىٰٓ أَن يَنفَعَنَآ أَوْ نَتَّخِذَهُۥ وَلَدًا﴾</q>

فقَدَّر الله تعالى أنه نفع امرأة فرعون التي قالت تلك المقالة؛ فإنه لما صار قرة عين لها، وأحبته حباً شديداً، فلم يزل لها بمنْزلة الولد الشفيق حتى كبر، ونبأه الله وأرسله، فبادرت إلى الإسلام والإيمان به، رضي الله عنها وأرضاها. [السعدي:٦١٢]

السؤال: هل انتفعت امرأة فرعون من شفقتها على موسى؟

٥- <q>﴿وَأَصْبَحَ فُؤَادُ أُمِّ مُوسَىٰ فَٰرِغًا ۖ إِن كَادَتْ لَتُبْدِى بِهِۦ لَوْلَآ أَن رَّبَطْنَا عَلَىٰ قَلْبِهَا لِتَكُونَ مِنَ ٱلْمُؤْمِنِينَ﴾</q>

فإن العبد إذا أصابته مصيبة فصبر وثبت ازداد بذلك إيمانه، ودل ذلك على أن استمرار الجزع مع العبد دليل على ضعف إيمانه. [السعدي:٦١٣]

السؤال: ما علاقة الجزع بزيادة الإيمان ونقصانه؟

٦- <q>﴿وَأَصْبَحَ فُؤَادُ أُمِّ مُوسَىٰ فَٰرِغًا ۖ إِن كَادَتْ لَتُبْدِى بِهِۦ لَوْلَآ أَن رَّبَطْنَا عَلَىٰ قَلْبِهَا لِتَكُونَ مِنَ ٱلْمُؤْمِنِينَ﴾</q>

قيل: فارغا من كل شيء إلا من ذكر موسى. [ابن تيمية:١٠/٢١٩]

السؤال: حب الأم لأولادها عظيم، بين ذلك من خلال الآية.

٧- <q>﴿وَقَالَتِ ٱمْرَأَتُ فِرْعَوْنَ قُرَّتُ عَيْنٍ لِّى وَلَكَ ۖ لَا تَقْتُلُوهُ عَسَىٰٓ أَن يَنفَعَنَآ أَوْ نَتَّخِذَهُۥ وَلَدًا وَهُمْ لَا يَشْعُرُونَ﴾</q>

وجود الصالحين من بين المفسدين يخفف من لأواء فساد المفسدين؛ فإن وجود امرأة فرعون كان سبباً في صد فرعون عن قتل الطفل؛ مع أنه تحقق أنه إسرائيلي. [ابن عاشور:٢٠/٨٦]

السؤال: وجود الصالحين بين المفسدين يخفف من الفساد، بين ذلك؟

التوجيهات

١- التمكين في الأرض يحتاج إلى صبر، وإعداد، وبذل جهد, <q>﴿وَنُمَكِّنَ لَهُمْ فِى ٱلْأَرْضِ وَنُرِىَ فِرْعَوْنَ وَهَٰمَٰنَ وَجُنُودَهُمَا مِنْهُم مَّا كَانُوا۟ يَحْذَرُونَ﴾</q>

٢- قد تأتي المنح مع المحن؛ فإن الله تعالى يَعِدُ أم موسى في لحظة كربتها بالفرج مع فضل عظيم، وهو جعل ابنها نبيا مرسلا، <q>﴿وَلَا تَخَافِى وَلَا تَحْزَنِىٓ ۖ إِنَّا رَآدُّوهُ إِلَيْكِ وَجَاعِلُوهُ مِنَ ٱلْمُرْسَلِينَ﴾</q>

٣- الصبر عند المصائب منة من الله تعالى، فاسأل الله إياها، <q>﴿لَوْلَآ أَن رَّبَطْنَا عَلَىٰ قَلْبِهَا لِتَكُونَ مِنَ ٱلْمُؤْمِنِينَ﴾</q>

العمل بالآيات

١- وجه رسالة إلى أسرة ظلم أحد أفرادها وبشرهم بهذه الآية: <q>﴿وَلَا تَحْزَنِىٓ ۖ إِنَّا رَآدُّوهُ إِلَيْكِ وَجَاعِلُوهُ مِنَ ٱلْمُرْسَلِينَ﴾</q>

٢- سل الله تعالى أن يجعل زوجتك وذريتك قرة عين لك, <q>﴿وَقَالَتِ ٱمْرَأَتُ فِرْعَوْنَ قُرَّتُ عَيْنٍ لِّى وَلَكَ ۖ لَا تَقْتُلُوهُ عَسَىٰٓ أَن يَنفَعَنَآ أَوْ نَتَّخِذَهُۥ وَلَدًا﴾</q>

٣- ادع الله تعالى أن يربط على قلبك، ويثبتك في السراء والضراء, <q>﴿لَوْلَآ أَن رَّبَطْنَا عَلَىٰ قَلْبِهَا لِتَكُونَ مِنَ ٱلْمُؤْمِنِينَ﴾</q>

معاني الكلمات

<q>﴿الْيَمِّ﴾</q> النَّهْرِ، وَهُوَ نَهْرُ النِّيلِ.

<q>﴿خَاطِئِينَ﴾</q> آثِمِينَ.

<q>﴿قُرَّةُ عَيْنٍ لِي﴾</q> مَصْدَرُ سُرُورٍ لِي.

<q>﴿فَارِغًا﴾</q> خَالِيًا مِنْ كُلِّ شَيْءٍ إِلاَّ هَمَّ مُوسَى عليه السلام.

<q>﴿لَتُبْدِي بِهِ﴾</q> فَتُصَرِّحُ بِأَنَّهُ ابْنُهَا.

<q>﴿قُصِّيهِ﴾</q> تَتَبَّعِي أَثَرَهُ.

<q>﴿عَنْ جُنُبٍ﴾</q> عَنْ بُعْدٍ.

<q>﴿يَكْفُلُونَهُ لَكُمْ﴾</q> يَقُومُونَ بِتَرْبِيَتِهِ وَإِرْضَاعِهِ.

