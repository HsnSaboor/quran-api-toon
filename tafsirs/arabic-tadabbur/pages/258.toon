quran[6]{c,v,t}:
  14,19,"

الوقفات التدبرية

١- <q>﴿أَلَمْ تَرَ أَنَّ ٱللَّهَ خَلَقَ ٱلسَّمَٰوَٰتِ وَٱلْأَرْضَ بِٱلْحَقِّ ۚ إِن يَشَأْ يُذْهِبْكُمْ وَيَأْتِ بِخَلْقٍ جَدِيدٍ﴾</q>

<q>﴿إن يشأ يذهبكم ويأت بخلق جديد﴾</q> أي: هو قادر على الإفناء كما قدر على إيجاد الأشياء؛ فلا تعصوه، فإنكم إن عصيتموه <q>﴿يذهبكم ويأت بخلق جديد﴾</q> أفضل، وأطوع منكم. [القرطبي:١٢/١٢٥]

السؤال: ما العقوبة التي ستحل بنا إن تركنا طاعة الله، وآثرنا شهوات أنفسنا؟

٢- <q>﴿وَقَالَ ٱلشَّيْطَٰنُ لَمَّا قُضِىَ ٱلْأَمْرُ إِنَّ ٱللَّهَ وَعَدَكُمْ وَعْدَ ٱلْحَقِّ﴾</q>

فقام فيهم إبليس -لعنه الله- يومئذ خطيباً؛ ليزيدهم حزناً إلى حزنهم، وغبناً إلى غبنهم، وحسرة إلى حسرتهم. [ابن كثير:٢/٥١٠]

السؤال: ما الحكمة من خطبة إبليس في المعذبين في النار؟

٣- <q>﴿وَقَالَ ٱلشَّيْطَٰنُ لَمَّا قُضِىَ ٱلْأَمْرُ إِنَّ ٱللَّهَ وَعَدَكُمْ وَعْدَ ٱلْحَقِّ وَوَعَدتُّكُمْ فَأَخْلَفْتُكُمْ﴾</q>

حكى الله تعالى عنه ما سيقوله في ذلك الوقت ليكون تنبيهاً للسامعين، وحثاً لهم على النظر في عاقبتهم، والاستعداد لما لا بد منه، وأن يتصوروا ذلك المقام الذي يقول فيه الشيطان ما يقول؛ فيخافوا، ويعملوا ما ينفعهم هناك. [الألوسي:١٤/٢٦٦]

السؤال: ما الحكمة من إعلامنا بما سيقوله الشيطان لأتباعه يوم القيامة؟

٤- <q>﴿وَمَا كَانَ لِىَ عَلَيْكُم مِّن سُلْطَٰنٍ إِلَّآ أَن دَعَوْتُكُمْ فَٱسْتَجَبْتُمْ لِى ۖ فَلَ﴾</q>

وهم الذين سلطوه على أنفسهم بموالاته والالتحاق بحزبه؛ ولهذا ليس له سلطان على الذين آمنوا، وعلى ربهم يتوكلون. [السعدي:٤٢٥]

السؤال: ما صفة من ثبت عليه سلطان الشيطان؟

٥- <q>﴿وَمَا كَانَ لِىَ عَلَيْكُم مِّن سُلْطَٰنٍ إِلَّآ أَن دَعَوْتُكُمْ فَٱسْتَجَبْتُمْ لِى﴾</q>

واعلم أن الله ذكر في هذه الآية أنه ليس له سلطان، وقال في آية أخرى: <q>﴿إنما سلطانه على الذين يتولونه والذين هم به مشركون﴾</q> [النحل: ١٠٠]، فالسلطان الذي نفاه عنه هو سلطان الحجة والدليل، فليس له حجة أصلاً على ما يدعو إليه، وإنما نهاية ذلك أن يقيم لهم من الشبه والتزيينات ما به يتجرؤون على المعاصي. وأما السلطان الذي أثبته فهو التسلط بالإغراء على المعاصي لأوليائه؛ يؤزهم إلى المعاصي أزاً. [السعدي:٤٢٥]

السؤال: نُفِيَ السلطان عن إبليس في آية، وأُثْبِتَ له في آية أخرى، فكيف تجمع بينهما؟

٦- <q>﴿تَحِيَّتُهُمْ فِيهَا سَلَٰمٌ﴾</q>

يسلم بعضهم على بعض، وتسلم الملائكة عليهم . [القرطبي:٢/٥٥٥]

السؤال: السلام أفضل أنواع التحية، ما الدليل على ذلك؟

٧- <q>﴿أَلَمْ تَرَ كَيْفَ ضَرَبَ ٱللَّهُ مَثَلًا كَلِمَةً طَيِّبَةً كَشَجَرَةٍ طَيِّبَةٍ أَصْلُهَا ثَابِتٌ وَفَرْعُهَا فِى ٱلسَّمَآءِ﴾</q>

فالكلمة الطيبة: التوحيد، وهي كالشجرة، والأعمال ثمارها في كل وقت. [ابن تيمية:٤/١١٠]

السؤال: الكلمة الطيبة هي التوحيد، والأعمال ثمارها، بين ذلك.

التوجيهات

١- موقف الضعفاء من المتكبرين يوم القيامة يجعلك لا تجامل أحداً في أمر الدين، ويحملك على اتباع الشرع لا الأشخاص، <q>﴿فَقَالَ ٱلضُّعَفَٰٓؤُا۟ لِلَّذِينَ ٱسْتَكْبَرُوٓا۟ إِنَّا كُنَّا لَكُمْ تَبَعًا فَهَلْ أَنتُم مُّغْنُونَ عَنَّا مِنْ عَذَابِ ٱللَّهِ مِن شَىْءٍ ۚ قَالُوا۟ لَوْ هَدَىٰنَا ٱللَّهُ لَهَدَيْنَٰكُمْ﴾</q>

٢- أكثر ما يتمناه المشركون يوم القيامة: الهداية، فاحرص عليها في الدنيا ما دمت تقدر عليها، <q>﴿قَالُوا۟ لَوْ هَدَىٰنَا ٱللَّهُ لَهَدَيْنَٰكُمْ﴾</q>

٣- اصبر على الطاعات، وعن المعاصي قبل أن يأتي يومٌ لا ينفع فيه صبرٌ أو جزع، <q>﴿ۖ سَوَآءٌ عَلَيْنَآ أَجَزِعْنَآ أَمْ صَبَرْنَا مَا لَنَا مِن مَّحِيصٍ﴾</q>

العمل بالآيات

١- لا تأمن الشيطان، وأكثر من الاستعاذة بالله منه؛ فإنه سبب كل بلاء، <q>﴿ۖ وَمَا كَانَ لِىَ عَلَيْكُم مِّن سُلْطَٰنٍ إِلَّآ أَن دَعَوْتُكُمْ فَٱسْتَجَبْتُمْ لِى﴾</q>

٢- اجلس مع نفسك جلسة محاسبة، وراجع ما مضى من عملك, <q>﴿فَلَا تَلُومُونِى وَلُومُوٓا۟ أَنفُسَكُم﴾</q>

٣- اقرأ شرحاً لكلمة التوحيد: «لا إله إلا الله»، وشروطها، وأركانها، وتأمل في معانيها، <q>﴿أَلَمْ تَرَ كَيْفَ ضَرَبَ ٱللَّهُ مَثَلًا كَلِمَةً طَيِّبَةً كَشَجَرَةٍ طَيِّبَةٍ أَصْلُهَا ثَابِتٌ وَفَرْعُهَا فِى ٱلسَّمَآءِ﴾</q>

معاني الكلمات

<q>﴿سَوَاءٌ عَلَيْنَا﴾</q> يَسْتَوِي عَلَيْنَا وَعَلَيْكُمْ.

<q>﴿مَحِيصٍ﴾</q> مَهْرَبٍ.

<q>﴿سُلْطَانٍ﴾</q> حُجَّةٍ وَقُوَّةٍ أَقْهَرُكُمْ بِهَا عَلَى اتِّبَاعِي.

<q>﴿بِمُصْرِخِكُمْ﴾</q> بِمُغِيثِكُمْ.

<q>﴿كَفَرْتُ﴾</q> تَبَرَّأْتُ.

<q>﴿كَلِمَةً طِيِّبَةً﴾</q> هِيَ كَلِمَةُ التَّوْحِيدِ «لا إِلَهَ إِلاَّ اللهِ».

<q>﴿كَشَجَرَةٍ طَيِّبَةٍ﴾</q> هِيَ: النَّخْلَةُ.

