quran[10]{c,v,t}:
  45,23,"

الوقفات التدبرية

١- <q>﴿أَفَرَءَيْتَ مَنِ ٱتَّخَذَ إِلَٰهَهُۥ هَوَىٰهُ وَأَضَلَّهُ ٱللَّهُ عَلَىٰ عِلْمٍ وَخَتَمَ عَلَىٰ سَمْعِهِۦ وَقَلْبِهِۦ وَجَعَلَ عَلَىٰ بَصَرِهِۦ غِشَٰوَةً فَمَن يَهْدِيهِ مِنۢ بَعْدِ ٱللَّهِ ۚ أَفَلَا تَذَكَّرُونَ﴾</q>

<q>﴿اتخذ إلهه هواه﴾</q> أي: أطاعه حتى صار له كالإله. [ابن جزي:٢/٣٢٨]

السؤال: كيف يكون الهوى معبودا من دون الله؟

٢- <q>﴿أَفَرَءَيْتَ مَنِ ٱتَّخَذَ إِلَٰهَهُۥ هَوَىٰهُ وَأَضَلَّهُ ٱللَّهُ عَلَىٰ عِلْمٍ وَخَتَمَ عَلَىٰ سَمْعِهِۦ وَقَلْبِهِۦ وَجَعَلَ عَلَىٰ بَصَرِهِۦ غِشَٰوَةً فَمَن يَهْدِيهِ مِنۢ بَعْدِ ٱللَّهِ ۚ أَفَلَا تَذَكَّرُونَ﴾</q>

وفيها مِن ذَمِّ اتباع هوى النفس ما فيها، وعن ابن عباس: ما ذَكَرَ اللّه تعالى هوى إلا ذمه. وقال وهب: إذا شككتَ في خير أمرين فانظر أبعدهما مِن هواك فأته، وقال سهل التستري: هواك داؤك، فإن خالفته فدواؤك. [الألوسي:٢٥/٢٠٩]

السؤال: كيف يتعامل العاقل مع ما تهواه نفسه وتشتهيه من المعاصي والمنكرات؟

٣- <q>﴿أَفَرَءَيْتَ مَنِ ٱتَّخَذَ إِلَٰهَهُۥ هَوَىٰهُ وَأَضَلَّهُ ٱللَّهُ عَلَىٰ عِلْمٍ وَخَتَمَ عَلَىٰ سَمْعِهِۦ وَقَلْبِهِۦ وَجَعَلَ عَلَىٰ بَصَرِهِۦ غِشَٰوَةً فَمَن يَهْدِيهِ مِنۢ بَعْدِ ٱللَّهِ ۚ أَفَلَا تَذَكَّرُونَ﴾</q>

وهذه الآية أصل في التحذير من أن يكون الهوى الباعث للمؤمنين على أعمالهم، ويتركوا اتباع أدلة الحق، فإذا كان الحق محبوباً لأحد فذلك من التخلق بمحبة الحق تبعاً للدليل؛ مثل ما يهوى المؤمن الصلاة والجماعة وقيامَ رمضان وتلاوة القرآن. وفي الحديث: <q>﴿أرِحنا بها يا بلال﴾</q> يعني الإقامة للصلاة ... وأَما اتباع الأمرِ الْمحبوب لإِرضاء النفْسِ دون نظَرٍ في صلاحه أَو فَساده فَذلكَ سبب الضلالِ وسوء السيرة. [ابن عاشور:٢٥/٣٥٩]

السؤال: قررت الآية الكريمة أصلاً مهمًا في اتباع هوى النفس، ما هو؟

٤- <q>﴿وَإِذَا تُتْلَىٰ عَلَيْهِمْ ءَايَٰتُنَا بَيِّنَٰتٍ مَّا كَانَ حُجَّتَهُمْ إِلَّآ أَن قَالُوا۟ ٱئْتُوا۟ بِـَٔابَآئِنَآ إِن كُنتُمْ صَٰدِقِينَ﴾</q>

لم يجبهم إلى إحياء آبائهم إكراماً لهذه الأمة، لشرف نبيها عليه أفضل الصلاة والسلام؛ لأنَّ سنته الإلهية جرت بأنَّ مَن لم يؤمن بعد كشف الأمر بإيجاد الآيات المقترحات أهلكه, كما فعل بالأمم الماضية. [البقاعي:٧/١٠٦]

السؤال: من إكرام هذه الأمة عدم الاستجابة لمقترحات المشركين من إحياء آبائهم، وضح ذلك.

٥- <q>﴿وَإِذَا تُتْلَىٰ عَلَيْهِمْ ءَايَٰتُنَا بَيِّنَٰتٍ مَّا كَانَ حُجَّتَهُمْ إِلَّآ أَن قَالُوا۟ ٱئْتُوا۟ بِـَٔابَآئِنَآ إِن كُنتُمْ صَٰدِقِينَ﴾</q>

قال الزمخشري: فإن قلت لم سمي قولهم حجة وليس بحجة؟ قلت: لأنهم أدلوا به كما يدلي المحتج بحجته، وساقوه مساقها، فسميت حجة على سبيل التهكم. أو لأنه في حسبانهم وتقديرهم حجة. أو...كأنه قيل: ما كان حجتهم إلا ما ليس بحجة. والمراد نفي أن تكون لهم حجة البتة. [القرطبي:١٩/١٦٧]

السؤال: لم سمى الله تعالى قولهم حجة؟

٦- <q>﴿وَتَرَىٰ كُلَّ أُمَّةٍ جَاثِيَةً﴾</q>

على رُكَبها خوفاً وذعراً، وانتظاراً لحكم الملك الرحمن. [السعدي:٧٧٨]

السؤال: ما سبب جثو الأمم يوم القيامة؟

٧- <q>﴿فَأَمَّا ٱلَّذِينَ ءَامَنُوا۟ وَعَمِلُوا۟ ٱلصَّٰلِحَٰتِ فَيُدْخِلُهُمْ رَبُّهُمْ فِى رَحْمَتِهِۦ ۚ ذَٰلِكَ هُوَ ٱلْفَوْزُ ٱلْمُبِينُ﴾</q>

وابتدىء في التفصيل بوصف حال المؤمنين مع أن المقام للحديث عن المبطلين في قوله: <q>﴿يومئذ يخسر المبطلون﴾</q> تنويهاً بالمؤمنين، وتعجيلاً لمسرتهم، وتعجيلاً لمساءة المبطلين. [ابن عاشور:٢٥/٣٧١]

السؤال: مظاهر إكرام الله تعالى للمؤمنين متعددة، بين أحدها من خلال الآية الكريمة.

التوجيهات

١- اعلم أن أعظم الخذلان أن يضلك الله تعالى وأنت على علم، <q>﴿أَفَرَءَيْتَ مَنِ ٱتَّخَذَ إِلَٰهَهُۥ هَوَىٰهُ وَأَضَلَّهُ ٱللَّهُ عَلَىٰ عِلْمٍ﴾</q>

٢- هدايتك وسعادتك ونجاحك بيد الله وحده فاطلبها منه، <q>﴿فَمَن يَهْدِيهِ مِنۢ بَعْدِ ٱللَّهِ ۚ أَفَلَا تَذَكَّرُونَ﴾</q>

٣- حاسب نفسك قبل أن تحاسب، <q>﴿هَٰذَا كِتَٰبُنَا يَنطِقُ عَلَيْكُم بِٱلْحَقِّ﴾</q>

العمل بالآيات

١- حاول تعداد أخطائك ومعاصيك التي فعلتها أو نطقت بها الأسبوع الماضي فقط، <q>﴿هَٰذَا كِتَٰبُنَا يَنطِقُ عَلَيْكُم بِٱلْحَقِّ﴾</q>

٢- قل: «اللهم اجعل في قلبي نورا وفي سمعي نورا وفي بصري نورا»، <q>﴿أَفَرَءَيْتَ مَنِ ٱتَّخَذَ إِلَٰهَهُۥ هَوَىٰهُ وَأَضَلَّهُ ٱللَّهُ عَلَىٰ عِلْمٍ وَخَتَمَ عَلَىٰ سَمْعِهِۦ وَقَلْبِهِۦ وَجَعَلَ عَلَىٰ بَصَرِهِۦ غِشَٰوَةً فَمَن يَهْدِيهِ مِنۢ بَعْدِ ٱللَّهِ ۚ أَفَلَا تَذَكَّرُونَ﴾</q>

٣- قل: «اللهم اهدني فيمن هديت، وعافني فيمن عافيت، وتولني فيمن توليت»، <q>﴿فَمَن يَهْدِيهِ مِنۢ بَعْدِ ٱللَّهِ ۚ أَفَلَا تَذَكَّرُونَ﴾</q>

معاني الكلمات

<q>﴿أَفَرَأَيْتَ﴾</q> أَخْبِرْنِي.

<q>﴿وَخَتَمَ﴾</q> طَبَعَ.

<q>﴿غِشَاوَةً﴾</q> غِطَاءً.

<q>﴿لاَ رَيْبَ فِيهِ﴾</q> لاَ شَكَّ فِيهِ.

<q>﴿إِنْ نَظُنُّ إِلاَّ ظَنًّا﴾</q> مَا نَتَوَقَّعُ وُقُوعَهَا إِلاَّ تَوَهُّمًا.

