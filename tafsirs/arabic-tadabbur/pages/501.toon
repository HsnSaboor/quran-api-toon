quran[10]{c,v,t}:
  45,23,"<div class=ar lang=ar><h3>الوقفات التدبرية</h3><p>١- <span class="qpc-hafs">﴿أَفَرَءَيْتَ مَنِ ٱتَّخَذَ إِلَٰهَهُۥ هَوَىٰهُ وَأَضَلَّهُ ٱللَّهُ عَلَىٰ عِلْمٍ وَخَتَمَ عَلَىٰ سَمْعِهِۦ وَقَلْبِهِۦ وَجَعَلَ عَلَىٰ بَصَرِهِۦ غِشَٰوَةً فَمَن يَهْدِيهِ مِنۢ بَعْدِ ٱللَّهِ ۚ أَفَلَا تَذَكَّرُونَ﴾</span></p><p><span class="qpc-hafs">﴿اتخذ إلهه هواه﴾</span> أي: أطاعه حتى صار له كالإله. [ابن جزي:٢/٣٢٨]</p><p>السؤال: كيف يكون الهوى معبودا من دون الله؟</p><p>٢- <span class="qpc-hafs">﴿أَفَرَءَيْتَ مَنِ ٱتَّخَذَ إِلَٰهَهُۥ هَوَىٰهُ وَأَضَلَّهُ ٱللَّهُ عَلَىٰ عِلْمٍ وَخَتَمَ عَلَىٰ سَمْعِهِۦ وَقَلْبِهِۦ وَجَعَلَ عَلَىٰ بَصَرِهِۦ غِشَٰوَةً فَمَن يَهْدِيهِ مِنۢ بَعْدِ ٱللَّهِ ۚ أَفَلَا تَذَكَّرُونَ﴾</span></p><p>وفيها مِن ذَمِّ اتباع هوى النفس ما فيها، وعن ابن عباس: ما ذَكَرَ اللّه تعالى هوى إلا ذمه. وقال وهب: إذا شككتَ في خير أمرين فانظر أبعدهما مِن هواك فأته، وقال سهل التستري: هواك داؤك، فإن خالفته فدواؤك. [الألوسي:٢٥/٢٠٩]</p><p>السؤال: كيف يتعامل العاقل مع ما تهواه نفسه وتشتهيه من المعاصي والمنكرات؟</p><p>٣- <span class="qpc-hafs">﴿أَفَرَءَيْتَ مَنِ ٱتَّخَذَ إِلَٰهَهُۥ هَوَىٰهُ وَأَضَلَّهُ ٱللَّهُ عَلَىٰ عِلْمٍ وَخَتَمَ عَلَىٰ سَمْعِهِۦ وَقَلْبِهِۦ وَجَعَلَ عَلَىٰ بَصَرِهِۦ غِشَٰوَةً فَمَن يَهْدِيهِ مِنۢ بَعْدِ ٱللَّهِ ۚ أَفَلَا تَذَكَّرُونَ﴾</span></p><p>وهذه الآية أصل في التحذير من أن يكون الهوى الباعث للمؤمنين على أعمالهم، ويتركوا اتباع أدلة الحق، فإذا كان الحق محبوباً لأحد فذلك من التخلق بمحبة الحق تبعاً للدليل؛ مثل ما يهوى المؤمن الصلاة والجماعة وقيامَ رمضان وتلاوة القرآن. وفي الحديث: <span class="qpc-hafs">﴿أرِحنا بها يا بلال﴾</span> يعني الإقامة للصلاة ... وأَما اتباع الأمرِ الْمحبوب لإِرضاء النفْسِ دون نظَرٍ في صلاحه أَو فَساده فَذلكَ سبب الضلالِ وسوء السيرة. [ابن عاشور:٢٥/٣٥٩]</p><p>السؤال: قررت الآية الكريمة أصلاً مهمًا في اتباع هوى النفس، ما هو؟</p><p>٤- <span class="qpc-hafs">﴿وَإِذَا تُتْلَىٰ عَلَيْهِمْ ءَايَٰتُنَا بَيِّنَٰتٍ مَّا كَانَ حُجَّتَهُمْ إِلَّآ أَن قَالُوا۟ ٱئْتُوا۟ بِـَٔابَآئِنَآ إِن كُنتُمْ صَٰدِقِينَ﴾</span></p><p>لم يجبهم إلى إحياء آبائهم إكراماً لهذه الأمة، لشرف نبيها عليه أفضل الصلاة والسلام؛ لأنَّ سنته الإلهية جرت بأنَّ مَن لم يؤمن بعد كشف الأمر بإيجاد الآيات المقترحات أهلكه, كما فعل بالأمم الماضية. [البقاعي:٧/١٠٦]</p><p>السؤال: من إكرام هذه الأمة عدم الاستجابة لمقترحات المشركين من إحياء آبائهم، وضح ذلك.</p><p>٥- <span class="qpc-hafs">﴿وَإِذَا تُتْلَىٰ عَلَيْهِمْ ءَايَٰتُنَا بَيِّنَٰتٍ مَّا كَانَ حُجَّتَهُمْ إِلَّآ أَن قَالُوا۟ ٱئْتُوا۟ بِـَٔابَآئِنَآ إِن كُنتُمْ صَٰدِقِينَ﴾</span></p><p>قال الزمخشري: فإن قلت لم سمي قولهم حجة وليس بحجة؟ قلت: لأنهم أدلوا به كما يدلي المحتج بحجته، وساقوه مساقها، فسميت حجة على سبيل التهكم. أو لأنه في حسبانهم وتقديرهم حجة. أو...كأنه قيل: ما كان حجتهم إلا ما ليس بحجة. والمراد نفي أن تكون لهم حجة البتة. [القرطبي:١٩/١٦٧]</p><p>السؤال: لم سمى الله تعالى قولهم حجة؟</p><p>٦- <span class="qpc-hafs">﴿وَتَرَىٰ كُلَّ أُمَّةٍ جَاثِيَةً﴾</span></p><p>على رُكَبها خوفاً وذعراً، وانتظاراً لحكم الملك الرحمن. [السعدي:٧٧٨]</p><p>السؤال: ما سبب جثو الأمم يوم القيامة؟</p><p>٧- <span class="qpc-hafs">﴿فَأَمَّا ٱلَّذِينَ ءَامَنُوا۟ وَعَمِلُوا۟ ٱلصَّٰلِحَٰتِ فَيُدْخِلُهُمْ رَبُّهُمْ فِى رَحْمَتِهِۦ ۚ ذَٰلِكَ هُوَ ٱلْفَوْزُ ٱلْمُبِينُ﴾</span></p><p>وابتدىء في التفصيل بوصف حال المؤمنين مع أن المقام للحديث عن المبطلين في قوله: <span class="qpc-hafs">﴿يومئذ يخسر المبطلون﴾</span> تنويهاً بالمؤمنين، وتعجيلاً لمسرتهم، وتعجيلاً لمساءة المبطلين. [ابن عاشور:٢٥/٣٧١]</p><p>السؤال: مظاهر إكرام الله تعالى للمؤمنين متعددة، بين أحدها من خلال الآية الكريمة.</p><h3>التوجيهات</h3><p>١- 	اعلم أن أعظم الخذلان أن يضلك الله تعالى وأنت على علم، <span class="qpc-hafs">﴿أَفَرَءَيْتَ مَنِ ٱتَّخَذَ إِلَٰهَهُۥ هَوَىٰهُ وَأَضَلَّهُ ٱللَّهُ عَلَىٰ عِلْمٍ﴾</span></p><p>٢- 	هدايتك وسعادتك ونجاحك بيد الله وحده فاطلبها منه، <span class="qpc-hafs">﴿فَمَن يَهْدِيهِ مِنۢ بَعْدِ ٱللَّهِ ۚ أَفَلَا تَذَكَّرُونَ﴾</span></p><p>٣- حاسب نفسك قبل أن تحاسب، <span class="qpc-hafs">﴿هَٰذَا كِتَٰبُنَا يَنطِقُ عَلَيْكُم بِٱلْحَقِّ﴾</span></p><h3>العمل بالآيات</h3><p>١- حاول تعداد أخطائك ومعاصيك التي فعلتها أو نطقت بها الأسبوع الماضي فقط، <span class="qpc-hafs">﴿هَٰذَا كِتَٰبُنَا يَنطِقُ عَلَيْكُم بِٱلْحَقِّ﴾</span></p><p>٢- قل: «اللهم اجعل في قلبي نورا وفي سمعي نورا وفي بصري نورا»، <span class="qpc-hafs">﴿أَفَرَءَيْتَ مَنِ ٱتَّخَذَ إِلَٰهَهُۥ هَوَىٰهُ وَأَضَلَّهُ ٱللَّهُ عَلَىٰ عِلْمٍ وَخَتَمَ عَلَىٰ سَمْعِهِۦ وَقَلْبِهِۦ وَجَعَلَ عَلَىٰ بَصَرِهِۦ غِشَٰوَةً فَمَن يَهْدِيهِ مِنۢ بَعْدِ ٱللَّهِ ۚ أَفَلَا تَذَكَّرُونَ﴾</span></p><p>٣- قل: «اللهم اهدني فيمن هديت، وعافني فيمن عافيت، وتولني فيمن توليت»، <span class="qpc-hafs">﴿فَمَن يَهْدِيهِ مِنۢ بَعْدِ ٱللَّهِ ۚ أَفَلَا تَذَكَّرُونَ﴾</span></p><h3>معاني الكلمات</h3><p><span class="qpc-hafs">﴿أَفَرَأَيْتَ﴾</span> أَخْبِرْنِي.</p><p><span class="qpc-hafs">﴿وَخَتَمَ﴾</span> طَبَعَ.</p><p><span class="qpc-hafs">﴿غِشَاوَةً﴾</span> غِطَاءً.</p><p><span class="qpc-hafs">﴿لاَ رَيْبَ فِيهِ﴾</span> لاَ شَكَّ فِيهِ.</p><p><span class="qpc-hafs">﴿إِنْ نَظُنُّ إِلاَّ ظَنًّا﴾</span> مَا نَتَوَقَّعُ وُقُوعَهَا إِلاَّ تَوَهُّمًا.</p></div>"
