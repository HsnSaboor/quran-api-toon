quran[4]{c,v,t}:
  2,187,"

الوقفات التدبرية

١- <q>﴿وَكُلُوا۟ وَٱشْرَبُوا۟ حَتَّىٰ يَتَبَيَّنَ لَكُمُ ٱلْخَيْطُ ٱلْأَبْيَضُ مِنَ ٱلْخَيْطِ ٱلْأَسْوَدِ مِنَ ٱلْفَجْرِ﴾</q>

وفي إباحته تعالى جواز الأكل إلى طلوع الفجر دليلٌ على استحباب السحور؛ لأنه من باب الرخصة، والأخذ بها محبوب. [ابن كثير: ١/٢١٠]

السؤال: كيف يستدل بالآية على استحباب السحور؟

٢- <q>﴿وَلَا تُبَٰشِرُوهُنَّ وَأَنتُمْ عَٰكِفُونَ فِى ٱلْمَسَٰجِدِ﴾</q>

وفي ذكره تعالى الاعتكاف بعد الصيام إرشادٌ وتنبيهٌ على الاعتكاف في الصيام، أو في آخر شهر الصيام. [ابن كثير: ١/٢١٣]

السؤال: ما الذي يدل عليه ذكر الاعتكاف بعد الصيام؟

٣- <q>﴿وَلَا تُبَٰشِرُوهُنَّ وَأَنتُمْ عَٰكِفُونَ فِى ٱلْمَسَٰجِدِ﴾</q>

فلا يكون الاعتكاف إلا في المساجد باتفاق العلماء؛ كما قال تعالى: <q>﴿ولا تباشروهن وأنتم عاكفون في المساجد﴾</q>: لا يكون الاعتكاف لا بخلوة، ولا غير خلوة؛ لا في غار، ولا عند قبر، ولا غير ذلك مما يقصد الضالون السفر إليه والعكوف عنده؛ كعكوف المشركين على أوثانهم. [ابن تيمية: ١/٤٤٨-٤٤٩]

السؤال: هل يصح اعتكاف في غير المساجد؟ استخرج الدليل من الآية.

٤- <q>﴿تِلْكَ حُدُودُ ٱللَّهِ فَلَا تَقْرَبُوهَا﴾</q>

أبلغ من قوله: <q>﴿فلا تفعلوها﴾</q>؛ لأن القربان يشمل النهي عن فعل المحرم بنفسه، والنهي عن وسائله الموصلة إليه، والعبد مأمور بترك المحرمات والبعد منها غاية ما يمكنه، وترك كل سبب يدعو إليها. [السعدي: ٨٧-٨٨]

السؤال: لماذا نهى الله عن قربان حدوده المحرمة بدلا من النهي عن فعلها؟

٥- <q>﴿وَلَا تَأْكُلُوٓا۟ أَمْوَٰلَكُم بَيْنَكُم بِٱلْبَٰطِلِ وَتُدْلُوا۟ بِهَآ إِلَى ٱلْحُكَّامِ لِتَأْكُلُوا۟ فَرِيقًا مِّنْ أَمْوَٰلِ ٱلنَّاسِ بِٱلْإِثْمِ وَأَنتُمْ تَعْلَمُونَ﴾</q>

لما ذكر سبحانه الصيام وما فيه؛ عقبه بالنهي عن الأكل الحرام المفضي إلى عدم قبول عبادته من صيامه واعتكافه. [الألوسي: ٢/٦٩]

السؤال: ما علاقة النهي عن أكل الحرام بالصيام؟

٦- <q>﴿وَلَا تَأْكُلُوٓا۟ أَمْوَٰلَكُم بَيْنَكُم بِٱلْبَٰطِلِ وَتُدْلُوا۟ بِهَآ إِلَى ٱلْحُكَّامِ لِتَأْكُلُوا۟ فَرِيقًا مِّنْ أَمْوَٰلِ ٱلنَّاسِ بِٱلْإِثْمِ وَأَنتُمْ تَعْلَمُونَ﴾</q>

لا تصانعوا بأموالكم الحكام وترشوهم؛ ليقضوا لكم على أكثر منها... اتفق أهل السنة على أن من أخذ ما وقع عليه اسم مال- قل أو كثر- أنه يفسق بذلك، وأنه محرم عليه أخذه. [القرطبي: ٣/٢٢٦]

السؤال: من محافظة الصائم على صومه ابتعاده عن الرشوة، وضح ذلك من سياق الآيات؟

٧- <q>﴿وَٱتَّقُوا۟ ٱللَّهَ لَعَلَّكُمْ تُفْلِحُونَ﴾</q>

من اتقى الله تعالى تفجرت ينابيع الحكمة من قلبه، وانكشفت له دقائق الأسرار حسب تقواه. [الألوسي: ٢/٧٤]

السؤال: ما ثمرة التقوى؟

التوجيهات

١- الغاية من إنزال الشرائع ووضع الحدود تقوى الله عز وجل، <q>﴿ۗ تِلْكَ حُدُودُ ٱللَّهِ فَلَا تَقْرَبُوهَا ۗ كَذَٰلِكَ يُبَيِّنُ ٱللَّهُ ءَايَٰتِهِۦ لِلنَّاسِ لَعَلَّهُمْ يَتَّقُونَ﴾</q>

٢- لا تقترب من الشبهات فتقع في الحرام، <q>﴿ۗ تِلْكَ حُدُودُ ٱللَّهِ فَلَا تَقْرَبُوهَا﴾</q>

٣- احذر أكل أموال الناس بالباطل، <q>﴿وَلَا تَأْكُلُوٓا۟ أَمْوَٰلَكُم بَيْنَكُم بِٱلْبَٰطِلِ وَتُدْلُوا۟ بِهَآ إِلَى ٱلْحُكَّامِ لِتَأْكُلُوا۟ فَرِيقًا مِّنْ أَمْوَٰلِ ٱلنَّاسِ بِٱلْإِثْمِ وَأَنتُمْ تَعْلَمُونَ﴾</q>

العمل بالآيات

١- اكتب خمسة من أضرار الرشوة على الفرد والمجتمع، وأرسلها في رسالة، <q>﴿وَلَا تَأْكُلُوٓا۟ أَمْوَٰلَكُم بَيْنَكُم بِٱلْبَٰطِلِ وَتُدْلُوا۟ بِهَآ إِلَى ٱلْحُكَّامِ لِتَأْكُلُوا۟ فَرِيقًا مِّنْ أَمْوَٰلِ ٱلنَّاسِ بِٱلْإِثْمِ وَأَنتُمْ تَعْلَمُونَ﴾</q>

٢- تعاون مع غيرك لاسترداد حق مسلم أخذ بسبب الرشوة، <q>﴿وَلَا تَأْكُلُوٓا۟ أَمْوَٰلَكُم بَيْنَكُم بِٱلْبَٰطِلِ وَتُدْلُوا۟ بِهَآ إِلَى ٱلْحُكَّامِ لِتَأْكُلُوا۟ فَرِيقًا مِّنْ أَمْوَٰلِ ٱلنَّاسِ بِٱلْإِثْمِ وَأَنتُمْ تَعْلَمُونَ﴾</q>

٣- تذكر مسلماً أخطأت عليه، واعتذر منه ولو برسالة حتى يحبك الله سبحانه، <q>﴿وَلَا تَعْتَدُوٓا۟ ۚ إِنَّ ٱللَّهَ لَا يُحِبُّ ٱلْمُعْتَدِينَ﴾</q>

معاني الكلمات

<q>﴿الرَّفَثُ﴾</q> الْجِمَاعُ.

<q>﴿لِبَاسٌ﴾</q> سَكَنٌ، وَسِتْرٌ عَنِ الْحَرَامِ.

<q>﴿تَخْتَانُونَ﴾</q> تَخُونُون، فَتَقَعُونَ فِي المَعْصِيَةِ

<q>﴿بَاشِرُوهُنَّ﴾</q> جَامِعُوهُنَّ.

<q>﴿الْخَيْطُ الأَبْيَضُ﴾</q> نُورُ الْفَجْرِ.

<q>﴿الْخَيْطِ الأَسْوَدِ﴾</q> سَوَادِ اللَّيْلِ.

<q>﴿عَاكِفُونَ﴾</q> مُقِيمُونَ فِي الْمَسَاجِدِ؛ بِنِيَّةِ التَّقَرُّبِ إِلَى اللهِ.

<q>﴿حُدُودُ اللَّهِ﴾</q> مُحَرَّمَاتُهُ وَمَنْهِيَّاتُهُ.

<q>﴿وَتُدْلُوا﴾</q> تَدْفَعُوا.

<q>﴿الأَهِلَّةِ﴾</q> جَمْعُ هِلاَلٍ؛ وَهُوَ القَمَرُ فِي بِدَايَةِ ظُهُورِهِ.

