quran[8]{c,v,t}:
  18,54,"<div class=ar lang=ar><h3>الوقفات التدبرية</h3><p>١- <span class="qpc-hafs">﴿وَلَقَدْ صَرَّفْنَا فِى هَٰذَا ٱلْقُرْءَانِ لِلنَّاسِ مِن كُلِّ مَثَلٍ ۚ وَكَانَ ٱلْإِنسَٰنُ أَكْثَرَ شَىْءٍ جَدَلًا﴾</span></p><p>عن علي: أن النبي- صلى الله عليه وسلم- طرقه وفاطمةَ ليلاً؛ فقال: <span class="qpc-hafs">﴿ألاَ تصليان؟!﴾</span> فقال علي: يا رسول الله إنما أنفسنا بيد الله إن شاء أن يبعثنا بعثَنا، قال: فانصرف رسول الله حين قلت له ذلك ولم يرجع إليّ شيئاً، ثم سمعته يَضرب فخذه ويقول: <span class="qpc-hafs">﴿وكان الإنسان أكثر شيء جدلاً﴾</span>. [ابن عاشور:١٥/٣٤٨]</p><p>السؤال: الناصح بخير يُقابل بالقبول قدر المستطاع، وضح ذلك.</p><p>٢- <span class="qpc-hafs">﴿وَكَانَ ٱلْإِنسَٰنُ أَكْثَرَ شَىْءٍ جَدَلًا﴾</span></p><p>كثير من الناس يجادلون في الحق بعد ما تبين، ويجادلون بالباطل ليدحضوا به الحق؛ ولهذا قال: <span class="qpc-hafs">﴿وكان الإنسان أكثر شيء جدلاً﴾</span> أي: مجادلة ومنازعة فيه، مع أن ذلك غير لائق بهم، ولا عدل منهم، والذي أوجب له ذلك وعدم الإيمان بالله إنما هو الظلم والعناد، لا لقصور في بيانه وحجته، وبرهانه. [السعدي:٤٨٠]</p><p>السؤال: كثرة المجادلة مع العلماء وطلبة العلم هل هي من الخير في شيء؟ وما السبب الذي يجعل الإنسان يكثر من الجدال مع أهل الحق؟</p><p>٣- <span class="qpc-hafs">﴿وَمَا نُرْسِلُ ٱلْمُرْسَلِينَ إِلَّا مُبَشِّرِينَ وَمُنذِرِينَ ۚ وَيُجَٰدِلُ ٱلَّذِينَ كَفَرُوا۟ بِٱلْبَٰطِلِ لِيُدْحِضُوا۟ بِهِ ٱلْحَقَّ ۖ وَٱتَّخَذُوٓا۟ ءَايَٰتِى وَمَآ أُنذِرُوا۟ هُزُوًا﴾</span></p><p>ففرق بين الآيات الدالة على العلم التي يعلم بالعقل أنها دلائل للرب، وبين النذر: وهو الإخبار عن المخوف؛ كإخبار الأنبياء بما يستحقه العصاة من العذاب؛ فهذا يعلم بالخبر والنذر. [ابن تيمية:٤/٢٦٠]</p><p>السؤال: ما الفرق بين الآيات والنذر؟</p><p>٤- <span class="qpc-hafs">﴿وَمَا نُرْسِلُ ٱلْمُرْسَلِينَ إِلَّا مُبَشِّرِينَ وَمُنذِرِينَ﴾</span></p><p><span class="qpc-hafs">﴿وما نرسل المرسلين إلا مبشرين﴾</span> أي: بالجنة لمن آمن، <span class="qpc-hafs">﴿ومنذرين﴾</span> أي: مخوفين بالعذاب من كفر . [القرطبي:١٣/٣١١]</p><p>السؤال: اذكر أسلوبين من أساليب الدعوة إلى الله تعالى جاء ذكرهما في الآية.</p><p>٥- <span class="qpc-hafs">﴿وَمَنْ أَظْلَمُ مِمَّن ذُكِّرَ بِـَٔايَٰتِ رَبِّهِۦ فَأَعْرَضَ عَنْهَا وَنَسِىَ مَا قَدَّمَتْ يَدَاهُ ۚ إِنَّا جَعَلْنَا عَلَىٰ قُلُوبِهِمْ أَكِنَّةً أَن يَفْقَهُوهُ وَفِىٓ ءَاذَانِهِمْ وَقْرًا ۖ وَإِن تَدْعُهُمْ إِلَى ٱلْهُدَىٰ فَلَن يَهْتَدُوٓا۟ إِذًا أَبَدًا﴾</span></p><p>وفي هذه الآية من التخويف لمن ترك الحق بعد علمه أن يحال بينهم وبينه، ولا يتمكن منه بعد ذلك، ما هو أعظم مرهب وزاجر عن ذلك. [السعدي:٤٨١]</p><p>السؤال: هناك فرقٌ بين من يعرض عن الحق وهو عالم به، ومن هو جاهل به، تحدث عن ذلك في ضوء هذه الآية.</p><p>٦- <span class="qpc-hafs">﴿وَمَنْ أَظْلَمُ مِمَّن ذُكِّرَ بِـَٔايَٰتِ رَبِّهِۦ فَأَعْرَضَ عَنْهَا وَنَسِىَ مَا قَدَّمَتْ يَدَاهُ﴾</span></p><p>أي: لا أحد أظلم لنفسه ممن وعظ بآيات ربه، فتهاون بها، وأعرض عن قبولها. [القرطبي:١٣/٣١٢]</p><p>السؤال: من أظلم الناس لنفسه؟</p><p>٧- <span class="qpc-hafs">﴿وَإِذْ قَالَ مُوسَىٰ لِفَتَىٰهُ لَآ أَبْرَحُ حَتَّىٰٓ أَبْلُغَ مَجْمَعَ ٱلْبَحْرَيْنِ أَوْ أَمْضِىَ حُقُبًا﴾</span></p><p>في هذا من الفقه: رحلة العالم في طلب الازدياد من العلم، والاستعانة على ذلك بالخادم والصاحب، واغتنام لقاء الفضلاء والعلماء -وإن بعدت أقطارهم- وذلك كان دأب السلف الصالح، وبسبب ذلك وصل المرتحلون إلى الحظ الراجح، وحصلوا على السعي الناجح؛ فرسخت لهم في العلوم أقدام، وصح لهم من الذكر والأجر والفضل أفضل الأقسام، قال البخاري: ورحل جابر بن عبد الله مسيرة شهر إلى عبد الله بن أنيس- رضي الله عنهم- في حديث. [القرطبي:١٣/٣١٨]</p><p>السؤال: ماذا يتعلم طالب العلم من رحلة موسى عليه الصلاة والسلام؟</p><h3>التوجيهات</h3><p>١- الجدل والمخاصمة غريزة في الإنسان؛ فليحرص على تهذيبها وتوجيهها في الخير, <span class="qpc-hafs">﴿وَكَانَ ٱلْإِنسَٰنُ أَكْثَرَ شَىْءٍ جَدَلًا﴾</span></p><p>٢- استخدم الترغيب والترهيب في دعوتك إلى الله تعالى،<span class="qpc-hafs">﴿وَمَا نُرْسِلُ ٱلْمُرْسَلِينَ إِلَّا مُبَشِّرِينَ وَمُنذِرِينَ﴾</span></p><p>٣- قد يضرب الله سبحانه الأكنة والغشاوة على قلب العاصي، فلا يستطيع تدبر القرآن وفهم أمثاله وقصصه حتى يتوب، <span class="qpc-hafs">﴿وَمَنْ أَظْلَمُ مِمَّن ذُكِّرَ بِـَٔايَٰتِ رَبِّهِۦ فَأَعْرَضَ عَنْهَا وَنَسِىَ مَا قَدَّمَتْ يَدَاهُ ۚ إِنَّا جَعَلْنَا عَلَىٰ قُلُوبِهِمْ أَكِنَّةً أَن يَفْقَهُوهُ﴾</span></p><h3>العمل بالآيات</h3><p>١- اقرأ قصة من القصص الواردة في سورة الكهف، وتدبر ما فيها من العبر والعظات, <span class="qpc-hafs">﴿وَلَقَدْ صَرَّفْنَا فِى هَٰذَا ٱلْقُرْءَانِ لِلنَّاسِ مِن كُلِّ مَثَلٍ ۚ وَكَانَ ٱلْإِنسَٰنُ أَكْثَرَ شَىْءٍ جَدَلًا﴾</span></p><p>٢- حدد واحدا من أسباب غفلتك، وابدأ خطوات جادة في تركه، واسأل الله أن يعوضك خيرا منه، <span class="qpc-hafs">﴿وَمَنْ أَظْلَمُ مِمَّن ذُكِّرَ بِـَٔايَٰتِ رَبِّهِۦ فَأَعْرَضَ عَنْهَا وَنَسِىَ مَا قَدَّمَتْ يَدَاهُ﴾</span></p><p>٣- زُر عالمًا، واستمع منه العلم، أو اقرأ عليه كتابا، أو تعلم من أدبه وسمته؛ فذاك من الباقيات الصالحات، <span class="qpc-hafs">﴿وَإِذْ قَالَ مُوسَىٰ لِفَتَىٰهُ لَآ أَبْرَحُ حَتَّىٰٓ أَبْلُغَ مَجْمَعَ ٱلْبَحْرَيْنِ أَوْ أَمْضِىَ حُقُبًا﴾</span></p><h3>معاني الكلمات</h3><p><span class="qpc-hafs">﴿صَرَّفْنَا﴾</span> وَضَّحْنَا، وَنَوَّعْنَا.</p><p><span class="qpc-hafs">﴿سُنَّةُ الأَوَّلِينَ﴾</span> إِهْلاَكُ المُكَذِّبِينَ.</p><p><span class="qpc-hafs">﴿قُبُلاً﴾</span> عِيَانًا.</p><p><span class="qpc-hafs">﴿لِيُدْحِضُوا﴾</span> لِيُزِيلُوا.</p><p><span class="qpc-hafs">﴿أَكِنَّةً﴾</span> أَغْطِيَةً.</p><p><span class="qpc-hafs">﴿وَقْرًا﴾</span> صَمَمًا وَثِقَلاً فِي السَّمْعِ.</p><p><span class="qpc-hafs">﴿مَوْئِلاً﴾</span> مَلْجَأً، وَمَخْلَصًا.</p><p><span class="qpc-hafs">﴿لِفَتَاهُ﴾</span> لِخَادِمِهِ يُوشَعَ بْنِ نُونٍ.</p><p><span class="qpc-hafs">﴿لاَ أَبْرَحُ﴾</span> لاَ أَزَالُ أُتَابِـعُ المَسِيرَ.</p><p><span class="qpc-hafs">﴿مَجْمَعَ﴾</span> مُلْتَقَى.</p><p><span class="qpc-hafs">﴿حُقُبًا﴾</span> زَمَنًا طَوِيلاً.</p><p><span class="qpc-hafs">﴿فَاتَّخَذَ سَبِيلَهُ﴾</span> فَأَصْبَحَ الحُوتُ حَيًّا، وَاتَّخَذَ طَرِيقًا فِي البَحْرِ.</p><p><span class="qpc-hafs">﴿سَرَبًا﴾</span> طَرِيقًا مَفْتُوحًا فِي المَاءِ.</p></div>"
  18,55,"18:54"
