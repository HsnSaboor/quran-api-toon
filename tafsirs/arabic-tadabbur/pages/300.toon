tafsir[8]{c,v,t}:
  18,54,"

الوقفات التدبرية

١- <q>﴿وَلَقَدْ صَرَّفْنَا فِى هَٰذَا ٱلْقُرْءَانِ لِلنَّاسِ مِن كُلِّ مَثَلٍ ۚ وَكَانَ ٱلْإِنسَٰنُ أَكْثَرَ شَىْءٍ جَدَلًا﴾</q>

عن علي: أن النبي- صلى الله عليه وسلم- طرقه وفاطمةَ ليلاً؛ فقال: <q>﴿ألاَ تصليان؟!﴾</q> فقال علي: يا رسول الله إنما أنفسنا بيد الله إن شاء أن يبعثنا بعثَنا، قال: فانصرف رسول الله حين قلت له ذلك ولم يرجع إليّ شيئاً، ثم سمعته يَضرب فخذه ويقول: <q>﴿وكان الإنسان أكثر شيء جدلاً﴾</q>. [ابن عاشور:١٥/٣٤٨]

السؤال: الناصح بخير يُقابل بالقبول قدر المستطاع، وضح ذلك.

٢- <q>﴿وَكَانَ ٱلْإِنسَٰنُ أَكْثَرَ شَىْءٍ جَدَلًا﴾</q>

كثير من الناس يجادلون في الحق بعد ما تبين، ويجادلون بالباطل ليدحضوا به الحق؛ ولهذا قال: <q>﴿وكان الإنسان أكثر شيء جدلاً﴾</q> أي: مجادلة ومنازعة فيه، مع أن ذلك غير لائق بهم، ولا عدل منهم، والذي أوجب له ذلك وعدم الإيمان بالله إنما هو الظلم والعناد، لا لقصور في بيانه وحجته، وبرهانه. [السعدي:٤٨٠]

السؤال: كثرة المجادلة مع العلماء وطلبة العلم هل هي من الخير في شيء؟ وما السبب الذي يجعل الإنسان يكثر من الجدال مع أهل الحق؟

٣- <q>﴿وَمَا نُرْسِلُ ٱلْمُرْسَلِينَ إِلَّا مُبَشِّرِينَ وَمُنذِرِينَ ۚ وَيُجَٰدِلُ ٱلَّذِينَ كَفَرُوا۟ بِٱلْبَٰطِلِ لِيُدْحِضُوا۟ بِهِ ٱلْحَقَّ ۖ وَٱتَّخَذُوٓا۟ ءَايَٰتِى وَمَآ أُنذِرُوا۟ هُزُوًا﴾</q>

ففرق بين الآيات الدالة على العلم التي يعلم بالعقل أنها دلائل للرب، وبين النذر: وهو الإخبار عن المخوف؛ كإخبار الأنبياء بما يستحقه العصاة من العذاب؛ فهذا يعلم بالخبر والنذر. [ابن تيمية:٤/٢٦٠]

السؤال: ما الفرق بين الآيات والنذر؟

٤- <q>﴿وَمَا نُرْسِلُ ٱلْمُرْسَلِينَ إِلَّا مُبَشِّرِينَ وَمُنذِرِينَ﴾</q>

<q>﴿وما نرسل المرسلين إلا مبشرين﴾</q> أي: بالجنة لمن آمن، <q>﴿ومنذرين﴾</q> أي: مخوفين بالعذاب من كفر . [القرطبي:١٣/٣١١]

السؤال: اذكر أسلوبين من أساليب الدعوة إلى الله تعالى جاء ذكرهما في الآية.

٥- <q>﴿وَمَنْ أَظْلَمُ مِمَّن ذُكِّرَ بِـَٔايَٰتِ رَبِّهِۦ فَأَعْرَضَ عَنْهَا وَنَسِىَ مَا قَدَّمَتْ يَدَاهُ ۚ إِنَّا جَعَلْنَا عَلَىٰ قُلُوبِهِمْ أَكِنَّةً أَن يَفْقَهُوهُ وَفِىٓ ءَاذَانِهِمْ وَقْرًا ۖ وَإِن تَدْعُهُمْ إِلَى ٱلْهُدَىٰ فَلَن يَهْتَدُوٓا۟ إِذًا أَبَدًا﴾</q>

وفي هذه الآية من التخويف لمن ترك الحق بعد علمه أن يحال بينهم وبينه، ولا يتمكن منه بعد ذلك، ما هو أعظم مرهب وزاجر عن ذلك. [السعدي:٤٨١]

السؤال: هناك فرقٌ بين من يعرض عن الحق وهو عالم به، ومن هو جاهل به، تحدث عن ذلك في ضوء هذه الآية.

٦- <q>﴿وَمَنْ أَظْلَمُ مِمَّن ذُكِّرَ بِـَٔايَٰتِ رَبِّهِۦ فَأَعْرَضَ عَنْهَا وَنَسِىَ مَا قَدَّمَتْ يَدَاهُ﴾</q>

أي: لا أحد أظلم لنفسه ممن وعظ بآيات ربه، فتهاون بها، وأعرض عن قبولها. [القرطبي:١٣/٣١٢]

السؤال: من أظلم الناس لنفسه؟

٧- <q>﴿وَإِذْ قَالَ مُوسَىٰ لِفَتَىٰهُ لَآ أَبْرَحُ حَتَّىٰٓ أَبْلُغَ مَجْمَعَ ٱلْبَحْرَيْنِ أَوْ أَمْضِىَ حُقُبًا﴾</q>

في هذا من الفقه: رحلة العالم في طلب الازدياد من العلم، والاستعانة على ذلك بالخادم والصاحب، واغتنام لقاء الفضلاء والعلماء -وإن بعدت أقطارهم- وذلك كان دأب السلف الصالح، وبسبب ذلك وصل المرتحلون إلى الحظ الراجح، وحصلوا على السعي الناجح؛ فرسخت لهم في العلوم أقدام، وصح لهم من الذكر والأجر والفضل أفضل الأقسام، قال البخاري: ورحل جابر بن عبد الله مسيرة شهر إلى عبد الله بن أنيس- رضي الله عنهم- في حديث. [القرطبي:١٣/٣١٨]

السؤال: ماذا يتعلم طالب العلم من رحلة موسى عليه الصلاة والسلام؟

التوجيهات

١- الجدل والمخاصمة غريزة في الإنسان؛ فليحرص على تهذيبها وتوجيهها في الخير, <q>﴿وَكَانَ ٱلْإِنسَٰنُ أَكْثَرَ شَىْءٍ جَدَلًا﴾</q>

٢- استخدم الترغيب والترهيب في دعوتك إلى الله تعالى،<q>﴿وَمَا نُرْسِلُ ٱلْمُرْسَلِينَ إِلَّا مُبَشِّرِينَ وَمُنذِرِينَ﴾</q>

٣- قد يضرب الله سبحانه الأكنة والغشاوة على قلب العاصي، فلا يستطيع تدبر القرآن وفهم أمثاله وقصصه حتى يتوب، <q>﴿وَمَنْ أَظْلَمُ مِمَّن ذُكِّرَ بِـَٔايَٰتِ رَبِّهِۦ فَأَعْرَضَ عَنْهَا وَنَسِىَ مَا قَدَّمَتْ يَدَاهُ ۚ إِنَّا جَعَلْنَا عَلَىٰ قُلُوبِهِمْ أَكِنَّةً أَن يَفْقَهُوهُ﴾</q>

العمل بالآيات

١- اقرأ قصة من القصص الواردة في سورة الكهف، وتدبر ما فيها من العبر والعظات, <q>﴿وَلَقَدْ صَرَّفْنَا فِى هَٰذَا ٱلْقُرْءَانِ لِلنَّاسِ مِن كُلِّ مَثَلٍ ۚ وَكَانَ ٱلْإِنسَٰنُ أَكْثَرَ شَىْءٍ جَدَلًا﴾</q>

٢- حدد واحدا من أسباب غفلتك، وابدأ خطوات جادة في تركه، واسأل الله أن يعوضك خيرا منه، <q>﴿وَمَنْ أَظْلَمُ مِمَّن ذُكِّرَ بِـَٔايَٰتِ رَبِّهِۦ فَأَعْرَضَ عَنْهَا وَنَسِىَ مَا قَدَّمَتْ يَدَاهُ﴾</q>

٣- زُر عالمًا، واستمع منه العلم، أو اقرأ عليه كتابا، أو تعلم من أدبه وسمته؛ فذاك من الباقيات الصالحات، <q>﴿وَإِذْ قَالَ مُوسَىٰ لِفَتَىٰهُ لَآ أَبْرَحُ حَتَّىٰٓ أَبْلُغَ مَجْمَعَ ٱلْبَحْرَيْنِ أَوْ أَمْضِىَ حُقُبًا﴾</q>

معاني الكلمات

<q>﴿صَرَّفْنَا﴾</q> وَضَّحْنَا، وَنَوَّعْنَا.

<q>﴿سُنَّةُ الأَوَّلِينَ﴾</q> إِهْلاَكُ المُكَذِّبِينَ.

<q>﴿قُبُلاً﴾</q> عِيَانًا.

<q>﴿لِيُدْحِضُوا﴾</q> لِيُزِيلُوا.

<q>﴿أَكِنَّةً﴾</q> أَغْطِيَةً.

<q>﴿وَقْرًا﴾</q> صَمَمًا وَثِقَلاً فِي السَّمْعِ.

<q>﴿مَوْئِلاً﴾</q> مَلْجَأً، وَمَخْلَصًا.

<q>﴿لِفَتَاهُ﴾</q> لِخَادِمِهِ يُوشَعَ بْنِ نُونٍ.

<q>﴿لاَ أَبْرَحُ﴾</q> لاَ أَزَالُ أُتَابِـعُ المَسِيرَ.

<q>﴿مَجْمَعَ﴾</q> مُلْتَقَى.

<q>﴿حُقُبًا﴾</q> زَمَنًا طَوِيلاً.

<q>﴿فَاتَّخَذَ سَبِيلَهُ﴾</q> فَأَصْبَحَ الحُوتُ حَيًّا، وَاتَّخَذَ طَرِيقًا فِي البَحْرِ.

<q>﴿سَرَبًا﴾</q> طَرِيقًا مَفْتُوحًا فِي المَاءِ.

