quran[8]{c,v,t}:
  12,79,"<div class=ar lang=ar><h3>الوقفات التدبرية</h3><p>١- <span class="qpc-hafs">﴿قَالَ مَعَاذَ ٱللَّهِ أَن نَّأْخُذَ إِلَّا مَن وَجَدْنَا مَتَٰعَنَا عِندَهُۥٓ﴾</span></p><p>ينبغي لمن أراد أن يوهم غيره بأمر لا يحب أن يطلع عليه أن يستعمل المعاريض القولية والفعلية المانعة له من الكذب؛ كما فعل يوسف؛ حيث ألقى الصُّواع في رحل أخيه، ثم استخرجها منه موهماً أنه سارق، وليس فيه إلا القرينة الموهمة لإخوته، وقال بعد ذلك: <span class="qpc-hafs">﴿معاذ الله أن نأخذ إلا من وجدنا متاعنا عنده﴾</span> ولم يقل: «من سرق متاعنا». [السعدي:٤١١]</p><p>السؤال: كيف تخلص يوسف- عليه السلام- من الكذب عندما أراد أن يأخذ أخاه؟</p><p>٢- <span class="qpc-hafs">﴿وَمَا شَهِدْنَآ إِلَّا بِمَا عَلِمْنَا وَمَا كُنَّا لِلْغَيْبِ حَٰفِظِينَ﴾</span></p><p>تضمنت هذه الآية جواز الشهادة بأي وجه يحصل العلم بها؛ فإن الشهادة مرتبطة بالعلم عقلا وشرعاً، فلا تسمع إلا ممن علم. [القرطبي:١١/٤٢٦]</p><p>السؤال: ما تقول فيمن يشهد على أمور لا علم له بها، هل يصح ذلك؟</p><p>٣- <span class="qpc-hafs">﴿فَصَبْرٌ جَمِيلٌ ۖ عَسَى ٱللَّهُ أَن يَأْتِيَنِى بِهِمْ جَمِيعًا﴾</span></p><p>ذكر الله الصبر الجميل، و الصفح الجميل، و الهجر الجميل؛ فالصبر الجميل: الذي لا شكوى معه، والهجر الجميل: الذي لا أذى معه، والصفح الجميل: الذي لا عتاب معه. [ابن تيمية:٤/٦٣-٦٤]</p><p>السؤال: ما المقصود بالصبر الجميل، والصفح الجميل، والهجر الجميل؟</p><p>٤- <span class="qpc-hafs">﴿فَصَبْرٌ جَمِيلٌ ۖ عَسَى ٱللَّهُ أَن يَأْتِيَنِى بِهِمْ جَمِيعًا ۚ إِنَّهُۥ هُوَ ٱلْعَلِيمُ ٱلْحَكِيمُ﴾</span></p><p>جرت سنته تعالى أن الشدة إذا تناهت يجعل وراءها فرجاً عظيماً ... كأنه عليه السلام لما رأى اشتداد البلاء قوي رجاؤه بالفرج، فقال ما قال. [الألوسي:١٣/٥١]</p><p>السؤال: قرب الفرج له علامة يدركها الربانيون، فما هي؟</p><p>٥- <span class="qpc-hafs">﴿وَقَالَ يَٰٓأَسَفَىٰ عَلَىٰ يُوسُفَ وَٱبْيَضَّتْ عَيْنَاهُ مِنَ ٱلْحُزْنِ فَهُوَ كَظِيمٌ﴾</span></p><p>واستدل بالآية على جواز التأسف والبكاء عند النوائب, ولعل الكف عن أمثال ذلك لا يدخل تحت التكليف؛ فإنه قلَّ من يملك نفسه عند الشدائد, وقد روى الشيخان من حديث أنس أنه صلى الله عليه وسلم بكى على ولده إبراهيم، وقال: <span class="qpc-hafs">﴿إن العين تدمع، والقلب يخشع، ولا نقول إلا ما يرضي ربنا، وإنا لفراقك يا إبراهيم لمحزونون﴾</span>. وإنما المنهي عنه: ما يفعله الجهلة من النياحة، ولطم الخدود والصدور، وشق الجيوب، وتمزيق الثياب. [الألوسي:١٣/٥٣]</p><p>السؤال: ما المستحب، وما الجائز، وما المحرم عند حصول المصائب؟</p><p>٦- <span class="qpc-hafs">﴿قَالَ إِنَّمَآ أَشْكُوا۟ بَثِّى وَحُزْنِىٓ إِلَى ٱللَّهِ وَأَعْلَمُ مِنَ ٱللَّهِ مَا لَا تَعْلَمُونَ﴾</span></p><p>أي: إنما أشكو إلى الله لا إليكم، ولا إلى غيركم. والبث: أشدّ الحزن. <span class="qpc-hafs">﴿وأعلم من الله ما لا تعلمون﴾</span> أي: أعلم من لطفه ورأفته ورحمته ما يوجب حسن ظنّي به، وقوة رجائي فيه. [ابن جزي:١/٤٢٥]</p><p>السؤال: ما الذي يقصده يعقوب-عليه السلام- بقوله: <span class="qpc-hafs">﴿وأعلم من الله ما لا تعلمون﴾</span>؟</p><p>٧- <span class="qpc-hafs">﴿قَالَ إِنَّمَآ أَشْكُوا۟ بَثِّى وَحُزْنِىٓ إِلَى ٱللَّهِ﴾</span></p><p>الشكوى إلى الله لا تنافي الصبر، وإنما الذي ينافيه الشكوى إلى المخلوقين. [السعدي:٤١١]</p><p>السؤال: متى تعتبر الشكوى منافيةً للصبر؟</p><h3>التوجيهات</h3><p>١- الجأ إلى الله أولا قبل أن تلجأ إلى غيره؛ خاصة عند الشدائد، <span class="qpc-hafs">﴿عَسَى ٱللَّهُ أَن يَأْتِيَنِى بِهِمْ جَمِيعًا﴾</span></p><p>٢- البكاء أو الحزن عند وجود المصائب لا ينافي اليقين والثبات، <span class="qpc-hafs">﴿وَتَوَلَّىٰ عَنْهُمْ وَقَالَ يَٰٓأَسَفَىٰ عَلَىٰ يُوسُفَ وَٱبْيَضَّتْ عَيْنَاهُ مِنَ ٱلْحُزْنِ فَهُوَ كَظِيمٌ﴾</span></p><p>٣- مشاعر الحب والشوق للولد ليست منافية للإيمان، وليست عيباً أو نقصاً في الرجال، ولكن قد تكون محلا للابتلاء، <span class="qpc-hafs">﴿وَقَالَ يَٰٓأَسَفَىٰ عَلَىٰ يُوسُفَ وَٱبْيَضَّتْ عَيْنَاهُ مِنَ ٱلْحُزْنِ فَهُوَ كَظِيمٌ﴾</span></p><h3>العمل بالآيات</h3><p>١- تأمل معاني أسماء الله الحسنى التي وردت في كلام يعقوب -عليه السلام- في القصة، و كيف كانت سببا في ثباته، <span class="qpc-hafs">﴿لَّهِ وَأَعْلَمُ مِنَ ٱللَّهِ مَا لَا تَعْلَمُونَ﴾</span></p><p>٢- ٢.	احرص اليوم على دعاء الخروج من المنزل -وفيه الاستعاذة من الظلم- وقل : «اللهم إني أعوذ بك أن أَضِل أو أُضل، أو أزل أو أُزل، أو أظلم أو أُظلم، أو أجهل أو يجهل علي» <span class="qpc-hafs">﴿قَالَ مَعَاذَ ٱللَّهِ أَن نَّأْخُذَ إِلَّا مَن وَجَدْنَا مَتَٰعَنَا عِندَهُۥٓ إِنَّآ إِذًا لَّظَٰلِمُونَ﴾</span></p><p>٣- ذكر، وانصح، وتعاهد إخوانك بالخير، كما فعل كبير إخوة يوسف مع إخوته، <span class="qpc-hafs">﴿قَالَ كَبِيرُهُمْ أَلَمْ تَعْلَمُوٓا۟ أَنَّ أَبَاكُمْ قَدْ أَخَذَ عَلَيْكُم مَّوْثِقًا مِّنَ ٱللَّهِ وَمِن قَبْلُ مَا فَرَّطتُمْ فِى يُوسُفَ﴾</span></p><h3>معاني الكلمات</h3><p><span class="qpc-hafs">﴿مَعَاذَ اللَّهِ﴾</span> نَعْتَصِمُ بِاللَّهِ، وَنَسْتَجِيرُ بِهِ.</p><p><span class="qpc-hafs">﴿اسْتَيْأَسُوا﴾</span> يَئِسُوا وَانْقَطَعَ رَجَاؤُهُم.</p><p><span class="qpc-hafs">﴿خَلَصُوا نَجِيًّا﴾</span> انْفَرَدُوا يَتَشَاوَرُونَ.</p><p><span class="qpc-hafs">﴿مَوْثِقًا﴾</span> عَهْدًا مُؤَكَّدًا.</p><p><span class="qpc-hafs">﴿فَرَّطْتُمْ﴾</span> قَصَّرْتُمْ.</p><p><span class="qpc-hafs">﴿أَبْرَحَ﴾</span> أُفَارِقَ.</p><p><span class="qpc-hafs">﴿وَالْعِيرَ﴾</span> القَافِلَةَ.</p><p><span class="qpc-hafs">﴿سَوَّلَتْ﴾</span> زَيَّنَتْ.</p><p><span class="qpc-hafs">﴿كَظِيمٌ﴾</span> شَدِيدُ الكِتْمَانِ لِحُزْنِهِ.</p><p><span class="qpc-hafs">﴿تَفْتَأُ﴾</span> مَا تَزَالُ.</p><p><span class="qpc-hafs">﴿حَرَضًا﴾</span> تُشْرِفُ عَلَى الهَلاَكِ.</p><p><span class="qpc-hafs">﴿بَثِّي﴾</span> هَمِّي.</p></div>"
