quran[8]{c,v,t}:
  12,79,"

الوقفات التدبرية

١- <q>﴿قَالَ مَعَاذَ ٱللَّهِ أَن نَّأْخُذَ إِلَّا مَن وَجَدْنَا مَتَٰعَنَا عِندَهُۥٓ﴾</q>

ينبغي لمن أراد أن يوهم غيره بأمر لا يحب أن يطلع عليه أن يستعمل المعاريض القولية والفعلية المانعة له من الكذب؛ كما فعل يوسف؛ حيث ألقى الصُّواع في رحل أخيه، ثم استخرجها منه موهماً أنه سارق، وليس فيه إلا القرينة الموهمة لإخوته، وقال بعد ذلك: <q>﴿معاذ الله أن نأخذ إلا من وجدنا متاعنا عنده﴾</q> ولم يقل: «من سرق متاعنا». [السعدي:٤١١]

السؤال: كيف تخلص يوسف- عليه السلام- من الكذب عندما أراد أن يأخذ أخاه؟

٢- <q>﴿وَمَا شَهِدْنَآ إِلَّا بِمَا عَلِمْنَا وَمَا كُنَّا لِلْغَيْبِ حَٰفِظِينَ﴾</q>

تضمنت هذه الآية جواز الشهادة بأي وجه يحصل العلم بها؛ فإن الشهادة مرتبطة بالعلم عقلا وشرعاً، فلا تسمع إلا ممن علم. [القرطبي:١١/٤٢٦]

السؤال: ما تقول فيمن يشهد على أمور لا علم له بها، هل يصح ذلك؟

٣- <q>﴿فَصَبْرٌ جَمِيلٌ ۖ عَسَى ٱللَّهُ أَن يَأْتِيَنِى بِهِمْ جَمِيعًا﴾</q>

ذكر الله الصبر الجميل، و الصفح الجميل، و الهجر الجميل؛ فالصبر الجميل: الذي لا شكوى معه، والهجر الجميل: الذي لا أذى معه، والصفح الجميل: الذي لا عتاب معه. [ابن تيمية:٤/٦٣-٦٤]

السؤال: ما المقصود بالصبر الجميل، والصفح الجميل، والهجر الجميل؟

٤- <q>﴿فَصَبْرٌ جَمِيلٌ ۖ عَسَى ٱللَّهُ أَن يَأْتِيَنِى بِهِمْ جَمِيعًا ۚ إِنَّهُۥ هُوَ ٱلْعَلِيمُ ٱلْحَكِيمُ﴾</q>

جرت سنته تعالى أن الشدة إذا تناهت يجعل وراءها فرجاً عظيماً ... كأنه عليه السلام لما رأى اشتداد البلاء قوي رجاؤه بالفرج، فقال ما قال. [الألوسي:١٣/٥١]

السؤال: قرب الفرج له علامة يدركها الربانيون، فما هي؟

٥- <q>﴿وَقَالَ يَٰٓأَسَفَىٰ عَلَىٰ يُوسُفَ وَٱبْيَضَّتْ عَيْنَاهُ مِنَ ٱلْحُزْنِ فَهُوَ كَظِيمٌ﴾</q>

واستدل بالآية على جواز التأسف والبكاء عند النوائب, ولعل الكف عن أمثال ذلك لا يدخل تحت التكليف؛ فإنه قلَّ من يملك نفسه عند الشدائد, وقد روى الشيخان من حديث أنس أنه صلى الله عليه وسلم بكى على ولده إبراهيم، وقال: <q>﴿إن العين تدمع، والقلب يخشع، ولا نقول إلا ما يرضي ربنا، وإنا لفراقك يا إبراهيم لمحزونون﴾</q>. وإنما المنهي عنه: ما يفعله الجهلة من النياحة، ولطم الخدود والصدور، وشق الجيوب، وتمزيق الثياب. [الألوسي:١٣/٥٣]

السؤال: ما المستحب، وما الجائز، وما المحرم عند حصول المصائب؟

٦- <q>﴿قَالَ إِنَّمَآ أَشْكُوا۟ بَثِّى وَحُزْنِىٓ إِلَى ٱللَّهِ وَأَعْلَمُ مِنَ ٱللَّهِ مَا لَا تَعْلَمُونَ﴾</q>

أي: إنما أشكو إلى الله لا إليكم، ولا إلى غيركم. والبث: أشدّ الحزن. <q>﴿وأعلم من الله ما لا تعلمون﴾</q> أي: أعلم من لطفه ورأفته ورحمته ما يوجب حسن ظنّي به، وقوة رجائي فيه. [ابن جزي:١/٤٢٥]

السؤال: ما الذي يقصده يعقوب-عليه السلام- بقوله: <q>﴿وأعلم من الله ما لا تعلمون﴾</q>؟

٧- <q>﴿قَالَ إِنَّمَآ أَشْكُوا۟ بَثِّى وَحُزْنِىٓ إِلَى ٱللَّهِ﴾</q>

الشكوى إلى الله لا تنافي الصبر، وإنما الذي ينافيه الشكوى إلى المخلوقين. [السعدي:٤١١]

السؤال: متى تعتبر الشكوى منافيةً للصبر؟

التوجيهات

١- الجأ إلى الله أولا قبل أن تلجأ إلى غيره؛ خاصة عند الشدائد، <q>﴿عَسَى ٱللَّهُ أَن يَأْتِيَنِى بِهِمْ جَمِيعًا﴾</q>

٢- البكاء أو الحزن عند وجود المصائب لا ينافي اليقين والثبات، <q>﴿وَتَوَلَّىٰ عَنْهُمْ وَقَالَ يَٰٓأَسَفَىٰ عَلَىٰ يُوسُفَ وَٱبْيَضَّتْ عَيْنَاهُ مِنَ ٱلْحُزْنِ فَهُوَ كَظِيمٌ﴾</q>

٣- مشاعر الحب والشوق للولد ليست منافية للإيمان، وليست عيباً أو نقصاً في الرجال، ولكن قد تكون محلا للابتلاء، <q>﴿وَقَالَ يَٰٓأَسَفَىٰ عَلَىٰ يُوسُفَ وَٱبْيَضَّتْ عَيْنَاهُ مِنَ ٱلْحُزْنِ فَهُوَ كَظِيمٌ﴾</q>

العمل بالآيات

١- تأمل معاني أسماء الله الحسنى التي وردت في كلام يعقوب -عليه السلام- في القصة، و كيف كانت سببا في ثباته، <q>﴿لَّهِ وَأَعْلَمُ مِنَ ٱللَّهِ مَا لَا تَعْلَمُونَ﴾</q>

٢- ٢. احرص اليوم على دعاء الخروج من المنزل -وفيه الاستعاذة من الظلم- وقل : «اللهم إني أعوذ بك أن أَضِل أو أُضل، أو أزل أو أُزل، أو أظلم أو أُظلم، أو أجهل أو يجهل علي» <q>﴿قَالَ مَعَاذَ ٱللَّهِ أَن نَّأْخُذَ إِلَّا مَن وَجَدْنَا مَتَٰعَنَا عِندَهُۥٓ إِنَّآ إِذًا لَّظَٰلِمُونَ﴾</q>

٣- ذكر، وانصح، وتعاهد إخوانك بالخير، كما فعل كبير إخوة يوسف مع إخوته، <q>﴿قَالَ كَبِيرُهُمْ أَلَمْ تَعْلَمُوٓا۟ أَنَّ أَبَاكُمْ قَدْ أَخَذَ عَلَيْكُم مَّوْثِقًا مِّنَ ٱللَّهِ وَمِن قَبْلُ مَا فَرَّطتُمْ فِى يُوسُفَ﴾</q>

معاني الكلمات

<q>﴿مَعَاذَ اللَّهِ﴾</q> نَعْتَصِمُ بِاللَّهِ، وَنَسْتَجِيرُ بِهِ.

<q>﴿اسْتَيْأَسُوا﴾</q> يَئِسُوا وَانْقَطَعَ رَجَاؤُهُم.

<q>﴿خَلَصُوا نَجِيًّا﴾</q> انْفَرَدُوا يَتَشَاوَرُونَ.

<q>﴿مَوْثِقًا﴾</q> عَهْدًا مُؤَكَّدًا.

<q>﴿فَرَّطْتُمْ﴾</q> قَصَّرْتُمْ.

<q>﴿أَبْرَحَ﴾</q> أُفَارِقَ.

<q>﴿وَالْعِيرَ﴾</q> القَافِلَةَ.

<q>﴿سَوَّلَتْ﴾</q> زَيَّنَتْ.

<q>﴿كَظِيمٌ﴾</q> شَدِيدُ الكِتْمَانِ لِحُزْنِهِ.

<q>﴿تَفْتَأُ﴾</q> مَا تَزَالُ.

<q>﴿حَرَضًا﴾</q> تُشْرِفُ عَلَى الهَلاَكِ.

<q>﴿بَثِّي﴾</q> هَمِّي.

