quran[7]{c,v,t}:
  42,45,"<div class=ar lang=ar><h3>الوقفات التدبرية</h3><p>١- <span class="qpc-hafs">﴿وَتَرَىٰهُمْ يُعْرَضُونَ عَلَيْهَا خَٰشِعِينَ مِنَ ٱلذُّلِّ﴾</span></p><p>أي: الذل قد اعتراهم بما أسلفوا من عصيان الله تعالى. [ابن كثير:٤/١٢٢]</p><p>السؤال: ما سبب ذلهم يوم القيامة ؟.</p><p>٢- <span class="qpc-hafs">﴿وَقَالَ ٱلَّذِينَ ءَامَنُوٓا۟ إِنَّ ٱلْخَٰسِرِينَ ٱلَّذِينَ خَسِرُوٓا۟ أَنفُسَهُمْ وَأَهْلِيهِمْ يَوْمَ ٱلْقِيَٰمَةِ ۗ أَلَآ إِنَّ ٱلظَّٰلِمِينَ فِى عَذَابٍ مُّقِيمٍ﴾</span></p><p>أما خسرانهم لأنفسهم فلكونهم صاروا في النار معذبين بها، وأما خسرانهم لأهليهم فلأنهم إن كانوا معهم في النار فلا ينتفعون بهم، وإن كانوا في الجنة فقد حيل بينهم وبينهم. [الشوكاني:٤/٥٤٣]</p><p>السؤال: بين كيفية خسران النفس والأهل يوم القيامة؟</p><p>٣- <span class="qpc-hafs">﴿سْتَجِيبُوا۟ لِرَبِّكُم مِّن قَبْلِ أَن يَأْتِىَ يَوْمٌ لَّا مَرَدَّ لَهُۥ مِنَ ٱللَّهِ ۚ مَا لَكُم مِّن مَّلْجَإٍ يَوْمَئِذٍ وَمَا لَكُم مِّن نَّكِيرٍ﴾</span></p><p>هذه الآية ونحوها فيها ذم الأمل، والأمر بانتهاز الفرصة في كل عمل يعرض للعبد؛ فإن للتأخير آفات. [السعدي:٧٦١]</p><p>السؤال: ما الأمل المذموم؟ وهل يسوغ تأخير العمل؟</p><p>٤- <span class="qpc-hafs">﴿فَإِنْ أَعْرَضُوا۟ فَمَآ أَرْسَلْنَٰكَ عَلَيْهِمْ حَفِيظًا﴾</span></p><p>أي حافظاً لأعمالهم حتى تحاسبهم عليها، وقيل موكلاً بهم لا تفارقهم دون أن يؤمنوا، أي: ليس لك إكراههم على الإيمان. [القرطبي:١٨/٥٠٠. ]</p><p>السؤال: في الآية تسلية للدعاة عند عدم الاستجابة لهم، وضح ذلك.</p><p>٥- <span class="qpc-hafs">﴿وَإِنَّآ إِذَآ أَذَقْنَا ٱلْإِنسَٰنَ مِنَّا رَحْمَةً فَرِحَ بِهَا ۖ وَإِن تُصِبْهُمْ سَيِّئَةٌۢ بِمَا قَدَّمَتْ أَيْدِيهِمْ فَإِنَّ ٱلْإِنسَٰنَ كَفُورٌ﴾</span></p><p>وفيه إشارة إلى أنَّ إذاقة الرحمة ليست للفرح والبطر, بل للشكر لموليها. وإصابة المِحنة ليست للكفران والجزع, بل للرجوع إلى مُبْلِيها. [الألوسي:٢٥/٧٥]</p><p>السؤال: ما الواجب على المؤمن أن يفعله في حال الرخاء, وفي حال الشِدَّة؟</p><p>٦- <span class="qpc-hafs">﴿وَإِن تُصِبْهُمْ سَيِّئَةٌۢ بِمَا قَدَّمَتْ أَيْدِيهِمْ فَإِنَّ ٱلْإِنسَٰنَ كَفُورٌ﴾</span></p><p>أي: يجحد ما تقدم من النعم، ولا يعرف إلا الساعة الراهنة. [ابن كثير:٤/١٢٢-١٢٣]</p><p>السؤال: ما الفرق بين المسلم والكافر في النظر إلى النعم السابقة؟</p><p>٧- <span class="qpc-hafs">﴿لِّلَّهِ مُلْكُ ٱلسَّمَٰوَٰتِ وَٱلْأَرْضِ ۚ يَخْلُقُ مَا يَشَآءُ ۚ يَهَبُ لِمَن يَشَآءُ إِنَٰثًا وَيَهَبُ لِمَن يَشَآءُ ٱلذُّكُورَ﴾</span></p><p>وقيل: قَدَّمَ الإناث توصية برعايتهنَّ لضعفهنَّ؛ لا سيما وكانوا قريبي العهد بالوأد, وفي الحديث: <span class="qpc-hafs">﴿من ابتُلِيَ بشيء من هذه البنات فأحسن إليهنَّ كنَّ له ستراً من النار﴾</span>. [الألوسي: ٢/٧٥-٧٦]</p><p>السؤال: بين تكريم ا الإسلام للمرأة وحفظه لها من خلال الآية والحديث.</p><h3>التوجيهات</h3><p>١- ما أعظم خسائر الظالم يوم القيامة، <span class="qpc-hafs">﴿ۗ وَقَالَ ٱلَّذِينَ ءَامَنُوٓا۟ إِنَّ ٱلْخَٰسِرِينَ ٱلَّذِينَ خَسِرُوٓا۟ أَنفُسَهُمْ وَأَهْلِيهِمْ يَوْمَ ٱلْقِيَٰمَةِ﴾</span></p><p>٢- مهمة الرسل التبيلغ والدعوة, <span class="qpc-hafs">﴿فَإِنْ أَعْرَضُوا۟ فَمَآ أَرْسَلْنَٰكَ عَلَيْهِمْ حَفِيظًا﴾</span></p><p>٣- حكمة الله تعالى وعلمه فيما يهب للعباد من الذرية,<span class="qpc-hafs">﴿يَخْلُقُ مَا يَشَآءُ ۚ يَهَبُ لِمَن يَشَآءُ إِنَٰثًا وَيَهَبُ لِمَن يَشَآءُ ٱلذُّكُورَ﴾</span></p><h3>العمل بالآيات</h3><p>١- استجب لكل أمر أمرك به الله تعالى من فعل أو ترك, <span class="qpc-hafs">﴿ٱسْتَجِيبُوا۟ لِرَبِّكُم مِّن قَبْلِ أَن يَأْتِىَ يَوْمٌ لَّا مَرَدَّ لَهُۥ مِنَ ٱللَّهِ ۚ مَا لَكُم مِّن مَّلْجَإٍ يَوْمَئِذٍ وَمَا لَكُم مِّن نَّكِيرٍ﴾</span></p><p>٢- انصح أهلك وادع الله لهم ولنفسك بالهداية، <span class="qpc-hafs">﴿إِنَّ ٱلْخَٰسِرِينَ ٱلَّذِينَ خَسِرُوٓا۟ أَنفُسَهُمْ وَأَهْلِيهِمْ يَوْمَ ٱلْقِيَٰمَةِ﴾</span></p><p>٣- انظر أمرا أمرتك به آية أو حديثا كنت مترددا في تطبيقه، وسارع في الاستجابة له، <span class="qpc-hafs">﴿ٱسْتَجِيبُوا۟ لِرَبِّكُم مِّن قَبْلِ أَن يَأْتِىَ يَوْمٌ لَّا مَرَدَّ لَهُۥ مِنَ ٱللَّهِ ۚ مَا لَكُم مِّن مَّلْجَإٍ يَوْمَئِذٍ وَمَا لَكُم مِّن نَّكِيرٍ﴾</span></p><h3>معاني الكلمات</h3><p><span class="qpc-hafs">﴿خَاشِعِينَ﴾</span> خَاضِعِينَ مُتَضَائِلِينَ.</p><p><span class="qpc-hafs">﴿يَنْظُرُونَ مِنْ طَرْفٍ خَفِيٍّ﴾</span> يُسَارِقُونَ النَّظَرَ، وَلاَ يَنْظُرُونَ بِمِلْءِ أَعْيُنِهِمْ.</p><p><span class="qpc-hafs">﴿فَمَا لَهُ مِنْ سَبِيلٍ﴾</span> مَا لَهُ مِنْ طَرِيقٍ يَصِلُ بِهِ إِلَى الحَقِّ فِي الدُّنْيَا.</p><p><span class="qpc-hafs">﴿لاَّ مَرَدَّ لَهُ﴾</span> لاَ يُمْكِنُ رَدُّهُ.</p><p><span class="qpc-hafs">﴿نَكِيرٍ﴾</span> لاَ تُنْكِرُونَ ذُنُوبَكُمْ، وَلَيْسَ لَكُمْ مَكَانٌ تَسْتَخْفُونَ وَتَتَنَكَّرُونَ فِيهِ.</p><p><span class="qpc-hafs">﴿حَفِيظًا﴾</span> حَافِظًا لأَِعْمَالِهِمْ.</p><p><span class="qpc-hafs">﴿كَفُورٌ﴾</span> جَحُودٌ؛ يُعَدِّدُ المَصَائِبَ، وَيَنْسَى النِّعَمَ.</p><p><span class="qpc-hafs">﴿يُزَوِّجُهُمْ﴾</span> يَجْمَعُ لَهُ النَّوْعَيْنِ.</p><p><span class="qpc-hafs">﴿عَقِيمًا﴾</span> لاَ يُولَدُ لَهُ.</p><p><span class="qpc-hafs">﴿وَحْيًا﴾</span> إِعْلاَمًا فِي المَنَامِ، أَوْ بِالإِلْهَامِ.</p><p><span class="qpc-hafs">﴿مِنْ وَرَاءِ حِجَابٍ﴾</span> كَمَا كَلَّمَ مُوسَى عليه السلام.</p><p><span class="qpc-hafs">﴿رَسُولاً﴾</span> هُوَ: جِبْرِيلُ عليه السلام.</p></div>"
  42,46,"42:45"
