quran[7]{c,v,t}:
  42,45,"

الوقفات التدبرية

١- <q>﴿وَتَرَىٰهُمْ يُعْرَضُونَ عَلَيْهَا خَٰشِعِينَ مِنَ ٱلذُّلِّ﴾</q>

أي: الذل قد اعتراهم بما أسلفوا من عصيان الله تعالى. [ابن كثير:٤/١٢٢]

السؤال: ما سبب ذلهم يوم القيامة ؟.

٢- <q>﴿وَقَالَ ٱلَّذِينَ ءَامَنُوٓا۟ إِنَّ ٱلْخَٰسِرِينَ ٱلَّذِينَ خَسِرُوٓا۟ أَنفُسَهُمْ وَأَهْلِيهِمْ يَوْمَ ٱلْقِيَٰمَةِ ۗ أَلَآ إِنَّ ٱلظَّٰلِمِينَ فِى عَذَابٍ مُّقِيمٍ﴾</q>

أما خسرانهم لأنفسهم فلكونهم صاروا في النار معذبين بها، وأما خسرانهم لأهليهم فلأنهم إن كانوا معهم في النار فلا ينتفعون بهم، وإن كانوا في الجنة فقد حيل بينهم وبينهم. [الشوكاني:٤/٥٤٣]

السؤال: بين كيفية خسران النفس والأهل يوم القيامة؟

٣- <q>﴿سْتَجِيبُوا۟ لِرَبِّكُم مِّن قَبْلِ أَن يَأْتِىَ يَوْمٌ لَّا مَرَدَّ لَهُۥ مِنَ ٱللَّهِ ۚ مَا لَكُم مِّن مَّلْجَإٍ يَوْمَئِذٍ وَمَا لَكُم مِّن نَّكِيرٍ﴾</q>

هذه الآية ونحوها فيها ذم الأمل، والأمر بانتهاز الفرصة في كل عمل يعرض للعبد؛ فإن للتأخير آفات. [السعدي:٧٦١]

السؤال: ما الأمل المذموم؟ وهل يسوغ تأخير العمل؟

٤- <q>﴿فَإِنْ أَعْرَضُوا۟ فَمَآ أَرْسَلْنَٰكَ عَلَيْهِمْ حَفِيظًا﴾</q>

أي حافظاً لأعمالهم حتى تحاسبهم عليها، وقيل موكلاً بهم لا تفارقهم دون أن يؤمنوا، أي: ليس لك إكراههم على الإيمان. [القرطبي:١٨/٥٠٠. ]

السؤال: في الآية تسلية للدعاة عند عدم الاستجابة لهم، وضح ذلك.

٥- <q>﴿وَإِنَّآ إِذَآ أَذَقْنَا ٱلْإِنسَٰنَ مِنَّا رَحْمَةً فَرِحَ بِهَا ۖ وَإِن تُصِبْهُمْ سَيِّئَةٌۢ بِمَا قَدَّمَتْ أَيْدِيهِمْ فَإِنَّ ٱلْإِنسَٰنَ كَفُورٌ﴾</q>

وفيه إشارة إلى أنَّ إذاقة الرحمة ليست للفرح والبطر, بل للشكر لموليها. وإصابة المِحنة ليست للكفران والجزع, بل للرجوع إلى مُبْلِيها. [الألوسي:٢٥/٧٥]

السؤال: ما الواجب على المؤمن أن يفعله في حال الرخاء, وفي حال الشِدَّة؟

٦- <q>﴿وَإِن تُصِبْهُمْ سَيِّئَةٌۢ بِمَا قَدَّمَتْ أَيْدِيهِمْ فَإِنَّ ٱلْإِنسَٰنَ كَفُورٌ﴾</q>

أي: يجحد ما تقدم من النعم، ولا يعرف إلا الساعة الراهنة. [ابن كثير:٤/١٢٢-١٢٣]

السؤال: ما الفرق بين المسلم والكافر في النظر إلى النعم السابقة؟

٧- <q>﴿لِّلَّهِ مُلْكُ ٱلسَّمَٰوَٰتِ وَٱلْأَرْضِ ۚ يَخْلُقُ مَا يَشَآءُ ۚ يَهَبُ لِمَن يَشَآءُ إِنَٰثًا وَيَهَبُ لِمَن يَشَآءُ ٱلذُّكُورَ﴾</q>

وقيل: قَدَّمَ الإناث توصية برعايتهنَّ لضعفهنَّ؛ لا سيما وكانوا قريبي العهد بالوأد, وفي الحديث: <q>﴿من ابتُلِيَ بشيء من هذه البنات فأحسن إليهنَّ كنَّ له ستراً من النار﴾</q>. [الألوسي: ٢/٧٥-٧٦]

السؤال: بين تكريم ا الإسلام للمرأة وحفظه لها من خلال الآية والحديث.

التوجيهات

١- ما أعظم خسائر الظالم يوم القيامة، <q>﴿ۗ وَقَالَ ٱلَّذِينَ ءَامَنُوٓا۟ إِنَّ ٱلْخَٰسِرِينَ ٱلَّذِينَ خَسِرُوٓا۟ أَنفُسَهُمْ وَأَهْلِيهِمْ يَوْمَ ٱلْقِيَٰمَةِ﴾</q>

٢- مهمة الرسل التبيلغ والدعوة, <q>﴿فَإِنْ أَعْرَضُوا۟ فَمَآ أَرْسَلْنَٰكَ عَلَيْهِمْ حَفِيظًا﴾</q>

٣- حكمة الله تعالى وعلمه فيما يهب للعباد من الذرية,<q>﴿يَخْلُقُ مَا يَشَآءُ ۚ يَهَبُ لِمَن يَشَآءُ إِنَٰثًا وَيَهَبُ لِمَن يَشَآءُ ٱلذُّكُورَ﴾</q>

العمل بالآيات

١- استجب لكل أمر أمرك به الله تعالى من فعل أو ترك, <q>﴿ٱسْتَجِيبُوا۟ لِرَبِّكُم مِّن قَبْلِ أَن يَأْتِىَ يَوْمٌ لَّا مَرَدَّ لَهُۥ مِنَ ٱللَّهِ ۚ مَا لَكُم مِّن مَّلْجَإٍ يَوْمَئِذٍ وَمَا لَكُم مِّن نَّكِيرٍ﴾</q>

٢- انصح أهلك وادع الله لهم ولنفسك بالهداية، <q>﴿إِنَّ ٱلْخَٰسِرِينَ ٱلَّذِينَ خَسِرُوٓا۟ أَنفُسَهُمْ وَأَهْلِيهِمْ يَوْمَ ٱلْقِيَٰمَةِ﴾</q>

٣- انظر أمرا أمرتك به آية أو حديثا كنت مترددا في تطبيقه، وسارع في الاستجابة له، <q>﴿ٱسْتَجِيبُوا۟ لِرَبِّكُم مِّن قَبْلِ أَن يَأْتِىَ يَوْمٌ لَّا مَرَدَّ لَهُۥ مِنَ ٱللَّهِ ۚ مَا لَكُم مِّن مَّلْجَإٍ يَوْمَئِذٍ وَمَا لَكُم مِّن نَّكِيرٍ﴾</q>

معاني الكلمات

<q>﴿خَاشِعِينَ﴾</q> خَاضِعِينَ مُتَضَائِلِينَ.

<q>﴿يَنْظُرُونَ مِنْ طَرْفٍ خَفِيٍّ﴾</q> يُسَارِقُونَ النَّظَرَ، وَلاَ يَنْظُرُونَ بِمِلْءِ أَعْيُنِهِمْ.

<q>﴿فَمَا لَهُ مِنْ سَبِيلٍ﴾</q> مَا لَهُ مِنْ طَرِيقٍ يَصِلُ بِهِ إِلَى الحَقِّ فِي الدُّنْيَا.

<q>﴿لاَّ مَرَدَّ لَهُ﴾</q> لاَ يُمْكِنُ رَدُّهُ.

<q>﴿نَكِيرٍ﴾</q> لاَ تُنْكِرُونَ ذُنُوبَكُمْ، وَلَيْسَ لَكُمْ مَكَانٌ تَسْتَخْفُونَ وَتَتَنَكَّرُونَ فِيهِ.

<q>﴿حَفِيظًا﴾</q> حَافِظًا لأَِعْمَالِهِمْ.

<q>﴿كَفُورٌ﴾</q> جَحُودٌ؛ يُعَدِّدُ المَصَائِبَ، وَيَنْسَى النِّعَمَ.

<q>﴿يُزَوِّجُهُمْ﴾</q> يَجْمَعُ لَهُ النَّوْعَيْنِ.

<q>﴿عَقِيمًا﴾</q> لاَ يُولَدُ لَهُ.

<q>﴿وَحْيًا﴾</q> إِعْلاَمًا فِي المَنَامِ، أَوْ بِالإِلْهَامِ.

<q>﴿مِنْ وَرَاءِ حِجَابٍ﴾</q> كَمَا كَلَّمَ مُوسَى عليه السلام.

<q>﴿رَسُولاً﴾</q> هُوَ: جِبْرِيلُ عليه السلام.

