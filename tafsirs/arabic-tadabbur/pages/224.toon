quran[9]{c,v,t}:
  11,20,"

الوقفات التدبرية

١- <q>﴿يُضَٰعَفُ لَهُمُ ٱلْعَذَابُ ۚ مَا كَانُوا۟ يَسْتَطِيعُونَ ٱلسَّمْعَ وَمَا كَانُوا۟ يُبْصِرُونَ﴾</q>

<q>﴿يضاعف لهم العذاب﴾</q> ... لأنهم ضلوا بأنفسهم، وأضلوا غيرهم. [السعدي:٣٧٩]

السؤال: لماذا يضاعف لهم العذاب؟

٢- <q>﴿لَا جَرَمَ أَنَّهُمْ فِى ٱلْءَاخِرَةِ هُمُ ٱلْأَخْسَرُونَ﴾</q>

يخبر تعالى عن حالهم أنهم أخسر الناس صفقة في الدار الآخرة؛ لأنهم: استبدلوا الدركات عن الدرجات، واعتاضوا عن نعيم الجنان بحميم آن، وعن شرب الرحيق المختوم بسموم وحميم، وظل من يحموم، وعن الحور العين بطعام من غسلين، وعن القصور العالية بالهاوية، وعن قرب الرحمن ورؤيته بغضب الديان وعقوبته. [ابن كثير:٢/٤٢٣]

السؤال: لمَ وصفهم الله تعالى بالأخسرين، ولم يصفهم بالخاسرين؟

٣- <q>﴿إِنَّ ٱلَّذِينَ ءَامَنُوا۟ وَعَمِلُوا۟ ٱلصَّٰلِحَٰتِ وَأَخْبَتُوٓا۟ إِلَىٰ رَبِّهِمْ أُو۟لَٰٓئِكَ أَصْحَٰبُ ٱلْجَنَّةِ ۖ هُمْ فِيهَا خَٰلِدُونَ﴾</q>

<q>﴿وأخبتوا إلى ربهم﴾</q>: الإخبات الخشوع للمخافة الثابتة في القلب، وأصل الإخبات الاستواء؛ من الخبت وهو الأرض المستوية الواسعة؛ فالإخبات: الخشوع والاطمئنان، أو الإنابة إلى الله عز وجل المستمرة. [القرطبي:١١/٩٦]

السؤال: كيف يكون العبد من المخبتين؟

٤- <q>﴿فَقَالَ ٱلْمَلَأُ ٱلَّذِينَ كَفَرُوا۟ مِن قَوْمِهِۦ مَا نَرَىٰكَ إِلَّا بَشَرًا مِّثْلَنَا وَمَا نَرَىٰكَ ٱتَّبَعَكَ إِلَّا ٱلَّذِينَ هُمْ أَرَاذِلُنَا بَادِىَ ٱلرَّأْىِ وَمَا نَرَىٰ لَكُمْ عَلَيْنَا مِن فَضْلٍۭ بَلْ نَظُنُّكُمْ كَٰذِبِينَ﴾</q>

قال علماؤنا: إنما كان ذلك لاستيلاء الرياسة على الأشراف، وصعوبة الانفكاك عنها، والأنفة من الانقياد للغير. والفقير خلي عن تلك الموانع؛ فهو سريع إلى الإجابة والانقياد، وهذا غالب أحوال أهل الدنيا. [القرطبي:١١/٩٩]

السؤال: لماذا يقبل الحق أهل الفقر والمسكنة، ويرده أهل الرياسة والغنى غالبا؟

٥- <q>﴿﴾</q> فَقَالَ ٱلْمَلَأُ ٱلَّذِينَ كَفَرُوا۟ مِن قَوْمِهِۦ مَا نَرَىٰكَ إِلَّا بَشَرًا مِّثْلَنَا وَمَا نَرَىٰكَ ٱتَّبَعَكَ إِلَّا ٱلَّذِينَ هُمْ أَرَاذِلُنَا بَادِىَ ٱلرَّأْىِ﴾

وكان هذا جهلاً منهم؛ لأنهم عابوا نبي الله -صلى الله عليه وسلم- بما لا عيب فيه؛ لأن الأنبياء -صلوات الله وسلامه عليهم- إنما عليهم أن يأتوا بالبراهين والآيات، وليس عليهم تغيير الصور والهيئات، وهم يرسلون إلى الناس جميعا، فإذا أسلم منهم الدنيء لم يلحقهم من ذلك نقصان؛ لأن عليهم أن يقبلوا إسلام كل من أسلم منهم. [القرطبي:١١/٩٩]

السؤال: هل اتباع الضعفاء والفقراء للداعية عيب ونقص في دعوته؟

٦- <q>﴿فَقَالَ ٱلْمَلَأُ ٱلَّذِينَ كَفَرُوا۟ مِن قَوْمِهِۦ مَا نَرَىٰكَ إِلَّا بَشَرًا مِّثْلَنَا وَمَا نَرَىٰكَ ٱتَّبَعَكَ إِلَّا ٱلَّذِينَ هُمْ أَرَاذِلُنَا بَادِىَ ٱلرَّأْىِ وَمَا نَرَىٰ لَكُمْ عَلَيْنَا مِن فَضْلٍۭ بَلْ نَظُنُّكُمْ كَٰذِبِينَ﴾</q>

<q>﴿أراذلنا﴾</q>: جمع أرذل؛ وهم سفلة الناس؛ وإنما وصفوهم بذلك لفقرهم، جهلاً منهم واعتقاداً أن الشرف هو بالمال والجاه، وليس الأمر كما اعتقدوا، بل المؤمنون كانوا أشرف منهم على حال فقرهم وخمولهم في الدنيا. <q>﴿بادي الرأي﴾</q> أي: أول الرأي من غير نظر، ولا تدبير، والمعنى: اتبعك الأراذل من غير نظر، ولا تثبت. [ابن جزي:١/٣٩٤]

السؤال: بينت هذه الآية معالم أهل الكفر في رميهم بالتهم لأهل الحق, وضحها.

٧- <q>﴿قَالَ يَٰقَوْمِ أَرَءَيْتُمْ إِن كُنتُ عَلَىٰ بَيِّنَةٍ مِّن رَّبِّى وَءَاتَىٰنِى رَحْمَةً مِّنْ عِندِهِۦ فَعُمِّيَتْ عَلَيْكُمْ أَنُلْزِمُكُمُوهَا وَأَنتُمْ لَهَا كَٰرِهُونَ﴾</q>

وهذا تعريض بأنهم لو تأملوا تأملا بريئا من الكراهية والعداوة لعلموا صدق دعوته. [ابن عاشور:١٢/٥١]

السؤال: للعناد والكراهية أثر في مواقف المشركين والمعاندين، وضح ذلك؟

التوجيهات

١- إضلال الآخرين سبب في مضاعفة العذاب؛ فإياك أن تدل غيرك على معصية، <q>﴿ۘ يُضَٰعَفُ لَهُمُ ٱلْعَذَابُ﴾</q>

٢- لا تحتقر أحداً في دعوتك لمكانته الاجتماعية أو المادية، <q>﴿فَقَالَ ٱلْمَلَأُ ٱلَّذِينَ كَفَرُوا۟ مِن قَوْمِهِۦ مَا نَرَىٰكَ إِلَّا بَشَرًا مِّثْلَنَا وَمَا نَرَىٰكَ ٱتَّبَعَكَ إِلَّا ٱلَّذِينَ هُمْ أَرَاذِلُنَا بَادِىَ ٱلرَّأْىِ﴾</q>

٣- اعتنِ أكثر بهداية الوجهاء؛ فإنهم سبب لهداية أتباعهم، <q>﴿فَقَالَ ٱلْمَلَأُ ٱلَّذِينَ كَفَرُوا۟ مِن قَوْمِهِۦ مَا نَرَىٰكَ إِلَّا بَشَرًا مِّثْلَنَا﴾</q>

العمل بالآيات

١- صلِّ ركعتين، ثم ادع الله تعالى وتضرع إليه أن يرزقك الإخبات إليه؛ أي: التواضع والتسليم له سبحانه، <q>﴿إِنَّ ٱلَّذِينَ ءَامَنُوا۟ وَعَمِلُوا۟ ٱلصَّٰلِحَٰتِ وَأَخْبَتُوٓا۟ إِلَىٰ رَبِّهِمْ أُو۟لَٰٓئِكَ أَصْحَٰبُ ٱلْجَنَّةِ ۖ هُمْ فِيهَا خَٰلِدُونَ﴾</q>

٢- أرسل رسالة تقترح فيها ثلاث وسائل لهداية الوجهاء ودعوتهم، <q>﴿فَقَالَ ٱلْمَلَأُ ٱلَّذِينَ كَفَرُوا۟ مِن قَوْمِهِۦ مَا نَرَىٰكَ إِلَّا بَشَرًا مِّثْلَنَا﴾</q>

٣- ألقِ كلمة، أو ابذل نصيحة، أو غيَّر منكرًا بالأسلوب الحسن، ثم اقرأ قصص الأنبياء في سورة هود؛ فسيظهر لك من مقاصدها الشيءُ الكثير، <q>﴿وَلَقَدْ أَرْسَلْنَا نُوحًا إِلَىٰ قَوْمِهِۦٓ إِنِّى لَكُمْ نَذِيرٌ مُّبِينٌ﴾</q>

معاني الكلمات

<q>﴿مُعْجِزِينَ﴾</q> فَائِتِينَ مِنْ عَذَابِ اللهِ بِالهَرَبِ.

<q>﴿وَضَلَّ﴾</q> ذَهَبَ.

<q>﴿لا جَرَمَ﴾</q> حَقًّا.

<q>﴿وَأَخْبَتُوا﴾</q> خَضَعُوا لِلَّهِ.

<q>﴿وَالأَصَمِّ﴾</q> الَّذِي لا يَسْمَعُ.

<q>﴿الْمَلأُ﴾</q> رُؤَسَاءُ الكُفْرِ.

<q>﴿أَرَاذِلُنَا﴾</q> أَسَافِلُنَا.

<q>﴿بَادِيَ الرَّأْيِ﴾</q> مِنْ غَيْرِ تَفَكُّرٍ، وَلاَ رَوِيَّةٍ.

<q>﴿فَعُمِّيَتْ عَلَيْكُمْ﴾</q> فَأُخْفِيَتْ عَلَيْكُمْ.

<q>﴿أَنُلْزِمُكُمُوهَا﴾</q> أَنُجْبِرُكم عَلَى قَبُولِهَا.

