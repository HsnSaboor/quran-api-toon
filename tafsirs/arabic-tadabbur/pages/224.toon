quran[9]{c,v,t}:
  11,20,"<div class=ar lang=ar><h3>الوقفات التدبرية</h3><p>١- <span class="qpc-hafs">﴿يُضَٰعَفُ لَهُمُ ٱلْعَذَابُ ۚ مَا كَانُوا۟ يَسْتَطِيعُونَ ٱلسَّمْعَ وَمَا كَانُوا۟ يُبْصِرُونَ﴾</span></p><p><span class="qpc-hafs">﴿يضاعف لهم العذاب﴾</span> ... لأنهم ضلوا بأنفسهم، وأضلوا غيرهم. [السعدي:٣٧٩]</p><p>السؤال: لماذا يضاعف لهم العذاب؟</p><p>٢- <span class="qpc-hafs">﴿لَا جَرَمَ أَنَّهُمْ فِى ٱلْءَاخِرَةِ هُمُ ٱلْأَخْسَرُونَ﴾</span></p><p>يخبر تعالى عن حالهم أنهم أخسر الناس صفقة في الدار الآخرة؛ لأنهم: استبدلوا الدركات عن الدرجات، واعتاضوا عن نعيم الجنان بحميم آن، وعن شرب الرحيق المختوم بسموم وحميم، وظل من يحموم، وعن الحور العين بطعام من غسلين، وعن القصور العالية بالهاوية، وعن قرب الرحمن ورؤيته بغضب الديان وعقوبته. [ابن كثير:٢/٤٢٣]</p><p>السؤال: لمَ وصفهم الله تعالى بالأخسرين، ولم يصفهم بالخاسرين؟</p><p>٣- <span class="qpc-hafs">﴿إِنَّ ٱلَّذِينَ ءَامَنُوا۟ وَعَمِلُوا۟ ٱلصَّٰلِحَٰتِ وَأَخْبَتُوٓا۟ إِلَىٰ رَبِّهِمْ أُو۟لَٰٓئِكَ أَصْحَٰبُ ٱلْجَنَّةِ ۖ هُمْ فِيهَا خَٰلِدُونَ﴾</span></p><p><span class="qpc-hafs">﴿وأخبتوا إلى ربهم﴾</span>: الإخبات الخشوع للمخافة الثابتة في القلب، وأصل الإخبات الاستواء؛ من الخبت وهو الأرض المستوية الواسعة؛ فالإخبات: الخشوع والاطمئنان، أو الإنابة إلى الله عز وجل المستمرة. [القرطبي:١١/٩٦]</p><p>السؤال: كيف يكون العبد من المخبتين؟</p><p>٤- <span class="qpc-hafs">﴿فَقَالَ ٱلْمَلَأُ ٱلَّذِينَ كَفَرُوا۟ مِن قَوْمِهِۦ مَا نَرَىٰكَ إِلَّا بَشَرًا مِّثْلَنَا وَمَا نَرَىٰكَ ٱتَّبَعَكَ إِلَّا ٱلَّذِينَ هُمْ أَرَاذِلُنَا بَادِىَ ٱلرَّأْىِ وَمَا نَرَىٰ لَكُمْ عَلَيْنَا مِن فَضْلٍۭ بَلْ نَظُنُّكُمْ كَٰذِبِينَ﴾</span></p><p>قال علماؤنا: إنما كان ذلك لاستيلاء الرياسة على الأشراف، وصعوبة الانفكاك عنها، والأنفة من الانقياد للغير. والفقير خلي عن تلك الموانع؛ فهو سريع إلى الإجابة والانقياد، وهذا غالب أحوال أهل الدنيا. [القرطبي:١١/٩٩]</p><p>السؤال: لماذا يقبل الحق أهل الفقر والمسكنة، ويرده أهل الرياسة والغنى غالبا؟</p><p>٥- <span class="qpc-hafs">﴿﴾</span> فَقَالَ ٱلْمَلَأُ ٱلَّذِينَ كَفَرُوا۟ مِن قَوْمِهِۦ مَا نَرَىٰكَ إِلَّا بَشَرًا مِّثْلَنَا وَمَا نَرَىٰكَ ٱتَّبَعَكَ إِلَّا ٱلَّذِينَ هُمْ أَرَاذِلُنَا بَادِىَ ٱلرَّأْىِ﴾</p><p>وكان هذا جهلاً منهم؛ لأنهم عابوا نبي الله -صلى الله عليه وسلم- بما لا عيب فيه؛ لأن الأنبياء -صلوات الله وسلامه عليهم- إنما عليهم أن يأتوا بالبراهين والآيات، وليس عليهم تغيير الصور والهيئات، وهم يرسلون إلى الناس جميعا، فإذا أسلم منهم الدنيء لم يلحقهم من ذلك نقصان؛ لأن عليهم أن يقبلوا إسلام كل من أسلم منهم. [القرطبي:١١/٩٩]</p><p>السؤال: هل اتباع الضعفاء والفقراء للداعية عيب ونقص في دعوته؟</p><p>٦- <span class="qpc-hafs">﴿فَقَالَ ٱلْمَلَأُ ٱلَّذِينَ كَفَرُوا۟ مِن قَوْمِهِۦ مَا نَرَىٰكَ إِلَّا بَشَرًا مِّثْلَنَا وَمَا نَرَىٰكَ ٱتَّبَعَكَ إِلَّا ٱلَّذِينَ هُمْ أَرَاذِلُنَا بَادِىَ ٱلرَّأْىِ وَمَا نَرَىٰ لَكُمْ عَلَيْنَا مِن فَضْلٍۭ بَلْ نَظُنُّكُمْ كَٰذِبِينَ﴾</span></p><p><span class="qpc-hafs">﴿أراذلنا﴾</span>: جمع أرذل؛ وهم سفلة الناس؛ وإنما وصفوهم بذلك لفقرهم، جهلاً منهم واعتقاداً أن الشرف هو بالمال والجاه، وليس الأمر كما اعتقدوا، بل المؤمنون كانوا أشرف منهم على حال فقرهم وخمولهم في الدنيا. <span class="qpc-hafs">﴿بادي الرأي﴾</span> أي: أول الرأي من غير نظر، ولا تدبير، والمعنى: اتبعك الأراذل من غير نظر، ولا تثبت. [ابن جزي:١/٣٩٤]</p><p>السؤال: بينت هذه الآية معالم أهل الكفر في رميهم بالتهم لأهل الحق, وضحها.</p><p>٧- <span class="qpc-hafs">﴿قَالَ يَٰقَوْمِ أَرَءَيْتُمْ إِن كُنتُ عَلَىٰ بَيِّنَةٍ مِّن رَّبِّى وَءَاتَىٰنِى رَحْمَةً مِّنْ عِندِهِۦ فَعُمِّيَتْ عَلَيْكُمْ أَنُلْزِمُكُمُوهَا وَأَنتُمْ لَهَا كَٰرِهُونَ﴾</span></p><p>وهذا تعريض بأنهم لو تأملوا تأملا بريئا من الكراهية والعداوة لعلموا صدق دعوته. [ابن عاشور:١٢/٥١]</p><p>السؤال: للعناد والكراهية أثر في مواقف المشركين والمعاندين، وضح ذلك؟</p><h3>التوجيهات</h3><p>١- إضلال الآخرين سبب في مضاعفة العذاب؛ فإياك أن تدل غيرك على معصية، <span class="qpc-hafs">﴿ۘ يُضَٰعَفُ لَهُمُ ٱلْعَذَابُ﴾</span></p><p>٢- لا تحتقر أحداً في دعوتك لمكانته الاجتماعية أو المادية، <span class="qpc-hafs">﴿فَقَالَ ٱلْمَلَأُ ٱلَّذِينَ كَفَرُوا۟ مِن قَوْمِهِۦ مَا نَرَىٰكَ إِلَّا بَشَرًا مِّثْلَنَا وَمَا نَرَىٰكَ ٱتَّبَعَكَ إِلَّا ٱلَّذِينَ هُمْ أَرَاذِلُنَا بَادِىَ ٱلرَّأْىِ﴾</span></p><p>٣- اعتنِ أكثر بهداية الوجهاء؛ فإنهم سبب لهداية أتباعهم، <span class="qpc-hafs">﴿فَقَالَ ٱلْمَلَأُ ٱلَّذِينَ كَفَرُوا۟ مِن قَوْمِهِۦ مَا نَرَىٰكَ إِلَّا بَشَرًا مِّثْلَنَا﴾</span></p><h3>العمل بالآيات</h3><p>١- صلِّ ركعتين، ثم ادع الله تعالى وتضرع إليه أن يرزقك الإخبات إليه؛ أي: التواضع والتسليم له سبحانه، <span class="qpc-hafs">﴿إِنَّ ٱلَّذِينَ ءَامَنُوا۟ وَعَمِلُوا۟ ٱلصَّٰلِحَٰتِ وَأَخْبَتُوٓا۟ إِلَىٰ رَبِّهِمْ أُو۟لَٰٓئِكَ أَصْحَٰبُ ٱلْجَنَّةِ ۖ هُمْ فِيهَا خَٰلِدُونَ﴾</span></p><p>٢- أرسل رسالة تقترح فيها ثلاث وسائل لهداية الوجهاء ودعوتهم، <span class="qpc-hafs">﴿فَقَالَ ٱلْمَلَأُ ٱلَّذِينَ كَفَرُوا۟ مِن قَوْمِهِۦ مَا نَرَىٰكَ إِلَّا بَشَرًا مِّثْلَنَا﴾</span></p><p>٣- ألقِ كلمة، أو ابذل نصيحة، أو غيَّر منكرًا بالأسلوب الحسن، ثم اقرأ قصص الأنبياء في سورة هود؛ فسيظهر لك من مقاصدها الشيءُ الكثير، <span class="qpc-hafs">﴿وَلَقَدْ أَرْسَلْنَا نُوحًا إِلَىٰ قَوْمِهِۦٓ إِنِّى لَكُمْ نَذِيرٌ مُّبِينٌ﴾</span></p><h3>معاني الكلمات</h3><p><span class="qpc-hafs">﴿مُعْجِزِينَ﴾</span> فَائِتِينَ مِنْ عَذَابِ اللهِ بِالهَرَبِ.</p><p><span class="qpc-hafs">﴿وَضَلَّ﴾</span> ذَهَبَ.</p><p><span class="qpc-hafs">﴿لا جَرَمَ﴾</span> حَقًّا.</p><p><span class="qpc-hafs">﴿وَأَخْبَتُوا﴾</span> خَضَعُوا لِلَّهِ.</p><p><span class="qpc-hafs">﴿وَالأَصَمِّ﴾</span> الَّذِي لا يَسْمَعُ.</p><p><span class="qpc-hafs">﴿الْمَلأُ﴾</span> رُؤَسَاءُ الكُفْرِ.</p><p><span class="qpc-hafs">﴿أَرَاذِلُنَا﴾</span> أَسَافِلُنَا.</p><p><span class="qpc-hafs">﴿بَادِيَ الرَّأْيِ﴾</span> مِنْ غَيْرِ تَفَكُّرٍ، وَلاَ رَوِيَّةٍ.</p><p><span class="qpc-hafs">﴿فَعُمِّيَتْ عَلَيْكُمْ﴾</span> فَأُخْفِيَتْ عَلَيْكُمْ.</p><p><span class="qpc-hafs">﴿أَنُلْزِمُكُمُوهَا﴾</span> أَنُجْبِرُكم عَلَى قَبُولِهَا.</p></div>"
  11,21,"11:20"
  11,22,"11:20"
  11,23,"11:20"
