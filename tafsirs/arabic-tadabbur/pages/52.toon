quran[7]{c,v,t}:
  3,16,"

الوقفات التدبرية

١- <q>﴿ٱلصَّٰبِرِينَ وَٱلصَّٰدِقِينَ وَٱلْقَٰنِتِينَ وَٱلْمُنفِقِينَ وَٱلْمُسْتَغْفِرِينَ بِٱلْأَسْحَارِ﴾</q>

تخصيص الأسحار بالاستغفار لأن الدعاء فيها أقرب إلى الإجابة، إذ العبادة حينئذ أشق، والنفس أصفى، والروع أجمع. [الألوسي:٣/١٠٢]

السؤال: لماذا خصص الأسحار بالاستغفار؟

٢- <q>﴿ٱلصَّٰبِرِينَ وَٱلصَّٰدِقِينَ وَٱلْقَٰنِتِينَ وَٱلْمُنفِقِينَ وَٱلْمُسْتَغْفِرِينَ بِٱلْأَسْحَارِ﴾</q>

كانوا يحيون الليل صلاة، ثم يقعدون في السحر يستغفرون؛ فيختمون قيام الليل بالاستغفار. [ابن تيمية:٢/٣٩]

السؤال: بِمَ تختم أكثر العبادات؟

٣- <q>﴿شَهِدَ ٱللَّهُ أَنَّهُۥ لَآ إِلَٰهَ إِلَّا هُوَ وَٱلْمَلَٰٓئِكَةُ وَأُو۟لُوا۟ ٱلْعِلْمِ قَآئِمًۢا بِٱلْقِسْطِ ۚ لَآ إِلَٰهَ إِلَّا هُوَ ٱلْعَزِيزُ ٱلْحَكِيمُ﴾</q>

وفي هذا دليل على أن أشرف الأمور علم التوحيد؛ لأن الله شهد به بنفسه، وأشهد عليه خواص خلقه، والشهادة لا تكون إلا عن علم ويقين، بمنزلة المشاهدة للبصر. [السعدي: ١٢٥]

السؤال: ما منْزلة علم التوحيد؟ وكيف تستدل على ما تقول بهذه الآية؟

٤- <q>﴿شَهِدَ ٱللَّهُ أَنَّهُۥ لَآ إِلَٰهَ إِلَّا هُوَ وَٱلْمَلَٰٓئِكَةُ وَأُو۟لُوا۟ ٱلْعِلْمِ قَآئِمًۢا بِٱلْقِسْطِ ۚ لَآ إِلَٰهَ إِلَّا هُوَ ٱلْعَزِيزُ ٱلْحَكِيمُ﴾</q>

في هذه الآية دليل على شرف العلم من وجوه كثيرة: منها: أن الله قرن شهادة العلماء بشهادته وشهادة ملائكته، وكفى بذلك فضلاً ... ومنها: أنه تعالى جعلهم شهداء وحجة على الناس، وألزم الناس العمل بالأمر المشهود به؛ فيكونون هم السبب في ذلك، فيكون كل من عمل بذلك نالهم من أجره، وذلك فضل الله يؤتيه من يشاء، ومنها: أن إشهاده تعالى أهل العلم يتضمن ذلك تزكيتهم وتعديلهم، وأنهم أمناء على ما استرعاهم عليه. [السعدي: ١٢٥]

السؤال: دلت الآية على شرف العلم والعلماء من عدة وجوه، بَيِّنها.

٥- <q>﴿إِنَّ ٱلدِّينَ عِندَ ٱللَّهِ ٱلْإِسْلَٰمُ ۗ وَمَا ٱخْتَلَفَ ٱلَّذِينَ أُوتُوا۟ ٱلْكِتَٰبَ إِلَّا مِنۢ بَعْدِ مَا جَآءَهُمُ ٱلْعِلْمُ بَغْيًۢا بَيْنَهُمْ ۗ وَمَن يَكْفُرْ بِـَٔايَٰتِ ٱللَّهِ فَإِنَّ ٱللَّهَ سَرِيعُ ٱلْحِسَابِ﴾</q>

سبب الاجتماع والألفة: جمع الدين والعمل به كله؛ وهو عبادة الله وحده لا شريك له كما أمر به باطنا وظاهرا. وسبب الفرقة: ترك حظ مما أمر العبد به، والبغي بينهم. ونتيجة الجماعة: رحمة الله، ورضوانه، وصلواته، وسعادة الدنيا والآخرة، وبياض الوجوه. ونتيجة الفرقة: عذاب الله، ولعنته، وسواد الوجوه، وبراءة الرسول ﷺ منهم. [ابن تيمية:٢/٥٥]

السؤال: ما سبب الاجتماع؟ و ما سبب الفرقة في الأمة؟

٦- <q>﴿وَمَا ٱخْتَلَفَ ٱلَّذِينَ أُوتُوا۟ ٱلْكِتَٰبَ إِلَّا مِنۢ بَعْدِ مَا جَآءَهُمُ ٱلْعِلْمُ بَغْيًۢا بَيْنَهُمْ ۗ وَمَن يَكْفُرْ بِـَٔايَٰتِ ٱللَّهِ فَإِنَّ ٱللَّهَ سَرِيعُ ٱلْحِسَابِ﴾</q>

إخبار أنهم اختلفوا بعد معرفتهم بالحقائق من أجل البغي؛ وهو الحسد. [ابن جزي: ١/١٣٩]

السؤال: بينت الآية سبباً من أسباب الاختلاف, فما هو؟

٧- <q>﴿إِنَّ ٱلَّذِينَ يَكْفُرُونَ بِـَٔايَٰتِ ٱللَّهِ وَيَقْتُلُونَ ٱلنَّبِيِّۦنَ بِغَيْرِ حَقٍّ وَيَقْتُلُونَ ٱلَّذِينَ يَأْمُرُونَ بِٱلْقِسْطِ مِنَ ٱلنَّاسِ فَبَشِّرْهُم بِعَذَابٍ أَلِيمٍ﴾</q>

دلت هذه الآية على أن الأمر بالمعروف والنهي عن المنكر كان واجباً في الأمم المتقدمة. [القرطبي: ٥/٧٣]

السؤال: بين عظم شعيرة الأمر بالمعروف والنهي عن المنكر؟

التوجيهات

١- تواضع لله تعالى؛ فمهما بلغت في مقامات العبودية فأنت مقصر في حق الله تعالى، <q>﴿ٱلصَّٰبِرِينَ وَٱلصَّٰدِقِينَ وَٱلْقَٰنِتِينَ وَٱلْمُنفِقِينَ وَٱلْمُسْتَغْفِرِينَ بِٱلْأَسْحَارِ﴾</q>

٢- علم التوحيد أهم العلوم الشرعية؛ فاحرص على أن يكون لك اطلاعٌ كبيرٌ فيه، <q>﴿شَهِدَ ٱللَّهُ أَنَّهُۥ لَآ إِلَٰهَ إِلَّا هُوَ وَٱلْمَلَٰٓئِكَةُ وَأُو۟لُوا۟ ٱلْعِلْمِ قَآئِمًۢا بِٱلْقِسْطِ ۚ لَآ إِلَٰهَ إِلَّا هُوَ ٱلْعَزِيزُ ٱلْحَكِيمُ﴾</q>

٣- أهل الكتاب لم يؤتوا من قلة علم وضآلة معرفة، وإنما كان هلاكهم لأنهم وظفوا ما عندهم من علوم ومعارف للبغي بينهم بسبب الحسد، <q>﴿وَمَا ٱخْتَلَفَ ٱلَّذِينَ أُوتُوا۟ ٱلْكِتَٰبَ إِلَّا مِنۢ بَعْدِ مَا جَآءَهُمُ ٱلْعِلْمُ بَغْيًۢا بَيْنَهُمْ﴾</q>

العمل بالآيات

١- ابحث عن محبوب دنيوي تعلقت به نفسك وحاول أن تصبر عنه هذا اليوم تربية لنفسك، <q>﴿ٱلصَّٰبِرِينَ وَٱلصَّٰدِقِينَ وَٱلْقَٰنِتِينَ﴾</q>

٢- ادع الله بحاجة تريدها، وقدم قبل دعائك عملا صالحا؛ فهو أرجى لقبوله، <q>﴿ٱلَّذِينَ يَقُولُونَ رَبَّنَآ إِنَّنَآ ءَامَنَّا فَٱغْفِرْ لَنَا ذُنُوبَنَا وَقِنَا عَذَابَ ٱلنَّارِ﴾</q>

٣- صلِّ اليوم بالليل ولو ركعات قليلة، ثم استغفر الله تعالى، <q>﴿ٱلصَّٰبِرِينَ وَٱلصَّٰدِقِينَ وَٱلْقَٰنِتِينَ وَٱلْمُنفِقِينَ وَٱلْمُسْتَغْفِرِينَ بِٱلْأَسْحَارِ﴾</q>

معاني الكلمات

<q>﴿وَالْقَانِتِينَ﴾</q> الْمُطِيعِينَ للهِ.

<q>﴿بِالأَسْحَارِ﴾</q> بِآخِرِ اللَّيْلِ.

<q>﴿قَائِمًا بِالْقِسْطِ﴾</q> مُقِيمًا لِلْعَدْلِ فِي كُلِّ أَمْرٍ.

<q>﴿بَغْيًا﴾</q> حَسَدًا وَعُدْوَانًا.

<q>﴿حَبِطَتْ﴾</q> بَطَلَتْ.

