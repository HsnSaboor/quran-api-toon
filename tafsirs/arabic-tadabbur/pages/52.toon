quran[7]{c,v,t}:
  3,16,"<div class=ar lang=ar><h3>الوقفات التدبرية</h3><p>١- <span class="qpc-hafs">﴿ٱلصَّٰبِرِينَ وَٱلصَّٰدِقِينَ وَٱلْقَٰنِتِينَ وَٱلْمُنفِقِينَ وَٱلْمُسْتَغْفِرِينَ بِٱلْأَسْحَارِ﴾</span></p><p>تخصيص الأسحار بالاستغفار لأن الدعاء فيها أقرب إلى الإجابة، إذ العبادة حينئذ أشق، والنفس أصفى، والروع أجمع. [الألوسي:٣/١٠٢]</p><p>السؤال: لماذا خصص الأسحار بالاستغفار؟</p><p>٢- <span class="qpc-hafs">﴿ٱلصَّٰبِرِينَ وَٱلصَّٰدِقِينَ وَٱلْقَٰنِتِينَ وَٱلْمُنفِقِينَ وَٱلْمُسْتَغْفِرِينَ بِٱلْأَسْحَارِ﴾</span></p><p>كانوا يحيون الليل صلاة، ثم يقعدون في السحر يستغفرون؛ فيختمون قيام الليل بالاستغفار. [ابن تيمية:٢/٣٩]</p><p>السؤال: بِمَ تختم أكثر العبادات؟</p><p>٣- <span class="qpc-hafs">﴿شَهِدَ ٱللَّهُ أَنَّهُۥ لَآ إِلَٰهَ إِلَّا هُوَ وَٱلْمَلَٰٓئِكَةُ وَأُو۟لُوا۟ ٱلْعِلْمِ قَآئِمًۢا بِٱلْقِسْطِ ۚ لَآ إِلَٰهَ إِلَّا هُوَ ٱلْعَزِيزُ ٱلْحَكِيمُ﴾</span></p><p>وفي هذا دليل على أن أشرف الأمور علم التوحيد؛ لأن الله شهد به بنفسه، وأشهد عليه خواص خلقه، والشهادة لا تكون إلا عن علم ويقين، بمنزلة المشاهدة للبصر. [السعدي: ١٢٥]</p><p>السؤال: ما منْزلة علم التوحيد؟ وكيف تستدل على ما تقول بهذه الآية؟</p><p>٤- <span class="qpc-hafs">﴿شَهِدَ ٱللَّهُ أَنَّهُۥ لَآ إِلَٰهَ إِلَّا هُوَ وَٱلْمَلَٰٓئِكَةُ وَأُو۟لُوا۟ ٱلْعِلْمِ قَآئِمًۢا بِٱلْقِسْطِ ۚ لَآ إِلَٰهَ إِلَّا هُوَ ٱلْعَزِيزُ ٱلْحَكِيمُ﴾</span></p><p>في هذه الآية دليل على شرف العلم من وجوه كثيرة: منها: أن الله قرن شهادة العلماء بشهادته وشهادة ملائكته، وكفى بذلك فضلاً ... ومنها: أنه تعالى جعلهم شهداء وحجة على الناس، وألزم الناس العمل بالأمر المشهود به؛ فيكونون هم السبب في ذلك، فيكون كل من عمل بذلك نالهم من أجره، وذلك فضل الله يؤتيه من يشاء، ومنها: أن إشهاده تعالى أهل العلم يتضمن ذلك تزكيتهم وتعديلهم، وأنهم أمناء على ما استرعاهم عليه. [السعدي: ١٢٥]</p><p>السؤال: دلت الآية على شرف العلم والعلماء من عدة وجوه، بَيِّنها.</p><p>٥- <span class="qpc-hafs">﴿إِنَّ ٱلدِّينَ عِندَ ٱللَّهِ ٱلْإِسْلَٰمُ ۗ وَمَا ٱخْتَلَفَ ٱلَّذِينَ أُوتُوا۟ ٱلْكِتَٰبَ إِلَّا مِنۢ بَعْدِ مَا جَآءَهُمُ ٱلْعِلْمُ بَغْيًۢا بَيْنَهُمْ ۗ وَمَن يَكْفُرْ بِـَٔايَٰتِ ٱللَّهِ فَإِنَّ ٱللَّهَ سَرِيعُ ٱلْحِسَابِ﴾</span></p><p>سبب الاجتماع والألفة: جمع الدين والعمل به كله؛ وهو عبادة الله وحده لا شريك له كما أمر به باطنا وظاهرا. وسبب الفرقة: ترك حظ مما أمر العبد به، والبغي بينهم. ونتيجة الجماعة: رحمة الله، ورضوانه، وصلواته، وسعادة الدنيا والآخرة، وبياض الوجوه. ونتيجة الفرقة: عذاب الله، ولعنته، وسواد الوجوه، وبراءة الرسول ﷺ منهم. [ابن تيمية:٢/٥٥]</p><p>السؤال: ما سبب الاجتماع؟ و ما سبب الفرقة في الأمة؟</p><p>٦- <span class="qpc-hafs">﴿وَمَا ٱخْتَلَفَ ٱلَّذِينَ أُوتُوا۟ ٱلْكِتَٰبَ إِلَّا مِنۢ بَعْدِ مَا جَآءَهُمُ ٱلْعِلْمُ بَغْيًۢا بَيْنَهُمْ ۗ وَمَن يَكْفُرْ بِـَٔايَٰتِ ٱللَّهِ فَإِنَّ ٱللَّهَ سَرِيعُ ٱلْحِسَابِ﴾</span></p><p>إخبار أنهم اختلفوا بعد معرفتهم بالحقائق من أجل البغي؛ وهو الحسد. [ابن جزي: ١/١٣٩]</p><p>السؤال: بينت الآية سبباً من أسباب الاختلاف, فما هو؟</p><p>٧- <span class="qpc-hafs">﴿إِنَّ ٱلَّذِينَ يَكْفُرُونَ بِـَٔايَٰتِ ٱللَّهِ وَيَقْتُلُونَ ٱلنَّبِيِّۦنَ بِغَيْرِ حَقٍّ وَيَقْتُلُونَ ٱلَّذِينَ يَأْمُرُونَ بِٱلْقِسْطِ مِنَ ٱلنَّاسِ فَبَشِّرْهُم بِعَذَابٍ أَلِيمٍ﴾</span></p><p>دلت هذه الآية على أن الأمر بالمعروف والنهي عن المنكر كان واجباً في الأمم المتقدمة. [القرطبي: ٥/٧٣]</p><p>السؤال: بين عظم شعيرة الأمر بالمعروف والنهي عن المنكر؟</p><h3>التوجيهات</h3><p>١- تواضع لله تعالى؛ فمهما بلغت في مقامات العبودية فأنت مقصر في حق الله تعالى، <span class="qpc-hafs">﴿ٱلصَّٰبِرِينَ وَٱلصَّٰدِقِينَ وَٱلْقَٰنِتِينَ وَٱلْمُنفِقِينَ وَٱلْمُسْتَغْفِرِينَ بِٱلْأَسْحَارِ﴾</span></p><p>٢- علم التوحيد أهم العلوم الشرعية؛ فاحرص على أن يكون لك اطلاعٌ كبيرٌ فيه، <span class="qpc-hafs">﴿شَهِدَ ٱللَّهُ أَنَّهُۥ لَآ إِلَٰهَ إِلَّا هُوَ وَٱلْمَلَٰٓئِكَةُ وَأُو۟لُوا۟ ٱلْعِلْمِ قَآئِمًۢا بِٱلْقِسْطِ ۚ لَآ إِلَٰهَ إِلَّا هُوَ ٱلْعَزِيزُ ٱلْحَكِيمُ﴾</span></p><p>٣- أهل الكتاب لم يؤتوا من قلة علم وضآلة معرفة، وإنما كان هلاكهم لأنهم وظفوا ما عندهم من علوم ومعارف للبغي بينهم بسبب الحسد، <span class="qpc-hafs">﴿وَمَا ٱخْتَلَفَ ٱلَّذِينَ أُوتُوا۟ ٱلْكِتَٰبَ إِلَّا مِنۢ بَعْدِ مَا جَآءَهُمُ ٱلْعِلْمُ بَغْيًۢا بَيْنَهُمْ﴾</span></p><h3>العمل بالآيات</h3><p>١- ابحث عن محبوب دنيوي تعلقت به نفسك وحاول أن تصبر عنه هذا اليوم تربية لنفسك، <span class="qpc-hafs">﴿ٱلصَّٰبِرِينَ وَٱلصَّٰدِقِينَ وَٱلْقَٰنِتِينَ﴾</span></p><p>٢- ادع الله بحاجة تريدها، وقدم قبل دعائك عملا صالحا؛ فهو أرجى لقبوله، <span class="qpc-hafs">﴿ٱلَّذِينَ يَقُولُونَ رَبَّنَآ إِنَّنَآ ءَامَنَّا فَٱغْفِرْ لَنَا ذُنُوبَنَا وَقِنَا عَذَابَ ٱلنَّارِ﴾</span></p><p>٣- صلِّ اليوم بالليل ولو ركعات قليلة، ثم استغفر الله تعالى، <span class="qpc-hafs">﴿ٱلصَّٰبِرِينَ وَٱلصَّٰدِقِينَ وَٱلْقَٰنِتِينَ وَٱلْمُنفِقِينَ وَٱلْمُسْتَغْفِرِينَ بِٱلْأَسْحَارِ﴾</span></p><h3>معاني الكلمات</h3><p><span class="qpc-hafs">﴿وَالْقَانِتِينَ﴾</span> الْمُطِيعِينَ للهِ.</p><p><span class="qpc-hafs">﴿بِالأَسْحَارِ﴾</span> بِآخِرِ اللَّيْلِ.</p><p><span class="qpc-hafs">﴿قَائِمًا بِالْقِسْطِ﴾</span> مُقِيمًا لِلْعَدْلِ فِي كُلِّ أَمْرٍ.</p><p><span class="qpc-hafs">﴿بَغْيًا﴾</span> حَسَدًا وَعُدْوَانًا.</p><p><span class="qpc-hafs">﴿حَبِطَتْ﴾</span> بَطَلَتْ.</p></div>"
