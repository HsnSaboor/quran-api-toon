quran[8]{c,v,t}:
  12,15,"

الوقفات التدبرية

١- <q>﴿وَجَآءُوٓ أَبَاهُمْ عِشَآءً يَبْكُونَ﴾</q>

وفطنة الحاكم لا تنخدع لمثل هذه الحيل، ولا تنوط بها حكماً، وإنما يناط الحكم بالبينة. [ابن عاشور:١٢/٢٣٦]

السؤال: ينبغي للحاكم ألا ينخدع بالدموع وحدها، بل يطالب بالبينة، دلل لذلك.

٢- <q>﴿وَجَآءُوٓ أَبَاهُمْ عِشَآءً يَبْكُونَ﴾</q>

أي: زينت لكم أنفسكم أمراً قبيحاً من التفريق بيني وبينه؛ لأنه رأى من القرائن والأحوال، ومن رؤيا يوسف التي قصها عليه ما دَلَّه على ما قال. [السعدي:٣٩٥]

السؤال: ما القرينة التي دلت على كذب إخوة يوسف؟

٣- <q>﴿فَصَبْرٌ جَمِيلٌ﴾</q>

قال الثوري عن بعض أصحابه أنه قال: ثلاث من الصبر: أن لا تحدث بوجعك، ولا بمصيبتك، ولا تزكي نفسك. [ابن كثير:٢/٤٥٣]

السؤال: بين بعض أنواع الصبر الجميل ؟

٤- <q>﴿فَصَبْرٌ جَمِيلٌ ۖ وَٱللَّهُ ٱلْمُسْتَعَانُ عَلَىٰ مَا تَصِفُونَ﴾</q>

و «الصبر الجميل» صبر بلا شكوى؛ قال يعقوب عليه الصلاة والسلام: <q>﴿إنما أشكو بثي وحزني إلى الله﴾</q> [يوسف: ٨٦] مع قوله: <q>﴿فصبر جميل والله المستعان على ما تصفون﴾</q>، فالشكوى إلى الله لا تنافي الصبر الجميل. [ابن تيمية:٤/٢٢]

السؤال: ما الصبر الجميل؟ وهل تنافيه الشكوى لله تعالى؟

٥- <q>﴿وَجَآءَتْ سَيَّارَةٌ فَأَرْسَلُوا۟ وَارِدَهُمْ فَأَدْلَىٰ دَلْوَهُۥ ۖ قَالَ يَٰبُشْرَىٰ هَٰذَا غُلَٰمٌ ۚ وَأَسَرُّوهُ بِضَٰعَةً ۚ وَٱللَّهُ عَلِيمٌۢ بِمَا يَعْمَلُونَ﴾</q>

<q>﴿والله عليم بما يعملون﴾</q> أي: عليم بما يفعله إخوة يوسف، ومشتروه، وهو قادر على تغيير ذلك ودفعه، ولكن له حكمة وقدر سابق، فترك ذلك ليمضي ما قدره وقضاه ... وفي هذا تعريض لرسوله محمد- صلى الله عليه وسلم- وإعلام له بأني عالم بأذى قومك لك، وأنا قادر على الإنكار عليهم، ولكني سأملي لهم، ثم أجعل لك العاقبة والحكم عليهم؛ كما جعلت ليوسف الحكم والعاقبة على إخوته. [ابن كثير:٢/٤٥٤]

السؤال: ما وجه ختم الآية بقوله: <q>﴿والله عليم بما يعملون﴾</q>؟

٦- <q>﴿وَلَمَّا بَلَغَ أَشُدَّهُۥٓ ءَاتَيْنَٰهُ حُكْمًا وَعِلْمًا ۚ وَكَذَٰلِكَ نَجْزِى ٱلْمُحْسِنِينَ﴾</q>

وأما النور والعلم والحكمة؛ فقد دل عليه قوله تعالى في قصة يوسف: <q>﴿ولما بلغ أشده آتيناه حكماً وعلماً وكذلك نجزي المحسنين﴾</q>؛ فهي لكل محسن. [ابن تيمية:٤/٢٢]

السؤال: كل محسن له نصيب من النور، والعلم، والحكمة، بين ذلك من الآية؟

٧- <q>﴿وَلَمَّا بَلَغَ أَشُدَّهُۥٓ ءَاتَيْنَٰهُ حُكْمًا وَعِلْمًا ۚ وَكَذَٰلِكَ نَجْزِى ٱلْمُحْسِنِينَ﴾</q>

وفي ذكر المحسنين إيماء إلى أنّ إحسانه هو سبب جزائه بتلك النعمة. [ابن عاشور:١٢/٢٤٨. ]

السؤال: اذكر فائدة من فوائد صفة الإحسان.

التوجيهات

١- احذر الكذب في أحوالك كلها، <q>﴿قَالُوا۟ يَٰٓأَبَانَآ إِنَّا ذَهَبْنَا نَسْتَبِقُ وَتَرَكْنَا يُوسُفَ عِندَ مَتَٰعِنَا فَأَكَلَهُ ٱلذِّئْبُ﴾</q>

٢- قوة الإيمان بالقدر تكسب الصبر عند المصائب، <q>﴿قَالَ بَلْ سَوَّلَتْ لَكُمْ أَنفُسُكُمْ أَمْرًا ۖ فَصَبْرٌ جَمِيلٌ ۖ وَٱللَّهُ ٱلْمُسْتَعَانُ عَلَىٰ مَا تَصِفُونَ﴾</q>

٣- الإحسان في العبادة من أسباب حفظ الله ونصره وتمكينه، <q>﴿وَلَمَّا بَلَغَ أَشُدَّهُۥٓ ءَاتَيْنَٰهُ حُكْمًا وَعِلْمًا ۚ وَكَذَٰلِكَ نَجْزِى ٱلْمُحْسِنِينَ﴾</q>

العمل بالآيات

١- استعذ بالله من الكذب, <q>﴿قَالُوا۟ يَٰٓأَبَانَآ إِنَّا ذَهَبْنَا نَسْتَبِقُ وَتَرَكْنَا يُوسُفَ عِندَ مَتَٰعِنَا فَأَكَلَهُ ٱلذِّئْبُ﴾</q>

٢- حدد أمراً أهمك، واصبر عليه صبراً جميلاً، ولا تتبعه بشكوى، ولا عتاب، ولا أذية، لعل الله ييسره لك، <q>﴿فَصَبْرٌ جَمِيلٌ ۖ وَٱللَّهُ ٱلْمُسْتَعَانُ عَلَىٰ مَا تَصِفُونَ﴾</q>

٣- أكثر اليوم من دعاء: <q>﴿رب زدني علما﴾</q>، <q>﴿ۚ وَكَذَٰلِكَ مَكَّنَّا لِيُوسُفَ فِى ٱلْأَرْضِ وَلِنُعَلِّمَهُۥ مِن تَأْوِيلِ ٱلْأَحَادِيثِ﴾</q>

معاني الكلمات

<q>﴿وَأَجْمَعُوا﴾</q> عَزَمُوا وَصَمَّمُوا.

<q>﴿نَسْتَبِقُ﴾</q> نَتَسَابَقُ فِي الجَرْيِ، وَالرَّمْيِ بِالسِّهَامِ.

<q>﴿بِمُؤْمِنٍ لَنَا﴾</q> بِمُقِرٍّ لَنَا، وَمُصَدِّقٍ لَنَا.

<q>﴿سَوَّلَتْ﴾</q> زيَّنَتْ.

<q>﴿فَصَبْرٌ جَمِيلٌ﴾</q> احْتِمَالٌ لِلمُصِيبَةِ لاَ شَكْوَى مَعَهُ لأِحَدٍ مِنَ الخَلْقِ.

<q>﴿سَيَّارَةٌ﴾</q> جَمَاعَةٌ مِنَ المُسَافِرِينَ.

<q>﴿وَارِدَهُمْ﴾</q> مَنْ يَتَقَدَّمُهُمْ لِطَلَبِ المَاءِ.

<q>﴿فَأَدْلَى دَلْوَهُ﴾</q> فَأَرْسَلَ دَلْوَهُ فِي البِئْرِ؛ لِيَمْلَأَهَا بِالمَاءِ.

<q>﴿وَأَسَرُّوهُ بِضَاعَةً﴾</q> كَتَمَ إِخْوَةُ يُوسُفَ كَوْنَهُ أَخَاهُمْ لِيَبِيعُوهُ.

<q>﴿وَشَرَوْهُ﴾</q> بَاعَهُ إِخْوَتُهُ.

<q>﴿بَخْسٍ﴾</q> قَلِيلٍ.

<q>﴿مَثْوَاهُ﴾</q> مَقَامَهُ.

<q>﴿أَشُدَّهُ﴾</q> مُنْتَهَى قُوَّتِهِ فِي شَبَابِهِ.

