quran[8]{c,v,t}:
  12,15,"<div class=ar lang=ar><h3>الوقفات التدبرية</h3><p>١- <span class="qpc-hafs">﴿وَجَآءُوٓ أَبَاهُمْ عِشَآءً يَبْكُونَ﴾</span></p><p>وفطنة الحاكم لا تنخدع لمثل هذه الحيل، ولا تنوط بها حكماً، وإنما يناط الحكم بالبينة. [ابن عاشور:١٢/٢٣٦]</p><p>السؤال: ينبغي للحاكم ألا ينخدع بالدموع وحدها، بل يطالب بالبينة، دلل لذلك.</p><p>٢- <span class="qpc-hafs">﴿وَجَآءُوٓ أَبَاهُمْ عِشَآءً يَبْكُونَ﴾</span></p><p>أي: زينت لكم أنفسكم أمراً قبيحاً من التفريق بيني وبينه؛ لأنه رأى من القرائن والأحوال، ومن رؤيا يوسف التي قصها عليه ما دَلَّه على ما قال. [السعدي:٣٩٥]</p><p>السؤال: ما القرينة التي دلت على كذب إخوة يوسف؟</p><p>٣- <span class="qpc-hafs">﴿فَصَبْرٌ جَمِيلٌ﴾</span></p><p>قال الثوري عن بعض أصحابه أنه قال: ثلاث من الصبر: أن لا تحدث بوجعك، ولا بمصيبتك، ولا تزكي نفسك. [ابن كثير:٢/٤٥٣]</p><p>السؤال: بين بعض أنواع الصبر الجميل ؟</p><p>٤- <span class="qpc-hafs">﴿فَصَبْرٌ جَمِيلٌ ۖ وَٱللَّهُ ٱلْمُسْتَعَانُ عَلَىٰ مَا تَصِفُونَ﴾</span></p><p>و «الصبر الجميل» صبر بلا شكوى؛ قال يعقوب عليه الصلاة والسلام: <span class="qpc-hafs">﴿إنما أشكو بثي وحزني إلى الله﴾</span> [يوسف: ٨٦] مع قوله: <span class="qpc-hafs">﴿فصبر جميل والله المستعان على ما تصفون﴾</span>، فالشكوى إلى الله لا تنافي الصبر الجميل. [ابن تيمية:٤/٢٢]</p><p>السؤال: ما الصبر الجميل؟ وهل تنافيه الشكوى لله تعالى؟</p><p>٥- <span class="qpc-hafs">﴿وَجَآءَتْ سَيَّارَةٌ فَأَرْسَلُوا۟ وَارِدَهُمْ فَأَدْلَىٰ دَلْوَهُۥ ۖ قَالَ يَٰبُشْرَىٰ هَٰذَا غُلَٰمٌ ۚ وَأَسَرُّوهُ بِضَٰعَةً ۚ وَٱللَّهُ عَلِيمٌۢ بِمَا يَعْمَلُونَ﴾</span></p><p><span class="qpc-hafs">﴿والله عليم بما يعملون﴾</span> أي: عليم بما يفعله إخوة يوسف، ومشتروه، وهو قادر على تغيير ذلك ودفعه، ولكن له حكمة وقدر سابق، فترك ذلك ليمضي ما قدره وقضاه ... وفي هذا تعريض لرسوله محمد- صلى الله عليه وسلم- وإعلام له بأني عالم بأذى قومك لك، وأنا قادر على الإنكار عليهم، ولكني سأملي لهم، ثم أجعل لك العاقبة والحكم عليهم؛ كما جعلت ليوسف الحكم والعاقبة على إخوته. [ابن كثير:٢/٤٥٤]</p><p>السؤال: ما وجه ختم الآية بقوله: <span class="qpc-hafs">﴿والله عليم بما يعملون﴾</span>؟</p><p>٦- <span class="qpc-hafs">﴿وَلَمَّا بَلَغَ أَشُدَّهُۥٓ ءَاتَيْنَٰهُ حُكْمًا وَعِلْمًا ۚ وَكَذَٰلِكَ نَجْزِى ٱلْمُحْسِنِينَ﴾</span></p><p>وأما النور والعلم والحكمة؛ فقد دل عليه قوله تعالى في قصة يوسف: <span class="qpc-hafs">﴿ولما بلغ أشده آتيناه حكماً وعلماً وكذلك نجزي المحسنين﴾</span>؛ فهي لكل محسن. [ابن تيمية:٤/٢٢]</p><p>السؤال: كل محسن له نصيب من النور، والعلم، والحكمة، بين ذلك من الآية؟</p><p>٧- <span class="qpc-hafs">﴿وَلَمَّا بَلَغَ أَشُدَّهُۥٓ ءَاتَيْنَٰهُ حُكْمًا وَعِلْمًا ۚ وَكَذَٰلِكَ نَجْزِى ٱلْمُحْسِنِينَ﴾</span></p><p>وفي ذكر المحسنين إيماء إلى أنّ إحسانه هو سبب جزائه بتلك النعمة. [ابن عاشور:١٢/٢٤٨. ]</p><p>السؤال: اذكر فائدة من فوائد صفة الإحسان.</p><h3>التوجيهات</h3><p>١- احذر الكذب في أحوالك كلها، <span class="qpc-hafs">﴿قَالُوا۟ يَٰٓأَبَانَآ إِنَّا ذَهَبْنَا نَسْتَبِقُ وَتَرَكْنَا يُوسُفَ عِندَ مَتَٰعِنَا فَأَكَلَهُ ٱلذِّئْبُ﴾</span></p><p>٢- قوة الإيمان بالقدر تكسب الصبر عند المصائب، <span class="qpc-hafs">﴿قَالَ بَلْ سَوَّلَتْ لَكُمْ أَنفُسُكُمْ أَمْرًا ۖ فَصَبْرٌ جَمِيلٌ ۖ وَٱللَّهُ ٱلْمُسْتَعَانُ عَلَىٰ مَا تَصِفُونَ﴾</span></p><p>٣- الإحسان في العبادة من أسباب حفظ الله ونصره وتمكينه، <span class="qpc-hafs">﴿وَلَمَّا بَلَغَ أَشُدَّهُۥٓ ءَاتَيْنَٰهُ حُكْمًا وَعِلْمًا ۚ وَكَذَٰلِكَ نَجْزِى ٱلْمُحْسِنِينَ﴾</span></p><h3>العمل بالآيات</h3><p>١- استعذ بالله من الكذب, <span class="qpc-hafs">﴿قَالُوا۟ يَٰٓأَبَانَآ إِنَّا ذَهَبْنَا نَسْتَبِقُ وَتَرَكْنَا يُوسُفَ عِندَ مَتَٰعِنَا فَأَكَلَهُ ٱلذِّئْبُ﴾</span></p><p>٢- حدد أمراً أهمك، واصبر عليه صبراً جميلاً، ولا تتبعه بشكوى، ولا عتاب، ولا أذية، لعل الله ييسره لك، <span class="qpc-hafs">﴿فَصَبْرٌ جَمِيلٌ ۖ وَٱللَّهُ ٱلْمُسْتَعَانُ عَلَىٰ مَا تَصِفُونَ﴾</span></p><p>٣- أكثر اليوم من دعاء: <span class="qpc-hafs">﴿رب زدني علما﴾</span>، <span class="qpc-hafs">﴿ۚ وَكَذَٰلِكَ مَكَّنَّا لِيُوسُفَ فِى ٱلْأَرْضِ وَلِنُعَلِّمَهُۥ مِن تَأْوِيلِ ٱلْأَحَادِيثِ﴾</span></p><h3>معاني الكلمات</h3><p><span class="qpc-hafs">﴿وَأَجْمَعُوا﴾</span> عَزَمُوا وَصَمَّمُوا.</p><p><span class="qpc-hafs">﴿نَسْتَبِقُ﴾</span> نَتَسَابَقُ فِي الجَرْيِ، وَالرَّمْيِ بِالسِّهَامِ.</p><p><span class="qpc-hafs">﴿بِمُؤْمِنٍ لَنَا﴾</span> بِمُقِرٍّ لَنَا، وَمُصَدِّقٍ لَنَا.</p><p><span class="qpc-hafs">﴿سَوَّلَتْ﴾</span> زيَّنَتْ.</p><p><span class="qpc-hafs">﴿فَصَبْرٌ جَمِيلٌ﴾</span> احْتِمَالٌ لِلمُصِيبَةِ لاَ شَكْوَى مَعَهُ لأِحَدٍ مِنَ الخَلْقِ.</p><p><span class="qpc-hafs">﴿سَيَّارَةٌ﴾</span> جَمَاعَةٌ مِنَ المُسَافِرِينَ.</p><p><span class="qpc-hafs">﴿وَارِدَهُمْ﴾</span> مَنْ يَتَقَدَّمُهُمْ لِطَلَبِ المَاءِ.</p><p><span class="qpc-hafs">﴿فَأَدْلَى دَلْوَهُ﴾</span> فَأَرْسَلَ دَلْوَهُ فِي البِئْرِ؛ لِيَمْلَأَهَا بِالمَاءِ.</p><p><span class="qpc-hafs">﴿وَأَسَرُّوهُ بِضَاعَةً﴾</span> كَتَمَ إِخْوَةُ يُوسُفَ كَوْنَهُ أَخَاهُمْ لِيَبِيعُوهُ.</p><p><span class="qpc-hafs">﴿وَشَرَوْهُ﴾</span> بَاعَهُ إِخْوَتُهُ.</p><p><span class="qpc-hafs">﴿بَخْسٍ﴾</span> قَلِيلٍ.</p><p><span class="qpc-hafs">﴿مَثْوَاهُ﴾</span> مَقَامَهُ.</p><p><span class="qpc-hafs">﴿أَشُدَّهُ﴾</span> مُنْتَهَى قُوَّتِهِ فِي شَبَابِهِ.</p></div>"
  12,16,"12:15"
