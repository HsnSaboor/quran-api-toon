tafsir[151]{c,v,t}:
  4,1,"﴿مِّن نَّفۡسࣲ وَ ٰ⁠حِدَةࣲ﴾: هي آدَمُ.﴿زَوۡجَهَا﴾: هي حَوّاءُ، خُلِقَتْ من ضِلْعٍ من أضلاعِ آدمَ.﴿وَبَثَّ مِنۡهُمَا﴾: نَشَر من آدمَ وحَواءَ.﴿تَسَآءَلُونَ بِهِۦ﴾: يَسْألُ به بعضُكم بعضًا، فيقولُ السائلُ: أسألُك باللهِ.﴿وَٱلۡأَرۡحَامَ﴾: واتقوا الأرحامَ أن تقطعُوها."
  4,2,"﴿وَءَاتُواْ﴾: وأَعطُوا يا أوصياءَ اليتامى.﴿ٱلۡيَتَـٰمَىٰٓ﴾: هم مَن ماتَ آباؤهم وهم دونَ البلوغ. وإعطاؤُهم المالَ إذا وصَلُوا سِنَّ البُلوغِ، وأصبح لديهم قُدْرَةٌ على حِفْظِ المالِ.﴿وَلَا تَتَبَدَّلُواْ ٱلۡخَبِيثَ بِٱلطَّيِّبِ﴾: ولا تأخُذوا الجيِّدَ من أموالهِم، وتجعلُوا مكانَه الرديءَ من أموالِكم.﴿وَلَا تَأۡكُلُوٓاْ أَمۡوَ ٰ⁠لَهُمۡ إِلَىٰٓ أَمۡوَ ٰ⁠لِكُمۡ﴾: ولا تَخْلِطُوا أموالَهم بأموالِكم، فتأكلُوها مع أموالِكم.﴿حُوبࣰا﴾: إثْمًا وظُلمًا."
  4,3,"﴿تُقۡسِطُواْ﴾: تَعْدِلُوا.﴿فِي ٱلۡيَتَـٰمَىٰ﴾: في يَتامى النساءِ اللاتي تحتَ أيديكم بألّا تُعْطُوهنَّ مهورَهنَّ كغيرِهنَّ، فلا تَنْكِحُوهن، وانكِحُوا غيرَهن.﴿طَابَ﴾: حَلَّ.﴿أَدۡنَىٰٓ أَلَّا تَعُولُواْ﴾: أقربُ إلى ألّا تَجُوروا، ولا تَميلوا."
  4,4,"﴿صَدُقَـٰتِهِنَّ﴾: مُهورِهنَّ.﴿نِحۡلَةࣰ﴾: عَطِيةً واجبةً.﴿شَيۡءࣲ مِّنۡهُ﴾: شيءٍ من المَهْرِ، فوَهَبْنَه لكم."
  4,5,"﴿ٱلسُّفَهَآءَ﴾: المضَيِّعين لما لِهم بسوءِ تَدْبيرِهم.﴿قِيَـٰمࣰا﴾: قِوامَكم في مَعايِشكم."
  4,6,"﴿وَٱبۡتَلُواْ﴾: واختبِرُوهم لمعرفةِ قُدُراتِهم.﴿بَلَغُواْ ٱلنِّكَاحَ﴾: وصَلُوا إلى سِنِّ البلوغِ.﴿ءَانَسۡتُم مِّنۡهُمۡ رُشۡدࣰا﴾: عَلِمْتُمْ منهم صَلاحًا في العقلِ والدِّين.﴿إِسۡرَافࣰا﴾: بغيرِ ما أباحَه اللهُ لكم.﴿وَبِدَارًا﴾: ومُبادرةً لأَكْلِها.﴿أَن يَكۡبَرُواْ﴾: قبل أن يكبَرُوا فيأ خُذُوها منكم.﴿بِٱلۡمَعۡرُوفِ﴾: بقَدْرِ حاجتِه عند الضرورةِ على وجْه القَرْضِ.﴿فَأَشۡهِدُواْ﴾: بأَنْ يَشْهَدَ شهودٌ معكم.﴿حَسِيبࣰا﴾: محاسِبًا."
  4,7,"﴿لِّلرِّجَالِ﴾: للذُّكورِ من أولادِ الميتِ صغارًا وكبارًا."
  4,8,"﴿أُوْلُواْ ٱلۡقُرۡبَىٰ﴾: ممَّن لا حَقَّ لهم في التَّرِكَةِ.﴿فَٱرۡزُقُوهُم مِّنۡهُ﴾: على وجهِ الاستحبابِ."
  4,9,"﴿فَلۡيَتَّقُواْ ٱللَّهَ﴾: في ذلك النهيُ عن الإجحافِ بالورثةِ الضعفاءِ، فلايزيدُ في وصيَّتِه لغيرِهمِ على الثلث، وكذلك إنْ تَرَكهم أغنياءَ حَسُنَ أن يُوصيَ لغيرِهم."
  4,10,"﴿سَعِيرࣰا﴾: نارًا مُوقدةً."
  4,11,"﴿لِلذَّكَرِ مِثۡلُ حَظِّ ٱلۡأُنثَيَيۡنِ﴾: إذا لم يكن هناك وارثٌ غيرُ أولادِه.﴿فَلِأُمِّهِ ٱلثُّلُثُ﴾: ولأبيه الباقي.﴿مِنۢ بَعۡدِ وَصِيَّةࣲ﴾: هذه القِسْمَةُ للتَّرِكَةِ بعد إخراجِ وصيةِ الميتِ بما لايتجاوزُ الثلثَ."
  4,12,"﴿لَّهُنَّ وَلَدࣱ﴾: ذكرًا أو أنثى.﴿مِنۢ بَعۡدِ وَصِيَّةࣲ﴾: من بعدِ إنفاذِ وصِيَّتِهنّ الجائزةِ.﴿لَّكُمۡ وَلَدࣱ﴾: ذَكَرًا أو أنثى، منهن، أو من غيرِهنّ.﴿كَلَـٰلَةً﴾: هو الميتُ الذي لا ولَدَ له ولا والدَ﴿أَخٌ أَوۡ أُخۡتࣱ﴾: من أُمّ.﴿غَيۡرَ مُضَآرࣲّ﴾: لا ضَرَرَ فيه على الوَرَثَةِ، فإنْ قَصَدَ صاحبُها الضَّرَرَ لوَرَثَتِه فهو باطلٌ لا يَنْفُذُ."
  4,14,"﴿مُّهِينࣱ﴾: مُخْزٍ."
  4,15,"﴿ٱلۡفَـٰحِشَةَ﴾: الزِّنى.﴿فَأَمۡسِكُوهُنَّ﴾: فاحبِسُوهُنَّ، وكان هذا قبل نَسْخِها.﴿سَبِيلࣰا﴾: مَخْرَجًا، والسبيلُ هو: الحُكْمُ بالرَّجْمِ للمُحْصَنِ والمحصَنةِ، والجلْدِ مئةَ جَلْدَةٍ، وتَغْريبِ عامٍ لغيرهما."
  4,16,"﴿يَأۡتِيَـٰنِهَا﴾: أي: فاحشةَ الزِّنى.﴿فَـَٔاذُوهُمَا﴾: بالضَّرْبِ، والهَجْرِ والتوبيخِ، ثم نُسِخَ بالجلْدِ والرَّجْمِ."
  4,17,"﴿عَلَى ٱللَّهِ﴾: فهو الذي يقبَلُها.﴿بِجَهَـٰلَةࣲ﴾: بجَهْلٍ منهم لعاقِبَتِها، وإيجابِها لسَخَطِ اللهِ."
  4,19,"﴿كَرۡهࣰا﴾: هُنَّ كارهاتٌ لذلك، وكانوا في الجاهليَّةِ يجعلون نِساءَ الآباءِ والأقاربِ من التَّرِكَةِ، فيتزوَّجُون بهنَّ.﴿وَلَا تَعۡضُلُوهُنَّ﴾: لا يَحِلُّ لكم أن تَحْبِسُوا زوجاتِكم عندَكم مع عَدَمِ رغبتِكم فيهن، وذلك لقَصْدِ أن يفتَدِينَ ببعضِ المهْرِ من الحبْسِ.﴿بِفَـٰحِشَةࣲ مُّبَيِّنَةࣲ﴾: بالزِّنى البيِّنِ، أو بذاءةِ اللسانِ، أو النُّشوزِ."
  4,20,"﴿إِحۡدَىٰهُنَّ﴾: هي مَن تُريدون طَلاقَها.﴿قِنطَارࣰا﴾: مالًا كثيرًا مَهْرًا لها.﴿بُهۡتَـٰنࣰا﴾: ظُلمًا بغيرِ حَقّ."
  4,21,"﴿أَفۡضَىٰ﴾: بالجِماعِ.﴿مِّيثَـٰقًا غَلِيظࣰا﴾: إمساكَهُنَّ بمعروفٍ، أو تَسْرِيحَهُنَّ بإحسانٍ."
  4,22,"﴿سَلَفَ﴾: مضى في الجاهلية، فلا مُؤاخَذَةَ فيه.﴿وَمَقۡتࣰا﴾: وبُغْضًا، أي: يُبْغِضُ اللهُ فاعلَه."
  4,23,"﴿أُمَّهَـٰتُكُمۡ﴾: ويَدْخُلُ فيه الجَدّاتُ.﴿وَبَنَاتُكُمۡ﴾: ويشْمَلُ بناتِ الأولادِ.﴿وَأَخَوَ ٰ⁠تُكُمۡ﴾: الشقيقاتُ، أو لأبٍ، أو لأمّ.﴿وَأُمَّهَـٰتُ نِسَآئِكُمۡ﴾: سواءٌ أدخَلْتُمْ بنسائكم أم لا.﴿وَرَبَـٰٓئِبُكُمُ﴾: وبناتُ نسائِكم من غيرِكم، اللاتي يتربَّينَ في بيوتِكم، فإن لم يكونوا كذلك، ولم تَدْخُلوا بأمَّهاتِهن وطَلَّقْتموهن، أو مِتْنَ قبلَ الدُّخولِ، فلا جُناحَ عليكم أن تنكِحُوهنّ.﴿وَحَلَـٰٓئِلُ أَبۡنَآئِكُمُ﴾: زوجاتُ أبنائِكم ممَّن دَخَلَ الابنُ بها، أو لَم يدْخُلْ."
  4,24,"﴿وَٱلۡمُحۡصَنَـٰتُ﴾: يَحْرُمُ نِكاحُ ذَواتِ الأزواج غيرِ المَسْبِيّات.﴿مَا مَلَكَتۡ أَيۡمَـٰنُكُمۡ﴾: مَن سَبَيْتم في الجهادِ، فيَحِلُّ النكاحُ بعد الاستِبْراءِ بحَيْضَةٍ، من غير طلاقِ زوجِها الحربيِّ لها.﴿مَّا وَرَآءَ ذَ ٰ⁠لِكُمۡ﴾: مِن سِواهنّ.﴿مُّحۡصِنِينَ﴾: أعِفّاءَ.﴿غَيۡرَ مُسَـٰفِحِينَ﴾: غيرَ زانِين.﴿أُجُورَهُنَّ﴾: مُهورَهُنَّ وهذا في النِّكاحِ الشَّرْعيِّ.﴿مِنۢ بَعۡدِ ٱلۡفَرِيضَةِ﴾: من زيادةٍ أو نقصانٍ في المهْرِ، فذلك سائغٌ عند التَّراضي."
  4,25,"﴿طَوۡلًا﴾: قُدرةً وسَعَةً، وهو المَهْرُ لنِكاحِ الحَرائرِ.﴿بَعۡضُكُم مِّنۢ بَعۡضࣲ﴾: في النسَبِ والدِّينِ.﴿بِإِذۡنِ أَهۡلِهِنَّ﴾: بموافقةِ سَيّدِهن؛ لأنّ منافعَهنّ له.﴿أَخۡدَانࣲ﴾: ولا مُسِرّاتٍ بالزِّنى باتخاذِ أصدقاءَ.﴿فَعَلَيۡهِنَّ﴾: فعلى الإماءِ خمسون جَلْدَةً، ونَفْيُ ستةِ أشهرٍ، وليس على الإماءِ رَجْمٌ لأنه لايَتَنَصَّفُ.﴿ذَ ٰ⁠لِكَ﴾: أي: ما أُبيحَ لكم من نِكاحِ الإماءِ.﴿خَشِيَ ٱلۡعَنَتَ﴾: خوفَ الوقوعِ في الزِّنى والمشقَّةِ.﴿وَأَن تَصۡبِرُواْ﴾: عن نكاحِ الإماء مع العفَّةِ."
  4,26,"﴿سُنَنَ﴾: طُرُقَ الأنبياءِ وأتباعِهم لتَقْتَدُوا بها."
  4,27,"﴿يَتَّبِعُونَ ٱلشَّهَوَ ٰ⁠تِ﴾: يَنْقادُون لشهَواتِ أنفسِهم من أهلِ الباطلِ.﴿تَمِيلُواْ﴾: تَنْحَرفُوا عن الدِّينِ بإتيانِكم ما حَرَّمَ عليكم."
  4,28,"﴿أَن يُخَفِّفَ﴾: أن يُيَسِّرَ عليكم."
  4,29,"﴿بِٱلۡبَـٰطِلِ﴾: كالرِّبا والقِمار.﴿تِجَـٰرَةً﴾: موافِقَةً للشَّرعِ.﴿وَلَا تَقۡتُلُوٓاْ أَنفُسَكُمۡ﴾: بألّا تُهْلِكُوها بارتكابِ المعاصي، وألّا يقتلَ بعضُكم بعضًا، وألّا يقتلَ نفسَه حقيقةً."
  4,30,"﴿ذَ ٰ⁠لِكَ﴾: ما نهى اللهُ عنه مما تقدَّم.﴿عُدۡوَ ٰ⁠نࣰا﴾: متجاوِزًا حَدَّ الشَّرْعِ."
  4,31,"﴿كَبَآئِرَ مَا تُنۡهَوۡنَ عَنۡهُ﴾: هي كلُّ ذَنْبٍ رَتَّبَ اللهُ عليه الحَدَّ، أو صَرَّح بالوعيدِ فيه.﴿سَيِّـَٔاتِكُمۡ﴾: الصَّغائرَ.﴿مُّدۡخَلࣰا كَرِيمࣰا﴾: الجنةَ."
  4,32,"﴿مَا فَضَّلَ ٱللَّهُ بِهِۦ بَعۡضَكُمۡ عَلَىٰ بَعۡضࣲ﴾: ما فَضَّل اللهُ به غيرَكم عليكم في المواهِبِ والأرزاقِ.﴿نَصِيبࣱ﴾: مقدارٌ من الجزاءِ بحسَبِ العملِ.﴿مِن فَضۡلِهِۦٓ﴾: من عَوْنِه، وتوفيقِه."
  4,33,"﴿وَلِكُلࣲّ﴾: ولكلِّ واحدٍ.﴿مَوَ ٰ⁠لِيَ﴾: ورَثَةٌ يرثُون.﴿عَقَدَتۡ أَيۡمَـٰنُكُمۡ﴾: تحالَفْتُم معهم بالأيمانِ على النُّصرةِ، وإعطائِهم قَدْرًا من الميراثِ، وهذا منسوخٌ."
  4,34,"﴿قَوَّ ٰ⁠مُونَ﴾: أهلُ قيامٍ بمصالحهنَّ.﴿بِمَا فَضَّلَ ٱللَّهُ﴾: بما خَصَّهم من القِوامةِ والتفضيلِ، كالإنفاقِ وكفايةِ المؤونةِ.﴿قَـٰنِتَـٰتٌ﴾: مطيعاتٌ لله، قائماتٌ بحقوقِ الزوج.﴿حَـٰفِظَـٰتࣱ لِّلۡغَيۡبِ﴾: حافظاتٌ لمايَجبُ حِفْظُه عند غَيبةِ أزواجِهنَّ عنهن.﴿بِمَا حَفِظَ ٱللَّهُ﴾: بحِفْظِ اللهِ، وتوفيقِه لهن.﴿نُشُوزَهُنَّ﴾: استعلاءَهن على أزواجِهنَّ.﴿فَعِظُوهُنَّ﴾: بالكلمةِ الطيبةِ، إن نفعَتْ.﴿ٱلۡمَضَاجِعِ﴾: جَمْعُ مَضْجَع، وهو الفِراشُ، فلا تَقْرَبُوهنَّ، إنْ نَفَعَ ذلك.﴿وَٱضۡرِبُوهُنَّ﴾: ضَرْبًا غيرَ مُبَرِّحٍ أومؤثِّرٍ.﴿فَلَا تَبۡغُواْ عَلَيۡهِنَّ سَبِيلًا﴾: فاحذَرُوا ظُلْمَهنَّ."
  4,35,"﴿فَٱبۡعَثُواْ﴾: أي: إلى الزوجَيْن.﴿حَكَمࣰا﴾: عَدْلًا ممَّنْ يَصْلُحُ لذلك.﴿بَيۡنَهُمَآ﴾: بينَ الزوجَين، أو الحكَمَين."
  4,36,"﴿وَٱلۡيَتَـٰمَىٰ﴾: الأولادِ الذين ماتَ أباؤُهم وهم دونَ البُلوغ.﴿وَٱلۡمَسَـٰكِينِ﴾: الذين لا يملِكُون ما يَكْفيهم.﴿ٱلۡجُنُبِ﴾: البعيدِ.﴿وَٱلصَّاحِبِ بِٱلۡجَنۢبِ﴾: الرفيقِ في السَّفَر والحَضَرِ.﴿وَٱبۡنِ ٱلسَّبِيلِ﴾: المسافرِ المحتاجِ.﴿وَمَا مَلَكَتۡ أَيۡمَـٰنُكُمۡ﴾: الرقيقِ ذكورًا وإناثًا."
  4,37,"﴿وَأَعۡتَدۡنَا﴾: وأَعْدَدْنا.﴿مُّهِينࣰا﴾: مُخْزِيًا."
  4,38,"﴿رِئَآءَ ٱلنَّاسِ﴾: من أجلِ الرِّياءِ والسُّمعةِ.﴿قَرِينࣰا﴾: مُلازِمًا له، ويعملُ بطاعتِه."
  4,39,"﴿وَمَاذَا عَلَيۡهِمۡ﴾: وأيُّ ضررٍ يَلْحقهم؟"
  4,40,"﴿لَا يَظۡلِمُ مِثۡقَالَ ذَرَّةࣲ﴾: لا يُنْقِصُ أحدًا من جزاءِ عَمَلِه مقدارَ ذَرّة."
  4,41,"﴿فَكَيۡفَ﴾: فكيف يكون حالُ الناسِ يومَ القيامةِ؟﴿بِكَ﴾: أيها الرسولُ.﴿عَلَىٰ هَـٰٓؤُلَآءِ﴾: على أمَّتِك.﴿شَهِيدࣰا﴾: شاهدًا على الأمَّةِ بما عَمِلت."
  4,42,"﴿تُسَوَّىٰ بِهِمُ ٱلۡأَرۡضُ﴾: يجعلهم الله والأرضَ سواءً، فيصيرون ترابًا.﴿وَلَا يَكۡتُمُونَ﴾: ولا يُخْفُون عن اللهِ شيئًا، وسوف تَشْهَدُ على عَمَلِهم جَوارحُهم."
  4,43,"﴿وَأَنتُمۡ سُكَـٰرَىٰ﴾: نَزَلَ هذا الحكمُ قبلَ تحريمِ الخمرِ.﴿عَابِرِي سَبِيلٍ﴾: مَن كان مُجتازًا من باب المسجد، أوهو المسافر.﴿لَـٰمَسۡتُمُ﴾: جامَعْتُمْ.﴿فَتَيَمَّمُواْ صَعِيدࣰا طَيِّبࣰا﴾: فاقصِدوا ترابًا طاهرًا."
  4,44,"﴿نَصِيبࣰا مِّنَ ٱلۡكِتَـٰبِ﴾: حَظًّا من العِلْم بالتوراةِ.﴿ٱلسَّبِيلَ﴾: الطريقَ المستقيمَ."
  4,45,"﴿وَلِيࣰّا﴾: يَتَوَلّاكم."
  4,46,"﴿هَادُواْ﴾: هم اليهودُ.﴿يُحَرِّفُونَ ٱلۡكَلِمَ﴾: بتغييرِ اللفظِ أو المعنى أو هما جميعًا.﴿غَيۡرَ مُسۡمَعࣲ﴾: لا سَمِعْتَ، وهذا من قَبيلِ الاستهزاءِ.﴿وَرَ ٰ⁠عِنَا﴾: افهَمْ عنا، وأفْهِمْنا.﴿لَيَّۢا بِأَلۡسِنَتِهِمۡ﴾: يَلْوُون ألسنتَهم عن الحق.﴿وَٱسۡمَعۡ﴾: دونَ «غيرَ مُسْمَعٍ».﴿وَٱنظُرۡنَا﴾: انتظِرْنا نَفْهَمْ عنك، بَدَلَ «راعِنا».﴿وَأَقۡوَمَ﴾: وأصوبَ قولًا.﴿لَّعَنَهُمُ﴾: طَرَدَهم من رحمتِه."
  4,47,"﴿لِّمَا مَعَكُم﴾: من الكُتُبِ.﴿أَن نَّطۡمِسَ وُجُوهࣰا فَنَرُدَّهَا عَلَىٰٓ أَدۡبَارِهَآ﴾: نَمْحُوَ الوجوهَ، ونجعلَ أبصارَها في أدبارِ الوجوهِ.﴿أَصۡحَـٰبَ ٱلسَّبۡتِ﴾: هم اليهودُ الذين نُهُوا عن الصَّيدِ في يومِ السبت، فلم يَنْتَهُوا.﴿مَفۡعُولًا﴾: كائنًا لا محالةَ."
  4,49,"﴿يُزَكُّونَ﴾: يُثْنُون، وهم اليهودُ."
  4,51,"﴿نَصِيبࣰا﴾: حَظًّا.﴿بِٱلۡجِبۡتِ وَٱلطَّـٰغُوتِ﴾: هما كلُّ معبودٍ من دونِ اللهِ، أو مُطاعٍ في معصيته."
  4,53,"﴿نَصِيبࣱ﴾: حَظٌّ.﴿فَإِذࣰا لَّا يُؤۡتُونَ﴾: إن جُعِلَ لهم ذلك فإذن لايُعْطُون، لشِدَّةِ بُخْلِهم.﴿نَقِيرًا﴾: النُّقطةَ في ظَهْر النَّواةِ، أو وسَطِها."
  4,54,"﴿ٱلنَّاسَ﴾: محمدًا وأصحابَه.﴿فَضۡلِهِۦ﴾: النبوَّةِ، والنصْرِ.﴿فَقَدۡ ءَاتَيۡنَآ ءَالَ إِبۡرَ ٰ⁠هِيمَ﴾: فكيف لا يَحْسُدون آلَ إبراهيمَ، واليهودُ يعترفون به؟ فما آتينا محمدًا ليس ببِدْعٍ حتى يُحْسَدَ عليه.﴿ٱلۡحِكۡمَةَ﴾: ما أُوحِي إليهم من غيرِ الكتابِ.﴿مُّلۡكًا عَظِيمࣰا﴾: مُلْكَ سليمانَ."
  4,55,"﴿سَعِيرًا﴾: نارًا تُوقَدُ عليهم."
  4,56,"﴿نَضِجَتۡ﴾: احترقَتْ."
  4,57,"﴿مُّطَهَّرَةࣱ﴾: من كلِّ دَنَسٍ يكونُ في نساءِ أهلِ الدُّنيا.﴿ظَلِيلًا﴾: كثيفًا ممتدًّا."
  4,58,"﴿نِعِمَّا﴾: نِعْمَ الشيءُ."
  4,59,"﴿وَأُوْلِي ٱلۡأَمۡرِ﴾: الأئمةَ، ومَن ولّاه المسلمون، مالم يَكُنْ في طاعتِهم معصيةٌ.﴿فَرُدُّوهُ﴾: أرْجِعُوا الحُكْمَ فيه.﴿تَأۡوِيلًا﴾: عاقبةً ومَرْجِعًا."
  4,60,"﴿أُنزِلَ إِلَيۡكَ﴾: هوالقرآنُ.﴿ٱلطَّـٰغُوتِ﴾: غيرِ ما شَرَع الله."
  4,61,"﴿يَصُدُّونَ﴾: يُعْرِضُون."
  4,62,"﴿فَكَيۡفَ﴾: فكيف يكون حالُهم؟﴿وَتَوۡفِيقًا﴾: بين الخُصومِ."
  4,63,"﴿وَعِظۡهُمۡ﴾: خَوِّفْهم من النِّفاقِ.﴿بَلِيغࣰا﴾: مُؤَثِّرًا، زاجرًا لهم."
  4,65,"﴿شَجَرَ بَيۡنَهُمۡ﴾: وقَعَ بينَهم من نِزاعٍ.﴿حَرَجࣰا﴾: ضِيقًا.﴿وَيُسَلِّمُواْ﴾: ويَنْقادوا."
  4,66,"﴿كَتَبۡنَا﴾: فَرَضْنا.﴿ٱقۡتُلُوٓاْ أَنفُسَكُمۡ﴾: أن يقتُلَ بعضُكم بعضًا.﴿مَا يُوعَظُونَ بِهِۦ﴾: مايُنْصَحُون به.﴿تَثۡبِيتࣰا﴾: تَصْديقًا."
  4,68,"﴿صِرَ ٰ⁠طࣰا﴾: طريقًا."
  4,70,"4:69"
  4,71,"﴿خُذُواْ حِذۡرَكُمۡ﴾: بالاستعدادِ لعدوِّكم.﴿ثُبَاتٍ﴾: جَمْعُ ثُبَة، وهي الجماعةُ بعدَ جماعةٍ."
  4,72,"﴿شَهِيدࣰا﴾: حاضِرًا، فيُصِبْني شيءٌ."
  4,73,"﴿كَأَن لَّمۡ تَكُنۢ بَيۡنَكُمۡ وَبَيۡنَهُۥ مَوَدَّةࣱ﴾: كأنه ليس منكم، ولا بينَكم وبينَه مودةُ الإيمانِ؛ حَسَدًا منه."
  4,74,"﴿يَشۡرُونَ﴾: يَبِيعون."
  4,75,"﴿ٱلۡقَرۡيَةِ﴾: مكَّةَ."
  4,76,"﴿ٱلطَّـٰغُوتِ﴾: البَغْيِ والفسادِ في الأرضِ.﴿كَيۡدَ ٱلشَّيۡطَـٰنِ﴾: تدبيرَه."
  4,77,"﴿كُفُّوٓاْ أَيۡدِيَكُمۡ﴾: لا تُقاتِلوا، وذلك قبلَ الإذنِ بالجِهادِ.﴿أَجَلࣲ﴾: وقتٍ.﴿فَتِيلًا﴾: مقدارَ الخيطِ في شِقِّ نَواةِ التمرةِ."
  4,78,"﴿بُرُوجࣲ مُّشَيَّدَةࣲ﴾: حُصونٍ مَنيعةٍ.﴿مِنۡ عِندِكَ﴾: أيُّها الرسولُ، وهذا من جَهْلِهم."
  4,79,"﴿فَمِن نَّفۡسِكَ﴾: بذَنْبٍ اكْتَسَبْتَه.﴿شَهِيدࣰا﴾: على صِدْقِ رسالتِك."
  4,80,"﴿تَوَلَّىٰ﴾: أعْرَضَ عن طاعةِ الله ورسولِه.﴿حَفِيظࣰا﴾: حافظًا لما يعملون، مُحاسِبًا."
  4,81,"﴿طَاعَةࣱ﴾: أمْرُنا طاعةٌ.﴿بَرَزُواْ﴾: خَرَجُوا.﴿بَيَّتَ﴾: دَبَّر بلَيْلٍ.﴿غَيۡرَ ٱلَّذِي تَقُولُ﴾: غيرَ ما أعْلَنُوه من الطاعةِ.﴿وَكِيلًا﴾: ناصرًا."
  4,83,"﴿جَآءَهُمۡ﴾: جاء هذه الطائفةَ المُبَيِّتَةَ.﴿أَذَاعُواْ بِهِۦ﴾: أفشَوْه، وأعْلَنُوه.﴿لَعَلِمَهُ ٱلَّذِينَ يَسۡتَنۢبِطُونَهُۥ﴾: لَعَلِمَ حقيقةَ معناه أهلُ الفقهِ والاستنباطِ منهم، فهم يعلمون ما ينبغي أن يُفْشى، أو يُكْتَمَ."
  4,84,"﴿لَا تُكَلَّفُ إِلَّا نَفۡسَكَ﴾: لا تُلْزَمُ فِعْلَ غيرِك، ولا تُؤاخَذُ به.﴿وَحَرِّضِ ٱلۡمُؤۡمِنِينَ﴾: وحُضَّهم على الجهادِ.﴿يَكُفَّ﴾: يَمْنَعَ.﴿بَأۡسَ﴾: شدَّةَ.﴿تَنكِيلࣰا﴾: عقوبةً."
  4,85,"﴿شَفَـٰعَةً حَسَنَةࣰ﴾: هي السَّعْيُ لحصولِ الآخَرينَ على الخيرِ.﴿مِّنۡهَا﴾: نصيبٌ مِن ثوابِها.﴿كِفۡلࣱ﴾: نَصِيبٌ من إثمِها.﴿مُّقِيتࣰا﴾: قديرًا، أو حفيظًا شاهدًا."
  4,86,"﴿حَسِيبًا﴾: مُجازِيًا."
  4,88,"﴿فِئَتَيۡنِ﴾: فِرْقَتَين.﴿أَرۡكَسَهُم﴾: رَدَّهم إلى الكفرِ، وأوقعَهم فيه.﴿سَبِيلࣰا﴾: طَريقًا."
  4,89,"﴿سَوَآءࣰ﴾: كُفّارًا مِثْلَهم.﴿أَوۡلِيَآءَ﴾: أصفياءَ.﴿تَوَلَّوۡاْ﴾: أعرضُوا."
  4,90,"﴿يَصِلُونَ إِلَىٰ قَوۡمِۭ﴾: يَتَّصِلُون بقومٍ.﴿مِّيثَـٰقٌ﴾: عَهْدٌ.﴿حَصِرَتۡ﴾: ضاقَتْ.﴿ٱلسَّلَمَ﴾: الاستسلامَ."
  4,91,"﴿ءَاخَرِينَ﴾: من المنافقين.﴿ٱلۡفِتۡنَةِ﴾: الشِّركِ.﴿أُرۡكِسُواْ﴾: ارتَدُّوا، ووَقَعُوا.﴿يَعۡتَزِلُوكُمۡ﴾: يَنْصَرِفُوا عنكم.﴿ٱلسَّلَمَ﴾: الاستسلامَ.﴿ثَقِفۡتُمُوهُمۡ﴾: وجَدْتُموهم.﴿سُلۡطَـٰنࣰا﴾: حُجَّةً بَيِّنَةً على قَتْلِهِم، أو أسْرِهم."
  4,92,"﴿خَطَـࣰٔا﴾: مِن غيرِ عَمْدٍ.﴿إِلَّآ أَن يَصَّدَّقُواْ﴾: إلا أن يَتَصدَّقُوا بها عليه، ويَعْفُوا.﴿مِّيثَـٰقࣱ﴾: عهدٌ."
  4,94,"﴿فَتَبَيَّنُواْ﴾: كُونُوا على بَيِّنَةٍ فيمَن تقتُلونه.﴿ٱلسَّلَـٰمَ﴾: بدا منه شيءٌ من علاماتِ الإسلام، لأنه قد يكونُ مؤمنًا يُخفي إيمانَه.﴿كُنتُم مِّن قَبۡلُ﴾: تُخْفُون إيمانَكم عن قومِكم المشركين.﴿فَمَنَّ ٱللَّهُ عَلَيۡكُمۡ﴾: فأعَزَّكم بالإيمانِ، والقوةِ."
  4,95,"﴿ٱلۡقَـٰعِدُونَ﴾: المتخلِّفون عن الجهادِ.﴿أُوْلِي ٱلضَّرَرِ﴾: أصحابِ الأعذارِ.﴿وَكُلࣰّا﴾: وكلَّ أحدٍ من المجاهدين والقاعدين، من أهلِ الأعذارِ.﴿ٱلۡحُسۡنَىٰ﴾: الجنةَ."
  4,96,"﴿دَرَجَـٰتࣲ﴾: منازلَ."
  4,97,"﴿ظَالِمِيٓ أَنفُسِهِمۡ﴾: بقُعودِهم في دارِ الكفرِ، وتَرْكِ الهجرةِ."
  4,98,"﴿لَا يَسۡتَطِيعُونَ حِيلَةࣰ﴾: لايَقْدِرُون على دَفْعِ الظُّلمِ عنهم."
  4,100,"﴿مُرَ ٰ⁠غَمࣰا﴾: مُتَحَوَّلًا.﴿سَعَةࣰ﴾: في الرِّزقِ."
  4,101,"﴿ضَرَبۡتُمۡ﴾: سافَرْتُم.﴿يَفۡتِنَكُمُ﴾: يَعْتدِيَ عليكم."
  4,102,"﴿كُنتَ﴾: أي: في ساحةِ القتالِ، وأُقيمَت الصلاةُ.﴿وَلۡيَأۡخُذُوٓاْ أَسۡلِحَتَهُمۡ﴾: هم الطائفةُ التي تُصَلِّي معه، تحملُ سلاحَها، وتُصَلي مع الإمامِ رَكعةً واحدةً، ثم يأخُذون مكانَ الطائفةِ التي لم تُصَلِّ.﴿فَلۡيَكُونُواْ﴾: هم الطائفةُ القائمةُ بإزاءِ العدوِّ.﴿مِن وَرَآئِكُمۡ﴾: من وراءِ المُصَلِّين.﴿فَلۡيُصَلُّواْ مَعَكَ﴾: وهم الذين لم يُصَلُّوا، فيُصَلُّون مع الإمامِ رَكْعَةً.﴿فَيَمِيلُونَ عَلَيۡكُم مَّيۡلَةࣰ وَ ٰ⁠حِدَةࣰ﴾: فَيقْضُون عليكم.﴿وَلَا جُنَاحَ﴾: ولا إثمَ."
  4,103,"﴿فَأَقِيمُواْ ٱلصَّلَوٰةَ﴾: كاملةً برُكوعِها وسجودِها.﴿مَّوۡقُوتࣰا﴾: في أوقاتٍ معلومةٍ."
  4,104,"﴿وَلَا تَهِنُواْ﴾: ولا تَضْعُفوا.﴿فِي ٱبۡتِغَآءِ ٱلۡقَوۡمِ﴾: في طَلَبِ عَدوِّكم.﴿تَأۡلَمُونَ﴾: من القتالِ.﴿وَتَرۡجُونَ﴾: من الثوابِ والنَّصْرِ."
  4,105,"﴿بِمَآ أَرَىٰكَ ٱللَّهُ﴾: بما أوْحى إليك، وبَصَّرَكَ به.﴿خَصِيمࣰا﴾: مُدافِعًا عنهم."
  4,107,"﴿وَلَا تُجَـٰدِلۡ﴾: ولا تُدافِعْ، وتخاصِمْ.﴿يَخۡتَانُونَ﴾: يَخُونون بمعصيةِ اللهِ.﴿خَوَّانًا﴾: كثيرَ الخيانةِ.﴿أَثِيمࣰا﴾: كثيرَ الذَّنْبِ."
  4,108,"﴿يَسۡتَخۡفُونَ﴾: يَسْتَتِرُون.﴿وَهُوَ مَعَهُمۡ﴾: بعِلْمِه.﴿يُبَيِّتُونَ﴾: يُدَبِّرُون ليلًا."
  4,109,"﴿وَكِيلࣰا﴾: مُجادِلًا يقومُ بأمرِهم."
  4,110,"﴿يَظۡلِمۡ نَفۡسَهُۥ﴾: بارتكابِ معصيةٍ."
  4,111,"﴿يَكۡسِبُهُۥ عَلَىٰ نَفۡسِهِۦ﴾: يَضُرُّها."
  4,112,"﴿إِثۡمࣰا﴾: ذَنبًا عن عَمْدٍ.﴿ٱحۡتَمَلَ بُهۡتَـٰنࣰا﴾: تَحَمَّلَ كَذِبًا.﴿مُّبِينࣰا﴾: بَيِّنًا."
  4,113,"﴿فَضۡلُ ٱللَّهِ﴾: بالنبوَّةِ، فعَصَمَك بتوفيقِه.﴿يُضِلُّوكَ﴾: يُزِلُّوك عن الحقِّ.﴿ٱلۡحِكۡمَةَ﴾: السُّنَّةَ."
  4,114,"﴿نَّجۡوَىٰهُمۡ﴾: كلامِهم سِرًّا.﴿مَعۡرُوفٍ﴾: أعمالِ البِرِّ، والخيرِ."
  4,115,"﴿يُشَاقِقِ﴾: يُخالِفْ، ويُعادِ.﴿تَبَيَّنَ﴾: ظَهَرَ.﴿نُوَلِّهِۦ مَا تَوَلَّىٰ﴾: نَتْرُكْه وما تَوَجَّه إليه."
  4,116,"﴿مَا دُونَ ذَ ٰ⁠لِكَ﴾: ما دونَ الشِّرك."
  4,117,"﴿إِنَـٰثࣰا﴾: أوثانًا لها أسماءٌ مؤنثةٌ.﴿مَّرِيدࣰا﴾: متمرِّدًا على اللهِ، وهو إبليسُ."
  4,118,"﴿لَّعَنَهُ ٱللَّهُ﴾: طَرَدَه من رَحْمَتِه.﴿نَصِيبࣰا مَّفۡرُوضࣰا﴾: جُزْءًا منهم معلومًا، وبَيَّن ذلك بما بعدَه."
  4,119,"﴿وَلَأُضِلَّنَّهُمۡ﴾: ولَأَصْرِفَنَّهم عن طريقِ الهدايةِ.﴿وَلَأُمَنِّيَنَّهُمۡ﴾: لَأَعِدَنَّهم بالأماني الكاذبةِ.﴿فَلَيُبَتِّكُنَّ﴾: لَأَدْعُوَنَّهم إلى تَقْطِيعِ.﴿خَلۡقَ ٱللَّهِ﴾: في الفِطْرَةِ والهيئةِ."
  4,120,"﴿يَعِدُهُمۡ﴾: بالوعودِ الكاذبةِ.﴿وَيُمَنِّيهِمۡ﴾: بالأماني الباطلةِ.﴿غُرُورًا﴾: خديعةً."
  4,121,"﴿مَحِيصࣰا﴾: مَلْجَأً."
  4,122,"﴿قِيلࣰا﴾: قولًا."
  4,123,"﴿لَّيۡسَ بِأَمَانِيِّكُمۡ﴾: لا يُنالُ هذا الفضلُ بالأماني."
  4,124,"﴿نَقِيرࣰا﴾: النُّقطةَ في ظَهْرِ النَّواةِ."
  4,125,"﴿وَهُوَ مُحۡسِنࣱ﴾: عاملٌ للحَسَناتِ.﴿مِلَّةَ﴾: دينَ.﴿حَنِيفࣰا﴾: مائلًا عن العقائدِ الفاسدةِ.﴿خَلِيلࣰا﴾: صَفِيًّا."
  4,127,"﴿وَمَا يُتۡلَىٰ عَلَيۡكُمۡ﴾: أي: والقرآنُ الذي يُتْلى عليكم يُفْتِيكم فيهنَّ.﴿وَٱلۡمُسۡتَضۡعَفِينَ﴾: أي: ما يُتْلى عليكم في اليتامى، والمستضعفين.﴿بِٱلۡقِسۡطِ﴾: بالعَدْلِ."
  4,128,"﴿بَعۡلِهَا﴾: زَوْجِها.﴿نُشُوزًا﴾: استعلاءً بنفسِه عنها.﴿فَلَا جُنَاحَ﴾: فلا حَرَجَ.﴿وَأُحۡضِرَتِ ٱلۡأَنفُسُ ٱلشُّحَّ﴾: وجُبِلَتِ الأنفسُ على شُحِّ كلٍّ من الزوجَيْن بنصيبِه."
  4,129,"﴿أَن تَعۡدِلُواْ﴾: العَدْلَ التامَّ في مَيْلِ القلبِ.﴿فَلَا تَمِيلُواْ﴾: فلا تُعْرِضُوا عن المرغوبِ عنها.﴿فَتَذَرُوهَا﴾: فَتتْرُكوها.﴿كَٱلۡمُعَلَّقَةِ﴾: لا هيَ مُطَلَّقةٌ، ولا هي ذاتُ زوجٍ."
  4,130,"﴿يُغۡنِ ٱللَّهُ كُلࣰّا﴾: يَجْعَلْه مُسْتغنيًا عن الآخَر."
  4,131,"﴿وَإِيَّاكُمۡ﴾: وصَّينا أُمَّةَ محمدٍ ﷺ."
  4,132,"﴿وَكِيلًا﴾: قائمًا بشؤونِ خَلْقِه."
  4,134,"﴿ثَوَابَ ٱلدُّنۡيَا﴾: عَرَضَ الدنيا.﴿فَعِندَ ٱللَّهِ ثَوَابُ ٱلدُّنۡيَا وَٱلۡـَٔاخِرَةِ﴾: هَلّا طَلَب بعَمَلِه ما عندَ اللهِ من ثوابِ الدنيا والآخرةِ."
  4,135,"﴿قَوَّ ٰ⁠مِينَ﴾: ليتكرَّرْ منكم القيامُ.﴿بِٱلۡقِسۡطِ﴾: بالعَدْلِ، والإقرارِ بما عليكم من الحقوقِ.﴿شُهَدَآءَ لِلَّهِ﴾: مُؤَدِّين للشَّهادةِ، لمرضاةِ اللهِ.﴿إِن يَكُنۡ﴾: المشهودُ عليه.﴿أَوۡلَىٰ بِهِمَا﴾: أحقُّ منكم بكلِّ واحدٍ منهما.﴿أَن تَعۡدِلُواْ﴾: مخافةَ أن تَعْدِلُوا عن الحقِّ، فتَجُوروا.﴿تَلۡوُۥٓاْ﴾: تُحَرِّفُوا الشهادةَ.﴿أَوۡ تُعۡرِضُواْ﴾: بتَرْكِ أدائِها، أو كِتمانِها."
  4,137,"﴿سَبِيلَۢا﴾: طريقًا."
  4,139,"﴿أَوۡلِيَآءَ﴾: أنصارًا.﴿أَيَبۡتَغُونَ﴾: أيَطْلُبون؟﴿ٱلۡعِزَّةَ﴾: النُّصْرَةَ، والمنَعَةَ."
  4,140,"﴿مِّثۡلُهُمۡ﴾: في الكفرِ، لأنكم رَضِيتم بالكفرِ والاستهزاءِ."
  4,141,"﴿ٱلَّذِينَ يَتَرَبَّصُونَ بِكُمۡ﴾: المنافقون ينتظرون ما يَحُلُّ بكم.﴿فَتۡحࣱ﴾: نَصْرٌ، وغنيمةٌ.﴿نَسۡتَحۡوِذۡ﴾: نساعِدْكم، ونَغْلِبْ عليكم.﴿وَنَمۡنَعۡكُم﴾: بتَخْذِيلهم، وتَثْبيطِهم عنكم.﴿سَبِيلًا﴾: تَسَلُّطًا، وطريقًا ما داموا عاملين بالحقِّ."
  4,142,"﴿يُخَـٰدِعُونَ ٱللَّهَ﴾: بما يُظْهِرُونه من الإيمان، ويُبْطِنون الكفرَ، ظنًّا منهم أنه يَخْفى عليه.﴿وَهُوَ خَـٰدِعُهُمۡ﴾: يُوصِلُ إليهم العقوبةَ بطريقٍ خَفِيّ.﴿يُرَآءُونَ﴾: يَقْصِدُون بصَلاتِهم الرياءَ والسُّمْعةَ."
  4,143,"﴿مُّذَبۡذَبِينَ﴾: لايَسْتقِرُّون على حالٍ، بل هم مُتَحَيِّرون.﴿سَبِيلࣰا﴾: طريقًا إلى الحقِّ."
  4,144,"﴿سُلۡطَـٰنࣰا مُّبِينًا﴾: حُجَّةً ظاهرةً على كَذِبِكم في إيمانِكم."
  4,145,"﴿ٱلدَّرۡكِ﴾: الطَّبَقَةِ."
  4,147,"4:146"
  4,148,"﴿مَن ظُلِمَ﴾: فلا حَرَجَ أن يُخْبِرَ بما أُسِيءَ إليه."
  4,150,"﴿بَيۡنَ ذَ ٰ⁠لِكَ﴾: بين الإيمانِ والكُفرِ، دِينًا متوسِّطًا بينهما."
  4,152,"﴿أُجُورَهُمۡ﴾: ثوابَهم."
  4,153,"﴿جَهۡرَةࣰ﴾: عِيانًا نَنْظُرُ إليه.﴿ٱلصَّـٰعِقَةُ﴾: النارُ نَزَلَتْ عليهم، فأهلَكَتْهُم.﴿سُلۡطَـٰنࣰا﴾: حُجَّةً تُؤَيِّدُ صِدْقَ نبوَّتهِ."
  4,154,"﴿ٱلطُّورَ﴾: جَبَلَ الطُّورِ.﴿بِمِيثَـٰقِهِمۡ﴾: امتَنَعُوا عن الالتزامِ بالعَهْدِ المؤكَّدِ للعملِ بالتَوْراة، فَرفَعَ اللهُ عليهم جَبَلَ الطُّور، فقَبِلُوها.﴿ٱلۡبَابَ﴾: بابَ بيتِ المَقْدِسِ.﴿سُجَّدࣰا﴾: خاضِعين لله، لكنهم دَخَلُوا يزحَفُون على أستاهِهم.﴿لَا تَعۡدُواْ فِي ٱلسَّبۡتِ﴾: لا تَعْتَدُوا بالصَّيدِ يومَ السَّبْتِ، ولكنهم خالَفُوا.﴿مِّيثَـٰقًا غَلِيظࣰا﴾: عهدًا مؤكَّدًا، فنقضُوه."
  4,155,"﴿فَبِمَا نَقۡضِهِم مِّيثَـٰقَهُمۡ﴾: لَعَنّاهم بسببِ نَقْضِهم العهودَ المؤكَّدةَ.﴿غُلۡفُۢ﴾: عليها أغطِيَةٌ، لاتفقَهُ ما تقولُ.﴿طَبَعَ﴾: خَتَمَ.﴿إِلَّا قَلِيلࣰا﴾: إلا إيمانًا قليلًا كإيمانِهم بموسى عليه السلامُ والتوراةِ."
  4,156,"﴿بُهۡتَـٰنًا﴾: افتراءً برَمْيِها بالزِّنى."
  4,157,"﴿شُبِّهَ لَهُمۡ﴾: قَتَلُوا رجلًا يُشْبِهُه.﴿يَقِينَۢا﴾: مُتَيَقِّنِين بأنه عيسى، بل كانوا شاكِّين مُتَوَهِّمين فيه."
  4,159,"﴿لَيُؤۡمِنَنَّ بِهِۦ﴾: أي: بعدَ نُزولِه آخرَ الزَّمانِ.﴿شَهِيدࣰا﴾: شاهدًا عليهم بتكذيبِ مَن كذَّبه، وغالى فيه."
  4,161,"﴿وَأَعۡتَدۡنَا﴾: وأَعْدَدْنا."
  4,162,"﴿ٱلرَّ ٰ⁠سِخُونَ﴾: المُتَمَكِّنون.﴿وَٱلۡمُقِيمِينَ ٱلصَّلَوٰةَ﴾: أي: وأمدَحُ هؤلاء."
  4,163,"﴿وَٱلۡأَسۡبَاطِ﴾: الأنبياءِ الذين كانوا في قبائِلِ بني إسرائيلَ الاثنتي عشرةَ مِن ولدِ يعقوبَ.﴿زَبُورࣰا﴾: اسمُ الكتابِ الذي أُنْزلَ على داودَ، وهو صُحُفٌ مكتوبةٌ."
  4,165,"﴿مُّبَشِّرِينَ﴾: أي: بثوابي.﴿وَمُنذِرِينَ﴾: بعقابي.﴿بَعۡدَ ٱلرُّسُلِ﴾: بعد إرسالِ الرُّسُلِ."
  4,166,"﴿وَكَفَىٰ بِٱللَّهِ شَهِيدًا﴾: حَسْبُك اللهُ شاهدًا على صِدْقِك."
  4,168,"4:167"
  4,169,"4:167"
  4,170,"﴿فَإِنَّ لِلَّهِ مَا فِي ٱلسَّمَـٰوَ ٰ⁠تِ وَٱلۡأَرۡضِ﴾: أي: فإنه غَنِيٌّ عنكم، وعن إيمانِكم لأنه مالكُ ما في السمواتِ والأرضِ."
  4,171,"﴿لَا تَغۡلُواْ﴾: لا تُجاوِزُوا الحقَّ، فتُفْرِطُوا.﴿وَكَلِمَتُهُۥٓ﴾: وخَلَقَه بالكلمةِ التي أرسلَ جبريلَ بها إلى مريمَ، وهي قولُه: «كن» فكان.﴿وَرُوحࣱ مِّنۡهُ﴾: كان إنسانًا بإحياءِ اللهِ له بقولِه: «كن».﴿وَلَا تَقُولُواْ ثَلَـٰثَةٌ﴾: ولا تجعلُوا عيسى وأمَّه مع اللهِ شريكَيْن.﴿وَكِيلࣰا﴾: مُدَبِّرًا، وكَلَ الخَلْقُ أمورَهم إليه."
  4,172,"﴿لَّن يَسۡتَنكِفَ﴾: لن يأْنَفَ، ويَسْتَكْبِرَ."
  4,174,"﴿بُرۡهَـٰنࣱ﴾: محمدٌ ﷺ.﴿نُورࣰا﴾: قرآنًا."
  4,175,"﴿وَٱعۡتَصَمُواْ بِهِۦ﴾: تَمَسَّكُوا به.﴿صِرَ ٰ⁠طࣰا مُّسۡتَقِيمࣰا﴾: طريقًا لاعِوَجَ فيه."
  4,176,"﴿يَسۡتَفۡتُونَكَ﴾: يَطْلُبون حُكْمَك.﴿فِي ٱلۡكَلَـٰلَةِ﴾: في ميراثِ مَن مات، وليس له ولدٌ، ولا والد.﴿فَإِن كَانَتَا ٱثۡنَتَيۡنِ﴾: مَن مات كَلالةً وله أختان.﴿حَظِّ﴾: نصيبِ.﴿أَن تَضِلُّواْ﴾: لئلّا تَضِلُّوا عن الحقِّ."
