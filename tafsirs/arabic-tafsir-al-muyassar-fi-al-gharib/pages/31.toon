tafsir[29]{c,v,t}:
  31,2,"31:1"
  31,3,"31:1"
  31,4,"﴿يُؤۡتُونَ﴾: يُعْطُونَ.﴿يُوقِنُونَ﴾: يُؤْمِنُونَ."
  31,5,"﴿ٱلۡمُفۡلِحُونَ﴾: الفائِزُونَ."
  31,6,"﴿لَهۡوَ ٱلۡحَدِيثِ﴾: هُوَ كلُّ ما يُلْهِي عَن طاعةِ اللهِ.﴿بِغَيۡرِ عِلۡمࣲ﴾: جَهْلًا بِعاقِبَةِ ذَلِكَ.﴿وَيَتَّخِذَهَا﴾: ويَتَّخِذَ سَبيلَ اللهِ وآياتِ كِتابِه.﴿هُزُوًا﴾: مُسْتهْزَأً بهِا."
  31,7,"﴿وَلَّىٰ﴾: أعْرَضَ وأَدْبَرَ.﴿مُسۡتَكۡبِرࣰا﴾: مُتَكبِّرًا.﴿وَقۡرࣰا﴾: ثِقَلًا أو صَمَمًا فلا يَنْتَفِعُ بِما يَسْمَعُ."
  31,9,"﴿حَقࣰّا﴾: أي: وعْدًا حَقًّا ثابِتًا."
  31,10,"﴿عَمَدࣲ﴾: دَعائِمَ، مُفْرَدُه عِمادٌ.﴿رَوَ ٰ⁠سِيَ﴾: أي: جِبالًا ثَوابِتَ.﴿أَن تَمِيدَ بِكُمۡ﴾: أي: لِئلا تَتَحَرَّكَ الأرْضُ وتَضْطَرِبَ بِكم.﴿بَثَّ﴾: نَشَر وفَرَّقَ.﴿زَوۡجࣲ كَرِيمٍ﴾: صِنْفٍ حَسَنٍ كَثِيرِ المَنفَعَةِ."
  31,11,"﴿ضَلَـٰلࣲ مُّبِينࣲ﴾: عُدُولٍ واضِحٍ عَنِ الطَّرِيقِ المُسْتَقِيمِ."
  31,12,"﴿لُقۡمَـٰنَ﴾: هو رَجُلٌ صالِحٌ كانَ مِن حُكَماءِ بني إسرْائِيلَ.﴿ٱلۡحِكۡمَةَ﴾: العقلَ والفهمَ وإصابةَ القولِ.﴿كَفَرَ﴾: أي: جَحَدَ نِعَمَ اللهِ بِعَدَمِ شُكْرِها."
  31,14,"﴿وَصَّيۡنَا﴾: أمَرْنا.﴿وَهۡنًا﴾: ضَعْفًا.﴿وَفِصَـٰلُهُۥ﴾: فِطامُه عَنِ الرَّضاعَةِ.﴿ٱلۡمَصِيرُ﴾: المَرْجِعُ."
  31,15,"﴿جَـٰهَدَاكَ﴾: بَذَلا الجُهْدَ وحاوَلا أن يُجْبِراكَ.﴿وَصَاحِبۡهُمَا﴾: عاشِرْهُما.﴿أَنَابَ إِلَيَّ﴾: رَجَع إليّ بالإخْلاصِ والتَّوبة.﴿مَرۡجِعُكُمۡ﴾: مَصِيرُكُم.﴿فَأُنَبِّئُكُم﴾: فَأُخْبِرُكُم."
  31,16,"﴿إِنَّهَآ﴾: أي: السَّيِّئةَ أو الحَسَنَةَ.﴿مِثۡقَالَ حَبَّةࣲ﴾: وزْنَ حَبَّةٍ.﴿خَرۡدَلࣲ﴾: وهْوَ أصْغَرُ الحُبُوبِ، والمرادُ أصغرُ شيءٍ.﴿فِي صَخۡرَةٍ﴾: في باطِنِ جَبَلٍ."
  31,17,"﴿بِٱلۡمَعۡرُوفِ﴾: المعْرُوفُ كُلُّ فِعْلٍ يُعْرَفُ حُسْنُه بالشَّرْعِ أو العَقْلِ.﴿ٱلۡمُنكَرِ﴾: وهْوَ كُلُّ فِعْلٍ يُنكِرُه الشَّرعُ أوِ العَقْلُ.﴿مِنۡ عَزۡمِ ٱلۡأُمُورِ﴾: أي: مِنَ الأمُورِ الَّتي يَنْبَغِي العَزْمُ والحِرْصُ عليها."
  31,18,"﴿وَلَا تُصَعِّرۡ خَدَّكَ﴾: أي: لا تُمِلْه عُجْبًا واسْتِكْبارًا.﴿مَرَحًا﴾: فَرَحًا وبَطَرًا.﴿مُخۡتَالࣲ﴾: مُتَكَبِّرٍ.﴿فَخُورࣲ﴾: مُتَباهٍ بنفسه."
  31,19,"﴿وَٱقۡصِدۡ فِي مَشۡيِكَ﴾: أي: تَوَسَّطْ فِيه مَعَ تَواضُعٍ وسَكِينَةٍ.﴿وَٱغۡضُضۡ﴾: واخْفِضْ.﴿أَنكَرَ ٱلۡأَصۡوَ ٰ⁠تِ﴾: أي: أقبَحَها."
  31,20,"﴿سَخَّرَ لَكُم﴾: ذَلَّلَ لَكُم.﴿وَأَسۡبَغَ﴾: عَمَّ وأَتَمَّ.﴿يُجَـٰدِلُ﴾: يُخاصِمُ.﴿فِي ٱللَّهِ﴾: أي: في تَوحِيدِه وإخْلاصِ العِبادَةِ لَهُ."
  31,21,"﴿عَذَابِ ٱلسَّعِيرِ﴾: عَذابِ جَهَنَّمَ المُسْتَعِرَةِ."
  31,22,"﴿يُسۡلِمۡ وَجۡهَهُۥٓ إِلَى ٱللَّهِ﴾: يُفوِّضْ إلِيهِ أمْرَهُ ويُخلِصْ لَهُ عِبادَتَه.﴿مُحۡسِنࣱ﴾: مُطِيعٌ للهِ في أمْرِهِ ونَهْيِهِ.﴿ٱسۡتَمۡسَكَ﴾: تمسَّكَ واعْتَصَمَ.﴿بِٱلۡعُرۡوَةِ ٱلۡوُثۡقَىٰ﴾: العَهْدِ الأوْثَقِ والسَّبَبِ الأقْوى.﴿عَـٰقِبَةُ ٱلۡأُمُورِ﴾: مَرْجِعُها."
  31,23,"﴿فَنُنَبِّئُهُم﴾: فَنُخْبِرُهُم."
  31,24,"﴿نَضۡطَرُّهُمۡ﴾: نُلْجِئُهُم ونَسُوقُهُم.﴿عَذَابٍ غَلِيظࣲ﴾: أي: فَظِيعٍ وثَقِيلٍ، وهُوَ عَذابُ جَهَنَّمَ."
  31,26,"31:25"
  31,27,"﴿يَمُدُّهُۥ﴾: أي: يَزِيدُه، فَيَصِيرُ ما في البِحارِ كلِّها مِدادًا.﴿مَّا نَفِدَتۡ﴾: ما فَنِيَتْ."
  31,28,"﴿كَنَفۡسࣲ وَ ٰ⁠حِدَةٍ﴾: أي: كَخَلْقِ نَفْسٍ واحِدَةٍ وبَعْثِها."
  31,29,"﴿يُولِجُ﴾: يُدخِلُ.﴿سَخَّرَ﴾: ذلَّلَ.﴿مُّسَمࣰّى﴾: مَعْلُومٍ مُحدَّدٍ."
  31,31,"﴿ٱلۡفُلۡكَ﴾: السُّفُنَ.﴿لِيُرِيَكُم﴾: ليُظْهِرَ لَكُم.﴿مِّنۡ ءَايَـٰتِهِۦٓ﴾: أي: مِن آياتِه الدّالَّةِ عَلى قُدْرَتِه.﴿لَـَٔايَـٰتࣲ﴾: لدَلالاتٍ.﴿صَبَّارࣲ شَكُورࣲ﴾: أي: صَبّارٍ عَلى الضَّرّاءِ، وشَكُورٍ عَلى السَّرّاءِ."
  31,32,"﴿غَشِيَهُم﴾: عَلاهُم وغَطّاهُم.﴿كَٱلظُّلَلِ﴾: أي: كَشَيءٍ يكُونُ ظِلًّا مِثْلِ الِجبالِ والسَّحابِ.﴿مُّقۡتَصِدࣱ﴾: مُتَوَسِّطٌ في عَمَلِهِ وعِبادَتِه.﴿يَجۡحَدُ﴾: يُنكِرُ.﴿بِـَٔايَـٰتِنَآ﴾: بحُجَجِنا.﴿خَتَّارࣲ﴾: غَدّارٍ ناقِضٍ لِلْعهَدِ.﴿كَفُورࣲ﴾: جَحُودٍ للنِّعَمِ لا يَشْكُرُها."
  31,33,"﴿وَٱخۡشَوۡاْ يَوۡمࣰا﴾: أي: خافُوه واسْتَعِدُّوا لَهُ.﴿لَّا يَجۡزِي﴾: لا يُغْنِي.﴿فَلَا تَغُرَّنَّكُمُ﴾: فلا تَخْدَعَنَّكُم.﴿ٱلۡغَرُورُ﴾: ما يَغُرُّ ويَخْدَعُ مِن شَيطانٍ وغَيرِهِ."
  31,34,"﴿ٱلۡغَيۡثَ﴾: المَطَرَ.﴿تَدۡرِي﴾: تَعْلَمُ."
