tafsir[16]{c,v,t}:
  86,1,"﴿وَٱلطَّارِقِ﴾: أقْسَمَ اللهُ سُبحانَهُ بالنَّجْمِ الَّذِي يَطْرُقُ ليلًا."
  86,2,"﴿وَمَآ أَدۡرَىٰكَ﴾: وأيُّ شَيءٍ أعْلَمَكَ؟.﴿مَا ٱلطَّارِقُ﴾: ما عِظَمُ هذا النَّجمِ؟"
  86,3,"﴿ٱلنَّجۡمُ ٱلثَّاقِبُ﴾: النَّجمُ المُضِيءُ المُتَوهِّجُ."
  86,4,"﴿إِن﴾: ما.﴿لَّمَّا﴾: إلّا.﴿عَلَيۡهَا حَافِظࣱ﴾: أُوكِلَ بها مَلَكٌ رَقِيبٌ يَحْفَظُ عَلَيها أعْمالَها."
  86,6,"﴿مَّآءࣲ دَافِقࣲ﴾: مَنيٍّ مُنْصَبٍّ بِسُرعَةٍ في الرَّحِم."
  86,7,"﴿ٱلصُّلۡبِ﴾: العَمُودِ العَظْميِّ في وسَطِ الظَّهْرِ، وهو ذُو الفِقْراتِ.﴿وَٱلتَّرَآئِبِ﴾: جَمْع ترِيبةٍ، وهي عظامُ الصَّدرِ الَّتِي بَينَ التَّرقُوَتَينِ والثَّديينِ."
  86,8,"﴿رَجۡعِهِۦ﴾: إعادَتِهِ إلى الحياةِ بَعْدَ الموتِ."
  86,9,"﴿تُبۡلَى﴾: تُخْتَبرُ.﴿ٱلسَّرَآئِرُ﴾: ما يُخْفيهِ الإنسانُ مِنَ العقائِدِ والأعْمالِ."
  86,10,"﴿قُوَّةࣲ﴾: يدفعُ بِها عَن نَّفْسِهِ."
  86,11,"﴿ذَاتِ ٱلرَّجۡعِ﴾: ذاتِ المطَرِ الَّذِي يَرْجِعُ و يَتَكَرَّرُ."
  86,12,"﴿ٱلصَّدۡعِ﴾: التَّشَقُّقِ بِما يَتَخلَّلُها مِن نَّباتٍ."
  86,13,"﴿فَصۡلࣱ﴾: فاصِلٌ بَيْنَ الحقِّ والباطِلِ."
  86,14,"﴿بِٱلۡهَزۡلِ﴾: باللَّعِبِ والباطِل."
  86,15,"﴿يَكِيدُونَ كَيۡدࣰا﴾: يُخْفونَ قَصْدَ الضُّرِّ ويُظْهِرُونَ خِلافَه."
  86,16,"﴿وَأَكِيدُ كَيۡدࣰا﴾: لإظْهارِ الحقِّ."
  86,17,"﴿فَمَهِّلِ ٱلۡكَـٰفِرِينَ﴾: فأنْظِرْهُم.﴿أَمۡهِلۡهُمۡ﴾: أنْظِرْهُم.﴿رُوَيۡدَۢا﴾: مُهلةً غيرَ طويلةٍ."
