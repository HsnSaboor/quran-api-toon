tafsir[8]{c,v,t}:
  98,1,"﴿مُنفَكِّينَ﴾: تاركِينَ كُفْرَهُم.﴿ٱلۡبَيِّنَةُ﴾: العَلامةُ الَّتِي وُعِدُوا بِها في الكُتُبِ السّابِقَةِ."
  98,2,"﴿صُحُفࣰا﴾: قُرآنًا في صُحُفٍ."
  98,3,"﴿كُتُبࣱ قَيِّمَةࣱ﴾: أخْبارٌ صادِقَةٌ، تهدِي إلى الحقِّ."
  98,4,"﴿جَآءَتۡهُمُ ٱلۡبَيِّنَةُ﴾: تَبيَّنُوا أنُّه النَّبِيُّ الَّذِي وُعِدُوا بِهِ."
  98,5,"﴿مُخۡلِصِينَ لَهُ ٱلدِّينَ﴾: قاصِدِينَ بِعِبادَتِهِم وجْهَهُ.﴿حُنَفَآءَ﴾: مائِلِينَ عَنِ الشِّركِ إلى الإيمانِ.﴿دِينُ ٱلۡقَيِّمَةِ﴾: دِينُ الاسْتِقامةِ، وهو الإسلامُ."
  98,6,"﴿شَرُّ﴾: أشَدُّ شَرًّا."
  98,7,"﴿ٱلۡبَرِيَّةِ﴾: الخَلْقِ."
  98,8,"﴿جَنَّـٰتُ عَدۡنࣲ﴾: جَنّاتُ إقامَةٍ واسْتِقرارٍ في مُنْتَهى الحُسْنِ.﴿مِن تَحۡتِهَا﴾: مِن تَحْتِ قُصُورِها وأشجارِها.﴿خَشِيَ رَبَّهُۥ﴾: خافَ اللهَ واجْتَنَبَ مَعاصيَهُ."
