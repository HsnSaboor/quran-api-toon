tafsir[105]{c,v,t}:
  11,1,"﴿أُحۡكِمَتۡ ءَايَـٰتُهُۥ﴾: جُعِلَتْ مُحْكَمَةً مُتقنةً، لا نَقْصَ فيها ولا عَيْبَ.﴿فُصِّلَتۡ﴾: بُيِّنَتْ فيها الأحكامُ والقِصصُ والمواعظُ."
  11,3,"﴿مَّتَـٰعًا حَسَنًا﴾: بطِيبِ الحياةِ وسَعَةِ الرِّزقِ.﴿إِلَىٰٓ أَجَلࣲ مُّسَمࣰّى﴾: إلى وقتِ انقضاءِ آجالِكم.﴿فَضۡلَهُۥ﴾: جزاءَ فَضْلِه في الدُّنيا والآخرةِ.﴿تَوَلَّوۡاْ﴾: تُعْرِضُوا."
  11,5,"﴿يَثۡنُونَ صُدُورَهُمۡ﴾: يَطْوُونها على الكفرِ والعَداوةِ.﴿يَسۡتَغۡشُونَ ثِيَابَهُمۡ﴾: يَتَغَطَّوْن بها."
  11,6,"﴿دَآبَّةࣲ﴾: كلُّ حَيَوانٍ يَمْشي -على هيئتهِ- على الأرضِ.﴿مُسۡتَقَرَّهَا﴾: مكانَ استقرارِها في حياتِها وبعدَ مَماتِها.﴿وَمُسۡتَوۡدَعَهَا﴾: موضعَ استيداعِها بعد موتِها.﴿كِتَـٰبࣲ مُّبِينࣲ﴾: واضحٍ، وهو اللَّوحُ المحفوظُ."
  11,7,"﴿عَرۡشُهُۥ﴾: العرشُ: سريرُ المُلْكِ الذي استوى عليه الرحمنُ، وتحمِلُه الملائكةُ، وهو أعظمُ المخلوقاتِ، وهو سَقْفُ الجنَّةِ.﴿لِيَبۡلُوَكُمۡ﴾: لِيَخْتَبِرَكم.﴿أَحۡسَنُ عَمَلࣰا﴾: أعْمَلُ بطاعةِ اللهِ وأَوْرَعُ عن مَحارمِه."
  11,8,"﴿أُمَّةࣲ مَّعۡدُودَةࣲ﴾: وقتٍ معلومٍ.﴿وَحَاقَ﴾: أحاطَ."
  11,9,"﴿مِنَّا رَحۡمَةࣰ﴾: نِعْمةً مِن نِعَمِنا الكثيرةِ.﴿نَزَعۡنَـٰهَا مِنۡهُ﴾: سَلَبْناها منه.﴿لَيَـُٔوسࣱ﴾: شديدُ اليأسِ من رحمةِ اللهِ.﴿كَفُورࣱ﴾: كثيرُ الجُحودِ للنِّعَمِ."
  11,10,"﴿ضَرَّآءَ مَسَّتۡهُ﴾: بَلْوى أصابَتْه.﴿ٱلسَّيِّـَٔاتُ﴾: المصائبُ والشَّدائدُ.﴿لَفَرِحࣱ﴾: بَطِرٌ بالنِّعْمةِ مُغْتَرٌّ بها.﴿فَخُورٌ﴾: كثيرُ التعاظُمِ على الناسِ."
  11,12,"﴿بَعۡضَ مَا يُوحَىٰٓ إِلَيۡكَ﴾: ما يَشُقُّ على المشركين سماعُه، ويُثيرُ غضَبَهم.﴿أَن يَقُولُواْ﴾: خشيةَ أن يقولوا على وجهِ التكذيبِ والاستهزاءِ.﴿لَوۡلَآ﴾: هَلّا.﴿وَكِيلٌ﴾: حفيظٌ يُدَبِّرُ جميعَ شؤونِ خَلْقهِ."
  11,13,"﴿ٱفۡتَرَىٰهُ﴾: أتى به مِن عندِ نفسِه.﴿مُفۡتَرَيَـٰتࣲ﴾: مُخْتَلَقاتٍ من عندِ أنفسِكم.﴿وَٱدۡعُواْ مَنِ ٱسۡتَطَعۡتُم﴾: واستعينُوا بمَن أمكنكم الاستعانةُ به."
  11,15,"﴿نُوَفِّ إِلَيۡهِمۡ أَعۡمَـٰلَهُمۡ﴾: نُعْطِهم جزاءَ أعمالِهم في الدنيا.﴿لَا يُبۡخَسُونَ﴾: لا يُنْقَصُون شيئًا ممّا قُسِمَ لهم."
  11,16,"﴿وَحَبِطَ﴾: بَطَلَ في الآخرةِ نَفْعُ ما عَمِلوه."
  11,17,"﴿بَيِّنَةࣲ مِّن رَّبِّهِۦ﴾: حُجَّةٍ وبَصيرةٍ من اللهِ.﴿وَيَتۡلُوهُ﴾: يَتْبَعُه ويُقَوِّيه.﴿شَاهِدࣱ مِّنۡهُ﴾: يَشْهَدُ على كَوْنِ القرآنِ من عندِ اللهِ.﴿كِتَـٰبُ مُوسَىٰٓ﴾: التوراةُ.﴿إِمَامࣰا﴾: يُؤتَمُّ به في الدِّين، ويُقْتدى به.﴿وَرَحۡمَةً﴾: نِعْمَةً عظيمةً من اللهِ.﴿ٱلۡأَحۡزَابِ﴾: الكفارِ الذين جَمَعهم تكذيبُ رسولِ اللهِ عليه الصلاة والسلام، وكَيْدُهم له.﴿مِرۡيَةࣲ مِّنۡهُ﴾: شَكٍّ من تنزيلِ القرآنِ من اللهِ."
  11,18,"﴿يُعۡرَضُونَ عَلَىٰ رَبِّهِمۡ﴾: سيُعْرَضون على اللهِ في موقفِ الحسابِ.﴿ٱلۡأَشۡهَـٰدُ﴾: جَمْعُ شاهِدٍ، وهم: الملائكةُ والأنبياءُ والمؤمنون.﴿لَعۡنَةُ ٱللَّهِ﴾: غَضَبُه وسُخْطُه."
  11,19,"﴿يَصُدُّونَ﴾: يَمْنَعُون الناسَ.﴿سَبِيلِ ٱللَّهِ﴾: الطريقِ المُوصِلَةِ إليه، وهي دينُ الإسلامِ.﴿وَيَبۡغُونَهَا عِوَجࣰا﴾: ويُريدون أن تكونَ سبيلُ اللهِ مائلةً وفْقَ أهوائِهم."
  11,20,"﴿مُعۡجِزِينَ﴾: فائتين من عذابِ اللهِ بالهَرَبِ.﴿أَوۡلِيَآءَ﴾: أنصارٍ."
  11,21,"﴿وَضَلَّ﴾: ذَهَبَ.﴿يَفۡتَرُونَ﴾: يَكْذِبُون على اللهِ من ادِّعاءِ الشفعاءِ، الذين يَتَوَهَّمُون شفاعتَهم."
  11,22,"﴿لَا جَرَمَ﴾: حقًا، أو لا مَحالةَ."
  11,23,"﴿وَأَخۡبَتُوٓاْ إِلَىٰ رَبِّهِمۡ﴾: أنابُوا إليه وخَضَعُوا له."
  11,24,"﴿ٱلۡفَرِيقَيۡنِ﴾: فريقَي الكُفْرِ والإيمانِ."
  11,25,"﴿نَذِيرࣱ مُّبِينٌ﴾: بَيِّنُ الإنذارِ بما أُرْسِلْتُ به."
  11,27,"﴿ٱلۡمَلَأُ﴾: الأشرافُ والسّادةُ.﴿أَرَاذِلُنَا﴾: سَفَلَةُ الناسِ منا وفُقَراؤُنا.﴿بَادِيَ ٱلرَّأۡيِ﴾: أي: اتّبعُوك من غيرِ تفكيرٍ ولا رَوِيَّةٍ."
  11,28,"﴿أَرَءَيۡتُمۡ﴾: أخْبِرُوني.﴿بَيِّنَةࣲ﴾: حُجَّةٍ وبرهانٍ، تَشْهَدُ بالنبوَّةِ.﴿وَءَاتَىٰنِي رَحۡمَةࣰ مِّنۡ عِندِهِۦ﴾: وهي الرِّسالةُ.﴿فَعُمِّيَتۡ﴾: أُخْفِيَتْ."
  11,30,"11:29"
  11,31,"﴿خَزَآئِنُ ٱللَّهِ﴾: خزائنُ رزقِه، وما لا يَصِلُ إليه عِلْمُ الناسِ.﴿تَزۡدَرِيٓ أَعۡيُنُكُمۡ﴾: تَسْتَحْقِرُهم وتَسْتهينُ بهم.﴿خَيۡرًا﴾: توفيقًا وإيمانًا وأجرًا."
  11,33,"﴿بِمُعۡجِزِينَ﴾: بفائتين من عذابِ اللهِ بالهَرَبِ."
  11,34,"﴿يُغۡوِيَكُمۡ﴾: يُضِلَّكم."
  11,35,"﴿فَعَلَيَّ إِجۡرَامِي﴾: فعَلَيَّ إثمي وعُقوبتُه.﴿مِّمَّا تُجۡرِمُونَ﴾: ممّا تَقْترفونه من الكفرِ والتكذيب."
  11,36,"﴿فَلَا تَبۡتَئِسۡ﴾: لا تَحْزَنْ."
  11,37,"﴿ٱلۡفُلۡكَ﴾: السَّفينةَ.﴿بِأَعۡيُنِنَا﴾: بمَرْأى مِنّا وأنت في حِفْظِنا.﴿وَوَحۡيِنَا﴾: وبأَمْرِنا لك ومَعُونَتِنا.﴿وَلَا تُخَـٰطِبۡنِي فِي ٱلَّذِينَ ظَلَمُوٓاْ﴾: لا تَطْلُبْ مني إمهالَهم."
  11,39,"﴿يُخۡزِيهِ﴾: يُهينُه ويُذِلُّه.﴿وَيَحِلُّ عَلَيۡهِ﴾: ويَنْزِلُ به.﴿عَذَابࣱ مُّقِيمٌ﴾: دائمٌ لا ينقطِعُ، وهو النارُ."
  11,40,"﴿وَفَارَ ٱلتَّنُّورُ﴾: ونَبَعَ الماءُ بقوَّةٍ من المكانِ الذي يُخْبَزُ فيه.﴿مِن كُلࣲّ زَوۡجَيۡنِ ٱثۡنَيۡنِ﴾: من كلِّ نوعٍ من أنواعِ الحيَواناتِ ذكرًا وأنثى.﴿إِلَّا مَن سَبَقَ عَلَيۡهِ ٱلۡقَوۡلُ﴾: إلّا مَن تَقَدَّمَ حُكْمُ اللهِ عليه بأنه من المُغْرَقين."
  11,41,"﴿مَجۡرٜىٰهَا﴾: جَرْيُها على وجهِ الماء.﴿وَمُرۡسَىٰهَآ﴾: ومُنْتَهى سَيْرِها."
  11,42,"﴿مَعۡزِلࣲ﴾: مكانٍ عَزَلَ نفسَه فيه عن المؤمنين."
  11,43,"﴿سَـَٔاوِيٓ﴾: سألتجِئُ وأتحَصَّنُ.﴿لَا عَاصِمَ﴾: لا مانعَ ولا حافِظَ."
  11,44,"﴿أَقۡلِعِي﴾: أمْسِكِي عن إنزالِ المطرِ.﴿وَغِيضَ ٱلۡمَآءُ﴾: نَقَصَ وغارَ في الأرضِ.﴿وَقُضِيَ ٱلۡأَمۡرُ﴾: تَمَّ حُكْمُ اللهِ بإهلاكِ قومِ نوحٍ.﴿وَٱسۡتَوَتۡ عَلَى ٱلۡجُودِيِّ﴾: استقرَّتِ السفينةُ على جَبَلِ الجوديِّ.﴿بُعۡدࣰا﴾: هَلاكًا."
  11,46,"11:45"
  11,47,"﴿أَعُوذُ بِكَ﴾: أعتصِمُ وأستجيرُ بك."
  11,48,"﴿بِسَلَـٰمࣲ مِّنَّا﴾: بأمانٍ وسَلامةٍ منّا.﴿وَبَرَكَـٰتٍ عَلَيۡكَ﴾: خيراتٍ ونِعَمٍ دائمةٍ عليك.﴿وَأُمَمࣱ سَنُمَتِّعُهُمۡ﴾: وهم الكفارُ."
  11,50,"﴿عَادٍ﴾: قومِ هودٍ عليه السلام، وهم قبيلةٌ من العَرَبِ.﴿مُفۡتَرُونَ﴾: كاذِبُون في إشراكِكم باللهِ."
  11,51,"﴿فَطَرَنِيٓ﴾: خَلَقَني."
  11,52,"﴿ٱلسَّمَآءَ﴾: المطرَ.﴿مِّدۡرَارࣰا﴾: كثيرًا مُتتابعًا من غيرِ إضْرارٍ.﴿وَلَا تَتَوَلَّوۡاْ﴾: لا تُعْرِضُوا عَمّا دَعَوْتُكم إليه."
  11,53,"﴿بِبَيِّنَةࣲ﴾: بحُجَّةٍ واضحةٍ.﴿عَن قَوۡلِكَ﴾: من أجلِ قولِك."
  11,54,"﴿إِن نَّقُولُ﴾: ما نقولُ.﴿ٱعۡتَرَىٰكَ﴾: أصابَكَ.﴿بِسُوٓءࣲ﴾: بجُنونٍ؛ لنَهْيِك عن عبادتِها."
  11,55,"﴿فَكِيدُونِي﴾: فاجتهِدُوا في إلحاقِ الضَّرَرِ بي.﴿لَا تُنظِرُونِ﴾: لا تُمْهِلُوني بما تُريدون كيدَه."
  11,56,"﴿تَوَكَّلۡتُ عَلَى ٱللَّهِ﴾: فَوَّضْتُ أمري إليه، واعتمَدْتُ عليه.﴿دَآبَّةٍ﴾: كلُّ حَيَوانٍ يَمْشِي -على هيئتِه- على الأرضِ.﴿ءَاخِذُۢ بِنَاصِيَتِهَآ﴾: مالِكُها وقادرٌ عليها."
  11,57,"﴿وَيَسۡتَخۡلِفُ رَبِّي قَوۡمًا غَيۡرَكُمۡ﴾: يأتي بقومٍ آخَرين بَعْدَكم.﴿حَفِيظࣱ﴾: رقيبٌ مُهَيْمِنٌ."
  11,58,"﴿جَآءَ أَمۡرُنَا﴾: أي: بهَلاكِ قومِ هودٍ.﴿غَلِيظࣲ﴾: شديدٍ، وهو الرِّيحُ الباردةُ التي أُهلِكَتْ بها عادٌ."
  11,59,"﴿جَبَّارٍ﴾: متكبِّرٍ.﴿عَنِيدࣲ﴾: لا يَقْبَلُ الحقَّ ولا يَتْبَعُه."
  11,60,"﴿لَعۡنَةࣰ﴾: سُخْطًا من اللهِ، وبُعْدًا من رحمتِه.﴿بُعۡدࣰا﴾: هَلاكًا."
  11,61,"﴿ثَمُودَ﴾: قومِ صالحٍ عليه السلامُ، وهم قبيلةٌ من العَرَبِ.﴿أَنشَأَكُم مِّنَ ٱلۡأَرۡضِ﴾: ابتدأ خَلْقَكم منها.﴿وَٱسۡتَعۡمَرَكُمۡ فِيهَا﴾: جَعَلَكم عُمّارَها وسكّانَها."
  11,62,"﴿مَرۡجُوࣰّا﴾: نرجو أن تكونَ فينا سَيِّدًا مُطاعًا.﴿مُرِيبࣲ﴾: مُوقِعٍ في القلقِ وعَدَمِ الاطمئنانِ."
  11,63,"﴿أَرَءَيۡتُمۡ﴾: أخْبِروني.﴿بَيِّنَةࣲ مِّن رَّبِّي﴾: حُجَّةٍ وبُرْهانٍ منه.﴿رَحۡمَةࣰ﴾: أي: النبوَّةَ والحِكْمةَ.﴿تَخۡسِيرࣲ﴾: إيقاعٍ في الخُسْرانِ وإبعادٍ عن الخير."
  11,64,"﴿ءَايَةࣰ﴾: علامةً دالَّةً على صِدْقي.﴿فَذَرُوهَا﴾: فاترُكوها.﴿بِسُوٓءࣲ﴾: بأيِّ أذى."
  11,65,"﴿فَعَقَرُوهَا﴾: فنَحَرُوا الناقةَ.﴿تَمَتَّعُواْ فِي دَارِكُمۡ﴾: استَمْتِعُوا بالعيشِ في بلدِكم."
  11,66,"﴿جَآءَ أَمۡرُنَا﴾: أي: بهَلاكِ قومِ صالحٍ.﴿خِزۡيِ﴾: ذُلِّ ومَهانَةِ."
  11,67,"﴿ٱلصَّيۡحَةُ﴾: الصوتُ الشديدُ المُهلِكُ.﴿جَـٰثِمِينَ﴾: لاصِقِين بالأرضِ على رُكَبهِم ووُجوهِهم لا حَراكَ بهم."
  11,68,"﴿كَأَن لَّمۡ يَغۡنَوۡاْ فِيهَآ﴾: كأنّ قومَ صالحٍ لم يُقيموا في ديارِهم ويَتمتَّعُوا فيها.﴿بُعۡدࣰا﴾: هَلاكًا."
  11,69,"﴿رُسُلُنَآ﴾: الملائكةُ.﴿بِٱلۡبُشۡرَىٰ﴾: ببِشارَتِه بالولَدِ.﴿حَنِيذࣲ﴾: مَشْويٍّ في النارِ، أو على حِجارةٍ مُحمّاةٍ بها."
  11,70,"﴿نَكِرَهُمۡ﴾: أنكرَ عَدَمَ أكلِهم.﴿وَأَوۡجَسَ مِنۡهُمۡ خِيفَةࣰ﴾: أحَسَّ في نفسِه خوْفًا منهم."
  11,72,"﴿يَـٰوَيۡلَتَىٰٓ﴾: كلمةٌ أرادَتْ بها التعجُّبَ.﴿بَعۡلِي﴾: زوجي.﴿شَيۡخًا﴾: كبيرًا في السِّن."
  11,73,"﴿حَمِيدࣱ﴾: محمودٌ في صفاتِه وأفعالِه.﴿مَّجِيدࣱ﴾: ذو شَرَفٍ وكَرَمٍ، أو كثيرُ الخيرِ والإحسانِ."
  11,74,"﴿ٱلرَّوۡعُ﴾: الخوفُ."
  11,75,"﴿لَحَلِيمٌ﴾: صَبُورٌ على الأذى، كثيرُ الصَّفْحِ عَمَّن ناله بمَكْروهٍ.﴿أَوَّ ٰ⁠هࣱ﴾: كثيرُ التضرُّعِ إلى اللهِ.﴿مُّنِيبࣱ﴾: رَجّاعٌ إلى اللهِ في أمورِه كلِّها."
  11,76,"﴿جَآءَ أَمۡرُ رَبِّكَ﴾: أي: بهَلاكِ قومِ لوطٍ."
  11,77,"﴿سِيٓءَ بِهِمۡ﴾: ساءَه حُضورُهم وأحْزَنَه.﴿وَضَاقَ بِهِمۡ ذَرۡعࣰا﴾: ضَعُفَتْ طاقَتُه عن تَدْبيرِ خَلاصِهم.﴿عَصِيبࣱ﴾: شديدٌ شَرُّه وبلاؤُه."
  11,78,"﴿يُهۡرَعُونَ﴾: يُسْرِعُون المشيَ إليه؛ لطَلَبِ الفاحشةِ.﴿هَـٰٓؤُلَآءِ بَنَاتِي﴾: نساؤُكم بناتي فتزوَّجُوهنَّ.﴿وَلَا تُخۡزُونِ﴾: لا تَفْضَحُوني ولا تُهينوني.﴿رَّشِيدࣱ﴾: حَسَنُ التقديرِ للأمورِ."
  11,79,"﴿مِنۡ حَقࣲّ﴾: من حاجةٍ أو رغبةٍ."
  11,80,"﴿لَوۡ أَنَّ لِي بِكُمۡ قُوَّةً﴾: لو وجَدْتُ مُعِينًا منكم لَمَنعْتُكم من أضيافي.﴿أَوۡ ءَاوِيٓ إِلَىٰ رُكۡنࣲ شَدِيدࣲ﴾: أو ألجأُ إلى عشيرةٍ قويَّة تمنعني منكم."
  11,81,"﴿فَأَسۡرِ بِأَهۡلِكَ﴾: فاخرُجْ أنتَ وأهلُك المؤمنون.﴿بِقِطۡعࣲ مِّنَ ٱلَّيۡلِ﴾: بآخِر الليلِ.﴿إِلَّا ٱمۡرَأَتَكَ﴾: فلا تَسْرِ بها."
  11,82,"﴿جَآءَ أَمۡرُنَا﴾: أي: بهلاكِ قومِ لوطٍ.﴿جَعَلۡنَا عَـٰلِيَهَا سَافِلَهَا﴾: جَعَلْنا عاليَ قُراهم سافِلَها فقَلَبْناها عليهم.﴿وَأَمۡطَرۡنَا﴾: أرْسَلْنا.﴿سِجِّيلࣲ﴾: من طِينٍ مُتَحَجِّر.﴿مَّنضُودࣲ﴾: مُتتابعٍ في النزولِ."
  11,83,"﴿مُّسَوَّمَةً عِندَ رَبِّكَ﴾: مُعَلَّمَةً عند الله بعَلامةٍ تميِّزُها."
  11,84,"﴿مَدۡيَنَ﴾: قومِ شُعيبٍ عليه السلام، وهم قبيلةٌ من العربِ.﴿يَوۡمࣲ مُّحِيطࣲ﴾: لا يَفْلِتُ فيه أحدٌ من العذاب."
  11,85,"﴿أَوۡفُواْ﴾: أتِمُّوا.﴿بِٱلۡقِسۡطِ﴾: بالعدلِ من غيرِ زيادةٍ ولا نقصٍ.﴿وَلَا تَبۡخَسُواْ﴾: ولا تَنْقُصُوا.﴿وَلَا تَعۡثَوۡاْ﴾: ولا تُفْرِطُوا في الفسادِ."
  11,86,"﴿بَقِيَّتُ ٱللَّهِ خَيۡرࣱ لَّكُمۡ﴾: ما أبقى اللهُ لكم من الحَلالِ فيه بَرَكَةٌ وخيرٌ لكم.﴿بِحَفِيظࣲ﴾: برقيبٍ أُحْصِي أعمالَكم."
  11,87,"﴿ٱلۡحَلِيمُ﴾: العاقلُ المتأنِّي.﴿ٱلرَّشِيدُ﴾: الحَسَنُ التدبيرِ في المالِ."
  11,88,"﴿بَيِّنَةࣲ﴾: حُجَّةٍ واضحةٍ.﴿حَسَنࣰا﴾: واسعًا حلالًا.﴿وَمَا تَوۡفِيقِيٓ﴾: وما هدايتي إلى إصابةِ الحقِّ والإصلاحِ.﴿تَوَكَّلۡتُ﴾: اعتمَدْتُ وفوَّضْتُ أمري.﴿وَإِلَيۡهِ أُنِيبُ﴾: أرْجِعُ في كلِّ أموري."
  11,89,"﴿لَا يَجۡرِمَنَّكُمۡ شِقَاقِيٓ﴾: لا تَحْمِلَنَّكم مُعاداتي.﴿وَمَا قَوۡمُ لُوطࣲ مِّنكُم بِبَعِيدࣲ﴾: أي: وما إهلاكُهم بزمانٍ ولا مكانٍ بعيدٍ منكم."
  11,90,"﴿وَدُودࣱ﴾: كثيرُ المودَّةِ والمحبَّةِ لِمَن تابَ إليه وأنابَ."
  11,91,"﴿مَا نَفۡقَهُ﴾: لا نَفْهَمُ ولا نُدْرِكُ.﴿رَهۡطُكَ﴾: عشيرتُك الأقربون.﴿لَرَجَمۡنَـٰكَ﴾: لَقَتَلْناك رَجْمًا بالحجارةِ."
  11,92,"﴿وَٱتَّخَذۡتُمُوهُ وَرَآءَكُمۡ ظِهۡرِيًّا﴾: نَبَذْتُم أمرَ اللهِ وراءَ ظُهورِكم، فلم تَمْتثلُوا له.﴿مُحِيطࣱ﴾: لا يَخْفى عليه شيءٌ من أقوالِكم وأفعالِكم."
  11,93,"﴿عَلَىٰ مَكَانَتِكُمۡ﴾: حالتِكم التي أنتم عليها من الكفر.﴿يُخۡزِيهِ﴾: يُهينُه ويُذِلُّه.﴿وَٱرۡتَقِبُوٓاْ﴾: وانتظِرُوا عاقبةَ أمرِكم.﴿رَقِيبࣱ﴾: مُنتظِرٌ."
  11,94,"﴿جَآءَ أَمۡرُنَا﴾: أي: بهَلاكِ قومِ شُعيبٍ.﴿ٱلصَّيۡحَةُ﴾: وهي الصوتُ الشديدُ المُهلِكُ.﴿جَـٰثِمِينَ﴾: لاصِقين بالأرض على رُكَبِهم ووجوهِهم لاحَراكَ بهم."
  11,95,"﴿كَأَن لَّمۡ يَغۡنَوۡاْ فِيهَآ﴾: كأنّ قومَ شعيبٍ لم يُقيموا في ديارهم ويتمتَّعوا فيها.﴿بُعۡدࣰا﴾: هَلاكًا."
  11,96,"﴿بِـَٔايَـٰتِنَا﴾: بالتوراةِ، وبما أعْطَيْناه من أدلَّةٍ على توحيدِنا.﴿وَسُلۡطَـٰنࣲ مُّبِينٍ﴾: حُجَّةٍ بينةٍ على صِدْقِه."
  11,97,"﴿وَمَلَإِيْهِۦ﴾: أشرافِ قومهِ وسادتِهم.﴿بِرَشِيدࣲ﴾: مُصيبٍ للحقِّ وللطريقِ السَّديدِ."
  11,98,"﴿يَقۡدُمُ قَوۡمَهُۥ﴾: يتقدَّمُهم.﴿فَأَوۡرَدَهُمُ ٱلنَّارَ﴾: فأدخَلَهم فيها.﴿ٱلۡوِرۡدُ ٱلۡمَوۡرُودُ﴾: المَدْخَلُ الذي يَدْخُلونه، وهو النارُ."
  11,99,"﴿وَأُتۡبِعُواْ﴾: أُلْحِقُوا.﴿فِي هَـٰذِهِۦ﴾: أي: الدنيا.﴿لَعۡنَةࣰ﴾: إبعادًا عن اللهِ.﴿ٱلرِّفۡدُ ٱلۡمَرۡفُودُ﴾: العطاءُ المعطى لهم، وهو لعنةُ الدنيا والآخرةِ."
  11,100,"﴿نَقُصُّهُۥ عَلَيۡكَ﴾: نُخْبِرُك به.﴿قَآئِمࣱ﴾: له آثارٌ باقية.﴿وَحَصِيدࣱ﴾: ما لا أثَر له."
  11,101,"﴿فَمَآ أَغۡنَتۡ عَنۡهُمۡ﴾: فما نَفَعَتْهم.﴿جَآءَ أَمۡرُ رَبِّكَ﴾: أي: بهَلاكِهم.﴿غَيۡرَ تَتۡبِيبࣲ﴾: غيرَ تَخْسيرٍ وإهلاكٍ."
  11,103,"﴿لَـَٔايَةࣰ﴾: لَعِبْرَةً وعِظةً."
  11,105,"11:104"
  11,106,"﴿زَفِيرࣱ﴾: إخراجُ النَّفَسِ من الصَّدْرِ؛ من شِدَّةِ الحُزْنِ.﴿وَشَهِيقٌ﴾: رَدُّ النَّفَسِ إلى الصَّدْرِ مع طولٍ فيه."
  11,108,"﴿غَيۡرَ مَجۡذُوذࣲ﴾: غيرَ مقطوعٍ عنهم."
  11,109,"﴿مِرۡيَةࣲ﴾: شَكٍّ."
  11,110,"﴿ٱلۡكِتَـٰبَ﴾: التوراةَ.﴿كَلِمَةࣱ سَبَقَتۡ مِن رَّبِّكَ﴾: وهي حُكْمُه بتأخيرِ عذابِ الخَلْقِ إلى يومِ القيامةِ.﴿مُرِيبࣲ﴾: مُوقِعٍ في القَلَقِ وعدمِ الاطمئنانِ."
  11,112,"﴿وَلَا تَطۡغَوۡاْ﴾: ولا تتجاوَزُوا حدودَ اللهِ."
  11,113,"﴿وَلَا تَرۡكَنُوٓاْ﴾: ولا تَمِيلُوا بمَوَدَّةٍ.﴿أَوۡلِيَآءَ﴾: أنصارٍ."
  11,114,"﴿وَزُلَفࣰا مِّنَ ٱلَّيۡلِ﴾: جَمْعُ زُلْفَة، أي: ساعاتٍ من أوَّلِه."
  11,116,"﴿فَلَوۡلَا﴾: فهَلّا.﴿ٱلۡقُرُونِ﴾: جَمْعُ قَرْنٍ، وهم القومُ المقتَرنون في زمانٍ واحدٍ.﴿أُوْلُواْ بَقِيَّةࣲ﴾: أصحابُ خيرٍ وصلاحٍ.﴿مَآ أُتۡرِفُواْ فِيهِ﴾: ما مُتِّعُوا فيه من لذّاتِ الدُّنيا ونعيمِها."
  11,118,"11:117"
  11,119,"﴿وَتَمَّتۡ﴾: وجَبَتْ.﴿كَلِمَةُ رَبِّكَ﴾: حُكْمُه وقضاؤُه.﴿ٱلۡجِنَّةِ﴾: الجِنِّ."
  11,120,"﴿نَّقُصُّ عَلَيۡكَ﴾: نُخْبِرُك ونُبيِّنُ لك.﴿نُثَبِّتُ﴾: نُقَوِّي ونُطَمْئِنُ."
  11,121,"﴿مَكَانَتِكُمۡ﴾: حالتِكم التي أنتم عليها من الكفرِ."
  11,123,"﴿وَلِلَّهِ غَيۡبُ ٱلسَّمَـٰوَ ٰ⁠تِ وَٱلۡأَرۡضِ﴾: عِلْمُ جميعِ ما هو غائبٌ عن العبادِ فيهما.﴿وَتَوَكَّلۡ عَلَيۡهِ﴾: اعتمِدْ وفَوِّضْ أمْرَك إليه وحدَه."
