tafsir[47]{c,v,t}:
  69,1,"﴿ٱلۡحَآقَّةُ﴾: القِيامة الواقِعةُ حَقًّا الَّتِي يَتَحَقَّقُ فِيها الوعْدُ والوَعِيدُ."
  69,3,"﴿وَمَآ أَدۡرَىٰكَ﴾: وأيُّ شَيءٍ عَرَّفَكَ حَقيقَةَ القيامَةِ؟"
  69,4,"﴿بِٱلۡقَارِعَةِ﴾: بالقِيامَةِ الَّتِي تَقْرَعُ القُلُوبَ بِأهْوالِها."
  69,5,"﴿بِٱلطَّاغِيَةِ﴾: بالصَّيحَةِ العَظِيمَةِ الَّتِي جاوزَتِ الحدَّ في شِدَّتِها."
  69,6,"﴿صَرۡصَرٍ﴾: بارِدَةٍ.﴿عَاتِيَةࣲ﴾: شَدِيدَةٍ الهُبُوبِ."
  69,7,"﴿سَخَّرَهَا عَلَيۡهِمۡ﴾: سَلَّطَها اللهُ عَلَيهِم.﴿حُسُومࣰا﴾: مُتَتابِعَةً.﴿صَرۡعَىٰ﴾: مَوْتى.﴿أَعۡجَازُ نَخۡلٍ﴾: أُصُولُ نَخْلٍ.﴿خَاوِيَةࣲ﴾: خَرِبَةٍ مُتآكِلَةِ الأَجْوافِ."
  69,8,"﴿بَاقِيَةࣲ﴾: نَفْسٍ باقِيةٍ دُونَ هَلاكٍ."
  69,9,"﴿وَٱلۡمُؤۡتَفِكَـٰتُ﴾: وأَهلُ قُرى قَوْمِ لُوطٍ الَّذِينَ انْقَلَبَتْ بِهم دِيارُهُم.﴿بِٱلۡخَاطِئَةِ﴾: بِسَبَبِ الفَعْلَةِ المنكرَةِ مِنَ الكُفْرِ والفواحِشِ."
  69,10,"﴿فَأَخَذَهُمۡ﴾: فَأَهْلَكَهُم.﴿رَّابِيَةً﴾: بالِغةً في الشِّدَّةِ."
  69,11,"﴿طَغَا ٱلۡمَآءُ﴾: جاوَزَ حَدَّهُ حتّى عَلا وارْتَفَعَ فَوْقَ كُلِّ شَيءٍ.﴿حَمَلۡنَـٰكُمۡ﴾: حَمَلْناكُم وأنتُم في أصْلابِ آبائِكُم وأُمَّهاتِكُم.﴿ٱلۡجَارِيَةِ﴾: السَّفِينَةِ الَّتِي تَجْرِي في الماءِ."
  69,12,"﴿لِنَجۡعَلَهَا﴾: لِنَجْعَلَ الواقِعةَ الَّتِي نَجا فِيها المُؤمِنُونَ، وأُغْرِقَ فِيها الكافِرُونَ.﴿تَذۡكِرَةࣰ﴾: عِبْرةً وعِظَةً.﴿وَتَعِيَهَآ﴾: وتَحْفَظَها."
  69,13,"﴿ٱلصُّورِ﴾: القَرْنِ الَّذِي يَنْفُخُ فيه المَلَكُ عِنْدَ قِيامِ السّاعةِ."
  69,14,"﴿وَحُمِلَتِ ٱلۡأَرۡضُ وَٱلۡجِبَالُ﴾: رُفِعَت عن أماكِنِها.﴿فَدُكَّتَا دَكَّةࣰ وَ ٰ⁠حِدَةࣰ﴾: دُقَّتا دَقَّةً واحِدَةً."
  69,15,"﴿وَقَعَتِ ٱلۡوَاقِعَةُ﴾: قامَتِ القِيامةِ."
  69,16,"﴿وَٱنشَقَّتِ﴾: انْصَدَعَتْ مُتَشَقِّقَةً.﴿وَاهِيَةࣱ﴾: ضَعِيفَةٌ لا تَماسُكَ فِيها."
  69,17,"﴿وَٱلۡمَلَكُ عَلَىٰٓ أَرۡجَآئِهَا﴾: والملائِكَةُ على أطْرافِها.﴿عَرۡشَ رَبِّكَ﴾: وهو سَرِيرُ الملْكِ الَّذِي تَحْمِلُه الملائِكةُ، واسْتَوى عَلَيهِ الرحمنُ، وهو أعْظَمُ المَخْلُوقاتِ، وهو سَقْفُ جَنَّةِ الفِرْدَوسِ.﴿ثَمَـٰنِيَةࣱ﴾: أي من الملائِكةِ العِظامِ."
  69,18,"﴿تُعۡرَضُونَ﴾: أي: عَلى اللهِ.﴿لَا تَخۡفَىٰ مِنكُمۡ خَافِيَةࣱ﴾: لا تَخْفى عَلى اللهِ نَفْسٌ خافِيةٌ مِنكُم."
  69,19,"﴿هَآؤُمُ﴾: تعالَوا."
  69,20,"﴿ظَنَنتُ﴾: أيْقَنْتُ.﴿حِسَابِيَهۡ﴾: جَزائِي يومَ القيامةِ."
  69,21,"﴿رَّاضِيَةࣲ﴾: مَرْضِيَّةٍ."
  69,22,"﴿عَالِيَةࣲ﴾: مُرْتَفِعَةِ المكانِ والدَّرجاتِ."
  69,23,"﴿قُطُوفُهَا﴾: ثِمارُها.﴿دَانِيَةࣱ﴾: قَرِيبَةُ التَّناوُلِ."
  69,24,"﴿هَنِيٓـَٔۢا﴾: أكْلًا وشُرْبًا يَهْنأُ بِهما صاحِبُهُما.﴿أَسۡلَفۡتُمۡ﴾: قدَّمْتُم.﴿ٱلۡأَيَّامِ ٱلۡخَالِيَةِ﴾: أيّامِ الدُّنيا الماضِيةِ."
  69,26,"﴿حِسَابِيَهۡ﴾: جَزائِي."
  69,27,"﴿يَـٰلَيۡتَهَا﴾: ياليتَ الموتَةَ الَّتِي مِتُّها في الدُّنيا.﴿ٱلۡقَاضِيَةَ﴾: القاطِعةَ لِأَمْرِي فلا أُبْعَثُ."
  69,28,"﴿مَآ أَغۡنَىٰ﴾: ما نَفَعَ."
  69,29,"﴿هَلَكَ﴾: غابَ.﴿سُلۡطَـٰنِيَهۡ﴾: مُلْكِي."
  69,30,"﴿فَغُلُّوهُ﴾: اجْعَلُوا القَيْدَ في عُنُقِه."
  69,31,"﴿صَلُّوهُ﴾: أدْخِلُوهُ."
  69,32,"﴿سِلۡسِلَةࣲ﴾: مَجْمُوعِ حَلَقٍ مِن حَدِيدٍ داخِلٍ بَعْضُها فِي بَعْضٍ.﴿ذَرۡعُهَا﴾: مِقْدارُ طُولِها بالذِّراعِ.﴿فَٱسۡلُكُوهُ﴾: فَأَدْخِلُوه في السِّلْسِلَةِ."
  69,34,"﴿وَلَا يَحُضُّ﴾: ولا يَحُثُّ."
  69,35,"﴿هَـٰهُنَا﴾: يَومَ القِيامةِ.﴿حَمِيمࣱ﴾: قَرِيبٌ يدفعُ عنَه العذابَ."
  69,36,"﴿غِسۡلِينࣲ﴾: صَدِيدِ أهْلِ النّارِ وما يَسِيلُ مِن أجْسادِهِم."
  69,37,"﴿ٱلۡخَـٰطِـُٔونَ﴾: المذْنِبُونَ أشَدَّ الذَّنبِ وهو الإشْراكُ."
  69,38,"﴿بِمَا تُبۡصِرُونَ﴾: مِنَ الأرضِ والجِبالِ والبِحارِ والبَشَرِ والسَّمواتِ ونحوِها."
  69,39,"﴿وَمَا لَا تُبۡصِرُونَ﴾: مِنَ الأرواحِ والملائِكةِ وأُمُورِ الآخِرَةِ."
  69,40,"﴿لَقَوۡلُ رَسُولࣲ كَرِيمࣲ﴾: يَنْطِقُ بِهِ مُحَمَّدٌ ﷺ، والكَلامُ كَلامُ المُرسِلِ سُبْحانَهُ وتَعالى."
  69,41,"﴿قَلِيلࣰا مَّا تُؤۡمِنُونَ﴾: تُؤْمِنُونَ إيمانا قَلِيلا لا يُنْجِيكُم مِن الخُلُود في النّارِ."
  69,42,"﴿قَلِيلࣰا مَّا تَذَكَّرُونَ﴾: تَتَذَكَّرُونَ تَذَكُّرًا قَلِيلًا."
  69,44,"﴿وَلَوۡ تَقَوَّلَ عَلَيۡنَا بَعۡضَ ٱلۡأَقَاوِيلِ﴾: ولَو كَذَبَ عَلَينا بأنّا قُلْنا قَوْلًا لم نَقُلْه."
  69,45,"﴿لَأَخَذۡنَا مِنۡهُ بِٱلۡيَمِينِ﴾: لَأَخَذْناهُ بِقُوَّةٍ وقُدْرَةٍ."
  69,46,"﴿ٱلۡوَتِينَ﴾: هو عِرْقٌ عُلِّقَ به القلبُ ويَسْقِي الجسدَ بالدَّمِ، فإذا قُطِعَ مات صاحِبُه."
  69,47,"﴿عَنۡهُ حَـٰجِزِينَ﴾: يَمنعُونَ مِنهُ عِقابَنا."
  69,48,"﴿لَتَذۡكِرَةࣱ﴾: لَعِظَةٌ."
  69,50,"﴿وَإِنَّهُۥ﴾: أي التَّكْذِيبَ.﴿لَحَسۡرَةٌ﴾: لَنَدامةٌ عَظِيمَةٌ."
  69,51,"﴿لَحَقُّ ٱلۡيَقِينِ﴾: الخبرُ الصِّدقُ."
  69,52,"﴿فَسَبِّحۡ﴾: فَنَزِّهْ."
