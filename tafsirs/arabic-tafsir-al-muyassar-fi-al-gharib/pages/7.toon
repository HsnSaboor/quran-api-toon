tafsir[187]{c,v,t}:
  7,1,"﴿الٓمٓصٓ﴾: سبقَ شرحُ الحروفِ المقطَّعة أولَ سورة البقرة."
  7,2,"﴿حَرَجࣱ﴾: ضِيقٌ منه لتبليغِه.﴿وَذِكۡرَىٰ﴾: وتذكيرٍ."
  7,3,"﴿أَوۡلِيَآءَ﴾: أنصارًا كالشياطين والأحبارِ."
  7,4,"﴿أَهۡلَكۡنَـٰهَا﴾: أرَدْنا إهلاكَها.﴿بَأۡسُنَا﴾: عذابُنا.﴿بَيَـٰتًا﴾: نائمين ليلًا.﴿قَآئِلُونَ﴾: حالَ استراحتِهم وسطَ النهارِ."
  7,6,"7:5"
  7,7,"﴿عَلَيۡهِم﴾: على الرسُلِ والمُرْسَلِ إليهم.﴿بِعِلۡمࣲ﴾: عالمِين بما يُسِرُّون، وما يُعْلِنون."
  7,8,"﴿وَٱلۡوَزۡنُ يَوۡمَئِذٍ ٱلۡحَقُّ﴾: وزنُ صحائفِ الأعمالِ بالميزانِ العَدْلِ.﴿ثَقُلَتۡ مَوَ ٰ⁠زِينُهُۥ﴾: بثِقَلِ ما فيها من أعمالٍ حسنةٍ."
  7,10,"﴿مَكَّنَّـٰكُمۡ﴾: جَعَلْنا لكم مكانًا.﴿مَعَـٰيِشَ﴾: ما تعيشُون به من مَأْكَلٍ، ومَشْرَبٍ."
  7,11,"﴿خَلَقۡنَـٰكُمۡ﴾: خَلَقْنا أباكم آدمَ من ترابٍ.﴿صَوَّرۡنَـٰكُمۡ﴾: صَوَّرْناه على الهيئةِ المفضَّلَةِ."
  7,12,"﴿مَا مَنَعَكَ أَلَّا تَسۡجُدَ﴾: ما مَنَعَكَ من السجودِ فأَحْوَجَك ألّا تسجدَ."
  7,13,"﴿فَٱهۡبِطۡ مِنۡهَا﴾: فانْزِلْ من الجنةِ.﴿تَتَكَبَّرَ فِيهَا﴾: تَتَعالى في الجنةِ عن أمري وطاعتي.﴿ٱلصَّـٰغِرِينَ﴾: الذَّلِيلِين الحقيرِين."
  7,14,"﴿أَنظِرۡنِيٓ﴾: أمْهِلْني.﴿يَوۡمِ يُبۡعَثُونَ﴾: يومَ يُحيي اللهُ الخَلْقَ."
  7,15,"﴿مِنَ ٱلۡمُنظَرِينَ﴾: ممن كَتَبْتُ عليهم تأخيرَ الأجَلِ إلى النفخةِ الأولى."
  7,16,"﴿فَبِمَآ أَغۡوَيۡتَنِي﴾: فبسببِ إضلالِكَ لي.﴿لَأَقۡعُدَنَّ لَهُمۡ﴾: لَأَتَرَبَّصَنَّ في إغواءِ بني آدمَ.﴿صِرَ ٰ⁠طَكَ ٱلۡمُسۡتَقِيمَ﴾: طريقَك القويمَ، وهو الإسلامُ."
  7,17,"﴿شَـٰكِرِينَ﴾: ذاكِرين نعمتَك مُثْنِين بها عليك."
  7,18,"﴿مَذۡءُومࣰا﴾: ممقُوتًا مَعِيبًا.﴿مَّدۡحُورࣰا﴾: مُبْعَدًا مَطْرودًا."
  7,19,"﴿ٱلظَّـٰلِمِينَ﴾: المتجاوِزِين حُدودَ اللهِ."
  7,20,"﴿فَوَسۡوَسَ لَهُمَا﴾: فألقى الشيطانُ لآدمَ وحواءَ وسْوَسَةً لإيقاعِهما في معصيةِ اللهِ.﴿مَا وُۥرِيَ﴾: ما سُتِرَ.﴿سَوۡءَ ٰ⁠ تِهِمَا﴾: عَوْراتِهما.﴿ٱلۡخَـٰلِدِينَ﴾: في الجنةِ، الماكثين فيها أبدًا."
  7,21,"﴿وَقَاسَمَهُمَآ﴾: وحَلَفَ الشيطانُ باللهِ لآدمَ وحوّاءَ."
  7,22,"﴿فَدَلَّىٰهُمَا﴾: فأوقعهما وجَرَّأهما على ما أراد.﴿بِغُرُورࣲ﴾: بخِداعِه.﴿وَطَفِقَا﴾: وأَخَذا.﴿يَخۡصِفَانِ﴾: يَلْصَقانِ على عَوْراتهِما."
  7,23,"﴿ظَلَمۡنَآ أَنفُسَنَا﴾: بمخالفةِ أمْرِك."
  7,24,"﴿ٱهۡبِطُواْ﴾: انزِلُوا من الجنةِ إلى الأرضِ.﴿وَمَتَـٰعٌ﴾: ما تتمتعون به.﴿إِلَىٰ حِينࣲ﴾: إلى وقتِ انقضاءِ آجالِكم."
  7,25,"﴿تُخۡرَجُونَ﴾: تُبْعَثُون أحياءً من الأرض يومَ القيامةِ."
  7,26,"﴿أَنزَلۡنَا﴾: جَعَلْنا لكم.﴿يُوَ ٰ⁠رِي﴾: يَسْتُرُ.﴿سَوۡءَ ٰ⁠ تِكُمۡ﴾: عَوْراتِكم.﴿وَرِيشࣰا﴾: لباسًا للزِّينةِ والتجمُّلِ.﴿وَلِبَاسُ ٱلتَّقۡوَىٰ﴾: ولباسُ تقوى الله بفِعْل الأوامرِ واجتنابِ النواهي."
  7,27,"﴿لَا يَفۡتِنَنَّكُمُ﴾: لا يَخْدَعَنَّكم الشيطانُ بتزيينِ المعصيةِ.﴿لِيُرِيَهُمَا سَوۡءَ ٰ⁠ تِهِمَآ﴾: لتنكشِفَ لهما عوراتُهما.﴿وَقَبِيلُهُۥ﴾: ذريّةُ الشيطانِ.﴿أَوۡلِيَآءَ﴾: أنصارًا."
  7,28,"﴿فَـٰحِشَةࣰ﴾: قَبيحًا من الفِعْلِ."
  7,29,"﴿بِٱلۡقِسۡطِ﴾: بالعدلِ.﴿وَأَقِيمُواْ وُجُوهَكُمۡ﴾: وأخْلِصُوا لله العبادةَ.﴿عِندَ كُلِّ مَسۡجِدࣲ﴾: في كلِّ موضعٍ من مواضعِ العبادةِ، ولا سِيَّما المساجدُ.﴿ٱلدِّينَ﴾: الطاعةَ والعبادةَ."
  7,30,"﴿حَقَّ عَلَيۡهِمُ﴾: ثَبَتَتْ لهم، ووَجَبَتْ عليهم."
  7,31,"﴿زِينَتَكُمۡ﴾: الزينةَ المشروعةَ من ثيابٍ ساترةٍ، ونظافةٍ، وطهارةٍ.﴿عِندَ كُلِّ مَسۡجِدࣲ﴾: عند أداءِ كلِّ صلاةٍ.﴿وَلَا تُسۡرِفُوٓاْ﴾: ولا تتجاوزُوا حدودَ الاعتدالِ."
  7,32,"﴿زِينَةَ ٱللَّهِ﴾: اللِّباسَ الحسنَ الذي جَعَلَه اللهُ زينةً لكم.﴿خَالِصَةࣰ﴾: مخصوصةً بالمؤمنين."
  7,33,"﴿ٱلۡفَوَ ٰ⁠حِشَ﴾: القبائحَ من الأعمالِ.﴿وَمَا بَطَنَ﴾: وما كان خفيًّا.﴿وَٱلۡإِثۡمَ﴾: المعاصيَ كلَّها.﴿وَٱلۡبَغۡيَ﴾: الاعتداءَ على الناس.﴿سُلۡطَـٰنࣰا﴾: دليلًا وبرهانًا.﴿وَأَن تَقُولُواْ عَلَى ٱللَّهِ مَا لَا تَعۡلَمُونَ﴾: وحَرَّم اللهُ أن تَنْسِبوا إليه ما لم يَشْرَعْه."
  7,34,"﴿أَجَلࣱ﴾: وقتٌ لحُلولِ العقوبةِ.﴿لَا يَسۡتَأۡخِرُونَ﴾: لا يتأخَّرُون عنه.﴿وَلَا يَسۡتَقۡدِمُونَ﴾: ولا يتقدَّمُون عليه."
  7,35,"﴿يَقُصُّونَ﴾: يَتْلُون ويُبَيِّنُون.﴿ءَايَـٰتِي﴾: آياتِ كتابي، وأدلَّتي على صِدْقِ ما جاؤُوا به."
  7,36,"﴿وَٱسۡتَكۡبَرُواْ عَنۡهَآ﴾: استعْلَوا عن اتِّباع دلائلِ توحيدِ اللهِ."
  7,37,"﴿ٱفۡتَرَىٰ﴾: اختلَقَ.﴿نَصِيبُهُم﴾: حَظُّهم من خيرٍ وشّرٍ في الدَنيا.﴿مِّنَ ٱلۡكِتَـٰبِ﴾: مما كُتِبَ لهم في اللَّوحِ المحفوظِ.﴿رُسُلُنَا﴾: مَلَكُ الموتِ وأعوانُه.﴿يَتَوَفَّوۡنَهُمۡ﴾: يقبِضُون أرواحَهم.﴿ضَلُّواْ عَنَّا﴾: ذهَبُوا عنّا.﴿وَشَهِدُواْ﴾: واعتَرفوا."
  7,38,"﴿فِيٓ أُمَمࣲ﴾: في جملةِ جماعاتٍ من أمثالِكم في الكفر.﴿خَلَتۡ﴾: سَبَقتْ.﴿لَّعَنَتۡ أُخۡتَهَا﴾: لَعَنَتِ الجماعةُ الداخلةُ النارَ،نظيرتَها من أهلِ ملَّتِها.﴿ٱدَّارَكُواْ فِيهَا﴾: اجتمعَتِ الأممُ في النار جميعًا.﴿أُخۡرَىٰهُمۡ﴾: منزلةً ودخولًا، وهم الأتباعُ.﴿لِأُولَىٰهُمۡ﴾: منزلةً ودخولًا، وهم الرؤساءُ والقادةُ في الضلالِ.﴿ضِعۡفࣰا﴾: زائدًا على مِثْلِه مرَّةً أو مرّاتٍ.﴿لَّا تَعۡلَمُونَ﴾: لا تدْرِكُون -أيها الأتباعُ- ما لكلِّ فريقٍ منكم من العذابِ."
  7,39,"﴿فَمَا كَانَ لَكُمۡ عَلَيۡنَا مِن فَضۡلࣲ﴾: نحن القادةُ متساوون معكم-أيُّها الأتباعُ- في الضَّلالِ واستحقاقِ العذابِ."
  7,40,"﴿بِـَٔايَـٰتِنَا﴾: بحُجَجِنا وآياتِنا الدالَّةِ على وحْدانيَّتِنا.﴿وَٱسۡتَكۡبَرُواْ عَنۡهَا﴾: واستعْلَوْا عن التصديقِ بها، والعملِ بَشْرعِنا.﴿لَا تُفَتَّحُ لَهُمۡ أَبۡوَ ٰ⁠بُ ٱلسَّمَآءِ﴾: لا يَصْعَدُ لهم في الحياةِ إلى اللهِ عملٌ صالحٌ، ولا تُفَتَّحُ لأرواحِهم إذا ماتوا أبوابُ السماءِ.﴿حَتَّىٰ يَلِجَ﴾: إلا إذا دَخَلَ.﴿سَمِّ ٱلۡخِيَاطِ﴾: ثَقْبِ الإبرةِ."
  7,41,"﴿مِهَادࣱ﴾: فراشٌ مِن تحتهم.﴿غَوَاشࣲ﴾: أغطيةٌ من النارِ."
  7,42,"﴿إِلَّا وُسۡعَهَآ﴾: إلّا ما تُطيقُ من الأعمالِ."
  7,43,"﴿وَنَزَعۡنَا﴾: وأذهبَ اللهُ تعالى.﴿مِّنۡ غِلࣲّ﴾: من حِقْدٍ وضغائنَ كانت من بعضِهم في الدُّنيا.﴿مِن تَحۡتِهِمُ﴾: من تحتِ غُرَفِهم ومنازلهِم.﴿هَدَىٰنَا لِهَـٰذَا﴾: وفَّقَنا للعملِ الصالحِ.﴿أُورِثۡتُمُوهَا﴾: آلَ أمرُكم إليها."
  7,44,"﴿مَا وَعَدَنَا رَبُّنَا﴾: على ألسنةِ رُسُلِه من إثابةِ أهلِ طاعتِه.﴿مَّا وَعَدَ رَبُّكُمۡ﴾: على ألسنةِ رسُلِه من عِقابِ أهلِ معصيتِه.﴿فَأَذَّنَ مُؤَذِّنُۢ﴾: فنادى منادٍ.﴿لَّعۡنَةُ ٱللَّهِ﴾: غَضَبُ اللهِ وسَخَطُه.﴿ٱلظَّـٰلِمِينَ﴾: الذين كفرُوا، وتجاوَزُوا حدودَه."
  7,45,"﴿وَيَبۡغُونَهَا عِوَجࣰا﴾: ويَطْلُبون أن تكونَ سبيلُ اللهِ غيرَ مستقيمةٍ."
  7,46,"﴿وَبَيۡنَهُمَا﴾: وبينَ أصحابِ الجنةِ وأصحابِ النارِ.﴿حِجَابࣱ﴾: حاجزٌ عظيمٌ يسمّى ب «الأعراف».﴿وَعَلَى ٱلۡأَعۡرَافِ رِجَالࣱ﴾: وعلى أعالي ذلك السُّورِ رجالٌ استوَتْ حسناتُهم وسيئاتُهم.﴿كُلَّۢا﴾: من أهلِ الجنةِ والنارِ.﴿بِسِيمَىٰهُمۡ﴾: بعلاماتِهم، كبياضِ وجوهِ أهلِ الجنةِ، وسوادِ وجوهِ أهلِ النارِ.﴿يَطۡمَعُونَ﴾: يَرْجُون دخولَ الجنةِ."
  7,47,"﴿صُرِفَتۡ﴾: حُوِّلَتْ.﴿تِلۡقَآءَ﴾: جِهةَ."
  7,48,"﴿مَآ أَغۡنَىٰ عَنكُمۡ﴾: ما نَفَعكم.﴿جَمۡعُكُمۡ﴾: ما كنتم تَجْمعون من الأموالِ والرجالِ."
  7,49,"﴿أَهَـٰٓؤُلَآءِ﴾: أي: الضعفاءُ والفقراءُ.﴿لَا يَنَالُهُمُ ٱللَّهُ بِرَحۡمَةٍ﴾: لا يُدْخِلُهم الجنةَ."
  7,50,"﴿أَفِيضُواْ﴾: صُبُّوا بكثرةٍ.﴿رَزَقَكُمُ ٱللَّهُ﴾: من الطعام."
  7,51,"﴿ٱتَّخَذُواْ دِينَهُمۡ لَهۡوࣰا وَلَعِبࣰا﴾: جَعَلُوا ما أمرَهم اللهُ باتِّباعِه لهوًا وباطلًا.﴿وَغَرَّتۡهُمُ﴾: وخَدَعَتْهم.﴿نَنسَىٰهُمۡ﴾: نُعامِلُهم معاملةَ الشيء المَنسِيِّ.﴿كَمَا نَسُواْ﴾: كما تركُوا العملَ.﴿يَوۡمِهِمۡ هَـٰذَا﴾: يومِ القيامةِ.﴿بِـَٔايَـٰتِنَا يَجۡحَدُونَ﴾: يُنكرون أدلةَ اللهِ وبراهينَه مع عِلْمِهم بأنها حقٌّ."
  7,52,"﴿بِكِتَـٰبࣲ﴾: بقرآنٍ أنزَلْناه إليك.﴿فَصَّلۡنَـٰهُ﴾: بيَّناه أتمَّ بَيانٍ."
  7,53,"﴿هَلۡ يَنظُرُونَ﴾: ما ينتظرون.﴿تَأۡوِيلَهُۥ﴾: ما يَؤولُ إليه أمرُهم من العقابِ.﴿نَسُوهُ مِن قَبۡلُ﴾: تَرَكُوا الإيمانَ بالقرآنِ في الدنيا.﴿أَوۡ نُرَدُّ﴾: أو نُعادُ إلى الدنيا.﴿خَسِرُوٓاْ أَنفُسَهُمۡ﴾: صاروا إلى الهَلاكِ بدخولِهم النارَ وخُلودِهم فيها.﴿وَضَلَّ﴾: وذَهَبَ.﴿يَفۡتَرُونَ﴾: يَعْبُدُونه من دونِ اللهِ."
  7,54,"﴿ٱسۡتَوَىٰ﴾: علا وارتفعَ، استواءً يَليق بجَلالِه وعَظَمَتِه.﴿ٱلۡعَرۡشِ﴾: سريرِ المُلْكِ الذي استوى عليه الرحمنُ، وتَحْمِلُه الملائكة، وهو أعظمُ المخلوقات، وهو سَقْفُ الجنةِ.﴿يُغۡشِي ٱلَّيۡلَ ٱلنَّهَارَ﴾: يُدْخِلُ سبحانَه الليلَ على النهارِ حتى يَذْهَبَ نورُه، ويُدْخِلُ النهارَ على الليل حتى يَذْهَبَ ظلامُه.﴿يَطۡلُبُهُۥ﴾: كلٌّ من الليلِ والنهارِ يَطْلُبُ الآخَرَ.﴿حَثِيثࣰا﴾: طَلَبًا سريعًا دائمًا.﴿مُسَخَّرَ ٰ⁠تِۭ﴾: مُذَلَّلاتٍ خاضعاتٍ.﴿لَهُ ٱلۡخَلۡقُ﴾: إيجادُ الأشياءِ من العَدَمِ.﴿وَٱلۡأَمۡرُ﴾: التدبيرُ والتصرُّفُ في مخلوقاتِه كما يشاءُ.﴿تَبَارَكَ ٱللَّهُ﴾: كَثُرَتْ بَرَكَتُه واتسعَتْ."
  7,55,"﴿تَضَرُّعࣰا﴾: تَذَلُّلًا.﴿وَخُفۡيَةً﴾: سِرًّا.﴿ٱلۡمُعۡتَدِينَ﴾: المتجاوِزِين حدودَ ما شَرَعَه اللهُ."
  7,56,"﴿بَعۡدَ إِصۡلَـٰحِهَا﴾: ببعثةِ الرسلِ وعُمْرانِها بطاعةِ اللهِ."
  7,57,"﴿بُشۡرَۢا﴾: مُبَشِّراتٍ بالمطرِ قبلَ نزولِه.﴿بَيۡنَ يَدَيۡ رَحۡمَتِهِۦ﴾: أمامَ نزولِ المطرِ.﴿أَقَلَّتۡ﴾: حَمَلَتْ.﴿ثِقَالࣰا﴾: مُحمَّلًا بالمطرِ.﴿لِبَلَدࣲ مَّيِّتࣲ﴾: لأرضٍ لا نباتَ فيها ولا مَرْعى."
  7,58,"﴿وَٱلۡبَلَدُ ٱلطَّيِّبُ يَخۡرُجُ نَبَاتُهُۥ﴾: مَثَلٌ ضربَه اللهُ للمؤمنِ بأنه طَيِّبٌ وعَمَلَه طيبٌ.﴿وَٱلَّذِي خَبُثَ﴾: مَثَلٌ ضَرَبَه اللهُ للكافرِ بأنه خبيثٌ وعَمَلَه خبيثٌ.﴿نَكِدࣰا﴾: عسِرًا رديئًا لا نَفْعَ فيه.﴿نُصَرِّفُ﴾: نُبَيِّنُ.﴿ٱلۡـَٔايَـٰتِ﴾: الحُجَجَ والبراهينَ."
  7,60,"﴿ٱلۡمَلَأُ﴾: أشرافُ القومِ وسادتُهم.﴿ضَلَـٰلࣲ﴾: ذَهابٍ عن الحقِّ والصوابِ."
  7,62,"﴿وَأَعۡلَمُ مِنَ ٱللَّهِ﴾: وأَعْلَمُ مما أوحاه الله إليَّ من شريعتِه."
  7,64,"﴿ٱلۡفُلۡكِ﴾: السفينةِ.﴿بِـَٔايَـٰتِنَآ﴾: بحُجَجِنا الواضحةِ.﴿عَمِينَ﴾: جَمْعُ عَمٍ، أي: لا تُبْصِرُ قلوبُهم الحقَّ والإيمان."
  7,65,"﴿عَادٍ﴾: قومِ هودٍ عليه السلام، وهم قبيلةٌ من العربِ."
  7,66,"﴿سَفَاهَةࣲ﴾: خِفَّةِ عقلٍ وحَماقةٍ.﴿لَنَظُنُّكَ﴾: لَنُوقِنُ بأنك."
  7,68,"﴿أَمِينٌ﴾: على ما أقولُ من وحْيِ اللهِ."
  7,69,"﴿خُلَفَآءَ﴾: تَخْلُفُون في الأرض مَن قبلَكم.﴿بَصۜۡطَةࣰ﴾: قوةً وضَخامةً وطُولًا.﴿ءَالَآءَ ٱللَّهِ﴾: جَمْعُ إلىً، وهي نِعَمُه الكثيرةُ عليكم."
  7,70,"﴿وَنَذَرَ﴾: ونَتْرُكَ.﴿بِمَا تَعِدُنَآ﴾: بما تُخَوِّفُنا به من العذابِ."
  7,71,"﴿رِجۡسࣱ﴾: عذابٌ.﴿وَغَضَبٌ﴾: سُخْطٌ وانتقامٌ.﴿أَسۡمَآءࣲ سَمَّيۡتُمُوهَآ﴾: أصنامٍ سَمَّيتُموها آلهةً.﴿سُلۡطَـٰنࣲ﴾: حُجَّةٍ ومَعْذِرةٍ تعتذرون بها.﴿فَٱنتَظِرُوٓاْ﴾: نزولَ عذابِ الله عليكم."
  7,72,"﴿وَقَطَعۡنَا دَابِرَ﴾: وأهْلَك اللهُ الكفارَ من قومِ عادٍ، واستأصَلَهم بالريحِ."
  7,73,"﴿ثَمُودَ﴾: قومِ صالحٍ عليه السلام، وهم قبيلةٌ من العربِ.﴿بَيِّنَةࣱ﴾: برهانٌ على صِدْقِ نبيِّكم.﴿ءَايَةࣰ﴾: دليلًا على نبوَّتي.﴿فَذَرُوهَا﴾: فاترُكُوها.﴿بِسُوٓءࣲ﴾: بأيِّ أذى."
  7,74,"﴿خُلَفَآءَ﴾: تَخْلُفُون في الأرضِ مَن قبلَكم.﴿وَبَوَّأَكُمۡ﴾: ومَكَّن لكم وأَنْزَلَكم.﴿فِي ٱلۡأَرۡضِ﴾: أرضِ الحِجْرِ.﴿قُصُورࣰا﴾: بيوتًا عظيمةً.﴿وَلَا تَعۡثَوۡاْ﴾: ولا تُفْرِطُوا في الفَساد."
  7,75,"﴿ٱسۡتَكۡبَرُواْ﴾: استَعْلَوْا عن الإيمان."
  7,77,"﴿فَعَقَرُواْ ٱلنَّاقَةَ﴾: فنَحرُوها.﴿وَعَتَوۡاْ﴾: وتجاوَزُوا الحَدَّ في الاستِكْبار.﴿بِمَا تَعِدُنَآ﴾: بما تتوعَّدُنا به من العَذابِ."
  7,78,"﴿ٱلرَّجۡفَةُ﴾: الزَّلزلةُ الشديدةُ من الأرضِ.﴿جَـٰثِمِينَ﴾: لاصِقِين بالأرضِ على رُكَبهِم ووُجوهِهم، لا حَراكَ بهم."
  7,79,"﴿فَتَوَلَّىٰ﴾: فأَعْرَضَ."
  7,80,"﴿ٱلۡفَـٰحِشَةَ﴾: الفَعْلَةَ المُنْكَرةُ، وهي إتيانُ الرِّجالِ."
  7,81,"﴿مِّن دُونِ ٱلنِّسَآءِ﴾: تاركين ما أحلَّه اللهُ لكم من نسائِكم.﴿مُّسۡرِفُونَ﴾: متجاوِزُون ما أحلَّه اللهُ لكم إلى الحَرامِ."
  7,82,"﴿يَتَطَهَّرُونَ﴾: يتنزَّهُون عن إتيانِ الرجالِ في أدبارِهم."
  7,83,"﴿ٱلۡغَـٰبِرِينَ﴾: الهالِكين الباقين في العذابِ."
  7,84,"﴿وَأَمۡطَرۡنَا عَلَيۡهِم﴾: وأرسل اللهُ على الكفارِ من قومِ لوطٍ.﴿مَّطَرࣰا﴾: حجارةً متتابعةً."
  7,85,"﴿مَدۡيَنَ﴾: قومِ شُعَيبٍ عليه السَّلام، وهم قبيلةٌ من العربِ.﴿بَيِّنَةࣱ﴾: حُجَّةٌ ظاهرةٌ.﴿فَأَوۡفُواْ﴾: فأتِمُّوا.﴿وَلَا تَبۡخَسُواْ﴾: ولا تَنْقُصُوا.﴿بَعۡدَ إِصۡلَـٰحِهَا﴾: بشرائعِ الأنبياءِ، وعُمْرانِها بطاعَةِ اللهِ."
  7,86,"﴿صِرَ ٰ⁠طࣲ﴾: طريقٍ.﴿تُوعِدُونَ﴾: تُخَوِّفون الناسَ بالقَتْل إن لم يُعْطُوكم أموالَهم.﴿وَتَبۡغُونَهَا عِوَجࣰا﴾: وتُريدون أن تكونَ سبيلُ اللهِ مائلة وفْقَ أهوائِكم."
  7,87,"﴿فَٱصۡبِرُواْ﴾: فانتظرُوا أيُّها المكذِّبون.﴿يَحۡكُمَ ٱللَّهُ بَيۡنَنَا﴾: يَفْصِلَ بينَنا وبينكَم."
  7,88,"﴿ٱسۡتَكۡبَرُواْ﴾: استعلَوْا عن الإيمانِ.﴿مِلَّتِنَا﴾: دينِنا."
  7,89,"﴿ٱفۡتَحۡ﴾: احكُمْ.﴿ٱلۡفَـٰتِحِينَ﴾: الحاكمين."
  7,91,"﴿ٱلرَّجۡفَةُ﴾: الزَّلزلةُ الشديدةُ من الأرضِ.﴿جَـٰثِمِينَ﴾: لاصِقين بالأرضِ على رُكَبِهم ووجوهِهم، لا حَراكَ بهم."
  7,92,"﴿كَأَن لَّمۡ يَغۡنَوۡاْ فِيهَا﴾: كأنّ قومَ شُعَيبٍ لم يُقيموا في ديارِهم، و يتمتَّعوا فيها."
  7,93,"﴿فَتَوَلَّىٰ﴾: فأَعرَضَ.﴿ءَاسَىٰ﴾: أحْزَنُ."
  7,94,"﴿مِّن نَّبِيٍّ﴾: أي: كذَّبه قومُه.﴿أَخَذۡنَآ﴾: ابتلَينا.﴿بِٱلۡبَأۡسَآءِ﴾: البؤسِ وضيقِ المعيشةِ.﴿وَٱلضَّرَّآءِ﴾: ما يَضرُّ الإنسانَ في نفسِه أو معيشتِه.﴿يَضَّرَّعُونَ﴾: يُظْهِرُون الخضوعَ والاستكانةَ للهِ."
  7,95,"﴿ٱلسَّيِّئَةِ﴾: الحالِ السيئةِ من البلاءِ والجَدْبِ.﴿ٱلۡحَسَنَةَ﴾: الحالَ الحسنةَ من الرَّخاءِ والنِّعمةِ والعافيةِ.﴿حَتَّىٰ عَفَواْ﴾: حتى كَثُروا وكَثُرَتْ أموالُهم.﴿فَأَخَذۡنَـٰهُم﴾: فأهلَكْناهم.﴿بَغۡتَةࣰ﴾: فَجْأةً."
  7,96,"﴿وَٱتَّقَوۡاْ﴾: واجتَنَبُوا ما نهاهم اللهُ عنه.﴿بَرَكَـٰتࣲ مِّنَ ٱلسَّمَآءِ وَٱلۡأَرۡضِ﴾: ما يتتابعُ عليهم من الخير من كلِّ وجْهٍ."
  7,97,"﴿بَأۡسُنَا﴾: عذابُ اللهِ.﴿بَيَـٰتࣰا﴾: ليلًا."
  7,98,"﴿يَلۡعَبُونَ﴾: يشتغلون بما لا يعودُ عليهم بفائدةٍ."
  7,99,"﴿مَكۡرَ ٱللَّهِ﴾: استدراجَه للمكذِّبين بما أنعمَ به عليهم، وعقوبتَهم."
  7,100,"﴿يَهۡدِ﴾: يتبيَّنْ.﴿يَرِثُونَ ٱلۡأَرۡضَ﴾: بالسُّكنى.﴿مِنۢ بَعۡدِ أَهۡلِهَآ﴾: من بعدِ إهلاكِ أهلِها السابقين.﴿وَنَطۡبَعُ﴾: ونَخْتِمُ.﴿لَا يَسۡمَعُونَ﴾: الموعظةَ سماعَ منتفعٍ بها."
  7,101,"﴿نَقُصُّ﴾: نَذْكُرُ.﴿أَنۢبَآئِهَا﴾: أخبارِها.﴿بِٱلۡبَيِّنَـٰتِ﴾: بالحُجَجِ الظاهرةِ الدالَّةِ على صِدْقِهم.﴿ٱلۡكَـٰفِرِينَ﴾: الذين كَتَبَ اللهُ عليهم ألّا يُؤمنوا."
  7,102,"﴿مِّنۡ عَهۡدࣲ﴾: مِن وفاءٍ بما وصّاهم اللهُ به.﴿لَفَـٰسِقِينَ﴾: لخارجينَ عن طاعةِ اللهِ وامتثالِ أمرِه."
  7,103,"﴿بِـَٔايَـٰتِنَآ﴾: بالمعجزاتِ الظاهرةِ الدالَّةِ على صِدْقِه.﴿فِرۡعَوۡنَ﴾: لَقَبٌ لكلِّ مَن مَلَك مِصْرَ في القديم.﴿فَظَلَمُواْ بِهَا﴾: فَجحَدُوا وكَفَروا بها."
  7,105,"﴿حَقِيقٌ﴾: جديرٌ وحَرِيٌّ.﴿بِبَيِّنَةࣲ﴾: ببُرهانٍ وحُجَّةٍ واضحةٍ على صِدْقِ ما أقولُ."
  7,107,"﴿ثُعۡبَانࣱ﴾: حَيَّةٌ عظيمةٌ.﴿مُّبِينࣱ﴾: ظاهرةٌ لكلِّ مَن يَراها."
  7,108,"﴿وَنَزَعَ يَدَهُۥ﴾: وأخرجَ يدَه من فتحةِ قميصِه، أو من تحتِ إبْطِه."
  7,109,"﴿ٱلۡمَلَأُ﴾: أشرافُ القومِ وسادَتُهم."
  7,110,"﴿تَأۡمُرُونَ﴾: تُشيرون عليَّ أيها الأشرافُ."
  7,111,"﴿أَرۡجِهۡ وَأَخَاهُ﴾: أخِّرْ موسى وأخاه هارونَ، ولا تَفْصِلْ في شأنِهما الآن.﴿فِي ٱلۡمَدَآئِنِ﴾: في مُدُنِ مِصْرَ وأقاليمِها.﴿حَـٰشِرِينَ﴾: مَن يَحْشُرُ السَّحَرَةَ فيَجْمَعُهم إليك."
  7,113,"7:112"
  7,114,"7:112"
  7,115,"7:112"
  7,116,"﴿سَحَرُوٓاْ أَعۡيُنَ ٱلنَّاسِ﴾: صَرَفُوها عن حقيقةِ إدراكِها، فخُيِّلَ إلى الأبصارِ أنّ ما فعلُوه حقيقةٌ.﴿وَٱسۡتَرۡهَبُوهُمۡ﴾: وأخافوا الناسَ إخافةً شديدةً."
  7,117,"﴿تَلۡقَفُ﴾: تبتلِعُ بسرعة.﴿مَا يَأۡفِكُونَ﴾: ما يُلْقُونه من الحِبال والعِصِيِّ، ويُوهِمونَ الناسَ أنه حقٌّ."
  7,118,"﴿فَوَقَعَ ٱلۡحَقُّ﴾: فظهر الحقُّ في أمرِ موسى عليه السلام."
  7,119,"﴿وَٱنقَلَبُواْ﴾: وانصرفَ فرعونُ وقومُه.﴿صَـٰغِرِينَ﴾: أذلّاءَ بما لَحِقَهم من الهزيمةِ والخَيبةِ."
  7,121,"7:120"
  7,122,"7:120"
  7,123,"﴿ءَاذَنَ لَكُمۡ﴾: أسْمَحَ لكم بالإيمان بما يَدْعُو إليه موسى.﴿لَمَكۡرࣱ مَّكَرۡتُمُوهُ﴾: إن إيمانَكم بالله وإقرارَكم بنبوَّةِ موسى لَحيلةٌ احتَلْتُموها."
  7,124,"﴿مِّنۡ خِلَـٰفࣲ﴾: بقَطْع اليدِ اليمنى والرِّجلِ اليسرى، أو اليدِ اليسرى والرِّجلِ اليمنى.﴿لَأُصَلِّبَنَّكُمۡ﴾: لَأُبالِغَنَّ في شَدِّ أطرافِكم وتعليقِكم على جُذوع النَّخْلِ."
  7,125,"﴿مُنقَلِبُونَ﴾: راجِعُون إلى اللهِ."
  7,126,"﴿وَمَا تَنقِمُ﴾: ولَسْتَ تَعِيبُ منا -يا فرعونُ- وتُنْكِرُ.﴿بِـَٔايَـٰتِ رَبِّنَا﴾: بحُجَجِه وأدلَّتِه.﴿أَفۡرِغۡ﴾: أنْزِلْ وأسبِغْ."
  7,127,"﴿أَتَذَرُ﴾: أتَتْرُك.﴿لِيُفۡسِدُواْ فِي ٱلۡأَرۡضِ﴾: في أرضِ مصرَ بتغييرِ دينِ الناسِ إلى عبادةِ اللهِ وحدَه.﴿وَيَذَرَكَ وَءَالِهَتَكَ﴾: وقد تَرَكَك وتَرَكَ عبادةَ آلهتِك؟﴿وَنَسۡتَحۡيِۦ نِسَآءَهُمۡ﴾: ونَسْتبقيهنَّ أحياءً للخدمةِ والامتهانِ.﴿قَـٰهِرُونَ﴾: عالُون عليهم بقَهْرِ المُلْكِ والسلطانِ."
  7,129,"﴿مِن قَبۡلِ أَن تَأۡتِيَنَا﴾: برسالةِ اللهِ إلينا.﴿وَمِنۢ بَعۡدِ مَا جِئۡتَنَا﴾: برسالةِ اللهِ.﴿وَيَسۡتَخۡلِفَكُمۡ فِي ٱلۡأَرۡضِ﴾: ويَجْعَلَكم خلفاءَ في أرضِ مصرَ بعد هَلاكِ فرعونَ وقومِه."
  7,130,"﴿أَخَذۡنَآ﴾: ابتَلَيْنا.﴿بِٱلسِّنِينَ﴾: بالقحطِ والجَدْبِ."
  7,131,"﴿ٱلۡحَسَنَةُ﴾: العافيةُ والرَّخاءُ والخِصْبُ.﴿سَيِّئَةࣱ﴾: بلاءٌ وجَدْبٌ.﴿يَطَّيَّرُواْ﴾: يتشاءمُوا.﴿طَـٰٓئِرُهُمۡ﴾: ما يُصيبُهم من البلاءِ والجَدْبِ.﴿عِندَ ٱللَّهِ﴾: بقضاءِ اللهِ وقَدَرِه."
  7,132,"﴿مِنۡ ءَايَةࣲ﴾: من دَلالةٍ وحُجَّةٍ."
  7,133,"﴿وَٱلۡقُمَّلَ﴾: حشراتٌ تُفْسِدُ الثمار، وتَقْضي على الحَيَوانِ والنباتِ.﴿وَٱلدَّمَ﴾: فصارَتْ مياهُ القِبْط دمًا، ولم يَجِدوا ماءً صالحًا للشُّربِ.﴿مُّفَصَّلَـٰتࣲ﴾: مُفَرَّقاتٍ بعضُها في إثرِ بعضٍ."
  7,134,"﴿وَقَعَ﴾: نَزَلَ.﴿ٱلرِّجۡزُ﴾: العذابُ.﴿بِمَا عَهِدَ عِندَكَ﴾: بما أوحى إليك مِن رَفْعِ العذاب بالتوبةِ."
  7,135,"﴿يَنكُثُونَ﴾: يَنْقُضُون عُهودَهم، ويبْقَوْن على كُفْرِهم وضلالهِم."
  7,136,"﴿بِـَٔايَـٰتِنَا﴾: بحُجَجِنا، وما أرَيْناهم من المعجزاتِ على يدِ موسى.﴿غَـٰفِلِينَ﴾: مُعْرِضِين."
  7,137,"﴿يُسۡتَضۡعَفُونَ﴾: يُسْتَذَلُّون للخِدْمَةِ والامتهانِ.﴿مَشَـٰرِقَ ٱلۡأَرۡضِ وَمَغَـٰرِبَهَا﴾: بلادَ الشامِ.﴿كَلِمَتُ رَبِّكَ ٱلۡحُسۡنَىٰ﴾: ما وعَدَهم من تمكينِهم في الأرضِ ونَصْرِه إياهم على فرعونَ وقومِه.﴿يَعۡرِشُونَ﴾: يَبْنُون من الأبنيةِ والقصورِ وغيرِهما."
  7,138,"﴿يَعۡكُفُونَ﴾: يُقيمون ويُواظِبون من أجلِ العبادةِ."
  7,139,"﴿مُتَبَّرࣱ مَّا هُمۡ فِيهِ﴾: مُهْلَكٌ ما هم فيه من الدِّين الباطِل والشِّرْكِ بالله."
  7,140,"﴿فَضَّلَكُمۡ﴾: بكثرةِ الأنبياء وإهلاكِ عدوِّكم.﴿عَلَى ٱلۡعَـٰلَمِينَ﴾: من أهلِ عَصْرِكم."
  7,141,"﴿يَسُومُونَكُمۡ﴾: يُذيقُونكم.﴿وَيَسۡتَحۡيُونَ نِسَآءَكُمۡ﴾: ويَسْتَبْقُون نساءَكم للخِدْمَةِ والامتهانِ.﴿بَلَآءࣱ﴾: اختبارٌ ونعمةٌ."
  7,142,"﴿وَأَصۡلِحۡ﴾: واحمِلْ بني إسرائيلَ على عبادةِ اللهِ وطاعتِه."
  7,143,"﴿لَن تَرَىٰنِي﴾: لن تَقْدِرَ على رؤيتي في الدنيا.﴿تَجَلَّىٰ رَبُّهُۥ لِلۡجَبَلِ﴾: ظَهَرَ ربُّه للجَبَلِ على الوجهِ اللائقِ بجَلالِه.﴿دَكࣰّا﴾: مُسْتويًا بالأرض.﴿وَخَرَّ﴾: وسقط.﴿صَعِقࣰا﴾: مَغْشِيًّا عليه؛ لعِظَمِ ما رأى.﴿أَوَّلُ ٱلۡمُؤۡمِنِينَ﴾: بك من قومي."
  7,144,"﴿ٱصۡطَفَيۡتُكَ﴾: اختَرْتُك.﴿وَبِكَلَـٰمِي﴾: وبتكليمي إياك من غيرِ واسطةٍ."
  7,145,"﴿فِي ٱلۡأَلۡوَاحِ﴾: ألواحِ التوراةِ.﴿مِن كُلِّ شَيۡءࣲ﴾: يحتاجون إليه في دينِهم، وما يُصْلِحُ معاشَهم.﴿فَخُذۡهَا بِقُوَّةࣲ﴾: فخُذِ التوراةَ بجِدٍّ واجتهاد.﴿بِأَحۡسَنِهَا﴾: بحَسَنِها، وكلُّها حَسَنٌ بما شَرَعَ اللهُ فيها.﴿دَارَ ٱلۡفَـٰسِقِينَ﴾: مصيرَهم في الآخرة، وهي النارُ."
  7,146,"﴿عَنۡ ءَايَـٰتِيَ﴾: عن فَهْمِ حُجَجِ الله وأدلَّتِه وكتابِه.﴿ٱلۡغَيِّ﴾: الضلالِ."
  7,147,"﴿حَبِطَتۡ أَعۡمَـٰلُهُمۡ﴾: بطَلَتْ أعمالُهم، فلا ثوابَ عليها."
  7,148,"﴿مِنۢ بَعۡدِهِۦ﴾: مِن بعدِ ما فارَقَهم لمناجاةِ ربِّه.﴿عِجۡلࣰا جَسَدࣰا﴾: معبودًا مِن ذَهَبِهم على صورةِ العجلِ بلا رُوحٍ.﴿لَّهُۥ خُوَارٌ﴾: له صوتٌ يُشْبِهُ صوتَ البقرِ."
  7,149,"﴿وَلَمَّا سُقِطَ فِيٓ أَيۡدِيهِمۡ﴾: ولما نَدِمُوا على عبادةِ العجلِ عند رجوعِ موسى عليه السلام."
  7,150,"﴿أَسِفࣰا﴾: حزينًا على عبادةِ قومِه العجلَ.﴿أَعَجِلۡتُمۡ أَمۡرَ رَبِّكُمۡ﴾: أستعجَلْتم مجيئي إليكم وما وصَّيتُكم به من التوحيدِ، فَعَبدْتُم العِجْلَ؟﴿فَلَا تُشۡمِتۡ﴾: فلا تَسُرَّ."
  7,152,"﴿ٱلۡمُفۡتَرِينَ﴾: المكذِّبين المبتدِعين."
  7,154,"﴿يَرۡهَبُونَ﴾: يخافون أشدَّ الخوفِ من ربِّهم."
  7,155,"﴿لِّمِيقَـٰتِنَا﴾: للوقتِ الذي واعَدَ اللهُ موسى أن يَلْقاه فيه؛ للتوبةِ والاعتذارِ عَمّا فعلَ سُفَهاءُ بني إسرائيل.﴿ٱلرَّجۡفَةُ﴾: الزَّلزلةُ الشديدةُ.﴿ٱلسُّفَهَآءُ﴾: ضِعافُ العقولِ.﴿إِنۡ هِيَ إِلَّا فِتۡنَتُكَ﴾: ما عبادةُ قومي للعِجْلِ إلا ابتلاءٌ واختبارٌ."
  7,156,"﴿وَٱكۡتُبۡ لَنَا﴾: واجعَلْنا ممَّن كَتَبْتَ له.﴿حَسَنَةࣰ﴾: الصالحاتِ من الأعمالِ.﴿يَتَّقُونَ﴾: يخافون اللهَ ويخشَونَ عقابَه.﴿بِـَٔايَـٰتِنَا﴾: بدلائلِ توحيدِنا."
  7,157,"﴿ٱلۡأُمِّيَّ﴾: الذي لا يقرأُ ولا يكتبُ.﴿يَجِدُونَهُۥ﴾: يَجِدونَ صفتَه ونبوَّتَه.﴿ٱلۡخَبَـٰٓئِثَ﴾: من المطاعمِ والمشاربِ والمناكحِ.﴿وَيَضَعُ عَنۡهُمۡ﴾: ويَرْفَعُ عنهم بالتخفيفِ أو الإذهاب.﴿إِصۡرَهُمۡ وَٱلۡأَغۡلَـٰلَ ٱلَّتِي كَانَتۡ عَلَيۡهِمۡ﴾: ما أُلْزِمُوا العملَ به من التكاليفِ الشاقةِ في التوراة.﴿وَعَزَّرُوهُ﴾: وعَظَّموه ووَقَّرُوه.﴿ٱلنُّورَ﴾: القرآنَ."
  7,158,"﴿وَكَلِمَـٰتِهِۦ﴾: ما أُنْزِلَ إلى النبي ﷺ من ربِّه والنبيين من قبلِه."
  7,159,"﴿يَهۡدُونَ بِٱلۡحَقِّ﴾: يستقيمون على الحقِّ، ويَدْعُون الناسَ إلى الهدايةِ."
  7,160,"﴿وَقَطَّعۡنَـٰهُمُ﴾: وفَرَّقْنا قومَ موسى من بني إسرائيلَ.﴿أَسۡبَاطًا﴾: جمعُ سِبْطٍ، وهو ولَدُ الوَلَدِ، والمرادُ: قبائلُ بعددِ الأسباطِ مِن ولَدِ يعقوبَ.﴿فَٱنۢبَجَسَتۡ﴾: فانفجرَتْ.﴿ٱلۡغَمَـٰمَ﴾: السَّحابَ.﴿ٱلۡمَنَّ﴾: شيءٌ يُشْبِهُ الصَّمْغَ، طعمُه كالعَسَل.﴿وَٱلسَّلۡوَىٰ﴾: طائرٌ يُشْبِهُ السُّمانى."
  7,161,"﴿ٱلۡقَرۡيَةَ﴾: بيتَ المَقْدِسِ:﴿حِطَّةࣱ﴾: مسألتُنا حِطَّةٌ، أي: حُطَّ عنا ذنوبَنا.﴿سُجَّدࣰا﴾: خاضِعين للهِ تواضُعًا."
  7,162,"﴿رِجۡزࣰا﴾: عذابًا."
  7,163,"﴿حَاضِرَةَ ٱلۡبَحۡرِ﴾: قريبةً من البحرِ الأحمرِ مُشْرِفةً عليه.﴿إِذۡ يَعۡدُونَ﴾: إذ يعتدي أهلُ القريةِ بصيدِ السمكِ.﴿فِي ٱلسَّبۡتِ﴾: في يومِ السبتِ الذي أُمِرُوا بتعظيمِه.﴿شُرَّعࣰا﴾: ظاهرةً على وجهِ البحرِ قريبةً من الشاطئ.﴿وَيَوۡمَ لَا يَسۡبِتُونَ﴾: وفي سائرِ الأيام غيرِ يومِ السبتِ.﴿نَبۡلُوهُم﴾: نَخْتَبِرُهم."
  7,164,"﴿قَالُواْ مَعۡذِرَةً﴾: نَعِظُهم لنُعْذَرَ فيهم عندَ اللهِ."
  7,165,"﴿بَـِٔيسِۭ﴾: أليمٍ شديدٍ."
  7,166,"﴿عَتَوۡاْ﴾: تمرَّدوا وتكبَّروا."
  7,167,"﴿تَأَذَّنَ﴾: أعلمَ.﴿لَيَبۡعَثَنَّ﴾: ليُسَلِّطَنَّ.﴿يَسُومُهُمۡ﴾: يُذيقُهم."
  7,168,"﴿وَقَطَّعۡنَـٰهُمۡ﴾: وفَرَّقْنا بني إسرائيلَ.﴿وَبَلَوۡنَـٰهُم﴾: واخَتَبْرناهم."
  7,169,"﴿خَلۡفࣱ﴾: مَن يَخْلُفُ غيرَه بالسُّوءِ.﴿عَرَضَ هَـٰذَا ٱلۡأَدۡنَىٰ﴾: ما يَعْرِضُ لهم من متاعِ الدنيا مِن دنيءِ المكاسبِ، كالرِّشوةِ والتحريفِ.﴿عَرَضࣱ مِّثۡلُهُۥ﴾: متاعٌ زائلٌ من أنواعِ الكسبِ الحرامِ.﴿مِّيثَـٰقُ ٱلۡكِتَـٰبِ﴾: ما أخذه اللهُ عليهم من العهودِ في التوراةِ على العملِ بها.﴿وَدَرَسُواْ مَا فِيهِ﴾: وعَلِمُوا ما في التوراةِ، فضيَّعوها وتَرَكُوا العملَ بها."
  7,170,"﴿يُمَسِّكُونَ﴾: يتمسَّكون."
  7,171,"﴿نَتَقۡنَا﴾: اقتلَعْنا ورَفَعْنا.﴿ظُلَّةࣱ﴾: سَحابةٌ تُظِلُّهم.﴿وَظَنُّوٓاْ﴾: وأيقَنُوا.﴿وَاقِعُۢ بِهِمۡ﴾: إن لم يقبَلُوا أحكامَ التوراةِ.﴿بِقُوَّةࣲ﴾: بجِدٍّ واجتهادٍ.﴿وَٱذۡكُرُواْ مَا فِيهِ﴾: بالعملِ بما فيه."
  7,172,"﴿أَخَذَ﴾: استخرج.﴿وَأَشۡهَدَهُمۡ عَلَىٰٓ أَنفُسِهِمۡ﴾: وقرَّرَهم -جميعًا- بتوحيدِه بما أوْدَعَه في فِطَرِهم.﴿أَن تَقُولُواْ﴾: لئلا تقولوا."
  7,173,"﴿أَفَتُهۡلِكُنَا﴾: أفتعذِّبُنا.﴿ٱلۡمُبۡطِلُونَ﴾: الذين أبْطَلُوا أعمالهم بالإشراكِ بالله."
  7,174,"﴿نُفَصِّلُ﴾: نبيِّنُ."
  7,175,"﴿وَٱتۡلُ﴾: واقصُصْ.﴿نَبَأَ﴾: خبرَ رجلٍ من بني إسرائيلَ.﴿ءَاتَيۡنَـٰهُ ءَايَـٰتِنَا﴾: أتاه اللهُ علمًا ببعض الكتبِ المنزَّلَةِ.﴿فَٱنسَلَخَ مِنۡهَا﴾: ثم كَفَرَ بها وجَعَلَها وراءَ ظهرِه.﴿فَأَتۡبَعَهُ ٱلشَّيۡطَـٰنُ﴾: لَحِقه فأدركَه فصارَ قرينَه.﴿ٱلۡغَاوِينَ﴾: الضالِّين الراسِخين في الضلالِ."
  7,176,"﴿لَرَفَعۡنَـٰهُ﴾: لَرَفَعْنا قَدْرَه بالعلمِ والعملِ بها.﴿أَخۡلَدَ إِلَى ٱلۡأَرۡضِ﴾: رَكَنَ إلى الدُّنيا، واطمأَنَّ بها."
  7,177,"﴿سَآءَ﴾: قَبُحَ.﴿يَظۡلِمُونَ﴾: بالتكذيب وأنواع المعاصي."
  7,178,"﴿مَن يَهۡدِ ٱللَّهُ﴾: مَن يُوَفِّقْه للإيمانِ والعَمَلِ الصالحِ."
  7,179,"﴿ذَرَأۡنَا﴾: خَلَقْنا.﴿لَّا يَفۡقَهُونَ بِهَا﴾: لا يفْهمون بها الحقَّ ولا يَعْقلون.﴿كَٱلۡأَنۡعَـٰمِ﴾: كالبَهائمِ التي لا تفقَهُ ما يُقالُ لها، ولا تُمَيِّزُ."
  7,180,"﴿فَٱدۡعُوهُ بِهَا﴾: فاطْلُبُوا من الله بأسمائِه ما تُريدون.﴿وَذَرُواْ﴾: واترُكُوا.﴿يُلۡحِدُونَ فِيٓ أَسۡمَـٰٓئِهِۦ﴾: يَميلون بها عَمّا جُعِلَتْ له."
  7,181,"﴿يَهۡدُونَ بِٱلۡحَقِّ﴾: يَسْتقيمون على الحقِّ، ويَدْعُون الناسَ إلى الهدايةِ.﴿وَبِهِۦ يَعۡدِلُونَ﴾: وبالحقِّ يقْضُون بينَ الناسِ."
  7,182,"﴿سَنَسۡتَدۡرِجُهُم﴾: سَنُدْنِيهم -في حالِ اغْتِرارِهم- إلى ما يُهْلِكُهم ويضاعِفُ عِقابَهم."
  7,183,"﴿وَأُمۡلِي لَهُمۡ﴾: وأمْهِلُهم مدةً طويلةً.﴿مَتِينٌ﴾: قويٌّ لا يُدْفَعُ."
  7,184,"﴿جِنَّةٍ﴾: جُنونٍ."
  7,185,"﴿مَلَكُوتِ﴾: المُلْكِ العظيمِ. (زِيدت فيه الواوُ والتاء للمبالغةِ).﴿بَعۡدَهُۥ﴾: بعد القرآنِ العظيمِ."
  7,186,"﴿وَيَذَرُهُمۡ﴾: ويَتْرُكُهم.﴿طُغۡيَـٰنِهِمۡ﴾: ضَلالِهم وكُفْرِهم.﴿يَعۡمَهُونَ﴾: يتردَّدُون مُتَحَيِّرين."
  7,187,"﴿مُرۡسَىٰهَا﴾: قيامُها.﴿لَا يُجَلِّيهَا﴾: لا يُظْهِرُها.﴿ثَقُلَتۡ فِي ٱلسَّمَـٰوَ ٰ⁠تِ وَٱلۡأَرۡضِ﴾: ثَقُلَ عِلْمُ قيامِ الساعةِ، وخَفِيَ على أهلِ السمواتِ والأرض.﴿بَغۡتَةࣰ﴾: فجأةً.﴿حَفِيٌّ عَنۡهَا﴾: عالِمٌ بها، مُسْتَقْصٍ بالسؤالِ عنها."
  7,189,"﴿نَّفۡسࣲ وَ ٰ⁠حِدَةࣲ﴾: هي آدمُ عليه السلام.﴿وَجَعَلَ مِنۡهَا﴾: وخَلَقَ منها.﴿زَوۡجَهَا﴾: هي حواءُ.﴿لِيَسۡكُنَ إِلَيۡهَا﴾: ليأنسَ ويطمئِنَّ بها.﴿تَغَشَّىٰهَا﴾: جامَعَها، والمرادُ جنسُ الزوجين مِن ذريةِ آدمَ.﴿فَمَرَّتۡ بِهِۦ﴾: استمرَّ بذلك الحَمْلِ إلى تمامهِ.﴿أَثۡقَلَت﴾: صارت ذات ثِقَلٍ بكِبَرِ الحَمْلِ.﴿صَـٰلِحࣰا﴾: أي: خَلْقًا سَوِيًّا صالحًا."
  7,190,"﴿جَعَلَا﴾: أي: الزوجان من ذريةِ آدمَ.﴿لَهُۥ شُرَكَآءَ﴾: أي: للهِ في ذلك الوَلَدِ، كنَحْوِ تسميتِه: عبدَ العُزّى."
  7,192,"7:191"
  7,193,"7:191"
  7,194,"7:191"
  7,195,"﴿أَلَهُمۡ﴾: ألهذه الآلهة؟﴿يَبۡطِشُونَ﴾: يأخذُون بها، فَيدْفَعُون عنكم.﴿فَلَا تُنظِرُونِ﴾: فلا تُمْهلوني بعد تدبيرِ كَيْدِكم."
  7,196,"﴿وَلِـِّۧيَ﴾: مُتَوَلِّي حِفْظي وجميعِ أموري.﴿ٱلۡكِتَـٰبَ﴾: القرآنَ العظيمَ."
  7,198,"7:197"
  7,199,"﴿خُذِ﴾: اقْبَلْ أنتَ وأمَّتُكَ.﴿ٱلۡعَفۡوَ﴾: ما تيسَّرَ من أخلاقِ الناسِ وأعمالِهم.﴿بِٱلۡعُرۡفِ﴾: هو كلُّ ما عُرِفَ حُسْنُه في الشَّرْعِ والعَقْلِ."
  7,200,"﴿يَنزَغَنَّكَ﴾: يُصِيبَنَّك وسْوَسَةٌ.﴿فَٱسۡتَعِذۡ بِٱللَّهِ﴾: فاستَجِرْ به والَجأْ إليه."
  7,201,"﴿ٱتَّقَوۡاْ﴾: خافُوا اللهَ بفِعْلِ أوامرِه وتَرْكِ نواهِيه.﴿طَـٰٓئِفࣱ مِّنَ ٱلشَّيۡطَـٰنِ﴾: عارضٌ من وسْوَسَتِه.﴿تَذَكَّرُواْ﴾: عقابَ اللهِ وثوابَه.﴿مُّبۡصِرُونَ﴾: مُنْتَهُون عن المعصيةِ على بَصيرةٍ."
  7,202,"﴿وَإِخۡوَ ٰ⁠نُهُمۡ﴾: وإخوانُ الشَّياطين.﴿يَمُدُّونَهُمۡ﴾: يَزيدُونهم.﴿ٱلۡغَيِّ﴾: الضَّلالِ.﴿لَا يُقۡصِرُونَ﴾: لا يَكُفُّون عن الإغواءِ."
  7,203,"﴿بِـَٔايَةࣲ﴾: بعلامةٍ دالَّةٍ على صِدْقِك.﴿ٱجۡتَبَيۡتَهَا﴾: اختلَقْتَها واخترَعْتَها.﴿هَـٰذَا﴾: أي القرآنُ المجيدُ.﴿بَصَآئِرُ﴾: جمعُ بَصيرةٍ، وهي الحُجَجُ والبراهينُ التي يُسْتَبصَرُ بها.﴿وَهُدࣰى﴾: بيانٌ يَهْدي المؤمنين."
  7,205,"﴿تَضَرُّعࣰا﴾: تَذَلُّلًا وخُضوعًا.﴿وَخِيفَةࣰ﴾: خائفًا منه تعالى.﴿وَدُونَ ٱلۡجَهۡرِ﴾: متوسِّطًا بين الَجهْرِ والإسرارِ.﴿بِٱلۡغُدُوِّ﴾: أولِ النهارِ.﴿وَٱلۡـَٔاصَالِ﴾: جمعُ أصيلٍ، وهو من العَصْرِ إلى المغربِ، والمرادُ: آخرُ النهارِ."
  7,206,"﴿وَيُسَبِّحُونَهُۥ﴾: يُنَزِّهُونه عن كلِّ ما لا يليقُ به."
