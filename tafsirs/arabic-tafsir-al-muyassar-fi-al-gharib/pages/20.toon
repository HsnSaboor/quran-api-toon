tafsir[105]{c,v,t}:
  20,2,"﴿لِتَشۡقَىٰٓ﴾: لِتَتْعبَ بفَرْطِ تأسُّفِكَ على كُفْرِهِم."
  20,3,"﴿تَذۡكِرَةࣰ﴾: عِظَةً وعِبْرةً."
  20,5,"﴿ٱلۡعَرۡشِ﴾: هو سَرِيَرُ المُلْكِ الذي اسْتَوى عَلَيه الرحمنُ، وتَحمِلُه الملائِكةُ، وهو أعْظَمُ المخْلُوقاتِ، وهو سَقْفُ الجنَّةِ.﴿ٱسۡتَوَىٰ﴾: عَلا وارْتَفَعَ، اسْتِواءً يلِيقُ بِجَلالِه وعَظَمَتِه."
  20,6,"﴿وَمَا تَحۡتَ ٱلثَّرَىٰ﴾: باطِنِ الأَرْضِ."
  20,8,"20:7"
  20,9,"﴿حَدِيثُ مُوسَىٰٓ﴾: خبرُ مُوسى بن عِمْرانَ عليه الصَّلاةُ والسَّلامُ، لمّا رَجَعَ مِن مَدْيَنَ إلى مِصْرَ."
  20,11,"20:10"
  20,12,"﴿طُوࣰى﴾: اسْمِ الوادِي الُمقَدَّسِ."
  20,14,"﴿لِذِكۡرِيٓ﴾: لِتَذْكُرَني فِيها."
  20,16,"﴿فَلَا يَصُدَّنَّكَ﴾: فلا يَصْرِفَنَّكَ.﴿فَتَرۡدَىٰ﴾: فَتَهْلَكَ."
  20,18,"﴿أَتَوَكَّؤُاْ عَلَيۡهَا﴾: أعْتَمِدُ عَلَيها في المَشْيِ.﴿وَأَهُشُّ بِهَا﴾: وأَهُزُّ بِها الشَّجَرَ لِيَسْقُطَ مِنه الوَرَقُ.﴿مَـَٔارِبُ﴾: حاجاتٌ ومَنافعُ."
  20,20,"20:19"
  20,21,"20:19"
  20,22,"﴿إِلَىٰ جَنَاحِكَ﴾: جَنبِك تَحْتَ العَضُدِ.﴿مِنۡ غَيۡرِ سُوٓءٍ﴾: مِن غَيرِ مَرَضٍ ولا بَرَصٍ."
  20,24,"﴿طَغَىٰ﴾: تَجاوَزَ حَدَّه بالتَّمَرُّدِ على ربِّه."
  20,26,"20:25"
  20,27,"﴿وَٱحۡلُلۡ عُقۡدَةࣰ مِّن لِّسَانِي﴾: وأَطْلِقْ عَنْ لِساني العُقْدَةَ التي فِيه."
  20,29,"﴿وَزِيرࣰا﴾: مُعِينًا في إبْلاغِ رِسالتِكَ."
  20,31,"﴿ٱشۡدُدۡ بِهِۦٓ أَزۡرِي﴾: قَوِّني به وشُدَّ به ظَهْري."
  20,32,"﴿فِيٓ أَمۡرِي﴾: في النُّبوَّةِ وتَبْلِيغِ الرِّسالةِ."
  20,34,"20:33"
  20,35,"20:33"
  20,36,"﴿أُوتِيتَ سُؤۡلَكَ﴾: أُعطِيتَ كلَّ ما سألتَ."
  20,37,"﴿وَلَقَدۡ مَنَنَّا عَلَيۡكَ﴾: ولَقَدْ أنْعَمْنا عَلَيكَ.﴿مَرَّةً أُخۡرَىٰٓ﴾: نِعْمَةً أُخْرى بإنْجائِكَ مِن بَطْشِ فِرْعَونَ وجُنُودِه حِينَ كُنْتَ رَضِيعًا."
  20,38,"﴿أَوۡحَيۡنَآ﴾: ألْهَمْنا."
  20,39,"﴿ٱقۡذِفِيهِ﴾: ضَعِيه.﴿ٱلتَّابُوتِ﴾: الصُّنْدُوقِ الخَشَبِيِّ.﴿فَٱقۡذِفِيهِ فِي ٱلۡيَمِّ﴾: فاطْرَحِيه في النِّيلِ.﴿وَأَلۡقَيۡتُ عَلَيۡكَ مَحَبَّةࣰ مِّنِّي﴾: أي: أحْبَبْتُك، فَصِرْتَ بِذَلكَ مَحْبُوبًا بَيْنَ العِبادِ.﴿وَلِتُصۡنَعَ عَلَىٰ عَيۡنِيٓ﴾: ولِتُرَبّى بِمَرأىً مِنِّي."
  20,40,"﴿كَيۡ تَقَرَّ عَيۡنُهَا﴾: كي تُسَرَّ أُمُّ مُوسى بِسَلامةِ ولَدِها ورُجُوعِه إليها.﴿وَفَتَنَّـٰكَ﴾: وابْتَلَيناك.﴿عَلَىٰ قَدَرࣲ﴾: عَلى مَوْعِدٍ مُوافِقٍ للوقْتِ الُمقدَّرِ في عِلْمِ اللهِ تَعالى."
  20,41,"﴿وَٱصۡطَنَعۡتُكَ لِنَفۡسِي﴾: هَيَّأْتُكَ لِتَبْلِيغِ الرِّسالةِ عَنِّي."
  20,42,"﴿وَلَا تَنِيَا﴾: ولا تَضْعُفا."
  20,43,"﴿طَغَىٰ﴾: جاوَزَ الحَدَّ في الكُفْرِ والظُّلْمِ."
  20,45,"﴿أَن يَفۡرُطَ عَلَيۡنَآ﴾: أن يُعاجِلَنا ويُبادِرَ بالعُقُوبَةِ.﴿أَوۡ أَن يَطۡغَىٰ﴾: أو أن يَتَمَرَّدَ على الحقِّ فلا يَقْبَلَه."
  20,47,"﴿وَلَا تُعَذِّبۡهُمۡ﴾: أي: ولا تُعَذِّبْهم بِذَبْحِ أبْنائِهِم واسْتِحْياءِ بَناتِهِم وتَكْلِيفِهِم بِما لا يُطِيقُونَ مِنَ الأَعْمالِ."
  20,49,"20:48"
  20,50,"﴿خَلۡقَهُۥ﴾: أي: صورتَه اللائِقَةَ بخاصَّتِه ومَنفَعَتِه."
  20,51,"﴿فَمَا بَالُ ٱلۡقُرُونِ ٱلۡأُولَىٰ﴾: فما شأنُ الأممِ السّابِقَةِ؟"
  20,52,"﴿فِي كِتَـٰبࣲ﴾: وهو اللَّوحُ الَمحْفُوظُ.﴿لَّا يَضِلُّ رَبِّي﴾: أي: لا يُخْطِئُ ربِّي في أفْعالِه وأَحْكامِه.﴿وَلَا يَنسَى﴾: أيَّ شيءٍ ممّا عَلِمه مِنها."
  20,53,"﴿مَهۡدࣰا﴾: أي: مُيَسَّرةً للانْتِفاعِ بِها، فَصارَتْ كالفِراشِ والِمْهادِ لكلِّ واحدٍ مِنكُم.﴿وَسَلَكَ لَكُمۡ فِيهَا سُبُلࣰا﴾: وجَعَل لَكُم فِيها طُرُقًا كَثِيرَةً.﴿أَزۡوَ ٰ⁠جࣰا مِّن نَّبَاتࣲ شَتَّىٰ﴾: أنْواعًا مُخْتَلِفَةً مِنَ النَّباتِ."
  20,54,"﴿لِّأُوْلِي ٱلنُّهَىٰ﴾: لِذَوي العُقُولِ السَّلِيمَةِ."
  20,56,"﴿ءَايَـٰتِنَا﴾: أدلَّتَنا وحُجَجَنا.﴿وَأَبَىٰ﴾: وامْتَنَعَ عَن قَبُولِ الحَقِّ."
  20,58,"﴿مَكَانࣰا سُوࣰى﴾: في مَكانٍ مُعْتَدِلٍ مُسْتَوٍ بَيْنَنا وبَيْنَكَ."
  20,59,"﴿يَوۡمُ ٱلزِّينَةِ﴾: يومُ العيدِ حِينَ يتزيَّنُ الناسُ.﴿وَأَن يُحۡشَرَ﴾: وأن يُجْمَعَ."
  20,61,"﴿لَا تَفۡتَرُواْ﴾: لا تَخْتَلِقُوا.﴿فَيُسۡحِتَكُم﴾:. فَيَسْتَأْصِلَكُم ويُبِيدَكُمْ.﴿خَابَ﴾: خَسِرَ وهَلَكَ."
  20,62,"﴿وَأَسَرُّواْ ٱلنَّجۡوَىٰ﴾: تَحادَثَ السَّحَرةُ سِرًّا في خَفاءٍ."
  20,63,"﴿بِطَرِيقَتِكُمُ ٱلۡمُثۡلَىٰ﴾: بِطَرِيقةِ السِّحْرِ العظيمةِ التي أنْتُم عَلَيها."
  20,64,"﴿فَأَجۡمِعُواْ كَيۡدَكُمۡ﴾: فأَحْكِمُوا مَكْرَكُم، ولا تَجْعَلُوهُ مُتَفَرِّقًا.﴿مَنِ ٱسۡتَعۡلَىٰ﴾: مَن عَلا عَلى صاحِبِه فَغَلَبَهُ وقَهَرَهُ."
  20,66,"20:65"
  20,67,"﴿فَأَوۡجَسَ﴾: فَأَضْمَرَ.﴿خِيفَةࣰ﴾: خَوْفًا."
  20,68,"﴿أَنتَ ٱلۡأَعۡلَىٰ﴾: أنتَ الغالِبُ على هَؤلاءِ السَّحَرةِ."
  20,69,"﴿تَلۡقَفۡ﴾: تَبْتَلِعْ بِسُرْعَةٍ.﴿وَلَا يُفۡلِحُ ٱلسَّاحِرُ﴾: ولا يَظْفَرَ السَّحرةُ بِبُغْيتِهِم."
  20,71,"﴿خِلَـٰفࣲ﴾: مُخالِفًا بينها: يدًا مِن جِهَةٍ ورِجْلًا مِنَ الجِهَةِ الأخْرى.﴿وَلَأُصَلِّبَنَّكُمۡ﴾: ولَأُبالِغَنّ في شَدِّ أطْرافِكَم ورَبْطِ أجْسادِكُم.﴿فِي جُذُوعِ ٱلنَّخۡلِ﴾: على جُذُوعِ النَّخْلِ.﴿وَأَبۡقَىٰ﴾: وأَدْوَمُ، لا يَنْقَطِعُ."
  20,72,"﴿لَن نُّؤۡثِرَكَ﴾: لن نُفَضِّلَكَ."
  20,74,"﴿مُجۡرِمࣰا﴾: كافِرًا.﴿لَا يَمُوتُ فِيهَا وَلَا يَحۡيَىٰ﴾: أي: لا يمُوتُ فيها فَيَسْتَرِيحَ، ولا يحيا حياةً يتلذَّذُ بِها."
  20,76,"﴿جَنَّـٰتُ عَدۡنࣲ﴾: جَنّاتُ إقامَةٍ دائمةٍ.﴿مَن تَزَكَّىٰ﴾: مَن تَطهَّرَ مِنَ الكُفْرِ والمَعاصِي."
  20,77,"﴿أَنۡ أَسۡرِ﴾: أنِ اخْرُجْ ليلًا بِعِبادِي.﴿فَٱضۡرِبۡ لَهُمۡ﴾: فاجْعَلْ لهم.﴿يَبَسࣰا﴾: يابسًا لا ماءٌ فِيها ولا طِينٌ.﴿لَّا تَخَـٰفُ دَرَكࣰا﴾: لا تخافُ مِن فِرْعَونَ وجُنُودِهِ أن يَلْحَقَ بكُم فيُدْرِكَكُم.﴿وَلَا تَخۡشَىٰ﴾: ولا تَخْشى مِنَ الغَرَقِ في البَحْرِ."
  20,78,"﴿فَغَشِيَهُم مِّنَ ٱلۡيَمِّ مَا غَشِيَهُمۡ﴾: فَغَمَرَهُم مِن مّاءِ البَحْرِ ما لا يَعْلَمُ كُنهَه إلّا اللهُ."
  20,80,"﴿ٱلۡمَنَّ﴾: شيءٌ يُشْبِهُ الصَّمْغَ، طَعْمُه كالعَسَلِ.﴿وَٱلسَّلۡوَىٰ﴾: طَيرٌ يُشْبِهُ السُّمانى."
  20,81,"﴿وَلَا تَطۡغَوۡاْ فِيهِ﴾: ولا تَحْمِلنَّكُم العافيةُ والسَّعَةُ في الرِّزقِ على تَجاوُزِ الحدِّ في العِصْيانِ.﴿فَيَحِلَّ عَلَيۡكُمۡ﴾: فيَنْزِلَ بِكُم.﴿هَوَىٰ﴾: هَلَكَ وخَسِرَ."
  20,82,"﴿ثُمَّ ٱهۡتَدَىٰ﴾: ثُمَّ التَزَمَ الهِدايةَ واسْتَقامَ عَلَيها."
  20,84,"﴿عَلَىٰٓ أَثَرِي﴾: خَلْفي سَوفَ يَلْحَقُون بِي.﴿لِتَرۡضَىٰ﴾: لِتَزْدادَ عَنِّي رِضًا."
  20,85,"﴿قَدۡ فَتَنَّا﴾: قد ابتلينا.﴿وَأَضَلَّهُمُ﴾: دَعاهُم إلى الضَّلالَةِ التي هِيَ عِبادةُ العِجْلِ.﴿ٱلسَّامِرِيُّ﴾: مَنسُوبٌ إلى «قبيلةِ السّامِرَة» قيل: كان إسْرائِيليًا، وقيل: كانَ قِبْطيًا."
  20,86,"﴿أَسِفࣰا﴾: حَزِينًا كَئِيبًا.﴿وَعۡدًا حَسَنًا﴾: أي: بإنزالِ التَّوراةِ.﴿ٱلۡعَهۡدُ﴾: الزَّمانُ.﴿فَأَخۡلَفۡتُم مَّوۡعِدِي﴾: خالفْتُم ما وعَدْتُّمُونِي مِن عِبادَةِ اللهِ وحْدَه."
  20,87,"﴿بِمَلۡكِنَا﴾: باخْتِيارِنا.﴿أَوۡزَارࣰا﴾: أثْقالًا.﴿مِّن زِينَةِ ٱلۡقَوۡمِ﴾: مِن حُلِيِّ قومِ فِرْعَونَ.﴿فَقَذَفۡنَـٰهَا﴾: فَأَلْقَينا الحُلِيَّ في النّارِ.﴿فَكَذَ ٰ⁠لِكَ أَلۡقَى ٱلسَّامِرِيُّ﴾: أي: فَكَذَلِك ألْقى السّامِريُّ ما كان مَعَهُ مِن تُرْبَةِ حافِرِ فَرَسِ جِبْريلَ عليه السَّلامُ."
  20,88,"﴿عِجۡلࣰا جَسَدࣰا﴾: مَعْبُودًا مِن ذَهَبِهِم على صُورَةِ العِجْلِ بلا رُوحٍ.﴿لَّهُۥ خُوَارࣱ﴾: له صَوْتٌ يُشْبِهُ صوتَ البَقَرِ.﴿فَنَسِيَ﴾: فَغَفَلَ عنه مُوسى نِسْيانًا."
  20,89,"﴿أَلَّا يَرۡجِعُ إِلَيۡهِمۡ قَوۡلࣰا﴾: لا يُكَلِّمُهم ولا يَرُدُّ عَلِيهِم جَوابًا."
  20,90,"﴿فُتِنتُم بِهِۦ﴾: بِهَذا العِجْلِ."
  20,91,"﴿لَن نَّبۡرَحَ عَلَيۡهِ عَـٰكِفِينَ﴾: لَن نَزالَ مُقيمِينَ على عِبادَةِ العِجْل."
  20,93,"20:92"
  20,94,"﴿وَلَمۡ تَرۡقُبۡ قَوۡلِي﴾: ولَمْ تَعْمَلْ بوَصِيَّتِي لَكَ فِيهِم."
  20,95,"﴿فَمَا خَطۡبُكَ﴾: أي: ما الَّذِي حَمَلَكَ على ما صَنَعْتَ؟"
  20,96,"﴿فَقَبَضۡتُ قَبۡضَةࣰ﴾: فَأَخَذْتُ بِكَفِّي تُرابًا.﴿مِّنۡ أَثَرِ ٱلرَّسُولِ﴾: مِن أثَرِ حافِرِ فرسِ جِبْرِيلَ عليهِ السلامُ.﴿فَنَبَذۡتُهَا﴾: فألقيتُ حَفْنَةَ التُّرابِ على الحُليِّ التي صُنِعَ منها العِجلُ.﴿سَوَّلَتۡ لِي نَفۡسِي﴾: زَيَّنَتْ لي نَفْسِي ما صَنَعْتُ."
  20,97,"﴿لَا مِسَاسَ﴾: أي لا يَمَسَّكَ أحدٌ، ولا تَمَسَّ أحدًا في الدُّنيا، فَتَعِيشَ مَنبُوذًا.﴿لَكَ مَوۡعِدࣰا﴾: أي: في الآخرةِ لِعِقابِك.﴿لَّن تُخۡلَفَهُۥ﴾: لَن يُخْلِفَكَ اللهُ إيّاهُ.﴿ظَلۡتَ عَلَيۡهِ عَاكِفࣰا﴾: أقمتَ مواظِبًا على عبادتِه.﴿ثُمَّ لَنَنسِفَنَّهُۥ﴾: ثم لنَذْرُوَنَّه حَتّى لا يَبْقى منه أثَرٌ.﴿ٱلۡيَمِّ﴾: البَحرِ."
  20,99,"﴿ذِكۡرࣰا﴾: القرآنَ؛ لِما فيه مِنَ التَّذْكِيرِ."
  20,100,"﴿وِزۡرًا﴾: إثمًا عَظِيمًا."
  20,102,"﴿ٱلصُّورِ﴾: القَرْنِ الذي يُنفَخُ فيه للبعثِ.﴿وَنَحۡشُرُ﴾: نَسُوقُ.﴿زُرۡقࣰا﴾: زُرْقَ العُيونِ والأجْسادِ من هَوْلِ المصيبة."
  20,103,"﴿يَتَخَـٰفَتُونَ بَيۡنَهُمۡ﴾: يَتَسارُّونَ فِيما بَيْنَهم."
  20,104,"﴿أَمۡثَلُهُمۡ طَرِيقَةً﴾: أعْلَمُهم وأَكْمَلُهم رأيًا."
  20,105,"﴿يَنسِفُهَا رَبِّي نَسۡفࣰا﴾: يَقْلعُها رَبي مِن أُصُولِها فَتَتَطايرُ كالصُّوفِ المنفُوشِ."
  20,106,"﴿فَيَذَرُهَا﴾: فَيَتْرُكُ الأرضَ.﴿قَاعࣰا﴾: أرْضًا لا نَباتٌ فيها ولا بناءٌ.﴿صَفۡصَفࣰا﴾: مَلْساءَ مُسْتَوِيَةً."
  20,107,"﴿عِوَجࣰا﴾: مَيْلًا.﴿وَلَآ أَمۡتࣰا﴾: ولا ارْتفِاعًا ولا انْخِفاضًا."
  20,108,"﴿لَا عِوَجَ﴾: لا مَحِيدَ لهم من اتِّباعِ داعِي اللهِ إلى المَحْشَرِ.﴿هَمۡسࣰا﴾: صَوْتًا خَفِيًّا."
  20,110,"﴿مَا بَيۡنَ أَيۡدِيهِمۡ﴾: أي: مِن أمْرِ القِيامةِ.﴿وَمَا خَلۡفَهُمۡ﴾: أي: مِن أمْرِ الدُّنْيا."
  20,111,"﴿وَعَنَتِ﴾: ذلَّتْ وخَضَعَتْ.﴿ٱلۡقَيُّومِ﴾: الدّائِمِ القَيّامِ بِتَدْبِيرِ الخَلْقِ وحِفْظِهِم.﴿خَابَ﴾: خَسِرَ وهَلَكَ.﴿ظُلۡمࣰا﴾: شِرْكًا باللهِ."
  20,112,"﴿ظُلۡمࣰا وَلَا هَضۡمࣰا﴾: ظُلْمًا بِزيادةِ سَيِّئاتِه في الآخِرةِ، ولا هَضْمًا بِنَقْصِ حَسَناتِه فيها."
  20,113,"﴿أَوۡ يُحۡدِثُ لَهُمۡ ذِكۡرࣰا﴾: أي: يُحدِثُ فِيهم هذا القرآنُ تَذَكُّرًا واعْتِبارًا."
  20,114,"﴿وَلَا تَعۡجَلۡ بِٱلۡقُرۡءَانِ﴾: لا تُسارِعْ بِقِراءتِه.﴿مِن قَبۡلِ أَن يُقۡضَىٰٓ إِلَيۡكَ وَحۡيُهُۥ﴾: من قَبْلِ أن يَفرغَ جبريلُ ويُتِمَّ إليك الوحيَ."
  20,115,"﴿عَهِدۡنَآ إِلَىٰٓ ءَادَمَ﴾: وصَّيناهُ، أو أوحينا إليه.﴿عَزۡمࣰا﴾: قوَّةً في الإرادةِ يَحْفَظُ بها ما أُمِرَ به."
  20,116,"﴿أَبَىٰ﴾: امْتَنَعَ مِنَ السُّجُودِ اسْتِكْبارًا."
  20,117,"﴿فَتَشۡقَىٰٓ﴾: فتعانيَ المتاعِبَ والمشاقَّ في الدُّنيا."
  20,118,"﴿أَلَّا تَجُوعَ فِيهَا﴾: أي: لا يُصِيبَكَ في الجنَّةِ جُوعٌ.﴿وَلَا تَعۡرَىٰ﴾: أي: لا تَعْرى فيها عن الملابِسِ."
  20,119,"﴿لَا تَظۡمَؤُاْ فِيهَا﴾: لا يُصِيبُكَ في الجنَّةِ عَطَشٌ.﴿وَلَا تَضۡحَىٰ﴾: ولا يُصيبُك حرُّ شَمْسٍ."
  20,120,"﴿شَجَرَةِ ٱلۡخُلۡدِ﴾: هي الشجرةُ التي مَن أكَلَ مِنها لم يَمُتْ.﴿لَّا يَبۡلَىٰ﴾: لا يَنْقَطِعُ."
  20,121,"﴿فَبَدَتۡ لَهُمَا سَوۡءَ ٰ⁠ تُهُمَا﴾: فانْكَشَفَتْ لِآدَمَ وحَوّاءَ عَوْراتُهما.﴿وَطَفِقَا يَخۡصِفَانِ﴾: وجَعلا يَلْصَقان.﴿فَغَوَىٰ﴾: فَضَلَّ طَريقَ الصَّوابِ."
  20,122,"﴿ٱجۡتَبَـٰهُ﴾: اصْطَفاه."
  20,123,"﴿ٱهۡبِطَا﴾: انْزِلا مِنَ الجَنَّةِ إلى الأرضِ.﴿فَلَا يَضِلُّ﴾: أي: عَن طَرِيقِ الهِدايةِ.﴿وَلَا يَشۡقَىٰ﴾: لا يَشْقى في الآخرةِ بعِقابِ اللهِ."
  20,124,"﴿ذِكۡرِي﴾: أي: عَن ذِكْرِي الَّذِي أُذَكِّرهُ بِهِ مِن قُرآنٍ وغَيْرِهِ.﴿ضَنكࣰا﴾: ضَيِّقةً شاقَّةً في حَياتِه وقَبْرِه."
  20,126,"﴿فَنَسِيتَهَا﴾: أي: بِتَرْكِ الإيمانِ بها.﴿تُنسَىٰ﴾: تُتْرَكُ في النّارِ."
  20,127,"﴿مَنۡ أَسۡرَفَ﴾: تَجاوَزَ حدودَ ما شَرَعَ اللهُ.﴿وَأَبۡقَىٰٓ﴾: أدْوَمُ مِن عذابِ الدُّنيا، فلا يَنْقَطِعُ."
  20,128,"﴿يَهۡدِ لَهُمۡ﴾: أي: يَدُلَّهم على طَريقِ الرَّشادِ.﴿مِّنَ ٱلۡقُرُونِ﴾: مِنَ الأُمَمِ الماضيةِ.﴿لَـَٔايَـٰتࣲ﴾: لَعِبَرًا وعِظاتٍ.﴿لِّأُوْلِي ٱلنُّهَىٰ﴾: لأصْحابِ العقولِ السَّلِيمةِ."
  20,129,"﴿لَكَانَ لِزَامࣰا﴾: لَلازَمَهم الهَلاكُ عاجِلًا؛ بسببِ كُفْرِهم."
  20,130,"﴿ءَانَآيِٕ ٱلَّيۡلِ﴾: ساعاتِ الليلِ.﴿تَرۡضَىٰ﴾: أي: تُثابُ على عَمَلِك بما يُرضِيكَ."
  20,131,"﴿وَلَا تَمُدَّنَّ عَيۡنَيۡكَ﴾: لا تُكَرِّرِ النَّظَرَ إلى المُشْرِكِينَ مُسْتَحْسِنًا.﴿أَزۡوَ ٰ⁠جࣰا مِّنۡهُمۡ﴾: أصْنافًا مِن الكفّارِ.﴿زَهۡرَةَ ٱلۡحَيَوٰةِ﴾: زينتَها وبَهْجَتَها التي لا تَدُومُ.﴿لِنَفۡتِنَهُمۡ﴾: لِنَبْتليَهم."
  20,132,"﴿وَٱصۡطَبِرۡ عَلَيۡهَا﴾: داوِمْ على إقامةِ الصَّلاةِ بِصَبْرٍ."
  20,133,"﴿بِـَٔايَةࣲ﴾: بِمُعْجِزَةٍ.﴿بَيِّنَةُ مَا فِي ٱلصُّحُفِ ٱلۡأُولَىٰ﴾: أي: هذا القرآنُ مصدِّقٌ لما في الكُتُبِ السّابِقَةِ مِنَ الحقِّ."
  20,134,"﴿مِّن قَبۡلِهِۦ﴾: أي: من قبْلِ أن نُرسِلَ إليهم رَسُولًا.﴿أَن نَّذِلَّ وَنَخۡزَىٰ﴾: أن يُصيَبنا ذُلٌّ وخِزيٌ بعذابِكَ في الدُّنيا والآخِرةِ."
  20,135,"﴿كُلࣱّ مُّتَرَبِّصࣱ﴾: كلٌّ مِنّا ومِنكُم منتظِرٌ دوائرَ الزمانِ.﴿فَتَرَبَّصُواْ﴾: فانْتَظِرُوا."
