tafsir[28]{c,v,t}:
  67,1,"﴿تَبَـٰرَكَ ٱلَّذِي﴾: تَكاثَرَ خَيرُ اللهِ وبِرُّهُ عَلى جَمِيعِ خَلْقِهِ.﴿بِيَدِهِ ٱلۡمُلۡكُ﴾: التَّصَرُّفُ في مُلْكِ الدُّنيا والآخِرَةِ."
  67,2,"﴿لِيَبۡلُوَكُمۡ﴾: لِيَخْتَبِرَكُم."
  67,3,"﴿طِبَاقࣰا﴾: مُتَناسِقَةً.﴿تَفَـٰوُتࣲ﴾: اخْتِلافٍ وتَبايُنٍ.﴿فَٱرۡجِعِ ٱلۡبَصَرَ﴾: فَأَعِدِ النَّظَرَ.﴿فُطُورࣲ﴾: شُقُوقٍ أو صُدُوعٍ."
  67,4,"﴿كَرَّتَيۡنِ﴾: مَرَّةً بَعْدَ مَرَّةٍ.﴿يَنقَلِبۡ﴾: يَرْجِعْ.﴿خَاسِئࣰا﴾: ذَلِيلًا صاغِرًا.﴿حَسِيرࣱ﴾: مُتْعَبٌ كَلِيلٌ."
  67,5,"﴿ٱلدُّنۡيَا﴾: القَرِيبةَ.﴿بِمَصَـٰبِيحَ﴾: بِنُجُومٍ عَظِيمَةٍ مُضِيئةٍ.﴿رُجُومࣰا﴾: شُهُبًا مُحْرِقَةً.﴿لِّلشَّيَـٰطِينِ﴾: لِمُسْتَرِقِي السَّمْعِ مِنَ الشَّياطِينِ.﴿ٱلسَّعِيرِ﴾: النّارِ المُوقَدَةِ."
  67,6,"﴿وَبِئۡسَ ٱلۡمَصِيرُ﴾: وساءَ المَرْجِعُ لهم جَهَنَّمُ."
  67,7,"﴿أُلۡقُواْ﴾: طُرِحُوا.﴿شَهِيقࣰا﴾: صَوْتًا شَدِيدًا مُنْكَرًا.﴿تَفُورُ﴾: تَغْلِي غَلَيانًا شَدِيدًا."
  67,8,"﴿تَمَيَّزُ﴾: تَتَمَزَّقُ.﴿مِنَ ٱلۡغَيۡظِ﴾: مِن شِدَّةِ غَضَبِها عَلى الكُفّارِ.﴿أُلۡقِيَ﴾: طُرِحِ.﴿فَوۡجࣱ﴾: جَماعةٌ مِنَ النّاسِ.﴿خَزَنَتُهَآ﴾: الملائِكةُ المُوكَّلُونَ بأَمْرِها.﴿نَذِيرࣱ﴾: رَسُولٌ يُحَذِّرُكُم مِن هَذا العَذابِ."
  67,10,"﴿نَسۡمَعُ﴾: سَماعَ مَن يَطْلُبُ الحقَّ.﴿نَعۡقِلُ﴾: نُفَكِّرُ فِيما نُدْعى إلَيهِ.﴿ٱلسَّعِيرِ﴾: النّارِ المُوقَدَةِ."
  67,11,"﴿فَسُحۡقࣰا﴾: فَبُعْدًا عَن رَّحَمَةِ اللهِ."
  67,12,"﴿بِٱلۡغَيۡبِ﴾: وهُمْ غائِبُونَ عَنْ أعْيُنِ النّاسِ، وقَبْلَ مُعايَنَةِ العَذابِ.﴿وَأَجۡرࣱ﴾: ثَوابٌ."
  67,13,"﴿أَسِرُّواْ﴾: وأَخْفُوا.﴿أَوِ ٱجۡهَرُواْ بِهِۦٓ﴾: أعْلِنُوهُ.﴿بِذَاتِ ٱلصُّدُورِ﴾: بِما يَتَرَدَّدُ في النَّفْسِ مِنَ الخواطِرِ والنِّياتِ."
  67,14,"﴿يَعۡلَمُ﴾: اللهُ.﴿مَنۡ خَلَقَ﴾: المخلُوقِينَ.﴿ٱللَّطِيفُ﴾: العالِمُ خَبايا الأُمُورِ والمُدَبِّرُ لَها بِرِفْقٍ وحِكْمَةٍ.﴿ٱلۡخَبِيرُ﴾: العَلِيمُ بِباطِنِ أمرِهِم."
  67,15,"﴿ذَلُولࣰا﴾: سَهْلةً مُمَهَّدَةً تَسْتَقِرُّونَ عَلَيها.﴿مَنَاكِبِهَا﴾: نواحِيها وجَوانِبِها.﴿ٱلنُّشُورُ﴾: البَعْثُ مِن قُبُورِكُم لِلْحِسابِ."
  67,16,"﴿ءَأَمِنتُم﴾: هَلْ أمِنتُم؟﴿مَّن فِي ٱلسَّمَآءِ﴾: الَّذِي فَوقَ السَّماءِ.﴿يَخۡسِفَ بِكُمُ ٱلۡأَرۡضَ﴾: يَقْلِبَ ظاهِرَ الأرضِ باطِنًا، وباطِنَها ظاهِرًا مُصاحِبةً لِذَواتِكم.﴿تَمُورُ﴾: تَضْطَرِبُ بِكُم حَتّى تَهْلِكُوا."
  67,17,"﴿حَاصِبࣰا﴾: رِيحًا تَرْجُمُكُم بالحِجارةِ الصَّغِيرةِ.﴿نَذِيرِ﴾: تَحْذِيرِي لَكُم."
  67,18,"﴿نَكِيرِ﴾: إنْكارِي عَلَيهِم بإنْزِالِ العَذابِ بِهِم."
  67,19,"﴿صَـٰٓفَّـٰتࣲ﴾: باسِطاتٍ أجْنِحَتَها عِنْدَ طَيَرانِها في الهواءِ.﴿وَيَقۡبِضۡنَ﴾: ويَضْمُمْنَ أجْنِحَتَها."
  67,20,"﴿أَمَّنۡ هَـٰذَا﴾: بَلْ مَن هَذا.﴿جُندࣱ لَّكُمۡ﴾: حِزْبٌ لَكُم.﴿مِّن دُونِ ٱلرَّحۡمَـٰنِ﴾: مِن غَيْرِ الرَّحمنِ.﴿إِنِ﴾: ما.﴿غُرُورٍ﴾: خِداعٍ وضَلالٍ مِنَ الشَّيطانِ."
  67,21,"﴿لَّجُّواْ﴾: اسْتَمَرُّوا في طُغْيانِهِم وكُفْرِهِم.﴿عُتُوࣲّ﴾: مُعانَدَةٍ واسْتِكْبارٍ﴿وَنُفُورٍ﴾: فِرارٍ مِنَ الحقِّ."
  67,22,"﴿مُكِبًّا﴾: ساقِطًا عَلى وجْهِهِ.﴿أَهۡدَىٰٓ﴾: أشَدُّ اسْتِقامةً عَلى الطَّرِيقةِ.﴿سَوِيًّا﴾: مُسْتَوِيًا."
  67,23,"﴿أَنشَأَكُمۡ﴾: أوْجَدَكُم مِن العَدَمِ.﴿وَٱلۡأَفۡـِٔدَةَ﴾: القُلُوبَ."
  67,24,"﴿ذَرَأَكُمۡ﴾: خَلَقَكُم ونَشَرَكُم.﴿تُحۡشَرُونَ﴾: تُجْمَعُونَ لِلْحِسابِ والجَزاءِ."
  67,26,"﴿نَذِيرࣱ﴾: مُخَوِّفٌ.﴿مُّبِينࣱ﴾: أُبَيِّنُ لَكُمُ الشَّرائِعَ."
  67,27,"﴿زُلۡفَةࣰ﴾: قَرِيبًا مِنهُم.﴿سِيٓـَٔتۡ﴾: ظَهَرَتْ الذِّلَّةُ والكآبةُ.﴿بِهِۦ تَدَّعُونَ﴾: تَطْلُبُونَ تَعْجِيلَه في الدُّنيا."
  67,28,"﴿أَرَءَيۡتُمۡ﴾: أخْبِرُوني.﴿أَهۡلَكَنِيَ﴾: أماتَنِي.﴿يُجِيرُ﴾: يَحْمِي ويَمْنَعُ."
  67,29,"﴿ءَامَنَّا بِهِۦ﴾: صَدَّقْنا بِهِ وعَمِلْنا بِشَرْعِهِ.﴿تَوَكَّلۡنَا﴾: اعْتَمَدْنا في كُلِّ أُمُورِنا.﴿ضَلَـٰلࣲ﴾: بُعْدٍ عَن صِراطِ اللهِ المُسْتَقِيمِ."
  67,30,"﴿أَرَءَيۡتُمۡ﴾: أخْبِرُونِي.﴿أَصۡبَحَ﴾: صارَ.﴿غَوۡرࣰا﴾: ذاهِبًا في الأرضِ لا تصِلُونَ إلَيهِ.﴿مَّعِينِۭ﴾: جارٍ على وجْهِ الأَرْضِ تَراهُ العُيُونُ."
