tafsir[149]{c,v,t}:
  6,1,"﴿وَجَعَلَ ٱلظُّلُمَـٰتِ وَٱلنُّورَ﴾: وخَلَقَ سَوادَ الليلِ، وضياءَ النهارِ.﴿يَعۡدِلُونَ﴾: يُشْرِكُون."
  6,2,"﴿خَلَقَكُم﴾: خَلَقَ أباكم آدمَ.﴿قَضَىٰٓ أَجَلࣰا﴾: قَدَّر مُدَّةَ بقائِكم في الدنيا.﴿وَأَجَلࣱ مُّسَمًّى عِندَهُۥ﴾: وقَدَّر أجلًا محدَّدًا هو يومُ القِيامةِ.﴿تَمۡتَرُونَ﴾: تَشُكُّون في أمرِ الساعةِ."
  6,3,"﴿سِرَّكُمۡ وَجَهۡرَكُمۡ﴾: ما تُخْفُونه، وما تُعْلِنُونه.﴿مَا تَكۡسِبُونَ﴾: جميعَ أعمالِكم."
  6,4,"﴿مِّنۡ ءَايَةࣲ﴾: من دليلٍ على أنّ اللهَ حقُّ."
  6,5,"﴿أَنۢبَـٰٓؤُاْ مَا كَانُواْ بِهِۦ يَسۡتَهۡزِءُونَ﴾: أخبارُ ما استَهْزَؤُوا به، وهو القرآنُ، أو محمدٌ ﷺ."
  6,6,"﴿مِّن قَرۡنࣲ﴾: من أمةٍ مُكَذِّبَةٍ.﴿مَا لَمۡ نُمَكِّن لَّكُمۡ﴾: ما لم نُعْطِكم، كطُولِ الأعمارِ، وقوةِ الأبدانِ.﴿مِّدۡرَارࣰا﴾: مطرًا كثيرًا.﴿قَرۡنًا ءَاخَرِينَ﴾: أممًا أخرى."
  6,7,"﴿كِتَـٰبࣰا فِي قِرۡطَاسࣲ﴾: كتابًا مكتوبًا في صحيفةٍ."
  6,8,"﴿مَلَكࣰا﴾: أي: لِيُصَدِّقَه، ويُنْذِرَ معه.﴿لَّقُضِيَ ٱلۡأَمۡرُ﴾: بإهلاكِهم، والمعاجَلَةِ بعقوبتِهم.﴿لَا يُنظَرُونَ﴾: لا يُمْهَلُون للتوبةِ."
  6,9,"﴿وَلَوۡ جَعَلۡنَـٰهُ﴾: ولو جَعَلْنا الرسولَ المُرْسَلَ إلى النبيِّ ﷺ.﴿وَلَلَبَسۡنَا عَلَيۡهِم مَّا يَلۡبِسُونَ﴾: ولَكان الأمرُ مختلِطًا عليهم بسببِ ما لَبَسُوه على أنفسِهم."
  6,10,"﴿فَحَاقَ﴾: فَنَزَل وأحاطَ.﴿مَّا كَانُواْ بِهِۦ يَسۡتَهۡزِءُونَ﴾: هو العذابُ الذي كانوا يستنكرونه."
  6,12,"6:11"
  6,13,"﴿مَا سَكَنَ﴾: ما استقرَّ."
  6,14,"﴿وَلِيࣰّا﴾: مَعْبُودًا.﴿فَاطِرِ﴾: خالقِ.﴿أَسۡلَمَ﴾: انقادَ، واستسلمَ"
  6,16,"﴿مَّن يُصۡرَفۡ عَنۡهُ﴾: أي: العذابُ."
  6,18,"﴿ٱلۡقَاهِرُ﴾: الغالِبُ."
  6,19,"﴿وَمَنۢ بَلَغَ﴾: كلَّ مَن بَلَغَه."
  6,21,"6:20"
  6,22,"﴿أَيۡنَ شُرَكَآؤُكُمُ﴾: أين آلهتُكم لينفعُوكُم؟"
  6,23,"﴿فِتۡنَتُهُمۡ﴾: جوابُهم حين يُخْتَبَرُون بهذا السؤالِ."
  6,24,"﴿وَضَلَّ عَنۡهُم﴾: وغابَ عنهم.﴿مَّا كَانُواْ يَفۡتَرُونَ﴾: ما كانوا يعتقدونه مِن نَفْعِ آلهتِهم له."
  6,25,"﴿أَكِنَّةً﴾: أغْطِيةً فلا تفقهُ القرآنَ فِقْهَ انتفاعٍ به.﴿وَقۡرࣰا﴾: ثِقَلًا، وصَمَمًا.﴿يُجَـٰدِلُونَكَ﴾: يُخاصِمُونك.﴿أَسَـٰطِيرُ﴾: ما سَطَّرُوه من الأباطيلِ."
  6,26,"﴿يَنۡهَوۡنَ عَنۡهُ﴾: يَنْهَون الناسَ عن اتِّباع محمدٍ ﷺ.﴿وَيَنۡـَٔوۡنَ عَنۡهُ﴾: ويَبْتَعِدُون عنه."
  6,27,"﴿وُقِفُواْ﴾: حُبِسُوا.﴿نُرَدُّ﴾: إلى الدُّنيا."
  6,28,"﴿بَدَا﴾: ظَهَرَ.﴿مَّا كَانُواْ يُخۡفُونَ﴾: أي: عن أتْباعهِم من أمْرِ البعثِ، وصِدْقِ الرُّسُلِ.﴿لَكَـٰذِبُونَ﴾: في أنهم لو عادُوا إلى الدنيا لآمَنوا."
  6,29,"﴿بِمَبۡعُوثِينَ﴾: بعد الموتِ."
  6,30,"﴿وُقِفُواْ﴾: حُبِسوا.﴿هَـٰذَا﴾: أي: البعثُ الذي كنتم تُنْكِرونه."
  6,31,"﴿ٱلسَّاعَةُ﴾: يومُ القيامةِ.﴿عَلَىٰ مَا فَرَّطۡنَا فِيهَا﴾: على ما قَدَّمْناه في حياتِنا الدُّنيا.﴿أَوۡزَارَهُمۡ﴾: ذنوبَهم.﴿يَزِرُونَ﴾: يَحْمِلون."
  6,33,"﴿لَا يُكَذِّبُونَكَ﴾: في قَرارةِ أنفسِهم، بل يعتقدون صِدْقَك."
  6,34,"﴿لِكَلِمَـٰتِ ٱللَّهِ﴾: لِآياتِه التي وعَدَ فيها النبيَّ ﷺ بالنصرِ."
  6,35,"﴿نَفَقࣰا﴾: مَنفَذًا، وسَرَبًا.﴿سُلَّمࣰا﴾: دَرَجًا تَرْتقي عليه.﴿فَتَأۡتِيَهُم بِـَٔايَةࣲ﴾: بغيرِما جِئْنا به."
  6,36,"﴿يَسۡمَعُونَ﴾: سَماعَ تَفَهُّمٍ لِما تَقْتَضيه العقولُ.﴿وَٱلۡمَوۡتَىٰ﴾: هم الكفارُ."
  6,37,"﴿لَوۡلَا﴾: هَلّا.﴿ءَايَةࣱ﴾: علامةٌ تَدُلُّ على صِدْقِه، وتَضْطَرُّهُمْ إلى الإيمانِ.﴿لَا يَعۡلَمُونَ﴾: أي: إنّ الإنزالَ يكونُ وفْقَ حِكْمَتِه تعالى."
  6,38,"﴿أُمَمٌ﴾: جماعاتٌ متجانِسَةٌ في الخَلْقِ والرِّزقِ.﴿مَّا فَرَّطۡنَا﴾: ما أغفَلْنا.﴿ٱلۡكِتَـٰبِ﴾: اللوحِ المحفوظِ."
  6,39,"﴿صُمࣱّ﴾: لا يَسْمَعُون ما ينفَعُهم.﴿وَبُكۡمࣱ﴾: لا يتكلَّمُون بالحقِّ.﴿فِي ٱلظُّلُمَـٰتِ﴾: في ظلماتِ الكفرِ، والحَيْرةِ.﴿صِرَ ٰ⁠طࣲ﴾: طريقٍ."
  6,40,"﴿أَرَءَيۡتَكُمۡ﴾: أخْبرُوني.﴿عَذَابُ ٱللَّهِ﴾: في الدُّنيا.﴿إِن كُنتُمۡ صَـٰدِقِينَ﴾: أي: في أنّ آلهتَكُم تنفَعُ، أو تضرُّ."
  6,41,"﴿وَتَنسَوۡنَ مَا تُشۡرِكُونَ﴾: وتَتْرُكون آلهتَكم."
  6,42,"﴿بِٱلۡبَأۡسَآءِ﴾: في الأموالِ.﴿وَٱلضَّرَّآءِ﴾: في الأبدانِ.﴿يَتَضَرَّعُونَ﴾: يَتَذَلَّلُون لربِّهم."
  6,43,"﴿فَلَوۡلَآ﴾: فَهَلّا.﴿بَأۡسُنَا﴾: بَلاؤُنا."
  6,44,"﴿أَبۡوَ ٰ⁠بَ كُلِّ شَيۡءٍ﴾: من الخيرِ كالرزقِ والعافيةِ، استدراجًا منّا.﴿بَغۡتَةࣰ﴾: فَجأة.﴿مُّبۡلِسُونَ﴾: يائِسون من كلِّ خيرٍ."
  6,45,"﴿فَقُطِعَ دَابِرُ ٱلۡقَوۡمِ﴾: فاسْتُؤصِلُوا جميعًا."
  6,46,"﴿وَخَتَمَ عَلَىٰ قُلُوبِكُم﴾: وطَبَعَ عليها.﴿بِهِ﴾: بذلك المأخوذِ منكم.﴿نُصَرِّفُ ٱلۡـَٔايَـٰتِ﴾: نَجِيءُ بالحُجَجِ على وجوهٍ متعددةٍ.﴿يَصۡدِفُونَ﴾: يُعْرِضُون."
  6,47,"﴿بَغۡتَةً﴾: من غيرِ مُقَدِّماتٍ.﴿جَهۡرَةً﴾: بعد مُقَدِّماتٍ تَدُلُّ عليه."
  6,49,"﴿يَفۡسُقُونَ﴾: يَخْرُجُون عن طاعةِ اللهِ."
  6,50,"﴿وَلَآ أَعۡلَمُ ٱلۡغَيۡبَ﴾: أي: فأُخْبِرَكم بما سيكونُ مستقبلًا.﴿ٱلۡأَعۡمَىٰ وَٱلۡبَصِيرُ﴾: الضالُّ والمهتدي."
  6,51,"﴿وَأَنذِرۡ بِهِ﴾: وأعْلِمْ، وخَوِّفْ -أيها الرسولُ- بالقرآنِ.﴿وَلِيࣱّ﴾: ناصرٌ يَنْصُرُهم.﴿وَلَا شَفِيعࣱ﴾: يَشْفَعُ لهم من دونِ اللهِ."
  6,52,"﴿وَلَا تَطۡرُدِ ٱلَّذِينَ﴾: ولا تُبْعِدْ عن مَجالسِك الضُّعفاءَ؛ موافَقَةً لمن طَلَبَ منك.﴿بِٱلۡغَدَوٰةِ وَٱلۡعَشِيِّ﴾: أولِ النهار، وآخرِه."
  6,53,"﴿فَتَنَّا﴾: ابتَلَيْنا عبادَنا باختلافِ حظوظِهم في الرِّزْقِ والُخلُقِ، اختبارًا منا.﴿لِّيَقُولُوٓاْ﴾: ليقولَ الكافرون الأغنياءُ.﴿أَهَـٰٓؤُلَآءِ﴾: الضعفاءُ من المسلمين.﴿مَنَّ ٱللَّهُ عَلَيۡهِم﴾: أي: بالهدايةِ دونَنا."
  6,54,"﴿ٱلَّذِينَ يُؤۡمِنُونَ﴾: يُصَدِّقُون.﴿بِجَهَـٰلَةࣲ﴾: أي: منه لعاقبتِها."
  6,55,"﴿وَلِتَسۡتَبِينَ سَبِيلُ﴾: ولتظهَرَ طريقُ."
  6,57,"﴿بَيِّنَةࣲ﴾: بَصيرةٍ، ويقينٍ.﴿وَكَذَّبۡتُم بِهِۦ﴾: بالحقِّ الذي جاءني من الله.﴿مَا تَسۡتَعۡجِلُونَ بِهِۦٓ﴾: من العذابِ.﴿ٱلۡفَـٰصِلِينَ﴾: بين الحقِّ والباطلِ."
  6,59,"﴿مَفَاتِحُ ٱلۡغَيۡبِ﴾: خزائنُ الغيبِ تُخَزَّنُ فيها، كعِلْمِ الساعةِ وعِلْمِ ما يَسْتَعْجِلُه الكفّارُ من العذابِ.﴿كِتَـٰبࣲ مُّبِينࣲ﴾: هو اللَّوحُ المحفوظُ الذي لا لَبْسَ فيه."
  6,60,"﴿يَتَوَفَّىٰكُم﴾: في أثناءِ نومِكم، فيَقْبِضُ نفوسَكم التي بها تُمَيِّزُون.﴿جَرَحۡتُم﴾: كسَبْتُم بجَوارِ حِكم من الخيرِ والشرِّ.﴿يَبۡعَثُكُمۡ﴾: باليقظةِ من النومِ.﴿فِيهِ﴾: في النهارِ.﴿لِيُقۡضَىٰٓ أَجَلࣱ مُّسَمࣰّى﴾: لتُقْضى آجالُكم المحدَّدةُ في الدنيا."
  6,61,"﴿حَفَظَةً﴾: ملائكةً يَحْفَظُون أعمالَكم ورِزْقَكم وأَجَلَكم.﴿رُسُلُنَا﴾: من الملائكةِ المُكَلَّفين بذلك.﴿لَا يُفَرِّطُونَ﴾: لا يُضَيِّعُون ما أُمِرُوا به."
  6,63,"﴿تَضَرُّعࣰا﴾: دعاءَ تَذَلُّلٍ جَهْرًا."
  6,64,"﴿كَرۡبࣲ﴾: شِدَّةٍ وغَمّ."
  6,65,"﴿مِّن فَوۡقِكُمۡ﴾: كالطُّوفان.﴿مِن تَحۡتِ أَرۡجُلِكُمۡ﴾: كالزِّلزالِ.﴿يَلۡبِسَكُمۡ شِيَعࣰا﴾: يَخْلِطَ أمْرَكم عليكم، فتكونوا فِرَقًا متناحِرَةً يَتَشَيَّعُ بعضُها لبعضٍ.﴿وَيُذِيقَ بَعۡضَكُم بَأۡسَ بَعۡضٍ﴾: يَقْتلَ بعضُكم بعضًا.﴿نُصَرِّفُ ٱلۡـَٔايَـٰتِ﴾: نَجيءُ بالحُجَجِ على وجوهٍ متعددةٍ."
  6,66,"﴿بِهِۦ﴾: بالقرآنِ، أو العذابِ.﴿بِوَكِيلࣲ﴾: بحفيظٍ على أعمالِكم حتى أُجازيَكم بها."
  6,67,"﴿لِّكُلِّ نَبَإࣲ مُّسۡتَقَرࣱّ﴾: لكلِّ شيءٍ وقْتٌ يَقَعُ فيه."
  6,68,"﴿يَخُوضُونَ﴾: بالاستهزاءِ والباطلِ.﴿وَإِمَّا يُنسِيَنَّكَ﴾: وإنْ أنساك.﴿ٱلذِّكۡرَىٰ﴾: تَذَكُّرِك."
  6,69,"﴿مِنۡ حِسَابِهِم مِّن شَيۡءࣲ﴾: ليس على المؤمنين شيءٌ من حِسابِ اللهِ على استهزاءِ المشركين.﴿وَلَـٰكِن ذِكۡرَىٰ﴾: ولكنْ على المؤمنين أن يُذَكِّروا المشركين ليُمْسِكوا عن الخوضِ."
  6,70,"﴿وَذَرِ﴾: واتْرُك.﴿بِهِۦٓ﴾: بالقرآن.﴿أَن تُبۡسَلَ نَفۡسُۢ﴾: لكيلا تُحْبَسَ، وتُفْضَحَ.﴿وَلِيࣱّ﴾: ناصرٌ.﴿وَلَا شَفِيعࣱ﴾: يَشْفَعُ لها في الآخرة.﴿وَإِن تَعۡدِلۡ كُلَّ عَدۡلࣲ﴾: وإن تَفْتَدِ بأيِّ فداءٍ.﴿حَمِيمࣲ﴾: شديدِ الحرارةِ، وهو ما يَسِيلُ من صديدِهم."
  6,71,"﴿وَنُرَدُّ عَلَىٰٓ أَعۡقَابِنَا﴾: ونَرْجِعُ إلى الضَّلالةِ.﴿ٱسۡتَهۡوَتۡهُ﴾: هَوَتْ به، وأضَلَّتْه.﴿لِنُسۡلِمَ﴾: لنَنْقادَ، ونُخْلِصَ."
  6,73,"﴿ٱلصُّورِ﴾: القَرْنِ الذي يُنفَخُ فيه للبعثِ.﴿وَٱلشَّهَـٰدَةِ﴾: وما تُشاهِدُونه."
  6,74,"﴿مُّبِينࣲ﴾: واضحٍ."
  6,75,"﴿وَكَذَ ٰ⁠لِكَ نُرِيٓ﴾: كما أرَيْناه الحقَّ نُرِيه.﴿مَلَكُوتَ﴾: المُلْكَ العظيمَ.﴿ٱلۡمُوقِنِينَ﴾: الراسِخين في الإيمان."
  6,76,"﴿جَنَّ﴾: أظلمَ.﴿هَـٰذَا رَبِّي﴾: حَكى ما يعتقدونه لأَجْلِ إلْزامِهم الحُجَّةَ.﴿أَفَلَ﴾: غابَ."
  6,77,"﴿بَازِغࣰا﴾: طالعًا."
  6,79,"﴿وَجَّهۡتُ وَجۡهِيَ﴾: قَصَدْتُ بعبادتي.﴿فَطَرَ﴾: خَلَقَ.﴿حَنِيفࣰا﴾: مائلًا عن الشِّرْكِ."
  6,80,"﴿وَحَآجَّهُۥ قَوۡمُهُۥ﴾: وجادَلَه قومُه.﴿وَلَآ أَخَافُ مَا تُشۡرِكُونَ بِهِۦٓ﴾: لاأخافُ آلهتَكم، فلن تَضُرَّني."
  6,81,"﴿سُلۡطَـٰنࣰا﴾: حُجَّةً بيِّنةً.﴿بِٱلۡأَمۡنِ﴾: أي: من عذابِ اللهِ."
  6,82,"﴿يَلۡبِسُوٓاْ﴾: يَخْلِطُوا.﴿بِظُلۡمٍ﴾: بشِرْكٍ."
  6,83,"﴿وَتِلۡكَ حُجَّتُنَآ﴾: وتلك البراهينُ التي أوْرَدَها إبراهيمُ."
  6,85,"6:84"
  6,86,"﴿ٱلۡعَـٰلَمِينَ﴾: من أهلِ زمانِهم."
  6,87,"﴿وَٱجۡتَبَيۡنَـٰهُمۡ﴾: واختَرْناهم."
  6,88,"﴿لَحَبِطَ﴾: لَبَطَلَ."
  6,89,"﴿وَٱلۡحُكۡمَ﴾: والعِلْمَ.﴿هَـٰٓؤُلَآءِ﴾: أهلُ مكةَ.﴿وَكَّلۡنَا بِهَا﴾: ألْزَمْنا بالإيمانِ بها."
  6,90,"﴿أُوْلَـٰٓئِكَ﴾: أي: الأنبياءُ.﴿إِنۡ هُوَ إِلَّا ذِكۡرَىٰ﴾: ما القرآنُ إلا تذكيرٌ."
  6,91,"﴿وَمَا قَدَرُواْ ٱللَّهَ حَقَّ قَدۡرِهِۦٓ﴾: وما عَرَفَ هؤلاء المشركون رَبَّهم حَقَّ مَعْرفَتِه.﴿تَجۡعَلُونَهُۥ قَرَاطِيسَ﴾: تكتبون عنه دفاترَ وكتبًا مُقَطَّعةً؛ فيَتِمُّ لكم ما تُريدونه من التحريفِ.﴿خَوۡضِهِمۡ﴾: باطِلِهم."
  6,92,"﴿بَيۡنَ يَدَيۡهِ﴾: ماتَقَدَّمَه من الكتبِ السماويةِ.﴿أُمَّ ٱلۡقُرَىٰ﴾: مكةَ."
  6,93,"﴿غَمَرَ ٰ⁠تِ ٱلۡمَوۡتِ﴾: أهوالِه وشدائدِه.﴿بَاسِطُوٓاْ أَيۡدِيهِمۡ﴾: لقَبْضِ أرواحِ الكفّارِ، وتَعْذ يبهم.﴿أَخۡرِجُوٓاْ أَنفُسَكُمُ﴾: يقولون لهم: أخْرِجُوا أنفسَكم إلينا.﴿ٱلۡهُونِ﴾: الهَوانِ والذُّلِّ."
  6,94,"﴿مَّا خَوَّلۡنَـٰكُمۡ﴾: ما مَكَّنّاكم فيه من الدنيا، كالأموالِ والأولادِ، فلم تَنْتَفعوا.﴿أَنَّهُمۡ فِيكُمۡ شُرَكَـٰٓؤُاْ﴾: شركاءُ للهِ يَسْتحقون العبادةَ.﴿بَيۡنَكُمۡ﴾: تَواصُلُكم الذي كان بينَكم في الحياةِ الدنيا.﴿وَضَلَّ﴾: ذهبَ، وغابَ."
  6,95,"﴿فَالِقُ ٱلۡحَبِّ﴾: يَشُقُّه، فيَخْرُجُ منه الزَّرع.﴿وَٱلنَّوَىٰ﴾: جَمْعِ النَّواة، وهي البِذْرةُ.﴿يُخۡرِجُ ٱلۡحَيَّ مِنَ ٱلۡمَيِّتِ﴾: كالإنسانِ من النُّطفةِ.﴿وَمُخۡرِجُ ٱلۡمَيِّتِ مِنَ ٱلۡحَيِّ﴾: كالنُّطفةِ من الإنسانِ.﴿فَأَنَّىٰ تُؤۡفَكُونَ﴾: فكيف تُصْرَفون عن الحقِّ، وتَعْبُدُون مع الله غيرَه؟"
  6,96,"﴿فَالِقُ ٱلۡإِصۡبَاحِ﴾: يَشُقُّ ضياءَ الصَّباحِ من ظلامِ الليلِ.﴿حُسۡبَانࣰا﴾: جَعَلَهُما محلَّ حسابٍ لمصالحِ العباد، وأَجْراهما بحِسابٍ مُقَدَّرٍ."
  6,98,"﴿مِّن نَّفۡسࣲ وَ ٰ⁠حِدَةࣲ﴾: آدمَ عليه السلام.﴿فَمُسۡتَقَرࣱّ﴾: هي أرحامُ النساءِ.﴿وَمُسۡتَوۡدَعࣱ﴾: هي أصلابُ الرجالِ."
  6,99,"﴿فَأَخۡرَجۡنَا مِنۡهُ﴾: من النَّباتِ.﴿خَضِرࣰا﴾: زَرْعًا، وشَجَرًا أخضرَ.﴿مُّتَرَاكِبࣰا﴾: يَرْكَبُ بعضُه بعضًا كسَنابلِ القَمْحِ.﴿مِن طَلۡعِهَا﴾: الطَّلْعُ: ما تنشأُ فيه عناقيدُ الرُّطَبِ.﴿قِنۡوَانࣱ﴾: جمعُ قِنْو، وهو عُنقودُ النَّخْلِ.﴿دَانِيَةࣱ﴾: قريبةٌ إلى الأرض.﴿مُشۡتَبِهࣰا﴾: في المنظرِ.﴿وَغَيۡرَ مُتَشَـٰبِهٍ﴾: في الطَّعْمِ.﴿ٱنظُرُوٓاْ﴾: فَكِّرُوا في قُدْرَةِ خالقهِ.﴿وَيَنۡعِهِۦٓ﴾: ونُضْجِه."
  6,100,"﴿وَخَرَقُواْ﴾: واختَلَقُوا، ونَسَبُوا."
  6,101,"﴿بَدِيعُ﴾: مُبْدِعٌ على غيرِ مثالٍ سَبَقَ.﴿أَنَّىٰ﴾: كيف؟"
  6,102,"﴿وَكِيلࣱ﴾: رقيبٌ مُدَبِّرٌ لأمورِ خَلْقِه."
  6,103,"﴿لَّا تُدۡرِكُهُ﴾: لا تُحيطُ به، ولا تَبْلُغُ كُنْهَ حَقيقتِه."
  6,104,"﴿بَصَآئِرُ﴾: براهينُ واضحةٌ.﴿فَعَلَيۡهَا﴾: فعلى نفسِه يعودُ وبالُ ذلك.﴿بِحَفِيظࣲ﴾: أُحْصِي أعمالَكم، بل أنا مُبَلِّغٌ."
  6,105,"﴿نُصَرِّفُ ٱلۡـَٔايَـٰتِ﴾: نُبَيِّنُ البراهينَ، والحُجَجَ.﴿وَلِيَقُولُواْ دَرَسۡتَ﴾: أي: لتقومَ الحُجَّةُ عليهم، وليقولوا: تَعَلَّمْتَ من أهلِ الكتابِ."
  6,107,"﴿حَفِيظࣰا﴾: رقيبًا تحفَظُ أقوالَهم وأعمالَهم.﴿بِوَكِيلࣲ﴾: مُوَكَّلٍ على أمورِهم."
  6,108,"﴿ٱلَّذِينَ يَدۡعُونَ مِن دُونِ ٱللَّهِ﴾: هم الأصنامُ.﴿عَدۡوَۢا﴾: اعتداءً.﴿زَيَّنَّا﴾: حَسَّنّا."
  6,109,"﴿جَهۡدَ أَيۡمَـٰنِهِمۡ﴾: بأيمانٍ مُؤَكَّدةٍ.﴿ءَايَةࣱ﴾: معجزةٌ خارقةٌ:﴿وَمَا يُشۡعِرُكُمۡ﴾: وما يُدْريكم.﴿أَنَّهَآ﴾: لعلَّ المعجزاتِ."
  6,110,"﴿وَنُقَلِّبُ أَفۡـِٔدَتَهُمۡ﴾: فنَحُولُ بينَهم وبينَ الإيمانِ.﴿فِي طُغۡيَـٰنِهِمۡ﴾: في تَمَرُّدِهم.﴿يَعۡمَهُونَ﴾: يَتَحَيَّرون، فلا يَهْتَدُون إلى الحقِّ."
  6,111,"﴿وَحَشَرۡنَا﴾: وجَمَعْنا.﴿قُبُلࣰا﴾: فعايَنُوه مُواجَهةً."
  6,112,"﴿شَيَـٰطِينَ ٱلۡإِنسِ﴾: هم المَرَدَةُ العُتاةُ من الإنسِ.﴿زُخۡرُفَ ٱلۡقَوۡلِ﴾: هو القولُ المُزَيَّنُ.﴿غُرُورࣰا﴾: ليَغْتَرَّ به سامِعُه.﴿وَمَا يَفۡتَرُونَ﴾: وما يَخْتَلِقُونه من كَذِبٍ."
  6,113,"﴿وَلِتَصۡغَىٰٓ إِلَيۡهِ﴾: ولتَمِيلَ إلى القولِ المُزَيَّنِ.﴿وَلِيَقۡتَرِفُواْ﴾: ولِيكْتَسِبُوا من الأعمالِ السيئةِ."
  6,114,"﴿أَبۡتَغِي﴾: أطْلُبُ.﴿ٱلۡمُمۡتَرِينَ﴾: الشّاكِّين."
  6,115,"﴿كَلِمَتُ رَبِّكَ﴾: القرآنُ الكريمُ.﴿لَّا مُبَدِّلَ لِكَلِمَـٰتِهِۦ﴾: لا أحدَ مُغَيِّرٌ لما حَكَمَ به."
  6,116,"﴿يَخۡرُصُونَ﴾: يظنُّون، يَكْذِبُون."
  6,118,"6:117"
  6,119,"﴿وَمَا لَكُمۡ أَلَّا﴾: وأيُّ شيءٍ يَمْنَعُكم؟"
  6,120,"﴿ظَـٰهِرَ ٱلۡإِثۡمِ وَبَاطِنَهُۥٓ﴾: عَلانِيَتُه وسِرُّه.﴿يَقۡتَرِفُونَ﴾: يكتسِبُون."
  6,121,"﴿لَفِسۡقࣱ﴾: لَخُروجٌ عن طاعةِ اللهِ.﴿لَيُوحُونَ﴾: لَيُوَسْوِسُون لهم بما يخالِفُ الحقَّ.﴿لِيُجَـٰدِلُوكُمۡ﴾: ليُثيروا الشبهاتِ لمجادَلَتِكم."
  6,122,"﴿مَيۡتࣰا﴾: في الضلالةِ.﴿زُيِّنَ﴾: حُسِّنَ."
  6,123,"﴿أَكَـٰبِرَ مُجۡرِمِيهَا﴾: رُؤَساءَها وعُظماءَها.﴿لِيَمۡكُرُواْ فِيهَا﴾: بالصَّدِّ عن دينِ اللهِ.﴿وَمَا يَمۡكُرُونَ إِلَّا بِأَنفُسِهِمۡ﴾: وبالُ مَكْرِهم عائدٌ عليهم."
  6,124,"﴿أَعۡلَمُ حَيۡثُ يَجۡعَلُ رِسَالَتَهُۥ﴾: أعلمُ بمَن يَسْتحِقُّ أن يجعلَه رسولًا، فدَعُوا طَلَبَ ماليسَ مِن شأنِكم.﴿صَغَارٌ﴾: ذلٌّ، وهَوانٌ."
  6,125,"﴿حَرَجࣰا﴾: شديدَ الضِّيقِ.﴿يَصَّعَّدُ﴾: يتكَلَّفُ ما لا يُطيقُ من الصُّعود.﴿ٱلرِّجۡسَ﴾: الشيطانَ."
  6,126,"﴿صِرَ ٰ⁠طُ رَبِّكَ﴾: الإسلاُم.﴿ٱلۡـَٔايَـٰتِ﴾: البراهينَ."
  6,127,"﴿دَارُ ٱلسَّلَـٰمِ﴾: دارُ السَّلامةِ من المكروه، وهي الجنةُ.﴿وَلِيُّهُم﴾: ناصِرُهم."
  6,128,"﴿يَحۡشُرُهُمۡ﴾: أي: جميعَ الثَّقَلَيْن من الجنِّ والإنسِ.﴿ٱسۡتَكۡثَرۡتُم مِّنَ ٱلۡإِنسِ﴾: بإضلالهِم، وصَدِّهم عن سبيلِ اللهِ.﴿ٱسۡتَمۡتَعَ بَعۡضُنَا بِبَعۡضࣲ﴾: استمتاعُ الجنِّ بالإنس: تَلَذُّذهم باتِّباع الإنسِ لهم، واستمتاعُ الإنس بالجن: قَبولُهم تحسينَ المعاصي منهم، فوقَعُوا فيها، وتَلَذَّ ذُوا بها.﴿وَبَلَغۡنَآ أَجَلَنَا﴾: بانقضاءِ حياتِنا الدنيا، ووُصولِنا إلى دارِ الجَزاءِ.﴿مَثۡوَىٰكُمۡ﴾: موضعُ مَقامِكم.﴿إِلَّا مَا شَآءَ ٱللَّهُ﴾: أي: شاءَ عَدَمَ خُلودِه، من عُصاةِ المُوَحِّدِين."
  6,129,"﴿نُوَلِّي بَعۡضَ ٱلظَّـٰلِمِينَ بَعۡضَۢا﴾: نُسَلِّط بعضَ الظّالمين من الإنسِ على بعضٍ في الدنيا."
  6,130,"﴿رُسُلࣱ مِّنكُمۡ﴾: الرسُلُ هم من الإنسِ، ورسُلُ الجِنِّ هم الذين يُنْذِرُون قومَهم.﴿وَغَرَّتۡهُمُ﴾: وخَدَعَتْهم زِينتُها، فاطمأنُّوا إليها."
  6,131,"﴿بِظُلۡمࣲ﴾: بسببِ ظُلْمِ مَن يَظْلِمُ.﴿وَأَهۡلُهَا غَـٰفِلُونَ﴾: أي: لا يُهلِكُهم إلا بعد إرسالِ الرسل، وارتفاعِ الغفلةِ عنهم بذلك، وتَحَقُّقِ الإنذارِ."
  6,132,"﴿دَرَجَـٰتࣱ﴾: مراتبُ."
  6,133,"﴿كَمَآ أَنشَأَكُم مِّن ذُرِّيَّةِ قَوۡمٍ ءَاخَرِينَ﴾: أحْدَثَكم من نَسْلِ خَلْقٍ آخرين كانوا قبلَكم."
  6,134,"﴿بِمُعۡجِزِينَ﴾: بفائتين عَمّا هو نازلٌ بكم."
  6,135,"﴿مَكَانَتِكُمۡ﴾: طريقتِكم، فاثبُتُوا عليها.﴿عَـٰقِبَةُ ٱلدَّارِ﴾: الجنةُ."
  6,136,"﴿ذَرَأَ﴾: خَلَقَ.﴿ٱلۡحَرۡثِ﴾: ثمراتِ الزَّرْعِ.﴿لِشُرَكَآئِنَا﴾: للأصنامِ التي يعبُدونها."
  6,137,"﴿قَتۡلَ أَوۡلَـٰدِهِمۡ﴾: وهو دَفْنُ البناتِ وهُنَّ أحياءٌ.﴿شُرَكَآؤُهُمۡ﴾: رؤساؤُهم، وشياطينُهم.﴿لِيُرۡدُوهُمۡ﴾: ليُهْلِكُوهم.﴿وَلِيَلۡبِسُواْ﴾: ولِيَخْلِطُوا."
  6,138,"﴿وَحَرۡثٌ﴾: وزَرْعٌ.﴿حِجۡرࣱ﴾: ممنوعةٌ، فهي لأصنامِهم.﴿حُرِّمَتۡ﴾: فلا يركبونَها."
  6,139,"﴿خَالِصَةࣱ﴾: حلالٌ.﴿أَزۡوَ ٰ⁠جِنَا﴾: نسائِنا.﴿شُرَكَآءُ﴾: يأكلُ منه الذكورُ والإناثُ.﴿وَصۡفَهُمۡ﴾: جزاءَ وصْفِهم."
  6,140,"﴿سَفَهَۢا﴾: طَيشًا.﴿مَا رَزَقَهُمُ﴾: من الأنعام."
  6,141,"﴿جَنَّـٰتࣲ مَّعۡرُوشَـٰتࣲ﴾: بساتينَ مرفوعاتٍ عن الأرض كالعِنَبِ.﴿وَغَيۡرَ مَعۡرُوشَـٰتࣲ﴾: قائمةً على سُوقِها كالنَّخْلِ، أوما خَرَج في البَرِّ.﴿مُتَشَـٰبِهࣰا﴾: في المنظرِ.﴿وَغَيۡرَ مُتَشَـٰبِهࣲ﴾: في الطَّعْمِ.﴿وَءَاتُواْ حَقَّهُۥ﴾: بالزَّكاةِ والصدقات."
  6,142,"﴿حَمُولَةࣰ﴾: مُهَيَّأً للحَمْلِ عليه.﴿وَفَرۡشࣰا﴾: صِغارَ الأنعامِ."
  6,143,"﴿ثَمَـٰنِيَةَ أَزۡوَ ٰ⁠جࣲ﴾: هذه الأنعامُ ثمانيةُ أصنافٍ، أربعةٌ منها في الغنم، وهي: الضَّأْنُ ذُكورًا وإناثًا، والمَعْزُ ذكورًا وإناثًا، وأربعةٌ في الإبِلِ والبقَرِ، ذكورًا وإناثًا.﴿أَمَّا ٱشۡتَمَلَتۡ عَلَيۡهِ﴾: أي: هل حَرَّمَ ما اشتملت عليه؟ فإن كان التحريمُ منه فإن ذلك يَسْتَلْزِم ُ تحريمَ الجميعِ، فلماذا حَلَّلُوا بعضَها، وحَرَّمُوا بعضَها الآخر؟"
  6,144,"﴿شُهَدَآءَ﴾: حاضِرين."
  6,145,"﴿مُحَرَّمًا﴾: أي: طعامًا محرَّمًا.﴿عَلَىٰ طَاعِمࣲ يَطۡعَمُهُۥٓ﴾: على مَن يأكلُه.﴿مَّسۡفُوحًا﴾: جاريًا.﴿رِجۡسٌ﴾: نَجَسٌ.﴿أُهِلَّ لِغَيۡرِ ٱللَّهِ بِهِۦ﴾: هو المذبوحُ الذي ذُكِرَ عليه اسمُ غيرِ اللهِ.﴿فَمَنِ ٱضۡطُرَّ﴾: إلى الأَكْلِ من هذه المحرَّماتِ.﴿غَيۡرَ بَاغࣲ﴾: غيرَ طالبٍ بأَكْلِه التلذُّذَ.﴿وَلَا عَادࣲ﴾: ولا متجاوزٍ حَدَّ الضَّرورةِ."
  6,146,"﴿إِلَّا مَا حَمَلَتۡ ظُهُورُهُمَآ﴾: إلا الشَّحْمَ المخالِطَ لظُهورِهما.﴿أَوِ ٱلۡحَوَايَآ﴾: أو المخالِطَ للأمعاءِ.﴿بِبَغۡيِهِمۡ﴾: بأعمالهِم السيئةِ."
  6,147,"﴿وَلَا يُرَدُّ بَأۡسُهُۥ﴾: ولا يُدْفَعُ عِقابُه إنْ أنْزَلَه بهم."
  6,148,"﴿وَلَا حَرَّمۡنَا مِن شَيۡءࣲ﴾: أي: لو شاءَ ما حَرَّمْنا على أنفسِنا شيئًا من الأنعام.﴿بَأۡسَنَا﴾: عقابَنا.﴿تَخۡرُصُونَ﴾: تَتَوَهَّمون، وتظنون."
  6,149,"﴿ٱلۡحُجَّةُ ٱلۡبَـٰلِغَةُ﴾: هي القاطِعَةُ لشُبَهِهِم، وهذه الحُجَّةُ هي الرُّسُلُ، وما جاؤُوا به من كُتُبٍ، ومعجزاتٍ."
  6,150,"﴿هَلُمَّ﴾: هاتُوا.﴿حَرَّمَ هَـٰذَا﴾: حَرَّم ماحَرَّمْتُم من الأنعام.﴿فَلَا تَشۡهَدۡ﴾: لأنّ شهادتَهم باطلةٌ.﴿يَعۡدِلُونَ﴾: يُشْرِكون."
  6,151,"﴿إِمۡلَـٰقࣲ﴾: فَقْرٍ.﴿مَا ظَهَرَ﴾: ما أُعْلِنَ منها.﴿وَمَا بَطَنَ﴾: ما خَفِيَ منها."
  6,152,"﴿بِٱلَّتِي هِيَ أَحۡسَنُ﴾: بما يُصْلِحُ مالَه، وينتفعُ به.﴿يَبۡلُغَ أَشُدَّهُۥ﴾: وهو سِنُّ البُلوغِ مع الرُّشْدِ، فادفعُوا إليه ماله.﴿بِٱلۡقِسۡطِ﴾: بالعدلِ.﴿وُسۡعَهَا﴾: طاقَتَها.﴿وَبِعَهۡدِ ٱللَّهِ أَوۡفُواْ﴾: بما عَهِدَ به إليكم من الالتزامِ بشرعِه."
  6,153,"﴿هَـٰذَا صِرَ ٰ⁠طِي﴾: الإسلامُ طريقي.﴿ٱلسُّبُلَ﴾: طُرُقَ الضَّلالِ والبِدَعِ.﴿فَتَفَرَّقَ بِكُمۡ﴾: فتميلَ بكم."
  6,154,"﴿تَمَامًا عَلَى ٱلَّذِيٓ أَحۡسَنَ﴾: تمامًا لنِعْمَتِه على المُحْسنين من مِلَّتِه."
  6,155,"﴿وَهَـٰذَا﴾: أي: القرآنُ."
  6,156,"﴿أَن تَقُولُوٓاْ﴾: لئلّا تقولُوا أيها الكفارُ.﴿طَآئِفَتَيۡنِ﴾: اليهودِ والنصارى.﴿وَإِن كُنَّا﴾: وإنّنا كنّا.﴿دِرَاسَتِهِمۡ﴾: تلاوةِ كتبِهم بلُغاتها.﴿لَغَـٰفِلِينَ﴾: لاندْري ما فيها."
  6,157,"﴿أَهۡدَىٰ مِنۡهُمۡ﴾: أشَدَّ استقامةً على الحقِّ.﴿وَصَدَفَ﴾: أعرَضَ."
  6,158,"﴿يَنظُرُونَ﴾: ينتظر المُعْرِضون.﴿ٱلۡمَلَـٰٓئِكَةُ﴾: المختصُّون بقَبْضِ الأرواحِ.﴿يَأۡتِيَ رَبُّكَ﴾: للفَصْل بين عبادِه يومَ القيامةِ.﴿بَعۡضُ ءَايَـٰتِ رَبِّكَ﴾: بعضُ علاماتِ السّاعةِ.﴿مِن قَبۡلُ﴾: من قبلِ إتيانِ هذه الآياتِ.﴿خَيۡرࣰا﴾: عملًا صالحًا."
  6,159,"﴿فَرَّقُواْ دِينَهُمۡ﴾: جَعَلُوه متفرِّقًا، فأخذوا ببعضِه، وتركوا بعضَه.﴿شِيَعࣰا﴾: فِرَقًا وأحزابًا."
  6,161,"﴿صِرَ ٰ⁠طࣲ مُّسۡتَقِيمࣲ﴾: طريقٍ لا عِوَجَ فيه، وهو الإسلامُ.﴿قِيَمࣰا﴾: يقومُ بأمْرِ الدنيا والآخرةِ.﴿حَنِيفࣰا﴾: مائلًا إلى الحقِّ."
  6,162,"﴿وَنُسُكِي﴾: وذَبْحي للأنعام.﴿وَمَحۡيَايَ﴾: ما أعمَلُه في حياتي.﴿وَمَمَاتِي﴾: ما يُقَدِّره عليّ في الموتِ."
  6,163,"﴿أَوَّلُ ٱلۡمُسۡلِمِينَ﴾: أولُ مَن انقادَ للهِ من هذه الأمةِ."
  6,164,"﴿أَبۡغِي﴾: أطْلُبُ.﴿وَلَا تَكۡسِبُ كُلُّ نَفۡسٍ إِلَّا عَلَيۡهَا﴾: لا يُؤاخَذُ ممّا أتَتْ به من الذَّنبِ سِواها.﴿وَلَا تَزِرُ وَازِرَةࣱ وِزۡرَ أُخۡرَىٰ﴾: ولا تَحْمِلُ نفسٌ آثمةٌ إثمَ نفسٍ أخرى."
  6,165,"﴿خَلَـٰٓئِفَ﴾: خُلَفاءَ الأممِ الماضيةِ.﴿وَرَفَعَ بَعۡضَكُمۡ فَوۡقَ بَعۡضࣲ﴾: في الرِّزقِ والقوةِ وغيرِهما.﴿دَرَجَـٰتࣲ﴾: مراتبَ.﴿لِّيَبۡلُوَكُمۡ﴾: ليختبرَكم.﴿فِي مَآ ءَاتَىٰكُمۡ﴾: أي: من نِعَمِه."
