tafsir[36]{c,v,t}:
  35,1,"﴿فَاطِرِ﴾: مُبْدِعٍ عَلى غَيرِ مِثالٍ سَبَقَ.﴿أُوْلِيٓ أَجۡنِحَةࣲ﴾: أصْحابَ أجْنِحَةٍ."
  35,2,"﴿مَّا يَفۡتَحِ﴾: أي: ما يُرسِلْ ويُعْطِ.﴿رَّحۡمَةࣲ﴾: نِعْمَةٍ.﴿مُمۡسِكَ﴾: مانِعَ.﴿مُرۡسِلَ﴾: مُعْطِيَ."
  35,3,"﴿فَأَنَّىٰ تُؤۡفَكُونَ﴾: فَكَيفَ تُصْرَفُونَ عَن تَوحِيدِهِ؟."
  35,5,"﴿وَعۡدَ ٱللَّهِ﴾: أي: بالبعْثِ والثَّوابِ والعِقابِ.﴿حَقࣱّ﴾: ثابِتٌ وكائِنٌ لا محالةَ.﴿فَلَا تَغُرَّنَّكُمُ﴾: فَلا تَخْدَعَنَّكُم.﴿ٱلۡغَرُورُ﴾: الشَّيطانُ."
  35,6,"﴿حِزۡبَهُۥ﴾: أي: أتْباعَهُ.﴿ٱلسَّعِيرِ﴾: النّارِ الموقَدَةِ."
  35,7,"﴿أَجۡرࣱ كَبِيرٌ﴾: وهو الجنَّةُ."
  35,8,"﴿زُيِّنَ لَهُۥ﴾: أي: حَسَّنَ له الشَّيطانُ.﴿سُوٓءُ عَمَلِهِۦ﴾: عَمَلُه السَّيِّئُ والقبيحُ.﴿فَلَا تَذۡهَبۡ نَفۡسُكَ عَلَيۡهِمۡ حَسَرَ ٰ⁠تٍ﴾: فلا تُهِلكْ نفسَك حُزْنًا على كُفْرِهِم."
  35,9,"﴿فَتُثِيرُ﴾: فَتُحَرِّكُ.﴿مَّيِّتࣲ﴾: جَدْب.﴿بَعۡدَ مَوۡتِهَا﴾: بَعْدَ يُبْسِها وجَفافِها.﴿ٱلنُّشُورُ﴾: بَعْثُ الموتى مِن قُبُورِهِم للجزاءِ."
  35,10,"﴿يَصۡعَدُ﴾: يَرْتَقِي.﴿ٱلۡكَلِمُ ٱلطَّيِّبُ﴾: الكلامُ الطَّيِّبُ مِن ذِكْرٍ ودُعاءٍ وتِلاوَةٍ.﴿يَرۡفَعُهُۥ﴾: أي: يَرفَعُه اللهُ إلَيهِ ويَقْبَلُه.﴿يَمۡكُرُونَ ٱلسَّيِّـَٔاتِ﴾: أي: يَمْكُرُونَ المكَراتِ السَّيِّئاتِ، وهي مَذْكُورةٌ في قوله تعالى:﴿وَإِذۡ يَمۡكُرُ بِكَ ٱلَّذِينَ كَفَرُواْ لِيُثۡبِتُوكَ أَوۡ يَقۡتُلُوكَ أَوۡ يُخۡرِجُوكَ﴾: [الأنفال: ٣٠].﴿يَبُورُ﴾: يَفسُدُ ويَبْطُلُ."
  35,11,"﴿مِن نُّطۡفَةࣲ﴾: هي مَنِيُّ الرجلِ يَقْذِفُه في رَحِمِ امْرَأَتِه.﴿أَزۡوَ ٰ⁠جࣰا﴾: ذُكُورًا وإناثًا تَزَوَّجَ بعضُهم بَعْضًا.﴿لَا تَضَعُ﴾: لاتَلِدُ.﴿مُّعَمَّرࣲ﴾: طَوِيلِ العُمُرِ."
  35,12,"﴿فُرَاتࣱ﴾: حُلْوٌ شَدِيدُ الحَلاوَةِ.﴿سَآئِغࣱ شَرَابُهُۥ﴾: سَهْلٌ مُرُورُهُ في الحَلْقِ.﴿أُجَاجࣱ﴾: شَدِيدُ المُلوحَةِ.﴿لَحۡمࣰا طَرِيࣰّا﴾: هو السَّمَكُ.﴿حِلۡيَةࣰ﴾: هي اللُّؤلُؤُ والمَرْجانُ.﴿ٱلۡفُلۡكَ﴾: السُّفُنَ.﴿مَوَاخِرَ﴾: جوارِيَ تَشُقُّ الماءَ شَقًّا.﴿لِتَبۡتَغُواْ﴾: لِتَطْلُبُوا."
  35,13,"﴿يُولِجُ﴾: يُدخِلُ.﴿لِأَجَلࣲ مُّسَمࣰّى﴾: لِوقْتٍ مَعْلُومٍ.﴿قِطۡمِيرٍ﴾: القِشْرَةِ الرَّقيقَةِ على نَواةِ التَّمْرَةِ."
  35,14,"﴿وَلَا يُنَبِّئُكَ﴾: ولا يُخْبِرُكَ."
  35,15,"﴿ٱلۡفُقَرَآءُ﴾: المحْتاجُونَ."
  35,17,"﴿بِعَزِيزࣲ﴾: بمُمْتَنِعٍ."
  35,18,"﴿وَلَا تَزِرُ﴾: لا تَحْمِلُ.﴿وَازِرَةࣱ﴾: أي: نفسٌ مُذْنِبَةٌ.﴿مُثۡقَلَةٌ﴾: أي: نَفْسٌ أثْقَلَتْها الذُّنوبُ.﴿حِمۡلِهَا﴾: ذُنُوبِها التي أثْقَلَتْها.﴿يَخۡشَوۡنَ﴾: يخافُونَ.﴿تَزَكَّىٰ﴾: تَطَهَّرَ مِنَ الشِّرْكِ والمعاصِي.﴿ٱلۡمَصِيرُ﴾: المرْجِعُ."
  35,19,"﴿ٱلۡأَعۡمَىٰ﴾: مَن فَقَدَ بَصَرَه، والمُرادُ بِه هُنا الكافِرُ لأنّهُ عَمِيَ عَن دِينِ الحقِّ."
  35,21,"﴿ٱلۡحَرُورُ﴾: الرِّيحُ الحارَّةُ."
  35,23,"﴿نَذِيرٌ﴾: رَسُولٌ مُنْذِرٌ مِن عَذابِ اللهِ."
  35,24,"﴿بَشِيرࣰا وَنَذِيرࣰا﴾: بَشِيرًا لِأَهْلِ الطّاعةِ ونَذَيرًا لِأَهْلِ المعْصِيةِ.﴿نَذِيرࣱ﴾: نَبِيٌّ مُنْذِرٌ مِن عَذابِ اللهِ."
  35,25,"﴿بِٱلۡبَيِّنَـٰتِ﴾: بالمعْجِزاتِ الواضِحةِ.﴿وَبِٱلزُّبُرِ﴾: بالكُتُبِ التي فيها مَواعِظُ.﴿وَبِٱلۡكِتَـٰبِ ٱلۡمُنِيرِ﴾: الكُتُبِ الَّتي أنارَتْ طَرِيقَ الشَّرْعِ والهِدايَةِ، ومْنِها القرآنُ الكريمُ."
  35,27,"﴿جُدَدُۢ﴾: جَمْعُ جُدَّةٍ، وهي الطَّرِيقَةُ والخِطَّةُ في الشَّيءِ تكونُ واضِحةً فِيهِ.﴿وَغَرَابِيبُ﴾: جمع غِرْبِيبٍ، وهو شَديدُ السَّوادِ يُشْبِهُ لَونُه لَونَ الغُرابِ."
  35,29,"﴿لَّن تَبُورَ﴾: لَن تَكْسُدَ، ولَن تَهْلِكَ."
  35,31,"35:30"
  35,32,"﴿ٱلَّذِينَ ٱصۡطَفَيۡنَا﴾: الَّذِيِنَ اخْتَرْناهُم.﴿ظَالِمࣱ لِّنَفۡسِهِۦ﴾: أي: بِأن وقَعَ في بَعْضِ المعاصِي.﴿مُّقۡتَصِدࣱ﴾: أي: بِأَداءِ الواجِباتِ واجْتِنابِ المُحَرَّماتِ.﴿سَابِقُۢ بِٱلۡخَيۡرَ ٰ⁠تِ﴾: أي: مُسارعٌ مُجْتَهِدٌ في الأعْمالِ الصّالحةِ فَرْضِها ونَفْلِها."
  35,33,"﴿يُحَلَّوۡنَ﴾: يُزيَّنُونَ بالحِلْيةَ.﴿أَسَاوِرَ﴾: مُفْرَدُه سِوارٌ: وهو ما يُلْبَسُ في اليدِ مِنَ الحُلِيِّ ويُحِيطُ بالمِعْصَمِ.﴿حَرِيرࣱ﴾: ثِيابٌ رَقِيقَةٌ."
  35,34,"﴿ٱلۡحَزَنَ﴾: أي: كُلَّ ما يُحْزِنُ ويُغِمُّ."
  35,35,"﴿أَحَلَّنَا﴾: أنزَلنا.﴿دَارَ ٱلۡمُقَامَةِ﴾: دارَ الإقامةِ الدّائمةِ، وهي الجنَّةُ.﴿نَصَبࣱ﴾: تَعَبٌ ومَشَقَّةٌ.﴿لُغُوبࣱ﴾: إعياءٌ مِنَ التَّعَبِ وفُتُورٌ."
  35,36,"﴿لَا يُقۡضَىٰ عَلَيۡهِمۡ﴾: أي: بالموتِ.﴿كَفُورࣲ﴾: مُتَمادٍ في الكُفْرِ مُصِرٍّ عليه."
  35,37,"﴿يَصۡطَرِخُونَ﴾: يَصْرُخُونَ بِشِدَّةٍ مُسْتَغِيثِينَ.﴿مَّا يَتَذَكَّرُ فِيهِ مَن تَذَكَّرَ﴾: أي: مِثْلُه كافٍ للاتِّعاظِ لِمنْ أرادَ أن يَتَّعِظَ فِيهِ.﴿ٱلنَّذِيرُ﴾: وهو الرَّسولُ ﷺ."
  35,39,"﴿خَلَـٰٓئِفَ﴾: يَخْلُفُ بَعْضُكُم بَعْضًا.﴿مَقۡتࣰا﴾: بُغْضًا وغَضَبًا.﴿خَسَارࣰا﴾: هَلاكًا وخُسْرانًا."
  35,40,"﴿أَرَءَيۡتُمۡ شُرَكَآءَكُمُ﴾: أخْبرُونِي عَن شُركائِكُم.﴿ءَاتَيۡنَـٰهُمۡ﴾: أعْطَيناهُم.﴿غُرُورًا﴾: خِداعًا."
  35,42,"﴿جَهۡدَ أَيۡمَـٰنِهِمۡ﴾: مُجْتَهِدِينَ فِيها بالحَلِفِ بأغْلَظِها.﴿نُفُورًا﴾: بُعْدًا عَنِ الحقِّ وفِرارًا مِنه."
  35,43,"﴿لَا يَحِيقُ﴾: لا يُحِيطُ ولا يَنْزِلُ.﴿ٱلۡمَكۡرُ ٱلسَّيِّئُ﴾: أي: وبالُ مَكْرِهِم السَّيِّئِ.﴿سُنَّتَ ٱلۡأَوَّلِينَ﴾: طَرِيقَةَ اللهِ فِيهِم وعادَتَهُ بِتَعْذِيبِهِم لِتكْذِيبِهِم."
  35,44,"﴿لِيُعۡجِزَهُۥ﴾: لِيَفُوتَه."
  35,45,"﴿يُؤَاخِذُ﴾: يُعاقِبُ.﴿يُؤَخِّرُهُمۡ﴾: يُمْهِلُهُم."
