tafsir[46]{c,v,t}:
  68,1,"﴿نٓ﴾: سَبَقَ الكَلامُ عَلى الحروفِ المُقَطَّعةِ في أوَّلِ سُورَةِ البَقَرَةِ.﴿وَٱلۡقَلَمِ﴾: أقْسَمَ اللهُ بالقلمِ الَّذِي يَكْتُبُ بهِ الملائِكةُ والنّاسُ.﴿وَمَا يَسۡطُرُونَ﴾: أقْسَمَ اللهُ بِما يَكْتُبُونَ مِنَ الخَيرِ والنَّفْعِ والعُلُومِ."
  68,3,"﴿لَأَجۡرًا﴾: لَثَوابًا عَظِيمًا.﴿غَيۡرَ مَمۡنُونࣲ﴾: غيرَ مَنقُوصٍ ولا مَقْطُوعٍ."
  68,5,"68:4"
  68,6,"﴿بِأَييِّكُمُ﴾: في أيٍّ مِنكُم.﴿ٱلۡمَفۡتُونُ﴾: الفِتْنَةُ و الجنُونُ."
  68,8,"68:7"
  68,9,"﴿وَدُّواْ﴾: تَمَنَّوا وأحَبُّوا.﴿لَوۡ تُدۡهِنُ﴾: لو تُلايِنُهُم وتُصانِعُهُم عَلى بَعْضِ ما هُم عَلَيهِ.﴿فَيُدۡهِنُونَ﴾: فَيَلِينُونَ لَكَ."
  68,10,"﴿حَلَّافࣲ﴾: كَثِيرِ الحَلْفِ.﴿مَّهِينٍ﴾: حَقِيرٍ."
  68,11,"﴿هَمَّازࣲ﴾: مُغْتابٍ للنّاسِ.﴿مَّشَّآءِۭ بِنَمِيمࣲ﴾: يَمْشِي بَينَ النّاسِ ويَنْقُلُ حَدِيثَ بَعْضِهِم إلى بَعْضٍ عَلى وجْهِ الإفْسادِ بَيْنَهُم."
  68,12,"﴿مَّنَّاعࣲ﴾: شَدِيدِ المنْعِ لِلخَيْرِ.﴿مُعۡتَدٍ﴾: مُتَجاوِزٍ حَدَّه في العُدْوانِ عَلى النّاسِ وتَناوُلِ الُمحَرَّماتِ.﴿أَثِيمٍ﴾: كَثِيرِ الآثامِ."
  68,13,"﴿عُتُلِّۭ﴾: شَدَيدٍ في كُفْرِهِ، فاحِشٍ لَئِيمٍ.﴿زَنِيمٍ﴾: مَنسُوبٍ إلى غَيرِ أبِيهِ."
  68,14,"﴿أَن كَانَ ذَا مَالࣲ وَبَنِينَ﴾: طَغى وتَكَبَّرَ لِأَجْلِ أن رَّزَقَهُ اللهُ مالًا وبَنِينَ فَلَمْ يَشْكُرِ النِّعْمَةَ."
  68,15,"﴿أَسَـٰطِيرُ ٱلۡأَوَّلِينَ﴾: أباطِيلُ الأوَّلِينَ وخُرافاتُهُم."
  68,16,"﴿سَنَسِمُهُۥ﴾: سَنَجْعلُ عَلامةً لازِمةً لا تُفارِقُهُ.﴿عَلَى ٱلۡخُرۡطُومِ﴾: عَلى أنْفِهِ عُقُوبةً لَهُ."
  68,17,"﴿بَلَوۡنَـٰهُمۡ﴾: اخْتَبَرْنا أهْلَ مَكَّةَ بالجُوعِ والقَحْطِ.﴿ٱلۡجَنَّةِ﴾: الحَدِيقَةِ.﴿لَيَصۡرِمُنَّهَا﴾: لَيَقْطَعُنَّ ثِمارَها.﴿مُصۡبِحِينَ﴾: مُبَكِّرِينَ في الصَّباحِ."
  68,18,"﴿وَلَا يَسۡتَثۡنُونَ﴾: ولَمْ يَقُولُوا: إن شاءَ اللهُ."
  68,19,"﴿فَطَافَ عَلَيۡهَا طَآئِفࣱ مِّن رَّبِّكَ﴾: فَأَنْزَلَ اللهُ عَلَيها نارًا أحْرَقَتْها لَيلًا."
  68,20,"﴿كَٱلصَّرِيمِ﴾: مُحْتَرِقَةً سَوْداءَ كالليلِ المُظْلمِ."
  68,21,"﴿فَتَنَادَوۡاْ﴾: فَنادى بَعْضُهُم بَعْضا.﴿مُصۡبِحِينَ﴾: وقْتَ الصَّباحِ."
  68,22,"﴿ٱغۡدُواْ﴾: اذْهَبُوا مُبَكِّرِينَ.﴿حَرۡثِكُمۡ﴾: زَرْعِكُم.﴿صَـٰرِمِينَ﴾: قاطِعِينَ ثِمارَكُم."
  68,23,"﴿يَتَخَـٰفَتُونَ﴾: يُسِرُّ بَعْضُهُم إلى بَعْضٍ في الكَلامِ."
  68,25,"﴿وَغَدَوۡاْ﴾: سارُوا في أوَّلِ النَّهارِ.﴿عَلَىٰ حَرۡدࣲ﴾: على أمْرٍ مُجْمَعٍ عَلَيهِ."
  68,26,"﴿فَلَمَّا رَأَوۡهَا﴾: أي مُحْتَرِقَةً.﴿لَضَآلُّونَ﴾: أخْطأنا الطَّريقَ إلى حَدِيقَتِنا."
  68,27,"﴿مَحۡرُومُونَ﴾: حُرِمْنا خيرَها بِسَبَبِ مَنعِنا الَمساكِينَ."
  68,28,"﴿أَوۡسَطُهُمۡ﴾: أعْدَلُهُم وأَفْضَلُهُم.﴿لَوۡلَا﴾: هَلّا.﴿تُسَبِّحُونَ﴾: تَقُولُونَ: إن شاء اللهُ."
  68,29,"﴿سُبۡحَـٰنَ رَبِّنَآ﴾: نُنَزِّهُ رَبَّنا عَنِ الظُّلْمِ فِيما أصابَنا."
  68,30,"﴿يَتَلَـٰوَمُونَ﴾: يَلُومُ بَعْضُهم بَعْضًا."
  68,31,"﴿يَـٰوَيۡلَنَآ﴾: نادَوا عَلى أنْفُسِهِم بِالشَّرِّ والعَذابِ.﴿طَـٰغِينَ﴾: مُتَجاوِزِينَ الحدَّ في مَنعِنا الفُقَراءَ."
  68,32,"﴿رَ ٰ⁠غِبُونَ﴾: طالِبُونَ الخيرَ والعفوَ عَن سيِّئاتِنا."
  68,33,"﴿كَذَ ٰ⁠لِكَ ٱلۡعَذَابُ﴾: نَفْعَلُ بِمن تَعَدّى حُدُودَنا مِثلَ ما فَعَلْنا بِهَؤُلاءِ."
  68,35,"68:34"
  68,36,"﴿كَيۡفَ تَحۡكُمُونَ﴾: كَيفَ تَقْضُونَ بِهذا الحُكْمِ الظّالِمِ؟"
  68,37,"﴿كِتَـٰبࣱ﴾: أُنْزِلَ مِن عِنْدِ اللهِ.﴿تَدۡرُسُونَ﴾: تَقْرَؤونَ فِيهِ هَذا الحُكْمَ الجائِرَ."
  68,38,"﴿لَمَا تَخَيَّرُونَ﴾: ما تَشْتَهُونَ وتَخْتارُونَ، ليسَ لَكُم ذَلِكَ."
  68,39,"﴿أَيۡمَـٰنٌ عَلَيۡنَا﴾: عُهُودٌ ومَواثِيقُ عَلَينا.﴿بَـٰلِغَةٌ﴾: مُؤَكَّدةٌ."
  68,40,"﴿زَعِيمٌ﴾: كَفِيلٌ وضامِنٌ."
  68,41,"﴿أَمۡ لَهُمۡ شُرَكَآءُ﴾: ألَهُم أرْبابٌ يَفْعَلُونَ بِهِم ما زَعَمُوا مِنَ الكَرامةِ؟"
  68,42,"﴿سَاقࣲ﴾: يَكْشِفُ رَبُّنا عَن ساقِهِ يَوْمَ القِيامَةِ فَيَسْجُدُ لَهُ كُلُّ مُؤْمِنٍ ومُؤْمِنَةٍ، ولا يَتَمكَّنُ المنافِقُونَ مِنَ السُّجُودِ."
  68,43,"﴿خَـٰشِعَةً أَبۡصَـٰرُهُمۡ﴾: مُنْكَسِرَةً لا يَرْفَعُونَها.﴿تَرۡهَقُهُمۡ﴾: تَغْشاهُم."
  68,44,"﴿فَذَرۡنِي وَمَن يُكَذِّبُ﴾: خَلِّ بينِي وبَينَ مَنُ يُكذِّبُ.﴿سَنَسۡتَدۡرِجُهُم﴾: سَنَمُدُّهُم بالأمْوالِ والأَولادِ والنِّعَمِ اسْتِدْراجًا لَهُم."
  68,45,"﴿وَأُمۡلِي لَهُمۡ﴾: وأُمْهِلُهُم وأُطِيلُ أعْمارَهُم لِيَزْدادُوا إثْما.﴿كَيۡدِي﴾: مَكْرِي بِالكُفّارِ.﴿مَتِينٌ﴾: قَوِيٌّ شدِيدٌ."
  68,46,"﴿مِّن مَّغۡرَمࣲ﴾: مِن غَرامَةِ ذَلِكَ الأَجْرِ.﴿مُّثۡقَلُونَ﴾: يَثْقُلُ عَلَيهِم حِمْلُهُ."
  68,47,"﴿أَمۡ عِندَهُمُ ٱلۡغَيۡبُ﴾: بَلْ أعِنْدَهُم عِلْمُ الغَيبِ؟"
  68,48,"﴿كَصَاحِبِ ٱلۡحُوتِ﴾: هُو يُونُسُ -عَلَيهِ السَّلامُ-.﴿مَكۡظُومࣱ﴾: مَمْلُوءٌ غَمًّا وكَرْبًا."
  68,49,"﴿نِعۡمَةࣱ مِّن رَّبِّهِۦ﴾: التَّوبَةُ وقَبُولُها مِنهُ.﴿لَنُبِذَ﴾: لَطُرِحَ.﴿بِٱلۡعَرَآءِ﴾: بالأرْضِ الفَضاءِ المهْلِكَةِ.﴿مَذۡمُومࣱ﴾: آتٍ بِما يُلامُ عَلَيهِ."
  68,50,"﴿فَٱجۡتَبَـٰهُ﴾: فاخْتارَهُ لِرِسالتِهِ."
  68,51,"﴿لَيُزۡلِقُونَكَ﴾: لَيُصِيبُونَكَ بالعَينِ لِبُغْضِهِم إيّاكَ.﴿ٱلذِّكۡرَ﴾: القُرَآنَ."
