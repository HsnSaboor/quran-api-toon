tafsir[26]{c,v,t}:
  72,1,"﴿ٱسۡتَمَعَ﴾: لِتِلاوَتِي لِلْقُرآنِ.﴿نَفَرࣱ﴾: جَماعَةٌ.﴿عَجَبࣰا﴾: بَدِيعًا في بَلاغَتِهِ وأَحْكامِهِ."
  72,2,"﴿يَهۡدِيٓ إِلَى ٱلرُّشۡدِ﴾: يَدْعُو إلى الحقِّ."
  72,3,"﴿تَعَـٰلَىٰ﴾: عَلَتْ وارْتَفَعَتْ.﴿جَدُّ رَبِّنَا﴾: عَظَمَةُ رَبِّنا وجَلالُهُ.﴿صَـٰحِبَةࣰ﴾: زَوْجةً."
  72,4,"﴿سَفِيهُنَا﴾: إبْلِيسُ.﴿شَطَطࣰا﴾: قَوْلًا بعِيدًا عَنِ الحقِّ والصَّوابِ."
  72,6,"﴿يَعُوذُونَ﴾: يَسْتَجِيرُونَ ويَلُوذُونَ.﴿فَزَادُوهُمۡ﴾: فَزادَ رِجالُ الجِنِّ الإنسَ باسْتِعاذَتِهم بِهِم.﴿رَهَقࣰا﴾: خَوْفًا."
  72,7,"﴿وَأَنَّهُمۡ﴾: وأَنَّ كُفارَ الإنْسِ.﴿ظَنُّواْ كَمَا ظَنَنتُمۡ﴾: حَسِبُوا كما حَسِبْتُم -يا مَعْشرَ الِجنِّ-.﴿أَن لَّن يَبۡعَثَ ٱللَّهُ أَحَدࣰا﴾: بَعْدَ الموتِ."
  72,8,"﴿لَمَسۡنَا ٱلسَّمَآءَ﴾: طَلَبْنا بُلُوغَ السَّماءِ لاسْتِماعِ كَلامِ أهْلِها.﴿حَرَسࣰا شَدِيدࣰا﴾: مَلائِكةً تَحْرُسُها.﴿وَشُهُبࣰا﴾: جَمْعُ شِهابٍ، وهي النُّجُومُ الَّتِي كانتْ تُرْجَمُ بِها الشَّياطِينُ."
  72,9,"﴿نَقۡعُدُ مِنۡهَا مَقَـٰعِدَ﴾: نَتَّخِذُ مِنَ السَّماءِ مَواضِعَ.﴿لِلسَّمۡعِ﴾: لِنَسْتَمِعَ إلى أخْبارِها.﴿فَمَن يَسۡتَمِعِ ٱلۡـَٔانَ﴾: فَمَن يُحاوِلِ الآنَ اسْتِراقَ السَّمْعِ.﴿شِهَابࣰا﴾: شِهابًا بالمِرْصادِ، يُحْرِقُه ويُهْلِكُهُ."
  72,10,"﴿رَشَدࣰا﴾: خَيرًا وهُدىً."
  72,11,"﴿وَمِنَّا دُونَ ذَ ٰ⁠لِكَ﴾: ومِنّا قَومٌ دُونَ ذَلِكَ كُفّارٌ وفُسّاقٌ.﴿طَرَآئِقَ﴾: فِرَقًا ومَذاهِبَ.﴿قِدَدࣰا﴾: مخْتَلِفَةً."
  72,12,"﴿ظَنَنَّآ﴾: أيْقَنّا.﴿أَن لَّن نُّعۡجِزَ ٱللَّهَ فِي ٱلۡأَرۡضِ﴾: أن لَن نَفُوتَ اللهَ إذا أرادَ بِنا أمْرًا فِي الأَرْضِ.﴿وَلَن نُّعۡجِزَهُۥ هَرَبࣰا﴾: ولَن نسْتَطِيعَ أن نُفْلِتَ مِن عِقابِهِ هَرَبًا."
  72,13,"﴿ٱلۡهُدَىٰٓ﴾: القُرآنَ.﴿بَخۡسࣰا﴾: نُقْصانًا مِن حَسَناتِه.﴿رَهَقࣰا﴾: ظُلمًا يَلْحَقُهُ بِزِيادةٍ في سَيِّئاتِهِ."
  72,14,"﴿ٱلۡمُسۡلِمُونَ﴾: الخاضِعُونَ للهِ بالطّاعةِ.﴿ٱلۡقَـٰسِطُونَ﴾: الجائِرُونَ العُصاةُ.﴿أَسۡلَمَ﴾: وخَضَعَ للهِ بالطّاعةِ.﴿تَحَرَّوۡاْ﴾: قَصَدُوا.﴿رَشَدࣰا﴾: طَرِيقَ الحقِّ والصَّوابِ."
  72,15,"﴿وَأَمَّا ٱلۡقَـٰسِطُونَ﴾: الجائِرُونَ عَن طَرِيقِ الإسْلامِ.﴿حَطَبࣰا﴾: وقُودًا."
  72,16,"﴿وَأَلَّوِ ٱسۡتَقَـٰمُواْ عَلَى ٱلطَّرِيقَةِ﴾: لَو سارَ الكُفّارُ مِنَ الإنْسِ والِجنِّ على طَرِيقَةِ الإسْلامِ.﴿غَدَقࣰا﴾: كَثِيرًا."
  72,17,"﴿لِّنَفۡتِنَهُمۡ فِيهِ﴾: لِنَخْتَبِرَهُم.﴿ذِكۡرِ رَبِّهِۦ﴾: طاعَةِ رَبِّهِ واسْتِماعِ القُرآنِ، والعَمَلِ بِهِ.﴿يَسۡلُكۡهُ﴾: يُدْخِلْهُ.﴿صَعَدࣰا﴾: شَدِيدًا شاقًّا."
  72,18,"﴿وَأَنَّ ٱلۡمَسَـٰجِدَ لِلَّهِ﴾: وأَنَّ المساجِدَ لِعبادَة اللهِ وحْدَهُ.﴿فَلَا تَدۡعُواْ مَعَ ٱللَّهِ أَحَدࣰا﴾: فلا تَعْبُدُوا فِيها غَيرَهُ."
  72,19,"﴿عَبۡدُ ٱللَّهِ﴾: مُحَمَّدٌ ﷺ.﴿لِبَدࣰا﴾: جَماعاتٍ مُتَراكِمَةً، بَعْضُها فَوْقَ بَعْضٍ؛ مِن شِدَّةِ ازْدِحامِهِم لِسَماعِ القُرآنِ مِنهُ."
  72,21,"﴿إِنِّي لَآ أَمۡلِكُ لَكُمۡ ضَرࣰّا﴾: لا أقْدِرُ أن أدْفَعَ عَنْكُم ضَرًّا.﴿وَلَا رَشَدࣰا﴾: ولا أجْلِبُ لَكُم نَفْعًا."
  72,22,"﴿لَن يُجِيرَنِي﴾: لَن يُنْقِذَني مِن عَذابِ اللهِ.﴿مُلۡتَحَدًا﴾: مَلْجَأً أفِرُّ إلَيهِ مِن عَذابِهِ."
  72,23,"﴿إِلَّا بَلَـٰغࣰا مِّنَ ٱللَّهِ وَرِسَـٰلَـٰتِهِۦ﴾: لَكِنْ أمْلِكُ أنْ أبَلِّغَكُم عَنِ اللهِ ما أمَرَنِي بِتَبْلِيغِهِ لَكُم."
  72,24,"﴿مَا يُوعَدُونَ﴾: ما يَعِدُهُم رَبُّهُم.﴿نَاصِرࣰا﴾: مُعِينًا.﴿عَدَدࣰا﴾: جُنْدًا."
  72,25,"﴿إِنۡ أَدۡرِيٓ﴾: ما أعْلَمُ.﴿مَّا تُوعَدُونَ﴾: ما يَعِدُكُم رَبُّكُم مِنَ العَذابِ وقِيامِ السّاعةِ.﴿أَمَدًا﴾: مُدَّةً طَوِيلَةً."
  72,26,"﴿ٱلۡغَيۡبِ﴾: ما غابَ عَنِ الأبْصارِ.﴿فَلَا يُظۡهِرُ﴾: فلا يُطْلِعُ."
  72,27,"﴿إِلَّا مَنِ ٱرۡتَضَىٰ مِن رَّسُولࣲ﴾: إلّا مَن اختارهم اللهُ لِرسالَتِهِ، فَإنَّه يُطْلِعُهُم عَلى بَعْضِ الغَيبِ.﴿يَسۡلُكُ مِنۢ بَيۡنِ يَدَيۡهِ وَمِنۡ خَلۡفِهِۦ رَصَدࣰا﴾: يُرْسِلُ مِن أمامِ الرَّسُولِ ومِن خَلْفِهِ ملائِكَةً يحفَظُونَهُ مِنَ الِجنِّ؛ لِئلّا يَسْتَرِقُوهُ ويَهْمِسُوا بِهِ إلى الكَهَنَةِ."
  72,28,"﴿وَأَحَاطَ بِمَا لَدَيۡهِمۡ﴾: وعَلِمَ اللهُ بِكُلِّ ما عَنْدَهُم.﴿وَأَحۡصَىٰ كُلَّ شَيۡءٍ عَدَدَۢا﴾: عَلِمَ اللهُ عَدَدَ الأَشْياءِ كُلِّها."
