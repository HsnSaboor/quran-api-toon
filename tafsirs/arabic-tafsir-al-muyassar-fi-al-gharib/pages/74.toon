tafsir[52]{c,v,t}:
  74,1,"﴿ٱلۡمُدَّثِّرُ﴾: المتَغَطِّي بِثِيابِهِ."
  74,2,"﴿قُمۡ﴾: أي مِن مَّضْجَعِكَ.﴿فَأَنذِرۡ﴾: فَحَذِّر النّاس مِن عَذابِ اللهِ."
  74,3,"﴿وَرَبَّكَ فَكَبِّرۡ﴾: وخُصَّ رَبَّكَ وحْدَهُ بالتَّعْظِيمِ والعِبادَةِ."
  74,4,"﴿وَثِيَابَكَ فَطَهِّرۡ﴾: أي مِنَ النَّجاساتِ."
  74,5,"﴿وَٱلرُّجۡزَ فَٱهۡجُرۡ﴾: ودُمْ على هَجْر أعْمالِ الشِّرْكِ كُلِّها."
  74,6,"﴿وَلَا تَمۡنُن تَسۡتَكۡثِرُ﴾: ولا تُعْطِ العَطِيَّةَ؛ كَي تَلْتَمِسَ أكْثَرَ مِنها."
  74,7,"﴿وَلِرَبِّكَ فَٱصۡبِرۡ﴾: ولِمَرْضاةِ رَبِّكَ فاصْبِرْ عَلى الأَوامِرِ والنَّواهِي."
  74,8,"﴿نُقِرَ﴾: نُفِخَ نَفْخَةَ البعثِ والنُّشُورِ.﴿ٱلنَّاقُورِ﴾: القَرْنِ الَّذِي يُنْفَخُ فِيهِ."
  74,10,"74:9"
  74,11,"﴿ذَرۡنِي وَمَنۡ خَلَقۡتُ وَحِيدࣰا﴾: دَعْنِي -أيُّها الرَّسُولُ- أنا والَّذِي خَلَقْتُه في بَطْنِ أُمِّهِ وحِيدًا لا مالَ لَهُ ولا ولدَ."
  74,12,"﴿مَّمۡدُودࣰا﴾: مبسُوطًا واسِعًا."
  74,13,"﴿شُهُودࣰا﴾: حاضِرِينَ مَعَهُ في «مكَّةَ» لا يغِيبُونَ عَنْهُ."
  74,14,"﴿وَمَهَّدتُّ لَهُۥ﴾: ويَسَّرتُ لَهُ سُبُلَ العيشِ."
  74,15,"﴿أَنۡ أَزِيدَ﴾: أي في مالِهِ ووَلَدِهِ."
  74,16,"﴿كَلَّآ﴾: ليس الأمرُ كما يَزْعُمُ.﴿لِـَٔايَـٰتِنَا﴾: للقرآنِ.﴿عَنِيدࣰا﴾: معانِدًا مُكَذِّبًا."
  74,17,"﴿سَأُرۡهِقُهُۥ﴾: سَأُكَلِّفُه.﴿صَعُودًا﴾: مَشَقَّةً مِنَ العذابِ."
  74,18,"﴿فَكَّرَ﴾: في نَفْسِهِ.﴿وَقَدَّرَ﴾: وهَيَّأ ما يقُولُه مِنَ الطَّعنِ في مُحَمَّدٍ ﷺ والقرآنِ."
  74,19,"﴿فَقُتِلَ﴾: فَلُعِنَ، واسْتَحَقَّ بِذَلِكَ الهَلاكَ.﴿كَيۡفَ قَدَّرَ﴾: كَيفَ أعَدَّ في نفسهِ هَذا الطَّعْنَ."
  74,21,"﴿نَظَرَ﴾: تَأَمَّلَ فيما قَدَّرَ وهَيَّأَ مِنَ الطَّعْنِ في القرآنِ."
  74,22,"﴿عَبَسَ﴾: قَطَّبَ وجْهَهُ.﴿وَبَسَرَ﴾: واشْتَدَّ في العُبُوسِ."
  74,23,"﴿أَدۡبَرَ﴾: رَجَعَ مُعْرِضًا عَنِ الحقِّ.﴿وَٱسۡتَكۡبَرَ﴾: وتَعاظَمَ أن يَعْتَرِفَ بِهِ."
  74,24,"﴿إِنۡ هَـٰذَآ﴾: ما الَّذِي يَقُولُه مُحَمَّدٌ.﴿يُؤۡثَرُ﴾: يُنْقلُ عَنِ الأوّلِينَ."
  74,25,"﴿قَوۡلُ ٱلۡبَشَرِ﴾: كلامُ المخلُوقيِنَ، تَعَلَّمَهُ مُحَمَّدٌ مِنهُم، ثُمَّ ادَّعى أنَّهُ مِن عندِ اللهِ."
  74,26,"﴿سَأُصۡلِيهِ﴾: سَأُدْخِلُهُ.﴿سَقَرَ﴾: جَهَنَّمَ."
  74,27,"﴿وَمَآ أَدۡرَىٰكَ﴾: وما أعلَمَكَ.﴿مَا سَقَرُ﴾: أيُّ شَيءٍ جَهَنَّمُ؟"
  74,28,"﴿لَا تُبۡقِي﴾: لا تَتْرُكُ مِن أجْزاءِ المُعَذَّبِينَ شَيئًا.﴿وَلَا تَذَرُ﴾: ولا تَتْرُكُ مَن فيها مَيِّتًا، ولَكِنَّها تُحْرِقُهُم كُلَّما جُدِّدَ خَلْقُهُم."
  74,29,"﴿لَوَّاحَةࣱ﴾: حَرّاقَةٌ، مُغيِّرةٌ، مُسَوِّدةٌ.﴿لِّلۡبَشَرِ﴾: للجُلودِ، مُفْردُها: بَشَرةٌ."
  74,30,"﴿عَلَيۡهَا﴾: يَلِي أمَر جَهَنَّمَ ويَتَسَلَّطُ على أهْلِها بالعَذابِ.﴿تِسۡعَةَ عَشَرَ﴾: مَلَكًا مِنَ الزَّبانِيَةِ الأَشِداءِ."
  74,31,"﴿أَصۡحَـٰبَ ٱلنَّارِ﴾: خَزَنَةَ النّارِ.﴿عِدَّتَهُمۡ﴾: ذِكْرَ عَدَدِهِم.﴿فِتۡنَةࣰ﴾: اخْتِبارًا.﴿لِيَسۡتَيۡقِنَ﴾: وليَحْصُلَ اليقِينُ.﴿ٱلَّذِينَ أُوتُواْ ٱلۡكِتَـٰبَ﴾: اليهُودُ والنَّصارى.﴿وَلَا يَرۡتَابَ﴾: ولا يَشُكَّ.﴿مَّرَضࣱ﴾: نِفاقٌ.﴿مَاذَآ أَرَادَ ٱللَّهُ بِهَـٰذَا مَثَلࣰا﴾: ما الَّذِي أرادَهُ اللهُ بِهذا العَدَدِ؟﴿كَذَ ٰ⁠لِكَ﴾: بِمِثْلِ ذَلِكَ الَّذِي ذُكِرَ.﴿جُنُودَ رَبِّكَ﴾: عَدَدَهُم.﴿هِيَ﴾: النّارُ.﴿ذِكۡرَىٰ﴾: تَذْكِرَةٌ ومَوْعِظَةٌ."
  74,32,"﴿كَلَّا﴾: ليسَ الأمرُ كَما ذَكَرُوا."
  74,33,"﴿إِذۡ أَدۡبَرَ﴾: حِينَ ولّى وذَهَبَ."
  74,34,"﴿أَسۡفَرَ﴾: أضاءَ."
  74,35,"﴿إِنَّهَا﴾: إنَّ النّارَ.﴿ٱلۡكُبَرِ﴾: العَظائِمِ."
  74,36,"﴿نَذِيرࣰا﴾: إنْذارًا وتَخْوِيفًا."
  74,37,"﴿يَتَقَدَّمَ﴾: يَتَقَرَّبَ إلى رَبِّهِ بِفِعْلِ الطّاعاتِ.﴿أَوۡ يَتَأَخَّرَ﴾: بِفِعْلِ المعاصِي."
  74,38,"﴿بِمَا كَسَبَتۡ﴾: مِن أعْمالِ الخيرِ والشَّرِ.﴿رَهِينَةٌ﴾: مَحْبُوسَةٌ مَرْهُوَنةٌ بِكَسْبِها."
  74,39,"﴿إِلَّآ أَصۡحَـٰبَ ٱلۡيَمِينِ﴾: وهم المسْلِمُونَ المخلِصُونَ."
  74,40,"﴿يَتَسَآءَلُونَ﴾: يَسْأَلُ بَعْضُهُم بَعْضًا."
  74,41,"﴿عَنِ ٱلۡمُجۡرِمِينَ﴾: عَنِ الكافِرِينَ الَّذينَ أجْرمُوا في حَقِّ أنْفُسِهِم."
  74,42,"﴿مَا سَلَكَكُمۡ﴾: ما الَّذِي أدْخَلَكُم.﴿سَقَرَ﴾: جَهَنَّمَ."
  74,44,"74:43"
  74,45,"﴿نَخُوضُ﴾: نَتَحَدَّثُ بالباطِلِ.﴿مَعَ ٱلۡخَآئِضِينَ﴾: مَعَ أهْلِ الضَّلالةِ."
  74,47,"74:46"
  74,48,"﴿شَفَـٰعَةُ﴾: طَلَبُ قَضاءِ حاجَةِ المشْفُوعِ لَهُ عِنْدَ المَشْفُوعِ عنْدَهُ.﴿ٱلشَّـٰفِعِينَ﴾: الملائِكَةِ والنَّبِيِّينَ وغَيرِهِم."
  74,49,"﴿فَمَا لَهُمۡ﴾: فما لِهؤُلاءِ المشْرِكِينَ.﴿عَنِ ٱلتَّذۡكِرَةِ﴾: عَنِ القُرآنِ وما فِيهِ مِنَ المواعِظِ.﴿مُعۡرِضِينَ﴾: مُنْصَرِفِينَ."
  74,50,"﴿حُمُرࣱ﴾: حُمُرٌ وحْشِيِّةٌ.﴿مُّسۡتَنفِرَةࣱ﴾: شَدِيَدُة النِّفارِ."
  74,51,"﴿قَسۡوَرَةِۭ﴾: أسَدٍ كاسِرٍ."
  74,52,"﴿صُحُفࣰا﴾: كُتُبًا.﴿مُّنَشَّرَةࣰ﴾: مَفْتُوحَةً مَقْرُوءَةً."
  74,53,"﴿كَلَّا﴾: ليسَ الأمرُ كَما زَعَمُوا.﴿لَّا يَخَافُونَ ٱلۡـَٔاخِرَةَ﴾: لا يُصَدِّقُونَ بالبَعْثِ والجزاءِ."
  74,54,"﴿كَلَّآ﴾: حَقًّا.﴿إِنَّهُۥ﴾: إنَّ القُرآنَ.﴿تَذۡكِرَةࣱ﴾: مَوْعِظَةٌ بَلِيغَةٌ كافِيَةٌ لاتِّعاظِهِم."
  74,55,"﴿ذَكَرَهُۥ﴾: اتَّعظَ بِما فِيهِ وانْتَفَعَ بِهُداهُ."
  74,56,"﴿وَمَا يَذۡكُرُونَ﴾: وما يَتَّعِظُونَ بِه.﴿أَهۡلُ ٱلتَّقۡوَىٰ﴾: المسْتَحِقُّ لِأَن يُتَّقى ويُطاعَ.﴿وَأَهۡلُ ٱلۡمَغۡفِرَةِ﴾: والجديرُ بأن يَغْفِرَ لِمَن آمنَ بِهِ وأطاعَهُ."
