tafsir[85]{c,v,t}:
  15,1,"﴿مُّبِينࣲ﴾: واضحٍ في معانِيه وأحكامِه."
  15,2,"﴿رُّبَمَا﴾: أي: رُبَّ شيءٍ، وهو حرفٌ يَدُلُّ على أنّ ما بعدَه قليلُ الحصولِ.﴿يَوَدُّ﴾: يتمنّى."
  15,3,"﴿ذَرۡهُمۡ﴾: اترُكْ أيُّها الرسولُ الكفارَ.﴿وَيَتَمَتَّعُواْ﴾: يَسْتَمْتِعُوا بعيشِهم في الحياةِ الدنيا.﴿وَيُلۡهِهِمُ﴾: يَشْغَلْهم.﴿ٱلۡأَمَلُ﴾: رجاءُ البقاءِ في الدُّنيا والطمعِ فيها."
  15,4,"﴿كِتَابࣱ﴾: أجَلٌ.﴿مَّعۡلُومࣱ﴾: مُقَدَّرٌ ومُحَدَّدٌ لإهلاكِها."
  15,5,"﴿وَمَا يَسۡتَـٔۡخِرُونَ﴾: لا يتأخَّرُون عن موعدِ هلاكِهم."
  15,6,"﴿ٱلذِّكۡرُ﴾: القرآنُ."
  15,7,"﴿لَّوۡ مَا﴾: هَلّا، حَضُّوه على هذا الفِعْلِ؛ لتشهدَ الملائكةُ على صِدْقِه."
  15,8,"﴿بِٱلۡحَقِّ﴾: بالعذابِ الذي قدَّره اللهُ.﴿مُّنظَرِينَ﴾: مُؤَخَّرِين ومُمْهَلِين."
  15,9,"﴿لَحَـٰفِظُونَ﴾: نتكَفَّلُ بحِفْظِه من الزيادةِ أو النقصِ أو التحريفِ أو التبديلِ."
  15,10,"﴿شِيَعِ ٱلۡأَوَّلِينَ﴾: فِرَقِ الأمم السابقةِ."
  15,12,"﴿كَذَ ٰ⁠لِكَ﴾: كما أدخَلْنا التكذيبَ والاستهزاءَ في قلوبِ الأممِ السابقةِ.﴿نَسۡلُكُهُۥ﴾: نُدْخِلُه."
  15,13,"﴿خَلَتۡ﴾: مَضَتْ.﴿سُنَّةُ ٱلۡأَوَّلِينَ﴾: ما جَرى به قضاءُ الله وحُكْمُه من إهلاكِ المكذِّبين."
  15,14,"﴿يَعۡرُجُونَ﴾: يَصْعَدُون، فيَرَوْن عجائبَ مَلَكوتِ اللهِ."
  15,15,"﴿سُكِّرَتۡ﴾: سُدَّتْ ومُنِعَتْ عن الإبصارِ."
  15,16,"﴿بُرُوجࣰا﴾: منازلَ للكواكبِ السيّارةِ تَنْزِلُ بها."
  15,17,"﴿رَّجِيمٍ﴾: مَرْجومٍ، أي: مَطْرودٍ من رحمةِ اللهِ."
  15,18,"﴿ٱسۡتَرَقَ ٱلسَّمۡعَ﴾: خَطِفَ المسموعَ من كلامِ الملأِ الأعلى.﴿فَأَتۡبَعَهُۥ﴾: لَحِقَه.﴿شِهَابࣱ﴾: شُعْلَةُ نارٍ تُرى هابطةً من السماءِ.﴿مُّبِينࣱ﴾: منيرٌ واضحٌ."
  15,19,"﴿وَٱلۡأَرۡضَ مَدَدۡنَـٰهَا﴾: بَسَطَها اللهُ، وهَيَّأها للاستقرار والعيشِ فيها.﴿رَوَ ٰ⁠سِيَ﴾: جِبالًا تُثَبِّتُها.﴿مَّوۡزُونࣲ﴾: مُقَدَّرٍ بمقدارٍ معيَّنٍ."
  15,20,"﴿مَعَـٰيِشَ﴾: ما تَعيشُون به من الأرزاقِ."
  15,21,"﴿عِندَنَا خَزَآئِنُهُۥ﴾: قادِرُون على إيجادِه وتدبيرِه والإنعامِ به من جميعِ الأصنافِ.﴿بِقَدَرࣲ مَّعۡلُومࣲ﴾: بمقدارٍ مُحَدَّدٍ."
  15,22,"﴿لَوَ ٰ⁠قِحَ﴾: حَواملَ للسَّحابِ ولِلَقاحِ الشجَرِ، أو مُلقِّحاتٍ للسَّحابِ وللأشجارِ.﴿وَمَآ أَنتُمۡ لَهُۥ بِخَـٰزِنِينَ﴾: لَسْتم بقادرين على حِفْظِ الماءِ وادِّخاره."
  15,23,"﴿ٱلۡوَ ٰ⁠رِثُونَ﴾: للأرضِ ومَن عليها؛ لأنه سبحانه هو الباقي بعد فَناءِ الخَلْقِ."
  15,24,"﴿ٱلۡمُسۡتَقۡدِمِينَ﴾: الذين ماتُوا من لَدُنْ آدمَ عليه السَّلامُ.﴿ٱلۡمُسۡتَـٔۡخِرِينَ﴾: الأحياءَ، ومَن سيأتي إلى يوم القيامة."
  15,26,"﴿صَلۡصَـٰلࣲ﴾: طينٍ يابسٍ غيرِ مطبوخٍ، يُسْمَعُ له صَلْصَلةٌ، أي: صوتٌ حين النَّقْرِ عليه.﴿حَمَإࣲ﴾: طينٍ أسودَ.﴿مَّسۡنُونࣲ﴾: متغيِّرِ اللونِ والرائحةِ، أو مُصَوَّرٍ صورةَ إنسانٍ."
  15,27,"﴿وَٱلۡجَآنَّ﴾: أبا الجنِّ، وهو إبليسُ.﴿مِن قَبۡلُ﴾: من قَبْلِ خَلْقِ آدمَ.﴿نَّارِ ٱلسَّمُومِ﴾: نارٍ شديدةِ الحرارةِ لا دُخانَ لها."
  15,29,"﴿سَوَّيۡتُهُۥ﴾: أكمَلْتُ صورتَه، وأتممتُ خَلْقَه.﴿مِن رُّوحِي﴾: ما به حياتُه بأمري، فصارَ بَشَرًا.﴿سَـٰجِدِينَ﴾: سجودَ تحيةٍ وتكريمٍ."
  15,31,"﴿أَبَىٰٓ﴾: امتنعَ."
  15,32,"﴿مَا لَكَ﴾: ما مَنعَكَ."
  15,34,"﴿رَجِيمࣱ﴾: مَرْجُومٌ، أي: مَطْرودٌ من رحمةِ اللهِ."
  15,35,"﴿ٱللَّعۡنَةَ﴾: غَضَبَ اللهِ وسُخْطَه، والبعدَ من رحمتِه.﴿ٱلدِّينِ﴾: الجزاءِ والحِسابِ."
  15,36,"﴿فَأَنظِرۡنِيٓ﴾: أخِّرْني وأمْهِلْني."
  15,38,"﴿ٱلۡوَقۡتِ ٱلۡمَعۡلُومِ﴾: حين تموتُ الخلائقُ، وهو النَّفْخَةُ الأولى."
  15,39,"﴿بِمَآ أَغۡوَيۡتَنِي﴾: فبسببِ إضلالِك لي.﴿لَأُزَيِّنَنَّ لَهُمۡ﴾: لَأُحَسِّنَنَّ لذريَّةِ آدمَ المعاصيَ.﴿وَلَأُغۡوِيَنَّهُمۡ﴾: لَأَحْمِلنَّهم على تَرْكِ الهدى والرَّشادِ."
  15,40,"﴿ٱلۡمُخۡلَصِينَ﴾: المختارِين من عبادِك لطاعتِك."
  15,41,"﴿صِرَ ٰ⁠طٌ عَلَيَّ﴾: طريقٌ حقٌّ عليَّ أن أُراعِيَه."
  15,42,"﴿سُلۡطَـٰنٌ﴾: تَسَلُّطٌ.﴿ٱلۡغَاوِينَ﴾: الضالِّين والمُشْركين."
  15,44,"﴿جُزۡءࣱ مَّقۡسُومٌ﴾: نصيبٌ معيَّنٌ مَتميِّزٌ عن غيرِه بحسَبِ أعمالِهم."
  15,46,"﴿بِسَلَـٰمٍ﴾: سالمين من كلِّ سوءٍ."
  15,47,"﴿وَنَزَعۡنَا﴾: أذْهَبَ الله تعالى.﴿غِلٍّ﴾: حِقْدٍ وعَداوةٍ كانَتْ من بعضِهم في الدُّنيا.﴿مُّتَقَـٰبِلِينَ﴾: تتقابلُ وُجوهُهم؛ لمِا هم فيه من المحبةِ والتواصُلِ."
  15,48,"﴿نَصَبࣱ﴾: تَعَبٌ وإعياءٌ."
  15,49,"﴿نَبِّئۡ﴾: أخْبِرْ."
  15,50,"﴿ٱلۡأَلِيمُ﴾: المؤلمُ الموجِعُ."
  15,51,"﴿ضَيۡفِ إِبۡرَ ٰ⁠هِيمَ﴾: ضيوفِه عليه السلامُ من الملائكةِ الكرامِ."
  15,52,"﴿وَجِلُونَ﴾: خائفون فَزِعُون."
  15,53,"﴿عَلِيمࣲ﴾: ذي عِلْمٍ كثيرٍ، وهو إسحاقُ."
  15,54,"﴿عَلَىٰٓ أَن مَّسَّنِيَ ٱلۡكِبَرُ﴾: مع حالةِ كِبَرِ السِّنِّ."
  15,55,"﴿بِٱلۡحَقِّ﴾: بالخبرِ اليقينِ الذي لا شَكَّ فيه.﴿ٱلۡقَـٰنِطِينَ﴾: اليائسين من الوَلَدِ."
  15,56,"﴿ٱلضَّآلُّونَ﴾: البعيدون عن الحقِّ والصَّوابِ."
  15,57,"﴿فَمَا خَطۡبُكُمۡ﴾: ما أمْرُكم الخطيرُ الذي جِئْتُم من أجلِه؟"
  15,59,"﴿إِلَّآ ءَالَ لُوطٍ﴾: إلّا لوطًا وأهلَه المؤمنين به."
  15,60,"﴿قَدَّرۡنَآ﴾: قَضَيْنا وحَكَمْنا بأمرِ اللهِ.﴿ٱلۡغَـٰبِرِينَ﴾: الباقين في العذابِ."
  15,61,"﴿ءَالَ لُوطٍ﴾: أي: لوطًا عليه السلامُ."
  15,62,"﴿قَوۡمࣱ مُّنكَرُونَ﴾: لا أعْرِفُكم."
  15,63,"﴿فِيهِ يَمۡتَرُونَ﴾: يَشُكُّون في نزول العذاب بهم."
  15,64,"﴿بِٱلۡحَقِّ﴾: بالخبرِ اليقينِ الذي لا شَكَّ فيه."
  15,65,"﴿فَأَسۡرِ بِأَهۡلِكَ﴾: فاخرُجْ أنت وأهلُك المؤمنون.﴿بِقِطۡعࣲ مِّنَ ٱلَّيۡلِ﴾: بآخِر الليلِ.﴿وَٱتَّبِعۡ أَدۡبَـٰرَهُمۡ﴾: وسِرْ أنت وراءهم؛ لئلا يَتَخَلَّفَ منهم أحدٌ فيَهْلِكَ."
  15,66,"﴿وَقَضَيۡنَآ إِلَيۡهِ﴾: أوْحَيْنا إلى لوطٍ.﴿دَابِرَ هَـٰٓؤُلَآءِ مَقۡطُوعࣱ﴾: آخرَهم، والمرادُ: جميعُ قومِك مُهْلَكون، لايبقى منهم أحدٌ.﴿مُّصۡبِحِينَ﴾: وقتَ الصباحِ."
  15,67,"﴿يَسۡتَبۡشِرُونَ﴾: يُظْهِرُون سرورَهم؛ طَمَعًا في فِعْل الفاحِشَةِ."
  15,68,"﴿ضَيۡفِي﴾: ضُيوفي.﴿فَلَا تَفۡضَحُونِ﴾: لا تُظْهروا ما يُوجبُ العارَ لي."
  15,69,"﴿وَلَا تُخۡزُونِ﴾: لا تُوقعوني في الذُّل والهَوانِ؛ بإيذائِكم لضيوفي."
  15,70,"﴿عَنِ ٱلۡعَـٰلَمِينَ﴾: عن ضيافَةِ أحدٍ من الناسِ أو حمايتهِ."
  15,71,"﴿هَـٰٓؤُلَآءِ بَنَاتِيٓ﴾: نساؤُكم بناتي فتزوَّجوهنَّ."
  15,72,"﴿لَعَمۡرُكَ﴾: قَسَمٌ من اللهِ بحياةِ النبيِّ عليه الصلاة والسلام؛ تشريفًا له.﴿سَكۡرَتِهِمۡ﴾: ضَلالَتِهم وشِدَّةِ محبَّتِهم الفاحشةَ التي أزالَتْ عقولَهم.﴿يَعۡمَهُونَ﴾: يترَدَّدُون مُتَحَيِّرين."
  15,73,"﴿ٱلصَّيۡحَةُ﴾: الصوتُ الشديدُ المُهْلِكُ.﴿مُشۡرِقِينَ﴾: وقتَ شُروقِ الشمسِ."
  15,74,"﴿وَأَمۡطَرۡنَا﴾: أرسَلْنا.﴿سِجِّيلٍ﴾: طينٍ مُتَحَجِّرِ."
  15,75,"﴿لَـَٔايَـٰتࣲ﴾: لَدلائلَ وعِظاتٍ.﴿لِّلۡمُتَوَسِّمِينَ﴾: الناظرين المُعْتَبِرين."
  15,76,"﴿وَإِنَّهَا﴾: قُرى قومِ لوطٍ.﴿لَبِسَبِيلࣲ﴾: طريقٍ.﴿مُّقِيمٍ﴾: ثابتٍ واضحٍ، يَمُرُّ بها الناسُ ويَرَوْن آثارَها."
  15,77,"﴿لَـَٔايَةࣰ﴾: لَدلالةً وعِبْرَةً."
  15,78,"﴿أَصۡحَـٰبُ ٱلۡأَيۡكَةِ﴾: سكانُ مِنطَقَةِ الشجرِ الكثيرِ المُلتفِّ، وهم قومُ شعيبٍ عليه السلام."
  15,79,"﴿وَإِنَّهُمَا﴾: قرى قومِ لوطٍ، ومساكنَ قومِ شعيبٍ.﴿لَبِإِمَامࣲ مُّبِينࣲ﴾: طريقٍ واضحٍ، يَأْتمُّ به أهلُ القوافل، ويَسْلُكونه في سَفَرهم."
  15,80,"﴿أَصۡحَـٰبُ ٱلۡحِجۡرِ﴾: سكانُ وادٍ بين المدينةِ والشّامِ، وهم ثمودُ.﴿ٱلۡمُرۡسَلِينَ﴾: أي: صالحًا؛ لأنّ مَن كذَّبَ نبيًّا فقد كَذَّبهم جميعًا."
  15,81,"﴿ءَايَـٰتِنَا﴾: أدلَّتَنا وحُجَجَنا الدالَّهَ على صِدْقِ نبيِّهم، ومنها الناقةُ.﴿مُعۡرِضِينَ﴾: صادِّين عنها، لا يتفكرون."
  15,83,"﴿ٱلصَّيۡحَةُ﴾: الصوتُ الشديدُ المُهلِكُ.﴿مُصۡبِحِينَ﴾: وقتَ الصَّباحِ."
  15,84,"﴿فَمَآ أَغۡنَىٰ﴾: ما دَفَعَ عنهم العذابَ.﴿مَّا كَانُواْ يَكۡسِبُونَ﴾: ما حَصَّلُوه من بناءِ البيوتِ والحُصونِ في الجبالِ، وجَمْعِ الأموالِ."
  15,85,"﴿ٱلصَّفۡحَ ٱلۡجَمِيلَ﴾: أي: الحَسَنَ، الذي لا أذِيَّةَ فيه."
  15,87,"﴿سَبۡعࣰا مِّنَ ٱلۡمَثَانِي﴾: الفاتحةَ، وهي سبعُ آياتٍ تتكرَّر في كلِّ صلاةٍ."
  15,88,"﴿لَا تَمُدَّنَّ عَيۡنَيۡكَ﴾: لا تَطْمَحْ ببصَرِك.﴿إِلَىٰ مَا مَتَّعۡنَا بِهِۦٓ﴾: إلى ما عندَ غيرِك من حُطامِ الدنيا وزِينتِها.﴿أَزۡوَ ٰ⁠جࣰا﴾: أصنافًا.﴿وَٱخۡفِضۡ جَنَاحَكَ﴾: وتواضَعْ وأَلِنْ جانبَك."
  15,90,"﴿كَمَآ أَنزَلۡنَا﴾: أُنذِرُكم عذابَ اللهِ كما أنزلَه.﴿ٱلۡمُقۡتَسِمِينَ﴾: اليهودِ والنصارى وغيرِهم الذين قسَّمُوا القرآنَ، فآمنوا ببعضِه وكفرُوا ببعضٍ."
  15,91,"﴿عِضِينَ﴾: أجزاءً وأقسامًا؛ ليوافِقَ أهواءَهم."
  15,92,"﴿لَنَسۡـَٔلَنَّهُمۡ﴾: سُؤالَ توبيخٍ، فلَنُحاسِبَنَّهم ولَنَجْزِيَنَّهم."
  15,94,"﴿فَٱصۡدَعۡ بِمَا تُؤۡمَرُ﴾: اجهَرْ بدعوةِ الحقِّ وأظْهِرْها."
  15,96,"15:95"
  15,97,"﴿يَضِيقُ صَدۡرُكَ﴾: يَنْقَبِضُ ألمًا وحُزْنًا."
  15,98,"﴿ٱلسَّـٰجِدِينَ﴾: المُصَلِّين العابِدين."
  15,99,"﴿ٱلۡيَقِينُ﴾: الموتُ، المتيقَّنُ حُدوثُه."
