tafsir[52]{c,v,t}:
  30,2,"30:1"
  30,3,"﴿أَدۡنَى ٱلۡأَرۡضِ﴾: أقْرَبِ أرْضِ الشّامِ إلى فارِس.﴿غَلَبِهِمۡ﴾: أي: كَوْنِهِم مَغْلُوبِينَ."
  30,4,"﴿بِضۡعِ سِنِينَ﴾: أي: ما بينَ الثَّلاثَةِ إلى العَشْرَةِ"
  30,6,"30:5"
  30,7,"﴿ظَـٰهِرࣰا مِّنَ ٱلۡحَيَوٰةِ ٱلدُّنۡيَا﴾: فَيَنْظُرُونَ إلى الأسْبابِ الظّاهِرَةِ ولا يَنْظُرُونَ إلى مُسَبِّبِها المتَصَرِّفِ فِيها الَّذي هُوَ اللهُ تَعالى."
  30,8,"﴿أَوَ لَمۡ يَتَفَكَّرُواْ﴾: أوَلَمْ يَتَأَمَّلُوا ويَتَدَبَّرُوا.﴿أَجَلࣲ مُّسَمࣰّى﴾: وقْتٍ مُقَدَّرٍ هُوَ يومُ القِيامَةِ.﴿بِلِقَآيِٕ رَبِّهِمۡ﴾: المُرادُ به البَعْثُ بَعْدَ الموتِ."
  30,9,"﴿عَـٰقِبَةُ ٱلَّذِينَ مِن قَبۡلِهِمۡ﴾: أي: مَصِيرُهُم الَّذي انْتهَوا إليهِ.﴿وَأَثَارُواْ ٱلۡأَرۡضَ﴾: حَرَثُوها للزِّراعَةِ.﴿وَعَمَرُوهَآ﴾: أي: بالبُنْيانِ والزِّراعَةِ.﴿بِٱلۡبَيِّنَـٰتِ﴾: بالبَراهِينِ الواضِحةِ، ومنها المُعْجِزاتُ الحِسِّيةُ."
  30,10,"﴿ٱلسُّوٓأَىٰٓ﴾: تَأْنِيثُ «الأسْوأ»، ومعناها: العُقُوبَةُ المتناهِيةُ في السُّوءِ، وهي نارُ جَهَنَّم."
  30,11,"﴿يَبۡدَؤُاْ﴾: يُنْشِئُ ابتِداءً.﴿يُعِيدُهُۥ﴾: يُعِيدُ الخَلْقَ مِن بَعْدِ فَنائِهِ."
  30,12,"﴿يُبۡلِسُ ٱلۡمُجۡرِمُونَ﴾: يَيْئَسُونَ بانْقِطاعِ حُجَّتِهِم."
  30,13,"﴿مِّن شُرَكَآئِهِمۡ﴾: أي: مِن آلهَتِهِم الَّتي كانُوا يَعْبُدُونَها مِن دُونِ اللهِ."
  30,14,"﴿يَتَفَرَّقُونَ﴾: أي: فَرِيقٌ في الجنَّة، وفَرِيقٌ في السَّعِيرِ."
  30,15,"﴿رَوۡضَةࣲ﴾: المرادُ بِها هُنا «الجنَّةُ».﴿يُحۡبَرُونَ﴾: يُكَرَّمُونَ ويُنَعَّمُونَ."
  30,16,"﴿وَلِقَآيِٕ ٱلۡـَٔاخِرَةِ﴾: أي: البَعْثِ بَعْدَ الموتِ.﴿فِي ٱلۡعَذَابِ مُحۡضَرُونَ﴾: مُقيمُونَ فِيهِ."
  30,17,"﴿فَسُبۡحَـٰنَ ٱللَّهِ﴾: أي: فنزِّهُوهُ عمّا لا يَلِيقُ بِه.﴿حِينَ تُمۡسُونَ﴾: أي: وقْتَ دُخُولِكُم في المساءِ.﴿وَحِينَ تُصۡبِحُونَ﴾: أي: وقْتَ دُخُولِكَمُ في الصَّباحِ."
  30,18,"﴿وَعَشِيࣰّا﴾: وقْتَ العَشِيِّ، أي: بَعْدَ زَوالِ الشَّمسِ.﴿وَحِينَ تُظۡهِرُونَ﴾: أي: وقْتَ الظَّهِيَرةِ."
  30,19,"﴿بَعۡدَ مَوۡتِهَا﴾: أي: قَحْطِها وجَفافِها.﴿تُخۡرَجُونَ﴾: أي: تُبعثُونَ مِن قُبُورِكُم."
  30,20,"﴿تَنتَشِرُونَ﴾: تَتَفَرَّقُونَ."
  30,21,"﴿مِّنۡ أَنفُسِكُمۡ﴾: مِن جِنْسِكُم.﴿لِّتَسۡكُنُوٓاْ إِلَيۡهَا﴾: لِتألَفُوها وتَطْمئنُّوا إلَيها.﴿مَّوَدَّةࣰ وَرَحۡمَةً﴾: مَحَبَّةً وشَفَقَةً.﴿يَتَفَكَّرُونَ﴾: يَتَدَبَّرُونَ."
  30,22,"﴿أَلۡسِنَتِكُمۡ﴾: لُغاتِكُم."
  30,23,"﴿ٱبۡتِغَآؤُكُم﴾: طَلَبُكُم والتِماسُكُم.﴿مِّن فَضۡلِهِۦٓ﴾: مِن رِزْقِه."
  30,24,"﴿خَوۡفࣰا وَطَمَعࣰا﴾: أي: خَوْفًا مِنَ الصَّواعِقِ وطَمعًا في الغَيثِ.﴿بَعۡدَ مَوۡتِهَآ﴾: بَعْدَ قَحْطِها وجَفافِها."
  30,25,"﴿بِأَمۡرِهِۦ﴾: بِإرادَتِه وقُدْرَتِهِ.﴿تَخۡرُجُونَ﴾: أي: مِن قُبُورِكُم أحْياءً."
  30,26,"﴿لَّهُۥ قَـٰنِتُونَ﴾: مُنْقادُونَ لإرادَتِه."
  30,27,"﴿يَبۡدَؤُاْ﴾: يُنْشِئُ.﴿أَهۡوَنُ﴾: هيِّنٌ ويَسِيرُ.﴿ٱلۡمَثَلُ ٱلۡأَعۡلَىٰ﴾: الوصْفُ الأَعْلى."
  30,28,"﴿مَلَكَتۡ أَيۡمَـٰنُكُم﴾: أي: العبِيدُ والإماءُ.﴿كَخِيفَتِكُمۡ أَنفُسَكُمۡ﴾: أي: كَما تَخافُونَ الأحْرارَ المُشابِهِينَ لَكُم في الحرِّيَّةِ وتَمَلُّكِ الأمْوالِ."
  30,30,"﴿فَأَقِمۡ وَجۡهَكَ لِلدِّينِ﴾: أي: اسْتَقِمْ واسْتَمِر عَلى دِينِ الإسْلامِ.﴿حَنِيفࣰا﴾: مائِلًا إليه مُسْتَقِيمًا عَلِيهِ، غَيْرَ مُلْتَفِتٍ إلى غَيْرِه مِنَ الأدْيانِ الباطِلَةِ.﴿فِطۡرَتَ ٱللَّهِ﴾: أي: الزَمُوا فِطْرَةَ اللهِ، وهِيَ الإسْلامُ.﴿فَطَرَ ٱلنَّاسَ عَلَيۡهَا﴾: أي: خَلَقَهُم عَلَيها."
  30,31,"﴿مُنِيبِينَ إِلَيۡهِ﴾: راجِعِينَ إليهِ بالتَّوبَةِ والإخْلاصِ."
  30,32,"﴿فَرَّقُواْ دِينَهُمۡ﴾: أي: آمَنُوا بِبَعْضٍ وكَفَرُوا بِبَعْضٍ.﴿شِيَعࣰا﴾: فِرَقًا وأحْزابًا مُخْتلِفَةً.﴿كُلُّ حِزۡبِۭ﴾: كلُّ فَرِيقٍ.﴿فَرِحُونَ﴾: مَسْرُورُونَ."
  30,33,"﴿ضُرࣱّ﴾: قَحْطٌ وشِدَّةٌ.﴿مُّنِيبِينَ إِلَيۡهِ﴾: مُلْتَجِئِينَ إليهِ بالتَّوبَةِ والإخْلاصِ.﴿أَذَاقَهُم مِّنۡهُ رَحۡمَةً﴾: أي: كَشَفَ عَنْهُم ضُرَّهُم."
  30,35,"﴿سُلۡطَـٰنࣰا﴾: بُرْهانًا أو كِتابًا."
  30,36,"﴿فَرِحُواْ بِهَا﴾: فرِحُوا بِها فَرَحَ بَطَرٍ لا فَرَحَ شُكْرٍ.﴿بِمَا قَدَّمَتۡ أَيۡدِيهِمۡ﴾: أي: بِسَبَبِ أعْمالِهِم السَّيِّئةِ.﴿يَقۡنَطُونَ﴾: يَيْئَسُونَ."
  30,37,"﴿أَوَ لَمۡ يَرَوۡاْ﴾: أي: أوَلَمْ يَعْلَمُوا.﴿وَيَقۡدِرُ﴾: يُضَيِّقُ."
  30,38,"﴿فَـَٔاتِ﴾: فأعْطِ.﴿ٱلۡمِسۡكِينَ﴾: الفَقِيرَ الَّذِي لا يَمْلِكُ ما يَكْفِيهِ ويَسُدُّ حاجَتَه.﴿ٱبۡنَ ٱلسَّبِيلِ﴾: المُسافِرَ المُحْتاجَ."
  30,39,"﴿وَمَآ ءَاتَيۡتُم﴾: وما أعطَيتُم.﴿رِّبࣰا﴾: قَرْضًا أو هَدِيَّةً بِقَصْدِ الرِّبا والزِّيادَةِ.﴿لِّيَرۡبُوَاْ﴾: لِيَزِيِدَ ويَنْمُوَ.﴿فَلَا يَرۡبُواْ﴾: فَلا يَزِيدُ.﴿ٱلۡمُضۡعِفُونَ﴾: أي: هُمْ أصْحابُ الأجْرِ المُضاعَفِ."
  30,40,"﴿مِن شُرَكَآئِكُم﴾: مِنَ آلَهتِكُم الَّتي تَعْبُدُونَها مِن دُونِ اللهِ.﴿سُبۡحَـٰنَهُۥ وَتَعَـٰلَىٰ﴾: تَنَزَّهَ اللهُ وتَقَدَّسَ."
  30,41,"﴿بِمَا كَسَبَتۡ أَيۡدِي ٱلنَّاسِ﴾: أي: بِسَبَبِ أعْمالِهِم السَّيِّئةِ.﴿بَعۡضَ ٱلَّذِي﴾: أي: عُقُوبَةَ بَعْضِ الَّذي.﴿يَرۡجِعُونَ﴾: أي: يَتُوبُونَ إلى اللهِ."
  30,43,"﴿لِلدِّينِ ٱلۡقَيِّمِ﴾: أي: نَحْوَ الدِّينِ المسْتَقِيم، وهو الإسْلامُ.﴿لَّا مَرَدَّ لَهُۥ﴾: أي: لا يقْدِرُ أحدٌ على ردِّهِ.﴿يَصَّدَّعُونَ﴾: يَتَفَرَّقُونَ، فَرِيقٌ في الجنَّةِ وفَرِيقٌ في السَّعيرِ."
  30,44,"﴿يَمۡهَدُونَ﴾: يُوَطِّئُونَ ويُهَيِّئُونَ الطَّريقَ إلى مَنازِلَ في الجنَّةِ."
  30,46,"﴿مُبَشِّرَ ٰ⁠تࣲ﴾: أي: بِنُزُولِ المَطَرِ.﴿مِّن رَّحۡمَتِهِۦ﴾: والمرادُ بها هُنا: المَطرُ.﴿ٱلۡفُلۡكُ﴾: السُّفُنُ.﴿لِتَبۡتَغُواْ﴾: لِتَطْلُبُوا."
  30,47,"﴿بِٱلۡبَيِّنَـٰتِ﴾: بالمُعْجِزاتِ والبراهِينِ الواضِحةِ.﴿ٱلَّذِينَ أَجۡرَمُواْ﴾: الَّذينَ فَعَلُوا الإجْرامَ واكْتَسَبُوا السَّيِّئاتِ."
  30,48,"﴿فَتُثِيرُ﴾: فتُحَرِّكُ وتَنْشُرُ.﴿فَيَبۡسُطُهُۥ﴾: فَيَنْشُرُه.﴿كِسَفࣰا﴾: قِطَعًا متفرِّقةً.﴿ٱلۡوَدۡقَ﴾: المطَرَ.﴿مِنۡ خِلَـٰلِهِۦ﴾: مِن فُرَجِ السَّحابِ ووَسَطِه.﴿يَسۡتَبۡشِرُونَ﴾: يَفْرَحُونَ."
  30,49,"﴿لَمُبۡلِسِينَ﴾: لَآيسِينَ مِن نُّزُولِ المطَرِ.﴿بَعۡدَ مَوۡتِهَآ﴾: بَعْدَ جَدْبِها وجَفافِها."
  30,51,"﴿رِيحࣰا﴾: أي: رِيحًا مُفْسِدَةً لِنَباتِهم.﴿فَرَأَوۡهُ مُصۡفَرࣰّا﴾: فَرَأَوُا النَّباتَ مُصْفَرًّا بَعْدَ الخُضْرَةِ.﴿لَّظَلُّواْ﴾: لَصارُوا.﴿يَكۡفُرُونَ﴾: يَجْحَدُونَ باللهِ وبنِعَمِه."
  30,52,"﴿وَلَّوۡاْ﴾: انصَرَفُوا."
  30,53,"﴿بِهَـٰدِ ٱلۡعُمۡيِ﴾: بمُرْشِدِ مَن أعْماهُ اللهُ عَنِ الحقِّ.﴿مُّسۡلِمُونَ﴾: خاضِعُونَ مُنْقادُونَ."
  30,54,"﴿مِّن ضَعۡفࣲ﴾: أي: مِن نُّطْفَةٍ ضَعِيفَةٍ.﴿مِنۢ بَعۡدِ ضَعۡفࣲ﴾: أي: مِن بَعْدِ ضَعْفِ الطُّفولَةِ والصِّغَرِ.﴿قُوَّةࣲ﴾: أي: قُوَّةِ الشَّبابِ.﴿ضَعۡفࣰا﴾: أي: ضَعْفَ الكِبَرِ والهرَمِ.﴿وَشَيۡبَةࣰ﴾: أي: بياضًا في الشَّعْرِ وضَعْفًا في قُوى الجسِمِ."
  30,55,"﴿غَيۡرَ سَاعَةࣲ﴾: غيرَ فَتْرَةِ قَصِيرةٍ مِنَ الزَّمَنِ.﴿يُؤۡفَكُونَ﴾: يُصْرَفُونَ عَنِ الحقِّ والصِّدقِ."
  30,57,"﴿مَعۡذِرَتُهُمۡ﴾: اعْتِذارُهُم.﴿وَلَا هُمۡ يُسۡتَعۡتَبُونَ﴾: لا يُطْلَبُ مِنهُم إرْضاءُ اللهِ تَعالى بالتَّوبَةِ والطّاعَةِ."
  30,58,"﴿بِـَٔايَةࣲ﴾: أي: بِأيِّ حُجَّةٍ.﴿مُبۡطِلُونَ﴾: أي: أصْحابُ أباطِيلَ."
  30,59,"﴿يَطۡبَعُ﴾: يَخْتِمُ، فلا تَعِي شيئًا مِنَ الحَقِّ."
  30,60,"﴿وَلَا يَسۡتَخِفَّنَّكَ﴾: لا يَحْمِلَنَّكَ على الخِفَّةِ وتَرْكِ الصَّبْرِ."
