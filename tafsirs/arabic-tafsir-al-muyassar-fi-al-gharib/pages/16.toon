tafsir[115]{c,v,t}:
  16,1,"﴿أَتَىٰٓ﴾: قَرُبَ ودَنا.﴿أَمۡرُ ٱللَّهِ﴾: عقابُه للمُشْركين، أو القيامةُ.﴿سُبۡحَـٰنَهُۥ﴾: تنزيهًا لله."
  16,2,"﴿بِٱلرُّوحِ﴾: بالوَحْي؛ الذي فيه الحياةُ التامَّةُ.﴿مِنۡ عِبَادِهِۦٓ﴾: الذين اختصَّهم بالرسالة.﴿أَنذِرُوٓاْ﴾: خَوِّفُوا."
  16,4,"﴿نُّطۡفَةࣲ﴾: ماءِ الحياةِ، وهو المَنِيُّ.﴿خَصِيمࣱ﴾: شديدُ الخصومةِ والمجادَلةِ.﴿مُّبِينࣱ﴾: بيِّنُ الخُصومةِ واضحُها."
  16,5,"﴿وَٱلۡأَنۡعَـٰمَ﴾: هي الإبِلُ والبَقَرُ والغنم.﴿دِفۡءࣱ﴾: ما تَسْتَدْفِئُون به مِن صوفِها ووَبَرِها وشَعْرِها."
  16,6,"﴿جَمَالٌ﴾: زينةٌ تَسُرُّكم.﴿تُرِيحُونَ﴾: تَرُدُّونها في المساء إلى حَظائرِها.﴿تَسۡرَحُونَ﴾: تُخْرِجُونها في الصَّباح إلى مَراعِيها."
  16,7,"﴿أَثۡقَالَكُمۡ﴾: أمتعتَكم الثقيلةَ.﴿بِشِقِّ ٱلۡأَنفُسِ﴾: بجُهْدٍ شديدٍ ومشَقَّةٍ زائدةٍ عليها."
  16,8,"﴿وَزِينَةࣰ﴾: لتتزيَّنُوا بها حالَ ركوبِها، وحالَ جَمالِ منظرها."
  16,9,"﴿قَصۡدُ ٱلسَّبِيلِ﴾: بيانُ الطَّريقِ المستقيمِ، وهو الإسلامُ.﴿جَآئِرࣱ﴾: مائلٌ عن الاستقامةِ، وهو ما خالَفَ الإسلامَ."
  16,10,"﴿تُسِيمُونَ﴾: تَرعَوْن دَوابَّكم."
  16,11,"﴿لَـَٔايَةࣰ﴾: دلالةً واضحةً."
  16,12,"﴿وَسَخَّرَ لَكُمُ﴾: ذلَّلَ لمنافعِكم."
  16,13,"﴿ذَرَأَ﴾: خَلَقَ."
  16,14,"﴿لَحۡمࣰا طَرِيࣰّا﴾: هو السَّمَكُ.﴿حِلۡيَةࣰ﴾: ما تتحَلّى به النِّساءُ وتَتَزَيَّنُ، كاللؤلؤِ والمَرْجانِ.﴿ٱلۡفُلۡكَ﴾: السُّفُنَ.﴿مَوَاخِرَ فِيهِ﴾: تَشُقُّ الماءَ بجَرْيِها فيه ذَهابًا ورُجوعًا."
  16,15,"﴿رَوَ ٰ⁠سِيَ﴾: جبالًا ثوابِتَ.﴿أَن تَمِيدَ بِكُمۡ﴾: حتى لا تَمِيلَ بكم وتضطربَ.﴿وَسُبُلࣰا﴾: طُرُقًا.﴿تَهۡتَدُونَ﴾: إلى مقاصِدِكم."
  16,16,"﴿وَعَلَـٰمَـٰتࣲ﴾: معالمَ تَسْتَدِلُّون بها على الطُّرُقِ نهارًا."
  16,17,"﴿أَفَمَن يَخۡلُقُ﴾: وهو اللهُ تعالى.﴿كَمَن لَّا يَخۡلُقُ﴾: أتَجْعَلُونه في استحقاقِ العبادةِ كالآلهةِ المزعومةِ التي لا تملِك شيئًا؟"
  16,18,"﴿نِعۡمَةَ ٱللَّهِ﴾: نِعَمَه عليكم.﴿لَا تُحۡصُوهَآ﴾: لا تُطيقوا حَصْرَها ولا القيامَ بشُكْرها؛ لكثرتِها وتَنَوُّعِها."
  16,19,"﴿مَا تُسِرُّونَ﴾: ما تُخْفُونَه من أقوالِكم وأعمالِكم."
  16,21,"﴿أَيَّانَ﴾: وقتَ.﴿يُبۡعَثُونَ﴾: يُحْيَوْن مِن قُبورِهم."
  16,22,"﴿قُلُوبُهُم مُّنكِرَةࣱ﴾: جاحدةٌ وحدانيةَ اللهِ."
  16,23,"﴿لَا جَرَمَ﴾: حَقًّا، أو لا مَحالةَ."
  16,24,"﴿أَسَـٰطِيرُ ٱلۡأَوَّلِينَ﴾: جَمْعُ أُسْطورة، وهي: ما سُطِّرَ في كتب السابقينَ من الأخبارِ المكذوبةِ."
  16,25,"﴿أَوۡزَارَهُمۡ﴾: آثامَ ضلالِهم.﴿مَا يَزِرُونَ﴾: ما يَحْمِلُونه من آثامٍ."
  16,26,"﴿مَكَرَ﴾: دَبَّرَ في حِيلةٍ وخَفاءٍ.﴿فَأَتَى ٱللَّهُ بُنۡيَـٰنَهُم﴾: أهْلكَه وأفْناه.﴿مِّنَ ٱلۡقَوَاعِدِ﴾: من أساسِه.﴿فَخَرَّ﴾: سَقَطَ.﴿حَيۡثُ لَا يَشۡعُرُونَ﴾: من مَأْمَنِهم، ومن جهةٍ لا تَخْطُرُ ببالِهم."
  16,27,"﴿يُخۡزِيهِمۡ﴾: يُذِلُّهم اللهُ ويُهينُهم بالعذابِ.﴿شُرَكَآءِيَ﴾: الآلهةُ التي عَبَدْتُموها من دوني.﴿تُشَـٰٓقُّونَ فِيهِمۡ﴾: تُخاصِمُون وتُعادُون الأنبياءَ وأتباعَهم في شأنهم.﴿ٱلۡخِزۡيَ﴾: الذُّلَّ والهَوانَ.﴿وَٱلسُّوٓءَ﴾: العذابَ."
  16,28,"﴿تَتَوَفَّىٰهُمُ ٱلۡمَلَـٰٓئِكَةُ﴾: تَقْبِضُ أرواحَهم.﴿فَأَلۡقَوُاْ ٱلسَّلَمَ﴾: استَسْلَمُوا لأمرِ اللهِ حين رَأَوا الموتَ."
  16,29,"﴿مَثۡوَى ٱلۡمُتَكَبِّرِينَ﴾: مَأْواهم ومَقَرُّهم."
  16,30,"﴿حَسَنَةࣱ﴾: مَكْرُمَةٌ من اللهِ بالعيشِ الهنيءِ والرِّزقِ الواسعِ."
  16,31,"﴿جَنَّـٰتُ عَدۡنࣲ﴾: جناتُ إقامةٍ.﴿مِن تَحۡتِهَا﴾: من تحتِ قُصورِها وأشجارِها."
  16,32,"﴿طَيِّبِينَ﴾: طاهِرين زاكِيَةً أفعالُهم وأقوالُهم.﴿سَلَـٰمٌ عَلَيۡكُمُ﴾: تحيةٌ خاصةٌ بكم، وسَلِمْتُم من كلِّ آفةٍ."
  16,33,"﴿هَلۡ يَنظُرُونَ﴾: ما ينتظِرُ الكفارُ.﴿تَأۡتِيَهُمُ ٱلۡمَلَـٰٓئِكَةُ﴾: لقَبْضِ أرواحِهم.﴿أَمۡرُ رَبِّكَ﴾: عذابُ الاستئصالِ في الدنيا، أو القيامةُ التي فيها عذابُهم."
  16,34,"﴿وَحَاقَ﴾: نَزَلَ وأحاطَ."
  16,35,"﴿كَذَ ٰ⁠لِكَ فَعَلَ ٱلَّذِينَ مِن قَبۡلِهِمۡ﴾: بمِثْلِ هذا الاحتجاجِ الباطلِ احتجَّ الكفارُ السابقون."
  16,36,"﴿ٱلطَّـٰغُوتَ﴾: كلَّ معبودٍ باطلٍ، كالشيطانِ والأوثانِ والأمواتِ، وكلَّ داعٍ إلى ضَلالٍ.﴿حَقَّتۡ﴾: وجَبَتْ."
  16,38,"﴿جَهۡدَ أَيۡمَـٰنِهِمۡ﴾: غايةَ اجتهادِهم بالأيمانِ المؤكَّدةِ."
  16,39,"﴿لِيُبَيِّنَ لَهُمُ﴾: أي: يَبْعَثُ اللهُ جميعَ العبادِ؛ ليُظْهِرَ لهم حقيقةَ البعثِ."
  16,41,"﴿لَنُبَوِّئَنَّهُمۡ﴾: لَنُنْزِلَنَّهم.﴿حَسَنَةࣰ﴾: دارًا حسنةً، أو رزقًا واسعًا وعَيْشًا هنيئًا."
  16,42,"﴿يَتَوَكَّلُونَ﴾: يعتمدون عليه ويُفَوِّضُون أمرَهم إليه."
  16,43,"﴿أَهۡلَ ٱلذِّكۡرِ﴾: العلماءَ من أهلِ الكتبِ السابقةِ."
  16,44,"﴿بِٱلۡبَيِّنَـٰتِ﴾: وأرسَلْنا الرسلَ بالمعجزاتِ الواضحةِ الدالَّةِ على صِدْقِهم.﴿وَٱلزُّبُرِ﴾: وبالكتبِ المنزَّلةِ، المتضمِّنةِ للشرائعِ.﴿ٱلذِّكۡرَ﴾: القرآنَ؛ لما فيه من الموعظةِ والتنبيهِ."
  16,45,"﴿مَكَرُواْ ٱلسَّيِّـَٔاتِ﴾: دبَّروا المكايدَ بخَفاءٍ، وأشركوا مع اللهِ.﴿يَخۡسِفَ﴾: يُغيِّبَ."
  16,46,"﴿تَقَلُّبِهِمۡ﴾: أسفارِهم وتصرُّفِهم في أمورِهم.﴿بِمُعۡجِزِينَ﴾: بفائتين اللهَ بالفِرارِ من عَذابِه."
  16,47,"﴿عَلَىٰ تَخَوُّفࣲ﴾: على تَنَقُّصٍ شيئًا فشيئًا في الأموالِ والأنفسِ والثمراتِ حتى يَهْلِكُوا، أو على مخافَةٍ من العَذابِ."
  16,48,"﴿مِن شَيۡءࣲ﴾: أي: له ظِلٌّ، كالجبالِ والشجَرِ.﴿يَتَفَيَّؤُاْ ظِلَـٰلُهُ﴾: يَميلُ ظِلُّ الأشياءِ وينتقلُ من جانبٍ إلى آخَر.﴿سُجَّدࣰا لِّلَّهِ﴾: مُنْقادةً خاضعةً لعَظَمَةِ رِّبها، وتسخيرِه.﴿دَ ٰ⁠خِرُونَ﴾: أذلّاءُ مُنقادُون لحُكم الله تعالى."
  16,49,"﴿يَسۡجُدُ﴾: سجودَ طاعةٍ وعبادةٍ، أو سُجودَ تسخيرٍ وخضوعٍ.﴿دَآبَّةࣲ﴾: كلِّ حَيَوانٍ يمشي -على هيئته- على الأرضِ."
  16,51,"﴿لَا تَتَّخِذُوٓاْ﴾: لا تَعْبُدوا.﴿فَٱرۡهَبُونِ﴾: خافونِ دونَ غيري."
  16,52,"﴿وَلَهُ ٱلدِّينُ﴾: وللهِ وحدَه العبادةُ والإخلاصُ.﴿وَاصِبًا﴾: دائمًا، أو واجبًا لازمًا."
  16,53,"﴿مَسَّكُمُ﴾: أصابكم.﴿ٱلضُّرُّ﴾: سوءُ الحالِ بنَقْصٍ في الأموالِ أو الأنفسِ أو الثمراتِ.﴿تَجۡـَٔرُونَ﴾: ترفعونَ أصواتَكم بالدُّعاءِ والاستغاثةِ."
  16,55,"﴿بِمَآ ءَاتَيۡنَـٰهُمۡ﴾: من النِّعَمِ.﴿فَتَمَتَّعُواْ﴾: عِيشُوا في أمْنٍ وسلامةٍ، والتَذُّوا بالدنيا، والمرادُ التهديدُ."
  16,56,"﴿وَيَجۡعَلُونَ﴾: ويجعلُ المشركون على وجْهِ التقرُّبِ.﴿لِمَا لَا يَعۡلَمُونَ﴾: لآلهتِهم التي لا عِلْمَ لها، ولا تنفعُ ولا تَضُرُّ.﴿تَفۡتَرُونَ﴾: تَكْذِبُون على الله من الباطِلِ."
  16,57,"﴿مَّا يَشۡتَهُونَ﴾: ما يُحِبُّون من البنين."
  16,58,"﴿كَظِيمࣱ﴾: ممتلِئٌ غَمًّا وحُزْنًا وغَضَبًا."
  16,59,"﴿يَتَوَ ٰ⁠رَىٰ مِنَ ٱلۡقَوۡمِ﴾: يَسْتَخْفي من قومِه؟﴿أَيُمۡسِكُهُۥ﴾: أيُبقي مَوْلُودَه الأنثى حيًا.﴿هُونٍ﴾: ذُلٍّ وهَوانٍ.﴿يَدُسُّهُۥ﴾: يُخْفِيه، فَيدْفِنُه حيًّا حتى يموتَ."
  16,60,"﴿مَثَلُ ٱلسَّوۡءِ﴾: الصِّفةُ القبيحةُ من كراهةِ البناتِ، والجهلِ، والكفرِ باللهِ.﴿وَلِلَّهِ ٱلۡمَثَلُ ٱلۡأَعۡلَىٰ﴾: الصفةُ العُليا من استحقاقِ العبوديةِ، والكمالِ، والجلالِ، والغنى، والجودِ."
  16,61,"﴿أَجَلࣲ مُّسَمࣰّى﴾: وقتٍ محدَّدٍ هو نهايةُ آجالِهم.﴿وَلَا يَسۡتَقۡدِمُونَ﴾: لا يَتَقَدَّمون عليه."
  16,62,"﴿مَا يَكۡرَهُونَ﴾: ما لا يُحبون نِسْبتَه إلى أنفسِهم من البناتِ.﴿وَتَصِفُ﴾: تقولُ.﴿ٱلۡحُسۡنَىٰ﴾: حُسْنَ العاقبةِ.﴿لَا جَرَمَ﴾: حقًّا، أو لا مَحالةَ.﴿مُّفۡرَطُونَ﴾: مَتْرُوكون مَنسِيُّون فيها أبدًا."
  16,63,"﴿فَزَيَّنَ﴾: حَسَّنَ.﴿وَلِيُّهُمُ ٱلۡيَوۡمَ﴾: مُتَوَلٍّ إغواءَهم في الدنيا."
  16,64,"﴿ٱلۡكِتَـٰبَ﴾: القرآنَ العظيمَ.﴿لِتُبَيِّنَ لَهُمُ﴾: لتُوَضِّحَ للناسِ."
  16,65,"﴿لَـَٔايَةࣰ﴾: دليلًا وحُجَّةً على قُدرةِ الله."
  16,66,"﴿ٱلۡأَنۡعَـٰمِ﴾: وهي: الإبِلُ والبَقَرُ والغَنَمُ.﴿لَعِبۡرَةࣰ﴾: لعِظَةً.﴿فَرۡثࣲ﴾: خُلاصةِ المأكول في الكَرِشِ والأمعاءِ.﴿خَالِصࣰا﴾: مُصَفّى من جميعِ الشوائبِ.﴿سَآئِغࣰا﴾: سهلَ المُرورِ في الحَلْقِ، هنيئًا."
  16,67,"﴿سَكَرࣰا﴾: خَمْرًا (وهذا امتنانٌ قبلَ التحريمِ)."
  16,68,"﴿وَأَوۡحَىٰ﴾: وألْهَمَ.﴿وَمِمَّا يَعۡرِشُونَ﴾: وفيما يَبْنيه الناسُ من البيوتِ والخَلايا."
  16,69,"﴿سُبُلَ رَبِّكِ﴾: طُرُقَه التي ألْهَمكِ؛ لامتصاصِ ما في أزهارِ الثمار.﴿ذُلُلࣰا﴾: مُذَلَّلةً لكِ لا عُسْرَ فيها.﴿شَرَابࣱ﴾: هو العَسَلُ."
  16,70,"﴿يَتَوَفَّىٰكُمۡ﴾: يُميتكُم عندَ نهايةِ أعمارِكم.﴿أَرۡذَلِ ٱلۡعُمُرِ﴾: أردَئهِ وأحقَرِه، وهو وقتُ الهَرَمِ."
  16,71,"﴿فَهُمۡ فِيهِ سَوَآءٌ﴾: فهم لا يَرْضَوْن بالتساوي في الرزقِ، فكيف رَضُوا أن يَجْعلوا للهِ شركاءَ من عبيدِه؟"
  16,72,"﴿وَحَفَدَةࣰ﴾: جَمْعَ حَفِيدٍ، أي: أولادَ الأولادِ، أو أعوانًا وخَدَمًا."
  16,74,"﴿فَلَا تَضۡرِبُواْ لِلَّهِ ٱلۡأَمۡثَالَ﴾: لا تَجْعَلُوا للهِ أشباهًا مماثِلين له مِن خَلْقِه، تُشْرِكُونهم معه في العبادةِ."
  16,75,"﴿هَلۡ يَسۡتَوُۥنَ﴾: لا، فكذلك اللهُ المالكُ مع عبيدِه، فكيف تُسَوُّون بينَهما؟"
  16,76,"﴿أَبۡكَمُ﴾: أخْرَسُ منذُ ولادَتِه.﴿كَلٌّ﴾: عِبْءٌ يعتَمِدُ على غيرِه في معيشَتِه.﴿مَوۡلَىٰهُ﴾: مَن يلي أمرَه ويَعُولُه.﴿بِٱلۡعَدۡلِ﴾: بالحقِّ وعبادةِ اللهِ.﴿صِرَ ٰ⁠طࣲ﴾: طريقٍ."
  16,77,"﴿غَيۡبُ ٱلسَّمَـٰوَ ٰ⁠تِ وَٱلۡأَرۡضِ﴾: عِلْمُ ما غابَ فيهما.﴿كَلَمۡحِ ٱلۡبَصَرِ﴾: كنَظْرَةٍ سريعةٍ بالبَصَرِ."
  16,79,"﴿مُسَخَّرَ ٰ⁠تࣲ﴾: مُذَلَّلاتٍ للطَّيَرانِ."
  16,80,"﴿سَكَنࣰا﴾: مَسْكَنًا واستقرارًا لكم.﴿بُيُوتࣰا﴾: كالخِيام.﴿تَسۡتَخِفُّونَهَا﴾: تَجِدُونها خفيفةَ الحَمْلِ والنَّقْلِ.﴿يَوۡمَ ظَعۡنِكُمۡ﴾: وقتَ سَفَرِكم.﴿وَمِنۡ أَصۡوَافِهَا﴾: أي: أصوافِ الضَّأنِ.﴿وَأَوۡبَارِهَا﴾: أي: أوبارِ الإبِل، وهو ما يَعْلُو أجسادَها.﴿وَأَشۡعَارِهَآ﴾: أي: أشعارِ المَعْزِ.﴿أَثَـٰثࣰا﴾: مَتاعًا لبيوتِكم، كالأغطيةِ والفُرُشِ.﴿وَمَتَـٰعًا﴾: ما تتمتَّعُون وتنتفِعُون به.﴿إِلَىٰ حِينࣲ﴾: إلى وقتٍ محدَّدٍ في الدنيا."
  16,81,"﴿ظِلَـٰلࣰا﴾: ما تَسْتظِلُّون به من شدَّةِ الحرِّ.﴿أَكۡنَـٰنࣰا﴾: أماكنَ وِقايةٍ وسِتْرٍ، كالكهوفِ.﴿سَرَ ٰ⁠بِيلَ﴾: كلَّ ما يُلْبَس من ثيابٍ أو دُروعٍ.﴿بَأۡسَكُمۡ﴾: الشدَّةَ في حروبِكم، كالطَّعْنِ والضَّرْبِ والشَّظايا.﴿تُسۡلِمُونَ﴾: تَنقادُون وتَخْضَعُون لأمرِ اللهِ وحُكْمِه."
  16,82,"﴿تَوَلَّوۡاْ﴾: أعْرَضُوا.﴿ٱلۡمُبِينُ﴾: الواضحُ."
  16,84,"﴿شَهِيدࣰا﴾: هو رسولُهم يَشْهَدُ على مَن آمَنَ منهم، وعلى مَن كَفَرَ.﴿لَا يُؤۡذَنُ لِلَّذِينَ كَفَرُواْ﴾: بالاعتذار عَمّا وقَعَ منهم.﴿وَلَا هُمۡ يُسۡتَعۡتَبُونَ﴾: لا يُطْلَبُ منهم العُتْبى، أي: الرجوعُ إلى ما يُرْضي اللهَ من التوبةِ والعملِ الصّالحِ."
  16,85,"﴿يُنظَرُونَ﴾: يُمْهَلُون ويُؤَخَّرون عنه."
  16,86,"﴿شُرَكَآءَهُمۡ﴾: آلهتَهم المزعومةَ.﴿نَدۡعُواْ﴾: نعبدُ.﴿فَأَلۡقَوۡاْ إِلَيۡهِمُ ٱلۡقَوۡلَ﴾: رَدَّتِ الآلهةُ على عابدِيها قائلين."
  16,87,"﴿وَأَلۡقَوۡاْ إِلَى ٱللَّهِ يَوۡمَئِذٍ ٱلسَّلَمَ﴾: أظهرَ المشركونَ خُضوعَهم وانقيادَهم للهِ يومَ القيامةِ.﴿وَضَلَّ﴾: غابَ وضاعَ.﴿يَفۡتَرُونَ﴾: يختلِقُونَه مِن الأكاذيبِ."
  16,89,"﴿شَهِيدًا عَلَىٰ هَـٰٓؤُلَآءِ﴾: تَشْهَدُ على أمَّتِك أنكَ بَلَّغْتَهم رسالةَ ربِّك.﴿ٱلۡكِتَـٰبَ﴾: القرآنَ.﴿تِبۡيَـٰنࣰا﴾: بَيانًا وتوضيحًا.﴿لِّكُلِّ شَيۡءࣲ﴾: مما يَحْتاجُ إليه الناسُ من أمورِ الشريعةِ."
  16,90,"﴿بِٱلۡعَدۡلِ﴾: بالتوسُّطِ والإنصافِ في الأمور.﴿وَٱلۡإِحۡسَـٰنِ﴾: كمالِ العملِ وإتقانِه، وإيصالِ النفعِ إلى الخَلْقِ.﴿وَإِيتَآيِٕ ذِي ٱلۡقُرۡبَىٰ﴾: إعطاءِ القَرابةِ حَقَّهم من الصِّلةِ والبِرِّ.﴿ٱلۡفَحۡشَآءِ﴾: ما عَظُمَ قُبْحُه من الذنوبِ قولًا أو فعلًا.﴿وَٱلۡبَغۡيِ﴾: ظُلْمِ الناسِ وتجاوُزِ الحَدِّ في الاستعلاءِ والتعدِّي عليهم."
  16,91,"﴿بِعَهۡدِ ٱللَّهِ﴾: ما يَلْتَزِمُه المسلمُ باختيارِه بينَه وبينَ اللهِ، أو بينَ الناسِ.﴿وَلَا تَنقُضُواْ ٱلۡأَيۡمَـٰنَ﴾: لا تُبْطِلُوها وتَتْرُكُوا العَمَلَ بمُقْتضاها.﴿كَفِيلًا﴾: رَقيبًا أو ضامِنًا."
  16,92,"﴿غَزۡلَهَا﴾: ما فَتَلَتْه من صُوفٍ ونحوِه.﴿أَنكَـٰثࣰا﴾: جَمْعُ نِكْثٍ، وهو: ما حُلَّ فَتْلُه؛ ليُغْزَلَ ثانيةً.﴿دَخَلَۢا بَيۡنَكُمۡ﴾: خديعةً ومُنْكَرًا بينَكم.﴿أَرۡبَىٰ مِنۡ أُمَّةٍ﴾: أكثرَ عَددًَا وأوفرَ مالًا من الجماعة التي عاهَدْتموها.﴿يَبۡلُوكُمُ ٱللَّهُ﴾: يختبرُكم بالوفاءِ بِالعهودِ وعَدَمِ نَقْضِها."
  16,93,"﴿أُمَّةࣰ وَ ٰ⁠حِدَةࣰ﴾: أهلَ دينٍ واحدٍ، وهو الإسلامُ.﴿وَيَهۡدِي﴾: يُوَفِّقُ إلى الهدايةِ."
  16,94,"﴿فَتَزِلَّ قَدَمُۢ﴾: فتنحَرِفَ أقدامُكم عن محَجَّةِ الحقِّ.﴿ثُبُوتِهَا﴾: استقامتِها عليه.﴿ٱلسُّوٓءَ﴾: ما يَسُوءُكم من العذابِ في الدنيا."
  16,95,"﴿وَلَا تَشۡتَرُواْ﴾: لا تَسْتبدلوا."
  16,96,"﴿يَنفَدُ﴾: يزولُ ويَفْنى.﴿بَاقࣲ﴾: لا يزولُ ولا يَفْنى."
  16,97,"﴿طَيِّبَةࣰ﴾: سعيدةً في الدنيا، يصاحِبُها القناعة بما قَسَمهُ اللهُ وقَدَّره."
  16,98,"﴿فَإِذَا قَرَأۡتَ﴾: أي: فإذا أرَدْتَ أن تَقْرَأَ.﴿فَٱسۡتَعِذۡ بِٱللَّهِ﴾: فالتجِئْ واستَجِرْ به.﴿ٱلرَّجِيمِ﴾: المَرْجُومِ، أي: المَطْرودِ من رحمةِ اللهِ."
  16,99,"﴿سُلۡطَـٰنٌ﴾: تَسَلُّطٌ واستيلاءٌ.﴿يَتَوَكَّلُونَ﴾: يَعْتمدون عليه ويُفَوِّضُون أمرَهم إليه."
  16,100,"﴿يَتَوَلَّوۡنَهُۥ﴾: يَتِّخِذُونه مُعِينًا لهم ويُطيعونه.﴿هُم بِهِۦ﴾: بسببِ الشيطانِ وإغوائِه إيّاهم."
  16,101,"﴿بَدَّلۡنَآ ءَايَةࣰ﴾: أزَلْناها، أو أنْزَلْنا غيرَها.﴿مُفۡتَرِۭ﴾: كَذّابٌ تَختَلِقُ الباطِلَ على اللهِ مِن عندِك."
  16,102,"﴿رُوحُ ٱلۡقُدُسِ﴾: جبريلُ عليه السلامُ."
  16,103,"﴿لِّسَانُ﴾: لُغةُ وكلامُ.﴿يُلۡحِدُونَ إِلَيۡهِ﴾: يَنْسِبُون إليه التعليمَ.﴿أَعۡجَمِيࣱّ﴾: لا يُفْصِحُ عن مُرادِه.﴿مُّبِينٌ﴾: في غايةِ الوضوحِ والبيانِ."
  16,104,"﴿لَا يَهۡدِيهِمُ ٱللَّهُ﴾: لا يُوَفِّقُهم للإيمانِ؛ لعِلْمِه بعدَمِ قَبولِهم له."
  16,105,"﴿يَفۡتَرِي﴾: يَخْتِلقُ."
  16,106,"﴿مَن كَفَرَ بِٱللَّهِ﴾: فهم الكاذبون حقًّا، وعليهم غَضَبٌ من الله.﴿أُكۡرِهَ﴾: أُرْغِمَ على النُّطْقِ بالكفرِ فَتَلفَّظَ به؛ خَوْفًا من هَلاكِه.﴿شَرَحَ بِٱلۡكُفۡرِ صَدۡرࣰا﴾: اعتَقَدَه وطابَتْ نفسُه به."
  16,107,"﴿ٱسۡتَحَبُّواْ ٱلۡحَيَوٰةَ﴾: اختارُوها وفَضَّلُوها."
  16,108,"﴿طَبَعَ﴾: خَتَم."
  16,109,"﴿لَا جَرَمَ﴾: حقًّا، أو لا مَحالةَ."
  16,110,"﴿فُتِنُواْ﴾: اختُبِرُوا بتعذيبِهم، وتَلَفَّظُوا بالكُفرِ."
  16,111,"﴿تُجَـٰدِلُ عَن نَّفۡسِهَا﴾: تُخاصِمُ عن ذاتِها، وتسعى في خَلاصِها.﴿وَتُوَفَّىٰ﴾: تُعْطى وافيًا كامِلًا."
  16,112,"﴿قَرۡيَةࣰ﴾: أي: مكةَ.﴿رَغَدࣰا﴾: واسعًا كثيرًا، أو هنيئًا سهلًا.﴿لِبَاسَ ٱلۡجُوعِ وَٱلۡخَوۡفِ﴾: ما غَشِيَها من صُنوفِ البَلاءِ وإحاطَتِه بها كاللِّباس."
  16,113,"﴿مِّنۡهُمۡ﴾: من جنسِهم، يَعْرِفُون نَسَبَه وأمانتَه."
  16,114,"﴿وَٱشۡكُرُواْ نِعۡمَتَ ٱللَّهِ﴾: بالاعترافِ بها، واستعمالِها في طاعَتِه."
  16,115,"﴿ٱلۡمَيۡتَةَ﴾: ما لم يُذْبَحْ بطريقةٍ شَرْعِيَّةٍ من الحَيَوانِ.﴿وَٱلدَّمَ﴾: أي: المُراقَ من الذَّبِيحةِ.﴿وَمَآ أُهِلَّ لِغَيۡرِ ٱللَّهِ بِهِۦ﴾: ما ذُكِرَ عليه غيرُ اسمِ اللهِ عندَ ذَبْحِه.﴿فَمَنِ ٱضۡطُرَّ﴾: فمَن ألجأَتْه الضَّرورةُ إلى أكْلِ شيءٍ من هذه المُحَرَّماتِ.﴿غَيۡرَ بَاغࣲ﴾: غيرَ طالبٍ للمُحَرَّمِ وهو يَجِدُ غيرَه، أو غيرَ طالبٍ بأَكْلِه التلذُّذَ، أو غيرَ ظالمٍ لمضطرٍ آخرَ يُؤدِّي إلى هَلاكِه.﴿وَلَا عَادࣲ﴾: ولا متجاوزٍ ما يَسُدُّ جَوْعتَه."
  16,116,"﴿لِمَا تَصِفُ أَلۡسِنَتُكُمُ﴾: لمجرَّدِ وصْفِ ألسنتِكُم للشيء دونَ دليلٍ.﴿لِّتَفۡتَرُواْ﴾: تختَلِقُوا."
  16,118,"﴿ٱلَّذِينَ هَادُواْ﴾: اليهودِ."
  16,119,"﴿ٱلسُّوٓءَ﴾: الذُّنوبَ والمعاصِيَ.﴿بِجَهَـٰلَةࣲ﴾: بِجَهْلٍ منهم لعاقبتِها وإيجابِها سَخَطَ اللهِ.﴿وَأَصۡلَحُوٓاْ﴾: استقامُوا بعد تَوْبَتِهم."
  16,120,"﴿أُمَّةࣰ﴾: إمامًا قُدْوةً جامعًا لخِصالِ الخيرِ.﴿قَانِتࣰا لِّلَّهِ﴾: مُطيعًا خاضِعًا له.﴿حَنِيفࣰا﴾: مائلًا عن الأديانِ الباطلةِ إلى الدِّينِ الحقِ."
  16,121,"﴿ٱجۡتَبَىٰهُ﴾: اختاره اللهُ لرسالتِه.﴿وَهَدَىٰهُ﴾: أرْشَدَه ووَفَّقه."
  16,122,"﴿حَسَنَةࣰ﴾: نِعْمةً حسنةً، كالثَّناءِ الجميلِ عليه إلى يومِ القيامة، والاقتداءِ به."
  16,123,"﴿مِلَّةَ إِبۡرَ ٰ⁠هِيمَ﴾: شريعتَه، وهي الإسلامُ."
  16,124,"﴿جُعِلَ ٱلسَّبۡتُ﴾: فُرِضَ تَعْظِيمُه والتفرُّغُ للعبادةِ فيه.﴿ٱلَّذِينَ ٱخۡتَلَفُواْ فِيهِ﴾: هم اليهودُ، حيث أمَرَهم نبيُّهم بتعظيمِ يومِ الجُمُعَةِ، فاختاروا السَّبْتَ."
  16,125,"﴿بِٱلۡحِكۡمَةِ﴾: بالطريقةِ الحَكِيمةِ وفْقَ شَرْعِ اللهِ.﴿وَٱلۡمَوۡعِظَةِ ٱلۡحَسَنَةِ﴾: بالتذكيرِ المناسِبِ للأشخاصِ والأحوالِ."
  16,127,"﴿ضَيۡقࣲ﴾: حَرَجٍ وغَمٍّ."
