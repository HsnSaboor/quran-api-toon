tafsir[71]{c,v,t}:
  40,1,"﴿حمٓ﴾: انْظُرْ أوَّلَ سورة البقرةِ."
  40,3,"﴿ٱلتَّوۡبِ﴾: التَّوبَةِ.﴿ذِي ٱلطَّوۡلِ﴾: صاحِبِ الإنْعامِ والتفضُّلِ على عبادِهِ الطّائِعِينَ.﴿إِلَيۡهِ ٱلۡمَصِيرُ﴾: إلى اللهِ مَرْجِعُكُم أيُّها الخَلْقُ."
  40,4,"﴿فَلَا يَغۡرُرۡكَ﴾: فلا يَخْدَعْكَ.﴿تَقَلُّبُهُمۡ فِي ٱلۡبِلَـٰدِ﴾: تَرَدُّدُهُم وتَصَرُّفُهُم في البِلادِ بأنْواعِ التِّجاراتِ والمكاسِبِ."
  40,5,"﴿وَٱلۡأَحۡزَابُ﴾: الأُمَمُ الَّتي اجْتَمَعتْ عَلى تَكْذِيبِ رُسُلِها كَعادٍ وثَمُودَ.﴿لِيَأۡخُذُوهُ﴾: لِيقْتُلُوهُ.﴿لِيُدۡحِضُواْ بِهِ﴾: لِيُبْطِلُوا بِجِدالِهِم.﴿فَأَخَذۡتُهُمۡ﴾: فَعاقَبْتُهُمْ."
  40,6,"﴿حَقَّتۡ﴾: وجَبَتْ وثَبَتَتْ.﴿كَلِمَتُ رَبِّكَ﴾: كَلِمَةُ العذابِ وهي قولُه تَعالى: (لَأَمۡلَأَنَّ جَهَنَّمَ مِنكَ ومِمَّن تَبِعَكَ مِنۡهُمۡ أجۡمَعِينَ)."
  40,7,"﴿ٱلۡعَرۡشَ﴾: هو سَرِيرُ المُلْكِ الَّذيِ اسْتَوى عَلَيهِ الَّرحْمنُ، وتَحْمِلُهُ الملائِكَةُ، وهُوَ أعْظَمُ المَخْلُوقاتِ، وهو سَقْفُ الجنَّةِ.﴿وَمَنۡ حَوۡلَهُۥ﴾: أي: الملائِكةُ الذين يَحُفُّونَ بالعرْشِ.﴿يُسَبِّحُونَ﴾: يُنَزِّهُونَ.﴿وَقِهِمۡ﴾: وجَنِّبْهُم.﴿عَذَابَ ٱلۡجَحِيمِ﴾: عذابَ النّارِ."
  40,8,"﴿جَنَّـٰتِ عَدۡنٍ﴾: بساتين إقامَةٍ دائِمَةٍ."
  40,9,"﴿وَقِهِمُ ٱلسَّيِّـَٔاتِ﴾: واصْرِفْ عَنْهُم سُوءَ عاقِبَةِ سيِّئاتِهِم."
  40,10,"﴿لَمَقۡتُ ٱللَّهِ﴾: بُغْضُ اللهِ لَكُم.﴿مَّقۡتِكُمۡ أَنفُسَكُمۡ﴾: بُغْضِكُم لِأَنْفُسِكُم الآنَ بَعْدَ أنْ أدْرَكْتُم أنّكُم تَسْتَحِقُّونَ سَخَطَ اللهِ وعَذابَهُ."
  40,11,"﴿أَمَتَّنَا ٱثۡنَتَيۡنِ﴾: أمَتَّنا مَرَّتَينِ: حِينَ كُنّا نُطَفًا في بُطُونِ أمَّهاتِنا قَبْلَ نَفْخِ الرُّوحِ وحِينَ انْقَضى أجَلُنا في الحياةِ الدُّنيا.﴿وَأَحۡيَيۡتَنَا ٱثۡنَتَيۡنِ﴾: وأَحْيَيْتَنا مَرَّتَينِ: في دارِ الدُّنيا، يَوْمَ وُلِدْنا، ويَوْمَ بُعِثْنا مِن قُبُورِنا.﴿خُرُوجࣲ﴾: أي: مِنَ النّارِ."
  40,12,"﴿ٱلۡعَلِيِّ﴾: العاِلي عَلى خَلْقِهِ ذاتًا وقُدْرَةً وقَهْرًا."
  40,13,"﴿ءَايَـٰتِهِۦ﴾: دَلائِلَ عَظَمَتِه الَّتي تَظْهَرُ في هَذا العالَمِ.﴿رِزۡقࣰا﴾: مَطَرًا هُوَ سَبَبُ رِزْقِكُم.﴿يُنِيبُ﴾: يَرْجِعُ إلى طاعَةِ اللهِ."
  40,14,"﴿ٱلدِّينَ﴾: العِبادَةَ والدُّعاءَ."
  40,15,"﴿رَفِيعُ ٱلدَّرَجَـٰتِ﴾: ارْتَفَعَتْ دَرَجاتُه ارْتِفاعًا بايَنَ بِهِ مَخْلُوقاتِهِ.﴿ٱلرُّوحَ﴾: الوَحْيَ الَّذِي يَحْيَوْنَ بِهِ.﴿يَوۡمَ ٱلتَّلَاقِ﴾: يومَ القِيامةِ الَّذِي يَلْتَقِي فِيهِ الأولُونَ والآخِرُونَ."
  40,16,"﴿بَـٰرِزُونَ﴾: يَظْهَرُونَ أمامَ رَبِّهِم.﴿ٱلۡقَهَّارِ﴾: الَّذِي قَهَرَ جَميعَ الخَلائِقِ، فَكُلُّها تَحْتَ تَصَرُّفِهِ وتَدْبِيرِهِ فَلا تَتَحَرَّكُ ولا تَسْكُنُ إلّا بِإْذِنِهِ."
  40,18,"﴿يَوۡمَ ٱلۡـَٔازِفَةِ﴾: يَوْمَ القِيامَةِ القريبَ وإنِ اسْتَبْعَدُوهُ.﴿ٱلۡحَنَاجِرِ﴾: جَمْعِ حَنْجَرةٍ، وهي الحُلْقُومُ.﴿كَـٰظِمِينَ﴾: مُمْتلِئِين غمًّا وحُزْنًا.﴿حَمِيمࣲ﴾: قَرِيبٍ وصاحِبٍ.﴿شَفِيعࣲ﴾: يَشْفَعُ لَهُم عنْدَ رَبِّهِمِ.﴿يُطَاعُ﴾: يُسْتَجابُ لَهُ."
  40,19,"﴿خَآئِنَةَ ٱلۡأَعۡيُنِ﴾: ما تَخْتَلِسُهُ العُيُونُ مِن نَّظَراتٍ."
  40,20,"﴿يَقۡضِي بِٱلۡحَقِّ﴾: يَحْكُمُ بالعَدْلِ.﴿لَا يَقۡضُونَ بِشَيۡءٍ﴾: لا يَحْكُمُونَ بِشَيءٍ؛ لأنّ هذه الآلهةَ لا تَعْلَمُ شَيئًا ولا تَقْدِرُ عَلى شَيءٍ."
  40,21,"﴿عَـٰقِبَةُ ٱلَّذِينَ كَانُواْ مِن قَبۡلِهِمۡ﴾: خاتِمةُ ومَصِيرُ الأُمَمِ السّابِقةِ قَبْلَهُم.﴿وَءَاثَارࣰا فِي ٱلۡأَرۡضِ﴾: وأبْقى آثارًَا مِنهُم في الأَرْضِ يُسْتَدَلُّ بِها عَلى قُوَّتِهِم.﴿فَأَخَذَهُمُ﴾: فَأَهْلَكَهُم.﴿وَاقࣲ﴾: دافعٍ يَدْفَعُ عَنْهُم عَذابَ اللهِ."
  40,23,"﴿وَسُلۡطَـٰنࣲ﴾: حُجَّةٍ."
  40,25,"﴿وَٱسۡتَحۡيُواْ نِسَآءَهُمۡ﴾: اسْتَبْقُوا نِساءَهم لِلْخِدْمَةِ والاسْتِرْقاقِ.﴿وَمَا كَيۡدُ ٱلۡكَـٰفِرِينَ إِلَّا فِي ضَلَـٰلࣲ﴾: وما تَدْبِيرُ الكافِرِينَ إلا في ذَهابٍ وهَلاكٍ."
  40,26,"﴿ذَرُونِيٓ﴾: اتْرُكُونِي.﴿ٱلۡأَرۡضِ﴾: أرْضِ مِصْرَ."
  40,27,"﴿عُذۡتُ﴾: لَجَأْتُ واسْتَجَرْتُ."
  40,28,"﴿يُصِبۡكُم﴾: يَلْحَقْكُم.﴿يَعِدُكُمۡ﴾: يَتَوَعَّدُكُم بهِ مِنَ العُقُوبَةِ.﴿مُسۡرِفࣱ﴾: مُتَجاوِزٌ لِلْحَدِّ بالشِّرْكِ والقَتْلِ بِغَيْرِ حَقٍّ."
  40,29,"﴿ظَـٰهِرِينَ﴾: غالِبينَ.﴿ٱلۡأَرۡضِ﴾: أرْضِ مِصْرَ.﴿فَمَن يَنصُرُنَا﴾: فَمَن يَدْفَعُ عَنّا.﴿بَأۡسِ ٱللَّهِ﴾: عَذابِ اللهِ.﴿مَآ أُرِيكُمۡ إِلَّا مَآ أَرَىٰ﴾: ما أُرِيكُم مِّنَ الرّأيِ والنَّصِيحَةِ إلّا ما أرى لِنَفْسِي ولَكُم صَلاحًا وصَوابًا.﴿سَبِيلَ ٱلرَّشَادِ﴾: طَرِيقَ الحقِّ والصَّوابِ."
  40,30,"﴿يَوۡمِ ٱلۡأَحۡزَابِ﴾: يَوْمِ عَذابِ الَّذينَ تَجَمَّعُوا على أنبيائِهِم فَأَهْلكَهُم اللهُ."
  40,31,"﴿دَأۡبِ﴾: عادَةِ."
  40,32,"﴿يَوۡمَ ٱلتَّنَادِ﴾: يَومَ يُنادِي فِيه بعضُ النّاسِ بَعْضًا مِن هَوْلِ الموقِفِ."
  40,33,"﴿تُوَلُّونَ﴾: تَذْهَبُونَ وتَنْصَرِفُونَ.﴿مُدۡبِرِينَ﴾: ذاهِبِينَ هارِبِينَ.﴿عَاصِمࣲ﴾: مانِعٍ يَمْنَعُكُم."
  40,34,"﴿بِٱلۡبَيِّنَـٰتِ﴾: الدَّلائِلِ الُمظْهِرَةِ أنّهُ رَسُول مِنَ اللهِ.﴿هَلَكَ﴾: ماتَ.﴿مُسۡرِفࣱ﴾: مُتَجاوِزٌ لِلْحَقِّ.﴿مُّرۡتَابٌ﴾: شاكٌّ في وحْدانِيَّةِ اللهِ."
  40,35,"﴿سُلۡطَـٰنٍ﴾: حُجَّةٍ مَقْبُولةٍ.﴿يَطۡبَعُ ٱللَّهُ﴾: يَخْتِمُ اللهُ.﴿جَبَّارࣲ﴾: الَّذِي يُكْرِهُ الناسَ عَلى ما لا يُحِبُّونَ عَمَلَه لِظُلْمِهِ."
  40,36,"﴿صَرۡحࣰا﴾: بِناءً عَظِيمًا.﴿ٱلۡأَسۡبَـٰبَ﴾: أبْوابَ السَّمَواتِ وما يُوصِلُنِي إلَيها."
  40,37,"﴿كَيۡدُ﴾: احْتِيالُ.﴿تَبَابࣲ﴾: خَسارٍ وبَوارٍ."
  40,39,"﴿مَتَـٰعࣱ﴾: تَمَتُّعٌ في مُدَّةٍ قَلِيلَةٍ.﴿ٱلۡقَرَارِ﴾: الدَّوامِ في المكانِ."
  40,40,"﴿بِغَيۡرِ حِسَابࣲ﴾: بَغَيرِ تَقْتِيرٍ."
  40,42,"40:41"
  40,43,"﴿لَا جَرَمَ﴾: حَقًّا.﴿لَيۡسَ لَهُۥ دَعۡوَةࣱ﴾: لا يَمْلِكُ إجابَةَ دَعْوَةِ الدّاعِينَ.﴿مَرَدَّنَآ﴾: مَصِيرَنا.﴿ٱلۡمُسۡرِفِينَ﴾: المتَعَدِّينَ حُدُودَهُ بالشِّرْكِ باللهِ."
  40,44,"﴿وَأُفَوِّضُ أَمۡرِيٓ إِلَى ٱللَّهِ﴾: وأَتَوَكَّلُ عَلى اللهِ وأَلْجَأُ إلَيهِ وأَعْتَصِمُ بِهِ."
  40,45,"﴿سَيِّـَٔاتِ مَا مَكَرُواْ﴾: عُقُوباتِ مَكْرِ فِرْعَونَ وآلِهِ.﴿وَحَاقَ﴾: وحَلَّ."
  40,46,"﴿يُعۡرَضُونَ عَلَيۡهَا﴾: يُشاهِدُونَ مَقاعِدَهُم في النّارِ.﴿غُدُوࣰّا﴾: أوَّلَ النَّهارِ.﴿وَعَشِيࣰّا﴾: آخِرَ النَّهارِ."
  40,47,"﴿يَتَحَآجُّونَ﴾: يتخاصَمُونَ.﴿نَصِيبࣰا﴾: قِسْطًا."
  40,49,"40:48"
  40,50,"﴿بِٱلۡبَيِّنَـٰتِ﴾: بالحُجَجِ الواضِحَةِ.﴿إِلَّا فِي ضَلَـٰلٍ﴾: إلّا في ضَياعٍ."
  40,51,"﴿وَيَوۡمَ يَقُومُ ٱلۡأَشۡهَـٰدُ﴾: يَوْمَ القِيامةِ، فَيُشْهَدُ للرُّسُلِ بالتَّبْلِيغِ، وعَلى الكُفّارِ بالتَّكْذِيبِ."
  40,52,"﴿وَلَهُمُ ٱللَّعۡنَةُ﴾: ولَهُم الطَّرْدُ مِن رحْمَةِ اللهِ.﴿سُوٓءُ ٱلدَّارِ﴾: الدّارُ السَّيِّئَةُ في الآخِرَةِ وهي النّارُ."
  40,53,"﴿ٱلۡكِتَـٰبَ﴾: التَّوراةَ."
  40,54,"﴿لِأُوْلِي ٱلۡأَلۡبَـٰبِ﴾: لِأصْحابِ العُقُولِ السَّلِيمةِ."
  40,55,"﴿بِٱلۡعَشِيِّ﴾: آخِرِ النَّهارِ.﴿وَٱلۡإِبۡكَـٰرِ﴾: أوَّلِ النَّهارِ."
  40,56,"﴿سُلۡطَـٰنٍ﴾: بُرْهانٍ وحُجَّةٍ."
  40,58,"﴿ٱلۡمُسِيٓءُ﴾: مَن كَفَرَ بِاللهِ وخالفَ أمْرَهُ."
  40,60,"﴿ٱدۡعُونِيٓ﴾: خُصُّونِي بِدُعاءِ العِبادةِ ودُعاءِ المسْأَلةِ.﴿يَسۡتَكۡبِرُونَ عَنۡ عِبَادَتِي﴾: يَتَكَبَّرُونَ عَنْ إفْرادِي بالعِبادَةِ.﴿دَاخِرِينَ﴾: صاغِرِينَ ذَلِيلِينَ."
  40,61,"﴿لِتَسۡكُنُواْ﴾: لِتَهْدَؤُوا فِيهِ مِنَ الحرَكَةِ والتَّعَبِ.﴿مُبۡصِرًا﴾: مُضِيئًا يُبْصِرُ فِيهِ النّاسُ."
  40,62,"﴿فَأَنَّىٰ تُؤۡفَكُونَ﴾: فَكَيفَ تُصْرَفُونَ عَنِ الحقِّ والصَّوابِ فَتَعْدِلُونَ عَنِ الإيمانِ باللهِ، وتَعْبُدُونَ غَيرَه؟"
  40,63,"﴿يُؤۡفَكُ﴾: يُصْرَفُ عَنِ الحقِّ.﴿بِـَٔايَـٰتِ ٱللَّهِ﴾: مُعْجِزاتِهِ.﴿يَجۡحَدُونَ﴾: يُكَذِّبُونَ."
  40,64,"﴿قَرَارࣰا﴾: مَكانَ اسْتِقْرارٍ، ويَسَّرَ لَكُم الإقامَةَ عَلَيها.﴿بِنَآءࣰ﴾: سَقْفًا للأَرْضِ.﴿وَصَوَّرَكُمۡ فَأَحۡسَنَ صُوَرَكُمۡ﴾: وخَلَقَكُم في أكْمَلِ هَيْئَةٍ، وأحْسَنِ تَقْويمٍ.﴿فَتَبَارَكَ ٱللَّهُ﴾: فَتَكاثَر خَيْرُهُ وفَضْلُهُ وبَرَكتُهُ."
  40,65,"﴿ٱلۡحَيُّ﴾: الموصُوفُ بالحياةِ الحقِيقِيَّةِ الكامِلةِ.﴿ٱلدِّينَ﴾: الطّاعَةَ."
  40,66,"﴿ٱلۡبَيِّنَـٰتُ﴾: دَلائلُ التَّوحِيدِ.﴿أُسۡلِمَ﴾: أخْضَعَ وأنقادَ بالطّاعةِ التامَّةِ."
  40,67,"﴿نُّطۡفَةࣲ﴾: مَنِيٍّ.﴿عَلَقَةࣲ﴾: دَمٍ غَلِيظٍ أحْمَرَ.﴿لِتَبۡلُغُوٓاْ أَشُدَّكُمۡ﴾: ليَتِمّ خَلْقُكُم، وتَتَكامَلَ قُواكُم ويَتَناهى شَبابُكُم.﴿شُيُوخࣰا﴾: جَمْعُ شَيخ، وهو مَن بَلَغَ سِنّ الخمْسِينَ إلى آخِرِ عُمُرِهِ."
  40,69,"40:68"
  40,70,"﴿بِٱلۡكِتَـٰبِ﴾: بالقرآنِ."
  40,71,"﴿ٱلۡأَغۡلَـٰلُ﴾: جَمْعُ غُلٍّ، وهو القَيْدُ يُقَيَّدُ بِه، فَتُجْعَلُ العُنُقُ في وسطِه.﴿وَٱلسَّلَـٰسِلُ﴾: جَمْعُ سِلْسِلةٍ، وهي مَجْمُوعُ حِلَقٍ غَلِيظَةٍ مِن حَدِيدٍ مُتَّصِلٍ بَعْضُها بِبَعْضٍ.﴿يُسۡحَبُونَ﴾: يُجَرُّونَ."
  40,72,"﴿ٱلۡحَمِيمِ﴾: الماءِ الحارِّ الَّذِي اشْتَدَّ غَلَيانُه وحَرّهُ.﴿يُسۡجَرُونَ﴾: يُوقَدُ بِهِم."
  40,74,"﴿ضَلُّواْ عَنَّا﴾: غابُوا عَنْ عُيُونِنا."
  40,75,"﴿تَفۡرَحُونَ﴾: تَفْرَحُونَ بِما تَقْتَرِفُونَهُ مِنَ المعاصِي والآثامِ.﴿تَمۡرَحُونَ﴾: تَبْطَرُونَ وتَبغُونَ على عِبادِ اللهِ."
  40,76,"﴿مَثۡوَى ٱلۡمُتَكَبِّرِينَ﴾: مَنزِلُهُم."
  40,78,"﴿بِـَٔايَةٍ﴾: بِمُعْجِزَةٍ.﴿أَمۡرُ ٱللَّهِ﴾: بِنُزُولِ العَذابِ على الكُفّارِ.﴿ٱلۡمُبۡطِلُونَ﴾: الَّذين يَتَّبِعُونَ الباطِلَ."
  40,80,"﴿وَلِتَبۡلُغُواْ عَلَيۡهَا حَاجَةࣰ فِي صُدُورِكُمۡ﴾: ولِتَبْلُغُوا بالحَمُولَةِ على بَعْضِها، وهي الإبِلُ، حاجَةً في صُدُورِكُم مِنَ الوصُولِ إلى الأقْطارِ البعِيدةِ. والحاجةُ: النِّيَّةُ والعَزِيمَةُ.﴿ٱلۡفُلۡكِ﴾: السُّفُنِ."
  40,82,"﴿وَءَاثَارࣰا فِي ٱلۡأَرۡضِ﴾: وأَبْقى آثارًا في الأرضِ مِنَ الأَبْنِيَةِ والمصانِع والغِراسِ.﴿فَمَآ أَغۡنَىٰ﴾: فَما أجْزَأَ وكَفى."
  40,83,"﴿بِٱلۡبَيِّنَـٰتِ﴾: بالُمعْجِزاتِ الظّاهِراتِ.﴿فَرِحُواْ بِمَا عِندَهُم مِّنَ ٱلۡعِلۡمِ﴾: الُمناقِضِ لما جاءتْ به الرُّسُلُ، وقالُوا: نَحْنُ أعْلمُ مِنَ الرُّسُلِ ولَن نُّعَذِّبَ.﴿وَحَاقَ بِهِم﴾: ونَزَلَ وأَحاطَ بِهم.﴿مَّا كَانُواْ بِهِۦ يَسۡتَهۡزِءُونَ﴾: ما كانُوا يَسْتَعْجِلُونَ بِهِ رسُلَهُم عَلى سَبِيلِ السُّخْرِيَةِ والاسْتِهْزاءِ، وهُوَ عَذابُ الاسْتِئْصالِ."
  40,84,"﴿بَأۡسَنَا﴾: عَذابَنا."
  40,85,"﴿سُنَّتَ ٱللَّهِ ٱلَّتِي قَدۡ خَلَتۡ فِي عِبَادِهِۦ﴾: طَرِيقَتَهُ الَّتِي سَنَّها في الأُمَم كلِّها ألّا ينفَعَها الإيمانُ إذا رَأَوا العَذابَ.﴿وَخَسِرَ هُنَالِكَ ٱلۡكَـٰفِرُونَ﴾: وهَلَكَ عِنْدَ مَجِيءِ بأْسِ اللهِ الكافِرُونَ بِرَبِّهِم."
