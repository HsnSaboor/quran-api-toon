tafsir[53]{c,v,t}:
  24,1,"﴿وَفَرَضۡنَـٰهَا﴾: أوْجَبْنا أحْكامَ هذه السُّورةِ عَلَيكُم.﴿ءَايَـٰتِۭ بَيِّنَـٰتࣲ﴾: دَلالاتٍ واضِحاتٍ."
  24,2,"﴿فَٱجۡلِدُواْ﴾: فاضربُوا بالسَّوطِ.﴿رَأۡفَةࣱ﴾: رَحْمَةٌ ورِقَّةٌ.﴿وَلۡيَشۡهَدۡ﴾: ولْيَحْضُرْ."
  24,3,"﴿وَحُرِّمَ ذَ ٰ⁠لِكَ﴾: أي: نكاحُ الزِّانِيةِ حتى تَتَوْبَ أوْ حُرِّم الزِّنى نَفْسُه."
  24,4,"﴿يَرۡمُونَ﴾: يَقْذِفُونَ بالزِّنى.﴿ٱلۡمُحۡصَنَـٰتِ﴾: النِّساءَ الحرائِرَ العَفِيفاتِ، وكذلك الرِّجالُ.﴿ٱلۡفَـٰسِقُونَ﴾: الخارِجُونَ عَن طاعَةِ اللهِ."
  24,6,"﴿يَرۡمُونَ أَزۡوَ ٰ⁠جَهُمۡ﴾: يَقْذِفُونَ زَوْجاتِهم بالزِّنى.﴿لَمِنَ ٱلصَّـٰدِقِينَ﴾: أي: في قَذْفِه زَوْجَتَه بالزِّنى."
  24,7,"﴿وَٱلۡخَـٰمِسَةُ﴾: أي: الشَّهادَةُ الخامِسَةُ.﴿مِنَ ٱلۡكَـٰذِبِينَ﴾: أي: في قَذْفِه زَوْجتَه بالزِّنى."
  24,8,"﴿وَيَدۡرَؤُاْ عَنۡهَا﴾: ويَدْفَعُ عَنِ الزَّوجَةِ المَقْذُوفَةِ."
  24,10,"﴿تَوَّابٌ﴾: كثِيرُ القَبُولِ لِتَوْبَةِ مَن تابَ إليهِ مِن عِبادِهِ.﴿حَكِيمٌ﴾: أي: في شَرائِعِه وأَحْكامِه، فلم يُنْزِلْ بالكاذِبِ مِن المتَلاعِنَينِ ما دَعا به على نَفْسِه."
  24,11,"﴿بِٱلۡإِفۡكِ﴾: أقْبحِ الكَذِبِ وأفْحَشِه، وهو اتِّهامُ أمِّ المؤمنينَ عائِشَةَ رضي اللهُ عَنَها بالفاحِشةِ.﴿عُصۡبَةࣱ مِّنكُمۡ﴾: جَماعةٌ مُنْتَسِبُونَ إليكُم.﴿مَّا ٱكۡتَسَبَ﴾: جَزاءُ ما ارْتَكَبَ.﴿تَوَلَّىٰ كِبۡرَهُۥ﴾: تَحَمَّلَ مُعْظَمَ الإفْكِ، وهو عبدُ اللهِ بنُ أُبيِّ بنِ سَلُولٍ كبيرُ المنافِقِيِنَ."
  24,12,"﴿لَّوۡلَآ﴾: هَلّا.﴿إِفۡكࣱ مُّبِينࣱ﴾: بُهْتانٌ واضِحٌ."
  24,14,"﴿لَمَسَّكُمۡ﴾: لَأصابَكُم.﴿فِي مَآ أَفَضۡتُمۡ فِيهِ﴾: بِسَبَبِ ماخُضْتُم فيه مِن حَدِيثِ الإفْكِ."
  24,15,"﴿إِذۡ تَلَقَّوۡنَهُۥ﴾: حِينَ تَتَلَقَّفُونَ حَدِيثَ الإفْكِ وتَتَناقَلُونَه.﴿وَتَحۡسَبُونَهُۥ هَيِّنࣰا﴾: وتَظُنُّونَ تَلَقِّيَ الإفْكِ شَيئًا سَهْلًا لا يَلْحَقُكُم فيه إثْمٌ."
  24,16,"﴿مَّا يَكُونُ لَنَآ﴾: ما يَحِلُّ لَنا ولا يَنْبَغِي.﴿سُبۡحَـٰنَكَ﴾: تَنْزِيهًا لكَ يا رَبِّ.﴿بُهۡتَـٰنٌ﴾: افْتِراءٌ وكَذِبٌ."
  24,18,"﴿ٱلۡـَٔايَـٰتِ﴾: آياتِ القرآنِ المشْتَمِلَةَ على الأحْكامِ والمَواعِظِ."
  24,19,"﴿تَشِيعَ﴾: تَنْتَشِرَ.﴿ٱلۡفَـٰحِشَةُ﴾: الزِّنى وكلُّ قولٍ سيِّئٍ."
  24,20,"﴿وَلَوۡلَا فَضۡلُ ٱللَّهِ﴾: أي: لولا فَضْلُ اللهِ لَعاجَلَ مَن خالَفَ أمْرَه بالعُقُوبَةِ.﴿رَءُوفࣱ﴾: كَثِيرُ الرَّأْفَةِ والمَحَبَّةِ لِعِبادِه.﴿رَّحِيمࣱ﴾: بِعِبادِه فَيَتَقَدَّمُ إلَيِهم بِمِثْلِ هذا الإعْذارِ والإنْذارِ."
  24,21,"﴿خُطُوَ ٰ⁠تِ ٱلشَّيۡطَـٰنِ﴾: طُرُقَه وآثارَه.﴿بِٱلۡفَحۡشَآءِ﴾: ما عَظُمَ قُبْحُه مِنَ الذُّنوب.﴿وَٱلۡمُنكَرِ﴾: ما يُنْكِرُه الشَّرعُ أو يَكرَهُه.﴿مَا زَكَىٰ﴾: ما طَهُرَ، ولا تَطَهَّرَ مِن دَنَسِ الذُّنُوبِ﴿يُزَكِّي﴾: يُطَهِّرُ."
  24,22,"﴿وَلَا يَأۡتَلِ﴾: ولا يَحْلِفْ.﴿أُوْلُواْ ٱلۡفَضۡلِ﴾: أصْحابُ الفَضَلِ في الدِّينِ.﴿وَٱلسَّعَةِ﴾: الغِنى في المالِ.﴿أَن يُؤۡتُوٓاْ﴾: أي: يَحْلِفُونَ على ألّا يُعْطُوا.﴿أُوْلِي ٱلۡقُرۡبَىٰ﴾: أصْحابَ القَرابَةِ.﴿وَلۡيَعۡفُواْ﴾: أي: ولْيَتَجاوزُوا عَن ذَنْبِهِم وإساءَتِهِم.﴿وَلۡيَصۡفَحُوٓاْ﴾: أي: بالإعْراضِ عَن مُّؤاخَذَتِهِم."
  24,23,"﴿يَرۡمُونَ﴾: يَقْذِفُون بالزِّنى.﴿ٱلۡمُحۡصَنَـٰتِ﴾: العفِيفاتِ.﴿ٱلۡغَـٰفِلَـٰتِ﴾: اللّاتي لا تَخْطُرُ بِبالِهنَّ الفاحِشَةُ."
  24,25,"﴿دِينَهُمُ ٱلۡحَقَّ﴾: جَزاءَهم الثّابِتَ لهم بالعَدْلِ."
  24,26,"﴿مِمَّا يَقُولُونَ﴾: أي: مِنِ اتِّهامِهِم."
  24,27,"﴿حَتَّىٰ تَسۡتَأۡنِسُواْ﴾: حتى تَسْتأذِنُوا."
  24,28,"﴿هُوَ أَزۡكَىٰ لَكُمۡ﴾: الرُّجُوعُ أْطَهرُ لكُم."
  24,29,"﴿جُنَاحٌ﴾: حَرَجٌ.﴿غَيۡرَ مَسۡكُونَةࣲ﴾: ليسَتْ مُخَصَّصَةً لِسَكَنِ أُناسٍ مُعَيَّنِينَ كالفَنادِقِ والمساجِدِ.﴿مَتَـٰعࣱ لَّكُمۡ﴾: مَنفَعَةٌ ومَصْلَحَةٌ لكُم."
  24,30,"﴿يَغُضُّواْ مِنۡ أَبۡصَـٰرِهِمۡ﴾: يَخْفِضُوا نَظَرَهُم إلى المُحَرَّماتِ.﴿أَزۡكَىٰ﴾: أطَهرُ."
  24,31,"﴿وَلَا يُبۡدِينَ﴾: ولا يُظْهِرْنَ.﴿زِينَتَهُنَّ﴾: مواضِعَ زينَتِهنَّ مِنَ الجَسَدِ.﴿إِلَّا مَا ظَهَرَ مِنۡهَا﴾: مِنَ الثِّيابِ الظّاهِرَةِ التي جَرَتِ العادَةُ بِلُبسِها.﴿عَلَىٰ جُيُوبِهِنَّ﴾: أي: على فَتَحات ثِيابِهِنَّ مِن جِهَةِ صُدُورِهِنَّ.﴿لِبُعُولَتِهِنَّ﴾: لأزْواجِهِنَّ.﴿أَوۡ نِسَآئِهِنَّ﴾: مِنَ المسْلِماتِ المخْتَصّاتِ بهِنَّ بالصُّحْبَةِ أو الخِدْمَةِ.﴿مَا مَلَكَتۡ أَيۡمَـٰنُهُنَّ﴾: أي: مِنَ العَبِيدِ والإماءِ.﴿غَيۡرِ أُوْلِي ٱلۡإِرۡبَةِ﴾: الَّذينَ لا حاجةَ لهم في النِّساءِ.﴿أَوِ ٱلطِّفۡلِ﴾: أي: الأطْفالِ.﴿لَمۡ يَظۡهَرُواْ﴾: لم يَطَّلِعُوا ولم يَبْلُغُوا حَدَّ الشَّهْوةِ."
  24,32,"﴿ٱلۡأَيَـٰمَىٰ﴾: الَّذينَ لا أزْواجَ لَهُم مِنَ الأحْرارِ والحرائِر."
  24,33,"﴿وَلۡيَسۡتَعۡفِفِ﴾: ولْيطْلُب العِفَّةَ عَنِ الزِّنى والحَرامِ.﴿لَا يَجِدُونَ نِكَاحًا﴾: أي: لا يَجِدُونَ قُدْرَةً مالِيَّةً على النِّكاحِ.﴿ٱلۡكِتَـٰبَ﴾: أي: المُكاتَبَةَ، وهي أن يكاتِبَ الرَّجلُ عبدَه على مالٍ يُؤَدِّيهِ مُنَجَّمًا، فإذا أدّاه فهو حُرٌّ.﴿مِمَّا مَلَكَتۡ أَيۡمَـٰنُكُمۡ﴾: مِن عَبيدِكُم وإمائِكُم.﴿فَكَاتِبُوهُمۡ﴾: أي: فاكْتُبُوا مَعَهُم عَقْدَ مُكاتَبَةٍ.﴿فَتَيَـٰتِكُمۡ﴾: إماءَكُم وجَوارِيَكُم.﴿ٱلۡبِغَآءِ﴾: الزِّنى.﴿تَحَصُّنࣰا﴾: تَعَفُّفًا.﴿غَفُورࣱ رَّحِيمࣱ﴾: أي: لمن أُكرِهَتْ على الزِّنى، وبَقِيَ الإثْمُ على مَن أكْرَهَها."
  24,34,"﴿ءَايَـٰتࣲ مُّبَيِّنَـٰتࣲ﴾: آياتِ القرآنِ المفصَّلاتِ.﴿خَلَوۡاْ﴾: مَضَوا."
  24,35,"﴿كَمِشۡكَوٰةࣲ﴾: الِمشْكاةُ: الكَوَّة في الحائِطِ غيرُ النّافِذَةِ.﴿مِصۡبَاحٌ﴾: سِراجٌ.﴿زُجَاجَةٍ﴾: قِنْدِيلٍ مِنَ الزُّجاجِ صافٍ أزْهَرَ.﴿كَوۡكَبࣱ دُرِّيࣱّ﴾: نَجْمٌ مُضِيءٌ كالدُّرِّ في صَفائِه وإشْراقِه.﴿لَّا شَرۡقِيَّةࣲ وَلَا غَرۡبِيَّةࣲ﴾: أي: بَلْ هِيَ في موقِعٍ مُتَوَسِّطٍ بينَ الشَّرقِ والغَرْبِ، فَتَتَعَرَّضُ للشَّمسِ طوالَ النَّهارِ."
  24,36,"﴿بُيُوتٍ﴾: مَساجِدَ.﴿أَذِنَ﴾: أمَرَ وقَضى.﴿تُرۡفَعَ﴾: تُبْنىَ وتُعَظَّمَ.﴿بِٱلۡغُدُوِّ وَٱلۡـَٔاصَالِ﴾: أوَّلِ النَّهار وآخِرِه."
  24,37,"﴿لَّا تُلۡهِيهِمۡ﴾: لا تشْغَلُهُم.﴿تَتَقَلَّبُ﴾: تَضْطَربُ وتَتَحَوَّلُ."
  24,39,"﴿كَسَرَابِۭ﴾: السَّرابُ: ما يُرى ظُهرًا في المفاوِزِ من لَمَعانِ الشَّمْسِ عِنْدَ اشْتِدادِ الحرِّ، يَظُنُّه العَطْشانُ ماءً.﴿بِقِيعَةࣲ﴾: جَمْعِ «قاعٍ» وهو المستَوي مِنَ الأرضِ."
  24,40,"﴿لُّجِّيࣲّ﴾: عَمِيقٍ كَثِيرِ الماءِ.﴿يَغۡشَىٰهُ﴾: يَعْلوُ ويُغَطِّي.﴿يَدَهُۥ لَمۡ يَكَدۡ يَرَىٰهَا﴾: لم يُقارِبْ رُؤيتَها مِن شِدَّةِ الظُّلُماتِ."
  24,41,"﴿صَـٰٓفَّـٰتࣲ﴾: باسِطاتٍ أجْنِحَتَها في الهَواءِ.﴿صَلَاتَهُۥ﴾: أي: المُصَلِّي مِنهُم عَلِم صَلاتَه.﴿وَتَسۡبِيحَهُۥ﴾: أي: المُسَبِّحُ مِنهم عَلِمَ تَسْبِيحَهُ."
  24,42,"﴿ٱلۡمَصِيرُ﴾: المَرْجِعُ بعد الموتِ."
  24,43,"﴿يُزۡجِي﴾: يَسُوقُ بِرِفْقٍ.﴿يُؤَلِّفُ﴾: يَجْمَعُ.﴿رُكَامࣰا﴾: مُجْتَمِعًا ومُتَراكِمًا بَعْضُهَ فَوْقَ بَعْضٍ.﴿ٱلۡوَدۡقَ﴾: المَطَرَ.﴿مِنۡ خِلَـٰلِهِۦ﴾: مِن مَّخارِجِ السَّحابِ.﴿مِن جِبَالࣲ﴾: أي: مِثلِ جبالٍ في عَظَمَتِه.﴿سَنَا بَرۡقِهِۦ﴾: ضَوءُ بَرْقِه ولمَعانُه."
  24,44,"﴿لِّأُوْلِي ٱلۡأَبۡصَـٰرِ﴾: لأصْحابِ العُقُولِ السَّلِيمةِ."
  24,45,"﴿عَلَىٰ بَطۡنِهِۦ﴾: كالحيّاتِ ونحوِها.﴿عَلَىٰ رِجۡلَيۡنِ﴾: كالإنْسانِ.﴿عَلَىٰٓ أَرۡبَعࣲ﴾: كالبهائِمِ ونحوِها."
  24,47,"﴿يَتَوَلَّىٰ﴾: يُعرِضُ."
  24,49,"﴿لَّهُمُ ٱلۡحَقُّ﴾: أي: في قَضاءِ النَّبيِّ ﷺ وحُكْمِهِ.﴿مُذۡعِنِينَ﴾: مُسْرِعِينَ مُنْقادِينَ."
  24,50,"﴿مَّرَضٌ﴾: أي: مِنَ النِّفاقِ.﴿ٱرۡتَابُوٓاْ﴾: شَكُّوا.﴿أَن يَحِيفَ﴾: أن يَجُورَ."
  24,52,"24:51"
  24,53,"﴿جَهۡدَ أَيۡمَـٰنِهِمۡ﴾: أي: بأَيمانٍ مُغَلَّظَةٍ.﴿لَيَخۡرُجُنَّ﴾: أي: لِلْجِهادِ."
  24,54,"﴿فَإِن تَوَلَّوۡاْ﴾: فَإن تُعْرِضُوا.﴿مَا حُمِّلَ﴾: ما أُمِرَ به مِن تَبْلِيغِ الرِّسالَةِ.﴿مَّا حُمِّلۡتُمۡ﴾: ما أُمِرْتُم بِه مِنَ الطّاعةِ والانْقِيادِ.﴿ٱلۡبَلَـٰغُ ٱلۡمُبِينُ﴾: التَّبْلِيغُ الواضِحُ."
  24,55,"﴿لَيَسۡتَخۡلِفَنَّهُمۡ﴾: أي: لَيَجْعَلَنَّهم خُلَفاءَ.﴿وَلَيُمَكِّنَنَّ لَهُمۡ﴾: ولَيُثَبِّتَنَّ لَهُم.﴿دِينَهُمُ﴾: وهو دينُ الإسلامِ.﴿ٱلۡفَـٰسِقُونَ﴾: الخارِجُونَ عَن طاعَةِ اللهِ."
  24,57,"﴿مُعۡجِزِينَ﴾: فائتِينَ مِن عَذابِ اللهِ.﴿وَمَأۡوَىٰهُمُ﴾: ومَرْجِعُهُم.﴿وَلَبِئۡسَ﴾: وقَبُحَ.﴿ٱلۡمَصِيرُ﴾: المرجِعُ."
  24,58,"﴿ٱلَّذِينَ مَلَكَتۡ أَيۡمَـٰنُكُمۡ﴾: هُمُ العبيدُ والإماءُ.﴿ٱلۡحُلُمَ﴾: أي: سِنَّ الاحْتِلامِ.﴿ثَلَـٰثُ عَوۡرَ ٰ⁠تࣲ لَّكُمۡ﴾: أي: ثلاثةُ أوقاتٍ يَخْتَلُّ فيها السِّتْرُ ويَقِلُّ.﴿جُنَاحُۢ﴾: حَرَجٌ.﴿طَوَّ ٰ⁠فُونَ﴾: أي: كَثِيرُو التَّطْوافِ والتَّردُّدِ عَلَيكُم لِلْخِدْمَةِ وقَضاءِ المصالِحِ.﴿يُبَيِّنُ﴾: يُوضِّحُ.﴿ٱلۡـَٔايَـٰتِ﴾: أي: آياتِ القُرآنِ الدّالَّةَ على الأحْكامِ."
  24,59,"﴿ٱلۡحُلُمَ﴾: سِنَّ الاحْتِلامِ والبُلُوغِ."
  24,60,"﴿وَٱلۡقَوَ ٰ⁠عِدُ مِنَ ٱلنِّسَآءِ﴾: العَجائِزُ اللّاتي قَعَدْنَ عَنِ الحَيضِ والاسْتِمْتاعِ لِكِبَرِهِنَّ.﴿لَا يَرۡجُونَ نِكَاحࣰا﴾: لا يَطْمَعْنَ فيه.﴿مُتَبَرِّجَـٰتِۭ﴾: مُظْهِراتٍ.﴿وَأَن يَسۡتَعۡفِفۡنَ﴾: وأن يَتْرُكْنَ وضْعَ الثِّيابِ لِطَلَبِ العِفَّةِ."
  24,61,"﴿حَرَجࣱ﴾: إثْمٌ.﴿أَوۡ مَا مَلَكۡتُم مَّفَاتِحَهُۥٓ﴾: أي: البُيوتِ الَّتي تَمْلِكُونَ التَّصرُّفَ فِيها بإذِنِ أرْبابِها.﴿أَشۡتَاتࣰا﴾: مُتَفَرِّقِينَ.﴿ٱلۡـَٔايَـٰتِ﴾: أي: آياتِ القرآنِ الدّالَّةَ على الأحْكامِ."
  24,62,"﴿أَمۡرࣲ جَامِعࣲ﴾: أمرٍ مُهِمٍّ يَجِبُ اجْتِماعُهُم لَهُ.﴿لِبَعۡضِ شَأۡنِهِمۡ﴾: أي: لِبَعْضِ أُمُورِهِم."
  24,63,"﴿دُعَآءَ ٱلرَّسُولِ﴾: دَعْوتَهُ لَكُم لِلاجْتِماعِ، أو نِداءَكُم لَهُ ﷺ.﴿يَتَسَلَّلُونَ﴾: يَخْرُجُونَ خِفْيةً مِن غِيرِ إذْنٍ.﴿لِوَاذࣰا﴾: أي: مُسْتَترِينَ بعضُهم بِبَعْضٍ عنْدَ الخُروجِ.﴿فِتۡنَةٌ﴾: بَلاءٌ ومِحْنَةٌ في الدُّنْيا."
