tafsir[92]{c,v,t}:
  12,1,"﴿ٱلۡمُبِينِ﴾: الواضِحِ في معانيه وأحكامِه."
  12,3,"﴿ٱلۡغَـٰفِلِينَ﴾: السّاهِين، أي: لم يَكُنْ لك عِلْمٌ بهذا الإخبارِ."
  12,4,"﴿سَـٰجِدِينَ﴾: أي: سجودَ تَكريمٍ واحترامٍ."
  12,5,"﴿فَيَكِيدُواْ لَكَ﴾: يَحْتالُوا من أجلِ إهلاكِك حَسَدًا.﴿مُّبِينࣱ﴾: ظاهرُ العداوةِ."
  12,6,"﴿يَجۡتَبِيكَ﴾: يختارُك لأمورٍ عظيمة.﴿تَأۡوِيلِ ٱلۡأَحَادِيثِ﴾: تفسيرِ الرُّؤى المناميةِ.﴿وَيُتِمُّ نِعۡمَتَهُۥ عَلَيۡكَ﴾: أي: بالنبوَّةِ والرسالةِ."
  12,7,"﴿ءَايَـٰتࣱ﴾: عِبَرٌ، وعلاماتٌ دالَّةٌ على قدرةِ اللهِ."
  12,8,"﴿عُصۡبَةٌ﴾: جماعةٌ من الرجالِ متناصِرُون.﴿ضَلَـٰلࣲ مُّبِينٍ﴾: خطأٍ بيِّنٍ في تفضيلِهما علينا."
  12,9,"﴿ٱطۡرَحُوهُ أَرۡضࣰا﴾: ألْقُوه في أرضٍ بعيدةٍ.﴿يَخۡلُ لَكُمۡ وَجۡهُ أَبِيكُمۡ﴾: يَخْلُصْ لكم حُبُّ أبيكم وإقبالُه عليكم.﴿مِنۢ بَعۡدِهِۦ﴾: من بعدِ قَتْلِ يوسفَ أو إبعادِه.﴿صَـٰلِحِينَ﴾: تائبين إلى اللهِ مِن فَعْلَتِكم."
  12,10,"﴿غَيَـٰبَتِ ٱلۡجُبِّ﴾: جوفِ البئرِ وأسفلِه حيثُ يَغيبُ خبرُه.﴿ٱلسَّيَّارَةِ﴾: المسافرين المارِّينَ بالبئرِ."
  12,12,"﴿يَرۡتَعۡ﴾: يَتَنعَّمْ في أكْلِ ما لَذَّ له وطابَ.﴿وَيَلۡعَبۡ﴾: يتسابَقْ ويرمِ بالسِّهام معنا."
  12,13,"﴿لَيَحۡزُنُنِيٓ﴾: لَيُؤْلمُ نفسي فِراقُ يوسفَ.﴿غَـٰفِلُونَ﴾: ساهُون."
  12,14,"﴿لَّخَـٰسِرُونَ﴾: عاجِزُون لا خيرَ فينا."
  12,15,"﴿وَأَجۡمَعُوٓاْ﴾: عَزَمُوا.﴿وَأَوۡحَيۡنَآ إِلَيۡهِ﴾: أعلمَ اللهُ يوسُفَ؛ تَطْمينًا لقَلْبِه.﴿لَتُنَبِّئَنَّهُم﴾: لتُخْبِرَنَّ إخوتَك."
  12,17,"﴿نَسۡتَبِقُ﴾: نتسابَقُ في الجَرْيِ والرَّمْيِ بالسِّهامِ.﴿مَتَـٰعِنَا﴾: ما ننتفِعُ به من الطَّعامِ والثيابِ ونحوِهما.﴿بِمُؤۡمِنࣲ لَّنَا﴾: بمُصَدِّقٍ لنا."
  12,18,"﴿سَوَّلَتۡ﴾: زَيَّنَتْ.﴿فَصَبۡرࣱ جَمِيلࣱ﴾: وهو ما لا جَزَعَ فيه، ولا شَكْوى معه لأحدٍ من الخَلْقِ."
  12,19,"﴿سَيَّارَةࣱ﴾: جماعةٌ من المسافرين.﴿وَارِدَهُمۡ﴾: مَن يتقدَّمُهم ليطلُبَ لهم الماءَ.﴿فَأَدۡلَىٰ دَلۡوَهُۥ﴾: فأَنْزَلَها الواردُ في البئرِ.﴿وَأَسَرُّوهُ﴾: وأخفى الوارِدُ وأصحابُه يوسفَ عن بقيةِ المسافرين.﴿بِضَـٰعَةࣰ﴾: متاعًا للتجارة."
  12,20,"﴿وَشَرَوۡهُ﴾: باعه إخوتُه.﴿بَخۡسࣲ﴾: قليلٍ ناقصٍ عن مِثْلِه.﴿ٱلزَّ ٰ⁠هِدِينَ﴾: المُعْرِضين عنه، غيرِ المبالِين به."
  12,21,"﴿أَكۡرِمِي مَثۡوَىٰهُ﴾: اجعلي مَقامَه عندنا كريمًا.﴿فِي ٱلۡأَرۡضِ﴾: أرضِ مصرَ.﴿وَٱللَّهُ غَالِبٌ عَلَىٰٓ أَمۡرِهِۦ﴾: لا يُعْجِزُه شيءٌ، ولا ينازعُه في حُكْمِه أحدٌ."
  12,22,"﴿أَشُدَّهُۥٓ﴾: منتهى قوتِه الجسميةِ، وتكامُلَ عَقْلِه.﴿حُكۡمࣰا﴾: حِكْمةً وفَهْمًا سديدًا، أو النبوَّةَ."
  12,23,"﴿وَرَ ٰ⁠وَدَتۡهُ﴾: ودَعَتْ امرأةُ العزيزِ يوسُفَ إلى نفسِها بلِينٍ ومُخادَعَةٍ.﴿هَيۡتَ لَكَ﴾: هلمَّ إليَّ وأقْبِلْ.﴿مَعَاذَ ٱللَّهِ﴾: أستجيرُ بالله وأعتصِمُ به ممّا تُريدين مني.﴿إِنَّهُۥ رَبِّيٓ﴾: إن زوجَكِ سيِّدي.﴿مَثۡوَايَ﴾: مَقامي عنده."
  12,24,"﴿هَمَّتۡ بِهِۦ﴾: مالَتْ إليه وعَزَمَتْ على فِعْلِ الفاحشةِ به.﴿وَهَمَّ بِهَا﴾: ما خَطَرَ بنفسِه من الميلِ بمقتضى الطبيعةِ البشريَّة.﴿بُرۡهَـٰنَ رَبِّهِۦ﴾: حُجَّةَ رَبِّه الواضحةَ التي مَنَعَتْه عن المَيْلِ لخَطَراتِ نفسِه.﴿ٱلسُّوٓءَ﴾: كلَّ ما يَسُوءُه، ومنه خيانةُ سَيِّدِه.﴿وَٱلۡفَحۡشَآءَ﴾: ما يَشْتَدُّ قُبْحُه من المعاصي، ومنه الزِّنى.﴿ٱلۡمُخۡلَصِينَ﴾: المختارِين لطاعةِ اللهِ ورسالتِه."
  12,25,"﴿وَٱسۡتَبَقَا ٱلۡبَابَ﴾: تسابَقا إليه، هو يريدُ الخروجَ وهي تمنعُه.﴿وَقَدَّتۡ قَمِيصَهُۥ مِن دُبُرࣲ﴾: شَقَّتْه طُولًا مِن خَلْفٍ.﴿وَأَلۡفَيَا سَيِّدَهَا﴾: وجدا زوجَها."
  12,26,"﴿وَشَهِدَ شَاهِدࣱ﴾: صَبِيٌّ في المهد أنطقَه اللهُ ببراءته."
  12,28,"﴿كَيۡدِكُنَّ﴾: احتيالِكنَّ ومَكْرِكنَّ."
  12,30,"﴿شَغَفَهَا حُبًّا﴾: دَخَلَ حُبُّه إلى غِلاف قلبِها، حتى تَمَكَّنَ."
  12,31,"﴿بِمَكۡرِهِنَّ﴾: باغتيابِهنَّ لها واحتيالِهنَّ في ذَمِّها.﴿أَعۡتَدَتۡ﴾: هَيَّأت.﴿مُتَّكَـࣰٔا﴾: ما يَتَّكِئْنَ عليه من الوَسائدِ ونحوِها.﴿أَكۡبَرۡنَهُۥ﴾: أعْظَمْنَه، ودَهِشْنَ من جَمالِه الرائعِ.﴿وَقَطَّعۡنَ أَيۡدِيَهُنَّ﴾: جَرَحْنَها بالسَّكاكين؛ لانشغالِهنَّ بحُسْنِه.﴿حَـٰشَ لِلَّهِ﴾: معاذَ اللهِ وتنزيهًا له."
  12,32,"﴿فَٱسۡتَعۡصَمَ﴾: امتنَع وأبى.﴿ٱلصَّـٰغِرِينَ﴾: الأذِلّاءِ المُهانِين."
  12,33,"﴿أَصۡبُ إِلَيۡهِنَّ﴾: أمِلْ إلى إجابتِهنَّ.﴿ٱلۡجَـٰهِلِينَ﴾: الذين يرتكِبُون الإثمَ؛ لجَهْلِهم بعواقِبه."
  12,35,"﴿بَدَا﴾: ظَهَر.﴿ٱلۡـَٔايَـٰتِ﴾: الأدلَّةَ على براءةِ يوسفَ وعِفَّتِه.﴿حَتَّىٰ حِينࣲ﴾: إلى زمنٍ غيرِ محدَّدٍ."
  12,36,"﴿خَمۡرࣰا﴾: عِنَبًا يصير خَمْرًا.﴿بِتَأۡوِيلِهِۦٓ﴾: بتفسيرِ ما رَأَيْنا."
  12,37,"﴿ذَ ٰ⁠لِكُمَا﴾: التعبيرُ للرؤيا، أو العِلْمُ بالغَيبِ."
  12,39,"12:38"
  12,40,"﴿سَمَّيۡتُمُوهَآ﴾: جَعَلْتُموها آلهةً، تَوَهُّمًا منكم وضلالًا.﴿سُلۡطَـٰنٍ﴾: حُجَّةٍ تَدُلُّ على صحَّتِها.﴿ٱلۡقَيِّمُ﴾: المستقيمُ، والثابتُ الذي لا شَكَّ فيه."
  12,42,"﴿ظَنَّ﴾: عَلِمَ.﴿رَبِّكَ﴾: سيِّدِكَ الملِكِ.﴿فَأَنسَىٰهُ ٱلشَّيۡطَـٰنُ﴾: فأنسى الشيطانُ ساقِيَ المَلِكِ.﴿ذِكۡرَ رَبِّهِۦ﴾: ذِكْرَ يوسُفَ عند سيِّده الملِكِ.﴿بِضۡعَ﴾: من ثلاثٍ إلى تسعٍ."
  12,43,"﴿عِجَافࣱ﴾: جَمْعُ عَجْفاءَ، وهي التي بلغَتْ غايةَ الهُزال.﴿تَعۡبُرُونَ﴾: تُفَسِّرُون."
  12,44,"﴿أَضۡغَـٰثُ أَحۡلَـٰمࣲ﴾: تَخاليطُ مَناماتٍ كاذبةٍ.﴿بِتَأۡوِيلِ ٱلۡأَحۡلَـٰمِ﴾: بتفسيرِ ما يراه النائمون ممّا لا حقيقةَ له."
  12,45,"﴿وَٱدَّكَرَ﴾: تَذَكَّرَ أمْرَ يوسُفَ.﴿أُمَّةٍ﴾: مُدَّةٍ."
  12,47,"﴿دَأَبࣰا﴾: جادِّين على عادتِكم.﴿فَمَا حَصَدتُّمۡ﴾: ما قَطَعْتُموه حالَ نُضْجِه.﴿فَذَرُوهُ﴾: اترُكُوه وادَّخِرُوه."
  12,48,"﴿شِدَادࣱ﴾: شديدةُ الجَدْبِ.﴿يَأۡكُلۡنَ مَا قَدَّمۡتُمۡ لَهُنَّ﴾: يأكلُ الناسُ كلَّ ما ادَّخَرْتُم لأجْلِهنَّ.﴿تُحۡصِنُونَ﴾: تُخَبِّئونه من البَذْرِ للزِّراعةِ."
  12,49,"﴿يُغَاثُ ٱلنَّاسُ﴾: يأتيهم المطرُ.﴿يَعۡصِرُونَ﴾: ما يُعْصَرُ من الثِّمارِ؛ لكثرةِ الخيرِ."
  12,50,"﴿رَبِّكَ﴾: سيِّدِكَ الملِكِ.﴿مَا بَالُ ٱلنِّسۡوَةِ﴾: ما شأنُهنَّ وحقيقةُ أمْرِهنَّ معي؟﴿قَطَّعۡنَ أَيۡدِيَهُنَّ﴾: جَرَحْنَها بالسَّكاكين.﴿بِكَيۡدِهِنَّ﴾: باحتيالهنَّ ومَكْرِهنَّ."
  12,51,"﴿مَا خَطۡبُكُنَّ﴾: ما شأنكُنَّ؟﴿حَـٰشَ لِلَّهِ﴾: معاذَ اللهِ وتنزيهًا له.﴿حَصۡحَصَٱلۡحَقُّ﴾: ظَهَرَ بَعْدَ خَفائِه."
  12,52,"﴿ذَ ٰ⁠لِكَ﴾: أي: ما قُلْتُه في تنزيهِ يوسفَ، واعترافي بإغرائه.﴿لِيَعۡلَمَ﴾: أي: زوجي.﴿لَمۡ أَخُنۡهُ بِٱلۡغَيۡبِ﴾: لم تَقَعْ مني الفاحشةُ والأبوابُ مُغَلَّقَةٌ.﴿لَا يَهۡدِي﴾: لا يُوَفِّقُ."
  12,54,"﴿أَسۡتَخۡلِصۡهُ لِنَفۡسِي﴾: أجْعَلْ يوسفَ مِن خاصَّتي وأهلِ مَشُورتي.﴿مَكِينٌ﴾: ذو مَكانةٍ رفيعةٍ وقولٍ نافذٍ."
  12,55,"﴿ٱلۡأَرۡضِ﴾: أرضِ مصرَ."
  12,56,"﴿وَكَذَ ٰ⁠لِكَ﴾: وكما أنْعَمْنا على يوسفَ بالخَلاصِ من السِّجْنِ.﴿يَتَبَوَّأُ مِنۡهَا﴾: يَنْزِلُ من بلاد مِصرَ."
  12,58,"﴿مُنكِرُونَ﴾: لم يَعْرِفُوا يوسفَ لطولِ المدةِ، وتَغَيُّرِهيئتِه."
  12,59,"﴿جَهَّزَهُم بِجَهَازِهِمۡ﴾: هيَّأ لهم ما هم في حاجةٍ إليه من طعامٍ ومَتاعٍ.﴿ٱلۡمُنزِلِينَ﴾: المُضِيفِين."
  12,61,"﴿سَنُرَ ٰ⁠وِدُ عَنۡهُ أَبَاهُ﴾: سنجتهدُ في استمالةِ أبيه برِفْقٍ؛ ليُرْسِلَه معنا."
  12,62,"﴿لِفِتۡيَـٰنِهِ﴾: غِلْمانِ يوسفَ.﴿بِضَـٰعَتَهُمۡ فِي رِحَالِهِمۡ﴾: ثمنَ ما اشترَوْه في أمتعتِهم.﴿ٱنقَلَبُوٓاْ﴾: رَجَعُوا."
  12,63,"﴿مُنِعَ مِنَّا ٱلۡكَيۡلُ﴾: حُكِمَ بمَنعِه عنّا بعدَ هذه المرَّةِ.﴿نَكۡتَلۡ﴾: نَحصُلْ على ما نَحْتاج إليه مُقَدَّرًا بالكَيْلِ."
  12,65,"﴿مَتَـٰعَهُمۡ﴾: أوْعِيتَهم، أو أمتعتَهم.﴿مَا نَبۡغِي﴾: ماذا نَطْلُبُ أكثرَ من هذا الإكرامِ؟﴿وَنَمِيرُ أَهۡلَنَا﴾: نَجْلُبُ لهم الطعامَ."
  12,66,"﴿مَوۡثِقࣰا مِّنَ ٱللَّهِ﴾: عَهْدًا، وتُؤَكِّدُوه بالحَلِفِ باللهِ.﴿يُحَاطَ بِكُمۡ﴾: تُغْلَبُوا، فلا تَسْتطيعوا الإتيانَ به، أو تَهْلِكُوا جميعًا.﴿وَكِيلࣱ﴾: رقيبٌ مُطَّلعٌ."
  12,67,"﴿وَمَآ أُغۡنِي عَنكُم﴾: لا أدْفَعُ عنكم.﴿عَلَيۡهِ تَوَكَّلۡتُ﴾: اعتمَدْتُ على ربي وفَوَّضْتُ أمري إليه."
  12,68,"﴿حَاجَةࣰ فِي نَفۡسِ يَعۡقُوبَ﴾: وهي شَفَقَتُه على أولادِه أن تصيبَهم العَيْنُ.﴿قَضَىٰهَا﴾: أدْرَكَها، ووَصّى أولادَه باتِّقائِها."
  12,69,"﴿ءَاوَىٰٓ إِلَيۡهِ أَخَاهُ﴾: ضَمَّ إليه شقيقَه بِنْيامينَ.﴿فَلَا تَبۡتَئِسۡ﴾: فلا تَحْزَنْ."
  12,70,"﴿ٱلسِّقَايَةَ﴾: إناءٌ للشُّرْبِ، وهو هنا المِكيالُ الذي يُكالُ به الطَّعامُ.﴿أَذَّنَ مُؤَذِّنٌ﴾: نادى مُنادٍ.﴿ٱلۡعِيرُ﴾: القافلةُ المحمَّلةُ بالطَّعام."
  12,72,"﴿صُوَاعَ ٱلۡمَلِكِ﴾: المكيالَ الذي يَكيلُ به.﴿زَعِيمࣱ﴾: ضامِنٌ وكفيلٌ."
  12,74,"12:73"
  12,75,"﴿جَزَ ٰ⁠ٓؤُهُۥ مَن وُجِدَ فِي رَحۡلِهِۦ﴾: عقوبةُ سَرِقَتِه استرقاقُ مَن وُجِدَ المِكْيالُ في مَتاعِه."
  12,76,"﴿كَذَ ٰ⁠لِكَ كِدۡنَا لِيُوسُفَ﴾: يَسَّرْنا له هذا التدبيرَ الخَفِيَّ للتوصُّلِ إلى غَرَضِه.﴿دِينِ ٱلۡمَلِكِ﴾: شريعةِ مَلِكِ مصرَ."
  12,77,"﴿أَسَرَّهَا﴾: فأخفى يوسفُ مقالَتَهم التي سَمِعَها مِن نِسْبَتِهم إياه إلى السَّرِقَةِ.﴿مَّكَانࣰا﴾: مَنزِلَةً."
  12,79,"﴿مَعَاذَ ٱللَّهِ﴾: نَسْتجيرُ باللّٰهِ ونعتصِمُ به.﴿مَتَـٰعَنَا﴾: مِكْيالَنا الَّذي نَكِيلُ به الطَّعامَ."
  12,80,"﴿ٱسۡتَيۡـَٔسُواْ مِنۡهُ﴾: يَئِسُوا من إجابةِ يوسفَ لمَطْلبِهم.﴿خَلَصُواْ﴾: انفردُوا عن الناسِ.﴿نَجِيࣰّا﴾: مُتَسارِّين يتشاوَرُون بينهم.﴿مَّوۡثِقࣰا مِّنَ ٱللَّهِ﴾: عَهْدًا وأكّدْتُموه بالحَلِفِ باللهِ.﴿مَا فَرَّطتُمۡ﴾: قَصَّرْتُم.﴿فَلَنۡ أَبۡرَحَ ٱلۡأَرۡضَ﴾: لن أُفارِقَ أرضَ مصرَ."
  12,81,"﴿وَمَا كُنَّا لِلۡغَيۡبِ حَـٰفِظِينَ﴾: ولم نَدْرِ حين عاهَدْناك على رَدِّه أنه سيَسْرِقُ."
  12,82,"﴿وَٱلۡعِيرَ﴾: القافلةَ.﴿أَقۡبَلۡنَا فِيهَا﴾: عُدْنا فيها."
  12,83,"﴿سَوَّلَتۡ﴾: زَيَّنَتْ.﴿فَصَبۡرࣱ جَمِيلٌ﴾: وهو ما لا جَزَعَ فيه، ولا شَكْوى معه لأحدٍ من الخَلْقِ."
  12,84,"﴿وَتَوَلَّىٰ عَنۡهُمۡ﴾: أعرضَ يعقوبُ عن خِطابِهم.﴿يَـٰٓأَسَفَىٰ﴾: يا حُزني الشديدَ.﴿وَٱبۡيَضَّتۡ عَيۡنَاهُ﴾: بذَهابِ سوادِهما، مما أدّى إلى ضَعْف بَصَرِه أو ذَهابِه.﴿كَظِيمࣱ﴾: ممتلئُ القلب حُزْنًا، يَكْتُمُه ولا يُبْدِيه."
  12,85,"﴿تَفۡتَؤُاْ﴾: لا تَزالُ.﴿حَرَضًا﴾: مُشرِفًا على الهَلاكِ."
  12,86,"﴿بَثِّي﴾: هَمِّي الشديدَ."
  12,87,"﴿فَتَحَسَّسُواْ مِن يُوسُفَ﴾: تَعَرَّفُوا وتَطَلَّبُوا خبرَه.﴿رَّوۡحِ ٱللَّهِ﴾: رحمتِه وفَرَجِه."
  12,88,"﴿ٱلضُّرُّ﴾: الشِّدَّةُ والجوعُ من الجَدْبِ.﴿مُّزۡجَىٰةࣲ﴾: رديئةٍ قليلةٍ."
  12,90,"﴿مَنَّ ٱللَّهُ عَلَيۡنَآ﴾: تَفضَّلَ علينا بالسَّلامةِ والاجتماعِ."
  12,91,"﴿ءَاثَرَكَ ٱللَّهُ عَلَيۡنَا﴾: اختارك وفَضَّلَكَ علينا بما خَصَّكَ به من صفاتِ الكمالِ."
  12,92,"﴿لَا تَثۡرِيبَ﴾: لا تأنيبَ ولا لَوْمَ."
  12,93,"﴿يَأۡتِ بَصِيرࣰا﴾: يَرْجِعُ إليه بَصَرُهُ."
  12,94,"﴿فَصَلَتِ ٱلۡعِيرُ﴾: خرجَتِ القافلةُ من مصرَ قاصدةً الشّامَ.﴿لَأَجِدُ رِيحَ يُوسُفَ﴾: لَأَشُمُّ رائحتَه.﴿تُفَنِّدُونِ﴾: تَسْخَرُوا مني وتنسِبُوني إلى العَجْزِ، وضَعْفِ الرأيِ، أو تُكَذِّبوني."
  12,95,"﴿ضَلَـٰلِكَ﴾: خَطَئِك وبُعْدِك عن الصوابِ في حُبِّ يوسفَ."
  12,96,"﴿ٱلۡبَشِيرُ﴾: الذي بَشَّرَ يعقوبَ بأنّ يوسفَ حيٌّ."
  12,98,"12:97"
  12,99,"﴿ءَاوَىٰٓ إِلَيۡهِ أَبَوَيۡهِ﴾: ضَمَّهما وأنزلَهما عنده."
  12,100,"﴿وَرَفَعَ أَبَوَيۡهِ عَلَى ٱلۡعَرۡشِ﴾: أجْلَسَهما بجانبِه على سريرِ مُلْكِه؛ إكرامًا لهما.﴿وَخَرُّواْ﴾: هَوى أبوه وإخوتُه إلى الأرضِ.﴿لَهُۥ سُجَّدࣰا﴾: ساجدين تكريمًا ليوسفَ، على عادتِهم في تحيةِ الملُوك وأشباهِهم.﴿هَـٰذَا تَأۡوِيلُ رُءۡيَـٰيَ مِن قَبۡلُ﴾: أي: هذا السجودُ تفسيرٌ وتصديقٌ للرؤيا التي رأيتُها في صِغَري.﴿حَقࣰّا﴾: صِدْقًا، وليسَتْ من أكاذيبِ الأحلامِ.﴿أَحۡسَنَ بِيٓ﴾: أفاض اللهُ عليَّ من نِعَمِه.﴿ٱلۡبَدۡوِ﴾: باديةِ الشّامِ.﴿نَّزَغَ ٱلشَّيۡطَـٰنُ﴾: أفسَدَ وأغوى؛ لأنه هو سببُ الإفسادِ.﴿لَطِيفࣱ﴾: عليمٌ بخَفايا الأمورِ، مُدَبِّرٌ لها،ومُسَهِّلٌ لصعابِها."
  12,101,"﴿مِنَ ٱلۡمُلۡكِ﴾: مُلْكِ مِصْرَ.﴿تَأۡوِيلِ ٱلۡأَحَادِيثِ﴾: تفسير الرُّؤى، وغيرِها من العِلْمِ.﴿فَاطِرَ ٱلسَّمَـٰوَ ٰ⁠تِ وَٱلۡأَرۡضِ﴾: يا خالقَهما ومُبْدِعَهما.﴿وَلِيِّۦ﴾: مُتَوَلِّي حِفْظي وجميعِ شأني."
  12,102,"﴿ذَ ٰ⁠لِكَ﴾: ما ذُكِرَ من قصةِ يوسفَ وإخوانِه.﴿وَمَا كُنتَ لَدَيۡهِمۡ﴾: وما كنتَ حاضرًا مع إخوةِ يوسفَ.﴿أَجۡمَعُوٓاْ أَمۡرَهُمۡ﴾: حينَ دبَّرُوا إلقاءَه في جوفِ البئرِ وظُلْمَتِه.﴿وَهُمۡ يَمۡكُرُونَ﴾: يَحْتالُون في خُفْيَةٍ؛ لإيقاعِ الأذى والشَّرِّ به."
  12,103,"﴿ٱلنَّاسِ﴾: مُشْركِي قومِك."
  12,105,"﴿وَكَأَيِّن﴾: وكثيرٌ.﴿مِّنۡ ءَايَةࣲ﴾: من الدلائلِ الدالَّةِ على وحْدانيةِ اللهِ وقدرتِه.﴿يَمُرُّونَ عَلَيۡهَا﴾: يشاهِدُونها."
  12,106,"﴿وَهُم مُّشۡرِكُونَ﴾: فهم يَخْلِطُون مع إيمانِهم باللهِ ربًّا الإشراكَ في ألوهيَّتِه وعبادتِه."
  12,107,"﴿غَـٰشِيَةࣱ﴾: عقوبةٌ في الدنيا تَعُمُّهم.﴿بَغۡتَةࣰ﴾: فَجْأةً."
  12,108,"﴿بَصِيرَةٍ﴾: يقينٍ وحُجَّةٍ واضحةٍ."
  12,109,"﴿أَهۡلِ ٱلۡقُرَىٰٓ﴾: المدنِ والحاضرةِ."
  12,110,"﴿ٱسۡتَيۡـَٔسَ ٱلرُّسُلُ﴾: يَئِسوا من إيمانِ قومِهم.﴿وَظَنُّوٓاْ أَنَّهُمۡ قَدۡ كُذِبُواْ﴾: وظَنَّ المُرْسَلُ إليهم أن الرُّسَلَ قد كَذَبُوهم فيما أخبرُوهم عن اللهِ.﴿جَآءَهُمۡ نَصۡرُنَا﴾: جاء نَصْرُنا لرُسِلِنا عند شِدَّةِ الكَرْبِ.﴿بَأۡسُنَا﴾: عذابُنا."
  12,111,"﴿عِبۡرَةࣱ﴾: عِظَةٌ.﴿لِّأُوْلِي ٱلۡأَلۡبَـٰبِ﴾: أصحابِ العقولِ السليمةِ.﴿مَا كَانَ﴾: أي: هذا القرآنُ.﴿يُفۡتَرَىٰ﴾: يُخْتَلَقُ.﴿تَصۡدِيقَ ٱلَّذِي بَيۡنَ يَدَيۡهِ﴾: أي: القرآنُ يَشْهَدُ على صِدْقِ ما تقدَّمه من الكتبِ المنزَّلةِ، وأنها من عندِ اللهِ.﴿وَتَفۡصِيلَ كُلِّ شَيۡءࣲ﴾: تبيينَ ما يَحْتاجُ إليه العبادُ من أمورِ الدينِ."
