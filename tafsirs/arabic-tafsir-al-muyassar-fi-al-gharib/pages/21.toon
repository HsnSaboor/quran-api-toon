tafsir[95]{c,v,t}:
  21,2,"﴿مِّن ذِكۡرࣲ﴾: أي: مِن قُرْآنٍ.﴿مُّحۡدَثٍ﴾: أي: يَتَجَدَّدُ نُزُولُه."
  21,3,"﴿لَاهِيَةࣰ﴾: غافِلةً.﴿وَأَسَرُّواْ ٱلنَّجۡوَى﴾: اجْتَمَعُوا سِرًّا على أمْرٍ خَفِيٍّ.﴿ٱلسِّحۡرَ﴾: القرآنَ (على زَعْمِ الكُفّار)."
  21,5,"﴿أَضۡغَـٰثُ أَحۡلَـٰمِۭ﴾: أخْلاطُ أحْلامٍ لا حقيقةَ لها.﴿بَلِ ٱفۡتَرَىٰهُ﴾: بَلِ اخْتَلَقَه."
  21,7,"﴿إِلَّا رِجَالࣰا﴾: أي: مِنَ البَشَرِ فقط.﴿أَهۡلَ ٱلذِّكۡرِ﴾: أهْلَ العِلْمِ بالكُتُبِ الُمنَزَّلةِ السّابقَةِ."
  21,9,"﴿ٱلۡمُسۡرِفِينَ﴾: الُمتَجاوِزِينَ الحَدَّ بِكُفْرِهم بِرَبِّهم."
  21,10,"﴿ذِكۡرُكُمۡ﴾: عِزُّكُم وشَرَفُكم إنْ عَمِلْتُم بما جاءَ فيه."
  21,11,"﴿قَصَمۡنَا﴾: أهْلَكْنا واسَتْأصَلْنا.﴿كَانَتۡ ظَالِمَةࣰ﴾: كانَ أهلُها ظالِميَنَ بِكُفْرِهم باللهِ وبِما جاءتْهم به رُسُلُه.﴿وَأَنشَأۡنَا﴾: خَلَقْنا وأَوْجَدْنا."
  21,12,"﴿أَحَسُّواْ بَأۡسَنَآ﴾: أي: عَلِمُوا وتيَقَّنُوا بِوُقُوعِ عَذابِنا بِمُشاهَدَةِ بَوادِرِه.﴿يَرۡكُضُونَ﴾: يَهرُبُون مُسرِعِينَ."
  21,13,"﴿لَا تَرۡكُضُواْ﴾: لا تَهرُبُوا.﴿أُتۡرِفۡتُمۡ فِيهِ﴾: أُنْعِمْتُم فِيه مِنَ التَّرفِ.﴿لَعَلَّكُمۡ تُسۡـَٔلُونَ﴾: لَعَلَّكُم تُسْأَلُونَ مِن دُنْياكُم شَيْئًا، قِيلَ لَهُم ذَلك اسْتِهْزاءً بِهِم."
  21,14,"﴿يَـٰوَيۡلَنَآ﴾: يا هَلاكَنا."
  21,15,"﴿تِّلۡكَ دَعۡوَىٰهُمۡ﴾: أي: كلِمتَهم: «يا ويلَنا» يَدْعُونَ بها، ويُرَدِّدُونَها.﴿حَصِيدًا﴾: مُسْتَأْصَلِينَ كما يُحصَدُ الزَّرْعُ.﴿خَـٰمِدِينَ﴾: هالِكِينَ، قدِ انْطَفَأَتْ شَرارَةُ حَياتِهمِ."
  21,16,"﴿لَـٰعِبِينَ﴾: عَبَثًا ولَهْوًا وباطِلًا."
  21,17,"﴿لَهۡوࣰا﴾: ما يُتلهّى بِه مِن زَوْجَةٍ ووَلَدٍ.﴿مِن لَّدُنَّآ﴾: مِن عِنْدِنا مِنَ أهْل السَّماءِ مِنَ الحُورِ العِينِ."
  21,18,"﴿بَلۡ نَقۡذِفُ﴾: بل نَرْمِي.﴿فَيَدۡمَغُهُۥ﴾: فيَمْحَقُه ويَدْحَضُه.﴿زَاهِقࣱ﴾: زائِلٌ وذاهِبٌ.﴿ٱلۡوَيۡلُ﴾: العَذابُ."
  21,19,"﴿لَا يَسۡتَكۡبِرُونَ عَنۡ عِبَادَتِهِۦ﴾: لا يَتَعاظَمُونَ عَن عِبادتِه.﴿وَلَا يَسۡتَحۡسِرُونَ﴾: لا يُصِيبُهُم إعياءٌ ولا مَلَلٌ مِن عِبادَةِ اللهِ."
  21,20,"﴿لَا يَفۡتُرُونَ﴾: لا يَضْعُفُونَ ولا يَسْأمُونَ."
  21,21,"﴿أَمِ ٱتَّخَذُوٓاْ ءَالِهَةࣰ مِّنَ ٱلۡأَرۡضِ هُمۡ يُنشِرُونَ﴾: هَلِ اتَّخَذَ المُشْرِكُونَ آلهةً مِنَ الأرْضِ قادِرَةً على إحْياءِ المَوتى؟"
  21,22,"﴿لَفَسَدَتَا﴾: لبَطَلَتا، واخْتَلَّ نِظامُهما.﴿فَسُبۡحَـٰنَ ٱللَّهِ﴾: تَنَزَّهَ اللهُ تعالى.﴿عَمَّا يَصِفُونَ﴾: عَمّا يَصِفُه الكافِرونَ مِنِ ادِّعاءِ شَريكٍ لَه."
  21,24,"﴿أَمِ ٱتَّخَذُواْ﴾: بَلِ اتَّخَذُوا.﴿هَاتُواْ بُرۡهَـٰنَكُمۡ﴾: ايتُوا بِحُجَّتِكُم على اتِّخاذِكُم الآلِهَةَ المزْعُومةَ.﴿ذِكۡرُ مَن مَّعِيَ﴾: القرآنُ الذي جِئْتُ به.﴿وَذِكۡرُ مَن قَبۡلِي﴾: أي: الكُتُبُ السّابِقَةُ."
  21,26,"﴿ٱتَّخَذَ ٱلرَّحۡمَـٰنُ وَلَدࣰا﴾: أي: بزَعْمِهِم أنّ الملائِكةَ بناتُ اللهِ.﴿سُبۡحَـٰنَهُۥ﴾: تَنَزَّهَ اللهُ عَنْ ذَلِكَ.﴿مُّكۡرَمُونَ﴾: أكْرَمَهُم الله بِعِبادَتِه وخَصَّصَهم بالفَضائِلِ."
  21,27,"﴿لَا يَسۡبِقُونَهُۥ بِٱلۡقَوۡلِ﴾: أي: لا يَتَكَلَّمُونَ إلّا بما يْأمُرُهم بِه ربُّهم؛ لِكَمالِ انْقِيادِهم وطاعَتِهم."
  21,28,"﴿يَعۡلَمُ مَا بَيۡنَ أَيۡدِيهِمۡ﴾: يَعلَمُ كلَّ ما عَمِلُوه.﴿وَمَا خَلۡفَهُمۡ﴾: وما هم عامِلُونَ في الُمسْتَقْبَل.﴿إِلَّا لِمَنِ ٱرۡتَضَىٰ﴾: أي: إلا لِمَن رَضِيَ اللهُ بشَفاعَتِهم لَهُ.﴿مُشۡفِقُونَ﴾: حَذِرونَ أن يَعْصُوه."
  21,30,"﴿رَتۡقࣰا﴾: مُلْتَصِقَتَينِ لا فاصِلَ بَيْنَهما.﴿فَفَتَقۡنَـٰهُمَا﴾: ففَصَلْناهُما بِقُدرَتِنا."
  21,31,"﴿رَوَ ٰ⁠سِيَ﴾: جبالًا ثَوابِتَ.﴿أَن تَمِيدَ بِهِمۡ﴾: لِئلا تَتَحَرَّكَ الأرضُ وتَضطَرِبَ بِأهْلِها.﴿فِجَاجࣰا سُبُلࣰا﴾: طُرُقًا واسِعةً."
  21,32,"﴿سَقۡفࣰا﴾: أي: سَقْفًا لِلأَرْضِ.﴿مَّحۡفُوظࣰا﴾: أي: عَنِ السُّقوطِ، وعَنِ اخْتِراقِ الشَّياطِينِ."
  21,33,"﴿كُلࣱّ﴾: أي: كلٌّ مِنَ الشَّمسِ والقَمَرِ والنُّجُومِ.﴿فَلَكࣲ﴾: مَدارٍ.﴿يَسۡبَحُونَ﴾: يدُورُونَ بانْبِساطٍ وسُهُولةٍ."
  21,34,"﴿ٱلۡخُلۡدَ﴾: دَوامَ البقاءِ في الدُّنيا."
  21,35,"﴿وَنَبۡلُوكُم﴾: نَخْتَبِرُكُم ونَبْتَلِيكُم.﴿فِتۡنَةࣰ﴾: اخْتِبارًا وابْتِلاءً."
  21,36,"﴿هُزُوًا﴾: مُسْتَهْزَأً بِك.﴿يَذۡكُرُ ءَالِهَتَكُمۡ﴾: يَعِيبُ آلهتَكُم."
  21,37,"﴿خُلِقَ ٱلۡإِنسَـٰنُ مِنۡ عَجَلࣲ﴾: خُلِقَ الإنسانُ عَجُولًا مُتَسَرِّعًا بِفِطْرَتِه.﴿سَأُوْرِيكُمۡ ءَايَـٰتِي﴾: أي: بنَصْرِ هذا الدِّينِ وهَلاكِ مَن كَفَرَ به وحارَبَه."
  21,38,"﴿ٱلۡوَعۡدُ﴾: أي: الوعدُ بالعذابِ."
  21,39,"﴿لَا يَكُفُّونَ﴾: لا يَقْدِرُونَ أن يَمْنَعُوا."
  21,40,"﴿بَغۡتَةࣰ﴾: فَجْأَةً.﴿فَتَبۡهَتُهُمۡ﴾: فتُحَيِّرُهم.﴿وَلَا هُمۡ يُنظَرُونَ﴾: ولا هم يُؤخَّرُونَ، ولا هم يُمهَلُونَ لتوبَةٍ أو اعْتِذارٍ."
  21,41,"﴿فَحَاقَ﴾: نَزَلَ وأَحاطَ.﴿سَخِرُواْ مِنۡهُم﴾: اسْتَهْزَؤُوا بهم."
  21,42,"﴿يَكۡلَؤُكُم﴾: يَحْفَظُكُم ويَحْرُسُكُم.﴿مِنَ ٱلرَّحۡمَـٰنِ﴾: أي: مِن عَذابِه وعِقابِه إذا حَلَّ بِكُم.﴿ذِكۡرِ رَبِّهِم﴾: أي: القرآنِ وما فيه مِن مَّواعِظَ."
  21,43,"﴿وَلَا هُم مِّنَّا يُصۡحَبُونَ﴾: أي: ولا هم يُجارُون مِن عَذابِنا."
  21,44,"﴿بَلۡ مَتَّعۡنَا﴾: بل أمهَلْناهُم؛ لِيَتَمَتَّعُوا.﴿نَنقُصُهَا مِنۡ أَطۡرَافِهَآ﴾: أي: نَنْقُصُ أرضَ الكفّارِ بالظُّهُورِ والغَلَبَةِ عليها مِن كُلِّ ناحيةٍ وجِهَةٍ، فنَفْتحُها بلَدًا بعد بلَدٍ.﴿أَفَهُمُ ٱلۡغَـٰلِبُونَ﴾: أي: كيف يكونُون غالِبينَ بعد نَقْصِنا لأَرْضِهم مِن أطْرافِها؟"
  21,45,"﴿أُنذِرُكُم﴾: أُخَوِّفُكُم.﴿بِٱلۡوَحۡيِ﴾: بالقرآنِ.﴿ٱلصُّمُّ﴾: جمعُ الأصَمّ، وهو الذي لا يَسْمَعُ، والمرادُ الكافرُ الذي لا يُصْغِي لِلْحَقِّ.﴿ٱلدُّعَآءَ﴾: النِّداءَ."
  21,46,"﴿مَّسَّتۡهُمۡ﴾: أصابَتْهُم.﴿نَفۡحَةࣱ﴾: دُفْعَةٌ يسيرةٌ.﴿يَـٰوَيۡلَنَآ﴾: يا هلاكَنا."
  21,47,"﴿ٱلۡمَوَ ٰ⁠زِينَ ٱلۡقِسۡطَ﴾: المَوازِينَ العادلةَ.﴿لِيَوۡمِ ٱلۡقِيَـٰمَةِ﴾: لِأهْلِ يومِ القيامةِ.﴿مِثۡقَالَ حَبَّةࣲ﴾: وزنَ حَبَّة﴿خَرۡدَلٍ﴾: وهو أصغرُ الحُبوبِ، والمرادُ أصْغرُ شَيءٍ."
  21,48,"﴿ٱلۡفُرۡقَانَ﴾: المُعْجِزاتِ التي يُمَيَّزُ بها الحقُّ عنِ الباطِلِ.﴿وَضِيَآءࣰ﴾: أي: التَّوْراةَ التي أضاءتْ لهم أمرَ دينِهِم.﴿وَذِكۡرࣰا﴾: يَتَذَكَّرُونَ بما في التَّوراةِ من المواعظِ."
  21,49,"﴿يَخۡشَوۡنَ رَبَّهُم﴾: يخافُونَ عذابَه.﴿بِٱلۡغَيۡبِ﴾: في حالِ غيابِهم عَنْ أعْيُنِ النّاسِ.﴿مُشۡفِقُونَ﴾: خائِفُونَ."
  21,50,"﴿وَهَـٰذَا ذِكۡرࣱ﴾: وهذا القرآنُ موعظَة لِمَن اتَّعَظَ به."
  21,51,"﴿رُشۡدَهُۥ﴾: هُداه اللائقَ به.﴿مِن قَبۡلُ﴾: مِن قَبْلِ مُوسى وهارُونَ."
  21,52,"﴿ٱلتَّمَاثِيلُ﴾: الأصنامُ التي صَنَعْتُمُوها بِأَيْدِيكُم.﴿لَهَا عَـٰكِفُونَ﴾: مُقِيمُونَ على عِبادَتِها على الدَّوامِ."
  21,54,"﴿ضَلَـٰلࣲ مُّبِينࣲ﴾: خُسْرانٍ واضِحٍ."
  21,55,"﴿بِٱلۡحَقِّ﴾: أي: أجادٌّ أنت فيما تَقُولُ؟﴿ٱللَّـٰعِبِينَ﴾: مِن الهازِلِينَ."
  21,56,"﴿فَطَرَهُنَّ﴾: خَلَقَهُنَّ."
  21,57,"﴿لَأَكِيدَنَّ أَصۡنَـٰمَكُم﴾: لَأَمْكُرَنَّ بأصنامِكُم ولَأَكْسِرَنَّها."
  21,58,"﴿جُذَ ٰ⁠ذًا﴾: حُطامًا قِطَعًا مُكسَّرةً."
  21,60,"﴿يَذۡكُرُهُمۡ﴾: يَعِيبُهم."
  21,61,"﴿عَلَىٰٓ أَعۡيُنِ ٱلنَّاسِ﴾: ظاهرًا بِمَرْأىً مِنَ النّاسِ.﴿يَشۡهَدُونَ﴾: أي: يَشْهَدُونَ عليه أنّه يَذْكُرُهم بِسُوءٍ."
  21,63,"21:62"
  21,64,"21:62"
  21,65,"﴿نُكِسُواْ عَلَىٰ رُءُوسِهِمۡ﴾: أي: لمّا غُلِبوا في الحُجَّةِ غَيَّروا رأيَهم."
  21,67,"﴿أُفࣲّ لَّكُمۡ﴾: قُبْحًا لكم."
  21,69,"21:68"
  21,70,"﴿كَيۡدࣰا﴾: مَكْرًا لهلاكِه."
  21,71,"﴿إِلَى ٱلۡأَرۡضِ﴾: هي أرضُ «الشّام».﴿بَـٰرَكۡنَا فِيهَا﴾: أي: بِكَثْرَةِ الخيراتِ، وبِكَوْنِها أرْضَ الأنبياءِ عليهمُ الصَّلاةُ والسَّلامُ."
  21,72,"﴿وَيَعۡقُوبَ نَافِلَةࣰ﴾: زِيادةً عمّا طَلَبَ إبراهيمُ عليه الصَّلاةُ والسَّلامُ."
  21,74,"﴿حُكۡمࣰا﴾: نُبُوَّةً وفَصْلَ القَضاءِ بينَ الخُصُومِ.﴿ٱلۡقَرۡيَةِ﴾: هي قريةُ «سَدُوم».﴿ٱلۡخَبَـٰٓئِثَ﴾: هي أفعالُهم الُمنْكَرَةُ من إتيانِهم الرِّجالَ، وقَطْعِ السبيلِ وغيرِ ذلك.﴿قَوۡمَ سَوۡءࣲ﴾: قومًا عُرِفُوا بالأعمالِ القبيحةِ.﴿فَـٰسِقِينَ﴾: خارجِينَ عَن طاعةِ اللهِ."
  21,75,"﴿فِي رَحۡمَتِنَآ﴾: أي: في أهلِ رحمتِنا، وهم الأنبياءُ عليهمُ الصَّلاةُ والسَّلامُ."
  21,76,"﴿مِن قَبۡلُ﴾: أي: مِن قَبْلِ إبراهيمَ ولوطٍ عليهما الصَّلاةُ والسَّلامُ.﴿ٱلۡكَرۡبِ﴾: أي: الغَرَقِ بالطُّوفانِ."
  21,77,"﴿بِـَٔايَـٰتِنَآ﴾: بِحُجَجِنا الدالَّةِ على صِدْقِه.﴿قَوۡمَ سَوۡءࣲ﴾: قَومًا عُرِفُوا بالسُّوءِ والقُبْحِ.﴿فَأَغۡرَقۡنَـٰهُمۡ﴾: أي: بالطُّوفانِ الذي حَلَّ بهم."
  21,78,"﴿فِي ٱلۡحَرۡثِ﴾: أي: في قَضِيَّةِ الحَرْثِ.﴿نَفَشَتۡ فِيهِ﴾: انْتَشَرَتْ في الحَرْثِ ليلًا مِن غَيرِ راعٍ."
  21,79,"﴿فَفَهَّمۡنَـٰهَا سُلَيۡمَـٰنَ﴾: ففَهَّمنا سُليمانَ المسْأَلةَ بِمُراعاةِ مَصْلَحَةِ الطرفَينِ بالعَدْلِ.﴿حُكۡمࣰا وَعِلۡمࣰا﴾: نُبُوَّةً وعِلْمًا بأحْكامِ اللهِ.﴿وَسَخَّرۡنَا﴾: طَوَّعْنا."
  21,80,"﴿صَنۡعَةَ لَبُوسࣲ﴾: صِناعةَ دُروعٍ تُلبَسُ في الحربِ.﴿لِتُحۡصِنَكُم﴾: لِتَحْمِيَكم وتحفظَكُم.﴿مِّنۢ بَأۡسِكُمۡ﴾: مِن حَرْبِكُم."
  21,81,"﴿عَاصِفَةࣰ﴾: شديدةَ الهَبُوب.﴿إِلَى ٱلۡأَرۡضِ﴾: أي: أرْضِ بيتِ المقْدِسِ بالشّامِ."
  21,82,"﴿يَغُوصُونَ لَهُۥ﴾: يَنْزِلُونَ له في البحرِ لاسْتِخْراجِ ما يُطْلَبُ.﴿حَـٰفِظِينَ﴾: أي: حفِظَهمُ اللهُ من أنْ يَنْفَلِتُوا عَنْ سُليمانَ ومِن أنْ يُفْسِدُوا أعْمالَهم."
  21,83,"﴿مَسَّنِيَ ٱلضُّرُّ﴾: أصابَنِي الضُّرُّ مِن مَّرَضٍ ونَحْوِه."
  21,84,"﴿فَكَشَفۡنَا مَا بِهِۦ مِن ضُرࣲّ﴾: فَرَفَعْنا عَنْه مَرَضَهُ بِشِفائِنا إيِّاهُ.﴿وَذِكۡرَىٰ﴾: تَذْكِرَةً."
  21,86,"21:85"
  21,87,"﴿وَذَا ٱلنُّونِ﴾: أي: واذْكُرْ صاحِبَ الحُوتِ، وذو النُّون لَقَبُ نَبِيِّ اللهِ يُونُسَ عليه الصَّلاةُ والسَّلامُ لابْتِلاعِ الحُوتِ لَه.﴿مُغَـٰضِبࣰا﴾: غَضْبانَ على قَومِه؛ لِكُفْرِهم.﴿أَن لَّن نَّقۡدِرَ عَلَيۡهِ﴾: أن لَن نُّضَيِّقَ عليه، ولَن نُّؤاخِذَه بِخُروجِه مِن بَيْنِ قومِه.﴿ٱلظُّلُمَـٰتِ﴾: هي ظُلْمَةُ الليلِ، وظُلْمَةُ البحرِ، وظُلْمَةُ بَطْنِ الحُوتِ."
  21,88,"﴿وَنَجَّيۡنَـٰهُ مِنَ ٱلۡغَمِّ﴾: وخَلَّصْناه مِن غَمِّهِ بإخْراجِنا له مِن بَطْنِ الحُوتِ."
  21,89,"﴿لَا تَذَرۡنِي فَرۡدࣰا﴾: لا تَتْرُكْنِي وحِيدًا لا عَقِبَ لي."
  21,90,"﴿وَأَصۡلَحۡنَا لَهُۥ زَوۡجَهُۥٓ﴾: أي: جَعَلْناها صالحةً في أخْلاقِها وصالحةً للحَمْلِ والولادةِ.﴿وَيَدۡعُونَنَا رَغَبࣰا﴾: يَعْبُدُونَنا راغِبينَ فيما عِنْدَنا.﴿وَرَهَبࣰا﴾: خائِفِينَ من عُقُوبَتِنا.﴿خَـٰشِعِينَ﴾: مُتَواضِعِينَ مُتَذَلِّلينَ."
  21,91,"﴿أَحۡصَنَتۡ فَرۡجَهَا﴾: حَفِظَتْ فَرْجَها مِنَ الحَلالِ والحَرام ولْم يَمَسَّها بَشَرٌ.﴿فَنَفَخۡنَا فِيهَا مِن رُّوحِنَا﴾: أي: أمَرْنا جبريلَ حتّى نَفَخَ في جَيْبِ قميصِها، فَخَلقَ اللهُ بذلكَ النَّفْخِ عيسى عليه السلام في بَطْنِها.﴿ءَايَةࣰ لِّلۡعَـٰلَمِينَ﴾: علامةً للخلْقِ على قُدْرِة اللهِ تعالى."
  21,92,"﴿أُمَّتُكُمۡ﴾: أي: الأنبياءُ عليهمُ الصَّلاةُ والسَّلامُ.﴿أُمَّةࣰ وَ ٰ⁠حِدَةࣰ﴾: أي: دينُهم واحدٌ، وهو الإسلامُ."
  21,93,"﴿وَتَقَطَّعُوٓاْ أَمۡرَهُم﴾: تَفَرَّقُوا في أمْرِ دِينِهم فِرَقًا."
  21,94,"﴿فَلَا كُفۡرَانَ لِسَعۡيِهِۦ﴾: لا جُحَودَ لِعَمَلِه بل يُشْكَرُ سَعْيُه ويُثابُ عليه."
  21,95,"﴿وَحَرَ ٰ⁠مٌ﴾: واجِبٌ."
  21,96,"﴿فُتِحَتۡ يَأۡجُوجُ وَمَأۡجُوجُ﴾: أي: يُفْتَحُ السَّدُّ عنهما فينطَلِقُونَ.﴿حَدَبࣲ﴾: مَكانٍ مُرْتَفعٍ مِنَ الأَرْضِ.﴿يَنسِلُونَ﴾: يَتَفَّرقُونَ في الأَرْضِ مُسْرِعِينَ."
  21,97,"﴿ٱلۡوَعۡدُ ٱلۡحَقُّ﴾: يومُ القيامةِ.﴿شَـٰخِصَةٌ﴾: مَفْتُوحَةٌ أجْفانُهم لا تَطْرِفُ.﴿مِّنۡ هَـٰذَا﴾: أي: يومِ البعثِ والحسابِ."
  21,98,"﴿حَصَبُ﴾: حَطَبُ.﴿وَ ٰ⁠رِدُونَ﴾: داخِلُونَ."
  21,100,"﴿زَفِيرࣱ﴾: أنينُ تَنَفُّسِهم الشَّدِيدُ.﴿لَا يَسۡمَعُونَ﴾: مِن هَولِ عَذابِهم."
  21,101,"﴿ٱلۡحُسۡنَىٰٓ﴾: السَّعادَةُ بِدُخُولِ الجنَّة.﴿عَنۡهَا﴾: أي: عَن نّارِ جَهَنَّمَ."
  21,102,"﴿حَسِيسَهَا﴾: أي: صَوْتَ لَهِيبِها."
  21,103,"﴿لَا يَحۡزُنُهُمُ﴾: لا يُخِيفُهم.﴿ٱلۡفَزَعُ ٱلۡأَكۡبَرُ﴾: الهولُ العظيمُ يومَ القيامةِ.﴿تَتَلَقَّىٰهُمُ﴾: تَسْتَقْبِلُهم مُهَنِّئين."
  21,104,"﴿نَطۡوِي ٱلسَّمَآءَ﴾: أي: نَطْويها كما يَطْوي الكاتِبُ الوَرَقَةَ التي يَكْتُبُ فيها.﴿ٱلسِّجِلِّ﴾: الصَّحِيفَةِ، الورقةِ التي يُكتبُ فيها.﴿لِلۡكُتُبِ﴾: هي ما دُوِّن في الصَّحيفة وكُتِب فيها.﴿كَمَا بَدَأۡنَآ أَوَّلَ خَلۡقࣲ نُّعِيدُهُۥ﴾: أي: نُعيدُ الخَلْقَ حُفاةً عُراةً غُرْلًا يومَ القيامةِ، كما بَدَأْناهم أوَّلَ مرَّةٍ في بُطُونِ أمَّهاتِهم."
  21,105,"﴿ٱلزَّبُورِ﴾: كِتابِ داودَ عليه الصلاةُ والسلامُ، أو الكُتُبِ المنزَّلَةِ.﴿مِنۢ بَعۡدِ ٱلذِّكۡرِ﴾: أي: مِن بَعْدِ الكِتابةِ في الذِّكْرِ، وهو التَّوراةُ، أو اللَّوحُ الَمحْفُوظُ."
  21,106,"﴿إِنَّ فِي هَـٰذَا﴾: أي: في هذا المَتْلُوِّ.﴿لَبَلَـٰغࣰا﴾: وُصُولًا إلى البُغْيةِ."
  21,108,"﴿مُّسۡلِمُونَ﴾: مُسْتَسْلِمُونَ مُنْقادُونَ للهِ تعالى."
  21,109,"﴿فَإِن تَوَلَّوۡاْ﴾: فَإنْ أعْرَضُوا عَنِ الإسْلامِ.﴿ءَاذَنتُكُمۡ﴾: أعْلَمْتُكُم مِن أنَّ بَعْضَكُم لِبَعْضٍ حَرْبٌ، لا صُلْحَ بَيْنَكُم ولا سِلْمَ.﴿عَلَىٰ سَوَآءࣲ﴾: فأنا وأنتم مُسْتَوُونَ في العِلْمِ.﴿وَإِنۡ أَدۡرِيٓ﴾: لا أدْرِي."
  21,111,"﴿لَعَلَّهُۥ فِتۡنَةࣱ لَّكُمۡ﴾: أي: لعلَّ الإمهالَ اختبارٌ لَكُمَ."
  21,112,"﴿قَـٰلَ رَبِّ ٱحۡكُم بِٱلۡحَقِّ﴾: أي: افصِلْ بَيْنِيَ وبْيَنَ قومِي بِما هُو الحقُّ عِنْدَكَ."
