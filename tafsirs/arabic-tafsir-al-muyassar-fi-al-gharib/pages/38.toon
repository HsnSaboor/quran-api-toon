tafsir[74]{c,v,t}:
  38,2,"﴿عِزَّةࣲ﴾: تكبُّرٍ عَنِ الحقِّ.﴿وَشِقَاقࣲ﴾: مُشاقَّةٍ ومُخالَفةٍ للهِ ولِرَسُولِهِ."
  38,3,"﴿كَمۡ أَهۡلَكۡنَا﴾: كَثِيرًا أهْلَكْنا.﴿مِّن قَرۡنࣲ﴾: مِن أُمَّةٍ.﴿فَنَادَواْ﴾: فاسْتَغاثُوا حِينَ عايَنُوا العَذابَ.﴿وَّلَاتَ﴾: ولَيسَ.﴿حِينَ مَنَاصࣲ﴾: وقتَ فِرارٍ."
  38,4,"﴿مُّنذِرࣱ مِّنۡهُمۡ﴾: رَسُولٌ مِنهُم."
  38,5,"﴿عُجَابࣱ﴾: عَجِيبٌ."
  38,6,"﴿ٱلۡمَلَأُ﴾: أشْرافُ القوم ورُؤساؤُهُم.﴿أَنِ ٱمۡشُواْ﴾: أنِ امْضُوا على ما كُنتُم عَلَيهِ ولا تَدْخُلُوا في دِينِه.﴿وَٱصۡبِرُواْ عَلَىٰٓ ءَالِهَتِكُمۡ﴾: أي: اثبُتُوا على عِبادَتِها.﴿لَشَيۡءࣱ يُرَادُ﴾: أي: شَيءٌ مُدَبَّرٌ يُريدُهُ محمدٌ بِنا وبآلَهتِنا؛ لِيَتَحَكَّمَ فِينا بِما يُرِيدُ."
  38,7,"﴿ٱلۡمِلَّةِ ٱلۡـَٔاخِرَةِ﴾: هي النَّصْرانِيَّةُ، أو دِينُ قُرَيشٍ.﴿إِلَّا ٱخۡتِلَـٰقٌ﴾: إلا كَذِبٌ اختَلَقَهُ محمدٌ وافْتَراهُ."
  38,9,"38:8"
  38,10,"﴿فَلۡيَرۡتَقُواْ﴾: فَلْيَصْعَدُوا.﴿ٱلۡأَسۡبَـٰبِ﴾: المعارِجِ إلى السَّماءِ."
  38,11,"﴿جُندࣱ مَّا هُنَالِكَ﴾: أي: هَؤُلاءِ الجُنْدُ المكذِّبُونَ الَّذينَ هُم في عِزَّةٍ وشِقاقٍ.﴿مَهۡزُومࣱ مِّنَ ٱلۡأَحۡزَابِ﴾: سَيُهْزَمُ هَذا الجُنْدُ ويُغلَبُ، كما هُزِمَ الَّذينَ مِن قَبْلِهِم مِنَ الأحْزابِ المكَذِّبِينَ."
  38,12,"﴿ٱلۡأَوۡتَادِ﴾: صاحِبُ القُوَّةِ العظِيمةِ مِنَ الجُنُودِ والمبانِي الشّاهِقَةِ."
  38,13,"﴿وَأَصۡحَـٰبُ لۡـَٔيۡكَةِ﴾: أصْحابُ الأشْجارِ والبَساتِينِ."
  38,14,"﴿فَحَقَّ عِقَابِ﴾: فحَلَّ بهم عِقابِي وعَذابي."
  38,15,"﴿يَنظُرُ﴾: يَنْتَظِرُ.﴿صَيۡحَةࣰ وَ ٰ⁠حِدَةࣰ﴾: نَفْخَةً واحِدةً في الصُّورِ.﴿مَّا لَهَا مِن فَوَاقࣲ﴾: مالها مِن تَوقُّفٍ مِقْدارَ فَواقِ ناقَةٍ: وهو مابيَن حَلْبَتَيها مِنَ المدَّةِ القلِيلَةِ."
  38,16,"﴿قِطَّنَا﴾: نصيبَنا مِنَ العذابِ."
  38,17,"﴿ذَا ٱلۡأَيۡدِ﴾: صاحِبَ القُوَّةِ.﴿أَوَّابٌ﴾: كَثِيرُ الرُّجُوعِ إلى اللهِ وطاعَتِهِ عَن كُلِّ ما يَكْرَهُهُ."
  38,18,"﴿بِٱلۡعَشِيِّ﴾: بآخِرِ النَّهارِ.﴿وَٱلۡإِشۡرَاقِ﴾: أوَّلِ النَّهارِ."
  38,19,"﴿وَٱلطَّيۡرَ مَحۡشُورَةࣰ﴾: أي: سَخَّرْنا الطَّيرَ مَجْمُوعَةً إليهِ تُسَبِّحُ اللهَ مَعَهُ."
  38,20,"﴿وَشَدَدۡنَا مُلۡكَهُۥ﴾: أي: قَوَّيْناهُ بأسْبابِ القُوَّةِ كُلِّها.﴿ٱلۡحِكۡمَةَ﴾: النُّبوَّةَ.﴿وَفَصۡلَ ٱلۡخِطَابِ﴾: أي: الفَصْلَ في الكَلامِ والخُصُوماتِ."
  38,21,"﴿نَبَؤُاْ ٱلۡخَصۡمِ﴾: خبرُ المتخاصِمَينِ.﴿تَسَوَّرُواْ ٱلۡمِحۡرَابَ﴾: تَسَلَّقُوا مَكانَ عِبادَتِهِ وأتَوهُ مِن أعلى سُورِهِ."
  38,22,"﴿فَفَزِعَ﴾: فَخافَ.﴿بَغَىٰ﴾: ظَلَمَ وتَعدّى.﴿بِٱلۡحَقِّ﴾: بالعَدْلِ.﴿وَلَا تُشۡطِطۡ﴾: لا تَجُرْ في حُكْمِكَ.﴿وَٱهۡدِنَآ﴾: أرْشِدْنا.﴿سَوَآءِ ٱلصِّرَ ٰ⁠طِ﴾: وسَطِ الطَّرِيقِ وهو الطَّرِيقُ الحقُّ."
  38,23,"﴿أَكۡفِلۡنِيهَا﴾: أعْطِنيها حتّى أكْفَلَها.﴿وَعَزَّنِي﴾: غَلَبَني.﴿فِي ٱلۡخِطَابِ﴾: في المُحاجَّةِ الكَلامِيَّةِ."
  38,24,"﴿ٱلۡخُلَطَآءِ﴾: الشُّركاءِ.﴿لَيَبۡغِي﴾: لَيَظْلِمُ ويَتَعَدّى.﴿وَظَنَّ﴾: أيْقَنَ.﴿فَتَنَّـٰهُ﴾: ابْتَلَيناهُ وامْتَحَنّاه.﴿وَخَرَّ رَاكِعࣰا﴾: سَقَطَ ساجِدًا للهِ.﴿وَأَنَابَ﴾: رَجَعَ إلى اللهِ بالتَّوبَةِ."
  38,25,"﴿لَزُلۡفَىٰ﴾: لقُرْبةً ومَكانَةً.﴿وَحُسۡنَ مَـَٔابࣲ﴾: حُسْنَ مَرْجِعٍ في الآخِرَةِ، وهو الجنَّةُ."
  38,26,"﴿بِٱلۡحَقِّ﴾: بالعَدْلِ والإنْصافِ.﴿ٱلۡهَوَىٰ﴾: أي: هَوى النَّفْسِ المُخالِفَ لِلْحَقِّ.﴿بِمَا نَسُواْ يَوۡمَ ٱلۡحِسَابِ﴾: أي: بِسَبَبِ تَرْكِهِم العَمَلَ لِيومِ الحِسابِ."
  38,27,"﴿بَـٰطِلࣰا﴾: لَعِبًا وعَبَثًا.﴿فَوَيۡلࣱ﴾: فَهَلاكٌ."
  38,29,"﴿لِّيَدَّبَّرُوٓاْ﴾: لِيَتَفكَّرُوا.﴿وَلِيَتَذَكَّرَ﴾: ليتَّعِظَ.﴿أُوْلُواْ ٱلۡأَلۡبَـٰبِ﴾: أصْحابُ العُقُولِ السَّلِيمَةِ."
  38,30,"﴿أَوَّابٌ﴾: توّابٌ كثيرُ الرُّجُوعِ إلى اللهِ."
  38,31,"﴿بِٱلۡعَشِيِّ﴾: بآخِرِ النَّهارِ (مِن بَعْدِ الزَّوالِ إلى الغُرُوبِ).﴿ٱلصَّـٰفِنَـٰتُ﴾: الخُيُولُ الأصِيلةُ الواقِفَةُ على ثَلاثِ قَوائِمَ وطرفِ حافِرِ الرّابِعَةِ.﴿ٱلۡجِيَادُ﴾: السَّريعَةُ في الجَرْي."
  38,32,"﴿أَحۡبَبۡتُ حُبَّ ٱلۡخَيۡرِ﴾: آثَرْتُ حُبَّ الخيلِ.﴿تَوَارَتۡ بِٱلۡحِجَابِ﴾: غَرَبَتِ الشَّمسُ."
  38,33,"﴿فَطَفِقَ مَسۡحَۢا بِٱلسُّوقِ وَٱلۡأَعۡنَاقِ﴾: فَشَرَعَ يَقْطَعُ سُوقَها وأعْناقَها بالسَّيفِ."
  38,34,"﴿فَتَنَّا﴾: ابتَلَينا.﴿جَسَدࣰا﴾: شِقَّ ولَدٍ وُلِد لَهُ.﴿أَنَابَ﴾: رَجَعَ إلى اللهِ بالتَّوبَةِ."
  38,36,"﴿فَسَخَّرۡنَا لَهُ﴾: فَذَلَّلْنا لَه.﴿رُخَآءً﴾: لَيِّنةً طَيِّعةً.﴿حَيۡثُ أَصَابَ﴾: حيثُ أرادَ."
  38,37,"﴿بَنَّآءࣲ﴾: يَبْنِي لَهُ ما يشاءُ.﴿وَغَوَّاصࣲ﴾: يَغُوصُ في البحْرِ لاسْتِخْراجِ نَفائِسِه."
  38,38,"﴿مُقَرَّنِينَ فِي ٱلۡأَصۡفَادِ﴾: مُقَيَّدين في الأغْلالِ والسَّلاسِلِ."
  38,39,"﴿فَٱمۡنُنۡ أَوۡ أَمۡسِكۡ﴾: فأعْطِ مَن شِئْتَ، وامنَعْ مَن شِئْتَ."
  38,40,"﴿لَزُلۡفَىٰ﴾: لَقُرْبةً وكَرامةً.﴿وَحُسۡنَ مَـَٔابࣲ﴾: حُسْنَ مَرْجِعٍ في الآخِرَةِ، وهو الجَنّةُ."
  38,41,"﴿بِنُصۡبࣲ﴾: بِتَعَبٍ ومَشَقَّةٍ.﴿وَعَذَابٍ﴾: ألَمٍ وضُرٍّ."
  38,42,"﴿ٱرۡكُضۡ بِرِجۡلِكَ﴾: اضْرِبْ بِها الأرْضَ."
  38,43,"﴿أَهۡلَهُۥ﴾: زَوْجَهُ ووَلَدَهُ.﴿وَمِثۡلَهُم مَّعَهُمۡ﴾: وزِدْناهُ مِثْلَهُم بَنِينَ وحَفَدَةً.﴿لِأُوْلِي ٱلۡأَلۡبَـٰبِ﴾: لأصْحابِ العُقُولِ السَّلِيمَةِ."
  38,44,"﴿ضِغۡثࣰا﴾: حُزْمَةً مِنَ الحَشِيشِ ونَحْوِهِ.﴿وَلَا تَحۡنَثۡ﴾: لا تَتْرُكِ الوفاءَ بِيَمِينِكَ.﴿أَوَّابࣱ﴾: رَجّاعٌ إلى طاعَةِ اللهِ."
  38,45,"﴿أُوْلِي ٱلۡأَيۡدِي﴾: أصْحابَ القُوى في طاعةِ اللهِ.﴿وَٱلۡأَبۡصَـٰرِ﴾: البصائرِ في الدِّينِ."
  38,46,"﴿أَخۡلَصۡنَـٰهُم بِخَالِصَةࣲ﴾: خَصَصْناهُم واصْطَفَيناهُم بِخاصَّةٍ عَظِيمَةٍ.﴿ذِكۡرَى ٱلدَّارِ﴾: ذِكْرِ الدّارِ الآخرةِ في قُلُوبِهِم."
  38,47,"﴿ٱلۡمُصۡطَفَيۡنَ﴾: الَّذينَ اخْتَرْناهُم لِرِسالَتِنا وطاعَتِنا.﴿ٱلۡأَخۡيَارِ﴾: الُمخْتارِينَ الفضلاءِ المُخْتَصِّينَ بالخيرِ."
  38,49,"﴿ذِكۡرࣱ﴾: عِظَةٌ وشَرَفٌ لك أيُّها الرسولُ ولِقَومِكَ.﴿مَـَٔابࣲ﴾: مَصِيرٍ."
  38,50,"﴿جَنَّـٰتِ عَدۡنࣲ﴾: جَنّاتِ إقامَةٍ."
  38,51,"﴿مُتَّكِـِٔينَ﴾: جالِسِينَ مُتَمَكِّنِينَ على السُّرُرِ.﴿يَدۡعُونَ﴾: يَطْلُبُونَ."
  38,52,"﴿قَـٰصِرَ ٰ⁠تُ ٱلطَّرۡفِ﴾: لا يَمْدُدْنَ أبْصارَهُنَّ إلى غَيْرِ أزْواجِهِنَّ.﴿أَتۡرَابٌ﴾: مُتَساوِياتٌ في السِّنِّ."
  38,54,"﴿نَّفَادٍ﴾: فَناءٍ وانْقِطاعِ."
  38,55,"﴿لِلطَّـٰغِينَ﴾: الُمتَجاوِزِينَ الحَدَّ في الكُفْرِ والمعاصِي.﴿مَـَٔابࣲ﴾: مَرْجِعٍ ومَصِيرٍ."
  38,56,"﴿يَصۡلَوۡنَهَا﴾: يُعذَّبُونَ فِيها، تَغْمُرُهُم مِن جَمِيعِ جَوانِبِهِم.﴿ٱلۡمِهَادُ﴾: الفِراشُ."
  38,57,"﴿حَمِيمࣱ﴾: ماءٌ شَدِيدُ الحَرارَةِ.﴿وَغَسَّاقࣱ﴾: صَدِيدٌ سائِلٌ مِن أجْسادِ أهْلِ النّارِ."
  38,58,"﴿وَءَاخَرُ﴾: عَذابٌ آخَرُ.﴿شَكۡلِهِۦٓ﴾: مِثْلِه.﴿أَزۡوَ ٰ⁠جٌ﴾: أصْنافٌ وألْوانٌ."
  38,59,"﴿فَوۡجࣱ﴾: جَماعَةٌ عَظِيمةٌ.﴿مُّقۡتَحِمࣱ﴾: داخِلٌ.﴿صَالُواْ ٱلنَّارِ﴾: مُقاسُونَ حَرَّها."
  38,60,"﴿قَدَّمۡتُمُوهُ لَنَا﴾: بَدَأْتُم بالكُفْرِ قَبْلنا وسَنَنْتُمُوهُ لَنا.﴿ٱلۡقَرَارُ﴾: دارُ الاسْتِقْرارِ، وهي جَهَنَّمُ."
  38,61,"﴿ضِعۡفࣰا﴾: مُضاعَفًا."
  38,63,"﴿أَتَّخَذۡنَـٰهُمۡ سِخۡرِيًّا﴾: هَلْ أخْطأنا في تَحْقِيرِنا لَهُم، واسْتِهْزائِنا بِهِم؟﴿زَاغَتۡ﴾: لم تَقَعْ عَلَيهِم."
  38,64,"﴿ذَ ٰ⁠لِكَ﴾: جِدالَ أهْلِ النّارِ وخِصامَهُم."
  38,65,"﴿ٱلۡقَهَّارُ﴾: الَّذي قَهَرَ كُلَّ شَيءٍ وغَلَبَهُ."
  38,67,"﴿نَبَؤٌاْ عَظِيمٌ﴾: خَبَرٌ عظِيمُ النَّفْعِ."
  38,69,"﴿بِٱلۡمَلَإِ ٱلۡأَعۡلَىٰٓ﴾: مَلائِكَةِ السَّماءِ."
  38,71,"38:70"
  38,72,"﴿رُّوحِي﴾: رُوحِ الحَياةِ الَّتي يَخْلُقُها اللهُ.﴿فَقَعُواْ لَهُۥ سَـٰجِدِينَ﴾: فاسْجُدُوا لَهُ سُجُودَ تَحِيَّةٍ وإكْرامٍ، لا سُجُودَ عِبادَةٍ وتَعْظِيمٍ."
  38,74,"38:73"
  38,75,"﴿أَسۡتَكۡبَرۡتَ﴾: أتَعَظَّمْتَ وتَكَبَّرْتَ الآنَ عَنِ السُّجُودِ لآدَمَ؟﴿أَمۡ كُنتَ مِنَ ٱلۡعَالِينَ﴾: أم كُنْتَ مِنَ الُمتَكَبِّرِينَ عَلى رَبِكَ مِن قَبْلُ."
  38,77,"﴿رَجِيمࣱ﴾: مَطْرُودٌ."
  38,78,"﴿لَعۡنَتِيٓ﴾: طَرْدِي وإبْعادِي.﴿ٱلدِّينِ﴾: الجَزاءِ."
  38,79,"﴿فَأَنظِرۡنِيٓ﴾: فأخِّرْ أجَلِي، ولا تُهْلِكْنِي."
  38,80,"﴿ٱلۡمُنظَرِينَ﴾: المُؤَخَّرِينَ."
  38,81,"﴿إِلَىٰ يَوۡمِ ٱلۡوَقۡتِ ٱلۡمَعۡلُومِ﴾: إلى يومِ النَّفْخَةِ الأُولى الَّتي يَمُوتُ مِنها مَن بَقِيَ مِنَ الخلائِقِ."
  38,83,"﴿ٱلۡمُخۡلَصِينَ﴾: الَّذينَ أخْلَصْتَهُم لِعِبادَتِكَ وعَصَمْتَهم من إضْلالِ الشَّيطانِ."
  38,85,"38:84"
  38,86,"﴿ٱلۡمُتَكَلِّفِينَ﴾: الُمتَقَوِّلينَ للقُرآنِ مِن تِلْقاءِ نَفْسِي."
  38,87,"﴿ذِكۡرࣱ﴾: تَذْكِيرٌ."
  38,88,"﴿نَبَأَهُۥ﴾: خَبَرَ صِدْقِ القُرآنِ.﴿بَعۡدَ حِينِۭ﴾: حِينَ يَغْلِبُ الإسْلامُ، وحيِنَ يَقَعُ عَلَيكُم العَذابُ."
