tafsir[51]{c,v,t}:
  42,1,"﴿حمٓ عٓسٓقٓ﴾: سَبَقَ الكَلامُ عَلى الحروفِ المقطَّعةِ في أوَّلِ سُورةِ البقرةِ."
  42,2,"42:1"
  42,3,"﴿ٱلۡعَزِيزُ﴾: القويُّ الَّذِي لا يُعْجِزُهُ شَيءٌ أرادَهُ.﴿ٱلۡحَكِيمُ﴾: الَّذِي لا يَدْخُلُ تَدْبِيرَهُ خَلَلٌ ولا زَلَلٌ."
  42,4,"﴿ٱلۡعَلِيُّ﴾: العالي بِذاتِهِ وقُدْرَتِهِ وقَهْرِهِ."
  42,5,"﴿يَتَفَطَّرۡنَ﴾: يَتَشَقَّقْنَ.﴿مِن فَوۡقِهِنَّ﴾: مِن أعْلاهُنَّ مِن عَظَمِةِ اللهِ وجَلالِهِ.﴿يُسَبِّحُونَ﴾: يُنَزِّهُونَ اللهَ عَمّا لا يَلِيقُ بِهِ قائِلِينَ: سُبَحانَ اللهِ.﴿وَيَسۡتَغۡفِرُونَ لِمَن فِي ٱلۡأَرۡضِ﴾: ويَطْلُبُونَ مِن رَبِّهِم أن يَسْتُرَ ذُنُوبَ أهْلِ الأَرْضِ مِنَ المُؤمِنِين."
  42,6,"﴿مِن دُونِهِۦٓ﴾: غَيرَ اللهِ.﴿أَوۡلِيَآءَ﴾: مَعْبُودِينَ يَتَوَلَّونَهُم بالمحبَّةِ والتَّعظِيمِ.﴿ٱللَّهُ حَفِيظٌ عَلَيۡهِمۡ﴾: يُحْصِي عَلَيهِم أعْمالَهُم فَيُجازِيهِم بِها يَومَ القِيامةِ.﴿وَمَآ أَنتَ عَلَيۡهِم بِوَكِيلࣲ﴾: ولَسْتَ مُوَكَّلًا بِحِفْظِ أعمالِهِم وإنّما أنتَ مُنْذِرٌ."
  42,7,"﴿وَكَذَ ٰ⁠لِكَ﴾: مِثْلَ ذَلِكَ الإيجادِ.﴿لِّتُنذِرَ أُمَّ ٱلۡقُرَىٰ﴾: لتُخَوِّفَ أهْلَ مَكَّةَ العَذابَ.﴿وَمَنۡ حَوۡلَهَا﴾: وتُنْذِرَ مَن حَولَ مَكَّةَ مِن سائِر الناسِ العَذابَ.﴿يَوۡمَ ٱلۡجَمۡعِ﴾: يومَ القِيامةِ، وسُمِّيَ بيومِ الجمْعِ لاجْتِماعِ الخلائقِ فِيهِ.﴿لَا رَيۡبَ فِيهِ﴾: لا شَكَّ فِيه.﴿ٱلسَّعِيرِ﴾: النّارِ الموقَدةِ على أهْلِها."
  42,8,"﴿أُمَّةࣰ وَ ٰ⁠حِدَةࣰ﴾: أهْلَ دِينٍ واحِدٍ.﴿وَٱلظَّـٰلِمُونَ﴾: والكافِرُونَ بِاللهِ.﴿وَلِيࣲّ﴾: قَرِيبٍ مُحِبٍّ يَتَوَلّاهُم بِنَفْعِهِ.﴿نَصِيرٍ﴾: ناصِرٍ يَمْنَعُهم مِن عِقابِ اللهِ حِينَ يُعاقِبُهُم."
  42,9,"﴿أَمِ ٱتَّخَذُواْ﴾: بَل اتَّخَذُوا.﴿أَوۡلِيَآءَ﴾: مَعْبودِينَ يَتَوَلَّونَهُم بالمحَبَّةِ والتَّعْظِيمِ ويَطْلُبُونَ مِنهُم النَّفْعَ والنُّصْرَةَ.﴿ٱلۡوَلِيُّ﴾: النّاصِرُ المُعِينُ الَّذِي تَنْفَعُ وِلايتُهُ، يَتَوَلّاهُ عَبْدُهُ بالعِبادَةِ والطّاعَةِ، ويَتَوَلّى عِبادَهُ المؤمِنِينَ بِهدايَتِهِم وإعانَتِهِم، ويَتَولّى عُمُومَ خَلْقِهِ بَتَدْبِيرِهِ ونُفُوذِ القَدَرِ فِيهِم."
  42,10,"﴿عَلَيۡهِ تَوَكَّلۡتُ﴾: اعتمدت على الله بقلبي في جَلْبِ المنافِعِ ودَفْعِ المضارِّ.﴿وَإِلَيۡهِ أُنِيبُ﴾: أرْجِعُ إلى اللهِ في جَمِيعِ أُمُوريِ."
  42,11,"﴿فَاطِرُ﴾: خالِقُ ومُبْدِعُ.﴿وَمِنَ ٱلۡأَنۡعَـٰمِ أَزۡوَ ٰ⁠جࣰا﴾: وجَعَلَ مِنَ الأنْعامِ أزْواجًا ذُكُورًا وإناثًا.﴿يَذۡرَؤُكُمۡ فِيهِ﴾: يُكَثِّرُكُم بسَبِبِ هَذا التَّزاوُجِ بِالتَّوالُدِ نَسْلًا بَعْدَ نسْلٍ.﴿لَيۡسَ كَمِثۡلِهِۦ شَيۡءࣱ﴾: لا يُماثِلُهُ شَيءٌ مِن مَّخلُوقاتِهِ لا في ذاتِهِ ولا في صِفاتِهِ ولا في أسْمائِهِ ولا في أفْعالِهِ، لانْفِرادِهِ وتَوَحُّدِهِ بِالكَمالِ مِن كُلِّ وجْهٍ.﴿وَهُوَ ٱلسَّمِيعُ﴾: لجَمِيعِ الأصْواتِ.﴿ٱلۡبَصِيرُ﴾:: لِأَعْمالِ الخلْقِ لا يَخْفى عَلَيهِ شَيءٌ مِنها."
  42,12,"﴿مَقَالِيدُ ٱلسَّمَـٰوَ ٰ⁠تِ وَٱلۡأَرۡضِ﴾: مَفاتِيحُ خَزائِنِ السَّمواتِ والأرْضِ.﴿يَبۡسُطُ﴾: يُوسِّعُ.﴿وَيَقۡدِرُ﴾: ويُضَيِّقُ."
  42,13,"﴿شَرَعَ﴾: بَيَّنَ ووَضِّحَ.﴿أَنۡ أَقِيمُواْ ٱلدِّينَ﴾: التَّوحِيدَ.﴿كَبُرَ﴾: عَظُمَ.﴿يَجۡتَبِيٓ إِلَيۡهِ﴾: يَصْطَفِي إلى التَّوحِيدِ.﴿وَيَهۡدِيٓ﴾: ويُوَفِّقُ للعَمَلِ بِطاعَتِهِ.﴿يُنِيبُ﴾: يَرْجِعُ عَنِ الكُفْرِ ويَحْرِصُ على الخيرِ."
  42,14,"﴿بَغۡيَۢا بَيۡنَهُمۡ﴾: تجاوُزًا للحَدِّ واعْتِداءً مِن بَعْضِهم علىِ بَعْضٍ.﴿كَلِمَةࣱ سَبَقَتۡ مِن رَّبِّكَ﴾: بتأخِيرِ العذابِ عَنْهُم.﴿أَجَلࣲ مُّسَمࣰّى﴾: يَومِ القِيامَةِ.﴿لَّقُضِيَ بَيۡنَهُمۡ﴾: لفُصِلَ بينَهُم بِتَعْجِيلِ عَذابِ الكافِريِنَ مِنهُم في الدُّنيا.﴿مُرِيبࣲ﴾: مُوقِعٍ في الرِّيَبةِ والاخْتِلافِ المَذْمُومِ."
  42,15,"﴿فَلِذَ ٰ⁠لِكَ﴾: فإلى ذَلِك الدِّينِ القيِّمِ.﴿مِن كِتَـٰبࣲ﴾: مِنَ الكُتُب.﴿لَا حُجَّةَ﴾: لا خُصُومةَ ولا جِدالَ بَعْدَ تَبَيُّنِ الحقِّ.﴿ٱلۡمَصِيرُ﴾: المرجِعُ."
  42,16,"﴿يُحَآجُّونَ﴾: يُجادِلُونَ في دِينِ اللهِ بالإبْطالِ وفِتْنَةِ النّاسِ عَنْهُ.﴿مِنۢ بَعۡدِ مَا ٱسۡتُجِيبَ لَهُۥ﴾: مِن بَعْدِ ما اسْتَجابَ النّاسُ لمحمَّدٍ ﷺ وأَسْلَمُوا.﴿حُجَّتُهُمۡ دَاحِضَةٌ﴾: مُجادَلَتُهُم باطِلةٌ."
  42,17,"﴿بِٱلۡحَقِّ﴾: بالصِّدقِ.﴿وَٱلۡمِيزَانَ﴾: العَدْلَ.﴿وَمَا يُدۡرِيكَ﴾: وأيَّ شَيءٍ يُعْلِمُكَ؟"
  42,18,"﴿مُشۡفِقُونَ مِنۡهَا﴾: خائِفُونَ مِن قِيامِها.﴿يُمَارُونَ﴾: يُخاصِمُونَ ويُجادِلُونَ."
  42,19,"﴿لَطِيفُۢ بِعِبَادِهِۦ﴾: رَفِيقٌ بالِغُ الرَّأْفةِ بِعبادِهِ المؤْمِنِينَ."
  42,20,"﴿حَرۡثَ ٱلۡـَٔاخِرَةِ﴾: عَمَلًا لِأَجْلِ الآخِرةِ.﴿حَرۡثِهِۦ﴾: عَمَلِهِ الحَسَنِ.﴿وَمَن كَانَ يُرِيدُ حَرۡثَ ٱلدُّنۡيَا﴾: ومَن كانَ يُريدُ بِعَمَلِهِ الدُّنيا، لا يَسْعى إلا لَها، وهُوَ الكافرُ بالآخِرةِ.﴿نُؤۡتِهِۦ مِنۡهَا﴾: نُعْطِه مِنَ الدُّنيا ما قَسَمْناهُ له مِن مُّدَةِ حياةٍ وعافِيةٍ ورزْقٍ."
  42,21,"﴿شَرَعُواْ لَهُم﴾: ابْتَدَعُوا لَهُم.﴿كَلِمَةُ ٱلۡفَصۡلِ﴾: القَضاءُ السّابقُ بأنّ الجَزاءَ يومَ القِيامَةِ.﴿لَقُضِيَ بَيۡنَهُمۡ﴾: لفُرِغَ مِنَ الحُكْمِ بَينَكُم وبَينَهُم بِتَعْجِيلِ العَذابِ لَهُم في الدُّنيا.﴿وَإِنَّ ٱلظَّـٰلِمِينَ﴾: وإنَّ الكافِرِينَ باللهِ.﴿أَلِيمࣱ﴾: مُوجِعٌ."
  42,22,"﴿ٱلظَّـٰلِمِينَ﴾: الكافِرينَ.﴿مُشۡفِقِينَ﴾: خائِفِينَ.﴿وَهُوَ وَاقِعُۢ بِهِمۡ﴾: والعَذابُ نازلٌ بِهِم.﴿رَوۡضَاتِ ٱلۡجَنَّاتِ﴾: بَساتِينِ الجَّناتِ، وأنْزَهِها."
  42,23,"﴿لَّآ أَسۡـَٔلُكُمۡ عَلَيۡهِ أَجۡرًا﴾: لا أسْأَلُكُم عَلى ما أدْعُوكُم إلَيهِ مِنَ الحقِّ عِوَضًا مِن أمْوالِكُم.﴿إِلَّا ٱلۡمَوَدَّةَ فِي ٱلۡقُرۡبَىٰ﴾: إلّا أن تَوَدُّوني في قَرابتِي مِنكُم، وتَصِلُوا الرَّحِمَ التِّي بينِي وبَينَكُم.﴿وَمَن يَقۡتَرِفۡ﴾: ومَن يَكْتَسِبْ.﴿نَّزِدۡ لَهُۥ فِيهَا حُسۡنًا﴾: نُضاعِفْ لَهُ تِلْكَ الحَسَنَةَ.﴿غَفُورࣱ﴾: ساتِرٌ عُيُوبَ عِبادِهِ.﴿شَكُورٌ﴾: كَثِيرُ الشُّكْرِ للمُطِيعِينَ."
  42,24,"﴿أَمۡ﴾: بَلْ.﴿ٱفۡتَرَىٰ﴾: اخْتَلَقَ.﴿يَخۡتِمۡ﴾: يَطْبَعْ.﴿وَيَمۡحُ﴾: ويُزِيلُ.﴿بِكَلِمَـٰتِهِۦٓ﴾: الَّتي لا تَتَبَدَّلُ ولا تَتَغَيَّرُ، وبِوعْدِهِ الصّادِقِ الَّذِي لا يَتَخَلَّفُ.﴿بِذَاتِ ٱلصُّدُورِ﴾: بِما في قُلُوبِ العبادِ."
  42,26,"42:25"
  42,27,"﴿بَسَطَ﴾: وسَّعَ.﴿لَبَغَوۡاْ﴾: لَطَغى بَعْضُهُم عَلى بَعْضٍ.﴿بِقَدَرࣲ﴾: بمِقْدار."
  42,28,"﴿ٱلۡغَيۡثَ﴾: المطرَ.﴿قَنَطُواْ﴾: يَئِسُوا مِن نُّزُولِهِ.﴿رَحۡمَتَهُۥ﴾: المطرَ.﴿ٱلۡوَلِيُّ﴾: الَّذِي يَتَولى عِبادَهُ بإحْسانِهِ وفَضْلِهِ.﴿ٱلۡحَمِيدُ﴾: المحْمُودُ."
  42,29,"﴿بَثَّ﴾: نَشَرَ وفَرَّقَ.﴿دَآبَّةࣲ﴾: اسْم لِكُلِّ ذِي رُوحٍ لا يطِيرُ بِجَناحَيْهِ، لِدَبِيبِهِ عَلى الأرْضِ."
  42,31,"﴿بِمُعۡجِزِينَ﴾: بَفائِتِينَ اللهَ.﴿وَلِيࣲّ﴾: يَتَوَلىَّ أُمُورَكُم، فَيُوصِلُ لَكُم المنافِعَ.﴿نَصِيرࣲ﴾: يَدْفَعُ عَنْكُمُ المضارِّ."
  42,32,"﴿ٱلۡجَوَارِ﴾: السُّفُنُ العَظِيمَةُ الَّتي تَجِري في البَحْرِ.﴿كَٱلۡأَعۡلَـٰمِ﴾: كالجبالِ."
  42,33,"﴿رَوَاكِدَ﴾: سَواكِنَ لا تَجْرِي."
  42,34,"﴿يُوبِقۡهُنَّ﴾: يُغْرِقْهُنَّ."
  42,35,"﴿مَّحِيصࣲ﴾: مَلْجأٍ."
  42,36,"﴿فَمَتَـٰعُ ٱلۡحَيَوٰةِ ٱلدُّنۡيَا﴾: فهو مَتاعٌ لَكُم، سرْعانَ ما يَزُولُ."
  42,37,"﴿وَٱلۡفَوَ ٰ⁠حِشَ﴾: ما فَحُشَ وقَبُحَ مِن أنْواعِ المعاصِي.﴿يَغۡفِرُونَ﴾: يَصْفَحُونَ عن عُقُوبِة المُسِيءِ إلَيهِم."
  42,38,"﴿ٱسۡتَجَابُواْ لِرَبِّهِمۡ﴾: آمنُوا باللهِ وقَبِلُوا شَرْعَه.﴿وَأَمۡرُهُمۡ شُورَىٰ بَيۡنَهُمۡ﴾: ويتَشاوَرُونَ في جَمِيعِ أُمُورِهِم ولا يَعْجَلونَ."
  42,39,"﴿ٱلۡبَغۡيُ﴾: الظُّلْمُ.﴿يَنتَصِرُونَ﴾: يَنْتقِمُونَ مِمَّن ظَلَمَهُم بِمِثْلِ ظُلْمِهِ."
  42,40,"﴿وَجَزَ ٰ⁠ٓؤُاْ سَيِّئَةࣲ سَيِّئَةࣱ مِّثۡلُهَا﴾: وجَزاءُ سيئةِ المُسِيءِ عُقُوبَتُهُ بِسَيِّئَةٍ مِثْلِها مِن غَيرِ زِيادةٍ."
  42,41,"﴿سَبِيلٍ﴾: مُؤاخَذَةٍ."
  42,42,"﴿وَيَبۡغُونَ﴾: ويَتَجاوَزُونَ الحدَّ الَّذي أُبيحَ لهُم إلى ما لم يُؤذَنْ لَهُم فِيهِ.﴿أَلِيمࣱ﴾: مُوجِعٌ."
  42,43,"﴿وَغَفَرَ﴾: قابَلَ الإساءَةَ بالعَفْوِ.﴿ذَ ٰ⁠لِكَ﴾: الصَّبْرَ والمغْفِرَةَ.﴿عَزۡمِ ٱلۡأُمُورِ﴾: مُحْكَمِها ومُتْقَنِها الَّذِي تُحْمَدُ عاقِبَتُهُ."
  42,44,"﴿وَلِيࣲّ﴾: ناصرٍ يَهْديِهِ سَبِيلَ الرَّشادِ.﴿ٱلظَّـٰلِمِينَ﴾: الكافِرِينَ باللهِ.﴿مَرَدࣲّ﴾: رُجُوعٍ إلى الدُّنيا؛ لِنَسْتَدِركَ الإيمانَ والعَمَلَ الصّالِحَ."
  42,45,"﴿خَـٰشِعِينَ مِنَ ٱلذُّلِّ﴾: خاضِعِينَ بِسَبَبِ الذُّلِّ.﴿طَرۡفٍ خَفِيࣲّ﴾: عَيْنٍ ذَلِيلةٍ مِنَ الخَوْفِ والهَوانِ.﴿مُّقِيمࣲ﴾: دائِمٍ."
  42,46,"﴿أَوۡلِيَآءَ﴾: أعْوانٍ ونُصَراءَ.﴿يَنصُرُونَهُم﴾: يَمْنَعُونَهُم مِن عَذابِ اللهِ.﴿وَمَن يُضۡلِلِ ٱللَّهُ﴾: ومَن يَخْذُلْه اللهُ عَن طَرِيقِ الحقِّ.﴿سَبِيلٍ﴾: طَرِيقٍ يَصِل بِهِ إلى الحقِّ والنَّجاةِ."
  42,47,"﴿ٱسۡتَجِيبُواْ لِرَبِّكُم﴾: أجِيبُوا داعيَ اللهِ وآمِنُوا بِه.﴿لَّا مَرَدَّ لَهُۥ﴾: لا شَيءَ يَرُدُّ مَجِيئَهُ إذا جاء اللهُ بِهِ.﴿مَّلۡجَإࣲ﴾: مَعْقِل تَحْتَرِزُونَ فِيهِ مِن عَذابِ اللهِ.﴿نَّكِيرࣲ﴾: إنْكارٍ وتَغْيِيرٍ."
  42,48,"﴿رَحۡمَةࣰ﴾: غِنىً وسَعةً وغَيرَ ذَلِكَ.﴿سَيِّئَةُۢ﴾: مُصِيَبةٌ تَسُوءُهُم في أجْسادِهِم أوْ نُفُوسِهِم.﴿بِمَا قَدَّمَتۡ أَيۡدِيهِمۡ﴾: بما أسْلفَتْ مِنَ المعاصِي.﴿كَفُورࣱ﴾: جَحُودٌ نِعَمَ رَبِّه لا يَذْكُرُ إلا المصائِبَ."
  42,49,"﴿يَهَبُ﴾: يُعْطِي."
  42,50,"﴿يُزَوِّجُهُمۡ﴾: يُنَوِّعُهُم.﴿عَقِيمًا﴾: لا يُولَدُ له."
  42,51,"﴿عَلِيٌّ﴾: عالٍ بِذاتِه وأسْمائِهِ وصِفاتِه وأفعالِه."
  42,52,"﴿رُوحࣰا﴾: قُرآنًا.﴿ٱلۡكِتَـٰبُ﴾: الكُتُبُ السّابِقَةُ.﴿لَتَهۡدِيٓ﴾: لَتَدُلُّ وتُرْشِدُ.﴿صِرَ ٰ⁠طࣲ مُّسۡتَقِيمࣲ﴾: هُوَ الإسْلامُ."
  42,53,"﴿تَصِيرُ﴾: تَرْجِعُ."
