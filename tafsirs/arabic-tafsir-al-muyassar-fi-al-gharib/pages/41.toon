tafsir[50]{c,v,t}:
  41,1,"﴿حمٓ﴾: سَبَقَ الكَلامُ عَلى الحرُوفِ المقطَّعةِ في أوَّلِ سُورةِ البقرةِ."
  41,3,"﴿فُصِّلَتۡ﴾: بُيِّنتْ، أو نُوِّعَتْ."
  41,4,"﴿لَا يَسۡمَعُونَ﴾: لَهُ سَماعَ قَبُولٍ وإجابَةٍ."
  41,5,"﴿أَكِنَّةࣲ﴾: أغْطية تَمْنَعُنا من فَهْم ما تَدْعُوننا إليه.﴿وَقۡرࣱ﴾: ثِقَلٌ وصَمَمٌ، يمْنَعُنا مِنَ السَّمْعِ.﴿حِجَابࣱ﴾: ساتِرٌ يَحْجُبُنا عَنْ إجابَةِ دَعْوَتِكَ."
  41,6,"﴿فَٱسۡتَقِيمُوٓاْ إِلَيۡهِ﴾: فاسْلُكُوا الطَّريقَ الُموصِلَ إلَيهِ.﴿وَوَيۡلࣱ﴾: هَلاكٌ وعَذابٌ."
  41,7,"﴿لَا يُؤۡتُونَ ٱلزَّكَوٰةَ﴾: لا يُؤَدُّونَ الصَّدَقةَ إلى مُسْتَحِقِّيها."
  41,8,"﴿غَيۡرُ مَمۡنُونࣲ﴾: غَيرُ مَنقُوصٍ ولا مَحْسُوبٍ ليُمَنَّ بِهِ، بَلْ هُوَ خالٍ مِنَ المَنِّ والأَذى."
  41,9,"﴿أَندَادࣰا﴾: شُرَكاءَ."
  41,10,"﴿رَوَ ٰ⁠سِيَ﴾: جِبالًا ثَوابِتَ.﴿وَبَـٰرَكَ فِيهَا﴾: أدامَ خَيرَها، وأَنْبَتَ شَجَرَها.﴿وَقَدَّرَ﴾: وقَسَّمَ.﴿أَقۡوَ ٰ⁠تَهَا﴾: أرْزاقَ أهْلِها، وما يُصْلِحُهُم مِنَ المعاشِ.﴿فِيٓ أَرۡبَعَةِ أَيَّامࣲ﴾: أي: في تَتمَّةِ الأيامِ الأرْبَعَةِ.﴿سَوَآءࣰ﴾: مُسْتَوِيَةً مُهَيَّأةً.﴿لِّلسَّآئِلِينَ﴾: لِلْمُحْتاجِينَ إليها مِنَ البَشَرِ، أو لِمن يَطْلُبُ مَعْرِفَةَ ذَلكَ."
  41,11,"﴿ٱسۡتَوَىٰٓ﴾: ارْتَفَعَ.﴿دُخَانࣱ﴾: بُخارٌ مُرْتَفِعٌ.﴿ٱئۡتِيَا﴾: انْقادا لِأَمْرِي.﴿طَوۡعًا أَوۡ كَرۡهࣰا﴾: مُخْتارَتَينِ أو مُجْبَرتَين.﴿طَآئِعِينَ﴾: مُذْعِنِينَ لَكَ، ليسَ لَنا إرادَةٌ تُخالِفُ إرادتَكَ."
  41,12,"﴿فَقَضَىٰهُنَّ﴾: فأَوْجَدَهُنَّ وفَرَغَ من خَلْقِهنَّ.﴿وَأَوۡحَىٰ فِي كُلِّ سَمَآءٍ أَمۡرَهَا﴾: وألقى في كل سماءٍ من السمواتِ السبعِ ما أراد من الأمورِ التي بها قِوامُها وصَلاحُها.﴿بِمَصَـٰبِيحَ﴾: بالنجومِ المضيئةِ.﴿وَحِفۡظࣰا﴾: وزَيَّنّاها حِفْظًا لها من الشياطينِ الذين يَسْتَرِقون السَّمْعَ."
  41,13,"﴿أَنذَرۡتُكُمۡ﴾: خَوَّفْتُكُمْ.﴿صَـٰعِقَةࣰ﴾: وقْعَةَ عذابٍ يَسْتأصِلُكم."
  41,14,"﴿مِنۢ بَيۡنِ أَيۡدِيهِمۡ وَمِنۡ خَلۡفِهِمۡ﴾: يَتْبَعُ بعضُهم بعضًا واتصلَتْ نِذارتُهم."
  41,15,"﴿بِـَٔايَـٰتِنَا﴾: الُمعْجزات."
  41,16,"﴿صَرۡصَرࣰا﴾: شديدةَ البُرودةِ والصوتِ.﴿نَّحِسَاتࣲ﴾: مَشْؤوماتٍ عليهم.﴿ٱلۡخِزۡيِ﴾: الهَوانِ والهلاكِ."
  41,17,"﴿فَهَدَيۡنَـٰهُمۡ﴾: بيَّنّا لهم طُرُقَ الخيرِ والشرِّ.﴿ٱلۡعَمَىٰ﴾: الكفرَ.﴿فَأَخَذَتۡهُمۡ﴾: فأهلكَتْهُم.﴿صَـٰعِقَةُ﴾: مُهْلِكَةُ.﴿ٱلۡعَذَابِ ٱلۡهُونِ﴾: الذي معه هَوانٌ وإذلالٌ."
  41,19,"﴿يُحۡشَرُ﴾: يُجْمَعُ.﴿يُوزَعُونَ﴾: تَرُدُّ زبانيةُ العذابِ أوَّلَهم على آخِرِهم؛ ليجتمِعُوا جميعًا."
  41,21,"﴿أَوَّلَ مَرَّةࣲ﴾: الخَلْقَ الأَوَّلَ ولَمْ تَكُونُوا شيئًا."
  41,22,"﴿تَسۡتَتِرُونَ﴾: تَسْتَخْفُونَ عِنْدَ ارْتِكابِكُم المعاصِيَ في الدُّنيا.﴿أَن يَشۡهَدَ﴾: مَخافَةَ أن يَشْهَدَ."
  41,23,"﴿أَرۡدَىٰكُمۡ﴾: أهْلَكَكُم، فَأَوْرَدَكُم النّارَ.﴿ٱلۡخَـٰسِرِينَ﴾: الهالِكِينَ."
  41,24,"﴿مَثۡوࣰى﴾: مَأْوىً.﴿يَسۡتَعۡتِبُواْ﴾: يَسْأَلُوا العُتْبى وهي الرَّجْعَةُ لَهُم إلى الَّذِي يُحِبُّونَ بِتَخْفِيفِ العَذابِ عَنْهُم.﴿ٱلۡمُعۡتَبِينَ﴾: الَّذِينَ يُقْبَلُ عُذْرُهُم ويُجابُونَ إلى ما طَلَبُوا."
  41,25,"﴿وَقَيَّضۡنَا﴾: هَيَّأنا وأَعْدَدْنا.﴿قُرَنَآءَ﴾: نُظَراءَ مُلازِمِينَ مِن شَياطِينِ الإنْسِ والجِنِّ.﴿فَزَيَّنُواْ﴾: فَحَسّنُوا.﴿مَّا بَيۡنَ أَيۡدِيهِمۡ﴾: مِن أمْرِ الدُّنيا حتّى آثَرُوها على الآخِرةِ.﴿وَمَا خَلۡفَهُمۡ﴾: ما بَعْدَ مَماتِهم وذَلكَ بالتَّكْذِيبِ بالَمعادِ.﴿وَحَقَّ عَلَيۡهِمُ ٱلۡقَوۡلُ﴾: وجَبَ لَهُم العَذابُ.﴿فِيٓ أُمَمࣲ﴾: في جُمْلةِ أُمَمٍ كافِرةٍ.﴿قَدۡ خَلَتۡ﴾: مَضَتْ."
  41,26,"﴿وَٱلۡغَوۡاْ﴾: وأْتُوا فِيهِ بالتَّخْلِيطِ والصَّفِيرِ عِنْدَ قِراءتِهِ."
  41,28,"﴿دَارُ ٱلۡخُلۡدِ﴾: دارُ الإقامةِ الدّائِمَةِ.﴿يَجۡحَدُونَ﴾: يَكْفُرُونَ."
  41,29,"﴿ٱلۡأَسۡفَلِينَ﴾: أشَدَّ عَذابًا مِنّا."
  41,30,"﴿ٱسۡتَقَـٰمُواْ﴾: سَلَكُوا الطَّريقَ القَوِيمَ، وأَدَّوا فَرائِضَ اللهِ.﴿تَتَنَزَّلُ عَلَيۡهِمُ ٱلۡمَلَـٰٓئِكَةُ﴾: أي: عِنْدَ نُزُولِ الموتِ بِهِم مُطَمْئِنَةً.﴿أَلَّا تَخَافُواْ﴾: تَقُولُ لَهُم: لا تخافُوا مِنَ الموتِ وما بَعْدَهُ.﴿وَلَا تَحۡزَنُواْ﴾: عَلى ما تُخَلِّفُونَه وراءَكُم مِن أُمَورِ الدُّنيا.﴿وَأَبۡشِرُواْ﴾: وسُرُّوا."
  41,31,"﴿أَوۡلِيَآؤُكُمۡ﴾: أنْصارُكُم وأَحِبّاؤُكُم.﴿تَدَّعُونَ﴾: تَتَمَنَّونَ."
  41,32,"﴿نُزُلࣰا﴾: ضِيافَةً وتَكْرِمَةً."
  41,33,"﴿وَمَنۡ أَحۡسَنُ قَوۡلࣰا﴾: لا أحَدَ أحْسَنُ قَولًا.﴿دَعَآ إِلَى ٱللَّهِ﴾: دَعا إلى تَوْحِيدِ اللهِ وعِبادَتِه وحْدَهُ."
  41,34,"﴿ٱلۡحَسَنَةُ﴾: الصَّبرُ والحِلْمُ والعَفْوُ.﴿ٱلسَّيِّئَةُ﴾: الغَضَبُ والجَهْلُ والإساءَةُ.﴿ٱدۡفَعۡ بِٱلَّتِي هِيَ أَحۡسَنُ﴾: ادْفَعْ -أيُّها الرَّسُولُ- بِعَفْوِكَ وحِلْمِكَ وإحْسانِكَ مَن أساءَ إليكَ.﴿وَلِيٌّ﴾: مُحِبٌّ مُناصِرٌ.﴿حَمِيمࣱ﴾: قَرِيبٌ مُشْفِقٌ."
  41,35,"﴿وَمَا يُلَقَّىٰهَآ﴾: وما يُعْطى ويُوفَّقُ لهذهِ الَمنْزِلَةِ الحمِيدَةِ.﴿حَظٍّ﴾: نَصِيبٍ."
  41,36,"﴿وَإِمَّا يَنزَغَنَّكَ مِنَ ٱلشَّيۡطَـٰنِ نَزۡغࣱ﴾: وإمّا يُلْقِيَنَّ الشَّيطانُ في نَفْسِكَ وسْوَسَةً مِن حدِيثِ النَّفْسِ تَحْمِلُكَ عَلى مُجازاةِ الُمسِيءِ بالإساءَةِ.﴿فَٱسۡتَعِذۡ بِٱللَّهِ﴾: فاسْتَجِرْ بِاللهِ واعْتَصِمْ بِهِ."
  41,37,"﴿وَمِنۡ ءَايَـٰتِهِ﴾: ومِن حُجَجِ اللهِ عَلى خَلقِهِ، ودَلائِلِهِ عَلى وحْدانِيَّتهِ وكَمالِ قُدْرَتِهِ."
  41,38,"﴿فَٱلَّذِينَ عِندَ رَبِّكَ﴾: هُمُ الملائِكَةُ.﴿لَا يَسۡـَٔمُونَ﴾: لا يَفْتُرُونَ ولا يَمَلُّونَ."
  41,39,"﴿خَـٰشِعَةࣰ﴾: يابِسَةً مُسْتَكِينَةً لا نَباتَ فِيها.﴿ٱهۡتَزَّتۡ﴾: تَحَرَّكَتْ وتَشَقَّقَتْ بالنَّباتِ.﴿وَرَبَتۡ﴾: وانْتَفَخَتْ وعَلَتْ."
  41,40,"﴿يُلۡحِدُونَ﴾: يَمِيلُونَ عَنِ الحَقِّ إنْكارًا لَهُ.﴿ٱعۡمَلُواْ مَا شِئۡتُمۡ﴾: وعِيدٌ في صِيغَةِ الأمْر."
  41,41,"﴿بِٱلذِّكۡرِ﴾: بالقرآنِ."
  41,42,"﴿ٱلۡبَـٰطِلُ﴾: الشَّيطانُ وأيُّ أمْرٍ يُبْطِلُ شَيئًا مِنهُ.﴿مِنۢ بَيۡنِ يَدَيۡهِ وَلَا مِنۡ خَلۡفِهِۦ﴾: مِن أيِّ جِهَةٍ مِن جِهاتِهِ، فهو مَحْفُوظٌ بِحِفْظِ اللهِ.﴿حَكِيمٍ﴾: ذِي حِكْمَةٍ.﴿حَمِيدࣲ﴾: مَحْمُودٍ عَلى نِعَمِهِ عَلى الخَلْقِ وعَلى ما لَهُ مِن صِفاتِ الكَمالِ."
  41,43,"﴿مَّا يُقَالُ لَكَ﴾: لا يقُولُ لَكَ المشرِكُونَ."
  41,44,"﴿أَعۡجَمِيࣰّا﴾: عَلى غَيرِ لُغَةِ العَرَبِ.﴿لَوۡلَا﴾: هَلّا.﴿فُصِّلَتۡ ءَايَـٰتُهُۥٓ﴾: بُيِّنتْ آياتُه فَنَفْقَهَهُ ونَعْلَمَهُ.﴿ءَا۬عۡجَمِيࣱّ وَعَرَبِيࣱّ﴾: أأَعْجَمِيٌّ هَذا القُرآنُ، ولِسانُ الَّذِي أُنْزِل عَليهِ عَرَبيٌّ؟﴿هُدࣰى﴾: بَيانٌ لِلْحَقِّ.﴿وَشِفَآءࣱ﴾: مِنَ الجَهْلِ والأمْراضِ.﴿وَقۡرࣱ﴾: ثِقَلٌ وصَمَمٌ.﴿وَهُوَ عَلَيۡهِمۡ عَمًى﴾: عَمِيَتْ قُلُوبُهُم عَنِ القُرآنِ فَلا يَهْتَدُونَ بِهِ.﴿أُوْلَـٰٓئِكَ يُنَادَوۡنَ مِن مَّكَانِۭ بَعِيدࣲ﴾: كَأنّ أُولئِكَ المشرِكِينَ يَسْمَعُونَ صَوْتًا مِن بَعِيدٍ، ولا يَفْهَمُونَ مَعانِيَهُ."
  41,45,"﴿ٱلۡكِتَـٰبَ﴾: التَّوراةَ.﴿وَلَوۡلَا كَلِمَةࣱ سَبَقَتۡ مِن رَّبِّكَ﴾: بِتَأْجِيلِ العَذابِ عَن قَومِكَ.﴿لَقُضِيَ بَيۡنَهُمۡ﴾: لَفُصِلَ بينهم بإهْلاكِ الكافِرينَ في الحالِ.﴿وَإِنَّهُمۡ لَفِي شَكࣲّ مِّنۡهُ﴾: وإنّ الفريقَ المُبْطِلَ مِنهُم لَفِي شَكٍّ مما قالُوا في التَّوراةِ.﴿مُرِيبࣲ﴾: مُوقِعٍ في قَلَقِ النَّفْسِ وعَدَمِ طُمَأنِينتِها؛ لأنّهُم قالُوهُ ظنًّا بِغَيرِ حُجَّةٍ."
  41,46,"﴿فَعَلَيۡهَا﴾: فَعَلى نَفْسِهِ جَنى.﴿بِظَلَّـٰمࣲ﴾: بِذِي ظُلْمٍ."
  41,47,"﴿إِلَيۡهِ يُرَدُّ﴾: إلى اللهِ وحْدَهُ يُرجَعُ.﴿مِّنۡ أَكۡمَامِهَا﴾: مِن أوْعِيَتِها. مُفْرَدُها: كِمٌّ.﴿ءَاذَنَّـٰكَ﴾: أعْلَمناكَ.﴿مَا مِنَّا مِن شَهِيدࣲ﴾: يَشْهَدُ أنّ لَكَ شَريكًا."
  41,48,"﴿وَضَلَّ عَنۡهُم﴾: وذَهَبَ عَنِ المشْرِكِينَ.﴿وَظَنُّواْ﴾: أيقَنُوا.﴿مَّحِيصࣲ﴾: مَلْجَأٍ مِن عَذابِ اللهِ."
  41,49,"﴿لَّا يَسۡـَٔمُ﴾: لا يَمَلُّ.﴿ٱلۡإِنسَـٰنُ﴾: المُرادُ هُنا الكافرُ بِاللهِ.﴿مِن دُعَآءِ ٱلۡخَيۡرِ﴾: مِن سُؤالِهِ رَبَّهُ أن يَمُدَّهُ بالمالِ والصِّحَّةِ.﴿وَإِن مَّسَّهُ﴾: وإنْ أصابَه.﴿ٱلشَّرُّ﴾: فَقْرٌ ومَرَضٌ.﴿فَيَـُٔوسࣱ﴾: مُبالِغٌ في اعْتِقادِ عَدَمِ حُصُولِ الخيرِ لَهُ.﴿قَنُوطࣱ﴾: شَدِيد اليأسِ."
  41,50,"﴿ضَرَّآءَ﴾: شدَّةٍ وبَلاءٍ.﴿هَـٰذَا لِي﴾: أسْتَحِقُّه على اللهِ لأنّه راضٍ عَنِّي.﴿لَلۡحُسۡنَىٰ﴾: الجنَّةِ.﴿غَلِيظࣲ﴾: شَدِيدٍ، وهو خُلُودُهُم في النّارِ."
  41,51,"﴿وَنَـَٔابِجَانِبِهِۦ﴾: تَباعَدَ عَن شُكْرِ نِعْمَةِ اللهِ وطاعَتِهِ.﴿عَرِيضࣲ﴾: كَثِيرٍ."
  41,52,"﴿أَرَءَيۡتُمۡ﴾: أخْبِرُونِي.﴿مَنۡ أَضَلُّ﴾: لا أحَد أشَدُّ ذَهابًا عَن قَصْدِ السَّبيلِ.﴿فِي شِقَاقِۭ﴾: في خِلافٍ وفِراقٍ لأمر الله.﴿بَعِيدࣲ﴾: واسِع المسافَةِ مِنَ الرَّشادِ."
  41,53,"﴿ءَايَـٰتِنَا﴾: مِنَ الفُتُوحاتِ وظُهُورِ الإسْلامِ عَلى الأقاليمِ وسائِرِ الأدْيانِ.﴿ٱلۡـَٔافَاقِ﴾: أقْطارِ السَّمَواتِ والأرْضِ.﴿وَفِيٓ أَنفُسِهِمۡ﴾: مِن لطِيفِ الصَّنْعَةِ وبدِيعِ الحِكْمةِ.﴿أَوَ لَمۡ يَكۡفِ بِرَبِّكَ﴾: أو لم يَكْفِ ربُّكَ شاهِدًا عَلى صِدْقِكَ وصِدْقِ ما أُنزِلَ إليكَ."
  41,54,"﴿مِرۡيَةࣲ مِّن لِّقَآءِ رَبِّهِمۡ﴾: شَكٍّ عَظِيمٍ مِنَ البعثِ بَعْدَ المماتِ.﴿مُّحِيطُۢ﴾: أحاطَ بِكُلِّ شَيءٍ عِلْمًا."
