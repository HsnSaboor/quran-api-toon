tafsir[42]{c,v,t}:
  79,1,"﴿وَٱلنَّـٰزِعَـٰتِ﴾: أُقْسِمُ بالملائِكةِ الَّتِي تَنْزِعُ أرْواحَ الكُفّارِ.﴿غَرۡقࣰا﴾: نَزْعًا غَرْقًا، أي مُغْرِقًا، أي تَنْزِعُ الأرْواحَ من أقاصِي الأَجْسادِ."
  79,2,"﴿وَٱلنَّـٰشِطَـٰتِ﴾: والملائِكَةِ الَّتِي تَقْبِضُ أرْواحَ المؤمِنِينَ.﴿نَشۡطࣰا﴾: بِنَشاطٍ ورِفقٍ."
  79,3,"﴿وَٱلسَّـٰبِحَـٰتِ﴾: والملائِكَةِ الَّتِي تَسْبَحُ في نُزُولِها مِنَ السَّماءِ وصُعُودِها إليها."
  79,4,"﴿فَٱلسَّـٰبِقَـٰتِ﴾: فالملائِكَةِ الَّتِي تُسارِعُ إلى تَنِفيذِ أمْرِ اللهِ."
  79,5,"﴿فَٱلۡمُدَبِّرَ ٰ⁠تِ أَمۡرࣰا﴾: فالملائِكةِ المُنَفِّذاتِ أمْرَ رَبِّها."
  79,6,"﴿يَوۡمَ تَرۡجُفُ ٱلرَّاجِفَةُ﴾: يومَ تَضْطَرِبُ الأرضُ بالنَّفْخَةِ الأُولى نَفْخَةِ الإماتَةِ."
  79,7,"﴿تَتۡبَعُهَا ٱلرَّادِفَةُ﴾: تَتْبَعُها نَفْخَةٌ أُخْرى لِبَعْثِ الخَلْقِ."
  79,8,"﴿قُلُوبࣱ﴾: قُلُوبُ الكُفّارِ.﴿وَاجِفَةٌ﴾: مُضْطَرِبَةٌ مِن شِدَّةِ الخوفِ."
  79,9,"﴿خَـٰشِعَةࣱ﴾: ذَلِيلَةٌ مِن هَوْلِ ما تَرى."
  79,10,"﴿أَءِنَّا لَمَرۡدُودُونَ﴾: أنُرَدُّ بَعْدَ مَوتِنا؟.﴿ٱلۡحَافِرَةِ﴾: إلى أوَّلِ حالِنا، فَنَصِيرُ أحياءً بَعْدَ مَوْتِنا."
  79,11,"﴿أَءِذَا كُنَّا عِظَـٰمࣰا نَّخِرَةࣰ﴾: أنُرَدُّ وقَدْ صِرْنا عِظامًا بالِيةً."
  79,12,"﴿كَرَّةٌ خَاسِرَةࣱ﴾: رَجْعَةٌ خائِبةٌ كاذِبةٌ."
  79,13,"﴿زَجۡرَةࣱ وَ ٰ⁠حِدَةࣱ﴾: نَفْخَةٌ واحِدَةٌ."
  79,14,"﴿بِٱلسَّاهِرَةِ﴾: على وجْهِ الأَرْضِ."
  79,16,"﴿ٱلۡمُقَدَّسِ﴾: الُمطَهَّرِ المبارَكِ.﴿طُوًى﴾: وادٍ في جانِبِ جَبَلِ الطُّورِ."
  79,17,"﴿طَغَىٰ﴾: أفْرَطَ في العِصْيانِ."
  79,18,"﴿هَل لَّكَ﴾: أتَوَدُّ.﴿تَزَكَّىٰ﴾: تُطَهِّرَ نَفْسَكَ."
  79,20,"﴿فَأَرَىٰهُ﴾: فَأَرى مُوسى فِرْعَونَ.﴿ٱلۡـَٔايَةَ ٱلۡكُبۡرَىٰ﴾: العلامةَ العُظْمى: العَصا واليدَ."
  79,22,"﴿أَدۡبَرَ﴾: ولّى مُعْرِضًا عَنِ الإيمانِ.﴿يَسۡعَىٰ﴾: في مُعارَضَةِ مُوسى."
  79,23,"﴿فَحَشَرَ﴾: فَجَمَعَ النّاسَ."
  79,25,"﴿فَأَخَذَهُ ٱللَّهُ﴾: فَعاقَبَهُ.﴿نَكَالَ ٱلۡـَٔاخِرَةِ﴾: عَذابَ الآخِرَةِ.﴿وَٱلۡأُولَىٰٓ﴾: وعَذابَ الدُّنيا."
  79,26,"﴿لَعِبۡرَةࣰ﴾: لَمَوْعِظَةً."
  79,27,"﴿ءَأَنتُمۡ أَشَدُّ خَلۡقًا أَمِ ٱلسَّمَآءُ﴾: أبَعْثُكُم-أيُّها الناسُ- بَعْدَ الموتِ أشَدُّ في تَقْدِيرِكُم أم خَلْقُ السَّماءِ؟﴿بَنَىٰهَا﴾: خَلَقَها."
  79,28,"﴿رَفَعَ سَمۡكَهَا﴾: رَفَعَها فَوقَكُم كالبِناءِ فَأَعلى سَقْفَها في الهواءِ.﴿فَسَوَّىٰهَا﴾: فعَدَّلَ أجْزاءَها بإتْقان."
  79,29,"﴿وَأَغۡطَشَ لَيۡلَهَا﴾: وأَظْلَمَ لَيلَها.﴿وَأَخۡرَجَ ضُحَىٰهَا﴾: وأَبْرَزَ نَهارَها."
  79,30,"﴿بَعۡدَ ذَ ٰ⁠لِكَ﴾: بَعْدَ خَلْقِ السَّماءِ.﴿دَحَىٰهَآ﴾: بَسَطَها وأَوْدَعَ فِيها منافِعَها."
  79,31,"﴿وَمَرۡعَىٰهَا﴾: وأَنبَتَ فِيها ما يُرعى مِنَ النباتاتِ."
  79,32,"﴿أَرۡسَىٰهَا﴾: أثْبتَها في الأرضِ."
  79,33,"﴿مَتَـٰعࣰا لَّكُمۡ﴾: مَنفَعَةً لَكُم."
  79,34,"﴿ٱلطَّآمَّةُ ٱلۡكُبۡرَىٰ﴾: القِيامَةُ الكُبْرى والشِدَّةُ العُظْمى وهي النَّفْخَةُ الثّانِيةُ."
  79,35,"﴿يَتَذَكَّرُ ٱلۡإِنسَـٰنُ مَا سَعَىٰ﴾: يُعْرَضُ عَلى الإنسانِ عَمَلُهُ، فَيَتَذَكَّرُهُ ويَعْتَرِفُ بِهِ."
  79,36,"﴿وَبُرِّزَتِ﴾: وأُظهِرَتْ."
  79,37,"﴿طَغَىٰ﴾: أفْرَطَ في العِصيانِ."
  79,38,"﴿وَءَاثَرَ ٱلۡحَيَوٰةَ ٱلدُّنۡيَا﴾: وفَضَّل الحياةَ الدُّنيا على الآخِرَةِ."
  79,39,"﴿ٱلۡمَأۡوَىٰ﴾: المصِيرُ والمآلُ."
  79,40,"﴿مَقَامَ رَبِّهِۦ﴾: القِيامَ بينَ يَدَيِ اللهِ لِلحِسابِ.﴿ٱلۡهَوَىٰ﴾: الأَهْواءِ الفاسِدةِ."
  79,41,"﴿ٱلۡمَأۡوَىٰ﴾: مَسْكَنُهُ."
  79,42,"﴿أَيَّانَ مُرۡسَىٰهَا﴾: مَتى وقْتُ السّاعةِ؟"
  79,43,"﴿فِيمَ أَنتَ مِن ذِكۡرَىٰهَآ﴾: لَسْتَ في شَيءٍ مِن عِلْمِها."
  79,44,"﴿إِلَىٰ رَبِّكَ مُنتَهَىٰهَآ﴾: مَرَدُّ ذَلِكَ إلى اللهِ عَزَّ وجَلَّ."
  79,45,"﴿مُنذِرُ﴾: مُحذِّرٌ مِنها."
  79,46,"﴿عَشِيَّةً﴾: ما بَينَ الظُّهْرِ إلى غُرُوبِ الشَّمسِ.﴿ضُحَىٰهَا﴾: ما بَينَ طُلُوعِ الشَّمسِ إلى نِصْفِ النَّهارِ."
