tafsir[77]{c,v,t}:
  43,1,"﴿حمٓ﴾: سَبَقَ الكَلامُ على الحُرُوفِ المُقَطَّعةِ في أوَّلِ سُورَةِ البَقَرةِ."
  43,2,"﴿وَٱلۡكِتَـٰبِ﴾: القُرآنِ.﴿ٱلۡمُبِينِ﴾: الواضِح لَفْظًا ومَعْنىً."
  43,4,"﴿أُمِّ ٱلۡكِتَـٰبِ﴾: اللَّوحِ المحْفُوظِ.﴿لَعَلِيٌّ﴾: رَفِيعٌ.﴿حَكِيمٌ﴾: مُحْكَمٌ لا اخْتِلافَ فِيهِ ولا تَناقُضَ."
  43,5,"﴿أَفَنَضۡرِبُ عَنكُمُ ٱلذِّكۡرَ﴾: أفَنُعْرِضُ عَنْكُم ونَتْرُكُ إنْزالَ القُرآنِ إلَيكُم.﴿صَفۡحًا﴾: أي: إعْراضًا.﴿مُّسۡرِفِينَ﴾: مُتَجاوِزِينَ الحدَّ في الإعْراضِ عَنِ القُرآنِ."
  43,6,"﴿وَكَمۡ﴾: كَثِيرًا.﴿ٱلۡأَوَّلِينَ﴾: القُرُونِ الَّتي مَضَتْ."
  43,8,"﴿بَطۡشࣰا﴾: قُوَّةً وبأسًا.﴿مَثَلُ﴾: عُقُوبةُ."
  43,10,"﴿مَهۡدࣰا﴾: فِراشًا وبِساطًا.﴿سُبُلࣰا﴾: طُرُقًا لِمَعاشِكُم ومَتاجِرِكُم."
  43,11,"﴿مَآءَۢ﴾: مَطَرًا.﴿بِقَدَرࣲ﴾: بِمِقْدارِ الحاجَةِ.﴿فَأَنشَرۡنَا﴾: فَأَحْيَيْنا.﴿بَلۡدَةࣰ﴾: قِطْعَةً واسِعَةً مِنَ الأرْضِ.﴿مَّيۡتࣰا﴾: مُقْفِرًا مِنَ النَّباتِ والزَّرْعِ.﴿تُخۡرَجُونَ﴾: تُبْعَثُونَ يومَ القيامةِ."
  43,12,"﴿ٱلۡأَزۡوَ ٰ⁠جَ﴾: الأصْنافَ مِن حَيوانٍ ونَباتٍ ذُكُورًا وإناثًا.﴿ٱلۡفُلۡكِ﴾: السُّفُنِ.﴿وَٱلۡأَنۡعَـٰمِ﴾: البَهائِمِ كالإبِلِ والخيلِ والبِغالِ والحمِيرِ."
  43,13,"﴿سَخَّرَ﴾: ذَلَّلَ وطَوَّعَ.﴿مُقۡرِنِينَ﴾: مُطِيقِينَ."
  43,14,"﴿لَمُنقَلِبُونَ﴾: راجِعُونَ."
  43,15,"﴿جُزۡءًا﴾: نَصِيبًا."
  43,16,"﴿أَمِ﴾: بَلِ.﴿ٱتَّخَذَ﴾: أتَزْعُمُونَ أنَّ الله اتَّخَذَ.﴿وَأَصۡفَىٰكُم﴾: وأَخْلَصَكُم."
  43,17,"﴿ضَرَبَ﴾: جَعَلَ.﴿مَثَلࣰا﴾: شبيهًا.﴿ظَلَّ﴾: صارَ.﴿كَظِيمٌ﴾: حَزِينٌ مملُوءٌ بالهَمِّ والكَرْبِ."
  43,18,"﴿يُنَشَّؤُاْ﴾: يُرَبّى.﴿ٱلۡحِلۡيَةِ﴾: الزِّينةِ.﴿ٱلۡخِصَامِ﴾: الِجدالِ."
  43,19,"﴿أَشَهِدُواْ خَلۡقَهُمۡ﴾: أحَضَرُوا حِينَ خَلْقِهِم؟"
  43,20,"﴿يَخۡرُصُونَ﴾: يَكْذِبُونَ."
  43,21,"﴿مُسۡتَمۡسِكُونَ﴾: يَعْمَلُونَ به ويَدِينُونَ بما فِيهِ."
  43,22,"﴿أُمَّةࣲ﴾: طَرِيقةٍ ودِينٍ.﴿عَلَىٰٓ ءَاثَـٰرِهِم﴾: وراءَهُم.﴿مُّهۡتَدُونَ﴾: مُتَّبِعُونَ."
  43,23,"﴿مُتۡرَفُوهَآ﴾: الرُّؤَساءُ الَّذيِنَ أطْغَتْهُم النِّعْمَةُ."
  43,25,"﴿فَٱنتَقَمۡنَا مِنۡهُمۡ﴾: عاقَبْناهُم على ذُنُوبِهِم.﴿عَـٰقِبَةُ﴾: آخِرُ أمْرٍ."
  43,26,"﴿بَرَآءࣱ﴾: بَرِيءٌ."
  43,27,"﴿فَطَرَنِي﴾: خَلَقَنِي.﴿سَيَهۡدِينِ﴾: سَيُوَفِّقُنِي لاتِّباعِ سَبِيلِ الرُّشْدِ."
  43,28,"﴿وَجَعَلَهَا كَلِمَةَۢ بَاقِيَةࣰ﴾: وجَعَلَ إبْراهِيمُ كَلِمةَ التَّوحِيدِ قَوْلًا باقِيًا على مَرِّ الزَّمانِ.﴿عَقِبِهِۦ﴾: ولَدِهِ مِن بَعْدِهِ."
  43,29,"﴿مَتَّعۡتُ﴾: أجْزَلْتُ النِّعمَةَ ولَمْ أُعاجِلْ بالعُقُوبَةِ.﴿ٱلۡحَقُّ﴾: القُرَآنُ.﴿مُّبِينࣱ﴾: يُبَيِّنُ لَهُم مّا يَحْتاجُونَ إلَيهِ مِن أُمُورِ دِينِهِم."
  43,31,"﴿لَوۡلَا﴾: هَلّا.﴿ٱلۡقَرۡيَتَيۡنِ﴾: مَكَّةَ والطّائِفِ."
  43,32,"﴿رَحۡمَتَ رَبِّكَ﴾: النُّبُوَّةُ.﴿سُخۡرِيࣰّا﴾: مُذَلَّلًا في شُؤُونِ المعاشِ.﴿وَرَحۡمَتُ رَبِّكَ﴾: النُّبُوَّةُ.﴿مِّمَّا يَجۡمَعُونَ﴾: مِنَ الأمْوالِ."
  43,33,"﴿أُمَّةࣰ وَ ٰ⁠حِدَةࣰ﴾: جماعَةً واحِدَةً، كُلُّهُم كُفّارٌ.﴿وَمَعَارِجَ﴾: وسَلالِمَ.﴿يَظۡهَرُونَ﴾: يَصْعَدُونَ."
  43,34,"﴿وَسُرُرًا﴾: جَمْعُ سَرِيرٍ، وهو ككرْسِيٍّ واسِعٍ يُمْكِنُ الاضْطِجاعُ عَلَيهِ.﴿يَتَّكِـُٔونَ﴾: يَجْلِسُونَ عَلَيها مُعْتَمِدِينَ على مَرافِقِهِم."
  43,35,"﴿وَزُخۡرُفࣰا﴾: وجَعَلْنا لهم ذَهَبًا."
  43,36,"﴿يَعۡشُ﴾: يُعرِضْ.﴿ذِكۡرِ ٱلرَّحۡمَـٰنِ﴾: القرآن.﴿نُقَيِّضۡ﴾: نَجْعَلْ.﴿قَرِينࣱ﴾: مُلازِمٌ ومُصاحِبٌ."
  43,37,"﴿ٱلسَّبِيلِ﴾: طَرِيقِ الحقِّ"
  43,38,"﴿يَـٰلَيۡتَ﴾: ودِدْتُّ وتمنَّيتُ.﴿بُعۡدَ ٱلۡمَشۡرِقَيۡنِ﴾: بُعْدَ ما بَينَ المشْرِقِ والمغْرِبِ."
  43,40,"43:39"
  43,41,"43:39"
  43,42,"43:39"
  43,43,"43:39"
  43,44,"﴿لَذِكۡرࣱ﴾: لَشَرَفٌ."
  43,45,"﴿مَنۡ أَرۡسَلۡنَا﴾: أتْباعَ مَن أرْسَلْنا، وهُم مُّؤمِنُو أهْلِ الكِتابِ."
  43,46,"﴿بِـَٔايَـٰتِنَآ﴾: بِحُجَجِنا.﴿وَمَلَإِيْهِۦ﴾: عُظَماءِ قَومِهِ."
  43,48,"﴿مِنۡ أُخۡتِهَا﴾: مِنَ الَّتِي قَبْلَها."
  43,49,"﴿ٱلسَّاحِرُ﴾: العالِمُ، ولَمْ يَكُنِ السِّحْرُ صِفَةَ ذَمٍّ عِنْدَ فِرْعَونَ ومَلَئِهِ."
  43,50,"﴿يَنكُثُونَ﴾: يغْدِرُونَ ويَنْقُضُونَ ما عاهَدُوا عليهِ أنْفُسَهُم."
  43,51,"﴿مِن تَحۡتِيٓ﴾: مِن تَحْتِ قُصُورِي."
  43,52,"﴿أَمۡ﴾: بَلْ.﴿مَهِينࣱ﴾: ضَعِيفٌ حَقِيرٌ.﴿يُبِينُ﴾: أي: يُبِين الكَلامَ."
  43,53,"﴿فَلَوۡلَآ﴾: فَهَلّا.﴿مُقۡتَرِنِينَ﴾: مُتَتابِعِينَ."
  43,54,"﴿فَٱسۡتَخَفَّ قَوۡمَهُۥ﴾: حَمَلَ قَومَه عَلى خفَّةِ العَقْل."
  43,55,"﴿ءَاسَفُونَا﴾: أغْضَبُونا.﴿ٱنتَقَمۡنَا مِنۡهُمۡ﴾: عاقَبْناهُم عَلى ذُنُوبِهم."
  43,56,"﴿سَلَفࣰا﴾: قَوْمًا تَقَدَّمُوا لِيتَّعِظَ بِهِمُ الآخَرُونَ.﴿وَمَثَلࣰا﴾: عِبْرةً وعِظَةً."
  43,57,"﴿ضُرِبَ ٱبۡنُ مَرۡيَمَ مَثَلًا﴾: ضَرَبَ المشركُونَ نَبِيَّ اللهِ عِيسى مَثَلًا لِآلِهَتِهِم وشَبَّهُوهُ بِها في دُخُولِ النّارِ.﴿يَصِدُّونَ﴾: يَصِيحُونَ فَرَحًا وسُرُورًا."
  43,58,"﴿خَصِمُونَ﴾: شِدِيدُو التَّمَسُكِ بالخُصُومَةِ مَعَ ظُهُورِ الحقِّ عِنْدَهُم."
  43,59,"﴿مَثَلࣰا لِّبَنِيٓ إِسۡرَ ٰ⁠ٓءِيلَ﴾: عِبْرةً لَهُم يَعْرِفُونَ بِهِ قُدْرَةَ اللهِ عَلى ما يُرِيدُ؛ إذْ خَلَقَهُ مِن غَيرِ أبٍ."
  43,60,"﴿مِنكُم﴾: بَدَلًا مِنكُم.﴿يَخۡلُفُونَ﴾: يَخْلُفُ بَعْضُهُم بَعْضًا بَدَلًا مِن بنِي آدمَ."
  43,61,"﴿وَإِنَّهُۥ﴾: وإنّ نُزولَ عِيسى عَلَيهِ السَّلامُ في آخِرِ الزَّمانِ.﴿لَعِلۡمࣱ﴾: لَدَلِيلٌ وعَلامةٌ.﴿فَلَا تَمۡتَرُنَّ﴾: فَلا تَشُكُّوا أنّها واقِعةٌ."
  43,62,"﴿مُّبِينࣱ﴾: بَيِّنُ العَداوَةِ."
  43,63,"﴿بِٱلۡبَيِّنَـٰتِ﴾: بالأدِلَّةِ الواضِحاتِ.﴿بِٱلۡحِكۡمَةِ﴾: بالنُّبُوَّةِ."
  43,65,"﴿ٱلۡأَحۡزَابُ﴾: الفِرَقُ مِنَ النَّصارى.﴿فَوَيۡلࣱ﴾: فَهَلاكٌ وعَذابٌ ألِيمٌ."
  43,66,"﴿يَنظُرُونَ﴾: يَنْتَظِرُونَ.﴿بَغۡتَةࣰ﴾: فَجْأةً."
  43,67,"﴿ٱلۡأَخِلَّآءُ﴾: الأصْدِقاءُ."
  43,69,"43:68"
  43,70,"﴿وَأَزۡوَ ٰ⁠جُكُمۡ﴾: وقُرَناؤُكُم المؤمِنُونَ.﴿تُحۡبَرُونَ﴾: تُنَعَّمُونَ وتُسَرُّونَ."
  43,71,"﴿بِصِحَافࣲ﴾: بآنِيةٍ يُؤْكَلُ فِيها.﴿وَأَكۡوَابࣲ﴾: آنِيَةٍ للشُّرْبِ.﴿وَتَلَذُّ﴾: وتَجِدُ فِيها ما يَسُرُّها."
  43,73,"43:72"
  43,74,"﴿ٱلۡمُجۡرِمِينَ﴾: الكافِرينَ."
  43,75,"﴿لَا يُفَتَّرُ﴾: لا يُخَفَّفُ.﴿مُبۡلِسُونَ﴾: آيِسُونَ مِن رَّحْمَةِ اللهِ."
  43,77,"﴿يَـٰمَـٰلِكُ﴾: هو اسْمُ خازِنِ جَهَنَّمَ.﴿لِيَقۡضِ عَلَيۡنَا رَبُّكَ﴾: لِيُمِتْنا ربُّكَ.﴿مَّـٰكِثُونَ﴾: مُقِيمُونَ في العذابِ."
  43,79,"﴿أَمۡ﴾: بَلْ.﴿أَبۡرَمُوٓاْ﴾: أحْكَمُوا.﴿مُبۡرِمُونَ﴾: مُحْكِمُونَ أمْرًا في مُجازاتِهم بِالنَّكالِ والعَذابِ."
  43,80,"﴿سِرَّهُمۡ﴾: ما يُخْفُونَه مِن غَيرِهِم.﴿وَنَجۡوَىٰهُم﴾: الحدِيثَ الَّذِي يَتَسارُّونَ بِهِ فِيما بَينَهُم.﴿وَرُسُلُنَا﴾: الملائِكَةُ الحَفَظَةُ."
  43,81,"﴿فَأَنَا۠ أَوَّلُ ٱلۡعَـٰبِدِينَ﴾: أوَّلُ عابِدِيهِ بِذلكَ مِنكُم، ولَكِنَّهُ لا ولَدَ لَهُ، فأَنا أعْبُدُهُ بِأنّه لا ولَدَ لَهُ."
  43,82,"﴿سُبۡحَـٰنَ﴾: تنْزِيهًا وتَقْدِيسًا.﴿يَصِفُونَ﴾: يَكْذِبُونَ."
  43,83,"﴿يَخُوضُواْ﴾: يَتَحَدَّثُوا بالباطِل على غيرِ هُدىً."
  43,84,"﴿فِي ٱلسَّمَآءِ إِلَـٰهࣱ وَفِي ٱلۡأَرۡضِ إِلَـٰهࣱ﴾: مَعْبُودٌ في السَّماءِ وفي الأَرْضِ."
  43,85,"﴿وَتَبَارَكَ﴾: كَثُرَ خَيْرُهُ.﴿تُرۡجَعُونَ﴾: تُرَدُّونَ بَعْدَ مَماتِكُم."
  43,86,"﴿ٱلشَّفَـٰعَةَ﴾: طَلَبَ قَضاءِ حاجَةِ المشْفُوعِ لَهُ عِنْدَ المشْفُوعِ عِنْدَهُ مِنَ التَّجاوُزِ عَنِ السَّيئاتِ والزَّلّاتِ وغَيرِها."
  43,87,"﴿فَأَنَّىٰ يُؤۡفَكُونَ﴾: كَيْفَ يُصْرَفُونَ عَنْ عِبادَةِ الله؟"
  43,88,"﴿وَقِيلِهِۦ﴾: وعِنْدَ اللهِ عِلْمُ قولِ الرَّسُولِ ﷺ."
  43,89,"﴿فَٱصۡفَحۡ﴾: فَأَعْرِضْ.﴿سَلَـٰمࣱ﴾: سَلامُ مُتارَكَةٍ ومُفارَقَةٍ لِلْجاهِلِينَ."
