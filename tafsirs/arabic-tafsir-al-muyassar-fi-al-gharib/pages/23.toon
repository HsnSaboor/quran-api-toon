tafsir[98]{c,v,t}:
  23,1,"﴿أَفۡلَحَ﴾: فازَ بِالنَّجاةِ مِنَ النّارِ."
  23,2,"﴿خَـٰشِعُونَ﴾: خاضِعُونَ بِقُلوبِهِم وجَوارِحِهِم."
  23,3,"﴿عَنِ ٱللَّغۡوِ مُعۡرِضُونَ﴾: أي: تارِكُونَ لِكُلِّ ما لا خَيرَ فِيه مِنَ العَبَثِ."
  23,5,"﴿حَـٰفِظُونَ﴾: أي: ممّا حَرَّم الله مِنَ الزِّنى وسائرِ الفواحِشِ."
  23,7,"﴿ٱبۡتَغَىٰ وَرَآءَ ذَ ٰ⁠لِكَ﴾: طَلَبَ التَّمَتُّعَ بِغَيرِ ما أحَلَّه اللهُ.﴿ٱلۡعَادُونَ﴾: المُجاوِزُونَ حُدَودَ اللهِ."
  23,8,"﴿رَ ٰ⁠عُونَ﴾: حافِظُونَ."
  23,10,"23:9"
  23,11,"﴿ٱلۡفِرۡدَوۡسَ﴾: أعْلى مَنازِلِ الجنَّةِ وأَوسَطَها، وهو أفْضَلُها."
  23,12,"﴿ٱلۡإِنسَـٰنَ﴾: آدَمَ.﴿مِن سُلَـٰلَةࣲ مِّن طِينࣲ﴾: أي: مِن طِينٍ مأخُوذٍ مِن جَمِيعِ الأرضِ."
  23,13,"﴿نُطۡفَةࣰ﴾: هي مَنِيُّ الرَّجُلِ يَقْذِفُه في رَحِمِ امْرَأَتِه.﴿قَرَارࣲ مَّكِينࣲ﴾: مُسْتَقِرٍّ مُتمَكِّنٍ، وهو رَحِمُ المرْأَةِ."
  23,14,"﴿عَلَقَةࣰ﴾: دَمًا أحْمرَ غَلِيظًا.﴿مُضۡغَةࣰ﴾: قِطْعَةَ لَحْمِ قَدْرَ ما يُمَضَغُ.﴿فَكَسَوۡنَا ٱلۡعِظَـٰمَ لَحۡمࣰا﴾: أي: أنْبَتْنا على كُلِّ عَظْمٍ لَحْمًا مُناسِبًا.﴿خَلۡقًا ءَاخَرَ﴾: مُباينًا لِلْأَوَّلِ، وذلِكَ بِنَفْخِ الرُّوحِ فيه بَعْدَ أنْ كانَ جمادًا."
  23,16,"﴿تُبۡعَثُونَ﴾: تُحْيَوْن مِن قُبُورِكُم؛ لَلْحِسابِ."
  23,17,"﴿سَبۡعَ طَرَآئِقَ﴾: سَبْعَ سَمَواتٍ جُعِلَ بعضُها فَوْقَ بَعْضٍ."
  23,18,"﴿بِقَدَرࣲ﴾: أي: بِمِقْدارِ الحاجَةِ.﴿فَأَسۡكَنَّـٰهُ فِي ٱلۡأَرۡضِ﴾: أي: جَعَلْناه مُسْتَقِرًّا فِيها.﴿عَلَىٰ ذَهَابِۭ بِهِۦ﴾: أي: على إذْهابِ هذا الماءِ."
  23,19,"﴿جَنَّـٰتࣲ﴾: بساتِينَ."
  23,20,"﴿وَشَجَرَةࣰ﴾: هي شَجَرَةُ الزَّيتُونِ.﴿طُورِ﴾: هو جَبَلٌ ب «سَيْناءَ».﴿بِٱلدُّهۡنِ﴾: أي: مُلْتَبِسًا ثَمَرُها بالزَّيتِ.﴿وَصِبۡغࣲ﴾: إدامٍ يُغْمَسُ فيه الخُبْزُ."
  23,21,"﴿لَعِبۡرَةࣰ﴾: لَعِظَةً وآيةً على القُدْرَةِ والرَّحْمَةِ."
  23,22,"﴿وَعَلَيۡهَا﴾: أي: وعلى الإبِلِ من الأنعامِ.﴿ٱلۡفُلۡكِ﴾: السُّفُنِ."
  23,24,"﴿ٱلۡمَلَؤُاْ﴾: أشرافُ القومِ وسادَتُهم.﴿أَن يَتَفَضَّلَ﴾: أن يتَرَأَّسَ ويَشْرُفَ عليكم."
  23,25,"﴿جِنَّةࣱ﴾: أي: جُنُونٌ أو مَسٌّ من الجِنِّ.﴿فَتَرَبَّصُواْ﴾: فانْتَظِرُوا.﴿حِينࣲ﴾: أي: وقتٍ مّا."
  23,27,"﴿بِأَعۡيُنِنَا﴾: بِمَرْأىً مِنّا.﴿أَمۡرُنَا﴾: أي: بِعَذابِهم بالطُّوفانِ.﴿وَفَارَ﴾: نَبَعَ الماءُ وخَرَجَ بِقُوَّةٍ.﴿ٱلتَّنُّورُ﴾: هو المكانُ الذي يُخْبزُ فِيه.﴿فَٱسۡلُكۡ﴾: أدْخِلْ.﴿مِن كُلࣲّ﴾: أي: من كُلِّ الأَحْياءِ.﴿زَوۡجَيۡنِ﴾: ذَكَرًا وأنْثى.﴿سَبَقَ عَلَيۡهِ ٱلۡقَوۡلُ﴾: أي: سَبَق القضاءُ بِهلاكِه؛ لِكُفْرِه كزَوْجَتِكَ وابْنِكَ."
  23,28,"﴿ٱسۡتَوَيۡتَ﴾: اعْتَدَلَتْ، أي: بَعْدَ رُكُوبِكَ في السَّفِينةِ.﴿ٱلۡفُلۡكِ﴾: السَّفِينةِ."
  23,29,"﴿مُنزَلࣰا﴾: إنْزِالًا أومَكانَ إنْزالٍ."
  23,30,"﴿لَـَٔايَـٰتࣲ﴾: عِبَرًا وحُجَجًا يُسْتَدَلُّ بها على سُنَنِ اللهِ في أمْثالِ هؤلاءِ مِنَ الكَفَرةِ والمُشْرِكِينَ.﴿وَإِن كُنَّا﴾: وإننا كُنّا.﴿لَمُبۡتَلِينَ﴾: لمُخْتَبِريِنَ الناسَ بهذه الآياتِ."
  23,31,"﴿ثُمَّ أَنشَأۡنَا﴾: أحْدَثْنا وخَلَقْنا.﴿قَرۡنًا ءَاخَرِينَ﴾: جِيلًا آخَرَ: هم قَومُ عادٍ أو قومُ ثمُودَ."
  23,32,"﴿رَسُولࣰا مِّنۡهُمۡ﴾: هو هودٌ أو صالحٌ عليهما الصَّلاةُ والسَّلامُ."
  23,33,"﴿ٱلۡمَلَأُ﴾: الأشْرافُ.﴿بِلِقَآءِ ٱلۡـَٔاخِرَةِ﴾: أي: بِلقاءِ اللهِ يومَ القِيامةِ.﴿وَأَتۡرَفۡنَـٰهُمۡ﴾: جَعَلْناهُم في تَرَفٍ وسَعَةٍ حتّى بَطِرُوا."
  23,34,"﴿لَّخَـٰسِرُونَ﴾: أي: بِتَرْكِكُم آلِهَتَكم واتِّباعِكُم الرسولَ عليه السلام."
  23,35,"﴿مُّخۡرَجُونَ﴾: أي: من قُبُورِكُم أحياءً."
  23,36,"﴿هَيۡهَاتَ﴾: بَعُدَ، أي: ما تُوعدُونَ به أيُّها القومُ.﴿لِمَا تُوعَدُونَ﴾: هو البعثُ بَعْدَ الموتِ."
  23,37,"﴿وَمَا نَحۡنُ بِمَبۡعُوثِينَ﴾: أي: بَعْدَ المماتِ."
  23,38,"﴿إِنۡ هُوَ إِلَّا رَجُلٌ﴾: هو هُودٌ أو صالحٌ عليهما الصَّلاةُ والسَّلامُ.﴿ٱفۡتَرَىٰ﴾: اختَلَقَ.﴿بِمُؤۡمِنِينَ﴾: بِمُصَدِّقِينَ."
  23,40,"﴿عَمَّا قَلِيلࣲ﴾: أي: بَعْدَ زَمَنٍ قَريبٍ."
  23,41,"﴿ٱلصَّيۡحَةُ﴾: صَوْتٌ شَدِيدٌ مُهْلِكٌ.﴿بِٱلۡحَقِّ﴾: أي: يَسْتَحِقُّونَ ذَلك العذابَ؛ لِكُفْرِهم وطُغْيانِهم.﴿فَجَعَلۡنَـٰهُمۡ غُثَآءࣰ﴾: أي: أمْواتًا كَغُثاءِ السَّيلِ الذي يَطْفُو على الماءِ.﴿فَبُعۡدࣰا﴾: أي: عَن رَّحْمَةِ اللهِ."
  23,42,"﴿أَنشَأۡنَا﴾: خلَقْنا وأوْجَدْنا.﴿قُرُونًا ءَاخَرِينَ﴾: أقْوامًا آخَرِينَ مِثْلَ قَوْمِ لُوطٍ وشُعَيبٍ وأيُّوبَ ويونسَ عليهمُ الصَّلاةُ والسَّلامُ."
  23,43,"﴿مَا تَسۡبِقُ﴾: ما تَتَقَدَّمُ.﴿أَجَلَهَا﴾: الوَقْتَ المَحْدُودَ لهلاكِها.﴿وَمَا يَسۡتَـٔۡخِرُونَ﴾: ولا يتأخَّرُونَ."
  23,44,"﴿تَتۡرَا﴾: يَتْبَعُ بعضُهم بَعْضًا.﴿أَحَادِيثَ﴾: أخْبارًا يَتَحَدَّثُ الناسُ بها للعِبْرَةِ وغيرِها.﴿فَبُعۡدࣰا﴾: أي: بُعْدًا عَن رَّحْمَةِ اللهِ."
  23,45,"﴿بِـَٔايَـٰتِنَا﴾: أي: بالمُعْجِزاتِ التِّسْعِ، وهي: العَصا واليدُ البيضاءُ والسِّنونَ المُجْدِبةُ ونَقْصُ الثَّمَراتِ، والطُّوفانُ والجَرادُ والقُمَّلُ والضَّفادِعُ والدَّمُ﴿وَسُلۡطَـٰنࣲ مُّبِينٍ﴾: بُرْهانٍ مُظْهِرٍ لِلْحَقِّ."
  23,46,"﴿وَمَلَإِيْهِۦ﴾: وأشْرافِ قَومِه.﴿عَالِينَ﴾: مُسْتَعْلِينَ على النّاسِ بالبَغْيِ والظُّلْمِ."
  23,47,"﴿لَنَا عَـٰبِدُونَ﴾: أي: مُنْقادُون اْنِقيادَ العَبِيدِ."
  23,49,"23:48"
  23,50,"﴿ءَايَةࣰ﴾: علامةً على عَظِيمِ قُدْرَتِنا.﴿وَءَاوَيۡنَـٰهُمَآ﴾: وجَعَلْنا لَهُما مأْوىً ومْنزِلًا.﴿رَبۡوَةࣲ﴾: بُقْعَةٍ مُرْتَفِعَةٍ.﴿ذَاتِ قَرَارࣲ﴾: أي: فيها أسْبابُ الاسْتِقْرارِ من الزَّرِعِ والثِّمارِ.﴿وَمَعِينࣲ﴾: وماءٍ جارٍ تَسْتَمْتِعُ بِرُؤيَتِه العُيونُ."
  23,51,"﴿مِنَ ٱلطَّيِّبَـٰتِ﴾: مايُسْتَطابُ مِنَ الحَلالِ."
  23,52,"﴿أُمَّتُكُمۡ أُمَّةࣰ﴾: دِينُكُم دِينٌ واحِدٌ وهو دَعْوةُ جَمِيعِ الأنْبِياءِ إلى عِبادَةِ اللهِ وحْدَه لا شَرِيكَ لَه."
  23,53,"﴿فَتَقَطَّعُوٓاْ أَمۡرَهُم بَيۡنَهُمۡ﴾: تَفرَّقَ الأتْباعُ في أمْرِ دِينِهِم.﴿زُبُرࣰا﴾: قِطَعًا وفِرَقًا.﴿فَرِحُونَ﴾: مَسْرُورُونَ."
  23,54,"﴿فَذَرۡهُمۡ﴾: فاتْرُكْهُم.﴿فِي غَمۡرَتِهِمۡ﴾: في غَفْلَتِهِم التي غَمَرَتْهُم وغَطَّتْهم مِن كُلِّ الجِهاتِ.﴿حَتَّىٰ حِينٍ﴾: إلى وقْتِ نُزُولِ العَذاب بِهِم."
  23,55,"﴿أَيَحۡسَبُونَ﴾: أيظُنُّونَ.﴿نُمِدُّهُم﴾: نُعْطِيهِم اسْتِدْراجًا"
  23,57,"﴿مُّشۡفِقُونَ﴾: وجِلُونَ وحَذِرُونَ."
  23,59,"23:58"
  23,60,"﴿يُؤۡتُونَ مَآ ءَاتَواْ﴾: يُعْطُونَ ما أعْطَوا مِنَ الصَّدقاتِ.﴿وَجِلَةٌ﴾: خائِفَةٌ."
  23,62,"23:61"
  23,63,"﴿فِي غَمۡرَةࣲ﴾: في غَفْلَةٍ.﴿مِّن دُونِ ذَ ٰ⁠لِكَ﴾: مِن دُونِ الشِّركِ."
  23,64,"﴿مُتۡرَفِيهِم﴾: مُنَعَّمِيهِم الذين أبْطَرَتْهُم النِّعَمُ.﴿يَجۡـَٔرُونَ﴾: يَصْرُخُونَ مُسْتَغِيثِينَ."
  23,65,"﴿لَا تَجۡـَٔرُواْ﴾: لا تَصْرُخُوا."
  23,66,"﴿تَنكِصُونَ﴾: تَرْجِعُونَ وراءَكُم مُعْرِضِينَ عَنْ سَماعِ الآياتِ."
  23,67,"﴿بِهِۦ سَـٰمِرࣰا﴾: أي: مُتَسامِرِينَ باللَّيلِ حَولَ الكَعْبَةِ.﴿تَهۡجُرُونَ﴾: تَتَكَلَّمُونَ بِساقِطِ القولِ."
  23,68,"﴿أَفَلَمۡ يَدَّبَّرُواْ ٱلۡقَوۡلَ﴾: أفلم يَتَفَكَّرُوا في القرآنِ."
  23,70,"﴿جِنَّةُۢ﴾: جُنُونٌ."
  23,71,"﴿بِذِكۡرِهِمۡ﴾: بالقرآنِ الذي فِيهِ عِزُّهُم وشَرفُهُم."
  23,72,"﴿خَرۡجࣰا﴾: أجْرًا مِنَ المالِ.﴿فَخَرَاجُ رَبِّكَ﴾: ثوابُ اللهِ وعَطاؤُه."
  23,73,"﴿صِرَ ٰ⁠طࣲ مُّسۡتَقِيمࣲ﴾: دِينٍ قَوِيمٍ وهو الإسْلامُ."
  23,74,"﴿لَنَـٰكِبُونَ﴾: لمائِلُونَ ومُنْحَرِفُونَ عَنْه."
  23,75,"﴿مِّن ضُرࣲّ﴾: مِن جَدْبٍ وجُوعٍ.﴿لَّلَجُّواْ﴾: لَتَمادَوا واسْتَمَرُّوا.﴿فِي طُغۡيَـٰنِهِمۡ﴾: في كُفْرِهِم وعِنادِهِم.﴿يَعۡمَهُونَ﴾: يَتَرَدَّدُونَ."
  23,76,"﴿فَمَا ٱسۡتَكَانُواْ﴾: فما خَضَعُوا وما أظْهَرُوا المَسْكَنَةَ.﴿وَمَا يَتَضَرَّعُونَ﴾: وما يَتَذَلَّلُونَ للهِ تعالى بالدُّعاءِ."
  23,77,"﴿مُبۡلِسُونَ﴾: آيِسُونَ مِن كُلِّ خَيرٍ، مُتَحَيِّرُونَ."
  23,79,"﴿ذَرَأَكُمۡ﴾: خَلَقَكُم وبَثَّكُم."
  23,80,"﴿ٱخۡتِلَـٰفُ ٱلَّيۡلِ وَٱلنَّهَارِ﴾: تَعاقُبُهُما وتَفاوُتُهُما."
  23,81,"﴿ٱلۡأَوَّلُونَ﴾: آباؤهُم وأَسْلافُهُم المُتَقَدِّمون."
  23,82,"﴿لَمَبۡعُوثُونَ﴾: أي: من قُبُورِنا أحْياءً."
  23,83,"﴿أَسَـٰطِيرُ ٱلۡأَوَّلِينَ﴾: الأكاذِيبُ الَّتي كَتَبَها المُتَقَدِّمُونَ."
  23,85,"﴿أَفَلَا تَذَكَّرُونَ﴾: أنَّ اللهَ قادِرٌ على البَعْثِ والنُّشُورِ."
  23,87,"﴿أَفَلَا تَتَّقُونَ﴾: أفلا تَخافُونَ عِقابَ اللهِ على كُفْرِكُم وشِرْكِكُم؟"
  23,88,"﴿مَلَكُوتُ كُلِّ شَيۡءࣲ﴾: مالِكُ كُلِّ شَيءٍ والمُتَصَرِّفُ فِيه.﴿يُجِيرُ﴾: يُغِيثُ ويَحْمِي غيرَه.﴿وَلَا يُجَارُ عَلَيۡهِ﴾: ولا يُغِيثُ ولا يَحْمِي أحَدٌ منه أحَدًا."
  23,89,"﴿فَأَنَّىٰ تُسۡحَرُونَ﴾: فَكَيفَ تُصْرَفَونَ عَنِ الحقِّ؟"
  23,90,"﴿لَكَـٰذِبُونَ﴾: أي: في شِرْكِهِم وإنْكارِهِم البَعْثَ."
  23,91,"﴿لَّذَهَبَ كُلُّ إِلَـٰهِۭ بِمَا خَلَقَ﴾: أي: لانْفَردَ كُلُّ مَعْبُودٍ بِمَخْلُوقاتِه.﴿وَلَعَلَا﴾: ولَغَلَبَ.﴿سُبۡحَـٰنَ ٱللَّهِ﴾: تَنَزَّه وتَقَدَّسَ.﴿عَمَّا يَصِفُونَ﴾: أي: من كَذِبِهِم وبُهْتانِهِم بِأَنَّ له شَرِيكًا أوْ ولَدًَا."
  23,92,"﴿وَٱلشَّهَـٰدَةِ﴾: وما يُشاهَدُ."
  23,93,"﴿مَا يُوعَدُونَ﴾: أي: مِنَ العَذابِ."
  23,95,"23:94"
  23,96,"23:94"
  23,97,"﴿هَمَزَ ٰ⁠تِ﴾: نَزَغاتٍ ووَساوِسَ."
  23,98,"﴿أَن يَحۡضُرُونِ﴾: أي: مِن حُضُورِ الشَّياطِينِ في أُمُورِي."
  23,99,"﴿ٱرۡجِعُونِ﴾: رُدُّوني إلى الدُّنيا."
  23,100,"﴿هُوَ قَآئِلُهَا﴾: يَقُولُها باللِّسانِ ولا يَعْمَلُ بِمُقْتَضاها.﴿بَرۡزَخٌ﴾: هو الحاجِزُ الَّذي بين الموتِ والبَعْثِ."
  23,101,"﴿ٱلصُّورِ﴾: القَرْنِ الذي يُنفَخُ فيه للَبعْثِ.﴿فَلَآ أَنسَابَ بَيۡنَهُمۡ﴾: أي: فلا تَنْفَعُهم أنْسابُهم، ولا يَتَفاخَرُونَ بها مِن هَوْلِ الموْقِفِ.﴿وَلَا يَتَسَآءَلُونَ﴾: أي: لا يَسْأَلُ أحَدٌ أحَدًا."
  23,102,"﴿ثَقُلَتۡ مَوَ ٰ⁠زِينُهُۥ﴾: أي: بِكَثْرةِ حسناتِهِ.﴿ٱلۡمُفۡلِحُونَ﴾: الفائِزُونَ بالجنَّةِ والنَّجاةِ مِنَ النّارِ."
  23,103,"﴿خَفَّتۡ مَوَ ٰ⁠زِينُهُۥ﴾: أي: قَلَّتْ أعْمالُه الصّالِحَةُ.﴿خَسِرُوٓاْ أَنفُسَهُمۡ﴾: أي: ضَيَّعُوها."
  23,104,"﴿تَلۡفَحُ﴾: تَحْرِقُ.﴿كَـٰلِحُونَ﴾: عابِسُونَ تَقَلَّصَتْ شِفاهُهُم عن أسْنانِهِم؛ مِن إحْراقِ النّارِ وُجُوهَهُم."
  23,105,"﴿ءَايَـٰتِي﴾: أي: آياتُ القُرآن."
  23,106,"﴿شِقۡوَتُنَا﴾: هي المَلَذّاتُ والشَّهَواتُ التي كُتِبَتْ عَلَينا في سابِقِ عِلْمِكَ وساقَتْنا إلى الشِّقاءِ."
  23,107,"﴿فَإِنۡ عُدۡنَا﴾: فَإن رَّجَعْنا إلى الضَّلالِ."
  23,108,"﴿ٱخۡسَـُٔواْ فِيهَا﴾: امْكُثُوا في النّارِ أذِلّاءَ صاغِرِينَ."
  23,110,"﴿سِخۡرِيًّا﴾: مَهْزُوءًا بهم."
  23,112,"23:111"
  23,113,"﴿ٱلۡعَآدِّينَ﴾: أي: المُتَمَكِّنِينَ مِن مَّعْرِفَةِ العَدَدِ مِنَ الملائِكَةِ أو مِنَ النّاسِ."
  23,115,"﴿عَبَثࣰا﴾: لَعِبًا مِن غَيرِ فائِدةٍ ولاحِكْمَةٍ."
  23,116,"﴿ٱلۡمَلِكُ﴾: الَّذي يَحِقُّ لَهُ المُلْكُ على الإطْلاقِ﴿ٱلۡحَقُّ﴾: الثّابِتُ الَّذي لا يَزُولُ.﴿ٱلۡعَرۡشِ﴾: هو سَرِيرُ المُلْكِ الَّذي اسْتَوى عليه الرَّحمنُ، وتَحْمِلُه الملائِكةُ، وهو أعْظَمُ المَخْلُوقاتِ، وهو سَقْفُ الجنَّةِ."
  23,118,"23:117"
