tafsir[71]{c,v,t}:
  27,1,"﴿طسٓ﴾: تَقَدَّمَ الكلامُ على مِثْلِه أوَّلَ سُورَةِ البقرةِ."
  27,3,"27:2"
  27,4,"﴿يَعۡمَهُونَ﴾: يَتَرَدَّدُونَ ويَتَحَيَّرُونَ."
  27,6,"27:5"
  27,7,"﴿ءَانَسۡتُ﴾: أبْصَرْتُ ما يُؤْنِسُ.﴿بِشِهَابࣲ قَبَسࣲ﴾: بِشُعْلَةِ نارٍ مَقْبُوسَةٍ، أي: مأخُوذَةٍ.﴿تَصۡطَلُونَ﴾: تَسْتَدْفِئُونَ بِها."
  27,8,"﴿بُورِكَ مَن فِي ٱلنَّارِ﴾: أي: إنّ اللهَ باركَ مَن فِي النّارِ ومَن حَولَها مِنَ الملائِكَةِ."
  27,10,"﴿تَهۡتَزُّ﴾: تَتَحَرَّكُ بخِفَّةٍ.﴿جَآنࣱّ﴾: حَيَّةٌ خَفِيفَةٌ في سُرْعَةِ حَرَكَتِها.﴿وَلَّىٰ﴾: هرَبَ.﴿وَلَمۡ يُعَقِّبۡ﴾: لم يَرْجِعْ."
  27,12,"﴿فِي جَيۡبِكَ﴾: في فَتْحَةِ قَمِيصِكَ الَّتي يُدْخَلُ منها الرَّأسُ.﴿مِنۡ غَيۡرِ سُوٓءࣲ﴾: مِن غَيرِ بَرَصٍ ولا مَرَضٍ.﴿فِي تِسۡعِ ءَايَـٰتٍ﴾: وهي: اليدُ، والعَصا، والسِّنونَ، ونَقْصُ الثَّمراتِ، والطُّوفانُ، والجَرادُ، والقُمَّلُ، والضَّفادِعُ، والدَّمُ."
  27,13,"﴿مُبۡصِرَةࣰ﴾: واضِحَةً هادِيةً."
  27,14,"﴿وَجَحَدُواْ بِهَا﴾: أنْكَرُوها بألْسِنَتِهِم.﴿وَعُلُوࣰّا﴾: تَرَفُّعًا واسْتِكْبارًا عَنِ الإيمانِ بِها."
  27,16,"﴿وَوَرِثَ سُلَيۡمَـٰنُ دَاوُۥدَ﴾: أي: نُبوَّتَه وعِلْمَه ومُلْكَه.﴿مَنطِقَ ٱلطَّيۡرِ﴾: فَهْمَ أغْراضِه كلِّها مِن أصْواتِه.﴿وَأُوتِينَا﴾: وأُعْطِينا."
  27,17,"﴿وَحُشِرَ﴾: وجُمِعَ.﴿فَهُمۡ يُوزَعُونَ﴾: فهم يُكَفُّونَ عَنِ التَّفرُّقِ، فكان على كُلِّ جِنْسٍ مَن يَرُدُّ أوَّلَهم على آخِرِهم كي يقِفُوا ويسِيرُوا مُنْتَظِمِينَ."
  27,18,"﴿لَا يَحۡطِمَنَّكُمۡ﴾: أي: لا تُمَكِّنوهُم مِن قَتْلِكُم وإهْلاكِكُم."
  27,19,"﴿أَوۡزِعۡنِيٓ﴾: ألْهِمْنِي ووَفِّقْنِي."
  27,21,"﴿بِسُلۡطَـٰنࣲ مُّبِينࣲ﴾: بِحُجَّةٍ تُبيِّنُ عُذْرَه في غِيابِه."
  27,22,"﴿أَحَطتُ﴾: عَلِمْتُ الأمرَ مِن جَميعِ جِهاتِهِ.﴿وَجِئۡتُكَ﴾: بَلَدٍ باليمنِ سُمِّي باسْمِ «سَبأِ بنِ يَشْجُبَ»،ويقَعُ شَرْقَ صَنْعاء ويُسَمّى الآنَ «مَأْرِبًا»."
  27,23,"﴿وَلَهَا عَرۡشٌ﴾: أي: سَرِيرُ المُلْكِ، تَجْلِسُ عليه لإدارةِ مُلْكِها."
  27,24,"﴿فَصَدَّهُمۡ﴾: فَصَرَفَهُم."
  27,25,"﴿ٱلۡخَبۡءَ﴾: المخْبوُءَ المسْتُورَ."
  27,27,"﴿سَنَنظُرُ﴾: أي: سَنَتَأَمَّلُ."
  27,28,"﴿تَوَلَّ عَنۡهُمۡ﴾: تَنَحَّ عَنْهُم."
  27,30,"27:29"
  27,31,"﴿أَلَّا تَعۡلُواْ﴾: ألّا تَتَكَبَّرُوا عليَّ."
  27,32,"﴿يَـٰٓأَيُّهَا ٱلۡمَلَؤُاْ﴾: يا أيُّها الأشْرافُ.﴿أَفۡتُونِي﴾: أشِيرُوا عَليَّ.﴿قَاطِعَةً أَمۡرًا﴾: مُبْرِمَةً أمْرًا.﴿تَشۡهَدُونِ﴾: تَحْضُرُونِ."
  27,33,"﴿وَأُوْلُواْ بَأۡسࣲ﴾: أصْحابُ نَجْدةٍ وبَلاءٍ في الحرْبِ."
  27,35,"﴿فَنَاظِرَةُۢ﴾: فمُنتَظِرةٌ."
  27,37,"﴿لَّا قِبَلَ لَهُم بِهَا﴾: لا طاقَةَ لَهُم بِمُقاوَمَتِها.﴿صَـٰغِرُونَ﴾: ذَلِيلُونَ مُهانُونَ."
  27,39,"﴿عِفۡرِيتࣱ﴾: مارِدٌ قويٌّ شَدِيدٌ."
  27,40,"﴿أَن يَرۡتَدَّ﴾: أن يَرْجِعَ.﴿طَرۡفُكَ﴾: نَظَرُكَ.﴿لِيَبۡلُوَنِيٓ﴾: لِيَخْتَبِرَنِي.﴿أَمۡ أَكۡفُرُ﴾: أي: بِتَرْكِ شُكْرِ النِّعْمةِ."
  27,41,"﴿نَكِّرُواْ﴾: غيِّرُوا."
  27,42,"﴿وَأُوتِينَا ٱلۡعِلۡمَ﴾: وأُعْطِينا العِلْمَ بِاللهِ وبِقُدْرَتِه."
  27,44,"﴿ٱلصَّرۡحَ﴾: القَصْرَ.﴿حَسِبَتۡهُ لُجَّةࣰ﴾: ظنَّتْهُ ماءً تتردَّدُ أمْواجُه.﴿مُّمَرَّدࣱ﴾: أمْلَسُ.﴿مِّن قَوَارِيرَ﴾: مِن زُجاجٍ صافٍ شَفّافٍ."
  27,45,"﴿يَخۡتَصِمُونَ﴾: يَتَنازَعُونَ."
  27,46,"﴿بِٱلسَّيِّئَةِ قَبۡلَ ٱلۡحَسَنَةِ﴾: أي: بالكُفْرِ قَبْلَ الإيمانِ."
  27,47,"﴿ٱطَّيَّرۡنَا بِكَ﴾: تَشاءَمْنا بِكَ، لأنّنا أُصِبْنا بالشَّدائِدِ.﴿طَـٰٓئِرُكُمۡ﴾: شُؤْمُكُم.﴿عِندَ ٱللَّهِ﴾: أي: قَدَّرَهُ اللهُ عَلَيكُم.﴿تُفۡتَنُونَ﴾: تُمتَحَنُونَ وتُخْتَبرُونَ."
  27,48,"﴿رَهۡطࣲ﴾: رِجالٍ مِن أبْناءِ الأشْرافِ."
  27,49,"﴿تَقَاسَمُواْ بِٱللَّهِ﴾: تحالَفُوا باللهِ.﴿لَنُبَيِّتَنَّهُۥ﴾: لَنَأْتِيَنَّهُ بَغْتَةً في الليلِ، فَنْقتُلَهُ.﴿مَا شَهِدۡنَا﴾: ما حَضَرْنا."
  27,50,"﴿وَمَكَرُواْ﴾: دبَّرُوا الشَّرَّ بِحِيلَةٍ."
  27,51,"﴿دَمَّرۡنَـٰهُمۡ﴾: أهْلكْناهُم."
  27,52,"﴿خَاوِيَةَۢ﴾: خالِيةً خَرِبةً."
  27,54,"27:53"
  27,55,"27:53"
  27,56,"﴿يَتَطَهَّرُونَ﴾: يَتَنَزَّهُونَ مِن إتْيانِ الرِّجالِ."
  27,57,"﴿مِنَ ٱلۡغَـٰبِرِينَ﴾: مِنَ الباقِينَ في العَذابِ والهَلاكِ."
  27,59,"﴿ٱصۡطَفَىٰٓ﴾: اخْتارَ."
  27,60,"﴿حَدَآئِقَ ذَاتَ بَهۡجَةࣲ﴾: بَساتِينَ ذاتَ مَنظَرٍ حَسَنٍ.﴿يَعۡدِلُونَ﴾: يَنْحَرِفُونَ عَن طَرِيقِ الحقِّ إلى طَرِيقِ الباطِلِ وهو الشِّركُ."
  27,61,"﴿قَرَارࣰا﴾: مُسْتَقَرًّا.﴿خِلَـٰلَهَآ﴾: وسَطَها.﴿رَوَ ٰ⁠سِيَ﴾: جِبالًا ثَوابِتَ.﴿ٱلۡبَحۡرَيۡنِ﴾: العَذْبِ والمِلْحِ.﴿حَاجِزًا﴾: فاصِلًا يَمْنَعُ اخْتِلاطَهُما."
  27,62,"﴿ٱلۡمُضۡطَرَّ﴾: الَّذي أصابَه بَلاءٌ وشِدَّةٌ.﴿خُلَفَآءَ﴾: أي: تَخْلُفُونَ مَن سَبَقَكُم في الأرضِ."
  27,63,"﴿بُشۡرَۢا﴾: تُبَشِّرُ بالمَطَرِ."
  27,64,"﴿يَبۡدَؤُاْ ٱلۡخَلۡقَ﴾: يُنْشِئُه.﴿بُرۡهَـٰنَكُمۡ﴾: حُجَّتَكُم."
  27,65,"﴿أَيَّانَ يُبۡعَثُونَ﴾: مَتى يُبْعثُونَ مِن قُبُورِهِم."
  27,66,"﴿بَلِ ٱدَّ ٰ⁠رَكَ عِلۡمُهُمۡ فِي ٱلۡـَٔاخِرَةِ﴾: بَلْ تَكامَلَ علمُهُم بِها عِنْدَما بُعِثُوا يومَ القيامةِ.﴿فِي شَكࣲّ مِّنۡهَا﴾: أي: مِنَ الآخِرةِ في الدُّنيا.﴿عَمُونَ﴾: أي: غافِلُونَ، فَقُلُوبُهُم عَمْياءُ."
  27,67,"﴿لَمُخۡرَجُونَ﴾: لمَبْعُوثُونَ مِن قُبُورِنا."
  27,68,"﴿أَسَـٰطِيرُ ٱلۡأَوَّلِينَ﴾: الأكاذيبُ الَّتي كَتَبها المتقدِّمُونَ."
  27,70,"﴿ضَيۡقࣲ﴾: حَرَجٍ وضِيقِ صَدْرٍ."
  27,72,"﴿رَدِفَ لَكُم﴾: لَحِقَكُم، أو اقْتَرَبَ لَكُم."
  27,74,"﴿مَا تُكِنُّ﴾: ما تُخْفِي.﴿وَمَا يُعۡلِنُونَ﴾: وما يُظْهِرُونَ."
  27,75,"﴿غَآئِبَةࣲ﴾: هو ما يَغيبُ ويَخْفى عَلى الخَلْقِ.﴿مُّبِينٍ﴾: واضِحٍ."
  27,77,"27:76"
  27,78,"27:76"
  27,79,"27:76"
  27,80,"﴿مُدۡبِرِينَ﴾: مُعْرِضِينَ."
  27,82,"﴿وَقَعَ ٱلۡقَوۡلُ﴾: أي: وجَبَ العَذابُ.﴿دَآبَّةࣰ﴾: هي مِن أشْراطِ السّاعةِ الكُبْرى.﴿تُكَلِّمُهُمۡ﴾: تُحدِّثُهُم.﴿لَا يُوقِنُونَ﴾: لا يُصَدِّقُونَ."
  27,83,"﴿نَحۡشُرُ﴾: نَجْمَعُ.﴿فَهُمۡ يُوزَعُونَ﴾: فهم يُكَفُّونَ عَنِ التَّفَرُّقِ، فكان على كُلِّ جِنْسٍ مَن يَرُدُّ أوَّلَهم على آخِرِهِم ثُمَّ يُساقُون جميعًا."
  27,85,"27:84"
  27,86,"27:84"
  27,87,"﴿ٱلصُّورِ﴾: القَرْنِ الَّذي يُنفَخُ فيهِ للبَعْثِ.﴿فَفَزِعَ﴾: خافَ خَوْفًا شَدِيدًا مِن هَوْلِ النَّفخَةِ.﴿دَ ٰ⁠خِرِينَ﴾: صاغِرِينَ مُطِيعِينَ."
  27,88,"﴿تَحۡسَبُهَا جَامِدَةࣰ﴾: تَظُنُّها ثابِتةً في أماكِنِها.﴿مَرَّ ٱلسَّحَابِ﴾: مِثْلَ السَّحابِ الَّذي تُسَيِّرُه الرِّياحُ."
  27,90,"﴿فَكُبَّتۡ وُجُوهُهُمۡ فِي ٱلنَّارِ﴾: أي: أُلقُوا على وُجُوهِهِم فِيها."
  27,91,"﴿حَرَّمَهَا﴾: جَعَلها حَرَمًا آمِنًا لا يُسْفَكُ فيها دَمٌ."
  27,93,"27:92"
