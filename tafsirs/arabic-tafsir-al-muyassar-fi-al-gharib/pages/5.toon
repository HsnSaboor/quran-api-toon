tafsir[104]{c,v,t}:
  5,1,"﴿أَوۡفُواْ بِٱلۡعُقُودِ﴾: أتِمُّوا عهودَ اللهِ الموَثَّقَةَ.﴿ٱلۡأَنۡعَـٰمِ﴾: الإبِلِ، والبَقَرِ، والغَنَمِ.﴿إِلَّا مَا يُتۡلَىٰ عَلَيۡكُمۡ﴾: إلا ما نَصَّ الله على تحريمِه كالميتةِ، ولحمِ الخِنْزيرِ.﴿غَيۡرَ مُحِلِّي ٱلصَّيۡدِ﴾: أُحِلَّتْ لكم الأنعامُ حالَ تحريمِ الصيدِ عليكم.﴿وَأَنتُمۡ حُرُمٌ﴾: بدخولِكم في الإحرامِ بالحجِّ أوالعُمرةِ."
  5,2,"﴿لَا تُحِلُّواْ﴾: لا يَقَعْ منكم الإخلالُ.﴿شَعَـٰٓئِرَ ٱللَّهِ﴾: جَمْعُ شَعيرةٍ، وهي حُرُماتُه، ومعالمُه.﴿وَلَا ٱلشَّهۡرَ ٱلۡحَرَامَ﴾: لا تَسْتَحِلُّوا القتالَ في الأشهرِ الحُرُم وهي: ذو القِعْدةِ وذو الحِجَّةِ والمحرمُ ورَجَبٌ.﴿وَلَا ٱلۡهَدۡيَ﴾: ولا تَسْتَحِلُّوا أن تأخذُوا ما أهداه المرءُ من الأنعامِ إلى بيتِ اللهِ، أو تَحُولُوا بينَه وبينَ المكانِ الذي يُهدى إليه.﴿وَلَا ٱلۡقَلَـٰٓئِدَ﴾: بأن تُؤْخَذَ غَصْبًا، و هي ضفائرُ صوفٍ يَضَعُونها في رَقَبَةِ البَهيمةِ علامةً على أنها هَدْيٌ.﴿وَلَآ ءَآمِّينَ ٱلۡبَيۡتَ ٱلۡحَرَامَ﴾: ولا تَسْتَحِلُّوا قتالَ قاصدي البيتِ الحرامِ.﴿حَلَلۡتُمۡ﴾: من إحرامِكم.﴿وَلَا يَجۡرِمَنَّكُمۡ﴾: ولا يَحْمِلَنَّكم.﴿شَنَـَٔانُ﴾: بُغْضُ.﴿أَن صَدُّوكُمۡ﴾: لأَجْل صَدِّهم إياكم.﴿ٱلۡبِرِّ﴾: العمل بِما أمَرَ اللهُ بالعملِ به.﴿وَٱلتَّقۡوَىٰ﴾: اجتنابِ ما أمرَ اللهُ باجتنابِه.﴿ٱلۡإِثۡمِ﴾: هوكلُّ فِعْلٍ أو قولٍ يُوجِبُ الذَّنْبَ.﴿وَٱلۡعُدۡوَ ٰ⁠نِ﴾: التعَدِّي على الناسِ بما فيه ظُلْمٌ."
  5,3,"﴿ٱلۡمَيۡتَةُ﴾: الحيَوانُ الذي تُفارِقُه الحياةُ من دونِ ذَبْحٍ.﴿وَٱلدَّمُ﴾: أي: السائلُ.﴿وَمَآ أُهِلَّ لِغَيۡرِ ٱللَّهِ﴾: ما ذُكِرَ عليه غيرُ اسمِ اللهِ عند الذَّبْحِ.﴿وَٱلۡمُنۡخَنِقَةُ﴾: التي حُبِسَ نَفَسُها حتى ماتَتْ.﴿وَٱلۡمَوۡقُوذَةُ﴾: التي ضُرِبَتْ بعصا أو حَجَرٍ حتى ماتَتْ.﴿وَٱلۡمُتَرَدِّيَةُ﴾: التي سَقطَتْ من مكانٍ عالٍ، فماتَتْ.﴿وَٱلنَّطِيحَةُ﴾: التي نَطَحَتْها شاةٌ أو بقرةٌ، فماتَتْ.﴿ٱلسَّبُعُ﴾: كالأسدِ والنَّمِرِ.﴿ذَكَّيۡتُمۡ﴾: ذَبَحْتُم قبلَ أن يموتَ، فهو حَلالٌ.﴿ٱلنُّصُبِ﴾: حجارةٍ كان المشركونَ يذْبحون عليها في الجاهليةِ تَقَرُّبًا إلى الأصنامِ.﴿وَأَن تَسۡتَقۡسِمُواْ بِٱلۡأَزۡلَـٰمِ﴾: القِداحِ التي كانوا يَطْلُبون بها عِلْمَ ما قُسِمَ لهم.﴿فِسۡقٌ﴾: خُروجٌ عن طاعةِ اللهِ.﴿ٱلۡيَوۡمَ﴾: يومَ فتحِ مكةَ في السنةِ الثامنةِ من الهجرة.﴿نِعۡمَتِي﴾: بإكمالِ الدين، وفتحِ مكةَ، وقَهْرِ الكُفّارِ.﴿مَخۡمَصَةٍ﴾: مَجاعةٍ.﴿مُتَجَانِفࣲ﴾: مائلٍ.﴿لِّإِثۡمࣲ﴾: حَرامٍ."
  5,4,"﴿وَمَا عَلَّمۡتُم﴾: أي: صَيْدُ ما دَرَّبْتُموه من الكِلابِ ونحوِها.﴿مُكَلِّبِينَ﴾: جَمْعُ مُكَلِّبٍ، وهو مُعَلِّمُ الكِلابِ طريقةَ الاصطيادِ."
  5,5,"﴿وَٱلۡمُحۡصَنَـٰتُ﴾: أي: ونكاحُ الحَرائرِ من النساءِ المؤمناتِ.﴿أُجُورَهُنَّ﴾: مُهورَهُنَّ.﴿مُحۡصِنِينَ﴾: أعِفّاءَ.﴿غَيۡرَ مُسَـٰفِحِينَ﴾: غيرمرتكبين للزِّنى.﴿أَخۡدَانࣲ﴾: عشيقاتٍ يَزْنُون بهنَّ سِرًّا.﴿حَبِطَ﴾: بَطَلَ."
  5,6,"﴿إِذَا قُمۡتُمۡ﴾: إذا أرَدْتُم القيامَ، وأنتم على غير طُهْرٍ.﴿ٱلۡمَرَافِقِ﴾: جمعُ مِرْفَقٍ، وهو المِفْصَلُ الذي بينَ الذِّراعِ والعَضُدِ.﴿وَأَرۡجُلَكُمۡ﴾: واغسِلُوا أرجُلَكم.﴿إِلَى ٱلۡكَعۡبَيۡنِ﴾: هما العَظْمان البارِزان عند مُلْتقى السّاقِ بالقَدَمِ.﴿فَٱطَّهَّرُواْ﴾: بالاغتسالِ.﴿مِّنَ ٱلۡغَآئِطِ﴾: من قَضاءِ الحاجةِ.﴿لَـٰمَسۡتُمُ ٱلنِّسَآءَ﴾: جامَعْتُموهُنَّ.﴿فَتَيَمَّمُواْ صَعِيدࣰا﴾: فاضرِبُوا بأيدِيكم وجهَ الأرضِ.﴿حَرَجࣲ﴾: ضِيقٍ."
  5,7,"﴿نِعۡمَةَ ٱللَّهِ عَلَيۡكُمۡ﴾: بهدايتِكم للإسلامِ.﴿وَمِيثَـٰقَهُ﴾: وعَهْدَه الذي أخَذَه عليكم حين بايَعْتم الرسولَ ﷺ على السَّمْعِ والطاعةِ."
  5,8,"﴿قَوَّ ٰ⁠مِينَ﴾: أي بالحقِّ ابتغاءَ وجهِ اللهِ.﴿شُهَدَآءَ بِٱلۡقِسۡطِ﴾: تَشْهَدون بالعدلِ.﴿وَلَا يَجۡرِمَنَّكُمۡ﴾: ولا يَحْمِلَنَّكم.﴿شَنَـَٔانُ﴾: عَداوةُ."
  5,10,"5:9"
  5,11,"﴿هَمَّ﴾: عَزَمَ.﴿أَن يَبۡسُطُوٓاْ إِلَيۡكُمۡ أَيۡدِيَهُمۡ﴾: أنَ يبْطِشَ يهودُ بني النَّضِيرِ بكم، يومَ سار إليهم الرسولُ ﷺ ونَفَرٌ من أصحابِه في شأنٍ معهم.﴿فَكَفَّ﴾: فصَرَفَ."
  5,12,"﴿مِيثَـٰقَ﴾: العهدَ المؤكَّدَ بالوفاءِ به.﴿ٱثۡنَيۡ عَشَرَ نَقِيبࣰا﴾: عَريفًا من كبارِ القومِ، بعَددِ فروعِهم، يأخُذُون عليهم العهدَ.﴿وَعَزَّرۡتُمُوهُمۡ﴾: ونَصَرْتُموهم، وعَظَّمتُموهم.﴿وَأَقۡرَضۡتُمُ ٱللَّهَ﴾: وأنْفَقْتم في سبيلهِ.﴿ضَلَّ سَوَآءَ ٱلسَّبِيلِ﴾: أخطأ وسَطَ طريقِ الحقِّ."
  5,13,"﴿فَبِمَا﴾: فبسببِ.﴿لَعَنَّـٰهُمۡ﴾: طَرَدْناهم مِن رحمتِنا.﴿قَـٰسِيَةࣰ﴾: غليظةً لا تَعِي خيرًا.﴿ٱلۡكَلِمَ﴾: التوراةَ.﴿وَنَسُواْ حَظࣰّا﴾: تَرَكُوا قَدْرًا مِمّا أُمِرُوا به.﴿وَلَا تَزَالُ تَطَّلِعُ عَلَىٰ خَآئِنَةࣲ مِّنۡهُمۡ﴾: ولا تزال  أيها الرسولُ  تَقِفُ من اليهودِ على خيانةٍ، وغَدْرٍ."
  5,14,"﴿مِيثَـٰقَهُمۡ﴾: العهدَ المؤكَّدَ على طاعتي﴿فَأَغۡرَيۡنَا﴾: فأَلْقَيْنا.﴿بَيۡنَهُمُ﴾: بينَ النصارى، فكلُّ فِرْقَةٍ تُعادي صاحبتَها."
  5,15,"﴿رَسُولُنَا﴾: محمدٌ ﷺ.﴿مِّمَّا كُنتُمۡ تُخۡفُونَ﴾: كالرَّجْمِ للزّاني.﴿وَيَعۡفُواْ عَن كَثِيرࣲ﴾: ممّا تُخْفُونه، فيَتْرُكُ بيانَه.﴿نُورࣱ﴾: محمدٌ ﷺ.﴿وَكِتَـٰبࣱ﴾: القرآنُ الكريمُ."
  5,16,"﴿سُبُلَ ٱلسَّلَـٰمِ﴾: طريقَ اللهِ الذي شَرَعَه.﴿صِرَ ٰ⁠طࣲ مُّسۡتَقِيمࣲ﴾: طريقٍ لاعِوَجَ فيه."
  5,17,"﴿فَمَن يَمۡلِكُ مِنَ ٱللَّهِ شَيۡـًٔا﴾: فمَنِ الذي يَقْدِرُ أن يمنعَ من أمْرِ اللهِ؟"
  5,18,"﴿نَحۡنُ أَبۡنَـٰٓؤُاْ ٱللَّهِ﴾: فقالت اليهودُ: عزيرٌ ابنُ اللهِ، وقالت النصارى: المسيحُ ابنُ اللهِ.﴿أَنتُم بَشَرࣱ﴾: أنتم خَلْقٌ مثلُ سائرِ بني آدمَ يحاسبُهم على أعمالهم.﴿ٱلۡمَصِيرُ﴾: المَرْجِعُ."
  5,19,"﴿رَسُولُنَا﴾: محمدٌ ﷺ﴿عَلَىٰ فَتۡرَةࣲ مِّنَ ٱلرُّسُلِ﴾: على انقطاعٍ من الرسلِ مُدّةً من الزمانِ.﴿أَن تَقُولُواْ﴾: لئلّا تقُولوا."
  5,20,"﴿وَجَعَلَكُم مُّلُوكࣰا﴾: وجْهُ الامتنانِ كثرةُ الملوكِ والأنبياءِ فيهم، أو أنكم تملكون أمرَكم بعد أن كنتم مملوكين لفرعونَ.﴿مِّنَ ٱلۡعَـٰلَمِينَ﴾: عالَمِي زمانِكم."
  5,21,"﴿ٱلۡأَرۡضَ ٱلۡمُقَدَّسَةَ﴾: المطهَّرَةَ المباركةَ، وهي بيتُ المَقْدِسِ وما حولَها.﴿وَلَا تَرۡتَدُّواْ عَلَىٰٓ أَدۡبَارِكُمۡ﴾: ولا تَرْجِعُوا عن قتالِ الأشدّاء."
  5,22,"﴿جَبَّارِينَ﴾: أشدّاءَ، لاطاقَةَ لنا بحَرْبِهم."
  5,23,"﴿يَخَافُونَ﴾: أي: اللهَ.﴿ٱدۡخُلُواْ عَلَيۡهِمُ ٱلۡبَابَ﴾: ادخُلوا على هؤلاءِ الأشدّاءِ بابَ مدينتِهم."
  5,24,"﴿لَن نَّدۡخُلَهَآ﴾: لن نَدْخُلَ مدينةَ الجبّارين."
  5,25,"﴿لَآ أَمۡلِكُ﴾: لا أقْدِرُ أن أحملَ أحدًا على ما أُحِبُّ.﴿فَٱفۡرُقۡ﴾: فاقضِ﴿ٱلۡفَـٰسِقِينَ﴾: الخارجينَ عن طاعةِ اللهِ."
  5,26,"﴿فَإِنَّهَا﴾: الأرضَ المقدسةَ.﴿فَلَا تَأۡسَ﴾: فلاتحزَنْ."
  5,27,"﴿ٱبۡنَيۡ ءَادَمَ﴾: قابيلَ، وهابيلَ.﴿قَرَّبَا قُرۡبَانࣰا﴾: قَدَّما ما يُتَقَرَّبُ به إلى اللهِ.﴿أَحَدِهِمَا﴾: هابيل."
  5,29,"﴿تَبُوٓأَ بِإِثۡمِي﴾: تَرْجِعَ حاملًا ذَنْبَ قَتْلي.﴿وَإِثۡمِكَ﴾: الذي صار عليك بذنوبِك من قَبْلِ قَتْلي."
  5,30,"﴿فَطَوَّعَتۡ﴾: فشَجَّعَتْ."
  5,31,"﴿يَبۡحَثُ﴾: يَحْفِرُ حُفْرَةً.﴿سَوۡءَةَ﴾: ما تسوءُ رؤيتُه، وهو الجَسَدُ المتغيِّرُ.﴿فَأُوَ ٰ⁠رِيَ﴾: فأَسْتُرَ."
  5,32,"﴿مِنۡ أَجۡلِ ذَ ٰ⁠لِكَ﴾: بسببِ جنايةِ القَتْلِ.﴿بِغَيۡرِ نَفۡسٍ﴾: تُوجِبُ القِصاصَ.﴿فَسَادࣲ﴾: مُوجِبٍ للقَتْلِ.﴿لَمُسۡرِفُونَ﴾: لمتجاوِزُون حُدودَ الله."
  5,33,"﴿أَوۡ يُصَلَّبُوٓاْ﴾: بأن يُشَدَّ الجاني على خَشَبةٍ.﴿مِّنۡ خِلَـٰفٍ﴾: بقَطْعِ يُمنى اليدَيْن مع يُسْرى الرِّجْلَين، أو يُسرى اليدين مع يُمنى الرِّجْلَين.﴿أَوۡ يُنفَوۡاْ﴾: أو يُنْفَوا إلى بلدٍ غيرِ بلدِهم، ويُحْبَسُوا.﴿خِزۡيࣱ﴾: ذُلٌّ."
  5,35,"﴿ٱلۡوَسِيلَةَ﴾: مايُتَقَرَّبُ به إلى اللهِ بطاعتِه."
  5,36,"﴿وَمِثۡلَهُۥ﴾: ومَلكُوا مِثْلَه."
  5,37,"﴿مُّقِيمࣱ﴾: دائمٌ."
  5,38,"﴿نَكَـٰلࣰا﴾: عقوبةً."
  5,39,"﴿ظُلۡمِهِۦ﴾: سَرِقَتِه."
  5,41,"﴿فِي ٱلۡكُفۡرِ﴾: في إنكارِ نبوَّتِك.﴿ءَامَنَّا بِأَفۡوَ ٰ⁠هِهِمۡ﴾: هم المنافقون.﴿وَمِنَ ٱلَّذِينَ هَادُواْ﴾: لا يَحْزُنْك تَسَرُّعُ اليهودِ إلى إنكارِ نبوَّتِكِ.﴿لِلۡكَذِبِ﴾: مايفْتَريه أحبارُ اليهودِ.﴿لَمۡ يَأۡتُوكَ﴾: لم يَحْضُروا مجلسَك تَكَبُّرًا.﴿ٱلۡكَلِمَ﴾: التوراةَ، هي جمعُ «كلمة».﴿مِنۢ بَعۡدِ مَوَاضِعِهِۦ﴾: من بعدِ ما عَقَلُوه موضوعًا في مواضِعِه.﴿أُوتِيتُمۡ هَـٰذَا﴾: إنْ جاءكم محمدٌ ﷺ بما يُوافِقُ الحكمَ الذي بَدَّ لْناه من أحكامِ التوراةِ.﴿فِتۡنَتَهُۥ﴾: ضَلالتَه.﴿فَلَن تَمۡلِكَ﴾: فلن تستطيعَ دَفْعَ ذلك.﴿خِزۡيࣱ﴾: ذُلٌّ."
  5,42,"﴿لِلسُّحۡتِ﴾: للمال الحَرامِ كالرَّشوة.﴿بِٱلۡقِسۡطِ﴾: بالعدلِ.﴿ٱلۡمُقۡسِطِينَ﴾: العادِلين."
  5,43,"﴿يَتَوَلَّوۡنَ مِنۢ بَعۡدِ ذَ ٰ⁠لِكَ﴾: من بعدِ حُكْمِك إذا لم يُرْضِهم."
  5,44,"﴿أَسۡلَمُواْ﴾: انقادُوا لحُكْمِ اللهِ.﴿لِلَّذِينَ هَادُواْ﴾: اليهودِ.﴿وَٱلرَّبَّـٰنِيُّونَ﴾: والعُبّادُ.﴿وَٱلۡأَحۡبَارُ﴾: والعلماء.﴿ٱسۡتُحۡفِظُواْ﴾: اسْتُودِعُوا عِلْمَه.﴿وَكَانُواْ عَلَيۡهِ شُهَدَآءَ﴾: أي: الربّانيُّون والأحبارُ شهداءُ لمحمدٍ ﷺ بأنه نبيٌّ يَقْضي بالحقِّ.﴿وَلَا تَشۡتَرُواْ بِـَٔايَـٰتِي ثَمَنࣰا قَلِيلࣰا﴾: ولا تأخُذُوا بتَرْكِ حُكمي مُقابِلًا حقيرًا."
  5,45,"﴿بِٱلنَّفۡسِ﴾: تُقْتَلُ بالنفسِ.﴿وَٱلۡجُرُوحَ قِصَاصࣱ﴾: يُقْتَصُّ في الجُروحِ.﴿تَصَدَّقَ بِهِۦ﴾: تجاوَزَ عن حَقِّه.﴿كَفَّارَةࣱ﴾: تكفيرٌ لذنوبهِ."
  5,46,"﴿وَقَفَّيۡنَا﴾: وأتْبَعْنا.﴿عَلَىٰٓ ءَاثَـٰرِهِم﴾: على آثارِ النبيِّين.﴿مُصَدِّقࣰا لِّمَا بَيۡنَ يَدَيۡهِ﴾: مصدِّقًا للتوراةِ، عاملًا بمافيها ممّالم يَنْسَخْه كتابُه الإنجيلُ."
  5,47,"﴿ٱلۡفَـٰسِقُونَ﴾: الخارجون عن طاعةِ اللهِ."
  5,48,"﴿إِلَيۡكَ﴾: إلى محمدٍ ﷺ.﴿مُصَدِّقࣰا لِّمَا بَيۡنَ يَدَيۡهِ﴾: أنزَلْناه بتصديقِ ماقبلَه.﴿مِنَ ٱلۡكِتَـٰبِ﴾: من الكُتُبِ.﴿وَمُهَيۡمِنًا عَلَيۡهِ﴾: وشاهِدًا بصحةِ الكتبِ المنزَّلَةِ، ورقيبًا عليها، وحافظًا لما فِيها.﴿لِكُلࣲّ﴾: لكلِّ أمةٍ.﴿شِرۡعَةࣰ﴾: شريعةً.﴿وَمِنۡهَاجࣰا﴾: وطريقًا واضحًا. وهذا قبلَ نَسْخِ الشَّرائعِ السابقةِ بالقرآنِ، وأمّا بعدَه فلا مِنهاجَ إلا ما جاءَ به.﴿لَجَعَلَكُمۡ﴾: لَجعَلَ شرائعَكم.﴿لِّيَبۡلُوَكُمۡ﴾: شاءَ الابتلاءَليختبرَكم، فيتميَّزَ المطيعُ من العاصي.﴿فَٱسۡتَبِقُواْ﴾: فسارِعُوا."
  5,49,"﴿يَفۡتِنُوكَ﴾: يَصْرِفُوك، فلا تعمَلَ بما فيه.﴿فَإِن تَوَلَّوۡاْ﴾: فإن أعْرَضُوا عَمّا تَحْكُمُ به﴿بِبَعۡضِ ذُنُوبِهِمۡ﴾: بسببِ ذنوبٍ اكتسبوها."
  5,51,"﴿أَوۡلِيَآءَ﴾: أنصارًا على أهلِ الإيمان.﴿بَعۡضُهُمۡ أَوۡلِيَآءُ بَعۡضࣲ﴾: بعضُ اليهودِ أولياءُ بعضهم الآخَرِ، وكذا النَّصارى."
  5,52,"﴿مَّرَضࣱ﴾: نفاقٌ، وشكٌّ.﴿يُسَـٰرِعُونَ فِيهِمۡ﴾: يبادِرُون في مُوالاةِ اليهودِ.﴿دَآئِرَةࣱ﴾: مايَدُور من المَكارهِ، فينتصرُ اليهودُ، فينالون منّا.﴿بِٱلۡفَتۡحِ﴾: فتحِ مكة.﴿مَآ أَسَرُّواْ﴾: ما أضمَرُوه من موالاةِ الكافرين."
  5,53,"﴿جَهۡدَ أَيۡمَـٰنِهِمۡ﴾: بأغلظِ الأَيْمانِ.﴿حَبِطَتۡ﴾: بَطَلَتْ، فلاثَوابَ لها."
  5,54,"﴿أَذِلَّةٍ﴾: رُحماءَ.﴿أَعِزَّةٍ﴾: أشدّاءَ."
  5,55,"﴿وَلِيُّكُمُ﴾: ناصرُكم.﴿رَ ٰ⁠كِعُونَ﴾: خاضِعُون للهِ."
  5,57,"﴿هُزُوࣰا﴾: سُخْرِيَّةً واستهزاءً."
  5,58,"﴿لَّا يَعۡقِلُونَ﴾: أي: حقيقةَ العبادةِ."
  5,59,"﴿وَأَنَّ أَكۡثَرَكُمۡ فَـٰسِقُونَ﴾: وإيمانَنا بأنّ أكثرَكم خارجون عن طاعةِ اللهِ."
  5,60,"﴿مَثُوبَةً﴾: جزاءً.﴿وَعَبَدَ﴾: ومَن عَبَدَ.﴿ٱلطَّـٰغُوتَ﴾: كلُّ مَن عُبِدَ من دونِ اللهِ.﴿شَرࣱّ مَّكَانࣰا﴾: ساء مكانُهم في الآخرة.﴿سَوَآءِ ٱلسَّبِيلِ﴾: الطريقِ الصحيحِ."
  5,61,"﴿جَآءُوكُمۡ﴾: هم أناسٌ من اليهود جاؤُوكم بالكفرِ."
  5,62,"﴿ٱلۡإِثۡمِ﴾: الكفرِ.﴿ٱلسُّحۡتَ﴾: الحَرامَ كالرَّشوةِ."
  5,63,"﴿لَوۡلَا﴾: هَلّا.﴿ٱلرَّبَّـٰنِيُّونَ﴾: أئمتُهم.﴿وَٱلۡأَحۡبَارُ﴾: علماؤُهم."
  5,64,"﴿مَغۡلُولَةٌ﴾: مَحْبوسةٌ عن فِعْلِ الخيرِ.﴿طُغۡيَـٰنࣰا﴾: غُلُوًّا في إنكارِ ما عَلِمُوا صِحَّتَه مِن نبوَّةِ محمدٍ ﷺ.﴿بَيۡنَهُمُ﴾: بين طوائفِ اليهودِ."
  5,65,"﴿لَكَفَّرۡنَا﴾: لَمَحَوْنا."
  5,66,"﴿مِن فَوۡقِهِمۡ﴾: لَأَنْزَلَ عليهم المطرَ، فتنبُتُ لهم به الأرضُ.﴿وَمِن تَحۡتِ أَرۡجُلِهِم﴾: مما تُخْرِجُه الأرض من بَرَكَتِها.﴿مُّقۡتَصِدَةࣱ﴾: معتدلةٌ، ليسَتْ غاليةً."
  5,67,"﴿يَعۡصِمُكَ﴾: يَحْفَظُك، فلا تُنالُ بسوءٍ."
  5,68,"﴿لَسۡتُمۡ عَلَىٰ شَيۡءٍ﴾: لَسْتُمْ على حَظٍّ من الدِّين يُعْتَدُّ به.﴿طُغۡيَـٰنࣰا وَكُفۡرࣰا﴾: تَجَبُّرًا وجُحودًا.﴿فَلَا تَأۡسَ﴾: فلا تَحْزَنْ."
  5,69,"﴿وَٱلصَّـٰبِـُٔونَ﴾: أي: كذلك، وهم قومٌ باقون على فِطْرتِهم، ولادِينَ مقرَّرٌلهم."
  5,70,"﴿مِيثَـٰقَ﴾: العهدَ المؤكَّدَ."
  5,71,"﴿وَحَسِبُوٓاْ أَلَّا تَكُونَ فِتۡنَةࣱ﴾: وظنَّ هؤلاء اليهودُ ألّا يقعَ عليهم من اللهِ ابتلاءٌ بالشدائدِ."
  5,73,"﴿ثَالِثُ ثَلَـٰثَةࣲ﴾: الأبُ، والابنُ، وروحُ القُدُسِ."
  5,75,"﴿خَلَتۡ﴾: تَقَدَّمَتْ.﴿يَأۡكُلَانِ ٱلطَّعَامَ﴾: يحتاجان إليه كسائرِ البَشَرِ، وليس هذا شأنَ الربِّ.﴿يُؤۡفَكُونَ﴾: يُصْرَفون عن الحقِّ الذي بَيَّنتُه لهم."
  5,77,"﴿لَا تَغۡلُواْ﴾: لا تتجاوزُوا الحقَّ.﴿قَوۡمࣲ﴾: هم اليهودُ.﴿سَوَآءِ ٱلسَّبِيلِ﴾: قَصْدِ الطَّريقِ."
  5,78,"﴿لُعِنَ﴾: طُرِدَ من رحمةِ اللهِ."
  5,79,"﴿لَا يَتَنَاهَوۡنَ﴾: لا ينتَهُون، ولا يَنْهى بعضُهم بعضًا."
  5,80,"﴿أَن سَخِطَ ٱللَّهُ عَلَيۡهِمۡ﴾: ما قَدَّمَتْ لهم أنفسُهم هو سَخَطُ اللهِ عليهم."
  5,81,"﴿فَـٰسِقُونَ﴾: خارجُون عن طاعةِ اللهِ."
  5,82,"﴿ٱلَّذِينَ قَالُوٓاْ﴾: هم وفْدُ نَصارى الحبشةِ، وقد دَخَلُوا في الإسلامِ.﴿رُهۡبَانࣰا﴾: مُتَعَبِّدين."
  5,83,"﴿ٱلشَّـٰهِدِينَ﴾: الذين يَشْهَدُون لأنبيائِك يومَ القيامةِ أنهم قد بَلَّغُوا أمَمهم رسالاتِك."
  5,85,"5:84"
  5,86,"5:84"
  5,87,"﴿وَلَا تَعۡتَدُوٓاْ﴾: ولا تتجاوَزُوا حدودَ ما حَرَّم اللهُ."
  5,89,"﴿بِٱللَّغۡوِ﴾: بما لا تَقْصِدُون عَقْدَه.﴿عَقَّدتُّمُ﴾: بما أوْجَبْتُموه على أنفسِكم.﴿مِنۡ أَوۡسَطِ﴾: ممّا تعتادُونه من غير إسرافٍ أو تَقْتيرٍ.﴿وَٱحۡفَظُوٓاْ أَيۡمَـٰنَكُمۡ﴾: باجتنابِ المسارعةِ إلى الحَلْفِ، والحِنْثِ به."
  5,90,"﴿ٱلۡمَيۡسِرُ﴾: القِمارُ.﴿وَٱلۡأَنصَابُ﴾: الحجارةُ التي يَذْبَحُون عندها تعظيمًا لها.﴿وَٱلۡأَزۡلَـٰمُ﴾: القِداحُ التي يَسْتَقْسِمُون بها قبلَ الشُّروعِ في شيءٍ.﴿رِجۡسࣱ﴾: إثمٌ وقَذَرٌ."
  5,92,"﴿تَوَلَّيۡتُمۡ﴾: أعْرَضْتُم."
  5,93,"﴿جُنَاحࣱ﴾: حَرَجٌ في شُرْبِهم الخمرَ قبلَ تحريمِها."
  5,94,"﴿لَيَبۡلُوَنَّكُمُ﴾: لَيختبرَنَّكم.﴿لِيَعۡلَمَ ٱللَّهُ﴾: عِلْمًا ظاهرًا للخَلْقِ.﴿ٱعۡتَدَىٰ﴾: تجاوزَ حدودَ اللهِ."
  5,95,"﴿حُرُمࣱ﴾: مُحْرِمُون بحَجٍّ أو عُمْرَةٍ.﴿مِّثۡلُ مَا قَتَلَ مِنَ ٱلنَّعَمِ﴾: يَذْبَحُ مثلَ ذلك الصيدِ من بهيمةِ الأنعامِ: الإبلِ، أو البقرِ، أو الغنمِ.﴿ٱلۡكَعۡبَةِ﴾: الحَرَمِ.﴿طَعَامُ مَسَـٰكِينَ﴾: يَشْتري بقيمةِ المِثْل من النَّعَمِ طعامًا يُهديه لفقراءِ الحَرَمِ.﴿عَدۡلُ ذَ ٰ⁠لِكَ﴾: ما عادَلَه من غيرِ جِنْسِه، فيصومُ بدَلَ الإطعامِ يومًا عن كل نصفِ صاعٍ. والجاني مُخَيَّرٌ بين الأنواعِ المذكورة.﴿وَبَالَ أَمۡرِهِۦ﴾: عاقبةَ فِعْلهِ.﴿سَلَفَ﴾: مضى قبلَ التحريمِ."
  5,96,"﴿ٱلۡبَحۡرِ﴾: هوكلُّ ماءٍ فيه صَيْدٌ.﴿وَطَعَامُهُۥ﴾: ماقَذَفَ به البحرُ، وطَفا عليه ميتًا.﴿مَتَـٰعࣰا لَّكُمۡ﴾: منفعةً وقُوتًا للمُقيمين منكم.﴿وَلِلسَّيَّارَةِ﴾: جَمْعُ سَيّار، وهو المسافرُ.﴿حُرُمࣰا﴾: مُحْرِمين بحَجٍ أو عُمرةٍ."
  5,97,"﴿قِيَـٰمࣰا لِّلنَّاسِ﴾: صَلاحًا لدينهم، وقِوامًا لأمرِهم، وأمْنًا لمَن تَوَجَّه إليها.﴿وَٱلشَّهۡرَ ٱلۡحَرَامَ﴾: وهي الأشهُر التي حَرَّمَ اللهُ فيها القتالَ، وهي: ذو القِعدةِ وذو الحِجَّةِ والمحرمُ ورَجَبٌ، يدفَعُ اللهُ بعضَ الناس عن بعضٍ بها.﴿وَٱلۡهَدۡيَ﴾: مايُهدى إلى الحَرَم من بهيمةِ الأنعام.﴿وَٱلۡقَلَـٰٓئِدَ﴾: ماقُلِّد إشعارًا بأنه يُقْصَدُ به النُّسُكُ، وهي ضَفائرُ صُوفٍ يَضَعُونها في رَقَبَةِ البَهيمةِ."
  5,99,"5:98"
  5,100,"﴿ٱلۡخَبِيثُ وَٱلطَّيِّبُ﴾: كلُّ ما يَتَّصِفُ بوَصْفِ الخُبْثِ والطَّيبِ من الأشخاصِ، والأعمالِ، والأقوالِ.﴿يَـٰٓأُوْلِي ٱلۡأَلۡبَـٰبِ﴾: يا أصحابَ العقولِ السِّليمةِ."
  5,101,"﴿لَا تَسۡـَٔلُواْ عَنۡ أَشۡيَآءَ﴾: عَمّالاحاجةَ لكم بالسؤالِ عنه.﴿تُبۡدَ لَكُمۡ﴾: (الثانية): تَظْهَرْ لكم بجوابِ النبيِّ ﷺ، أو بما يَنْزِلُ به الوحيُ، فيكونُ ذلك سببًا للتكاليفِ الشاقّةِ.﴿عَفَا ٱللَّهُ عَنۡهَا﴾: عمّا سَلَفَ من مَسْألَتِكم."
  5,102,"﴿ثُمَّ أَصۡبَحُواْ بِهَا كَـٰفِرِينَ﴾: فلمّا أُمِرُوا بها جَحَدُوها."
  5,103,"﴿مَا جَعَلَ ٱللَّهُ﴾: ما شَرَعَ اللهُ للمشركين ما ابتدَعُوه في بهيمةِ الأنعامِ من تَرْكِ الانتفاعِ بها، وتَرْكِها للأصنامِ.﴿مِنۢ بَحِيرَةࣲ﴾: هي التي تُشَقُّ أُذُنُها إذا ولَدَتْ عددًا من البُطونِ، أو التي لا يَحْلُبها أحدٌ من الناسِ.﴿وَلَا سَآئِبَةࣲ﴾: هي التي تُترك للأصنام إثْر نَذْرٍ.﴿وَلَا وَصِيلَةࣲ﴾: هي التي تتصلُ وِلادتُها بأنثى بعد أنثى.﴿وَلَا حَامࣲ﴾: هو الذَّكَرُ من الإبِلِ إذا نُتِجَ مِن صُلْبِه عددٌ من الإبِلِ، أو الذي يُعفى من الحَمْلِ."
  5,104,"﴿حَسۡبُنَا﴾: كافينا."
  5,105,"﴿عَلَيۡكُمۡ أَنفُسَكُمۡ﴾: ألْزِمُوا أنفسَكم بطاعةِ اللهِ."
  5,106,"﴿شَهَـٰدَةُ بَيۡنِكُمۡ﴾: فليَشْهَدْ على الوصيةِ.﴿ٱلۡمَوۡتُ﴾: علاماتُ الموتِ.﴿ذَوَا عَدۡلࣲ﴾: ذوا رُشْدٍ وأمانةٍ.﴿غَيۡرِكُمۡ﴾: من غيرِ المسلمين عند الحاجةِ في السفرِ للوصيةِ.﴿تَحۡبِسُونَهُمَا﴾: تَسْتَوْقِفونهما.﴿ٱلصَّلَوٰةِ﴾: صلاةِ العصرِ.﴿إِنِ ٱرۡتَبۡتُمۡ﴾: في شَهادتِهما، فإن صَدَّقْتُموهما فلا حاجةَ إلى القَسَم، وليس على شهودِ المسلمين إقسامٌ.﴿لَا نَشۡتَرِي بِهِۦ ثَمَنࣰا﴾: لا نأخُذُ عِوَضًا من الدُّنيا، ولا نُحابي أحدًا.﴿وَلَوۡ كَانَ ذَا قُرۡبَىٰ﴾: ولو كانَ المشهودُ له قريبًا."
  5,107,"﴿فَإِنۡ عُثِرَ عَلَىٰٓ أَنَّهُمَا ٱسۡتَحَقَّآ إِثۡمࣰا﴾: إنْ ظَهَرَ لأولياءِ الميتِ أنّ الشاهدَين الكافرَين قد أثِما بالخيانةِ في الشهادةِ.﴿مِنَ ٱلَّذِينَ ٱسۡتَحَقَّ عَلَيۡهِمُ ٱلۡأَوۡلَيَـٰنِ﴾: أي: الأَجْدران من الذين وجَبَ عليهم أن يكونا أقربَ أولياءِ الميتِ إليه.﴿وَمَا ٱعۡتَدَيۡنَآ﴾: وما تجاوَزْنا الحقَّ في أيْمانِنا."
  5,108,"﴿ذَ ٰ⁠لِكَ أَدۡنَىٰٓ أَن يَأۡتُواْ بِٱلشَّهَـٰدَةِ عَلَىٰ وَجۡهِهَآ﴾: ذلك الحكمُ عند الارتيابِ في الشاهدَين الكافرَين من الحَلْفِ أقربُ إلى أن يأتُوا بالشهادة على حقيقتِها.﴿أَوۡ يَخَافُوٓاْ أَن تُرَدَّ أَيۡمَـٰنُۢ بَعۡدَ أَيۡمَـٰنِهِمۡ﴾: أو خَشْيَةَ أن تُرَدَّ اليمينُ الكاذبةُ من قِبَلِ أصحابِ الحقِّ الذين يَحْلِفُون بما يتضَمَّنُ كَذِبَ الكافرين."
  5,109,"﴿مَاذَآ أُجِبۡتُمۡ﴾: ماذا أجابَتْكم أممكُم؟﴿لَا عِلۡمَ لَنَآ﴾: لا نعلمُ ما في صدورِهم، وما أحدَثُوا بعدنا."
  5,110,"﴿نِعۡمَتِي عَلَيۡكَ﴾: إذ خَلَقْتُك من غيرِ أبٍ.﴿وَعَلَىٰ وَ ٰ⁠لِدَتِكَ﴾: إذ رَفَعْتُ شأنَها، وبَرَّأتُها مما نُسِبَ إليها.﴿بِرُوحِ ٱلۡقُدُسِ﴾: جبريلَ.﴿فِي ٱلۡمَهۡدِ﴾: وأنت رضيعٌ قبل أوانِ الكلامِ.﴿وَكَهۡلࣰا﴾: وكبيرًا، لا يتفاوَتُ كلامُك في الحالَين.﴿ٱلۡكِتَـٰبَ﴾: وعَلَّمْتُك الكتابةَ.﴿وَٱلۡحِكۡمَةَ﴾: قوةَ الفهمِ، والإدراكِ.﴿ٱلۡأَكۡمَهَ﴾: مَن وُلِدَ أعمى.﴿تُخۡرِجُ ٱلۡمَوۡتَىٰ﴾: من قُبورِهم أحياءً.﴿كَفَفۡتُ بَنِيٓ إِسۡرَ ٰ⁠ٓءِيلَ﴾: مَنَعْتُهم حين هَمُّوا بقَتْلِكَ."
  5,111,"﴿ٱلۡحَوَارِيِّـۧنَ﴾: خُلَصاءِ عيسى عليه السلام."
  5,112,"﴿مِنَ ٱلشَّـٰهِدِينَ﴾: على هذه الآيةِ، فتكونُ حُجّةً لك."
  5,114,"﴿تَكُونُ لَنَا عِيدࣰا﴾: نَتَّخِذُ يومَ نُزُولِها عيدًا لنا، فنُعَظِّمُه.﴿لِّأَوَّلِنَا وَءَاخِرِنَا﴾: لنا ولمَن بعدَنا من عَقِبِنا.﴿وَءَايَةࣰ﴾: وعلامةً على صِدْقِك."
  5,116,"5:115"
  5,117,"﴿شَهِيدࣰا﴾: رقيبًا.﴿تَوَفَّيۡتَنِي﴾: وفَّيْتَ أجلي على الأرضِ ورَفَعْتَني إلى السماءِ حيًّا."
  5,119,"5:118"
  5,120,"5:118"
