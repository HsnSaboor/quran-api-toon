tafsir[29]{c,v,t}:
  45,1,"﴿حمٓ﴾: سَبقَ الكلامُ على الحروف المقطَّعة أولَ سورة البقرة."
  45,3,"45:2"
  45,4,"﴿وَمَا يَبُثُّ﴾: وما يَنْشُرُ ويُفَرِّقُ.﴿دَآبَّةٍ﴾: ما يَدِبُّ عَلى الأرضِ غَيرَ الإنْسانِ.﴿يُوقِنُونَ﴾: يَعْلَمُونَ حَقائِقَ الأَشْياءِ، فيُقِرُّونَ بِها."
  45,5,"﴿وَٱخۡتِلَـٰفِ ٱلَّيۡلِ وَٱلنَّهَارِ﴾: تَعاقُبِهِما، أو تَفاوَتِهِما بالطُّولِ والقِصَرِ والظُّلْمَةِ والضِّياءِ.﴿رِّزۡقࣲ﴾: مَطَرٍ يَكُونُ مِنهُ القُوتُ.﴿وَتَصۡرِيفِ ٱلرِّيَـٰحِ﴾: تَبْدِيلِ اللهِ سبحانه وتعالى للرِّياحِ صُعُودًا ونُزُولًا، واخْتلِافِ جِهاتِ هُبُوبِها."
  45,7,"﴿وَيۡلࣱ﴾: هَلاكٌ شَدِيدٌ.﴿أَفَّاكٍ﴾: كَذّابٍ.﴿أَثِيمࣲ﴾: كَثِيرِ الآثامِ."
  45,9,"﴿هُزُوًا﴾: مَوْضِعَ سُخْرِيةٍ واسْتِخْفافٍ."
  45,10,"﴿مِّن وَرَآئِهِمۡ﴾: من أمامِهم.﴿وَلَا يُغۡنِي عَنۡهُم﴾: ولا يَنْفَعُهُم.﴿أَوۡلِيَآءَ﴾: نُصَراءَ."
  45,11,"﴿رِّجۡزٍ﴾: أسْوأِ العَذابِ."
  45,12,"﴿ٱلۡفُلۡكُ﴾: السُّفُنُ."
  45,14,"﴿يَغۡفِرُواْ﴾: يَعْفُوا ويَتجاوَزُوا.﴿لَا يَرۡجُونَ﴾: لا يَخافُونَ.﴿أَيَّامَ ٱللَّهِ﴾: بأسَهُ ووَقائِعَه ونِقَمَهُ."
  45,15,"﴿فَعَلَيۡهَا﴾: فَعَلى نَفْسِهِ جَنى."
  45,16,"﴿ٱلۡكِتَـٰبَ﴾: التَّوْراةَ والإنْجِيلَ.﴿وَٱلۡحُكۡمَ﴾: الفَهْمَ للكِتابِ والعِلْمَ بِالسُّنَنِ الَّتي لم تَنْزِلْ في الكِتابِ.﴿ٱلۡعَـٰلَمِينَ﴾: عالمَي أهلِ زَمانِهِم."
  45,17,"﴿بَيِّنَـٰتࣲ﴾: دَلالاتٍ تُبَيِّنُ الحقَّ مِنَ الباطِلِ.﴿ٱلۡعِلۡمُ﴾: الكتابُ والنُّبُوَّةُ والدَّلائِلُ الواضِحَةُ الَّتِي تُفَرِّقُ بين الحقِّ والباطِلِ.﴿بَغۡيَۢا﴾: ظُلْمًا وحَسَدًا."
  45,18,"﴿شَرِيعَةࣲ﴾: مِنهاجٍ واضِحٍ.﴿مِّنَ ٱلۡأَمۡرِ﴾: مِن أمْرِ الدِّينِ.﴿أَهۡوَآءَ﴾: ما تَمِيلُ نُفُوسُهُم إلَيهِ مِمّا يُخالِفُ شَرْعَ اللهِ."
  45,19,"﴿يُغۡنُواْ﴾: يَدْفَعُوا."
  45,20,"﴿بَصَـٰٓئِرُ﴾: جَمْعُ بصِيرةِ، وهي الحُجَّةُ فِيما يحتاجُونَ إليهِ مِنَ الأحْكامِ."
  45,21,"﴿ٱجۡتَرَحُواْ﴾: اكْتَسَبُوا.﴿سَوَآءࣰ مَّحۡيَاهُمۡ وَمَمَاتُهُمۡ﴾: مُسْتَويةً حالةُ حياتِهِم وحالاتُ موتِهِم."
  45,23,"﴿وَخَتَمَ عَلَىٰ سَمۡعِهِۦ﴾: وطَبَع عَلى سَمْعِهَ، فَلا يَسْمَعُ مَواعِظَ اللهِ.﴿غِشَـٰوَةࣰ﴾: غِطاءً فَلا يَنْتَفِعُ بِبَصَرِهِ."
  45,24,"﴿ٱلدَّهۡرُ﴾: مُرورُ السِّنينَ والأَيّامِ.﴿عِلۡمٍ﴾: يَقِينٍ بَلْ يَقُولُونَ ذَلكَ تَخَرُّصًا."
  45,26,"45:25"
  45,27,"﴿ٱلۡمُبۡطِلُونَ﴾: الَّذِينَ أبْطَلُوا في دَعْواهُم للهِ شَرِيكًا."
  45,28,"﴿جَاثِيَةࣰ﴾: بارِكَةً عَلى الرُّكَبِ مُسْتَوفِزَةً.﴿كِتَـٰبِهَا﴾: كِتابِ أعْمالِها."
  45,29,"﴿كِتَـٰبُنَا﴾: كِتابُ أعْمالِكُم الَّذِي دوَّنَتْهُ ملائِكَتِي.﴿نَسۡتَنسِخُ﴾: نَأمُرُ الحَفَظَةَ أن تَكْتُبَ."
  45,31,"45:30"
  45,32,"﴿بِمُسۡتَيۡقِنِينَ﴾: بِمُتَحَقِّقِينَ."
  45,33,"﴿وَبَدَا﴾: وظَهَرَ.﴿وَحَاقَ﴾: ونَزَلَ وأَحاطَ."
  45,34,"﴿نَنسَىٰكُمۡ﴾: نَتْرُكُكُم في عَذابِ جَهَنَّمَ.﴿وَمَأۡوَىٰكُمُ﴾: ومَسْكَنُكُم."
  45,35,"﴿هُزُوࣰا﴾: مُسْتَهْزَأً بِها.﴿وَغَرَّتۡكُمُ﴾: وخَدَعَتْكُم.﴿لَا يُخۡرَجُونَ مِنۡهَا﴾: أي مِنَ النّارِ.﴿يُسۡتَعۡتَبُونَ﴾: يُرْضِيهِم أحَدٌ بِتَمْكِينِهِم مِنَ التَّوبَةِ."
  45,37,"﴿ٱلۡكِبۡرِيَآءُ﴾: السُّلطانُ والعَظَمَةُ."
