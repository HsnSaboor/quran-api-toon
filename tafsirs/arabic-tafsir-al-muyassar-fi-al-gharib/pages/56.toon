tafsir[75]{c,v,t}:
  56,1,"﴿ٱلۡوَاقِعَةُ﴾: القِيامَةُ."
  56,2,"﴿كَاذِبَةٌ﴾: لا يَكُونُ عِنْدَ وُقُوعِها تَكْذِيبٌ."
  56,3,"﴿خَافِضَةࣱ رَّافِعَةٌ﴾: هي خافِضَةٌ يَحْصُلُ عِنْدَها خَفْضُ أقْوامٍ كانُوا مُرْتَفِعِينَ ورَفْعُ أقْوامٍ كانُوا مُنْخَفِضِينَ، وخافِضَةُ جِهاتٍ كانَتْ مُرْتَفِعَةً كالجِبالِ والصَّوامِعِ، رافِعَةٌ ما كانَ مُنْخَفِضًا بِسَبَبِ ما يَحْدُثُ في الكَونِ."
  56,4,"﴿رُجَّتِ﴾: اضْطَرَبَتْ، بِسَبَبِ الزَّلازِلِ والخَسْفِ ونَحْوِ ذَلِكَ."
  56,5,"﴿وَبُسَّتِ﴾: فُتِّتَتِ الجبالُ ونُسِفَتْ."
  56,6,"﴿هَبَآءࣰ﴾: ما يَلُوحُ في خُيُوطِ شُعاعِ الشَّمسِ مِن دَقِيقِ الغُبارِ.﴿مُّنۢبَثࣰّا﴾: مُتَفَرِّقًا."
  56,7,"﴿أَزۡوَ ٰ⁠جࣰا﴾: أصْنافًا."
  56,8,"﴿أَصۡحَـٰبُ ٱلۡمَيۡمَنَةِ﴾: هُمُ الَّذِينَ يُجْعَلُونَ في الجِهَةِ اليُمْنى فِي الجَنَّةِ أوْ فِي الَمحْشَرِ."
  56,9,"﴿أَصۡحَـٰبُ ٱلۡمَشۡـَٔمَةِ﴾: أصْحابُ الشَّقاوَةِ الَّذِينَ يُؤْخَذُ بِهِم ذاتَ الشِّمال إلى النّارِ."
  56,10,"﴿وَٱلسَّـٰبِقُونَ﴾: إلى الخَيْراتِ.﴿ٱلسَّـٰبِقُونَ﴾: إلى مُنْتَهى الفَضْلِ والرِّفْعَةِ."
  56,12,"56:11"
  56,13,"﴿ثُلَّةࣱ﴾: جَماعةٌ."
  56,15,"﴿سُرُرࣲ﴾: جَمْعُ سَرِيرٍ، وهو مَجِلِسُ العُظَماءِ والمُلُوكِ أيْضًا.﴿مَّوۡضُونَةࣲ﴾: مَسْبُوكٍ بَعْضُها بِبَعْضٍ."
  56,16,"﴿مُتَقَـٰبِلِينَ﴾: يَجْلِسُ بَعْضُهُم مُقابِلَ بَعْضٍ، وذَلِكَ مِن تَمامِ النَّعِيمِ لمِا فِيهِ مِنَ الأُنْسِ بِمُشاهَدَةِ الأَصْحابِ والحَدِيثِ مَعَهُم."
  56,17,"﴿يَطُوفُ﴾: يَدُورُ عَلى نَحْوٍ دائِمٍ.﴿مُّخَلَّدُونَ﴾: أي دائِمُونَ عَلى الطَّوافِ عَلَيهِم ومُناوَلَتِهِم."
  56,18,"﴿بِأَكۡوَابࣲ﴾: جَمْعُ كُوبٍ، وهو إناءُ الخمْرِ.﴿وَأَبَارِيقَ﴾: جَمْعِ إبْريقٍ، وهو إناءٌ تُحْمَلُ فِيهِ الخمْرُ فتُصَبُّ في الأكْوابِ.﴿وَكَأۡسࣲ﴾: هو إناءٌ للخَمْرِ كاْلكُوبِ.﴿مَّعِينࣲ﴾: هو الجارِي، والمُرادُ بِهِ الخَمْرُ الَّتِي لِكَثْرَتِها تَجْرِي ولَيسَتْ عَزِيَزةً كَما هِي في الدُّنيا."
  56,19,"﴿لَّا يُصَدَّعُونَ﴾: لا يُصِيبُهُم صُداعُ الرَّأْسِ.﴿وَلَا يُنزِفُونَ﴾: أي لا يَعْتَرِيهِم اخْتِلاطُ العَقْلِ."
  56,20,"﴿يَتَخَيَّرُونَ﴾: يَخْتارُونَهُ ويَشْتَهُونَهُ."
  56,22,"﴿وَحُورٌ﴾: نِساءٌ ذَواتُ حَوَرٍ أي: نِساءٌ شَدِيداتُ بياضِ العَينِ وسَوادِها.﴿عِينࣱ﴾: واسِعاتُ العُيُونِ."
  56,23,"﴿كَأَمۡثَـٰلِ﴾: كأشْباهِ.﴿ٱللُّؤۡلُوِٕ﴾: الدُّرِّ.﴿ٱلۡمَكۡنُونِ﴾: المَخْزُونِ المُخَبَّأِ لِنَفاسَتِهِ."
  56,25,"﴿لَغۡوࣰا﴾: هُوَ الكَلامُ الَّذِي لا يُعْتَدُّ بِهِ.﴿تَأۡثِيمًا﴾: هُوَ اللَّومُ والإنْكارُ."
  56,26,"﴿سَلَـٰمࣰا سَلَـٰمࣰا﴾: سَلَّمْنا سَلامًا إثْرَ سَلامٍ."
  56,28,"﴿سِدۡرࣲ﴾: شَجَرٍ مِن شَجَرِ العِضاه، ذِي ورَقٍ عَرِيضٍ مُدَوَّرٍ.﴿مَّخۡضُودࣲ﴾: أُزِيلَ شَوْكُهُ."
  56,29,"﴿وَطَلۡحࣲ﴾: شَجَرٍ مِن شَجَرِ العِضاه، واحدُه طَلْحةٌ، كَثِيرَةُ الظِّلِّ مِن التِفافِ أغْصانِها.﴿مَّنضُودࣲ﴾: مُتَراصٍّ مُتَراكِبٍ بالأغْصانِ."
  56,30,"﴿وَظِلࣲّ مَّمۡدُودࣲ﴾: لا يَتَقَلَّصُ كَظِلِّ الدُّنيا."
  56,31,"﴿وَمَآءࣲ مَّسۡكُوبࣲ﴾: مَصبُوبٍ."
  56,33,"﴿لَّا مَقۡطُوعَةࣲ وَلَا مَمۡنُوعَةࣲ﴾: دائِمَةٍ مَبْذُولَةٍ لَهُم."
  56,34,"﴿وَفُرُشࣲ﴾: جَمْعُ فِراشٍ، وهو ما يُفْرَشُ.﴿مَّرۡفُوعَةٍ﴾: عَلى الأَسِرَّةِ."
  56,36,"56:35"
  56,37,"56:35"
  56,38,"56:35"
  56,39,"56:35"
  56,40,"56:35"
  56,41,"56:35"
  56,42,"﴿سَمُومࣲ﴾: هي الرِّيحُ الشَّدِيدَةُ الحَرارةِ.﴿وَحَمِيمࣲ﴾: هو الماءُ الشَّديدُ الحَرارةِ."
  56,43,"﴿يَحۡمُومࣲ﴾: الدُّخانِ الأَسْوَدِ."
  56,45,"﴿مُتۡرَفِينَ﴾: ذوي نِعْمَةٍ واسِعةٍ."
  56,46,"﴿يُصِرُّونَ﴾: يَثْبُتُونَ عَلَيهِ.﴿ٱلۡحِنثِ﴾: الذَّنبِ والمَعْصِيَةِ.﴿ٱلۡعَظِيمِ﴾: القَوِيِّ في نَوْعِهِ، وهو الشِّركُ."
  56,48,"56:47"
  56,49,"56:47"
  56,50,"﴿لَمَجۡمُوعُونَ﴾: يُبْعَثُونَ ويُحْشَرُونَ جَمِيعًا."
  56,52,"﴿شَجَرࣲ مِّن زَقُّومࣲ﴾: شَجَرَةٍ كَرِيهَةِ الرّائِحَةِ يُنبتُها اللهُ في جَهَنَّمَ."
  56,54,"﴿ٱلۡحَمِيمِ﴾: هُوَ الماءُ الشَّدِيدُ الغَلَيانِ."
  56,55,"﴿ٱلۡهِيمِ﴾: جَمْعُ أهْيَمَ، وهُوَ البَعِيرُ الَّذِي أصابَهُ الهُيامُ، وهو داءُ يُصُيِبُ الإبِلَ فلا تَزالُ تَشْرَبُ ولا تَرْوى."
  56,56,"﴿نُزُلُهُمۡ﴾: النُّزُلُ هو ما يُقَدَّمُ للضَّيفِ مِن طَعامٍ."
  56,58,"﴿تُمۡنُونَ﴾: ما يَكُونُ مِنكُم مِن الَمنِيِّ."
  56,60,"﴿قَدَّرۡنَا بَيۡنَكُمُ ٱلۡمَوۡتَ﴾: قَضَيْنا عَلَيكُم بِالمَوْتِ أوْ سَوَّينا بَينَكُم في الموتِ.﴿بِمَسۡبُوقِينَ﴾: بِمَغْلُوبِينَ."
  56,61,"﴿نُّبَدِّلَ أَمۡثَـٰلَكُمۡ﴾: نُغَيِّرَ خَلْقَكُم.﴿فِي مَا لَا تَعۡلَمُونَ﴾: مِنَ الصِّفاتِ والأحْوال."
  56,62,"﴿ٱلنَّشۡأَةَ ٱلۡأُولَىٰ﴾: خَلْقَ اللهِ إياكُم ولَمْ تكُونُوا شَيئًا مَذْكُورًا."
  56,64,"﴿تَزۡرَعُونَهُۥٓ﴾: تُنْبِتُونَهُ."
  56,65,"﴿حُطَـٰمࣰا﴾: يابِسًا هَشِيمًا لا يُنْتَفعُ بِهِ.﴿فَظَلۡتُمۡ﴾: فصِرْتُمْ.﴿تَفَكَّهُونَ﴾: تَعْجَبُونَ مِن يُبْسِهِ بَعْدَ خُضْرَتِهِ."
  56,66,"﴿إِنَّا لَمُغۡرَمُونَ﴾: لَمُلْزَمُونَ غَرامَةَ ما أنْفَقْنا."
  56,67,"﴿مَحۡرُومُونَ﴾: من الرِّزقِ."
  56,69,"﴿ٱلۡمُزۡنِ﴾: السَّحابِ."
  56,70,"﴿أُجَاجࣰا﴾: شَدِيدَ المُلُوحَةِ."
  56,71,"﴿تُورُونَ﴾: تُوقِدُونَ."
  56,72,"﴿شَجَرَتَهَآ﴾: الَّتِي تُقْدَحُ مِنها النّارُ.﴿ٱلۡمُنشِـُٔونَ﴾: الخالِقُونَ."
  56,73,"﴿تَذۡكِرَةࣰ﴾: تَذْكِيرًا لَكُم بِنارِ جَهَنَّمَ.﴿وَمَتَـٰعࣰا﴾: ومَنفَعَةً.﴿لِّلۡمُقۡوِينَ﴾: لِلْمُسافِريِنَ."
  56,74,"﴿فَسَبِّحۡ﴾: فنَزِّهْ."
  56,75,"﴿بِمَوَ ٰ⁠قِعِ ٱلنُّجُومِ﴾: بِمَساقِطِ النُّجُومِ في مَغارِبِها في السَّماءِ."
  56,77,"56:76"
  56,78,"﴿مَّكۡنُونࣲ﴾: مَصُونٍ مَسْتُورٍ، وهو الكِتابُ الَّذِي بأيدِي الملائِكةِ."
  56,79,"﴿ٱلۡمُطَهَّرُونَ﴾: هُمُ المَلائِكةُ الَّذِينَ طَهَّرَهُم اللهُ مِنَ الآفاتِ والذُّنُوبِ."
  56,81,"﴿ٱلۡحَدِيثِ﴾: القرآنِ.﴿مُّدۡهِنُونَ﴾: مُكَذِّبُونَ."
  56,82,"﴿رِزۡقَكُمۡ﴾: شُكْرَكُم لِنِعَمِ اللهِ عَلَيكُم."
  56,83,"﴿فَلَوۡلَآ﴾: فَهَلّا.﴿بَلَغَتِ﴾: أي النَّفْسُ.﴿ٱلۡحُلۡقُومَ﴾: الحَلْقَ."
  56,85,"﴿وَنَحۡنُ أَقۡرَبُ إِلَيۡهِ مِنكُمۡ﴾: بِمَلائِكَتِنا ولَكِنَّكُم لا تَرَونَهُم."
  56,86,"﴿فَلَوۡلَآ﴾: فَهَلّا.﴿غَيۡرَ مَدِينِينَ﴾: غَيرَ مُحاسَبِينَ ولا مَجْزِيِّينَ بِأَعْمالِكُم."
  56,87,"﴿تَرۡجِعُونَهَآ﴾: تَرُدُّونَ النَّفْسَ."
  56,89,"﴿فَرَوۡحࣱ﴾: فَلَهُ رَحْمَةٌ وفَرَحٌ عِنْدَ مَوتِهِ.﴿وَرَيۡحَانࣱ﴾: مُسْتَراحٌ."
  56,91,"﴿فَسَلَـٰمࣱ لَّكَ﴾: فسَلامةٌ لَكَ وأَمْنٌ."
  56,92,"﴿فَنُزُلࣱ﴾: فَضِيافَةٌ.﴿حَمِيمࣲ﴾: شَرابِ جَهَنَّمَ المَغْلِيِّ."
  56,94,"﴿وَتَصۡلِيَةُ﴾: وإدْخالٌ لِيُقاسِيَ الحرَّ."
  56,95,"﴿حَقُّ ٱلۡيَقِينِ﴾: اليَقِينُ حقًا."
  56,96,"﴿فَسَبِّحۡ﴾: فَنَزِّهْ."
