tafsir[46]{c,v,t}:
  54,1,"﴿ٱلسَّاعَةُ﴾: القِيامَةُ.﴿وَٱنشَقَّ﴾: انْفَلَقَ فِلْقَتَينِ."
  54,2,"﴿ءَايَةࣰ﴾: بُرْهانًا عَلى صِدْقِ الرَّسُولِ مُحَمَّدٍ ﷺ.﴿مُّسۡتَمِرࣱّ﴾: ذاهِبٌ مُضْمَحِلٌّ لا دَوامَ لَهُ."
  54,3,"﴿أَهۡوَآءَهُمۡ﴾: ما تُحِبُّهُ أنفُسُهُم مِنَ الضَّلالِ والتَّكْذِيبِ.﴿أَمۡرࣲ﴾: مِن خَيرٍ أوْ شَرٍّ.﴿مُّسۡتَقِرࣱّ﴾: واقِعٌ بأَهْلِهِ يَوْمَ القِيامَةِ."
  54,4,"﴿مُزۡدَجَرٌ﴾: كِفايَةٌ لِرَدْعِهم."
  54,5,"﴿حِكۡمَةُۢ﴾: هَذا القُرْآنُ فِيهِ حِكْمَةٌ عَظِيمةٌ.﴿بَـٰلِغَةࣱ﴾: بالِغَةٌ غايَتَها.﴿فَمَا﴾: فأيُّ شَيءٍ.﴿تُغۡنِ﴾: تَدْفَعُ أوْ تَنْفَعُ.﴿ٱلنُّذُرُ﴾: الإنْذاراتُ."
  54,6,"﴿فَتَوَلَّ﴾: فَأَعْرِضْ.﴿ٱلدَّاعِ﴾: المَلَكُ بنَفْخِهِ في «القَرْنِ».﴿نُّكُرٍ﴾: فَظِيعٍ مُنْكَرٍ وهو موقِفُ الحِسابِ."
  54,7,"﴿خُشَّعًا﴾: ذَلِيلَةً.﴿ٱلۡأَجۡدَاثِ﴾: القُبُورِ.﴿مُّنتَشِرࣱ﴾: مُنْبَثٌّ عَلى وجْهِ الأرْضِ."
  54,8,"﴿مُّهۡطِعِينَ﴾: مُسْرِعِينَ مادِّينَ أعْناقَهُم.﴿ٱلدَّاعِ﴾: صوتِ المَلَكِ.﴿عَسِرࣱ﴾: شَدِيدُ الهَوْلِ."
  54,9,"﴿وَٱزۡدُجِرَ﴾: وانْتَهَرُوهُ مُتَوَعِّدِينَ إيّاهُ بأنْواعِ الأَذى."
  54,10,"﴿مَغۡلُوبࣱ﴾: ضَعِيفٌ عَن مُقاوَمةِ هَؤُلاءِ.﴿فَٱنتَصِرۡ﴾: لِي بِعِقابٍ مِن عِنْدِكَ."
  54,11,"﴿مُّنۡهَمِرࣲ﴾: كَثِيرٍ مُتَدَفِّقٍ."
  54,12,"﴿وَفَجَّرۡنَا﴾: وشَقَقْنا.﴿عُيُونࣰا﴾: مِن عُيُونٍ مُتَفَجِّرَةٍ بالماءِ.﴿فَٱلۡتَقَى ٱلۡمَآءُ﴾: فالتَقى ماءُ السَّماءِ وماءُ الأرْضِ.﴿عَلَىٰٓ أَمۡرࣲ قَدۡ قُدِرَ﴾: عَلى إهْلاكِهِم الَّذِي قَدَّرَهُ اللهُ لَهُم."
  54,13,"﴿ذَاتِ أَلۡوَ ٰ⁠حࣲ﴾: سَفِيَنةٍ ذاتِ ألْواحٍ.﴿وَدُسُرࣲ﴾: ومَسامِيرَ شُدَّتْ بِها."
  54,14,"﴿بِأَعۡيُنِنَا﴾: بِمَرْأىً مِنّا وحِفْظٍ."
  54,15,"﴿وَلَقَد تَّرَكۡنَـٰهَآ﴾: ولَقَدْ أبْقَينا قِصَّةَ نُوحٍ.﴿ءَايَةࣰ﴾: عِبْرةً.﴿مُّدَّكِرࣲ﴾: مُتَّعِظٍ."
  54,17,"﴿يَسَّرۡنَا﴾: سَهَّلْنا.﴿لِلذِّكۡرِ﴾: لِلتِّلاوَةِ والحِفْظِ والفَهْمِ والتَّدَبُّرِ."
  54,19,"﴿صَرۡصَرࣰا﴾: شَدِيدَةَ البَرْدِ والصَّوتِ.﴿نَحۡسࣲ﴾: شُؤْمٍ.﴿مُّسۡتَمِرࣲّ﴾: اسْتَمَرَّ بِهِمُ العَذابُ إلى أن وافى بِهِمْ جَهَنَّمَ."
  54,20,"﴿تَنزِعُ ٱلنَّاسَ﴾: تَقَلَعُ النّاسَ مِنَ الأرْضِ، فتَصْرَعُهم عَلى رُؤوسِهِم، فَتَنْدَقُّ رِقابُهُم وتَنْفَصِلُ عَنْ أجْسامِهِم.﴿أَعۡجَازُ﴾: أُصُولُ.﴿مُّنقَعِرࣲ﴾: مُنْقَلِعٍ."
  54,22,"54:21"
  54,23,"﴿بِٱلنُّذُرِ﴾: بالآياتِ الَّتِي أُنْذِرُوا بِها."
  54,24,"﴿ضَلَـٰلࣲ﴾: بُعْدٍ عَنِ الصَّوابِ.﴿وَسُعُرٍ﴾: جُنُونٍ."
  54,25,"﴿أَءُلۡقِيَ﴾: أأُنْزِلَ.﴿ٱلذِّكۡرُ﴾: الوَحْيُ والقُرآنُ.﴿أَشِرࣱ﴾: صاحِبُ بَطَرٍ وتَكَبُّرٍ."
  54,27,"﴿مُرۡسِلُواْ﴾: مُخْرِجُو.﴿فَٱرۡتَقِبۡهُمۡ﴾: اخْتِبارًا.﴿فَٱرۡتَقِبۡهُمۡ﴾: فانْتَظِرْ ما يَحُلُّ عَلَيهِم مِنَ العَذابِ.﴿وَٱصۡطَبِر﴾: واصْبِرْ عَلى الأَذى الَّذِي يُصِيبُكَ مِنَ المدْعُوِّينَ."
  54,28,"﴿وَنَبِّئۡهُمۡ﴾: وأَخْبِرْهُم.﴿قِسۡمَةُۢ﴾: مَقْسُومٌ.﴿بَيۡنَهُمۡ﴾: بَيْنَ ثَمُودَ والنّاقَةِ.﴿كُلُّ شِرۡبࣲ﴾: كُلُّ نَصِيبٍ مِن الشَّرابِ.﴿مُّحۡتَضَرࣱ﴾: يَحْضُرُهُ صاحِبُهُ ويَسْتَحِقُّهُ."
  54,29,"﴿فَتَعَاطَىٰ﴾: فَتَناوَلَ النّاقَةَ بِيَدِهِ لِيَعْقِرَها.﴿فَعَقَرَ﴾: فَقَتَلَ."
  54,31,"﴿كَهَشِيمِ﴾: كالشَّجَرِ اليابِسِ الَّذِي يَسْقُطُ ويَتَناثَرُ.﴿ٱلۡمُحۡتَظِرِ﴾: الَّذِي يُرِيدُ أن يَعْمَلَ سِياجًا لِحِفْظِ المواشِي فَيَحْتَطِبَ لِذَلِكَ."
  54,33,"54:32"
  54,34,"﴿حَاصِبًا﴾: رِيحًا شَدِيدَةً تَرْمِيهِم بِحِجارَةٍ.﴿بِسَحَرࣲ﴾: في آخِرِ الليلِ."
  54,35,"﴿نَجۡزِي﴾: نُثِيبُ.﴿مَن شَكَرَ﴾: مَن آمَنَ بِاللهِ ووَحّدَهُ."
  54,36,"﴿وَلَقَدۡ أَنذَرَهُم﴾: خَوَّفَهُم.﴿بَطۡشَتَنَا﴾: بَأْسَنا وعَذابَنا.﴿فَتَمَارَوۡاْ﴾: فَشَكُّوا.﴿بِٱلنُّذُرِ﴾: بالإنْذارِ."
  54,38,"﴿صَبَّحَهُم بُكۡرَةً﴾: جاءَهُم وقْتَ الصَّباحِ.﴿مُّسۡتَقِرࣱّ﴾: نازلٌ بِهم."
  54,40,"54:39"
  54,41,"﴿ءَالَ فِرۡعَوۡنَ﴾: أتْباعَ فِرْعَونَ.﴿ٱلنُّذُرُ﴾: الإنْذارُ تِلْو الإنْذارِ مِن مُوسى عَلَيهِ السَّلامُ بالعُقُوبةِ عَلى كُفْرِهِم."
  54,42,"﴿بِـَٔايَـٰتِنَا﴾: بِأَدلَّتِنا الدّالّةِ عَلى وحْدانِيَّتِنا ونُبُوَّةِ أنْبِيائِنا.﴿فَأَخَذۡنَـٰهُمۡ﴾: فَعاقَبْناهُم.﴿عَزِيزࣲ﴾: لا يُغالَبُ.﴿مُّقۡتَدِرٍ﴾: قادِرٍ عَلى هَلاكِكُم."
  54,43,"﴿أَكُفَّارُكُمۡ﴾: يا مَعْشَرَ العَرَبِ.﴿بَرَآءَةࣱ﴾: مِنَ العذابِ ألّا يُصِيبَكُم ما أصابَهُم.﴿ٱلزُّبُرِ﴾: الكُتُبِ المنَزَّلةِ عَلى الأنبياءِ المُتقَدِّمِينَ."
  54,44,"﴿جَمِيعࣱ﴾: نَحْنَ يَدٌ واحِدَةٌ عَلى مَن خالَفَنا.﴿مُّنتَصِرࣱ﴾: نَغْلِبُ غَيرَنا."
  54,45,"﴿ٱلۡجَمۡعُ﴾: جَمْعُ كُفّارِ مَكَّةَ أمامَ المُؤمِنِينَ."
  54,46,"﴿أَدۡهَىٰ﴾: أفْظَعُ وأَعْظَمُ.﴿وَأَمَرُّ﴾: أشدُّ مَرارَةً مِنَ القَتْلِ والأَسْرِ."
  54,47,"﴿ضَلَـٰلࣲ﴾: تِيهٍ عَنِ الحقِّ.﴿وَسُعُرࣲ﴾: جُنُونٍ أو نارٍ تَسْتَعِرُ عَلَيهِم."
  54,48,"﴿يُسۡحَبُونَ﴾: يُجَرُّونَ.﴿مَسَّ سَقَرَ﴾: شِدَّةَ عَذابِ جَهَنَّمَ."
  54,49,"﴿بِقَدَرࣲ﴾: بمِقَدارٍ قَدَّرْناهُ، وسَبَق عِلْمُنا بِهِ، وكِتابَتُنا لَهُ في اللَّوحِ المَحْفُوظِ."
  54,50,"﴿وَ ٰ⁠حِدَةࣱ﴾: قَوْلَةٌ واحِدَةٌ، وهي «كُنْ».﴿كَلَمۡحِۭ بِٱلۡبَصَرِ﴾: فَيُوجَدُ في أقْصَرِ وقْتٍ."
  54,51,"﴿أَشۡيَاعَكُمۡ﴾: أشْباهَكُم في الكُفْرِ مِنَ الأُمَمِ السّابِقَةِ.﴿مُّدَّكِرࣲ﴾: مُتَّعِظٍ."
  54,52,"﴿ٱلزُّبُرِ﴾: الكُتَبِ الَّتِي كَتَبَتْها الحَفَظَةُ."
  54,53,"﴿مُّسۡتَطَرٌ﴾: مُسَطَّرٌ في صَحائِفِهم."
  54,55,"﴿مَقۡعَدِ صِدۡقٍ﴾: مَجْلِسِ حَقٍّ.﴿مَلِيكࣲ﴾: اللهِ الملِكِ العَظِيمِ.﴿مُّقۡتَدِرِۭ﴾: عَظِيمِ القُدْرَةِ."
