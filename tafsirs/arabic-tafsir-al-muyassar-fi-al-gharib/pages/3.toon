tafsir[185]{c,v,t}:
  3,1,"﴿الٓمٓ﴾: سَبَقَ شَرْحُها في الآية"
  3,2,"﴿ٱلۡقَيُّومُ﴾: القائمُ بنفسِه، والمُقيمُ لأحوالِ خَلْقِه."
  3,3,"﴿ٱلۡكِتَـٰبَ﴾: القرآنَ.﴿مُصَدِّقࣰا لِّمَا بَيۡنَ يَدَيۡهِ﴾: يَشْهَدُ على صِدْقِ ما قبلَه من كُتُبٍ."
  3,4,"﴿ٱلۡفُرۡقَانَ﴾: ما يُفَرِّقُ بينَ الحقِّ والباطلِ، وهو القرآنُ."
  3,6,"﴿كَيۡفَ يَشَآءُ﴾: مِن ذَكَرٍ وأنثى، وشَقِيٍّ وسعيدٍ، وغيرِ ذلك."
  3,7,"﴿مُّحۡكَمَـٰتٌ﴾: واضحاتُ المعنى، ظاهراتُ الدَّلالةِ.﴿أُمُّ ٱلۡكِتَـٰبِ﴾: أصلُه الذي يُرْجَعُ إليه عندَ الاشتِباهِ.﴿مُتَشَـٰبِهَـٰتࣱ﴾: لا يتعَيَّنُ معناها، ولا تَظْهَرُ دَلالتُها.﴿زَيۡغࣱ﴾: مَيْلٌ.﴿فَيَتَّبِعُونَ مَا تَشَـٰبَهَ مِنۡهُ﴾: يَتَّبعون الآياتِ المتشابهاتِ، فيُشَكِّكُون بها على المؤمنين.﴿ٱبۡتِغَآءَ ٱلۡفِتۡنَةِ﴾: طَلَبًا منهم للتَّلبيسِ عليهم في دينِهم.﴿وَٱبۡتِغَآءَ تَأۡوِيلِهِۦ﴾: ولتأويلِهم لها على الوجه الذي يوافِقُ مذهبَهم.﴿وَٱلرَّ ٰ⁠سِخُونَ﴾: والمتمَكِّنُونَ.﴿كُلࣱّ﴾: كلُّ القرآنِ.﴿وَمَا يَذَّكَّرُ﴾: وما يتدبَّرُ المعانيَ على وجْهِها الصحيحِ.﴿أُوْلُواْ ٱلۡأَلۡبَـٰبِ﴾: أصحابُ العقولِ السليمةِ."
  3,8,"﴿لَا تُزِغۡ قُلُوبَنَا﴾: لاتَصْرِفْ قلوبَنا عن الإيمانِ بك."
  3,10,"﴿لَن تُغۡنِيَ عَنۡهُمۡ﴾: لن تنفعَهم، ولن تُنْجِيَهم.﴿مِّنَ ٱللَّهِ﴾: من عقوبتهِ، إن أحَلَّها بهم عاجلًا في الدنيا.﴿وَقُودُ ٱلنَّارِ﴾: حَطَبُ النارِ."
  3,11,"﴿كَدَأۡبِ ءَالِ فِرۡعَوۡنَ﴾: شَأْنُ الكافرين في تكذيبهِم ومايَنْزِلُ بهم من العقوبةِ مِثْلُ شأنِ آلِ فرعونَ.﴿فَأَخَذَهُمُ ٱللَّهُ﴾: فعاجَلَهم بالعُقوبةِ."
  3,12,"﴿لِّلَّذِينَ كَفَرُواْ﴾: لليهودِ.﴿وَتُحۡشَرُونَ﴾: وتُجْمَعون، وتُساقُون.﴿ٱلۡمِهَادُ﴾: الفِراشُ."
  3,13,"﴿ءَايَةࣱ﴾: دَلالَةٌ عظيمةٌ.﴿ٱلۡتَقَتَا﴾: أي: في معركةِ بدرٍ.﴿يَرَوۡنَهُم مِّثۡلَيۡهِمۡ﴾: يرى المشركون المسلمين في العددِ مثلَيْهم.﴿لَعِبۡرَةࣰ﴾: لعِظَةً.﴿لِّأُوْلِي ٱلۡأَبۡصَـٰرِ﴾: لأصحابِ البصائرِ."
  3,14,"﴿زُيِّنَ﴾: حُسِّنَ.﴿وَٱلۡقَنَـٰطِيرِ ٱلۡمُقَنطَرَةِ﴾: والأموالِ الكثيرةِ.﴿ٱلۡمُسَوَّمَةِ﴾: المُعَلَّمَةِ الحِسانِ.﴿وَٱلۡأَنۡعَـٰمِ﴾: من الإبِلِ والبقرِوالغَنَمِ.﴿وَٱلۡحَرۡثِ﴾: الأرضِ المتخَذَةِ للزِّراعةِ.﴿ٱلۡمَـَٔابِ﴾: المَرْجِعِ."
  3,15,"﴿مِّن ذَ ٰ⁠لِكُمۡ﴾: ممّا حُسِّنَ للناسِ في الحياةِ الدُّنيا.﴿مُّطَهَّرَةࣱ﴾: من الحَيْضِ والنِّفاسِ، وسوءِ الخُلُقِ.﴿وَرِضۡوَ ٰ⁠نࣱ﴾: ورِضا."
  3,16,"﴿وَقِنَا﴾: ونَجِّنا."
  3,17,"﴿وَٱلصَّـٰدِقِينَ﴾: الذين صَدَقُوا اللهَ، فعَمِلُوا بماجاء به.﴿وَٱلۡقَـٰنِتِينَ﴾: والمطيعين له.﴿بِٱلۡأَسۡحَارِ﴾: بآخِرِ الليلِ."
  3,18,"﴿وَٱلۡمَلَـٰٓئِكَةُ﴾: أي: يَشْهَدُون كذلك.﴿بِٱلۡقِسۡطِ﴾: بالعَدْلِ."
  3,19,"﴿مِنۢ بَعۡدِ مَا جَآءَهُمُ ٱلۡعِلۡمُ﴾: أي: المقتضي لعَدَمِ الاختلافِ، بما تَضَمَّنَتْه كُتُبُهم المنزَّلةُ.﴿بَغۡيَۢا بَيۡنَهُمۡ﴾: حَسَدًا وطَلَبًا للدُّنيا، فصَدَّهم عن اتِّباعِ الَحقِّ.﴿سَرِيعُ ٱلۡحِسَابِ﴾: يحفَظُ ذلك عليهم بغيرِ كُلْفَةٍ."
  3,20,"﴿حَآجُّوكَ﴾: جادَلُوك أيُّها الرسولُ.﴿أَسۡلَمۡتُ﴾: أخلَصْتُ.﴿وَمَنِ ٱتَّبَعَنِ﴾: وكذلك أسْلَمَ وجهَه مَنِ اتَّبعَني.﴿وَٱلۡأُمِّيِّـۧنَ﴾: مُشْركي العربِ الذين لايكتبُون.﴿تَوَلَّوۡاْ﴾: أعْرَضُوا."
  3,21,"﴿بِٱلۡقِسۡطِ﴾: بالعَدْلِ."
  3,22,"﴿حَبِطَتۡ﴾: بَطَلَتْ."
  3,23,"﴿إِلَى ٱلَّذِينَ﴾: إلى اليهودِ الذين كانوا في زمن النبيِّ ﷺ مِمَّن أُوتي عِلْمًا.﴿نَصِيبࣰا مِّنَ ٱلۡكِتَـٰبِ﴾: حَظًّا من التوراةِ.﴿كِتَـٰبِ ٱللَّهِ﴾: التوراةِ.﴿يَتَوَلَّىٰ﴾: يأبى."
  3,24,"﴿ذَ ٰ⁠لِكَ﴾: الانصرافُ عن الحقِّ.﴿وَغَرَّهُمۡ﴾: وخَدَعَهم.﴿يَفۡتَرُونَ﴾: يختلِقُون من الأكاذيبِ في ادِّعائِهم أنهم أبناءُ اللهِ وأحِبّاؤُه."
  3,25,"﴿فَكَيۡفَ﴾: أي: فكيف يكونُ حالهُم؟﴿وَوُفِّيَتۡ﴾: وجُوزِيَتْ.﴿مَّا كَسَبَتۡ﴾: ما عَمِلَتْ من خيرٍ أو شَرٍّ."
  3,26,"﴿تَنزِعُ﴾: تَسْلُبُ."
  3,27,"﴿تُولِجُ﴾: تُدْخِلُ.﴿وَتُخۡرِجُ ٱلۡحَيَّ مِنَ ٱلۡمَيِّتِ﴾: تُخْرِجُ الإنسانَ الحَيَّ من النُّطْفةِ الميتةِ.﴿وَتُخۡرِجُ ٱلۡمَيِّتَ مِنَ ٱلۡحَيِّ﴾: تُخْرِجُ النُّطْفَةَ الميتة من الإنسانِ الحيِّ.﴿بِغَيۡرِ حِسَابࣲ﴾: بغير مُحاسَبةٍ."
  3,28,"﴿لَّا يَتَّخِذِ ٱلۡمُؤۡمِنُونَ ٱلۡكَـٰفِرِينَ أَوۡلِيَآءَ﴾: لا تَتَّخِذُوا أيها المؤمنون الكافرين أنصارًا.﴿إِلَّآ أَن تَتَّقُواْ مِنۡهُمۡ تُقَىٰةࣰ﴾: إلاأن تكونوا ضِعافًا، فرَخَّص لكم في مُهادنتِهم اتقاءً لشَرِّهم.﴿ٱلۡمَصِيرُ﴾: رجوعُ الخلائقِ للحِسابِ."
  3,29,"﴿تُبۡدُوهُ﴾: تُظْهِرُوه."
  3,30,"﴿مُّحۡضَرࣰا﴾: مُوَفَّرًا.﴿أَمَدَۢا﴾: زَمَنًا وأجَلًا."
  3,32,"﴿تَوَلَّوۡاْ﴾: أعْرَضُوا."
  3,33,"﴿ٱصۡطَفَىٰٓ﴾: اختار.﴿عَلَى ٱلۡعَـٰلَمِينَ﴾: جَعَلَهم أفضلَ أهلِ زمانِهم."
  3,34,"﴿ذُرِّيَّةَۢ بَعۡضُهَا مِنۢ بَعۡضࣲ﴾: تَسَلْسَلَ الفَضْلُ في ذَراريهم."
  3,35,"﴿ٱمۡرَأَتُ عِمۡرَ ٰ⁠نَ﴾: أمُّ مريمَ.﴿نَذَرۡتُ﴾: جَعَلْتُه لخِدْمَةِ بيتِ المقدسِ.﴿مُحَرَّرࣰا﴾: خالصًا لعبادتِك."
  3,36,"﴿وَضَعۡتُهَآ أُنثَىٰ﴾: أي: لاتَصْلُحُ للخِدْمةِ.﴿وَلَيۡسَ ٱلذَّكَرُ كَٱلۡأُنثَىٰ﴾: ليس الذَّكَرُ الذي أرَدْتُ للخدمةِ كالأنثى التي لا تَصْلُحُ لذلك.﴿أُعِيذُهَا﴾: أُحَصِّنُها.﴿ٱلرَّجِيمِ﴾: المَطْرودِ من رحمتك."
  3,37,"﴿وَأَنۢبَتَهَا نَبَاتًا حَسَنࣰا﴾: تَوَلّى ابْنَتَها، فكَمُلَتْ بذلك أحوالُها.﴿ٱلۡمِحۡرَابَ﴾: مَحَلَّ عبادتهِ."
  3,38,"﴿هُنَالِكَ﴾: عند رؤيةِ زكريّا ما عندَ مريمَ من رزقِ اللهِ، وفَضْلهِ.﴿ذُرِّيَّةࣰ طَيِّبَةً﴾: ولَدًا مباركًا. وتُطْلَقُ الذُّرِّيَّةُ على الجمعِ والواحدِ."
  3,39,"﴿ٱلۡمِحۡرَابِ﴾: مُقَدَّم المسجدِ، وهو مكانُ عبادتِه.﴿مُصَدِّقَۢا بِكَلِمَةࣲ مِّنَ ٱللَّهِ﴾: يُصَدِّقُ بعيسى عليه السلامُ.﴿وَسَيِّدࣰا﴾: شريفًا في العِلْمِ والعبادةِ.﴿وَحَصُورࣰا﴾: يَكُفُّ عن النساءِ، فيمتنعُ عنهنَّ مع القُدرةِ."
  3,40,"﴿أَنَّىٰ﴾: من أيِّ وجهٍ؟﴿ٱلۡكِبَرُ﴾: الشيخوخةُ.﴿عَاقِرࣱ﴾: عَقيمٌ.﴿كَذَ ٰ⁠لِكَ ٱللَّهُ﴾: هَيِّنٌ عليه أن يخلقَ ولدًا من الكبيرِ والعقيمِ."
  3,41,"﴿ءَايَةࣰ﴾: علامةً أسْتَدِلُّ بها على وجودِ الوَلَدِ.﴿رَمۡزࣰا﴾: إشارةً وإيماءً.﴿بِٱلۡعَشِيِّ﴾: مِن زوالِ الشمسِ إلى أن تَغِيبَ.﴿وَٱلۡإِبۡكَـٰرِ﴾: من مَطْلَعِ الفجرِ إلى وقتِ الضُّحى."
  3,42,"﴿ٱصۡطَفَىٰكِ﴾: اختارَكِ لطاعتِه.﴿ٱلۡعَـٰلَمِينَ﴾: عالَمِي زمانِك."
  3,43,"﴿ٱقۡنُتِي﴾: أخْلِصي الطاعةَ لربِّك."
  3,44,"﴿وَمَا كُنتَ لَدَيۡهِمۡ﴾: أي: نحن نُعْلِمُك أخبارَهم.﴿يُلۡقُونَ أَقۡلَـٰمَهُمۡ﴾: يُجْرُون القُرْعَةَ، بإلقاءِ سِهامِهم على كَفالةِ مريمَ، فأصابَتْ زكريا."
  3,45,"﴿بِكَلِمَةࣲ مِّنۡهُ﴾: يكونُ وجودُه بكلمةٍ من اللهِ، وهي قولُه: «كن»، فيكونُ.﴿وَجِيهࣰا﴾: له الجاهُ العظيمُ عندَ اللهِ."
  3,46,"﴿فِي ٱلۡمَهۡدِ﴾: في مَضْجَعِ الصبيِّ في رَضاعِه.﴿وَكَهۡلࣰا﴾: مَن كان بينَ سِنِّ الشَّبابِ والشيخوخةِ."
  3,47,"﴿أَنَّىٰ﴾: من أيِّ وجه؟"
  3,48,"﴿ٱلۡكِتَـٰبَ﴾: الكتابةَ."
  3,49,"﴿بِـَٔايَةࣲ﴾: بعلامةٍ دالَّةٍ على أني مُرْسَلٌ من اللهِ.﴿فِيهِ﴾: في ذلك الخَلْقِ.﴿ٱلۡأَكۡمَهَ﴾: مَن وُلِدَ أعمى.﴿وَٱلۡأَبۡرَصَ﴾: مَن يَظْهَرُ في جِلْده بياضٌ.﴿تَدَّخِرُونَ﴾: تُخَبِّئون لوقتِ الحاجةِ."
  3,50,"﴿وَمُصَدِّقࣰا﴾: وجِئتُكم مُصَدِّقًا.﴿بَعۡضَ ٱلَّذِي حُرِّمَ عَلَيۡكُمۡ﴾: مثلَ لحومِ الإبلِ، والشُّحومِ، وغيرِها."
  3,51,"﴿صِرَ ٰ⁠طࣱ﴾: طريقٌ."
  3,52,"﴿إِلَى ٱللَّهِ﴾: مُتَوَجِّهًا إلى اللهِ.﴿ٱلۡحَوَارِيُّونَ﴾: هم أصْفِياءُ عيسى عليه السلامُ."
  3,53,"﴿ٱلشَّـٰهِدِينَ﴾: الذين شَهِدُوا بالحقِّ، وأقَرُّوا بالتوحيدِ."
  3,54,"﴿وَمَكَرُواْ﴾: أرادوا قَتْلَ عيسى عليه السلام.﴿وَمَكَرَ ٱللَّهُ﴾: بحَقٍّ على ما يَلِيقُ به، وذلك من إلقائِه شَبَهَ عيسى على بعض أتباعِه حتى قَتَلُوه، ورَفْعِ عيسى إليه."
  3,55,"﴿مُتَوَفِّيكَ﴾: قابضُك من الأرضِ.﴿وَمُطَهِّرُكَ﴾: ومُخَلِّصُك.﴿ٱلَّذِينَ ٱتَّبَعُوكَ﴾: هم خُلَّصُ أصحابِك الذين لم يَغْلُوا فيك.﴿فَوۡقَ ٱلَّذِينَ كَفَرُوٓاْ﴾: ظاهرين على الذين جَحَدُوا نبوَّتَك."
  3,56,"﴿فِي ٱلدُّنۡيَا﴾: بالقَتْلِ والصَّغارِ."
  3,57,"﴿فَيُوَفِّيهِمۡ أُجُورَهُمۡ﴾: فيُعْطِيهم ثوابَ أعمالِهم كاملًا."
  3,58,"﴿مِنَ ٱلۡـَٔايَـٰتِ﴾: من الدَّلائلِ الواضحةِ على صحةِ رسالتِك.﴿وَٱلذِّكۡرِ ٱلۡحَكِيمِ﴾: القُرآنِ الذي يَفْصِلُ بينَ الحَقِّ والباطلِ"
  3,59,"﴿كَمَثَلِ ءَادَمَ﴾: مَثَلُه كمَثَلِ خَلْقِ آدمَ من غير أبٍ، ولا أمٍّ."
  3,60,"﴿ٱلۡمُمۡتَرِينَ﴾: الشاكِّين."
  3,61,"﴿حَآجَّكَ فِيهِ﴾: جادَلَك في عيسى.﴿نَبۡتَهِلۡ﴾: نَتَوَجَّهْ إلى اللهِ بالدُّعاء."
  3,63,"﴿تَوَلَّوۡاْ﴾: أعْرَضُوا عن تصديِقك."
  3,64,"﴿سَوَآءِۭ﴾: عَدْلٍ وحَقّ، نلتزمُ بها.﴿وَلَا يَتَّخِذَ بَعۡضُنَا بَعۡضًا أَرۡبَابࣰا﴾: ماكان بطاعةِ الأتباعِ للرؤساءِ فيما أمروهُم به من المعاصِي.﴿مُسۡلِمُونَ﴾: خاضِعُون لرَبِّنا."
  3,65,"﴿تُحَآجُّونَ فِيٓ إِبۡرَ ٰ⁠هِيمَ﴾: تُجادِلُون في أنّ إبراهيمَ على مِلَّتِكم."
  3,66,"﴿حَـٰجَجۡتُمۡ﴾: جادَلْتُم.﴿فِيمَا لَكُم بِهِۦ عِلۡمࣱ﴾: في أمْرِ دينِكم مِمّا تعتقدون صِحَّتَه."
  3,67,"﴿حَنِيفࣰا﴾: مُتَّبِعًا أمْرَ الله.﴿مُّسۡلِمࣰا﴾: خاشِعًا لربِّه، مُلْتَزِمًا بأحكامِه."
  3,68,"﴿أَوۡلَى﴾: أحَقُّ.﴿وَهَـٰذَا ٱلنَّبِيُّ﴾: محمدٌ ﷺ."
  3,69,"﴿لَوۡ يُضِلُّونَكُمۡ﴾: عن الإسلامِ."
  3,70,"﴿لِمَ تَكۡفُرُونَ بِـَٔايَـٰتِ ٱللَّهِ﴾: لِمَ تَجْحَدُون بآياتِ اللهِ التي أنزلها على رُسُلهِ في كُتُبِكم؟﴿وَأَنتُمۡ تَشۡهَدُونَ﴾: أنه الحقُّ، فتَجِدُونه مكتوبًا عندَكم ثم تُنْكِرونه."
  3,71,"﴿تَلۡبِسُونَ﴾: تَخْلِطُون.﴿ٱلۡحَقَّ﴾: الذي في كُتُبِكم.﴿بِٱلۡبَـٰطِلِ﴾: بما حَرَّفْتُموه بأيدِيكم.﴿وَتَكۡتُمُونَ ٱلۡحَقَّ﴾: وتُخْفُون ما في كُتبِكم من مَبْعَثِ محمدٍ ﷺ."
  3,72,"﴿ءَامِنُواْ﴾: صَدِّقوا.﴿وَجۡهَ ٱلنَّهَارِ﴾: أوَّلَه.﴿لَعَلَّهُمۡ يَرۡجِعُونَ﴾: لعلَّهم يَتَشَكَّكُون في دينِهم، ويَرْجِعُون عنه."
  3,73,"﴿وَلَا تُؤۡمِنُوٓاْ﴾: ولاتُصَدِّقوا.﴿أَن يُؤۡتَىٰٓ أَحَدࣱ مِّثۡلَ مَآ أُوتِيتُمۡ﴾: لا تُصَدِّقُوهم لئلا يَعْلَمُوا مثلَ ما عَلِمْتُم.﴿يُحَآجُّوكُمۡ﴾: يَتَّخِذُوه حُجَّةً."
  3,74,"﴿ذُو ٱلۡفَضۡلِ﴾: ذو العَطاءِ"
  3,75,"﴿بِقِنطَارࣲ﴾: على كثيرٍ من المالِ.﴿قَآئِمࣰا﴾: أي: بالمطالبةِ.﴿ٱلۡأُمِّيِّـۧنَ﴾: العربِ.﴿سَبِيلࣱ﴾: حَرَجٌ في أموالهِم؛ لأنّ اللهَ أحَلَّها لنا."
  3,76,"﴿مَنۡ أَوۡفَىٰ بِعَهۡدِهِۦ﴾: مَن أدّى أمانتَه."
  3,77,"﴿يَشۡتَرُونَ بِعَهۡدِ ٱللَّهِ﴾: يَسْتبدلون بوصيةِ اللهِ باتِّباعِ محمدٍ ﷺ.﴿وَأَيۡمَـٰنِهِمۡ﴾: الكاذبةِ.﴿لَا خَلَـٰقَ﴾: لا نصِيبَ.﴿وَلَا يُزَكِّيهِمۡ﴾: ولا يُطَهِّرُهم مِن دَنَسِ ذُنوبِهم."
  3,78,"﴿يَلۡوُۥنَ أَلۡسِنَتَهُم بِٱلۡكِتَـٰبِ﴾: يُحَرِّفُون الكلامَ، ويُبَدِّلون آياتِ اللهِ."
  3,79,"﴿رَبَّـٰنِيِّـۧنَ﴾: جَمْعُ رَبّانِيّ، وهو الذي يُصْلِحُ أمورَ الناسِ، ويقومُ بها."
  3,81,"﴿مِيثَـٰقَ ٱلنَّبِيِّـۧنَ﴾: العهدَ المؤكَّدَ على الأنبياءِ في تصديقِ بعضِهم بعضًا.﴿لَمَآ﴾: لَئِنْ.﴿إِصۡرِي﴾: عَهْدِي الُموَثَّقَ."
  3,82,"﴿تَوَلَّىٰ﴾: أعْرَضَ.﴿ٱلۡفَـٰسِقُونَ﴾: الخارجون عن طاعةِ اللهِ."
  3,83,"﴿يَبۡغُونَ﴾: يريدون.﴿أَسۡلَمَ﴾: استسلمَ، وخَضَعَ.﴿طَوۡعࣰا﴾: طَواعيةً، كالملائكةِ والأنبياءِ.﴿وَكَرۡهࣰا﴾: رَغْمًا عنه، كمَن أسلمَ مخافةَ القتلِ."
  3,84,"﴿وَٱلۡأَسۡبَاطِ﴾: الأنبياءِ الذين كانُوا في قبائلِ بني إسرائيل مِن ولَدِ يعقوبَ.﴿مُسۡلِمُونَ﴾: مُنقادُون بالطاعةِ."
  3,86,"﴿يَهۡدِي﴾: يُوَفِّقُ للإيمانِ، ويُرْشِدُ للصَّوابِ.﴿ٱلۡبَيِّنَـٰتُ﴾: الدَّلائلُ الواضحاتُ."
  3,87,"﴿لَعۡنَةَ ٱللَّهِ﴾: الطَّرْدَ من رحمةِ اللهِ."
  3,88,"﴿وَلَا هُمۡ يُنظَرُونَ﴾: ولا يُؤَخَّرُ عنهم لمعذِرَةٍ يَعْتَذِرُون بها."
  3,89,"﴿وَأَصۡلَحُواْ﴾: ما أفسَدُوه."
  3,90,"﴿لَّن تُقۡبَلَ تَوۡبَتُهُمۡ﴾: عند حُضورِ الموتِ."
  3,91,"﴿وَلَوِ ٱفۡتَدَىٰ بِهِۦٓ﴾: ولو دَفَعَ هذا المالَ ليَفْتَدِيَ نفسَه من العذابِ."
  3,92,"﴿ٱلۡبِرَّ﴾: الجنةَ."
  3,93,"﴿إِلَّا مَا حَرَّمَ﴾: هو يعقوبُ، إذ حَرَّمَ على نفسِه -دونَ أتباعِه- لمرضٍ ألَمَّ به، ولمّا نَزَلَتِ التوراةُ حَرَّمَ اللهُ على بني إسرائيلَ بعضَ الأطعمةِ لظُلْمِهم.﴿إِن كُنتُمۡ صَـٰدِقِينَ﴾: في دَعْواكم أنّ اللهَ أنزلَ في التوراةِ تحريمَ ماحَرَّمه يعقوبُ على نفسِه."
  3,95,"﴿صَدَقَ ٱللَّهُ﴾: فيما أخبرَ به.﴿حَنِيفࣰا﴾: مستقيمًا لا عِوَجَ فيه."
  3,96,"﴿بِبَكَّةَ﴾: بمكةَ.﴿مُبَارَكࣰا﴾: تُضاعَفُ فيه الحَسَناتُ."
  3,97,"﴿ءَايَـٰتُۢ﴾: علاماتٌ.﴿مَّقَامُ إِبۡرَ ٰ⁠هِيمَ﴾: وهو الحَجَرُ الذي كان يَقِفُ عليه حين كان يرفعُ القَواعدَ من البيت.﴿سَبِيلࣰا﴾: سَعَةً.﴿وَمَن كَفَرَ﴾: ومَن جَحَدَ وُجوبَه."
  3,98,"﴿لِمَ تَكۡفُرُونَ بِـَٔايَـٰتِ ٱللَّهِ﴾: لِمَ تُنْكِرُون ما في كتبِكم من دلائلَ على أن الدينَ هو الإسلامُ؟"
  3,99,"﴿تَصُدُّونَ﴾: تمنعون.﴿عِوَجࣰا﴾: مَيْلًا عن القصدِ، والاستقامةِ.﴿شُهَدَآءُ﴾: عالِمُون أنّ ما جِئْتُ به هو الحقُّ."
  3,100,"﴿يَرُدُّوكُم بَعۡدَ إِيمَـٰنِكُمۡ كَـٰفِرِينَ﴾: يُلْقُوا إليكم الشُّبَهَ، فتَرْجِعُوا جاحِدِين للحقِّ."
  3,101,"﴿ءَايَـٰتُ ٱللَّهِ﴾: القرآنُ الكريمُ.﴿وَفِيكُمۡ رَسُولُهُۥ﴾: يُبَلِّغُها لكم، وهو حُجَّةٌ أخرى للهِ عليكم.﴿يَعۡتَصِم بِٱللَّهِ﴾: يتمسَّكْ بدِينِه، وطاعتِه.﴿هُدِيَ﴾: وُفِّقَ.﴿صِرَ ٰ⁠طࣲ﴾: طريقٍ."
  3,102,"﴿مُّسۡلِمُونَ﴾: مُذْعِنُون له بالطاعةِ."
  3,103,"﴿وَٱعۡتَصِمُواْ بِحَبۡلِ ٱللَّهِ﴾: وتمسَّكُوا بدينِ اللهِ.﴿فَأَلَّفَ﴾: فجَمَعَ.﴿إِخۡوَ ٰ⁠نࣰا﴾: مُتَحابِّين.﴿شَفَا﴾: حافَةٍ وطَرفٍ."
  3,104,"﴿أُمَّةࣱ﴾: جماعةٌ."
  3,105,"﴿كَٱلَّذِينَ تَفَرَّقُواْ﴾: من أهلِ الكتابِ.﴿ٱلۡبَيِّنَـٰتُ﴾: الحُجَجُ الواضحاتُ."
  3,106,"﴿تَبۡيَضُّ وُجُوهࣱ﴾: هم أهلُ السَّعادَةِ.﴿وَتَسۡوَدُّ وُجُوهࣱ﴾: هم أهلُ الشَّقاءِ.﴿أَكَفَرۡتُم﴾: فُيقال لهم توبيخًا"
  3,108,"﴿بِٱلۡحَقِّ﴾: بالصِّدْقِ واليقينِ."
  3,109,"﴿تُرۡجَعُ ٱلۡأُمُورُ﴾: مَصِيرُ أمْرِ جميعِ الخَلْقِ، فيُجازي كُلًّا بما يستحِقُّ."
  3,110,"﴿كُنتُمۡ﴾: أنتم يا أمةَ محمدٍ ﷺ، على الشَّرْطِ المذكورِ.﴿ٱلۡفَـٰسِقُونَ﴾: الخارِجُون عن دينِ اللهِ."
  3,111,"﴿إِلَّآ أَذࣰى﴾: إلا ما يُؤْذِي أسماعَكم من الكَذِبِ على اللهِ والتحريفِ.﴿يُوَلُّوكُمُ ٱلۡأَدۡبَارَ﴾: يُهْزَموا."
  3,112,"﴿ٱلذِّلَّةُ﴾: الهَوانُ والصَّغارُ.﴿ثُقِفُوٓاْ﴾: وُجِدُوا.﴿إِلَّا بِحَبۡلࣲ مِّنَ ٱللَّهِ﴾: إلا بعَهْدٍ من الله يأمَنُون به على أنفسِهم.﴿وَحَبۡلࣲ مِّنَ ٱلنَّاسِ﴾: بذِمَّةٍ من الناسِ.﴿وَبَآءُو﴾: واستحَقُّوا غَضَبَ اللهِ.﴿ٱلۡمَسۡكَنَةُ﴾: ذُلُّ الفاقةِ والفقرِ."
  3,113,"﴿أُمَّةࣱ قَآئِمَةࣱ﴾: جماعةٌ ثابتةٌ على الحقِّ.﴿ءَانَآءَ ٱلَّيۡلِ﴾: جَمْعُ إنى، وهي ساعاتُه."
  3,115,"﴿فَلَن يُكۡفَرُوهُ﴾: فلن يُعْدَمُوا ثوابَه."
  3,116,"﴿لَن تُغۡنِيَ﴾: لن تَدْفَعَ عنهم.﴿مِّنَ ٱللَّهِ﴾: من عذابِ اللهِ."
  3,117,"﴿مَا يُنفِقُونَ﴾: في وجوهِ الخيرِ.﴿صِرٌّ﴾: بَرْدٌ شديدٌ.﴿أَصَابَتۡ حَرۡثَ قَوۡمࣲ﴾: هَبَّتْ علىَ زَرْعِ قومٍ كانوا يَرْجُون خيرَه. وكذلك إنفاقُ الكافرِ لا ينفَعُه."
  3,118,"﴿بِطَانَةࣰ مِّن دُونِكُمۡ﴾: أصفياءَ مِن دونِ المؤمنين، تُطْلِعُونَهم على أسرارِكم.﴿لَا يَأۡلُونَكُمۡ خَبَالࣰا﴾: لا يُقَصِّرُون في إفسادِ حالِكم.﴿مَا عَنِتُّمۡ﴾: مَشَقَّتَكم.﴿ٱلۡـَٔايَـٰتِ﴾:: الحُجَجَ."
  3,119,"﴿وَتُؤۡمِنُونَ بِٱلۡكِتَـٰبِ كُلِّهِۦ﴾: وتؤمنون بالكُتُبِ المنَّزلَةِ كلها، وهم لا يُؤمنون بكتابِكم.﴿مِنَ ٱلۡغَيۡظِ﴾: من شِدَّةِ الغَضَبِ."
  3,120,"﴿كَيۡدُهُمۡ﴾: أذى مَكْرِهم."
  3,121,"﴿غَدَوۡتَ مِنۡ أَهۡلِكَ﴾: خَرَجْتَ من بيتِك يومَ أُحُدٍ.﴿تُبَوِّئُ ٱلۡمُؤۡمِنِينَ﴾: تَتَّخِذُ لهم."
  3,122,"﴿طَّآئِفَتَانِ﴾: هما بنو سَلِمَةَ وبنو حارثةَ، حَدَّثَتْهم أنفسُهم يومَ أُحُدٍ بالرُّجوعِ عن لقاءِ العدوِّ، ولكنَّ اللهَ عَصَمَهم.﴿تَفۡشَلَا﴾: تَجْبُنا.﴿وَلِيُّهُمَا﴾: الدافعُ عنهما الضَّعْفَ."
  3,123,"﴿أَذِلَّةࣱ﴾: قليلو العَدَدِ والعُدَّةِ."
  3,124,"﴿مُنزَلِينَ﴾: من السماءِ يُقاتِلون معكم."
  3,125,"﴿وَيَأۡتُوكُم﴾: ويأتي كفارُ مكةَ لقتالِكم.﴿مِّن فَوۡرِهِمۡ هَـٰذَا﴾: مِن ساعَتِهم هذه.﴿مُسَوِّمِينَ﴾: مُعْلِمِين أنفسَهم بعلاماتٍ واضِحاتٍ."
  3,126,"﴿وَمَا جَعَلَهُ﴾: وما جَعَلَ هذا الإمدادَ بالملائكةِ."
  3,127,"﴿لِيَقۡطَعَ طَرَفࣰا﴾: ليُهلِكَ فريقًامن الكفّارِ بالقَتْلِ.﴿أَوۡ يَكۡبِتَهُمۡ﴾: أو يُغِيظَهم، ويُحْزِنَهم.﴿فَيَنقَلِبُواْ خَآئِبِينَ﴾: فيعودُوا غيرَ ظافِرين بمَطْلَبِهم."
  3,129,"3:128"
  3,130,"﴿أَضۡعَـٰفࣰا مُّضَـٰعَفَةࣰ﴾: كانوا في الجاهليةِ إذا حانَ موعِدُ السَّدادِ يقولُ المقترضُ: أخِّرْ عني، وأَزِيدُك."
  3,132,"3:131"
  3,133,"3:131"
  3,134,"﴿ٱلسَّرَّآءِ﴾: في اليُسْرِ وسَعَةِ العيشِ.﴿وَٱلضَّرَّآءِ﴾: الضِّيقِ والشدةِ.﴿وَٱلۡكَـٰظِمِينَ﴾: الذين يُمْسِكون مافي أنفسِهم من الغيظِ بالصبر.﴿وَٱلۡعَافِينَ﴾: والذين يَصْفَحُون عمَّن ظَلَمَهم."
  3,135,"﴿فَـٰحِشَةً﴾: هي الفعْلَةُ القبيحةُ الخارجةُ عَمّا أذِنَ اللهُ.﴿ظَلَمُوٓاْ أَنفُسَهُمۡ﴾: بارتكابِ مادونَ الفاحشةِ.﴿ذَكَرُواْ ٱللَّهَ﴾: ذكَروا وعيدَه على المعصية.﴿وَلَمۡ يُصِرُّواْ﴾: ولم يَثْبُتوا على ما أتَوا من الذُّنوبِ.﴿وَهُمۡ يَعۡلَمُونَ﴾: قُبْحَه."
  3,136,"﴿أَجۡرُ ٱلۡعَـٰمِلِينَ﴾: ثوابُ المطيعين."
  3,137,"﴿خَلَتۡ﴾: مضَتْ.﴿سُنَنࣱ﴾: ماسَنَّه اللهُ في الأممِ المكذِّبة والسُّنَّةُ: المثالُ المُتَّبَعُ.﴿عَـٰقِبَةُ ٱلۡمُكَذِّبِينَ﴾: قد أُمْهِلُ المكذِّبين وأسْتَدْرِجُهم إلى أجَلٍ، ثم أُحِلُّ بهم عُقوبتي، وهذا ماحدَث مع المشركين يومَ أُحُدٍ."
  3,138,"﴿هَـٰذَا﴾: الذي أوضَحْتُه لكم بما تَقَدَّم أو القرآنُ."
  3,139,"﴿وَلَا تَهِنُواْ﴾: ولا تضْعُفُوا بالذي نالَكم يومَ أُحُدٍ.﴿ٱلۡأَعۡلَوۡنَ﴾: الغالِبُون على عَدُوِّكم بالنصرِ."
  3,140,"﴿قَرۡحࣱ﴾: جِراْحٌ وقَتْلٌ يومَ أُحُد.﴿مِّثۡلُهُۥ﴾: يومَ بدرٍ.﴿نُدَاوِلُهَا﴾: يُصَرِّفُها اللهُ، فيظفَرُ المؤمنُ بالكافر، والكافرُ بالمؤمن.﴿وَيَتَّخِذَ مِنكُمۡ شُهَدَآءَ﴾: ويُكَرِّمَ أقوامًا بالشهادةِ."
  3,141,"﴿وَلِيُمَحِّصَ﴾: ولِيَخْتبرَ.﴿وَيَمۡحَقَ﴾: ويُهْلِكَهم."
  3,142,"﴿وَلَمَّا يَعۡلَمِ﴾: أي: عِلْمًا ظاهرًا للخَلْقِ."
  3,143,"﴿ٱلۡمَوۡتَ﴾: أسبابَه. وكان قومٌ من الصَّحابة مِمَّنْ لم يَشْهدوا بدرًا تمنَّوا أن يجاهِدُوا.﴿فَقَدۡ رَأَيۡتُمُوهُ﴾: حَصَلَ ذلك يومَ أُحُدٍ، ولكن فَرَّ بعضُهم، وصَبَر بعضُهم."
  3,144,"﴿خَلَتۡ﴾: مَضَتْ، فسوف يَقْبِضُه اللهُ إليه عند انقضاءِ أجَلِه.﴿ٱنقَلَبۡتُمۡ عَلَىٰٓ أَعۡقَـٰبِكُمۡ﴾: ارتَددْتُم عن دينِكم.﴿فَلَن يَضُرَّ ٱللَّهَ﴾: فلن يُوهِنَ ذلك عزةَ اللهِ ولا سُلطانَه، وإنما يَضُرُّ نفسَه.﴿ٱلشَّـٰكِرِينَ﴾: على نِعْمَةِ الإسلامِ، الثابتين على دينِهم."
  3,145,"﴿بِإِذۡنِ ٱللَّهِ﴾: بقَدَرِه حتى يَسْتوفيَ مُدَّتَه.﴿كِتَـٰبࣰا﴾: كَتَبَ اللهُ ذلك كتابًا.﴿مُّؤَجَّلࣰا﴾: مؤقتًا لا يتقدَّمُ على أجَلهِ ولا يتأخَّرُ.﴿نُؤۡتِهِۦ مِنۡهَا﴾: أي: ما قُسِم له فيها من رزقٍ."
  3,146,"﴿وَكَأَيِّن﴾: كثيرٌ.﴿رِبِّيُّونَ كَثِيرࣱ﴾: جموعٌ كثيرةٌ من أصحابِهم، أو علماءُ.﴿وَهَنُواْ﴾: ضَعُفُوا.﴿وَمَا ٱسۡتَكَانُواْ﴾: ما ذَلُّوا لعَدُوِّهم."
  3,147,"﴿وَإِسۡرَافَنَا﴾: من الذُّنوبِ الكَبائرِ."
  3,148,"﴿ثَوَابَ ٱلدُّنۡيَا﴾: بالنصر، والتمكينِ في الأرض.﴿وَحُسۡنَ ثَوَابِ ٱلۡـَٔاخِرَةِ﴾: وخيرَ جزاءِ الآخرةِ.﴿وَٱللَّهُ يُحِبُّ ٱلۡمُحۡسِنِينَ﴾: مَن أحسنَ عبادتَه لربِّه."
  3,149,"﴿يَرُدُّوكُمۡ عَلَىٰٓ أَعۡقَـٰبِكُمۡ﴾: يُضِلُّوكم عن طريقِ الحقِّ."
  3,150,"﴿مَوۡلَىٰكُمۡ﴾: ناصِرُكم."
  3,151,"﴿سَنُلۡقِي فِي قُلُوبِ ٱلَّذِينَ كَفَرُواْ ٱلرُّعۡبَ﴾: لأنّ المشركين عَزَمُوا على استئصالِ المسلمين بعد أُحُدٍ، ولكنَّ اللهَ قَذَفَ فيهم الرُّعْبَ، فرجَعوا عَمّا هَمُّوا به.﴿سُلۡطَـٰنࣰا﴾: دليلًا على استحقاقِها العبادةَ.﴿مَثۡوَى﴾: مكانُ الإقامةِ."
  3,152,"﴿صَدَقَكُمُ ٱللَّهُ وَعۡدَهُۥٓ﴾: حَقَّقَ ما وعَدَكم مِن نَصْرٍ في أُحُدٍ قبلَ تَرْكِ الرُّماةِ مقاعِدَهم.﴿تَحُسُّونَهُم﴾: تستأصِلُونهم بالقَتْلِ.﴿فَشِلۡتُمۡ﴾: جَبُنتم. وجواب «إذا» مقدرٌ: امتُحِنْتُم.﴿وَتَنَـٰزَعۡتُمۡ﴾: اختلَفْتم: هل تَبْقَون في مَواقِعِكم، أو تتركونها للغَنائم؟﴿صَرَفَكُمۡ﴾: رَدَّكم عنهم بالهزيمةِ.﴿لِيَبۡتَلِيَكُمۡ﴾: ليَخْتَبِرَكم."
  3,153,"﴿تُصۡعِدُونَ﴾: تَسِيرون في مستوى الأرضِ وبُطونِ الأوديةِ هاربين.﴿وَلَا تَلۡوُۥنَ﴾: لاتَلْتَفِتُون إلى أحَدٍ.﴿فِيٓ أُخۡرَىٰكُمۡ﴾: في الطائفةِ المتأخرةِ.﴿فَأَثَـٰبَكُمۡ﴾: فجازاكم.﴿غَمَّۢا بِغَمࣲّ﴾: الغَمُّ الأولُ ما أُشيعَ من قَتْل الرسولِ ﷺ، والثاني: ما نالهم من القَتْلِ والجِراحِ.﴿عَلَىٰ مَا فَاتَكُمۡ﴾: من نَصْرٍ وغنيمةٍ. وفَعَلَ بكم ذلك تدريبًا لاحتمالِ الشدائدِ."
  3,154,"﴿أَمَنَةࣰ﴾: أمانًا.﴿طَآئِفَةࣰ مِّنكُمۡ﴾: هم أهلُ الإخلاصِ.﴿أَهَمَّتۡهُمۡ أَنفُسُهُمۡ﴾: خَلاصُ أنفسِهم من القَتْلِ، وهم المنافقون.﴿ظَنَّ ٱلۡجَـٰهِلِيَّةِ﴾: بأنّ الإسلامَ لن تقومَ له قائمةٌ.﴿هَل لَّنَا مِنَ ٱلۡأَمۡرِ مِن شَيۡءࣲ﴾: هل كان لنا من اختيارٍ في الخروجِ للقتالِ؟﴿يُخۡفُونَ﴾: من الحَسْرةِ على خروجِهم للقتالِ.﴿إِلَىٰ مَضَاجِعِهِمۡ﴾: إلى المواضع التي كُتِبَ عليهم أنْ يُقْتَلَوا فيها.﴿مَا فِي صُدُورِكُمۡ﴾: من الشَّكِّ، والنفاق.﴿وَلِيُمَحِّصَ﴾: ليمِيزَ الخبيثَ من الطَّيِّبِ."
  3,155,"﴿تَوَلَّوۡاْ﴾: فَرُّوا.﴿ٱلۡتَقَى ٱلۡجَمۡعَانِ﴾: أي: يومَ أُحُدٍ، والجَمْعان: المؤمنون، والمشركون.﴿ٱسۡتَزَلَّهُمُ﴾: أوْقَعَهم.﴿مَا كَسَبُواْ﴾: من الذُّنوبِ."
  3,156,"﴿كَٱلَّذِينَ كَفَرُواْ﴾: من المنافقين.﴿ضَرَبُواْ فِي ٱلۡأَرۡضِ﴾: سَفَرًا للبحث عن معاشِهم فماتوا.﴿غُزࣰّى﴾: غازين.﴿ذَ ٰ⁠لِكَ﴾: هذا القولُ."
  3,157,"﴿مِّمَّا يَجۡمَعُونَ﴾: ممّا يجْمَعُه أهلُ الدنيا."
  3,159,"﴿فَبِمَا رَحۡمَةࣲ﴾: فبرحمةٍ.﴿فَظًّا﴾: سَيِّئَ الخُلُقِ جافيًا.﴿لَٱنفَضُّواْ﴾: لَتَفرَّقُوا عنك.﴿وَشَاوِرۡهُمۡ﴾: لتقتديَ بك الأمةُ، وذلك في غير ما ورَدَ به الشَّرعُ.﴿فَإِذَا عَزَمۡتَ﴾: عَقِبَ المُشاورةِ، وقَصَدْتَ إمضاءَ الأمرِ."
  3,161,"﴿أَن يَغُلَّ﴾: أن يَخُونَ أصحابَه بأن يأخذَ من الغنيمةِ غيرَ ما اخْتَصَّه اللهُ.﴿بِمَا غَلَّ﴾: بما أخَذَه حاملًا له ليُفضحَ به."
  3,162,"﴿كَمَنۢ بَآءَ بِسَخَطࣲ﴾: كمَن رَجَعَ بغضبٍ شديدٍ."
  3,163,"﴿هُمۡ دَرَجَـٰتٌ﴾: ذوو دَرَجاتٍ، فدَرجاتُ مَنِ اتَّبعَ رضوانَه ليسَتْ كدرجاتِ الآخَرين."
  3,164,"﴿مَنَّ﴾: أنعمَ.﴿مِّنۡ أَنفُسِهِمۡ﴾: من أهلِ لسانِهم.﴿وَيُزَكِّيهِمۡ﴾: ويُطَهِّرُهم.﴿وَٱلۡحِكۡمَةَ﴾: والسُّنَّةَ.﴿وَإِن كَانُواْ﴾: وإنّهم كانوا."
  3,165,"﴿مُّصِيبَةࣱ﴾: يومَ أُحدٍ.﴿أَصَبۡتُم مِّثۡلَيۡهَا﴾: يومَ بدرٍ من المشركين.﴿أَنَّىٰ هَـٰذَا﴾: كيف يكونُ هذا، ونحن مسلمون فينا نبيُّ اللهِ؟﴿مِنۡ عِندِ أَنفُسِكُمۡ﴾: عقوبةٌ لكم بسببِ مخالفتِكم أمْرَ رسولِكم."
  3,166,"﴿يَوۡمَ ٱلۡتَقَى ٱلۡجَمۡعَانِ﴾: يومَ أُحُدٍ.﴿فَبِإِذۡنِ ٱللَّهِ﴾: بعِلْمِه."
  3,167,"﴿ٱدۡفَعُواْ﴾: كونوا عَوْنًا لنا بتكثيرِكم سَوادَنا."
  3,168,"﴿لَوۡ أَطَاعُونَا﴾: بتَرْكِ الخروجِ من المدينةِ.﴿فَٱدۡرَءُواْ﴾: فادفَعُوا."
  3,169,"﴿أَحۡيَآءٌ﴾: حياةً بَرْزَخيةً.﴿عِندَ رَبِّهِمۡ﴾: في الجنةِ."
  3,170,"﴿وَيَسۡتَبۡشِرُونَ﴾: ويَفْرحون.﴿أَلَّا خَوۡفٌ عَلَيۡهِمۡ﴾: فيما يَسْتقبلون من أمورِ الآخرةِ.﴿وَلَا هُمۡ يَحۡزَنُونَ﴾: على مافاتَهم في الدنيا."
  3,172,"﴿ٱلَّذِينَ ٱسۡتَجَابُواْ﴾: هم الذين خرجُوا يَتَعَقَّبون المشركين في «حمراءِ الأسَدِ»، بعد هزيمتِهم في أُحُدٍ.﴿ٱلۡقَرۡحُ﴾: الجراحُ من معركةِ أُحُدٍ."
  3,173,"﴿قَالَ لَهُمُ ٱلنَّاسُ﴾: هم بعضُ المشركين، قالوا: إن أبا سفيان ومَن معه سيعودون إليكم.﴿حَسۡبُنَا ٱللَّهُ﴾: اللهُ كافِينا."
  3,174,"﴿فَٱنقَلَبُواْ﴾: فرَجَعُوا من حمراءِ الأسَدِ."
  3,175,"﴿يُخَوِّفُ أَوۡلِيَآءَهُۥ﴾: يُخَوِّفُكم بأوليائِه."
  3,176,"﴿حَظࣰّا﴾: نصيبًا."
  3,177,"﴿ٱشۡتَرَوُاْ﴾: استبدلُوا."
  3,178,"﴿وَلَا يَحۡسَبَنَّ ٱلَّذِينَ كَفَرُوٓاْ﴾: إذا أطَلْنا أعمارَهم، ومَتَّعْناهم.﴿إِنَّمَا نُمۡلِي لَهُمۡ﴾: نُؤَخِّرُ أجَلَهم، وعذابَهم.﴿إِثۡمࣰا﴾: ظلمًا وطُغيانًا."
  3,179,"﴿لِيَذَرَ﴾: لِيَدَعَ.﴿عَلَىٰ مَآ أَنتُمۡ عَلَيۡهِ﴾: من التباسِ المؤمن مِنكم بالمنافقِ.﴿عَلَى ٱلۡغَيۡبِ﴾: الذي يَعْلَمُه من عبادِه، فتَعْرِفُوا المؤمنَ منهم من المنافقِ، ولكنه يَمِيزُهم بالمِحَنِ.﴿يَجۡتَبِي﴾: يَصْطَفي مِن رُسُله ليُطْلِعَه على شيءٍ من غيبهِ."
  3,180,"﴿سَيُطَوَّقُونَ﴾: سيكونُ طَوْقًا من نارٍ يُوضَعُ في أعناقِهم."
  3,181,"﴿ٱلَّذِينَ قَالُوٓاْ﴾: هم اليهودُ.﴿إِنَّ ٱللَّهَ فَقِيرࣱ﴾: يَطْلبُ منا أن نُقْرِضَه مالًا، وهذا للتشكيكِ على المسلمين."
  3,182,"﴿بِمَا قَدَّمَتۡ أَيۡدِيكُمۡ﴾: من المعاصي."
  3,183,"﴿عَهِدَ إِلَيۡنَآ﴾: في التوراةِ.﴿بِقُرۡبَانࣲ﴾: بصَدَقَةٍ يُتَقَرَّبُ بها إلى الله، فتنزلُ نارٌ من السماءِ فتحرقُها."
  3,184,"﴿بِٱلۡبَيِّنَـٰتِ﴾: بالمعجزاتِ الواضحاتِ.﴿وَٱلزُّبُرِ﴾: الكتبِ التي أنزلها اللهُ."
  3,185,"﴿مَتَـٰعُ ٱلۡغُرُورِ﴾: مُتْعَةٌ زائلةٌ، فلا تَغْترُّوا بها."
  3,186,"﴿لَتُبۡلَوُنَّ﴾: لَتُخْتَبَرُنَّ.﴿فِيٓ أَمۡوَ ٰ⁠لِكُمۡ﴾: بإخراجِ النفقاتِ الواجبةِ والمُسْتَحَبَّةِ، وبالجوائح التي تُصيبها.﴿وَأَنفُسِكُمۡ﴾: بما يجبُ عليكم من الطاعاتِ، وما يَحُلُّ بكم من الجِراح، وفَقْدِ الأحبابِ.﴿مِنۡ عَزۡمِ ٱلۡأُمُورِ﴾: من الأمورِ التي يُتنافَسُ فيها."
  3,187,"﴿مِيثَـٰقَ﴾: العهدَ المُوَثَّقَ.﴿فَنَبَذُوهُ﴾: تركُوا العملَ به﴿وَٱشۡتَرَوۡاْ بِهِۦ ثَمَنࣰا قَلِيلࣰا﴾: أخذُوا ثمنًا بَخْسًا مقابلَ كِتْمانِهم الحقَّ، وتحريفِهم كتبَهم."
  3,188,"﴿ٱلَّذِينَ يَفۡرَحُونَ﴾: أهلَ الكتابِ ومَن كان مثلَهم من الذين أخَذَ ميثاقَهم.﴿بِمَآ أَتَواْ﴾: بكِتْمانهم أنّ النبيَّ ﷺ مُرْسَلٌ بالحقِّ.﴿بِمَفَازَةࣲ﴾: بمَنجاةٍ."
  3,190,"﴿وَٱخۡتِلَـٰفِ ٱلَّيۡلِ وَٱلنَّهَارِ﴾: في تَعاقُبِهِما واختلافِهما طُولًا وقِصَرًا.﴿لَـَٔايَـٰتࣲ﴾: لَدلائلَ.﴿ٱلۡأَلۡبَـٰبِ﴾: العقولِ السليمةِ."
  3,191,"﴿وَيَتَفَكَّرُونَ﴾: ويتدبَّرون.﴿بَـٰطِلࣰا﴾: عَبَثًا.﴿سُبۡحَـٰنَكَ﴾: نُنَزِّهُك."
  3,192,"﴿أَخۡزَيۡتَهُۥ﴾: أهَنْتَه، وهو الخالدُ فيها."
  3,193,"﴿مُنَادِيࣰا﴾: هو محمدٌ ﷺ.﴿ٱلۡأَبۡرَارِ﴾: الصالحين."
  3,194,"﴿وَلَا تُخۡزِنَا﴾: ولاتَفْضَحْنا بذنوبِنا."
  3,195,"﴿بَعۡضُكُم مِّنۢ بَعۡضࣲ﴾: هم سَواءُ في الجزاءِ على العملِ."
  3,196,"﴿لَا يَغُرَّنَّكَ تَقَلُّبُ ٱلَّذِينَ كَفَرُواْ﴾: لا تَغْتَرَّ بما عليه أهلُ الكفرِ من تَصَرُّفِهم في الأرضِ وضَرْبِهم فيها."
  3,197,"﴿مَأۡوَىٰهُمۡ﴾: مصيرُهم.﴿ٱلۡمِهَادُ﴾: الفِراشُ والمَضْجَعُ."
  3,198,"﴿نُزُلࣰا﴾: هوما يُهَيَّأ للنَّزيلِ ضِيافةً."
  3,199,"﴿ثَمَنࣰا قَلِيلًا﴾: من حُطامِ الدُّنيا، فلايكتُمون ما أنزلَ اللهُ ولايُحَرِّفُونه."
  3,200,"﴿وَصَابِرُواْ﴾: أي غالِبُوا أعداءَكم في الصَّبْرِ.﴿وَرَابِطُواْ﴾: وأقِيمُوا على جهادِ العَدُوِّ."
