tafsir[268]{c,v,t}:
  2,1,"﴿الٓمٓ﴾: هذه الحروفُ المقطَّعَةُ تُشيرُ إلى أنّ القرآنَ مركَّبٌ من هذه الحروفِ التي تألَّفَتْ منها لغةُ العربِ، وقد عَجَزَ العربُ وغيرُهم عَنِ الإتيانِ بمثلِ القرآنِ، فدلَّ هذا على أن القرآنَ وحْيٌ من اللهِ."
  2,2,"﴿ٱلۡكِتَـٰبُ﴾: القرآنُ.﴿لَا رَيۡبَۛ فِيهِ﴾: لا شكَّ أنّه مِن عندِ اللهِ.﴿لِّلۡمُتَّقِينَ﴾: الذين يَخافون اللهَ، ويتَّبعون أحكامَه."
  2,3,"﴿يُؤۡمِنُونَ﴾: يُصَدِّقُون.﴿بِٱلۡغَيۡبِ﴾: بما لا يُدْرَكُ بالحواسِّ والعُقولِ، فلا يُعْرَفُ إلا بالوَحْيِ، كالإيمانِ بالملائكةِ.﴿وَيُقِيمُونَ﴾: يحافظون على أدائِها في مواقيتِها وفْقَ ما شَرَعَ اللهُ."
  2,4,"﴿بِمَآ أُنزِلَ إِلَيۡكَ﴾: إلى محمدٍ ﷺ، مِنَ القرآنِ والسُّنةِ.﴿وَمَآ أُنزِلَ مِن قَبۡلِكَ﴾: مِن كُتُبٍ كالتَّوراةِ والإنجيلِ﴿وَبِٱلۡـَٔاخِرَةِ هُمۡ يُوقِنُونَ﴾: يُصَدِّقُون بدارِ الحياةِ بعد الموتِ، وما فيها مِنَ الحِسابِ."
  2,5,"﴿ٱلۡمُفۡلِحُونَ﴾: الفائِزون."
  2,6,"﴿كَفَرُواْ﴾: جَحَدُوا ما أُنْزِلَ إليك من ربِّك.﴿سَوَآءٌ﴾: مُتَساوٍ.﴿ءَأَنذَرۡتَهُمۡ﴾: أخَوَّفْتَهم، وحَذَّرْتَهم."
  2,7,"﴿خَتَمَ﴾: طَبَعَ عليها، فلا تَعِي خيرًا.﴿غِشَـٰوَةࣱ﴾: غطاءٌ، فلم يُوَفِّقْهم للهُدى.﴿عَذَابٌ﴾: نارُ جَهنَّمَ في الآخِرَةِ."
  2,8,"﴿وَمِنَ ٱلنَّاسِ﴾: فريقُ المُنافقين الذين يَقُولون بألسِنَتِهم: صَدَّقْنا، وهم في باطنِهم كاذِبُون."
  2,9,"﴿يُخَـٰدِعُونَ﴾: يُظْهِرُون خِلافَ ما يُضْمِرُون.﴿وَمَا يَشۡعُرُونَ﴾: وما يُحِسُّون بذلك؛ لفسادِ قُلوبهِم."
  2,10,"﴿مَّرَضࣱ﴾: شكٌّ وفسادٌ."
  2,11,"﴿لَا تُفۡسِدُواْ﴾: بالمعاصِي، وإفشاءِ أسرارِ المؤمنين ومُوالاةِ الكافرين."
  2,13,"﴿ءَامِنُواْ﴾: صَدِّقُوا بقُلوبِكم، وألسنتِكم، وجَوارِحِكم.﴿ٱلسُّفَهَآءُ﴾: ضعافُ العقولِ والرأيِ، يَعْنُون بهم الصَّحابةَ.﴿لَّا يَعۡلَمُونَ﴾: ما هم فيه مِنَ الخُسرانِ."
  2,14,"﴿شَيَـٰطِينِهِمۡ﴾: زُعَمائِهم.﴿مُسۡتَهۡزِءُونَ﴾: مُسْتَخِفُّون بالمؤمنين، ساخرُون منهم."
  2,15,"﴿وَيَمُدُّهُمۡ﴾: يُمْهِلُهم.﴿طُغۡيَـٰنِهِمۡ﴾: ضَلالَتِهم.﴿يَعۡمَهُونَ﴾: يَتَردَّدُون."
  2,16,"﴿ٱشۡتَرَوُاْ ٱلضَّلَـٰلَةَ بِٱلۡهُدَىٰ﴾: استبدَلُوا الكفرَ بالإيمانِ."
  2,17,"﴿مَثَلُهُمۡ﴾: شَبَهُ المنافقين.﴿ٱسۡتَوۡقَدَ﴾: أوقَدَ.﴿أَضَآءَتۡ﴾: سَطَعَتْ وأنارَتْ."
  2,18,"﴿صُمُّۢ﴾: عَنْ سَماعِ الحقِّ سماعَ تَدَبُّر، والصَّمَمُ: الانسدادُ.﴿بُكۡمٌ﴾: عن النُّطقِ بالحق، والبُكْمُ: الخُرْسُ.﴿عُمۡيࣱ﴾: عَنْ إبصارِ نورِ الهدايةِ.﴿لَا يَرۡجِعُونَ﴾: لا يعُودون إلى الإيمانِ."
  2,19,"﴿أَوۡ﴾: هذا شَبَهُ فريقٍ آخرَ من المنافقين الذين يَظْهَرُ لهم الحقُّ تارةً، ويَشُكُّون فيه تارة.﴿كَصَيِّبࣲ﴾: الصَّيِّب: المَطَرُ الشَّديدُ، والمعنى: كأصحابِ صَيِّبٍ.﴿ٱلصَّوَ ٰ⁠عِقِ﴾: جَمْعُ صاعِقَةٍ، وهي العذابُ المُهْلِكُ المُحْرِقُ.﴿مُحِيطُۢ بِٱلۡكَـٰفِرِينَ﴾: لا يَفُوتونه، ولا يُعْجِزُونه."
  2,20,"﴿يَكَادُ﴾: يُقارِبُ.﴿يَخۡطَفُ﴾: يَسْلُبُ من شِدَّةِ لَمَعانِه.﴿قَامُواْ﴾: وقَفُوا في أماكنِهم مُتَحَيِّرين."
  2,21,"﴿لَعَلَّكُمۡ تَتَّقُونَ﴾: لتَتَّقُوه بطاعَتِه."
  2,22,"﴿جَعَلَ﴾: صَيَّر.﴿فِرَ ٰ⁠شࣰا﴾: بسِاطًا تَسْهُلُ حياتُكم عليه.﴿أَندَادࣰا﴾: نُظَراءَ في العبادةِ.﴿تَعۡلَمُونَ﴾: تَعْلَمُون تَفَرُّدَه بالخَلْقِ والرِّزقِ، واستحقاقَه العبوديةَ."
  2,23,"﴿رَيۡبࣲ﴾: شكٍ.﴿مِّن مِّثۡلِهِۦ﴾: تُماثِلُ سورةً منه.﴿شُهَدَآءَكُم﴾: أعوانَكم الذين يَشْهدون لكم."
  2,24,"﴿لَن تَفۡعَلُواْ﴾: مستقبلًا.﴿وَقُودُهَا﴾: حَطَبُها.﴿أُعِدَّتۡ﴾: هُيِّئَتْ."
  2,25,"﴿وَبَشِّرِ﴾: أخبِرْهم بما يَسُرُّهم.﴿مِن تَحۡتِهَا﴾: من تحتِ قُصُورِ الجنّاتِ العاليةِ وأشجارِها الظَّليلةِ.﴿مِن قَبۡلُ﴾: في الدُّنيا.﴿مُتَشَـٰبِهࣰا﴾: وجَدُوا طَعمًا جديدًا، وإنْ تَشابَه مع سابقِه.﴿مُّطَهَّرَةࣱ﴾: من الدَّنَسِ الحِسِّي كالَحيْضِ، والمعنويِّ كالكَذِبِ."
  2,26,"﴿لَا يَسۡتَحۡيِۦٓ﴾: من الحقِّ أنَ يذْكُرَ شيئًا مّا، صغيرًا أو كبيرًا.﴿فَمَا فَوۡقَهَا﴾: فما هو أكبرُ منها.﴿ٱلۡفَـٰسِقِينَ﴾: الخارجين عن طاعةِ الله."
  2,27,"﴿يَنقُضُونَ﴾: يَنْكُثون.﴿عَهۡدَ ٱللَّهِ﴾: العهدَ الذي أخذه عليهم بالتوحيدِ والطّاعةِ.﴿مِنۢ بَعۡدِ مِيثَـٰقِهِۦ﴾: مِن بعدِ تأكيدِه باليمينِ."
  2,28,"﴿أَمۡوَ ٰ⁠تࣰا﴾: عَدَمًا غيرَ مخلوقِين.﴿فَأَحۡيَـٰكُمۡ﴾: فأنشأكم بَشَرًا سويًّا.﴿يُحۡيِيكُمۡ﴾: يوَم الَبْعثِ."
  2,29,"﴿ٱسۡتَوَىٰٓ إِلَى ٱلسَّمَآءِ﴾: ارتفعَ وقَصَدَ إلى خَلْق السمواتِ، وتقديرِ ما في كلِّ واحدةٍ.﴿فَسَوَّىٰهُنَّ﴾: خَلَقَهُنَّ مُسْتَوِياتٍ، ودبَّرَهُنَّ."
  2,30,"﴿خَلِيفَةࣰ﴾: قومًا يَخْلُف بعضُهم بعضًا لعِمارةِ الأرضِ.﴿يَسۡفِكُ ٱلدِّمَآءَ﴾: يُريقُها بغيرِ حَقٍّ.﴿نُسَبِّحُ بِحَمۡدِكَ﴾: نُنَزِّهُك التنزيهَ اللائقَ.﴿وَنُقَدِّسُ لَكَ﴾: نُمَجِّدُك، ونُطَهِّرُ ذِكْرَك عَمّا لا يَليقُ بك."
  2,31,"﴿ٱلۡأَسۡمَآءَ﴾: أسماءَ الأشياءِ التي يَتَعارَفُ بها الناسُ.﴿هَـٰٓؤُلَآءِ﴾: الموجوداتِ التي عَلَّمَها آدمَ."
  2,32,"﴿سُبۡحَـٰنَكَ﴾: تَنْزيهًا للهِ."
  2,33,"﴿بِأَسۡمَآئِهِمۡ﴾: بأسماءِ الأشياءِ التي عَجَزُوا عن معرفتِها.﴿تُبۡدُونَ﴾: تُظْهِرُون.﴿تَكۡتُمُونَ﴾: تُخْفُون."
  2,34,"﴿ٱسۡجُدُواْ لِـَٔادَمَ﴾: إكرامًا له، وإظهارًا لفَضْلهِ.﴿أَبَىٰ﴾: تَكَبُّرًا وحَسَدًا.﴿وَٱسۡتَكۡبَرَ﴾: استعظمَ نفسَه."
  2,35,"﴿رَغَدًا﴾: هنيئًا واسعًا.﴿ٱلظَّـٰلِمِينَ﴾: المتجاوِزين أمرَ اللِه."
  2,36,"﴿فَأَزَلَّهُمَا ٱلشَّيۡطَـٰنُ عَنۡهَا﴾: فأوْقَعَهما الشيطانُ في الخطيئةِ ليُبْعِدَهما عَنِ الجنةِ.﴿بَعۡضُكُمۡ لِبَعۡضٍ﴾: آدمُ، وحواءُ، والشيطانُ.﴿مَتَـٰعٌ﴾: انتفاعٌ، واستمتاعٌ.﴿إِلَىٰ حِينࣲ﴾: إلى وقتِ انتهاءِ آجالِكم."
  2,37,"﴿كَلِمَـٰتࣲ﴾: ما ألْهمه اللهُ مِن كلماتٍ للتَّوبةِ."
  2,38,"﴿فَلَا خَوۡفٌ﴾: آمِنُون من أهوالِ القيامةِ.﴿وَلَا هُمۡ يَحۡزَنُونَ﴾: على ما فاتَهم من الدُّنيا."
  2,40,"﴿ٱذۡكُرُواْ نِعۡمَتِيَ﴾: اصطفائي للرُّسُلِ منكم، وإنزالَ الكتبِ عليكم، ونجاتكم من فرعونَ.﴿وَأَوۡفُواْ بِعَهۡدِيٓ﴾: أتِمُّوا وصِيَّتي لكم بالإيمان بكتبي وبرُسُلي جميعًا.﴿أُوفِ بِعَهۡدِكُمۡ﴾: ما وعَدْتُكم به من الرحمةِ في الدنيا والآخرةِ."
  2,41,"﴿أَوَّلَ كَافِرِۭ بِهِۦ﴾: بالقرآنِ.﴿وَلَا تَشۡتَرُواْ بِـَٔايَـٰتِي ثَمَنࣰا قَلِيلࣰا﴾: ولا تَبيعُوا ما آتيكم به من العِلْم بما في كتابِكم من أمرِ محمدٍ ﷺ، بثمَنٍ بَخْس."
  2,42,"﴿وَلَا تَلۡبِسُواْ﴾: ولا تَخْلِطُوا.﴿وَتَكۡتُمُواْ ٱلۡحَقَّ﴾: وتُخْفُوا صفةَ محمدٍ ﷺ في التوراةِ."
  2,44,"﴿بِٱلۡبِرِّ﴾: بالطاعةِ، والعملِ الصالحِ.﴿ٱلۡكِتَـٰبَ﴾: التوراةَ."
  2,45,"﴿لَكَبِيرَةٌ﴾: شاقةٌ ثقيلةٌ.﴿ٱلۡخَـٰشِعِينَ﴾: الخاضِعين لطاعَتهِ."
  2,46,"﴿يَظُنُّونَ﴾: يُوقِنون."
  2,47,"﴿ٱلۡعَـٰلَمِينَ﴾: عالَمِي زمانِكم؛ بكثرةِ الأنبياءِ، وإنزالِ الكتبِ."
  2,48,"﴿يَوۡمࣰا﴾: يومَ القيامةِ.﴿لَّا تَجۡزِي نَفۡسٌ﴾: لا يُغني أحدٌ عن أحدٍ شيئًا.﴿عَدۡلࣱ﴾: فِدْيةٌ."
  2,49,"﴿نَجَّيۡنَـٰكُم﴾: نَجَّينا آباءَكم.﴿يَسۡتَحۡيُونَ نِسَآءَكُمۡ﴾: يَسْتَبْقُونَهُن للخِدْمةِ والامتهانِ.﴿بَلَآءࣱ﴾: اختبارٌ."
  2,50,"﴿فَرَقۡنَا بِكُمُ ٱلۡبَحۡرَ﴾: فَصَلْنا لكم البحرَ، وجَعَلْنا فيه طُرُقًا يابسةً لعُبورِكم."
  2,51,"﴿ٱتَّخَذۡتُمُ ٱلۡعِجۡلَ﴾: أي مَعبْودًا لكم من دونِ اللهِ."
  2,53,"﴿ٱلۡكِتَـٰبَ﴾: التوراةَ.﴿ٱلۡفُرۡقَانَ﴾: الفارقَ بينَ الحقِّ والباطلِ."
  2,54,"﴿فَٱقۡتُلُوٓاْ أَنفُسَكُمۡ﴾: بأَنْ يَقْتُلَ بعضُكم بعضًا."
  2,55,"﴿جَهۡرَةࣰ﴾: عِيانًا.﴿ٱلصَّـٰعِقَةُ﴾: نارٌ مِنَ السماءِ."
  2,57,"﴿ٱلۡغَمَامَ﴾: السَّحابَ.﴿ٱلۡمَنَّ﴾: شيءٌ يُشْبه الصَّمْغَ، طَعْمُه كالعَسَلِ.﴿ٱلسَّلۡوَىٰ﴾: طيرٌ يُشْبِهُ السُّمانى."
  2,58,"﴿ٱلۡقَرۡيَةَ﴾: بيتَ المَقْدِسِ.﴿رَغَدࣰا﴾: هنيئًا.﴿حِطَّةࣱ﴾: ربَّنا ضَعْ عنا ذُنوبَنا."
  2,59,"﴿رِجۡزࣰا﴾: عذابًا.﴿يَفۡسُقُونَ﴾: يَخْرُجون عن طاعةِ اللهِ."
  2,60,"﴿ٱسۡتَسۡقَىٰ﴾: سألَ اللهَ أنَ يَسْقِيَ قومَه.﴿وَلَا تَعۡثَوۡاْ﴾: ولا تُفْرِطُوا في الفسادِ."
  2,61,"﴿وَقِثَّآئِهَا﴾: جَمْعُ قِثّاءَةٍ، وهو نَبْتٌ ثِمارُه تُشْبِهُ الخِيارَ، ولكنه أطولُ منه.﴿وَفُومِهَا﴾: الحِنْطَةِ.﴿ٱلَّذِي هُوَ أَدۡنَىٰ﴾: الطعامَ الذي هو أقلُّ قَدْرًا وقيمةً.﴿مِصۡرࣰا﴾: أيَّ مدينةٍ.﴿ٱلۡمَسۡكَنَةُ﴾: الفاقَةُ، والحاجَةُ.﴿وَبَآءُو﴾: رَجَعُوا."
  2,62,"﴿وَٱلَّذِينَ هَادُواْ﴾: اليهودَ.﴿ٱلصَّـٰبِـِٔينَ﴾: قومٌ بَقُوا على فِطْرتهم، ولا دينَ مقرَّرٌ لهم.﴿وَلَا هُمۡ يَحۡزَنُونَ﴾: على ما فاتَهُمْ من أمورِ الدُّنيا."
  2,63,"﴿مِيثَـٰقَكُمۡ﴾: العهدَ المؤكَّدَ منكم بالإيمان.﴿ٱلطُّورَ﴾: جبلَ سيناءَ.﴿مَآ ءَاتَيۡنَـٰكُم﴾: الكتابَ الذي أعطيناكم وهو التَّوراةُ.﴿بِقُوَّةࣲ﴾: بجِدٍّ."
  2,64,"﴿تَوَلَّيۡتُم﴾: عَصَيْتُم."
  2,65,"﴿فِي ٱلسَّبۡتِ﴾: في هذا اليومِ الذي أُمِرُوا بتعظيمِه.﴿خَـٰسِـِٔينَ﴾: أذِلَّةً صاغِرين."
  2,66,"﴿نَكَـٰلࣰا﴾: عقوبةً.﴿لِّمَا بَيۡنَ يَدَيۡهَا﴾: من الذنوبِ."
  2,67,"﴿هُزُوࣰا﴾: مَوْضِعَ سُخْرِيَةٍ واستِخْفافٍ."
  2,68,"﴿فَارِضࣱ﴾: المُسِنَّةُ الهَرِمَةُ.﴿بِكۡرٌ﴾: الصغيرةُ الفتيةُ.﴿عَوَانُۢ﴾: متوسطةٌ بين البِكْرِ والهَرِمَةِ."
  2,69,"﴿فَاقِعࣱ لَّوۡنُهَا﴾: شديدةُ الصُّفْرَةِ."
  2,70,"﴿تَشَـٰبَهَ﴾: التبسَ."
  2,71,"﴿لَّا ذَلُولࣱ تُثِيرُ ٱلۡأَرۡضَ﴾: غيرُ مُذَلَّلَةٍ للعَمَلِ في حِراثةِ الأرضِ.﴿ٱلۡحَرۡثَ﴾: الزرعَ.﴿مُسَلَّمَةࣱ﴾: خاليةٌ مِنَ العيوبِ.﴿لَّا شِيَةَ فِيهَا﴾: لا لونَ فيها يخالِفُ لونَ جِلْدِها."
  2,72,"﴿فَٱدَّ ٰ⁠رَ ٰ⁠ـٔتُمۡ﴾: فاختلفتم، كلٌّ يَدْفَعُ عن نفسِه تُهْمَةَ القتلِ.﴿مُخۡرِجࣱ﴾: مُظْهِرٌ."
  2,73,"﴿بِبَعۡضِهَا﴾: بجُزْءٍ مِنَ البقرةِ المذبوحةِ.﴿ءَايَـٰتِهِۦ﴾: معجزاتهِ، وحُجَجَه."
  2,75,"﴿أَن يُؤۡمِنُواْ لَكُمۡ﴾: أن يُصَدِّقَ اليهودُ بدينِكم.﴿كَلَـٰمَ ٱللَّهِ﴾: التوراةَ.﴿يُحَرِّفُونَهُۥ﴾: يَصْرِفُونه عن معناه.﴿عَقَلُوهُ﴾: فَهِمُوه بعقولهِم على الوجهِ الصَّحيحِ."
  2,76,"﴿بِمَا فَتَحَ﴾: بما بَيَّنَ اللهُ لكم في التوراةِ من أمْرِ محمدٍ ﷺ.﴿لِيُحَآجُّوكُم﴾: لتكونَ لهم الحُجَّةُ عليكم في الآخرةِ."
  2,78,"﴿وَمِنۡهُمۡ أُمِّيُّونَ﴾: ومن اليهودِ طائفةٌ يَجْهَلُون القراءةَ والكتابةَ.﴿ٱلۡكِتَـٰبَ﴾: التوراةَ وما فيها من صفاتِ محمدٍ ﷺ.﴿أَمَانِيَّ﴾: أكاذيبَ."
  2,79,"﴿فَوَيۡلࣱ﴾: فوعيدٌ شديدٌ.﴿ثَمَنࣰا قَلِيلࣰا﴾: عَرَضًا مِنَ الدنيا."
  2,80,"﴿عَهۡدࣰا﴾: ميثاقًا بهذا الزعمِ."
  2,81,"﴿سَيِّئَةࣰ﴾: شِرْكًا."
  2,83,"﴿مِيثَـٰقَ﴾: العهدَ المؤكَّدَ.﴿ٱلۡيَتَـٰمَىٰ﴾: الأولادِ الذين ماتَ آباؤُهم وهم دونَ البُلوغِ.﴿وَٱلۡمَسَـٰكِينِ﴾: الذين لا يَمْلِكُون ما يَكْفيهم.﴿حُسۡنࣰا﴾: أطيبَ الكلامِ.﴿مُّعۡرِضُونَ﴾: مستمرُّون في تكذيبِهم."
  2,84,"﴿مِيثَـٰقَكُمۡ﴾: العهدَ المؤكَّدَ في التَّوراة.﴿أَقۡرَرۡتُمۡ﴾: اعترفتُمْ."
  2,85,"﴿هَـٰٓؤُلَآءِ﴾: يا هؤلاءِ.﴿تَظَـٰهَرُونَ عَلَيۡهِم﴾: يتَقَوّى كلٌّ منكم على إخوانِه بالأعداءِ.﴿تُفَـٰدُوهُمۡ﴾: تُحَرِّرُوهم مِنَ الأَسْرِ بدَفْعِ الفِدْيَةِ.﴿ٱلۡكِتَـٰبِ﴾: التوراةِ."
  2,86,"﴿ٱشۡتَرَوُاْ ٱلۡحَيَوٰةَ ٱلدُّنۡيَا﴾: استحَبُّوها."
  2,87,"﴿وَقَفَّيۡنَا﴾: أتْبَعْنا بعضَهم خَلْفَ بعضٍ.﴿ٱلۡبَيِّنَـٰتِ﴾: المعجزاتِ الواضحاتِ.﴿بِرُوحِ ٱلۡقُدُسِ﴾: جبريلَ."
  2,88,"﴿وَقَالُواْ﴾: وقال بنو إسرائيلَ.﴿غُلۡفُۢ﴾: مُغَطّاةٌ لا يَنْفُذُ إليها قولُك."
  2,89,"﴿جَآءَهُمۡ﴾: جاء اليهودَ.﴿كِتَـٰبࣱ﴾: هو القرآنُ الكريمُ.﴿مُصَدِّقࣱ﴾: موافِقٌ.﴿لِّمَا مَعَهُمۡ﴾: من التوراة.﴿مِن قَبۡلُ﴾: مِن قَبْلِ بِعْثَةِ محمدٍ ﷺ.﴿يَسۡتَفۡتِحُونَ﴾: يَسْتَنْصِرُون بالنبيِّ الذي ينتظرونه."
  2,90,"﴿بِئۡسَمَا﴾: قَبُحَ.﴿ٱشۡتَرَوۡاْ﴾: باعوا.﴿بَغۡيًا﴾: ظُلمًا وحَسَدًا.﴿أَن يُنَزِّلَ﴾: من أجْلِ أن يُنَزِّلَ.﴿مِن فَضۡلِهِۦ﴾: هو تنزيلُ القرآنِ على محمدٍ ﷺ.﴿فَبَآءُو﴾: فرَجَعُوا.﴿بِغَضَبٍ﴾: بغَضَبِ اللهِ بسببِ تكذيبِهم للنبيَّ ﷺ.﴿عَلَىٰ غَضَبࣲ﴾: بعد غضبهِ بسببِ تحريفِهم للتوراةِ."
  2,91,"﴿بِمَا وَرَآءَهُۥ﴾: بما أنزل اللهُ بعدَ التوراةِ.﴿لِّمَا مَعَهُمۡ﴾: من التَّوراةِ."
  2,92,"﴿بِٱلۡبَيِّنَـٰتِ﴾: بالمُعْجِزاتِ الواضحاتِ.﴿ٱتَّخَذۡتُمُ ٱلۡعِجۡلَ﴾: أي مَعْبودًا."
  2,93,"﴿مِيثَـٰقَكُمۡ﴾: العهدَ المؤكَّدَ.﴿ٱلطُّورَ﴾: جبلَ الطُّورِ.﴿وَأُشۡرِبُواْ فِي قُلُوبِهِمُ ٱلۡعِجۡلَ﴾: امتزجَ حُبُّ عبادَةِ العِجْلِ بقُلوبهِم."
  2,94,"﴿خَالِصَةࣰ﴾: خاصةً بكم.﴿فَتَمَنَّوُاْ ٱلۡمَوۡتَ﴾: ادْعُوا بالموتِ على الكاذبِ."
  2,95,"﴿قَدَّمَتۡ﴾: كَسَبَتْ."
  2,96,"﴿بِمُزَحۡزِحِهِۦ﴾: مُبْعِدِه، ومُنْجِيه.﴿أَن يُعَمَّرَ﴾: طولُ العُمْرِ."
  2,97,"﴿مَن كَانَ﴾: هم اليهودُ الزاعمون أنّ جبريلَ عَدُوٌّ لهم.﴿لِّمَا بَيۡنَ يَدَيۡهِ﴾: لما قبلَه مِنَ الكُتُب."
  2,99,"﴿بَيِّنَـٰتࣲ﴾: علاماتٍ دالّاتٍ على نُبُوَّتك.﴿ٱلۡفَـٰسِقُونَ﴾: الخارجون عن دينِ اللهِ."
  2,100,"﴿عَهۡدࣰا﴾: هو الميثاقُ الذي أعطاه اليهودُ رَبَّهم.﴿نَّبَذَهُۥ﴾: نَقَضَه."
  2,102,"﴿مَا تَتۡلُواْ ٱلشَّيَـٰطِينُ﴾: ما تُحَدِّثُ به الشياطينُ السَّحَرَةَ.﴿عَلَىٰ مُلۡكِ﴾: على عَهْدِ.﴿وَمَآ أُنزِلَ﴾: وكذلك اتَّبَعَ اليهودُ السِّحْرَ الذي أُنْزِلَ على الملَكَين. وقد عَلَّم اللهُ الملَكَين السِّحْرَ ابتلاءً منه.﴿فِتۡنَةࣱ﴾: ابتلاءٌ يَختبرُ اللهُ بهما عبادَه، وهو تعليمُ إنذارٍ من السِّحْرِ، لا تعليمُ دعوةٍ.﴿فَلَا تَكۡفُرۡ﴾: بتعَلُّمِ السِّحْرِ، وطاعةِ الشياطين.﴿ٱشۡتَرَىٰهُ﴾: اختار السِّحْرَ، واستحَبَّه.﴿خَلَـٰقࣲ﴾: نصيبٍ في الخيرِ."
  2,103,"﴿لَمَثُوبَةࣱ﴾: ثوابُ اللهِ."
  2,104,"﴿رَ ٰ⁠عِنَا﴾: أي: سَمْعَك، فافهَمْ عنا، وأفْهِمْنا.﴿ٱنظُرۡنَا﴾: انظُرْ إلينا وتَعَهَّدْنا."
  2,105,"﴿يَخۡتَصُّ﴾: يُؤْثِرُ."
  2,106,"﴿مَا نَنسَخۡ﴾: ما نُبَدِّلْ.﴿نُنسِهَا﴾: نَمْحُها مِنَ القُلوبِ."
  2,107,"﴿وَلِيࣲّ﴾: قَيِّمٍ بأمرِكم."
  2,108,"﴿سَوَآءَ ٱلسَّبِيلِ﴾: طريقَ اللهِ المستقيم."
  2,109,"﴿يَرُدُّونَكُم﴾: يُرْجِعُونكم.﴿بِأَمۡرِهِۦٓ﴾: بحُكْمِه فيهم."
  2,110,"﴿وَمَا تُقَدِّمُواْ﴾: وما تَعْمَلُوا مِن عَمَلٍ."
  2,111,"﴿أَمَانِيُّهُمۡ﴾: أوهامُهم الفاسدةُ.﴿بُرۡهَـٰنَكُمۡ﴾: حُجَّتَكم."
  2,112,"﴿أَسۡلَمَ﴾: أخلَصَ لطاعَتِه.﴿وَهُوَ مُحۡسِنࣱ﴾: مُتَّبِعٌ للرسولِ ﷺ."
  2,113,"﴿عَلَىٰ شَيۡءࣲ﴾: أي: من الدِّينِ الصَّحيحِ.﴿وَهُمۡ يَتۡلُونَ ٱلۡكِتَـٰبَ﴾: يَقْرَؤون التوراةَ والإنجيلَ، وفيهما الإيمانُ بالأنبياءِ جميعًا.﴿ٱلَّذِينَ لَا يَعۡلَمُونَ﴾: هم مُشْرِكو العربِ وغيرُهم.﴿يَحۡكُمُ﴾: يَفْصِلُ، ويَقْضي."
  2,114,"﴿وَمَنۡ أَظۡلَمُ﴾: لا أحدَ أظلمُ.﴿خِزۡيࣱ﴾: ذِلَّةٌ وهَوانٌ."
  2,115,"﴿تُوَلُّواْ﴾: تَتَوَجَّهُوا.﴿فَثَمَّ وَجۡهُ﴾: فإنكم مُبْتَغُون وجْهَه.﴿وَ ٰ⁠سِعٌ﴾: واسعُ الرحمةِ بعبادِه."
  2,116,"﴿سُبۡحَـٰنَهُۥ﴾: تَنَزَّهَ عن هذا الباطلِ.﴿قَـٰنِتُونَ﴾: خاضِعُون له، مُطيعون."
  2,117,"﴿بَدِيعُ﴾: مُبْدِعٌ على غيرِ مثالٍ سَبَقَ."
  2,118,"﴿لَوۡلَا﴾: هَلّا.﴿ءَايَةࣱ﴾: مُعْجزةٌ.﴿تَشَـٰبَهَتۡ﴾: في الكُفرِ والعِنادِ.﴿يُوقِنُونَ﴾: يُصَدِّقُون ويَتَّبِعُون الرسولَ ﷺ."
  2,119,"﴿بَشِيرࣰا﴾: للمؤمنين بخَيْرَي الدُّنيا و الآخرةِ.﴿وَنَذِيرࣰا﴾: ومُخَوِّفًا للمعانِدِين بالعذابِ."
  2,120,"﴿مِلَّتَهُمۡ﴾: دينَهم.﴿هُوَ ٱلۡهُدَىٰ﴾: الدِّينُ الصحيحُ.﴿وَلِيࣲّ﴾: قريبٍ يمنعُك من عذابِ اللهِ."
  2,121,"﴿حَقَّ تِلَاوَتِهِۦٓ﴾: يَتَّبِعُونه حَقَّ اتِّباعِه."
  2,122,"﴿ٱلۡعَـٰلَمِينَ﴾: عالَمِي زَمانِكم بكثرةِ الأنبياءِ، وإنزالِ الكُتُبِ."
  2,123,"﴿لَّا تَجۡزِي﴾: لا تُغْني.﴿عَدۡلࣱ﴾: فِدْيَةٌ تُنْجِيها من العذابِ.﴿شَفَـٰعَةࣱ﴾: وساطةٌ في حُصولِ النفعِ."
  2,124,"﴿ٱبۡتَلَىٰٓ﴾: اختبرَ.﴿بِكَلِمَـٰتࣲ﴾: بما شَرَع له من تعاليمَ.﴿فَأَتَمَّهُنَّ﴾: فأدّاهن على الوجهِ الأكمَلِ.﴿إِمَامࣰا﴾: قُدوةً للناس.﴿وَمِن ذُرِّيَّتِي﴾: واجعَلْ بعضَ نَسْلي مَن يُقْتَدى به.﴿عَهۡدِي﴾: الإمامةُ في الدِّين."
  2,125,"﴿ٱلۡبَيۡتَ﴾: الكعبةَ.﴿مَثَابَةࣰ﴾: مَرْجِعًا ومَجْمَعًا للناسِ.﴿مَّقَامِ إِبۡرَ ٰ⁠هِـۧمَ﴾: الحَجَرِ الذي وقَفَ عليه.﴿وَعَهِدۡنَآ﴾: وأَوْحَينا.﴿ٱلۡعَـٰكِفِينَ﴾: المقيمينَ فيه للعبادةِ."
  2,126,"﴿أُمَتِّعُهُۥ﴾: فأَرْزُقُه في حياتهِ.﴿أَضۡطَرُّهُۥٓ﴾: أُلْجِئُه.﴿ٱلۡمَصِيرُ﴾: المَرْجِعُ."
  2,127,"﴿ٱلۡقَوَاعِدَ مِنَ ٱلۡبَيۡتِ﴾: أُسُس الكعبةِ التي تنهضُ عليها."
  2,128,"﴿مُسۡلِمَيۡنِ لَكَ﴾: منقادَيْن لأحكامِك.﴿مُّسۡلِمَةࣰ﴾: منقادةً.﴿وَأَرِنَا مَنَاسِكَنَا﴾: بَصِّرْنا بمعالِم عِبادتِنا."
  2,129,"﴿فِيهِمۡ﴾: في هذه الأمةِ.﴿مِّنۡهُمۡ﴾: من ذريةِ إسماعيلَ.﴿ٱلۡكِتَـٰبَ وَٱلۡحِكۡمَةَ﴾: القرآنَ، والسُنَّةَ.﴿وَيُزَكِّيهِمۡ﴾: يُطَهِّرُهم من الشِّرْكِ، وسوءِ الأخلاقِ."
  2,130,"﴿يَرۡغَبُ عَن مِّلَّةِ إِبۡرَ ٰ⁠هِـۧمَ﴾: يُعْرِضُ عن دينِه.﴿سَفِهَ نَفۡسَهُۥ﴾: جَهِلَتْ نَفْسُه ما ينفعُها.﴿ٱصۡطَفَيۡنَـٰهُ﴾: اختَرناه."
  2,131,"﴿أَسۡلِمۡ﴾: أخْلِصْ نفسَك لله."
  2,132,"﴿ٱصۡطَفَىٰ﴾: اختارَ."
  2,133,"﴿كُنتُمۡ﴾: أيُّها اليهودُ.﴿شُهَدَآءَ﴾: حاضِرِين، فلا تَدَّعُوا الأباطيلَ.﴿مُسۡلِمُونَ﴾: مُنْقادُون، خاضِعُون."
  2,134,"﴿خَلَتۡ﴾: مَضَتْ.﴿مَا كَسَبَتۡ﴾: ما عَمِلَتْ."
  2,135,"﴿تَهۡتَدُواْ﴾: تُصِيبوا الحقَّ.﴿بَلۡ مِلَّةَ إِبۡرَ ٰ⁠هِـۧمَ﴾: بل الهدايةُ أن نتَّبعَ دينَ إبراهيمَ.﴿حَنِيفࣰا﴾: مائلًا عن الباطلِ."
  2,136,"﴿وَٱلۡأَسۡبَاطِ﴾: هم الأنبياءُ من ولَدِ يعقوبَ في قبائلِ بني إسرائيلَ الاثنتي عَشْرَةَ.﴿مُسۡلِمُونَ﴾: خاضعون."
  2,137,"﴿تَوَلَّوۡاْ﴾: أعْرَضُوا.﴿شِقَاقࣲ﴾: خلافٍ شديدٍ.﴿فَسَيَكۡفِيكَهُمُ ٱللَّهُ﴾: سيَكْفيك شَرَّهم."
  2,138,"﴿صِبۡغَةَ ٱللَّهِ﴾: الزَمُوا دينَ اللهِ الإسلامَ.﴿صِبۡغَةࣰ﴾: دِينًا."
  2,139,"﴿أَتُحَآجُّونَنَا﴾: أتجادِلُوننا وتخاصِمُوننا؟﴿مُخۡلِصُونَ﴾: لا نعبدُ أحدًا غيره."
  2,140,"﴿وَمَنۡ أَظۡلَمُ﴾: لا أحدَ أظلمُ.﴿كَتَمَ﴾: أخْفى، وادَّعى خِلافَها."
  2,141,"﴿خَلَتۡ﴾: مَضَتْ.﴿كَسَبَتۡ﴾: عَمِلَتْ."
  2,142,"﴿ٱلسُّفَهَآءُ﴾: الجُهّالُ وضِعافُ العقولِ، وهم اليهودُ.﴿مَا وَلَّىٰهُمۡ﴾: أيُّ شيءٍ صَرَفَ المسلمين؟﴿عَن قِبۡلَتِهِمُ﴾: عن بيتِ المقْدِسِ، وهي قِبلة المسلمين أولَ الإسلامِ.﴿صِرَ ٰ⁠طࣲ﴾: طريقٍ."
  2,143,"﴿وَسَطࣰا﴾: عُدُولًا خِيارًا، لا إفراطَ عندكم، ولا تفْريطَ.﴿لِّتَكُونُواْ شُهَدَآءَ﴾: لتَشْهَدُوا على الأممِ في الآخرةِ أنّ رُسُلَهم بَلَّغُوا.﴿شَهِيدࣰا﴾: يشهدُ أنه بَلَّغَ الرسالةَ إلى أمَّتِه.﴿ٱلَّتِي كُنتَ عَلَيۡهَآ﴾: التي صَرَفْناك عنها إلى الكعبةِ.﴿يَنقَلِبُ عَلَىٰ عَقِبَيۡهِ﴾: يَرْتَدُّ عن دينِه.﴿وَإِن كَانَتۡ﴾: وإنّ تحويلَ الِقْبلَةِ.﴿لَكَبِيرَةً﴾: لَثقيلةً شاقةً.﴿لِيُضِيعَ إِيمَـٰنَكُمۡ﴾: يُبْطِلَ صلاتَكم إلى القِبْلَةِ السّابقةِ."
  2,144,"﴿فِي ٱلسَّمَآءِ﴾: أي: انتظارًا للوَحْي في شأنِ القِبْلَةِ.﴿فَلَنُوَلِّيَنَّكَ﴾: فَلنُوَجِّهَنّك.﴿فَوَلِّ وَجۡهَكَ﴾: اصرِفْ وجْهَك.﴿شَطۡرَ﴾: جِهَةَ.﴿فَوَلُّواْ﴾: فَتَوجَّهُوا.﴿أَنَّهُ ٱلۡحَقُّ﴾: أن تحويلَكَ إلى الكعبةِ هو الثابتُ في كُتُبهِم."
  2,145,"﴿ءَايَةࣲ﴾: حُجَّةٍ.﴿ٱلظَّـٰلِمِينَ﴾: لأنفسِهم، المخالِفِين لأمرِ ربِّهم."
  2,146,"﴿ٱلَّذِينَ ءَاتَيۡنَـٰهُمُ ٱلۡكِتَـٰبَ﴾: هم أحبارُ اليهود، وعلماءُ النَّصارى.﴿يَعۡرِفُونَهُۥ﴾: يَعْرِفُون محمدًا، أو يَعْرِفُون أن البيتَ الحرامَ قِبْلَتُهم، وقبلةُ الأنبياءِ السابقين."
  2,147,"﴿ٱلۡمُمۡتَرِينَ﴾: الشّاكِّين."
  2,148,"﴿وَلِكُلࣲّ وِجۡهَةٌ﴾: ولكلِّ أهلِ دينٍ قبلةٌ.﴿هُوَ مُوَلِّيهَا﴾: مُتَوَجِّهٌ إليها في صلاتِه.﴿فَٱسۡتَبِقُواْ﴾: فبادِرُوا، وسارِعُوا.﴿يَأۡتِ بِكُمُ﴾: يومَ القيامةِ."
  2,149,"﴿فَوَلِّ وَجۡهَكَ﴾: تَوَجَّهْ.﴿شَطۡرَ﴾: نَحْوَ.﴿وَإِنَّهُۥ﴾: وإنّ تَوَجُّهَك إليه."
  2,150,"﴿حُجَّةٌ﴾: هي قولُهم حينَ تَوَجَّهَ إلى المسجدِ الحرامِ: اشتاقَ إلى دينِ قومِه.﴿ٱلَّذِينَ ظَلَمُواْ﴾: هم مشركُو قريشٍ، أو المعاندون أهلُ الكتابِ، فسيَبْقَون على جِدالهم وعِنادهِم.﴿وَلِأُتِمَّ نِعۡمَتِي﴾: باختيار أكملِ الشَّرائعِ لكم."
  2,151,"﴿كَمَآ أَرۡسَلۡنَا﴾: كما أنَعمْنا عليكم باستقبالِ الكعبةِ أرسَلْنا.﴿يُزَكِّيكُمۡ﴾: يُطَهِّرُكم من الشِّرك، وسوءِ الأخلاقِ.﴿ٱلۡحِكۡمَةَ﴾: السُّنَّةَ."
  2,152,"﴿فَٱذۡكُرُونِيٓ﴾: بالطاعةِ.﴿أَذۡكُرۡكُمۡ﴾: بالثَّوابِ والمغفرةِ."
  2,154,"﴿أَحۡيَآءࣱ﴾: حياةً خاصةً بهم في قُبورِهم.﴿لَّا تَشۡعُرُونَ﴾: لا تُحِسُّون بهذه الحياةِ."
  2,155,"﴿وَلَنَبۡلُوَنَّكُم﴾: ولَنَخْتَبِرَنَّكم."
  2,156,"﴿إِنَّا لِلَّهِ﴾: إنّا عَبيدٌ له، مُدَبَّرُون بتصريفِه."
  2,157,"﴿صَلَوَ ٰ⁠تࣱ﴾: مغفرةٌ، وثناءٌ حَسَنٌ."
  2,158,"﴿شَعَآئِرِ ٱللَّهِ﴾: منْ معالمِ دينِه، وأعلامِ مَناسِكِه.﴿حَجَّ ٱلۡبَيۡتَ﴾: قَصَدَه للحجِّ أو العمرةِ.﴿فَلَا جُنَاحَ﴾: فلا حَرَجَ ولا إثمَ، بل يجبُ السَّعْيُ.﴿يَطَّوَّفَ بِهِمَا﴾: يَسْعى بينهما.﴿تَطَوَّعَ﴾: فَعَلَ الطاعةَ مِن نفسِه."
  2,159,"﴿يَكۡتُمُونَ﴾: يُخْفُون. وهم أحبارُ اليهودِ، وعلماءُ النصارى، وكلُّ مَن كَتَمَ الحقَّ.﴿ٱلۡبَيِّنَـٰتِ﴾: الآياتِ الواضحاتِ الدالَّةِ على نُبُوَّةِ محمدٍ ﷺ.﴿بَيَّنَّـٰهُ﴾: أظْهَرْناه في التوراةِ والإنجيلِ."
  2,160,"﴿وَأَصۡلَحُواْ﴾: ما أفْسَدُوه."
  2,161,"﴿لَعۡنَةُ ٱللَّهِ﴾: الطَّرْدُ مِن رحمته."
  2,162,"﴿خَـٰلِدِينَ فِيهَا﴾: دائمِين في اللَّعْنَةِ والنارِ.﴿يُنظَرُونَ﴾: يُمْهَلُون لكي يَعْتَذِرُوا."
  2,164,"﴿ٱخۡتِلَـٰفِ ٱلَّيۡلِ وَٱلنَّهَارِ﴾: تعاقُبِهما.﴿ٱلۡفُلۡكِ﴾: السُّفُن.﴿بَعۡدَ مَوۡتِهَا﴾: بعد قَحْطِها وجَفافِها.﴿بَثَّ﴾: نَشَر، وفَرَّقَ.﴿دَآبَّةࣲ﴾: كلِّ ما دَبَّ على وجهِ الأرضِ.﴿وَتَصۡرِيفِ ٱلرِّيَـٰحِ﴾: تَوْجيهِها، وهُبوبِها، وفْقَ ما يريدُ.﴿ٱلۡمُسَخَّرِ﴾: المُسَيَّرِ.﴿لَـَٔايَـٰتࣲ﴾: لَعلاماتٍ ودَلالاتٍ على قُدْرةِ اللهِ."
  2,165,"﴿أَندَادࣰا﴾: نُظَراءَ كالأصنامِ والأولياءِ.﴿كَحُبِّ ٱللَّهِ﴾: يَمْنحونهم من التعظيم ما لا يَليقُ إلا باللهِ.﴿إِذۡ يَرَوۡنَ ٱلۡعَذَابَ أَنَّ ٱلۡقُوَّةَ لِلَّهِ جَمِيعࣰا﴾: أي: ليعلَمُوا حين يَرَوْنَ عذابَ جهنَّمَ أن اللهَ هو المتفرِّدُ بالقوةِ."
  2,166,"﴿ٱلَّذِينَ ٱتُّبِعُواْ﴾: هم الرؤساءُ.﴿ٱلۡأَسۡبَابُ﴾: الصِّلاتُ من القَرابَةِ والأَتْباعِ وغيرِ ذلك."
  2,167,"﴿كَرَّةࣰ﴾: عودةً إلى الدنيا.﴿كَذَ ٰ⁠لِكَ﴾: أي: كما أراهم عذابه، يُريهم أعمالَهم الفاسدةَ.﴿حَسَرَ ٰ⁠تٍ﴾: نَداماتٍ."
  2,168,"﴿خُطُوَ ٰ⁠تِ ٱلشَّيۡطَـٰنِ﴾: طُرُقَه، وآثارَه."
  2,169,"﴿وَٱلۡفَحۡشَآءِ﴾: المعصيةِ البالغةِ القُبْحِ."
  2,170,"﴿أَلۡفَيۡنَا﴾: وجَدْنا.﴿أَوَلَوۡ كَانَ ءَابَآؤُهُمۡ لَا يَعۡقِلُونَ﴾: أي: يَتَّبِعُونهم؟"
  2,171,"﴿وَمَثَلُ ٱلَّذِينَ كَفَرُواْ﴾: صِفَتُهم مع مَن يَدْعُوهم إلى الهُدى.﴿ٱلَّذِي يَنۡعِقُ﴾: هو الرّاعِي الذي يَصيحُ بالبهائمِ، ويَزْجُرُها، وهي لا تَفْهَمُ معنى كلامِه، وإنما تَسْمَعُ صوته.﴿صُمُّۢ﴾: سَدُّوا أسماعَهم عن الحقِّ.﴿بُكۡمٌ﴾: أسْكَتُوا ألسنتَهم عن النُّطْقِ بالحقِّ.﴿عُمۡيࣱ﴾: لا يَرَوْن أدلَّةَ الحقِّ."
  2,173,"﴿وَمَآ أُهِلَّ بِهِۦ لِغَيۡرِ ٱللَّهِ﴾: هي الذَّبائحُ التي يُذْكَرُ عند ذَبْحِها غيرُ اللهِ.﴿غَيۡرَ بَاغࣲ﴾: غيرَ طالِبٍ للمُحَرَّمِ، مع كونهِ لا يجدُ غيرَ ما ذُكِرَ، مما أحَلَّه اللهُ.﴿وَلَا عَادࣲ﴾: ولا مُتَجاوزٍ حَدَّ الضَّرورةِ."
  2,174,"﴿ٱلَّذِينَ يَكۡتُمُونَ﴾: هم أهلُ الكتابِ الذين يُخْفُون.﴿مَآ أَنزَلَ ٱللَّهُ مِنَ ٱلۡكِتَـٰبِ﴾: من صفةِ محمدٍ ﷺ وغيرِ ذلك من الحقِّ.﴿وَيَشۡتَرُونَ بِهِۦ ثَمَنࣰا قَلِيلًا﴾: يأخذون مُقابِلَ الإخفاءِ قليلًا مِن عَرَضِ الدُّنيا.﴿إِلَّا ٱلنَّارَ﴾: إلا ما يُورِدُهم النارَ.﴿وَلَا يُكَلِّمُهُمُ﴾: ولا يُطَهِّرُهم"
  2,176,"﴿شِقَاقِۭ بَعِيدࣲ﴾: مُنازَعَةٍ بعيدةٍ عن الصَّوابِ."
  2,177,"﴿ٱلۡبِرَّ﴾: الخيرَ.﴿أَن تُوَلُّواْ﴾: أن تَتَوَجَّهُوا في الصَّلاةِ.﴿قِبَلَ﴾: جِهَةَ.﴿مَنۡ ءَامَنَ﴾: بِرَّ مَن آمَنَ.﴿عَلَىٰ حُبِّهِۦ﴾: وهو للمالِ مُحِبٌّ.﴿وَٱبۡنَ ٱلسَّبِيلِ﴾: هو المسافِرُ المحتاجُ.﴿وَفِي ٱلرِّقَابِ﴾: في تحريرِ العبيدِ، والأسرى.﴿ٱلۡبَأۡسَآءِ﴾: البؤسِ والفقرِ.﴿ٱلضَّرَّآءِ﴾: المرضِ.﴿ٱلۡبَأۡسِ﴾: مواطِنِ القتالِ."
  2,178,"﴿كُتِبَ﴾: فَرَضَ اللهُ.﴿ٱلۡقِصَاصُ﴾: أن يُوقَعَ على الجاني مثلُ ما جَنى.﴿فَمَنۡ عُفِيَ لَهُۥ﴾: مَن سامَحه وليُّ المقتولِ بالعفوِ عَنِ القِصاصِ والاكتفاءِ بالدِّيَةِ.﴿فَٱتِّبَاعُۢ﴾: فاتِّباعُ ما أوجبه اللهُ نحوَ القاتِلِ من الدِّيَةِ.﴿بِٱلۡمَعۡرُوفِ﴾: من غير عُنفٍ من قِبَلِ وليِّ المقتولِ.﴿وَأَدَآءٌ إِلَيۡهِ﴾: أداءُ ما لَزِمَ وليَّ القاتلِ إلى أولياءِ المقتولِ.﴿بِإِحۡسَـٰنࣲ﴾: من غيرِ تأخيرٍ، ولا نَقْصٍ.﴿ٱعۡتَدَىٰ﴾: تجاوَزَ بعد أخْذِ الدِّيةِ."
  2,179,"﴿حَيَوٰةࣱ﴾: أي: آمِنةٌ لكم، وفيه عقوبةٌ لأهلِ السَّفَهِ.﴿ٱلۡأَلۡبَـٰبِ﴾: العُقولِ السَّليمةِ."
  2,180,"﴿كُتِبَ﴾: فَرَضَ اللهُ.﴿ٱلۡمَوۡتُ﴾: علاماتُه ومقدِّماتُه.﴿خَيۡرًا﴾: مالًا.﴿بِٱلۡمَعۡرُوفِ﴾: بالعدلِ."
  2,181,"﴿بَدَّلَهُۥ﴾: غَيَّرَ ما وصّى به الميتُ.﴿إِثۡمُهُۥ﴾: إثمُ التغييرِ."
  2,182,"﴿جَنَفًا أَوۡ إِثۡمࣰا﴾: مَيْلًا عَنِ الحَقِّ على سبيل الخطأ أو العَمْدِ.﴿بَيۡنَهُمۡ﴾: أطرافِ المَيتِ.﴿فَلَآ إِثۡمَ عَلَيۡهِ﴾: فلا ذَنْبَ عليه بتغييرِ الوصيةِ."
  2,183,"﴿ٱلَّذِينَ مِن قَبۡلِكُمۡ﴾: هم أهلُ الكتابِ."
  2,184,"﴿أَيَّامࣰا مَّعۡدُودَ ٰ⁠تࣲ﴾: أيامًا مُحْصَياتٍ، وهي شهرُ رمضانَ.﴿فَعِدَّةࣱ مِّنۡ أَيَّامٍ أُخَرَ﴾: فعليه صيامٌ بقَدْرِ ما أفْطَرَ، من أيامٍ أُخَرَ.﴿يُطِيقُونَهُۥ﴾: يَتَكَلَّفُون صيامَه ويَشُقُّ عليهم.﴿مِسۡكِينࣲ﴾: هو المحتاجُ الذي لا يَمْلِكُ ما يَكْفيه.﴿تَطَوَّعَ خَيۡرࣰا﴾: زاد في قَدْرِ الفِدْيةِ تَبَرُّعًا منه."
  2,185,"﴿هُدࣰى﴾: إرشادًا إلى سبيلِ الحقِّ.﴿وَبَيِّنَـٰتࣲ﴾: دلائلَ واضحةً من البيان.﴿وَٱلۡفُرۡقَانِ﴾: والفَصْل بينَ الحقِّ والباطلِ.﴿ٱلۡعِدَّةَ﴾: عدةَ الصيامِ شهرًا، أو عدةَ ما أفْطَرَ فيه المريضُ والمسافرُ.﴿وَلِتُكَبِّرُواْ ٱللَّهَ﴾: ولِتُعَظِّمُوه بذِكْرِه، وذلك هو التكبيرُ يومَ الفِطْرِ."
  2,186,"﴿فَلۡيَسۡتَجِيبُواْ لِي﴾: فليُطيعوني فيما أمَرْتُهُم به، ونَهَيْتُهم عنه.﴿يَرۡشُدُونَ﴾: يَهْتدون."
  2,187,"﴿ٱلرَّفَثُ﴾: الجِماعُ.﴿لِبَاسࣱ﴾: سِتْرٌ وسَكَنٌ.﴿تَخۡتَانُونَ﴾: تَخُونون. وكانوا يُجامِعُون نساءَهم بعدالعِشاء، وكان هذا مُحَرَّمًا أولَ الإسلامِ.﴿بَـٰشِرُوهُنَّ﴾: جامِعُوهنَّ.﴿ٱبۡتَغُواْ مَا كَتَبَ ٱللَّهُ لَكُمۡ﴾: واطْلبُوا ما قدَّره اللهُ من الوَلَدِ.﴿ٱلۡخَيۡطُ ٱلۡأَبۡيَضُ﴾: ضوءُ الصبحِ.﴿ٱلۡخَيۡطِ ٱلۡأَسۡوَدِ﴾: سوادِ الليلِ.﴿ءَايَـٰتِهِۦ﴾: أحكامَه."
  2,188,"﴿بِٱلۡبَـٰطِلِ﴾: بسببٍ باطلٍ كاليمينِ الكاذبةِ والرَّشوةِ.﴿وَتُدۡلُواْ بِهَآ إِلَى ٱلۡحُكَّامِ لِتَأۡكُلُواْ فَرِيقࣰا مِّنۡ أَمۡوَ ٰ⁠لِ ٱلنَّاسِ﴾: لا تُلْقُوا بأموالِكم إلى الحُكّام؛ لتأكلوا أموالَ طائفةٍ من الناسِ بالحُجَجِ الباطلةِ.﴿وَأَنتُمۡ تَعۡلَمُونَ﴾: تحريمَ ذلك."
  2,189,"﴿ٱلۡأَهِلَّةِ﴾: جمعُ هِلالٍ، أي: عَنْ تَغَيُّر أحوالهِا بزيادةٍ أو نقصانٍ.﴿مَوَ ٰ⁠قِيتُ﴾: علاماتٌ على أوقات العبادةِ والمعاملاتِ.﴿ٱلۡبِرُّ﴾: الخير.﴿بِأَن تَأۡتُواْ ٱلۡبُيُوتَ مِن ظُهُورِهَا﴾: كانوا أولَ الإسلام إذا أحْرَمُوا بحَجّ أو عُمْرَةٍ فَعَلُوا ذلك.﴿مَنِ ٱتَّقَىٰ﴾: فِعْلُ مَن اتَّقى."
  2,190,"﴿وَلَا تَعۡتَدُوٓاْ﴾: لا تَرْتَكِبُوا المَناهيَ كقَتْلِ مَن لا يحِلُّ قَتْلُه."
  2,191,"﴿ثَقِفۡتُمُوهُمۡ﴾: وجَدْتُموهم في أيِّ مكانٍ تَمَكَّنْتُم مِن قَتْلهِم.﴿وَٱلۡفِتۡنَةُ﴾: الشِّرْك باللهِ."
  2,192,"﴿فَإِنِ ٱنتَهَوۡاْ﴾: تَرَكُوا ما هم فيه من الكفرِ والقِتالِ."
  2,193,"﴿فِتۡنَةࣱ﴾: شِرْكٌ بالله، أو فتنةٌ للمسلمين عن دينِهم.﴿ٱلدِّينُ لِلَّهِ﴾: خالصًا لله، لا يُعْبَدُ معه غيرُه."
  2,194,"﴿ٱلشَّهۡرُ ٱلۡحَرَامُ﴾: الشهرُ الذي حَرَّمَ اللهُ القتالَ فيه.﴿بِٱلشَّهۡرِ ٱلۡحَرَامِ﴾: إذا قاتَلُوكم فيه قاتَلْتُموهم فيه.﴿وَٱلۡحُرُمَـٰتُ قِصَاصࣱ﴾: مَن هَتَكَ حُرْمَةً عليكم فلكم أن تَهْتِكُوا حُرْمَةً عليه، مُساواةً."
  2,195,"﴿ٱلتَّهۡلُكَةِ﴾: المَهالِك، وهو كلُّ ما صَدَقَ عليه أنه تَهْلُكَةٌ في الدِّين، أو الدُّنيا."
  2,196,"﴿وَأَتِمُّواْ﴾: أدُّوهما تامَّيْنِ من غيرِ مَحْظورٍ.﴿أُحۡصِرۡتُمۡ﴾: حَبَسَكم حابِسٌ عن إتمامِهما بعد الإحرام بِهما.﴿فَمَا ٱسۡتَيۡسَرَ﴾: فعليكم ذَبْحُ ما تَيَسَّرَ.﴿ٱلۡهَدۡيِ﴾: ما يُهدى إلى البيت من الإبِلِ، أو البقر، أو الغنمِ.﴿وَلَا تَحۡلِقُواْ رُءُوسَكُمۡ﴾: لا تُحِلُّوا من الإحرام بالَحلْقِ إن كنتم مُحْصَرِين.﴿مَحِلَّهُۥ﴾: الموضع الذي حُصِرْتُم فيه.﴿أَوۡ نُسُكࣲ﴾: أو ذبيحةٍ، وهي شاة لفقراءِ الحرمِ.﴿أَمِنتُمۡ﴾: كنتم في أمْنٍ وصحةٍ.﴿تَمَتَّعَ بِٱلۡعُمۡرَةِ إِلَى ٱلۡحَجِّ﴾: أحرمَ بعُمْرَةٍ، ثم أقامَ حلالًا بمكةَ إلى أن يُحْرِمَ بالحجِّ.﴿ذَ ٰ⁠لِكَ﴾: أي بالهَدْيِ وما تَرَتَّبَ عليه من الصِّيامِ.﴿حَاضِرِي ٱلۡمَسۡجِدِ ٱلۡحَرَامِ﴾: ساكنِي أرضِ الحَرمِ."
  2,197,"﴿ٱلۡحَجُّ أَشۡهُرࣱ مَّعۡلُومَـٰتࣱ﴾: وقتُ الحجِّ أشهرٌ معلوماتٌ، هي: شوالٌ وذو القِعْدَةِ وعَشْرُ ذي الحِجَّةِ.﴿فَرَضَ﴾: أوْجَبَ الحَجَّ على نفسِه، وعَزَمَ.﴿رَفَثَ﴾: الجِماعَ ومقدِّماتِه.﴿فُسُوقَ﴾: الخُروجَ عن طاعةِ اللهِ بإتيانِ ما نُهِيَ عنه في حال إحرامِه لحَجِّه.﴿وَلَا جِدَالَ﴾: ولا تنازُعَ، ولا مِراءَ.﴿وَتَزَوَّدُواْ﴾: خُذُوا زادًا من الطَّعامِ والشَّرابِ، وزادًا من صالحِ الأعمالِ.﴿يَـٰٓأُوْلِي ٱلۡأَلۡبَـٰبِ﴾: يا أصحاب العقولِ السليمةِ."
  2,198,"﴿جُنَاحٌ﴾: حَرَجٌ.﴿فَضۡلࣰا﴾: التماسَ الرزقِ بالتجارةِ وقْتَ الحَجِّ.﴿أَفَضۡتُم﴾: دَفَعْتُم.﴿ٱلۡمَشۡعَرِ ٱلۡحَرَامِ﴾: المَعْلَمِ الحَرامِ، وهو مُزْدَلِفَةُ.﴿كَمَا هَدَىٰكُمۡ﴾: على الوَجْهِ الصَّحيحِ الذي هداكم إليه.﴿وَإِن كُنتُم﴾: ولقد كنتم."
  2,199,"﴿مِنۡ حَيۡثُ أَفَاضَ ٱلنَّاسُ﴾: كما عَمِلَ إبراهيمُ عليه السلامُ."
  2,200,"﴿قَضَيۡتُم مَّنَـٰسِكَكُمۡ﴾: فَرَغْتُم مِن حَجِّكم، وذَبَحْتُم النُّسُكَ.﴿خَلَـٰقࣲ﴾: نَصِيبٍ."
  2,201,"﴿فِي ٱلدُّنۡيَا حَسَنَةࣰ﴾: عافيةً ورزقًا.﴿وَفِي ٱلۡـَٔاخِرَةِ حَسَنَةࣰ﴾: الَجنّةَ."
  2,202,"﴿نَصِيبࣱ مِّمَّا كَسَبُواْ﴾: حَظٌّ من أعمالهِم.﴿سَرِيعُ ٱلۡحِسَابِ﴾: مُحْصٍ أعمالَ عبادِه، ومُجازِيهم بها."
  2,203,"﴿فِيٓ أَيَّامࣲ مَّعۡدُودَ ٰ⁠تࣲ﴾: هي أيامُ الحادي عشر والثاني عشرَ والثالثَ عشرَ مِن ذِي الحِجّةِ، في مِنى.﴿تَعَجَّلَ﴾: نَفرَ من مِنى في اليومِ الثاني عشرَ.﴿فَلَآ إِثۡمَ﴾: فلا حَرَجَ، ولا ذَنْبَ عليه في تَعَجُّله.﴿وَمَن تَأَخَّرَ﴾: فنَفَرَ في اليومِ الثالثَ عَشَرَ."
  2,204,"﴿وَمِنَ ٱلنَّاسِ﴾: من المنافقين.﴿عَلَىٰ مَا فِي قَلۡبِهِۦ﴾: من محبَّةِ الإسلامِ.﴿أَلَدُّ ٱلۡخِصَامِ﴾: شديدُ العَداوةِ والمخاصَمَةِ."
  2,205,"﴿تَوَلَّىٰ﴾: خَرَجَ مِن عندِك.﴿ٱلۡحَرۡثَ﴾: الزَّرْعَ.﴿وَٱلنَّسۡلَ﴾: نَسْلَ كلِّ دابَّةٍ."
  2,206,"﴿أَخَذَتۡهُ ٱلۡعِزَّةُ﴾: حَمَلَه الكِبْرُ وحَمِيَّةُ الجاهليةِ.﴿فَحَسۡبُهُۥ﴾: فكافيتُه.﴿ٱلۡمِهَادُ﴾: الفِراشُ."
  2,207,"﴿يَشۡرِي﴾: يَبيعُ."
  2,208,"﴿ٱلسِّلۡمِ﴾: شرائعِ الإسلامِ.﴿كَآفَّةࣰ﴾: في جميعِ أحكامِه، فلا تُضَيِّعُوا منها شيئًا.﴿خُطُوَ ٰ⁠تِ ٱلشَّيۡطَـٰنِ﴾: طُرُقَه وآثارَه.﴿مُّبِينࣱ﴾: ظاهرُ العَداوةِ."
  2,209,"﴿زَلَلۡتُم﴾: أخْطَأْتُم الحقَّ.﴿ٱلۡبَيِّنَـٰتُ﴾: الحُجَجُ الواضحَةُ.﴿عَزِيزٌ﴾: في نِقْمَتِه.﴿حَكِيمٌ﴾: يَضَعُ كلَّ شيءٍ في مَوْضِعِه المناسِبِ."
  2,210,"﴿هَلۡ يَنظُرُونَ﴾: ما ينتظرُ هؤلاء الكافرونَ.﴿يَأۡتِيَهُمُ ٱللَّهُ﴾: على الوجهِ الذي يَليقُ به.﴿ظُلَلࣲ﴾: جمعُ ظُلَّةٍ، وهي ما يُسْتَظَلُّ به.﴿ٱلۡغَمَامِ﴾: السَّحابِ.﴿وَقُضِيَ ٱلۡأَمۡرُ﴾: وفُصِلَ القضاءُ بالعَدْلِ."
  2,211,"﴿ءَايَةِۭ بَيِّنَةࣲ﴾: علامةٍ واضحةٍ، كعَصا موسى ويدِه.﴿نِعۡمَةَ ٱللَّهِ﴾: الإسلامَ، وما فَرَضَ من شرائعِ دينِه."
  2,212,"﴿زُيِّنَ﴾: حُسِّنَ.﴿وَيَسۡخَرُونَ﴾: ويَسْتهزِئُون.﴿فَوۡقَهُمۡ﴾: يُدْخِلُهم اللهُ أعلى درجاتِ الجنةِ."
  2,213,"﴿أُمَّةࣰ وَ ٰ⁠حِدَةࣰ﴾: جماعةً واحدةً متفقين على دينٍ واحدٍ.﴿مُبَشِّرِينَ﴾: مَن أطاع اللهَ بالجنةِ.﴿وَمُنذِرِينَ﴾: ومُحَذِّرينَ مَن عصاه النارَ.﴿ٱلۡكِتَـٰبَ﴾: الكُتُبَ السماويةَ.﴿فِيهِ﴾: في الكتابِ الذي أنزلَه اللهُ.﴿أُوتُوهُ﴾: أُعْطُوا الكتابَ.﴿ٱلۡبَيِّنَـٰتُ﴾: حُجَجُ اللهِ، وأدِلَّتهُ.﴿بَغۡيَۢا﴾: حَسَدًا، وحِرْصًا على الدنيا.﴿فَهَدَى ٱللَّهُ﴾: فوفَّقَ أمةَ محمدٍ ﷺ إلى الحَقِّ.﴿صِرَ ٰ⁠طࣲ﴾: طريقٍ."
  2,214,"﴿خَلَوۡاْ﴾: مضَوا.﴿ٱلۡبَأۡسَآءُ﴾: الفقرُ والشِّدَّةُ.﴿ٱلضَّرَّآءُ﴾: الأمراضُ.﴿زُلۡزِلُواْ﴾: أُزعِجُوا إزعاجًا شديدًا."
  2,215,"﴿وَٱلۡيَتَـٰمَىٰ﴾: والذين مات آباؤُهم وهم دونَ البُلوغِ.﴿وَٱلۡمَسَـٰكِينِ﴾: والمحتاجِين الذين لا يملكونَ ما يَكْفيهم.﴿وَٱبۡنِ ٱلسَّبِيلِ﴾: والمسافرِ المحتاجِ."
  2,216,"﴿كُتِبَ﴾: فَرَضَ اللهُ.﴿وَٱللَّهُ يَعۡلَمُ﴾: ما هو خيرٌ لكم."
  2,217,"﴿يَسۡـَٔلُونَكَ﴾: يَسْألك المُشْركون.﴿قِتَالࣲ فِيهِ﴾: هل يَحِلُّ القِتالُ فيه؟﴿وَصَدٌّ﴾: ومَنعٌ.﴿وَكُفۡرُۢ بِهِۦ﴾: وكُفْرٌ باللهِ.﴿وَٱلۡمَسۡجِدِ ٱلۡحَرَامِ﴾: وصَدٌّ عن المسجدِ الحرامِ كذلك.﴿وَٱلۡفِتۡنَةُ﴾: الشِّرْكُ.﴿أَكۡبَرُ مِنَ ٱلۡقَتۡلِ﴾: أعظمُ من القَتْلِ في الشهرِ الحرامِ.﴿حَبِطَتۡ﴾: بَطَلَتْ، وفَسَدَتْ."
  2,219,"﴿وَٱلۡمَيۡسِرِ﴾: القِمارِ.﴿إِثۡمࣱ﴾: أضرارٌ، ومفاسدُ.﴿وَمَنَـٰفِعُ﴾: مِن جهةِ كَسْبِ المالِ واللَّذَّةِ وغيرِهما، وهذا قبلَ التحريمِ.﴿ٱلۡعَفۡوَ﴾: الفَضْلَ الزائدَ على الحاجةِ."
  2,220,"﴿إِصۡلَاحࣱ لَّهُمۡ﴾: مُخالَطَتُهم على وجهِ الإصلاحِ لأموالِهم.﴿لَأَعۡنَتَكُمۡ﴾: لَأَوقَعكُم فيما فيه الحَرَجُ والمَشَقَّةُ بتحريمِ مخالطَتِهم.﴿حَكِيمࣱ﴾: يتَصَرَّفُ في مُلْكِه بما تَقْتضيه حِكْمَتُه."
  2,221,"﴿ٱلۡمُشۡرِكَـٰتِ﴾: الوثنيّاتِ.﴿وَلَأَمَةࣱ﴾: المملوكةُ الرقيقةُ.﴿أُوْلَـٰٓئِكَ﴾: المشركون رجالًا ونساءً.﴿إِلَى ٱلنَّارِ﴾: إلى الأعمالِ المُوجبةِ للنارِ.﴿بِإِذۡنِهِۦ﴾: بأمرهِ، وتوفيقِه."
  2,222,"﴿فَٱعۡتَزِلُواْ﴾: اجتنِبُوا الجِماعَ، لا المجالسةَ، أو الملامسةَ.﴿وَلَا تَقۡرَبُوهُنَّ﴾: ولا تجامِعُوهُنَّ.﴿يَطۡهُرۡنَ﴾: ينقطِعُ دَمُهُن.﴿تَطَهَّرۡنَ﴾: اغتسَلْن.﴿فَأۡتُوهُنَّ مِنۡ حَيۡثُ أَمَرَكُمُ ٱللَّهُ﴾: فجامِعُوهن في الموضعِ الذي أحلَّه اللهُ وهو القُبُلُ."
  2,223,"﴿حَرۡثࣱ لَّكُمۡ﴾: موضعُ زَرْعٍ لنُطَفِكم.﴿أَنَّىٰ شِئۡتُمۡ﴾: من أيِّ جهةٍ شِئْتم، في موضع الحَرْثِ.﴿وَقَدِّمُواْ لِأَنفُسِكُمۡ﴾: من التقرُّبِ إلى اللهِ بفعلِ الخيراتِ."
  2,224,"﴿عُرۡضَةࣰ لِّأَيۡمَـٰنِكُمۡ﴾: مانعًا لكم، وحاجزًا من البِرّ، وفِعْلِ الخيرِ. فإذا دُعِيتم إلى فِعْلِه قُلْتم: إنّكم أقْسَمْتُم ألّا تفعلُوه، فالحالِفُ يُمْكِنُه أن يفعلَ البِرَّ، ثم يُكَفِّرَ.﴿أَن تَبَرُّواْ﴾: مانعًا من بِرِّكم، وإصلاحِكم."
  2,225,"﴿بِٱللَّغۡوِ﴾: هو اليمينُ بغير إرادةٍ لها وقَصْدٍ.﴿كَسَبَتۡ قُلُوبُكُمۡ﴾: قَصَدَتْه قُلوبُكم."
  2,226,"﴿يُؤۡلُونَ﴾: يَحْلِفُون ألّا يُجامِعُوا نساءَهم أكثرَ من أربعةِ أشهرٍ.﴿تَرَبُّصُ أَرۡبَعَةِ أَشۡهُرࣲ﴾: عليهم انتظارُ أربعةِ أشهرٍ.﴿فَآءُو﴾: رَجَعُوا قبلَ فواتِ الأشهرِ الأربعةِ.﴿غَفُورࣱ﴾: لا يُؤاخِذُهم بتلك اليمينِ."
  2,227,"﴿عَزَمُواْ ٱلطَّلَـٰقَ﴾: وقَعَ العَزْمُ منهم على الطَّلاقِ باستمرارِهم في اليمينِ."
  2,228,"﴿يَتَرَبَّصۡنَ﴾: ينتَظِرْن دُونَ نكاحٍ بعدَ الطَّلاقِ.﴿ثَلَـٰثَةَ قُرُوٓءࣲ﴾: ثلاثةَ أوقاتٍ من الطُّهر أو الحيضِ للتأكدِ من فراغِ الرَّحِم.﴿يَكۡتُمۡنَ﴾: يُخْفِينَ الحَمْلَ، أو الحيضَ.﴿وَبُعُولَتُهُنَّ﴾: هم أزواجُ المطلقاتِ.﴿أَحَقُّ بِرَدِّهِنَّ﴾: أحقُّ بمُراجَعَتِهِنَّ في العِدَّةِ.﴿دَرَجَةࣱ﴾: منزلةٌ زائدةٌ من القِوامةِ على البيتِ، والإنفاقِ، والزيادةِ في الميراث، وغيرِ ذلك."
  2,229,"﴿ٱلطَّلَـٰقُ مَرَّتَانِ﴾: أي: الذي تحصُلُ به الرَّجْعَةُ، وهو مرة بعدَ مرة.﴿بِمَعۡرُوفٍ﴾: حُسْنِ العِشْرةِ بعدَ مراجَعَتِها.﴿تَسۡرِيحُۢ بِإِحۡسَـٰنࣲ﴾: تَخْلِيةُ سبيلِها، مع أداءِ حُقوقِها.﴿شَيۡـًٔا﴾: ممّا أعْطَيْتُموه من المَهْر ونحوِه على وجهِ المُضارَّةِ.﴿إِلَّآ أَن يَخَافَآ﴾: يخافَ الزوجان ألّا يقوما بالحقوقِ الزوجيَّةِ. وهي المُخالَعَةُ بالمعروفِ.﴿فَإِنۡ خِفۡتُمۡ﴾: أي: الأولياءُ، أو المتوسِّطون بين الزوجَيْن.﴿فِيمَا ٱفۡتَدَتۡ﴾: فيما تدفَعُه المرأةُ للزوجِ مقابلَ الطلاقِ، وهو الخُلْعُ.﴿فَلَا تَعۡتَدُوهَا﴾: فلا تَتَجاوَزُوها."
  2,230,"﴿فَإِن طَلَّقَهَا﴾: أي الطَّلْقَةَ الثالثةَ.﴿نكِحَ﴾: بزَواجٍ صَحيحٍ وجِماعٍ.﴿فَإِن طَلَّقَهَا﴾: أي الزوجُ الثاني.﴿فَلَا جُنَاحَ عَلَيۡهِمَآ﴾: أي على الزوجِ الأولِ والمرأةِ.﴿أَن يَتَرَاجَعَآ﴾: أن يتزوَّجا بعَقْدٍ جديدٍ، ومَهْرٍ جديدٍ."
  2,231,"﴿فَبَلَغۡنَ أَجَلَهُنَّ﴾: فقارَبْنَ انقضاءَ العِدَّةِ.﴿فَأَمۡسِكُوهُنَّ﴾: فراجِعُوهُنَّ.﴿بِمَعۡرُوفٍ﴾: مِن غيرِ قَصْدٍ لضِرارٍ.﴿سَرِّحُوهُنَّ﴾: اترُكُوهُنَّ، حتى تنقضِيَ العِدَّةُ.﴿وَلَا تُمۡسِكُوهُنَّ ضِرَارࣰا﴾: لا تَكُنْ مُراجَعَتُهن بقَصْدِ الاعتداءِ، والظلمِ لهن.﴿هُزُوࣰا﴾: لَعِبًا بها بالتجرُّؤِ عليها.﴿وَٱلۡحِكۡمَةِ﴾: السُّنَّةِ."
  2,232,"﴿وَإِذَا طَلَّقۡتُمُ﴾: خطابٌ لأولياءِ المطلقةِ دونَ الثلاثِ، إذا خَرَجَتْ من العِدَّةِ، وأرادَتْ زوجَها بنِكاحٍ جديدٍ.﴿فَبَلَغۡنَ أَجَلَهُنَّ﴾: انتهَتْ عِدَّتُهن من غيرِ مراجعَةٍ لهنَّ.﴿فَلَا تَعۡضُلُوهُنَّ﴾: فلا يجوزُ لوَلِيِّها أن يَمْنَعَها من التزوُّجِ بعَقْدٍ جديدٍ.﴿ذَ ٰ⁠لِكُمۡ﴾: تمكينُ الأزواجِ من نكاحِ زوجاتِهِم.﴿أَزۡكَىٰ﴾: أكثرُ نماءً وأنفعُ."
  2,233,"﴿حَوۡلَيۡنِ﴾: سنتَيْنِ.﴿وَعَلَى ٱلۡمَوۡلُودِ لَهُۥ﴾: هو الأبُ.﴿رِزۡقُهُنَّ﴾: رِزْقُ المُرضِعاتِ المُطَلَّقاتِ.﴿وُسۡعَهَا﴾: قَدْرَ طاقَتِها.﴿لَا تُضَآرَّ وَ ٰ⁠لِدَةُۢ بِوَلَدِهَا﴾: لا يَحِلُّ للوالدَين أن يَجْعلوا المولودَ وسيلةً للمُضارَّةِ بينهما.﴿وَعَلَى ٱلۡوَارِثِ مِثۡلُ ذَ ٰ⁠لِكَ﴾: أي: عند مَوْتِ الوالدِ وجَبَ على وارثِه مثلُ ما يجبُ على الوالدِ مِنَ النفقةِ والكِسْوةِ.﴿أَرَادَا﴾: الوالدان.﴿فِصَالًا﴾: فِطامَ المولودِ عن الرَّضاعةِ قبل السنتَين.﴿تَسۡتَرۡضِعُوٓاْ﴾: إرضاعَ المولودِ من مُرْضِعَةٍ أخرى.﴿إِذَا سَلَّمۡتُم﴾: سَلَّم الوالدُ للأمِّ حَقَّها، وسَلَّمَ للمُرْضِعَةِ أجْرَها."
  2,234,"﴿يَتَرَبَّصۡنَ﴾: ينتظِرْنَ في منزلِ الزوجِ.﴿بَلَغۡنَ أَجَلَهُنَّ﴾: انقضَتِ المدةُ المذكورةُ.﴿فِيمَا فَعَلۡنَ﴾: مِنَ الخروجِ والتَّزيُّنِ والتعرُّضِ للخُطّابِ."
  2,235,"﴿وَلَا جُنَاحَ﴾: ولا إثمَ.﴿عَرَّضۡتُم بِهِۦ مِنۡ خِطۡبَةِ ٱلنِّسَآءِ﴾: لَمَّحْتُم مِن طَلَبِ الزواج مِنَ المُتوفّى عنهن أزواجُهُنَّ، أو المطلقاتِ طلاقًا بائنًا، في أثناءِ العِدَّةِ.﴿أَكۡنَنتُمۡ﴾: أضْمَرْتُم من نيةِ الزواجِ بهنَّ بعد انتهاءِ عِدَّتِهن.﴿لَّا تُوَاعِدُوهُنَّ سِرًّا﴾: على النِّكاح.﴿قَوۡلࣰا مَّعۡرُوفࣰا﴾: أي: يُفْهَمُ منه أنّ مِثْلَها يُرْغَبُ فيها.﴿حَتَّىٰ يَبۡلُغَ ٱلۡكِتَـٰبُ﴾: حتى تنقضِيَ عِدَّتُها."
  2,236,"﴿لَّا جُنَاحَ﴾: لا إثمَ. والمرادُ به التَّبِعَةُ من المهرِ ونحوِه.﴿إِن طَلَّقۡتُمُ﴾: قبلَ المسيسِ، وفَرْضِ المَهْرِ.﴿أَوۡ تَفۡرِضُواْ لَهُنَّ﴾: قبلَ أن تُحَدِّدوا مَهْرًا لهنَّ.﴿وَمَتِّعُوهُنَّ﴾: أي: بشيءٍ ينتفِعْنَ به جَبْرًا لهن.﴿عَلَى ٱلۡمُوسِعِ قَدَرُهُۥ﴾: على المُطَلِّق الغنيِّ قَدْرُ سَعَةِ رزقِه.﴿ٱلۡمُقۡتِرِ﴾: المُطَلِّقِ الفقيرِ.﴿قَدَرُهُۥ﴾: قَدَرُ ما يَمْلِكُه.﴿حَقًّا عَلَى ٱلۡمُحۡسِنِينَ﴾: أي: حَقًّا ثابتًا على الذين يُحْسِنون إلى الُمطَلَّقاتِ."
  2,237,"﴿وَإِن طَلَّقۡتُمُوهُنَّ﴾: بعد العَقْدِ.﴿تَمَسُّوهُنَّ﴾: تُجامِعُوهن.﴿فَرَضۡتُمۡ لَهُنَّ فَرِيضَةࣰ﴾: التَزمْتُم لهنَّ بمَهْرٍ معينٍ.﴿إِلَّآ أَن يَعۡفُونَ﴾: إلا أن يَتَسامَحَ المُطَلَّقاتُ، فيترُكْنَ نصفَ المَهْرِ المستحَقِّ لهنَّ.﴿أَوۡ يَعۡفُوَاْ ٱلَّذِي﴾: أو يتسامَحَ الزوجُ، فيتركَ للمطلقةِ المهرَ كلَّه.﴿ٱلۡفَضۡلَ﴾: الإحسانَ، والتسامحَ في الحقوقِ."
  2,238,"﴿حَـٰفِظُواْ﴾: واظِبُوا.﴿وَٱلصَّلَوٰةِ ٱلۡوُسۡطَىٰ﴾: هي صلاةُ العَصْرِ.﴿قَـٰنِتِينَ﴾: خاشِعين ذلِيلِين."
  2,239,"﴿فَرِجَالًا﴾: ماشِين.﴿رُكۡبَانࣰا﴾: راكبين.﴿فَٱذۡكُرُواْ ٱللَّهَ﴾: أقيمُوا صلاتَكم كما أُمِرْتُمْ."
  2,240,"﴿مَّتَـٰعًا﴾: يُمَتَّعْنَ بالسُّكنى والنفقةِ في منزلِ الزوجِ، وذلك قبلَ النَّسْخِ.﴿إِلَى ٱلۡحَوۡلِ﴾: إلى سنةٍ كاملةٍ.﴿غَيۡرَ إِخۡرَاجࣲ﴾: لا يُخْرِجُهُنَّ الوَرَثَةُ.﴿فَإِنۡ خَرَجۡنَ﴾: باختيارِهنَّ قبلَ الحَوْلِ.﴿فَلَا جُنَاحَ﴾: فلا إثمَ.﴿مِن مَّعۡرُوفࣲ﴾: من أمورٍ مُباحَةٍ."
  2,241,"﴿مَتَـٰعُۢ﴾: من كِسوةٍ ونفقةٍ."
  2,243,"2:242"
  2,244,"2:242"
  2,245,"﴿يُقۡرِضُ﴾: يُنْفِقُ في سبيلِ اللهِ.﴿يَقۡبِضُ﴾: يُضَيِّقُ في الرِّزقِ.﴿وَيَبۡصُۜطُ﴾: ويُوَسِّعُ فيه."
  2,246,"﴿ٱلۡمَلَإِ﴾: الأشرافِ.﴿هَلۡ عَسَيۡتُمۡ﴾: هل الأمرُ كما أتَوَقَّعُه منكم، وهو الجُبْنُ عن القتالِ؟﴿كُتِبَ﴾: فُرِضَ.﴿تَوَلَّوۡاْ﴾: فَرُّوا."
  2,247,"﴿أَنَّىٰ يَكُونُ لَهُ ٱلۡمُلۡكُ﴾: كيف يكونُ له المُلْكُ، وهو لا يستحِقُّه؟﴿ٱصۡطَفَىٰهُ﴾: اختارَه.﴿بَسۡطَةࣰ﴾: سَعَةً وقوةً.﴿وَ ٰ⁠سِعٌ﴾: واسعُ الفَضْلِ."
  2,248,"﴿ءَايَةَ﴾: علامةَ.﴿ٱلتَّابُوتُ﴾: الصندوقُ الذي فيه التوراةُ، وكان الأعداءُ قد انتزَعُوه.﴿سَكِينَةࣱ﴾: طمأنينةٌ تُثَبِّتُ قلوبَ المُخْلِصين.﴿وَبَقِيَّةࣱ﴾: هي الألواحُ وعَصا موسى، وغيرُ ذلك."
  2,249,"﴿فَصَلَ﴾: خَرَجَ.﴿مُبۡتَلِيكُم﴾: مُخْتَبِركُم.﴿فَلَيۡسَ مِنِّي﴾: ليس من أهلِ ديني وطاعتي.﴿لَّمۡ يَطۡعَمۡهُ﴾: لم يَشْرَبْه.﴿ٱغۡتَرَفَ﴾: أخَذَ منه قليلًا.﴿جَاوَزَهُۥ هُوَ﴾: عَبَرَ طالوتُ النهرَ مع القلَّةِ المؤمنَةِ.﴿قَالُواْ﴾: قال الذين عَبَرُوا، وحَصَلَ معهم استضعافٌ لأنفسهم.﴿لَا طَاقَةَ﴾: لا قُدْرَةَ.﴿يَظُنُّونَ﴾: يَسْتيقِنون."
  2,250,"﴿وَلَمَّا بَرَزُواْ﴾: ولمّا صارُوا في مُتَّسَعٍ مِنَ الأرضِ.﴿لِجَالُوتَ﴾: قائدِ الجبابرةِ."
  2,251,"﴿وَٱلۡحِكۡمَةَ﴾: النبوَّةَ.﴿وَلَوۡلَا دَفۡعُ ٱللَّهِ﴾: بأن يَدْفَعَ صالحُهم المفسدين بأنْ يَصُدُّوهم عن محاولةِ الفَسادِ.﴿لَّفَسَدَتِ ٱلۡأَرۡضُ﴾: لَفَسَدَ ما عليها، واختَلَّ نظامُها."
  2,253,"﴿مَّن كَلَّمَ ٱللَّهُ﴾: كموسى عليه السلامُ.﴿وَرَفَعَ بَعۡضَهُمۡ دَرَجَـٰتࣲ﴾: كمحمدٍ ﷺ بعمومِ رسالتِه، وخَتْمِ النبوةِ به.﴿ٱلۡبَيِّنَـٰتِ﴾: المُعْجِزاتِ الباهراتِ كإحياء الموتى بإذنِ الله.﴿بِرُوحِ ٱلۡقُدُسِ﴾: جبريلَ عليه السلامُ.﴿مِنۢ بَعۡدِهِم﴾: من بعدِ هؤلاءِ الرُّسُل."
  2,254,"﴿أَنفِقُواْ﴾: بإخراجِ الزَّكاةِ المفروضةِ وغيرها من الصدقاتِ.﴿لَّا بَيۡعࣱ﴾: فيكونَ معه رِبحٌ تَفْتَدَون به أنفسَكم.﴿وَلَا خُلَّةࣱ﴾: ولا صَداقةٌ.﴿شَفَـٰعَةࣱ﴾: شفاعةُ شافعٍ مُؤَثِّرةٌ."
  2,255,"﴿ٱلۡقَيُّومُ﴾: القائمُ على كلِّ شيءٍ.﴿سِنَةࣱ﴾: نُعاسٌ.﴿كُرۡسِيُّهُ﴾: موضعُ قَدَمَي الرَّبِّ، ولا يَعْلَمُ كيفيتَه إلا اللهُ.﴿وَلَا يَـُٔودُهُۥ﴾: ولا يُثْقِلُه."
  2,256,"﴿لَآ إِكۡرَاهَ فِي ٱلدِّينِ﴾: لاتُكْرِهُوا أحدًا على الدُّخولِ في دينِ الإسلامِ.﴿ٱلرُّشۡدُ﴾: الحقُّ أو الإيمانُ.﴿ٱلۡغَيِّ﴾: الباطِلُ أو الكفرُ.﴿بِٱلطَّـٰغُوتِ﴾: بكلِّ ما عُبِدَ من دونِ اللهِ.﴿بِٱلۡعُرۡوَةِ ٱلۡوُثۡقَىٰ﴾: الطريقةِ المثلى، أو الإسلامِ.﴿لَا ٱنفِصَامَ لَهَا﴾: لا انقطاعَ، ولا انكسارَ لها."
  2,257,"﴿ٱللَّهُ وَلِيُّ ٱلَّذِينَ ءَامَنُواْ﴾: اللَّهُ يَتَوَلّاهم بتوفيقِه.﴿مِّنَ ٱلظُّلُمَـٰتِ﴾: من ظُلُماتِ الكفرِ.﴿إِلَى ٱلنُّورِ﴾: إلى نورِ الإيمانِ.﴿أَوۡلِيَآؤُهُمُ ٱلطَّـٰغُوتُ﴾: أنصارُهم هم الذين يَعْبُد ونَهم من دونِ اللهِ."
  2,258,"﴿أَلَمۡ تَرَ﴾: ألم يَنْتهِ عِلْمُك.﴿حَآجَّ﴾: جادَلَ، وهومَلِكُ بابلَ نَمْرُوذُ.﴿فِي رَبِّهِۦٓ﴾: في وجودِ ربِّه.﴿أَنۡ ءَاتَىٰهُ ٱللَّهُ ٱلۡمُلۡكَ﴾: لأنه أعطاه الُملْكَ فتَجَبَّر.﴿أَنَا۠ أُحۡيِۦ وَأُمِيتُ﴾: أقتلُ مَن أرَدْتُ، وأعفُو عَمَّنْ أرَدْتُ قَتْلَه.﴿فَبُهِتَ﴾: فَتَحَيَّر، وقامَتْ عليه الحُجَّةُ."
  2,259,"﴿كَٱلَّذِي﴾: عُزَيْرٌ.﴿قَرۡيَةࣲ﴾: بيت المقدس.﴿خَاوِيَةٌ عَلَىٰ عُرُوشِهَا﴾: تَهَدَّمَتْ دُورُها، واشتدَّ خَرابُها.﴿أَنَّىٰ﴾: كيف؟ وهو استبعادٌ لإحيائِها.﴿لَمۡ يَتَسَنَّهۡ﴾: لم يتغَيَّرْ.﴿ءَايَةࣰ﴾: دَلالةً على قدرةِ اللهِ على البعثِ.﴿نُنشِزُهَا﴾: نرفعُها، ونُرَكِّبُ بعضَها على بعضٍ."
  2,260,"﴿أَرِنِي﴾: رؤيةَ العينِ.﴿لِّيَطۡمَئِنَّ قَلۡبِي﴾: ليُؤْمِنَ قلبي.﴿فَصُرۡهُنَّ إِلَيۡكَ﴾: فاضْمُمْهُنَّ إليك، واجمَعْهُنَّ، ثم قَطِّعْهُنَّ.﴿سَعۡيࣰا﴾: مُسْرِعَةً."
  2,261,"﴿أَنۢبَتَتۡ سَبۡعَ سَنَابِلَ﴾: أخْرَجَتْ ساقًا تَشَعَّبَ منه سَبْعُ شُعَبٍ، في كل شُعبةٍ سنبلةٌ.﴿يُضَـٰعِفُ﴾: الأجْرَ."
  2,262,"﴿مَنࣰّا﴾: التحَدُّثَ بما أعْطى، حتى يَبْلُغَ ذلك المُعْطى، فيؤذِيَه.﴿أَذࣰى﴾: التطاولَ على المُعْطى.﴿وَلَا خَوۡفٌ عَلَيۡهِمۡ﴾: فيما يَسْتقبلونه من أجْر الآخرةِ.﴿وَلَا هُمۡ يَحۡزَنُونَ﴾: على شيءٍ فاتَهم في الدنيا."
  2,263,"﴿قَوۡلࣱ مَّعۡرُوفࣱ﴾: رَدٌّ جميل يُرَدُّ به السّائلُ.﴿وَمَغۡفِرَةٌ﴾: وعَفْوٌ عمّا بَدَرَ من السّائلِ مِن إلحاحٍ."
  2,264,"﴿كَٱلَّذِي﴾: لا تُبْطِلُوها كما تَبْطُلُ صَدَقَةُ الذي.﴿رِئَآءَ ٱلنَّاسِ﴾: ليراه الناسُ فَيمدَحُوه.﴿صَفۡوَانٍ﴾: حجرٍ أملسَ.﴿وَابِلࣱ﴾: مطرٌ غزيرٌ.﴿فَتَرَكَهُۥ صَلۡدࣰا﴾: أملسَ يابِسًا لا شي ءَ عليه. وكذلك شأنُ المُرائِي لاتنفَعُه نفقتُه.﴿لَّا يَقۡدِرُونَ﴾: لا ينتفعون."
  2,265,"﴿وَتَثۡبِيتࣰا﴾: ويقينًا راسخًا بأنّ اللهَ سيَجْزيهم.﴿بِرَبۡوَةٍ﴾: بأرضٍ عاليةٍ.﴿وَابِلࣱ﴾: مطرٌ غزيرٌ.﴿أُكُلَهَا﴾: ثَمَرَتَها.﴿فَطَلࣱّ﴾: فالمطرُ الضعيفُ يَكْفيها."
  2,266,"﴿أَيَوَدُّ أَحَدُكُمۡ﴾: نَزَلَتِ الآيةُ في رجلٍ غنيٍّ يعملُ بطاعةِ اللهِ، ثم يعملُ بالمعاصي.﴿إِعۡصَارࣱ﴾: ريحٌ شديدةٌ فيها نارٌ مُحرقةٌ.﴿كَذَ ٰ⁠لِكَ﴾: هكذا حالُ غيرِ المخلصينَ في نفقاتِهم."
  2,267,"﴿مِن طَيِّبَـٰتِ مَا كَسَبۡتُمۡ﴾: من جَيِّدِه، وحَلالِه.﴿وَلَا تَيَمَّمُواْ ٱلۡخَبِيثَ﴾: ولا تَقْصِدُوا بالإنفاقِ الرَّديءَ من المالِ.﴿وَلَسۡتُم بِـَٔاخِذِيهِ إِلَّآ أَن تُغۡمِضُواْ فِيهِ﴾: وإنْ أُعْطِيتُموه لم تأخُذُوه إلاإذا تَغاضَيْتُم عن رَداءتِه."
  2,268,"﴿يَعِدُكُمُ ٱلۡفَقۡرَ﴾: يُخَوِّفُكم، ويُغْرِيكم بالبُخْلِ.﴿بِٱلۡفَحۡشَآءِ﴾: بالمعاصي."
  2,269,"﴿ٱلۡحِكۡمَةَ﴾: الإصابةَ في القولِ والفعلِ.﴿ٱلۡأَلۡبَـٰبِ﴾: العقولِ السليمةِ."
  2,270,"﴿نَّذۡرࣲ﴾: ما تُوجِبُه على نفسِك.﴿لِلظَّـٰلِمِينَ﴾: المانعين لحقِّ اللهِ في المالِ."
  2,271,"﴿إِن تُبۡدُواْ ٱلصَّدَقَـٰتِ﴾: إنْ تُظْهِروها.﴿فَنِعِمَّا هِيَ﴾: فنِعْمَ ما تَصَدَّقْتُم به."
  2,272,"﴿فَلِأَنفُسِكُمۡ﴾: يعودُ نَفْعُه عليكم."
  2,273,"﴿أُحۡصِرُواْ﴾: لايَسْتطيعون السَّفرَ طَلَبًا للرِّزقِ، لانشغالهِم بالجهادِ.﴿ضَرۡبࣰا﴾: سَفَرًا لطَلَبِ الرِّزْق.﴿بِسِيمَـٰهُمۡ﴾: بعلاماتِهم، وآثارِ الحاجةِ فيهم.﴿إِلۡحَافࣰا﴾: إلحاحًا إن اضْطُرُّوا للسؤالِ."
  2,275,"﴿يَأۡكُلُونَ ٱلرِّبَوٰاْ﴾: يتعامَلُون به. والرِّبا: ما يُؤَدِّيه المُقْتَرِضُ زيادةً على ما اقترضَ، مشروطةً في العَقْدِ.﴿لَا يَقُومُونَ﴾: أي: في الآخرةِ حينَ يُبْعَثُون مِن قُبورِهم.﴿يَتَخَبَّطُهُ ٱلشَّيۡطَـٰنُ﴾: يُوقِعُه في الاضطرابِ.﴿ٱلۡمَسِّ﴾: الجنونِ.﴿فَٱنتَهَىٰ﴾: فارتدَعَ.﴿مَا سَلَفَ﴾: ما مَضى قبلَ التحريمِ، فلا إثمَ عليه فيه.﴿وَمَنۡ عَادَ﴾: أي: إلى الرِّبا."
  2,276,"﴿يَمۡحَقُ﴾: يُذْهِبُ.﴿وَيُرۡبِي﴾: يُنَمِّي، ويُضاعِفُ الأجْرَ."
  2,277,"﴿وَلَا خَوۡفٌ عَلَيۡهِمۡ﴾: في الآخرةِ.﴿وَلَا هُمۡ يَحۡزَنُونَ﴾: على ما فاتَهم في الدُّنيا."
  2,278,"﴿وَذَرُواْ﴾: اترُكُوا طَلبَ.﴿مَا بَقِيَ مِنَ ٱلرِّبَوٰٓاْ﴾: ما بَقِيَ لكم من زيادةٍ على رؤوسِ أموالِكم."
  2,279,"﴿فَأۡذَنُواْ﴾: اعْلَمُوا ذلك، واستَيْقِنُوه.﴿لَا تَظۡلِمُونَ وَلَا تُظۡلَمُونَ﴾: لا تَأْخُذُون باطلًا لا يَحِلُّ لكم، ولا تُنْقَصُون من أموالِكم."
  2,280,"﴿ذُو عُسۡرَةࣲ﴾: غيرُقادرٍ على السَّدادِ.﴿فَنَظِرَةٌ إِلَىٰ مَيۡسَرَةࣲ﴾: فعليكم أن تُمْهِلُوه إلى أن يُيَسِّرَ اللهُ عليه الأداءَ.﴿وَأَن تَصَدَّقُواْ﴾: أي: على المُعْسِرِ."
  2,281,"﴿تُوَفَّىٰ كُلُّ نَفۡسࣲ مَّا كَسَبَتۡ﴾: تُجازى بما عَمِلَتْ."
  2,282,"﴿تَدَايَنتُم﴾: تبايَعْتُمْ، وتَعاطَيْتُم بالدَّين.﴿أَجَلࣲ مُّسَمࣰّى﴾: وقتٍ معلومٍ.﴿وَلۡيُمۡلِلِ ٱلَّذِي عَلَيۡهِ ٱلۡحَقُّ﴾: يُمْلي المَدينُ ما عليه من الدَّين.﴿وَلَا يَبۡخَسۡ﴾: ولا يُنْقِصْ.﴿سَفِيهًا﴾: مُبَذِّرًا مُتلاعِبًا.﴿وَلِيُّهُۥ﴾: القائمُ بأَمْرِه.﴿أَن تَضِلَّ إِحۡدَىٰهُمَا﴾: مَخافةَ أنْ تَنْسى إحداهما.﴿وَلَا يَأۡبَ ٱلشُّهَدَآءُ إِذَا مَا دُعُواْ﴾: لا يَمْتنعون من الإجابة إذا دُعُوا لإقامةِ الشهادةِ.﴿وَلَا تَسۡـَٔمُوٓاْ﴾: ولا تَمَلُّوا من كتابةِ الدَّيْن.﴿إِلَىٰٓ أَجَلِهِۦ﴾: إلى وقتِه المعلومِ.﴿أَقۡسَطُ﴾: أعدَلُ.﴿وَأَقۡوَمُ﴾: وأصْوَبُ.﴿وَأَدۡنَىٰٓ أَلَّا تَرۡتَابُوٓاْ﴾: وأقربُ إلى نَفْيِ الشَّكِّ.﴿وَلَا يُضَآرَ﴾: لا يجوزُ الإضرارُبهما.﴿فُسُوقُۢ﴾: خروجٌ عن طاعةِ اللهِ."
  2,283,"﴿فَرِهَـٰنࣱ مَّقۡبُوضَةࣱ﴾: ادفَعُوا إلى صاحبِ الحقِّ شيئًا لضَمانِ حَقِّه.﴿فَإِنَّهُۥٓ ءَاثِمࣱ قَلۡبُهُۥ﴾: فهو ذو قَلْبٍ فاجرٍ."
  2,284,"﴿تُبۡدُواْ﴾: تُظْهِروا."
  2,285,"﴿لَا نُفَرِّقُ﴾: نُؤْمِنُ بجميعِ الرسُلِ.﴿غُفۡرَانَكَ﴾: نَطْلُبُ مغفرتَك."
  2,286,"﴿وُسۡعَهَا﴾: قَدْرَ ما تُطيقُ.﴿لَهَا مَا كَسَبَتۡ﴾: أي: مَن فَعَلَ خيرًا نال أجْرَه.﴿وَعَلَيۡهَا مَا ٱكۡتَسَبَتۡ﴾: أي: ومَن فَعَلَ شرًّا نال جَزاءَه.﴿إِصۡرࣰا﴾: عَهْدًا لا نُطيقُ القيامَ به.﴿مَا لَا طَاقَةَ لَنَا بِهِۦ﴾: ما لانَسْتطيعُه.﴿أَنتَ مَوۡلَىٰنَا﴾: أنت وليُّنا، وناصِرُنا."
