tafsir[63]{c,v,t}:
  33,1,"﴿ٱتَّقِ ٱللَّهَ﴾: أي: داوِمْ على تَقْواه عزَّ وجلّ."
  33,3,"﴿وَكِيلࣰا﴾: حافِظًا مُفَوَّضًا إليه كُلُّ أمْرٍ."
  33,4,"﴿فِي جَوۡفِهِۦ﴾: أي: في صَدْرِه.﴿تُظَـٰهِرُونَ﴾: مِنَ الظِّهارِ، وهو أن يقُولَ الرَّجُلُ لامْرَأَتِه: أنتِ عليَّ كَظَهْرِ أُمِّي.﴿أَدۡعِيَآءَكُمۡ﴾: أولادَكُم المتَبَنَّينَ.﴿يَهۡدِي﴾: يُرْشِدُ."
  33,5,"﴿ٱدۡعُوهُمۡ لِـَٔابَآئِهِمۡ﴾: انْسُبُوهُم إليهِم.﴿أَقۡسَطُ﴾: أعْدَلُ وأَقْوَمُ.﴿وَمَوَ ٰ⁠لِيكُمۡ﴾: أي: هُم أولياؤُكُم في الدِّينِ.﴿جُنَاحࣱ﴾: إثمٌ.﴿تَعَمَّدَتۡ﴾: قَصَدَتْ وعَزَمَتْ."
  33,6,"﴿ٱلنَّبِيُّ أَوۡلَىٰ بِٱلۡمُؤۡمِنِينَ﴾: أي: أحَقُّ، فَلَهُ أن يَحْكُمَ فِيهِم بِما يشاءُ.﴿وَأُوْلُواْ ٱلۡأَرۡحَامِ﴾: ذَوُو القَراباتِ.﴿أَوۡلَىٰ بِبَعۡضࣲ﴾: أي: أحَقُّ.﴿مِنَ ٱلۡمُؤۡمِنِينَ وَٱلۡمُهَـٰجِرِينَ﴾: أي: مِن أنْ يُورَثُوا بالإيمانِ والهجرةِ. (كان ذلك في أوَّلِ الإسلامِ، ثم نُسِخ بآيةِ المواريثِ).﴿إِلَّآ أَن تَفۡعَلُوٓاْ إِلَىٰٓ أَوۡلِيَآئِكُم مَّعۡرُوفࣰا﴾: أي: مِن صَدَقَةٍ أو وصَيَّةٍ للأقارِبِ غَيرِ الورثةِ.﴿فِي ٱلۡكِتَـٰبِ﴾: أي: في اللَّوحِ المحفوظِ.﴿مَسۡطُورࣰا﴾: مَكْتُوبًا."
  33,7,"﴿مِيثَـٰقَهُمۡ﴾: عَهْدَهُم المُؤَكَّدَ."
  33,9,"﴿جُنُودࣱ﴾: وهم الأحْزابُ يومَ الخنْدَقِ سَنَةَ خَمْسٍ للهجرةِ.﴿رِيحࣰا﴾: أي: ريحًا شدِيدةً اقتلَعَتْ خيامَهُم وقَلَبَتْ قُدورَهم.﴿وَجُنُودࣰا لَّمۡ تَرَوۡهَا﴾: أي: جُنُودًا مِنَ الملائِكةِ."
  33,10,"﴿مِّن فَوۡقِكُمۡ﴾: مِن أعْلى الوادِي مِن جِهةِ المشْرقِ، وهم كانُوا مِن غَطَفانَ وهَوازِنَ وأهْلِ نَجْدٍ.﴿وَمِنۡ أَسۡفَلَ مِنكُمۡ﴾: مِن بَطْنِ الوادِي مِن جِهَةِ المغْرِبِ، وهم كانُوا مِن مُّشْرِكي مَكَّةَ ومَن كان معهم.﴿زَاغَتِ ٱلۡأَبۡصَـٰرُ﴾: مالَتِ الأَبصْارُ وشَخَصَتْ مِن شِدَّةِ الفزَعِ والهَوْلِ.﴿وَبَلَغَتِ ٱلۡقُلُوبُ ٱلۡحَنَاجِرَ﴾: أي: ارْتَفَعَتْ عَن مَّكانِها مِنَ الفَزَعِ والخَوْفِ ووَصَلَتْ إلى الحناجِرِ، مُفْرَدُها حَنْجَرَةٌ وهيَ جَوْفُ الحُلْقُومِ.﴿ٱلظُّنُونَا۠﴾: أي: الظُّنُونَ السَّيِّئةَ بِأنّ اللهِ لا يَنْصُرُ دِينَه."
  33,11,"﴿ٱبۡتُلِيَ﴾: اخْتُبِر.﴿زِلۡزَالࣰا﴾: واضْطَرَبُوا."
  33,12,"﴿فِي قُلُوبِهِم مَّرَضࣱ﴾: شَكٌّ، وهم ضُعَفاءُ الإيمانِ.﴿غُرُورࣰا﴾: باطِلًا."
  33,13,"﴿يَثۡرِبَ﴾: وهو الاسْمُ القديمُ للمدينةِ النَّبَوِيَّةِ.﴿لَا مُقَامَ لَكُمۡ﴾: لا إقامَةَ لَكُم هاهُنا.﴿عَوۡرَةࣱ﴾: أي: غيرُ حَصِينةٍ يُخْشى عَلَيها مِنَ الأعْداءِ.﴿فِرَارࣰا﴾: أي: مِن مَّيدانِ القِتالِ."
  33,14,"﴿دُخِلَتۡ عَلَيۡهِم مِّنۡ أَقۡطَارِهَا﴾: أي: ولو دَخَلَ جيشُ الأحزابِ «المدينةَ» مِن جَوانِبِها.﴿ٱلۡفِتۡنَةَ﴾: هي الشِّركُ باللهِ، والرُّجُوعُ عَنِ الإسْلامِ.﴿لَـَٔاتَوۡهَا﴾: لَأعْطَوها، ولأَجابُوا إلى ما طُلِبَ إليهم.﴿وَمَا تَلَبَّثُواْ بِهَآ﴾: وما أبْطَؤُوا عَن فِتْنةِ الشِّركِ."
  33,15,"﴿لَا يُوَلُّونَ ٱلۡأَدۡبَـٰرَ﴾: لا يَفِرُّونَ مِن مَّيدانِ القِتالِ.﴿مَسۡـُٔولࣰا﴾: أي: يُسْأَلُ عنه ويُحاسَبُ عَلَيهِ."
  33,17,"﴿يَعۡصِمُكُم﴾: يَمْنَعُكُم."
  33,18,"﴿ٱلۡمُعَوِّقِينَ﴾: المُثَبِّطِينَ عَنِ الجِهادِ مَعَ الرَّسولِ ﷺ.﴿هَلُمَّ إِلَيۡنَا﴾: تَعالَوا وانْضَمُّوا إلينا.﴿ٱلۡبَأۡسَ﴾: القتالَ."
  33,19,"﴿أَشِحَّةً عَلَيۡكُمۡ﴾: بُخَلاءَ عَلَيكُم بكلِّ ما يَنْفَعُكُم.﴿تَدُورُ أَعۡيُنُهُمۡ﴾: يمِينًا وشِمالًا مِن شِدَّةِ الخوفِ.﴿يُغۡشَىٰ عَلَيۡهِ﴾: يُغمى عَلَيهِ مِن سَكَراتِ الموتِ.﴿سَلَقُوكُم﴾: آذَوْكُم ورَمَوْكُم.﴿حِدَادٍ﴾: قاطِعةٍ كالحديدِ.﴿أَشِحَّةً عَلَى ٱلۡخَيۡرِ﴾: بُخَلاءَ حَرِيصِينَ على المالِ والغَنِيمَةِ.﴿فَأَحۡبَطَ﴾: فَأبْطَلَ."
  33,20,"﴿يَوَدُّواْ﴾: يَتَمَنَّوا.﴿بَادُونَ فِي ٱلۡأَعۡرَابِ﴾: كانُوا مَعَهُم في الباديةِ بعيدِينَ عَن مَّيدانِ الحربِ."
  33,21,"﴿أُسۡوَةٌ حَسَنَةࣱ﴾: قُدْوَةٌ صالِحَةٌ في كُلِّ الأُمُورِ.﴿يَرۡجُواْ﴾: يَخافُ."
  33,22,"﴿ٱلۡأَحۡزَابَ﴾: الجيوشَ التي تَحَزَّبَتْ حَوْلَ المدينةِ."
  33,23,"﴿قَضَىٰ نَحۡبَهُۥ﴾: وفّى بِنَذْرِهِ ونالَ الشَّهادَةَ.﴿وَمَا بَدَّلُواْ تَبۡدِيلࣰا﴾: وما غَيَّرُوا عَهْدَ اللهِ، بل ثَبَتُوا عَلَيهِ."
  33,25,"﴿بِغَيۡظِهِمۡ﴾: أي: مُتَلَبِّسين بِغَيظِهِم وغَضَبِهِم."
  33,26,"﴿ظَـٰهَرُوهُم﴾: أعانُوهُم.﴿مِن صَيَاصِيهِمۡ﴾: مِن حُصُونِهِم ومَعاقِلِهِم.﴿وَقَذَفَ﴾: وألْقى.﴿ٱلرُّعۡبَ﴾: الخوفَ الشَّدِيدَ.﴿فَرِيقࣰا تَقۡتُلُونَ﴾: وهم الرِّجالُ.﴿وَتَأۡسِرُونَ فَرِيقࣰا﴾: وهم النِّساءُ والذُّرِّيَّةُ."
  33,27,"﴿لَّمۡ تَطَـُٔوهَا﴾: لم تَدْخُلُوها."
  33,28,"﴿أُمَتِّعۡكُنَّ﴾: أُعْطِكُنَّ المُتْعَةَ بِشيءٍ مِنَ الدُّنيا.﴿وَأُسَرِّحۡكُنَّ﴾: أفارِقْكُنَّ بالطَّلاقِ."
  33,29,"﴿أَعَدَّ﴾: هَيَّأَ.﴿أَجۡرًا﴾: ثوابًا."
  33,30,"﴿بِفَـٰحِشَةࣲ مُّبَيِّنَةࣲ﴾: بمَعْصِيةٍ ظاهِرةِ القُبْحِ.﴿يَسِيرࣰا﴾: هَيِّنًا."
  33,31,"﴿يَقۡنُتۡ﴾: يَخْضَعْ ويُطِعْ.﴿أَعۡتَدۡنَا﴾: أعْدَدْنا وهَيَّأنا.﴿رِزۡقࣰا كَرِيمࣰا﴾: وهو الجنَّةُ."
  33,32,"﴿فَلَا تَخۡضَعۡنَ بِٱلۡقَوۡلِ﴾: فلا تُلِنَّ القولَ والحديثَ للرِّجال.﴿مَرَضࣱ﴾: فُجُورٌ ومَيْلٌ إلى المعْصِيَةِ.﴿مَّعۡرُوفࣰا﴾: مُعْتَدِلًا بعِيدًا عَنِ الرِّيبةِ والشَّكِّ."
  33,33,"﴿وَقَرۡنَ﴾: والزَمْنَ.﴿وَلَا تَبَرَّجۡنَ﴾: ولا تُظْهِرْنَ محاسِنَكُنَّ.﴿ٱلۡجَـٰهِلِيَّةِ ٱلۡأُولَىٰ﴾: أي: التي كانتْ قَبْلَ الإسْلامِ.﴿ٱلرِّجۡسَ﴾: الأذىَ والسُّوءَ والخُبْثَ."
  33,34,"﴿وَٱلۡحِكۡمَةِ﴾: السُّنَّةِ النَّبَويَّةِ."
  33,35,"﴿ٱلۡقَـٰنِتِينَ﴾: المطِيعِينَ الخاضِعِينَ للهِ.﴿وَٱلۡحَـٰفِظِينَ فُرُوجَهُمۡ﴾: أي: عَنِ الزِّنى ومُقَدِّماتِه.﴿أَعَدَّ﴾: هيَّأ.﴿أَجۡرًا عَظِيمࣰا﴾: ثوابًا عَظِيمًا، وهو الجنّةُ."
  33,36,"﴿ٱلۡخِيَرَةُ﴾: الاخْتِيارُ.﴿ضَلَّ﴾: بَعُدَ عَنِ الصِّراطِ المُسْتَقِيمِ."
  33,37,"﴿لِلَّذِيٓ أَنۡعَمَ ٱللَّهُ عَلَيۡهِ﴾: أي: بالإسْلامِ، وهو زَيدُ بْنُ حارِثَة الَّذي تَبَنّاهُ النَّبيُّ ﷺ قَبْلَ أن يُبْطِلَ القرآنُ هذا التَّبَنِّي﴿وَأَنۡعَمۡتَ عَلَيۡهِ﴾: بأن أعتَقْتَه مِنَ الرِّقِّ.﴿وَتُخۡفِي فِي نَفۡسِكَ﴾: وهو ما أوْحى اللهُ إلى نبِيِّه مِن طَلاقِ زَيدٍ لِزَوْجِهِ ثُمَّ زَواجِه ﷺ مِنها.﴿وَطَرࣰا﴾: حاجَةً مُهِمَّةً وهي نِكاحُها.﴿حَرَجࣱ﴾: إثْمٌ.﴿أَزۡوَ ٰ⁠جِ أَدۡعِيَآئِهِمۡ﴾: أي: في نِكاحِ زَوْجاتِ أولادِهِم المُتَبنَّينَ، الذي كان حَرامًا على عادَةِ أهْلِ الجاهِليَّةِ، فأبْطَلَها الإسْلامُ."
  33,38,"﴿فَرَضَ ٱللَّهُ لَهُۥ﴾: أي: أحَلَّ اللهُ له.﴿سُنَّةَ ٱللَّهِ﴾: عادَةَ اللهِ وطَرِيقَتَهُ.﴿خَلَوۡاْ﴾: مضَوا.﴿قَدَرࣰا مَّقۡدُورًا﴾: أي: قَضاءً مَقْضِيًّا لابُدَّ مِن وُقُوعِهِ."
  33,39,"﴿حَسِيبࣰا﴾: عَلِيمًا بالأعْمالِ ومُحاسِبًا عَلَيها."
  33,40,"﴿وَخَاتَمَ ٱلنَّبِيِّـۧنَ﴾: أي: آخِرَهُم، فلا نُبُوَّةَ بَعْدَه إلى يومِ القيامةِ."
  33,42,"﴿بُكۡرَةࣰ وَأَصِيلًا﴾: أوَّلَ النهارِ وآخِرَه."
  33,43,"﴿يُصَلِّي عَلَيۡكُمۡ﴾: يُنَزِّلُ رَحْمَتَهُ عَلَيكُم.﴿مِّنَ ٱلظُّلُمَـٰتِ إِلَى ٱلنُّورِ﴾: مِن ظُلُماتِ الضَّلالةِ إلى نُورِ الهِدايةِ."
  33,45,"﴿شَـٰهِدࣰا﴾: أي: على أُمَّتِكَ."
  33,46,"﴿وَسِرَاجࣰا مُّنِيرࣰا﴾: أي: يُسْتَضاءُ بِهَدْيِهِ في ظُلُماتِ الضَّلالةِ."
  33,48,"﴿وَكِيلࣰا﴾: حافِظًا مُفَوَّضًا إليهِ كُلُّ أمْرٍ."
  33,49,"﴿أَن تَمَسُّوهُنَّ﴾: أن تُجامِعُوهُنَّ.﴿تَعۡتَدُّونَهَا﴾: تُحْصُونَها عَلَيهِنّ.﴿فَمَتِّعُوهُنَّ﴾: أعْطُوهُنّ مُتْعَةً يَتَمَتَّعْنَ بِها.﴿وَسَرِّحُوهُنَّ﴾: خَلُّوا سَبِيلَهُنَّ."
  33,50,"﴿أُجُورَهُنَّ﴾: مُهُورَهُنَّ.﴿مَلَكَتۡ يَمِينُكَ﴾: أي: مِنَ الإماءِ.﴿مِمَّآ أَفَآءَ ٱللَّهُ عَلَيۡكَ﴾: مِمّا رَدَّهُ اللهُ عَلَيكَ بالغَنِيمَةِ.﴿مَا فَرَضۡنَا عَلَيۡهِمۡ﴾: ما أوْجَبْنا عَلَيهِم مِن شُرُوطِ العَقْدِ وحُقُوقِهِ.﴿حَرَجࣱ﴾: ضِيقٌ وإثْمٌ."
  33,51,"﴿تُرۡجِي﴾: تُؤَخِّرُ في المبيتِ.﴿تُـٔۡوِيٓ﴾: تَضُمُّ إليكَ في المبيتِ.﴿وَمَنِ ٱبۡتَغَيۡتَ﴾: ومَن طَلَبْتَ.﴿مِمَّنۡ عَزَلۡتَ﴾: مِمَّنْ أخَّرْتَ المبيتَ معها.﴿جُنَاحَ﴾: حَرَجَ.﴿أَدۡنَىٰٓ﴾: أقْرَبُ.﴿أَن تَقَرَّ أَعۡيُنُهُنَّ﴾: أي: لِعِلْمِهِنَّ أنَّه مِن عِنْدِ اللهِ."
  33,52,"﴿مِنۢ بَعۡدُ﴾: أي: مِن بَعْدِ أزواجِكَ اللاتِي مَعَكَ.﴿وَلَآ أَن تَبَدَّلَ بِهِنَّ مِنۡ أَزۡوَ ٰ⁠جࣲ﴾: ولا أنْ تَتَزَوَّجَ بَدَلَهُنَّ غَيْرَهُنَّ.﴿إِلَّا مَا مَلَكَتۡ يَمِينُكَ﴾: أي: مِنَ الإماءِ فهُنَّ حَلالٌ لَكَ.﴿رَّقِيبࣰا﴾: حَفِيظًا مُطَّلِعًا."
  33,53,"﴿غَيۡرَ نَـٰظِرِينَ إِنَىٰهُ﴾: غَيرَ مُنْتَظِرِينَ نُضْجَه واسْتِواءَه.﴿طَعِمۡتُمۡ﴾: أكَلْتُم.﴿فَٱنتَشِرُواْ﴾: فانصَرِفُوا وتَفَرَّقُوا.﴿وَلَا مُسۡتَـٔۡنِسِينَ لِحَدِيثٍ﴾: أي: لا تُطِيلُوا المكْثَ عِنْدَه لاسْتِئْناسِ الحديثِ فيما بَيْنَكُم.﴿مِنَ ٱلۡحَقِّ﴾: أي: مِن بَيانِه.﴿مَتَـٰعࣰا﴾: حاجَةً مِنَ الماعُونِ وغيرِه.﴿حِجَابࣲ﴾: سِتْرٍ بَيْنَكُم وبَيْنَهُنَّ."
  33,54,"﴿تُبۡدُواْ﴾: تُظْهِرُوا."
  33,55,"﴿لَّا جُنَاحَ﴾: لا إثْمَ.﴿وَلَا مَا مَلَكَتۡ أَيۡمَـٰنُهُنَّ﴾: أي: مِنَ الإماءِ والعبيدِ لِشِدَّةِ الحاجَةِ إليهِم في الخِدْمَةِ."
  33,56,"﴿يُصَلُّونَ عَلَى ٱلنَّبِيِّ﴾: يُثْنُونَ على النَّبيِّ ﷺ بإظْهارِ شَرَفِهِ وتَعْظِيمِ شَأْنِه."
  33,57,"﴿يُؤۡذُونَ﴾: أي: بالشِّركِ والمعاصِي.﴿لَعَنَهُمُ ٱللَّهُ﴾: طَرَدَهُم مِن رَحْمَتِهِ.﴿مُّهِينࣰا﴾: مُذِلًّا."
  33,58,"﴿بِغَيۡرِ مَا ٱكۡتَسَبُواْ﴾: بِغَيرِ ذَنْبٍ ارْتَكَبُوه.﴿ٱحۡتَمَلُواْ﴾: حَمَلُوا وهم لا يُطِيقُونَه.﴿بُهۡتَـٰنࣰا﴾: كَذِبًا شَنِيعًا.﴿مُّبِينࣰا﴾: ظاهرَ القُبْحِ."
  33,59,"﴿يُدۡنِينَ عَلَيۡهِنَّ﴾: يُرْخِينَ ويُسْدِلْنَ على أجْسادِهِنَّ.﴿مِن جَلَـٰبِيبِهِنَّ﴾: مِن أرْدِيتِهِنَّ ومَلاحِفِهِنّ.﴿أَدۡنَىٰٓ﴾: أقْرَبُ.﴿أَن يُعۡرَفۡنَ﴾: بالحِشْمَةِ والسِّتْرِ.﴿فَلَا يُؤۡذَيۡنَ﴾: فلا يُتعرَّضُ لَهُنّ بِمَكْرُوهٍ أوْ أذى."
  33,60,"﴿مَّرَضࣱ﴾: شَكٌّ ورِيبَةٌ.﴿ٱلۡمُرۡجِفُونَ﴾: المُشِيعُونَ للأَخْبارِ الكاذِبَةِ.﴿لَنُغۡرِيَنَّكَ بِهِمۡ﴾: لنُسَلِّطنَّكَ عَلَيهِم."
  33,61,"﴿مَّلۡعُونِينَ﴾: مَطْرُودِينَ مَنَ رَحْمَةِ اللهِ.﴿ثُقِفُوٓاْ﴾: وُجِدُوا."
  33,62,"﴿سُنَّةَ ٱللَّهِ﴾: طَرِيَقةَ اللهِ وعادَتَهُ.﴿خَلَوۡاْ﴾: مَضَوا."
  33,63,"﴿عَنِ ٱلسَّاعَةِ﴾: أي: عَن وقْتِ يومِ القِيامةِ."
  33,64,"﴿لَعَنَ ٱلۡكَـٰفِرِينَ﴾: طَرَدَهُم مِن رَحْمَتِهِ.﴿وَأَعَدَّ﴾: جَهَّزَ.﴿سَعِيرًا﴾: نارًا مُسْتَعِرةً شَدِيدَةَ الحرارةِ."
  33,66,"﴿تُقَلَّبُ وُجُوهُهُمۡ﴾: تُحَوَّلُ مِن نّاحيةٍ إلى أُخْرى لِيزْدادَ عَذابُهُم."
  33,67,"﴿ٱلسَّبِيلَا۠﴾: الطَّريقَ المستقيمَ."
  33,68,"﴿ضِعۡفَيۡنِ﴾: مِثلَينِ.﴿وَٱلۡعَنۡهُمۡ﴾: اطرُدْهُم مِن رَحْمَتِكَ.﴿كَبِيرࣰا﴾: شَدِيدًا ثَقِيلَ الموقِعِ."
  33,69,"﴿وَجِيهࣰا﴾: عظيمَ القَدْرِ والجاهِ."
  33,70,"﴿سَدِيدࣰا﴾: صَوابًا."
  33,72,"﴿ٱلۡأَمَانَةَ﴾: التَّكالِيفَ الشَّرْعِيةَ مِن الأوامِرِ والنَّواهِي.﴿فَأَبَيۡنَ﴾: امْتَنَعْنَ.﴿وَأَشۡفَقۡنَ مِنۡهَا﴾: خِفْنَ مِنَ الخِيانَة فِيها.﴿ظَلُومࣰا جَهُولࣰا﴾: شَدِيدَ الظُّلمِ والجَهْلِ لِنَفْسِهِ."
