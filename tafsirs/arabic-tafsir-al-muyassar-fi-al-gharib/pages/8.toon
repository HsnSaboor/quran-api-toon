tafsir[68]{c,v,t}:
  8,1,"﴿ٱلۡأَنفَالِ﴾: جَمْعُ نَفَل، وهي: الغنائمُ في غزوةِ «بَدْر».﴿ذَاتَ بَيۡنِكُمۡ﴾: الصِّلَةُ التي تَرْبِطُ بعضَكم ببعض."
  8,2,"﴿وَجِلَتۡ﴾: خافَتْ وفَزِعَتْ.﴿وَعَلَىٰ رَبِّهِمۡ يَتَوَكَّلُونَ﴾: يعتمدون عليه ويُفَوِّضون أمرَهم إليه."
  8,4,"﴿دَرَجَـٰتٌ﴾: منازلُ عاليةٌ."
  8,5,"﴿كَمَآ أَخۡرَجَكَ﴾: هذه الحالُ في كراهةِ فريقٍ من المؤمنين للقتالِ بعد تَبَيُّنِه، مثلُ إخراجِك في حالِ كراهتِهم."
  8,6,"﴿فِي ٱلۡحَقِّ﴾: في القتالِ."
  8,7,"﴿ٱلطَّآئِفَتَيۡنِ﴾: القافلةِ الآتيةِ من الشام وما تحمِلُه من أرزاقٍ، أو النَّفيرِ لقتالِ الأعداءِ.﴿غَيۡرَ ذَاتِ ٱلشَّوۡكَةِ﴾: غيرَ ذاتِ السِّلاحِ والقُوَّةِ، وهي: القافلةُ.﴿وَيَقۡطَعَ دَابِرَ ٱلۡكَـٰفِرِينَ﴾: الدابِرُ: الآخِرُ، أي: ويستأصِلَ الكافرين بالهَلاكِ."
  8,8,"﴿لِيُحِقَّ ٱلۡحَقَّ﴾: ليُظْهِرَه للناسِ ويُبَيِّنَه."
  8,9,"﴿تَسۡتَغِيثُونَ﴾: تَطْلُبون النَّصْرَ على عَدُوِّكم.﴿مُرۡدِفِينَ﴾: يَتْبَعُ بعضُهم بعضًا."
  8,10,"﴿وَمَا جَعَلَهُ ٱللَّهُ﴾: وما جَعَلَ الإمدادَ.﴿وَلِتَطۡمَئِنَّ﴾: ولِتَسْكُنَ وتُوقِنَ بنَصْرِ اللهِ."
  8,11,"﴿يُغَشِّيكُمُ﴾: يُلْقي اللهُ عليكم.﴿أَمَنَةࣰ مِّنۡهُ﴾: أمانًا من الله لكم.﴿وَيُذۡهِبَ﴾: ويُزيلَ.﴿رِجۡزَ ٱلشَّيۡطَـٰنِ﴾: وساوِسَه بما خَطَرَ لهم من الخوفِ والفَشَلِ.﴿وَلِيَرۡبِطَ عَلَىٰ قُلُوبِكُمۡ﴾: وليُقَوِّيَها بالصَّبرِ والشَّجاعةِ."
  8,12,"﴿أَنِّي مَعَكُمۡ﴾: بإعانتي ونَصْري.﴿فَثَبِّتُواْ ٱلَّذِينَ ءَامَنُواْ﴾: فَقَوُّوا عزائمَهم، وبَشِّرُوهم بالنَّصْرِ.﴿ٱلرُّعۡبَ﴾: الخوفَ الشديدَ.﴿فَوۡقَ ٱلۡأَعۡنَاقِ﴾: رؤوسَ الكفارِ.﴿كُلَّ بَنَانࣲ﴾: كلَّ طَرَفٍ ومِفْصَلٍ في الجسمِ."
  8,13,"﴿ذَ ٰ⁠لِكَ﴾: ما وقَعَ عليهم من القَتْل.﴿شَآقُّواْ ٱللَّهَ﴾: خالَفُوا أمْرَه."
  8,15,"﴿زَحۡفࣰا﴾: مُتقارِبين يَدْنُو كلُّ فريقٍ من الآخَرِ.﴿فَلَا تُوَلُّوهُمُ ٱلۡأَدۡبَارَ﴾: فلا تُدِيروا لهم ظُهورَكم مُنْهَزِمين."
  8,16,"﴿مُتَحَرِّفࣰا لِّقِتَالٍ﴾: مائِلًا عن موقفِه إلى موضعٍ أصلَحَ للقتالِ فيه.﴿مُتَحَيِّزًا﴾: مُنْحازًا ومنضَمًّا.﴿فِئَةࣲ﴾: جماعةٍ من المسلمين في ميدانِ القتالِ.﴿بَآءَ بِغَضَبࣲ مِّنَ ٱللَّهِ﴾: استحَقَّ غضَبه."
  8,17,"﴿وَلِيُبۡلِيَ ٱلۡمُؤۡمِنِينَ﴾: وليختبرَ اللهُ المؤمنين بنِعَمِه وإحسانِه."
  8,18,"﴿مُوهِنُ﴾: مُضْعِفُ ومُبْطِلُ.﴿كَيۡدِ ٱلۡكَـٰفِرِينَ﴾: مَكْرِهم واحتيالِهم."
  8,19,"﴿تَسۡتَفۡتِحُواْ﴾: تطلُبوا النَّصْرَ أيها الكفارُ.﴿جَآءَكُمُ ٱلۡفَتۡحُ﴾: تَهَكُّمٌ بالكفارِ، فقد نَصَرَ اللهُ المؤمنين ب «بَدْرٍ».﴿وَإِن تَعُودُواْ﴾: إلى الكفرِ وقتالِ النبيِّ ﷺ.﴿نَعُدۡ﴾: بهزيمَتِكم ونَصْرِه - ﷺ - عليكم.﴿فِئَتُكُمۡ﴾: جماعتُكم.﴿مَعَ ٱلۡمُؤۡمِنِينَ﴾: بتأييدِه ونَصْرِه."
  8,20,"﴿وَلَا تَوَلَّوۡاْ﴾: ولا تُعْرِضُوا عن طاعةِ اللهِ ورسولهِ.﴿تَسۡمَعُونَ﴾: ما يُتلى عليكم من الحُجَجِ والبراهينِ."
  8,22,"﴿ٱلدَّوَآبِّ﴾: جَمْعُ دابّة، وهي: ما دَبَّ على الأرضِ مِن خَلْقِ اللهِ.﴿ٱلصُّمُّ﴾: مَنِ انسَدَّتْ آذانُهم عن سماعِ الحقِّ.﴿ٱلۡبُكۡمُ﴾: مَن خَرِسَتْ ألسنتُهم عن النُّطقِ به."
  8,23,"﴿لَّأَسۡمَعَهُمۡ﴾: مواعِظَ القرآنِ وعِبَرَه.﴿لَتَوَلَّواْ﴾: لَأَعْرَضُوا عن الإيمان عِنادًا.﴿مُّعۡرِضُونَ﴾: صادُّون عنه."
  8,24,"﴿لِمَا يُحۡيِيكُمۡ﴾: لما فيه الحياةُ الأبديةُ.﴿بَيۡنَ ٱلۡمَرۡءِ وَقَلۡبِهِۦ﴾: بين الإنسانِ وخواطِرِ قلبِه، فاللهُ أملكُ لقلوبِ عبادِه منهم."
  8,25,"﴿فِتۡنَةࣰ﴾: ابتلاءً ومِحْنَةً تنزِلُ بكم."
  8,26,"﴿مُّسۡتَضۡعَفُونَ﴾: قليلُو العَدَدِ، مَقْهُورون.﴿يَتَخَطَّفَكُمُ﴾: يَأْخُذَكُم بسُرعةٍ.﴿ٱلنَّاسُ﴾: كفارُ قريشٍ.﴿فَـَٔاوَىٰكُمۡ﴾: جَعَلَ اللهُ لكم «المدينةَ» مَأْوىً تَأْوُون إليه."
  8,27,"﴿لَا تَخُونُواْ ٱللَّهَ﴾: بتَرْكِ ما أوْجَبَه عليكم، وارتكابِ ما نَهاكم عنه.﴿أَمَـٰنَـٰتِكُمۡ﴾: ما ائتُمِنتُم عليه من التكاليفِ الشرعيةِ."
  8,28,"﴿فِتۡنَةࣱ﴾: اختبارٌ لكم."
  8,29,"﴿فُرۡقَانࣰا﴾: فَصْلًا بين الحَقِّ والباطِلِ."
  8,30,"﴿يَمۡكُرُ بِكَ﴾: يَكِيدُ لك.﴿لِيُثۡبِتُوكَ﴾: ليَحْبِسُوك.﴿يُخۡرِجُوكَ﴾: من بلدِك «مكةَ»."
  8,31,"﴿أَسَـٰطِيرُ ٱلۡأَوَّلِينَ﴾: جَمْعُ أُسْطُورة، وهي: ما سُطِّرَ في كُتُبِ السابقين من الأخبارِ المكذوبةِ."
  8,32,"﴿إِن كَانَ هَـٰذَا﴾: ما جاءَ به محمدٌ."
  8,33,"﴿وَأَنتَ فِيهِمۡ﴾: وأنت مقيمٌ بينَهم في «مكةَ»."
  8,34,"﴿وَمَا لَهُمۡ أَلَّا يُعَذِّبَهُمُ ٱللَّهُ﴾: وأيُّ شيءٍ يَمْنَعُ من عذابه لهم؟﴿يَصُدُّونَ﴾: يَمْنَعُون.﴿عَنِ ٱلۡمَسۡجِدِ ٱلۡحَرَامِ﴾: عن الطَّوافِ بالكعبةِ، والصَّلاةِ فيه.﴿وَمَا كَانُوٓاْ أَوۡلِيَآءَهُۥٓ﴾: وما كان الكفارُ أولياءَ اللهِ ولا المسجدِ الحرامِ."
  8,35,"﴿مُكَآءࣰ﴾: صَفيرًا.﴿وَتَصۡدِيَةࣰ﴾: وتَصْفيقًا.﴿فَذُوقُواْ ٱلۡعَذَابَ﴾: في الدنيا بالقَتْلِ والأَسْرِ في «بدرٍ»، وفي الآخرةِ بالنارِ."
  8,36,"﴿حَسۡرَةࣰ﴾: ندامةً وأَسَفًا."
  8,37,"﴿لِيَمِيزَ﴾: ليَفْصِلَ.﴿فَيَرۡكُمَهُۥ﴾: يَجْمَعَه ويَضُمَّ بعضَه إلى بعضٍ."
  8,38,"﴿إِن يَنتَهُواْ﴾: عن الكفرِ، ويَرْجِعُوا إلى الإيمان.﴿وَإِن يَعُودُواْ﴾: إلى قتالِ النبيِّ ﷺ.﴿مَضَتۡ﴾: سَبَقَتْ.﴿سُنَّتُ ٱلۡأَوَّلِينَ﴾: سنَّتُنا في عقوبةِ مَن كَذَّبَ واستمرَّ على كُفْرِه."
  8,39,"﴿فِتۡنَةࣱ﴾: شِرْكٌ وصَدٌّ عن سبيل الله.﴿وَيَكُونَ ٱلدِّينُ كُلُّهُۥ لِلَّهِ﴾: وتكونَ الطاعةُ والعبادةُ كلُّهاخالصةً لله.﴿فَإِنِ ٱنتَهَوۡاْ﴾: فإن انزجَرَ المشركون عن شِرْكِهم وفتنةِ المؤمنين."
  8,40,"﴿مَوۡلَىٰكُمۡ﴾: مُعينُكم وناصِرُكم."
  8,41,"﴿غَنِمۡتُم﴾: ظَفِرْتُمْ به من الأعداءِ بالجِهادِ.﴿وَلِذِي ٱلۡقُرۡبَىٰ﴾: قَرابةِ الرسولِ ﷺ، وهم بنو هاشمٍ وبنو المطَّلِبِ.﴿وَٱلۡيَتَـٰمَىٰ﴾: الأطفالِ الذين مات آباؤُهم وهم دونَ سِنِّ البُلوغ.﴿وَٱلۡمَسَـٰكِينِ﴾: أهلِ الحاجةِ الذين لا يَمْلِكُون ما يَكْفيهم.﴿وَٱبۡنِ ٱلسَّبِيلِ﴾: المسافرِ الذي انقطعَتْ به النفقةُ.﴿وَمَآ أَنزَلۡنَا﴾: من الملائكةِ والآياتِ والنَّصْرِ.﴿يَوۡمَ ٱلۡفُرۡقَانِ﴾: يومَ «بَدْرٍ» حينَ فَرَقَ اللهُ بينَ الحقِّ والباطلِ."
  8,42,"﴿بِٱلۡعُدۡوَةِ ٱلدُّنۡيَا﴾: جانبِ الوادي الأقربِ إلى «المدينة».﴿ٱلۡقُصۡوَىٰ﴾: البعيدةِ عن «المدينةِ».﴿وَٱلرَّكۡبُ﴾: عِيرُ التجارةِ وأصحابُها.﴿أَسۡفَلَ مِنكُمۡ﴾: في مكانٍ أسفلَ من مكانِكم جهةَ ساحلِ البحرِ الأحمرِ.﴿لِّيَقۡضِيَ ٱللَّهُ أَمۡرࣰا كَانَ مَفۡعُولࣰا﴾: بنَصْرِ أوليائِه وخِذْلانِ أعدائِه.﴿لِّيَهۡلِكَ مَنۡ هَلَكَ﴾: ليموتَ مَن يموتُ من الكفّارِ.﴿عَنۢ بَيِّنَةࣲ﴾: عن حُجَّةٍ عايَنَها.﴿وَيَحۡيَىٰ مَنۡ حَيَّ﴾: ويعيشَ مَن يعيشُ مِنهُم."
  8,43,"﴿لَّفَشِلۡتُمۡ﴾: لَجَبُنْتُم وضَعُفتم.﴿وَلَتَنَـٰزَعۡتُمۡ﴾: اختلَفْتُم.﴿فِي ٱلۡأَمۡرِ﴾: في القتالِ.﴿سَلَّمَ﴾: عَصَمَ من الضَّعْفِ والاختلافِ."
  8,45,"8:44"
  8,46,"﴿رِيحُكُمۡ﴾: قُوَّتُكم ونَصْرُكم.﴿مَعَ ٱلصَّـٰبِرِينَ﴾: بالعَوْنِ والنصرِ والتأييدِ."
  8,47,"﴿بَطَرࣰا﴾: كِبْرًا.﴿وَرِئَآءَ ٱلنَّاسِ﴾: مراءاةً لهم وطَلَبًا للفَخْرِ."
  8,48,"﴿زَيَّنَ﴾: حَسَّنَ.﴿جَارࣱ لَّكُمۡ﴾: مُعينٌ وناصرٌ لكم.﴿تَرَآءَتِ ٱلۡفِئَتَانِ﴾: التقى المسلمون مع الكفارِ.﴿نَكَصَ عَلَىٰ عَقِبَيۡهِ﴾: رَجَعَ إلى الوراء ووَلّى هاربًا.﴿إِنِّيٓ أَرَىٰ مَا لَا تَرَوۡنَ﴾: مِن الملائكةِ الذين جاؤوا لنُصْرَةِ المؤمنين."
  8,49,"﴿ٱلۡمُنَـٰفِقُونَ﴾: جَمْعُ مُنافق، وهو: مَن يُظهِرُ الإسلامَ ويُبْطِنُ الكفرَ.﴿فِي قُلُوبِهِم مَّرَضٌ﴾: ضِعافُ الإيمانِ الشاكُّون من غيرِ نِفاقٍ.﴿غَرَّ هَـٰٓؤُلَآءِ دِينُهُمۡ﴾: أي: اغترَّ المسلمون بدينِهم حتى تَكَلَّفُوا قتالَ المشركين.﴿يَتَوَكَّلۡ عَلَى ٱللَّهِ﴾: يُفَوِّضْ أمرَه إليه ويعتمدْ عليه."
  8,50,"﴿يَتَوَفَّى﴾: يَقْبِضُ ويَنْتَزِعُ.﴿وَأَدۡبَـٰرَهُمۡ﴾: ظهورَهم.﴿ٱلۡحَرِيقِ﴾: المُحْرِقِ، وهو جهنَّمُ."
  8,51,"﴿بِمَا قَدَّمَتۡ أَيۡدِيكُمۡ﴾: بسبب أعمالِكم السيئةِ.﴿لَيۡسَ بِظَلَّـٰمࣲ﴾: ليس بذي ظُلْمٍ."
  8,52,"﴿كَدَأۡبِ ءَالِ فِرۡعَوۡنَ﴾: حالُ المشركين في الكفرِ واستحقاقِ العذابِ كحالِ آلِ فرعونَ.﴿فَأَخَذَهُمُ ٱللَّهُ﴾: أنزلَ بهم عقابَه."
  8,53,"﴿ذَ ٰ⁠لِكَ﴾: أي: التعذيبُ على الأعمالِ السيئة."
  8,55,"﴿ٱلدَّوَآبِّ﴾: جَمْعُ دابَّةٍ، وهي: ما دَبَّ على الأرضِ من خَلْقِ اللهِ."
  8,56,"﴿عَـٰهَدتَّ﴾: التزَمْتَ معهم بميثاقٍ.﴿يَنقُضُونَ﴾: يُبْطِلُون."
  8,57,"﴿فَإِمَّا تَثۡقَفَنَّهُمۡ﴾: فإن ظَفِرْتَ بهم وصادَفْتَهم.﴿فَشَرِّدۡ بِهِم﴾: ففرِّقْ وخَوِّفْ بقَتْلهِم والتنكيلِ بهم.﴿مَّنۡ خَلۡفَهُمۡ﴾: غيرَهم من المحاربين."
  8,58,"﴿فَٱنۢبِذۡ إِلَيۡهِمۡ﴾: فألْقِ إليهم عَهْدَهم.﴿عَلَىٰ سَوَآءٍ﴾: حتى يَسْتَوِيَ الفريقان في العِلْم بأنه لا عَهْدَ بينَهم."
  8,59,"﴿سَبَقُوٓاْ﴾: أفلَتُوا ونَجَوْا من الظَّفَرِ بهم.﴿لَا يُعۡجِزُونَ﴾: لن يُفْلِتُوا من عذابِ اللهِ."
  8,60,"﴿وَأَعِدُّواْ﴾: وهَيِّئوا.﴿رِّبَاطِ ٱلۡخَيۡلِ﴾: إعدادِها ورَبْطِها؛ انتظارًا للغَزْوِ عليها.﴿تُرۡهِبُونَ﴾: تُخَوِّفُون.﴿مِن دُونِهِمۡ﴾: مِن غيرِهم.﴿لَا تَعۡلَمُونَهُمُ﴾: لم تَظْهَرْ لكم عداوتُهم.﴿يُوَفَّ إِلَيۡكُمۡ﴾: يُخْلِفْه اللهُ لكم في الدنيا، ويَدَّخِرْ لكم ثوابَه في الآخرة.﴿لَا تُظۡلَمُونَ﴾: لا تُنْقَصُون شيئًا من أجرِ الإنفاقِ."
  8,61,"﴿جَنَحُواْ﴾: مالَ المحارِبُون.﴿لِلسَّلۡمِ﴾: للمُسالمةِ وتَرْكِ الحربِ.﴿فَٱجۡنَحۡ لَهَا﴾: فمِلْ إلى المصالحةِ.﴿وَتَوَكَّلۡ عَلَى ٱللَّهِ﴾: اعتمِدْ عليه وفَوِّضْ أمْرَك إليه."
  8,62,"﴿يَخۡدَعُوكَ﴾: يُدَبِّرُوا إيقاعَك فيما تَكْرَهُ.﴿حَسۡبَكَ ٱللَّهُ﴾: كافِيك وناصِرُك."
  8,63,"﴿وَأَلَّفَ﴾: وجَمَعَ."
  8,65,"﴿حَرِّضِ﴾: بالِغْ في الحَثِّ.﴿لَّا يَفۡقَهُونَ﴾: لا يَعْلمون ما أعَدَّه اللهُ للمجاهدين في سبيلِه."
  8,66,"﴿مَعَ ٱلصَّـٰبِرِينَ﴾: بتأييدِه ونَصْرِه."
  8,67,"﴿يُثۡخِنَ﴾: يُبالِغَ في قَتْلِ الأعداءِ.﴿عَرَضَ ٱلدُّنۡيَا﴾: حُطامَها، وهو: الفِداءُ من أسْرى «بدر».﴿يُرِيدُ ٱلۡـَٔاخِرَةَ﴾: ثوابَها، بإظهارِ الدِّين، وما يَحْصِلُ لكم من أجْر الجهادِ.﴿عَزِيزٌ﴾: قويٌّ قادرٌ لا يُقْهَرُ.﴿حَكِيمࣱ﴾: ذو حِكْمةٍ في أفعالِه كلِّها."
  8,68,"﴿كِتَـٰبࣱ مِّنَ ٱللَّهِ﴾: قَضاءٌ وحُكْمٌ منه.﴿سَبَقَ﴾: بإباحةِ الغنيمةِ وفِداءِ الأسرى.﴿لَمَسَّكُمۡ﴾: لَأصابَكم."
  8,69,"﴿مِمَّا غَنِمۡتُمۡ﴾: مِن قِتالِ عَدُوِّكم وفِداءِ الأسرى."
  8,70,"﴿مِّمَّآ أُخِذَ مِنكُمۡ﴾: من المالِ بأن يُيَسِّرَ اللهُ لكم من فَضْلِه خيرًا كثيرًا."
  8,71,"﴿خِيَانَتَكَ﴾: بالغَدْرِ بك وخِداعِكَ.﴿خَانُواْ ٱللَّهَ﴾: بمخالفةِ أمْرِه.﴿مِن قَبۡلُ﴾: قبلَ غزوةِ «بدرٍ».﴿فَأَمۡكَنَ مِنۡهُمۡ﴾: فأقدرك الله عليهم ونَصَرَك."
  8,72,"﴿وَهَاجَرُواْ﴾: انتقلُوا إلى دارِ الإسلام، أو بلدٍ يتمكَّنُون فيه من العبادةِ.﴿وَٱلَّذِينَ ءَاوَواْ﴾: هم الأنصارُ الذين أسكنُوا النبيَّ ﷺ والمهاجرين في دُورِهم.﴿أَوۡلِيَآءُ بَعۡضࣲ﴾: في النُّصْرَةِ والمعونةِ.﴿وَلَـٰيَتِهِم﴾: نُصْرَتهِم.﴿ٱسۡتَنصَرُوكُمۡ﴾: طلبُوا نُصْرَتَكم.﴿فِي ٱلدِّينِ﴾: بأنهم من أهلِ دينِكم.﴿مِّيثَـٰقࣱ﴾: عَهْدٌ مؤكَّدٌ."
  8,73,"﴿إِلَّا تَفۡعَلُوهُ﴾: أي: تَوَلِّيَ المؤمنين ونُصْرتهم.﴿فِتۡنَةࣱ﴾: للمؤمنين عن دينِهم.﴿وَفَسَادࣱ كَبِيرࣱ﴾: بالصَّدِّ عن سبيلِ اللهِ، وقوةِ الكفرِ."
  8,75,"﴿مِنۢ بَعۡدُ﴾: بعدَ السابقين إلى الإيمانِ والهجرةِ.﴿فَأُوْلَـٰٓئِكَ مِنكُمۡ﴾: أي: لهم ما لكم وعليهم ما عليكم.﴿وَأُوْلُواْ ٱلۡأَرۡحَامِ﴾: ذَوو القَراباتِ.﴿أَوۡلَىٰ بِبَعۡضࣲ﴾: في الميراثِ من عامَّةِ المسلمين.﴿كِتَـٰبِ ٱللَّهِ﴾: حُكْمِه الذي كَتَبَه في اللَّوحِ المحفوظِ."
