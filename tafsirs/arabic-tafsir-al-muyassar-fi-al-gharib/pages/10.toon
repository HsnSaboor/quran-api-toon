tafsir[94]{c,v,t}:
  10,1,"﴿ٱلۡحَكِيمِ﴾: المُحْكَمِ في لَفْظِه ومعناه."
  10,2,"﴿قَدَمَ صِدۡقٍ﴾: أجرًا حسنًا؛ بما قَدَّموا من صالحِ الأعمالِ."
  10,3,"﴿ٱسۡتَوَىٰ﴾: علا وارتفعَ، استواءً يَليق بجَلالِه وعَظَمَتِه.﴿يُدَبِّرُ ٱلۡأَمۡرَ﴾: يَقْضِي أمورَ الدنيا والآخرةِ، ويُصَرِّفُها وحدَه على أكملِ الوجوهِ.﴿إِلَّا مِنۢ بَعۡدِ إِذۡنِهِۦ﴾: إلا أنْ يأذنَ اللهُ له بالشفاعةِ."
  10,4,"﴿مَرۡجِعُكُمۡ﴾: مَعادُكم يومَ القيامةِ.﴿بِٱلۡقِسۡطِ﴾: بالعَدْلِ.﴿حَمِيمࣲ﴾: ماءٍ شديدِ الحرارةِ."
  10,5,"﴿ضِيَآءࣰ﴾: ذاتَ ضياءٍ في النهار.﴿نُورࣰا﴾: ذاتَ نورٍ في الليل.﴿وَقَدَّرَهُۥ مَنَازِلَ﴾: وهَيَّأ للقَمَرِ منازلَ لا يتَعدّاها.﴿وَٱلۡحِسَابَ﴾: ولتعلمُوا حسابَ الأشهرِ والأيامِ.﴿ذَ ٰ⁠لِكَ﴾: أي: الَخلْقُ والتقديرُ.﴿إِلَّا بِٱلۡحَقِّ﴾: إلا لحكمةٍ عظيمةٍ بالغةٍ.﴿يُفَصِّلُ﴾: يُبَيِّنُ.﴿ٱلۡـَٔايَـٰتِ﴾: الحُجَجَ والأدَّلةَ الدالَّةَ على عَظَمَتِه."
  10,6,"﴿ٱخۡتِلَـٰفِ ٱلَّيۡلِ وَٱلنَّهَارِ﴾: إتيانِ أحدِهما بعد الآخَرِ."
  10,7,"﴿لَا يَرۡجُونَ لِقَآءَنَا﴾: لا يتوقَّعُون حسابَ الآخرةِ.﴿وَٱطۡمَأَنُّواْ بِهَا﴾: رَكَنُوا إليها.﴿ءَايَـٰتِنَا﴾: الكونيةِ والشرعيةِ.﴿غَـٰفِلُونَ﴾: ساهُون ومُعْرِضُون."
  10,9,"﴿يَهۡدِيهِمۡ﴾: يُرْشِدُهم، ويُوَفِّقُهم إلى العملِ المُوصِلِ إلى الجنة.﴿مِن تَحۡتِهِمُ﴾: مِن تحتِ غُرَفِهم ومنازلهِم."
  10,10,"﴿دَعۡوَىٰهُمۡ فِيهَا سُبۡحَـٰنَكَ ٱللَّهُمَّ﴾: دعاؤُهم الذي يَدْعُون به في الجنةِ التسبيحُ والتنزيهُ لله.﴿وَتَحِيَّتُهُمۡ﴾: من اللهِ وملائكتِه لهم، وتحيةُ بعضِهم بعضًا.﴿سَلَـٰمࣱ﴾: دعاءٌ لهم بالسَّلامةِ من كلِّ مكروهٍ."
  10,11,"﴿ٱلشَّرَّ﴾: إجابةَ دعائِهم في الشرِّ.﴿ٱسۡتِعۡجَالَهُم بِٱلۡخَيۡرِ﴾: تعجيلَ اللهِ لهم بالخيرِ.﴿لَقُضِيَ إِلَيۡهِمۡ أَجَلُهُمۡ﴾: لأُهْلِكُوا جميعًا.﴿فَنَذَرُ﴾: نَتْرُكُ.﴿طُغۡيَـٰنِهِمۡ﴾: تجاوُزِهم الَحدَّ في إنكارِ البعثِ.﴿يَعۡمَهُونَ﴾: يتردَّدُون متحَيِّرين."
  10,12,"﴿مَسَّ﴾: أصاب.﴿ٱلضُّرُّ﴾: الشِّدَّةُ والمكروهُ.﴿لِجَنۢبِهِۦٓ﴾: مُضْطجعًا على جَنْبِه.﴿مَرَّ كَأَن لَّمۡ يَدۡعُنَآ﴾: استمرَّ على ما كان عليه قبل أن يُبْتلى.﴿لِلۡمُسۡرِفِينَ﴾: المتجاوِزِين الَحدَّ في الكفرِ والمعاصي."
  10,13,"﴿ٱلۡقُرُونَ﴾: جَمْعُ قَرْن، وهم: القومُ المقتَرِنون في زمانٍ واحدٍ.﴿ظَلَمُواْ﴾: أشرَكُوا وكَذَّبُوا.﴿بِٱلۡبَيِّنَـٰتِ﴾: الدَّلالاتِ الواضحاتِ الدالَّةِ على صدقِهم."
  10,14,"﴿خَلَـٰٓئِفَ﴾: جَمْعُ خليفة، وهو مَن يَخْلُفُ غيرَه."
  10,15,"﴿بَيِّنَـٰتࣲ﴾: واضحاتٍ.﴿لَا يَرۡجُونَ لِقَآءَنَا﴾: لا يتَوقَّعُون حسابَ الآخرةِ.﴿أَوۡ بَدِّلۡهُ﴾: أو غَيِّرْ فيه بما ليس منه."
  10,16,"﴿وَلَآ أَدۡرَىٰكُم بِهِۦ﴾: ولا أعْلَمَكم به على لساني.﴿عُمُرࣰا﴾: زَمَنًا طويلًا، وهو أربعون سنةً."
  10,17,"﴿ٱفۡتَرَىٰ﴾: اختَلَق."
  10,18,"﴿شُفَعَـٰٓؤُنَا﴾: يَشْفَعُون لنا.﴿بِمَا لَا يَعۡلَمُ﴾: وهو أنّ له شفيعًا عندَه بغيرِ إذنِه.﴿سُبۡحَـٰنَهُۥ﴾: تنزيهًا له."
  10,19,"﴿أُمَّةࣰ وَ ٰ⁠حِدَةࣰ﴾: على دينٍ واحدٍ، وهو الإسلامُ.﴿وَلَوۡلَا كَلِمَةࣱ سَبَقَتۡ مِن رَّبِّكَ﴾: وهي تأخيرُه القضاءَ بينَهم إلى يومِ القيامةِ.﴿لَقُضِيَ بَيۡنَهُمۡ﴾: عاجلًا في الدُّنيا."
  10,20,"﴿لَوۡلَآ﴾: هَلّا.﴿ءَايَةࣱ﴾: علامةٌ حِسِّيةٌ مما اقترحُوه، كجَعْلِ الجبالِ ذَهَبًا.﴿إِنَّمَا ٱلۡغَيۡبُ لِلَّهِ﴾: نُزولُ الآيةِ غَيْبٌ، واللهُ هو المختصُّ به."
  10,21,"﴿ٱلنَّاسَ﴾: المشركين.﴿رَحۡمَةࣰ﴾: يُسْرًا ورَخاءً.﴿ضَرَّآءَ﴾: شِدَّةً وبَلاءً.﴿مَّكۡرࣱ فِيٓ ءَايَاتِنَا﴾: بالتكذيبِ والاستهزاءِ بها.﴿أَسۡرَعُ مَكۡرًا﴾: أسرعُ استدراجًا وعقوبةً لكم.﴿رُسُلَنَا﴾: الكَتَبةَ من الملائكةِ."
  10,22,"﴿ٱلۡفُلۡكِ﴾: السُّفُنِ.﴿طَيِّبَةࣲ﴾: سَهْلَةِ الهُبوبِ، موافِقَةٍ للغَرَضِ والمنفعةِ.﴿عَاصِفࣱ﴾: شديدةُ الهبوبِ.﴿وَظَنُّوٓاْ﴾: أيقَنُوا.﴿أُحِيطَ بِهِمۡ﴾: وقَعَ عليهم الهلاكُ.﴿ٱلدِّينَ﴾: الدُّعاءَ."
  10,23,"﴿يَبۡغُونَ فِي ٱلۡأَرۡضِ﴾: يُفْسِدُون فيها متجاوِزينَ الحَدَّ في المعاصي.﴿بَغۡيُكُمۡ عَلَىٰٓ أَنفُسِكُم﴾: مَصِيرُ فسادِكم عائدٌ عليكم.﴿مَّتَـٰعَ ٱلۡحَيَوٰةِ ٱلدُّنۡيَا﴾: تتمتعون به مَتاعًا زائلًا."
  10,24,"﴿مَثَلُ ٱلۡحَيَوٰةِ ٱلدُّنۡيَا﴾: حالُها في سُرْعَةِ انقضائِها وذَهابِ لَذّاتِها.﴿فَٱخۡتَلَطَ بِهِۦ نَبَاتُ ٱلۡأَرۡضِ﴾: فَنَبتَ بماءِ المطر أنواعٌ من النباتِ، تشابَكَتْ واختلَطَ بعضُها ببعض.﴿أَخَذَتِ ٱلۡأَرۡضُ زُخۡرُفَهَا﴾: ظَهَرَ حُسْنُها واستكمَلَت بهاءَها.﴿وَٱزَّيَّنَتۡ﴾: وتَزَيَّنَتْ بأصنافِ النباتِ وأشكالِه وألوانِه.﴿وَظَنَّ﴾: أيقنَ.﴿قَـٰدِرُونَ عَلَيۡهَآ﴾: مُتَمَكِّنون مِن جَنْي ثمارِها والانتفاعِ بها.﴿أَمۡرُنَا﴾: قضاؤُنا بهَلاكِ ما عليها من النباتِ والزينةِ.﴿فَجَعَلۡنَـٰهَا حَصِيدࣰا﴾: فجَعَلْنا زَرْعَها كالنَّباتِ المقطوعِ.﴿كَأَن لَّمۡ تَغۡنَ﴾: كأن لم تَكُنِ الزروعُ قائمةً على ظَهْرِ الأرض.﴿بِٱلۡأَمۡسِ﴾: في الماضي القريب.﴿نُفَصِّلُ﴾: نُبَيِّنُ.﴿ٱلۡـَٔايَـٰتِ﴾: الحُجَجَ والأدلَّةَ الواضحةَ."
  10,25,"﴿دَارِ ٱلسَّلَـٰمِ﴾: الجنةِ.﴿وَيَهۡدِي﴾: وُيَوفِّقُ.﴿صِرَ ٰ⁠طࣲ مُّسۡتَقِيمࣲ﴾: الطريقِ الواضحِ، وهو دينُ الإسلامِ."
  10,26,"﴿ٱلۡحُسۡنَىٰ﴾: الجنةُ.﴿وَزِيَادَةࣱ﴾: النظرُ إلى وجهِ اللهِ الكريمِ في الجنةِ.﴿وَلَا يَرۡهَقُ﴾: لا يَغْشى ولا يعلوُ.﴿قَتَرࣱ﴾: غبارٌ فيه سَوادٌ.﴿ذِلَّةٌ﴾: هَوانٌ وكآبةٌ."
  10,27,"﴿كَسَبُواْ﴾: عَمِلُوا.﴿مِّنَ ٱللَّهِ﴾: من عذابِه.﴿مِنۡ عَاصِمࣲ﴾: من مانعٍ.﴿قِطَعࣰا﴾: أجزاءً."
  10,28,"﴿قِطَعࣰا﴾: الزَمُوا مكانَكم في موقفِ الحسابِ.﴿أَنتُمۡ وَشُرَكَآؤُكُمۡ﴾: أنتم وآلهتكُم، حتى تَرَوْا ما يُفْعَلُ بكم.﴿فَزَيَّلۡنَا بَيۡنَهُمۡ﴾: فرَّقْنا بينَ المشركين ومَعْبُوديهم."
  10,30,"﴿تَبۡلُواْ﴾: تَخْتَبِرُ وتَعْلَمُ.﴿مَّآ أَسۡلَفَتۡ﴾: ما قَدَّمَتْ مِن عَمَلٍ.﴿وَضَلَّ﴾: ذَهَبَ وبَطَلَ.﴿يَفۡتَرُونَ﴾: يَعْبُدون مِن آلهةٍ مزعومةٍ."
  10,31,"﴿يُدَبِّرُ ٱلۡأَمۡرَ﴾: يَقْضي أمورَ الدُّنيا والآخرةِ ويُصَرِّفُها وحدَه على أكملِ الوجوهِ."
  10,32,"﴿فَأَنَّىٰ تُصۡرَفُونَ﴾: فكيف تُصْرَفون عن عبادةِ اللهِ إلى عبادةِ غيره؟"
  10,33,"﴿حَقَّتۡ﴾: وجَبَتْ.﴿كَلِمَتُ رَبِّكَ﴾: حُكْمُه وقضاؤُه.﴿فَسَقُوٓاْ﴾: خرجُوا عن طاعةِ اللهِ وكفرُوا به."
  10,34,"﴿فَأَنَّىٰ تُؤۡفَكُونَ﴾: فكيف تُصْرَفون عن الحقِّ إلى الباطلِ؟"
  10,35,"﴿يَهۡدِيٓ إِلَى ٱلۡحَقِّ﴾: يُرْشِدُ إليه.﴿يَهۡدِي لِلۡحَقِّ﴾: يُرْشِدُ ويُوَفِّقُ إليه.﴿لَّا يَهِدِّيٓ﴾: لا يهتدي بنفسه."
  10,36,"﴿ظَنًّا﴾: تَخْمينًا وتوهُّمًا."
  10,37,"﴿تَصۡدِيقَ ٱلَّذِي بَيۡنَ يَدَيۡهِ﴾: مُصَدِّقًا للكتبِ التي أنزلها اللهُ على أنبيائِه.﴿وَتَفۡصِيلَ ٱلۡكِتَـٰبِ﴾: ومُفَصِّلًا لما شَرَعَه اللهُ فيه من العقائِد والأحكامِ."
  10,38,"﴿وَٱدۡعُواْ مَنِ ٱسۡتَطَعۡتُم﴾: واستَعِينُوا بمَن أمْكَنَكم الاستعانةُ به."
  10,39,"﴿كَذَّبُواْ﴾: سارَعُوا إلى التكذيبِ.﴿بِمَا لَمۡ يُحِيطُواْ بِعِلۡمِهِۦ﴾: أي: بالقرآنِ، قبل أن يُدْرِكُوا ما اشتملَ عليه.﴿وَلَمَّا يَأۡتِهِمۡ تَأۡوِيلُهُۥ﴾: ولَمّا يأتِهم عاقبةُ ما تَوَعَّدَهم اللهُ به في القرآنِ."
  10,41,"10:40"
  10,42,"﴿ٱلصُّمَّ﴾: الذين لا ينتفِعُون بسماعِ القرآنِ، ولا يَقْبَلُون ما فيه."
  10,43,"﴿يَنظُرُ إِلَيۡكَ﴾: يعايِنُ دلائلَ نبوَّتِك الصادقةِ، فلا ينتفعُ بها."
  10,45,"﴿لَّمۡ يَلۡبَثُوٓاْ﴾: لم يَمْكُثوا في الدنيا.﴿يَتَعَارَفُونَ بَيۡنَهُمۡ﴾: يَعْرِفُ بعضُهم بعضًا كحالِهم في الدنيا."
  10,46,"﴿أَوۡ نَتَوَفَّيَنَّكَ﴾: أي: قبلَ تعذيبِهم.﴿شَهِيدٌ عَلَىٰ مَا يَفۡعَلُونَ﴾: مُطَّلِعٌ على أعمالِهم، ومُجازِيهم عليها."
  10,47,"﴿جَآءَ رَسُولُهُمۡ﴾: في الدنيا، وبَلَّغَهم فكذَّبُوه، أو في الآخرةِ للشهادةِ عليهم.﴿بِٱلۡقِسۡطِ﴾: بالعَدْلِ."
  10,48,"﴿هَـٰذَا ٱلۡوَعۡدُ﴾: قيامُ الساعةِ والعذابُ الذي تُخَوِّفنا به."
  10,49,"﴿أَجَلٌ﴾: مدةٌ معلومةٌ لانقضاءِ آجالِهم.﴿فَلَا يَسۡتَـٔۡخِرُونَ﴾: لا يتأخَّرُون عنه.﴿وَلَا يَسۡتَقۡدِمُونَ﴾: لا يتقدَّمُون عليه."
  10,50,"﴿أَرَءَيۡتُمۡ﴾: أخْبِرُوني.﴿بَيَـٰتًا﴾: ليلًا.﴿مَّاذَا يَسۡتَعۡجِلُ مِنۡهُ﴾: أيُّ شيءٍ من أنواعِ العذابِ يَسْتعجلُونه؟"
  10,51,"﴿ءَآلۡـَٔـٰنَ﴾: أتؤمنون بالعذابِ حين لا ينفعُكم الإيمانُ؟"
  10,52,"﴿عَذَابَ ٱلۡخُلۡدِ﴾: الدائمَ الذي لا ينقطعُ، وهوجَهَنَّمُ."
  10,53,"﴿وَيَسۡتَنۢبِـُٔونَكَ﴾: ويستخبِرُك المشركون عن العذابِ.﴿إِي وَرَبِّيٓ﴾: نَعَمْ وربِّي.﴿وَمَآ أَنتُم بِمُعۡجِزِينَ﴾: بفائتين من عذابِ اللهِ بالهَرَبِ."
  10,54,"﴿ظَلَمَتۡ﴾: أشرَكَتْ وكَفَرَتْ.﴿لَٱفۡتَدَتۡ بِهِۦ﴾: لَجَعَلَتْه فِدْيَةً لها من عذابِ الآخرةِ.﴿وَأَسَرُّواْ ٱلنَّدَامَةَ﴾: أخْفَوا الغَمَّ والحَسْرَةَ.﴿بِٱلۡقِسۡطِ﴾: بالعَدْلِ."
  10,56,"10:55"
  10,57,"﴿مَّوۡعِظَةࣱ﴾: هو القرآنُ العظيمُ."
  10,58,"﴿بِفَضۡلِ ٱللَّهِ﴾: الذي تَفَضَّلَ به عليكم، وهو الإسلامُ والإيمانُ.﴿وَبِرَحۡمَتِهِۦ﴾: التي رَحِمَكم بها، وهي إنزالُ القرآنِ."
  10,59,"﴿أَرَءَيۡتُم﴾: أخْبِروني.﴿مَّآ أَنزَلَ ٱللَّهُ﴾: ما خَلَقه اللهُ لأجلِ نَفْعِكم.﴿أَمۡ عَلَى ٱللَّهِ تَفۡتَرُونَ﴾: تَكْذِبُون بنسبةِ التحريمِ والتحليلِ إليه."
  10,60,"﴿وَمَا ظَنُّ ٱلَّذِينَ يَفۡتَرُونَ عَلَى ٱللَّهِ ٱلۡكَذِبَ﴾: أيُّ شيءٍ ظَنُّهم، وما يُصْنَعُ بهم فيه؟"
  10,61,"﴿فِي شَأۡنࣲ﴾: في أمْرٍمن أمورِك.﴿شُهُودًا﴾: رُقَباءَ مُطَّلِعِين عليه.﴿تُفِيضُونَ فِيهِ﴾: تَشْرَعُون فيه وتَعْمَلُونه.﴿وَمَا يَعۡزُبُ﴾: ما يَغِيبُ ولا يَبْعُدُ.﴿مِّثۡقَالِ ذَرَّةࣲ﴾: وزنِ أصغرِ نملةٍ.﴿كِتَـٰبࣲ مُّبِينٍ﴾: واضحٍ، وهو اللَّوحُ المحفوظُ."
  10,62,"﴿وَلَا هُمۡ يَحۡزَنُونَ﴾: على ما فاتهم من حُظوظِ الدُّنيا."
  10,64,"﴿ٱلۡبُشۡرَىٰ﴾: البِشارةُ بما يَسُرُّهم.﴿لَا تَبۡدِيلَ لِكَلِمَـٰتِ ٱللَّهِ﴾: لا إخلافَ لوَعْدِ اللهِ."
  10,65,"﴿ٱلۡعِزَّةَ لِلَّهِ جَمِيعًا﴾: الغَلَبَةَ، والقوةَ والقدرةَ التامةَ له تعالى."
  10,66,"﴿ٱلظَّنَّ﴾: الشَّكَّ.﴿يَخۡرُصُونَ﴾: يَكْذِبُون فيما يَنْسُبونَه إلى اللهِ."
  10,67,"﴿مُبۡصِرًا﴾: مُضِيئًا يُبْصِرُ فيه الناسُ.﴿لَـَٔايَـٰتࣲ﴾: دَلالاتٍ وحججًا."
  10,68,"﴿سُبۡحَـٰنَهُۥ﴾: تَنْزِيهًا له عَمّا نَسَبُوه إليه.﴿إِنۡ عِندَكُم﴾: ليس لَدَيكم.﴿سُلۡطَـٰنِۭ﴾: حُجَّةٍ وبُرهانٍ."
  10,70,"﴿مَرۡجِعُهُمۡ﴾: مَصِيرُهم."
  10,71,"﴿كَبُرَ عَلَيۡكُم﴾: عَظُمَ وثَقُلَ عليكم.﴿مَّقَامِي﴾: إقامتي بينكم.﴿وَتَذۡكِيرِي﴾: ووَعْظِي إياكم.﴿بِـَٔايَـٰتِ ٱللَّهِ﴾: بحُجَجِه وبَراهينِه.﴿فَعَلَى ٱللَّهِ تَوَكَّلۡتُ﴾: اعتمَدْتُ وفوَّضْتُ أمري إليه.﴿فَأَجۡمِعُوٓاْ أَمۡرَكُمۡ﴾: اكتُمُوه واعزِمُوا عليه.﴿وَشُرَكَآءَكُمۡ﴾: وادْعُوا آلهتَكم؛ لنُصْرَتِكم.﴿غُمَّةࣰ﴾: مُسْتَتِرًا خَفِيًّا.﴿ٱقۡضُوٓاْ إِلَيَّ﴾: افعَلُوا ما تُريدون بي من العقوبةِ.﴿وَلَا تُنظِرُونِ﴾: ولا تُمهِلُوني."
  10,72,"﴿تَوَلَّيۡتُمۡ﴾: أعْرَضْتُم عن الإيمان."
  10,73,"﴿ٱلۡفُلۡكِ﴾: السَّفينةِ.﴿خَلَـٰٓئِفَ﴾: أي: يَخْلُفُون الذين هَلَكُوا بالغَرَقِ."
  10,74,"﴿بِٱلۡبَيِّنَـٰتِ﴾: بالمعجزاتِ الدالَّةِ على صِدْقِهم.﴿نَطۡبَعُ﴾: نَخْتِمُ.﴿ٱلۡمُعۡتَدِينَ﴾: المتجاوِزين حُدودَ اللهِ."
  10,75,"﴿وَمَلَإِيْهِۦ﴾: أشرافِ قومِه."
  10,76,"﴿ٱلۡحَقُّ﴾: المعجزاتُ التي أظْهرها موسى عليه السلام."
  10,78,"﴿لِتَلۡفِتَنَا﴾: لتَصْرِفَنا.﴿ٱلۡكِبۡرِيَآءُ﴾: المُلْكُ والسُّلْطانُ.﴿ٱلۡأَرۡضِ﴾: أرضِ مصرَ."
  10,79,"﴿عَلِيمࣲ﴾: مُتْقِنٍ للسِّحْرِ."
  10,81,"10:80"
  10,82,"﴿وَيُحِقُّ ٱللَّهُ ٱلۡحَقَّ﴾: يُثَبِّتُه ويُظْهِره.﴿بِكَلِمَـٰتِهِۦ﴾: بقضائِه وأمْرِه."
  10,83,"﴿يَفۡتِنَهُمۡ﴾: يُعَذِّبَهم؛ ليَحْمِلَهم على الرجوعِ عن الإيمان.﴿لَعَالࣲ﴾: متكبِّرٌ متطاولٌ.﴿ٱلۡمُسۡرِفِينَ﴾: المتجاوِزِين الحَدَّ في الكفرِ والفسادِ."
  10,85,"﴿فِتۡنَةࣰ﴾: موضعَ ابتلاءٍ واختبارٍ."
  10,87,"﴿تَبَوَّءَا﴾: اتَّخِذا.﴿وَٱجۡعَلُواْ بُيُوتَكُمۡ﴾: أي: اجعَلُوها مساجدَ تُصَلُّون فيها عند الخوفِ."
  10,88,"﴿ٱطۡمِسۡ عَلَىٰٓ أَمۡوَ ٰ⁠لِهِمۡ﴾: أهْلِكْها وأتْلِفْها.﴿وَٱشۡدُدۡ عَلَىٰ قُلُوبِهِمۡ﴾: اخْتِمْ عليها."
  10,90,"﴿وَجَـٰوَزۡنَا بِبَنِيٓ إِسۡرَ ٰ⁠ٓءِيلَ ٱلۡبَحۡرَ﴾: قَطَعْناه بهم حتى تَرَكُوه وراءَهم.﴿فَأَتۡبَعَهُمۡ﴾: لَحِقَهم.﴿بَغۡيࣰا وَعَدۡوًا﴾: ظُلْمًا واعتداءً.﴿أَدۡرَكَهُ ٱلۡغَرَقُ﴾: أحاطَ به، وقَرُبَ هَلاكُه."
  10,91,"﴿ءَآلۡـَٔـٰنَ﴾: آلآن تُؤْمِنُ حين نَزَلَ بك الموتُ؟"
  10,92,"﴿نُنَجِّيكَ﴾: نَجْعَلُكَ على مُرْتفَعٍ من الأرضِ.﴿بِبَدَنِكَ﴾: بجَسَدِك الذي لا رُوحَ فيه.﴿خَلۡفَكَ﴾: بَعْدَك من الناسِ.﴿ءَايَةࣰ﴾: عِبرةً يعتبرون بك."
  10,93,"﴿بَوَّأۡنَا﴾: أنْزَلْنا وأسْكَنّا.﴿مُبَوَّأَ صِدۡقࣲ﴾: مَنزلًا كريمًا مختارًا.﴿يَقۡضِي﴾: يَحْكُمُ."
  10,94,"﴿ٱلۡكِتَـٰبَ﴾: التوراةَ والإنجيلَ.﴿ٱلۡمُمۡتَرِينَ﴾: الشاكِّين."
  10,95,"﴿بِـَٔايَـٰتِ ٱللَّهِ﴾: بحُجَجِه وأدِلَّتِه."
  10,96,"﴿حَقَّتۡ﴾: وجَبَتْ."
  10,97,"﴿ءَايَةٍ﴾: عِبْرةٍ وموعظةٍ."
  10,98,"﴿فَلَوۡلَا﴾: فهَلّا.﴿ٱلۡخِزۡيِ﴾: الذُّلِّ والهَوانِ.﴿إِلَىٰ حِينࣲ﴾: إلى وقتِ انقضاءِ آجالِهم."
  10,100,"﴿ٱلرِّجۡسَ﴾: عذابَ اللهِ وغَضَبَه."
  10,101,"﴿ٱنظُرُواْ﴾: تَفَكَّرُوا واعتَبِرُوا.﴿ٱلۡـَٔايَـٰتُ﴾: الدلائلُ والعِبَرُ.﴿وَٱلنُّذُرُ﴾: جَمْعُ نَذِير، وهم: الرسُلُ."
  10,102,"﴿مِثۡلَ أَيَّامِ ٱلَّذِينَ خَلَوۡاْ مِن قَبۡلِهِمۡ﴾: مثلَ ما حَلَّ بالأممِ السابقةِ من العذابِ."
  10,104,"﴿يَتَوَفَّىٰكُمۡ﴾: يُمِيتُكم."
  10,105,"﴿أَقِمۡ وَجۡهَكَ لِلدِّينِ﴾: استقِمْ على دينِ الإسلامِ مُخْلِصًا لله في عبادتِك وعَمَلِك.﴿حَنِيفࣰا﴾: مائلًا عن الأديانِ الباطلةِ."
  10,106,"﴿ٱلظَّـٰلِمِينَ﴾: المُشْركين."
  10,107,"﴿بِضُرࣲّ﴾: بشدَّةٍ أو بلاءٍ.﴿بِخَيۡرࣲ﴾: برَخاءٍ أو نِعْمةٍ."
  10,108,"﴿ٱلۡحَقُّ﴾: القرآنُ العظيمُ.﴿بِوَكِيلࣲ﴾: بحَفيظٍ أحفَظُ أمورَكم."
