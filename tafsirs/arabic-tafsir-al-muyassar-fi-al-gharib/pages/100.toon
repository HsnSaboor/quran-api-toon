tafsir[11]{c,v,t}:
  100,1,"﴿وَٱلۡعَـٰدِيَـٰتِ﴾: أقْسَمَ اللهُ تَعالى بالخَيلِ الجارياتِ في سَبِيلِ اللهِ.﴿ضَبۡحࣰا﴾: حِينَ يَظْهَرُ صَوْتُها مِن سُرْعَةِ عَدْوِها."
  100,2,"﴿فَٱلۡمُورِيَـٰتِ قَدۡحࣰا﴾: فالخَيلِ اللاتِي تَنْقَدِحُ النّارُ مِن حَوافِرِها؛ من شِدَّةِ عَدْوِها."
  100,3,"﴿فَٱلۡمُغِيرَ ٰ⁠تِ﴾: فالمُغِيراتِ عَلى الأعداءِ.﴿صُبۡحࣰا﴾: عِنْدَ الصُّبْحِ."
  100,4,"﴿فَأَثَرۡنَ بِهِۦ﴾: فهَيَّجْنَ بِهذا العَدْوِ.﴿نَقۡعࣰا﴾: غُبارًا."
  100,5,"﴿فَوَسَطۡنَ بِهِۦ﴾: فتوسَّطْنَ بِرُكْبانِهِنَّ.﴿جَمۡعًا﴾: جُموعَ الأعداءِ."
  100,6,"﴿لِرَبِّهِۦ لَكَنُودࣱ﴾: لِنِعَمِ رَبَّهِ لَجَحُودٌ."
  100,7,"﴿عَلَىٰ ذَ ٰ⁠لِكَ لَشَهِيدࣱ﴾: مُقِرٌّ بِجُحُودِهِ."
  100,8,"﴿ٱلۡخَيۡرِ﴾: المالِ."
  100,9,"﴿بُعۡثِرَ مَا فِي ٱلۡقُبُورِ﴾: أخْرَجَ اللهُ الأمواتَ مِنَ القُبُورِ لِلْحِسابِ؟"
  100,10,"﴿وَحُصِّلَ﴾: واسْتُخْرِجَ.﴿مَا فِي ٱلصُّدُورِ﴾: ما اسْتَتَرَ في الصُّدُورِ مِن خَيْرٍ أو شَرٍّ."
  100,11,"﴿لَّخَبِيرُۢ﴾: لَمُطَّلِعٌ على باطِنِ أمْرِهِم فلا يَخْفى عَلَيهِ شيءٌ مِن ذَلِكَ."
