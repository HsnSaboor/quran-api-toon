tafsir[49]{c,v,t}:
  14,1,"﴿بِإِذۡنِ رَبِّهِمۡ﴾: بأَمْرِه وتيسيرِه وتوفيقِه.﴿صِرَ ٰ⁠طِ﴾: طريقِ.﴿ٱلۡعَزِيزِ﴾: الغالبِ الذي لا يَقْدِرُ عليه أحدٌ.﴿ٱلۡحَمِيدِ﴾: المَحْمودِ في كلِّ حالٍ، المُثْنى عليه من نفسِه ومن عبادِه."
  14,2,"﴿وَوَيۡلࣱ﴾: هَلاكٌ ووَعيدٌ."
  14,3,"﴿يَسۡتَحِبُّونَ﴾: يختارون.﴿وَيَبۡغُونَهَا عِوَجًا﴾: ويُريدُون أن تكونَ سبيلُ اللهِ مائلةً وفْقَ أهوائِهم."
  14,4,"﴿وَيَهۡدِي﴾: يُوَفِّقُ مَن يشاءُ إلى الهدى."
  14,5,"﴿بِـَٔايَـٰتِنَآ﴾: بالمعجِزاتِ الدالَّةِ على صِدْقِه.﴿بِأَيَّىٰمِ ٱللَّهِ﴾: بنِعَمِه وبَلاياه التي وقعَتْ على الأممِ السابقةِ.﴿لَـَٔايَـٰتࣲ﴾: دلالاتٍ وعِبَرًا.﴿صَبَّارࣲ﴾: كثيرِ الصبرِ على الطاعاتِ والبلاءِ.﴿شَكُورࣲ﴾: كثيرِ الشُّكرِ على نِعَمِ اللهِ، قائمٍ بحقوقِه."
  14,6,"﴿يَسُومُونَكُمۡ﴾: يُذِيقُونكم.﴿وَيَسۡتَحۡيُونَ نِسَآءَكُمۡ﴾: يَسْتَبْقُونَهنَّ أحياءً؛ للخِدْمةِ والامتِهان.﴿بَلَآءࣱ﴾: اختبارٌ لكم بالنِّعَمِ والفِتَن."
  14,7,"﴿تَأَذَّنَ رَبُّكُمۡ﴾: أعْلَمَ إعلامًا مُؤَكَّدًا."
  14,9,"﴿بِٱلۡبَيِّنَـٰتِ﴾: بالبراهينِ الواضحاتِ على صِدْقِهم.﴿فَرَدُّوٓاْ أَيۡدِيَهُمۡ فِيٓ أَفۡوَ ٰ⁠هِهِمۡ﴾: عَضَّتِ الأممُ على أيديها؛ غيظًا واستكبارًا عن الإيمانِ.﴿مُرِيبࣲ﴾: مُوقعٍ في القَلَقِ وعَدَمِ الاطمئنانِ."
  14,10,"﴿فَاطِرِ ٱلسَّمَـٰوَ ٰ⁠تِ وَٱلۡأَرۡضِ﴾: خالِقِهما ومُبْدِعِهما.﴿إِلَىٰٓ أَجَلࣲ مُّسَمࣰّى﴾: مُدَّةِ بقائِكم في الدنيا، فلا يُعَذِّبكُم فيها.﴿بِسُلۡطَـٰنࣲ مُّبِينࣲ﴾: حُجَّةٍ ظاهرةٍ تَشْهَدُ على صِدْقِكم."
  14,11,"﴿يَمُنُّ عَلَىٰ مَن يَشَآءُ﴾: يَتَفَضَّلُ عليه فيَصْطَفِيه للرِّسالةِ.﴿بِإِذۡنِ ٱللَّهِ﴾: بأمْرِه ومشيئتِه.﴿وَعَلَى ٱللَّهِ فَلۡيَتَوَكَّلِ﴾: فلْيَعْتَمِدْ عليه، ولْيُفَوِّضْ أمرَه إليه."
  14,12,"﴿هَدَىٰنَا سُبُلَنَا﴾: أرْشَدَنا إلى طريقِ النَّجاة، ووَفَّقنا إلى اتِّباعِ شَرْعِه."
  14,13,"﴿مِلَّتِنَا﴾: دينِنا."
  14,14,"﴿ٱلۡأَرۡضَ مِنۢ بَعۡدِهِمۡ﴾: أي: أرضَ الكافرين وديارَهم مِن بَعْدِ إهلاكِهم.﴿مَقَامِي﴾: مَوْقِفَه بين يَدَي اللهِ للحسابِ، أو: قيامي عليه ومراقبتي له."
  14,15,"﴿وَٱسۡتَفۡتَحُواْ﴾: سألَ الرُّسلُ ربَّهم النصرَ على أعدائِهم، أو طَلَبُوا منه الحُكْمَ بينهَم.﴿وَخَابَ﴾: خَسِرَ وهَلَكَ.﴿جَبَّارٍ﴾: مُتَعاظِمٍ في نفسِه، مُتَكَبِّرٍ على غيرِه وعن الحقِّ.﴿عَنِيدࣲ﴾: معاندٍ للحقِّ، مائلٍ عنه لا يَقْبَلُه."
  14,16,"﴿مِّن وَرَآئِهِۦ جَهَنَّمُ﴾: أمامَ هذا الكافرِ ما أعَدَّ اللهُ من العذابِ في النار.﴿صَدِيدࣲ﴾: ما يَسِيلُ من أجسادِ أهلِ النّارِ."
  14,17,"﴿يَتَجَرَّعُهُۥ﴾: يَتَكلَّفُ ابتلاعَه مرَّة بعدَ مرَّةٍ؛ لحرارتهِ مع غَلَبَةِ العَطَشِ عليه.﴿وَلَا يَكَادُ يُسِيغُهُۥ﴾: لا يَسْتطيعُ ابتلاعَه بسهولةٍ، بل يَشْرَبُه بعد عَناءٍ، فيُقَطِّعُ أمعاءَه.﴿وَمِن وَرَآئِهِۦ﴾: وله بعدَ هذا العذابِ.﴿غَلِيظࣱ﴾: شديدٌ مؤلمٌ."
  14,18,"﴿مَّثَلُ ٱلَّذِينَ كَفَرُواْ﴾: صفةُ أعمالِ الكفارِ في الدنيا وبُطْلانِها عندَ اللهِ بسببِ كُفْرِهم.﴿عَاصِفࣲ﴾: شديدِ الريحِ.﴿لَّا يَقۡدِرُونَ مِمَّا كَسَبُواْ عَلَىٰ شَيۡءࣲ﴾: لا يَجِدُون من أعمال البِرِّ ما يَنْفعُهم في الآخرةِ."
  14,19,"﴿بِٱلۡحَقِّ﴾: على الوجهِ الصحيحِ الدّالِّ على حكمتِه، وكمالِ قدرتِه."
  14,20,"﴿بِعَزِيزࣲ﴾: بممتنعٍ أو متعسِّرٍ."
  14,21,"﴿وَبَرَزُواْ﴾: خَرَجَ الخلائقُ من قبورِهم؛ للحسابِ.﴿ٱلضُّعَفَـٰٓؤُاْ﴾: ضعفاءُ الرأيِ، وهم الأتباعُ.﴿لِلَّذِينَ ٱسۡتَكۡبَرُوٓاْ﴾: وهم القادةُ والرؤساءُ.﴿تَبَعࣰا﴾: أتباعًا.﴿لَوۡ هَدَىٰنَا ٱللَّهُ﴾: لو وفَّقَنا إلى الإيمانِ.﴿لَهَدَيۡنَـٰكُمۡ﴾: لَأَرشَدْناكم إليه.﴿سَوَآءٌ عَلَيۡنَآ أَجَزِعۡنَآ﴾: يَسْتَوي ضَعْفُنا عن تَحمُّلِ ما نَزَلَ بنا جميعًا من العذابِ.﴿مَّحِيصࣲ﴾: مَهْرَبٍ ومَنجى."
  14,22,"﴿قُضِيَ﴾: أُحكِمَ، وفُرِغَ منه، وهو الحِسابُ، ودخولُ السُّعداءِ الجنةَ، والأشقياءِ النارَ.﴿وَعۡدَ ٱلۡحَقِّ﴾: بالبعثِ والجزاءِ.﴿وَوَعَدتُّكُمۡ﴾: وعْدًا باطلًا بعَدَمَ البعثِ والجَزاءِ.﴿سُلۡطَـٰنٍ﴾: تَسَلُّطٍ وإجبارٍ، أو حُجَّةٍ.﴿بِمُصۡرِخِكُمۡ﴾: بمُغِيثِكم مما أنتم فيه من العذابِ.﴿بِمُصۡرِخِيَّ﴾: بمُغِيثِيَّ مما أنا فيه منه.﴿بِمَآ أَشۡرَكۡتُمُونِ﴾: بإشراكِكم إياي مع الله في العبادةِ.﴿مِن قَبۡلُ﴾: في الدنيا."
  14,23,"﴿مِن تَحۡتِهَا﴾: من تحتِ أشجارِ الجِنانِ وقُصورِها.﴿بِإِذۡنِ رَبِّهِمۡ﴾: بأمرِه وتوفيقِه وفَضْلِه.﴿تَحِيَّتُهُمۡ فِيهَا﴾: من اللهِ والملائكةِ، ويُحيِّي بعضُهم بعضًا."
  14,24,"﴿كَلِمَةࣰ طَيِّبَةࣰ﴾: كلمةَ التوحيدِ: لا إلهَ إلا اللهُ.﴿كَشَجَرَةࣲ طَيِّبَةٍ﴾: كشَجَرَةٍ طيبةِ المنظرِ والثَّمَرِ، وهي النَّخْلَةُ.﴿ثَابِتࣱ﴾: متمكِّنٌ بعروقِه في الأرضِ.﴿وَفَرۡعُهَا فِي ٱلسَّمَآءِ﴾: وأعلاها مرتفِعٌ جهةَ العلوِّ."
  14,25,"﴿تُؤۡتِيٓ أُكُلَهَا﴾: تُعطي ثمارَها.﴿كُلَّ حِينِۭ بِإِذۡنِ رَبِّهَا﴾: كلَّ وقتٍ وقَّته اللهُ لإثْمارِها."
  14,26,"﴿كَلِمَةٍ خَبِيثَةࣲ﴾: هي كلمةُ الكفرِ.﴿كَشَجَرَةٍ خَبِيثَةٍ﴾: كشجرةٍ رديئةٍ فاسدةٍ في الرائحةِ والطَّعْمِ والمأكلِ، وهي شجرةُ الحَنْظَلِ.﴿ٱجۡتُثَّتۡ﴾: اقتُلِعَتْ من أصلِها.﴿قَرَارࣲ﴾: استقرارٍ وثباتٍ."
  14,27,"﴿ٱلثَّابِتِ﴾: الراسخِ الواضحِ، وهو كلمةُ الشهادتين.﴿وَفِي ٱلۡـَٔاخِرَةِ﴾: في القبرِ عندَ سؤالِ المَلَكَين."
  14,28,"﴿بَدَّلُواْ نِعۡمَتَ ٱللَّهِ كُفۡرࣰا﴾: اختارُوا الكفرَ بدلًا عن شُكْرِ نعمتِه.﴿وَأَحَلُّواْ﴾: أنْزَلُوا.﴿دَارَ ٱلۡبَوَارِ﴾: دارَ الهَلاك، وهي جهنمُ."
  14,29,"﴿يَصۡلَوۡنَهَا﴾: يَدْخُلُونها ويُقاسُون حَرَّها.﴿وَبِئۡسَ ٱلۡقَرَارُ﴾: ساء المستقَرُّ مُسْتَقَرُّهم."
  14,30,"﴿أَندَادࣰا﴾: شركاءَ ونُظَراءَ مع اللهِ في عبادتِه.﴿تَمَتَّعُواْ﴾: استمتِعُوا بالعيشِ في الحياةِ الدنيا."
  14,31,"﴿لَّا بَيۡعࣱ فِيهِ﴾: لا فِداءٌ فيه، بأن يبيعَ المرءُ ما يَفْدِي به نفسَه.﴿وَلَا خِلَـٰلٌ﴾: ولا صَداقَةٌ ولا مُوادَّةٌ تنفَعُ."
  14,32,"﴿وَسَخَّرَ لَكُمُ﴾: ذَلَّلَ لمنافِعِكم.﴿ٱلۡفُلۡكَ﴾: السُّفُنَ."
  14,33,"﴿دَآئِبَيۡنِ﴾: دائمَيْن في حركتِهما، ومنافِعِهما لكم."
  14,34,"﴿نِعۡمَتَ ٱللَّهِ﴾: نِعَمَه عليكم.﴿لَا تُحۡصُوهَآ﴾: لا تُطِيقوا حَصْرَها ولا القيامَ بشُكْرها؛ لكثرتِها وتنوُّعِها.﴿كَفَّارࣱ﴾: كثيرُ الجُحودِ لنِعَمِ رَبِّه."
  14,35,"﴿هَـٰذَا ٱلۡبَلَدَ﴾: أي: مكةَ.﴿وَٱجۡنُبۡنِي﴾: أبْعِدْني."
  14,36,"﴿فَمَن تَبِعَنِي﴾: اقتدى بي في التوحيدِ.﴿فَإِنَّهُۥ مِنِّي﴾: فهو على ديني وسُنَّتي."
  14,37,"﴿ٱلۡمُحَرَّمِ﴾: الذي يَحْرُمُ عندَه ما لا يَحْرُمُ في غيرِه.﴿تَهۡوِيٓ إِلَيۡهِمۡ﴾: تَحِنُّ وتُسْرِعُ إليهم شوقًا وحُبًّا."
  14,39,"﴿وَهَبَ لِي﴾: أعطاني ورزقني."
  14,40,"﴿مُقِيمَ ٱلصَّلَوٰةِ﴾: مُحافِظًا عليها، مُداومًا على أدائِها على أتمِّ أحوالِها.﴿وَتَقَبَّلۡ دُعَآءِ﴾: تقبَّلْ عبادتي، واستجِبْ دعائي."
  14,41,"﴿وَلِوَ ٰ⁠لِدَيَّ﴾: دعا لوالدِه بالمغفرةِ قبلَ أنْ يَتبيَّنَ له عداوتُه للهِ."
  14,42,"﴿تَشۡخَصُ فِيهِ ٱلۡأَبۡصَـٰرُ﴾: تَرْتَفِعُ فيه عيونُ أهلِ الموقفِ، فتبقى مفتوحةً لا تتحَّركُ؛ مِن هَوْلِ ما يَرَوْنه."
  14,43,"﴿مُهۡطِعِينَ﴾: مُسْرِعين إلى إجابةِ الداعي للحسابِ.﴿مُقۡنِعِي رُءُوسِهِمۡ﴾: رافِعيها من شدَّةِ الخوفِ.﴿لَا يَرۡتَدُّ إِلَيۡهِمۡ طَرۡفُهُمۡ﴾: لا تَرْجِعُ إليهم أجْفانُهم، بل تبقى عيونُهم مفتوحةً على حالِها.﴿وَأَفۡـِٔدَتُهُمۡ هَوَآءࣱ﴾: وقلوبُهم خاليةٌ لا تَعي شيئًا؛ من هَوْلِ ما تَرى، وشدَّةِ الدَّهْشةِ."
  14,44,"﴿وَأَنذِرِ﴾: خَوِّف أيُّها الرسولُ.﴿يَأۡتِيهِمُ ٱلۡعَذَابُ﴾: أي: عذابُ اللهِ يومَ القيامةِ.﴿أَجَلࣲ قَرِيبࣲ﴾: وقتٍ غيرِ بعيدٍ.﴿مَا لَكُم مِّن زَوَالࣲ﴾: لا زوالَ لكم عن الحياةِ الدُّنيا إلى الآخرةِ."
  14,45,"﴿وَتَبَيَّنَ لَكُمۡ كَيۡفَ فَعَلۡنَا بِهِمۡ﴾: وعَلِمْتُم بما تشاهدُونه في منازلِهم، وبما أُخْبِرْتُم، ما أنزَلْناه بهم من أنواعِ العقوباتِ."
  14,46,"﴿وَعِندَ ٱللَّهِ مَكۡرُهُمۡ﴾: عِلْمُه وجَزاؤُه.﴿وَإِن كَانَ مَكۡرُهُمۡ لِتَزُولَ مِنۡهُ ٱلۡجِبَالُ﴾: وما كان تدبيرُهم -وإن عَظُمَ- مُعَدًّا لإزالةِ الجبالِ؛ لضَعْفِه."
  14,47,"﴿وَعۡدِهِۦ رُسُلَهُۥٓ﴾: ما وعَدَهم به من النصرِ والتمكينِ، وإهلاكِ أعدائِهم.﴿عَزِيزࣱ﴾: غالِبٌ لا يمتنعُ عليه شيءٌ."
  14,48,"﴿وَبَرَزُواْ﴾: خَرَجَ الخَلْقُ من قُبورِهم؛ للحسابِ."
  14,49,"﴿مُّقَرَّنِينَ﴾: مُقَيَّدين، أو مَقْرونًا بعضُهم مع بعضٍ.﴿ٱلۡأَصۡفَادِ﴾: جَمْعُ صَفَدٍ، وهو ما يُوثَقُ به من القُيودِ."
  14,50,"﴿سَرَابِيلُهُم﴾: ثيابُهم، أو قُمْصانُهم.﴿قَطِرَانࣲ﴾: دُهْنٍ من عُصارةِ بعضِ الأشجارِ، أسودَ كالزِّفْتِ، وهو نَتِنٌ، حارٌّ، شديدُ الاشتعالِ.﴿وَتَغۡشَىٰ﴾: تَعْلُو وتُحيطُ."
  14,52,"﴿هَـٰذَا﴾: أي: القرآنُ.﴿أُوْلُواْ ٱلۡأَلۡبَـٰبِ﴾: أصحابُ العقولِ السليمةِ."
