tafsir[26]{c,v,t}:
  57,1,"﴿سَبَّحَ لِلَّهِ﴾: نَزَّهَهُ عِنِ السُّوءِ ومَجَّدَهُ.﴿ٱلۡعَزِيزُ﴾: الَّذِي لا يُغْلَبُ.﴿ٱلۡحَكِيمُ﴾: الَّذِي يَضَعُ الأَفْعالَ حِيثُ يَلِيقُ بِها."
  57,3,"﴿ٱلۡأَوَّلُ﴾: الَّذِي ليسَ قَبْلَهُ شَيءٌ.﴿ٱلۡـَٔاخِرُ﴾: الَّذِي لَيسَ بَعْدَه شَيءٌ.﴿ٱلظَّـٰهِرُ﴾: الَّذِي لَيسَ فَوْقَه شَيءٌ.﴿ٱلۡبَاطِنُ﴾: الَّذِي لَيسَ دُونَهُ شَيءٌ."
  57,4,"﴿ٱسۡتَوَىٰ﴾: عَلا وارْتَفَعَ.﴿ٱلۡعَرۡشِ﴾: سَرير المُلْكِ الَّذِي تَحْمِلُه الملائِكَةُ، واسْتَوىَ عَليهِ الرَّحمنُ، وهو أعْظَمُ المخلُوقاتِ، وهو سَقْفُ جَنَّةِ الفِرْدَوسِ.﴿يَلِجُ فِي ٱلۡأَرۡضِ﴾: يَدْخُلُ مِن حَبٍّ ومَطَرٍ وغَيرِ ذَلِكَ.﴿يَعۡرُجُ فِيهَا﴾: يَصْعَدُ مِنَ الملائِكةِ والأرْواحِ والأَدْعِيَةِ والأَعْمالِ.﴿مَعَكُمۡ﴾: بِعِلْمِهِ."
  57,6,"﴿يُولِجُ ٱلَّيۡلَ فِي ٱلنَّهَارِ﴾: يُدْخِلُ ما نَقَصَ مِن ساعاتِ الليل في النَّهارِ فَيَزِيدُ النَّهارَ.﴿وَيُولِجُ ٱلنَّهَارَ فِي ٱلَّيۡلِ﴾: ويُدْخِلُ ما نَقَصَ من ساعاتِ النَّهارِ في الليلِ فَيَزيدُ الليلَ.﴿بِذَاتِ ٱلصُّدُورِ﴾: بما فِي صُدُورِ خَلْقِهِ."
  57,7,"﴿جَعَلَكُم مُّسۡتَخۡلَفِينَ﴾: جَعَلَها في أيْدِيكُم، واسْتَخْلَفَكُم عَلَيها."
  57,8,"﴿مِيثَـٰقَكُمۡ﴾: عَهْدَكُم المؤَكَّدَ."
  57,9,"﴿ٱلظُّلُمَـٰتِ﴾: ظُلُماتِ الكُفْرِ.﴿ٱلنُّورِ﴾: نُور الإيمانِ.﴿لَرَءُوفࣱ﴾: لَرَحِيمٌ بِهِم أشَدَّ رَحْمةٍ."
  57,10,"﴿وَمَا لَكُمۡ أَلَّا تُنفِقُواْ﴾: أيُّ شَيءٍ يَمْنَعُكُم مِنَ الإنْفاقِ؟﴿مِيرَ ٰ⁠ثُ ٱلسَّمَـٰوَ ٰ⁠تِ وَٱلۡأَرۡضِ﴾: مُلْكُ السَّمَواتِ والأرْضِ، وسَيَنْتَقِلُ إلى مالِكِه الحقِيقِي.﴿ٱلۡفَتۡحِ﴾: فَتْحِ مَكَّةَ.﴿ٱلۡحُسۡنَىٰ﴾: الجنَّةَ."
  57,11,"﴿يُقۡرِضُ ٱللَّهَ﴾: يُنْفِقُ مُخْلِصًا عَمَلَهُ للهِ."
  57,12,"﴿يَسۡعَىٰ نُورُهُم﴾: يُضِيءُ لَهُم نُورُ عَمَلِهِم عَلى الصِّراطِ عَلى قَدْرِ أعْمالِهِم."
  57,13,"﴿ٱنظُرُونَا﴾: انْتَظِرُونا، وتَريَّثُوا في سَيرِكُم حتى نَلْحَقَ بِكُم.﴿نَقۡتَبِسۡ﴾: نَأْخُذْ.﴿قِيلَ﴾: القائِلُ: المؤمِنُونَ.﴿ٱرۡجِعُواْ وَرَآءَكُمۡ﴾: ارْجِعُوا إلى المكانِ الَّذِي قَبَسْتُم فِيهِ النُّورَ.﴿فَٱلۡتَمِسُواْ﴾: فاطْلُبُوا.﴿فَضُرِبَ بَيۡنَهُم﴾: فَوُضِعَ بَيْنَ المؤمِنينَ والمنافِقِينَ.﴿بِسُورࣲ﴾: بِجِدارٍ مُحِيطٍ مُرْتَفِعٍ.﴿بَاطِنُهُۥ﴾: داخِلُهُ.﴿وَظَـٰهِرُهُۥ﴾: خارِجُهُ.﴿مِن قِبَلِهِ﴾: في جِهَتِهِ المقابِلَةِ الَّتِي فِيها المنافِقُونَ."
  57,14,"﴿فَتَنتُمۡ أَنفُسَكُمۡ﴾: آثمْتُمُوها، وأَهْلَكْتُمُوها بالنِّفاقِ.﴿وَتَرَبَّصۡتُمۡ﴾: وانْتَظَرْتُم بالنَّبِي الموتَ وبِالمؤمِنِينَ الدَّوائِرَ.﴿وَٱرۡتَبۡتُمۡ﴾: شَكَكْتُم في التَّوحِيدِ ونُبُوَّةِ محمَّدٍ ﷺ.﴿وَغَرَّتۡكُمُ﴾: خَدَعَتْكُم.﴿ٱلۡأَمَانِيُّ﴾: ما تُمَنُّونَ بِهِ أنْفُسَكُم مِنَ الأباطِيلِ.﴿أَمۡرُ ٱللَّهِ﴾: الموتُ.﴿ٱلۡغَرُورُ﴾: الشَّيطانُ."
  57,15,"﴿فِدۡيَةࣱ﴾: عِوَضٌ تَتَخَلّصُونَ بِهِ مِنَ العذابِ.﴿مَأۡوَىٰكُمُ﴾: مَصِيرُكُم الَّذِي تَخْلُدُونَ فِيهِ.﴿وَبِئۡسَ ٱلۡمَصِيرُ﴾: وساءَ مَرْجِعُ مَن صارَ إلى النّارِ."
  57,16,"﴿أَلَمۡ يَأۡنِ﴾: ألَمْ يَأْتِ الوَقْتُ؟﴿تَخۡشَعَ﴾: تَرِقَّ وتَلِينَ.﴿ٱلۡأَمَدُ﴾: الزَّمانُ أو الغايَةُ، وبُعْدُ عَهْدِهِم بالأنبياءِ والصّالِحِينَ."
  57,17,"﴿ٱلۡأَرۡضَ﴾: الميْتَةَ الَّتِي لا تُنْبِتُ شَيئًا.﴿بَعۡدَ مَوۡتِهَا﴾: بَعْدَ يُبْسِها لاحْتِباسِ الماءِ عَنْها.﴿ٱلۡـَٔايَـٰتِ﴾: الدَّلائِلَ والحُجَجَ.﴿لَعَلَّكُمۡ تَعۡقِلُونَ﴾: رَجاءَ أن تَعْقِلُوا."
  57,18,"﴿ٱلۡمُصَّدِّقِينَ﴾: المتَصَدِّقِينَ مِن أمْوالِهِم.﴿وَأَقۡرَضُواْ ٱللَّهَ قَرۡضًا﴾: أنْفَقُوا في سَبِيلِ اللهِ نَفَقاتٍ طَيِّبةً بِها نُفُوسُهُم."
  57,19,"﴿ٱلصِّدِّيقُونَ﴾: الَّذِينَ كَمُلَ تَصْدِيقُهُم بِما جاءَتْ بِهِ الرُّسُلُ، اعتِقادًا وقَوْلًا وعَمَلًا.﴿وَٱلشُّهَدَآءُ﴾: هُمُ القَتْلى في سَبِيلِ اللهِ، والَّذِينَ يَشْهَدُونَ عَلى الأُمَمِ السّابِقَةِ."
  57,20,"﴿كَمَثَلِ غَيۡثٍ﴾: كَحالِ القَطْرِ.﴿ٱلۡكُفَّارَ﴾: الزُّرّاعَ، لِأنّ الزّارِعَ يَسْتُرُ ما يَزْرَعُهُ بِتُرابِ الأرْضِ.﴿يَهِيجُ﴾: يَيْبَسُ.﴿مُصۡفَرࣰّا﴾: تَحَوَّلَ لونُه إلى الصُّفْرةِ.﴿حُطَـٰمࣰا﴾: مُتَهَشِّمًا مُتَكَسِّرًا.﴿مَتَـٰعُ ٱلۡغُرُورِ﴾: تَمتُّعٌ يَنْخَدِعُ بِهِ أهْلُهُ."
  57,21,"﴿مَغۡفِرَةࣲ﴾: أسبابِ المغفِرَةِ مِنَ التَّوبَةِ والابْتِعادِ عَنِ المعاصِي."
  57,22,"﴿كِتَـٰبࣲ﴾: اللوحِ المحفُوظِ.﴿نَّبۡرَأَهَآ﴾: نَخْلُقَ الخَلِيقَةَ."
  57,23,"﴿تَأۡسَوۡاْ﴾: تَحْزَنُوا.﴿تَفۡرَحُواْ﴾: فَرَحَ بَطَرٍ وأَشَرٍ.﴿مُخۡتَالࣲ﴾: مُتَكَبِّرٍ."
  57,24,"﴿يَبۡخَلُونَ﴾: بأمْوالِهمِ.﴿يَتَوَلَّ﴾: يُعْرِضْ عَن طاعَةِ اللهِ.﴿ٱلۡغَنِيُّ﴾: عَنْ خَلْقِهِ.﴿ٱلۡحَمِيدُ﴾: المحمُودُ على أوصافِهِ الكامِلةِ."
  57,25,"﴿بِٱلۡبَيِّنَـٰتِ﴾: بالحُجَجِ الواضِحاتِ.﴿لِيَقُومَ ٱلنَّاسُ بِٱلۡقِسۡطِ﴾: لِيَتَعامَلَ النّاسُ بَيْنَهُم بالعَدلِ.﴿بَأۡسࣱ﴾: قُوَّةٌ.﴿عَزِيزࣱ﴾: لا يُغْلَبُ."
  57,27,"﴿قَفَّيۡنَا﴾: أتْبَعْنا.﴿رَأۡفَةࣰ﴾: لِينًا.﴿وَرَهۡبَانِيَّةً﴾: وابْتَدَعُوا رَهْبانِيَّةً بالغُلُوِّ في العِبادةِ.﴿مَا كَتَبۡنَـٰهَا﴾: ما فَرَضْناها.﴿إِلَّا ٱبۡتِغَآءَ رِضۡوَ ٰ⁠نِ ٱللَّهِ﴾: التَزَمُوا بالرَّهْبانِيَّةِ المُبْتدَعَةِ يَطْلُبُونَ بِذَلِكَ رِضا اللهِ.﴿فَمَا رَعَوۡهَا حَقَّ رِعَايَتِهَا﴾: فما قامُوا بِها حَقَّ القيامِ."
  57,28,"﴿كِفۡلَيۡنِ﴾: ضعْفَينِ.﴿تَمۡشُونَ بِهِۦ﴾: تَهْتَدُونَ بِهِ."
  57,29,"﴿لِّئَلَّا يَعۡلَمَ﴾: لِيعلَمَ.﴿ٱلۡفَضۡلِ ٱلۡعَظِيمِ﴾: الإحْسانِ والعَطاءِ الكَثِيرِ الواسِعِ."
