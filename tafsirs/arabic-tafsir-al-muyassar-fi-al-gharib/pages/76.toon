tafsir[28]{c,v,t}:
  76,1,"﴿هَلۡ أَتَىٰ﴾: قَدْ مَضى.﴿حِينࣱ مِّنَ ٱلدَّهۡرِ﴾: وقْتٌ طويلٌ مِنَ الزَّمانِ قَبلَ أن تُنفَخَ فيه الُّروحُ.﴿لَمۡ يَكُن شَيۡـࣰٔا مَّذۡكُورًا﴾: لمَ يكُنْ شَيئًا يُذكرُ."
  76,2,"﴿نُّطۡفَةٍ أَمۡشَاجࣲ﴾: مِن نُّطْفَةٍ مُخْتَلِطَةٍ مِن مّاءِ الرَّجُلِ وماءِ المرأةِ.﴿نَّبۡتَلِيهِ﴾: أي بتكاليفِ الشَّريعةِ."
  76,3,"﴿هَدَيۡنَـٰهُ﴾: بيَّنّا له.﴿ٱلسَّبِيلَ﴾: طَرِيقَ الهُدى والضَّلالِ.﴿كَفُورًا﴾: جاحِدًا."
  76,4,"﴿أَعۡتَدۡنَا﴾: أعْدَدْنا.﴿سَلَـٰسِلَاْ﴾: حِلَقًا غَلِيظَةً مِن حَدِيدٍ تُشَدُّ بِها أرْجُلُهُم.﴿وَأَغۡلَـٰلࣰا﴾: قُيُودًا تُغَلُّ بِها أيْدِيهِم.﴿وَسَعِيرًا﴾: ونارًا يُحرَقُونَ بِها."
  76,5,"﴿ٱلۡأَبۡرَارَ﴾: أهْلَ الطّاعةِ والإخلاصِ الَّذِينَ يُؤَدّونَ حقَّ اللهِ.﴿كَأۡسࣲ﴾: إناءٍ للخَمْرِ.﴿مِزَاجُهَا﴾: ما خُلِطَ بالخمْرِ لِتَخْفِيفِ حِدَّتِهِ.﴿كَافُورًا﴾: أحْسَنَ أنْواعِ الطِّيبِ."
  76,6,"﴿يَشۡرَبُ بِهَا﴾: يَشْرَبُ مِنها.﴿عِبَادُ ٱللَّهِ﴾: هم الأبرارُ.﴿يُفَجِّرُونَهَا﴾: يَسْتَقُونَ مِنها حيثُ شاؤُوا.﴿تَفۡجِيرࣰا﴾: إجراءً سَهْلا."
  76,7,"﴿يُوفُونَ﴾: يُؤَدُّونَ وافيًا دُونَ نَقْصٍ ولا تَقْصِيرٍ.﴿بِٱلنَّذۡرِ﴾: ما أوْجَبُوهُ على أنْفُسِهِم مِن فِعْلِ الخيرِ المُتَقرَّبِ بِهِ إلى اللهِ.﴿وَيَخَافُونَ يَوۡمࣰا﴾: ويخافُونَ عِقابَ اللهِ يومَ القِيامةِ.﴿مُسۡتَطِيرࣰا﴾: مُنْتَشِرًا."
  76,8,"﴿عَلَىٰ حُبِّهِۦ﴾: مَعَ حُبِّهِم لَهُ وحاجَتِهِم إلَيهِ.﴿مِسۡكِينࣰا﴾: مُحْتاجًا.﴿وَيَتِيمࣰا﴾: وطِفْلًا ماتَ أبُوهُ ولا مالَ لَهُ.﴿وَأَسِيرًا﴾: الَّذِي تَمَّ أسْرُهُ في الحرْبِ."
  76,9,"﴿لِوَجۡهِ ٱللَّهِ﴾: اْبتِغاءَ مَرْضاةِ اللهِ.﴿جَزَآءࣰ﴾: عِوَضًا."
  76,10,"﴿عَبُوسࣰا﴾: تَكْلَحُ فِيهِ الوُجُوهُ.﴿قَمۡطَرِيرࣰا﴾: تَتَقَطَّبُ الجِباهُ مِن فَظاعَةِ أمْرِهِ."
  76,11,"﴿وَلَقَّىٰهُمۡ﴾: جَعَلَهُم يَلْقَونَ.﴿نَضۡرَةࣰ﴾: نُورًا في وُجُوهِهِم."
  76,13,"﴿مُّتَّكِـِٔينَ﴾: جالِسِينَ على وجْهِ التَّمَكُّنِ والرّاحَةِ.﴿ٱلۡأَرَآئِكِ﴾: الأَسِرَّةِ المزيَّنَةِ بفاخرِ الثِّيابِ والسُّتُورِ.﴿شَمۡسࣰا﴾: حرَّ شَمْسٍ؛ لِعَدَمِ وُجُودِها.﴿زَمۡهَرِيرࣰا﴾: شِدّةَ بَرْدٍ."
  76,14,"﴿وَدَانِيَةً عَلَيۡهِمۡ﴾: وقَريبةً مِنهُم.﴿ظِلَـٰلُهَا﴾: أشْجارُ الجنَّةِ مُظَلَّلَةٌ عَليهِم.﴿وَذُلِّلَتۡ﴾: وسُهِّلَ لَهُم.﴿قُطُوفُهَا﴾: أخْذُ ثِمارِها."
  76,15,"﴿وَيُطَافُ عَلَيۡهِم﴾: ويَدُورُ عَلَيهِم الَخَدمُ.﴿بِـَٔانِيَةࣲ مِّن فِضَّةࣲ﴾: بأواني الطَّعامِ وأَوْعِيَتِهِ الفِضِّيَّةِ.﴿قَوَارِيرَا۠﴾: مِنَ الزُّجاجِ."
  76,16,"﴿قَدَّرُوهَا تَقۡدِيرࣰا﴾: قدَّرها السُّقاةُ على مِقْدارِ ما يَشْتَهِي الشارِبُونَ لا تَزِيدُ ولا تَنْقُصُ."
  76,17,"﴿كَأۡسࣰا﴾: إناءً مَمْلُوءًا خمَرًا.﴿مِزَاجُهَا﴾: ما تُخْلَطُ بِهِ."
  76,18,"﴿سَلۡسَبِيلࣰا﴾: الماءُ السَّهْلُ المَساغِ."
  76,19,"﴿وِلۡدَ ٰ⁠نࣱ﴾: غِلْمانٌ دائِمُونَ.﴿لُؤۡلُؤࣰا﴾: دُرًّا مُضِيئًا.﴿مَّنثُورࣰا﴾: مُفَرَّقًا."
  76,20,"﴿رَأَيۡتَ ثَمَّ﴾: أبْصَرْتَ أيَّ مَكانٍ في الجنَّةِ."
  76,21,"﴿عَـٰلِيَهُمۡ﴾: يَعْلُوهُم ويُجَمِّلُ أبْدانَهُم.﴿ثِيَابُ سُندُسٍ خُضۡرࣱ﴾: ثِيابٌ بطائِنُها مِنَ الحريرِ الرَّقِيقِ الأخْضَرِ.﴿وَإِسۡتَبۡرَقࣱ﴾: وظاهِرُها مِنَ الحريرِ الغلِيظِ.﴿وَحُلُّوٓاْ﴾: وأُلْبِسُوا للزِّينَةِ.﴿أَسَاوِرَ﴾: جَمْعُ سِوارٍ، وهو ما يُلْبسُ في المِعْصَمِ مِنَ الحُليِّ.﴿طَهُورًا﴾: لا رِجْسَ فِيهِ ولا دَنَسَ."
  76,22,"﴿سَعۡيُكُم﴾: عَمَلُكُم في الدُّنيا.﴿مَّشۡكُورًا﴾: مَرْضِيًّا عِنْدَ اللهِ مَقْبُولًا."
  76,24,"﴿فَٱصۡبِرۡ لِحُكۡمِ رَبِّكَ﴾: فاصْبِرْ لحُكْمِ رَبِّكَ القَدَريِّ واقْبَلْهُ، ولِحُكْمِهِ الدِّينِيِّ فامْضِ عَلَيهِ.﴿ءَاثِمًا﴾: عاصِيًا.﴿أَوۡ كَفُورࣰا﴾: أو مُبالِغًا في الكُفْرِ والضَّلالِ."
  76,25,"﴿بُكۡرَةࣰ﴾: أوَّلَ النَّهارِ.﴿وَأَصِيلࣰا﴾: آخِرَ النَّهارِ."
  76,26,"﴿فَٱسۡجُدۡ لَهُۥ﴾: فاخْضَعْ لِربِّكَ.﴿وَسَبِّحۡهُ﴾: وصَلِّ لَهُ، وتهجَّدْ لَهُ."
  76,27,"﴿ٱلۡعَاجِلَةَ﴾: الدُّنيا.﴿ثَقِيلࣰا﴾: عَظِيمَ الشَّدائِدِ."
  76,28,"﴿وَشَدَدۡنَآ﴾: وأحكمنا.﴿أَسۡرَهُمۡ﴾: خَلْقَهُم.﴿بَدَّلۡنَآ أَمۡثَـٰلَهُمۡ﴾: أهْلَكْناهُم، وجِئْنا بِقَوْمٍ مُطِيعِينَ."
  76,29,"﴿تَذۡكِرَةࣱ﴾: عِظَةٌ للعالَمِينَ.﴿سَبِيلࣰا﴾: طَرِيقًا يُوصِلُهُ إلى مَغْفِرَةِ اللهِ ورِضْوانِهِ."
  76,31,"76:30"
