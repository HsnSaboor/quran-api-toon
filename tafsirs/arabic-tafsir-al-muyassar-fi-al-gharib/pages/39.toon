tafsir[64]{c,v,t}:
  39,2,"39:1"
  39,3,"﴿ٱلدِّينُ ٱلۡخَالِصُ﴾: الطّاعَةُ التّامَّةُ السّالِمَةُ مِنَ الشِّرْكِ.﴿زُلۡفَىٰٓ﴾: قُرْبى."
  39,4,"﴿لَّٱصۡطَفَىٰ﴾: لاخْتارَ.﴿ٱلۡقَهَّارُ﴾: الَّذي قَهَرَ خَلْقَه بِقُدْرَتِهِ، فَكُلُّ شَيءٍ لَهُ مُتَذَلِّلٌ خاضِعٌ."
  39,5,"﴿يُكَوِّرُ ٱلَّيۡلَ عَلَى ٱلنَّهَارِ﴾: يُدْخِلُ الليلَ على النَّهارِ.﴿وَيُكَوِّرُ ٱلنَّهَارَ عَلَى ٱلَّيۡلِ﴾: يُدْخِلُ النَّهارَ على الليلِ.﴿وَسَخَّرَ﴾: ذَلَّل.﴿لِأَجَلࣲ مُّسَمًّى﴾: إلى حِينِ قِيامِ السّاعةِ."
  39,6,"﴿نَّفۡسࣲ وَ ٰ⁠حِدَةࣲ﴾: آدَمَ عَلَيهِ السَّلامُ.﴿وَأَنزَلَ﴾: خَلَقَ.﴿مِّنَ ٱلۡأَنۡعَـٰمِ ثَمَـٰنِيَةَ أَزۡوَ ٰ⁠جࣲ﴾: ثمانيةَ أنْواعٍ ذَكَرًا وأُنْثى مِنَ الإبِلِ والبَقَرِ والضَّأنِ والَمعْزِ.﴿خَلۡقࣰا مِّنۢ بَعۡدِ خَلۡقࣲ﴾: طَوْرًا بَعْدَ طَورِ مِنَ الخَلْقِ.﴿ظُلُمَـٰتࣲ ثَلَـٰثࣲ﴾: ظُلُماتِ البَطْنِ والرَّحِمِ والَمشِيمَةِ.﴿فَأَنَّىٰ تُصۡرَفُونَ﴾: فَكَيفَ تَعْدِلُونَ عَنْ عِبادَةِ رَبِّكُم إلى عِبادَةِ غَيْرِه؟"
  39,7,"﴿وَلَا تَزِرُ وَازِرَةࣱ وِزۡرَ أُخۡرَىٰ﴾: ولا تُؤْخَذُ نَفْسٌ بإثْمِ غَيْرِها.﴿بِذَاتِ ٱلصُّدُورِ﴾: بأسْرارِ النُّفُوسِ وما تُخْفِيهِ."
  39,8,"﴿مُنِيبًا﴾: تائِبًا إليِهِ.﴿خَوَّلَهُۥ﴾: مَنَحَه.﴿أَندَادࣰا﴾: شُرَكاءَ.﴿تَمَتَّعۡ بِكُفۡرِكَ قَلِيلًا﴾: تَمَتَّعْ بالسَّلامَةِ مِنَ العَذابِ زَمَنًا قَلِيلًا."
  39,9,"﴿قَـٰنِتٌ﴾: عابدٌ لِرَبِّهِ، طائِعٌ لَهُ.﴿ءَانَآءَ﴾: ساعاتِ.﴿أُوْلُواْ ٱلۡأَلۡبَـٰبِ﴾: أصْحابُ العُقُولِ السَّلِيمَةِ."
  39,10,"﴿حَسَنَةࣱ﴾: في الدُّنيا بالعافِيةِ، وفي الآخِرةِ بالجنَّةِ.﴿بِغَيۡرِ حِسَابࣲ﴾: مِن غَيْرِ حَدٍّ ولا مِقْدارٍ."
  39,12,"﴿أَوَّلَ ٱلۡمُسۡلِمِينَ﴾: أوَّلَ مَن أسْلَمَ مِن أُمَّتِي."
  39,14,"39:13"
  39,15,"﴿فَٱعۡبُدُواْ مَا شِئۡتُم﴾: صِيغَةُ أمْرٍ على جِهَةِ التَّهْدِيدِ."
  39,16,"﴿ظُلَلࣱ﴾: جَمْعُ ظُلَّةٍ قِطَعُ عَذابٍ كالسَّحابِ العظِيمِ.﴿عِبَادَهُۥ﴾: كُلَّ عَبْدٍ مِنَ النّاسِ مِن مُّؤْمِنٍ وكافِرٍ."
  39,17,"﴿ٱلطَّـٰغُوتَ﴾: كُلَّ ما عُبِدَ مِن دُونِ اللهِ مِن شَيطانٍ وغَيرِهِ.﴿وَأَنَابُوٓاْ﴾: وتابُوا."
  39,18,"﴿أَحۡسَنَهُۥٓ﴾: أرْشَدَهُ، وأَحْسَنُ الكَلامِ كَلامُ اللهِ ثُمَّ كَلامُ رَسُولِهِ.﴿أُوْلُواْ ٱلۡأَلۡبَـٰبِ﴾: أصْحابُ العُقُولِ السَّليمَةِ."
  39,19,"﴿حَقَّ﴾: وجَبَ."
  39,20,"﴿غُرَفࣱ﴾: منازِلُ عالِيةٌ في الجنُّةِ."
  39,21,"﴿ٱلسَّمَآءِ﴾: السَّحابِ.﴿مَآءࣰ﴾: مَطَرًا.﴿فَسَلَكَهُۥ﴾: فأدْخَلَه.﴿يَنَـٰبِيعَ﴾: جَمْعُ يَنْبُوعٍ وهو العينُ الكَثِيرةُ النَّبعِ التي لا يَنضُبُ ماؤُها.﴿يَهِيجُ﴾: يَيْبَسُ بَعْدَ خُضْرتِهِ ونَضارَتِهِ.﴿حُطَـٰمًا﴾: مُتَكَسِّرًا مُتَفَتِّتًا.﴿لِأُوْلِي ٱلۡأَلۡبَـٰبِ﴾: لِأَصْحابِ العُقُول السَّلِيمَةِ."
  39,22,"﴿شَرَحَ ٱللَّهُ صَدۡرَهُۥ لِلۡإِسۡلَـٰمِ﴾: وسَّعَ اللهُ صدْرَهُ بالإيمانِ بِهِ والإسْلامِ.﴿فَوَيۡلࣱ﴾: فَهَلاكٌ.﴿لِّلۡقَـٰسِيَةِ قُلُوبُهُم مِّن ذِكۡرِ ٱللَّهِ﴾: الَّذينَ غَلُظَتْ قُلُوبُهُم وأَعْرَضَتْ عَن ذِكْرِ اللهِ."
  39,23,"﴿أَحۡسَنَ ٱلۡحَدِيثِ﴾: القرآنَ العَظِيمَ.﴿مُّتَشَـٰبِهࣰا﴾: يُشْبِهُ بَعْضُه بَعْضًا في الحُسْنِ والإحْكامِ وعَدَمِ الاخْتِلافِ.﴿مَّثَانِيَ﴾: تُثَنّى فيه وتُكَرَّرُ القِصَصُ والأَحْكامُ والحُجَجُ والبَيِّناتُ.﴿تَقۡشَعِرُّ﴾: تَتَقَبَّضُ وتَتَغَيَّرُ بِسَبَبِ الخوفِ.﴿تَلِينُ﴾: تَطْمئِنُّ وتَسْكُنُ."
  39,24,"﴿أَفَمَن يَتَّقِي بِوَجۡهِهِۦ سُوٓءَ ٱلۡعَذَابِ﴾: أفمن يُلْقى في النّارِ مكْتُوفًا فلا يَقْدِرُ أن يَتَّقِيَ النّارَ إلا بِوجْهِهِ كَمَن هُو مُنَعَّمٌ في الجنَّةِ؟"
  39,25,"﴿مِنۡ حَيۡثُ لَا يَشۡعُرُونَ﴾: مِنَ الموضِعِ الَّذي لا يعلَمُونَ بِمَجِيءِ العَذابِ مِنهُ."
  39,26,"﴿ٱلۡخِزۡيَ﴾: العَذابَ والهَوانَ."
  39,27,"﴿ضَرَبۡنَا﴾: ذَكَرْنا ووَصَفْنا.﴿مَثَلࣲ﴾: نَبَأٍ عَظِيمٍ يَدْعُو إلى الاعْتِبارِ ويَسْتَوجِبُ الإيمانَ."
  39,28,"﴿غَيۡرَ ذِي عِوَجࣲ﴾: لا لَبْسَ فِيهِ ولا اخْتِلافَ."
  39,29,"﴿رَّجُلࣰا فِيهِ شُرَكَآءُ﴾: عَبْدًا مَمْلُوكًا لِشُرَكاءَ.﴿مُتَشَـٰكِسُونَ﴾: متنازِعُونَ، سَيِّئةٌ أخْلاقُهُم.﴿سَلَمࣰا لِّرَجُلٍ﴾: خالِصًا لِرَجُلٍ واحِدٍ.﴿مَثَلًا﴾: حالًَا."
  39,31,"39:30"
  39,32,"﴿فَمَنۡ أَظۡلَمُ﴾: لا أحَدَ أظْلَمُ.﴿بِٱلصِّدۡقِ﴾: بالقرآنِ.﴿مَثۡوࣰى﴾: مأوىً ومَسْكَنٌ."
  39,33,"﴿بِٱلصِّدۡقِ﴾: لا إلَهَ إلّا اللهُ.﴿وَصَدَّقَ بِهِۦٓ﴾: مَن آمَنَ بالقُرْآنِ مِن نَّبِيِّ اللهِ وأَتْباعِهِ."
  39,35,"39:34"
  39,36,"﴿بِكَافٍ عَبۡدَهُۥ﴾: حامِي رَسُولِهِ مُحَمَّدٍ ﷺ.﴿مِن دُونِهِۦ﴾: بالَّذِينَ يَعْبُدُونَ مِن دُونِهِ وهُمُ الأَصْنامُ.﴿مِن دُونِهِۦ﴾: آلهَتِهِم الَّذين يَزْعُمُون أنها سَتُؤْذِيكَ."
  39,37,"﴿وَمَن يَهۡدِ ٱللَّهُ﴾: ومَن يُوفِّقْه اللهُ للإيمانِ بهِ والعملِ بِكِتابِهِ."
  39,38,"﴿مُمۡسِكَـٰتُ رَحۡمَتِهِۦ﴾: حابِساتُ رَحْمَتِهَ.﴿حَسۡبِيَ ٱللَّهُ﴾: كافيَّ اللهُ.﴿يَتَوَكَّلُ﴾: يَعْتَمِدُ ويُفَوِّضُ أمْرَهُ."
  39,39,"﴿ٱعۡمَلُواْ عَلَىٰ مَكَانَتِكُمۡ﴾: اعْمَلُوا على حالَتِكُم الَّتِي رَضَيتُمُوها لِأَنْفُسِكُم."
  39,40,"﴿يُخۡزِيهِ﴾: يُهينُهُ.﴿مُّقِيمٌ﴾: دائِمٌ."
  39,41,"﴿فَلِنَفۡسِهِۦ﴾: فَنَفْعُ هِدايتِهِ لِنَفْسِهِ.﴿يَضِلُّ عَلَيۡهَا﴾: يَعُودُ ضَرَرُ ضَلالِهِ عَلى نَفْسِهِ.﴿بِوَكِيلٍ﴾: بِحَفِيظٍ ومَسْؤُولٍ عَنْ أعْمالِهِم."
  39,43,"﴿شُفَعَآءَ﴾: جَمْعُ شَفِيعٍ وهو الَّذِي يَطْلُبُ مِن غَيْرِه قَضاءَ حاجةِ شَخْصٍ آخَرَ، والمرادُ، واللهُ أعلمُ، ما يعبُدُونَه مِن دُونِ اللهِ."
  39,44,"﴿قُل لِّلَّهِ ٱلشَّفَـٰعَةُ﴾: لِأَنَّ شَفاعةَ غَيرِهِ مَوقُوفَةٌ على إذْنِهِ سُبحانَه للشّافِعِ ورِضاهُ عَنِ المشْفُوعِ لَهُ، فلا تُطْلَبُ مِن هؤلاءِ الآلِهَةِ."
  39,45,"﴿ٱشۡمَأَزَّتۡ﴾: نَفَرَتْ.﴿مِن دُونِهِۦٓ﴾: وهُمُ الأَصْنامُ والأَوْثانُ والأَوْلِياءُ."
  39,46,"﴿فَاطِرَ﴾: هُوَ الخالِقُ والُمبْدِعُ عَلى غَيرِ مِثالٍ.﴿تَحۡكُمُ﴾: تَفْصِلُ وتَقْضِي."
  39,47,"﴿وَبَدَا﴾: وظَهَرَ.﴿يَحۡتَسِبُونَ﴾: يَظُنُونَ أنَّهُ واقِعٌ بِهِم."
  39,48,"﴿وَحَاقَ بِهِم﴾: ونَزَلَ وأَحاطَ بِهِم."
  39,49,"﴿خَوَّلۡنَـٰهُ﴾: أعْطَيناهُ تَفَضُّلًا مِنّا.﴿عَلَىٰ عِلۡمِۭ﴾: عَلى خَيرٍ عِنْدِي.﴿فِتۡنَةࣱ﴾: بَلْوى يَبْتَلِي اللهُ بِها عِبادَهُ لِيَنْظُرَ مَن يَشْكُرُهُ مِمَّنْ يَكْفُرُهُ."
  39,50,"﴿فَمَآ أَغۡنَىٰ عَنۡهُم﴾: ما دَفَعَ عَنْهُمُ العَذابَ."
  39,51,"﴿سَيِّـَٔاتُ مَا كَسَبُواْ﴾: جَزاءُ سَيِّئاتِهِم وهو العَذابُ.﴿وَمَا هُم بِمُعۡجِزِينَ﴾: وماهُمْ بِفائِتِينَ اللهَ ولا سابِقِيهِ."
  39,52,"﴿وَيَقۡدِرُ﴾: ويُضَيِّقُ."
  39,53,"﴿أَسۡرَفُواْ عَلَىٰٓ أَنفُسِهِمۡ﴾: تَمادَوا في المَعاصِي والكَبائِر.﴿لَا تَقۡنَطُواْ﴾: لا تَيْئَسُوا."
  39,54,"﴿وَأَنِيبُوٓاْ﴾: ارْجِعُوا إلى رَبِّكُم بالتَّوبَةِ والطّاعةِ.﴿وَأَسۡلِمُواْ لَهُۥ﴾: واخْضَعُوا لَهُ بالطّاعةِ والإقْرارِ بَتَوْحِيدِهِ وإخْلاصِ العِبادةِ لَهُ.﴿لَا تُنصَرُونَ﴾: لا تُمنَعُونَ."
  39,55,"﴿أَحۡسَنَ مَآ أُنزِلَ إِلَيۡكُم مِّن رَّبِّكُم﴾: هو القُرآنُ العظِيمُ، وفِيهِ الخبرُ والأمْرُ بالحَسَنِ والأَحْسَنِ، ومُقْتَضاهُ فِيهِ حَسَنٌ وأَحْسَنُ، وإن كانَ في نَفْسِه أحْسَنَ الحَدِيثِ.﴿بَغۡتَةࣰ﴾: فَجْأةً."
  39,56,"﴿أَن تَقُولَ﴾: لِئَلّا تَقُولَ.﴿يَـٰحَسۡرَتَى﴾: يا نَدَمِي؛ اغْتِمامًا عَلى ما فاتَ.﴿مَا فَرَّطتُ﴾: ما ضَيَّعْتُ في الدُّنيا مِنَ العَمَلِ بِما أمَرَنِي اللهُ بِه.﴿فِي جَنۢبِ ٱللَّهِ﴾: في طاعَتِهِ.﴿ٱلسَّـٰخِرِينَ﴾: المُسْتَهْزِئِينَ بِأمْرِ اللهِ وكِتابِهِ ورَسُولِهِ والمؤُمِنِينَ."
  39,58,"﴿كَرَّةࣰ﴾: رَجْعَةً إلى الحياةِ الدُّنيا."
  39,60,"﴿مَثۡوࣰى﴾: مأوىً ومَسْكَنٌ."
  39,61,"﴿بِمَفَازَتِهِمۡ﴾: بِسَبِبِ فَوْزِهِم بالأَعْمالِ الصّالِحَةِ.﴿ٱلسُّوٓءُ﴾: أذى جَهَنَّمَ."
  39,62,"﴿وَكِيلࣱ﴾: حَفِيظٌ يُدَبِّرُ جَمِيعَ شَؤُونِ خَلْقِهِ."
  39,63,"﴿مَقَالِيدُ﴾: مَفاتِيحُ خَزائِن."
  39,65,"﴿لَيَحۡبَطَنَّ﴾: لَيَبْطُلَنَّ."
  39,67,"﴿وَمَا قَدَرُواْ ٱللَّهَ حَقَّ قَدۡرِهِۦ﴾: ما عَظَّمُوا اللهَ حَقَّ تعظِيمِهِ إذْ عَبَدُوا مَعَهُ غَيرَهُ.﴿قَبۡضَتُهُۥ﴾: في قَبْضَتِه عَلى ما يَلِيقُ بِه."
  39,68,"﴿ٱلصُّورِ﴾: الَقْرنِ الَّذِي يُنْفخُ فِيهِ.﴿فَصَعِقَ﴾: فَماتَ مِنَ الفَزَعِ وشِدَّةِ الصَّوْتِ.﴿أُخۡرَىٰ﴾: هي نَفْخَةُ البَعْثِ.﴿يَنظُرُونَ﴾: يُبْصِرُونَ، لِكَمالِ حياتِهِم."
  39,69,"﴿وَأَشۡرَقَتِ﴾: أضاءَتْ.﴿ٱلۡأَرۡضُ﴾: أرْضُ القِيامَةِ.﴿وَوُضِعَ ٱلۡكِتَـٰبُ﴾: ونَشَرَتِ الملائِكةُ صَحِيفَةَ كُلِّ فَرْدٍ.﴿وَٱلشُّهَدَآءِ﴾: هُمُ الَّذِينَ يَشْهَدُونَ على النّاسِ بأعْمالِهِم."
  39,71,"﴿وَسِيقَ﴾: وحُثَّ الكافِرُونَ على السَّيرِ بِعْنْفٍ.﴿زُمَرًا﴾: جماعاتٍ مُتَفَرِّقةً، بَعْضُهُم عَلى إثْرِ بَعْضٍ.﴿حَقَّتۡ﴾: وجَبَتْ.﴿كَلِمَةُ ٱلۡعَذَابِ﴾: قَضاءُ اللهِ بالعَذابِ."
  39,72,"﴿فَبِئۡسَ﴾: فَقَبُحَ.﴿مَثۡوَى﴾: مَصِيرُ."
  39,73,"﴿وَسِيقَ﴾: وحُثَّ المتَّقُونَ عَلى السَّيرِ مُكَرَّمِينَ.﴿زُمَرًا﴾: جماعاتٍ مُتَفَرِّقةً، بعضُهم على إثْرِ بَعْضٍ.﴿طِبۡتُمۡ﴾: طابَتْ أحْوالُكُم."
  39,74,"﴿ٱلۡأَرۡضَ﴾: أرْضَ الجنَّةِ.﴿نَتَبَوَّأُ﴾: نَنْزِلُ."
  39,75,"﴿حَآفِّينَ﴾: مُحِيطِينَ بجَوانِبِ العَرْشِ.﴿ٱلۡعَرۡشِ﴾: هو سَرِيرُ الُملْكِ الَّذي اسْتَوى عَلَيهِ الَّرحمنُ، وتَحْمِلُهُ الملائِكَةُ، وهو أعْظَمُ المَخْلُوقاتِ، وهو سَقْفُ الجنَّةِ.﴿يُسَبِّحُونَ﴾: يُنَزِّهُونَ."
