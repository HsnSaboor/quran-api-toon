tafsir[73]{c,v,t}:
  28,2,"28:1"
  28,3,"﴿نَّبَإِ مُوسَىٰ﴾: خَبَرِ مُوسى.﴿بِٱلۡحَقِّ﴾: بالصِّدْقِ."
  28,4,"﴿عَلَا﴾: تَجَبَّرَ وتكَبَّرَ.﴿شِيَعࣰا﴾: طَوائِفَ مُتَفَرِّقةً.﴿وَيَسۡتَحۡيِۦ نِسَآءَهُمۡ﴾: أي: يَسْتَبْقِيهِنَّ للخِدْمَةِ والامْتِهانِ."
  28,5,"﴿أَن نَّمُنَّ﴾: أن نَتَفَضَّلَ.﴿أَئِمَّةࣰ﴾: قادَةً في الخيرِ.﴿ٱلۡوَ ٰ⁠رِثِينَ﴾: أي: ورِثُوا أرضَ مِصْرَ بَعْدَ هَلاكِ فِرْعَونَ وقَومِهِ."
  28,6,"﴿وَنُمَكِّنَ﴾: ونُثَبِّتَ لهم.﴿يَحۡذَرُونَ﴾: يَخافُونَ."
  28,7,"﴿وَأَوۡحَيۡنَآ﴾: وألْهَمْنا.﴿فِي ٱلۡيَمِّ﴾: في نَهْرِ النِّيلِ."
  28,8,"﴿فَٱلۡتَقَطَهُۥٓ﴾: فأخَذَهُ.﴿لِيَكُونَ﴾: أي: في المآلِ والعاقِبَةِ."
  28,9,"﴿قُرَّتُ عَيۡنࣲ﴾: مَصْدرُ سُرورٍ وسَعادةٍ تَقَرُّ العَينُ بِهِ."
  28,10,"﴿فُؤَادُ﴾: قَلْبُ.﴿فَـٰرِغًا﴾: خالِيًا مِن كلِّ شَيءٍ، ليمْلَأَه هَمُّ مُوسى وذِكْرُه.﴿لَتُبۡدِي بِهِۦ﴾: لَتُظْهِرُ أنَّ مُوسى ابْنُها.﴿أَن رَّبَطۡنَا﴾: أن ثبَّتناها بالصَّبرِ والثَّباتِ."
  28,11,"﴿قُصِّيهِ﴾: اتَّبعِي أثَرَ مُوسى وتَعَرَّفي خَبَرَه.﴿عَن جُنُبࣲ﴾: عن بُعدٍ."
  28,12,"﴿وَحَرَّمۡنَا عَلَيۡهِ﴾: أي: مَنَعْناهُ مِن قَبُولِ الرَّضاعَةِ.﴿يَكۡفُلُونَهُۥ﴾: يقُومُونَ بإرْضاعِه وتَرْبِيَتِهِ.﴿نَـٰصِحُونَ﴾: مُشْفِقُونَ."
  28,13,"﴿كَيۡ تَقَرَّ عَيۡنُهَا﴾: كَي تُسَرَّ أمُّ مُوسى بِسَلامَةِ ولَدِها ورُجُوعِهِ إليها."
  28,14,"﴿أَشُدَّهُۥ وَٱسۡتَوَىٰٓ﴾: أي: مُنْتَهى قُوَّتِه، وتكامَلَ عَقْلُه.﴿ءَاتَيۡنَـٰهُ حُكۡمࣰا وَعِلۡمࣰا﴾: أعْطَيناه حِكْمَةً وفَهْمًا ومَعْرِفَةً بالدِّينِ."
  28,15,"﴿عَلَىٰ حِينِ غَفۡلَةࣲ﴾: وقْتِ غَفْلَةِ أهْلِها.﴿فَٱسۡتَغَـٰثَهُ﴾: فَطَلَبَ الغَوثَ والنَّصْرَ مِن مُوسى عَلَيهِ الصَّلاةُ والسَّلامُ.﴿مِن شِيعَتِهِۦ﴾: أي: مِن بَنِي إسْرائِيلَ قَومِ مُوسى عَلَيهِ الصَّلاةُ والسَّلامُ.﴿ٱلَّذِي مِنۡ عَدُوِّهِۦ﴾: أي: القِبْطِيِّ الَّذي كان مِن قَومِ فِرْعَونَ.﴿فَوَكَزَهُۥ﴾: ضَرَبَه مُوسى بجُمْعِ كَفِّه.﴿فَقَضَىٰ عَلَيۡهِ﴾: قَتَلَه."
  28,17,"﴿ظَهِيرࣰا﴾: مُعِينًا."
  28,18,"﴿يَتَرَقَّبُ﴾: يَتَوَقَّعُ المكْرُوهَ ويُراقِبُ ما يَحْدُثُ.﴿يَسۡتَصۡرِخُهُۥ﴾: يَطْلُبُ مِنهُ النَّصْرَ.﴿لَغَوِيࣱّ﴾: لَشَدِيدُ الضَّلالِ وسُوءِ النَّظرِ."
  28,19,"﴿أَن يَبۡطِشَ﴾: أن يَأْخُذَ بقوَّةٍ وعُنْفٍ."
  28,20,"﴿أَقۡصَا ٱلۡمَدِينَةِ﴾: آخِرِ المدينةِ.﴿ٱلۡمَلَأَ﴾: أشْرافَ القَومِ.﴿يَأۡتَمِرُونَ﴾: يَتَشاورُونَ في شَأْنِكَ.﴿ٱلنَّـٰصِحِينَ﴾: المُشْفِقِينَ."
  28,22,"﴿تِلۡقَآءَ مَدۡيَنَ﴾: جِهَةَ مَدْيَنَ.﴿سَوَآءَ ٱلسَّبِيلِ﴾: أي: الطَّرِيقَ المُسْتَويَ إلى مَدْيَنَ."
  28,23,"﴿وَرَدَ﴾: بَلَغَ.﴿أُمَّةࣰ﴾: جَماعةً.﴿تَذُودَانِ﴾: تَحبِسانِ غَنَمَهُما عَنِ الماءِ.﴿مَا خَطۡبُكُمَا﴾: ما شَأْنُكما؟﴿يُصۡدِرَ ٱلرِّعَآءُ﴾: يَنْصَرِفَ الرُّعاةُ بِمَواشِيهِم عَنِ الماءِ."
  28,24,"﴿تَوَلَّىٰٓ إِلَى ٱلظِّلِّ﴾: رَجَعَ إليه."
  28,26,"28:25"
  28,27,"﴿تَأۡجُرَنِي﴾: تَكُونَ لي أجِيرًا في رَعْيِ الغَنَمِ.﴿حِجَجࣲ﴾: سِنِينَ."
  28,28,"﴿أَيَّمَا ٱلۡأَجَلَيۡنِ﴾: أيَّ المُدَّتَينِ.﴿قَضَيۡتُ﴾: وفَّيتُ به وأتْمَمْتُه.﴿فَلَا عُدۡوَ ٰ⁠نَعَلَيَّ﴾: لا اعْتِداءَ ولا ظُلْمَ عليّ بالمطالَبَةِ بأكْثَرَ مِنه.﴿وَكِيلࣱ﴾: شاهِدٌ وحَفِيظٌ."
  28,29,"﴿ٱلۡأَجَلَ﴾: المُدَّةَ المُتَّفَقَ عَلَيها وهي عَشْرُ سِنِينَ.﴿ءَانَسَ﴾: أبصَرَ ما يُؤْنِسُ.﴿جَذۡوَةࣲ﴾: جَمْرَةٍ وشُعْلَةٍ.﴿تَصۡطَلُونَ﴾: تَسْتَدْفِئُونَ بِها."
  28,30,"﴿شَـٰطِيِٕ﴾: جانِبِ.﴿ٱلۡبُقۡعَةِ﴾: القِطْعَةِ مِنَ الأرْضِ."
  28,31,"﴿تَهۡتَزُّ﴾: تتحرَّكُ بخِفَّةٍ.﴿جَآنࣱّ﴾: حَيَّةٌ خَفِيفَةٌ في سُرْعَةِ حرَكَتِها.﴿وَلَّىٰ﴾: هَرَبَ.﴿وَلَمۡ يُعَقِّبۡ﴾: لم يَرْجِعْ.﴿أَقۡبِلۡ﴾: تَقَدَّمْ."
  28,32,"﴿ٱسۡلُكۡ﴾: أدْخِلْ.﴿فِي جَيۡبِكَ﴾: في فَتْحَةِ قَمِيصِكَ الَّتِي يُدْخَلُ مِنها الرَّأسُ.﴿مِنۡ غَيۡرِ سُوٓءࣲ﴾: مِن غَيرِ مَرَضٍ ولا بَرَصٍ.﴿جَنَاحَكَ﴾: يَدَكَ.﴿مِنَ ٱلرَّهۡبِ﴾: لِتَأْمَنَ مِنَ الخَوْفِ.﴿وَمَلَإِيْهِۦٓ﴾: أشْرافِ قومهِ."
  28,34,"﴿رِدۡءࣰا﴾: مُعِينًا."
  28,35,"﴿سَنَشُدُّ عَضُدَكَ﴾: سَنُقَوِّيكَ ونُعِينُكَ.﴿سُلۡطَـٰنࣰا﴾: حُجَّةً أو مَهابَةً في قُلُوبِ الأعْداءِ."
  28,37,"﴿عَـٰقِبَةُ ٱلدَّارِ﴾: العاقِبةُ المحْمُودَةُ في الدّارِ الآخِرَةِ."
  28,38,"﴿ٱلۡمَلَأُ﴾: الأشْرافُ مِن قَومِه.﴿فَأَوۡقِدۡ﴾: فَأَشْعِلْ.﴿صَرۡحࣰا﴾: قَصْرًا.﴿أَطَّلِعُ﴾: أنظُرُ."
  28,40,"﴿فَنَبَذۡنَـٰهُمۡ فِي ٱلۡيَمِّ﴾: فَطَرَحْناهُمْ في البَحْرِ، فَأَغْرَقَنْاهُم."
  28,42,"﴿مِّنَ ٱلۡمَقۡبُوحِينَ﴾: مِنَ المذْمُومِينَ والمُبْعَدِينَ مِن كُلِّ خَيْرٍ."
  28,43,"﴿ٱلۡقُرُونَ ٱلۡأُولَىٰ﴾: الأُمَمَ الماضِيَةَ."
  28,44,"﴿قَضَيۡنَآ إِلَىٰ مُوسَى﴾: عَهِدْنا إليهِ وكَلَّفْناهُ.﴿ٱلۡأَمۡرَ﴾: أي: أمْرَ الرِّسالَةِ.﴿مِنَ ٱلشَّـٰهِدِينَ﴾: مِنَ الحاضِرِينَ في ذلك الوقتِ."
  28,45,"﴿أَنشَأۡنَا﴾: خَلَقْنا.﴿قُرُونࣰا﴾: أُمَمًا.﴿فَتَطَاوَلَ عَلَيۡهِمُ ٱلۡعُمُرُ﴾: امْتَدَّ عَلَيهِمُ الزَّمانُ.﴿ثَاوِيࣰا﴾: مُقِيمًا."
  28,46,"﴿ٱلطُّورِ﴾: جَبَلِ طُورِ سَيناءَ."
  28,47,"﴿بِمَا قَدَّمَتۡ أَيۡدِيهِمۡ﴾: أي: بِسَبَبِ أعْمالِهِم السَّيِّئَةِ."
  28,48,"﴿أُوتِيَ﴾: أُعْطِيَ.﴿سِحۡرَانِ﴾: أي: التَّوراةُ والقرآنُ حَسَبَ زَعْمِهِم، أو هُما ذَوا سِحْرٍ، أي: مُوسى ومُحَمَّدٌ  عليهما الصَّلاةُ والسَّلامُ  حَسَبَ زَعْمِهِم."
  28,50,"28:49"
  28,51,"﴿وَصَّلۡنَا لَهُمُ ٱلۡقَوۡلَ﴾: أي: نَزَّلْنا عَلَيهِم القرآنَ يَتْبَعُ بَعْضُهُ بَعْضًا."
  28,53,"﴿مُسۡلِمِينَ﴾: أي: مُخْلِصِينَ للهِ بالتوحيدِ."
  28,54,"﴿وَيَدۡرَءُونَ﴾: يَدْفَعُونَ."
  28,55,"﴿ٱللَّغۡوَ﴾: السّاقِطَ مِنَ القَوْلِ.﴿لَا نَبۡتَغِي﴾: لا نُرِيدُ ولا نُحِبُّ."
  28,56,"﴿لَا تَهۡدِي﴾: أي: هِدايةَ توفِيقٍ."
  28,57,"﴿نُتَخَطَّفۡ﴾: نُخْتلَسْ ونُسْتَلَبْ قَتْلًا وأسْرًا.﴿أَوَ لَمۡ نُمَكِّن لَّهُمۡ حَرَمًا ءَامِنࣰا﴾: أولم نَجْعَلْهُم يَنْعَمُونَ بالأمْنِ والتَّمكِينِ في البلدِ الحرامِ.﴿يُجۡبَىٰٓ إِلَيۡهِ﴾: يُجْلَبُ إليه."
  28,58,"﴿وَكَمۡ﴾: كَثِيرًا.﴿بَطِرَتۡ مَعِيشَتَهَا﴾: طَغَتْ وكَفَرتْ نِعْمَةَ العَيشِ بالرَّغَدِ.﴿ٱلۡوَ ٰ⁠رِثِينَ﴾: أي: للعِباد بَعْدَ إهْلاكِهم."
  28,59,"﴿فِيٓ أُمِّهَا﴾: وهي مَكَّة المكَرَّمةُ، وتُعْرَفُ بأمِّ القُرى."
  28,60,"﴿وَمَآ أُوتِيتُم﴾: وما أُعْطِيتُم."
  28,61,"﴿وَعۡدًا حَسَنࣰا﴾: أي: بِدُخُولِ الجنَّةِ.﴿مِنَ ٱلۡمُحۡضَرِينَ﴾: أي: مِمَّن أُحْضِرُوا لِلْحِسابِ والعَذابِ."
  28,63,"﴿حَقَّ عَلَيۡهِمُ ٱلۡقَوۡلُ﴾: وجَبَ لهم العَذابُ.﴿أَغۡوَيۡنَآ﴾: أضْلَلْنا.﴿تَبَرَّأۡنَآ﴾: أي: مِن عِبادتِهم إيّانا."
  28,65,"28:64"
  28,66,"﴿فَعَمِيَتۡ عَلَيۡهِمُ ٱلۡأَنۢبَآءُ﴾: فَخَفِيَتْ عَلَيهِمُ الأَخْبارُ الَّتي كانُوا يَحْتَجُّونَ بِها."
  28,68,"﴿ٱلۡخِيَرَةُ﴾: الاخْتِيارُ."
  28,69,"﴿مَا تُكِنُّ﴾: ما تُخْفِي."
  28,70,"﴿ٱلۡأُولَىٰ﴾: الحَياةِ الأُولى هي الدُّنيا.﴿وَٱلۡـَٔاخِرَةِ﴾: الدّارِ الآخرةِ."
  28,71,"﴿أَرَءَيۡتُمۡ﴾: أي: أخْبِرُونِي.﴿سَرۡمَدًا﴾: دائِمًا مُسْتَمِرًّا.﴿بِضِيَآءٍ﴾: بنُورٍ."
  28,72,"﴿تَسۡكُنُونَ فِيهِ﴾: تَسْتَقِرُّونَ فِيه مِنَ التَّعَبِ."
  28,73,"﴿لِتَسۡكُنُواْ فِيهِ﴾: لِتَسْتَقِرُّوا في اللَّيلِ وتَرْتاحَ أبْدانُكُم.﴿لِتَبۡتَغُواْ مِن فَضۡلِهِۦ﴾: لِتطْلُبُوا وتَلْتَمِسُوا مِن رِزْقِهِ."
  28,75,"﴿وَنَزَعۡنَا﴾: وأَخْرَجْنا.﴿شَهِيدࣰا﴾: وهو نَبِيُّ كُلِّ أُمَّةٍ.﴿هَاتُواْ بُرۡهَـٰنَكُمۡ﴾: أحْضِرُوا حُجَّتَكُم.﴿يَفۡتَرُونَ﴾: يَخْتَلِقُونَ."
  28,76,"﴿فَبَغَىٰ عَلَيۡهِمۡ﴾: تَكَبَّرَ عَلَيهِم.﴿وَءَاتَيۡنَـٰهُ﴾: وأعْطَيناهُ.﴿ٱلۡكُنُوزِ﴾: الأمْوالِ المدَّخَرَةِ في الخَزائِنِ.﴿لَتَنُوٓأُ بِٱلۡعُصۡبَةِ﴾: لَتُثْقِلُ الجَماعَةَ الكَثِيرَةَ.﴿أُوْلِي ٱلۡقُوَّةِ﴾: أصْحابِ القُوَّةِ، الأقْوِياءِ.﴿لَا تَفۡرَحۡ﴾: لا تَبْطَرْ فَرَحًا بِكَثْرَةِ المالِ."
  28,77,"﴿وَٱبۡتَغِ﴾: والتَمِسْ.﴿ءَاتَىٰكَ﴾: أعْطاكَ.﴿وَلَا تَنسَ نَصِيبَكَ﴾: ولا تَترُكْ حَظَّكَ مِنَ الدُّنيا.﴿وَلَا تَبۡغِ﴾: ولا تَلْتمِسْ."
  28,78,"﴿أُوتِيتُهُۥ﴾: أُعْطِيتُ هَذا المالَ.﴿مِنَ ٱلۡقُرُونِ﴾: مِنَ الأُمَمِ."
  28,79,"﴿أُوتِيَ﴾: أُعطِيَ.﴿لَذُو حَظٍّ﴾: لَصاحِبُ نَصِيبٍ."
  28,80,"﴿أُوتُواْ﴾: أُعطُوا.﴿وَيۡلَكُمۡ﴾: زَجْرٌ لهم عَنْ هَذا التَّمَنِّي.﴿وَلَا يُلَقَّىٰهَآ﴾: أي: لا يُعطى تِلْكَ الخَصْلَةَ أوِ الجنَّةَ."
  28,81,"﴿فَخَسَفۡنَا بِهِۦ﴾: أي: فَجَعَلْنا الأرضَ تَبْتَلِعُهُ وهو حَيٌّ.﴿فِئَةࣲ﴾: جَماعَةٍ."
  28,82,"﴿وَيۡكَأَنَّ﴾: كَلِمَةُ تَندُّمٍ وتَفَجُّعٍ، أي: ألمْ تَعْلَمْ.﴿يَبۡسُطُ﴾: يُوسِّعُ.﴿وَيَقۡدِرُ﴾: يُضَيِّقُ.﴿مَّنَّ﴾: أنْعَمَ.﴿وَيۡكَأَنَّهُۥ﴾: ألَمْ تَعْلَمْ."
  28,83,"﴿عُلُوࣰّا﴾: تَكَبُّرًا.﴿وَٱلۡعَـٰقِبَةُ﴾: أي: العاقِبةُ المحْمُودَةُ، وهي الجنَّةُ."
  28,85,"﴿فَرَضَ﴾: أي: أنْزَلَ وأَوْجَبَ عَلَيكَ العَمَلَ بِمُقْتَضاه.﴿لَرَآدُّكَ﴾: لَمُرْجِعُكَ.﴿إِلَىٰ مَعَادࣲ﴾: المرادُ بِهِ هُنا «مَكَّةُ».﴿ضَلَـٰلࣲ مُّبِينࣲ﴾: انحِرافٍ واضِحٍ."
  28,86,"﴿تَرۡجُوٓاْ﴾: تَتَوَقَّعُ وتَنْتَظِرُ.﴿أَن يُلۡقَىٰٓ﴾: أي: أن يُنزَّلَ.﴿ظَهِيرࣰا﴾: مُعِينًا."
  28,87,"﴿وَلَا يَصُدُّنَّكَ﴾: ولا يَصْرِفُنَّكَ."
  28,88,"﴿إِلَّا وَجۡهَهُۥ﴾: إلّا إيّاهُ، أو إلّا ما أُرِيدَ به وجْهُه.﴿ٱلۡحُكۡمُ﴾: القَضاءُ النّافِذُ، يَقْضِي بما شاءَ."
