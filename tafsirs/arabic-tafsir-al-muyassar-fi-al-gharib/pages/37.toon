tafsir[141]{c,v,t}:
  37,1,"﴿وَٱلصَّـٰٓفَّـٰتِ﴾: هي الملائِكَةُ التي تَصْطَفُّ في عِبادَتِها."
  37,2,"﴿فَٱلزَّ ٰ⁠جِرَ ٰ⁠تِ﴾: هي الملائكةُ التي تَزْجُرُ السَّحابَ وتَسُوقُه."
  37,3,"﴿ذِكۡرًا﴾: هو القرآنُ."
  37,5,"37:4"
  37,6,"﴿ٱلۡكَوَاكِبِ﴾: النُّجُومِ."
  37,7,"﴿مَّارِدࣲ﴾: مُتَمَرِّدٍ خارجٍ عَنِ الطّاعةِ."
  37,8,"﴿وَيُقۡذَفُونَ﴾: ويُرجَمُونَ (بالشُّهُبِ)."
  37,9,"﴿دُحُورࣰا﴾: إبْعادًا وطَرْدًا.﴿وَاصِبٌ﴾: دائمٌ لا يَنْقَطِعُ."
  37,10,"﴿خَطِفَ ٱلۡخَطۡفَةَ﴾: أي: اسْتَرَقَ السَّمْعَ خِلْسةً.﴿فَأَتۡبَعَهُۥ﴾: تَبِعَه ولحِقَه.﴿شِهَابࣱ ثَاقِبࣱ﴾: نَجْمٌ مُضِيءٌ."
  37,11,"﴿لَّازِبِۭ﴾: مُلْتَزِقٍ بَعْضُه ببَعْضٍ."
  37,12,"﴿وَيَسۡخَرُونَ﴾: يَسْتَهْزِئُونَ بِكَ."
  37,14,"﴿ءَايَةࣰ﴾: مُعْجِزَةً مِن مُّعْجِزاتِكَ.﴿يَسۡتَسۡخِرُونَ﴾: يبالِغُونَ في سُخْرِيَّتِهِم."
  37,16,"37:15"
  37,17,"37:15"
  37,18,"﴿دَ ٰ⁠خِرُونَ﴾: أذِلّاءُ صاغِرُونَ."
  37,19,"﴿زَجۡرَةࣱ وَ ٰ⁠حِدَةࣱ﴾: نَفْخَةٌ واحِدَةٌ."
  37,20,"﴿يَـٰوَيۡلَنَا﴾: يا هَلاكَنا."
  37,21,"﴿يَوۡمُ ٱلۡفَصۡلِ﴾: يومُ القضاءِ بَيْنَ الخَلْقِ."
  37,22,"﴿ٱحۡشُرُواْ﴾: اجْمَعُوا.﴿وَأَزۡوَ ٰ⁠جَهُمۡ﴾: قُرَناءَهُم ونُظراءَهُم."
  37,23,"﴿فَٱهۡدُوهُمۡ إِلَىٰ صِرَ ٰ⁠طِ ٱلۡجَحِيمِ﴾: دُلُّوهُم إلى طَرِيقِ النّارِ، وسُوقُوهُم إليها."
  37,24,"﴿وَقِفُوهُمۡ﴾: احْبِسُوهُم في مَوْقِفِ الحِسابِ."
  37,26,"﴿مُسۡتَسۡلِمُونَ﴾: مُنْقادُونَ أذلّاءُ لِعَجِزِهِم عَنِ الحِيلَةِ."
  37,28,"﴿عَنِ ٱلۡيَمِينِ﴾: أي: عَنِ النّاحيةِ الَّتي كان مِنها الحقُّ، فَتَصْرِفُونَنا عَنْها."
  37,30,"﴿طَـٰغِينَ﴾: متجاوِزِينَ الحَدَّ في الكُفْرِ والضَّلالِ."
  37,31,"﴿فَحَقَّ﴾: ثَبَتَ ووَجَبَ."
  37,32,"﴿فَأَغۡوَيۡنَـٰكُمۡ﴾: فأَضْلَلْناكُم.﴿غَـٰوِينَ﴾: ضالِّيِنَ."
  37,34,"37:33"
  37,35,"37:33"
  37,36,"37:33"
  37,37,"37:33"
  37,38,"37:33"
  37,39,"37:33"
  37,40,"37:33"
  37,41,"37:33"
  37,42,"37:33"
  37,43,"37:33"
  37,44,"37:33"
  37,45,"﴿يُطَافُ﴾: يُدارُ.﴿بِكَأۡسࣲ﴾: بِكأسٍ مِن خمْرٍ.﴿مَّعِينِۭ﴾: نابِعٍ مِنَ العُيوَنِ."
  37,47,"﴿لَا فِيهَا غَوۡلࣱ﴾: لا أذىً فيها ولا مَكْروهٌ على شاربيها.﴿وَلَا هُمۡ عَنۡهَا يُنزَفُونَ﴾: ولا هم عَن شُرْبِها تَذْهَبُ عُقُولُهم، أي: لا تُنزَفُ عُقُولُهم كما يُنْزَفَ دَمُ الجَرِيحِ."
  37,48,"﴿قَـٰصِرَ ٰ⁠تُ ٱلطَّرۡفِ﴾: حُورٌ قَصَرْنَ نَظَرَهُنَّ على أزْواجِهِنَّ.﴿عِينࣱ﴾: جَمْعُ «عَيناءَ»: واسعةُ العَينِ حَسَنَتُها."
  37,49,"﴿مَّكۡنُونࣱ﴾: مَصُونٌ لم يَمْسَسْهُ أحَدٌ."
  37,51,"﴿قَرِينࣱ﴾: صاحِبٌ مُلازِمٌ."
  37,53,"﴿لَمَدِينُونَ﴾: لَمَجْزِيُّونَ ومُحاسَبُونَ."
  37,55,"﴿سَوَآءِ ٱلۡجَحِيمِ﴾: وسَطِها."
  37,56,"﴿تَٱللَّهِ﴾: واللهِ.﴿كِدتَّ﴾: قارَبْتَ.﴿لَتُرۡدِينِ﴾: لَتُهْلِكُنِي."
  37,57,"﴿ٱلۡمُحۡضَرِينَ﴾: أي: في العذابِ مِثلَك."
  37,59,"37:58"
  37,60,"37:58"
  37,61,"37:58"
  37,62,"﴿نُّزُلًا﴾: ما يُهَيَّأُ للنَّزيلِ إكْرامًا لهُ.﴿شَجَرَةُ ٱلزَّقُّومِ﴾: الشَّجَرَةُ الخَبيَثةُ الملعُونةُ ذاتُ الثَّمرِ المُرِّ الكرِيهِ الرّائِحَةِ."
  37,63,"﴿فِتۡنَةࣰ لِّلظَّـٰلِمِينَ﴾: مِحْنَةً لَهُم لِكَوْنِهِم يُعَذَّبُونَ بِها في الآخِرةِ."
  37,64,"﴿تَخۡرُجُ﴾: تَنْبُتُ.﴿أَصۡلِ ٱلۡجَحِيمِ﴾: قَعْرِ جَهَنَّمَ."
  37,65,"﴿طَلۡعُهَا﴾: ثَمَرُها.﴿كَأَنَّهُۥ رُءُوسُ ٱلشَّيَـٰطِينِ﴾: تشبيهٌ للمَحْسُوسِ بالمتَخَيَّلِ؛ لِتناهِيهِ في البَشاعَةِ والقُبْحِ."
  37,67,"﴿لَشَوۡبࣰا﴾: لخَلْطًا ومِزاجًا.﴿مِّنۡ حَمِيمࣲ﴾: الماءِ الحارِّ الشَّديدِ الحرارةِ."
  37,68,"﴿مَرۡجِعَهُمۡ﴾: مَرَدَّهُم.﴿ٱلۡجَحِيمِ﴾: جَهَنَّمَ."
  37,69,"﴿أَلۡفَوۡاْ﴾: وجَدُوا."
  37,70,"﴿يُهۡرَعُونَ﴾: يُسْرِعُونَ إلى متابعةِ آبائِهِم الضّالِّينَ."
  37,72,"﴿مُّنذِرِينَ﴾: مُرسَلِينَ."
  37,74,"37:73"
  37,75,"37:73"
  37,76,"﴿ٱلۡكَرۡبِ ٱلۡعَظِيمِ﴾: الغَرَقِ بالطُّوفانِ العظيمِ."
  37,78,"﴿ٱلۡـَٔاخِرِينَ﴾: الَّذينَ جاؤُوا بَعْدَه."
  37,80,"37:79"
  37,81,"37:79"
  37,82,"﴿ٱلۡـَٔاخَرِينَ﴾: الباقِينَ الَّذين كذَّبوُا نوحًا عليه الصَّلاةُ والسَّلامُ."
  37,83,"﴿شِيعَتِهِۦ﴾: أي: جَماعَتِهِ الَّذينَ هُمُ الأنبِياءُ والمرْسَلُونَ عليهم الصَّلاةُ والسَّلامُ."
  37,85,"37:84"
  37,86,"﴿أَئِفۡكًا﴾: أكَذِبًا وباطِلًا."
  37,88,"﴿فَنَظَرَ﴾: تَأَمَّلَ."
  37,89,"﴿سَقِيمࣱ﴾: مَرِيضٌ."
  37,90,"﴿فَتَوَلَّوۡاْ عَنۡهُ مُدۡبِرِينَ﴾: فانصَرَفُوا عنه مُعْرِضِين."
  37,91,"﴿فَرَاغَ إِلَىٰٓ﴾: ذَهَبَ خُفْيَةً."
  37,93,"﴿فَرَاغَ عَلَيۡهِمۡ﴾: مالَ وأَقْبَل عَلَيهِم.﴿بِٱلۡيَمِينِ﴾: أي: بيَدِه اليُمْنى."
  37,94,"﴿يَزِفُّونَ﴾: يُسْرِعُونَ في مَشْيِهِم."
  37,95,"﴿تَنۡحِتُونَ﴾: تَبْرُونَ وتَقْشِرُونَ بِأَيْدِيكُم."
  37,97,"﴿ٱلۡجَحِيمِ﴾: النّارِ الشَّديدةِ الاتِّقادِ."
  37,98,"﴿ٱلۡأَسۡفَلِينَ﴾: المقْهُورِينَ المغْلُوبِينَ."
  37,100,"37:99"
  37,101,"﴿حَلِيمࣲ﴾: أي: عِنْدَما يَكْبَر."
  37,103,"﴿أَسۡلَمَا﴾: اسْتَسْلَما لأمْرِ اللهِ وانْقادا لَه.﴿وَتَلَّهُۥ لِلۡجَبِينِ﴾: أي: أضْجَعَه على جَبينِه على الأرضِ."
  37,105,"37:104"
  37,106,"﴿ٱلۡبَلَـٰٓؤُاْ ٱلۡمُبِينُ﴾: الاخْتِبارُ الواضِحُ."
  37,107,"﴿بِذِبۡحٍ عَظِيمࣲ﴾: بكَبْشٍ مَذْبُوحٍ عَظِيمِ القَدْرِ."
  37,108,"﴿عَلَيۡهِ﴾: أي: على ذِكْرِه الحَسَنِ.﴿فِي ٱلۡـَٔاخِرِينَ﴾: في الأُمَمِ التي جاءتْ بَعْدَه."
  37,110,"37:109"
  37,111,"37:109"
  37,112,"37:109"
  37,113,"37:109"
  37,114,"37:109"
  37,115,"﴿مِنَ ٱلۡكَرۡبِ ٱلۡعَظِيمِ﴾: أي: مِنَ الغَرَقِ وتَسَلُّطِ فِرْعَونَ."
  37,117,"37:116"
  37,118,"37:116"
  37,119,"﴿عَلَيۡهِمَا﴾: أي: على ذِكْرِهِما الحَسَنِ.﴿فِي ٱلۡـَٔاخِرِينَ﴾: في الأمَمِ الَّتي جاءَتْ بَعْدَهُما."
  37,121,"37:120"
  37,122,"37:120"
  37,123,"37:120"
  37,124,"37:120"
  37,125,"﴿بَعۡلࣰا﴾: وهو اسْمٌ لِصَنَمٍ كانُوا يَعْبُدُونَهُ.﴿وَتَذَرُونَ﴾: تَتْرُكُونَ."
  37,127,"﴿لَمُحۡضَرُونَ﴾: أي: لِلْحِسابِ والعِقابِ."
  37,129,"﴿عَلَيۡهِ﴾: أي: على ذِكْرِه الحَسَنِ.﴿فِي ٱلۡـَٔاخِرِينَ﴾: في الأُمَمِ الَّتي جاءَتْ بَعْدَهُ."
  37,131,"37:130"
  37,132,"37:130"
  37,133,"37:130"
  37,134,"37:130"
  37,135,"﴿فِي ٱلۡغَـٰبِرِينَ﴾: الباقِينَ في العذابِ."
  37,136,"﴿دَمَّرۡنَا﴾: أهْلَكْنا.﴿ٱلۡـَٔاخَرِينَ﴾: الباقِينَ مِن قَومِ لُوطٍ عَلَيهِ السَّلامُ الَّذينَ لم يُؤْمِنُوا بِهِ."
  37,137,"﴿مُّصۡبِحِينَ﴾: داخِلِينَ وقْتَ الصَّباحِ."
  37,139,"37:138"
  37,140,"﴿أَبَقَ﴾: هَرَبَ.﴿ٱلۡمَشۡحُونِ﴾: المَمْلُوءِ."
  37,141,"﴿فَسَاهَمَ﴾: اقْتَرَعَ وقَبِلَ القُرْعَةَ.﴿ٱلۡمُدۡحَضِينَ﴾: المَغْلُوبِينَ بالقُرْعَةِ."
  37,142,"﴿فَٱلۡتَقَمَهُ﴾: فابْتَلَعَه.﴿مُلِيمࣱ﴾: آتٍ بما يُلامُ عَلَيهِ."
  37,143,"﴿ٱلۡمُسَبِّحِينَ﴾: بِذِكْرِ اللهِ وكَثْرةِ العِبادةِ."
  37,144,"﴿لَلَبِثَ﴾: لمَكَثَ."
  37,145,"﴿فَنَبَذۡنَـٰهُ﴾: طَرَحْناه.﴿بِٱلۡعَرَآءِ﴾: بِأرْضٍ خاليةٍ عاريةٍ من الشَّجرِ والبناءِ.﴿سَقِيمࣱ﴾: ضَعِيفُ البَدَنِ بسَبِبِ حَبْسِهِ في بَطْنِ الحُوتِ."
  37,146,"﴿يَقۡطِينࣲ﴾: القَرْعِ."
  37,148,"37:147"
  37,149,"37:147"
  37,150,"37:147"
  37,151,"﴿إِفۡكِهِمۡ﴾: من كَذِبِهِم وافْتِرائِهِم."
  37,153,"﴿أَصۡطَفَى﴾: هل اخْتارَ؟"
  37,155,"37:154"
  37,156,"﴿سُلۡطَـٰنࣱ مُّبِينࣱ﴾: حُجَّةٌ واضِحةٌ."
  37,158,"﴿وَبَيۡنَ ٱلۡجِنَّةِ﴾: بَيْنَ الملائِكَةِ.﴿لَمُحۡضَرُونَ﴾: أي: لِلْعَذابِ."
  37,160,"37:159"
  37,161,"37:159"
  37,162,"﴿بِفَـٰتِنِينَ﴾: بمُضِلِّينَ ومُفْسِدِينَ أحَدًا."
  37,163,"﴿صَالِ ٱلۡجَحِيمِ﴾: يَدْخُلُ النارَ، ويُقاسي حَرَّها."
  37,165,"﴿ٱلصَّآفُّونَ﴾: الواقِفُونَ صُفُوفًا."
  37,166,"﴿ٱلۡمُسَبِّحُونَ﴾: المُنَزِّهُونَ للهِ والمُقَدِّسُونَ له عَن كُلِّ ما لا يَلِيقُ بِه."
  37,168,"﴿ذِكۡرࣰا مِّنَ ٱلۡأَوَّلِينَ﴾: أي: كِتابًا مِن كُتُبِ الأوَّلِينَ كالتَّوراةِ والإنْجِيلِ."
  37,170,"﴿فَكَفَرُواْ بِهِۦ﴾: أي: فَجاءَهُم الرَّسُولُ بالقرآنِ فَكَفَرُوا بِهِ."
  37,172,"37:171"
  37,173,"37:171"
  37,174,"37:171"
  37,175,"37:171"
  37,176,"37:171"
  37,177,"﴿بِسَاحَتِهِمۡ﴾: بِفِنائِهِم، والمرادُ: القَومُ."
  37,179,"37:178"
  37,180,"37:178"
  37,181,"37:178"
  37,182,"37:178"
