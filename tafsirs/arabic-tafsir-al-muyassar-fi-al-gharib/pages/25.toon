tafsir[66]{c,v,t}:
  25,1,"﴿تَبَارَكَ﴾: تَكاثَرَ خَيْرُه وعَظُمَتْ بَرَكاتُه.﴿ٱلۡفُرۡقَانَ﴾: القُرآنَ، الفارقَ بَيْنَ الحقِّ والَباطِلِ.﴿نَذِيرًا﴾: مُخَوِّفًا."
  25,2,"﴿فَقَدَّرَهُۥ﴾: أي: فَهَيَّأَه لِما يَصْلُحُ لَهُ ويلِيقُ بِهِ."
  25,3,"﴿نُشُورࣰا﴾: بَعْثًا بَعْدَ الموتِ."
  25,4,"﴿هَـٰذَآ﴾: أي: القرآنُ.﴿إِفۡكٌ﴾: كَذِبٌ وبُهْتانٌ.﴿ٱفۡتَرَىٰهُ﴾: اختَلَقَه وتَقَوَّلَه.﴿قَوۡمٌ ءَاخَرُونَ﴾: أي: من الَّذينَ أسْلَمُوا مِن أهْلِ الكِتابِ.﴿وَزُورࣰا﴾: كَذِبًا عظِيمًا."
  25,5,"﴿أَسَـٰطِيرُ ٱلۡأَوَّلِينَ﴾: الأكاذيبُ الَّتي كَتَبها المتقدِّمُونَ.﴿ٱكۡتَتَبَهَا﴾: طَلَبَ كِتابَتَها.﴿تُمۡلَىٰ عَلَيۡهِ﴾: تُقْرَأُ عَلَيهِ لِيِحْفَظَها."
  25,6,"﴿ٱلسِّرَّ﴾: هو كلُّ ما يَغِيبُ ويَخْفى."
  25,8,"﴿جَنَّةࣱ﴾: أي: بُسْتانٌ مُثْمِرٌ.﴿مَّسۡحُورًا﴾: مَجْنُونًا، غَلَبَ السِّحرُ على عَقْلِه."
  25,10,"﴿جَنَّـٰتࣲ﴾: بَساتِينَ وحَدائقَ.﴿قُصُورَۢا﴾: بُيُوتًا مُشَيَّدةً."
  25,11,"﴿وَأَعۡتَدۡنَا﴾: وجَعَلْناه مُعَدًّا لهم.﴿سَعِيرًا﴾: أي: نارًا مُشْتَعِلةً تُسَعَّر بهم."
  25,12,"﴿تَغَيُّظࣰا﴾: صَوْتَ غَلَيانٍ وفَوَرانٍ.﴿وَزَفِيرࣰا﴾: النَّفَسَ الخارِجَ مِنَ الجَوفِ بِشِدَّةٍ."
  25,13,"﴿مِنۡهَا﴾: أي: مِن جَهَنَّمَ.﴿مُّقَرَّنِينَ﴾: مُقَيَّدةً أيدِيهِم إلى أعْناقِهِم.﴿ثُبُورࣰا﴾: هَلاكًا."
  25,15,"﴿وَمَصِيرࣰا﴾: ومَرْجِعًا."
  25,16,"﴿مَّسۡـُٔولࣰا﴾: أي: يَسْأَلُ اللهَ عِبادُه المتَّقُونَ"
  25,18,"﴿سُبۡحَـٰنَكَ﴾: تَنْزِيهًا لَكَ يا رَبَّنا.﴿مَا كَانَ يَنۢبَغِي لَنَآ﴾: ما كان يَحِقُّ ولا يَصِحُّ لَنا.﴿أَوۡلِيَآءَ﴾: المُرادُ به: آلهةٌ نَعْبُدُهُم.﴿نَسُواْ ٱلذِّكۡرَ﴾: غَفَلُوا عَن دَلائِلِ الوَحْدانيَّةِ.﴿بُورࣰا﴾: هالِكِينَ أو فاسِدِين."
  25,19,"﴿صَرۡفࣰا﴾: دَفْعًا.﴿يَظۡلِم﴾: أي: يُشْرِكْ بِاللهِ."
  25,20,"﴿فِتۡنَةً﴾: ابْتِلاءً واخْتِبارًا."
  25,21,"﴿لَا يَرۡجُونَ﴾: لا يخافُونَ.﴿أَوۡ نَرَىٰ﴾: أي: عِيانًا.﴿ٱسۡتَكۡبَرُواْ فِيٓ أَنفُسِهِمۡ﴾: أضْمَرُوا الاسْتِكْبارَ عَنِ الحَقِّ في قُلُوبِهِم.﴿وَعَتَوۡ﴾: تَجاوَزُوا الحدَّ في الطُّغيانِ."
  25,22,"﴿حِجۡرࣰا مَّحۡجُورࣰا﴾: حَرامًا محرَّمًا عَلَيكُمُ الجنَّةُ."
  25,23,"﴿هَبَآءࣰ﴾: أي: كالهباءِ وهو ما يُرى في ضَوءِ الشَّمسِ مِن دقِيقِ الغُبارِ.﴿مَّنثُورًا﴾: مُفَرَّقًا."
  25,24,"﴿مَقِيلࣰا﴾: مَكانًا للرّاحَةِ وقتَ القَيْلُولَةِ."
  25,25,"﴿تَشَقَّقُ ٱلسَّمَآءُ﴾: تَتَفَتَّحُ السَّمَواتُ.﴿بِٱلۡغَمَـٰمِ﴾: بالسَّحابِ الأبيضِ الرَّقِيقِ."
  25,26,"﴿عَسِيرࣰا﴾: صَعْبًا شَدِيدًا."
  25,27,"﴿يَعَضُّ ٱلظَّالِمُ عَلَىٰ يَدَيۡهِ﴾: أي: تَحَسُّرًا."
  25,28,"﴿خَلِيلࣰا﴾: صَدِيقًا."
  25,29,"﴿ٱلذِّكۡرِ﴾: أي: القرآنِ والإيمانِ به.﴿خَذُولࣰا﴾: كثيرَ الخِذْلانِ لِمَن يُوالِيهِ، والخِذْلانُ: التَّخَلِّي عَنِ النُّصْرَةِ."
  25,30,"﴿مَهۡجُورࣰا﴾: مَتْرُوكًا، تُرِكَ الإيمانُ به والعَمَلُ بِما فِيه."
  25,31,"﴿ٱلۡمُجۡرِمِينَ﴾: أي: الكافِرِينَ والمُشْرِكِينَ."
  25,32,"﴿لَوۡلَا﴾: هَلّا.﴿جُمۡلَةࣰ وَ ٰ⁠حِدَةࣰ﴾: أي: دُفْعةً واحِدَةً.﴿لِنُثَبِّتَ بِهِۦ فُؤَادَكَ﴾: لنُقَوِّيَ به قَلْبَكَ.﴿وَرَتَّلۡنَـٰهُ تَرۡتِيلࣰا﴾: أي: أنْزَلْناه وفرَّقْناه آيةً بعْدَ آيةٍ."
  25,33,"﴿بِمَثَلٍ﴾: بِحُجَّةٍ أو شُبْهَةٍ."
  25,35,"﴿وَزِيرࣰا﴾: مُعِينًا لِتَبْلِيغِ الرِّسالةِ."
  25,36,"﴿فَدَمَّرۡنَـٰهُمۡ﴾: فَأَهْلَكْناهُم."
  25,37,"﴿ءَايَةࣰ﴾: عِبْرةً.﴿وَأَعۡتَدۡنَا﴾: هَيَّأنا."
  25,38,"﴿وَأَصۡحَـٰبَ ٱلرَّسِّ﴾: أصْحابَ البِئْرِ.﴿وَقُرُونَۢا﴾: وأُمَمًا."
  25,39,"﴿ضَرَبۡنَا لَهُ ٱلۡأَمۡثَـٰلَ﴾: بَيَّنّا لجَمِيعِ الأمَمِ الحُجَجَ، وأَزَلْنا عَنْهم الشَّبُهاتِ.﴿تَبَّرۡنَا﴾: أهْلَكْنا."
  25,40,"﴿ٱلۡقَرۡيَةِ﴾: هي «سَدُومُ» قَرْيَةُ قَومِ لُوطٍ.﴿مَطَرَ ٱلسَّوۡءِ﴾: أي: بالحِجارةِ مِنَ السَّماءِ.﴿لَا يَرۡجُونَ نُشُورࣰا﴾: لا يتَوَقَّعُونَ بَعْثًا بَعْدَ الموتِ."
  25,41,"﴿هُزُوًا﴾: مُسْتَهْزَأً بِه."
  25,42,"﴿إِن كَادَ﴾: إنّه قارَبَ."
  25,43,"﴿وَكِيلًا﴾: حَفِيظًا يَحْفَظُه مِنِ اتِّباعِ هَواهُ."
  25,44,"﴿كَٱلۡأَنۡعَـٰمِ﴾: كالبَهائِمِ لا يَفْهَمُونَ."
  25,45,"﴿مَدَّ ٱلظِّلَّ﴾: بَسَطَه مِن طُلُوعِ الفَجْرِ إلى طُلُوعِ الشَّمسِ.﴿سَاكِنࣰا﴾: ثابِتًا، لا تُزِيلُهُ الشَّمْسُ.﴿دَلِيلࣰا﴾: أي: يُسْتَدَلُّ بأحْوالِ الشَّمسِ على أحْوالِ الظِّلِّ."
  25,46,"﴿قَبۡضࣰا يَسِيرࣰا﴾: أي: يَتَقَلَّصُ الظِّلُّ تَدْرِيجيًّا بِقَدْرِ ارْتِفاعِ الشَّمسِ."
  25,47,"﴿لِبَاسࣰا﴾: ساتِرًا بِظَلامِهِ.﴿سُبَاتࣰا﴾: راحَةً لَكُم.﴿نُشُورࣰا﴾: تَنْتَشِرُونَ فِيهِ لمَعاشِكُم."
  25,49,"﴿أَنۡعَـٰمࣰا﴾: بَهائِمَ.﴿وَأَنَاسِيَّ﴾: أُناسًا."
  25,50,"﴿صَرَّفۡنَـٰهُ بَيۡنَهُمۡ﴾: أنْزَلْنا المَطَرَ على أنْحاءٍ مُخْتَلِفَةٍ.﴿كُفُورࣰا﴾: جُحُودًا بالنِّعمَةِ."
  25,52,"﴿وَجَـٰهِدۡهُم بِهِۦ﴾: وجاهِدِ الكُفّارَ بالقُرآنِ والبُرْهانِ."
  25,53,"﴿مَرَجَ﴾: خَلَطَ وأرْسَلَ.﴿عَذۡبࣱ فُرَاتࣱ﴾: حُلْوٌ شَدِيدُ الحَلاوَةِ.﴿أُجَاجࣱ﴾: شَدِيدُ المُلُوحَةِ.﴿بَيۡنَهُمَا بَرۡزَخࣰا﴾: حاجِزًا بين البَحْرَينِ يَمْنَعُ اخْتِلاطَ أحَدِهِما بالآخَر.﴿وَحِجۡرࣰا مَّحۡجُورࣰا﴾: أي: مانِعًا حَصِينًا."
  25,54,"﴿ٱلۡمَآءِ﴾: هو مَنِيُّ الرَّجلِ والمرْأةِ.﴿وَصِهۡرࣰا﴾: القَرابَةَ النّاشِئَةَ مِنَ الزَّواجِ بَيْنَ الزَّوْجِ وأهْلِ زَوْجتِهِ."
  25,55,"﴿عَلَىٰ رَبِّهِۦ ظَهِيرࣰا﴾: مُعِينًا للشَّيطانِ على رَبِّه."
  25,57,"25:56"
  25,58,"25:56"
  25,59,"﴿ثُمَّ ٱسۡتَوَىٰ﴾: أي: عَلا وارْتَفَعَ كَما يَلِيقُ بِجَلالِهِ.﴿ٱلۡعَرۡشِ﴾: هو سريرُ المُلْكِ الَّذِي اسْتَوى عليه الرَّحْمَنُ وتَحْمِلُهُ الملائِكةُ، وهو أعْظَمُ المخْلُوقاتِ، وهو سَقْفُ الجنَّةِ."
  25,60,"﴿نُفُورࣰا﴾: تَباعُدًا عَنِ الإيمانِ."
  25,61,"﴿تَبَارَكَ﴾: تَكاثَرَ خَيْرُه وعَظُمَتْ بَرَكاتُه.﴿بُرُوجࣰا﴾: مَنازِلَ للكَواكِبِ والنُّجُومِ.﴿سِرَ ٰ⁠جࣰا﴾: شَمْسًا تُضِيءُ."
  25,62,"﴿خِلۡفَةࣰ﴾: يَخْلُفُ أحدُهما الآخَرَ فَيَتَعاقَبانِ.﴿أَن يَذَّكَّرَ﴾: أن يَعْتَبرَ."
  25,63,"﴿هَوۡنࣰا﴾: أي: بسَكِينَةٍ وتَواضُعٍ.﴿قَالُواْ سَلَـٰمࣰا﴾: أي: قالُوا قَوْلًا سَدِيدًا يَسْلَمُونَ بهِ مِنَ الأذى."
  25,64,"﴿يَبِيتُونَ﴾: يَقْضُونَ لَيالِيَهُم."
  25,65,"﴿ٱصۡرِفۡ﴾: ادْفَعْ.﴿غَرَامًا﴾: لِزامًا، يُلازِمُ صاحِبَهُ."
  25,67,"﴿لَمۡ يُسۡرِفُواْ﴾: لم يَتَجاوَزُوا حَدَّ الاعْتِدالِ.﴿وَلَمۡ يَقۡتُرُواْ﴾: ولم يُضَيِّقوا في الإنْفِاقِ.﴿قَوَامࣰا﴾: وسَطًا بَيْنَ التَّبذِيرِ والتَّضْيِيقِ."
  25,68,"﴿لَا يَدۡعُونَ﴾: لا يَعْبُدُونَ.﴿أَثَامࣰا﴾: عِقابًا."
  25,69,"﴿وَيَخۡلُدۡ فِيهِۦ﴾: ويَبْقى فيه على الدَّوامِ.﴿مُهَانًا﴾: ذلِيلًا حَقِيرًا."
  25,71,"﴿مَتَابࣰا﴾: توبةً."
  25,72,"﴿ٱلزُّورَ﴾: شَهادَةً كاذِبَةً.﴿بِٱللَّغۡوِ﴾: بِكُلِّ ساقِطٍ مِن قَوْلٍ أو فِعْلٍ.﴿مَرُّواْ كِرَامࣰا﴾: مُكْرِمِينَ أنْفُسَهُم بالإعْراضِ عَنْهُ."
  25,73,"﴿لَمۡ يَخِرُّواْ﴾: لم يَسْقُطُوا ولَمْ يَقَعُوا.﴿صُمࣰّا وَعُمۡيَانࣰا﴾: أي: لا يَسْمَعُونَ ولا يُبْصِرُونَ، والمعنى إنّما يَخِرُّونَ عَلَيها سامِعِينَ مُبْصِرِينَ مُنْتَفِعِينَ."
  25,74,"﴿قُرَّةَ أَعۡيُنࣲ﴾: مَوْضِعَ سُرورٍ وفَرَحٍ."
  25,75,"﴿ٱلۡغُرۡفَةَ﴾: المرادُ منها أعلى مَنازِلِ الجنَّةِ وأَفْضَلُها."
  25,77,"﴿مَا يَعۡبَؤُاْ بِكُمۡ﴾: لا يُبالي بكُم.﴿لِزَامَۢا﴾: أي: عَذابًا داِئمًا مُلازِمًا لَكُم."
