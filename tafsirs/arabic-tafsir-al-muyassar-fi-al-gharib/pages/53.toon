tafsir[53]{c,v,t}:
  53,1,"﴿هَوَىٰ﴾: غابَ."
  53,2,"﴿غَوَىٰ﴾: خَرَجَ عنِ الرَّشادِ."
  53,3,"﴿ٱلۡهَوَىٰٓ﴾: ما تَمِيلُ إلَيهِ النَّفْسُ مِن غَيرِ دَلِيلٍ."
  53,5,"﴿شَدِيدُ ٱلۡقُوَىٰ﴾: مَلَكٌ شَدِيدُ القُوَّةِ."
  53,6,"﴿مِرَّةࣲ﴾: مَنظَرٍ حَسَنٍ.﴿فَٱسۡتَوَىٰ﴾: عَلى صُورَتِهِ الحقِيقِيَّةِ للرَّسولِ ﷺ."
  53,7,"﴿بِٱلۡأُفُقِ ٱلۡأَعۡلَىٰ﴾: أُفُقِ الشَّمسِ عِنْدَ مَطْلَعِها."
  53,8,"﴿فَتَدَلَّىٰ﴾: فَزادَ في القُرْبِ."
  53,9,"﴿قَابَ قَوۡسَيۡنِ﴾: مِقْدارَ قَوسَينِ."
  53,11,"﴿ٱلۡفُؤَادُ﴾: قَلْبُه."
  53,12,"﴿أَفَتُمَـٰرُونَهُۥ﴾: أتُكَذِّبُونَ مُحَمَّدًا ﷺ فَتُجادِلُونَه عَلى ما يَراهُ مِن آياتِ رَبِّهِ؟"
  53,13,"﴿رَءَاهُ﴾: رَأى مُحَمّدٌ ﷺ جِبْرِيلَ.﴿نَزۡلَةً﴾: مَرَّةً."
  53,14,"﴿سِدۡرَةِ ٱلۡمُنتَهَىٰ﴾: شَجَرةِ نَبْقٍ في السَّماءِ السّابِعةِ، يَنْتَهي إلَيها ما يُعْرَجُ بِهِ مِنَ الأَرْضِ، وما يُهْبَطُ بِه مِن فَوْقِها."
  53,16,"﴿يَغۡشَى ٱلسِّدۡرَةَ﴾: يُغَطِّيها ويَسْتُرُها."
  53,17,"﴿زَاغَ﴾: مالَ.﴿طَغَىٰ﴾: جاوَزَ ما أُمِرَ برُؤْيَتِهِ."
  53,18,"﴿ءَايَـٰتِ﴾: دَلائلِ عَظَمةِ اللهِ."
  53,19,"﴿ٱللَّـٰتَ وَٱلۡعُزَّىٰ ۞ وَمَنَوٰةَ﴾: هي أصْنامٌ اتَّخَذَها العَربُ آلِهَةً.﴿ٱلثَّالِثَةَ ٱلۡأُخۡرَىٰٓ﴾: صِفَتا تأكيدٍ لمناةٍ."
  53,20,"53:19"
  53,22,"﴿ضِيزَىٰٓ﴾: جائِرةٌ."
  53,23,"﴿سُلۡطَـٰنٍ﴾: حُجَّةٍ.﴿تَهۡوَى﴾: تَشْتَهِيهِ وتَمِيلُ إلَيهِ."
  53,24,"﴿تَمَنَّىٰ﴾: اشْتَهى."
  53,26,"﴿وَكَم مِّن مَّلَكࣲ﴾: وكَثِيرٍ مِنَ الملائِكَةِ."
  53,27,"﴿تَسۡمِيَةَ ٱلۡأُنثَىٰ﴾: صِفَةَ الأُنْثى، وهي أن يُقالَ لَها: بِنْتٌ."
  53,28,"﴿ٱلظَّنَّ﴾: التَّوهُّمَ الباطِلَ.﴿لَا يُغۡنِي﴾: لا يُجدِي ولا يَقُومُ مَقامَ الحَقِّ."
  53,30,"﴿مَبۡلَغُهُم مِّنَ ٱلۡعِلۡمِ﴾: مُنْتَهى عِلْمِهِم، لا عِلْمَ لَهُم فَوْقَهُ؛ والمرادُ ظَنُّهُم الفاسِدُ."
  53,31,"﴿بِٱلۡحُسۡنَى﴾: بالجنَّةِ."
  53,32,"﴿ٱللَّمَمَ﴾: الذُّنُوبَ الصِّغارَ الَّتِي لا يُصِرُّ صاحِبُها عَلَيها، أو يُلِمُّ بِها على وجْهِ النُّدْرَةِ.﴿أَنشَأَكُم مِّنَ ٱلۡأَرۡضِ﴾: خَلَقَ أباكُم آدمَ مِن تُرابٍ.﴿فَلَا تُزَكُّوٓاْ أَنفُسَكُمۡ﴾: فَتَمْدَحُوها بالتَّقْوى."
  53,33,"﴿تَوَلَّىٰ﴾: أعْرَضَ عَن طاعَةِ اللهِ."
  53,34,"﴿وَأَكۡدَىٰٓ﴾: تَوَقَّفَ عَنِ العَطاءِ."
  53,36,"﴿صُحُفِ مُوسَىٰ﴾: هي أسْفارُ التَّوراةِ."
  53,37,"﴿وَإِبۡرَ ٰ⁠هِيمَ﴾: وصُحُفِ إبراهِيمَ التي سُجِّل فيها ما أوْحى اللهُ إليهِ.﴿وَفَّىٰٓ﴾: بَلَّغَ ما أُرْسِلَ بِه."
  53,38,"﴿أَلَّا تَزِرُ﴾: أي لا تَحْمِلُ ولا تُؤاخَذُ.﴿وَازِرَةࣱ﴾: حاملةُ إثْمٍ."
  53,39,"﴿لَّيۡسَ لِلۡإِنسَـٰنِ إِلَّا مَا سَعَىٰ﴾: لا يَحْصُلُ للإنسانِ مِنَ الأجْرِ إلّا ما كَسَبَ هُوَ لِنَفْسِهِ بِسَعْيِهِ."
  53,40,"﴿سَعۡيَهُۥ﴾: عَمَلَه واكْتِسابَه.﴿يُرَىٰ﴾: يُشاهَدُ عِنْدَ الحسابِ."
  53,41,"﴿يُجۡزَىٰهُ﴾: يُجزى الإنسانُ عَلى سَعْيِهِ.﴿ٱلۡأَوۡفَىٰ﴾: التامَّ الكامِلَ."
  53,42,"﴿ٱلۡمُنتَهَىٰ﴾: انْتِهاءَ جَمِيعِ خَلْقِهِ ورُجُوعَهُم إلى حُكْمِهِ في الآخِرةِ."
  53,43,"﴿أَضۡحَكَ وَأَبۡكَىٰ﴾: خَلَقَ في الإنْسانِ قُوَّتَي الضَّحِكِ والبُكاءِ وأَسْبابَهُما مِن سُرورٍ وحُزْنٍ."
  53,44,"﴿أَمَاتَ وَأَحۡيَا﴾: انْفَرَدَ بالإماتَةِ والإحْياءِ."
  53,46,"﴿نُّطۡفَةٍ﴾: ماءٍ قَلِيلٍ.﴿تُمۡنَىٰ﴾: تُصَبُّ في الرَّحِمِ وتُقْذَفُ."
  53,47,"﴿ٱلنَّشۡأَةَ﴾: الخَلقَ.﴿ٱلۡأُخۡرَىٰ﴾: الأخِيَرةَ الَّتِي لا نَشْأَةَ بَعْدَها."
  53,48,"﴿وَأَقۡنَىٰ﴾: أرضى الَّذِي أغْناهُ."
  53,49,"﴿ٱلشِّعۡرَىٰ﴾: نَجْمٍ مُضِيءٍ كانَ يَعْبُدُهُ بَعْضُ أهْل الجاهِلِيَّةِ."
  53,50,"﴿عَادًا ٱلۡأُولَىٰ﴾: قَوْمَ نَبِيِّ اللهِ هُودٍ عَلَيهِ السَّلامُ، وهي أوَّلُ العرَبِ البائِدةِ."
  53,51,"﴿وَثَمُودَاْ﴾: قَوْمَ نَبِيِّ اللهِ صالِحٍ عَلَيهِ السَّلامُ.﴿فَمَآ أَبۡقَىٰ﴾: فَما تَرَكَها بَلْ أهْلَكَها."
  53,52,"﴿وَأَطۡغَىٰ﴾: أشَدَّ طَغْيانًا وتَمَرُّدًا على اللهِ."
  53,53,"﴿وَٱلۡمُؤۡتَفِكَةَ﴾: هي القُرى المَخْسُوفُ بِها، المقلوبُ أعلاها أسفلها، وهي قُرى قَوْمِ لُوطٍ عَلَيهِ السَّلامُ.﴿أَهۡوَىٰ﴾: أسْقَطَ، فَجَعَلَها هاوِيَةً."
  53,54,"﴿فَغَشَّىٰهَا مَا غَشَّىٰ﴾: فَأَلْبَسَها ما ألْبَسَها مِنَ الحِجارَةِ المُتَتابِعَةِ النّازِلَةِ عَلَيهِم."
  53,55,"﴿ءَالَآءِ﴾: نِعَمِ، جَمْعُ إلىً.﴿تَتَمَارَىٰ﴾: تَتَشَكَّكُ."
  53,56,"﴿هَـٰذَا﴾: الَّذِي أنْذَرْتُكُم بِهِ مِنَ الوقائِعِ.﴿نَذِيرࣱ﴾: إنْذارٌ.﴿مِّنَ ٱلنُّذُرِ ٱلۡأُولَىٰٓ﴾: الَّتي أنْذَرْتُها الأُمَمَ الَّتي قَبْلَكُم."
  53,57,"﴿أَزِفَتِ﴾: قَرُبَتْ.﴿ٱلۡـَٔازِفَةُ﴾: القِيامَةُ."
  53,58,"﴿لَيۡسَ لَهَا مِن دُونِ ٱللَّهِ كَاشِفَةٌ﴾: لا يَعْلَمُ بوَقْتِ وُقُوعِها إلّا اللهُ."
  53,59,"﴿هَـٰذَا ٱلۡحَدِيثِ﴾: القرآنِ.﴿تَعۡجَبُونَ﴾: مِن أن يَكُونَ صَحِيحًا."
  53,60,"﴿وَتَضۡحَكُونَ﴾: مِنهُ سُخْرِيَةً واسْتِهْزاءً.﴿وَلَا تَبۡكُونَ﴾: خَوْفًا مِن وعِيدِهِ."
  53,61,"﴿سَـٰمِدُونَ﴾: لاهُونَ مُعْرِضُونَ عَنْهُ."
