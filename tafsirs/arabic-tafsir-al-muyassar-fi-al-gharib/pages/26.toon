tafsir[176]{c,v,t}:
  26,2,"﴿ٱلۡكِتَـٰبِ﴾: القرآنِ."
  26,3,"﴿بَـٰخِعࣱ نَّفۡسَكَ﴾: مُهْلِكُها غَمًّا وحُزْنًا."
  26,4,"﴿ءَايَةࣰ﴾: مُعْجِزَةً.﴿خَـٰضِعِينَ﴾: مُنْقادِينَ بالكُرْهِ مِنهُم."
  26,5,"﴿مُحۡدَثٍ﴾: أي: مُجَدَّدٍ إنْزالُه."
  26,7,"﴿أَوَ لَمۡ يَرَوۡاْ﴾: أوَلَم يَنْظُرُوا.﴿زَوۡجࣲ كَرِيمٍ﴾: صِنْفٍ حَسَنٍ كَثِيرِ النَّفْعِ."
  26,8,"﴿لَـَٔايَةࣰ﴾: لَدَلالةً واضِحَةً."
  26,10,"26:9"
  26,11,"﴿أَلَا يَتَّقُونَ﴾: ألا يَخافُونَ عِقابَ اللهِ تعالى؟"
  26,13,"26:12"
  26,14,"﴿ذَنۢبࣱ﴾: وهو قَتْلُ القِبْطِيِّ."
  26,15,"﴿بِـَٔايَـٰتِنَآ﴾: بِمُعْجزاتِنا وحُجَجِنا.﴿إِنَّا مَعَكُم﴾: أي: بالعِلْمِ والحِفْظِ والنُّصْرَةِ."
  26,17,"26:16"
  26,18,"﴿أَلَمۡ نُرَبِّكَ﴾: ألم نَرْعَكَ.﴿وَلِيدࣰا﴾: صَغِيرًا."
  26,19,"﴿فَعۡلَتَكَ﴾: أي: قَتْلَ القِبْطِيِّ.﴿مِنَ ٱلۡكَـٰفِرِينَ﴾: أي: من الجاحِدِينَ لِنِعْمَتِي."
  26,20,"﴿مِنَ ٱلضَّآلِّينَ﴾: مِنَ المُخْطِئِينَ لا المتعَمِّدِينَ."
  26,21,"﴿حُكۡمࣰا﴾: أي: نُبُوَّةً وحِكْمَةً."
  26,22,"﴿تَمُنُّهَا عَلَيَّ﴾: تَعُدُّها نِعْمَةً مِنكَ عليّ.﴿عَبَّدتَّ﴾: جَعَلْتَهُم عَبِيدًا تَذْبَحُ مَن تَشاءُ وتَتْرُكُ مَن تَشاءُ مِن أبْنائِهِم وتَسْتَبْقِي نِساءَهُم لِلْخِدْمَةِ والامْتِهانِ."
  26,24,"26:23"
  26,25,"26:23"
  26,26,"26:23"
  26,27,"26:23"
  26,28,"26:23"
  26,29,"26:23"
  26,30,"﴿بِشَيۡءࣲ مُّبِينࣲ﴾: أي: بِبُرْهانٍ قاطِعٍ."
  26,32,"26:31"
  26,33,"﴿بَيۡضَآءُ﴾: أي: مِن غَيرِ مَرَضٍ ولا بَرَصٍ."
  26,34,"﴿لِلۡمَلَإِ﴾: لأشْرافِ قَوْمِهِ.﴿لَسَـٰحِرٌ عَلِيمࣱ﴾: أي: ساحِرٌ ماهِرٌ."
  26,36,"﴿أَرۡجِهۡ﴾: أخِّرْهُ.﴿ٱلۡمَدَآئِنِ﴾: المُدُنِ.﴿حَـٰشِرِينَ﴾: جامِعِينَ للسَّحَرةِ."
  26,38,"26:37"
  26,39,"26:37"
  26,40,"26:37"
  26,41,"26:37"
  26,42,"26:37"
  26,43,"26:37"
  26,44,"26:37"
  26,45,"﴿تَلۡقَفُ﴾: تَبْتَلِعُ بِسُرْعَةٍ.﴿مَا يَأۡفِكُونَ﴾: ما يَكْذِبُونَهُ ويُمَوِّهُونَهُ."
  26,47,"26:46"
  26,48,"26:46"
  26,49,"﴿مِّنۡ خِلَـٰفࣲ﴾: أي: بِقَطْعِ اليَدِ اليُمْنى والرِّجْلِ اليُسْرى أو عَكْسِ ذَلِك.﴿وَلَأُصَلِّبَنَّكُمۡ﴾: ولَأُبالِغَنَّ في شَدِّ أطْرافِكُم ورَبْطِ أجْسادِكُم على جُذُوعِ النَّخْلِ."
  26,50,"﴿لَا ضَيۡرَ﴾: لا ضَرَرَ عَلَينا فِيما يُصِيبُنا.﴿مُنقَلِبُونَ﴾: راجِعُونَ."
  26,51,"﴿أَوَّلَ ٱلۡمُؤۡمِنِينَ﴾: أي: مِن قَومِ فِرْعَونَ."
  26,52,"﴿أَنۡ أَسۡرِ بِعِبَادِيٓ﴾: أي: اخْرُجْ بِهِم لَيْلًا.﴿مُّتَّبَعُونَ﴾: يَتَّبِعُكُم فِرْعَونُ وجُنُودُه."
  26,53,"﴿ٱلۡمَدَآئِنِ﴾: المُدُنِ.﴿حَـٰشِرِينَ﴾: جامِعِينَ لِلْجَيشِ."
  26,54,"﴿لَشِرۡذِمَةࣱ﴾: لَطائِفَةٌ حَقِيرَةٌ قَلِيلةُ العَدَدِ."
  26,55,"﴿لَنَا لَغَآئِظُونَ﴾: لَمُغْضِبُونا بِخُرُوجِهِم مِن غَيْرِ إذْنٍ مِنّا."
  26,56,"﴿حَـٰذِرُونَ﴾: مُتَيَقِّظُونَ."
  26,57,"﴿جَنَّـٰتࣲ﴾: بَساتِينَ."
  26,59,"26:58"
  26,60,"﴿مُّشۡرِقِينَ﴾: وقْتَ شُرُوقِ الشَّمْسِ."
  26,61,"﴿ٱلۡجَمۡعَانِ﴾: جَمْعُ مُوسى وهُم بنُو إسْرائيلَ، وجَمْعُ فِرْعَونَ وهم القِبْطُ.﴿لَمُدۡرَكُونَ﴾: لَمُلحَقُون من قِبَلِ فِرْعَونَ وجُنُودِهِ."
  26,63,"﴿فَٱنفَلَقَ﴾: أي: انْشَقَّ البَحْرُ إلى اثْنَي عَشْرَ طَرِيقًا.﴿فِرۡقࣲ﴾: قِطْعةٍ من البحْرِ مُرْتَفِعَةٍ.﴿كَٱلطَّوۡدِ﴾: كالجَبَلِ المُتَطاوِلِ في السَّماءِ."
  26,64,"﴿وَأَزۡلَفۡنَا﴾: وقَرَّبْنا.﴿ثَمَّ﴾: هُناك.﴿ٱلۡـَٔاخَرِينَ﴾: وهم فِرْعَونُ وقَوْمُه."
  26,66,"26:65"
  26,67,"﴿لَـَٔايَةࣰ﴾: لَعِبرةً عَجِيبةً."
  26,69,"26:68"
  26,70,"26:68"
  26,71,"﴿لَهَا عَـٰكِفِينَ﴾: على عِبادتِها مُقِيمِينَ على الدَّوامِ."
  26,73,"26:72"
  26,74,"26:72"
  26,75,"﴿أَفَرَءَيۡتُم﴾: هَل تأمَّلْتُم ما أنْتُم عَلَيه؟"
  26,77,"26:76"
  26,78,"26:76"
  26,79,"26:76"
  26,80,"26:76"
  26,81,"26:76"
  26,82,"﴿يَوۡمَ ٱلدِّينِ﴾: يومَ الجَزاءِ."
  26,83,"﴿حُكۡمࣰا﴾: عِلْمًا وفَهْمًا."
  26,84,"﴿لِسَانَ صِدۡقࣲ﴾: ثَناءً حَسَنًا.﴿فِي ٱلۡـَٔاخِرِينَ﴾: أي: في الَّذينَ يأتُونَ بَعْدِي إلى يومِ القِيامَةِ."
  26,86,"26:85"
  26,87,"﴿وَلَا تُخۡزِنِي﴾: ولا تَفْضَحْنِي."
  26,89,"﴿بِقَلۡبࣲ سَلِيمࣲ﴾: أي: مِنَ النِّفاقِ والكُفْرِ."
  26,90,"﴿وَأُزۡلِفَتِ﴾: قُرِّبَتْ."
  26,91,"﴿وَبُرِّزَتِ﴾: أُظْهِرَتْ.﴿لِلۡغَاوِينَ﴾: للضّالِينَ عَن طَرِيقِ الهِدايةِ."
  26,93,"26:92"
  26,94,"﴿فَكُبۡكِبُواْ فِيهَا﴾: أُلْقُوا في جَهَنَّمَ على وُجُوهِهِم مرَّةً بَعْدَ مَرَّةٍ إلى أنِ اسْتَقرُّوا في قَعْرِها."
  26,96,"﴿يَخۡتَصِمُونَ﴾: يَتَنازَعُون."
  26,97,"﴿إِن كُنَّا﴾: إنَّنا كُنّا."
  26,98,"﴿نُسَوِّيكُم بِرَبِّ ٱلۡعَـٰلَمِينَ﴾: نَجْعَلُكُم مِثْلَ رَبِّ العالَمِينَ."
  26,100,"﴿شَـٰفِعِينَ﴾: فَيُخَلِّصُونا مِنَ العَذابِ."
  26,101,"﴿حَمِيمࣲ﴾: قَرِيبٍ ومُشْفِقٍ."
  26,102,"﴿كَرَّةࣰ﴾: رَجْعَةً إلى الدُّنيا."
  26,104,"26:103"
  26,105,"26:103"
  26,106,"26:103"
  26,107,"26:103"
  26,108,"26:103"
  26,109,"26:103"
  26,110,"26:103"
  26,111,"﴿ٱلۡأَرۡذَلُونَ﴾: أي: أسافلُ النّاسِ وأَراذِلُهم."
  26,113,"26:112"
  26,114,"26:112"
  26,115,"26:112"
  26,116,"﴿ٱلۡمَرۡجُومِينَ﴾: مِنَ المقْتُولِينَ رَمْيًا بالحِجارَةِ."
  26,118,"﴿فَٱفۡتَحۡ﴾: فاحْكُمْ."
  26,119,"﴿ٱلۡمَشۡحُونِ﴾: المَمْلُوءِ بالنّاسِ والدَّوابِّ والمتاعِ."
  26,121,"26:120"
  26,122,"26:120"
  26,123,"26:120"
  26,124,"26:120"
  26,125,"26:120"
  26,126,"26:120"
  26,127,"26:120"
  26,128,"﴿رِيعٍ﴾: مكانٍ مُرْتَفِعٍ.﴿ءَايَةࣰ﴾: بِناءً شامِخًا."
  26,129,"﴿مَصَانِعَ﴾: حُصُونًا أو قُصُورًا.﴿تَخۡلُدُونَ﴾: أي: تَبْقَونَ في الدُّنيا ولا تَمُوتُونَ."
  26,130,"﴿بَطَشۡتُم﴾: أخَذْتُم بِعُنْفٍ.﴿جَبَّارِينَ﴾: قاهِرِينَ ظالِمِين."
  26,132,"﴿أَمَدَّكُم﴾: أنْعَمَ عليكُم وأَعْطاكُم."
  26,133,"﴿بِأَنۡعَـٰمࣲ﴾: مِنَ الإبِلِ والبَقَرِ والغَنَمِ."
  26,134,"﴿وَجَنَّـٰتࣲ﴾: حَدائِقَ وبَساتِينَ."
  26,136,"26:135"
  26,137,"﴿إِنۡ هَـٰذَآ﴾: ما هَذا.﴿خُلُقُ ٱلۡأَوَّلِينَ﴾: دِينُ الأوَّلِينَ وعاداتُهُم."
  26,139,"26:138"
  26,140,"26:138"
  26,141,"26:138"
  26,142,"26:138"
  26,143,"26:138"
  26,144,"26:138"
  26,145,"26:138"
  26,146,"﴿مَا هَـٰهُنَآ﴾: أي: في الدُّنيا."
  26,148,"﴿طَلۡعُهَا﴾: ثَمَرُها.﴿هَضِيمࣱ﴾: مُنْكَسِرٌ مِن لِينِهِ ورُطُوبَتِه."
  26,149,"﴿فَـٰرِهِينَ﴾: ماهِرِين بنَحْتِها."
  26,151,"26:150"
  26,152,"26:150"
  26,153,"﴿مِنَ ٱلۡمُسَحَّرِينَ﴾: مِنَ المغْلُوبِ على عُقُولِهِم بِكَثْرَةِ السِّحرِ."
  26,154,"﴿بِـَٔايَةٍ﴾: بِحُجَّةٍ واضِحَةٍ."
  26,155,"﴿لَّهَا شِرۡبࣱ﴾: لها نَصِيبٌ مِنَ الماءِ."
  26,157,"﴿فَعَقَرُوهَا﴾: فَنَحَرُوها."
  26,159,"26:158"
  26,160,"26:158"
  26,161,"26:158"
  26,162,"26:158"
  26,163,"26:158"
  26,164,"26:158"
  26,165,"﴿أَتَأۡتُونَ ٱلذُّكۡرَانَ﴾: أتَنْكِحُونَ الرِّجالَ؟"
  26,166,"﴿وَتَذَرُونَ﴾: وتَتْرُكُونَ.﴿عَادُونَ﴾: مُتَجاوِزُونَ ما أباحَهُ اللهُ لَكُم مِنَ الحَلالِ إلى الحَرامِ."
  26,168,"﴿مِّنَ ٱلۡقَالِينَ﴾: مِنَ المُبْغِضِينَ أشَدَّ البُغْضِ."
  26,170,"26:169"
  26,171,"﴿فِي ٱلۡغَـٰبِرِينَ﴾: في الباقِينَ في العذابِ والهلاكِ."
  26,172,"﴿دَمَّرۡنَا﴾: أهْلَكْنا."
  26,174,"26:173"
  26,175,"26:173"
  26,176,"﴿أَصۡحَـٰبُ لۡـَٔيۡكَةِ﴾: أصْحابُ الشَّجَرِ المُلْتَفِّ."
  26,178,"26:177"
  26,179,"26:177"
  26,180,"26:177"
  26,181,"﴿مِنَ ٱلۡمُخۡسِرِينَ﴾: مِنَ النّاقِصِينَ للحُقُوقِ بالتَّطفِيفِ."
  26,182,"﴿بِٱلۡقِسۡطَاسِ﴾: بالميزانِ."
  26,183,"﴿وَلَا تَبۡخَسُواْ﴾: ولا تَنْقُصُوا.﴿وَلَا تَعۡثَوۡاْ﴾: ولا تُفْسِدُوا أشَدَّ الإفْسادِ."
  26,184,"﴿وَٱلۡجِبِلَّةَ ٱلۡأَوَّلِينَ﴾: والخَلائِقَ من الأُمَمِ المتقدِّمةِ."
  26,185,"﴿مِنَ ٱلۡمُسَحَّرِينَ﴾: مِنَ المغلُوبِ على عُقُولِهِم بِكَثْرَةِ السِّحْرِ."
  26,187,"﴿كِسَفࣰا﴾: قِطَعَ عَذابٍ."
  26,189,"﴿يَوۡمِ ٱلظُّلَّةِ﴾: أي: أظَلَّتْهُم سَحابَةٌ، ثُمَّ أمْطَرَتْهُم نارًَا."
  26,191,"26:190"
  26,192,"26:190"
  26,193,"﴿ٱلرُّوحُ ٱلۡأَمِينُ﴾: جِبْرِيلُ عَلَيهِ السَّلامُ."
  26,195,"26:194"
  26,196,"﴿وَإِنَّهُۥ﴾: وإنَّ ذِكْرَ هَذا القُرآنِ.﴿زُبُرِ ٱلۡأَوَّلِينَ﴾: كُتُبِ الرُّسُلِ السّابِقِينَ."
  26,198,"﴿ٱلۡأَعۡجَمِينَ﴾: الَّذِينَ لا يتكَلَّمُونَ باللغةِ العَربيةِ."
  26,200,"﴿سَلَكۡنَـٰهُ﴾: أدْخَلْناه."
  26,202,"﴿بَغۡتَةࣰ﴾: فَجْأَةً."
  26,203,"﴿مُنظَرُونَ﴾: مُمْهَلُون لِنُؤمِنَ."
  26,205,"﴿مَّتَّعۡنَـٰهُمۡ سِنِينَ﴾: أي: طَوَّلْنا لَهُم أعْمارَهُم."
  26,207,"﴿مَآ أَغۡنَىٰ عَنۡهُم﴾: أي: لم يَنْفَعْهُم."
  26,209,"﴿ذِكۡرَىٰ﴾: أي: تَذْكِيرٌ وتَنْبِيهٌ."
  26,211,"﴿وَمَا يَنۢبَغِي لَهُمۡ﴾: ولا يَصِحُّ مِنهُم."
  26,212,"﴿لَمَعۡزُولُونَ﴾: لمحْجُوُبونَ."
  26,214,"﴿عَشِيرَتَكَ﴾: قَبِيلَتَكَ."
  26,215,"﴿وَٱخۡفِضۡ جَنَاحَكَ﴾: ألِنْ جانِبَكَ وتَواضَعْ."
  26,217,"26:216"
  26,218,"26:216"
  26,219,"﴿وَتَقَلُّبَكَ﴾: وتَصرُّفَكَ أو تَقَلُّبَكَ في الرُّكُوعِ والسُّجُودِ والقِيامِ."
  26,221,"26:220"
  26,222,"﴿أَفَّاكٍ﴾: كَذّابٍ.﴿أَثِيمࣲ﴾: كَثِيرِ الآثامِ."
  26,223,"﴿يُلۡقُونَ ٱلسَّمۡعَ﴾: يُلْقُونَ ما سَمِعُوه مِنَ السَّماءِ إلى الكُهّانِ."
  26,224,"﴿ٱلۡغَاوُۥنَ﴾: الضّالُّونَ عَنِ الحقِّ."
  26,225,"﴿كُلِّ وَادࣲ﴾: كلِّ فَنٍّ مِن فُنُونِ الكَذِبِ.﴿يَهِيمُونَ﴾: يخُوضُونَ."
  26,227,"﴿يَنقَلِبُونَ﴾: يَرْجِعُونَ إليهِ."
