tafsir[58]{c,v,t}:
  29,1,"﴿الٓمٓ﴾: سَبَقَ الكَلامُ على مِثْلِه في أوَّلِ سورةِ البَقَرةِ."
  29,2,"﴿لَا يُفۡتَنُونَ﴾: لا يُبتَلَونَ."
  29,4,"﴿أَن يَسۡبِقُونَا﴾: أن يُعْجِزُونا ويَفُوتُونا.﴿سَآءَ﴾: بِئْسَ."
  29,5,"﴿يَرۡجُواْ﴾: يَتَوَقَّعُ ويَطْمَعُ.﴿أَجَلَ ٱللَّهِ﴾: الوَقْتَ المُعَيَّنَ للبَعْثِ والجَزاءِ."
  29,6,"﴿جَـٰهَدَ﴾: أي: الكُفّارَ ونَفْسَه الأَمّارةَ بالسُّوءِ."
  29,7,"﴿لَنُكَفِّرَنَّ﴾: لَنَمْحُوَنَّ.﴿وَلَنَجۡزِيَنَّهُمۡ﴾: لَنُثِيبَنَّهم."
  29,8,"﴿وَوَصَّيۡنَا﴾: أي: أمَرْنا.﴿حُسۡنࣰا﴾: أي: بَرًّا بِهِما وعَطْفًا عَلَيهِما.﴿جَـٰهَدَاكَ﴾: ألْزَماكَ."
  29,10,"﴿فِتۡنَةَ ٱلنَّاسِ﴾: ابتلاءَهم وتَعْذِيبَهُم"
  29,12,"﴿وَلۡنَحۡمِلۡ﴾: ولْنَتَحَمَّلْ."
  29,13,"﴿أَثۡقَالَهُمۡ﴾: أي: أثْقالَ ذُنُوبِهِم العَظِيمَةَ.﴿يَفۡتَرُونَ﴾: يَخْتَلِقُونَ."
  29,14,"﴿فَلَبِثَ﴾: مَكَثَ.﴿ٱلطُّوفَانُ﴾: الماءُ الكَثِيرُ الذي غَمَرهُم مِن جَمِيعِ الجِهاتِ."
  29,15,"﴿ءَايَةࣰ﴾: عِبْرةً عَظِيمةً."
  29,17,"﴿أَوۡثَـٰنࣰا﴾: أصْنامًا.﴿تَخۡلُقُونَ إِفۡكًا﴾: تَفْتَرُونَ كَذِبًا.﴿فَٱبۡتَغُواْ﴾: فالتَمِسُوا."
  29,19,"﴿أَوَ لَمۡ يَرَوۡاْ﴾: أوَلم يَعْلَمُوا.﴿يُبۡدِئُ﴾: يُنشِئُ ابتداءً.﴿يُعِيدُهُۥٓ﴾: يُعِيدُ الخَلْقَ مِن بَعْدِ فَنائِهِ."
  29,20,"﴿يُنشِئُ﴾: يَخلُقُ.﴿ٱلنَّشۡأَةَ ٱلۡـَٔاخِرَةَ﴾: أي: نَشْأَةً ثانيةً عِنْدَ البعْثِ."
  29,21,"﴿تُقۡلَبُونَ﴾: تُرجَعُونَ."
  29,22,"﴿بِمُعۡجِزِينَ﴾: بِسابِقِينَ اللهَ."
  29,23,"﴿بِـَٔايَـٰتِ ٱللَّهِ﴾: أي: بالقرآنِ.﴿وَلِقَآئِهِۦٓ﴾: أي: بالبعثِ بَعْدَ الموتِ."
  29,24,"﴿لَـَٔايَـٰتࣲ﴾: لَأَدِلَّةً واضِحَةً."
  29,25,"﴿أَوۡثَـٰنࣰا﴾: أصْنامًا، أي: اتَّخذتُموها آلِهَةً.﴿مَّوَدَّةَ بَيۡنِكُمۡ﴾: أي: للتَّوادِّ والتَّواصُل بَيْنَكُم لاجْتِماعِكُم على عِبادَتِها.﴿يَكۡفُرُ بَعۡضُكُم بِبَعۡضࣲ﴾: أي: يتبرَّأُ بعضُكُم مِن بَعْضٍ.﴿مَأۡوَىٰكُمُ﴾: مَنزِلُكُم الذي تَأْوُونَ وتَرْجِعُونَ إليهِ."
  29,26,"﴿فَـَٔامَنَ﴾: أي: صَدَّقَ إبراهيمَ عَلَيهِ الصَّلاةُ والسَّلامُ."
  29,27,"﴿وَٱلۡكِتَـٰبَ﴾: أي: الكُتُبَ المنزَّلةَ، مِنَ التَّوراةِ والإنْجِيلِ والزَّبُورِ والقرآنِ.﴿أَجۡرَهُۥ﴾: أي: ثَوابَه."
  29,28,"﴿ٱلۡفَـٰحِشَةَ﴾: هي إتْيانُهم الرِّجالَ في أدْبارِهِم."
  29,29,"﴿ٱلسَّبِيلَ﴾: أي: الطَّريقَ على المارَّةِ والمسافِرِينَ، بأخْذِ أمْوالِهِم، أو قَتْلِهِم، أو إكْراهِهِم على الفاحِشَةِ.﴿فِي نَادِيكُمُ﴾: في مَجْلِسِكُم.﴿ٱلۡمُنكَرَ﴾: وهو كلُّ فِعْلٍ يُنكِره الشَّرْعُ أو العقْلُ كالسُّخْرِيَةِ مِنَ النّاسِ وحَذْفِ المارّةِ."
  29,31,"﴿رُسُلُنَآ﴾: أي: مِنَ الَملائِكَةِ.﴿هَـٰذِهِ ٱلۡقَرۡيَةِ﴾: هي «سَدُومُ» قَرْيَةُ قَوْمِ لُوطٍ."
  29,32,"﴿مِنَ ٱلۡغَـٰبِرِينَ﴾: مِنَ الباقِينَ في العَذابِ والهَلاكِ."
  29,33,"﴿سِيٓءَ بِهِمۡ﴾: اعْتَراهُ الغَمُّ بِمَجِيئِهِم خَوْفًا عَليهِم مِن قَومِهِ.﴿وَضَاقَ بِهِمۡذَرۡعࣰا﴾: أي: عَجَزَ عَن تَدْبِيرِ خَلاصِهِم."
  29,34,"﴿رِجۡزࣰا﴾: عَذابًا شَدِيدًا."
  29,35,"﴿مِنۡهَآ﴾: أي: مِن دِيارِ قَومِ لُوطٍ.﴿ءَايَةَۢ بَيِّنَةࣰ﴾: أي: آثارًا واضِحةً."
  29,36,"﴿وَٱرۡجُواْ﴾: تَوَقّعُوا، أوِ اخْشَوا.﴿وَلَا تَعۡثَوۡاْ﴾: لا تُفْسدُوا أشدَّ الفَسادِ."
  29,37,"﴿ٱلرَّجۡفَةُ﴾: الزَّلْزَلةُ الشَّدِيدَةُ.﴿جَـٰثِمِينَ﴾: مَيِّتِينَ بارِكِينَ على رُكَبِهِم."
  29,38,"﴿فَصَدَّهُمۡ﴾: فصَرفَهُم.﴿ٱلسَّبِيلِ﴾: أي: سَبِيلِ اللهِ المُسْتَقِيمِ.﴿مُسۡتَبۡصِرِينَ﴾: أي: عُقَلاءَ ذَوِي بَصائِرَ مُتَمَكِّنِينَ مِن مَّعْرِفَةِ الحقِّ."
  29,39,"﴿بِٱلۡبَيِّنَـٰتِ﴾: بالأدِلَّةِ الواضِحةِ.﴿سَـٰبِقِينَ﴾: فائِتِينَ مِن عَذابِ اللهِ."
  29,40,"﴿حَاصِبࣰا﴾: ريحًا عاصِفًا ترمِيهِم بالحَصْباءِ.﴿ٱلصَّيۡحَةُ﴾: صَوْتٌ مِنَ السَّماءِ مُهلِكٌ مُرْجِفٌ.﴿خَسَفۡنَا بِهِ﴾: جَعَلْنا الأرْضَ تبتَلِعُه وهو حَيٌّ."
  29,41,"﴿أَوۡهَنَ ٱلۡبُيُوتِ﴾: أضْعَفَها."
  29,43,"﴿نَضۡرِبُهَا﴾: أي: نُبَيِّنُها.﴿وَمَا يَعۡقِلُهَآ﴾: وما يَفْهَمُها."
  29,44,"﴿لَـَٔايَةࣰ﴾: لدَلالَةً عَظِيمةً."
  29,45,"﴿ٱلۡفَحۡشَآءِ﴾: أي: كُلِّ عَمَلٍ قَبِيحٍ.﴿وَٱلۡمُنكَرِ﴾: وهو كلُّ فِعْلٍ يُنكِرُه الشَّرعُ أو العَقْلُ."
  29,46,"﴿أَهۡلَ ٱلۡكِتَـٰبِ﴾: وهُمُ اليَهُودُ والنَّصارى."
  29,47,"﴿وَمَا يَجۡحَدُ﴾: وما يُنكِرُ.﴿بِـَٔايَـٰتِنَآ﴾: أي: بالقرآنِ وما فيه مِن دَلائِلَ وبَراهِينَ.﴿ٱلۡكَـٰفِرُونَ﴾: أي: المُكابِرُونَ في كُفْرِهِم."
  29,48,"﴿لَّٱرۡتَابَ﴾: لَشَكَّ.﴿ٱلۡمُبۡطِلُونَ﴾: هُمْ أهلُ الباطِلِ."
  29,49,"﴿هُوَ ءَايَـٰتُۢ﴾: أي: القرآنُ آياتٌ تُتْلى.﴿بَيِّنَـٰتࣱ﴾: واضِحاتٌ.﴿أُوتُواْ﴾: أُعْطُوا.﴿ٱلظَّـٰلِمُونَ﴾: أي: المُعانِدُونَ الَّذينَ يَعْلَمُونَ الحقَّ ولا يَتَّبعُونَه."
  29,50,"﴿ءَايَـٰتࣱ﴾: أي: مُعْجِزاتٌ حِسِّيَّةٌ تُثْبِتُ صِدْقَهُ.﴿عِندَ ٱللَّهِ﴾: أي: إنْ شاءَ أنْزَلَها، وإنْ شاءَ مَنَعَها."
  29,52,"29:51"
  29,53,"﴿أَجَلࣱ مُّسَمࣰّى﴾: وقْتٌ مُعَيَّنٌ لا يَتَقَدَّمُ ولا يَتَأَخَّرُ.﴿بَغۡتَةࣰ﴾: فُجاءَةً."
  29,54,"﴿لَمُحِيطَةُۢ﴾: أي: سَتُحِيطُ بِهِم في الآخِرَةِ."
  29,56,"29:55"
  29,57,"29:55"
  29,58,"﴿لَنُبَوِّئَنَّهُم﴾: لَنُنَزِّلَنَّهُم.﴿غُرَفࣰا﴾: مَنازِلَ عالِيةً."
  29,60,"﴿وَكَأَيِّن مِّن دَآبَّةࣲ﴾: أي: كَثِيرٌ مِنَ الدَّوابِّ.﴿لَّا تَحۡمِلُ رِزۡقَهَا﴾: أي: لا تُطِيقُ حَمْلَهُ ولا ادِّخارَهُ."
  29,61,"﴿فَأَنَّىٰ يُؤۡفَكُونَ﴾: فَكَيفَ يُصرَفُونَ عَن تَوحِيدِهِ؟"
  29,62,"﴿يَبۡسُطُ﴾: يُوَسِّعُ.﴿وَيَقۡدِرُ﴾: يُضَيِّقُ."
  29,63,"﴿مِنۢ بَعۡدِ مَوۡتِهَا﴾: مِن بَعْدِ قَحْطِ الأرْضِ وجَفافِها."
  29,64,"﴿لَهِيَ ٱلۡحَيَوَانُ﴾: لَهِيَ الحَياةُ الدّائِمَةُ الَّتي لا يُنَغِّصُها شَيءٌ."
  29,65,"﴿فِي ٱلۡفُلۡكِ﴾: في السُّفُن"
  29,67,"﴿وَيُتَخَطَّفُ ٱلنَّاسُ﴾: أي: يُسْتَلَبُونَ قَتْلًا وأسْرًا.﴿أَفَبِٱلۡبَـٰطِلِ﴾: أي: بالشِّركِ."
  29,68,"﴿ٱفۡتَرَىٰ﴾: اخْتَلَقَ.﴿مَثۡوࣰى﴾: مَسْكَنٌ."
  29,69,"﴿جَـٰهَدُواْ فِينَا﴾: أي: الكُفّارَ والنَّفْسَ والشَّيطانَ.﴿لَنَهۡدِيَنَّهُمۡ سُبُلَنَا﴾: لَنُرْشِدَنَّهُم طُرُقَنا."
