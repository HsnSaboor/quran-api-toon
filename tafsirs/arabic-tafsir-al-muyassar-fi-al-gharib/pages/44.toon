tafsir[49]{c,v,t}:
  44,1,"﴿حمٓ﴾: سَبَقَ الكلامُ عَلى الحُرُوفِ المقَطَّعةِ أوَّلَ سُورَةِ البقرةِ."
  44,2,"﴿ٱلۡمُبِينِ﴾: الواضِحِ لَفْظًا ومَعْنىً."
  44,3,"﴿مُّبَـٰرَكَةٍ﴾: كَثِيرَةِ الخَيراتِ، وهي لَيلةُ القَدْرِ."
  44,4,"﴿يُفۡرَقُ﴾: يُقضى ويُفَصَّلُ مِنَ اللوحِ المحْفُوظِ إلى الكَتَبةِ مِنَ الملائِكَةِ.﴿حَكِيمٍ﴾: مُحْكَمٍ."
  44,6,"44:5"
  44,7,"44:5"
  44,8,"44:5"
  44,9,"44:5"
  44,10,"﴿فَٱرۡتَقِبۡ﴾: فانْتَظِرْ.﴿بِدُخَانࣲ﴾: ظُلْمَةٍ كَهَيئَةِ الدُّخانِ بِسَبِبِ الجَدْبِ.﴿مُّبِينࣲ﴾: واضِحٍ."
  44,11,"﴿يَغۡشَى﴾: يَعُمُّ."
  44,13,"﴿أَنَّىٰ﴾: كَيفَ.﴿ٱلذِّكۡرَىٰ﴾: التَّذَكُّرُ والاتِّعاظُ."
  44,14,"﴿تَوَلَّوۡاْ عَنۡهُ﴾: أعْرَضُوا عَنْه.﴿مُعَلَّمࣱ﴾: عَلَّمَه بَشَرٌ أو الكَهَنَةُ أو الشَّياطِينُ."
  44,16,"﴿نَبۡطِشُ﴾: نُعَذِّبُ، والبَطْشُ أخْذٌ بِشِدَّةٍ."
  44,17,"﴿فَتَنَّا﴾: ابْتَلينا واخْتَبَرْنا."
  44,18,"﴿أَدُّوٓاْ﴾: سَلِّمُوا وأرْسِلُوا مَعِي.﴿عِبَادَ ٱللَّهِ﴾: بَنِي إسْرائِيلَ."
  44,19,"﴿وَأَن لَّا تَعۡلُواْ عَلَى ٱللَّهِ﴾: لا تَتَكَبَّرُوا على اللهِ بِتَكْذِيبِ رُسُلِه.﴿بِسُلۡطَـٰنࣲ﴾: بِبُرْهانٍ."
  44,20,"﴿عُذۡتُ بِرَبِّي﴾: استَجَرْتُ بِاللهِ.﴿تَرۡجُمُونِ﴾: تَقْتُلُوني رَجْمًا بالحِجارَةِ."
  44,21,"﴿فَٱعۡتَزِلُونِ﴾: كُفُّوا عَنْ أذايَ."
  44,22,"﴿مُّجۡرِمُونَ﴾: مُشْرِكُونَ بِاللهِ كافِرُونَ."
  44,23,"﴿فَأَسۡرِ﴾: اجْعَلْهُم يَسِيُرونَ لَيلًا."
  44,24,"﴿رَهۡوًا﴾: ساكِنًا مُسْتَقِرًّا عَلى حالِه مُنْفَرِجًا."
  44,26,"﴿وَمَقَامࣲ كَرِيمࣲ﴾: ومَنازِلَ جَمِيلَةٍ."
  44,27,"﴿وَنَعۡمَةࣲ﴾: عَيْشٍ لَيِّنٍ رَغْدٍ.﴿فَـٰكِهِينَ﴾: مُتَنَعِّمِينَ، مُتْرَفِينَ."
  44,28,"﴿كَذَ ٰ⁠لِكَ﴾: مِثْلَ ذَلِكَ العِقابِ يُعاقِبُ اللهُ مَن كَذَّبَ، وبَدّلَ نِعْمةَ اللهِ كُفْرًا.﴿وَأَوۡرَثۡنَـٰهَا﴾: ومَلَّكْناها."
  44,29,"﴿مُنظَرِينَ﴾: مُؤَخَّرِينَ عَنِ العُقُوبَةِ."
  44,30,"﴿ٱلۡمُهِينِ﴾: المُذِلِّ."
  44,31,"﴿عَالِيࣰا﴾: جَبّارًا.﴿مِّنَ ٱلۡمُسۡرِفِينَ﴾: مُتَجاوِزًا للحَدِّ في العُلوِّ والتَّكَبُّرِ عَلى عبادِ اللهِ."
  44,32,"﴿ٱلۡعَـٰلَمِينَ﴾: عالَمِي زَمانِهِم."
  44,33,"﴿ٱلۡـَٔايَـٰتِ﴾: الُمعْجِزاتِ.﴿بَلَـٰٓؤࣱاْ﴾: اخْتِبارٌ بالرَّخاءِ والشِّدَةِ."
  44,35,"﴿بِمُنشَرِينَ﴾: بِمَبْعُوثِينَ."
  44,37,"﴿تُبَّعࣲ﴾: أحَدِ مُلُوكِ اليمنِ الحِمْيَرِيِّينَ مِمَّن جَمَعَ مُلْكَ مَناطِقِ اليمنِ كُلِّها."
  44,39,"44:38"
  44,40,"﴿يَوۡمَ ٱلۡفَصۡلِ﴾: يومَ القَضاءِ بَينَ الخَلْقِ.﴿مِيقَـٰتُهُمۡ﴾: مَوعِدُ جزائِهِم"
  44,41,"﴿يُغۡنِي﴾: يَدْفَعُ.﴿مَّوۡلࣰى﴾: صاحِبٌ."
  44,43,"﴿شَجَرَتَ ٱلزَّقُّومِ﴾: شَجَرةً كَرِيهةَ الرّائِحَةِ صَغِيرةَ الوَرَقِ مَسْمُومةً خَلَقَها اللهُ في جَهَنَّمَ."
  44,44,"﴿ٱلۡأَثِيمِ﴾: الكَثِيرِ الآثامِ، والمرادُ بِه المشْرِكُ."
  44,45,"﴿كَٱلۡمُهۡلِ﴾: كالمَعْدَنِ المُذابِ."
  44,46,"﴿ٱلۡحَمِيمِ﴾: الماءِ الَّذِي بَلَغَ الغايَةَ فِي الحرارةِ."
  44,47,"﴿فَٱعۡتِلُوهُ﴾: ادْفَعُوهُ وقُودُوهُ بِعُنْفٍ.﴿سَوَآءِ﴾: وسَطِ."
  44,48,"﴿صُبُّواْ﴾: أفْرِغُوا."
  44,49,"﴿ذُقۡ﴾: قُولُوا لَهُ عَلى وجْهِ الإهانَةِ: أحْسِسْ.﴿أَنتَ ٱلۡعَزِيزُ ٱلۡكَرِيمُ﴾: أي: الذَّلِيلُ المُهانُ، عُكِسَ المَدْلُولُ للتَّهَكُّمِ بِهِ."
  44,50,"﴿تَمۡتَرُونَ﴾: تَشُكُّونَ."
  44,51,"﴿مَقَامٍ﴾: مَسْكَنٍ.﴿أَمِينࣲ﴾: آمِنٍ صاحِبُه مِنَ الآفاتِ."
  44,53,"﴿سُندُسࣲ﴾: الرقِيقِ مِنَ الحرِيرِ الخالِصِ.﴿وَإِسۡتَبۡرَقࣲ﴾: الغليظِ مِنَ الحريرِ الخالصِ.﴿مُّتَقَـٰبِلِينَ﴾: أي: في مَجالِسِهِم ومُحادَثاتِهِم."
  44,54,"﴿وَزَوَّجۡنَـٰهُم﴾: قَرنّاهُم.﴿بِحُورٍ﴾: جَمْعُ حَوْراءَ وهي البيضاءُ.﴿عِينࣲ﴾: واسِعاتِ الأَعْيُنِ."
  44,55,"﴿يَدۡعُونَ﴾: يَطْلُبُونَ."
  44,56,"﴿ٱلۡمَوۡتَةَ ٱلۡأُولَىٰ﴾: الَّتِي سَلَفَتْ لَهُم في الُّدنيا."
  44,58,"﴿يَسَّرۡنَـٰهُ﴾: سَهَّلْنا لَفْظَ القرآنِ ومَعْناهُ."
  44,59,"﴿فَٱرۡتَقِبۡ﴾: فانْتَظِر ما وعَدْتُكَ.﴿مُّرۡتَقِبُونَ﴾: مُنْتَظِرُونَ موتَكَ وقَهْرَكَ."
