tafsir[45]{c,v,t}:
  77,1,"﴿وَٱلۡمُرۡسَلَـٰتِ﴾: أُقسِمُ بالرِّياحِ حِينَ تَهُبُّ.﴿عُرۡفࣰا﴾: مُتَتابِعةً يَتْبَعُ بَعْضُها بَعْضًا كعُرْفِ الفَرَسِ."
  77,2,"﴿فَٱلۡعَـٰصِفَـٰتِ﴾: وبالرِّياحِ الشَّدَيدَةِ الهُبُوبِ المُهْلِكَةِ.﴿عَصۡفࣰا﴾: هُبُوبًا شَدِيدًا."
  77,3,"﴿وَٱلنَّـٰشِرَ ٰ⁠تِ نَشۡرࣰا﴾: وبالملائِكةِ المُوَكَّلِينَ بالسُّحُبِ يَسُوقُونَها حَيثُ شاء اللهُ."
  77,4,"﴿فَٱلۡفَـٰرِقَـٰتِ فَرۡقࣰا﴾: وبالملائِكةِ الَّتِي تَنْزِلُ مِن عِندِ اللهِ بما يَفْرُقُ بَينَ الحقِّ والباطِلِ والحَلالِ والحَرامِ."
  77,5,"﴿فَٱلۡمُلۡقِيَـٰتِ ذِكۡرًا﴾: وبالملائِكةِ الَّتِي تَتَلَقّى الوَحْيَ مِن عِنْدِ اللهِ وتُبَلّغُهُ رُسُلَهُ."
  77,6,"﴿عُذۡرًا أَوۡ نُذۡرًا﴾: إعْذارًا وإنْذارًا مِنَ اللهِ إلى خَلْقِهِ."
  77,7,"﴿لَوَ ٰ⁠قِعࣱ﴾: لَنازِلٌ بِكُم لا مَحالَةَ."
  77,8,"﴿طُمِسَتۡ﴾: ذَهَبَ ضِياؤُها."
  77,9,"﴿فُرِجَتۡ﴾: تَصَدَّعتْ."
  77,10,"﴿نُسِفَتۡ﴾: تَطايَرَتْ وتَناثَرَتْ."
  77,11,"﴿أُقِّتَتۡ﴾: عُيِّنَ لَهُم وقْتٌ لِلْفَصْلِ بَينَهُم وبَينَ الأُمَمِ."
  77,13,"﴿لِيَوۡمِ ٱلۡفَصۡلِ﴾: لِيومِ القضاءِ بين الخلائِقِ."
  77,14,"﴿وَمَآ أَدۡرَىٰكَ﴾: وما أعْلَمَكَ."
  77,15,"﴿وَيۡلࣱ﴾: هَلاكٌ عَظِيمٌ."
  77,16,"﴿ٱلۡأَوَّلِينَ﴾: السابِقِينَ مِنَ الأُمَم الماضِيةِ."
  77,17,"﴿ثُمَّ نُتۡبِعُهُمُ ٱلۡـَٔاخِرِينَ﴾: ثم نُلحِقُ بِهِمُ المُتَأخِّرِينَ المُكَذِّبِينَ."
  77,18,"﴿كَذَ ٰ⁠لِكَ﴾: مِثلَ ذلِك الإهْلاكِ الفَظِيعِ.﴿بِٱلۡمُجۡرِمِينَ﴾: مِن كُفّارِ «مكَّةَ»."
  77,19,"﴿وَيۡلࣱ﴾: هَلاكٌ وعَذابٌ شَدِيدٌ."
  77,20,"﴿مَّآءࣲ مَّهِينࣲ﴾: ماءٍ ضَعِيفٍ حَقِيرٍ وهو النطْفَةُ."
  77,21,"﴿فِي قَرَارࣲ مَّكِينٍ﴾: في مَكانٍ حَصِينٍ، وهو رَحِمُ المرأَةِ."
  77,22,"﴿إِلَىٰ قَدَرࣲ مَّعۡلُومࣲ﴾: وقتٍ مَعْلُومٍ عِندَ اللهِ تَعالى."
  77,23,"﴿فَقَدَرۡنَا﴾: فَقَدَرْنا على خَلْقِهِ وتَصْوِيِرهِ وإخْراجِهِ.﴿ٱلۡقَـٰدِرُونَ﴾: على الأشياءِ."
  77,24,"﴿وَيۡلࣱ﴾: هَلاكٌ وعَذابٌ شَدِيدٌ."
  77,25,"﴿كِفَاتًا﴾: وِعاءً جامِعًا."
  77,26,"﴿أَحۡيَآءࣰ﴾: تَضُمُّ على ظَهْرِها أحياءً.﴿وَأَمۡوَ ٰ⁠تࣰا﴾: و تَضُمُّ في بَطْنِها أمْواتًا."
  77,27,"﴿رَوَ ٰ⁠سِيَ﴾: جِبالًا ثَوابِتَ.﴿شَـٰمِخَـٰتࣲ﴾: عالياتٍ.﴿فُرَاتࣰا﴾: عَذْبًا سائِغًا."
  77,28,"﴿وَيۡلࣱ﴾: هلاكٌ ودمارٌ."
  77,29,"﴿ٱنطَلِقُوٓاْ إِلَىٰ مَا كُنتُم بِهِۦ تُكَذِّبُونَ﴾: يُقال لِلْكافِرينَ يومَ القيامةِ: سيرُوا إلى عذابِ جَهَنَّم الَّذِي كُنْتُم بِهِ تُكَذِّبُونَ في الدُّنيا."
  77,30,"﴿ٱنطَلِقُوٓاْ إِلَىٰ ظِلࣲّ﴾: سِيرُوا، فاسْتَظِلُّوا بِدُخانِ جَهَنَّمَ.﴿شُعَبࣲ﴾: قِطَعٍ."
  77,31,"﴿لَّا ظَلِيلࣲ﴾: لا يُظِلُّ ذلك الظِّلُّ مِن حَرِّ ذَلِكَ اليومِ.﴿وَلَا يُغۡنِي مِنَ ٱللَّهَبِ﴾: ولا يَدْفَعُ مِنَ حرِّ اللهبِ شيئًا."
  77,32,"﴿إِنَّهَا﴾: إنّ جَهَنَّمَ.﴿بِشَرَرࣲ﴾: اسْمِ جَمْعِ شَرَرَةٍ: وهي القِطعَةُ المشْتَعِلَةُ مِن دَقِيقِ الحَطَبِ يَدْفَعُها لَهَبُ النّارِ في الهواءِ.﴿كَٱلۡقَصۡرِ﴾: كالبِناءِ العَظِيمِ العالِي."
  77,33,"﴿جِمَـٰلَتࣱ﴾: جمعُ جَمَلٍ، طائِفَةٌ مِنَ الإبِلِ الذُّكُورِ لا إناثَ فيها.﴿صُفۡرࣱ﴾: سُودٌ يمِيلُ لونُها إلى الصُّفْرةِ."
  77,34,"﴿وَيۡلࣱ﴾: هَلاكٌ وعذابٌ شَدِيدٌ."
  77,35,"﴿لَا يَنطِقُونَ﴾: لا يَنْطِقُ فيه المُكَذِّبُونَ بِكَلامٍ يَنْفَعُهُم."
  77,37,"77:36"
  77,38,"﴿يَوۡمُ ٱلۡفَصۡلِ﴾: يومٌ يَفْصِلُ اللهُ فِيهِ بَينَ الخلائِقِ.﴿جَمَعۡنَـٰكُمۡ وَٱلۡأَوَّلِينَ﴾: جَمَعْناكُم مَعَ الكُفّارِ مِنَ الأُمَمِ الماضِيةِ."
  77,39,"﴿كَيۡدࣱ﴾: حِيلةٌ في الخلاصِ مِنَ العذابِ.﴿فَكِيدُونِ﴾: فاحْتالُوا، وأنقذوا أنفُسَكُم مِن بَطْشِ اللهِ وانتِقامِهِ."
  77,41,"﴿وَعُيُونࣲ﴾: وعُيُونِ الماءِ الجاريةِ."
  77,43,"﴿هَنِيٓـَٔۢا﴾: سائِغًا."
  77,45,"77:44"
  77,46,"77:44"
  77,47,"77:44"
  77,48,"77:44"
  77,49,"77:44"
  77,50,"﴿فَبِأَيِّ حَدِيثِۭ﴾: فبأيِّ كِتابٍ وكَلامٍ."
