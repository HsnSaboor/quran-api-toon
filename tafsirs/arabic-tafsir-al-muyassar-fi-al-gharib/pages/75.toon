tafsir[37]{c,v,t}:
  75,1,"﴿لَآ أُقۡسِمُ﴾: أحْلِفُ."
  75,2,"﴿وَلَآ أُقۡسِمُ﴾: وأحْلِفُ.﴿بِٱلنَّفۡسِ ٱللَّوَّامَةِ﴾: بالأنْفُسِ الَّتِي تَلُومُ صاحِبَها على تَرْكِ الطّاعاتِ وفِعْلِ السَّيئاتِ."
  75,3,"﴿أَيَحۡسَبُ﴾: أيَظُنُّ.﴿أَلَّن نَّجۡمَعَ عِظَامَهُۥ﴾: أن لَن نَّقَدِرَ على جَمْعِ عِظامِهِ بَعْدَ تَفَرُّقِها."
  75,4,"﴿بَلَىٰ﴾: بَلْ سَنَجْمَعُها.﴿أَن نُّسَوِّيَ بَنَانَهُۥ﴾: نُعيدَ خَلْقَ أصابِعِه أو أنامِلِه مُقَوَّمةً مُتْقَنةً."
  75,5,"﴿لِيَفۡجُرَ﴾: لِيَبْقى على فجُورِهِ.﴿أَمَامَهُۥ﴾: فِيما يَسْتَقْبِلُ مِن أيامِ عُمُرِهِ."
  75,6,"﴿أَيَّانَ﴾: مَتى."
  75,7,"﴿بَرِقَ ٱلۡبَصَرُ﴾: تَحَيَّر البَصَرُ ودُهِشَ فَزِعًا مما رَأى مِن أهْوالِ يَومِ القِيامَةِ."
  75,8,"﴿وَخَسَفَ ٱلۡقَمَرُ﴾: وذَهبَ نُورُ القَمَرِ."
  75,9,"﴿وَجُمِعَ ٱلشَّمۡسُ وَٱلۡقَمَرُ﴾: في ذَهابِ ضَوْئِهِما."
  75,11,"﴿كَلَّا﴾: ليسَ الأمرُ كَما تَتَمَنّاهُ.﴿لَا وَزَرَ﴾: لا مَلْجأَ لَكَ ولا مَنجى."
  75,12,"﴿ٱلۡمُسۡتَقَرُّ﴾: مَصِيرُ الخلائِقِ يومَ القِيامةِ."
  75,13,"﴿بِمَا قَدَّمَ وَأَخَّرَ﴾: بِجَمِيعِ أعْمالِهِ: مِن خَيرٍ وشَرٍّ، ما قدَّمَهُ مِنها في حياتِهِ وما أخَّرَهُ."
  75,14,"﴿عَلَىٰ نَفۡسِهِۦ بَصِيرَةࣱ﴾: بَصِيرٌ بِنَفْسِهِ، يعلَمُ اسْتِحْقاقَهُ لِلْعِقابِ."
  75,15,"﴿وَلَوۡ أَلۡقَىٰ مَعَاذِيرَهُۥ﴾: حتّى في حِينِ إخْبارِه باعْتِذاراتِهِ الكاذِبةِ."
  75,16,"﴿لَا تُحَرِّكۡ بِهِۦ لِسَانَكَ لِتَعۡجَلَ بِهِۦٓ﴾: لا تُحَرِّكْ –أيُّها النَّبِيُّ- بالقُرآنِ لِسانَكَ حتّى نُزُولِ الوحْيِ؛ لِأَجْلِ أن تَتَعَجَّلَ بِحِفْظِهِ، مخافَةَ أن يَتَفَلَّتَ مِنكَ."
  75,17,"﴿جَمۡعَهُۥ﴾: في صَدرِكَ.﴿وَقُرۡءَانَهُۥ﴾: أن تَقْرَأَهُ بِلِسانِكَ مَتى شِئْتَ."
  75,18,"﴿فَإِذَا قَرَأۡنَـٰهُ﴾: فَإذا قَرَأَهُ عَلَيكَ رَسُولُنا جِبْرِيلُ.﴿فَٱتَّبِعۡ قُرۡءَانَهُۥ﴾: فاسْتمِعْ لِقِراءتِه وأَنْصِتْ لَهُ، ثُمُّ اقْرَأْهُ كَما أقْرَأَكَ إيّاهُ."
  75,19,"﴿بَيَانَهُۥ﴾: تَوْضِيحَ ما أشْكَلَ عَلَيكَ فَهْمُهُ مِن مَّعانِيهِ وأَحْكامِهِ."
  75,20,"﴿كَلَّا﴾: ليسَ الأمرُ كَما زَعَمْتُم أن لّا بَعْثَ ولا جَزاءَ.﴿ٱلۡعَاجِلَةَ﴾: الدُّنيا وزِينَتَها."
  75,22,"﴿وُجُوهࣱ﴾: وُجُوهُ أهْلِ السَّعادةِ.﴿يَوۡمَئِذࣲ﴾: يومَ القيامةِ.﴿نَّاضِرَةٌ﴾: مُشْرِقَةٌ مُتَأَلِّقَةٌ."
  75,23,"﴿إِلَىٰ رَبِّهَا نَاظِرَةࣱ﴾: تَنْظُرُ إلى خالِقِها فَتَتَمَتَّعُ بِذَلِكَ."
  75,24,"﴿وَوُجُوهࣱ﴾: ووُجُوهُ الأشْقِياءِ.﴿يَوۡمَئِذِۭ﴾: يَومَ القِيامَةِ.﴿بَاسِرَةࣱ﴾: عابِسَةٌ كالِحَةٌ."
  75,25,"﴿تَظُنُّ﴾: تَتَوقَّعُ.﴿فَاقِرَةࣱ﴾: مُصِيَبةٌ عَظِيمَةٌ."
  75,26,"﴿كَلَّآ﴾: حَقًّا.﴿بَلَغَتِ ٱلتَّرَاقِيَ﴾: وصَلَتْ الرُّوحُ إلى الحُلْقُومِ."
  75,27,"﴿وَقِيلَ﴾: وقالَ بَعْضُ الحاضِرِينَ لِبَعْضٍ.﴿مَنۡۜ رَاقࣲ﴾: هَل مِن راقٍ يَرْقِيهِ ويَشْفيهِ؟"
  75,28,"﴿وَظَنَّ﴾: وأَيقَنَ المُحْتَضِرُ.﴿أَنَّهُ﴾: الأمرَ الَّذِي نَزَلَ بِهِ.﴿ٱلۡفِرَاقُ﴾: فراقُ الدُّنيا؛ لِمُعايَنَتِهِ مَلائِكَةَ الموْتِ."
  75,29,"﴿وَٱلۡتَفَّتِ ٱلسَّاقُ بِٱلسَّاقِ﴾: واتَّصَلَتْ شِدَّةُ آخِر الدُّنيا بِشِدَّةِ أوّلِ الآخِرَةِ."
  75,30,"﴿ٱلۡمَسَاقُ﴾: المرْجِعُ."
  75,31,"﴿فَلَا صَدَّقَ﴾: فلا آمنَ الكافِرُ بالرَّسُولِ ﷺ والقرآنِ."
  75,32,"﴿كَذَّبَ﴾: بالقرآنِ.﴿وَتَوَلَّىٰ﴾: وأَعْرَضَ عَنِ الإيمانِ."
  75,33,"﴿يَتَمَطَّىٰٓ﴾: يَتَبَخْتَرُ مُخْتالًا في مِشْيتِهِ."
  75,34,"﴿أَوۡلَىٰ لَكَ﴾: هَلاكٌ لَكَ.﴿فَأَوۡلَىٰ﴾: فَهَلاكٌ."
  75,36,"﴿ٱلۡإِنسَـٰنُ﴾: هو المُنْكِرُ لِلْبَعثِ.﴿سُدًى﴾: هَمَلًا لا يُحاسَبُ؟"
  75,37,"﴿نُطۡفَةࣰ﴾: ماءً قَلِيلًا.﴿مَّنِيࣲّ﴾: ماءِ الرَّجُلِ.﴿يُمۡنَىٰ﴾: يُراقُ ويُصَبُّ في الأرحامِ."
  75,38,"﴿عَلَقَةࣰ﴾: قِطْعَةً مِن دمٍ جامِدٍ.﴿فَسَوَّىٰ﴾: فعَدَّلَ صُورَتَهُ وقَوَّمَها في أحْسَنِ تَقْوِيمٍ."
  75,39,"﴿ٱلزَّوۡجَيۡنِ﴾: الصِّنْفَينِ."
  75,40,"﴿يُحۡـِۧيَ ٱلۡمَوۡتَىٰ﴾: يُعيدُ الخلْقَ بَعْدَ فَنائِهِم."
