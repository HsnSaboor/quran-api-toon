tafsir[99]{c,v,t}:
  18,1,"﴿عِوَجَا﴾: اختِلافًا، ولا اختِلالًا فيِ ألفاظِه ولا فيِ معانيه."
  18,2,"﴿قَيِّمࣰا﴾: مستقيمًا معتدلًا، لا إفراطَ فيه ولا تفريطَ.﴿بَأۡسࣰا شَدِيدࣰا﴾: عقوبةً عاجلةً في الدنيا وآجِلَةً في الآخرةِ.﴿أَجۡرًا حَسَنࣰا﴾: ثوابًا جزيلًا، هو الجنةُ."
  18,4,"18:3"
  18,5,"﴿كَبُرَتۡ﴾: عَظُمَتْ في الشَّناعَةِ والقُبْحِ."
  18,6,"﴿بَـٰخِعࣱ نَّفۡسَكَ﴾: مُهْلِكُها ومُجْهِدُها.﴿عَلَىٰٓ ءَاثَـٰرِهِمۡ﴾: بعدَ تَوَلِّي قومِك عنك.﴿ٱلۡحَدِيثِ﴾: القرآنِ.﴿أَسَفًا﴾: حُزْنًا وغَضَبًا؛ لحِرْصِك على إيمانهم."
  18,7,"﴿لِنَبۡلُوَهُمۡ﴾: لِنَخْتَبِرَهم."
  18,8,"﴿صَعِيدࣰا﴾: تُرابًا.﴿جُرُزًا﴾: لا نباتَ فيه."
  18,9,"﴿ٱلۡكَهۡفِ﴾: النَّقْبِ المتَّسِعِ في الجبل، وهو أكبرُ من المغارة.﴿وَٱلرَّقِيمِ﴾: اللَّوْحِ الذي كُتِبَتْ فيه أسماءُ أهلِ الكهفِ."
  18,10,"﴿أَوَى ٱلۡفِتۡيَةُ إِلَى ٱلۡكَهۡفِ﴾: لجَؤُوا إليه؛ لعبادةِ اللهِ، وفِرارًا بدِينهم.﴿وَهَيِّئۡ﴾: يَسِّرْ.﴿رَشَدࣰا﴾: اهتداءً إلى الحق، وسَدادًا في العمل."
  18,11,"﴿فَضَرَبۡنَا عَلَىٰٓ ءَاذَانِهِمۡ﴾: أنَمْناهم نومًا عميقًا؛ بحيث لا يَسْمعون."
  18,12,"﴿بَعَثۡنَـٰهُمۡ﴾: أيقَظْناهم مِن نومِهم.﴿ٱلۡحِزۡبَيۡنِ﴾: الفريقَين المختلفَين في مُدَّةِ بقائِهم في الكهفِ.﴿أَمَدࣰا﴾: غايةً ومُدَّة."
  18,14,"﴿وَرَبَطۡنَا عَلَىٰ قُلُوبِهِمۡ﴾: قَوَّيْناها بالصَّبْرِ والتثبيتِ على الحقِّ.﴿شَطَطًا﴾: قولًا بعيدًا مجانِبًا للحقِّ."
  18,15,"﴿لَّوۡلَا﴾: هَلّا.﴿بِسُلۡطَـٰنِۭ بَيِّنࣲ﴾: دليلٍ واضحٍ.﴿ٱفۡتَرَىٰ﴾: اختَلَقَ.﴿كَذِبࣰا﴾: بنسبةِ الشريكِ إلى اللهِ تعالى."
  18,16,"﴿ٱعۡتَزَلۡتُمُوهُمۡ﴾: فارَقْتُم قومَكم؛ فِرارًا بدِينِكم.﴿فَأۡوُۥٓاْ﴾: الجَؤُوا.﴿يَنشُرۡ﴾: يَبْسُطْ ويُوَسِّعْ.﴿وَيُهَيِّئۡ﴾: يُيَسِّرْ.﴿مِّرۡفَقࣰا﴾: ما تنتفعون به من أسبابِ العيشِ."
  18,17,"﴿تَّزَ ٰ⁠وَرُ﴾: تميلُ.﴿ذَاتَ ٱلۡيَمِينِ﴾: جهةَ يمينِ الكهفِ.﴿تَّقۡرِضُهُمۡ﴾: تَتْرُكُهم وتتجاوَزُهم.﴿فَجۡوَةࣲ مِّنۡهُ﴾: مُتَّسَعٍ من الكهفِ وفَضائِه، فلا يتأَذَّون من جَوِّه، أو من حرارةِ الشمس، ويأتيهم الهواءُ النافعُ.﴿ءَايَـٰتِ ٱللَّهِ﴾: دلائلِ قُدرتِه.﴿يَهۡدِ ٱللَّهُ﴾: يوفِّقه.﴿وَلِيࣰّا﴾: مُعِينًا وناصِرًا."
  18,18,"﴿رُقُودࣱ﴾: نِيامٌ.﴿بِٱلۡوَصِيدِ﴾: بفِناءِ الكَهْفِ، كأنه يَحْرُسُهم.﴿رُعۡبࣰا﴾: خَوفًا وفَزَعًا."
  18,19,"﴿وَكَذَ ٰ⁠لِكَ﴾: وكما أنَمْناهم وحَفِظْناهم مدةً طويلة.﴿بَعَثۡنَـٰهُمۡ﴾: أيْقَظْناهم من نومِهم كما كانوا.﴿بِوَرِقِكُمۡ﴾: بنقُودِكم الفِضِّيَّةِ.﴿أَيُّهَآ﴾: أيُّ أهلِ المدينةِ.﴿أَزۡكَىٰ طَعَامࣰا﴾: أحَلُّ وأطيبُ.﴿وَلۡيَتَلَطَّفۡ﴾: وليتكلَّفِ اللُّطْفَ والرِّفْقَ في المعاملةِ، حتى لا ينكشِفَ أمرُنا."
  18,20,"﴿يَظۡهَرُواْ عَلَيۡكُمۡ﴾: يَطَّلِعُوا على مكانِكم ويَعْلَمُوا به.﴿يَرۡجُمُوكُمۡ﴾: يَقْتُلوكم بالرَّجْمِ بالحجارةِ.﴿مِلَّتِهِمۡ﴾: دينِهم الباطلِ."
  18,21,"﴿وَكَذَ ٰ⁠لِكَ﴾: وكما أنَمْناهم السنينَ الطِّوالَ، ثم أيْقَظْناهم بعدَها.﴿أَعۡثَرۡنَا عَلَيۡهِمۡ﴾: أطْلَعْنا عليهم أهلَ زمانِهم.﴿وَعۡدَ ٱللَّهِ﴾: بالبعثِ.﴿أَمۡرَهُمۡ﴾: في أمرِ القِيامةِ، فمِن مُقِرٍّ لها وجاحِدٍ، أو في أمْرِ الفِتْيَةِ المؤمنين وما اطَّلعوا عليه مِن أحوالِهم.﴿ٱلَّذِينَ غَلَبُواْ عَلَىٰٓ أَمۡرِهِمۡ﴾: أصحابُ الكلمةِ والنفوذِ."
  18,22,"﴿رَجۡمَۢا بِٱلۡغَيۡبِ﴾: قولًا بلا عِلْمٍ ولا اطِّلاعٍ.﴿بِعِدَّتِهِم﴾: بعَدَدِهم.﴿فَلَا تُمَارِ فِيهِمۡ﴾: فلا تجادِلْ في شأنِ أصحابِ الكهفِ وعَدَدِهم أحدًا من الخائضين فيه.﴿إِلَّا مِرَآءࣰ ظَـٰهِرࣰا﴾: إلا جِدالًا واضحًا بذِكْرِ ما قَصَصْنا عليك مِن شأنِهم دونَ زيادةٍ."
  18,24,"﴿وَٱذۡكُر رَّبَّكَ﴾: بقولِ: إنْ شاء الله.﴿يَهۡدِيَنِ﴾: يُوَفِّقَني.﴿مِنۡ هَـٰذَا﴾: من قصةِ أصحابِ الكهفِ في الدِّلالةِ على نُبَوَّتي.﴿رَشَدࣰا﴾: هدايةً ودَلالة للناسِ على ذلك."
  18,25,"﴿وَلَبِثُواْ فِي كَهۡفِهِمۡ﴾: ومَكَثَ الفِتْيانُ فيه نِيامًا."
  18,26,"﴿أَبۡصِرۡ بِهِۦ وَأَسۡمِعۡ﴾: ما أبصَرَ اللهَ وأسمَعَه بكلِّ موجودٍ، فهو لا يَغِيبُ عنه شيء!﴿مَا لَهُم﴾: ليس للخَلْقِ.﴿وَلِيࣲّ﴾: مُعينٍ وناصرٍ.﴿حُكۡمِهِۦٓ﴾: قَضائِه وتشريعِه."
  18,27,"﴿مُلۡتَحَدࣰا﴾: مَلْجَأً ومَلاذًا."
  18,28,"﴿وَٱصۡبِرۡ نَفۡسَكَ﴾: احبِسْها في طاعةِ اللهِ.﴿بِٱلۡغَدَوٰةِ وَٱلۡعَشِيِّ﴾: أولِ النهار وآخرِه، والمرادُ دوامُ العبادةِ.﴿وَلَا تَعۡدُ عَيۡنَاكَ عَنۡهُمۡ﴾: لا تَصْرِفْ نَظَرَكَ عنهم إلى غيرِهِم.﴿أَغۡفَلۡنَا قَلۡبَهُۥ﴾: جَعَلْناه غافلًا.﴿فُرُطࣰا﴾: ضَياعًا وهَلاكًا ومُتَجاوِزًا فيه الاعتدالَ."
  18,29,"﴿ٱلۡحَقُّ﴾: ما جئتكُم به هو الحقُّ.﴿فَمَن شَآءَ فَلۡيُؤۡمِن وَمَن شَآءَ فَلۡيَكۡفُرۡ﴾: تهديدٌ ووعيدٌ لمن اختارَ الكفرَ بعد بيانِ الحقِّ ووُضوحِه.﴿سُرَادِقُهَا﴾: سُورُها المحيطُ بها.﴿كَٱلۡمُهۡلِ﴾: ماءٌ غليظٌ كالمُنْصَهِر من المعادنِ، أو كعَكَرِ الزيتِ، بَلَغَ منتهى الحَرارةِ.﴿مُرۡتَفَقًا﴾: منزِلًا ومُقامًا."
  18,31,"﴿جَنَّـٰتُ عَدۡنࣲ﴾: جِنانُ إقامةٍ دائمةٍ.﴿يُحَلَّوۡنَ﴾: يُزَيَّنُون.﴿سُندُسࣲ﴾: رقيقِ الحَريرِ.﴿وَإِسۡتَبۡرَقࣲ﴾: ما غَلُظَ من الحريرِ وثَخُنَ.﴿ٱلۡأَرَآئِكِ﴾: الأَسِرَّةِ المزيَّنَةِ بفاخِرِ السَّتائرِ."
  18,32,"﴿وَٱضۡرِبۡ لَهُم﴾: واذكُرْ للمؤمنين والكافرين المستكبرِين وأَوْرِدْ لهم.﴿جَنَّتَيۡنِ﴾: حديقتَين.﴿وَحَفَفۡنَـٰهُمَا بِنَخۡلࣲ﴾: جَعَلْنا النَّخْلَ محيطًا بكلٍّ منهما."
  18,33,"﴿ءَاتَتۡ أُكُلَهَا﴾: أثمرَتْ ثمرَها الذي يُؤْكَلُ.﴿وَلَمۡ تَظۡلِم مِّنۡهُ﴾: ولم تَنْقُصْ من إثمارها عَبْرَ السنينَ."
  18,34,"﴿لَهُۥ ثَمَرࣱ﴾: لصاحبِ البستانينِ أنواعٌ من المال سِوى حديقتَيه.﴿نَفَرࣰا﴾: أولادًا وخَدَمًا وأعوانًا."
  18,35,"﴿ظَالِمࣱ لِّنَفۡسِهِۦ﴾: كافرٌ بالبعثِ، مُعْجَبٌ بمالِه.﴿تَبِيدَ﴾: تَهْلِكَ وتَفْنى."
  18,36,"﴿قَآئِمَةࣰ﴾: كائنةً وواقعةً.﴿مُنقَلَبࣰا﴾: مَرْجِعًا وعاقبةً."
  18,38,"﴿لَّـٰكِنَّا۠﴾: لكنْ أنا أقولُ."
  18,39,"﴿وَلَوۡلَآ﴾: وهَلّا."
  18,40,"﴿حُسۡبَانࣰا﴾: جَمْعُ حُسْبانَةٍ، وهو العذابُ كالصَّواعِقِ.﴿صَعِيدࣰا﴾: أرضًا أو ترابًا.﴿زَلَقًا﴾: لا نَباتَ فيها، ومَلْساءُ لا تَثْبُتُ عليها قَدَمٌ. والمرادُ أنها عَدِيمةُ النَّفْعِ."
  18,41,"﴿غَوۡرࣰا﴾: غائِرًا ذاهبًا في أسفلِ الأرضِ."
  18,42,"﴿وَأُحِيطَ بِثَمَرِهِۦ﴾: وأُهلِكَتْ أموالُ الكافرِ بما فيها حديقتاه، كما تَوَقَّعَ المؤمنُ.﴿يُقَلِّبُ كَفَّيۡهِ﴾: دَلالةً على نَدَمِه وأَسَفِه وحَسْرَتِه.﴿خَاوِيَةٌ عَلَىٰ عُرُوشِهَا﴾: متهدِّمةٌ سَقَطَ بعضُها على بعضٍ، خاليةٌ مما كان فيها."
  18,43,"﴿فِئَةࣱ﴾: جماعةٌ ممَّنِ افتَخَرَ بهم.﴿وَمَا كَانَ مُنتَصِرًا﴾: ما كان ممتنعًا بنفسِه وقوَّتِه عندَ انتقامِ اللهِ منه."
  18,44,"﴿هُنَالِكَ﴾: في مثلِ هذه الشَّدائدِ، أو يومِ القيامةِ.﴿ٱلۡوَلَـٰيَةُ لِلَّهِ﴾: النُّصْرَةُ للهِ وحدَه لا يَقْدِرُ عليها غيرُه.﴿عُقۡبࣰا﴾: عاقبةً لمَن تَوَلّاهم."
  18,45,"﴿وَٱضۡرِبۡ لَهُم﴾: اذكُرْ للناسِ وأَوْرِدْ.﴿مَّثَلَ ٱلۡحَيَوٰةِ ٱلدُّنۡيَا﴾: صِفَتَها في زينتِها، وتَقَلُّبَها وسُرْعَةَ زوالِها.﴿هَشِيمࣰا﴾: يابسًا مُتَكَسِّرًا، بعد خُضْرَتِه ونَضارَتِه.﴿تَذۡرُوهُ ٱلرِّيَـٰحُ﴾: تُذْهِبُه وتُفَرِّقُه إلى كلِّ جهةٍ.﴿مُّقۡتَدِرًا﴾: كاملَ القُدْرةِ على كلِّ شيءٍ."
  18,46,"﴿زِينَةُ ٱلۡحَيَوٰةِ ٱلدُّنۡيَا﴾: فيهما جَمالٌ ونَفْعٌ وقوَّةٌ.﴿وَٱلۡبَـٰقِيَـٰتُ ٱلصَّـٰلِحَـٰتُ﴾: الأعمالُ الصالحةُ بما فيها: التسبيحُ، والتحميدُ، والتكبيرُ، والتهليلُ.﴿أَمَلࣰا﴾: ما كان يأمُلُه صاحبُها في الدُّنيا عندَ اللهِ في الآخِرة."
  18,47,"﴿نُسَيِّرُ ٱلۡجِبَالَ﴾: نُزيلُها عن أماكنِها، ونُسَيِّرها في الجوِّ كالسَّحابِ.﴿بَارِزَةࣰ﴾: ظاهرةً للأَعْيُنِ لا يَسْتُرها شيءٌ.﴿وَحَشَرۡنَـٰهُمۡ﴾: جَمَعْنا الأوَّلِين والآخِرين لموقفِ الحسابِ.﴿نُغَادِرۡ﴾: نَتْرُكْ."
  18,48,"﴿صَفࣰّا﴾: مُصْطَفِّين جميعًا لا يَغِيبُ أحدٌ منهم.﴿كَمَا خَلَقۡنَـٰكُمۡ أَوَّلَ مَرَّةِۭ﴾: مِثْلَ خَلْقِنا الأولِ لكم: فُرادى، حُفاةَ الأقدامِ، عُراةَ الأجسامِ، غيرَ مَخْتُونين.﴿بَلۡ زَعَمۡتُمۡ﴾: يا مُنْكِري البَعْثِ.﴿مَّوۡعِدࣰا﴾: لبَعْثِكم ومُجازاتِكم على أعمالِكم."
  18,49,"﴿ٱلۡكِتَـٰبُ﴾: صحائفُ أعمالِ العبادِ.﴿مُشۡفِقِينَ﴾: خائفين.﴿يَـٰوَيۡلَتَنَا﴾: يا هَلاكَنا، نداءٌ منهم على أنفسِهم بالخُسْرانِ والهَلاكِ.﴿لَا يُغَادِرُ﴾: لا يَتْرُك.﴿أَحۡصَىٰهَا﴾: عَدَّها وأثْبتَها."
  18,50,"﴿ٱسۡجُدُواْ لِـَٔادَمَ﴾: تحيةً وإكرامًا له وإظهارًا لفَضْلِه، لا عبادةً.﴿فَفَسَقَ عَنۡ أَمۡرِ رَبِّهِۦٓ﴾: خَرَجَ عن طاعةِ ربِّه بتَرْكِ السُّجودِ؛ تَكَبُّرًا.﴿أَوۡلِيَآءَ﴾: أعوانًا."
  18,51,"﴿مَّآ أَشۡهَدتُّهُمۡ﴾: أي: إبليسَ وذريتَه.﴿عَضُدࣰا﴾: أعوانًا وأنصارًا في شأنٍ من شؤوني."
  18,52,"﴿فَدَعَوۡهُمۡ﴾: استغاثُوا بهم.﴿مَّوۡبِقࣰا﴾: مَهْلِكًا في جَهَنَّمَ يَهْلِكُون فيه."
  18,53,"﴿فَظَنُّوٓاْ﴾: أيقَنوا.﴿مُّوَاقِعُوهَا﴾: واقِعُونَ فيها وداخِلُوها.﴿مَصۡرِفࣰا﴾: مكانًا يَنْصَرِفُون ويَلْجَؤُون إليه."
  18,54,"﴿صَرَّفۡنَا﴾: بَيَّنّا ونوَّعْنا بأساليبَ مختلفةٍ.﴿كُلِّ مَثَلࣲ﴾: كلِّ معنى يَحْصُلُ الاتِّعاظُ به.﴿جَدَلࣰا﴾: خُصومةً في الباطل."
  18,55,"﴿سُنَّةُ ٱلۡأَوَّلِينَ﴾: سُنَّةُ اللهِ في إهلاكِ السابقين بالاستئصال.﴿قُبُلࣰا﴾: صُنوفًا وأنواعًا، أو مَوُاجَهَةً ومقابَلَةً."
  18,56,"﴿لِيُدۡحِضُواْ بِهِ﴾: ليُزِيلُوا بجِدالِهم وباطِلِهم.﴿هُزُوࣰا﴾: استهزاءً وسُخْريَةً."
  18,57,"﴿أَكِنَّةً﴾: أغطيةً مانعةً.﴿أَن يَفۡقَهُوهُ﴾: لِئلّا يَفْهَمُوا القرآنَ؛ عُقوبةً لهم.﴿وَقۡرࣰا﴾: ثِقَلًا في السَّمعِ."
  18,58,"﴿مَّوۡعِدࣱ﴾: أي: مُقَدَّرٌ لعذابهِم."
  18,59,"﴿وَتِلۡكَ ٱلۡقُرَىٰٓ﴾: مِنَ الأممِ السابقةِ.﴿لِمَهۡلِكِهِم﴾: لهَلاكِهم."
  18,60,"﴿لِفَتَىٰهُ﴾: تلميذِه وخادِمِه يُوشَعَ بنِ نونٍ.﴿لَآ أَبۡرَحُ﴾: لا أزال أسِيرُ.﴿مَجۡمَعَ ٱلۡبَحۡرَيۡنِ﴾: مُلتقاهما.﴿أَمۡضِيَ حُقُبࣰا﴾: أسيرُ زمنًا طويلًا."
  18,61,"﴿فِي ٱلۡبَحۡرِ سَرَبࣰا﴾: طريقًا فيه، كالشَّقِّ في الأرضِ."
  18,62,"﴿جَاوَزَا﴾: فارَقا مكانَهما.﴿غَدَآءَنَا﴾: طعامَنا أوَّلَ النهارِ.﴿نَصَبࣰا﴾: تَعَبًا."
  18,63,"﴿أَرَءَيۡتَ﴾: أتَذْكُرُ؟﴿إِذۡ أَوَيۡنَآ إِلَى ٱلصَّخۡرَةِ﴾: حين لَجَأْنا إليها للراحةِ.﴿سَبِيلَهُۥ﴾: طريقَه.﴿عَجَبࣰا﴾: يُتعَجَّبُ منه."
  18,64,"﴿نَبۡغِ﴾: نَطْلبُه، وهو علامةٌ على مكانِ العبدِ الصّالحِ.﴿فَٱرۡتَدَّا﴾: رَجَعا.﴿عَلَىٰٓ ءَاثَارِهِمَا﴾: على طريقِهما الذي جاءا منه.﴿قَصَصࣰا﴾: يَتْبَعان آثارَ مسيرِهما، حتى وصَلا إلى الصَّخْرةِ."
  18,65,"﴿عَبۡدࣰا مِّنۡ عِبَادِنَآ﴾: هو الخَضِرُ، وهو نبيٌّ توفّاه الله.﴿رَحۡمَةࣰ﴾: نبوَّةً."
  18,66,"﴿رُشۡدࣰا﴾: إصابةً للحقِّ وصَوابًا أسترشِدُ به."
  18,68,"﴿خُبۡرࣰا﴾: عِلْمًا ومعرفةً بحقيقتِه."
  18,70,"﴿عَن شَيۡءٍ﴾: أي: تُنْكِرُه عليَّ في عِلْمِكَ.﴿أُحۡدِثَ لَكَ مِنۡهُ ذِكۡرࣰا﴾: أبتدِئُكَ ببيانِه وتَوْضيحِ ما خَفِيَ عليك."
  18,71,"﴿فَٱنطَلَقَا﴾: فسار موسى والخَضِرُ يَمْشِيان على الساحلِ.﴿شَيۡـًٔا إِمۡرࣰا﴾: أمرًا عظيمًا مُنْكَرًا."
  18,73,"﴿وَلَا تُرۡهِقۡنِي﴾: لا تُحَمِّلني وتُكَلِّفني.﴿مِنۡ أَمۡرِي عُسۡرࣰا﴾: في صُحْبتي إياك وتَعَلُّمي منك مشقَّةً."
  18,74,"﴿زَكِيَّةَۢ﴾: نقيةً طاهرةً لم تبلُغْ حَدَّ التكليفِ.﴿بِغَيۡرِ نَفۡسࣲ﴾: بغيرِ حَقٍّ من قِصاصٍ عليها.﴿نُّكۡرࣰا﴾: مُنْكَرًا عظيمًا."
  18,76,"﴿مِن لَّدُنِّي عُذۡرࣰا﴾: إلى الغايةِ التي أعْذُرُكَ في فِراقي بسببِها."
  18,77,"﴿ٱسۡتَطۡعَمَآ أَهۡلَهَا﴾: طَلَبا من أهلِ القريةِ الطعامَ على وجْهِ الضِّيافَةِ.﴿فَأَبَوۡاْ﴾: امتنعُوا.﴿يُرِيدُ﴾: يَقْرُبُ ويُوشِكُ.﴿أَن يَنقَضَّ﴾: أن يسقطَ؛ بسببِ مَيَلانِه.﴿فَأَقَامَهُۥ﴾: سوّاه الخَضرُ وعَدَّلَ ميلَه."
  18,78,"﴿سَأُنَبِّئُكَ﴾: سأُخْبِرُكَ.﴿بِتَأۡوِيلِ﴾: بحقيقةِ مَقْصِدي من أفعالي."
  18,79,"﴿لِمَسَـٰكِينَ﴾: محتاجِين لا يملِكُون ما يَكْفيهم ويَسُدُّ حاجتَهم.﴿أَعِيبَهَا﴾: أُحْدِثَ فيها عَيْبًا بخَرْقِها.﴿وَرَآءَهُم﴾: أمامَهم.﴿كُلَّ سَفِينَةٍ﴾: صالحةٍ غيرِ مَعِيبةٍ.﴿غَصۡبࣰا﴾: قَهْرًا وظُلْمًا."
  18,80,"﴿يُرۡهِقَهُمَا﴾: يَدْفَعَ والدَيه إلى تجاوُزِ حدودِ اللهِ والكفرِ."
  18,81,"﴿زَكَوٰةࣰ﴾: دِينًا وصَلاحًا.﴿رُحۡمࣰا﴾: رحمةً بوالدَيه وبِرًّا بهما."
  18,82,"﴿كَنزࣱ﴾: مالٌ مَدْفونٌ من الذَّهَبِ والفِضَّةِ.﴿يَبۡلُغَآ أَشُدَّهُمَا﴾: قوَّتَهما وكمالَ عَقْلِهما.﴿ذَ ٰ⁠لِكَ تَأۡوِيلُ﴾: الذي بَيَّنْتُ لك أسبابَه هو مآلُ تلك الأمورِ."
  18,83,"﴿وَيَسۡـَٔلُونَكَ﴾: أي: كفارُ قريشٍ بتَلْقينٍ من اليهود.﴿ذِي ٱلۡقَرۡنَيۡنِ﴾: عبدٌ صالحٌ مَلَّكه اللهُ الأرضَ، وأعطاه العِلْمَ والحكمةَ، حتى بَلَغَ سلطانُه المشرقَ والمغربَ، فسُمِّيَ ذا القَرْنين، فكأنه حاز قَرْنَي الدنيا.﴿ذِكۡرًا﴾: خَبَرًا تتذكَّرون به."
  18,84,"﴿مَكَّنَّا لَهُۥ﴾: سَهَّلْنا لَه التَّصَرُّفَ كَيفَ شاءَ.﴿سَبَبࣰا﴾: طَرِيقًا يُوصِلُه إلى مُرادِهِ."
  18,85,"﴿فَأَتۡبَعَ﴾: سَلَك وسارَ.﴿سَبَبًا﴾: طريقًا نَحْوَ الغَرْبِ."
  18,86,"﴿مَغۡرِبَ ٱلشَّمۡسِ﴾: مَوْضِعَ غُرُوبِها، وهُوَ نِهايةُ الأَرْضِ مِنَ الغَرْبِ.﴿عَيۡنٍ﴾: نَبْعٍ جارِيةٍ بالماءِ أو غيرِه.﴿حَمِئَةࣲ﴾: ذاتِ طينٍ أسْودَ.﴿تُعَذِّبَ﴾: بالقتلِ أو غيرِه إنْ لم يُؤمِنُوا.﴿حُسۡنࣰا﴾: بِدعوتِهم إلى الهُدى والرَّشادِ."
  18,87,"﴿ظَلَمَ﴾: نفسَه بكُفْرِه بِرَبِّه.﴿نُّكۡرࣰا﴾: مُنْكَرًا عَظِيمًا في جَهَنَّمَ."
  18,88,"﴿ٱلۡحُسۡنَىٰ﴾: الجنَّةُ.﴿يُسۡرࣰا﴾: سَهْلًا لا مَشَقَّةَ فِيه."
  18,89,"﴿سَبَبًا﴾: طَرِيقًا نَحْوَ الشَّرْقِ."
  18,90,"﴿مَطۡلِعَ ٱلشَّمۡسِ﴾: مَوْضِعَ طُلُوعِها، وهُوَ نِهايةُ الأرْضِ مِنَ الشَّرْقِ.﴿سِتۡرࣰا﴾: ساترًا مِنَ البِناء أوْ الأَشْجار."
  18,91,"﴿كَذَ ٰ⁠لِكَ﴾: كما وصَفْنا أمْرَ ذِي القَرنْيَنِ مِن بُلُوغِه المَغْرِبَ والمشْرِقَ.﴿خُبۡرࣰا﴾: عِلْمًا ومَعْرِفةً."
  18,93,"﴿ٱلسَّدَّيۡنِ﴾: الجَبَلَينِ."
  18,94,"﴿يَأۡجُوجَ وَمَأۡجُوجَ﴾: أُمَّتانِ عظِيمتان مِن بَنِي آدَمَ مَوْجُودتانِ.﴿خَرۡجًا﴾: نَصِيبًا وأجْرًا مِنَ المالِ.﴿سَدࣰّا﴾: حاجِزًا."
  18,95,"﴿رَدۡمًا﴾: حاجِزًا قَوِيًّا."
  18,96,"﴿زُبَرَ ٱلۡحَدِيدِ﴾: قِطَعَه الكَبيرةَ.﴿ٱلصَّدَفَيۡنِ﴾: جانِبَي الجبَلَينِ.﴿أُفۡرِغۡ﴾: أصُبَّ.﴿قِطۡرࣰا﴾: نُحاسًا مُذابًا."
  18,97,"﴿يَظۡهَرُوهُ﴾: يَعْلُوه ويَصْعَدُوا إليه.﴿نَقۡبࣰا﴾: ثَقْبًا؛ لِصَلابَتِه وسَماكَتِه."
  18,98,"﴿وَعۡدُ رَبِّي﴾: وعْدُ رَبِّي بِخُرُوجِ يأجُوجَ ومَأجُوجَ.﴿دَكَّآءَ﴾: مُنْهَدِمًا مُسْتَويًا بالأَرض."
  18,99,"﴿يَمُوجُ﴾: يضْطَرِبُ ويَخْتَلِطُ بَعْضُهم في بَعْضٍ.﴿ٱلصُّورِ﴾: القَرْنِ الذي يُنْفَخُ فيه للبعثِ."
  18,100,"﴿وَعَرَضۡنَا﴾: أبْرَزْنا."
  18,101,"﴿غِطَآءٍ﴾: سِتْرٍ وحِجابٍ.﴿ذِكۡرِي﴾: هُو القرآنُ والآياتُ الكونيةُ.﴿لَا يَسۡتَطِيعُونَ سَمۡعًا﴾: لا يُطِيقُونَ سَماعَ الحُجَجِ والبَراهِينِ بُغْضًا وعِنادًا."
  18,102,"﴿مِن دُونِيٓ أَوۡلِيَآءَ﴾: مِن غيرِي آلهةً.﴿أَعۡتَدۡنَا﴾: أعْدَدْنا وأحْضَرْنا.﴿نُزُلࣰا﴾: مَنزِلًا مُعَدًّا لهم."
  18,104,"﴿ضَلَّ سَعۡيُهُمۡ﴾: ضاعَ عَمَلُهم.﴿يَحۡسَبُونَ أَنَّهُمۡ يُحۡسِنُونَ صُنۡعًا﴾: يَظُنُّونَ أنّهم مُحْسِنُونَ في أعْمالِهم."
  18,105,"﴿فَحَبِطَتۡ﴾: فبَطَلَتْ.﴿وَزۡنࣰا﴾: قَدْرًا وثِقَلًا."
  18,106,"﴿هُزُوًا﴾: مُسْتَهْزَأً بِهما."
  18,107,"﴿جَنَّـٰتُ ٱلۡفِرۡدَوۡسِ﴾: أعلى مَناِزلِ الجنِّةِ وأَوْسَطُها، وهي أفْضَلُها.﴿نُزُلًا﴾: مَنزِلًا مُعدًّا لهم."
  18,108,"﴿لَا يَبۡغُونَ﴾: لا يُرِيدُونَ."
  18,109,"﴿مِدَادࣰا﴾: حِبْرًا للأقْلامِ.﴿لَنَفِدَ﴾: لَفَنِيَ.﴿كَلِمَـٰتُ رَبِّي﴾: عِلْمُه وحِكَمُه وما أوْحاه إلى ملائِكَتِه ورُسُلِه.﴿مَدَدࣰا﴾: زِيادةً."
  18,110,"﴿يَرۡجُواْ﴾: يخافُ عذابَ ربِّه، ويَرْجُو ثَوابَه يومَ لِقائِه."
