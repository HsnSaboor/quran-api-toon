tafsir[52]{c,v,t}:
  51,1,"﴿وَٱلذَّ ٰ⁠رِيَـٰتِ﴾: الرِّياحِ المُثِيراتِ للتُّرابِ."
  51,2,"﴿فَٱلۡحَـٰمِلَـٰتِ﴾: فالسُّحُبِ الحامِلاتِ.﴿وِقۡرࣰا﴾: ثِقَلًا عَظِيمًا مِنَ الماءِ."
  51,3,"﴿فَٱلۡجَـٰرِيَـٰتِ﴾: فالسُّفُنِ الجارِياتِ في البِحارِ.﴿يُسۡرࣰا﴾: جَرْيًا ذا يُسْرٍ وسُهُولةٍ."
  51,4,"﴿فَٱلۡمُقَسِّمَـٰتِ﴾: فالملائِكةِ المُقَسِّماتِ.﴿أَمۡرًا﴾: أمْرَ اللهِ في خَلْقِهِ."
  51,5,"﴿لَصَادِقࣱ﴾: لَكائِنٌ حقٌّ يَقِينٌ."
  51,6,"﴿ٱلدِّينَ﴾: الحِسابَ.﴿لَوَ ٰ⁠قِعࣱ﴾: لَكائِنٌ لا مَحالةَ."
  51,7,"﴿ذَاتِ ٱلۡحُبُكِ﴾: ذاتِ الخَلْقِ الحَسَنِ."
  51,8,"﴿مُّخۡتَلِفࣲ﴾: مُضْطَرِبٍ."
  51,9,"﴿يُؤۡفَكُ﴾: يُصْرَفُ."
  51,10,"﴿قُتِلَ﴾: لُعِنَ.﴿ٱلۡخَرَّ ٰ⁠صُونَ﴾: الكَذّابُونَ الظّانُّونَ غيرَ الحقِّ."
  51,11,"﴿غَمۡرَةࣲ﴾: لُجَّةِ مِنَ الكُفْرِ.﴿سَاهُونَ﴾: غافِلُونَ."
  51,12,"﴿أَيَّانَ﴾: مَتى.﴿يَوۡمُ ٱلدِّينِ﴾: يومُ الجَزاءِ."
  51,13,"﴿يُفۡتَنُونَ﴾: يُعَذَّبُونَ بالإحْرِاقِ بالنّارِ."
  51,14,"﴿فِتۡنَتَكُمۡ﴾: عَذابَكُم."
  51,16,"﴿ءَاخِذِينَ﴾: قابِلينَ على وجْهِ الرِّضا.﴿ءَاتَىٰهُمۡ﴾: أعْطاهُم.﴿مُحۡسِنِينَ﴾: فاعِلِينَ الحَسَناتِ والطّاعاتِ."
  51,17,"﴿يَهۡجَعُونَ﴾: يَنامُونَ."
  51,18,"﴿وَبِٱلۡأَسۡحَارِ﴾: جَمْعُ سَحَر، وهُو آخِرُ الليلِ."
  51,19,"﴿حَقࣱّ﴾: واجِبٌ ثابِتٌ.﴿لِّلسَّآئِلِ﴾: الَّذِي يُظْهِرُ فَقْرَهُ فَيسْأَلُ النّاسَ.﴿وَٱلۡمَحۡرُومِ﴾: الفَقِيرِ الُمتَعَفِّفِ."
  51,20,"﴿لِّلۡمُوقِنِينَ﴾: لِأَهْلِ اليقِينِ بِأنّ اللهَ ورَسُولَه حَقٌّ."
  51,21,"﴿وَفِيٓ أَنفُسِكُمۡ﴾: وفي خَلْقِ أنْفُسِكُم دَلائِلُ وعِبَرٌ."
  51,22,"﴿رِزۡقُكُمۡ﴾: مادَّةُ رِزْقِكُم مِنَ الأمْطارِ وما قَدَّرَهُ اللهُ.﴿وَمَا تُوعَدُونَ﴾: مِنَ الجَزاءِ في الدُّنيا والآخِرةِ."
  51,23,"﴿مِّثۡلَ مَآ أَنَّكُمۡ تَنطِقُونَ﴾: فَتَحَقَّقَ الوعِيدُ مِثْلَ نُطْقِكُم الَّذِي لا تَشُكُّونَ فِيهِ."
  51,24,"﴿ضَيۡفِ إِبۡرَ ٰ⁠هِيمَ﴾: هُم مِن الملائِكةِ."
  51,25,"﴿سَلَـٰمࣰا﴾: سَلَّمنا سَلاما.﴿سَلَـٰمࣱ﴾: أمْرِي سَلامٌ لَكُم.﴿مُّنكَرُونَ﴾: لا أعْرِفُهُم."
  51,26,"﴿فَرَاغَ﴾: فَمال خِفْيَةً."
  51,28,"﴿فَأَوۡجَسَ﴾: أحَسَّ في نَفْسِهِ.﴿بِغُلَـٰمٍ عَلِيمࣲ﴾: هو إسْحاقُ عَلَيهِ السَّلامُ."
  51,29,"﴿صَرَّةࣲ﴾: صَيْحَةٍ.﴿فَصَكَّتۡ﴾: فَلَطَمَتْ.﴿عَقِيمࣱ﴾: لا تَحْمِلُ."
  51,31,"﴿فَمَا خَطۡبُكُمۡ﴾: فَما شَأنُكُم؟"
  51,32,"﴿قَوۡمࣲ مُّجۡرِمِينَ﴾: هُم قَومُ لُوطٍ عَلَيهِ السَّلامُ."
  51,34,"﴿مُّسَوَّمَةً﴾: عَلَيها عَلامةٌ، وكَلُّ حَجَرٍ عَلَيهِ اسْمُ صاحِبِهِ.﴿لِلۡمُسۡرِفِينَ﴾: للمُفَرِّطِينَ بِكُفْرِهِم وشِيُوعِ الفاحِشَةِ فِيهِم."
  51,36,"﴿بَيۡتࣲ﴾: بيتِ لُوطٍ عَلَيهِ السَّلامُ."
  51,37,"﴿تَرَكۡنَا﴾: أبْقينا.﴿ءَايَةࣰ﴾: أثَرًا مِن العَذابِ والخَرابِ يُتَّعظُ بِها."
  51,38,"﴿بِسُلۡطَـٰنࣲ﴾: بِحُجَّةٍ."
  51,39,"﴿فَتَوَلَّىٰ﴾: فَأَعْرَضَ.﴿بِرُكۡنِهِۦ﴾: بِقُوَّتِهِ وجانِبِهِ."
  51,40,"﴿فَأَخَذۡنَـٰهُ﴾: فَأَهْلَكْناهُ.﴿فَنَبَذۡنَـٰهُمۡ﴾: فَطَرحْناهُم.﴿ٱلۡيَمِّ﴾: البَحْرِ.﴿مُلِيمࣱ﴾: مُسْتَوْجِبٌ العِقابَ، آتٍ بِما يَلُومُهُ اللهُ عَلَيهِ."
  51,41,"﴿ٱلۡعَقِيمَ﴾: التي لا بَرَكَةَ فِيها ولا تَأْتِي بِخَيرٍ."
  51,42,"﴿مَا تَذَرُ﴾: ما تَدَعُ.﴿كَٱلرَّمِيمِ﴾: العَظْمِ الَّذِي بَلِي فَتَفَتَّتَ."
  51,43,"﴿تَمَتَّعُواْ﴾: مُباحٌ لكُم أن تَتَمَتَّعُوا بِنِعَمِ الدُّنيا الزّائِلةِ.﴿حَتَّىٰ حِينࣲ﴾: إلى آجالِكُم."
  51,44,"﴿فَعَتَوۡاْ﴾: تَكَبَّرُوا فَأَعْرَضُوا.﴿فَأَخَذَتۡهُمُ﴾: فَأَصابَتْهُم.﴿ٱلصَّـٰعِقَةُ﴾: الصَّيحَةُ العَظِيمَةُ الُمهْلِكَةُ.﴿يَنظُرُونَ﴾: إلى عُقُوبَتِهِم بأَعْيُنِهِم فَيَكُونُ أشَدَّ للعُقُوبَةِ."
  51,45,"﴿قِيَامࣲ﴾: نُهُوضٍ ودِفاعٍ."
  51,47,"﴿بَنَيۡنَـٰهَا﴾: خَلَقْناها وجَعَلْناها سَقْفًا لِلأَرْضِ.﴿بِأَيۡيْدࣲ﴾: بِقُوِّةٍ.﴿لَمُوسِعُونَ﴾: لَمُقْتَدِرُونَ، مِن أوْسَعَ إذا كانَ ذا وُسْعٍ وهي القُدْرَةُ."
  51,48,"﴿فَرَشۡنَـٰهَا﴾: جَعَلْناها فِراشًا لاسْتِقْرارِ الخَلْقِ عَلَيها.﴿ٱلۡمَـٰهِدُونَ﴾: المُوطِّئُونَ الَمُهَيِّئُونَ."
  51,49,"﴿زَوۡجَيۡنِ﴾: صِنْفَينِ ذَكَرًا وأُنْثى."
  51,50,"﴿فَفِرُّوٓاْ﴾: فارِقُوا الشِّرْكَ المُسَبِّبَ لِعَذابِكُم."
  51,52,"51:51"
  51,53,"﴿أَتَوَاصَوۡاْ﴾: هَلْ أوصْىَ بَعْضُهُم بَعْضًا؟﴿طَاغُونَ﴾: مُتَعَدُّونَ، طُغاةٌ عَنْ أمْرِ رَبِّهِم."
  51,54,"﴿فَتَوَلَّ عَنۡهُمۡ﴾: فأَعْرِضْ عَنْهُم.﴿فَمَآ أَنتَ بِمَلُومࣲ﴾: فَلَيسَ عَلَيكَ لَوْمٌ في ذَنْبِهِم."
  51,55,"﴿ٱلذِّكۡرَىٰ﴾: التَّذْكِيرَ والمَوعِظَةَ."
  51,56,"﴿لِيَعۡبُدُونِ﴾: إرادَةَ أن يَعْبُدُونِي إرادَةً شَرْعِيَّةً دِينِيَّةً، وقَدْ تَقَعُ العِبادة وقَدْ لا تَقَعُ."
  51,58,"﴿ٱلۡمَتِينُ﴾: الشَّدِيدُ الكامِلُ في قُوَّتِهِ."
  51,59,"﴿ذَنُوبࣰا﴾: حَظًّا ونَصِيبًا."
  51,60,"﴿فَوَيۡلࣱ﴾: عَذابٌ وهَلاكٌ."
