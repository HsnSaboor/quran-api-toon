tafsir[65]{c,v,t}:
  36,1,"﴿يسٓ﴾: سَبَقَ الكلامُ على الحروفِ المُقَطَّعَةِ في أوَّلِ سُورةِ البقرةِ."
  36,3,"36:2"
  36,4,"﴿صِرَ ٰ⁠طࣲ مُّسۡتَقِيمࣲ﴾: طَرِيقٍ مُعْتَدِلٍ وهو الإسْلامُ."
  36,6,"36:5"
  36,7,"﴿حَقَّ ٱلۡقَوۡلُ﴾: وجَبَ القولُ أي: العذابُ."
  36,8,"﴿أَغۡلَـٰلࣰا﴾: قُيُودًا تَشُدُّ أيدِيَهُم إلى أعناقِهِم تَحتَ أذقانِهم.﴿مُّقۡمَحُونَ﴾: رافِعُونَ رؤوسَهم غاضُّونَ أبْصارَهُم."
  36,9,"﴿سَدࣰّا﴾: حاجِزًا ومانِعًا.﴿فَأَغۡشَيۡنَـٰهُمۡ﴾: غَطَّينا أبْصارَهُم."
  36,11,"﴿أَجۡرࣲ كَرِيمٍ﴾: أجْرٍ حَسَنٍ، وهو دخولُ الجنّةِ."
  36,12,"﴿نُحۡيِ ٱلۡمَوۡتَىٰ﴾: نَبْعَثُهُم بَعْدَ الموتِ.﴿وَءَاثَـٰرَهُمۡ﴾: أي: ما أبْقَوهُ مِنَ الحسَناتِ الَّتي لايَنْقَطِعُ نَفْعُها بَعْدَ الموتِ.﴿إِمَامࣲ مُّبِينࣲ﴾: كِتابٍ واضِحٍ، وهو اللَّوحُ المحفُوظُ."
  36,13,"﴿أَصۡحَـٰبَ ٱلۡقَرۡيَةِ﴾: أهْلَ القَرْيَةِ، وهي «أنْطاكِيَةُ»."
  36,14,"﴿فَعَزَّزۡنَا بِثَالِثࣲ﴾: أي: قوَّيناهُما بِرَسُولٍ ثالِثٍ."
  36,16,"36:15"
  36,17,"36:15"
  36,18,"﴿تَطَيَّرۡنَا بِكُمۡ﴾: تَشاءَمْنا بِكُم.﴿لَنَرۡجُمَنَّكُمۡ﴾: لَنَقْتُلَنَّكُم رَمْيًا بالِحجارَةِ."
  36,19,"﴿طَـٰٓئِرُكُم مَّعَكُمۡ﴾: شُؤْمُكُم مَعَكُم، الذي هو كُفْرُكُم وشِرْكُكُم."
  36,20,"﴿أَقۡصَا ٱلۡمَدِينَةِ﴾: مِن مَّكانٍ بَعِيدٍ فِيها."
  36,22,"﴿فَطَرَنِي﴾: خَلَقَنِي."
  36,23,"﴿وَلَا يُنقِذُونِ﴾: لا يُنَجُّونَنِي مِمّا أنافِيه."
  36,24,"﴿ضَلَـٰلࣲ مُّبِينٍ﴾: خَطَأٍ ظاهِرٍ."
  36,26,"36:25"
  36,27,"36:25"
  36,28,"﴿جُندࣲ﴾: جَيشٍ."
  36,29,"﴿صَيۡحَةࣰ﴾: صَوْتًا مُهلِكًا مِنَ السَّماءِ.﴿خَـٰمِدُونَ﴾: مَيِّتُونَ لا حَراكَ فِيهِم."
  36,30,"﴿يَسۡتَهۡزِءُونَ﴾: يَسْخَرُونَ."
  36,31,"﴿مِّنَ ٱلۡقُرُونِ﴾: مِنَ الأُمَمِ الخالِيةِ."
  36,32,"﴿مُحۡضَرُونَ﴾: نُحْضِرُهُم للحسابِ والجزاءِ."
  36,33,"﴿وَءَايَةࣱ لَّهُمُ﴾: دَلالةٌ لَهُم.﴿ٱلۡأَرۡضُ ٱلۡمَيۡتَةُ﴾: هي الَّتي لا نَباتَ فِيها.﴿أَحۡيَيۡنَـٰهَا﴾: أي: بإنْزالِ المطرِ عَلَيها وإخراجِ النَّباتِ منها."
  36,34,"﴿جَنَّـٰتࣲ﴾: بَساتِينَ.﴿فَجَّرۡنَا﴾: شَقَقْنا."
  36,36,"﴿ٱلۡأَزۡوَ ٰ⁠جَ﴾: الأَصْنافَ والأَنْواعَ."
  36,37,"﴿ءَايَةࣱ لَّهُمُ﴾: علامةٌ لَهُم.﴿نَسۡلَخُ مِنۡهُ﴾: نَنْزِعُ مِنهُ."
  36,38,"﴿لِمُسۡتَقَرࣲّ لَّهَا﴾: مُسْتَقَرُّها تَحْتَ العَرْشِ، كما جاء في الحديثِ المتَّفقِ عَلَيه."
  36,39,"﴿مَنَازِلَ﴾: مسافات، وهي ثمانيةٌ وعِشْرُونَ مَنزِلًا.﴿كَٱلۡعُرۡجُونِ ٱلۡقَدِيمِ﴾: كالعِذْقِ اليابسِ المتَقَوِّسِ."
  36,40,"﴿أَن تُدۡرِكَ﴾: أن تَلْحَقَ.﴿فَلَكࣲ﴾: مَدارٍ.﴿يَسۡبَحُونَ﴾: يَدُورُونَ في فَلَكِ السَّماءِ بانْبِساطٍ وسُهُولَةٍ."
  36,41,"﴿ءَايَةࣱ لَّهُمۡ﴾: دليلٌ لَهُم.﴿ٱلۡمَشۡحُونِ﴾: الممْلُوءِ."
  36,43,"﴿صَرِيخَ لَهُمۡ﴾: مُغِيثَ لَهُم.﴿يُنقَذُونَ﴾: يُخَلَّصُونَ مِنَ الغَرَقِ."
  36,45,"﴿مَا بَيۡنَ أَيۡدِيكُمۡ﴾: مِنَ الآخرةِ وأهْوالِها.﴿وَمَا خَلۡفَكُمۡ﴾: مِن أحْوالِ الدُّنيا وعِقابِها."
  36,47,"36:46"
  36,48,"36:46"
  36,49,"﴿يَنظُرُونَ﴾: ينتظِرُونَ.﴿صَيۡحَةࣰ وَ ٰ⁠حِدَةࣰ﴾: هي نَفْخَةُ الفَزَعِ عِنْدَ قِيامِ السّاعةِ.﴿يَخِصِّمُونَ﴾: يَخْتَصِمُونَ في شُؤونِ حياتِهم غافِلينَ عَن يَوْمِ القيامةِ."
  36,50,"﴿تَوۡصِيَةࣰ﴾: وصِيَّةً."
  36,51,"﴿ٱلصُّورِ﴾: «القَرْنِ» الذي يُنفَخُ فيه للبعث.﴿ٱلۡأَجۡدَاثِ﴾: القُبُورِ.﴿يَنسِلُونَ﴾: يُسْرِعُونَ في الخُرُوجِ."
  36,52,"﴿يَـٰوَيۡلَنَا﴾: يا هَلاكَنا.﴿مَنۢ بَعَثَنَا﴾: مَن أحْيانا؟﴿مِن مَّرۡقَدِنَاۜ﴾: مِن قُبُورِنا."
  36,53,"﴿صَيۡحَةࣰ وَ ٰ⁠حِدَةࣰ﴾: نَفْخَةً واحِدَةً.﴿مُحۡضَرُونَ﴾: نُحْضِرُهم للحِسابِ والجَزاءِ."
  36,55,"﴿فِي شُغُلࣲ﴾: في نَعِيمٍ عَظِيمٍ يُلْهِيهِم عمّا سِواه.﴿فَـٰكِهُونَ﴾: مُتَلَذِّذُونَ."
  36,56,"﴿ٱلۡأَرَآئِكِ﴾: الأَسِرَّةِ المزَيَّنةِ."
  36,57,"﴿مَّا يَدَّعُونَ﴾: ما يَشْتَهُونَ."
  36,59,"﴿وَٱمۡتَـٰزُواْ﴾: تميَّزُوا، وانفرِدُوا عَنِ المؤمِنِينَ."
  36,60,"﴿أَعۡهَدۡ إِلَيۡكُمۡ﴾: أُوصِكُم وأُبَلِّغْكُم."
  36,62,"﴿جِبِلࣰّا﴾: خَلْقًا."
  36,64,"﴿ٱصۡلَوۡهَا﴾: ادخُلُوا جَهَنَّمَ وقاسُوا حَرَّها."
  36,65,"﴿نَخۡتِمُ﴾: نَطْبَعُ."
  36,66,"﴿لَطَمَسۡنَا عَلَىٰٓ أَعۡيُنِهِمۡ﴾: لصَيرَّناها مَمْسُوحَةً لا يُرى لها شِقٌّ ولا جَفْنٌ.﴿فَٱسۡتَبَقُواْ ٱلصِّرَ ٰ⁠طَ﴾: بادَرُوا إليه.﴿فَأَنَّىٰ يُبۡصِرُونَ﴾: فكيفَ يُبْصِرُونَ وقد طُمِسَتْ أبْصارُهُم؟"
  36,67,"﴿لَمَسَخۡنَـٰهُمۡ عَلَىٰ مَكَانَتِهِمۡ﴾: لَغَيَّرْنا خَلْقَهم في المكانِ الَّذي هم فيهِ.﴿مُضِيࣰّا﴾: أي: ذَهابًا إلى الأمامِ."
  36,68,"﴿نُّعَمِّرۡهُ﴾: نُطِلْ عُمُرَه.﴿نُنَكِّسۡهُ فِي ٱلۡخَلۡقِ﴾: نَرُدَّه إلى أرْذَلِ العُمُرِ وأَضْعَفِه."
  36,70,"﴿وَيَحِقَّ ٱلۡقَوۡلُ﴾: أي: تَجِبَ كلمةُ العذابِ."
  36,71,"﴿مِّمَّا عَمِلَتۡ أَيۡدِينَآ﴾: أي: مما أبْدَعْناهُ وعَمِلْناهُ.﴿لَهَا مَـٰلِكُونَ﴾: مالِكُونَ أمْرَها، يَتَصَرَّفُونَ بِها كيفَ شاؤُوا."
  36,72,"﴿ذَلَّلۡنَـٰهَا﴾: سَخَّرْناها لَهُم.﴿رَكُوبُهُمۡ﴾: مَرْكُوبُهم الّذي يَرْكَبُونَه."
  36,74,"36:73"
  36,75,"﴿وَهُمۡ لَهُمۡ جُندࣱ مُّحۡضَرُونَ﴾: والحالُ أنَّ هذه الآلهةَ قَدْ أُحْضِرَتْ مُجْتَمِعَةً لِتُعايِنَ عذابَ عابِديِها، وهي لا تَسْتَطِيعُ نَصْرَهُم."
  36,77,"﴿مِن نُّطۡفَةࣲ﴾: هي مَنِيُّ الرَّجُلِ يقْذِفُه في رَحمِ امْرَأتِه.﴿خَصِيمࣱ﴾: كثيرُ الخُصُومَةِ بالباطلِ."
  36,78,"﴿رَمِيمࣱ﴾: باليةٌ مُتفَتِّتةٌ."
  36,79,"﴿أَنشَأَهَآ﴾: خَلَقَها."
  36,80,"﴿مِّنۡهُ تُوقِدُونَ﴾: تَقْدَحُونَ منه."
  36,82,"36:81"
  36,83,"﴿مَلَكُوتُ﴾: هو المُلْكُ التّامُّ للأشياءِ كلِّها."
