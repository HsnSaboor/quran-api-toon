tafsir[19]{c,v,t}:
  58,1,"﴿تُجَـٰدِلُكَ﴾: تُراجِعُكَ الكَلامَ في زَوْجِها وهي خَوْلَةُ بِنْتُ ثَعْلَبةَ وزَوْجُها أوسُ بنُ الصّامتِ.﴿تَحَاوُرَكُمَآ﴾: تَخاطُبَكُما ومُراجَعَتَكُما الكَلامَ."
  58,2,"﴿يُظَـٰهِرُونَ﴾: يَقُولُ الرَّجُلُ مِنهُم لِزوجَتِهِ: «أنْتِ عَليَّ كَظَهْرِ أُمِّي» أي في حُرْمَةِ النِّكاحِ."
  58,3,"﴿ۡ ثُمَّ يَعُودُونَ لِمَا قَالُواْ﴾: ثُمَّ يَرْجِعُونَ عَن قَوْلِهِم ويَعْزِمُونَ على وطْءِ نِسائِهِم.﴿يَتَمَآسَّا﴾: يَمَسَّ أحَدُهُما الآخَرَ، وهي كِنايةٌ عَنِ الِجماعِ."
  58,4,"﴿مِسۡكِينࣰا﴾: هو الَّذِي لا يَمْلِكُ ما يَكْفِيهِ ويَسُدُّ حاجَتَهُ."
  58,5,"﴿يُحَآدُّونَ﴾: يُشاقُّونَ ويُخالِفُونَ.﴿كُبِتُواْ﴾: خُذِلُوا وأُهِينُوا.﴿مُّهِينࣱ﴾: مُذِلٌّ."
  58,6,"﴿أَحۡصَىٰهُ ٱللَّهُ﴾: كَتَبهُ في اللَّوح المحْفُوظِ، وحَفِظَهُ عَلَيهم في صحائفِ أعْمالِهِم.﴿شَهِيدٌ﴾: شاهِدٌ يَعْلَمُهُ ويُحِيطُ بِهِ، فلا يعْزُبُ عنه شَيءٌ مِنهُ."
  58,7,"﴿نَّجۡوَىٰ﴾: مُناجاةٍ ومُسارَّةٍ وما يَكْتُمُهُ النّاسُ مِن أحادِيثِهِم.﴿هُوَ رَابِعُهُمۡ﴾: مُشاهِدُهُم بِعِلْمِهِ، وهو عَلى عَرْشِهِ.﴿وَلَآ أَدۡنَىٰ مِن ذَ ٰ⁠لِكَ﴾: ولا أقَلَّ مِن ذَلِكَ.﴿هُوَ مَعَهُمۡ﴾: بِعِلْمِه وهُوَ فَوْقَ العَرْشِ."
  58,8,"﴿ٱلنَّجۡوَىٰ﴾: حَدِيثِ السِّرِّ الَّذِي يُثيرُ الشَّكَ في نُفُوسِ المؤمِنينَ.﴿وَيَتَنَـٰجَوۡنَ﴾: يَتَحَدَّثُونَ سِرًّا.﴿حَيَّوۡكَ﴾: سَلَّمُوا عَلَيكَ.﴿حَسۡبُهُمۡ﴾: كافِيهِم مِنَ العَذابِ.﴿يَصۡلَوۡنَهَا﴾: يَدْخُلُونَها ويُقاسُونَ حَرَّها.﴿فَبِئۡسَ ٱلۡمَصِيرُ﴾: فَساءَ المنْقَلَبُ والمرْجِعُ."
  58,10,"58:9"
  58,11,"﴿تَفَسَّحُواْ﴾: لِيُوسِّعْ بَعْضُكُم لِبَعْضٍ المَجالِسَ.﴿يَفۡسَحِ ٱللَّهُ لَكُمۡ﴾: يُوَسِّعِ اللهُ عَلَيكُم في الدُّنيا والآخِرةِ.﴿ٱنشُزُواْ﴾: قُومُوا من مجالِسِكُم.﴿يَرۡفَعِ﴾: يَرْفَعْ مَكانَةً.﴿دَرَجَـٰتࣲ﴾: مَراتِبَ رَفِيَعةً في دِينِهِم."
  58,12,"﴿نَـٰجَيۡتُمُ ٱلرَّسُولَ﴾: أرَدْتُم أن تُكَلِّمُوا رَسُولَ اللهِ ﷺ سرًّا.﴿وَأَطۡهَرُ﴾: وأَزْكى لِقُلُوبِكُم مِنَ المأثَمِ."
  58,13,"﴿ءَأَشۡفَقۡتُمۡ﴾: أخَشِيتُم الفَقْرَ عَقِبَ تَقْدِيمِ الصَّدَقةِ؟"
  58,14,"﴿تَوَلَّوۡاْ قَوۡمًا﴾: اتخذوهم أصدقاءَ يُحِبُّونهم وينصرونهم."
  58,16,"﴿جُنَّةࣰ﴾: وِقايِةً وسِتْرَةً.﴿مُّهِينࣱ﴾: مُذِلٌّ في النّارِ."
  58,17,"﴿لَّن تُغۡنِيَ﴾: لَن تَدْفَعَ."
  58,19,"﴿ٱسۡتَحۡوَذَ﴾: غَلَبَ واسْتَولى.﴿فَأَنسَىٰهُمۡ﴾: جَعَلَهُم يَتْرُكُونَ.﴿ذِكۡرَ ٱللَّهِ﴾: تَوْحِيدَ اللهِ، والعَمَلَ بِطاعَتِهِ."
  58,20,"﴿يُحَآدُّونَ﴾: يُخالِفُونَ.﴿ٱلۡأَذَلِّينَ﴾: مِن جُمْلةِ الأذِلّاءِ المغلوبِينَ المهانِينَ."
  58,21,"﴿كَتَبَ﴾: قَضى وكَتَبَ في اللَّوحِ المحْفُوظِ.﴿لَأَغۡلِبَنَّ﴾: لَتَكونَنَّ الغَلَبةُ بِالقُوَّةِ للهِ ولِرُسُلِهِ.﴿عَزِيزࣱ﴾: مانِعٌ حِزْبَهُ مِن أن يُذَلَّ."
  58,22,"﴿يُوَآدُّونَ﴾: يُحِبُّونَ ويُوالُونَ.﴿حَآدَّ﴾: عادى.﴿عَشِيرَتَهُمۡ﴾: أقْرِباءَهُم.﴿كَتَبَ﴾: ثَبَّتَ.﴿وَأَيَّدَهُم﴾: قَوّاهُم.﴿بِرُوحࣲ﴾: بِنَصْرٍ وتأْيِيدٍ.﴿حِزۡبَ ٱللَّهِ﴾: أولياؤُهُ.﴿ٱلۡمُفۡلِحُونَ﴾: الفائِزُونَ بِسَعادةِ الدُّنيا والآخِرَةِ."
