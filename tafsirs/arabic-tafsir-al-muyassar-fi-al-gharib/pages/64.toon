tafsir[17]{c,v,t}:
  64,1,"﴿يُسَبِّحُ﴾: يُنَزِّهُ.﴿ٱلۡحَمۡدُ﴾: الثَّناءُ الحسنُ الجميلُ."
  64,3,"﴿وَصَوَّرَكُمۡ﴾: خَلَقَكُم.﴿ٱلۡمَصِيرُ﴾: المَرْجِعُ يَومَ القِيامَةِ."
  64,4,"﴿تُسِرُّونَ﴾: تُخْفُونَ.﴿تُعۡلِنُونَ﴾: تُظْهِرُونَهُ.﴿بِذَاتِ ٱلصُّدُورِ﴾: بما تُخْفِيهِ النَّفُوسُ."
  64,5,"﴿فَذَاقُواْ﴾: حَلَّ بِهِم.﴿وَبَالَ﴾: سُوءَ عاقِبَةِ."
  64,6,"﴿بِٱلۡبَيِّنَـٰتِ﴾: الآياتِ الواضِحاتِ والمُعْجِزاتِ الظّاهراتِ.﴿وَتَوَلَّواْ﴾: أعْرَضُوا عَنِ الحَقِّ.﴿وَّٱسۡتَغۡنَى ٱللَّهُ﴾: عَنْ عِبادَتِهِم وإيمانِهِم.﴿حَمِيدࣱ﴾: مَحْمُودٌ في أقوالِهِ وأفعالِهِ وصِفاتِهِ."
  64,7,"﴿يُبۡعَثُواْ﴾: يُخْرَجُوا مِن قُبُورِهِم.﴿يَسِيرࣱ﴾: هِيِّنٌ."
  64,8,"﴿وَٱلنُّورِ﴾: واهْتَدُوا بالقرآنِ."
  64,9,"﴿لِيَوۡمِ ٱلۡجَمۡعِ﴾: لِيومِ الحَشْرِ.﴿ٱلتَّغَابُنِ﴾: الغَبْنُ والتَّفاوُتُ بَينَ الخَلْقِ.﴿يُكَفِّرۡ﴾: يَمْحُ.﴿تَحۡتِهَا﴾: تَحْتِ قُصُورِها وأَشْجارِها."
  64,10,"﴿وَبِئۡسَ ٱلۡمَصِيرُ﴾: وساءَ المَرْجِعُ الَّذِي صارُوا إلَيهِ، وهو جَهَنَّمُ."
  64,11,"﴿مُّصِيبَةٍ﴾: مَكْرُوهٍ.﴿بِإِذۡنِ ٱللَّهِ﴾: بمشيئته.﴿يَهۡدِ﴾: يُوَفِقْهُ اللهُ إلى مَرْضاتِهِ."
  64,12,"﴿تَوَلَّيۡتُمۡ﴾: أعْرَضْتُم عَن طاعَةِ اللهِ."
  64,13,"﴿ٱللَّهُ لَآ إِلَـٰهَ إِلَّا هُوَ﴾: لا مَعْبُودَ بِحَقٍّ سِواهُ.﴿فَلۡيَتَوَكَّلِ﴾: فَلْيَعْتَمِدوا في كُلِّ الأُمُورِ."
  64,14,"﴿عَدُوࣰّا لَّكُمۡ﴾: أي: يَمْنَعُونَكُم مِنَ الإسْلامِ أو الهِجْرَةِ أو يكُونونَ سَبَبًا لِلْمَعاصِي.﴿وَإِن تَعۡفُواْ﴾: تَتَجاوَزُوا عَن سَيِّئاتِهِم.﴿وَتَغۡفِرُواْ﴾: وتَسْتُرُوها عَلَيهِم."
  64,15,"﴿فِتۡنَةࣱ﴾: اخِتبارٌ لَكُم وشُغْلٌ عَنِ الآخِرَةِ.﴿أَجۡرٌ﴾: ثَوابٌ."
  64,16,"﴿مَا ٱسۡتَطَعۡتُمۡ﴾: أطَقْتُم.﴿خَيۡرࣰا﴾: يَكُنْ خَيرًا.﴿وَمَن يُوقَ شُحَّ نَفۡسِهِۦ﴾: ومَن سَلِمَ مِنَ البُخْلِ والحِرْصِ.﴿ٱلۡمُفۡلِحُونَ﴾: الظّافِرُونَ بِكُلِّ خَيرٍ."
  64,17,"﴿تُقۡرِضُواْ ٱللَّهَ﴾: تُنْفِقُوا أمْوالَكُم في سَبِيلِ اللهِ بِإخْلاصٍ وطِيبِ نَفْسٍ.﴿شَكُورٌ﴾: مُجازٍ على الطّاعةِ.﴿حَلِيمٌ﴾: لا يَعْجَلُ بالعُقُوبَةِ عَلى مَن عَصاهُ."
  64,18,"﴿ٱلۡغَيۡبِ﴾: ما غابَ.﴿ٱلشَّهَـٰدَةِ﴾: ما لم يَغِبْ عَنِ الأَبْصارِ."
