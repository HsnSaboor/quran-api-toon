tafsir[10]{c,v,t}:
  101,1,"﴿ٱلۡقَارِعَةُ﴾: السّاعةُ الَّتِي تَقْرَعُ قُلُوبَ النّاسِ بِأَهْوالِها."
  101,3,"﴿وَمَآ أَدۡرَىٰكَ﴾: وأيُّ شَيءٍ أعَلَمَكَ بِها؟"
  101,4,"﴿كَٱلۡفَرَاشِ ٱلۡمَبۡثُوثِ﴾: كالفَراشِ المُنْتَشِرِ."
  101,5,"﴿كَٱلۡعِهۡنِ ٱلۡمَنفُوشِ﴾: كالصُّوفِ المُتَعَدِّدِ الألوانِ الَّذِي يُنْفَشُ باليدِ، فَيَصِيرُ هَباءً ويَزُولُ."
  101,6,"﴿مَن ثَقُلَتۡ مَوَ ٰ⁠زِينُهُۥ﴾: مَن رَجَحَتْ مَوازِينُ حَسَناتِهِ."
  101,7,"﴿عِيشَةࣲ رَّاضِيَةࣲ﴾: حياةٍ مُرْضِيَةٍ في الجنَّةِ."
  101,8,"﴿مَنۡ خَفَّتۡ مَوَ ٰ⁠زِينُهُۥ﴾: مَن خَفَّتْ مَوازِينُ حسناتِهِ ورَجَحَتْ مَوازينُ سَيِّئاتِهِ."
  101,9,"﴿فَأُمُّهُۥ هَاوِيَةࣱ﴾: فَمَأواهُ جَهَنَّمُ؛ لِأنّهُ يَهْوِي فِيها عَلى أُمِّ رَأْسِهِ."
  101,10,"﴿وَمَآ أَدۡرَىٰكَ﴾: وأيُّ شَيءٍ أعْلَمكَ؟﴿مَا هِيَهۡ﴾: ما هذهِ الهاوِيةُ؟."
  101,11,"﴿حَامِيَةُۢ﴾: قَدْ حَمِيَتْ مِنَ الوَقُودِ عَلَيها."
