tafsir[40]{c,v,t}:
  50,1,"﴿قٓ﴾: سَبَقَ الكلامُ على الحُروفِ المُقَطَّعةِ في أوَّلِ سُورَةِ البقرةِ.﴿ٱلۡمَجِيدِ﴾: ذي المجْدِ والشَّرَفِ."
  50,2,"﴿عَجِيبٌ﴾: مُسْتَغْرَبٌ يُتَعَجَّبُ مِنهُ."
  50,3,"﴿رَجۡعُۢ﴾: بَعْثٌ."
  50,4,"﴿تَنقُصُ ٱلۡأَرۡضُ﴾: تُفْنِي مِن أجْسامِهِم.﴿حَفِيظُۢ﴾: مَحفُوظٌ."
  50,5,"﴿مَّرِيجٍ﴾: مُخْتَلِطٍ مُضْطَرِبٍ."
  50,6,"﴿فُرُوجࣲ﴾: شُقُوقٍ وُصُدُوعٍ."
  50,7,"﴿مَدَدۡنَـٰهَا﴾: بَسَطْناها.﴿رَوَ ٰ⁠سِيَ﴾: جِبالًا ثَوابِتَ.﴿زَوۡجِۭ﴾: نَوْعٍ وجِنْسٍ.﴿بَهِيجࣲ﴾: حَسَنِ المنْظَر."
  50,8,"﴿تَبۡصِرَةࣰ﴾: تَجْعَلُ المرءَ مُبْصِرًا.﴿وَذِكۡرَىٰ﴾: تُذَكِّرُ النّاسِي.﴿مُّنِيبࣲ﴾: رَجّاعٍ إلى اللهِ."
  50,9,"﴿مُّبَـٰرَكࣰا﴾: كَثِيرَ الخيَرِ والمنافِعِ.﴿وَحَبَّ ٱلۡحَصِيدِ﴾: وحَبَّ الزَّرْعِ المحْصُودِ."
  50,10,"﴿بَاسِقَـٰتࣲ﴾: مُرْتَفِعاتٍ.﴿طَلۡعࣱ﴾: هُو أوَّلُ ما يَظْهَرُ مِن ثَمَرِ التَّمْرِ وهُو غِلافُ العُنْقُودِ.﴿نَّضِيدࣱ﴾: مَنضُودٌ، مُصَفَّفٌ بعْضُهُ فَوْقَ بَعْضٍ."
  50,11,"﴿مَّيۡتࣰا﴾: أجْدَبَتْ وقَحَطَتْ.﴿كَذَ ٰ⁠لِكَ﴾: كَما أحْيا اللهُ هَذِه الأَرْضَ الميتَةَ.﴿ٱلۡخُرُوجُ﴾: خَرُوجُ النّاسِ يَومَ البعْثِ."
  50,12,"﴿ٱلرَّسِّ﴾: البِئْرِ."
  50,14,"﴿وَأَصۡحَـٰبُ ٱلۡأَيۡكَةِ﴾: أصْحابُ الشَّجَرِ المُلْتَفِّ وهم قُوُم شُعَيبٍ عَلَيهِ السَّلامُ.﴿وَقَوۡمُ تُبَّعࣲ﴾: هُم سَبأٌ، وتُبَّعٌ هُوَ أحَدُ مُلُوكِ اليمَنِ.﴿فَحَقَّ﴾: صَدَقَ وتَحَقَّقَ.﴿وَعِيدِ﴾: إنذارِي بالعُقُوبةِ."
  50,15,"﴿أَفَعَيِينَا﴾: أفَعَجَزْنا.﴿لَبۡسࣲ﴾: اشْتِباهٍ وشَكٍّ.﴿خَلۡقࣲ جَدِيدࣲ﴾: قِيامِ الخَلْقِ في البَعْثِ."
  50,16,"﴿مَا تُوَسۡوِسُ بِهِۦ﴾: تُحَدِّث بِه.﴿حَبۡلِ ٱلۡوَرِيدِ﴾: عِرْقِ العُنُقِ المُتَّصِلِ بالقلبِ."
  50,17,"﴿يَتَلَقَّى﴾: يُسَجِّلُ.﴿ٱلۡمُتَلَقِّيَانِ﴾: المَلَكانِ المُوكَّلانِ بِكِتابَةِ أعْمالِ النّاسِ وأَقْوالِهِم.﴿عَنِ ٱلۡيَمِينِ﴾: عَن يَمِينِ الإنْسانِ.﴿قَعِيدࣱ﴾: مُقاعِدٌ، مِثْلُ جَلِيسٍ للمُجالِسِ."
  50,18,"﴿رَقِيبٌ﴾: مَلَكٌ يَرْقُبُ قَوْلَهُ ويَكْتُبُهُ.﴿عَتِيدࣱ﴾: حاضِرٌ مُعَدٌّ لِذَلِكَ."
  50,19,"﴿سَكۡرَةُ ٱلۡمَوۡتِ﴾: شِدَّةُ غَمَراتِ الموتِ.﴿تَحِيدُ﴾: تَفِرُّ وتَهْرُبُ."
  50,20,"﴿ٱلصُّورِ﴾: القَرْنِ الَّذِي يَنْفُخُ فِيهِ إسْرافِيلُ.﴿يَوۡمُ ٱلۡوَعِيدِ﴾: أي الَّذِي تَوَعَّدَ اللهُ بِه الكُفّارَ."
  50,21,"﴿سَآئِقࣱ﴾: مَلَكٌ يَسُوقُ الإنْسانَ إلى المَحْشَرِ.﴿وَشَهِيدࣱ﴾: مَلَكٌ يَشْهَدُ عَلى النَّفْسِ بِما عَمِلَتْ."
  50,22,"﴿حَدِيدࣱ﴾: قَوِيُّ الَّنفاذِ في المرئِي."
  50,23,"﴿قَرِينُهُۥ﴾: المَلَكُ الكاتِبُ الشَّهِيدُ عَلَيهِ.﴿عَتِيدٌ﴾: مُهَيَّأٌ محفُوظٌ."
  50,24,"﴿عَنِيدࣲ﴾: مُعانِدٍ لِلْحَقِّ."
  50,25,"﴿مُعۡتَدࣲ﴾: ظالِمٍ مُتَجاوِزٍ لْلِحَقِّ.﴿مُّرِيبٍ﴾: شاكٍّ."
  50,27,"﴿قَرِينُهُۥ﴾: شَيْطانُه الَّذِي كانَ مُوَكَّلًا بِهِ في الدُّنيا.﴿مَآ أَطۡغَيۡتُهُۥ﴾: ما أضْلَلْتُهُ.﴿ضَلَـٰلِۭ﴾: طَرِيقٍ بَعِيدٍ عن سَبِيلِ الهُدى."
  50,28,"﴿قَدَّمۡتُ إِلَيۡكُم بِٱلۡوَعِيدِ﴾: أعْلَمْتُكُم ما يَنْتَظِرُ العاصِيَ مِن العُقُوبَةِ."
  50,30,"﴿مَّزِيدࣲ﴾: زِيادةٍ في وارِدِيها."
  50,31,"﴿وَأُزۡلِفَتِ﴾: وقُرِّبَتْ.﴿غَيۡرَ بَعِيدٍ﴾: مَكانًا غَيرَ بَعِيدٍ مِنَ المُتَّقِينَ."
  50,32,"﴿أَوَّابٍ﴾: كَثِيرِ الرُّجُوعِ مِن ذُنُوبِهِ.﴿حَفِيظࣲ﴾: حافظٍ لِكُلِّ عَمَلٍ صالِحٍ قَرَّبَهُ إلى ربِّهِ."
  50,33,"﴿بِٱلۡغَيۡبِ﴾: في حالِ غِيابهِ عَنْ أعْيُنِ النّاسِ.﴿مُّنِيبٍ﴾: تائبٍ مِن ذُنُوبِهِ."
  50,34,"﴿بِسَلَـٰمࣲ﴾: وأَنْتُم سالِمُونَ.﴿يَوۡمُ ٱلۡخُلُودِ﴾: هُوَ الَّذِي لا زَوالَ لَهُ ولا مَوْتَ."
  50,35,"﴿مَزِيدࣱ﴾: النَّظَرُ إلى وجْهِ اللهِ الكريمِ."
  50,36,"﴿مِّن قَرۡنٍ﴾: مِن أُمَّةٍ.﴿بَطۡشࣰا﴾: قُوَّةً وسَطْوَةً.﴿فَنَقَّبُواْ﴾: فَطَوَّفُوا.﴿مَّحِيصٍ﴾: مَهْرَبٍ مِن عَذابِ اللهِ."
  50,37,"﴿قَلۡبٌ﴾: عَقْلٌ.﴿أَلۡقَى ٱلسَّمۡعَ﴾: أصْغى السَّمْعَ، واسْتَمَعَ بِأُذُنَيْهِ.﴿شَهِيدࣱ﴾: حاضِرٌ بِقَلْبِهِ."
  50,38,"﴿وَمَا مَسَّنَا﴾: وما أصابَنا.﴿لُّغُوبࣲ﴾: تَعَبٍ."
  50,40,"﴿وَأَدۡبَـٰرَ ٱلسُّجُودِ﴾: عَقِبَ الصَّلَواتِ."
  50,41,"﴿وَٱسۡتَمِعۡ﴾: أيُّها النَّبِيُّ لِما أُخْبِرُكَ بِهِ مِن أهْوالِ يَوْمِ القِيامَةِ.﴿ٱلۡمُنَادِ﴾: هُوَ المَلَكُ المُوَكَّلُ بِنَفْخِ الصُّورِ.﴿مَّكَانࣲ قَرِيبࣲ﴾: صَخْرَةِ بَيتِ المَقْدِسِ."
  50,42,"﴿بِٱلۡحَقِّ﴾: بِالصِّدْقِ.﴿يَوۡمُ ٱلۡخُرُوجِ﴾: يومُ البَعْثِ مِنَ القُبُورِ."
  50,44,"﴿تَشَقَّقُ﴾: تَتَصَدَّعُ.﴿سِرَاعࣰا﴾: مُسْرِعِينَ."
  50,45,"﴿بِجَبَّارࣲ﴾: بِمُسَلَّطٍ عَلَيهِم تُجْبِرُهُم عَلى الإيمانِ."
