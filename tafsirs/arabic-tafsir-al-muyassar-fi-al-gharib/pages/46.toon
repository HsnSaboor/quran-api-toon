tafsir[28]{c,v,t}:
  46,1,"﴿حمٓ﴾: سبق شَرْحُ الحروفِ المقطَّعةِ أوَّلَ سُورةِ البَقَرَةِ."
  46,3,"﴿وَأَجَلࣲ مُّسَمࣰّى﴾: وتَعْيِينِ ساعَةٍ مُحَدَّدَةٍ لِبَقائِهِما."
  46,4,"﴿شِرۡكࣱ﴾: شِرْكَةٌ ونَصِيبٌ.﴿مِّن قَبۡلِ هَـٰذَآ﴾: مِن قَبْل هذا القرآنِ.﴿أَثَـٰرَةࣲ﴾: بَقِيَّةٍ تُؤْثَرُ عَنِ الأوَّلِينَ."
  46,6,"﴿كَانُواْ لَهُمۡ﴾: كانَتِ الأصْنامُ للعابِدِينَ."
  46,8,"﴿فَلَا تَمۡلِكُونَ لِي﴾: فَلا تَقْدِرُونَ على أن تَرُدُّوا عَنِّي.﴿تُفِيضُونَ﴾: وتُكْثِرُونَ القَوْلَ فِيهِ، وتَخُوضُونَ وتتوسَّعُونَ."
  46,9,"﴿بِدۡعࣰا﴾: أوَّلَ مَبْعُوثٍ، فَقَدْ كانَ قَبْلِي رُسُلٌ."
  46,10,"﴿أَرَءَيۡتُمۡ﴾: أخْبِرُونِي.﴿شَاهِدࣱ﴾: هُوَ عَبْدُاللهِ بْنُ سَلامٍ.﴿عَلَىٰ مِثۡلِهِۦ﴾: أي القُرآنِ، مِنَ المعانِي الموجُودَةِ في التَّوراةِ."
  46,11,"﴿مَّا سَبَقُونَآ إِلَيۡهِ﴾: ما سَبَقَنا فُقَراءُ المسِلمِينَ إلى الإيمانِ.﴿إِفۡكࣱ﴾: كَذِبٌ."
  46,12,"﴿إِمَامࣰا﴾: يُقْتَدى بِهِ في الدِّينِ.﴿مُّصَدِّقࣱ﴾: لِكِتاب مُوسى وغيرِه من كُتُب اللهِ."
  46,14,"46:13"
  46,15,"﴿كُرۡهࣰا﴾: مَشَقَّةً.﴿وَفِصَـٰلُهُۥ﴾: وفِطامُهُ.﴿أَشُدَّهُۥ﴾: نِهايةَ قُوَّتِهِ البَدَنِيَّةِ والعقْلِيَّةِ.﴿أَوۡزِعۡنِيٓ﴾: ألْهِمْنِي."
  46,16,"﴿فِيٓ أَصۡحَـٰبِ ٱلۡجَنَّةِ﴾: في جُمْلة أصْحابِ الجنَّة."
  46,17,"﴿أُفࣲّ﴾: اسْمُ فِعْلٍ مَعْناه: أتَضَجَّرُ.﴿أُخۡرَجَ﴾: أُبْعَثَ بَعْدَ الموتِ.﴿خَلَتِ﴾: مَضَتِ.﴿ٱلۡقُرُونُ﴾: جَمْعُ قَرْنٍ وهو الأُمَّةُ الَّتي تَقارَبَ زَمانُ حياتِها أي: فماتُوا ولم يُبْعَثْ مِنهُم أحَدٌ؟﴿يَسۡتَغِيثَانِ ٱللَّهَ﴾: يَطْلُبانِ عَوْنَهُ.﴿وَيۡلَكَ﴾: هَلاكًا لَكَ.﴿أَسَـٰطِيرُ﴾: القِصَصُ الباطِلةُ."
  46,18,"﴿حَقَّ عَلَيۡهِمُ ٱلۡقَوۡلُ﴾: وجَبَ عَلَيهِمُ القَوْلُ بالعَذابِ."
  46,20,"﴿أَذۡهَبۡتُمۡ﴾: يقُولُ اللهُ لَهُم ذَلِكَ.﴿ٱلۡهُونِ﴾: الهَوانِ والذُّلِّ.﴿تَفۡسُقُونَ﴾: تَخْرُجُونَ عَن طاعَةِ اللهِ بالشِّرْكِ."
  46,21,"﴿بِٱلۡأَحۡقَافِ﴾: الرِّمالِ الكثِيرَةِ الَّتي لَمْ تَبْلُغْ أن تَكُونَ جَبَلًا، وتَقَعُ في جَنُوبِ الجزِيرَةِ العَرَبِيَّةِ، وهي مَنازلُ عادٍ قَومِ هُودٍ.﴿ٱلنُّذُرُ﴾: جَمْعُ النَّذِيرِ وهو الرَّسُولُ."
  46,22,"﴿لِتَأۡفِكَنَا﴾: لِتَصْرِفَنا."
  46,24,"﴿رَأَوۡهُ﴾: أي العذابَ.﴿عَارِضࣰا﴾: كالسَّحابِ الَّذي يَعْتَرِضُ جَوَّ السَّماءِ.﴿أَوۡدِيَتِهِمۡ﴾: منازِلِهم في السُّهُولِ."
  46,25,"﴿كُلَّ شَيۡءِۭ﴾: ما مِن شَأنِه أن تُدَمِّرَهُ مِنَ الإنْسانِ والحيوانِ والدِّيارِ.﴿مَسَـٰكِنُهُمۡ﴾: أي آثارُ المساكِنِ وبقاياها."
  46,26,"﴿فِيمَآ إِن مَّكَّنَّـٰكُمۡ فِيهِ﴾: في الَّذِي لَم نَجْعَل لَّكُم القُدْرَةَ عَلَيهِ.﴿وَأَفۡـِٔدَةࣰ﴾: عُقُولًا.﴿أَغۡنَىٰ﴾: نَفَعَ.﴿يَجۡحَدُونَ﴾: يُنْكِرُونَ.﴿وَحَاقَ بِهِم﴾: ونَزَلَ وأَحاطَ بِهِم.﴿مَّا كَانُواْ بِهِۦ يَسۡتَهۡزِءُونَ﴾: العَذابُ الَّذِي كانُوا يَسْخَرُونَ مِنهُ."
  46,27,"﴿وَصَرَّفۡنَا ٱلۡـَٔايَـٰتِ﴾: بيَّنّا لَهُم أنْواعَ الأَدِلَّةِ."
  46,28,"﴿فَلَوۡلَا﴾: فَهَلّا.﴿قُرۡبَانًا﴾: لِأَجْلِ التَّقَرُّبِ بِهِم إلى اللهِ، وهو مُعْتَرِضٌ بَيْنَ (ٱتَّخَذُواْ) ومَفْعُولِهِ: (ءالِهَةَۢ).﴿ضَلُّواْ عَنۡهُمۡ﴾: غابُوا عَنْهُم.﴿إِفۡكُهُمۡ﴾: كَذِبُهُم في زَعمِهِم أنَّ الأصْنامَ شُرَكاءُ لله.﴿يَفۡتَرُونَ﴾: يَخْتَلِقُونَه مِن كَونِ الأصْنامِ تُقَرِّبُهُم إلى اللهِ."
  46,29,"﴿صَرَفۡنَآ إِلَيۡكَ﴾: أمَلْناهُم إلَيكَ وأَقْبَلْنا بِهِم نَحْوَك.﴿نَفَرࣰا﴾: جَماعَةً.﴿أَنصِتُواْ﴾: وجِّهُوا أسْماعَكُم إلى الكَلامِ.﴿قُضِيَ﴾: فُرِغَ مِن قِراءتِه.﴿وَلَّوۡاْ﴾: انْصَرفُوا.﴿مُّنذِرِينَ﴾: المُنْذِرُ: المُخْبِرُ بِخَبرِ مُخِيفٍ."
  46,30,"﴿مُصَدِّقࣰا لِّمَا بَيۡنَ يَدَيۡهِ﴾: مُصَدِّقًا لما سَبَقَه مِن كُتُبِ اللهِ الَّتِي أنْزَلَها على رُسُلِه."
  46,31,"﴿دَاعِيَ ٱللَّهِ﴾: رَسُولَ اللهِ محمَّدًا ﷺ.﴿وَيُجِرۡكُم﴾: ويَمْنَعْكُم."
  46,32,"﴿فَلَيۡسَ بِمُعۡجِزࣲ فِي ٱلۡأَرۡضِ﴾: فَلا يَفُوتُ عِقابَ الله.﴿أَوۡلِيَآءُ﴾: نُصَراءُ."
  46,33,"﴿وَلَمۡ يَعۡيَ بِخَلۡقِهِنَّ﴾: ولَمْ يَعْجَزْ عَنْ خَلْقِهِنَّ."
  46,35,"﴿أُوْلُواْ ٱلۡعَزۡمِ مِنَ ٱلرُّسُلِ﴾: هُمْ: نُوحٌ وإبراهيمُ وموسى وعِيسى ومُحَمَّدٌ عَلَيهِمُ الصَّلاةُ والسَّلامُ.﴿وَلَا تَسۡتَعۡجِل﴾: الَهلاكَ.﴿لَمۡ يَلۡبَثُوٓاْ﴾: لم يَمْكُثُوا.﴿بَلَـٰغࣱ﴾: هَذا بَلاغٌ للنّاسِ.﴿ٱلۡفَـٰسِقُونَ﴾: الخارِجُونَ عَنِ الإيمانِ بالإشْراكِ."
