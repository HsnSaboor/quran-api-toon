tafsir[105]{c,v,t}:
  17,1,"﴿سُبۡحَـٰنَ ٱلَّذِيٓ﴾: تنزيهًا لله عن كلِّ سوءٍ، وتعظيمًا لشأنِه على كمالِ قدرتِه.﴿أَسۡرَىٰ﴾: الإسراءُ هو سَيْرُ الليلِ.﴿بِعَبۡدِهِۦ﴾: محمد ﷺ بجسَدِه ورُوحِه، حالَ اليَقَظةِ.﴿بَـٰرَكۡنَا حَوۡلَهُۥ﴾: أكْثَرْنا فيه الخيرَ بالخِصْبِ والثِّمارِ والمياهِ، وببَعْثِ كثيرٍ من الأنبياءِ منه.﴿مِنۡ ءَايَـٰتِنَآ﴾: من عجائبِ قدرةِ اللهِ وأدِلَّةِ وحْدانيتِه."
  17,2,"﴿ٱلۡكِتَـٰبَ﴾: التوراةَ.﴿وَكِيلࣰا﴾: معبودًا تُفَوِّضون إليه أمورَكم."
  17,3,"﴿ذُرِّيَّةَ مَنۡ حَمَلۡنَا مَعَ نُوحٍ﴾: يا سُلالةَ الذين نَجّاهم اللهُ من الغَرَقِ مع نوحٍ، لا تُشْرِكوا بالله."
  17,4,"﴿وَقَضَيۡنَآ إِلَىٰ بَنِيٓ إِسۡرَ ٰ⁠ٓءِيلَ﴾: وأَعْلَمْناهم.﴿ٱلۡكِتَـٰبِ﴾: التوراةِ.﴿فِي ٱلۡأَرۡضِ﴾: في بيتِ المَقْدِسِ والشامِ.﴿وَلَتَعۡلُنَّ﴾: لتَتَجاوَزُنَّ الحَدَّ في التكبُّرِ والظُّلْمِ."
  17,5,"﴿وَعۡدُ أُولَىٰهُمَا﴾: مَوْعِدُ أُولى مَرَّتَي الإفسادِ.﴿بَعَثۡنَا﴾: سَلَّطْنا.﴿أُوْلِي بَأۡسࣲ﴾: ذوي شجاعةٍ وقُوَّةٍ في الحروب.﴿فَجَاسُواْ﴾: طافُوا وعاثُوا.﴿خِلَـٰلَ ٱلدِّيَارِ﴾: وسْطَها بالإفسادِ.﴿مَّفۡعُولࣰا﴾: نافِذًا لابُدَّ من وقُوعِه."
  17,6,"﴿ٱلۡكَرَّةَ عَلَيۡهِمۡ﴾: الغَلَبَةَ والانتصارَ على عَدُوِّكم.﴿نَفِيرًا﴾: عددًا وعشيرةً."
  17,7,"﴿وَعۡدُ ٱلۡـَٔاخِرَةِ﴾: مَوْعِدُ المرَّةِ الثانيةِ من الإفسادِ.﴿لِيَسُـُٔواْ وُجُوهَكُمۡ﴾: ليجعَلُوا آثارَ الإهانةِ والَمذَلَّةِ باديةً فيها.﴿وَلِيُتَبِّرُواْ﴾: يُدَمِّرُوا ويُهْلِكُوا.﴿مَا عَلَوۡاْ﴾: ما استَوْلَوْا عليه.﴿تَتۡبِيرًا﴾: تَدْميرًا كاملًا."
  17,8,"﴿وَإِنۡ عُدتُّمۡ﴾: يا بني إسرائيلَ إلى الإفسادِ والظُّلمِ.﴿عُدۡنَا﴾: إلى عقابِكم ومَذلَّتِكم.﴿حَصِيرًا﴾: سِجْنًا يُحْبَسون فيه."
  17,9,"﴿يَهۡدِي﴾: يُرْشِدُ الناسَ ويَدْعُوهم.﴿هِيَ أَقۡوَمُ﴾: أحسنُ الطرقِ وأصوبُها."
  17,10,"﴿أَعۡتَدۡنَا﴾: أعدَدْنا."
  17,11,"﴿دُعَآءَهُۥ بِٱلۡخَيۡرِ﴾: مثلَ ما يَدْعُو بالخيرِ."
  17,12,"﴿ءَايَتَيۡنِ﴾: علامتَين في الدَّلالةِ على وحْدانيَّة اللهِ وقدرتِه.﴿ءَايَةَ ٱلَّيۡلِ﴾: علامتَه، وهي القمرُ.﴿ءَايَةَ ٱلنَّهَارِ﴾: علامتَه، وهي الشمسُ.﴿مُبۡصِرَةࣰ﴾: مضيئةً ومُبْصَرًا بها.﴿فَضۡلࣰا﴾: رِزْقًا؛ لأنّ النهارَ وقتٌ للتصرُّفِ في شؤونِ المعاشِ.﴿وَٱلۡحِسَابَ﴾: حسابَ الأشهرِ والأيامِ."
  17,13,"﴿طَـٰٓئِرَهُۥ﴾: ما عَمِلَه من خيرٍ أو شّرٍ.﴿كِتَـٰبࣰا﴾: وهو صحيفةُ أعمالِه.﴿يَلۡقَىٰهُ﴾: يَراه.﴿مَنشُورًا﴾: مفتوحًا غيرَ مَطْوِيٍّ."
  17,14,"﴿حَسِيبࣰا﴾: مُحاسِبًا."
  17,15,"﴿وَلَا تَزِرُ وَازِرَةࣱ﴾: ولا تحمِلُ نفسٌ آثمةٌ.﴿وِزۡرَ أُخۡرَىٰ﴾: إثْمَ نفسٍ مُذْنبةٍ غيرِها."
  17,16,"﴿أَمَرۡنَا﴾: بطاعةِ الله وتوحيدِه واتِّباعِ رُسُلِه.﴿مُتۡرَفِيهَا﴾: مُنَعَّمِيها، وهم الرؤساءُ والكبراءُ فيها.﴿فَفَسَقُواْ﴾: فخَرَجُوا عن أمرِ ربِّهم وعَصَوْه.﴿فَحَقَّ﴾: وجَبَ.﴿ٱلۡقَوۡلُ﴾: الوعيدُ والعذابُ.﴿فَدَمَّرۡنَـٰهَا تَدۡمِيرࣰا﴾: أهْلَكْناها إهلاكًا مُسْتأصِلًا."
  17,17,"﴿وَكَمۡ﴾: وكثيرًا.﴿ٱلۡقُرُونِ﴾: الأُمَمِ المكذِّبةِ."
  17,18,"﴿ٱلۡعَاجِلَةَ﴾: الحياةَ الدنيا.﴿يَصۡلَىٰهَا﴾: يَدْخُلها.﴿مَذۡمُومࣰا﴾: مَلُومًا.﴿مَّدۡحُورࣰا﴾: مَطْرودًا من رحمةِ اللهِ."
  17,19,"﴿مَّشۡكُورࣰا﴾: مقبولًا عندَ اللهِ، وسيُثِيبُهم عليه."
  17,20,"﴿كُلࣰّا نُّمِدُّ﴾: نَزيدُ كُلًّا من الفريقَين من غيرِ انقطاعٍ.﴿عَطَآءِ رَبِّكَ﴾: رزقِه.﴿مَحۡظُورًا﴾: ممنوعًا عن أحدٍ."
  17,22,"﴿فَتَقۡعُدَ﴾: فتَصيرَ.﴿مَذۡمُومࣰا﴾: من اللهِ وملائكتِه وصالحي المؤمنين."
  17,23,"﴿وَقَضَىٰ﴾: حَكَمَ وأَمَرَ.﴿أُفࣲّ﴾: كلمةٌ تَدُلُّ على التضجُّرِ والاستثقالِ.﴿وَلَا تَنۡهَرۡهُمَا﴾: لا يَصْدُرْ منك إليهما قولٌ قبيحٌ.﴿كَرِيمࣰا﴾: طَيِّبًا حَسَنًا مَقْرونًا بالاحترامِ والحياءِ."
  17,24,"﴿وَٱخۡفِضۡ لَهُمَا جَنَاحَ ٱلذُّلِّ﴾: وكُنْ متواضِعًا مُتَذَلِّلًا لأمِّك وأبيك.﴿مِنَ ٱلرَّحۡمَةِ﴾: لرِقَّتِك ورحمتِك بهما."
  17,25,"﴿لِلۡأَوَّ ٰ⁠بِينَ﴾: الرَّجّاعين إلى اللهِ بالتوبةِ والإنابةِ."
  17,26,"﴿وَءَاتِ﴾: وأعْطِ.﴿وَٱلۡمِسۡكِينَ﴾: الذي لا يَمْلِكُ ما يَكْفيه ويَسُدُّ حاجتَه.﴿وَٱبۡنَ ٱلسَّبِيلِ﴾: المسافرَ المنقطعَ عن مالِه في سَفَرِه، وإن كان غنيًا في بلدِه.﴿وَلَا تُبَذِّرۡ﴾: لا تُنْفِقْ مالَكَ في غيرِ موضِعِه الموافِقِ للشَّرعِ."
  17,27,"﴿إِخۡوَ ٰ⁠نَ ٱلشَّيَـٰطِينِ﴾: أشباهَهم وقُرَناءَهم في الفسادِ والمعاصي."
  17,28,"﴿ٱبۡتِغَآءَ رَحۡمَةࣲ﴾: طَلَبًا لرزقٍ تنتظرُه.﴿مَّيۡسُورࣰا﴾: لَيِّنًا لطيفًا."
  17,29,"﴿مَغۡلُولَةً﴾: مقبوضَةً عن الإنفاقِ في الخيرِ.﴿وَلَا تَبۡسُطۡهَا كُلَّ ٱلۡبَسۡطِ﴾: لا تُسْرِفْ، ولا تتوسَّعْ في النفقةِ فوقَ طاقَتِك.﴿مَّحۡسُورًا﴾: نادمًا على إسرافِك وضَياعِ مالِك."
  17,30,"﴿يَبۡسُطُ ٱلرِّزۡقَ﴾: يُوَسِّعُه.﴿وَيَقۡدِرُ﴾: ويُضَيِّقُه."
  17,31,"﴿إِمۡلَـٰقࣲ﴾: فَقْرٍ.﴿خِطۡـࣰٔا﴾: إثمًا."
  17,32,"﴿فَـٰحِشَةࣰ﴾: فَعْلَةً قبيحةً ظاهرةَ القُبْحِ.﴿وَسَآءَ سَبِيلࣰا﴾: بئسَ الطريقُ طريقُه."
  17,33,"﴿فَقَدۡ جَعَلۡنَا﴾: بما أذِنَ فيه الشَّرْعُ، كالقِصاصِ.﴿لِوَلِيِّهِۦ﴾: لِمَن يَلي أمرَه مِن وارثٍ أو حاكمٍ.﴿سُلۡطَـٰنࣰا﴾: حُجَّةً في طَلَبِ قَتْلِ القاتلِ أو الدِّيَةِ.﴿فَلَا يُسۡرِف فِّي ٱلۡقَتۡلِ﴾: لا يُجاوِزِ الحَدَّ المشروعَ فيه."
  17,34,"﴿ٱلۡيَتِيمِ﴾: مَن مات أبوه وهو دونَ سِنِّ البُلوغِ.﴿هِيَ أَحۡسَنُ﴾: بالطريقةِ الحُسنى.﴿يَبۡلُغَ أَشُدَّهُۥ﴾: قوتَه على حِفْظِ مالِه، وحُسْنِ التصرُّفِ فيه.﴿مَسۡـُٔولࣰا﴾: يُسأَل صاحبُ العهدِ عنه، ويحاسَبُ يومَ القيامةِ."
  17,35,"﴿بِٱلۡقِسۡطَاسِ ٱلۡمُسۡتَقِيمِ﴾: بالميزانِ السَّوِيِّ.﴿تَأۡوِيلࣰا﴾: مآلًا وعاقبةً عندَ اللهِ."
  17,36,"﴿وَلَا تَقۡفُ﴾: لا تَتَّبِعْ.﴿مَا لَيۡسَ لَكَ بِهِۦ عِلۡمٌ﴾: ما لا عِلْمَ لك به من قولٍ أو فِعْلٍ.﴿وَٱلۡفُؤَادَ﴾: القلبَ.﴿مَسۡـُٔولࣰا﴾: أي: صاحبُها، يُسْأَلُ عَمّا فَعَلَ بها."
  17,37,"﴿مَرَحًا﴾: فَخْرًا وتكبُّرًا.﴿لَن تَخۡرِقَ ٱلۡأَرۡضَ﴾: تَثْقُبَها بمَشْيِك عليها بهذه الصفةِ."
  17,38,"﴿كُلُّ ذَ ٰ⁠لِكَ﴾: ما تَقَدَّم ذِكْرُه من الأوامرِ والنَّواهي.﴿كَانَ سَيِّئُهُۥ﴾: السَّيِّئُ منه، هو الَمنْهِيّاتُ."
  17,39,"﴿ٱلۡحِكۡمَةِ﴾: الأحكامِ المُحْكَمَةِ التي لا يَتَطرَّقُ إليها الفسادُ.﴿مَّدۡحُورًا﴾: مَطْرودًا من رحمةِ اللهِ."
  17,40,"﴿أَفَأَصۡفَىٰكُمۡ﴾: اختاركم وخَصَّكم."
  17,41,"﴿صَرَّفۡنَا﴾: بيَّنّا، ونَوَّعْنا القولَ في أساليبَ مختلفةٍ."
  17,42,"﴿سَبِيلࣰا﴾: طريقًا إلى المغالَبَةِ."
  17,43,"﴿سُبۡحَـٰنَهُۥ﴾: تنزيهًا لله."
  17,44,"﴿يُسَبِّحُ بِحَمۡدِهِۦ﴾: يُنَزِّهُ اللهَ تنزيهًا مَقْرونًا بالثناءِ والحمدِ له.﴿لَّا تَفۡقَهُونَ﴾: لا تَفْهَمُون ولا تُدْرِكُون.﴿حَلِيمًا﴾: لا يُعاجِلُ بالعقوبةِ مَنِ انطمَسَتْ بَصيرتُه فعَصاه."
  17,45,"﴿حِجَابࣰا مَّسۡتُورࣰا﴾: مانِعًا ساتِرًا، يَمْنَعُ عقولَهم عن فَهْمِ القُرآنِ والانتفاعِ به؛ عقوبةً لهم على كُفرِهم."
  17,46,"﴿أَكِنَّةً﴾: أغْطِيَةً.﴿وَقۡرࣰا﴾: ثِقْلًا وصَمَمًا عن استماعِ القرآنِ وتَدَبُّرِه.﴿وَحۡدَهُۥ﴾: داعيًا لتوحيدِه، ناهيًا عن الشِّرك بِه.﴿وَلَّوۡاْ عَلَىٰٓ أَدۡبَـٰرِهِمۡ﴾: أدْبَرُوا راجِعين.﴿نُفُورࣰا﴾: نافِرين من قولِك؛ تَكَبُّرًا عن الحقّ."
  17,47,"﴿بِمَا يَسۡتَمِعُونَ بِهِۦٓ﴾: بما يستمعون القرآنَ، وقَصْدُهم السخريةُ والتكذيبُ.﴿وَإِذۡ هُمۡ نَجۡوَىٰٓ﴾: ونَعْلَمُ ما هم مُتَسارُّون بينهم في شأنِكِ.﴿مَّسۡحُورًا﴾: أصابَه السِّحْرُ فاختلطَ عَقْلُه."
  17,48,"﴿ٱنظُرۡ﴾: تأمَّلْ وتَعَجَّبْ.﴿ضَرَبُواْ لَكَ ٱلۡأَمۡثَالَ﴾: شَبَّهُوك فقالُوا: ساحِرٌ، وتارةً شاعرٌ، وتارةً مجنونٌ، مع عِلْمِهم بخِلافِه.﴿فَضَلُّواْ﴾: انحرَفُوا.﴿سَبِيلࣰا﴾: طريقًا إلى الحقِّ والصوابِ."
  17,49,"﴿وَرُفَـٰتًا﴾: أجزاءً مُتَكَسِّرةً مُتَفتتةً."
  17,51,"﴿يَكۡبُرُ فِي صُدُورِكُمۡ﴾: يَعْظُمُ ويُسْتَبْعَدُ في عقولِكم قَبولُه للحياةِ، كالسمواتِ.﴿يُعِيدُنَا﴾: يُرْجِعُنا إلى الحياةِ بعدَ موتِنا.﴿فَطَرَكُمۡ﴾: خَلَقَكم من غيرِ مثالٍ سابقٍ.﴿فَسَيُنۡغِضُونَ إِلَيۡكَ رُءُوسَهُمۡ﴾: سيُحَرِّكُونها استهزاءً وتعجُّبًا.﴿مَتَىٰ هُوَ﴾: أي: البعثُ."
  17,52,"﴿يَدۡعُوكُمۡ﴾: يُناديكم خالقُكم على لسانِ المَلَكِ؛ للخروجِ من قبورِكم.﴿بِحَمۡدِهِۦ﴾: بأمرِ اللهِ، حامدين اللهَ على كمالِ قدرتِه."
  17,53,"﴿يَنزَغُ﴾: يُفْسِدُ ويُوَسْوِسُ.﴿مُّبِينࣰا﴾: واضحَ العداوةِ."
  17,54,"﴿وَكِيلࣰا﴾: مُفَوَّضًا إليك أمرُهم."
  17,55,"﴿فَضَّلۡنَا بَعۡضَ ٱلنَّبِيِّـۧنَ﴾: بالفضائلِ وإنزالِ الكتبِ.﴿زَبُورࣰا﴾: الكتابُ المنزَّلُ على داودَ عليه السلام، وكلُّه تحميدٌ وثناءٌ على اللهِ."
  17,56,"﴿كَشۡفَ ٱلضُّرِّ﴾: إزالتَه.﴿تَحۡوِيلًا﴾: نَقْلَه إلى غيرِكم، أوتبديلَه من حالٍ إلى أخرى."
  17,57,"﴿ٱلَّذِينَ يَدۡعُونَ﴾: اتخذهم المُشْركون آلهةً، كالملائكة والأنبياء.﴿يَبۡتَغُونَ﴾: يَطْلبون باجتهادٍ.﴿ٱلۡوَسِيلَةَ﴾: القُرْبةَ بالطاعةِ والدرجةِ العُليا.﴿أَيُّهُمۡ أَقۡرَبُ﴾: يَطْلُبها الذي هو أقربُ إلى اللهِ، فكيف بمَن دونَه؟﴿مَحۡذُورࣰا﴾: حقيقًا بأن يَحْذَرَه العِبادُ."
  17,58,"﴿وَإِن مِّن قَرۡيَةٍ﴾: وما مِن قريةٍ كَذَّب أهلُها.﴿فِي ٱلۡكِتَـٰبِ﴾: في اللَّوحِ المحفوظِ.﴿مَسۡطُورࣰا﴾: مَكْتوبًا."
  17,59,"﴿بِٱلۡـَٔايَـٰتِ﴾: بالمُعْجزاتِ التي اقترحها المشركون.﴿مُبۡصِرَةࣰ﴾: معجزةً واضحةً.﴿فَظَلَمُواْ بِهَا﴾: فكفَرُوا بها فأَهْلَكَهم اللهُ."
  17,60,"﴿أَحَاطَ بِٱلنَّاسِ﴾: عِلْمًا وقُدرةً، فهُم في قَبْضَتِه، ولا يَخْرجُون عن مشيئتِه.﴿ٱلرُّءۡيَا﴾: ما عاينَه النبيُّ ﷺ ليلةَ الإسراءِ والمعراجِ من عجائبِ مخلوقاتِ اللهِ.﴿فِتۡنَةࣰ﴾: ابتلاءً وامتحانًا.﴿وَٱلشَّجَرَةَ ٱلۡمَلۡعُونَةَ﴾: شجرةَ الزَّقُّومِ، جَعَلَها اللهُ ابتلاءً لبعضِ الناس الذين أنكروا خَلْقَ شجرةٍ في النارِ.﴿وَنُخَوِّفُهُمۡ﴾: نُخَوِّفُ المشركين بأصنافِ الوعيدِ والعذابِ.﴿طُغۡيَـٰنࣰا﴾: تجاوُزًا للحَدِّ في الكفرِ والضَّلالِ."
  17,61,"﴿ٱسۡجُدُواْ لِـَٔادَمَ﴾: تحيةً وإكرامًا له وإظهارًا لفضلِه، لا عِبادةً."
  17,62,"﴿أَرَءَيۡتَكَ﴾: أخْبِرْني.﴿لَأَحۡتَنِكَنَّ ذُرِّيَّتَهُۥٓ﴾: لأَسْتَوْلِيَنَّ عليهم بالإغواءِ والإضلالِ.﴿إِلَّا قَلِيلࣰا﴾: مَن عَصَمَه اللهُ تعالى مِن عبادِه."
  17,64,"﴿وَٱسۡتَفۡزِزۡ﴾: واستَخِفَّ، أو أزْعِجْ.﴿بِصَوۡتِكَ﴾: بدَعْوَتِك إياهم إلى المعاصي والآثام.﴿وَأَجۡلِبۡ عَلَيۡهِم﴾: واستحِثَّهم، واجْمَعْ عليهم كلَّ ما تَقْدِرُ عليه مِن جنودِك.﴿بِخَيۡلِكَ وَرَجِلِكَ﴾: من كلِّ راكبٍ وماشٍ في المعصيةِ والفَسادِ.﴿وَشَارِكۡهُمۡ فِي ٱلۡأَمۡوَ ٰ⁠لِ﴾: بتحريضِهم على كَسْبِ الأموالِ المحرَّمةِ، وإنفاقِها فيما يُغضبُ اللهَ.﴿وَٱلۡأَوۡلَـٰدِ﴾: وبتَزْيِينِ إنجابِهم عن طريقِ الزِّنى، أو التخلُّصِ منهم، وتجاوزِ حدودِ الشَّرعِ.﴿غُرُورًا﴾: وعْدًا باطلًا خادعًا."
  17,65,"﴿سُلۡطَـٰنࣱ﴾: تَسَلُّطٌ وقوةٌ على إغوائِهم.﴿وَكِيلࣰا﴾: حافِظًا لعبادِه."
  17,66,"﴿يُزۡجِي﴾: يُجْري ويُسَيِّرُ برِفْقٍ.﴿ٱلۡفُلۡكَ﴾: السُّفُنَ.﴿لِتَبۡتَغُواْ﴾: لتَطْلُبُوا.﴿مِن فَضۡلِهِۦٓ﴾: مِن رزقِ اللهِ."
  17,67,"﴿ٱلضُّرُّ﴾: الشِّدَّةُ وخَوْفُ الغَرَقِ.﴿ضَلَّ﴾: غابَ عن عقولِكم.﴿مَن تَدۡعُونَ إِلَّآ إِيَّاهُ﴾: الذين تَعْبُدُونهم من الآلهةِ، وتَذَكَّرْتُم اللهَ وحدَه."
  17,68,"﴿يَخۡسِفَ بِكُمۡ جَانِبَ ٱلۡبَرِّ﴾: يُغَوِّرَ بكم الأرضَ، ويُغيِّبَكم فيها.﴿حَاصِبࣰا﴾: المَطَرَ الذي فيه حِجارةٌ من السماء، أو ريحًا شديدة تَرْمي بالحصى الصِّغارِ.﴿وَكِيلًا﴾: حَفيظًا وناصِرًا من الله."
  17,69,"﴿فِيهِ﴾: في البحر.﴿قَاصِفࣰا﴾: شديدةً عاصفةً، تُكَسِّرُ كلَّ ما أتَتْ عليه.﴿تَبِيعࣰا﴾: مُطالِبًا بما فَعَلْنا، ونصيرًا يأخذُ بالثأرِ لكم."
  17,70,"﴿كَرَّمۡنَا بَنِيٓ ءَادَمَ﴾: بالرسُلِ والرِّسالات، وغيرِها من النِّعَمِ. ومَنحْناهم عقولًا يُدْرِكون بها ويُمَيِّزون."
  17,71,"﴿يَوۡمَ﴾: أي: يومَ القيامةِ.﴿بِإِمَـٰمِهِمۡ﴾: بمَنِ اقتَدَوْا به في الدُّنيا من كتابٍ، أو نبيّ، أو قائدٍ.﴿كِتَـٰبَهُۥ﴾: كتابَ أعمالِه.﴿فَتِيلࣰا﴾: مِقْدارَ الخيطِ الذي في شَقِّ النَّواة."
  17,72,"﴿فِي هَـٰذِهِۦٓ أَعۡمَىٰ﴾: في الدُّنيا أعمى القَلْبِ والبَصيرةِ."
  17,73,"﴿وَإِن كَادُواْ﴾: ولقد قارَبَ المشركون.﴿لَيَفۡتِنُونَكَ﴾: لَيَصْرِفُونك ويَخْدَعُونك في ظَنِّهم.﴿لِتَفۡتَرِيَ عَلَيۡنَا﴾: لِتَتَقَوَّلَ علينا مَّما اقترحُوه عليك.﴿لَّٱتَّخَذُوكَ خَلِيلࣰا﴾: خَصُّوك بالصداقةِ الخاصَّةِ."
  17,74,"﴿تَرۡكَنُ﴾: تميلُ."
  17,75,"﴿ضِعۡفَ ٱلۡحَيَوٰةِ وَضِعۡفَ ٱلۡمَمَاتِ﴾: عذابًا مُضاعَفًا مِثْلَي ما يُعَذَّبُ به غيرُك في الدنيا والآخِرَةِ."
  17,76,"﴿لَيَسۡتَفِزُّونَكَ﴾: لَيُزعِجُونك بعَداوتهم لِيُخْرِجُوك.﴿مِنَ ٱلۡأَرۡضِ﴾: من مكةَ.﴿وَإِذࣰا﴾: لو أخرجُوك.﴿خِلَـٰفَكَ﴾: بَعْدَك."
  17,77,"﴿تَحۡوِيلًا﴾: تَبْديلًا."
  17,78,"﴿لِدُلُوكِ ٱلشَّمۡسِ﴾: وقتِ ميلِها عن وسَطِ السماءِ، وهو الزَّوالُ في الظَّهيرةِ.﴿غَسَقِ ٱلَّيۡلِ﴾: إقبالِ ظُلْمَتِه وسَوادِه.﴿وَقُرۡءَانَ ٱلۡفَجۡرِ﴾: وأقمْ صَلاةَ الفجرِ.﴿مَشۡهُودࣰا﴾: تَحْضُرُها ملائكةُ الليلِ، وملائكةُ النهارِ."
  17,79,"﴿فَتَهَجَّدۡ بِهِۦ﴾: فاقْرأ القرآنَ في صلاةِ الليلِ.﴿نَافِلَةࣰ لَّكَ﴾: زيادةً لك، وفضيلةً ورَفْعَ دَرَجاتٍ.﴿مَقَامࣰا مَّحۡمُودࣰا﴾: شافِعًا للناسِ عند فَصْلِ القضاءِ بينَهم، يحْمَدُكَ فيه الأوَّلون والآخِرون."
  17,80,"﴿مُدۡخَلَ صِدۡقࣲ﴾: إدخالًا مَرْضِيًّا لا أرى فيه ما أكْرَهُ.﴿مُخۡرَجَ صِدۡقࣲ﴾: إخراجًا مَرْضِيًّا مما هوشَرٌّ لي.﴿سُلۡطَـٰنࣰا﴾: حُجَّةً بيِّنةً ثابتةً، أو قوَّةً وعِزًّا.﴿نَّصِيرࣰا﴾: ناصرًا ومُعِينًا على مَن خالفني."
  17,81,"﴿ٱلۡحَقُّ﴾: الإسلامُ.﴿وَزَهَقَ ٱلۡبَـٰطِلُ﴾: ذَهَبَ وبَطَل الشِّرْكُ."
  17,82,"﴿خَسَارࣰا﴾: ضَلالًا وهَلاكًا؛ بسبب كُفْرِهم."
  17,83,"﴿وَنَـَٔا بِجَانِبِهِۦ﴾: تباعَدَ عن شُكْرِ اللهِ وطاعَتِه؛ تَكَبُّرًا.﴿ٱلشَّرُّ﴾: الشِّدَّةُ والضَّرَرُ.﴿يَـُٔوسࣰا﴾: شديدَ اليأسِ من رحمةِ الله."
  17,84,"﴿شَاكِلَتِهِۦ﴾: ما يُجانِسُ أخلاقَه التي اعتادَ عليها."
  17,85,"﴿مِنۡ أَمۡرِ رَبِّي﴾: مما استأثرَ اللهُ تعالى بعِلْمِها."
  17,86,"﴿لَنَذۡهَبَنَّ بِٱلَّذِيٓ أَوۡحَيۡنَآ إِلَيۡكَ﴾: لَمَحَوْنا القرآنَ من القلوبِ والمصاحِفِ، حتى لا يَبْقى له أثرٌ.﴿وَكِيلًا﴾: مَن يَلْتزِمُ باستردادِه بعد الذَّهابِ به."
  17,87,"﴿إِلَّا رَحۡمَةࣰ مِّن رَّبِّكَ﴾: لكن رحمةً من اللهِ أبقَيْنا القرآنَ فلم نُذْهِبْه."
  17,88,"﴿ظَهِيرࣰا﴾: مُعِينًا على تحقيقِ مُرادِهم."
  17,89,"﴿صَرَّفۡنَا﴾: بَيَّنّا ونَوَّعْنا بأساليبَ مختلفةٍ.﴿كُلِّ مَثَلࣲ﴾: كلِّ معنى يَحْصُلُ الاتعاظُ به.﴿كُفُورࣰا﴾: جُحودًا للحَقِّ."
  17,90,"﴿يَنۢبُوعًا﴾: عَيْنًا لا يَجِفُّ ماؤُها."
  17,91,"﴿جَنَّةࣱ﴾: حديقةٌ.﴿فَتُفَجِّرَ ٱلۡأَنۡهَـٰرَ﴾: تُجْرِيها بقُوَّةٍ."
  17,92,"﴿كِسَفًا﴾: قِطَعًا.﴿قَبِيلًا﴾: مقابَلَةً وعِيانًا."
  17,93,"﴿زُخۡرُفٍ﴾: ذَهَبٍ.﴿تَرۡقَىٰ﴾: تَصْعَدَ.﴿سُبۡحَانَ رَبِّي﴾: تَنْزيهًا للهِ عن اقتراحاتهم، وتَعجُّبًا من شِدَّةِ كُفْرِهم."
  17,95,"﴿مُطۡمَئِنِّينَ﴾: ساكنِين فيها."
  17,97,"﴿وَبُكۡمࣰا﴾: لايَنْطِقُون.﴿وَصُمࣰّا﴾: لا يَسْمَعُون.﴿مَّأۡوَىٰهُمۡ﴾: مَصيرُهم.﴿خَبَتۡ﴾: سَكَنَ لَهَبُها.﴿سَعِيرࣰا﴾: تَوَقُّدًا واشتِعالًا."
  17,98,"﴿ذَ ٰ⁠لِكَ﴾: الموصوفُ من العذابِ.﴿وَرُفَـٰتًا﴾: أجزاءً من العذابِ."
  17,99,"﴿أَجَلࣰا﴾: وقْتًا مُحَدَّدًا للموتِ والحسابِ.﴿لَّا رَيۡبَ فِيهِ﴾: لا شَكَّ في وقوعِه.﴿كُفُورࣰا﴾: جُحودًا للحَقِّ."
  17,100,"﴿رَحۡمَةِ رَبِّيٓ﴾: رِزْقِه وسائرِ نِعَمِه.﴿قَتُورࣰا﴾: بخيلًا مَنُوعًا."
  17,101,"﴿ءَايَـٰتِۭ بَيِّنَـٰتࣲ﴾: معجزاتٍ واضحاتِ الدَّلالةِ على نُبُوَّتِه.﴿فَسۡـَٔلۡ﴾: سؤالَ تقريرٍ على صِدْقِك.﴿مَسۡحُورࣰا﴾: أصابكَ السِّحْرُ فاختلطَ عَقْلُكَ."
  17,102,"﴿هَـٰٓؤُلَآءِ﴾: المعجزاتِ التسعَ.﴿بَصَآئِرَ﴾: دَلالاتٍ وعِبَرًا يُستَدَلُّ بها على وحدانيةِ اللهِ وقدرتِه.﴿لَأَظُنُّكَ﴾: لمَوقِنٌ أنك.﴿مَثۡبُورࣰا﴾: مُهْلَكًا، أو ممنوعًا عن الخير، مطبوعًا على الشَّرِّ."
  17,103,"﴿يَسۡتَفِزَّهُم﴾: يُزْعِجَهم بعَداوتِه ليُخْرِجَهم.﴿مِّنَ ٱلۡأَرۡضِ﴾: من أرضِ «مصرَ»."
  17,104,"﴿ٱلۡأَرۡضَ﴾: أرضَ «مصرَ والشام».﴿وَعۡدُ ٱلۡـَٔاخِرَةِ﴾: يومُ القيِامةِ.﴿لَفِيفࣰا﴾: جميعًا مختلِطِين من كلِّ نوعٍ لا تتعارفُون."
  17,106,"﴿فَرَقۡنَـٰهُ﴾: أوْضَحْناه، وفَرَقْنا فيه بين الحقِّ والباطِل.﴿عَلَىٰ مُكۡثࣲ﴾: على تَمَهُّلٍ وتَأَنٍّ؛ ليَفْهموه ويَتَيَسَّرَلهم حِفْظُه.﴿وَنَزَّلۡنَـٰهُ تَنزِيلࣰا﴾: على حَسَبِ الحوادث والمصالحِ والأحوالِ."
  17,107,"﴿مِن قَبۡلِهِۦٓ﴾: من قَبْلِ القرآنِ.﴿يَخِرُّونَ لِلۡأَذۡقَانِ سُجَّدࣰا﴾: يَسْقُطون بسرعةٍ ساجدين على وجوهِهم؛ تعظيمًا لله وشُكْرًا له."
  17,108,"﴿سُبۡحَـٰنَ رَبِّنَآ﴾: تنزيهًا له على قُدرتِه التامةِ، وأنه لا يُخْلِفُ الميعادَ.﴿لَمَفۡعُولࣰا﴾: مُنْجَزًا واقعًا."
  17,109,"﴿خُشُوعࣰا﴾: سُكونًا وضَراعةً وخُضوعًا."
  17,110,"﴿بِصَلَاتِكَ﴾: بقراءتِك في الصلاةِ.﴿وَلَا تُخَافِتۡ﴾: ولا تُسِرَّ.﴿وَٱبۡتَغِ﴾: اقْصِدْ.﴿بَيۡنَ ذَ ٰ⁠لِكَ﴾: بينَ الجَهْرِ بقراءتِك والإسرارِ بها.﴿سَبِيلࣰا﴾: طريقًا وسَطًا."
  17,111,"﴿وَلِيࣱّ مِّنَ ٱلذُّلِّ﴾: ناصرٌ ومُعِينٌ لذُلٍّ يَلْحَقُه، فهو الغَنِيُّ العزيزُ القَوِيُّ.﴿وَكَبِّرۡهُ تَكۡبِيرَۢا﴾: عَظِّمْه تعظيمًا تامًّا مع كمالِ التنزيهِ."
