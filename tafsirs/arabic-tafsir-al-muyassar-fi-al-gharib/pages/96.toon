tafsir[15]{c,v,t}:
  96,1,"﴿ٱقۡرَأۡ﴾: اقْرَأْ -أيُّها النَّبِيُّ- ما أُنِزلَ إلَيكَ مِن القُرآنِ.﴿بِٱسۡمِ رَبِّكَ﴾: مُفْتَتِحًا باسْمِ رَبِّكَ.﴿ٱلَّذِي خَلَقَ﴾: المُتَفَرِّدِ بالخَلْقِ."
  96,2,"﴿عَلَقٍ﴾: قِطْعَةِ دَمٍ غَلِيظ أحْمَرَ."
  96,3,"﴿ٱلۡأَكۡرَمُ﴾: الكثِيرُ الإحسانِ."
  96,4,"﴿بِٱلۡقَلَمِ﴾: الكِتابة بالقَلَمِ."
  96,6,"﴿كَلَّآ﴾: حَقًّا.﴿لَيَطۡغَىٰٓ﴾: لَيتَجاوَزُ حُدُودَ اللهِ."
  96,7,"﴿أَن رَّءَاهُ ٱسۡتَغۡنَىٰٓ﴾: لِأَجْلِ أنَّهُ وجَدَ نَفْسَه مُسْتَغْنِيًا شَدِيدَ الغِنى."
  96,8,"﴿ٱلرُّجۡعَىٰٓ﴾: المَصِيرَ."
  96,9,"﴿أَرَءَيۡتَ ٱلَّذِي يَنۡهَىٰ﴾: أرأيتَ أعْجَبَ مِن طُغيانِ هذا الرَّجُلِ -وهو أبو جَهْلٍ- الَّذِي يَنْهى."
  96,10,"﴿عَبۡدًا﴾: هو مُحَمَّدٌ ﷺ."
  96,11,"﴿أَرَءَيۡتَ إِن كَانَ عَلَى ٱلۡهُدَىٰٓ﴾: أرأيت إن كان المَنهِيُّ عَنِ الصَّلاةِ عَلى الهُدى فَكَيفَ يَنْهاهُ؟"
  96,13,"﴿وَتَوَلَّىٰٓ﴾: وأَعْرَضَ عَنْهُ."
  96,15,"﴿كَلَّا﴾: لَيسَ الأمرُ كَما يَزْعُمُ أبو جَهْلٍ.﴿لَنَسۡفَعَۢا بِٱلنَّاصِيَةِ﴾: لَنَأْخُذَنَّ بِمُقَدَّمِ رَأْسِهِ أخْذًا عَنِيفًا، وليُطْرَحَنَّ في النّارِ."
  96,17,"﴿فَلۡيَدۡعُ نَادِيَهُۥ﴾: فليُحْضِرْ أهْلَ نادِيهِ الَّذِين يَسْتَنْصِرُ بِهِم."
  96,18,"﴿سَنَدۡعُ ٱلزَّبَانِيَةَ﴾: سَنَدعُو ملائِكةَ العذابِ."
  96,19,"﴿كَلَّا﴾: لَيس الأمرُ على ما يَظُنُّ. إنُّه لَن يَنالَكَ -أيُّها الرَّسُولُ- بِسُوءٍ.﴿لَا تُطِعۡهُ﴾: فلا تُطِعْهُ فيما دَعاكَ إلَيهِ.﴿وَٱقۡتَرِب﴾: واجْتَهِدْ في القُربِ مِن اللهِ."
