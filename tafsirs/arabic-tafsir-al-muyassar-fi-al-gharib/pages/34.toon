tafsir[49]{c,v,t}:
  34,2,"﴿يَلِجُ﴾: يَدْخُلُ.﴿يَخۡرُجُ مِنۡهَا﴾: أي: مِنَ النَّباتِ والمعادِن والِمياهِ.﴿وَمَا يَنزِلُ مِنَ ٱلسَّمَآءِ﴾: مِنَ الأمْطارِ والملائِكةِ والكُتُبِ.﴿وَمَا يَعۡرُجُ فِيهَا﴾: وما صَعَدُ إلَيها مِنَ الملائِكَةِ وأعْمالِ الخلْقِ."
  34,3,"﴿ٱلسَّاعَةُ﴾: القِيامةُ.﴿لَا يَعۡزُبُ عَنۡهُ﴾: لا يَغِيبُ عَنْهُ ولا يَخْفى عَلَيهِ.﴿مِثۡقَالُ ذَرَّةࣲ﴾: مِقْدارُ أصْغرِ نَمْلَةٍ.﴿كِتَـٰبࣲ مُّبِينࣲ﴾: كِتابٍ واضِحٍ، وهو اللَّوحُ المَحْفُوظُ."
  34,4,"﴿وَرِزۡقࣱ كَرِيمࣱ﴾: وهو الجنَّةُ."
  34,5,"﴿مُعَـٰجِزِينَ﴾: ظانِّينَ أنّهم يُعْجِزُونَنا ويَغْلِبُونَنا.﴿مِّن رِّجۡزٍ﴾: أسْوَأِ العَذابِ وأشَدِّهِ."
  34,6,"﴿وَيَرَى﴾: يَعْلمُ.﴿وَيَهۡدِيٓ﴾: يُرْشِدُ."
  34,7,"﴿يُنَبِّئُكُمۡ﴾: يُخْبِرُكُم بِنَبَأٍ غَرِيبٍ.﴿مُزِّقۡتُمۡ﴾: قُطِّعْتُم، وتَفَرَّقَتْ أجْسادُكُم إلى أجْزاءٍ."
  34,8,"﴿أَفۡتَرَىٰ﴾: هَلِ اخْتَلَقَ؟﴿جِنَّةُۢ﴾: جُنُونٌ."
  34,9,"﴿مَا بَيۡنَ أَيۡدِيهِمۡ وَمَا خَلۡفَهُم مِّنَ ٱلسَّمَآءِ وَٱلۡأَرۡضِ﴾: أي: كُلٌّ مِنَ السَّماءِ والأرضِ يُحِيطُ بِهِم مِن أمامِهِم وخَلْفِهِم.﴿نَخۡسِفۡ بِهِمُ ٱلۡأَرۡضَ﴾: نَجْعَلِ الأرْضَ تَبْتَلِعُهُم وهُمْ أحْياءٌ.﴿كِسَفࣰا مِّنَ ٱلسَّمَآءِ﴾: قِطَعًا مِنها.﴿مُّنِيبࣲ﴾: راجِعٍ إلى رَبِّهِ بالتَّوبَةِ والطّاعَةِ."
  34,10,"﴿أَوِّبِي﴾: سَبِّحِي.﴿وَأَلَنَّا لَهُ ٱلۡحَدِيدَ﴾: جَعَلْنا الحديدَ في يدِهِ لَيِّنًا، يَصْنَعُ بِهِ ما يَشاءُ."
  34,11,"﴿سَـٰبِغَـٰتࣲ﴾: أي: دُرُوعًا واسِعاتٍ تُغَطِّي الِجسْمَ كلَّه.﴿قَدِّرۡ فِي ٱلسَّرۡدِ﴾: أي: قَدِّرْ في نَسْجِ الدُّرُوعِ وإحْكامِها تَقْدِيرًا مُناسِبًا يَجْمَعُ ما بَينَ الخِفَّةِ والحَصانَةِ."
  34,12,"﴿غُدُوُّهَا شَهۡرࣱ﴾: أي: تَجْرِي الرِّيحُ مِن أوَّلِ النَّهارِ إلى انْتِصافِه مَسِيرَةَ شَهْرٍ بالسَّيرِ المُعْتادِ.﴿وَرَوَاحُهَا شَهۡرࣱ﴾: أي: تَجْرِي الرِّيحُ مِن مُّنْتَصَفِ النَّهارِ إلى اللَّيلِ مَسِيرَةَ شَهْرٍ.﴿وَأَسَلۡنَا لَهُۥ عَيۡنَ ٱلۡقِطۡرِ﴾: وأَسَلْنا لَهُ عَينَ النُّحاسِ كما يَسِيلُ الماءُ.﴿مَن يَزِغۡ﴾: مَن يَمِلْ ويَعدِلْ.﴿ٱلسَّعِيرِ﴾: النّارِ المسْتَعِرةِ."
  34,13,"﴿مَّحَـٰرِيبَ﴾: قُصُورٍ أو مساجِدَ.﴿وَتَمَـٰثِيلَ﴾: صُوَرٍ مُجَسَّمَةٍ من نُّحاسٍ وزُجاجٍ وغيرِهِما (وحُرِّمَ ذلك في الإسْلامِ).﴿وَجِفَانࣲ﴾: جَمْعُ «جَفْنَةٍ»، وهي القَصْعةُ الكَبِيرةُ.﴿كَٱلۡجَوَابِ﴾: جَمْعِ «جابِيَةٍ»، وهي الحوضُ الكبيرُ الذي يُجْمعُ فيه الماءُ.﴿رَّاسِيَـٰتٍ﴾: ثابتاتٍ على المواقِد، لا تَتَحَرَّكُ لِعِظَمِها."
  34,14,"﴿قَضَيۡنَا﴾: حَكَمْنا.﴿دَآبَّةُ ٱلۡأَرۡضِ﴾: الأَرَضَةُ الَّتي تَأْكُلُ الخَشَبَ.﴿مِنسَأَتَهُۥ﴾: عَصاهُ.﴿خَرَّ﴾: سَقَطَ ووَقَعَ.﴿تَبَيَّنَتِ﴾: عَلِمَتْ.﴿مَا لَبِثُواْ﴾: ما أقامُوا.﴿ٱلۡمُهِينِ﴾: المُذِلِّ."
  34,15,"﴿لِسَبَإࣲ﴾: «سبأ» بَلَدٌ باليمنِ سُمِّيَ باسم «سبأ بن يَشْجُب»، ويقعُ شرقَ صنعاء، ويُسَمّى الآنَ «مأرِبًا».﴿ءَايَةࣱ﴾: دَلالةٌ على قُدْرَتِنا.﴿جَنَّتَانِ عَن يَمِينࣲ وَشِمَالࣲ﴾: مَجْمُوعَتانِ كَبِيرَتانِ مِنَ البساتِينِ الكثيرةِ عَن يَمِينِ الوادِي وشِمالِه.﴿طَيِّبَةࣱ﴾: كريمةُ التُّربةِ حَسَنةُ الهواءِ."
  34,16,"﴿سَيۡلَ ٱلۡعَرِمِ﴾: السَّيلَ الجارِفَ الشَّدِيدَ.﴿خَمۡطࣲ﴾: هو الثَّمرُ المُرُّ الكريهُ الطَّعْمِ والرائِحَةِ.﴿أَثۡلࣲ﴾: هو شَجَرٌ شَبِيهٌ بالطَّرْفاءِ لا ثَمَرَ لَهُ.﴿سِدۡرࣲ﴾: هو شجرُ النَّبْقِ كثِيرُ الشَّوكِ."
  34,17,"﴿نُجَـٰزِيٓ﴾: نُعاقِبُ.﴿ٱلۡكَفُورَ﴾: الجَحودَ المبالِغَ في الكُفْرِ بِنِعَمِ اللهِ ورُسُلِه."
  34,18,"﴿بَيۡنَهُمۡ﴾: أي: بينَ أهلِ «سبأٍ» الَّذينَ كانُوا باليمنِ.﴿ٱلۡقُرَى ٱلَّتِي بَـٰرَكۡنَا فِيهَا﴾: هي بلادُ «الشّامِ».﴿قُرࣰى ظَـٰهِرَةࣰ﴾: قُرىً مُتَواصِلةً مُتَقارِبة يُرى بَعْضُها مِن بَعْضٍ (على امْتِداد الطَّرِيقِ مِنَ اليمنِ إلى الشّامِ).﴿قَدَّرۡنَا فِيهَا ٱلسَّيۡرَ﴾: أي: جَعَلْنا مَسافَةَ السَّيرِ بَيْنَ القُرى مَسافَةً متقارِبةً نَحْوًا مِن نِّصفِ يومٍ ليكونَ المَقِيلُ في قَرْيَةٍ والمبيتُ في أُخْرى.﴿ءَامِنِينَ﴾: لا تخافُونَ عَدُوًّا ولا جُوعًا ولا عَطَشًا."
  34,19,"﴿بَـٰعِدۡ بَيۡنَ أَسۡفَارِنَا﴾: أي: اجْعَلْ هذه القُرى المُتَقارِبةَ مُتَباعِدةً لِيَبْعُدَ سَفَرُنا بَينَها.﴿أَحَادِيثَ﴾: أي: ذوي أخبارٍ يتحدّثُ الناسُ بها في مجالِسِهِم للتَّعَجُّبِ والاعْتِبارِ.﴿وَمَزَّقۡنَـٰهُمۡ﴾: فَرَّقْناهُم في البلادِ.﴿لَـَٔايَـٰتࣲ﴾: لَعِبرًا وعِظاتٍ."
  34,20,"﴿صَدَّقَ عَلَيۡهِمۡ﴾: حقَّقَ عَلَيهِم.﴿ظَنَّهُۥ﴾: بأنّهم يَتَّبِعُونَه."
  34,21,"﴿سُلۡطَـٰنٍ﴾: تَسَلُّطٍ واسْتِيلاءٍ بالوسْوَسَةِ والإغْواءِ."
  34,22,"﴿زَعَمۡتُم مِّن دُونِ ٱللَّهِ﴾: أي: زَعَمْتُمُوهُم شركاءَ للهِ.﴿مِثۡقَالَ ذَرَّةࣲ﴾: مِقْدارَ أصْغَرِ نَمْلَةٍ.﴿شِرۡكࣲ﴾: مُشارَكَةٍ.﴿ظَهِيرࣲ﴾: مُعِينٍ على الخَلْقِ والتَّدبيرِ."
  34,23,"﴿فُزِّعَ عَن قُلُوبِهِمۡ﴾: أُزيِلَ الفَزَعُ والخوفُ عَن قُلُوبِهِم."
  34,25,"﴿أَجۡرَمۡنَا﴾: اكْتَسَبْنا مِنَ الذُّنُوبِ."
  34,26,"﴿يَفۡتَحُ بَيۡنَنَا﴾: يَقْضِي ويَحْكُمُ بَيْنَنا.﴿ٱلۡفَتَّاحُ﴾: الحاكِمُ بَينَ خَلْقِهِ."
  34,27,"﴿أَرُونِيَ﴾: أي: بالحُجَّةِ والدَّليلِ."
  34,28,"﴿كَآفَّةࣰ لِّلنَّاسِ﴾: للنّاسِ أجْمَعِينَ."
  34,30,"﴿مِّيعَادُ يَوۡمࣲ﴾: هو يومُ القيامةِ.﴿لَّا تَسۡتَـٔۡخِرُونَ عَنۡهُ﴾: لا تتأخَّرُونَ عَنْهُ.﴿لَا تَسۡتَقۡدِمُونَ﴾: لا تَتَقَدَّمُونَ عَلَيه."
  34,31,"﴿وَلَا بِٱلَّذِي بَيۡنَ يَدَيۡهِ﴾: ولا بالَّذي تَقَدَّمَهُ مِنَ الكُتُبِ السَّماوِيَّةِ كالتَّوراةِ والإنْجِيلِ والزَّبُورِ.﴿مَوۡقُوفُونَ﴾: محبوسُونَ في مَوْقِفِ الحِسابِ.﴿يَرۡجِعُ بَعۡضُهُمۡ إِلَىٰ بَعۡضٍ ٱلۡقَوۡلَ﴾: يتراجعُون الكلام باللَّومِ والعِتابِ فيما بَينَهُم."
  34,32,"﴿ٱلَّذِينَ ٱسۡتَكۡبَرُواْ﴾: هم القادَةُ والرُّؤساءُ الضّالُّون المُضِلُّونَ.﴿صَدَدۡنَـٰكُمۡ﴾: مَنَعْناكُم.﴿بَلۡ كُنتُم مُّجۡرِمِينَ﴾: بَلْ كُنْتُم اخْتَرْتُم سَبِيلَ الإجْرامِ لِمَحْضِ إرادَتِكُم."
  34,33,"﴿بَلۡ مَكۡرُ ٱلَّيۡلِ وَٱلنَّهَارِ﴾: بَلْ صَدَّنا مَكْرُكُم بِنا وتَدْبِيرُكُم الشَّرَّ لَنا في اللَّيلِ والنَّهارِ.﴿أَندَادࣰا﴾: أمْثالًا وشُرَكاءَ مِن مَّخْلُوقاتِه.﴿أَسَرُّواْ ٱلنَّدَامَةَ﴾: أي: أضْمَرَ وأَخْفى الفَرِيقانِ الحسْرةَ والنَّدامةَ.﴿ٱلۡأَغۡلَـٰلَ﴾: الأطْواقَ.﴿يُجۡزَوۡنَ﴾: يُعاقَبونَ."
  34,34,"﴿مِّن نَّذِيرٍ﴾: مِن رَّسولٍ.﴿مُتۡرَفُوهَآ﴾: مُتَنَعِّمُوها.﴿كَـٰفِرُونَ﴾: جاحِدُون، مُنْكِرُونَ."
  34,35,"﴿بِمُعَذَّبِينَ﴾: أي: في الدُّنيا ولا في الآخرةِ."
  34,36,"﴿يَبۡسُطُ﴾: يُوَسِّعُ.﴿يَقۡدِرُ﴾: يُضَيِّقُ."
  34,37,"﴿زُلۡفَىٰٓ﴾: قُرْبى.﴿لَهُمۡ جَزَآءُ ٱلضِّعۡفِ﴾: لهم الثَّوابُ المُضاعَفُ.﴿ٱلۡغُرُفَـٰتِ﴾: المنازلِ العالِيةِ في الجنّةِ.﴿ءَامِنُونَ﴾: أي: مِن جَمِيعِ ما يكْرَهُونَ كالعذابِ والموتِ والأحْزانِ."
  34,38,"﴿مُعَـٰجِزِينَ﴾: ظانّينَ أنّهُم يُعْجِزُونَنا ويَغلِبُونَنا.﴿فِي ٱلۡعَذَابِ مُحۡضَرُونَ﴾: مُقيمُونَ فيه تُحضِرُهم الزَّبانيةُ، فَلا يَسْتَطِيعُونَ الخُرُوجَ منه."
  34,39,"﴿يَبۡسُطُ﴾: يُوَسِّعُ.﴿يَقۡدِرُ﴾: يُضَيِّقُ.﴿يُخۡلِفُهُۥ﴾: يُعَوِّضُه لكم في الدُّنيا وفي الآخِرةِ."
  34,40,"﴿يَحۡشُرُهُمۡ﴾: يَجْمَعُهُم."
  34,41,"﴿سُبۡحَـٰنَكَ﴾: نُنَزِّهُكَ يا اللهُ.﴿أَنتَ وَلِيُّنَا﴾: أنتَ الَّذي نُوالِيهِ ونَعْبُدُهُ.﴿ٱلۡجِنَّ﴾: أي: الشَّياطِينَ."
  34,43,"﴿أَن يَصُدَّكُمۡ﴾: أن يَمْنَعَكُم.﴿إِفۡكࣱ مُّفۡتَرࣰى﴾: كَذِبٌ مُخْتَلَقٌ.﴿مُّبِينࣱ﴾: واضِحٌ."
  34,44,"﴿يَدۡرُسُونَهَا﴾: يَقْرَؤُونَها ويَفْهَمُونَها.﴿مِن نَّذِيرࣲ﴾: مِن رَّسولٍ."
  34,45,"﴿وَكَذَّبَ ٱلَّذِينَ مِن قَبۡلِهِمۡ﴾: أي: مِنَ الأُمَمِ الماضيةِ كَعادٍ وثمُودَ.﴿وَمَا بَلَغُواْ﴾: وما بلَغَ أهلُ مَكَّةَ.﴿مِعۡشَارَ مَآ ءَاتَيۡنَـٰهُمۡ﴾: عُشْرَ ما أعْطَيناهُم مِنَ النِّعَمِ.﴿نَكِيرِ﴾: إنْكارِي عليهم بالعِقابِ والعَذابِ."
  34,46,"﴿أَعِظُكُم بِوَ ٰ⁠حِدَةٍ﴾: أنْصَحُكُم وأُوصِيكُم بِخَصْلَةٍ واحِدَةٍ.﴿أَن تَقُومُواْ لِلَّهِ﴾: أن تَجْتَهِدُوا بالقِيامِ لهذا الأَمْرِ، مُخْلِصِينَ للهِ مِن غَيرِ هَوىً ولا عَصَبِيَّةٍ.﴿مِّن جِنَّةٍ﴾: مِن جُنُونٍ."
  34,48,"﴿يَقۡذِفُ بِٱلۡحَقِّ﴾: يَرْمِي الباطِلَ بالحقِّ فيَدْمَغُه."
  34,49,"﴿ٱلۡحَقُّ﴾: القرآنُ.﴿وَمَا يُبۡدِئُ ٱلۡبَـٰطِلُ وَمَا يُعِيدُ﴾: أي: ذَهَبَ واضْمَحَلَّ، ولم يَبْقَ مِنهُ إقْبالٌ ولا إدْبارٌ."
  34,50,"﴿ضَلَلۡتُ﴾: أي: عَنِ الصِّراطِ المُسْتَقِيمِ."
  34,51,"﴿إِذۡ فَزِعُواْ﴾: خافُوا عِنْدَ مُعايَنَتِهِم العَذابَ.﴿فَلَا فَوۡتَ﴾: أي: لا يفُوتُنِي أحَدٌ مِنهُم فَيَهْرُبَ.﴿مَّكَانࣲ قَرِيبࣲ﴾: مَوْضِعٍ قَرِيبٍ، فهُم لا يَبْعُدُونَ عَنِ اللهِ حيثُ كانُوا."
  34,52,"﴿وَأَنَّىٰ لَهُمُ ٱلتَّنَاوُشُ مِن مَّكَانِۭ بَعِيدࣲ﴾: وكَيْفَ لَهُمْ أن يَتَناوَلُوا الإيمانَ في الآخِرةِ وقَدْ تَرَكُوه في الدُّنيا؟"
  34,53,"﴿وَيَقۡذِفُونَ بِٱلۡغَيۡبِ مِن مَّكَانِۭ بَعِيدࣲ﴾: يَرْمُونَ مِن مَّكانٍ بَعِيدٍ وهُمْ لا يَرَوْنَ."
  34,54,"﴿وَحِيلَ﴾: وحُجِزَ ومُنِعَ.﴿مَا يَشۡتَهُونَ﴾: أي: مِنَ التَّوبَةِ والعوْدَةِ إلى الدُّنيا.﴿بِأَشۡيَاعِهِم﴾: بأمثالِهِم مِنَ الكُفّارِ.﴿مُّرِيبِۭ﴾: مُوقِعٍ في الرِّيبةِ."
