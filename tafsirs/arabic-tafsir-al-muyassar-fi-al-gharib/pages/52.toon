tafsir[40]{c,v,t}:
  52,1,"﴿وَٱلطُّورِ﴾: هُوَ الجَبَلُ الَّذِي كَلَّمَ اللهُ عَلَيهِ مُوسى عَلَيهِ السَّلامُ."
  52,2,"﴿مَّسۡطُورࣲ﴾: مَكْتُوبٍ، وهُو القُرآنُ."
  52,3,"﴿فِي رَقࣲّ مَّنشُورࣲ﴾: مَكْتُوبٍ في صَحِيفةٍ مَبْسُوطَةٍ."
  52,4,"﴿وَٱلۡبَيۡتِ ٱلۡمَعۡمُورِ﴾: هو فَوْقَ السَّماءِ السّابِعةِ تَطُوفُ بِه الملائِكةُ دائِمًا."
  52,5,"﴿وَٱلسَّقۡفِ ٱلۡمَرۡفُوعِ﴾: هو السَّماءُ الدُّنيا، جَعَلَها اللهُ سَقْفًا للأرْضِ."
  52,6,"﴿ٱلۡمَسۡجُورِ﴾: الممْلُوءِ بالمياهِ."
  52,8,"﴿دَافِعࣲ﴾: مانِعٍ يَمْنَعُه حِينَ وقُوعِهِ."
  52,9,"﴿تَمُورُ﴾: تَتَحرَّكُ وتَضْطَرِبُ."
  52,10,"﴿وَتَسِيرُ﴾: تَزُولُ عَنْ أماكِنِها وتَسيرُ كَسَيرِ السَّحابِ."
  52,11,"﴿فَوَيۡلࣱ﴾: فَهَلاكٌ."
  52,12,"﴿فِي خَوۡضࣲ﴾: في انْدِفاعٍ في الكَلامِ الباطِلِ.﴿يَلۡعَبُونَ﴾: يَسْتَهْزِئُونَ."
  52,13,"﴿يُدَعُّونَ﴾: يُدْفَعُونَ.﴿دَعًّا﴾: دَفْعًا بِعُنْفٍ ومهانَةٍ."
  52,15,"52:14"
  52,16,"﴿ٱصۡلَوۡهَا﴾: ادْخُلُوها واحْتَرِقُوا بِنارِها."
  52,18,"﴿فَـٰكِهِينَ﴾: طَيِّبَةً أنْفُسُكُم مُتَمَتِّعِينَ عَلى وجْهِ السُّرِورِ."
  52,19,"﴿هَنِيٓـَٔۢا﴾: أكْلًا وشُرْبًا هَنِيئًا أي سائِغًا."
  52,20,"﴿مُتَّكِـِٔينَ﴾: جالِسِين عَلى وجْهِ التَّمَكُّن والرّاحةِ.﴿سُرُرࣲ﴾: جَمْعُ سَرِيرٍ وهو ما يُضْطَجَعُ عَلَيهِ، وهو مَجْلِسُ المنَعَّمِينَ.﴿مَّصۡفُوفَةࣲ﴾: مُتَقابِلَةٍ.﴿وَزَوَّجۡنَـٰهُم﴾: قَرَنّاهُم.﴿بِحُورٍ﴾: بِنِساءٍ شَدِيداتِ بَياضِ العَينِ وسَوادها.﴿عِينࣲ﴾: واسِعاتِ العُيونِ حِسانِهِنَّ."
  52,21,"﴿وَمَآ أَلَتۡنَـٰهُم﴾: وما نَقَصْناهُم.﴿رَهِينࣱ﴾: مَحْبُوسٌ مقْرُونٌ."
  52,22,"﴿وَأَمۡدَدۡنَـٰهُم﴾: وزِدْناهُم."
  52,23,"﴿يَتَنَـٰزَعُونَ﴾: يَتَعاطَونَ، ويُناوِلُ بعضُهم بَعْضًا.﴿كَأۡسࣰا﴾: إناءً مَمْلُوءًا مِنَ الخَمْرِ.﴿لَغۡوࣱ﴾: كَلامٌ لا فائِدةَ فِيهِ.﴿تَأۡثِيمࣱ﴾: إثْمٌ ومَعْصِيَةٌ."
  52,24,"﴿مَّكۡنُونࣱ﴾: مَصُونٌ في أصْدافِهِ."
  52,26,"﴿مُشۡفِقِينَ﴾: خائِفِينَ مِن عَذابِ رَبِنا."
  52,27,"﴿ٱلسَّمُومِ﴾: نارِ جَهَنَّمَ وحَرارَتِها."
  52,28,"﴿ٱلۡبَرُّ﴾: المُحْسِنُ."
  52,29,"﴿بِنِعۡمَتِ رَبِّكَ﴾: بمَنِّهِ ولُطْفِهِ.﴿بِكَاهِنࣲ﴾: يُخْبِرُ بالغَيبِ دُونَ عِلْمٍ."
  52,30,"﴿نَّتَرَبَّصُ﴾: نَنْتَظِرُ.﴿رَيۡبَ ٱلۡمَنُونِ﴾: حوادِثَ الدَّهرِ فَيَمُوتُ."
  52,32,"﴿أَحۡلَـٰمُهُم﴾: عُقُولُهم.﴿طَاغُونَ﴾: مُتَجاوِزُونَ الحدَّ."
  52,33,"﴿تَقَوَّلَهُۥ﴾: اخْتَلَقَهُ."
  52,35,"52:34"
  52,36,"52:34"
  52,37,"﴿ٱلۡمُصَۜيۡطِرُونَ﴾: المُتَسَلِّطُونَ."
  52,38,"﴿سُلَّمࣱ﴾: دَرَجٌ ومَصْعَدٌ إلى السَّماءِ.﴿يَسۡتَمِعُونَ﴾: الكَلامَ الَّذِي يَجْرِي في السَّماءِ ويَسْتَرِقُونَهُ.﴿بِسُلۡطَـٰنࣲ﴾: بِحُجَّةٍ."
  52,40,"﴿مَّغۡرَمࣲ﴾: غَرامةٍ مَطْلُوبَةٍ مِنهُم."
  52,42,"﴿كَيۡدࣰا﴾: مَكْرًا.﴿ٱلۡمَكِيدُونَ﴾: يَعُودُ ضَرَرُ مَكْرِهِم عَلَيهِم."
  52,44,"﴿كِسۡفࣰا﴾: قِطَعًا كِبارًا مِنَ العَذابِ.﴿مَّرۡكُومࣱ﴾: مُتَراكِمٌ بَعْضُهُ فَوْقَ بَعْضٍ."
  52,45,"﴿فَذَرۡهُمۡ﴾: فَدَعْهُم.﴿يُصۡعَقُونَ﴾: يُهلَكُونَ، وهو يومُ القِيامَةِ."
  52,46,"﴿لَا يُغۡنِي﴾: لا يَدْفَعُ."
  52,47,"﴿عَذَابࣰا دُونَ ذَ ٰ⁠لِكَ﴾: مِنَ القَتْلِ والسَّبْيِ وعَذابِ القَبْرِ."
  52,48,"﴿بِأَعۡيُنِنَا﴾: بِمَرْأىً مِنّا وحِفْظٍ واعْتِناءٍ.﴿حِينَ تَقُومُ﴾: إلى الصَّلاةِ، وحِينَ تَقُومُ مِنَ النَّومِ."
  52,49,"﴿وَإِدۡبَـٰرَ ٱلنُّجُومِ﴾: عِنْدَ صَلاةِ الصُّبْحِ حِينَ يُغَطِّي ضَوءُ الصُّبْحِ النُّجُومَ."
