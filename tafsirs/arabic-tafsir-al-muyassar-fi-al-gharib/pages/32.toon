tafsir[27]{c,v,t}:
  32,1,"﴿الٓمٓ﴾: سَبَقَ الكَلامُ عَلى مِثْلهِ في أوَّلِ سُورةِ البقرةِ."
  32,2,"﴿لَا رَيۡبَ فِيهِ﴾: لاشَكَّ فِيه."
  32,3,"﴿أَمۡ يَقُولُونَ﴾: بل أيقُولُ المشرِكُونَ.﴿ٱفۡتَرَىٰهُ﴾: اختَلَقَ محمدٌ ﷺ القرآنَ مِن تِلْقاءِ نَفْسِهِ.﴿نَّذِيرࣲ﴾: أي: رَسُولٍ مُنْذِرٍ."
  32,4,"﴿ٱسۡتَوَىٰ عَلَى ٱلۡعَرۡشِ﴾: عَلا وارْتَفَعَ سُبْحانَه وتَعالى عَلى عَرْشِهِ كَما يَليقُ بِجَلالِهِ.﴿ٱلۡعَرۡشِ﴾: هُوَ سَريرُ المُلْكِ الَّذي اسْتَوى عَلَيهِ الرَّحْمَنُ، وتَحْمِلُهُ الملائِكَةُ، وهْوَ أعْظَمُ المْخلُوقاتِ، وهو سَقْفُ الجنَّةِ.﴿وَلِيࣲّ﴾: ناصِرٍ يَنْصُرُكُم.﴿تَتَذَكَّرُونَ﴾: تَتَّعِظُونَ."
  32,5,"﴿يُدَبِّرُ ٱلۡأَمۡرَ﴾: يَقْضِي القَضاءَ.﴿يَعۡرُجُ﴾: يَصْعَدُ."
  32,7,"﴿أَحۡسَنَ كُلَّ شَيۡءٍ﴾: أحْكَمَهُ وأَتْقَنَهُ.﴿طِينࣲ﴾: تُرابٍ."
  32,8,"﴿نَسۡلَهُۥ﴾: ذُرِّيَّتَه.﴿سُلَـٰلَةࣲ﴾: نُطْفَةٍ مَسْلُولَةٍ.﴿مَّهِينࣲ﴾: ذَلِيلٍ."
  32,9,"﴿سَوَّىٰهُ﴾: أتمَّ خَلْقَهُ.﴿وَٱلۡأَفۡـِٔدَةَ﴾: القُلُوبَ."
  32,10,"﴿ضَلَلۡنَا فِي ٱلۡأَرۡضِ﴾: ضِعْنا فِيها وصِرْنا تُرابًا.﴿كَـٰفِرُونَ﴾: مُنْكِرُونَ."
  32,11,"﴿يَتَوَفَّىٰكُم﴾: يَقبِضُ أرْواحَكُم.﴿وُكِّلَ بِكُمۡ﴾: وُكِّلَ بِقَبْضِ أرْواحِكِم."
  32,12,"﴿نَاكِسُواْ رُءُوسِهِمۡ﴾: أي: مُطْرِقُوها خِزْيًا ونَدامَةً.﴿مُوقِنُونَ﴾: مُصَدِّقُونَ."
  32,13,"﴿هُدَىٰهَا﴾: رُشْدَها، وتَوفِيقَها لِلْإيمانِ.﴿حَقَّ﴾: وجَبَ وثَبَتَ."
  32,14,"﴿ٱلۡخُلۡدِ﴾: الدّائِمِ."
  32,15,"﴿يُؤۡمِنُ﴾: يُصَدِّقُ.﴿ذُكِّرُواْ بِهَا﴾: وُعِظِوُا بِها.﴿خَرُّواْ﴾: سَقَطوُا."
  32,16,"﴿تَتَجَافَىٰ﴾: تَرْتَفِعُ وتَتَنَحّى.﴿عَنِ ٱلۡمَضَاجِعِ﴾: عَنِ الفُرُشِ الَّتِي يُضْطَجَعُ عَلَيها."
  32,17,"﴿مِّن قُرَّةِ أَعۡيُنࣲ﴾: مِن موجِباتِ المسَرَّةِ والفَرَحِ."
  32,19,"﴿نُزُلَۢا﴾: ما يُهيَّأُ للنَّزيلِ ضِيافَةً وإكْرامًا."
  32,20,"﴿فَمَأۡوَىٰهُمُ﴾: المكانُ الَّذي يَأْوُونَ إليه."
  32,21,"﴿ٱلۡعَذَابِ ٱلۡأَدۡنَىٰ﴾: وهو ما يُصِيبُهُم في الدُّنيا مِنَ البَلاءِ والِمحَنَ.﴿ٱلۡعَذَابِ ٱلۡأَكۡبَرِ﴾: وهو ما يُصِيبُهُم يومَ القِيامةِ مِن عَذابِ جَهَنَّمَ."
  32,22,"﴿ذُكِّرَ﴾: وُعِظَ."
  32,23,"﴿فِي مِرۡيَةࣲ﴾: في شَكٍّ.﴿مِّن لِّقَآئِهِۦ﴾: أي: مِن لِقاءِ مُوسى عَلَيهِ الصَّلاةُ والسَّلامُ."
  32,25,"﴿يَفۡصِلُ﴾: يَقْضِي."
  32,26,"﴿أَوَ لَمۡ يَهۡدِ لَهُمۡ﴾: أوَلم يُبَيِّنْ لَهُم.﴿مِّنَ ٱلۡقُرُونِ﴾: مِنَ الأُمَمِ السّابقِةِ.﴿لَـَٔايَـٰتٍ﴾: لَعِبَرًا وعِظاتٍ."
  32,27,"﴿ٱلۡجُرُزِ﴾: الأرْضِ اليابِسةِ الغَلِيظَةِ الجرْداءِ الَّتي لا نَباتَ فِيها."
  32,28,"﴿هَـٰذَا ٱلۡفَتۡحُ﴾: هذا القضاءُ بين العِبادِ."
  32,29,"﴿يُنظَرُونَ﴾: يُمْهَلُونَ لِيؤْمِنُوا."
  32,30,"﴿وَٱنتَظِرۡ﴾: أي: انْتَظِرْ ما اللهُ صانِعٌ بِهِم."
