tafsir[118]{c,v,t}:
  9,1,"﴿بَرَآءَةࣱ﴾: إعذارٌ وتَحَلُّلٌ من العهودِ.﴿عَـٰهَدتُّم﴾: التزَمْتُم معهم بميثاقٍ."
  9,2,"﴿فَسِيحُواْ﴾: فسِيروا آمنين.﴿غَيۡرُ مُعۡجِزِي ٱللَّهِ﴾: لن تُفْلِتُوا من عقوبةِ الله.﴿مُخۡزِي ٱلۡكَـٰفِرِينَ﴾: مُذِلُّهم في الدنيا والآخرة."
  9,3,"﴿وَأَذَ ٰ⁠نࣱ﴾: إعلامٌ وإنذارٌ.﴿يَوۡمَ ٱلۡحَجِّ ٱلۡأَكۡبَرِ﴾: يومَ النَّحرِ.﴿تُبۡتُمۡ﴾: رَجَعْتُم إلى الحقِّ وتَرَكْتُم الشِّركَ.﴿تَوَلَّيۡتُمۡ﴾: أعْرَضْتُم.﴿وَبَشِّرِ﴾: وأنذِرْ."
  9,4,"﴿لَمۡ يَنقُصُوكُمۡ شَيۡـࣰٔا﴾: لم يَخُونوا العهدَ ولا شروطَه.﴿وَلَمۡ يُظَـٰهِرُواْ﴾: ولم يُعاونوا.﴿إِلَىٰ مُدَّتِهِمۡ﴾: إلى مدةِ العهدِ المحددةِ."
  9,5,"﴿ٱنسَلَخَ﴾: خَرَجَ وانقَضى.﴿ٱلۡأَشۡهُرُ ٱلۡحُرُمُ﴾: الأشهرُ الأربعةُ التي أمَّنتم بها المشركين.﴿وَخُذُوهُمۡ﴾: وأْسِروهم.﴿وَٱحۡصُرُوهُمۡ﴾: اقصِدُوهم بالحِصارِ في معاقِلِهم، أو امنعُوهم من الخروجِ والتنقُّلِ في البلادِ.﴿كُلَّ مَرۡصَدࣲ﴾: كلَّ طريقٍ ومَرْقَبٍ.﴿تَابُواْ﴾: رَجَعُوا عن الكفر ودخلوا في الإسلام.﴿فَخَلُّواْ سَبِيلَهُمۡ﴾: فاترُكوهم ولا تتعرَّضوا لهم."
  9,6,"﴿ٱسۡتَجَارَكَ﴾: طَلَبَ جِوارَكَ، أي: حمايتَك وأمانَك.﴿فَأَجِرۡهُ﴾: فأمِّنْهُ.﴿كَلَـٰمَ ٱللَّهِ﴾: القرآنَ الكريمَ.﴿أَبۡلِغۡهُ مَأۡمَنَهُۥ﴾: أعِدْهُ من حيثُ أتى آمِنًا."
  9,7,"﴿كَيۡفَ يَكُونُ﴾: لا يكونُ.﴿عَهۡدٌ﴾: التزامٌ بميثاقٍ.﴿ٱلۡمَسۡجِدِ ٱلۡحَرَامِ﴾: الحَرَمِ كلِّه.﴿فَمَا ٱسۡتَقَـٰمُواْ لَكُمۡ﴾: فما أقاموا على الوفاءِ بعهدكم."
  9,8,"﴿يَظۡهَرُواْ عَلَيۡكُمۡ﴾: يَظْفَرُوا بكم ويَغْلِبوكم.﴿لَا يَرۡقُبُواْ﴾: لا يُراعُوا.﴿إِلࣰّا﴾: قَرابةً ولا حِلْفًا.﴿ذِمَّةࣰ﴾: عَهْدًا ولا حَقًّا."
  9,9,"﴿ٱشۡتَرَوۡاْ﴾: استبدَلُوا.﴿ثَمَنࣰا قَلِيلࣰا﴾: عَرَضَ الدنيا الزائلَ.﴿فَصَدُّواْ عَن سَبِيلِهِۦٓ﴾: فأعرضُوا عن الحقِّ، ومنعُوا غيرَهم عنه.﴿سَآءَ﴾: قَبُحَ."
  9,11,"﴿وَنُفَصِّلُ﴾: نُبيِّنُ."
  9,12,"﴿نَّكَثُوٓاْ﴾: نَقَضُوا.﴿أَيۡمَـٰنَهُم﴾: مواثيقَهم المؤكَّدةَ بالأَيْمان.﴿وَطَعَنُواْ فِي دِينِكُمۡ﴾: ذَمُّوا الإسلامَ وعابُوه.﴿لَآ أَيۡمَـٰنَ لَهُمۡ﴾: لا عهودَ لهم يُوَفّى بها."
  9,13,"﴿وَهَمُّواْ﴾: وعَزَمُوا وعَمِلوا.﴿بَدَءُوكُمۡ﴾: بالإيذاءِ والقتالِ.﴿أَوَّلَ مَرَّةٍ﴾: أولَ الأمرِ «بمكةَ» «وببَدْرٍ» وغيرِهما.﴿أَتَخۡشَوۡنَهُمۡ﴾: أتَخافُونهم، أو أتخافون ملاقاتَهم في الحربِ؟"
  9,14,"﴿يُعَذِّبۡهُمُ﴾: يَقْتُلْهم.﴿وَيُخۡزِهِمۡ﴾: ويُذِلّهم بالهزيمةِ والأَسْرِ.﴿وَيَشۡفِ﴾: يُزِلِ الغَمَّ ونحوَه."
  9,15,"﴿غَيۡظَ قُلُوبِهِمۡ﴾: غَضَبَها وما تحمِلُه من كراهةٍ للأعداءِ."
  9,16,"﴿تُتۡرَكُواْ﴾: دونَ اختبارٍ وابتلاءٍ.﴿وَلِيجَةࣰ﴾: بِطانةً وأولياءَ."
  9,17,"﴿مَا كَانَ﴾: ما صَحَّ ولا استقامَ.﴿أَن يَعۡمُرُواْ مَسَـٰجِدَ ٱللَّهِ﴾: أن يَبْنُوها ويَصُونوها، أو أن يُقيموا العبادةَ فيها.﴿حَبِطَتۡ﴾: بَطَلتْ."
  9,19,"﴿سِقَايَةَ ٱلۡحَآجِّ﴾: سَقْيَ الحُجّاجِ الماءَ.﴿لَا يَهۡدِي﴾: لا يُوَفِّقُ﴿ٱلظَّـٰلِمِينَ﴾: الكافرين."
  9,20,"﴿دَرَجَةً﴾: مَنزِلَةً."
  9,21,"﴿وَرِضۡوَ ٰ⁠نࣲ﴾: رضا اللهِ عنهم الذي لا سُخْطَ بعدَه.﴿مُّقِيمٌ﴾: دائمٌ لا يَزُولُ."
  9,23,"﴿أَوۡلِيَآءَ﴾: نصراءَ وأصدقاءَ.﴿ٱسۡتَحَبُّواْ ٱلۡكُفۡرَ﴾: اختارُوه ودامُوا عليه."
  9,24,"﴿وَعَشِيرَتُكُمۡ﴾: قبيلتُكم وذوو القَرابةِ القريبة.﴿ٱقۡتَرَفۡتُمُوهَا﴾: اكتسَبْتموها.﴿كَسَادَهَا﴾: عَدَمَ رَواجِها.﴿تَرۡضَوۡنَهَآ﴾: تُعْجِبُكم وتميلُ أنفسُكم إليها.﴿فَتَرَبَّصُواْ﴾: فانتظِرُوا.﴿بِأَمۡرِهِۦ﴾: بعقابِه."
  9,25,"﴿بِمَا رَحُبَتۡ﴾: مع وُسْعِها.﴿وَلَّيۡتُم﴾: فَرَرْتُم.﴿مُّدۡبِرِينَ﴾: مُنْهَزِمِين، جاعِلين ظُهورَكم جهةَ عدوِّكم."
  9,26,"﴿سَكِينَتَهُۥ﴾: طمأنينتَه وأَمْنَه.﴿جُنُودࣰا﴾: ملائكةً."
  9,28,"﴿نَجَسࣱ﴾: خُبَثاءُ في عقائدِهم وأعمالِهم الشِّرْكيةِ.﴿عَامِهِمۡ هَـٰذَا﴾: وهو العامُ التاسعُ من الهجرةِ.﴿عَيۡلَةࣰ﴾: فَقْرًا."
  9,29,"﴿وَلَا يَدِينُونَ دِينَ ٱلۡحَقِّ﴾: ولا يَلْتزمون أحكامَ الإسلام الذي ارتضاه الله دِينًا للناسِ.﴿ٱلۡجِزۡيَةَ﴾: ما قُدِّرَ على أهل الكِتابِ من المالِ كلَّ عامٍ؛ جزاءً لما مُنِحُوا من الأمنِ.﴿عَن يَدࣲ﴾: بأيدِيهم غيرَ ممتنعين.﴿صَـٰغِرُونَ﴾: خاضِعونَ أذلّاءُ."
  9,30,"﴿عُزَيۡرٌ﴾: حَبْرٌ من علماءِ اليهودِ، يُعَظِّمُونه؛ لعِلْمِه وعبادتِه.﴿يُضَـٰهِـُٔونَ﴾: يُشابِهُون.﴿قَـٰتَلَهُمُ ٱللَّهُ﴾: دعاءٌ عليهم بالهَلاكِ.﴿أَنَّىٰ يُؤۡفَكُونَ﴾: كيف يُصْرَفُون عن الحقِّ الواضحِ إلى الباطلِ؟"
  9,31,"﴿أَحۡبَارَهُمۡ﴾: جَمْعُ حَبْرٍ، وهم العلماءُ من اليهودِ.﴿وَرُهۡبَـٰنَهُمۡ﴾: جَمْعُ راهبٍ، وهم العُبّادُ من النَّصارى.﴿أَرۡبَابࣰا مِّن دُونِ ٱللَّهِ﴾: إذ أطاعُوهم في تحريمِ ما أحلَّ اللهُ، وتحليلِ ما حَرَّمه.﴿وَٱلۡمَسِيحَ ٱبۡنَ مَرۡيَمَ﴾: واتخذ النصارى عيسى عليه السلام إلهًا فعبدُوه.﴿سُبۡحَـٰنَهُۥ﴾: تَنَزَّه اللهُ وتَقَدَّسَ."
  9,32,"﴿يُرِيدُونَ﴾: يريدُ الكفّارُ بتكذيبهِم.﴿أَن يُطۡفِـُٔواْ﴾: أن يُبْطِلُوا.﴿نُورَ ٱللَّهِ﴾: دينَ الإسلامِ وما فيه من الهُدى والرَّشادِ.﴿يُتِمَّ نُورَهُۥ﴾: يُكْمِلَ اللهُ دينَه ويُظْهِرَه."
  9,33,"﴿بِٱلۡهُدَىٰ﴾: بالإيمانِ الصَّحيحِ، والعلمِ النافعِ.﴿وَدِينِ ٱلۡحَقِّ﴾: دينِ الإسلامِ.﴿لِيُظۡهِرَهُۥ﴾: ليُعْلِيَه.﴿عَلَى ٱلدِّينِ كُلِّهِۦ﴾: على الأديانِ جميعًا."
  9,34,"﴿لَيَأۡكُلُونَ أَمۡوَ ٰ⁠لَ ٱلنَّاسِ﴾: لَيأخُذُونها.﴿بِٱلۡبَـٰطِلِ﴾: بغيرِ حَقٍّ كالرِّشوةِ وغيرِها.﴿وَيَصُدُّونَ عَن سَبِيلِ ٱللَّهِ﴾: ويمنعون الناسَ من الدخولِ في الإسلامِ، أو اتباعِ الحقِّ.﴿يَكۡنِزُونَ ٱلذَّهَبَ وَٱلۡفِضَّةَ﴾: يجمعونَ الأموالَ.﴿وَلَا يُنفِقُونَهَا فِي سَبِيلِ ٱللَّهِ﴾: ولايُؤَدُّون زَكاتَها، ولايُخْرِجون منها الحقوقَ الواجبةَ."
  9,35,"﴿فَتُكۡوَىٰ﴾: تُحْرَقُ.﴿فَذُوقُواْ مَا كُنتُمۡ تَكۡنِزُونَ﴾: ذُوقوا سوءَ عاقبةِ جَمْعِكم."
  9,36,"﴿عِدَّةَ ٱلشُّهُورِ﴾: أي: عَدَدَها الذي يَتَألَّفُ منه العامُ.﴿فِي كِتَـٰبِ ٱللَّهِ﴾: في حُكْمِه القَدَريِّ الذي كُتب في اللَّوحِ المحفوظِ.﴿أَرۡبَعَةٌ حُرُمࣱ﴾: أي: ذاتُ حُرْمَةٍ وتعظيمٍ، وهي: رَجَبٌ، وذو القِعدة، وذو الحِجَّةِ، والمُحَرَّمُ.﴿ٱلۡقَيِّمُ﴾: المستقيمُ الذي لا عِوَجَ فيه.﴿فَلَا تَظۡلِمُواْ فِيهِنَّ أَنفُسَكُمۡ﴾: بارتكابِ ما حَرَّمَ اللهُ؛ لعِظَمِ حُرْمتِها.﴿كَآفَّةࣰ﴾: جميعًا، وفي كلِّ الشهورِ.﴿وَٱعۡلَمُوٓاْ أَنَّ ٱللَّهَ مَعَ ٱلۡمُتَّقِينَ﴾: بالعَوْنِ والنَّصرِ."
  9,37,"﴿ٱلنَّسِيٓءُ﴾: تأخيرُ حُرْمَةِ شهرٍ إلى شهرٍ آخرَ، كما كانت تفعلُه العربُ في الجاهليةِ.﴿يُحِلُّونَهُۥ﴾: أي: النسيءَ.﴿لِّيُوَاطِـُٔواْ﴾: ليوافِقُوا بتحليلِ شهرٍ وتحريمِ آخرَ بَدَلَه.﴿عِدَّةَ﴾: عددَ.﴿مَا حَرَّمَ ٱللَّهُ﴾: من الأشهرِ، بحيث تكونُ أربعةً في العددِ.﴿لَا يَهۡدِي﴾: لا يُوَفِّقُ."
  9,38,"﴿ٱنفِرُواْ﴾: اخرُجُوا بخِفَّةٍ ونشاطٍ.﴿فِي سَبِيلِ ٱللَّهِ﴾: إلى الجهادِ لإعلاءِ كلمةِ اللهِ.﴿ٱثَّاقَلۡتُمۡ إِلَى ٱلۡأَرۡضِ﴾: تباطَأْتم في الخروجِ ومِلْتُم إلى الإقامةِ في أرضِكم ومساكِنِكُم.﴿مِنَ ٱلۡـَٔاخِرَةِ﴾: بدلَ نعيمِ الآخرةِ.﴿مَتَـٰعُ ٱلۡحَيَوٰةِ ٱلدُّنۡيَا﴾: ما يُتَمَتَّعُ به مِن لَذّاتِ الدنيا."
  9,39,"﴿يُعَذِّبۡكُمۡ﴾: يُنْزِلْ عقوبتَه بكم."
  9,40,"﴿إِلَّا تَنصُرُوهُ﴾: إن لم تَنْصُروا النبيَّ ﷺ.﴿ثَانِيَ ٱثۡنَيۡنِ﴾: أحدَ اثنين، والثاني هو أبوبكرٍ الصدّيقُ رضي الله عنه.﴿ٱلۡغَارِ﴾: النَّقْبِ في الَجبَلِ، وهو في جبلِ ثورٍ ب«مكةَ».﴿لِصَـٰحِبِهِۦ﴾: أبي بكرٍ الصديقِ رضي الله عنه.﴿سَكِينَتَهُۥ﴾: طمأنينتَه.﴿بِجُنُودࣲ﴾: هم الملائكةُ، يَحْرُسُونه ويَصْرِفُون أبصارَ الكفارِ عنه.﴿كَلِمَةَ ٱلَّذِينَ كَفَرُواْ﴾: أي: دعوةَ الشِّركِ والكفرِ.﴿ٱلسُّفۡلَىٰ﴾: المغلوبةَ.﴿كَلِمَةُ ٱللَّهِ﴾: كلمةُ التوحيدِ.﴿ٱلۡعُلۡيَا﴾: الغالبةُ."
  9,41,"﴿خِفَافࣰا﴾: على الصِّفةِ التي يَخِفُّ عليكم الجهادُ فيها.﴿وَثِقَالࣰا﴾: وعلى الصفةِ التي يَثْقُلُ عليكم الجهادُ فيها."
  9,42,"﴿لَوۡ كَانَ﴾: أي: ما دَعَوْتَهم إليه من الخروجِ للجهادِ.﴿عَرَضࣰا﴾: مَتاعًا وغَنيمةً.﴿قَرِيبࣰا﴾: سَهْلَ المأخَذِ.﴿قَاصِدࣰا﴾: متوسِّطًا بَيْنَ القُرْبِ والبُعْدِ لا مَشَقَّةَ فيه.﴿ٱلشُّقَّةُ﴾: المسافةُ البعيدةُ التي تُقْطَعُ بمَشَقَّةٍ.﴿يُهۡلِكُونَ أَنفُسَهُمۡ﴾: بالَحلِفِ الكاذبِ والنِّفاقِ."
  9,43,"﴿عَفَا ٱللَّهُ عَنكَ﴾: العَفْوُ: هو التجاوُزُ عن الخطأ وتَرْكُ المؤاخذةِ عليه."
  9,45,"﴿يَسۡتَـٔۡذِنُكَ﴾: يَطْلُبُ الإذنَ للتخَلُّفِ عن الجهادِ.﴿وَٱرۡتَابَتۡ قُلُوبُهُمۡ﴾: شَكَّتْ في الإسلامِ وشرائعِه.﴿يَتَرَدَّدُونَ﴾: يتَحيَّرُون."
  9,46,"﴿ٱلۡخُرُوجَ﴾: مَعَك إلى الجهادِ.﴿لَأَعَدُّواْ لَهُۥ عُدَّةࣰ﴾: لَتَأهَّبُوا له بإعدادِ السِّلاحِ، والزادِ، وما يُحتاجُ إليه.﴿ٱنۢبِعَاثَهُمۡ﴾: خروجَهم للجهادِ.﴿فَثَبَّطَهُمۡ﴾: مَنَعهم وعوَّقهم بقَضائِه وقَدَرِه.﴿ٱقۡعُدُواْ﴾: تَخَلَّفُوا عن الجِهادِ.﴿مَعَ ٱلۡقَـٰعِدِينَ﴾: من المرضى والضُّعَفاءِ والنِّساءِ والصِّبْيانِ."
  9,47,"﴿خَبَالࣰا﴾: شرًّا وفسادًا.﴿وَلَأَوۡضَعُواْ خِلَـٰلَكُمۡ﴾: أسْرَعُوا في المَشْيِ بينَكم بالنميمةِ وإفسادِ القلوبِ.﴿يَبۡغُونَكُمُ﴾: يُريدُون لكم.﴿ٱلۡفِتۡنَةَ﴾: ما تُفْتَنُون به؛ كي تتثاقَلُوا عن الجهادِ في سبيلِ اللهِ.﴿سَمَّـٰعُونَ لَهُمۡ﴾: مَن يَسْمعون كلام المنافقين، ويُطيعونهم."
  9,48,"﴿ٱبۡتَغَوُاْ﴾: طلبُوا وأرادوا.﴿ٱلۡفِتۡنَةَ﴾: فتنةَ المؤمنين وصَدَّهم عن دينِهم.﴿مِن قَبۡلُ﴾: من قبلِ غزوةِ «تبوكَ».﴿وَقَلَّبُواْ لَكَ ٱلۡأُمُورَ﴾: أرادُوا إبطالَ ما جِئْتَ به بتحايُلِهم ومَكْرِهم.﴿ٱلۡحَقُّ﴾: النصرُ من عندِ اللهِ.﴿وَظَهَرَ﴾: علا وغَلَبَ.﴿أَمۡرُ ٱللَّهِ﴾: دينُه، وهو الإسلامُ."
  9,49,"﴿وَمِنۡهُم﴾: ومن المنافقين.﴿ٱئۡذَن لِّي﴾: في التخَلُّف عن الجهادِ.﴿وَلَا تَفۡتِنِّيٓ﴾: لاتُوقِعْني في فتنةِ النِّساءِ حالةَ الخروجِ معك.﴿فِي ٱلۡفِتۡنَةِ﴾: فتنةِ النِّفاقِ والتخلُّفِ عن الجهادِ.﴿سَقَطُواْ﴾: وقعوا في الإثمِ لمخالَفَتِهم أمرَ اللهِ ورسولِه."
  9,50,"﴿حَسَنَةࣱ﴾: نصرٌ وغنيمةٌ.﴿مُصِيبَةࣱ﴾: مَكْرُوهٌ من هزيمةٍ أو شدَّةٍ.﴿قَدۡ أَخَذۡنَآ أَمۡرَنَا مِن قَبۡلُ﴾: قد احْتَطْنا لأنفسِنا حين تَخَلَّفْنا عن الجهادِ قبلَ هذه المصيبةِ.﴿وَيَتَوَلَّواْ﴾: وينصَرِفُوا."
  9,51,"﴿مَا كَتَبَ ٱللَّهُ لَنَا﴾: ما قَدَّرَه علينا.﴿هُوَ مَوۡلَىٰنَا﴾: ناصِرُنا ومُتَوَلِّي أمورِنا.﴿وَعَلَى ٱللَّهِ فَلۡيَتَوَكَّلِ﴾: فلْيَعْتَمِدْ ولْيُفَوِّضْ أمرَه إليه."
  9,52,"﴿هَلۡ تَرَبَّصُونَ﴾: ما تنتظرون أن يَقَعَ.﴿إِحۡدَى ٱلۡحُسۡنَيَيۡنِ﴾: إحدى العاقبتَين: النصرَ، أوالشهادةَ في سبيلِ اللهِ."
  9,53,"﴿طَوۡعًا﴾: طائعِين.﴿كَرۡهࣰا﴾: كارهِين.﴿فَـٰسِقِينَ﴾: خارجِين عن دينِ اللهِ."
  9,54,"﴿كُسَالَىٰ﴾: متثاقلون عن الصَّلاةِ."
  9,55,"﴿لِيُعَذِّبَهُم بِهَا﴾: بما يَلْقَون من التعبِ في جَمْعِها، وبالمصائبِ التي تقعُ فيها.﴿وَتَزۡهَقَ﴾: تَخْرُجَ."
  9,56,"﴿يَفۡرَقُونَ﴾: يَخافُون."
  9,57,"﴿مَلۡجَـًٔا﴾: حِصْنًا ومأمَنًا يلجَؤُون إليه.﴿مَغَـٰرَ ٰ⁠تٍ﴾: جَمْعُ مَغارةٍ، وهي الكَهْفُ، أو الغارُ في الجبلِ يُؤْويهم.﴿مُدَّخَلࣰا﴾: مكانًا يَدْخلونه كالنَّفَقِ في الأرضِ.﴿لَّوَلَّوۡاْ﴾: لَأَقْبَلُوا.﴿يَجۡمَحُونَ﴾: يُسْرِعون في دخولِه لا يَمْنَعُهم شيءٌ."
  9,58,"﴿يَلۡمِزُكَ﴾: يَعِيبُك.﴿ٱلصَّدَقَـٰتِ﴾: في قِسْمةِ أموالِ الصَّدقاتِ."
  9,59,"﴿حَسۡبُنَا ٱللَّهُ﴾: كافِينا.﴿إِلَى ٱللَّهِ رَ ٰ⁠غِبُونَ﴾: مُحِبُّون أن يُغْنيَنا من فضلِه."
  9,60,"﴿ٱلصَّدَقَـٰتُ﴾: الزَّكَواتُ المفروضةُ.﴿لِلۡفُقَرَآءِ﴾: للمحتاجِين الذين لا يَمْلِكُون شيئًا.﴿وَٱلۡمَسَـٰكِينِ﴾: الذين لا يَمْلِكُون ما يَكْفيهم ويَسُدُّ حاجتَهم.﴿وَٱلۡعَـٰمِلِينَ عَلَيۡهَا﴾: السُّعاةُ الذين يَجْمعون الزكاةَ من أصحابِها.﴿وَٱلۡمُؤَلَّفَةِ قُلُوبُهُمۡ﴾: المستمالةِ قلوبُهم إلى الإسلام كمن يُرْجى إسلامُه أو قوَّةُ إيمانِه.﴿وَفِي ٱلرِّقَابِ﴾: وتُعطى الزكاةُ في عِتْقِ رقابِ العبيدِ والمكاتَبين.﴿وَٱلۡغَـٰرِمِينَ﴾: الذين استدانُوا لأنفسهم، ولا قُدَرةَ لهم على الوفاءِ، أو استدانُوا لإصلاحِ ذاتِ البَيْنِ.﴿وَفِي سَبِيلِ ٱللَّهِ﴾: وللغُزاةِ وللمرابطين في سبيل الله.﴿وَٱبۡنِ ٱلسَّبِيلِ﴾: المسافرِ المنقطعِ عن مالِه في سفرِه، وإن كان غنيًا في بلدِه.﴿فَرِيضَةࣰ مِّنَ ٱللَّهِ﴾: هذه القِسْمةُ فَرَضَها اللهُ فريضةً وقَدَّرها."
  9,61,"﴿أُذُنࣱ﴾: يستمعُ لكلِّ ما يُقالُ له ويُصَدِّقُه.﴿قُلۡ أُذُنُ خَيۡرࣲ لَّكُمۡ﴾: أي: أُذُنٌ في الخيرِ والحقِّ، وفيما يجبُ سَماعُه وقَبولُه.﴿وَيُؤۡمِنُ لِلۡمُؤۡمِنِينَ﴾: ويُصَدِّقُ المؤمنين فيما يُخبرونه."
  9,63,"﴿يُحَادِدِ﴾: يخالِفْ."
  9,64,"﴿تُنَبِّئُهُم﴾: تُخَبِّرُهم.﴿بِمَا فِي قُلُوبِهِمۡ﴾: بما يُضْمِرُونَه في قلوبِهم من الكفرِ.﴿مُخۡرِجࣱ مَّا تَحۡذَرُونَ﴾: مُظْهِرٌ ما تَخافُونه من الفضيحةِ."
  9,65,"﴿وَلَئِن سَأَلۡتَهُمۡ﴾: عَمّا قالوا من الطَّعْنِ في حَقِّك وحَقِّ أصحابِك.﴿نَخُوضُ وَنَلۡعَبُ﴾: نتحَدَّثُ بكلامٍ لم نَقْصِدْ به الإساءةَ."
  9,66,"﴿إِن نَّعۡفُ عَن طَآئِفَةࣲ مِّنكُمۡ﴾: بالتوفيق للتوبةِ والإخلاصِ فيها.﴿نُعَذِّبۡ طَآئِفَةَۢ﴾: بسبب تَرْكِ التوبةِ والإصرارِ على النِّفاقِ."
  9,67,"﴿بَعۡضُهُم مِّنۢ بَعۡضࣲ﴾: أي: مُتَشابهون في صفةِ النِّفاقِ والبُعْدِ عن الإيمانِ.﴿بِٱلۡمُنكَرِ﴾: بالكفرِ والمعاصي.﴿ٱلۡمَعۡرُوفِ﴾: هو كلُّ ما عُرِفَ حُسْنُه في الشَّرعِ والعَقْلِ.﴿وَيَقۡبِضُونَ أَيۡدِيَهُمۡ﴾: ويُمْسِكُون عن الإنفاقِ في طاعةِ اللهِ ومَرْضاتِه.﴿نَسُواْ ٱللَّهَ﴾: تَرَكُوا طاعتَه وأوامرَه.﴿فَنَسِيَهُمۡ﴾: فتركَهم من رحمتِه وثوابِه.﴿ٱلۡفَـٰسِقُونَ﴾: الخارجُون عن الإيمانِ والطاعة."
  9,68,"﴿حَسۡبُهُمۡ﴾: كافِيهم؛ عقابًا على كفرِهم.﴿وَلَعَنَهُمُ ٱللَّهُ﴾: طَرَدَهم مِن رحمتِه.﴿مُّقِيمࣱ﴾: دائمٌ لا ينقطعُ."
  9,69,"﴿بِخَلَـٰقِهِمۡ﴾: بنصيبِهم الذي قُدِّرَ لهم من مَلاذِّ الدنيا.﴿وَخُضۡتُمۡ﴾: ودَخَلْتُم في الباطلِ والطَّعْنِ في الدِّينِ.﴿حَبِطَتۡ﴾: بَطَلَتْ."
  9,70,"﴿نَبَأُ﴾: خبرُ.﴿وَأَصۡحَـٰبِ مَدۡيَنَ﴾: هم قومُ شعيبٍ عليه السلام.﴿وَٱلۡمُؤۡتَفِكَـٰتِ﴾: قُرى قومِ لوطٍ عليه السلام، التي انقلبَتْ بهم، فصار عالِيها سافلَها.﴿بِٱلۡبَيِّنَـٰتِ﴾: بالوَحْيِ والمعجزاتِ.﴿كَانُوٓاْ أَنفُسَهُمۡ يَظۡلِمُونَ﴾: بتعريضِها للعقابِ؛ بسببِ كُفْرِهم."
  9,71,"﴿أَوۡلِيَآءُ بَعۡضࣲ﴾: أنصارُ بعضٍ.﴿عَزِيزٌ﴾: لا يُعْجِزُه شيء عن إنجازِ وعْدِه بالمؤمنين، ووعيدِه بمَن عَصاه وكَفَرَ به.﴿حَكِيمࣱ﴾: يَضَعُ الأمورَ في محالِّها."
  9,72,"﴿مِن تَحۡتِهَا﴾: من تحتِ قصورِها وأشجارِها.﴿طَيِّبَةࣰ﴾: حسنةَ البناءِ، طَيِّبةَ القَرارِ.﴿جَنَّـٰتِ عَدۡنࣲ﴾: أي: إقامةٍ وخُلودٍ.﴿أَكۡبَرُ﴾: ممّا هم فيه من أنواعِ النعيمِ."
  9,73,"﴿وَٱغۡلُظۡ﴾: واشدُدْ في جهادِك.﴿وَمَأۡوَىٰهُمۡ﴾: مصيرُهم."
  9,74,"﴿كَلِمَةَ ٱلۡكُفۡرِ﴾: هي استهزاؤهُم بالرسولِ عليه الصلاةُ والسلام، وبالدِّينِ.﴿وَهَمُّواْ﴾: وصَمَّمَ المنافقون على قَتْلِ الرسولِ ﷺ.﴿بِمَا لَمۡ يَنَالُواْ﴾: بما لم يُمَكِّنْهم اللهُ منه.﴿وَمَا نَقَمُوٓاْ﴾: وما وجَدَ المنافقون شيئًا يَكْرَهُونه ويَعِيبونَه.﴿وَإِن يَتَوَلَّوۡاْ﴾: يُعْرِضُوا، أو يَسْتمِرُّوا على حالِهم.﴿وَلِيࣲّ﴾: يَلي أمورَهم وينفَعُهم.﴿وَلَا نَصِيرࣲ﴾: ولا ناصرٍ يَدْفَعُ عنهم ما هم فيه."
  9,75,"﴿عَـٰهَدَ ٱللَّهَ﴾: قَطَعَ على نفسِه العهدَ مع اللهِ."
  9,77,"﴿فَأَعۡقَبَهُمۡ نِفَاقࣰا﴾: فأَوْرَثَهم اللهُ جزاءَ صنيعِهم زيادةً في نفاقِهم."
  9,78,"﴿سِرَّهُمۡ﴾: ما انطَوتْ عليه نفوسُهم من النِّفاق.﴿وَنَجۡوَىٰهُمۡ﴾: ما يتحَدَّثون به بينهَم من الكَيْدِ والمَكْر."
  9,79,"﴿يَلۡمِزُونَ ٱلۡمُطَّوِّعِينَ﴾: يَعِيبُون المتصدِّقين ويَطْعَنُون في إخلاصِهم.﴿جُهۡدَهُمۡ﴾: طاقَتَهم وما تَبْلُغُه قُوَّتُهم."
  9,80,"﴿سَبۡعِينَ مَرَّةࣰ﴾: أي: مهما كَثُرَ استغفارُك لهم وتكرَّر.﴿لَا يَهۡدِي﴾: لا يُوَفِّقُ.﴿ٱلۡفَـٰسِقِينَ﴾: الخارجين عن دينِ الله."
  9,81,"﴿ٱلۡمُخَلَّفُونَ﴾: الذين تخلَّفُوا عن الجهادِ في غزوةِ «تبوكَ».﴿بِمَقۡعَدِهِمۡ﴾: أي: بقُعودِهم.﴿خِلَـٰفَ رَسُولِ ٱللَّهِ﴾: مخالِفِين رسولَ الله ﷺ.﴿لَا تَنفِرُواْ﴾: لا تَخْرُجُوا إلى الجهادِ."
  9,82,"﴿قَلِيلࣰا﴾: في الدنيا.﴿كَثِيرࣰا﴾: في الآخرةِ."
  9,83,"﴿أَوَّلَ مَرَّةࣲ﴾: هي غزوةُ «تبوكَ».﴿ٱلۡخَـٰلِفِينَ﴾: المتخلِّفين عن الجهادِ كالنِّساءِ والصِّبيانِ."
  9,84,"﴿وَلَا تَقُمۡ عَلَىٰ قَبۡرِهِۦٓ﴾: لأجلِ الدَّفْنِ، أو الزيارةِ، أو الدعاءِ له."
  9,85,"﴿أَن يُعَذِّبَهُم بِهَا﴾: بما يَلْقَون من التعب في جَمْعِها، وبالمصائبِ التي تقعُ فيها.﴿وَتَزۡهَقَ﴾: تَخْرُجَ."
  9,86,"﴿أُوْلُواْ ٱلطَّوۡلِ﴾: أصحابُ الغِنى والمقدرةِ على الجهادِ.﴿ذَرۡنَا﴾: اتْرُكْنا."
  9,87,"﴿ٱلۡخَوَالِفِ﴾: جَمعُ خالِفة، ويقال للمرأةِ والرجل، والمرادُ: النِّساءُ اللاتي تخلَّفْنَ في البيوتِ، أو الرجالُ العاجزون عن القتال.﴿وَطُبِعَ﴾: ختمَ اللهُ."
  9,88,"﴿ٱلۡخَيۡرَ ٰ⁠تُ﴾: في الدنيا والآخرةِ."
  9,90,"﴿ٱلۡمُعَذِّرُونَ﴾: المعتذرون بأعذارٍ كاذبةٍ عن عدمِ الخروجِ للغَزْوِ.﴿ٱلۡأَعۡرَابِ﴾: سُكّانِ الباديةِ.﴿وَقَعَدَ﴾: عن الغزوِ لغيرِ عُذْرٍ."
  9,91,"﴿حَرَجٌ﴾: إثمٌ.﴿نَصَحُواْ﴾: أخلَصُوا.﴿مِن سَبِيلࣲ﴾: من طريقٍ للمؤاخذةِ."
  9,92,"﴿لِتَحۡمِلَهُمۡ﴾: على ما يَرْكَبون عليه في الغَزْو.﴿تَوَلَّواْ﴾: انْصَرَفُوا مِن عندِك.﴿حَزَنًا﴾: أسَفًا على ما فاتَهم من شَرَفِ الجهادِ وثوابِه."
  9,93,"﴿ٱلسَّبِيلُ﴾: طريقُ العقوبةِ والمؤاخَذَةِ."
  9,94,"﴿إِذَا رَجَعۡتُمۡ إِلَيۡهِمۡ﴾: من الغَزْوِ.﴿لَن نُّؤۡمِنَ لَكُمۡ﴾: لن نُصَدِّقَكم."
  9,95,"﴿إِذَا ٱنقَلَبۡتُمۡ إِلَيۡهِمۡ﴾: رَجَعْتُم إليهم من الغَزْو.﴿لِتُعۡرِضُواْ عَنۡهُمۡ﴾: لتَتْرُكُوهم وتَصْفَحُوا عنهم.﴿رِجۡسࣱ﴾: خبثاءُ في بَواطِنِهم واعتقاداتِهم.﴿وَمَأۡوَىٰهُمۡ﴾: مصيرُهم."
  9,96,"﴿ٱلۡفَـٰسِقِينَ﴾: الخارجين عن دينِ اللهِ."
  9,97,"﴿ٱلۡأَعۡرَابُ﴾: سُكّانُ الباديةِ.﴿وَأَجۡدَرُ﴾: وأحَقُّ."
  9,98,"﴿مَغۡرَمࣰا﴾: غَرامةً وخَسارةً.﴿وَيَتَرَبَّصُ﴾: ينتظرُ.﴿ٱلدَّوَآئِرَ﴾: جَمْعُ دائرةٍ، وهي: تَقَلُّباتُ الدَّهْرِ ومصائبُه.﴿ٱلسَّوۡءِ﴾: كلُّ ما يسوءُ ويَضُرُّ."
  9,99,"﴿وَيَتَّخِذُ مَا يُنفِقُ﴾: ويحتسِبُ ما ينفقُه في سبيلِ اللهِ.﴿قُرُبَـٰتٍ عِندَ ٱللَّهِ﴾: جَمْعُ قُرْبَةٍ، وهي: ما يُتَقَرَّبُ به إلى اللهِ تعالى.﴿وَصَلَوَ ٰ⁠تِ ٱلرَّسُولِ﴾: جَمْعُ صلاةٍ، وهي هنا: الدعاُء، أي: ويَجْعَلُ إنفاقَه في سبيلِ اللهِ وسيلةً إلى دعاءِ الرسولِ ﷺ له."
  9,100,"﴿ٱلۡمُهَـٰجِرِينَ﴾: الذين هَجَرُوا قومَهم، وانتقلُوا من بلدِ الفتنةِ إلى دارِ الإسلامِ.﴿وَٱلۡأَنصَارِ﴾: الذين نصرُوا النبي ﷺ، وآوَوا المهاجرين.﴿بِإِحۡسَـٰنࣲ﴾: في الاعتقادِ والأقوالِ والأعمالِ.﴿تَحۡتَهَا﴾: تحتَ قصورِها وأشجارِها."
  9,101,"﴿مَرَدُواْ عَلَى ٱلنِّفَاقِ﴾: مَهَرُوا فيه واستمَرُّوا عليه.﴿سَنُعَذِّبُهُم مَّرَّتَيۡنِ﴾: الأولى: في الدنيا بفضيحتِهم، أو بأنواعِ المكارِهِ التي تنالُهم، والثانية: بعذابِ القبرِ.﴿عَذَابٍ عَظِيمࣲ﴾: نارِ جهنمَ."
  9,102,"﴿عَمَلࣰا صَـٰلِحࣰا﴾: ما سَبَقَ لهم من الجهادِ مع توبتِهم.﴿وَءَاخَرَ سَيِّئًا﴾: تَخَلُّفَهم عن غزوةِ «تبوكَ»."
  9,103,"﴿تُطَهِّرُهُمۡ﴾: تُزيلُ بها أثَرَ ذنوبِهم.﴿وَتُزَكِّيهِم بِهَا﴾: تُنَمِّي بها حَسَناتِهم وترفَعُهم إلى منازلِ المُخْلَصِين.﴿وَصَلِّ عَلَيۡهِمۡ﴾: ادْعُ لهم واستغفِرْ.﴿سَكَنࣱ لَّهُمۡ﴾: سكينةٌ لنفوسِهم وطُمَأنينةٌ لقلوبِهم."
  9,104,"﴿وَيَأۡخُذُ ٱلصَّدَقَـٰتِ﴾: يَقْبَلُها ويُثيبُ عليها."
  9,105,"﴿وَسَتُرَدُّونَ﴾: ستُرْجَعُون يومَ القيامةِ."
  9,106,"﴿مُرۡجَوۡنَ لِأَمۡرِ ٱللَّهِ﴾: مُؤَخَّرون لحُكمِ اللهِ فيهم."
  9,107,"﴿ضِرَارࣰا﴾: لأجل الضَّرَر بِالمؤمنين.﴿وَإِرۡصَادࣰا﴾: انتظارًا وإعدادًا.﴿لِّمَنۡ حَارَبَ ٱللَّهَ وَرَسُولَهُۥ﴾: هو أبو عامرٍ الفاسقُ.﴿مِن قَبۡلُ﴾: أي: من قَبْلِ بناءِ مسجدِ الضِّرارِ.﴿ٱلۡحُسۡنَىٰ﴾: الخيرَ والإحسانَ إلى المسلمين."
  9,108,"﴿لَا تَقُمۡ فِيهِ﴾: أي للصَّلاةِ في مَسْجدِ الضِّرارِ.﴿لَّمَسۡجِدٌ أُسِّسَ عَلَى ٱلتَّقۡوَىٰ﴾: هو مَسْجدُ قُباءٍ.﴿يُحِبُّونَ أَن يَتَطَهَّرُواْ﴾: طهارةً حسِّيةً من النجاساتِ، ومعنويةً من الذُّنوبِ والمعاصي."
  9,109,"﴿وَرِضۡوَ ٰ⁠نٍ﴾: ورجاءِ مَرْضاةِ اللهِ.﴿عَلَىٰ شَفَا جُرُفٍ﴾: على طَرَفِ حُفْرَةٍ، أو مكانٍ يَجْرُفُه الماءُ.﴿هَارࣲ﴾: مُشْرِفٍ على السُّقوط.﴿فَٱنۡهَارَ بِهِۦ﴾: فسَقَطَ المكانُ بالبُنيانِ مع بانيه.﴿لَا يَهۡدِي﴾: لا يُوَفِّقُ."
  9,110,"﴿بُنۡيَـٰنُهُمُ﴾: مسجدُ الضِّرارِ.﴿رِيبَةࣰ فِي قُلُوبِهِمۡ﴾: شَكًّا ونفاقًا راسخًا في قلوبِهم.﴿تَقَطَّعَ قُلُوبُهُمۡ﴾: تتقَطَّعَ قلوبُهم بَمْوتِهم، فالنِّفاقُ ملازمٌ لهم ماداموا أحياءً."
  9,111,"﴿فَٱسۡتَبۡشِرُواْ﴾: أظْهِرُوا السُّرورَ."
  9,112,"﴿ٱلسَّـٰٓئِحُونَ﴾: الصّائمون."
  9,114,"﴿مَّوۡعِدَةࣲ وَعَدَهَآ إِيَّاهُ﴾: وهي الاستغفارُ له.﴿لَأَوَّ ٰ⁠هٌ﴾: كثيرُ التضرُّعِ إلى اللهِ.﴿حَلِيمࣱ﴾: صَبُورٌ على الأذى، كثيرُ الصَّفْحِ عَمَّن نالَه بمَكْروه."
  9,115,"﴿مَّا يَتَّقُونَ﴾: ما يَجِبُ عليهم اتقاؤُه من المُحَرَّماتِ."
  9,116,"﴿وَلِيࣲّ﴾: يَتَوَلّى أمورَكم وينفَعُكم.﴿وَلَا نَصِيرࣲ﴾: يَنْصُرُكم ويَدْفَعُ عنكم ما أنتم فيه."
  9,117,"﴿سَاعَةِ ٱلۡعُسۡرَةِ﴾: وقتِ الشِّدةِ، وهي غزوةُ «تبوكَ».﴿يَزِيغُ قُلُوبُ﴾: تميلُ إلى التخَلُّفِ عن الجهادِ.﴿بِهِمۡ رَءُوفࣱ﴾: كثيرُ الرأفةِ والرحمةِ بهم في عاجِلِهم وآجِلِهم."
  9,118,"﴿وَعَلَى ٱلثَّلَـٰثَةِ﴾: أي: وتابَ على الثلاثةِ، وهم: كَعْبُ بنُ مالك، وهِلالُ ابنُ أميةَ، ومُرارةُ بنُ الرَّبِيعِ.﴿خُلِّفُواْ﴾: تَخَلَّفوا عن الجهادِ في غزوةِ «تبوكَ».﴿بِمَا رَحُبَتۡ﴾: أي: مع سَعَتِها؛ ندمًا بسبب تَخَلُّفِهم عن الغزوِ.﴿وَظَنُّوٓاْ﴾: أيقنوا.﴿ثُمَّ تَابَ عَلَيۡهِمۡ﴾: وفَّقهم اللهُ للتوبةِ.﴿لِيَتُوبُوٓاْ﴾: ليستمِرُّوا على التوبةِ ويثبتُوا عليها."
  9,120,"﴿مَا كَانَ لِأَهۡلِ ٱلۡمَدِينَةِ﴾: أي: ليس لهم.﴿وَلَا يَرۡغَبُواْ بِأَنفُسِهِمۡ عَن نَّفۡسِهِۦ﴾: لا يَرْضَوْا لها بالراحة، ورسولُ الله ﷺ في تعبٍ ومشقةٍ.﴿ظَمَأࣱ﴾: عَطَشٌ.﴿وَلَا نَصَبࣱ﴾: تَعَبٌ.﴿وَلَا مَخۡمَصَةࣱ﴾: جُوعٌ شديدٌ.﴿مَوۡطِئࣰا﴾: مكانًا.﴿يَغِيظُ﴾: يُغْضِبُ.﴿نَّيۡلًا﴾: بقَتْلٍ، أو أسْرٍ، أو جِراحَةٍ، أو غنيمةٍ ونحوِها."
  9,122,"﴿فَلَوۡلَا﴾: فهَلّا.﴿نَفَرَ﴾: خَرَج للغزوِ والجهادِ."
  9,123,"﴿يَلُونَكُم﴾: يجاوِرُونكم.﴿غِلۡظَةࣰ﴾: شدَّةً."
  9,124,"﴿فَمِنۡهُم﴾: فمِنَ المنافقين.﴿يَسۡتَبۡشِرُونَ﴾: يَفْرحُون بفضلِ اللهِ عليهم."
  9,125,"﴿مَّرَضࣱ﴾: شكٌّ ونِفاقٌ.﴿رِجۡسًا إِلَىٰ رِجۡسِهِمۡ﴾: نِفاقًا وكُفْرًا إلى كُفْرِهم."
  9,126,"﴿يُفۡتَنُونَ﴾: يُبْتلَوْن بأنواعِ البَلاءِ.﴿وَلَا هُمۡ يَذَّكَّرُونَ﴾: لا يَتَّعِظُون بما نَزَلَ بهم."
  9,127,"﴿نَّظَرَ بَعۡضُهُمۡ إِلَىٰ بَعۡضٍ﴾: تغامَزَ المنافقون بالعيونِ؛ إنكارًا لنزولِ السورةِ، وغيظًا لما فيها من بيانِ عيوبِهم.﴿هَلۡ يَرَىٰكُم مِّنۡ أَحَدࣲ﴾: يُريدون الهروبَ من مجلسِ النبيِّ ﷺ.﴿صَرَفَ ٱللَّهُ قُلُوبَهُم﴾: عن الإيمانِ.﴿لَّا يَفۡقَهُونَ﴾: لا يَفْهَمونَ لعَدَمِ تَدَبُّرِهم وإنصافِهم."
  9,128,"﴿مِّنۡ أَنفُسِكُمۡ﴾: من قومِكم.﴿عَزِيزٌ عَلَيۡهِ﴾: ما تَلْقَوْن من المكروهِ والمشقَّةِ.﴿رَءُوفࣱ﴾: عظيمُ الرحمةِ شفيقٌ."
  9,129,"﴿تَوَلَّوۡاْ﴾: أعْرَضُوا.﴿حَسۡبِيَ ٱللَّهُ﴾: يكفيني اللهُ.﴿عَلَيۡهِ تَوَكَّلۡتُ﴾: اعتمَدْتُ عليه وفوَّضْتُ جميعَ أموري إليه.﴿ٱلۡعَرۡشِ﴾: سريرِ المُلك الذي استوى عليه الرحمنُ، وتحمِلُه الملائكةُ، وهو أعظمُ المخلوقاتِ، وهو سَقْفُ الجنةِ."
