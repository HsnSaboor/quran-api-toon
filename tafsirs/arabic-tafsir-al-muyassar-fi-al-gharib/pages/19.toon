tafsir[89]{c,v,t}:
  19,2,"19:1"
  19,3,"﴿خَفِيࣰّا﴾: سِرًّا."
  19,4,"﴿وَهَنَ﴾: ضَعُفَ.﴿وَٱشۡتَعَلَ ٱلرَّأۡسُ شَيۡبࣰا﴾: انْتَشَرَ الشَّيبُ في رَأسِي.﴿شَقِيࣰّا﴾: مَحْرُومًا مِن إجابَةِ الدُّعاءِ."
  19,5,"﴿ٱلۡمَوَ ٰ⁠لِيَ﴾: العَصَبَةَ وأقْرَبَ القَرابَةِ.﴿عَاقِرࣰا﴾: التي لا تَلِدُ.﴿وَلِيࣰّا﴾: ولَدًا وارِثًا ومُعِينًا."
  19,6,"﴿يَرِثُنِي﴾: يَرِثُ نُبُوَّتي.﴿رَضِيࣰّا﴾: مَرْضِيًّا مِنكَ ومِن عِبادِكَ."
  19,7,"﴿سَمِيࣰّا﴾: مُسَمّىً باسْمِه."
  19,8,"﴿أَنَّىٰ﴾: كيفَ؟﴿عِتِيࣰّا﴾: النِّهايةَ في كِبَر السِّنِّ."
  19,9,"﴿هَيِّنࣱ﴾: سَهْلٌ.﴿وَلَمۡ تَكُ شَيۡـࣰٔا﴾: ولم تَكُ شيئًا مَذْكُورًا ولا مَوْجُودًا."
  19,10,"﴿ءَايَةࣰ﴾: علامةً.﴿سَوِيࣰّا﴾: صَحِيحًا مُعافىً."
  19,11,"﴿ٱلۡمِحۡرَابِ﴾: المُصَلّى.﴿بُكۡرَةࣰ وَعَشِيࣰّا﴾: صَباحًا ومَساءً."
  19,12,"﴿ٱلۡكِتَـٰبَ﴾: أي: التَّوْراةَ.﴿بِقُوَّةࣲ﴾: بجِدٍّ واجْتِهادٍ.﴿ٱلۡحُكۡمَ﴾: الحِكْمَةَ وحُسنَ الفَهْمِ.﴿صَبِيࣰّا﴾: صغيَر السِّنِّ."
  19,13,"﴿حَنَانࣰا﴾: رَحْمَةً ومحبةً.﴿وَزَكَوٰةࣰ﴾: طَهارةً مِنَ الذُّنُوبِ.﴿تَقِيࣰّا﴾: خائفًا مِنَ اللهِ، ومُطِيعًا لَه."
  19,14,"﴿بَرَّۢا﴾: بارًّا ومطيعًا.﴿جَبَّارًا﴾: مُتَكَبِّرًا عَنْ طاعِةِ ربِّه، وطاعةِ والدَيْه.﴿عَصِيࣰّا﴾: عاصِيًا لِرَبِّه ولِوالِدَيْه."
  19,16,"﴿فِي ٱلۡكِتَـٰبِ﴾: في هَذا القُرْآنِ.﴿ٱنتَبَذَتۡ﴾: تباعَدَتْ واعْتَزَلَتْ.﴿شَرۡقِيࣰّا﴾: مَكانًا مِمّا يلِي الشَّرقَ عَنْ أهْلِها."
  19,17,"﴿رُوحَنَا﴾: أي: جِبْرِيلَ عليهِ السَّلامُ.﴿فَتَمَثَّلَ لَهَا بَشَرࣰا﴾: تصَوَّرَ لَها في صُورَةِ إنْسانٍ.﴿سَوِيࣰّا﴾: تامَّ الخَلْقِ."
  19,18,"﴿أَعُوذُ بِٱلرَّحۡمَـٰنِ﴾: ألْتَجِئُ وأَسْتَجِيرُ بالرَّحمنِ."
  19,19,"﴿زَكِيࣰّا﴾: طاهِرًا مِنَ الذُّنوبِ."
  19,20,"﴿أَنَّىٰ﴾: كيفَ؟﴿لَمۡ يَمۡسَسۡنِي بَشَرࣱ﴾: لم يَمَسَّني بَشَرٌ بِنِكاحٍ حَلالٍ.﴿بَغِيࣰّا﴾: زانيةً."
  19,21,"﴿ءَايَةࣰ﴾: علامةً تَدُلُّ على قُدْرَةِ اللهِ.﴿رَحۡمَةࣰ مِّنَّا﴾: جَعَلَه اللهُ رحمةً لأمِّه ولِمَن آمَنَ به.﴿مَّقۡضِيࣰّا﴾: قَضاءً سابِقًا مُقَدَّرًا."
  19,22,"﴿فَٱنتَبَذَتۡ﴾: فتباعَدَتْ."
  19,23,"﴿نَسۡيࣰا مَّنسِيࣰّا﴾: شَيْئًا لا يُعْرَفُ ولا يُذكَرُ."
  19,24,"﴿فَنَادَىٰهَا﴾: أي: جبريلُ أو عِيسى.﴿سَرِيࣰّا﴾: جَدْوَلَ ماءٍ."
  19,25,"﴿هُزِّيٓ﴾: حَرِّكِي."
  19,26,"﴿وَقَرِّي عَيۡنࣰا﴾: وطِيبِي نَفْسًا بِمَولُودِكِ.﴿نَذَرۡتُ﴾: أوْجَبْتُ على نَفْسِي.﴿صَوۡمࣰا﴾: سُكُوتًا.﴿إِنسِيࣰّا﴾: أحَدًا مِنَ النّاسِ."
  19,27,"﴿شَيۡـࣰٔا فَرِيࣰّا﴾: أمْرًا عَظِيمًا مُفْتَرىً."
  19,28,"﴿يَـٰٓأُخۡتَ هَـٰرُونَ﴾: يا أُخْتَ الرَّجلِ الصّالحِ هارُونَ.﴿ٱمۡرَأَ سَوۡءࣲ﴾: رَجُلَ سَوْءٍ يأتي الفَواحِشَ.﴿بَغِيࣰّا﴾: زانيةً."
  19,29,"﴿ٱلۡمَهۡدِ﴾: ما يُهَيَّأ للرَّضِيعِ مِن فِراشٍ ونَحْوِه.﴿صَبِيࣰّا﴾: طِفْلًا رَضِيعًا."
  19,30,"﴿ٱلۡكِتَـٰبَ﴾: الإنْجِيلَ."
  19,31,"﴿مُبَارَكًا﴾: عَظِيمَ الخيرِ والنَّفْعِ﴿مَا دُمۡتُ حَيࣰّا﴾: ما بَقِيِتُ حَيًّا."
  19,32,"﴿بَرَّۢا﴾: بارًّا ومُطِيعًا.﴿جَبَّارࣰا﴾: مُتَكَبِّرًا.﴿شَقِيࣰّا﴾: عاصِيًا لِربِّي."
  19,33,"﴿وَيَوۡمَ أُبۡعَثُ حَيࣰّا﴾: أي: يَوْمَ القِيامةِ."
  19,34,"﴿فِيهِ يَمۡتَرُونَ﴾: يَشُكُّ فيه اليهودُ والنَّصارى ويُجادِلُونَ."
  19,35,"﴿مَا كَانَ﴾: ما يَنْبَغِي ولا يَلِيقُ.﴿سُبۡحَـٰنَهُۥٓ﴾: تَقَدَّسَ وتَنَزَّهَ عَن ذَلِكَ.﴿قَضَىٰٓ﴾: أرادَ.﴿فَيَكُونُ﴾: أي: كَما أرادَه."
  19,36,"﴿هَـٰذَا صِرَ ٰ⁠طࣱ مُّسۡتَقِيمࣱ﴾: هَذا طريقٌ لا اعْوِجاجَ فِيه."
  19,37,"﴿ٱلۡأَحۡزَابُ﴾: الفِرَقُ مِن أهْلِ الكِتابِ.﴿فَوَيۡلࣱ﴾: فهَلاكٌ.﴿مَّشۡهَدِ﴾: شُهُودِ.﴿يَوۡمٍ عَظِيمٍ﴾: يومِ القِيامَةِ."
  19,38,"﴿أَسۡمِعۡ بِهِمۡ وَأَبۡصِرۡ﴾: ما أقدَرَهم على السَّمعِ والبَصَرِ يوم القيامةِ!﴿فِي ضَلَـٰلࣲ مُّبِينࣲ﴾: في انْحِرافٍ واضحٍ عَن سَبَيلِ الحقِّ."
  19,39,"﴿يَوۡمَ ٱلۡحَسۡرَةِ﴾: يومَ النَّدامةِ على ما فرَّطُوا في جَنْبِ اللهِ."
  19,41,"﴿صِدِّيقࣰا﴾: عَظِيمَ الصِّدقِ."
  19,42,"﴿وَلَا يُغۡنِي﴾: ولا يَدْفَعُ."
  19,43,"﴿أَهۡدِكَ﴾: أُرْشِدْكَ.﴿صِرَ ٰ⁠طࣰا سَوِيࣰّا﴾: طريقًا مُسْتَويًا لا اعْوِجاجَ فيه."
  19,44,"﴿لَا تَعۡبُدِ ٱلشَّيۡطَـٰنَ﴾: لا تُطِعِ الشَّيطانَ في عِبادةِ الأصْنام.﴿عَصِيࣰّا﴾: مُخالِفًا مُسْتكْبِرًا عَن طاعَةِ اللهِ."
  19,45,"﴿لِلشَّيۡطَـٰنِ وَلِيࣰّا﴾: قَرِينًا لَه في اللَّعنةِ، وقريبًا منه في النّار."
  19,46,"﴿أَرَاغِبٌ أَنتَ عَنۡ ءَالِهَتِي﴾: أمُعْرِضٌ أنت عَن عِبادَةِ آلَهتِي.﴿لَأَرۡجُمَنَّكَ﴾: لَأَقْتُلَنَّك رَمْيًا بِالحِجارَةِ.﴿مَلِيࣰّا﴾: زَمانًا طَوِيلًا مِنَ الدَّهْرِ."
  19,47,"﴿سَلَـٰمٌ عَلَيۡكَ﴾: تحيةُ تَودِيعٍ ومُتارَكَةٍ، أي: تَسْلَمُ ممّا تَكْرَهُه مِنِّي.﴿بِي حَفِيࣰّا﴾: كَثيرَ الِبرِّ واللُّطْفِ."
  19,48,"﴿وَأَعۡتَزِلُكُمۡ﴾: وأُفارِقُكُم.﴿شَقِيࣰّا﴾: مَحْرُومًا مِن إجابَةِ الدُّعاءِ."
  19,50,"﴿لِسَانَ صِدۡقٍ﴾: ثَناءً حَسَنًا.﴿عَلِيࣰّا﴾: رفيعَ القَدْرِ باقيًا في النّاسِ."
  19,51,"﴿مُخۡلَصࣰا﴾: مُخْتارًا لِرِسالتِه."
  19,52,"﴿ٱلطُّورِ﴾: جَبَلِ طُورِ سَيناءَ.﴿وَقَرَّبۡنَـٰهُ نَجِيࣰّا﴾: فشَرَّفْناه بِمُناجاتِنا وتَكْلِيمِنا إيّاه سرًّا."
  19,54,"19:53"
  19,55,"19:53"
  19,56,"﴿صِدِّيقࣰا﴾: عظيمَ الصِّدقِ في قولِه وعَمَلِه."
  19,57,"﴿وَرَفَعۡنَـٰهُ﴾: أي: ذِكْرَه ومَنزِلَتَه، قيل: إنّه رُفِعَ إلى السَّماءِ الرابعةِ.﴿عَلِيًّا﴾: رفيعَ القَدْرِ، أو ذا مَكانٍ عالٍ في السَّماءِ."
  19,58,"﴿وَٱجۡتَبَيۡنَآ﴾: واصْطَفَينا للرِّسالةِ والنُّبوَّةِ.﴿خَرُّواْ﴾: وقَعُوا.﴿وَبُكِيࣰّا﴾: وباكِينَ مِن خَشْيَتِه سُبْحانَه وتَعالىَ."
  19,59,"﴿خَلَفَ مِنۢ بَعۡدِهِمۡ﴾: فجاءَ بَعْدَهُم.﴿خَلۡفٌ﴾: أتْباعُ سُوءٍ.﴿غَيًّا﴾: جَزاءَ الغَيِّ، أو وادِيًا في جَهَنَّمَ."
  19,61,"﴿جَنَّـٰتِ عَدۡنٍ﴾: جناتِ خُلْدٍ وإقامَةٍ دائِمةٍ.﴿بِٱلۡغَيۡبِ﴾: أي: غائبةً عَنْهم لا يُشاهِدُونها.﴿مَأۡتِيࣰّا﴾: آتِيًا لا مَحالةَ."
  19,62,"﴿لَغۡوًا﴾: كَلامًا باطِلًا.﴿بُكۡرَةࣰ وَعَشِيࣰّا﴾: أي: على مِقْدارِ ما يَعرِفُونَ من الغَداءِ والعَشاءِ، وإلّا فليسَ في الجنَّةِ بُكْرَةٌ ولا عَشِيَّةٌ."
  19,63,"﴿نُورِثُ﴾: نُعْطِي."
  19,64,"﴿وَمَا نَتَنَزَّلُ﴾: أي: نَحْنُ الملائكةُ مِنَ السَّماءِ إلى الأرضِ.﴿لَهُۥ مَا بَيۡنَ أَيۡدِينَا﴾: مما يُسْتَقْبَلُ مِن أُمُورِ الآخِرَةِ.﴿وَمَا خَلۡفَنَا﴾: مِمّا مَضى مِن أُمُورِ الدُّنْيا.﴿وَمَا بَيۡنَ ذَ ٰ⁠لِكَ﴾: وما بَيْنَ الدُّنْيا والآخِرةِ.﴿نَسِيࣰّا﴾: ناسِيًا لشيءٍ مِنَ الأشياءِ."
  19,65,"﴿وَٱصۡطَبِرۡ لِعِبَـٰدَتِهِۦ﴾: واثْبُتْ عَلى طاعةِ الله بِصَبْرٍ ومُواظَبَةٍ.﴿سَمِيࣰّا﴾: مُماثِلًا في ذاتِه وأَسْمائِه وصِفاتِه وأفعالِه."
  19,67,"19:66"
  19,68,"﴿لَنَحۡشُرَنَّهُمۡ﴾: لَنَجْمَعَنَّ هَؤلاءِ المُنْكِرِينَ لِلبَعْثِ يومَ القيامةِ.﴿جِثِيࣰّا﴾: بارِكِينَ على رُكَبِهِم."
  19,69,"﴿ثُمَّ لَنَنزِعَنَّ﴾: ثم لَنَأخُذَنَّ.﴿شِيعَةٍ﴾: طائِفَةٍ.﴿عِتِيࣰّا﴾: تَمرُّدًا وعِصْيانًا للهِ تَعالى."
  19,70,"﴿هُمۡ أَوۡلَىٰ بِهَا صِلِيࣰّا﴾: هُم أوْلى بجَهَنَّمَ دُخُولًا."
  19,71,"﴿إِلَّا وَارِدُهَا﴾: إلّا واردٌ النارَ بالمُرُورِ على الصِّراطِ المنْصُوبِ على مَتْنِ جَهَنَّمَ.﴿حَتۡمࣰا مَّقۡضِيࣰّا﴾: أمْرًا مَحْتُومًا قُضِيَ وحُكِمَ أنّه لابُدَّ مِن وُقُوعِه."
  19,72,"﴿وَّنَذَرُ﴾: ونَتْرُكُ."
  19,73,"﴿خَيۡرࣱ مَّقَامࣰا﴾: أفْضَلُ مَنزِلًا.﴿وَأَحۡسَنُ نَدِيࣰّا﴾: وأَحْسَنُ مَجْلِسًا."
  19,74,"﴿مِّن قَرۡنٍ﴾: مِن أُمَمٍ.﴿هُمۡ أَحۡسَنُ أَثَـٰثࣰا وَرِءۡيࣰا﴾: أحْسنُ مَتاعًا مِنهُم، وأَجْمَلُ مَنظَرًا."
  19,75,"﴿فَلۡيَمۡدُدۡ﴾: فَلْيُمْهِلْهُ اسْتِدْراجًا.﴿هُوَ شَرࣱّ مَّكَانࣰا﴾: شرٌّ مَسْكَنًا ومُسْتَقَرًّا.﴿وَأَضۡعَفُ جُندࣰا﴾: وأَضْعَفُ قوةً ورِجالًا."
  19,76,"﴿وَٱلۡبَـٰقِيَـٰتُ ٱلصَّـٰلِحَـٰتُ﴾: أعمالُ الخيرِ.﴿وَخَيۡرࣱ مَّرَدًّا﴾: وخيرٌ مَرْجِعًا وعاقِبَةً."
  19,77,"﴿لَأُوتَيَنَّ﴾: لَأُعْطَينَّ في الآخِرَةِ."
  19,78,"﴿أَطَّلَعَ ٱلۡغَيۡبَ﴾: أعَلِمَ الغَيبَ؟﴿عَهۡدࣰا﴾: أي: عَهْدًا بِدُخُولِ الجنَّةِ."
  19,79,"﴿وَنَمُدُّ لَهُۥ﴾: ونَزِيدُه في الآخِرَةِ."
  19,80,"﴿وَنَرِثُهُۥ﴾: أي: بَعْدَ هَلاكِه فيَصِيرُ لنا مالُه وولدُه."
  19,81,"﴿عِزࣰّا﴾: شُفَعاءَ وأنْصارًا يَتَعزَّزُونَ بِهِم."
  19,82,"﴿وَيَكُونُونَ عَلَيۡهِمۡ ضِدًّا﴾: وتَكُونُ هَذهَ الآلهةُ مُخالِفةً لهم تُخاصِمُهُم، على عَكْسِ ما كانُوا يَرْجُونَه مِن هَؤلاءِ."
  19,83,"﴿تَؤُزُّهُمۡ﴾: تُهَيِّجُ الكافِرِينَ وتَدْفَعُهُم إلى المَعاصِي."
  19,84,"﴿نَعُدُّ لَهُمۡ﴾: نُحْصِي أعْمالَهم وأَعمارَهُم."
  19,85,"﴿وَفۡدࣰا﴾: قادِمِينَ على اللهِ مُكْرَمِينَ."
  19,86,"﴿وَنَسُوقُ ٱلۡمُجۡرِمِينَ﴾: أي: نَحُثُّهم على السَّيرِ ونَطْرُدُهم كما تُطْرَدُ البَهائِمُ﴿وِرۡدࣰا﴾: عِطاشًا."
  19,88,"19:87"
  19,89,"﴿شَيۡـًٔا إِدࣰّا﴾: شَيئًا عَظِيمًا مُنْكَرًا."
  19,90,"﴿يَتَفَطَّرۡنَ مِنۡهُ﴾: يَتَشَقَّقْنَ ويَتَفَتَّتْنَ مِن شَناعَتِه.﴿تَنشَقُّ﴾: وتَتَصَدَّعُ.﴿وَتَخِرُّ ٱلۡجِبَالُ﴾: أي: تَسْقُطُ وتَنْهَدِمُ.﴿هَدًّا﴾: أي: مَهْدُودَةً ومَكْسُورَةً."
  19,92,"19:91"
  19,93,"19:91"
  19,94,"19:91"
  19,95,"19:91"
  19,96,"19:91"
  19,97,"﴿لُّدࣰّا﴾: شَدِيدِي الخُصُومَةِ بالباطِل."
  19,98,"﴿مِّن قَرۡنٍ﴾: مِن أُمَمٍ.﴿رِكۡزَۢا﴾: صَوْتًا خَفِيًّا."
