tafsir[70]{c,v,t}:
  22,1,"﴿إِنَّ زَلۡزَلَةَ ٱلسَّاعَةِ﴾: هي حَرَكَةُ الأرضِ مِن أسْفَلِها، واضْطِرابُها الذي يَحدُثُ عِنْدَ قِيامِ السّاعةِ."
  22,2,"﴿تَذۡهَلُ﴾: تَغْفُلُ وتَنْسى.﴿تَضَعُ﴾: تُسْقِطُ، وتُلْقِي جَنِينَها.﴿سُكَـٰرَىٰ﴾: أي: كالسُّكارى؛ مِن شِدَّةِ الخوفِ."
  22,3,"﴿يُجَـٰدِلُ﴾: يُخاصِمُ.﴿مَّرِيدࣲ﴾: مُتَمَرِّدٍ على اللهِ."
  22,4,"﴿كُتِبَ عَلَيۡهِ﴾: قُدِّرَ على الشَّيطانِ.﴿مَن تَوَلَّاهُ﴾: مَنِ اتَّخَذَه ولِيًّا وتَبِعَه.﴿وَيَهۡدِيهِ﴾: ويُوصِلُه ويَسُوقُه.﴿عَذَابِ ٱلسَّعِيرِ﴾: عذابِ جَهَنَّمَ الُموْقَدَةِ."
  22,5,"﴿رَيۡبࣲ﴾: شَكٍّ.﴿مِن نُّطۡفَةࣲ﴾: هي مَنِيُّ الرَّجُلِ يَقْذِفُه في رَحِم امْرَأتِه.﴿عَلَقَةࣲ﴾: الدَّم الأحْمَرِ الغَلِيظِ.﴿مُّضۡغَةࣲ﴾: قِطْعَةِ لَحْمٍ صَغِيرةٍ قَدْرَ ما يُمْضَغُ.﴿مُّخَلَّقَةࣲ﴾: ما وُلِد تامَّ الخَلْقِ.﴿غَيۡرِ مُخَلَّقَةࣲ﴾: ما تُسْقِطُه الرَّحِمُ قَبْلَ أن يَتِمَّ خَلْقُه.﴿وَنُقِرُّ﴾: نُثَبِّتُ ونُبْقِي.﴿إِلَىٰٓ أَرۡذَلِ ٱلۡعُمُرِ﴾: أخَسِّه، وهو الهَرمُ والخَرَفُ؛ حتى لا يَعْقِلَ.﴿هَامِدَةࣰ﴾: يابِسةً لا نَباتَ فيها.﴿ٱهۡتَزَّتۡ﴾: تَحرَّكَتْ بالنَّباتِ تَتَفَتَّحُ عَنْه.﴿وَرَبَتۡ﴾: زادَتْ وضاعفَتْ النَّباتَ بِنُزُولِ المطرِ.﴿مِن كُلِّ زَوۡجِۭ بَهِيجࣲ﴾: مِن كُلِّ صِنْفٍ حَسَنٍ ولونٍ مُسْتَحْسَنٍ."
  22,7,"﴿يَبۡعَثُ مَن فِي ٱلۡقُبُورِ﴾: أي: يَبْعَثُهم أحْياءً."
  22,8,"﴿يُجَـٰدِلُ﴾: يُخاصِمُ."
  22,9,"﴿ثَانِيَ عِطۡفِهِۦ﴾: لاويًا عُنُقَه في استكبارٍ عَنِ الحَقِّ.﴿خِزۡيࣱ﴾: ذُلٌّ وهَوانٌ."
  22,11,"﴿عَلَىٰ حَرۡفࣲ﴾: على ضَعْفٍ وشَكٍّ.﴿فِتۡنَةٌ﴾: ابْتِلاءٌ وشِدَّةٌ.﴿ٱنقَلَبَ عَلَىٰ وَجۡهِهِۦ﴾: رَجَعَ عمّا كان عليه مِنَ الاسْتِقامَةِ.﴿ٱلۡخُسۡرَانُ ٱلۡمُبِينُ﴾: الخَسارةُ العَظِيمَةُ والصَّفْقَةُ الخاسِرةُ."
  22,13,"﴿ٱلۡمَوۡلَىٰ﴾: النَّصِيرُ.﴿ٱلۡعَشِيرُ﴾: الصّاحِبُ المُعاشِرُ."
  22,14,"﴿مِن تَحۡتِهَا﴾: أي: مِن تَحْتِ قُصُورِها."
  22,15,"﴿فَلۡيَمۡدُدۡ﴾: فليَشْدُدْ.﴿بِسَبَبٍ﴾: بحَبْلٍ.﴿إِلَى ٱلسَّمَآءِ﴾: أي: سَماءِ بيتِه، وهو سَقْفُه.﴿ثُمَّ لۡيَقۡطَعۡ﴾: أي: ذلك الحبلَ، لِيَخْنُقَ بِه نَفْسَه.﴿كَيۡدُهُۥ﴾: مَكْرُه وحِيلَتُه.﴿مَا يَغِيظُ﴾: ما يَجِدُ في نَفْسِه مِنَ الغَيظِ والغَضَبِ."
  22,16,"﴿بَيِّنَـٰتࣲ﴾: واضحاتٍ."
  22,17,"﴿ٱلَّذِينَ هَادُواْ﴾: اليهُودَ.﴿ٱلصَّـٰبِـِٔينَ﴾: هم قَومٌ باقُونَ على فِطْرَتِهم، ولا دِينَ مقرَّرَ لهم يَتَّبِعونه.﴿وَٱلۡمَجُوسَ﴾: هم عَبَدَةُ النّارِ.﴿يَفۡصِلُ بَيۡنَهُمۡ﴾: يَقْضِي بَيْنَهم.﴿شَهِيدٌ﴾: رَقِيبٌ يُحصِي أعمالَ خَلْقِه كلَّها."
  22,18,"﴿أَلَمۡ تَرَ﴾: ألم تَعلَمْ.﴿يَسۡجُدُ لَهُۥ﴾: يَنْقادُ له ويَخْضَعُ.﴿حَقَّ عَلَيۡهِ﴾: وجَبَ عليه."
  22,19,"﴿خَصۡمَانِ﴾: فريقانِ: وهم المؤمِنُونَ والكُفّارُ.﴿ٱخۡتَصَمُواْ﴾: اخْتَلَفُوا.﴿فِي رَبِّهِمۡ﴾: في دِينِ ربِّهم.﴿قُطِّعَتۡ لَهُمۡ﴾: جُعِلَتْ لَهم.﴿ٱلۡحَمِيمُ﴾: الماءُ البالغُ نِهايةَ الحرارةِ."
  22,20,"﴿يُصۡهَرُ بِهِۦ﴾: يُذابُ به."
  22,21,"﴿مَّقَـٰمِعُ﴾: مَطارِقُ."
  22,22,"﴿مِنۡ غَمٍّ﴾: مِنَ أجْلِ ما نالَهُم مِنَ الغَمِّ والكَرْبِ."
  22,23,"﴿يُحَلَّوۡنَ فِيهَا﴾: يُلْبَسُونَ في الجنَّةِ الحُليَّ.﴿أَسَاوِرَ﴾: مفردُه سِوارٌ: وهو ما يُلبَسُ في اليد للتزيُّنِ، ويُحِيطُ بالمِعْصَمِ."
  22,24,"﴿وَهُدُوٓاْ﴾: هَداهُمُ اللهُ ووَفَّقَهم.﴿إِلَى ٱلطَّيِّبِ مِنَ ٱلۡقَوۡلِ﴾: إلى كَلِمةِ التَّوحِيدِ أنْ لا إلَهَ إلا اللهُ.﴿إِلَىٰ صِرَ ٰ⁠طِ ٱلۡحَمِيدِ﴾: الصِّراطِ المحمُودِ وهو الإسْلام."
  22,25,"﴿سَوَآءً﴾: مُسْتَوِيًا.﴿ٱلۡعَـٰكِفُ فِيهِ﴾: المقيمُ فيه المُلازمُ له.﴿وَٱلۡبَادِ﴾: القادمُ إليه مِن غَيْرِ أهْلِه.﴿بِإِلۡحَادِۭ﴾: بِعُدُولٍ عَنِ القَصْدِ."
  22,26,"﴿بَوَّأۡنَا لِإِبۡرَ ٰ⁠هِيمَ﴾: أي: بَيَّنّا له.﴿وَطَهِّرۡ بَيۡتِيَ﴾: أي: مِنَ الشِّركِ والكُفْرِ وسائِرِ النَّجاساتِ."
  22,27,"﴿وَأَذِّن فِي ٱلنَّاسِ﴾: أي: أعْلِمْهم بإعْلانٍ.﴿رِجَالࣰا﴾: جَمْعُ راجِلٍ، وهو مَن جاء يَمْشِي على رِجْلَيه.﴿وَعَلَىٰ كُلِّ ضَامِرࣲ﴾: أي: ورُكبانًا على كلِّ بعيرٍ مَهزولٍ أتْعَبَه طولُ السَّفَرِ.﴿فَجٍّ عَمِيقࣲ﴾: طَرِيقٍ بَعِيدٍ."
  22,28,"﴿أَيَّامࣲ مَّعۡلُومَـٰتٍ﴾: أيّامٍ مُعَيَّنةٍ هي: عاشرُ ذِي الحِجَّةِ وثلاثةُ أيّامٍ بَعْدَه.﴿عَلَىٰ مَا رَزَقَهُم مِّنۢ بَهِيمَةِ ٱلۡأَنۡعَـٰمِ﴾: أي: على ذَبْحِ ما رَزَقَهُم مِن بهِيَمَةِ الأنعامِ، وهي: الإبِلُ والَبَقرُ والغَنَمُ.﴿ٱلۡبَآئِسَ ٱلۡفَقِيرَ﴾: هو الفقيرُ الذي اشْتَدَّ فَقْرُه."
  22,29,"﴿ثُمَّ لۡيَقۡضُواْ تَفَثَهُمۡ﴾: ثم لِيُزِيلُوا وسَخَهم بعد خُرُوجِهِم مِن إحْرامِهِم.﴿وَلۡيُوفُواْ نُذُورَهُمۡ﴾: ولْيُوَفُّوا بما أوجَبُوه على أنْفُسِهم مِن أعْمالِ البِرِّ في الحجِّ وغيرِه.﴿بِٱلۡبَيۡتِ ٱلۡعَتِيقِ﴾: وهو الكَعْبةُ، وقد أعْتَقَها اللهُ مِن تَسَلُّطِ الجبّارينَ عَلَيها."
  22,30,"﴿حُرُمَـٰتِ ٱللَّهِ﴾: جَمْعُ حُرْمَةٍ، وهي ما وجَبَ القيامُ به، وحَرُمَ التَّفْرِيطُ فيه.﴿ٱلرِّجۡسَ مِنَ ٱلۡأَوۡثَـٰنِ﴾: أي: مِن عِبادَةِ الأوثانِ، فإنها رِجْسٌ.﴿ٱلزُّورِ﴾: الكذِبِ والافْتِراءِ على اللهِ."
  22,31,"﴿حُنَفَآءَ لِلَّهِ﴾: مُسْتَقِيمِينَ على الحقِّ.﴿خَرَّ﴾: سَقَطَ.﴿فَتَخۡطَفُهُ﴾: فَتَسْلُبُه وتَذْهبُ بِه.﴿تَهۡوِي بِهِ﴾: تَقْذِفُه وتَرْمِي بِه.﴿سَحِيقࣲ﴾: بَعِيدٍ."
  22,32,"﴿شَعَـٰٓئِرَ ٱللَّهِ﴾: هي معالمُ دِينِه، ومِنها شَعِيرةُ الحَجِّ."
  22,33,"﴿إِلَىٰٓ أَجَلࣲ مُّسَمࣰّى﴾: وهو وقتُ ذَبْحِها.﴿ثُمَّ مَحِلُّهَآ﴾: أي: حيثُ يَحِلُّ ذَبْحُها."
  22,34,"﴿مَنسَكࣰا﴾: ذَبْحًا يَذْبَحُونَه أو عِيدًا أو حَجًّا يَحُجُّونَه.﴿عَلَىٰ مَا رَزَقَهُم﴾: على ذَبْحِ ما رَزَقَهُم.﴿ٱلۡمُخۡبِتِينَ﴾: الخاشِعِينَ المخْلصِيِنَ."
  22,35,"﴿وَجِلَتۡ﴾: خافتْ."
  22,36,"﴿وَٱلۡبُدۡنَ﴾: وهي الإبِلُ والبَقَرُ مما يُجْزِئُ ذَبْحُه عَنْ سَبْعةٍ.﴿صَوَآفَّ﴾: أي: قائِماتٍ، بأن تُقامَ على قَوائِمِها الأرْبَعِ، ثم تُعْقَلَ إحْدى يَدَيها.﴿وَجَبَتۡ جُنُوبُهَا﴾: سقَطَتْ جُنوبُها على الأرضِ.﴿ٱلۡقَانِعَ﴾: الفقيرَ المُتَعَفِّفَ عَنِ السُّؤالِ.﴿وَٱلۡمُعۡتَرَّ﴾: الُمحتاجَ الَّذي يَسْأَلُ."
  22,37,"﴿ٱلتَّقۡوَىٰ مِنكُمۡ﴾: إخْلاصُكم لله وخَشْيَتُكُم مِنه."
  22,38,"﴿يُدَ ٰ⁠فِعُ﴾: يَدْفْعُ ويَرُدُّ.﴿خَوَّانࣲ﴾: كثيرِ الخِيانَةِ.﴿كَفُورٍ﴾: جَحُودٍ لِنِعَمِ اللهِ."
  22,39,"﴿أُذِنَ لِلَّذِينَ﴾: أي: شُرِعَ لهم القِتالُ."
  22,40,"﴿صَوَ ٰ⁠مِعُ﴾: مَعابدُ رُهْبانِ النَّصارى.﴿بِيَعࣱ﴾: كَنائِسُ النَّصارى.﴿صَلَوَ ٰ⁠تࣱ﴾: كنائِسُ اليهُودِ."
  22,42,"22:41"
  22,43,"22:41"
  22,44,"﴿وَأَصۡحَـٰبُ مَدۡيَنَ﴾: قومُ شُعَيبٍ عليه الصَّلاة والسَّلامُ.﴿فَأَمۡلَيۡتُ﴾: فأَمهَلْتُ.﴿ثُمَّ أَخَذۡتُهُمۡ﴾: أي: بالعقاب فَأَهْلَكْتُهم.﴿نَكِيرِ﴾: أي: إنْكارِي عَلَيهم."
  22,45,"﴿فَكَأَيِّن﴾: فَكَثِيرًا.﴿ظَالِمَةࣱ﴾: أي: أهلُها بالكُفْرِ والشِّركِ.﴿خَاوِيَةٌ عَلَىٰ عُرُوشِهَا﴾: ساقِطةٌ على سُقُوفِها.﴿وَبِئۡرࣲ مُّعَطَّلَةࣲ﴾: وبِئْرٍ مَهْجُورَةٍ بِمَوْتِ أهْلِها.﴿وَقَصۡرࣲ مَّشِيدٍ﴾: وقَصْرٍ مُجَصَّصٍ مَرْفُوعِ البُنْيانِ، خَرِبَ بِمَوتِ أهْلِه."
  22,47,"﴿مِّمَّا تَعُدُّونَ﴾: أي: مما تَحْسُبُونَ من سِنِي الدُّنيا."
  22,48,"﴿أَمۡلَيۡتُ لَهَا﴾: أمْهَلْتُها.﴿ظَالِمَةࣱ﴾: أي: أهلُها بالكفرِ والشِّركِ.﴿ثُمَّ أَخَذۡتُهَا﴾: أي: أهْلَكْتُها.﴿ٱلۡمَصِيرُ﴾: المرْجِعُ."
  22,50,"﴿وَرِزۡقࣱ كَرِيمࣱ﴾: ورِزْقٌ حَسَنٌ لا يَنْقَطِعُ، وهو الجنَّةُ."
  22,51,"﴿وَٱلَّذِينَ سَعَوۡاْ فِيٓ ءَايَـٰتِنَا﴾: والذين اجْتَهَدُوا في مُحارَبةِ القرآنِ وإبْطالِ آياتِه وحُجَجِه.﴿مُعَـٰجِزِينَ﴾: ظانِّينَ أنّهم يُعْجِزُونَنا ويَغْلِبُوننا.﴿أَصۡحَـٰبُ ٱلۡجَحِيمِ﴾: أهلُ النارِ الموقَدَةِ."
  22,52,"﴿تَمَنَّىٰٓ﴾: قَرَأَ ما نَزَلَ عَلَيهِ.﴿أَلۡقَى ٱلشَّيۡطَـٰنُ فِيٓ أُمۡنِيَّتِهِۦ﴾: أي: ألْقى في قِراءتِه الوَساوِسَ والشُّبُهاتِ.﴿فَيَنسَخُ ٱللَّهُ﴾: أي: فَيُزِيلُه.﴿مَا يُلۡقِي ٱلشَّيۡطَـٰنُ﴾: أي: ما يُلْقِيهِ مِن وساوِسَ وشُبُهاتٍ.﴿ثُمَّ يُحۡكِمُ ٱللَّهُ ءَايَـٰتِهِۦ﴾: ثُمَّ يُثَبِّتُ اللهُ آياتِه كما نَزَلَتْ ويَحفْظُها مِنَ التَّبْدِيل."
  22,53,"﴿فِتۡنَةࣰ﴾: ابْتلِاءً واخْتِبارًا.﴿مَّرَضࣱ﴾: شكٌّ ونِفاقٌ.﴿وَٱلۡقَاسِيَةِ قُلُوبُهُمۡ﴾: أي: غَلُظَتْ قُلُوبُهم عَن قَبُولِ الحَقِّ.﴿شِقَاقِۭ بَعِيدࣲ﴾: خِلافٍ بَعِيدٍ عَنِ الصَّوابِ."
  22,54,"﴿أَنَّهُ ٱلۡحَقُّ مِن رَّبِّكَ﴾: أنّ القرآنَ هو الحقُّ النازِلُ مِن عِنْدِ اللهِ عَلَيكَ.﴿فَتُخۡبِتَ لَهُۥ﴾: فَتَخْشَعَ لَهُ وتَخْضَعَ."
  22,55,"﴿فِي مِرۡيَةࣲ مِّنۡهُ﴾: في شَكٍّ مِن هَذا القُرآنِ.﴿بَغۡتَةً﴾: فَجْأةً.﴿يَوۡمٍ عَقِيمٍ﴾: هو يومُ القيامةِ الَّذي لا خيرَ فيه للكفارِ، ولا يومَ بَعْدَه."
  22,56,"﴿ٱلۡمُلۡكُ﴾: السُّلْطانُ القاهِرُ.﴿يَوۡمَئِذࣲ﴾: أي: يومَ القيامةِ."
  22,57,"﴿مُّهِينࣱ﴾: مُخْزٍ ومُذِلٌّ."
  22,58,"﴿رِزۡقًا حَسَنࣰا﴾: وهو الجنَّةُ."
  22,59,"﴿مُّدۡخَلࣰا﴾: مكانَ دخولٍ، وهو الجنَّةُ."
  22,60,"﴿ثُمَّ بُغِيَ عَلَيۡهِ﴾: ثُمَّ اعْتُدِيَ عليه بالظُّلْمِ."
  22,61,"﴿يُولِجُ﴾: يُدخِلُ."
  22,62,"﴿مَا يَدۡعُونَ مِن دُونِهِۦ﴾: ما يَعْبُدُه الُمشْرِكُون مِن دُونِ اللهِ مِنَ الأصْنامِ وغَيرِها.﴿ٱلۡعَلِيُّ﴾: أي: على خَلْقِه ذاتًا وقدْرًا وقَهْرًا."
  22,63,"﴿مَآءࣰ﴾: مَطَرًا."
  22,64,"﴿ٱلۡحَمِيدُ﴾: المحمودُ المُسْتَحِقُّ لِلْحمْدِ في كُلِّ حالٍ."
  22,65,"﴿سَخَّرَ﴾: ذَلَّلَ.﴿ٱلۡفُلۡكَ﴾: السُّفُنَ.﴿يُمۡسِكُ ٱلسَّمَآءَ﴾: يَحْفظُ السَّماءَ."
  22,66,"﴿لَكَفُورࣱ﴾: لَجَحُودٌ."
  22,67,"﴿مَنسَكًا﴾: شَرِيعةً خاصَّةً.﴿هُمۡ نَاسِكُوهُ﴾: هم عامِلُونَ به.﴿فَلَا يُنَـٰزِعُنَّكَ فِي ٱلۡأَمۡرِ﴾: فلا يَحِقُّ لَهُم أنْ يخاصِمُوكَ في شَرِيعَتِكَ.﴿هُدࣰى مُّسۡتَقِيمࣲ﴾: دِينٍ قَوِيمٍ لا اعْوِجاجَ فِيه."
  22,69,"22:68"
  22,70,"﴿فِي كِتَـٰبٍ﴾: أي: في اللَّوحِ المحْفُوظِ."
  22,71,"﴿سُلۡطَـٰنࣰا﴾: حُجَّةً وبُرْهانًا.﴿لِلظَّـٰلِمِينَ﴾: للمُشْرِكِينَ."
  22,72,"﴿ٱلۡمُنكَرَ﴾: الأمرَ الذي يُنْكَرُ مِنَ العُبُوسِ والغَضَبِ والكَراهَةِ.﴿يَسۡطُونَ﴾: يَبْطِشُونَ.﴿بِشَرࣲّ مِّن ذَ ٰ⁠لِكُمُ﴾: بِشَرٍّ مِن غَيظِكُم على مَن يَتْلُو عليكُم آياتِ اللهِ.﴿وَبِئۡسَ ٱلۡمَصِيرُ﴾: ساءَ وقَبُحَ المكانُ الذي يَرجِعُونَ إليه."
  22,73,"﴿فَٱسۡتَمِعُواْ لَهُۥٓ﴾: أي: سَماعَ تَدَبُّرٍ.﴿تَدۡعُونَ﴾: تَعْبُدُونَ.﴿ذُبَابࣰا﴾: ذُبابةً واحِدةً مَعَ صِغَرِها.﴿وَإِن يَسۡلُبۡهُمُ﴾: أي: وإن يَأْخُذِ الذُّبابُ شيئًا مِن هَذهِ المعْبُوداتِ.﴿لَّا يَسۡتَنقِذُوهُ مِنۡهُ﴾: أي: لا يَقْدِرُوا -لِعَجْزِهِم- على اسْتِرْدادِ ما أُخِذَ مِنهم.﴿ٱلطَّالِبُ﴾: هو المَعبُودُ مِن دُونِ اللهِ.﴿ٱلۡمَطۡلُوبُ﴾: هو الذُّبابُ."
  22,74,"﴿مَا قَدَرُواْ ٱللَّهَ حَقَّ قَدۡرِهِۦٓ﴾: ما عَظَّمَ المشْرِكُونَ اللهَ تَعالى حقَّ تَعْظِيمِهِ."
  22,75,"﴿يَصۡطَفِي﴾: يَخْتارُ."
  22,76,"﴿مَا بَيۡنَ أَيۡدِيهِمۡ﴾: أي: أعْمالَهم التي عَمِلُوها.﴿مَا خَلۡفَهُمۡ﴾: أي: أعْمالَهم التي سَيَعْمَلُونَها."
  22,78,"﴿وَجَـٰهِدُواْ فِي ٱللَّهِ﴾: أي: في سَبِيِلهِ لإعْلاءِ كَلِمَتِهِ.﴿هُوَ ٱجۡتَبَىٰكُمۡ﴾: اصْطَفاكُم اللهُ لِحَمْلِ دِينِه.﴿مِنۡ حَرَجࣲ﴾: مِن ضِيقٍ ومَشَقَّةٍ بتكْلِيفٍ يَشُقُّ عَلَيكُم.﴿مِن قَبۡلُ﴾: أي: في الكُتُبِ المُنَزَّلةِ السّابِقَةِ.﴿فِي هَـٰذَا﴾: أي: في هَذا القرآنِ.﴿شُهَدَآءَ عَلَى ٱلنَّاسِ﴾: أي: على الأممِ السّابَقَةِ أنّ رُسُلَهم قد بَلَّغَتْهم رِسالاتِ ربِّهم.﴿وَٱعۡتَصِمُواْ بِٱللَّهِ﴾: أي: اجْعَلُوه عِصْمةً لكم مما تَحْذَرُونَ، والتَجِئُوا إليه في جميعِ أُمُورِكُم.﴿هُوَ مَوۡلَىٰكُمۡ﴾: هو ناصِرُكُم، ومُتَوَلِّي أمورِكُم."
