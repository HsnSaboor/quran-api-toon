tafsir[52]{c,v,t}:
  55,2,"55:1"
  55,3,"55:1"
  55,4,"﴿ٱلۡبَيَانَ﴾: النُّطْقَ والتَّعْبِيرَ عَمّا في الضَّمائِرِ."
  55,5,"﴿بِحُسۡبَانࣲ﴾: يَجْرِيانِ بِحِسابٍ مُتْقَنٍ."
  55,7,"﴿ٱلۡمِيزَانَ﴾: العَدْلَ الَّذِي شَرَعَهُ لِعِبادِهِ."
  55,8,"﴿أَلَّا تَطۡغَوۡاْ﴾: لِئَلّا تَعْتَدُوا."
  55,9,"﴿بِٱلۡقِسۡطِ﴾: بالعَدْلِ.﴿وَلَا تُخۡسِرُواْ﴾: ولا تُنْقِصُوا."
  55,10,"﴿وَضَعَهَا﴾: مَهَّدَها.﴿لِلۡأَنَامِ﴾: لِلْخَلْقِ."
  55,11,"﴿ٱلۡأَكۡمَامِ﴾: جَمْعُ كِمٍّ وهو وِعاءُ الثَّمرَةِ."
  55,12,"﴿ذُو ٱلۡعَصۡفِ﴾: ذُو القِشْرِ.﴿وَٱلرَّيۡحَانُ﴾: كُلُّ نَبْتٍ طَيِّبِ الرّائِحةِ."
  55,13,"﴿ءَالَآءِ﴾: نِعَمِ."
  55,14,"﴿ٱلۡإِنسَـٰنَ﴾: أي أباه، وهو آدَمُ.﴿مِن صَلۡصَـٰلࣲ﴾: مِن طِينٍ يابِسٍ.﴿كَٱلۡفَخَّارِ﴾: الطينِ الَّذِي طُبِخَ بالنّارِ."
  55,15,"﴿ٱلۡجَآنَّ﴾: إبْلِيسَ.﴿مَّارِجࣲ﴾: لَهَبِ الَّنارِ المُخْتَلِطِ بَعْضُهُ بِبَعْضٍ."
  55,17,"﴿ٱلۡمَشۡرِقَيۡنِ﴾: مَشْرِقَي الشَّمْسِ في الشِّتاءِ والصَّيفِ.﴿ٱلۡمَغۡرِبَيۡنِ﴾: مَغْرِبَيِ الشَّمسِ في الشِّتاءِ والصَّيفِ."
  55,19,"﴿مَرَجَ﴾: خَلَطَ.﴿ٱلۡبَحۡرَيۡنِ﴾: الماءَ العَذْبَ والمِلْحَ.﴿يَلۡتَقِيَانِ﴾: في مَرْأى العَينِ."
  55,20,"﴿بَرۡزَخࣱ﴾: حاجِزٌ.﴿لَّا يَبۡغِيَانِ﴾: لا يطْغى أحَدُهُما عَلى الآخَرِ."
  55,22,"﴿ٱللُّؤۡلُؤُ﴾: الدُّرُّ.﴿وَٱلۡمَرۡجَانُ﴾: صِغارُ اللُّؤلُؤ."
  55,24,"﴿ٱلۡجَوَارِ﴾: السُّفُنُ الضَّخْمَةُ الَّتِي تَجْرِي في البَحْرِ.﴿ٱلۡمُنشَـَٔاتُ﴾: المَرْفُوعاتُ الشِّراعِ.﴿كَٱلۡأَعۡلَـٰمِ﴾: كالجِبالِ."
  55,26,"﴿عَلَيۡهَا﴾: عَلى وجْهِ الأرْضِ.﴿فَانࣲ﴾: هالِكٌ."
  55,27,"﴿ٱلۡجَلَـٰلِ﴾: ذُو العَظَمَةِ والكِبْرِياءِ.﴿وَٱلۡإِكۡرَامِ﴾: والفَضْلِ والجُودِ."
  55,29,"55:28"
  55,30,"55:28"
  55,31,"﴿سَنَفۡرُغُ﴾: سنفرغ لحسابكم ومجازاتكم بأعْمالِكُم.﴿أَيُّهَ ٱلثَّقَلَانِ﴾: أيُّها الإنْسُ والجِنُّ."
  55,33,"﴿تَنفُذُواْ﴾: تَخْرُجُوا.﴿أَقۡطَارِ﴾: أطْرافِ.﴿بِسُلۡطَـٰنࣲ﴾: بِقُوَّةٍ وحُجَّةٍ."
  55,35,"﴿شُوَاظࣱ﴾: لَهَبٌ.﴿وَنُحَاسࣱ﴾: مُذابٌ يُصَبُّ على رُؤُوسِكُم.﴿فَلَا تَنتَصِرَانِ﴾: فَلا يَنْصُرُ بَعْضُكُم بَعْضًا."
  55,37,"﴿ٱنشَقَّتِ﴾: تَفَطَّرَتْ يَوْمَ القِيامَةِ.﴿وَرۡدَةࣰ﴾: حَمْراءَ كَلَونِ الوَرْدِ.﴿كَٱلدِّهَانِ﴾: كالزَّيتِ الَمغْلِيِّ والرَّصاصِ المُذابِ."
  55,39,"55:38"
  55,40,"55:38"
  55,41,"﴿بِسِيمَـٰهُمۡ﴾: بعَلاماتِهِم.﴿بِٱلنَّوَ ٰ⁠صِي﴾: بمُقَدِّمَةِ رُؤُوسِهِم."
  55,43,"55:42"
  55,44,"﴿حَمِيمٍ﴾: الماءِ الشَّدِيدِ الحَرارَةِ.﴿ءَانࣲ﴾: بالغٍ مُنْتَهاهُ في الحرارةِ."
  55,46,"﴿مَقَامَ رَبِّهِۦ﴾: وقْتَ قِيامِهِ بين يَدَي رَبِّهِ."
  55,48,"﴿أَفۡنَانࣲ﴾: أغْصانٍ نَضِرَةٍ مِنَ الفَواكِهِ والثِّمارِ."
  55,50,"55:49"
  55,51,"55:49"
  55,52,"﴿زَوۡجَانِ﴾: صِنْفانِ."
  55,54,"﴿بَطَآئِنُهَا﴾: جَمْعُ بِطانَةٍ وهي: ما يَلِي الأرْضَ مِنَ الفِراشِ.﴿إِسۡتَبۡرَقࣲ﴾: غَلِيظِ الحرِيرِ الخالِصِ.﴿وَجَنَى﴾: وثَمَرُ.﴿دَانࣲ﴾: قَرِيبٌ إليهِم."
  55,56,"﴿فِيهِنَّ﴾: في هَذِه الفُرُشِ.﴿قَـٰصِرَ ٰ⁠تُ ٱلطَّرۡفِ﴾: لا يَصْرِفْنَ أبْصارَهُنَّ إلى غَيرِ أزْواجِهِنَّ.﴿لَمۡ يَطۡمِثۡهُنَّ﴾: لم يَطَأْهُنَّ."
  55,58,"﴿ٱلۡيَاقُوتُ﴾: حَجَرٌ مِنَ الأحْجارِ الكَرِيمَةِ، ذُو ألْوانٍ.﴿وَٱلۡمَرۡجَانُ﴾: صِغارُ اللُّؤلُؤِ."
  55,60,"55:59"
  55,61,"55:59"
  55,62,"﴿وَمِن دُونِهِمَا﴾: ومِن دُونِ الجنَّتَينِ السّابِقَتَينِ في الدَّرَجِ."
  55,64,"﴿مُدۡهَآمَّتَانِ﴾: خَضْراوانِ، وقَدِ اشْتَدَّتْ خُضْرَتُهُما حَتّى مالَتْ إلى السَّوادِ."
  55,66,"﴿نَضَّاخَتَانِ﴾: فَوّارتانِ بالماءِ لا تَنْقَطِعانِ."
  55,68,"55:67"
  55,69,"55:67"
  55,70,"﴿فِيهِنَّ﴾: في هَذِه الجنّاتِ الأرْبَعِ.﴿خَيۡرَ ٰ⁠تٌ﴾: زَوْجاتٌ طيِّباتُ الأخْلاقِ.﴿حِسَانࣱ﴾: حِسانُ الوُجُوهِ."
  55,72,"﴿حُورࣱ﴾: نِساءٌ ذَواتُ حَوَرٍ، وهو شِدَّةُ بَياضِ العَينِ وشِدَّةُ سَوادِها.﴿مَّقۡصُورَ ٰ⁠تࣱ﴾: مَسْتُوراتٌ مَصُوناتٌ.﴿ٱلۡخِيَامِ﴾: البُيوتِ."
  55,74,"55:73"
  55,75,"55:73"
  55,76,"﴿رَفۡرَفٍ﴾: وسائِدَ ذَواتِ أغْطِيَةٍ.﴿وَعَبۡقَرِيٍّ﴾: وفُرُشٍ بَدِيعَةٍ."
  55,78,"﴿تَبَـٰرَكَ﴾: كَثُرَ خَيرُهُ.﴿ٱلۡجَلَـٰلِ﴾: العَظَمَةِ والمَجْدِ.﴿وَٱلۡإِكۡرَامِ﴾: لِأَوْلِيائِهِ."
