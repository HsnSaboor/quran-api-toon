tafsir[25]{c,v,t}:
  26,112,"﴿قالَ وما عِلْمِي﴾ أيْ عِلْم لِي"
  26,113,"﴿إنْ﴾ ما ﴿حِسابهمْ إلّا عَلى رَبِّي﴾ فَيُجازِيهِمْ ﴿لَوْ تَشْعُرُونَ﴾ تَعْلَمُونَ ذَلِكَ ما عَبَدْتُمُوهُمْ"
  26,114,""
  26,115,"﴿إنْ﴾ ما ﴿أنا إلّا نَذِير مُبِين﴾ بَيِّن الإنْذار"
  26,116,"﴿قالُوا لَئِنْ لَمْ تَنْتَهِ يا نُوح﴾ عَمّا تَقُول لَنا ﴿لَتَكُونَن مِن المَرْجُومِينَ﴾ بِالحِجارَةِ أوْ بِالشَّتْمِ"
  26,117,"﴿قالَ﴾ نُوح"
  26,118,"﴿فافْتَحْ بَيْنِي وبَيْنهمْ فَتْحًا﴾ أيْ اُحْكُمْ"
  26,119,"﴿فَأَنْجَيْناهُ ومَن مَعَهُ فِي الفُلْك المَشْحُون﴾ المَمْلُوء مِن النّاس والحَيَوان والطَّيْر"
  26,120,"﴿ثُمَّ أغْرَقْنا بَعْد﴾ بَعْد إنْجائِهِمْ ﴿الباقِينَ﴾ مِن قَوْمه"
  26,121,""
  26,122,"26:121"
  26,123,"26:121"
  26,124,"26:121"
  26,125,"26:121"
  26,126,"26:121"
  26,127,"﴿وما أسْأَلكُمْ عَلَيْهِ مِن أجْر إنْ﴾ ما"
  26,128,"﴿أتَبْنُونَ بِكُلِّ رِيع﴾ مَكان مُرْتَفِع ﴿آيَة﴾ بِناء عَلَمًا لِلْمارَّةِ ﴿تَعْبَثُونَ﴾ بِمَن يَمُرّ بِكُمْ وتَسْخَرُونَ مِنهُمْ والجُمْلَة حال فِي ضَمِير تَبْنُونَ"
  26,129,"﴿وتَتَّخِذُونَ مَصانِع﴾ لِلْماءِ تَحْت الأَرْض ﴿لَعَلَّكُمْ﴾ كَأَنَّكُمْ ﴿تَخْلُدُونَ﴾ فِيها لا تَمُوتُونَ"
  26,130,"﴿وإذا بَطَشْتُمْ﴾ بِضَرْبٍ أوْ قَتْل ﴿بَطَشْتُمْ جَبّارِينَ﴾ مِن غَيْر رَأْفَة"
  26,131,"﴿فاتَّقُوا اللَّه﴾ فِي ذَلِكَ ﴿وأَطِيعُونِ﴾ فِيما أمَرْتُكُمْ بِهِ"
  26,132,"﴿واتَّقُوا الَّذِي أمُدّكُمْ﴾ أُنْعِم عَلَيْكُمْ"
  26,133,""
  26,134,"﴿وجَنّات﴾ بَساتِين ﴿وعُيُون﴾ أنْهار"
  26,135,"﴿إنِّي أخاف عَلَيْكُمْ عَذاب يَوْم عَظِيم﴾ فِي الدُّنْيا والآخِرَة إنْ عَصَيْتُمُونِي"
  26,136,"﴿قالُوا سَواء عَلَيْنا﴾ مُسْتَوٍ عِنْدنا ﴿أوَعَظْت أمْ لَمْ تَكُنْ مِن الواعِظِينَ﴾ أصْلًا أيْ لا نَرْعَوِي لِوَعْظِك"