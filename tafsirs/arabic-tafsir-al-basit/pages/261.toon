tafsir[10]{c,v,t}:
  14,43,"قوله تعالى: ﴿مُهْطِعِينَ﴾ قال أبو إسحاق: منصوب على الحال، المعنى: إنما يؤخرهم ليوم تشخص فيه أبصارُهُم مهطعين، فعلى ما ذكره الألف واللام في: ﴿الْأَبْصَارُ﴾ يدل على الكناية؛ لأن التأويل بأبصارهم على ما ذَكر، وأما تفسير الإهطاع {1} فقال أبو عبيدة: هو الإسراع {2}، يقال: أهطع البعير في سيره واستهطع، إذا أسرع {3}، وهو اختيار الزجاج؛ قال: مهطعين: مسرعين، وأنشد {4}:بِدِجْلةَ أَهْلُهَا ولَقَد أراهُمْ {5} ... بِدِجْلةَ مُهْطِعِينَ إلى السّمَاعِ {6}قال: أي مسرعين {7}، وأنشد أبو عبيدة:بمُهْطِعٍ سُرُحٍ كأنّ زِمَامَه ... في رأسِ جِذْعٍ من أَوالَ مُشَذَّبِ {8} قال أبو عبيدة: أهطع وهطع إذا أسرع مقبلًا خائفًا، لا يكون إلا مع خوف {9}، وقال أحمد بن يحيىَّ: المُهطِعُ الذي ينظر في ذُلٍّ وخشوعٍ {10}، وقال ابن جريج: المهطع الساكت المنطلق إلى الهُتافِ إذا هتف هاتفٌ {11} وقال الليث: يقال للرجل إذا أقرَّ وذلَّ قد أهطع {12}، وأنشد:ونِمْرُ بن سَعْدٍ لي مُطيعٌ ومُهطِعُ {13}فهذه أربعة أقوال لأهل اللغة في تفسير هذا الحرف، وأما قول المفسرين: فقال سعيد بن جبير، والحسن، وقتادة: مسرعين {14}، وقال سعيد عن قتادة: منطلقين عامدين إلى الداعي {15}، وقال نافع بن الأزرق لابن عباس: أخبرني عن قولى: ﴿مُهْطِعِينَ﴾ ما الإهطاع؟ قال: النظر {16}، وفي ذلك يقول الشاعر {17}:إذا دَعَانَا فأهْطَعْنا لدَعْوته ... داعٍ سميعٌ فَلَفُّونَا وسَاقُوْنا {18}وهذا قول مجاهد والضحاك والكلبي والعوفي عن ابن عباس قالوا: ناظرين مديمي النظر من غير أن يطرفوا {19}، ونحو ذلك قال أبو الضحى؛ قال: الإهطاع من التَّحْمِيج {20} الذي زدتُم {21} النظر ولا يَطْرِف {22}.وهذه الأقوال توافق ما حكينا من أهل اللغة، والجامع لهذه الأقوال قول من قال الإهطاع: إسراعٌ مع إدامة نظر {23}.وقوله تعالى: ﴿مُقْنِعِي رُءُوسِهِمْ﴾ قال ابن السكَيت: أقنع رأسه إذا رفعه {24}، قال النضر: أقنع فلانٌ رأسه، وهو أن يرفع بصره ووجهه إلى السماء، قال: والمقنع: الرافع رأسه إلى السماء {25}، وقال أحمد بن يحييَّ: الإقناع: رفع الرأس والنظر في ذل وخشوع {26}.ومنه ما روي عن النبيّ ﷺ أنه قال: ""تُقْنِع يديك في الدعاء"". أي: ترفعهما {27}.وقال أبو إِسحاق: المقنع الرافع {28}، وأنشد للشمَّاخ:يُبَاكرْن العِضَاهَ بمُقْنَعاتٍ ... نَوَاجِذُهُنَّ كالحدأِ الوَقِيعِ {29}أراد بأفواه مرفوعات إلى العِضَاة، يصف إبلًا ترعى الشجرَ، شبَّه أنيابها بالفؤوس المحدُودة، والحِدأُ: الفؤوس بالكسر، وعند الكوفيين الحَدَأُ بالفتح جمع حَدَأة، فهما لغتان {30}، ونحو ما قال أهل اللغة قال المفسرون في الإقناع، قالوا: ﴿مُقْنِعِي رُءُوسِهِمْ﴾: رافعي رؤوسهم، وهو قول ابن عباس ومجاهد والضحاك وقتادة وابن زيد {31}، قال الحسن: وجوه الناس يوم القيامة إلى السماء لا ينظر أحد إلى أحد {32}.وقوله تعالى: ﴿لَا يَرْتَدُّ إِلَيْهِمْ طَرْفُهُمْ﴾ أي لا ترجع إليهم أبصارهم من شدة النظر؛ فهي شاخصة والطَرْفُ: تحريك الجفون في النظر، يقال: شخص بصره فما يَطْرِف {33}، والطرْفُ: اسم جامع للبصر لا يُثنَى ولا يُجمع {34}.وتأويل قوله: ﴿لَا يَرْتَدُّ إِلَيْهِمْ طَرْفُهُمْ﴾ أي: نظرهم إلى شيء واحد، فكأن ذلك الشيء الذي ينظرون إليه قد ذهب بنظرهم نحوه؛ فليسوا ينظرون إلى غيره، هذا معنى قولنا: لا يرجع إليهم نظرهم.وقوله تعالى: ﴿وَأَفْئِدَتُهُمْ هَوَاءٌ﴾ قال ابن عباس في رواية عطاء: يريد خرجت القلوب من مواضعها فصارت في الحناجر {35}، ونحو هذا قال قتادة: انتزعت حتى صارت في حناجرهم {36}، فعلى هذا، الأفئدة: أريد بها مواضع القلوب، وذهب قوم من أهل اللغة إلى الفرق بين القلب والفؤاد؛ فقال الليث: القلب مضغةٌ من الفؤاد معلَّقة بالنيَّاط {37}.وقال النبيّ ﷺ: ""أتاكم أهل اليمن هم أرقُّ قلوبًا وألينُ أفئدة"" {38}، فوصف القلوب بالرقّة والأفئدة باللين، وكأن القلب أخصُّ منا لفؤاد، ولذلك قالوا: أصبت حبة قلبه {39}، والهواء: ما بين السماء والأرض {40}، والعرب تسمّي كل خالٍ هواء {41}، يقولون: بيت هواء، إذا كان خاليًا قفْرًا لا شيء فيه، والمعنى في الآية: أن قلوبهم ارتفعت إلى حناجرهم من فزع ذلك اليوم وهوله، وبقي موضعها هواء لا شيء فيه كهواء ما بين السماء والأرض، ولهذا المعنى قالوا للجبان: مُجوَّفٌ هواء، أي أنه لا قلب له، ومنه قول حسان:فأنْتَ مُجوَّفٌ نَخِبٌ هَوَاءُ {42} وقال زهير يصف ناقة:كأنّ الرَّحْلَ منها فَوقَ صَعْلٍ ... من الظِّلْمَانِ جُؤْجُؤُهُ هَواءُ {43}أي لا قلب في صدره فهو خال، وذهب آخرون إلى أن معنى الآية: أن قلوبهم عما ذهلوا من الفزع خلت عن العقول، وهو معنى قول ابن عباس في رواية العوفي، وبه قال مجاهد، ومُرَّة، وابن زيد، واختاره الأخفش؛ فقال في قوله: ﴿وَأَفْئِدَتُهُمْ هَوَاءٌ﴾ أي جَوْفٌ لا عقول لها ولا خير فيها {44}، وعلى هذا القول، المراد بالأفئدة: القلوب، وهو الصحيح في اللغة {45}، قال الله تعالى: ﴿إِنَّ السَّمْعَ وَالْبَصَرَ وَالْفُؤَادَ كُلُّ أُولَئِكَ كَانَ عَنْهُ مَسْئُولًا﴾ [الإسراء: 36] يعني القلب، وقال امرؤ القيس:رَمَتْني بسَهْمٍ أصابَ الفُؤادَ ... غداةَ الرَّحِيل فلم أشهريعني أصاب قلبي، الأزهري: ولم أرهم يفرقون بينهما {46}، ويحتاج في هذا التفسير إلى تقدير المضاف، كأن المعنى: وأفئدتهم ذات هواء؛ أي خالية."
  14,44,"قوله تعالى: ﴿وَأَنْذِرِ النَّاسَ﴾ هذا عطف على قوله: ﴿وَلَا تَحْسَبَنَّ اللَّهَ غَافِلًا﴾ لأنه قد تمَّ وصف الكفار وحالهم عند البعث في القيامة، ثم عاد إلى خطاب النبيّ ﷺ وأمره بالإنذار فقال: ﴿وَأَنْذِرِ النَّاسَ﴾ قال ابن عباس: يعني أهل مكة {1}، قال: ولو أن أهل مكة اتبعوا النبي ﷺ ما اختلف عليه اثنان، قال: ويقال لو آمن الوليد بن المغيرة ما تخلَّف عن رسول الله ﷺ أحد.وقوله تعالى: ﴿يَوْمَ يَأْتِيهِمُ الْعَذَابُ﴾ (يوم) مفعول به، والعامل فيه أنذرهم؛ كما يقول: خوّفه العقاب وخوّفه الهلاك، ولا يكون على الظرف؛ لأنه لم يؤمر بالإنذار في ذلك اليوم {2}.وقوله تعالى: ﴿فَيَقُولُ﴾ عطف ﴿يَأْتِيهِمُ﴾؛ يعني: فيقولون في ذلك اليوم، ﴿الَّذِينَ ظَلَمُوا﴾ قال ابن عباس: يريد أشركوا {3}، ﴿رَبَّنَا أَخِّرْنَا إِلَى أَجَلٍ قَرِيبٍ﴾ استمْهَلوا مدةً يسيرة لكي يجيبوا الدعوة ويتبعوا الرسل، قال ابن عباس: يريدون الرجعة إلى الدنيا، وهذا معنى وليس بتفسير، وذلك أنهم لما استَمهَلوا للإجابة صار كأنهم قالوا: أرجعنا إلى الدنيا أيامًا؛ لأن الآخرة ليست بدار تكليف، وإنما كُلِّفوا الإجابة في دار [الدنيا فيجابون عن هذا الاستمهال، ويقال لهم: ﴿أَوَلَمْ يكُونُوا أَقْسَمْتُمْ مِنْ قبْلُ مَا لَكُمْ مِنْ] {4} زَوَالٍ﴾ قال مجاهد: أي من انتقال عن الدنيا إلى الآخرة {5}؛ أي لا تبعثون.قال ابن عباس: يريد حلفتم في الدنيا أنكم لا تبعثون {6}، وهو قوله: ﴿وَأَقْسَمُوا بِاللَّهِ جَهْدَ أَيْمَانِهِمْ لَا يَبْعَثُ اللَّهُ مَنْ يَمُوتُ﴾ [النحل: 38]."
  14,45,"قوله تعالى: ﴿وَسَكَنْتُمْ فِي مَسَاكِنِ الَّذِينَ ظَلَمُوا أَنْفُسَهُمْ﴾ قال المفسرون: يعني الأممَ الكافرة قبلهم؛ قومَ نوح وعاد وثمود، ظلموا أنفسهم بالكفر والمعصية {1}، وهذا احتجاج عليهم؛ يقول: كان ينبغي أن ينزجروا ويرتدعوا اعتبارًا بمساكنهم، بعد ما تبيّن لكم كيف فعلنا بهم، ﴿وَضَرَبْنَا لَكُمُ الْأَمْثَالَ﴾ قال ابن عباس: يريد الأمثال التي في القرآن {2}."
  14,46,"قوله تعالى: ﴿وَقَدْ مَكَرُوا مَكْرَهُمْ﴾ [يعني مكرهم بالنبيّ ﷺ وما همُّوا به من قتله أو نفيه {1}. ﴿وَعِنْدَ اللَّهِ مَكْرُهُمْ﴾ {2} أي قد عرف الله مكرهم، وهو عالم به لا يخفى عليه ما فعلوا، فهو يجازيهم عيه، وقال أبو علي: وعند الله جزاءُ مكرِهم فحذف المضافَ كما حُذف من قوله: ﴿تَرَى الظَّالِمِينَ مُشْفِقِينَ مِمَّا كَسَبُوا وَهُوَ وَاقِعٌ بِهِمْ﴾ [الشورى: 22] أي: جزاؤه.وقوله تعالى: ﴿وَإِنْ كَانَ مَكْرُهُمْ لِتَزُولَ مِنْهُ الْجِبَالُ﴾ (إن) هاهنا يعني بها: ما، واللام المكسورة بعدها يعني بها الجحد، ومن سبيلها نصبُ الفعل المستقبل، والنحويون يسمونها لام الجحود {3}، ومثله قوله: ﴿وَمَا كَانَ اللَّهُ لِيُطْلِعَكُم﴾، و ﴿مَا كَانَ اللَّهُ لِيَذَرَ﴾ [آل عمران: 179] والجبال هاهنا مَثلٌ لأمر النبيّ ﷺ وأمرِ دين الإسلام وأعلامِه ودلالتِه، على معنى أن ثبوته كثبوت الجبال الراسية؛ لأن أدته تعالى قد وعد نبيه ﷺ إظهار دينه على كل الأديان، ويدل على صحة هذا المعنى قوله بعدُ: ﴿فَلَا تَحْسَبَنَّ اللَّهَ مُخْلِفَ وَعْدِهِ رُسُلَهُ﴾ أي {4}: فقد وعدك الظهور عليهم والغلبة لهم ومعنى الآية: وما كان مكرهم ليزول منه ما هو مثلُ الجبال في امتناعه ممن أراد إزالته {5}، هذا الذي ذكرنا معنى قول الحسن: كان مكرُهم أوهنَ وأضعفَ من أن تزول منه الجبال {6}، قال: و (إن) هاهنا بمعنى (ما) {7}؛كقوله: ﴿لَاتَّخَذْنَاهُ مِنْ لَدُنَّا إِنْ كُنَّا فَاعِلِينَ﴾ {8} [الأنبياء: 17] وقول: ﴿فِيمَا إِنْ مَكَّنَّاكُمْ فِيهِ﴾ {9} [الأحقاف: 26]، وهو كثير، وهذا القول اختيار أبي إسحاق {10} وأبي بكر وأبي علي {11}.قال أبو علي: وقد استعمل لفظ الجبال في غير هذا، في تعظيم الشيء وتفخيمه {12}، قال ابن مُقبل:إذا مِتُّ عن ذِكرِ القوافي فَلَنْ تَرَى ... لها شَاعِرًا مِثلي أطَبَّ وأَشْعَرَاوأكثرَ بَيْتًا شَاعِرًا ضُرِبَتْ به ... بُطُون جِبَالِ الشِّعْرِ حتَّى تَيَسَّرا {13} فاستعار للشعر جبالاً؛ يريد امتناعه على من أراده. هذا الذي ذكرنا معنى قراءة العامة {14}، وقرأ الكسائي: (لَتزولُ) بفتح اللام الأولى وضم الثانية {15}، وعلى هذه القراءة معنى قوله: ﴿وَقَدْ مَكَرُوا مَكْرَهُمْ﴾ يعني الأمم الكافرة من قبل؛ وهم الذين ذُكروا في قوله: ﴿الَّذِينَ ظَلَمُوا أَنْفُسَهُمْ﴾ وهو معنى قول ابن عباس: يريد ما مكر نمرود بإبراهيم، يجوز أن يعني أيضًا مكر الكفار بالنبيّ ﷺ كما ذكرنا، ﴿وَإِنْ كَانَ مَكْرُهُمْ﴾ معنى (إنْ) على هذه القراءة المخففة من الثقيلة، قاله أبو علي {16}.وقال أبو بكر: (إنْ) مع اللام يعني بها هاهنا: (قد)؛ كما يقول العربي: إنْ كان عبد الله لَيزورنا، يريد: قد كان، واللام في: ﴿لِتَزُولَ﴾ لام الجواب، والمستقبل بعدها مرفوع، والمعنى قد كانت الجبال تزول من مكرهم على تعظيم أمر مكرهم؛ كقوله: ﴿وَمَكَرُوا مَكْرًا كُبَّارًا﴾ [نوح: 22].وقال أبو إسحاق: وإن كان مكرُهم يبلغ في الكيد إلى إزالة الجبال، فإن الله ينصرُ دينه {17}، فإن قيل هذه القراءة على ما ذكرتم يُوجب أن الجبال قد زالت بمكرهم وهل كان ذلك؟والجواب عن هذا من وجهين: أحدهما لأهل المعاني، والثاني للمفسرين؛ أما أهل المعاني فإنهم قالوا: هذا مبالغة في وصف مكرهم بالعظيم، وإن لم يكن جبلٌ قط زال لمكرهم، فهذا على مذهب العرب في المبالغة؛ يقول: وإن كان مكرُهم قد بلغ من كِبَرِه وعِظَمِه أن يُزيلَ ما هو مثل الجبال في الامتناع على من {18} أراد إزالتَه ثباتُها؛ كأنه قيل: لو أزال مكرُهم الجبال لما أزال أمرَ الإسلام.يدل على صحة ما ذكرنا قراءةُ جماعة من الصحابة: (وإن كاد مَكْرُهم لَتَزولُ) بالدال {19}، أي {20}: قد قاربت الجبال أن تَزولَ، وهذا معنى قول أبي إسحاق {21} وأبي بكر {22} وأبي علي {23}؛ قال أبو علي: ومثل هذا في تعظيم الأمر قول الشاعر:ألمْ تَرَ صَدْعًا في السَّمَاءِ مُبَيِّنًا ... على ابنِ لُبَيْنى الحارثِ بن هِشَامِ {24}وهذا ليس على أنه شوهد صدع في السماء، ولكنه مبالغة على معنى أن الأمر قد قرب من ذلك، ومثله كثير في الشعر، وذكر ابن قتيبة باب ما أفرطت الشعراء في وصفه، وأنشد أبياتًا كثيرة، ثم قال: وهذا كله علي المبالغة في الوصف، وينوون في جمعه {25}: يكافى يفعل {26}، وأنشد أبو إسحاق قول الأعشى:لئن كنتَ في جُبٍّ ثَمانينَ قامةً ... ورُقِّيتَ أسبابَ السماءِ بِسُلّملَيسْتَدرِكَنَّكَ القَوْلُ حتَّى تَهِرّهُ ... وتَعْلَمَ أني عنكم غيرُ مُنَجِّمِ {27} قال: فإنما بالغ في الوصف، وهو يعلم أنه لا يُرَقَّى {28} أسبابَ السماء {29}.وقال أبو بكر في قول الأعشى: تأويله لئن كنت فيما تَقْدِر ويُقَدَّر لك في قعر الأرض أو في السماء، لَيَصلنَّ إليك مني ما كره، لذلك معنى ﴿وَإِنْ كَانَ مَكْرُهُمْ لِتَزُولَ مِنْهُ الْجِبَالُ﴾: عند أنفسهم وفيما يقدّرون، فليس ينفعهم ذلك إذا كان الله قد وعد على ألسنة رسله ظهورَ الحق على الباطل.وأما المفسرون فإنهم ذهبوا إلى قصة نمرود مع التابوت والنسور، وأن الجبال حين سمعت حفيف النسور والتابوت عند هبوطها ظنت أن ذلك أمرٌ من الله تعالى عظيم، وأن الساعة قد قامت ففزعت وزالت، وهذا يُروى عن علي -رضي الله عنه- ومجاهد وعكرمة {30}.قال مجاهد: كان ذلك بختنصر {31}."
  14,47,"قوله تعالى: ﴿فَلَا تَحْسَبَنَّ اللَّهَ مُخْلِفَ وَعْدِهِ رُسُلَهُ﴾ قال الفراء: أُضيفت ﴿مُخْلِفَ﴾ إلى الوعد ونُصبت الرسلُ على التأويل؛ لأن الإخلاف قد يقع بالوعد كما يقع بالرسل، فيقول أخلفت الوعدَ وأخلفت الرسلَ {1}، وإذا كان الفعل يقع على شيئين مختلفين مثل: كَسَوْتك الثوبَ وأدخلتك الدار، فابدأ بإضافة الفعل إلى الرجل؛ تقول: هو كاسي عبد الله ثوبًا، ومدخله الدارَ، ويجوز: هو كاسي الثوبِ عبد الله، ومدخل الدارِ زيدًا؛ لأن الفعل قد يأخذ الدار كأخذه عبد الله فيقول: أدخلت الدار، وكسوت الثوب، ومثله قول الشاعر {2}: تَرَى الثورَ فيها مُدخِلَ الظِّلِّ رَأسَهُ ... وسَائِرُهُ بَادٍ إلى الشَّمْس أجْمَعُ {3}أي مدخل رأسه الظلَّ، فقلب وأضاف مُدخلَ إلى الظلِّ [لأن الظل] {4} التبس برأسه {5}، فصار كل واحد منهما داخلًا في صاحبه {6}، قال ابن عباس: ﴿فَلَا تَحْسَبَنَّ اللَّهَ﴾: يا محمد، ﴿مُخْلِفَ وَعْدِهِ رُسُلَهُ﴾ يريد النصر والفتح وإظهار الدين {7}، ﴿إِنَّ اللَّهَ عَزِيزٌ ذُو انْتِقَامٍ﴾ قال: يريد: أن الله منيع شديد الانتقام، ومعنى الانتقام الجزاء بما كان من السيئات."
  14,48,"قوله تعالى: ﴿يَوْمَ تُبَدَّلُ الْأَرْضُ﴾ الآية. ذكر الزجاج في نصب (يوم) وجهين؛ أحدهما: أنه صفة لقوله ﴿يَوْمَ يَقُومُ الْحِسَابُ﴾ {1}، والآخر: أنه على معنى ينتقم يوم تبدل {2}، وذكرنا في قوله: {بَدَّلْنَاهُمْ جُلُودًا} [النساء: 56] أن التبديل يقع على معنيين، أحدهما: تبديل العين إلى غيره، والثاني: تبديل الصورةِ والعين قائمة، وقد ذُكر المعنيان في هذه الآية، قال ابن عباس: الأرض هي تلك الأرض، وإنما تُبدل آكامُها وجبالها وأشجارها {3}، ثم أنشد {4}:فما الناسُ بالناسِ الذين عَهِدتُهُم ... ولا الدَّارُ بالدَّارِ التي كنت أعْرِفُ {5}ونحو هذا روى أبو هريرة عن النبيّ ﷺ قال: ""يبدل الله الأرض غير الأرض فيبسطها {6} ويمدُّها مدَّ الأديم العُكاظيِّ لا ترى فيها عوجًا ولا أمتًا"" {7}.وقال الحسن: هي هذه الأرض إلا أنها تُغيَّر إلى سورة أخرى {8}.وأما تبديل السموات فقال ابن عباس في رواية أبي صالح: وتبديل المموات بأن يزاد فيها وينقص منها {9}.وقال ابن الأنباري: باختلاف هيئتها؛ كما ذكر الله تعالى أنها مرة كالمهل {10}، وتكون كالدهان {11}، وعلى هذا القول معنى التبديلِ في الآية: وتبديلُ الصورةِ باختلاف الهيئةِ، والعينُ كما هي، كما تقول: قد بدلت قميصي جُبة؛ أن تقلبَ العينَ من حال إلى حال أخرى، وهو اختيار أبي إسحاق، قال: قد يقول: بَدَّل زيدٌ، إذا تغيرت حاله، فمعنى تبديل الأرض: تسيير جبالها وتفجير بحارها، وكونها مستوية لا ترى فيها عوجًا ولا أمتًا، وتبديل السموات: انتثار كواكبها وانفطارها، وتكوير شمسها وخسوف قمرها.قال: وقوله: ﴿وَالسَّمَاوَاتُ﴾ أي وتبدل السمواتُ غيرَ السموات {12}، ومثله قال أبو علي: قال وهو كقوله -ﷺ-: لا يُقتل مؤمنٌ بكافر ولا ذو عهد في عهده"" {13} {14}.المعنى: ولا ذو عهد في عهده بكافر، كما كان التقدير في الآية؛ والسموات غير السموات، وذهب قوم إلى تبديل العين، فقال ابن مسعود: تبدل بأرض كالفضة بيضاء نقية، لم يُسفك فيها دم ولم يعمل عليها خطيئة {15}، ونحو ذلك قال ابن عباس في رواية الكلبي وعطاء {16}.يؤكد هذا ما روى سَهْل بن سَعد عن رسول الله -ﷺ- قال: ""يُحْشرُ الناسُ يوم القيامة على أرض بيضاء عَفْراءَ كَقُرْصَةِ النَّقيّ ليس فيها معلم لأحد"" {17}.وقال علي -رضي الله عنه- في هذه الآية: الأرض من فضة والسماء من ذهب {18}، ومذهب أكثر المفسرين؛ عكرمة، ومجاهد، والقرظي، وكعب: على أن هذا التبديل هو تبديل العين {19}.وسألتْ عائشةُ رسولَ الله ﷺ عن هذه الآية وقالت: أين يكون الناس يومئذ؟ قال: ""على الصراط"" {20} قوله تعالى: ﴿وَبَرَزُوا لِلَّهِ الْوَاحِدِ الْقَهَّارِ﴾ أىِ ظهروا وخرجوا من قبورهم، وهو كقوله: ﴿وَبَرَزُوا لِلَّهِ جَمِيعًا﴾ [إبراهيم: 21] وقد مرّ."
  14,49,"قوله تعالى: ﴿وَتَرَى الْمُجْرِمِينَ﴾ قال ابن عباس: يريد الذين أجرموا، زعموا أن لله شريكًا وولدًا ونظيرًا {1}، ﴿يَوْمَئِذٍ﴾ يريد يوم القيامة، ﴿مُقَرَّنِينَ﴾ يقال: قرنت الشيء بالشيء، إذا شددته به ووصلته، والقَرْنُ اسم الحبل الذي شُدَّ به شيئان {2}، وجاء هاهنا على التكثير لكثرة أولئك القوم.وقوله تعالى: ﴿فِي الْأَصْفَادِ﴾ جمع صفْد وهو القيد، يقال: صَفَدْتُ الرجلَ فهو مَصْفُود، والمصدر: الصَّفْد، والاسم: الصَّفَد، ومثله الصِّفادُ: وهو كل ما يوثق به من نِسْع أو قِدِّ {3}، ويقال أيضًا من هذا صَفَّدته بالتشديد، ومنه الحديث: ""صُفِّدت الشَّياطين"" {4}.قال أبو عبيد: شُدَّت بالأغلال، قال عمرو:وأُبْنَا بالمُلُوكِ مُصَفَّدِينا {5} قال: وأما أصْفَدْتُه بالألف، فهو أن تعطيه وتصله، والاسم منه الصَّفَد، وكذلك الوَثاق {6}.وقال الزجاج: صَفَدتُه بالحديد وأصفدته، ومثله في العطية {7}، إلا أن الاختيار في العطية أصفدته، وفي الحديد صفدته {8}.قال ابن عباس: يريد بالأصفاد: سلاسلَ الحديد والأغلال {9}.قال الكلبي: ﴿مُقَرَّنِينَ﴾ كل كافر مع شيطان في غل {10}، وقال هطاء: وهو معنى قوله: ﴿وَإِذَا النُّفُوسُ زُوِّجَتْ﴾ [التكوير: 7] أي قُرنت نفوس المؤمنين بالحور العِين، ونفوس الكافرين بالشياطين {11}، وفي هذا المعنى أيضاً قوله: ﴿احْشُرُوا الَّذِينَ ظَلَمُوا وَأَزْوَاجَهُمْ﴾ [الصافات: 22].قال ابن عباس: وقرناؤهم من الشياطين {12}، وقال قوم في معنى: ﴿مُقَرَّنِينَ﴾: قُرن بعضهم ببعض {13}.وقال ابن زيد: قُرنت أيديهم وأرجلُهم إلى رقابهم بالأغلال {14}، فهذا {15} ثلاثة أقوال في معنى: ﴿مُقَرَّنِينَ﴾."
  14,50,"قوله تعالى: ﴿سَرَابِيلُهُمْ مِنْ قَطِرَانٍ﴾ السرابيل جمع سِرْبال وهو القُمُص، والفعل منه تسربلتُ، وسربلتُ غيري {1}.قال امرئ القيس:لَعُوبٌ تُنَسِّيني إذا قُمتُ سِرْبالي {2} وقال الزجاج: هو كل ما لُبِس {3}.والقطران: هناء الإبل.قال الليث: وهو شيء يَتَحلَّب من شجر يقال له: الأَبْهُل {4}.قال الفراء: أهلَ الحجاز وبنو أسد يفتحون القاف ويكسرون الطاء، وبعض قيس {5} وتميم {6} يقولون: قِطْران بكسر القاف وتسكين الطاء {7}، وأنشد:عَلَيْهم سَرَابِيلُ الحَدِيدِ كأنَّهم ... جِمَالٌ بها القَطرانُ مَطْلِيَّةٌ بُزُل {8} وفيه لغة أخرى وهو فتح القاف وتسكين الطاء {9}، وبه قرأ عيسى بن عمر. قال أبو إسحاق: وجُعلت سرابيلهم من قطران والله أعلم؛ لأن القطران يبالغ في اشتعال النار في الجلود، ولو أراد الله المبالغة في إحراقهم بغير نار وبغير قطران لقدر على ذلك، ولكنه عذَّب بما يَعقل العبادُ العذابَ من جهته، وحذّرهم ما يعرفون حقيقته {3}.قال ابن الأنباري: والنار لا تُبطل ذلك القطران ولا يُفنيها، كما لا يُهلك أغلالَها وأنكالَها وحَيّاتِها وهوامَها وأشجارَها {11}، وللقطران أيضًا روائح خبيئة، وقال غيره: وفيه أيضًا عقاب بالتسويد لسواد دخانه {12}."
  14,51,"قوله تعالى: ﴿لِيَجْزِيَ اللَّهُ كُلَّ نَفْسٍ مَا كَسَبَتْ﴾ هذه اللام تتعلق بقوله: ﴿وَتَغْشَى﴾ أي تغشى النار وجوههم ليقع لهم الجزاء من الله بما كسبوا، فمعنى ﴿كُلَّ نَفْسٍ﴾ هاهنا من الكفار؛ لأن جزاء المؤمن لا يقع بهذا {1}.وقوله تعالى: ﴿إِنَّ اللَّهَ سَرِيعُ الْحِسَابِ﴾ ذكرنا معناه في سورة البقرة عند تمام المائتين منها."
  14,52,"قوله تعالى: ﴿هَذَا بَلَاغٌ لِلنَّاسِ﴾ قال ابن عباس: يريد ما أنزلت إليك من قصة إبراهيم ودعائه لوالده وما تبرأ منه من عبادة الأصنام وما دعا للمؤمنين، وقال غيره من أهل العلم: ﴿هَذَا﴾: القرآن {1}، ﴿بَلَاغٌ لِلنَّاسِ﴾ والبلاغ اسم يقوم مقام التبليغ، قال أبو علي الجرجاني: تأويله: فعلنا هذا؛ يعني إنزال القرآن وما فيه من المواعظ لتبلِّغ الناس، وهذا عطف على البلاغ بالفعل، وهو قوله: ﴿وَلِيُنْذَرُوا بِهِ﴾ {2}، قال ابن عباس: ولتنذر يامحمد قومك {3}، ﴿وَلِيَعْلَمُوا أَنَّمَا هُوَ إِلَهٌ وَاحِدٌ﴾ أي بما ذكر فيه من الحجج التي تدل على وحدانيته، ﴿وَلِيَذَّكَّرَ أُولُو الْأَلْبَابِ﴾ قال يريد وليتعظ أهل اللب والعقل والبصائر."
