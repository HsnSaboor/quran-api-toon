tafsir[8]{c,v,t}:
  14,34,"قوله تعالى: ﴿وَآتَاكُمْ مِنْ كُلِّ مَا سَأَلْتُمُوهُ﴾ قال أبو علي: المفعول محذوف تقديره من كل مسؤول شيئًا أو مسؤولًا أو نحو ذلك، ومثله قوله: ﴿يُخْرِجْ لَنَا مِمَّا تُنْبِتُ الْأَرْضُ﴾ [البقرة: 61] أي: شيئًا، فحذف المفعول، وكذلك قوله: ﴿وَأُوتِينَا مِنْ كُلِّ شَيْءٍ﴾ [النمل: 16] قال: ويجوز في قياس قول أبي الحسن {1} أن يكون الجار والمجرور في موضع نصب، وتكون (من) زيادة في الإيجاب كما تكون زيادة في غير الإيجاب {2}، وقال ابن الأنباري: تقدير الآية: ﴿وَآتَاكُمْ مِنْ كُلِّ مَا سَأَلْتُمُوهُ﴾ وما لم تسألوه؛ لأنا لم نسأله شمسًا ولا قمرًا ولا كثيراً من نِعمه التي ابتدأنا بالإحسان إلينا بها، فاكتُفِي بالسؤال عن غير {3} المسؤول؛ كقوله: ﴿سَرَابِيلَ تَقِيكُمُ الْحَرَّ﴾ {4} [النحل: 81]، قال: ويجوز أن يكون المعنى: وآتاكم من كل ما تتمنُّون تشْتهون وتُؤثرون {5}، قال الكسائى: العرب تقول إذا أتيت فلانًا أعطاك سُؤلك، وصرت منه إلى ما سألت، لا يعنون السؤال بعينه، ولكنهم يريدون ما يشتهي وَيتمنّى وُيؤثر، هذا كلامه {6}، وأما مفعول الإيتاء فهو على ما ذكره أبو علي {7}.وقوله تعالى: ﴿وَإِنْ تَعُدُّوا نِعْمَتَ اللَّهِ لَا تُحْصُوهَا﴾ النعمة هاهنا اسم أقيم مقام المصدر يقال: أنعم الله عليه، يُنْعِم إنعامًا ونِعْمَةً، أقيم الاسم مُقَام الإنعام؛ كقولك: أنفقت عليه إنفاقًا ونفقةً، بمعنى واحد {8} ولذلك لم يجمع؛ لأنه في مذهب المصدر، ومعنى قوله: ﴿لَا تُحْصُوهَا﴾: لا يأتوا على جميعها بالعَدِّ لكثرتها، بيانه قوله: ﴿وَأَحْصَى كُلَّ شَيْءٍ عَدَدًا﴾ [الجن: 28] أي أحاط علمه باستيفاء عدد كل شيء.وقال الكلبي: لا تحفظوها {9}، وقال أبو العالية: لا تطيقون عدّها {10}، والقولان قد فُسّر بهما {11} قوله: ﴿عَلِمَ أَنْ لَنْ تُحْصُوهُ﴾ [المزمل: 20] قال الفراء: علم أن لن تحفظوا مواقيت الليل {12}، وقال غيره: معناه: علم أن لن تطيقوه {13}.وقوله تعالى: ﴿إِنَّ الْإِنْسَانَ لَظَلُومٌ كَفَّارٌ﴾ قال ابن عباس: يريد: أبا جهل ظلوم لنفسه كفّار بنعمة ربه {14}، وقال أبو إسحاق: هذا اسم للجنس، فقصد به الكافر خاصة؛ كما قال: {وَالْعَصْرِ (1) إِنَّ الْإِنْسَانَ لَفِي خُسْرٍ (2) إِلَّا الَّذِينَ آمَنُوا وَعَمِلُوا} فالإنسان غير المؤمن ظلوم كَفَّار {15}، قال المفسرون: ظلوم: كافرٌ شاكرٌ غيرَ من أنعم عليه، واضعٌ الشكر غير موضعه، ﴿كَفَّارٌ﴾: جحود لنعم الله {16}."
  14,35,"قوله تعالى: ﴿وَإِذْ قَالَ إِبْرَاهِيمُ رَبِّ اجْعَلْ هَذَا الْبَلَدَ آمِنًا﴾ تفسير هذا قد سبق في سورة البقرة {1}.وقوله تعالى: ﴿وَاجْنُبْنِي وَبَنِيَّ أَنْ نَعْبُدَ الْأَصْنَامَ﴾ قال الكفراء: أهل الحجاز تقول: جَنبَنِي يَجْنُبُنِي خفيفة، وأهل نجد تقول: أجْنبَنِي شرَّه وجَنَّبَنِي شرَّه {2}، ونحو هذا قال الكسائي {3}، وقال الزجاج: أجْنَبْتُه كذا وكذا: جعلته ناحية منه وجانبًا، وكذلك جَنَّبْتُه وجَنَبْتُه {4}، وأنشد أبو عبيدة لأُميّة بن الأَسْكَر:وتَنْفُضُ مَهْدَهُ شَفَقًا عَلَيْه ... وتَجْنُبُه قلائِصنا الصِّعَابَا {5} قال أبو إسحاق: ومعنى الدعاء من إبراهيم أن يُجَنَّبَ عبادة الأصنام، وهو غير عابد لها، على معنى: ثبِّتْنِي على اجتناب عبادتها؛ كما قال: ﴿وَاجْعَلْنَا مُسْلِمَيْنِ لَكَ﴾ [البقرة: 128]، أي: ثبِّتْنا على الإسلام {6}.وقال غيره من أهل المعاني قوله: ﴿وَبَنِيَّ﴾ دعاء لمن أذن الله في أن يدعو له؛ فكأنه قال: وبنيَّ الذين أذنت لي في الدعاء لهم؛ لأن دعاء الأنبياء مستجاب، وقد كان من نسله من عبد الصنم {7}، أو خص بهذه الدعوة أبناءه من صُلْبِه {8}.والصَّنم: الصورة التي تُعْبَد، وجمعه أصنام {9}."
  14,36,"قوله تعالى: ﴿رَبِّ إِنَّهُنَّ أَضْلَلْنَ كَثِيرًا مِنَ النَّاسِ﴾ قال أبو إسحاق وغيره: أي ضَلُّوا بسببها؛ لأن الأصنام لا تعقل ولا تفعل شيئًا؛ كما يقول: قد افْتَنَتْنِي هذه الدار؛ أي: أحْبَبْتُها واسْتَحْسَنْتُها وافْتُتِنْتُ بسببها {1}، فلما ضل الناس بسببها صارت كأنها أضلتهم، فنُسِب الفعل إليها.وقوله تعالى: ﴿فَمَنْ تَبِعَنِي﴾ قال ابن عباس: يريد على ديني بالتوحيد لك والمعرفة بك {2}.وقوله تعالى: ﴿فَإِنَّهُ مِنِّي﴾ قال ابن الأنباري: يريد من المُتديِّنين بميني المتمسِّكين بحبلي؛ كما قال {3}:إذا حاوَلْتَ في أسَدٍ فُجُورًا ... فإني لَسْتُ منكَ ولَسْتَ مِنّي {4}أراد: ولستَ من المتمسِّكين بِحَبْلي {5}.وقوله تعالى: ﴿وَمَنْ عَصَانِي فَإِنَّكَ غَفُورٌ رَحِيمٌ﴾ [قال السّدي: معناه ومن عصاني ثم تاب {6}، ﴿فَإِنَّكَ غَفُورٌ رَحِيمٌ﴾] {7} له إن تاب وإن آمن، لا أنه يقول: أن من كفر فإن الله يغفر له، وقال مقاتل: ومن عصاني فيما دون الشرك فإنك غفور رحيم {8}، وشرح أبو بكر هذا فقال: معناه: فمن عصاني فخالف في بعض الشرائع، وعقْدُ التوحيد معه فإنك غفور رحيم، إن شئت تغفر له غفرت إذ كان مسلمًا {9}، وذكر وجهين آخرين، أحدهمما. أن هذا كان قبل أن يُعلِّمه الله أنه لا يغفر {10} الشرك، كما استغفر لأبويه {11}، وهو يُقَدِّر أن ذلك غيرُ محظور، فلما عرف أنهما غير مغفور لهما تبرأ منهما {12}. والآخر: ومن عصاني بإقامته على الكفر فإنك غفور رحيم، يعني: أنك قادر على أن تغفر له وترحمه؛ بأن تنقله عن الكفر إلى الإسلام وتهديه إلى الصواب {13}."
  14,37,"قوله تعالى: ﴿رَبَّنَا إِنِّي أَسْكَنْتُ مِنْ ذُرِّيَّتِي﴾ قال الفراء: ولم يأت منهم بشىء {1} يقع عليه الفعل، وهو حائز أن يقول: قد أصبنا من بنى فلان، وقتلنا من بني فلان، وإن لم يقل رجالاً؛ لأن (من) تؤدّي عن بعض القوم؛ كقولك: قد أصبنا من الطعام وشربنا من الماء، ومثله: ﴿أَنْ أَفِيضُوا عَلَيْنَا مِنَ الْمَاءِ﴾ {2} [الأعراف: 50] قال أبو بكر: ويجوز أن يقال: إن (من) دخلت لتوكيد الكلام، والتقدير: ربنا إني أسكنت ذريتي {3} كما قال ذو الرُّمّة:تَبَسَّمْن عن نَوْرِ الأقَاحيِّ في الضُّحَى ... وفَتَّرْنَ من أبْصَارِ مضْرُوجةٍ نُجْلِ {4} وعلى ما ذكر الفراء (من) دخلت للتبعيض، والتأويل: إني أسكنت بعض ذريتي، وذلك أنه أنزل إسماعيل بعض ذرية إبراهيم، يدل على هذا قول ابن عباس في هذه الآية ﴿إِنِّي أَسْكَنْتُ مِنْ ذُرِّيَّتِي﴾ يريد: إسماعيل {5}، ﴿بِوَادٍ غَيْرِ ذِي زَرْعٍ﴾ قال: يريد وادي مكة، ومكة كلها واد، والكلام في الوادي قد ذكرنا عند قوله: ﴿فَسَالَتْ أَوْدِيَةٌ﴾ [الرعد: 17] والقول الأول: اختيار أبي علي، قال: معناه إني أسكنت من ذريتي ناسًا، فحذف المفعول لدلالة الإسكان عليه {6}.وقوله تعالى: ﴿عِنْدَ بَيْتِكَ الْمُحَرَّمِ﴾ قيل معناه: عند بيتك المحرم الذي كان قبل أن ترفعه من الأرض حتى رفعته أيام الطوفان؛ لأن إسكان الخليلِ إسماعيلَ مكة كان قبل بنائهما البيت، وقيل: عند بيتك المحرم الذي قد مضى في سابق علمك أنه يحدث في هذا الوادي {7}.وقوله تعالى: ﴿رَبَّنَا لِيُقِيمُوا الصَّلَاةَ﴾ قال ابن عباس: يريد ليعبدوك {8}.﴿فَاجْعَلْ أَفْئِدَةً مِنَ النَّاسِ تَهْوِي إِلَيْهِمْ﴾، أبو عبيد عن الأصمعي قال: هَوَى يَهْوِي هُوِيًّا، إذا سقط من عُلو إلى سفْل {9}، وقال ابن الأعرابي: هَوَت العُقابُ {10} نَهْوِي هَوِيُّا بالفتح، إذا انقضّت {11} على صيد أو غيره {12}، وقال الفراء في هذه الآية: ﴿تَهْوِي إِلَيْهِم﴾ تريدهم؛ كما تقول: رأيت فلانًا يَهْوِي نحوك {2}، معناه: تنحط إليهم وتنحدر وتنزل {14}، يقال هوى الحجر من رأس الجبل يهوي، إذا انحدر وانصب {15}، هذا قول أهل اللغة في هذا الحرف.فأما قول المفسرين؛ فقال ابن عباس في رواية عطاء: يريد تحِنّ {16} إليهم زيارة بيتك {17}، وفي هذا بيان أن حنين الناس إليهم إنما هو لحج البيت لا لأعيانهم، وفي هذا دعاء للمؤمنين بأن يرزقهم حج البيت، ودعاءٌ لسكان مكة {18} من ذريته؛ لأنهم يرتفقون {19} بمن يأتي مكة لزيارة البيت {20}، وقال قتادة في قوله: ﴿تَهْوِي إِلَيْهِم﴾: تنزع إليهم {21}، وقال أبو إسحاق: أي: اجعل أفئدة جماعة من الناس تنزع إليهم {22}، وهذا معنى قول مجاهد: لو قال: أفئدة الناس؛ لازدحمت عليه فارس والروم والترك والهند {23}، وقال سعيد بن جبير: لو قال: أفئدة الناس؛ لحجت إليه اليهود والنصارى والمجوس، ولكنه قال: ﴿أَفْئِدَةً مِنَ النَّاسِ﴾ فهم المسلمون {24}، وقال ابن عباس في قوله: ﴿أَفْئِدَةً مِنَ النَّاسِ﴾: يريد من المؤمنين من ذريته ومن غير ذريته.وقوله تعالى: ﴿وَارْزُقْهُمْ مِنَ الثَّمَرَاتِ﴾ ذكرنا تفسيره في سورة البقرة عند قوله: ﴿وَارْزُقْ أَهْلَهُ مِنَ الثَّمَرَاتِ﴾ [البقرة: 126].وقوله تعالى: ﴿لَعَلَّهُمْ يَشْكُرُونَ﴾ قال: يريد كي يوحدوك ويعظموك."
  14,39,"قوله تعالى: ﴿الْحَمْدُ لِلَّهِ الَّذِي وَهَبَ لِي عَلَى الْكِبَرِ إِسْمَاعِيلَ وَإِسْحَاقَ﴾ قال ابن عباس: وُلِدَ إسماعيلُ لإبراهيم وهو ابن تسع وتسعين سنة {1}، ووُلد له إسحاقُ وهو ابن مائة واثنتى {2} عشرة سنة {3}."
  14,40,"قوله تعالى: ﴿رَبِّ اجْعَلْنِي مُقِيمَ الصَّلَاةِ﴾ ذكره على النعت ولم يذكره على الفعل؛ لأن النعت ألزم وأكثر من الفعل، كأنه قال: رب اجعلني من عادتي إقامة الصلاة، ولو قال: اجعلني أقيم الصلاة، لم يكن فيه من المبالغة ما في المقيم، وذكرنا استقصاء هذا الفصل فيقوله: ﴿وَلَا تَجْعَلْ يَدَكَ مَغْلُولَةً إِلَى عُنُقِكَ﴾ الآية [الإسراء: 29].وقوله تعالى: ﴿وَمِنْ ذُرِّيَّتِي﴾ قال الزجاج: أي: واجعل من ذريتي من يقيم الصلاة {1}، وهذا كما ذكرنا في قوله: ﴿إِنِّي أَسْكَنْتُ مِنْ ذُرِّيَّتِي﴾، وقوله: ﴿وَآتَاكُمْ مِنْ كُلِّ مَا سَأَلْتُمُوهُ﴾.وقوله تعالى: ﴿رَبَّنَا وَتَقَبَّلْ دُعَاءِ﴾ قال ابن عباس: يريد عبادتي {2}، وهذا كقوله ﷺ: ""الدُّعاءُ مخُّ العبادة"" {3}."
  14,41,"قوله تعالى: ﴿رَبَّنَا اغْفِرْ لِي وَلِوَالِدَيَّ﴾ قال أبو إسحاق: كان هذا الدعاء من إبراهيم لوالديه قبل أن يتبين له أن أباه عَدُوُّ للهِ {1}، وقد ذكرنا ذلك في قوله: ﴿وَمَا كَانَ اسْتِغْفَارُ إِبْرَاهِيمَ لِأَبِيهِ إِلَّا عَنْ مَوْعِدَةٍ وَعَدَهَا إِيَّاهُ﴾ الآية. [التوبة: 114] ولعل الأمّ كانت مسلمة، يدل على ذلك أنه ذكر عذره في استغفاره لأبيه دون أُمِّه {2}، وقال ابن الأنباري: استغفر لأبويه وهما حيّان طمعًا في أن يُهْدَيا إلى الإسلام ويَسْعَدا بالدين {3}، وقال غيره: استغفر لهما بشرط الإيمان {4}، يدل عليه ما قال ابن عباس في هذه الآية: يريد: من لقيك مؤمنًا مصدقًا فتجاوز عنه {5}، وهو معنى قوله: ﴿وَلِلْمُؤْمِنِينَ﴾، وقيل: أراد بوالديه آدم وحواء {6}."
  14,42,"قوله تعالى: ﴿وَلَا تَحْسَبَنَّ اللَّهَ غَافِلًا عَمَّا يَعْمَلُ الظَّالِمُونَ﴾ قال ابن عباس: يريد المشركين أهل مكة {1}، وكان سفيان بن عيينة إذا قرأ هذه الآية قال: هذا تعزية للمظلوم، ووعيد للظالم {2}.وقوله تعالى: ﴿لِيَوْمٍ تَشْخَصُ فِيهِ الْأَبْصَارُ﴾ قال شمر: يقال: شخص الرجلُ بصرَه، [وشخص البصرُ نفسُه، إذا سما وطَمَح وشَصا {3}، كلُّ ذلك مِثْلُ الشُّخُوصِ {4}.وقال ابن السِّكِّيت: شَخَصَ بصرُهُ] {5}، إذا فتح عينيه لا يَطْرِفُ {6}.قال الفراء: أي لا يغتمض من هول ما يرى في ذلك اليوم {7}.وقال ابن عباس: يريد يوم القيامة تشخص فيه أبصار الخلائق إلى الهواء، يريد: أنهم لعجائب ما يرون، ولشدة الحَيْرةِ والدووة لا يغْتَمضون {8}."
