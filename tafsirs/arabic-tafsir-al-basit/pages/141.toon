tafsir[8]{c,v,t}:
  6,102,"قوله تعالى: ﴿ذَلِكُمُ اللَّهُ رَبُّكُمْ لَا إِلَهَ إِلَّا هُوَ خَالِقُ كُلِّ شَيْءٍ﴾ ارتفع ﴿خَالِقُ كُلِّ شَيْءٍ﴾ على أنه خبر ابتداء محذوف، كأنه قيل: هو خالق كل شيء؛ لأنه لما تقدم ذكره استغنى عن هو {1}.وقوله تعالى: ﴿فَاعْبُدُوهُ﴾ قال ابن عباس: (فأطيعوه) {2}، وقيل: وحدوه {3}.وقوله تعالى: ﴿وَهُوَ عَلَى كُلِّ شَيْءٍ وَكِيلٌ﴾ قد ذكرنا معنى الوكيل {4} في صفة الله تعالى، وقال بعض أصحاب المعاني: (إنما جاز وصف القديم بأنه وكيل فيما هو مالك، لأنه لما كانت منافع مملوكاته لغيره وجلّ عن أن تلحقه المنافع والمضار صحت هذه الصفة في هذه الجهة من حيث إن له أن يصرف ما هو مالك له، ثم التصريف فيما يدبره بمنزلة ما يدبره الوكيل فيما تعود منافعه على غيره، فهو على كل شيء وكيل بالحفظ له والتدبير) {5}."
  6,103,"قوله تعالى: ﴿لَا تُدْرِكُهُ الْأَبْصَارُ﴾ الآية. احتج نفاة الرؤية {1} بهذه الآية على أهل السنة {2} فقالوا: أخبر الله تعالى أن الأبصار لا تدركه، وإنما قال هذا على سبيل التمدح، وما نفى عن نفسه على سبيل التمدح به وجب أن يكون ذلك على التأييد كقوله: ﴿لَا شَرِيكَ لَهُ﴾ [الأنعام: 163]، و ﴿لَا تَأْخُذُهُ سِنَةٌ وَلَا نَوْمٌ﴾ [البقرة: 255] {3}.والجواب [عن] {4} هذا من وجوه:أحدها: أن الإدراك غير الرؤية لأنه يصح أن يقال: رآه وما أدركه، ويدل على هذا قوله تعالى إخباراً عن قوم موسى ﴿إِنَّا لَمُدْرَكُونَ (61) قَالَ كَلَّا﴾ [الشعراء:61 - 62] وكان قوم فرعون قد رأوا قوم موسى ولم يدركوهم، [و] {5} الدليل على ذلك قوله تعالى ﴿فَلَمَّا تَرَاءَى الْجَمْعَانِ﴾ [الشعراء: 61] أي: رأى أحدهما الآخر، وكان الله تعالى قد {6} وعد موسى أنهم لا يدركونه بقوله تعالى: ﴿لَا تَخَافُ دَرَكًا وَلَا تَخْشَى﴾ [طه: 77].وقولهم: ﴿إِنَّا لَمُدْرَكُونَ﴾ [الشعراء:61] يريدون أنهم قد قربوا من إدراكهم إياهم، ألا ترى أن موسى نفى ذلك بقوله: (كلّا)، وهذا مذهب جماعة من المفسرين {7} قالوا: [معنى] {8} الإدراك: الإحاطة بكنه الشيء وحقيقته، فالأبصار ترى الباري ولا تحيط به، كما أن القلوب تعرفه ولا تحيط به، قال الله تعالى: ﴿وَلَا يُحِيطُونَ بِهِ عِلْمًا﴾ [طه: 110] قال سعيد بن المسيب في تفسير قوله تعالى: ﴿لَا تُدْرِكُهُ الْأَبْصَارُ﴾: (لا تحيط به الأبصار) {9}.وقال ابن عباس في رواية عطاء: (كلت {10} أبصار المخلوقين عن الإحاطة به) {11}، وقال الزجاج: (معنى إدراك الشيء: الإحاطة بحقيقته، وقد ينظر الرجل إلى الشيء ولا يدركه)، ثم احتج على أن معنى الإدراك هاهنا الإحاطة بقوله تعالى: ﴿وَهُوَ يُدْرِكُ الْأَبْصَارَ﴾ [الأنعام: 103] فقال: (أعلم الله تعالى أنه يدرك الأبصار، وفي هذا الإعلام دليل أن خلقه لا يدركون الأبصار، أي ة لا [يعرفون] {12} [كيف] {13} حقيقة البصر، وما الشيء الذي صار به الإنسان يبصر من عينيه دون أن يبصر من غيرهما من سائر أعضائه، فأعلم جل وعز أن خلقاً من خلقه لا يدرك المخلوقون كنهه ولا يحيطون بعلمه، فكيف به جل وعز والأبصار لا تحيط به) {14}، قال أصحابنا فعلى هذا نقول: الباري يُرى ولا يُدرك؛ لأن معنى الإدراك هو: الإحاطة بالرؤية بالمرئي، وإنما يجوز ذلك على من كان محدوداً وله جهات، والقديم {15} الذي لا نهاية لوجوده يُرى ولكن لا يُدرك، وعلى هذا القول فاقد قلنا بظاهر الآية.الوجه الثاني: تخصيص الآية، وهو قول جماعة من المفسرين أيضاً، قال ابن عباس: ﴿لَا تُدْرِكُهُ الْأَبْصَارُ﴾ (ينقطع عنه في الدنيا) {16}، وقال مقاتل: (لا تراه الأبصار في الدنيا، وهو يُرى في الآخرة) {17}، وعلى هذا القول لا فرق بين الرؤية والإدراك، وهو مذهب شيخنا أبي الحسن {18}؛ لأنه لا يفرق بينهما، ويقول: (معنى الآية ﴿لَا تُدْرِكُهُ الْأَبْصَارُ﴾ في الدنيا، قال: والدليل على أن هذه الآية مخصوصة بالدنيا قوله تعالى: ﴿وُجُوهٌ يَوْمَئِذٍ نَاضِرَةٌ (22) إِلَى رَبِّهَا نَاظِرَةٌ﴾ [القيامة:22 - 23] وهذه الآية مطلقة، وقوله ﴿وُجُوهٌ يَوْمَئِذٍ﴾ [القيامة: 22] مقيد، والمطلق يحمل على المقيد، فلما كان قوله ﴿لَا تُدْرِكُهُ الْأَبْصَارُ﴾ يوجب نفي الرؤية، وقوله: ﴿إِلَى رَبِّهَا نَاظِرَةٌ﴾ [القيامة: 23] يوجب الرؤية، ولا يجوز التضاد، قلنا: الذي نفاه أراد به في الدنيا، والذي أثبته أراد به في الآخرة) {19}.الوجه الثالث: ما قاله السدي وهو أنه قال: (البصر بصران، بصر معاينة، وبصر علم) {20}، وكذا هو في اللغة، قال الليث: (البَصَر: العين، والبَصَر: نفاذ في القلب. قال: فمعنى قوله: ﴿لَا تُدْرِكُهُ الْأَبْصَارُ﴾ لا يدركه علم العلماء، ونظيره ﴿وَلَا يُحِيطُونَ بِهِ عِلْمًا﴾ [طه: 110] {21}، وهذا وجه حسن، وأما قولهم: إن هذا على سبيل التمدح، قلنا: ليس كذلك؛ لأنه ليس في أن يستحيل أن يرى استحقاق مدح، ألا ترى أن كثيراً من الأشياء الناقصة يستحيل أن يرى كالكفر والجهل، ثم لا يجب {22} لها بذلك صفة مدح، فليس بأن يستحيل أن يرى تمدح؟، وإنما معنى الآية: أنه منع الرائين من رؤيته في الدنيا ولا يقدر أحد على أن يمنعه من رؤيته له، فهذا وجه التمدح، وهو معنى الآية، وعلى هذا الوجه، قال ابن عباس في قوله ﴿وَهُوَ يُدْرِكُ الْأَبْصَارَ﴾ قال: (يرى ولا يُرى، ولا يخفى عليه شيء ولا يفوته) {23}. وإنما خص الأبصار بإدراكه إياها مع أنه يدرك كل شيء تحقيقاً للمعنى الذي ذكرنا؛ لأن غير الباري لا يجوز أن يرى البصر، ولا يراه البصر، وقد يرى غير البصر، ولا يراه البصر، فلا يبعد ذلك {24} وذكرنا قول الزجاج في معنى ﴿وَهُوَ يُدْرِكُ الْأَبْصَارَ﴾.وقوله تعالى: ﴿وَهُوَ اللَّطِيفُ الْخَبِيرُ﴾ قال الأزهري: (اللطيف من أسماء الله عز وجل [ومعناه] {25} الرفيق بعباده) {26}، وقال عمرو بن أبي {27} عمرو، عن أبيه {28}: (اللطيف الذي يوصل إليك أَرَبَك في رفق) {29}، وقال أبو العباس {30} عن ابن الأعرابي: ([يقال] {31}: لطف فلان لفلان يلطف: إذا رفق، لطفاً، ويقال: لطف الله لك، أي: أوصل إليك ما تحب برفق) {32}، وقال الليث: (اللَّطف: البِرُّ والكرامة، وأمٌّ لطيفةٌ بولدها، وفلان لَطيفٌ بهذا الأمر أي: رفيق) {33}، قال ابن عباس: ﴿وَهُوَ اللَّطِيفُ﴾ بأوليائه ﴿الْخَبِيرُ﴾ بهم) {34}."
  6,104,"قوله تعالى: ﴿قَدْ جَاءَكُمْ بَصَائِرُ مِنْ رَبِّكُمْ﴾ الآية. البصائر: جمع البصيرة، وهي الدلالة التي توجب إبصار النفوس للشيء، ومنه يقال للدم الذي يستدل به {1} على القتيل: بصيرة {2}؛ قال ابن عباس: (يريد: رشداً أو بياناً، وهدىً من ربكم) {3}، وقال الكلبي: (يعني: بينات القرآن) {4}، وقال الزجاج: (أي قد جاءكم القرآن الذي فيه البيان والبصائر) {5}.وقوله تعالى: ﴿فَمَنْ أَبْصَرَ فَلِنَفْسِهِ﴾ قال ابن عباس: (يريد: فمن اهتدى فلنفسه ﴿وَمَنْ عَمِيَ﴾ يريد: عن سبيل الهدى، فعليها) {6}، وقال الكلبي: (﴿فَمَنْ أَبْصَرَ﴾ صدّق بالقرآن، وآمن بمحمد ﷺ ﴿فَلِنَفْسِهِ﴾ عمل ﴿وَمَنْ عَمِيَ﴾ عن الحق فلم يصدّق، فعلى نفسه جنى العذاب) {7}، وقال الزجاج: (المعنى: فلنفسه نفع ذلك ﴿وَمَنْ عَمِيَ فَعَلَيْهَا﴾، أي: فعلى نفسه ضرر ذلك، لأن الله جل وعز غني عن خلقه) {8}.وقوله: ﴿وَمَا أَنَا عَلَيْكُمْ بِحَفِيظٍ﴾ قال عطاء عن ابن عباس: (يريد: ما أدفع عنكم ما يريد الله بكم) {9}، وقال الكلبي: (﴿وَمَا أَنَا عَلَيْكُمْ بِحَفِيظٍ﴾ [أي: برقيب أحصي عليكم أعمالكم {10}] أي: إنما أنا رسول أبلغكم عن ربي، وهو الحفيظ عليكم الذي لا يخفى عليه شيء من أفعالكم) {11}، ونحو هذا قال الحسن: (أي: برقيب على آعمالكم حتى أجازيكم بها) {12}، قال أبو إسحاق {5}: (أي: لست آخذكم بالإيمان أخذ الحفيظ عليكم، والوكيل، وهذا قبل الأمر بالقتال، فلما أُمر {14} بالقتال صار حفيظاً عليهم، ومسيطراً على كل من تولى)."
  6,105,"قوله تعالى: ﴿وَكَذَلِكَ نُصَرِّفُ الْآيَاتِ﴾، قال الزجاج: (موضع الكاف التي في أول (كذلك) نصب، المعنى: ونصرف الآيات مثل ما صرفناها فيما تلي عليكم) {1}، وقال غيره من النحويين {2}: (المعنى: نصرف الآيات في غير هذه السورة مثل التصريف في هذه السورة، فهو في موضع صفة المصدر، كأنه قيل: تصريفاً مثل هذا التصريف) {3}، وذكرنا معنى تصريف الآيات في هذه السورة قبل.وقال ابن عباس في هذه الآية: ((﴿وَكَذَلِكَ نُصَرِّفُ﴾ {4} نبيّن الآيات في القرآن في كل وجه ندعوهم بها ونخوّفهم) {5}.وقوله تعالى: ﴿وَلِيَقُولُوا دَرَسْتَ﴾ قال أبو بكر {6}: (دخلت الواو في ﴿وَلِيَقُولُوا﴾ عطفاً على مضمر، التقدير: وكذلك نصرف الآيات لنلزمهم الحجة ﴿وَلِيَقُولُوا﴾ فحذف المعطوف عليه لوضوح معناه) {7}.وأما (درست) {8}. فقال أبو زيد: (درسْت أدرس دِراسة وهي القراءة، وقال: وإنما يقال ذلك إذا قرأت على غيرك) {9}، وقال ابن الأعرابي: (درست الكتاب أدرسُه دَرْساً ودراسةً، أي: ذللته بكثرة القراءة) {10}. قال الأصمعي: (أصل درس الكتاب من قولهم: درس الطعام إذا داسه يدرسه دِراساً، والدِّراس الدِّياس بلغة أهل الشام. قال وأنشدني ابن ميادة {11}:يكفيك من بعض ازدياد الآفاق ... سَمْرَاءَ مما دَرَسَ ابن مِخْرَاقْ {12}أي: داس: يعني حنطةً سمراء، قال: ودرس السورة من هذا، أي: يدرسها، فيخف على لسانه) {13}، وقال أبو الهيثم: (درست الكتاب، أي: ذللته بكثرة القراءة حتى خَفّ حِفظه عليّ، من قولهم: دَرَسْتُ الثوبَ أدرُسه دَرْساً فهو مَدْرُوس وَدَرِيس، أي: أَخْلَقْتُه، ومنه قيل للثوب الخَلَق: دِريس، لأنه قد لان. وقال كعب بن زهير {14}: وفي الحِلْم إدْهان وفي العَفو دُرْسة ... وفي الصِّدق مَنْجاةُ من الشر فاصدْق {15}قال: الدُّرْسةُ: الرياضة، ومنه درست السورة حتى حفظتها) {16}، وهذا القول قريب مما قاله الأصمعي بل هو نفسه، لأن المعنى فيهما يعود إلى التذليل والتليين {17}.قال ابن عباس: ﴿وَلِيَقُولُوا﴾ (يعني: أهل مكة حين تقرأ عليهم القرآن ﴿دَرَسْتَ﴾ يقولون: تعلمت من يسار {18} [أبي فكيهة] {19} وجبر {20} مولى قريش، وقرأت علينا تزعم أنه من عند الله) {21}، وفي قول ابن عباس تعلّمت دليل على أن معنى ﴿دَرَسْتَ﴾ قرأت على غيرك. وأخبرنا سعيد بن {22} محمد -رحمه الله- أنبا ابن مقسم {23} العطار ببغداد عن أبي إسحاق {24} النحوي قال: (معناه: وليقولوا قرأت كتب أهل الكتاب) {1}، وقال الفراء: (يقولون: تعلمت من يهود) {26}، وأخبرني العروضي {27} عن الأزهري، قال: أخبرني المنذري {28} عن أبي العباس {29} في قول الله تعالى: ﴿وَلِيَقُولُوا دَرَسْتَ﴾ قال: (معناه وكذلك نبين لهم الآيات من هنا وهنا لكي يقولوا إنك دَرَسْت، أي: تعلمت، أي: هذا الذي جئت به [عُلِّمتَ] {30} {31}.وقرأ ابن كثير {32} وأبو عمرو (دَارسْت) وهو قراءة ابن عباس {33} ومجاهد {34}، وفسرها (قرأت على اليهود وقرؤوا عليك).وقال الزجاج {35} وأبو علي: (أي: دارست أهل الكتاب وذاكرتهم ويقوّي هذه القراءة قوله تعالى: ﴿إِنْ هَذَا إِلَّا إِفْكٌ افْتَرَاهُ وَأَعَانَهُ عَلَيْهِ قَوْمٌ آخَرُونَ﴾ [الفرقان: 4]، {36}، وقرأ ابن عامر: (دَرَسَتْ) أي: هذه الأخبار التي تلوتها علينا قديمة، قد درست وانمحت ومضت، من الدرس الذي هو تعفي الأثر وامحاء الرسم {37}.قال الأزهري: (من قرأ (دَرسَتْ) {38} فمعناه: تقادمت، أي: هذا الذي تتلوه علينا شيء قد تطاول ومرّ، من قولهم: درس الأثر يدرس درساً) {39}.فأما معنى اللام في قوله: ﴿وَلِيَقُولُوا دَرَسْتَ﴾ فقال أبو بكر: (وأما تصريف الآيات فليسعد بها قوم بفهمها والعمل بما فيها، ويشقى آخرون بالإعراض عنها، فمن يقول للنبي: ((دارست) أو (درست) فهو شقي، ومن يتبين الحق فيها ويعمل [بها] {40} سعيد) {41}، ويقوي هذا الذي قاله أبو بكر قوله تعالى: ﴿وَلِنُبَيِّنَهُ لِقَوْمٍ يَعْلَمُونَ﴾ [الأنعام: 105] قال ابن عباس: (يريد: أولياءه الذين هداهم إلى سبيل الرشاد) {42}، وقال أبو إسحاق: (إن السبب الذي أداهم إلى أن قالوا: (درست) هو تلاوة الآيات عليهم، وهذه اللام يسميها أهل اللغة: لام الصيرورة {43}، وهو كقوله عز وجل: ﴿فَالْتَقَطَهُ آلُ فِرْعَوْنَ لِيَكُونَ لَهُمْ عَدُوًّا وَحَزَنًا﴾ [القصص: 8] وهم لم يلتقطوه يطلبون بأخذه أن يعاديهم، ولكن كانت عاقبة الأمران صار ﴿لَهُمْ عَدُوًّا وَحَزَنًا﴾ كما [يقول] {44}: كتب فلان هذا الكتاب لحتفه، وهو لم يقصد بالكتاب أن يهلك نفسه، ولكن العاقبة كانت الهلاك) {45}، ومعنى هذا الكلام يعود إلى معنى قول أبي بكر، لأن المعنى: أن تصريف الآيات صار سبباً لمقالتهم هذه، وذلك للشقاوة التي لحقتهم وقضيت عليهم، وهذا يدل على أن الله تعالى جعل تصريف الآيات سبباً لضلالة قوم وشقوتهم بما قضى عليهم في الأزل من الضلالة، وهذا كقوله تعالى: ﴿وَأَمَّا الَّذِينَ فِي قُلُوبِهِمْ مَرَضٌ فَزَادَتْهُمْ رِجْسًا إِلَى رِجْسِهِمْ﴾ [التوبة: 125] {46}."
  6,107,"قوله تعالى: ﴿وَلَوْ شَاءَ اللَّهُ مَا أَشْرَكُوا﴾، قال الزجاج: (أي: لو شاء لجعلهم مؤمنين) {1}، وهذا نص صريح في أن شركهم كان بمشيئة الله تعالى {2}.وقوله تعالى: ﴿وَمَا جَعَلْنَاكَ عَلَيْهِمْ حَفِيظًا﴾ قال عطاء عن ابن عباس: (يريد: تمنعهم {3} مني) {4}، ومعنى هذا الكلام أنك لم تُبعث لتحفظ المشركين عن العذاب، إنما بُعثت مبلغاً فلا تهتم لشركهم، فإن ذلك بمشية الله {5}. وقال مقاتل: (﴿وَمَا جَعَلْنَاكَ عَلَيْهِمْ حَفِيظًا﴾ رقيباً إن لم يوحدوا، ومما أنت عليهم بمسيطر، نسختها آية السيف) {6}."
  6,108,"قوله تعالى: ﴿وَلَا تَسُبُّوا الَّذِينَ يَدْعُونَ مِنْ دُونِ اللَّهِ﴾ الآية قال [قتادة] {1} {2} والمفسرون {3}: (كان المسلمون يسبون أصنام الكفار فنهاهم عن ذلك لئلا يسبوا الله).وقال الزجاج: (نهوا في ذلك الوقت قبل القتال أن يلعنوا الأصنام التي كانت يعبدها المشركون) {4}.وقال أبو بكر {5} بن الأنباري: (هذه آية منسوخة أنزلها الله [عز وجل] {6} والنبي بمكة، فلما قواه بأصحابه نسخ هذه الآية ونظائرها بقوله: ﴿فَاقْتُلُوا {7} الْمُشْرِكِينَ حَيْثُ وَجَدْتُمُوهُمْ﴾ [التوبة: 5] {8}.وقوله تعالى: ﴿فَيَسُبُّوا اللَّهَ عَدْوًا بِغَيْرِ عِلْمٍ﴾ أي: فيسبوا الله ظلمًا بالجهل، يقال: عَدَا {9} فلان عَدْوًا وعُدُوًا وعُدْوانًا وعَدَاء، أي: ظلم ظلمًا جاوز القدر {10}.قال السدي: (معناه: لا تسبوا الأصنام فيسبوا من أمركم بما أنتم عليه من عيبها) {11}.وقال آخرون: (معنى ﴿فَيَسُبُّوا اللَّهَ عَدْوًا بِغَيْرِ عِلْمٍ﴾ فيحملهم الغيظ والجهل على أن يسبوا من تعبدون، كما سببتم من تعبدون) {12}. هذا معنى ﴿فَيَسُبُّوا اللَّهَ﴾ لا أنهم كانوا يصرحون بسب الله لأنهم كانوا يقرون أن الله خالقهم وإن أشركوا به.قال الزجاج: (وعدوا) منصوب على المصدر؛ لأن المعنى: فيعدوا عدوًا {13}، قال: ويكون بإرادة اللام {14} والمعنى: فيسبوا الله للظلم) {15}.وقوله تعالى: ﴿كَذَلِكَ زَيَّنَّا لِكُلِّ أُمَّةٍ عَمَلَهُمْ﴾ قال المفسرون {16}. (يعني: كما زينا لهؤلاء المشركين عبادة الأصنام والأوثان وطاعة الشيطان بالحرمان والخِذلان ﴿كَذَلِكَ زَيَّنَّا لِكُلِّ أُمَّةٍ عَمَلَهُمْ﴾ من الخير والشر والطاعة والمعصية)، قال ابن عباس في رواية عطاء: (يريد: زينت لأوليائي وأهل طاعتي محبتي وعبادتي، وزينت لأعدائي وأهل معصيتي كفر نعمتي وخذلتهم حتى أشركوا) {17}، قال الزجاج: (وهذا هو القول، لأنه بمنزلة {18}: ﴿وَطَبَعَ اللَّهُ عَلَى قُلُوبِهِمْ﴾ [التوبة: 93]، والدليل على هذا قوله تعالى: ﴿أَفَمَنْ زُيِّنَ لَهُ سُوءُ عَمَلِهِ فَرَآهُ حَسَنًا فَإِنَّ اللَّهَ يُضِلُّ مَنْ يَشَاءُ وَيَهْدِي مَنْ يَشَاءُ﴾ [فاطر: 8] {19}.وهذه الآية بتفسير هؤلاء دليل على تكذيب القدرية {20} حيث قالوا: لا يحسن من الله خلق الكفر وتزيينه {21}."
  6,109,"[قوله تعالى] {1}: ﴿وَأَقْسَمُوا بِاللَّهِ جَهْدَ أَيْمَانِهِمْ﴾ الآية، ذكرنا معنى القسم {2} عند قوله تعالى: ﴿وَإِذَا حَضَرَ الْقِسْمَةَ﴾ [النساء: 8] والاستقسام في سورة المائدة {3} والإقسام من ذلك الأصل أيضًا، وذلك أن اليمين موضوعة لتوكيد الخبر الذي يخبر به الإنسان إما مثبتًا للشيء أو نافيًا. ولما كان الخبر يدخله الصدق والكذب لم يأمن المخبر بالشيء عن نفسه أن يرد خبره ولا يقبل، فأكّد خبره باليمين، ولما كان التنازع يكثر في الإقسام، والدعاوى في الأشياء لا تنقطع إلا بالتوكيد، اشتقوا لفظه من القسم، وبنوها على أَفَعَل، فقالوا: أَقْسَم {4} فلان بالله، يقسم إقسامًا، وأرادوا أنه حاز القسم الذي وقع التنازع فيه، بذكر الله، وبنوا الفعل على أفعل؛ لأنهم قصدوا قصد رجل أمال الشيء إلى جانبه باليمين، واسم اليمين القَسَم، والجمع الأقسام.وهذا الذي ذكرنا في معنى القسم مذهب الزجاج وأبي علي الفسوي {5} وغيرهما ممن يوثق بعربيتهم، قال المفسرون: (8) (لما أُنزل قوله تعالى: ﴿إِنْ نَشَأْ نُنَزِّلْ عَلَيْهِمْ مِنَ السَّمَاءِ آيَةً فَظَلَّتْ أَعْنَاقُهُمْ لَهَا خَاضِعِينَ﴾ [الشعراء: 4] أقسم المشركون بالله ﴿لَئِنْ جَاءَتْهُمْ آيَةٌ لَيُؤْمِنُنَّ بِهَا﴾ وسأل المسلمون رسول الله ﷺ أن ينزلها الله عليهم حتى يؤمنوا، وعلم الله تعالى منهم أنهم لا يؤمنون، فأنزل هذه الآية: ﴿وَأَقْسَمُوا بِاللَّهِ جَهْدَ أَيْمَانِهِمْ﴾ {6}، قال الكلبي {7} ومقاتل {8}: (إذا حلف الرجل بالله فهو جهد يمينه)، وقال الزجاج: (اجتهدوا في المبالغة في اليمين) {9}، وقال عطاء {10}: (يريد. بأغلظ الأيمان).وقوله تعالى: ﴿قُلْ إِنَّمَا الْآيَاتُ عِنْدَ اللَّهِ﴾ أي: إنه هو القادر على الإتيان بها {11}، وقيل: (معناه: إنها عند الله يأتي بها متى شاء، وليس لكم أن تتحكموا في طلبها) {12}.وقوله تعالى: ﴿وَمَا يُشْعِرُكُمْ﴾ قال أبو علي: (ما) استفهام وفاعل ﴿يُشْعِرُكُمْ﴾ ضمير ما، والمعنى: وما يدريكم إيمانهم، فحذف المفعول، وحذف المفعول كثير، والتقدير: وما يدريكم إيمانهم، أي: هم لا يؤمنون مع مجيء الآية إياهم {13}.ونحو هذا ذكره ابن الأنباري {14} فقال: (كأن الكلام انقطع عند ﴿يُشْعِرُكُمْ﴾ بتقدير مفعول معه يراد به، أي شيء يشعركم إيمانهم، ويوقع في أنفسكم صحة ما حلف عليه الكفار)، وهذا معنى قول الزجاج: (أي لستم تعلمون الغيب، ولا تدرون أنهم يؤمنون) {15}، ألا ترى أنه ذكر مفعول الإشعار، وقال مجاهد: (وما يدريكم [أنكم] {16} تؤمنون، ثم استقبل يخبر فقال: ﴿أَنَّهَا إِذَا جَاءَتْ لَا يُؤْمِنُونَ﴾) {17}.وقوله تعالى: ﴿أَنَّهَا إِذَا جَاءَتْ لَا يُؤْمِنُونَ﴾ قرأ ابن كثير {18} وأبو عمرو (إنها) بكسر الهمزة على الاستئناف، وهي القراءة الجيدة. قال سيبويه: (سألت الخليل عن هذه القراءة، فقلت: ما منع أن تكون كقولك: ما يدريك أنه لا يفعل؟ فقال: لا يحسن ذلك في هذا الموضع إنما قال: ﴿وَمَا يُشْعِرُكُمْ﴾ ثم ابتدأ فأوجب فقال: (إنها إذا جاءت لا يؤمنون) ولو قال: (وما يشعركم أنها) بالفتح كان ذلك عذرًا لهم {19}، انتهى كلامه.ومعنى قوله: (كان [ذلك] {20} عذرًا لهم) أنك لو فتحت أن وجعلتها التي في نحو: بلغني أن زيدًا {21} منطلق، لكان عذرًا لمن أخبر عنهم أنهم لا يؤمنون، لأنه إذا قال القائل: إن زيداً لا يؤمن، فقلت: وما يدريك أنه لا يؤمن، كانت المعنى: انه يؤمن، وإذا كان كذلك كان عذرًا لمن نفى الإيمان عنه، وليس المراد في الآية عذرهم وأنهم يؤمنون {22}، ألا ترى أن الله سبحانه قد أعلمنا في الآية الثانية أنهم لا يؤمنون بقوله تعالى: ﴿وَلَوْ أَنَّنَا نَزَّلْنَا﴾ إلى قوله: ﴿مَا كَانُوا لِيُؤْمِنُوا إِلَّا أَنْ يَشَاءَ اللَّهُ﴾ [الأنعام: 111] وقرأ الباقون (أنها) بالفتح.قال الخليل: (هي بمنزلة قول العرب: أئت السوق أنك تشتري لنا شيئًا، أي: [لعلك] {23} فكأنه قال: لعلها إذا جاءت لا يؤمنون) {19}، انتهى كلامه. وأن بمعنى {25} لعل كثير في كلامهم كقوله {26}: أرِيني جَوَادًا مَاتَ هَزْلًا لأَنَّنِي ... أَرَى مَا تَرَيْنَ أَوْ بَخِيلًا مُخَلَّداوقال آخر {27}:هَل أَنْتُمْ عَائِجُونَ بِنَا لأنا ... نَرَى العَرَصاتِ أَوْ أَثَرَ الخيامِوقال عدي {28} بن زيد:أَعاذِل ما يُدْرِيكِ أَنَّ مَنِيَّتِي ... إلى ساعَةٍ في اليَومِ أو في ضُحى الغَدِ {29} وفسر علي: لعل منيتي، ويدل على صحة هذا وجودته في المعنى أنه قد جاء في التنزيل لعل بهذا {30} العلم كقوله تعالى: ﴿وَمَا يُدْرِيكَ لَعَلَّهُ يَزَّكَّى﴾ [عبس: 3] ﴿وَمَا يُدْرِيكَ لَعَلَّ السَّاعَةَ قَرِيبٌ﴾ [الشورى: 17]، وهذا الذي ذكره الخليل من أن {31} بمعنى لعل مذهب الفراء أيضًا قال: (وللعرب لغة في لعل بأن، وهو وجه جيد أن تجعل أن في موضع لعل) {32}، ثم ذكر وجهًا آخر لهذه القراءة: (وهو أن تجعل لا صلة قال: ومثله: ﴿مَا مَنَعَكَ أَلَّا تَسْجُدَ﴾ [الأعراف: 12] معناه: أن تسجد، فيكون التقدير: وما يشعركم أنها إذا جاءت يؤمنون) {33}، والمعنى على هذا: أنها لو جاءت لم يؤمنوا {34}.قال الزجاج: (والذي ذكر أن لا لغوٌ {35} غالط؛ لأن ما كان لغوًا لا يكون غير لغو، ومن قرأ (إنها) بالكسرة لم يكن لا لغوًا، فليس يجوز أن يكون معنى لفظه مرة النفي ومرة الإيجاب) {36}.قال أبو علي: (يجوز أن يكون لا في تأويل زائدة، وفي تأويل غير زائدة، كقول الشاعر {37}:أَبَى جُوده لا البُخْلَ واستَعْجَلَتْ بِهِ ... نَعَمْ مِنَ فَتًى لا يَمْنَعُ الجُودَ قاتِلهْينشد: لا البخلِ ولا البخلَ، فمن نصب البخلَ جعلها زائدة كأنه قال: أبي جوده البخل، ومن قال: لا البخلِ أضاف لا إلى البخل. ومثل هذه الآية في أن لا فيها يجوز أن يكون زائدة ويجوز أن لا يكون قوله تعالى: ﴿وَحَرَامٌ عَلَى قَرْيَةٍ أَهْلَكْنَاهَا أَنَّهُمْ لَا يَرْجِعُونَ﴾ [الأنبياء: 95]، {38}، وسنذكر الوجهين في الآية إذا انتهينا إليها إن شاء الله {39}.واختلفوا في قوله ﴿لَا يُؤْمِنُونَ﴾ فقرأ {40} بعضهم بالياء، وهو وجه القراءة؛ لأن قوله: [و] {41} أَقْسَمُوا بالله) الآية [الأنعام: 109] إنما يراد به قوم مخصوصون يدلك على ذلك قوله تعالى: ﴿وَلَوْ أَنَّنَا نَزَّلْنَا إِلَيْهِمُ الْمَلَائِكَةَ﴾ الآية [الأنعام: 111] وليس كل الناس بهذا الوصف، [و] {41} المعني: وما يشعركم أيها المؤمنون لعلهم إذا جاءتهم الآية التي اقترحوا لم يؤمنوا، فالوجه الياء؛ لأن الذين نفى عنهم الإيمان هم الغُيّب المقسمون، أي: لا يؤمنون هؤلاء الغيب المقسمون، وقرأ حمزة وابن عامر بالتاء، وهو على الانصراف من الغيبة إلى الخطاب، والمراد بالمخاطبين في (يؤمنون) هم الغُيّب المقسمون الذين أخبر عنهم أنهم لا يؤمنون {43}.وذهب مجاهد وابن زيد {44} إلى أن الخطاب في قوله ﴿وَمَا يُشْعِرُكُمْ﴾ للكفار الذين أقسموا، قال مجاهد: (وما يدريكم أنكم تؤمنون إذا جاءت) {45}، وهذا يقوي [قراءة] {46} من قرأ (تؤمنون) بالتاء، على ما ذكرنا أولاً الخطاب في قوله ﴿وَمَا يُشْعِرُكُمْ﴾ للمؤمنين، وذلك أنهم تمنوا نزول الآية ليؤمن المشركون، وهو الوجه؛ لأنه قيل للمؤمنين: تمنون ذلك، وما يدريكم أنهم يؤمنون، على ما شرحنا وبينا {47}."
  6,110,"قوله تعالى ﴿وَنُقَلِّبُ أَفْئِدَتَهُمْ وَأَبْصَارَهُمْ﴾ قال المفسرون {1}: (نحول بينهم وبين الإيمان لو جاءتهم تلك الآية فلا يؤمنون، حُلنا بينهم وبين الإيمان أول مرة). قال ابن عباس في رواية عطاء: (﴿وَنُقَلِّبُ أَفْئِدَتَهُمْ وَأَبْصَارَهُمْ﴾ حتى يرجعوا إلى ما سبق عليهم من علمي، قال: وهذا كقوله تعالى: ﴿وَاعْلَمُوا أَنَّ اللَّهَ يَحُولُ بَيْنَ الْمَرْءِ وَقَلْبِهِ﴾ [الأنفال: 24] قال: يريد: يحول بين المؤمن وبين أن يكفر به وبين الكافر وبين أن يؤمن به) {2}، والتقليب {3} والقلب واحد وهو تحويلك {4} الشىء عن وجهه، ومعنى تقليب [الأفئدة والأبصار] {5} هاهنا، هو أن الواجب من مقتضى الآية أن يؤمنوا إذا جاءتهم الآية فعرفوها بقلوبهم ورأوها بأبصارهم، فإذا لم يؤمنوا كان ذلك بتقليب الله تعالى قلوبهم وأبصارهم عن وجهها الذي يجب أن يكون عليه، وهو معنى ما قاله المفسرون: (نحول بينهم وبين {6} الإيمان لو جاءتهم الآية) {7}.وقد أخبرنا أبو إبراهيم إسماعيل {8} بن أبي القاسم الصوفي -رحمه الله-[أنبا] {9} أبو عمرو محمَّد بن {10} جعفر بن مطر أنبا إبراهيم {11} بن شريك نبا شهاب {12} نبا حماد {13} عن أيوب {14} وهشام {15} ومعلى {16} بن زياد عن الحسن قال: (قالت عائشة رضي الله عنها: دعوة كان رسول الله ﷺ يكثر أن يدعو بها: ""يا مقلب القلوب ثبت قلبي على دينك"" فقلت: يا رسول الله، دعوة كثيراً ما تدعو بها؟ قال: ""إنه ليس من عبد إلا وقلبه بين إصبعين من أصابع الله، فإذا شاء أن يقيمه أقامه، [وإذا] {17} شاء أن يزيغه أزاغه"" {18}.وقوله تعالى: ﴿كَمَا لَمْ يُؤْمِنُوا﴾ دخلت الكاف على محذوف تقديره: فلا يؤمنون ﴿كَمَا لَمْ يُؤْمِنُوا بِهِ أَوَّلَ مَرَّةٍ﴾ يعني: أول مرة أتتهم الآيات، مثل انشقاق القمر، وغيره من الآيات، والتقدير: فلا يؤمنون ثاني مرة بما طلبوا من الآيات؛ كما لم يؤمنوا أول مرة، وهذا معنى قول ابن زيد {19} ومجاهد {20} والكلبي {21}.والكناية في (به) يجوز أن تعود على القرآن، وعلى محمد، ويجوز أن تعود على ما طلبوا من الآيات {22} وقال بعضهم: معنى الكاف في قوله ﴿كَمَا لَمْ يُؤْمِنُوا﴾ معنى الجزاء {23}، ومعنى الآية: ونقلب أفئدتهم وأبصارهم عقوبة لهم على تركهم الإيمان في المرة الأولى، يعني: كما لم يؤمنوا أول مرة، فكذلك نقلب أفئدتهم وأبصارهم في المرة الثانية، وعلى هذا لا محذوف في الآية، وهو معنى قول ابن عباس {24} والعوفي {25} وهذه الآية حجة على القدرية الذين يكذبون بقضاء الكفر {26}.وقوله تعالى: ﴿وَنَذَرُهُمْ فِي طُغْيَانِهِمْ يَعْمَهُونَ﴾ قال عطاء، عن ابن عباس: (يريد: أخذلهم وأدعهم في ضلالتهم يتمادون) {27}."
