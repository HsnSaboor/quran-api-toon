tafsir[5]{c,v,t}:
  9,32,"وقوله تعالى: ﴿يُرِيدُونَ أَنْ يُطْفِئُوا نُورَ اللَّهِ بِأَفْوَاهِهِمْ﴾، قال ابن عباس: ""يريدون أن يخمدوا دين الله بتكذيبهم"" {1}، فمعنى نور الله في قول أكثرهم: الإسلام {2}، يعني أنهم يكذبون به، ولعرضون عنه، يريدون إبطاله بذلك.وقال الكلبي: ""يردون {3} القرآن بألسنتهم تكذيبًا له"" {4}، وقوله تعالى: ﴿وَيَأْبَى اللَّهُ إِلَّا أَنْ يُتِمَّ نُورَهُ﴾.قال الفراء: ""لم يجىء عن العرب حرف على (فعل) (يفعل) مفتوح العين في الماضي والغابر إلا وثانيه أو ثالثه أحد حروف الحلق، غير أبى يأبى، جاء نادرًا"" {5}، ويقال: رجل أبيٌّ، وأبيان {6}، وأباء: ذو إباء شديد، وأخذه إباء {7}: إذا كان يأبى الطعام فلا يشتهيه.وقوله تعالى: ﴿إِلَّا أَنْ يُتِمَّ نُورَهُ﴾، قال ابن عباس: ""إلا أن يظهر دينه"" {8}.قال الفراء: ""دخلت (إلا) لأن في (أبيت) طرفًا من الجحد، ألا ترى أن (أبيت) كقولك: لم أفعل {9}، ولا أفعل، ولولا ذلك لم يجز دخول (إلا) كما إنك لا تقول: ضربت إلا أخاك، ولا ذهب إلا أخوك، [دون أن تقول: ضربت القوم، وذهب القوم] {10} وأنشد:فهل {11} لي أم غيرها إن تركتها ... أبى الله إلا أن أكون لها ابنما {12} {13} وقال الزجاج: ""دخلت (إلا) ولا جحد في الكلام، وأنت لا تقول: ضربت إلا زيدا؛ لأن الكلام غير دال على المحذوف، وإذا قلت: ﴿وَيَأْبَى اللَّهُ إِلَّا أَنْ يُتِمَّ نُورَهُ﴾ فالمعنى: ويأبى الله كل شيء إلا إتمام نوره، والحذف مستعمل مع الإباء"" {14}، وأنكر قول الفراء فقال: ""لو جاز ما قال على أن فيه طرفًا من الجحد لجاز: كرهت إلا أخاك، ولا دليل ههنا على المكروه ما هو؟ ولا من هو؟ فـ (كرهت) مثل (أبيت) [إلا أن أبيت] {15} الحذف مستعمل معها {16} "" {17}."
  9,33,"قوله تعالى: ﴿هُوَ الَّذِي أَرْسَلَ رَسُولَهُ﴾، قال ابن عباس: ""يريد: محمدًا ﷺ {1} ﴿بِالْهُدَى﴾ قال: بالقرآن {2}، وقيل: بالبيان الذي يؤدي إلى نعيم الثواب في الجنة"" {3}، ﴿وَدِينِ الْحَقِّ﴾، قال ابن عباس: ""يريد الحنيفية"" {4}، ﴿لِيُظْهِرَهُ عَلَى الدِّينِ كُلِّهِ﴾ [قال ابن عباس: ""ليظهر الرسول على الدين كله"" {5}] {6} يعني {7}: ليعلمه شرائع الدين كلها فيظهر عليها حتى لا يخفى عليه منها شيء.وقال في رواية عطاء: ""ليعليه على جميع الأديان"" {8}، وعلى هذا اختلفوا: فقال أبو هريرة والضحاك: ""ذلك عند خروج عيسى"" {9}.وقال السدي: ""ذلك عند خروج المهدي لا يبقى أحد إلا دخل في دين الإسلام، أو أدى الخراج"" {10}، وقال الكلبي: ""لا تقوم الساعة حتى يكون ذلك"" {11}.وقال أهل المعاني: ""معناه: ليعلي دين الإسلام على كل دين بالحجة والغلبة"" {12}، وقد صح ظهوره عليها فحجة هذا الدين أقوى الحجج، والغلبة لهذا الدين على سائر الأديان؛ فإن أهل الإسلام يغزون أهل سائر الملل، [وأهل سائر الملل] {13} لا يغزون أهل الإسلام {14}.وقيل: أراد في جزيرة العرب {15}، وحصل ذلك بإجلاء أهل الذمة منها، وظهور الدين فيها كلها."
  9,34,"قوله تعالى: ﴿يَا أَيُّهَا الَّذِينَ آمَنُوا إِنَّ كَثِيرًا مِنَ الْأَحْبَارِ وَالرُّهْبَانِ﴾ قال ابن عباس: ""يريد أن كثيراً من الفقهاء والعباد من أهل الكتاب"" {1}، وقال السدي: ""أما الأحبار فمن اليهود، وأما الرهبان فمن النصارى"" {2}.وقوله تعالى: ﴿لَيَأْكُلُونَ أَمْوَالَ النَّاسِ بِالْبَاطِلِ﴾ هو ما ذكرنا في مواضع من أخذهم الرشى {3} في الحكم وما كانوا يصيبونه من المآكل من سفلتهم، وخافوا ذهاب ذلك عنهم بتصديق النبي -ﷺ- لو صدقوه، فصرفوا الناس عن الإيمان به، فذلك قوله {4}: ﴿وَيَصُدُّونَ عَنْ سَبِيلِ اللَّهِ﴾، قال ابن عباس: ""يريد قريظة والنضير وصدهم {5} عن طاعة الله"" {6}، قال أهل المعاني: ""أراد بقوله: ﴿لَيَأْكُلُونَ أَمْوَالَ النَّاسِ بِالْبَاطِلِ﴾ يتملكونها، فوضع يأكلون موضعه؛ لأن الأكل عرّضهم لذلك"" {7}.وقوله تعالى: ﴿وَالَّذِينَ يَكْنِزُونَ الذَّهَبَ وَالْفِضَّةَ﴾ ذكر في محل ""الذين"" قولان: أحدهما: النصب بالعطف على اسم إن، فيكون المعنى ويأكلها الذين يكنزون. والثاني: الرفع بالاستئناف {8}، والقولان مبنيان على سبب النزول.واختلفوا في نزول الآية، فالأكثرون على أن قوله: ﴿وَالَّذِينَ يَكْنِزُونَ﴾ إلى آخره مستأنف نازل في هذه الأمة، قال ابن عباس في رواية عطاء: ﴿وَالَّذِينَ يَكْنِزُونَ الذَّهَبَ وَالْفِضَّةَ﴾ يريد: من المؤمنين"" {9}، وقال السدي: ""أما الذين يكنزون الذهب والفضة فهم أهل القبلة"" {10}، وروي عن ابن عباس أنه قرأ هذه الآية فقال: هم أهل الكتاب، وهي خاصة [عامة] {11}، قال أهل العلم: ""أراد أن الآية نازلة في أهل الكتاب وهي خاصة] {12} فيمن لم يؤد الزكاة من المسلمين، عامة في جميع أهل الكتاب من أنفق ومن {13} لم ينفق؛ لأنهم كفار لا تقبل منهم نفقاتهم وإن أنفقوا"" {14}، وقال أبو ذر: ""كنت بالشام فقرأت هذه الآية: ﴿وَالَّذِينَ يَكْنِزُونَ الذَّهَبَ وَالْفِضَّةَ﴾ فقال معاوية: ليست هذه الآية فينا، إنما هذه الآية في أهل الكتاب، فقلت: إنها لفينا وفيهم"" {15}.وأصل الكنز في كلام العرب: الجمع، وكل شيء جمع بعضه إلى بعض فهو مكنوز، على ظهر الأرض كان أو في بطنها، يدل على ذلك قول الهذلي {16}:لا دَرَّ دَرّي إن أطعمت نازلكم ... قِرْف الحتيّ وعندي البر مكنوز {17}وقال الليث: ""يقال: كنز الإنسان مالاً يكنزه، والكنز: اسم للمال إذا أحرز في وعاء"" {18}، يقال: كنزت البر في الجراب فاكتنز، واختلفوا في المراد بهذا الكنز، وترك هذا الإنفاق، فالذي عليه الأكثرون -وهو الإجماع اليوم- أن المراد بهذا الكنز هو جمع المال الذي لا تؤدى زكاته {19}.ومعنى قوله: ﴿وَلَا يُنْفِقُونَهَا فِي سَبِيلِ اللَّهِ﴾ لا يؤدون زكاتها وهذا مذهب عمر وابنه وجابر، وقول ابن عباس {20} والضحاك {21} والسدي {22}، قال ابن عمر: ""كل ما أدي زكاته فليس بكنز وإن كان تحت سبع أرضين، وكل مال لم تؤد زكاته فهو كنز، وإن كان فوق الأرض"" {23}، وقال عمر: ""ما أدي {24} زكاته فليس بكنز"" {25}، وقال جابر: ""إذا أخرجت الصدقة من مالك فقد أذهبت عنه شره وليس بكنز"" {26}.وقال ابن عباس في قوله تعالى: ﴿وَلَا يُنْفِقُونَهَا فِي سَبِيلِ اللَّهِ﴾ ""يريد: الذين لا يؤدون زكاة أموالهم"" {27}.وذهب آخرون إلى أن المراد بهذا جمع المال وإن أديت الزكاة، قال {28} علي -رضي الله عنه-: ""كل مال زاد على أربعة آلاف فهو كنز أديت منه {29} الزكاة أو لم تؤد"" {30}، وقال عبد الواحد بن زيد {31}: ""كل ما فضل من المال عن حاجته {4} صاحبه إليه فهو كنز"" {33}، وروى ثوبان عن رسول الله -ﷺ- أنه قال لما نزلت هذه الآية: ""تبًا للذهب تبًا للفضة يقولها ثلاثًا"" قالوا: يا رسول الله: فأي المال نتخذ؟ قال: ""لسانا ذاكرًا، وقلبا شاكرًا، وزوجة مؤمنة تعين أحدكم على دينه"" {34}.وعن أبي ذر قال: أتيت رسول الله -ﷺ- وهو في ظل الكعبة، فلما رآني قد أقبلت قال: ""هم الأخسرون ورب الكعبة، [هم الأخسرون ورب الكعبة] {35} "" قلت: من هم فداك أبي وأمي؟ قال: ""الأكثرون، إلا من قال بالمال في عباد الله هكذا وهكذا، عن يمينه وعن شماله ومن خلفه، وقليل ما هم"" {36}.وروي هنا أيضًا عن جماعة من الصحابة أنهم ذهبوا إلى أن {37} هذه الآية فيمن ادخر المال عن الإنفاق في سبيل الله بعد الزكاة أيضًا {38}.والصواب: القول الأول؛ لأنه لا وعيد لمن جمع المال من الحلال وأدى الزكاة لقوله ﷺ: ""من أدى زكاة ماله فقد أدى الحق الذي عليه"" {39}، وقوله ﷺ: ""نعما بالمال الصالح للرجل الصالح"" {40}، وقول ابن عمر -وسئل عن هذه الآية-، فقال: ""من كنزها فلم يؤد زكاتها فويل له، وما أبالي لو كان لي مثل أحد ذهبًا أعلم عدده أزكيه وأعمل بطاعة الله فيه"" {41}، فعلى هذا من كان له دراهم أو دنانير فدفنها تحت الأرض وهو {13} يؤدي زكاتها فهو بمعزل عن {43} الوعيد المذكور في هذه الآية، ولا يطلق اسم الكنز بالشرع على ذلك المال {44}، وإن كان له مال فوق الأرض وهو لا يؤدي زكاته فذلك المال بالشرع يسمى {45} كنزًا، ولحقه الوعيد.وقوله تعالى: ﴿وَلَا يُنْفِقُونَهَا فِي سَبِيلِ اللَّهِ﴾، قال الفراء والزجاج: ""إن شئت جعلت الكناية {46} راجعة إلى مدلول عليه، وهو الكنوز كأنه قال: ولا ينفقون الكنوز"" {47}، قال الزجاج: ""ويجوز أن يكون محمولًا على الأموال {48}؛ لأن الأموال هي الذهب والفضة، قال: ويجوز أن تكون: ولا ينفقون الفضة، وحذف الذهمب لأنه داخل في الفضة"" {49}، وهذا معنى قول الفراء: ""وإن شئت اكتفيت بذكر أحدهما من صاحبه، كقوله تعالى: ﴿وَإِذَا رَأَوْا تِجَارَةً أَوْ لَهْوًا انْفَضُّوا إِلَيْهَا﴾ [الجمعة:11] فجعله {50} للتجارة، وقوله تعالى: ﴿وَمَنْ يَكْسِبْ خَطِيئَةً أَوْ إِثْمًا ثُمَّ يَرْمِ بِهِ بَرِيئًا﴾ [النساء: 112] {51} فجعله للإثم، وأنشدوا {52}:نحن بما عندنا وأنت بما عندك ... راض والرأي مختلف {53}وأنشد الفراء للفرزدق:إني ضمنت لمن أتاني ما جنى ... وأبي {54} وكان وكنت غير غدور {55} ولم يقل غدورين، وذلك لاتفاق المعنى يكتفى بذكر الواحد"" {56}.وهذا أيضًا مذهب أبي عبيدة قال: ""صار الخبر عن أحدهما كالخبر {57} عنهما، وأنشد قول ضابيء البرجمي {58}:فمن يك أمسى بالمدينة رحله ... فإني وقيار بها لغريب {59} {60}وإلى هذا ذهب صاحب النظم وزاد بياناً فقال: ""الذهب والفضة في أنهما جميعًا ثمنان للأشياء كلها {37} ويكنزان، وهما جميعًا جوهران يدخران يجريان في عامة الأمور مجرى واحداً، فاقتصر في الكناية عن أحدهما دون الآخر؛ إذ {37} في ذكر أحدهما ذكر لهما {63} جميعًا""، وقال أبو بكر بن الأنباري: ""اكتفى بإعادة الذكر على الفضة لأنها أقرب إلى العائد وأعم وأغلب، كقوله: ﴿وَاسْتَعِينُوا بِالصَّبْرِ وَالصَّلَاةِ وَإِنَّهَا﴾ [البقرة: 45] ردّ الكناية إلى الأغلب والأقرب"" {64}.وقوله تعالى: ﴿فَبَشِّرْهُمْ بِعَذَابٍ أَلِيمٍ﴾ أي ضع الوعيد بالعذاب الأليم موضع {65} البشرى بالنعيم، ويجوز أن يكون المعنى: فأخبرهم؛ لأن أصل البشرى: ما يظهر في بشرة الوجه من فرح أو غم، إلا أنه أكثر {66} في الفرح، وكلا القولين بما مضى الكلام فيه {67}."
  9,35,"وقوله تعالى: ﴿يَوْمَ يُحْمَى عَلَيْهَا فِي نَارِ جَهَنَّمَ﴾ الآية، ""يوم"" ظرف للعذاب الأليم في قوله: ﴿فَبَشِّرْهُمْ بِعَذَابٍ أَلِيمٍ﴾.وقوله: ﴿يَوْمَ يُحْمَى﴾: قال الأصمعي: ""أحميت الحديدة في النار فأنا أحميها إحماءً حتى حميت تحمى {1} حميا"" {2}، وذلك إذا أوقدت عليها، وقوله: ﴿عَلَيْهَا﴾ ليس منه {3} صلة الإحماء؛ لأنه يقال: أحميت الحديدة ولا يقال: على الحديدة، إلا إذا جعل (على) من صلة معنى الإحماء، وهو الإيقاد فمعنى قوله: ""يحمى عليها"" أي يوقد عليها، أنشد ابن السكيت {4}:إن كنت جلمود بصر {5} لا أؤبسه ... أوقد عليه فأحميه فينصدع {6} والكناية {3} في ﴿عَلَيْهَا﴾ تعود إلى ما عادت في قوله: ﴿وَلَا يُنْفِقُونَهَا﴾ {8}، قال ابن عباس: ﴿يَوْمَ يُحْمَى عَلَيْهَا﴾ أي: على الكنوز"" {9}، وقوله تعالى: ﴿فَتُكْوَى بِهَا﴾ معنى الكي في اللغة: إلصاق الحار من نار {10} أو حديدة بالعضو حتى يحترق الجلد، يقال: كوى البيطار {11} بالمكواة يكوي كيًا، وقوله تعالى: ﴿جِبَاهُهُمْ﴾ جمع الجبهة وهي مستوى ما بين الحاجبين إلى الناصية، والأجبه: الرجل العريض الجبهة، وجبهت الرجل: إذا استقبلته بمكروه، كأنك ضربت به جبهته.والجنوب: جمع الجنب، وهو الجانب المشبك بالعظام المقوسة، قال المفسرون: ""من كان له مال في الدنيا لم يؤد زكاته أحمي دراهمه ودنانيره في نار جهنم وكوي بها في هذه المواضع، لا يوضع دينار مكان دينار ولا درهم مكان درهم، ولكن يوسع جلده، فيوضع بكل درهم ودينار كية على جلده"" {12}، وهذا معنى قول ابن مسعود {13} وابن عباس {14}، وكان أبو ذر يقول: ""بشر الكانزين بكي في الجباه وكي في الجنوب وكي في الظهور حتى يلتقي الحر في أجوافهم"" {15}، ولهذا المعنى الذي أشار إليه أبو ذر خصت هذه المواضع [بالكي؛ لأن داخلها جوف بخلاف اليد والرجل، وكان أبو بكر الوراق {16} يقول: خُصت هذه المواضع] {17}؛ لأن صاحب المال إذا رأى الفقير قبض جبهته وزوى ما بين عينيه وطوى عنه كشحه {18}، وولاه ظهره"" {19}.وقوله تعالى: ﴿هَذَا مَا كَنَزْتُمْ لِأَنْفُسِكُمْ﴾ أي: يقال لهم: هذا الذي تكوون به ما جمعتم لأنفسكم وبخلتم به عن حق الله، وإضمار القول كثير في القرآن.وقوله تعالى: ﴿فَذُوقُوا مَا كُنْتُمْ تَكْنِزُونَ﴾ من باب حذف المضاف، أي: ذوقوا عذاب ما كنتم تكنزون، وحديث أبي هريرة يفسّر هذه الآية، وهو ما أخبرنا الأستاذ أبو إسحاق أحمد بن محمد بن إبراهيم {20} [رحمه الله قال {21}: أنا {22} أبو محمد عبد الله بن حامد الأصفهاني قال: أخبرنا {23} أبو يحيى أحمد بن محمد بن إبراهيم] {24} السمرقندي {25} قال: ثنا محمد بن نصر المروزي {26} قال: ثنا محمد بن عبد الملك ابن أبي الشوارب {27} قال: ثنا عبد العزيز بن المختار {28} قال: ثنا سهيل {29} عن أبيه {30} عن أبي هريرة قال: قال رسول الله -ﷺ: ""ما من صاحب كنز لا يؤدي زكاته إلا أحمي عليه في نار جهنم، فيجعل صفائح، فتكوى بها جبينه وجنباه، حتى يحكم الله بين عباده في يوم كان مقداره خمسين ألف سنة مما تعدون، ثم يرى سبيله إما إلى الجنة وإما إلى النار"" {31}."
  9,36,"قوله تعالى: ﴿إِنَّ عِدَّةَ الشُّهُورِ عِنْدَ اللَّهِ اثْنَا عَشَرَ شَهْرًا﴾ الآية، قد ذكرنا معنى العدة والشهر في سورة البقرة {1}، قال أبو إسحاق: ""أعلم الله -عز وجل- أن عدة شهور المسلمين التي تُعبدوا بأن يجعلوها لسنتهم اثنا عشر شهراً، على منازل القمر، واستهلال الأهلة، وكان أهل الكتاب يعملون على أن السنة ثلثمائة وخمس وستون يومًا وبعض يوم، على هذا يجري أمر النصارى واليهود، فأعلم الله -عز وجل- أن سني المسلمين على الأهلة"" {2}.قوله تعالى: ﴿فِي كِتَابِ اللَّهِ﴾، قال الواقدي: ""يعني اللوح المحفوظ"" {3}، وهو قول عامة أهل التأويل {4}، ونحو هذا يحكى عن ابن عباس ﴿فِي كِتَابِ اللَّهِ﴾ قال: ""في الإمام {5} الذي عند الله كتبه يوم خلق السموات والأرض"" {6}.قال أبو علي الفارسي: "" [لا يجوز تعلق] {7} الكتاب بالعدة؛ لأن فيه {8} فصلاً بين الصلة والموصول بالخبر الذي هو اثنا عشر، ولكنه يتعلق بمحذوف على أن يكون صفة للخبر تقديره: ""اثنا عشر شهرًا مكتوبًا في كتاب الله""، قال: والكتاب لا يكون إلا مصدرًا، ولا يجوز أن يعني به كتاب من الكتب؛ وذلك لتعلق اليوم به، وسائر الظروف لا تتعلق بأسماء الأعيان؛ لأنه لا معاني في أسماء الأعيان للفعل، (لا تقول: غلامك يوم الجمعة)، على أن يتعلق اليوم بالغلام، فبهذا يعلم أنه مصدر"" هذا كلامه {9}.ويمكن أن يكون الكتاب اسمًا على ما ذكره أهل التفسير {10}، ويضمر للظرف ما {11} يتعلق به على أن يكون المعنى: ﴿فِي كِتَابِ اللَّهِ﴾: كتبه يوم خلق السموات والأرض، على ما يحكى عن ابن عباس {12}، وذكر أبو علي هذه الآية في ""المسائل الحلبية""، فقال: ""الفائدة في قوله: ﴿فِي كِتَابِ اللَّهِ﴾ بعد قوله: ﴿عِنْدَ اللَّهِ﴾ أن في ﴿كِتَابِ اللَّهِ﴾ من الاختصاص ما ليس في قوله: ﴿عِنْدَ اللَّهِ﴾ ألا ترى أنه قد توصف أشياء بأنها عنده ولا توصف بأنها في كتابه كقوله: ﴿إِنَّ اللَّهَ عِنْدَهُ عِلْمُ السَّاعَةِ﴾ [لقمان: 34] ففي ﴿كِتَابَ اللَّهِ﴾ معنى زائد على ما في ﴿عِنْدِ اللَّهِ﴾ فجرى في هذا المعنى مجرى قولك: خرج من الدار من البيت {13} و ﴿عِنْدِ اللَّهِ﴾ متعلق بالمصدر الذي هو العدة وهو العامل فيه.وقوله تعالى: ﴿فِي كِتَابِ اللَّهِ﴾ متعلق بمحذوف لأنه صفة لـ (اثني عشر) قال: ويجوز أن يكون متعلقا بـ""حرم"" على تقدير: منها أربعة حرم في كتاب الله، أي: فيما كتب الله يوم خلق السموات والأرض، والمعنى: أن الحرم منها في كتاب الله أي فيما فرض كونه {14} حرمًا أربعة أشهر لا أكثر منه {15}، فإذا نسأتم أنتم المشهور فجعلتم {16} أكثر من أربعة أشهر وحللتم ما حرم الله وحرمتم ما أحل الله كان ذلك زيادة في الكفر، كما ذمهم الله بفعل ذلك"" {17}.وقوله تعالى: ﴿مِنْهَا أَرْبَعَةٌ حُرُمٌ﴾ وهي: رجب وذو القعدة وذو الحجة والمحرم {18}، في قول الجميع، ومعنى الحرم: أنه يعظم انتهاك المحارم فيها بأشد {19} مما يعظم في غيرها، وكانت العرب تعظمها حتى لو لقي الرجل منهم قاتل أبيه لم يهجه.قال أهل المعاني: ""وفي جعل بعض المشهور أعظم حرمة من بعض فوائد من المصلحة في الكف عن الظلم فيها لعظم منزلتها في حكم خالقها، فربما أدى ذلك إلى ترك الظلم رأسًا؛ لانطفاء الثائرة في تلك المدة"" {20}.وقد ذكرنا هذا مستقصى عند قوله: ﴿جَعَلَ اللَّهُ الْكَعْبَةَ الْبَيْتَ الْحَرَامَ﴾ [المائدة: 97] {21} الآية.وقوله: ﴿ذَلِكَ الدِّينُ الْقَيِّمُ﴾ الدين له معان كثيرة في اللغة، ومناه ههنا {22}: الحساب، ومنه قيل: ""الكيس من دان نفسه، وعمل لما بعد الموت"" {23} أي: حاسبها، و""القيم"": معناه المستقيم، وقد ذكرناه عند قوله: ﴿دِينًا قِيَمًا﴾ [الأنعام: 161]. قال المفسرون وأهل المعاني: ""ذلك الحساب المستقيم الصحيح، والعدد المستوي"" {24}. وقال الحسن: "" ﴿ذَلِكَ الدِّينُ الْقَيِّمُ﴾: الذي {25} لا يبدل ولا يغير"" {26}، فالقيم على هذا بمعنى {27}: القائم الدائم الذي لا يزول.قال أهل العلم: ""فالواجب على المسلمين بدليل هذه الآية أن يعتبروا به في بيوعهم، ومُدد ديونهم، وأحوال زكاتهم، وسائر أحكامهم، السنة العربية بالأهلة، ولا يجوز لهم {28} اعتبار السنة العجمية والرومية {29} {30}.قوله تعالى: ﴿فَلَا تَظْلِمُوا فِيهِنَّ أَنْفُسَكُمْ﴾، قال ابن عباس في رواية عطاء: ""تحفّظوا من أنفسكم فيها واجتنبوا الخطايا، فإن الحسنات فيها تضعف والسيئات فيها تضعف {31} "" {32}، فعلى هذا القول: الكناية تعود إلى الحرم، وهو قول قتادة، قال: ""الظلم في الأشهر الحرم أعظم وزرًا من الظلم فيما سواها، وإن كان الظلم على كل حال عظيما، ولكن الله يعظم من أمره ما يشاء، فاصطفى من الملائكة رسلاً، ومن الناس، ومن الأرض والمساجد، والأيام والشهور والليالي، فعظموا ما عظم الله"" {33}.وقال محمد بن إسحاق: ﴿فَلَا تَظْلِمُوا فِيهِنَّ أَنْفُسَكُمْ﴾ بأن تجعلوا حرامها حلالاً، وحلالها حرامًا كما فعل أهل الشرك في النسيء"" {34}، وعلى هذا: الكناية تعود إلى الشهور كلها [وقد روي عن ابن عباس أنه {22} قال: "" ﴿فَلَا تَظْلِمُوا فِيهِنَّ أَنْفُسَكُمْ﴾ {36}: في الشهور كلها"" {37}] {38}، وحكى الزجاج القولين جميعًا، وقال: ""من قال في الأربعة: أراد تعظيم شأن المعاصي فيهن كما قال تعالى: ﴿فَلَا رَفَثَ وَلَا فُسُوقَ وَلَا جِدَالَ فِي الْحَجِّ﴾ [البقرة: 197]، وهذه الأشياء لا تجوز في غير الحج، ولكنه -عز وجل- عرّف الأيام التي تكون فيها المعاصي أكثر إثمًا وعقابًا"" {39}، واختار الفراء أن تكون الكناية راجعة إلى الأربعة لقوله: ﴿فِيهِنَّ﴾ ولم يقل (فيها) كما قال: ﴿مِنْهَا أَرْبَعَةٌ حُرُمٌ﴾ لما عادت الكناية إلى كلها، قال: وكذلك كلام العرب لما بين الثلاثة إلى العشرة يقولون: لثلاث خلون، إلى العشرة [(فإذا جُزت العشرة) {40} قالوا: خلت، ويقولون لما بين الثلاثة إلى العشرة] {38}: (هن) و (هؤلاء) {42} فإذا جزت العشرة قالوا: (هي) و (هذه) إرادة أن تُعرف سمة القليل من الكثير، قال: ""ويجوز في كل واحد ما جار في صاحبه""، وأنشد:أصبحن في قُرح وفي داراتها ... سبع ليال غير معلوفاتها {43} {44}ولم يقل: غير معلوفاتهن وهي سبع، وكل صواب؛ إلا أن المؤْثر ما فسرت لك {45}.والأصل في هذا أن جمع القلة يكنى عنه كما يكنى عن جماعة مؤنثة، ويكنى عن جمع الكثرة كما يكنى عن واحدة مؤنثة، كما قال حسان:لنا الجفنات الغر يلمعن بالضحى {46} ... وأسيافنا يقطرن من نجدة {47} دما {48}فقال: يلمعن ويقطرن؛ لأن الأسياف والجفنات جمع قلة، ولو جمع جمع {22} الكثرة لقال: تلمع وتقطر، هذا هو الاختيار، ويجوز إجراء أحدهما مجرى الآخر، كقول النابغة:ولا عيب فيهم غير أن سيوفهم ... بهن فلول من قراع الكتائب {50} فقال: بهن والسيوف جمع كثرة، وروي عن ابن عباس أيضًا أنه قال: "" ﴿فَلَا تَظْلِمُوا فِيهِنَّ أَنْفُسَكُمْ﴾ باستحلال القتل والغارة فيهن"" {51}، وهذا يوجب ترك القتال في الأربعة الحرم، وبقاؤها على ما كانت قبل الإسلام، وقد ذكرنا الخلاف في هذا الحكم في سورة البقرة {52}، في قوله: ﴿يَسْأَلُونَكَ عَنِ الشَّهْرِ الْحَرَامِ قِتَالٍ فِيهِ﴾ [البقرة: 217].وقوله تعالى: ﴿وَقَاتِلُوا الْمُشْرِكِينَ كَافَّةً كَمَا يُقَاتِلُونَكُمْ كَافَّةً﴾، قال ابن عباس: ""كافة: جميعًا"" {53}، يريد: قاتلوهم كلهم ولا تُحابوا {54} بعضهم بترك القتال؛ كما أنهم يستحلون قتال جميعكم، ويجوز أن يكون المعنى: قاتلوهم بأجمعكم، مجتمعين على قتالهم كما يفعلون هم، يريد: تعاونوا وتناصروا على ذلك ولا تتجادلوا، وكلا المعنيين يحتمله قوله {55}: جميعًا، والمعنى الثاني يوجب تعين فرض القتال على كل أحد، ونذكر الخلاف فيه في قوله -عز وجل-: ﴿انْفِرُوا خِفَافًا وَثِقَالًا﴾ [التوبة: 41] الآية.قال الفراء: ""كافة يقول: جميعًا، والكافة لا تكون مذكرة ولا مجموعة على عدد الرجال، فتقول: كافّين أو كافات للنسوة، ولكنها (كافة) بالهاء والتوحيد؛ لأنها وإن كانت على لفظ (فاعلة) فإنها في مذهب مصدر مثل: الخاصة والعاقبة والعافية {56}؛ لذلك لم تُدخل فيها العرب الألف واللام؛ لأنها في {57} مذهب قولك: قاموا معًا، [وقاموا جميعًا"" {58}] {59}.وقال الزجاج: ﴿كَافَّةً﴾ منصوب على الحال، وهو مصدر على (فاعلة) كما قالوا: العاقبة والعافية، ولا يجوز أن يثنى ويجمع، كما أنك إذا قلت: قاتلوهم عامة لم تثن ولم تجمع، وكذلك (خاصة)، هذا مذهب النحويين"" {60}.وقد أحكمنا الكلام في هذا الحرف عند قوله: ﴿ادْخُلُوا فِي السِّلْمِ كَافَّةً﴾ [البقرة: 208] {61}.وقوله تعالى: ﴿وَاعْلَمُوا أَنَّ اللَّهَ مَعَ الْمُتَّقِينَ﴾، قال ابن عباس: ""يريد مع أوليائه الذين يخافونه فيما كلفهم من أمره ونهيه"" {62}، قال الزجاج: ""تأويله أنه ضامن لهم النصر"" {63}."
