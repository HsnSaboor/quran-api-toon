tafsir[21]{c,v,t}:
  26,184,"﴿وَاتَّقُوا الَّذِي خَلَقَكُمْ وَالْجِبِلَّةَ الْأَوَّلِينَ﴾ مفسر فيما مضى. والجبلة: الخليقة {1}. يقال: جُبل فلان على كذا وكذا، أي: خُلق {2}، قال الشاعر:والموت أعظم حادث ... مما يمر على الجبلة {3}ونذكر اللغات فيها عند قوله: ﴿وَلَقَدْ أَضَلَّ مِنْكُمْ جِبِلًّا كَثِيرًا﴾ [يس: 62] 62]-إن شاء الله تعالى-. قال المفسرون: يعني: الأمم الخالية {4}."
  26,185,"قوله: ﴿إِنَّمَا أَنْتَ مِنَ الْمُسَحَّرِين﴾ فسرناه في هذه السورة {1}."
  26,186,"قوله: ﴿وَإِنْ نَظُنُّكَ لَمِنَ الْكَاذِبِينَ﴾ أي في أنك رسول الله {1}."
  26,187,"قوله: ﴿فَأَسْقِطْ عَلَيْنَا كِسَفًا مِنَ السَّمَاءِ﴾ مفسر في قوله: ﴿أَوْ تُسْقِطَ السَّمَاءَ كَمَا زَعَمْتَ عَلَيْنَا كِسَفًا﴾ [الإسراء: 92].قوله: ﴿إِنْ كُنْتَ مِنَ الصَّادِقِينَ﴾ أي: بأن العذاب نازل بنا. قاله مقاتل {1}."
  26,188,"﴿قَالَ رَبِّي أَعْلَمُ بِمَا تَعْمَلُونَ)﴾ يعني: من نقصان الكيل والوزن {1}.والمعنى: أنه أعلم به؛ فهو مجازيكم ومعذبكم إن شاء، وليس عندي من العذاب، وما عليَّ إلا الدعوة {2}؛ وذلك أن هذا جواب لقولهم: "" ﴿فَأَسْقِطْ عَلَيْنَا كِسَفًا﴾."
  26,189,"قوله: ﴿فَكَذَّبُوهُ فَأَخَذَهُمْ عَذَابُ يَوْمِ الظُّلَّة﴾ مضى تفسير الظلة في سورة البقرة {1}. وهاهنا سحاب {2} أظلتهم فاجتمعوا تحتها مستجيرين {3} بها مما نالهم من حر ذلك اليوم، ثم أطبقت عليهم، وكان من أعظم يوم في الدنيا عذابًا {4}.قال ابن عباس: بعث الله عليهم وَقَدَة وحرًا شديدًا فأخذ بأنفاسهم؛ فدخلوا أجواف البيوت فأخذ بأنفاسهم، فخرجوا من البيوت هربًا إلى البرية فبعث الله سحابة فأظلتهم من الشمس فوجدوا لها بَرْدًا، فنادى بعضهم بعضًا حتى إذا اجتمعوا تحتها أسقطها الله عليهم نارًا {5}. وهذا قول أكثر المفسرين {6}.وروي عن ابن عباس: أنهم لما صاروا تحت السحابة أسقطها الله عليهم. وقال زيد بن معاوية: لما اجتمعوا تحتها صيح بهم منها فهلكوا {7}.وقال عطاء عن ابن عباس: بعث الله عليهم سَمُومًا {8}] فخرجوا إلى الأيكة يستظلون بها، فأضرمها الله عليهم نارًا فاحترقوا {9}."
  26,191,"26:190"
  26,192,"قوله: ﴿وَإِنَّهُ لَتَنْزِيلُ رَبِّ الْعَالَمِينَ﴾ يعني: القرآن {1}. قال ابن عباس: نَزَّل القرآنَ ربُ العالمين."
  26,193,"﴿نَزَلَ بِهِ الرُّوحُ الْأَمِينُ (193) عَلَى قَلْبِكَ﴾ أي: نَزَّل الله بالقرآن جبريل {1}.وتقرأ ﴿نَزَلَ﴾ مخففة، و (الروحُ الأمين) رفعًا {2}. فمن شدد فحجته قوله: ﴿لَتَنْزِيلُ رَبِّ الْعَالَمِينَ﴾ وقوله: ﴿نَزَّلَهُ عَلَى قَلْبِكَ﴾ [البقرة: 97] وقوله: ﴿يُنَزِّلُ الْمَلَائِكَةَ﴾ [النحل: 2] وينزل مطاوع نَزَّل، ومن أسند الفعل إلى الروح وخفف؛ فلأنه ينزل بأمر الله -سبحانه وتعالى-، ومعناه معنى المثقلة {3}.و (الروح الأمين) هو جبريل {4}؛ قال ابن عباس: أمين فيما بين الله وبين أنبيائه.وقال مقاتل: أمين فيما استودعه من الرسالة إلى أنبيائه {5}."
  26,194,"وقوله: ﴿عَلَى قَلْبِكَ﴾ قال مقاتل: يقول: لنثبت قلبك {1}. والمعنى: نَزَل به الروحُ الأمين فتلاه عليك حتى وعيته بقلبك {2}.وقال أبو إسحاق: نزل فوعاه قلبك وثبت فيه فلا تنساه أبدًا {3}. ﴿لِتَكُونَ مِنَ الْمُنْذِرِينَ﴾ [ممن أنذر المكذبين بآيات الله] {4}."
  26,196,"قوله تعالى: ﴿وَإِنَّهُ لَفِي زُبُرِ الْأَوَّلِينَ﴾ وإنَّ ذكرَ القرآن وخبرَه لفي كتب الأولين {1}. يعني: أن الله تعالى أخبر في كتبهم عن القرآن وإنزاله على النبي -ﷺ- المبعوث في آخر الزمان {2}. وقال مقاتل: وإنَّ أمرَ محمد، وذكرَه، ونعتَه {3} لفي كتب الأولين {4}. وهذا كقوله: ﴿الَّذِي يَجِدُونَهُ مَكْتُوبًا عِنْدَهُمْ في التَّوْرَاةِ وَالْإِنْجِيلِ﴾ [الأعراف: 157] {5}. والزُّبُر: الكتب، زَبُور وزُبُر، مثل: رَسُولٌ ورُسُل {6}."
  26,197,"قوله: ﴿أَوَلَمْ يَكُنْ لَهُمْ آيَةً أَنْ يَعْلَمَهُ عُلَمَاءُ بَنِي إِسْرَائِيلَ﴾ قرأه العامة: ﴿يَكُن﴾ بالياء ﴿آّيّةً﴾ نصبًا {1}.قال إسحاق: (أنْ) اسم كان، و (آيةً) خبره؛ والمعنى. أو لم يكن لهم {2} عِلْم علماء بني إسرائيل أن النبي -ﷺ- حق وأن نبوته حق، (آية) أي: علامة {3}، موضحة؛ لأن العلماء الذين آمنوا من بني إسرائيل وجدوا ذكر النبي -ﷺ- مكتوبًا عندهم في التوراة والإنجيل {4}.قال ابن عباس، في رواية الكلبي: بعث أهلُ مكة إلى اليهود وهم بالمدينة فسألوهم عن محمد -ﷺ-؛ فقالوا: إنَّ هذا لزمانُه، وإنَّا نجد في التوراة نعتَه وصفتَه. فكان ذلك آية لهم على صدقه {5}. فعلى هذا: أراد بعلماء بني إسرائيل: يهود المدينة ومن كان منهم عالمًا بالكتاب.وقال مقاتل: يعني: ابن سلام وأصحابه {6}.وقال مجاهد: علماء بني إسرائيل؛ عبد الله بن سلام، وغيره من علمائهم {7}.وقال عطية في هذه الآية: كانوا خمسة: عبد الله بن سلام، وابن يامينَ، وثعلبةُ، وأسد، وأَسِيد {8}.قرأ ابن عامر: (تكن) بالتاء (آيةٌ) رفعًا، قال أبو إسحاق: جعل (آيةٌ) هي الاسم، و (أن يعلمه) خبر تكن {9}. ونحو هذا قال الفراء {10}. قال أبو علي: إذا اجتمع في باب: كان، معرفة ونكرة فالذي يُجعل اسم كان منهما: المعرفة، كما كان المبتدأ: المعرفة، والنكرة: الخبر، وهو يجيء في الشعر للاضطرار؛ الاسم: نكرة والخبر: معرفة، ولا يجوز هذا حيث لا يُضْطُّر إليه تصحيحُ وزنٍ، ولا إقامةُ قافيةٍ، فقوله: (أولم تكن لهم آية) لا يجوز أن يكون التأنيث في (تكن) لأنه حينئذ يصير اسمًا لكان، ولكن في (تكن) ضمير القصة، و (آيةٌ) خبر مبتدأ مقدم، والجملة في موضع نصب كما تقول: كان زيدٌ منطلقٌ، على معنى: كان الأمر هذا وكان الشأن هذا، قاسم كان ضمير مستتر، وارتفع زيد بالابتداء، ومنطلق: خبره، والجملة في موضع نصب بكونها خبرًا.قال: ومن ذلك قول الشاعر:ولا أُنْبَأَنَّ أن وجهكِ شأنَه ... خُمُوش وإنْ كان الحميمُ حميمُ {11} ذكر هذا في كتاب ""الإيضاح""؛ ونحو هذا ذَكر في كتاب ""الحجة"" {12}؛ وزاد في هذا الفصل بأن قال: (ءايةٌ) مرتفعة بأنها خبر الابتداء الذي هو: ﴿أَنْ يَعْلَمَهُ عُلَمَاءُ بَنِي إِسْرَائِيلَ﴾ وقال: ولا يمتنع أن لا تضمر {13} القصة ولكن ترفع: ﴿أَنْ يَعْلَمَه﴾ بقوله: (تكن) وإن كان في تكن علامة تأنيث؛ لأن ﴿أَنْ يَعْلَمَه﴾ في المعنى هو الآية، فيحمل الكلام على المعنى؛ كما حُمل على المعنى في قوله: ﴿فَلَهُ عَشْرُ أَمْثَالِهَا﴾ [الأنعام: 160] فأنث لما كان المراد بالأمثال: الحسنات. وكذلك قرأ من قرأ: ﴿ثُمَّ لَمْ تَكُنْ فِتْنَتُهُمْ إِلَّا أَنْ قَالُوا﴾ [الأنعام: 23] {14}."
  26,198,"قوله: ﴿وَلَوْ نَزَّلْنَاهُ عَلَى بَعْضِ الْأَعْجَمِينَ (198) فَقَرَأَهُ عَلَيْهِمْ﴾ قال الكلبي: على رجل عجمي {1}. والمعنى: ولو نزلنا القرآن على رجل ليس بعربي اللسان ﴿فَقَرَأَهُ عَلَيْهِمْ﴾ بغير لغة العرب ما آمنوا به، وقالوا: ما نفقه قولك؛ نظيره قوله: ﴿وَلَوْ جَعَلْنَاهُ قُرْآنًا أَعْجَمِيًّا لَقَالُوا لَوْلَا فُصِّلَتْ آيَاتُه﴾ [فصلت: 44] قال مقاتل: يقول: لو نزلنا هذا القرآن على رجل ليس بعربي اللسان فقرأه على كفار مكة لقالوا: ما نفقه قولك {2}.قوله: ﴿فَقَرَأَهُ عَلَيْهِمْ مَا كَانُوا بِهِ مُؤْمِنِينَ﴾ يعني: بالقرآن مصدقين بأنه من الله {3}.وفيه قول آخر؛ روى داوود بن أبي هند، عن محمد بن أبي موسى، قال: كنت واقفًا مع عبد الله بن مطيع بن الأسود بعرفات؛ فقرأ هذه الآية: ﴿وَلَوْ نَزَّلْنَاهُ عَلَى بَعْضِ الْأَعْجَمِينَ﴾ قال: لو نزل على جملي هذا فقرأ عليهم ﴿مَا كَانُوا بِهِ مُؤْمِنِينَ﴾ {4}. وهذا القول أليق بما بعده.قال أبو إسحاق: (الأعجمين) جمع أعجم، والأنثى عجماء، والأعجم الذي لا يفصح، وكذلك الأعجمي، فأما العَجَمِي فالذي من جنس العجم أفصح أو لم يفصح {5}.قال أبو علي الفارسي: أعجم صفة {6}، كأحمر؛ لأنه قد وُصف به في النكرة، وهو قوله:.. .. .. .. .. كما أَوتْ ... حِزقٌ يمانيةٌ لأعجمَ طِمْطِم {7}وقد دخلته الألف واللام على حد دخولها على أحمر، للتعريف في قولهم: زياد الأعجم، فقد علمت لجريه على النكرة، ودخول لام التعريف عليه أنه صفة في النكرة، مثل أحمر، وفي التعريف بمنزلة: الأحمر، وإذا كان كذلك ثبت أنه صفة، وإذا علمت أنه صفة علمت أن جمعه بالواو والنون، والياء والنون {8} خطأ، وإذا كان هذا القبيل من الصفة لا يُجمع بالواو والنون في قول النحويين أجمعين، علمتَ أن قول أبي إسحاق: الأعجمين جمع أعجم، [والأنثى] {9} عجماء، خطأ بيَّن؛ والقول فيه: أنه جمع أعجمي ليس جمع أعجم، وأعجم وأعجمي معناهما واحد، وكلاهما وَصْف الذي لا يُفصح من العجم كان أو من العرب، إلا أنَّ الذي تدخله ياء التشديد ينصرف، وإنْ كان المعني فيه الصفة {10}، [كما أن صياقلة {11} ونحوه لما دخله تاء التأنيث انصرف للتاء، والمعنى: معنى الجمع] {12} فأعجمي كقولهم: أحمري، وأنت تريد الأحمر، كما لا تريد بكرسي إضافتَه إلى شيء، وهذا مروي مأخوذ من رواة اللغة؛ يدلك على ذلك قول العجاج:والدهرُ بالإنسان دَوَّارِيُ {13} ألا ترى أن المراد بدَوَّارِي: دوارٌ واحد، كذلك أعجم وأعجمي {14}. والذي قلنا من أن الأعجمين جمع أعجمي هو قول سيبويه؛ وقد نص عليه {15}؛ وذهب أبو إسحاق عنه {16}، قال سيبويه في الباب المترجم: هذا بابٌ من الجمع بالواو والنون، [وتكسير الاسم. سألت الخليل عن قولهم: الأَشْعَرُون؛ فقال: إنما أَلحقوا الواو والنون] {12} وحذفوا ياء الإضافة كما كَسَّروا فقالوا: الأشاعرُ، والأشاعث، والمَسَامِعة، فلما كَسَّروا مِسْمَعًا والأشعث حين أرادوا معنى بني مِسْمَع وبني الأشعث، أَلحقوا الواو والنون، فكذلك الأعجمون {18}.فقد تبينت من نص سيبويه أن الأعجمين جمع أعجمي، وأن ياءي النسب والإضافة {19} محذوفان حُذفا في الجمع، وأنه جُمع على هذا [الحد] {20} كما كُسِّر على الأشاعث. ومثل قولهم: الأعجمون، قولهم: النُّمَيْرُون. ومما يدلك على صحة هذا: أن ما كان صفة من هذا القبيل لا يجمع بالواو والنون، ألا ترى أنه لا يقال في جمع أسود: أسودون، وإذا كان ذلك مرفوضًا علمت أنه جَمْع الاسم إذا أُلحق ياء النسب؛ لأنه بدخول ياء النسب يخرج من ذلك الحد في اللفظ، وإن كان موافقًا له في المعنى، كما خرج بذلك من الامتناع من الانصراف، وكما لم يُجمع مذكر هذا القبيل بالواو والنون، كذلك لم يُجمع مؤنثه، نحو: حمراء، وسوداء، بالألف والتاء. انتهت الحكاية عن أبي علي {21}.وذكرنا تفسير الأعجمي في سورة النحل {22}."
  26,199,"26:198"
  26,200,"قوله تعالى: ﴿كَذَلِكَ سَلَكْنَاهُ في قُلُوبِ الْمُجْرِمِينَ﴾ تفسيره كتفسير قوله: ﴿كَذَلِكَ سَلَكْنَاهُ في قُلُوبِ الْمُجْرِمِينَ﴾ [في سورة: الحجر {1}.قال ابن عباس: ﴿كَذَلِكَ سَلَكْنَاه﴾ يريد الشرك سلكه في قلوب المجرمين {2}. و] {3} قال الحسن: ﴿سَلَكْنَاهُ في قُلُوبِ الْمُجْرِمِينَ﴾ الشرك جعلناه في قلوب المجرمين {4}. وهو قول ابن جريج وابن زيد {5}. وقال مقاتل: يقول: هكذا جعلنا الكفر بالقرآن في قلوب المجرمين {6}."
  26,201,"﴿لَا يُؤْمِنُونَ بِهِ﴾ بالقرآن {1} ﴿حَتَّى يَرَوُا الْعَذَابَ الْأَلِيمَ﴾ فعلى هذا: أراد بالمجرمين: مشركي مكة. وعلى قول الحسن وابن عباس؛ أراد: المجرمين من الأمم الخالية؛ أخبر الله أنه أدخل الشرك، وجعله في قلوبهم فلم يؤمنوا إلا عند نزول العذاب حين لم ينفعهم. قال ابن عباس في قوله: ﴿لَا يُؤْمِنُونَ بِهِ﴾ الآية، قال: لا يصدقون بتوحيد الله ﴿حَتَّى يَرَوُا الْعَذَابَ﴾ الذي أهلكهم الله به مما قص من لدن: نوح، إلى: شعيب. وعلى التأويلين جميعًا في الآية دلالة على أن الله تعالى خالق الشرك، سالكه في قلوب المجرمين.قال الفراء: يقول سلكنا التكذيب في قلوب المجرمين كيلا يؤمنوا به {2}.وقال أبو إسحاق: أي: سلكنا تكذيبهم في قلوبٍ جعل الله مجازاتِهم أن طبع على قلوبهم وسلك فيها الشرك {3}.وقوله تعالى: ﴿لَا يُؤمِنُونَ بِه﴾ قال: أخبر أنه لما سلك في قلوبهم الشرك منعهم من الإيمان به {3}. وتفسير القدرية لقوله: ﴿كَذَلِكَ سَلَكْنَاهُ في قُلُوبِ الْمُجْرِمِينَ﴾ أمررنا القرآن في قلوبهم بإخطاره ببالهم لتقوم الحجة عليهم {5}. وهذا التفسير خَلْفٌ {6} فاسد؛ لم يقله أحد من المفسرين، ولا أصحاب المعاني إلا القدرية؛ وكيف يصح هذا والله تعالى يقول: ﴿لَا يُؤمِنُونَ بِه﴾ أفتراه سلك القرآن في قلوبهم حتى لا يؤمنوا؟ وكان من الواجب أن يؤمنوا إذا أدخل الله القرآن في قلوبهم، ثم السلك ليس بمعنى: الإمرار والإخطار؛ إنما هو بمعنى: الإدخال والإثبات، كسلك الخيط في الحريرة، يدل على هذا قوله تعالى: ﴿مَا سَلَكَكُمْ في سَقَرَ﴾ [المدثر 42] لا يجوز أن يقال في معناه: ما أخطركم بها. والهاء في قوله: ﴿سَلَكْنَاهُ﴾ تعود إلى معنى قوله: ﴿مَا كَانُوا بِهِ مُؤْمِنِين﴾ ومعناه: كذبوا، وكذبوا يدل على التكذيب فكنى عنه، وهو قول المفسرين وأهل المعاني: سلكنا الشرك وسلكنا التكذيب، فظاهر الآية يدل على صحة قول مقاتل، وأن هذا إخبار عن مشركي مكة ولو كان خبرًا عن مشركي الأمم المتقدمة لقيل: لم يؤمنوا حتى يروا العذاب الأليم فأتاهم بغتة، وقد قال:"
  26,202,"﴿فَيَأْتِيَهُمْ بَغْتَةً﴾ يعني العذاب {1} ﴿وَهُمْ لَا يَشْعُرُونَ﴾ به فيتمنوا الرجعة والنَّظِرَهَ {2}، وهو قوله:"
  26,203,"﴿فَيَقُولُوا هَلْ نَحْنُ مُنْظَرُونَ﴾ أي: لِنعتِب {1} ونراجع، قاله مقاتل {2}.وقال ابن عباس: إنهم يسألون تأخير العذاب فلا يجابون ولا يصرف عنهم {3}.قال مقاتل: فلما أوعدهم النبي -ﷺ- بالعذاب قالوا: فمتى العذاب تكذيبًا به {4}، فقال الله تعالى:"
  26,204,"﴿أَفَبِعَذَابِنَا يَسْتَعْجِلُونَ (204) أَفَرَأَيْتَ إِنْ مَتَّعْنَاهُمْ سِنِينَ﴾ [قال ابن عباس:] {1} ﴿أَفَرَءَيْتَ﴾ يا محمد إن متعنا كفار مكة ﴿سِنِينَ﴾ قال: يريد منذ خلق الله الدنيا إلى أن تنقضي في النعيم والسرور والنَّضارة {2}.وقال الكلبي: يعني عَمَّرهم؛ وهو معنى قول مقاتل: ﴿سِنِينَ﴾ في الدنيا {3}.قال صاحب النظم: قوله: ﴿أَفَرَءَيْتَ﴾ غير متعد إلى شيء؛ إنما هو سؤال واستخبار عن معنى بلفظ الاستفهام، كقوله تعالى: {أَرَأَيْتَ إِذْ أَوَيْنَا إِلَى الصَّخْرَةِ فَإِنِّي نَسِيتُ الْحُوت} [الكهف: 63] دخول الفاء في قوله: ﴿فَإِنِّي﴾ يدل على أنه مستأنف."
  26,205,"26:204"
  26,206,"قوله: ﴿ثُمَّ جَاءَهُمْ مَا كَانُوا يُوعَدُونَ﴾ أي: من العذاب {1}."
