tafsir[5]{c,v,t}:
  9,87,"قوله تعالى: ﴿رَضُوا بِأَنْ يَكُونُوا مَعَ الْخَوَالِفِ﴾، قال المفسرون: (يعني النساء) {1}، قال الفراء: (النساء الخوالف: اللاتي يخلفن في البيت ولا يبرحن) {2}.[وقال الزجاج] {3}: (أي رضوا بأن يكونوا في تخلفهم عن الجهاد كالنساء، قال: وقد {4} يجوز أن يكون جمع خالفة في الرجال والخالفة: الذي هو غير نجيب {5}، ولم يأت (فاعل) صفة جمعه (فواعل) إلا حرفان، قالوا: فارس وفوارس، وهالك وهوالك {6} {7}.وذكرنا الكلام في الخالف مستقصى في قوله تعالى: ﴿فَاقْعُدُوا مَعَ الْخَالِفِينَ﴾ [التوبة: 83].وقوله تعالى: ﴿وَطُبِعَ عَلَى قُلُوبِهِمْ﴾، قال ابن عباس: (يريد بالنفاق) {8}، ﴿فَهُمْ لَا يَفْقَهُونَ﴾، قال الضحاك: (لا يعلمون أمر الله) {9}.وقال الحسن: (ليسوا بفقهاء ولا علماء، ولو كانوا فقهاء لما تخلفوا عن الجهاد معه) {10}، وذكرنا الكلام في هذا عند قوله: ﴿بَلْ طَبَعَ اللَّهُ عَلَيْهَا بِكُفْرِهِمْ﴾ [النساء: 155]، وقوله: ﴿خَتَمَ اللَّهُ عَلَى قُلُوبِهِمْ﴾ [البقرة: 7]."
  9,88,"قوله تعالى: ﴿وَأُولَئِكَ لَهُمُ الْخَيْرَاتُ﴾ {1}، قال الأخفش {2} وأبو عبيدة {3} والمبرد {4}: (الخيرات جمع خيرة، وهن الجواري الفاضلات الحسان)، أبو زيد: يقال: (هي خيرة النساء، وشرة النساء) {5}، وأنشد أبو عبيدة:ربلات هند خيرة الملكات {6}"
  9,90,"قوله تعالى: ﴿وَجَاءَ الْمُعَذِّرُونَ مِنَ الْأَعْرَابِ لِيُؤْذَنَ لَهُمْ﴾ الآية، ذكرنا معنى العذر والاعتذار وأصله في اللغة عند قوله: ﴿قُلْ لَا تَعْتَذِرُوا﴾ [التوبة: 66]، وتقول: أعذر {1} فلان أي كان منه ما يُعذر به، ومنه قولهم: قد أعذر من أنذر، واعتذر اعتذارًا: إذا أتى بعذر صدق فيه أو كذب، وعذر تعذيرًا: أي قصر ولم يبالغ. يقال: قام فلان قيام {2} تعذير فيما استكفتيه: إذا لم يبالغ، وقصر فيما اعتمد عليه، فمن قرأ (المُعَذِرُون) بالتخفيف وهو قراءة جماعة من الصحابة والتابعين {3}، فمعناه المجتهدون المبالغون في العذر، روى الضحاك عن ابن عباس أنه قرأ: (وجاء المعذرون) {4}، وقال (لعن الله المعذرين) {5} ذهب إلى أن المعذرين هم الذين لا عذر لهم {6}.و ﴿الْمُعَذِّرُونَ﴾ {7} بالتشديد: الذين يعتذرون بلا عذر، كأنهم المقصرون الذين لا عذر لهم، وعلى هذه القراءة، معنى الآية: إن الله تعالى فصل بين أصحاب العذر وبين الكاذبين، قال ابن عباس: (هم الذين تخلفوا بعذر بإذن رسول الله -ﷺ-) {8}.وقال عطاء عنه: (يريد الأعراب [الذين يعتذرون] {9} إلى النبي -ﷺ- في تخلفهم ليؤذن لهم في التخلف) {10}.وقال الضحاك: (هم وهي عامر بن الطفيل {11} جاؤا {12} إلى رسول الله -ﷺ-، وقالوا: إن نحن غزونا معك تُغير أعراب طيء على حلائلنا {13} وأولادنا ومواشينا فعذرهم رسول الله -ﷺ-) {14}.ونحو هذا قال مجاهد: (هم أهل العذر) {15}، ومن قرأ: ﴿الْمُعَذِّرُونَ﴾ بالتشديد وهو قراءة العامة {16} فله وجهان من العربية والتأويل:أحدهما: ما ذكره الفراء والزجاج وابن الأنباري: (وهو أن الأصل في هذا اللفظ عند النحويين: المعتذرون فحولت فتحة التاء إلى العين وأبدلت الذال من التاء، وأدغمت في الذال التي بعدها فصارتا ذالًا مشددة {17}) {18}.والاعتذار ينقسم في كلام العرب على قسمين، يقال: اعتذر {19}: إذا كذب في عذره، قال الله تعالى: ﴿يَعْتَذِرُونَ إِلَيْكُمْ إِذَا رَجَعْتُمْ إِلَيْهِمْ﴾، فدل على فساد عذرهم بقوله {20}: ﴿قُلْ لَا تَعْتَذِرُوا﴾ [التوبة: 94]، ويقال: اعتذر: إذا جاء بعذر صحيح، ومنه قول لبيد:ومن يبك حولًا كاملًا فقد اعتذر {21} يريد فقد جاء بعذر صحيح.(الوجه الثاني من العربية - أن يكون ﴿الْمُعَذِّرُونَ﴾ {22} على (مفعلين) من التعذير الذي هو التقصير على ما بينا، فإن قلنا: المعذرون {22} [معناه: المعتذرون بعذر] {24} صحيح فوجهه من التأويل ما ذكرنا في قراءة من خفف، وإن قلنا أن معناه: المعتذرون بعذر باطل، أو أخذناه من التعذير فوجهه من التأويل ما قال قتادة) {25}: (هم الذين اعتذروا بالكذب) {15}، ونحو هذا قال محمد بن إسحاق: (هم أعراب من غفار، اعتذروا فلم يعذرهم الله) {27}.فإن قيل على هذا: إذا كانوا مقصرين فلم أفردوا من الكاذبين الله ورسوله؟والجواب عن هذا ما أخبرني العروضي {28} عن الأزهري قال أخبرني المنذري عن ابن فهم {29} عن محمد بن سلام {30} عن يونس النحوي أنه سأله عن قوله: ﴿وَجَاءَ الْمُعَذِّرُونَ﴾، قال: قلت ليونس (المعذرون) مخففة كأنها أقيس؛ لأن المعذر الذي له عذر، والمعذر الذي يعتذر ولا عذر له، فقال يونس: (قال أبو عمرو {31} بن العلاء: كلا الفريقين كان {32} مسيئًا، جاء قوم فعذروا، وجلح {33} آخرون فقعدوا) {34}، يريد أن قومًا تكلفوا عذرًا بالباطل، فهم الذين عناهم {35} الله بقوله: ﴿وَجَاءَ الْمُعَذِّرُونَ﴾ وتخلف آخرون {36} من غير تكلف عذر وإظهار علة جرأة على الله ورسوله، وهو معنى قوله: وجلح آخرون فقعدوا).وقوله تعالى: ﴿وَقَعَدَ الَّذِينَ كَذَبُوا اللَّهَ وَرَسُولَهُ﴾، قال عطاء عن ابن عباس: (يريد لم يصدقوا نبيه واتخذوا إسلامهم جنة) {37}، فبان بهذا أنه ليس يريد الكذب في العذر إنما يريد كذبهم في قولهم {38}: إنا مؤمنون."
  9,91,"ثم ذكر الله تعالى أهل العذر فقال: ﴿لَيْسَ عَلَى الضُّعَفَاءِ﴾، قال ابن عباس: (يريد الزمنى والمشايخ والعجزة) {1}، ﴿وَلَا عَلَى الْمَرْضَى وَلَا عَلَى الَّذِينَ لَا يَجِدُونَ مَا يُنْفِقُونَ حَرَجٌ﴾ يعني المقلين من المؤمنين، ﴿إِذَا نَصَحُوا لِلَّهِ وَرَسُولِهِ﴾، قال ابن عباس: (يريد لم يعدلوا بالله شيئاً، وعرفوا الله بتوحيده، وأن ما جاء به محمد ﷺ حق وصدق، وغضبوا لله ورسوله، وأبغضوا من أبغض الله وأحبوا أولياء {2} الله) {3}، ففسر ابن عباس النصح لله ورسوله بما ذكر.وقال أهل المعاني: (معنى النصح إخلاص العمل من الغش) {4}، ومنه التوبة النصوح، فمعنى: ﴿نَصَحُوا لِلَّهِ وَرَسُولِهِ﴾ أخلصوا أعمالهم من الغش والنفاق لهما.وفائدة قوله: ﴿إِذَا نَصَحُوا لِلَّهِ وَرَسُولِهِ﴾ بعدما ذكر عذرهم أن المعذور يكون على قسمين: أحدهما فريق منهم يغتنمون عذرهم، فهؤلاء [ليسوا ممن نصح لله ورسوله، وفريق يتمنون أن لم يكن لهم عذر فيتمكنوا من الجهاد، فهؤلاء] {5} هم {6} الذين نصحوا لله ورسوله، وهم الذين أرادهم الله بقوله: ﴿مَا عَلَى الْمُحْسِنِينَ مِنْ سَبِيلٍ﴾، قال ابن عباس: (من إثم) {7}.وقال أهل المعاني: (من طريق العقاب) {8}، يعني أنه قد سد بإحسانه طريق العقاب على نفسه.﴿وَاللَّهُ غَفُورٌ رَحِيمٌ﴾، قال ابن عباس: (يريد لمن كان على هذه الخصال) {3}."
  9,92,"قوله تعالى: ﴿وَلَا عَلَى الَّذِينَ إِذَا مَا أَتَوْكَ لِتَحْمِلَهُمْ﴾، قال المفسرون: (نزلت هذه الآية في البكائين) {1}، قال ابن عباس {2} ومقاتل {3} ومحمد بن كعب {4} ومحمد بن إسحاق {5}: (هم سبعة نفر من قبائل شتى، وذكروا أسماءهم {6}.وقال مجاهد {7}: (هم ثلاثة إخوة: معقل {8} وسويد {9} والنعمان {10} بنو مقرن، سألوا رسول الله -ﷺ- أن يحملهم على الخفاف المرقوعة والنعال المخصوفة ليغزوا، فقال النبي -ﷺ-: ""لا أجد ما أحملكم عليه"" فتولوا وهم يبكون) {11}، وقال ابن عباس: (سألوه أن يحملهم على الدواب، فقال النبي -ﷺ-: ""لا أجد ما أحملكم عليه"" {12} لأن الشقة بعيدة، والرجل يحتاج إلى بعيرين بعير يركبه، وبعير يحمل ماءه وزاده.وقال الحسن: نزلت في أبي موسى الأشعري وأصحابه أتوا رسول الله ﷺ يستحملونه، ووافق ذلك منه غضبًا فقال: ""والله لا أحملكم ولا أجد ما أحملكم عليه"" فتولوا يبكون، فدعاهم رسول الله -ﷺ- وأعطاهم ذودًا {13} غر الذرى {14}، فقال أبو موسى: ألست حلفت {15} يا رسول الله؟ فقال: ""أما إني [إن شاء الله] {16} لا أحلف بيمين {17} فأرى غيرها خيرًا منها إلا أتيت الذي هو خير وكفرت عن يميني"" {18}.وقوله تعالى: ﴿قُلْتَ لَا أَجِدُ مَا أَحْمِلُكُمْ﴾ [قال صاحب ""النظم"": (جاء قوله: ﴿قُلْتَ لَا أَجِدُ﴾ مجيء الخبر لقوله: ﴿وَلَا عَلَى الَّذِينَ﴾ وليس بخبر، وإنما هو منسوق على ما قبله، وتأويله: ولا على الذين إذا ما أتوك لتحملهم وقلت لا أجد ما أحملكم عليه] {16} فهو مبتدأ منسوق على ما قبله بغير واو، والجواب في قوله: ﴿تَوَلَّوْا وَأَعْيُنُهُمْ تَفِيضُ مِنَ الدَّمْعِ حَزَنًا﴾ ومعناه جرت أعينهم من {20} امتلاء من {15} حزن في قلوبهم)."
