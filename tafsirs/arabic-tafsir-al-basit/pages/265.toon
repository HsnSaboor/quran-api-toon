tafsir[18]{c,v,t}:
  15,52,"﴿إِذْ دَخَلُوا عَلَيْهِ فَقَالُوا سَلَامًا﴾ أي: سلموا سلامًا، فقال إبراهيم: ﴿إِنَّا مِنْكُمْ وَجِلُونَ﴾ مختصر، وشرحه في قوله: ﴿قَالُوا سَلَامًا قَالَ سَلَامٌ فَمَا لَبِثَ أَنْ جَاءَ بِعِجْلٍ﴾ [هود: 69] إلى قوله: ﴿وَأَوْجَسَ مِنْهُمْ خِيفَةً﴾ [هود: 70] وقد مر، والوجل: الفزع، قال الكسائي: ومثله الواجل {1}."
  15,54,"قوله تعالى: ﴿قَالَ أَبَشَّرْتُمُونِي عَلَى أَنْ مَسَّنِيَ الْكِبَرُ﴾ معنى (على) هاهنا الحال؛ أي: على حالة الكبر، كقول النابغة:على حِينَ عَاتَبْتُ المَشِيبَ على الصِّبَا {1}أي: في ذلك الوقت، ومعنى: ﴿مَسَّنِيَ الْكِبَرُ﴾ أي: بتغييره إيّاي عن حال الشباب التي أطمع فيها الولد إلى حال الهَرَمِ.وقوله تعالى: ﴿فَبِمَ تُبَشِّرُونَ﴾ استفهام تعجب؛ كأنه عجيب من الولد على كبره، هذا معنى قول مجاهد {2}، وفَتْحُ النون في (تُبَشِّرُونَ) قرأه العامة {3}، وهذه النون علامة للرفع، والفعل غير معدى إلى مفعول، وقرأ نافع بكسر النون {4}، وذلك أنه عُدِّي إلى المضمر المنصوب؛ لأن المعنى عليه، فاجتمع نونان {5}؛ إحداهما التي هي علامة للرفع، والثانية المتصلة بالياء التي المضمر المنصوب المتكلم، فاستثقل النونين فحذف أحدهما وأبقى الكسرة التي تدل على الياء المفعولة {6}، وأنشد أبو عبيدة لأبي حَيّة النُّمَيريّ:أبِالمَوْتِ الذي لا بُدّ أنّي ... مُلاقٍ لا أبَاكِ تُخَوِّفِينِي {7} فأسقط النون التي هي علامة التأنيث في المخاطبة {8}، وأنشد الفراء والزجاج {9}:تراه كالثَّغَامِ يُعَلُّ مِسْكًا ... يَسُوءُ الفَالِياتِ إذا فَلَيْنِي {10}أراد فلينني، فحذف إحدى النونين، قالا: والحذف بعد إدغام إحدى النونين (في الأخرى) {11} كقراءة ابن كثير: (تُبْشِرُون)، ثم حذفت إحداهما لثقل التضعيف كما قالوا: رُبمَّا ورُبَمَا {12}، وكما قالوا: إنْك في إنَّك، أنشد الفراء {13}: لقد عَلِمَ الضَّيْفُ والمُرْمِلونَ ... إذا اغْبرَّ أُفْقٌ وهبَّتْ شَمَالابأنْكَ الرَّبِيعُ وغَيْثٌ مَرِيعٌ ... وقِدْمًا هُنَاكَ تَكونُ الثِّمَالا {14}قال أبو علي: المحذوف النون الثانية؛ لأن التكرير بها وقع، ولم تحذف الأولى التي هي علامة للرفع، وقد حذفوا هذه النونَ في كلامهم لأنها زائدة، ولأن علامةَ الضمير الياءُ دونها، ونظيرُ حذفهم لها من المنصوب حذفهم لها من المجرور في قولهم {15}:قَدْنِي مِنْ نَصْرِ الخُبَيْبَين قَدِي {16} فحذف وأثبت في بيت، وقال الأعشى في حذف هذه النون اللاحقة مع الياء:فهل يَمْنَعنّي ارْتِيَادِي البلادَ .... من حَذَرِ المَوْتِ أنْ يأتيَنْ {17}وإنّما هو يمنعَنّني {18}، وأما ابن كثير فإنه أدغم ولم يحذف {19}."
  15,55,"قوله تعالى: ﴿قَالُوا بَشَّرْنَاكَ بِالْحَقِّ﴾ قال ابن عباس: يريد بما قضاه الله {1}؛ يريد أن الله تعالى قضى أن يخرج من ذريته مثل ما أخرج من صلب آدم وأكثر، وذلك أن إسحاق كان هو الذي بُشّر به إبراهيم، ومن نسله جميعُ بني إسرائيل على كثرتهم.وقوله تعالى: ﴿فَلَا تَكُنْ مِنَ الْقَانِطِينَ﴾ أي من الآيسين، والقنوط: الإياس من الخير، وهذا يدل على يأس إبراهيم من الولد واستبعاده ذلك على الكبر."
  15,56,"قوله تعالى: ﴿وَمَنْ يَقْنَطُ﴾ وقُرئ ﴿يَقْنَطُ﴾ بفتح النون {1}، قال أبو علي: قنط يَقْنَطُ أعلى اللغات يدل على ذلك اجتماعهم في قوله: ﴿مِنْ بَعْدِ مَا قَنَطُوا﴾ {2} [الشورى: 28]، وحكاية أبي عبيدة تدل أيضًا على أن قَنَطَ أكثر {3}؛ لأن مضارع فَعَل (يجيء على يَفعِل ويَفعُل؛ مثل: فَسَق يَفْسِقُ يَفْسُقُ، ولا يجيء مضارع فَعِل) {4} على يَفْعُلُ {5}.قال ابن عباس: يريد: ومن ييئس {6} من رحمة ربه إلا المكذبون {7}، وهذا يدل على أن إبراهيم لم يكن قانطًا، ولكنه استبعد ذلك، فظنت الملائكةُ به قنوطًا، فنفى ذلك عن نفسه، وأخبر أن القانط من رحمة الله ضال."
  15,57,"قوله تعالى: ﴿قَالَ فَمَا خَطْبُكُمْ﴾ قال الكلبي: فما بالكم وما الذي جئتم له {1}."
  15,58,"﴿قَالُوا إِنَّا أُرْسِلْنَا إِلَى قَوْمٍ مُجْرِمِينَ﴾ يعنون: قوم لوط."
  15,59,"﴿إِلَّا آلَ لُوطٍ﴾ استثنى ليس من الأول {1}، وآلُ لوط: أتباعه والذين كانوا على دينه."
  15,60,"وقوله تعالى: ﴿إِلَّا امْرَأَتَهُ﴾ استثناء من الضمير في ﴿لَمُنَجُّوهُمْ﴾ فعادت إلى القوم المجرمين؛ لأنه استثناء بعد استثناء، فتعود إلى المستثنى منه أولاً؛ كما تقول: لفلان عليّ خمسة إلا درهمين إلا درهمًا، فيصير هذا إقرارًا بأربعة {1}.وقوله تعالى: ﴿قَدَّرْنَا إِنَّهَا لَمِنَ الْغَابِرِينَ﴾ معنى التقدير في الغة: جعل الشيء على مقدار غيره، يقال: قَدِّر هذا الشيء بهذا، أي: اجعله على مقداره {2}، وقدَّر الإلهُ الأقواتَ، أي: جعلها على مقدار الكفاية، ثم يفسر التقدير بالقضاء؛ فيقال: قضى الله عليه كذا، وقدَّره عليه؛ أي: جعله على مقدار ما يكفي في الخير والشر، وقيل في معنى قدّرنا هاهنا: كتبنا {3}، وحكى الزجاج: دبَّرنا {4}، وقيل: قضينا {5}، وقرأ عا صم في رواية أبى بكر {6}: ﴿قَدَّرْنَا﴾ مخففًا {7}، يقال: قدَّرت الشيء وقدْرته، قال الهذلي:ومفْوِهَةِ عَنْسٍ قَدَرْتُ لساقِها ... فخرَّتْ كما تَتَّايَعُ الرِّيحُ بالقَفْلِ {8}المعنى: قَدَّرْتُ ضربتي لساقها فضربتها {9} فخرت، ومن هذا قراءة ابن كثير ﴿نَحْنُ قَدَّرْنَا بَيْنَكُمُ الْمَوْتَ﴾ [الواقعة: 60]، خفيفًا {10}، وقراءة الكسائي ﴿وَالَّذِي قَدَّرَ فَهَدَى﴾ {11} [الأعلى: 3]، والمشددة في هذا المعنى أكثر استعمالاً، كقوله ﴿وَقَدَّرَ فِيهَا أَقْوَاتَهَا﴾ [فصلت: 10]، وقوله: ﴿وَخَلَقَ كُلَّ شَيْءٍ فَقَدَّرَهُ تَقْدِيرًا﴾ [الفرقان: 2].وقوله تعالى: ﴿إِنَّهَا لَمِنَ الْغَابِرِينَ﴾ في موضع مفعول التقرير، والمعنى: قضينا أنها تتخلف وتبقى مع من يبقى حتى تهلك كما يهلكون، ولا تكون ممن يسري مع لوط فينجو."
  15,61,"قوله تعالى: ﴿فَلَمَّا جَاءَ آلَ لُوطٍ الْمُرْسَلُونَ﴾ قال أهل المعاني: يعني جاء لوطًا؛ كما قال في سورة هود؛ في ذكر هذه القصة: ﴿وَلَمَّا جَاءَتْ رُسُلُنَا لُوطًا﴾ [هود: 77] وآل الرجل يُذْكَر والمراد به الرجل، كما ذكرنا في قوله ﴿مِمَّا تَرَكَ آلُ مُوسَى وَآلُ هَارُونَ﴾ [البقرة: 248]"
  15,62,"وقوله تعالى: ﴿إِنَّكُمْ قَوْمٌ مُنْكَرُونَ﴾ أي: غير معروفين؛ لأنهم أتوه على صورة رجال مرد حِسان {1} الوجوه فلم يعرفوهم، فلم يعرفهم لوط، وذكرنا معنى الإنكار عند قوله: ﴿نَكِرَهُمْ﴾ [هود: 70]."
  15,63,"وقوله تعالى: ﴿قَالُوا بَلْ جِئْنَاكَ بِمَا كَانُوا فِيهِ يَمْتَرُونَ﴾ أي: بالعذاب الذي كانوا فيه يَشُكّون في نزوله على من كَذَّبك، أن المعذب بهذا العذاب الذي جئتنا به هم لا أنت، ومعنى (بل) هاهنا نفي؛ لإنكار لوط إيَّاهم، أي: دع ذلك فإنا رسل ربك جئناك {1} بعذابهم، فلما بَيَّنُوا له الأمر عرفهم."
  15,64,"وقوله تعالى: ﴿وَأَتَيْنَاكَ بِالْحَقِّ﴾ قال الكلبي: بالعذاب {1}، وقيل باليقين {2}، والمعنى: بالأمر الثابت الذي لا شك فيه من عذاب قومك."
  15,65,"قوله تعالى ﴿فَأَسْرِ بِأَهْلِكَ بِقِطْعٍ مِنَ اللَّيْلِ﴾ مفسَّر في سورة هود {1}.وقوله تعالى: ﴿وَاتَّبِعْ أَدْبَارَهُمْ﴾ قال ابن عباس: يقول للوط أَتبع آثار بناتك وأهلك لئلا يتخلف منهم أحد فينالَه العذاب {2}، وكذلك قيل: ﴿وَلَا يَلْتَفِتْ مِنْكُمْ أَحَدٌ﴾ قال الكلبي: يعني لا يتخلف منكم أحد {3}، وقال الزجاج: لئلا يرى عظيم ما ينزل بهم من النبلاء {4}، وقال غيره: معناه الإسراع وترك الاهتمام لِمَا خَلَّفَ وراءه {5}، كما يقول: امض لشأنك ولا تُعرِّج على شيء، وهذا مما تقدَّم في سورة هود {1}.وقوله تعالى: ﴿وَامْضُوا حَيْثُ تُؤْمَرُونَ﴾ قال ابن عباس: يعني الشام {7}، وقال المفضل: حيث يقول لكم جبريل {8}، قال الكلبي: أمرهم جبريل امضوا إلى صُغَر {9}؛ وهي إحدى قريات لوط {10}، ولم يكونوا يعملون مثل عمل سدوم، وهذا قول مقاتل {11}."
  15,66,"قوله تعالى: ﴿وَقَضَيْنَا إِلَيْهِ﴾ قال المفضل: أي: أوحينا إليه وألهمناه {1}، وقال بعضهم: وفرغنا إلى لوط من ذلك الأمر {2}، يقال. قضيت الأمر، إذا فرغت منه وأتممته، وقد ذكرنا ذلك في قوله: ﴿وَإِذَا قَضَى أَمْرًا﴾ في سورة البقرة {3}، وقال ابن قتيبة: أي أخبرناه {4}.وقال صاحب النظم: أي فرغنا منه {5}، كقوله ﴿ثُمَّ اقْضُوا إِلَيَّ﴾ [يونس: 71] وقد مرّ، ويقال: إن معنى ﴿وَقَضَيْنَا إِلَيْهِ﴾: من الخبر؛ كقوله: ﴿وَقَضَيْنَا إِلَى بَنِي إِسْرَائِيلَ في الْكِتَابِ﴾ [الإسراء: 4] أي: أخبرناهم به.وقوله تعالى: ﴿ذَلِكَ الْأَمْرَ﴾ أي: الأمر الذي أعلمناه إبراهيم أنّا نهلكهم، في قوله: ﴿إِنَّا أُرْسِلْنَا إِلَى قَوْمٍ مُجْرِمِينَ﴾، فأومأ في قصة لوط إلى ما أخبر به إبراهيم من إهلاك قوم لوط، ثم ترجم قوله: ﴿ذَلِكَ الْأَمْرَ﴾ بقوله: ﴿أَنَّ دَابِرَ هَؤُلَاءِ مَقْطُوعٌ مُصْبِحِينَ﴾ قال الزجاج: موضع (أن) نصب، وهو بدل من قوله: ﴿ذَلِكَ الْأَمْرَ﴾ لأنه فَسّر الأمر بقوله: ﴿أَنَّ دَابِرَ﴾ {6} المعنى: وقضينا إليه أن دابر هؤلاء مقطوع، ونحو هذا قال الفراء والكسائي {7}.قال ابن عباس: يريد أن هلاكهم في الصبح {8}، ومضى الكلام في الدابر {9}."
  15,67,"قوله تعالى: ﴿وَجَاءَ أَهْلُ الْمَدِينَةِ﴾ يعني مدينة لوط؛ وهي سدوم، ﴿يَسْتَبْشِرُونَ﴾ قال الكلبي وغيره: بعملهم الخبيث طمعًا منهم في ركوبهم الفاحشة {1}.قال ابن عباس: قالوا نزل بلوط ثلاثة مرد ما رأينا قط أصبح منهم، فقال لهم لوط لما قصدوا أضيافه:"
  15,68,"﴿إِنَّ هَؤُلَاءِ ضَيْفِي فَلَا تَفْضَحُونِ﴾ يقال: فضحه يفضحه فضحًا وفضيحة، إذا أبان من أمره ما يلزمه به العار، (يقال: فضحه فافْتَضَحَ {1}، قال الفراء) {2}: ويقال فَضَحَك الصبح، أي: بَيّنك للناس {3}، قال المفسرون: أراد أن من حق الضيف إكرامُه، فلا تفضحوني بقصدكم إيّاه بالسوء {4}، والكريم يحافظ على ضيفه ويحامي عنه، وقال المفضل: لما دَقُّوا على لوط بابَه {5} أشرف عليهم وقال: هؤلاء ضيفي فلا تفضحوني عندهم، فيعلموا أنه ليس لي عندكم قَدْر {6}."
  15,69,"وقوله تعالى: ﴿وَاتَّقُوا اللَّهَ وَلَا تُخْزُونِ فِي ضَيْفِي﴾ مذكور وفي سورة هود {1}."
  15,70,"فقالوا له: ﴿قَالُوا أَوَلَمْ نَنْهَكَ عَنِ الْعَالَمِينَ﴾ قال الكلبي وأكثر المفسرين: المعنى: أولم ننهك أن تَضِيف أحدًا من العالمين {1}، قال الزجاج: معناه: أولم ننهك عن ضيافة العالمين {2}، قال المفضل: أولم ننهك أن تُدخل أحدًا بيتك؛ لأنّا نريد منهم الفاحشة {3}، والتفسير ذكره الكلبي، وتوجيه الكلام ذكره الزجاج، والمعنى ذكره المفضل، وقال ابن عباس في رواية عطاء: لا تتعرض لنا في شيء مما نريد؛ يعني أنهم قالوا نهيناك أن تكلمنا في أحد من الناس إذا قصدناه بالفاحشة، فيكون التقدير على هذا المعنى: أولم ننهك عن منع العالمين أو حفظهم أو حمايتهم، فقال لهم لوط:"
