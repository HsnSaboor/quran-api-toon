tafsir[6]{c,v,t}:
  6,132,"قوله تعالى: ﴿وَلِكُلٍّ دَرَجَاتٌ مِمَّا عَمِلُوا﴾ الآية. قال ابن عباس: (يريد: فضائل مما عملوا ﴿وَمَا رَبُّكَ بِغَافِلٍ عَمَّا يَعْمَلُونَ﴾ يريد: عمل المشركين والدرجات للمؤمنين {1}، فعلى هذا أثبت الدرجات للمؤمنين في {2} أول الآية وأوعد المشركين بأنه ليس ﴿بِغَافِلٍ عَمَّا يَعْمَلُونَ﴾ في آخر الآية على معنى: أنه يجازيهم به، وتقدير الآية: ولكل عاملٍ بطاعة الله درجات جزاء من أجل ما عملوا، وقال آخرون: (هذا عام في كل عامل {3} عملًا طاعة كان أو معصية {4} على تقدير: ولكل عامل بطاعة الله أو معصيته {5} منازل في عمله). ومثلت الأعمال {6} بالدرجات ليتبين أنه وإن عمّ أحد قسميها صفة الحسن، وعمّ الآخر صفة القبح، فليست في المراتب سواء، وأنه بحسب ذلك يقع الجزاء، فالأعظم من العقاب للأعظم من السيئات، والأعظم من الثواب للأعظم من الحسنات، وجملة معنى الآية: أن بعضهم أوفر وأجزل ثوابًا من بعض على قدر أعمالهم، وبعضهم أشدّ عذابًا من بعض {7} على قدر أعمالهم في الدنيا {8}.وقوله تعالى: ﴿وَمَا رَبُّكَ بِغَافِلٍ عَمَّا يَعْمَلُونَ﴾ أي: لا يفوته شيء منها ولا من مراتبها حتى يجازي عليه بما يستحق من الجزاء {9}."
  6,133,"قوله تعالى: ﴿وَرَبُّكَ الْغَنِيُّ﴾. قال ابن عباس: (يريد: عن عبادة من تولى غيره) {1}، وقال مقاتل: (عن عبادة خلقه) {2}، ومعنى الغنى عن الشيء: أنه الذي يستوي عنده عدم ذلك الشيء ووجوده {3}.وقوله تعالى: ﴿ذُو الرَّحْمَةِ﴾. قال ابن عباس: (بأوليائه وأهل طاعته) {4}، وقال الكلبي: (ذو الرحمة بخلقه، وذو التجاوز) {5}، وقال مقاتل: (ذو النعمة فلا يعجل {6} عليهم بالعذاب، -يعني: كفار مكة-).وقوله تعالى: ﴿وَيَسْتَخْلِفْ مِنْ بَعْدِكُمْ مَا يَشَاءُ﴾. قال الكلبي: (وينشئ من بعدكم خلقًا آخر) {7} ﴿كَمَا أَنْشَأَكُمْ﴾ مثل ما أنشاكم، أي: خلقكم ابتداء ﴿مِنْ ذُرِّيَّةِ قَوْمٍ آخَرِينَ﴾ -يعني: آباءهم الماضين-، وهذا وعيد لهم بالإهلاك {8}."
  6,134,"قوله تعالى: ﴿إِنَّ مَا تُوعَدُونَ لَآتٍ﴾. قال الحسن: (أي: من مجيء الساعة؛ لأنهم كانوا يكذبون بالنشأة الثانية) {1}، فيجوز أن يكون (توعدون) من الإيعاد: أي ما توعدون به من العقوبة في الآخرة، ويجوز أن يكون من الوعد، لاختلاط الخير بالشر، فيكون على التغليب، إذ مجيء الساعة خير للمؤمنين، وشر على الكافرين، وقوله تعالى: ﴿وَمَا أَنْتُمْ بِمُعْجِزِينَ﴾ أي: بفائتين: يقال: أعجزني فلان، أي: فاتني وغلبني فلم أقدر عليه {2}.قال ابن عباس: (يريد: وما يعجزني منكم أحد) {3}."
  6,135,"قوله تعالى: ﴿قُلْ يَا قَوْمِ اعْمَلُوا عَلَى مَكَانَتِكُمْ﴾. قال ابن عباس في رواية عطاء: (يريد: على حالاتكم التي أنتم عليها) {1}، قال الزجاج: (المعنى: اعملوا على ما أنتم عليه، يقال للرجل إذا أمرته أن يثبت على حاله: على مكانتك يا فلان، أي: أثبت على ما أنت عليه) {2}.وقال مقاتل: (على جديلتكم) {3}، وهذا القول راجع إلى ما ذكرنا؛ لأن الجديلة {4} معناها: الطريقة، والطريقة يراد بها هاهنا: ما هم عليها، ومثل هذا قول مجاهد: (على وتيرتكم) {5}، وقول الكلبي: (على منازلكم) {6} وقول يمان: (على مذاهبكم) {7}.وقال أبو إسحاق: (المعنى: اعملوا على تمكنكم وجهتكم التي كنتم عند أنفسكم في العلم بها) {8}.قال أبو علي: (المكانة في اللغة: المنزلة والتمكن، كأنه اعملوا على قدر منزلتكم وتمكنكم في دنياكم فإنكم لن تضرونا {9} بذلك شيئًا) {10}، قال ابن عباس: (وهذا وعيد وتهدد) {11}، يريد: أن هذا الأمر أمر وعيدٍ، كقوله تعالى: ﴿وَقُلْ لِلَّذِينَ لَا يُؤْمِنُونَ اعْمَلُوا عَلَى مَكَانَتِكُمْ إِنَّا عَامِلُونَ﴾ [هود: 121].قال الزجاج: (ومعنى هذا الأمر: المبالغة في الوعيد؛ لأن ما بعده يدل على الوعيد، وقد أعلمهم بقوله: ﴿لَا يُفْلِحُ الظَّالِمُونَ﴾ أن من عمل بعملهم فالنار مصيره، فكأنه قيل لهم: أقيموا على ما أنتم عليه من الكفران رضيتم بعذاب النار) {12}.وقرئ (مكانتكم) و (مكاناتكم) {13}، والوجه الإفراد؛ لأنه مصدر، والمصادر في أكثر الأمر مفردة، وقد تجمع في بعض الأحوال، والأمر العامّ على الوجه الأول {14}.وقوله تعالى: ﴿إِنِّي عَامِلٌ﴾. قال مقاتل: (أي: عامل على جديلتي التي أمرت بها) {3}، يريد ﴿اعْمَلُوا عَلَى مَكَانَتِكُمْ إِنِّي عَامِلٌ﴾ على مكانتي: فحذفت الثانية لدلالة الأولى في ذلك الجانب على الثانية في هذا الجانب، وجملة المعنى: اعملوا ما أنتم عاملون إني عامل مما أمرني به ربي ، ﴿فَسَوْفَ تَعْلَمُونَ مَنْ تَكُونُ لَهُ عَاقِبَةُ الدَّارِ﴾ موضع (من) نصب بوقوع العلم عليه، ويجوز أن يكون رفعًا على معنى: تعلمون أينا ﴿تَكُونُ لَهُ عَاقِبَةُ الدَّارِ﴾ كقوله: ﴿لِنَعْلَمَ أَيُّ الْحِزْبَيْنِ﴾ [الكهف: 12]، والوجهان ذكرهما الفراء {16}.قال ابن عباس: (﴿مَنْ تَكُونُ لَهُ عَاقِبَةُ الدَّارِ﴾ يعني: الجنة. ﴿فَسَوْفَ تَعْلَمُونَ﴾ من له الجنة أنتم أم أوليائي وأهل طاعتي) {17}، فإن قيل: أليس الكافر أيضًا له عاقبة في الآخرة، فكيف قيل: إن {18} عاقبة الدار للمؤمنين؟ قيل: العاقبة تكون على الكافر ولا تكون له، كما يقال: لهم الكرة، ولهم الظفر، وفي ضده يقال: عليهم الكرة والظفر {19}.وقرئ {20}: (تكون) بالتاء، والياء؛ لأن العاقبة مصدر كالعافية، وتأنيثه غير حقيقي فمن أنث فكقوله: ﴿فَأَخَذَتْهُمُ الصَّيْحَةُ﴾ [الحجر: 73] ومن ذكر فكقوله: ﴿وَأَخَذَ الَّذِينَ ظَلَمُوا الصَّيْحَةُ﴾ [هود: 67]، وقال تعالى: ﴿قَدْ جَاءَتْكُمْ مَوْعِظَةٌ﴾ [يونس: 57] وفي أخرى: ﴿فَمَنْ جَاءَهُ مَوْعِظَةٌ﴾ [البقرة: 275] {21}، وقوله تعالى: ﴿إِنَّهُ لَا يُفْلِحُ الظَّالِمُونَ﴾. قال ابن عباس: (يريد: لا يسعد من كفر نعمتي وأشرك بي) {22}."
  6,136,"قوله تعالى: ﴿وَجَعَلُوا لِلَّهِ مِمَّا ذَرَأَ مِنَ الْحَرْثِ وَالْأَنْعَامِ نَصِيبًا﴾ الآية، قال ابن عباس {1} والمفسرون {2}: (كان المشركون يجعلون لله من حروثهم وأنعامهم وثمارهم نصيبًا ، وللأوثان نصيبًا، فما كان للصنم أنفق عليه، وما كان لله أطعم الضيفان {3} والمساكين، ولا يأكلون من ذلك كله شيئًا، فما سقط مما جعلوه لله في نصيب الأوثان تركوه، وقالوا: إن الله غني عن هذا، وإن سقط مما جعلوه للأوثان في نصيب الله التقطوه وردّوه إلى نصيب الصنم، وقالوا: إنه فقير. فذلك قوله: ﴿وَجَعَلُوا لِلَّهِ مِمَّا ذَرَأَ﴾). قال ابن عباس: (خلق، ﴿مِنَ الْحَرْثِ﴾ قال: يريد التمر والقمح، وجميع ما يؤكل، (الأنعام) يريد: الضأن والماعز والإبل والبقر، ﴿نَصِيبًا فَقَالُوا هَذَا لِلَّهِ بِزَعْمِهِمْ﴾ يريد: بكذبهم) {4}.وقد ذكرنا تفسير الزُّعم {5} والزَّعم في سورة النساء [: 60].فإن قيل: أليس جميع الأشياء لله فكيف نسبوا إلى الكذب في قولهم: ﴿هَذَا لِلَّهِ﴾؟ قلنا: إفرازهم النصيبين نصيبًا لله، ونصيبًا للشيطان، وحكمهم بذلك كذب منهم {6} لم يأمر الله تعالى به، وهم كانوا يفعلون ذلك تدينًا وتعبدًا واعتقادًا أن ذلك أمر به {7} الله تعالى وأنه يرضى به {8}، قال الزجاج: (وتقدير الكلام: جعلوا لله نصيبًا ولشركائهم نصيبًا، ودل على هذا المحذوف تفصيله القسمين فيما بعد، وهو قوله: ﴿هَذَا لِلَّهِ بِزَعْمِهِمْ وَهَذَا لِشُرَكَائِنَا﴾) {9}، وجعل الأوثان شركاءهم؛ لأنهم جعلوا لها نصيبًا من أموالهم ينفقونها عليها فشاركوها في مالهم {10}.وقوله تعالى: ﴿فَمَا كَانَ لِشُرَكَائِهِمْ فَلَا يَصِلُ إِلَى اللَّهِ وَمَا كَانَ لِلَّهِ فَهُوَ يَصِلُ إِلَى شُرَكَائِهِمْ﴾ معناه ما ذكرنا عن ابن عباس {11}: أنه كان إذا اختلط شيء مما جعلوه لله بما جعلوه للأوثان لم يخرجوه ولم يردوه، وإذا كان على الضد ردّوه.وقال الحسن {12} والسدّي {13}: (هو أنه إذا هلك الذي لأوثانهم أخذوا بدله مما لله، ولا يفعلون مثل ذلك فيما لله عز وجل).وقال مجاهد: (هو أنه إذا انفجر من سقي ما جعلوه للشيطان في نصيب الله سدوه، وإن كان على ضد ذلك تركوه) {14}، وزاد قتادة: (إذا أصابتهم السنة استعانوا بما جزءوا لله ووفروا ما جزءوا لشركائهم) {15}، وزاد مقاتل: (وإن زكا ونما نصيب الآلهة ولم يترك نصيب الله تركوه للآلهة وقالوا: لو شاء الله زكا نصيبه، وإن زكا نصيب الله ولم يترك نصيب الآلهة قالوا: لا بد لآلهتنا من نفقة فأخذوا نصيب الله فأعطوه السدنة، فذلك قوله: ﴿فَمَا كَانَ لِشُرَكَائِهِمْ﴾ يعني: من تمام الحرث والأنعام ﴿فَلَا يَصِلُ إِلَى اللَّهِ﴾ يعني: إلى المساكين) {16}، وإنما قال: ﴿إِلَى اللَّهِ﴾ لأنهم كانوا يفرزونه لله ويسمونه نصيب الله ﴿وَمَا كَانَ لِلَّهِ﴾ من التمام فهو يصل إلى آلهتهم ثم ذم الله فعلهم فقال: ﴿سَاءَ مَا يَحْكُمُونَ﴾ أي: ساء الحكم حكمهم حيث صرفوا ما جعلوا لله على جهة التبرر للأوثان {17}."
  6,137,"قوله تعالى: ﴿وَكَذَلِكَ زَيَّنَ لِكَثِيرٍ مِنَ الْمُشْرِكِينَ﴾ الآية. قال الزجاج {1}: (أي: ومثل ذلك الفعل القبيح ﴿زَيَّنَ لِكَثِيرٍ مِنَ الْمُشْرِكِينَ قَتْلَ أَوْلَادِهِمْ شُرَكَاؤُهُمْ﴾) {2}، وقال أبو بكر: (وذلك إشارة إلى ما نعاه الله عليهم من قسمهم ما قسموا بالجهل، فكأنه قيل: ومثل ذلك الذي أتوه في القسم جهلًا وخطأً ﴿زَيَّنَ لِكَثِيرٍ مِنَ الْمُشْرِكِينَ﴾ فشبه تزيين الشركاء بخطأهم في القسم) {3}، وهذا معنى قول الزجاج.قال مجاهد {4}: (﴿شُرَكَاؤُهُمْ﴾: شياطينهم أمروهم أن يئدوا أولادهم خشية العيلة) {5}، وسميت الشياطين شركاء؛ لأنهم أطاعوهم في معصية الله فأشركوهم مع الله في وجوب طاعتهم، وأضيفت الشركاء إليهم، لأنهم اتخذوها، كقوله تعالى: ﴿أَيْنَ شُرَكَاؤُكُمُ الَّذِينَ كُنْتُمْ تَزْعُمُونَ﴾ [الأنعام: 22] {6}.وقال الكلبي {7}: (كان لآلهتهم سدنة وخدام هم الذين كانوا يزينون للكفار قتل أولادهم، وكان الرجل يقوم في الجاهلية فيحلف بالله لئن ولد له كذا غلامًا لينحرن أحدهم كما حلف {8} عبد المطلب على ابنه عبد الله) {9}، وعلى هذا القول الشركاء هم: السدنة سمّوها شركاء كما سميت الشياطين شركاء في قول مجاهد {10} والشركاء رفع بالتزيين.ولما تقدم ذكر المشركين كنى عنهم في قوله: (شركاؤهم) كقوله تعالى: ﴿لَا يَنْفَعُ نَفْسًا إِيمَانُهَا﴾ [الأنعام: 158] لما تقدم ذكر النفس كنى عنها، ومثله ﴿وَإِذِ ابْتَلَى إِبْرَاهِيمَ رَبُّهُ﴾ [البقرة: 124] وأضيف المصدر الذي هو القتل إلى المفعولين الذين هم الأولاد كقوله: ﴿مِنْ دُعَاءِ الْخَيْرِ﴾ [فصلت: 49]، أي: من دعائه الخير فحذف ذكر الفاعل، كذلك التقدير في الآية: قتلهم أولادهم {11}.وقرأ ابن عامر {12} (زُيِّنَ) بضم الزاي، (قَتْلَ) رفعًا، (أَوْلَادَهُم) بالنصب، (شُرَكَائِهِم) بالجرّ على تقدير: ﴿زَيَّنَ لِكَثِيرٍ مِنَ الْمُشْرِكِينَ قَتْلَ﴾ شركائهم أولادهم، ولكنه فصل بين المضاف والمضاف إليه بالمفعول به، وهو الأولاد، والمفعول به مفعول المصدر، قال أبو علي: (وهو قبيح، قليل في الاستعمال؛ لأنهم لا يفصلون بين المضاف والمضاف إليه بالظرف الذي توسعوا فيه، وفصلوا به في كثير من المواضع، نحو قوله تعالى: ﴿إِنَّ فِيهَا قَوْمًا جَبَّارِينَ﴾ [المائدة: 22].ونحو قول الشاعر:عَلَى أَنَّني بَعْدَ مَا قَدْ مَضى ... ثلاثُون لِلْهَجرِ حَوْلًا كَمِيلًا {13}[فصل بين العدد والمعدود {14}]، ونحو قوله:فَلا تَلْحَني فيها فإنَّ بِحُبِّهَا ... أَخَاكَ مُصابُ القَلْبِ جَمٌّ بَلابِلُهْ {15} ألا ترى أنه فصل بين أن واسمها بما يتعلق بخبرها ، ولو كان بغير الظرف لم يجز، ألا ترى أنهم لا يجيزون إن زيدًا عمرًا {16} في (أ): (عمروا).]] ضارب إذا نصبت زيدًا (¬2) بضارب {17}، فإذا لم يجيزوا الفصل بين المضاف والمضاف إليه بالظرف في الكلام مع اتساعهم في الظرف في الكلام، وإنما يجوز في الشعر، كقوله:كَمَا خُطَّ الكِتابُ بِكَفِّ يَوْمًا ... يَهودِي يُقَارِبُ أَوْ يُزيلُ {18}فأن لا يجوز في المفعول به الذي لم يتسع فيه بالفصل أجدر، ووجه ذلك على ضعفه وقلة الاستعمال أنه قد جاء في الشعر [الفصل] (¬5) على حد ما قرأه، قال الطرماح: يُطِفْنَ بِحُوزِي المَرَاتِعِ لَمْ يُرَعْ {19} ... بِوَادِيهِ مِنْ قرْعِ القِسِيِّ الكَنَائِنِ {20}وأنشد أبو الحسن {21}:زَجَّ القلوصِ أبي مزَادَةْ {22} وهذان البيتان مثل قراءة ابن عامر، ألا ترى أنه فصل فيهما بين المصدرين والمضاف إليهما بالمفعول به، كما فصل ابن عامر بين المصدر وما حكمه أن يكون مضافًا إليه، وأضيف القتل في هذه القراءة إلى الشركاء وإن لم يتولوا ذلك؛ لأنهم هم الذين زينوا ذلك ودعوا إليه فكأنهم فعلوا ذلك) {23}.وقوله تعالى: ﴿لِيُرْدُوهُمْ﴾. قال ابن عباس: (يريد: في النار) {24}، والإرداء في اللغة: الإهلاك {25} وفي القرآن: ﴿إِنْ كِدْتَ لَتُرْدِينِ﴾ [الصافات: 56].وقوله تعالى: ﴿وَلِيَلْبِسُوا عَلَيْهِمْ دِينَهُمْ﴾. قال ابن عباس: (يدخلوا عليهم الشك في دينهم) {26}، وقال الكلبي: (ليخلطوا ويشبهوا، وكانوا على دين إسماعيل فرجعوا عنه) {27}.وقوله تعالى: ﴿وَ {28} لَوْ شَاءَ اللَّهُ مَا فَعَلُوهُ﴾ أخبر أن جميع ما فعله المشركون كان ذلك بمشيئة الله إذ لو لم يشأ ما فعلوا {29}.وقوله تعالى: ﴿فَذَرْهُمْ وَمَا يَفْتَرُونَ﴾. قال ابن عباس: (يريد: وما يقولون أن لله شريكًا) {30}."
