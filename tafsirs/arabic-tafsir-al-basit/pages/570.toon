tafsir[10]{c,v,t}:
  70,40,"قوله تعالى: ﴿فَلَا أُقْسِمُ﴾ معناه: وأقسم، وقد مر هذا في مواضع {1}.وقوله: ﴿بِرَبِّ الْمَشَارِقِ وَالْمَغَارِبِ﴾ يعني مشرق كل {2} يوم من السنة، ومغربه.﴿إِنَّا لَقَادِرُونَ﴾ على أن نهلكهم حين عصوا.﴿أَنْ نُبَدِّلَ خَيْرًا مِنْهُمْ﴾ من يطيعني. وقال مقاتل: لقادرون على أن نخلق أمثل منهم، وأطوع لله {3}.﴿وَمَا نَحْنُ بِمَسْبُوقِينَ﴾ مفسر في قوله: ﴿وَمَا نَحْنُ بِمَسْبُوقِينَ (60) عَلَى أَنْ نُبَدِّلَ أَمْثَالَكُمْ﴾ {4}.وقوله: ﴿فَذَرْهُمْ يَخُوضُوا﴾ مفسر في آخر سورة الطور {5}.قوله تعالى: ﴿يَوْمَ يَخْرُجُونَ مِنَ الْأَجْدَاثِ سِرَاعًا كَأَنَّهُمْ إِلَى نُصُبٍ يُوفِضُونَ (43)﴾، أي: ينسلون بسرعة، فكأنهم إلى عَلَمٍ نُصِبَ لهم يستبقون، وهذا كقوله: ﴿يَوْمَ يَخْرُجُونَ مِنَ الْأَجْدَاثِ﴾، و ﴿إِلَى رَبِّهِمْ يَنْسِلُونَ﴾ [يس: 51]، وكقوله: ﴿خُشَّعًا أَبْصَارُهُمْ﴾ {6} الآيات.والنصب: كل شيء نُصب. قال ابن عباس: إلى غاية {7}، أو علم يسرعون {8}. وهو [قول] {9} أكثر المفسرين {10}.وقال الحسن: يعني إلى أنصابهم أيهم يستلم أولاً {11}، يعني الأوثان.قال أبو إسحاق: وهذا على قراءة من قرأ: ﴿نَصَبٌ﴾ بضمتين {12}، كقوله: ﴿وَمَا ذُبِحَ عَلَى النُّصُبِ﴾ قال: ومعناه: أصنام لهم {13}.قال أبو علي: (النُصْب) يجوز أن يكون جمع نَصْب مثل: سَقْفٍ، وسُقْفٍ، ووَرْدٍ، ووُرْدٍ، فيجوز فيه التخفيف والتثقيل {2}، مثل: أَسدٍ في جمع أُسَدٍ، قال ويجوز أن يكون النَّصْبُ والنُّصْبُ لغتين مثل: الضَّعْف، والضُّعف، ويكون التثقيل كَشُغْل، وشُغُل، وطُنْب، وطُنُب {15}.والكلام في النصب والأنصاب قد تقدم {16}.وقوله: ﴿يُوفِضُونَ﴾ قال [أبو عبيدة] {17}: يسرعون {18}.ونحو ذلك قال الزجاج {19}، والفراء {20}.وأنشدوا:لأنْعَتَنْ {21} نَعامَةً مِيفاضا ... خَرْجاءَ ظلت تطلُبُ الأضاضا {22}قال الزجاج: الميفاض: السريعة، والأضاض: الموضع الذي يُلْجأ إليه، [يقال] {23}: أضَّتْني إليك حاجةً أضاضا {24}.وقال المبرد: الإيفاض {25}: ضرب من السير {26}.وجميع ألفاظ المفسرين دالة على الإسراع.قال ابن عباس {27}، وقتادة {28}، ومقاتل {26}: يسعون.وقال أبو (العالية) {30}، ومجاهد {31}: يستبقون {32}.وقال الحسن: يبتدرون {33}.وقال محمد بن كعب: يشتدون {26}.وقال الليث: الإبل تَفِضُ وَفْضًا، وتَسْتَوْفِض، وأوفَضَها صاحبها.وعلى هذا الإيفاض واقع، وهو في الآية مطاوع {35}، ويقال: وفض واستوفض بمعنى واحد {36}."
  70,42,"70:41"
  70,43,"70:41"
  70,44,"70:41"
  71,1,"﴿إِنَّا أَرْسَلْنَا نُوحًا إِلَى قَوْمِهِ أَنْ أَنْذِرْ قَوْمَكَ﴾ قال الفراء {1}، والزجاج {2}: (أنْ) في موضع {3} نصب؛ لأنك أسقطت منه الخافض، لأن الأصل بأن أنْذِرْ قَوْمَكَ، فلما سقطت الباء أفضى الفعل إلى (أن) فنصبها.قال أبو إسحاق: ويجوز أن يكون [أنْ] {4} تفسيرًا لما أرسل به، فيكون المعنى {3}: إنا أرسلنا نوحاً إلى قومه أن أنذر قومك {6}.وقوله: ﴿مِنْ قَبْلِ أَنْ يَأْتِيَهُمْ عَذَابٌ أَلِيمٌ﴾ قال الكلبي {7}، ومقاتل {8}: يعني الغرق بالطوفان {9}.قوله: ﴿أَنِ اعْبُدُوا اللَّهَ﴾ (أن) في محل نصب بقوله: [مبين]، أي: أبين لكم. قال مقاتل {10} {11}، والكلبي {12}: وحدوا الله.﴿وَأَطِيعُونِ﴾ في التوحيد {3}."
  71,3,"71:2"
  71,4,"وقوله {1}: ﴿يَغْفِرْ لَكُمْ مِنْ ذُنُوبِكُمْ﴾ قال أبو إسحاق: دخلت (من) تختص الذنوب من سائر الأشياء لم تدخل {2} لتبعيض الذنوب كقوله: ﴿فَاجْتَنِبُوا الرِّجْسَ مِنَ الْأَوْثَانِ﴾ {3} [الحج: 30].وقال غيره {4}: (من) بمعنى: (عن)، والمعنى: يصفح لكم عن ذنوبكم {5}.ويجوز أن يريد: يغفر لكم السالفة من ذنوبكم، وهي بعض الذنوب التي تضاف إليهم، ولما كانت ذنوبهم التي يستأنفونها لا يجوز الوعد بغفرانها على الإطلاق قيدت بهذا التقييد {6}.قال مقاتل: (من) هاهنا صلة، يعني: يغفر لكم ذنوبكم {7}. (ونحوه قال الكلبي {8}) {9}.وقوله تعالى: ﴿وَيُؤَخِّرْكُمْ إِلَى أَجَلٍ مُسَمًّى﴾، قال الفراء: يريد إلى أجل تعرفونه لا يميتكم غرقاً، ولا حرقاً {10}، ولا قتلاً.وليس في هذا حجة لأهل القدر {11} {12}؛ لأنه إنما أراد: مسمى عندكم -قال-، ومثله قوله: ﴿وَهُوَ أَهْوَنُ عَلَيْهِ﴾ [الروم: 27]، أي: عندكم في معرفتكم {13}.قال الزجاج: أي يؤخركم عن العذاب، فتموتوا غير ميتة المُستأصَلين بالعذاب {14}. هذا كلامهما.(وليس فيه ما يَدفع قول أهل {15} القدر؛ لأن ظاهر قوله: ﴿وَيُؤَخِّرَكُمْ إِلَى أَجَلٍ مُسَمًّى﴾ أنهم إذا آمنوا {5} بقوا إلى أجلهم المسمى، وإذا لم يؤمنوا عوجلوا بالعذاب قبل الأجل، والصحيح في هذا ما روى عطاء عن ابن عباس قال: ينسى في أعماركم {17}؛ وذلك أن الله كان قد قضى قبل أن خلقهم، أنهم إن آمنوا بارك الله في أعمارهم {18}، وإن لم يؤمنوا عوجلوا بالعذاب المهلك، فبأي الأجلين {19} هلكوا كان ذلك بقضاء من الله وقدر.هذا معنى قول ابن عباس: (ينسى في أعماركم {20}) {21}.. . . . . . . . . . . . . . . . . . . . . . . .وقال مقاتل: يؤخركم إلى منتهى أجلكم {20} في عافية، فلا يعاقبكم بالسنين ولا بغيره {23}.والمعنى على هذا القول: يؤخركم من العقوبات والشدائد إلى آجالكم، لا من المهلكات.وقوله تعالى: ﴿إِنَّ أَجَلَ اللَّهِ إِذَا جَاءَ لَا يُؤَخَّرُ﴾ يعني أجل الموت، وأجل العذاب، وكل أجل مسمى عند الله لشيء إذا جاء لم يؤخر.والمعنى: آمنوا قبل الموت تسلموا من العقوبات، فإن أجل الموت إذا حل لم يؤخر، فلا يمكنكم الإيمان إذا جاء الأجل."
  71,6,"قوله: ﴿فَلَمْ يَزِدْهُمْ دُعَائِي إِلَّا فِرَارًا (6)﴾ قال مقاتل: يعني تباعداً من الإيمان {1}.وقال قتادة: هو أنه كان الرجل يذهب بابنه إلى نوح فيقول: احذر لا يغرك، فإن أبي قد ذهب بي إليه وأنا مثلك، فحذرني كما حذرتك {2}.وقوله: ﴿وَإِنِّي كُلَّمَا دَعَوْتُهُمْ لِتَغْفِرَ لَهُمْ﴾ قال صاحب النظم: ظاهر هذا أن المغفرة جزاء لدعائهم، وهو في الباطن جزاء.المعنى: هو سبب ادعائهم، وهذا مقتضى من قوله: ﴿قَالَ يَا قَوْمِ إِنِّي لَكُمْ نَذِيرٌ مُبِينٌ (2) أَنِ اعْبُدُوا اللَّهَ وَاتَّقُوهُ وَأَطِيعُونِ (3) يَغْفِرْ لَكُمْ مِنْ ذُنُوبِكُمْ﴾ فالتأويل: وإني كلما دعوتهم لتغفر لهم؛ لأمرهم بعبادة الله واتقائه وطاعته لتغفر لهم.وقوله: ﴿وَاسْتَغْشَوْا ثِيَابَهُمْ﴾ قال ابن عباس: جعلوا ثيابهم على رؤوسهم لئلا يسمعوا كلامي {3}.وقال مقاتل: غطوا رؤوسهم لئلا يسمعوا دعائي {4}."
  71,8,"قوله تعالى: ﴿ثُمَّ إِنِّي دَعَوْتُهُمْ جِهَارًا (8)﴾ قال ابن عباس: بأعلى {1} صوتي {2}.وقال أبو إسحاق: أي دعوتهم مظهرًا لهم الدعوة، و ﴿جَهَارًا﴾ منصوب مصدر موضوع موضع الحال {3} {4}. المعنى: دعوتهم مجاهرًا لهم بالدعاء إلى توحيد الله وتقواه {5}.﴿ثُمَّ إِنِّي أَعْلَنْتُ لَهُمْ﴾ قال مجاهد {6}، (ومقاتل) {7}: صحْت بهم {8}.﴿وَأَسْرَرْتُ لَهُمْ إِسْرَارًا﴾ فيما بيني وبينهم.قال ابن عباس: يريد الرجل بعد الرجل، أكلمه سرًا فيما بيني وبينه {9}، أدعوه إلى عبادتك، وتوحيدك. {10}وقال الزجاج: إني خلطت دُعاءهم بالعلانية بدعاء السر {11}."
  71,10,"قوله تعالى: ﴿فَقُلْتُ اسْتَغْفِرُوا رَبَّكُمْ﴾ قال مقاتل: إن قوم نوح لما كذبوه زماناً طويلاً، جس الله عنهم المطر، وأعقم أرحامَهم أربعين سنة، فهلكت جناتهم، ومواشيهم، فصاحوا إلى نوح، فقال لهم نوح: استغفروا ربكم من الشرك {1}.والمعنى: استدعوا مغفرة ربكم بالتوحيد، وترك الشرك.﴿يُرْسِلِ السَّمَاءَ﴾، أي: ماء السماء، ويجوز أن يكون المراد بالسماء المطر لقوله: ﴿مِدْرَارًا﴾، وهو الكثير الدرّ، والدر تخلّب {2} الشيء حالاً بعد حال، يقال: درت الناقة، ودر اللبن، يدرّ ويدُرّ دَرّاً ودُرُوراً، ودَرت السحاب، ودرّ المطر {3}.قال مقاتل: (مدراراً {4}): متتابعاً {5}.﴿وَيُمْدِدْكُمْ بِأَمْوَالٍ وَبَنِينَ﴾ قال عطاء: يكثر أموالكم، وأولادكم {6}.﴿وَيَجْعَلْ لَكُمْ جَنَّاتٍ﴾ يعني البساتين {7}.﴿وَيَجْعَلْ لَكُمْ أَنْهَارًا﴾ قال مقاتل: كانوا [يسخطون] {8} الله فأهلك كل شيء لهم، ودفنت أنهارهم، فدعاهم نوح إلى توحيد الله، وقال: إنكم إذا وحدتم تصيبوا الدنيا والآخرة {9}.وقال أبو إسحاق {4}: أعلمهم أن إيمانهم بالله يجمع لهم من الحظ الوافر في الآخرة، والخِصْب والغنى في الدنيا {11}.قوله تعالى: ﴿مَا لَكُمْ لَا تَرْجُونَ لِلَّهِ وَقَارًا (13)﴾ الرجاء هاهنا بمعنى الخوف -ذكرنا ذلك فيما تقدم {12} -ومنه قول الهذلي {13}:إذا لَسَعَتْهُ النَّحْلُ لمْ يَرْجُ لسْعَها {14} و (الوقار): العظمة، والتوقير: التعظيم، ومنه قوله تعالى: ﴿وَتُوَقِّرُوهُ﴾ [الفتح: 9] {15}يعني مالكم لا تخافون لله عظمة، وهو قول أبي عبيدة {16}، والفراء {17}، والزجاج {18}، (وابن قتيبة {19}، والكلبي {20}) {21}.وجميع ما قال المفسرون يعود إلى هذا المعنى، روى سعيد بن جبير عن ابن عباس: ما لكم لا تعلمون حق عظمة الله {22} {23}.وقال الحسن: ما لكم لا تعرفون لله حقاً، ولا تشكرونه {24}.وقال مجاهد: لا تُبالون عظمة ربكم {25}.وقال قتادة: لا ترجون لله عاقبة {26}.وقال ابن زيد {27}: لا ترون لله طاعة {28}.ومعنى هذه الأقوال واحد {4}، وهو أنهم لو عظموا الله، وعرفوا حق عظمته، وحدوه، وأطاعوه، وشكروه {4}.وهذا معنى قول مقاتل: فمن {31} لم يوحده لم يعظمه {9}.(والمعنى: لمَ لا تعظمونه فتوحدونه، وقد جعل في أنفسكم {4} آية تدل على توحيده: من خلقه إياكم، ومن خلق السموات والأرضين) {34}، فقال عز وجل: ﴿وَقَدْ خَلَقَكُمْ أَطْوَارًا (14)﴾قال المفسرون: يعني نطفة، ثم علقة، ثم شيئاً بعد شيء {31}، إلى آخر الخلق، وطوراً {31} بعد طور ينقلكم من حال إلى حال {4} {38}.قال الليث: الطور: التارة، تقول: طَوْرًا بعد طَوْرٍ: أي تارة بعد تارة، والناس أطوار، أي: أخياف {39} على حالات شتى {40}.وقال ابن الأنباري: الطور الحال، وجمعه أطوار، وتلا هذه الآية، قال: ومعناها: ضروباً، وأحوالاً مختلفة {41}.(ثم) {21} وعظهم ليعتبروا في صنعه فقال:"
