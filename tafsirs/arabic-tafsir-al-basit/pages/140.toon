tafsir[6]{c,v,t}:
  6,95,"قوله تعالى: ﴿إِنَّ اللَّهَ فَالِقُ الْحَبِّ وَالنَّوَى﴾ الآية، قال ابن عباس في رواية عطاء: (يريد: بالنبات) {1}، قال الكلبي: (الحب ما لم يكن له نوى كالبر والشعير، والنوى: ما لم يكن له حب مثل نوى التمر والخوخ وغيرهما، فلقهما الله بالنبت) {2}.وقال الحسن {3} وقتادة {4} والسدي {5} وابن زيد {6}: (فلق الحبة عن السنبلة والنواة عن النخلة).وقال أبو إسحاق: (أي: يشق الحبة اليابسة والنواة اليابسة فيخرج منهما ورقًا أخضر) {7}، وقال مجاهد {8} وأبو مالك: (يعني: الشقين الذين فيهما) {9}، وروي عن ابن عباس {10} وهو قول الضحاك ومقاتل: ﴿فَالِقُ الْحَبِّ وَالنَّوَى﴾ (أي: خالقهما)، ذهبوا بفالق مذهب فاطر.قال مقاتل: (يعني: خالق الحب البر والشعير والذرة والحبوب كلها، ﴿وَالنَّوَى﴾ يعني: نوى كل ثمرة لها نوى الخوخ والتين والنبق والمشمش والغبيراء {11} والإجاص {12} وما كان من الثمار لها نوى) {13}.قال الليث {14}: (النَّوى: نَوَى التمر وأشباهه من كُلٍّ {15}، والواحدة نواة، ونَوَّت البسرة وأَنْوَت: إذا انعقدت نواتها).وقوله تعالى: ﴿يُخْرِجُ الْحَيَّ مِنَ الْمَيِّتِ وَمُخْرِجُ الْمَيِّتِ مِنَ الْحَيِّ﴾ قال ابن عباس: (يخرج من النطفة بشرًا حيًّا ثم يخرج النطفة الميتة من الحي) {16}، وهو قول الكلبي ومقاتل {17}، قال الكلبي: (يخرج النسمة والفروجة {18} والفرخ من النطفة والبيضة، ثم يخرج النطفة والبيضة من الحي) {19}.وقال ابن عباس في رواية عطاء: (يخرج المؤمن من الكافر، والكافر من المؤمن، والعاصي من الطائع) {20}، وهو قول الحسن {21}. وقال السدي: (يخرج النبات عن الحب) {22}، وهذا اختيار أبي إسحاق قال: معنى ﴿يُخْرِجُ الْحَيَّ مِنَ الْمَيِّتِ﴾ يخرج النبات: الغض الطري الخضِر من الحب اليابس، ﴿وَمُخْرِجُ الْمَيِّتِ مِنَ الْحَيِّ﴾ [أي] {23}: ويخرج الحب اليابس من النبات الحي النامي) {24}.وقوله تعالى: ﴿ذَلِكُمُ اللَّهُ فَأَنَّى تُؤْفَكُونَ﴾ قال ابن عباس {25}: (يريد: الله وحده لا شريك له يفعل هذا فكيف [تكذبون]؟) {26}.قال الزجاج: (احتج الله عليهم بما يشاهدونه من خلقه؛ لأنهم أنكروا البعث، فأعلمهم أنه خلق هذه الأشياء، وأنه قادر على بعثهم، ثم قال: ﴿فَأَنَّى تُؤْفَكُونَ﴾ أي: فمن أين تصرفون عن الحق بعد هذا البيان) {7}."
  6,96,"قوله تعالى: ﴿فَالِقُ الْإِصْبَاحِ﴾ الآية: الفَلْق: مصدر فَلَقْتُ أفْلِق فَلْقًا، ويقال: سمعت ذاك من فَلْق {1} فيه، ذكره ابن السكيت {2}، وأما ﴿الْإِصْبَاحِ﴾ فقال الليث {3}: (الصُّبْح والصَّباح هما أول النهار، وهو الإصباح أيضًا، قال الله تعالى: ﴿فَالِقُ الْإِصْبَاحِ﴾ يعني: الصبح، وقال:أَفْنَى رِياحًا وذَوِى رِياحِ ... تَناسُخُ الإِمْسَاءِ وَالإِصْبَاحِ {4}يريد: المساء والصباح). الفراء مثله في الإصباح {5}، وقال الزجاج: (الإصباح والصبح واحد) {6}. وأما التفسير، فقال كثير من أهل التفسير في قوله ﴿فَالِقُ الْإِصْبَاحِ﴾: (شاقّ عمود الصبح عن ظلمة الليل وسواده) {7}، ولا أدري كيف قالوا هذا؛ فإن الليل يشق عن عمود الصبح لا الصبح عن الليل {8}.[وأما] {9} ابن عباس {10} والمحققون {11} قالوا: ﴿فَالِقُ الْإِصْبَاحِ﴾ أي: خالق الإصباح كل يوم جديد).وقال الكلبي: ﴿فَالِقُ الْإِصْبَاحِ﴾: خالق الصباح كل يوم) {12}.وقال أبو إسحاق: ﴿فَالِقُ الْإِصْبَاحِ﴾: (جائز أن يكون خالق الإصباح، وجائز أن يكون معناه: سياق الإصباح، وهو راجع إلى معنى خالق) {6}، وقال في سورة الفلق: (الفلق الخلق، وإذا تأملت الخلق تبين لك أن أكثره عن انفلاق) {14}، وقد ذكرنا هذا المعنى في قوله تعالى: ﴿فَالِقُ الْحَبِّ وَالنَّوَى﴾ [الأنعام:95].وقال الليث: (الله تعالى فلق الصبح، أي: أبدأه وأوضحه) {15}، فعلى هذا المعنى ﴿فَالِقُ الْإِصْبَاحِ﴾: مبديه وموضحه، وذلك أن معنى الفلق راجع إلى الإبداء والإيضاح؛ لأن الفلق يتضمن الإبداء {16}.وقوله تعالى: ﴿وَجَعَلَ اللَّيْلَ سَكَنًا﴾ السكن: معناه في اللغة ما سكنت إليه، يريد: أن الناس يسكنون في الليل سكون الراحة، بأن جعل الله تعالى ذلك لهم سكنًا {17}. قال ابن عباس: (يريد: أن كل ذي روح يسكن فيه) {18}، وقال الكلبي: (يسكن فيه الخلق ويرجعوا إلى أوطانهم) {19}، وهو مثل قوله تعالى: ﴿هُوَ {20} اَلَّذِى جَعَلَ لَكُمٌ الّيلَ لِتَسكنُواْ فِيهِ﴾ [يونس: 67].واختلف القراء {21} في قوله: ﴿وَجَعَلَ اللَّيْلَ﴾ فقرأ الأكثرون (جَاعِلُ) بالألف؛ لأن قبله اسم فاعل وهو [قوله] {22}: ﴿فَالِقُ الْحَبِّ﴾ و ﴿فَالِقُ الْإِصْبَاحِ﴾ و (جاعل) هاهنا حسن ليكون المعطوف [مثل المعطوف] {23} عليه، ألا ترى أن حكم الاسم أن يعطف على اسم مثله؛ لأن الاسم بالاسم أشبه من الفعل بالاسم، وقرأ أهل الكوفة ﴿وَجَعَلَ اللَّيْلَ﴾ لأن اسم الفاعل الذي قبله بمعنى الماضي، فلما كان فَاعِلٌ بمنزلة فَعَلَ في المعنى عطف عليه فعل؛ لموافقته له في المعنى، ويدلك على أنه بمنزلة فَعَل أنه نزل منزلته فيما عُطِفَ عليه، وهو قوله تعالى ﴿وَالشَّمْسَ وَالْقَمَرَ﴾ [الأنعام: 96]، ألا ترى أنه لما كان المعنى فعل في (جاعل) حمل المعطوف على ذلك فنصب (الشَّمْسَ [والْقَمَرَ] {24} {25}وقوله تعالى: ﴿وَالشَّمْسَ وَالْقَمَرَ حُسْبَانًا﴾ قال ابن عباس: (يريد: بحساب) {26} مثل ما قال في سورة يونس ﴿لِتَعْلَمُوا عَدَدَ السِّنِينَ وَالْحِسَابَ﴾ [يونس: 5]، وقال الكلبي: (منازلهما بحساب لا يُجاوزانه حتى ينتهيا إلى أقصى منازلهما) {27}.وروى شيبان {28} عن قتادة قال: ([يدوران] {29} في حساب) {30}، وأما معنى الحساب فإن العروضي {31} والقرشي {32} أخبراني عن الأزهري قال: أخبرني المنذري {33} عن أحمد بن يحيى، أنه حكى عن الأخفش أنه قال: (معناه: بحسابٍ، فحذف الباء) {34}، والكلام مختصر تقديره: وجعل الشمس والقمر يجريان بحساب كقوله: ﴿لِمَنْ خَلَقْتَ طِينًا﴾ [الإسراء: 61] أي: من طين، وقال ثعلب: (﴿حُسْبَانًا﴾ مصدر كما تقول: حَسَبْته أَحْسبُه حُسْبانًا وحِسَابًا) {35}، وأنشد أبو عبيد عن أبي زيد:على الله حُسْباني إذا النَّفْسُ أَشْرَفَتْ ... على طَمَعٍ أَو خافَ شيئًا ضَمِيرُها {36}وجعله الأخفش {37} جمع حِسَابٍ، وهو قول أبي الهيثم {38} قال: (الحُسبان جمع حساب مثل: رِكَابٍ ورُكْبَانٍ، وشِهَابٍ وشُهْبَانٍ، وكذلك أحسبة مثل: شهاب وأشهبة) {39}.وهو قول أبي عبيدة {40} والمبرد {41} ذكرا ذلك في قوله تعالى: ([الشَّمْسُ] {42} وَالقَمَرُ بِحُسْبَانٍ) [الرحمن:5]، ومن جعل الحسبان مصدرًا جعله كالرجحان والنقصان {43}.فأما نصب ﴿الشَّمْسَ وَالْقَمَرَ﴾ فقال أبو إسحاق: (النصب على تأويل وجعل الشمس والقمر؛ لأن في ﴿جَاعِلٌ﴾ معنى جعل، وبه نصبت ﴿سَكَنًا﴾، كما تقول: هو معطي زيدٍ درهمًا، فنصب الدرهم محمول على تأويل أعطى) {44}، ونحو هذا قال أبو علي {45}. وقال الفراء: (الليل في قوله (وَجَاعِلُ الَّليْلِ) في موضع نصب في المعنى فرُد ﴿الشَّمْسَ وَالْقَمَرَ﴾ على معناه لما فرّق بقوله ﴿سَكَنًا﴾، فإذا لم تفرق بينهما بشيء آثروا الخفض، وقد يجوز أن ينصب وإن لم يحل بينهما بشيء) {46}، وأنشد:بَيْنَا نَحْنُ ننظره أَتَانَا ... مُعَلّقَ شِكوة وزِنَادَ رَاعِ {47} وقد شرح ابن الأنباري هذا فقال: (العرب قد تجرى اسمًا على الخفض ثم تعطف عليه منصوبًا، وكذلك يقدمون المنصوب ثم يعطفون عليه المخفوض في باب فاعل، فيقولون: هو ضارب عبد الله في الدار ومحمدًا، وهو ضارب عبد الله في الدار ومحمدٍ، إذا نصبوا بعد الخفض قدروا أن المعطوف عليه منصوب وأن الفاعل منوّن، وذلك أن قولنا: هو ضارب عبد الله يجري مجرى ضارب عبد الله، وإذا خفضوا بعد النصب قدّروا أن المنصوب مخفوض وأن الاسم المبني على فاعل لا تنوين فيه، وأنشد:فنبَيْنَا نَحْنُ ننظره أَتَانَا ... مُعَلّقَ شِكوة وزِنَادَ رَاعِفحمل على تأويل النصب أراد: معلقًا شكوةً، وقال امرئ القيس:فَظَلَّ طُهَاةُ اللَّحْمِ [مِنْ بَيْنِ] {48} مُنْضِجٍ ... صَفِيفَ شِوَاءٍ أوْ قدِيرٍ مُعَجَّلِ {49}فخفض القدير وهو نسق على الصفيف تقديرًا أن الصفيف مخفوض، كأنه قال: من بين منضج صفيف) {50}.وقوله تعالى: ﴿ذَلِكَ تَقْدِيرُ الْعَزِيزِ الْعَلِيمِ﴾ قال ابن عباس: (يريد: الذي قدر الأقوات في كل زمان وما يصلح فيه) {18}، وقال المفسرون: (يعني: ﴿الْعَزِيزِ﴾: في ملكه يصنع ما أراد، ﴿الْعَلِيمِ﴾: بما قدر من خلقهما) {52}."
  6,98,"قوله تعالى: ﴿وَهُوَ الَّذِي أَنْشَأَكُمْ مِنْ نَفْسٍ وَاحِدَةٍ﴾ قال ابن عباس: (يريد: آدم) {1}، ﴿فَمُسْتَقَرٌّ وَمُسْتَوْدَعٌ﴾ قال ابن الأنباري: (أي: أراد: فلكم مستقر ومستودع، وبهذا الإضمار يحسن اتصال هذا الكلام بما قبله وحسن الإضمار؛ لأن الفاء يغلب على ما بعدها الاتصال بما يسبقها، فحذف ما يحذف بعد الفاء؛ إنما هو لدلالة الذي قبلها عليه للمواصلة، كقول العرب: إن تزرني فمحسن، وإن قصدتني فبار، وهم يريدون: فأنت بار، فيحذفون لوضوح المعنى) {2}.وأما تفسير: المستقر والمستودع، فقال ابن عباس في رواية عطاء: (يريد: مستقر في الأرحام ومستودع في الأصلاب) {3}، وهذا التفسير على القراءتين {4} في المستقر، وقال في رواية سعيد بن جبير: (المستقر ما في الرحم، والمستودع ما في الصلب) {5}، وهذا على قراءة من كسر القاف.وقال كريب {6}: (كتب حبر تيماء {7} إلى ابن عباس يسأله عن هذه، فكتب إليه المستودع: الصلب، والمستقر: الرحم، ثم قرأ: ﴿وَنُقِرُّ فِي الْأَرْحَامِ مَا نَشَاءُ﴾ [الحج: 5]) {8}، وهذا التفسير على قراءة من فتح القاف، وقال في رواية العوفي: (كل مخلوق قد فرع من خلقه فهو المستقر، والمستودع: ما في أصلاب الرجال الذي الله خالقه) {9}، ونحو هذا روى عكرمة عنه قال: (المستقر: الذي قد خُلق واستقر في الرحم، والمستودع: الذي قد استودع في الصلب مما لم يخلق بعد) {10}. وقال الوالبي {11} والضحاك عنه: (المستقر في الرحم، والمستودع ما استودع في أصلاب الرجال والدواب) {12}.وقال سعيد بن جبير: (﴿فَمُسْتَقَرٌّ﴾ في بطون الأمهات ﴿وَمُسْتَوْدَعٌ﴾: في أصلاب الآباء، قال: وقال لي ابن عباس: أتزوجتَ يا ابن جبير؟ قلت: لا، وما أريد ذلك يومي هذا. قال: فضرب ظهري، وقال: أما أنه مع ذاك ما كان من مستودع في ظهرك فسيخرج) {13}.وأكثر أهل التفسير والمعاني: على أن المستقر والمستودع في الأصلاب والأرحام {14} وقد أحسن أبو علي شرح الحرفين كل الإحسان، مع ذكر اختلاف القراءتين في المستقر فقال: (قال سيبويه: ""قالوا: قرَّ في مكانه واستقر"" {15}، فمن كسر القاف كان المستقر بمعنى: القارّ، وإذا كان كذلك وجب أن يكون خبره المضمر منكم، أي: منكم مستقر، كقولك: بعضكم مستقر، أي: مستقر في الأرحام، ومن فتح القاف فليس على أنه مفعول به، ألا ترى أن استقر لا يتعدى، وإذا لم يتعد لم يبن منه اسم مفعولٍ به، وإذا لم يكن مفعولًا به كان اسم مكان، فالمستقر بمنزلة المقرّ، كما كان المستقر بمنزلة القارّ، وإذا كان كذلك لم يجز أن يكون خبره المضمر منكم، كما جاز ذلك في قول من كسر القاف، فإذا لم يجز ذلك جعلت الخبر المضمر لكم، فيكون التقدير: لكم مَقَرٌّ.فأما المستودع فإن استودع فعلٌ يتعدى إلى مفعولين، [تقول] {16}: استودعت زيدًا ألفًا، وأودعت مثله، فاستودع مثل أَوْدَع، كما أن استجاب بمنزلة أجاب، فالمستودع يجوز أن يكون الإنسان الذي استودع ذلك المكان، ويجوز أن يكون المكان نفسه، فمن قرأ (فَمُستقَر) بفتح القاف جعل المستودع مكانًا ليكون مثل المعطوف عليه، أي: فلكم مكان استقرار، ومكان استيداع، ومن قرأ (فمستقِر) فالمعنى: منكم مستقر في الأرحام، ومنكم مستودع في الأصلاب، فالمستودع اسم المفعول به ليكون مثل المستقر في أنه اسم لغير المكان) {17}."
  6,99,"قوله تعالى: ﴿وَهُوَ الَّذِي أَنْزَلَ مِنَ السَّمَاءِ مَاءً﴾ قال ابن عباس: (يريد: المطر الذي ينزل، ليس من نقطة إلا ومعها ملك) {1}.﴿فَأَخْرَجْنَا بِهِ﴾ يعني: بالمطر ﴿نَبَاتَ كُلِّ شَيْءٍ﴾ ذكر الفراء فيه قولين: (أحدهما يقول: رزق كل شيء، يريد: ما ينبت مما يصلح غذاء لكل شيء، قال: وكذا جاء التفسير، وهو وجه الكلام، قال: وقد يجوز في العربية أن [تضيف] {2} النبات إلى ﴿كُلِّ شَيْءٍ﴾ وأنت تريد بكل شيء النبات أيضًا، فيكون مثل قوله تعالى: ﴿إِنَّ هَذَا لَهُوَ [حَقُّ] {3} الْيَقِينِ﴾ [الواقعة: 95] واليقين هو الحق) {4}.وقوله تعالى: ﴿فَأَخْرَجْنَا مِنْهُ خَضِرًا﴾ قال أبو إسحاق: (معنى خَضِر كمعنى أَخْضَر، يقال: اخْضَرَّ فهو أخضَرُ وخَضِرٌ، مثل اعْوَرَّ فهو أَعْوَرُ وعَوِرٌ) {5}، وقال غيره: ومثله نَمِرَ بمعنى: أنمر، تقول العرب: أَرِنيهَا نَمِرَةً أُرِكَهَا مَطِرَةً) {6}.وقال الليث: (الخضر في كتاب الله هو الزرع، وفي الكلام كل نبات من الخُضَر) {7}، قال ابن عباس: (يريد: القمح والسلت {8} والشعير والذرة والأرز) {9}، ويعني بهذا: ما كان رطبًا أخضر مما ينبت من هذه الحبوب.وقوله تعالى: ﴿نُخْرِجُ مِنْهُ حَبًّا مُتَرَاكِبًا﴾ يعني: من الخضر، نخرج ﴿حَبًّا مُتَرَاكِبًا﴾ بعضه على بعض في سنبلة واحدة {10}.وقوله تعالى: ﴿وَمِنَ النَّخْلِ مِنْ طَلْعِهَا قِنْوَانٌ دَانِيَةٌ﴾ قال أبو عبيد: (أَطْلَعَت النخلة إذا أخرجت طَلْعَها، وطَلْعُها كُفُرَّاها {11} قبل أن ينشق عن الإغَريض {12}، والإغريض يسمى طَلْعًا أيضًا، قال: والطلع أول ما يرى من عذق النخلة، الواحدة طلعة) {13}، قال أبو زيد: (أَطْلَعَ النَّخْلُ الطَّلْعَ إطْلاعًا، وطَلَعَ الطَّلْع يَطْلعُ طُلوعًا) {14}.و ﴿قِنْوَانٌ﴾، قال الزجاج: (جمع قِنْو، مثل صِنْوٍ وصِنْوَانٍ، وإذا ثنيت القِنْو قلت: قِنْوانِ، بكسر النون) {15}.قال أبو عبيدة: (ثم جاء جمعه على لفظ الاثنين مثل صنو وصنوان، والإعراب في النون للجمع، وليس لهما في كلام العرب نظير) {16}، قال امرؤ القيس {17}:فَأَثتْ أَعَالِيه وآدت أُصُولُهُ ... وَمَالَ بِقِنْوانٍ مِنَ البُسْرِ أَحْمَرَا قال أبو علي: الكسرة التي في (قنوان) ليست التي كانت في قنو، لأن وتلك قد حذفت في التكسير، وعاقبتها الكسرة التي [يجلبها التكسير، وكذلك التي {18}] في هجان {19}، وأنت تريد الجمع ليست الكسرة التي كانت في الواحد، ولكنه مثل الكسرة في ظراف {20} إذا جمعت عليه ظريفًا) {21}، وقد ذكرنا مثل هذا في الفُلك في سورة البقرة [: 164]، ونظير هذا مما يوضحه الضمة التي في آخر مَنْصُور على قول من قال: يا جارُ {22} ليست التي كانت فيه في قول من قال: يا جارِ {23}، قال ابن عباس: (يريد: العراجين {24} التي قد تدلت من الطلع، ﴿دَانِيَةٌ﴾ يريد: تدنو ممن يجتنيها) {25}، وروي عنه أيضاً أنه قال: (يعني: قصار النخل اللاصقة عذوقها بالأرض) {26}.قال أبو إسحاق: (﴿دَانِيَةٌ﴾ أي: قريبة المتناول، قال: ولم يقل: ومنها قنوان بعيدة؛ لأن في الكلام دليلًا أن البعيدة السحيقة قد كانت غير سحيقة، فاجتزأ بذكر القريبة عن ذكر البعيدة كما قال: ﴿سَرَابِيلَ تَقِيكُمُ الْحَرَّ﴾ [النحل: 81] ولم يقل: وسرابيل تقيكم البرد؛ لأن في الكلام دليلاً على أنها تقي البرد؛ لأن ما ستر من الحر ستر من البرد) {27}.وقوله تعالى: ﴿وَجَنَّاتٍ مِنْ أَعْنَابٍ﴾ الوجه: كسر {28} التاء؛ لأنها في موضع نصب نسقًا على قوله (خَضِرًا) أي: فأخرجنا خَضِرًا ﴿وَجَنَّاتٍ مِنْ أَعْنَابٍ﴾ وروى الأعشى {29} عن أبي بكر {30} [وجنات) رفعًا {31} قال أبو بكر {18}] ابن الأنباري: (وله مذهبان أحدهما: أن يكون الجنات مفعولة في المعنى رفعت بمضمر بعدها، تأويله ﴿وَجَنَّاتٍ مِنْ أَعْنَابٍ﴾ أخرجناها، فجرى مجرى قول العرب: أكرمت عبد الله وأخوه، يريدون: وأخوه أكرمته أيضاً، ومثله [قول] {33}: أكلت طعامك وطعام أخيك، قال الفرزدق:غَداةَ أحلَّتْ لابْنِ أَصْرَمَ طَعْنَةُ ... حُصَيْنٍ عَبيطَاتِ السَّدَائِفِ والخَمْرُ {34}فرفع الخَمر، وهي مفعولة، على معنى: والخمر أحلتها الطعنة، والمذهب الآخر: رفع الجنات بالنسق على القنوان؛ تغليبًا لمعنى الجوار، كما قال الشاعر:وزَجَّجْنَ الحَوَاجِبَ والعُيُونَا {35}فنسق العيون على الحواجب تغليبًا للمجاورة، والعيون لا تزجج، كما أن الجنات من الأعناب لا [يكنّ] {36} من الطلع) {37}.وقوله تعالى: ﴿وَالزَّيْتُونَ وَالرُّمَّانَ﴾ قال الفراء: (يريد: شجر الزيتون، وشجر الرمان، كما قال: ﴿وَاسْأَلِ الْقَرْيَةَ﴾ [يوسف: 82] يريد: أهلها) {38}وقوله تعالى: ﴿مُشْتَبِهًا وَغَيْرَ مُتَشَابِهٍ﴾، قال قتادة: (مشتبهًا ورقها مختلفًا ثمرها) {39}، وهو قول مقاتل {40} وأكثر المفسرين {41}، وقال الزجاج: (أي: شجره، يشبه بعضه بعضًا ﴿وَغَيْرَ مُتَشَابِهٍ﴾ في الطعم) {42}.وقوله تعالى: ﴿انْظُرُوا إِلَى ثَمَرِهِ﴾ قال عبد العزيز بن يحيى: (نظر الاستدلال والعبرة) {43}، وقال أبو روق: (اعتبروا واتعظوا) {44}، ﴿إِلَى ثَمَرِهِ إِذَا أَثْمَرَ﴾، قال الفراء: (يقول: انظروا إليه أول ما يعقد) {45}، والثمر: جمع ثمرة مثل: بقرة وبقر وشجرة وشجر وجزرة وجزر، وقد كسروها على فِعال، كما قالوا: أكمة وأكام ورقبة ورقاب {46}.وقرأ حمزة والكسائي (ثُمُرِه) بضم الثاء {47} والميم، وله وجهان: الأبين أن يكون جمع ثمرة على ثُمُر، كما قالوا: خشبة وخُشُب؛ قال الله تعالى: ﴿كَأَنَّهُمْ خُشُبٌ مُسَنَّدَةٌ﴾ [المنافقون: 4] وكذلك أكمة وأكم، ثم يخففون [فيقولون] {48}: أكم {49} قال:ترى الأكم منه {50} سجدًا للحوافر {51}ونظيره من المعتل ساحَة وسُوْح {52} وقارَة وقور، ولابهَ {53} ولُوب، وناقة ونُوق. والوجه الآخر: أن يكون جمع ثمرة على ثمار، ثم جمع ثمارًا على ثُمرٍ، فيكون ثُمر جمع الجمع {54}.وقوله تعالى: ﴿وَيَنْعِهِ﴾ الينع: النضج {55}. قال أبو عبيدة: (يقال: يَنَع يَيْنَع بالفتح في الماضي والكسر في المستقبل) {56}، وأنشد:حَوْلَهَا الزَّيْتُونُ قَدْ يَنَعَا {57} وقال الليث: (ينعت الثمرة، بالكسر، وأينعت، فهي [تينع] {58} وتونع إيناعًا، ويَنعًا بفتح الياء، ويُنعًا [بضهما] {59}، والنعت يانِع ومونِع) {60}.وقوله تعالى: ﴿إِنَّ فِي ذَلِكُمْ لَآيَاتٍ لِقَوْمٍ يُؤْمِنُونَ﴾ يريد: يصدّقون أن الذي أخرج هذا النبات قادر على أن يحيى الموتى ويبعثهم.قال أبو إسحاق {61}: (احتج الله عز وجل بتصريف ما خلق، ونقله من حالٍ إلى حالٍ بما يعلمون أنه لا يقدر عليه [المخلوقون] {62}، وأعلم أنه كذلك يبعثهم؛ لأنهم كانوا ينكرون البعث فقال: ﴿إِنَّ فِي ذَلِكُمْ لَآيَاتٍ لِقَوْمٍ يُؤْمِنُونَ﴾، أعلمهم أن فيما قصّ عليهم دليلًا [لمن صدّق]) {63}."
  6,100,"قوله تعالى: ﴿وَجَعَلُوا لِلَّهِ شُرَكَاءَ الْجِنَّ﴾ قال الحسن: (معناه: أطاعوا الشياطين في عبادة الأوثان) {1}، وهو اختيار الزجاج قال: (المعنى: أنهم أطاعوا الجن فيما سوّلت من شركهم فجعلوهم شركاء لله) {2}.وذكر الفراء {3} وأبو إسحاق {4} في نصب (الجن) وجهين: (أحدهما: أن يكون الجن مفعولاً فيكون المعنى: وجعلوا لله الجن شركاء، ويكون الشركاء مفعولاً ثانياً. والثاني {5}: أن يكون الجن بدلاً من الشركاء ومفسراً للشركاء) {6}.وقوله تعالى: (وَخَلَقَهُمْ) يجوز أن تعود الكناية على هؤلاء الذين جعلوا لله شركاء، والمعنى: وجعلوا لله الذي خلقهم شركاء لا يخلقون، ويجوز أن تعود الكناية على الجن، فيكون المعنى: والله خلق الجن، فكيف يكون الشريك لله عز وجل، المحدث الذي لم يكن ثم كان {7}.وقوله تعالى ﴿وَخَرَقُوا لَهُ بَنِينَ وَبَنَاتٍ﴾، قال المفسرون {8}: (يعني: كفار العرب الذين قالوا: الملائكة بنات الله). قال ابن عباس: يريد: افتعلوا له بنين وبنات) {9}.وقال قتادة {10} وابن زيد {11} ومجاهد {12} وابن جريج {13}: (كذبوا).وقال الفراء: (معنى ﴿وَخَرَقُوا﴾: افتعلوا ذلك كذباً وكفراً، قال: [وخَرَقوا] {14} واخترقوا وخلقوا واختلقوا وافتروا واحد {15}، يقال {16}: خلق فلان الكلمة واختلقها واخترقها وخرّقها إذا افتعلها وابتدعها كذباً)، الليث: (تخرّق الكذب وتخلقه) {17}.وقال الزجاج: (معنى خرقوا واختلقوا: كذبوا) {18}، وقرأ {19} نافع: (وَخَرَّقُوا) {20} مشددة، والاختيار التخفيف؛ لأنها أكثر، والتشديد للمبالغة والتكثير {21}. وزعمت النصارى أن المسيح ابن الله، واليهود أن عزيزاً ابن الله، فأعلم الله عز وجل أنهم اختلقوا ذلك ﴿بِغَيْرِ عِلْمٍ﴾ أي: لم يذكروه عن علم، إنما ذكروه تكذباً، قاله {22} الزجاج، وقال غيره: معناه ﴿بِغَيْرِ عِلْمٍ﴾ منهم أن هذا لا يجوز على القديم جل وعز، فهو داخل في الذم لهم {23}."
  6,101,"قوله تعالى: ﴿بَدِيعُ السَّمَاوَاتِ وَالْأَرْضِ أَنَّى يَكُونُ لَهُ وَلَدٌ وَلَمْ تَكُنْ لَهُ صَاحِبَةٌ﴾ أي: من أين يكون له ولد ولا يكون الولد إلا من صاحبه ﴿وَخَلَقَ كُلَّ شَيْءٍ﴾ احتج جل وعز في نفي الولد بأنه خالق كل شيء، وليس كمثله شيء، فكيف يكون الولد لمن لا مثل له، وإذا نسب إليه الولد فقد جعل له مثل {1}، فالآية متضمنة للحجة على استحالة أن يكون لله ولد؛ لأن ﴿بَدِيعُ السَّمَاوَاتِ وَالْأَرْضِ﴾ لا مثل له، والولد لا يصح إلا مع المماثلة.وقوله تعالى: ﴿وَهُوَ بِكُلِّ شَيْءٍ عَلِيمٌ﴾ قال ابن عباس: (لأنه هو الخالق لخلقه) {2}."
