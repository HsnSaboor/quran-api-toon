tafsir[7]{c,v,t}:
  9,14,"قوله تعالى: ﴿قَاتِلُوهُمْ يُعَذِّبْهُمُ اللَّهُ بِأَيْدِيكُمْ﴾ "" [قال مقاتل: وعدهم الله النصر بهذه الآية"" {1}، ومعنى: ﴿يُعَذِّبْهُمُ اللَّهُ بِأَيْدِيكُمْ﴾] {2} يقتلهم بسيوفكم ورماحكم، في معنى قول ابن عباس والمفسرين {3}.وقوله تعالى: ﴿وَيُخْزِهِمْ﴾، قال ابن عباس: ""بعد {4} قتلكم إياهم"" {5}. وهذا يدل على أن هذا الإخزاء وقع بهم في الآخرة، وقال آخرون: ""معناه: يذلهم بالقهر والأسر"" {6}.وقوله تعالى: ﴿وَيَشْفِ صُدُورَ قَوْمٍ مُؤْمِنِينَ﴾، قال ابن عباس والسدي ومجاهد: ""يعني بني خزاعة"" {7}، وذلك حين أعانت قريش بني بكر عليهم حتى نكوا {8} فيهم {9}، فشفى الله صدورهم من بني بكر واستوفى ثأرهم بالنبي ﷺ والمؤمنين حين استووا في القتل، وذلك أنه لما جاء المستغيث من خزاعة رسول الله -ﷺ- وأنشد {10}:اللهمَّ إني ناشد محمدًا ... حلف أبينا وأبيه الأتلدا {11}.. الأبيات.قال رسول الله -ﷺ-: ""لا نُصرت إن لم أنصركم"" {12} وغضب لهم، وخرج إلى مكة ونصر الله رسوله وشفى صدور خزاعة.قال أبو إسحاق: ""وفي هذه الآية، دليل على تثبيت النبوة؛ لأنه وعدهم النصر ووفى به، فدل به على صدق ما أتى به محمد ﷺ"" {13}، ودلّ كلام أبي إسحاق {14} في تفسير قوله: ﴿وَيَشْفِ صُدُورَ قَوْمٍ مُؤْمِنِينَ﴾ أن هذا يراد به أصحاب النبي -ﷺ- لا حلفاؤه من خزاعة؛ لأنه قال: ""فيه دليل على أنهم اشتد غضبهم لله عز وجل"" {15}، فعنده الشفاء إنما هو من داء الغضب لله ولدينه ورسوله، وعند غيره من المفسرين: الشفاء من داء الحقد لخزاعة على بني بكر وقريش {16}."
  9,15,"قوله تعالى: ﴿وَيُذْهِبْ غَيْظَ قُلُوبِهِمْ﴾، قال المفسرون: ""يعني: كربها ووجدها بمعونة قريش بكرًا عليهم"" {1}.﴿وَيَتُوبُ اللَّهُ عَلَى مَنْ يَشَاءُ﴾ يعني {2} من المشركين كأبي سفيان وعكرمة ابن أبي جهل {3} وسهيل بن عمرو {4}، تاب الله عليهم، وهداهم للإسلام.قال الزجاج: ""قوله تعالى: ﴿وَيَتُوبُ اللَّهُ﴾ ليس بجواب لقوله: ﴿قَاتِلُوهُمْ﴾ ولكنه مستأنف؛ لأن ﴿يَتُوبُ﴾ ليس من جنس ما يجاب به ﴿قَاتِلُوهُمْ﴾ "" {5}.وقال الفراء: ""رفع قوله: ﴿وَيَتُوبُ اللَّهُ﴾ لأن معناه ليس من شروط الجزاء، إنما هو استئناف، كقولك للرجل: ائتني أعطك، وأحبُّك بعد وأكرمُك، استئناف ليس بشرط للجزاء، ومثله قوله: ﴿فَإِنْ يَشَإِ اللَّهُ يَخْتِمْ عَلَى قَلْبِكَ﴾ [الشورى:24] تم الجزاء ههنا، ثم استأنف: ﴿وَيَمْحُ اللَّهُ الْبَاطِلَ﴾ {6} "" {7}.وقوله تعالى: ﴿وَاللَّهُ عَلِيمٌ حَكِيمٌ﴾، قال ابن عباس: ""يريد: ""عليم"" بنيات المؤمنين وحبهم لله ""حكيم"" فيما قضى في الذين نقضوا القضية {8} "" {9}."
  9,16,"قوله تعالى: ﴿أَمْ حَسِبْتُمْ أَنْ تُتْرَكُوا﴾ الآية، قال الفراء: ""هذا من الاستفهام الذي يتوسط الكلام فيجعل بـ""أم"" ليفرق بينه وبين الاستفهام المبتدأ الذي لم يتصل بكلام، ولو أريد به الابتداء لكان بالألف أو بـ""هل"" {1} "" وهذا مما قد {2} أحكمناه {3} في سورة البقرة {4}.قال ابن عباس: ""الخطاب في هذه الآية للمنافقين كانوا يتوسلون إلى رسول الله -ﷺ- بالخروج معه إلى الجهاد تعذيرا، والنفاق في قلوبهم"" {5}.ومعنى: ﴿وَلَمَّا يَعْلَمِ اللَّهُ﴾ أي: العلم الذي يجازي عليه؛ لأنه إنما يجازي على ما عملوا {6}، قاله الزجاج {7}، وهذا مما ذكرناه في سورة البقرة عند قوله: ﴿إِلَّا لِنَعْلَمَ﴾ {8} وفي سورة آل عمران [142].﴿الَّذِينَ جَاهَدُوا مِنْكُمْ﴾، قال ابن عباس: ""يريد: بنية صادقة"" {9}.وقوله تعالى: ﴿وَلَمْ يَتَّخِذُوا مِنْ دُونِ اللَّهِ وَلَا رَسُولِهِ وَلَا الْمُؤْمِنِينَ وَلِيجَةً﴾، قال الكفراء: ""الوليجة: البطانة من المشركين يتخذونهم فيفشون إليهم أسرارهم"" {10}.وقال أبو عبيدة: ""كل شيء أدخلته في شيء ليس منه فهو وليجة، والرجل يكون في القوم وليس منهم: وليجة"" {11}.وأصله من الولوج، فوليجة الرجل: من يختصه بدخلة أمره دون الناس، يقال هو وليجتي وهم وليجتى للواحد والجمع.قال ابن عباس في قوله: ﴿وَلِيجَةً﴾ ""يريد: أولياء من المشركين"" {12}.وقال قتادة: ""خيانة"" {13}، وقال الضحاك: ""خديعة"" {14}.وهذان القولان ليسا تفسيرًا للوليجة، بل هما تفسير لعلة اتخاذ الوليجة، كأنهما قالا: ولم يتخذوا وليجة للخيانة والخديعة؛ لأن اتخاذ الوليجة من الكفار خيانة وخديعة، قال ابن عباس: ""إن الله لا يرضى أن يكون الباطن خلافًا للظاهر ولا الظاهر خلافًا للباطن، إنما يريد الله من خلقه الاستقامة كما قال: ﴿إِنَّ الَّذِينَ قَالُوا رَبُّنَا اللَّهُ ثُمَّ اسْتَقَامُوا﴾ [فصلت: 30]، الأحقاف: 13] {15} "".وقال أبو {16} إسحاق: ""لما فرض القتال تبين المنافق من غيره، ومن يوالي المؤمنين ممن يوالي أعداءهم فأنزل الله هذه الآية"" {7}.وتقدير لفظ الآية مع المعنى: ولما يعلم الله المجاهدين والممتنعين من اتخاذ الوليجة."
  9,17,"قوله تعالى: ﴿مَا كَانَ لِلْمُشْرِكِينَ أَنْ يَعْمُرُوا مَسَاجِدَ اللَّهِ﴾ الآية، قال ابن عباس: ""لما أسر العباس يوم بدر أقبل عليه المسلمون فعيروه بكفره بالله وقطيعة الرحم وأغلظ عليّ القول، فقال العباس: ما لكم تذكرون مساوئنا ولا تذكرون محاسننا؟ قال له علىّ: ألكم محاسن؟! فقال: نعم، إنا لنعمر المسجد الحرام، ونحجب الكعبة ونسقي الحاج ونفك العاني، فأنزل الله -عز وجل- ردًا على العباس ﴿مَا كَانَ لِلْمُشْرِكِينَ﴾ {1}.ومعنى ما كان لهم ذلك: أنه أوجب على المسلمين منعهم عن ذلك، وأكثر المفسرين حملوا العمارة ههنا على دخول المسجد الحرام {2} والقعود فيه {3}، وهو قول ابن عباس والحسن، قال {4} في رواية عطاء: ""يريد: لا يدخلوه ولا يقعدوا فيه كما كانوا قبل ذلك"" {5}.وقال الحسن: ""يقول {6}: ما كان للمشركين أن يتركوا فيكونوا أهل المسجد الحرام"" {7}. وقال الكلبي: ""ما كان للمشركين أن يدخلوا المسجد وهم مشركون"" {8}.وذهب آخرون إلى {9} العمارة المعروفة من رم المسترم {10} من أبنية المسجد {11}، وهذا محظور على الكافر يمنع منه ولا يمكن.واختلف القراء في قوله: ﴿مَسَاجِدَ اللَّهِ﴾ فقرأ أبو عمرو وابن كثير على التوحيد {12} وحجتهما قوله: ﴿وَعِمَارَةَ الْمَسْجِدِ الْحَرَامِ﴾ ومن جمع فحجته أن المشركين ليسوا بأولياء لمساجد المسلمين، لا المسجد الحرام ولا غيره [وإذا لم يكونوا أولياءها لم يكن لهم عمارتها، إنما عمارتها للمسلمين الذين هم أولياؤه {13} فدخل في ذلك المسجد الحرام وغيره، {14}، ويدل على أنهم ليس لهم عمارة المسجد قوله تعالى: ﴿وَمَا كَانُوا أَوْلِيَاءَهُ إِنْ أَوْلِيَاؤُهُ إِلَّا الْمُتَّقُونَ﴾ [الأنفال: 34]، قال الفراء في هذه الآية: ""ربما ذهبت العرب بالواحد إلى الجمع، ألا ترى الرجل على البرذون {15} فتقول: قد أخذتَ في ركوب البراذين؟ وترى الرجل كثير الدراهم فتقول: إنه لكثير الدرهم {16}، وتقول العرب: عليه أخلاق نعلين، وأخلاق ثوب، ومنه قول الشاعر {17}:جاء الشتاء وقميصي أخلاق {18}وقوله تعالى: ﴿شَاهِدِينَ عَلَى أَنْفُسِهِمْ بِالْكُفْرِ﴾، قال الزجاج: ""شاهدين"" {19} حال، المعنى: ما كانت {20} لهم عمارة المسجد في حال إقرارهم بالكفر"" {21}.ومعنى: ﴿شَاهِدِينَ عَلَى أَنْفُسِهِمْ بِالْكُفْرِ﴾: قال ابن عباس في رواية الضحاك: ""شهادتهم على أنفسهم بالكفر: سجودهم لأصنامهم وإقرارهم أنها مخلوقة"" {22}، وقال في رواية عطاء: ""يريد: حين اتخذوا لله شفعاء وأنداداً"" {23}، وهذا معنى القول {24} الأول.وقال الحسن: ""لم يقولوا نحن كفار ولكن كلامهم بالكفر شاهد عليهم بكفرهم"" {25} يعني أن {6} فيما يخبرون به دليلًا على كفرهم، لا أنهم يقولون نحن كفار، ولكن كما تقول للرجل: كلامك يشهد أنك ظالم، وقال السدي: ""شهادتهم على أنفسهم بالكفر هو أن النصراني يُسأل ما أنت؟ فيقول: نصراني واليهودي يقول: يهودي، وعابد الوثن يقول: مشرك"" {27}.وذكر ابن الأنباري في هذا وجهين:أحدهما: أنه قال: شهادتهم على أنفسهم بالكفر عدولهم عن أمر النبي -ﷺ- وهو حق لا يخفى على مميز، ولا يرتاب به عاقل، فكانوا {28} في ذلك بمنزلة من شهد على نفسه بالكفر.والثاني: أنهم آمنوا بأنبياء {29} شهدوا لمحمد ﷺ بالصدق فلما آمنوا بهم وكذبوه دلوا على كفرهم {30}، وجرى ذلك مجرى الشهادة منهم على أنفسهم بالكفر"" {31}.وقوله تعالى: ﴿أُولَئِكَ حَبِطَتْ أَعْمَالُهُمْ﴾، قال ابن عباس: ""يريد: أن أعمالهم لغير الله"" {23}.وقال الزجاج: ""أي كفرهم قد أذهب ثواب أعمالهم"" {21}.ودلت هذه الآية مع ما ذكرنا من التفسير في العمارة أن الكافر ممنوع من عمارة مسجد من مساجد المسلمين، ولو أوصى بها {34} لم تقبل وصيته، ويمنع عن دخول المساجد، فإن دخل بغير إذن مسلم استحق التعزير، وإن دخل بإذن لم يعزر، والأولى تعظيم المساجد ومنعهم منها للآية، وقد أنزل رسول الله ﷺ وفد ثقيف في المسجد وهم كفار {35}، وشد ثمامة {36} بن أثال الحنفي على سارية من سواري المسجد وهو كافر {37}، وليس في الآية حجة لمن جعل دخول الكافر المسجد وصلاته فيه إيمانًا منه؛ لأنا {38} لا نأمن أن تكون صلاته قبل سماع الشهادتين منه سخرية واستهزاءً، ولا يكون فعله {39} عمارة للمسجد ما لم تتقدم منه كلمة الإيمان، وإن حملنا العمارة على عمارة البناء سقط هذا الاستدلال."
  9,18,"قوله تعالى: ﴿إِنَّمَا يَعْمُرُ مَسَاجِدَ اللَّهِ مَنْ آمَنَ بِاللَّهِ﴾ أي: إنما يعمرها بحقها من آمن بالله، وقال رسول الله -ﷺ- ""إذا رأيتم الرجل يعتاد المسجد فاشهدوا له بالايمان؛ فإن الله -عز وجل- يقول ﴿إِنَّمَا يَعْمُرُ مَسَاجِدَ اللَّهِ مَنْ آمَنَ بِاللَّهِ﴾ "" {1}، وهذا يدل على أن المراد بالعمارة دخول المسجد والقعود فيه.وقوله تعالى: ﴿مَنْ آمَنَ بِاللَّهِ﴾ إلى قوله: ﴿وَآتَى الزَّكَاةَ﴾، قال ابن عباس: ""يعني المهاجرين والأنصار والتابعين بإحسان"" {2}، والإيمان بالله يجمع الصلاة والزكاة، ولكنهما من أوكد أقسام الإسلام وما أوجبه الإيمان، فذكرهما، قال الزجاج: ""ولم يذكر الرسول ﷺ في هذا {3}؛ لأن في قوله: ﴿وَأَقَامَ الصَّلَاةَ وَآتَى الزَّكَاةَ﴾ دليل على تصديقه؛ لأن المعنى: وآتى الزكاة التي أتى بتحديدها الرسول ﷺ {4}.قال أهل المعاني: ""يريد من كان بهذه الصفة كان من أهل عمارة المسجد، وليس المعنى أن من عمرها كان بهذه الصفة"" {5}، غير أنه قلَّ من يعمرها إلا وقد جمع هذه الصفات، كما قال رسول الله -ﷺ- في الخبر الذي ذكرنا.وقوله تعالى: ﴿وَلَمْ يَخْشَ إِلَّا اللَّهَ﴾، قال الزجاج: ""تأويله: لم يخف في باب الدين إلا الله جل وعز"" {6}.وقال أهل المعاني: ""يعني: لا يترك هذه العبادات لخشية أحد ولكن يخشى الله فيقيم ذلك، والخشية من غير الله المنهي عنها أن يترك أمر الله لخشية غيره، فأما أن يخشى الناس خشية لا تؤديه إلى ترك أمر الله فليس بمنهى عنه"" {7}.وقوله تعالى: ﴿فَعَسَى أُولَئِكَ أَنْ يَكُونُوا مِنَ الْمُهْتَدِينَ﴾ أي فأولئك هم المهتدون، وعسى من الله واجبة، ولكن ذكر بلفظ ""عسى"" ليكونوا على رجاء وطمع وحذر، وابن عباس والمفسرون يقولون: ""عسى واجبة من الله"" {8}، ومعنى الاهتداء ههنا الإمساك بطاعة الله التي تؤدي إلى الجنة."
  9,19,"قوله تعالى: ﴿أَجَعَلْتُمْ سِقَايَةَ الْحَاجِّ﴾ الآية، ذكر المفسرون أقوالًا في نزول هذه الآية فقال ابن عباس في رواية الوالبي: ""قال العباس: لئن كنتم سبقتمونا بالإسلام والهجرة والجهاد لقد كنا نعمر المسجد الحرام ونسقي الحاج، فأنزل الله هذه الآية"" {1}، وقال في رواية العوفي: ""إن المشركين قالوا: عمارة بيت الله وقيام على السقاية خير من الإيمان والجهاد، فأنزل الله هذه الآية"" {2}.وقال الحسن والشعبي والقرظي: ""افتخر علي والعباس وطلحة بن شيبة {3}: فقال طلحة: أنا صاحب البيت بيدي مفتاحه؛ ولو أشاء بتُّ فيه، وقال العباس: [أنا صاحب السقاية والقائم عليها، وقال علي] {4}: أنا صاحب الجهاد، فأنزل الله هذه الآية"" {5}.والسقاية: الموضع الذي يتخذ فيه {6} الشراب في المواسم وغيرها، ومنه قوله تعالى: ﴿جَعَلَ السِّقَايَةَ فِي رَحْلِ أَخِيهِ﴾ [يوسف: 70]، يعني إناء، قاله الليث {7}، قال: وسقاية الحاج: سقيهم الشراب"" {8}.فالسقاية يجوز أن تكون اسمًا، ويجوز أن تكون مصدرًا، كالرعاية والحماية {9}، فإن جعلته اسمًا فالمعنى: أجعلتم أهل {10} سقاية الحاج أو {11} أصحابها؟ ثم حذفت المضاف، وإن جعلته مصدرًا فهو مصدرٌ يراد به الفاعل على تقدير: أجعلتم ساقي الحاج [أو سقاة {12} الحاج] {4} وعمار {14} المسجد، كمن آمن {15}، وإن شئت تركتها مصدرًا وأضمرت المضاف في قوله: ﴿كَمَنْ آمَنَ﴾ فقلت: التقدير: أجعلتم سقاية الحاج كإيمان من آمن؟ وهذه الوجوه ذكرها الفراء {16} والزجاج {17} وابن الأنباري {18}، وقد استقصينا ما في هذا عند قوله: ﴿وَلَكِنَّ الْبِرَّ مَنْ آمَنَ بِاللَّهِ﴾ {19}، قال الحسن: ""وكانت السقاية نبيذ زبيب"" {20} وقوله تعالى: ﴿وَعِمَارَةَ الْمَسْجِدِ الْحَرَامِ﴾، قال ابن عباس: ""يريد: تجميره وتخليقه {21} "" {22}.وقوله تعالى: ﴿كَمَنْ آمَنَ بِاللَّهِ﴾ إلى قوله: ﴿لَا يَسْتَوُونَ عِنْدَ اللَّهِ﴾ قال العوفي عن ابن عباس: ""أخبر أن عمارتهم المسجد الحرام، وقيامهم على السقاية لا ينفعهم عند الله مع الشرك {23} بالله، [وأن الإيمان بالله والجهاد مع نبيه خير مما هم عليه"" {24}] {25}.وقوله تعالى: ﴿وَاللَّهُ لَا يَهْدِي الْقَوْمَ الظَّالِمِينَ﴾ أي قد هدى المؤمنين الذين وصفهم، ولم يهد الذين سووا بهم {26}، وقال مقاتل: ""لا يستوون عند الله في الفضل"" {27}، وقال الكلبي: ""في الثواب"" {28}، وقال الأشتر بن عبد الله {29}. ""الذين زعموا أنهم أهل العمارة سماهم الله ظالمين بشركهم فلم تغن عنهم العمارة شيئًا""."
  9,20,"ثم نعت المهاجرين فقال: ﴿الَّذِينَ آمَنُوا﴾ إلى قوله: ﴿أَعْظَمُ دَرَجَةً عِنْدَ اللَّهِ﴾ أي من الذين افتخروا بعمارة البيت وسقي الحاج، فإن قيل: إنهم كانوا كفارًا فكيف جاز في صفة المؤمنين أنهم أعظم درجة عند الله منهم، ولا درجة لهم عند الله؟ قيل: هذا على ما كانوا يقدرون هم لأنفسهم وإن كان ذلك التقدير خطأ {1}، كقوله {2}: ﴿أَصْحَابُ الْجَنَّةِ يَوْمَئِذٍ خَيْرٌ مُسْتَقَرًّا﴾ [الفرقان: 24]، وقال الزجاج: ""المعنى: أعظم من غيرهم درجة"" {3}، فيدخل في هذا كل ذي درجة ويحصل للمهاجرين المزية.وقوله تعالى: ﴿وَأُولَئِكَ هُمُ الْفَائِزُونَ﴾ معنى الفوز في اللغة: الظفر بالبغية وإدراك الطلبة {4}، قال الزجاج: ""والفائز: الذي يظفر بأمنيته من الخير"" {5}، وهذا مما قد سبق {6}."
