tafsir[4]{c,v,t}:
  6,138,"قوله تعالى: ﴿وَقَالُوا هَذِهِ أَنْعَامٌ وَحَرْثٌ حِجْرٌ﴾ معنى الحجر في اللغة: الحرام، وأصله {1} من المنع، ومنه سمّي العقل حجرًا لمنعه عن القبائح، وفلان في حجر القاضي أي: منعه {2}، قال أبو إسحاق: (المعنى: أنهم حرموا أنعامًا وحرثًا وجعلوه لأصنامهم فقالوا: ﴿لَا يَطْعَمُهَا إِلَّا مَنْ نَشَاءُ بِزَعْمِهِمْ﴾، فأعلم الله عز وجل أن هذا التحريم زعم منهم، لا حجة لهم فيه، ولا برهان) {3}.﴿وَأَنْعَامٌ حُرِّمَتْ ظُهُورُهَا﴾ قال ابن عباس: (يريد: مما سيبوا لآلهتهم) {4}.قال الزجاج: (وهي نحو ما وصفنا من البحيرة والسائبة والحامي الذي قد حمي ظهره أن يركب) {5}.﴿وَأَنْعَامٌ لَا يَذْكُرُونَ اسْمَ اللَّهِ عَلَيْهَا﴾ قال ابن عباس: (يريد: يقتلونها لآلهتهم، إما يقذفونها {6}، وإما يخنقونها بالوتر) {7}.وقال الزجاج: (يذبحونها لأصنامهم ولا يذكرون اسم الله عليها، فأعلم الله عز وجل أن ذلك افتراء {8}، فقال: ﴿افْتِرَاءً عَلَيْهِ﴾ أي: يفعلون ذلك افتراء، وهذا يسميه سيبويه مفعول له {9}، أي: لا يذكرون اسم الله عليها للافتراء على الله، وهو أنهم زعموا أن الله أمرهم بذلك، قال الزجاج: وحقيقته أن قوله تعالى: ﴿لَا يَذْكُرُونَ﴾ بمعنى: يفترون، كأنه قال: يفترون افتراء) {10}."
  6,139,"قوله تعالى: ﴿وَقَالُوا مَا فِي بُطُونِ هَذِهِ الْأَنْعَامِ خَالِصَةٌ لِذُكُورِنَا﴾. قال ابن عباس {1} والشعبي {2} وقتادة {3}: (يعني: ألبان البحائر، كانت للذكور دون النساء، فإذا ماتت اشترك في لحمها ذكورهم وإناثهم).وقال غيرهم من المفسرين {4}: (يعني: أجنة البحائرِ والسوائب، ما ولد منها حيًّا فهو خالص للرجال دون النساء، وما ولد ميتًا أكله الرجال والنساء).وقوله تعالى: ﴿خَالِصَةٌ لِذُكُورِنَا﴾ ذكر ابن الأنباري: في تأنيث خالصة ثلاثة أقوال: قولين للفراء، وقولًا للكسائي: (أحدها: أن الهاء ليست للتأنيث، وإنما هي للمبالغة في الوصف كما قالوا: راوية وعلامة ونسَّابة، والداهية والطاغية، وأنه لمنكر ومنكرة، وكذلك تقول: هو خالصة لي، وخالص لي، وهذا قول الكسائي {5}.وقال الفراء {6}: (وقد تكون (خالصة) مصدرًا لتأنيثها كما تقول: العاقبة والعافية، وهو مثل قوله تعالى: ﴿إِنَّا أَخْلَصْنَاهُمْ بِخَالِصَةٍ ذِكْرَى الدَّارِ﴾ [ص: 46] {7}، قال أبو بكر: فعلى هذا أنثت الخالصة؛ لأنها أجريت مجرى المصادر التي تكون بلفظ التأنيث إخبارًا عن الأسماء المذكرة كقولهم: عطاؤك عافية، والمطر رحمة، والرخص نعمة، ومعروف عندهم الرجل خالصتي، قال الشاعر {8}:كُنتَ أمنيتي وكَنتَ خَالصتي ... وليس كلُّ امرئ بمؤتمنِالقول الثالث {9}: للفراء (أن تأنيث (خالصة) لتأنيث (الأنعام) {10}، لأن ما في بطونها مثلها، فأنث لتأنيثها) {11}، وعلى هذا كأنه قيل: وقالوا الأنعام التي في بطون الأنعام ﴿خَالِصَةٌ لِذُكُورِنَا﴾ {12}، وقال الزجاج: (جُعل معنى (ما) التأنيث؛ لأنها في معنى الجماعة كأنهم قالوا: جماعة ﴿مَا فِي بُطُونِ هَذِهِ الْأَنْعَامِ خَالِصَةٌ لِذُكُورِنَا﴾ {13}، وأبين من هذا كله أن يقال: (ما) عبارة عن الألبان أو الأجنة، وإذا كان عبارة عن مؤنث جاز تأنيثه على المعنى، وتذكيره على اللفظ، كما جُعل في هذه الآية فإنه أنث خبره الذي هو (خالصة) لمعناه وذُكر في قوله (ومحرم) على اللفظ {14}، وهذا قريب مما قاله أبو إسحاق؛ لأنه جعل (ما) بمعنى الجماعة. وذكر أبو علي فيه {15} قولين: (أحدهما: أن (خالصة) مصدر، ويكون المعنى: ما في بطون هذه الأنعام ذو خلوص. والثاني: أن يكون صفة، وأنث على المعنى لأنه كثرة، والمراد به: الأجنة والمضامين) {16}.وقوله تعالى: ﴿وَمُحَرَّمٌ عَلَى أَزْوَاجِنَا﴾ يعني: النساء. قال ابن عباس: (يريدون على نسائنا) {17}.وقوله تعالى: ﴿وَإِنْ يَكُنْ مَيْتَةً﴾. قرأ {18} ابن كثير (يَكُن) بالياء (مَيْتَةٌ) رفعًا.قال أبو بكر: (الميتة: أريد بها الميت زيدت عليها الهاء للإبهام، كما قالوا: الدابة فارة، والشاة ذبحته، والأُرْويَّة {19} عاينته، فيذكّرون إذا {20} كان الحرف يقع على المذكر والمؤنث، وقراءة ابن كثير (وإن يكن ميتة) فالميتة اسم الكون، وخبر الكون مضمر يراد به: وإن يكن لهم ميتة، أو وإن يكن هناك ميتة، وذكر الفعل لأن الميتة في معنى الميت) {21}.وقال أبو علي: (لم يلحق الفعل علامة التأنيث لما كان الفاعل المسند إليه تأنيثه غير حقيقي، ولا يحتاج الكون إلى خبر لأنه بمعنى: وإن وقع ميتة، أو حدث ميتة. وقرأ ابن عامر (وإن تَكُن) بالتاء (مَيْتةٌ) بالرفع، ألحق الفعل علامة التأنيث لما كان الفاعل المسند إليه في اللفظ مؤنثًا، وقرأ عاصم في رواية أبو بكر (وإن تَكُن) بالتاء (مَيْتَةً) بالنصب على تقدير: وإن تكن المذكورة أو المعينة ميتة، فأنث الفعل وإن كان المتقدم مذكرًا؛ لأنه حمله على المعنى. وقرأ الباقون بالياء (ميتةً) بالنصب، تأويله: وإن يكن المذكور ميتة، ذكروا الفعل؛ لأنه مسند إلى ضمير ما تقدم في قوله: ﴿مَا فِي بُطُونِ هَذِهِ الْأَنْعَامِ﴾ [الأنعام:139] وهو مذكر، وانتصب الميتة لما كان الفعل مسندًا إلى الضمير) {22}.وقوله تعالى: ﴿فَهُمْ فِيهِ شُرَكَاءُ﴾ قال ابن عباس: (يريد: الرجال والنساء) {23}، وذكرت الكناية في قوله (فِيهِ) لما ذكرنا أن الميتة غير مختصة بالأنثى {24}؛ لأن المراد بالميتة هاهنا: الحيوان كيف ما كان {25}.وقوله تعالى: ﴿سَيَجْزِيهِمْ وَصْفَهُمْ﴾ قال {26}: (يريد: سيعذبهم بما وصفوا الله به، وما أحلوا مما حرم الله، وما حرموا مما أحل الله) {27}.وقال أبو إسحاق: (المعنى -والله أعلم-: سيجزيهم جزاء وصفهم الذي هو كذب) {28}.وقوله تعالى: ﴿إِنَّهُ حَكِيمٌ عَلِيمٌ﴾ قال ابن عباس: (يريد: أنه أحكم وأعلم من أن يفعل هذا) {29}."
  6,140,"قوله تعالى: ﴿قَدْ خَسِرَ الَّذِينَ قَتَلُوا أَوْلَادَهُمْ﴾، قال ابن عباس {1} والمفسرون {2}: (يعني: الذين كذبوا يدفنون بناتهم أحياء في الجاهلية). وقوله {3} تعالى: ﴿سَفَهًا بِغَيْرِ عِلْمٍ﴾ (سفهًا) منصوب على معنى اللام، أي: للسفه، مثل: فعلت ذلك حذر الشر، ويجوز أن يكون منصوبًا على تأويل المصدر؛ لأن قتلهم أولادهم سفه، فكأنه قال: قد سفهوا سفهًا، والوجهان ذكرهما الزجاج {4}.وقوله تعالى: ﴿وَحَرَّمُوا مَا رَزَقَهُمُ اللَّهُ افْتِرَاءً عَلَى اللَّهِ﴾ قال المفسرون {5} (يعني: البحيرة والسائبة والوصيلة والحامي والحرث، حرموها على أنفسهم، وقالوا: إن الله أمرهم بها). ونصب (افتراء) مثل نصب (سفهًا) {6}."
  6,141,"قوله تعالى: ﴿وَهُوَ الَّذِي أَنْشَأَ جَنَّاتٍ﴾، ذكر الزجاج وجه اتصال هذه الآية بما قبلها فقال: (احتج الله عليهم، ونبه على عظيم ما أتوه في أن أقدموا على الكذب على الله، وشرَّعُوا من الدين ما لم يأذن به فقال: ﴿وَهُوَ الَّذِي أَنْشَأَ جَنَّاتٍ﴾، فكأنه قال: افتروا على الله، وهو المحدِث للأشياء، الفاعِل ما لا يقدر أحد على الإتيان بمثله فقال: ﴿وَهُوَ الَّذِي أَنْشَأَ﴾ أي: أبدع) {1}، يقال: نشأ {2} الشيء ينشأ نشأً ونشأة ونشاءةً إذا ظهر وارتفع، والله ينشئه إنشاءً، أي {3}: يظهره ويرفعه، ويبتدئ خلقه.قوله تعالى: ﴿جَنَّاتٍ مَعْرُوشَاتٍ﴾ يقال: عَرَّشْتُ {4} الكرم أَعْرِشُه عَرْشًا، وعَرَشْتُه تَعْرِيشًا إذا عطفت العيدان التي تُرسل عليها قُضبان الكَرْم، والواحد عَرْش، والجميع عُروش، ويقال: عَرِيش، وجمعه عُرُشٌ، واعْتَرشَ العِنَبُ العَريشَ اعْتِراشًا إذا عَلاه {5}. قال ابن عباس: (يريد: ما يعرش من الكروم. ﴿وَغَيْرَ مَعْرُوشَاتٍ﴾ يريد: أن كثيراً من الأعناب لا يُعرش) هذا قوله في رواية عطاء {6} وهو قول الضحاك {7} والفراء {8}: (إن المعروشات وغير المعروشات كلاهما الكرم خاصّة، منه ما عُرش، ومنه ما لا يُعرش).وروي عن ابن عباس أيضًا أنه قال: (﴿مَعْرُوشَاتٍ﴾ ما انبسط على وجه الأرض، وانتشر مما يعرش، مثل: الكروم والقرع والبطيخ، {وَغَيْرَ مَعْرُوشَاتٍ} ما قام على ساق وبسق {9}، مثل النخل والزرع وسائر الأشجار) {10}.وقوله تعالى: ﴿وَالنَّخْلَ وَالزَّرْعَ﴾ فسر ابن عباس: (الزرع هاهنا بجميع الحبوب التي تقتات، ﴿مُخْتَلِفًا أُكُلُهُ﴾ قال: يريد بكل شيء منها طعم غير طعم الآخر) {11}، والأكل كل ما أكل، وهاهنا المراد به: ثمر النخل والزرع، ومضى القول في الأكل عند قوله تعالى: ﴿فَآتَتْ أُكُلَهَا ضِعْفَيْنِ﴾ [البقرة: 265] وانتصب (مختلفًا) على الحال {12} أي: أنشأه في حال اختلاف أكله.فإن قيل: كيف أنشأه في حال اختلاف أكله وهو قد أنشأه من قبل ظهور أكله، وأكله ثمره؟ والجواب: ما ذكره الزجاج وابن الأنباري {13} وهو: (أن الله تعالى قد دل على خلقه جميع الأشياء في غير موضع من كتابه، فكان في ذلك دليل على إنشائه هذين قبل اختلاف أكلهما، ثم دل على أنه هو المنشئ لهما في حال اختلاف طعم الثمار، فلم يجب بهذا أن يكون غير منشئ لهما فيما تقدم).قال الزجاج: (ويجوز أن يكون أنشأه ولا أكل فيه، ﴿مُخْتَلِفًا أُكُلُهُ﴾؛ لأن المعنى: مقدرًا ذلك فيه، كما تقول: لتدخلن منزل زيدٍ آكلين شاربين، والمعنى: أنكم تدخلون مقدّرين ذلك، وسيبويه {14} مثل هذا بقولهم: مررت برجل معه صقرا صائدًا به غدًا، فنصب صائدًا على الحال، والمعنى: مقدرًا به الصيد) {1}.وقال أبو بكر: (ويجوز أن يكون نصب ﴿مُخْتَلِفًا﴾ على القطع من ﴿وَالنَّخْلَ وَالزَّرْعَ﴾ لا على الحال، والقطع النعت، فكأنه قال: ﴿وَالنَّخْلَ وَالزَّرْعَ﴾ المختلف أكلهما فلما كان (مختلفًا) نكرةً، ﴿وَالنَّخْلَ وَالزَّرْعَ﴾ معرفتان، لم تحمل نكرة على إعراب معرفة، فقطعت من لفظهما، أجاز الكسائي والفراء {16}: جاءني زيد أحمر يا هذا، وقالا: أحمر ينتصب على القطع من زيد على أنه نعتٌ في الأصل، ودال على صاحبه، فإن نصبت على الحال استحالت المسألة، إذ كانت العمرة في الرجل لا تنتقل كما ينتقل الركوب والقيام والجلوس، فالذي ينصبُ (مختلفًا) على القطع يقول: معناه النعت.قال: وأما توحيده الهاء {17} العائدة على ﴿وَالنَّخْلَ وَالزَّرْعَ﴾ فلأنه اكتفي بإعادة الذكر على أحدهما من إعادته عليهما جميعًا كقوله عز وجل: ﴿وَإِذَا رَأَوْا تِجَارَةً أَوْ لَهْوًا انْفَضُّوا إِلَيْهَا﴾ [الجمعة: 11] والمعنى: إليهما. وقوله تعالى: ﴿وَاللَّهُ وَرَسُولُهُ أَحَقُّ أَنْ يُرْضُوهُ﴾ {18} [التوبة: 62] ويجوز أن تكون الهاء مخصوصًا بها النخل؛ لأن أهل التفسير {19} قالوا في قوله: ﴿مُخْتَلِفًا أُكُلُهُ﴾ أي: منه الحامض والمر والحلو والجيد والرديء، وكل هذا من نعت ضروب التمر) {13}.وقوله تعالى: ﴿وَالزَّيْتُونَ وَالرُّمَّانَ مُتَشَابِهًا وَغَيْرَ مُتَشَابِهٍ﴾. قال أبو بكر: وهو قول غيره من المفسرين {21}: (إن ورق الزيتون يشبه ورق الرمان في الشيوع، وفي أن ورقه يشتمل على الغصن ويستره من أوله إلى آخره، فأحدهما متشابه بالآخر في ورقه غير متشابه في ثمره؛ لأن طعم الزيتون غير طعم الرمان، ويجوز أن يكون التشابه وغير التشابه في كل واحد من الزيتون والرمان، وذلك أن الرمان يشبه بعضه بعضًا في اللون والخِلقة، ثم يختلف الطعم فمنه حلو، ومنه حامض، وكذلك الزيتون)، وهذا قول الفراء {22}، وقد مر القول في هذا.وقوله تعالى: ﴿كُلُوا مِنْ ثَمَرِهِ إِذَا أَثْمَرَ﴾: أمر إباحة {23}، ومضى الكلام في الثَّمَر {24} والثُّمُر.وقوله تعالى: ﴿وَآتُوا حَقَّهُ يَوْمَ حَصَادِهِ﴾، قال الأزهري {25}: (يريد -والله أعلم-: يوم حَصْدِه).وقال جميع أهل اللغة: {26} (يقال: حِصَاد وحَصَاد وجِزاز وجَزاز وقِطاف وقَطاف وجِداد وجَداد) {27} قال سيبويه: (جاؤوا بالمصادر حين أرادوا انتهاء الزمان على مثال فِعَال، وربما قالوا فيه: فَعال) {28}.واختلفوا في معنى قوله: ﴿وَآتُوا حَقَّهُ يَوْمَ حَصَادِهِ﴾ أي حقٍّ هو؟ فقال ابن عباس في رواية عطاء {29}: (يعني: زكاته، يريد به: العشر ونصف العشر مما سقى بالسواني). وهذا قول طاووس {30} والحسن {31} وسعيد بن المسيب {32} والضحاك {33} وابن زيد {34} وجماعة {35}.فإن قيل: على هذا كيف يؤدي الزكاة يوم الحصاد والحب في السنبل؟فالجواب: أن معناه قدروا إخراج الواجب منه، فإن وقت الحصاد قريب من زمان التنقية الذي هو وقت وجوب الإخراج هذا في الزرع، فأما في النخل فلا اختلاف بين المسلمين أن ثمارها إذا حصدت وجب إخراج ما يجب فيها من الصدقة. وقوله: ﴿وَآتُوا حَقَّهُ يَوْمَ حَصَادِهِ﴾ ظاهر في ﴿وَالنَّخْلَ وَالزَّرْعَ﴾ محمول عليه في وجوب الإخراج منه، إلا أنه لا يمكن ذلك عند الحصاد فيؤخر إلى زمان التنقية {36}.وقال بعضهم: (هذا حق في المال سوى الزكاة، أمر الله تعالى به تأديبًا وحضًا على البر، فإن فعل فحسن، وإن لم يفعل فلا شيء على تاركه، وليس بأمرٍ حتمٍ).وهذا قول عطاء {37} وحماد {38} والحكم {39} {40} ومجاهد، وإبراهيم ، والربيع، قال مجاهد: (إذا حصدت فحضرك المساكين فاطرح لهم منه، وإذا دسته وذريته فاطرح لهم منه، وإذا كدسته فاطرح لهم منه، فإذا عرفت كيله فاعزل زكاته) {41}. وقال إبراهيم {42}: (هو الضِّغْث) {43}. وقال الربيع {44}: (لقاط السنبل) {45}. وفي الآية قول ثالث، وهو: إن هذا كان قبل وجوب الزكاة فلما فرضت الزكاة نسخ هذا، وهو {46} قول سعيد بن جبير {47} وعطية {48} والسدي، قال السدي: (نسخها العشر ونصف العشر) {49}.وقال مقسم عن ابن عباس: (نسخت الزكاة كل نفقة في القرآن) {50}، والقول هو الأول {51}.وقوله تعالى: ﴿وَلَا تُسْرِفُوا﴾ قال أبو العباس {52} عن ابن الآعرابي: (السَّرَف تجاوز ما حُدّ لك) {53}.وقال شَمِر: (سَرَف الماء ما ذهب منه في غير سقى ولا نفع قال: أرْوَت البئر النخيل وذهب بقيّة الماء سَرَفًا) {54}، فإن أخذت الإسراف مما قاله ابن الأعرابي فهو: مجاوزة الحد، وإن أخذت من قول شمر فهو: الإنفاق فيما لا يجدي عليك {55}.وقد فُسر الإسراف بالوجهين {56} في هذه الآية.وقال ابن عباس: كان رجال يتبرعون عند الصرام، فيقول الرجل: لا أمنع سائلا حتى أمسي، فعمد ثابت بن قيس بن شماس إلى خمسمائة نخلة فجدها ثم قسمها في يومٍ واحدٍ، ولم يدخل منها إلى منزله شيئًا، فأنزل الله ﴿وَآتُوا حَقَّهُ يَوْمَ حَصَادِهِ وَلَا تُسْرِفُوا﴾ أي: لا تعطوا كله {57}.وهذا قول السدي {58} ويمانٍ والفراء {59}، وحكاه الزجاج أيضًا وقال {60}: (فيكون على هذا التأويل، أن الإنسان إذا أعطى كل ماله، ولم يوصل إلى عياله شيئًا فقد أسرف؛ لأنه جاء في الخبر (ابدأ بمن تعول) {61})، فهذا مجاوزة حد الإعطاء.وقال سعيد بن المسيب: (معناه: لا تمنعوا الصدقة) {62}، وهذا يتوجه على أن تأويله: لا تتجاوزوا الحد في البخل والإمساك حتى تمنعوا الواجب من الصدقة، وهذا ضد القول الأول، ولكنهما راجعان إلى معنى مجاوزة الحد، فالأول: مجاوزة في الإعطاء. والثاني: مجاوزة في البخل.وقال مقاتل {63} وعطية: (معناه: لا تشركوا الأصنام في الحرث والأنعام) {64}، وهذا أيضًا من باب المجاوزة؛ لأن من أشرك الأصنام في الحرث والأنعام فقد جاوز ما حُدّ له. وروى عطاء، عن ابن عباس في قوله: ﴿وَلَا تُسْرِفُوا إِنَّهُ لَا يُحِبُّ الْمُسْرِفِينَ﴾ (لا تجعلوا لله شريكًا، إنه لا يحب من جعل له شريكًا) {65}، وهذا أيضًا من مجاوزة الحد.وقال إياس بن معاوية {66}: (ما جاوزت به أمر الله فهو سرف وإسراف) {67}، وهذا كله على الأصل الذي ذكره ابن الأعرابي، وقال الزهري: (معناه: لا تنفقوا في معصية الله) {68}، قال مجاهد: (لو كان أبو قبيس {69} ذهبًا فأنفقه رجل في طاعة الله لم يكن مسرفًا ، ولو أنفق درهمًا في معصية الله كان مسرفًا) {70}، وهذا المعنى أراد حاتم الطائي {71} حين قيل له: لا خير في السرف، فقال: (لا سرف في الخير) {72}، وهذا على الأصل الثاني في معنى السرف، وذلك أن من أنفق في معصية، فقد أنفق فيما لا يجدي عليه {73}.142 - قوله تعالى: ﴿وَمِنَ الْأَنْعَامِ حَمُولَةً وَفَرْشًا﴾ الآية معناها: وأنشأ من الأنعام حمولة وفرشا؛ لأن قوله: ﴿وَمِنَ الْأَنْعَامِ﴾ نسق علي قوله: ﴿وَهُوَ الَّذِي أَنْشَأَ جَنَّاتٍ﴾ [الأنعام: 141] قاله {74} الفراء {59} وأبو إسحاق {76}.وأما الحمولة، فقال الفراء: (الحمولة: ما أطاق العمل والحمل، والفرش: الصغار) {59}.وقال ابن السكيت: (قال أبو زيد: الحمولة: ما احتمل عليه الحيّ من بعير أو حمار أو غيره كانت عليها أحمال أو لم تكن، وأنكر أبو الهيثم ما قاله أبو زيد، وقال: الحمولة من الإبل التي تحمل الأحمال على ظهرها، فأما الحُمر والبغال فلا تدخل في الحمولة) {78}، وقال الليث: (الحمولة: الإبل التي تحمل الأثقال) {79}، وقال النابغة: وأنزلت بيتي في يَفَاعٍ مُمُنَّعٍ ... نُخَالُ به راعِي الحَمُولةِ طَائِرَا {80}وقال عنترة:ما رَاعَني إلاَّ حَمُولَة أَهلِهَا ... وَسْطَ الدِّيار تَسَفُّ حَبَّ الخِمْخِمِ {81}وأما الفرش، فقال أبو إسحاق: (أجمع أهل اللغة {82} على أن الفرش صغار الإبل. قال: وقال بعض المفسرين: الفرش صغار الأنعام، وإن البقر والغنم من الفرش، قال: ويدل على هذا قوله تعالى: ﴿ثَمَانِيَةَ أَزْوَاجٍ مِنَ الضَّأْنِ اثْنَيْنِ﴾ [الأنعام: 143]، فلما جاء هذا بدلاً من قوله ﴿حَمُولَةً وَفَرْشًا﴾ جعله للبقر والغنم مع الإبل) {83}.قال الأزهري {84}: ومما يحقق هذا قوله: وَلَنا الحَامِلُ الحَمولةُ والفرشُ ... من الضَّأنِ والحُصُون السُّيوفُ {85}وقال الليث: (الفرش: من النعم التي لا تصلح إلا للذبح، وهي ما دون الحَمولة) {86}. وقال الكسائي {87}: (الحمولة ما حمل، والفرش الصغار) {88}، هذا قول أهل اللغة {89} في تفسير الحرفين.وأما {90} المفسرون فقال عطاء، عن ابن عباس: (﴿حَمُولَةً﴾: الحوامل، ﴿وَفَرْشًا﴾: الذي ليس بحامل) {91}.وقال ابن مسعود: (الحمولة: الكبار، والفرش: الصغار) {92}.وقال الحسن: (الفرش: الحواشي) {93}.وروي عن ابن عباس {94}: (أن الحمولة: الإبل والخيل والبغال والحمير، وكل شيء يحمل عليه، وأما الفرش: فالغنم) {95}، وهذا مثل قول أبي زيد في الحمولة.وقال مجاهد: (الحمولة: ما حمل عليها، والفرش: صغار الإبل) {96}وقال قتادة: (الحمولة: الإبل، والفرش: البقر والغنم) {97}.وقال الربيع بن أنس: (الحمولة: الإبل والبقر، والفرش: الماعز والضأن) {98}، ونحو ذلك قال الكلبي {99}.وقوله تعالى: ﴿كُلُوا مِمَّا رَزَقَكُمُ اللَّهُ﴾. قال ابن عباس: (يريد: أحل الله لكم الذبائح مما ذكر اسم الله عليه) {100}.وقال أبو إسحاق: (أي: لا تُحرموا ما حرمتم مما جرى ذكره) {83}.﴿وَلَا تَتَّبِعُوا خُطُوَاتِ الشَّيْطَانِ﴾ (يريد: ما زين الشيطان وشرع عمرو بن لحي)، قاله ابن عباس {102}. وقال الزجاج: (المعنى: لا تسلكوا الطريق الذي يُسَوّله لكم الشيطان) {103}.وقوله تعالى: ﴿إِنَّهُ لَكُمْ عَدُوٌّ مُبِينٌ﴾ قال ابن عباس: (يريد: بيّن العداوة، أخرج آدم من الجنة، وهو القائل: ﴿لَأَحْتَنِكَنَّ ذُرِّيَّتَهُ إِلَّا قَلِيلًا﴾ [الإسراء: 62] {104}."
