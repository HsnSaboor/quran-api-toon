tafsir[7]{c,v,t}:
  27,57,"قوله: ﴿قَدَّرْنَاهَا مِنَ الْغَابِرِينَ﴾ [قال مقاتل: تركناها {1}. والمعنى: جعلناها بتقديرنا من الغابرين {2}] {3} أي: قدرناها بما كتبنا عليها، وقضينا أنها ﴿مِنَ الْغَابِرِينَ﴾ أي: الباقين في العذاب {4}."
  27,58,"وقوله: ﴿وَأَمْطَرْنَا عَلَيْهِمْ مَطَرًا فَسَاءَ مَطَرُ الْمُنْذَرِينَ﴾ أي: على شذاذها مطرًا وهو الحجارة {1} ﴿فَسَاءَ مَطَرُ الْمُنْذَرِينَ﴾ مر تفسيره في سورة الشعراء [الآية 173]."
  27,59,"قوله: ﴿قُلِ الْحَمْدُ لِلَّهِ﴾ المفسرون على أن هذا خطاب لرسول الله -ﷺ-، أُمِر أن يقول: ﴿الْحَمْدُ لِلَّهِ﴾ {1}. قال مقاتل: على هلاك كفار الأمم الخالية {2}.وقال الفراء: قيل للوط: ﴿قُلِ الْحَمْدُ لِلَّهِ﴾ على هلاك من هلك {3}. والتقدير على هذا: وقلنا للوط: ﴿قُلِ الْحَمْدُ لِلَّهِ﴾ والمفسرون على ما ذكرنا.قوله تعالى: ﴿وَسَلَامٌ عَلَى عِبَادِهِ الَّذِينَ اصْطَفَى﴾ قال مقاتل: هم الأنبياء الذين اختارهم الله لرسالته {4}.وقال ابن عباس في رواية أبي مالك: هم أصحاب محمد -ﷺ- {5}. وهو قول السدي، وسفيان بن سعيد {6}.وقال عطاء عنه: يريد الذين وحدوني وآمنوا بي {7}. وعلى هذا هم جميع المؤمنين {8}.وقال الكلبي: هم أمة محمد -ﷺ-، اصطفاهم الله لمعرفته وطاعته {9}. ومعني السلام عليهم: أنهم سَلِموا مما عاب به الكفار.ثم قال: ﴿آللَّهُ خَيْرٌ أَمَّا يُشْرِكُونَ﴾ {10} قال ابن عباس: ثم رجع إلى المشركين فقال: ﴿آللَّهُ خَيْرٌ أَمَّا يُشْرِكُونَ﴾ يا أهل مكة، يريد: الذين جعلتموهم لي أندادًا.وقال مقاتل: أراد يشركون به. يقول: الله أفضل أم الآلهة التي يعبدونها، يعني: كفار مكة، قال: وكان النبي إذا قرأ هذه الآية قال: ""بل الله خير وأبقى وأجل وأكرم"" {11}.وهذا مذهب أهل التفسير {12}.وجعل الفراء هذه الآية من باب حذف المضاف؛ فقال: يقول: أعبادة الله خير أم عبادة الأصنام {3}. وأحسن من هذا أن يقال: الله خير لمن عبده أم الأصنام؛ يدل على صحة هذا أن هذا ذُكر بعد ذكر هلاك الكفار وسلامة المؤمنين، إلزامًا للحجة على المشركين، فقيل لهم بعد ما ذُكر هلاك الكفار: الله خير أم الأصنام. والمعنى: أن الله نجَّى مَنْ عبده من الهلاك، والأصنامُ لم تغن شيئاً عن عابديها عند نزول العذاب. وهذا معنى ما ذهب إليه المفسرون؛ وإن لم يبينوا هذا البيان.وقال أهل المعاني: يجوز في الخير الذي لا شر فيه، والشر الذي لا خير فيه إذا كان يتوهم بعض الجهال الأمر على خلاف ما هو به أن يقال: هذا الخير خير من الشر، فلما كان المشركون يتوهمون في الأصنام وفي عبادتها خيرًا، قيل لهم احتجاجًا عليهم: ﴿آللَّهُ خَيْرٌ أَمَّا يُشْرِكُونَ﴾ {14}."
  27,60,"قوله تعالى: ﴿أَمَّنْ خَلَقَ السَّمَاوَاتِ وَالْأَرْضَ﴾ {1} تقدير الكلام: أما تشركون خير أم من خلق السموات والأرض، فحذف ذكر الأول لقرب ذكره في قوله: ﴿أَمَّا يُشْرِكُونَ﴾ وهذا معنى قول أبي حاتم {2}.وقوله: (حَدَائِقَ) قال الليث: الحديقة: أرض ذات شجر مثمر، والحديقة من الرياض: كل روضة قد أحدق بها حاجزٌ، أو أرضٌ مرتفعة، وأنشد لطرفة:تَرَبعت القُفَّين في الشَّول ترتعي ... حدائق مَولِيِّ الأسرةِ أَغْيدِ {3}وكل شيء استدار بشيء فقد أحدق به {4}.وقال أبو عبيدة: الحديقة والجنة في الدنيا مثل الحائط {5}.قال الفراء: إنما يقال حديقة لكل بستان عليه حائط، وما لم يكن عليه حائط لا يقال له: حديقة {6}.وقال ابن قتيبة: إنما يقال حديقة؛ لأنها يُحدَق عليها، أي: يُحْظَر {7}.قال ابن عباس: يريد الأجنة والشجر {8}.وقال مقاتل: يعني حيطان النخل والشجر {9}.وقال الكلبي: الحدائق من البساتين: ما أحيط عليه حائط {10}.قوله: ﴿ذَاتَ بَهْجَةٍ﴾ قال الكلبي: ذات منظر حسن {11}.وقال ابن عباس ومقاتل: ذات حُسن {12}.وقال قتادة: النخل الحسان {13}.والبهجة: الحُسْن يبتهج به مَنْ رآه، أي: يُسر.قوله: ﴿مَا كَانَ لَكُمْ أَنْ تُنْبِتُوا شَجَرَهَا﴾ أي: ما ينبغي لكم ذلك؛ لأنكم لا تقدرون عليها {14}.ثم قال مستفهمًا منكرًا عليهم: ﴿أَإِلَهٌ مَعَ اللَّهِ﴾ أي: هل معه معبود سواه أعانه على صنعه {15} ﴿بَلْ﴾ أي: ليس معه إله ﴿هُمْ قَوْمٌ﴾ يعني: كفار مكة ﴿يَعْدِلُونَ﴾ يشركون به غيره. هذا معنى قول المفسرين {16}. وقال أبو إسحاق: يعدلون عن القصد والحق، أي: يكفرون {17}."
  27,61,"وقوله: ﴿أَمَّنْ جَعَلَ الْأَرْضَ قَرَارًا وَجَعَلَ خِلَالَهَا أَنْهَارًا﴾ قال مقاتل: مستقرًا لا تميد بأهلها {1} ﴿وَجَعَلَ خِلَالَهَا﴾ فيما بينها {2} ﴿أَنْهَارًا﴾ كقوله: ﴿وَفَجَّرْنَا خِلَالَهُمَا نَهَرًا﴾ [الكهف 33].﴿وَجَعَلَ لَهَا رَوَاسِيَ﴾ قال ابن عباس: يريد الجبال الثوابت أَثْبَتَ بها الأرض {3}.﴿وَجَعَلَ بَيْنَ الْبَحْرَيْنِ حَاجِزًا﴾ قال: يريد قضاء من قضائه، وسلطانًا من قدرته، حجز بين العذب والمالح، فلا المالح يغير العذب، ولا العذب يغير المالح. وهذا قول أكثر المفسرين {4}. ومعنى الحجز في اللغة: المنع.قال أبو إسحاق: حجز بينهما بقدرته فلا يختلط العذب بالملح {5}.وقال أهل المعاني: ويكون ذلك بكف كل واحد منهما عن صاحبه، وفيه دليل على أن الله تعالى قادر على كف النار عن الحطب حتى لا تحرقه، ولا تسحقه، كما كف الماء الملح عن العذب المجاور له أن يختلط به.وقال السدي: قول الله تعالى: ﴿وَجَعَلَ بَيْنَ الْبَحْرَيْنِ حَاجِزًا﴾ هي البرزخ، وهو الحجر المحجور، وهو بحر الشام وبحر العراق والناس فيما بينهما؛ وعلى هذا معنى الحاجز بين البحرين: الجزائر والأرض والبلاد كما بين بحر فارس وبحر الروم {6}. والناس على القول الأول.قوله تعالى: ﴿أَإِلَهٌ مَعَ اللَّهِ بَلْ أَكْثَرُهُمْ لَا يَعْلَمُونَ﴾ توحيدَ ربهم، وسلطانَه وقدرته. قاله ابن عباس ومقاتل {7}.وقال أهل المعاني: لا يعلمون ما لهم وما {8} عليهم في العبادة إن أخلصوها أو أشركوا فيها {9}."
  27,62,"قوله عز وجل: ﴿أَمَّنْ يُجِيبُ الْمُضْطَرَّ إِذَا دَعَاهُ﴾ {1} قال عطاء عن ابن عباس: المضطر: المكروب. وعنه أيضًا: هو المجهود {2}. ومعنى المضطر في اللغة: المحوج الملجأ إلى الشيء. وقد مر {3}.قال أهل المعاني: ومعنى إجابة المضطر هو فِعل ما دَعا إليه؛ وهذا لا يكون إلا من قادر على الإجابة مختار لها؛ لأنها وقعت على حسب ما دعا به الداعي {4}.﴿وَيَكْشِفُ السُّوءَ﴾ الضر {5} ﴿وَيَجْعَلُكُمْ خُلَفَاءَ الْأَرْضِ﴾ قال السدي: خلفاء مَنْ قبلكم من الأمم {6}.وقال غيره: معناه: جعلكم خلفاء {7} يخلف كل قرن منكم القرن الذي قبله، وأهلُ كل عصر أهل العصر الأول {8}. والمعنى: يهلك قرنًا وينشئ آخرين {9}. وهذا معنى {10} قول ابن عباس: يريد: أولادُكم خلفاءُ منكم.قوله عز وجل: ﴿قَلِيلًا مَا تَذَكَّرُونَ﴾ قال ابن عباس: قليلاً ما تتعظون.ومن قرأ بالياء فالمعنى: قليلاً يذَّكر هؤلاء المشركون الذين يجعلون مع الله آلهة أخرى {11}."
  27,63,"وقوله: ﴿أَمَّنْ يَهْدِيكُمْ﴾ أي: يرشدكم {1} ﴿فِي ظُلُمَاتِ الْبَرِّ وَالْبَحْرِ﴾ [قال ابن عباس: يريد إلى البلاد التي يتوجهون إليها في البر والبحر. وهذا كقوله: ﴿وَهُوَ الَّذِي جَعَلَ لَكُمُ النُّجُومَ لِتَهْتَدُوا بِهَا فِي ظُلُمَاتِ الْبَرِّ وَالْبَحْرِ﴾] {2} [الأنعام: 97]."
