tafsir[7]{c,v,t}:
  6,45,"قوله تعالى: ﴿فَقُطِعَ دَابِرُ الْقَوْمِ الَّذِينَ ظَلَمُوا﴾ الدابر: التابع {1} [للشيء من خلفه كالولد للوالد.قال الليث: (الدبر التابع {2}] يقال: دبر فلان القوم يدبرهم دبرًا ودبورًا إذا كان آخرهم) {3}.قال أمية بن أبي {4} الصلت:فَاستؤصلُوا بِعَذَابٍ حَصَّ دَابِرَهُمْ ... فَمَا اسْتَطَاعُوا لَهُ صَرْفًا وَلا انْتَصرُوا {5}وقال أبو عبيدة: (﴿دَابِرُ الْقَوْمِ﴾: آخرهم الذي يدبرهم {6}، وأنشد:آلُ المُهَلَّبِ جَذَّ اللهُ دابِرَهُمْ ... أَضْحَوْا رَمَادًا فلا أصْلٌ ولا طَرَفُ) {7}وقال الأصمعي وغيره: (الدابر: الأصل، يقال: قطع الله دابره، أي: أذهب الله أصله، وأنشده {8}:فِدًى لكُمَا رجْلَيَّ رحلي وناقتي ... غَداةَ الكُلاَّبِ إذ تُحَزُّ الدَّوابِرُأي: يقتل القوم فتذهب {9} أصولهم ولا يبقى لهم أثر) {10}.وقال ابن بزرج {11}: (دابر الأمر: آخره. ودابر الرجل: عقبه، وقولهم: قطع الله دابرهم: دعاء عليه {12} بانقطاع العقب حتى لا يبقى أحد يخلفه). {13}فأما التفسير: فقال الكلبي: (﴿دَابِرُ الْقَوْمِ﴾ غابرهم الذي يتخلف في آخر القوم) {14}، ونحو ذلك قال قطرب {15} {16}.وقال السدي وابن زيد: (﴿دَابِرُ الْقَوْمِ﴾: أصل القوم) {17}، والمعنى: قُطع خلفهم من نسلهم وغيرهم، فلم تبق {18} لهم باقية؛ لأنهم استؤصلوا بالعذاب. وأحسب الذين فسروا الدابر بالأصل ذهبوا إلى أن الأصل يبقى ببقاء النسل، فإذا انقطع النسل {19} انقطع الأصل وذهب، ففي قطع الدابر قطع الأصل، وحقيقة تفسير الدابر الآخر {20} والعقب والأصل معنى وليس بتفسير.وقوله تعالى: ﴿وَالْحَمْدُ لِلَّهِ رَبِّ الْعَالَمِينَ﴾ قال الزجاج {21}: (حمد الله عز وجل نفسه على أن قطع دابرهم واستأصل شأفتهم) {22}، ومعنى هذا: أن قطع دابرهم نعمة على الرسل الذين أرسل إليهم فكذبوهم، فذكر الحمد هاهنا تعليم لهم ولمن آمن بهم ليحمدوا الله تعالى على كفايته إياهم شر الذين ظلموا ، وليحمد محمد ﷺ وأصحابه ربهم إذ أهلك المشركين المكذبين {23}."
  6,46,"قوله تعالى: ﴿قُلْ أَرَأَيْتُمْ إِنْ أَخَذَ اللَّهُ سَمْعَكُمْ وَأَبْصَارَكُمْ وَخَتَمَ عَلَى قُلُوبِكُمْ﴾ قال ابن عباس: (يريد: فلا يسمعون القرآن {1}، ولا يبصرون {2} سبل الهدى، ولا يفهمون {3} ثوابًا ، ولا يخافون عقابًا) {4}.وقال الكلبي: (أي ﴿أَخَذَ اللَّهُ سَمْعَكُمْ﴾ فلا تسمعوا موعظة، ﴿وَأَبْصَارَكُمْ﴾ فلا تبصروا الحق، ﴿وَخَتَمَ﴾ وطبع ﴿عَلَى قُلُوبِكُمْ﴾ فلم تعرفوا {5} الحق ولم تعقلوا الهدى) {6}، ونحو هذا قال مقاتل {7}.وقوله تعالى: ﴿مَنْ إِلَهٌ غَيْرُ اللَّهِ يَأْتِيكُمْ بِهِ﴾) ﴿مَنْ﴾ رفع بالابتداء وخبره ﴿إِلَهٌ﴾ و ﴿غَيْرُ﴾ صفة له {8}.وقوله تعالى: ﴿يَأْتِيكُمْ بِهِ﴾ قال الزجاج: (هذه الهاء تعود على معنى الفعل المعنى ﴿مَنْ إِلَهٌ غَيْرُ اللَّهِ يَأْتِيكُمْ﴾ ما أُخذ منكم، قال: ويجوز أن يعود على السمع ويكون ما عطف على السمع داخلًا في القصة معه إذ كان معطوفًا عليه) {9}.قال الحسين {10} بن الفضل {11}: (المخاطبة للمؤمنين؛ لأن الكفار كانوا صماً بكمًا عميًا لا يعقلون؛ لأن {12} الله قد أخذها منهم، وكأنه يقول للمؤمنين: أرأيتم إن أخذها الله منكم فمن يردها عليكم) {13}.واختلفوا في قوله: ﴿بِهِ انْظُرْ﴾ فروى المسيبي {14} عن نافع ﴿بِهِ انْظُرْ﴾ بضم الهاء {15} هو على لغة من يقرأ: ﴿فَخَسَفْنَا بِهِ وَبِدَارِهِ الْأَرْضَ﴾ [القصص: 81] {16} فحذف الواو لالتقاء الساكنين فصار ﴿بِهِ انْظُرْ﴾، والباقون يكسرون الهاء {17}.قال ابن عباس في قوله تعالى: ﴿مَنْ إِلَهٌ غَيْرُ اللَّهِ يَأْتِيكُمْ بِهِ﴾ (أي: لا يقدر هؤلاء الذين تعبدون أن يجعلوا لكم أسماعًا وأبصارًا وقلوبًا تعقلون {18} بها وتفهمون) {19} وهذا يدل على أن الآية في الكفار، وكذلك باقي الآية يدل على هذا، وحينئذٍ يحمل أخذ هذه الأعضاء على إذهابها أصلا يقول: إن أخذها حتى لا تبصروا ولا تسمعوا بتة من يردها عليكم {20}.وقوله تعالى: ﴿انْظُرْ كَيْفَ نُصَرِّفُ الْآيَاتِ﴾ قال الكلبي: (يبين لهم في القرآن الآيات) {21}.وقال أهل المعاني: (معنى تصريف الآيات: توجيهها في الجهات التي تظهرها أتم الإظهار).وقوله تعالى: ﴿ثُمَّ هُمْ يَصْدِفُونَ﴾ قال الليث: (الصدوف: الميل عن الشيء) {22}، وقال أبو عبيد: (صدف، ونكب: عدل) {23}.وقال ابن عباس {24} والحسن {25} ومجاهد {26} وقتادة {27} والسدي {28}: ﴿ثُمَّ هُمْ يَصْدِفُونَ﴾: (يعرضون) {29} قال عدي بن الرقاع:إِذَا ذَكَرْنَ حَدِيثاً قُلْنَ أَحْسَنَهُ ... وهُنَّ عَنْ كُلِّ سُوءٍ يُتَّقَى صُدف {30}قال أبو إسحاق: (أعلم الله عز وجل أنه يُصرف لهم الآيات، وهي العلامات التي تدل على توحيده وصحة نبوة نبيه ﷺ، ثم هم يعرضون عما وضح لهم وظهر عندهم) {31}."
  6,47,"قوله تعالى: ﴿قُلْ أَرَأَيْتَكُمْ إِنْ أَتَاكُمْ عَذَابُ اللَّهِ بَغْتَةً أَوْ جَهْرَةً﴾ قال ابن عباس والحسن: (ليلًا أو نهارًا) {1} وقال الكلبي: (فجأة أو علانية) {2}.قال أهل المعاني: (نقيض الجهرة الخفية، وهاهنا قوبل بالبغتة؛ لأن البغتة متضمنة معنى الخفية؛ لأنه يأتيهم من حيث لا يشعرون، فخفى {3} سببه) {4}.وقوله تعالى: ﴿هَلْ يُهْلَكُ إِلَّا الْقَوْمُ الظَّالِمُونَ﴾ قال ابن عباس: (يريد: الذين جعلوا لله شركاء) {5}، قال الزجاج: (أي: ﴿هَلْ يُهْلَكُ﴾ إلا أنتم ومن أشبهكم؛ لأنكم كفرتم وأنتم معاندون وقد علمتم أنكم ظالمون) {6}."
  6,48,"قوله تعالى: ﴿وَمَا نُرْسِلُ الْمُرْسَلِينَ﴾ الآية، قال أبو إسحاق: (أي: ليس إرسالهم أن يأتوا الناس بما يقترحون عليهم من الآيات إنما يأتون من الآيات بما يبين براهينهم، وإنما قصدهم التبشير والإنذار) {1}، ثم ذكر ثواب المصدّق في باقي الآية وعقاب المكذب في الآية الثانية وهي قوله تعالى: ﴿وَالَّذِينَ كَذَّبُوا بِآيَاتِنَا يَمَسُّهُمُ الْعَذَابُ﴾ [الأنعام: 49] ومعنى المسّ {2} في اللغة: التقاء الشيئين من غير فصل، وقيل: ﴿يَمَسُّهُمُ الْعَذَابُ﴾ لأنه يحل فيهم وكأنه مماس لهم والفرق {3} بينه وبين اللمس: أن اللمس مماسه بحاسّة والمسّ قد يكون بحاسّة وبغير حاسّة؛ لأن الحجر يماسّ الحجر ولا يلمسه {4}."
  6,50,"قوله تعالى: ﴿قُلْ لَا أَقُولُ لَكُمْ عِنْدِي خَزَائِنُ اللَّهِ﴾ الآية الخزائن {1}: جمع الخِزانة وهي اسم المكان الذي يُخزن فيه الشيء. وخَزَنُ الشيء إحرازُه بحيث لا تناله {2} الأيدي، والخزانة أيضًا عمل الخازن {3}، قال ابن عباس {4}: (يريد: خزائن رحمة الله).وقال الكلبي {5}: (أي: رزق الله).وقوله تعالى: ﴿وَلَا أَعْلَمُ الْغَيْبَ﴾ قال ابن عباس: (يريد: عاقبة ما يصيرون إليه) {6}، وقال الكلبي {7}: (يعني: نزول ذلك الرزق على ﴿وَلَا أَقُولُ لَكُمْ إِنِّي مَلَكٌ﴾ {8} فتنكروا قولي وتجحدوا أمري).وقوله تعالى: ﴿إِنْ أَتَّبِعُ إِلَّا مَا يُوحَى إِلَيَّ﴾ قال ابن عباس: (يريد: ما أخبركم إلا بما أنزله الله إلى) {9}.وقال الكلبي {10}: (أي: ما أعمل إلا بما ينزل عليّ).وقال أبو إسحاق: (أعلمهم النبي ﷺ أنه لا يملك خزائن الله التي منها يرزق ويعطي ولا يعلم الغيب فيخبركم بما غاب عنه مما مضى ومما سيكون إلا بوحي من الله عز وجل وليس بملك يشاهد من أمور الله عز وجل ما لا يشاهده البشر: ﴿إِنْ أَتَّبِعُ إِلَّا مَا يُوحَى إِلَيَّ﴾ {11}، (أي: ما أنبأتكم به من غيب فيما مضى وفيما سيكون فهو بوحي من الله عز وجل) {12}.وقال أهل العلم {13} قوله: ﴿إِنْ أَتَّبِعُ إِلَّا مَا يُوحَى إِلَيَّ﴾ (يدل بظاهره على {14} أن الرسل لا يجتهدون ولا يقيسون، والصحيح من مذهب الشافعي أنهم يقيسون ويجتهدون، وعنده أن القياس على النصوص بالوحي اتباع للوحي) {15}.وقوله تعالى: ﴿قُلْ هَلْ يَسْتَوِي الْأَعْمَى وَالْبَصِيرُ﴾ قال ابن عباس: يريد: بالأعمى: الكافر ﴿وَالْبَصِيرُ﴾ الذي قد أبصر دينه) {16}.وقال قتادة: ﴿الْأَعْمَى وَالْبَصِيرُ﴾: (الكافر والمؤمن) {17}.وقال سعيد ابن جبير {18} ومجاهد {19}: (الضالّ، والمهتدي)، وقيل: الجاهل، والعالم) {20}.(أَفَلاَ تَتَفَكَّرُونَ) قال ابن عباس: (يريد: يعتبرون {21}) {22}.وقال مقاتل: ((أَفَلاَ تَتَفَكَّرُونَ) {23} أنهما لا يستويان) {24}."
  6,51,"قوله تعالى: ﴿وَأَنْذِرْ بِهِ الَّذِينَ يَخَافُونَ أَنْ يُحْشَرُوا إِلَى رَبِّهِمْ﴾ الآية، معنى الإنذار {1}: الإعلام بموضع المخافة، وهو مما تقدم {2} بيانه {3}، وقوله: ﴿بِهِ﴾ قال ابن عباس: (يقول: خوَّف بالقرآن) {4}.وقاله الزجاج {5}، وقال الضحاك: (بالله) {6}.وقوله تعالى: ﴿الَّذِينَ يَخَافُونَ أَنْ يُحْشَرُوا﴾ قال ابن عباس {7} والحسن {8}: (يريد المؤمنين يخافون يوم القيامة وما فيها من شدة الأهوال).وقال الضحاك {9}: (يعلمون ﴿أَنْ يُحْشَرُوا إِلَى رَبِّهِمْ﴾).قال الفراء: ﴿يَخَافُونَ أَنْ يُحْشَرُوا إِلَى رَبِّهِمْ﴾ (علمًا بأنه سيكون، ولذلك فسر المفسرون ﴿يَخَافُونَ﴾: يعلمون) {10}.وقال الزجاج: (المراد بالذين ﴿يَخَافُونَ أَنْ يُحْشَرُوا﴾ كل معترف بالبعث من مسلم وكتابي. قال {11}: وإنما خص الذين يخافون الحشر دون غيرهم وهو ﷺ كان ينذر جميع الخلق؛ لأن ﴿الَّذِينَ يَخَافُونَ﴾ الحشر الحجة عليهم أوجب، لاعترافهم بالمعاد) {12}. وقال غيره من أهل المعاني: (هم الكفار؛ لأنهم يشكّون في الحشر، ولذلك قال: ﴿يَخَافُونَ أَنْ يُحْشَرُوا﴾) {13}.وقوله تعالى: ﴿إِلَى رَبِّهِمْ﴾ أي: إلى المكان الذي جعله ربهم لمجتمعهم {14}.وقوله تعالى: ﴿لَيْسَ لَهُمْ مِنْ دُونِهِ وَلِيٌّ وَلَا شَفِيعٌ﴾ موضع ﴿لَيْسَ﴾ نصب بوقوعها موقع الحال، كأنه قيل: متخلّين من ولي أو شفيع والعامل فيه ﴿يَخَافُونَ﴾ {15}، قال الضحاك: ﴿لَيْسَ لَهُمْ مِنْ دُونِهِ﴾ (أي: غير الله ﴿وَلِيٌّ وَلَا شَفِيعٌ﴾) {16}.وقال أبو إسحاق: (إن النصارى واليهود ذكرت أنها أبناء الله وأحباؤه فأعلم الله عز وجل أن أهل الكفر ليس لهم من دون الله ولي ولا شفيع) {17}، وهذا الذي قاله ظاهر في أهل الكفر.والمفسرون على أن الآية في المؤمنين، ويكون معنى قوله: ﴿لَيْسَ لَهُمْ مِنْ دُونِهِ وَلِيٌّ وَلَا شَفِيعٌ﴾ على قولهم: إن شفاعة الرسل والملائكة للمؤمنين إنما تكون بإذن الله لقوله تعالى: ﴿مَنْ ذَا الَّذِي يَشْفَعُ عِنْدَهُ إِلَّا بِإِذْنِهِ﴾ [البقرة: 255]، وذلك راجع إلى الله لما كان بإذن الله {18}.وقوله تعالى: ﴿لَعَلَّهُمْ يَتَّقُونَ﴾ قال ابن عباس: (كي يخافون في الدنيا وينتهوا عما نهيتهم) {19}."
  6,52,"قوله تعالى: ﴿وَلَا تَطْرُدِ الَّذِينَ يَدْعُونَ رَبَّهُمْ بِالْغَدَاةِ وَالْعَشِيِّ﴾ الآية. أخبرنا الشيخ أبو بكر أحمد بن محمد الحارثي، أنبأ أبو محمد عبد الله بن محمد {1} بن جعفر، حدثنا أبو يحيى عبد الرحمن {2} بن محمد الدارمي {3}، حدثنا سهل بن عثمان {4} العسكري، حدثنا أسباط {5} بن محمَّد، عن الأشعث {6} بن سوار عن كردوس {7}، عن عبد الله بن مسعود قال: (مر الملأ من قريش على رسول الله ﷺ وعنده صهيب {8} وخبّاب {9} وبلال {10} وعمار وغيرهم {11} من ضعفاء المسلمين، فقالوا: يا محمد، رضيت بهؤلاء عن قومك، أفنحن نكون تبعًا لهؤلاء {12} الذين مَنَّ الله عليهم! إطردهم عنك فلعلك إن طردتهم اتبعناك، فأنزل الله هذه الآية) {13}.وقال خباب بن الأرت: (كنا مع النبي ﷺ أنا وعمار، وصهيب، إذ جاء عيينة بن {14} حصن {15} والأقرع {16} بن حابس. فقالا له: إنه {17} لا يحسن بنا الجلوس مع هؤلاء العبيد الفقراء، فأقمهم عنك حتى نخلو بك، فإن وفود العرب تأتيك، فنستحي أن يرونا مع هؤلاء الأعبُد، ثم إذا انصرفنا فإن شئت فأعدهم إلى مجلسك، فأجابهم النبي ﷺ إلى ذلك فقالا له: اكتب لنا بهذا على نفسك كتابًا فدعا بصحيفة وأحضر عليًّا -رضي الله عنه- ليكتب، فأنزلت هذه الآية وما بعدها، فنحّى رسول الله ﷺ الصحيفة، وأقبل علينا، ودنونا منه) {18}.قال ابن الأنباري: (عظم الأمر في هذا على النبي ﷺ وخوف الدخول في جملة الظالمين؛ لأنه كان قد همّ بتقديم الرؤساء وأُولي الأموال على الضعفاء وذوي المسكنة، مقدّرًا أنه يستجر بإسلامهم إسلام قومهم وحلفائهم ومن يلوذ بهم، وكان عليه السلام لا يقصد في ذلك إلا قصد الخير، ولا ينوي ازدراء بالفقراء ولا احتقارًا، فأعلمه الله تبارك وتعالى أن ذلك غير جائز) {19}.وأما التفسير فقال ابن عباس في قوله تعالى: ﴿يَدْعُونَ رَبَّهُمْ بِالْغَدَاةِ وَالْعَشِيِّ﴾ (يعبدون ربهم بالصلاة المكتوبة يعني: صلاة الصبح وصلاة العصر) {20}.فالدعاء هاهنا العبادة في قول ابن عباس والحسن {21} ومجاهد {22} وقتادة {23} والضحاك {24} قالوا: (يعبدون الله بالصلاة المكتوبة).وقال إبراهيم {25}: (الدعاء هاهنا الذكر، أي: يذكرون ربهم طرفي النهار) {26}. وروي عن إبراهيم بخلاف هذا، وهو أنه قال: (هذا في الصلوات الخمس) {27}، وهو قول جميع أهل التأويل {28} قالوا: (هذا في الصلوات المكتوبات).وقرأ ابن عامر: (بِالْغُدْوةِ) {29} بالواو {30}، وقال أبو علي: (الوجه قراءة العامة ﴿بِالْغَدَاوةِ﴾؛ لأنها تستعمل نكرة وتتعرف {31} باللام، فأما (غدوة) فمعرفة وهو علم صيغ له واسم موضوع {32} للتعريف وإذا كان كذلك فلا ينبغي أن يُدخل عليه الألف واللام كما لا يُدخل على سائر الأعلام، وإن كانت قد كتبت في المصحف بالواو لم تدل على ذلك ألا ترى أنهم قد كتبوا (الصلوة) بالواو وهي ألف فكذلك (الغداة).قال سيبويه: (غدوة وبكرة جُعل كل واحد منهما اسمًا للحين، كما جعلوا أم حُبين {33} اسما لدابة معروفة. قال: وزعم يونس عن أبي عمرو أنك إذا قلت: لقيته يومًا من الأيام غدوة أو بكرة وأنت تريد المعرفة لم تنون) {34}، وهذا يقوي قراءة العامة، ووجه قراءة ابن عامر أن سيبويه {35} قال: (زعم الخليل أنه يجوز أن يقول: أتيتك اليوم غدوةً وبكرةً، فجعلهما بمنزلة ضحوة {36}).وأيضاً فإن بعض أسماء الزمان جاء معرفة بغير ألف ولام ثم أجازوا دخول اللام فيه نحو ما حكاه أبو زيد من: (قولهم: لقيته فَيْنة {37} غير معروف والفينة بعد الفينة) {38} فألحق لام المعرفة، ما استعمل معرفةً ووجه ذلك أنه يقدر فيه التنكير والشيوع كما يقدر فيه {39} ذلك إذا ثني، [وذلك مستمر في جميع المعارف) {40} انتهى كلامه. قوله: (يقدر فيه التنكير كما يقدر فيه ذلك إذا ثني) {41}] كلام يُحتاج إلى شرحه فنقول: اعلم أن المعرفة: [لا يصح تثنيتها من قبل أن حدّ المعرفة {42}] أنها ما خص الواحد من جنسه ولم يشع في أُمته، فإذا شورك في اسمه فقد خرج عن أن يكون علمًا معروفًا، وصار مشتركًا فيه شائعًا، وإذا كان الأمر كذلك فلا تصح التثنية إلا في النكرات دون المعارف، وإذا صح هذا فإنك لم تُثَنّ زيدًا حتى سلبته تعريفه وأشعته في أمته فجعلته من جماعة كل واحد منهم زيد، فجرى لذلك {43} مجرى فرس ورجل في أن كل واحد منهما شائع لا يخص واحداً بعينه، وصار كأنه بعد نزع التعريف عنه يجوز أن يقال: الزيد والعمر كما قال ابن ميادة {44}:وجدنا الَولِيدَ بْنَ اليَزِيدِ مُبَارَكًا ... شَدِيدًا بأعْبَاءِ الخِلاَفَةِ كَاهِلُهْ {45} وكما أنشد ابن السكيت {46}:يا ليتَ أُمَّ العمرو {47} كانت صاحبيويدلك {48} على أنه لا يثنى إلا بعد خلع التعريف عنه دخول اللام عليه بعد التثنية في قولك: الزيدان والعمران {49}، ولو كان التعريف الذي كانا يدلان عليه مفردين باقيًا فيهما لما جاز دخول اللام عليهما بعد التثنية، كما لا يجوز ذلك قبل التثنية في وجه الاستعمال وغالب الأمر، وكما نزعوه التعريف بالتثنية نزعوه أيضًا بالإضافة قال الشاعر {50}: لَاَ زيدُنَا يَوْمَ النَّقَا رأسَ زَيْدِكُمْ ... بِأَبْيَضَ مِنْ ماءِ الحدِيدِ يَمَانِفإضافة الاسم يدل على أنه قد كان خلع عنه ما كان فيه من تعريفه وكساه التعريف بإضافته إياه إلى الضمير {51} فهذا معنى قول أبي علي: (يقدّر فيه التنكير والشيوع كما يقدّر فيه ذلك إذا ثنّى) وكل هذا يقوي قراءة ابن عامر.وقوله تعالى: ﴿يُرِيدُونَ وَجْهَهُ﴾ قال ابن عباس في رواية عطاء عنه: (يطلبون ثواب الله ويعملون ابتغاء مرضاة الله، لا يعدلون بالله شيئًا) {52}.وقال أهل المعاني: (في هذا قولين: أحدهما: أن معناه: يريدون طاعته {53}، كأنه بمعنى الوجه الذي وجههم فيه وهو طاعتهم له). ونحو من هذا قال الزجاج فقال: (أعلم الله أنهم يريدون ما عنده، وشهد لهم بصدق النيات، وأنهم مخلصون في ذلك له، فقال: ﴿يُرِيدُونَ وَجْهَهُ﴾، أي: (يريدون وجه الله عز وجل ويقصدون الطريق الذي أمرهم بقصده) {54}، وكان الزجاج ذهب في معنى الوجه إلى الجهة والطريق -وذكرنا هذا مشروحًا في قوله تعالى: ﴿فَثَمَّ وَجْهُ اللَّهِ﴾ [البقرة: 115]- وعلى هذا ﴿وَجْهَهُ﴾: جهته التي أمر بقصدها. [و] {55} القول الثاني: ﴿يُرِيدُونَ وَجْهَهُ الله﴾ أي: يريدونه إلا أنه يؤتى بلفظ الوجه للتعظيم بتفخيم الذكر، كما يقال: هذا وجه الرأي، وأشار أبو إسحاق إلى هذا المعنى فقال في سورة الكهف: (أي: لا يقصدون بعبادتهم إلا إياه) {56}.وقوله تعالى: ﴿مَا عَلَيْكَ مِنْ حِسَابِهِمْ مِنْ شَيْءٍ﴾ قال ابن عباس في رواية عطاء: (ما عليك من حساب المشركين من شيء ولا على المشركين من حسابك من شيء إنما الله الذي يثيب أولياءه ويعذب أعداءه، وأنت وأصحابك قد غفر الله لهم وصاروا إلى رحمته) {57}، انتهى كلامه. وعلى هذا الكناية في ﴿حِسَابِهِمْ﴾ و ﴿عَلَيْهِمْ﴾ تعود إلى المشركين {58} الذين قالوا للنبي ﷺ أن يطرد عنه الفقراء، ومعناه: الإبعاد بينه وبينهم، ونهي النبي ﷺ عن استمالتهم بتقريبهم. يقول: ليس عليك من حسابهم من شيء إن كفروا وكذبوا فتطرد الفقراء لتدني مجلسهم منك ﴿وَمَا مِنْ حِسَابِكَ عَلَيْهِمْ مِنْ شَيْءٍ﴾ أي: ليس ثوابك عليهم حتى تلين لهم وهو معنى قول ابن عباس: (إنما الله الذي يثيب أولياءه ويعذب أعداءه) فهذا وجه، والمفسرون {59} يردون الكناية إلى ﴿الَّذِينَ يَدْعُونَ رَبَّهُمْ﴾ وهم الفقراء وذلك أشبه بالظاهر؛ لأن الكناية في قوله: ﴿فَتَطْرُدَهُمْ﴾ عائدة على الفقراء لا محالة، فكذلك ما قبله من الكناية أشبه أن تعود عليهم، وعلى هذا ذكروا في قوله تعالى: ﴿وَمَا مِنْ حِسَابِكَ عَلَيْهِمْ مِنْ شَيْءٍ﴾ [قولين] {60}:أحدهما: ما عليك من عملهم ومن حساب عملهم من شيء، وهذا يروى عن الحسن {61} وابن عباس {57}.قال أهل المعاني: (هذه القصة شبيهة بقصة {63} نوح عليه السلام إذ قال له قومه: ﴿قَالُوا أَنُؤْمِنُ لَكَ وَاتَّبَعَكَ الْأَرْذَلُونَ﴾ [الشعراء: 111] فأجابهم نوح: ﴿قَالَ وَمَا عِلْمِي بِمَا كَانُوا يَعْمَلُونَ (112) إِنْ حِسَابُهُمْ إِلَّا عَلَى رَبِّي لَوْ تَشْعُرُونَ﴾ [الشعراء: 112 - 113]، وعنوا بقولهم: ﴿الْأَرْذَلُونَ﴾ الحاكة والمحترفين بالحرف الوضيعة، فقال نوح: ﴿وَمَا عِلْمِى﴾ بعملهم، أي: وجه مكاسبهم، [ما حساب] {64} عملهم إلا على الله، فوض دناءة مكاسبهم إلى الله تعالى أي: أنه أعلم بعملهم وما لي ولذلك، وكذلك في هذه الآية كان هؤلاء الفقراء يعملون بالنهار لقوتهم ويرجعون إلى مسجد رسول الله ﷺ فازدراهم المشركون لفقرهم وحاجتهم إلى الأعمال الخسيسة لقوتهم، وهمّ النبي ﷺ برفع المشركين عليهم في المجلس فقيل له: ﴿وَمَا مِنْ حِسَابِكَ عَلَيْهِمْ مِنْ شَيْءٍ﴾ [أي: لا يلزمك عار بعملهم ﴿فَتَطْرُدَهُمْ﴾.وقوله تعالى: ﴿وَمَا مِنْ حِسَابِكَ عَلَيْهِمْ مِنْ شَيْءٍ﴾] {65} ذكر تأكيدًا للمطابقة وازدواج الكلام، وإن كان مستغنى عنه بالأول)، وإلى هذا المعنى أشار الزجاج {66}.القول الثاني: ما عليك من حساب رزقهم من شيء فتملهم وتطردهم، ﴿وَمَا مِنْ حِسَابِكَ عَلَيْهِمْ مِنْ شَيْءٍ﴾، أي: ليس رزقك عليهم ولا رزقهم عليك وإنما يرزقك وإياهم الله الرازق، فدعهم يدنون منك ولا تطردهم {67}.وقوله تعالى: ﴿فَتَكُونَ مِنَ الظَّالِمِينَ﴾ جواب لقوله: ﴿وَلَا تَطْرُدِ﴾ في أول الآية {68}، ومعناه: فتكون من الضارين لنفسك بالمعصية؛ قاله ابن عباس {69}.وهذا الظُّلمُ معناه: النقصان، أي: ينقص ثوابك بطردهم لو طردتهم، والظلم بمعنى: النقص معروف في اللغة {70} يقال: ظلم حقه، وهو كثير في القرآن -وقد ذكرنا ذلك-. وقال ابن زيد {71}: (﴿فَتَكُونَ مِنَ الظَّالِمِينَ﴾ (لهم بطردهم)، وهذا قول حسن) أي: إنهم لم يستحقوا منك الطرد فإذا طردتهم فقد ظلمتهم {72}."
