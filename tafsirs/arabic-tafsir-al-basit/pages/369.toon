tafsir[19]{c,v,t}:
  26,40,"﴿لَعَلَّنَا نَتَّبِعُ السَّحَرَةَ﴾ على أمرهم ﴿إِنْ كَانُوا هُمُ الْغَالِبِينَ﴾ لموسى ولأخيه. قاله مقاتل {1}. وإنما قالوا: ﴿لَعَلَّنَا نَتَّبِعُ السَّحَرَةَ﴾؛ لأن السحرة لم يكونوا متبوعين، وإنما كانوا سحرة حشروا إليهم من مدائن صعيد مصر، فقالوا: إن غَلبوا موسى اتبعناهم {2}.وما بعد هذا [41 - 43] مفسر إلى قوله:"
  26,42,"26:41"
  26,43,"26:41"
  26,44,"﴿وَقَالُوا بِعِزَّةِ فِرْعَوْنَ﴾ أي: بقوته التي يمتنع بها من لَحاق الضيم {1}.قال مقاتل: يعني: بعظمة فرعون، كقوله لشعيب: ﴿وَمَا أَنْتَ عَلَيْنَا بِعَزِيزٍ﴾ [هود 91] يعني: بعظيم {2}. وهذا قَسَم غير مبرور {3}.والباقي [45 - 49] مفسر إلى قوله:"
  26,46,"26:45"
  26,47,"26:45"
  26,48,"26:45"
  26,49,"26:45"
  26,50,"﴿لَا ضَيْرَ﴾ أي: لا ضرر علينا فيما ينالنا في الدنيا مع أملنا للمغفرة. قاله الزجاج {1}.وقال مقاتل: ﴿لَا ضَيْرَ﴾ هل هو إلا أن يقتلنا {2} ﴿إِنَّا إِلَى رَبِّنَا مُنْقَلِبُونَ﴾ راجعون في الآخرة {3}."
  26,51,"قوله تعالى: ﴿إِنَّا نَطْمَعُ أَنْ يَغْفِرَ لَنَا رَبُّنَا خَطَايَانَا﴾ مفسر في سورة طه {1}.﴿أَنْ كُنَّا﴾ أي: لأن كنا {2} ﴿أَوَّلَ الْمُؤْمِنِينَ﴾ قال الفراء: أول مؤمني أهل {3} زماننا {4}.وقال مقاتل: أول المصدقين بتوحيد الله من أهل مصر {5}.وقال الزجاج: زعم الفراء أنهم كانوا أول مؤمني أهل دهرهم {6}! ولا أحسبه عرف الرواية في التفسير؛ لأنه جاء في التفسير: أن الذين كانوا مع موسى ستمائة ألف؛ وإنما المعنى: أن كنا أولَ من آمن في هذه الحال عند ظهور آية موسى {7}.وقال غيره: ﴿كُنَّا أَوَّلَ الْمُؤْمِنِينَ﴾ بآيات موسى ممن كان يعمل بالسحر {8}."
  26,52,"قوله تعالى: ﴿وَأَوْحَيْنَا إِلَى مُوسَى أَنْ أَسْرِ بِعِبَادِي﴾ مفسر في سورة طه {1}.﴿إِنَّكُمْ مُتَّبَعُونَ﴾ يتبعكم فرعون وقومه ليحولوا بينكم وبين الخروج من أرض مصر {2}."
  26,53,"﴿فَأَرْسَلَ فِرْعَوْنُ فِي الْمَدَائِنِ حَاشِرِينَ﴾ يحشرون الناس لطلب موسى وهارون {1}. أي: أرسَل من جَمع له الجيش {2}."
  26,54,"[قوله: ﴿إِنَّ هَؤُلَاءِ﴾ قال مقاتل: ثم قال فرعون: ﴿إِنَّ هَؤُلَاءِ﴾ يعنى: بني إسرائيل.وقال أبو إسحاق:] {1} معناه: فجمع جمعه فقال: ﴿إِنَّ هَؤُلَاءِ لَشِرْذِمَةٌ قَلِيلُونَ﴾ والشرذمة في كلام العرب: القليل {2}.وقال المبرد: الشرذمة: القطعة من الناس غير الكثير، وجمعها: الشراذم {3}. ويقال للحلفاء إذا قلوا {4}: بنوا فلان شرذمة بني فلان. قال مقاتل في قوله: (شرذمة) عصابة {5}.وقوله: ﴿قَلِيلُونَ﴾ قال الفراء: يقال: عصبة قليلة، وقليلون، وكثيرون، جائز عربي؛ وإنما جاز لأن القلة تلزم جميعهم في المعنى فظهرت أسماؤهم، ومثله: أنتم حي واحد، وحي واحدون؛ قال الكُمَيْت:فَرَدَّ قواصي الأحياء منهم ... فقد رجعوا كحيٍّ واحِدينا {6} ومعنى واحدون: واحد. ونحو هذا قال الزجاج {7}. وكان الشرذمة الذين قللهم فرعون ستمائة ألف، في قول مجاهد، ومقاتل، وابن الهاد، وابن مسعود {8}.قال مجاهد: ولا يُحصى عدد أصحاب فرعون {9}."
  26,55,"وقوله: ﴿وَإِنَّهُمْ لَنَا لَغَائِظُونَ﴾ قال أبو إسحاق: يقال: غاظني فلان، وأغاظني، [والأول أفصح {1}.وروى ثعلب عن ابن الأعرابي: غاظني فلان وأغاظني] {2} وغيظني بمعنى واحد {3}. والغيظ: الغضب، ومنه قوله: ﴿تَكَادُ تَمَيَّزُ مِنَ الْغَيْظِ﴾ [الملك 8] والتغيظ والاغتياظ واقعان منه؛ قال الله تعالى: {سَمِعُوا لَهَا تَغَيُّظًا} [الفرقان 12] وقد مر. والمغايظة بين اثنين.قال مقاتل: ﴿وَإِنَّهُمْ لَنَا لَغَائِظُونَ﴾ بقتلهم أبكارنا ثم هربهم منا {4}.وقال آخرون: أي مما أخذوه من العواري التي استعاروها من أوللي، وخروجهم من أرضنا على مخالفة لنا {5}."
  26,56,"وقوله: ﴿وَإِنَّا لَجَمِيعٌ حَاذِرُونَ﴾ وقرئ: (حذرون) {1} قال الفراء: وكأن: الحاذر الذي يحذرك الآن. وكأن: الحَذِر المخلوق حَذِرًا لا تلقاه إلا حذرًا {2}.وقال الزجاج: الحاذر: المستعد. والحذر: المتيقظ {3}.وقال أبو عبيدة: رجل حَذِر وحَذُر {4} وحاذر.قال ابن أحمر:هل أُنسأَنْ يومًا إلى غيره ... إنِّي حواليٌ وإنِّى حَذِر {5}قال: حوالي: ذو حيلة {6}.وأنشد أيضًا للعباس بن مرداس:وإني حاذرٌ أنْمِى سلاحي ... إلى أوصال ذَيَّال منيع {7}قال أبو علي: يقال: حَذِر يَحذَر حَذَرًا، واسم الفاعل: حَذِر. فأما حاذر فإنه يراد به أنه يفعل الحذر فيما يَستقبل. وكذلك قوله: وإني حاذر، كأنه يريد: متحذر عند اللقاء {8}.وقال شمر: الحاذر: المُؤدِي الشاكُّ في السلاح {9}. وكذا جاء في التفسير؛ روى أبو إسحاق عن الأسود في قوله: ﴿حَاذِرُونَ﴾ قال: مُؤدُون مقوون {10}. أي: ذووا أداة وقوة. ويروى عنه: مؤدون مستعدون. وقال الضحاك: شاكُّون في السلاح {11}.وقال مقاتل: مُؤدُون علينا السلاح {12}.وسأل شافع بن الأزرق، ابنَ عباس {13}، عن قوله: ﴿حَاذِرُونَ﴾ ما هو؟ فقال: التامون {14} السلاح.وأنشد قول النجاشي {15}: حنيفةُ في كتائبَ حاذراتٍ ... يقودهم أبو الشِّبل الهِزبرُ {16}وهذا الذي ذكره أهل التفسير معنى وليس بتفسير؛ وذلك أن من شأن من يحذر الشيء أن يستعد له، ويأخذ له الحذر، وإلا فكم من حذر لا سلاح معه. ومعنى الحَذَر في اللغة: اجتناب الشيء خوفًا منه؟ قال اليث في قوله: ﴿حَاذِرُون﴾ نَخاف شَرَّهم {17}. وذكرنا مثل هذا في قوله: ﴿خُذُوا حِذْرَكُمْ﴾ [النساء71] {18}."
  26,57,"قوله تعالى: ﴿فَأَخْرَجْنَاهُمْ﴾ يعني: فرعون وقومه {1}. ﴿مِنْ جَنَّاتٍ﴾ قال مقاتل: يعني البساتين ﴿وَعُيُونٍ﴾ يعني: أنهارًا جارية {2}."
  26,58,"﴿وَكُنُوزٍ﴾ يعني: الأموال الظاهرة من الذهب والفضة {1}. وإنما سمي: كنزًا؛ لأنه لم يعط حق الله منها. وكل ما لا يعطى حقُّ الله منه فهو كنز وإن كان ظاهرًا {2}.ثم قال: ﴿وَمَقَامٍ كَرِيمٍ﴾ [يعني: المساكن الحسان {3}. قال المفسرون في قوله: ﴿وَمَقَامٍ كَرِيمٍ﴾] {4}: هو المجلس الحسن {5} من مجالس الأمراء والرؤساء التي كانت تَحفُّ بها الأتباع {6}."
  26,59,"وقوله: ﴿كَذَلِكَ﴾ أي: كما وصفنا {1}. وقال مقاتل: هكذا فعلنا بهم في الخروج من مصر، ومما كانوا منه من الخير {2}.وقوله: ﴿وَأَوْرَثْنَاهَا بَنِي إِسْرَائِيلَ﴾ قال الحسن: رجع بنوا إسرائيل إلى مصر بعد إهلاك فرعون {3}. وقال مقاتل: إن الله تعالى ردَّ بني إسرائيل بعد ما أغرق فرعون وقومه إلى مصر {2}."
  26,60,"﴿فَأَتْبَعُوهُمْ مُشْرِقِينَ (60)﴾ قال عبد الله بن مسلم {1}: لحِقوهم مصبحين حين شرقت الشمس، أي: طلعت، يقال: أشرقنا، أي: دخلنا في الشروق {2}. وقد مر {3}. والكلام في معنى: أتبع ذكرناه في قوله: ﴿فَأَتْبَعَهُ الشَّيْطَانُ﴾ [الأعراف: 175] {4}."
