tafsir[5]{c,v,t}:
  9,73,"قوله تعالى: ﴿يَا أَيُّهَا النَّبِيُّ جَاهِدِ الْكُفَّارَ وَالْمُنَافِقِينَ﴾، قال ابن عباس في رواية علي بن أبي طلحة: (أمره الله بجهاد الكفار بالسيف، والمنافقين باللسان) {1}، وزاد عطاء عنه بيانًا فقال: (يريد جاهد الكفار بالسيوف والرماح والنبل، والمنافقين باللسان وشدة الانتهار وترك الرفق) {2}، ونحو هذا قال ابن جريج والضحاك: (بتغليظ الكلام) {3}.وقال عبد الله {4} في قوله: ﴿جَاهِدِ الْكُفَّارَ وَالْمُنَافِقِينَ﴾ قال: بيده، فإن لم يستطع فبلسانه، فإن لم يستطع فبقلبه، فمن لم يستطع فليكفهر في وجهه {5} إذا لقيه {6}.قال أبو إسحاق: (لما كشفت حال المنافقين أمر بجهادهم، والمعنى: جاهدهم بالحجة، فالحجة على المنافق جهاد لهم) {7}، وعلى هذا الاحتجاج على المنافقين والملحدين والرادين للكتاب {8} والسنة، والمخالفين لهما من الجهاد.وقوله تعالى: ﴿وَاغْلُظْ عَلَيْهِمْ﴾ يقال: غلظ الشيء يغلظ غلظا في الخلقة، ثم يقال: رجل غليظ: إذا كان فظا، وغلظ له القول وأغلظ: إذا لم يرفق به، وهذا نحو قوله: ﴿وَلْيَجِدُوا فِيكُمْ غِلْظَةً﴾ [التوبة: 123]، قال أهل المعاني: (وهي قوة القلب على إحلال الألم بصاحبه، كما {9} أن الرقة ضعف القلب عن ذلك) {10}.قال ابن عباس: (يريد شدة الانتهار، والنظر بالبغضة، والمقت) {11}.وقال ابن مسعود: (هو أن تكفهر في وجوههم) {12}، قال عطاء: (وهذه الآية نسخت كل شيء من العفو والصفح) {13}."
  9,74,"قوله تعالى: ﴿يَحْلِفُونَ بِاللَّهِ مَا قَالُوا﴾ الآية، نزلت حين بلغ النبي -ﷺ- أن المنافقين يسيؤون فيه القول ويطعنون فيه، وفي الدين والقرآن، فأنكر ذلك عليهم فحلفوا ما قالوا فكذبهم الله تعالى فقال: ﴿وَلَقَدْ قَالُوا كَلِمَةَ الْكُفْرِ﴾ {1} يعني سبهم الرسول، وطعنهم في الدين، وقال قتادة: (قالوا {2}: ﴿لَئِنْ رَجَعْنَا إِلَى الْمَدِينَةِ لَيُخْرِجَنَّ الْأَعَزُّ مِنْهَا الْأَذَلَّ﴾ [المنافقون: 8] فسعي بها إلى النبي -ﷺ-، فدعاهم فحلفوا ما قالوا) {3}، وكان هذا في غزوة تبوك {4}، وقال السدي: (قالوا: إذا قدمنا المدينة عقدنا على رأس عبد الله بن أبي تاجًا يباهي به رسول الله -ﷺ-) {5}.وقوله تعالى: ﴿وَهَمُّوا بِمَا لَمْ يَنَالُوا﴾، قال ابن عباس ومجاهد: (هم المنافقون بقتل المؤمن الذي أنكر عليهم طعنهم في الرسول {6}، قال {7}: وهو عامر بن قيس {8} الذي سعى بهم، وقال السدي: (هو أنهم لم ينالوا ما هموا به من عقد التاج على رأس عبد الله بن أبي) {9}، وقال الكلبي: (هموا أن يفتكوا بالنبي ﷺ ليلاً ويغتالوه فأعلمه الله ذلك فأمر من نحاهم عن طريقه وسماهم رجلاً رجلاً، وكانوا خمسة عشر رجلاً) {10}، وهذا اختيار أبي إسحاق {11}.وقوله تعالى: ﴿وَمَا نَقَمُوا إِلَّا أَنْ أَغْنَاهُمُ اللَّهُ وَرَسُولُهُ مِنْ فَضْلِهِ﴾، قال ابن عباس: (يريد مما كانوا غنموا حتى صارت لهم العقد {12} والأموال من العين {13} والحيوان) {14}.وقال الكلبي: (كانوا قبل قدوم النبي -ﷺ-، في ضنك من عيشهم لا يركبون الخيل، ولا يحوزون الغنيمة، فلما قدم عليهم رسول الله -ﷺ-، استغنوا بالغنائم) {15}، وذكرنا معنى ﴿نَقَمُوا﴾ عند قوله: ﴿هَلْ تَنْقِمُونَ مِنَّا﴾ [المائدة: 59] {16}.قال أهل المعاني في هذه الآية: (إنهم عملوا بضد الواجب فجعلوا موضع شكر الغني أن نقموه فهذا معنى قوله: ﴿وَمَا نَقَمُوا إِلَّا أَنْ أَغْنَاهُمُ اللَّهُ﴾ {17} ويجوز أن يكون المعنى: إنهم بطروا النعمة {18} بالغني فنقموا بطرُا وأشرًا {19}، وقال ابن قتيبة: (أي: ليس ينقمون شيئًا ولا يتعرفون من الله إلا الصنع {20}، [وهذا كقول الشاعر:ما نقموا من بني أمية إلا ... أنهم يحلمون إن غضبوا] {21}وهذا ليس مما ينقم، وإنما أراد: إن الناس لا ينقمون عليهم {22} شيئا كقول النابغة: ولا عيب فيهم غير إن سيوفهم ... بهن فلول من قراع الكتائب {23}أي ليس فيهم عيب) {24}.وقوله تعالى: ﴿فَإِنْ يَتُوبُوا يَكُ خَيْرًا لَهُمْ﴾، قال الكلبي: (لما نزلت هذه الآية قام {25} الجلاس بن سويد {26}، وكان ممن طعن علي النبي -ﷺ-، فقال: أسمع الله قد عرض علي التوبة، وأنا أستغفر الله وأتوب إليه بما قلته فقبل رسول الله -ﷺ- توبته) {27}، ونحو هذا روى عطاء عن ابن عباس.وقوله تعالى: ﴿وَإِنْ يَتَوَلَّوْا﴾ أي يعرضوا عن الإيمان، قال ابن عباس: ([يريد كما تولى ابن أبي) {28}. ﴿يُعَذِّبْهُمُ اللَّهُ عَذَابًا أَلِيمًا فِي الدُّنْيَا﴾ بالقتل، قال الزجاج] {29}: (لأنهم {30} أمر بقتلهم) {31} وفي ﴿الْآخِرَةِ﴾: بالنار، ﴿وَمَا لَهُمْ فِي الْأَرْضِ مِنْ وَلِيٍّ وَلَا نَصِيرٍ﴾، قال عطاء: (يريد لا يتولاهم أحد من الأنصار) {32}."
  9,75,"قوله تعالى: ﴿وَمِنْهُمْ مَنْ عَاهَدَ اللَّهَ﴾ الآية، المعاهدة: معاقدة بعزيمة تتحقق بذكر الله، نحو: علي عهد {1} الله لأفعلن كذا، قال ابن عباس وسعيد بن جبير وقتادة: (أتى ثعلبة بن حاطب {2} مجلسًا من الأنصار فأشهدهم وقال: (لئن آتاني الله من فضله آتيت منه كل ذي حق حقه، وتصدقت منه، ووصلت منه القرابة، فابتلاه الله، فلم يف بما قال) {3}.وقال أبو أمامة الباهلي: (عاود ثعلبة رسول الله -ﷺ- مرارًا كل ذلك يقول: ادع الله أن يرزقني مالاً ورسول الله -ﷺ- يقول له: ""قليل تؤدي شكره خير من كثير لا تطيقه"" حتى قال: والذي بعثك بالحق نبيًا {4} لئن رزقني الله مالاً لأعطين كل ذي حق حقه، فقال رسول الله -ﷺ-: ""اللهم ارزق ثعلبة مالًا"" فاتخذ غنمًا وكثر ماله حتى اشتغل به عن الصلاة مع رسول الله -ﷺ-، وخرج عن المدينة، ومنع الزكاة، وبلغ من أمره ما قص الله في كتابه) {5}.. . . . . . . . . . . . . . . . . . . . . . . .وقوله تعالى: ﴿لَنَصَّدَّقَنَّ﴾، قال الزجاج: (الأصل: لنتصدقن ولكن التاء أدغمت في الصاد لقربها منها) {6}.قال الليث: (المتصدق: المعطي والمتصدق: السائل) {7}، وأنكر ذلك {4} أهل اللغة، ولم يجيزوا أن يقال للسائل: متصدق، قال ذلك الفراء {9} والأصمعي {10} وغيرهما، فالمتصدق المعطي، قال الله تعالى: ﴿وَتَصَدَّقْ عَلَيْنَا إِنَّ اللَّهَ يَجْزِي الْمُتَصَدِّقِينَ﴾ [يوسف: 88].وقوله تعالى: ﴿وَلَنَكُونَنَّ مِنَ الصَّالِحِينَ﴾ أي لنعملن ما يعمل أهل الصلاح في أموالهم من صلة الرحم، والنفقة في الخير، وقال عطاء عن ابن عباس: (يريد الحج) {11}، لأن ثعلبة كان مسكينًا فعاهد الله لئن وسع الله عليه {12} ليصدقن وليحجن.وقال الضحاك: (نزلت هذه الآيات في رجال من المنافقين سماهم، بسط الله لهم الدنيا فبخلوا بها بعدما عاهدوا أن يتصدقوا) {13}."
  9,77,"قوله تعالى: ﴿فَأَعْقَبَهُمْ نِفَاقًا فِي قُلُوبِهِمْ﴾ الآية، قال الليث: (يقال أعقبت {1} فلانًا ندامة: إذا صيرت عاقبة أمره ذلك، وأنشد للهذلي {2}:أودى {3} بني وأعقبوني حسرة ..... بعد الرقاد وعبرة لا {4} تقلع {5}قال الأزهري: (ويقال: أكل فلان أكلة أعقبته سقمًا، وأعقبه الله خيرًا بإحسانه {6} بمعنى عوضه وأبدله، وهو معنى قول النابغة {7}:ومن أطاع فأبدله {8} بطاعته ...... كما أطاعك واد لله على الرشد {9} فإن {10} شئت قلت في قوله: ﴿فَأَعْقَبَهُمْ نِفَاقًا﴾ صير عاقبة أمرهم ذلك، وإن شئت قلت {11}: عوضهم وأبدلهم والمعنى واحد؛ لأنه التصيير إلى حالة {12} مخصوصة في العاقبة بخير أو بشر، فالخير ما ذكره النابغة، والشر ما ذكره الله في هذه الآية، قال عطاء عن ابن عباس: (فأعقبه الله نفاقًا حتى مات) {13}.وقال مجاهد: (أعقبهم الله ذلك بحرمان التوبة كما حرم إبليس) {14}.قال الزجاج: ([والمعنى: أضلهم بفعلهم، قال: ويجوز أن يكون لما قال: ﴿بَخِلُوا بِهِ﴾ قال: ﴿فَأَعْقَبَهُمْ نِفَاقًا﴾، {15} أي فأعقبهم بخلهم نفاقًا) {16}.وقوله تعالى: ﴿إِلَى يَوْمِ يَلْقَوْنَهُ﴾ هذا دليل على أنه مات منافقا، فقد روي أنه أتى النبي -ﷺ- بصدقته فقال: ""إن الله منعني أن أقبل منك صدقتك"" ثم لم يقبلها أبو بكر ولا عمر ولا عثمان، ومات في خلافته {17}، فمن قال: أعقبهم الله {18} رد الضمير في ﴿يَلْقَوْنَهُ﴾ إلى اسم الله عز وجل، ومن قال: أعقبهم بخلهم، رد الضمير إليه، بمعنى: يلقون جزاء بخلهم {19}.وقوله تعالى: ﴿بِمَا أَخْلَفُوا اللَّهَ مَا وَعَدُوهُ وَبِمَا كَانُوا يَكْذِبُونَ﴾ هذا بيان عما يوجبه الكذب مع إخلاف الوعد من النفاق، فمن أخلف في المواثيق مع الله فقد تعرض للنفاق، وكان جزاؤه من الله إفساد قلبه بما يكسبه {20} النفاق، فأما ما روي عن النبي -ﷺ-: ""ثلاث من كن فيه فهو منافق وإن صلى وصام وزعم أنه مؤمن، إذا حدث كذب، وإذا وعد أخلف، وإذا ائتمن خان"" {21}، فقد أجرى هذا الخبر على ظاهره الحسن {22} وعبد الله بن عمرو {23} ومحمد بن كعب {24}، وقال عطاء بن أبي {25} رباح: (حدثني جابر بن عبد الله أن رسول الله -ﷺ- إنما قال هذا الحديث في المنافقين خاصة، الذين حدثوا النبي -ﷺ- فكذبوه، وائتمنهم على سره {26} فخانوه، ووعدوا أن يخرجوا معه في الغزو فأخلفوه) {27} فعنده هذا الحديث خاص في المنافقين {28}."
  9,79,"قوله تعالى: ﴿الَّذِينَ يَلْمِزُونَ الْمُطَّوِّعِينَ﴾ الآية، مضى الكلام في اللمز عند قوله: ﴿وَمِنْهُمْ مَنْ يَلْمِزُكَ فِي الصَّدَقَاتِ﴾ [التوبة: 58].والمطوعون: المتطوعون {1}، والتطوع التنفل، وهو الطاعة لله عز وجل فيما ليس بواجب، ومضى الكلام في إدغام التاء في الطاء عند قوله: ﴿وَمَنْ تَطَوَّعَ خَيْرًا﴾ [البقرة: 158] {2}، وقوله: ﴿حَتَّى يَطْهُرْنَ﴾ [البقرة: 222] {3}، قال المفسرون: حث النبي -ﷺ- على الصدقة فجاء عمر وعثمان وعبد الرحمن بن عوف، بصدقة عظيمة، وجاء رجل يقال له: أبو عقيل الأنصاري {4} بصاع من تمر وكان قد أجر نفسه ليلة إلى الصبح يسقي نخل رجل، فأخذ أجرته فجعل نصفها صدقة لوجه الله تعالى ونصفها لعياله، فلمزهم المنافقون وقالوا: ما أخرج هؤلاء صدقاتهم إلا رياء، وأما أبو عقيل فإنما جاء بصاعه ليذكر نفسه، وإن كان الله ورسوله لغنيين عن صاعه، فأنزل الله هذه الآية {5}.وقوله تعالى: ﴿وَالَّذِينَ لَا يَجِدُونَ إِلَّا جُهْدَهُمْ﴾ يعني أبا عقيل، وقال عطاء عن ابن عباس: هو سهل بن نافع {6}.قال الليث: الجهد شيء قليل يعيش به المقل {7}.وقال الزجاج: (إلا جهدهم) و (جهدهم) بالفتح والضم {8}.قال الفراء: الضم لغة أهل الحجاز والفتح لغيرهم {9}، وحكى {10} ابن السكيت عنه الفرق بينهما فقال: الجُهد: الطاقة، تقول: هذا جهدي أي طاقتي، والجهد: المشقة، تقول: اجهد جهدك {11}. وقال الشعبي: الجهد في العمل، والجهل في القوت {12}.وقوله تعالى: ﴿فَيَسْخَرُونَ مِنْهُمْ﴾ الكناية تعود إلى الذين لا يجدون إلا جهدهم، وقوله تعالى: ﴿سَخِرَ اللَّهُ مِنْهُمْ﴾ خبر الابتداء الذي هو قوله: ﴿الَّذِينَ يَلْمِزُونَ﴾ ومعناه: جازاهم جزاء سخريتهم، ومضى الكلام في هذا {13}، قال ابن عباس: (يريد حيث صاروا إلى النار) {14}.وقال صاحب ""النظم"": قوله: ﴿الَّذِينَ يَلْمِزُونَ﴾ صفة للمكني المتصل بقوله في الآية التي قبل هذه: ﴿سِرَّهُمْ وَنَجْوَاهُمْ﴾ [التوبة: 78] ولا يحتمل أن يكون قوله: (الَّذِينَ {15} يَلْمِزُونَ) مبتدأ؛ لأنه لم يجيء له جواب، وقوله تعالى: ﴿سَخِرَ اللَّهُ مِنْهُمْ﴾ لا يحتمل أن يكون جوابًا لأنه فعل ماض {16}، وهذه السخرية لا تكون إلا في الآخرة، فكان هذا القول دعاء، وقد قال بعضهم {17}: ﴿الَّذِينَ﴾ مبتدأ منقطع مما قبله وقوله: ﴿سَخِرَ اللَّهُ مِنْهُمْ﴾ خبره، دعاء كان أو خبرًا، في الدنيا كان أو في الآخرة."
