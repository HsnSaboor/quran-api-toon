tafsir[12]{c,v,t}:
  20,65,"قوله تعالى: ﴿قَالُوا يَا مُوسَى إِمَّا أَنْ تُلْقِيَ وَإِمَّا أَنْ نَكُونَ أَوَّلَ مَنْ أَلْقَى﴾ قال الفراء: (المعنى: اختر أحد هذين الأمرين) {1}. والمراد بالإلقاء هاهنا: إلقاء العصا على الأرض، وكانت السحرة معهم عصي، وكان موسى قد ألقى عصاه يوم دخل على فرعون، كما قال الله تعالى: ﴿فَأَلْقَى عَصَاهُ فَإِذَا هِيَ ثُعْبَانٌ مُبِينٌ﴾ {2}، ولما أراد السحرة معارضته قالوا له هذا القول."
  20,66,"فقال موسى: ﴿بَلْ أَلْقُوا﴾ أمرهم بالإلقاء أولًا، لتكون معجزته أظهر إذا ألقوا هم بم معهم، ثم يلقي هو عصاه فتبتلع كل ذلك على ما ذكر {1}.وقوله تعالى: ﴿فَإِذَا حِبَالُهُمْ وَعِصِيُّهُمْ﴾ في الكلام محذوف تقديره: فألقوا فإذا حبالهم.[قال أبو إسحاق: (وترك هاهنا؛ لأنه قد جاء في موضع آخر: ﴿فَأَلْقَوْا حِبَالَهُمْ وَعِصِيَّهُمْ﴾ [الشعراء: 44] {2}] {3}.قال ابن عباس في رواية عطاء: (كان عدد السحرة سبعين ألف رجل، ومع كل رجل عصا وحبل غليظ مثل حبال السفن) {4}.وقال عكرمة، وابن جريج: (كانوا تسع مائة) {5}.وقال محمد بن إسحاق: (كانوا خمسة عشر ألفًا) {6}.وقوله تعالى: ﴿يُخَيَّلُ إِلَيْهِ مِنْ سِحْرِهِمْ أَنَّهَا تَسْعَى﴾ يقال خُيل على الرجل تخييلا: إذا أدخل عليه التهمة والشبهة، وأصل هذا الحرف: من الشَبَه والاشتباه الذي ينافي الحق والحقيقة، ومنه الخَيَال الذي يشبه الشيء وليس منه كخَيال الإنسان في المرآة، وخَياله في النوم، وأَخَال الشيء إذا اشتبه وأشكل فهو مخيل {7}، ومنه قول الشاعر {8}:والصَّدْقُ أَبْلَجُ لا يُخَيلُ سَبِيلُهُ ... والصَّدقُ يَعْرِفُهُ ذَوُو الأَلبَابِومعنى هذه الآية كمعنى قوله: ﴿سَحَرُوا أَعْيُنَ النَّاسِ﴾ [الأعراف: 116] وذكر الكلام فيه. وموضع (أن) من قوله: ﴿أَنَّها تَسْعَى﴾ رفع على معنى يخيل إليه سعيها {9}.قال الكلبي: (خُيل إلى موسى أن الأرض حيات كلها، وأنها تسعي على بطنها) {10}. وكثير من الكلام اللائق بهذه الآيات قد مضى في سورة الأعراف {11}."
  20,67,"قوله تعالى: ﴿فَأَوْجَسَ﴾ قال الفراء: (أحس {1} ووجد) {2}.وقال الزجاج: (أضمر) {3}. وقال في موضع آخر: (وقع في نفسه الخوف) {4}. وقد ذكرناه مستقصى في سورة هود {5}.وقوله تعالى: ﴿خِيفَةً مُوسَى﴾ أي: خوفًا، وأصلها: خوفه فانقلبت الواو ياء لانكسار الخاء {6}. وإنما خاف موسى؛ لأن سحرهم كان من جنس ما أراهم في العصا، فخاف أن يلتبس على الناس أمره، ولا يؤمنوا به. هذا معنى قول الكلبي، ومقاتل {7}.وقيل: (كان خوف طباع، لكثرة ما يخيل له من الحيات العظام)، وهذا معنى قول محمد بن إسحاق {8}."
  20,68,"فقال الله تعالى: ﴿لَا تَخَفْ إِنَّكَ أَنْتَ الْأَعْلَى﴾ قال ابن عباس: (يريد أنت الغالب) {1}. والمعنى: أنت الأعلى عليهم بالظفر والغلبة."
  20,69,"﴿وَأَلْقِ مَا فِي يَمِينِكَ﴾ يعني العصا ﴿تَلْقَفْ مَا صَنَعُوا﴾ قال الزجاج: (القراءة بالجزم {1}، جواب الأمر، ويجوز الرفع على معنى الحال، كأنه قال: ألقها تلقفه) {2}، هذا كلامه.وشرحه أبو علي فقال: (وجه قراءة من قرأ: ﴿تَلْقَفُ﴾ بالرفع، وهي قراءة ابن عامر: أنه في موضع الحال، والحال يجوز أن يكون من الفاعل المُلْقِي، ويجوز أن يكون من المفعول المُلْقَى، فإن جعلته من الفاعل المُلْقِي جعلته المُتلَقَّفَ، وإن كان التَّلَقُفُ في الحقيقة للعصا، ووجه جعل المُتَلَقَّف أن التَّلَقُفُ في الحقيقة للعصا، ووجه جعل المُتَلَقَّف أن التَّلَقُف بإلقائه كان فجاز أن ينسب إليه، والفعل كثيرًا يضاف إلى المسبب، ويجوز أن يكون الحال من المفعول، وجعلت تَلْقَفْ حالًا، وإن لم تتلقف بعد، كما جاء في التنزيل: ﴿هَدْيًا بَالِغَ الْكَعْبَةِ﴾ [المائدة: 95] وكما أجاز النحويون: مررتُ برجلٍ معه صقر صائدًا به غدًا، وهذا النحو من الحال كثير في التنزيل وغيره) {3}.وقال: (﴿تَلْقَفْ﴾ على التأنيث، حملًا للكلام على المعنى؛ لأنه المراد بما في يمينه العصا. ومن قرأ: تلقفْ بالجزم، فعلى أن يكون جوابًا، كأنه: إن تُلْقِهِ تَلَقَّفْ، ويجوز أن يكون تَلْقَفْ خطابًا لموسى، كما ذكر في قراءة من رفع يجوز أن يكون حالًا للفاعل) {3}. وذكرنا معنى التلقف في سورة الأعراف مستقصى {5}.وقوله تعالى: ﴿إِنَّمَا صَنَعُوا كَيْدُ سَاحِرٍ﴾ أي: الذي صنعوه كيد ساحر. وقرئ: كيد سحر {6}. وساحر أقوى؛ لأنّ الكيد للساحر في الحقيقة وليس للسحر، ومن قرأ: كيد سحر، أضاف الكيد إلى السحر على التوسع، وأراد كيد ذي سحر، فيكون المعنى مثل كيد ساحر، ويجوز أن يكون معنى كيد سحر: كيد من سحر كما قالوا: قميص حرير، وجبة وَشْي، ذكر ذلك ابن الأنباري {7}. والمعنى: الذي صنعوه تخيل سحر لا حقيقة له.[وقوله: ﴿وَلَا يُفْلِحُ السَّاحِرُ حَيْثُ أَتَى﴾ قال ابن عباس: (ولا يسعد الساحر حيث ما كان) {8}.وروى جندب بن عبد الله البجلي {9}: أن رسول الله -ﷺ- قال: ""إذا أخذتم الساحر فاقتلوه، ثم قرأ: ﴿وَلَا يُفْلِحُ السَّاحِرُ حَيْثُ أَتَى﴾ قال: لا يأمن حيث وجد"" {10}.قال أبو إسحاق: (معناه حيث كان الساحر يجب أن يقتل. قال: وكذلك مذهب أهل الفقه في السحرة) {2}. ونحوه هذا المعنى ذكر الفراء] {12} {13}."
  20,70,"وقوله تعالى: ﴿فَأُلْقِيَ السَّحَرَةُ سُجَّدًا﴾ ففعل ما أمر به موسى، ﴿فَأُلْقِيَ السَّحَرَةُ سُجَّدًا﴾ وترك ذكره؛ لأنه ذكر في سورة الأعراف {1}، والشعراء {2} أنه ألقى عصاه، فتلقفت ما صنعوا، وما يقع من الكلام في تفسير هذه الآية قد سبق في سورة الأعراف {3}."
  20,71,"قوله تعالى: ﴿قَالَ آمَنْتُمْ لَهُ قَبْلَ أَنْ آذَنَ لَكُمْ﴾ الكلام في هذا، ووجه اختلاف القراء في ﴿آمَنْتُمْ﴾ {1}. قد تقدم في سورة الأعراف {2}. بوصل الباء إذا كان باللهِ تعالى، وإذا كان بغيره وصل باللام، كذا جاء في التنزيل {3}، مثل قوله: ﴿فَمَا آمَنَ لِمُوسَى﴾ [يونس: 83]، ﴿وَقَالُوا لَنْ نُؤْمِنَ لَكَ﴾ [الإسراء: 90]، ﴿وَمَا أَنْتَ بِمُؤْمِنٍ لَنَا﴾ [يوسف: 17]، ﴿فَآمَنَ لَهُ لُوطٌ﴾ [العنكبوت: 26]؛ لأنه يراد به مجرد التصديق، وقد قال في سورة الأعراف: ﴿قَالَ فِرْعَوْنُ آمَنْتُمْ بِهِ﴾ [الأعراف: 123]، فهما بمعنى واحد.قوله تعالى: ﴿إِنَّهُ لَكَبِيرُكُمُ الَّذِي عَلَّمَكُمُ السِّحْرَ﴾ قال ابن عباس: (يريد معلمكم) {4}. وقال: (ولذلك يقول أهل مكة: جئت {5} من عند كبيري، [وحتى أستأذن كبيري) {6}.وقال الكسائي: (الصبي بالحجاز إذا جاء من عند معلمه قال: جئت من عند كبيري) {7}] {8}.وقال محمد بن إسحاق: (إنه لعظيم السحار) {9}.والكبير في اللغة: الرئيس {10}، ومنه قوله تعالى: ﴿قَالَ كَبِيرُهُمْ﴾ [يوسف: 80]، يعني رئيسهم الذي هو أعلمهم، ولم يرد الكبير في السن، ولهذا يقال للمعلم: الكبير.قال أهل المعاني: جعل نسبتهم إلى اتباع رئيسهم بالسجود علة لصرف الناس عن اتباع موسى.وقوله تعالى: ﴿وَلَأُصَلِّبَنَّكُمْ فِي جُذُوعِ النَّخْلِ﴾ قال المبرد: (المعنى على جذوع النخل، وإنما وقعت في ومعانيها الوعاء، كقولك: زيد في الدار، والمتاع في الوعاء؛ لأنّ الجذع جعل كأنه قد حل فيه، فصار الجذع له مكانًا كالبيت) {11}. كما قال الأسدي {12}:تَداركت شَمْاسًا ويَحْيى وخالدِا ... وقَد نصبت فَوقَ الجُذُوع قُبُورهَاأي: جعلت الجذوع لهم مكان القبور، ونحو هذا قال أبو عبيدة، والفراء، والزجاج {13} وأنشدوا {14}: وَهُم صَلَبُوا العَبدِيَّ في جِذْعِ نَخْلَةِ ... فَلا عَطَستْ شَيْبَانُ إِلاَ بِأجْدَعاولما كانت الجذوع تضمهم كما يضم الوعا ما فيه قيل: ﴿فِي جُذُوعِ النَّخْلِ﴾، وهذا كقوله تعالى: ﴿أَمْ لَهُمْ سُلَّمٌ يَسْتَمِعُونَ فِيهِ﴾ [الطور: 38]، أي: عليه. ﴿وَلَتَعْلَمُنَّ﴾ أيها السحرة ﴿أَيُّنَا أَشَدُّ عَذَابًا﴾ لكم ﴿وَأَبْقَى﴾ وأدوم أنا على إيمانكم، أو رب موسى على ترككم الإيمان به."
  20,72,"قوله تعالى: ﴿قَالُوا لَنْ نُؤْثِرَكَ﴾ أي: لن نفضلك ولن نختارك ﴿عَلَى مَا جَاءَنَا مِنَ الْبَيِّنَاتِ﴾ قال ابن عباس: (يريد من اليقين والعلم) {1}. وقال مقاتل: (يعني اليد والعصا) {2}.وقال عكرمة: (هو أنهم حيث خروا سجدًا أراهم الله في سجودهم منازلهم في الجنة التي إليها يصيرون) {3}. ونحو هذا قال القاسم بن أبي بزة {4}: (ما رفعوا رؤوسهم حتى رأوا الجنة والنار، ورأوا ثواب أهلها عند ذلك قالوا: ﴿لَنْ نُؤْثِرَكَ عَلَى مَا جَاءَنَا مِنَ الْبَيِّنَاتِ﴾) {5}.وقوله تعالى: ﴿وَالَّذِي فَطَرَنَا﴾ ذكر الفراء والزجاج فيه وجهين أحدهما: (لن نؤثرك على الله والذي خلقنا. والثاني: أنه قسم) {6}.﴿فَاقْضِ مَا أَنْتَ قَاضٍ﴾ قال ابن عباس وجميع المفسرين: (فاصنع ما أنت صانع) {7}. ﴿إِنَّمَا تَقْضِي هَذِهِ الْحَيَاةَ الدُّنْيَا﴾ قال ابن عباس: (يريد إنما سلطانك وملكك في هذه الدنيا، فأما في الآخرة فليس لك فيها حظ ولا سلطان) {8}."
  20,73,"قوله تعالى: ﴿إِنَّا آمَنَّا بِرَبِّنَا لِيَغْفِرَ لَنَا خَطَايَانَا﴾ قال ابن عباس: (الشرك الذي كنا فيه) {1}. ﴿وَمَا أَكْرَهْتَنَا عَلَيْهِ مِنَ السِّحْرِ﴾ روي: (أن فرعون كان يكره الناس على تعلم السحر) {2}.وروي: (أنه أكرههم على معارضة موسى بالسحر) {3}. والقولان مرويان في التفسير.﴿وَاللَّهُ خَيْرٌ وَأَبْقَى﴾ قال ابن عباس: (يريد ثواب الله خير وأبقى) {4}. فعلى هذا المضاف محذوف.وقال أبو إسحاق: (أي الله خير لنا منك وأبقى عذابًا) {5}. وهذا جواب قوله: ﴿وَلَتَعْلَمُنَّ أَيُّنَا أَشَدُّ عَذَابًا وَأَبْقَى﴾ [طه: 71] وهذا معنى قول محمد بن إسحاق: (والله خير منك [ثوابًا وأبقى عقابًا) {6}.وقال محمد بن كعب: (والله خير منك إن أطيع، وأبقى عذابًا منك] {7} إن عصي) {8}."
  20,74,"قوله تعالى: ﴿إِنَّهُ مَنْ يَأْتِ رَبَّهُ مُجْرِمًا﴾ هذا ابتداء كلام من الله تعالى وانتهى الإخبار عن السحرة {1}.وقيل: (هذا أيضًا إخبار عنهم أنهم قالوه) {2}.والكناية في قوله: ﴿إِنَّهُ﴾ الأمر والشأن، أي: بأن الأمر والشأن هذا، وهو أن المجرم يدخل النار، والمؤمن يدخل الجنة، ويجوز أن يكون هاء الإضمار على شريطة التفسير، وبينا ذلك في سورة يوسف [90].ومعنى ﴿مُجْرِمًا﴾ قال ابن عباس في رواية الضحاك: (المجرم الكافر) {3}.وقال في رواية عطاء: (يريد أجرم، وفعل مثل ما فعل فرعون) {4}. ﴿فَإِنَّ لَهُ جَهَنَّمَ لَا يَمُوتُ فِيهَا وَلَا يَحْيَى﴾ قال: (يريد لا يموت فيستريح، ولا يحيي فيفتر عنه العذاب) {5}.قال الكلبي: (ولا يحيي فيها حياة تنفعه) {6}].وروى أبو نضرة {7} عن أبي سعيد الخدري قال: قال رسول الله -ﷺ-: ""إن أهل النار الذين لا يريد الله إخراجهم تُميتهم النار إماتة حتى يصيروا فحمًا، ثم يخرجون ضبائر {8} فيلقون على أنهار الجنة، فيرش عليهم من أنهار الجنة، حتى ينبتوا كما تنبت الحبة في حميل السيل) {9} {10}.قال المبرد: (تأويل قوله: ﴿لَا يَمُوتُ فِيهَا وَلَا يَحْيَى﴾ لا يموت ميتة مريحة، ولا يحيى حياة ممتعة، وهو يألم كما يألم الحي ليفهم ذلك، ويبلغ بهم حالة الموتى في المكروه، إلا أنه لا يبلغ الحالة التي يبطل فيها عن الفهم، والعرب تقول: فلان لا حي ولا ميت، إذا كان غير منتفع بحياته، وكذلك يقولون لمن يكلم ولم يبلغ حاجته: تكلمت ولم تتكلم، أي: لم تبلغ) {11}. كما قال ابن مرداس {12} {13}:وقَدْ كُنْتُ في الحَرْبِ ذا تُدْرَاءٍ ... فَلَمْ أُعْطَ شَيْئًا ولَمْ أُمْنَعِلأنه عندما أعطيه يقصر عن حقه، بأنّه قد وصل إليه القليل لم يمنع. وأنشد ابن الأنباري في مثل هذا المعنى لعبيد الله بن عبد الله بن عتبة بن مسعود {14}:أَلاَ مَا لِنَفْسٍ لا تَمُوُت فَيَنْقَضِي ... شَقاهَا ولا تَحْيَا حَياةً لَهَا طَعْمُ"
  20,75,"قوله تعالى: ﴿وَمَنْ يَأْتِهِ مُؤْمِنًا﴾ قال ابن عباس: (مصدقًا) {1}. ﴿قَدْ عَمِلَ الصَّالِحَاتِ﴾ [قال: (يريد قد أدى الفرائض) {2}. فهذا من صفة النكرة التي هي الحال] {3}، ﴿فَأُولَئِكَ لَهُمُ الدَّرَجَاتُ الْعُلَى﴾ قال: (قصرت دونها الصفة) {4}.قال ابن عباس فيما روى عنه سعيد بن جبير: (لله عباد ولدوا في الإسلام ونشؤا في أعمال البر، لم يخالطوا المعاصي وأهلها حتى ماتوا على ذلك، إذا كان يوم القيامة نادى المنادي: أين من أتى ربه مؤمنًا فاضلًا قد عمل الصالحات بصدق النية، فعرف القوم صفتهم، فقالوا: لبيك دعوتنا، قال: فإن الله يقول: ﴿فَأُولَئِكَ لَهُمُ الدَّرَجَاتُ الْعُلَى (75) جَنَّاتُ عَدْنٍ﴾ الآية، وعقد لهم لواء فاتبع القوم لواءهم حتى دخلوا الجنة) {5}.والآية دليل على أن الأمور بخواتيمها وأن الإيمان بالموافاة لقوله: ﴿وَمَنْ يَأْتِهِ مُؤْمِنًا﴾ ودليل على أن الدرجات إنما تستحق بالأعمال الصالحة، وقد يدخل الجنة من لا ينال الدرجات العلى.وهذا معنى قوله-عليه السلام-: ""تدخلون الجنة برحمة الله وتقسمون الدرجات بأعمالكم"" {6}."
  20,76,"قوله تعالى: ﴿وَذَلِكَ جَزَاءُ مَنْ تَزَكَّى﴾ قال عطاء عن ابن عباس: (من قال لا إله إلا الله) {1}. ونحو ذلك قال الكلبي {2}.ومعنى ﴿تَزَكَّى﴾ تطهير من الذنوب بالطاعة بدلًا من التدنس بالمعاصي. وقصد أن يكون زاكيا في الخير."
