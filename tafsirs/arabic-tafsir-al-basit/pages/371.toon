tafsir[26]{c,v,t}:
  26,84,"﴿وَاجْعَلْ لِي لِسَانَ صِدْقٍ فِي الْآخِرِينَ﴾ قال ابن عباس، ومجاهد، وسفيان، والسدي، ومقاتل، والكلبي، والمفسرون يعني: ثناءً حسنًا {1}. ﴿فِي الْآخِرِينَ﴾ يعني: في الذين يأتون بعدي {2}.قال أبو إسحاق: معناه اجعل لي ثناء حسنًا باقيًا إلى آخر الدهر {3}.قال المفسرون: وأعطاه الله ذلك، وكل أهل دين يتولونه ويثنون عليه {4}. وذكرنا أن اللسان قد يُذكر والمراد به القول {5}، ومنه:إني أتتني لسانٌ ...... البيت {6}والعرب إذا مدحت شيئًا أضافته إلى الصدق {7}؛ كقوله تعالى: ﴿قَدَمَ صِدْقٍ﴾ [يونس: 2] وقد مر {8}."
  26,85,"﴿وَاجْعَلْنِي مِنْ وَرَثَةِ جَنَّةِ النَّعِيمِ﴾ قال ابن عباس: اجعل مصيرِي إلى جنة النعيم {1}. وقال الكلبي: من الذين ذكروا في قوله: ﴿أُولَئِكَ هُمُ الْوَارِثُونَ (10) الَّذِينَ يَرِثُونَ الْفِرْدَوْسَ﴾ [المؤمنون: 10، 11] والنعيم: نقيض البؤس {2}."
  26,86,"﴿وَاغْفِرْ لِأَبِي إِنَّهُ كَانَ مِنَ الضَّالِّينَ﴾ قال مقاتل: من المشركين {1}. وهذا الاستغفار منه لأبيه إنما كان قبل أن يتبرأ منه {2}. وقد ذكرنا ذلك عند ﴿وَمَا كَانَ اسْتِغْفَارُ إِبْرَاهِيمَ لِأَبِيهِ﴾ الآية، [التوبة: 114] {3}."
  26,87,"﴿وَلَا تُخْزِنِي﴾ قال مقاتل والكلبي: لا تعذبني {1} ﴿يَوْمَ يُبْعَثُونَ﴾ يوم يبعث الخلق بعد الموت {2}. ثم فسر ذلك اليوم وأبدل منه؛ فقال:"
  26,88,"﴿يَوْمَ لَا يَنْفَعُ مَالٌ وَلَا بَنُونَ﴾ [ومفعول النفع محذوف للعلم به كأنه قيل: لا ينفع مال ولا بنون أحدًا] {1}."
  26,89,"﴿إِلَّا مَنْ أَتَى اللَّهَ بِقَلْبٍ سَلِيمٍ﴾ وفي هذا الاستثناء قولان؛ أحدهما: إنه استثناء من الأول على معنى: أن الكافر لا ينفعه ماله وإن تصدق به، ولا ابنوه يغيثونه، [فيكون قوله ﴿إِلَّا مَنْ﴾ استثناء ممن لا ينفعه بماله، وبنوه؛ وهو الكافر.القول الثاني: إن قوله: ﴿إِلَّا مَنْ﴾ استثناء ليس من الأول على معنى:] {1} لكن من أتى الله بقلب سليم ينفعه ذلك، وهو سلامة قلبه {2}.واختلفوا في معنى القلب السليم؛ فقال ابن عباس: سليم من الشرك والنفاق. وهو قول مجاهد، والكلبي، ومقاتل، وقتادة، والحسن، وأكثر المفسرين؛ قالوا: القلب السليم، الذي سلم من الشرك، والشك، والنفاق {3}. وإذا كان سليمًا من هذه الأشياء كان موقنًا مخلصًا. وقال سعيد ابن المسيب: القلب السليم هو الصحيح وهو قلب المؤمن، وقلب الكافر والمنافق مريض، كما قال الله تعالى: ﴿فِي قُلُوبِهِمْ مَرَضٌ﴾ [البقرة: 10] {4}"
  26,90,"قوله تعالى: ﴿وَأُزْلِفَتِ الْجَنَّةُ لِلْمُتَّقِينَ﴾ قال ابن عباس: قربت الجنة لأوليائي {1}.قال أبو إسحاق: تأويله أنه قرب دخولهم إياها ونظرهم إليها {2}."
  26,91,"﴿وَبُرِّزَتِ الْجَحِيمُ﴾ أي: أظهرت {1}. قال مقاتل: كشف الغطاء عيت الجحيم {2} (للغاوين) للكافرين {3}، وهم الضالون عن الهدى {4}.والغاوي: الضال {5}. ﴿وَقِيلَ لَهُمْ﴾ في ذلك اليوم على وجه التوبيخ واللوم {6}."
  26,92,"﴿أَيْنَ مَا كُنْتُمْ تَعْبُدُونَ (92) مِنْ دُونِ اللَّهِ هَلْ يَنْصُرُونَكُمْ﴾ هل يمنعوفكم من العذاب ﴿أَوْ يَنْتَصِرُونَ﴾ يمتنعون منه {1}.ثم يؤمر بهم فيُلقون في النار، فذلك قوله:"
  26,93,"26:92"
  26,94,"﴿فَكُبْكِبُوا فِيهَا﴾ قال ابن عباس، والسدي، والكلبي: جمعوا {1}.وقال مجاهد: دهوروا {2}. وقال مقاتل: قذفوا {3}.قال أبو إسحاق: معنى: (كبكبوا) طُرح بعضهم على بعض {4}.وحقيقة ذلك في اللغة: تكرير الانكباب كأنه إذا أُلقي يَنْكَبُّ مرة بعد مرة حتى يستقرَّ فيها {5}.وقال أبو عبيدة: نكسوا فيها، وهو من قولهم: كبَّه الله لوجهه {6}.قال ابن قتيبة: (كبكبوا) أُلقوا على رؤوسهم، وأصل الحرف: كُبِّبُوا، فأبدل من الباء الوسطى كافًا استثقالًا لاجتماع ثلاث باءات، [كما قالوا: كمكموا، من الكُمَّة، وهي: القَلَنْسوة، والأصل: كُمِّموا] {7}. كما قالوا: ريح صرصر {8}، ورقرقت العين بمعنى: دمعت، وله نظائر {9}.ومن قال في تفسير: (كبكبوا) جمعوا {10}، أراد: جمعوا بطرح بعضهم على بعض في النار. وهذا الفعل للمعبودين من دون الله، أخبر الله تعالى أنهم يُطرحون في النار مع عابديهم، فقال: ﴿فَكُبْكِبُوا فِيهَا هُمْ وَالْغَاوُونَ﴾ قال ابن عباس: يريد: هم وما يعبدون من دون الله {11}.وقال الكلبي: العابد والمعبود {12}.وقال السدي: جمعوا فيها الآلهة والمشركون {13}. وعلى هذا: ﴿الْغَاوُونَ﴾ هم عبدة الأصنام.وقال قوم: ﴿فَكُبْكِبُوا فِيهَا﴾ يعني الكفار ﴿وَالْغَاوُونَ﴾ كفرة الجن. وهو قول الكلبي {14}.وقال قتادة، ومقاتل: يعني الشياطين {15}. والقول هو الأول؛ لأن الشياطين ذكروا فيما بعد؛ وهو قوله:"
  26,95,"﴿وَجُنُودُ إِبْلِيسَ أَجْمَعُونَ﴾ يعني: ذرية إبليس كلهم {1}."
  26,96,"﴿قَالُوا﴾ يعني: الكفرة والغاوون ﴿وَهُمْ فِيهَا يَخْتَصِمُونَ﴾ مع الشياطين والمعبودين {1}."
  26,97,"﴿تَاللَّهِ إِنْ كُنَّا لَفِي ضَلَالٍ مُبِينٍ (97) إِذْ نُسَوِّيكُمْ بِرَبِّ الْعَالَمِينَ﴾ والله ما كنا إلا في ضلال] {1} حيث سويناكم بالله فأعظمناكم، وعبدناكم، وعدلناكم به {2}."
  26,98,"26:97"
  26,99,"﴿وَمَا أَضَلَّنَا إِلَّا الْمُجْرِمُونَ﴾ قال مقاتل: وما أضلنا عن الهدى إلا الشياطين {1}. وهو قول ابن عباس.وقال الكلبي: إلا أوَّلونا الذين اقتدينا بهم {2}."
  26,100,"﴿فَمَا لَنَا مِنْ شَافِعِينَ﴾ من يشفع لنا من الملائكة والنبيين {1}. قال ابن عباس: يريد النبي -ﷺ- {2} والمؤمنين، حين يشفعون للموحدين."
  26,101,"﴿وَلَا صَدِيقٍ حَمِيمٍ﴾ قال ابن عباس: ولا قريب من المؤمنين. وقال مقاتل: يعني: القريب الشفيق {1}. وقال الكلبي ﴿وَلَا صَدِيقٍ﴾ ذي قرابة يهمه أمرنا {2}. والحميم: القريب الذي توده ويودك {3}.قال ابن عباس: إن المؤمن يشفع يوم القيامة للمؤمنين المذنبين {4}. وروى جابر بن عبد الله -رضي الله عنهما- أن رسول الله -ﷺ- قال: ""إن الرجل ليقول في الجنة: رب {5} ما فعل صديقي فلان، وصديقه في الجحيم، فيقول الله تعالى: أخرجوا له صديقه إلى الجنة، فيقول من بقي: ﴿فَمَا لَنَا مِنْ شَافِعِينَ (100) وَلَا صَدِيقٍ حَمِيمٍ﴾ "" {6}.ومعنى {7} الحميم في اللغة: القريب، من قولهم: أَحَمَّ الأمر، وأَحَمَّ إذا قَرُب، ودنا {8}.وقال المبرد: حَميم الرجل من يخصه، وهو مأخوذ من: الحَامَّة، يقال: دُعِي فلانٌ في الحامَّة، لا في العامَّة {9}. ثم قالوا:"
  26,102,"﴿فَلَوْ أَنَّ لَنَا كَرَّةً﴾ أي: رجعة إلى الدنيا {1} ﴿فَنَكُونَ مِنَ الْمُؤْمِنِينَ﴾ اصدقين بالتوحيد {2}. أي: حتى تحل لنا الشفاعة كما حلت للمؤمنين {3}."
  26,103,"﴿إِنَّ فِي ذَلِكَ﴾ يعني فيما أخبر من قصة إبراهيم ﴿لَآيَةً﴾ لعبرة لمن بعدهم.والباقي [103 - 104] مفسر فيما مضى من السورة إلى قوله:"
  26,105,"﴿كَذَّبَتْ قَوْمُ نُوحٍ الْمُرْسَلِينَ﴾ قال أبو إسحاق: دخلت التاء و: ﴿قوم﴾ مذكرون؛ لأن المعنى: كذبت جماعة قوم نوح {1}.وقوله: ﴿الْمُرْسَلِينَ﴾ قال ابن عباس، ومقاتل، والمفسرون: يعني نوحًا وحده {2}. وعلى هذا إنما جاز الجمع؛ لأن من كذب رسولاً واحدًا من رسل الله فقد كذب الجماعة، وخالفها؛ لأن كل رسول يأمر بتصديق جميع الرسل {3}. وهذا معنى قول الحسن؛ لما سئل عن هذا وأمثاله فقال: إن الآخِر جاء بما جاء به الأول، فإذا كَذبوا واحدًا فقد كذبوهم أجمعين {4}. وقال الكلبي ﴿كَذَّبَتْ قَوْمُ نُوحٍ﴾ نوحًا، وما أخبرهم من مجيء المرسلين بعده {5}. قال الزجاج: وجائز أن يكونوا كذبوا جميع الرسل {6}."
  26,106,"﴿إِذْ قَالَ لَهُمْ أَخُوهُمْ نُوحٌ﴾ قال ابن عباس: ابن أبيهم، يعني: أن الأخوة كانت من جهة النسب، لا من جهة الدين. وهو قول جميع المفسرين: أخوهم في النسب. يعني: أنه منهم، وليس بأخيهم في الدين {1}.قال الزجاج: كل رسول يأتي بلسان قومه، ليوضح لهم الحجة، ويكون أبين لهم {2}، كقوله تعالى: ﴿وَمَا أَرْسَلْنَا مِنْ رَسُولٍ إِلَّا بِلِسَانِ قَوْمِهِ﴾ الآية، [إبراهيم: 4] وقوله: ﴿أَلَا تَتَّقُونَ﴾ مفسر {3} في هذه السورة."
  26,107,"﴿إِنِّي لَكُمْ رَسُولٌ أَمِينٌ﴾ [قال ابن عباس: ائتمني الله على رسالته، وبعثني إليكم {1}. وهو قول مقاتل:] {2} أمين على الرسالة فيما ينكم وبين ربكم {3}.وقال الكلبي: كان فيهم أمينًا قبل ذلك {4}."
  26,108,"﴿فَاتَّقُوا اللَّهَ﴾ بطاعته وعبادته ﴿وَأَطِيعُونِ﴾ فيما آمركم به من الإيمان والتوحيد."
  26,109,"﴿وَمَا أَسْأَلُكُمْ عَلَيْهِ مِنْ أَجْرٍ﴾ قال مقاتل: وذلك أنهم قالوا للأنبياء: إنكم تريدون أن تتملكوا علينا في أموالنا! فردت عليهم الأنبياء فقالوا: وما نسألكم عليه من أجرة يعني: على الإيمان جُعلا.﴿إِنْ أَجْرِيَ﴾ ما جزائي وثوابي ﴿إِلَّا عَلَى رَبِّ الْعَالَمِينَ﴾ {1}."
  26,111,"وقوله: ﴿قَالُوا أَنُؤْمِنُ لَكَ﴾ قال مقاتل: أنصدق بقولك {1} ﴿وَاتَّبَعَكَ الْأَرْذَلُونَ﴾ الواو هاهنا للحال، ومعها: قد، مضمرة؛ لأن واو الحال قَلَّ ما تصحب الأفعال، ولهذا قرأ من قرأ: (وأتْباعُك) قال الفراء: وهو وجه حسن {2}.وقال الزجاج: هي في العربية جيدة؛ لأن واو الحال تصحب الأسماء أكثر في العربية؛ لأنك تقول: جئتك وأصحابك الزيدون، ويجوز: وصحبك، والأكثر: جئتك وقد صحبك الزيدون {3}. ومعنى ﴿الْأَرْذَلُونَ﴾ هو كمعنى الأراذل وقد مر {4}.قال ابن عباس في رواية عطاء: يريد المساكين بأنهم شرار الناس ليس لهم مال ولا عز {5}.وقال مقاتل، والكلبي: يعنون السفلة {6}. وكان آمن شرح بنوه، ونساؤه، وأُناس من ضعفاء قومه {7}.وروى الضحاك عن ابن عباس قال: الحاكة {8}. وهو قول عكرمة، وزاد: الأساكفة {9}.قال أبو إسحاق: والصناعات لا تضر في باب الديانات {10}.وروي عن ابن عباس، في تفسير الأرذلين: الغلفة {11}. والصحيح: أنهم أرادوا بالأرذلين الذين مكاسبهم دنية؛ لقوله: ﴿قَالَ وَمَا عِلْمِي بِمَا كَانُوا يَعْمَلُونَ﴾.لما نسبوا أتباع نوح إلى دناءة المكاسب، أجابهم نوح بأن قال:"
