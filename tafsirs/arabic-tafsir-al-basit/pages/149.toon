tafsir[5]{c,v,t}:
  6,153,"قوله تعالى: ﴿وَأَنَّ هَذَا صِرَاطِي مُسْتَقِيمًا﴾ الآية، قال الفراء: (تفتح (أن) من وقوع (أتل) [الأنعام: 151] عليها يعني: وأتل عليكم ﴿وَأَنَّ هَذَا صِرَاطِي مُسْتَقِيمًا﴾ قال: وإن شئت جعلتها خفضًا يريد: ﴿ذَلِكُمْ وَصَّاكُمْ بِهِ﴾ [الأنعام: 152] وبأن {1} هذا صراطي)، وقال أبو علي: (من فتح (أن) فقياس {2} قول سيبويه أنه حملها على (فاتبعوه) والتقدير: ولأن ﴿هَذَا صِرَاطِي مُسْتَقِيمًا فَاتَّبِعُوهُ﴾ كقوله ﴿إِنَّ هَذِهِ أُمَّتُكُمْ أُمَّةً وَاحِدَةً {3}﴾ [المؤمنون: 52] قال سيبويه: ولأن هذه أمتكم، وقال في قوله: {وأن المساجد لله [فلا تدعوا مع الله أحدًا] {4} [الجن: 18] المعنى: ولأن المساجد لله {5}، وقرأ ابن عامر {6}: (وأن هذا) مفتوحة مخففة، والمخففة [هاهنا] {7} كالمشدودة، وفيه ضمير القصة والحديث، وعلى هذه الشريطة يخفف، والتقدير: وأنه هذا، كقول الأعشى:في فِتَيةٍ كسيُوفِ الهند قد علمُوا ... أَنْ هالِكٌ .............. {8}أي: قد علموا أنه هالك. قال: والفاء التي في قوله (فاتبعوا) مثل الفاء التي في قولك: يزيد فامرر، ومن كسر (إن) استأنف بها، والفاء {9} في قوله عاطفة جملة على جملة، وعلى القول الأول زيادة) {10}، وذكرنا وجه انتصاب قوله (مستقيما) عند قوله: ﴿وَهَذَا صِرَاطُ رَبِّكَ مُسْتَقِيمًا قَدْ فَصَّلْنَا الْآيَاتِ﴾ [الأنعام: 126] في هذه السورة. قال ابن عباس في قوله: ﴿وَأَنَّ هَذَا صِرَاطِي مُسْتَقِيمًا﴾ (يريد: ديني دين الحنيفية أقوم الأديان وأحسنها) {11}.وقال مقاتل: (الذي ذكر في هذه الآيات {12} من أمره ونهيه ﴿صِرَاطِي مُسْتَقِيمًا فَاتَّبِعُوهُ﴾) {13}.وقوله تعالى: ﴿وَلَا تَتَّبِعُوا السُّبُلَ﴾ قال ابن عباس: (اليهودية والنصرانية والمجوسية وعبادة الأوثان) {14}، وهذا تفسير ما ذكره مجملًا في رواية عطاء قال: (يريد: مثل الذي يسلك الطريق فيأخذ بنيات {15} الطريق) {16}، وقال مجاهد ﴿وَلَا تَتَّبِعُوا السُّبُلَ﴾ (يعني: البدع والشبهات) {17}، وقال مقاتل: (يعني: طريق الضلالة فيما حرموا على أنفسهم من الأنعام والحرث {13}.وقوله تعالى: ﴿فَتَفَرَّقَ بِكُمْ عَنْ سَبِيلِهِ﴾ قال ابن عباس: (فتضل {19} بكم عن دينه) {20}. وقال مجاهد: (أي: تميل وتخالف، ﴿ذَلِكُمْ وَصَّاكُمْ بِهِ﴾ في الكتاب ﴿لَعَلَّكُمْ تَتَّقُونَ﴾ السبل) {21}. وقال عطاء: ﴿لَعَلَّكُمْ تَتَّقُونَ﴾: (كي تخافوا) {22} قال المفسرون {23}: (هذه الآيات محكمات، لم ينسخهن شيء في جميع الكتب، وهن محرمات على بني آدم، من عمل بهن دخل الجنة، ومن تركهن دخل النار)."
  6,154,"قوله تعالى: ﴿ثُمَّ آتَيْنَا مُوسَى الْكِتَابَ﴾ الآية. قال أبو بكر {1}. (الذي بعد (ثم) مقدم على الذي قبلها في النّية، والتقدير: ثم كنا قد آتينا موسى الكتاب قبل إنزالنا القرآن على محمَّد ﷺ؛ لأن التوراة أنزلت قبل القرآن.قال: وجواب آخر وهو: أن (ثم) أوجبت تأخير الخبر بعد الخبر الأول، أي: ﴿قُلْ تَعَالَوْا أَتْلُ مَا حَرَّمَ رَبُّكُمْ عَلَيْكُمْ﴾ [الأنعام: 151]، إلى قوله: ﴿لَعَلَّكُمْ تَتَّقُونَ﴾ [الأنعام: 153] ثم قال بعد ذلك: ﴿ثُمَّ آتَيْنَا مُوسَى الْكِتَابَ﴾ يريد: ثم أخبركم بعد ما أخبرتكم به عن نزول القرآن على محمد (بنزول التوراة على موسى، فدخلت (ثم) لتأخير الخبر لا لتأخير النزول) {2}. وهذا قول أبي إسحاق، وأنكر القول الأول فقال: ((ثم) لا يكون الذي بعدها معناه التقديم، وإنما دخلت ثم للعطف على معنى التلاوة، والمعنى: ﴿قُلْ تَعَالَوْا أَتْلُ مَا حَرَّمَ رَبُّكُمْ عَلَيْكُمْ﴾ وأتلو عليكم لا تقتلوا أولادكم، ولا تقتلوا النفس التي حرم الله، ثم أتلو عليكم ما آتاه الله جل وعز موسى) {3}.وقوله تعالى: ﴿تَمَامًا عَلَى الَّذِي أَحْسَنَ﴾ كثر الاختلاف في هذا بين أهل المعاني، والذي يعتمد في تفسير هذا قولان مجمع على صحتهما:أحدهما: أن المعنى (تماما) من الله عز وجل على المحسنين، و ﴿الَّذِي أَحْسَنَ﴾ بمعنى: من أحسن، ومن أحسن هو المحسن، كأنه قيل: تمامًا على المحسن، والمحسن [يكون] {4} هاهنا في مذهب الجمع كما قال: ﴿إِنَّ الْإِنْسَانَ لَفِي خُسْرٍ﴾ [العصر: 2]، وهذا كما يقول الرجل: أوصي بمالي لمن غزا وحج وللذي غزا وحج] {5}، يريد: الغزاة والحجاج، ويدل على صحة هذا التأويل قراءة ابن مسعود {6} (تماما على الذين أحسنوا). والمحسنون {7} هم الأنبياء صلوات الله عليهم [أجمعين] {8}، أو المؤمنون. وتلخيصه: آتينا موسى الكتاب تتميمًا منا على الأنبياء و {9} المؤمنين الكتب، وتفصيلًا منا لكل شيء، وإنما فسرنا التمام بالتتميم هاهنا لما يعود معناه إليك؛ لأنك إذا قلت: أعطيتك الشيء تمامًا، كان معناه: تممته لك {10}.القول الثاني: ﴿تَمَامًا عَلَى الَّذِي أَحْسَنَ﴾ أي: على الذي أحسنه موسى من طاعة الله جل وعز واتباع أمره، أو على الذي أحسنه موسى من العلم، وكتب الله القديمة، فيكون (أحسن) بمعنى: علم، والتأويل ﴿آتَيْنَا مُوسَى الْكِتَابَ تَمَامًا﴾ على ما أحسن من العلم والحكمة، وكتب الله المتقدمة، وأراد بقوله: (تمامًا) على ذلك، أي: زيادة على ذلك، والقولان ذكرهما الفراء {11} والزجاج {12} وأبو بكر {13} وأبو محمد بن قتيبة {14}.قال الزجاج: (و (تمامًا) منصوب على مفعول له وكذلك ﴿وَتَفْصِيلًا﴾ المعنى: آتيناه لهذه العلة أي: للتمام والتفصيل) {15}، والمفسرون {16} على هذين القولين، فالقول الأول قول مجاهد والحسن، قال مجاهد: (تمامًا على المؤمنين المحسنين) {17}. وقال الحسن: (تمامًا على المحسنين، و ﴿الَّذِي أَحْسَنَ﴾ هو المؤمن) {18}.وقال الكلبي: (﴿آتَيْنَا مُوسَى الْكِتَابَ﴾ الألواح، فيها التوراة ﴿تَمَامًا عَلَى الَّذِي﴾ أحسنه من تبليغ رسالاته) {19}. وهذا معنى القول الثاني.وأجاز الفراء {20} والكوفيون {21} قولاً آخر وهو: أن يكون (أحسن) اسمًا موضعه خفض على النعت للذي وهو ساد مسد الصلة، ونائب عنها، يراد به: ﴿تَمَامًا عَلَى الَّذِي أَحْسَنَ﴾ من غيره، فحذفت من لبيان أمرها، وجرى (أحسن) على إعراب (الذي) كما قالت العرب: مررت بالذي أخيك، وجلست إلى الذي مثلك، فحملوا على الذي إعراب الاسم بعده، وجعلوه {22} يسد مسد صلته، وأنشدوا:إن الدبيري الذي مثل الحلم {23}فنصب مثل على الإتباع للذي، وهي سادة مسد صلته، وإنما جاز حمل (أحسن) على (الذي) و (الذي) معرفة و (أحسن) في تأويل نكرة؛ لأنه يطالب من، ومن يؤدي عن الإضافة، والمضاف معرفة، ومن كلام العرب: مررت يزيد خير منك، على أن خيرًا نعت لزيد؛ إذ كان كالمضاف من أجل صحبته من، وهذا كلام أبي بكر {24}، ويدل على صحة هذا القول قراءة يحيى {25} بن يعمر: ﴿تَمَامًا عَلَى الَّذِي أَحْسَنَ﴾، والتقدير: على الذي هو أحسن، أي: الذي هو أحسن الأشياء، وأحسن من غيره، وهذا يدل على أن (أحسن) هاهنا اسم، ويعضد هذا القول [أيضًا] {26} ما روي عن ابن عباس أنه قال في تفسير قوله: ﴿تَمَامًا عَلَى الَّذِي أَحْسَنَ﴾ يقول: (أتم له الكتاب على أحسنه) {27} فجعل الأحسن من نعت الكتاب، نظيره ﴿وَتَمَّتْ كَلِمَتُ رَبِّكَ الْحُسْنَى﴾ {28} [الأعراف: 137]. وقال أبو إسحاق: (أجاز الكوفيون أن يكون (أحسن) في موضع خفض وأن {29} يكون من صفة (الذي) وهذا عند البصريين خطأ؛ لأنهم لا يعرفون الذي إلا موصولًا ولا توصف إلا بعد تمام صلتها) {30}، وقوله تعالى: ﴿لَعَلَّهُمْ بِلِقَاءِ رَبِّهِمْ يُؤْمِنُونَ﴾ قال ابن عباس: (كي يؤمنوا بالبعث ويصدقوا بالثواب والعقاب) {31}."
  6,155,"قوله تعالى: ﴿وَهَذَا كِتَابٌ أَنْزَلْنَاهُ مُبَارَكٌ﴾ الآية، مضى الكلام في هذا في هذه السورة.﴿فَاتَّبِعُوهُ وَاتَّقُوا لَعَلَّكُمْ تُرْحَمُونَ﴾ قال الزجاج: (أي: لتكونوا راجين للرحمة) {1}.قوله تعالى: ﴿أَنْ تَقُولُوا إِنَّمَا أُنْزِلَ الْكِتَابُ﴾ الآية [الأنعام: 156]، (أن) عند الفراء {2} والكسائي {3} متعلقة بأنزلناه على تقدير: أنزلناه؛ لأن لا تقولوا، ثم حذف الجار وحرف النفي كقوله: ﴿يُبَيِّنُ اللَّهُ لَكُمْ أَنْ تَضِلُّوا﴾ [النساء: 176]. وقوله: ﴿رَوَاسِيَ أَنْ تَمِيدَ بِكُمْ﴾ [النحل: 15] أي: لئلا، وعند البصريين {4}. معناه: أنزلناه كراهة أن تقولوا، ولا يُجيزون إضمار لا، لا يقولون: جئت أن أكرمك، على معنى: أن لا أكرمك {5} وقد ذكرنا ما في هذا في آخر سورة {6} النساء."
  6,156,"قال الفراء: (ويجوز أن يكون ﴿أَنْ﴾ متعلقة باتقوا والتأويل: و {1} اتقوا ﴿أَنْ تَقُولُوا إِنَّمَا أُنْزِلَ الْكِتَابُ﴾) {2}.قال ابن عباس: (يعني: التوراة والإنجيل {3} ﴿عَلَى طَائِفَتَيْنِ مِنْ قَبْلِنَا﴾ وهم اليهود والنصارى {4}، ﴿وَإِنْ كُنَّا عَنْ دِرَاسَتِهِمْ لَغَافِلِينَ﴾ يريد: لم ندرس التوراة والإنجيل فتعرف {5} ما فيها) {6}. قال الزجاج: (المعنى: وما كنا إلا غافلين عن دراستهم، أي: كنا غافلين عن تلاوة كتبهم) {7}. قال المفسرون: (الخطاب لأهل مكة، والمراد بالآية: إثبات الحجة عليهم بإنزال القرآن على محمد، كيلا يقولوا يوم القيامة إن التوراة والإنجيل أنزلا ﴿عَلَى طَائِفَتَيْنِ مِنْ قَبْلِنَا﴾ وكنا غافلين عما فيهما، فقطع الله معاذيرهم بإنزال القرآن فيهم) {8}، وقال قتادة: (﴿دِرَاسَتِهِمْ﴾ قراءتهم) {9}."
  6,157,"وقال [الكلبي] {1} والكسائي: ﴿وَإِنْ كُنَّا عَنْ دِرَاسَتِهِمْ لَغَافِلِينَ﴾ لا نعلم {2} ما هي؛ لأن كتابهم لم يكن بلغتنا، فأنزل الله تعالى كتابًا بلغتهم، وبعث منهم رسولاً يعرفون نسبه، ويعرفونه بالصدق فقال: ﴿فَقَدْ جَاءَكُمْ بَيِّنَةٌ مِنْ رَبِّكُمْ﴾ [الأنعام:157] أي: رسول من ربكم ﴿بِلِسَانٍ عَرَبِيٍّ مُبِينٍ﴾ [الشعراء: 195] حين لم تعرفوا {3} دراسة الطائفتين وحين قلتم لو جاءنا ﴿الْكِتَابُ لَكُنَّا أَهْدَى مِنْهُمْ﴾ [الأنعام: 157] {4}."
