tafsir[11]{c,v,t}:
7,1," <q>﴿المص﴾</q> قال أبو إسحاق: (الذي اخترنا {1} في تفسيرها قول ابن عباس {2} -رضي الله عنه- {3}: (إن معناها أنا الله أعلم، وأفضل)، وعلى هذا التفسير: هذه الحروف واقعة في موضع جُمل، والجمل {4} إذا كانت ابتداء وخبرًا فقط لا موضع لها. مثل قولك: أنا الله أعلم. لا موضع لها من الإعراب، إنما يرتفع بعض ذا ببعض؛ فالله يرتفع [بأنا] {5}، و (أعلم) خبر مستأنف يراد به: وأنا أعلم {6}، وإذا كان معنى <q>﴿المص﴾</q>: أنا الله أعلم كان إعرابها كإعراب الشيء الذي هو تأويل لها) {7}. ",footnotes:1:في (ب): (أخبرنا)، وهو تصحيف.أخرجه الطبري في "تفسيره" 8/ 115، وابن أبي حاتم 5/ 1437، والبيهقي في "الأسماء والصفات" 1/ 232 عن ابن عباس قال: (أنا الله أفصل) اهـ. وذكره السيوطي في "الدر" 3/ 125. وفي سنده عطاء بن السائب الثقفي، صدوق اختلط فساء حفظه - انظر "تهذيب التهذيب" 3/ 103. والراجح أن الحروف المقطعة في أوائل السور حروف هجائية. ذكرت للدلالة على إعجاز القرآن وأن الخلق عاجزون عن معارضته بمثله مع أنه مركب من هذه الحروف التي يتخاطبون بها ليكون عجزهم أبلغ في "الحجة" عليهم وهذا اختيار جماعة من المحققين انظر: "الكشاف" 1/ 76، و"تفسير ابن كثير" 2/ 224، والشوكاني 2/ 273، والشنقيطي 3/ 3 - 7.في (أ): (رحمه الله).في (أ): و (الجملة).في (ب): (يرتفع أنا).لفظ: (الواو) ساقط من (ب)، ويريد أن قوله: "أعلم خبر بعد خبر". انظر "تفسير الرازي" 14/ 14، حيث نقل قول الواحدي.انظر: "معاني الزجاج" 2/ 313 - 314
7,2," قوله تعالى: <q>﴿كِتَابٌ أُنْزِلَ إِلَيْكَ﴾</q>، أجمع النحويون: على أن الكتاب مرفوع بمضمر قبله، المعنى: هذا <q>﴿كِتَابٌ أُنْزِلَ إِلَيْكَ﴾</q> {1}. وأجاز الفراء أن يكون موضع هذه الحروف المعجمة رفعًا بما بعدها، و <q>﴿كِتَابٌ﴾</q> مرتفع بها كالمبتدأ والخبر، والمعنى: <q>﴿المص﴾</q> حروف <q>﴿كِتَابٌ أُنْزِلَ إِلَيْكَ﴾</q>، وأطال الكلام في بيان هذا {2}، ثم أنكر الزجاج {3} عليه هذا القول، وطال الخطب بينهما، وإذا رجعت إلى كتابيهما عرفت ما أقول. وقوله تعالى: <q>﴿فَلَا يَكُنْ فِي صَدْرِكَ حَرَجٌ مِنْهُ﴾</q> [الأعراف:2]. قال ابن عباس {4} وأبو العالية: (ضيق) {5}. قال أبو إسحاق: (معناه: لا يضيق صدرك بالإبلاغ ولا تخافن؛ وذلك أنه يروى عن النبي ﷺ أنه قال: "أي رب إني أخاف أن يثلغوا {6} رأسي" {7}، فأعلم الله عز وجل أنه في أمان منهم، فقال: <q>﴿فَلَا يَكُنْ فِي صَدْرِكَ حَرَجٌ مِنْهُ﴾</q> أي: فلا يضيقن صدرك من تأدية ما أرسلت به) {8}. وقال الفراء: (لا يضيق صدرك بالقرآن بأن يكذبوك) {9}. وقال مجاهد {10} ومقاتل {11}: (فلا يكن في قلبك شك {12} في القرآن أنه من الله). وقال أبو إسحاق: (وتأويل هذا، وقوله: <q>﴿فَلَا تَكُونَنَّ مِنَ الْمُمْتَرِينَ﴾</q> [البقرة: 147]، وقوله: <q>﴿فَإِنْ كُنْتَ فِي شَكٍّ﴾</q> الآية [يونس: 94] أن ما خوطب به النبي ﷺ فهو خطاب لأمته فكأنه بمنزلة: فلا تشكوا ولا ترتابوا) {13}. قال ابن قتيبة: (وأصل الحرج الضيق، والشك في الشيء يضيق صدره؛ لأنه لا يعلم حقيقته فسمي الشك حرجا) {14} وأما اشتقاق هذا الحرف فقد ذكرناه في سورة الأنعام [125]. وقوله: <q>﴿لِتُنْذِرَ بِهِ﴾</q>. قال الفراء: (اللام في <q>﴿لِتُنْذِرَ﴾</q> متعلق بقوله <q>﴿أُنْزِلَ﴾</q> على التقديم والتأخير، على تقدير <q>﴿كِتَابٌ أُنْزِلَ إِلَيْكَ﴾</q> لتنذر به <q>﴿فَلَا يَكُنْ فِي صَدْرِكَ حَرَجٌ مِنْهُ﴾</q>) {15}. وقال ابن الأنباري: (ويجوز أن تكون اللام صلة للكون {16} على معنى: <q>﴿فَلَا يَكُنْ فِي صَدْرِكَ﴾</q> شيء {17} <q>﴿لِتُنْذِرَ بِهِ﴾</q>، كما يقول الرجل من العرب للرجل: لا تكن ظالما ليقضي {18} صاحبك دينه، فتحمل {19} لام كي على الكون) {20}. قال صاحب النظم {21}: (وفيه وجه آخر: وهو أن تكون {22} اللام بمعنى أن، والمعنى {23}: لا يضيق صدرك ولا يضعف عن أن تنذر به، والعرب تضع هذه اللام في موضع (أن) كقوله تعالى <q>﴿يُرِيدُونَ أَنْ يُطْفِئُوا﴾</q> [التوبة: 32] وفي موضع آخر <q>﴿لِيُطْفِئُوا﴾</q> [الصف: 8]، وهما جميعا بمعنى واحد) {24}. وقوله تعالى: <q>﴿وَذِكْرَى لِلْمُؤْمِنِينَ﴾</q>. قال ابن عباس: (يريد: ومواعظ للمصدقين) {25}. قال الزجاج: (هو اسم في موضع المصدر وفيه ألف التأنيث بمنزلة دعوت دعوى، ورجعت رجعى، واتقيت تقوى) {26}. وقال الليث: (الذكرى اسم للتذكرة) {27} والتفعلة مصدر كالتفعيل نحو قوله تعالى <q>﴿تَبْصِرَةً وَذِكْرَى﴾</q> [ق: 8]. وأما محل <q>﴿ذِكْرَى﴾</q> من الإعراب، فقال الفراء: (يجوز أن يكون في موضع نصب على معنى: <q>﴿لِتُنْذِرَ بِهِ﴾</q> وتذكر، قال: ويجوز أن يكون رفعًا بالرد على الكتاب كأنك قلت: كتاب حق وذكرى {28}. وقال الزجاج: (ويجوز على أن يكون وهو <q>﴿ذِكْرَى لِلْمُؤْمِنِينَ﴾</q>، قآل: ويجوز أن يكون خفضًا؛ لأن معنى <q>﴿لِتُنْذِرَ﴾</q>: لأن تنذر فهو في موضع خفض؛ لأن المعنى للإنذار والذكرى) {29}. ",footnotes:1:هذا نص كلام الزجاج في "معانيه" 2/ 314، وانظر: "معاني الأخفش" 2/ 293 "إعراب النحاس" 1/ 98 ، "المشكل" 1/ 281.انظر: "معاني الفراء" 1/ 369 - 370.انظر: "معاني الزجاج" 2/ 213 - 214 "إعراب النحاس" 1/ 598."تنوير المقباس" 2/ 80، وذكره الواحدي في "الوسيط" 1/ 156، وأخرج ابن حسنون في "اللغات" ص 23 - 25، والوزان 3 ب عن ابن عباس قال: (حرج: ضيق بلغة قيس عيلان، وشك بلغة قريش).ذكره الثعلبي في "الكشف" 187 ب، والبغوي في "تفسيره" 3/ 213.في (ب): (تبلغوا)، وهو تحريف - والثلغ: الشدخ وضرب الشيء الرطب بالشيء اليابس حتى ينشدخ. انظر "النهاية" 1/ 220.هذا طرف من حديث طويل أخرجه أحمد في "المسند" 4/ 162، ومسلم في "صحيحه" رقم (2865) عن عياض بن حمار المجاشعي، أن رسول الله (قال == ذات يوم في خطبته: "إن الله أمرني أن أحرق قريشا، فقلت: رب إذا يثلغوا رأسي فيدعوه خبزة .. ". الحديث. ومعنى يثلغوا رأسي، أي: يشدخوه ويشجوه كما يشدخ الخبز أي: يكسر. أفاده الإِمام النووي رحمه الله تعالى في "شرح مسلم" 17/ 289."معاني الزجاج" 2/ 315، وانظر: "معاني النحاس" 3/ 7 - 8"معاني الفراء" 1/ 370."تفسير مجاهد" 1/ 231، وأخرجه الطبري في "تفسيره" 8/ 116، وابن أبي حاتم 5/ 1438 بسند جيد."تفسير مقاتل" 2/ 29.في (أ): (شيء)، وهو تحريف."معاني الزجاج" 2/ 315، ومثله في "معاني النحاس" 2/ 7 - 8 والراجح أن المراد بالحرج في الآية الضيق لأن ذلك هو الغالب من معناه في كلام العرب وهو اختيار أبي عبيدة في "مجاز القرآن" 1/ 210، والطبري في "تفسيره" 8/ 116، وابن عطية 5/ 423، وأبي حيان في "البحر" 4/ 266."تفسير غريب القرآن" ص 176."معاني الفراء" 1/ 370، وانظر: "معاني الزجاج" 2/ 315، و"تفسير الطبري" 8/ 117، و"معاني النحاس" 3/ 8.في (ب): (ليكون).في (ب): (شك).في (أ): (لتقضى) بالتاء.في (أ): (فيحمل) بالياء.ذكره الرازي في "تفسيره" 14/ 16، وأبو حيان في "البحر" 4/ 266، ونقله السمين في "الدر" 5/ 242 - 243 عن الواحدي عن ابن الأنباري، وانظر: كلام ابن الأنباري على مادة حرج في "الزاهر" 1/ 236، و"المذكر والمؤنث" 1/ 258، و"شرح القصائد" ص 321، ص 580، و"إيضاح الوقف والابتداء" 2/ 650.صاحب "النظم"، أبو علي الحسن بن يحيى الجرجاني. تقدمت ترجمته، وكتابه "نظم القرآن" مفقود.في (أ): (يكون) بالباء.في (ب): (فالمعنى).ذكره الرازي في "تفسيره" 14/ 16، وأبو حيان في "البحر" 4/ 266، ونقله السمين في "الدر" 5/ 242 - 244، وقال: (هذا قول ساقط جدًّا؛ كيف يكون حرف يختص بالأفعال يقع موقع آخر مختص بالأسماء. ونقل الشيخ أبو حيان في "البحر" عن ابن الأنباري وصاحب النظم: أن اللام متعلقة بما تعلق به خبر الكون إذ التقدير: فلا يكن حرج مستقرًا في صدرك لأجل الإنذار، والذي نقله الواحدي عن نص ابن الأنباري في ذلك أن اللام متعلقة بالكون وعن صاحب النظم أن اللام بمعنى أن، فيجوز أن يكون لهما كلامان) اهـ. ملخصًا. وانظر: "إعراب النحاس" 1/ 599، و"البيان" 1/ 353، و"التبيان" ص 367، و"الفريد" 2/ 266.ذكره الرازي في "تفسيره" 14/ 17، وذكره الواحدي في "الوسيط" 1/ 156 بدون نسبة. وفي "تنوير المقباس" 2/ 80 نحوه."معاني الزجاج" 2/ 316."تهذيب اللغة" 2/ 1286، وانظر: "العين" 5/ 346، وأصل الذكر بالكسر حفظ الشيء وجرى الشيء على اللسان، والذكر والذكرى بالكسر ضد النسيان، انظر: "الجمهرة" 2/ 694، و"الصحاح" 2/ 664، و"المجمل" 2/ 360، و"المفردات" ص 328، و"اللسان" 3/ 1507. (ذكر).انظر: "معاني الفراء" 1/ 370.انظر: "معاني الزجاج" 2/ 315 - 316، وعلى هذا فيه ثلاثة أوجه: الرفع: عطفًا على كتاب أو على إضمار مبتدأ، والنصب: على المصدر أي وتذكر ذكرى أو على العطف على موضع التنذر). والجر على العطف على المصدر المنسبك في أن المقدرة بعد لام كي أي: للإنذار والتذكير أو على الضمير في (به) وانظر: "إعراب النحاس" 1/ 599، و"المشكل" 1/ 281، و"البيان" 1/ 353، و"التبيان" ص 367، و"الفريد" 2/ 266، و"الدر المصون" 5/ 244.
7,3," وقوله تعالى: <q>﴿اتَّبِعُوا مَا أُنْزِلَ إِلَيْكُمْ مِنْ رَبِّكُمْ﴾</q>. قال الحسن: (يا ابن آدم أمرت باتباع كتاب الله وسنة محمد ﷺ {1}؛ والله ما نزلت آية إلا ويجب أن تعلم فيما أنزلت وما معناها) {2}. ونحو هذا قال الزجاج: (أي: اتبعوا القرآن وما أتى به النبي ﷺ فإنه مما أنزل عليه؛ لقوله: <q>﴿وَمَا آتَاكُمُ الرَّسُولُ فَخُذُوهُ وَمَا نَهَاكُمْ عَنْهُ فَانْتَهُوا﴾</q> {3} [الحشر: 7]. وقوله تعالى: <q>﴿وَلَا تَتَّبِعُوا مِنْ دُونِهِ أَوْلِيَاءَ﴾</q>. قال ابن عباس: (يريد: لا تتخذوا غيره أولياء، <q>﴿قَلِيلًا﴾</q> يا معشر المشركين <q>﴿مَا تَذَكَّرُونَ﴾</q> يريد: ما تتعظون) {4}. وهذا من قول ابن عباس يدل على أن الآية خطاب للمشركين {5}، و <q>﴿تذكرون﴾</q> أصله تتذكرون فأدغم تاء تتفعل في الذال لأن التاء مهموسة والذال مجهورة {6}، والمجهور أزيد صوتًا من المهموس فحسن إدغام الأنقص في الأزيد، و <q>﴿مَا﴾</q> موصولة بالفعل وهي معه بمنزلة المصدر، والمعنى: قليلاً {7} تذكركم، وقرأ حمزة {8} والكسائي وحفص {9} خفيفة الذال شديدة الكاف حذفوا التاء التي أدغمها الأولون وذلك حسن لاجتماع ثلاثة أحرف متقاربة ويقوى ذلك قولهم: اسطاع {10}. وقرأ ابن عامر <q>﴿يَتَذَكَّرُونَ﴾</q> بياء {11} وتاء ووجهه {12} أن هذا خطاب للنبي (ﷺ) {13} أي: قليلاً ما يتذكر هؤلاء الذين {14} ذكروا بهذا الخطاب {15}. ",footnotes:1:في (أ): (صلى الله عليه).ذكره الواحدي في "الوسيط" 1/ 156، والرازي في "تفسيره" 14/ 18، و"الخازن" 2/ 209."معاني الزجاج" 2/ 316، ونحوه ذكر الطبري في "تفسيره" 8/ 117، والنحاس في "معانيه" 3/ 8 - 9 والسمرقندي في "تفسيره" 1/ 530.في "تنوير المقباس" 2/ 81 نحوه دون لفظ (المشركين).انظر: "تفسير الطبري" 8/ 117، و"معاني الزجاج" 2/ 316، والنحاس 3/ 9.الهمس: الخفاء، وهو جريان النفس عند النطق بالحرف لضعف الاعتماد على مخرجه. وضده الجهر وهو الظهور والإعلان والمراد به انحباس النفس عند النطق بالحرف لقوة الاعتماد على مخرجه، انظر: "سر صناعة الإعراب" 1/ 60، و"غاية المريد" لعطية نصر ص 139.في (ب): قليلاً ما تذكركم. والنص من "الحجة" 4/ 5 - 7، وانظر: "الدر المصون" 5/ 246.قرأ حمزة والكسائي، وحفص عن عاصم - <q>﴿قيلا ما تذكرون﴾</q> بالتاء خفيفة الذال مشددة الكاف، وقرأ الباقون <q>﴿تذكرون﴾</q> بالتاء مشددة الذال والكاف. وقرأ ابن عامر: <q>﴿قليلاً ما يتذكرون﴾</q> بياء وتاء، وتخفيف الذال وتشديد الكاف، وقد روي عنه بتاءين (تتذكرون). انظر: "السبعة" ص 278، و"المبسوط" ص 279، و"التذكرة" 2/ 417، و"التيسير" ص 109، والنشر 2/ 267.حفص عن عاصم، وحفص هو حفص بن سليمان بن المغيرة الأسدي، أبو عمر الكوفي، صاحب عاصم، إمام في القراءة ضابط لها بخلاف حاله في الحديث، فهو متروك الحديث مع إمامته في القراءة، توفي سنة 180هـ وله تسعون سنة. انظر: "الجرح والتعديل" 3/ 173، و"معرفة القراء" 1/ 140، و"غاية النهاية" 1/ 154، و"تهذيب التهذيب" 1/ 450، و"تقريب التهذيب" ص 172 (1405).انظر: "معاني الزجاج" 2/ 316 - 317، و"إعراب النحاس" 1/ 599، و"المشكل" 1/ 281، وقد جاء في سورة الكهف [الآية: 97] قوله تعالى: <q>﴿فَمَا اسْطَاعُوا أَنْ يَظْهَرُوهُ وَمَا اسْتَطَاعُوا لَهُ نَقْبًا﴾</q> [الكهف: 97]. قرأ حمزة بتشديد الطاء، والباقون بالتخفيف. انظر: "السبعة" ص401، و"الحجة" لأبي علي 5/ 179.هنا وقع اضطراب في نسخة (ب) فوقع الكلام على هذه الآيات في 140 ب.في (ب): (ووجه)، وهو تحريف.في (أ): (عليه السلام).لفظ: (الذين) ساقط من (ب).هذا كلام أبي علي في "الحجة" 5/ 4 - 6. وانظر: "معاني القراءات" 1/ 400، و"الحجة" لابن زنجله ص 279، و"الكشف" 1/ 460.
7,4," وقوله تعالى: <q>﴿وَكَمْ مِنْ قَرْيَةٍ أَهْلَكْنَاهَا﴾</q> الآية. قال أبو إسحاق: (موضع <q>﴿كَمْ﴾</q> رفع با لابتداء، وخبره <q>﴿أَهْلَكْنَاهَا﴾</q> قال: وهو أحسن من أن يكون في موضع نصب؛ لأن قولك: (زيد ضربته) أجود من (زيدًا ضربته) والنصب جيد عربي أيضًا كقوله {1}: <q>﴿إِنَّا كُلَّ شَيْءٍ خَلَقْنَاهُ بِقَدَرٍ﴾</q> [القمر: 49] {2}). وقال أهل العربية {3} والمعاني: (الآية من حذف {4} المضاف لأن التقدير: وكم من أهل قرية، يدل على هذا قوله: <q>﴿أَوْ هُمْ قَائِلُونَ﴾</q> {5} فعاد بالكلام [إلى] {6} أهل القرية). وقوله تعالى: <q>﴿فَجَاءَهَا بَأْسُنَا﴾</q> قال الفراء: (يقال: إنما أتاها العباس {7} من قبل الإهلاك، فكيف تقدم الهلاك؟ قيل: إن الهلاك والبأس يقعان معًا كما تقول: أعطيتني فأحسنت، فلم يكن الإحسان قبل الإعطاء ولا بعده، إنما وقعا معًا) {8}. وقال غيره {9}: (هذا على مذهب الإرادة، والتقدير: وكم من قرية أردنا إهلاكها {10} <q>﴿فَجَاءَهَا بَأْسُنَا﴾</q> كقوله تعالى: <q>﴿إِذَا قُمْتُمْ إِلَى الصَّلَاةِ فَاغْسِلُوا﴾</q> [المائدة: 6]. <q>﴿فَإِذَا قَرَأْتَ الْقُرْآنَ فَاسْتَعِذْ بِاللَّهِ﴾</q> {11}) [النحل: 98]. ومعنى <q>﴿فَجَاءَهَا بَأْسُنَا﴾</q> يريد: جاءها عذابنا. قاله ابن عباس {12}. وقوله تعالى: <q>﴿بَيَاتًا﴾</q> أي: ليلاً {13}. قال الفراء: (يقال: بات الرجل وهو يبيت بيتًا، وربما قالوا: بياتا، قال: وسمي البيت بيتًا لأنه يبات فيه) {14}. وقال الليث: (البيتوتة دخولك في الليل، قال: ومن قال: بات فلان إذا نام فقد أخطأ) {15}. وقال ابن كيسان: (بات يجوز أن يجرى مجرى نام وأن يجرى مجرى كان) {16}. وقال الزجاج: (يقال {17}: بات بياتًا حسنًا وبيتة حسنة والمصدر من الأصل بات بيتًا وأصل تسمية البيت من أنه يصلح للمبيت) {18}. وقد ذكر هذا الحرف {19} في قوله تعالى: <q>﴿إِذْ يُبَيِّتُونَ﴾</q> [النساء: 108] و <q>﴿بَيَّتَ طَائِفَةٌ مِنْهُمْ﴾</q> [النساء: 81]. وقوله تعالى: <q>﴿أَوْ هُمْ قَائِلُونَ﴾</q> {20}. قال الفراء: (وفيه واو مضمرة. المعنى: أهلكناها <q>﴿فَجَاءَهَا بَأْسُنَا بَيَاتًا أَوْ هُمْ قَائِلُونَ﴾</q> فاستثقلوا {21} نسقًا على أثر نسق، ولو قيل كان صوابًا). قال ابن الأنباري: (أضمرت واو الحال لوضوح معناها؛ كما تقول العرب: لقيت عبد الله مسرعًا أو {22} هو يركض، ولا يضرنك ظالمًا أو {23} أنت مظلوم، يريدون (أو وأنت) فيحذفون الواو عند أمنهم اللبس؛ لأن الذكر قد عاد على صاحب الحال، ومن أجل أن (أو) حرف عطف والواو كذلك استثقلوا جمعًا بين حرفين من حروف العطف فحذفوا الثاني) {24}. قال: (و (أو) في هذا الموضع لا يوجب الشك، لكنها دخلت للتفصيل، والتفصيل يضارع الإباحة فيقول الرجل لصاحبه: لأكرمنك منصفًا لي أو ظالمًا، لم يحمل (أو) في هذا على شك بل يُعنى بها التفصيل) {25}. وقال الزجاج: (لا يحتاج {26} إلى ضمير الواو كما تقول: جاءني {27} زيد راجلًا أو هو فارس لم {28} تحتج إلى واو؛ لأن الذكر قد عاد إلى الأول، قال: و (أو) {29} هاهنا دخلت على جهة تصرف الشيء ووقوعه إما مرة كذا، وإما مرة كذا على تقدير: جاءهم بأسنا مرة ليلاً ومرة نهارًا فاعتبروا بهلاك من شئتم منهم) {30}. قال الليث: (القيلولة نومة نصف النهار وهي القائلة) {31}. قال الفراء: (قال الرجل يقيلُ قيلولةَ وقيلًا وقائلة ومقيلًا) {32}. وقال الأزهري: (القيلولة عند العرب الاستراحة نصف النهار إذا اشتد الحر وإن لم يكن مع ذلك نوم، والدليل على ذلك أن الجنة لا نوم فيها، والله تعالى يقول: <q>﴿أَصْحَابُ الْجَنَّةِ يَوْمَئِذٍ خَيْرٌ مُسْتَقَرًّا وَأَحْسَنُ مَقِيلًا﴾</q> [الفرقان: 24]) {33} ومعنى الآية: أنهم جاءهم بأسنا وهم غير متوقعين له؛ إما ليلاً وهم نائمون أو نهارًا وهم قائلون كأنهم غافلون {34}. ",footnotes:1:والنصب في هذه الآية أجود، وهي القراءة المشهورة التي عليها الجماعة لأن الفائدة فيه أثر من فائدة الرفع لأن التقدير: خلقنا كل شيء بقدر فيدل على العموم واشتمال الخلق على جميع الأشياء. انظر: "إعراب النحاس" 1/ 599، و"المشكل" 2/ 701 - 703، "البيان" 2/ 406."معاني الزجاج" 2/ 318. وانظر: "إعراب النحاس" 2/ 114، و"المشكل" 1/ 281 - 282. والنصب على الاشتغال بإضمار فعل يفسره ما بعده ويقدر الفعل متأخرا عن كم لأن لها صدر الكلام والتقدير: وكم من قرية أهلكنا. انظر: "الدر المصون" 5/ 248.انظر: "معاني الزجاج" 2/ 317، و"تفسير السمرقندي" 1/ 531.الظاهر عدم الحذف لعدم الحاجة إليه؛ لأن إهلاك القرية يمكن أن يقع عليها == نفسها ولأن القرية لا تسمى بذلك إلا وفيها مساكن لأهلها وسكان منهم ففي إهلاكها إهلاك من فيها من أهلها. أفاده الطبري في "تفسيره" 8/ 118. وقال: (هذا أولى بالحق لموافقته ظاهر التنزيل المتلو) اهـ. وهو اختيار الزمخشري في الكشف 1/ 67، وأبو حيان في "البحر" 4/ 268، والسمين في "الدر" 5/ 248.في (ب): (هم قائلون).لفظ: (إلى) ساقط من (ب).في (ب): (الناس)، وهو تصحيف."معاني الفراء" 1/ 371.هذا قول مكي في "المشكل" 1/ 282 وقال السمين في "الدر" 5/ 248: (والجمهور أجابوا عن ذلك بوجهين أحدهما: أنه على حذف الإرادة. والثاني: أن المعنى: أهلكناها أي: خذلناهم ولم نوِّفقهم فنشأ عن ذلك هلاكهم فعبر بالمسبب عن سببه وهو باب واسع) اهـ وانظر: "تاريخ الطبري" 12/ 300 - 301.في (ب): (هلاكها).في النسخ: (وإذا)، وهو تحريف."تنوير المقباس" 2/ 81هذا قول الجمهور منهم أبو عبيدة في "المجاز" 1/ 210 وابن قتيبة في "تفسير غريب القرآن" 176، والطبري في "تفسيره" 8/ 118، والزجاج في "معانيه" 2/ 317، والسمرقندي 1/ 531، وقال الكرماني في غرائبه 1/ 396: (المفسرون عن آخرهم فسروا <q>﴿بياتا﴾</q> ليلاً) اهـ. وقال السمين في الدر 5/ 250. (قال الواحدي <q>﴿بياتًا﴾</q> أي: ليلاً. وظاهر هذه العبارة أن يكون ظرفًا لولا أن يقال: أراد تفسير معنى) اهـ.ذكره الرازي في "تفسيره" 14/ 21، وفي "تهذيب اللغة" 1/ 250 عن الفراء قال: (باب الرجل إذا سهر الليل كله في طاعة أو معصية). قال الأزهري: (وقوله تعالى <q>﴿فَجَاءَهَا بَأْسُنَا بَيَاتًا﴾</q> أي: ليلاً، والتبييت سمي بيتا لأنه يبات فيه) اهـ. ولم أقف عليه في معاني الفراء."تهذيب اللغة" 1/ 250، و"العين" 8/ 138. وأصل البيت مأوى الإنسان بالليل، ثم يقال للمسكن: بيت من غير اعتبار الليل فيه وجمعه بيوت وهي بالمساكن أخص وأبيات وهي لأبيات الشعر، والبات والتبييت: قصد العدو ليلاً، والبيوت: ما يفعل بالليل، ويقال لكل فعل دبر فيه بالليل: بيت. انظر: "الجمهرة" 1/ 257، و"الصحاح" 1/ 244، و"المجمل" 1/ 139، و"المفردات" ص 151، و"اللسان" 1/ 393، (بيت)."تهذيب اللغة" 1/ 250.لفظ: (يقال) ساقط من (أ)."معاني الزجاج" 2/ 317، وانظر "الزاهر" 1/ 443.انظر: "البسيط" نسخة جستربتي 2/ 12 ب و 22 ب.في "معاني الفراء" 4/ 372: <q>﴿بَيَاتًا أَوْ هُمْ قَائِلُونَ﴾</q>.لفظ: (فاستثقلوا) ساقط من (ب).في (ب): (إذ هو)، وهو تحريف.في (ب): (وأنت).ذكره السمين في "الدر" 5/ 252.لم أقف عليه.في (ب): (لا تحتاج) بالتاء.جاء في النسخ: (كم جاءني)، ولعله تحريف.في "معاني الزجاج" 2/ 317: (جاءني زيد راجلًا أو وهو فارس أو جاءني زيد وهو فارس) اهـ.في (أ): (قال: الواو).انظر: "معاني الزجاج" 2/ 318، وقوله: على تقدير إلى آخره. لم يرد فيه."تهذيب اللغة" 3/ 2861، وانظر: "العين" 5/ 215 (قيل).ذكره أبو حيان في "البحر" 4/ 264، وفي "اللسان" 6/ 3796 قيل: (قال الليث: القيلولة نوم نصف النهار وهي القائلة، قال: يقيل، وقد قال القوم: قيلًا وقائلة وقيلولة ومقالًا ومقيلًا الأخيرة عن سيبويه) اهـ. انظر: "الكتاب" 4/ 89، و"الجمهرة" 2/ 977، و"الصحاح" 5/ 1808، و"المجمل" 3/ 739، و"المفردات" ص 690 (قبل)."تهذيب اللغة" 3/ 2861 ولم يذكر الآية.انظر: "معاني الزجاج" 2/ 318، و"معاني النحاس" 3/ 9.
7,5," قوله تعالى: <q>﴿فَمَا كَانَ دَعْوَاهُمْ﴾</q> قال أهل اللغة: (الدعوى اسم {1} يقوم مقام الادعاء {2} ومقام الدعاء)، حكى سيبويه: (اللهم أشركنا في صالح دعاء المسلمين ودعوى المسلمين) {3} وأنشدوا: وَإِنْ مَذِلَتْ رِجْلِي دَعَوْتُكِ أَشْتَفِي ... بِدَعْوَاكِ منْ مَذْلٍ بِهَا فَيَهُونُ {4} قال ابن عباس في معنى الآية: (فما كان تضرعهم <q>﴿إِذْ جَاءَهُمْ بَأْسُنَا إِلَّا أَنْ قَالُوا إِنَّا كُنَّا ظَالِمِينَ﴾</q> فأقروا على أنفسهم بالشرك) {5}. قال ابن الأنباري: (يريد: فما كان قولهم <q>﴿إِذْ جَاءَهُمْ بَأْسُنَا﴾</q> إلا الاعتراف بالظلم والإقرار بالإساءة) {6} وقوله تعالى: <q>﴿إِلَّا أَنْ قَالُوا﴾</q>. الاختيار عند النحويين أن يكون موضع <q>﴿أَنْ﴾</q> رفعا بكان ويكون الدعوى نصبا {7} كقوله: <q>﴿فَمَا كَانَ جَوَابَ قَوْمِهِ إِلَّا أَنْ قَالُوا﴾</q> [النمل: 56]، وقوله <q>﴿فَكَانَ عَاقِبَتَهُمَا أَنَّهُمَا فِي النَّارِ﴾</q> [الحشر: 17]. وقوله تعالى: <q>﴿مَا كَانَ حُجَّتَهُمْ إِلَّا أَنْ قَالُوا﴾</q> {8} [الجاثية: 25]. ويجوز أن يكون على الضد {9} من هذا بأن يكون الدعوى رفعًا و <q>﴿أَنْ قَالُوا﴾</q> نصبًا كقوله تعالى: <q>﴿لَيْسَ الْبِرَّ أَنْ تُوَلُّوا﴾</q> [البقرة: 177] على قراءة {10} من رفع <q>﴿الْبِرَّ﴾</q> والأصل في هذا الباب أنه إذا {11} اجتمع بعد كان معرفتان فأنت مخير في أن ترفع {12} أحدهما وتنصب الآخر كقولك: كان زيدٌ أخاك، وإن شئت كان زيدًا أخوك. قال الزجاج: (إلا أن الاختيار إذا كانت الدعوى في موضع رفع أن يقول: فما كانت في دعواهم، فلما قال: <q>﴿كَانَ﴾</q> دل أن الدعوى في موضع نصب غير أنه يجوز تذكير الدعوى، وإن كانت رفعًا فتقول: كان دعواه [باطلًا] {13} وباطلة) {14}. وما حكينا من القولين في موضع الدعوى من الإعراب معنى قول الفراء {15} والزجاج {16}. قوله تعالى: <q>﴿فَلَنَسْأَلَنَّ الَّذِينَ أُرْسِلَ إِلَيْهِمْ﴾</q> [الأعراف: 6] قال عطاء عنه: (يُسأل الناس جميعًا عما أجابوا المرسلين، ويُسأل المرسلون عما بلغوا) {17}. وقال ابن عباس: (يسأل الأمم عما جاءهم من الله، ويسأل {18} النبيين هل بلغتم رسالتي) {19}. وقال الضحاك: (<q>﴿الَّذِينَ أُرْسِلَ إِلَيْهِمْ﴾</q> الأمم الذين أتاهم الرسل يُسألون هل بلغكم الرسل ما أرسلوا به إليكم، <q>﴿وَلَنَسْأَلَنَّ الْمُرْسَلِينَ﴾</q> يعني: الأنبياء هل بلغتم قومكم ما أرسلتم به وماذا أجابكم قومكم) {20}. وقال السدي: (نسأل {21} الأمم ماذا عملوا فيما جاءت به الرسل، ونسأل الرسل هل بلغوا ما أرسلوا به) {22}. ",footnotes:1:الدعوى -بفتح الدال وسكون العين-، والادعاء -بكسر الدال وفتح العين-، والدعاء -بضم الدال وفتح العين-، انظر: "العين" 2/ 221، و"الجمهرة" 2/ 666 و 1059، و"الصحاح" 6/ 2336، و"المجمل" 2/ 326، و"المفردات" ص 316، و"اللسان" 3/ 1385 (دعا).في (ب): (الإدغام)، وهو تحريف."تهذيب اللغة" 2/ 1188، وفي "الكتاب" 4/ 40، قال: (الدعوى ما ادعيت، وقال بعض العرب: اللهم أشركنا في دعوى المسلمين) اهـ.الشاهد لكثير عزة في "ديوانه" ص 227، وبلا نسبة في "تفسير الطبري" 8/ 120، و"تهذيب اللغة" 4/ 3367، و"تفسير الثعلبي" 187 ب، و"المخصص" 5/ 84، و"تفسير ابن عطية" 5/ 428، وابن الجوزي 3/ 169، و"اللسان" 7/ 4164 (مذل) "الدر المصون" 5/ 254، وفي "الديوان": إذا خدِرَتْ رجلي ذكرتكِ أشتفي ... بذكركِ من مذل بها فيهونُ ومذلت رجله - بفتح الميم وكسر الذال أي: خدرت، انظر: "اللسان" 7/ 4164 (مذل).ذكره الرازي في "تفسيره" 14/ 21، وأبو حيان في "البحر" 4/ 269، وانظر "تنوير المقباس" 2/ 81، وفيه: (دعواهم - قولهم).ذكره الواحدي في "الوسيط" 1/ 157، وابن الجوزي في "تفسيره" 3/ 168، والرازي 14/ 21.فدعواهم: خبر مقدم و <q>﴿إِلَّا أَنْ قَالُوا﴾</q> اسم كان مؤخر. وهو اختيار الفراء في "معانيه" 1/ 372، والزجاج 2/ 319، والنحاس في "إعراب القرآن" 1/ 600، والزمخشري في "الكشاف" 2/ 67، وابن عطية في "تفسيره" 5/ 424، قال الهمداني في "الفريد" 2/ 270: (وهذا أحسن حملًا على ما ورد من نظائره في التنزيل) اهـ.في النسخ: (ومكان) بالواو وهو تحريف.هذا قول مكي في "المشكل" 1/ 282، والعكبري في "التبيان" ص 369، واختاره أبو حيان في "البحر" 4/ 269.قرأ حمزة وعاصم في رواية: <q>﴿لَيْسَ الْبِرَّ﴾</q> -بفتح الراء-، وقرآ الباقون <q>﴿البرُ﴾</q> == بالرفع فمن رفع جعل <q>﴿البر﴾</q> اسم ليس و <q>﴿أن تولوا﴾</q> الخبر، ومن نصب جعل <q>﴿البر﴾</q> خبر مقدم و <q>﴿أن تولوا﴾</q> اسم (ليس). انظر: "السبعة" ص 176، و"الحجة" لأبي علي 2/ 270، و"المشكل" 1/ 117.انظر "الحجة" لأبي علي 2/ 270.في (ب): (يرفع أحدهما وينصب) بالياء.لفظ: (باطلاً) ساقط من (ب).انظر: "معاني الزجاج" 2/ 319، وعليه يكون تذكير الفعل قرينة مرجحة لإسناد الفعل إلى (أن قالوا) ولو كان مسندا للدعوى لكان الأرجح (كانت أفاده). السمين في "الدر" 5/ 254.انظر: "معاني الفراء" 1/ 372.انظر: "معاني الزجاج" 2/ 319.أخرجه الطبري في "تفسيره" 8/ 121، وابن أبي حاتم 5/ 1439 بسند جيد، وذكره السيوطي في "الدر" 3/ 126.في (أ): (نسأل الأمم .. ونسأل النبيين) بالنون.انظر: "تنوير المقباس" 2/ 81، و"تفسير البغوي" 3/ 214، وابن الجوزي 3/ 169.ذكره الواحدي في "الوسيط" 1/ 157.في (ب): (يسال) بالياء.أخرجه الطبري في "تفسيره" 8/ 121، بسند جيد.
  7,6,""
7,7," قوله تعالى: <q>﴿فَلَنَقُصَّنَّ عَلَيْهِمْ بِعِلْمٍ﴾</q> [الأعراف: 7] قال الضحاك: (لنخبرنهم بما عملوا بعلم منا <q>﴿وَمَا كُنَّا غَائِبِينَ﴾</q> عن الرسل والأمم ما بلغت وما رد عليهم قومهم) {1}. وقال ابن عباس: (<q>﴿فَلَنَقُصَّنَّ عَلَيْهِمْ بِعِلْمٍ﴾</q> ينطق لهم كتاب أعمالهم؛ يقول الله: <q>﴿هَذَا كِتَابُنَا يَنْطِقُ عَلَيْكُمْ بِالْحَقِّ﴾</q>) {2} [الجاثية: 29]. ",footnotes:1:ذكره بدون نسبة الواحدي في "الوسيط" 1/ 158، والبغوي 3/ 214، وابن الجوزي 3/ 169.أخرجه الطبري في "تفسيره" 8/ 122، وابن أبي حاتم 5/ 1440، بسند ضعيف.
7,8," قوله تعالى: <q>﴿وَالْوَزْنُ يَوْمَئِذٍ الْحَقُّ﴾</q> يعني: يوم السؤال <q>﴿وَالْوَزْنُ﴾</q> ابتداء، وخبره <q>﴿الْحَقُّ﴾</q> {1} وابن عباس {2} وعامة المفسرين {3} على أن المراد بهذا الوزن أعمال العباد. قال ابن الأنباري: (أكد الله به الاحتجاج على العباد وقطع به عذرهم وبين به {4} لهم عدله وأنه لا يظلم أحدًا) {5}. وقوله تعالى: <q>﴿فَمَنْ ثَقُلَتْ مَوَازِينُهُ﴾</q> ورد الخبر (أن الله تعالى ينصب ميزانا له لسان وكفتان يوم القيامة فتوزن {6} به أعمال العباد خيرها وشرها) {7}. قال ابن عباس: (يوزن الحسنات والسيئات في ميزان له لسان وكفتان فأما المؤمن فيؤتى بعمله في أحسن صورة فيوضع في كفة الميزان فتثقل {8} حسناته على سيئاته، فذلك قوله: <q>﴿فَمَنْ ثَقُلَتْ مَوَازِينُهُ فَأُولَئِكَ هُمُ الْمُفْلِحُونَ﴾</q> الناجون، قال: وهذا كما قال في سورة الأنبياء: <q>﴿وَنَضَعُ الْمَوَازِينَ الْقِسْطَ لِيَوْمِ الْقِيَامَةِ فَلَا تُظْلَمُ نَفْسٌ شَيْئًا﴾</q>) {9} [الأنبياء: 47]. وقال مقاتل: (<q>﴿وَالْوَزْنُ يَوْمَئِذٍ الْحَقُّ﴾</q> وزن الأعمال يومئذ العدل <q>﴿فَمَنْ ثَقُلَتْ مَوَازِينُهُ﴾</q> من المؤمنين وزن ذرة على سيئاته <q>﴿فَأُولَئِكَ هُمُ الْمُفْلِحُونَ﴾</q>) {10}. فأما كيفية وزن الأعمال فله وجهان: أحدهما: أن أعمال المؤمن تتصور في صورة حسنة، وأعمال الكافر تتصور في صورة قبيحة فتوزن تلك الصورة كما ذكره ابن عباس. والثاني: أن الوزن يعود إلى الصحف التي فيها أعمال العباد مكتوبة، وسئل رسول الله ﷺ عما يوزن {11} يوم القيامة، فقال: "الصحف" {12}. هذا الذي ذكرنا مذهب عامة المفسرين {13} وأهل العلم في هذه الآية، وكان مجاهد والضحاك والأعمش {14} يفسرون الوزن والميزان: (العدل والقضاء) ويذهبون إلى أن هذا تمثيل وتحقيق للقسط والعدل يومئذٍ، فقال مجاهد: (<q>﴿وَالْوَزْنُ يَوْمَئِذٍ الْحَقُّ﴾</q> والقضاء {15} يومئذٍ العدل) {16}. وروى جويبر {17} عن الضحاك (أن الميزان العدل) {18}. فعلى مذهب هؤلاء: الوزن والميزان عبارة عن العدل كما تقول: هذا الكلام في وزن هذا وفي وزانه أي: أنه يعادله ويساويه وليس هناك وزن في الحقيقة، وقد قال الشاعر: قَدْ كُنْتُ قَبْلَ لقائِكُمُ ذا مِرَّةٍ ... عِنْدى لكلِّ مُخَاصِمٍ ميزانُه {19} أراد: عندي لكل مخاصم كلام يُعادل كلامه؛ فجعل الوزن مثلًا للعدل، والميزان مثلا للكتاب الذي فيه أعمال العباد من حيث أنه لا يزيد {20} فيه ولا يكذب ويخبر بما له وما عليه، فكنى عن الكتب بالموازين، وجعل ما يكثر في الكتاب من الحسنات بمنزلة ما يثقل في الميزان. قال أبو إسحاق: (وهذا كله في باب اللغة والاحتجاج سائغ {21}، والأولى من هذا {22} أن يتبع ما جاء في الأسانيد الصحاح من ذكر الميزان) {23}. وقال ابن الأنباري: (والقول الأول هو اختيارنا لتتابع الأخبار به واتفاق أكثر أهل العلم عليه ولشهادة ظاهر القرآن له، قال: وإنما جمع الله تعالى فقال: <q>﴿فَمَنْ ثَقُلَتْ مَوَازِينُهُ﴾</q> ولم يقل: ميزانه من أجل أن العرب توقع الجمع على الواحد فيقولون: خرج إلى البصرة في السفن، وخرج إلى مكة على البغال. قال: ويجوز أن يكون جمع الميزان إذ {24} كانت <q>﴿مَنْ﴾</q> في معنى {25} جمع فصرف الكلام إلى معنى <q>﴿مَنْ﴾</q> يدل على صحة هذا قوله: <q>﴿فَأُولَئِكَ هُمُ الْمُفْلِحُونَ﴾</q> بالجمع تغليبًا لمعنى <q>﴿مَنْ﴾</q> على لفظه) {26}. وقال غيره: (الموازين هاهنا جمع موزون لا جمع ميزان وأراد بالموازين الأعمال الموزونة) {27}. ",footnotes:1:انظر "معاني الفراء" 1/ 373، و"إعراب النحاس" 1/ 600، و"المشكل" 1/ 282.يأتي تخريجه فيما بعد.ذكره مثله الواحدي في "الوسيط" 1/ 158، والبغوي في "تفسيره" 3/ 214، وأخرجه الطبري في "تفسيره" 80/ 122، عن عمرو بن دينار والسدي.لفظ: (به) ساقطة من (ب).لم أقف عليه: وقال ابن الجوزي في زاد المسير 3/ 171 (في الميزان خمسة حكم - أحدها: امتحان الخلق بالإيمان بذلك في الدنيا، والثانية: إظهار علامة السعادة والشقاوة في الآخرة، والثالثة: تعريف العباد ما لهم من خير وشر، والرابعة: إقامة "الحجة" عليهم، والخامسة: الإعلام بأن الله عادل لا يظلم) اهـ.في (ب): (فيوزن) بالياء.لم أقف عليه بهذا اللفظ وهو مشهور من قول ابن عباس، وسيأتي تخريجه. وقال الزجاج في "معانيه" 2/ 319: (الأولى من هذا أن يتبع ما جاء بالأسانيد الصحاح فإن جاء في الخبر أنه ميزان له كفتان من حيث ينقل أهل الثقة فينبغي أن يقبل ذلك) اهـ.في (ب): (فيثقل) بالياء.ذكره السمرقندي في "تفسيره" 1/ 531 والثعلبي 187 ب، والواحدي في "الوسيط" 1/ 158، والبغوي في "تفسيره" 3/ 315، وابن الجوزي 3/ 171، والرازي 14/ 24، والقرطبي 7/ 166، وغيرهم، وذكره السيوطي في "الدر" 8/ 129، 130، وقال: (أخرجه البيهقي في شعب الإيمان وأخرجه أبو الشيخ عن الكلبي عن أبي صالح عن ابن عباس) اهـ."تفسير مقاتل" 2/ 30.في (ب): (ما يوزن).لم أقف عيه.قال الحافظ ابن كثير في "تفسيره" 2/ 226: (يمكن الجمع بين الآثار الواردة في ذلك بأن يكون ذلك كله صحيح فتارة توزن الأعمال وتارة توزن محالها وتارة يوزن فاعلها والله أعلم). وانظر: "فتح الباري" 13/ 537 - 540.ذكره الرازي في "تفسيره" 8/ 25، والقرطبي 7/ 165، وأبو حيان في "البحر" 4/ 270 عن الأعمش.لفظ: (الواو) ساقطة من (ب).أخرجه الطبري في "تفسيره" 8/ 122، وابن أبي حاتم 5/ 1440 بسند جيد.جويبر -تصغير جابر-: جويبر بن سعيد الأزدي. ضعيف، تقدمت ترجمته.ذكره الزجاج في "معانيه" 2/ 319، والأزهري في "تهذيب اللغة" 4/ 3886، والرازي في "تفسيره" 8/ 25، والقرطبي 7/ 165، وأبو حيان في "البحر" 4/ 270.لم أهتد إلى قائله، وهو في تفسير ابن الجوزي 3/ 170، والرازي 14/ 25، و"اللسان" 8/ 4829 (وزن).في (أ): (لا تزيد فيه ولا تكذب).في (ب): (شائع) وقال القرطبي في "التذكرة" ص 364: (وهذا القول مجاز وليس بشيء وإن كان شائعًا في اللغة للسنة الثابتة في الميزان الحقيقي ووصفه بكفتين ولسان وإن كل كفة منهما طباق السموات والأرض) اهـ. وقال أيضًا في "تفسيره" 7/ 165: (قد أجمعت الأمة في الصدر الأول على الأخذ بهذه الظواهر من غير == تأويل، وإذا أجمعوا على منع التأويل وجب الأخذ بالظاهر وصارت هذه الظواهر نصوصًا) اهـ. ونحوه ذكر ابن عطية في "تفسيره" 5/ 432، والشوكاني 2/ 277، وصديق خان 4/ 305، والقاسمي 7/ 2617.في (ب): (والأولى أن يتبع من هذا).انظر: "معاني الزجاج" 2/ 319.في (ب): (إذا).في (ب): (موضع).ذكره بدون نسبة الواحدي في "الوسيط" 1/ 158، وذكره الرازي في "تفسيره" 14/ 26 عن الزجاج، وانظر: "معاني الفراء" 1/ 373، و"تفسير الطبري" 8/ 123.انظر: "تفسير البغوي" 3/ 216، و"الرازي" 14/ 27، و"الدر المصون" 5/ 256.
7,9," قوله تعالى: <q>﴿وَمَنْ خَفَّتْ مَوَازِينُهُ﴾</q>. قال مقاتل: (يعني: الكفار) {1}. قال ابن عباس: (يؤتى بعمل الكفار في أقبح سورة، فيوضع في كفة الميزان، فيخف وزنه حتى يقع في النار، ثم يقال للكافر: الحق بعملك، ثم قال: وحق لميزان لا يكون فيها رضوان الله أن يخف، وأما المؤمن فإذا خفت حسناته ثقلت بكتاب كالأنملة {2} فيه شهادة أن لا إله إلا الله وأن محمدًا عبده ورسوله فترجح حسناته على سيئاته) {3}. وروي أيضًا: (أنه إذا خفت حسنات المؤمن أخرج رسول الله ﷺ من حجزته {4} بطاقة {5} كالأنملة، فيلقيها في كفة الميزان اليمنى التي فيها حسناته فترجح الحسنات، فيقول ذلك العبد المؤمن للنبي ﷺ: بأبي أنت وأمي ما أحسن وجهك وأحسن خلقك فمن أنت؟ فيقول: أنا نبيك محمد، وهذه صلواتك {6} التي كنت تصلي علي، قد {7} وفيتك أحوج ما تكون إليها) {8}. وقوله تعالى: <q>﴿فَأُولَئِكَ الَّذِينَ خَسِرُوا أَنْفُسَهُمْ﴾</q>، قال ابن عباس: (يريد: صاروا إلى العذاب <q>﴿بِمَا كَانُوا بِآيَاتِنَا يَظْلِمُونَ﴾</q>، قال: يريد: يجحدون بما جاء به محمد ﷺ) {9}. ",footnotes:1:"تفسيرمقاتل" 2/ 30.الأنملة -مثلثة الهمزة والميم- المفصل الأعلى الذي فيه الظفر من الإصبع والجمع أنامل وأنملات وهي رؤوس الأصابع. انظر: "اللسان" 8/ 4550 (نمل).سبق تخريجه.حُجْزته، بضم الحاء وسكون الجيم: أصلها موضع شد الإزار، ثم قيل للإزار: حُجْزة للمجاورة، وحجزة الإزار جنبته ومعقد الإزار. انظر: "النهاية" 1/ 344، و"اللسان" 2/ 786 (حجر).البطاقة، بالكسر: الورقة ورقعة صغيرة يثبت فيها مقدار ما يجعل فيها إن كان عينًا فوزنه أو عدده وإن كان متاعًا فقيمته، والرقعة الصغيرة تكون في الثوب وفيها ثمنه. انظر: "النهاية" 1/ 135، و"اللسان" 1/ 302 (بطق).في (ب): (صلاتك).في (ب): (وقد).ذكره الرازي في "تفسيره" 8/ 25، وقال: (رواه الواحدي في "البسيط") اهـ. == وذكره القرطبي في "تفسيره" 7/ 167. وفي "التذكرة" ص 361، وقال: (ذكره القشيري في "تفسيره") اهـ. وحديث البطاقة مشهور. أخرجه الإمام أحمد في "المسند" 2/ 213 - و- 221 - 223، وابن ماجه (4300) كتاب الزهد، باب: ما يرجى من رحمة الله تعالى، والترمذي حديث (2639) كتاب الإيمان، باب: ما جاء فيمن يموت وهو يشهد أن لا إله إلا الله، والحاكم في "المستدرك" 1/ 6 - و- 529 - عن عبد الله بن عمرو رضي الله عنه قال: قال رسول الله: "توضع الموازين يوم القيامة فيؤتى بالرجل فيوضع في كفة فيوضع ما أحصى عليه فتمايل به الميزان، قال: فيبعث به إلى النار: قال: فإذا أدبر به إذا صائح يصيح من عند الرحمن يقول: لا تعجلوا لا تعجلوا فإنه قد بقي له فيؤتى ببطاقة فيها لا إله إلا الله فتوضع مع الرجل في كفة حتى يميل به الميزان" اهـ. لفظ أحمد، قال الترمذي: (هذا حديث حسن غريب) اهـ. وقال الحاكم: (هذا حديث صحيح على شرط مسلم ولم يخرجاه) اهـ. ووافقه الذهبي في "التلخيص"، وقال السيوطي في "الدر" 8/ 131، والشوكاني في "تفسيره" 2/ 278، وصديق خان 3/ 307: (إسناده عند أحمد حسن) اهـ. وصححه الشيخ الألباني في سلسلة الأحاديث الصحيحة 1/ 43، رقم 135.ذكره الواحدي في "الوسيط" 1/ 159 ولم أقف عليه عند غيره.
7,10," قوله تعالى: <q>﴿وَلَقَدْ مَكَّنَّاكُمْ فِي الْأَرْضِ﴾</q>، قال الزجاج: (معنى التمكين في الأرض: التمليك والقدرة) {1}، وهو قول ابن عباس قال: (يريد: ملكناكم {2} في الأرض، يريد: ما بين مكة إلى اليمن، وما بين مكة إلى الشام) {3}. وقولى تعالى: <q>﴿وَجَعَلْنَا لَكُمْ فِيهَا مَعَايِشَ﴾</q>، يقال: عاش يعيش عيشا ومعاشًا ومعيشة وعيشة ومعيشا بغير هاء {4} ومنه قول رؤبة: إليك أشكو شِدَّةَ المَعِيشِ {5} قال الليث: (العيش: المطعم والمشرب {6} وما يكون به الحياة، والمعيشة: ما يعاش به) {7}، [وقال الزجاج: (ومعنى المعايش: يحتمل أن يكون ما يعيشون به] {8} ويمكن أن يكون الوصلة إلى ما يعيشون به) {9}. وقد أشار ابن عباس إلى المعنين اللذين ذكرهما الزجاج فقال في قوله: <q>﴿وَجَعَلْنَا لَكُمْ فِيهَا مَعَايِشَ﴾</q> (يريد: بما أفضل عليكم في الرزق وما فضلكم به على العرب، وهو أنهم ينسبون إلى الله وإلى حرمه وأمنه والعرب لهم تبع) {10} فقوله: (بما أفضل عليكم في الرزق) إشارة إلى [الوصلة] {11} إلى ما يعيشون به؛ لأنهم بذلك التفضيل توصلوا إلى المكاسب والتجارات، وعلى ما ذكره ابن عباس من التفسير تكون الآية خطابًا لقريش. فأما القراءة {12} في المعايش فقال الفراء: (لا تهمز لأنها في الواحدة مفعلة الياء في الفعل فلذلك لم يهمز وإنما يهمز من هذا ما كانت الياء فيه زائدة، مثل: مدينة ومدائن، وقبيلة وقبائل، لما كانت الياء لا يعرف لها أصل ثم قارنتها ألف مجهولة أيضًا همزت. قال: ومثل معايش من الواو [مما لا يهمز (معاون) في جمع معونة، و (مناور) في جمع منارة، وذلك أن الواو] {13} ترجع {14} إلى أصلها لسكون الألف قبلها) {15} هذا مذهب جميع القراء في المعايش لا يهمزونها، وروى خارجة {16} عن نافع <q>﴿معائش﴾</q> بالهمز {17}. قال الفراء: (ربما همزت العرب هذا وشبهه يتوهمون أنها فعيلة لشبهها بوزنها في اللفظ وعدة الحروف كما جمعوا مسيل الماء أمسلة {18} شبه بفعيل وهو مفعل) {19}. وقال أبو إسحاق: (جميع النحويين البصريين يزعمون أن همز <q>﴿مَعَايِشَ﴾</q> خطأ، وذكروا أن الهمز إنما يكون في هذه الياء إذا كانت زائدة نحو: صحيفة وصحائف، فأما <q>﴿مَعَايِشَ﴾</q> فمن العيش الياء أصلية، فأما ما {20} رواه نافع من همز <q>﴿مَعَايِشَ﴾</q> فلا أعرف له وجهًا إلا أن لفظ هذه الياء التي من نفس الكلمة أسكن في معيشة فصار على لفظ صحيفة فحمل الجمع على ذلك، ولا أحب القراءة بالهمز) {21}. قال أبو علي الفارسي: (قوله: <q>﴿مَعَايِشَ﴾</q> العين منه ياء ووزن المعيشة من الفعل عند الخليل {22} وسيبويه مَفْعِلة، (وكان الأصل مَعْيِشة إلا أن الاسم وافق الفعل في وزنه؛ لأن (معيش) على وزن (يعيش) فأعل كما أعل الفعل وقد وجدنا الاسم إذا وافق الفعل في البناء أعل كما يعل {23} فمن ذلك إعلالهم لباب ودار ونار ونحوه، لما كان على وزن فعل أعل كما أعل فأما القراءة {24} في المعايش فقال الفراء: (لا تهمز لأنها في الواحدة مفعلة الياء في الفعل فلذلك لم يهمز وإنما يهمز من هذا ما كانت الياء فيه زائدة، مثل: مدينة ومدائن، وقبيلة وقبائل، لما كانت الياء لا يعرف لها أصل ثم قارنتها ألف مجهولة أيضًا همزت. قال: ومثل معايش من الواو [مما لا يهمز (معاون) في جمع معونة، و (مناور) في جمع منارة، وذلك أن الواو] {13} ترجع {14} إلى أصلها لسكون الألف قبلها) {15} هذا مذهب جميع القراء في المعايش لا يهمزونها، وروى خارجة {16} عن نافع <q>﴿معائش﴾</q> بالهمز {29}. وجميع {30} المتقدمين من النحويين البصريين. فإذا جمع معيشة مكسرًا ردت ألف الجمع ثالثة قبل الياء والألف ساكنة والياء أيضًا ساكنة، ومن حكم الساكنين إذا اجتمعا أن يحرك أحدهما أو يحذف، فالحذف هنا لا يجوز لالتباس الجمع بالواحد، وإذا لم يجز الحذف لاجتماعهما لزم تحريك أحدهما ، ولا يخلو من أن يكون الأول {31} أو الثاني، فلا يجوز تحريك الأول لارتفاع دلالته بتحريكه له على الجمع وإذا لم يجز تحريك الأول لزم تحريك الثاني لاجتماع الساكنين، فإذا حركت رجعت {32} ياء كما أن ما كان من الواو إذا {33} حركت في الجمع رجعت واوًا صحيحة مثل: (مقاوم) و (مقاول) في جمع (مقام) و (مقال)، أنشد النحويون {34}: وإنَّي لَقَوَّامُ مقاوم لَمْ يَكُنْ ... جَرِيرٌ وَلاَ مَوْلَى جَرِيرٍ يَقُومُهَا فصحح الواو في الجمع لما لزم تحريكها لاجتماع الساكنين، فبان بهذا أن جمع (معيشة) على (معايش) يزيل مشابهته الفعل في البناء وعلمت بذلك زوال المعنى الموجب للإعلال في الواحد {35} فيلزم التصحيح في التكسير لزوال المشابهة في اللفظ. فإن قيل: هل أعل العين إذا كانت ياء أو واوًا في نحو هذا الجمع كما أعلت في قائل وبائع بقلبها همزة لما اعتلا في الفعل؟ والجواب أن إعلال (معايش) لا يلزم؛ لأن زنة الفعل قد بطلت عنه ولزم {36} تصحيحه كما بينا، فأما قائل وبائع فإنما لزم إعلالها؛ لمشابهتهما الفعل في الزنة وهو الأمر {37} من المفاعلة، ولأنهما يعملان عمل الفعل، فصار لذلك أدخل في الإعلال وأقرب إليه، ولم يكن ذلك في (معايش) وبابه، ألا ترى أنه لا شيء فيه مما يوجب الإعلال من مشابهته الفعل في زنته وحركاته وسكونه) {38}. وقال غير أبي علي [في] {39} علة همز قايل وبايع: (إنما همز عين فاعل في باب ما اعتلت عينه من ذوات الواو والياء؛ لأن الواو والياء قد انقلبتا ألفين في قال وباع، فلما بني منهما فاعل اجتمعت ألف فاعل مع الألف المنقلبه عن الواو {40} أو الياء وهما ساكنتان فلم يمكن النطق بهما فهمزت الأخيرة منهما فقيل: قائل وبائع هذا هو الأصل، ثم يجور تحفيف الهمزة فيصير ياء؛ لأن الهمزة المكسورة إذا خففت صارت ياء {41}. فأما (معايش) ففي تصحيح يائه ما يغني عن الهمزة) رجعنا إلى كلام أبي علي قال: (فأما قراءة هذا القارئ <q>﴿معائش﴾</q> بالهمز، فقال أبو عثمان: (أصل أخذ هذه القراءة عن نافع قال: ولم يكن يدري ما {42} العربية، وكلام العرب التصحيح في نحو هذا) {43}. قال أبو علي: ومن أعل فهمز ياء <q>﴿مَعَايِشَ﴾</q> فمجازه على وجه الغلط كما حكى سيبويه (أن بعضهم قال في جمع مصيبة: مصائب فهمز وهو غلط لأن مصائب مفاعل {44} فتوهمها فعايل نحو: صحائف وسفائن. قال: ومنهم من يقول: مصاوب فيجيء به على الأصل والقياس) {45}، وقول {46} سيبويه: (وهو غلط) يعني: أنه توهم الياء التي في مصيبة -وهي {47} منقلبة عن العين التي هي واو- الياء التي {48} للمد في نحو: [سفينة وصحيفة، وهمزوا الياء المنقلبة عن الواو التي هي عين الفعل كما همزوا الياء التي للمد {13} في نحو] {50} سفائن وصحائف، ولا يشبه هذه الياء تلك، ألا ترى أن هذه منقلبة عن واو هي عين أصلها الحركة، وتلك زائدة للمد لا حظ لها في الحركة). وقد ذكرنا الكلام مستقصى في المصائب عند قوله {51}: <q>﴿الَّذِينَ إِذَا أَصَابَتْهُمْ مُصِيبَةٌ﴾</q> [البقرة: 156]، (ومثل هذا مما حمل على الغلط قول بعضهم في جمع مَسِيل: مسلان، فمسيل مفعل والياء فيه عين الفعل، فتوهم من قال في جمعه: مسلان أنها زائدة للمد فجمعه على فعلان كما يجمع قضيب على قضبان، وعلى هذا {52} التوهم أيضًا جمعوا مسيلًا أمسلة. وقد جاء ذلك في شعر هذيل، قال أبو ذؤيب {53}: وَأَمْسِلَةٍ مَدَافِعُها خَلِيفُ {54} فتوهموه فعيلاً، وإنما هو مفعل {55}، ومثل هذا من الشواذ والغلط لا يعترض به على الشائع المطرد ولا يحمل غيره عليه، وإنما حكمه أن يعرف أصله ويبين وجه الصواب فيه، ومن أين وقع الشبه الذي جاء من أجله الغلط، فمسلان من سأل خطأ وإن كان قد قيل، فكذلك {56} همز {57} معايش غلط) {58}، فأما الكلام في (مدائن) فسنذكره إذا أتينا إلى قوله: <q>﴿وَأَرْسِلْ فِي الْمَدَائِنِ حَاشِرِينَ﴾</q> {59} [الأعراف: 111] من هذه السورة {60} إن شاء الله. وقوله تعالى: <q>﴿قَلِيلًا مَا تَشْكُرُونَ﴾</q>، قال ابن عباس: (يريد: أنكم غير شاكرين لأنعمي {61} [ولا] طائعين) {62}. وتقدير هذا تقدير قوله: {قَلِيلًا مَا تَذَكَّرُونَ} [الأعراف: 3]. [وقد مر] {63}. ",footnotes:1:"معاني القرآن" للزجاج 2/ 320، وانظر: "تفسير الطبري" 8/ 125، و"معاني النحاس" 3/ 11.في (ب): (مكناكم)."تنوير المقباس" 2/ 81 - 82، وذكره الواحدي في "الوسيط" 1/ 160.النص من "تهذيب اللغة" 3/ 2281، وانظر: "اللسان" 5/ 3190 (عيش)."ديوانه" ص 78، و"الزاهر" 1/ 250، والقرطبي 3/ 81، و"الدر المصون" 2/ 420، 5/ 258، وتمامه: ومر أعوام نتفن ريشي أي أذهبن مالي، وفي "الديوان": أَشْكُو إِلَيْك شِدَّةَ المعَيشِ ... دهرًا تنقَّى المُخَ بِالتَمشِيشِفي (ب): (والمشروب)."تهذيب اللغة" 3/ 2281، وانظر: "العين" 2/ 189، و"الجمهرة" 2/ 872، و"الصحاح" 3/ 1512، و"المجمل" 2/ 639، و"مقاييس اللغة" 4/ 194، و"المفردات" ص 596 (عيش).ما بين المعقوفين ساقط من (أ)."معاني الزجاج" 2/ 320، ومثله ذكر النحاس في "معانيه" 3/ 11.في "تنوير المقباس" 2/ 82 نحوه.لفظ: (الوصلة) ساقط من (أ).قرأ الجمهور <q>﴿معايش﴾</q> بالياء، وقرأ عبد الرحمن بن هرمز الأعرج - وزيد بن علي، والأعمش، وخارجة بن مصعب عن نافع، وابن عامر في رواية: <q>﴿معائش﴾</q> بالهمز، والقياس بدون همز؛ لأن الياء أصل وإذا كانت زائدة همزت مثل صحيفة وصحائف. لكن قال الفراء في "معانيه" 1/ 373: (وربما همزت العرب هذا وشبهه يتوهمون أنها فعيلة بشبهها بوزنها في اللفظ وعدة الحروف كما جمعوا مسيل الماء أمسله شبه بفعيل وهو مفعل وقد همزت العرب المصائب وواحدتها مصيبة، شبهت بفعيلة لكثرتها في الكلام) اهـ. وقال أبو حيان في "البحر" 4/ 271: (رواها عرب فصحاء ثقات فوجب قبولها، وقد ردها نحاة البصرة ولسنا متعبدين بأقوال نحاة البصرة) اهـ. بتصرف. وانظر: "السبعة" ص 278، و"إعراب النحاس" 1/ 600، و"معرفة القراءات" 1/ 400، و"إعراب القراءات" 1/ 176، و"مختصر الشواذ" ص 48، و"المبسوط" ص 179، و"الدر المصون" 5/ 258.ما بين المعقوفين ساقط من (ب).في (ب): (فترجع)."معاني الفراء" 1/ 273.خارجة بن مُصْعَب بن خارجة الضبعي أبو الحجاج الخراساني، فقيه، مقرئ، متروك الحديث. أخذ القراءة عن نافع وغيره، وله شذوذ كثير عنه لم يتابع عليه، توفي سنة 168 هـ وله 98 سنة. انظر: "الجرح والتعديل" 3/ 375، و"ميزان الاعتدال" 1/ 625، و"غاية النهاية" 1/ 268، و"تهذيب التهذيب" 1/ 512.ذكرها أكثرهم كما في المراجع السابقة في فقرة رقم (2).في (أ): (مسله) وهو تحريف."معاني الفراء" 1/ 373 - 374.في (ب): (فأما رواه)، وهو تحريف."معاني الزجاج" 2/ 320 - 321، وانظر: "إعراب النحاس" 1/ 600، 601، و"المشكل" 1/ 283 - 284.في "الكتاب" 4/ 349، وكذا في "الإغفال" ص730 (فمعيشة يصلح أن تكون مَفْعلُة -بفتح الميم وسكون الفاء وضم العين-، أو -مفعلة- بكسر العين) اهـ. وانظر "الكتاب" 4/ 349، وص 355.في (ب): (كما يعل الفعل)، ثم تكرر قوله: (وقد وجدنا) إلى قوله: (كما يعل).قرأ الجمهور <q>﴿معايش﴾</q> بالياء، وقرأ عبد الرحمن بن هرمز الأعرج - وزيد بن علي، والأعمش، وخارجة بن مصعب عن نافع، وابن عامر في رواية: <q>﴿معائش﴾</q> بالهمز، والقياس بدون همزة لأن الياء أصل وإذا كانت زائدة همزت مثل صحيفة وصحائف. لكن قال الفراء في "معانيه" 1/ 373: (وربما همزت العرب هذا وشبهه يتوهمون أنها فعيلة بشبهها بوزنها في اللفظ وعدة الحروف كما جمعوا مسيل الماء أمسله شبه بفعيل وهو مفعل وقد همزت العرب المصائب وواحدتها مصيبة، شبهت بفعيلة لكثرتها في الكلام) اهـ. وقال أبو حيان في "البحر" 4/ 271: (رواها عرب فصحاء ثقات فوجب قبولها، وقد ردها نحاة البصرة ولسنا متعبدين بأقوال نحاة البصرة) اهـ. بتصرف. وانظر: "السبعة" ص 278، و"إعراب النحاس" 1/ 600، و"معرفة القراءات" 1/ 400، و"إعراب القراءات" 1/ 176، و"مختصر الشواذ" ص 48، و"المبسوط" ص 179، و"الدر المصون" 5/ 258.ما بين المعقوفين ساقط من (ب).في (ب): (فترجع)."معاني الفراء" 1/ 273.خارجة بن مُصْعَب بن خارجة الضبعي أبو الحجاج الخراساني، فقيه، مقرئ، متروك الحديث. أخذ القراءة عن نافع وغيره، وله شذوذ كثير عنه لم يتابع عليه، توفي سنة 168 هـ وله 98 سنة. انظر: "الجرح والتعديل" 3/ 375، و"ميزان الاعتدال" 1/ 625، و"غاية النهاية" 1/ 268، و"تهذيب التهذيب" 1/ 512.ذكرها أكثرهم كما في المراجع السابقة في فقرة رقم (2).= و"معجم الأدباء" 7/ 107، و"سير أعلام النبلاء" 12/ 270، و"لسان الميزان" 2/ 57.انظر: "المنصف" 7/ 107، و"المقتضب" 1/ 261.لفظ: (الأول) غير واضح في (أ)، وفي (ب): (الأول والثاني).في (أ): (رجعت واوًا صحيحة ياء كما أن).في (أ): (وإذا).الشاهد للأخطل في "ديوانه" ص 322، و"أمالي القالي" 3/ 77، و"الخصائص" 3/ 145، وللفرزدق في "المقتضب" 1/ 260، و"المخصص" 14/ 21، وبدون نسبة في "معاني الزجاج" 1/ 206 - 2/ 320، و"إعراب النحاس" 1/ 601، و"المنصف" 1/ 306. والشاهد قوله: (مقاوم) في جمع مقامة وأصلها مجلس القوم.في "الحجة" لأبي علي 4/ 7: (فمعيشة موافقة للفعل في البناء ألا ترى أنه مثل يعيش في الزنة وتكسيرها يزيل مشابهته في البناء فقد علمت بذلك زوال المعنى الموجب للإعلال في الواحد في المجمع فلزم التصحيح في التكسير لزوال المشابهة في اللفظ) اهـ.في (أ): (ولزوم).قوله: (وهو الأمر من المفاعلة) ليس في "الإغفال".انظر: "الحجة" لأبي علي 4/ 7 - 8، و"الإغفال" ص 730 - 740، و"معجم الإبدال والإعلال" للخراط ص 198.لفظ: (في) ساقط من (ب).في (ب): (عن الواو والياء).ذكره نحو المبرد في "المقتضب" 1/ 237، وابن جني في "المنصف" 1/ 280، وانظر: "الكتاب" 4/ 345، و"التصريف" للجرجاني ص 86، و"الممتع" لابن عصفور 1/ 327، و"شرح مختصر تصريف العزي" للتفتازاني ص 131، و"شذا العرف" للحملاوي ص 74.في (أ): (يدري العربية).انظر: "المنصف" 1/ 307، وقال أبو حيان في "البحر" 4/ 271 - 272: (أما قول المازني (أصل أخذ هذه القراءة عن نافع) فليس بصحيح لأنها نقلت عن ابن عامر والأعرج وزيد بن علي والأعمش، وأما قوله (إن نافعًا لم يكن يدري ما العربية) فشهادة على النفي، ولو فرضنا أنه لا يدري ما العربية وهي هذه الصناعة التي يتوصل بها إلى التكلم بلسان العرب فهو لا يلزمه ذلك، إذ هو فصيح متكلم بالعربية ناقل للقراءة عن العرب الفصحاء، وكثير من هؤلاء النحاة يسيئون الظن بالقراء، ولا يجوز لهم ذلك) اهـ.في "الكتاب" 4/ 356، و"الإغفال" ص 741 (وهو غلط، وإنما هو مُفْعِلة وتوهموها فَعْيِلة)."الكتاب" 4/ 356.في (أ): (وقال)، وهو تحريف.(وهو)، وهو تحريف.في "الإغفال" (التي تزاد للمد).ما بين المعقوفين ساقط من (ب).في "الإغفال" ص 742: صفائح.انظر "البسيط" النسخة الأزهرية 1/ 98 أ.هذا من "الحجة" 3/ 8.أبو ذؤيب خويلد بن خالد الهذلي. تقدمت ترجمته."شرح ديوان الهذليين" للسكري 1/ 185، و"المخصص" 5/ 123، 10/ 107، و"الدر المصون" 5/ 259، وصدره: بَوادٍ لا أنِيسَ به يَبَابٍ ويباب بالفتح؛ خراب فقر ليس فيه أحد.= انظر: "اللسان" 8/ 4947 (يبب)، وأمسلة، بسكون الميم وكسر السين: جمع مَسِيل وهو: مجرى الماء. انظر: "اللسان" 7/ 4205 (مسل) ومدافعها. المجاري التي تدفع إلى الأودية. انظر: "اللسان" 3/ 1394 (دفع)، وخليف بفتح الخاء وكسر اللام: الطريق بين الجبلين انظر: "اللسان" 2/ 1242 (خلف).إلى هنا انتهى النقل من "الحجة".في (ب): (فلذلك).في (أ): (همزة).انظر: "الإغفال" ص 730 - 744، و"الحجة" 4/ 7 - 8، وهو أخذ منهما مع بعض التصرف اليسير في العبارة وانظر: "تفسير الطبري" 8/ 25، و"المشكل" 1/ 283، والمراجع المذكورة في "القراءة" ص 30 من هذا الجزء.في (ب): (وأرسل فرعون في المدائن حاشرين) من هذه السورة إن شاء الله. وهذا وهم، وجاء في سورة الشعراء الآية: 53 قوله تعالى: <q>﴿فَأَرْسَلَ فِرْعَوْنُ فِي الْمَدَائِنِ حَاشِرِينَ﴾</q>.انظر تفسير هذه الآية في هذا الجزء ص 267.لفظ: (ولا) ساقط من (ب).ذكره الواحدي في "الوسيط" 1/ 160، وابن الجوزي في "زاد المسير" 3/ 172، وفي "تنوير المقباس" 2/ 82 نحوه.لفظ: (وقد مر) ساقط من (أ).
7,11," قوله تعالى: <q>﴿وَلَقَدْ خَلَقْنَاكُمْ ثُمَّ صَوَّرْنَاكُمْ﴾</q>. قال ابن عباس: (أما <q>﴿خَلَقْنَاكُمْ﴾</q> فآدم {1}، وأما <q>﴿صَوَّرْنَاكُمْ﴾</q> {2} فذريته) {3}. وبيان هذا ما قاله مجاهد: (<q>﴿خَلَقْنَاكُمْ﴾</q> يعني: آدم <q>﴿ثُمَّ صَوَّرْنَاكُمْ﴾</q> {4} في ظهر آدم) {5}، وإنما <q>﴿خَلَقْنَاكُمْ﴾</q> بلفظ الجمع وهو يريد آدم؛ [لأنه أبو البشر وفي خلقه خلق يخرج من صلبه، وعلى هذا أيضًا يجوز أن يكون <q>﴿صَوَّرْنَاكُمْ﴾</q> لآدم وحده، وهو قول يونس {6}، قال: (يجوز أن يكون معنى <q>﴿صَوَّرْنَاكُمْ﴾</q> لآدم] {7} كما تقول: قد ضربناكم وإنما ضربت سيدهم) {8}، واختار أبو عبيد {9} في هذه الآية قول مجاهد لقوله بعده {10}: {ثُمَّ قُلْنَا لِلْمَلَائِكَةِ اسْجُدُوا}، وكان قوله: <q>﴿لِلْمَلَائِكَةِ اسْجُدُوا﴾</q> قبل خلق ذرية آدم وتصويرهم في الأرحام، و (ثم) يوجب التراخي {11} والترتيب، فمن جعل الخلق والتصوير في هذه الآية لأولاد آدم في الأرحام لم يكن قد راعى حكم (ثم) في الترتيب، إلا أن يأخذ. بقول الأخفش فإنه يقول: ((ثم) هاهنا في معنى الواو) {12}. قال الزجاج: (وهذا خطأ لا يجيزه الخليل {13} وسيبويه {14} وجميع من يوثق بعلمه) {15}. قال أبو عبيد {16}: (وقد بينه مجاهد {17} حين قال: إن الله خلق آدم [و] صورهم {18} في ظهره ثم أمر بعد ذلك بالسجود) قال: وهذا بين في حديث [آخر] {19} وهو أنه أخرجهم من ظهر آدم في سورة الذر) {20}. [و] قوله {21} تعالى: <q>﴿فَسَجَدُوا إِلَّا إِبْلِيسَ﴾</q>. قال الزجاج: (وهو استثناء ليس من الأول ولكنه ممن أمر بالسجود مع الملائكة بدليل قوله: <q>﴿قَالَ مَا مَنَعَكَ أَلَّا تَسْجُدَ إِذْ أَمَرْتُكَ﴾</q> [الأعراف:12] فدل أن إبليس ممن أُمِر بالسجود) {22} ",footnotes:1:في (أ): (آدم).في (أ): (ثم صورناكم).أخرجه الطبري في "تفسيره" 8/ 126، وابن أبي حاتم 5/ 1442 بسند جيد.لفظ: (ثم) ساقط من (ب)."تفسير مجاهد" 1/ 232، وأخرجه الطبري في "تفسيره" 8/ 127، وابن أبي حاتم 5/ 1442 من طرق جيدة، وقال النحاس في "معانيه" 3/ 13: (هذا أحسن الأقوال، يذهب مجاهد إلى أنه خلقهم في ظهر آدم، ثم صورهم حين أخذ عليهم الميثاق، ثم كان السجود لآدم بعد، ويقوي هذا: <q>﴿وَإِذْ أَخَذَ رَبُّكَ مِنْ بَنِي آدَمَ مِنْ ظُهُورِهِمْ ذُرِّيَّتَهُمْ﴾</q> [الأعراف: 172]، والحديث أنه أخرجهم أمثال الذر فَأخّذ عليهم الميثاق) اهـ. وسيأتي تخريج الحديث.يونس بن حبيب الضبي، لُغوي. تقدمت ترجمته.ما بين المعقوفين ساقط من (ب).ذكره الثعلبي في "الكشف" 188 أ.لم أقف عليه بعد طول بحث عنه.في (ب): (بعد).انظر: "حروف المعاني" للزجاجي ص 16، و"معاني الحروف" للرماني ص 105، وذكر عدة أوجه في هذه الآية، و"رصف المباني" ص 249، و"المغني" لابن هشام 1/ 117."معاني الأخفش" 2/ 294.انظر: "العين" 8/ 218.انظر: "الكتاب" 1/ 291، 1/ 429، 3/ 89، 3/ 501."معاني الزجاج" 2/ 321، ونحوه ذكر النحاس في "معانيه" 3/ 12. وقال: (هذا القول خطأ على مذهب أهل النظر من النحويين، ولا يجوز أن تكون، (ثم) بمعنى الواو لاختلاف معنييهما) اهـ.لم أقف عليه.سبق تخريجه.لفظ: (الواو) ساقطة من (ب).لفظ: (آخر) ساقطة من (ب).أخرج أحمد في "المسند" 1/ 272، وابن أبي عاصم في "السنة" 1/ 89 رقم == (202)، والنسائي في "تفسيره" 1/ 506 رقم (211)، والطبري 9/ 111، والحاكم في "المستدرك" 1/ 27 - 2/ 544، عن ابن عباس -رضي الله عنهما- عن النبي ﷺ قال: "أخذ الله تبارك وتعالى الميثاق من ظهر آدم بنعمان -يعني عرفة- فأخرج من صلبه كل ذرية ذرأها، فنثرهم بين يديه كالذر، ثم كلمهم قبلا"، قال: <q>﴿أَلَسْتُ بِرَبِّكُمْ قَالُوا بَلَى شَهِدْنَا أَنْ تَقُولُوا يَوْمَ الْقِيَامَةِ إِنَّا كُنَّا عَنْ هَذَا غَافِلِينَ﴾</q> -إلى- <q>﴿الْمُبْطِلُونَ﴾</q>) [الأعراف:172، 173]. وصححه الحاكم في "المستدرك" ووافقه الذهبي في "التلخيص". وقال الهيثمي في "مجمع الزوائد" 7/ 25: (رواه أحمد ورجاله رجال الصحيح) اهـ. وقال الشوكاني في "تفسيره" 2/ 384، وصديق خان 5/ 73 (إسناده لا مطعن فيه) اهـ. وحسن إسناده الألباني في "ظلال الجنة في تخريج السنة" لابن أبي عاصم 1/ 89، وصححه في "السلسلة الصحيحة" رقم (1623). وفي الباب أحاديث كثيرة بمعناه، انظر: "الدر المنثور" 3/ 261.لفظ: (الواو) ساقط من (ب)."معاني الزجاج" 2/ 14، وعلى هذا القول يكون الاستثناء منقطع، وإبليس ليس من الملائكة لكنه أمر بالسجود معهم، وذهب الجمهور إلى أن الاستثناء متصل وإن إبليس من الملائكة أو من طائفة منهم، واختاره الطبري في "تفسيره" 1/ 224، 225، والبغوي 1/ 81، وابن عطية 1/ 245، 246، وغيرهم، والظاهر والله أعلم أنه ليس من الملائكة؛ لأن الملائكة خلقت من نور وإبليس خلق من نار ولأن الملائكة مسخرة لا تعصي الله تعالى وإبليس عصى وكفر ولقوله تعالى: <q>﴿إِلَّا إِبْلِيسَ كَانَ مِنَ الْجِنِّ فَفَسَقَ عَنْ أَمْرِ رَبِّهِ﴾</q> [الكهف: 50] وتوجه الخطاب إليه وأمر بالسجود مع الملائكة لأنه كان في عامتهم ومعهم يعمل بعملهم ويتعبد كما يتعبدون ولكن غلب عليه الطبع الخبيث. أفاده شيخنا محمد بن صالح العثيمين -رحمه الله تعالى- في كتاب "أحكام من القرآن الكريم" 1/ 162 - 164، وانظر: "معاني النحاس" 3/ 14، و"النكت والعيون" للماوردي 1/ 102، و"زاد المسير" 1/ 65.
