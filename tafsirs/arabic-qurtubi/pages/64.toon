quran[7]{c,v,t}:
3,109," "
3,110," قوله تعالى: <q>﴿كُنْتُمْ خَيْرَ أُمَّةٍ﴾</q> اختلف قول أهل المعاني في هذا: فقال الفرَّاء {1} والزجاجُ {2}، وغيرُهما {3}: كنتم خير أُمَّةٍ عند الله، في اللَّوْح المحفوظ. وقالا {4} أيضًا: معنى <q>﴿كُنْتُمْ خَيْرَ أُمَّةٍ﴾</q>: أنتم خير أمة؛ كقوله: <q>﴿وَاذْكُرُوا إِذْ كُنْتُمْ قَلِيلًا فَكَثَّرَكُمْ﴾</q> [الأعراف: 86]، وقال في موضع آخر: <q>﴿وَاذْكُرُوا إِذْ أَنْتُمْ قَلِيلٌ مُسْتَضْعَفُونَ﴾</q> [الأنفال: 26]. وإضمارُ (كان) {5} وإظهارُها في مثل هذا، سواءٌ، إلّا أنها إذا ذُكِرت كانت للتأكيد، ووقوع الأمرِ لا مَحالة. قال ابن الأنباري {6}: وهذا القول ظاهرُ الاختلال؛ لأن (كان) يُلغى {7} مُوسَّطًا ومُؤَخَّرًا، ولا يُلغَى {7} مُقدَّما؛ تقول العرب: (عبدُ الله كان قائمٌ) و (عبدُ الله قائمٌ، كان)؛ على أنَّ (كان) مطروحة، ولا يقولون: (كانَ عبدُ الله قائمٌ)، على إلغائها، لأنَّ سبيلهم أن يبدأوا بما [تنصرف الغايةُ إليه، والمُلْغَى غير معني به، على أنَّه لا يجوز] {9} إلغاءُ الكَوْنِ في الآية؛ لانتصاب خبره، وإذا (أُعْمِلَ) {10} الكَوْنُ في الخَبَرِ، فنصبه، لم يكن مُلغًى. وقال بعضُ النحويين {11}: إنما قال: <q>﴿كُنْتُمْ﴾</q>، ولم يقل: (أنتم)؛ لتَقَدُّمِ {12} البِشَارَةِ بهذه الأُمَّة، ولِمَا قد {13} كان يُسمَعُ مِنَ الخير في هذه الأمَّةِ؛ فكأنَّه {14} قيل: كنتم خير أُمَّةٍ بُشِّرَت بها. وهذا القول، يُروى معناه عن الحَسَنِ {15}. وقال بعضهم {16}: الكَوْنُ ههنا بمعنى: الوقوع والحُدُوث، وهي التَّامَّةُ التي لا تحتاج إلى خبر، فمعنى <q>﴿كُنْتُمْ خَيْرَ أُمَّةٍ﴾</q>: حَدَثْتم خَيْرَ أُمَّةٍ، ووُجِدْتُم وخُلِقْتُم خَيرَ أمَةٍ، فيكون <q>﴿خَيْرَ أُمَّةٍ﴾</q> حينئذ بمعنى الحَالِ. وهذا معنى قولِ [ابن] {17} جَرِير {18}. وحكى الزجاجُ {19} عن بعضهم: كنتم [منذ] {20} آمنتم خيرَ أُمَّةٍ {21}. فأمَّا المُخاطَبون بهذا: فقال ابن عباس في رواية سعيد بن جبير {22}: هم الذين هاجروا مع النبي ﷺ إلى المدينة. وعلى هذا {23}: عِكْرِمة {24}، ومقاتل {25}، والضَّحَّاك {26}: أن هذا خاصة لأصحاب محمد {27} ﷺ. يدل على هذا القول: ما روي عن عمر رضي الله عنه، أنه قال في هذه الآية {28}: هي لأوَّلِنا، ولا تكون لآخرنا. وقال {29} في رواية عطاء {30}: يريد: أُمَّةَ محمد ﷺ. فعلى هذا: هم جميع المؤمنين من هذه الأمَّة. قال الزجاج {31}: هذا الخطاب، أصلُه: أنه خوطب به أصحابُ رسول الله ﷺ، وهو يَعُمُّ سائرَ أُمَّتِهِ. وقوله تعالى: <q>﴿أُخْرِجَتْ لِلنَّاسِ﴾</q> يُحتَمَلُ أنْ يكون <q>﴿للِنَّاسِ﴾</q>، مِنْ صِلَةِ <q>﴿أُمَّةٍ﴾</q>، أي: كنتم خير أمةٍ للنَّاسِ أُخْرِجَت، يعني: أفهم {32} خير أمَّة للنَّاس، تجيئون بهم في السلاسل، فتُدْخِلُونَهم في الإسلام. وهذا المعنى يُروى عن أبي هريرة {33}. وقال قتادة {34}: لم يُؤْمَرْ نَبِيٌّ وأمَّتُهُ بالقتال، إلّا هذه الأمَّة ونَبِيها، يُقاتِلُونَ، فَيَسْبُونَ الرُّومَ والتُّرْكَ والعَجَمَ، فَيُدْخِلونهم في دينهم، فهم خير أمَّة للنَّاس. ويُحتَمَلُ {35} أن يكون <q>﴿للِنَّاسِ﴾</q> {36} مِن {37} صِلَةِ <q>﴿أُخْرِجَتْ﴾</q>؛ ومعناه: ما أَخرَجَ {38} [اللهُ] {39} للنَّاسِ أمَّةً، خيرًا {40} مِنْ أمَّةِ أحمد {41}؛ فهم {42} خير أمَّةٍ أُظْهِرَت {43} وأُخْرِجَت للنَّاس. وقوله تعالى: <q>﴿تَأْمُرُونَ بِالْمَعْرُوفِ وَتَنْهَوْنَ عَنِ الْمُنْكَرِ﴾</q> الظاهرُ أنَّ {44} هذا مَدْحٌ لهذه الأمَّة بهذه الخصال، وإخبارٌ عنهم بهذه الجملة، وحُكِي عن مجاهد أنه قال {45}: الخَيْرِيَّةُ في هذه الأمَّةِ على هذه الشَّرِيطَةِ {46}؛ يعني: كنتم خيرَ أُمَّةٍ، ما أَمَرْتُم بالمعروف، ونَهَيْتُم عن المنكر، وآمنتم بالله، وهذا أيضًا اختيار الزجاج {47}. والمَعْرُوفُ: كلُّ حَسَنٍ جميل، يُعرَفُ بجلالته، وعُلُوِّ قَدْرهِ {48}. ولا يجوز إطلاق هذه الصفة على القبيح، وإنْ كان يُعرَف، لأنه بمنزلة ما لا يُعْرَف؛ لخُمُولِهِ وسُقُوطِهِ. ",footnotes:1:في "معاني القرآن" له: 1/ 229.في "معاني القرآن" له: 1/ 456. وقد أورده الزجاج بلفظ (قيل: ..).ممن جوز هذا القول: النحاس، في "إعراب القرآن" 1/ 357.قائل هذا القول، هو: الفراء، في المرجع السابق. والعبارات التالية له نقلها == المؤلف بتصرف يسير. أما الزجاج فلم يذكر هذا المعنى في هذا الموضع. وممن قال بهذا: ابن قتيبة في "تأويل مشكل القرآن" 295. وجعله من باب مخالفة ظاهر اللفظ معناه، قال: (ومنه أن يأتي الفعلُ على بِنْيَةِ الماضي وهو دائمٌ أو مُستَقبَل) وذكره. وقال به الطبري، في "تفسيره" 4/ 45 - 46، وابن فارس، في "الصاحبي" 364، ويرويه أبو العباس عن ابن الأعرابي، كما في "تهذيب اللغة" 4/ 3084 (كون)، وجوزه النحاس في "إعراب القرآن" 1/ 357.في (ج): (كل).لم أقف على مصدر قوله.في (ب)، (ج): (تلغى).في (ب)، (ج): (تلغى).ما بين المعقوفين غير مقروء في (أ). والمثبت من: (ب)، (ج).في (أ): (عمل).لم أقف عليهم.في (ج): (فتقدم).في (أ)، (ب): (قدم). والمثبت من (ج).في (ج): (وكأنه).قوله في "تفسير الطبري" 4/ 45، "النكت والعيون" 1/ 416.منهم الطبري، كما سيأتي.ما بين المعقوفين: زيادة من: (ج).في "تفسيره" 7/ 106.في "معاني القرآن" له 1/ 456. أورد هذا القول وصدَّره بلفظ (قيل ..).في (أ)، (ب)، (ج): (قد). ولم أر لها وجهًا. وأثبتُّها من: "معاني القرآن" للزجاج. وقد تكون (مُذ) فحرِّفت إلى (قد).قد يكون القائل ابن الأنباري؛ حيث أورد ابن الجوزي في الزاد نحو هذا القول، وقال: (ذكره ابن الأنباري) ونصه: (مذ كنتم). انظر: "زاد المسير" 1/ 439.هذه الرواية، في "مصنف ابن أبي شيبة" 6/ 398 رقم (32349)، و"مسند أحمد" (شرح الشيخ أحمد شاكر): 4/ 153 رقم (2463)، 335 (1928)، 355 (3989)، 5/ 112 (3321)، وصححه الشيخ شاكر، وتفسير النسائي: 1/ 319، "تفسير الطبري" 4/ 45، "تفسير عبد الرزاق" 130، "تفسير ابن أبي حاتم" == 3/ 732، "المعجم الكبير" للطبراني: 12/ 6 رقم (12303)، ومستدرك الحاكم: 2/ 294. وصححه ووافقه الذهبي، "تفسير الثعلبي" 3/ 98 أ، وذكرها ابن حجر في "المطالب العالية" 3/ 315 رقم (3570) وعزاها للحارث بن أبي أسامة في مسنده عن ابن عباس، وذكرها الهيثمي في "مجمع الزوائد" 6/ 327 وقال: (رواه أحمد والطبراني ورجال أحمد رجال الصحيح)، وأوردها ابن حجر في "فتح الباري" 8/ 225 وعزاها لمن سبق وقال عن إسنادها: (جيد)، وأوردها السيوطي في "الدر" 2/ 113، وزاد نسبة إخراجها لعبد بن حميد، والفريابي، وابن المنذر، عن ابن عباس موقوفًا.في (ج): (ذلك).قوله في "تفسير الطبري" 4/ 43، "تفسير الثعلبي" 3/ 98 أ، "أسباب النزول" للواحدي: (121)، "تفسير البغوي" 2/ 89، "زاد المسير" 1/ 438، "الدر المنثور" 2/ 113 وزاد نسبة إخراجه لابن المنذر.قوله في "تفسيره" 1/ 295، والمصادر السابقة ما عدا الطبري. وقد ورد قول مقاتل وعكرمة في معرض بيانهما لسبب نزول الآية، فقد قال مقاتل في تفسيره (وذلك أن مالك بن الصَّيف، ووهب بن يهوذا، قالا لعبد الله بن مسعود، ومعاذ بن جبل، وسالم مولى أبي حذيفة: إن ديننا خيرٌ مِمَّا تدعوننا إليه فأنزل الله عز وجل - فيهم: <q>﴿كُنْتُمْ خَيْرَ أُمَّةٍ أُخْرِجَتْ لِلنَّاسِ﴾</q> في زمانكم، كما فضل بني إسرائيل في زمانهم). وانظر المصادر السابقة.قوله في "تفسير الطبري" 4/ 44، "تفسير الثعلبي" 3/ 98 أ، ولكنه فيه: (عن الضحاك عن ابن عباس)، "تفسير البغوي" 2/ 89في (ب): (النبي).قوله في "تفسير الطبري" 4/ 43، وابن أبي حاتم: 3/ 732، "تفسير الثعلبي" 3/ 98 أ، "تفسير البغوي" 2/ 89.أي: ابن عباس - رضي الله عنه -.لم أقف على مصدر هذه الرواية.في "معاني القرآن" له: 1/ 456، نقله عنه بتصرف يسير جدًّا.في (ج): (أنتم).ورد هذا عنه مرفوعا وموقوفًا، أما المرفوع فقد أخرجه: البخاري في "الصحيح" (3010) في الجهاد، باب الأسارى في السلاسل، ولفظه عنده من رواية أبي هريرة رضي الله عنه عن النبي ﷺ قال: "عجب ربنا من قوم يدخلون الجنة في السلاسل". وأخرجه أحمد مرفوعًا بنحو لفظ البخاري. انظر: "المسند" (شرح الشيخ شاكر): 15/ 168 (8000)، 18/ 48 (9260)، 19/ 33 (9781)، 66 (9890)، وأبو داود في "السنن" (2677) كتاب الجهاد، باب: (في الأسير يوثق). وابن حبان في "صحيحه" "الإحسان" 1/ 343 رقم (134). أما الموقوف، فقد أخرجه: البخاري (4557) في التفسير، سورة آل عمران، باب (7) ولفظه: (<q>﴿كُنْتُمْ خَيْرَ أُمَّةٍ أُخْرِجَتْ لِلنَّاسِ﴾</q> قال: خير الناس للناس، تأتون بهم في السلاسل في أعناقهم حتى يدخلوا في الإسلام). وأخرجه عنه كذلك: النسائي في "تفسيره" 1/ 318، والطبري في "تفسيره" == 4/ 44، وابن أبي حاتم في "تفسيره" 3/ 732، والثعلبي في "تفسيره" 3/ 98ب، وأورده البغوي في "تفسيره" 2/ 90، والسيوطي في "الدر" 2/ 113 وزاد نسبة إخراجه للفريابي، وعبد بن حميد، وابن المنذر، والحاكم. ولكنيِّ لم أجده في مستدركه. قال ابن حبان في معناه: (والقصد في هذا الخبر: السَّبْيُ الذين يسبيهم المسلمون من دار الشرك مكتَّفِين في السلاسل يُقادون بها إلى دور الإسلام، حتى يُسْلِمُوا، فيدخلوا الجنة). "الإحسان في تقريب صحيح ابن حبان" 1/ 343 - 344. وقد نقل ابنُ حجر أقوال أهل العلم في شرحه. انظر: "فتح الباري" 6/ 145، 8/ 225.قوله في "تفسير الثعلبي" 3/ 99 أ، "تفسير البغوي" 2/ 89.من قوله: (ويحتمل ..) إلى- (أخرجت للناس): نقله بتصرف يسير عن "تفسير الثعلبي" 3/ 99 أ.في (ج): (من الناس).من: ساقطة من (ج).في (ب): (فلا تخرج).ما بين المعقوفين: في في (أ)، (ب): إليه. وهي ساقطة من: (ج). وليست في "تفسير الثعلبي". ورجَّحتُ أن أصلها كما أثبتُّه، وقد حُرِّفت إلى (إليه).في (ج): (خير).في (ج): (محمد).(من أمة أحمد فهم): ساقطة من: (ب).في (ج): (ظهرت).في (ج): (من).قوله في "الطبري" 4/ 44، "الدر المنثور" 2/ 113 وزاد نسبة إخراجه لابن المنذر.في (ب): (الطريقة).في "معاني القرآن" له: 1/ 456.انظر: "تفسير الطبري" 4/ 44، "اللسان" 5/ 2899 - 2900 (عرف)، و"التعريفات" للجرجاني: 221، و"التوقيف على مهمات التعاريف" 666.
3,111," قوله تعالى: <q>﴿لَنْ يَضُرُّوكُمْ إِلَّا أَذًى﴾</q> هذا وعْد مِنَ الله تعالى {1} للمؤمنين، في أهل الكتاب، أنَّهم منصورون عليهم، وأنَّه لا ينالهم منهم غَلَبَةٌ. ومعنى <q>﴿إِلَّا أَذًى﴾</q>؛ أي: أذًى باللِّسانِ، مثل {2}: الوعيد، والبُهْت {3}. وقال الحسن {4} وقتادة {5}: أي: دعاء إلى الضلالة. وموضع <q>﴿إِلَّا أَذًى﴾</q> نصبٌ بالاستثناء المتصل؛ المعنى: لن يضروكم إلا ضَرَرًا يسيرًا. فـ (الأذى) وقع موقع الضَّرَر {6}. والأذى: مصدر (أَذِيْتُ بالشيء أذًى) {7}. وقوله تعالى: <q>﴿وَإِنْ يُقَاتِلُوكُمْ يُوَلُّوكُمُ الْأَدْبَارَ﴾</q> قال أبو على {8}: (وَلَّى) منقول مِن (فَعل)؛ تقول: (داري تَلِي دارَهْ)، وَ (وَلِيَتْ {9} داري دارَه)، فإذا {10} نَقَلْتَ {11} إلى (فَعَّلَ)، قلت: (ولّاني مآخيرَهُ) {12}، و (ولّاني مَيَامِنَه) {13}، فهو مثل: (فَرِحَ) و (فَرّحْتُه) {14}، ومثل هذا: قوله: <q>﴿لَيُوَلُّنَّ الْأَدْبَارَ﴾</q> [الحشر: 12]، وقوله: <q>﴿وَيُوَلُّونَ الدُّبُرَ﴾</q> [القمر: 45]، إلّا أنّ المفعول الثاني الزائِد في نَقل (فَعِلَ) {15} إلى (فَعَلَ) محذوفٌ من الآيتين، ولو لم يُحذَفْ لكان كقوله: <q>﴿يُوَلُّوكُمُ الْأَدْبَارَ﴾</q> {16}. وقوله تعالى: <q>﴿ثُمَّ لَا يُنْصَرُونَ﴾</q> محمول {17} على الاستئناف، لا على العطف {18}. والتقدير: ثم هم لا ينصرون. وإنَّما لم يُحتملْ {19} على العطف؛ لأنه غير مشاكل للمعطوف عليه؛ وذلك أن سبب التولية: القتال، وليس كذلك منعُ النصر؛ لأن {20} سببه: الكفر {21}. وأيضًا فإنه آخر آية، فكان الرفعُ فيه أقوى؛ ليشاكل {22} سائرَ الفواصل بالنُّون {23}، كما قال: <q>﴿وَلَا يُؤْذَنُ لَهُمْ فَيَعْتَذِرُونَ﴾</q> [المرسلات: 36] {24}. قال المفسرون: صدق الله وعْدَه بالنصر، فلم يقاتل يهودُ {25} المدينة رسولَ الله ﷺ والمسلمين {26}، إلّا ولَوا منهزمين، وكانت الدَّبْرَةُ {27} عليهم، ففيه أعظم دلالة على (صحة) {28} نبوة محمد ﷺ. ",footnotes:1:تعالى: ساقطة من: (ب)، (ج).في (ج): (ثم).البُهْت -بضم الباء-، والبَهِيتة، والبهتان: الكذب والافتراء. والبَهت -بفتح الباء-: أن يقول المرء في غيره ما لم يفعله. يقال: (بَهَته، يَبهَتُه، بَهْتًا، وبَهَتا، وبُهْتانًا). والبَهْتُ: الانقطاع والحَيْرة، يقال: (بَهَتَ، وبَهِتَ، وبُهِتَ): إذا تَحيَرّ. وهو أصل== معنى الكلمة. فـ (البُهتان): هو الباطل الذي يُتحير من بطلانه. انظر: (بهت) في. "مقاييس اللغة" 1/ 308، والنهاية في "غريب الحديث" 1/ 165، "اللسان" 1/ 367 - 368.قوله في "تفسير الطبري" 4/ 47، "تفسير ابن أبي حاتم" 3/ 734، "زاد المسير" 1/ 240.قوله في "تفسير الطبري" 4/ 46 ونصه عنده: (لن يضروكم إلا أذى تسمعونه منهم). "تفسير ابن أبي حاتم" 3/ 734.وقيل: هو استثناء منقطع؛ أي: لن يضروكم بقتال أو غلبة، ولكن بكلمة أذى أو نحوها. وممن قال بهذا: الأخفش، والطبري، والنحاس، ومكي، وأبو بكر الأنباري. انظر: "معاني القرآن" للأخفش: 1/ 213، "تفسير الطبري" 4/ 41، "إعراب القرآن" للنحاس: 1/ 358، "البيان" للأنباري: 1/ 285، "الدر المصون" للسمين الحلبي: 3/ 352، "مشكل إعراب القرآن" لمكي: 1/ 170.الأذى: هو ما تسمعه من مكروه. يقال: (أذِيتُ بالشيء، آذَى أذًى وأذاة وأذِيَّة)، فـ (أنا أذٍ). أمَّا (آذى)، فمصدرها: إيذاء، وأذيّة. وتأذَّيْت به تأذِّيا. انظر: "تهذيب اللغة" 1/ 140 (أذا)، "الصحاح" 6/ 2266 (أذا)، "اللسان" 1/ 54.هو: الفارسي، ولم أقف على مصدر قوله فيما رجحت إليه من مؤلفاته، وقد وجدته -مع اختلاف يسير جدًا- في "إعراب القرآن" المنسوب للزجاج: 2/ 447 في كلام طويل نقله عن أبي علي في تعليقه على قوله -تعالى-: <q>﴿فَلَنُوَليَنَّكَ قِبْلَة تَرضَاهَا﴾</q> [الآية: 144 من سورة البقرة].في (ب): (ووليته).في (ج): (وإذا).في "إعراب القرآن" المنسوب للزجاج: نقلته.في (أ)، (ب): (ما آخيره). والمثبت من: (ب)، (ج)، "إعراب القرآن". وفي "إعراب القرآن": (قلت: وَلِيتُ مآخيره، وولّاني مآخيره). والمآخير: لم أقف على المراد بها في معاجم اللغة التي رجعت إليها، وقد ورد فيها (المئخار)، وهي النخلة التي يبقى حملها إلى آخر الصِّرام، أو يبقى إلى آخر الشتاء، وجمعها: مآخير. انظر: "كتاب النخل"، لأبي حاتم السجستاني: 92، وانظر مادة (أخر) في "اللسان" 1/ 45، "التاج" 6/ 17. ولكن هذا المعنى ليس هو - المراد هنا، وإنما يراد بها هنا -والله أعلم- جهة الخلف من الإنسان: الظهر وما يليه. ويعزز هذا قوله بعده: (وولاني ميامنه).ورد في "إعراب القرآن" المنسوب للزجاج: (ووليت ميامنه، وولاني ميامنه). والميامن: جمع (مَيمَنه)، وهي خلاف الميسرة في الإنسان. انظر: "اللسان" 8/ 4967 (يمن).في "إعراب القرآن" السابق، أضاف بعدها: (وليس مثل: لقي وألقيته ولقَّيْته).في (أ): (فعِّل). وفي (ب)، (ج): (غير مشكولة). وما أثبته هو الصواب.فـ (الأدبار) مفعول ثانٍ. انظر: "التبيان" للعكبري: ص 204، "الدر المصون" 3/ 352.من قوله: (محمول ..) إلى (ثم لا ينصرون): ساقط من (ج).انظر: "إعراب الحديث النبوي" للعكبري: 172.في (ج): (يحمل).في (ج): (لأنه).أي: لو قلنا بعطفه على جواب الشرط، للزم تقييد عدم نصرهم في حالة مقاتلتهم لنا فقط. ولكن -في الحقيقة- هم غير منصورين مطلقًا؛ لكفرهم، سواءً أقاتلوا أم لم يقاتلوا.في (ج): (لتشاكل).في (ب): (والنون).في رفع <q>﴿فَيَعْتَذِرُونَ﴾</q> -هنا- وجهان: أ- أنها معطوفة على ما قبلها <q>﴿وَلَا يُؤْذَنُ﴾</q> فهي نفي؛ أي: فلا يعتذرون فلم يجعل الاعتذار متسببًا عن الإذن؛ إذ لو كان كذلك لنُصب وحذف النون. وذهب الفرَّاء إلى أن الرفع فيها لمراعاة الفواصل. ب- أنها مستأنفة؛ أي: فهم يعتذرونه ومعناها: أنهم ينطقون في مواقف دون أخرى. انظر: "معاني القرآن" للفراء: 1/ 229، 3/ 226، "التبيان" للعكبري: ص 204، "البيان" للأنباري: 2/ 488، "البحر المحيط" 8/ 408.في (ب): (بعد) بدلًا من (يهود).(والمسلمين): ساقطة من: (ج).في (ج): (الدائرة).= الدَّبْرَة: العاقبة، والهزيمة في القتال. أمَّا الدِّبْرة -بكسر الدال المشددة- فهي خلاف القِبلة. انظر: "القاموس المحيط" ص 389 (دبر).زيادة من (أ).
3,112," قوله تعالى: <q>﴿ضُرِبَتْ عَلَيْهِمُ الذِّلَّةُ﴾</q> قد مضى الكلام في معنى ضَرْبِ الذِّلَّةِ والمَسْكَنَةِ على اليهود، في سورة البقرة {1}. وقوله تعالى: <q>﴿أَيْنَ مَا ثُقِفُوا﴾</q> أي: وُجِدوا، وصُودِفوا {2}. ومضى الكلام في هذا عند قوله: <q>﴿حَيثُ ثَقفتُمُوهُم﴾</q> [البقرة: 191]. وقوله تعالى: <q>﴿إِلَّا بِحَبْلٍ مِنَ اللَّهِ﴾</q> قال الفرّاء {3}: يقول: (إلَّا أنْ يَعتَصموا بحبل من الله)، فأضمر ذلك، وأنشد: رأتني بحَبْلَيْها فَصدّتْ مَخَافَةً ... وفي الحَبْلِ رْوْعاءُ الفُؤادِ فَرُوقُ {4} قال أراد: أقْبَلْتُ {5} بحبليها {6}. وقد نُعي هذا عليه، فقيل: لا يجوز حذف الموصول وإبقاء صلته {7}؛ وذلك أن الموصول لمّا احتاج إلى الصِّلَةِ للبيان عنه، فالحاجة إلى ذِكْرِهِ أشدُّ {8}، وإنَّما يجوز حذفُ الشيء للاستغناء بدلالة غيره عليه، فلو دَلّ دليل عليه لحُذف مع صلته؛ لأنه معها بمنزلِةِ شيءٍ واحد. ويجوز حذف الصلة دون الموصول؛ لأن الموصول [هو المعتمد عليه، والصلة تبع له؛ لأنها للبيان عنه، فإذا حُذِفَ الموصول] {9} وجب حذفُ الصلة معه؛ [لأنها تَبَعٌ] {10} له. وقد أخبرني العَرُوضي رحمه الله، عن الأزهري، قال {11}: أخبرني المُنْذِريُّ، عن ثعلب، أنه قال: هذا الذي قاله الفرّاء {12}، بعيدٌ {13}، ولكن المعنى إن شاءَ الله: ضربت عليهم الذِّلَّة أينما ثُقِفُوا؛ أي: بكلِّ مَكان إلّا بموضِع حَبْلٍ مِنَ الله، وهو استثناء مُتَّصل، كما تقول: (ضُرِبت عليهم الذِّلَّة في الأمكنة، إلّا في هذا المكان)، ثمّ حذف المضافُ {14}. قال: وقول الشاعر: (رأتني بحبليها)؛ هو كما تقول: (أنا بالله، وبك) {15}؛ أي: مُتَمَسِّك. فتكون الباءُ مِن صِلَة (رأتني متمسكًا بحبليها) {6}، فاكتفى بالرُّؤيَةِ {17} مِن التمسك. قال الأزهري: والقول، ما قال أبو العباس {18}. وقال الأخفش {19}: قوله: <q>﴿إِلَّا بِحَبْلٍ مِنَ اللَّهِ﴾</q> استثناء خارج عن {20} أول الكلام {21}، ومعنى (إلّا): لكِنْ {22}. واختار الزَّجَّاج هذا الوجه، فقال {23}: ما بعد الاستثناء {24} ليس من الأول؛ المعنى {25}: أنهم أذلَّاءُ، إلَّا أنهم يعتصمون بالعهد إذا أُعطوه. ونَصَرَ محمدُ بن جَرِير هذه الطريقة أيضًا، فقال {26}: إن أهل الكتاب (قد) {27} ضربت عليهم الذلة، سواء كانوا على عهد من الله، أو لم يكونوا على عهد، فلا يخرجون بالاستثناء {28} عن الذِّلة إلى العِزَّة. قال {29}: وتمام الكلام عند قوله: <q>﴿أَيْنَ مَا ثُقِفُوا﴾</q>، ثم قال: <q>﴿إِلَّا بِحَبْلٍ مِنَ اللَّهِ﴾</q> أراد {30}: لكن قد يعتصمون بحبل من الله، أو قد يُثْقَفُونَ بحبل من الله، وحَبْلٍ مِنَ الناس كما قال: <q>﴿وَمَا كاَنَ لِمُؤمِنٍ أَن يَقتُلَ مُؤْمَنًا إِلا خَطأ﴾</q> [النساء:92]، فـ (الخَطَأ) وإن كان منصوبًا بما عمل فيِه ما قبل الاستثناء، فليس باستثناء مُتَّصل حتى يَدُلَّ على أنَّ قتلَه خطأ مباحٌ {31}، ولكن معناه: قد يقتله خطأ {32}. ومَن نَصرَ طريقة أبي العباس، قال {33}: إنَّ عِزَّ {34} المسلمين عِزٌّ لأهلِ الذِّمَةِ؛ لأنَّ أخْذَهم عَهْدَ المسلمين يَحقِنُ دماءَهم، ويمنع فُرُوجَهم وأموالهم عن الاغتنام بالسَّبْي، ثم هذا [العِزُّ] {35} لا يخرجهم عن الذِّلَّة في أنفسهم، فهم على ما وصفهم الله من الذِّلَّة أينما ثقفوا، وإنْ اعتصموا بالذِّمَة {36}. وأما التفسير: فقد ذكرنا معضى (الحبل) عند قوله: <q>﴿وَاعتَصِمُوا بِحَبْلِ اللَّهِ﴾</q> [آل عمران: 103] وبعض المفسرين يذهب إلى أن حبلَ الله ههنا الإسلام {37}؛ يعني [إلّا] {9} أنْ يُسْلِمُوا. وهذا بعيدة لعطف (حبل الناس) عليه، وإذا أسلموا، استغنوا عن حَبْلِ الناس، ولو أرادَ الله تعالى بالحبلَ الأوَّل: الإسلام، وبالثاني: الذِّمَّة؛ لقالَ: (أو حبل من الناس)، ولكن الصحيح: أن كلا {39} الحبلين؛ المراد به العهد، والذِّمَّة، والأمان، كما قال ابن عباس {40} يريد: بعهد مِنَ الله، وعهد مِنَ المؤمنين، وانما ذكر الله تعالى حبلَ الله مع حبل المؤمنين؛ لأن الأمان الذي يأخذونه {41} من المؤمنين، هو بإذن الله تعالى، فهو أمانٌ مِن جهته. وباقي الآية مشروح في سورة البقرة {42}. ",footnotes:1:انظر: "تفسير البسيط" عند تفسير آية: 61 من سورة البقرة.انظر: (ثقف) في "اللسان" 1/ 492، "القاموس" ص 795.في "معاني القرآن" له: 1/ 230. نقله عنه بنصه.البيت لحميد بن ثور، وهو في ديوانه: 35. وورد في "معاني القرآن" للفراء: 1/ 230، "تفسير الطبري" (49)، "تهذيب اللغة" 1/ 731، "تفسير الثعلبي" 3/ 101 أ، "أساس البلاغة" 1/ 381، "اللسان" 2/ 761، 7/ 4410، 6/ 3401. "البحر المحيط" 3/ 32. وروايته في الديوان: فجئت بحبليها فردَّت مخافةً ... إلى النفس روعاءُ الجَنان فَرُوق ووردت روايته في "اللسان" 7/ 4410 رأتني بنِسْعَيها فردت مخافتي ... إلى الصدر روْعاءُ الفؤادِ فَرُوق وفي "اللسان" 6/ 3401: رأتني مُجَلِّيها فصدت مخافةً ... وفي الخيل روعاء الفؤاد فروق و (الروعاء): الناقة الحديدة الفؤاد. "القاموس" 724 (روع). و (الفَرُوق): == الشديدة الفزع. من (الفَرَق): وهو الخوف. "اللسان" 6/ 3397 (فرق). قال الأستاذ محمود شاكر في تعليقه على البيت في هامش "تفسير الطبري" 7/ 113 (ط. شاكر): (مدح ناقته بحدة الفؤاد، تفزع لكل نبأة؛ من يقظتها؛ كما قالوا: (مجنونة)، يقول ذلك في ناقته: رأتني أقبلت بالحبلين لأشد عليها راحلي، فصدَّت خائفة. يصفها بأنها كريمة لم تبتذلها الأسفار. ثم قال: فلما شددت عليها الرحل، كانت في الحبل ذكية شهمة، تتوجس لكل نبأة؛ من يقظتها وتوقدها).في (ب): (قبلت).في (ج): (بحبلها).وهي -هنا- الجار والمجرور. ففي الآية <q>﴿بِحَبْلٍ﴾</q>، وفي البيت (بحبليها).في (ج): (ذكر ما شد).ما بين المعقوفين: زيادة من: (ج).ما بين المعقوفين: في (أ)، (ب): (لا يتبع). والمثبت من (ج).قوله في "تهذيب اللغة" 1/ 731 - 732 (حبل) إلى نهاية: (ومعنى (ألا): (لكن). وقد نقله عنه بتصرف واختصار يسيرين.(الفراء): ساقطة من: (ج).وفي "تهذيب اللغة": (بعيد أن تحذف (أن) وتُبقِي صلتها).ثم حذف المضاف: ليس في "تهذيب اللغة". وقد ذهب إلى هذا الزمخشري، وأيَّد كون الاستثناء متصلًا هنا، وقال: (وهو استثناء من أتم الأحوال؛ المعنى: ضربت عليهم الذلة في عامة الأحوال إلا في حالة اعتصامهم بحبل الله وحبل الناس ..). "الكشاف" 1/ 455.وبك: ليس في "تهذيب اللغة". بالنسبة لهذه الألفاظ مثل (أنا بالله، وبك) وأمثالها، وبغض النظر عن مجال الاستدلال النحوي بها، فإن الآثار الشرعية قد وردت بالنهي عن استعمالها بهذه الصورة. فقد قال ﷺ: "إذا حلف أحدكم فلا يقل: ما شاء الله وشئت، ولكن ليقل: ما شاء الله، ثم شئت". أخرجه ابن ماجه (2117) كتاب الكفارات، باب (13)، وصححه الألباني في "صحيح سنن ابن ماجه":1/ 362. وورد في الحديث عنه ﷺ: "لا تقولوا ما شاء الله وشاء فلان، ولكن قولوا: ما شاء الله، ثم شاء فلان". رواه أبو داود في "السنن" (4980)، كتاب الأدب، والبيهقي في "السنن" 3/ 216، وأحمد في "المسند" 5/ 384، 394، 398. وعن ابن عباس: جاء رجل إلى النبي ﷺ، فراجعه في بعض الكلام، فقال: ما شاء الله وشئت. فقال ﷺ: "أجعلتني والله عِدْلاً، بل ما شاء الله وحده". أخرجه البيهقي في "السنن" 3/ 217، والبخاري في الأدب المفرد: 344 رقم (783)، وغيرهما. انظر سلسلة الأحاديث الصحيحة: 1/ حديث رقم (136 - 139). وقد ذكر العلماء أن قول الإنسان (ما لى غير الله وأنت)، و (توكلت على الله == وعليك)، وأنا بالله وبك) وأمثالها من عبارات، تعد من ألفاظ الشرك التي يجب أن تُجتَنَب، كما دلت على ذلك الآثار السابقة. انظر تيسير العزيز الحميد: 598 - 602في (ج): (بحبلها).في (ب): (بالراية).هو ثعلب.قوله في "معاني القرآن" له 1/ 213، ولكنه هنا من، تتمة قول الأزهري السابق في "التهذيب".في (ب)، "معاني القرآن"، "تهذيب اللغة": (من).أي إنه استثناء منقطع.في "معاني القرآن"، "تهذيب اللغة": (في معنى لكن).في "معاني القرآن" له 1/ 457 نقله عنه بنصه.في (ج): (الا استثناء).المعنى: ليست في "معاني القرآن".في "تفسيره" 4/ 50. نقله عنه بالمعنى.زيادة من (أ).في (ج): (بالاستغناء).في المرجع السابق. نقله بالمعنى.من قوله: (أراد ..) إلى (بحبل من الله): مكرر في (أ).في (ج): (ماح).(خطأ): ساقطة من: (ب).لم أقف على هذا القائل. وممن ذهب إلى أن الاستثناء منقطع ونصر هذا الرأي: ابن عطية في "المحرر الوجيز" 3/ 270.في (ج): (إن الله عز).ما بين المعقوفين: زيادة من (ج).وهو اختيار ابن عطية في "المحرر الوجيز" 3/ 270 - 271.ممن قال بذلك: ابن زيد، ومقاتل. انظر: "تفسير مقاتل" 1/ 293، "تفسير الطبري" 7/ 73.ما بين المعقوفين: زيادة من: (ج).في (أ)، (ب)، (ج): كلي.قوله في "تفسير الطبري" 4/ 48، "تفسير ابن أبي حاتم" 3/ 735، وأورده السيوطي في " الدر" 2/ 115 وزاد نسبة إخراجه لابن المنذر.في (ج): أخذونه.انظر: "تفسير البسيط" [البقرة: 61].
3,113," قوله تعالى: <q>﴿لَيْسُوا سَوَآءً﴾</q> قال أبو الهيثم {1}: يقال: (فلانٌ وفلانٌ سَواء) {2}؛ أي: متساويان، و (قوم سَواء)؛ لأنه مصدر لا يُثَنّى ولا يُجمع. ومضى الكلام في (سواء) في أول سورة البقرة {3}. قال ابن الأنباري {4}: يريد: ليس أهل الكتاب الذين سبق ذكرُهم وتقدم وصفُهم، سواءً؛ أي: متساوين في دينهم ومذهبهم. ثمّ ابتدأ فقال {5}: <q>﴿مِنْ أَهْلِ الْكِتَابِ أُمَّةٌ قَائِمَةٌ﴾</q> إنقطع الكلامُ عند (سواءً)، ورفع (الأُمة) بـ (مِنْ) {6}، وأضمر {7} (الأمَّة) المذمومة؛ لأن القائمة تكفي من التي ليست بقائمة، على مذهب العرب من الاكتفاء بالشيء من ضده، كما قال أبو ذؤيب {8}: عَصاني إليها القَلْبُ إِنّي لأمرها ... مطيعٌ فما أدري أَرُشْدٌ طِلابُها؟ {9} أراد: أم غيٌّ؟. فاكتفى بالرُّشد مِن غيره {10}. وقال آخر: وما أدري إذا يَمَّمْتُ أرضًا ... أُريدُ الخيرَ أيُّهُما يَلِيني {11} أراد {12}: أريد الخير والشر، فاكتفى بالخير من الشر {13}. ويجوز أن يرتفع (الأُمَّة) {14} بـ (سواء)، ويكون المعنى: لا يستوي من أهل الكتاب أمَّةٌ قائمةٌ، وأخرى غيرُ قائمةٍ. وهذا الذي ذكر {15} ابنُ الأنباري، كُلُّهُ مذهبُ الفرّاء في هذه الآية {16}. قال [أبو إسحاق] {17}: هذا الذي قاله {18}، خطأ فاحش في هذا المكان {19}؛ لأن ذِكْرَ أهلِ الكتابِ قد جرى في هذه القصة، وأنهم كانوا يكفرون بآيات الله، ويقتلون [الأنبياء] {20}، فأعلمَ اللهُ عز وجل أنَّ منهم المؤمنين، الذين هم {21} أمةٌ قائمةٌ، فما الحاجَةُ إلى أن يقال: غير قائمة؟ وإنما [المبدوء] {22} به ما {23} كان مِن فِعْلِ أكثرِهم؛ من الكفر والمُشَاقَّةِ للنبي ﷺ. فّذَكَرَ مَنْ كان منهم مباينًا لهؤلاء. فعند الزجّاج: لا يحتاج إلى إضمار الأمَّةِ المذمومة؛ لأن ذِكْرَ أهلِ الكتاب قد جرى، ثُمّ أخبر الله تعالى أنهم غير متساوين، بقوله: <q>﴿لَيْسُوا سَوَاءً﴾</q>، وههنا وقف التمام. ثُمّ أنبأ بافتراقهم، فقال: <q>﴿مِنْ أَهْلِ الْكِتَابِ أُمَّةٌ قَائِمَةٌ﴾</q> {24} قال أبو بكر {25}: وقول الفرّاء هو الحق، واحتجاج الزّجاج عليه مُخْتَلٌّ {26} فاسد، لأنه لو اكتفى بقوله: <q>﴿ذَلِكَ بِأَنَّهُمْ كَانُوا يَكْفُرُونَ بِآيَاتِ اللَّهِ وَيَقْتُلُونَ﴾</q> [آل عمران: 112] من إضمار الأُمَّة الكافرة بعد ذِكْرِ الأُمَّة المؤمنة، لاكتفى بقوله عز وجل: <q>﴿مِنْهُمُ الْمُؤْمِنُونَ وَأَكْثَرُهُمُ الْفَاسِقُونَ﴾</q> [آل عمران: 110]، مِن ذِكْر الأُمَّتين جميعًا؛ فلما لم يكتفِ بالمؤمنين من الأُمَّة القائمة، لم يكتفِ بالفاسقين من الأُمَّة الكافرة، إذْ كان الله جل وعلا أتى بإخبار بعد إخبار، وَوَصْفٍ لهم إثْرَ وَصْفٍ؛ للزيادة {27} في الإفهام، والمبالغة في الإيضاح والبيان. والله أعلم. وكان أبو عبيدة يذهب مذهب الفرّاء: من إضمار الأُمَّة المذمومة، إلّا أنه لا يجعل تمامَ الوقف عند قوله: <q>﴿لَيْسُوا سَوَاءً﴾</q>، ويقول {28}: (الأُمَّة) رُفِع بـ <q>﴿لَيْسُوا﴾</q>. قال: وجُمِعت (ليس) وهي مُقَدَّمة، على لغة مَن يجمع الفعلَ وإن يقدم، كقولهم: (أكلوني البراغيثُ) {29}، واحتج بقول الفرزدق: ولكنْ دِيافِيٌّ أَبُوهُ وأُمُّهُ ... بِحَوْرانَ {30} يَعْصِرْنَ السَّلِيطَ أقارِبُهُ {31} ولم يرتض هذا القولَ أحدٌ مِن النحويين، وقالوا: هذا الذي قاله، لغة رديئة في القياس والاستعمال. أما القياس؛ فلأن الجمعَ عارِضٌ، والعارِضُ لا تُؤكَّد عَلامَتُه؛ لأنه بمنزلة ما لا يُعتَدُّ بِه، وليس كالتأنيث؛ للزومه، فَتُقَدَّم [له] {32} العَلامَةُ؛ لِتُؤذِنَ به قبل ذِكْرِهِ. ومع {33} [هذا؛ فجائز] {34} تركها فيه، فكيف {35} بالعارض {36}؟ ولزوم {37} الفعل للفاعل يغني عن التثنية والجمع فيه، فلا يدخل جمعٌ على جمع، كما لا يدخل تعريفٌ على تعريف. وأما الاستعمال؛ فإن أكثر العرب تَرَك هذه اللغة، وهي من لغة من لا يُرتَضى لغتُه، ولم ينزل الله عز وجل كتابَه إلا بأعرب اللغات، وأقربها من البيان. ومتى جُمع الفعلُ مُقدَّمًا [أوْهَمَ] {38} أسماءً {39} قبله، ولم يَقِفْ المخاطَبُ على معنى الكلام، إلّا بعد تفكر [من التَّوَهُّم] {32}. ومعنى <q>﴿أُمَّةٌ قَائِمَةٌ﴾</q>: قال ابن عباس {41}: يريد: قائمة على الحَقِّ، وعلى أمر الله، لم تتركه كما تركه الآخرون. وقال مجاهد {42}: عادلة. وقال السُدِّي {43}: قائمة بطاعة الله. وقال ابن قتيبة {44}: مواظبة على أمر الله. وقوله تعالى: <q>﴿يَتْلُونَ آيَاتِ اللَّهِ﴾</q>. أي: يقرأون كتاب الله. <q>﴿آنَاءَ اللَّيْلِ﴾</q>. ساعاته. والواحد: (إنًى)، مقصورٌ؛ مثل: (مِعًى) {45}. قال الراجز: لله درُّ جعفرٍ أيَّ فتًى ... مُشَمِّرٍ عن ساقه كُلَّ إنًى {46} ويجوز: (إنْيٌ)، مثل: (نِحْيٌ) {47}، و (حِسْيٌ) {48}. قال الأعشى: في كلِّ إنْيٍ حَذَاهُ الليلُ يَنْتَعِلُ {49} قال المفسرون: يعني بـ (الأُمَّة القائمة) ههنا: عبد الله بن سلام، ومن آمَنَ معه من أهل الكتاب. هذا قول ابن عباس {50}، وقتادة {51}، وابن جريج {52}. وقوله تعالى: <q>﴿وَهُمْ يَسْجُدُونَ﴾</q> قال الفرَّاء {53}، والزجاج {54}: أي: يُصلُّون؛ لأن التلاوة لا تكون في السجود ولا في الركوع. فالمراد بـ (السجود) (هنا) {55}: الصلاة، وإنَّما ذكرت بلفظ السجود؛ لأن السجود نهاية ما فيها من التواضع. فعلى ما ذكروا {56}؛ الواو في (وهم) واو الحال؛ أي: يقرأون القرآن مُصَلِّينَ. وقال غيرهما {57}: يجوز أن يكون المراد: حقيقة السجود، لا الصلاة؛ فيكون التأويل: يتلون آيات الله آناء الليل {58}، وهم مع ذلك يَسجدون. فليست الواوُ حالًا، وإنَّما هي عطف جملةٍ على جملة {59}. وعلى هذا؛ لم يعدل بالسجود عن ظاهره. وقال ابن مسعود {60}: هذه في صلاة العَتَمَة؛ يصلونها، ومن سواهم من أهل الكتاب لا يصليها. ",footnotes:1:قوله في "تهذيب اللغة" 2/ 1794 (سوى).في "تهذيب اللغة": (سواعد) -بدلًا من: (سوى) - ويبدو أنها تصحيف.عند آية 6 من سورة البقرة. انظر حول (سواء): "الوجوه والنظائر" لهارون بن موسى 36، و"تحصيل نظائر == القرآن" للحكيم الترمذي 27، "الأضداد" لابن الأنباري 40، "الحجة" للفارسي 1/ 245، "الصحاح" 6/ 2384 (سواء)، و"قاموس القرآن" للدامغاني ص 252، و"التصاريف" لمكي 111، و"نزهة الأعين النواظر" 359، "المغني" لابن هشام 187 - 189.لم أقف على مصدر قوله. وقد ورد بعضُ قوله في "إيضاح الوقف والابتداء" له: 2/ 582.فقال: ساقطة من: (ب).ممن قال بالوقف التام -هنا- أكثر أهل العلم، ومنهم: نافع، ويعقوب، والأخفش، والزجاج، وأبو حاتم. انظر: "القطع والائتناف" للنحاس: 232، "معاني القرآن" للأخفش 1/ 213، "معاني القرآن" للزجاج 1/ 458، و"منار الهدى" للأشموني 68 وقال: (وهو الأصح). وإعراب <q>﴿أُمَّةٌ﴾</q> على هذا الوجه: مبتدأ مؤخر، و <q>﴿مِن أَهلِ الكِتَابِ﴾</q> خبر مقدم. انظر: "التبيان" للعكبري: ص 205.في (ج): (فأضمر).في (ج): (ذيب). وهو: خويلد بن خالد بن مُحرِّث الهُذَلي. تقدم.ورد البيت منسوبًا له في "شرح أشعار الهذليين" 1/ 43، "تأويل مشكل القرآن" ==215، "تفسير الثعلبي" 3/ 101 - ب، "مغني اللبيب" 18، 59، 820، وانظر: "شرح شواهد المغني" 27، 142، 672)، "الدرر اللوامع" 2/ 172. كما ورد غير منسوب في "معاني القرآن" للفراء: 1/ 230، "منهج السالك" 3/ 116، "همع الهوامع" 5/ 241. وقد ورد في بعض المصادر: (دعاني إليها القلب) وفي معاني الفراء، وتأويل المشكل، وتفسير الثعلبي: (عصيت إليها القلب) كما ورد في جميع المصادر المذكورة: (إني لأمره * سميع ..). قال الأصمعي: (عصاني القلب): جعل لا يقبل مني؛ أي: ذهب إليها قلبي سفها، فأنا أتبع ما يأمرني به، فما أدري أرُشدٌ الذي وقع فيه أم غيٌّ). "شرح أشعار الهذليين" 1/ 43.وقد تطرق المؤلف لهذا المعنى عند الآية: 6 من سورة البقرة.في (ج): (أيهما أريد). والبيت للمثقب العبدي، وهو في ديوانه: 212. وورد منسوبًا له، في "المفضليات" 574، "الشعر والشعراء" 1/ 403، و"الصناعتين" 205، و"الحماسة البصرية" 1/ 40، "شرح شواهد المغني" 191، "خزانة الأدب" 11/ 80 وورد غير منسوب في "معاني القرآن" للفراء: 231. وروايته في "المفضليات": (يممت أمرًا ..)، وعند الفراء: (يممت وجها ..) وفي "الحماسة البصرية" كما عند المؤلف، وفي "شرح شواهد المغني" "الخزانة": (وجهت وجهًا ..). وبعد هذا البيت: أألخير الذي أنا أبتغيه ... أم الشر الذي هو يبتغيني ومعنى (يميت): قصدت، و (يليني): من (الوَلْي)، وهو: القرب.في (ج): (المعنى: لا يستوي أراد). ولم أثبت هذه الزيادة؛ لأنه لا وجه لها، ويبدو أنها سبق قلم من الناسخ.انظر المصادر السابقة التي أوردت البيتين؛ حيث تطرقت إلى موضوع الحذف الوارد في الآية.في (ج): (الأمر).في (ج): (ذكره).انظر: "معاني القرآن" للفراء 1/ 230.ما بين المعقوفين غير مقروء في (أ). والمثبت من: (ب)، (ج). وقوله في "معاني القرآن" له: 1/ 460. نقله عنه بنصه.في (ج): (قال).في "معاني القرآن" في مثل هذا المكان.ما بين المعقوفين: مطموس في (أ). ومثبت من (ب)، (ج)، "معاني القرآن".هم: ساقطة من (ب).ما بين المعقوفين: في (أ): البدو. والمثبت من (ب)، (ج)، "معاني القرآن".في (ب): (مما).في (أ)، (ب): <q>﴿لَيْسُوا سَوَاءً مِنْ أَهْلِ الْكِتَابِ أُمَّةٌ قَائِمَةٌ﴾</q>. وما أثبته من: (ج)؛ لأنه الأولى والأنسب بسياق الكلام. وما ورد في (أ)، (ب) مما سبق به الفكر والقلب عادة في مثل هذه المواطن.هو ابن الأنباري، كما سبق، ولم أقف على مصدر قوله وهو من تتمة النقل السابق عنه.في (ج): (محتمل).في (ج): (الزيادة).لم أقف على مصدر قوله وليس موجودًا في "مجاز القرآن" بهذا النص؛ ونَصُّهُ == في (المجاز) هو: (العرب تُجوِّزُ في كلامهم مثل هذا أن يقولوا: (أكلوني البراغيثُ)، قال أبو عبيدة: سمعتها من أبي عمرو الهذلي في منطقه، وكان وجه الكلام أن يقول: (أكلني البراغيث). وفي القرآن: <q>﴿عَمُوا وَصَمُّوا كَثِيرٌ مِنْهُمْ﴾</q> [المائدة: 71]، وقد يجوز أن يجعله كلامين، فكأنك قلت: <q>﴿لَيْسُوا سَوَاءً مِنْ أَهْلِ الْكِتَابِ﴾</q>، ثم قلت: <q>﴿أُمَّةٌ قَائِمَةٌ﴾</q>.) "المجاز" 1/ 101 - 102.هذا مثل وضع عَلَما على لغة (طيئ)، وقيل لغة (أزد شنوءة)، أو (بلحارث)، وكما ورد في الهامش السابق عن أبي عبيدة أنه نطق بها بعض (هذيل). وقد ألحقوا في هذه اللغة علامة الجمع أو التثنية بالفعل، مع ظهور الفاعل، فجمع في (أكلوني البراغيث) واو الجماعة والاسم الظاهر. والأصل المتبع أن يقال: (أكلني البراغيث). انظر الكلام عن هذه اللغة في "كتاب سيبويه" 2/ 40 - 41، "معاني القرآن" للفراء: 1/ 316، "المسائل المشكلة" للفارسي: 109، "سر صناعة الإعراب" 629، "نتائج الفكر" للسهيلي:166، "إعراب الحديث النبوي" للعكبري: 125، 137 - 138، "رصف المباني" 111، "الجنى الداني" 150، 170، "البحر المحيط" 3/ 24، "مغني اللبيب" 478، "أوضح المسالك" ص 82، "همع الهوامع" 2/ 256، "الاقتراح في علم أصول النحو" للسيوطي: 43، "معجم الشوارد النحوية" 108.في (أ)، (ب)، (ج): (بحوزان). والمثبت من: الديوان ومصادر البيت.البيت في ديوانه: 44. وقد ورد منسوبًا له في "كتاب سيبويه" 2/ 40 (وانظر شرح أبيات سيبويه، للنحاس: 113)، "أمالي بن الشجري" 1/ 201، "شرح المفصل" 3/ 89، 7/ 7، "معجم البلدان" 2/ 494، "خزانة الأدب" 5/ 63، 234، 7/ 346، 446، 11/ 372، "اللسان" 2/ 1193 (خطأ)، 4/ 2065 (سلط)،== 3/ 1455 (دوف)، "الدر اللوامع" 1/ 142. وورد غير منسوب في "الحجة" للفارسي: 1/ 132، "الخصائص" 2/ 194، و"إعراب الحديث النبوي" 125، 138، "رصف المباني" 112، "الجنى الداني" 150، "همع الهوامع" 2/ 256. والبيت من قصيدة قالها في هجاء عمرو بن عفراء الضبِّي. و (دِيافيّ) نسبة إلى (دِياف) وهي من قرى الشام، وأهلها نَبَط، و (حوران): من قرى الشام. انظر: "معجم البلدان" 2/ 494، "الخزانة" 5/ 235. و (السليط): الزيت. وقيل: كل دهن عصر من حب. انظر: "اللسان" 4/ 2065 (سلط). يقول الشاعر -هنا- عن المهجو: إنَّ أهله من النَّبطِ، وليسوا من العرب الخلَّص، أصحاب الانتجاع والشجاعة والحروب، بل هم من أهل (دِياف)، ممن يعيشون على عصر الزيت. وزاده هجاءً بقوله: (يعصرن) -بنون النسوة- يشبههم بالنساء ذوات الخدمة والتبذل، وليسوا كالرجال ممن شأنهم الحروب. والشاهد فيه: قوله: (يعصرن السليط أقاربه) ولم يقل (يعصر)، على الأصل، حيث إنه فعل مقدمة، وفاعله (أقاربه)، والنون في الفعل علامة لكون الفاعل جمعًا.ما بين المعقوفين زيادة من: (ج).في (ج): مع.ما بين المعقوفين: غير مقروء في (أ). وفي (ب): هذا الحيز. والمثبت من: (ج).في (ج): (وكيف).في (ب): (العارض).في (ب): ولزومه. في (ج): (ولزم).في (أ)، (ب)، (ج): وهم. وما أثبته هو كما رجحت صوابه؛ لأني لم أجد في معاجم اللغة التي رجعت إليها، أن (وهم) يتعدى بدون الهمزة، أو بالتضعيف. وما يؤكد هذا أن الواو في (وهم) لصقت بالألف في (مقدما) في (أ)، (ج).في (ب): (إنهاء).ما بين المعقوفين زيادة من: (ج).قوله في "تفسير الطبري" 4/ 54، "ابن أبي حاتم" 3/ 738، "معاني القرآن" للنحاس: 1/ 462، "تفسير البغوي" 2/ 93، وقد رجح هذا الطبري في تفسيره في الموضع السابق، وابن كثير في "تفسيره" 1/ 427.قوله في "تفسيره" 133، "تفسير الطبري" 4/ 53، "تفسير ابن أبي حاتم" 3/ 738، "معاني القرآن" للنحاس: 1/ 462، "تفسير البغوي" 2/ 93، "الدر المنثور" 2/ 116 وزاد نسبته لعبد بن حميد.قوله في "تفسير الطبري" 4/ 53، "ابن أبي حاتم" 3/ 737، "البغوي" 2/ 93.في "تفسير غريب القرآن" له 108.في (أ)، (ب)، (ج): (معًا). والمثبت من كتب اللغة. انظر: "تهذيب اللغة" 1/ 225 (أنى).في (ب): (أنى). ولم أقف على قائله، وقد أورده الثعلبي في "تفسيره" 3/ 102 أ، ولم يعزه لقائل، ولم أقف على مصادر أخرى له.في (ب): (محي). والنِحْيُ: الزِّقُّ -وهو السقاء الذي يُتَّخذ للشراب، أو ما كان للسمن خاصة-، أو نوع من الرُّطَب، أو سهم عريض النصل. ويقال -كذلك-: (النِّحْي، والنَّحَى). والجمع: (أنحاء، ونُحِيٌّ، ونِحاءٌ). انظر: (نحا) في "اللسان" 7/ 4372، "القاموس" ص 1337.الحِسْيُ: سهل من الأرض يستنقع فيه الماء. وقيل: غِلَظٌ فوقه رمل يجتمع فيه ماء المطر، فكلما نَزحتَ دلوا جمَّت أخرى. والجمع: أحساء. انظر: "الصحاح" 1313 (حسا)، "المجمل" 233 (حسو)، "اللسان" 2/ 880 (حسا)، "القاموس" ص 1274 (حسا).في (أ)، (ب)، (ج): ورد البيت كالتالي: (في كل إنيٌ جداه الليل شغل). وما أثبته فمن مصادر البيت. والبيت ليس للأعشى كما ذكر المؤلف، بل هو لأبي أُثَيْلَة، المُتَنَخِّل، مالك بن عويمر بن عثمان الهُذَلي. وقد ورد منسوبًا له في "سيرة بن هشام" 2/ 186، "مجاز القرآن" 1/ 102، 2/ 33، "شرح أشعار الهذليين" 3/ 1283، "الشعر والشعراء" ص 439، "الصحاح" 2273 (أنا)، "اللسان" 1/ 162 (أنى).= وورد غير منسوب في "تفسير الطبري" 4/ 54، "معاني القرآن" للزجاج: 1/ 459، "المنتخب" لكراع النمل: 2/ 608، "معاني القرآن" للأخفش: 1/ 214، وكتاب "حروف الممدود والمقصور" للكسائي: 64، "المنصف" 2/ 107، "تهذيب اللغة" 1/ 3614 (نعل)، 1/ 225 (أنى)، "تفسير الثعلبي" 3/ 102 أ. وأول البيت: حلْوٌ ومُرٌّ كَعَطْفِ القِدْح مِرَّتُهُ وقد ورد في بعض المصادر: (بكل إني ..)، وورد: (قضاه الله ..)، و (قضاه الليل ..) بدلًا من: (حذاه الليل)، وفي المنتخب، لكراع النمل: (حَدَاهُ الليل)، وورد: (كعطف القدح شيمتُهُ ..). الشاعر -هنا- يرثي ابنه أثَيْلَة، ويصفه بأنه (حلو ومر)؛ أي: حلو وسهل لمن يستحق المعاملة الحسنة، ومرٌّ وشديد على من يستحق الشدة والخشونة. وقوله: (كعطف القدح)، (القِدْح): السهم قبل أن يُراش ويُنْصل. و (المِرَّة): الشِّدّة، والقوة. يريد: أنه يُطوَى كما يُطوَى القِدح، ثم يعود إلى شدَّته واستقامته. قوله: (حذاه الليل): أي: قطعة اليل حِذاءً. و (ينتعل)، أي: يتخذه نعلًا. أي: إنه يسري في كل ساعة من ساعات الليل، لا يتأَخر ولا يهاب. انظر: "شرح أشعار الهذليين" 2/ 1283، وتعليق الأستاذ محمود شاكر على البيت في هامش "تفسير الطبري" 7/ 125 - 126. وفسر كراع النمل: (حداه الليل)؛ أي: ساقه وقال: (أي: ينتعل كل إنيٍ حداه؛ أي: ساقه، و (في) زائدة) المنتخب: 608.قوله في "تفسير الطبري" 4/ 52، "تفسير ابن أبي حاتم" 3/ 737، "الدر المنثور" 2/ 115، وزاد نسبة إخراجه لابن إسحاق، وابن المنذر، والطبراني، والبيهقي في الدلائل، وابن عساكر.لم أقف على مصدر قوله وقد أورده ابن الجوزي في الزاد: 1/ 442. والذي في تفسير الطبري عنه: (ليس كل القوم هلك، قد كان لله فيهم بقية) 4/ 52.قوله في "تفسير الطبري" 4/ 52.في "معاني القرآن" له 1/ 231.في "معاني القرآن" له 1/ 459. المؤلف -هنا- دمج بين عبارات الفراء والزجاج، ولفَّقَ بينها.زيادة من (أ).في (أ) و (ج): (ذكر).ممن قال ذلك: الطبري في "تفسيره" 4/ 56، رادًّا على الفراء رأيَه السابق. والعبارة التالية قريبة من عبارته في تفسيره.(آناء الليل): ساقطة من: (ج).أي: أنها معطوفة على قوله تعالى <q>﴿يَتْلُونَ﴾</q>، في موضع رفع نعت لـ <q>﴿أُمَّةٌ﴾</q>. وقد تكون مستأنفة لا محل لها من الإعراب. واستحسن هذا مكِّي بن أبي طالب.قوله في "تفسير الطبري" 4/ 55، "تفسير ابن أبي حاتم" 2/ 739، "التاريخ == الكبير" للبخاري 1/ 2/ 308، وأورده السيوطي في "الدر" 2/ 116 وزاد نسبة إخراجه للفريابي، وعبد بن حميد، وابن المنذر. وقد وردت في رواية أخرى للطبري عن ابن مسعود عبارةٌ مُدرَجة، تبيِّن أن صلاة العتمة هي صلاة العشاء، ونصها: (خرج علينا رسول الله ﷺونحن ننتظر العشاء- يريد: العتمة- فقال لنا: ما على الأرض أحدٌ من أهل الأديان ينتظر هذه الصلاة في هذا الوقت غيركم. قال: فنزلت: <q>﴿لَيْسُوا سَوَاءً﴾</q>). وقد يكون الإدراج من الطبري أو من أحد رواة الأثر عن ابن مسعود. أخرج هذه الرواية: أحمد 1/ 396، والطبري في "تفسيره" 4/ 55، وابن أبي حاتم 3/ 738، والنسائي في "تفسيره" 1/ 320، وابن حبان (الإحسان) 4/ 397 رقم: 1530)، والبزار (انظر: "كشف الأستار" 1/ 190 رقم: 375)، والواحدي في "أسباب النزول" ص123، وانظر: "تفسير ابن مسعود" 1/ 176 - 178. وقد ورد عن ابن عباس، والسُدِّي تفسير <q>﴿آنَاءَ اللَّيْلِ﴾</q> بجوف الليل. وعن الثوري، عن منصور بن المعتمر السلمي: أنها بين المغرب والعشاء. وهي معان متقاربة، لأن كلًّا منها يصدق عليه أنه من آناء الليل. إلا أن الطبري يرى أن أَوْلاها، هو قول من قال: هي تلاوة القرآن في صلاة العشاء، لأنه صلاة لا يصليها أحد من أهل الكتاب. انظر: "تفسير الطبري" 4/ 54 - 56، "تفسير ابن أبي حاتم" 3/ 738 - 739.
3,114," قوله تعالى <q>﴿يُؤْمِنُونَ بِاللَّهِ وَالْيَوْمِ الْآخِرِ وَيَأْمُرُونَ بِالْمَعْرُوفِ﴾</q> قال ابن عباس {1}: يريد: بتوحيد الله. <q>﴿وَيَنْهَوْنَ عَنِ الْمُنْكَرِ﴾</q>: يريد: عن الشرك بالله. وقال الزجاج {2}: أي: يأمرون باتِّباع {3} النبي ﷺ، وينهون عن الإقامة على مُشَاقَّتِه. وقوله تعالى: <q>﴿وَيُسَارِعُونَ فِي الْخَيْرَاتِ﴾</q> فيه وجهان لأصحاب المعاني: أحدهما: أنهم يبادرونها خوف الفَوْتِ بالموت {4}. والآخر: [يعملونها] {5} غير متثاقلين {6} فيها {7}. والسُّرْعة محمودةٌ، بخلاف العَجَلَة؛ وذلك أنَّ (السرعة): التقدم فيما ينبغي أن تتقدم {8} فيه. ونقيضها مذموم، وهو: (الإبطاء) {9}. و (العَجَلَة) مذمومة، وهي: التقدم فيما لا ينبغي أن تتقدم {10} فيه {11}. ونقيضها: (الأَنَاة) {12}، وهي محمودة. ",footnotes:1:لم أقف على مصدر قوله. وفي "النكت والعيون" 2/ 881 أورد عن ابن عباس، أن (المعروف: اتباع الرسول. والمنكر: عبادة الأصنام).في "معاني القرآن" له 1/ 460. نقله عنه بنصه.في (ب): (يأمرون بتوحيد الله باتباع النبي).ممن قال بذلك: الطبري في "تفسيره" 4/ 56. وهو المتبادر من معنى الآية.ما بين المعقوفين في (أ)، (ب): (يعلمونها). والمثبت من: (ج).في (ب): (متشاقين).لم أقف على من قال بهذا القول، ممن سبق المؤلف.في (ب): (يتقدم).انظر: "اللسان" 4/ 1994 (سرع)، "بصائر ذوي التمييز" 3/ 214.في (ب): يتقدم.قال الفيروز آبادي: (والعجلة من مقتضيات الشهوة؛ فلذلك ذُمَّت في جميع القرآن، حتى قيل: إن العجلة من الشيطان. وقوله -تعالى-: <q>﴿وَعَجِلْتُ إِلَيْكَ رَبِّ لِتَرْضَى﴾</q> [طه: 84]، ذُكر أن عجلته -وإن كانت مذمومة- فالذي دعا إليها أمرٌ محمود، وهو: طلب رضا الله). "بصائر ذوي التمييز" 4/ 23.في (ب): (الإناء).
3,115," قوله تعالى: <q>﴿وَمَا يَفْعَلُوا مِنْ خَيْرٍ فَلَنْ يُكْفَرُوهُ﴾</q> موضع <q>﴿يَفْعَلُوا﴾</q>: جزم بالشرط، وجوابه: <q>﴿فَلَنْ يُكْفَرُوهُ﴾</q>. وفيهما قراءتان {1}: الياءُ؛ للكناية عن الأُمَّةِ القائمة، ثم سائر الخلق داخل في هذا الشرط. ومن قرأ بالتَّاء؛ فلأن نظائره جاءت بالتَّاء؛ مخاطبة لجميع الخلائق، من غير تخصيص قوم دون قوم؛ كقوله: <q>﴿وَمَا تَفْعَلُوا مِنْ خَيْرٍ يَعْلَمْهُ اللَّهُ﴾</q> [البقرة: 197]، <q>﴿وَمَا تُنْفِقُوا مِنْ خَيْرٍ يُوَفَّ إِلَيْكُمْ﴾</q> {2} [البقرة: 272]. ومعنى <q>﴿فَلَنْ يُكْفَرُوهُ﴾</q>: فلن تعدموا {3} ثوابه، ولن تُجحَدوا جزاءَه {4} وسُمِّيَ منعُ الجزاء على عمل الخير كفرًا؛ لأنه بمنزلة الجَحْدِ له، والسَّتْر {5}؛ لئلا يقع الجزاء عليه. ولمَّا جعل ثواب الطاعة من الله تعالى شُكْرًا لأن معنى الشاكر في {6} صفته: أنَّه يُثِيب {7} على الطاعة {8} جعل منع الثواب كفرًا. ومعنى {9} قوله تعالى: <q>﴿وَاللَّهُ عَلِيمٌ بِالْمُتَّقِينَ﴾</q> أي: لا يُضيع شيئًا من أعمالهم {10}؛ لأن المُجازي به عليمٌ بهم. ",footnotes:1:قرأ حمزة، والكسائي، وحفص عن عاصم بالياء في <q>﴿يَفعَلُوا﴾</q> و <q>﴿يُكفَرُوهُ﴾</q>. وقرأ ابن كثير، ونافع، وأبي بكر عن عاصم، وابن عامر، بالتاء فيهما. وورد عن أبي عمرو القراءة بالياء، والتاء. انظر: "السبعة" 215، "الحجة" للفارسي: 3/ 73، "النشر" 2/ 241.ورد في (أ)، (ب)، (ج): (وما تفعلوا من خير يوف غليكم) وليست هذه آية قرآنية. والصواب ما أثبته. وقد أورد هذه الآية في هذا الموضع -في سياق بيان وجه القراءة بالتاء- الفارسيُّ في "الحجة" 3/ 73 - وهو من مصادر المؤلف في كتابه هذا-، وكذا أوردها مكيُّ في "الكشف" 1/ 354.في (ب): (تقدموا). وقوله: (ولن تعدموا ثوابه ولن تجحدوا جزاءه): بنصها في "تفسير الثعلبي" 3/ 103أ.في (ج): (جزاه). انظر: "تفسير الطبري" 4/ 57.أصل معنى كلمة (كفر): السَّتْر والتغطية. انظر: (كفر) في "تهذيب اللغة" 4/ 3160. "مقاييس اللغة" 5/ 191. وعبارة الطبري في بيان معنى الآية: (فلن يغطي على ما فعلوا من خير، فيتركوا بغير مجازاة، ولكنهم يشكرون على ما فعلوا من ذلك فيجزل لهم الثواب). "تفسيره" 4/ 57، وانظر: "المحرر الوجيز" 3/ 280.في (ج): (مع).في (ج): (يثبت).قال الزجاج: (فكأن الشكر من الله -تعالى- هو: إثابتة الشاكر على شكره، وقبوله للطاعة شكرا على طريقة المقابلة؛ كما قال عز اسمه: <q>﴿فَمَنِ اعْتَدَى عَلَيْكُمْ فَاعْتَدُوا عَلَيْهِ بِمِثْلِ مَا اعْتَدَى عَلَيْكُم﴾</q> [البقرة: 194]). "تفسير أسماء الله الحسنى" 48. ونقل الأزهري عن الزجاج -كذلك- قوله: (والشكور من أسماء الله -جل وعز- معناه: أنه يزكو عنده القليل من أعمال العباد، فيضاعف لهم به الجزاء). "تهذيب اللغة" 2/ 1913.ومعنى: ساقطة من: (ج).في (أ) و (ج): (عملهم).
