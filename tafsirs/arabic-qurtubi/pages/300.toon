quran[8]{c,v,t}:
  18,54,"<div class=ar lang=ar><p>قوله تعالى: <span class="qpc-hafs">﴿وَلَقَدْ صَرَّفْنَا فِي هَذَا الْقُرْآنِ لِلنَّاسِ مِنْ كُلِّ مَثَلٍ﴾</span> مفسرًا في سورة بني إسرائيل في موضعين {1}].</p><p>وقوله تعالى: <span class="qpc-hafs">﴿وَكَانَ الْإِنْسَانُ أَكْثَرَ شَيْءٍ جَدَلًا﴾</span> قال ابن عباس: (يريد النضر بن الحارث، وجداله في القرآن) {2}. وقال الكلبي: (يعني أبي بن خلف) {3} {4}.</p><p>وقال أبو إسحاق: (معناه كان الكافر، ويدل عليه قوله: <span class="qpc-hafs">﴿وَيُجَادِلُ الَّذِينَ كَفَرُوا بِالْبَاطِلِ﴾</span> [الكهف: 56] الآية. وإن قيل: هل يجادل غير الإنسان؟ قيل: إن إبليس قد جادل، وإن كل ما يعقل من الملائكة، والجن يجادل، ولكن الإنسان أكثر هذه الأشياء جدلاً) {5} {6}.</p></div>",footnotes:1:سورة الإسراء الآية رقم (41): <span class="qpc-hafs">﴿وَلَقَدْ صَرَّفْنَا فِي هَذَا الْقُرْآنِ لِيَذَّكَّرُوا وَمَا يَزِيدُهُمْ إِلَّا نُفُورًا﴾</span>. وقوله في الآية رقم (89): <span class="qpc-hafs">﴿وَلَقَدْ صَرَّفْنَا لِلنَّاسِ فِي هَذَا الْقُرْآنِ مِنْ كُلِّ مَثَلٍ فَأَبَى أَكْثَرُ النَّاسِ إِلَّا كُفُورًا﴾</span> [سورة الإسراء|2:"معالم التنزيل" 5/ 181، "المحرر الوجيز" 9/ 337، "البحر المحيط" 6/ 139.|3:أبي بن خلف بن وهب الجمحي، كان من أشد الناس وأكثرهم أذى للرسول -ﷺ- وللصحابة رضوان الله عليهم، رماه النبي -ﷺ- يوم أحد بحربة فقتله.</p><p>انظر: "جوامع السير" ص 54، "الكامل في التاريخ" 2/ 148 ، "الأعلام" 2/ 22.|4:"معالم التنزيل" 5/ 181، "البحر المحيط" 6/ 139، "القرطبي" 11/ 5.|5:"معاني القرآن" للزجاج 3/ 296.|6:الأولى -والله أعلم- أن تكون عامة في المؤمن والكافر، ويؤيد هذا ما ثبت في "الصحيحين" وغيرهما من حديث علي -رضي الله عنه- أن النبي -ﷺ- طرقه وفاطمة ليلاً فقال: ألا تصليان؟ فقلت: يا رسول الله إنما أنفسنا بيد الله إن شاء أن يبعثنا بعثنا، فانصرف حين قلت ذلك ولم يرجع إلى شيئًا، ثم سمعته يضرب فخذه ويقول: <span class="qpc-hafs">﴿وَكَانَ الْإِنْسَانُ أَكْثَرَ شَيْءٍ جَدَلًا﴾</span> [الكهف: 54].
  18,55,"<div class=ar lang=ar><p>قوله تعالى: <span class="qpc-hafs">﴿وَمَا مَنَعَ النَّاسَ﴾</span> قال ابن عباس: (يريد أهل مكة) {1}. <span class="qpc-hafs">﴿أَنْ يُؤْمِنُوا﴾</span> أي: الإيمان <span class="qpc-hafs">﴿إِذْ جَاءَهُمُ الْهُدَى﴾</span> محمد -ﷺ- جاءهم من الله بالرشاد والبيان {2}. وهذا مفسر في سورة بني إسرائيل {3}.</p><p>وقوله تعالى: <span class="qpc-hafs">﴿وَيَسْتَغْفِرُوا رَبَّهُمْ﴾</span> عطف على أن يؤمنوا.</p><p>وقوله تعالى: <span class="qpc-hafs">﴿إِلَّا أَنْ تَأْتِيَهُمْ سُنَّةُ الْأَوَّلِينَ﴾</span> قال صاحب النظم: (<span class="qpc-hafs">﴿سُنَّةُ اَلأَوَّلِينَ﴾</span> أنهم إذا تمردوا ولم يؤمنوا أن يعذبوا ويهلكوا) {4}.</p><p>يقول: فقدرت على هؤلاء العذاب أي: لم أقدر عليهم الإيمان، فذلك الذي يمنعهم من الإيمان؛ لأني قد قدرت عليهم الإهلاك وهو سنة الأولين {5} -وهذه الآية على هذا التفسير دليل إثبات القدر.</p><p>وقال أبو إسحاق: (المعنى إلاَّ طلب أن تأتيهم سنة الأولين، وسنة الأولين أنهم عاينوا العذاب فطلب المشركون ذلك <span class="qpc-hafs">﴿وَإِذْ قَالُوا اللَّهُمَّ إِنْ كَانَ هَذَا هُوَ الْحَقَّ﴾</span> [الأنفال: 32] {6}.</p><p>وقوله تعالى: <span class="qpc-hafs">﴿أَوْ يَأْتِيَهُمُ الْعَذَابُ قُبُلًا﴾</span> قال ابن عباس والكلبي: (يريد قتل المؤمنين إياهم ببدر) {7}. معنى <span class="qpc-hafs">﴿قبُلًا﴾</span>: عيانًا أي: مقابلة. قرأ أهل الكوفة: قُبُلاً {8}، وهو يحتمل تأويلين أحدهما: أنه بمعنى قِبَلاً، فقد قال أبو زيد: (لقيت فلانًا قِبَلاً ومُقابَلَةً وقَبَلاً وقُبُلاً وقَبَلِيّاً وقبيلاً) {9}. أي: صنفاً صنفاً، كل قبيل منه غير صاحبه، ويجوز أن يكون ضربًا واحدًا، ويجيئهم منه شيء بعد شيء. وهذا الحرف قد مضى تفسيره في سورة بني إسرائيل {10}، والأنعام {11}.</p></div>",footnotes:1:ذكرته كتب التفسير بلا نسبة. انظر: "المحرر الوجيز" 9/ 339، "الجامع لأحكام القرآن" 10/ 110، "روح المعاني" 15/ 300.|2:"معالم التنزيل" 5/ 182، "فتح القدير" 3/ 422.|3:عند قوله سبحانه في سورة الإسراء الآية رقم (94): <span class="qpc-hafs">﴿وَمَا مَنَعَ النَّاسَ أَنْ يُؤْمِنُوا إِذْ جَاءَهُمُ الْهُدَى إِلَّا أَنْ قَالُوا أَبَعَثَ اللَّهُ بَشَرًا رَسُولًا﴾</span>.|4:لم أقف عليه. ويشهد لهذا عدد من الآيات التي تحققت فيها سنته سبحانه في إهلاك من كفر وصد عن سبيله فعم قوم نوح الغرق، وأهلكت عاد الريح العقيم، وأخذت ثمود الصيحة، وقلبت على اللوطية ديارهم فجعل الله عاليها سافلها قال سبحانه == في سورة العنكبوت الآية رقم (40): <span class="qpc-hafs">﴿فَكُلًّا أَخَذْنَا بِذَنْبِهِ فَمِنْهُمْ مَنْ أَرْسَلْنَا عَلَيْهِ حَاصِبًا وَمِنْهُمْ مَنْ أَخَذَتْهُ الصَّيْحَةُ وَمِنْهُمْ مَنْ خَسَفْنَا بِهِ الْأَرْضَ وَمِنْهُمْ مَنْ أَغْرَقْنَا وَمَا كَانَ اللَّهُ لِيَظْلِمَهُمْ وَلَكِنْ كَانُوا أَنْفُسَهُمْ يَظْلِمُونَ﴾</span>.|5:ويشهد لهذا عدد من الآيات في كتاب الله، يقول -سبحانه وتعالى- في سورة يونس الآية (96، 97): <span class="qpc-hafs">﴿إِنَّ الَّذِينَ حَقَّتْ عَلَيْهِمْ كَلِمَتُ رَبِّكَ لَا يُؤْمِنُونَ (96) وَلَوْ جَاءَتْهُمْ كُلُّ آيَةٍ حَتَّى يَرَوُا الْعَذَابَ الْأَلِيمَ﴾</span>. وقوله تعالى في سورة يونس الآية (101): <span class="qpc-hafs">﴿قُلِ انْظُرُوا مَاذَا فِي السَّمَاوَاتِ وَالْأَرْضِ وَمَا تُغْنِي الْآيَاتُ وَالنُّذُرُ عَنْ قَوْمٍ لَا يُؤْمِنُونَ﴾</span>.|6:"معاني القرآن" للزجاج 3/ 296.|7:ذكرته كتب التفسير بدون نسبة. انظر: "معالم التنزيل" 5/ 182 بمعناه، "المحرر الوجيز" 9/ 340، "الكشاف" 2/ 294، "تفسير كتاب الله العزيز" 2/ 469. وذكره القرطبي في "الجامع لأحكام القرآن" 11/ 6 ونسبه لابن عباس والكلبي.|8:قرأ ابن كثير، ونافع، وأبو عمرو، وابن عامر: (قِبَلاً) بكسر القاف. وقرأ عاصم، وحمزة، والكسائي: (قُبُلاً) بضم القاف.</p><p>انظر: "السبعة" ص 393، "الحجة للقراء السبعة" 5/ 152، "المبسوط في القراءات" 236، "التبصرة" ص 249، "النشر" 2/ 311.|9:"جامع البيان" 15/ 267، "الحجة للقراء السبعة" 5/ 153، "لسان العرب" (قبل) 6/ 3520.|10:عند قوله سبحانه في سورة الإسراء الآية رقم (92): <span class="qpc-hafs">﴿أَوْ تُسْقِطَ السَّمَاءَ كَمَا زَعَمْتَ عَلَيْنَا كِسَفًا أَوْ تَأْتِيَ بِاللَّهِ وَالْمَلَائِكَةِ قَبِيلًا﴾</span>.|11:عند قوله سبحانه في سورة الأنعام الآية رقم (111): <span class="qpc-hafs">﴿وَلَوْ أَنَّنَا نَزَّلْنَا إِلَيْهِمُ الْمَلَائِكَةَ وَكَلَّمَهُمُ الْمَوْتَى وَحَشَرْنَا عَلَيْهِمْ كُلَّ شَيْءٍ قُبُلًا مَا كَانُوا لِيُؤْمِنُوا إِلَّا أَنْ يَشَاءَ اللَّهُ وَلَكِنَّ أَكْثَرَهُمْ يَجْهَلُونَ﴾</span>
  18,56,"<div class=ar lang=ar><p>وقوله تعالى: <span class="qpc-hafs">﴿وَيُجَادِلُ الَّذِينَ كَفَرُوا بِالْبَاطِلِ﴾</span> قال ابن عباس: (يريد المستهزئين، والمقتسمين وأتباعهم) {1}. وجدالهم بالباطل: أنهم ألزموه أن يأتي بالآيات على أهوائهم على ما كانوا يقترحون.</p><p>وقوله تعالى: <span class="qpc-hafs">﴿لِيُدْحِضُوا بِهِ الْحَقَّ﴾</span> قال ابن عباس: (ليبطلوا به ما جاء به محمد -ﷺ-) {2}. ومعنى الإدحاض: الإذهاب والإهلاك. يقال: دَحَضَتْ رجله تَدْحَضُ دَحْضًا أي: زلت. ودَحَضْتَ حجته: إذا أبطلتها {3}.</p><p>ومن هذا ما روي في الحديث: (أنه كان يصلي الأولى حين تَدْحَض الشمس) {4}. أي: تزول وتزلق عن بطن السماء.</p><p>وقوله تعالى: <span class="qpc-hafs">﴿وَاتَّخَذُوا آيَاتِي﴾</span> يعني القرآن <span class="qpc-hafs">﴿وَمَا أُنْذِرُوا﴾</span> وإن جعلت <span class="qpc-hafs">﴿مَا﴾</span> موصولاً بمعنى: الذي، كان الراجع من الصلة محذوفًا على تقدير: وما أنذروا به أي: خوفوا به من النار والقيامة. وإن جعلت بمعنى المصدر لم يحتج إلى الراجع، ويكون المعنى: واتخذوا آياتي هزوا {5}. والهزؤ: مصدر وصف به، كقوله تعالى: <span class="qpc-hafs">﴿أَتَتَّخِذُنَا هُزُوًا﴾</span> [البقرة: 67]، وقد مر.</p></div>",footnotes:1:"الجامع لأحكام القرآن" 11/ 6.|2:ذكره الطبري في "جامع البيان" 15/ 267 بدون نسبة، وكذلك الثعلبي في "الكشف والبيان" 3/ 390 ب.|3:انظر: "تهذيب اللغة" دحض) 2/ 1154، "مقاييس اللغة" (دحض) 2/ 332، "القاموس المحيط" (دحض) 642، "الصحاح" (دحض) 3/ 1075.|4:أخرج نحوه البخاري كتاب: مواقيت الصلاة، باب: وقت الظهر عند الزوال 1/ 200، وأبو داود كتاب: الصلاة باب: وقت صلاة الظهر 1/ 285، وابن ماجه كتاب الصلاة، باب: وقت الظهر 1/ 221، والنسائي كتاب المواقيت، باب: أول وقت الظهر 1/ 176، والإمام أحمد في "مسنده" 4/ 420.|5:"الكشاف" 2/ 394، "البحر المحيط" 6/ 139، "التفسير الكبير" 21/ 141.
  18,57,"<div class=ar lang=ar><p>قوله تعالى: <span class="qpc-hafs">﴿وَمَنْ أَظلَمُ﴾</span> استفهام بمعنى التقرير أي: لا أحد أظلم: <span class="qpc-hafs">﴿مِمَّن ذُكِرَ﴾</span>. قال ابن عباس: (وعظ) {1}. ولهذا دخلت الباء في <span class="qpc-hafs">﴿بِآيَاتِ رَبِّهِ﴾</span> يريد: العقاب والعذاب. <span class="qpc-hafs">﴿فَأَعْرَضَ عَنْهَا﴾</span> قال: (يريد فتهاون بها) {2}. قال قتادة في هذه الآية: (إياكم والإعراض عن ذكر الله، فإن من أعرض عن ذكر الله فقد اغتر أكبر الغرة) {3}.</p><p>وقوله تعالى: <span class="qpc-hafs">﴿وَنَسِيَ مَا قَدَّمَتْ يَدَاهُ﴾</span> قال قتادة: (نسي ما سلف من الذنوب الكبيرة) {4}.</p><p>وقوله تعالى: <span class="qpc-hafs">﴿إِنَّا جَعَلْنَا عَلَى قُلُوبِهِمْ أَكِنَّةً أَنْ يَفْقَهُوهُ وَفِي آذَانِهِمْ وَقْرًا﴾</span> مفسر في سورة بني إسرائيل {5}، والأنعام {6}. <span class="qpc-hafs">﴿وَإِنْ تَدْعُهُمْ إِلَى الْهُدَى﴾</span> قال ابن عباس: (يريد إلى الإيمان) {7}. <span class="qpc-hafs">﴿فَلَنْ يَهْتَدُوا إِذًا أَبَدًا﴾</span> قال أبو إسحاق: (أخبر الله أن هؤلاء بأعيانهم أهل الطبع) {8}.</p></div>",footnotes:1:ذكره البغوي في "تفسيره" 5/ 182 بدون نسبة، وكذلك السمرقندي في "بحر العلوم" 2/ 304، والقرطبي في "الجامع لأحكام القرآن" 11/ 7.|2:ذكره القرطبي في "تفسيره" 10/ 112 بدون نسبة، والشوكاني في "فتح القدير" 3/ 423.|3:لم أقف عليه. ويدل عليه قوله سبحانه في سورة طه الآيات (124، 125، 126): <span class="qpc-hafs">﴿وَمَنْ أَعْرَضَ عَنْ ذِكْرِي فَإِنَّ لَهُ مَعِيشَةً ضَنْكًا وَنَحْشُرُهُ يَوْمَ الْقِيَامَةِ أَعْمَى (124) قَالَ رَبِّ لِمَ حَشَرْتَنِي أَعْمَى وَقَدْ كُنْتُ بَصِيرًا (125) قَالَ كَذَلِكَ أَتَتْكَ آيَاتُنَا فَنَسِيتَهَا وَكَذَلِكَ الْيَوْمَ تُنْسَى﴾</span>.|4:"جامع البيان" 15/ 268، وذكره السمرقندي في "بحر العلوم" 2/ 304 بلا نسبة.|5:عند قوله سبحانه في سورة الإسراء الآية رقم (46) <span class="qpc-hafs">﴿وَجَعَلْنَا عَلَى قُلُوبِهِمْ أَكِنَّةً أَنْ يَفْقَهُوهُ وَفِي آذَانِهِمْ وَقْرًا﴾</span> الآية.|6:عند قوله سبحانه في سورة الأنعام الآية رقم: (25) <span class="qpc-hafs">﴿وَمِنْهُمْ مَنْ يَسْتَمِعُ إِلَيْكَ وَجَعَلْنَا عَلَى قُلُوبِهِمْ أَكِنَّةً أَنْ يَفْقَهُوهُ وَفِي آذَانِهِمْ وَقْرًا﴾</span>. الآية.|7:ذكره القرطبي في "الجامع لأحكام القرآن" 11/ 7 بلا نسبة.|8:"معاني القرآن" للزجاج 3/ 297.
  18,58,"<div class=ar lang=ar><p>قوله تعالى: <span class="qpc-hafs">﴿بَلْ لَهُمْ مَوْعِدٌ﴾</span> قال المفسرون: (يعني البعث والحساب) {1}. <span class="qpc-hafs">﴿لَنْ يَجِدُوا مِنْ دُونِهِ مَوْئِلًا﴾</span> قال الأخفش، وأبو عبيد: (منجا، من وأل يئل وألاً على فعول) {2}. وأنشد أبو عبيدة للأعشى {3}:</p><p>وقد أخالس ربَّ البيت غفلته ... وقد يحاذر مني ثم ما يئل</p><p>وقال الفراء: (<span class="qpc-hafs">﴿مَوْئِلًا﴾</span>: منجا وهو: الملجأ) {4}. ومعناهما واحد، والعرب تقول: إنه ليوائل إلى موضعه. يريدون يذهب إلى حرزه، والمنجا والملجأ في هذا لفظ المفسرين. قال ابن عباس في رواية الوالبي: (ملجأ) {5}. وهو قول الكلبي ومجاهد في رواية إسرائيل {6}. وروى ورقاء عنه: (محرزًا) {7}. وقال قتادة وابن زبد: (منجا) {8}.</p></div>",footnotes:1:"معالم التنزيل" 5/ 183، "الكشاف" 2/ 394، "الدر المنثور" 4/ 416.|2:"معاني القرآن" للأخفش 1/ 619.|3:البيت للأعشى. أخالس: خلس الشئ أي سرقه. ثم ما يئل: ما ينجو.</p><p>انظر: "ديوانه" ص 59، "مجاز القرآن" 1/ 408، "جامع البيان" 15/ 269، "الجامع لأحكام القرآن" 11/ 8، "البحر المحيط" 6/ 132، "الدر المصون" 7/ 513.|4:"معاني القرآن" للفراء 2/ 148.|5:"جامع البيان" 15/ 269، "النكت والعيون" 3/ 320، "القرطبي" 11/ 8.|6:ذكرته كتب التفسير بدون نسبة. انظر: "جامع البيان" 15/ 269، "معالم التنزيل" 5/ 183، "النكت والعيون" 3/ 320، "الكشاف" 2/ 489، "القرطبي" 10/ 112.|7:"جامع البيان" 15/ 269، "النكت والعيون" 3/ 320، "البحر المحيط" 6/ 140.|8:"تفسير القرآن" للصنعاني 1/ 341، وذكره الثعلبي في "الكشف والبيان" 3/ 390 أبدون نسبة، وكذلك السمرقندي في "بحر العلوم" 2/ 304.
  18,59,"<div class=ar lang=ar><p>وقوله تعالى: <span class="qpc-hafs">﴿وَتِلْكَ الْقُرَى أَهْلَكْنَاهُمْ﴾</span> قال الزجاج: (<span class="qpc-hafs">﴿وَتِلْك﴾</span> رفع بالابتداء، و <span class="qpc-hafs">﴿الْقُرَى﴾</span> صفة لها، و <span class="qpc-hafs">﴿أَهْلَكنَاهُمْ﴾</span> خبر الابتداء. قال: وجائز أن يكون موضع <span class="qpc-hafs">﴿وَتِلْكَ الْقُرَى﴾</span> نصبا، ويكون <span class="qpc-hafs">﴿أَهْلَكْنَاهُمْ﴾</span> مفسرًا للناصب، ويكون المعنى: وأهلكنا تلك القرى أهلكناهم) {1}. قال الأخفش: (أراد أهلها لذلك قال: <span class="qpc-hafs">﴿أهلَكْنَاهُمْ﴾</span> حملة على القوم والأهل) {2}.</p><p>قال ابن عباس: (يريد ما أهلك بالشام واليمن لما ظلموا وأشركوا وكذبوا بالأنبياء) {3}.</p><p><span class="qpc-hafs">﴿وَجَعَلْنَا لِمَهلِكِهِم﴾</span> والمهلك هاهنا يجوز أن يكون: مصدرًا، وأن يكون: وقتًا، والمعنى: جعلنا لإهلاكهم أو لوقت إهلاكهم، وكل فعل على أفعل.</p><p>فالمصدر واسم الزمان والمكان فيه سواء، تقول: أدخلتُه مُدْخلاً وهذا مُدْخله، أي: المكان الذي يدخل منه وقت إدخاله {4}. وقرأ عاصم في رواية أبي بكر: <span class="qpc-hafs">﴿لِمَهْلَكِهم﴾</span> بفتح الميم واللام {5}، وهو مصدر هلك يهلك، والمعنى لوقت هلاكهم يكون المهلك مصدرًا مضافًا إلى الفاعل {6}.</p><p>قال أبو علي: (ويجوز على لغة تميم أن يكون مصدرًا مضافًا إلى المفعول؛ لأنهم يقولون: هلكني زيد، كأنهم جعلوه من باب رجع، ورجعته، وغاض الماء وغضته، وعلى هذا حمل بعضهم {7}:</p><p>ومهمهٍ هالك من تعرَّجا</p><p>قال: هو بمنزلة: مُهْلِكِ مَنْ تَعَرَّجا. فقدل: <span class="qpc-hafs">﴿لِمَهْلَكِهم﴾</span>، على قول من عَدَّى: هلكت مصدر مضاف إلى المفعول به، نحو <span class="qpc-hafs">﴿مِنْ دُعَاءِ الْخَيْرِ﴾</span> [فصلت: 49]. وقرئ في رواية حفص {8}: <span class="qpc-hafs">﴿لِمَهْلِكِهِم﴾</span> بفتح الميم وكسر اللام {9}.</p><p>قال أبو إسحاق: (هذا على أن يكون مهلك اسما للزَّمان، يقال: هلك يهلك، هذا زمن مهلكه) {10}.</p><p>قال أبو علي: (ويجوز أن يكون مصدرًا، وقد جاء المصدر من باب فعل يفعل بكسر العين قال: <span class="qpc-hafs">﴿إِلىَّ مَرْجِعُكُمْ﴾</span> [آل عمران: 55]، وقال: <span class="qpc-hafs">﴿وَيَسْأَلُونَكَ عَنِ الْمَحِيضِ﴾</span> [البقرة: 222]، والفتح في المصدر أكثر وأوسع) {11}.</p><p>وقوله تعالى: <span class="qpc-hafs">﴿مَوْعِدًا﴾</span> قال ابن عباس: (يريد وقتًا) {12}. وقال مجاهد: (أجلا) {13}.</p></div>",footnotes:1:"معاني القرآن" للزجاج 3/ 298.|2:"معاني القرآن" للأخفش 1/ 619.|3:لم أقف عليه. وهذا الإجمال في تعيين هذه القرى وأسباب هلاكها، وأنواع الهلاك الذي وقع عليها جاء مفصلاً في آيات أخرى كثيرة، كما جاء في القرآن الكريم من قصة قوم نوح، وقوم هود، وقوم صالح، وقوم شعيب، وقوم موسى.|4:"معاني القرآن" للفراء 2/ 148، "معاني القرآن" للزجاج 3/ 297، "إعراب القرآن" للنحاس 2/ 283، " إملاء ما من به الرحمن" 1/ 401.|5:قرأ عاصم في رواية أبي بكر: (لِمَهْلَكِهم) بفتح الميم واللام الثانية.</p><p>انظر: "السبعة" ص 393، "الحجة للقراء السبعة" 5/ 156، "المبسوط في القراءات العشر" ص 236، "التبصرة" ص 249.|6:"الدر المصون" 7/ 515، "إعراب القرآن" للنحاس 2/ 283، "مشكل إعراب القرآن" 1/ 444، "معاني القرآن" للفراء 2/ 148.|7:هذا عجز بيت للعجاج وصدره:</p><p>عصرًا وحضنا عيشة المعذلجا</p><p>انظر: "ديوانه" 2/ 43، "المحتسب" 1/ 92، "المقتضب" 4/ 180، "الخصائص" 2/ 210، "الحجة للقراء السبعة" 5/ 156، "الدر المصون" 7/ 515.|8:"الحجة للقراء السبعة" 5/ 156.|9:قرأ عاصم في رواية حفص: (لِمَهْلِكِهم) بكسر اللام فيهما وفتح الميم. انظر: "الغاية في القراءات" ص 308، "العنوان في القراءات" ص 123، "حجة القراءات" ص 421، "الكشف عن وجوه القراءات" 2/ 65.|10:"معاني القرآن" للزجاج 3/ 297.|11:"الحجة للقراء السبعة" 5/ 157.|12:ذكره الماوردي في "تفسيره" 3/ 321 بدون نسبة.|13:"جامع البيان" 15/ 270، "النكت والعيون" 3/ 321، "تفسير كتاب الله العزيز" 2/ 469.
  18,60,"<div class=ar lang=ar><p>قوله تعالى: <span class="qpc-hafs">﴿وَإِذْ قَالَ مُوسَى لِفَتَاهُ﴾</span> الآية. روي عن أبي بن كعب من طرق كثيرة أنه قال: (سمعت رسول الله -ﷺ- يقول: "بينما موسى في ملأ من بني إسرائيل إذ جاءه رجل فقال: هل تعلم أحدًا أعلم منك؟ فقال موسى: لا. فأوحى الله إلى موسى: بلى عبدنا خضر {1}، فسأل موسى السبيل إلى لقياه فجعل الله له الحوت آية. [وقيل؛ إذا فقدت الحوت] {2} فأرجع فإنك ستلقاه" {3}.</p><p>وروى سعيد بن جبير عن ابن عباس قال: (قام موسى خطيبًا في بني إسرائيل فأبلغ في الخطبة، وحدث في نفسه أن أحدًا لم يؤت من العلم ما أوتي، فعلم الله الذي حدث نفسه من ذلك فقال له: يا موسى إن من عبادي من قد آتيته من العلم ما لم أوتك، قال: إي ربي من عبادك؟ قال: نعم، قال: فدلني على هذا الرجل الذي آتيته من العلم ما لم تؤتني حتى أتعلم منه قال: يدلك عليه بعض زادك. فقال لفتاه يوشع: <span class="qpc-hafs">﴿لَا أَبْرَحُ حَتَّى أَبْلُغَ مَجْمَعَ الْبَحْرَيْنِ﴾</span> الآية، فكان فيما تزود حوتًا مالحاً في زبيل {4}، ثم كان من أمرهما ما قص الله في كتابه) {5}.</p><p>فقوله: <span class="qpc-hafs">﴿وَإِذْ قَالَ مُوسَى﴾</span> معناه: واذكر إذ قال موسى، لما في قصته من العبرة وقوله تعالى: <span class="qpc-hafs">﴿لِفَتَاهُ﴾</span> أجمعوا أنه: يوشع بن نون. قال عطاء عن ابن عباس: (يريد غلامه) {6}.</p><p>قال الفراء، والزجاج: (وإنما سمي فتى موسى؛ لأنه كان ملازمًا له يأخذ عنه العلم ويخدمه) {7}.</p><p>وقوله تعالى: <span class="qpc-hafs">﴿لَا أَبْرَحُ﴾</span> قال جميع أهل التأويل: (معناه لا أزال) {8}. يقال: برحت أفعل كذا أي: ما زلت، ومنه قوله تعالى: <span class="qpc-hafs">﴿لَنْ نَبْرَحَ عَلَيْهِ عَاكِفِينَ﴾</span> [طه: 91]، أي: لن نزال. وأصله من قوله: برح الرجل براحا، إذا راح من موضعه، ومنه قوله: <span class="qpc-hafs">﴿فَلَنْ أَبْرَحَ الْأَرْضَ﴾</span> [يوسف: 80] وقد مرَّ بنا، فإذا قلت: ما برح يفعل كذا، فكأنك قلت: أقام يفعل ذلك، ودام على حاله تلك من غير مفارقة. قال أبو إسحاق: (معنى <span class="qpc-hafs">﴿لَا أَبْرَحُ﴾</span>: لا أزال، ولو كان معناه لا أزول كان محالاً؛ لأنه إذا لم يزل من مكانه لا يقطع أرضًا، وأنشد {9}:</p><p>وأبرح ما أدام الله قومي ... بحمد الله مُنْتَطِقًا مُجِيدًا</p><p>أي: لا زال) {10}. وقال صاحب النظم: (قوله: <span class="qpc-hafs">﴿لَا أَبْرَحُ حَتَّى أَبْلُغَ مَجْمَعَ الْبَحْرَيْنِ﴾</span> مكفوف عن إتمام نظمه؛ لأن فيه إضمارًا وهو: لا أبرح أمضى ماضيًا، أي: سائرًا حتى أبلع مجمع البحرين) {11}.</p><p>قال ابن عباس في رواية عطاء: (يريد ملتقى البحرين العذب والمالح) {12}.</p><p>وقال قتادة: (يعني بحر فارس وبحر الروم) {13}. وكان مجمع البحرين الموضع الذي وعد موسى للقاء الخضر -عليه السلام-.</p><p>وقوله تعالى: <span class="qpc-hafs">﴿أَوْ أَمْضِيَ﴾</span> أو أسير. <span class="qpc-hafs">﴿حُقُباً﴾</span> قال ابن عباس فيما روى عنه الوالبي يقول: (دهرًا) {14}. وقال في رواية عطاء: (الحقب الواحد بضع وثمانين سنة، السنة ثلاثمائة وستون يومًا، اليوم الواحد ألف سنة) {15}. وقال مجاهد: (الحقب سبعون خريفاً) {16}.</p><p>وأمما أهل اللغة فإنهم كلهم قالوا: (الحقب ثمانون سنة) {17}.</p><p>قال صاحب النظم: (<span class="qpc-hafs">﴿أَوْ﴾</span> بمعنى حتى، مثل قولك: لا آتيك أو تكرمني، فيرجع تأويل الآية: لا أبرح ماضيًا إلى أن أمضي حقبًا حتى أبلغ مجمع البحرين. قال: ونظير هذا في الكلام أن تقول: لا أزال إلى أن أسير سنة حتى أقضى حاجتي. ومعنى إلى أن أسير سنة: وإن احتجت إلى أن أسير سنة) {18}. وعلى ما ذكر يكون في الآية تقديم وتأخير، ولا يجوز أن يجعل <span class="qpc-hafs">﴿أَوْ﴾</span> للعطف؛ لأنه ليس المراد حتى أبلغ مجمع البحرين وحتى أمضي حقبا، و <span class="qpc-hafs">﴿أَوْ﴾</span> هاهنا الناصبة للفعل بإضمار أن كما تقول: لألزمنك أو تعطيني حقي، التقدير: إلى أن تعطيني حقى {19}، ومنه قول امرئ القيس {20}:</p><p>فقلت له لا تبك عينك إنَّما ... نحاول ملكًا أو نموت فنعذرا</p><p>المعنى: إلى أن نموت.</p></div>",footnotes:1:الخضر هو صاحب موسى-عليه السلام-، وقد اشتهر بهذا اللقب وسمي به في القرآن والسنة، وقد أخرج البخاري في "صحيحه" 6/ 309 بسنده عن أبي هريرة -رضي الله عنه- عن النبي -ﷺ- قال: "إنما سمي الخضرة لأنه جلس على فروة بيضاء، فإذا هي تهتز من خلفه خضراء".</p><p>قال ابن كثير -رحمه الله- في "البداية والنهاية" 15/ 327: قيل إنما سمي الخضر خضرا: لحسنه وإشراقة وجهه، وهذا لا ينافي ما ثبت في الصحيح؛ فإن كان ولابد من التعليل بأحدهما فما ثبت في الصحيح أولى وأقوى بل لا يلتفت إلى ما عداه.|2:ما بين المعقوفين ساقط من الأصل ومن نسخة (ص).|3:"جامع البيان" 15/ 278، "تفسير القرآن" للصنعاني 1/ 340، "معالم التنزيل" 5/ 184، "المحرر الوجيز" 9/ 347 - 348، "تفسير القرآن العظيم" 3/ 103، "الدر المنثور" 4/ 417، "تفسير النسائي" 2/ 8. وأخرجته كتب الصحاح والسنن من عدة طرق.</p><p>فقد أخرجه البخاري في كتاب التفسير سورة الكهف 8/ 409، وفي كتاب: العلم 1/ 173، وكتاب أحاديث الأنبياء باب حديث الخضر 6/ 431، وكتاب: التوحيد 13/ 448، وأخرجه مسلم في "صحيحه" في كتاب: الفضائل، باب: فضل الخضر -عليه السلام- 4/ 1850، وأخرجه الترمذي في "جامعه" كتاب: التفسير سورة الكهف 8/ 558، وأخرجه أبو داود في "سننه" كتاب: السنن، باب: في القدر حديث رقم (4705)، وأخرجه الإمام أحمد في "مسنده" 5/ 117.|4:الزبيل: الجراب، وقيل: وعاء يحمل فيه. انظر: "تهذيب اللغة" (زبل) 2/ 1509، "لسان العرب" (زبل) 6/ 15.|5:"جامع البيان" 15/ 278، "تفسير القرآن" للصنعاني 1/ 405، "ابن كثير" 3/ 103، "الدر المنثور" 4/ 421. وأخرجه البخاري في كتاب: التفسير سورة الكهف 8/ 409، ومسلم في كتاب الفضائل باب: فضل الخضر 4/ 1850، والترمذي في كتاب: التفسير: سورة الكهف 8/ 588، والنسائي في "تفسيره" 2/ 8.|6:ذكر نحوه بلا نسبة "جامع البيان" 15/ 271، "النكت والعيون" 3/ 321، "المحرر الوجيز" 9/ 346 - 347، "زاد المسير" 5/ 164، "القرطبي" 11/ 11.|7:"معاني القرآن" للزجاج 3/ 299، "معاني القرآن" للفراء 2/ 154.|8:"معالم التنزيل" 5/ 185، "المحرر الوجيز" 9/ 348، "النكت والعيون" 2/ 323، "الجامع لأحكام القرآن" 11/ 9.|9:البيت لخداش بن زهير. منتطق: يقال جاء فلان منتطقًا فرسه إذا جنبه ولم يركبه. انظر: "معاني القرآن" للزجاج 3/ 298، "المقاصد النحوية" 2/ 64،"أساس البلاغة" 2/ 454، "خزانة الأدب" 9/ 243، "شرح ابن عقيل" 1/ 264، "تهذيب اللغة" (نطق) 4/ 3602، "لسان العرب" (نطق) 7/ 4463.|10:"معاني القرآن" للزجاج 3/ 298.|11:ذكر نحوه بلا نسبة "الكشاف" 2/ 395، "إملاء ما من به الرحمن" ص 401، "البحر المحيط" 6/ 144، "الدر المصور" 7/ 517، "التفسير الكبير" 21/ 145.|12:"جامع البيان" 15/ 271، "الدر المنثور" 4/ 417.|13:"جامع البيان" 15/ 271، "تفسير القرآن" للصنعاني 1/ 405، "معالم التنزيل" 5/ 185، "المحرر الوجيز" 9/ 349.|14:"جامع البيان" 15/ 272، "النكت والعيون" 3/ 322، "ابن كثير" 3/ 103.|15:ذكرت كتب التفسير نحوه بدون نسبة.</p><p>انظر: "التسهيل لعلوم التنزيل" ص 385، "الكشاف" 2/ 490، "التفسير الكبير" 21/ 146، "أنوار التنزيل" 3/ 230، "زاد المسير" 5/ 165، "مدارك التنزيل" 2/ 956، "الجامع لأحكام القرآن" 11/ 10.|16:"جامع البيان" 15/ 272، "النكت والعيون" 3/ 322، "ابن كثير" 3/ 103، "الجامع لأحكام القرآن" 11/ 11.|17:"معاني القرآن" للزجاج 3/ 299، "معاني القرآن" للفراء 2/ 154، "تفسير المشكل من غريب القرآن" ص 144.|18:ذكر نحوه بلا نسبة "البحر المحيط" 6/ 145، "الدر المصون" 8/ 517 ، "إملاء ما من به الرحمن" 401، "التفسير الكبير" 21/ 146.|19:"البحر المحيط" 6/ 145، "الدر المصون" 7/ 520، "إملاء ما من به الرحمن" ص 401، "روح المعاني" 15/ 312.|20:البيت لامرئ القيس. انظر: "ديوانه" ص 64، "الكتاب" لسيبويه 3/ 47، "خزانة الأدب" 4/ 212، "المقتضب" 2/ 28، "اللامات" ص 68، "شرح المفصل" 7/ 22.
  18,61,"<div class=ar lang=ar><p>قوله تعالى: <span class="qpc-hafs">﴿فَلَمَّا بَلَغَا﴾</span> يعني: موسى وصاحبه. <span class="qpc-hafs">﴿مَجْمَعَ بَيْنِهِمَا﴾</span> قال ابن عباس: (يريد ملتقى العذب والمالح) {1}. وعلي قول قتادة: (ملتقى بحر الروم وبحر فارس) {2}. وهو حيث وعد لقاء الخضر.</p><p>وقوله تعالى: <span class="qpc-hafs">﴿نَسِيَا حُوتَهُمَا﴾</span> إلى آخر الآية. قال سعيد بن جبير عن ابن عباس: (كان فيما تزودا حوتًا مالحًا في زبيل، وكان يصيبان منه عند العشاء والغداء، فلما انتهيا إلى الصخرة على ساحل البحر، وضع فتاه المكتل {3} فأصاب الحوت [ندى البحر فتحرك في] {4} المكتل فقلب المكتل، وانسرب في البحر) {5}.</p><p>وروى أبي بن كعب عن رسول الله -ﷺ- قال: "لما أراد موسى أن يطلبه قيل له: تزود معك حوتًا مالحًا فحيث {6} يفقد الحوت ثم تجد الرجل، فانطلق هو وفتاه حتى أتيا الصخرة، فقال لفتاه: امكث حتى آتيك، وانطلق موسى لحاجته، فجرى الحوت حتى وقع في البحر، فقال فتاه: إذا جاء نبي الله حدثته، فأنساه الشيطان" {7}.</p><p>قال ابن عباس في رواية عطاء: (نسي الفتى أن يذكر قصة الحوت لموسى) {8}.</p><p><span class="qpc-hafs">﴿فَاتَّخَذَ سَبِيلَهُ فِي الْبَحْرِ سَرَبًا﴾</span> قال: (يريد مسيرًا) {9}. وفي حديث أبي: "جعل لا يصيب الحوت شيئًا من الماء إلا جمد، حتى اتخذ سبيله في البحر سربًا شبه النقب" {7}.</p><p>وقال قتادة: (جعل لا يسلك طريقًا إلا صار الماء جامدًا) {11}.</p><p>وقال الربيع بن أنس: (انجاب الماء على مسلك الحوت فصارت كوة لم تلتئم) {12}.</p><p>وروي أيضًا عن النبي -ﷺ- في حديث أبي بن كعب قال: "ما انجاب الماء مذ كان الناس غير مكان الحوت الذي دخل منه كالكوة، حتى رجع إليه موسى فرأى مسلكه" {13}. هذا معنى قوله: <span class="qpc-hafs">﴿فَاتَّخَذَ سَبِيلَهُ فِي الْبَحْرِ سَرَبًا﴾</span>.</p><p>وقال الكلبي: (كان عند تلك الصخرة التي نزلا عندها عين ماء فتوضأ يوشع من ذلك الماء، فانتضح على الحوت في المكتل ثم طفر في البحر) {14}.</p><p>والسَّرب معناه في اللغة: المحفور في الأرض لا نفاذ له، شبه مسلك الحوت في الماء {15}، والماء منجاب عنه بالسَّرب. كما قال الفراء: (حيي الحوت بالماء الذي أصابه من العين، فلما وقع في الماء جمد مذهبه في البحر فكان كالسرب) {16}.</p><p>هذا قول المفسرين في هذه الآية. وعلى ما قالوا في نظم الآية تقديم وتأخير على تقدير: فلما بلغا مجمع بينهما اتخذ الحوت [سبيله في البحر سربا، ونسي يوشع أن يذكر ذلك لموسى؛ لأن النسيان لم يتقدم على ذهاب الحوت] {17}، ذهب الحوت فنسي الفتى أن يذكر ذلك لموسى حتى جازوا ذلك المكان على ما في القرآن من الآيات بعد هذه الآية.</p><p>وقوله تعالى: <span class="qpc-hafs">﴿نَسِيَا حُوتَهُمَا﴾</span> إجماع المفسرين أن النسيان هاهنا معناه: نسيان الفتى ذكر قصة الحوت لموسى، والناسي كان أحدهما، وأضيف إليهما جميعًا.</p><p>واختلفوا في وجه هذا فقال الفراء: (إنما نسيه يوشع فأضافة إليهما كما قال: <span class="qpc-hafs">﴿يَخْرُجُ مِنْهُمَا اللُّؤْلُؤُ وَالْمَرْجَانُ﴾</span> [الرحمن: 22] وإنما يخرج من الملح دون العذب) {16}. وعلى هذا أضيف إليهما توسعا، وذكر غيره العلة في جواز هذا التوسع فقال: (إنهما كانا جميعًا تزوداه لسفرهما، فجاز إضافته إليهما كما يقال: نسي القوم زادهم، وإنما نسيه أحدهم) {19}.</p><p>وقال أبو علي الفارسي: (هذا من باب حذف المضاف. المعنى: نسي أحدهما حوتهما، فلما حذف المضاف عادت الكناية إلى الفعل فقيل: نسيا. قال: وكذلك قوله: <span class="qpc-hafs">﴿يَخْرُجُ مِنْهُمَا﴾</span> [الرحمن: 22] المعنى: من أحدهما، وفيه حذف أيضًا من وجه آخر وهو أن التقدير: نسيا أمر حوتهما وقصته؛ لأن يوشع نسي أن يذكر أمره لموسى على ما بينا) {20}.</p><p>هذا الذي ذكره مذهب المفسرين، وجميع أهل المعاني، وقد أغنى الزجاج عن الحذف والتقديم والتأخير الذي يلزم على مذهب هؤلاء فقال في قوله: <span class="qpc-hafs">﴿نَسِيَا حُوتَهُمَا﴾</span> (كان النسيان من يوشع أن يقدمه، وكان النسيان من موسى أن يأمره فيه بشيء) {21}.</p><p>وعلى هذا المعنى لما بلغا مجمع بينهما نسي يوشع أن يقدم الحوت للأكل، ونسي موسى أيضًا أن يأمره بذلك، فلما نسياه حيا بإذن الله، وذهب في البحر، فصح المعنى واستغنى عن تقدير الحذف والتقديم والتأخير، غير أن مذهب المفسرين في النسيان ما ذكرنا أولى.</p><p>وذكر في انتصاب قوله: <span class="qpc-hafs">﴿سَرَبَاً﴾</span> وجهين أحدهما: أنه مفعول ثان، كما تقول: اتخذت زيدًا وكيلاً.</p><p>والثاني: أن "سَرَبا" هاهنا مصدر سرب ينسرب إذا ذهب على وجهه {22}. منه قول الشاعر {23}:</p><p>ونحن خلعنا قيده فهو سارب</p><p>وذكرنا هذا عند قوله: <span class="qpc-hafs">﴿وَسَارِبٌ بِالنَّهَارِ﴾</span> [الرعد: 10]، وكأنه قيل: سَرب الحوت سربًا، ودل عليه قوله: <span class="qpc-hafs">﴿وَاتَّخَذَ سَبِيلَهُ فِي الْبَحْرِ﴾</span> [الكهف: 63]؛ لأنه بمعنى سرب، ولهذا نظائر كثيرة في التنزيل. وعلى هذا قد حصل في معنى السرب قول آخر. وبنحو هذا القول أخبرني العروضي عن الأزهري قال: (أخبرني المنذري عن ابن اليزيدي عن أبي حاتم. في قوله: <span class="qpc-hafs">﴿سَرَبًا﴾</span> قال: أظنه يريد ذهابًا يسرب سربًا، كقولك: يذهب ذهابًا) {24}.</p></div>",footnotes:1:"جامع البيان" 15/ 271، "الدر المنثور" 4/ 417.|2:"جامع البيان" 15/ 271، "تفسير القرآن" للصنعاني 1/ 405، "معالم التنزيل" 5/ 185، "المحرر الوجيز" 9/ 349.|3:المكتل: الزنبيل يحمل فيه التمر وغيره. انظر: "تهذيب اللغة" (كتل) 4/ 3100، "القاموس المحيط" (الكتلة) ص 1052، "لسان العرب" (كتل) 6/ 3822.|4:في جميع النسخ: جرى البحر فترك المكتل. وما أثبته هو الصواب والموافق للسياق، والمخبت في "الوسيط" للمؤلف 3/ 157.|5:"جامع البيان" 15/ 278، "تفسير القرآن" للصنعاني 1/ 408، "تفسير القرآن العظيم" 3/ 103، "الدر المنثور" 4/ 421.|6:في (ص): (فحنت)، وهو تصحيف.|7:سبق تخريج الحديث في أول القصة.|8:"الكشف والبيان" 3/ 390 أ، "بحر العلوم" 2/ 305 وذكره بدون نسبة.|9:ذكر نحوه بلا نسبة "المحرر الوجيز" 9/ 352، "بحر العلوم" 2/ 305، "الجامع لأحكام القرآن" 11/ 13.|10:سبق تخريج الحديث في أول القصة.|11:"جامع البيان" 15/ 274، "المحرر الوجيز" 9/ 352، "البحر المحيط" 6/ 145.|12:ذكرته كتب التفسير ونسبته لأبي بن كعب. انظر: "جامع البيان" 273/ 15، "الكشف والبيان" 3/ 39 أ، "لباب التأويل" 4/ 223، "معالم التنزيل" 5/ 186، "زاد المسير" 5/ 166، "تفسير القرآن العظيم" 3/ 103.|13:"جامع البيان" 15/ 273، "معالم التنزيل" 5/ 186، "تفسير القرآن العظيم" 3/ 103.</p><p>وسبق تخريج الحديث في أول القصة.|14:"معالم التنزيل" 5/ 186، "بحر العلوم" 2/ 305، "الكشاف" 2/ 395، "روح المعاني" 15/ 314، "التفسير الكبير" 21/ 146.|15:انظر (سرب) "تهذيب اللغة" 3/ 1663، "الصحاح" 1/ 146، "اللسان" 4/ 1981.|16:"معاني القرآن" للفراء 2/ 154.|17:ما بين المعقوفين ساقط من نسخة (س).|18:"معاني القرآن" للفراء 2/ 154.|19:"جامع البيان" 15/ 273، "المحرر الوجيز" 9/ 354، "النكت والعيون" 3/ 323، "روح المعاني" 15/ 314.|20:"الحجة للقراء السبعة" 2/ 311.|21:"معاني القرآن" للزجاج 3/ 299.|22:"معاني القرآن" للزجاج 3/ 299، "مشكل إعراب القرآن" 1/ 445، "إعراب القرآن" للنحاس 2/ 283، "تهذيب اللغة" (سرب) 2/ 1663.|23:هذا عجز بيت للأخنس بن شهاب التغلبي، وصدره:</p><p>وكل أناس قاربوا قيد فحلهم</p><p>انظر: "تهذيب اللغة" (سرب) 2/ 1662، "لسان العرب" (سرب) 4/ 1980.|24:"تهذيب اللغة": (سرب) 2/ 1663.