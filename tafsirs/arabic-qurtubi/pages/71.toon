quran[8]{c,v,t}:
  3,158,"<div class=ar lang=ar><p>قوله تعالى: <span class="qpc-hafs">﴿وَلَئِنْ مُتُّمْ﴾</span> قال المفسرون: يريد: مقيمين عن الجهاد. <span class="qpc-hafs">﴿أَوْ قُتِلْتُمْ﴾</span>؛ يريد: مجاهدين {1}.</p><p><span class="qpc-hafs">﴿لَإِلَى اللَّهِ تُحْشَرُونَ﴾</span>؛ يعني: في الحالين. وهذا تهديد بالحشر، وتحذير من القيامة.</p><p>واللام في <span class="qpc-hafs">﴿لَئِنْ﴾</span> خلف من القسم. والثانية {2}: جواب، على معنى: والله إن متم، أو قتلتم لتحشرون إلى الله.</p><p>قال أبو عبيد: وتقول في الكلام: (لَئِن أحسنتَ إِليَّ؛ لأحْسِنَنَّ إليك) -بالنُّونِ-. فإذا حُلْت بينهما بالصفة {3}، قلت: (لَئِن أحسنتَ إليَّ، لإليكَ أُحْسِن) -بغير نُونِ-. كما في الآية-، لأن اللام قد تحولت إلى الصفة {4}.</p></div>",footnotes:1:انظر: "بحر العلوم" 1/ 310، و"زاد المسير" 1/ 485.|2:أي (اللام) التي في قوله: <span class="qpc-hafs">﴿لَإِلَى اللَّهِ﴾</span>.|3:(بالصفة): ساقطة من (ج). ويعني بـ (الصفة): حرف الجَرِّ.|4:انظر: "الأصول في النحو" 2/ 166، و"البسيط في شرح جمل الزجاجي" 2/ 919.
  3,159,"<div class=ar lang=ar><p>قوله تعالى: <span class="qpc-hafs">﴿فَبِمَا رَحْمَةٍ مِنَ اللَّهِ﴾</span>.</p><p>أكثر النحويِّينَ على أنَّ (ما) -ههنا- صِلَةٌ {1}، لا تمنع الباءَ مِن عَمَلِها فيما عملت فيه، وهي مع كونها صلةً، تُحْدِثُ معنى التأكيد {2} وحُسْن النَّظْم. وهي كثيرةٌ في القرآن؛ كقوله: <span class="qpc-hafs">﴿عَمَّا قَلِيلٍ﴾</span> [المؤمنون: 40]، و <span class="qpc-hafs">﴿جُندٌ مَّا﴾</span> [ص: 11]، <span class="qpc-hafs">﴿فبَمَا نَقضِهِم﴾</span> [النساء: 155]، <span class="qpc-hafs">﴿مِمَّا خَطَايَاهُمْ﴾</span> {3} [نوح: 25].</p><p>[وتكثر] {4} -أيضًا- في الشعر؛ قال امرؤ القيس:</p><p>وقاهم جَدُّهُمْ بِبَني أبِيهم ... وبالأشْقَيْنَ ما كانَ العِقَابُ {5}</p><p>أراد: (وبالأشْقَيْنَ {6} كان العِقَابُ) {7}.</p><p>وقال النابغة:</p><p>المرءُ يَهْوَى أنْ يَعِيـ ... ـشَ وطُولُ عَيْشٍ ما يَضُرُّهْ {8} أراد: (وطول عيش يَضُرُّهْ). فأكد الكلام بـ (ما).</p><p>والعرب قد تزيد في الكلام ما يُسْتغنى عنه؛ للتأكيد؛ كقوله: (أنت فعلت كذا وكذا؛ يا هذا!) فأدخلوا (يا هذا)؛ للتأكيد؛ إذ كانت (أنت) دالاًّ على الخطاب. وكذلك قولهم: (لَمَّا أنْ زارني عبد الله، زُرْتُه). معناه: لَمَّا زارني {9}.</p><p>قال الله تعالى: <span class="qpc-hafs">﴿فَلَمَّا أَنْ جَاءَ الْبَشِيرُ﴾</span> [يوسف: 96]، أراد: فلَمَّا جاء. فأكّد بـ (أنْ) {10}. وكذلك قولهم:</p><p>يا تَيْمَ تَيْمَ عَدِيٍّ {11} أكد الكلام بـ (تَيْم) {12} الثاني. هذا قول أكثر أهل التأويل.</p><p>وقال بعضهم {13}: يجوز أن تكون (ما) استفهامًا للتعجب {14}، تقديره: (فَبِأَيِّ رَحْمَةٍ مِنَ اللهِ لِنْتَ لهم؟!)؛ أي: سَهُلَتْ لهم أخلاقُكَ، وكثر احتمالك {15}.</p><p>وقوله تعالى: <span class="qpc-hafs">﴿لِنْتَ لَهُمْ﴾</span> (لانَ، يَلِينُ، لِينًا) {16}، و (لَيَانًا) -بالفتح: إذا رَقَّ، وحَسُنَ [خُلُقُهُ] {17}، وانْقادَ {18}.</p><p>قال الشاعر:</p><p>وإنْ هي أعطتك اللَّيانَ كأنها ... لِغَيرك مِن خُلّانِها سَتَلِينُ {19} وقوله تعالى: <span class="qpc-hafs">﴿وَلَوْ كُنْتَ فَظًّا﴾</span> الفظُّ {20}: الغليظ الجانب، السَّيّءُ الخُلُق {21}. يقال: (فَظِظْتَ، تَفَظُّ، فَظَاظَةً، وَفِظَاظًا)، فأنت فَظٌّ {22}، وأصله. (فَظِظٌ)؛ كقولك: (حَذِرٌ) {23}؛ من: (حَذِرْتَ) {24}، و (فَرِقٌ) {25}؛ مِن: (فَرِقْتَ). إلّا أنَّ ما كان مِن المضاعف على هذا الوزن، يُدْغَم؛ نحو: (رَجُلٌ صَبٌّ) {26}. وأصله: صَبِبٌ) {27}.</p><p>قال الكلبي {28}: ولو كنت فظًّا في القول، غليظ القَلْبِ في الفعل {29}. <span class="qpc-hafs">﴿لَانْفَضُّوا مِنْ حَوْلِكَ﴾</span> أي: لَتَفَرَّقوا وَنَفَرُوا منك؛ كما تتطاير شظايا الشيء المتكَسِّر.</p><p>والفَضُّ: الكسر والتفريق {30}. يقال: (فَضضْتَ القومَ، فانْفَضُّوا). ومنه يقال: (لا يَفْضُضِ اللهُ فاكَ) {31}.</p><p>قال الزّجاج {32}: المعنى: إنَّ لِينَكَ لهم، يُوجِبُ {33} دخولهم في الإسلام {34}؛ لأنك تأتيهم بالحُجَجِ والبراهين، مع لِينٍ وخُلُقٍ عظيم.</p><p>وقوله تعالى: <span class="qpc-hafs">﴿فَاعْفُ عَنْهُمْ﴾</span>. أي: ما فعلوا يومَ أُحُد حتى أشفعك فيهم. وقال الكلبي: فاعف عنهم أي الشيء يكون منهم و <span class="qpc-hafs">﴿وَاسْتَغْفِرْ لَهُمْ﴾</span>. مِنْ ذلك الذَنْب.</p><p>وقوله تعالى: <span class="qpc-hafs">﴿وَشَاوِرْهُمْ فِي الْأَمْرِ﴾</span> يقال: (شَاوَرَ مُشَاوَرَةً)، و (شِوارا) {35}، و (مَشُورَةً) {36}، و (مَشْوَرَةً) {37}. و (القوم شُورى). وهي مصدرٌ، سُمِّي القومُ بها، كقوله: <span class="qpc-hafs">﴿وَإِذْ هُمْ نَجْوَى﴾</span> {38} [الإسراء: 47].</p><p>وقد ذَكَرْنا أمْرَ هذه الكلمة وما فيها، عند قوله: <span class="qpc-hafs">﴿عَنْ تَرَاضٍ مِنْهُمَا وَتَشَاوُرٍ﴾</span> [البقرة: 233].</p><p>قال أصحاب المعاني {39}: هذه عامَّةٌ في اللفظ، خاصَّةٌ في المعنى؛ لأن المعنى: وشاورهم فيما ليس عندك فيه من الله {40} أَمْرٌ وَوَحْيٌ {41} وعَهْد. يدل عليه: قراءةُ ابن عباس: (وشاورهم في بعض الأمر) {42}.</p><p>وقال الكلبي {43}: إنما أُمِرَ بالمُشَاوَرَةِ معهم في لِقَاءِ العدُوِّ، والحربِ ومكايِدِها {44}. فالأمر -عنده- بالمشاورة، خاصٌّ في الحرب.</p><p>وروى عَمرو بن دينار، عن ابن عباس، أنه قال {45}: الذي أُمِرَ النبيُّ ﷺ، بمشاورته في هذه الآية: أبو بكر وعمر- رضي الله عنهما-.</p><p>وقال قتادة {46}، والربيع {47}، ومقاتل {48}: إنما أُمِرَ بالمشاورة مع استغنائه بوحي الله وجَزَالَةِ رأيه؛ تَطْيِيبًا لِنُفُوسِ القوم، ورَفْعًا {49} مِن أقدارهم؛ إذْ كانت العربُ إذا لم يُشَاوروا في الأمر، شَقَّ عليهم.</p><p>قال الشافعي ({50}: وهذا كقوله ﷺ: "والبِكْرُ تُسْتَأمَر" {51}، ولو أكرهها {52} الأبُ على النِّكاح، جَازَ، لكنَّها تُسْتَأمر؛ تطييبا لِنَفْسِها.</p><p>وقال الحَسَنُ {53}، وسُفْيانُ بن عُيَيْنَة {54}: إنما ذلك؛ لِيَقْتَدِيَ به غيرُهُ في المُشَاوَرَةِ، ويَصِير سُنَّة.</p><p>وقوله تعالى: <span class="qpc-hafs">﴿فَإِذَا عَزَمْتَ﴾</span>؛ أي: على ما تريد إمضاءَهُ {55}.</p><p><span class="qpc-hafs">﴿فَتَوَكَّلْ عَلَى اللَّهِ﴾</span>، لا على المشاورة. ومعنى التَّوَكُّلِ: تفويضُ الأَمْرِ إلى الله؛ لِلثِّقَةِ بِحُسْنِ تدبيره.</p></div>",footnotes:1:(صلة)؛ بمعنى زيادة.|2:في (ب): (التوكيد).|3:المؤلف -هنا- أوردها على قراءة أبي عمرو: <span class="qpc-hafs">﴿خَطَايَاهُم﴾</span>. وقرأ الباقون: <span class="qpc-hafs">﴿خَطِيئَاتِهِمْ﴾</span>. انظر: "الكشف" لمكي 2/ 337، و"إتحاف فضلاء البشر" (425). وممن ذهب إلى كون (ما) -هنا- (صِلَة):</p><p>الفراء في: "معاني القرآن" 114، والمبرد في "الكامل" 1/ 342، والطبري في "تفسيره" 4/ 150، وكراع النمل في "المنتخب" 2/ 687، والزجاج في "معاني القرآن" 1/ 482، وابن شقير في "المحلى ووجوه النصب" 290، وابن جني في "سر صناعة الإعراب" 1/ 261، والثعلبي في "تفسيره" 3/ 136 أ، والسفاريني في "لباب الإعراب" 463.</p><p>قال الزجاج في "معاني القرآن" 1/ 482: "ما" بإجماع النحويين -هنا- صِلَةٌ، لا تمنع الباء من عملها فيما عملت.|4:ما بين المعقوفين مطموس في (أ). والمثبت من (ب)، (ج).|5:البيت في "ديوانه" 45. وورد منسوبًا له في "الأصمعيات" 131، و"الشعر والشعراء" 54، وكتاب "المعاني الكبير" 2/ 886، و"فصل المقال" للبكري 385. البيت من قصيدة قالها الشاعر حين غزا بني أسد فأخطأهم، وأصاب بني كنانة بدلًا منهم، وهو لا يدري. و (الجَدُّ) -هنا-: الحظ والبخت.</p><p>أي: أن بني أسد وقاهم حظهم من سطوته، بقتل بني عمهم -بني كنانة- لأن أسد وكنانة أخوان.</p><p>والشاهد في البيت زيادة (ما) في قوله: (وبالأشقين ما كان العقاب). ويجوز كون (ما) مع الفعل بتأويل المصدر؛ أي: وبالأشقَيْن كون العقاب.|6:في (ج): (بالأشقين). بدون واو.|7:(العقاب): ساقطة من (ج).|8:البيت نسب للنابغة الذبياني، وقد ورد في ديوانه 122. ونسبته له المصادر التالية: "الشعر والشعراء" 85، و"جمهرة أشعار العرب" (63)، و"الأضداد" لابن الأنباري 196. ونسب للنابغة الجعدي، وقد ورد منسوبًا له في "ديوانه" 191.</p><p>ونسبته إليه المصادر التالية: "الأمالي" للقالي 2/ 8، و"الأمالي" للمرتضى 1/ 266، و"الأشباه والنظائر في النحو" للسيوطي 5/ 163، و"خزانة الأدب" 3/ 172.</p><p>وقد ورد في الشعر المنسوب لِلَبِيد. انظر "ديوانه" 356.</p><p>وأورده ابن الشجري في "أماليه" 2/ 365، ونسبه لبعض المُعمِّرِين.</p><p>وورد في: "المدخل" للحدادي 146، و"زاد المسير" 1/ 485 ونسباه للنابغة ولم يحددا مَن مِنهما. == وورد غير منسوب في: "أمالي الزجاجي" 111، و"النكت والعيون" 2/ 911. وورد البيت بروايات عدة منها: (المرء يرغب في الحياة)، و (المرء يأمل أن يعيش). و (المرء يهوى ما يعيش). وورد: (وطول عيش ..)، و (وطول عمر ..). وورد: (قد يضره) بدلًا من: (ما يضره) وليس فيها موضع الشاهد.</p><p>ويجوز أن تكون (ما) في البيت بمعنى (الذي)، والتأويل: وطول عيش الذي يضره. انظر: "الأضداد"، لابن الأنباري 196.|9:انظر: "مغني اللبيب" 50.|10:في (ج): (أن). بدلًا من: بأن.|11:في (أ)، (ب): (يتم يتم)، والمثبت من (ج)، ومصادر الشاهد. وهذا جزء من بيت شعر لجرير، وهو في "ديوانه" 219، وتمامه:</p><p>يا تيمَ تيمَ عَدِيٍّ لا أبا لكُمُ ... لا يُوقِعَنَّكمُ في سَوْأةٍ عُمَرُ</p><p>وقد ورد منسوبًا له في: "كتاب سيبويه" 1/ 53، 2/ 205، و"الكامل" 3/ 217، و"المقتضب" 4/ 229، و"اللامات" 101، و"الخصائص" 1/ 345، و"العمدة" 2/ 841، و"شرح المفصل" 2/ 10، 105، و"اللسان" 1/ 18 (أبي)، و"المقاصد النحوية" 4/ 240، و"شرح شواهد المغني" 2/ 855، و"خزانة الأدب" 2/ 298، 301، 4/ 99، 107، 8/ 317، 10/ 191.= وورد غير منسوب في: "الأصول في النحو" 1/ 343، و"أمالي ابن الشجري" 2/ 307، و"شرح ابن عقيل" 3/ 17، و"ارتشاف الضرب" 3/ 315، و"منهج السالك". 3/ 153، و"همع الهوامع" 5/ 196، 2/ 122، و"الدرر اللوامع" 2/ 154.</p><p>وورد في أكثر المصادر: (لا يُلْقِيَنَّكُمُ في سوأة ..).</p><p>والبيت من قصيدة قالها الشاعر في هجاء عمر بن لَجَأ التَيْمِي. ويعني بـ (تيم): تيم بن عبد مناة بن أدّ. و (عدي) أخو (تيم). وأضاف (تيم) إلى (عدي) تخصيصًا، وتمييزًا لهم عن بطون عدة كلها تُدْعَى تَيْمًا. وقوله: (لا أبا لكم)، أصلها: أن يُنسب المخاطبُ إلى غير أب معلوم؛ شتمًا له، ثم كثرت في الاستعمال حتى جُعلت في كل خطاب يغلظ فيه على المخاطب. و (السوأة): الفعلة القبيحة.</p><p>يريد الشاعر تحذير بني تيم، وهي قبيلة عمر بن لجأ، بأن يمنعوا عمر من التعرض للشاعر بهجاء؛ وإلّا فإن الشاعر سيتعرض لِتَيْم في شعره، ويلقيهم في بلِيَّة، هم في غنى عنها.</p><p>ويجوز في (تيم) الأولى الضمُّ، على أنه منادى مفرد عَلَم، ويحوز النصبُ على تقدير إضافته إلى ما بعد (تيم) الثانية، أو بتقدير إضافته إلى محذوف وهو: (عدي). (وتيم) الثاني لا يجوز فيه إلا النصب على أنه منادى مضاف، أو مفعول بإضمار (أعني)، أو عطف بيان، أو توكيد، أو بدل. انظر: "ارتشاف الضرب" 3/ 135. والشاهد فيه: تكرير (تيم) للتأكيد.|12:في (أ)، (ب): يتم. والمثبت من (ج).|13:لم أقف على القائل. وممن أورد هذا القول ممن سبق المؤلف: الثعلبيُّ في "تفسيره" 3/ 136 أ، قائلاً: (وقال بعضهم: ..) ولم يعين.|14:ورد في: (ج) في هذا الموضع كلمة زائدة، لا وجه لها، وهي: (قوله).|15:وقد جوز هذا الرأي الفخر الرازي في "تفسيره" 9/ 64 قائلًا: (وقال المحققون: دخول اللفظ المهمل الضائع في كلام أحكم الحاكمين، غير جائز)، ثم ذكر هذا الرأي واستصوبه.</p><p>والذي دفع لهذا الرأي هو تنزيه كتاب الله من أن يكون فيه حرف زائد مهمل، لا معنى له. وهذا فيه نظر؛ لأن القائلين بزيادة (ما) ويغرها من الحروف، لا يقصدون جواز سقوطها، وأنها مهملة لا معنى لها، بل يقولون: إنها مَزيدة لمعنًى مقصود، وهو -هنا- في (ما): التوكيد؛ أسوة بسائر ألفاظ التوكيد الواردة في القرآن. وكون (ما) للاستفهام التعجبي، قد رَدَّه علماءُ النحو، من ناحية الصناعة النحوية، ومنهم: ابن هشام في "المغني" 394، وأبو حيان في "البحر المحيط" 3/ 98، والسمين الحلبي في "الدر المصون" 3/ 362.|16:ضُبطت: (لَيْنًا) بفتح اللام، في "تهذيب اللغة" 4/ 3314 (لين)، و"تفسير الثعلبي" 3/ 136 أ، وضبطت في بقية المصادر اللغوية التالية: (لينا) بكسر اللام.|17:ما بين المعقوفين زيادة من (ج).|18:ورد في مصادر اللغة: اللِّين: ضد الخشونة، قال الراغب: (ويستعمل ذلك في الأجسام، ثم يستعار للخُلُق وغيره من المعاني). "مفردات ألفاظ القرآن" 752 (لين). أما (اللِّيان) بكسر اللام فمصدر الملاينة، يقال: (لايَنْته مُلايَنْة)، و (لِيَانا). انظر (لين) في: "جمهرة اللغة" 2/ 989، و"الصحاح" 6/ 2198، و"المقاييس" 5/ 225، و"اللسان" 7/ 4117، و"القاموس" (1232).|19:البيت، لكُثَيِّر عَزَّة وقد ورد منسوبًا له في: "زهر الآداب" 1/ 17. وليس في ديوانه، وأورده محقق ديوانه وجعله مما نُسِب له، وأحال على المصدر السابقة == انظر "ديوانه" 176.</p><p>ورواية البيت في المصدر السابق:</p><p>وإن هي أعطتك الليان فإنها ... لآخر من خلانها ستلين|20:من قوله: (الفظ ..) إلى (.. وأصله صبب): نقله -بتصرف- عن "معاني القرآن"، للزجاج: 1/ 483.|21:انظر: "تهذيب اللغة" 3/ 2806 (فظظ)، و"الفرق بين الحروف الخمسة" 155، و"زينة الفضلاء" للأنباري 98.|22:انظر: "اللسان" 6/ 3437 (فظظ). قال الراغب: (الفظُّ: الكريه الخُلُق؛ مستعار من: (الفظِّ)؛ أي: ماء الكرش، وذلك مكروه شربه، لا يتناول إلا في أشدّ ضرورة). "مفردات ألفاظ القرآن" 640 (فظظ).|23:في (أ): (حَذِرَ) بفتح الراء، وفي (ب)، (ج): مهملة من الشكل، والصواب ما أثبت.|24:في (أ): (حَذَرت) بفتح الذال، وفي (ب)، (ج): مهملة من الشكل، والصواب ما أثبت، وهي بكسر الذال. انظر: (حذر) في: "التهذيب" 1/ 767، و"القاموس" 373.|25:في (أ): (فَرِق) بفتح القاف. وفي (ب)، (ج): مهملة من الشكل. والصواب ما أثبت. يقال: (رجلٌ فَرقٌ): شديد الفزع. انظر: "القاموس" 917 (فرق).|26:في (أ): (صبِّ)، وفي (ب)، (ج): مهملة من الشكل. والصواب ما أثبت. يقال: (رجلٌ صبُّ): بيِّنُ الصَّبَابَة. والصبابة: رِقّة الشَّوْق. انظر: "جمهرة اللغة" 1/ 71 (صب)، و"المخصص" 4/ 61.|27:في (أ): (صبَبٌ) بفتح الباء الأولى، وفي (ب)، (ج): مهملة من الشكل، == والصواب ما أثبت.</p><p>قال سيبويه عن (صَبِّ): (زعم الخليل أنها (فَعِلٌ)؛ لأنك تقول: (صَبِبْتُ صبابة)، كما تقول: (قَنِعْتُ قَناعةً)، و"قَنِعٌ". "كتاب سيبويه" 4/ 419. وانظر: "المخصص" 4/ 61.|28:قوله في: "تفسير الثعلبي" 3/ 136 ب.|29:قال السمين الحلبي: (وعن الغِلْظَةِ تنشأ الفظاظة، فلم قُدِّمت؟ فقيل: قدِّم ما هو ظاهر للحسِّ، على ما هو خافٍ في القلب؛ لأنه كما تقدم أن الفظاظة: الجفوة في العشرة قولًا وفعلًا. والغِلْظُ: قساوة القلب، وهذا أحسن من قَوْلِ من جعلهما بمعنًى، وجمع بينهما). "الدر المصون" 3/ 463.|30:انظر: "تهذيب اللغة" 3/ 2799 (فض)، و"الفرق بين الحروف الخمسة" 156، و"زينة الفضلاء" 98.|31:معناه لا يكسر الله أسنانك، ويفرِّقها. والفم يقوم مقام الأسنان. وقد يقال: (لا يُفْضِ الله فاك)، ومعناه حينها: لا يجعل الله فاك فضاءً، لا أسنان فيه.</p><p>انظر: "الزاهر" 1/ 274 - 277، و"تهذيب اللغة" (فض) 3/ 2799، و"الفائق" 3/ 123، و"النهاية في غريب الحديث" 3/ 453.|32:في "معاني القرآن" له 1/ 482. نقله عنه بنصه.|33:في "المعاني" مما يوجب.|34:في "المعاني" في الدين.|35:في (ج): (سوارا).|36:قال في (لسان العرب): (والمَشُورَة بضم السين (مَفْعَلة) ولا تكون (مفعولة)؛ لأنها مصدر، والمصادر لا تجيء على مثال (مفعولة)، وإن جاءت على مثال (مفعول)، وكذلك المَشْوَرَة) 4/ 2358 (شور).|37:(ومَشْوَرة): ساقطة من (ج). انظر (شور) في: "تهذيب اللغة" 2/ 1803، و"اللسان" 4/ 2358.|38:في (ج): (فإذا).|39:انظر: "معاني القرآن" للزجاج 1/ 483. ومن قوله: (قال أصحاب المعاني ..) إلى نهاية تفسير هذا المقطع: موجود في "تفسير الثعلبي" 3/ 137أ. نقله عنه بالمعنى.|40:في (ب): (من الله فيه) بدلًا من (فيه من الله).|41:في (ج): (ورحى).|42:أخرج هذه القراءة عنه البخاري في "الأدب المفرد" رقم (257)؛ وابن أبي == حاتم في "تفسيره" 3/ 802، وذكرها ابن جني في "المحتسب" 1/ 175، وأبو الليث في "بحر العلوم" 1/ 311، والثعلبي في "تفسيره" 3/ 137أ، وابن الجوزي في "زاد المسير" 1/ 489، ونسبها -كذلك- إلى ابن مسعود، وذكرها السيوطي في "الدر المنثور" 2/ 160 وقال: (بسند حسن)، وزاد نسبة إخراجها إلى سعيد بن منصور، وابن المنذر.|43:قوله في: "تفسير الثعلبي" / 137 أ.|44:من قوله: (ومكايدها ..) إلى (.. خاص في العرب): ساقط من (ج).|45:أخرج قوله: الحاكم في "المستدرك" 3/ 70 كتاب معرفة الصحابة. وقال: (صحيح على شرط الشيخين) ووافقه الذهبي، وأخرجه البيهقي في "السنن الكبرى" 10/ 109 كتاب أدب القاضي. باب: (مشاورة الوالي ..)، والنحاس في "معاني القرآن" 1/ 502.|46:قوله في: "تفسير الطبري" 4/ 152، و"ابن أبي حاتم" 3/ 802، و"الثعلبي" 3/ 137أ، وأورده السيوطى في "الدر" 2/ 159وزاد نسبة إخراجه إلى ابن المنذر.|47:قوله في "تفسير الطبري" 4/ 152، والمصادر السابقة.|48:قوله في: "تفسيره" 1/ 310، و"تفسير الثعلبي" 3/ 137 أ.|49:في (ب): (ورخصا).|50:قوله معناه في كتاب "الأم" 5/ 19.|51:الحديث: أخرجه مسلم في "صحيحه" رقم (1421) كتاب النكاح. باب: (استئذان الثيب في النكاح). ونصه عنده:</p><p>(الثَّيِّبُ أحق بنفسها من وليها، والبكر تُستَأمَر، وإذنها سكوتها). وورد عنده بلفظ: "الأيِّم أحق .. والبكر تستأذن في نفسها، وإذنها صُمَاتُها).</p><p>وأخرجه الشافعي بلفظ (تستأمر) في "الأم" 7/ 165، وبلفظ (تستأذن) في "الأم" 2/ 19، وأخرجه أحمد في "المسند" 1/ 219، وانظر: "الدراية" لابن حجر 2/ 59، 61، 62.|52:في (ب): أكرمها.|53:قوله في: كتاب "الأم" للشافعي 7/ 100، و"أحكام القرآن" له 2/ 119، و"تفسير ابن أبي حاتم" 632، و"معاني القرآن" للنحاس 502، و"سنن البيهقي" 10/ 109، كتاب "آداب القاضي"، و"زاد المسير" 1/ 488. وأورده السيوطي في: "الدر" 2/ 159 وزاد نسبة إخراجه إلى سعيد بن منصور، وابن المنذر.|54:قوله، في: "تفسير الطبري" 4/ 153، و"زاد المسير" 1/ 488.|55:في (أ)، (ب)، (ج): إمضاؤه. وما أثبت هو الصواب.
  3,160,"<div class=ar lang=ar><p>قوله تعالى: <span class="qpc-hafs">﴿إِنْ يَنْصُرْكُمُ اللَّهُ فَلَا غَالِبَ لَكُمْ وَإِنْ يَخْذُلْكُمْ﴾</span> الآية.</p><p>معنى (الخِذْلان): القعود عن النُّصرَةِ وقت الحاجة إليها، والإسلامُ للهَلَكَةِ.</p><p>يقال: (خَذَلَ، يَخْذُلُ، خِذْلانًا، وخَذْلًا). ويقال للبقرة والظَّبْيَة، إذا تخلفت مع ولدها في المرعى، وتركت صواحباتها: (خَذُول) {1}.</p><p>قال {2} طَرَفَة:</p><p>خَذُولٌ تُرَاعِي رَبْرَبًا بِخَمِيلَةٍ ... تَنَاوَلُ أطرافَ البَرِيرِ وترتدي {3} وقال ذو الرُّمَّةِ {4}:</p><p>دَعَتْ مَيَّةَ الأعدادُ واستَبدَلت بها ... خَنَاطِيلَ آجَالٍ {5} مِنَ العِينِ {6} خُذَّلِ {7}</p><p>أي: متخلفات من الأولاد.</p><p>والخَنَاطِيل {8}: جماعاتٌ في تَفْرِقَةٍ، لا واحد لها مِنْ لَفْظِها. وقيل: واحدها (خُنْطُول) {9}.</p><p>قال محمد بن إسحاق بن يَسَار -في هذه الآية- {10}: أي: إنْ يَنْصُرْكَ {11} اللهُ؛ فَلاَ غالبَ لك مِنَ النَّاس، ولن يَضُرَّكَ خِذْلانُ مَنْ خَذَلَكَ، وإنْ يَخْذلْكَ؛ فَلَنْ يَنْصُرَكَ الناسُ؛ أي: لا تترك أمري للناس، وارفض الناسَ {12} لأمري.</p><p>وقوله تعالى: <span class="qpc-hafs">﴿فَمَنْ ذَا الَّذِي يَنْصُرُكُمْ مِنْ بَعْدِهِ﴾</span>.</p><p>(مَنْ) -ههنا-: تقريرٌ لِلنَّفْي؛ أي: لا يَنْصُرُكُمْ أحدٌ {13} مِنْ بَعْدِهِ. وإنما تضمن حرفُ الاستفهام معنى النفي؛ لأن جوابَهُ يجب أن يكون بالنفي، فصار ذِكْرُهُ يغني عن ذِكْرِ جوابه، وكان أبلغ لتقرير المخاطَبِ فيه، بما لا يتهيأ له إنكاره.</p></div>",footnotes:1:وتُسمَّى كذلك: خاذِل.</p><p>انظر هذه المعاني لـ (خذل) في: "ما اتفق لفظه واختلف معناه" لليزيدي 121، و"التهذيب" 1/ 998، و"معاني القرآن"، للنحاس 1/ 503، و"المقاييس" 2/ 165، و"الكليات" لأبي البقاء 310، و"اللسان" 2/ 1118.|2:في (ج): (وقال).|3:البيت من معلقته، وهو في: "ديوانه" 21، و"شرح القصائد السبع" لابن الأنباري 141، و"جمهرة أشعار العرب" ص 149، و"تهذيب اللغة" 1/ 999 (خذل)، و"المقاييس" 2/ 165، و"شرح المعلقات السبع" للزوزني 47، و"شرح القصائد العشر" للتبريزي 58، و"اللسان" 2/ 1118 ولم ينسبه.</p><p>قوله: (تراعي ربربا)؛ أي: ترعى مع (الرَّبْرَب)، وهو: قطيع الظباء وبقر الوحش، وقيل: أولاد البقرة.</p><p>و (الخميلة): الأرض السهلة اللينة، التي فيها شجر. والجمع: (خَمائل).</p><p>و (البَرِير): ثمر الإراك البالغ، ومفردها: (بَرِيرة).</p><p>وخَصَّ الخذول -هنا-؛ لأنها فَزِعةٌ بانفرادها، وَلِهَةٌ على وليدها، فهي تمد عنقها مرتاعة، فيظهر -حينها- جمالها، وحسنها، ولو كانت في قطيعها، لم يَبِنْ حسنُها، ثم وصفها بأنها ترعى أطراف شجر الأراك، وتمد عنقها، وتتطاول؛ لتنال ما علا من أغصان الشجر، فتتهَدَّل عليها الأغصان حتى تصبح كأنها رداءٌ لها.</p><p>انظر: "شرح القصائد" لابن الأنباري 141 - 142، والتبريزي 58 - 59.|4:هو: أبو الحارث، غَيْلان بن عُقْبَة بن بُهَيْش. شاعر إسلامي، في الطبقة الثانية من فحول شعراء الإسلام، مات سنة (117هـ).</p><p>انظر: "الشعر والشعراء" ص 350، و"طبقات فحول الشعراء" 2/ 549، و"وفيات الأعيان" 4/ 11.|5:في (أ)، (ب)، (ج): مهملة من الشكل. والمثبت من مصادر البيت.|6:في (أ): (العَيْن). في (ب)، (ج): مهملة من الشكل. والمثبت من مصادر البيت.|7:البيت في: ديوانه: 1455.</p><p>وورد منسوبًا له في: "الصحاح" 4/ 1686 (خطل)، و"اللسان" 5/ 2835 (عدد)، و"التاج" 14/ 215 (خنطل).</p><p>(الأعداد): جمع (عِدٍّ)، وهو الماء الدائم الذي لا ينقطع. و (الخناطيل): القطعان من الإبل والبقر، وهي -هنا في البيت- بقر الوحش. و (آجال): جمع: (إجْل) -بكسر الهمزة، وتسكين الجيم- وهو: القطيع من بقر الوحش والظباء. و (العِين): بقر الوحش. والثور منها: (أَعْيَن)، والبقرة: (عَيْناء). و (خُذل): أي: أقامت على ولدها، وتركت صواحبها.</p><p>الشاعر -هنا- يذكر امرأة تسمى (ميّة)، وهي التي كان يشبب بها ويعشقها، يقول: تركت منازلَها وظعنت عنها، بعدما نضبت الغدرانُ في القيظ، وحضرت ماءً عِدًّا؛ واستبدلت الدارُ بها بقرَ الوحش، التي خالفتها إلى منازلها وأقامت فيها.</p><p>انظر: "اللسان" 5/ 2835 (عدد)، 3/ 1278 (خنطل)، 1/ 32 - 33 (أجل) ، و"القاموس" ص 1218 (عين).|8:في (أ)، (ب)، (ج): والخناظيل -بالظاء-. والمثبت من: مصادر اللغة.|9:في (أ)، (ب)، (ج): (خنظول) بالظاء. == الوارد في كتب اللغة التي رجعت إليها، أن واحد الخناطيل: (خِنْطيلة)، و (خُنْطُولة). أما (الخنطول)، فهو يطلق على: القرن الطويل.</p><p>انظر: "التهذيب" 1/ 1113 (خنطل)، و"الصحاح" 4/ 1686 (خطل)، و"اللسان" 3/ 1278 (خنطل)، و"التاج": 14/ 215 (خنطل).|10:قوله، في:"سيرة ابن هشام" 3/ 70، و"تفسير الطبري" 4/ 154، و"تفسير ابن أبي حاتم" 3/ 803.|11:في (ج): (ينصركم).|12:في "سيرة ابن هشام": (وارفض أمر الناس ..).|13:(أحد): مطموسة في: (ب).
  3,161,"<div class=ar lang=ar><p>قوله تعالى: <span class="qpc-hafs">﴿وَمَا كَانَ لِنَبِيٍّ أَنْ يَغُلَّ﴾</span> الآية.</p><p>اختلفوا في سبب نزول هذه الآية:</p><p>فرَوَى عكرمةُ، ومِقْسَم {1}، وسعيد بن جبير، عن ابن عباس: أنَّ الآية نزلت في قَطِيفَةٍ {2} حمراءَ، فُقِدَت يوم بَدْر، قال بعض الناس: لَعَلَّ النبي ﷺ أخذها {3}.</p><p>وقال -في رواية الضحّاك- {4}: إن رسول الله ﷺ، لَمَّا وَقَعَ في يده غنائمُ هَوَازِنَ يوم حُنَيْنٍ، غَلَّهُ رجلٌ بِمِخْيَط، فأنزل الله هذه الآية.</p><p>وقال قتادة -في نزول هذه الآية- {5}: نزلت وقد غَلَّ طوائفُ مِن أصحابه. ورُوي عن ابن عباس -من طريقٍ آخرَ-: أنَّ أشراف الناس استدعوا رسول الله ﷺ، [وطلبوا] {6} تخصيصهم {7} بشيءٍ مِنَ المغانم؛ فنزلت هذه الآيةُ {8}</p><p>وقال الكلبي {9}، ومقاتل {10}: نزلت حين ترك الرُّمَاةُ المَرْكَزَ يومَ أحُد؛ طلبا للغنيمة، وقالوا: نخشى أنْ يقول النبي ﷺ: مَن {11} أخَذَ شيئًا فهو له، وأنْ لا يقسِم الغنائمَ، كما لم يَقْسِمْ {12} يومَ بَدْر. فقال النبي ﷺ: ظننتم أنَّا نَغُلُّ، ولا نَقْسِم لكم. فأنزل الله هذه الآية.</p><p>وفي قوله <span class="qpc-hafs">﴿يَغُلَّ﴾</span> قراءتان: أحدهما: فتح الياء، وضم الغَيْن {13}؛ ومعناه: ما كان لِنَبِيٍّ أن يَخُونَ. مِنَ (الغُلُول)، وهو: الخِيَانَةِ. يُقال: (غَلَّ، يَغُلُّ، غُلُولًا): إذا خَانَ، وأصلُهُ: أخْذُ الشيء في خُفْيَةٍ {14}.</p><p>قال الزّجاج {15}: وما {16} كان مِنْ هذا الباب، فهو راجعٌ إلى هذا، مِنْ ذلك: (الغَالُّ): وهو الوادي الذي {17} يُنْبِتُ الشجرَ، في مُطْمَئِن مِنَ الأرض {18}، وجمعه: (غُلّان)، ومن ذلك: (الغِلّ): الحقد في الصدر؛ لأنه كامن {19}، و (الغِلاَلَة): الثوب الذي يلبس تحت الثياب {20}. و (الغَلَلُ) {21}: الماء الذي يجري في أصول الشجر؛ لأنه مستَتِرٌ بالأشجار.</p><p>فمعنى قوله تعالى: <span class="qpc-hafs">﴿وَمَا كَانَ لِنَبِيٍّ أَنْ يَغُلَّ﴾</span>، أي: أن يَخُونَ فيكم {22} الغنيمةَ مِن أصحابه. أو أنْ يَخُونَ بأن يعطيَ البعضَ دون البعضِ، على ما روي في سبب النزول.</p><p>فإن قيل: ما معنى تخصيص النبي ﷺ ههنا-، وغيرُهُ يساويه في أنه ليس له ذلك؟.</p><p>قلنا: (أَنْ) مع المستقبل، تكون بمعنى المصدر؛ كأنه قيل: (ما كان لِنَبي الغُلُول)؛ أراد: ما غَلَّ نَبِيٌّ. ينفي عن الأنبياء الغُلُولَ، لا أنه {23} ينهاهم بهذا اللفْظَ.</p><p>وقال {24} بعض أهلِ المعاني: اللّام فيه منقولة؛ معناه: ما كان نَبِيٌّ {25} ليَغُل، كقوله -عز وجل-: <span class="qpc-hafs">﴿مَا كَانَ لِلَّهِ أَنْ يَتَّخِذَ مِنْ وَلَدٍ﴾</span> [مريم: 35]، أي: ما كان الله لِيَتّخِذَ [ولدا] {26}، على نفي الاتخاذ، -كذلك- الآيةُ على نفي الغُلُول عن الأنبياء.</p><p>وحجة هذه القراءة: ما روي عن ابن عباسٍ -في أكثر الروايات- في سبب نزول الآية، وعن الكلبي ومقاتل، وذلك يدل على نَسَبِ الغُلُول إلى النبي ﷺ، فَنَفى ذلك عنه. و-أيضًا- فإنَّ ما هو مِن هذا {27} القبيل في التنزيل، أُسنِدَ الفعلُ فيه إلى الفاعل، نحو: <span class="qpc-hafs">﴿مَا كَانَ لَنَا أَنْ نُشْرِكَ بِاللَّهِ﴾</span> [يوسف: 38]، و <span class="qpc-hafs">﴿مَا كَانَ لِيَأْخُذَ أَخَاهُ﴾</span> [يوسف: 76]، و <span class="qpc-hafs">﴿وَمَا كَانَ لِنَفْسٍ أَنْ تَمُوتَ﴾</span> [آل عمران: 145]، و <span class="qpc-hafs">﴿وَمَا كَانَ اللَّهُ لِيُضِلَّ قَوْمًا﴾</span> [التوبة: 115] ، و <span class="qpc-hafs">﴿وَمَا كَانَ اللَّهُ لِيُطْلِعَكُمْ﴾</span> [آل عمران: 179].</p><p>ولا يكاد يجيء منه: (ما كان زيدٌ ليُضْرَبَ)، فيُسنَد الفعلُ فيه إلى المفعول به، فكذلك: <span class="qpc-hafs">﴿وَمَا كَانَ لِنَبِيٍّ أَنْ يَغُلَّ﴾</span> يُسندُ {28} فيه الفعلُ إلى الفاعل. يُؤكِّدُ {29} هذا الفصل، ما حكى أبو عبيد {30} عن يونس {31} أنه اختار (يَغُلّ) -بفتح الياء-، وقال: لا يكون في الكلام: (ما كان لك أن تُضْرَب) بضم التاء.</p><p>وهذه القراءة اختيار ابن عباس، كان {32} يقرأ (يَغُلّ) بفتح الياء، فقيل له: إنَّ ابن مسعود يقرأ: <span class="qpc-hafs">﴿يُغَلّ﴾</span>، فقال ابن عباس: قد كان النبي يُقتَل، فكيف {33} لا يُخَوَّنُ؟ {34}.</p><p>والقراءة الثانية: <span class="qpc-hafs">﴿يُغَلّ﴾</span> بضم الياء، وفتح الغين.</p><p>وهذه القراءة تحتملُ وجهين {35}: أحدهما: أن يكون من (الغُلُول). والثاني: أن يكون من (الإغلال).</p><p>فإن جعلتها من (الغُلُول) احتملت معنيين: أحدهما: أن معنى قوله: <span class="qpc-hafs">﴿وَمَا كاَنَ لِنبيٍّ أَن يُغَلّ﴾</span> {36}؛ أي: ليس لأحدٍ أن يَغُلَّهُ، فيأخذ مِنَ الغنيمة التي حازها {37} على طريق الخيانة، وإن كان لا يجوز أن يُغَلّ غيرُ النبيِّ، مِن إمام المسلمين وأميرٍ لهم {38}.</p><p>وفائدة تخصيص النبي ﷺ بالذِّكْر: أن الغُلُول يَعْظُمُ بحضرته، ويكبر كِبَرًا لا يكبر عند غيره؛ لأن المعاصي بحضرته أعظم.</p><p>المعنى {39} الثاني: أن تكون (أَنْ) مع الفعل، بمنزلة المصدر؛ كما ذَكَرْنا في القراءة الأولى. ويكون المعنى: ما كان لِنَبيٍّ غُلولٌ من المُتَحقِّقِينَ بِنُبُوَّتِهِ؛ أي: لم يَخُنْهُ أصحابُهُ وأنصارُهُ، ويكون في هذا ذَمٌّ لِمَن خانَه.</p><p>يُؤكِّد هذا المعنى ما روى عطاءٌ عن ابن عباس {40}، في قوله: <span class="qpc-hafs">﴿وَمَا كاَنَ لِنبيٍّ أَن يَغُلَّ﴾</span>؛ يريد: أن يكون ممن يَصْحَبُهُ، أحدٌ يَغُلُّ ويَسْتَحلُّ الغُلُولَ.</p><p>وإن أخذت بهذه القراءةِ مِنَ (الإغْلال)، احتَمَلَتْ -أيضا- معنيين:</p><p>أحدهما: أن يكون (الإغلال) بمعنى (الغُلول). يقال: (غَلّ الرجلُ مِنَ الغنيمة، يَغل غَلًّا، وغلولًا)، و (أَغَلّ إغلالًا): إذا سَرَق منها {41}. ذكره الزّجاج في باب الوفاق {42} ومِن هذا يقال: (أغَلّ الجازِر، والسَّالِخُ): إذا أبْقَى في الجِلْدِ شيئًا مِنَ اللَّحْمِ؛ على طريقِ السَّرِقَةِ والخيانة {43}.</p><p>قال النَّمْر بن تَوْلَب {44}: جَزَى اللهُ عنَا جَمْرَةَ ابْنَةَ نَوْفَلٍ ... جَزاءَ مُغِلٍّ {45} بالأمانَةِ كاذبِ {46}</p><p>وقال آخر:</p><p>حَدَّثْتَ {47} نفْسَكَ بالوَفَاءِ ولم تَكُنْ ... للْغَدْر خائنَةً مُغلَّ الإصْبَع {48}</p><p>قوله: (لِلْغَدْرِ) {49}؛ أي: لِكَراهَةِ الغَدرِ. و (الخائِنَة): يحتمل أن تكَون مصدرا؛ كـ (العافِيَةِ)، و (العَاقِبَةِ).</p><p>و-حينئذٍ - يُقَدَّرُ حذفُ المضاف؛ أي: لم يكنَ صاحبَ خائِنَةٍ؛ أي: خيانَة. وإنْ شئتَ جعلته مثل: (راوِيَة).</p><p>ونَسَبَ {50} الإغْلالَ إلى الإصْبَع، كَمَا نَسَبَ {51} الآخرُ الخيانةَ إلى اليَدِ، في قوله:</p><p>أَحَذَّ {52} يَدِ القَمِيصِ {53} قال: جعلت (الإغلالَ) بمعنى (الغُلول). فقد ذكرنا للغُلُول معنيين في هذه القراءة.</p><p>المعنى الثاني: أنْ يكون (الإغلالُ) بمعنى النسبة إلى الغُلُول. وقد يَردُ {54} (الإفْعَال) بمعنى النسمة، شاذًّا، وإن كان الأكثر فيه التَفْعيل؛ كقولهم: (أسْقاهُ)، أي: قال له: سَقَاكَ اللهُ {55}.</p><p>ومنه قول ذي الرُّمَّة:</p><p>وأُسْقِيهِ حتى كاد {56} ... البيت.</p><p>ويقال (أَكْفَرَهُ): إذا نَسَبَهُ إلى الكفر.</p><p>قال الكُمَيْت {57}:</p><p>فَطَائِفَةٌ قَدْ أكفَرُوني بِحُبِّكُمْ {58}</p><p>فيكون المعنى: وما كان لِنَبِيٍّ أن يُنْسَبَ إلى الغُلُول؛ أي: لا يُقَال له غَلَلْتَ.</p><p>قال الفرّاءُ، في {59} هذه الآية {60}: وقرأ {61} أصحاب عبد الله {62}: <span class="qpc-hafs">﴿يُغَلّ﴾</span>؛ يريدون: أنْ يُسَرَّقَ ويُخَوَّنَ {63}، وذلك جائزٌ، وإنْ لم يَقُل: (يُغلَّل)، فيكون مثل قوله: <span class="qpc-hafs">﴿فَإِنَّهُمْ لَا يُكَذِّبُونَكَ﴾</span>، و <span class="qpc-hafs">﴿ويُكَذِّبُونَكَ﴾</span> {64} [الأنعام: 33].</p><p>ومِن حُجَّةِ هذه القراءة: ما رُوي عن ابن عبّاس، من طريق الضّحاك، وما روي عن قتادة، في سبب نزول هذه الآية {65}.</p><p>وقوله تعالى: <span class="qpc-hafs">﴿وَمَنْ يَغْلُلْ يَأْتِ بِمَا غَلَّ يَوْمَ الْقِيَامَةِ﴾</span>.</p><p>أي: يأتي به حاملًا له على ظهره، كما روي أن النبي ﷺ، خَطَبَ يومًا، فذَكَرَ الغُلُولَ، وعَظَّمَه، وعَظَّمَ أَمْرَهُ، فقال: "لا أُلْفِيَنَّ {66} أحدَكمْ يجيء على رقبته يوم القيامة بَعِيرٌ له رُغَاء {67}، يقول: يا رسولَ الله! أعِنِّي {68}.</p><p>فأقول: لا أملك لك مِنَ الله شيئًا، قد أَبْلَغْتُكَ". وذَكَر في الحديث: الشاةَ والفرَسَ والصَّامِتَ {69}.</p><p>وهذا قول: ابن عباس {70}، وأبي هريرة {71}، وأبي حُمَيْد الساعدي {72}، وابن عمر {73}، وقتادة {74}.</p><p>وقوله تعالى: <span class="qpc-hafs">﴿ثُمَّ تُوَفَّى كُلُّ نَفْسٍ مَا كَسَبَتْ﴾</span>.</p><p>قال ابن عباس {75}: يريد: تجازى ثوابَ عَمَلِها.</p><p><span class="qpc-hafs">﴿وَهُمْ لَا يُظْلَمُونَ﴾</span>. قال {75}: وهم لا يُنقَصُونَ مِنْ ثوابِ أعمالهم شيئًا.</p></div>",footnotes:1:هو: أبو القاسم، مِقْسم بن بُجْرة، ويقال: نَجْدة الكِنْدي، ثم التُّجيبي النخعي. يقال له: مولى ابن عباس، من مشاهير التابعين، أسلم في حياة النبي ﷺ، وبايع == معاذًا في اليمن، ويقال: إن له صُحبة، صَدوق وكان يُرْسل، مات سنة (101هـ). انظر: "ميزان الاعتدال" 5/ 301، و"الإصابة" 3/ 455، و"تقريب التهذيب" 545 (6873).|2:القطيفة: دِثَارٌ أو كِسَاءٌ مُخَمَّلٌ؛ أي: له أهداب. وجمعها: قطائف، وقُطُف. انظر (قطف) في: "القاموس" 845، و"المعجم الوسيط" 2/ 753.|3:الأثر عن ابن عباس -من رواية مقسم-، أخرجه: أبو داود (3971) كتاب الحروف والقراءات، والترمذي (3009) كتاب التفسير. باب: (4) من سورة آل عمران. وقال: (حديث حسن غريب)، والطبري في "تفسيره" 7/ 348، 349، وأورده السيوطي في "الدر" 2/ 361 وزاد نسبة إخراجه إلى عبد بن حميد. ومن رواية عكرمة، أخرجه: الطبري في "تفسيره" 4/ 155، وابن أبي حاتم في "تفسيره" 3/ 803، والطبراني في "المعجم الكبير" 11/ 364 رقم (12028، 12029)، والواحدي في "أسباب النزول" (130). ومن رواية سعيد بن جبير، أخرجه الطبري في "تفسيره" 4/ 155.|4:من رواية جويبر عن الضحاك، عن ابن عباس، أوردها الثعلبي 3/ 140 ب، وابن الجوزي في "زاد المسير" 1/ 490.|5:قوله في: "تفسير الطبري" 4/ 157، و"زاد المسير" 1/ 490. وهذا القول من قتادة تفسير للآية على القراءة الثانية <span class="qpc-hafs">﴿يَغُلَّ﴾</span>.|6:ما بين المعقوفين زيادة يقتضيها السياق.|7:ويجوز أن تكون: لتخصيصهم. بدلًا من الكلمة التي أضفتها قبلها.|8:لم أقف على مصدر هذه الرواية، وقد ذكرها ابن الجوزي في "زاد المسير" 1/ 490.|9:قوله في "تفسير الثعلبي" 3/ 140 ب.|10:قوله في "تفسيره" 1/ 310، والمصدر السابق. وبه قال الفراء في "معاني القرآن" 1/ 246.|11:من قوله: (من ..) إلى (فقال النبي ﷺ): ساقط من (ج).|12:في (أ): (يُقْسَم). وفي: (ب)، (ج): مهملة من الشكل. وأثبَتُّ ضبطَها من "تفسير الثعلبي" 3/ 140 ب؛ نظرًا لتقارب سياق المؤلف لهذا القول، مع سياق الثعلبي، وهي الأليق بسياق الكلام.|13:القراءة بفتح الياء، وضم الغَين: <span class="qpc-hafs">﴿يَغُلَّ﴾</span>، قرأ بها: ابن كثير، وأبو عمرو، وعاصم. وقرأ الباقون: <span class="qpc-hafs">﴿يَغُلَّ﴾</span> -بضم الياء، وفتح الغين-. انظر: "الحجة" للفارسي 3/ 94، و"النشر" 2/ 243، و"إتحاف فضلاء البشر" 181.|14:انظر: "تهذيب اللغة" 3/ 2689.|15:في "معاني القرآن" له 1/ 484، وقد نقله عنه بتصرف، واختصار. وقد ورد نص قول الزجاج في "تهذيب اللغة" 3/ 2689، مع اختلاف يسير عما في "معاني القرآن"، ووافق نقل المؤلف -هنا- عن الزجاج، بعضًا مما في نسخة "المعاني" المطبوعة، ووافق بعضًا مما في "التهذيب"، وليس في "المعاني". مما يدل على أن المؤلف نقل عن نسخةٍ من المعاني فيها بعض اختلاف عن النسخة المطبوعة المتداولة، أو نقل قولَ الزجاج عن كتابٍ آخر تصرف في عبارة الزجاج.|16:في "المعاني": فكل ما.|17:في (ب): (التي).|18:(في مطمئن من الأرض): ليست في "معاني القرآن". والعبارة في "التهذيب" (وهو الوادي المطمئن الكثير الشجر). وانظر: "المنتخب" لكراع النمل 1/ 424.|19:في "المعاني": وهو الحقد. وفي "التهذيب": وهو الحقد الكامن.|20:قوله: (والغلالة: الثوب الذي يلبس تحت الثياب): أورده في "التهذيب" من قول أبي زيد، وليس من قول الزجاج.|21:في (أ)، (ب)، (ج): (الغال). وفي "المعاني": الغل. وما أثبت من مصادر اللغة. انظر (غلل) في: "إصلاح المنطق" 26، و"غريب الحديث" لأبي عبيد 1/ 49؛ و"جمهرة اللغة" لابن دريد 2/ 2012، و"تهذيب اللغة" 3/ 2689، و"المقاييس" 4/ 376، و"اللسان" 6/ 3287.|22:هكذا وردت (فيكم) في (أ)، (ب)، (ج)، و"تفسير الوسيط" المؤلف 371. وأرى أن الأصوب أن تكون: (فيكتم)؛ لأنه أنسب للسياق الذي أراد المؤلف من خلاله أن يُدلِّل على أن معنى (الغل) -هنا- فيه كتمان وكمون وستر، وهو أنسب بسبب النزول الذي أورده المؤلف سابقًا، وأشار إليها هنا. ويعزز هذا ما قاله في تفسيره "الوجيز": (أي: يخون بكتمان شيء من الغنيمة عن أصحابه) 1/ 240.|23:في (ج): لأنه -. بدلًا من: (لا أنه).|24:من قوله: (وقال ..) إلى (.. ليتخذ ولدا): نقله بنصه عن "تفسير الثعلبي" 3/ 141 أ. ولم أقف على من قال بهذا القول، من أصحاب المعاني.|25:(في) (ج): (لنبي).|26:ما بين المعقوفين زيادة من (ج).|27:من قوله: (من هذا ..) إلى (يُسند فيه الفعل إلى الفاعل): نقله -بتصرف يسير- عن "الحجة" للفارسي 3/ 96.|28:من قوله: (يسند ..) إلى (.. عن يونس أنه): ساقط من (ج).|29:في (أ): (بمؤكد). والمثبت من (ب)، (ج).|30:(أ)، (ب)، (ج): (أبو عبيدة). وما أثبَتُّه فمن "تهذيب اللغة" 3/ 2688. فقد ورد فيه: (وأخبرني المنذري، عن الحسين بن فهم، عن ابن سلام، قال: كان أبو عمرو بن العلاء، ويونس يختاران ..) وذكره. وابن سَلّام، هو: أبو عبيد. والمؤلف، كثيرًا ما ينقل عن "تهذيب اللغة" بتصرف. وانظر: "اللسان" 6/ 3286 (غلل).|31:هو: أبو عبد الرحمن، يونس بن حبيب الضَبِّي بالولاء نحوي بصري، أخذ عن أبي عمرو بن العلاء، وحماد بن سلمة، وكانت له حلقة بالبصرة يحضرها أهل العلم، والأدباء وفصحاء الأعراب، توفي سنة (183هـ). انظر: "أخبار النحويين البصريين" 51، و"طبقات النحويين" للزبيدي 51، و"إنباه الرواة" 4/ 74.|32:من هنا، وإلى: (.. لأن المعاصي بحضرته أعظم): نقله -بتصرف- عن "الحجة" للفارسي 3/ 96 - 97. وهو من تتمة النقل السابق.|33:في (ج): (كيف).|34:انظر هذا الأثر عن ابن عباس في: "تفسير الطبري" 4/ 155، وانظر قراءة ابن عباس في "تفسير سفيان الثوري" 81، و"المعجم الكبير" للطبراني 11/ 101 (11174).|35:انظر: "غريب الحديث" لأبي عبيد 1/ 124، و"تفسير الثعلبي" 3/ 141 ب.|36:(أ)، (ب): (يَغُلّ) -بفتح الياء، وضم الغين، والمثبت من (ج)، وهو الصواب.|37:في (أ): (جازها). والمثبت من (ب)، (ج).|38:في (ب): (وأميرهم).|39:(المعنى): ساقط من (ب).|40:لم أقف على مصدر هذه الرواية.|41:يقال: (غَلَّ، يَغُلُّ، غُلولًا): للخيانة في المغنم خاصة. و (أغَلَّ، يُغِلُّ، إغلالًا): للخيانة في المغانم، وغيرها. و (غَلَّ، يَغِلُّ، غِلًّا): للحقد والضِّغْنِ والشحناء. انظر: "غريب الحديث" لأبي عبيد 1/ 124، و"إصلاح المنطق" 265 - 266، و"تهذيب اللغة" 3/ 2688 (غلل)، و"ما جاء على فعلت وأفعلت" للجواليقي 57، و"اللسان" 6/ 3285 (غلل).|42:لم أقف على مصدر قول الزجاج هذا.|43:انظر (غلل) في: "إصلاح المنطق" 65، و"التهذيب" 3/ 2690، و"اللسان" 6/ 3286.|44:من بداية بيت الشعر، وإلى (.. أي: لا يقال له: غللت): نقله المؤلف -بتصرف؛ واختصار- عن: "الحجة" للفارسي 3/ 95 - 97.</p><p>والنَّمْر، هو: ابن تَوْلَب بن أقَيْش العُكْلي، وكُنْيَته: أبو قيس، وأبو ربيعة. شاعر مُخضْرَم، أدرك الجاهلية والإسلام، وَفَدَ على النبي ﷺ، وأسلم وحسن إسلامه. انظر. "الشعر والشعراء" ص 191، و"الإصابة" 3/ 572، و"الأعلام" 8/ 48.|45:في (أ): (مُغَلٍّ). وفي (ب)، (ج): مهملة من الشكل. والمثبت من مصادر البيت.|46:البيت ورد في "شعره" ص 38، وورد منسوبا له في: "غريب الحديث" لأبي عبيد 1/ 123، و"إصلاح المنطق" 266، و"الزاهر" 1/ 469، و"تهذيب اللغة" 3/ 2689 (غلل)، و"الصحاح" 5/ 1784 (غلل)، و"المقاييس" 4/ 376 (غلل)، و"المحرر الوجيز" 3/ 401، و"اللسان" 6/ 3285 (غلل).</p><p>وقد ورد في "التهذيب"، و"الصحاح": (حمزة) بدلًا من (جمرة).</p><p>ومعنى (المُغِلِّ): الخائن.</p><p>ورد في إحدى نسخ "إصلاح المنطق" أشار إليها محقق الكتاب: (جَمرة، كانت أخيذة عنده، فسألته أن يزيرها قومها، ففعل، فلما أتتهم منعوها الرجوع ..). ص 266.|47:في (ب): (حدثته).|48:نسبته المصادر التالية لرجل من بني أبي بكر بن كلاب:</p><p>"مجاز القرآن" 1/ 158، و"الكامل" للمبرد 1/ 359، و"اللسان" 3/ 1294 (خون). وورد غير منسوب في: "إصلاح المنطق" 266، و"تفسير الطبري" 6/ 156، و"الجمهرة" لابن دريد 1/ 347، و"المخصص" 2/ 4، و"اللسان" 4/ 2395 (صبع)، 6/ 3286 (غلل).</p><p>يقال: (فلانٌ مُغِلُّ الإصبع): إذا كان خائنًا. انظر: "اللسان" 4/ 2395 (صبع).</p><p>يخاطب الشاعرُ رجلًا يُسمَّى (قرين بن سُلْميّ الحنفي) قتل أخاه، وقبل هذا البيت:</p><p>أقَرِينُ إشك لو رأيت فوارسي ... بعَمَايَتَيْنِ إلى جوانب ضَلْفَعِ</p><p>و (عمايتين)، و (ضلفع): مواضع في نجد. انظر مناسبة البيت في "الكامل" 1/ 358 - 359.|49:في (ج): (الغدر).|50:في (أ): (نُسِبَ)، وفي (ب)، (ج) مهملة من الشكل. والمثبت من "الحجة" للفارسي. وهو الصواب؛ حتى تتناسب مع الكلمة المنصوبة المعمولة لها بعدها.|51:في (أ): نُسِبَ. وفي (ب)، (ج) مهملة من الشكل. والمثبت من "الحجة" للفارسي، ويقال فيها ما قيل في التي قبلها.|52:في (أ)، (ب): أحد. والمثبت من (ج)، ومصادر البيت.|53:جزء من بيت شعر، للفرزدق. وتمامه:</p><p>أأطعَمْتَ العراقَ ورافِدَيْه ... فَزَاريَّا أحَذَّ يَدِ القميصِ</p><p>وهو في "ديوانه" 338، وورد منسوبًا له في: "الحيوان" للجاحظ 5/ 197، 6/ 510، و"الشعر والشعراء" 1/ 94، و"المعارف" 408، و"الكامل" 3/ 83، و"اللسان" 3/ 1688 (رفد)، 2/ 809 (حذذ).</p><p>وورد غير منسوب في: "المخصص" 2/ 4، و"همع الهوامع" 1/ 172، و"الدرر اللوامع" 25.</p><p>جاء في بعض المصادر: (أوَلَّيْت العراق)، وورد: (فَوَلَّيت)، وورد: (بَعَثت إلى العراق)، وفي الهمع: (لأطعمت ..) وهي خطأ بلا شك.</p><p>ومعنى (أحذَّ يدِ القميص)، أي: خفيف اليد. يصفه بالغلول والسرقة، وأراد: أحذ اليد، وأضاف اليد إلى القميص؛ لحاجته.</p><p>و (الحَذَذ): السرعة، وقيل: السرعة والخفة، و-كذلك-: خفة الذنَب، واللحية. و (فرسٌ أحَذّ): خفيف شعر الذنب، و (رجل أَحَذّ): سريع اليد خفيفها، وهذا التفسير هو الذي أراده المؤلف أعلاه. وقيل: (الأحَذّ): المقطوع؛ أي: أنه قصير اليد عن نيل المعالي، فجعله كالأحذ، الذي لا شعر لذنبه. انظر: "اللسان" 2/ 808 (حذذ).= والبيت، ضمن أبيات، يهجو بها الشاعرُ عمرَ بن هبيرة الفزاري، ويخاطب -معاتبًا- يزيدَ بن عبد الملك، الذي ولَّى ابنَ هبيرة العراقَ.|54:في (ج): (ترد).|55:في "الحجة" للفارسي 3/ 97: (.. كقولك: أسقيْتُهُ؛ أي: قلت له: سقاك الله).|56:وتمامه:</p><p>وأسقِيهِ حتى كاد مما أبُثُّهُ ... تكلِّمني أحجارُه ومَلاعبُه</p><p>وقبل هذا البيت:</p><p>وقفت على رَبْعٍ لِمَيَّة ناقتي ... فما زلت أبكي عنده وأخاطبه</p><p>وهو في "ديوانه" 821. وورد البيتُ -الشاهد- منسوبًا له، في: "كتاب سيبويه" 4/ 59، و"النوادر" 213، و"مجاز القرآن" 1/ 350، و"طبقات فحول الشعراء" 2/ 557، و"تهذيب اللغة"10/ 297، و"المحرر الوجيز" 3/ 404، و"لسان العرب" 4/ 2042 (سقى)، 4/ 2314 (شكا)، و"المقاصد النحوية" 2/ 176، و"التصريح" للأزهري 1/ 204، و"شرح شواهد الشافية" 41، و"الدرر اللوامع" 1/ 108.</p><p>وورد غير منسوب في: "منهج السالك" 1/ 263، و"همع الهوامع" 2/ 144. ورد في بعض الروايات: (وَأُشْكِيهِ ..)، وورد: (.. أبِثُّهُ) -بضم الهمزة، وكسر الباء-. ومعنى (أبُثُّه): أظهر له البَثَّ، وهو: الحزن والغم. انظر: "اللسان" 1/ 208 (بثث). يخاطب الشاعرُ -هنا- منزلَ معشوقته (مية). و (أسقيه): أدعوِ له بالسُّقْيا. والماضي: أسْقاهُ.|57:هو: أبو المُسْتَهِلّ، الكُمَيت بن زيد بن حُبَيْش، من بني أسد. شاعر إسلامي، عاش في أيام الدولة الأموية، ولم يدرك الدولة العباسية، وكان متشيعًا لبني هاشم، وُلِد سنة (60 هـ)، ومات سنة (126هـ).</p><p>انظر: "الشعر والشعراء" 2/ 385، و"جمهرة أشعار العرب" 351، و"أمالي الزجاجي" 137، و"الخزانة" 1/ 144.|58:صدر بيت، وعجزه:</p><p>وطائفةٌ قالوا مسيءٌ ومذنب</p><p>ورد في: "شرح هاشميات الكميت" 53، وورد منسوبًا له في "خزانة الأدب" 4/ 314.</p><p>وورد فيه: (.. قد أكفرتني بحبهم ..).</p><p>قال في "شرح الهاشميات": (و (طائفة)؛ يريد: الحرورية. (وطائفة)؛ يريد: المرجئة).|59:في (ج): (وفي).|60:في "معاني القرآن" له 1/ 246، نقله عنه بتصرف يسير.|61:في (ج): (وقال).|62:أي: ابن مسعود - رضي الله عنه -. وقال الطبري: (وهي قراءة عُظْم قَرَأة أهل المدينة والكوفة) "تفسيره" 4/ 157.|63:أي: ينسب إلى السرقة والخيانة.|64:القراءة الأولى: <span class="qpc-hafs">﴿يُكَذِّبُونَكَ﴾</span>، لابن كثير، وعاصم، وأبي عمرو، وابن عامر == والقراءة الثانية: <span class="qpc-hafs">﴿يُكْذِبُونَكَ﴾</span>، لنافع، والكسائي.</p><p>انظر:"السبعة" 257، و"الحجة" للفارسي 3/ 302، و"المبسوط" لابن مهران 618. أي: أن (كَذَّبه، وأكْذَبه)، بمعنًى واحد، وهو: نسبته إلى الكذب، وكذلك: (غَلَّ، وأغَلَّ) تتواردان على معنى واحد، وهو: النسبة إلى الغلول. انظر: "كتاب سيبويه" 4/ 58، و"الحجة" للفارسي 3/ 302. وحول رأي الفراء -هذا-، قال الأزهري: (وقال أبو العباس: جَعَلَ (يَغُل)، بمعنى: (يُغَلَّل)، وكلام العرب على غير ذلك في (فعَّلت)، و (أفْعَلْت). و (أفعلته): أدخلت ذاك فيه، و (فعَّلتُ): كثرت ذاك فيه). "التهذيب" 3/ 2688. وانظر: "الحجة" للفارسي 302 - 304.|65:انظر ما سبق ص 128 - 129.|66:في (ج): (لألفين). وهذه توافق رواية الإمام أحمد في "المسند": (لألفِيَنَّ يجيء أحدكم يوم القيامة ..) وسيأتي تخريجه.</p><p>وفي بعض الروايات: (لا ألفِينَّ ..) انظر: "فتح الباري" 6/ 186. ألفى الشيء: وجده. يقال: (ألْفَيْتُ الشيء، أُلْفِيهِ، إِلفاءً): إذا وجدته وصادفته ولقيته. انظر: "اللسان": 7/ 4056 (لفا).|67:الرُّغاء: صوت البعير. قال: (رَغَا البعيرُ، والضَّبُعُ، والنَّعامُ، رُغاءً): صوَّتَت فَضَجَّت. انظر: "القاموس" (1289) (رغا).|68:في مصادر الحديث التالية: أغثني.|69:في (ج): (والفَرَسَ الصامِتَ).</p><p>والصامت من المال: الذهب، والفضة، خلاف الناطق منه، وهو: الحيوان. انظر: "النهاية في غريب الحديث" 3/ 52، و"القاموس" 155 (صمت)، و"فتح الباري" 6/ 186.</p><p>والحديث من رواية أبي هريرة، أخرجه: البخاري في "الصحيح" (3073) كتاب الجهاد. باب الغلول وقول الله تعالى: <span class="qpc-hafs">﴿وَمَنْ يَغْلُلْ﴾</span>.</p><p>ومسلم في "الصحيح" رقم (1831) كتاب الإمارة. باب غلظ تحريم الغلول. وأحمد في "المسند" 2/ 426، وابن أبي شيبة في "المصنف" 6/ 529، رقم (33519). والطبري في "تفسيره" 4/ 158، والبيهقي في "السنن" 9/ 101، والثعلبي في "تفسيره" 3/ 141 ب. وأورده السيوطي في "الدر" 2/ 163 وزاد نسبة إخراجه إلى البيهقي في "الشُّعَب".|70:قول ابن عباس - رضي الله عنه - ومن بعده، هي آثار رواها المذكورون عن النبي ﷺ، بالمعنى نفسه. وقول ابن عباس رضي الله عنهما في "تفسير الطبري" 4/ 159، وأورد الأثر ابن كثير في "تفسيره" 1/ 455 ونسب أخراجه إلى ابن جرير، وقال: (لم يروه أحد من أهل الكتب الستة).|71:قوله في "تفسير الطبري" 4/ 158، 160، و"تفسير ابن أبي حاتم" 3/ 805.|72:قوله في: "صحيح مسلم" رقم (1832) كتاب الإمارة، باب تحريم هدايا العمال، والطبري في "تفسيره" 4/ 159، والبغوي في "تفسيره" 2/ 127، وابن كثير في "تفسيره" 1/ 455.</p><p>وأبو حميد الساعدي ، اختلف في اسمه كثيراً، المنذر بن سعد، وقيل: عبد الرحمن بن سعد بن المنذر، وقيل غير ذلك. أنصاري ، صحابي مشهور، شهد أحداً وما بعدها، تُوفي في آخر خلافة معاوية، وأول خلافة يزيد بن معاوية. انظر: "الاستيعاب" 4/ 199، و"الإصابة" 4/ 46.|73:قوله في: "تفسير الطبري" 4/ 160، وأورده الهيثمي في "مجمع الزوائد" 3/ 86، وقال: رواه البزار، ورجاله رجال الصحيح.|74:قوله في: "المصنف" لعبد الرزاق 5/ 242 (9493)، و"تفسير الطبري" 4/ 161.|75:لم أقف على مصدر قوله.|76:لم أقف على مصدر قوله.
  3,162,"<div class=ar lang=ar><p>قوله تعالى: <span class="qpc-hafs">﴿أَفَمَنِ اتَّبَعَ رِضْوَانَ اللَّهِ﴾</span>.</p><p>يعني: بترك الغُلُولِ -في قول: الكلبي {1}، والضحاك {2} -.</p><p><span class="qpc-hafs">﴿كَمَنْ بَاءَ بِسَخَطٍ مِنَ اللَّهِ﴾</span>، في فِعْلِ الغُلول.</p><p>وقيل: <span class="qpc-hafs">﴿أَفَمَنِ اتَّبَعَ رِضْوَانَ اللَّهِ﴾</span> بالعمل بطاعته والإيمان، <span class="qpc-hafs">﴿كَمَنْ بَاءَ بِسَخَطٍ مِنَ اللَّهِ﴾</span> في العملِ بمعصيته، والكفر به. وهذا القولُ يُحكَى عن محمد بن إسحاق {3}.</p><p>وعلى هذا المعنى دلّ كلامُ ابن عباس -في رواية عطاء-؛ لأنه قال {4}: <span class="qpc-hafs">﴿أَفَمَنِ اتَّبَعَ رِضْوَانَ اللَّهِ﴾</span>؛ يريد: المهاجرين والأنصار، {كَمَنْ بَاءَ بِسَخَطٍ مِنَ اللَّهِ}؛ يريد: المنافقين.</p><p>وقال الزجاج {5}: يروى أن النبي ﷺ، حين أمر المسلمين يوم أحد بالحرب، اتَّبَعَهُ المؤمنون، وتَخَلَّفَ عنه جماعةٌ مِنَ المنافقين {6}.</p><p>فأعلم الله عز وجل: أنّ مَنْ اتَّبَعَ نَبِيَّهُ، اتَّبَعَ رِضوانَهُ، وأنَّ مَن تَخَلّف عنه فقد باء بِسَخَطٍ مِنَ الله.</p><p>ومعنى (باءَ به)؛ أي: احتمله، ورَجَع به. وقد ذكرنا هذا في سورة البقرة {7}.</p></div>",footnotes:1:قوله في "بحر العلوم" 1/ 312.|2:قوله في: "المصنف" لعبد الرزاق 5/ 246 رقم (9507)، و"تفسير الطبري" 4/ 161، و"تفسير ابن أبي حاتم" 3/ 806. وأورده السيوطي في "الدر" 2/ 165 وزاد نسبة إخراجه إلى ابن المنذر.|3:قوله في: "سيرة ابن هشام" 3/ 70، و"تفسير الطبري" 4/ 161، و"تفسير ابن أبي حاتم" 3/ 807.|4:لم أقف على مصدر قوله.|5:في "معاني القرآن" له 1/ 486. نقله عنه بتصرف.|6:انظر: تفسير <span class="qpc-hafs">﴿إِذْ هَمَّتْ طَائِفَتَانِ مِنْكُمْ أَنْ تَفْشَلَا﴾</span> آية: 122 من سورة آل عمران.|7:انظر: "تفسير البسيط" عند تفسير قوله تعالى: <span class="qpc-hafs">﴿وَبَاءُوا بِغَضَبٍ مِنَ اللَّهِ﴾</span> البقرة: 61.
  3,163,"<div class=ar lang=ar><p>قوله تعالى: <span class="qpc-hafs">﴿هُمْ دَرَجَاتٌ عِنْدَ اللَّهِ﴾</span> أي: ذَوُو {1} درجات. فحذف المضاف. وحَسُن ذلك ههنا؛ لأن اختلاف أعمالهم، قد صيَّرَهم بمنزلة المختلفي الذوات، كاختلاف مراتب الدرجات؛ لتبعيدهم من استواء الأحوال، فجاء على هذا المَجَاز.</p><p>والمجاز في موضعه، أحسنُ مِنَ الحقيقة، لِمَا فيه [مِنَ] {2} الإيجاز مِن غيرِ إخلال، ومِنَ المُبالغة التي لا ينوبُ مَنَابها الحقيقة، إذْ {3} قولك: (هو الشمسُ ضياءً)، أبْلَغُ في النفس مِن: (هو كالشمس ضياءً). فكذلك: <span class="qpc-hafs">﴿هُمْ دَرَجَاتٌ﴾</span> {4}، أبلغ مِنْ: (هم أهلُ درجاتٍ) {5}.</p><p>وأصل الدَّرَجَةِ: الرُّتْبَةُ {6}، ومِنْهُ: (الدَّرْجُ)، لأنه يُطوَى رُتْبةً بعد رُتْبةٍ؛ قال: (أدْرَجَني إدْرَاجًا) {7} و (الدَّرَجَانُ) {8}: تَقارُبُ الخَطْوِ؛ كَمِشْيَة الشَّيْخ، والصَّبِيِّ؛ لتقارُبِ الرُّتَبِ {9}.</p><p>فأما التفسير: فالآيةُ تحتملُ ثلاثةَ أوجه:</p><p>أحدها: أن يكون المراد بقولهم: دَرَجاتُ المؤمنين والكافرين جميعًا. والمعنى: أن المؤمنين ذَوُو {10} دَرَجةٍ رفيعةٍ، والكافرين ذَوُو درجةٍ {11} خَسِيسَةٍ.</p><p>وهذا الوجه مروي عن ابن عباسٍ، قال {12}: يعني أنَّ مَن اتَّبَعَ رِضْوانَ الله، ومَنْ بَاءَ بِسَخَطٍ مِنَ الله، مختلِفُو {13} المَنَازِلِ عند الله فَلِمَن اتبع رِضْوانه الكرامةُ والثواب، ولِمَن باء بسخطٍ منه المَهَانةُ والعذاب.</p><p>وهذا قول الكلبي -أيضًا-، فإنه قال {14}: هم درجاتُ، بعضهم أشدُّ عذابًا مِنْ بعضٍ، وكلٌّ في عذابٍ وهَوَانٍ، وأهل الجَنَّةِ بعضهم أفضلَ من بعض، وكلٌّ {15} في فَضْلٍ وكَرَامَةٍ {16}.</p><p>الوجه الثاني: أن تكون الآيةُ خاصَّةً في المؤمنين؛ يريد: أنَّ بعضهم أرفع درجة عند الله مِنْ بعض.</p><p>وهذا قول ابن عباس -في رواية عطاء-، قال {17}: يريد: أصحاب النبي ﷺ، بعضهم أفضل من بعض، وهذا أيضًا اختيارُ الفرّاء، قال {18}: يقول: هم في الفضل مختلفون، بعضهم أرفع من بعض.</p><p>الوجه الثالث: أن تكون الآية خاصة في الكافرين {19}. وهذا قول الحسن، يقول {20}: بعض أهل النار أشدُّ عذابًا مِنْ بعضٍ؛ ألا تَرَاهُ {21} يقول: <span class="qpc-hafs">﴿وَلِكُلٍّ دَرَجَاتٌ مِمَّا عَمِلُوا﴾</span> [الأنعام: 132].</p><p>قال: وبلغني أن النبي ﷺ قال: (إنَّ منها {22} ضحْضاحًا {23}، وإنَّ منها غَمْرًا {24}، وإني لأرجو أنْ يكون أبو طالب في ضحْضَاحِها) {25}.</p><p>وقوله تعالى: <span class="qpc-hafs">﴿وَاللَّهُ بَصِيرٌ بِمَا يَعْمَلُونَ﴾</span> {26}.</p><p>فيه تحريضٌ على العمل بطاعته؛ لأن ثوابه لا يضيع؛ إذا عَمِلَه {27} مَنْ يعمل له، وتحذيرٌ مِنَ العملِ بمعصيته؛ لأن جزاءه لا يفوتُ إذا كان عالِمًا به. فهو تهديد ووعيدٌ للكافرين، وتبشيرٌ ووَعْدٌ للمؤمنين.</p></div>",footnotes:1:في (ب): (ذو).|2:ما بين المعقوفين: زيادة من (ج).|3:في (أ)، (ب): إذا. والمثبت من (ج).|4:في (أ): (بدرجات درجات).|5:انظر: "معاني القرآن" للزجاج 1/ 486، و"معاني القرآن" للنحاس 1/ 506. == قيل في تأويل الآية: إنهم جعلوا نفس الدرجات؛ للمبالغة؛ أي: إنهم متفاوتون في الجزاء على كسبهم، كما أن الدرجات تتفاوت. والأصل فيه: هم مثل الدرجات في التفاوت. انظر: "الدر المصون" 3/ 469 - 470.|6:انظر (درج) في: "جمهرة اللغة" 1/ 446، و"التهذيب" 2/ 1167، و"اللسان" 3/ 1351، وانظر: "تفسير الطبري" 4/ 162.</p><p>قال الراغب: (الدرجة، نحو المنزلة، لكن يقال للمنزلة: (درجة)، إذا اعتُبِرت بالصعود، دون الامتداد على البسيط؛ كدرجة السطع والسلَّم، ويعبر بها عن المنزلة الرفيعة ..). "مفردات ألفاظ القرآن": 310 (درج).|7:قال ابن دريد: (والدَّرْج: مصدر (دَرَجْتُ الشيء دَرْجًا)، و (أدرجته إدراجًا): إذا طويته). "جمهرة اللغة" 1/ 446.</p><p>وأراد المؤلف، هنا والله أعلم: الدَّرْج -أو الدَّرَج-: الذي يُكتَبُ فيه. يقال: (أنفذته في دَرْج الكتاب)؛ أي: في طَيِّه. انظر: "الصحاح" 314 (درج).</p><p>وفي "مفردات ألفاظ القرآن": 311 (درج): (والدرْج: طيُّ الكتاب والثوب. ويقال للمطوي: دَرْج).|8:في (أ)، (ب): (والدرجات). والمثبت من: (ج)، ومصادر اللغةُ.|9:انظر: (درج) في: "التهذيب" 2/ 1167، و"مفردات ألفاظ القرآن" 311، و"اللسان" 3/ 1351.|10:في (ب): (ذو). وكذا في الموضع التالي.|11:(ذوو درجة): بياض في (ج).|12:قوله في: "تفسير الثعلبي" 3/ 143 ب، و"تفسير البغوي" 2/ 129، و"زاد المسير" 1/ 493.|13:في (ب): (يختلفوا).|14:لم أقف على مصدر قوله.|15:من قوله: (وكل ..) إلى (.. بعضهم أفضل من بعض): ساقط من (ج).|16:وهو قول ابن إسحاق، واختيار الطبري. انظر: "تفسيره" 4/ 162.|17:لم أقف على مصدر هذه الرواية عنه.|18:في "معاني القرآن" له 1/ 246. نقله عنه بتصرف.|19:في (ج): (المنافقين).|20:لم أقف على مصدر قوله. والذي وقفت عليه من قوله، الآتي:</p><p>أ- يعني أهل الخير وأهل الشر درجات.</p><p>ب- إنها درجات الجنة.</p><p>ج- للناس درجات بأعمالهم، في الخير والشر. انظر: "تفسير الحسن البصري" 246، 247.|21:في (ج): (تسمعه) بدلًا من: (تراه).|22:الضمير يعود على النار.|23:أصل الضحْضَاح: الماء القليل، الرقيق، أو الذي يصل إلى الكعبين. فشَبَّه قِلَّةَ النار به. انظر: "غريب الحديث" لأبي عبيد 2/ 400، و"الفائق" 2/ 332.|24:الغَمْر: الماء الكثير. وجمعه: غِمَار، وغُمُور. انظر: "القاموس" 452 (غمر).|25:هذا الجزء من قول الحسن (والمتضمن حديث النبي ﷺ، المرسل عن الحسن (إن منها ضحضاحا ..)، قد ورد بألفاظ مختلفة من طريق أخرى صحيحة، في بيان حال أبي طالب عم النبي ﷺ، يوم القيامة.</p><p>فقد أخرج البخاريُّ عن عبد الله بن الحارث بن نوفل، أن العباس بن عبد المطلب، قال للنبي ﷺ: ما أغنيت عن عمك؟ فوالله كان يحيطك ويغضب لك. قال: "هو في ضحضاح من نار، ولولا أنا، لكان في الدرك الأسفل من النار". "الصحيح" (3883). كتاب مناقب الأنصار. باب قصة أبى طالب، (6208) كتاب الأدب. باب كنية المشرك.</p><p>وأخرجه مسلم في "الصحيح" رقم (209) كتاب الإيمان رقم (357) باب شفاعة النبي ﷺ لأبي طالب، وورد في لفظٍ لمسلم: "نعم وجدته في غمرات من النار، فأخرجته إلى ضحضاح".</p><p>وعن أبي سعيد الخدري رضي الله عنه: أنه سمع رسول الله ﷺ وذُكِرَ عنده عَمُّهُ أبو طالب، فقال -واللفظ للبخاري-: "لعله تنفعه شفاعتي يوم القيامة، فيجعل في ضحضاح من النار، يبلغ كعبيه، يغلي منه أم دماغه". == "صحيح البخاري": (6564) كتاب الرقاق. باب صفة الجنة والنار. و"صحيح مسلم" رقم (120) كتاب الإيمان، رقم (360) باب شفاعة النبي ﷺ لأبي طالب.</p><p>وانظر روايات أخرى بألفاظ أخرى في: "فتح الباري" 7/ 193 - 194، و"الفائق" للزمخشري 2/ 332.|26:في (أ)، (ب)، (ج): تعملون. والمثبت من رسم المصحف.|27:في (ج): (علمه).
  3,164,"<div class=ar lang=ar><p>قوله تعالى: <span class="qpc-hafs">﴿لَقَدْ مَنَّ اللَّهُ عَلَى الْمُؤْمِنِينَ إِذْ بَعَثَ فِيهِمْ رَسُولًا مِنْ أَنْفُسِهِمْ﴾</span> الآية.</p><p>لـ (المَنِّ) {1} -في كلام العرب- مَعَانٍ:</p><p>أحدها: الذي يسقط من السماء، وقد مرّ ذكره في قوله: <span class="qpc-hafs">﴿وَأَنْزَلْنَا عَلَيْكُمُ الْمَنَّ وَالسَّلْوَى﴾</span> [البقرة: 57]. والمَنُّ: الاعتداد بالصنَّيعَةِ {2}، وهو: أنْ تَمُنَّ بما أعطيت، وذلك في قوله: <span class="qpc-hafs">﴿لَا تُبْطِلُوا صَدَقَاتِكُمْ بِالْمَنِّ﴾</span> [البقرة: 264].</p><p>والمَنُّ: القَطْعُ. ومنه قوله: <span class="qpc-hafs">﴿أَجْرٌ غَيْرُ مَمْنُونٍ﴾</span> [فصلت: 8]؛ أي: غيرُ مَقْطُوع {3}.</p><p>والمَنُّ: الإعطاء والإنعام، والإحسان إلى مَنْ لا تَسْتَثِيبه. منه قوله تعالى: <span class="qpc-hafs">﴿هَذَا عَطَاؤُنَا فَامْنُنْ أَوْ أَمْسِكْ﴾</span> [ص: 39]، وقوله: <span class="qpc-hafs">﴿وَلَا تَمْنُنْ تَسْتَكْثِرُ﴾</span> [المدثر: 6] {4}. و (المَنَّانُ) -في صفة الله- تعالى-؛ معناه: المُعْطِي ابتداءً {5}.</p><p>فمعنى قوله: <span class="qpc-hafs">﴿لَقَدْ مَنَّ اللَّهُ عَلَى الْمُؤْمِنِينَ﴾</span>؛ أي: أنعَمَ عليهم، وأحسَنَ إليهم، إذ بَعَثَ فيهم رَسُولًا.</p><p>واختلفوا في المراد بـ (المؤمنين) في قوله: <span class="qpc-hafs">﴿عَلَى الْمُؤْمِنِينَ﴾</span>.</p><p>فقال بعضهم {6}: هذا خاصٌّ في العرب، لأن النبي ﷺ، كانَ مِنَ العَرَبِ، ولم يكُنْ حَيٌّ مِن أحياء العرب، إلّا [و] {7} قد وَلَدَهُ، وله فيهم نَسَبٌ، غير بني تَغْلِب؛ لأنهم كانوا نَصَارَى {8}، فطَهَّرَهُ {9} اللهُ منهم؛ لأنهم ثَبَتوا على النصرانية {10}. وعلى هذا دلّ كلام ابن عباس -في رواية عطاء- {11}، فإنه قال: يعنى المهاجرين والأنصار.</p><p>وعلى هذا التفسير، معنى قوله: <span class="qpc-hafs">﴿مِنْ أَنْفُسِهِمْ﴾</span>؛ أي: مِنْ نَسَبِهم. قال ابن عباس {12}: يريد: نَسَبه نَسَبهم، هو مِن وَلَدِ إسماعيل. وبه قال الكلبيُّ {13}.</p><p>ومعنى (المِنَّة) -على هذا التفسير-: أنه بُعِثَ واحدًا منهم؛ ليكونَ ذلك شَرَفًا لهم {14}. ففيه إنعامٌ مِنْ وجهين:</p><p>أحدهما: أنه أنقذهم به من النار، وهداهم. والثاني: أنْ جعله منهم. ودليل هذا التأويل، قولُه: <span class="qpc-hafs">﴿هُوَ الَّذِي بَعَثَ فِي الْأُمِّيِّينَ رَسُولًا مِنْهُمْ﴾</span> [الجمعة: 2].</p><p>وقال آخرون {15}: أراد المؤمنين كلَّهم، وعلى هذا معنى قوله: <span class="qpc-hafs">﴿مِنْ أَنْفُسِهِمْ﴾</span>؛ أي: إنه واحدٌ منهم، يعرفونه، ويعرفون نَسَبَهُ، ليس بِمَلَكٍ، ولا أحد مِن غيرِ بني آدم.</p><p>ومعنى (المِنّة) -على هذا القول-: أنّه {16} مَنَّ على المؤمنين، بإرساله واحدًا منهم، عُرِفَ أمرُهُ، وخُبِرَ صِدْقُهُ وأمانَتُهُ، فكانَ تَنَاوُلُ {17} الحُجّةِ والبرهانِ {18} سَهْلًا مِنْ قِبَلِهِ {19}.</p><p>وهذا القول اختيار الزجّاج؛ لأنه قال {20}: لو كانت المنّةُ فيه [أنه] {21} مِنَ العرب، لكانَ {22} العَجَمُ لا مِنَّة عليهم فيهِ، ولكن المِنَّة {23} فيه: أنَّهُ قد خُبِرَ أمْرُه، وشأنُه، وعُلِمَ صدقُهُ، بعد أنْ عَلِمُوا أنه كان واحدًا منهم، وإذا كان واحدًا منهم، كانَ أيْسَرَ عليهم معرِفةُ أحوالِهِ مِنَ الصِّدقِ والأمانة.</p><p>وعلى هذا التفسير: خُصّ المؤمنون بالذكر، وإنْ كانَ جميعُ المُكَلَّفِينَ في هذا سواء؛ لأن المِنّة على المُؤْمِنِ في هذا أعظمُ منها على الكافر؛ لانتفاع المؤمن ببعثته، فصار كقوله: <span class="qpc-hafs">﴿إِنَّمَا أَنْتَ مُنْذِرُ مَنْ يَخْشَاهَا﴾</span> [النازعات: 45]، وهو كان منذرًا لجميع البَشَرِ، ولكنْ لَمَّا كان المؤمنُ يخشَى الساعةَ دون الكافرين، وكان للمؤمن الانتفاعُ بإنذاره، أُضِيفَ إليه.</p><p>وباقي الآية مفسَّرَةٌ في سورة البقرة {24}.</p><p>وقوله تعالى: <span class="qpc-hafs">﴿وَإِنْ كَانُوا مِنْ قَبْلُ لَفِي ضَلَالٍ مُبِينٍ﴾</span> قيل: معناه: وقد كانوا {25}.</p><p>وقيل: معناه: وما كانوا مِنْ قَبْلِهِ؛ أي {26}: مِنْ قبل محمد، إلَّا في ضلال مبين. ومثله قوله: <span class="qpc-hafs">﴿وَإِنْ كُنْتُمْ مِنْ قَبْلِهِ لَمِنَ الضَّالِّينَ﴾</span> {27} [البقرة: 198].</p></div>",footnotes:1:في (ج): (المن) بدلا من: (للمن).|2:الصَّنِيعة: العَطِيَّة، والكرامة، والإحسان. والجمع: صَنائِع. انظر: (صنع) في: "اللسان" 4/ 2510، و"القاموس" 739.|3:وهذا قول ابن عباس، ومجاهد، والضحاك، وغيرهم. وحكى السُدِّي عن بعضهم، == أن معناه: غيرُ ممنونٍ عليهم. ورُدَّ عليه؛ لأن المِنَّة لله تعالى على أهل الجنة؛ لأنهم دخلوها برحمته تعالى وفضله، لا بأعمالهم. انظر: "تفسير ابن كثير" 4/ 519.|4:معنى الآية -على هذا الوجه-: لا تُعْطِ العطيَّةَ تلتمس أكثر منها. وهذا قول ابن عباس، وعكرمة، ومجاهد، وعطاء، وطاوس، وأبي الأحوص، وإبراهيم النخعي، والضحاك، وقتادة، والسدي، وغيرهم، واستظهره ابن كثير. ويرى الضحاك أن هذا خاص بالنبي ﷺ، مباح للناس عامة.</p><p>وقيل: لا تعط عطاءً وتستكثره؛ لأن الكريم يستقل ما يعطي، وإن كان كثيرًا. ذكره ابن جُزي.</p><p>وهناك أقوال أخرى في الآية، هي:</p><p>- لا تمنن بعملك على ربك تستكثره وهو قول الحسن، والربيع، واختيار الطبري.</p><p>- وقيل: لا تضعف أن تستكثر من الخير؛ على أنَّ (تَمْنُنْ) -في كلام العرب-: تضعف. وهي رواية خصيف عن مجاهد. أو لا تضعف عن تبليغ الرسالة، وتستكثر ما حملناك من ذلك. ذكره ابن جُزَي.</p><p>- وقيل: لا تمنن بالنبوة والقرآن على الناس، تستكثرهم به، تأخذ عليه عوضًا من الدنيا. وهو قول ابن زيد.</p><p>انظر: "تفسير الطبري" 29/ 148 - 150، "وتفسير ابن جزي" 806، و"تفسير ابن كثير" 4/ 466.|5:انظر هذه المعاني لـ (المن) في: "الزاهر" 2/ 355 - 357، و"تهذيب اللغة" 4/ 3459 - 3460، و"مفردات ألفاظ القرآن" 777، و"قاموس القرآن" للدامغاني 444، و"بصائر ذوي التمييز" 4/ 527 - 528.|6:من قوله: (قال بعضهم ..) إلى (.. على النصرانية): نقله -بتصرف- عن "تفسير الثعلبي" 3/ 143 - ب.|7:ما بين المعقوفين زيادة من (ج)، و"تفسير الثعلبي".|8:هم بنو تَغْلب بن وائل بن قاسط. ينتهي نسبهم إلى مَعَدّ بن عدنان. ومساكنهم بالجزيرة الفُرَاتية، وتعرف بديار بكر. وبينهم وبين بني بكر بن وائل دارت حرب (البَسُوس) المشهورة التي استمرت (40) سنة.</p><p>انظر: "جمهرة أنساب العرب" 303، 469، و"صبح الأعشى" 1/ 338، و"معجم القبائل العربية" 1/ 120.|9:في (أ)، (ب): (فظهره). والمثبت من (ج)، و"تفسير الثعلبي"، وكذا جاءت في "تفسير القرطبي" 4/ 264، 18/ 92. وهي الصواب.|10:أورد هذا القول القرطبيُّ في "تفسيره" 18/ 92 ونسبه لابن إسحاق، وكذا أورده أبنُ عطية في "المحرر" 3/ 409 ونسبه للنقاش.|11:لم أقف على مصدر هذه الرواية عنه.|12:لم أقف على مصدر قوله؛ وقد ذكره ابن الجوزي في "الزاد" 1/ 494.|13:لم أقف على مصدر قوله.= وممن ورد عنه أن هذا خاصٌّ في العرب: عائشةُ -رضي الله عنها-. فقد أخرج عنها ابن أبي حاتم في "تفسيره" 3/ 808 أنها قالت -بعد أن قرأت هذه الآية-: (هذه للعرب خاصة). وأورده القرطبي في: "تفسيره" 4/ 264، ونسب إخراجه لأبي محمد عبد الغني، بسنده عنها.</p><p>وأورده السيوطي في "الدر" 2/ 165 وزاد نسبة إخراجه إلى ابن المنذر، والبيهقي في "الشعب".</p><p>وهو اختيار الطبري في "تفسيره" 4/ 163حيث قال: (<span class="qpc-hafs">﴿مِنْ أَنْفُسِهِمْ﴾</span> نبيًا من أهل لسانهم، ولم يجعله من غير أهل لسانهم، فلا يفقهوا عنه ما يقول).|14:انظر: "بحر العلوم" لأبي الليث 1/ 313، و"النكت والعيون" 1/ 434.|15:ممن قال هذا: الزجاج -كما سيأتي-، وذكره الثعلبي في "تفسيره" 3/ 143 ب، ولم يعزه لقائل.|16:من قوله: (أنه) إلى (من قبله) نقله -بتصرف- عن "معاني القرآن" للزجاج 1/ 487.|17:في (أ)، (ب): (يتأول). والمثبت من (ج)، و"معاني القرآن".|18:في (أ): (البرهانُ) بضم النون. وفي (ب)، (ج): مهملة، وما أثبته هو الصواب.|19:في (ب): (قبل).|20:في "معاني القرآن" له 1/ 487. نقله عنه بتصرف يسير.|21:ما بين المعقوفين زيادة ليستقيم بها السياق.|22:في (ب): (لكانت).|23:في (ب): (أمانته).|24:انظر: تفسير الآية 129، والآية 151 من سورة البقرة.|25:لم أقف على من قال بهذا القول، إلا أنه يُخَرَّج على قول الكسائي -من الكوفيين- أنَّ (إنْ) إنْ دخلت على جملة فعلية، تكون بمعنى (قد)، واللام زائدة للتوكيد، وإن دخلت على جملة اسمية، فتكون (إنْ) هي النافية، واللام بمعنى (إلَّا).</p><p>انظر: "تفسير الطبري" 4/ 163، و"اللامات" للزجاجي 115، و"الجنى الداني" 214، و"الدر المصون" 2/ 334.|26:(من قبله أي): ساقط من (ج).|27:هذا رأي الكوفيين، ومنهم: الفراء، أنَّ (إنْ) -هنا- نافية، بمعنى (ما)، واللام بمعنى: (إلا)، بينما مذهب أهل البصرة أنَّ (إنْ) هي المخففة من الثقيلة، واللام هي الفارقة بينها وبين (إنْ) النافية.</p><p>انظر: المصادر السابقة، و"الفريد في إعراب القرآن المجيد" 1/ 656، و"الجنى الداني" 209، و"المغني" لابن هشام 306.
  3,165,"<div class=ar lang=ar><p>قوله تعالى: <span class="qpc-hafs">﴿أَوَلَمَّا أَصَابَتْكُمْ مُصِيبَةٌ﴾</span> الآية.</p><p>الواوُ في <span class="qpc-hafs">﴿أَوَلَمَّا﴾</span>، لِعَطْفِ جملةٍ على جملة. ودخل أَلِفُ الاستفهام على واو النَّسَقِ {1}؛ لأنَّ له صدر الكلام.</p><p>قال الزجّاج {2}: ومثله من الكلام قولُ القائل: (تكَلّمَ فلانٌ بكذا وكذا) فيقول مجيبًا له: (أوَ هُوَ مِمَّن يقول ذلك؟).</p><p>والمعنى: أَوَ حين أصابتكم مُصيبةٌ. ويعنى بالمصيبة: ما أصابتهم يوم أحد.</p><p>وقوله تعالى: <span class="qpc-hafs">﴿قَدْ أَصَبْتُمْ مِثْلَيْهَا﴾</span>.</p><p>هو مِنْ صفة النَّكِرَةِ {3}. ومعناه: قد أصبتم مثليها يوم بدر؛ وذلك [أنَّ] {4} المشركين قتلوا من المسلمين يوم أُحُد سبعين، [وقَتَلَ المسلمونَ منهم يوم بدر، سبعين] {4} وأسروا سبعين. هذا قول أكثرِ المفسرين: ابن عباس {6}، وقتادة {7}، وعكرمة {7}، والربيع {7}، والسُدِّي {10}.</p><p>وقال بعضهم {11}: أي: أَصبتم في يوم أحد مثلها {12}، وفي يوم بدر مثلها {13}. فقد أصَبتم مِثْلَيْ ما أصابكم، وقتلوا منكم في يوم أُحُد، وقتلتم منهم في يومين. وهذا اختيار الزجّاج {14}.</p><p>والأول أصح؛ لأن الكفار يوم بدر، نالوا مِنَ المسلمين -أيضًا- {15}؛ بقتل بعضهم {16}.</p><p>وقوله تعالى: <span class="qpc-hafs">﴿قُلْتُمْ أَنَّى هَذَا﴾</span>.</p><p>جواب الاستفهام. ومعناه: قلتم: مِنْ أينَ أصابَنَا هذا القتلُ والهزيمة، وقد تقدم الوَعْدُ بالنُّصْرَةِ، ونحن مسلمون، ورسول الله فينا، والوحي ينزل عليه [فينا] {17}؟.</p><p>وقوله تعالى: <span class="qpc-hafs">﴿قُلْ هُوَ مِنْ عِنْدِ أَنْفُسِكُمْ﴾</span>.</p><p>فيه ثلاثة أوْجُه:</p><p>أحدهما -وهو قول أكثر أهل التأويل-: أن {18} معناه: أنّكم تركتم ما أمِرْتُم به، وطلبتم الغنيمةَ وتركتم مراكزكم، فَمِنْ قِبَلِكُمْ جاء الشَّرُّ. وهذا قول: الكلبي {19}، وعطاء {20}، واختيار: الفرّاء {21}، والزجّاج {22}.</p><p>وعلى هذا القول: أضاف إليهم المعصيةَ والهزيمةَ، وإنْ كانت مخلوقة لله -تعالى- مُرَادةً، لأن المعصيةَ تضاف إلى العاصي من حيث المباشرة والكَسْب {23}.</p><p>والثاني: أن معنى قوله: <span class="qpc-hafs">﴿مِنْ عِنْدِ أَنْفُسِكُمْ﴾</span>؛ أي: بخرُوجِكُم مِنَ المدينة، وخلافكم على رسولكم؛ وذلك أنه دعاهم إلى التَحَصُّنِ بالمدينة، وكان {24} قد رأى في المنام أنَّ عليه درْعًا حَصِينَةً، فأوَّلَها: المدينة. فقالوا: كنا نَمْتَنِع في الجاهلية، ونحن اليوم أحقُّ بالامتناع، فأكرهوا رسولَ الله على الخروج. وهذا قول: قتادة {25}، والربيع {26}، وابن عباس -في رواية عطاء- {19}؛ لأنه قال: يريد: حيث اختلفوا على النبي ﷺ {28}.</p><p>الوجه الثالث {29}: ما روي عن علي - رضي الله عنه -، أنه قال: جاء جبريلُ إلى النبي ﷺ، يوم بَدْر، فقال {30}: يا محمدُ: إنَّ الله -تعالى- قد كَرِهَ ما صَنَعَ قومُكَ في أخذهم الفداءَ من الأُسارى، وقد أمرك أن تُخَيِّرَهم بين أن يُقَدِّمُوا الأُسارى فَيَضْرِبُوا أعناقَهم، وبين أن يأخذوا الفداء، على أن يُقْتَلَ منهم عِدَّتُهُم. فَذَكَرَ ذلك رسولُ الله ﷺ لقَومِهِ، فقالوا: يا رسول الله: عشائرُنا وإخواننا، لا؛ بل نأخذ فِدَاهم {31}، فنقوى {32} به على قتال العدوِّ، ويُستشهد منّا بعددهم {33}.</p><p>فقُتِلَ منهم يوم أحد سبعون رجلًا، عدد {34} أُسارى أهلِ بَدْر. فهو معنى قوله: <span class="qpc-hafs">﴿قُلْ هُوَ مِنْ عِنْدِ أَنْفُسِكُمْ﴾</span>؛ أي: بأخْذِكُم الفداء، واختياركم القَتْلَ {35}.</p><p>وقوله تعالى: <span class="qpc-hafs">﴿إِنَّ اللَّهَ عَلَى كُلِّ شَيْءٍ قَدِيرٌ﴾</span> يعنى: مِنَ النَّصْرِ؛ مع طاعتكم النبي ﷺ، وترك النصر؛ مع مخالفتكم ما أُمرتم به. وقال ابن عباس {19}: يريد: على نَصرِكُم، وعلى اتِّخاذِ الشهداءِ منكم، وتعجيلِ أوليائهِ إلى الجَنَّةِ، قديرٌ.</p></div>",footnotes:1:النَّسَق، هو: العطف.|2:في "معاني القرآن" له 1/ 487. نقله عنه بتصرف يسير.|3:أي: في موضع رفع؛ صفة لـ (مصيبة).|4:ما بين المعقوفين زيادة من (ج).|5:ما بين المعقوفين زيادة من (ج).|6:قوله في "تفسير الطبري" 4/ 165، و"تفسير ابن أبي حاتم" 3/ 810.|7:قوله في المصدرين السابقين.|8:قوله في المصدرين السابقين.|9:قوله في المصدرين السابقين.|10:قوله في المصدرين السابقين.</p><p>وانظر: "سيرة ابن هشام" 3/ 71، و"عيون الأثر" 1/ 432، 2/ 47 - 48، و"فتح الباري" 7/ 307، كتاب المغازي. باب 10 رقم الحديث: (3986).</p><p>قال ابن حجر: (واتفق أهل العلم بالتفسير على أن المخاطبين بذلك أهل أحُد، وأنَّ المراد بـ <span class="qpc-hafs">﴿أَصَبْتُمْ مِثْلَيْهَا﴾</span> يوم بدر، وعلى أن عدة من استشهد من المسلمين بأحد سبعون نفسًا). "الفتح" 7/ 307 وقد عدَّه الطبري إجماعًا. انظر "تفسيره" 4/ 164.|11:لم أقف على من قال بهذا القول. إلا ما ورد عن الزجاج كما سيأتي.|12:حيث قتل من الكفار يوم أحد ثلاثة وعشرون رجلًا. انظر: "عيون الأثر" 2/ 48.|13:(وفي يوم بدر مثلها): ساقط من (ج).</p><p>حيث قَتَلَ المسلمون من الكفار سبعينَ -كما سبق-، ولا مَدْخَلَ للأسرى -هنا- على هذا القول؛ لأنهم قد تم فداؤهم، فلا تتم المماثلة بهم.|14:في "معاني القرآن" له 1/ 488.|15:في (ب): (تعبا).|16:في (أ): (بعضُهم) برفع الضاد. وفي (ب)، (ج): مهملة. والصواب ما أثبت. واستشهد من المسلمين في بدر: أربعة عشر رجلًا؛ ستة من المهاجرين، وثمانية من الأنصار. انظر: "عيون الآثر" 1/ 432.|17:ما بين المعقوفين مطموس في (أ)، والمثبت من (ب)، (ج).|18:(أن): ساقطة من (ج).|19:لم أقف على مصدر قوله.|20:لم أقف على مصدر قوله. وقد يكون قوله هو قول ابن عباس الذي أورده ابن الجوزي في: "الزاد" 1/ 496؛ حيث إن أغلب أقوال عطاء التي يوردها المؤلف هي روايته عن ابن عباس.|21:في "معاني القرآن" له 1/ 246، وقد نقل المؤلف هذا القول عنه بنصه، وهو من قوله (تركتم ما أمرتم) إلى (.. جاء الشر).|22:في "معاني القرآن" له 1/ 488. وهو قول مقاتل في "تفسيره" 1/ 311، وأبي الليث في "بحر العلوم" 1/ 313.|23:(الكسب هو الفعل الذي يعود على فاعله بنفع، أو خير، كما قال تعالى: <span class="qpc-hafs">﴿لَهَا مَا كَسَبَتْ وَعَلَيْهَا مَا اكْتَسَبَتْ﴾</span> [البقرة: 286]. "مجموع فتاوى ابن تيمية" 8/ 387 == وانظر:"شرح العقيدة الطحاوية" ص 448.</p><p>وقد نقل السفاريني بعض اصطلاحات المتكلمين حول الكسب، فقال: (الكسب في اصطلاح المتكلمين: ما وقع من الفاعل مقارنًا لقدرة محدثة واختيار، وقيل: هو ما وجد بقدرة محدثة في المكتسب.</p><p>وقال العلَّامَةُ ابنُ حمدان -من علمائنا-: الكسب هو ما خلقه الله في محل قدرة المكتسب على وفق إرادته في كسبه ..). "لوامع الأنوار" 1/ 291. وانظر ما بعدها. وانظر للتوسع في موضوع الكسب: "شفاء العليل" 121 وما بعدها، و"شرح العقيدة الطحاوية" ص 438 وما بعدها، و"المعتزلة وأصولهم الخمسة" 169 - 184، و"أفعال العباد في القرآن الكريم" لعبد العزيز المجذوب 325 وما بعدها، و"الكليات"، لأبي البقاء 161.|24:(وكان): ساقطة من (ج).|25:قوله في: "تفسير الطبري" 4/ 164، و"زاد المسير" 1/ 496، و"الدر المنثور" 2/ 166، وزاد السيوطي نسبته إلى عبد بن حميد.|26:قوله في: "تفسير الطبري" 4/ 165، و"زاد المسير" 1/ 496.|27:لم أقف على مصدر قوله.|28:انظر ما سبق عند تفسير الآية: 152 <span class="qpc-hafs">﴿وَلَقَدْ صَدَقَكُمُ اللَّهُ وَعْدَهُ﴾</span>.|29:في (ج): (الثاني).|30:في (ج): (وقال).|31:هكذا جاءت في: (أ)، (ب)، (ج). على التخفيف. والأصل فيها أن تكون: (فداءهم). كما هي في "تفسير الطبري". وقد وردت في بعض ألفاظ الحديث: (.. بل نفاديهم)، ووردت: (قالوا الفداء).|32:هكذا في: (أ)، (ب)، (ج). وجاءت في المصادر التالية: (فنتقوّى).|33:الحديث أخرجه: الترمذي في "السنن" رقم (1567. كتاب السير. باب 18 (ما جاء في قتل الأسارى والفداء) وقال الترمذي: (حديث حسن غريب)، وأخرجه الطبري في "تفسيره" 1/ 166، وذكره الثعلبي في "تفسيره" 3/ 144 أ، والبغوي في "تفسيره" 2/ 129، وابن كثير في "تفسيره" 1/ 459 وزاد نسبة إخراجه للنسائي، ولم أهتد إليه في (سننه) المطبوعة.</p><p>وأورده السيوطي في "الدر" 2/ 368 وزاد نسبة إخراجه لابن أبي شيبة، وابن مردوية.|34:في (ج): (بعدد).|35:قال الشوكاني -بعد إيراده لهذا الأثر عن علي - رضي الله عنه -: (ولكنه يشكل على حديث التخيير السابق؛ ما نزل من المعاتبة منه سبحانه وتعالى لمن أخذ الفداء، بقوله: <span class="qpc-hafs">﴿مَا كَانَ لِنَبِيٍّ أَنْ يَكُونَ لَهُ أَسْرَى حَتَّى يُثْخِنَ فِي الْأَرْضِ﴾</span> [الأنفال: 67]، وما رُوي من بكائه ﷺ، هو وأبو بكر؛ ندمًا على أخذ الفداء. ولو كان أخذ ذلك بعد التخيير لهم من الله -سبحانه-، لم يعاتبهم عليه، ولا حصل ما حصل من النبي ﷺ، ومن معه من الندم والحزن، ولا صوَّب النبي ﷺ رأي عمر - رضي الله عنه -، حيث أشار بقتل الأسرى، وقال ما معناه: لو نزلت عقوبة لم ينج منها إلا عمر). "فتح القدير" 1/ 598 - 599.|36:لم أقف على مصدر قوله.