quran[6]{c,v,t}:
  7,52,"<div class=ar lang=ar></div>"
  7,53,"<div class=ar lang=ar><p>قوله تعالى: <span class="qpc-hafs">﴿هَلْ يَنْظُرُونَ إِلَّا تَأْوِيلَهُ﴾</span>، النظر هاهنا بمعنى: الانتظار {1}، وقد مر في سورة البقرة {2}، وإنما قيل لهم <span class="qpc-hafs">﴿هَلْ يَنْظُرُونَ﴾</span>، وإن كانوا جاحدين؛ لأنهم في منزلة المنتظر كأنهم ينتظرون ذلك لأنهم يأتيهم لا محالة، وفيه وجه آخر ذكرناه في قوله: <span class="qpc-hafs">﴿هَلْ يَنْظُرُونَ إِلَّا أَنْ تَأْتِيَهُمُ الْمَلَائِكَةُ﴾</span> [الأنعام: 158] في آخر سورة الأنعام.</p><p>وقوله تعالى: <span class="qpc-hafs">﴿إِلَّا تَأْوِيلَهُ﴾</span>. قال الفراء: (الهاء في <span class="qpc-hafs">﴿تَأْوِيلَهُ﴾</span> للكتاب يريد: عاقبته وما وعد الله فيه) {3} [يعني: من البعث والنشور والعقاب والحساب.</p><p>وقال مقاتل {4}: <span class="qpc-hafs">﴿إِلَّا تَأْوِيلَهُ﴾</span> عاقبة ما وعدوا] {5} على ألسنة الرسل. ومضى {6} الكلام في التأويل في سورة آل عمران {7} أولاً، ثم في النساء {8} ثانيًا.</p><p>وقوله تعالى: <span class="qpc-hafs">﴿يَوْمَ يَأْتِي تَأْوِيلُهُ﴾</span>. قال ابن عباس: (يريد: يوم القيامة) {9}.</p><p>قال الزجاج: (<span class="qpc-hafs">﴿يَوْمَ﴾</span> نصب بقوله <span class="qpc-hafs">﴿يَقُولُ﴾</span> {10}. قال: [و] {11} <span class="qpc-hafs">﴿الَّذِينَ نَسُوهُ﴾</span> معناه {12} أنهم صاروا في الإعراض عنه بمنزلة من نسى، وجائز أن يكون <span class="qpc-hafs">﴿نَسُوهُ﴾</span> تركوا {13} العمل له والإيمان له) {14}، وهذا كما ذكرنا في قوله: <span class="qpc-hafs">﴿كَمَا نَسُوا لِقَاءَ يَوْمِهِمْ هَذَا﴾</span> [الأعراف:51].</p><p>وقوله تعالى: <span class="qpc-hafs">﴿أَوْ نُرَدُّ﴾</span> نسق على قوله: <span class="qpc-hafs">﴿فَهَلْ لَنَا مِنْ شُفَعَاءَ﴾</span>، كأنه قيل: هل يشفع لنا شافع، أو هل نرد <span class="qpc-hafs">﴿فَنَعْمَلَ﴾</span>، منصوب على جواب الاستفهام [بالفاء {15}] {16}، ومعنى: <span class="qpc-hafs">﴿فَنَعْمَلَ غَيْرَ الَّذِي كُنَّا نَعْمَلُ﴾</span> نوحد الله قاله ابن عباس {17}.</p><p>قال الله تعالى {18}: <span class="qpc-hafs">﴿قَدْ خَسِرُوا أَنْفُسَهُمْ﴾</span>، قال ابن عباس: (يريد: قد خسروا النعيم {19} وصاروا إلى الخزي والعذاب) {20} ومضى الكلام {21} في: <span class="qpc-hafs">﴿خَسِرُوا أَنْفُسَهُمْ﴾</span>.</p><p>وقوله تعالى: <span class="qpc-hafs">﴿وَضَلَّ عَنْهُمْ مَا كَانُوا يَفْتَرُونَ﴾</span>، يريد: سقط عنهم ما كانوا {22} يقولون من أن مع الله إلهًا آخر {23}.</p></div>",footnotes:1:النَّظَر: تقليب البَصَرِ والبَصيرة لإدراك الشيء وتأمله ورؤيته، والنَّظَر: الانتظار يقال: نَظَرْتُه أي انتظَرْتْه، وأَنْظَرْتُه - أخَّرْتُه. انظر: "الجمهرة" 2/ 763، و"تهذيب اللغة" 4/ 3604، و"الصحاح" 5/ 380، و"المجمل" 3/ 873، و"مقاييس اللغة" 5/ 444، و"المفردات" ص 813، و"اللسان" 7/ 4466 (نظر).|2:انظر: "البسيط" النسخة الأزهرية 1/ 126ب.|3:"معاني الفراء" 1/ 380، وانظر: "مجاز القرآن" 1/ 216، و"تفسير غريب القرآن" ص 178.|4:"تفسير مقاتل" 2/ 40، وقال النحاس في "إعراب القرآن" 1/ 616 (في معناه قولان: أحدهما: هل ينظرون إلا ما وعدوا به في القرآن من العقاب والحساب، والقول الآخر: <span class="qpc-hafs">﴿هَلْ يَنْظُرُونَ إِلَّا تَأْوِيلَهُ﴾</span> من النظر إلى يوم القيامة) اهـ. وانظر: "معاني الزجاج" 2/ 341، والطبري 8/ 204، و"معاني النحاس" 3/ 41 - 42، والسمرقندي 1/ 545، والماوردي 2/ 228.|5:ما بين المعقوفين ساقط من (ب).|6:في النسخ: (ومعنى) والأولى (ومضى).|7:انظر: "البسيط" النسخة الأزهرية 1/ 175 أ.|8:انظر: "البسيط" نسخة جستربتي 2/ 4 أ.|9:أخرجه الطبري 8/ 204، وابن أبي حاتم 5/ 1494 بسند ضعيف، وقال ابن القيم كما في "بدائع التفسير" 2/ 217 - 218 (فمجيء تأويله مجيء نفس ما أخبرت به الرسل من اليوم الآخر والمعاد وتفاصيله، والجنة والنار ويسمى تعبير الرؤيا تأويلًا بالاعتبارين، فإنه تفسير لها وهو عاقبتها وما تؤول إليه، فتأويل ما أخبرت به الرسل == هو مجيء حقيقته ورؤيتها عيانًا ومنه تأويل الرؤيا وهو حقيقتها الخارجية التي ضربت للرائي في عالم المثال) اهـ.|10:"معاني الزجاج" 2/ 341، وانظر: "إعراب النحاس" 1/ 616، و"المشكل" 1/ 293، و"البيان" 1/ 364، و"التبيان" ص 378، و"الفريد" 2/ 310، و"الدر المصون" 5/ 337 وكلهم على أنه منصوب على الظرف والعامل فيه <span class="qpc-hafs">﴿يَقُولُ﴾</span>.|11:لفظ: (الواو) ساقط من (ب).|12:في (ب): (معنا)، وهو تحريف.|13:في (ب): (تركوه العمل)، وهو تحريف.|14:"معاني الزجاج" 2/ 341 - 342، وانظر: الطبري 8/ 204، و"معاني النحاس" 3/ 42، والسمرقندي 1/ 545، والماوردي 2/ 229.|15:لفظ: (بالفاء) ساقط من (ب).|16:هذا قول الزجاج في "معانيه" 2/ 342 وهو المشهور، وقول الجمهور: (فتكون جملة <span class="qpc-hafs">﴿أَوْ نُرَدُّ﴾</span> معطوفة على جملة <span class="qpc-hafs">﴿فَهَلْ لَنَا مِنْ شُفَعَاءَ﴾</span> داخلة معها في حكم الاستفهام. انظر: "معاني الفراء" 1/ 380، والأخفش 2/ 300، و"تفسير الطبري" 12/ 205، و"إعراب النحاس" 1/ 616، و"المشكل" 1/ 293، و"البيان" 1/ 364، و"التبيان" ص 378، و"الفريد" 2/ 310، و"البحر" 4/ 306، و"الدر المصون" 5/ 337.|17:"تنوير المقباس" 2/ 99 وفيه: (فنؤمن ونعمل غير الذي كنا نعمل في الشرك) اهـ.|18:في (ب) تكرار قال الله تعالى: <span class="qpc-hafs">﴿قَدْ خَسِرُوا أَنْفُسَهُمْ﴾</span>.|19:في (ب): (خسروا النعيم)، وهو تصحيف.|20:"تنوير المقباس" 2/ 9: وفيه (غبنوا أنفسهم بذهاب الجنة ولزوم النار) اهـ.|21:انظر: معنى الخسران في "البسيط" البقرة: 27.|22:في (ب) تكرار: (يريد سقط عنهم ما كانوا يفترون يريد سقط عنهم ما كانوا يقولون ...)|23:انظر: "تفسير الطبري" 8/ 205، والسمرقندي 1/ 545، والبغوي 3/ 235.
  7,54,"<div class=ar lang=ar><p>قوله تعالى: <span class="qpc-hafs">﴿إِنَّ رَبَّكُمُ اللَّهُ الَّذِي خَلَقَ السَّمَاوَاتِ وَالْأَرْضَ فِي سِتَّةِ أَيَّامٍ﴾</span> الآية. قال الليث: (السِّتُّ والسِّتة في التأسيس على غير لفظيهما، وهما في الأصل سِدْس وسِدْسَة، ولكنهم أرادوا إدغام الدال في السين فالتقتا عند مخرج التاء فغلبت {1} عليهما، وبيان ذلك أنك [تصغر] {2} ستة سُدَيْسة، وكذلك الأسداس، وجميع تصريفهما {3} على ذلك) {4}.</p><p>ابن السكيت: (يقال: جاء فلان سادسًا، وساديًا، وساتًّا؛ فسادس على لفظ السُّدس، وساتّ على لفظ ستَّة أدغموا الدال في السين فصارت تاء مشددة، ومن قال ساديًا أبدل من السين ياء) {5}.</p><p>قال أهل التفسير: (قوله <span class="qpc-hafs">﴿فِي سِتَّةِ أَيَّامٍ﴾</span>، أراد: في مقدار ستة أيام؛ لأن اليوم من لدن طلوع الشمس إلى غروبها، فكيف [يكون] {6} يوم ولا شمس ولا سماء؟ وهذا كقوله: <span class="qpc-hafs">﴿وَلَهُمْ رِزْقُهُمْ فِيهَا بُكْرَةً وَعَشِيًّا﴾</span> [مريم: 62] على مقادير البكرة والعشي في الدنيا؛ إذ لا ليل ثم ولا نهار {7}، فإن قيل: لأي علة <span class="qpc-hafs">﴿خَلَقَ السَّمَاوَاتِ وَالْأَرْضَ فِي سِتَّةِ أَيَّامٍ﴾</span>، ولو خلقهن في طرفة عين كان أدل على نفاذ قدرته، والله تعالى يقول: <span class="qpc-hafs">﴿وَمَا أَمْرُنَا إِلَّا وَاحِدَةٌ كَلَمْحٍ بِالْبَصَرِ﴾</span> [القمر: 50]، والجواب: ما قال سعيد بن جبير: (قدر الله على خلق السموات والأرض في لمحة ولحظة، وإنما خلقهن في ستة أيام تعليمًا لخلقه الرفق والتثبت في الأمور) {8}.</p><p>وقال أهل المعاني: (إن تدبير الحوادث على إنشاء شيء بعد شيء على ترتيب، أدل على عالم مدبر يصرفه على اختياره ويجريه على مشيئته) وقيل: (أراد بذلك زيادة البصيرة للملائكة في يقينهم {9} لما يشاهدونه من ظهور شيء وإنشاء خلق بعد خلق) {10}.</p><p>وقال أبو بكر بن الأنباري: (إن الله {11} خلق السموات والأرض والليل والنهار تكرمة لآدم وذريته، وقد بيّن هذا في قوله: <span class="qpc-hafs">﴿الَّذِي جَعَلَ لَكُمُ الْأَرْضَ فِرَاشًا وَالسَّمَاءَ بِنَاءً﴾</span> الآية [البقرة: 22]، وفي قوله: <span class="qpc-hafs">﴿وَمِنْ رَحْمَتِهِ جَعَلَ لَكُمُ اللَّيْلَ وَالنَّهَارَ﴾</span> [القصص: 73]، فلما كان خلق هذه الأشياء تكرمة لآدم وولده، وكانت الأيام سبعة أوقع في كل يوم منها ضربًا من التكرمة نبه به الملائكة على عظم شأن آدم وولده عنده، وكان خلق السموات والأرض في ستة أيام عن غير عجز من الله عز وجل أن يكون في لمحة، ولكنه تعالى أراد أن يوقع في كل يوم منها أمرًا من خلقه تستعظمه الملائكة وجميع المشاهدين له) {12}، وهذا معنى قول مجاهد: (إن ذلك رُتِّب على الأيام: الأحد والاثنين والثلاثاء والأربعاء والخميس والجمعة، فاجتمع الخلق فيه) {13}.</p><p>وقوله تعالى: <span class="qpc-hafs">﴿ثُمَّ اسْتَوَى عَلَى الْعَرْشِ﴾</span> أي: أقبل على خلقه، وقصد إلى ذلك بعد خلق السموات والأرض، وهذا قول الفراء {14} وأبي العباس {15} والزجاج {16}.</p><p>وقال آخرون: <span class="qpc-hafs">﴿اسْتَوَى﴾</span> معناه استولى {17} واحتجوا بقول البعيث {18}:</p><p>ثم اسْتَوَى بِشْرُ على العِرَاقِ ... من غير سيفٍ ودمٍ مُهْرَاقِ {19} يعني: بشر بن مروان {20}، وعلى هذا خصّ العرش بالإخبار عن الاستيلاء عليه؛ لأنه أعظم المخلوقات.</p><p>وقال الأخفش: (<span class="qpc-hafs">﴿اسْتَوَى﴾</span> أي: علا، يقال: استويت على ظهر البيت أي: علوته) {21} وهذا القول اختيار ابن جرير، قال: (معناه: ارتفع ارتفاع ملك وسلطان، لا ارتفاع انتقال وزوال) {22}، وهذا يعود إلى معنى الاستيلاء {23}. وقد شرحنا الاستواء في صفة الله تعالى مستقصى في سورة البقرة {24}.</p><p>و <span class="qpc-hafs">﴿الْعَرْشِ﴾</span> في كلام العرب {25} سرير الملك، يدل على ذلك سرير ملكة سبأ، سماه الله عرشًا فقال: <span class="qpc-hafs">﴿وَلَهَا عَرْشٌ عَظِيمٌ (23)﴾</span> [النمل: 23]، والعرش في اللغة: قد يكون عبارة عن الملك، يقال: {26} ثُلَّ عَرْشُه، إذا ذهب عزه وملكه، ومنه قول زهير:</p><p>تَدَاركتُما الأَحلافَ قد ثُلَّ عَرْشُهَا {27}</p><p>غير أنه لا يسوغ أن يكون المراد بالعرش في هذه الآية الملك؛ لأنه يوجب أن الله لم يكن مستويًا على ملكه قبل خلق السموات {28} والأرض.</p><p>وقوله تعالى: <span class="qpc-hafs">﴿يُغْشِي اللَّيْلَ النَّهَارَ﴾</span> وقرئ <span class="qpc-hafs">﴿يُغْشِي﴾</span> {29} مخففا، والإغشاء {30}.</p><p>والتغشية: إلباس الشيء {31} الشيء، وقد جاء التنزيل بالتشديد والتخفيف، فمما جاء {32} بتضعيف {33} العين قوله: <span class="qpc-hafs">﴿فَغَشَّاهَا مَا غَشَّى﴾</span> [النجم: 54]، ومما {34} جاء بنقل الهمزة: <span class="qpc-hafs">﴿فَأَغْشَيْنَاهُمْ فَهُمْ لَا يُبْصِرُونَ﴾</span> {35} [يس: 9]، والمفعول الثاني محذوف على معنى: فأغشيناهم العمى أو فقد الرؤية.</p><p>قال أبو إسحاق: (والمعنى: أن الليل يأتي على النهار ويغطيه ولم يقل: يغشي {36} النهار الليل؛ لأن في الكلام دليلًا عليه، وقد قال في موضع آخر: <span class="qpc-hafs">﴿يُكَوِّرُ اللَّيْلَ عَلَى النَّهَارِ وَيُكَوِّرُ النَّهَارَ عَلَى اللَّيْلِ﴾</span> {37} [الزمر: 5].</p><p>قال أبو علي: (وهذا {38} كما قال: <span class="qpc-hafs">﴿سَرَابِيلَ تَقِيكُمُ الْحَرَّ﴾</span> [النحل: 81]، ولم يذكر تقيكم البرد للعلم بذلك من الفحوى، ومثل هذا لا يضيق، وكل واحد من الليل والنهار منتصب بأنه مفعول به، والفعل قبل النقل غشي الليلُ النهارَ {39}، فإذا نقلت قلت: أغشى الله الليل النهار، أو غَشَّى الله الليل النهار، فصار ما كان فاعلًا قبل النقل مفعولًا أول) {40}.</p><p>وقوله تعالى: <span class="qpc-hafs">﴿يَطْلُبُهُ حَثِيثًا﴾</span>، قال الليث: (الحث: الإعجال والاتصال {41}، تقول: حثثت فلانًا فاحْتث وهو حثيث محثوث: جاد سريع) {42}.</p><p>قال الأعشي:</p><p>تَدَلَّى حثيثًا كَأَنَّ الصِّوَارَ ... أَتْبَعَهُ أَزْرِقيٌّ لَحِمْ {43} شبه الفرس في السرعة بالبازي {44}.</p><p>قال ابن عباس: (يريد {45} يطلب الليل النهار لا غفلة له) {46}.</p><p>و {47} قال المبرد: (يعني: يطلب الليل النهار دائبًا) {48}.</p><p>وقال غيره: (معنى: <span class="qpc-hafs">﴿يَطْلُبُهُ حَثِيثًا﴾</span> هو أن يستمر الليل في طلب النهار على منهاج من غير فتور يوجب الاضطراب، كما يكون في السوق الحثيث) {49}، وهذا معنى قول ابن عباس: (لا غفلة [له)] {50}.</p><p>وقوله تعالى: <span class="qpc-hafs">﴿وَالشَّمْسَ وَالْقَمَرَ وَالنُّجُومَ مُسَخَّرَاتٍ بِأَمْرِهِ﴾</span>، معنى التسخير: التذليل {51}. قال الزجاج: (وخلق هذه الأشياء جاريات مجاريها بأمره) {52}. وقال المفسرون: (معنى تسخيرهن: تذليلهن لما يراد منها من طلوع وأفول وسير ورجوع؛ إذ لَسْنَ قادرات ولا مميزات، وإنما يتصرفن في متصرفاتهن على حسب إرادة المدبر فيهن) {53}.</p><p>وقرأ {54} ابن عامر {55}: <span class="qpc-hafs">﴿وَالشَّمْسَ وَالْقَمَرَ وَالنُّجُومَ مُسَخَّرَاتٍ﴾</span> رفعًا كلها، والنصب {56} هو وجه الكلام لقوله تعالى: <span class="qpc-hafs">﴿وَاسْجُدُوا لِلَّهِ الَّذِي خَلَقَهُنَّ﴾</span> [فصلت: 37] فكما أخبر في هذه الآية أنه خلق الشمس والقمر، كذلك يُحمل على <span class="qpc-hafs">﴿خَلَقَ﴾</span> {57} في قوله: <span class="qpc-hafs">﴿إِنَّ رَبَّكُمُ اللَّهُ الَّذِي خَلَقَ السَّمَاوَاتِ وَالْأَرْضَ فِي سِتَّةِ أَيَّامٍ ثُمَّ اسْتَوَى عَلَى الْعَرْشِ يُغْشِي اللَّيْلَ النَّهَارَ يَطْلُبُهُ حَثِيثًا وَالشَّمْسَ وَالْقَمَرَ وَالنُّجُومَ﴾</span> [الأعراف:54]، وحجة ابن عامر قوله: <span class="qpc-hafs">﴿وَسَخَّرَ لَكُم مَّا في اَلسَّمَاوَاتِ وَمَا في اَلأَرْضِ﴾</span> [الجاثية: 13]، ومما في السماء الشمس والقمر، فإذا أخبر بتسخيرها حسن الإخبار عنها به، كما أنك إذا قلت: ضربت زيدًا استقام أن تقول: زيد مضروب {58}.</p><p>وقوله تعالى: <span class="qpc-hafs">﴿أَلَا لَهُ الْخَلْقُ وَالْأَمْرُ﴾</span>، قال أصحاب المعاني: (<span class="qpc-hafs">﴿لَهُ الْخَلْقُ﴾</span> لأنه خلقهم، وله أن يأمر فيهم بما أحب {59}، وله الحكم في الخلق يأمرهم بما يشاء)، وعلى هذا [المعنى] {60} <span class="qpc-hafs">﴿الْأَمْرُ﴾</span> هاهنا الذي هو نقيض النهي {61}، واستخرج سفيان بن عيينة من هذا أن كلام الله لا يجوز أن يكون مخلوقًا فقال: فرّق الله بين الخلق والأمر، فمن جمع بينهما فقد كفر) {62} يعني: من جعل الأمر الذي هو قوله من جملة ما خلقه فقد كفر. وقال ابن عباس في تفسير قوله: <span class="qpc-hafs">﴿أَلَا لَهُ الْخَلْقُ وَالْأَمْرُ﴾</span> (يريد: لم يبق شيء، من وجد بعد ذلك شيئًا فليأخذه) {48}، وهذا كلامه، ومعنى هذا: أن جميع {64} ما في العالم لله تعالى، فالخلق له لأنه خلقهم، وجميع الأمور تجري بقضائه وقدره، وهو مجريها ومنشئها فلا يبقى بعد هذا لأحد شيء {65}.</p><p>وقوله تعالى: <span class="qpc-hafs">﴿تَبَارَكَ اللَّهُ رَبُّ الْعَالَمِينَ﴾</span>، قال الليث: (تفسير <span class="qpc-hafs">﴿تَبَارَكَ اللَّهُ﴾</span> تمجيد وتعظيم) {66}.</p><p>وقال أبو العباس: (<span class="qpc-hafs">﴿تَبَارَكَ اللَّهُ﴾</span> ارتفع، والمتبارك المرتفع) {67}.</p><p>وقال ابن الأنباري: (<span class="qpc-hafs">﴿تَبَارَكَ اللَّهُ﴾</span> باسمه يتبرك في كل شيء) {68}.</p><p>وقال الزجاج: (<span class="qpc-hafs">﴿تَبَارَكَ﴾</span> تفاعل من البركة، كذلك يقول أهل اللغة) {69}.</p><p>وكذلك روي عن ابن عباس: (ومعنى: البركة الكثرة في كل خير، وقال في موضع آخر: (<span class="qpc-hafs">﴿تَبَارَكَ﴾</span> تعالى وتعاظم) {70}.</p><p>وقال أصحاب المعاني: (<span class="qpc-hafs">﴿تَبَارَكَ اللَّهُ﴾</span> أي: ثبت ما به استحق التعظيم فيما لم يزل ولا يزال) {71}، وأصل الحرف من الثبوت والدوام، وقد ذكرنا هذا في سورة الأنعام عند قوله: <span class="qpc-hafs">﴿وَهَذَا كِتَابٌ أَنْزَلْنَاهُ مُبَارَكٌ﴾</span> [الأنعام: 92].</p></div>",footnotes:1:في (ب): (فقلبت)، وهو تصحيف.|2:لفظ: (تصغر) ساقط من (أ).|3:في (ب): (تصريفها) وعند الأزهري في "تهذيب اللغة" 2/ 1623: (تصغيرها).|4:"تهذيب اللغة" 2/ 1623، وانظر: "العين" 7/ 186 (ست).|5:"إصلاح المنطق" ص 301، و"تهذيب اللغة" 2/ 1623. وانظر: "الصحاح" 1/ 251 (ستت)، و"المفردات" ص 403 (سدس)، و"اللسان" 4/ 1935 (ستت).|6:لفظ: (يكون) ساقط من (ب).|7:قال ابن الجوزي في "تفسيره" 3/ 211: (أي في مقدار ذلك ولم تكن الشمس حينئذ، قال ابن عباس ومجاهد والضحاك وكعب: مقدار كل يوم من تلك الأيام ألف سنة. ولا نعلم خلافًا في ذلك) اهـ. بتصرف.</p><p>وانظر: "تفسير السمرقندي" 1/ 545، والبغوي 3/ 235، وابن عطية 5/ 525، والرازي 14/ 118، والقرطبي 7/ 219.|8:ذكره الثعلبي في "الكشف" 191 أ، والبغوي 3/ 235، و"الخازن" 2/ 237.|9:في (ب): (في نفسهم).|10:ذكر هذه الأوجه الماوردي 2/ 230، وابن الجوزي 3/ 212، والرازي 14/ 118 و"الخازن" 2/ 237، وقال النحاس في "إعراب القرآن" 1/ 617: (لأنه علم أن ذلك أصلح ليظهر قدرته للملائكة شيئاً بعد شيء) اهـ.|11:في (ب): (الله تعالى).|12:ذكره الواحدي في "الوسيط" 1/ 191، وابن الجوزي 3/ 212 مختصرًا.|13:أخرجه الطبري 8/ 205، والبيهقي في "الأسماء والصفات" 2/ 243 بسند جيد، وذكره السيوطي في "الدر" 3/ 169.|14:"معاني الفراء" 1/ 25 وفيه حكى أوجه منها: (أن يستوي الرجل وينتهي شبابه أو يستوي عن اعوجاج، وبمعنى أقبل، وبمعنى صعد، وكل في كلام العرب جائز).|15:"تهذيب اللغة" 2/ 1794، وفي "مجالس ثعلب" 1/ 174 و269 قال: (يقال فيه ضروب، الفراء وأصحابنا يقولون أقبل. ويقال: استوى عليه من الاستواء، والمعتزلة يقولون: استولى) اهـ.|16:"معاني الزجاج" 1/ 107 قال: (فيه قولان: عمد وقصد إلى السماء، كما تقول: قد فرغ الأمير من بلد كذا وكذا ثم استوى إلى بلد كذا، معناه قصد الاستواء إليه، وقد قيل أيضاً: استوى أي صعد أمره إلى السماء).|17:هذا قول أهل التأويل من المعتزلة والجهمية والحرورية وغيرهم، وقد اتفق أهل العلم على إبطاله وأجمعوا على أن المراد بالاستواء على العرش، إنما هو الاستعلاء والارتفاع عليه، فهو سبحانه مستو على عرشه استواء يليق بجلاله وعظمته ولا يلزم لهذا أي لازم باطل مما يلزم لاستواء المخلوقين. انظر: "الإبانة" ص 36، و"الأسماء والصفات" 2/ 306 - 308، و"الفتاوى" 5/ 143 - 149، و"مختصر العلو" للألباني ص 26.|18:البعيث: هو خداش بن بشير بن خالد المجاشعي، أبو مالك البصري المعروف بالبَعِيث، شاعر أموي مجيد وخطيب بني تميم، كانت بينه وبين جرير مهاجاة دامت نحو 40 سنة، توفي سنة 134. انظر: "طبقات فحول الشعراء" 2/ 386، و"الشعر والشعراء" ص 329، و"معجم الأدباء" 3/ 289، و"الأعلام" 2/ 302.|19:الشاهد بدون نسبة فى "الصحاح" 6/ 2385 (سوا)، و"تفسير الماوردي" 2/ 229، و"الأسماء والصفات" للبيهقي 2/ 309، و"زاد المسير" 3/ 213، والقرطبي 7/ 220، و "رصف المباني" ص 434، و"اللسان" 4/ 2163 (سوا)، و"الخازن" == 2/ 339، و"الدر المصون" 1/ 243، ونسب في "تاج العروس" 19/ 551 (سوا)، إلى الأخطل، وفي هذه المراجع (قد استوى)، وقال شيخ الإسلام في "الفتاوى" 5/ 146: (لم يثبت نقل صحيح أنه شعر عربي، وكان غير واحد من أئمة اللغة أنكروه، وقالوا: إنه بيت مصنوع لا يعرف في اللغة) اهـ. ونسبه ابن كثير في "البداية والنهاية" 9/ 7 إلى الأخطل، وقال: (الأخطل نصراني، والاستدلال به باطل من وجوه كثيرة) اهـ. وهو ليس في ديوان الأخطل والواحدي نسبه هنا وفي "الوسيط" 1/ 192 (إلى البعيث) وانظر: "مختصر الصواعق المرسلة" 3/ 890، 898.|20:بشر بن مروان بن الحكم بن أبي العاص الأموي: أمير كان سمحًا جوادًا، ولى إمرة العراق لأخيه عبد الملك، وتوفي سنة 75 هـ، وله نيف وأربعون سنة. انظر: "سر أعلام النبلاء" 4/ 145، و"البداية والنهاية" 9/ 7، و"تهذيب تاريخ ابن عساكر" 3/ 251، و"الأعلام" 2/ 55.|21:"تهذيب اللغة" 2/ 1794، وانظر: "معاني الأخفش" 1/ 55 - 56.|22:"تفسير الطبري" 1/ 192، واختار أن معنى قوله: <span class="qpc-hafs">﴿ثُمَّ اسْتَوَى إِلَى السَّمَاءِ﴾</span> [البقرة: 29]: (علا عليهن وارتفع فدبرهن بقدرته وخلقهن سبع سموات) اهـ.|23:الطبري -رحمه الله تعالى- رجح في معنى الاستواء ما قال به السلف، ثم أخذ يناقش المؤولين، ومن باب إلزام الحجة لهم، قال: (قل علا عليها علو ملك وسلطان) اهـ، وهذه العبارة ليست من نهج السلف في الإثبات، والله اعلم.|24:انظر: "البسيط" البقرة: 29.|25:العرش: سرير الملك وسقف البيت، انظر: "العين" 1/ 249، و"الجمهرة" 2/ 728، و"تهذيب اللغة" 3/ 2391، و"الصحاح" 3/ 1009، و"المجمل" 3/ 658، و "مقاييس اللغة" 4/ 264، و"المفردات" ص 558، و"اللسان" 5/ 2880 (عرش).|26:هذا مثل يضرب لمن ذهب عزه وزال قوام أمره وساءت حاله. انظر: "جمهرة الأمثال" 1/ 290، و"المستقصى" للزمخشري 2/ 43، و"مجمع الأمثال" 1/ 271.|27:"ديوان زهير" ص 105، و"العين" 1/ 249، و"المنجد" لكراع ص 105، و"تهذيب اللغة" 3/ 2392، و"الصحاح" 3/ 1010، و"مقاييس اللغة" 4/ 265، و"اللسان" 5/ 2881 (عرش)، وتمامه:</p><p>وَذُبْيَانَ قد زَلَّتْ بِأَقْدامِهَا النَّعْلُ</p><p>قال ثعلب في "شرحه": (الأحلاف عبس وفزارة وثل عرشها هذا مثل أي: أصابها ما كسرها وهدمها) اهـ.|28:هذا هو الصحيح والآيات والأحاديث والآثار تدفع أن يكون المراد بالعرش الملك، وأهل السنة والجماعة يثبتون العرش واستواء الله تعالى عليه كيف يشاء، قال شيخ الإِسلام في "الفتاوى" 6/ 584 - 585: (العرش موجود بالكتاب والسنة وإجماع الأمة والآيات والأحاديث فيه صريحة متواترة وهو غير الكرسي والكرسي ثابت بالكتاب والسنة وإجماع جمهور السلف) اهـ. ملخصًا.</p><p>وانظر: "الأسماء والصفات" ص 272، و "شرح العقيدة الطحاوية" لابن أبي العز ص 256، 257.|29:قرأ حمزة والكسائي وأبو بكر عن عاصم: <span class="qpc-hafs">﴿يُغْشِي﴾</span> بفتح الغين، وتشديد الشين، وقرأ الباقون بإسكان الغين وتخفيف الشين. انظر: "السبعة" ص 282، و"المبسوط" ص 180 - 181، و"التذكرة" 2/ 419، و"التيسير" ص 110، و"النشر" 2/ 269.|30:الغِشَاء: الغطاء والإغشاء، والتغشية: تغطية شيء بشيء. انظر: "العين" 4/ 429، و"المنجد" لكراع ص 274، و"تهذيب اللغة" 3/ 2668، و"الصحاح" 6/ 2446، و"مقاييس اللغة" 4/ 425، و"المجمل" 3/ 696، و"المفردات" ص 607، و"اللسان" 6/ 3261 (غشى).|31:في (ب): (إلباس الشيء بالشيء).|32:في (ب): (فما جاء).|33:في "الحجة" لأبي علي 4/ 27 - 28: (غشى فعل متعدٍّ إلى مفعول واحد فإذا نقلت الفعل المتعدي إلى المفعول الواحد بالهمزة أو بتضعيف العين تعدى إلى مفعولين، وقد جاء التنزيل بالأمرين جميعًا) ثم ذكر نحو ما ذكره الواحدي.|34:في (ب): (وما جاء).|35:في (أ): (وهو لا ينصرون)، وهو تصحيف.|36:في (ب): (ويغشى).|37:"معاني الزجاج" 2/ 342، ومثله ذكر النحاس في "معانيه" 3/ 42.|38:في (ب): (فهذا).|39:في (ب): (بالنهار).|40:"الحجة" لأبي علي 4/ 28، وانظر: "معاني القراءات" 1/ 408، و"إعراب القراءات" 1/ 185، و"الحجة" لابن خالويه ص 156، ولابن زنجلة ص 284، و"الكشف" لمكي 1/ 464، ونقل قول الواحدي، والرازي في "تفسيره" 14/ 117.|41:في (ب): (والإيصال)، وعند الأزهري في "تهذيب اللغة" 1/ 739، عن الليث: (الإعجال في الاتصال).|42:"تهذيب اللغة" 1/ 739، وانظر: "الجمهرة" 1/ 81، و"الصحاح" 1/ 278، و"المجمل" 1/ 221، و"مقاييس اللغة" 2/ 29، و"المفردات" ص 218، و"اللسان" 2/ 773 (حثث).|43:"ديوانه" ص 199، وهو في "تهذيب اللغة" 1/ 740، و"اللسان" 2/ 774 (حثث)، و"الدر المصون" 5/ 342، وجاء في حاشية "الديوان" (الصوار: القطيع من بقر الوحش، وحثيثًا: سريعًا والأزرقي اللحم: الصقر، والمعنى يشبه هذا الفرس بسرعة الصقر الشره إلى أكل اللحم) اهـ.|44:في (ب): (شبه الفرس لسرعته بالبازي). والبازي واحد البُزاة التي تَصِيد، ضَرْب من الصُّقور. انظر: "اللسان" 1/ 278 (بزا).|45:لفظ: (يريد) ساقط من (ب).|46:ينظر: "تنوير المقباس" 2/ 100، وذكره الواحدي في "الوسيط" 1/ 193، وأخرج الطبري 8/ 206 بسند جيد عن ابن عباس قال: (يطلبه سريعًا) اهـ.|47:لفظ: (الواو) ساقط من (ب).|48:لم أقف عليه.|49:انظر: "تفسير الطبري" 8/ 206، والسمرقندي 1/ 546، والماوردي 2/ 230، والرازي 14/ 117.|50:لفظ: (له) ساقط من (ب).|51:انظر: "الصحاح" 2/ 679، و"المفردات" ص 402، و"اللسان" 4/ 1963 (سخر).|52:"معاني الزجاج" 2/ 342.|53:انظر: الطبري 8/ 206، والسمرقندي 1/ 546، والماوردي 2/ 230، والبغوي 3/ 236، وابن الجوزى 3/ 214، و"الخازن" 2/ 240.|54:في أصل (أ): (وقول) ثم صحح إلى (قرأ).|55:قرأ ابن عامر: (<span class="qpc-hafs">﴿وَالشَّمْسَ وَالْقَمَرَ وَالنُّجُومَ مُسَخَّرَاتٍ﴾</span> بالرفع في الأربع، وقرأ الباقون بالنصب غير أن التاء مكسورة من <span class="qpc-hafs">﴿مُسَخَّرَاتٍ﴾</span> لأنها تاء جمع المؤنث السالم. انظر: "السبعة" ص 282 - 283، و"المبسوط" ص 181، و"التذكرة" 2/ 419، و"التيسير" ص 110، و"النشر" 2/ 169.|56:وكذا قال مكي في "الكشف" 1/ 465، ونقل قول الواحدي الرازي في "تفسيره" 14/ 118.|57:انظر: "معاني الأخفش" 2/ 300، و"إعراب النحاس" 1/ 617.|58:هذا نص كلام أبي علي في "الحجة" 4/ 29 غير أنه لم يختر قراءة النصب. وانظر: "معاني القراءات" 1/ 408، و"إعراب القراءات" 1/ 185 - 186، و"الحجة" لابن خالويه ص 156 - 157، ولابن زنجلة ص 284.|59:في (ب): (بما حب).|60:لفظ: (المعنى) ساقط من (ب).|61:انظر: "تفسير الطبري" 8/ 206، والسمرقندي 1/ 546، والماوردي 2/ 230، والبغوي 3/ 236.|62:"تفسير سفيان بن عيينة" ص 249، وأخرجه الثعلبي في "الكشف" ص 191/ أ، والبيهقي في "الأسماء والصفات" 1/ 556، وزاد السيوطي في "الدر" 3/ 171 نسبته إلى ابن أبي حاتم، وذكره السمرقندي في "تفسيره" 1/ 546، والبغوي 3/ 236، والقرطبي 7/ 221، و"الخازن" 2/ 240، وفي "أصول السنة" لأبي بكر الحميدي في مجلة الحكمة 1/ 286 قال سفيان بن عيينة: (القرآن كلام الله، ومن قال مخلوق فهو مبتدع لم نسمع أحدًا يقول هذا) اهـ. وقال النحاس في "معانيه" 3/ 42 - 43 في تفسير الآية: (فرق بين الشيء المخلوق وبين الأمر وهو كلام، فدل أن كلامه غير مخلوق، وهو قول "كن") اهـ. وقال القرطبي في "تفسيره" 7/ 222: (وفي تفريقه بين الخلق والأمر دليل بيّن على فساد قول من قال يخلق القرآن؛ إذ لو كان كلامه الذي هو أمر مخلوقًا لكان قد قال: ألا له الخلق والخلق وذلك عِيٌّ من الكلام ومستهجن ومستغث والله يتعالى عن التكلم بما لا فائدة فيه) اهـ. وهذا هو الحق وأهل السنة والجماعة من السلف والخلف متفقون على أن القرآن كلام الله غير مخلوق. انظر: "الإبانة" ص 21، و"الفتاوى" 12/ 37، و"شرح الطحاوية" لابن أبي العز ص 137.|63:لم أقف عليه.|64:في (أ): (أن جميع الخلق ما في العالم). ثم ضرب على لفظ (الخلق) وهو الأولى.|65:ذكره الخازن 2/ 240.|66:"تهذيب اللغة" 1/ 319، وانظر: "العين" 5/ 368، و"الجمهرة" 1/ 325، و"الصحاح" 4/ 1575، و"المجمل" 1/ 121، و"مقاييس اللغة" 1/ 230، و"المفردات" ص 119، و"اللسان" 1/ 226 (برك).|67:"تهذيب اللغة" 1/ 319.|68:"تهذيب اللغة" 1/ 319، وفي "الزاهر" 1/ 53، قال ابن الأنباري: (فيه قولان: قال قوم: معنى تبارك: تقدس أي: تطهير، والقدس عند العرب: الطهر، وقال قوم: معنى تبارك اسمك: تفاعل من البركة أي: البركة تُكسب وتنال بذكر اسمك) اهـ.|69:"تهذيب اللغة" 1/ 319، ولم أقف عليه في "معانيه".|70:"تهذيب اللغة" 1/ 319، و"تفسير السمرقندي" 1/ 546، والبغوي 3/ 236، وابن الجوزي 3/ 214، و"الخازن" 2/ 240، و"تنوير المقباس" 2/ 100.|71:ذكره البغوي 3/ 236، و"الخازن" 2/ 240 عن المحققين.
  7,55,"<div class=ar lang=ar><p>قوله تعالى: <span class="qpc-hafs">﴿ادْعُوا رَبَّكُمْ تَضَرُّعًا وَخُفْيَةً﴾</span>، التضرع: التذلل والتخشع، وهو إظهار الذل الذي في النفس من قولهم: ضرع فلان لفلان، وتضرع له إذا ما تخشع له وسأله أن يعطيه، ومضى الكلام في هذا في سورة الأنعام عند قوله: <span class="qpc-hafs">﴿لَعَلَّهُمْ يَتَضَرَّعُونَ﴾</span> [الأنعام:42]، والخُفية: خلاف العلانية، وهو من أخفيت الشيء إذا سترته {1}، ويقال: خِفية أيضًا بالكسر {2} وقد قرئ بالوجهين {3}.</p><p>قال الزجاج: (<span class="qpc-hafs">﴿تَضَرُّعًا﴾</span> تملقًا، وحقيقته: أن يدعوه خاضعين متعبدين) {4}.</p><p>قال {5} أهل العلم: والسنة {6} والأدب في الدعاء أن يكون خفيًا لهذه الآية، ولما روي عن النبي ﷺ أنه قال: "خير الدعاء ما خفي" {7}.</p><p>وقال أيضًا لقوم رفعوا أصواتهم بالدعاء: "إنكم لستم تدعون أصمّ ولا غائبًا، إنكم تدعون سميعًا قريبًا، إنه معكم" {8}.</p><p>وقال الحسن: (إن الله يحب القلب النقي والدعاء الخفي، ولقد أثنى علي زكريا فقال: <span class="qpc-hafs">﴿إِذْ نَادَى رَبَّهُ نِدَاءً خَفِيًّا﴾</span> [مريم: 3]، وبين دعوة السر ودعوة العلانية سبعون ضعفًا ، ولقد كان المسلمون يجتهدون في الدعاء و {9} ما يُسمع لهم صوت، إن كان إلا همسًا بينهم وبين ربهم، وذلك أن الله يقول: <span class="qpc-hafs">﴿ادْعُوا رَبَّكُمْ تَضَرُّعًا وَخُفْيَةً﴾</span> {10}. وقال الزجاج في قوله <span class="qpc-hafs">﴿وَخُفْيَةً﴾</span> (أي: واعتقدوا عبادته في أنفسكم؛ لأن الدعاء معناه: العبادة) {11}.</p><p>وقوله تعالى: <span class="qpc-hafs">﴿إِنَّهُ لَا يُحِبُّ الْمُعْتَدِينَ﴾</span> أي: المجاوزين ما أمروا به، قال الكلبي: (<span class="qpc-hafs">﴿لَا يُحِبُّ الْمُعْتَدِينَ﴾</span> بالجهر في الدعاء) {12}.</p><p>وقال ابن جريج: (من الاعتداء رفع الصوت والنداء بالدعاء) {13}.</p></div>",footnotes:1:في (أ): (أي سترته).|2:انظر: "العين" 4/ 313، و"الجمهرة" 1/ 617 - 618، و"تهذيب اللغة" 1/ 1070، و"الصحاح" 6/ 2329، و"المجمل" 2/ 297، و"مقاييس اللغة" 2/ 202، و"المفردات" ص 289، و"اللسان" 2/ 1217 (خفي).|3:قرأ عاصم في رواية أبي بكر هنا وفي الأنعام آية 63: <span class="qpc-hafs">﴿وَخُفْيَةً﴾</span> بكسر الخاء، وقرأ الباقون بضمها في السورتين، وهما لغتان مشهورتان. انظر: "السبعة" ص 283، و"المبسوط" ص 170، و"التذكرة" 2/ 400، و"التيسير" ص 103، و"النشر" 2/ 259، وانظر: في "توجيه القراءات "الحجة" لأبي علي 4/ 29 - 30، و"معاني القراءات" 1/ 362، و"إعراب القراءات" 1/ 159، و"الحجة" لابن خالويه ص 141، ولابن زنجلة ص 255، و"الكشف" 1/ 435.|4:"معاني الزجاج" 2/ 344، وفيه: (قال قوم: تضرعوا تملقًا - حقيقته ..).|5:لفظ: (قال) ساقط من (ب).|6:انظر: "الفتاوى" 15/ 10 - 28، و"بدائع التفسير" 2/ 219 - 238.|7:لم أقف عليه بهذا اللفظ بعد طول بحث، وروي وكيع في "الزهد" 1/ 341 == رقم 118، وابن أبي شيبة 6/ 86 (29654)، وأحمد في "المسند" 3/ 44، و"الزهد" ص 16، وابن حبان في "صحيحه" 2/ 125 رقم 797، وابن السني في "القناعة" ص 26 - 27 رقم 28 - 29 بسند ضعيف عن سعد بن أبي وقاص، أن النبي ﷺ قال: "خير الذكر الخفي، وخير الرزق ما يكفي" اهـ. وفيه محمد بن عبد الرحمن بن لبيبة لين الحديث، كثير الإرسال. انظر: "تهذيب التهذيب" 3/ 627، وانظر: "المفاسد الحسنة" للسخاوي ص 247.|8:أخرجه البخاري رقم (2992) كتاب الجهاد والسير، باب: ما يكره من رفع الصوت في التكبير، ومسلم كتاب الذكر والدعاء، باب: استحباب خفض الصوت بالذكر رقم (2704)، عن أبي موسى الأشعري قال: (كنا مع النبي ﷺ في سفر فجعل الناس يجهرون التكبير فقال النبي ﷺ: "أيها الناس اربعوا على أنفسكم فإنكم لا تدعون أصم ولا غائبًا، إنكم تدعون سميعا قريبًا وهو معكم") اهـ.|9:لفظ: (الواو) ساقط من (ب).|10:أخرجه ابن المبارك في "الزهد" ص 45 - 46، والطبري في "تفسيره" 8/ 206، 207 بسند جيد، وأخرجه وكيع في "الزهد" 2/ 616، وابن أبي شيبة 6/ 87 (29662)، بلفظ: (كانوا يجتهدون في الدعاء ولا تسمع إلا همسًا) اهـ.|11:"معاني الزجاج" 2/ 344، ونحوه قال النحاس في "معانيه" 3/ 43.|12:"تنوير المقباس" 2/ 100، وذكره الواحدي في "الوسيط" 1/ 195، وابن الجوزي 3/ 215.|13:أخرجه الطبري 8/ 207 بسند جيد، ومحبة الله تعالى لا تنتفي عمن يجهر بالدعاء لمجرد الجهر، فالدعاء مأمور به مطلقًا <span class="qpc-hafs">﴿الله لَا يُحِبُّ الْمُعْتَدِينَ﴾</span> في كل شيء دعاء كان أو غيره، وأعظمهم الذين يدعون معه غيره أو يعتدون بترك التضرع والدعاء، وكل سؤال يناقض حكمة الله أو يتضمن مناقضة شرعه وأمره أو يتضمن خلاف ما أخبر به فهو اعتداء لا يحبه الله ولا يحب سائله، والدعاء خفية أحب إلى الله تعالى وأفضل، وفيه فوائد عظيمة وكثيرة، ذكرها ابن القيم كما في "بدائع التفسير" 2/ 219 - 233، وانظر: "أحكام القرآن" لابن العربي 2/ 784، والقرطبي 7/ 223.
  7,56,"<div class=ar lang=ar><p>قوله تعالى: <span class="qpc-hafs">﴿وَلَا تُفْسِدُوا فِي الْأَرْضِ بَعْدَ إِصْلَاحِهَا﴾</span> [الأعراف: 56]. قال عطاء، عن ابن عباس: (يريد: بالشرك بالله، وقطع الأرحام، وتكذيب النبي ﷺ بعد توحيد الله والتصديق بما جاء به النبي ﷺ) {1}.</p><p>قال المفسرون {2}: (الإفساد في الأرض: العمل فيها بالمعاصي، وسفك الدماء، وقوله تعالى: <span class="qpc-hafs">﴿بَعْدَ إِصْلَاحِهَا﴾</span> أي: بعد إصلاح الله إياها ببعث الرسول، وبيان الشريعة، والدعاء إلى طاعة الله عز وجل)، وهذا معنى قول الحسن، والسدي، والضحاك {3}.</p><p>وقال عطية: (معناه: لا تعصوا في الأرض فيمسك الله المطر، ويهلك الحرث بمعاصيكم) {4}، وطى هذا معنى قوله <span class="qpc-hafs">﴿بَعْدَ إِصْلَاحِهَا﴾</span> أي: بعد إصلاح الله تعالى إياها بالمطر والخصب {5}.</p><p>وقوله تعالى: <span class="qpc-hafs">﴿وَادْعُوهُ خَوْفًا وَطَمَعًا﴾</span>، معنى الخوف {6} الانزعاج لما لا يؤمن من المضار، ومعنى الطمع {7} توقع المحبوب، قال ابن عباس: (<span class="qpc-hafs">﴿وَادْعُوهُ خَوْفًا﴾</span> من عقابه، <span class="qpc-hafs">﴿وَطَمَعًا﴾</span> في ثوابه) {8}.</p><p>وقوله تعالى: <span class="qpc-hafs">﴿إِنَّ رَحْمَتَ اللَّهِ قَرِيبٌ مِنَ الْمُحْسِنِينَ﴾</span>. قال الفراء: (رأيت العرب {9} تؤنث القريبة في النسب لا يختلفون فيها، فإذا قالوا: دارك منا قريب، أو فلانة منك قريب، في القرب والبعد ذكروا وأنثوا، وذلك أن القرب إذا لم يكن في النسب كان في معنى المكان، فكأنه في تأويل هي: في مكان قريب، فجعل القريب خلفًا من المكان، كما قال الله {10} تعالى: <span class="qpc-hafs">﴿وَمَا هِيَ مِنَ الظَّالِمِينَ بِبَعِيدٍ﴾</span> [هود: 83] وقال: <span class="qpc-hafs">﴿وَمَا يُدْرِيكَ لَعَلَّ السَّاعَةَ تَكُونُ قَرِيبًا﴾</span> [الأحزاب: 63]، ولو أنث ذلك فبُني على بعدت فهي بعيدة، وقربت فهي قريبة، كان صوابًا حسنًا. وقال عروة بن حزام {11}:</p><p>عَشِيَّةَ لا عَفْرَاءُ مِنْكَ قَرِيبَةٌ ... فَتدْنُو ولا عَفْرَاءُ مِنْكَ بَعِيدُ {12}</p><p>فمن أنَّث جمع وثنى، ومن ذكر لم يُثنِّ ولم يجمع؛ لأنه ذهب إلى تأويل المكان) {13}، وهذا الذي ذكره الفراء هو مذهب أهل الكوفة، وبه قال ابن السكيت.</p><p>أخبرني العروضي {14}، قال: أخبرني الأزهري عن المنذري {15} عن الحراني {16} عن ابن السكيت قال: (تقول العرب: هو قريب مني، وهما قريب مني، وهم قريب {17} مني، وكذلك المؤنث، توحد قريبًا وتذكره؛ لأنه وإن كان فاعلًا فهو في تأويل (هو في مكان قريب مني)، وقد يجوز قريبة وجيدة بالهاء تبنيها على قربت وبعدت) {18}.</p><p>وأما مذهب البصريين فقال الزجاج: (إنما قيل: <span class="qpc-hafs">﴿قَرِيبٌ﴾</span> لأن الرحمة والغفران والعفو في معنى واحد، وكذلك كل تأنيث ليس بحقيقي) {19}.</p><p>ونحو هذا قال الأخفش قال: الرحمة بمعنى الإنعام {20}، فلذلك ذكر.</p><p>ومثل هذا قال سعيد بن جبير: (الرحمة هاهنا: الثواب) {21}.</p><p>وأما مذهب أهل الكوفة فقال الزجاج {22}: (وهو غلط؛ كل ما قرب في مكان أو نسب فهو جار على ما يصيبه من التأنيث والتذكير) {23}. والذي قاله الفراء هو مذهب أبي عمرو بن العلاء {24}، وقول الكسائي {25} وأبي عبيدة {26}.</p><p>وقال النضر بن شميل {27}: (الرحمة مصدر، ومن حق المصادر التذكير كقوله: <span class="qpc-hafs">﴿فَمَنْ جَاءَهُ مَوْعِظَةٌ مِنْ رَبِّهِ﴾</span>) {28} [البقرة: 275]، وهذا راجع إلى قول الزجاج؛ لأنه الموعظة أريد بها الوعظ، فلذلك ذكر {29} كما قال:</p><p>إنَّ السَّمَاحَةَ والمُرُؤءَةَ ضمِّنا {30}</p><p>قيل: أراد بالسماحة السخاء، وبالمروءة الكرم {31}.</p></div>",footnotes:1:في "تنوير المقباس" 2/ 100 نحوه.|2:انظر: "تفسير الطبري" 8/ 207، والسمرقندي 1/ 547، والماوردي 2/ 231.|3:ذكره الواحدي في "الوسيط" 1/ 195، والبغوي 3/ 238، و"الخازن" 2/ 241 عن الحسن والسدي والضحاك والكلبي، وذكره الماوردي 2/ 231، عن الحسن والكلبى، وذكره ابن عطية 5/ 532، عن الضحاك.|4:ذكره الثعلبي 191 أ، والواحدي في "الوسيط" 1/ 195، والبغوي 3/ 238.|5:والآية عامة في كل فساد قل أو كثر بعد أن أصلح الله خلق الأرض على الوجه الملائم لمنافع الخلق وما جاء من تعيين نوع الفساد والإصلاح ينبغي أن يحمل على التمثيل وهو قول جمهور المحققين.</p><p>انظر: "تفسير ابن عطية" 5/ 532، والقرطبي 7/ 226، و"بدائع التفسير" 2/ 234، و"البحر" 4/ 311.|6:انظر: "العين" 4/ 312، و"تهذيب اللغة" 1/ 966، و"الصحاح" 4/ 1358، و"مقاييس اللغة" 2/ 230، و"المفردات" ص 303، و"اللسان" 2/ 1291 (خوف).|7:انظر: "العين" 2/ 27، و"تهذيب اللغة" 3/ 2218، و"الصحاح" 3/ 1254، و"مقاييس اللغة" 3/ 425، و"المفردات" ص 524، و"اللسان" 5/ 2704 (طمع).|8:"تنوير المقباس" 2/ 100، وذكره الواحدي في "الوسيط" 1/ 195، وهو بدون نسبة في عامة كتب التفسير.</p><p>انظر: الطبري 8/ 207، والسمرقندي 1/ 547، والماوردي 2/ 231، والبغوي 3/ 238، وابن الجوزي 3/ 216.|9:في (ب): (القراء)، وهو تحريف.|10:لفظ: (الله) ساقط من (ب).|11:عُروة بن حِزام بن مُهاجر العُذْرى، شاعر إسلامي أحد المتيمين الذين قتلهم الهوى، وعامة شعره في بنت عمه عفراء، توفي سنة 30 هـ. انظر: "الشعر والشعراء" ص 413، و"الأغاني" 24/ 122، و"شرح شواهد المغني" للسيوطي 1/ 415، و"الأعلام" 4/ 226.|12:الشاهد في "ديوانه" ص 5، و"معاني الفراء" 1/ 381، و"تفسير الطبري" 8/ 208، و"الأغاني" 24/ 129، و"تهذيب اللغة" 3/ 2916، و"الخصائص" 2/ 412، و"تفسير الماوردي" 2/ 232، وابن عطية 5/ 534، وابن الجوزي 3/ 216، و"اللسان" 6/ 3566 (قرب)، و"البحر المحيط" 4/ 313، و"الدر المصون" 5/ 346.|13:"معاني الفراء" 1/ 381.|14:العروضي: هو أحمد بن محمد الصفار. تقدمت ترجمته.|15:المنذري: هو محمد بن أبي جعفر الهروي. تقدمت ترجمته.|16:الحراني: هو عبد الله بن الحسن الأموي. تقدمت ترجمته.|17:في (أ): (قرايب)، وهو تحريف.|18:"تهذيب اللغة" 3/ 2916 (قرب)، وانظر: "إصلاح المنطق" ص 119.|19:"معاني الزجاج" 2/ 344.|20:في "معاني الأخفش" 2/ 300، وكذلك عند الزجاج عن الأخفش (بمعنى المطر).|21:ذكره الواحدي في "الوسيط" 1/ 195، والبغوي 3/ 238، و"الخازن" 2/ 242، وأبو حيان في "البحر" 4/ 313.|22:لفظ: (الواو) ساقط من (ب).|23:"معاني الزجاج" 2/ 345.|24:ذكره الثعلبي في "الكشف" 191 ب، والبغوي 33/ 238، وانظر: "تهذيب اللغة" 3/ 2915.|25:لم أقف عليه.|26:في (ب): (أبو عبيد)، وفي مجاز القرآن 1/ 216 قال: (هذا موضع يكون في == المؤنثة والثنتين والجميع منها بلفظ واحد ولا يدخلون فيها الهاء لأنه ليس بصفة، ولكنه ظرف لهن، وموضع والعرب تفعل ذلك في قريب وبعيد، فإذا جعلوها صفة في معنى مقتربة قالوا: هي قريبة، وهما قريبتان، وهن قريبات) اهـ.|27:ذكره الثعلبي في "الكشف" 191 ب، والواحدي في "الوسيط" 1/ 196، والرازي 14/ 137، والقرطبي 7/ 227، وأبو حيان في "البحر" 313، والسمين في "الدر" 5/ 344.|28:لفظ: (من ربه) ساقط من (أ).|29:في (ب): (ذكرا).|30:الشاهد لزياد الأعجم في "ديوانه" ص 54، و"معاني الفراء" 1/ 128، و"الشعر والشعراء" ص 280، و"إعراب النحاس" 1/ 617، و"ذيل أمالي القالي" 3/ 9، و"المدخل" للحدادي ص 168، و"تفسير الثعلبي" 191 ب، والرازي 14/ 137، وعجزه:</p><p>قَبْرًا بِمَرْوَ عَلَى الطَرِيقِ الوَاضِحِ</p><p>والشاهد قوله (ضمنًا) والقياس ضمنتا؛ لأن خبر عن مؤنث وهو السماحة والمروءة.|31:ذكر هذه الوجوه في الآية عامة أهل اللغة والتفسير. انظر: "تفسير الطبري" 8/ 208، و"إعراب النحاس" 1/ 617، و"إعراب القراءات" 1/ 187، و"تفسير السمرقندي" 1/ 547، و"الخصائص" 2/ 411 - 412، و"المشكل" 1/ 294 وقد أطال ابن القيم -رحمه الله تعالى- كما في "بدائع التفسير" 2/ 232 - 258، فذكر اثني عشر مسلكًا في الإخبار عن الرحمة وهي مؤنثة بالتاء بقوله: (قريب) وهو مذكر، وبين ما فيها من الصحيح والمقارب والسقيم، واختار (إن هذا من باب الاستغناء بأحد المذكورين عن الآخر تبعًا له، ومعنى من "معانيه"، فالأصل: إن == الله قريب من المحسنين، وإن رحمة الله قريبة من المحسنين، فاستغنى بخبر المحذوف عن خبر الوجود، وسوغ ذلك ظهور المعنى والرحمة صفة قائمة بالموصوف لا تفارقه، وقرب رحمته تبع لقربه هو تبارك وتعالى، وقربه يستلزم قرب رحمته وهما متلازمان، ففي حذف التاء التأكيد على أن ذلك يستلزم القربين قربه وقربه رحمته، والأعم لا يستلزم الأخص بخلاف قربه، فإنه لما كان أخص، استلزم الأعم هو قرب رحمته، ففي العدول عن قريبة إلى قريب من استدعاء الإحسان وترغيب النفوس فيه ما لا يتخلف بعده إلا من غلبت عليه شقاوته ولا قوة إلا بالله).
  7,57,"<div class=ar lang=ar><p>قوله تعالى: <span class="qpc-hafs">﴿وهُوَ الذي يرسل الرياح نشرًا {1} بين يدي رحمته﴾، مضى الكلام في الرياح في سورة البقرة {2} بأبلغ الاستقصاء، فأما قوله: <span class="qpc-hafs">﴿نُشْرًا﴾</span>. يقال {3} أنشر الله الريح مثل أحياها فنشرت هي أي: حييت والإنشار بمعنى: الإحياء يستعمل في الريح، وكذلك لفظ الإحياء {4}.</p><p>قال المرّار {5}:</p><p>وَهَبَّتْ لَهُ رِيحُ الجنُوبِ وأحْيَيَتْ ... لَهُ رَيْدَةُ يُحْي المِيَاةَ نَسِيمُهَا {6} ومما يدل على ذلك أن الريح قد وصفت بالموت كما وصفت بالحياة. قال:</p><p>إني لأَرْجُو أَنْ تَمُوتَ الرِّيحُ ... فَأُقْعُدُ اليَوْمَ وأَسْتَرِيحُ {7}</p><p>فقوله: <span class="qpc-hafs">﴿نُشُرًا﴾</span> جمع: نشُور مثل رَسُول ورُسُل، والنشور بمعنى: المنتشر؛ كالرَّكوب معنى: المركوب، فكأن المعنى: رياح منتشرة، فمن قرأ <span class="qpc-hafs">﴿الرِّيَاحَ﴾</span> {8} بالجمع حسن وصفها بقوله: <span class="qpc-hafs">﴿نُشُرًا﴾</span> لأنه وصف الجمع بالجمع، ومن قرأ <span class="qpc-hafs">﴿الرِّيح﴾</span> واحدة <span class="qpc-hafs">﴿نُشُرًا﴾</span> جمعًا كقراءة ابن كثير، فإنه أراد بالريح الكثرة كقولهم: كثر الدرهم والدينار، والشاء {9} والبعير، وكقوله: <span class="qpc-hafs">﴿إِنَّ الْإِنْسَانَ لَفِي خُسْرٍ﴾</span> [العصر: 2] ثم قال: <span class="qpc-hafs">﴿إِلَّا الَّذِينَ آمَنُوا﴾</span>، فلما كان المراد بالريح الجمع وصفها بالجمع، كقول عنترة:</p><p>فِيهَا اثْنَتَانِ وأَرْبَعُونَ حَلُوبَةً ... سُودًا كَخَافِيَةِ الغُرابِ الأَسْحَمِ {10} وقرأ ابن عامر: <span class="qpc-hafs">﴿نُشْرًا﴾</span> خفف الشين كما يقال: كُتْبٌ ورُسْل، وقرأ حمزة والكسائي <span class="qpc-hafs">﴿نَشْرًا﴾</span>؛ والنشر مصدر نشرت الشيء ضد طويته، ويراد بالمصدر هاهنا المفعول، والرياح كأنها كانت بانقطاعها كالمطوية فأرسلها الله تعالى منشورة بعد إنطوائها، فقوله: <span class="qpc-hafs">﴿نَشْرًا﴾</span> مصدر حال من الرياح، ويجوز أن يكون النشر هاهنا الذي هو الحياة من قولهم: أنشر الله الميت فنشر. قال الأعشى:</p><p>يَا عَجَبَا لِلْمَيِّتِ النَّاشِرِ {11}</p><p>فإذا حملته على ذلك -وهو الوجه- كان المصدر يراد به الفاعل، كما تقول: أتاني ركضًا أي: راكضًا، ويجوز أن يكون انتصاب قوله: <span class="qpc-hafs">﴿نَشْرًا﴾</span> انتصاب المصادر لا الحال من باب (صُنْعَ الله)؛ لأنه إذا قال: <span class="qpc-hafs">﴿يُرْسِلُ اَلريَاحَ﴾</span> دل هذا الكلام على نشر الريح نشرًا، وقرأ عاصم <span class="qpc-hafs">﴿بُشْرًا﴾</span> جمع بشيرًا على (بُشْر) من قوله: <span class="qpc-hafs">﴿يُرْسِلَ الرِّيَاحَ مُبَشِّرَاتٍ﴾</span> [الروم: 46] أي: تبشر بالمطر والرحمة. قال الفراء: (النُشر من الرياح الطيبة اللينة التي تنشئ السحاب) {12}. قال ابن الأنباري: (واحدها نشور، وأصل هذا من النَّشْر وهو الرائحة الطيبة) {13}. ومنه قول امرئ القيس:</p><p>............ ونَشْرَ القُطُرْ {14}</p><p>وقال أبو عبيدة: (<span class="qpc-hafs">﴿نُشُرًا﴾</span> أي: متفرقة من كل جانب) {15}.</p><p>قال أبو بكر: (هي المنتشرة الواسعة الهبوب، والنشر: التفريق، ومنه نشر الثوب، ونشر الخشبة بالمنشار، والنشر المنتشر) {16}.</p><p>وقرأ حمزة والكسائي: <span class="qpc-hafs">﴿نَشْرًا﴾</span> يجوز أن يكون من باب حذف المضاف على معنى: ذوات نشر أي: ريح طيبة {17}.</p><p>وقوله تعالى: <span class="qpc-hafs">﴿بَيْنَ يَدَيْ رَحْمَتِهِ﴾</span>، قال ابن عباس: (يريد: بين يدي المطر) {13}.</p><p>وقال الكلبي: (قدّام مطره) {19}.</p><p>وقال أبو إسحاق: (أي: بين يدي المطر الذي هو رحمته) {20}</p><p>قال أبو بكر: (اليدان تستعملهما العرب في المجاز على معنى التقدمة، يقال: تكون هذه الفتن بين يدي الساعة، يريدون قبيل {21} أن تقوم، تشبيهًا وتمثيلاً، إذ كانت يد الإنسان تتقدمانه، والرياح تتقدم المطر وتؤذن به) {22}.</p><p>وقوله تعالى: <span class="qpc-hafs">﴿حَتَّى إِذَا أَقَلَّتْ سَحَابًا ثِقَالًا﴾</span>، يقال: أقلَّ فلان الشيءَ أي {23} حَمَله، وكذلك استقَلَّه {24}، والمعنى: حتى إذا حملت هذه الرياح سحابًا ثقالًا بما فيها من الماء، قاله المفسرون {25}.</p><p>وقوله تعالى: <span class="qpc-hafs">﴿سُقْنَاهُ لِبَلَدٍ مَيِّتٍ﴾</span> أي: سقنا السحاب، والسحاب لفظه مذكر وإن كان جمع سحابة، لذلك ذكَّر الكناية، وهو من باب تمر وتمرة وجَوْز وجَوْزة {26}.</p><p><span class="qpc-hafs">﴿لِبَلَدٍ مَيِّتٍ﴾</span>. قال ابن عباس: (يريد: ليس فيه نبات) {13}. وقال الكلبي: (إلى مكان لا ينبُت) {28}.</p><p>وقال أبو بكر: (أي: سقنا السحاب لبلدِ وإلى بلدٍ محتاج إلى المطر لانقطاعها عنه) {29}. فمنهم من يجعل اللام بمعنى إلى، كما يقال: هديته للدين وإلى الدين، ومنهم من يجعله لام أجل فيقول: سقناه لأجل بلدٍ ميتٍ {30}، وأما البلد فكل موضع من الأرض عامرٍ أو غير عامر خالٍ أو مسكونٍ فهو بلد، والطائفة منه (بَلْدة)، والجميع البلاد، والفلاة تسمى: بلدة {31}؛ قال الأعشى {32}: وَبَلْدَةٍ مِثْلِ ظَهْرِ التُّرْسِ مُوحِشَةٍ ... للجِنِّ بِاللَّيْلِ في حَافَاتِهَا {33} زَجَلُ</p><p>وقوله تعالى: <span class="qpc-hafs">﴿فَأَنْزَلْنَا بِهِ الْمَاءَ﴾</span>، قال الزجاج وابن الأنباري {34}: (جائز أن يكون فأنزلنا بالبلد الماء، وجائز أن يكون فأنزلنا بالسحاب الماء؛ لأن السحاب آلة لإنزال الماء) {35}.</p><p>وقوله تعالى: <span class="qpc-hafs">﴿فَأَخْرَجْنَا بِهِ مِنْ كُلِّ الثَّمَرَاتِ﴾</span>. الظاهر أن الكناية تعود إلى الماء؛ لأن إخراج الثمرات كان بالماء، وقال الزجاج: (وجائز أن يكون فأخرجنا بالبلد من كل الثمرات؛ لأن البلد ليس يخص به هاهنا بلد دون غيره) {36}.</p><p>وقوله تعالى: <span class="qpc-hafs">﴿كَذَلِكَ نُخْرِجُ الْمَوْتَى﴾</span> أي: مثل ذلك الإخراج الذي أشرنا إليه نخرج الموتى. وقال أبو بكر: (أي: نحيي الموتى مثل ذلك الإحياء الذي وصفناه في البلد الميت، فإحياء الأموات بعد أن صاروا رفاتا في التراب كإحياء الأرض بالنبات) {37}.</p><p>وقوله تعالى: <span class="qpc-hafs">﴿لَعَلَّكُمْ تَذَكَّرُونَ﴾</span>. قال ابن عباس: (يريد: كي تتعظوا) {28}.</p><p>وقال الزجاج: (أي: لعلكم بما بينا {39} لكم تستدلون على توحيد الله عز وجل وأنه يبعث الموتى. و (لعل) ترجٍ، والله يعلم أيتذكرون أم لا، وإنما خوطب العباد على قدر علمهم وما يرجوه بعضهم من بعض) {40}، وقد مضت هذه المسألة في سورة البقرة {41}.</p></div>",footnotes:1:في (ب): ﴿بُشْرًا﴾</span>، وهي قراءة سبعية كما في "السبعة" ص 283 وستأتي.|2:انظر: "البسيط" النسخة الأزهرية 1/ 101 أ.|3:في (ب): (فيقال).|4:انظر: "العين" 6/ 251، و"المنجد" لكراع ص 339، و"الجمهرة" 2/ 734، و"تهذيب اللغة" 4/ 3571، و"الصحاح" 2/ 827، و"المجمل" 3/ 868، و"مقاييس اللغة" 5/ 430، و"المفردات" ص 805، و"اللسان" 7/ 4423 (نشر).|5:المَرَّارُ بن سعيد بن حبيب الفقْعسي، أبو حسان، شاعر أموي مكثر. انظر: "الشعر والشعراء" ص 467، و"الأغاني" 10/ 366، و"معجم المرزباني" ص 304، و"الأعلام" 7/ 199.|6:الشاهد في "الحجة" لأبي علي 4/ 35 - 36، و"تفسير ابن الجوزي" 3/ 217، و"اللسان" 3/ 1790 (ريد)، و"البحر المحيط" 4/ 316. وَرْيدَة أي: ريح لينة. انظر: "اللسان" 3/ 1790 (ريد).|7:لم أهتد إلى قائله، وهو في "الحجة" لأبي علي 4/ 36، و"تفسير ابن الجوزي" 3/ 217، و"اللسان" 7/ 4295 (موت) و7/ 4423 (نشر)، و"البحر المحيط" 4/ 317، و"الدر المصون" 5/ 348.|8:قرأ ابن كثير وحمزة والكسائي: <span class="qpc-hafs">﴿الرَّيَاحَ﴾</span> على التوحيد، وقرأ الباقون: <span class="qpc-hafs">﴿الرِّيَاحَ﴾</span> بالجمع، وقرأ عاصم <span class="qpc-hafs">﴿بُشْرًا﴾</span> بضم الباء وسكون الشين، وقرأ ابن عامر: <span class="qpc-hafs">﴿نُشْرًا﴾</span> بضم النون وسكون الشين، وقرأ حمزة والكسائي: <span class="qpc-hafs">﴿نَشْرًا﴾</span> بفتح النون، وسكون الشين، وقرأ الباقون: <span class="qpc-hafs">﴿نُشُرًا﴾</span> بضم النون والشين. انظر: "السبعة" ص 283، و"المبسوط" ص 181، و"التذكرة" 2/ 420، و"التيسير" ص 110، و"النشر" 2/ 269 - 270.|9:في (أ): (الشاة)، وأصل النص في "الحجة" لأبي علي 4/ 23 وفيه: الشاء.|10:"ديوانه" ص 17، و"الحجة" لأبي علي 4/ 33، و"الدر المصون" 5/ 350، والشاهد من معلقته المشهورة قال النحاس في "شرح المعلقات" 2/ 13 - 14: (الحلوبة المحلوبة يستعمل في الواحد والجميع على لفظ واحد، والخوافي أواخر == ريش الجناح مما يلي الظهر، والأسحم: الأسود) اهـ. وانظر: شرحه في "شرح القصائد السبع" لابن الأنباري ص 305.|11:"ديوانه" ص 93، و"مجاز القرآن" 2/ 70، و"الجمهرة" 2/ 734، و"الاشتقاق" ص 242، و"تهذيب اللغة" 4/ 3570، و"الصحاح" 2/ 828، و"الخصائص" 3/ 325، و"مقاييس اللغة" 5/ 430، و"اللسان" 7/ 4423 (نشر)، و"الدر المصون" 5/ 347 وصدره: حتَى يقول النَّاسُ مِمَّا رَأَوا. وفي "حاشية الديوان": (الناشر الذي بعث من قبره، والمعنى: وعندئذٍ يتعجب الناس مما يرون فيقولون: يا عجبا للميت الذي بعث من جديد) اهـ.|12:"معاني الفراء" 1/ 381.|13:لم أقف عليه.|14:"ديوانه" ص 69، و"المنجد" لكراع ص 339، و"تفسير الطبري" 8/ 209، و"تهذيب اللغة" 4/ 3571، و"الصحاح" 2/ 827، و"اللسان" 7/ 4423 (نشر)، والخزانة 9/ 231 وتمامه:</p><p>كَأنَّ المُدَامَ وصَوْبَ الغَمَام ... ورِدحَ الخُزَامىَ ........</p><p>وفي "حاشية الديوان": (المدام: الخمر، وصوب الغمام: ماء السحاب، والخزامى: خيري البر وهو نبت حسن الريح، ونشر القطر: ريح العود الذي يتبخر به) اهـ.|15:"مجاز القرآن" 1/ 217، ومثله قال اليزيدي في "غريب القرآن" ص 146.|16:ذكره ابن الجوزي في "زاد المسير" 3/ 218، وانظر: "معاني الأخفش" 2/ 301، و"تفسير غريب القرآن" ص 178، و"معاني الزجاج" 2/ 345، و"تفسير الطبري" 8/ 209، و"نزهة القلوب" للسجستاني ص 454، و"معاني النحاس" 3/ 44.|17:ما تقدم في توجيه القراءات هو قول أبي علي في "الحجة" 4/ 32 - 39، وانظر: "معاني القراءات" 1/ 409، و"إعراب القراءات" 1/ 186، و"الحجة" لابن خالويه ص 157، ولابن زنجلة ص 285، و"الكشف" 1/ 465.|18:لم أقف عليه.|19:"تنوير المقباس" 2/ 100، وذكره الواحدي في "الوسيط" 1/ 196، وهذا قول أكثر المفسرين. انظر: "تفسير الطبري" 8/ 210، والسمرقندي 1/ 547، والبغوي 3/ 238، وابن عطية 5/ 539.|20:"معاني الزجاج" 2/ 345، ومثله ذكر النحاس في "معانيه" 3/ 45.|21:في (ب): (قبيل أن يكون تقوم)، وهو تحريف.|22:ذكره الخازن في "تفسيره" 2/ 243، ونحوه قال الطبري في "تفسيره" 8/ 210.|23:في (ب): (إذا حمله).|24:انظر: "المفردات" ص 681، و"اللسان" 6/ 3738 (قلل).|25:انظر: "تفسير الطبري" 8/ 210، و"معاني الزجاج" 2/ 345، و"النحاس" 3/ 45، و"تفسير السمرقندي" 1/ 547.|26:أصل السَّحْب الجَرُّ، ومنه السحاب لجره الماء ولجر الريح له وانسحابه في الهواء == والجمع سحاب وسُحُب وسحائب. انظر: "تهذيب اللغة" 2/ 1637، و"الصحاح" 1/ 146، و"مقاييس اللغة" 3/ 142، و"المفردات" ص 399، و"اللسان" 4/ 1948 (سحب).|27:لم أقف عليه.|28:"تنوير المقباس" 2/ 101.|29:ذكره الواحدي في "الوسيط" 1/ 197، وابن الجوزي 3/ 219.|30:انظر: "كتاب اللامات" للزجاجي ص 144، وللهروي ص 23، وقال أبو حيان في "البحر" 4/ 317: (اللام في <span class="qpc-hafs">﴿لِبَلَدٍ﴾</span> عندي لام التبليغ كقولك قلت لك) اهـ.|31:هذا قول الليث في "تهذيب اللغة" 1/ 383.</p><p>وانظر: "العين" 8/ 42، و"المنجد" ص 143، و"الجمهرة" 1/ 301، و"الصحاح" 2/ 449، و"المجمل" 1/ 134، و"مقاييس اللغة" 1/ 298، و"المفردات" ص 142، و"اللسان" 1/ 340 (بلد).|32:الشاهد في "ديوانه" ص 146، و"تهذيب اللغة" 1/ 383، و"تفسير الرازي" 14/ 142، و"اللسان" 1/ 341 (بلد)، و"الدر المصون" 5/ 352، وهو من معلقة أعشى قيس المشهورة، وفي "حاشية الديوان": (مثل ظهر الترس: شبهها بظهر الدرع في انبساطها وإقفارها لأنها لا شيء فوق ظهرها، وحافاتها: نواحيها، والزجل: الأصوات المختلطة) اهـ.|33:في (أ): (في حافتها).|34:ذكره الواحدي في "الوسيط" 1/ 197، وابن الجوزي 3/ 219، والرازي 14/ 142، و"الخازن" 2/ 243.|35:"معاني الزجاج" 2/ 345، ومثله ذكر النحاس في "معانيه" 3/ 45، والسمرقندي 1/ 548، والظاهر عودة الضمير إلى أقرب مذكور وهو بلد أي أنزلنا في ذلك البلد الميت الماء، أفاده أبو حيان في "البحر" 4/ 317 - 318.|36:"معاني الزجاج" 2/ 345، ومثله ذكر النحاس في "معانيه" 3/ 45، والأول أظهر وهو اختيار الزجاج في "معانيه"، والسمرقندي 1/ 548، وابن عطية 5/ 540، 541، وقال السمين في "الدر" 5/ 351: (الأحسن هو العود على الماء ولا ينبغي أن يعدل عنه) اهـ.|37:ذكره الواحدي في "الوسيط" 1/ 197، وانظر: "معاني الزجاج" 2/ 346، و"بدائع التفسير" 2/ 258.|38:"تنوير المقباس" 2/ 101.|39:في (ب): (لما بينا).|40:"معاني الزجاج" 2/ 246، ونحوه قال النحاس في "معانيه" 3/ 46.|41:انظر: "البسيط" البقرة: 21.