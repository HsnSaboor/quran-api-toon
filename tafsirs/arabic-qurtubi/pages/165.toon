quran[10]{c,v,t}:
7,121," قوله تعالى: <q>﴿قَالُوا آمَنَّا بِرَبِّ الْعَالَمِينَ﴾</q>، قيل في التفسير: (إن موسى قال للسحرة: أتؤمنون بي إن غلبتكم؟ فقالوا: لنأتين اليوم بسحر لا يغلبه سحر، ولئن غلبتنا لنؤمنن بك، فلما غلبهم <q>﴿قَالُوا آمَنَّا بِرَبِّ الْعَالَمِينَ﴾</q>) {1}. ",footnotes:1:أخرجه الطبري في "تفسيره" 9/ 22، عن ابن عباس، وابن مسعود وناس من أصحاب رسول الله ﷺ.
7,122," قوله تعالى: <q>﴿رَبِّ مُوسَى وَهَارُونَ﴾</q>. إنما خصهما بالذكر بعد دخولهما في جملة العالمين؛ لأن فيه معنى الذي دعى إلى الإيمان به موسى وهارون، وقيل: خصهما بالذكر تفضيلاً وتشريفاً كقوله: <q>﴿وَمَلَائِكَتِهِ وَرُسُلِهِ وَجِبْرِيلَ وَمِيكَالَ﴾</q> [البقرة: 98]. وقيل في التفسير: (إنهم لما <q>﴿قَالُوا آمَنَّا بِرَبِّ الْعَالَمِينَ﴾</q> قال لهم فرعون: إياي يعنون. قالوا: <q>﴿رَبِّ مُوسَى وَهَارُونَ﴾</q> {1}. ",footnotes:1:ذكره السمرقندي في "تفسيره" 1/ 561، والثعلبي 6/ 6 ب، والبغوي 3/ 266.
7,123," قوله تعالى: <q>﴿قَالَ فِرْعَوْنُ آمَنْتُمْ بِهِ قَبْلَ أَنْ آذَنَ لَكُمْ﴾</q>. قال الكلبي: (يقول: صدقتم بموسى من قبل أمري إياكم) {1}. ونحو ذلك قال الفراء {2}. وفي: <q>﴿آمَنْتُمْ﴾</q> ثلاثة أوجه من القراءة {3}: إحداها: تحقيق الهمزتين وهو مذهب أهل الكوفة، وأصل <q>﴿آمَنْتُمْ﴾</q> أآمنتم على (أفعلتم) إحدى الهمزتين للإفعال، والثانية ألفان فخففت الثانية فدخلت هاهنا همزة الاستفهام واجتمعت مع همزة أفعل فحققهما الكوفيون، وقرأ أبو عمرو ونافع بهمزة بعدها ألف ممدودة تكون في التقدير ألفين، فالهمزة همزة الاستفهام، والألفان الأولى منهما الهمزة التي هي في {4} أفعلتم خففت، والثانية {5} المنقلبة عن فاء الفعل. وقرأ حفص <q>﴿أامنتم﴾</q> بلفظ الخبر من غير مد، ووجه {6} الخبر أنه يخبرهم بإيمانهم على وجه التقريع لهم {7}، والإنكار عليهم، وكذلك أيضاً وجه الاستفهام يوبخهم به وينكره عليهم {8}. وقوله تعالى: <q>﴿إِنَّ هَذَا لَمَكْرٌ مَكَرْتُمُوهُ فِي الْمَدِينَةِ﴾</q>. قال الكلبي: (لصنيع صنعتموه فيما بينكم وبين موسى في مصر قبل خروجكم إلى هذا الموضع) {9}، أي: أنكم تواطأتم على هذا الأمر لتستولوا على مصر فتخرجوا منها أهلها وتتغلبوا عليها بسحركم. وقوله تعالى: <q>﴿فَسَوْفَ تَعْلَمُونَ﴾</q>، قال ابن عباس: (يريد تهدداً {10} منه للذين آمنوا بالله) {11}. قال أهل المعاني: (معنى التهديد في هذا اللفظ: أن فيه معنى أقدمتم بالجهل على سبب الشر، <q>﴿فَسَوْفَ تَعْلَمُونَ﴾</q> ما {12} يظهر لكم مما {13} يؤدي إليه إقدامكم على ما فعلتم، وهذا أبلغ من الإفصاح به) {14}. ",footnotes:1:"تنوير المقباس" 2/ 118، وهو قول مقاتل في "تفسيره" 2/ 45، وذكره عن مقاتل الثعلبي 6/ 7 أ، والبغوي 3/ 266."معاني الفراء" 1/ 391.قرأ حفص عن عاصم: <q>﴿آمَنْتُمْ﴾</q> بهمزة واحدة غير ممدودة على لفظ الخبر، وقرأ حمزة والكسائي وأبو بكر عن عاصم: <q>﴿أءامنتم﴾</q> بهمزتين، وقرأ الباقون: <q>﴿ءَآمَنْتُمْ﴾</q> بهمزة واحدة ممدودة. انظر: "السبعة" ص290، و"المبسوط" ص 184، و"التذكرة" 2/ 423، و"التيسير" ص 112، و"النشر" 1/ 368.لفظ: (في) ساقط من (ب).في: (أ): (والثالثة)، وهو تحريف.في (ب): (ولفظ الخبر).لفظ: (لهم) ساقط من (ب).هذا قول أبي علي في "الحجة" 4/ 68 - 71. وانظر: "معاني القراءات" 1/ 419، و"إعراب القراءات" 1/ 201، و"الحجة" لابن خالويه ص 161، ولابن زنجلة ص 293، و"الكشف" 1/ 473.ذكره الواحدي في "الوسيط" 1/ 219، وابن الجوزي 3/ 243.في (ب): (يريد تهديدًا).لم أقف عليه.في (ب): (من).في (ب): (ما).انظر: "تفسير الطبري" 9/ 23.
7,124," قوله تعالى: <q>﴿لَأُقَطِّعَنَّ أَيْدِيَكُمْ﴾</q> الآية. استعمل لفظ التقطيع هاهنا لمكان الأيدي وهي جمع. وقوله تعالى: <q>﴿وَأَرْجُلَكُمْ مِنْ خِلَافٍ﴾</q>. قال عبد العزيز بن يحيى: (على مخالفة، وهو أن يقطع من كل شق طرف كاليد اليمنى مع الرجل اليسرى) {1}. قال سعيد بن جبير: (وفرعون أول من فعل ذلك) {2}. ",footnotes:1:لم أقف عليه.أخرجه ابن أبي حاتم 5/ 1537 بسند جيد، وذكره الثعلبي 7/ 6 أ، وأخرجه الطبري 9/ 23 بسند لا بأس به عن سعيد بن جبير عن ابن عباس.
7,125," قوله تعالى: <q>﴿قَالُوا إِنَّا إِلَى رَبِّنَا مُنْقَلِبُونَ﴾</q>. هذا جواب السحرة لفرعون لما توعدهم بالقطع والصلب. قال ابن عباس في هذه الآية: (يريد: راجعون إلى ربنا بالتوحيد والإخلاص) {1}. وقال غيره {2}: (راجعون إلى ثواب ربنا وجنته، ولكنه فخم بالإضافة إلى لله، وهذا يدل على أنهم صبروا على وعيده بما توقعوا من الله تعالى من عظيم الثواب). ",footnotes:1:ذكره الواحدي في "الوسيط" 1/ 220.انظر: "تفسير الطبري" 9/ 24، والسمرقندي 1/ 561.
7,126," قوله {1} تعالى: <q>﴿وَمَا تَنْقِمُ مِنَّا إِلَّا أَنْ آمَنَّا بِآيَاتِ رَبِّنَا لَمَّا جَاءَتْنَا﴾</q>. يقال: نقمتُ أنقِم إذا بالغت في كراهية الشيء، وقد مرّ عند قوله: <q>﴿قُلْ يَا أَهْلَ الْكِتَابِ هَلْ تَنْقِمُونَ مِنَّا﴾</q> [المائدة: 59]. قال {2} عطاء عن ابن عباس: (يريد: ما لنا عندك من ذنب ولا ركبنا منك مكروهاً تعذبنا عليه <q>﴿إِلَّا أَنْ آمَنَّا﴾</q> {3}. وقال الضحاك: وما تطعن علينا {4} <q>﴿إِلَّا أَنْ آمَنَّا﴾</q>، أي. إلا إيماننا <q>﴿بِآيَاتِ رَبِّنَا﴾</q>. يعنون: ما أتى به موسى من الآيات في العصا واليد، آمنوا بها أنها من عند الله لا يقدر على مثلها إلا الله تعالى {5}. قوله تعالى: <q>﴿رَبَّنَا أَفْرِغْ عَلَيْنَا صَبْرًا﴾</q>، معنى الإفراغ في اللغة: الصّب، يقال: درهم مُفْرَغ إذا كان مصبوباً في قالب ليس بمضروب، وأصله من إفراغ الإناء؛ وهو صب ما فيه أجمع حتى يخلو الإناء، وهو من الفراغ، فاستعمل في الصب على التشبيه بحال إفراغ الإناء {6}. قال مجاهد: (اصبب علينا الصبر عند الصلب والقطع حتى لا نرجع كفاراً) {7}. وقال الزجاج: (أي: أنزل علينا صبراً يشتمل علينا) {8}، وإنما ذكر لفظ الاشتمال لمعنى {9} الإفراغ وهو أنك إذا صببت شيئاً على شيء شمله وعمّه. وقوله تعالى: <q>﴿وَتَوَفَّنَا مُسْلِمِينَ﴾</q>. قال مجاهد: (مخلصين بالعبادة) {10} وقال ابن كيسان: (أي: على دين موسى) {10}. ",footnotes:1:في: (ب) (وقوله).في: (ب) (وقال).ذكره الواحدي في "الوسيط" 1/ 220، والرازي 14/ 209، وذكره الثعلبي في "الكشف" 6/ 7 أ، والبغوي 3/ 266 من قول عطاء فقط.ذكره الثعلبي في "الكشف" 6/ 7 أ، والبغوي 3/ 266.انظر: "تفسير الطبري" 9/ 24، والسمرقندي 1/ 561.انظر: "العين" 4/ 408، و"تهذيب اللغة" 3/ 2777، و"الصحاح" 4/ 1324، و"مقاييس اللغة" 4/ 493، و"المفردات" ص 632، و"اللسان" 6/ 3396 (فرغ).ذكره الواحدي في "الوسيط" 1/ 220، وابن الجوزي 3/ 243، والرازي 4/ 209."معاني الزجاج" 2/ 367، ومثله ذكر النحاس في "معانيه" 3/ 64.في (ب): (بمعنى).لم أقف عليه.لم أقف عليه.
7,127," قوله تعالى: <q>﴿وَقَالَ الْمَلَأُ مِنْ قَوْمِ فِرْعَوْنَ أَتَذَرُ مُوسَى وَقَوْمَهُ لِيُفْسِدُوا فِي الْأَرْضِ﴾</q> الآية. هذا إغراء من الملأ وتحريض لفرعون على موسى، وإنكار أن يتركه مقيماً على مخالفته. قال سعيد بن جبير: (كان فرعون قد ملئ رعباً من موسى، وكان إذا رآه بال كما يبول الحمار، ولم يعلم قوم فرعون ذلك الرعب من فرعون، فأنكروا عليه خلاف عادة الملوك في السطوة لمن خالف عليهم، وشقِّ العصّا ولم يعلموا أنه غير قادر على قهره) {1}. وقوله تعالى: <q>﴿لِيُفْسِدُوا فِي الْأَرْضِ﴾</q>. قال ابن عباس: (يريد: يعبدوا الله ويوحدوه) {2}. وقال غيره: (أراد بالإفساد في الأرض دعاؤهم الناس إلى مخالفة فرعون في عبادته وتجهيلهم إياه) {3}، وهذا راجع إلى ما قاله ابن عباس؛ لأن عبادة الله وتوحيده تتضمن مخالفة فرعون وتجهيله. وقوله تعالى: <q>﴿وَيَذَرَكَ﴾</q>. قال ابن الأنباري: (إنه ينتصب على الصرف {4} عن الأول، يراد به <q>﴿أَتَذَرُ مُوسَى وَقَوْمَهُ لِيُفْسِدُوا فِي الْأَرْضِ﴾</q> وقد ترك أن يطيعك وأن يعبد ألهتك). وهذا قول الفراء {5}، واحتج على هذا بقراءة أبيّ: (أتذر موسى وقومه ليفسدوا في الأرض وقد تركوا أن يعبدوك) {6}. قال أبو بكر: (وقال بعض النحويين: الواو نائبة عن الفاء، والتقدير: فيذرك وآلهتك) {7}، وهذا قول أبي إسحاق، قال: (نصب <q>﴿وَيَذَرَكَ﴾</q> على جواب الاستفهام بالواو، والمعنى: أيكون منك أن تذر موسى وأن يذرك موسى) {8}. قال أبو بكر: (وحمله بعض الناس على إعراب (يُفسدوا)، وفي هذا بُعدٌ؛ لأن توحيده مع جمع (يفسدوا) يدل على انقطاعه منه) {9}. وقوله تعالى: <q>﴿وَآلِهَتَكَ﴾</q>. قال أبو بكر: (كان ابن عباس ينكر قراءة العامة ويقرأ: (وإلاهتك) أي: عبادتك، ويقول: {10} إن فرعون كان يُعبد ولا يَعبد) {11}، وبه قرأ الضحاك وابن مسعود والشعبي وابن أبي إسحاق {12}. قال الزجاج: (والمعنى: ويذرك وربوبيتك فـ (إلاهتك) بمنزلة ربوبيتك) {13}. وقرأ العامة <q>﴿وَآلِهَتَكَ﴾</q> على جمع إله مثل إزار وآزرة، وقد مرّ مستقصًى شرحه في أول الكتاب {14}، وعلى هذه القراءة فقد روي عن ابن عباس أنه قال: (كان فرعون صنع لقومه أصناماً صغاراً، وأمرهم بعبادتها، وقال: أنا ربكم ورب هذه الأصنام، فذلك قوله: <q>﴿أَنَا رَبُّكُمُ الْأَعْلَى﴾</q> {15} [النازعات: 24]، ونحو ذلك قال الزجاج، فقال: (إن فرعون كان له أصنام يعبدها قومه تقرباً إليه) {16}. وقال الحسن: (كان فرعون يعبد الأصنام) {17}، فعلى هذا كان يَعبد ويُعبد. وقال السدي: (كان يعبد ما يستحسن من البقر، وكانوا إذا رأوا بقرة حسناء، أمر قومه أن يعبدوها، وعلى ذلك أخرج السامري عجلاً) {18}، ونحو هذا روي عن سليمان التيمي {19}. وقوله تعالى: <q>﴿سَنُقَتِّلُ أَبْنَاءَهُمْ وَنَسْتَحْيِي نِسَاءَهُمْ﴾</q>. قال ابن عباس: (كان فرعون قد ترك قتل أبناء بني إسرائيل، فلما أتاه موسى بالرسالة -وكان من أمره ما كان- أمر بإعادة القتل عليهم، فذلك قوله: <q>﴿سَنُقَتِّلُ أَبْنَاءَهُمْ﴾</q> {20}. قال أهل المعاني: (إنما دعي فرعون إلى قتل موسى، لكنه لم يطمع في ذلك لما رأى من قوة أمره وعلوّ شأنه، فعدل عن ذلك إلى إضعاف بني إسرائيل بقتل أبنائهم واستحياء نساءهم للمهنة والخدمة) {21}. وقوله تعالى: <q>﴿وَإِنَّا فَوْقَهُمْ قَاهِرُونَ﴾</q>، قال ابن عباس: (يريد: وإنا على ذلك قادرون) {22}. ",footnotes:1:لم أقف عليه."تنوير المقباس" 2/ 119.انظر: "تفسير الطبري" 9/ 24، 25، والسمرقندي 1/ 562، والماوردي 2/ 248.واو الصرف: هي واو المعية عند الكوفين. انظر: "معجم المصطلحات النحوية والصرفية" ص 125.انظر: "معاني الفراء" 1/ 391، وهو قول الطبري في "تفسيره" 9/ 25.ذكر القراءة أيضًا عن أبي: أبو عبيد في "فضائل القرآن" ص 127، والطبري في "تفسيره" 9/ 25، والنحاس في "إعراب القرآن" 1/ 632، وابن عطية 6/ 42، والقرطبي 7/ 262، وأبو حيان في "البحر" 4/ 367، وجاء عند الجميع إلا النحاس: (وقد تركوك أن يعبدوك).انظر: "الإيضاح" لابن الأنباري 2/ 663، وذكره الواحدي في "الوسيط" 1/ 221، وانظر: "معاني القراءات" 1/ 419 - 420."معاني الزجاج" 2/ 367، وانظر: "إعراب النحاس" 1/ 632.قال ابن الأنباري في "الإيضاح" 2/ 663: (قال اليزيدي: <q>﴿وَيَذَرَكَ﴾</q> منصوب على معنى: <q>﴿لِيُفْسِدُوا فِي الْأَرْضِ﴾</q> وليذرك وآلهتك) اهـ. وقال السمين في "الدر" 5/ 423: (في النصب وجهان: أظهرهما أنه على العطف على <q>﴿لِيُفْسِدُوا﴾</q>، والثاني: النصب على جواب الاستفهام) اهـ.أخرج الطبري 9/ 25، 26، وابن أبي حاتم 5/ 1538 من طرق جيدة عن ابن عباس أنه قرأ: <q>﴿وَيَذَرَكَ وَآلِهَتَكَ﴾</q> بكسر الألف، وقال: (إنما كان فرعون يُعْبدَ ولا يَعْبُد) == اهـ وأخرج أبو عبيد في "فضائل القرآن" ص 172، القراءة بسند جيد، وانظر: "الدر المنثور" 3/ 200.ذكره عن ابن الأنباري السمين في "الدر" 5/ 424، وانظر: "تفسير الرازي" 14/ 211.ذكرها الثعلبي في "الكشف" 6/ 7 ب، 6/ 8 أعن ابن مسعود وابن عباس وابن أبي إسحاق والضحاك والشعبي، وذكرها البغوي 3/ 267، و"الخازن" 2/ 273، عن ابن مسعود وابن عباس والشعبي والضحاك وذكرها عن ابن مسعود وابن عباس أكثرهم. انظر: "مختصر الشواذ" ص 55، و"المحتسب" 1/ 256، وابن عطية 6/ 43، وابن الجوزي 3/ 244، و"البحر" 4/ 367 وهي قراءة مجاهد كما أخرجه الطبري 9/ 26 بسند جيد.لم أقف عليه في "معانيه"، وذكره عن الزجاج ابن الجوزي في "زاد المسير" 3/ 244.انظر: "البسيط" تفسير البسملة من الفاتحة.ذكره الثعلبي في "الكشف" 6/ 7 ب، وابن الجوزي 3/ 244، وذكره الواحدي في "الوسيط" 1/ 221 من رواية الكلبي عن ابن عباس."معاني الزجاج" 2/ 367.أخرجه الطبري 9/ 25، وابن أبي حاتم 5/ 1538 من عدة طرق جيدة، وذكره الثعلبي 6/ 7 ب، والماوردي 2/ 248، والبغوي 3/ 267.أخرجه الطبري 9/ 25 بسند جيد.أخرج ابن أبي حاتم 5/ 1538 بسند جيد، وذكره النحاس في "معانيه" 3/ 65.ذكره الثعلبي في "الكشف" 6/ 8 أ، والواحدي في "الوسيط" 1/ 221، والبغوي 3/ 267.انظر: "تفسير الماوردي" 2/ 248، والرازي 14/ 211، 212.ذكره الواحدي في "الوسيط" 1/ 221.
7,128," قوله تعالى: <q>﴿قَالَ مُوسَى لِقَوْمِهِ﴾</q>، وهم الذين اتبعوه وآمنوا به. قال ابن عباس: (لما آمنت السحرة اتبع موسى ستمائة ألف من بني إسرائيل)، <q>﴿اسْتَعِينُوا بِاللَّهِ وَاصْبِرُوا﴾</q> (وذلك أنهم شكوا إلى موسى إعادة قتل أبنائهم، فقال موسى: <q>﴿اسْتَعِينُوا بِاللَّهِ وَاصْبِرُوا﴾</q> على ما يفعل بكم). قاله ابن عباس {1}. وقوله تعالى: <q>﴿إِنَّ الْأَرْضَ لِلَّهِ يُورِثُهَا مَنْ يَشَاءُ مِنْ عِبَادِهِ﴾</q>. هذا إطماع من موسى قومه في أن يورثهم الله أرض فرعون وقومه، أي: يعطيهم بعد إهلاكهم، وذلك معنى الإرث، وهو جعل الشيء للخلف بعد السلف. وقوله تعالى: <q>﴿وَالْعَاقِبَةُ لِلْمُتَّقِينَ﴾</q>. قال ابن عباس: (أي: الجنة لمن اتقى الله في الآخرة) {2}. وقال غيره: (العاقبة {3} هاهنا النصر والظفر) {4}، ومعنى العاقبة: ما تؤدي إليه البادئة {5} من خير أو شر، إلا أنه إذا قيل: العاقبة له فهو في الخير {6}. ",footnotes:1:ذكره الثعلبي في "الكشف" 6/ 8 أ، والبغوي 3/ 267 - 268، وأخرج الطبري 9/ 27 بسند ضعيف عن ابن عباس قال: (لما آمنت السحرة اتبع موسى ستمائة ألف من بني إسرائيل) اهـ."تنوير المقباس" 2/ 119، وذكره الواحدي في "الوسيط" 1/ 221.في: (ب) (وقال غيره معنى العاقبة)، وهو تحريف.هذا قول الثعلبي في "الكشف" 6/ 8 أ، والبغوي 3/ 267، وانظر: "الماوردي" 2/ 249، والظاهر من الآية مجموع الأمرين النصر والظفر والجنة.في: (ب) (التادية).انظر: "تهذيب اللغة" 3/ 2504، و"اللسان" 5/ 3022 (عقب)، وقال الراغب في "المفردات" ص 575: (العاقبة إطلاقها يختص بالثواب وبالإضافة قد تستعمل في العُقوبة) اهـ.
7,129," قوله تعالى: <q>﴿قَالُوا أُوذِينَا﴾</q>. قال ابن عباس: (أي: بالقتل الأول، <q>﴿مِنْ قَبْلِ أَنْ تَأْتِيَنَا﴾</q> بالرسالة، <q>﴿وَمِنْ بَعْدِ مَا جِئْتَنَا﴾</q> بإعادة القتل عليهم والإتعاب في العمل). <q>﴿قَالَ عَسَى رَبُّكُمْ﴾</q>، قال {1}: (وعسى من الله واجب) {2}، قال سيبويه: (عسى {3} طمع وإشفاق) {4}. قال الزجاج: (وما طمع الله عز وجل فيه فهو واجب، وهو معنى قول المفسرين: عسى من الله واجب) {5}. وقوله تعالى: <q>﴿أَنْ يُهْلِكَ عَدُوَّكُمْ﴾</q>، يعني: فرعون وقومه. <q>﴿وَيَسْتَخْلِفَكُمْ فِي الْأَرْضِ﴾</q>، قال ابن عباس: (يملككم ما كان يملك فرعون) {6}. وقوله تعالى: <q>﴿فَيَنْظُرَ كَيْفَ تَعْمَلُونَ﴾</q>. قال أبو إسحاق: (أي: يرى ذلك بوقوع ذلك منكم؛ لأن الله لا {7} يجازيهم على ما يعلمه منهم، إنما يجازيهم على ما يقع منهم) {8}، وهذه الآية تسلية من موسى لقومه بما وعدهم عن ربه من إهلاك فرعون وقومه وجعلهم بدلاً منهم ليعملوا بطاعته، ثم حقق الله ذلك، فغرق فرعون وقومه واستخلفهم في ديارهم وأموالهم. ",footnotes:1:لفظ: (قال) ساقط من (ب)."تنوير المقباس" 2/ 120، وأخرج البيهقي في "سننه" 9/ 13 بسند جيد عنه قال: (كل عسى في القرآن فهي واجبة) اهـ. وذكره السيوطي في "الإتقان" 2/ 241.في (ب): (وعسى)."الكتاب" 4/ 233."معاني الزجاج" 2/ 367، وانظر: "مجاز القرآن" 1/ 225.ذكره الواحدي في "الوسيط" 1/ 222 بلا نسبة، ونقل ابن الجوزي 3/ 246 عن ابن عباس أنه قال: (أرض مصر) اهـ.لفظ: (لا) ساقط من (ب)."معاني الزجاج" 2/ 367.
7,130," قوله تعالى: <q>﴿وَلَقَدْ أَخَذْنَا آلَ فِرْعَوْنَ بِالسِّنِينَ وَنَقْصٍ مِنَ الثَّمَرَاتِ﴾</q> الآية. السنين: جمع السنة {1}، وقد ذكرنا {2} كيف كانت السنة في الأصل والاختلاف فيها عند قوله: <q>﴿لَمْ يَتَسَنَّهْ﴾</q> [البقرة: 259]. قال أبو علي الفارسي: (السنة على معنيين؛ أحدهما: يراد بها الحول والعام، والآخر: يراد بها الجدب، وهو {3} خلاف الخصب، فمما أريد به الجدب هذه {4} الآية، وقوله ﷺ: "اللهم سنين كسني يوسف" {5}، وقول عمر -رضي الله عنه-: (إنا لا نقطع في عام السنة) {6}. أي: في عام الجدب. وقول حاتم {7}: فإنَّا نُهِينُ المالُ منْ غَيْرِ ظنَّهٍ ... ولا يَشْتَكِينا في السنينَ ضَرِيرُها أي: لا يشتكينا الفقر في المحل لأنا نسعفه ونكفيه، ولما كانت السنة يعني بها الجدب اشتقوا منها كما يشتق من الجدب فقيل: أسنتوا كما يقال: أجدبوا) {8}. قال الشاعر {9}: وَرِجالُ مَكَّةَ مُسْنِتُونَ عِجَافُ وقالوا في جمع السنة: سنون وسنين، وإنما جمعت هذا الجمع للنقصان الذي لحقها، وقد مرّ بيان هذا في هذا الكتاب {10}. قال أبو زيد: (وبعض العرب يقول: هذه سنين ورأيت سنيناً فيعرب النون) {11}. ونحو ذلك قال الفراء {12}؛ فمن ذلك قول الشاعر {13}: دَعَاني مِنْ نَجْدٍ فَإنَّ سِنِينَهُ ... لَعِبْنَ بِنَا شِيبًا وَشَيَّبْننَا مُرْدًا وقال أبو إسحاق: (السنين في كلام العرب: الجدوب، يقال: مستهم السنة، [ومعناه: جدب السنة] {14} وشدة السنة) {15}. قال عطاء عن ابن عباس في قوله: <q>﴿أَخَذْنَا آلَ فِرْعَوْنَ بِالسِّنِينَ﴾</q>، (يريد: بالجوع) {16}. وقال الفراء: (<q>﴿بِالسِّنِينَ﴾</q> بالقحط والجدوبة عاماً بعد عام) {17}. قال ابن عباس {18} وقتادة {19} والمفسرون {20}: (السنون لأهل البوادي، <q>﴿وَنَقْصٍ مِنَ الثَّمَرَاتِ﴾</q> لأهل القرى). وقال الزجاج: (إنما {21} أخذوا بالضر لأن أحوال الشدة ترق القلب وترغب فيما عند الله وفي الرجوع، ألا ترى إلى قوله: <q>﴿وَإِذَا مَسَّكُمُ الضُّرُّ فِي الْبَحْرِ ضَلَّ مَنْ تَدْعُونَ إِلَّا إِيَّاهُ﴾</q> [الإسراء: 67]، وقوله: <q>﴿وَإِذَا مَسَّهُ الشَّرُّ فَذُو دُعَاءٍ عَرِيضٍ﴾</q>) {22} [فصلت: 51]. وقوله تعالى: <q>﴿لَعَلَّهُمْ يَذَّكَّرُونَ﴾</q>، قال ابن عباس: (يريد: كي تتعظوا) {23}. وقال أهل المعاني: (في العل) من الله تعالى أن معناه: أنه عاملهم معاملة الشاك إظهاراً للعدل بعد معرفته وعلمه أنَّهم يذّكرون أم لا. كما جاء الابتلاء والاختبار من الله تعالى للعبد على هذا التقدير) {24}. ",footnotes:1:انظر: "العين" 4/ 8، و"الجمهرة" 1/ 135، و"تهذيب اللغة" 2/ 1782، و"الصحاح" 6/ 2235، و"المجمل" 2/ 474، و"مقاييس اللغة" 3/ 103، و"المفردات" ص 429، و"اللسان" 4/ 2127 (سنة).انظر: "البسيط" النسخة الأزهرية 1/ 156 أ.لفظ: (هو) ساقط من (ب).في (ب): (في هذه الآية).الحديث أخرجه البخاري في "صحيحه" كتاب الاستسقاء، باب دعاء النبي ﷺ رقم (1006)، ومسلم رقم (675) عن أبي هريرة رضي الله عنه، كتاب المساجد، باب: استحباب القنوت، وأخرجه البخاري برقم (4821) كتاب التفسير، باب: يغشى الناس في تفسير سورة الدخان، ومسلم رقم (2798) كتاب صفة الجنة والنار، باب: الدخان، عن عبد الله بن مسعود رضي الله عنه.الأثر أخرجه عبد الرزاق في "المصنف" 10/ 242، وابن أبي شيبة 5/ 516 (28577) بسند ضعيف عن عمر بن الخطاب رضي الله عنه قال: (لا يقطع في عذق، ولا في عام السنة) اهـ، وأورده الحافظ في "تلخيص الحبير" 4/ 70 وقال: (أخرجه إبراهيم بن يعقوب الجوزجاني في "جامعه" عن أحمد بن حنبل وقال: سألت أحمد عنه فقال: العذق النخلة وعام سنة عام المجاعة، فقلت لأحمد تقول به؟ قال: إي لعمري) اهـ، وذكره الألباني في "إرواء الغليل" 8/ 80 وقال: (ضعيف أخرجه ابن أبي شيبة) اهـ."ديوانه" ص62، و"البحر المحيط" 4/ 369، و"الدر المصون" 5/ 427، وفي الديوان (وما) بدل (ولا)."الحجة" لأبي علي 2/ 369 - 372.الشاهد لعبد الله بن الزِّبَعْرَى في "ديوانه" ص 53، و"الصحاح" 5/ 2058 (هشم)، والقرطبي 7/ 264، و"اللسان" 4/ 2111 (سنن)، ولمطرود بن كعب الخزاعي في "الاشتقاق" ص 13، و"تهذيب اللغة" 4/ 3764 (هشم) ولبنت هاشم بن عبد مناف في "العين" 3/ 405، و"المبهج" لابن جني ص 60، و"اللسان" 8/ 4668 (هشم) وبلا نسبة في "النوادر" لأبي زيد ص 167، و"الكامل" للمبرد 1/ 209، و"المقتضب" 2/ 311، 315، و"سر صناعة الإعراب" 535، والرازي 14/ 214، و"البحر" 4/ 369، و"الدر المصون" 5/ 427، وصدره: عَمْرُو العُلاَ هَشَمَ الثَّرِيدَ لِقَوْمِهِ وعمرو هو ابن هاشم جد النبي ﷺ سمي هاشمًا؛ لأنه هشم الخبز فجعله ثريدًا، ومسنتون: أي أصابتهم سنة وقحط وعجاف: هزل وضعف. انظر: "حاشية ديوان عبد الله بن الزبعرى" ص 52 - 54.انظر: "البسيط" النسخة الآزهرية 1/ 73 أو 156 أ"تهذيب اللغة" 2/ 1782 وزاد: (وبعضهم يجعلها نون الجمع فيقول: هذه سنون،== ورأيت سنين، وهذا هو الأصل لأن النون نون الجمع والسنة سنة القحط) اهـ."معاني الفراء" 2/ 92 وفيه: (وهي لغة كثيرة في أسد وتميم وعامر وأنشدني بعض بني عامر) ثم ذكر الشاهد.الشاهد للصمة بن عبد الله القشيري في "ديوانه" ص 60 وبلا نسبة في "مجالس ثعلب" ص 147، 266، و"الحجة" لأبي علي 2/ 374، و"التكملة" لأبي علي ص 503، و"أمالي ابن الشجري" 2/ 261، والرازي 14/ 214، و"اللسان" 7/ 4346 (نجد)، و"الدر المصون" 5/ 426، والشاهد: (فإن سنينه) حيث نصب سنين بالفتحة ولم يعاملها معاملة المذكر السالم في نصبها بالياء انظر: "الخزانة" 8/ 58.ما بين المعقوفين ساقط من (ب)."معاني الزجاج" 2/ 368 وفيه: (وشدة السنة ونقص الثمرات) اهـ."تنوير المقباس" 2/ 120 وفيه: (بالقحط والجوع عامًا بعد عام) اهـ."معاني الفراء" 1/ 392.لم أقف عليه.أخرجه الطبري 9/ 29، وابن أبي حاتم 5/ 1542 بسند جيد.انظر: "الكشف" للثعلبي 6/ 9 أ، والبغوي 3/ 268 والرازي 14/ 214.في (ب): (وإنما)."معاني الزجاج" 2/ 368.سبق تخريجه.نقل هذا القول الرازي 14/ 215، عن الواحدي، وقال الطبري 9/ 28 في تفسير الآية: (يقول: عظة لهم وتذكيرًا لهم لينزجروا عن ضلالتهم ويفزعوا إلى ربهم بالتوبة) اهـ، وانظر: "معاني النحاس" 3/ 67.
