quran[25]{c,v,t}:
26,112," <q>﴿وَمَا عِلْمِي بِمَا كَانُوا يَعْمَلُونَ﴾</q> يعني: ما كنت أعلم أعمالهم، وصنائعهم، ولم {1} أُكلف ذلك إنما كلفت أن أدعوهم {2}. وقال مقاتل: يقول: لم أكن أعلم أن الله يهديهم للإيمان من بينكم ويدعكم {3}. وهذا القول غير الأول، ومعناه: أن نوحًا قال لهم: لا أدري إيش عملوا حتى استحقوا الهداية من بينكم دونكم، كأنه يقول: لا يضرهم دناءة مكاسبهم إذ هداهم الله. والقول هو الأول؛ لقوله: ",footnotes:1:في نسخة (ب): ولا."تفسير الوسيط" 3/ 357، ولم ينسبه."تفسير مقاتل" 52 أ.
26,113," <q>﴿إِنْ حِسَابُهُمْ إِلَّا عَلَى رَبِّي﴾</q> أي: ما حسابهم فيما يعملون من صنائعهم <q>﴿إِلَّا عَلَى رَبِّي﴾</q> وليس عليَّ من حسابهم شيء <q>﴿لَوْ تَشْعُرُونَ﴾</q> لو تعلمون ذلك {1}. وجواب <q>﴿لَوْ﴾</q> محذوف على معنى: <q>﴿لَوْ تَشْعُرُونَ﴾</q> أن حسابهم على ربهم لما عبتموهم بصنائعهم. ونظير قوله: إن حسابهم إلا على ربهم، قوله في سورة: هود في قصة نوح: <q>﴿أَنَّهُمْ مُلَاقُو رَبِّهِمْ﴾</q> [هود: 29]. ",footnotes:1:"تنوير المقباس" 311. واستدل ابن قتيبة بهذه الآية على أن الحساب يكون بمعنى: الجزاء. "تأويل مشكل القرآن" 513.
26,114," وقوله: <q>﴿وَمَا أَنَا بِطَارِدِ الْمُؤْمِنِينَ (114) إِنْ أَنَا إِلَّا نَذِيرٌ مُبِينٌ﴾</q> قال مقاتل: يعني وما أنا بالذي لا أقبل الإيمان من الذين تزعمون أنهم الأرذلون عندكم {1}. قال الكلبي {2} قال الأشراف لنوح: اطردهم يا نوح ونؤمن لك! فقال: <q>﴿وَمَا أَنَا بِطَارِدِ الْمُؤْمِنِينَ﴾</q>. ",footnotes:1:"تفسير مقاتل" 52 ب.قال الكلبي، في نسخة (ج).
26,115," <q>﴿إِنْ أَنَا إِلَّا نَذِيرٌ مُبِين﴾</q> قال ابن عباس: أنذركم النار، وأبين لكم ما يقربكم من الله. قال مقاتل: ما أنا إلا رسول بين {1}. ",footnotes:1:"تفسير مقاتل" 52 ب.
26,116," <q>﴿قَالُوا لَئِنْ لَمْ تَنْتَهِ يَا نُوحُ﴾</q> [عما تقول وتسكت] {1} {لَتَكُونَنَّ مِنَ الْمَرْجُومِينَ} قال ابن عباس، ومقاتل، والكلبي: من المقتولين {2}. وقال الضحاك: من المشتومين {3}. وقال قتادة: المضروبين بالحجارة {4}. وذكرنا معاني الرجم فيما تقدم {5}. ",footnotes:1:ما بين المعقوفين، ساقط من نسخة (ج)."تفسير مقاتل" 52 ب. و"تنوير المقباس" 311. و"تفسير الثعلبي" 8/ 114 أ. ونسبه الماوردي 4/ 179، لمحمد بن الحسن."تفسير الثعلبي" 8/ 114 أ، و"تفسير الوسيط" 3/ 358. و"تفسير البغوي" 6/ 121. ونسبه الماوردي 4/ 179، للسدي."تفسير الثعلبي" 8/ 114 أ. و"تفسير الماوردي" 4/ 179.في سورة هود 91.
26,117," <q>﴿قَالَ﴾</q> نوح <q>﴿رَبِّ إِنَّ قَوْمِي كَذَّبُونِ (117) فَافْتَحْ بَيْنِي وَبَيْنَهُمْ فَتْحًا﴾</q> قال ابن عباس، والمفسرون: فاقض بيني وبينهم قضاء {1}. قال مقاتل: يعني بالعذاب {2}. <q>﴿وَنَجِّنِي وَمَنْ مَعِيَ مِنَ الْمُؤْمِنِينَ﴾</q> من ذلك العذاب {3}. ",footnotes:1:"تنوير المقباس" 311. وأخرجه بسنده عبد الرزاق 2/ 74، عن قتادة. وأخرجه عنه كذلك ابن جرير 19/ 90، وأخرجه أيضًا عن ابن زيد. وأخرجه ابن أبي حاتم 8/ 2790، عن قتادة، والسدي، وعبد الرحمن بن زيد. وفي "مجاز القرآن" 2/ 87: "أي: احكم بيني وبينهم حُكماً". و"تفسير هود الهواري" 3/ 233، وفيه: وإذا قضى الله بين النبي وقومه هلكوا. قال ابن قتيبة: "ومنه قيل للقاضي: الفتاح". "غريب القرآن" 318."تفسير مقاتل" 52 ب."تنوير المقباس" 311.
  26,118,""
26,119," <q>﴿فَأَنْجَيْنَاهُ وَمَنْ مَعَهُ فِي الْفُلْكِ الْمَشْحُونِ﴾</q> مضى الكلام في تفسير الفلك، عند قوله: <q>﴿وَالْفُلْكِ الَّتِي تَجْرِي فِي الْبَحْرِ﴾</q> [البقرة: 164]. قال أبو إسحاق في هذه السورة: <q>﴿الْفُلْك﴾</q> السفن، واحدها: فَلَك، وجمعها: فُلْك، وزعم سيبويه أنها بمنزلة أَسَد، وأُسْد، قياس فَعْل، ألا ترى أنك تقول: قُفْل وأقفال، وجَمَل وأجمال، وكذلك: أَسَد وأُسْد وآسَاد، وفَلَك، وأفلاك وفُلْك في الجمع {1}. قال أبو علي الفارسي، فيما أصلح عليه: لم نعلم أحدًا قال في واحد الفُلْك: فَلَك، ولكن الواحد: فُلْك، وكُسِّر على فُلْك {2}، وقول سيبويه: إنه بمنزلة أَسَد وأُسْد، يريد: فُعَلا كسر على فُعْل، كما كسر فَعْل عليها {3}، واجتمعا في التكسير على فعل كما اجتمعا في التكسير على أفعال؛ لأنهما يتعاقبان كثيرًا على الشيء الواحد، نحو: البُخل والبخال {4}، والبَخل، والسُقم والسَقم، والعُجم والعَجم، والعُرب والعَرب، فلما كانا على هذا جاز اجتماعهما على هذا التكسير. ونظير هذا في أن لفظ التكسير جاء على لفظ الواحد قبل أن يُكَسَّر، قولهم: ناقة هَجَّانٌّ، وإبل هَجَّانٌ {5}، ودِرعٌ دِلاص، وأدرعٌ دِلاص، وهجان في الجمع {6}، على حد ظِرافٍ، وشِرَاقٍ، وليس على حد سنان وضناك {7}. وأما <q>﴿الْمَشْحُون﴾</q> فقال الليث: الشحن مَلوُك السفينةَ وإتمامُك جَهازَها كلَّه {8}. قال ابن عباس: يريد بالمشحون الذي قد شحن وملئ {9}. وقال مجاهد: المشحون: المملوء {10}. وقال قتادة: المُحَمَّل {11}. وقال مقاتل: المُوقِر من الناس، والطير، والحيوان، كلها من كل صنف ذكر وأنثى {12}. والفلك هاهنا واحد لا جمع، لذلك قال: <q>﴿الْمَشْحُونِ﴾</q> وعلى ما قال الزجاج: الفُلْك جمع؛ وهو خطأ له هاهنا {13}؛ لأن سفينة نوح كانت واحدة {14}. ",footnotes:1:"معاني القرآن" للزجاج 4/ 95. وتبعه النحاس، في "إعراب القرآن" 3/ 186، فقال: "زعم سيبويه".قال أبو عبيدة 2/ 88: "والفلك يقع لفظه على الواحد، والجميع من السفن سواء".في كتاب أبي علي: عليه، بدل: عليها.البخال، غير موجودة في كتاب أبي علي.في نسخة (أ)، الأولى هيجان، بالياء، والباقي بدونها كما في نسخة: ب، في المواضع الثلاثة. وفي نسخة (ج): بالياء، في الموضع الأول والثاني .. وفي كتاب أبي علي، بدون الياء في المواضع كلها.هكذا في نسخة (ب)، وفي نسخة (أ)، (ج): الجميع. وفي كتاب أبي علي: "وإنما دلاص، وهجان، في الجمع".هاتان الكلمتان غير واضحتين في كتاب أبي علي. الإغفال فيما أغفله الزجاج 2/ 220 أ. وقد ذكر هذه المسألة المبرد، في "المقتضب" 2/ 205. وفي الحاشية: درع دلاص: لينة براقة، والهجان: الإبل البيضاء. قال أبو حيان 7/ 31:"الفلك، واحد وجمع، غالب استعماله جمعاً". ويبين معنى: ظراف وشراق، وسنان وضناك."تهذيب اللغة" 4/ 184 (شحن)، بنصه، وفي كتاب "العين" 3/ 95: شحنت السفينة: ملأتها فهي مشحونة. وجَهازها بالفتح، وجِهاز بالكسر لغة ليست جيدة. "تهذيب اللغة" 6/ 36 (جهز).أخرج ابن جرير 19/ 92، بسنده، من طريقين عن ابن عباس " <q>﴿الْمَشْحُونِ﴾</q> قال: يعني: المُوقَر". وأخرجه كذلك ابن أبي حاتم 8/ 2891. ولفظه عند الثعلبي 8/ 114 أ "الموقر، والمجهز". وفي سؤالات نافع بن الأزرق لابن عباس "السفينة الموقرة الممتلئة". "غريب القرآن في شعر العرب" 95، والإتقان 125. يراجع الإتقان. وأخرجه الطستي عن ابن عباس، "الدر المنثور" 6/ 311."تفسير مجاهد" 2/ 463. ولفظه عند ابن جرير 19/ 92: "المفروغ منه المملوء". وهو كذلك عند ابن أبي حاتم 8/ 2792. وذكره أبو عبيدة 2/ 88، ولم ينسبه. واقتصر عليه ابن قتيبة، في "غريب القرآن" 318.أخرجه عبد الرزاق 2/ 74. وعنه ابن جرير 19/ 92."تفسير مقاتل" 52 ب. الوقِر: الثِقل يُحمل على ظهرٍ أو رأس. يقال: جاء يحمل وِقْره. ويقال: هذه نخلة موقِرة وموقَرة وموقر. "تهذيب اللغة" 9/ 280 (وقر).في نسخة (ج): وهو خطأ لا وجه له.وفي وصف الفلك بأنه مشحون إظهار لعظيم النعمة؛ لأن سلامة المملوء جداً أغرب. "نظم الدرر" 14/ 67.
26,120," وقوله: <q>﴿ثُمَّ أَغْرَقْنَا بَعْدُ﴾</q> قال مقاتل: بعد أهل السفينة {1}. وقال غيره: بعد نجاة نوح ومن معه <q>﴿الْبَاقِينَ﴾</q> من بقي منهم ولم يركب السفينة {1}. ",footnotes:1:"تفسير مقاتل" 52 ب."تفسير مقاتل" 52 ب.
26,121," <q>﴿إِنَّ فِي ذَلِكَ﴾</q> في هلاك قوم نوح بالغرق {1} <q>﴿لَآيَةً﴾</q> لعبرة لمن بعدهم {2} <q>﴿وَمَا كَانَ أَكْثَرُهُمْ﴾</q> أكثر قوم نوح <q>﴿مُؤْمِنِينَ﴾</q> مصدقين بتوحيد الله، ولو كان أكثرهم مؤمنين لم يعذبوا في الدنيا {1}. ",footnotes:1:"تفسير مقاتل" 52 ب."تفسير مقاتل" 52 ب، وفيه زيادة:"من هذه الأمة ليحذروا مثل عقوبتهم"."تفسير مقاتل" 52 ب.
26,122," <q>﴿وَإِنَّ رَبَّكَ لَهُوَ الْعَزِيزُ﴾</q> في انتقامه منهم بالغرق {1} <q>﴿الرَّحِيمُ﴾</q> بالمؤمنين إذ أنجاهم من الغرق {2}. وفي ذكر {3} تكذيب الأمم الخالية وتعذيب الله إياهم تخويف لكفار مكة {4}. ",footnotes:1:"تفسير مقاتل" 52 ب."تفسير مقاتل" 52 ب. و"تنوير المقباس" 311.ذكر، في نسخة (ج).مختصر مما ذكره مقاتل 52 ب.
26,123," وقوله: <q>﴿كَذَّبَتْ عَادٌ الْمُرْسَلِينَ﴾</q> التأنيث بمعنى القبيلة والجماعة. ومضى الكلام في معنى جمع المرسلين في قصة نوح. والباقي [124 - 127] مفسر فيما سبق إلى قوله: "
26,124," "
  26,125,""
  26,126,""
  26,127,""
26,128," <q>﴿أَتَبْنُونَ بِكُلِّ رِيعٍ﴾</q> قال ابن السكيت: الرِّيع: المكان المرتفع، وذَكَرَ الآية. قال: وقال عُمارة: الرِّيع: الجبل {1}. وقال أبو عبيدة: الريع: الارتفاع، جمع: رِيعة {2}. ونحو هذا قال المبرد، وابن قتيبة، وأنشدوا {3} لذي الرمة فقال: طِرَاقُ الخوافي واقعٌ فوقَ رِيعةٍ ... ندى لَيله في ريشه يترقرقُ {4} وقال الكسائي، والفراء: رِيع ورَيع بالكسر والفتح، لغتان؛ الواحدة: رِيعة ورَيعة، مثل: الرِّير والرَّيْر، وهو المكان المرتفع {5}. وقال الزجاج: هي في اللغة: الموضع من الأرض المرتفع. ومن ذلك: كم رَيْعُ أرضك؟ أي: كم ارتفاع أرضك {6}. وقال ابن الأعرابي: الريع: مسيل الوادي من كل مكان مشرف، وجمعه: أرياع وريوع {7}. قال ابن قتيبة: والريع، أيضًا: الطريق {8}، وأنشد للمسَيَّب بن عَلَس {9}، وذكر ظُعُنًا، فقال: في الآلِ يخفضها ويرفعها ... رِيعٌ يلوحُ كأنه سَحْل {10} شبه الطريق بالثوب الأبيض {11}. هذا كلام أهل اللغة في تفسير الرِّيع. وأما أهل التفسير فقال الوالبي عن ابن عباس: يعني: بكل شرف {12}. وقال قتادة: بكل طريق {13}. وهو لفظ مقاتل، والكلبي، والضحاك، وابن عباس، في رواية عطية {14}، وقال في رواية عطاء: بكل موضع. وهؤلاء الذين فسروا الريع بالطريق، والموضع، أرادوا الطريق والموضع المرتفع. وروى ابن أبي نجيح، وابن جريج، عن مجاهد: <q>﴿بِكُلِّ رِيعٍ﴾</q> قال: بكل فَجٍّ {15}. قال الزجاج: والفج: الطريق المنفرج في الجبل {6}. وقال عكرمة: بكل واد {17}. وهذا موافق لقول ابن الأعرابي {18}. قوله: <q>﴿آيَةً﴾</q> قال مقاتل، والكلبي: عَلمًا {19}. وعن ابن عباس: بنيانًا علمًا {20}. <q>﴿تَعْبَثُونَ﴾</q> قال عطاء، عن ابن عباس: يريد: تبنون ما لا تسكنون {21}. فعلى هذا أنكر هودٌ عليهم بناءهم ما يستغنون عنه، ولا يسكنونه، وجعل ذلك منهم عبثًا. وقال الكلبي: <q>﴿تَعْبَثُونَ﴾</q> بمن يمر بالطريق {22}. وعلى هذا معنى الآية: تبنون بالمواضع المرتفعة كي تشرفوا على المارة والسائلة، فتسخروا منهم وتعبثوا بهم. وقال مقاتل: بل {23} كانوا إذا سافروا لا يهتدون إلا بالنجوم، فبنوا القصور الطوال على الطرق عبثًا {24}. وروي عن سعيد بن جبير، ومجاهد أنهما قالا: هذا {25} في بنيان الحَمَام {26}. وعلى هذا أنكر عليهم اتخاذهم بروجًا للحَمَام عبثًا. وهذه أوجه أربعة في معنى العبث المذكور هاهنا. وذكر بعض أهل المعاني وجهًا له؛ فقال: كانوا يبنون بالمكان المرتفع البناء العالي ليدلوا بذلك على زيادة قوتهم، وذلك عبث. ",footnotes:1:"تهذيب اللغة" 3/ 179 (راع)."مجاز القرآن" 2/ 88، وفيه: والجميع أرياع، وريعة.في نسخة (ب): وأنشدوا قول ذي الرمة فقال.أنشده أبو عبيدة، "مجاز القرآن" 2/ 88، وفيه: مشرف، بدل: واقع. وهو كذلك عند ابن جرير 19/ 92، ونسباه لذي الرمة. وأنشده ابن قتيبة، "غريب القرآن" 318، ونسبه لذي الرمة، وفيه: مشرفاً، بدل: واقع. يصف ذي الرمة نظره كنظر البازي -نوع من الطيور- ومعنى: طراق: بعضه على بعض، والخوافي: ما دون القوادم من جناح الطائر، والرَّيعة: المكان المرتفع، ويترقق: يجيء ويذهب. "ديوان ذي الرمة" 175."معاني القرآن" للفراء2/ 281، ولفظه: "رِيع ورَيع، لغتان مثل: الريرِ، والرار، وهو: المخ الرديء". الرار، هكذا وردت. وما نقله عنه الأزهري، في "التهذيب" 3/ 180، موافق لما عند الواحدي. ولم ينسب الأزهري هذا القول للكسائي."معاني القرآن" للزجاج 4/ 96."تهذيب اللغة" 3/ 180 (راع).نسبه الماوردي 4/ 180، للسدي.راجع ترجمته في "جمهرة أشعار العرب" 111، و"الخزانة" 3/ 240، والأعلام 7/ 225.أنشده ابن قتيبة، "غريب القرآن" 318، وأنشده الماوردي 4/ 180، ثم قال: "السحل: الثوب الأبيض، شبه الطريق به". وأنشده الزمخشري 3/ 316، منسوبًا للمسيب. وهو كذلك في "لسان العرب" 11/ 328 (سحل). والألَلةُ: الهودج الصغير. "لسان العرب" 11/ 27 (ألل)."غريب القرآن" لابن قتيبة 318.أخرجه ابن جرير 19/ 94، وابن أبي حاتم 9/ 2793. من طريق علي بن أبي طلحة. وأخرجه ابن جرير أيضًا عن مجاهد. واقتصر عليه في الوجيز 2/ 793، ولم ينسبه.أخرجه بسنده، عبد الرزاق 2/ 74، وابن جرير 19/ 94. وابن أبي حاتم 9/ 2793.نسبه لهؤلاء الثعلبي 8/ 114 ب. وأخرجه ابن جرير 19/ 94، عن ابن عباس، والضحاك. وهو في "تفسير مقاتل" 52 ب. و"تنوير المقباس" 311. وذكر الماوردي 4/ 180، عن الكلبي، أنه فسر الريع بالسوق."تفسير مجاهد" 2/ 463، من طريق ابن أبي نجيح. وهو كذلك عند ابن أبي حاتم 9/ 2793. وأخرجه ابن جرير 19/ 94، عنه من طريق ابن جريج، وابن أبي نجيح."معاني القرآن" للزجاج 4/ 96."تفسير الثعلبي" 8/ 114 ب.الذي سبق ذكره، ولفطه: مسيل الوادي .."تفسير مقاتل" 52 ب. و"تنوير المقباس" 311، ولفظه: بكل طريق علامة. و"تفسير هود الهواري" 3/ 234، ولم ينسبه. وأخرجه ابن جرير 19/ 94، عن ابن عباس.اقتصر عليه في "تفسير الوسيط" 3/ 358، ولم ينسبه. أخرج ابن جرير 19/ 95، وابن أبي حاتم 9/ 2794، عن مجاهد: <q>﴿ءَايَةٍ﴾</q> بنيان."تفسير الوسيط" 3/ 358. وزاد المسير 6/ 134. وذكره السمرقندي، في "تفسيره" 2/ 479، وصدَّره بقوله: وروي عن ابن عباس."تنوير المقباس" 311، مختصرًا.بل، في نسخة (أ)، (ب)."تفسير مقاتل" 52 ب.هذا، في نسخة (ج).واقتصر على هذا القول في "الوجيز" 2/ 793. وأخرج هذا القول عن مجاهد، ابن جرير 19/ 95، وابن أبي حاتم 9/ 2794. وذكره الماوردي 4/ 181، عن السدي. وذكره عنهما البغوي 6/ 122. وابن الجوزي، في زاد المسير 6/ 13.
26,129," قوله تعالى: <q>﴿وَتَتَّخِذُونَ مَصَانِعَ لَعَلَّكُمْ تَخْلُدُونَ﴾</q> قال الليث: المصنعة شبه صهريج عميق يُتخذ للماء، والجمع {1} المصانع، والمصانع التي يتخذها الناس من الأبنية والآبار. قال لبيد: وما تَبْلى النجومُ الطوالعُ ... وتبلى الديارُ بعدنا والمصانعُ {2} وقال أبو عبيدة: كل بناء مَصْنَعة {3}. قال الأزهري: وقال بعضهم: هي أحباس تُتَّخذ للماء، كالزلَف، واحدها: مَصْنَعة، ومَصْنَع يحتفرها الناس فيملؤها ماءُ السماء فيشربونها. ويقال للقصور أيضًا: مصانع {4}. قال ابن عباس: هي الأبنية {5}. وقال مجاهد: قصورًا مشيدة، وبنيانًا مخلدًا {6}. وقال الكلبي: مصانع: منازل {7}. وقال مقاتل: يعني القصور {8}. وذكر قتادة القولين؛ أحدهما: القصور، والحصون. والثاني: مآخذ للماء {9}. وقال سفيان: المصانع التي يكون فيها الماء {10}. وقوله: <q>﴿لَعَلَّكُمْ تَخْلُدُونَ﴾</q> قال ابن عباس: يريد كي تخلدوا {11}. وهي اختيار الفراء والزجاج، وابن قتيبة؛ [قال الفراء: كيما يخلدوا {12}. وقال الزجاج: ومعنى <q>﴿لَعَلَّكُمْ تَخْلُدُونَ﴾</q> أي: كي تخلدون، أي: وتتخذون مباني للخلود {13}. وقال ابن قتيبة] {14}: وكأنهم كانوا يستوثقون من البناء، والحصون، ويذهبون إلى أنها تحصنهم من قدر الله {15}. وقال ابن عباس وقتادة ومقاتل: <q>﴿لَعَلَّكُمْ تَخْلُدُونَ﴾</q> كأنكم تخلدون {16} في الدنيا لا تموتون {17}. وهو قول الكلبي، وأكثر المفسرين؛ قالوا: يقول: كأنهم يخلدون {18}. و (لعل)، تأتي في الكلام بمعنى كأن؛ قال يونس في قوله: <q>﴿فَلَعَلَّكَ بَاخِعٌ نَفْسَكَ﴾</q> [الكهف: 6] معناه: كأنك فاعلٌ ذلك إن لم يؤمنوا {19}. والمعنى على هذا: أنهم كانوا قد جاوزوا في اتخاذ المصانع إلى الإسراف كأنهم يخلدون فيها فلا يموتون. قال ابن الأنباري: وتكون: (لعل) بمعنى الاستفهام؛ كقولك: لعلك تشتمني، معناه: هل تشتمني {20}. وهذا مذهب ابن زيد في هذه الآية؛ قال: (لعل) {21} استفهام يعني: فهل تخلدون حين تبنون هذه الأبنية {22}. ويجوز أن يكون معنى (لعل) هاهنا: الترجي للخلود، وكأنهم كانوا يرجون خلودهم في الدنيا لطول أعمارهم فاتخذوا الأبنية الشديدة {23}. ",footnotes:1:في نسخة (أ)، الجميع. وفي كتاب "العين" 1/ 305 (صنع): وتجمع المصانع.كتاب "العين" 1/ 305 (صنع)، ولم أجد قول الليث في "تهذيب اللغة" 2/ 37 (صنع)، وأما البيت فقد ذكره الأزهري منسوبًا للبيد. وهو مطلع قصيدة يرثي بها أخاه: أربد، وهي في الديوان 88، بلفظ: بلينا وما تبلى النجوم الطوالع ... وتبقى الجبال بعدنا والمصانع"مجاز القرآن" 2/ 88."تهذيب اللغة" 2/ 37 (صنع).قال ابن قتيبة: "المصانع: الباء، واحدها مصنعة". "غريب القرآن" 319."تفسير مجاهد" 2/ 463. وأخرجه ابن جرير 19/ 95، وابن أبي حاتم 9/ 2794. وأخرجه عبد الرزاق 2/ 75، بلفظ: قصور، وحصون."تنوير المقباس" 311. وذكر الهواري 3/ 234، عن الكلبي، أن المراد: القصور. وذكر البغوي 6/ 123، عنه: الحصون."تفسير مقاتل" 53 أ، وفيه: "يعني: القصور ليُذكروا بها، هذا منزل بني فلان، وبني فلان". واقتصر في الوجيز 2/ 793، على أن المراد بالمصانع: المباني والقصور.أخرج القول الثاني، عبد الرزاق 2/ 74. وابن جرير 19/ 95، وابن أبي حاتم 9/ 2794.قال ابن جرير 19/ 95: "والصواب من القول في ذلك أن يقال: إن المصانع جمع مصنعَةٍ، والعرب تسمي كل بناءٍ مصنعةً، وجائز أن يكون ذلك البناء كان قصوراً، وحصوناً مشيدة، وجائز أن يكون كان مآخذ للماء، ولا خبر يقطع العذر بأي ذلك كان، ولا هو مما يدرك من جهة العقل، فالصواب أن يقال فيه ما قال الله: إنهم كانوا يتخذون مصانع".ذكره عنه الثعلبي 8/ 114 ب. وابن الجوزي، "زاد المسير" 6/ 136."معاني القرآن" للفراء 2/ 281. وذكره ابن جرير 19/ 96، بقوله: "وكان بعض أهل العربية يزعم أن لعلكم في هذا الموضع بمعنى: كيما". ولم يسمه، ولم يعلق عليه."معاني القرآن" للزجاج 4/ 96، وفيه: ومعنى <q>﴿لَعَلَّكُمْ تَخْلُدُونَ﴾</q> أي: لأن تخلدوا.ما بين المعقوفين، ساقط من نسخة (أ)، (ب)."غريب القرآن" لابن قتيبة 319.كأنكم تخلدون، في نسخة (ج). ذكر البخاري، عن ابن عباس: <q>﴿لَعَلَّكُمْ تَخْلُدُونَ﴾</q> كأنكم. الفتح 8/ 496. وهو كذلك في "تنوير المقباس" 311. ووصله ابن جرير== 19/ 96، وابن أبي حاتم 9/ 2795، من طريق علي بن أبي طلبة. وأخرجه ابن جرير، عن قتادة أيضًا."تفسير مقاتل" 53 أ."تنوير المقباس" 311.ذكره عن يونس، الأزهري، "تهذيب اللغة" 1/ 106 (لعل).ذكره عن ابن الأنباري، الأزهري، "تهذيب اللغة" 1/ 106 (لعل).في نسخة (أ): لعلك.أخرجه ابن جرير 19/ 96، وابن أبي حاتم 9/ 2795. وذكره الثعلبي 8/ 114 ب.كون لعل للترجي ذكره الأزهري عن ابن الأنباري؛ بلفظ: "لعل يكون ترجياً، ويكون بمعنى: كي". "تهذيب اللغة" 1/ 106 (لعل).
26,130," قوله تعالى: <q>﴿وَإِذَا بَطَشْتُمْ بَطَشْتُمْ جَبَّارِينَ﴾</q> قال المفسرون: بطشتم بالسيف، والسوط {1}. قال ابن عباس: يريد الضرب بالسياط، والقتل بالسيف بغير حق {2}. وقال مقاتل: يقولون: إذا أخذتم قتلتم بغير حق {3}. وقال ابن مسلم، يقول: إذا ضربتم ضربتم بالسياط، ضرب الجبارين، وإذا عاقبتم قتلتم {4}. قال أبو إسحاق: وإنما أنكر ذلك عليهم لأنه ظلم فأما في الحق فالبطش بالسوط {5} والسيف جائز {6}. ومعنى الجبار هاهنا: القَتَّال بغير حق. وهو قول المفسرين {7}. ",footnotes:1:"تفسير ابن جرير" 19/ 96. قال الكلبي: تقتلون على الغضب، وقال غيره: == <q>﴿بَطَشْتُمْ جَبَّارِين﴾</q> بالسوط. "معاني القرآن" للفراء 2/ 281، ولم يسم أحداً. وأخرج ابن أبي حاتم 9/ 2795، عن مجاهد، قال: ضرب السياط. ونحوه عند السمرقندي 2/ 479، ولم ينسبه. قال الزجاج 4/ 96: "جاء في التفسير أن بطشهم كان بالسوط، والسيف".أخرج ابن جرير 19/ 96، عن ابن جريج: "قال: القتل بالسيف والسياط"."تفسير مقاتل" 53 أ."غريب القرآن" لابن قتيبة 319.في نسخة (ج): بالموت."معاني القرآن" للزجاج 4/ 96. و"زاد المسير" 6/ 136."تنوير المقباس" 311. وفي "تفسير مقاتل" 53 أ: "الجبار من يقتل بغير حق". وذكره السمرقندي 2/ 479، ولم ينسبه. وقسم ابن الأنباري الجبار إلى ستة أقسام، هذا أحدها. الزاهر في معاني كلمات الناس 1/ 81.
26,131," "
26,132," قوله تعالى: <q>﴿وَاتَّقُوا الَّذِي أَمَدَّكُمْ بِمَا تَعْلَمُونَ﴾</q> أي: أعطاكم ما تعلمون من الخير {1}. قال مقاتل: ثم أخبر بالذي أعطاهم فقال {1}: ",footnotes:1:"تفسير مقاتل" 53 أ."تفسير مقاتل" 53 أ.
26,133," <q>﴿أَمَدَّكُمْ بِأَنْعَامٍ﴾</q> إلي قوله: <q>﴿إِنِّي أَخَافُ عَلَيْكُم﴾</q> قال ابن عباس: يريد إن عصيتموني <q>﴿عَذَابَ يَوْمٍ عَظِيم﴾</q> يريد الذي أهلكوا به {1}. ونحو هذا قال مقاتل: يعني في الدنيا {2}. وقال الكلبي: يعني عذاب النار {3}. ",footnotes:1:"تفسير الوسيط" 3/ 359."تفسير مقاتل" 53 أ. وتعظيم اليوم أبلغ من تعظيم العذاب. نظم الدرر 14/ 71."تنوير المقباس" 311. وفي نسخة (ب): قال مقاتل الكلبي، وهو خطأ.
  26,134,""
  26,135,""
26,136," <q>﴿قَالُوا سَوَاءٌ عَلَيْنَا أَوَعَظْتَ أَمْ لَمْ تَكُنْ مِنَ الْوَاعِظِينَ﴾</q> قال مقاتل: وعظت بالعذاب أم تركت {1}. وقال الكلبي: نهيتنا أم لم تكن من الناهين لنا {2}. ",footnotes:1:"تفسير مقاتل" 53 أ."تفسير الوسيط" 3/ 359. و"تنوير المقباس" 311. و"تفسير البغوي" 6/ 123.
