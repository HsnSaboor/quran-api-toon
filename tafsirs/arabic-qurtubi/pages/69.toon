quran[5]{c,v,t}:
  3,149,"<div class=ar lang=ar><p>قوله تعالى: <span class="qpc-hafs">﴿إِنْ تُطِيعُوا الَّذِينَ كَفَرُوا﴾</span> يعني: اليهود؛ في قول ابن عباس {1}، والأكثرين.</p><p>وقال السُّدِّي {2}: يعني: أبا سفيان، وأصحابه.</p><p>وقال علي {3}: يعني: المنافقين؛ في قولهم للمؤمنين عند الهزيمة: ارجِعُوا إلى دِينِ آبائكم.</p><p>وقوله تعالى: <span class="qpc-hafs">﴿يَرُدُّوكُمْ عَلَى أَعْقَابِكُمْ﴾</span> أي: يُرْجعوكم إلى أَوَّلِ أمْرِكم؛ الشركِ بالله {4}.</p></div>",footnotes:1:لم أقف على مصدر قوله. وقد ورد عن ابن جريج: أنهم اليهود والنصارى، وممن قال بذلك: الطبري، والثعلبي.</p><p>انظر: "تفسير الطبري" 4/ 123، و"تفسير ابن أبي حاتم" 3/ 785، و"تفسير الثعلبي" 3/ 130 ب.قوله في: "تفسير الطبري" 4/ 123، و"تفسير ابن أبي حاتم" 3/ 784.قوله في: "تفسير الثعلبي" 3/ 130ب، و"زاد المسير" 1/ 474، و"تفسير القرطبي" 4/ 232.</p><p>وبه قال مقاتل في "تفسيره" 1/ 306، وأبو الليث في "بحر العلوم" 1/ 307.انظر: "بحر العلوم" 1/ 307، و"زاد المسير" 1/ 474، و"تفسير القرطبي" 4/ 232.
  3,150,"<div class=ar lang=ar><p>وقوله تعالى: <span class="qpc-hafs">﴿بَلِ اللَّهُ مَوْلَاكُمْ﴾</span> أي: ناصِرُكُم ومُعِينُكم. والمعني في هذه الآية: يقول: أنا مولاكم؛ فاسْتَغْنُوا عن مُوَالاةِ الكفَّار، وناصِرُكُمْ؛ فلا تَسْتَنْصِرُوهم.</p></div>"
  3,151,"<div class=ar lang=ar><p>[و] {1} قوله تعالى: <span class="qpc-hafs">﴿سَنُلْقِي فِي قُلُوبِ الَّذِينَ كَفَرُوا الرُّعْبَ﴾</span>.</p><p>قال المفسرون: هذا وَعْدٌ مِنَ الله تعالى للمؤمنين، بِخذلان أعدائِهم بالرُّعْب {2}.</p><p>وقال السُّدِّي {3}: لَمَّا انصرَفَ أبو سفيان وأصحابه مِن أُحُد إلى مَكَّةَ، هَمُّوا بالرجوع لاستئصال المسلمين، فألقى اللهُ في قلوبهم الرُّعْبَ، فَمَضوا ولم يرجعوا.</p><p>و (الإلقاء) {4}: أصلُهُ في الأعيان؛ كقوله: <span class="qpc-hafs">﴿وَأَلقَى اَلأَلوَاحَ﴾</span> [الأعراف: 150]، <span class="qpc-hafs">﴿فَأَلْقَوْا حِبَالَهُمْ وَعِصِيَّهُمْ﴾</span> [الشعراء: 44]، <span class="qpc-hafs">﴿إِذْ يُلْقُونَ﴾</span> [آل عمران: 44].</p><p>ويُسْتَعْمَلُ في غير الأعيان؛ تَوَسُّعًا؛ كقوله: <span class="qpc-hafs">﴿وَأَلْقَيْتُ عَلَيْكَ مَحَبَّةً مِنِّي﴾</span> [طه: 39]، ويقال: ألقَى عليه مَسْئلةً).</p><p>ومِثْلُ (الإلقاء) -في أنه يُسْتَعْمَلُ في الأعيان حقيقةً، وفي غير الأعيان تَوَسُّعًا-: (القَذْفُ)، و (الرَّجْمُ)، و (الرَّمْيُ)؛ يقال: (رَمَاهُ بالزِّنَا)؛ قال الله -عز وجل-: <span class="qpc-hafs">﴿وَالَّذِينَ يَرْمُونَ أَزْوَاجَهُمْ﴾</span> [النور: 6] أي: بالزِّنَا. وهذا اتِّسَاعٌ؛ لأن هذا ليس بِعَيْنٍ، وكذلك: (القَذْفُ).</p><p>قال الشاعر:</p><p>قَذَفُوا سَيِّدَهُم في وَرْطَةٍ ... قَذْفَكَ المَقْلَةَ وَسْطَ المُعْتَرَكْ {5} فالأوَّل: على الاتِّسَاع، والثاني: على الأصل؛ ألا تَرَى أنَّ المَقلَةَ تُلقَى للتَّصَافُنِ {6}.</p><p>وقوله تعالى: <span class="qpc-hafs">﴿الرُّعْبَ﴾</span> يُقرأ {7} بالتَّثْقِيلِ، والتخفيف {8}، وهما لُغَتَانِ، كـ (الطُّنْبِ {9} والطُّنُبِ)، و (العُنْقِ والعُنُقِ)، ومثله كثير {10}.</p><p>والرُّعْبُ، بمعنى: الرَّوْع {11}. يقال: (رَعَّبْتُهُ {12} رَعْبًا، وَرُعْبًا) {13} -لغتان-، فهو (مَرْعُوبٌ)، وَ (رَعِيبٌ) {14}. ويَجوز أنْ يكون (الرَّعْبُ) {15} مصدرًا، و (الرُّعْبُ) اسم منه {16}. وهو: الخوف الذي يحصل [في القلب.</p><p>(رَعَبْتُ] {17} الشيءَ، أَرْعَبُهُ رَعْبًا). و (سَيْلٌ راعِبٌ): يملأ الأوديةَ والأنْهَارَ {18}. ثم قالوا: (رَعَبْتُهُ فارْتَعَبَ)؛ أي: أفْزَعْتُهُ فَفَزعَ؛ كأنك قلت: ملأتُ قَلْبَهُ فَزَعًا. ومعنى الآية: يملأ قلوبَهُم فَزَعًا.</p><p>وقوله تعالى: <span class="qpc-hafs">﴿بِمَا أَشْرَكُوا بِاللَّهِ﴾</span> (ما) ليست بموصولة؛ لأنها للمصدر؛ أي: بإشراكهم بالله.</p><p>والباء في <span class="qpc-hafs">﴿بِاللَّهِ﴾</span>، مِنْ صِلَةِ معنى الإشراك، لا لَفْظه؛ لأن لفظَ الإشراك لا يقتضي الباء.</p><p>قال الأزهري {19}: إنَّمَا دَخَلَتْ البَاءُ في قوله: <span class="qpc-hafs">﴿لَا تُشرِك بِاَللَّهِ﴾</span> [لقمان:13]؛ لأن معناه: لا تَعْدِلْ به غَيْرَه، فتجعله شريكًا له، وذلك {20} قوله -تعالى-: <span class="qpc-hafs">﴿بِمَا أَشْرَكُوا بِاللَّهِ﴾</span>؛ أي: بِمَا عَدَلُوا باللهِ، ومَنْ عَدَلَ بالله شيئًا مِنْ خَلْقِهِ، فهو كافرٌ {21}.</p><p>وقوله تعالى: <span class="qpc-hafs">﴿مَا لَمْ يُنَزِّلْ بِهِ سُلْطَانًا﴾</span>.</p><p>أي: حُجَّةً، وَبَيَانًا. و (السُّلْطَانُ)؛ معناه: الحُجَّةُ، في قول أكثر المفسِّرينَ، وأهلِ اللغة {22}.</p><p>قال الزَّجَّاجُ {23}: واشتقاق (السُّلْطانِ) مِنَ (السَّلِيط)، وهو: ما يُضَاءُ به {24} السِّرَاجُ {25}. وقيل {26} للأمراء: سلاطين؛ لأنهم الذين يُقامُ {27} بهم الحُجَجُ، والحُقُوقُ.</p><p>وقال في موضع آخر {28}: السُّلْطانُ -في اللغة-: الحُجَّةُ. وإنَّمَا قيل للخليفة والأمير: (سُلْطان)؛ لأن معناه: أنه ذو الحُجَّةِ. والعَرَبُ تُؤنِّثُ (السلطان) وتُذَكِّرُ {29}؛ فتقول: (قَضَتْ {30} بِهِ عَلَيْكَ السُّلْطَانُ {31})، و (أمَرَتْكَ السُّلْطَانُ)؛ أي: قَضَتْ بِهِ عليك الحُجَّةُ، وَقَضَتْ به عليك حُجَّةُ الوَالِي.</p><p>ومَنْ قال: (قَضَى به عليك السُّلطانُ)؛ ذَهَبَ إلى معنى: (صاحبُ السُّلطانِ)؛ أي: صاحب الحُجَّةِ. وجائزٌ أنْ يذهب بـ (السُّلطان) إلى معنى: الاحتجاج والبرهان.</p><p>قال ابن السِّكِّيت {32}: السُّلْطان: مؤنَّثَةٌ {33}؛ يُقَال: (قَضَت {30} به عليهم {35} السُّلْطانُ)، وقد (آمَنَتْهُ {36} السُّلْطَانُ).</p><p>قال الأزهريُّ {37}: ورُبمَا ذُكِّرَ (السُّلْطانُ)، لأن لفظه {38} مُذَكَّرٌ؛ قال الله تعالى: <span class="qpc-hafs">﴿وَسُلْطَانٍ مُبِينٍ﴾</span> {39}.</p><p>وقال اللَّيْثُ {40}: السُّلْطان: القُدْرَةُ. يقال: (جعلت لِفُلانٍ سُلْطانا على كذا). والنُّونُ فيه زيادة؛ لأن أصل بِنَائِهِ {41} مِنَ (التَّسْلِيط). وعلى هذا: (سُلْطان المَلِكِ): قُوَّتُهُ وقُدْرَتُهُ.</p><p>والسُّلْطانُ: البُرْهان، لِقُوَّتِهِ على دفع الباطل. والتَّسْلِيطُ على الشيء: التَّقْوِية عليه.</p><p>وقال ابن دُرَيد {42}: سلْطان كلِّ شيء: حِدَّتُه. مِن {43} اللِّسَان السَّلِيط الحدِيد. و (السَّلاَطَةُ)، بمعنى: الحِدَّة، قد جَاءَ، ومنه قول الشاعر -يَصِفُ نَصْلًا {44} مُحَدَّدَة {45} -:</p><p>سلاَطٌ حِدَادٌ أَرْهَقَتْهَا المَوَاقِعُ {46}</p><p>هذا كلام أهل اللغة في معنى (السلطان) واشتقاقه.</p><p>قال أهل التفسير: لم [يُنْزل] {47} اللهُ حُجَّةً ولا بَيَانًا في عِبَادَةِ غَيْرِهِ، والإشْرَاكِ به؛ فهم يُشْرِكون بالله الأوثانَ مِنْ غيْرِ حُجَّةً ولا بُرْهان {48}.</p><p>وقوله تعالى: <span class="qpc-hafs">﴿وَمَأْوَاهُمُ النَّارُ﴾</span>. أي مرجعهم ومصيرهم.</p><p><span class="qpc-hafs">﴿وَبِئْسَ مَثْوَى الظَّالِمِينَ﴾</span> المَثْوَى: المكان الذي {49} يُقِيم به؛ مِن قولهم: (ثَوَى، يَثْوِي، ثَوَاءً) {50}.</p><p>ويقال للمقتول: (ثَوَى) {51}؛ لإقامته حيث قُتِل. وجَمْعُ الـ (مَثْوَى) {52}: مَثَاوِي {53}.</p></div>",footnotes:1:زيادة من (ب).انظر: "تفسير الثعلبي" 7/ 279.قوله، في: "تفسير الطبري" 4/ 124، و"تفسير الثعلبي" 3/ 130 ب، و"زاد المسير" 1/ 474.من قوله: (والإلقاء ..) إلى (.. والعنق): نقله -بتصرف واختصار- عن "الحجة" للفارسي 3/ 85 - 88البيت ليزيد بن طُعْمَة الخَطْمِيِّ. وقد ورد منسوبًا له في: كتاب "المعاني الكبير" 1/ 309، و"تهذيب اللغة" 4/ 3430 (مقل)، و"اللسان" 8/ 4813 (ورط)، 7/ 4245 (مقل).</p><p>وورد غير منسوب في: "مجالس ثعلب" 2/ 542، و"الحجة" للفارسي 3/ 87. وقد ورد في "المعاني الكبير" (قذفوا جارهم في هُوَّةٍ ..). == والوَرْطَةُ: الهَلَكَةُ، أو كلُّ غامض. وأصلها: الأرض التي لا طريق فيها. و (أوْرَطَهُ)، وَ (وَرَّطَهُ): أوقعه فيما لا خلاص له منه.</p><p>والمَقْلَةُ: هى حصاة القَسْمِ، التي توضع في الإناء، ويصب فيه الماء حتى يغمرها، فيعرف بها قَدْرُ ما يسقى كلُّ واحد؛ وذلك إذا قل الماء، وكانوا في سفر. وفي "مجالس ثعلب": 2/ 542: أنها الحجر الذي يُلقى في البئر، يُقدر به الماء انظر: "اللسان" 8/ 4812 (ورط)، 7/ 4245 (مقل).يقال: (تَصَافَنَ القومُ، تَصَافُنًا): إذا اقتسموا الماء بينهم على طريقة إلقاء المَقْلَةِ في الإناء. وذلك عند قلة الماء. كما سبق بيانه في الهامش السابق. انظر: "اللسان" 13/ 249 (صفن).في (ج): (يقرى).قرأ ابن كثير، ونافع، وعاصم، وأبو عمرو، وحمزة: (الرُّعْبَ) مخففة؛ أي: ساكنة العين.</p><p>وقرأ ابن عامر، والكسائي: (الرُّعُبَ) بالتثقيل؛ أي: مضمومة العين.</p><p>انظر: كتاب "السبعة" 217، و"الحجة" للفارسي 3/ 85، و"حجة القراءات" لابن زنجلة 176.في (أ): كالطِّنْبِ. وهى خطأ، وفي (ب): مهملة من غير شكل. والصواب ما أثبته. الطُّنْب: الحبلَ الذي يُشَدُّ به الخِبَاء والسُّرَادق. أو هو -أيضا-: عِرْق الشجر، وعَصَبُ الجَسَد، وَسَيْرٌ يُوصَلُ بِوَتَرِ القَوْسِ، ثم يدار على مَحزِّهَا الذي تقع فيه حلقة الوَتَر. ويُسمَّى -كذلك-: (الإطنابة). وجمع الطُّنْب: (أطْنَابٌ)، و (طِنَبَةٌ).</p><p>انظر: (طنب) في "الصحاح" 1/ 172، و"اللسان" 5/ 2708، و"التاج" 2/ 186 - 188.انظر: "أدب الكاتب" 536 - 537الرَّوْع: الفزع. يقال: (رُعْتُه، أرُوعُهُ، رَوْعا). انظر: "إصلاح المنطق" 123 (روع).هكذا جاءت في أ -بتشديد العين المفتوحة-. وأهملت من الشكل في (ب)، (ج). أكثر مصادر اللغة التي بين يدي، أوردتها: (رَعَبه) -بفتح العين من غير تشديد- والمصدر منها: (رُعْبًا ورُعُبا). أما (رَعَّبه) فمصدرها: (الترعيب).</p><p>انظر: (رعب) في: "اللسان" 3/ 1667، و"القاموس" ص 90، و"التاج" 2/ 25 - 26. وفي "الجمهرة" لابن دريد: "رُعِبَ الرجل، يُرْعَبُ رُعْبًا، فهو (مرعوب)، و (رَعَبْتُه أنا، أرْعَبُه)، فـ (أنا راعِبٌ له. 1/ 318 (رعب).وهكذا ورد ضبطها -بفتح الراء في الأولى، وضمها في الثانية، مع تسكين العين في الحالتين في: "تهذيب اللغة" 2/ 1422، و"المقاييس" 2/ 410، و"المجمل" 1/ 384.</p><p>وورد ضَبْطُها في أكثر المصادر اللغوية التي بين يدي، كالتالي: (رُعْبًا، ورُعُبًا). انظر: (رعب) في: كتاب "العين" 2/ 130، و"اللسان" 3/ 1667، و"القاموس" ص 90، و"المصباح المنير" 88، و"عمدة الحفاظ" 205، و"التاج" 2/ 25 - 26. وانظر: "تفسير القرطبي" 4/ 232.و -كذلك-: (رَعِبٌ). انظر: "عمدة الحفاظ" 205.في (أ): (الرَعَب). وفي (ب): (غير مشكولة). وفي (ج): ساقطة. والمثبت من: مصادر اللغة. ولتتناسب مع ما قبلها من قوله: (رَعْبا ورُعْبا).انظر: "مقاييس اللغة" 2/ 410.</p><p>وقال في "تاج العروس" عن الحالة الثانية، وهي: (الرُّعْب، والرُّعُب): (هما لغتان. وقيل: الأصل الضم، ولا سكون تخفيف. وقيل: العكس، والضم إتباع. وقيل: الأول مصدر، والثاني: اسم. وقيل: كلاهما اسم. وقيل: كلاهما مصدر). 1/ 371 (رعب).</p><p>وانظر: "تفسير القرطبي" 4/ 232، و"تفسير الفخر الرازي" 9/ 33.ما بين المعقوفين مطموس في (أ). وساقط من (ج). والمثبت من (ب).ويقال: (رعَبَ الحوضَ)، (يَرْعَبُهُ رَعْبا): مَلأه و (رَعَبَ السيلُ الوادي): ملأه. انظر: (رعب) في: "المقاييس" 2/ 410، و"اللسان" 3/ 1667.في "تهذيب اللغة"10/ 16 (شرك). نقله عنه بتصرف يسير.في "التهذيب" وكذلك.في "التهذيب" فهو مشرك. وفي نسخ أخرى منه أشار إليها محقِّقُهُ: فهو كافر مشرك.انظر: "تفسير غريب القرآن" لابن قتيبة ص 106، و"تأويل المشكل" له 504، و"تفسير الطبري" 7/ 279، و"نزهة القلوب" للسجستاني 276، و"تهذيب اللغة" 2/ 1732 (سلط)، و"المجمل" 2/ 471 (سلط)، و"مفردات ألفاظ القرآن"420 (سلط).في "معاني القرآن" له 3/ 76 عند تفسير آية 96 من سورة هود.السَّلِيطُ -عند عامَّةِ العرب-: الزَّيْتُ، وعند أهل اليمن: دهن السِّمْسِم، وقيل: هو كل دهن عُصِر من حَبِّ. انظر: "اللسان" 4/ 2065 (سلط).السراج: ليست في: "معاني القرآن".من قوله: (وقيل ..) على (.. الحقوق): في "معاني القرآن" للزجاج 5/ 127 عند تفسير آية 29 من سورة الحاقة.في (ج)، و"معاني القرآن": (تقام).في "معاني القرآن" له 2/ 123 - 124 عند تفسير آية 144 من سورة النساء. نقله عنه باختصار، وتصرف ببعض عباراته. وانظر: "المذكر والمؤنث" له 74.في (ج)، و"معاني القرآن" (وتُذَكِّره).في (ج): (قضيت).من قوله: (السلطان ..) إلى (.. قضت به عيك): ساقط من (ج).في "إصلاح المنطق" 362. نقله عنه بتصرف يسير.في (ج): (مؤنث).في (ج): (قضيت).في "إصلاح المنطق" علينا. وفي بعض النسخ منه أشار إليها محققه: (عليك)، و (عليه).في (ج): (أمنه).في "تهذيب اللغة" 2/ 1732 (سلط). نقله عنه بنصه.في (ج): (لأنه لفظا).سورة هود: 96، والمؤمنون: 45، وغافر: 23.</p><p>وورد في: "تهذيب اللغة" <span class="qpc-hafs">﴿بِسُلطَانٍ مُبِينٍ﴾</span>. وهي من سورة إبراهيم: 10، والنمل: 21، والدخان: 19، والذاريات: 38، والطور: 38.</p><p>انظر حول تذكير وتأنيث (السلطان): "المذكر والمؤنث" للفراء 74، و"المذكر والمؤنث" لابن الأنباري 1/ 381، و"الزاهر" لابن الأنباري 2/ 29 - 30، و"المذكر والمؤنث" لابن التستري 51، 83، و"اللسان" 4/ 2065 (سلط).قوله: في "تهذيب اللغة" 2/ 1733 (سلط). نقله عنه بمعناه.في (أ): (بنايه)، وفي (ج): (بيانه)، والمثبت من: (ب)، و"التهذيب".في "الجمهرة" 2/ 836 (سلط). قال: (حِدَّته وسطوته). ويبدو أن المؤلف نقله عن الأزهري، نظرا لتوافق عبارة المؤلف مع عبارة التهذيب. انظر: "تهذيب اللغة" 2/ 1723 (سلط).من قوله: (من ..) إلى (.. أرهقتها المواقع): بنصه في: "تهذيب اللغة" 2/ 1732 (سلط).في "التهذيب" نصالا.</p><p>النَّصْل: الحديدة التي توضع في رأس المهم أو الرمح، أو حديدة السيف ما لم يكن له مقبض. والجمع: أنْصُل، ونِصَال، ونُصُول. انظر: "القاموس" 1062 - 1063 (نصل).في (أ)، (ب): (محدودة). والمثبت من: (ج)، و"تهذيب اللغة"، وهو ما استصوبته؛ لأنه يقال: (حَدَّده، فهو مُحدَّد). "التاج" 2/ 332 (حدد).</p><p>أما (المحدود) -في اللغة-، فهو: المَمْنوع من الخير وغيره، أو كلُّ مَصْروفٍ عن خير أو شر.</p><p>انظر: (حدد) في: "اللسان" 2/ 799، و"القاموس" ص 276.لم أهتد إلى قائله. وقد ورد غير منسوب في: "تهذيب اللغة" 2/ 1732 (سلط)؛ و"اللسان" 4/ 2065 (سلط).ما بين المعقوفين غير مقروء في (أ). والمثبت من (ب)، (ج).انظر: "تفسير الطبري" 4/ 124، و"بحر العلوم" 1/ 307، و"تفسير القرطبي" 4/ 233.(الذي): ساقطة من (ب).يقال: (ثَوَى المكانَ)، و (ثَوَى به)، (يَثوي، ثَواءً، وثُوِيًّا). ويقال -كذلك-: (أثْوَى)؛ بمعنى: أقام. و (أثْوَيْتُه، وثَوَّيْته): ألزمته الثَّواءَ فيه. انظر (ثوى) في: "التهذيب" 1/ 510، و"اللسان" 1/ 524، و"التاج" 19/ 262.في "التهذيب" 1/ 510 (ثوى)، و"اللسان" 1/ 525 (ثوى): (ويقال للمقتول: قد ثَوَى).في (ج): (الثوى).انظر: المصادر السابقة، و"القاموس" (1268) (ثوى).
  3,152,"<div class=ar lang=ar><p>قوله تعالى: <span class="qpc-hafs">﴿وَلَقَدْ صَدَقَكُمُ اللَّهُ وَعْدَهُ﴾</span> الآية.</p><p>قال القُرَظِيُّ {1}: لَمَّا رَجَعَ رسولُ الله ﷺ، وأصحابُه إلى المدينة، وقد أصابهم ما أصابهم بِأُحُد، قال ناسٌ مِن أصحابه: مِنْ أين أصابَنَا هذا، وقد وَعَدَنا اللهُ النصرَ؟ [فأنزل اللهُ] {2}: <span class="qpc-hafs">﴿وَلَقَدْ صَدَقَكُمُ اللَّهُ وَعْدَهُ﴾</span>؟.</p><p>وقال بعضهم: كان رسولُ اللهِ ﷺ، رَأَى في المنام أنَّه {3} يذبح كَبْشًا، فصدَق رُؤياهُ بقتل {4} طَلْحَةَ بن عثمان {5}، صاحبِ لِوَاءِ المشركين، يوم أُحُد، وقَتْلِ تِسْعَة نَفَرٍ بعده على اللواء {6}، فذلك قوله: <span class="qpc-hafs">﴿وَلَقَدْ صَدَقَكُمُ اللَّهُ وَعْدَهُ﴾</span>؛ يريد: تصديق رؤيا رسول الله ﷺ.</p><p>والصِّدق يتعدى إلى مفعولين؛ تقول: صَدَقْتُهُ الوَعْدَ، والوَعِيدَ {7}.</p><p>قوله تعالى: <span class="qpc-hafs">﴿إِذْ تَحُسُّونَهُمْ بِإِذْنِهِ﴾</span>.</p><p>قال اللَيْثُ {8}: الحَسُّ: القَتْلُ الذَرِيع. قال: و <span class="qpc-hafs">﴿تَحُسُّونَهُمْ﴾</span>، أي: تقتلونهم قَتْلًا شديدًا كثيرًا.</p><p>وروى الحَرَّانيُّ {9} عن ابن السِّكِّيت {10}: الحَسُّ: مصدرُ (حَسَسْتُ القومَ، أَحُسُّهُمْ، حَسًّا): إذا قتلتهم.</p><p>وقال أبو عبيدة {11}، والزَّجَّاجُ {12}، وابنُ قُتَيْبَة {13}: الحَسُّ: الاستئصال بالقتل؛ يقال: (جَرَادٌ مَحْسُوسٌ): إذا قَتَلَه البَرْدُ. و (سَنَةٌ حَسُوسٌ): إذا أتَتْ على كلِّ شيء {14} ومعنى <span class="qpc-hafs">﴿تَحُسُّونَهُمْ﴾</span>: تستأصلونهم قَتْلًا {15}.</p><p>وقال أصحاب الاشتقاق: (حَسَّهُ، يَحُسُّهُ): إذا قَتَلَه؛ لأنه أبطل حِسَّهُ بالقتل، وأصابَهُ {16}؛ كما يقال: (بَطَنَهُ): إذا أصاب بَطْنَهُ {17}، و (رَأَسَهُ): إذا أصاب رَأسَهُ {18}. والتَّحَسُّسُ: طَلَبُ الأخبار بحَاسَّةِ السَمْعِ {19}.</p><p>وقوله تعالى: <span class="qpc-hafs">﴿بِإِذْنِهِ﴾</span> أي: بِعِلْمِهِ {20}</p><p>قال المفسرون {21}: كان المسلمون يوم أُحُد، يقتلون المشركين قتلا ذريعًا حتى وَلَّوْا هاربين، وانكشفوا منهزمين؛ فذلك قوله: <span class="qpc-hafs">﴿وَلَقَدْ صَدَقَكُمُ اللَّهُ وَعْدَهُ إِذْ تَحُسُّونَهُمْ بِإِذْنِهِ﴾</span>.</p><p>ثم أَخَلَّ الرُّمَاةُ {22} بالمكان الذي ألزمهم رسولُ الله ﷺ إيَّاهُ، فَحَمَلَ -حينئذ- خالدُ بنُ الوَلِيد {23}، مِن وَرَاء المسلمين، وتَرَاجَعَ المشركون، وقُتِلَ مِن المسلمين سبعونَ رجلًا، ثم هُزِمُوا {24}.</p><p>وقوله تعالى: <span class="qpc-hafs">﴿حَتَّى إِذَا فَشِلْتُمْ﴾</span> أي: جَبنْتُم عن عَدُوِّكم {25}.</p><p>قال الليث {26}: يقال: (فَشِلَ الرَّجُلُ، يَفْشَلُ) - عند الحَرْبِ والشِّدَّةِ: إذا ضَعُفَ، وذهبَتْ قُوَاهُ {27}. ويقال: (إنه لفَشْلٌ)، و (فَشِلٌ) {28}.</p><p>واختلفوا في جواب <span class="qpc-hafs">﴿حَتَّى إِذَا﴾</span> {29}:</p><p>فقال الفراء {30}: جوابه: <span class="qpc-hafs">﴿وَتَنَازَعْتُمْ﴾</span>، والواو فيه مُقْحَمَةٌ، معناها السقوط؛ كما قال: <span class="qpc-hafs">﴿فَلَمَّا أَسْلَمَا وَتَلَّهُ لِلْجَبِينِ (103) وَنَادَيْنَاهُ﴾</span> {31}؛ المعنى: نَادَيْنَاه. واحتج بقول الشاعر:</p><p>حَتَّى إذا قَمِلَتْ بُطُونُكُمُ ... ورَأَيْتُمُ أبْنَاءَكُمْ شَبُّوا وقلبتمُ ظَهْرَ المِجَنِّ لَنَا ... إنَّ اللَّئِيمَ العاجِزُ الخَبُّ {32}</p><p>قال: يريد: قَلَبْتُم. هذا مذهب الكوفيين.</p><p>وعند البصريين: لا يجوز زيادةُ الواو. ويتأولون هذه الآيةَ وأمثالَها، على حذف الجواب، والتقدير عندهم: (حتى إذا فَشِلْتُمْ، وتَنَازَعْتُم في الأمر، وعَصَيْتُم، امْتُحِنْتُمْ {33}؛ بأن نِيلَ منكم، وعُوقِبْتُم بِظَفَرِ أعدائكم بكم)، فحذف الجواب؛ لبيان {34} معناه؛ كما حذف في قوله -عز وجل-: <span class="qpc-hafs">﴿فَإِنِ اسْتَطَعْتَ أَنْ تَبْتَغِيَ نَفَقًا فِي الْأَرْضِ أَوْ سُلَّمًا فِي السَّمَاءِ﴾</span> [الأنعام: 35]؛ معناه: فافْعَلْ. فأسقط الجواب؛ إذْ أُمِنَ {35} اللَّبْسُ {36}.</p><p>والآية -عند الفراء- على التقديم والتأخير؛ لأنه يذهب إلى أن الفَشَلَ مُؤَخَّرٌ بعد التَّنازُع؛ والمعنى عنده: (حتى إذا تنازعتم في الأمر وعَصَيْتُم؛ فَشِلتم). فقدم المؤخر وأخر المقدم؛ كقوله: <span class="qpc-hafs">﴿إِنِّي مُتَوَفِّيكَ وَرَافِعُكَ إِلَيَّ﴾</span> {37}.</p><p>وغيره يقول: الفَشَل في موضعه، غَيْرُ مَنْوِيٍّ به التأخير. والتنازع والعصيان كانا بعد الفَشَلِ {38}.</p><p>والتنازع {39}: الاختلاف. وأصله مِنْ: (نَزَعَ القومُ الشيءَ، بعضُهُم مِن بَعْضٍ). وسنذكر شرحه عند قوله: <span class="qpc-hafs">﴿فَإِنْ تَنَازَعْتُمْ فِي شَيْءٍ﴾</span> [النساء: 59]، إن شاء الله.</p><p>وكان اختلاف القوم {40}: أن المشركين لَمَّا انكشفوا؛ قال بعضُ الرُّمَاةِ: ما مُقَامُنا هاهنا، قد انْهَزَمَ القومَ. وقال بعضُهم: لا نُجَاوِزُ أمْرَ رَسُولِ الله ﷺ {41}.</p><p>وقوله تعالى: <span class="qpc-hafs">﴿وَعَصَيْتُمْ﴾</span>. أي {42}: بِتَرْكِ المَرْكَزِ {43}.</p><p>وقوله تعالى: <span class="qpc-hafs">﴿مِنْ بَعْدِ مَا أَرَاكُمْ مَا تُحِبُّونَ﴾</span> يعني: الظَّفَرَ والنَّصْرَ والفَتْحَ، حين كان الدَّبْرَةُ {44} على المشركين {45}.</p><p>وقوله تعالى: <span class="qpc-hafs">﴿مِنْكُمْ مَنْ يُرِيدُ الدُّنْيَا﴾</span> يعني {46}: الذين تَرَكُوا المَرْكَزَ، وأقْبَلُوا إلى النَّهْبِ.</p><p><span class="qpc-hafs">﴿وَمِنْكُمْ مَنْ يُرِيدُ الْآخِرَةَ﴾</span> يعني: الذين ثَبَتُوا مَعَ عبد الله بن جُبَيْر -وهو أمير الرُّمَاةِ {47} - حتى قُتِلُوا.</p><p>وقوله تعالى: <span class="qpc-hafs">﴿ثُمَّ صَرَفَكُمْ عَنْهُمْ﴾</span> [أي] {48}: بالهزيمة؛ على معنى: صَرَفَ وجوهَكُم عنهم {49}.</p><p>وقال عَطَاء {50}: يريد: صرف حدكم {51} عنهم. وهذا صريح في أن [المعصيةَ مَخْلُوقَةٌ لله] {52} عز وجل؛ حيث أضاف انهزامهم وتَوَلِّيهم إلى نفسه؛ فقال: <span class="qpc-hafs">﴿صَرَفَكُمْ عَنْهُمْ﴾</span>، ولم يقل: (انْصَرَفْتُمْ) {53}.</p><p>وقوله تعالى: <span class="qpc-hafs">﴿لِيَبْتَلِيَكُمْ﴾</span>. أي: لِيَخْتَبِرَكُمْ بِمَا جَعَلَ عليكم مِنَ الدَّبْرَةِ والهزيمةِ، فَيَتَبَيَّنَ الصابرُ {54} مِنَ الجازع، والمُخْلِصُ مِنَ المنافق {55}.</p><p>وقوله تعالى: <span class="qpc-hafs">﴿وَلَقَدْ عَفَا عَنْكُمْ﴾</span> أي: ذَنْبَكُمْ {56}؛ حيث عصيتم رسولَ اللهِ ﷺ وحيث {57} انهزمتم، فَلَمْ يُؤاخِذْكُمْ بذَنْبِكُمْ.</p><p>وقال بعضُ المُفَسِّرِينَ {58}: ولقد عفا عنكم، فَلَمْ يَسْتَأصِلْكُم بعد المعصية والمخالفة، نظيره: <span class="qpc-hafs">﴿ثُمَ عَفَوْنَا عَنْكُمْ﴾</span> {59}.</p><p>وقوله تعالى: <span class="qpc-hafs">﴿وَاللَّهُ ذُو فَضْلٍ عَلَى الْمُؤْمِنِينَ﴾</span> قال ابن عباس {60}: يريد: بالمَغْفِرَةِ.</p></div>",footnotes:1:قوله في: "تفسير الثعلبي" 3/ 131 أ. وقد نقله المؤلف بنصه عنه، من قوله: (لما رجع ..) إلى (.. ولقد صدقكم الله وعده).</p><p>وانظر قوله -كذلك- في: "أسباب النزول" للمؤلف (129)، و"زاد المسير" 1/ 475، و"تفسير القرطبي" 4/ 233.</p><p>والقُرَظي، هو: أبو حمزة، محمد بن كعب بن سليم بن أسد القُرَظي. تقدمت ترجمته.ما بين المعقوفين مطموس في (أ)، والمثبت من: (ب)، (ج)، و"تفسير الثعلبي".(أ)، (ب)، (ج): (أن). وما أثبَتُه هو ما استصوبته.في (ب): (فقتل).انظر: "تفسير الطبري" 4/ 125 - 126.</p><p>وعند الواقدي: هو طلحة بن أبي طلحة، وأبو طلحة هو: عبد الله بن عبد العُزَّى بن عثمان بن عبد الدار بن قُصَي. انظر: "المغازي" 1/ 220.</p><p>والذي ورد في كتب السِّيَر عن رؤيا رسول الله ﷺ: أنه رأى في منامه كأنه في دِرْعٍ حَصِينة، ورأى كأن سيفه ذا الفقار انفصم من عند ظُبَتِه، ورأى بقرا تُذبح، ورأى كأنه مردفٌ كَبْشًا. فأولَّ النبي ﷺ الدرعَ الحصينة بالمدينة، وأما انفصام سيفه من عند ظُبَته: فمصيبة في نفسه؛ بأن يُقتل رجلٌ من أهل بيته، وأما البقر المذبوح: فقتلى في أصحابه، وأما أنه مُرْدف كَبشا: فكبش كتيبة العدو الذي سيقتلونه، أي: حامل لواء المشركين. وفي رواية عن الواقدي: (ورأيت في سيفي فَلًّا فكرهته)، فهو الذي أصاب وجهه الشريف ﷺ.</p><p>انظر: "المغازي" 1/ 209، و"سيرة ابن هشام" 3/ 66 - 67، و"طبقات ابن سعد" 2/ 37 - 38، و"تاريخ الطبري" 2/ 502، و"إمتاع الأسماع" للمقريزي 1/ 116.انظر: "المغازي" 1/ 226 - 228، و"الطبقات الكبرى" 2/ 40 - 41، و"تفسير ابن أبي حاتم" 3/ 787.وقد يتعدى للثاني بالحرف، تقول: (صَدَقتك في القول).قوله في: "تهذيب اللغة" 1/ 816 (حسس). نقله عنه ببعض التصرف.هو: أبو شعيب، عبد الله بن الحسن الحَرّاني. تقدمت ترجمته.في "تهذيب اللغة" 1/ 816 (حسس). وانظر قول ابن السكيت في "إصلاح المنطق" 26.في "مجاز القرآن" 1/ 104.في "معاني القرآن" 478.في "تفسير غريب القرآن" له 113.هذا قول ابن قتيبة المصدر السابق، تصرف فيه المؤلف بالتقديم والتأخير.انظر: "تفسير الطبري" 4/ 127، "نزهة القلوب"، للسجستاني 155، و"الموضع في تفسير القرآن" للحدادي 39.انظر: "مقاييس اللغة" 2/ 9 (حسس)، و"النكت والعيون" 1/ 429، و"تفسير القرطبي" 4/ 235.(إذا أصاب بطنه): ساقط من (ج).يقال: (بَطَنَه)، و (بَطَنَ له)، و (بَطَّنَه): ضرب بَطْنَه. انظر: "القاموس المحيط" ص 1180 (بطن).</p><p>و (رَأسَه، يرْأسَه، رَأسًا): أصاب رأسه. انظر: "اللسان" 3/ 1533 (رأس).انظر: "الزاهر" 1/ 473.هذا قول الزجاج في "معاني القرآن" 1/ 478.</p><p>وقيل: بأمره وحكمة وقضائه. وهو قول ابن عباس، والطبري، وأبو سليمان الدمشقي، وأبو الليث.</p><p>انظر: "تفسير الطبري" 4/ 127، و"بحر العلوم" 1/ 308، و"زاد المسير" 1/ 476، و"تفسير القرطبي" 4/ 235.</p><p>وقيل: بلطفه، وقيل: بمعونته، وقيل: بصدق وعده. وهذه الأقوال الثلاثة ذكرها الماوردي في: "النكت والعيون" 2/ 906.انظر: "تفسير البغوي" 2/ 118، و"تفسير الثعلبي" 3/ 131 ب، و"تفسير ابن كثير" 1/ 444.في (ب): (أجل الزمان).هو: أبو سليمان، خالد بن الوليد بن المغيرة المخزومي. سماه الرسول ﷺ: (سيف الله)، كان أحد أشراف قريش في الجاهلية، وقائد خيلهم، وشهد مع الكفار حروبهم ضد المسلمين إلى عمرة الحديبية، وأسلم سنة سبع بعد خيبر، وقيل: قبلها. وهو من أشهر قادة الجيوشَ عند المسلمين. توفي سنة (21 هـ). انظر: "الاستيعاب" 2/ 11، و"الإصابة" 1/ 413.انظر: أخبار غزوة أحد في: "صحيح البخاري" (4043) كتاب المغازي. باب غزوة أحد، و"سيرة ابن هشام" 3/ 3، و"الطبقات الكبرى" 2/ 36، و"إمتاع الأسماع" 1/ 116 وما بعدها، و"البداية والنهاية" 4/ 10 وما بعدها.انظر: "معاني القرآن" للزجاج 1/ 478، و"تفسير الطبري" 4/ 128، و"تفسير ابن أبي حاتم" 3/ 786.قوله في: "تهذيب اللغة" 3/ 2792 (فشل). نقله عنه بتصرف يسير.في (ب)، (ج): (قوته).(فشل): ساقطة من (ج).</p><p>وفي "التهذيب" ويقال: (وإنه لَخَشْلٌ فَشْل، وإنه لَخَشلٌ فَشِلٌ).</p><p>والفَشِلُ: الرجل الضعيف الجبان، وجمعه: أفشال. يقال: فَشِلَ فَشلا. أما الخَشل والخَشلُ: فهو -هنا-: الرديء من كل شيء. والله أعلم. انظر: "الصحاح" 4/ 1685 (خشل)، و"اللسان" 6/ 3418 (فشل)، 2/ 1167 (خشل).(إذا): ساقطة من (ج).في "معاني القرآن" له 1/ 238. نقله عنه باختصار، وتصرف.سورة الصافات: 103، 104. وبقيتها: <span class="qpc-hafs">﴿وَنَادَيْنَاهُ أَنْ يَا إِبْرَاهِيمُ﴾</span>. آية: 104.البيتان للأسود بن يَعْفُر النهشلي. وهما في "ديوانه" 19.</p><p>وأورد البكريُّ في "معجم ما استعجم" 2/ 379 البيت الأول ضمن أبيات نسبها للأسود قالها في هجاء بني نَجيح من بني مجاشع بن دارم.</p><p>وقد أورَدتْهما المصادر التالية، بدون نسبة "معاني القرآن" للفراء 2/ 51، و"تأويل مشكل القرآن" 254، وكتاب "المعاني الكبير" 1/ 533، و"المقتضب" 2/ 81، و"مجالس ثعلب" 1/ 59، و"شرح القصائد السبع" لابن الأنباري 55، و"تهذيب اللغة" 3/ 3047 (قمل)، 1/ 84 (باب الواوات)، و"سر صناعة الإعراب" 2/ 646، 647، و"أمالي ابن الشجري" 2/ 121، و"الإنصاف" للأنباري ص 367، 368، و"شرح المفصل" 8/ 94، و"رصف المباني" 487، و"لسان العرب" 6/ 3742 (قمل)، و"الجنى الداني" 165، و"تذكرة النحاة" 45، و"خزانة الأدب" 11/ 44، 45.</p><p>ورد في: "شرح القصائد السبع" (وقلبتم بطن المجن). وورد في بعض المصادر: (إن الغَدُورَ الفاحشُ الخب)، وفي بعضها: (إن اللئيم الفاجر)، وفي "سر صناعة الإعراب" (حتى إذا امتلأت بطونكم).</p><p>قَمِلَت: من (قَمِلَ القومُ): كثروا، و (قَمِل الرجلُ): سَمِنَ بعد هُزَال. ويريد -هنا-: كثرت قبائلكم.</p><p>والمِجَنُّ: التُّرْس. وقوله: (وقلبتم ظهر المجن): كناية عن إسقاط الحياء والتنكر للمعروف، وإبداء العداوة</p><p>والخِبُّ -بفتح الخاء وكسرها-: الخدّاع الذي يسعى بين الناس بالفساد. أما بكسر الخاء فقط - (الخِبُّ) -، فهو: الغَدْر.</p><p>والشاهد فيه عنده: أن الواو في (قلبتم) زائدة، وحقها أن تسقط. و (قلبتم): جواب (إذا).في (أ): (امتَحَنْتم) -بالبناء للمعلوم-. وفي: (ب)، (ج): مهملة من الشكل. والصواب ما أثبتُّه.(لبيان): ساقطة من (ج).(أ)، (ب): (أمَرَّ). والمثبت من (ج).وقد بينَّا مذهبي البصريين، والكوفيين في زيادة الواو من عدمه، مع ذكر طرف من أدلة الفريقين على ذلك. انظر التعليق على تفسير قوله تعالى: <span class="qpc-hafs">﴿وَلِأُحِلَّ لَكُمْ بَعْضَ الَّذِي حُرِّمَ عَلَيْكُمْ﴾</span> آية: 50 من سورة آل عمران. والتعليق على زيادة الواو في قوله تعالى: <span class="qpc-hafs">﴿وَرَسُولًا إِلَى بَنِي إِسْرَائِيلَ﴾</span> آية: 49، والتعليق على زيادة (إذ) في قوله: <span class="qpc-hafs">﴿إِذْ قَالَتِ امْرَأَتُ عِمْرَانَ﴾</span> آية: 35.سورة آل عمران: 55.انظر: "معاني القرآن" للزجاج 1/ 478، و"تفسير الطبري" 4/ 128 - 129.من قوله: (والتنازع ..) إلى (.. من بعض): نقله بنصه عن "تفسير الثعلبي" 3/ 131 ب.(القوم): ساقط من (ج).انظر: "صحيح البخاري" (4043) كتاب المغازي. باب غزوة أحد، و"سنن أبي داود" رقم (2662)، و"تفسير النسائي" 1/ 334، و"مسند الطيالسي" 2/ 95 - 96 رقم (761)، و"الطبقات الكبرى" 2/ 41، و"تفسير الطبري" 4/ 128 - 129، و"تاريخه" 2/ 507، و"إمتاع الأسماع" 1/ 127، و"البداية والنهاية" 4/ 26.من قوله: (أي ..) إلى (.. تحبون) ساقط من (ج).يعني ترك الرماة لموقعهم الذي عينه لهم رسول الله ﷺ وأمرهم ألّا يبرحوه انظر: "تفسير الطبري" 4/ 128 - 129.الدَّبْرَةُ -بفتح الدال-: الهزيمة في القتال. أما الدِّبرة -بكسر الدال-: فهي خلاف القبلة. انظر: "القاموس" ص 390 (دبر).وهذا قول عامة المفسرين، منهم: ابن عباس، وقتادة، ومجاهد، والسدي، وابن إسحاق.</p><p>انظر: "تفسير الطبري" 4/ 128 - 129، و"تفسير ابن أبي حاتم" 3/ 788.من قوله: (يعني ..) إلى (.. بالهزيمة) بنصه في: "تفسير الثعلبي" 3/ 132 أ.وهو أمير الرماة: ليس في "تفسير الثعلبي". وفي (ب): (الرملة). انظر: "تفسير الطبري" 4/ 129 - 130، و"تفسير ابن أبي حاتم" 3/ 789، و"المستدرك" 2/ 296 كتاب التفسير. سورة آل عمران.</p><p>وعبد الله بن جُبَيْر بن النعمان الأوسي الأنصاري. شهد العقبة وبدرًا، واستشهد يوم أحد -رضي الله عنه- انظر: "الاستيعاب" 3/ 14، و"أسد الغابة" 3/ 194.ما بين المعقوفين في (أ): (إلى). والمثبت من: (ب)، (ج)، و"تفسير الثعلبي".في (ج): (وههم).لم أقف على مصدر قوله.هكذا في: (أ)، (ب)، (ج).</p><p>ومعناها -والله أعلم-: صرف بأسكم وقوتكم عنهم، لأن (حَدّ الرَّجُلِ): بأسه ونفاذُهُ. في نجدته. يقال: (إنه لذو حَدٍّ). انظر: "اللسان" 2/ 801 (حدد).ما بين المعقوفين مطموس في (أ). والمثبت من (ب)، (ج).انظر تأويل المعتزلة لها في: "تنزيه القرآن عن المطاعن" 82.(أ)، (ب): (الصابرين). والمثبت من (ج).في (ب): (الشاك).في (ج): (دينكم).في (ج): (فحيث).ممن قال ذلك: مقاتل، والحسن، وابن جريج، وابن إسحاق، والطبري، وأبو الليث، والثعلبي.</p><p>انظر: "تفسير الطبري" 4/ 131 - 132، و"تفسير ابن أبي حاتم" 3/ 789 - 790، و"بحر العلوم" 1/ 308، و"تفسير الثعلبي" 3/ 132 أ. والعبارة له.سورة البقرة: 52. <span class="qpc-hafs">﴿ثُمَّ عَفَوْنَا عَنْكُمْ مِنْ بَعْدِ ذَلِكَ لَعَلَّكُمْ تَشْكُرُونَ﴾</span>.لم أقف على مصدر قوله بهذا النص. وقد أورد ابن الجوزي في "الزاد" 1/ 477، عنه قولَه: (إذ عفا عنهم جميعًا).
  3,153,"<div class=ar lang=ar><p>قوله تعالى: <span class="qpc-hafs">﴿إِذْ تُصْعِدُونَ﴾</span> (إذْ) مُتَعَلِّق بـ (عَفَا)؛ يعني: ولقد عَفَا عنكم إذْ تُصْعِدُونَ.</p><p>و (الإصْعَادُ)، قال الفَرَّاءُ {1} والزَّجَّاجُ {2}: هو الابتداء في كلِّ سَفَرٍ؛ يقال: (أَصْعَدْنَا مِن بَغْدادَ إلى خُرَاسانَ وإلى مَكَّةَ): إذا خرجنا إليها، وأَخَذْنا {3} في السَّفَرِ نحوها {4}.</p><p>وأَقْرَأَني العَرُوضِيُّ، عن الأزهري، عن المُنْذِري، عن الحَرَّانِيِّ، عن ابن السِّكِّيت، قال {5}: يقال: (صَعِدَ في الجَبَلِ)، و (أَصْعَدَ في البلاد).</p><p>وقال الأخفش {6}: (أَصْعَدَ في البلاد): سار ومَضَى {7}.</p><p>أبو عُبَيْد، عن أبي زيد، وأبي عمروٍ: يقال: (أَصْعَدَ الرجلُ في البلاد): حيث تَوَجَّهَ. {8} قال الأعشى:</p><p>ألا أيُّهذا السَّائِلِي أينَ أَصْعَدَتْ ... فإنَّ لَهَا في أهلِ يَثْرِبَ مَوْعِدَا {9} وقال ابن قُتَيبة {10}: <span class="qpc-hafs">﴿تُصْعِدُونَ﴾</span>: تُبْعِدُونَ في الهَزِيمَةِ؛ يقال: أَصعَدَ في الأرض: إذا أَمْعَنَ فيها {11} في الذَّهَاب {12}.</p><p>وقوله تعالى: <span class="qpc-hafs">﴿وَلَا تَلْوُونَ عَلَى أَحَدٍ﴾</span> أي: لا تُعَرِّجُونَ ولا تُقِيمون ولا تَلْتَفِتون هَرَبًا. يقال: (مَضَى ولم يَلْوِ على شيءٍ)؛ أي: لم يُعَرِّجْ. وأصله: أنَّ المُعَرِّجَ على الشيء، يَلْوِي إليه عُنُقَهُ، أو عِنَانَ {13} دابَّتِهِ. فإذا مضى، ولمْ يُعَرِّج، قيل: (لم يَلْوِ). ثم استُعْمِلَ في تَرْكِ التَّعْرِيج على الشيء.</p><p>فإن قيل: أليس اللهُ قد أخبَرَ أنَّه عَفَا عنهم -إذْ هُزِمُوا-، فكيف ذلك العَفْو، مع ما ابتلاهم به مِنَ القَتْلِ والجَرْح، وإدَالَةِ العَدُوِّ عليهم؟.</p><p>قيل: لولا عَفْوُ اللهِ، ما نَجَا منهم أحدٌ {14}، ولَصَارُوا في الآخرةِ من الخاسرين؛ حين عَصَوا رسولَهُ في تَرْكِ المَرْكَزِ والهزيمة، وهو يناديهم مِن وَرَائِهم: (إلَيَّ عِبَادَ اللهِ! إلَيَّ عِبَادَ الله!) وهم لا يَلْتَفِتُون إليهِ. وذلك قوله: <span class="qpc-hafs">﴿وَالرَّسُولُ يَدْعُوكُمْ فِي أُخْرَاكُمْ﴾</span>.</p><p>قال ابن عباس {15}: يريد: مِن خَلْفِكُم. يقال {16}: (جاءَ فلانٌ في آخِرِ النَّاسِ)، و (آخِرَةِ {17} النَّاس)، و (أُخْرَى الناس)، و (أُخْرَاة الناس) {18}.</p><p>وقوله تعالى: <span class="qpc-hafs">﴿فَأَثَابَكُمْ﴾</span> الإثَابَةُ: أكثر ما تُسْتَعمل {19} في الخير، ويجوز استعمالُه في الشَّرِّ، لأن أصله: ما يَرْجِعُ مِنَ الجَزَاء على الفِعْل، طاعةً كان أو معصيةً، ولكنه كَثُرَ في جَزَاء الطاعة {20}، كما تقول في (الطَّرَب)، فإنَّ أصْلَهُ: خِفَّةٌ تأخذ الإنسانَ، مِنْ فَرَحٍ أو حُزْنٍ {21}، كما قال {22}: طَرَبَ الوَالِهِ أوْ كالمُخْتَبَلْ {23}</p><p>إلا أنَّه كَثُرَ استعمالُهُ في خِفَّةِ الفَرَحِ، وَنَشَاطِ السُّرُورِ {24}.</p><p>وقال أصحابُ المعاني {25}: معنى قوله: <span class="qpc-hafs">﴿فَأَثَابَكُمْ غَمًّا بِغَمٍّ﴾</span>؛ أي: جَعَلَ مكانَ مَا تَرْجُونَ مِنَ الثَّوَابِ، الغَمَّ؛ كما تقول: (تَحِيَّتُكَ الضَّرْبُ)، و (عِتَابُكَ السَّيْفُ) {26}؛ أي: تجعل هذا مكانَ ذاك. قال عَمْرو بن مَعْد يكَرِب {27}:</p><p>وَخَيْلٍ قَدْ دَلَفْتُ لَهَا بِخَيْلٍ ... تَحِيَّةُ بَيْنهمْ ضرْبٌ وَجِيعُ {28} أي: جَعَلُوا الضربَ الوجِيعَ، مَكَانَ التَّحِيَّةَ بين القَوْمِ.</p><p>وقال الفَرّاء {29}: الإثابة -ههنا- في معنى: (عِقَاب)، ولكنه كما قال الشاعر:</p><p>أَخَافُ زِيَادًا أنْ يَكُونَ عَطَاؤُهُ {30} ... أدَاهِمَ سُودًا أوْ مُحَدْرَجَةً فُتْلا {31} يعني بـ (السُّودِ): القيود {32}، وبـ (المحَدْرَجَة): السِّيَاط. وأرادَ: أخافُ أنْ يَجْعَلَ {33} مَكانَ عَطائِهِ، القُيُودَ والسِّيَاطَ.</p><p>قال {34}: وقد يقول الرَّجُلُ [لـ] {35} الذي اجترم {36} إليه {37}: [(لَئِنْ] {38} أتَيتَنِي {39}؛ لأُثِيبنَّك ثَوَابَكَ)، معناه: لأعاقبنَّكَ. وهذا راجعٌ إلى ما ذكرنا مِن قَوْلِ أصحابِ المعاني.</p><p>وقوله تعالى: <span class="qpc-hafs">﴿غَمًّا بِغَمٍّ﴾</span> أي: أثَابَكم غَمًّا، وهو: الهَزِيمَة، وظَفَر المشركين بكم. <span class="qpc-hafs">﴿بِغَمٍّ﴾</span>، يعني: بِغَمِّكمْ رَسول الله ﷺ؛ إذْ عَصَيْتموهُ وَضَيَّعتم أمرَهُ. فالغَمُّ الأوّل لهم، والغَمُّ الثاني للنبي ﷺ. وهذا القول، اختيار الزجاج {40}.</p><p>وقال الحسن {41}: غَمّ يومِ أحُد للمسلمين، بغَمِّ يومِ بَدْرٍ للمشركين {42}.</p><p>وقيل: الغَمُّ الأَوَّل: ما أصابهم مِنَ الهزيمة والقتل. والغَم الثاني: إشْرافُ خالد بن الوَلِيد عليهم، في خَيْلِهِ، فَرَعَبَهم ذلك، وزَادَ مِنْ قَلَقِهم. وهذا قول أكثر المفسرين {43}، واختيار الفراء {44}.</p><p>وقيل: الغَمّ الأوَّل: ما أصابهم مِنَ القتل والجرح. والغَمّ الثاني: ما سَمِعوا أنَّ مُحَمَّدًا قد قُتِلَ. وهذا قول: قَتَادة {45}، والرَّبِيع {46}، وابنِ عبَّاس -في رواية عطاء- {47} فإنَّه قال في قوله: <span class="qpc-hafs">﴿غَمَّا بِغَمٍّ﴾</span>؛ يريد: الهزيمة، وحيث قال ابنُ قَمِيئَةُ {48}: قد قتلتُ محمدا.</p><p>والباء في قوله: <span class="qpc-hafs">﴿بِغَمٍّ﴾</span> -في القولين المتأخرين-؛ بمعنى: [(مع)] {49} أو بمعنى: (عَلَى)؛ كما يقال {50}: (نزلتُ بِبَنِي {51} فلان)، و (على بَنِي فلان)، و (ما زِلْتُ به حتى فَعَلَ)، و (ما زِلْتُ معه حتى فَعَل) {52}.</p><p>قوله تعالى: <span class="qpc-hafs">﴿لِكَيْلَا تَحْزَنُوا عَلَى مَا فَاتَكُمْ وَلَا مَا أَصَابَكُمْ﴾</span>.</p><p>اختلفوا {53} في اللّام في قوله: <span class="qpc-hafs">﴿لِكَيْلَا﴾</span>:</p><p>فقال بعضَ النحويِّين {54}: إنها مُتَّصِلَة بقوله: <span class="qpc-hafs">﴿وَلَقَدْ عَفَا عَنْكُمْ﴾</span> [كأنه قال: <span class="qpc-hafs">﴿وَلَقَدْ عَفَا عَنْكُمْ﴾</span>] {55}، {لِكَيْلَا تَحْزَنُوا عَلَى مَا فَاتَكُمْ}، [لأن] {56} في {57} عَفوِهِ -جلَّ وعَزَّ-، ما يُذْهِبُ كُلَّ غَمٍّ وَحُزْنٍ {58}. وقال آخرون: إنها مُتَّصِلَةٌ بقوله: <span class="qpc-hafs">﴿فَأَثَابَكُمْ﴾</span>.</p><p>ثُمْ اختلفوا:</p><p>فَقَالَ [أبو إسحاق] {59}: المعنى: أثابكم غَمَّ الهزيمة، بِغَمِّكُمْ النبيَ ﷺ بِمُخَالَفتِهِ {60}، ليكون غَمُّكُمْ، بأن خالفتموه فقط، لا على ما فاتكم مِنْ غَنِيمة، ولا ما أصابكم من هزيمة وجِرَاحٍ؛ وذلك أنَّ غَمَّ مُخَالَفَةِ الرَّسُولِ، يُنْسيهم غَمَّ فَوْتِ الغَنِيمَةِ.</p><p>وقال غيره: كان أصحاب رسول الله ﷺ، يَتَأَسَّفُونَ على ما فاتهم مِنْ غَنائم المشركين، وعلى ما حَلَّ بهم مِنَ القَتْلِ والجراح، فأنزلَ اللهُ بقلوبهم غَمَّ قَتْلِ الرسول ﷺ، ثمّ أزال ذلك الغم عنهم؛ لِيَفرحوا ببقائه، ولا يحزنوا مع بقائه على شَيءٍ {61} فَاتَهُمْ {62}.</p><p>وقولُ أبي إسحاق ألْيَقُ بَظَاهِرِ الآية؛ لأنه ليس في الآية ذِكْرُ إزَالَةِ غَمِّ قتلِ النبيِّ ﷺ، إلّا بأنْ {63} يُقال: إنَّ ذلك الغَمَّ، لَمْ يتحققْ؛ لأنَّهُ لَم يَصْدُقْ نعْيُ الرسول.</p><p>وحُكي عن المُفَضَّلِ {64} أنه كان يَجْعَلُ (لا) -في هذه الآية- صِلَةً {65}، ويقول: المعنى: لِكَيْ تَحْزَنُوا على ما فاتكم وما أصابكم؛ عُقُوبَةً لكم في خِلافِكُمْ إيَّاهُ؛ كقوله: <span class="qpc-hafs">﴿لِئَلَّا يَعْلَمَ﴾</span> {66} [الحديد: 29].</p><p>وقوله تعالى: <span class="qpc-hafs">﴿وَاللَّهُ خَبِيرٌ بِمَا تَعْمَلُونَ﴾</span>. تذكيرٌ؛ للتَّحْذِير {67}.</p></div>",footnotes:1:في "معاني القرآن" له 1/ 239.في "معاني القرآن" له 1/ 478 - 479.في (ب): (وابتدأنا).في (ب): (يوما).قوله في "إصلاح المنطق" 256. ونصه: (قد أصْعَد في الأرض إصعادًا، وقد صَعِدَ في الجبل، وعلى الجبل). وأورده الأزهري في "تهذيب اللغة" 2/ 2013 (صعد)، والنص له.في "معاني القرآن" له 1/ 218.ونصه عنده: "أصعد"؛ أي: مضى وسار. و (أصعد في الوادي)؛ أي: انحدر فيه. وأما (صَعِد)، فإنه ارتَقَى).</p><p>وأورده الازهريُّ -كما هو عند المؤلف-. ويبدو أن المؤلف نقله عنه. انظر: "التهذيب" 2/ 2013 (صعد).نقله -بنصه- عن "تهذيب اللغة" 2/ 2013 (صعد).البيت في: ديوانه: 45. وقد ورد منسوبًا له في المصادر التالية: "السيرة النبوية" لابن هشام 1/ 412، و"المقتضب" 4/ 259، و"الأضداد" لابن الأنباري 315، و"تفسير الثعلبي" 3/ 132ب، و"تفسير القرطبي" 4/ 239، و"المقاصد النحوية" 3/ 60، 326، و"الدرر اللوامع" 1/ 153، وأورده السيوطي في "همع الهوامع" 3/ 51 ولم ينسبه.</p><p>وقد ورد البيت في الديوان، وكل المصادر السابقة -ما عدا "الأضداد" وتفسيري الثعلبي، والقرطبي-: (أين يَمَّمَتَ) بدلًا من: (أين أصْعَدَتْ) وليس فيها موضع الشاهد. وورد عند القرطبي: (فإن لها من بطن يثربَ موعدا).</p><p>والبيت من قصيدة طويلة يمدح فيها النبي ﷺ وهو متوجه إلى المدينة المنورة؛ لِيُسْلِمَ، إلا أن قريشًا صرفته عن ذلك، فرجع ولم يُسْلِمْ. انظر خبره في: "سيرة ابن هشام" 1/ 411.في "تفسير غريب القرآن" له 114، وانظر: "أدب الكاتب" له 278.(فيها): ليست في (ج)، ولا في "تفسير غريب القرآن".وبقية عبارة ابن قتيبة: (وصعِد الجبل والسطح).</p><p>قال الطبري: (قالوا: فالهرب في مستوى الأرض، وبطون الأودية والشِّعاب: (إصعاد) لا صعود. قالوا: وإنما يكون (الصُّعُود) على الجبال والسلاليم والدَّرج؛ لأن معنى (الصعود): الارتقاء، والارتفاع على الشيء عُلُوًّا). "تفسيره" 4/ 132 - 133. وانظر: "مجاز القرآن" 1/ 105، و"الأضداد" لابن الأنباري 315.</p><p>ونقل الثعلبي عن المفضل، أن: (صَعِد، وأصْعَدَ، وصَعَدَ، بمعنى واحد). "تفسير الثعلبي" 2/ 132 ب.</p><p>وكذا فسر ابنُ اليزيدي (الإصعاد) بالصعود على الجبل. انظر: "غريب القرآن" لابن اليزيدي 44.(أ)، (ب): (عيْنان). والمُثبت من (ج).في (ج): (أحدا).لم أقف على مصدر قوله بهذا النص. والذي في "تفسير الطبري" 4/ 133من قوله -في تفسيرها-: (إليَّ عبادَ الله!) وقد يفهم من هذا القول أنه يناديهم مِن خَلْفهم، وهو ما فهمه الطبريُّ، حيث فسرها بذلك، ثم أورد قول ابن عباس -السابق- دليلًا على ذلك. انظر: "تفسيره" 4/ 133.من قوله: (يقال ..) إلى (.. وأخراة الناس): بنصه في: "تفسير الثعلبي" 3/ 133 أ. وأورده القرطبي في "تفسيره" 4/ 240. وعندهما زيادة: (.. وأخرَيَات الناس).في (ج): (احرة). وفي "تفسير الثعلبي" (أَخَرَةِ) وعند القرطبي: (أُخْرَةِ). وما ورد في (أ)، (ب) مِمّا أثبَتُّه، قد ورد في مصادر اللغة. يقال: (جاء أَخَرَة، وبأخَرَةٍ، وَأُخَرَةً، وبأخَرَةٍ)؛ أي: جاء آخر كل شيء. ويقال: (جاء أُخُرًا، وبآخِرَةٍ)، ويقال: (وآخِرَةِ السَّرْج، أو الرَّحل).</p><p>انظر: (أخر) في: "اللسان" 1/ 39، و"التاج" 6/ 17.(وأخرى الناس وأخراة الناس): ساقط من (ج). وقوله: (وأخراة الناس) ليس في "تفسير القرطبي".</p><p>و (أخراة) مثل (أخرى)؛ مؤنث (الآخر). انظر: "التاج" 6/ 17 (أخر).في (ج): (يستعمل).انظر: (ثوب) في: "تهذيب اللغة" 1/ 465، و"اللسان" 1/ 519.انظر: (طرب) في: "التهذيب" 3/ 2174، و"اللسان" 5/ 2649.في (ب): (يقال).شطر بيت للنابغة الجعدي. وصدره:</p><p>وَأرَانِي طَرِبًا في إثْرِهِمْ</p><p>وقد ورد في: شعره: 93. وورد منسوبًا له في: "أدب الكاتب" 18، و"تهذيب اللغة" 3/ 2174 (طرب)، و"الاقتضاب" 3/ 14، و"اللسان" 5/ 2649 (طرب). وروايته في شعره: (فأراني ..).</p><p>(الوالهُ): الذي ذهب عقله، أو قارب الذهاب؛ لفقد حبيبه، أو ولده، وهو (الثاكل).</p><p>و (المُختَبَل): الذي خَبَلَهُ الحُزْنُ فَجَنَّنَهُ وأفقده عقله، أو هو الذي قُطِع عضوٌ من أعضائه. وهذا التفسير الثاني، قال في: "الاقتضاب" إنه (أجود في هذا الموضع؛ ليختلف المعنيان).</p><p>انظر: "الاقتضاب" 4/ 134، و"القاموس" 972 (ثكل)، 990 (خبل).انظر: (مادة: طرب) في المصادر السابقةانظر: "تفسيرِ الطبري" 4/ 134، و"معاني القرآن" للنحاس 1/ 497، و"بحر العلوم" 1/ 308، و"تفسير الثعلبي" 3/ 133 ب.وهذا من كلام العرب السائر. كما يقول أبو زيد في: النوادر: 149.أبو ثور الزُّبَيْديَ، تقدم.ورد البيت في: شعره 149. وقد ورد منسوبًا له في:</p><p>"كتاب سيبويه" 3/ 50، و"النوادر" لأبي زيد 150، و"العمدة" لابن رشيق 2/ 1056، و"الممتع في صنعة الشعر" 159. == وأوردته المصادر التالية غير منسوب: "كتاب سيبويه" 2/ 232، و"المقتضب" 2/ 20، 4/ 413، و"الخصائص" 1/ 368، و"مفردات ألفاظ القرآن" 126، 835، و"المحرر الوجيز" 3/ 375، و"شرح المفصل" 2/ 80، و"التصريح" 1/ 353، و"خزانة الأدب" 9/ 257، 263؛ حيث ذكر نسبته للشاعر ولم يجزم بذلك.</p><p>أراد الشاعرُ بـ (الخيل) الأولى: خيل الأعداء، وبالثانية: خيلَه. والخيل -هنا-، يعني بها: الفُرسان. و (دَلَفْتُ): دَنَوْتُ وزَخفْتُ؛ يقال: (دَلَفَ الشيخ): إذا مَشى مَشْيًا لَيِّنًا. انظر: "خزانة الأدب" 9/ 264.في "معاني القرآن" له 1/ 239. نقله بنصه إلى نهاية بيت الشعر (فتلا).(أ)، (ب): (عطآه). والمثبت من: (ج)، ومصادر البيت.في (ج): (قتلا).</p><p>البيت، للفرزدق، وهو في: ديوانه: 169. وقد ورد منسوبًا له في. "طبقات فحول الشعراء" 2/ 304، و"تاريخ الطبري" 5/ 247، و"الصحاح" 1/ 305 (حدرج)، و"اللسان" 2/ 804 (حدرج). وورد غير منسوب في: "معاني القرآن"، للفراء 1/ 239، و"تفسير الطبري" 4/ 134، و"تفسير الثعلبي" 3/ 133 أ، و"المدخل" للحدادي 357، و"المحرر الوجيز" 3/ 376، و"زاد المسير" 1/ 478، و"البحر المحيط" 3/ 83.</p><p>ورواية البيت في الديوان، و"تاريخ الطبري":</p><p>فلمَّا خشِيتُ أن يكون عطاؤه ... أداهم سودا أو محدرجة سُمْرا</p><p>وفي "طبقات فحول الشعراء" (فلما خشينا ..). وورد في كل المصادر -ما عدا "تفسير الثعلبي"-: (سُمْرا) بدلا من: (فُتلا) التي لا تستقيم مع قافية القصيدة الرائية. واتفقت رواية المؤلف للبيت مع الثعلبي، مما يدل على أن المؤلف أخذ البِيت عنه.== (الأداهم): جمع: (أدْهَم)، وهو: الأسْوَد. وتُطلَقُ (الأداهمُ) على القيِود -وهي المرادة -هنا- في البيت-، وسميت بذلك؛ لِسَوَادها.</p><p>و (المُحَدْرَجة): السِّياط، وأصل المُحَدْرَج: المفتول، والأملس. ويقال -كذلك-: (الحُدرُج)، و (الحُدرُوج). انظر: "اللسان" 4/ 1443 (دهم)، 2/ 804 (حدرج). والبيت ضمن قصيدة طويلة قالها الشاعر في زِيَاد بن أبِيهِ، وكان قد تَوَعَّد الفرزدقَ، ثم أظهر عفوَهُ عنه، وأنه سيُؤَمِّنه وَيمُنُّ عليه، فلم يثق الشاعرُ في أمانه، وقال القصيدة في ذلك.في (ج): (القيود والسياط).في (ج): (تجعل).الفراء في: "معاني القرآن" 1/ 239. نقله عنه بنصه.ما بين المعقوفين زيادة لازمة لتستقيم العبارة.في (ج): (احترم). اجْتَرَمَ، بمعنى: (جَرَم، وأجرم): تَعَدَّى، وارتكب جُرْما؛ أي: ذنبًا. يقال: (جرم إليهم، وعليهم جريمة)، و (فلان يَتَجَرَّم علينا)؛ أي: يَتَجَنَّى علينا ما لم نجْنِه. انظر: "اللسان" 1/ 604 (جرم).في "معاني القرآن" عليك.ما بين المعقوفين في (أ)، (ج): (أي). وساقط من (ب). والمثبت من "معاني القرآن".في (أ): (أثييني)، وفي (ب): (أيثبتني)، وفي (ج): مهملة من النقط. والمثبت من "معاني القرآن".في "معانى القرآن" له 1/ 479.قوله في: "تفسير الثعلبي" 3/ 133 أ، و"النكت والعيون" 1/ 430، و"زاد المسير" 1/ 479، و"تفسير القرطبي" 4/ 240.وأخرج عنه ابن أبي حاتم قولَه في تفسيرها: (قال غَمَّا -والله- شديد، على غَمٍّ شديد، ما منهم إنسان إلا وقد همته نفسه). "تفسيره" 3/ 791.ممن قال ذلك: ابن عباس. انظر: "زاد المسير" 1/ 478، ومقاتل. انظر: "تفسيره" 1/ 307. ولم أقف على غيرهما قال به.في "معاني القرآن" له 1/ 240.قوله في: "تفسير الطبري" 4/ 135، و"تفسير ابن أبي حاتم" 3/ 791، و"زاد المسير" 1/ 478، وأورده السيوطي في "الدر" 2/ 154، وزاد نسبة إخراجه لابن المنذر.قوله في: "تفسير الطبري" 4/ 135.لم أقف على مصدر هذه الرواية عنه.في (ج): (قتيبة). == ابن قَمِيئة: اسمه عمرو، وقيل: عبد الله. وهو الذي قَتَلَ مُصْعَب ابن عُمَيْر (وكان يَظُنُّه رسولَ الله ﷺ، وكان بِيَدِ مُصْعب اللِّواء.</p><p>انظر: "المغازي" 1/ 244 - 246، و"تاريخ الطبري" 2/ 516، و"إمتاع الأسماع" 1/ 129، 130، 131.ما بين المعقوفين زيادة لازمة من (ج).في (ب): (قال).في (ج): (بني).انظر: "معاني القرآن" للأخفش 1/ 812، و"تفسير الطبري" 4/ 134، و"رصف المباني" 222، و"الجنى الداني" 40، 42.</p><p>و (الباء) في القول -وهو قول الحسن-: للسببية؛ أي: فأثابكم غمًّا؛ بسبب الغم الذي حلَّ بالكفار -على أيديكم- يوم بدر.</p><p>وابن عطية يسمي هذه الباء: (باء معادلة).</p><p>انظر: "المحرر الوجيز" 3/ 376، و"البحر المحيط" 3/ 84، و"الدر المصون" 3/ 442.في (ب): (واختلفوا).لم أهتد إليهم.ما بين المعقوفين زيادة من (ج).ما بين المعقوفين مطموس في (أ)، وساقط من (ب)، والمثبت من (ج).في (ب): (من).وقد استحسن هذا الوجه: القرطبي، واستبعده أبو حيان، والسمين الحلبي؛ وذلك لطول الفصل، ولأنه -في الظاهر- يتعلق بمجاوره، وهو: <span class="qpc-hafs">﴿فَأَثَابَكُمْ﴾</span>. انظر: "تفسير القرطبي" 4/ 241، و"البحر المحيط" 3/ 85، و"الدر المصون" 3/ 443.ما بين المعقوفين مطموس في (أ)، والمثبت من (ب)، (ج). وقول أبي إسحاق في "معاني القرآن" له 1/ 479. نقله عنه بمعناه.في (ج): (مخالفة).في (ج): (ما) بدلا من (شيء).لم أقف على من قال هذا القول بتمامه، إلا أن بعضه، وهو: أن الغم الأول: ما أصابهم من قتل وجراح، والغم الثاني: سماعهم قتل النبي ﷺ. قد سبق وروده عند تفسير قوله تعالى: <span class="qpc-hafs">﴿غَمًّا بِغَمٍّ﴾</span> آية: 153.في (ج): (أن).حكى قولَ المُفضَّل: الثعلبيُّ في "تفسيره" 3/ 133 ب، والقرطبى في "تفسيره" 4/ 241.بمعنى: (زيادة).انظر: "تفسير البيضاوي" 2/ 250، و"تفسير النسفي" 4/ 221.في (أ)، (ب): (التحذير)، والمثبت من (ج).