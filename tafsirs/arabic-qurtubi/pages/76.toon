quran[6]{c,v,t}:
  3,195,"<div class=ar lang=ar><p>قوله تعالى: <span class="qpc-hafs">﴿فَاسْتَجَابَ لَهُمْ رَبُّهُمْ أَنِّي﴾</span> أي: بِأنِّي.</p><p>وقوله تعالى: <span class="qpc-hafs">﴿بَعْضُكُمْ مِنْ بَعْضٍ﴾</span> أي: في الدِّينِ والنُصْرَةِ، والمُوَالاة. معناه: بعضكم يوالي بعضًا؛ كما ذكرنا في قوله: <span class="qpc-hafs">﴿ذُرِّيَّةً بَعْضُهَا مِنْ بَعْضٍ﴾</span> [آل عمران: 34]. هذا قولُ الكَلبِيِّ {1} وغيرِه {2}.</p><p>وقيل {3}: معناه: حُكْمُ جَمِيعِكم حُكْمُ واحِدٍ منكم؛ فيما أفْعَلُ بكم؛ مِنْ مُجازاتِكم على أعمالكم، وتَرْكِ تضييعها لكم. يستوي في ذلك ذُكْرانُكم وإناثكم.</p><p>وقوله تعالى: <span class="qpc-hafs">﴿وَقَاتَلُوا وَقُتِلُوا﴾</span>. أحسنُ {4} وجوهِ القِراءَةِ: تقديمُ <span class="qpc-hafs">﴿قَاتَلُوا﴾</span> على <span class="qpc-hafs">﴿قُتِلُوا﴾</span> {5}، لأن القتال قبل القتل. وقرأ ابنُ عامر، وابنُ كَثير: <span class="qpc-hafs">﴿وَقُتِّلُواْ﴾</span> -مُشَدَّدَة- {6}؛ لِتَكَرُّرِ القتلِ فيهم، فهو مثل: <span class="qpc-hafs">﴿مُفَتَّحَةً لَهُمُ الْأَبْوَابُ﴾</span> [ص: 50]، ومَنْ خَفَّفَ؛ فإن التخفيف يقع على القليل والكثير.</p><p>وقرأ حمزة، والكسائيُّ {7}: <span class="qpc-hafs">﴿وَقَاتَلُوا وَقُتِلُوا﴾</span>، ولها وجهان:</p><p>أحدهما: أن المعطوف بالواو، هو الأوَّلُ في المعنى، وإنْ كان مُؤَخَّرًا في اللفظ؛ لأن {8} الواوَ لا يُوجِبُ {9} ترتيبًا.</p><p>والثاني: أن المُرادَ بقوله: <span class="qpc-hafs">﴿وَقتُلُواْ﴾</span> ، أي: قُتِلَ بعضُهم، ثم قاتل مَنْ بَقِيَ منهم، ولم يَهِنُوا، ولم يَضْعُفوا، لِلْقَتْلِ الذي وَقَعَ بهم {10}.</p><p>وقوله تعالى: <span class="qpc-hafs">﴿ثَوَابًا مِّن عِندِ اَللَّهِ﴾</span> قال الزجاجُ {11}: هو مصدرٌ مؤكِّدٌ لِمَا قبله {12} ، لأن معنى <span class="qpc-hafs">﴿وَلَأُدْخِلَنَّهُمْ جَنَّاتٍ﴾</span>: لأُثِيبَنَّهُمْ.</p><p>قال: ومثله: <span class="qpc-hafs">﴿كِتَابَ اللهِ﴾</span> {13}، و <span class="qpc-hafs">﴿صُنْعَ اللهِ﴾</span> {14}؛ لأن ما قبله بمنزلة: (كَتَبَ اللهُ)، و (صَنَعَ اللهُ) {15}.</p></div>",footnotes:1:قوله، في: تفسير "بحر العلوم" 1/ 324، و"تفسير الثعلبي" 3/ 174أ.وهو قول: ابن عباس، والحسن، وقتادة، واختيار الطبري. انظر: "تفسير الطبري" 4/ 216، و"النكت والعيون" 1/ 443، و"زاد المسير" 1/ 375.هذا القول، أورده الطبري في تفسيره؛ مِن تتمة القول الأول، ولم يفصل بينهما. انظر: "تفسيره" 4/ 216. وأورده الثعلبي في "تفسيره" 3/ 174 أ، وصَدّره بـ (قيل) ولم ينسبه لقائل.من قوله: (أحسن ..) إلى (.. للقتل الذي وقع بهم): نقله -بالمعنى- من "الحجة" للفارسي 3/ 117.هي قراءة نافع، وعاصم، وأبي عمرو.</p><p>انظر: "السبعة" 221، و"القراءات" للأزهري 1/ 135، و"الحجة" للفارسي 3/ 117، و"الكشف" لمكي 1/ 373، و"التيسير" للداني 93.انظر: المصادر السابقة.انظر: المصادر السابقة، و"النشر" 2/ 246.في (ج): (فإن).في (ج): (لا توجب).استشهد الفارسي في هذا الموضع بقوله تعالى: <span class="qpc-hafs">﴿فَمَا وَهَنُوا لِمَا أَصَابَهُمْ فِي سَبِيلِ اللَّهِ﴾</span> [الآية: 146. سورة آل عمران].في "معاني القرآن" له 1/ 500. نقله عنه بتصرف واختصار.المصدر المؤكِّد، هو المفعول المطلق. وفي نصبه وجوه أخرى؛ منها: أنه منصوب على التمييز، الذي يسميه الفراء (التفسير). وقيل: منصوب على القطع؛ أي: الحال. وقيل غير ذلك.</p><p>انظر: "معاني القرآن" للفراء 1/ 251، و"إعراب القرآن" للنحاس 1/ 387، و"مشكل إعراب القرآن" 1/ 185، و"الدر المصون" 3/ 543 - 544.سورة النساء: 24. <span class="qpc-hafs">﴿وَالْمُحْصَنَاتُ مِنَ النِّسَاءِ إِلَّا مَا مَلَكَتْ أَيْمَانُكُمْ كِتَابَ اللَّهِ عَلَيْكُمْ﴾</span>، لأن قبلها جاء قوله تعالى: <span class="qpc-hafs">﴿حُرِّمَتْ عَلَيْكُمْ أُمَّهَاتُكُمْ وَبَنَاتُكُمْ وَأَخَوَاتُكُمْ﴾</span> إلى آخر الآية 23 من سورة النساء.سورة النمل: 88. <span class="qpc-hafs">﴿وَتَرَى الْجِبَالَ تَحْسَبُهَا جَامِدَةً وَهِيَ تَمُرُّ مَرَّ السَّحَابِ صُنْعَ اللَّهِ الَّذِي أَتْقَنَ كُلَّ شَيْءٍ إِنَّهُ خَبِيرٌ بِمَا تَفْعَلُونَ﴾</span>.انظر: "كتاب سيبويه" 1/ 381، و"المسائل الحلبيات" 303، وانظر: تفسير قوله تعالى: <span class="qpc-hafs">﴿كِتَابًا مُّؤَجَّلاً﴾</span> [الآية: 145].
  3,196,"<div class=ar lang=ar><p>قوله تعالى: <span class="qpc-hafs">﴿لَا يَغُرَّنَّكَ تَقَلُّبُ الَّذِينَ كَفَرُوا فِي الْبِلَادِ﴾</span></p><p>قال المفسرون: نزلت {1} في مشركي مَكَّة، وذلك أنهم كانوا يَتَجَبَّرُون {2} وَيتَنَعَّمُون. فقال بعض المؤمنين: إن {3} أعداء الله فيما نرى من الخير، وقد هَلَكْنَا من الجُوعِ والجَهْدِ، فنزلت هذه الآية.</p><p>وقال الفراء {4}: كانت اليهود تضرب في الأرض فَتُصِيبُ الأموالَ، فأنزل {5} الله: <span class="qpc-hafs">﴿لَا يَغُرَّنَكَ﴾</span> {6}.</p><p>قال الزجاج {7}: خطاب النبي ﷺ، خطاب الخَلْقِ في هذا الموضع؛ المعنى: لا يَغُرَّنَّكم أيها المؤمنون. وهذا قول قتادة {8}. قال: والله ما غَرُّوا نَبِيَّ اللهِ، حتى قبضه الله. والخطاب له، والمراد غيره {9}.</p><p>وقال بعض النَحْوِيِّين {10}: هذا خطابٌ لكل من سمعه من المكلفين؛ كأنه قيل: لا يَغُرَّنك أيُّها السامِعُ.</p><p>وُيبْنى المضارعُ مع النون الشديدة؛ لأن النون لحقت حرفَ الإعراب، على جهة التأكيد، فصار بمنزلة ضمِّ الاسم إلى الاسم في (خَمْسَةَ عَشَرَ)، ونحوه.</p><p>وقوله تعالى: <span class="qpc-hafs">﴿تَقَلُّبُ الَّذِينَ كَفَرُوا فِي الْبِلَادِ﴾</span>.</p><p>يعني: تَصَرُّفهم للتجارات {11}.</p><p>أعلَمَ {12} اللهُ أن ذلك مما لا ينبغي أن يُغْبَطوا به؛ لأن مصيرهم -بكفرهم- إلى النار، ولا خير {13} في نَعِيمٍ {14} بعده النار.</p></div>",footnotes:1:من قوله: (نزلت ..) إلى (.. فأنزل الله <span class="qpc-hafs">﴿لَا يَغُرَّنَّك﴾</span>): نقله -بتصرف يسير- عن "تفسير الثعلبي" 3/ 175أ.</p><p>وممن قال بذلك: مقاتل في "تفسيره" 1/ 323، وذكره أبو الليث في "بحر العلوم" 1/ 325 على أنه معنى الآية، ولم ينص على كونه سببًا في نزولها.</p><p>وذكره المؤلف في "أسباب النزول" 143، والبغوي في "تفسيره" 2/ 154، ولم ينسباه لقائل. وذكره الآلوسي، واستظهره. انظر: "روح المعاني" 4/ 172.في (ج)، و"تفسير الثعلبي": (يتَّجرون)، وكذا هي في: "روح المعاني"، حيث نقل الآلوسيُّ نَصَّ هذه العبارة عن الواحدي، وفيها (يتجرون). وهي أصوب وأليق بالمعنى المراد. والمثبت من (أ)، (ب)، وله وجه كذلك.(إن): ساقطة من (ج).في "معاني القرآن " له 1/ 251.في "معاني القرآن": (فقال الله عز وجل).ذكر هذا السببَ ابنُ الجوزي في "زاد المسير" 1/ 531، ونسبه لابن عباس.</p><p>وذكر ابن الجوزي عن أبي سليمان الدمشقي، أن النبي ﷺ، أراد أن يستلف من بعض اليهود شعيرًا، فأبى إلا على رَهْنٍ، فقال النبي ﷺ: "لو أعطاني لأوفيته، إني لأمينٌ في السماء، أمينٌ في الأرض" فنزلت هذه الآية.في "معاني القرآن" له 1/ 500. نقله عنه بنصه.قوله في: "تفسير الطبري" 4/ 217، و"تفسير ابن أبي حاتم" 3/ 845.(الخطاب له والمراد غيره): العبارة للثعلبي في "تفسيره" 3/ 175 أ.لم أقف عليهم.انظر: "معاني القرآن" للفراء 1/ 251، و"تفسير غريب القرآن" لابن قتيبة 117، و"معاني القرآن" للزجاج 1/ 500، و"تفسير الثعلبي" 3/ 175 أ، و"زاد المسير" 1/ 532.من قوله: (أعلم ..) إلى (.. نعيم بعده النار): نقله -بتصرف يسير- عن: "معاني القرآن" للزجاج 1/ 500 - 501.في (ج): (وأخبر).في "معاني القرآن": (بخير) بدلًا من (في نعيم).
  3,197,"<div class=ar lang=ar><p>فقال: <span class="qpc-hafs">﴿مَتَاعٌ قَلِيلٌ﴾</span> أي: تَقَلُّبُهُم مَتَاعٌ قَلِيلٌ. وقال الفراء {1}: ذلك متاعٌ قليل.</p><p>وقال الزجاج {2}: ذلك الكَسْبُ والرِّبْحُ الذي يربحونه، مَتَاعٌ قليل. وإنما وصفه {3} بالقِلَّةِ؛ لأنه فانٍ مُنْقَطِعٌ؛ ولأنَّهُ {4} -بالإضافة إلى نعيم الآخرة- قليلٌ.</p></div>",footnotes:1:قد يُفْهم قولُ الفراء هذا، من عباراته التي يقول فيها: (كانت اليهود تضرب في الأرض فتصيب الأموال، فقال الله عز وجل: لا يغرنك ذلك. وقوله: <span class="qpc-hafs">﴿مَتَعٌ قَلِيلٌ﴾</span> في الدنيا). "معاني القرآن" 1/ 251. معنى قوله: (ذلك)، أي: ضَرْبُ اليهود في الأرض، متاع قليل.في "معاني القرآن" له 1/ 501. نقله عنه بنصه.في (ب): (وصف).في (ج): (وإنه).
  3,198,"<div class=ar lang=ar><p>قوله تعالى: <span class="qpc-hafs">﴿لَكِنِ الَّذِينَ اتَّقَوْا رَبَّهُمْ﴾</span> الآية. قد ذكرنا التخفيفَ والتشديد في <span class="qpc-hafs">﴿لَكِنِ﴾</span> {1} عند قوله: <span class="qpc-hafs">﴿وَلَكِنَّ الشَّيَاطِينَ كَفَرُوا﴾</span> {2}، ومعناه {3} -ههنا-: الاستدراك بها، خلاف المعنى المتقدم؛ وذلك أن {4} قوله: <span class="qpc-hafs">﴿مَتَاعٌ قَلِيلٌ﴾</span> تَضَمَّنَ: ما لَهُم كثيرُ انتفاع؛ فجاء على ذلك: <span class="qpc-hafs">﴿لَكِنِ الَّذِينَ اتَّقَوْا رَبَّهُمْ﴾</span> لَهُمْ {5} الخلود في النعيم المقيم.</p><p>وقوله تعالى: <span class="qpc-hafs">﴿مِنْ تَحْتِهَا الْأَنْهَارُ﴾</span>. المعنى: مِنْ تحتِ أشجارِهَا وقصورها وأبْنِيَتِها.</p><p>وقوله تعالى: <span class="qpc-hafs">﴿نُزُلًا مِنْ عِنْدِ اللَّهِ﴾</span> النُّزُلُ {6}: ما يُهيّأ لضيف أو لقوم إذا نزلوا موضعًا.</p><p>ويقال: (أقمت لهم نُزُلَهم) ، أي: أقمت لهم غذاءَهم {7}، وما يصلح معه أن ينزلوا {8} عليه. هذا معناه في اللغة {9}.</p><p>وقال الكَلْبيُّ في تفسيره {10}: جزاءً وثوابًا {11}. وانتصابه على المصدر {12}، في قول الزجاج، قال {13}: هو مصدرٌ مُؤَكِّدٌ {14}؛ لأن خلودهم فيها: إنزالهم فيها أو نزولهم {15}.</p><p>وقال الفرّاء {16}: هو نصبٌ على التفسير {17}، كما تقول: (هو لك: هِبَةً وبَيْعًا وَصَدَقَة).</p><p>وقوله تعالى: <span class="qpc-hafs">﴿وَمَا عِنْدَ اللَّهِ خَيْرٌ لِلْأَبْرَارِ﴾</span> أي: مما يَتَقَلَّبُ {18} فيه الكفّار في دار الدنيا. و (الأبرار) {19} يجوز أن يكون واحده (بارٌّ)، مثل: صاحِبٌ وأصحاب. ويجوز أن يكون واحده (بَرٌّ)، وأصلُهُ: (بَرَرٌ) {20}، فأدْغِمَ {21} للتضعيف {22}.</p></div>",footnotes:1:قرأ أبو جعفر بتشديد النون المفتوحة. وقرأ الباقون بالتخفيف. انظر: "المبسوط" لابن مهران 151، و "تفسير الثعلبي" 3/ 175ب، و"زاد المسير" 1/ 532، و"النشر" 2/ 247.سورة البقرة:102. وانظر: "الحجة" للفارسى 2/ 169 - 180.في (ج): (معناه) بدون واو.(أن): ساقطة من (ج).(لهم): زيادة من (ب).النُّزُل، والنُّزْل -بضم الزاي وتسكينها. انظر: "القاموس المحيط" (1062) (نزل).في (ج): (عداوهم).من قوله: (أقمت ..) إلى (.. ينزلوا عليه): هو نص قول الزجاج في: "معاني القرآن" له 4/ 306 عند تفسير الآية 62 من سورة الصافات <span class="qpc-hafs">﴿أَذَلِكَ خَيْرٌ نُزُلًا﴾</span>.انظر هذا المعنى، وبقية المعاني و (نزل) في: "تهذيب اللغة" 4/ 3555، و"المقاييس" 5/ 417، و"مفردات ألفاظ القرآن" 800، و"اللسان" 7/ 4400.في (أ)، (ب): (تفسير)، والمثبت من (ج). وقد أورد قوله هذا: الثعلبي في: "تفسيره": 3/ 175 ب وورد في: "زاد المسير" 1/ 532، ونسبه إلى ابن عباس. ويبدو أنه من رواية الكلبي عنه.انظر: "بحر العلوم" 1/ 325، و"تفسير البغوي" 2/ 154.أي: المفعول المطلق.في "معاني القرآن" له 1/ 501. نقله عنه بنصه.مؤكد: ليس في "معاني القرآن".(أو نزولهم): ليس في "معاني القرآن".في "معاني القرآن" له 1/ 251. نقله عنه بتصرف.(التفسير) من مصطلحات الكوفيين. وهو (التمييز) عند البصريين، ويقال له كذلك: التبيين. وقد يُطلِقُ الفراءُ (التفسير) على المفعول لأجله، أو على بدل المطابقة. ولكنهما ليسا مرادان في هذا الموضع.</p><p>انظر: "همع الهوامع" 3/ 62. و"دراسة في النحو الكوفي" 266 - 228، و"النحو وكتب التفسير" 1/ 189، 190.في (أ): (ينقلب). وفي (ج): غير معجمة. والمثبت من (ب)؛ لأنها أولى وأليق بالمعنى. وكذا وردت في: "الكشاف" 1/ 491، و"تفسير القرطبي" 4/ 322، و"تفسير البيضاوي" 1/ 83من قوله: (والأبرار ..) إلى (للتضعيف) نقله عن "معاني القرآن" للزجاج 1/ 501.(وأصله برر): ساقط من (ج).في (ج): (وأدغم).في "الصحاح"، و"اللسان"، و"المصباح المنير"، و"التاج": أن (الأبرار) جمع (بَرٍّ). و (بَرَرَة) جمع (بارٍّ). انظر: (بر) في: "الصحاح" 2/ 588، و"اللسان" 1/ 253، و"المصباح" 17، و"التاج" 6/ 701.</p><p>وعند الراغب: أن (أبرار) جمع (بار). و (بَرَرَة) جمع (بَرٍّ). انظر: "مفردات ألفاظ القرآن": 115. وتبعه الفيروزآبادى في "بصائر ذوي التمييز" 2/ 213. وانظر: "البرهان" للزركشي 4/ 18، و"عمدة الحفاظ" 45.
  3,199,"<div class=ar lang=ar><p>وقوله تعالى: <span class="qpc-hafs">﴿وَإِنَّ مِنْ أَهْلِ الْكِتَابِ لَمَنْ يُؤْمِنُ بِاللَّهِ﴾</span> الآية.</p><p>اختلفوا في نزولها؛ فقال ابن عباس {1}، وجابر {2}، وقتادة {3}: نزلت في النَّجَاشيِّ {4} حينَ مات، وصلّى عليه النبيُّ ﷺ بالمدينة. فقال المنافقون: إنه يُصَلِّي على نصرانِيٍّ لم يَرَهُ قَطُّ {5}.</p><p>وقال ابن جُرَيْج {6}، وابن زيد {7}: نزلت في عبد الله بن سَلامٍ وأصحابه.</p><p>وقال مجاهد {8}: نزلت في مؤمِنِي أهلِ الكتابِ، كلِّهم.</p><p>و {9} قال الزجاج {10}: لَمَّا ذكر الذين كفروا من أهل الكتاب في قوله: <span class="qpc-hafs">﴿فَنَبَذُوهُ وَرَاءَ ظُهُورِهِمْ وَاشْتَرَوْا بِهِ ثَمَنًا قَلِيلًا﴾</span> [آل عمران: 187] ذكر حال مَنْ آمَنَ مِنْ أهلِ الكتاب، وأخبر أنهم صَدَقُوا في حال خُشُوعٍ.</p><p>وقوله تعالى: <span class="qpc-hafs">﴿لَا يَشْتَرُونَ بِآيَاتِ اللَّهِ ثَمَنًا قَلِيلًا﴾</span> أي: عَرَضًا مِنَ الدُّنياَ، كفعل اليهود الذين غَيَّروا التوراة بِثَمَن.</p><p>ومعنى: <span class="qpc-hafs">﴿سَرِيعُ الْحِسَابِ﴾</span> -ههنا-: أنه لا يُؤخِّرُ الجزاءَ عَمَّن استحقه؛ لِطُول الحِسَابِ والاشتغال به؛ كما يتأخر {11} لذلك الحقوقُ في الدنيا. ومضى الكلام في معنى سرعة حساب الله {12}.</p></div>",footnotes:1:قوله في: "تفسير الثعلبي" 3/ 1176، و"أسباب النزول" للمؤلف 143.قوله في: "تفسير الطبري" 4/ 218، و"تفسير الثعلبي" 176 أ، و"أسباب النزول" للمؤلف 143، 144.قوله، في: "تفسير عبد الرزاق" 1/ 144، و"تفسير الطبري" 4/ 218 - 219، و"تفسير الثعلبي" 3/ 176 أ، و"أسباب النزول" للمؤلف 143، 144.هو: أصحمة بن أبحر، والنجاشي، لقبه. قال ابن عيينة عن (أصحمة)، (هو بالعربية: عطية). وهو ملك الحبشة، وقد أكرم المسلمين الذين هاجروا إلى بلاده من مكة المكرمة، وأحسن استقبالهم، وأسلم ولم يهاجر. انظر: "تفسير عبد الرزاق" 1/ 144، و"الإصابة" 1/ 109.وبه قال ابن جريج في رواية عنه أخرجها الطبري في "تفسيره" 4/ 2191. وقال به أنس بن مالك، أخرجه عنه النسائي في "تفسيره" 356 رقم (108)، وابن أبي حاتم في "تفسيره" 3/ 846، والمؤلف في: "أسباب النزول" 144، والبزار</p><p>(انظر: "كشف الأستار عن زوائد البزار" 1/ 392 رقم: 832).</p><p>وذكره الهيثمي في "مجمع الزوائد" 3/ 38وزاد نسبة إخراجه للطبراني في "الأوسط"، وقال: (ورجال الطبراني ثقات)، وذكره ابن حجر في "الإصابة" 1/ 109، وزاد نسبة إخراجه لابن شاهين والدارقطني في: الأفراد.</p><p>وانظر: "تفسير ابن كثير" 1/ 481، و"الدر المنثور" 2/ 200.</p><p>وبه قال الحسن البصري. ذكر ذلك ابن كثير في "تفسيره" 1/ 481، ونسب إخراج الأثر عنه إلى عبد بن حميد، وابن أبي حاتم.</p><p>وصلاة الرسول على النجاشي، أخرجها الشيخان، ولكن ليس فيها اعتراض المنافقين، ولا أنه سبب نزول الآية.</p><p>انظر: "صحيح البخاري" (3877) كتاب: مناقب الأنصار. باب: موت النجاشي، و"صحيح مسلم" رقم (951 - 953) كتاب الجنائز. باب: في التكبير على الجنارة. وانظر: "جمع الزوائد" 3/ 38 - 39.قوله في: "تفسير الطبري" 4/ 219، و"تفسير الثعلبي" 3/ 176 ب، و"أسباب النزول" للمؤلف 144.قوله في: المصادر السابقة وبه قال مقاتل في "تفسيره" 1/ 323.قوله في: "تفسير الطبري" 4/ 219، و"تفسير ابن أبي حاتم" 3/ 846، و"تفسير الثعلبي" 3/ 176ب، و"أسباب النزول" للمؤلف173، وهو قول ابن عباس من رواية أبي صالح عنه. انظر:"زاد المسير" 1/ 533. وإلى هذا القول، ذهب الطبري في تفسيره، في الموضع السابق.(الواو): زيادة من (ج).في "معاني القرآن" له 1/ 501. نقله عنه بالمعنى.في (أ)، (ب)، (ج): (يتأخر). والأصل أن يقول: تتأخر. إلا أن المُثبَتَ على معنى: يتأخر قضاء الحقوق.انظر: تفسير الآية: 202 من سورة البقرة.
  3,200,"<div class=ar lang=ar><p>وقوله {1} تعالى: <span class="qpc-hafs">﴿يَا أَيُّهَا الَّذِينَ آمَنُوا اصْبِرُوا﴾</span></p><p>قال الحسن {2}: اصبروا على دينكم فلا تَدَعُوه لِشِدّةٍ. وهذا اختيار الزجّاج {3}.</p><p>وقال زيد بن أسلم {4}: أي: على الجهاد. وهو اختيار ابن الأنباري {5}.</p><p>وقال الفرّاء {6}: <span class="qpc-hafs">﴿اصْبِرُوا﴾</span> مع نَبِيِّكم {7}، <span class="qpc-hafs">﴿وَصَابِرُوا﴾</span> عدُوَّكم، فلا يكونن {8} أصْبَرَ منكم.</p><p><span class="qpc-hafs">﴿وَرَابِطُوا﴾</span>، أي: أقيموا على جهاد عدوكم بالحرب والحُجَّةِ. قاله الزجّاج {9}. وأصلُهُ -عند أهل اللغة-: مِن (مُرابَطَةِ الخَيْل)، وهو ارتباطها بإيزاء العَدُوِّ في بعض الثُّغُور {10}.</p><p>قال ابن قتيبة {11}: أصل (المُرَابَطَةِ) و (الرِّباط): أن يَرْبِطَ هؤلاء خيولَهم في الثَّغْرِ، وَيربط الكفارُ خيولَهم، كلٌّ يُعِدُّ لِصَاحبه، ثم سُمِّيَ المُقامُ بالثغور (رِباطًا)؛ لوجود هذا المعنى {12}.</p><p>وكلام ابن عباس -في رواية عطاء- يَدُلُّ على هذه الجملة، فإنه قال في قوله: <span class="qpc-hafs">﴿وَرَابِطُوا﴾</span> يريد: عَدُوِّي وعدوَّكم. حتى يرجع عن دينه إلى دينكم {13}.</p><p>وهذا اللفظ يتضمن معنى {14} ملازمة الجهاد. وهذا قول أكثر أهل التفسير {15}.</p><p>وقال أبو سَلَمَة بن عبد الرحمن {16}: معنى <span class="qpc-hafs">﴿وَرَابِطُوا﴾</span>: انتظروا الصلاة بعد الصلاة. واحتج {17} بقوله ﷺ في حديث أبي هريرة، حيث ذكر انتظار الصلاة بعد الصلاة- قال: (فَذلِكُمُ الرِّبَاط)، ثلاث مرّات {18}.</p><p>وأصل هذا من الرَّبْط، وهو: الشَّدُّ {19}. ويقال لِكُلِّ مَنْ صَبَرَ على أمْرٍ: (رَبَطَ قَلْبَه عليه)، و (ربط نفسه) {20}.</p><p>قال لَبِيد: رابطُ الجَأْشِ على كُلِّ وَجَلْ {21}</p><p>أي: صابرٌ ثابت. فقيل للصبر على الصلاة وربط النفس عليها: (رِبَاط).</p><p>وقال أبو عبيدة {22}، وابنُ الأنباري {5}: معنى <span class="qpc-hafs">﴿وَرَابِطُوا﴾</span>؛ أي: اثْبُتُوا، وداوموا {24}.</p><p>وأنشد ابنُ الأنباري قولَ الأخْطَل {25}: ما زال فينا رِباطُ الخيْل معْلِمَةً ... وفي كُلَيْبٍ رِباطُ اللُّؤْمِ والعَارِ {26}</p><p>قال: إنما {27} أراد بـ (الرِّبَاط): اللزوم والثبات. وهذا المعنى راجع إلى ما ذكرنا من الصبر ورَبْطِ النفس.</p><p>ثم هذا الثبات والدوام يجوز أن يكون على جهاد العدو، ويجوز أن يكون على الصلاة {28}.</p></div>",footnotes:1:في (ج): (قوله) بدون واو.قوله في: "تفسيرالطبري" 4/ 221، و"تفسير ابن أبي حاتم" 3/ 849، و"تفسير الثعلبي" 3/ 176 ب، و"زاد المسير" 1/ 534.في "معانى القرآن" له 1/ 501.</p><p>وهو قول محمد بن كعب القرظي. انظر: "تفسير الطبري" 4/ 221، و"تفسير ابن أبي حاتم" 3/ 847.</p><p>وهو اختيار الطبري في "تفسيره" 4/ 222 وعلله بقوله: (وذلك أن الله لم يخصص من معاني الصبر على الدين والطاعة شيئًا، فيجوز إخراجه من ظاهر التنزيل، فلذلك قلنا: إنه عنى بقوله: <span class="qpc-hafs">﴿اصْبِرُوا﴾</span>: الأمر بالصبر على جميع معاني طاعة الله، فيما أمر ونهى، صعبها وشديدها، وسهلها وخفيفها).قوله في: "تفسير الطبري" 4/ 222، و"تفسير ابن أبي حاتم" 3/ 848، وأورده السيوطي في "الدر" 2/ 201، 202. وزاد نسبة إخراجه لعبد بن حميد، والبيهقي في "الشعب".</p><p>وأخرجه الحاكم بنفس سند الطبري وابن أبي حاتم، إلا أنه زاد فقال: (.. عن زيد ابن أسلم عن أبيه عن عمر بن الخطاب - رضي الله عنه -) وفيه أن عمر بلغه أن أبا عبيدة حضر بالشام، وتألب عليه الأعداء، فكتب إليه يُصبِّره، وأنهى كتابه لهذه الآية. انظر: "المستدرك" 2/ 300. وصححه، ووافقه الذهبي.لم أقف على مصدر قوله.في "معاني القرآن" له 1/ 251. نقله عنه بنصه.في المعاني: (مع نبيكم على الجهاد).في (ج): (فلا يكون).في: "معاني القرآن"، له: 1/ 501 - 502. نقله عنه بنصه.هذا نص قول الأزهري في: "تهذيب اللغة": 2/ 1346 (ربط).في: "تفسير غريب القرآن"، له: 1/ 109. نقله عنه بتصرف.قال ابن فارس عن الرباط: هو (ملازمة ثَغْرِ العدو، كأنهم رُبطوا هناك، فثبتوا به، ولازموه). "المقاييس" 2/ 478 (ربط). وانظر: "تفسير الطبري" 4/ 222، و"معاني القرآن" للنحاس 1/ 530، و"مفردات ألفاظ القرآن" 338 - 339 (ربط)، و"أساس البلاغة" (316) (ربط).ورد معنى قول ابن عباس في: "زاد المسير" 1/ 534، وأورد الثعلبي في "تفسيره" 3/ 177 أقول عطاء، دون أن يرفعه لابن عباس، وفيه: (<span class="qpc-hafs">﴿وَرَابِطُوا﴾</span>: يعني. المشركين).(معنى): ساقط من (ج).هو قول: قتادة، وابن جريج، والضحاك، ومحمد بن كعب القُرَظي، ومقاتل. انظر: "تفسير الطبري" 4/ 221، 222، و"تفسير مقاتل" 1/ 324.</p><p>وهو الذي رجحه الطبري في "تفسيره" 4/ 223؛ مُعَلِّلًا بأنه: (هو المعنى المعروف من معاني (الرباط)، وإنما يوجه الكلام إلى الأغلب المعروف في استعمال الناس من معانيه، دون الخفي، حتى يأتي بخلاف ذلك -مما يوجب صرفه إلى الخفي من معانيه- حُجةٌ يجب التسليم لها، مِن كتاب، أو خبر من الرسول ﷺ، أو إجماع من أهل التأويل) 4/ 223.قوله في: "المستدرك" للحاكم 2/ 301، و"تفسير الطبري" 4/ 222، وانظر: "تفسير ابن كثير" 1/ 481.من قوله: (واحتج ..) إلى (.. الصلاة بعد الصلاة): ساقط من (ج).الحديث من رواية أبي هريرة. أخرجه مسلم في "الصحيح" رقم (251). كتاب الطهارة، باب فضل إسباغ الوضوء، والترمذي رقم (51، 52) أبواب الطهارة. باب ما جاء في إسباغ الوضوء، وقال: (حسن صحيح)، ومالك في "الموطأ" ص 118 (58) كتاب قصر الصلاة في السفر، باب انتظار الصلاة والمشي إليها.في (ج): (الشدة).انظر: (ربط): "تهذيب اللغة" 2/ 1346، و"مقاييس اللغة" 2/ 78، و"تفسير الثعلبي" 3/ 177 أ.في (ب): (رجل).</p><p>وهذا عجز بيت، وصدره:</p><p>يُسْئِدُ السَّيْرَ عليها راكبٌ</p><p>البيت في: "ديوانه" 176. وورد منسوبًا له في: "تهذيب اللغة" 2/ 1591 (سأد)، و"الصحاح" 2/ 482 (سأد)، و"تفسير الثعلبي" 3/ 177 أ، و"اللسان" 3/ 1905.</p><p>ومعنى (يُسْئِد): يُغذُّ ويسرع السَّيْرَ. يقال: (أسْأدَ الرجلُ السَّيْرَ): أدْأبَهُ. و (الإسآد): الإسراع والإغذاذُ في السير، وأكثر ما يستعمل ذلك في سير الليل. وعن أبي عمرو: الإسآد: أن تسير الإبلُ الليل مع النهار. و (الوَجَلُ): الخوف.</p><p>انظر (سأد) في: "الصحاح" 2/ 482، و"اللسان" 3/ 1905، و"القاموس" (1067) (وجل).في: "مجاز القرآن" 1/ 112.لم أقف على مصدر قوله.في "مجاز القرآن": ودوموا. وورد قول أبي عبيدة في: "تفسير الثعلبي" 3/ 177 أ، وفيه: (داوموا)، كما هي عند المؤلف.هو: غياث بن غوث بن الصلت، أبو مالك التغلبي. شاعر نَصْراني، ومات على نَصْرانِيَّتِه، كان مُقَدَّمًا عند خلفاء بني أمية، لكثرة مدحه لهم وانقطاعه إليهم. توفي سنة (90 هـ).</p><p>انظر. "شرح شواهد المغني" 1/ 123، "الأعلام" 5/ 123.البيت في "شعره" 635. وورد منسوبًا له في: "الصحاح" 5/ 1990 (علم)،</p><p>و"اللسان" 5/ 3084 (علم).</p><p>وورد غير منسوب في: "أساس البلاغة" 1/ 316.</p><p>قوله: (مُعْلِمة) -بكسر اللام، وهكذا ضبطت في شعره، والصحاح، و"اللسان"-: هي من قولهم: (أعْلَمَ الفارِسُ): جعل لنفسه علامة الشجعان. فهو مُعْلِم. والخيل المُعلِمة: المشهورة التي لها علامة في الحرب.</p><p>وفي "مجاز القرآن": (مُعْلَمَة) -بفتح اللام-: وهي للبناء للمجهول، من قولهم: (أعْلَمَ الفَرَسَ): عَلَّق عليه صوفًا أحمر أو أبيض في العرب. انظر: "اللسان" 5/ 3084 (علم).</p><p>وكُلَيب: هم رهط جرير، الذي يهجوه الأخطلُ في هذا البيت.(إنما): ساقط من (ج).والراجح أن (الرباط) -المذكور في الآية- معنيٌّ به المرابطة في الجهاد. وهو ما رجحه ابن جرير، وأكثر المفسرين. وقول رسول الله ﷺ: (فذلكم الرباط ..) إنما هو تشبيه المحافظة على الصلاة؛ بملازمتها والدوام عليها، والرباط في سبيل الله؛ بجامع ما في الأمرين من دوام ولزوم وانتظار. انظر: "المحرر الوجيز" 3/ 477.