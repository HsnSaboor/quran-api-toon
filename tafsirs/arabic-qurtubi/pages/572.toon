  72,6,"72:3"
  72,7,"72:3"
  72,8,"<div class=ar lang=ar><p>وقال الكلبي: يقول: أتينا السماء {1}.</p><p>قال أبو علي: تأويله عالجنا غيب السماء، ورمنا استراقه فنلقيه إلى الكهنة {2}، وليس من اللمس بالجارحة في شيء {3} لم أعثر على مصدر لقوله.]]. وهذا معنى قول الكلبي (¬3).</p><p>وقوله تعالى: <span class="qpc-hafs">﴿فَوَجَدْنَاهَا مُلِئَتْ حَرَسًا شَدِيدًا وَشُهُبًا﴾</span> {4} قال ابن عباس {5}، ومقاتل {6}: يعني الملائكة.</p><p>والحرس: جمع حارس. و <span class="qpc-hafs">﴿شَدِيدًا﴾</span> يراد به الكثرة، وذكرنا في مواضع أن فعيلًا قد يكون للكثير {7}.</p><p>وقوله: <span class="qpc-hafs">﴿وَشُهُبًا﴾</span> قال ابن عباس: يريد النار التي يرجم بها من استرق السمع {8}.</p><p>وقال الكلبي: ورُمينا بالنجوم (¬9)، وهذا كقوله: <span class="qpc-hafs">﴿فَأَتْبَعَهُ شِهَابٌ ثَاقِبٌ﴾</span> [الصافات: 15]، وقد مر، وذكرنا الكلام في هذا عند قوله: <span class="qpc-hafs">﴿رُجُومًا لِلشَّيَاطِينِ﴾</span> (¬10)، ...</p><p>وفي آيات غيرها {9}.</p><p>قال الكلبي: ولم تكن تحرس السماء في الفترة بين عيسى ومحمد -عليهما السلام- خمسمائة عام، فلمَّا بعث محمد -ﷺ- مُنعوا من السموات كلها، وحرست بالملائكة والشهب، فعند ذلك قالوا: <span class="qpc-hafs">﴿وَأَنَّا لَمَسْنَا السَّمَاءَ﴾</span> [الجن: 14] {10} الآية.</p><p>وذكر المفسرون {11}: أن الانقضاض الذي رُميت به الشياطين حدث بعد مبعث النبي، وهو أحد آياته، ويدل على هذا قوله: <span class="qpc-hafs">﴿وَأَنَّا كُنَّا نَقْعُدُ مِنْهَا﴾</span> [الجن: 9] الآية، أي كنا نسمع، فالآن حين حاولنا الاستماع رُمينا بالشهب. وهو قوله: <span class="qpc-hafs">﴿يَجِدْ لَهُ شِهَابًا رَصَدًا﴾</span>.</p><p>قال مقاتل: يعني رميًا من الكواكب، ورصدًا من الملائكة {5}.</p><p>قال أبو إسحاق: أي حفظة تمنع من الاستماع {13}.</p><p>وعلى هذا يجب أن يكون التقدير: شهابًا، ورصدًا؛ لأن الرصد غير الشهاب، وهو جمع راصد {14}.</p><p>وقال الفراء {15}، وابن قتيبة {16}: أي شهابًا قد أرصد له ليرجم به.</p><p>وعلى هذا الرصد من نعت الشهاب، وهو فَعَل بمعنى مفعول، كالنَّفَضِ والخيط.</p><p>روى عبد الرزاق عن مَعمر قال: قلت للزهري: أكان يُرمى بالنجوم في الجاهلية، قال: نعم، قلت: أفرأيت قوله: <span class="qpc-hafs">﴿وَأَنَّا كُنَّا نَقْعُدُ مِنْهَا مَقَاعِدَ لِلسَّمْعِ﴾</span> الآية، فقال: غلظت، وشدد أمرهَا حين بُعث النبي -ﷺ- {17}.</p><p>وروي أيضًا مرفوعًا ما يدل على هذا، وهو ما روي عن ابن عباس أنَّه قال: بينا رسول الله -ﷺ- جالس في نفر من الأنصار إذ رمي بنجم، فقال: "ما كنتم تقولون في مثل هذا في الجاهلية؟ " فقالوا {18}: كنا نقول يموت عظيم، أو يولد {19} عظيم {20} الحديث.</p><p>قال ابن قتيبة: وهذا يدل {21} على أن الرجم قد كان قبل مَبْعثه ولكنه لم يكن مثله في شدة الحراسة بعد مبعثه، وكانت تسترق في بعض الأحوال، فلما بُعث منعت من ذلك أصلًا. وعلى هذا وجدنا الشعر القديم، قال بِشر ابن أبي خازم، وهو جاهلي:</p><p>والعَيْرُ يُرْهِقُها الغُبِارُ وجَحْشُها ... يَنْقَضُّ خَلْفَها انْقِضَاضَ الكَوْكَبِ {22}</p><p>وقال أوس بن حجر، جاهلي:</p><p>فانْقَضَّ {23} كالدُّرِّي يَتْبَعُه ... نَقْعٌ يَثُورُ تَخَالُهُ طُنُبا {24} {25} ثم قالوا: <span class="qpc-hafs">﴿وَأَنَّا لَا نَدْرِي أَشَرٌّ أُرِيدَ بِمَنْ في الْأَرْضِ﴾</span>، أي: بحدوث الرجم بالكواكب، وحراسة السماء من استراق السمع، أريد شرًّا {26} بأهل الأرض أم صلاح. وهو قوله: <span class="qpc-hafs">﴿أَمْ أَرَادَ بِهِمْ رَبُّهُمْ رَشَدًا﴾</span>.</p><p>(هذا معنى أكثر المفسرين {27}، وأهل التأويل {28}) {29}.</p><p>قال مقاتل: <span class="qpc-hafs">﴿أَشَرٌّ أُرِيدَ بِمَنْ في الْأَرْضِ﴾</span> يعني بإرسال محمد -ﷺ- إليهم فيكذبوه، فيهلكوا كما هلك من كذب من الأمم الخالية، أراد أن يؤمنوا فيهتدوا {30}.</p><p>والمراد بـ: "الشر"، و"الرشد" على هذا القول: الكفر والإيمان {31}.</p><p>وقال ابن زيد: قالوا: لا ندري أعذاب أراد الله أن ينزله بأهل الأرض فمُنَعنا، أم أراد بهم الهدى بأن يبعث فيهم رسولاً. وهذا معنى القول الأول {32}.</p><p>ثم أخبر عن أحوالهم فقال: <span class="qpc-hafs">﴿وَأَنَّا مِنَّا الصَّالِحُونَ﴾</span>، أي: المؤمنون المخلصون. <span class="qpc-hafs">﴿وَمِنَّا دُونَ ذَلِكَ﴾</span>: دون الصالحين، يعنون الكفّار في قول مقاتل {33}، والكلبي {34}، ومجاهد {35}.</p><p>(وهو اختيار الفراء {36}، والزجاج {37}).</p><p>وقال ابن قتيبة: <span class="qpc-hafs">﴿وَأَنَّا مِنَّا الصَّالِحُونَ﴾</span> بعد استماع القرآن، <span class="qpc-hafs">﴿وَمِنَّا دُونَ ذَلِكَ﴾</span> أي منا بررة أتقياء، ومنا دون البررة، وهم مسلمون {38}، فجعل الفريقين جميعًا مسلمين، ولكن بعضهم دون بعض؛ وهذا قول السدي عن ابن عباس {39}. هذا كله معنى قوله:</p><p><span class="qpc-hafs">﴿كُنَّا طَرَائِقَ قِدَدًا﴾</span>، أي: أصنافًا، وضروبًا مختلفة، إمَّا مؤمنون، وكافرون، على القول الأول، وإمَّا مخلصون بررة ودونهم.</p><p>قال السدي: الجنُّ أمثالكم، فيهم قدرية، ومرجئة {40}، ورافضة {41}، وشيعة {42} {43}</p><p>وقال أبو عبيدة: في قوله: <span class="qpc-hafs">﴿طَرَائِقَ قِدَدًا﴾</span>، (أي) {44}: ضروبًا، وأجناسًا، ومللًا {45} {46}، وأنشد الكميت:</p><p>جمعت بالري منهم كل رافضة ... إذ هم طرائق في أهوائهم قددُ {47} {48}</p><p>وقال أبو إسحاق: وكنا جماعات متفرقين {49}.</p><p>وقال الفراء: كنا فرقًا مختلفة [أهواؤنا] {50}.</p><p>وقال ابن قتيبة: كنا أصنافًا وفرقًا {51}.</p><p>وذكرنا معنى الطريقة عند {52} قوله: <span class="qpc-hafs">﴿وَيَذْهَبَا بِطَرِيقَتِكُمُ الْمُثْلَى﴾</span> {53}.</p><p>والقدة: القطعة من الشيء، وصَار القوم قددًا إذا تفرقت أحوالهم {54} وأهواؤهم {55}.</p><p>وقال المبرد {39}: "الطرائق": الأجناس المتفقة، والمختلفة، وهو مأخوذ من الطريق، وهو تأكيد له -هاهنا- ويقال: القوم طرائق، أي على مذاهب شتى، والقدد نحو الطرائق، وهو تأكيد لها -هاهنا- يقال: لكل طريقة قدة. وأصله من قد السّيور {57}، يقال: صار الأديم قددًا.</p><p>ثم قالوا: <span class="qpc-hafs">﴿وَأَنَّا ظَنَنَّا﴾</span> هو قال ابن عباس {39}، والمفسرون {59}: عَلِمْنا وأيقنا.</p><p><span class="qpc-hafs">﴿أَنْ لَنْ نُعْجِزَ اللهَ في الْأَرْضِ﴾</span>، أي: لن نفوته إن أراد بنا أمرًا، ولن نسبقه.</p><p><span class="qpc-hafs">﴿وَلَنْ نُعْجِزَهُ هَرَبًا﴾</span> إن طلبنا، أي أنَّه يدركنا (حيث كنَّا) {60} ثم قال:</p><p>قوله تعالى: <span class="qpc-hafs">﴿وَأَنَّا لَمَّا سَمِعْنَا الْهُدَى﴾</span> قال ابن عباس: الذي جاء به محمد -ﷺ- كله هدى {61}. وقال مقاتل: يعني القرآن {62}.</p><p><span class="qpc-hafs">﴿آمَنَّا بِهِ﴾</span> صدقنا أنَّهُ من عند الله.</p><p><span class="qpc-hafs">﴿فَمَنْ يُؤْمِنْ بِرَبِّهِ﴾</span> يصدق بتوحيد الله.</p><p><span class="qpc-hafs">﴿فَلَا يَخَافُ بَخْسًا﴾</span> نقصًا من عمله وثوابه {63}.</p><p><span class="qpc-hafs">﴿وَلَا رَهَقًا﴾</span> ظلمًا، بأن يذهب عمله كله {64}؛ قاله الكلبي {39} ومقاتل {62}) {29}، وقال عطاء {39}: <span class="qpc-hafs">﴿رَهَقًا﴾</span>: عذابًا.</p><p>قال المبرد: البخس {69} الظلم، والرهق {70}: ما يغشاه من المكروه {39}، فيدخل فيه العذاب، ونقصان الحسنات، والثواب.</p><p>وقالوا: <span class="qpc-hafs">﴿وَأَنَّا مِنَّا الْمُسْلِمُونَ﴾</span> هم الذين آمنوا بالنبي -ﷺ-؛ قاله {72} ابن عباس {39} والمفسرون {74}.</p><p><span class="qpc-hafs">﴿وَمِنَّا الْقَاسِطُونَ﴾</span> وهم الجائرون {75} الظالمون {76} الكافرون {77}.</p><p>قال ابن عباس: وهم الذين جعلوا لله نِدًّا، وعدلوا به مخلوقًا {78}.</p><p>وذكرنا معنى "قسط" و"أقسط" في أول سورة النساء {79}.</p><p>ثم مدحوا الإيمان وقالوا: <span class="qpc-hafs">﴿فَمَنْ أَسْلَمَ فَأُولَئِكَ تَحَرَّوْا رَشَدًا﴾</span>، أي: قصدوا طريقا الحق {80}.</p><p>وقال أبو عبيدة: (تحروا توخوا وتعمدوا، وأنشد: دِيمةٌ هَطلا {81} فيها وَطَفٌ ... طَبَقُ الأرض تحري وتَدِرْ {82}) {83}</p><p>وقال الليث: (يُقال) {84}: هو يتحرى بكلامه وأمره الصَّواب، وكذلك يتحرى مسرة فلان {39}.</p><p>وقال الفراء: <span class="qpc-hafs">﴿تَحَرَّوْا رَشَدًا﴾</span> الهدى {86}.</p><p>قال المبرد: وأصل التحري من قولهم: ذلك أحرى، أي أحق وأقرب.</p><p>والحري {87} أن يفعل كذا، أي يجب عليك، كما تقول: يحق عليك أن تفعل {88}، ويقال: لا تَطُرْ حَرانا أي القرب الذي تحر أحق به {89}.</p><p>ثم ذموا الكافرين فقالوا: <span class="qpc-hafs">﴿وَأَمَّا الْقَاسِطُونَ﴾</span>. الآية. أي الذين كفروا وعدلوا بربهم كانوا وقوداً للنار في الآخرة يصلونها {90}.</p><p>وانقطع -هاهنا- كلام {91} الجن {92}.</p><p>قال مقاتل: ثم رجع إلى كفار مكة {93}، قوله تعالى: <span class="qpc-hafs">﴿وَأَلَّوِ اسْتَقَامُوا عَلَى الطَّرِيقَةِ﴾</span> {94} "أن" مخففة من الثقيلة، وفصل (لو) {95} بينها وبين الفعل {96} كفصل {97} السين {98} و"لا" في قوله: <span class="qpc-hafs">﴿أَلَّا يَرْجِعُ إِلَيْهِمْ قَوْلًا﴾</span> [طه: 89]، و <span class="qpc-hafs">﴿عَلِمَ أَنْ سَيَكُونُ﴾</span> [المزمل: 20]، وهو محمول على الوحي، كأنَّهُ أوحي إلى أن لو استقاموا على الطريقة) {99}.</p><p>قال ابن عباس: يريد طريقة الإسلام {100}.</p><p>وهو قول مقاتل {101}، (وإبراهيم {102}) {84}، ومجاهد {104}، وقتادة {105}، قالوا: معناه لو آمنوا واستقاموا على الهدى <span class="qpc-hafs">﴿لَأَسْقَيْنَاهُمْ مَاءً غَدَقًا﴾</span>، أي: كثيرًا.</p><p>قال عطاء: يريد لأغدقت لهم في النعيم والمعيشة {39}.</p><p>وقال مقاتل: يعني ماءً كثيرًا من السماء، وذلك بعد {107} ما رفع عنهم المطر سبع سنين {108}. وقال سعيد بن جبير: هو المال {109}.</p><p>وقال مجاهد: مالاً كثيرًا {110}. وقال {111} السدي: الماء الكثير {39}.</p><p>وهذا معنى ما روي عن عمر {113} (رضي الله عنه) {114} قال: حيث كان الماء كان المال، وحيث كان المال كانت الفتنة {115}.</p><p>وقال ابن قتيبة (أي: لو آمنوا جميعًا لوسعنا عليهم في الدنيا، وضرب الماء الغدق -وهو الكثير- لذلك مثلاً؛ لأن الخير كله والرزق بالمطر (يكون) {95}، فأقيم مقامه إذ كان سببه) {117}.</p><p>(ودليل هذا التأويل قوله تعالى: <span class="qpc-hafs">﴿وَلَوْ أَنَّ أَهْلَ الْقُرَى آمَنُوا وَاتَّقَوْا﴾</span> {118} الآية [الأعراف: 96]) {119}.</p><p>وتفسير الغدق عند أهل اللغة: الماء الكثير، يقال غَدِقَتْ العين -بالكسر- فهي غَدِقة، والغدق: (الماء الكثير) {107} {121}. قال المبرد: روضة مغدقة إذا كانت ريًّا من الماء {122}، ومن هذا يقال: مطر مغدوق، وغيداق، وغيدق إذا كان كثير الماء {39}.</p><p>هذا الذي ذكرنا في (تفسير) {95} الآية هو قول أكثر المفسرين: سعيد ابن المُسَيِّب {107}، وعطاء، وعطية، (والضحاك، والحسن {74}) {29}.</p><p>وقال الكلبي: وأن لو استقاموا على الطريقة يعني على طريقة الكفر، وكانوا كفارًا كلهم {128}. وهذا قول الربيع {129}، وزيد بن أسلم {130}، والثمالي {131}، (وأبي مجلز) {29} {133}، واختيار الفراء {134}، وابن كيسان {135}، قالوا: وأن لو استقاموا جميعًا على طريقة الكفر لوسعنا عليهم، وجعلنا ذلك فتنة عليهم، ودليل هذا التأويل قوله: <span class="qpc-hafs">﴿وَلَوْلَا أَنْ يَكُونَ النَّاسُ أُمَّةً وَاحِدَةً﴾</span> الآية.</p><p>قال أبو إسحاق: والذي يختار أن يكون: يعني بالطريقة طريقة الهدى؛ لأن الطريقة مُعَرَّفَة بالألف واللام، فالأوجب أن يكون طريقة الهدى، والله أعلم {136}.</p><p>وتمام هذا الكلام عند قوله: <span class="qpc-hafs">﴿لِنَفْتِنَهُمْ فِيهِ﴾</span> {137} (أي لنختبرهم فنعلم كيف شكرهم) {138}. هذا على القول الأول. (وعلى القول الثاني: نقول لو كانوا كفاراً كلهم وثبتوا على طريقة الكفر لوسعنا عليهم؛ فتنةً لهم، واستدراجًا) {139}.</p><p>قال الفراء: نفعل ذلك بهم ليكون فتنةً عليهم في الدنيا وزيادةً في عذاب الآخرة {15}.</p></div>",footnotes:1:"الوسيط" 4/ 365.|2:الكهنة: جمع كاهن، وهو الذي يتعاطى الخبر عن الكائنات في مستقبل الزمان، ويدّعي معرفة الأسرار. "لسان العرب" 13/ 363، مادة: (كهن)، و"النهاية في غريب الحديث والأثر" 4/ 214.|3:و [[كلمة (شهبا) ساقطة من: (ع).|4:"الدر المنثور" 8/ 303 وعزاه إلى ابن مردويه.|5:"تفسير مقاتل" 211/ ب.|6:نحو ما جاء في قوله: <span class="qpc-hafs">﴿لَا يَأْتُونَ بِمِثْلِهِ وَلَوْ كَانَ بَعْضُهُمْ لِبَعْضٍ ظَهِيرًا﴾</span> [الإسراء: 88]، وقوله <span class="qpc-hafs">﴿وَكَانَ الْكَافِرُ عَلَى رَبِّهِ ظَهِيرًا﴾</span> [الفرقان: 55].|7:و (¬9) لم أعثر على مصدر لقوله.|8:سورة الملك: 5: <span class="qpc-hafs">﴿وَلَقَدْ زَيَّنَّا السَّمَاءَ الدُّنْيَا بِمَصَابِيحَ وَجَعَلْنَاهَا رُجُومًا لِلشَّيَاطِينِ وَأَعْتَدْنَا لَهُمْ عَذَابَ السَّعِيرِ (5)﴾</span>. وقد جاء في تفسيرها: قال ابن عباس: يرجم بها الشياطين == الذين يسترقون السمع. قال أبو علي: فإن قيل: كيف يجوز أن تكون المصابيح زينة مع قوله: (وجعلناها رجومًا للشياطين فالقول إنها جعلت لهم لم تزل فتزول الزينة بزوالها، ولكن يجوز أن ينفصل منها نور يكون رجمًا للشياطين، كما ينفصل من السرج، وسائر ذوات الأنوار ما لا يزول بانفصالها منها صورتها. وهذا كما قال بعض أهل العربية: ينفصل من الكوكب شهاب نار، وهذا كقوله: "ولقد جعلنا في السماء بروجًا" الآية.</p><p>ومعنى لفظ الشهاب: الشُّعلة الساطعة من النار الموقدة، ومن العارض في الجو، نحو: "فأتبعه شهاب ثاقب". "المفردات في غريب القرآن" 467.</p><p>وقال أبو حيان: "شهاب": كوكب متوقد مضيء. "تحفة الأريب" 182.</p><p>وقال ابن فارس: "شهب" الشين والهاء والباء أصل واحد يدل على بياض في شيء من سواد لا تكون الشهة خالصة بياضًا .. ، ومن الباب الشهاب، وهو شُعلة نار ساطعة "معجم مقاييس اللغة" 3/ 220، مادة: (شهب)، وانظر: "لسان العرب" 1/ 508 مادة (شهب).|9:نحو ما جاء في سورة الحجر: 18 عند قوله تعالى: <span class="qpc-hafs">﴿إِلَّا مَنِ اسْتَرَقَ السَّمْعَ فَأَتْبَعَهُ شِهَابٌ مُبِينٌ (18)﴾</span>. جاء في تفسير الشهاب: "قال الواحدي: والشهاب: شعلة نار ساطع، ثم يسمى الكوكب شهابًا، والسنان شهابًا لبريقهما يشبهان النار".</p><p>وقال ابن عباس في قوله: (بشهاب مبين): يريد نارًا تنير لأهل الأرض.</p><p>قال المفسرون: إن الشهاب لا تخطئه أبدًا، وإنهم ليرمون فإذا توارى عنكم فقد أدركه. وقال أصحاب المعاني: إن الله تعالى سمى ما ترجم به الشياطين شهابًا، وهو في اللغة النار الساطعة، ونحن في رأي الحين نرى كأنهم يرمون بالنجوم، فيجوز أن ذلك كما نرى، ثم يصير نارًا إذا أدرك الشيطان، ويجوز أنهم يرمون بشعلة نار من الهواء، ولكن لبعده عما يخيل إلينا أنه نجم. والله أعلم بحقيقة ذلك.|10:ورد بنحوه في "الجامع لأحكام القرآن" 19/ 11.|11:قال بذلك قتادة، وابن زيد، وابن عباس، وأبي بن كعب، وعبد الله بن عمر، انظر: "جامع البيان" 29/ 111، و"التفسير الكبير" 30/ 158، و"القرطبي" 19/ 12، و"الدر المنثور" 8/ 302 وعزاه إلى عبد بن حميد عن ابن عباس، ويؤيد هذا القول الحديث عن سعيد بن جبير عن ابن عباس قال: كان الجن يصعدون إلى السماء يسمعون الوحي، فإذا سمعوا الكلمة زادوا فيها تسعًا، فأمَّا الكلمة فتكون حقًّا، وأمَّا ما زاد فيكون باطلاً، فلما بعث رسول الله -ﷺ- مُنِعوا مقاعدهم، فذكروا ذلك لإبليس، ولم تكن النجوم يُرمى بها قبل ذلك، فقال لهم إبليس: ما هذا إلا من أمر قد حدث في أرض، فبعث جنوده فوجدوا رسول الله -ﷺ- قائمًا يصلي بين جبلين، أراه قال: بمكة، فأتوه فأخبروه، فقال: هذا الذي حدث بالأرض.</p><p>أخرجه الترمذي في سننه وقال: هذا حديث حسن صحيح، 5/ 427 - 428 ح 3324، كتاب التفسير: باب ومن سورة الجن: 70.|12:"تفسير مقاتل" 211/ ب.|13:"معاني القرآن وإعرابه" 5/ 234 بنصه.|14:الرصد في اللغة: قال ابن فارس: الراء والصاد والدال أصل واحد، وهو التهيؤ لِرقبة شيء على مَسْلَكِه، ثم يحمل عليه ما يشاكله. "معجم مقاييس اللغة" 2/ 400، مادة == (رصد). وفي "الصحاح" الراصد للشيء: المراقب له، والرَّصَدُ: القوم يَرصدون كالحرس. 2/ 474 مادة: (رصد).|15:"معاني القرآن" 3/ 193 بنصه.|16:"تفسير غريب القرآن" 489.|17:"تأويل مشكل القرآن" 429، و"بحر العلوم" 3/ 412، و"الكشاف" 4/ 147، و"الجامع" للقرطبي 12/ 19، و"فتح القدير" 5/ 305 - 306، و"الكشاف" 29/ 87.|18:في (أ): فقال.|19:غير واضحة في: (أ).|20:الحديث أخرجه مسلم في "صحيحه" 4/ 1750: ح 124، كتاب السلام: باب 35، تحريم الكهانة وإتيان الكهان، ونص الحديث كما هو عنده: "عن ابن شهاب حدثني علي بن حسين أن عبد الله بن عباس قال: أخبرني رجل من أصحاب النبي -ﷺ- من الأنصار أنهم بينما هم جلوس ليلة مع رسول الله -ﷺ- رمي بنجم فاستنار، فقال لهم رسول الله -ﷺ-: "ماذا كنتم تقولون في الجاهلية إذا رُمي بمثل هذا؟ " قالوا: الله ورسوله اعلم، كنا نقول. وُلِدَ الليلة رجل عظيم، ومات رجل عظيم. فقال == رسول الله -ﷺ- "فإنها لا يُرمى بها لموت أحد ولا لحياته، ولكن ربنا تبارك وتعالى اسمه إذا قضى أمرًا سبح حملة العرش" .. الحديث.</p><p>كما أخرجه الترمذي في "سننه" 5/ 362: ح 3224، كتاب التفسير، ومن سورة سبأ: 35، قال أبو عيسى: (هذا حديث حسن صحيح).</p><p>وما أورده الإمام الواحدي فنقلًا عن "تأويل مشكل القرآن" لابن قتيبة: 430.|21:وردت في "تأويل مشكل القرآن" المطبوع بلفظ: (لِنَدُلَّ).|22:ورد البيت في "ديوانه" 37، و"كتاب المعاني الكبير" 2/ 739، و"الحيوان": لأبي عثمان الجاحظ: 6/ 273، برواية (الخبار) بدلًا من (الغبار)، و (خلفهما) بدلًا من (خلفها)، و"الكشاف" 29/ 87 برواية: (خلفهما).</p><p>معنى البيت: الخبار: أرض لينة رخوة تسوخ فيها القوائم. شبه الجحش بالكوكب المنقضّ في سرعته وبياضه. "ديوانه": 37. حاشية.|23:وانقض: هكذا وردت عند ابن قتيبة في التأويل.|24:ورد البيت في ديوانه: 3، برواية: (وانقض)، و"الحيوان" 6/ 274، "كتاب المعاني الكبير" 2/ 739، و"النكت والعيون" 6/ 112، و"التفسير الكبير" 3/ 157، و"المحرر الوجيز" 5/ 381، وعزاه إلى عوف بن الجزع، و"الجامع لأحكام القرآن" 12/ 19، و"الكشاف" 29/ 87 (وانقض).</p><p>ويراد بالنقع: الغبار الساطع. الدريّ: الكوكب المنقض يدرأ على الشيطان. تخاله طنبًا: يريد تخاله فسطاطًا مضروبًا. ديوانه: 3 حاشية.|25:ما بين القوسين من قول ابن قتيبة؛ نقله عنه الواحدي بتصرف يسير جدًّا. انظر: == "تأويل مشكل القرآن" ص 430.|26:وردت مكررة في النسخة: أ.|27:قال بذلك: ابن زيد، انظر قوله في "جامع البيان" 29/ 111، و"النكت والعيون" 6/ 112، و"الجامع لأحكام القرآن" 19/ 13.</p><p>كما قال به ابن قتيبة في "تأويل مشكل القرآن" 431، ورجحه الطبري في "جامع البيان" مرجع سابق، وقاله أيضًا السمرقندي في "بحر العلوم" 3/ 412، وإليه ذهب البغوي في "معالم التنزيل" 4/ 403، وعزاه القرطبي إلى الأكثرين من المفسرين. وهذا القول أحد القولين للآية، وهو القول الأول.|28:قاله الفراء في "معاني القرآن" 3/ 193، والزجاج 5/ 234.|29:ما بين القوسين ساقط من: (أ).|30:"تفسير مقاتل" 211/ ب، و"زاد المسير" 8/ 106، وإلى هذا القول ذهب الكلبي أيضًا، وعزاه الماوردي إلى السدي، وابن جريج، وحكاه ابن عطية في تفسيره. ويعد هذا القول الثاني من القولين في معنى الآية. انظر: "جامع البيان"، و"النكت والعيون" مرجعان سابقان، و"المحررالوجيز" 5/ 381|31:بمعنى أن هذا القول منفصل عن معنى الآية السابقة له.|32:ورد قوله بمعناه في "جامع البيان" 29/ 111، و"الجامع" للقرطبي 13/ 19.|33:"تفسير مقاتل" 211/ ب، بنحوه.|34:كلمة (والكلبي) ساقطة من (أ)، ولم أعثر على مصدر لقوله.|35:"جامع البيان" 29/ 112، و"معالم التنزيل" 4/ 403، و"تفسير القرآن العظيم" 4/ 459، و"الدر المنثور" 8/ 304 وعزاه إلى عبد بن حميد.|36:"معاني القرآن" 3/ 193، وعبارته سابقة لهذه الآية، وذلك عندما تناول تفسير قوله تعالى: <span class="qpc-hafs">﴿وَأَنَّا لَا نَدْرِي أَشَرٌّ أُرِيدَ بِمَنْ في الْأَرْضِ﴾</span>.|37:"معاني القرآن وإعرابه" 5/ 235. والكلام ما بين القوسين ساقط من: (أ).|38:"تأويل مشكل القرآن" 431 نقله عنه الواحدي بنصه.|39:لم أعثر على مصدر لقوله.|40:المرجئة: الإرجاء معناه التأخير، والآخر: إعطاء الرجاء، وإطلاق اسم المرجئة على الجماعة بالمعنى الأول؛ لأنهم كانوا يؤخرون العمل عن النية والعقد، وإما بالمعنى الثاني فظاهر أنهم كانوا يقولون: لا تضر مع الإيمان معصية، كما لا تنفع مع الكفر طاعة. وأول من قال بالقدر والإرجاء: غيلان الدمشقي، ثم الجهم بن صفوان. والمرجئة أربعة أصناف: مرجئة الخوارج، ومرجئة القدر، ومرجئة الجبر، والمرجئة الخالصة. انظر: "شرح أصول الاعتقاد" لللالكائي 1/ 25، و"الفرق بين الفرق" للأسفراييني 25، و"الملل والنحل" للشهرستاني 139، "مختصر لوامع الأنوار البهية" لابن سلوم 76.|41:الرافضة والروافض من فرق الشيعة الباطلة الهدامة المعاندة للأمة الإسلامية، والرافضة لقب أطلقه زيد بن علي بن الحسين على الذين تفرقوا عنه ممن بايعه بالكوفة؛ لإنكاره عليهم الطعن علي أبي بكر وعمر، فرفضه جماعته من الشيعة بسبب ثنائه عليهما، فسموا رافضة.</p><p>ومن أهل السنة من يطلق الوصف على الشيعة عمومًا باستثناء الزيدية.</p><p>ومن فرق الرافضة من أظهر بدعته في زمن علي رضي الله عنه فقال لـ: "علي" أنت الإله، فأحرق علي رضي الله عنه قومًا منهم، ونفى بعضهم. وهذه الفرقة من الروافض ومن شاكلهم يجمعهم إنكارهم للقرآن، والاعتقاد بتحريفه وتغيره، وإنكار السنة النبوية مكفرين أصحاب رسول الله -ﷺ-، وخاصة الخلفاء الراشدين: أبي بكر، وعمر، وعثمان، وغير ذلك من الأمور المنكرة الشنيعة التي ما أرادوا بها إلا إسقاط كلمة تكليف الشريعة عن أنفسهم حتى يتوسعوا في استحلال المحرمات الشرعية، ويعتذروا عند العوام بما يعدونه من تحريف الشريعة، وتغيير القرآن من عند الصحابة، فإنهم ليسوا من الأمة الإسلامية أصلاً.</p><p>انظر: "الفرق بين الفرق" للأسفراييني 21، و"القاموس الإسلامي" لأحمد عطية 2/ 474، و"الشيعة والتشيع فرق وتاريخ" لإحسان إلهي ظهير 45 و47، و"الموسوعة الميسرة" 854.|42:الشيعة: من الفرق الضالة عن الإسلام، ومنهم من لا يمت إلى الإسلام بشيء، قال الشهرستاني عنهم: "هم الذين شايعوا عليًّا رضي الله عنه على الخصوص، وقالوا بإمامته وخلافته نصًّا، ووصيه إما جليًّا أو خفيًّا، واعتقدوا أن الإمامة لا تخرج من أولاده، وإن خرجت فبظلم يكون من غيره، أو بتقية من عنده، وقالوا: ليست الإمامة قضية مصلحية تناط باختيار العامة، وينتصب الإمام بنصبهم؛ بل هي قضية أصولية، وهي ركن الدين، لا يجوز للرسل -عليهم السلام- إغفاله وإهماله، ولا تفويضه إلى العامة وإرساله، ويجمعهم القول بوجوب التعيين والتنصيص، وثبوت عصمة الأنبياء والأئمة وجوبًا عن الكبائر والصغائر، والقول بالتولي والتبري قولًا، وفعلًا وعقدًا إلا في حال التقية.</p><p>وهم خمس فرق: كيسانية، وزيدية، وإمامية، وغلاة، واسماعيلية. وبعضهم يميل في الأصول إلى الاعتزال، وبعضهم إلى السنة، وبعضهم إلى التشبيه.</p><p>وقد تعددت الآراء حول بداية التشيع مذهبًا وحركة، فالشيعة أنفسهم يرجعون بمذهبهم إلى بدايات الإسلام، وآخرون يرجعون إلى الفترة التي تلت وفاة الرسول -ﷺ- مباشرة، واختلاف الناس حول خلافته، ومنهم من يرجع ذلك إلى عهد علي، ومعركة صفين بصفة خاصة. إلخ.</p><p>انظر: "الملل والنحل" للشهرستاني: 146 - 147، و"القاموس الإسلامي" 3/ 217، وانظر: "شرح اعتقاد أهل السنة والجماعة" 1/ 22 - 23، و"الموسوعة العربية العالمية" 14/ 298 - 299.|43:ورد قول السدي هذا في "الكشف والبيان" 12/ 195/ ب، و"معالم التنزيل" 4/ 403، و"زاد المسير" 8/ 106، و"التفسير الكبير" 30/ 159، و"الجامع" للقرطبي 19/ 14، و"تفسير القرآن العظيم" 4/ 459، و"الدر المنثور" 8/ 304، وعزاه إلى أبي الشيخ في العظمة، و"فتح القدير" 5/ 306، وانظر: "تفسير السدي" 464.|44:ساقطة من: (ع).|45:في (أ): ميلًا.|46:النص في: "مجاز القرآن" 2/ 272، ولم يذكر: مللًا.|47:في (أ): قددًا.|48:وورد البيت في: "الدر المصون" 6/ 394، ولم أعثر عليه في ديوانه.</p><p>وورد غير منسوب في "البحر المحيط" 8/ 344 برواية: (الرأي).|49:"معاني القرآن وإعرابه" 5/ 235 بنصه.|50:وردت في النسختين (أ)، (ع): أهوانا، وما أثبتناه من "معاني القرآن" 3/ 193 فالكلام فيه بنصه، وهو الصواب.|51:"تأويل مشكل القرآن" 431 بنحوه، وانظر أيضًا: "تفسير غريب القرآن" 490.|52:في (أ): في.|53:سورة طه: 63: <span class="qpc-hafs">﴿قَالُوا إِنْ هَذَانِ لَسَاحِرَانِ يُرِيدَانِ أَنْ يُخْرِجَاكُمْ مِنْ أَرْضِكُمْ بِسِحْرِهِمَا وَيَذْهَبَا بِطَرِيقَتِكُمُ الْمُثْلَى (63)﴾</span>.</p><p>ومما جاء في تفسيرها: قال عكرمة: يذهبا بخياركم، وقال الحسن وأبو صالح بأشرافكم، وعن مجاهد: أولو العقل والشرف والأسنان، وهذه الأقوال معناها واحد، وهو معنى قول ابن عباس في رواية الوالبي: أمثلكم. قال الزجاج: معناه: جماعتكم الأشراف. قال: والعرب تقول للرجل الفاضل: هذا طريقة قومه ..</p><p>وتأويله: هذا الفتى ينبغي أن يجعله قومه قدوة، ويسلكوا طريقته، وينظروا إليه، ويتبعوه.</p><p>وقال الفراء: العرب تقول للقوم: هؤلاء طريقة قومهم، وطرائق قومهم، لأشرافهم؛ ويقولون للواحد أيضًا: هذا طريقة قومه، ويقولون للجمع بالتوحيد == والجميع، يعني: طريقة، وطرائق، قال: ومن ذلك قولى: <span class="qpc-hafs">﴿طَرَائِقَ قِدَدًا﴾</span>.</p><p>والطريقة اسم للأفاضل، على معنى أنهم الذين يقتدى بهم، ويتبع آثارهم، كما يسلك الطريقة.|54:في (ع): حالاتهم.|55:انظر: مادة (قدد) في "تهذيب اللغة" 8/ 268، و"الصحاح" 2/ 522، و"تاج العروس" 2/ 460.|56:لم أعثر على مصدر لقوله.|57:قال الليث: والقِدُّ: سير يُقَدُّ من جلد غير مدبوغ. "تهذيب اللغة" 8/ 268 (قدد).|58:لم أعثر على مصدر لقوله.|59:ممن قال بذلك: الفراء 3/ 193، والثعلبي 12/ 194/ أ، والبغوي 4/ 403، وابن عطية 5/ 382، وابن الجوزي 8/ 106، والفخر الرازي 30/ 158، والقرطبي 19/ 15، والخازن 4/ 317، وابن كثير 4/ 458، والشوكاني 5/ 306.|60:ما بين القوسين ساقطة من: (أ).|61:لم أعثر على مصدر لقوله|62:"تفسير مقاتل" 212/ أ.|63:عن ابن عباس بمعناه في: "جامع البيان" 29/ 112، قال: "لا يخاف نقصًا من حسناته، ولا زيادة في سيئاته، وعنه: ولا يخاف أن يبخس من عمله شيء".|64:بمعناه قال ابن زيد. المرجع السابق. قال: فيظلم ولا يعطي شيئًا.|65:لم أعثر على مصدر لقوله.|66:"تفسير مقاتل" 212/ أ.|67:ما بين القوسين ساقط من: (أ).|68:لم أعثر على مصدر لقوله.|69:البَخْس: الناقص، وقد بخسه حقَّه يبْخَسُهُ بَخْسًا إذا نقصه. انظر: مادة: (بخس) في "الصحاح" 3/ 907، و"لسان العرب" 6/ 24، و"القاموس المحيط" 2/ 199.|70:الراء والهاء والقاف: أصلان متقاربان، فأحدهما غشيان الشيءِ الشيءَ، والآخر: العجلة والتأخير. والرَّهق: العجلة والظلم. قال تعالى: <span class="qpc-hafs">﴿فَلَا يَخَافُ بَخْسًا وَلَا رَهَقًا﴾</span>، انظر: مادة: (رهق) في: "معجم مقاييس اللغة" 2/ 451، و"الصحاح" 4/ 1487، و"لسان العرب" 10/ 131.|71:لم أعثر على مصدر لقوله.|72:في (أ): قال.|73:لم أعثر على مصدر لقوله.|74:لم أعثر على مصدر لقولهم.|75:قال بذلك قتادة، وابن زيد. انظر: "جامع البيان" 29/ 113.</p><p>وإليه ذهب الطبري في: "جامع البيان" المرجع السابق، والزجاج في: "معاني القرآن وإعرابه" 5/ 235، والثعلبي في: "الكشف والبيان" 12/ 194/ أ.|76:قال به مجاهد. انظر: "تفسير الإمام مجاهد" 677، و"جامع البيان" 29/ 113.|77:قال به ابن قتيبة في: "تأويل مشكل القرآن" 431.|78:"معالم التنزيل" 4/ 403، ولم يذكر عنه: وعدلوا به مخلوقًا.|79:عند قوله تعالى: <span class="qpc-hafs">﴿وَإِنْ خِفْتُمْ أَلَّا تُقْسِطُوا فِي الْيَتَامَى فَانْكِحُوا مَا طَابَ لَكُمْ مِنَ النِّسَاءِ﴾</span>.</p><p>ومما جاء في تفسير القسط فيها ما يلي: "الإقساط: العدْل، يقال: أقسط الرجل إذا عدل، والقسط: العدل، والنصفة. قال الزجاجي: وأصل قسط وأقسط جمعياً من القسط، وهو النصيب، فإذا قالوا: قسط بمعنى جار أرادوا أنه ظلم صاحبه في قسطه الذي يصيبه ... وإذا قالوا: أقسط، فالمراد به أنه صار ذا قِسط وعَدل، فبني علي بناء أنصف إذا أتى بالنصف والعدل في قوله وفعله وقسمه.|80:التحري لغة: قصد الأولى والأحق. انظر: مادة: (حرى) في: "تهذيب اللغة" 5/ 213، و"لسان العرب" 14/ 174.|81:في (أ): هطلاه.|82:البيت لامرئ القيس، ورد البيت ديوانه: 105، وانظر مادة (هطل) في: "تهذيب اللغة" 6/ 77، و"الصحاح" 5/ 1850، و"لسان العرب" 14/ 174، 3/ 699، و"تاج العروس" 8/ 169 مادة (حرى).</p><p>ومعنى البيت: الديمة: المطر الدائم يومًا وليلة، الوطفاء: الدانية من الأرض، طبق الأرض: عمها، تحرى: تقصد حراهم وهو الغناء، قدر: تعتمد المكان وتثبت فيه.|83:ما بين القوسين من قول أبي عبيدة في "مجاز القرآن" 2/ 272.|84:ساقط من: (أ).|85:لم أعثر على مصدر لقوله.|86:"معاني القرآن" 3/ 193، مختصرًا وعبارته: أمّوا الهدى واتبعوه.|87:في (ع): بالحرى.|88:"التفسير الكبير" 30/ 160.|89:انظر: "لسان العرب" 14/ 172، مادة: (حري)، والعبارة عنه قال: تَطُرْ حرانا، أي: لا تقرب ما حولنا.|90:في (أ): بطونها.|91:في (أ): الكلام.|92:ورد ذلك عن ابن قتيبة، ولعل الإمام الواحدي نقله عنه بتصرف، وعبارة ابن قتيبة: (الكافرون. الآية، وانقطع كلام الجن) "تأويل مشكل القرآن" 431.|93:"زاد المسير" 8/ 107.|94:ورد في النسختين: وأن لو استقاموا على أصل معنى الآية.|95:ساقطة من: (أ).|96:في (ع): كفصل، وهو لفظ مكرر زائد.|97:كررت كلمة: كفصل مرتين في (ع).|98:في النسختين وردت: الشين، والصواب هو: السين|99:ما بين القوسين نقلاً عن "الحجة" بتصرف: 6/ 330.|100:"النكت والعيون" 6/ 116، و"زاد المسير" 8/ 157، و"ابن كثير" 4/ 459 بمعناه.|101:"تفسير مقاتل" 212/ أ، قال: يعني طريقة الهدى.|102:لم أعثر على مصدر قوله.|103:ساقط من: (أ).|104:"جامع البيان" 29/ 114، و"النكت والعيون" 6/ 116 بمعناه، و"المحرر الوجيز" 5/ 382 بمعناه، و"زاد المسير" 7/ 108، و"تفسير القرآن العظيم" 9/ 454، و"الدر المنثور" 8/ 305 وعزاه إلى عبد بن حميد، وابن المنذر.|105:"النكت والعيون" 6/ 1116، و"المحرر الوجيز" 5/ 382 بمعناه، و"زاد المسير" 8/ 107.|106:لم أعثر على مصدر لقوله.|107:بياض في: (ع).|108:"تفسير مقاتل" 212/ أ، و"معالم التنزيل" 4/ 403، و"فتح القدير" 5/ 308. وانظر: "لباب النقول في أسباب النزول" للسيوطي: 222.|109:"جامع البيان" 29/ 115.|110:المرجع السابق، و"الدر المنثور" 8/ 305 وعزاه إلى عبد بن حميد، وابن المنذر.|111:غير واضحة في: (ع).|112:لم أعثر على مصدر لقوله.|113:هو عمر بن الخطاب -رضي الله عنه-.|114:في (أ): رحمه الله، بدلاً من: رضي الله عنه.|115:"جامع البيان" 29/ 115، و"الكشف والبيان" 12/ 194/ ب، و"القرطبي" 19/ 17.|116:ساقطة من: (أ).|117:ما بين القوسين من قول ابن قتيبة، نقله عنه الإمام الواحدي بنصه: "تأويل مشكل القرآن" 432.|118:في: (أ)، و (ع): (الكتاب) بدلا من (القرى)، وهو خطأ واضح.|119:ما بين القوسين نقلاً عن الزجاج. انظر: "معاني القرآن وإعرابه" 5/ 235.|120:بياض في: (ع).|121:انظر مادة: (غدق) في: "تهذيب اللغة" 16، و"المستدرك" 129، و"معجم مقاييس اللغة" 4/ 415، و"الصحاح" 4/ 1536، و"لسان العرب" 10/ 282، و"معاني القرآن وإعرابه" 5/ 236.|122:قوله: إذا كانت ريًا من الماء: بياض في (ع).|123:لم أعثر على مصدر لقوله.|124:ساقطة من: (أ).|125:بياض في: (ع).|126:لم أعثر على مصدر لقولهم.|127:ما بين القوسين ساقط من: (أ).|128:"الكشف والبيان" 12/ 195/ أ، و"معالم التنزيل" 4/ 404، و"الجامع لأحكام القرآن" 91/ 18، و"تفسير القرآن العظيم" 4/ 460.|129:المراجع السابقة عدا "الجامع لأحكام القرآن"، وانظر أيضًا: "المحرر الوجيز" 5/ 382، و"زاد المسير" 8/ 107، و"فتح القدير" 5/ 308.|130:المراجع السابقة عدا "زاد المسير". وانظر أيضًا: "الجامع" للقرطبي 19/ 18.|131:انظر قوله في: "الكشف والبيان"، و"الجامع لأحكام القرآن" مرجعان سابقان، و"فتح القدير" 5/ 308.|132:ما بين القوسين ساقط من: (أ).|133:ورد قوله في "الكشف والبيان" 12/ 195/ أ، و"النكت والعيون" 6/ 116، و"الجامع لأحكام القرآن" 19/ 18، و"فتح القدير" 5/ 308.|134:"معاني القرآن" 3/ 193.|135:انظر قوله في: "الكشف والبيان" 12/ 195/ أ، و"معالم التنزيل" 4/ 404، و"زاد المسير" 8/ 107، و"الجامع لأحكام القرآن" 19/ 18، و"تفسير القرآن العظيم" 4/ 460، و"فتح القدير" 5/ 308.|136:"معاني القرآن وإعرابه" 5/ 236 بيسير من التصرف.|137:قال بذلك النحاس، وأبو عمرو، والسجاوندي، والأشموني. انظر: "القطع والائتناف" 2/ 766 - 767، و"المكتفى في الوقف والابتدا" 589، و"علل الوقوف" 3/ 1056، و"منار الهدى" 406، وتمام الآية: <span class="qpc-hafs">﴿لِنَفْتِنَهُمْ فِيهِ وَمَنْ يُعْرِضْ عَنْ ذِكْرِ رَبِّهِ يَسْلُكْهُ عَذَابًا صَعَدًا (17)﴾</span>.|138:ما بين القوسين من قول ابن قتيبة بنصه من "تأويل مشكل القرآن" 432.|139:ما بين القوسين أيضًا من قول ابن قتيبة، نقله الإمام الواحدي، ولكن بتصرف. انظر: المرجع السابق.|140:"معاني القرآن" 3/ 193 بنصه.
