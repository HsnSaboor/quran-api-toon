quran[32]{c,v,t}:
86,1," <q>﴿وَالسَّمَاءِ وَالطَّارِقِ﴾</q> قال المفسرون {1}: أقسم الله بالسماء، والطارق: يعني: الكواكب تطرق بالليل وتخفي بالنهار {2}. وقال الفراء <q>﴿الطَّارِقُ﴾</q> النجم؛ لأنه يطلع بالليل، وما أتاك ليلاً فهو طارق {3} (ونحو هذا) {4} قال (الزجاج {5}، والمبرد {6}، قال) {7}: ولا يكون الطارق نهارًا. والعرب تستعمل الطروق في صفة الخيال كثيرًا، قال ذو الرمة: ألا طَرَقَتْ مني هيومًا بذكرها ... وأيدي الثريا جنح في المغارب {8} ",footnotes:1:وعزاه ابن عطية إلى جمهور المتأولين في "المحرر الوجيز" 5/ 464، وعزاه أيضًا الشوكاني إلى المفسرين نقلاً عن الواحدي: 5/ 418، وقال به الطبري في "جامع البيان" 30/ 141، والزجاج في "معاني القرآن وإعربه" 5/ 311، والماوردي في "النكت والعيون" 6/ 245، وانظر "معالم التنزيل" 4/ 472، "الجامع لأحكام القرآن" 20/ 1، "تفسير القرآن العظيم" 4/ 531، "التحرير والتنوير" 30/ 258.وهو قول ابن عباس في "بحر العلوم" 3/ 467، وبه قال قتادة في "جامع البيان" 30/ 241."معاني القرآن" 3/ 254.ساقط من (أ)."معاني القرآن وإعرابه" 5/ 311."الوسيط" 4/ 464.ما بين القوسين ساقط من (أ).لم أعثر عليه في ديوانه
86,2," ثم {1} قال لنبيه -ﷺ- {2}: <q>﴿وَمَا أَدْرَاكَ مَا الطَّارِقُ﴾</q> وذلك أن هذا الاسم يقع على مَا طرق ليلاً، ولم يكن النبي -ﷺ- يدري ما المراد به لولا تبيينه بقوله: <q>﴿النَّجْمُ الثَّاقِبُ﴾</q>، أي المضي {3}، ولقد فسرناه عند قوله: <q>﴿شِهَابٌ ثَاقِبٌ﴾</q> {4}، و <q>﴿الطَّارِقُ﴾</q>، و <q>﴿النَّجْمُ الثَّاقِبُ﴾</q>، اسم الجنس، وأُريد به العموم في قول أهل المعاني، وأكثر أهل التفسير، وهو قول (الكلبي {5} {6}، ومقاتل {5}، (وقتادة {8}، والحسن {9}، والفراء {10}، والزجاج {11} {12} وقال ابن زيد {13}: أراد به الثريا، والعرب تسميه النجم {14}، وقد ذكرنا ذلك عند قوله: <q>﴿وَالنَّجْمِ إِذَا هَوَى﴾</q> {15}. وروى أبو الجوزاء عن ابن عباس أنه - زُحَل {16}. والقول هو الأول. وجواب القسم: <q>﴿إِنْ كُلُّ نَفْسٍ لَمَّا عَلَيْهَا حَافِظٌ﴾</q> أقسم الله -بما ذكر- أنه ما من نفس إلا عليها حافظ من الملائكة تحفظ عملها وقولها وفعلها، وتحصي ما تكسب من خير أو شر. (ذكر ذلك ابن عباس {17}، والكلبي {18}، وقتادة {19}، ومقاتل) {5} {21}. وفي قوله <q>﴿لَمَّا عَلَيْهَا﴾</q> {22}: التخفيف، والتشديد، فمن خلف كان لغوًا {23}، والمعنى: لَعَلَيْها حافظ. ومن شدد جعل <q>﴿لَمَّا﴾</q> بمعنى "إلاَّ"، وهي تستعمل بمعنى "إلا" في موضعين، هذا أحدهما، والآخر في باب القسم تقول: سألتك لمَّا فعلت. بمعنى: "إلا فعلت" {24} هذا كلام أبي إسحاق. وقال أبو علي: (مَن خفف كانت "إن" عنده المخفّفة من الثقيلة، والسلام في "لما"، هي التي تدخل مع هذه المخففة لتخلصها من "إن" النافية، و"ما" صلة كالتي في قوله: <q>﴿فَبِمَا رَحْمَةٍ﴾</q> {25}، <q>﴿عَمَّا قَلِيلٍ﴾</q> {26}، وتكون إن متلقية للقسم كما تتلقاه) (مثقلة) {12}، (ومن ثقل فقال: "لمّا عَلَيْها" كانت "إن" عنده النافية كالتي في قوله) {28}: <q>﴿فِيمَا إِنْ مَكَّنَّاكُمْ فِيهِ {29}﴾، و"مال" في معنى "إلا". قال سيبويه عن الخليل في قولهم {30}: نشدتك الله لَمَّا فعلت -قال-: المعنى: إلا فعلت {31}. وقال أبو الحسن: الثقيلة في معنى "إلا"، والعرب لا تكاد تعرفه {32}، وقال الكسائي: لا أعرف وجه التقيل) {33}. وقال أبو عبيد {34}: لا يوجد ذلك في كلام العرب يعني "لمَّا"، بمعنى "إلا" {5}، وقد روي عن ابن سيرين أنه كره التشديد وأنكره {36}. والكلام في هذا قد سبق في آخر سورة هود {37}. ثم نبه على البعث بقوله: ",footnotes:1:في (أ): وقال.في (ع): عليه السلام.وهو قول قتادة، وابن عباس. "تفسير عبد الرزاق" 2/ 265، "جامع البيان" 30/ 141.سورة الصافات: 10 وما جاء في تفسيرها قوله ﴿شِهَابٌ ثَاقِبٌ﴾</q> قال ابن عباس وغيره: نار مضيئة محرقة، قال الحسن وقتادة ثاقب: مضيء قال الليث الثقوب مصدر النار مصدر الثاقبة، والكواكب الثاقب، يقال: ثقب يثقب ثقوبًا، وهو شدة ضوؤه وتلألؤه، والخشب الثاقب: الصوع النقي، وقال أبو عبيدة: الثاقب: النير المضيء، ويقال أثقب نارا أي أضاءها، والثقوب ما يذكى به النار.لم أعثر على مصدر لقوله.ساقط من (أ).لم أعثر على مصدر لقوله.ورد معنى قوله في "تفسير عبد الرزاق" 2/ 265، "جامع البيان" 30/ 142."المحرر الوجيز" 5/ 464."معاني القرآن" 3/ 254."معاني القرآن وإعرابه" 5/ 311 بمعناه.ما بين القوسين ساقط من (أ).في (أ): ابن دريد.ورد قوله في "جامع البيان" 30/ 142، "الكشف والبيان" ج 13/ 73/ ب، "النكت والعيون" 6/ 246، "معالم التنزيل" 4/ 473، "المحرر الوجيز" 5/ 464/ 465، "زاد المسير" 8/ 223.سورة النجم: 1، ومما جاء في تفسير الآية: قال ابن عباس في رواية الكلبي: أقسم بالقرآن إذا نزل نجومًا على رسول الله -ﷺ-، والعرب تسمي التفريق تنجيمًا، والمفرق نجومًا، ومنه نجوم الدين، وأصل هذا أن العرب كانت تجعل مطالع منازل القمر ومساقطها مواقيت لحلول ديونها، فتقول إذا طلع النجم، وهو الثريا حل عليك مالي، وكذلك سائرها ثم جعل كل نجم تفريقًا، وان كان لم يكن موقتًا بطلوع نجم."الكشف والبيان" ج 13/ 73/ 2، "زاد المسير" 8/ 223.المرجعان السابقان؛ إضافة إلى: "جامع البيان" 30/ 143، "معالم التنزيل" 4/ 473، "لباب التأويل" 4/ 368، تفسير ابن عباس: للحميدي: 2/ 975، "الجامع الصحيح" للبخاري: 2/ 4049، كتاب الأنبياء الباب الأول خلق آدم وذريته."الكشف والبيان" ج 13/ 74/ أ، "معالم التنزيل" 4/ 473.ورد معنى قوله في "تفسير مقاتل" 236/ أ - ب، "تفسير عبد الرزاق": 2/ 365، "جامع البيان" 30/ 143، "النكت والعيون" 6/ 246، "الكشف والبيان" ج 13: 74/ أ، "زاد المسير" 8/ 223، "الجامع لأحكام القرآن" 20/ 3، "الدر المنثور" 8/ 474، وعزاه إلى عبد بن حميد، وابن المنذر.لم أعثر على مصدر لقوله.ما بين القوسين ذكر بدلاً من تعدادهم في نسخة: أ، لفظ: وغيره.قرأ ابن كثير، ونافع، وأبو عمرو، والكسائي، وأبو جعفر: "لَمَا" خفيفًا. وقرأ عاصم، وابن عامر، وحمزة "لَمَّا" مشددة. انظر: "القراءات وعلل النحويين فيها" 2/ 765، "الحجة" 6/ 397، "المبسوط" 402، "حجة القراءات" 758، "إتحاف فضلاء البشر" 436.أي غير عاملة: صلة زائدة."معاني القرآن وإعرابه" 5/ 311.سورة آل عمران: 159، قال تعالى <q>﴿فَبِمَا رَحْمَةٍ مِنَ اللَّهِ لِنْتَ لَهُمْ﴾</q>.سورة المؤمنون: 40: قال تعالى <q>﴿قَالَ عَمَّا قَلِيلٍ لَيُصْبِحُنَّ نَادِمِينَ﴾</q>.ما بين القوسين ساقط من (أ).ساقط من النسختين، ومثبت من الحجة وبها تستقيم العبارة: 6/ 397.سورة الأحقاف: 26، ﴿وَلَقَدْ مَكَّنَّاهُمْ فِيمَا إِنْ مَكَّنَّاكُمْ فِيهِ﴾في (أ): قوله.انظر: كتاب "حروف المعاني" للزجاجي: 11.الذي وجدته عن الأخفش في "النكت والعيون" 6/ 246، "البحر المحيط" 8/ 454: قال: إن "ما" التي بعد اللام صلة زائدة، وتقديره: إن كل نفس لعليها حافظ.ما بين القوسين نقلًا عن "الحجة" 6/ 397 بنصه.في (أ): أبو عبيدة.لم أعثر على مصدر لقوله."جامع البيان" 30/ 142، "الكشف والبيان" ج 13: 74/ أ، "التفسير الكبير" 31/ 128.سورة هود: 11، فقد استطرد الإمام الواحدي في بيان علة التخفيف والتشديد == مستندًا على أقوال أهل المعاني، وأهل النحو في ذلك، وقد أوجز القول في آية سورة الطارق مما أغنى عن تلخيص ما جاء في سورة هود، هذا وإن كان ما سطره من أقوال الذي بيان العلة في رد أو قبول أهل النحو لقراءة التخفيف أو التشديد، فانه لا يخرج القراءتين -قراءة التخفيف والتشديد- عن صحة سندها، فهما قراءتان صائبتان صحيحتا السند، متواترتان، وقد ذُكرتا في كتب القراءات المتواترة. والله أعلم.
  86,3,""
  86,4,"86:3"
86,5," <q>﴿فَلْيَنْظُرْ﴾</q> {1} قال مقاتل: يعني: (الذي يكون منه) {2} المكذب بالبعث {3}. <q>﴿مِمَّ خُلِقَ﴾</q>. أي من أي شيء خلقه الله، والمعنى: فلينظر نظر التفكير والاستدلال حتى يعرف أن الذي ابتدأه {4} من نطفة قادر على إعادته. ثم ذكر من أي شيء خلقه فقال: ",footnotes:1:<q>﴿فَلْيَنْظُرِ الْإِنْسَانُ مِمَّ خُلِقَ﴾</q>.ما بين القوسين ساقط من: ع."فتح القدير" 5/ 419، ورد بمعناه في "تفسير مقاتل" 236/ ب.في: أ: ابتدأ.
86,6," <q>﴿خُلِقَ مِنْ مَاءٍ دَافِقٍ﴾</q> قال ابن عباس {1} ومقاتل {2}: يعني: المني الذي يكون منه الولد. قال الكلبي: من ماء مهراق في رحم المرأة {3}. والدَّفْق صَبُّ الماء، يقال: دفقت الماء أي صببته، وهو مدفوق (ومندفق) {4} أي منصب {5} و <q>﴿دَافِقٍ﴾</q> هَاهنا معناه - مدفوق. قال الفراء: وأهل الحجاز أفعل لهذا من غيرهم، يجعلون الفاعل مفعولًا إذا كان في مذهب نعت كقولهم: سرُّ كاتم، وهمٌّ ناصب، وليلٌ نائم، قال: وأعان على ذلك أنها وافقت رؤوس الآي التي هي معهنّ {6}. وقال الزجاج: معناه من مَاءٍ ذي دَفْقٍ، وكذلك: سرٌّ كاتم، وهذا قول جميع النحويين {7}. وقد أحكمنا الكلام في هذه المسألة عند قوله: <q>﴿لَا عَاصِمَ الْيَوْمَ﴾</q> {8}. ",footnotes:1:"الوسيط" 4/ 465، وقد ورد بمثل قوله من غير نسبة في "معالم التنزيل" 4/ 473، "البحر المحيط" 8/ 455، "تفسير القرآن العظيم" 4/ 532.ورد بمعناه في "تفسير مقاتل" 236/ ب.لم أعثر على مصدر لقوله.ساقط من (أ).انظر ذلك في: مادة: (دفق): "تهذيب اللغة" 9/ 39، "الصحاح" 4/ 1475، "لسان العرب" 10/ 99."معاني القرآن" 3/ 355 بتصرف."معاني القرآن وإعرابه" 5/ 311، قال: معناه مدفوق، ومذهب سيبويه وأصحابه أن معناه النسب إلى الاندفاق، المعنى: من ماء ذي اندفاق، ولعل الإمام الواحدي نقل قول الزجاج من "تهذيب اللغة" 9/ 39: مادة: (دفق)، فقد ورد فيه بمثل ما نقل الواحدي عن الزجاج.سورة هود: 43، قال تعالى: <q>﴿قَالَ سَآوِي إِلَى جَبَلٍ يَعْصِمُنِي مِنَ الْمَاءِ قَالَ لَا عَاصِمَ الْيَوْمَ مِنْ أَمْرِ اللَّهِ إِلَّا مَنْ رَحِمَ﴾</q>: 43، ومما جاء في تفسير <q>﴿لَا عَاصِمَ﴾</q>: قال .. ولا يجوز -هاهنا- أن يكون المعصوم عاصمًا، هذا وجه في الاستثناء. قال أبو إسحق: ويجوز أن يكون عاصم في معنى مَعصُوم، ويكون معنى لا عاصم: لا ذا عصمة، كما قالوا: "عيشة راضية"، على جهة النسب، أي ذات رضًا، ويكون "من" على هذا التفسير في موضع رفع، ويكون المعنى: لا معصوم إلا المرحوم. وقد أجاز الفراء أن يكون الفاعل بمعنى المفعول نحو قوله: <q>﴿مِنْ مَاءٍ دَافِقٍ﴾</q> معناه مدفوق. وقال علماء البصرة: ماء دافق بمعنى مدفوق باطل من الكلام، لأن الفرق بين الفاعل وبناء المفعول واجب، وهذا عند سيبويه وأصحابه يكون على طريق النسب من غير أن يعتبر فيه فعل، فهو فاعل نحو: رامح، ولابن، ومعناه: ذو == رمح، وذو لبن، وكذلك -هاهنا-: عاصم بمعنى ذو عصمة من قبل الله تعالى؛ ليس أنه عُصِم فهو عاصم بمعنى معصوم على الإطلاق.
86,7," ثم وصف الماء فقال: <q>﴿يَخْرُجُ مِنْ بَيْنِ الصُّلْبِ وَالتَّرَائِبِ﴾</q>، قال الليث: التريبة ما بين الثندوتين {1} إلى الترقوتين {2} {3}. وبَعضهم يقول: كل عظم من ذلك تريبة، والجمع الترائب {4}. قال المبرد: هي ضلوع الصدر {5}. وقال أبو عبيدة: الترائب مُعَلَّق الحَلْي على الصدر {6}، وهو قول جميع أهل اللغة {7}، وأنشد {8} (قول الْمُثقِب {9}: ومِنْ ذَهَبٍ يَلُوحُ على تَريبٍ ... كَلَوْن العَاجِ لَيْس بذي غُصُونِ {10} وحكى الزجاج أن أهل اللغة [أجمعون {11}] {12} قالوا: الترائب موضع القلادة من الصدر، وأنشدوا {13}: ترائبها مصقولة كالسَّجَنْجَلِ {14} {15} قال (عطاء عن) {16} ابن عباس {17}، (والكلبي) {18} {16}، وسفيان {20} {21}: يريد صلب الرجل، وترائب المرأة، وهي موضع قلادتها: الولد لا يكون إلا من المائين. وقال عكرمة {22}، وسعيد (ابن جبير {23}، وابن زيد {24}، ومجاهد) {25} {26}: الترائب: الصدور. وقال مقاتل الترائب: موضع القلادة {27} بين الترقوة والثدي. وقال الفراء: وقوله: <q>﴿مِنْ بَيْنِ الصُّلْبِ وَالتَّرَائِبِ﴾</q> يريد من الصلب والترائب، وهو جائز أن تقول للشيئين: ليخرجن من بين هذين خير كثير، ومن هذين خير كثير {28}. ",footnotes:1:الثُّنْدُوَة: لحم الثدي، وقال ابن السكيت: هي الثَّنْدُوَة: اللحم الذي حول ثدي المرأة. "تهذيب اللغة" 14/ 90، مادة: (ثند).التُّرْقُوتان: العظمان المشرفان في أعلى الصدر من رأس المنكبين إلى طرف ثغرة النحر، وباطن الترقوتين الهواء الذي يهوي في الجوف لو خُرق، ويقال له: القلتان، وهما الحافنتان أيضًا. انظر: "تهذيب اللغة" 14/ 276 مادة: (ترب)، وانظر "لسان العرب" 1/ 230 مادة: (ترب).لم أعثر على مصدر لقوله، وقد ورد بنحوه من غير نسبة في "لسان العرب" 1/ 230: مادة: (ترب)، وقيل: ما بين التَّرْقوة إلى الثندوة.لم أجد من قال ذلك مما بين يدي من المصادر: وجاء في "الصحاح" 10/ 91: مادة: (ترب): والتريبة واحدة الترائب، وهي عظام الصدر ما بين الترقوة والثَّنْدَوة.لم أعثر على مصدر لقوله"مجاز القرآن" 2/ 294 بنصه.حكى الإجماع الأزهري، والجوهري، وابن منظور: انظر: مادة: (ترب) في: "تهذيب اللغة" 14/ 276، "الصحاح" 1/ 91، "لسان العرب" 1/ 230.أي أبو عبيدة.ما بين القوسين ساقط من (أ).ورد البيت في: ديوانه: 159. "مجاز القرآن" 2/ 294 برواية: "من ذهب يُشَنّ على تريب"، "جامع البيان" 30/ 145 برواية "له" بدلًا من "بذي"، "الكشف والبيان" ج 13: 74/ ب، "الجامع لأحكام القرآن" 20/ 6، "فتح القدير" 5/ 419، برواية "بنن" بدلًا من "يلوح": وكذا "روح المعاني" 30/ 97. وورد غير منسوب في: "تهذيب اللغة" 14/ 275: مادة: (ترب)، "لسان العرب" 1/ 230: مادة: (ترب)، "تاج العروس" 1/ 185: مادة: (ترب) برواية "له" بدلًا من "بذي". والتريب: جمع تريبة، وتجمع: ترائب، وهو عظام الصدر. انظر: "ديوانه" حاشية: 159.في (ع): الجمعين، وأثبت ما جاء في "معاني القرآن وإعرابه" 5/ 312.ساقط من: ع.في (أ): أنشد."معاني القرآن وإعرابه" 5/ 312.البيت لامرئ القيس، ونسب له في المعاني وهو في ديوانه: 42: دار صادر: وصدره: مُهَفْهَفَة بيضاء غيرُ مُفاضةٍ وقد ورد البيت غير منسوب في كتب اللغة: مادة: (ترب) في: "تهذيب اللغة" 14/ 275، "لسان العرب" 1/ 230. وورد منسوبًا في كتب التفسير نحو: "بحر العلوم" 3/ 468، "زاد المسير": 8/ 224، "الجامع لأحكام القرآن" 20/ 5، "فتح القدير" 5/ 419، "روح المعاني" 30/ 97. ومعنى: المهفهفة: اللطيفة الخصر، الضامرة البطن، المفاضة: المرأة العظيمة == البطن، المسترخية اللحم. الترائب: جمع تريبة: وهي موضع القلادة من الصدر. السقل والصقل: إزالة الصدأ والدنس وغيرهما. السجنجل: المرآة. وقيل هو قطع الذهب والفضة. يقول: هي امرأة دقيقة الخصر، ضامرة البطن، غير عظيمة البطن ولا مسترخية، وصدرها براق اللون متلألئ الصفاء كتلألؤ المرآة: ديوانه: 42: حاشية.ساقط من (أ).ورد معنى قوله في "تفسير القرآن العظيم" 4/ 532، "الدر المنثور" 8/ 475، وعزاه إلى عبد بن حميد، وابن المنذر.لم أعثر على مصدر لقوله.ساقط من (أ).سفين: في كلا النسختين."تفسير عبد الرزاق" 2/ 366، "جامع البيان" 30/ 144، "المحرر الوجيز" 5/ 465، "البحر المحيط" 8/ 455.ورد معنى قوله في "جامع البيان" 30/ 143، "الكشف والبيان" ج 13: 74/ ب، "الجامع لأحكام القرآن" 20/ 6، "فتح القدير" 5/ 419، "الدر المنثور" 8/ 475، وعزاه إلى عبد بن حميد."جامع البيان" 30/ 143، "الكشف والبيان" ج 13/ 74/ ب، "تفسير سعيد بن جبير" 371.المرجعان السابقان إضافة إلى: "معالم التنزيل" 4/ 473.ورد معنى قوله في "جامع البيان" 30/ 144، "النكت والعيون" 6/ 247، "الكشف والبيان" ج 13/ 74/ ب، "الجامع لأحكام القرآن" 20/ 5، "فتح القدير" 5/ 419.ما بين القوسين ساقط من: أ."تفسير مقاتل" 236/ ب."معاني القرآن" 3/ 255 بتصرف.
86,8," قوله (تعالى): <q>﴿إِنَّهُ عَلَى رَجْعِهِ لَقَادِرٌ﴾</q>، قال مجاهد: على أن يرد الماء في الإحليل {1} {2}. وقال عكرمة {3}، (والضحاك) {4} {5}: على أن يرد الماء في الصلب. وروي (عن الضحاك {6} {7} أيضًا: على رد الإنسان ماءً كما كان قبل، لقادر. وقال مقاتل (بن حيان) {7}: تقول: إن شئت رددته من الكبر إلى الشباب ومن الشباب إلى الصبا {9}، ومن الصبا {9} إلى النطفة {11}. وقال قتادة: إن الله [على] {12} بعث الإنسان وإعادته لقادر {13}، وهو قول الحسن {14}، ومقاتل (ابن سليمان {15}، وابن عباس {16}، في رواية عطاء، واختيار أهل المعاني {17}) {18}، قال أبو إسحق: ويشهد له قوله: <q>﴿يَوْمَ تُبْلَى السَّرَائِرُ﴾</q> [الطارق: 9]. (أي) {7} إنه قادر على بعثه يوم القيامة {20}. ومعنى الرجع: رد الشيء إلى أول حَاله {21}، والله -تعالى- قادر على أن يرد الماء في الإحليل، أو في الصُلب، وأن يرد الإنسان صبيًا بعد كبره، وأن يرده حيًا بعد موته، وهذا هو الوجه المراد لانتصاب قوله: <q>﴿يَوْمَ تُبْلَى السَّرَائِرُ﴾</q>، وهو ظرف للرجع {22}. قال صاحب النظم: يريده أن يبعث فيرد، ويرجع في هذا اليوم {23}. ومعنى <q>﴿تُبْلَى﴾</q> {24} تختبر. قاله (ابن عباس {23}، ومقاتل {26}، وقتادة {27}) {28}. وقال {29} الكلبي {23}، ومقاتل {31}: [بمعنى] {32} تظهر. و <q>﴿السَّرَائِرُ﴾</q>: أعمال بني آدم من الخير والشر، فرائضه التي أوجبت عليه، وهي سرائر بين الله والعبد، فتختبر تلك يوم القيامة حتى يظهر خيرها من شرها، ومؤديها عن مضيعها، وهذا معنى قول ابن عمر: "يبدي الله يوم القيامة كل سر، فيكون زينًا في الوجوه، وشينًا في الوجوه"، يعني من أداها كان وجهه مشرقًا، ومن ضيعها كان وجهه أغبر {33}. وقال أهل المعاني {34}: معنى <q>﴿تُبْلَى السَّرَائِرُ﴾</q> تختبر بإظهارها، وإظهارها موجبها، ففي الطاعة الحمد والثواب، وفي المعصية الذم والعقاب، وهذا كقوله: <q>﴿وَنَبْلُوَ أَخْبَارَكُمْ﴾</q> [محمد: 31] أي نكشفها ونظهرها، وقد مر {35}. ",footnotes:1:الإحليل: الذكر؛ ثقبه الذي يخرج منه البول، وجمعه الأحاليل. "تهذيب اللغة" 3/ 442: مادة: (حل).ورد قوله في "جامع البيان" 30/ 145، "الكشف والبيان" ج 13: 74/ ب، "النكت والعيون" 6/ 247، "معالم التنزيل" 4/ 473، "المحرر الوجيز" 5/ 466، "زاد المسير" 8/ 225، "التفسير الكبير" 31/ 131، "البحر المحيط" 8/ 455، "الدر المنثور" 8/ 476، وعزاه إلى عبد بن حميد، وابن المنذر، "فتح القدير" 5/ 420، "معاني القرآن" الفراء: 3/ 255.المراجع السابقة عدا "البحر المحيط"، ومعاني الفراء."جامع البيان" 30/ 146، "الكشف والبيان" ج 13: 75/ أ، "زاد المسير" 8/ 225، "الجامع لأحكام القرآن" 20/ 7، "فتح القدير" 5/ 420.ساقط من: أ."التفسير الكبير" 31/ 131، "الجامع لأحكام القرآن" 20/ 7.ساقط من (أ).ساقط من (أ).في (ع): الصبى.في (ع): الصبى.ورد قوله في "الكشف والبيان" ج 13/ 75/ أ، "معالم التنزيل" 4/ 473، "التفسير الكبير" 31/ 131، "فتح القدير" 5/ 420.ساقط من النسختين، وأثبت ما جاء في "الوسيط" 4/ 465، وبه ينتظم الكلام."جامع البيان": 30/ 146، "الكشف والبيان": ج 13/ 74/ ب، "معالم التنزيل" 4/ 473، "المحرر الوجيز" 5/ 466، "زاد المسير" 8/ 225، "الجامع لأحكام القرآن" 20/ 7، "البحر المحيط" 8/ 455."زاد المسير" 8/ 225، "الجامع لأحكام القرآن" 20/ 7، "الدر المنثور" 8/ 476، وعزاه إلى ابن المنذر، "تفسير الحسن البصري" 2/ 411."تفسير مقاتل" 236/ ب."المحرر الوجيز" 5/ 466، "الجامع لأحكام القرآن" 20/ 7، "البحر المحيط" 8/ 455."معاني القرآن" للفراء: 3/ 255.ما بين القوسين ساقط من أ.ساقط من (أ)."معاني القرآن" 5/ 312 بنصه.قال ابن فارس: "الراء، الجيم، والعين أصل كبير مطرد ومنقاس، يدل على ردٍّ وتكرار، تقول: رجع يرجع رجوعًا، إذا عاد، وراجع الرجل امرأته، وهي الرِّجْعَة، والرَّجُعَة، والرُجْعَى، والرجوع". 2/ 490: مادة: (رجع).، وأيضًا انظر: مادة: (رجع) في "الصحاح" 3/ 1216، "لسان العرب" 8/ 114.وهو قول الطبري في "جامع البيان" 30/ 146، وانظر "الكشاف" 4/ 202.لم أعثر على مصدر لقوله.<q>﴿يَوْمَ تُبْلَى السَّرَائِرُ﴾</q>.لم أعثر على مصدر لقوله."تفسير مقاتل" 236/ ب، "الكشف والبيان" ج 13/ 75/ ب، "معالم التنزيل" 4/ 473.ورد معنى قوله في المرجعين السابقين، وانظر أيضًا في "جامع البيان" 30/ 147.ما بين القوسين ذكر بدلًا منه في نسخة ألفظ: جماعة.في (ع): قال.لم أعثر على مصدر لقوله."الوسيط" 4/ 465.في كلا النسختين: ومعنى، ولا يستقيم المعنى بذلك، وأثبت ما رأيت به استقامة المعنى."معالم التنزيل" 4/ 474، "التفسير الكبير" 31/ 133.لم أعثر على مصدر لقولهم.ومما جاء في تفسير قوله تعالى: <q>﴿وَنَبْلُوَ أَخْبَارَكُمْ﴾</q> محمد: 31: "قال ابن عباس في رواية عطاء: يريد ليظهر ما تسرون، وقال في رواية الكلبي: يظهر نفاقكم للمؤمنين، ومعنى الآية: حتى نعلم المجاهدين، وحتى تكشف أخباركم وتظهر ويجوز أن يوضع البلو موضع الكشف؛ لأن القصد بالبلو: الكشف والإظهار، فجاز أن يفسر بما يؤول إليه".
  86,9,""
86,10," قوله تعالى <q>﴿فَمَا لَهُ﴾</q> {1} (أي لهذا الإنسان المنكر للبعث من قوة يمتنع بها من عذاب الله) {2}. <q>﴿وَلَا نَاصِرٍ﴾</q>. (ينصره من الله) {3}. ومعنى نفي القوة والناصر هو العامل في قوله: <q>﴿يَوْمَ تُبْلَى السَّرَائِرُ﴾</q> على قول من لا يجعل الرجع بمعنى البعث في قوله: <q>﴿إِنَّهُ عَلَى رَجْعِهِ﴾</q> [الطارق: 8] {4}. ",footnotes:1:<q>﴿فَمَا لَهُ مِنْ قُوَّةٍ وَلَا نَاصِرٍ﴾</q>ما بين القوسين في قول الثعلبي في "الكشف والبيان" ج: 13: 75/ أ.ما بين القوسين من قول الثعلبي: المرجع السابق.هذا القول قال عنه أبو حيان: إنه فاسد؛ لأن ما بعد الفاء لا يعمل فيما قبلها، وكذلك ما النافية، لا يعمل ما بعدها فيما قبلها على المشهور المنصور، انظر: "البحر المحيط" 8/ 455.
86,11," ثم ذكر قسمًا آخر فقال: <q>﴿وَالسَّمَاءِ ذَاتِ الرَّجْعِ﴾</q> قال أبو عبيدة: الرجع في كلام العرب: الماء، وأنشد للهذلي يصف السَّيف: أبْيَضُ كالرّجْع رَسُوبٌ إذا ما ... ثاخَ في مُحْتَفَلٍ يختلي {1} {2} قال الفراء: تبتدئ بالمطر، ثم ترجع به في كل عام {3}. وقال أبو إسحق: الرجع: المطر؛ لأنه يجيء ويرجع ويتكرر {4} {5}. وهذا معنى قول ابن عباس في رواية عطاء، قال: يبتدي بالمطر، ثم يرجع به في كل عام {6}. وهو قول مقاتل {7}، وسعيد (بن جبير {8}، وعكرمة عن ابن عباس {9}) {10}، ومجاهد {11} قالوا: ذات المطر تمطر، ثم تمطر، ثم ترجع تمطر بعد مطر. وقال أهل المعاني: رجع السماء إعطاء الخير الذي يكون من جهتها حالًا بعد حال على مرور الأزمان، ترجعه رجعة، أي تعطيه مرة بعد مرة {12}. وقال ابن زيد: هو أنها ترد وترجع شمسها وقمرها بعد مغيبهما {13}، والقول هو الأول {14}. قوله تعالى: <q>﴿وَالْأَرْضِ ذَاتِ الصَّدْعِ﴾</q> وصدعها إنما يكون عن {15} المطر والماء، ومعنى الصدع {16} في اللغة: الشق، يقال: صَدَعه إذا شقه فتصدع، ومنه قوله: <q>﴿يَوْمَئِذٍ يَصَّدَّعُونَ﴾</q> [الروم: 43] أي يتفرقون، والعرب تقول: صَدَعْتُ غنمي صِدْعَتَيْن، كقولك: فرقتها فرقتين، فالصدع مصدر، ثم يقال في الزّجاجة والحائط صَدْع، فيسمى به {17}، والذي في الآية هو الاسم لا المصدر. قال أبو عبيدة {18}، والفراء {19}، والزجاج {20}: تتصدع بالنبات، وهو معنى قول ابن عباس {21}، والمفسرين قالوا: تنشق عن النبات، والأشجار {22}. وقال مجاهد: هي [السدان {23}] بينهما طريق نافذ {24} يعني -الجبلين بينهما شق. وقال الليث: الصدْع {25} نبات الأرض؛ لأنه يصدع الأرض، فتتصدع به الأرض، وهذا قول مجاهد في رواية الليث {26}، قال: ذات النبات {27} وعلى هذا سمي النبات صدعًا؛ لأنه صادع للأرض. ",footnotes:1:ورد البيت في: "مجاز القرآن" 2/ 294، "ديوان الهذليين" 2/ 12، "تهذيب اللغة" 1/ 364 مادة: (رجع)، "لسان العرب" 8/ 120 مادة: (رجع)، و3/ 11 مادة: (ثوخ)، "معاني القرآن وإعرابه" للزجاج: 5/ 312، "جامع البيان" 30/ 147، "الكشف والبيان" ج 13/ 75/ ب، "المحرر الوجيز" 5/ 466، "البحر المحيط" 8/ 456، "فتح القدير" 5/ 420، و"المحرر" و"البحر" براوية: "ما شاخ" بدلًا من: "ما ثاخ".ومعنى البيت كما في: اللسان: أراد بالأبيض: السيف، والرَّجْع: الغدير. شبه السيف به في بياضه، والرَّسُوب: الذي يَرْسُب في اللحم، والمحتفل: أعظم موضع في الجسد، ويختلى: يقطع، وثاخ وساخ: ذهب في الأرض سُفلًا."معاني القرآن" 3/ 255 بنصه.في (أ): يكرر."معاني القرآن وإعرابه" 5/ 312 بنحوه.ورد معنى قوله في "جامع البيان" 30/ 148."تفسير مقاتل" 236/ ب، وعبارته: قال: ذات المطر.ورد معنى قوله في "الدر المنثور" 8/ 477، وعزاه إلى عبد بن حميد، "تفسير سعيد بن جبير" 371.ورد معنى قوله في "تفسير عبد الرزاق" 2/ 365، "جامع البيان" 30/ 148 "النكت والعيون" 8/ 248، "معالم التنزيل" 4/ 474، "التفسير الكبير" 31/ 133، "تفسير القرآن العظيم" 4/ 532، "الدر المنثور" 8/ 476، وعزاه إلى الفريابي، وعبد بن حميد، والبخاري في تاريخه، وابن المنذر، وابن أبي حاتم، وابن مردويه، وانظر "المستدرك" 2/ 520، وقال: صحيح الإسناد، ووافقه الذهبي.ما بين القوسين ساقط من (أ)."تفسير الإمام مجاهد" 720، "جامع البيان" 30/ 148، "الدر المنثور" 8/ 477، وعزاه إلى عبد بن حميد، وانظر "الجامع الصحيح" للبخاري: 3/ 322، كتاب التفسير باب 86.لم أعثر على مصدر لقولهم، وورد بمثله من غير نسبة في "التفسير الكبير" 31/ 133.ورد معنى قوله في "جامع البيان" 30/ 148، "النكت والعيون" 6/ 248، "المحرر الوجيز" 5/ 466، "التفسير الكبير" 31/ 133، "الجامع لأحكام القرآن" 20/ 11، "تفسير القرآن العظيم" 4/ 532، "فتح القدير" 5/ 420.وهو الصحيح الذي عليه أكثر المفسرين وأهل اللغة، حكى ذلك القرطبي في "الجامع لأحكام القرآن" 20/ 10، وأبو حيان في "البحر المحيط" 8/ 456.في (أ): من.في (أ): الصداع.انظر: مادة: (شق): "تهذيب اللغة" 2/ 5، إصلاح المنطق: لابن السكيت: 43، "مقاييس اللغة" 3/ 338، "الصحاح" 3/ 1241، "لسان العرب" 8/ 194."مجاز القرآن" 2/ 294."معاني القرآن" 3/ 255، واللفظ له."معاني القرآن وإعرابه" 5/ 313."جامع البيان" 30/ 149، "التفسير الكبير" 31/ 133، "تفسير القرآن العظيم" 4/ 532، "الدر المنثور" 8/ 520، "فتح القدير" 5/ 421، وانظر "المستدرك" 2/ 520، قال: صحيح الإسناد، ووافقه الذهبي. كما قال بمثله: سعيد بن جبير، وعكرمة، وأبو مالك، والضحاك، والحسن، وقتادة، والسدي، وغير واحد: "تفسير القرآن العظيم" 4/ 532.وممن قال بمعنى ذلك: الحسن، وعكرمة، وقتادة، وابن زيد، والضحاك، "جامع البيان" 3/ 149، وحكاه عن المفسرين: ابن الجوزي في "زاد المسير" 8/ 226، وأبو حيان في "البحر المحيط" 8/ 256، وبهذا القول: تنشق عن النبات والأشجار، قال السمرقندي في "بحر العلوم" 3/ 468.في كلا النسختين: الصدان، وأثبت ما جاء في "الكشف والبيان" ج 13: 75/ ب.ورد معنى قوله في: "تفسير الإمام مجاهد" 721، "جامع البيان" 30/ 149، "بحر العلوم" 3/ 468، "الكشف والبيان" ج 13: 75/ ب، "النكت والعيون" 6/ 249، "المحرر الوجيز" 5/ 466، "الجامع لأحكام القرآن" 20/ 11، "الدر المنثور" 8/ 477، وعزاه إلى عبد بن حميد."تهذيب اللغة" 2/ 5: مادة: (صدع) بنصه.بياض في: ع.لم أعثر على مصدر لقوله.
  86,12,""
86,13," وجواب القسم قوله: <q>﴿إِنَّهُ لَقَوْلٌ فَصْلٌ﴾</q> أي إن القرآن يفصل بين الحق والباطل بالبيان عن كل واحد منها {1}. والمفسرون يقولون: جِدٌ حق {2}، لقوله: <q>﴿وَمَا هُوَ بِالْهَزْلِ﴾</q> قالوا: باللعب {3}، والمعنى أن القرآن نزل للفصل بين الحق والباطل، ولم ينزل باللعب، وهو جد ليس بالهزل. ",footnotes:1:وهو قول الطبري في: "جامع البيان" 30/ 149، والزجاج في "معاني القرآن وإعرابه" 5/ 313، والثعلبي في "الكشف والبيان" 75/ ب.قال بمعنى ذلك، ابن عباس، وقتادة، وسعيد بن جبير، والضحاك، انظر: "جامع البيان" 30/ 149، "النكت والعيون": 6/ 249، "تفسير القرآن العظيم" 4/ 532، وأيضًا به قال السمرقندي في "بحر العلوم" 3/ 468، والثعلبي في: "الكشف والبيان": ج 13/ 75/ ب. وقيل: المراد بالقول الفصل: ما تقدم من الوعيد في هذه السورة من قوله: <q>﴿إِنَّهُ عَلَى رَجْعِهِ لَقَادِرٌ (8) يَوْمَ تُبْلَى السَّرَائِرُ﴾</q>. "الجامع لأحكام القرآن" 20/ 11. وقال أبو حيان: ويجوز أن يعود الضمير في أنه على الكلام الذي أخبر فيه ببعث == الإنسان ويوم القيامة، وابتلاء سرائره، أي أن ذلك القول قول جزم مطابق للواقع لا هزل فيه، ويكون الضمير قد عاد على مذكور، وهو الكلام الذي تضمنه الإخبار عن البعث، وليس من الأخبار التي فيها هزل؛ بل هو جد كله. "البحر المحيط" 8/ 456.قال بذلك ابن عباس، ومجاهد، وسعيد بن جبير، وقتادة، انظر "جامع البيان" 30/ 15، "النكت والعيون" 6/ 249، "الدر المنثور" 8/ 477، وعزاه إلى عبد بن حميد، وابن المنذر، والطستي، وابن أبي شيبة، كما قال به الزجاج في "معاني القرآن وإعرابه" 5/ 313، والسمرقندي في "بحر العلوم" 3/ 468، والثعلبي في "الكشف والبيان" ج 13/ 75/ ب. وعن السدي قال: بالكذب. وعن وكيع، والضحاك قالا: بالباطل. "النكت والعيون" 6/ 249.
  86,14,""
86,15," ثم أخبر عن مشركي مكهَ فقال: <q>﴿إِنَّهُمْ يَكِيدُونَ كَيْدًا﴾</q>. قال أبو إسحق: إنهم يخاتلون {1} النبي -ﷺ- ويظهرون ما هم على خلافه {2}. ",footnotes:1:معنى يخاتلون أي يخادعون، جاء في: مختار "الصحاح" خاتله: خدعه، والتَّخَاتُل: التخادع. 169: مادة: (ختل)."معاني القرآن وإعرابه" 5/ 313 بنصه.
86,16," <q>﴿وَأَكِيدُ كَيْدًا﴾</q> قال {1}: كيد الله استدراجهم من حيث لا يعلمون {2}. ",footnotes:1:أي الزجاج."معاني القرآن وإعرابه" 5/ 313.
86,17," (قوله تعالى {1}) <q>﴿فَمَهِّلِ الْكَافِرِينَ﴾</q> {2} قال ابن عباس {3}، ومقاتل {4}: هو وعيد {5} من الله تعالى لهم. (قوله تعالى {1}): <q>﴿أَمْهِلْهُمْ رُوَيْدًا﴾</q>، قالا {7}: يريد قليلًا {8}، حتى أهلكهم، ففعل ذلك ببدر، ونسخ الإمهال بآية السيف {9}، ومعنى مهل وأمهل: أنظر ولا تعجل، ويقال: مَهْلًا يا فلان، أي رفقًا وسُكونًا لا تَعْجَلْ {10}. وأما <q>﴿رُوَيْدًا﴾</q> فروى أبو عبيد عن أصحابه أن تكبير <q>﴿رُوَيْدًا﴾</q> رُوْد، وأنشد {11}: يمشي ولا تَكْلِمُ البَطحاء مِشيتهُ ... كأنه ثَمِلٌ يمشي على رُودِ {12} {13} أي على مُهْلَة ورفق وتؤدة. وذكر أبو على في باب الأسماء التي سمي بها الأفعال: رُويدًا زيدًا، تريد: أرْوِدْ زيدًا، معناه: أمهله، وأرفق به {14}. قال النحويون: رويدًا في كلام العرب على ثلاثة أوجه: يكون اسمًا لفعل الأمر ينصب "بها"، لأنها جعلت بدلًا من اللفظ بالقول، كقولك: رويدًا زيدًا، تريد أرود زيدًا، أي خله ودعه، وارفق به {15}. ومن هذا ما ذكره سيبوبه (سماعًا عن العرب: رويد الشعر يَغِبَّ، قال: يريدون: أرُوِدْ الشعر، كما تقول: دَع الشعر، وأنشد {16}: رُوَيدًا عَلِيُّا جُدَّ ما ثَدْيُ أمِّهِم {17} ... إلينا ولكن وُدُّهُم مُتَمايِنُ {18} {19} ولا ينصرف "رويد" في هذا الوجه؛ لأنها غير متمكنة. الوجه الثاني: أن تكون بمنزلة سَائر المصادر، فتضاف {20} إلى ما بعدها كما تضاف المصَادر، تقول: رويد زيد، كما تقول: ضرْب زيدٍ، قال الله عز وجل: <q>﴿فَضَرْبَ الرِّقَابِ﴾</q> [محمد: 4]. الوجه الثالث: أن يكون نعتًا منصوبًا كقولك: سَاروا سَيْرًا {21} رويدًا ويقولون "أيضًا" {22}: سَاروا رُوَيْدًا. يحذفون المنعوت، ويقيمون "رويدًا" مقامه، كما يفعلون بسائر النعوت المتمكنة. (و) {22} من ذلك قول العرب: ضَعْهُ رُوَيْدًا، أي وضعًا رُوَيْدًا. وتقول للرجل {24} يعالج الشيء: رويدًا، إنما تريد أن تقول: علاجًا رُوَيْدًا، ويجوز في هذا الوجه أمران: أحدهما: أن يكون رويدًا حالًا. والثاني: أن يكون نعتًا. (فإن أظهرت المنعوت لم يجز أن يكون للحال) {25}. والذي في الآية (هو) {26} ما ذكرنا في الوجه الثالث، لأنه يجوز أن يكون نعتًا للمصدر كأنه قيل: إمهالًا رويدًا، ويجوز أن يكون للحال، أي أمهلهم غير مستعجل مستأنيًا بهم {27}. فهذا بعض ما قيل في هذه الكلمة، وشرحها يطول. ",footnotes:1:ساقط من (ع).<q>﴿فَمَهِّلِ الْكَافِرِينَ أَمْهِلْهُمْ رُوَيْدًا﴾</q>."معالم التنزيل" 4/ 474، "لباب التأويل" 4/ 369، "زاد المسير" 8/ 226 من غير نسبة."الوسيط" 4/ 467.بياض في (ع).ساقط من (ع).أي ابن عباس، ومقاتل.ورد قول ابن عباس في "جامع البيان" 30/ 150، "الجامع لأحكام القرآن": 20/ 12، أما مقاتل فلم أعثر على مصدر لقوله، وإن كان ورد بمثل قوليهما من غير عزو في "الوسيط" 4/ 267، قال ابن عطية: <q>﴿رُوَيْدًا﴾</q> معناه قليلًا، قاله قتادة، وهذه حال هذه اللفظة إذا تقدمها شيء تصفه كقولك: رويدًا، وتقدمها فعل يعمل فيها كهذه الآية، وأما إذا ابتدأت بها فقلت: رويدًا يا فلان، فهي بمعنى الأمر بالتماهل، ويجري مجرى قولهم: صبرًا يا زيد، وقليلًا: يا عمرو. انظر: "المحرر الوجيز" 5/ 467.ممن قال بأن الآية منسوخة بآية السيف: هبة الله بن سلامة في: "الناسخ والمنسوخ" 196، وابن البازي في كتابه: "ناسخ القرآن العزيز ومنسوخه" 57، والبغوي في "معالم التنزيل" 4/ 474 والقرطبي في "الجامع لأحكام القرآن" 20/ 12. ورد ابن الجوزي في: "نواسخ القرآن" 251، القول بأنها منسوخة، والأكثرية عدها من المحكم، وعليه لم تذكر في كتبهم المعنية بـ"الناسخ والمنسوخ" نحو: كتاب "الناسخ والمنسوخ" في كتاب الله تعالى: لقتادة السدوسي، و"الناسخ والمنسوخ" للزهري، و"الناسخ والمنسوخ" في القرآن الكريم: لأبي جعفر النحاس، و"الناسخ والمنسوخ" لأبي منصور البغدادي، والاعتبار في "الناسخ والمنسوخ" لأبي بكر الهذاني، و"المصفى بأكف أهل الرسوخ" في علم "الناسخ والمنسوخ" لابن الجوزي.انظر: مادة: (مهل) في: "تهذيب اللغة" 6/ 321، "لسان العرب" 11/ 366، "تاج العروس" 8/ 121.البيت للجموح الظفري.وقد ورد البيت في: "تهذيب اللغة" 14/ 162: مادة: (رود) غير منسوب براوية: "فاتر"؛ بدلًا من: "ثمل"، "لسان العرب" 3/ 189: مادة: (رود) غير منسوب برواية: "تكاد لا تَثْلِم البطحاء وطأتُها"، كما ما ورد في حاشية "الجامع لأحكام القرآن" 20/ 13، حاشية 3: معزوًا، وبمثل ما جاء في اللسان، وورد في "معجم شواهد العربية" لعبد السلام هارون: 121، ونسبه إلى الجموح الظفري، كتاب "حروف المعاني" للزجاجي: 9: رقم: 35.ورد قول أبي عبيدة في: "تهذيب اللغة" 14/ 162: مادة: (رود)، "التفسير الكبير" 31/ 134 إلا أنه عزاه إلى أبي عبيدة، "الجامع لأحكام القرآن" 20/ 12، "لسان العرب" 3/ 89: مادة: (رود).الإيضاح العضُدي: لأبي علي الفارسي: 163، وانظر: "التفسير الكبير" 31/ 34.انظر: "شرح المفصل" لابن يعيش 4/ 39 - 41، "حروف المعاني" للزجاجي: 9.البيت للهذلي، كذا قال شارح المفصل.في (ع): لعهم.في (أ)، و (ع): متماني.ورد البيت في: "ديوان الهذليين" 3/ 46: برواية "رويدَ"، "كتاب سيبويه" 1/ 243 برواية: "ولكن بُغْضُهُم" بدلًا من "وُدُدهم"، "تهذيب اللغة" 10/ 460: مادة: (جد)، ج: 14/ 162: مادة (ورد)، ج: 15/ 529: مادة (مين)، "لسان العرب" 3/ 111: مادة: (جد)، برواية "أمِّهِ" بدلًا من: "أمهم"، و"متنابز" بدلًا من: "متماين"، وج: 13/ 426: مادة: (مين). ومعنى البيت: أن عليا قبيلة من كنانة، كأنها قال: رويدك عليًا أي أرْود بهم وارفق بهم. ثم قال: جُدَّ ثَدْىُ أُمهم إلينا، أي بيننا وبينهم خؤولة، ورَحم، وقرابة من قبل أُمِّهم، فهم منقطعون إلينا بها، وإن كان في ودهم مَيْنٌ: أي كذب، وملق. "شرح المفصل" 4/ 40. والشاهد: نصب "علي" بـ"رويد"، لأن رويدًا بدل من قولك: أرود، ومعناه أمهل. "شرح المفصل" المرجع السابق.في (أ): (ومضاف).في (أ): يسيرًا.ما بين القوسين المزدوجين ساقط من (أ).ما بين القوسين المزدوجين ساقط من (أ).في أ: (للأجل).ما بين القوسين أي من قوله: ومن هذا ما ذكره سيبويه إلى: لم يجز أن يكون للحال نقله عن سيبويه من كتابه: 1/ 243 - 245، باختصار، وانظر قول سيبويه أيضًا في: "تهذيب اللغة" 14/ 162: مادة: (رود).ساقط من (أ).غير مقروءة.
87,1," <q>﴿سَبِّحِ اسْمَ رَبِّكَ الْأَعْلَى﴾</q> قال الفراء: "سبح اسم ربك"، و" [فسبح] باسم ربك {1}، كل ذلك قد جاء، وهو كلام العرب {2}. هذا كلامه، وكأنة جعلهما {3} بمعنى واحد، وبينهما فرق؛ لأن معنى "سبح باسم ربك" نزه الله بذكر اسمه المنزه المنبئ {4} عن تنزيهه وعلوه عما يقول الظالمون. و"سبح اسم ربك" (نزهه من السوء، وقيل: سبحان ربي الأعلى) {5}، وهذا معنى قول المفسرين {6}، وقد روى عن علي {7}، وابن عباس {8}، وابن الزبير {9} {10} -رضي الله عنهم- أنهم قرؤوا (قوله {11}: <q>﴿سَبِّحِ اسْمَ رَبِّكَ﴾</q> فقالوا: سبحان ربي الأعلى، فإذا قلت: سبح باسم ربك، كان المعنى: سبح (بذكر اسمه، وإذا قلت: سبحان اسم ربك، كان المعنى سبح) {12} ربك، لأن الاسم هو المسمى. قال صاحب النظم: قد احتج بهذا الفصل من يقول: إن الاسم، والمسمى واحد؛ لأن أحدًا لا يقول: سبحان (اسم) {11} الله، وسبحان اسم ربنا، فمعنى "سبح اسم ربك": سبح ربك، والرب أيضًا اسم، فلو كان غير المسمى لم يجز أن يقع التسبيح عليه {14}. ",footnotes:1:سورة الواقعة: 74: 96. قال تعالى <q>﴿فَسَبِّحْ بِاسْمِ رَبِّكَ الْعَظِيمِ﴾</q>."معاني القرآن": 3/ 256.في: أ: جعلها.في: أ: المنهي.ما بين القوسين من قول الزجاج في "معاني القرآن وإعرابه": 5/ 315.قال بذلك إضافة إلى ما ذكره الواحدي: ابن عمر، وقتادة، "جامع البيان": 30/ 151، وقال به أيضًا: الثعلبي في "الكشف والبيان" ج 13: 76/ ب، وعزاه البغوي إلى جماعة من الصحابة والتابعين في "معالم التنزيل": 4/ 475. وذهب آخرون إلى أن معنى الآية: نزه يا محمد اسم ربك الأعلى أن تسمى به شيئاً سواه نحو ما قال المشركون عن آلهتهم: اللات، والعزى. وقال غيرهم: بل معنى ذلك: نزه الله عما يقول فيه المشركون. وقال بعضهم: نزه تسميتك يا محمد ربك الأعلى، وذكرك إياه أن نذكره إلا وأنت له خاشع متذلل. وقالوا أيضًا: صل بذكر ربك يا محمد. راجع ذلك في "جامع البيان": 30/ 151 - 152."جامع البيان": 30/ 151، "النكت والعيون": 6/ 252، "المحرر الوجيز": 5/ 468.المراجع السابقة عدا المحرر.في: ع: زبير."المحرر الوجيز": 5/ 468.ساقط من: أ.ما بين القوسين ساقط من: أ.ساقط من: أ.ورد قوله في "الوسيط": 4/ 469، وقد بين ابن تيمية أنه أمره بتسبيح ربه في كلا الآيتين: الواقعة، والأعلى، ولكن ليس أمر بصيغة معينة، فإذا قال: سبحان الله وبحمده، وسبحانك اللهم وبحمدك، فقد سبح ربه الأعلى والعظيم، فالله هو الأعلى، وهو العظيم، واسمه "الله" يتناول سائر الأسماء بطريق التضمن، وان كان التصريح بالعلو والعظمة ليس هو فيه، ففي اسم "الله" التصريح بالإلهية، واسمه "الله" أعظم من اسمه "الرب". "مجموع الفتاوى": 16/ 117.
87,2," قوله: <q>﴿الَّذِي خَلَقَ فَسَوَّى﴾</q> قال عطاء: أحسن مَا خلق {1}. وقال الكلبي: خلق كل ذي روح، فجمع خلقه وسواه: اليدين، والعينين، والرجلين {2}. وقال مقاتل: خلق لكل دَابة مَا يصلح لها من الخلق {3}. وقال أبو إسحق: خلق الإنسان مستويًا {4}. وعلى هذا معنى: "سوى" عَدّل قامته {5}. <q>﴿وَالَّذِي قَدَّرَ﴾</q> وقرئ بالتخفيف {6}، وهما بمعنى واحد {7}، وقد ذكرناه {8} في مواضع {9}. قال عطاء: قدر من النسل مَا أراد {10}. وقال مقاتل: قدر خلق الذكر والأنثى من الدواب {11}. <q>﴿فَهَدَى﴾</q>. الذكر، والأنثى كيف يأتيها، وهو قول ابن عباس {12}، (والكلبي) {13} {14}. قال عطاء: مثل قوله: <q>﴿أَعْطَى كُلَّ شَيْءٍ خَلْقَهُ ثُمَّ هَدَى﴾</q> {15} يريد الذكر والأنثى {16}. واختاره صاحب النظم، قال: معنى هذا {17} هداية الذكر لإتيان الأنثى كيف يأتيها؛ لأن إتيان ذكران الحيوان مختلف لاختلاف الصور والخلق، والهيآت، فلولا أنه عز وجل جعل كل ذكر على معرفته {18} كيف يأتي أنثى جنسه لما اهتدى لذلك {19}. وذكر مقاتل قولًا آخر فقال: هداه لمعيشته ومرعَاه {20}. وقال مجاهد: هدى الإنسان لسبيل الخير، والشر، والسعادة {21}، والشقاوة {22}. وقال السدي: قدر مُدة الجنين في الرحم، ثم هدى للخروج {23}. وقال الفراء: قدر فهدى وأضل، واكتفى من ذكر الضلال بالهدى {24} لكثرة ما يكون معه {25}. قوله (تعالى) {26}: <q>﴿وَالَّذِي أَخْرَجَ الْمَرْعَى﴾</q> أنبت العشب، وما ترعَاه السوائم. <q>﴿فَجَعَلَهُ﴾</q> {27} بعد الخضرة. <q>﴿غُثَاءً﴾</q> هشيما جافًا كالغثاء الذي تراه فوق السيل. قال المبرد: الغثاء: مَا تحطم من يبس البقل يأتي به السيل فيقذفه على جانب الوادي {28}. قال الكلبي: غثاء يبيسًا {16}. وقال مقاتل: يابسًا {30}. وقوله {31} (تعالي) {32}: <q>﴿أَحْوَى﴾</q>. فيه وجهان أحدهما: أنه من نعت الغثاء، والمعنى فجعله يابسًا أسود بعد الخضرة. قال عطاء: يريد بعد الخضرة والحسن صَار متغيرًا إلى السواد {16}. وقال الكلبي: حال عليه الحول فاسودّ {16}. وقال مقاتل: يعني باليًا بعد الخضرة {35}. هذا مذهب المفسرين {36}، وذلك أن الرطب إذا جف يبس واسودّ كما قال {37}: ربع الخمائل في الدرين الأسود {38} وذكر أبو عبيدة {39} هيجه حتى يبس فجعله أسود من احتراقه غثاء هشيماً، وهو في موضع آخر: من شدة خضرته، وكثرة مائه يقال له أحوى.]]، والفراء {40}، (والمبرد {41}، والزجاج) {42} {43}، وأبو علي {16} وجهًا آخر، وهو أن <q>﴿أَحْوَى﴾</q> في موضع نصب حال من المرعى، المعنى: الذي أخرج المرعى أحوى، أي أخضر يضرب إلى الحوَّهَ <q>﴿فَجَعَلَهُ غُثَاءً﴾</q>، وأحوى على هذا صفة للمرعى، والمعنى أسودّ من الري لشدة الخضرة كقوله: <q>﴿مُدْهَامَّتَانِ﴾</q> [الرحمن: 64]، وقد مر {45}. والحوّة: السواد، قال ذو الرمة: لَمياءُ في شَفَتَيْها حُوَّةٌ لَعَسٌ ... وفي اللثَّاتِ {46} وفي أنيابِها شَنَبُ {47} (قوله تعالى) {32}: <q>﴿سَنُقْرِئُكَ﴾</q> {49} أي سنجعلك قارئًا بأن نلهمك القراءة. <q>﴿فَلَا تَنْسَى﴾</q> ما تقرأه. والمعنى: نجعلك قارئًا للقرآن تقرأه فلا تنساه. قال أبو إسحق: أعلم الله أنه سيجعل للنبي -ﷺ- آية يتبين له بها الفَضْيلة {50}، وهي أن ينزل عليه جبريل حتى يقريه، فيقرأ، ولا ينسى شيئًا من ذلك، وهو أمي لا يكتب كتابًا ولا يقرؤه {51}، وهذا معنى قول قتادة {52}. وقال مجاهد {53}، ومقاتل {54}، (والكلبي) {55} {14} كان النبي -ﷺ- إذا نزل عليه القرآن أكثر تحريك لسَانه، مخافة أن ينسى، وكان لا يفرغ جبريل من آخر الوحي حتى يتكلم {21} هو بأوله مخافة النسيان، فقال الله تعالى: <q>﴿سَنُقْرِئُكَ فَلَا تَنْسَى﴾</q> أي سنعلمك فتحفظه، وهذا كقوله: <q>﴿وَلَا تَعْجَلْ بِالْقُرْآنِ مِنْ قَبْلِ أَنْ يُقْضَى {58} إِلَيْكَ وَحْيُهُ﴾</q> [طه: 16]، وقوله: <q>﴿لَا تُحَرِّكْ بِهِ لِسَانَكَ لِتَعْجَلَ بِهِ﴾</q> {21} [القيامة:16]. قوله (تعالى) {32}: <q>﴿إِلَّا مَا شَاءَ اللَّهُ﴾</q> {61}. قال عطاء عن ابن عباس: إلا مَا شاء الله أن ينسيَك {62}. ونحوه قال مقاتل: إلا مَا شاء الله أن تنسى منه {63}. وعلى هذا معنى الاستثناء يعود إلى مَا ينسيه الله بنسخه من رفع حكمه {64} وتلاوته، كما قال <q>﴿مَا نَنْسَخْ مِنْ آيَةٍ أَوْ نُنْسِهَا﴾</q> [البقرة: 106]، والإنساء {65} نوع من النسخ، (وهذا معنى قول الحسن {66}، وقتادة) {67} {43}. وقال الكلبي - <q>﴿إِلَّا مَا شَاءَ اللَّهُ﴾</q> استثناء منه، وله الاستثناء في كل شيء، ولم ينس بعد نزول هذه الآية شيئا {69} واختاره الفراء، فقال: لم يشأ أن ينسى شيئًا {70} وهو كقوله <q>﴿خَالِدِينَ فِيهَا مَا دَامَتِ السَّمَاوَاتُ وَالْأَرْضُ إِلَّا مَا شَاءَ رَبُّكَ﴾</q> {71} ولا يشاء، وأنت قائل في الكلام لأعطينك كل مَا سَألت إلا مَا شئت، وإلا أن أشاء أن أمنعك، والنية أن لا تمنعه، وعلى هذا مجاري الأيمان يستثنى فيها ونية الحالف {72} قال أبو إسحق: إلا مَا شاء الله، ثم يَذْكُره بعد {73}. يعني أنه قد ينسى مَا شاء الله، ثم يَذْكُر بعد ما قد نسيه، ولا ينسى نسيانًا كليًا. وقوله {31} (تعالى) {32}: <q>﴿إِنَّهُ يَعْلَمُ الْجَهْرَ﴾</q> أي من القول، والفعل {76}. <q>﴿وَمَا يَخْفَى﴾</q> منهما. والمعنى يعلم العلانية، والسر. وهذا يتصل بما قبله على معنى يعلم ما تجهر به يا محمد مما تقرؤه على جبريل، ويعلم ما تخفيه في نفسك من القراءة مخافة النسيان {77}. وكثير من المفسرين {78} قالوا: هذا ابتداء كلام آخر معترض بين قوله: <q>﴿سَنُقْرِئُكَ فَلَا تَنْسَى﴾</q> وقوله {31} (تعالى) {32}: <q>﴿وَنُيَسِّرُكَ لِلْيُسْرَى﴾</q> قال عطاء: نيسرك يا محمد في جميع أمورك لليسرى {16}. وقال مقاتل: نهون عليك عمل الجنة {82}، وهو معنى قول ابن عباس: نيسرك لأن تعمل خيرًا، واليسرى عمل الخير {83}. وروي عن ابن مسعود أنه قال: اليسرى الجنة {84}، والمعنى على هذا: نيسرك للعمل المؤدي إليها. وذُكر قولان آخران: أحدهما: نهون عليك الوحي، وتحفظه، وتعمله {85}، وتعمل به {86}. والآخر: نوفقك للشريعة اليسرى هى الحنيفة السمحة {87}. ",footnotes:1:ورد قوله في: "شفاء العليل" في مسائل القضاء والقدر والحكمة والتعليل: لابن قيم الجوزية: 117 - 118، وإحسان خلقه يتضمن تسويته، وتناسب خلقه وأجزائه؛ بحيث لم يحصل فيها تفاوت يخل بالتناسب والاعتدال، فالخلق: الإيجاد، والتسوية: إتقانه وإحسان خلْقه، قاله ابن قيم الجوزية: "شفاء العليل": 118."معالم التنزيل": 4/ 475، بنحوه، "روح المعاني": 30/ 104، "شفاء العليل": 118 وورد غير معزو في "لباب التأويل": 4/ 369.لم أعثر على قوله في تفسيره، ولا غيره من كتب التفسير، وقد ورد في: "شفاء العليل": 118."معاني القرآن وإعرابه": 5/ 315، وهذا القول من الزجاج على سبيل التمثيل، وإلا فالخلق والتسوية شامل للإنسان وغيره، قال تعالى: <q>﴿وَنَفْسٍ وَمَا سَوَّاهَا﴾</q> == [الشمس: 7]، <q>﴿فَسَوَّاهُنَّ سَبْعَ سَمَاوَاتٍ﴾</q> البقرة: 29]، فالتسوية شاملة لجميع مخلوقاته، <q>﴿مَا تَرَى فِي خَلْقِ الرَّحْمَنِ مِنْ تَفَاوُتٍ﴾</q> [الملك: 3] وما يوجد من التفاوت، وعدم التسوية، فهو راجع إلى عدم إعطاء التسوية للمخلوق، فإن التسوية أمر وجودي تتعلق بالتأثير والإبداع، فما عُدم منها فالعدم بإرادة الخالق بالتسوية، وذلك أمر عَدَمي يكفي فيها عدم الإبداع والتأثير، ففي قوله: <q>﴿مَا تَرَى فِي خَلْقِ الرَّحْمَنِ مِنْ تَفَاوُتٍ﴾</q> التفاوت حاصل بسبب عدم مشيئة التسوية، كما أن الجهل، والصمم، والعمى، والخرس، والبكم يكفي فيها عدم مشيئة خلْقها وإيجادها، والمقصود أن كل مخلوق فقد سواه خلقه سبحانه في مرتبة خلقه، وإن فاتته التسوية من وجه آخر لم يخلق له. قاله ابن قيم الجوزية في: "شفاء العليل": 118.ما مضى من الأقوال داخله في المرتبة الأولى من مراتب الهداية، وهي الهداية العامة؛ هداية كل نفس إلى مصالح معاشها وما يقيمها، المتضمنة أربعة أمور عامة وهي: الخلق، التسوية، التقدير، الهداية: "شفاء العليل": 117.قرأ بذلك: الكسائي وحده: "قدَرَ" خفيفاً، وقرأ الباقون: <q>﴿وَالَّذِي قَدَّرَ﴾</q> مشددة. انظر: كتاب "السبعة": 680، "القراءات وعلل النحويين فيها": 2/ 767، و"الحجة": 6/ 398، "المبسوط": 405، "النشر": 2/ 399، "الوافي": 379.أي قَدَر، وقَدِّر. فكلا الوجهين حسن. قاله أبو علي: "الحجة": 6/ 398.في: ع: ذكرنا.المواضع التي ذكر فيها <q>﴿قُدِرَ﴾</q>: سورة فصلت: 10: قال تعالى: <q>﴿وَقَدَّرَ فِيهَا أَقْوَاتَهَا﴾</q>: سورة المدثر: 18 - 20 قال تعالى: <q>﴿إِنَّهُ فَكَّرَ وَقَدَّرَ (18) فَقُتِلَ كَيْفَ قَدَّرَ (19) ثُمَّ قُتِلَ كَيْفَ قَدَّرَ﴾</q>."شفاء العليل": 118، بإضافة: ثم هدى الذكر للأنثى."تفسير مقاتل": 237/ ب، "شفاء العليل": 118، وانظر "الوسيط": 3/ 470 وعزاه إلى المفسرين."الجامع لأحكام القرآن": 20/ 15، "شفاء العليل": 118."الكشف والبيان": ج: 13: 77/ أ، "معالم التنزيل": 4/ 475، "المحرر الوجيز": 5/ 469 بمعناه، "الجامع لأحكام القرآن": 20/ 15، "شفاء العليل": 118.ساقط من: أ.سورة طه: 50.لم أعثر على مصدر لقوله.في: ع: هذي.في: ع: معرفة."الوسيط": 4/ 470، "شفاء العليل": 118."شفاء العليل": 118، "التفسير الكبير": 31/ 140 من غير عزو، ولم أعثر على قوله في تفسيره.بياض في: ع.ورد معنى قوله في: "تفسير الإمام مجاهد": 722، "جامع البيان": 30/ 152، "الكشف والبيان" -ج: 13: 77/ أ، "النكت والعيون": 6/ 252، وبمثل قوله ورد في "معالم التنزيل": 4/ 475، "زاد المسير": 8/ 228، "التفسير الكبير": 31/ 140 من غير عزو، "الجامع لأحكام القرآن": 20/ 15 بنحوه، "تفسير القرآن العظيم": 4/ 534 بمعناه، "الدر المنثور": 8/ 482 وعزاه أيضًا إلى الفريابي، وعبد بن حميد، وابن المنذر، وابن أبي حاتم، وانظر "شفاء العليل": 118.ورد معنى قوله في "معالم التنزيل": 4/ 475، "زاد المسير": 8/ 228، "الجامع لأحكام القرآن": 20/ 26، "روح المعاني": 30/ 104، "شفاء العليل": 118.في: أ: الهدا."معاني القرآن": 3/ 256 بنصه. والآية أعم من هذا كله، وأضعف الأقوال فيها قول الفراء، إذ المراد: هاهنا: الهداية العامة لمصالح الحيوان في معاشه، وليس المراد به الإيمان والضلال بمشيئة، وهو نظير قوله: <q>﴿رَبُّنَا الَّذِي أَعْطَى كُلَّ شَيْءٍ خَلْقَهُ ثُمَّ هَدَى﴾</q> طه: 50، فإعطاء الخلق إيجاده في الخارج، والهداية: التعليم، والدلالة على سبيل بقائه وما يحفظه ويقيمه، وما ذكر مجاهد فهو تمثيل منه لا تفسير مطابق للآية، فإن الآية شاملة لهداية الحيوان كله: ناطقه، وبهيمة، وطيره، ودوابه، فصيحه، وأعجمه، وكذلك قول من قال: إنه هداية الذكر لإتيان الأنثى تمثيل أيضًا، وهو فردٌ واحدٌ من أفراد الهداية إلى التقام الثدي عند خروجه من بطن أمه، والهداية إلى معرفته أمه دون غيرها حتى يتبعها أين ذهبت، والهداية إلى قصد ما ينفعه من المرعى دون ما يضره منه. قاله ابن قيم الجوزية "شفاء العليل": 119. وقال الشيخ السعدي: وهذه هي الهداية العامة التي مضمونها أنه هدى كل مخلوق لمصلحته. تيسير الكريم الرحمن: 5/ 403.بياض من: ع: 5<q>﴿فَجَعَلَهُ غُثَاءً أَحْوَى﴾</q>.لم أعثر على مصدر لقوله، والذي ورد عنه في الكامل، قال: فالغثاء ما يَبسَ من البقل حتى يصير حُطاماً، وينتهي في اليبس فيسودّ، فيقال له: غثاء، وهشيم، ودِنْدِن، وثن على قدر اختلاف أجناسه: 1/ 113.لم أعثر على مصدر لقوله."تفسير مقاتل": 237/ ب.في: أ: قوله.ساقط من: ع.لم أعثر على مصدر لقوله.لم أعثر على مصدر لقوله.ورد معنى قوله في "تفسير مقاتل": 237/ ب.وإلى معنى هذا ذهب قتادة، ومجاهد، وابن زيد، وابن عباس. "تفسير عبد الرزاق": 2/ 367 "جامع البيان": 30/ 153. == وإليه ذهب ابن قتيبة في: "تفسير غريب القرآن": 524، وانظر: "معالم التنزيل": 4/ 476، "الجامع لأحكام القرآن": 20/ 17، "لباب التأويل": 4/ 370. كما ذهب إلى ذلك الفراء في "معاني القرآن": 3/ 256، وأبو عبيدة في "مجاز القرآن": 2/ 295لم أعثر على قائله.لم أعثر على مصادر له."مجاز القرآن": 2/ 295، وقد ذكر الوجهين، قال: فجعله [[غثاء أحوى"معاني القرآن": 3/ 256، وذكر الوجهين أيضًا، وقال: الأحوى الذي قد أسودّ عن العتق، ويكون أيضًا أخرج المرعى أحوى فجعلة غثاء، فيكون مؤخراً معناه التقديم."الكامل": 1/ 305، واستدل في الآية لمن قال في السواد، ثم قال: وإنما سمي السواد سواداً لعِمارتِهِ، وكل خضرة عند العرب سواد."معاني القرآن وإعرابه": 5/ 315.ما بين القوسين ساقط من: أ.لم أعثر على مصدر لقوله.ومما جاء في تفسير قوله: <q>﴿مُدْهَامَّتَانِ﴾</q>: قال أبو عبيدة: في خضرتهما قد اسودتا == من الري، قال أبو إسحق: وكل نبت أخضر فتمام خضرته وريه أن يضرب إلى السواد، ومعنى الدهمة في كلام العرب السواد. قال الليث: أدهام الزرع إذ علاه السواد رياً. قال ابن عباس: شديد الخضرة إلى السواد. وقال الكلبي: خضراوان قد كلاهما سواد من شدة الخضرة والري، والأصل في ذلك أن الخضرة إذا اشتدت ضربت إلى السواد، سمت العرب الأخضر أسود، والأسود أخضر. والوجه الثاني: رده الطبري، قال: وهذا القول، وإن كان غير مدفوع أن يكون ما اشتدت خضرته من النبات، قد تسميه العرب أسود، غير صواب عندي، بخلافه تأويل أهل التأويل في أن الحرف إنما يحتال لمعناه المخرج بالتقديم والتأخير إذ لم يكن له وجه مفهوم إلا بتقديمه عن موضعه، أو تأخيره، فأما وله في موضعه وجه صحيح فلا وجه لطلب الاحتيال لمعناه بالتقديم والتأخير. "جامع البيان" - 30/ 153.في: أ: الثات.ورد البيت في ديوانه: 1/ 32، "تهذيب اللغة": 5/ 293: مادة: (حوى)، "لسان العرب": 1/ 507: مادة: (شنب)، "النكت والعيون": 6/ 253، "الجامع لأحكام القرآن": 20/ 17، وقد نسبه إلى الأعشى وهو خطأ، "فتح القدير": 5/ 423، "روح المعاني": 30/ 104، "البحر المحيط": 8/ 457، ومعنى البيت قال الأزهري: والحوَّه في الشفاه شبيه باللمى واللمس، براوية "لمس" بدلاً من "لعس"، والشنب: اختلفوا فيه، قال بعضهم: هو تحزيز أطراف الأسنان، وقيل: هو صفاؤها ونقاؤها، وقيل: هو تفليجها، وقيل: هو طيب نكهتها. انظر "تهذيب اللغة": 5/ 293: مادة: (حوى)، "لسان العرب": 1/ 507: مادة: (شنب).ساقط من: ع.<q>﴿سَنُقْرِئُكَ فَلَا تَنْسَى﴾</q>.الفضيلة: هكذا وردت في "معاني القرآن وإعرابه": مخطوط: 29/ ب، ووردت في المطبوع الفضلية: 5: 315، ولعله خطأ مطبعي."معاني القرآن وإعرابه": 5/ 315 - 316 بتصرف.وعن قتادة قال: كان الله ينسى نبيه -ﷺ- ما يشاء، وعنه أيضًا كان -ﷺ- لا ينسى شيئاً إلا ما شاء الله. انظر "تفسير عبد الرزاق": 2/ 367، "جامع البيان": 30/ 154، "الكشف والبيان": ج 13: 77/ أ، "النكت والعيون": 6/ 253، "المحرر الوجيز": 5/ 469، "البحر المحيط": 8/ 458."الكشف والبيان": ج 13: 77/ أ، "معالم التنزيل": 4/ 476، "التفسير الكبير". 31/ 142، "الجامع لأحكام القرآن": 20/ 18، "لباب التأويل": 4/ 370 من غير عزو، "فتح القدير": 5/ 424."تفسير مقاتل": 237/ ب، "التفسير الكبير": 31/ 142، وورد بمثله من غير نسبة في "لباب التأويل": 4/ 370.المرجعان السابقان، بإضافة: الكشف ج: 13: 77/ أ، "معالم التنزيل": 4/ 476، "الجامع لأحكام القرآن": 20/ 18، "فتح القدير": 5/ 424.ساقط من: أ.بياض في: ع.قوله أن يقضي: بياض في: ع.بياض في: ع.ساقط من: ع.<q>﴿إِلَّا مَا شَاءَ اللَّهُ إِنَّهُ يَعْلَمُ الْجَهْرَ وَمَا يَخْفَى﴾</q>."البحر المحيط": 8/ 458 - 459، "الدر المنثور": 8/ 483، وعزاه إلى ابن المنذر، وابن أبي حاتم."التفسير الكبير": 31/ 143، والذي ورد عنه في تفسيره: 237/ ب قال: يعني ما شاء الله فينسخها وباتي بخير منها.في: أ: حكمته.في: أ: الإنسان."النكت والعيون": 6/ 253، "المحرر الوجيز": 5/ 469، "زاد المسير": 8/ 229، "البحر المحيط": 8/ 458، وانظر "تفسير الحسن البصري": 2/ 412.المراجع السابقة عدا تفسير الحسن.ما بين القوسين ساقط من: أ.ورد معنى قوله في "التفسير الكبير": 31/ 142.من قوله: واختار إلى شيئا: كرر في نسخه: أ.سورة هود: 107 - 108."معاني القرآن": 3/ 256 بنحوه. وفيه الحالف التمام."معاني القرآن وإعرابه": 5/ 316 مختصرًا.في: أ: قوله.ساقط من: ع.هذا من قول الثعلبي في "الكشف والبيان": ج 13: 77/ ب.ورد هذا القول في "الكشف والبيان": ج 13: 77/ ب.منهم قتادة، قال: الوسوسة. "تفسير عبد الرزاق": 2/ 367، ولم أعثر على غيره ممن قال بذلك. وذهب إلى القول بعموم معنى الآية: الطبري في "جامع البيان": 30/ 154، وسعيد بن جبير كما في "الدر المنثور": 8/ 484، والشوكاني في "فتح القدير": 5/ 424.في: أ: قوله.ساقط من: ع.لم أعثر على مصدر لقوله."معالم التنزيل": 4/ 476، "فتح القدير": 5/ 424."النكت والعيون": 6/ 254، "معالم التنزيل": 4/ 476، "الجامع لأحكام القرآن": 20/ 19، "الدر المنثور": 8/ 484، وعزاه إلى ابن أبي حاتم."النكت والعيون": 6/ 254، "التفسير الكبير": 31/ 144، "الجامع لأحكام القرآن": 20/ 19.تعمله: كررت في نسخه: أ."فتح القدير": 5/ 424، وبمثله من غير عزو ورد في "معالم التنزيل": 4/ 476، == "التفسير الكبير": 31/ 144، "الجامع لأحكام القرآن": 20/ 19.ورد هذا القول من غير عزو في المراجع السابقة، وقال الشوكاني: الأولى حمل الآية على العموم أي: نوفقك للطريقة اليسرى في الدين والدنيا في كل أمر من أمورهما التي تتوجه إليك. "فتح القدير": 5/ 424.
