quran[9]{c,v,t}:
  30,42,"<div class=ar lang=ar><p>قال مقاتل: ثم خوفهم فقال: <span class="qpc-hafs">﴿قُلْ سِيرُوا فِي الْأَرْضِ﴾</span> الآية {1}، وقوله: <span class="qpc-hafs">﴿كَانَ أَكْثَرُهُمْ مُشْرِكِينَ﴾</span> فأهلكوا بكفرهم. وإخباره عنهم بالشرك إخبار عن إهلاكهم؛ ودل عليه قوله: <span class="qpc-hafs">﴿كَيْفَ كَانَ عَاقِبَةُ الَّذِينَ مِنْ قَبْلُ﴾</span> ومعلوم أن عاقبتهم كان إلى الهلاك.</p></div>",footnotes:1:"تفسير مقاتل" 80 أ.
  30,43,"<div class=ar lang=ar><p>قوله: <span class="qpc-hafs">﴿فَأَقِمْ وَجْهَكَ﴾</span> قال أبو إسحاق: أقم قَصدك، واجعل جهتَك اتباع الدين القيم {1}. قال مقاتل: وهو الإسلام المستقيم <span class="qpc-hafs">﴿مِنْ قَبْلِ أَنْ يَأْتِيَ يَوْمٌ لَا مَرَدَّ لَهُ مِنَ اللَّهِ﴾</span> يعني: يوم القيامة لا يقدر أحد على رد ذلك اليوم {2}؛ لأن الله قد قضى بمجيئه، فإذا جاءكم لا مردَّ له.</p><p><span class="qpc-hafs">﴿يَوْمَئِذٍ يَصَّدَّعُونَ﴾</span> أي: يتفرقون بعد الحساب، إلى الجنة والنار. قاله مقاتل {3}. وهذا كقوله: <span class="qpc-hafs">﴿يَوْمَئِذٍ يَتَفَرَّقُونَ﴾</span> وقد مر {4}. قال الفراء: <span class="qpc-hafs">﴿يَصَّدَّعُونَ﴾</span>: يتصدعون، أي: يتفرقون، تقول العرب: صدَعتُ غنمي صِدْعَتين، أي: فَرَقْتُها فِرقتين {5}.</p></div>",footnotes:1:"معاني القرآن" للزجاج 4/ 188."تفسير مقاتل" 80 أ."تفسير مقاتل" 80 أ. والزجاج، "معاني القرآن" 4/ 188.الآية 14، من هذه السورة."معاني القرآن" للفراء 2/ 325، وليس فيه: يتصدعون.
  30,44,"<div class=ar lang=ar><p>قوله: <span class="qpc-hafs">﴿مَنْ كَفَرَ فَعَلَيْهِ كُفْرُهُ﴾</span> قال ابن عباس: يجازى بكفره. قال مقاتل: عليه إثم كفره {1} <span class="qpc-hafs">﴿وَمَنْ عَمِلَ صَالِحًا فَلِأَنْفُسِهِمْ يَمْهَدُونَ﴾</span> أي: يوطئون لأنفسهم منازلهم {2}.</p><p>وقال الكلبي: يفرشون {3}.</p><p>وقال مجاهد: يسوون المضاجع في القبر {4}. يقال: مهدت لنفسي خيرًا؛ أي: هيأته ووطأته.</p></div>",footnotes:1:"تفسير مقاتل" 80 أ.قال الزجاج 4/ 188: أىِ: لأنفسهم يوطئون."تنوير المقباس" ص 342.أخرجه ابن جرير 21/ 52.
  30,45,"<div class=ar lang=ar><p>قوله: <span class="qpc-hafs">﴿لِيَجْزِيَ الَّذِينَ آمَنُوا﴾</span> اللام متعلقة بقوله: <span class="qpc-hafs">﴿يَمْهَدُونَ﴾</span> أي: يمهدون لأنفسهم ليجزيهم الله <span class="qpc-hafs">﴿مِنْ فَضْلِهِ﴾</span> قال ابن عباس: ليثيبهم الله أكثر من ثواب أعمالهم.</p></div>"
  30,46,"<div class=ar lang=ar><p>قوله تعالى: <span class="qpc-hafs">﴿وَمِنْ آيَاتِهِ أَنْ يُرْسِلَ الرِّيَاحَ مُبَشِّرَاتٍ﴾</span> قال ابن عباس: بالمطر {1} <span class="qpc-hafs">﴿وَلِيُذِيقَكُمْ مِنْ رَحْمَتِهِ﴾</span> قال: يريد الغيث والخَصْب. قال صاحب النظم: هو معطوف على تأويل: <span class="qpc-hafs">﴿مُبَشِّرَاتٍ﴾</span> على نظم: <span class="qpc-hafs">﴿وَمِنْ آيَاتِهِ أَنْ يُرْسِلَ الرِّيَاحَ﴾</span> ليبشركم وليذيقكم من رحمته، ولتجري الفلك في البحر بتلك الرياح بأمره، ولتبتغوا في البحر من فضله، يعني: الرزق بالتجارة. قال مقاتل: كل هذا بالرياح <span class="qpc-hafs">﴿وَلَعَلَّكُمْ تَشْكُرُونَ﴾</span> هذه النعمة فتوحدونه.</p></div>",footnotes:1:"تنوير المقباس" ص 342، وأخرجه ابن جرير 21/ 53، عن مجاهد.
  30,47,"<div class=ar lang=ar><p>ثم خوف كفار مكة، وعزَّى نبيه -ﷺ- فقال: <span class="qpc-hafs">﴿وَلَقَدْ أَرْسَلْنَا مِنْ قَبْلِكَ رُسُلًا إِلَى قَوْمِهِمْ فَجَاءُوهُمْ بِالْبَيِّنَاتِ﴾</span> {1} أي: بالدلالات الواضحات على صدقهم. وقال ابن عباس: بالفرائض والحلال والحرام.</p><p>وقال مقاتل: أخبروهم بالعذاب أنه نازل بهم إن لم يؤمنوا {1}.</p><p>قوله تعالى: <span class="qpc-hafs">﴿فَانْتَقَمْنَا مِنَ الَّذِينَ أَجْرَمُوا﴾</span> كفروا بآياتهم {3}.</p><p>وقال الكلبي: جرمهم هاهنا: الكفر {4}.</p><p><span class="qpc-hafs">﴿وَكَانَ حَقًّا عَلَيْنَا نَصْرُ الْمُؤْمِنِينَ﴾</span> قال الحسن: نصر المؤمنين: إنجاؤهم مع الرسل من عذاب الأمم. وهو قول الكلبي ومقاتل {5}. ومعنى: <span class="qpc-hafs">﴿وَكَانَ حَقًّا عَلَيْنَا﴾</span> واجبًا، يعني: وجوبًا هو أوجبه على نفسه من حيث أخبر به، وإذا أخبر بشيء حق ذلك الشيء ووُجِد على ما أخبر به. وقد أخبر أنه ينجي المؤمنين من عذاب المكذبين. ولا يجب على الله شيء ابتداءً بخلاف ما قالت القدرية. وفي هذا تبشير النبي -ﷺ- بالظَفَر في العاقبة، والنصر على مَنْ كذبه.</p></div>",footnotes:1:"تفسير مقاتل" 80 أ."تفسير مقاتل" 80 أ.الضمير يعود على البينات التي جاء بها الرسل، كما يدل عليه سياق الآية."تنوير المقباس" (342)، وهو قول مقاتل 80 أ."تنوير المقباس" ص 342، و"تفسير مقاتل" 80 أ.
  30,48,"<div class=ar lang=ar><p>قال مقاتل: ثم أخبر عن صُنعه ليعرفوا توحيده فقال: <span class="qpc-hafs">﴿اللَّهُ الَّذِي يُرْسِلُ الرِّيَاحَ فَتُثِيرُ سَحَابًا﴾</span> {1} يزعجه من حيث هو <span class="qpc-hafs">﴿فَيَبْسُطُهُ﴾</span> الله <span class="qpc-hafs">﴿فِي السَّمَاءِ كَيْفَ يَشَاءُ﴾</span> قال مقاتل: إن شاء بسطه مسيرة يوم، أو بعض يوم، أو مسيرة أيام {2} <span class="qpc-hafs">﴿وَيَجْعَلُهُ كِسَفًا﴾</span> أي: قطعًا {3}، بعد أن بسطه الله يجعله قطعًا متفرقًا يسير بها الريح. وتفسير الكِسْف، قد ذكرناه في أواخر سورة بني إسرائيل {4}.</p><p>وقوله: <span class="qpc-hafs">﴿فَتَرَى الْوَدْقَ يَخْرُجُ مِنْ خِلَالِهِ﴾</span> مفسر في سورة: النور {5} <span class="qpc-hafs">﴿فَإِذَا أَصَابَ بِهِ﴾</span> بالمطر <span class="qpc-hafs">﴿مَنْ يَشَاءُ مِنْ عِبَادِهِ إِذَا هُمْ يَسْتَبْشِرُونَ﴾</span> يفرحون بنزول المطر عليهم {6}.</p></div>",footnotes:1:"تفسير مقاتل" 80 أ."تفسير مقاتل". 80 أ، والمراد بذلك المطر النازل من السحاب تختلف كثرته وقلته، من مسيرة يوم، أو أيام، وهذا مقصود مقاتل، حيث قال: أو مسيرة أيام يمطرون. والظاهر من الآية بسطه في السماء قبل نزوله، بدليل ما ذكر في الآية بعد ذلك من تقطيع السحاب، ثم نزول المطر. والله أعلم.أخرج ابن جرير 21/ 54، عن قتادة. و"معاني القرآن" للزجاج 4/ 189، ولم ينسبه.عند قوله تعالى: <span class="qpc-hafs">﴿أَوْ تُسْقِطَ السَّمَاءَ كَمَا زَعَمْتَ عَلَيْنَا كِسَفًا﴾</span> [92] قال الواحدي: == "قوله تعالى: <span class="qpc-hafs">﴿كِسَفًا﴾</span> فيه وجهان من القراءة؛ جزم السين وفتحها، قال أبو زيد: يقال كسفت الثوب أكْسِفُه كَسْفُا، إذا قطعته قِطَعًا .. قال الفراء: وسمعت أعرابيًا يقول لبزاز: أعطني كِسْفة، يريد: قطعة كقولك: خِرْقَه، روى عمرو عن أبيه: يقال لِخِرَق القميص قبل أن يُؤَلَّفَ: الكِسَف، واحدها كِسْفَة".عند قوله تعالى: <span class="qpc-hafs">﴿أَلَمْ تَرَ أَنَّ اللَّهَ يُزْجِي سَحَابًا ..﴾</span> [43]."تفسير مقاتل" 80 ب.
  30,49,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَإِنْ كَانُوا مِنْ قَبْلِ أَنْ يُنَزَّلَ عَلَيْهِمْ مِنْ قَبْلِهِ﴾</span> اختلفوا في تفسير <span class="qpc-hafs">﴿قَبْلِ﴾</span> فذكر أبو إسحاق وابن الأنباري فيه قولين؛ أحدهما: أن الأُولى: داخلة في الإنزال، والثانية: على المطر، والمعنى: <span class="qpc-hafs">﴿وَإِنْ كَانُوا مِنْ قَبْلِ﴾</span> إنزال المطر، من قبل المطر، فلما دخلت الثانية على غير ما دخلت عليه الأولى صلح الجمع بينهما، كما تقول: أجيئك من قبل أن تجلس، مِنْ قبل أن تبلغ إلى المجلس، فلا تُنكر الإعادة إذا اختلف الشيئان. هذا كلام أبي بكر {1}، وهو قول قطرب {2}.</p><p>القول الثاني: أن تكرير <span class="qpc-hafs">﴿قَبْلِ﴾</span> إطناب بمعنى: التوكيد {3}. والمعنى: وإن كانوا من قبل إنزال المطر <span class="qpc-hafs">﴿لَمُبْلِسِينَ﴾</span> قال أبو إسحاق: والقول ما قال {4}؛ لأن تنزيل المطر بمعنى: المطر؛ لأن المطر لا يكون إلا تنزيلاً، كما أن الرياح لا تُعرف إلا بمرورها {5}؛ يعني أن قوله: <span class="qpc-hafs">﴿مِنْ قَبْلِ أَنْ يُنَزَّلَ﴾</span> بمعنى: من قبل المطر عن الإنزال حتى يقال: إن قبل الأولى للإنزال، والثانية للمطر، كما قال قطرب {6}.</p><p>وقوله: <span class="qpc-hafs">﴿لَمُبْلِسِينَ﴾</span> أي: آيسين قانطين من المطر. قاله ابن عباس ومقاتل {7}. والتقدير: وما كانوا إلا مبلسين. وقد تقدم لهذا نظائر.</p></div>",footnotes:1:المراد به: ابن الأنباري؛ ولم أقف على قوله.نسبه لقطرب الزجاج 4/ 189، والثعلبي 8/ 170 أ. وحكاه ابن جرير 21/ 54، ولم ينسبه. أي: لما اختلف المضاف إلى الضمير لفظًا صح تكراره، والمعنى واحد، فالأول من قبل إنزال المطر، والثاني من قبل المطر، والمطر لا يكون إلا تنزيلًا.هذا قول الأخفش. "معاني القرآن" 2/ 658، واختاره ابن جرير 21/ 54.هكذا في النسختين: (قال). والصواب: ما قالوا، كما هو واضح من سياق الكلام عند الزجاج، حيث قال: "وقال الأخفش وغيره من البصريين: تكرير قبل، على جهة التوكيد، والمعنى: وإن كانوا من قبل تنزيل المطر لمبلسين، والقول كما قالوا؛ لأن تنزيل المطر .. "."معاني القرآن" للزجاج 4/ 189.ويمكن حمل الضمير في قوله تعالى: <span class="qpc-hafs">﴿مِنْ قَبْلِهِ﴾</span> على لفظ الاستبشار المفهوم من قوله: <span class="qpc-hafs">﴿إِذَا هُمْ يَسْتَبْشِرُونَ﴾</span> أو على الحال الموصوف في الآية السابقة إجمالًا المتضمن وصف السحاب وكيفية تكونه وسوقه وبسطه في السماء قبل خروج الودق منه وأثنائه، وهذا -كما يظهر- أحسن وأولى بالسياق من القول بالإطناب. والله أعلم."تفسير مقاتل" 80 ب. وأخرجه ابن جرير 21/ 54، عن قتادة. و"غريب القرآن" لابن قتيبة ص 342، ولم ينسبه.
  30,50,"<div class=ar lang=ar><p>قوله تعالى: <span class="qpc-hafs">﴿فَانْظُرْ إِلَى آثَارِ رَحْمَتِ اللَّهِ﴾</span> أي: بعد إنزال المطر، فانظر إلى حُسنِ تأثيره في الأرض. وتقرأ (آثَارِ) على الجمع {1}؛ فمن أفرد فلأنه مضاف إلى مفرد. ومن جمع جاز؛ لأن رحمة الله يجوز أن يراد بها: الكثرة، كما قال: <span class="qpc-hafs">﴿وَإِنْ تَعُدُّوا نِعْمَتَ اللَّهِ﴾</span> [إبراهيم: 34، النحل: 18] {2}. قال مقاتل: <span class="qpc-hafs">﴿آثَارِ رَحْمَتِ اللَّهِ﴾</span> يعني: النبت، وهو أثر المطر {3}. والمطر: رحمة الله ونعمته على خلقه.</p><p>وقوله: <span class="qpc-hafs">﴿كَيْفَ يُحْيِ الْأَرْضَ بَعْدَ مَوْتِهَا﴾</span> أي: كيف يجعلها تنبت بعد أن لم يكن فيها نبت.</p><p>(إِنَّ ذَلِكَ) الذي فعل ما ترون؛ وهو الله تعالى: <span class="qpc-hafs">﴿لَمُحْيِ الْمَوْتَى﴾</span> في الآخرة، فلا تكذبوا بالبعث {3} <span class="qpc-hafs">﴿وَهُوَ عَلَى كُلِّ شَيْءٍ قَدِيرٌ﴾</span> من البعث والموت.</p><p>ثم عاب كافر النعمة، والجاهل بأن الله تعالى يفعل ما يشاء فقال:</p></div>",footnotes:1:قرأ ابن كثير ونافع وأبو عمرو وعاصم في رواية أبي بكر: <span class="qpc-hafs">﴿إِلَى أَثَرِ﴾</span> واحدة بغير ألف، وقرأ الباقون وحفص عن عاصم: <span class="qpc-hafs">﴿ءَاثَرِ﴾</span> جماعة. "السبعة في القراءات" ص 508، و"الحجة للقراء السبعة" 5/ 448، و"النشر في القراءات العشر" 2/ 345"الحجة للقراء السبعة" 5/ 448، بنصه."تفسير مقاتل" 80 ب."تفسير مقاتل" 80 ب.