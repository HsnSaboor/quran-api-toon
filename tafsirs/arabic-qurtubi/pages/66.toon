quran[11]{c,v,t}:
  3,122,"<div class=ar lang=ar><p>قوله تعالى: <span class="qpc-hafs">﴿إِذْ هَمَّتْ طَائِفَتَانِ مِنْكُمْ أَنْ تَفْشَلَا﴾</span> قال الزّجاج {1}: العامل في (إذ) {2}: التَّبْوِئَة؛ المعنى: كانت التَّبْوِئَةُ في ذلك الوقت. و <span class="qpc-hafs">﴿هَمَّتْ﴾</span>؛ أي: قَصَدَت وأرادت. يقال: (هَمَمْتَ بالشيء)، (أَهَمُّ به هَمًّا) {3}. والطائفتان -في قول ابن عباس وأكثر المفسرين- {4}: بَنُو سَلِمَة {5} مِن الخزرج، وبنو حَارِثَة من الأنصار {6}.</p><p>وكان سبب ذلك أن {7} عبد الله بن أُبَيٍّ انْخَزَلَ {8}، فرجع عن الطريق في ثلاثمائةٍ، وهمت الطائفتان بالانصراف معه، فعصمهم الله، فلم ينصرفوا ومضوا مع رسول الله ﷺ {9}.</p><p>والفَشَل: الجُبْنُ، والخَوَرُ {10}.</p><p>وقوله تعالى: <span class="qpc-hafs">﴿وَاللَّهُ وَلِيُّهُمَا﴾</span> قال ابن عباس {11}: يريد: ناصِرُهما، ومُوَالٍ لهما على مَنْ عاداهما {12}.</p><p>وقوله تعالى: <span class="qpc-hafs">﴿وَعَلَى اللَّهِ فَلْيَتَوَكَّلِ الْمُؤْمِنُونَ﴾</span> التَوَكُّل: تَفَعُّل، مِن: (وَكَلَ أمْرَهُ إلى فلان): إذا اعتمد في كفايته عليه، ولم يَتَوَلَّهُ بنفسه {13}. وفي الآية إشارة إلى أنَّه ينبغي أن يستدفع {14} الإنسان ما يعرض له مِن حَرْفٍ {15} ومكروهٍ بالتوكل على الله، وأن {16} يَصْرِفَ الجَزَعَ {17} عن نفسه بالتوكل.</p></div>",footnotes:1:في "معاني القرآن" له 1/ 465. نقله عنه بنصه.في (ب): (إذا).انظر: "اللسان": 8/ 4702 (همم).قول ابن عباس في: "تفسير الطبري": 4/ 72، و"تفسير ابن أبي حاتم": 3/ 749. وهو قول جابر بن عبد الله - رضي الله عنه -، ومجاهد، وقتادة، والربيع، والسدي، والشعبي. انظر: "صحيح البخاري": (4051)، كتاب: المغازي، باب: (إذ همت طائفتان ...)، (4558) كتاب التفسير. سورة آل عمران. باب: (إذ همت طائفتان ..)، و"تفسير الطبري" 4/ 72، و"تفسير ابن أبي حاتم" 3/ 749.في (ب): (بنو أسلمة). و (سَلِمة) -بفتح السين وكسر اللام-، وترد في بعض المراجع بفتح اللام، وهو خطأ.</p><p>قال الأستاذ محمود شاكر: (بنو سَلِمة -بفتح السين وكسر اللام- وليس في العرب (سَلِمة) -بكسر اللام- غيرها، وسائرها بفتح اللام. وهم: بنو سلمة بن سعد بن علي بن أسد بن سادرة بن تزيد بن جشم بن الخزرج). هامش "تفسير الطبري" 7/ 161. (ط. شاكر).</p><p>ويذكر ابن الأثير أن النسبة إلى سَلِمة بن سعد المذكور سابقًا: (السَّلَمي) عند النحويين، وينطقونها بفتح اللام، وأما المُحدِّثون فينطقونها (السَّلِمي) بكسر اللام. انظر: اللباب في "تهذيب الأنساب" 2/ 129.</p><p>وقد ورد ضبطها بالكسر في: "المغازي" للواقدي 1/ 319، و"المعارف" لابن قتيبة 109، 159، و"تاريخ الطبري" 2/ 354، 356، و"الاشتقاق"، لابن دريد 566، و"عيون الأثر" 2/ 9، و"فتح الباري" 7/ 357.هم بنو حارثة بن النَّبت، أو النبيت، من الأوس. انظر: "سيرة ابن هشام": 3/ 58، و"المعارف" 110، 159، و"تفسير الطبري" 4/ 72، و"معاني القرآن" للنحاس 1/ 469، و"التعريف والإعلام" للسهيلي 77.أن: ساقطة من (ج).انخزل؛ أي: انفرد وانقطع. و (الخَزْلُ، والاختزال، والانخزال): القطع والتقطع. انظر: "المجموع المغيث في غريب القرآن والحديث" 1/ 574، و"النهاية في غريب الحديث": 2/ 29 (خزل).وبقي من المجاهدين مع رسول الله ﷺ سبعمائة - رضي الله عنه - أجمعين- بعد رجوع ابنِ أُبَي ومن معه من الثلاثمائة، وكان عدد المشركين: ثلاثة آلاف.</p><p>انظر خبر هذه الغزوة في "سيرة ابن هشام" 3/ 3 وما بعدها، "طبقات ابن سعد" 2/ 36، و"تاريخ الطبري" 2/ 499 وما بعدها، و"المنتظم" لابن الجوزي 3/ 161، و"الكامل في التاريخ" 2/ 103، و"عيون الأثر" 2/ 5، و"البداية والنهاية" 3/ 10، و"حدائق الأنوار" لابن الديبع: 2/ 518.انظر: "تفسير الطبري" 4/ 74، و"معاني القرآن" للزجاج 1/ 465، و"تفسير المشكل من غريب القرآن" لمكي 51، و"تذكرة الأريب" لابن الجوزي 1/ 98، و"تحفة الأريب" لأبي حيان 247.</p><p>قال ابن عباس: <span class="qpc-hafs">﴿أَنْ تَفْشَلَا﴾</span> يعني: أن تَجْبُنا، بلغة حِمْيَر). "اللغات في القرآن": 20.لم أقف على مصدر قوله.وقد فسرها ابن إسحاق بقوله: (المدافع عنهما ما همَّتا به من فشلهما؛ وذلك أنه إنما كان ذلك منهما عن ضعف ووهن أصابهما، غير شك في دينهما، فتَولَّى دفع ذلك عنهما برحمته وعائدته، حتى سلمتا من وهونهما وضعفهما، ولحقتا بالنبي ﷺ). "سيرة ابن هشام": 3/ 58. وانظر: "تفسير الطبري" 4/ 74، و"تفسير ابن أبي حاتم" 3/ 749.(والتوكل: إظهار العجز، والاعتماد على الغير، والاسم: التُّكلان). "القاموس": (1069) (وكل). وانظر: "مقاييس اللغة": 6/ 136 (وكل).في (ب): (يدفع).في (ج): (حرب). وما في نسخة (ج) له وجاهته، ومناسبته التامة هنا؛ لأن المقام هنا مقام حديث عن الحرب، إلا أن ما أثبته وهو في نسخة الأصل (أ)، (ب)، له وجهه كذلك؛ لأن (الحرف) من (حَرَفَ الشيء، يحرف حَرْفا)، و (انحرف، وتَحرَّف): عَدَلَ. ومال عن الشيء، و (حَرَف الشيءَ عن وجهه): صرفه. فيكون معناها في هذا الموضع هو الصرف والميل والعدول عن الأمر السوي. وهو ما كان من أمر الطائفتين اللتين همَّتا بالميل والانصراف عن القتال مع النبي ﷺ، مما يستدعي أن يدفع الإنسان هذا الوهم الشيطاني عن نفسه بالتوكل.</p><p>انظر: (حرف) في: "اللسان" 2/ 839، و"القاموس" (799).في (ج): (أن).في (ب): (الجذع). الجَزَع: نقيض الصبر. وهو أبلغ الحزن، الذي يصرف الإنسان عما هو بصدده، ويقطعه عنه. يقال: (جَزع جَزَعًا، وجُزُوعا). انظر: (جزع) في: "مفردات ألفاظ القرآن" 194، و"القاموس" (709).
  3,123,"<div class=ar lang=ar><p>قوله تعالى: <span class="qpc-hafs">﴿وَلَقَدْ نَصَرَكُمُ اللَّهُ بِبَدْرٍ﴾</span>. الآية {1}.</p><p>النَّصْرُ: حُسْنُ المَعُونة {2}. وبَدْرٌ: بِئْرٌ {3} لرجل [يقال] {4} له: بَدْر {5}، سُمِّيَت باسم صاحبها، في قول الشعبي {6}.</p><p>يدل على هذا قولُ حَسَّان {7}:</p><p>وبِبِئْرٍ إذْ يَرُدُّ وجوهَهُم ... جبريلُ تحت لِوائِنا ومُحَمَّدُّ {8}</p><p>وقال الواقِدِيُّ {9} -عن شيوخه- {10}: (بدر) {11}، هو اسمٌ لِمَوضِعٍ {12}.</p><p>وقيل: هو ماءٌ {13} لبني غِفَار {14}، بين مكة والمدينة {15}.</p><p>وقوله تعالى: <span class="qpc-hafs">﴿وَأَنتُم أَذِلَّةٌ﴾</span> في موضع الحالِ، وإنّما كانوا أذلةً؛ لقلة العَدَدِ، وضعف الحال {16}؛ لقلة {17} السلاح والمال عن مقاومة العدو {18}.</p><p>ومعنى الذلِّ: الضَّعْف عن المقاومة. ونقيضه: العِزُّ، وهو: القوة والغَلَبَة {19}.</p><p>و <span class="qpc-hafs">﴿أَذِلَّةٌ﴾</span> {20}: جمع ذليل. والأصل في (فَعِيل) إذا كان صفةً، أن يجمع على (فُعَلاَء، نحو: (ظَرِيف وظُرَفَاء)، و (شَرِيك وشُرَكَاء)، ولكن لفظ {21} (فُعَلاَء) [اجتُنِبَ] {22} في التضعيف؛ لأنه [لو قيل: (خُلَلاَء) {23}، و (قُلَلاَء)، في جمع: خَلِيل {24} وقَلِيل، لا جتمع حرفان من جنسٍ واحد، فَعُدِل به] {25} إلى (أفْعِلَة)؛ لأن (أفْعِلَة) مِن جمْع الأسماء في (فَعِيل) {26}، [نحو: جَرِيب] {27} وأَجْرِبَة) {28}، و (قَفِيز {29} وأَقْفِزَة) {30}.</p><p>قال أبو إسحاق {31} في هذه الآية {32}: أعلم الله -جَلَّ وعَزَّ- أنَّهم حين لَزِمُوا الطاعةَ، نصرهم اللهُ، وهم قليل، ويوم أُحُد نَزَلَ بهم ما نزل؛ بمخالفة أمرِ النبي ﷺ، فجعل ذلك عقوبة.</p><p>وقوله تعالى: <span class="qpc-hafs">﴿فَاتَّقُوا اللَّهَ لَعَلَّكُمْ تَشْكُرُونَ﴾</span> أي: اتقوا معاصي الله بالعمل بطاعته، أو اتَّقوا عقابَ اللهِ بالعمل بطاعته؛ لتقوموا بشكر نعمته. وهذا {33} معنى قول محمد بن إسحاق بن يَسَار في هذه الآية {34}: اتَّقُونِي فإنَّه شكر نعمتي {35}.</p></div>",footnotes:1:(الآية): ساقطة من (ب).انظر: (نصر) في: "المجمل" 870، و"مفردات ألفاظ القرآن" 808(بئر): ساقطة من (ب)، (ج).ما بين المعقوفين: غير واضح في (أ). وفي (ب): اسمه -بدلًا من: (يقال له) -. وأثبَتُّه من (ج). وهكذا جاءت العبارة في "تفسير الثعلبي" 3/ 108 - ب. ويبدو أن المؤلف نقلها عنه.في (ب): وبدر كان رجل اسمه بدر.بيَّن الشعبي أن هذا الرجل من جهينة. انظر قوله في: "مصنف ابن أبي شيبة" 7/ 353 رقم (36646)، و"الطبقات الكبرى" 2/ 27، و"المعارف" 152، "تفسير الطبري" 4/ 74 - 75، و"تفسير ابن أبي حاتم" 3/ 750، و"تفسير الثعلبي" 3/ 108 ب، و"معجم ما استعجم" 1/ 231، وأورده السيوطي في "الدر" 2/ 123 وزاد نسبة إخراجه إلى عبد بن حميد، وابن المنذر.</p><p>وذكر ابن قتيبة والسهيلي أن بدرًا -هذا- رجل من غفار، من بطن يقال لهم: بنو النار. وقيل: إن بدرا -هذا- هو ابن قريش بن الحارث بن يخلد بن النضر بن كنانة.</p><p>انظر: "المعارف":152، و"التعريف والإعلام"، للسهيلي 77 - 78.تقدمت ترجمته.البيت لكعب بن مالك الأنصاري، وليس لحسّان، ولم أقف عليه في ديوانه، ولم أجد من نسبه له. رضي الله عنهما.</p><p>وهو في: "ديوان كعب" 191، وورد منسوبًا له في: "العمدة" لابن رشيق 799، و"معجم ما استعجم" 232.</p><p>وفي المعجم: (.. نَرُدُّ ..) بدلًا من: (.. يَرُدُّ ..).</p><p>والبيت من قصيدة يرثي فيها حمزة بن عبد المطلب - رضي الله عنه - عم النبي ﷺ.</p><p>والضمير في (وجوههم) يعود على المشركين الذين قُتِلوا وغيِّبوا في قليب بدر بعد المعركة.لم أهتد إلى قوله هذا في كتابه "المغازي"، وقد ورد في: "الطبقات الكبرى" 2/ 27، و"تفسير الطبري" 4/ 75، و"تفسير الثعلبي" 3/ 108 ب، و"معجم ما استعجم" 1/ 231.</p><p>والواقدي، هو: محمد بن عمر بن واقد السَّهْمي، تقدمت ترجمته.عن شيوخه: ساقطة من (ب).بدر: زيادة من (ب).وفي هذا الخبر عنه، أن الواقدي ذكر قول شيوخه -هذا- ليحيى بن النعمان == الغفاري، فقال: (سمعت شيوخنا من بني غفار يقولون: هو ماؤنا ومنزلنا، وما مكه أحدٌ قطُّ يقال له بدر، وما هو من بلاد جهينة، إنما هو من بلاد غفار. قال الواقدي: وهو المعروف عندنا) "معجم ما استعجم" 1/ 231.(ماء): ساقط من (ب).في (ب): (لبني عفان).ورد عن الربيع، والضحاك، وقتادة أنه ماء بين مكة والمدينة. وليس فيه أن هذا الماء لبني غفار. انظر: "تفسير الطبري" 4/ 75، و"تفسير ابن أبي حاتم" 3/ 750، و"تفسير الثعلبي" 3/ 107 ب، و"معجم ما استعجم" 1/ 307، و"الدر المنثور" 2/ 123.وهذا قول ابن عباس، وقتادة، والحسن، والربيع، وابن إسحاق. انظر: "تفسير الطبري" 4/ 75، و"تفسير ابن أبي حاتم" 3/ 751.في (ب): ولقلة.بلغ عدد المسلمين في هذه المعركة: ثلاثمائة وبضعة عشر رجلًا، وهذا قول عامة السلف، كما يقول الطبري في تاريخه: 2/ 432. على اختلاف الأقوال في العدد بعد الثلاثمائة: فقيل: (305)، وقيل: (307)، وقيل: (313)، وقيل: (314)، وقيل: (318)، وقيل: (319). ومعهم: فرسان، وستون درعًا، وسبعون بعيرا. أما المشركون: فقيل: عددهم: تسعمائة وخمسون رجلًا، وقيل: ألف رجل. ومعهم: ستمائة درع، ومائتا فرس، وقيل: مائة، وقيل: ثمانون، وقيل: ستون. انظر: "صحيح البخاري": كتاب: المغازي. باب: عدة أصحاب بدر، و"صحيح مسلم": كتاب: الجهاد والسير، باب: الامداد بالملائكة في غزوة بدر، و"طبقات ابن سعد" 2/ 21 - 22، و"سيرة ابن هشام" 2/ 354، و"تاريخ الطبري" 2/ 423، 431 - 432، و"المنتظم" 3/ 98، 100، 102، و"البداية والنهاية": 3/ 259،==260، و"حدائق الأنوار" 2/ 498، 499، و"عيون الأثر" 1/ 381، 383، وانظر: تفسير المصنف لقوله تعالى: <span class="qpc-hafs">﴿يَرَوْنَهُمْ مِثْلَيْهِمْ رَأْيَ الْعَيْنِ﴾</span> من آية 13 سورة آل عمران.انظر: "مفردات ألفاظ القرآن" (330) (ذلل)، "اللسان" 5/ 2925 (عزز) 3/ 1513 (ذلل)، "القاموس" 517 (عزز).من قوله: (وأذلة ..) إلى (.. وأقفزة): نقله بتصرف يسير من "معاني القرآن"، للزجاج 1/ 466، وانظر: "معاني القرآن" للنحاس 1/ 405.(لفظ): في (أ) غير واضحة وفي (ب): (لفظت)، وليست في "معاني القرآن". والمثبت من (ج).ما بين المعقوفين غير مقروء في (أ). وفي (ب): (خففت). وفي "معاني القرآن" (اجتنب). والمثبت من (ج).في "معاني القرآن": (جللاء).في "معاني القرآن": (جليل).ما بين المعقوفين زيادة لازمة من (ج) ومن "معاني القرآن".في (ب): (فعل).ما بين المعقوفين مطموس في (أ). وفي (ب): (نحو جريت). والمثبت من (ج) و"معاني القرآن".في (ب): (أجريت).في (ب): (وقفز).الجريب: من الأرض والطعام، مقدار معلوم الذراع والمساحة. وهو عشرة == أقفزة وقيل: قدر أربعة أقفزة. وقيل: يختلف باختلاف البلدان، كالاختلاف في الرطل والمد والذراع وغير ذلك. وقيل: ثلاثمائة وستون ذراعًا.</p><p>ويطلق -كذلك- على المزرعة، والوادي. وجمعه: أجربة وجُربان.</p><p>والقفيز: مكيال، وهو ثمانية مكاكيك عند أهل العراق - والمكّوك: مكيال يسع صاعًا ونصف، وقيل: غير ذلك.</p><p>وقيل: القفيز: مقدار مساحة من الأرض. وقيل: مكيال يتواضع الناس عليه.</p><p>ويجمع على أقفزة، وقُفْزان -بكسر القاف وضمها-. انظر: "التاج": 1/ 361 (جرب)، 8/ 129 (قفز)، و"القاموس": ص 954 (مكك).في "معاني القرآن"، له: 1/ 466. نقله عنه باختصار قليل وتصرف.(في هذه الآية): ساقط من (ج).في (ج): (هذا) بدون واو.قوله في: "سيرة ابن هشام" 3/ 59، و"تفسير الطبري" 4/ 74، و"تفسير ابن أبي حاتم" 3/ 751.في (ب): (لنعمتي).
  3,124,"<div class=ar lang=ar><p>قوله تعالى: <span class="qpc-hafs">﴿إِذْ تَقُولُ لِلْمُؤْمِنِينَ﴾</span> الآية. قال الشَّعْبيُّ {1}: حُدِّثَ المسلمون أن كُرْز بن جابر المُحَارِبي {2} يريد أن يُمِدَّ {3} المشركين، فَشَقَّ ذلك عليهم، فقيل لهم: <span class="qpc-hafs">﴿أَلَنْ يَكْفِيَكُمْ﴾</span>.</p><p>ومعنى الكِفَايَةِ، هو: سَدُّ الخَلَّةِ {4}، والقيام بالأمر، يقال: (كفاهُ أمْرَ كذا): إذا قامَ {5} بِهِ دونه، وسَدَّ خَلَّتَهُ {6}.</p><p>ومعنى الإمْدَاد: إعطاء الشيء حالًا بعد حال {7}.</p><p>قال المُفَضَّلُ {8}: ما كان على جهة القوة والإعانة، قيل فيه: (أَمَدَّهُ، يُمِدُّهُ) {9}، وما كان على جهة الزيادة، قيل فيه: (مَدَّةُ، يَمُدُّهُ، مَدًّا) {10}، ومنه قوله: <span class="qpc-hafs">﴿وَالْبَحْرُ يَمُدُّهُ﴾</span> {11}.</p></div>",footnotes:1:قوله في: "مصنف ابن أبي شيبة" رقم (36659) كتاب: المغازي. غزوة بدر الكبرى، و"تفسير الطبري" 4/ 76، و"تفسير ابن أبي حاتم" 3/ 752، و"تفسير الثعلبي" 3/ 110 ب، و"تفسير ابن كثير" 1/ 432، و"الدر المنثور" 2/ 123، وزاد نسبته إلى ابن المنذر.هو كرز بن جابر بن حُسيل بن لاحب بن حبيب بن عمرو بن شيبان بن محارب بن فِهْر القُرَشي الفهري. كان من رؤساء المشركين قبل أن يسلم، وهو الذي أغار على سَرْح المدينة مرَّةً، وفات النبي ﷺ، ولم يدركه، وهي المسماة: (غزوة بدر الأولى)، ثم أسلم وحسن إسلامه، ولاه رسول الله ﷺ الجيش الذي بعثهم في أثر العرنيين الذين قتلوا راعيه، واستشهد يوم في فتح مكة سنة (8 هـ). انظر: "أسد الغابة" 4/ 468، و"الإصابة" 3/ 290.في (ب): (أن هذا). بدلًا من (أن يمد).الخَلَّةُ -هنا-: الحاجة، والفقر. انظر: "القاموس" (994) (خلل).في (أ)، (ب): (أقام). والمثبت من (ج).انظر: "النكت والعيون" 1/ 421، و"اللسان" 15/ 225 (كفي)، و"بصائر ذوي التمييز" 4/ 368.انظر: "تهذيب اللغة" 4/ 3361 (مدد)، و"النكت والعيون" 1/ 421.قوله في: "تفسير الثعلبي" 3/ 111 ب.في (ب): (المد مده). وفي "تفسير الثعلبي": أمدَّه يُمِدُّه إمدادًا.في "تفسير الثعلبي": (مدَّه يمده مدادًا).</p><p>ذكر الرَّاغبُ أن أكثر ما جاء (الإمداد) في المحبوب، و (المد) في المكروه. فمن (الإمداد) قوله تعالى: <span class="qpc-hafs">﴿وَأَمْدَدْنَاهُمْ بِفَاكِهَةٍ وَلَحْمٍ مِمَّا يَشْتَهُونَ﴾</span> [الطور: 22]، و <span class="qpc-hafs">﴿وَيُمْدِدْكُمْ بِأَمْوَالٍ وَبَنِينَ﴾</span> [نوح: 12].</p><p>ومن (المد) قوله تعالى: <span class="qpc-hafs">﴿وَيَمُدُّهُمْ فِي طُغْيَانِهِمْ يَعْمَهُونَ﴾</span> [البقرة: 15]، وقوله: <span class="qpc-hafs">﴿وَنَمُدُّ لَهُ مِنَ الْعَذَابِ مَدًّ﴾</span> [مريم: 79].</p><p>وقد نقل الطبري عن يونس الجرْمي ذلك، وبيَّن أن ما كان منها متعلقًا بالشر وبمعنى أنك تركته، فهو: (مددت)، وما كان في الخير، وبمعنى أنك أعطيته، فهو: (أمددت). ونقل عن بعض نحوي الكوفة -ولم يسم أحدا منهم-: أنَّ كل زيادة أحدثت في الشيء من نفسه، فهي: (مَدَدت)؛ كقولنا: (مدَّ النهر، ومدَّه نهرٌ آخر غيرُه) حيث يتصل به، فيصير منه.</p><p>وكل زيادة أحدثت في الشيء من غيره، فهي: (أمدَدْت)؛ كقولنا: (أمددت الجيش بمدد).</p><p>انظر: "تفسيرالطبري" 1/ 135، و"مفردات ألفاظ القرآن" 763 (مدد)، و"تفسير الثعلبي" 3/ 111 ب، و"بصائر ذوي التمييز" 4/ 489.سورة لقمان: 27. وتمامها: <span class="qpc-hafs">﴿وَلَوْ أَنَّمَا فِي الْأَرْضِ مِنْ شَجَرَةٍ أَقْلَامٌ وَالْبَحْرُ يَمُدُّهُ مِنْ بَعْدِهِ سَبْعَةُ أَبْحُرٍ مَا نَفِدَتْ كَلِمَاتُ اللَّهِ إِنَّ اللَّهَ عَزِيزٌ حَكِيمٌ﴾</span>.
  3,125,"<div class=ar lang=ar><p>قوله تعالى: <span class="qpc-hafs">﴿بَلَى إِنْ تَصْبِرُوا وَتَتَّقُوا﴾</span> الآية. <span class="qpc-hafs">﴿بَلَى﴾</span>: تصديق لوعد الله. ومضى الكلامُ فيه {1} إذا وقع في ابتداء الآية.</p><p>وقوله تعالى: <span class="qpc-hafs">﴿إِنْ تَصْبِرُوا﴾</span> {2}. أي: على لقاء العدو.</p><p><span class="qpc-hafs">﴿وَتَتَّقُوا﴾</span> معصية الله، ومخالفة النبي ﷺ {3}.</p><p><span class="qpc-hafs">﴿وَيَأْتُوكُمْ مِنْ فَوْرِهِمْ هَذَا﴾</span> قال ابنُ عبَّاس -في رواية العَوْفي- {4}: مِن وجههم هذا. وهو قول: الحسن {5}، وقتادة {5}، والربيع {7}، والسّدِّي {5}، وابن زيد {9}.</p><p>وقال {10} في رواية باذان: من غَضَبِهم هذا {11}. وهو قول: مجاهد {12}، والضَّحَّاك {13}.</p><p>وأصل الفَوْرِ: غَلَيانُ القِدْرِ. يقال: (فارت القِدْرُ، تَفُورُ فَوْرًا)، وهو غليانها عند شدة الحَمْي {14}. ومنه: فَوْرُ الغَضَبِ؛ لأنه كَفَوْرِ القِدْرِ بالحَمْي. ومنه، يقال: (جاء على الفَوْر)؛ أي: على ابتداء الحَمْي، قبل أن تَبْرُدَ نَفْسُه عنه {15}.</p><p>وقوله تعالى: <span class="qpc-hafs">﴿مُسَوِّمِينَ﴾</span> مَنْ فَتَحَ الواو {16}، معناه: مُعْلَمِين، قد سُوِّمُوا، فهم مُسَوَّمِين.</p><p>والسُّوْمَة: العَلاَمَةُ يُفْرَقُ بها الشيءُ مِن غَيْرِه. ومضى شيءٌ من هذا في قوله: <span class="qpc-hafs">﴿وَالْخَيْلِ الْمُسَوَّمَةِ﴾</span> {17}.</p><p>وهذه {18} العَلامَةُ يُعْلِمُها الفارسُ يوم اللقاء؛ ليُعْرَفَ بها.</p><p>قال عنترة {19}:</p><p>فَتَعَرَّفوني إنَّنِي أنا ذِلكُم ... شاكٍ سِلاحي في الحوادِثِ مُعْلَمُ {20} ومَن كَسَرَ الواو {21}، نَسَبَ الفِعْلَ إليهم؛ لِمَا جاء في الخبر: أن النبي ﷺ قال يوم بدر: "سَوَمُوا، فإن الملائكة قد سَوَّمَتْ" {22}.</p><p>قال ابن عباس: كانت الملائكة قد سَوَّمت يوم بدر بالصُّوف الأبيض في نواصي الخيل، وأذنابها {23}.</p><p>وقال الربيعُ {24}، وهشامُ بن عُرْوة {25}: كانت عليهم عمائم صُفْرٌ، وروي عن علي {26} وابن عباس {27}: كانت عليهم عمائمُ بِيضٌ، قد أرسلوها بين أكتافهم.</p><p>قال المفسرون: فصبر المسلمون يوم بَدْرٍ، واتَّقوا اللهَ، فأَمَدَّهم {28} الله بخمسة آلافٍ من ملائكته {29} على ما [وَعَدَهم] {30}. قال الحسن {31}: فهؤلاء الخمسة آلاف رِدْءٌ {32} للمؤمنين إلى يوم القيامة.</p><p>وقال ابن عباس {33}، ومجاهد {34}: لم تقاتل الملائكة إلا يوم بدر، وفيما سوى ذلك، يشهدون القتال ولا يُقاتِلُون.</p></div>",footnotes:1:في (ج): (في).في (ج): <span class="qpc-hafs">﴿إِنْ تَصْبِرُوا وَتَتَّقُوا﴾</span>.انظر: "بحر العلوم": 1/ 296، و"تفسير ابن أبي حاتم": 3/ 753 ولفظه عندهما: (من سفرهم هذا)، و"تفسير الثعلبي" 3/ 112 أ، و"تفسير البغوي" 2/ 100، و"زاد المسير" 1/ 451.قوله في: "تفسير الطبري" 4/ 80، و"تفسير ابن أبي حاتم" 3/ 753، و"تفسير الثعلبي" 3/ 112 أ، و"تفسير البغوي" 2/ 100، و"زاد المسير" 1/ 451.قوله في المصادر السابقة.قوله في المصادر السابقة.قوله في: "الطبري" 4/ 80، و"ابن أبي حاتم" 3/ 753، و"الثعلبي" 3/ 112 ب.قوله في المصادر السابقة.قوله في: "تفسير الطبري" 4/ 80، و"تفسير الثعلبي" 3/ 112ب.أي: ابن عباس.ورد هذا القول في "تفسير الطبري" 4/ 80، و"تفسير ابن أبي حاتم" 3/ 753، و"تفسير الثعلبي" 3/ 112 أ، و"النكت والعيون" 1/ 421، ولكن هذه المصادر نسبت هذا القول لأبي صالح باذان، وليس في الأثر أنه رفعه لابن عباس.قوله، في "تفسيره" 135، و"تفسير الطبري" 4/ 81، و"ابن أبي حاتم" 3/ 753، و"الثعلبي" 3/ 112 أ، و"البغوي" 2/ 100، و"زاد المسير" 1/ 451.قوله في المصادر السابقة، عدا الأول.انظر: (فور) في: "مقاييس اللغة" 4/ 458، و"مفردات ألفاظ القرآن" 647.انظر: المصادر السابقة، و"تفسير الطبري" 4/ 81، و"تفسير الثعلبي" 3/ 112 أ.هي قراءة: نافع، وابن عامر، وحمزة، والكسائي: <span class="qpc-hafs">﴿مُسَوِّمِينَ﴾</span>. انظر: "السبعة": 216، و"حجة القراءات": 173.[سورة آل عمران: 14]. وانظر: "تهذيب اللغة": 2/ 1601 (سوم).من قوله: (هذه) إلى نهاية بيت الشعر الآتي: نقله بنصه عن "الحجة" للفارسي 3/ 76. غير أنه ليس في "الحجة": (قال عنترة) وإنما: (قال) فقط دون نسبة لقائل.تقدمت ترجمته.البيت: ليس لعنترة، وإنما هو لطريف بن تميم العنبري. وقد ورد منسوبًا له في: "كتاب سيبويه" 3/ 466، 4/ 378، و"الأصمعيات" 128، و"البيان والتبيين" 3/ 93، و"الاختيارين" 189، و"العقد الفريد" 3/ 208، و"الاقتضاب في شرح أدب الكتاب" 3/ 408، و"شرح أدب الكاتب"، للجواليقي 284، و"الكامل" لابن الأثير 1/ 367، و"معاهد التنصيص" 1/ 204، و"شرح شواهد شرح الشافية" (مطبوع مع شرح الشافية) 4/ 368. == كما ورد غير منسوب في: "المقتضب" 1/ 116، و"المنصف" 2/ 53، 3/ 66، و"الحجة" للفارسي 3/ 77.</p><p>وقد روي البيت في بعض المصادر بـ (فتوسَّموني) بدلا من: (فتعرفوني)، و (ذاكم) بدلًا من (ذلكم) وفي بعضها: (شاكي السلاح)، وفي "الكامل"، لابن الأثير: (لا تنكروني إنني داء لكم ..). وقبل هذا البيت:</p><p>أوَ كلما وردت عكاظ قبيلةٌ ... بعثوا إليَّ عريفهم يَتَوَسَّمُ</p><p>لقد كان من عادة الفرسان في الجاهلية -نظرا لما عليهم من ثارات كثيرة- أنهم إذا ما وردوا عكاظ في الموسم، يتقنعون لئلا يُعرَفوا، فيُقصدوا في الحروب؛ لأخذِ الثأرِ منهم، إلا الشاعر، فإنه لشجاعته يلقي القناع عن وجهه على خلاف العادة، فكان بعضُ من لهم ثأر عنده يمر به ويتفرس في وجهه، فخاطبهم الشاعرُ بقوله: تعرفوا عليَّ جيدًا، وتفرسوا فيَّ، فإنني لا أخشاكم، ولا أهابكم.</p><p>وقوله: (شاك سلاحي)؛ أي: لسلاحي شوكة وله حد. وأصله: (شائك)، فقُلِب إلى: شاكٍ وقيل: أصله: (شاككٌ) من: الشكَّة، وهي: السلاح. وقيل غير ذلك. وينطق (شاكٍ) -في البيت- بالضم، أو بالكسر، مع التنوين. وقوله: (مُعْلَم)، أي: يُعلِم نفسه بعلامة في الحرب؛ ليُعرَف بها. انظر: "الاقتضاب": 3/ 409.هي قراءة: ابن كثير، وأبي عمرو، وعاصم، <span class="qpc-hafs">﴿مُسَوِّمِينَ﴾</span>. انظر: "السبعة" 216، و"حجة القراءات" 173.الحديث أخرجه: ابن أبي شيبة في: "المصنف" 7/ 355 رقم (36657) وأبو عمرو الدوري في "جزء فيه قراءات النبي ﷺ" 80، وأخرجه الطبري في "تفسيره" 4/ 82.</p><p>وأوردته الكتب التالية، غير مسند: "تفسير الثعلبي" 3/ 112 ب، و"تفسير البغوي" 2/ 99، 100، و"زاد المسير" 1/ 452، و"الدر المنثور" 2/ 125. والحديث مرسل؛ لأنه من رواية عمير بن إسحاق، قال: (.. قال رسول الله ﷺ) وذكره. == قال الشيخ أحمد شاكر: (وعمير بن إسحاق، أبو محمد مولى بني هاشم، روى عن المقداد بن الأسود، وعمرو بن العاص، وأبي هريرة، كان قليل الحديث. قال أبو حاتم: لا نعلم روى عنه غير ابن عون. قال ابن معين: ثقة. وقال -ايضًا-: لا يساوي حديثه شيئًا، ولكن يكتب حديثه) ثم تابع الشيخ شاكر قائلًا: (فهذا الحديث مرسل -كما ترى-، وعن رجل يكتب حديثه ولا يحتج به). هامش "تفسير الطبري" 7/ 186. (ط. شاكر). وانظر: "ميزان الاعتدال" 4/ 216.</p><p>وأخرج الواقدي في "المغازي": 1/ 75 - 76 عن محمود بن لبيد، قال: قال رسول الله ﷺ: "إن الملائكة قد سَوَّمت فسَوِّموا، فأعْلَموا بالصوت في مغافرهم وقلانسهم".</p><p>وأخرجه ابن سعد في "الطبقات" 2/ 16 ولم يسنده، وأورده المتقي الهندي في: "كنز العمال": 10/ 403 رقم (29964) وزاد نسبة إخراجه لابن النجار.</p><p>ومحمود بن لييد بن عقبة بن رافع الأوسي الأشهلي، أبو نعيم المدني. قال عنه ابن حجر: (صحابي صغير، وجل روايته عن الصحابة، مات سنة 96، وقيل: 97، وله تسع وتسعون سنة). "تقريب التهذيب": 522 (6517).في (ب): (وأذناها). وفي (ج): (وأذانها).</p><p>ولم أقف على قول ابن عباس بهذا اللفظ، وإنما الذي ورد عنه، قوله: (فإنهم [أي: الملائكة] أتوا محمدًا النبي ﷺ مسومين بالصوف، فسوَّم محمد وأصحابه أنفسهم وخيلهم على سيماهم بالصوف).</p><p>أخرجه الطبري 4/ 83، وابن أبي حاتم 3/ 754، وانظر: "النكت والعيون" 1/ 422.لم أقف على مصدر قوله هذا. والذي في "تفسير الطبري" 4/ 83 قوله: (كانوا يومئذ على خيل بُلْق) وكذا ورد في "تفسير الثعلبي" 3/ 112 ب.قوله في: "مصنف ابن أبي شيبة" 7/ 361 رقم (36692)، و"تفسير الطبري" 4/ 83، و"ابن أبي حاتم" 3/ 755، و"المستدرك" 3/ 361، و"تفسير الثعلبي" == 3/ 112ب، و"النكت والعيون" 1/ 422، و"تفسير البغوي" 2/ 101، و"زاد المسير" 1/ 452، و"تفسير ابن كثير" 1/ 432، وقال: (رواه ابن مردويه من طريق هشام بن عروة، عن أبيه، عن عبد الله بن الزبير).</p><p>وهشام، هو: أبو المنذر، ابن عُرْوة بن الزبير بن العوام الأسدي. إمام ثقة حافظ حجة، مشهور بالورع والصلاح. توفي بغداد سنة (145هـ) أو (146هـ).</p><p>انظر: "الجرح والتعديل" 9/ 63، و"الميزان" 5/ 426، 427، و"التهذيب" 4/ 275، و"شذرات الذهب" 1/ 218.قوله في "سيرة ابن هشام" 2/ 274 ولفظه عنده: (العمائم تيجان العرب، وكانت سيما الملائكة يوم بدر عمائم بيضاء، أرخوها على ظهورهم، إلا جبريل فإنه كانت عليه عمامة صفراء).</p><p>وأخرج ابن أبي حاتم عنه قوله: (كان سيما الملائكة يوم بدر الصوف الأبيض)، وفي رواية أخرى عنده: (كان سيما الملائكة أهل بدر الصوف الأبيض، وكان سيما الملائكة -أيضًا- في نواصي الخيل). "تفسيره" 2/ 525.</p><p>وورد في "مصنف ابن أبي شيبة" بنفس السند الذي عند ابن أبي حاتم، ولكن لفظه: (كان سيما أصحاب رسول الله ﷺ ..) وذكره</p><p>وأورده الثعلبي في "تفسيره" 3/ 112 ب، بنفس لفظ المؤلف، حيث قال: (وقال علي ابن أبي طالب وابن عباس ..) وذكره، وكذا أورده البغوي في "تفسيره": 2/ 101، وأورده المتقي الهندي في "كنز العمال" 2/ 378 رقم (4299) بنفس لفظ ابن أبي حاتم، وزاد نسبته لابن المنذر.قوله في: "سيرة ابن هشام" 2/ 274، و"تفسير الثعلبي" 3/ 112 ب، و"تفسير البغوي" 2/ 101، و"تفسير ابن كثير" 1/ 432، وورد في "الدر المنثور" 2/ 125، وزاد نسبة إخراجه للطبراني.في (ب): (فأيديهم).في (ج): الملائكة.ما بين المعقوفين في (أ)، (ب): (وهم). والمثبت من (ج). وممن قال بهذا: ابن عباس، وقتادة، والربيع. انظر: "تفسير الطبري" 4/ 77.لم أقف على مصدر قوله.الرِّدْءُ -هنا-: العَوْنُ. انظر: "القاموس المحيط" 41 (ردأ).قوله في "المغازي" 1/ 79، و"سيرة ابن هشام" 2/ 274، "تفسير الطبري" 4/ 77، "النكت والعيون" 1/ 422، و"ابن كثير" 1/ 432، ونسب إخراجه إلى ابن مردويه.قوله في "تفسيره" 135، و"تفسير الطبري" 4/ 78.
  3,126,"<div class=ar lang=ar><p>قوله تعالى: <span class="qpc-hafs">﴿وَمَا جَعَلَهُ اللَّهُ إِلَّا بُشْرَى﴾</span> الكناية {1} تعود على المَصْدَرِ؛ كأنه قال: وما جعل الله المَدَدَ والإمْدادَ إلّا بُشْرى. فَدَلَّ <span class="qpc-hafs">﴿يُمْدِدْكُمْ﴾</span> على الإمداد، فَكَنَى عنه {2}، كما قال: <span class="qpc-hafs">﴿وَلَا تَأْكُلُوا مِمَّا لَمْ يُذْكَرِ اسْمُ اللَّهِ عَلَيْهِ وَإِنَّهُ لَفِسْقٌ﴾</span> [الأنعام: 121]؛ معناه {3}: وإن أكلَهُ لَفِسْقٌ. فَدَلَّ <span class="qpc-hafs">﴿تَأْكُلُوا﴾</span> على الأكل، فكنى عنه، والعرب تقول: (مَنْ صَدَقَ؛ كان خيرًا له، ومَن كَذَبَ؛ كان شرًا له). فدل الفعلان على المَصْدَرَيْنِ {4}. هذا كلام ابن الأنباري {5}. وكذلك قال الزجاج {6}؛ أي: وما جَعَلَ اللهُ ذِكْرَ المَدَدِ إلّا بُشْرَى {7}.</p><p>والبُشْرى: اسم من (الإبشار)، و (التبشير) {8}.</p><p>ومضى الكلام في معنى التبشير {9}، وسيأتي الكلام في (بُشْرى) في سورة يوسف إن شاء الله {10}.</p><p>وقوله تعالى: <span class="qpc-hafs">﴿وَلِتَطْمَئِنَّ قُلُوبُكُمْ﴾</span> فلا تجزع من كثرة العَدُوِّ {11}، وقِلَّةِ عَدَدِكم. وإنما قال: <span class="qpc-hafs">﴿وَلِتَطْمَئِنَّ﴾</span>، ولم يقل: واطْمِئْنانًا، كما قال <span class="qpc-hafs">﴿بُشْرَى﴾</span>، لأن ذِكْر المَدَدِ سببٌ لاطمئنان القلوب، ولم يكن نفس الاطمئنان، وكان ذكر المَدَدِ نفس البُشْرَى.</p><p>وقال صاحب النظم {12}: هذا على تأويل: وما جعله الله إلّا لِيُبَشِّركم {13}، ولِتَطمئنَّ به قلوبُكم.</p><p>ومن أجاز إقحام الواو -وهو مذهب الكوفيِّين {14} - جعلها مقحمةً في <span class="qpc-hafs">﴿وَلِتَطْمَئِنَّ﴾</span> فيكون التقدير: وما جعله الله إلا بُشْرَى لكم؛ لِتَطمئنَّ قلوبكم به.</p><p>قال: وزعم بعضهم أنَّ الواو لإضمارٍ بعده، على تأويل: (ولتطمئن قلوبكم به، جَعَل ذلك). واحتج بقوله: <span class="qpc-hafs">﴿وَزَيَّنَّا السَّمَاءَ الدُّنْيَا بِمَصَابِيحَ وَحِفْظًا﴾</span> [فصلت: 12]، على تأويل: (وحفظًا لها، جَعَل ذلك). ومثله: قوله: <span class="qpc-hafs">﴿وَلَوْ تَوَاعَدْتُمْ لَاخْتَلَفْتُمْ فِي الْمِيعَادِ وَلَكِنْ لِيَقْضِيَ اللَّهُ أَمْرًا كَانَ مَفْعُولًا﴾</span> [الأنفال: 42]، على {15} تأويل: ليقضي اللهُ أمرًا كان مفعولًا، فَعَلَ ذلك.</p><p>ونحو هذا قوله: <span class="qpc-hafs">﴿وَكَذَلِكَ نُرِي إِبْرَاهِيمَ مَلَكُوتَ السَّمَاوَاتِ وَالْأَرْضِ وَلِيَكُونَ مِنَ الْمُوقِنِينَ (75)﴾</span> {16} [الأنعام: 75].</p><p>وقوله تعالى: <span class="qpc-hafs">﴿وَمَا النَّصْرُ إِلَّا مِنْ عِنْدِ اللَّهِ﴾</span> قال المفسرون: أرادَ الله تعالى: أنْ لا يَرْكَن المؤمنون إلى الملائكة، وأَعْلَمَ أنهم وإنْ {17} حضروا وقاتلوا، فما النصر إلا من عند الله؛ ليستعينوا به [و] {18} يَتَوَكَّلوا عليه. والإمداد بالملائكة؛ بُشرَى لهم [وطُمَأنِينة] {19} لقلوبهم {20}؛ لما في البَشَرِ من الضَّعْف، فأما حقيقة النصرِ والاستعلاءِ في العرب، فهو من عند الله العزيز الحكيم {21}.</p></div>",footnotes:1:سبق بيان أن الكناية يُراد بها: الضمير.وقيل: الضمير يعود على النصر، وقيل: يعود على التسويم، وقيل: على التنزيل، وقيل: على العدد، وقيل: على الوعد.</p><p>انظر: "غرائب التفسير" للكرماني 1/ 268، و"الدر المصون" 3/ 389 - 390.(معناه وان أكله لفسق): ساقط من (ج).وهما الصدق والكذب.لم أقف على مصدر قوله.في "معاني القرآن" للزجاج 1/ 467.ومن قال بهذا: أبو الليث في "بحر العلوم" 1/ 296، والنحاس في "معاني القرآن" 1/ 471، وابن الجوزي في "الزاد" 1/ 454.انظر: "القاموس المحيط" 744 (بشر).انظر: "تفسير البسيط" عند تفسير <span class="qpc-hafs">﴿إِنَ اَللَّهَ يُبَشِرُكِ﴾</span> الآية: 39.وردت لفظة (بشرى) في سورة يوسف: 19 <span class="qpc-hafs">﴿قَالَ يَابُشرَى هَذَا غُلاَمٌ﴾</span>.في (ج): (العدد).قد أورد قوله هذا بنصه السمينُ الحلبي في "الدر المصون" 3/ 389.في (ب): (إلا بشرى لكم).سبق بيان مذهب الكوفيين والبصريين في موضوع زيادة الواو العاطفة. انظر: التعليق على تفسير قوله تعالى: <span class="qpc-hafs">﴿وَلِأُحِلَّ لَكُمْ﴾</span> [الآية 50 من سورة آل عمران].من قوله: (على ..) إلى (.. مفعولًا): ساقط من (ج).والتأويل هنا، على هذا الرأي: أي: وليكون من الموقنين أريناه انظر: "الدر المصون" 5/ 7.في (ج): (إن) بدون واو.ما بين المعقوفين زيادة من (ج).ما بين المعقوفين في (أ)، (ب): (بطمأنينة). والمثبت من (ج).في (ب): (قلوبهم) بدون اللام.انظر هذا المعنى في: "تفسير الطبري" 4/ 84
  3,127,"<div class=ar lang=ar><p>قوله تعالى: <span class="qpc-hafs">﴿لِيَقْطَعَ طَرَفًا مِنَ الَّذِينَ كَفَرُوا﴾</span> اللّام تعود إلى قوله: <span class="qpc-hafs">﴿وَلَقَد نَصَرَكُمُ اللَّهُ بِبَدرٍ﴾</span> {1}.</p><p><span class="qpc-hafs">﴿لِيَقْطَعَ طَرَفًا﴾</span>؛ أي: لِيُهلك طائفةً، ولِيَقْتُلَ قِطْعَةً. قال السُّدِّي {2}: معناه: لِيَهدِمَ رُكْنًا مِن أركان الشرك، بالقتل والأَسْرِ، فقُتِلَ من قادتهم وسادتهم يومَ بَدْرٍ، سبعون، وأُسِرَ سبعون {3}.</p><p>وقال بعضهم {4}: المعنى: وما النصر إلا من عند الله، ليقطع طرفًا {5}. وقيل {6}: إنَّ هذا راجعٌ إلى [معنى قوله] {7}: <span class="qpc-hafs">﴿وَلِتَطْمَئِنَّ قُلُوبُكُمْ بِهِ﴾</span>، و <span class="qpc-hafs">﴿لِيَقْطَعَ طَرَفًا﴾</span>، ولكنه ذُكِر بغير حرفِ العطف؛ لأنَّ الكلامَ إذا كان بعضُه ملتبسًا ببعضٍ، جاز حذفُ العاطف؛ كقوله: <span class="qpc-hafs">﴿ثَلَاثَةٌ رَابِعُهُمْ كَلْبُهُمْ﴾</span> [الكهف: 22].</p><p>وإنما قال: <span class="qpc-hafs">﴿طَرَفًا﴾</span> ولم يقل: (وَسَطًا)؛ لأنه لا يُوصَلُ إلى الوَسَطِ الا بعد قطع الطَّرَفِ، وهذا القَطْعُ إنما هو بأيدي المؤمنين، وإنما يقطعون الطَّرَفَ الذي يليهم مَنَ الكافرين، وهذا يوافق قوله: <span class="qpc-hafs">﴿قَاتِلُوا الَّذِينَ يَلُونَكُمْ مِنَ الْكُفَّارِ﴾</span> [التوبة: 123]، وعلى هذا -أيضًا- قولُه: <span class="qpc-hafs">﴿أَوَلَمْ يَرَوْا أَنَّا نَأْتِي الْأَرْضَ نَنْقُصُهَا مِنْ أَطْرَافِهَا﴾</span> [الرعد: 41].</p><p>وقوله تعالى: <span class="qpc-hafs">﴿أَوْ يَكْبِتَهُمْ﴾</span> الكَبْتُ -في اللغة-: صَرْعُ الشيء على وجهه؛ يُقال: (كَبَتَهُ، فانْكَبَتَ) {8}. هذا تفسيره، ثم قد {9} يُذكرُ {10} المرادُ به: الإخزَاءُ، والإهلاكُ، واللَّعْنُ، والهَزِيمَةُ، والغَيْظُ، والإذلالُ. وكلُّ هذا ذكره المفسرون في تفسير (الكَبْتِ) {11}.</p><p>وقوله تعالى: <span class="qpc-hafs">﴿خَائِبِينَ﴾</span> الخَيْبَةُ: حِرْمانُ البُغْيَة {12}، ولا تكون إلّا بعد الأَمَلِ. واليَأْسُ قد يكون قبل الأَمَلِ، وقد يكون بعده. فنقيض اليَأْسِ: الرَّجَاءُ، ونقيض الخَيْبَةِ: الظَّفَرُ.</p><p>وقد أنجز الله وَعْدَهُ يوم بَدْرٍ؛ بِقَطْع {13} طَرَفٍ مِن الكفار بالقتال والأسر، وَرَدَّ الباقين منهزمين، خائبين مِمّا أَمَّلُوا مِن الظَّفَرِ، فتحقق نصرُه، وعَلَت كلمَتُهُ.</p></div>",footnotes:1:انظر: "تفسير الطبري" 4/ 85، و"الثعلبي" 3/ 113 أ، و"البغوي" 2/ 101. وعزا السمين الحلبي هذا القول -كذلك- للحوفي. انظر: "الدر المصون" 3/ 390، واستبعده السمين؛ لطول الفصل بين اللام ومتعلقه.قوله هذا -بنصه- في: "تفسير الثعلبي" 3/ 113 أ، و"تفسير البغوي" 2/ 101.الذي وقفت عليه من قول السدي: أن المَعني بالآية: مَن قُتِل من الكفار يوم أحد، وهم ثمانية عشر رجلًا. وقد ورد قوله هذا في: "تفسير الطبري" 4/ 85، و"النكت والعيون" 1/ 422، و"زاد المسير" 1/ 454.</p><p>وممن قال بأن المراد بها مَن قتل يوم بدر: قتادة، والربيع، والحسن، وابن إسحاق، والجمهور. انظر: "تفسير الطبري" 4/ 85، و"زاد المسير" 1/ 454.</p><p>أما ما ذكره المؤلف من عدد قتلى وأسرى المشركين في معركة بدر، فانظر: "سيرة ابن هشام" 2/ 362، و"تاريخ الطبري" 2/ 474.لم أقف على القائل.قال السمين: (وفيه نظر من حيث إنه قد فُصل بين المصدر ومُتَعَلَّقه بأجنبي، وهو: الخبر). "الدر المصون" 3/ 390.ممن قال بهذا: أبو الليث في "بحر العلوم" 1/ 297.ما بين المعقوفين زيادة من (ج).</p><p>وعلى هذا الوجه يكون قوله تعالى: <span class="qpc-hafs">﴿وَمَا النَّصْرُ إِلَّا مِنْ عِنْدِ اللَّهِ﴾</span> جملة معترضة بين المعطوف والمعطوف عليه. == وهناك أقوال أخرى في عود الللام في <span class="qpc-hafs">﴿لِيَقْطَعَ﴾</span>. انظر: "تفسير ابن عطية" 3/ 313، و"الدر المصون" 3/ 390.انظر: كتاب "العين" 5/ 342 (كبت)، و"مجاز القرآن" 1/ 103، و"تهذيب اللغة" 10/ 152 (كبت).(قد): ساقطة من (ب).(يُذْكَرُ): وردت في (أ)، (ج): (يذكرو). وفي (ب): (يذكروا). وما أثبتُّهُ هو ما استصوبته، لأن في (أ)، (ج) قد تكون الضمة التي على الواو كتبها الناسخ بحجم أكبر من حجمها الطبيعي، وتزحلقت قليلًا إلى ما بعد الرَّاء. أما الذي في نسخة (ب) فلا وجه له، لأن الفعل كُتِب فيها في حالة الجمع، وحذفت منه النون التي هي علامة رفعه، والصواب إثباتها، لأنه من الأفعال الخمسة.انظر: "تفسير مقاتل" 1/ 299، و"سيرة ابن هشام" 3/ 61، و"غريب القرآن" لابن اليزيدي 44، و"تفسير غريب القرآن" لابن قتيبة 110، و"تفسير الطبري" 4/ 86، == و"معاني القرآن" للزجاج 1/ 467، و"ابن أبي حاتم" 3/ 756، و"نزهة القلوب" للسجستاني 485، و"بحر العلوم" 1/ 297، و"زاد المسير" 1/ 454.</p><p>قال ابن قتيبة: (لأن أهل النظر يَرَوْن أن التاء فيه منقلبة عن دال؛ كأن الأصل فيه: (يكبدُهُم)، أي: يصيبهم في أكبادهم بالحزن والغيظ وشدة العداوة. ومنه يقال: (فلان قد أحرق الحزنُ كبِدَهُ). و (أحرقت العداوة كبده). والعرب تقول للعدو: (أسود الكبد) ..) ثم أتبع قائلاً: (والتاء والدال متقاربتان المَخرَجَيْن. والعرب تدغم إحداهما في الأخرى، وتبدل إحداهما من الأخرى). "تفسير غريب القرآن" 110. وانظر (كبت) في "تهذيب اللغة" 4/ 3088، "اللسان" 6/ 3805، "عمدة الحفاظ" 477.انظر: "تهذيب اللغة" 1/ 957 (خاب)، و"معاني القرآن" للنحاس 1/ 472، و"اللسان" 3/ 1297 (خيب).في (ج): (فقطع).
  3,128,"<div class=ar lang=ar><p>قوله تعالى: <span class="qpc-hafs">﴿لَيْسَ لَكَ مِنَ الْأَمْرِ شَيْءٌ أَوْ يَتُوبَ عَلَيْهِمْ﴾</span> الآية.</p><p>ذَكَرَ النحويون -الفرّاء {1}، والزّجاج {2}، وغيرُهما {3} - في هذه الآية قولين: أحدهما: أنَّ قوله: <span class="qpc-hafs">﴿أَوْ يَتُوبَ عَلَيْهِمْ﴾</span> عَطْفٌ عَلَى قوله: <span class="qpc-hafs">﴿لِيَقْطَعَ طَرَفًا مِنَ الَّذِينَ كَفَرُوا أَوْ يَكْبِتَهُمْ﴾</span>، <span class="qpc-hafs">﴿أَوْ يَتُوبَ عَلَيْهِمْ﴾</span>، ويكون قولُه: <span class="qpc-hafs">﴿لَيْسَ لَكَ مِنَ الْأَمْرِ شَيْءٌ﴾</span> اعتراضًا بين المعطوف والمعطوف عليه؛ كما تقول: (ضَرَبْتُ زيدًا -فاعْلَمْ ذلك- وعَمْرًا) {4}. فعلى هذا القول: هذه الآية متصلة بما قبلها.</p><p>القول الثاني: وهو أنَّ الموافق لِمَا ذُكِرَ في تفسير هذه الآية: أنَّ معنى (أو) -ههنا- معنى (حتَّى) و (إلّا أنْ)؛ وذلك أنَّ أكثر المُفَسِّرِين -ابنَ عباس {5}، والحسنَ {6}، وقتادةَ {7}، والربيع {7} - قالوا: لَمّا كان من المشركين يوم أحد ما كان {9}، مِنْ كَسْرِ رَبَاعِيّةِ {10} النبي ﷺ، وشَجِّهِ حتَّى جَرَت الدِّماءُ على وجهه، قال: "كيف يُفْلِحُ قومٌ خَضَبُوا وَجْهَ نَبِيِّهم، وهو يدعوهم إلى ربهم؟! " {11}، فأنزل اللهُ هذه الآية، لِعِلْمِهِ أنَّ كثيرًا منهم سيؤمِنُونَ، فَكَفَّ عن ذلك {12}.</p><p>وقوله تعالى: <span class="qpc-hafs">﴿لَيْسَ لَكَ مِنَ الْأَمْرِ شَيْءٌ﴾</span> مختَصَرُ معناه: ليس لَكَ مِنَ الأمْرِ في عقابهم، أو {13} استصلاحهم شيءٌ، حتى تقَعَ إنابَتُهم {14} أو تعذيبهم. فيكون أمْرُكَ -حينئذٍ - تابعًا لأمْرِ اللهِ، بِرِضَاكَ بتدبيره</p><p>قال الفرّاء {15}: ومِثْلُ هذا مِن الكلام: (لأَذُمَّنَّكَ {16} أو تُعْطِيَنِي)؛ على معنى: (إلّا أنْ تُعْطِيَني)، و (حتى تُعْطِيَنِي) {17}.</p><p>وأنشد ابن الأنباري {18} على هذا:</p><p>فَقُلْتُ لَهُ لا تَبْكِ عيْنُكَ إنَّما ... نُحاوِلُ مُلْكًا أو نَمُوتَ فَنُعْذَرَا {19}</p><p>أراد: (حتَّى)، و (إلّا أنْ نموت) {20}.</p></div>",footnotes:1:في "معاني القرآن" له 1/ 234.في "معاني القرآن" له 1/ 468.انظر: "معاني القرآن" للأخفش 1/ 215، و"تفسير الطبري" 4/ 86، و"إيضاح الوقف والابتداء" لابن الأنباري 2/ 583، و"القطع والائتناف" للنحاس 233، و"معاني القرآن" له 1/ 474. واستحسنه الثعلبي في "تفسيره" 3/ 115 ب.وقد رجح الطبري هذا الرأي في "تفسيره" 4/ 86، وقال معلَّلًا: (لأنه لا شيء من أمرالخلق إلى أحد سوى خالقهم، قبل توبة الكفار وعقابهم، وبعد ذلك).لم أقف على مصدر قوله. وقد ذكره الماوردي في "النكت" (423)، وابن الجوزي في "الزاد" 1/ 456.قوله، في: "تفسير الطبري" 4/ 87، 88، و"النكت والعيون" 2/ 423، و"زاد المسير" 456.قوله في المصادر السابقة.قوله في المصادر السابقة.(ما كان): ساقطة من (ج).الرَّبَاعِيَّة: هي السن بين الثَّنِيَّة والناب. وجمعها: رباعيات. وهن أربع رباعيات: ثنتان من فوق، وثنتان من أسفل. انظر: كتاب "خلق الإنسان"، لابن أبي ثابت 166، و"القاموس" (719) (ربع).</p><p>قال ابن حجر: (والمراد بكسر الرَّباعية .. أنها كسرت فذهب منها فلقة، ولم تقلع من أصلها). "فتح الباري" 7/ 366.</p><p>وفي "سيرة ابن هشام" عن ابن إسحاق أن الذي فعل ذلك هو: عقبة بن أبي وقاص. == حيث رمى النبي ﷺ فكسر رباعيته اليمنى السفلى، وجرح شفته العليا وشَجَّه في وجهه.</p><p>ويذكر ابن هشام، عن أبي سعيد الخدري، أن عبد الله بن شهاب الزهري شجَّه في وجهه، وأن ابن قَميئة جرح وجنته، فدخل حلقتان من حِلَق المِغْفَر في وجنته. انظر: "سيرة ابن هشام" 3/ 27، و"تاريخ الطبري" 2/ 514.الحديث -كذلك- ورد من رواية أنس، وقد أخرجته الكتب التالية بألفاظ مختلفة، بنحو الذي ذكره المؤلف. فقد أخرجه البخاري -معلقًا- 5/ 35. كتاب المغازي. باب (ليس لك من الأمر شيء)، وأخرجه مسلم في (1791) كتاب الجهاد. باب غزوة أحد، وأحمد 3/ 206، 3/ 99، 253، 288، والترمذي (3002 - 3003) كتاب التفسير. (سورة آل عمران) وقال: (حسن صحيح). وابن ماجه (4027) كتاب الفتن: باب الصبر على البلاء. والنسائي في "تفسيره" 1/ 329، والبغوي في "شرح السنة" 13/ 333 رقم (3748) وقال عنه: (صحيح)، وابن سعد في "الطبقات" 2/ 44، والطبري في "تفسيره" 4/ 87، وفي "تاريخه" 2/ 515، وابن أبي حاتم في "تفسيره" 3/ 756، والنحاس في "الناسخ والمنسوخ" 1/ 213، والثعلبي في "تفسيره" 3/ 114 أ، والبغوي في "تفسيره" 2/ 102، والمؤلف في "أسباب النزول" (124).وهناك أسباب أخرى لنزول هذه الآية ذكرها المفسرون. انظر: "تفسير الطبري" 4/ 86 - 89، و"ابن أبي حاتم" 3/ 756 - 758، و"أسباب النزول" للمؤلف 124 - 126، و"لباب النقول" 57 - 58، و"الصحيح المسند من أسبالب النزول" 53 - 56.في (ج): (و) بدلًا من: (أو).وهكذا وردت في "تفسير الوسيط" للمؤلف (تح: بالطيور): 326. وورد في "تفسير الوجيز" له 1/ 118 (إثابتهم).في "معاني القرآن" له 1/ 234. نقله بمعناه وانظر: "معاني القرآن" 2/ 70.في (أ)، (ب): (لا أذمنك). وهي خطأ. والمثبت من (ج).الذي في "معاني القرآن" -في هذا الموضع-: (وإن شئت جعلت نصبه على مذهب (حتى)؛ كما تقول: (لا أزال ملازمك أو تعطيني)، أو (إلا ان تعطيني حقي).</p><p>وقال في موضع آخر 2/ 70: (والله لأضربَنك أوْ تُقِرَّ لي). فيكون معناه معنى (حتى) أو (إلا).في "إيضاح الوقف والابتداء" له 2/ 584.في (ج): (فنعذرا). والبيت لامرئ القيس، في "ديوانه" 64. وقد سبق إيراده وبيان مصادره عند تفسير قوله تعالى: <span class="qpc-hafs">﴿أَو يُحَاجُّوكُمْ﴾</span> [الآية: 73 من سورة آل عمران].الذي في كتاب "إيضاح الوقف والابتداء"، قوله -بعد أن ذكر البيت-: (أراد: حتى نموت).</p><p>وهناك قولان آخران في نصب <span class="qpc-hafs">﴿يَتُوبَ﴾</span>، وهما: -النصب بإضمار (أنْ) عطفًا على (الأمر)، والتقدير: (ليس لك من الأمر لك من الأمر شيء، أو من أن يتوب عليهم، أو يعذبهم)؛ أي: ليس لك من الأمر أو من توبته عليهم، أو من تعذيبهم شيء. وهو قول أبي حاتم، كما في "تفسير الثعلبي"- إنها معطوفة بالتأويل على <span class="qpc-hafs">﴿شَئءٍ﴾</span> وتقديرها: ليس لك من الأمر شيءٌ، أو توبةُ الله عليهم، أو تعذيبهم؛ أي: ليس لك أيضًا توبتهم ولا تعذيبهم، إنما مرد ذلك إلى الحقِّ تعالى.</p><p>انظر: كتاب "إيضاح الوقف والابتداء" 2/ 584، وكتاب "القطع والائتناف" 233، و"تفسير الثعلبي" 3/ 115 ب، و"الدر المصون" 3/ 393.
  3,129,"<div class=ar lang=ar><p>وقوله تعالى: <span class="qpc-hafs">﴿وَلِلَّهِ مَا فِي السَّمَاوَاتِ وَمَا فِي الْأَرْضِ﴾</span> قال أهلُ المعاني {1}: لَمَّا نَفَى [اللهُ] {2} الأمرَ عَنْ نَبِيِّهِ ﷺ، ذَكَرَ أنَّ جميع الأمر له؛ كأنه قال: الأمر ليس لك منه شيءٌ، فمن شاء عَذَّبَهُ، ومَن شاءَ غَفَرَ له.</p><p>وقوله تعالى: <span class="qpc-hafs">﴿مَا فِي السَّمَاوَاتِ﴾</span> ولم يقل: (مَنْ)؛ لأنه ذهب به مَذْهَب الجنس، فَدَخَلَ فيه الجميع {3}.</p><p>وقوله تعالى: <span class="qpc-hafs">﴿يَغْفِرُ لِمَنْ يَشَاءُ﴾</span> قال ابنُ عَبَّاس، في رواية عطاء {4}: الذنْبَ العظيمَ للمُوَحِّدِينَ {5}.</p><p><span class="qpc-hafs">﴿وَيُعَذِّبُ مَنْ يَشَاءُ﴾</span> يريد: المشركين {6}، على الذنب الصغير {7}.</p><p><span class="qpc-hafs">﴿وَاللَّهُ غَفُورٌ﴾</span> لأوليائه، <span class="qpc-hafs">﴿رَحِيمٌ﴾</span> بهم.</p></div>",footnotes:1:لم أقف عليهم.ما بين المعقوفين: زيادة من (ب).قال البقاعي: (وعُبِّر بـ (ما)؛ لأن غير العاقل أكثر، وهي به أجدر). "نظم الدرر" 5/ 61.لم أقف على مصدر هذه الروايةوقد أورد أبو الليث عن الضحاك مثل هذا القول: انظر: "بحر العلوم" 1/ 297.في (ج): (للمشركين).في (ج): (الصغير). وفي "تفسير ابن أبي حاتم" عن ابن عباس من رواية علي بن أبي طلحة في قوله تعالى: <span class="qpc-hafs">﴿وَيُعَذِّبُ مَن يَشَاءُ﴾</span> قال: (وأما أهل الشكِّ والرَّيْب فيخبرهم بما أخفوا من تكذيب) 3/ 758.
  3,130,"<div class=ar lang=ar><p>قوله تعالى: <span class="qpc-hafs">﴿يَا أَيُّهَا الَّذِينَ آمَنُوا لَا تَأْكُلُوا الرِّبَا أَضْعَافًا مُضَاعَفَةً﴾</span> قال ابن عباس {1}، وسعيد بن جبير {2} هو أنهم كانو يزيدون على المال، وُيؤَخِّرُونَ الأَجَلَ، كلَّما أخّر عن أَجَلٍ إلى غيره، زِيد زيادة.</p><p>وانتصب <span class="qpc-hafs">﴿أَضْعَافًا﴾</span> على الحال.</p><p>وقوله تعالى: <span class="qpc-hafs">﴿لَعَلَّكُمْ تُفْلِحُونَ﴾</span> قال عطاء {1}: يريد: كي تسعدوا، وتبقوا في الجنة. وقال الزّجاج {4}: المُفْلِحُ: الذي أدرك ما أمَّلَ مِنَ الخير. وذكرنا معنى (الإفلاح) فيما تقدم {5}.</p></div>",footnotes:1:لم أقف على مصدر قوله.قوله في "تفسير ابن أبي حاتم" 3/ 759، و"تفسير الثعلبي" 3/ 115 ب، و"زاد المسير" 1/ 458.لم أقف على مصدر قوله.في "معاني القرآن" له 1/ 468. نقله عنه بنصه.انظر: "تفسير البسيط" عند تفسير قوله تعالى <span class="qpc-hafs">﴿وَأُولَئِكَ هُمُ الْمُفْلِحُونَ﴾</span> [البقرة: 5].
  3,131,"<div class=ar lang=ar><p>قوله تعالى: <span class="qpc-hafs">﴿وَاتَّقُواْ النَّارَ﴾</span> الآية. قال أبو إسحاق {1}: أي: اتَّقُوا أن تُحِلُّوا ما حَرَّمَ اللهُ، فإنَّ مَنْ أَحَلَّ شيئًا مِمَّا حَرَّمَ اللهُ، فهو [كافرٌ] {2} بإجماع.</p><p>وهذا معنى قول ابن عبَّاس، قال {3}: يُهَدِّدُ المؤمنين إن استحلوا ما حَرَّمَ اللهُ عَلَيْهِم مِنَ الرِّبَا وغيره، مِمَّا أوجَبَ الله فيه النَّارَ؛ والتقدير: واتَّقُوا النَّارَ التي أُعِدَّت للكافرين، أن تستحلوا الرِّبا، فتستحقوها {4}.</p><p>وفي الآية تَقْويَةٌ لِرَجاءِ المؤمنين، رحمةً من الله -تعالى-؛ لأنه قال: <span class="qpc-hafs">﴿أُعِدَّت لِلكَافِرِينَ﴾</span>. فَجَعلها مُعَدَّةً للكفار، دونَ أهلِ الإيمان.</p></div>",footnotes:1:في "معاني القرآن" له 1/ 468. نقله عنه بنصه.ما بين المعقوفين زيادة من (ج) و"معاني القرآن".لم أقف على مصدر قوله. وقد ذكره ابن الجوزي في: "زاد المسير" 1/ 459.في (ج): (فيستحقوها).
  3,132,"<div class=ar lang=ar><p>قوله تعالى: <span class="qpc-hafs">﴿وَأَطِيعُوا اَللَّهَ وَاَلرَّسُولَ﴾</span> لَمَّا نَهَى عن أكل الرِّبَا، أمَرَ بطاعة الرسولِ فيما يأمرهم به، وينهاهم عنه، مِن أكلِ الرِّبَا وغيره.</p><p>وذُكِر عن محمد بن إسحاق بن يَسَار، أنَّه قال {1}: [في] {2} هذه الآية معاتَبة للذين عَصَوا رسولَ الله ﷺ حين أمرهم بما أمرهم به يوم أُحُد.</p></div>",footnotes:1:قوله، في: "سيرة ابن هشام" 3/ 61 - 62، و"تفسير الطبري" 4/ 91، و"تفسير ابن أبي حاتم" 3/ 761.ما بين المعقوفين زيادة من (ج).