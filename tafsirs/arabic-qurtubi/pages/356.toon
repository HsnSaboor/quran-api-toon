  24,46,""
24,47," <q>﴿وَيَقُولُونَ آمَنَّا بِاللَّهِ﴾</q> قال مقاتل: صدقنا بتوحيد الله وبالرسول محمد أنَّه من الله <q>﴿وَأَطَعْنَا﴾</q> قولهما، يعني المنافقين يقولون هذا بألسنتهم <q>﴿ثُمَّ يَتَوَلَّى فَرِيقٌ مِنْهُمْ﴾</q> ثم يعرض عن طاعتهما طائفة منهم <q>﴿مِنْ بَعْدِ ذَلِكَ﴾</q> من بعد قولهم أمنا {1}. قال مقاتل وغيره {2}: نزلت في بشر المنافق كان يخاصم يهوديًّا في أرض، فجعل اليهودي يجره إلى رسول الله -ﷺ-، وجعل المنافق يجره إلى كعب بن الأشرف، ويقول: إن محمدًا يحيف علينا. فقال الله <q>﴿وَمَا أُولَئِكَ بِالْمُؤْمِنِينَ﴾</q> يعني الذي يعرضون عن حكم الله ورسوله. ",footnotes:1:"تفسير مقاتل" 2/ 40 أ.قول مقاتل في "تفسيره" 2/ 40 أ. وذكره الثعلبي 3/ 88 أمن غير سند. وذكر الواحدي في "أسباب النزول" ص 133 من رواية الكلبي، عن أبي صالح، عن ابن عباس نحو هذا في سبب نزول قوله تعالى: <q>﴿أَلَمْ تَرَ إِلَى الَّذِينَ يَزْعُمُونَ﴾</q> [النساء: 60]. ومقاتل والكلبي وأمثالهما لا يعتمد عليهم في الرواية.
24,48," <q>﴿وَإِذَا دُعُوا إِلَى اللَّهِ﴾</q> إلى كتاب الله <q>﴿وَرَسُولِهِ لِيَحْكُمَ بَيْنَهُمْ﴾</q> الرسول فيما اختصموا فيه <q>﴿إِذَا فَرِيقٌ مِنْهُمْ مُعْرِضُونَ﴾</q> {1} عما يُدعون إليه من حكم الله ورسوله. وقال الفراء: إنَّما قال: <q>﴿لِيَحْكُمَ﴾</q>، ولم يقل: ليحكما؛ لأن المعنى: للرَّسول، وإنَّما بُدئ {2} بذكر الله إعظامًا لله {3}. وذكرنا مثل هذا فيما تقدم {4}. ",footnotes:1:في (أ)، (ظ): (فإذا)، وهو خطأ.في (أ): (بدأ)."معاني القرآن" للفراء 2/ 258 مع تقديم وتأخير.انظر: "البسيط" عند قوله تعالى <q>﴿وَاللَّهُ وَرَسُولُهُ أَحَقُّ أَنْ يُرْضُوهُ إِنْ كَانُوا مُؤْمِنِينَ﴾</q> [التوبة: 62].
24,49," <q>﴿وَإِنْ يَكُنْ لَهُمُ الْحَقُّ يَأْتُوا إِلَيْهِ مُذْعِنِينَ﴾</q> قال ابن عباس {1}، ومقاتل {2}: مسرعين. وقال الكلبي: طائعين {3}. وقال الزَّجَّاج: الإذعان في اللغة: الإسراع مع الطَّاعة. تقول: قد أذعن لي بحقي، أي: طاوعني لما كنت التمسه منه، وصار يسرع إليه {4}. وقال ابن الأعرابي: مذعنين: مقِّرين خاضعين {5}. وقال المبرد: طائعين غير ممتنعين كما تقول: أذعن فلان بحقي، إذا أقرَّ به ولم يمتنع {6}. أخبر الله تعالى أنَّ المنافقين يعرضون عن حكم الرسول لعلمهم بأنه {7} يحكم بالحق ولا يداهن، فإذا كان الحق لهم على غيرهم أسرعوا إلى حكمه لثقتهم بأنَّه كما يحكم عليهم بالحق يحكم لهم أيضًا بالحق وينتصف لهم ممَّن لهم الحق عليه. قال ابن عباس: ثم أخبر بما في قلوبهم من المرض والشك فقال: <q>﴿أَفِي قُلُوبِهِمْ مَرَضٌ﴾</q>. قال مقاتل: يعني الكفر {2}. <q>﴿أَمِ ارْتَابُوا﴾</q> أم شكوا في القرآن. وإنَّما جاء بلفظ الاستفهام؛ لأنَّه أشد في الذم والتوبيخ، أي أنَّ هذا أمرٌ قد ظهر حتى لا يحتاج فيه إلى البيّنة {9}، كما جاء في نقيضه على طريق الاستفهام لأنَّه أشد مبالغة وهو قول جرير: ألستم خير من ركب المطايا {10} أي أنتم كذلك {11}. وبنحو {12} هذا فسر ابن عباس فقال: أخبر الله تعالى بما في قلوبهم من المرض والشك. فجعل معنى هذا الاستفهام: الإخبار. قوله تعالى: <q>﴿أَمْ يَخَافُونَ أَنْ يَحِيفَ اللَّهُ عَلَيْهِمْ وَرَسُولُهُ﴾</q> قال ابن عباس والمفسرون {13}: أن يجور الله عليهم. والحيف: الميلُ في الحكم. وحيفُ النَّاحل أن يعطي بعض أولاده دون بعض {14}. وقال المبرد: يقال: حاف علي فلانٌ في القضية، أي جار علي وألزمني ما لا يلزم {15}. <q>﴿بَلْ أُولَئِكَ هُمُ الظَّالِمُونَ﴾</q> أي: لا يظلم الله ورسوله في الحكم، بل هم الذين يظلمون أنفسهم بالكفر والإعراض عن حكم رسول الله -ﷺ- {16}. قال مقاتل: ثم نعت الصادقين في إيمانهم فقال: ",footnotes:1:روى الطبري 18/ 156 مثل هذا القول عن مجاهد، ورواه ابن أبي حاتم 7/ 58 أ، ب عن ابن زيد، وذكره النحاس في "معاني القرآن" 4/ 547 عن عطاء. وحكاه الماوردي 4/ 115 والقرطبي 12/ 293 عن مجاهد."تفسير مقاتل" 2/ 40 أ.روى ابن أبي حاتم 7/ 58 ب مثل هذا القول عن الحسن، وذكره الماوردي 4/ 115 وقال: حكاه ابن عيسى."معاني القرآن" للزجاج 4/ 50.قول ابن الأعرابي في "تهذيب اللغة" للأزهري 2/ 320 (ذعن).انظر نحو هذا عند الطبري 18/ 156، وانظر: "لسان العرب" 13/ 172 (ذعن).في (ظ)، (ع): (أنَّه)."تفسير مقاتل" 2/ 40 أ.في (ع): حتى لا يحتاج فيه إلَّا إلى التنبيه.هذا صدر بيت من قصيدة يمدح بها عبد الملك بن مروان، وعجزه: وأندى العالمين بطون راح وهو في "ديوانه" 1/ 89، و"مجاز القرآن" لأبي عبيدة 1/ 36، 184، و"أمالي ابن الشَّجري" 1/ 265، و"لسان العرب" 7/ 10 (نقص)، "مغني اللبيب" لابن هشام 1/ 24. قال السيوطي في "شرح شواهد المغني" 1/ 44: المطايا: جمع مطية، وهي الدابة تمطو في مشيها أي: تسرع، وأندى: أسخى، والراح: جمع راحة وهو الكف. اهـ.من قوله: وإنما جاء بلفظ الاستفهام .. إلى هنا. هذا قول الثعلبي في "تفسيره" 3/ 88 أمع اختلاف يسير في العبارة. وقد ذكره ابن الجوزي 6/ 55، والقرطبي 12/ 294، وأبو حيان 6/ 467 من غير نسبة.في (أ): (ونحو).انظر: "الطبري" 18/ 156."تهذيب اللغة" للأزهري 5/ 264 (حاف)، وانظر: "لسان العرب" 9/ 60 (حيف).لم أجد من ذكره عنه، وانظر: "لسان العرب" 9/ 60 (حيف).انظر: "الطبري" 18/ 157.
  24,50,""
24,51," <q>﴿إِنَّمَا كَانَ قَوْلَ الْمُؤْمِنِينَ﴾</q> الآية {1}. قال الفراء: ليس هذا بخبر {2} ماض يخبر {2} عنه {4}، كما تقول: إنما كنت صبيًّا، ولكن معناه: إنما كان ينبغي أن يكون قول المؤمنين إذا دعوا أن يقولوا سمعنا وأطعنا، وهو أدب من الله تعالى. قال: وكذا جاء في التفسير {5}. وقال مقاتل: يقولوا سمعنا قول النبي وأطعنا أمره {1}. وقال ابن عباس: وإن كان ذلك فيما يكرهون {7} ويضرّ بهم {8}. قوله تعالى: <q>﴿وَمَنْ يُطِعِ اللَّهَ وَرَسُولَهُ﴾</q> قال ابن عباس: فيما ساءه وسرّه {9}. وقال مقاتل: في أمر الحكم <q>﴿وَيَخْشَ اللَّهَ﴾</q> في ذنوبه التي عملها <q>﴿وَيَتَّقْهِ﴾</q> فيما تعبد {10} فلم يعص الله {1}. والمعنى: يتقي عذاب الله بطاعته {12}. وفي (يتقه) وجوه من القراءات: أحدها: (يتَّقهي) موصولة بياء {13}، وهو الوجه؛ لأن ما قبل الهاء متحرك، وحكمها إذا تحرك ما قبلها أن تتبعها الياء في الوصل. وروى قالون {14}، عن نافع: بكسر الهاء ولا يبلغ بها الياء {15}. ووجهه أن الحركة قبل الهاء ليست تلزم، ألا ترى أنَّ الفعل إذا رفع دخلته الياء، وإذا دخل {16} الياء اختير حذف الياء بعد الهاء في الوصل مثل: (عليه) فلما كان الحرف المحذوف لا يلزم حذفه صار كأنَّه في اللفظ. وقرأ أبو عمرو: (ويتَّقه) جزمًا {17}. ووجهه أن ما يتبع هذه الهاء من الواو والياء زائد {18} فردَّ إلى الأصل، وحذف ما يلحقه من الزيادة. وقد حكى سيبويه {19} أنه سمع: (هذه أمة {20} الله)، في الوصل والوقف، وهذه الهاء التي في هذه قد أجروها مجرى هاء الضمير، فلما {21} استجازوا الحذف في هذه فكذلك يجوز في الهاء التي للضمير. وروى حفص عن عاصم (ويتقه) ساكنة القاف مكسورة الهاء مختلسه {22}. ووجهه أن (تقه) من (يتقه) بمنزلة: كتف، فكما {23} يسكن {24} كتف، كذلك سكَّن القاف من (تقه) {25} {26}. وقد تقدَّم لهذا نظائر واستشهادات. وقال ابن الأنباري {27}: هذا على لغة من يسقط الياء ويسكن الحرف الذي قبلها في باب الجزم فيقول: لم أر زيدًا، ولم أشتر طعامًا، ولم يتَّق زيد. وهو من التوهم {28}، والتقدير لما ذهبت الياء {29} استوثقوا من الجزم بتسكين ما قبل الياء. أنشد الفراء {30}: ومن يتَّق فإنَّ الله معه ... ورزق الله منتاب {31} وغاد وقال مقاتل بن سليمان وغيره {32}: لما بيَّن الله تعالى كراهية المنافقين لحكم النبي -ﷺ- أتوه فقالوا: والله لو أمرتنا أن نخرج من ديارنا وأموالنا ونسائنا لخرجنا، وإن أمرتنا بالجهاد جاهدنا، فأنزل الله فيما حلفوا قوله تعالى: ",footnotes:1:"تفسير مقاتل" 2/ 40 أ.في (أ): (الحبر) في الموضعين.في (أ): (الحبر) في الموضعين.(عنه): ساقطة من (ع)."معاني القرآن" للفراء 2/ 258."تفسير مقاتل" 2/ 40 أ.في (ظ)، (ع): (يكرهونه).ذكره عنه القرطبي 12/ 294.ذكره عنه البغوي 6/ 56. وذكره الرازي 24/ 22 من غير نسبة.في (أ): (يعبد)، والمثبت من باقي النسخ و"تفسير مقاتل"."تفسير مقاتل" 2/ 40 أ.هذا قول الطبري 14/ 157 بنصِّه.وهذه قراءة جمهور القراء. "السبعة" ص 457، "التَّبصرة" ص 274، "التيسير" ص 163.هو: عيسى بن مينا بن وردان بن عيسى، الزرقي مولى بني زهرة، أبو موسى، الملقب بقالون. قارئ المدينة في زمانه ونحويّهم. يقال إنَّه ربيب نافع، وقد اختص به كثيرًا، وهو الذي سمَّاه قالون لجودة قراءته، وهي لفظة رومية معناه: جيّد. وانقطع لإقراء القرآن والعربية، وطال عمره وبعد صيته. توفي سنة 120 هـ. "معرفة القراء الكبار" للذهبي 1/ 155، "غاية النهاية" 1/ 615، "شذرات الذهب" 2/ 48.انظر: "السبعة" ص 457، "التبصرة" ص 274، "التيسير" ص 163.هكذا في جميع النسخ، وفي "الحجّة": دخلت.انظر: "السبعة" ص 457، "التبصرة" ص 274، "التيسير" ص 162.في "الحجة": زائدة."الكتاب": 4/ 198.في (ظ)، (ع): (آية).في "الحجة": فكما.انظر: "السبعة" ص 458، "التبصرة" ص 274، "التيسير" ص 163.في (ظ)، (ع): (فلما)، والمثبت من (أ) والحجة.في (ع): (سكن).في (أ): (يقه).من قوله: (يتقهي) موصولة .. إلى هنا. نقلاً عن "الحجة" لأبي علي الفارسي 5/ 327 - 329 مع تقديم وتأخير واختلاف يسير. == وانظر أيضًا في "توجيه القراءات": "علل القراءات السبع" لابن خالويه 2/ 111 - 113، "حجة القراءات" لابن زنجلة ص 503 - 504، "الكشف" لمكي 2/ 140 - 142.ذكر ابن خالويه في "علل القراءات" 2/ 113 هذا القول باختصار مع البيت، ولم ينسبه لأحد. وابن خالويه يروي عن ابن الأنباري.أي توهّم أنَّها لام الفعل فتُسكن للجزم.(الياء): ساقطة من (ع).لم أجده في كتابه "معاني القرآن". ويظهر أنه من تمام كلام ابن الأنباري. والبيت بلا نسبة في "الخصائص" لابن جني 1/ 306، والصاحبي في "فقه اللغة" لابن فارس ص 48، و"شرح شواهد الشافية" ص 228، و"لسان العرب" 1/ 218 (أوب) 15/ 402 (وقي) والرواية عندهم: (مؤتاب) في موضع (منتاب). وصدر البيت في "همع الهوامع" 1/ 79 بلا نسبة.هكذا في جميع النسخ، وفي بقية المصادر التي ذكرت البيت: مؤتاب."تفسير مقاتل" 2/ 40 ب. وذكر الثعلبي 3/ 88 أنحوه بغير سند. وروى ابن مردويه كما في "الدر المنثور" 6/ 214 عن ابن عباس نحو هذا.
  24,52,""
24,53," <q>﴿وَأَقْسَمُوا بِاللَّهِ جَهْدَ أَيْمَانِهِمْ﴾</q> قال مقاتل: من حلف بالله فقد اجتهد في اليمين {1}. وقد مرّ {2}. <q>﴿لَئِنْ أَمَرْتَهُمْ﴾</q> يا محمد <q>﴿لَيَخْرُجُنَّ﴾</q> إلى الجهاد ومن أموالهم وديارهم {3}. <q>﴿قُلْ لَا تُقْسِمُوا﴾</q> قال ابن عباس: قل: لا تحلفوا فإنَّ الله لو بلغ منكم {4} الجهد. لم تبلغوه. يعني: لو كلَّفكم {5} ما تُقسمون عليه ما وفَّيتم بيمينكم {6} {7}. وتمّ الكلام. ثم قال: <q>﴿طَاعَةٌ مَعْرُوفَةٌ﴾</q> قال مقاتل بن حيان: أمرهم أن لا يحلفوا على شيء، ولكن أمرهم أن تكون منهم طاعة معروفة للنبي -عليه السلام- من غير أن يقسموا {8}. وقال مقاتل بن سليمان: <q>﴿قُلْ﴾</q> لهم <q>﴿لَا تُقْسِمُوا﴾</q> ولكن لتكن {9} منكم <q>﴿طَاعَةٌ مَعْرُوفَةٌ﴾</q> يعني حسنة [النبي -ﷺ- {1}. وهذا معنى قول الكلبي، يقول: أطيعوه وقوله المعروف من الكلام. وفسَّر ابن عباس الطاعة المعروفة] {11} -هاهنا- بأن يُضمروا في القلب طاعته بنيَّة خالصة {12}. وقال أبو إسحاق: تأويله: طاعة معروفة أمثل من قسمكم بما لا تصدقون فيه. فالخبر مُضمر وهو: "أمثل"، وحذف لأن في الكلام دليلًا {13} عليه {14}. وقال مجاهد: أي هذه طاعة معروفة منكم بالقول دون الاعتقاد. أي أنَّكم تكذبون فيما تقولون: لو أمرتنا أن نخرج من ديارنا وأموالنا خرجنا {15}. وذكر أبو عبيدة هذا الوجه فقال: أي هذه طاعة معروفة {16}. وعلى هذا معنى المعروفة أنها عرفت منهم، فهم يقولون ولا يفون بما يقولون. وقيل: طاعة معروفة منكم بالكذب {17} {18}. وقد حصل في ارتفاع الطاعة ثلاثة أقوال {19}. وقوله تعالى: <q>﴿إِنَّ اللَّهَ خَبِيرٌ بِمَا تَعْمَلُونَ﴾</q> أي من طاعتكم بالقول ومخالفتكم بالفعل {20}. وقال عطاء، عن ابن عباس: يريد بأعمالكم وسرائركم. قال مقاتل: ثم أمرهم الله بطاعته وطاعة رسوله فقال: <q>﴿قُلْ أَطِيعُوا اللَّهَ وَأَطِيعُوا الرَّسُولَ﴾</q> {1}. <q>﴿فَإِنْ تَوَلَّوْا﴾</q> قال الفراء: واجه القوم، ومعناه: فإن تتولَّوا، فهي في موضع جزم، ولو كانت لقوم غير مخاطبين كان فعلاً ماضيًا بمنزلة قولك: فإن قاموا، كما قال <q>﴿فَإِنْ تَوَلَّوْا فَقُلْ حَسْبِيَ اللَّهُ﴾</q> [التوبة: 129] هؤلاء غير مخاطبين، والجزاء يصلح فيه فَعَل ويفعل كهذه {22} الآية والتي في هذه السورة، وأنت تعرفهما بالقراءة بعدهما؛ ألا ترى قوله: {عَلَيْهِ مَا حُمِّلَ وَعَلَيْكُمْ مَا حُمِّلْتُمْ} ولم يقل: عليهم، وقوله <q>﴿وَإِنْ تَوَلَّوْا فَإِنَّمَا هُمْ فِي شِقَاقٍ﴾</q> [البقرة: 137] فهذا يدل على فعلوا. انتهى كلامه {23}. وقد بان بما ذكر أن قوله <q>﴿فَإِنْ تَوَلَّوْا﴾</q> {24} مخاطبة من الله تعالى لهم بعد أن أمر رسوله أن يخاطبهم بقوله: <q>﴿أَطِيعُوا اللَّهَ وَأَطِيعُوا الرَّسُولَ﴾</q>، ولو كان قوله: <q>﴿فَإِنْ تَوَلَّوْا﴾</q> من خطاب الرسول معهم لقال: فإنما علي ما حمل. قال ابن عباس: الذي حمِّل النبي -ﷺ- أن يبلغهم، وحملوا أن يطيعوه {25}. وقال مقاتل {3}، والسدي {27}: يقول فإنما على محمد ما أمر من تبلغ الرسالة، وعليكم ما أمرتم من طاعتهما. <q>﴿وَإِنْ تُطِيعُوهُ تَهْتَدُوا﴾</q> تصيبوا الحق {28}. <q>﴿وَمَا عَلَى الرَّسُولِ إِلَّا الْبَلَاغُ الْمُبِينُ﴾</q> ليس عليه إلاَّ أن يبلغ ويبين لكم. ",footnotes:1:"تفسير مقاتل" 2/ 40 ب.انظر: "البسيط" عند قوله تعالى: <q>﴿وَيَقُولُ الَّذِينَ آمَنُوا أَهَؤُلَاءِ الَّذِينَ أَقْسَمُوا بِاللَّهِ جَهْدَ أَيْمَانِهِمْ﴾</q> [المائدة: 53]، و"البسيط" عند قوله تعالى: <q>﴿وَأَقْسَمُوا بِاللَّهِ جَهْدَ أَيْمَانِهِمْ﴾</q> [الأنعام: 109].انظر: "تفسير مقاتل" 2/ 40 ب.(منكم): ساقطة من (ع).في (أ): (لم تبلغوا نعمتي لو كفلكم)، وهي عبارة لا معنى لها.في (ع): (بتمنيكم)، وهو خطأ.لم أجده.رواه ابن أبي حاتم 7/ 59 أ، ب وذكره السيوطي في "الدر المنثور" 6/ 214 ونسبه لابن أبي حاتم.في "تفسير مقاتل": ولكن هذه منكم."تفسير مقاتل" 2/ 40 ب.ساقط من (أ).ذكر البغوي 6/ 57، والقرطبي 12/ 296 نحو هذا المعنى ولم ينسباه لأحد.في (أ): (دلالة)."معاني القرآن" للزجاج 4/ 51.ذكر الثعلبي 3/ 88 أهذا القول وقال: وهذا معنى قول مجاهد. اهـ. وقد رواه بنحوه مختصر الطبري 18/ 157. وذكره السيوطي في "الدر المنثور" 6/ 214 بمثل رواية الطبري ونسبه لابن المنذر.هذا معنى ما قاله أبو عبيدة في "مجاز القرآن" 2/ 69، ونصُّه: (طاعة معروفة) مرفوعتان .. ، فرفعتا على ضمير يُرفع به، أو ابتداءً.(بالكذب): ساقطة من (ع).هذا قول الطبري 18/ 157، والثعلبي 3/ 88 ب.هذه الأقوال هي حسب ذكر الواحدي لها: الأول: أن تكون فاعلةً بفعل محذوف، أي: ولتكن طاعةٌ. الثاني: أنها مبتدأ والخبر محذوف، أي: أمثل أو أولى. الثالث: أنها خبر مبتدأ مضمر تقديره: هذه طاعة، أو المطلوب طاعة. وانظر: "إعراب القرآن" للنحاس 3/ 144، "مشكل إعراب القرآن" لمكي 2/ 514 - 515، "البيان في غريب إعراب القرآن" للأنباري 2/ 198، "الإملاء" للعكبري 2/ 158 - 159، "الدر المصون" للسمين الحلبي 8/ 432.انظر: "الطبري" 18/ 157، الثعلبي 3/ 88 أ."تفسير مقاتل" 2/ 40 ب.في (ظ): (هذه)، وفي (ع): (بهذه)."معاني القرآن" للفراء 2/ 258 مع تقديم وتأخير وتصرف في بعض العبارات.(تولوا) ساقط من (ظ).ذكره القرطبي 12/ 296 عن ابن عباس وغيره.انظر: "تفسير مقاتل" 2/ 40 ب.رواه ابن أبي حاتم في "تفسيره" 7/ 59 ب عن السدي. وذكره السيوطيِ في "الدر المنثور" 6/ 214 ونسبه لابن أبي حاتم."الطبرى" 18/ 158.
