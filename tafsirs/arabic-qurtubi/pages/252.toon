quran[10]{c,v,t}:
  13,19,"<div class=ar lang=ar><p>قوله تعالى: <span class="qpc-hafs">﴿أَفَمَنْ يَعْلَمُ أَنَّمَا أُنْزِلَ إِلَيْكَ مِنْ رَبِّكَ الْحَقُّ﴾</span> الآية. قال ابن عباس {1}: نزلت في حمزة وأبي جهل.</p><p>وقوله تعالى: <span class="qpc-hafs">﴿كَمَنْ هُوَ أَعْمَى﴾</span> قال: يريد أبا جهل أعمى القلب، قال أهل المعاني: الجاهل بالدين ممثل بالأعمى؛ لأن العلم يُهْتَدَى به إلى طريق الرشد من الغي، كما يهتدى بالبصر إلى طريق النجاة من طريق الهلاك، وبالضد من هذا حال الجهل والعمى.</p><p>وقوله تعالى: <span class="qpc-hafs">﴿إِنَّمَا يَتَذَكَّرُ﴾</span> أي يتعظ ويطلب ذكر ما رغب فيه من الجنة فيطيع الله، وما أوعد به فيرتدع عن المعاصي <span class="qpc-hafs">﴿أُولُو الْأَلْبَابِ﴾</span> قال ابن عباس: يريد المهاجرين والأنصار، والآية نازلة في هؤلاء، وهي لكل من كان بهذه الصفة من العلم والجهل والتذكر، فهي بيان عما يستحق كل واحد من العالم والجاهل، والمحق والمبطل من صفة المدح بالبصيرة والذم بالعمى والحيرة.</p></div>",footnotes:1:"زاد المسير" 4/ 323، والقرطبي 9/ 307، و"البحر المحيط" 5/ 384.
  13,20,"<div class=ar lang=ar><p>قوله تعالى: <span class="qpc-hafs">﴿الَّذِينَ يُوفُونَ بِعَهْدِ اللَّهِ وَلَا يَنْقُضُونَ الْمِيثَاق﴾</span> قال ابن عباس {1}: يريد الذي عاهدهم عليه في صُلب آدم {2}.</p></div>",footnotes:1:"زاد المسير" 4/ 324، القرطبي 9/ 307.يعني ما ذكر في قوله تعالى: <span class="qpc-hafs">﴿وَإِذْ أَخَذَ رَبُّكَ مِنْ بَنِي آدَمَ مِنْ ظُهُورِهِمْ ذُرِّيَّتَهُمْ وَأَشْهَدَهُمْ عَلَى أَنْفُسِهِمْ أَلَسْتُ بِرَبِّكُمْ قَالُوا بَلَى﴾</span> [الأعراف: 172].
  13,21,"<div class=ar lang=ar><p>قوله تعالى: <span class="qpc-hafs">﴿وَالَّذِينَ يَصِلُونَ مَا أَمَرَ اللَّهُ بِهِ أَنْ يُوصَلَ﴾</span>، قال ابن عباس {1}: يريد الإيمان بالأنبياء، يعني: يصل بينهم بالإيمان بالجميع، كما قال في الخبر عن المؤمنين: <span class="qpc-hafs">﴿لَا نُفَرِّقُ بَيْنَ أَحَدٍ مِنْ رُسُلِهِ﴾</span> [البقرة: 285] وقال أكثر المفسرين {2}: يريد صلة الأرحام.</p></div>",footnotes:1:القرطبي 9/ 310، والثعلبي 7/ 132 أ، و"تفسير كتاب الله العزيز" 2/ 304، وأخرجه ابن أبي حاتم وأبو الشيخ عن سعيد بن جبير كما في "الدر" 4/ 106 - 107.انظر: الطبري 13/ 139، الثعلبي 7/ 132 أ، ابن كثير 2/ 560، "زاد المسير" 4/ 324، القرطبي 9/ 310، و"تفسير كتاب الله العزيز" 2/ 304.
  13,22,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَالَّذِينَ صَبَرُوا﴾</span> قال في رواية عطاء {1}: يريد على دين ربهم وما أمر به من طاعته ونهى عن معصيته، وهو قول ابن زيد {2} وأبي عمران الجوني {3}. <span class="qpc-hafs">﴿ابْتِغَاءَ وَجْهِ رَبِّهِمْ﴾</span> أي: طلب تعظيم الله.</p><p>وقوله تعالى: <span class="qpc-hafs">﴿وَيَدْرَءُونَ بِالْحَسَنَةِ السَّيِّئَةَ﴾</span> قال ابن عباس {4}: يدفعون بالعمل الصالح الشرَّ من العمل، قال ابن كيسان {5}: هو أنهم إذا أذنبوا تابوا، ليدفعوا بالتوبة مَعَرّة الذنب، روي أن النبي ﷺ قال لمعاذ بن جبل "إذا عملت سيئة فأعمل بجنبها حسنة تمحها" {6} فعلى هذا الحسنة والسيئة بينه وبين الله.</p><p>وقال ابن زيد {7}: لا يكافئون الشر بالشر، بل يحلمون عن السفيه، ويردون على من يسفه عليهم معروفًا من القول، وهذا قول قتادة {8} واختيار ابن قتيبة {9}، وعلى هذا الحسنة والسيئة بينه وبين الناس.</p><p>وقوله تعالى: <span class="qpc-hafs">﴿أُولَئِكَ لَهُمْ عُقْبَى الدَّارِ﴾</span> قال ابن عباس {10}: يريد عقباه الجنة، والعقبى {11} كالعاقبة، يجوز أن يكون مصدرًا، كالشورى والقربى واللقيا، توضع موضع المصدر، وقد يجيء مثل هذا أيضًا على (فَعْلى) كالنجوى والدعوى والطغوى، وعلى (فِعْلى) كالذكرى والضيزى، ويجوز أن يكون اسمًا، وهو هاهنا مصدر مضاف إلى الفاعل، والمعنى: أولئك لهم أن تعقب أعمالهم الحسنة الجنة، أي تصير الجنة آخر أمرهم، والمراد بالدار الجنة، يعرف ذلك بإطلاقها، حيث ذكرت عقيب الأعمال الصالحة.</p></div>",footnotes:1:"تنوير المقباس" ص 157، القرطبي 9/ 310، الثعلبي 7/ 132 ب.الطبري 13/ 140، الثعلبي 7/ 132 ب.الثعلبي 7/ 132 ب، القرطبي 9/ 310."زاد المسير" 4/ 324، القرطبي 9/ 311، الثعلبي 7/ 133 أ.الثعلبي 7/ 132 ب، و"زاد المسير" 4/ 325.أخرجه أحمد في "المسند" 5/ 169، إلا أنه قال: "فأتبعها" وفي 5/ 177، وقال: "فأعمل حسنة" من حديث أبي ذر، ونحوه في الترمذي (1987) كتاب: البر والصلة، باب: ما جاء في معاشرة الناس، وحسنه الألباني في صحيح سنن الترمذي. وأخرجه سعيد بن منصور 3/ 64، وأبو نعيم في "حلية الأولياء" 4/ 217، 218.الثعلبي 7/ 132 ب، الطبري 13/ 141، القرطبي 9/ 311.الثعلبي 7/ 132 ب."مشكل القرآن وغريبه" ص 233، والثعلبي 7/ 132 ب، و"زاد المسير" 4/ 325."زاد المسير" 4/ 325، و"تفسير كتاب الله العزيز" 2/ 305."اللسان" (عقب) 5/ 3022، و"تهذيب اللغة" (عقب) 3/ 2507.
  13,23,"<div class=ar lang=ar><p>قوله تعالى: <span class="qpc-hafs">﴿جَنَّاتُ عَدْنٍ يَدْخُلُونَهَا﴾</span> قال الزجاج {1}: جنات بدل من عقبى.</p><p>قال ابن عباس {2}: هي وسط الجنة وقصبتها، مساندة بعرش الرحمن، غَرَسها الرحمنُ تبارك وتعالى بيده، والكلام في جنات عدن قد ذكرناه مستقصى عند قوله: <span class="qpc-hafs">﴿وَمَسَاكِنَ طَيِّبَةً فِي جَنَّاتِ عَدْنٍ﴾</span> [التوبة: 72]، وذكرنا هناك مذهب المفسرين ومذهب أهل اللغة.</p><p>وقوله تعالى: <span class="qpc-hafs">﴿وَمَنْ صَلَحَ﴾</span> موضع (من) رفع عطف على الواو في <span class="qpc-hafs">﴿يَدْخُلُونَهَا﴾</span>، قال أبو إسحاق {1}: وجائز أن يكون نصبًا، كما تقول قد دخلوا وزيدًا، أي مع زيد.</p><p>قال ابن عباس {4}: <span class="qpc-hafs">﴿وَمَنْ صَلَحَ مِنْ آبَائِهِمْ﴾</span> يريد من صَدَّق بما صدقوا به، وإن لم يعمل مثل أعمالهم.</p><p>وقال أبو إسحاق {1}: اعلم أن الأسباب لا تنفع بغير أعمال صالحة، فعلى قول ابن عباس معنى (صلح): صدق وآمن ووحد، وعلى ما ذكر أبو إسحاق معناه: صلح في عمله.</p><p>والصحيح ما قال ابن عباس؛ لأن الله تعالى جعل من ثواب المطيع سروره بما يراه في أهله، حيث بشره بدخول الجنة مع هؤلاء، فدل أنهم يدخلونها كرامة للمطيع، ولا فائدة في التبشير والوعد به، إذ كل مصلح في عمله قد وعد دخول الجنة {6}.</p><p>وقوله تعالى: <span class="qpc-hafs">﴿وَالْمَلَائِكَةُ يَدْخُلُونَ عَلَيْهِمْ مِنْ كُلِّ بَابٍ﴾</span> قال ابن عباس {7}: يريد بالتحية من الله والتحفة والهدايا.</p></div>",footnotes:1:"معاني القرآن وإعرابه" 3/ 147.القرطبي 9/ 311 نحوه."معاني القرآن وإعرابه" 3/ 147.القرطبي 9/ 312، و"البحر المحيط" 5/ 387، و"تفسير كتاب الله العزيز" 2/ 305."معاني القرآن وإعرابه" 3/ 147.قلت: ويشهد لهذا قوله تعالى: <span class="qpc-hafs">﴿وَالَّذِينَ آمَنُوا وَاتَّبَعَتْهُمْ ذُرِّيَّتُهُمْ بِإِيمَانٍ أَلْحَقْنَا بِهِمْ ذُرِّيَّتَهُمْ وَمَا أَلَتْنَاهُمْ مِنْ عَمَلِهِمْ مِنْ شَيْءٍ﴾</span> [الطور: 21]</p><p>وأخرج الطبري 13/ 141، وابن أبي شيبة وابن المنذر وابن أبي حاتم وأبو الشيخ عن مجاهد قوله: <span class="qpc-hafs">﴿وَمَنْ صَلَحَ مِنْ آبَائِهِمْ﴾</span> من آمن في الدنيا.</p><p>وأخرج ابن أبي حاتم وأبو الشيخ عن سعيد بن جبير قال: يدخل الرجل الجنة فيقول: أين أمي؟ أين ولدي؟ أين زوجتي؟ .. فيقال: لم يعملوا مثل عملك، فيقول: كنت أعمل لي ولهم، ثم قرأ <span class="qpc-hafs">﴿جَنَّاتُ عَدْنٍ يَدْخُلُونَهَا وَمَنْ صَلَحَ﴾</span> يعني من آمن بالتوحيد بعد هؤلاء <span class="qpc-hafs">﴿مِنْ آبَائِهِمْ وَأَزْوَاجِهِمْ وَذُرِّيَّاتِهِمْ﴾</span> يدخلون معهم .. "الدر المنثور" 2/ 158."زاد المسير" 4/ 325، والقرطبي 9/ 312، و"البحر المحيط" 5/ 387، و"تفسير كتاب الله العزيز" 2/ 306.
  13,24,"<div class=ar lang=ar><p>قوله تعالى: <span class="qpc-hafs">﴿سَلَامٌ عَلَيْكُمْ﴾</span> قال أبو إسحاق {1}: المعنى يدخلون عليهم من كل باب يقولون: سلام عليكم، فأضمر القول هاهنا، لأن في الكلام دليلًا عليه.</p><p>وقوله تعالى: <span class="qpc-hafs">﴿بِمَا صَبَرْتُمْ﴾</span> قال ابن عباس {2}: يريد في دار الدنيا، قال النحويون {3}: الباء في (بما) تتعلق بمعنى سلام؛ لأنه قد دل علي السلامة لكم بما صبرتم. وقال صاحب النظم: السلام قول، ولا يحتمل أن يكون القول ثوابًا للصبر الذي هو فعل، فدل هذا على أن المعنى في قوله: <span class="qpc-hafs">﴿سَلَامٌ عَلَيْكُمْ﴾</span> دعاء من الملائكة لهم، على معنى: سملكم الله بما صبرتم، أو خبر منهم، أي: أن الله سلمكم من أهوال هذا اليوم من شره، وأدخلكم الجنة بصبركم في الدنيا، ويجوز أن يتعلق بمحذوف على تقدير: الكرامة لكم بما صبرتم و (ما) هاهنا للمصدر، كأنه قبل بصبركم.</p><p>وقوله تعالى: <span class="qpc-hafs">﴿فَنِعْمَ عُقْبَى الدَّارِ﴾</span> الدار هاهنا أيضًا يجب أن يكون مصدرًا؛ لأنه لو كان اسمًا، وأضيف إلى الدار صار لها. وليس المراد ذكر عاقبة (الدار، إنما المراد ذكر عاقبة) {4} أهل الجنة ومدح عاقبتهم، والمقصود بالمدح محذوف على تقدير: نعم العقبى عقبى الدار، كقوله تعالى: <span class="qpc-hafs">﴿نِعْمَ الْعَبْدُ إِنَّهُ أَوَّابٌ﴾</span> [ص: 44] ولم يذكر أيوب لتقدم ذكره، ومثله قوله: <span class="qpc-hafs">﴿بِئْسَ مَثَلُ الْقَوْمِ الَّذِينَ كَذَّبُوا﴾</span> [الجمعة: 5] هذا كله إذا كان المراد بالدار الجنة. وقال صاحب النظم: (نعم) يقتضي اسمًا وخبرًا، والمعنى إن شاء الله: فنعم عقبى الدار ما أنتم فيه، أي هذا نعم عاقبة الدار التي كنتم فيها، عملتم فيها ما أعقبكم هذا الذي أنتم فيه، فعلى هذا، العقبى اسم، والدار هي الدنيا {5}.</p></div>",footnotes:1:"معاني القرآن وإعرابه" 3/ 147."تنوير المقباس" ص 157."التبيان في إعراب القرآن" للعكبري 2/ 757.ما بين القوسين مكرر في (أ)، (ج).القرطبي 9/ 313.
  13,25,"<div class=ar lang=ar><p>قوله تعالى: <span class="qpc-hafs">﴿وَالَّذِينَ يَنْقُضُونَ عَهْدَ اللَّهِ مِنْ بَعْدِ مِيثَاقِهِ﴾</span> الآية مفسرة في سورة البقرة بتمامها {1}.</p></div>",footnotes:1:عند قوله تعالى: <span class="qpc-hafs">﴿وَالَّذِينَ يَنْقُضُونَ عَهْدَ اللَّهِ مِنْ بَعْدِ مِيثَاقِهِ﴾</span> [آية: 27].
  13,26,"<div class=ar lang=ar><p>قوله تعالى: <span class="qpc-hafs">﴿اللَّهُ يَبْسُطُ الرِّزْقَ لِمَنْ يَشَاءُ وَيَقْدِرُ﴾</span> معنى القدر في اللغة {1}: قَطْع الشيء على مساواة غيره من غير زيادة ولا نقصان، والمقدار: المثال الذي يعمل عليه غيره في مساواته به، وقال المفسرون {2}: في معنى يقدر هاهنا: يضيق ويقتر، ومثله قوله: <span class="qpc-hafs">﴿وَمَنْ قُدِرَ عَلَيْهِ رِزْقُهُ﴾</span> [الطلاق: 3] أي: ضيق، وقوله: <span class="qpc-hafs">﴿فَقَدَرَ عَلَيْهِ رِزْقَهُ﴾</span> [الفجر: 16] بمعنى يضيق، وهو أن يعطيه على قدركفايته، لا يفضل عنه شيء من رزقه على صدر البسط.</p><p>وقوله تعالى: <span class="qpc-hafs">﴿وَفَرِحُوا بِالْحَيَاةِ الدُّنْيَا﴾</span> قال ابن عباس {3} والمفسرون: يريد مشركي مكة، فرحوا بما نالوا من الدنيا وأشروا وبطروا، فطغوا وكذبوا الرسول، ولم يشكروا ما بسط الله عليهم من الدنيا.</p><p>ثم قال: <span class="qpc-hafs">﴿وَمَا الْحَيَاةُ الدُّنْيَا فِي الْآخِرَةِ إِلَّا مَتَاعٌ﴾</span> أي: في حياة الآخرة، يعني بالقياس إليها، قال ابن عباس {4}: يريد ما في الدنيا يذهب ويبيد وهو قليل، وقال مجاهد {5}: أي: قليل ذاهب.</p><p>وقال الكلبي {6}: كالشيء الذي يتمتع به ثم يفنى ويذهب، مثل القصعة والقِدْر والقدح ينتفع بها ثم يذهب.</p></div>",footnotes:1:"تهذيب اللغة" (قدر) 3/ 2897 - 2898 و"اللسان" (قدر) 6/ 3546.الثعلبي 7/ 134 أ، والطبري 13/ 143 - 144، و"تفسير كتاب الله العزيز" 2/ 306."زاد المسير" 4/ 326، القرطبي 9/ 314، و"تفسير كتاب الله العزيز" 2/ 306.نقل في "البحر المحيط" 5/ 388، والقرطبي 9/ 314 عن ابن عباس أنه قال: زاد كزاد الراعي.الطبري 13/ 144، وابن أبي شيبة وابن المنذر وابن أبي حاتم وأبو الشيخ كما في "الدر" 4/ 110، "البحر المحيط" 5/ 388، القرطبي 9/ 314، الثعلبي 7/ 134 أ."تنوير المقباس" ص 158، الثعلبي 7/ 134 أ.
  13,27,"<div class=ar lang=ar><p>قوله تعالى: <span class="qpc-hafs">﴿وَيَقُولُ الَّذِينَ كَفَرُوا لَوْلَا أُنْزِلَ عَلَيْهِ آيَةٌ مِنْ رَبِّهِ﴾</span> الآية، قال المفسرون {1}: نزلت في أهل مكة حين طالبوا رسول الله ﷺ بالآيات، قال أهل المعاني: إنهم لم يستدلوا فيُعملوا مدلول الآيات التي بها، فلم يعتدوا بها، وقالوا هذا القول جهلًا منهم.</p><p>وقوله تعالى: <span class="qpc-hafs">﴿قُلْ إِنَّ اللَّهَ يُضِلُّ مَنْ يَشَاءُ﴾</span> قال ابن عباس {2}: يريد عن دينه، يعني كما أضلكم بعد ما رأوا من الآيات وحرمكم الاستدلال بها، <span class="qpc-hafs">﴿وَيَهْدِي إِلَيْهِ مَنْ أَنَابَ﴾</span> أي رجع إلى الحق، قاله الزجاج {3}، وإنما يرجع إلى الحق من يشاء الله، فكأنه قال: ويهدي إليه من يشاء، كما قال: <span class="qpc-hafs">﴿وَيَهْدِي مَنْ يَشَاءُ﴾</span> {4} في مواضع.</p></div>",footnotes:1:الطبري 13/ 144، والثعلبي 7/ 134 أ، و"زاد المسير" 4/ 326، والقرطبي 9/ 315، و"البحر المحيط" 5/ 388."تنوير المقباس" 158، و"زاد المسير" 4/ 326، والقرطبي 9/ 315."معاني القرآن وإعرابه" 3/ 147.يونس: 25، إبراهيم: 4، النحل: 93، فاطر: 8، المدثر: 31.
  13,28,"<div class=ar lang=ar><p>قوله تعالى: <span class="qpc-hafs">﴿الَّذِينَ آمَنُوا﴾</span> قال الزجاج {1}: (الذين) في موضع نصب ردًّا على (من)، المعنى: يهدي الله الذين آمنوا، <span class="qpc-hafs">﴿وَتَطْمَئِنُّ قُلُوبُهُمْ بِذِكْرِ اللَّهِ﴾</span> قال ابن عباس {2}: يريد إذا سمعوا القرآن خشعت قلوبهم واطمأنت، وإذا سمعوا ذكر الله أحبوه واستأنسوا به، ونحو هذا قال مقاتل {3}، وقال أبو إسحاق {4}: أي إذا ذكروا الله وحده آمنوا به غير شاكين، بخلاف من وصف بقوله: <span class="qpc-hafs">﴿وَإِذَا ذُكِرَ اللَّهُ وَحْدَهُ اشْمَأَزَّتْ قُلُوبُ الَّذِينَ لَا يُؤْمِنُونَ بِالْآخِرَةِ﴾</span> [الزمر: 45].</p><p>وقوله تعالى: <span class="qpc-hafs">﴿أَلَا بِذِكْرِ اللَّهِ تَطْمَئِنُّ الْقُلُوبُ﴾</span> قال ابن عباس {5} وغيره: يريد قلوب المؤمنين، قال الزجاج {6}: لأن الكافر غير مطمئن القلب، وذكرنا الجمع بين هذه الآية وبين قوله: <span class="qpc-hafs">﴿إِنَّمَا الْمُؤْمِنُونَ الَّذِينَ إِذَا ذُكِرَ اللَّهُ وَجِلَتْ قُلُوبُهُمْ﴾</span> في سورة الأنفال [2].</p></div>",footnotes:1:"معاني القرآن وإعرابه" 3/ 147 وفيه: يهدي إليه."تنوير المقباس" ص 158، بنحوه."تفسير مقاتل" 191 أ."معاني القرآن وإعرابه" 3/ 147. بنحوه."زاد المسير" 4/ 327، القرطبي 9/ 315."معاني القرآن وإعرابه" 3/ 148.