quran[12]{c,v,t}:
  19,65,""
  19,66,"<div class=ar lang=ar><p>وَتَقَدَّمَ اخْتِلافُهم في <span class="qpc-hafs">﴿أئِذا ما مِتُّ﴾</span> في بابِ الهَمْزَتَيْنِ مِن كَلِمَةٍ.</p></div>"
  19,67,"<div class=ar lang=ar><p>(واخْتَلَفُوا) فِي: <span class="qpc-hafs">﴿أوَلا يَذْكُرُ الإنْسانُ﴾</span> فَقَرَأ نافِعٌ وابْنُ عامِرٍ وعاصِمٌ بِتَخْفِيفِ الذالِ والكافِ مَعَ ضَمِّ الكافِ، وقَرَأ الباقُونَ بِتَشْدِيدِهِما وفَتْحِ الكافِ.</p></div>"
  19,68,"<div class=ar lang=ar><p>[انظر الآية ٨]</p></div>"
  19,69,""
  19,70,"<div class=ar lang=ar><p>[انظر الآية ٨]</p></div>"
  19,71,""
  19,72,"<div class=ar lang=ar><p>وَتَقَدَّمَ <span class="qpc-hafs">﴿نُنَجِّي الَّذِينَ﴾</span> في الأنْعامِ لِيَعْقُوبَ والكِسائِيِّ.</p></div>"
  19,73,"<div class=ar lang=ar><p>(واخْتُلِفَ) في <span class="qpc-hafs">﴿خَيْرٌ مَقامًا﴾</span> فَقَرَأ ابْنُ كَثِيرٍ بِضَمِّ (p-٣١٩)المِيمِ، وقَرَأ الباقُونَ بِفَتْحِها.</p></div>"
  19,74,"<div class=ar lang=ar><p>وَتَقَدَّمَ <span class="qpc-hafs">﴿وَرِئْيًا﴾</span> في بابِ الهَمْزِ المُفْرَدِ.</p></div>"
  19,75,""
  19,76,""