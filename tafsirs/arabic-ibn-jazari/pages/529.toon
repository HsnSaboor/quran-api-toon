quran[21]{c,v,t}:
54,7," (واخْتَلَفُوا) فِي: <q>﴿خُشَّعًا أبْصارُهُمْ﴾</q> فَقَرَأ البَصْرِيّانِ، وحَمْزَةُ، والكِسائِيُّ، وخَلَفٌ " خاشِعًا " بِفَتْحِ الخاءِ وألِفٍ بَعْدَها وكَسْرِ الشِينِ مُخَفَّفَةً، وقَرَأ الباقُونَ بِضَمِّ الخاءِ وفَتْحِ الشِينِ مُشَدَّدَةً مِن غَيْرِ ألِفٍ وَتَقَدَّمَ <q>﴿فَتَحْنا﴾</q> [الأنعام: ٤٤] في الأنْعامِ. "
  54,8,""
  54,9,""
  54,10,""
  54,11,""
54,12," وَتَقَدَّمَ <q>﴿عُيُونًا﴾</q> في البَقَرَةِ. "
  54,13,""
  54,14,""
  54,15,""
  54,16,""
  54,17,""
  54,18,""
  54,19,""
  54,20,""
  54,21,""
  54,22,""
  54,23,""
  54,24,""
54,25," وَتَقَدَّمَ <q>﴿أؤُلْقِيَ﴾</q> في الهَمْزَتَيْنِ مِن كَلِمَةٍ. "
54,26," (واخْتَلَفُوا) فِي: <q>﴿سَيَعْلَمُونَ غَدًا﴾</q> فَقَرَأ ابْنُ عامِرٍ، وحَمْزَةُ بِالخِطابِ، وقَرَأ الباقُونَ بِالغَيْبِ، وانْفَرَدَ الكارَزِينِيُّ عَنْ رَوْحٍ بِالتَخْيِيرِ فِيهِ، ولَمْ يَذْكُرْهُ غَيْرُهُ. "
  54,27,""
