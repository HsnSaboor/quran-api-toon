quran[29]{c,v,t}:
  91,1,"<div class=ar lang=ar><p>وَتَقَدَّمَ رُءُوسُ آيِ <span class="qpc-hafs">﴿والشَمْسِ وضُحاها﴾</span> في الإمالَةِ.</p></div>"
  91,2,"<div class=ar lang=ar></div>"
  91,3,"<div class=ar lang=ar></div>"
  91,4,"<div class=ar lang=ar></div>"
  91,5,"<div class=ar lang=ar></div>"
