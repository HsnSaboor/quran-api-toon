quran[18]{c,v,t}:
  73,20,"<div class=ar lang=ar><p>وَتَقَدَّمَ <span class="qpc-hafs">﴿ثُلُثَيِ اللَيْلِ﴾</span> لِهِشامٍ في البَقَرَةِ عِنْدَ <span class="qpc-hafs">﴿هُزُوًا﴾</span> [البقرة: ٦٧].</p><p>(واخْتَلَفُوا) فِي: <span class="qpc-hafs">﴿وَنِصْفَهُ وثُلُثَهُ﴾</span> فَقَرَأ ابْنُ كَثِيرٍ، والكُوفِيُّونَ بِنَصْبِ الفاءِ والثاءِ وضَمِّ الهاءَيْنِ، وقَرَأ الباقُونَ بِخَفْضِ الفاءِ والثاءِ وكَسْرِ الهاءَيْنِ.</p></div>"
  74,1,"<div class=ar lang=ar></div>"
  74,2,"<div class=ar lang=ar></div>"
  74,3,"<div class=ar lang=ar></div>"
  74,4,"<div class=ar lang=ar></div>"
  74,5,"<div class=ar lang=ar><p>(واخْتَلَفُوا) فِي: <span class="qpc-hafs">﴿والرُجْزَ فاهْجُرْ﴾</span> فَقَرَأ أبُو جَعْفَرٍ ويَعْقُوبُ، وحَفْصٌ بِضَمِّ راءِ <span class="qpc-hafs">﴿الرُجْزَ﴾</span>، وقَرَأ الباقُونَ بِكَسْرِها</p></div>"
