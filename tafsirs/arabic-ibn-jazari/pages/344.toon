tafsir[15]{c,v,t}:
  23,28,""
23,29," (واخْتَلَفُوا) فِي: <q>﴿أنْزِلْنِي مُنْزَلًا﴾</q>، فَرَوى أبُو بَكْرٍ بِفَتْحِ المِيمِ وكَسْرِ الزايِ، وقَرَأ الباقُونَ بِضَمِّ المِيمِ وفَتْحِ الزايِ. "
  23,30,""
  23,31,""
23,32," وَتَقَدَّمَ <q>﴿أنِ اعْبُدُوا اللَهَ﴾</q> في البَقَرَةِ. "
  23,33,""
  23,34,""
  23,35,""
23,36," (واخْتَلَفُوا) فِي: <q>﴿هَيْهاتَ هَيْهاتَ﴾</q> فَقَرَأ أبُو جَعْفَرٍ بِكَسْرِ التاءِ مِنهُما، وقَرَأ الباقُونَ بِفَتْحِها فِيهِما وَتَقَدَّمَ مَذْهَبُهم في الوَقْفِ عَلَيْهِما في بابِ الوَقْفِ عَلى المَرْسُومِ. "
  23,37,""
  23,38,""
  23,39,""
  23,40,""
  23,41,""
  23,42,""
