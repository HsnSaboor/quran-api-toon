quran[4]{c,v,t}:
  5,42,""
  5,43,""
  5,44,""
  5,45,"<div class=ar lang=ar><p>(واخْتَلَفُوا) فِي: (<span class="qpc-hafs">﴿العَيْنِ﴾</span> [آل عمران: ١٣] <span class="qpc-hafs">﴿والأنْفَ﴾</span> <span class="qpc-hafs">﴿والأُذُنَ﴾</span> <span class="qpc-hafs">﴿والسِنَّ﴾</span> <span class="qpc-hafs">﴿والجُرُوحَ﴾</span>) فَقَرَأ الكِسائِيُّ بِالرَفْعِ في الخَمْسَةِ، وافَقَهُ في " الجُرُوحِ " خاصَّةً ابْنُ كَثِيرٍ وأبُو عَمْرٍو وأبُو جَعْفَرٍ وابْنُ عامِرٍ، وقَرَأ الباقُونَ بِالنَصْبِ.</p></div>"