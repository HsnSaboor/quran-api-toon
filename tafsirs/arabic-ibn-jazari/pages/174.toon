quran[9]{c,v,t}:
  7,179,""
  7,180,"<div class=ar lang=ar><p>(واخْتَلَفُوا) فِي: <span class="qpc-hafs">﴿يُلْحِدُونَ﴾</span> هُنا والنَحْلِ وحم السَجْدَةِ فَقَرَأ حَمْزَةُ بِفَتْحِ الياءِ وكَسْرِ الحاءِ في ثَلاثِهِنَّ.</p><p>وَتَقَدَّمَ الخِلافُ عَنْ قالُونَ في <span class="qpc-hafs">﴿إنْ أنا إلّا﴾</span> [الأعراف: ١٨٨] عِنْدَ قَوْلِهِ <span class="qpc-hafs">﴿أنا أُحْيِي﴾</span> [البقرة: ٢٥٨] مِنَ البَقَرَةِ.</p></div>"
  7,181,""
  7,182,""
  7,183,""
  7,184,""
  7,185,""
  7,186,"<div class=ar lang=ar><p>(واخْتَلَفُوا) فِي: <span class="qpc-hafs">﴿وَيَذَرُهُمْ﴾</span> فَقَرَأ المَدَنِيّانِ، وابْنُ كَثِيرٍ وأبُو عَمْرٍو وابْنُ عامِرٍ بِالنُونِ، وقَرَأ الباقُونَ بِالياءِ، وقَرَأ حَمْزَةُ والكِسائِيُّ وخَلَفٌ بِجَزْمِ الراءِ، وقَرَأ الباقُونَ بِرَفْعِها.</p></div>"
  7,187,""