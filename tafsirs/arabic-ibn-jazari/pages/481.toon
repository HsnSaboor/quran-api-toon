quran[8]{c,v,t}:
  41,39,"<div class=ar lang=ar></div>"
  41,40,"<div class=ar lang=ar><p>وَتَقَدَّمَ <span class="qpc-hafs">﴿يُلْحِدُونَ﴾</span> في الأعْرافِ.</p></div>"
  41,41,"<div class=ar lang=ar></div>"
  41,42,"<div class=ar lang=ar></div>"
  41,43,"<div class=ar lang=ar></div>"
  41,44,"<div class=ar lang=ar><p>وَتَقَدَّمَ <span class="qpc-hafs">﴿أأعْجَمِيٌّ﴾</span> في الهَمْزَتَيْنِ مِن كَلِمَةٍ.</p></div>"
  41,45,"<div class=ar lang=ar></div>"
  41,46,"<div class=ar lang=ar></div>"