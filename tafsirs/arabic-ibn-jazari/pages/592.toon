tafsir[30]{c,v,t}:
87,16," (واخْتَلَفُوا) فِي: <q>﴿بَلْ تُؤْثِرُونَ﴾</q> فَقَرَأ أبُو عَمْرٍو بِالغَيْبِ، وانْفَرَدَ ابْنُ مِهْرانَ بِذَلِكَ عَنْ رَوْحٍ في كُلِّ كُتُبِهِ وبِالخِلافِ عَنْ رُوَيْسٍ في بَعْضِها، وقَرَأ الباقُونَ بِالخِطابِ، وهم في إدْغامِ اللامِ عَلى أُصُولِهِمْ. "
  87,17,""
  87,18,""
  87,19,""
  88,1,""
  88,2,""
  88,3,""
88,4," (واخْتَلَفُوا) فِي: <q>﴿تَصْلى نارًا﴾</q> فَقَرَأ البَصْرِيّانِ، وأبُو بَكْرٍ بِضَمِّ التاءِ وقَرَأ الباقُونَ بِفَتْحِها "
88,5," وَتَقَدَّمَ <q>﴿آنِيَةٍ﴾</q> لِهِشامٍ في الإمالَةِ. "
  88,6,""
  88,7,""
  88,8,""
  88,9,""
  88,10,""
88,11," (واخْتَلَفُوا) فِي: <q>﴿لا تَسْمَعُ فِيها لاغِيَةً﴾</q> فَقَرَأ ابْنُ كَثِيرٍ وأبُو عَمْرٍو ورُوَيْسٌ <q>﴿لا يُسْمَعُ﴾</q> بِياءٍ مَضْمُومَةٍ عَلى التَذْكِيرِ لاغِيَةٌ بِالرَفْعِ، وقَرَأ نافِعٌ كَذَلِكَ إلّا أنَّهُ بِالتاءِ عَلى التَأْنِيثِ، وقَرَأ الباقُونَ بِالتاءِ مَفْتُوحَةً لاغِيَةً بِالنَصْبِ "
  88,12,""
  88,13,""
  88,14,""
  88,15,""
  88,16,""
  88,17,""
  88,18,""
  88,19,""
  88,20,""
  88,21,""
88,22," وَتَقَدَّمَ <q>﴿بِمُسَيْطِرٍ﴾</q> في الطُورِ. "
  88,23,""
  88,24,""
88,25," (واخْتَلَفُوا) فِي: <q>﴿إيابَهُمْ﴾</q> فَقَرَأ أبُو جَعْفَرٍ بِتَشْدِيدِ الياءِ، وقَرَأ الباقُونَ بِتَخْفِيفِها. "
  88,26,""
