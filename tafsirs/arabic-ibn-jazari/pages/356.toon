quran[10]{c,v,t}:
  24,44,""
  24,45,""
  24,46,"<div class=ar lang=ar><p>وَتَقَدَّمَ اخْتِلافُهم في <span class="qpc-hafs">﴿مُبَيِّناتٍ﴾</span> كِلاهُما في سُورَةِ النِساءِ.</p></div>"
  24,47,""
  24,48,"<div class=ar lang=ar><p>وَتَقَدَّمَ <span class="qpc-hafs">﴿لِيَحْكُمَ﴾</span> المَوْضِعَيْنِ لِأبِي جَعْفَرٍ في البَقَرَةِ</p><p>وَتَقَدَّمَ اخْتِلافُهم في يَتَّقْهِ مِن بابِ هاءِ الكِنايَةِ.</p></div>"
  24,49,""
  24,50,""
