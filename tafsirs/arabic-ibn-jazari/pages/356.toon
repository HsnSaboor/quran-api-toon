tafsir[10]{c,v,t}:
  24,44,""
  24,45,""
24,46," وَتَقَدَّمَ اخْتِلافُهم في <q>﴿مُبَيِّناتٍ﴾</q> كِلاهُما في سُورَةِ النِساءِ. "
  24,47,""
24,48," وَتَقَدَّمَ <q>﴿لِيَحْكُمَ﴾</q> المَوْضِعَيْنِ لِأبِي جَعْفَرٍ في البَقَرَةِ وَتَقَدَّمَ اخْتِلافُهم في يَتَّقْهِ مِن بابِ هاءِ الكِنايَةِ. "
  24,49,""
  24,50,""
  24,51,""
  24,52,""
  24,53,""
