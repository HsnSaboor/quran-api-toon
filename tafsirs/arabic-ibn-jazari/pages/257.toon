quran[8]{c,v,t}:
  14,11,"<div class=ar lang=ar></div>"
  14,12,"<div class=ar lang=ar><p>وَتَقَدَّمَ إسْكانُ أبِي عَمْرٍو <span class="qpc-hafs">﴿سُبُلَنا﴾</span> في البَقَرَةِ.</p></div>"
  14,13,"<div class=ar lang=ar></div>"
  14,14,"<div class=ar lang=ar><p>وَتَقَدَّمَ إمالَةُ حَمْزَةَ <span class="qpc-hafs">﴿خافَ﴾</span></p></div>"
  14,15,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَخابَ﴾</span> في بابِها</p><p>وَتَقَدَّمَ <span class="qpc-hafs">﴿الرِياحَ﴾</span> [الحجر: ٢٢] لِلْمَدَنِيَّيْنِ في البَقَرَةِ.</p><p>(واخْتَلَفُوا) فِي: <span class="qpc-hafs">﴿خَلْقِ السَماواتِ والأرْضِ﴾</span> [البقرة: ١٦٤] هُنا و<span class="qpc-hafs">﴿خَلَقَ كُلَّ دابَّةٍ﴾</span> [النور: ٤٥] في النُورِ فَقَرَأ حَمْزَةُ والكِسائِيُّ وخَلَفٌ، (خالِقُ) فِيها بِألِفٍ وكَسْرِ اللامِ ورَفْعِ القافِ وخَفْضِ <span class="qpc-hafs">﴿السَماواتِ والأرْضِ﴾</span> [البقرة: ٣٣]، و(كُلِّ) بَعْدَهُما، وقَرَأ الباقُونَ بِفَتْحِ اللامِ والقافِ مِن غَيْرِ ألِفٍ، ونَصْبِ " السَماواتِ " بِالكَسْرِ، و" الأرْضَ " و" كُلَّ " بِالفَتْحِ.</p></div>"
  14,16,"<div class=ar lang=ar></div>"
  14,17,"<div class=ar lang=ar></div>"
  14,18,"<div class=ar lang=ar></div>"