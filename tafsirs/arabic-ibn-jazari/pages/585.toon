quran[42]{c,v,t}:
  80,1,"<div class=ar lang=ar><p>[انظر الآية ١٥ من النازعات]</p></div>"
  80,2,"<div class=ar lang=ar><p>[انظر الآية ١٥ من النازعات]</p></div>"
  80,3,"<div class=ar lang=ar><p>[انظر الآية ١٥ من النازعات]</p></div>"
  80,4,"<div class=ar lang=ar><p>[انظر الآية ١٥ من النازعات]</p><p>(واخْتَلَفُوا) فِي: <span class="qpc-hafs">﴿فَتَنْفَعَهُ﴾</span> فَقَرَأ عاصِمٌ بِنَصْبِ العَيْنِ، وقَرَأ الباقُونَ بِرَفْعِها.</p></div>"
  80,5,"<div class=ar lang=ar><p>[انظر الآية ١٥ من النازعات]</p></div>"
  80,6,"<div class=ar lang=ar><p>[انظر الآية ١٥ من النازعات]</p><p>(واخْتَلَفُوا) فِي: <span class="qpc-hafs">﴿لَهُ تَصَدّى﴾</span> فَقَرَأ المَدَنِيّانِ، وابْنُ كَثِيرٍ بِتَشْدِيدِ الصادِ، وقَرَأ الباقُونَ بِتَخْفِيفِها</p></div>"
  80,7,"<div class=ar lang=ar><p>[انظر الآية ١٥ من النازعات]</p></div>"
  80,8,"<div class=ar lang=ar><p>[انظر الآية ١٥ من النازعات]</p></div>"
  80,9,"<div class=ar lang=ar><p>[انظر الآية ١٥ من النازعات]</p></div>"
  80,10,"<div class=ar lang=ar><p>[انظر الآية ١٥ من النازعات]</p><p>وَتَقَدَّمَ <span class="qpc-hafs">﴿عَنْهُ تَّلَهّى﴾</span> في تاءاتِ البَزِّيِّ مِنَ البَقَرَةِ.</p></div>"
  80,11,"<div class=ar lang=ar></div>"
  80,12,"<div class=ar lang=ar></div>"
