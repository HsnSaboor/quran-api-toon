quran[27]{c,v,t}:
  83,35,"<div class=ar lang=ar></div>"
  83,36,"<div class=ar lang=ar><p>وَتَقَدَّمَ <span class="qpc-hafs">﴿هَلْ ثُوِّبَ﴾</span> في بابِهِ.</p></div>"
  84,1,"<div class=ar lang=ar></div>"
  84,2,"<div class=ar lang=ar></div>"
  84,3,"<div class=ar lang=ar></div>"
  84,4,"<div class=ar lang=ar></div>"
  84,5,"<div class=ar lang=ar></div>"
  84,6,"<div class=ar lang=ar></div>"
  84,7,"<div class=ar lang=ar></div>"
  84,8,"<div class=ar lang=ar></div>"
  84,9,"<div class=ar lang=ar></div>"
  84,10,"<div class=ar lang=ar></div>"
  84,11,"<div class=ar lang=ar></div>"
  84,12,"<div class=ar lang=ar><p>(واخْتَلَفُوا) فِي: <span class="qpc-hafs">﴿وَيَصْلى سَعِيرًا﴾</span> فَقَرَأ نافِعٌ، وابْنُ كَثِيرٍ، وابْنُ عامِرٍ، والكِسائِيُّ بِضَمِّ الياءِ وفَتْحِ الصادِ وتَشْدِيدِ اللامِ، وقَرَأ الباقُونَ بِفَتْحِ الياءِ، وإسْكانِ الصادِ وتَخْفِيفِ اللامِ.</p></div>"
  84,13,"<div class=ar lang=ar></div>"
  84,14,"<div class=ar lang=ar></div>"
  84,15,"<div class=ar lang=ar></div>"
  84,16,"<div class=ar lang=ar></div>"
  84,17,"<div class=ar lang=ar></div>"
  84,18,"<div class=ar lang=ar></div>"
  84,19,"<div class=ar lang=ar><p>(واخْتَلَفُوا) فِي: <span class="qpc-hafs">﴿لَتَرْكَبُنَّ﴾</span> فَقَرَأ ابْنُ كَثِيرٍ، وحَمْزَةُ، والكِسائِيُّ، وخَلَفٌ بِفَتْحِ الباءِ، وقَرَأ الباقُونَ بِضَمِّها</p></div>"
  84,20,"<div class=ar lang=ar></div>"
  84,21,"<div class=ar lang=ar><p>وَتَقَدَّمَ <span class="qpc-hafs">﴿قُرِئَ﴾</span> في الهَمْزِ المُفْرَدِ و<span class="qpc-hafs">﴿القُرْآنُ﴾</span> في النَقْلِ.</p></div>"
  84,22,"<div class=ar lang=ar></div>"
  84,23,"<div class=ar lang=ar></div>"
  84,24,"<div class=ar lang=ar></div>"
  84,25,"<div class=ar lang=ar></div>"