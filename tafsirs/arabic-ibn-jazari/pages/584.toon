quran[31]{c,v,t}:
  79,16,"<div class=ar lang=ar><p>وَتَقَدَّمَ <span class="qpc-hafs">﴿طُوًى﴾</span> في طه.</p></div>"
  79,17,"<div class=ar lang=ar></div>"
  79,18,"<div class=ar lang=ar><p>(واخْتَلَفُوا) فِي: <span class="qpc-hafs">﴿إلى أنْ تَزَكّى﴾</span> فَقَرَأ المَدَنِيّانِ، وابْنُ كَثِيرٍ ويَعْقُوبُ بِتَشْدِيدِ الزايِ، وقَرَأ الباقُونَ بِتَخْفِيفِها.</p></div>"
  79,19,"<div class=ar lang=ar></div>"
