quran[14]{c,v,t}:
  23,105,"<div class=ar lang=ar><p>وَقَوله تَعَالَى: <span class="qpc-hafs">﴿ألم تكن آياتي تتلى عَلَيْكُم فكنتم بهَا تكذبون﴾</span> أَي: تجحدون وتنكرون.</p></div>"
  23,106,"<div class=ar lang=ar><p>وَقَوله: <span class="qpc-hafs">﴿قَالُوا رَبنَا غلبت علينا شِقْوَتنَا﴾</span> وقرىء: " شقاوتنا " وهما بِمَعْنى وَاحِد، وَالْمرَاد مِنْهُ: إِنَّمَا أدخلنا النَّار بِمَا غلب علينا من حكمك وقضائك بشقاوتنا. وَقَوله: <span class="qpc-hafs">﴿وَكُنَّا قوما ضَالِّينَ﴾</span> أَي: عَن الْحق.</p></div>"
  23,107,"<div class=ar lang=ar><p>قَوْله تَعَالَى: <span class="qpc-hafs">﴿رَبنَا أخرجنَا مِنْهَا فَإِن عدنا فَإنَّا ظَالِمُونَ﴾</span> فيتركهم مِقْدَار عمر الدُّنْيَا، وَفِي رِوَايَة: مثلي عمر الدُّنْيَا.</p></div>"
  23,108,"<div class=ar lang=ar><p>ثمَّ يَقُول: <span class="qpc-hafs">﴿ [قَالَ] اخْسَئُوا فِيهَا وَلَا تكَلمُون﴾</span> قَالَ: فَيَنْقَطِع رجاؤهم حِينَئِذٍ، وَلَا يسمع بعد ذَلِك مِنْهُم إِلَّا الزَّفِير والشهيق، وَأما قَوْله: <span class="qpc-hafs">﴿اخْسَئُوا﴾</span> أَي: ابعدوا، وَهُوَ مثل قَوْلهم: خسأت الْكَلْب أَي: أبعدته.</p></div>"
  23,109,"<div class=ar lang=ar><p>قَوْله تَعَالَى: <span class="qpc-hafs">﴿إِنَّه كَانَ فريق من عبَادي يَقُولُونَ رَبنَا آمنا فَاغْفِر لنا وارحمنا وَأَنت خير الرَّاحِمِينَ﴾</span> . قَالَ أهل التَّفْسِير: هَذَا فِي بِلَال وسلمان وعمار وصهيب والفقراء من أَصْحَاب الرَّسُول.</p></div>"
  23,110,"<div class=ar lang=ar><p>وَقَوله: <span class="qpc-hafs">﴿فاتخذتموهم سخريا﴾</span> وقرىء: " سخريا " فَقَوله: <span class="qpc-hafs">﴿سخريا﴾</span> من الِاسْتِهْزَاء، وَقَوله: " سخريا " من التسخير.</p><p>وَقَوله: <span class="qpc-hafs">﴿حَتَّى أنسوكم ذكري﴾</span> أَي: اشتغلتم بالاستهزاء والسخرية عَلَيْهِم، وتركتم ذكري، وَكَانَ الْوَاجِب عَلَيْكُم أَن تذكروني بدل استهزائكم بهم.</p><p>وَقَوله: <span class="qpc-hafs">﴿وكنتم مِنْهُم تضحكون﴾</span> وَفِي الْآيَة دَلِيل على أَن الِاسْتِهْزَاء بِالنَّاسِ كَبِيرَة، وَهُوَ مَوْعُود عَلَيْهِ، وَعَن جَعْفَر بن مُحَمَّد - رَضِي الله عَنهُ - قَالَ: من ضحك ضحكة مج مجة من الْعلم لَا يعود إِلَيْهِ أبدا.</p></div>"
  23,111,"<div class=ar lang=ar><p>قَوْله تَعَالَى: <span class="qpc-hafs">﴿إِنِّي جزيتهم الْيَوْم بِمَا صَبَرُوا أَنهم هم الفائزون﴾</span> أَي: بصبرهم <span class="qpc-hafs">﴿أَنهم هم الفائزون﴾</span> أَي: الناجون.</p></div>"
  23,112,"<div class=ar lang=ar><p>قَوْله تَعَالَى: <span class="qpc-hafs">﴿قَالَ كم لبثتم فِي الأَرْض عدد سِنِين﴾</span> . يَعْنِي: قَالَ الله تَعَالَى للْكفَّار: <span class="qpc-hafs">﴿كم لبثتم فِي الأَرْض عدد سِنِين﴾</span> (أَي: فِي الدُّنْيَا، وَيُقَال: فِي الْقُبُور، وقرىء: " قل كم لبثتم فِي الأَرْض عدد سِنِين ") وَمَعْنَاهُ: قل يَا أَيهَا الْكَافِر.</p></div>"
  23,113,"<div class=ar lang=ar><p>قَوْله تَعَالَى: <span class="qpc-hafs">﴿قَالُوا لبثنا يَوْمًا أَو بعض يَوْم﴾</span> إِنَّمَا ذكرُوا يَوْمًا أَو بعض يَوْم؛ لأَنهم نسوا عدد مَا لَبِثُوا من هول مَا يلقاهم يَوْم الْقِيَامَة، فَإِن قَالَ قَائِل: هَذِه الْآيَة تدل على أَن عَذَاب الْقَبْر لَيْسَ بِثَابِت للْكفَّار؛ لِأَنَّهُ لَو كَانَ ثَابتا لم يَقُولُوا: لبثنا يَوْمًا أَو بعض يَوْم؟ وَالْجَوَاب عَنهُ من وَجْهَيْن: أَحدهمَا: أَنه ذهب عَن قُلُوبهم عَذَاب الْقَبْر من هول مَا يلقاهم يَوْم الْقِيَامَة، وَالثَّانِي: أَن الله تَعَالَى يرفع الْعَذَاب عَن أهل الْقُبُور بَين النفختين، فينسون عَذَاب الْقَبْر، ويستريحون، وَإِنَّمَا يَقُولُونَ لبثنا يَوْمًا أَو بعض يَوْم لهَذَا.</p><p>وَقَوله: <span class="qpc-hafs">﴿فاسأل العادين﴾</span> أَي: الْمَلَائِكَة الَّذين يعْرفُونَ عدد مَا لَبِثُوا.</p></div>"
  23,114,"<div class=ar lang=ar><p>قَوْله تَعَالَى: <span class="qpc-hafs">﴿قَالَ إِن لبثتم إِلَّا قَلِيلا﴾</span> يَعْنِي: مَا لبثتم إِلَّا قَلِيلا <span class="qpc-hafs">﴿لَو أَنكُمْ كُنْتُم تعلمُونَ﴾</span> أَي: لَو تعلمُونَ عدد مَا لبثتم، وَإِنَّمَا ذكر قَلِيلا؛ لِأَن الْوَاحِد من أهل الدُّنْيَا وَإِن لبث فِي الدُّنْيَا سِنِين كَثِيرَة، فَإِنَّهُ يكون قَلِيلا فِي جنب مَا يلبث فِي الْآخِرَة.</p></div>"
  23,115,"<div class=ar lang=ar><p>قَوْله تَعَالَى: <span class="qpc-hafs">﴿أفحسبتم أَنما خَلَقْنَاكُمْ عَبَثا﴾</span> أَي: لتلعبوا أَو تعبثوا، وَقد سمى الله تَعَالَى جَمِيع الدُّنْيَا لعبا ولهوا فَقَالَ: <span class="qpc-hafs">﴿اعلموا أَنما الْحَيَاة الدُّنْيَا لعب وَلَهو﴾</span> فالآية تدل على أَن الْآدَمِيّ لم يخلق لطلب الدُّنْيَا والاشتغال بهَا، وَإِنَّمَا خلق ليعبد الله وَيقوم بأوامره، وَعَن بَعضهم قَالَ: <span class="qpc-hafs">﴿أفحسبتم أَنما خَلَقْنَاكُمْ عَبَثا﴾</span> هُوَ فِي معنى قَوْله تَعَالَى: <span class="qpc-hafs">﴿أيحسب الْإِنْسَان أَن يتْرك سدى﴾</span> وَمَعْنَاهُ: أَنه لَا يهمل أمره وَقَالَ بَعضهم: خلق (لهلاك) الْأَبَد أَو لملك الْأَبَد.</p><p>وَقَوله: <span class="qpc-hafs">﴿وأنكم إِلَيْنَا لَا ترجعون﴾</span> ظَاهر الْمَعْنى.</p></div>"
  23,116,"<div class=ar lang=ar><p>قَوْله تَعَالَى: <span class="qpc-hafs">﴿فتعالى الله الْملك الْحق لَا إِلَه إِلَّا هُوَ رب الْعَرْش الْكَرِيم﴾</span> أَي: الْمُرْتَفع، وَقيل: الْحسن، وَقد بَينا معنى <span class="qpc-hafs">﴿تَعَالَى﴾</span> من قبل.</p></div>"
  23,117,"<div class=ar lang=ar><p>قَوْله تَعَالَى: <span class="qpc-hafs">﴿وَمن يدع مَعَ الله إِلَهًا آخر لَا برهَان لَهُ بِهِ﴾</span> أَي: لَا بَيِّنَة وَلَا حجَّة لَهُ بِهِ، قَالَ أهل الْعلم: لَا حجَّة لأحد فِي دَعْوَى الشّرك، وَإِنَّمَا الْحجَّة عَلَيْهِم.</p><p>وَقَوله: <span class="qpc-hafs">﴿فَإِنَّمَا حسابه عِنْد ربه﴾</span> هَذَا فِي معنى قَوْله تَعَالَى: <span class="qpc-hafs">﴿ثمَّ إِن علينا حسابهم﴾</span> ، وَرُوِيَ " أَن أَعْرَابِيًا أَتَى النَّبِي وَقَالَ: وَمن يحاسبنا يَوْم الْقِيَامَة؟ قَالَ: الله. قَالَ: نجونا وَرب الْكَعْبَة، إِن الْكَرِيم إِذا قدر غفر " وَالْخَبَر غَرِيب.</p><p>وَقَوله: <span class="qpc-hafs">﴿إِنَّه لَا يفلح الْكَافِرُونَ﴾</span> أَي: لَا يسْعد وَلَا يفوز.</p></div>"
  23,118,"<div class=ar lang=ar><p>قَوْله تَعَالَى: <span class="qpc-hafs">﴿وَقل رب اغْفِر وَارْحَمْ وَأَنت خير الرَّاحِمِينَ﴾</span></p><p><span class="qpc-hafs">﴿اغْفِر﴾</span> اسْتُرْ <span class="qpc-hafs">﴿وَارْحَمْ﴾</span> اعطف، والغفور: الستور، والرحيم هُوَ العطوف.</p><p>قَوْله: <span class="qpc-hafs">﴿وَأَنت خير الرَّاحِمِينَ﴾</span> . أَي: خير من رحم.</p></div>"