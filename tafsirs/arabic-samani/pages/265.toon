quran[19]{c,v,t}:
  15,52,"<div class=ar lang=ar><p>وَقَوله: <span class="qpc-hafs">﴿إِذا دخلُوا عَلَيْهِ فَقَالُوا سَلاما﴾</span> أَي: سلمُوا سَلاما.</p><p>وَقَوله: <span class="qpc-hafs">﴿قَالَ إِنَّا مِنْكُم وجلون﴾</span> وَسبب وَجل إِبْرَاهِيم مِنْهُم؛ أَنه قرب إِلَيْهِم الطَّعَام فَلم يأكلوه، وَقد كَانُوا إِذا لم يَأْكُل الضَّيْف استرابوا بِهِ.</p></div>"
  15,53,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿قَالُوا لَا توجل﴾</span> أَي: لَا تخف، قَالَ الشَّاعِر:</p><p>(لعمرك لَا أَدْرِي وَإِنِّي لأوجل ... على أَيّنَا تعدو الْمنية أول)</p><p>وَقَوله: <span class="qpc-hafs">﴿إِنَّا نبشرك بِغُلَام عليم﴾</span> مَعْنَاهُ: غُلَام فِي صغره، عليم فِي كبره، وَهُوَ إِسْحَاق.</p></div>"
  15,54,"<div class=ar lang=ar><p>وَقَوله تَعَالَى: <span class="qpc-hafs">﴿قَالَ أبشرتموني﴾</span> الأَصْل: أبشرتمونني؛ فأسقط إِحْدَى النونين وَاكْتفى بالكسرة. وَقَوله: <span class="qpc-hafs">﴿على أَن مسني الْكبر﴾</span> يَعْنِي: على حَال الْكبر، وَهَذَا على طَرِيق التَّعَجُّب، وَكَذَلِكَ قَوْله: <span class="qpc-hafs">﴿فَبِمَ تبشرون﴾</span> على طَرِيق التَّعَجُّب، وَلَيْسَ على طَرِيق الشَّك وَالْإِنْكَار.</p></div>"
  15,55,"<div class=ar lang=ar><p>قَوْله تَعَالَى: <span class="qpc-hafs">﴿قَالُوا بشرناك بِالْحَقِّ فَلَا تكن من القاطنين﴾</span> الْحق: وضع الشَّيْء فِي مَوْضِعه على مَا تَدْعُو إِلَيْهِ الْحِكْمَة، والقنوط هُوَ الْيَأْس، وَمعنى الْحق هَاهُنَا هُوَ الصدْق.</p></div>"
  15,56,"<div class=ar lang=ar><p>قَوْله تَعَالَى: <span class="qpc-hafs">﴿قَالَ وَمن يقنط من رَحْمَة ربه إِلَّا الضالون﴾</span> يَعْنِي: إِلَّا الْكَافِرُونَ، والقنوط من رَحْمَة الله كَبِيرَة من الْكَبَائِر كالأمن من مكر الله.</p></div>"
  15,57,"<div class=ar lang=ar><p>قَوْله تَعَالَى: <span class="qpc-hafs">﴿قَالَ فَمَا خطبكم أَيهَا المُرْسَلُونَ﴾</span> قد ذكرنَا مَعْنَاهُ فِي سُورَة هود.</p></div>"
  15,58,"<div class=ar lang=ar><p>قَوْله تَعَالَى: <span class="qpc-hafs">﴿قَالُوا إِنَّا أرسلنَا إِلَى قوم مجرمين﴾</span> أَرَادَ بِهِ قوم لوط.</p></div>"
  15,59,"<div class=ar lang=ar><p>وَقَوله: <span class="qpc-hafs">﴿إِلَّا آل لوط﴾</span> المُرَاد مِنْهُ لوط وَبنَاته وَمن آمن بِهِ، وَقد ذكرنَا. وَقَوله: <span class="qpc-hafs">﴿إِنَّا لمنجوهم أَجْمَعِينَ﴾</span> هَذَا اسْتثِْنَاء من الِاسْتِثْنَاء، فالاستثناء الأول من المهلكين، وَالثَّانِي من المنجين، فَبَقيَ الْمُسْتَثْنى بِالِاسْتِثْنَاءِ الثَّانِي فِي المهلكين وَهُوَ امْرَأَته، وَهَذَا مثل مَا يَقُول الرجل لَك: على عشرَة إِلَّا أَرْبَعَة إِلَّا ثَلَاثَة، فالمستثنى بِالِاسْتِثْنَاءِ الثَّانِي (بَقِي) فِي الْمقر بِهِ بِالْإِقْرَارِ الأول، فَيصير كَأَنَّهُ اسْتثْنى درهما، وَيجب تِسْعَة دَرَاهِم.</p><p>وَقَوله: <span class="qpc-hafs">﴿قَدرنَا﴾</span> أَي: حكمنَا. وَقَوله: <span class="qpc-hafs">﴿إِنَّهَا لمن الغابرين﴾</span> أَي: من البَاقِينَ فِي الْعَذَاب، قَالَ الشَّاعِر:</p><p>(لَا تكسع الشول بأغبارها ... إِنَّك لَا تَدْرِي من الناتج)</p><p>أَي: ببقاياها، وَفِي الْأَحَادِيث: " يذهب أهل الْعلم وَتبقى غبرات فِي أوعية سوء " أَي: بقايا.</p></div>"
  15,60,"15:59"
  15,61,"<div class=ar lang=ar><p>قَوْله تَعَالَى: <span class="qpc-hafs">﴿فَلَمَّا جَاءَ آل لوط المُرْسَلُونَ﴾</span> ظَاهر الْمَعْنى.</p></div>"
  15,62,"<div class=ar lang=ar><p>قَوْله تَعَالَى: <span class="qpc-hafs">﴿قَالَ إِنَّكُم قوم منكرون﴾</span> لِأَنَّهُ لم يعرفهُمْ.</p></div>"
  15,63,"<div class=ar lang=ar><p>قَوْله تَعَالَى: <span class="qpc-hafs">﴿قَالُوا بل جئْنَاك بِمَا كَانُوا فِيهِ يمترون﴾</span> أَي: يَشكونَ، وَفِي الْقِصَّة: أَن لوطا كَانَ يتوعدهم بِالْعَذَابِ، فَلَا يصدقونه فَهُوَ فِي معنى قَوْله: <span class="qpc-hafs">﴿بِمَا كَانُوا فِيهِ يمترون﴾</span> .</p></div>"
  15,64,"<div class=ar lang=ar><p>وَقَوله: <span class="qpc-hafs">﴿وآتيناك بِالْحَقِّ وَإِنَّا لصادقون﴾</span> ظَاهر الْمَعْنى.</p></div>"
  15,65,"<div class=ar lang=ar><p>قَوْله تَعَالَى: <span class="qpc-hafs">﴿فَأسر بأهلك﴾</span> سرى وَأسرى بِمَعْنى وَاحِد. وَقَوله: <span class="qpc-hafs">﴿بِقطع من اللَّيْل﴾</span> أَي: بِقِطْعَة من اللَّيْل. وَقَوله: <span class="qpc-hafs">﴿وَاتبع أدبارهم﴾</span> هَذَا دَلِيل على أَن الله تَعَالَى أمره أَن يقدم أَهله، ثمَّ يمْضِي فِي إثرهم.</p><p>وَقَوله: <span class="qpc-hafs">﴿وَلَا يلْتَفت مِنْكُم أحد﴾</span> أَمرهم بترك الإلتفات حَتَّى لَا يرتاعوا من الْعَذَاب إِذا نزل بقومهم، وَقيل: إِن الله تَعَالَى جعل ذَلِك عَلامَة لمن ينجو من آل لوط، فَإِن الْمَرْأَة التفتت لما سَمِعت الهدة فَهَلَكت.</p><p>وَقَوله: <span class="qpc-hafs">﴿وامضوا حَيْثُ تؤمرون﴾</span> يُقَال: أمروا أَن يمضوا إِلَى " زغر "، وَهِي بَلْدَة بِالشَّام، وَقيل: إِلَى أَرض الْأُرْدُن وفلسطين.</p></div>"
  15,66,"<div class=ar lang=ar><p>قَوْله تَعَالَى: <span class="qpc-hafs">﴿وقضينا إِلَيْهِ ذَلِك الْأَمر﴾</span> قد ذكرنَا أَن الْقَضَاء بِمَعْنى الْفَرَاغ وَمَعْنَاهُ: أَنا حكمنَا وأبرمنا الْأَمر الَّذِي أمرناه فِي قوم لوط. وَقَوله: <span class="qpc-hafs">﴿أَن دابر هَؤُلَاءِ﴾</span> أَي: أصل هَؤُلَاءِ، وَقيل: آخر هَؤُلَاءِ <span class="qpc-hafs">﴿مَقْطُوع مصبحين﴾</span> يَعْنِي: حِين يدْخلُونَ فِي الصُّبْح.</p></div>"
  15,67,"<div class=ar lang=ar><p>قَوْله تَعَالَى: <span class="qpc-hafs">﴿وَجَاء أهل الْمَدِينَة يستبشرون﴾</span> يَعْنِي: يبشر بَعضهم بَعْضًا لما يرجون من ارْتِكَاب الْفَاحِشَة.</p></div>"
  15,68,"<div class=ar lang=ar><p>قَوْله تَعَالَى: <span class="qpc-hafs">﴿قَالَ إِن هَؤُلَاءِ ضَيْفِي فَلَا تفضحون﴾</span> الفضيحة: فعل يفعل بِالْمَرْءِ يلْزمه بِهِ الْعَار (والأنفة)</p></div>"
  15,69,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿فَاتَّقُوا الله وَلَا تخزون﴾</span> فالخزي بِمَعْنى الفضيحة.</p></div>"
  15,70,"<div class=ar lang=ar><p>قَوْله تَعَالَى: <span class="qpc-hafs">﴿قَالُوا أولم ننهك عَن الْعَالمين﴾</span> مَعْنَاهُ: أولم ننهك أَن تضيف أحدا، وَقيل: أولم ننهك عَن الْعَالمين، يَعْنِي: إِدْخَال الغرباء فِي الْمَدِينَة، فَإنَّك إِن أدخلتهم (نركب مِنْهُم) الْفَاحِشَة.</p></div>"