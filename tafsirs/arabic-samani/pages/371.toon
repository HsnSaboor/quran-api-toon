quran[28]{c,v,t}:
  26,84,"<div class=ar lang=ar><p>وَقَوله: <span class="qpc-hafs">﴿وَاجعَل لي لِسَان صدق فِي الآخرين﴾</span> أَي: ثَنَاء حسنا إِلَى قيام السَّاعَة، وَيُقَال: إِن المُرَاد مِنْهُ تولي جَمِيع أهل الْأَدْيَان لَهُ، وَقبُول كل النَّاس إِيَّاه، وَيُقَال: إِن مَعْنَاهُ: اجْعَل فِي ذريتي من يقوم بِالْحَقِّ إِلَى قيام السَّاعَة.</p></div>"
  26,85,"<div class=ar lang=ar><p>وَقَوله: <span class="qpc-hafs">﴿واجعلني من وَرَثَة جنَّة النَّعيم﴾</span> أَي: مِمَّن تعطيه جنَّة النَّعيم.</p></div>"
  26,86,"<div class=ar lang=ar><p>وَقَوله: <span class="qpc-hafs">﴿واغفر لأبي إِنَّه كَانَ من الضَّالّين﴾</span> قَالَ أهل الْعلم: هَذَا قبل أَن يتبرأ مِنْهُ، ويستقين أَنه عَدو لله، على مَا ذَكرْنَاهُ فِي سُورَة التَّوْبَة، وَقَالَ بَعضهم: واغفر لأبي أَي: جِنَايَته على، كَأَنَّهُ أسقط حَقه وَعَفا عَنهُ.</p><p>وَعَن الْحسن الْبَصْرِيّ: أَن إِبْرَاهِيم - عَلَيْهِ السَّلَام - يتَعَلَّق بِأَبِيهِ يَوْم الْقِيَامَة، وَيَقُول: اللَّهُمَّ اغْفِر لَهُ، وأنجز لي مَا وَعَدتنِي، فيحول الله صُورَة أَبِيه إِلَى صُورَة ذبح، هُوَ ضبيع قَبِيح، فَإِذا رَآهُ إِبْرَاهِيم تَركه، وَقَالَ: لَيْسَ هَذَا بِأبي.</p></div>"
  26,87,"<div class=ar lang=ar><p>وَقَوله: <span class="qpc-hafs">﴿وَلَا تخزني يَوْم يبعثون﴾</span> أَي: لَا تفضحني، وَذَلِكَ بِأَن لَا يغْفر خطيئته، وكل من لم يغْفر لَهُ الله فقد أَخْزَاهُ.</p></div>"
  26,88,"<div class=ar lang=ar><p>وَقَوله <span class="qpc-hafs">﴿يَوْم لَا ينفع مَال وَلَا بنُون إِلَّا من أَتَى الله بقلب سليم﴾</span> قَالَ أَكثر أهل الْعلم: سليم من الشّرك، فَإِن الْآدَمِيّ لَا يَخْلُو من ذَنْب، وَقيل: مخلص، وَقيل: نَاصح، وَقيل: قلب فِيهِ لَا إِلَه إِلَّا الله.</p></div>"
  26,89,"26:88"
  26,90,"<div class=ar lang=ar><p>وَقَوله: <span class="qpc-hafs">﴿وأزلفت الْجنَّة لِلْمُتقين﴾</span> أَي: قربت، وَقد ثَبت عَن النَّبِي أَنه قَالَ: " الْجنَّة أقرب إِلَى أحدكُم من شِرَاك نَعله، وَالنَّار مثل ذَلِك ".</p></div>"
  26,91,"<div class=ar lang=ar><p>وَقَوله: <span class="qpc-hafs">﴿وبرزت الْجَحِيم﴾</span> أَي: أظهرت الْجَحِيم.</p><p><span class="qpc-hafs">﴿للغاوين﴾</span> أَي: للْكَافِرِينَ، والغاوي من وَقع فِي خيبة لَا رَجَاء فِيهَا.</p></div>"
  26,92,"<div class=ar lang=ar><p>قَوْله تَعَالَى: <span class="qpc-hafs">﴿وَقيل لَهُم أَيْن مَا كُنْتُم تَعْبدُونَ من دون الله هَل ينصرونكم﴾</span> أَي: يمْنَعُونَ الْعَذَاب عَنْكُم.</p><p>وَقَوله: <span class="qpc-hafs">﴿أَو ينْصرُونَ﴾</span> أَي: يمتنعون.</p></div>"
  26,93,"26:92"
  26,94,"<div class=ar lang=ar><p>وَقَوله: <span class="qpc-hafs">﴿فكبكبوا فِيهَا هم﴾</span> قَالَ القتيبي: طرح بَعضهم على بعض. وَقيل: دهوروا، ودهدهوا، ودهدوا، وَقيل: نكسوا فِيهَا، وَيُقَال: كَانَ فِي الأَصْل كببوا، فأدخلت الْكَاف فِيهِ فَصَارَ كبكبوا.</p><p>وَقَوله: <span class="qpc-hafs">﴿هُوَ الْغَاوُونَ﴾</span> أَي: الشَّيَاطِين مَعَهم، وَيُقَال: من اتَّبَعُوهُمْ فِي الشّرك.</p></div>"
  26,95,"<div class=ar lang=ar><p>وَقَوله: <span class="qpc-hafs">﴿وجنود إِبْلِيس أَجْمَعُونَ﴾</span> أَي: ذُريَّته.</p></div>"
  26,96,"<div class=ar lang=ar><p>قَوْله تَعَالَى: <span class="qpc-hafs">﴿قَالُوا وهم فِيهَا يختصمون﴾</span> أَي: يُجَادِل بَعضهم بَعْضًا.</p></div>"
  26,97,"<div class=ar lang=ar><p>وَقَوله: <span class="qpc-hafs">﴿تالله إِن كُنَّا لفي ضلال مُبين﴾</span> أَي: فِي خطأ بَين.</p></div>"
  26,98,"<div class=ar lang=ar><p>وَقَوله: <span class="qpc-hafs">﴿إِذْ نسويكم بِرَبّ الْعَالمين﴾</span> هَذَا قَوْلهم للأصنام وَمَعْنَاهُ: نعدلكم بِرَبّ الْعَالمين.</p></div>"
  26,99,"<div class=ar lang=ar><p>وَقَوله: <span class="qpc-hafs">﴿وَمَا أضلنا إِلَّا المجرمون﴾</span> أَي: القادة، وَيُقَال: إِبْلِيس وَابْن آدم الْكَافِر، وَهُوَ قابيل.</p></div>"
  26,100,"<div class=ar lang=ar><p>وَقَوله: <span class="qpc-hafs">﴿فَمَا لنا من شافعين﴾</span> فِي الْأَخْبَار: أَن الْمُؤمنِينَ يشفعون للمذنبين، وَكَذَلِكَ الْمَلَائِكَة والأنبياء.</p></div>"
  26,101,"<div class=ar lang=ar><p>وَقَوله: <span class="qpc-hafs">﴿وَلَا صديق حميم﴾</span> أَي: صديق خَاص، وَقيل: صديق قريب، وسمى حميما؛ لِأَنَّهُ يحمٌ لَك ويغضب لِأَجلِك، وَعَن الْحسن الْبَصْرِيّ قَالَ: استكثروا من الأصدقاء الْمُؤمنِينَ، فَإِن لَهُم شَفَاعَة يَوْم الْقِيَامَة. وَالصديق هُوَ الصَّادِق فِي الْمَوَدَّة على شَرط الدّين، وَفِي بعض الْأَخْبَار عَن النَّبِي بِرِوَايَة جَابر: " أَن الْمُؤمن يدْخل الْجنَّة وَيَقُول: أَيْن صديقي فلَان؟ فَيُقَال: هُوَ فِي النَّار بِذَنبِهِ، فَيشفع لَهُ فيخرجه الله من النَّار بِشَفَاعَتِهِ ".</p></div>"
  26,102,"<div class=ar lang=ar><p>وَقَوله: <span class="qpc-hafs">﴿فَلَو أَن لنا كرة﴾</span> أَي: رَجْعَة.</p><p>وَقَوله: <span class="qpc-hafs">﴿فنكون من الْمُؤمنِينَ﴾</span> وَإِذا كُنَّا مُؤمنين فَيكون لنا شُفَعَاء أَيْضا كَمَا للْمُؤْمِنين شُفَعَاء.</p></div>"
  26,103,"<div class=ar lang=ar><p>وَقَوله: <span class="qpc-hafs">﴿إِن فِي ذَلِك لآيَة وَمَا كَانَ أَكْثَرهم مُؤمنين وَإِن رَبك لَهو الْعَزِيز الرَّحِيم﴾</span> قد بَينا معنى الْكل.</p></div>"
  26,104,"26:103"
  26,105,"<div class=ar lang=ar><p>قَوْله تَعَالَى: <span class="qpc-hafs">﴿كذبت قوم نوح الْمُرْسلين﴾</span> قَالَ ابْن عَبَّاس: نوح أول رَسُول أرسل الله تَعَالَى وَهَذَا مَحْمُول على أَنه أول رَسُول أرْسلهُ الله تَعَالَى بعد آدم - صلوَات الله عَلَيْهِ - وَهُوَ صَاحب شَرِيعَة، وَإِنَّمَا ذكر الْمُرْسلين؛ لِأَن من كذب رَسُولا فقد كذب جَمِيع الرُّسُل.</p></div>"
  26,106,"<div class=ar lang=ar><p>وَقَوله: <span class="qpc-hafs">﴿إِذْ قَالَ لَهُم أخوهم نوح﴾</span> يَعْنِيك أَنه أخوهم فِي النّسَب.</p><p>وَقَوله: <span class="qpc-hafs">﴿أَلا تَتَّقُون﴾</span> أَي: أَلا تتقوا الله.</p></div>"
  26,107,"<div class=ar lang=ar><p>وَقَوله: <span class="qpc-hafs">﴿إِنِّي لكم رَسُول أَمِين﴾</span> أَي: أَمِين فِيمَا بَيْنكُم وَبَين الله تَعَالَى، وَفِي بعض التفاسير: أَن نوحًا كَانَ يُسمى الْأمين قبل أَن يَبْعَثهُ الله.</p></div>"
  26,108,"<div class=ar lang=ar><p>وَقَوله: <span class="qpc-hafs">﴿فَاتَّقُوا الله وأطيعون﴾</span> أَي: اتَّقوا الله بترك الشّرك، وأطيعون فِيمَا آمركُم [بِهِ] .</p></div>"
  26,109,"<div class=ar lang=ar><p>وَقَوله: <span class="qpc-hafs">﴿وَمَا أَسأَلكُم عَلَيْهِ من أجر﴾</span> أَي: من جعل.</p><p>وَقَوله: <span class="qpc-hafs">﴿إِن أجري إِلَّا على رب الْعَالمين﴾</span> أَي: ثوابي، قَالَ أهل الْعلم: وَلَا يجوز للنَّبِي أَن يَأْخُذ جعلا على النُّبُوَّة؛ لِأَنَّهُ يُؤَدِّي إِلَى تنفير النَّاس عَن قبُول الْإِيمَان، وَيجوز أَن يَأْخُذ الْهَدِيَّة؛ لِأَنَّهُ لَا يُؤَدِّي إِلَى التنفير.</p></div>"
  26,110,"<div class=ar lang=ar><p>وَقَوله: <span class="qpc-hafs">﴿فَاتَّقُوا الله وأطيعون﴾</span> أَعَادَهُ تَأْكِيدًا.</p></div>"
  26,111,"<div class=ar lang=ar><p>قَوْله تَعَالَى: <span class="qpc-hafs">﴿قَالُوا أنؤمن لَك واتبعك الأرذلون﴾</span> فِي التَّفْسِير: أَنهم الحاكة، والحجامون، والأساكفة وَمن أشبههم، وَقيل: إِنَّهُم أسافل النَّاس.</p></div>"