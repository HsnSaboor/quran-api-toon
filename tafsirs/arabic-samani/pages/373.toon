quran[23]{c,v,t}:
  26,137,"<div class=ar lang=ar><p>وَقَوله: <span class="qpc-hafs">﴿إِن هَذَا﴾</span> أَي: مَا هَذَا.</p><p><span class="qpc-hafs">﴿إِلَّا خلق الْأَوَّلين﴾</span> أَي: اخْتِلَاق الْأَوَّلين وكذبهم.</p><p>وقرى: " إِن هَذَا إِلَّا خلق الْأَوَّلين " بِضَم الْخَاء وَاللَّام أَي: عَادَتهم ودأبهم، وَيُقَال مَعْنَاهُ: أمرنَا كأمر الْأَوَّلين؛ نَعِيش وَنَمُوت.</p></div>"
  26,138,"<div class=ar lang=ar><p>وَقَوله: <span class="qpc-hafs">﴿وَمَا نَحن بمعذبين﴾</span> قَالُوا هَذَا إِنْكَار لما وعدهم هود من الْعَذَاب.</p></div>"
  26,139,"<div class=ar lang=ar><p>وَقَوله: <span class="qpc-hafs">﴿فَكَذبُوهُ فأهلكناهم﴾</span> ظَاهر الْمَعْنى إِلَى قَوْله: <span class="qpc-hafs">﴿إِن أجري إِلَّا على رب الْعَالمين﴾</span> .</p></div>"
  26,140,"26:139"
  26,141,"26:139"
  26,142,"26:139"
  26,143,"26:139"
  26,144,"26:139"
  26,145,"26:139"
  26,146,"<div class=ar lang=ar><p>قَوْله تَعَالَى: <span class="qpc-hafs">﴿أتتركون فِيمَا هَاهُنَا آمِنين﴾</span> يَعْنِي: فِي الدُّنْيَا آمِنين من الْعَذَاب.</p></div>"
  26,147,"<div class=ar lang=ar><p>وَقَوله: <span class="qpc-hafs">﴿فِي جنَّات وعيون وزروع ونخل طلعها هضيم﴾</span> قَالَ الْأَزْهَرِي: الهضيم هُوَ الدَّاخِل بعضه فِي بعض من النضج والنعامة، وَيُقَال: هُوَ اللين الرطب، وَيُقَال: هُوَ الرخو الَّذِي إِذا مَسّه الْإِنْسَان تفتت، وَقيل: هُوَ المذنب، وَهُوَ الَّذِي نضج بعضه من قبل الذَّنب، وَيُقَال هضيم أَي: الهاضم كَأَنَّهُ يهضم الطَّعَام.</p><p>وَكَانَ الْحسن الْبَصْرِيّ يَقُول: فِي وعظه: ابْن آدم، تَأْكُل كَذَا وَكَذَا ثمَّ تَقول: يَا جَارِيَة، هَاتِي الهاضوم، إِنَّه يهضم دينك لَا طَعَامك.</p></div>"
  26,148,"26:147"
  26,149,"<div class=ar lang=ar><p>قَوْله تَعَالَى: <span class="qpc-hafs">﴿وتنحتون من الْجبَال بُيُوتًا فارهين﴾</span> أَي: حاذقين، وَيُقَال: معجبين بِمَا نلتم، وَقُرِئَ: " فرهين " أَي: فرحين، وَقيل: شرهين، قَالَ الشَّاعِر:</p><p>(لَا أستكين إِذا مَا أزمة أزمت ... وَلنْ تراني بِخَير فاره الطّلب)</p><p>وَيُقَال: الفاره والفره بِمَعْنى وَاحِد.</p></div>"
  26,150,"<div class=ar lang=ar><p>وَقَوله: <span class="qpc-hafs">﴿فَاتَّقُوا الله وأطيعون﴾</span> إِلَى قَوْله: <span class="qpc-hafs">﴿لَا يصلحون﴾</span> ظَاهر الْمَعْنى، وَالْمرَاد مِنْهُ: لَا تتبعوا قادتكم فِي الشّرك.</p></div>"
  26,151,"26:150"
  26,152,"26:150"
  26,153,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿قَوْله تَعَالَى: {قَالُوا إِنَّمَا أَنْت من المسحرين﴾</span> أَي: سحرت مرّة بعد مرّة، وَيُقَال: <span class="qpc-hafs">﴿من المسحرين﴾</span> أَي: من الْبشر وَهُوَ الَّذِي لَهُ سحر وَهُوَ الرئة، وَيُقَال: فلَان مسحر أَي: مُعَلل بِالطَّعَامِ وَالشرَاب، قَالَ الشَّاعِر:</p><p>(أرانا موضِعين لحتم غيب ... ونسحر بِالطَّعَامِ (وَالشرَاب))</p><p>وَقَالَ آخر:</p><p>(فَإِن تسألينا فيمَ نَحن فإننا ... عصافير من هَذَا الْأَنَام المسحر)</p><p>أَي: الْمُعَلل بِالطَّعَامِ وَالشرَاب.</p></div>"
  26,154,"<div class=ar lang=ar><p>قَوْله تَعَالَى: <span class="qpc-hafs">﴿مَا أَنْت إِلَّا بشر مثلنَا فأت بِآيَة إِن كنت من الصَّادِقين﴾</span> قد ذكرنَا أَنهم طلبُوا نَاقَة حَمْرَاء عشراء، تخرج من صَخْرَة وتلد سقيا فِي الْحَال.</p></div>"
  26,155,"<div class=ar lang=ar><p>قَوْله تَعَالَى: <span class="qpc-hafs">﴿قَالَ هَذِه نَاقَة لَهَا شرب وَلكم شرب يَوْم مَعْلُوم﴾</span> فِي الْقِصَّة: أَن النَّاقة كَانَت تشرب مَاء الْبِئْر يَوْمًا فِي أول النَّهَار، وتسقيهم لَبَنًا فِي آخر النَّهَار، وَكَانَ عظم النَّاقة [ميلًا] فِي ميل، وَكَانَت إِذا شربت تُؤثر أضلاع جنبها فِي الْجَبَل.</p></div>"
  26,156,"<div class=ar lang=ar><p>وَقَوله: <span class="qpc-hafs">﴿وَلَا تمسوها بِسوء فيأخذكم عَذَاب يَوْم عَظِيم﴾</span> ظَاهر الْمَعْنى.</p></div>"
  26,157,"<div class=ar lang=ar><p>قَوْله تَعَالَى: <span class="qpc-hafs">﴿فَعَقَرُوهَا فَأَصْبحُوا نادمين﴾</span> وسنبين من عقرهَا فِي سُورَة النَّمْل إِن شَاءَ الله تَعَالَى.</p></div>"
  26,158,"<div class=ar lang=ar><p>وَقَوله: <span class="qpc-hafs">﴿فَأَخذهُم الْعَذَاب﴾</span> ظَاهر إِلَى قَوْله تَعَالَى: {إِن أجري إِلَّا على رب فِي قصَّة لوط صلوَات الله عَلَيْهِ.</p></div>"
  26,159,"26:158"