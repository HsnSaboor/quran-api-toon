quran[27]{c,v,t}:
  37,25,"<div class=ar lang=ar><p>قَوْله تَعَالَى: <span class="qpc-hafs">﴿مَا لكم لَا تناصرون﴾</span> أَي: لَا تتناصرون؛ فينصر بَعْضكُم بَعْضًا. وَفِي التَّفْسِير: أَن أَبَا جهل هُوَ الْقَائِل: نَحن جَمِيع منتصر، على مَا حكى الله تَعَالَى فَقَالَ الله تَعَالَى ردا لقَوْله: <span class="qpc-hafs">﴿مَا لكم لَا تناصرون﴾</span> أَي: لينصر بَعْضكُم الْبَعْض الْيَوْم إِن كُنْتُم صَادِقين.</p></div>"
  37,26,"<div class=ar lang=ar><p>قَوْله تَعَالَى: <span class="qpc-hafs">﴿بل هم الْيَوْم مستسلمون﴾</span> يَعْنِي: استسلموا وعضوا بِأَيْدِيهِم، وَعرفُوا أَنه لَا خلاص لَهُم من الْهَلَاك وَالْعَذَاب.</p></div>"
  37,27,"<div class=ar lang=ar><p>وَقَوله: <span class="qpc-hafs">﴿وَأَقْبل بَعضهم على بعض يتساءلون﴾</span> مَعْنَاهُ أَي: ويتلاومون، قَوْله تَعَالَى: <span class="qpc-hafs">﴿قَالُوا إِنَّكُم كُنْتُم تأتوننا عَن الْيَمين﴾</span> قَالَ الْفراء والزجاج وَغَيرهمَا من أهل الْمعَانِي: أَي من قبل الَّذين تلبسونه علينا، وَقيل: من قبل الْجنَّة تثبطوننا عَنْهَا، وَذكر بَعضهم: أَن رُؤَسَاء الْكفَّار كَانَ يحلفُونَ [للأتباع] أَنهم على الْحق.</p></div>"
  37,28,"<div class=ar lang=ar><p>فَقَوله: <span class="qpc-hafs">﴿إِنَّكُم كُنْتُم تأتوننا عَن الْيَمين﴾</span> أَي: عَن الْأَيْمَان الَّتِي حلفوا بهَا أَنهم صَادِقُونَ، وَالْيَمِين يذكر وَيُرَاد بِهِ الْقُوَّة، قَالَ الشَّاعِر:</p><p>(إِذا مَا راية رفعت لمجد ... تلقاها عرابة بِالْيَمِينِ)</p><p>أَي: بِالْقُوَّةِ.</p></div>"
  37,29,"<div class=ar lang=ar><p>قَوْله تَعَالَى: <span class="qpc-hafs">﴿قَالُوا بل لم تَكُونُوا مُؤمنين﴾</span> أَي: رُؤَسَاء يَقُولُونَ ذَلِك للأتباع،</p></div>"
  37,30,"<div class=ar lang=ar><p>وَقَوله: <span class="qpc-hafs">﴿وَمَا كَانَ لنا عَلَيْكُم من سُلْطَان بل كُنْتُم قوما طاغين﴾</span> يَعْنِي: إِنَّكُم فَعلْتُمْ مَا فَعلْتُمْ بِأَنْفُسِكُمْ، وَلم نَفْعل بكم شَيْئا.</p></div>"
  37,31,"<div class=ar lang=ar><p>قَوْله تَعَالَى: <span class="qpc-hafs">﴿فَحق علينا قَول رَبنَا﴾</span> أَي: وَجب علينا عَذَاب رَبنَا، قَالَ الْحسن: الضال والمضل جَمِيعًا فِي النَّار؛ فَهُوَ معنى قَوْله تَعَالَى: <span class="qpc-hafs">﴿إِنَّا لذائقون﴾</span> أَي: ذائقون الْعَذَاب.</p></div>"
  37,32,"<div class=ar lang=ar><p>قَوْله تَعَالَى: <span class="qpc-hafs">﴿فأغويناكم إِنَّا كُنَّا غاوين﴾</span> أَي: أضللناكم إِنَّا كُنَّا ضَالِّينَ.</p></div>"
  37,33,"<div class=ar lang=ar><p>قَوْله: <span class="qpc-hafs">﴿فَإِنَّهُم يَوْمئِذٍ فِي الْعَذَاب مشتركون﴾</span> يَعْنِي: أَنهم جَمِيعًا فِي الْعَذَاب.</p></div>"
  37,34,"<div class=ar lang=ar><p>قَوْله تَعَالَى: <span class="qpc-hafs">﴿إِنَّا كَذَلِك نَفْعل بالمجرمين﴾</span> ظَاهر الْمَعْنى، والجرم هَا هُنَا هُوَ الشّرك.</p></div>"
  37,35,"<div class=ar lang=ar><p>قَوْله تَعَالَى: <span class="qpc-hafs">﴿إِنَّهُم كَانُوا إِذا قيل لَهُم لَا إِلَه إِلَّا الله يَسْتَكْبِرُونَ﴾</span> عَن كلمة التَّوْحِيد، ويمتنعون مِنْهَا.</p></div>"
  37,36,"<div class=ar lang=ar><p>قَوْله تَعَالَى: <span class="qpc-hafs">﴿أئنا لتاركوا آلِهَتنَا لشاعر مَجْنُون﴾</span> قَالُوا ذَلِك للنَّبِي، فَقَالَ الله تَعَالَى ردا عَلَيْهِم:</p></div>"
  37,37,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿بل جَاءَ بِالْحَقِّ وَصدق الْمُرْسلين﴾</span> أَي: الْمُرْسلين الَّذين سبقوا فِي الرسَالَة.</p></div>"
  37,38,"<div class=ar lang=ar><p>قَوْله تَعَالَى: <span class="qpc-hafs">﴿إِنَّكُم لذائقوا الْعَذَاب الْأَلِيم وَمَا تُجْزونَ إِلَّا مَا كُنْتُم تَعْمَلُونَ﴾</span> ظَاهر الْمَعْنى،</p></div>"
  37,39,"37:38"
  37,40,"<div class=ar lang=ar><p>قَوْله تَعَالَى: <span class="qpc-hafs">﴿إِلَّا عباد الله المخلصين﴾</span> أَي: الَّذين أَخْلصُوا فِي التَّوْحِيد.</p></div>"
  37,41,"<div class=ar lang=ar><p>قَوْله تَعَالَى: <span class="qpc-hafs">﴿أُولَئِكَ لَهُم رزق مَعْلُوم﴾</span> أَي: مُقَدّر، ورزقهم الْمُقدر هُوَ رزقهم بكرَة وعشيا،</p></div>"
  37,42,"<div class=ar lang=ar><p>وَقَوله: <span class="qpc-hafs">﴿فواكه وهم مكرمون﴾</span> الْفَوَاكِه جمع الْفَاكِهَة.</p><p>وَقَوله: <span class="qpc-hafs">﴿وهم مكرمون﴾</span> أَي: بإدخالهم الْجنَّة.</p></div>"
  37,43,"<div class=ar lang=ar><p>قَوْله تَعَالَى: <span class="qpc-hafs">﴿فِي جنَّات النَّعيم﴾</span> يَعْنِي: إِنَّهُم فِي جنَّات النَّعيم.</p></div>"
  37,44,"<div class=ar lang=ar><p>وَقَوله: <span class="qpc-hafs">﴿على سرر مُتَقَابلين﴾</span> قَالَ أهل التَّفْسِير: لَا ينظر بَعضهم فِي قفا الْبَعْض.</p></div>"
  37,45,"<div class=ar lang=ar><p>قَوْله تَعَالَى: <span class="qpc-hafs">﴿يُطَاف عَلَيْهِم بكأس من معِين﴾</span> أَي: الْخمر الْجَارِي.</p></div>"
  37,46,"<div class=ar lang=ar><p>وَقَوله: <span class="qpc-hafs">﴿بَيْضَاء لَذَّة للشاربين﴾</span> قَالَ الْحسن الْبَصْرِيّ: خمر الْجنَّة أَبيض من اللَّبن، قَرَأَ ابْن مَسْعُود: " صفراء لَذَّة للشاربين ".</p></div>"
  37,47,"<div class=ar lang=ar><p>قَوْله تَعَالَى: <span class="qpc-hafs">﴿لَا فِيهَا غول﴾</span> أَي: لَا تغتال عُقُولهمْ، قَالَ الشَّاعِر:</p><p>(فَمَا زَالَت الكأس تغتالنا ... وتصرع بِالْأولِ الأول)</p><p>وَيُقَال: الْخمر غول الْعقل، وَالْحَرب غول النَّفس، وَيُقَال: الغول هُوَ الغائلة، وَمن الغائلة ذهَاب عقلهم، وَسَائِر الْمَفَاسِد الَّتِي فِي الْخمر، وَيُقَال فِي الْخمر أَرْبَعَة أَشْيَاء: السكر، والصداع، والقيء، و (الْبَوْل) ، وَلَا يُوجد من هَذِه الْأَرْبَع فِي خمر الْجنَّة.</p><p>وَقَوله: <span class="qpc-hafs">﴿وَلَا هم عَنْهَا ينزفون﴾</span> يُقَال: أنزف الرجل إِذا سكر، قَالَ الشَّاعِر:</p><p>(لعمري لَئِن أنزفتم أَو صحوتم ... لبئس الندامى كُنْتُم آل أبجرا)</p></div>"
  37,48,"<div class=ar lang=ar><p>قَوْله تَعَالَى: <span class="qpc-hafs">﴿وَعِنْدهم قاصرات الطّرف﴾</span> أَي: اللَّاتِي قصرن أطرافهن على أَزوَاجهنَّ أَي: عينهن أَي: حبسن فَلَا ينظرن إِلَى غير أَزوَاجهنَّ.</p><p>وَقَوله: <span class="qpc-hafs">﴿عين﴾</span> أَي: حسان الْأَعْين، وَفِي التَّفْسِير: الْبيَاض شَدِيد الْبيَاض، والسواد شَدِيد السوَاد، يَعْنِي فِي الْعين.</p></div>"
  37,49,"<div class=ar lang=ar><p>وَقَوله: <span class="qpc-hafs">﴿كأنهن بيض مَكْنُون﴾</span> الْعَرَب تشبه وَجه الْمَرْأَة فِي الْبيَاض بَيْضَة النعامة، وَيَقُولُونَ: أحسن اللَّوْن بَيَاض اللَّوْن مشوب بالصفرة، قَالَ ذُو الرمة:</p><p>(كحلاء فِي بزخ صفراء فِي دعجٌ ... كَأَنَّهَا فضَّة قد مَسهَا ذهب)</p><p>وَقَوله: <span class="qpc-hafs">﴿مَكْنُون﴾</span> أَي: مَسْتُور مصون من الريش (والخمار) .</p><p>وَقَالَ بَعضهم: فِي قَوْله <span class="qpc-hafs">﴿بيض مَكْنُون﴾</span> شبههن ببياض الْبَيْضَة عِنْد خُرُوجهَا من قشرتها، وَقيل: شبه بالسحاء الَّذِي بَين القشر الْأَعْلَى وَبَين الْبيَاض.</p></div>"
  37,50,"<div class=ar lang=ar><p>قَوْله تَعَالَى: <span class="qpc-hafs">﴿فَأقبل بَعضهم على بعض يتساءلون﴾</span> أَي: يسْأَل بَعضهم بَعْضًا عَن حَاله فِي الدُّنْيَا.</p></div>"
  37,51,"<div class=ar lang=ar><p>قَوْله تَعَالَى: <span class="qpc-hafs">﴿قَالَ قَائِل مِنْهُم إِنِّي كَانَ لي قرين﴾</span> قَالَ مُجَاهِد: القرين هَا هُنَا: هُوَ الشَّيْطَان (يغويه) ، وَيُقَال: القرين هَا هُنَا: قرينه الَّذِي كَانَ يَدعُوهُ إِلَى الْكفْر.</p><p>قَالَ عَطاء الْخُرَاسَانِي: نزلت الْآيَة فِي رجلَيْنِ كَانَا فِي بني إِسْرَائِيل اكتسبا مَالا عَظِيما، وَيُقَال: ورثا مَالا عَظِيما واقتسماه، فأنفق أَحدهمَا نصِيبه على الْفُقَرَاء، وَأما الآخر فَاشْترى بِهِ عقارا ودورا وأثرى، وهما اللَّذَان ذكرهمَا الله تَعَالَى فِي سُورَة الْكَهْف، وَقَالَ بَعضهم: هما أَخَوان سواهُمَا.</p></div>"