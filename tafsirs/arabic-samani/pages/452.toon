quran[29]{c,v,t}:
  37,154,"<div class=ar lang=ar><p>وَقَوله: <span class="qpc-hafs">﴿مَا لكم كَيفَ تحكمون﴾</span> أَي: كَيفَ تَقولُونَ أَن الله تَعَالَى اخْتَار الْبَنَات على الْبَنِينَ، وَأَنْتُم لَا تختارون إِلَّا الْبَنِينَ.</p></div>"
  37,155,"<div class=ar lang=ar><p>وَقَوله: <span class="qpc-hafs">﴿أَفلا تذكرُونَ﴾</span> أَي: أَفلا تتعظون،</p></div>"
  37,156,"<div class=ar lang=ar><p>قَوْله تَعَالَى: <span class="qpc-hafs">﴿أم لكم سُلْطَان مُبين﴾</span> أَي: حجَّة بَيِّنَة،</p></div>"
  37,157,"<div class=ar lang=ar><p>وَقَوله: <span class="qpc-hafs">﴿فَأتوا بِكِتَابِكُمْ﴾</span> أَي: بِكِتَاب من عنْدكُمْ يدل على مَا قلتموه <span class="qpc-hafs">﴿إِن كُنْتُم صَادِقين﴾</span> .</p></div>"
  37,158,"<div class=ar lang=ar><p>وَقَوله تَعَالَى: <span class="qpc-hafs">﴿وَجعلُوا بَينه وَبَين الْجنَّة نسبا﴾</span> الْجنَّة: هَا هُنَا هم الْمَلَائِكَة فِي قَول أَكثر الْمُفَسّرين، وَعَن بَعضهم: أَنهم الْجِنّ، وَقد كَانَ زعم بعض قُرَيْش أَن الْمَلَائِكَة بَنَات الله على مَا ذكرنَا؛ فَقَالَ أَبُو بكر الصّديق لَهُم: فَمن أمهاتهم؟ فَقَالُوا: سروات الْجِنّ؛ فَهَذَا معنى قَوْله تَعَالَى: <span class="qpc-hafs">﴿وَجعلُوا بَينه وَبَين الْجنَّة نسبا﴾</span> .</p><p>وَقَوله: <span class="qpc-hafs">﴿وَلَقَد علمت الْجنَّة إِنَّهُم لمحضرون﴾</span> أَي: محضرون الْحساب، وَقيل: محضرون الْعَذَاب،</p></div>"
  37,159,"<div class=ar lang=ar><p>قَوْله تَعَالَى: <span class="qpc-hafs">﴿سُبْحَانَ الله عَمَّا يصفونَ﴾</span> نزه نَفسه عَمَّا وصفوه بِهِ من هَذَا القَوْل الشنيع.</p><p>وَقَوله: <span class="qpc-hafs">﴿إِلَّا عباد الله المخلصين﴾</span> قد ذكرنَا من قبل، فَإِن قيل: أَي: اتِّصَال</p></div>"
  37,160,"<div class=ar lang=ar><p>لقَوْله: <span class="qpc-hafs">﴿إِلَّا عباد الله المخلصين﴾</span> بقوله: <span class="qpc-hafs">﴿سُبْحَانَ الله عَمَّا يصفونَ﴾</span> وَكَيف يَصح الِاسْتِثْنَاء فِي هَذَا الْبَاب، وَكلمَة إِلَّا للاستثناء؟</p><p>وَالْجَوَاب عَنهُ: أَن فِي الْآيَة تَقْدِيمًا وتأخيرا، فَكَأَن الله تَعَالَى قَالَ: وَلَقَد علمت الْجنَّة إِنَّهُم لمحضرون الْعَذَاب إِلَّا عباد الله المخلصين فَإِنَّهُم لَا يحْضرُون، ثمَّ قَالَ سُبْحَانَ الله عَمَّا يصفونَ؛ فَهَذَا هُوَ التَّقْدِير فِي الْآيَة.</p></div>"
  37,161,"<div class=ar lang=ar><p>قَوْله: <span class="qpc-hafs">﴿فَإِنَّكُم وَمَا تَعْبدُونَ﴾</span> أَي: من الْأَصْنَام،</p></div>"
  37,162,"<div class=ar lang=ar><p>وَقَوله: <span class="qpc-hafs">﴿مَا أَنْتُم عَلَيْهِ بفاتنين﴾</span> أَي: مَا أَنْتُم على الله بمضلين إِلَّا من أضلّهُ الله، قَالَ ابْن عَبَّاس: لَا يضلون إِلَّا من كتب الله لَهُ الضلال، وروى هَذَا القَوْل عَن الْحسن الْبَصْرِيّ وَمُحَمّد بن كَعْب الْقرظِيّ وَإِبْرَاهِيم النَّخعِيّ وَالضَّحَّاك وَغَيرهم.</p><p>قَالَ الشَّاعِر:</p><p>(فَرد بنعمته كَيده ... عَلَيْهِ وَكَانَ لنا فاتنا)</p><p>أَي: مضلا.</p></div>"
  37,163,"<div class=ar lang=ar><p>وَقَالَ بَعضهم: لَا يضلون إِلَّا من كتب الله أَنه يدْخل الْجَحِيم، وَقيل: إِلَّا من أشقاه الله؛ فَهَذَا معنى قَوْله: <span class="qpc-hafs">﴿إِلَّا من هُوَ صال الْجَحِيم﴾</span></p></div>"
  37,164,"<div class=ar lang=ar><p>قَوْله تَعَالَى: <span class="qpc-hafs">﴿وَمَا منا إِلَّا لَهُ مقَام مَعْلُوم﴾</span> هَذَا خبر عَن الْمَلَائِكَة، وَمَعْنَاهُ: وَمَا منا ملك إِلَّا وَله مقَام مَعْلُوم، وَفِي الْخَبَر عَن النَّبِي أَنه قَالَ: " لَيْسَ مَوضِع قدم فِي السَّمَاء إِلَّا وَفِيه ملك قَائِم أَو رَاكِع أَو ساجد ".</p><p>وَيُقَال: إِن مقَام جِبْرِيل عِنْد سِدْرَة الْمُنْتَهى وَلَا مُجَاوزَة لَهُ إِلَى مأواها.</p></div>"
  37,165,"<div class=ar lang=ar><p>قَوْله تَعَالَى: <span class="qpc-hafs">﴿وَإِنَّا لنَحْنُ الصافون﴾</span> أَي: المصطفون فِي السَّمَاء لِلْعِبَادَةِ</p></div>"
  37,166,"<div class=ar lang=ar><p><span class="qpc-hafs">﴿وَإِنَّا لنَحْنُ المسبحون﴾</span> أَي: الممجدون لله، والمنزهون إِيَّاه عَمَّا لَا يَلِيق بِهِ.</p></div>"
  37,167,"<div class=ar lang=ar><p>قَوْله تَعَالَى: <span class="qpc-hafs">﴿وَإِن كَانُوا ليقولون﴾</span> مَعْنَاهُ: وَقد كَانُوا يَقُولُونَ؛ أَي: قُرَيْش.</p></div>"
  37,168,"<div class=ar lang=ar><p>وَقَوله: <span class="qpc-hafs">﴿لَو أَن عندنَا ذكرا من الْأَوَّلين﴾</span> أَي: كتابا ككتاب الْأَوَّلين.</p><p>أَي: كتابا ككتاب الْأَوَّلين.</p></div>"
  37,169,"<div class=ar lang=ar><p>وَقَوله: <span class="qpc-hafs">﴿لَكنا عباد الله المخلصين﴾</span> ظَاهر الْمَعْنى.</p></div>"
  37,170,"<div class=ar lang=ar><p>قَوْله تَعَالَى: <span class="qpc-hafs">﴿فَكَفرُوا بِهِ﴾</span> فِيهِ حذف، والمحذوف: أَنه قد جَاءَهُم الْكتاب وَالذكر فَكَفرُوا بِهِ، وَقَوله: <span class="qpc-hafs">﴿فَسَوف يعلمُونَ﴾</span> تهديد من الله لَهُم.</p></div>"
  37,171,"<div class=ar lang=ar><p>قَوْله تَعَالَى: <span class="qpc-hafs">﴿وَلَقَد سبقت كلمتنا﴾</span> أَي: حكمنَا، وَقَوله: <span class="qpc-hafs">﴿لعبادنا الْمُرْسلين إِنَّهُم لَهُم المنصورون﴾</span> أَي: النُّصْرَة تكون لَهُم، وَقد قَالَ [الله] فِي مَوضِع آخر: <span class="qpc-hafs">﴿كتب الله لأغلبن أَنا ورسلي﴾</span> .</p></div>"
  37,172,"37:171"
  37,173,"<div class=ar lang=ar><p>وَقَوله: <span class="qpc-hafs">﴿وَإِن جندنا لَهُم الغالبون﴾</span> أَي: الْغَلَبَة تكون للْمُؤْمِنين، وَهَذَا لقوم دون قوم، وَفِي وَقت دون وَقت؛ لِأَن الْمُسلمين قد يغلبُونَ وينصر عَلَيْهِم غَيرهم، وَقيل: الْعَاقِبَة تكون لَهُم.</p></div>"
  37,174,"<div class=ar lang=ar><p>وَقَوله تَعَالَى: <span class="qpc-hafs">﴿فتول عَنْهُم حَتَّى حِين﴾</span> أَي: أعرض عَنْهُم حَتَّى حِين أَي: حِين الْمَوْت، وَقيل: إِلَى أَن يَأْتِيهم عَذَاب الله.</p></div>"
  37,175,"<div class=ar lang=ar><p>وَقَوله: <span class="qpc-hafs">﴿وأبصرهم فَسَوف يبصرون﴾</span> قَالَ قَتَادَة: أبصروا حِين لم يَنْفَعهُمْ الْبَصَر،</p></div>"
  37,176,"<div class=ar lang=ar><p>قَوْله تَعَالَى: <span class="qpc-hafs">﴿أفبعذابنا يستعجلون﴾</span> قد بَينا أَنهم قَالُوا: <span class="qpc-hafs">﴿اللَّهُمَّ إِن كَانَ هَذَا هُوَ الْحق من عنْدك فَأمْطر علينا حِجَارَة من السَّمَاء﴾</span> على مَا قَالَ الله، وَقَالَ تَعَالَى فِي مَوضِع آخر: <span class="qpc-hafs">﴿يستعجل بهَا الَّذين لَا يُؤمنُونَ بهَا﴾</span> أَي: يستعجل بالقيامة الَّذين لَا يُؤمنُونَ بهَا.</p></div>"
  37,177,"<div class=ar lang=ar><p>قَوْله تَعَالَى: <span class="qpc-hafs">﴿فَإِذا نزل بِسَاحَتِهِمْ﴾</span> أَي: نزل بِسَاحَتِهِمْ، وَمَعْنَاهُ: أَصَابَهُم الْعَذَاب، وَقَوله: <span class="qpc-hafs">﴿فسَاء صباح الْمُنْذرين﴾</span> أَي: فبئس صباح الَّذين أنذروا بِالْعَذَابِ، وَقد ثَبت أَن النَّبِي لما غزا خَيْبَر، وَوصل إِلَيْهَا رأى الْيَهُود وَقد خَرجُوا بمكاتلهم ومساحيهم من حصونهم؛ فَلَمَّا رآوا الْجَيْش، قَالُوا: مُحَمَّد وَالْخَمِيس؛ فَقَالَ النَّبِي: " الله أكبر خربَتْ خَيْبَر، إِنَّا إِذا نزلنَا بِسَاحَة قوم فسَاء صباح الْمُنْذرين ".</p></div>"
  37,178,"<div class=ar lang=ar><p>قَوْله تَعَالَى: <span class="qpc-hafs">﴿وتول عَنْهُم حَتَّى حِين﴾</span> هُوَ بِمَعْنى الأول، وَذكره على التَّأْكِيد،</p></div>"
  37,179,"<div class=ar lang=ar><p>وَقَوله: <span class="qpc-hafs">﴿وَأبْصر فَسَوف يبصرون﴾</span> أَي: انْتظر حالتهم وَمَا يؤول إِلَيْهِ أَمرهم؛ فينتظرون لحالهم وَمَا ينزل بهم.</p></div>"
  37,180,"<div class=ar lang=ar><p>قَوْله تَعَالَى: <span class="qpc-hafs">﴿سُبْحَانَ رَبك رب الْعِزَّة عَمَّا يصفونَ﴾</span> أَي: ذُو الْعِزَّة،</p></div>"
  37,181,"<div class=ar lang=ar><p>وَقَوله: <span class="qpc-hafs">﴿وَسَلام على الْمُرْسلين﴾</span> أَي: الْأَنْبِيَاء الَّذين أرْسلُوا إِلَى الْخلق.</p></div>"
  37,182,"<div class=ar lang=ar><p>وَقَوله: <span class="qpc-hafs">﴿وَالْحَمْد لله رب الْعَالمين﴾</span> على مَا ذكرنَا، وروى الْأَصْبَغ بن نباتة عَن عَليّ رَضِي الله عَنهُ أَنه قَالَ: من أَرَادَ أَن يكتال الْأجر يَوْم الْقِيَامَة بالمكيال الأوفى، فَلْيَكُن آخر كَلَامه فِي مَجْلِسه: <span class="qpc-hafs">﴿سُبْحَانَ رَبك رب الْعِزَّة عَمَّا يصفونَ﴾</span> إِلَى آخر السُّورَة ".</p><p>وَفِي بعض الْأَخْبَار بِرِوَايَة أبي سعيد الْخُدْرِيّ ((أَن النَّبِي كَانَ إِذا صلى أَو انْصَرف من مَجْلِسه قَالَ <span class="qpc-hafs">﴿سُبْحَانَ رَبك رب الْعِزَّة عَمَّا يصفونَ﴾</span> إِلَى ى خر السُّورَة)) (١) .</p></div>"