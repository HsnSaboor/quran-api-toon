quran[15]{c,v,t}:
  23,90,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿بَلۡ أَتَیۡنَـٰهُم بِٱلۡحَقِّ وَإِنَّهُمۡ لَكَـٰذِبُونَ ۝٩٠﴾</span> - قراءات</h3></p><p><div></p><p><p><span class="item-no">٥٢٠٠٢<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: وهي تُقْرَأ على وجه آخر: (بَلْ أتَيْتَهُمْ){1}<span class=comment-ref>٤٥٧٤</span> يا محمد بالحق؛ بالقرآن{2}. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٤٥٧٤</span> <span class="comment-type-4">قال</span> <u>ابنُ عطية</u> (٦/٣١٧): «قرأ ابن أبي إسحاق: (أتَيتَهم) على الخطاب لمحمد ﷺ».</div></p><p><h3><span class="qpc-hafs">﴿بَلۡ أَتَیۡنَـٰهُم بِٱلۡحَقِّ وَإِنَّهُمۡ لَكَـٰذِبُونَ ۝٩٠﴾</span> - تفسير الآية</h3></p><p><div></p><p><p><span class="item-no">٥٢٠٠٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: فأَكْذَبَهم اللهُ ﷿ حين أشركوا به، فقال سبحانه: <span class="qpc-hafs">﴿بل أتيناهم بالحق﴾</span> يقول: بل جئناهم بالتوحيد، <span class="qpc-hafs">﴿وإنهم لكاذبون﴾</span> في قولهم: إنّ الملائكة بنات الله ﷿{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٢٠٠٤<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿بل أتيناهم بالحق﴾</span>: القرآن، أنزله الله على النبي{2}. (ز)</p></p><p></div></p></div>",footnotes:1:قال المحقق: وفي ابن أبي زمنين ورقة ٢٢٨: أتيتَهم. تفسير يحيى بن سلّام ١/٤١٤.</p><p>وهي قراءة شاذة، تروى أيضًا عن قتادة، وأبي حيوة، وغيرهما. انظر: مختصر ابن خالويه ص١٠٠، والمحتسب ٢/٩٨.تفسير يحيى بن سلّام ١/٤١٤.تفسير مقاتل بن سليمان ٣/١٦٣.تفسير يحيى بن سلّام ١/٤١٤.
  23,91,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿مَا ٱتَّخَذَ ٱللَّهُ مِن وَلَدࣲ وَمَا كَانَ مَعَهُۥ مِنۡ إِلَـٰهٍۚ إِذࣰا لَّذَهَبَ كُلُّ إِلَـٰهِۭ بِمَا خَلَقَ وَلَعَلَا بَعۡضُهُمۡ عَلَىٰ بَعۡضࣲۚ سُبۡحَـٰنَ ٱللَّهِ عَمَّا یَصِفُونَ ۝٩١﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٢٠٠٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: يقول الله تعالى: <span class="qpc-hafs">﴿ما اتخذ الله من ولد﴾</span> يعني: الملائكة، <span class="qpc-hafs">﴿وما كان معه من إله﴾</span> يعني: مِن شريك، فلو كان معه إله <span class="qpc-hafs">﴿إذا لذهب كل إله بما خلق ولعلا بعضهم على بعض﴾</span> كفِعْل ملوك الدنيا، يلتمس بعضُهم قهرَ بعض، ثم نزَّه الربُّ نفسَه جل جلاله عن مقالتهم، فقال تعالى: <span class="qpc-hafs">﴿سبحان الله عما يصفون﴾</span> يعني: عمّا يقولون بأنّ الملائكة بنات الرحمن{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٢٠٠٦<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿ما اتخذ الله من ولد﴾</span> وذلك لقول المشركين: إن الملائكة بنات الله، <span class="qpc-hafs">﴿وما كان معه من إله﴾</span> وذلك لِما عبدوا مِن الأوثان، اتخذوا مع الله آلهة. قال: <span class="qpc-hafs">﴿إذا لذهب كل إله بما خلق﴾</span> يقول: لو كان معه آلهة <span class="qpc-hafs">﴿إذا لذهب كل إله بما خلق ولعلا بعضهم على بعض﴾</span> لَطَلَب بعضُهم مُلْكَ بعضٍ حتى يعلو عليه، كما يفعل ملوك الدنيا، <span class="qpc-hafs">﴿سبحان الله عما يصفون﴾</span> يُنَزِّه نفسه عما يكذبون{2}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٣/١٦٤.تفسير يحيى بن سلّام ١/٤١٤.
  23,92,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿عَـٰلِمِ ٱلۡغَیۡبِ وَٱلشَّهَـٰدَةِ فَتَعَـٰلَىٰ عَمَّا یُشۡرِكُونَ ۝٩٢﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٢٠٠٧<span class="dash">-</span></span> تفسير <span class="name-2">الحسن البصري</span>، قال: <span class="qpc-hafs">﴿عالم الغيب﴾</span>، الغيب هاهنا: ما لم يجِئْ مِن غيب الآخرة{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٢٠٠٨<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿عالم الغيب والشهادة﴾</span> يعني: غيب ما كان، وما يكون، والشهادة، <span class="qpc-hafs">﴿فتعالى﴾</span> يعني: فارتفع <span class="qpc-hafs">﴿عما يشركون﴾</span> لقولهم: الملائكة بنات الله{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٢٠٠٩<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿والشهادة﴾</span> ما أعلمَ العبادَ، <span class="qpc-hafs">﴿فتعالى﴾</span> ارتفع اللهُ <span class="qpc-hafs">﴿عما يشركون﴾</span> يرفع نفسه عما قالوا{3}. (ز)</p></p><p></div></p></div>",footnotes:1:علَّقه يحيى بن سلّام ١/٤١٤.تفسير مقاتل بن سليمان ٣/١٦٤.تفسير يحيى بن سلّام ١/٤١٤.
  23,93,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿قُل رَّبِّ إِمَّا تُرِیَنِّی مَا یُوعَدُونَ ۝٩٣ رَبِّ فَلَا تَجۡعَلۡنِی فِی ٱلۡقَوۡمِ ٱلظَّـٰلِمِینَ ۝٩٤ وَإِنَّا عَلَىٰۤ أَن نُّرِیَكَ مَا نَعِدُهُمۡ لَقَـٰدِرُونَ ۝٩٥﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٢٠١٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿قل رب إما تريني ما يوعدون﴾</span> مِن العذاب، يعني: القتل ببدر، وذلك أنّ النبي ﷺ أراد أن يدعو على كفار مكة، ثم قال: <span class="qpc-hafs">﴿رب فلا تجعلني في القوم الظالمين*وإنا على أن نريك ما نعدهم﴾</span> مِن العذاب <span class="qpc-hafs">﴿لقادرون﴾</span>{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٢٠١١<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: قوله: <span class="qpc-hafs">﴿قل﴾</span> يا محمد: <span class="qpc-hafs">﴿رب إما تريني ما يوعدون﴾</span> من العذاب، <span class="qpc-hafs">﴿رب فلا تجعلني في القوم الظالمين﴾</span> لا تُهْلِكْني معهم إن أريتني ما يوعدون. قوله: <span class="qpc-hafs">﴿وإنا على أن نريك ما نعدهم﴾</span> مِن العذاب <span class="qpc-hafs">﴿لقادرون﴾</span>{2}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٣/١٦٤.تفسير يحيى بن سلّام ١/٤١٤.
  23,94,""
  23,95,""
  23,96,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿ٱدۡفَعۡ بِٱلَّتِی هِیَ أَحۡسَنُ ٱلسَّیِّئَةَۚ﴾</span> - نزول الآية</h3></p><p><div></p><p><p><span class="item-no">٥٢٠١٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: نزلت في النبي ﷺ وأبي جهل -لعنه الله-، حين جهل على النبيِّ ﷺ{1}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿ٱدۡفَعۡ بِٱلَّتِی هِیَ أَحۡسَنُ ٱلسَّیِّئَةَۚ﴾</span> - تفسير الآية</h3></p><p><div></p><p><p><span class="item-no">٥٢٠١٣<span class="dash">-</span></span> عن <span class="name-1">أنس بن مالك</span> -من طريق عبد الوارث- في قوله: <span class="qpc-hafs">﴿ادفع بالتي هي أحسن السيئة﴾</span>، قال: قول الرجل لأخيه ما ليس فيه، فيقول: إن كنت كاذبًا فأنا أسأل الله أن يغفر لك، وإن كنت صادقًا فأنا أسأل الله أن يغفر لي{2}. (١٠/٦١٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٢٠١٤<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن جريج- <span class="qpc-hafs">﴿ادفع بالتي هي أحسن السيئة﴾</span>، يقول: أعْرِض عن أذاهم إيّاك{3}. (١٠/٦١٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٢٠١٥<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق عبد الكريم الجزري- <span class="qpc-hafs">﴿ادفع بالتي هي أحسن السيئة﴾</span>، قال: هو السلام، تُسَلِّم عليه إذا لقِيتَه{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٢٠١٦<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق منصور- في قوله تعالى: <span class="qpc-hafs">﴿ادفع بالتي هي أحسن﴾</span>، قال: المصافحة{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٢٠١٧<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق عوف- في قوله: <span class="qpc-hafs">﴿ادفع بالتي هي أحسن السيئة﴾</span>، قال: واللهِ، لا يصيبُها صاحبُها حتى يكظم غيظًا، ويصفح عمّا يكره{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٢٠١٨<span class="dash">-</span></span> عن <span class="name-2">عطاء</span>، <span class="qpc-hafs">﴿ادفع بالتي هي أحسن السيئة﴾</span>، قال: بالسَّلام{7}. (١٠/٦١٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٢٠١٩<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في الآية، قال: نعمت -واللهِ- جرعة تَتَجَرَّعُها وأنت مظلوم، فمَنِ استطاع أن يغلب الشرَّ بالخير فليفعل، ولا قوة إلا بالله{8}. (١٠/٦١٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٢٠٢٠<span class="dash">-</span></span> تفسير <span class="name-2">إسماعيل السدي</span>: <span class="qpc-hafs">﴿ادفع بالتي هي أحسن السيئة﴾</span>، يقول: ادفع بالعفو والصفح القولَ القبيحَ والأذى{9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٢٠٢١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثم قال الله ﷿ يُعَزِّي نبيَّه ﷺ ليصبر على الأذى: <span class="qpc-hafs">﴿ادفع بالتي هي أحسن السيئة نحن أعلم بما يصفون﴾</span>{1}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿ٱدۡفَعۡ بِٱلَّتِی هِیَ أَحۡسَنُ ٱلسَّیِّئَةَۚ﴾</span> - النسخ في الآية</h3></p><p><div></p><p><p><span class="item-no">٥٢٠٢٢<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: وذلك قبل أن يُؤمَر بقتالهم{11}<span class=comment-ref>٤٥٧٥</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٤٥٧٥</span> <span class="comment-type-4">قال</span> <u>ابنُ عطية</u> (٦/٣١٨): «قوله: <span class="qpc-hafs">﴿ادفع بالتي هي أحسن﴾</span> الآيةَ أمْرٌ بالصفح ومكارم الأخلاق، وما كان منها لهذا فهو محكم باقٍ في الأمة أبدًا، وما فيها مِن معنى موادعة الكفار وترْك التعرُّض لهم والصفح عن أمورهم فمنسوخ بالقتال».</div></p><p><h3><span class="qpc-hafs">﴿نَحۡنُ أَعۡلَمُ بِمَا یَصِفُونَ ۝٩٦﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٢٠٢٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿نحن أعلم بما يصفون﴾</span> مِن الكذب{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٢٠٢٤<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿نحن أعلم بما يصفون﴾</span> بما يكذبون{11}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿نَحۡنُ أَعۡلَمُ بِمَا یَصِفُونَ ۝٩٦﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٥٢٠٢٥<span class="dash">-</span></span> عن أبي هريرة، قال: أتى رجل النبيَّ ﷺ، فقال: يا رسول الله، إنّ لي قرابةً أصِلُهُم ويَقْطَعُونِ، وأُحْسِن إليهم ويُسِيئُون إلَيَّ، ويَجْهَلُون عَلَيَّ وأَحلم عنهم. قال: «<b>لَئِن كان كما تقول كأنّما تُسِفُّهم المَلَّ</b>{14}، <b>ولا يزال معك مِن الله ظهيرٌ عليهم ما دُمْت على ذلك</b>»{15}. (١٠/٦١٤)</p></p><p></div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٣/١٦٥.أخرجه أبو نعيم في الحلية ٨/٢٥٣. وعزاه السيوطي إلى ابن أبي حاتم.أخرجه ابن جرير ١٧/١٠٥، وإسحاق البستي في تفسيره ص٤٠٥. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه عبد الرزاق ٢/٤٨، وابن جرير ١٧/١٠٥.أخرجه أبو نعيم في حلية الأولياء ٣/٢٩٩.أخرجه ابن جرير ١٧/١٠٥.عزاه السيوطي إلى ابن أبي شيبة، وابن المنذر، وابن أبي حاتم.أخرجه ابن جرير ٦/٥٨-٥٩. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.علَّقه يحيى بن سلّام ١/٤١٤.تفسير مقاتل بن سليمان ٣/١٦٥.تفسير يحيى بن سلّام ١/٤١٥.تفسير مقاتل بن سليمان ٣/١٦٥.تفسير يحيى بن سلّام ١/٤١٥.المَلُّ والمَلَّةُ: الرَّمادُ الحارُّ الذي يُحْمى لِيُدْفَنَ فيه الخُبْزُ لِيَنضَجَ، والمعنى: تجعل وجوههم كلون الرَّماد. النهاية (سفف) (ملل).أخرجه مسلم ٤/١٩٨٢ (٢٥٥٨).
  23,97,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَقُل رَّبِّ أَعُوذُ بِكَ مِنۡ هَمَزَ ٰ⁠تِ ٱلشَّیَـٰطِینِ ۝٩٧﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٢٠٢٦<span class="dash">-</span></span> قال <span class="name-1">عبد الله بن عباس</span>: نزغاتهم{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٢٠٢٧<span class="dash">-</span></span> قال <span class="name-2">مجاهد بن جبر</span>: نفخهم، ونَفْثهم{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٢٠٢٨<span class="dash">-</span></span> قال <span class="name-2">الحسن البصري</span>: وساوِسُهم{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٢٠٢٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثم أمره أن يَتَعَوَّذ من الشيطان، فقال تعالى: <span class="qpc-hafs">﴿وقل رب أعوذ بك من همزات الشياطين﴾</span> يعني: الشياطين، في أمر أبي جهل، <span class="qpc-hafs">﴿وأعوذ بك رب أن يحضرون﴾</span>{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٢٠٣٠<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- قال: همزات الشياطين: خَنقُهم الناسَ، فذلك همزاتهم{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٢٠٣١<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: قوله: <span class="qpc-hafs">﴿وقل رب أعوذ بك من همزات الشياطين﴾</span>، وهو الجنون{6}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير الثعلبي ٧/٥٥، وتفسير البغوي ٥/٤٢٨.تفسير الثعلبي ٧/٥٥، وتفسير البغوي ٥/٤٢٨.تفسير الثعلبي ٧/٥٥، وتفسير البغوي ٥/٤٢٨.تفسير مقاتل بن سليمان ٣/١٦٥.أخرجه ابن جرير ١٧/١٠٦.تفسير يحيى بن سلّام ١/٤١٥.
  23,98,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَأَعُوذُ بِكَ رَبِّ أَن یَحۡضُرُونِ ۝٩٨﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٢٠٣٢<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿وأعوذ بك رب أن يحضرون﴾</span>، قال: في شيء مِن أمري{1}. (١٠/٦١٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٢٠٣٣<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: قوله: <span class="qpc-hafs">﴿وأعوذ بك رب أن يحضرون﴾</span> فأُطِيع الشيطان، فأَهْلَك، أمره الله أن يدعو بهذا{2}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَأَعُوذُ بِكَ رَبِّ أَن یَحۡضُرُونِ ۝٩٨﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٥٢٠٣٤<span class="dash">-</span></span> عن عمرو بن شعيب، عن أبيه، عن جدِّه، قال: كان رسول الله ﷺ يُعَلِّمنا كلماتٍ نَقُولُهُنَّ عند النوم مِن الفزع: «<b>بسم الله، أعوذ بكلمات الله التامَّة مِن غضبه، وعقابه، وشرِّ عباده، ومِن همزات الشياطين، وأن يحضرون</b>»{3}. (١٠/٦١٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٢٠٣٥<span class="dash">-</span></span> عن الوليد بن الوليد أنّه قال: يا رسول الله، إنِّي أجد وحْشَةً؟ قال: «<b>إذا أخذت مضجعك فقل: أعوذ بكلمات الله التامة مِن غضبه، وعِقابه، وشرِّ عباده، ومِن همزات الشياطين، وأن يحضرون؛ فإنّه لا يَضُرُّك، وبالحَرى</b>{4} <b>أن لا يقربك</b>»{5}. (١٠/٦١٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٢٠٣٦<span class="dash">-</span></span> عن ابن جريج، قال: قلت ل<span class="name-2">عطاء [بن أبي رباح]</span>: فما <span class="qpc-hafs">﴿وقل رب أعوذ بك من همزات الشياطين﴾</span>؟ قال: قَوْلٌ مِن القرآن ليس بواجب في الصلاة{6}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ١٧/١٠٦. وعزاه السيوطي إلى ابن أبي حاتم.تفسير يحيى بن سلّام ١/٤١٥.أخرجه أحمد ١١/٢٩٥-٢٩٦ (٦٦٩٦)، وأبو داود ٦/٤٠ (٣٨٩٣) بنحوه، والترمذي ٦/١٣٢ (٣٨٣٩)، والحاكم ١/٧٣٣ (٢٠١٠).</p><p>قال الترمذي: «هذا حديث حسن غريب». وقال الحاكم: «هذا حديث صحيح الإسناد، متصل في موضع الخلاف».بالحَرى أن يكون كذا: جَدِير وخَليْق. النهاية (حرا).أخرجه أحمد ٢٧/١٠٨ (١٦٥٧٣)، ٣٩/٢٥٨ (٢٣٨٣٩)، وفيه محمد بن يحيى بن حبان.</p><p>قال البيهقي في الأسماء والصفات ١/٤٧٤-٤٧٥ (٤٠٦): «هذا مرسل». وقال المنذري في الترغيب ٢/٣٠٢ (٢٤٨٠): «محمد لم يسمع مِن الوليد». وقال الهيثمي في المجمع ١٠/١٢٣ (١٧٠٤٨): «رجاله رجال الصحيح، إلا أنّ محمد بن يحيى بن حبان لم يسمع مِن الوليد بن الوليد». وقال البوصيري في إتحاف الخيرة المهرة ٦/٤٠٢ (٦٠٩٤): «هذا حديث رجاله ثقات». وقال الألباني في الصحيحة ٦/٥٣٦: «رجال إسناده ثقات، رجال الشيخين، لكنه مُنقَطِع».أخرجه عبد الرزاق ٢/٨٥ (٢٥٨٣).
  23,99,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿حَتَّىٰۤ إِذَا جَاۤءَ أَحَدَهُمُ ٱلۡمَوۡتُ قَالَ رَبِّ ٱرۡجِعُونِ ۝٩٩﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٢٠٣٧<span class="dash">-</span></span> عن جابر بن عبد الله، قال: قال رسول الله ﷺ: «<b>إذا حضر الإنسانَ الوفاةُ يُجْمَع له كلُّ شيء يمنعه عن الحق، فيُجعَل بين عينيه، فعند ذلك يقول</b>: <span class="qpc-hafs">﴿رب ارجعون لعلي أعمل صالحا فيما تركت﴾</span>»{1}. (١٠/٦١٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٢٠٣٨<span class="dash">-</span></span> عن ابن جُرَيج، قال: زعموا أنّ النبيَّ ﷺ قال لعائشة: «<b>إنّ المؤمن إذا عايَنَ الملائكةَ قالوا: نُرجِعُك إلى الدنيا؟ فيقول: إلى دار الهموم والأحزان؟! بل قُدُمًا إلى الله. وأمّا الكافر فيقولون له: نُرجِعُك؟ فيقول</b>: <span class="qpc-hafs">﴿ارجعون لعلي أعمل صالحا فيما تركت﴾</span>»{2}. (١٠/٦١٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٢٠٣٩<span class="dash">-</span></span> عن ابن وهب، قال: بلغني عن أبي هريرة أنه قال: قال رسول الله ﷺ: «<b>سألوا الرجعة لكي يُؤمِنوا بما كانوا يُكَذِّبون، وهم عِطاش لا يَرْوون، وجِياع لا يشبعون، وعُراة فلا يَكْتَسُون، [مغلوبين فلا ينتصرون، محزونين، مغلوبين، محسورين] أنفسَهم، وأهليهم، وأموالهم، ومكاسبهم</b>»{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٢٠٤٠<span class="dash">-</span></span> عن <span class="name-1">أبي هريرة</span> -من طريق أبي حازم- قال: إذا وُضِع الكافرُ في قبره فيرى مقعده مِن النار، قال: ربِّ، ارجعونِ حتى أتوب؛ أعمل صالحًا. فيقال: قد عُمِّرْتَ ما كنت مُعَمَّرًا. فيضيق عليه قبره، فهو كالمنهوش{4}، ينام ويفزع، تهوي إليه هوامُّ الأرض؛ حياتها وعقاربها{5}. (١٠/٦١٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٢٠٤١<span class="dash">-</span></span> عن <span class="name-2">الضَّحّاك بن مُزاحِم</span> -من طريق عبيد- يقول في قوله: <span class="qpc-hafs">﴿حتى إذا جاء أحدهم الموت قال رب ارجعون﴾</span>: يعني: أهل الشرك{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٢٠٤٢<span class="dash">-</span></span> قال <span class="name-2">الحسن البصري</span>: قوله: <span class="qpc-hafs">﴿حتى إذا جاء أحدهم الموت قال رب ارجعون﴾</span>، ليس أحدٌ مِن خَلْقِ الله ليس لله بوَلِيٍّ إلا وهو يسأل الله الرجعةَ إلى الدنيا عند الموت بكلام يتكلم به، وإن كان أخرس لم يتكلم في الدنيا بحرفٍ قطُّ، وذلك إذا استبان له أنّه مِن أهل النار سأل الله الرجعةَ، ولا يسمعه مَن يليه{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٢٠٤٣<span class="dash">-</span></span> عن أبي معشر، قال: كان <span class="name-2">محمد بن كعب القرظي</span> يقرأ علينا: <span class="qpc-hafs">﴿حتى إذا جاء أحدهم الموت قال رب ارجعون﴾</span>. قال محمد: إلى أيِّ شيء يُريد؟ إلى أيِّ شيء يرغب؟ أجَمْعَ المال، أو غَرْس الغِراس، أو بَنْيَ بنيان، أو شق أنهار؟ ثم يقول: <span class="qpc-hafs">﴿لعلي أعمل صالحا فيما تركت﴾</span>. يقول الجبار: <span class="qpc-hafs">﴿كلا﴾</span>{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٢٠٤٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿حتى إذا جاء أحدهم الموت﴾</span> يعني: الكفار؛ <span class="qpc-hafs">﴿قال رب ارجعون﴾</span> إلى الدُّنيا حين يُعايِنُ مَلَكَ الموت يُؤخَذ بلسانه، فينظر إلى سَيِّئاته قبل الموت، فلمّا هجم على الخزي سأل الرجعة إلى الدنيا ليعمل صالحًا فيما ترك، فذلك قوله سبحانه: <span class="qpc-hafs">﴿رب ارجعون﴾</span> إلى الدنيا{9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٢٠٤٥<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿رب ارجعون﴾</span> قال: هذه في الحياة، ألا تراه يقول: <span class="qpc-hafs">﴿حتى إذا جاء أحدهم الموت﴾</span> قال: حين تنقطع الدنيا، ويُعايِن الآخرةَ قبل أن يذوق الموت{10}<span class=comment-ref>٤٥٧٦</span>. (١٠/٦١٦)</p></p><p></div></p><p><div><span class=comment-ref>٤٥٧٦</span> <span class="comment-type-4">ذكر</span> <u>ابنُ عطية</u> (٦/٣٢٠) أنّ قوله: <span class="qpc-hafs">﴿ارْجِعُونِ﴾</span> معناه: إلى الحياة الدنيا، ثم قال: «وجمع الضمير يتخرج على معنيين: إما أن يخاطبه مخاطبة الجمع تعظيمًا على نحو إخباره تعالى عن نفسه بنون الجماعة في غير موضع، وإما أن تكون استغاثة بربه أوَّلًا، ثم خاطب ملائكة العذاب بقوله: <span class="qpc-hafs">﴿ارْجِعُونِ﴾</span>».</div></p></div>",footnotes:1:أخرجه ابن المقرئ في معجمه ص٢٥٤ (٨٣٣)، من طريق خالد العبد، عن صفوان بن سليم، عن عطاء، عن جابر به.</p><p>إسناده تالف؛ فيه خالد بن عبد الرحمن العبد، رماه عمرو بن علي بالوضع، وكذّبه الدارقطني، وقال ابن حبان: «كان يسرق الحديث، ويُحَدِّث مِن كتب الناس» كما في لسان الميزان لابن حجر ٣/٣٥٠.</p><p>وأخرج نحوه يحيى بن سلّام في تفسيره ١/٤١٥ عن رجل من بني حارثة.أخرجه ابن جرير ١٧/١٠٧-١٠٨.</p><p>قال الشوكاني في فتح القدير ٣/٥٩٣: «مرسل».أخرجه إسحاق البستي في تفسيره ص٤٠٦.</p><p>وفيه انقطاع بين ابن وهب وأبي هريرة، وما بين المعقوفين ذكر محققه أنه كذا في الأصل، كما أن فيه اضطراب لفظًا ومعنى، وأيضًا لعل فيه سقطًا.المنهوش: المهزول المجهود. النهاية (نهش).أخرجه ابن أبي حاتم -كما في تفسير ابن كثير ٥/٤٨٧-٤٨٨-. وعزاه السيوطي إلى ابن أبي الدنيا في ذِكْر الموت.أخرجه ابن جرير ١٧/١٠٨، وإسحاق البستي في تفسيره ص٤٠٦.علَّقه يحيى بن سلّام ١/٤١٥.أخرجه ابن جرير ١٧/١٠٧. وعلَّقه ابنُ أبي الدنيا في كتاب ذكر الموت -موسوعة ابن أبي الدنيا ٥/٤٧٨ (٢٦٤)-.تفسير مقاتل بن سليمان ٣/١٦٥.أخرجه ابن جرير ١٧/١٠٧. وعزاه السيوطي إلى ابن أبي حاتم.
  23,100,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿لَعَلِّیۤ أَعۡمَلُ صَـٰلِحࣰا فِیمَا تَرَكۡتُۚ كَلَّاۤۚ إِنَّهَا كَلِمَةٌ هُوَ قَاۤىِٕلُهَاۖ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٢٠٤٦<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عكرمة- في قوله: <span class="qpc-hafs">﴿لعلي أعمل صالحا﴾</span>، قال: أقول: لا إله إلا الله{1}. (١٠/٦١٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٢٠٤٧<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span>، في قوله: <span class="qpc-hafs">﴿لعلي أعمل صالحا فيما تركت﴾</span>، قال: لَعَلِّي أقول: لا إله إلا الله{2}. (١٠/٦١٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٢٠٤٨<span class="dash">-</span></span> قال <span class="name-2">قتادة بن دعامة</span>: ما تَمَنّى أن يرجع إلى أهله وعشيرته، ولا لِيَجْمَع الدنيا ويقضي الشهوات، ولكن تَمَنّى أن يرجع فيعمل بطاعة الله، فرَحِم اللهُ امرءًا عمِل فيما يَتَمَنّاه الكافرُ إذا رأى العذاب{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٢٠٤٩<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: وأخبرني رجل مِن أهل الكوفة عن <span class="name-2">السدي</span>، قال: إنّ الكافر إذا نزل به الموتُ، وعاين حسناتِه قليلةً وسيئاتِه كثيرةً؛ نَظَر إلى مَلَك الموت مِن قَبْلِ أن يخرج من الدنيا، فتَمَنّى الرجعة، وصدَّق بما كذب به، فعند ذلك يقول: <span class="qpc-hafs">﴿رب ارجعون﴾</span> يعني: إلى الدنيا، <span class="qpc-hafs">﴿لعلي أعمل صالحا فيما تركت﴾</span>. يقول الله: <span class="qpc-hafs">﴿كلا﴾</span> يعني: لا يرجع إلى الدنيا. ثم استأنف، فقال: <span class="qpc-hafs">﴿كلا إنها كلمة هو قائلها﴾</span> ولا يسمع بها بنو آدم. ونحوُ ذلك مثلُ قول فرعون في سورة يونس{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٢٠٥٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿لعلي﴾</span> يعني: لكي <span class="qpc-hafs">﴿أعمل صالحا فيما تركت﴾</span> مِن العمل الصالح، يعني: الإيمان، يقول ﷿: <span class="qpc-hafs">﴿كلا﴾</span> لا يُرَدُّ إلى الدنيا. ثم استأنف، فقال: <span class="qpc-hafs">﴿إنها كلمة هو قائلها﴾</span> يعني بالكلمة: قوله: <span class="qpc-hafs">﴿رب ارجعون﴾</span>{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٢٠٥١<span class="dash">-</span></span> قال <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿كلا إنها كلمة هو قائلها﴾</span>: لا بُدَّ له أن يقولها{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٢٠٥٢<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿لعلي أعمل صالحا فيما تركت﴾</span> فيما صنعتُ. قال الله: <span class="qpc-hafs">﴿كلا﴾</span> لستَ براجع إلى الدنيا. وهي مثل قوله: <span class="qpc-hafs">﴿وأنفقوا من ما رزقناكم من قبل أن يأتي أحدكم الموت فيقول رب لولا أخرتني إلى أجل قريب فأصدق وأكن من الصالحين﴾</span> [المنافقون:١٠]. ثم قال: <span class="qpc-hafs">﴿كلا إنها كلمة هو قائلها﴾</span> هذه الكلمة: <span class="qpc-hafs">﴿قال رب ارجعون (٩٩) لعلي أعمل صالحا فيما تركت﴾</span>{7}<span class=comment-ref>٤٥٧٧</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٤٥٧٧</span> <span class="comment-type-4">ذكر</span> <u>ابنُ عطية</u> (٦/٣٢١) أن قوله: <span class="qpc-hafs">﴿إنَّها كَلِمَةٌ هُوَ قائِلُها﴾</span> يحتمل ثلاثة معانٍ: <b>الأول</b>: الإخبار المؤكد بأن هذا الشيء يقع ويقول هذه الكلمة. <b>الثاني</b>: أن يكون المعنى: إنها كلمة لا تغني أكثر من أن يقولها ولا نفع له فيها ولا غوث. <b>الثالث</b>: أن تكون إشارةً إلى أنه لو رُدَّ لعاد فتكون آية ذمٍّ لهم.</div></p><p><h3><span class="qpc-hafs">﴿وَمِن وَرَاۤىِٕهِم﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٢٠٥٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثم قال سبحانه: <span class="qpc-hafs">﴿ومن ورائهم برزخ﴾</span>، يعني: ومِن بعد الموت أجل{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٢٠٥٤<span class="dash">-</span></span> عن <span class="name-3">سفيان بن حسين</span>، في قوله: <span class="qpc-hafs">﴿ومن ورائهم برزخ﴾</span>، قال: أمامهم{9}. (١٠/٦١٧)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿بَرۡزَخٌ إِلَىٰ یَوۡمِ یُبۡعَثُونَ ۝١٠٠﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٢٠٥٥<span class="dash">-</span></span> عن <span class="name-1">عائشة</span> -من طريق سعيد بن المسيب- قالت: ويْلٌ لأهل المعاصي مِن أهل القبور؛ يدخل عليهم في قبورهم حيّاتٌ سود؛ حَيَّةٌ عند رأسه، وحَيَّةٌ عند رجليه، يقرضانه حتى يلتقيان في وسطه، فذلك العذاب في البرزخ الذي قال الله: <span class="qpc-hafs">﴿ومن ورائهم برزخ إلى يوم يبعثون﴾</span>{10}. (١٠/٦١٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٢٠٥٦<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق العوفي- <span class="qpc-hafs">﴿ومن ورائهم برزخ إلى يوم يبعثون﴾</span>، يقول: أجل إلى حين{11}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٢٠٥٧<span class="dash">-</span></span> قال <span class="name-1">عبد الله بن عباس</span>: حجاب{12}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٢٠٥٨<span class="dash">-</span></span> عن <span class="name-1">أبي أُمامة</span> -من طريق أبي يوسف-: أنّه شهِد جنازة، فلمّا دُفِن الميتُ قال: هذا برزخ إلى يوم يبعثون{13}. (١٠/٦١٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٢٠٥٩<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span> -من طريق جعفر- في قوله: <span class="qpc-hafs">﴿ومن ورائهم برزخ﴾</span>، قال: ما بعد الموت{14}. (١٠/٦١٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٢٠٦٠<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق فطر بن خليفة- في قوله: <span class="qpc-hafs">﴿ومن ورائهم برزخ إلى يوم يبعثون﴾</span>، قال: ما بين الموت إلى البعث{15}. (١٠/٦١٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٢٠٦١<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span>، قال: البرزخ: الحاجِز ما بين الدنيا والآخرة{9}. (١٠/٦١٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٢٠٦٢<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- <span class="qpc-hafs">﴿ومن ورائهم برزخ إلى يوم يبعثون﴾</span>، قال: حجاز بين الميِّت والرجوع إلى الدنيا{17}. (١٠/٦١٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٢٠٦٣<span class="dash">-</span></span> عن <span class="name-2">الضَّحّاك بن مُزاحِم</span> -من طريق عبيد- قال: البرزخ: ما بين الدنيا والآخرة{18}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٢٠٦٤<span class="dash">-</span></span> قال <span class="name-2">الضَّحّاك بن مُزاحِم</span>: البرزخ: ما بين الموت إلى البعث{19}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٢٠٦٥<span class="dash">-</span></span> عن أبي مُحَلِّمٍ، قال: قيل ل<span class="name-2">عامر الشعبي</span>: مات فلان. قال: ليس هو في الدنيا ولا في الآخرة، هو في البرزخ{20}. (١٠/٦١٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٢٠٦٦<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق أبي رجاء- في الآية، قال: البَرْزَخ بين الدنيا والآخرة{21}. (١٠/٦١٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٢٠٦٧<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق المبارك بن فضالة- قال: البرزخ: هي هذه القبور التي بينكم وبين الآخرة{22}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٢٠٦٨<span class="dash">-</span></span> عن أبي المقدام، قال: كُنت أُسايِر <span class="name-2">الحسنَ</span> ونحن راجعون مِن جنازة بكر بن عبد الله، فقلتُ: أرأيتَ قول الله ﷿: <span class="qpc-hafs">﴿ومن ورائهم برزخ إلى يوم يبعثون﴾</span>. فنظر عن يمينه وعن شماله، فقال: هُم هؤلاء في البرزخ كما ترون؛ يركضون عليهم؛ هما يحيكم{23}؛ لا يسمعون الصوت{24}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٢٠٦٩<span class="dash">-</span></span> عن <span class="name-2">محمد بن كعب القرظي</span>، قال: البرزخ: ما بين الدنيا والآخرة؛ ليس مع أهل الدنيا يأكلون ويشربون، ولا مع أهل الآخرة يُجازَوْن بأعمالهم{9}. (١٠/٦١٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٢٠٧٠<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق مَعْمَر- قال: برزخ بقيةَ الدنيا{26}. (١٠/٦١٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٢٠٧١<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿ومن ورائهم برزخ﴾</span>، قال: أهل القبور في بَرْزَخ ما بين الدنيا والآخرة، هم فيه إلى يوم يبعثون{27}. (١٠/٦١٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٢٠٧٢<span class="dash">-</span></span> قال <span class="name-2">إسماعيل السُّدِّيّ</span>: أجَلٌ{12}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٢٠٧٣<span class="dash">-</span></span> قال <span class="name-2">إسماعيل السُّدِّيّ</span>: البرزخ: ما بين النفختين{29}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٢٠٧٤<span class="dash">-</span></span> عن <span class="name-2">الربيع</span>، قال: البرزخ: القبور{30}. (١٠/٦١٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٢٠٧٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثم قال سبحانه: <span class="qpc-hafs">﴿ومن ورائهم برزخ﴾</span> يعني: ومِن بعد الموت أجَلٌ <span class="qpc-hafs">﴿إلى يوم يبعثون﴾</span> يعني: يُحْشَرون بعد الموت{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٢٠٧٦<span class="dash">-</span></span> عن <span class="name-3">أبي صخر [حميد بن زياد الخراط]</span>، قال: البرزخ: المقابر، لا هم في الدنيا، ولا هم في الآخرة، فهم مُقِيمون إلى يوم يبعثون{9}. (١٠/٦١٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٢٠٧٧<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿ومن ورائهم برزخ إلى يوم يبعثون﴾</span>، قال: البرزخ: ما بين الموت إلى البعث{11}<span class=comment-ref>٤٥٧٨</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٤٥٧٨</span> <span class="comment-type-4">ذكر</span> <u>ابنُ عطية</u> (٦/٣٢١) أنّ البرزخ <span class="mustanad">في كلام العرب</span>: الحاجز بين المسافتين، ثم يستعار لِما عَدا ذلك، وأنّه هنا للمدة التي بين موت الإنسان وبين بعثه، ثم قال: «<span class="mustanad">هذا إجماع من المفسرين</span>».</div></p></div>",footnotes:1:أخرجه البيهقي في الأسماء والصفات (٢٠٥).عزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.تفسير البغوي ٥/٤٢٨.تفسير يحيى بن سلّام ١/٤١٥. يشير إلى قوله تعالى: <span class="qpc-hafs">﴿حَتّى إذا أدْرَكَهُ الغَرَقُ قالَ آمَنتُ أنَّهُ لا إلَهَ إلّا الَّذِي آمَنَتْ بِهِ بَنُو إسْرائِيلَ وأَنا مِنَ المُسْلِمِينَ﴾</span> [يونس:٩٠].تفسير مقاتل بن سليمان ٣/١٦٥.أخرجه ابن جرير ١٧/١٠٨.تفسير يحيى بن سلّام ١/٤١٥.تفسير مقاتل بن سليمان ٣/١٦٥.عزاه السيوطي إلى ابن أبي حاتم.أخرجه ابن أبي حاتم -كما في تفسير ابن كثير ٥/٤٨٧-٤٨٨-.أخرجه ابن جرير ١٧/١٠٩.تفسير الثعلبي ٧/٥٦.أخرجه ابن جرير ١٧/١٠٩. وعزاه السيوطي إلى سعيد بن منصور، وابن المنذر، وابن أبي حاتم، وسمويه في فوائده.أخرجه ابن جرير ١٧/١٠٩، وإسحاق البستي في تفسيره ص٤٠٦.أخرجه يحيى بن سلّام ١/٤١٦، وهناد (٣١٤)، وابن جرير ١٧/١١٠، وأبو نعيم في الحلية ٣/٢٩٠. وعزاه السيوطي إلى ابن أبي شيبة، وعبد بن حميد، وابن المنذر.عزاه السيوطي إلى ابن أبي حاتم.أخرجه ابن جرير ١٧/١١٠. وعزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ١٧/١١١، وإسحاق البستي في تفسيره ص٤٠٧.تفسير الثعلبي ٧/٥٦، وتفسير البغوي ٥/٤٢٨.أخرجه هناد (٣١٥).أخرجه إسحاق البستي في تفسيره ص٤٠٧. وعزاه السيوطي إلى عبد بن حميد.أخرجه آدم بن أبي إياس -كما في تفسير مجاهد ص٤٨٨-.كذا في المصدر: هما يحيكم، وهو كذلك في طبعة مكتبة الغرباء الأثرية ط١، ١٤٢٠ﻫ-٢٠٠٠م، ص١٣٣، ١٤٩.أخرجه ابن أبي الدنيا في كتاب القبور -موسوعة ابن أبي الدنيا ٦/٨٨ (١٤٩)-.عزاه السيوطي إلى ابن أبي حاتم.أخرجه عبد الرزاق ٢/٤٨، وابن جرير ١٧/١١٠. وعزاه السيوطي إلى عبد بن حميد.أخرجه يحيى بن سلّام ١/٤١٦ بنحوه. وعزاه السيوطي إلى عبد بن حميد.تفسير الثعلبي ٧/٥٦.علَّقه يحيى بن سلّام ١/٤١٦.عزاه السيوطي إلى عبد بن حميد.تفسير مقاتل بن سليمان ٣/١٦٥.عزاه السيوطي إلى ابن أبي حاتم.أخرجه ابن جرير ١٧/١٠٩.
  23,101,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿فَإِذَا نُفِخَ فِی ٱلصُّورِ فَلَاۤ أَنسَابَ بَیۡنَهُمۡ یَوۡمَىِٕذࣲ وَلَا یَتَسَاۤءَلُونَ ۝١٠١﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٢٠٧٨<span class="dash">-</span></span> قال <span class="name-1">عبد الله بن مسعود</span>: هي النفخة الثانية{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٢٠٧٩<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن مسعود</span> -من طريق زاذان- قال: إذا كان يومُ القيامة جَمَع الله الأولين والآخرين -وفي لفظ: يُؤخَذ بيد العبد أو الأَمَة يوم القيامة على رؤوس الأولين والآخرين-، ثم يُنادي مُنادٍ: ألا إنّ هذا فلان بن فلان، فمَن كان له حَقٌّ قِبَلَه فليأت إلى حقِّه- وفي لفظ: من كان له مظلمة فليجئْ فليأخذ حقَّه-. فيفرح -واللهِ- المرءُ أن يكون له الحقُّ على والده، أو ولده، أو زوجته، وإن كان صغيرًا، ومِصداق ذلك في كتاب الله: <span class="qpc-hafs">﴿فإذا نفخ في الصور فلا أنساب بينهم يومئذ ولا يتساءلون﴾</span>{2}. (١٠/٦٢٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٢٠٨٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطاء-: إنّها الثانية، فلا أنساب بينهم{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٢٠٨١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- في قوله: <span class="qpc-hafs">﴿فلا أنساب بينهم يومئذ ولا يتساءلون﴾</span>، قال: فذلك حين يُنفَخ في الصور، فلا يبقى حَيٌّ إلا الله، <span class="qpc-hafs">﴿وأقبل بعضهم على بعض يتساءلون﴾</span> [الصافات:٢٧] فذلك إذا بُعِثوا في النفخة الثانية{4}. (١٠/٦١٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٢٠٨٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> أنّه سُئِل عن قوله: <span class="qpc-hafs">﴿فلا أنساب بينهم ولا يتساءلون﴾</span>، وقوله: <span class="qpc-hafs">﴿وأقبل بعضهم على بعض يتساءلون﴾</span> [الصافات:٢٧]. فقال: إنّها مواقف؛ فأمّا الموقف الذي لا أنساب بينهم ولا يتساءلون عِند الصَّعْقَةِ الأولى لا أنساب بينهم فيها إذا صُعقوا، فإذا كانت النفخة الآخرة فإذا هم قيام يتساءلون{5}. (١٠/٦٢٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٢٠٨٣<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق سعيد بن جبير- أنّه سُئِل عن الآيتين. فقال: أمّا قوله: <span class="qpc-hafs">﴿ولا يتساءلون﴾</span> فهذا في النفخة الأولى حين لا يبقى على الأرض شيء، وأمّا قوله: <span class="qpc-hafs">﴿وأقبل بعضهم على بعض يتساءلون﴾</span> [الصافات:٢٧] فإنّهم لَمّا دخلوا الجنَّةَ أقبل بعضُهم على بعضٍ يتساءلون{6}. (١٠/٦٢٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٢٠٨٤<span class="dash">-</span></span> عن سعيد بن جبير، قال: قال رجل <span class="name-1">لابن عباس</span>: إنِّي أجِد في القرآن أشياءَ تختلف عَلَيَّ! قال: <span class="qpc-hafs">﴿فلا أنساب بينهم يومئذ ولا يتساءلون﴾</span>، <span class="qpc-hafs">﴿وأقبل بعضهم على بعض يتساءلون﴾</span> [الصافات:٢٧]. فقال: <span class="qpc-hafs">﴿فلا أنساب بينهم﴾</span> في النفخة الأولى، ثم ينفخ في الصور: <span class="qpc-hafs">﴿فصعق من في السموات ومن في الأرض إلا من شاء الله﴾</span> [الزمر:٦٨] فلا أنساب بينهم عند ذلك ولا يتساءلون، ثم في النفخة الآخرة أقبل بعضهم على بعض يتساءلون{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٢٠٨٥<span class="dash">-</span></span> قال <span class="name-2">أبو العالية الرِّياحِيِّ</span>: هو كقوله: <span class="qpc-hafs">﴿ولا يَسْأَلُ حَمِيمٌ حَمِيمًا﴾</span> [المعارج: ١٠]{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٢٠٨٦<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span>: <span class="qpc-hafs">﴿فلا أنساب بينهم﴾</span> يَتَعاطَفُون عليها كما كانوا يَتَعاطَفُون عليها في الدنيا، <span class="qpc-hafs">﴿ولا يتساءلون﴾</span> عليها أن يحمل بعضُهم عن بعض كما كانوا يتساءلون في الدنيا بأنسابهم، كقول الرجل: أسألك بالله وبالرَّحِم{9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٢٠٨٧<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span>، في الآية، قال: ليس أحدٌ مِن الناس يسأل أحدًا بنسبه، ولا بقرابته شيئًا{10}. (١٠/٦١٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٢٠٨٨<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق سفيان- <span class="qpc-hafs">﴿فلا أنساب بينهم يومئذ ولا يتساءلون﴾</span>، قال: في النفخة الأولى{11}. (١٠/٦١٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٢٠٨٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فإذا نفخ في الصور﴾</span> يعني: النفخة الثانية؛ <span class="qpc-hafs">﴿فلا أنساب بينهم﴾</span> يعني: لا نسبة بينهم؛ عم، وابن عم، وأخ، وابن أخ، وغيره، <span class="qpc-hafs">﴿يومئذ ولا يتساءلون﴾</span> يقول: ولا يسأل حميمٌ حميمًا{12}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٢٠٩٠<span class="dash">-</span></span> عن <span class="name-3">عبد الملك ابن جُرَيْج</span> -من طريق حجّاج- في الآية، قال: لا يُسألُ أحدٌ يومئذ بنَسَب شيئًا، ولا يتساءلون، ولا يَمُتُّ إليه برحم{13}. (١٠/٦١٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٢٠٩١<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: قوله: <span class="qpc-hafs">﴿فإذا نفخ في الصور﴾</span> والصور: قَرْن.= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٢٠٩٢<span class="dash">-</span></span> في تفسير عمرو [بن عبيد]، عن <span class="name-2">الحسن</span>: أنّ أنسابَهم يومئذٍ قائمةٌ معروفةٌ، قال: <span class="qpc-hafs">﴿يوم يفر المرء من أخيه (٣٤) وأمه وأبيه﴾</span> [عبس:٣٤-٣٥]، وسمعتُ بعضَ الكوفيين يقول: <span class="qpc-hafs">﴿يبصرونهم﴾</span> [المعارج:١١] أي: يرونهم. يقول: يعرفونهم في مواطن، ولا يعرفونهم في مواطن{9}<span class=comment-ref>٤٥٧٩</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٤٥٧٩</span> اختُلِف في صِفة ارتفاع الأنساب المذكورة في الآية، ومتى يكون ذلك، على قولين: <b>أحدهما</b>: أنّ هذا في النفخة الأولى، وذلك أنّ الناس بأجمعهم يموتون فلا يكون بينهم نسب في ذلك الوقت وهم أموات. <b>والآخر</b>: أنّ هذا عند النفخة الثانية، وقيام الناس من القبور فهم حينئذ لِهَول المطلع واشتغال كل امرئٍ بنفسه، قد انقطعت بينهم الوسائل، وزال انتفاع الأنساب؛ فلذلك نفاها، فالمعنى: فلا أنساب نافعة.</p><p>و<span class="comment-type-4">علَّقَ</span> <u>ابنُ عطية</u> (٦/٣٢١-٣٢٢) على القول الأول بقوله: «هذا التأويل يُزيل ما في الآية مِن ذِكْر هول الحشر». ثم قال: «وكذلك ارتفاع التساؤل لهذه الوجوه التي ذكرناها، ثم يأتي في القيامة مواطن يكون فيها السؤال والتعارف. وهذا التأويل حسن، وهو مرويُّ المعنى عن ابن عباس».</div></p><p><h3><span class="qpc-hafs">﴿فَإِذَا نُفِخَ فِی ٱلصُّورِ فَلَاۤ أَنسَابَ بَیۡنَهُمۡ یَوۡمَىِٕذࣲ وَلَا یَتَسَاۤءَلُونَ ۝١٠١﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٥٢٠٩٣<span class="dash">-</span></span> قال عمر بن الخطاب: سمعتُ رسولَ الله ﷺ يقول: «<b>كُلُّ سَبَبٍ ونَسَبٍ مُنقَطِع يوم القيامة إلّا سَبَبي ونسبي</b>»{15}. (١٠/٦٢١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٢٠٩٤<span class="dash">-</span></span> عن عبد الله بن عمر، قال: قال رسول الله ﷺ: «<b>كُلُّ نَسَب وصِهْر ينقطع يوم القيامة إلا نَسَبي وصِهْري</b>»{16}. (١٠/٦٢٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٢٠٩٥<span class="dash">-</span></span> عن المِسْور بن مخرمة، قال: قال رسول الله ﷺ: «<b>إنّ الأنساب تنقطع يوم القيامة غير نسبي وسببي وصهري</b>»{17}. (١٠/٦٢١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٢٠٩٦<span class="dash">-</span></span> عن أنس بن مالك، قال: قال رسولُ الله ﷺ: «<b>إذا دخل أهلُ الجنة الجنةَ وأهلُ النار النارَ نادى مُنادٍ مِن أهل العرش: يا أهل التَّظالُم، تَتارَكُوا مظالِمَكم، وادخلوا الجنة</b>»{18}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٢٠٩٧<span class="dash">-</span></span> عن الحسن البصري، قال: قال رسول الله ﷺ: «<b>ثلاثة مواطن لا يَسْأَلُ فيها أحدٌ أحدًا: إذا وُضِعت الموازين حتى يعلم أيثقل ميزانه أم يخف، وإذا تطايرت الكتب حتى يعلم أيأخذ كتابه بيمينه أم بشماله، وعند الصراط حتى يعلم أيَجُوزُ الصراطَ أم لا يجوز</b>»{19}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٢٠٩٨<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق حفص بن المغيرة- قال: ليس شيءٌ أبغضَ إلى الانسان يوم القيامة مِن أن يرى مَن يعرفه؛ مخافة أن يَذُوبَ{20} له عليه شيء. ثم قرأ: <span class="qpc-hafs">﴿يوم يفر المرء من أخيه﴾</span> [عبس:٣٤]{21}. (١٠/٦٢١)</p></p><p></div></p></div>",footnotes:1:تفسير الثعلبي ٧/٥٧.أخرجه ابن أبي الدنيا في كتاب الأهوال -موسوعة ابن أبي الدنيا ٦/٢٤٧ (٢٥٩) - مُطَوَّلًا، وابن جرير ١٧/١١٢-١١٣، وأبو نعيم في الحلية ٤/٢٠١-٢٠٢، وابن عساكر ١٨/٢٨٥. وعزاه السيوطي إلى ابن المبارك في الزهد، وابن المنذر، وابن أبي حاتم.تفسير البغوي ٥/٤٢٩.أخرجه ابن جرير ١٧/١١٢. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.عزاه السيوطي إلى سعيد بن منصور، وعبد بن حميد، وابن المنذر، وابن أبي حاتم.أخرجه ابن جرير ١٧/١١١، والحاكم ٢/٣٩٤ من وجه آخر.أخرجه البخاري مطولًا - كتاب التفسير ٤/١٨١٦.تفسير الثعلبي ٧/٥٦.علَّقه يحيى بن سلّام ١/٤١٦.عزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ١٧/١١١-١١٢. وعزاه السيوطي إلى عبد بن حميد.تفسير مقاتل بن سليمان ٣/١٦٦.عزاه السيوطي إلى ابن جرير، وعند ابن جرير ١٧/١١٣ عن حجاج، ولعل فيه سقطًا.علَّقه يحيى بن سلّام ١/٤١٦.أخرجه الحاكم ٣/١٥٣ (٤٦٨٤) بتمامه، والطبراني في الكبير ٣/٤٥ (٢٦٣٤، ٢٦٣٥) واللفظ له.</p><p>قال الحاكم: «هذا حديث صحيح الإسناد، ولم يُخَرِّجاه». وقال الذهبي في التلخيص: «منقطع». وقال الطبراني في الأوسط ٥/٣٧٦ (٥٦٠٦): «لم يُجَوِّد هذا الحديث عن سفيان بن عيينة إلا الحسن بن سهل، ورواه غيره عن سفيان عن جعفر عن أبيه، ولم يذكروا جابر بن عبد الله». وأورده الدارقطني في العلل ٢/١٩٠ (٢١١). وقال الهيثمي في المجمع ٩/١٧٣ (١٥٠١٩): «رواه الطبراني في الأوسط والكبير باختصار، ورجالهما رجال الصحيح، غير الحسن بن سهل، وهو ثقة». وينظر: الألباني في الصحيحة ٥/٥٨ (٢٠٣٦).أخرجه أبو الفضل الزهري في حديثه ص٣٨٨ (٣٥٩)، وابن عساكر في تاريخه ٦٧/٢١.</p><p>قال الألباني في الصحيحة ٥/٦٤: «وهذا إسناد ضعيف جِدًّا... وجملة القول: أنّ الحديث بمجموع هذه الطرق صحيح».أخرجه أحمد ٣١/٢٠٧-٢٠٨ (١٨٩٠٧)، ٣١/٢٥٨ (١٨٩٣٠)، والحاكم ٣/١٧٢ (٤٧٤٧).</p><p>قال الحاكم: «هذا حديث صحيح الإسناد، ولم يخرجاه». وقال ابن كثير في تفسيره ٥/٤٩٥: «هذا الحديث له أصل في الصحيحين عن المسور». وقال ابن الملقن في البدر المنير ٧/٤٨٩: «بإسناد صحيح». وأورده الألباني في الصحيحة ٤/٦٥٠ (١٩٩٥) وقال تعقيبًا على موافقة الذهبي للحاكم: «وهذا عجب منه، فإنّ أُمَّ بكر هذه لا تُعْرَف، بشهادة الذهبي نفسه، فإنّه أوردها في فصل النسوة المجهولات، وقال: تفرَّد عنها ابن أخيها عبد الله بن جعفر». ثم قال: «لَكِنِّي وجدت لها متابعًا قويًّا...» وذكره.أخرجه ابن أبي الدنيا في كتاب حسن الظن بالله ص١٠٧ (١١٦)، والطبراني في الأوسط ٥/٢٢٢ (٥١٤٤)، وابن جرير ١٧/١١٤.</p><p>قال الطبراني: «لم يروِ هذا الحديثَ عن أنس إلا سدوسٌ، تَفَرَّد به أبو عون». وقال الهيثمي في المجمع ١٠/٣٥٦ (١٨٤٢٦): «رواه الطبراني في الأوسط، وفيه الحكم بن سنان أبو عون، قال أبو حاتم: عنده وهم كثير، وليس بالقوي، ومحله الصدق، يُكْتَب حديثه. وضعّفه غيره، وبقية رجاله ثقات». وقال البوصيري في إتحاف الخيرة ٨/٢٠٥ (٧٧٩١): «رواه أبو يعلى، وفي سنده سدوس صاحب السامري، وهو ضعيف».أخرجه يحيى بن سلّام ١/٤١٦.من قولهم: ذاب لي عليه من الحق كذا، أي: ثبت ووجب. النهاية (ذوب)، واللسان (برد).أخرجه ابن جرير ١٧/١١٤.
  23,102,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿فَمَن ثَقُلَتۡ مَوَ ٰ⁠زِینُهُۥ فَأُو۟لَـٰۤىِٕكَ هُمُ ٱلۡمُفۡلِحُونَ ۝١٠٢ وَمَنۡ خَفَّتۡ مَوَ ٰ⁠زِینُهُۥ فَأُو۟لَـٰۤىِٕكَ ٱلَّذِینَ خَسِرُوۤا۟ أَنفُسَهُمۡ فِی جَهَنَّمَ خَـٰلِدُونَ ۝١٠٣﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٢٠٩٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فمن ثقلت موازينه﴾</span> بالعمل الصالح، يعني: المؤمنين؛ <span class="qpc-hafs">﴿فأولئك هم المفلحون﴾</span> يعني: الفائزين، <span class="qpc-hafs">﴿ومن خفت موازينه﴾</span> يعني: الكفار؛ <span class="qpc-hafs">﴿فأولئك الذين خسروا﴾</span> يعني: غَبَنوا <span class="qpc-hafs">﴿أنفسهم في جهنم خالدون﴾</span> لا يموتون{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٢١٠٠<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: قوله: <span class="qpc-hafs">﴿فمن ثقلت موازينه فأولئك هم المفلحون﴾</span> السعداء، وهم أهل الجنة، <span class="qpc-hafs">﴿ومن خفت موازينه فأولئك الذين خسروا أنفسهم﴾</span> أن يغنموها؛ فصاروا في النار. قال: <span class="qpc-hafs">﴿في جهنم خالدون﴾</span> لا يخرجون منها، ولا يموتون{2}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٣/١٦٦.تفسير يحيى بن سلّام ١/٤١٦.
  23,103,""
  23,104,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿تَلۡفَحُ وُجُوهَهُمُ ٱلنَّارُ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٢١٠١<span class="dash">-</span></span> عن أبي الدرداء، قال: قال رسول الله ﷺ في قوله: <span class="qpc-hafs">﴿تلفح وجوههم النار﴾</span>: «<b>تلفحهم لفحةً، فتَسِيل لحومُهم على أعقابهم</b>»{1}. (١٠/٦٢٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٢١٠٢<span class="dash">-</span></span> عن أبي هريرة، عن النبي ﷺ، قال: «<b>إنّ جَهَنَّم لَمّا سيق إليها أهلُها تَلَقَّتهم بعُنُق، فلفحتهم لفحةً، فلم تدع لحمًا على عظم إلا ألقته على العُرْقوب</b>{2}»{3}. (١٠/٦٢٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٢١٠٣<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن مسعود</span>، في قوله: <span class="qpc-hafs">﴿تلفح وجوههم النار﴾</span>، قال: لَفَحَتْهم لفحةً، فما أبْقَتْ لحمًا على عَظْمٍ إلا ألقته على أعقابهم{4}. (١٠/٦٢٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٢١٠٤<span class="dash">-</span></span> عن <span class="name-2">عبد الله بن أبي الهذيل</span> -من طريق أبي سِنان-، مثله{5}. (١٠/٦٢٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٢١٠٥<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق ابن جريج- <span class="qpc-hafs">﴿تلفح وجوههم النار﴾</span>، قال: تَنفَحُ{6}. (١٠/٦٢٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٢١٠٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿تلفح﴾</span> يعني: تنفخ <span class="qpc-hafs">﴿وجوههم النار﴾</span>{7}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَهُمۡ فِیهَا كَـٰلِحُونَ ۝١٠٤﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٢١٠٧<span class="dash">-</span></span> عن أبي هريرة، قال: قال رسول الله ﷺ: «<b>شَفَتُه السُّفْلى ساقِطَةٌ على صدره، والعليا قالِصَةٌ قد غطَّتْ وجهَه</b>»{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٢١٠٨<span class="dash">-</span></span> عن أبي سعيد الخدري، عن رسول الله ﷺ، في قوله: <span class="qpc-hafs">﴿تلفح وجوههم النار وهم فيها كالحون﴾</span>، قال: «<b>تشويه النار، فتقلص شفته العليا حتى تبلغ وسط رأسه، وتسترخي شفته السفلى حتى تضرب سُرَّتَه</b>»{9}. (١٠/٦٢٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٢١٠٩<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن مسعود</span> -من طريق أبي الأَحْوَص- في قوله: <span class="qpc-hafs">﴿وهم فيها كالحون﴾</span>، قال: ألم [تَرَ] إلى الرأس النَّضِيج؛ قد بَدَت أسنانُه، وقلصت شفتاه؟{10}. (١٠/٦٢٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٢١١٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- في قوله: <span class="qpc-hafs">﴿كالحون﴾</span>، قال: عابسون{11}. (١٠/٦٢٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٢١١١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وهم فيها كالحون﴾</span> عابسين، شفته العليا قالِصَةٌ لا تُغَطَّي أنيابَه، وشفته السفلى تضرب بطنه، وثناياه خارجة مِن فيه، بين شفتيه أربعون ذراعًا بذراع الرجل الطويل مِن الخلق الأول، كل ناب له مثل أحد{12}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٢١١٢<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿وهم فيها كالحون﴾</span>، قال: ألم تروا إلى الغنم إذا مسَّت النارُ وجوهَها؛ كيف هي؟{13}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَهُمۡ فِیهَا كَـٰلِحُونَ ۝١٠٤﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٥٢١١٣<span class="dash">-</span></span> عن <span class="name-1">أبي هريرة</span> -من طريق الحكم بن الأعرج- قال: يعظم الكافر في النار مسيرةِ سبع ليال، ضِرْسُه مثلُ أحد، شفاههم عند صدرهم، سُودٌ، زُرْق، حُبْنٌ{14}، مفتوحون، يتهافتون في النار، ويقول: هل امتلأتِ؟ وتقول: هل مِن مزيد؟ حتى يضع الرحمن قدمَه فيها، فتقول: ربِّ، قط قط{15}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٢١١٤<span class="dash">-</span></span> عن <span class="name-2">مغيث بن سُمَيٍّ</span>، قال: إذا جيء بالرجل إلى النار قيل: انتظر حتى نُتحِفَكَ. فيؤتى بكأس مِن سُمِّ الأفاعي والأَساوِد{16}، إذا أدناها مِن فيه نَثَرَتِ اللحمَ على حِدَة، والعظمَ على حِدَة{17}. (١٠/٦٢٣)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن مردويه -كما في تفسير ابن كثير ٥/٤٩٧-، من طريق سعد بن سعيد المقبري، عن أخيه، عن أبيه، عن أبي الدرداء به.</p><p>إسناده ضعيف جِدًّا؛ فيه سعد بن سعيد المقبري، قال ابن حجر في التقريب (٢٢٣٦): «ليّن الحديث». وفيه أخوه عبد الله بن سعيد المقبري، قال عنه ابن حجر في التقريب (٣٣٥٦): «متروك».العرقوب: هو الوتر الذي خلف الكعبين بين مفصل القدم والساق من ذوات الأربع، وهو من الإنسان فُوَيق العقب. النهاية (عرقب).أخرجه الطبراني في الأوسط ١/٩٢ (٢٧٨)، ٩/١٤٤ (٩٣٦٥)، وأبو نعيم في الحلية ٤/٣٦٣، ٥/٩٣.</p><p>ذكر الدارقطني في العلل ١١/٤٦ (٢١١٨) الاختلاف في طرقه بين وصله أو إرساله، ووقفه أو رفعه. وقال المنذري في الترغيب ٤/٢٦٧-٢٦٨ (٥٦١٠): «رواه الطبراني في الأوسط والبيهقي مرفوعًا، ورواه غيرهما موقوفًا عليه، وهو أصح». وقال الهيثمي في المجمع ١٠/٣٨٩ (١٨٥٨٦): «رواه الطبراني في الأوسط، وفيه محمد بن سليمان بن الأصبهاني، وهو ضعيف». وقال الألباني في الضعيفة ١١/٤٧٥ (٥٣٠٢): «ضعيف».عزاه السيوطي إلى أبي نعيم في الحلية.أخرجه ابن أبي شيبة ١٣/١٥٢، وابن أبي الدنيا في كتاب صفة النار -موسوعة ابن أبي الدنيا ٦/٤٢٤ (١١٠)-، وإسحاق البستي في تفسيره ص٤٠٨، وأبو نعيم في الحلية ٤/٣٥٩-٣٦٠. وعزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ١٧/١١٥.تفسير مقاتل بن سليمان ٣/١٦٦، ولعلها «تنفح» تصحفت.أخرجه يحيى بن سلّام في تفسيره ١/٤١٧، من طريق صاحب له، عن يحيى بن عبد الله المزني، عن أبيه، عن أبي هريرة به.</p><p>إسناده ضعيف؛ لجهالة صاحب يحيى بن سلّام شيخه في الرواية.أخرجه أحمد ١٨/٣٥٠ (١١٨٣٦)، والترمذي ٤/٥٤٣ (٢٧٦٩)، ٥/٣٩٤ (٣٤٥٠)، والحاكم ٢/٢٦٩ (٢٩٧١)، ٢/٤٢٨ (٣٤٩٠).</p><p>قال الترمذي: «حديث حسن صحيح غريب». وقال الحاكم: «هذا حديث صحيح الإسناد، ولم يخرجاه». وقال البغوي في شرح السنة ١٥/٢٥٢ (٤٤١٦): «هذا حديث حسن غريب».أخرجه الثوري في تفسيره ص٢١٨، وعبد الرزاق ٢/٤٨، وابن أبي شيبة ١٣/١٧٤-١٧٥، وهناد (٣٠٣، ٣٠٤)، وابن أبي الدنيا في كتاب صفة النار -موسوعة ابن أبي الدنيا ٦/٤٢٤ (١١٣)- بنحوه، وابن جرير ١٧/١١٦، والطبراني (٩١٢١)، والحاكم ٢/٣٩٥. وعزاه السيوطي إلى الفريابي، وابن المنذر وابن أبي حاتم بلفظ: كُلوح الرأس النضيج، بدت أسنانهم، وتقلصت شفاههم.أخرجه ابن جرير ١٧/١١٥-١١٦، وابن أبي حاتم -كما في تغليق التعليق ٤/٢٦٣، والإتقان ٢/٣١-. وعزاه السيوطي إلى ابن المنذر.تفسير مقاتل بن سليمان ٣/١٦٦.أخرجه ابن جرير ١٧/١١٦.حُبْنٌ: جمع أحْبَن: وهو المُسْتَسْقي، مِنَ الحَبَن -بالتحريك-، وهو عِظَمُ البطن. اللسان (حبن).أخرجه يحيى بن سلّام ١/٤١٧.الأَساوِد: جمع الأسود، وهي أخبث الحيات وأعظمها. النهاية (سود).أخرجه ابن أبي شيبة ١٣/١٥٣.