quran[15]{c,v,t}:
23,90," <q>﴿بَلۡ أَتَیۡنَـٰهُم بِٱلۡحَقِّ وَإِنَّهُمۡ لَكَـٰذِبُونَ ۝٩٠﴾</q> - قراءات ٥٢٠٠٢- قال يحيى بن سلّام: وهي تُقْرَأ على وجه آخر: (بَلْ أتَيْتَهُمْ){1}٤٥٧٤ يا محمد بالحق؛ بالقرآن{2}. (ز) ٤٥٧٤ قال ابنُ عطية (٦/٣١٧): «قرأ ابن أبي إسحاق: (أتَيتَهم) على الخطاب لمحمد ﷺ». <q>﴿بَلۡ أَتَیۡنَـٰهُم بِٱلۡحَقِّ وَإِنَّهُمۡ لَكَـٰذِبُونَ ۝٩٠﴾</q> - تفسير الآية ٥٢٠٠٣- قال مقاتل بن سليمان: فأَكْذَبَهم اللهُ ﷿ حين أشركوا به، فقال سبحانه: <q>﴿بل أتيناهم بالحق﴾</q> يقول: بل جئناهم بالتوحيد، <q>﴿وإنهم لكاذبون﴾</q> في قولهم: إنّ الملائكة بنات الله ﷿{3}. (ز) ٥٢٠٠٤- قال يحيى بن سلّام: <q>﴿بل أتيناهم بالحق﴾</q>: القرآن، أنزله الله على النبي{2}. (ز) ",footnotes:1:قال المحقق: وفي ابن أبي زمنين ورقة ٢٢٨: أتيتَهم. تفسير يحيى بن سلّام ١/٤١٤. وهي قراءة شاذة، تروى أيضًا عن قتادة، وأبي حيوة، وغيرهما. انظر: مختصر ابن خالويه ص١٠٠، والمحتسب ٢/٩٨.تفسير يحيى بن سلّام ١/٤١٤.تفسير مقاتل بن سليمان ٣/١٦٣.تفسير يحيى بن سلّام ١/٤١٤.
23,91," <q>﴿مَا ٱتَّخَذَ ٱللَّهُ مِن وَلَدࣲ وَمَا كَانَ مَعَهُۥ مِنۡ إِلَـٰهٍۚ إِذࣰا لَّذَهَبَ كُلُّ إِلَـٰهِۭ بِمَا خَلَقَ وَلَعَلَا بَعۡضُهُمۡ عَلَىٰ بَعۡضࣲۚ سُبۡحَـٰنَ ٱللَّهِ عَمَّا یَصِفُونَ ۝٩١﴾</q> - تفسير ٥٢٠٠٥- قال مقاتل بن سليمان: يقول الله تعالى: <q>﴿ما اتخذ الله من ولد﴾</q> يعني: الملائكة، <q>﴿وما كان معه من إله﴾</q> يعني: مِن شريك، فلو كان معه إله <q>﴿إذا لذهب كل إله بما خلق ولعلا بعضهم على بعض﴾</q> كفِعْل ملوك الدنيا، يلتمس بعضُهم قهرَ بعض، ثم نزَّه الربُّ نفسَه جل جلاله عن مقالتهم، فقال تعالى: <q>﴿سبحان الله عما يصفون﴾</q> يعني: عمّا يقولون بأنّ الملائكة بنات الرحمن{1}. (ز) ٥٢٠٠٦- قال يحيى بن سلّام: <q>﴿ما اتخذ الله من ولد﴾</q> وذلك لقول المشركين: إن الملائكة بنات الله، <q>﴿وما كان معه من إله﴾</q> وذلك لِما عبدوا مِن الأوثان، اتخذوا مع الله آلهة. قال: <q>﴿إذا لذهب كل إله بما خلق﴾</q> يقول: لو كان معه آلهة <q>﴿إذا لذهب كل إله بما خلق ولعلا بعضهم على بعض﴾</q> لَطَلَب بعضُهم مُلْكَ بعضٍ حتى يعلو عليه، كما يفعل ملوك الدنيا، <q>﴿سبحان الله عما يصفون﴾</q> يُنَزِّه نفسه عما يكذبون{2}. (ز) ",footnotes:1:تفسير مقاتل بن سليمان ٣/١٦٤.تفسير يحيى بن سلّام ١/٤١٤.
23,92," <q>﴿عَـٰلِمِ ٱلۡغَیۡبِ وَٱلشَّهَـٰدَةِ فَتَعَـٰلَىٰ عَمَّا یُشۡرِكُونَ ۝٩٢﴾</q> - تفسير ٥٢٠٠٧- تفسير الحسن البصري، قال: <q>﴿عالم الغيب﴾</q>، الغيب هاهنا: ما لم يجِئْ مِن غيب الآخرة{1}. (ز) ٥٢٠٠٨- قال مقاتل بن سليمان: <q>﴿عالم الغيب والشهادة﴾</q> يعني: غيب ما كان، وما يكون، والشهادة، <q>﴿فتعالى﴾</q> يعني: فارتفع <q>﴿عما يشركون﴾</q> لقولهم: الملائكة بنات الله{2}. (ز) ٥٢٠٠٩- قال يحيى بن سلّام: <q>﴿والشهادة﴾</q> ما أعلمَ العبادَ، <q>﴿فتعالى﴾</q> ارتفع اللهُ <q>﴿عما يشركون﴾</q> يرفع نفسه عما قالوا{3}. (ز) ",footnotes:1:علَّقه يحيى بن سلّام ١/٤١٤.تفسير مقاتل بن سليمان ٣/١٦٤.تفسير يحيى بن سلّام ١/٤١٤.
23,93," <q>﴿قُل رَّبِّ إِمَّا تُرِیَنِّی مَا یُوعَدُونَ ۝٩٣ رَبِّ فَلَا تَجۡعَلۡنِی فِی ٱلۡقَوۡمِ ٱلظَّـٰلِمِینَ ۝٩٤ وَإِنَّا عَلَىٰۤ أَن نُّرِیَكَ مَا نَعِدُهُمۡ لَقَـٰدِرُونَ ۝٩٥﴾</q> - تفسير ٥٢٠١٠- قال مقاتل بن سليمان: <q>﴿قل رب إما تريني ما يوعدون﴾</q> مِن العذاب، يعني: القتل ببدر، وذلك أنّ النبي ﷺ أراد أن يدعو على كفار مكة، ثم قال: <q>﴿رب فلا تجعلني في القوم الظالمين*وإنا على أن نريك ما نعدهم﴾</q> مِن العذاب <q>﴿لقادرون﴾</q>{1}. (ز) ٥٢٠١١- قال يحيى بن سلّام: قوله: <q>﴿قل﴾</q> يا محمد: <q>﴿رب إما تريني ما يوعدون﴾</q> من العذاب، <q>﴿رب فلا تجعلني في القوم الظالمين﴾</q> لا تُهْلِكْني معهم إن أريتني ما يوعدون. قوله: <q>﴿وإنا على أن نريك ما نعدهم﴾</q> مِن العذاب <q>﴿لقادرون﴾</q>{2}. (ز) ",footnotes:1:تفسير مقاتل بن سليمان ٣/١٦٤.تفسير يحيى بن سلّام ١/٤١٤.
  23,94,""
  23,95,""
23,96," <q>﴿ٱدۡفَعۡ بِٱلَّتِی هِیَ أَحۡسَنُ ٱلسَّیِّئَةَۚ﴾</q> - نزول الآية ٥٢٠١٢- قال مقاتل بن سليمان: نزلت في النبي ﷺ وأبي جهل -لعنه الله-، حين جهل على النبيِّ ﷺ{1}. (ز) <q>﴿ٱدۡفَعۡ بِٱلَّتِی هِیَ أَحۡسَنُ ٱلسَّیِّئَةَۚ﴾</q> - تفسير الآية ٥٢٠١٣- عن أنس بن مالك -من طريق عبد الوارث- في قوله: <q>﴿ادفع بالتي هي أحسن السيئة﴾</q>، قال: قول الرجل لأخيه ما ليس فيه، فيقول: إن كنت كاذبًا فأنا أسأل الله أن يغفر لك، وإن كنت صادقًا فأنا أسأل الله أن يغفر لي{2}. (١٠/٦١٤) ٥٢٠١٤- عن مجاهد بن جبر -من طريق ابن جريج- <q>﴿ادفع بالتي هي أحسن السيئة﴾</q>، يقول: أعْرِض عن أذاهم إيّاك{3}. (١٠/٦١٣) ٥٢٠١٥- عن مجاهد بن جبر -من طريق عبد الكريم الجزري- <q>﴿ادفع بالتي هي أحسن السيئة﴾</q>، قال: هو السلام، تُسَلِّم عليه إذا لقِيتَه{4}. (ز) ٥٢٠١٦- عن مجاهد بن جبر -من طريق منصور- في قوله تعالى: <q>﴿ادفع بالتي هي أحسن﴾</q>، قال: المصافحة{5}. (ز) ٥٢٠١٧- عن الحسن البصري -من طريق عوف- في قوله: <q>﴿ادفع بالتي هي أحسن السيئة﴾</q>، قال: واللهِ، لا يصيبُها صاحبُها حتى يكظم غيظًا، ويصفح عمّا يكره{6}. (ز) ٥٢٠١٨- عن عطاء، <q>﴿ادفع بالتي هي أحسن السيئة﴾</q>، قال: بالسَّلام{7}. (١٠/٦١٤) ٥٢٠١٩- عن قتادة بن دعامة -من طريق سعيد- في الآية، قال: نعمت -واللهِ- جرعة تَتَجَرَّعُها وأنت مظلوم، فمَنِ استطاع أن يغلب الشرَّ بالخير فليفعل، ولا قوة إلا بالله{8}. (١٠/٦١٤) ٥٢٠٢٠- تفسير إسماعيل السدي: <q>﴿ادفع بالتي هي أحسن السيئة﴾</q>، يقول: ادفع بالعفو والصفح القولَ القبيحَ والأذى{9}. (ز) ٥٢٠٢١- قال مقاتل بن سليمان: ثم قال الله ﷿ يُعَزِّي نبيَّه ﷺ ليصبر على الأذى: <q>﴿ادفع بالتي هي أحسن السيئة نحن أعلم بما يصفون﴾</q>{1}. (ز) <q>﴿ٱدۡفَعۡ بِٱلَّتِی هِیَ أَحۡسَنُ ٱلسَّیِّئَةَۚ﴾</q> - النسخ في الآية ٥٢٠٢٢- قال يحيى بن سلّام: وذلك قبل أن يُؤمَر بقتالهم{11}٤٥٧٥. (ز) ٤٥٧٥ قال ابنُ عطية (٦/٣١٨): «قوله: <q>﴿ادفع بالتي هي أحسن﴾</q> الآيةَ أمْرٌ بالصفح ومكارم الأخلاق، وما كان منها لهذا فهو محكم باقٍ في الأمة أبدًا، وما فيها مِن معنى موادعة الكفار وترْك التعرُّض لهم والصفح عن أمورهم فمنسوخ بالقتال». <q>﴿نَحۡنُ أَعۡلَمُ بِمَا یَصِفُونَ ۝٩٦﴾</q> - تفسير ٥٢٠٢٣- قال مقاتل بن سليمان: <q>﴿نحن أعلم بما يصفون﴾</q> مِن الكذب{1}. (ز) ٥٢٠٢٤- قال يحيى بن سلّام: <q>﴿نحن أعلم بما يصفون﴾</q> بما يكذبون{11}. (ز) <q>﴿نَحۡنُ أَعۡلَمُ بِمَا یَصِفُونَ ۝٩٦﴾</q> - آثار متعلقة بالآية ٥٢٠٢٥- عن أبي هريرة، قال: أتى رجل النبيَّ ﷺ، فقال: يا رسول الله، إنّ لي قرابةً أصِلُهُم ويَقْطَعُونِ، وأُحْسِن إليهم ويُسِيئُون إلَيَّ، ويَجْهَلُون عَلَيَّ وأَحلم عنهم. قال: «لَئِن كان كما تقول كأنّما تُسِفُّهم المَلَّ{14}، ولا يزال معك مِن الله ظهيرٌ عليهم ما دُمْت على ذلك»{15}. (١٠/٦١٤) ",footnotes:1:تفسير مقاتل بن سليمان ٣/١٦٥.أخرجه أبو نعيم في الحلية ٨/٢٥٣. وعزاه السيوطي إلى ابن أبي حاتم.أخرجه ابن جرير ١٧/١٠٥، وإسحاق البستي في تفسيره ص٤٠٥. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه عبد الرزاق ٢/٤٨، وابن جرير ١٧/١٠٥.أخرجه أبو نعيم في حلية الأولياء ٣/٢٩٩.أخرجه ابن جرير ١٧/١٠٥.عزاه السيوطي إلى ابن أبي شيبة، وابن المنذر، وابن أبي حاتم.أخرجه ابن جرير ٦/٥٨-٥٩. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.علَّقه يحيى بن سلّام ١/٤١٤.تفسير مقاتل بن سليمان ٣/١٦٥.تفسير يحيى بن سلّام ١/٤١٥.تفسير مقاتل بن سليمان ٣/١٦٥.تفسير يحيى بن سلّام ١/٤١٥.المَلُّ والمَلَّةُ: الرَّمادُ الحارُّ الذي يُحْمى لِيُدْفَنَ فيه الخُبْزُ لِيَنضَجَ، والمعنى: تجعل وجوههم كلون الرَّماد. النهاية (سفف) (ملل).أخرجه مسلم ٤/١٩٨٢ (٢٥٥٨).
23,97," <q>﴿وَقُل رَّبِّ أَعُوذُ بِكَ مِنۡ هَمَزَ ٰ⁠تِ ٱلشَّیَـٰطِینِ ۝٩٧﴾</q> - تفسير ٥٢٠٢٦- قال عبد الله بن عباس: نزغاتهم{1}. (ز) ٥٢٠٢٧- قال مجاهد بن جبر: نفخهم، ونَفْثهم{1}. (ز) ٥٢٠٢٨- قال الحسن البصري: وساوِسُهم{1}. (ز) ٥٢٠٢٩- قال مقاتل بن سليمان: ثم أمره أن يَتَعَوَّذ من الشيطان، فقال تعالى: <q>﴿وقل رب أعوذ بك من همزات الشياطين﴾</q> يعني: الشياطين، في أمر أبي جهل، <q>﴿وأعوذ بك رب أن يحضرون﴾</q>{4}. (ز) ٥٢٠٣٠- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- قال: همزات الشياطين: خَنقُهم الناسَ، فذلك همزاتهم{5}. (ز) ٥٢٠٣١- قال يحيى بن سلّام: قوله: <q>﴿وقل رب أعوذ بك من همزات الشياطين﴾</q>، وهو الجنون{6}. (ز) ",footnotes:1:تفسير الثعلبي ٧/٥٥، وتفسير البغوي ٥/٤٢٨.تفسير الثعلبي ٧/٥٥، وتفسير البغوي ٥/٤٢٨.تفسير الثعلبي ٧/٥٥، وتفسير البغوي ٥/٤٢٨.تفسير مقاتل بن سليمان ٣/١٦٥.أخرجه ابن جرير ١٧/١٠٦.تفسير يحيى بن سلّام ١/٤١٥.
23,98," <q>﴿وَأَعُوذُ بِكَ رَبِّ أَن یَحۡضُرُونِ ۝٩٨﴾</q> - تفسير ٥٢٠٣٢- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿وأعوذ بك رب أن يحضرون﴾</q>، قال: في شيء مِن أمري{1}. (١٠/٦١٥) ٥٢٠٣٣- قال يحيى بن سلّام: قوله: <q>﴿وأعوذ بك رب أن يحضرون﴾</q> فأُطِيع الشيطان، فأَهْلَك، أمره الله أن يدعو بهذا{2}. (ز) <q>﴿وَأَعُوذُ بِكَ رَبِّ أَن یَحۡضُرُونِ ۝٩٨﴾</q> - آثار متعلقة بالآية ٥٢٠٣٤- عن عمرو بن شعيب، عن أبيه، عن جدِّه، قال: كان رسول الله ﷺ يُعَلِّمنا كلماتٍ نَقُولُهُنَّ عند النوم مِن الفزع: «بسم الله، أعوذ بكلمات الله التامَّة مِن غضبه، وعقابه، وشرِّ عباده، ومِن همزات الشياطين، وأن يحضرون»{3}. (١٠/٦١٥) ٥٢٠٣٥- عن الوليد بن الوليد أنّه قال: يا رسول الله، إنِّي أجد وحْشَةً؟ قال: «إذا أخذت مضجعك فقل: أعوذ بكلمات الله التامة مِن غضبه، وعِقابه، وشرِّ عباده، ومِن همزات الشياطين، وأن يحضرون؛ فإنّه لا يَضُرُّك، وبالحَرى{4} أن لا يقربك»{5}. (١٠/٦١٥) ٥٢٠٣٦- عن ابن جريج، قال: قلت لعطاء [بن أبي رباح]: فما <q>﴿وقل رب أعوذ بك من همزات الشياطين﴾</q>؟ قال: قَوْلٌ مِن القرآن ليس بواجب في الصلاة{6}. (ز) ",footnotes:1:أخرجه ابن جرير ١٧/١٠٦. وعزاه السيوطي إلى ابن أبي حاتم.تفسير يحيى بن سلّام ١/٤١٥.أخرجه أحمد ١١/٢٩٥-٢٩٦ (٦٦٩٦)، وأبو داود ٦/٤٠ (٣٨٩٣) بنحوه، والترمذي ٦/١٣٢ (٣٨٣٩)، والحاكم ١/٧٣٣ (٢٠١٠). قال الترمذي: «هذا حديث حسن غريب». وقال الحاكم: «هذا حديث صحيح الإسناد، متصل في موضع الخلاف».بالحَرى أن يكون كذا: جَدِير وخَليْق. النهاية (حرا).أخرجه أحمد ٢٧/١٠٨ (١٦٥٧٣)، ٣٩/٢٥٨ (٢٣٨٣٩)، وفيه محمد بن يحيى بن حبان. قال البيهقي في الأسماء والصفات ١/٤٧٤-٤٧٥ (٤٠٦): «هذا مرسل». وقال المنذري في الترغيب ٢/٣٠٢ (٢٤٨٠): «محمد لم يسمع مِن الوليد». وقال الهيثمي في المجمع ١٠/١٢٣ (١٧٠٤٨): «رجاله رجال الصحيح، إلا أنّ محمد بن يحيى بن حبان لم يسمع مِن الوليد بن الوليد». وقال البوصيري في إتحاف الخيرة المهرة ٦/٤٠٢ (٦٠٩٤): «هذا حديث رجاله ثقات». وقال الألباني في الصحيحة ٦/٥٣٦: «رجال إسناده ثقات، رجال الشيخين، لكنه مُنقَطِع».أخرجه عبد الرزاق ٢/٨٥ (٢٥٨٣).
23,99," <q>﴿حَتَّىٰۤ إِذَا جَاۤءَ أَحَدَهُمُ ٱلۡمَوۡتُ قَالَ رَبِّ ٱرۡجِعُونِ ۝٩٩﴾</q> - تفسير ٥٢٠٣٧- عن جابر بن عبد الله، قال: قال رسول الله ﷺ: «إذا حضر الإنسانَ الوفاةُ يُجْمَع له كلُّ شيء يمنعه عن الحق، فيُجعَل بين عينيه، فعند ذلك يقول: <q>﴿رب ارجعون لعلي أعمل صالحا فيما تركت﴾</q>»{1}. (١٠/٦١٧) ٥٢٠٣٨- عن ابن جُرَيج، قال: زعموا أنّ النبيَّ ﷺ قال لعائشة: «إنّ المؤمن إذا عايَنَ الملائكةَ قالوا: نُرجِعُك إلى الدنيا؟ فيقول: إلى دار الهموم والأحزان؟! بل قُدُمًا إلى الله. وأمّا الكافر فيقولون له: نُرجِعُك؟ فيقول: <q>﴿ارجعون لعلي أعمل صالحا فيما تركت﴾</q>»{2}. (١٠/٦١٦) ٥٢٠٣٩- عن ابن وهب، قال: بلغني عن أبي هريرة أنه قال: قال رسول الله ﷺ: «سألوا الرجعة لكي يُؤمِنوا بما كانوا يُكَذِّبون، وهم عِطاش لا يَرْوون، وجِياع لا يشبعون، وعُراة فلا يَكْتَسُون، [مغلوبين فلا ينتصرون، محزونين، مغلوبين، محسورين] أنفسَهم، وأهليهم، وأموالهم، ومكاسبهم»{3}. (ز) ٥٢٠٤٠- عن أبي هريرة -من طريق أبي حازم- قال: إذا وُضِع الكافرُ في قبره فيرى مقعده مِن النار، قال: ربِّ، ارجعونِ حتى أتوب؛ أعمل صالحًا. فيقال: قد عُمِّرْتَ ما كنت مُعَمَّرًا. فيضيق عليه قبره، فهو كالمنهوش{4}، ينام ويفزع، تهوي إليه هوامُّ الأرض؛ حياتها وعقاربها{5}. (١٠/٦١٦) ٥٢٠٤١- عن الضَّحّاك بن مُزاحِم -من طريق عبيد- يقول في قوله: <q>﴿حتى إذا جاء أحدهم الموت قال رب ارجعون﴾</q>: يعني: أهل الشرك{6}. (ز) ٥٢٠٤٢- قال الحسن البصري: قوله: <q>﴿حتى إذا جاء أحدهم الموت قال رب ارجعون﴾</q>، ليس أحدٌ مِن خَلْقِ الله ليس لله بوَلِيٍّ إلا وهو يسأل الله الرجعةَ إلى الدنيا عند الموت بكلام يتكلم به، وإن كان أخرس لم يتكلم في الدنيا بحرفٍ قطُّ، وذلك إذا استبان له أنّه مِن أهل النار سأل الله الرجعةَ، ولا يسمعه مَن يليه{7}. (ز) ٥٢٠٤٣- عن أبي معشر، قال: كان محمد بن كعب القرظي يقرأ علينا: <q>﴿حتى إذا جاء أحدهم الموت قال رب ارجعون﴾</q>. قال محمد: إلى أيِّ شيء يُريد؟ إلى أيِّ شيء يرغب؟ أجَمْعَ المال، أو غَرْس الغِراس، أو بَنْيَ بنيان، أو شق أنهار؟ ثم يقول: <q>﴿لعلي أعمل صالحا فيما تركت﴾</q>. يقول الجبار: <q>﴿كلا﴾</q>{8}. (ز) ٥٢٠٤٤- قال مقاتل بن سليمان: <q>﴿حتى إذا جاء أحدهم الموت﴾</q> يعني: الكفار؛ <q>﴿قال رب ارجعون﴾</q> إلى الدُّنيا حين يُعايِنُ مَلَكَ الموت يُؤخَذ بلسانه، فينظر إلى سَيِّئاته قبل الموت، فلمّا هجم على الخزي سأل الرجعة إلى الدنيا ليعمل صالحًا فيما ترك، فذلك قوله سبحانه: <q>﴿رب ارجعون﴾</q> إلى الدنيا{9}. (ز) ٥٢٠٤٥- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿رب ارجعون﴾</q> قال: هذه في الحياة، ألا تراه يقول: <q>﴿حتى إذا جاء أحدهم الموت﴾</q> قال: حين تنقطع الدنيا، ويُعايِن الآخرةَ قبل أن يذوق الموت{10}٤٥٧٦. (١٠/٦١٦) ٤٥٧٦ ذكر ابنُ عطية (٦/٣٢٠) أنّ قوله: <q>﴿ارْجِعُونِ﴾</q> معناه: إلى الحياة الدنيا، ثم قال: «وجمع الضمير يتخرج على معنيين: إما أن يخاطبه مخاطبة الجمع تعظيمًا على نحو إخباره تعالى عن نفسه بنون الجماعة في غير موضع، وإما أن تكون استغاثة بربه أوَّلًا، ثم خاطب ملائكة العذاب بقوله: <q>﴿ارْجِعُونِ﴾</q>». ",footnotes:1:أخرجه ابن المقرئ في معجمه ص٢٥٤ (٨٣٣)، من طريق خالد العبد، عن صفوان بن سليم، عن عطاء، عن جابر به. إسناده تالف؛ فيه خالد بن عبد الرحمن العبد، رماه عمرو بن علي بالوضع، وكذّبه الدارقطني، وقال ابن حبان: «كان يسرق الحديث، ويُحَدِّث مِن كتب الناس» كما في لسان الميزان لابن حجر ٣/٣٥٠. وأخرج نحوه يحيى بن سلّام في تفسيره ١/٤١٥ عن رجل من بني حارثة.أخرجه ابن جرير ١٧/١٠٧-١٠٨. قال الشوكاني في فتح القدير ٣/٥٩٣: «مرسل».أخرجه إسحاق البستي في تفسيره ص٤٠٦. وفيه انقطاع بين ابن وهب وأبي هريرة، وما بين المعقوفين ذكر محققه أنه كذا في الأصل، كما أن فيه اضطراب لفظًا ومعنى، وأيضًا لعل فيه سقطًا.المنهوش: المهزول المجهود. النهاية (نهش).أخرجه ابن أبي حاتم -كما في تفسير ابن كثير ٥/٤٨٧-٤٨٨-. وعزاه السيوطي إلى ابن أبي الدنيا في ذِكْر الموت.أخرجه ابن جرير ١٧/١٠٨، وإسحاق البستي في تفسيره ص٤٠٦.علَّقه يحيى بن سلّام ١/٤١٥.أخرجه ابن جرير ١٧/١٠٧. وعلَّقه ابنُ أبي الدنيا في كتاب ذكر الموت -موسوعة ابن أبي الدنيا ٥/٤٧٨ (٢٦٤)-.تفسير مقاتل بن سليمان ٣/١٦٥.أخرجه ابن جرير ١٧/١٠٧. وعزاه السيوطي إلى ابن أبي حاتم.
23,100," <q>﴿لَعَلِّیۤ أَعۡمَلُ صَـٰلِحࣰا فِیمَا تَرَكۡتُۚ كَلَّاۤۚ إِنَّهَا كَلِمَةٌ هُوَ قَاۤىِٕلُهَاۖ﴾</q> - تفسير ٥٢٠٤٦- عن عبد الله بن عباس -من طريق عكرمة- في قوله: <q>﴿لعلي أعمل صالحا﴾</q>، قال: أقول: لا إله إلا الله{1}. (١٠/٦١٧) ٥٢٠٤٧- عن عكرمة مولى ابن عباس، في قوله: <q>﴿لعلي أعمل صالحا فيما تركت﴾</q>، قال: لَعَلِّي أقول: لا إله إلا الله{2}. (١٠/٦١٧) ٥٢٠٤٨- قال قتادة بن دعامة: ما تَمَنّى أن يرجع إلى أهله وعشيرته، ولا لِيَجْمَع الدنيا ويقضي الشهوات، ولكن تَمَنّى أن يرجع فيعمل بطاعة الله، فرَحِم اللهُ امرءًا عمِل فيما يَتَمَنّاه الكافرُ إذا رأى العذاب{3}. (ز) ٥٢٠٤٩- قال يحيى بن سلّام: وأخبرني رجل مِن أهل الكوفة عن السدي، قال: إنّ الكافر إذا نزل به الموتُ، وعاين حسناتِه قليلةً وسيئاتِه كثيرةً؛ نَظَر إلى مَلَك الموت مِن قَبْلِ أن يخرج من الدنيا، فتَمَنّى الرجعة، وصدَّق بما كذب به، فعند ذلك يقول: <q>﴿رب ارجعون﴾</q> يعني: إلى الدنيا، <q>﴿لعلي أعمل صالحا فيما تركت﴾</q>. يقول الله: <q>﴿كلا﴾</q> يعني: لا يرجع إلى الدنيا. ثم استأنف، فقال: <q>﴿كلا إنها كلمة هو قائلها﴾</q> ولا يسمع بها بنو آدم. ونحوُ ذلك مثلُ قول فرعون في سورة يونس{4}. (ز) ٥٢٠٥٠- قال مقاتل بن سليمان: <q>﴿لعلي﴾</q> يعني: لكي <q>﴿أعمل صالحا فيما تركت﴾</q> مِن العمل الصالح، يعني: الإيمان، يقول ﷿: <q>﴿كلا﴾</q> لا يُرَدُّ إلى الدنيا. ثم استأنف، فقال: <q>﴿إنها كلمة هو قائلها﴾</q> يعني بالكلمة: قوله: <q>﴿رب ارجعون﴾</q>{5}. (ز) ٥٢٠٥١- قال عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿كلا إنها كلمة هو قائلها﴾</q>: لا بُدَّ له أن يقولها{6}. (ز) ٥٢٠٥٢- قال يحيى بن سلّام: <q>﴿لعلي أعمل صالحا فيما تركت﴾</q> فيما صنعتُ. قال الله: <q>﴿كلا﴾</q> لستَ براجع إلى الدنيا. وهي مثل قوله: <q>﴿وأنفقوا من ما رزقناكم من قبل أن يأتي أحدكم الموت فيقول رب لولا أخرتني إلى أجل قريب فأصدق وأكن من الصالحين﴾</q> [المنافقون:١٠]. ثم قال: <q>﴿كلا إنها كلمة هو قائلها﴾</q> هذه الكلمة: <q>﴿قال رب ارجعون (٩٩) لعلي أعمل صالحا فيما تركت﴾</q>{7}٤٥٧٧. (ز) ٤٥٧٧ ذكر ابنُ عطية (٦/٣٢١) أن قوله: <q>﴿إنَّها كَلِمَةٌ هُوَ قائِلُها﴾</q> يحتمل ثلاثة معانٍ: الأول: الإخبار المؤكد بأن هذا الشيء يقع ويقول هذه الكلمة. الثاني: أن يكون المعنى: إنها كلمة لا تغني أكثر من أن يقولها ولا نفع له فيها ولا غوث. الثالث: أن تكون إشارةً إلى أنه لو رُدَّ لعاد فتكون آية ذمٍّ لهم. <q>﴿وَمِن وَرَاۤىِٕهِم﴾</q> - تفسير ٥٢٠٥٣- قال مقاتل بن سليمان: ثم قال سبحانه: <q>﴿ومن ورائهم برزخ﴾</q>، يعني: ومِن بعد الموت أجل{5}. (ز) ٥٢٠٥٤- عن سفيان بن حسين، في قوله: <q>﴿ومن ورائهم برزخ﴾</q>، قال: أمامهم{9}. (١٠/٦١٧) <q>﴿بَرۡزَخٌ إِلَىٰ یَوۡمِ یُبۡعَثُونَ ۝١٠٠﴾</q> - تفسير ٥٢٠٥٥- عن عائشة -من طريق سعيد بن المسيب- قالت: ويْلٌ لأهل المعاصي مِن أهل القبور؛ يدخل عليهم في قبورهم حيّاتٌ سود؛ حَيَّةٌ عند رأسه، وحَيَّةٌ عند رجليه، يقرضانه حتى يلتقيان في وسطه، فذلك العذاب في البرزخ الذي قال الله: <q>﴿ومن ورائهم برزخ إلى يوم يبعثون﴾</q>{10}. (١٠/٦١٦) ٥٢٠٥٦- عن عبد الله بن عباس -من طريق العوفي- <q>﴿ومن ورائهم برزخ إلى يوم يبعثون﴾</q>، يقول: أجل إلى حين{11}. (ز) ٥٢٠٥٧- قال عبد الله بن عباس: حجاب{12}. (ز) ٥٢٠٥٨- عن أبي أُمامة -من طريق أبي يوسف-: أنّه شهِد جنازة، فلمّا دُفِن الميتُ قال: هذا برزخ إلى يوم يبعثون{13}. (١٠/٦١٨) ٥٢٠٥٩- عن سعيد بن جبير -من طريق جعفر- في قوله: <q>﴿ومن ورائهم برزخ﴾</q>، قال: ما بعد الموت{14}. (١٠/٦١٩) ٥٢٠٦٠- عن مجاهد بن جبر -من طريق فطر بن خليفة- في قوله: <q>﴿ومن ورائهم برزخ إلى يوم يبعثون﴾</q>، قال: ما بين الموت إلى البعث{15}. (١٠/٦١٧) ٥٢٠٦١- عن مجاهد بن جبر، قال: البرزخ: الحاجِز ما بين الدنيا والآخرة{9}. (١٠/٦١٧) ٥٢٠٦٢- عن مجاهد بن جبر -من طريق ابن أبي نجيح- <q>﴿ومن ورائهم برزخ إلى يوم يبعثون﴾</q>، قال: حجاز بين الميِّت والرجوع إلى الدنيا{17}. (١٠/٦١٨) ٥٢٠٦٣- عن الضَّحّاك بن مُزاحِم -من طريق عبيد- قال: البرزخ: ما بين الدنيا والآخرة{18}. (ز) ٥٢٠٦٤- قال الضَّحّاك بن مُزاحِم: البرزخ: ما بين الموت إلى البعث{19}. (ز) ٥٢٠٦٥- عن أبي مُحَلِّمٍ، قال: قيل لعامر الشعبي: مات فلان. قال: ليس هو في الدنيا ولا في الآخرة، هو في البرزخ{20}. (١٠/٦١٩) ٥٢٠٦٦- عن الحسن البصري -من طريق أبي رجاء- في الآية، قال: البَرْزَخ بين الدنيا والآخرة{21}. (١٠/٦١٨) ٥٢٠٦٧- عن الحسن البصري -من طريق المبارك بن فضالة- قال: البرزخ: هي هذه القبور التي بينكم وبين الآخرة{22}. (ز) ٥٢٠٦٨- عن أبي المقدام، قال: كُنت أُسايِر الحسنَ ونحن راجعون مِن جنازة بكر بن عبد الله، فقلتُ: أرأيتَ قول الله ﷿: <q>﴿ومن ورائهم برزخ إلى يوم يبعثون﴾</q>. فنظر عن يمينه وعن شماله، فقال: هُم هؤلاء في البرزخ كما ترون؛ يركضون عليهم؛ هما يحيكم{23}؛ لا يسمعون الصوت{24}. (ز) ٥٢٠٦٩- عن محمد بن كعب القرظي، قال: البرزخ: ما بين الدنيا والآخرة؛ ليس مع أهل الدنيا يأكلون ويشربون، ولا مع أهل الآخرة يُجازَوْن بأعمالهم{9}. (١٠/٦١٨) ٥٢٠٧٠- عن قتادة بن دعامة -من طريق مَعْمَر- قال: برزخ بقيةَ الدنيا{26}. (١٠/٦١٨) ٥٢٠٧١- عن قتادة بن دعامة -من طريق سعيد- <q>﴿ومن ورائهم برزخ﴾</q>، قال: أهل القبور في بَرْزَخ ما بين الدنيا والآخرة، هم فيه إلى يوم يبعثون{27}. (١٠/٦١٨) ٥٢٠٧٢- قال إسماعيل السُّدِّيّ: أجَلٌ{12}. (ز) ٥٢٠٧٣- قال إسماعيل السُّدِّيّ: البرزخ: ما بين النفختين{29}. (ز) ٥٢٠٧٤- عن الربيع، قال: البرزخ: القبور{30}. (١٠/٦١٨) ٥٢٠٧٥- قال مقاتل بن سليمان: ثم قال سبحانه: <q>﴿ومن ورائهم برزخ﴾</q> يعني: ومِن بعد الموت أجَلٌ <q>﴿إلى يوم يبعثون﴾</q> يعني: يُحْشَرون بعد الموت{5}. (ز) ٥٢٠٧٦- عن أبي صخر [حميد بن زياد الخراط]، قال: البرزخ: المقابر، لا هم في الدنيا، ولا هم في الآخرة، فهم مُقِيمون إلى يوم يبعثون{9}. (١٠/٦١٨) ٥٢٠٧٧- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿ومن ورائهم برزخ إلى يوم يبعثون﴾</q>، قال: البرزخ: ما بين الموت إلى البعث{11}٤٥٧٨. (ز) ٤٥٧٨ ذكر ابنُ عطية (٦/٣٢١) أنّ البرزخ في كلام العرب: الحاجز بين المسافتين، ثم يستعار لِما عَدا ذلك، وأنّه هنا للمدة التي بين موت الإنسان وبين بعثه، ثم قال: «هذا إجماع من المفسرين». ",footnotes:1:أخرجه البيهقي في الأسماء والصفات (٢٠٥).عزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.تفسير البغوي ٥/٤٢٨.تفسير يحيى بن سلّام ١/٤١٥. يشير إلى قوله تعالى: <q>﴿حَتّى إذا أدْرَكَهُ الغَرَقُ قالَ آمَنتُ أنَّهُ لا إلَهَ إلّا الَّذِي آمَنَتْ بِهِ بَنُو إسْرائِيلَ وأَنا مِنَ المُسْلِمِينَ﴾</q> [يونس:٩٠].تفسير مقاتل بن سليمان ٣/١٦٥.أخرجه ابن جرير ١٧/١٠٨.تفسير يحيى بن سلّام ١/٤١٥.تفسير مقاتل بن سليمان ٣/١٦٥.عزاه السيوطي إلى ابن أبي حاتم.أخرجه ابن أبي حاتم -كما في تفسير ابن كثير ٥/٤٨٧-٤٨٨-.أخرجه ابن جرير ١٧/١٠٩.تفسير الثعلبي ٧/٥٦.أخرجه ابن جرير ١٧/١٠٩. وعزاه السيوطي إلى سعيد بن منصور، وابن المنذر، وابن أبي حاتم، وسمويه في فوائده.أخرجه ابن جرير ١٧/١٠٩، وإسحاق البستي في تفسيره ص٤٠٦.أخرجه يحيى بن سلّام ١/٤١٦، وهناد (٣١٤)، وابن جرير ١٧/١١٠، وأبو نعيم في الحلية ٣/٢٩٠. وعزاه السيوطي إلى ابن أبي شيبة، وعبد بن حميد، وابن المنذر.عزاه السيوطي إلى ابن أبي حاتم.أخرجه ابن جرير ١٧/١١٠. وعزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ١٧/١١١، وإسحاق البستي في تفسيره ص٤٠٧.تفسير الثعلبي ٧/٥٦، وتفسير البغوي ٥/٤٢٨.أخرجه هناد (٣١٥).أخرجه إسحاق البستي في تفسيره ص٤٠٧. وعزاه السيوطي إلى عبد بن حميد.أخرجه آدم بن أبي إياس -كما في تفسير مجاهد ص٤٨٨-.كذا في المصدر: هما يحيكم، وهو كذلك في طبعة مكتبة الغرباء الأثرية ط١، ١٤٢٠ﻫ-٢٠٠٠م، ص١٣٣، ١٤٩.أخرجه ابن أبي الدنيا في كتاب القبور -موسوعة ابن أبي الدنيا ٦/٨٨ (١٤٩)-.عزاه السيوطي إلى ابن أبي حاتم.أخرجه عبد الرزاق ٢/٤٨، وابن جرير ١٧/١١٠. وعزاه السيوطي إلى عبد بن حميد.أخرجه يحيى بن سلّام ١/٤١٦ بنحوه. وعزاه السيوطي إلى عبد بن حميد.تفسير الثعلبي ٧/٥٦.علَّقه يحيى بن سلّام ١/٤١٦.عزاه السيوطي إلى عبد بن حميد.تفسير مقاتل بن سليمان ٣/١٦٥.عزاه السيوطي إلى ابن أبي حاتم.أخرجه ابن جرير ١٧/١٠٩.
23,101," <q>﴿فَإِذَا نُفِخَ فِی ٱلصُّورِ فَلَاۤ أَنسَابَ بَیۡنَهُمۡ یَوۡمَىِٕذࣲ وَلَا یَتَسَاۤءَلُونَ ۝١٠١﴾</q> - تفسير ٥٢٠٧٨- قال عبد الله بن مسعود: هي النفخة الثانية{1}. (ز) ٥٢٠٧٩- عن عبد الله بن مسعود -من طريق زاذان- قال: إذا كان يومُ القيامة جَمَع الله الأولين والآخرين -وفي لفظ: يُؤخَذ بيد العبد أو الأَمَة يوم القيامة على رؤوس الأولين والآخرين-، ثم يُنادي مُنادٍ: ألا إنّ هذا فلان بن فلان، فمَن كان له حَقٌّ قِبَلَه فليأت إلى حقِّه- وفي لفظ: من كان له مظلمة فليجئْ فليأخذ حقَّه-. فيفرح -واللهِ- المرءُ أن يكون له الحقُّ على والده، أو ولده، أو زوجته، وإن كان صغيرًا، ومِصداق ذلك في كتاب الله: <q>﴿فإذا نفخ في الصور فلا أنساب بينهم يومئذ ولا يتساءلون﴾</q>{2}. (١٠/٦٢٠) ٥٢٠٨٠- عن عبد الله بن عباس -من طريق عطاء-: إنّها الثانية، فلا أنساب بينهم{3}. (ز) ٥٢٠٨١- عن عبد الله بن عباس -من طريق علي- في قوله: <q>﴿فلا أنساب بينهم يومئذ ولا يتساءلون﴾</q>، قال: فذلك حين يُنفَخ في الصور، فلا يبقى حَيٌّ إلا الله، <q>﴿وأقبل بعضهم على بعض يتساءلون﴾</q> [الصافات:٢٧] فذلك إذا بُعِثوا في النفخة الثانية{4}. (١٠/٦١٩) ٥٢٠٨٢- عن عبد الله بن عباس أنّه سُئِل عن قوله: <q>﴿فلا أنساب بينهم ولا يتساءلون﴾</q>، وقوله: <q>﴿وأقبل بعضهم على بعض يتساءلون﴾</q> [الصافات:٢٧]. فقال: إنّها مواقف؛ فأمّا الموقف الذي لا أنساب بينهم ولا يتساءلون عِند الصَّعْقَةِ الأولى لا أنساب بينهم فيها إذا صُعقوا، فإذا كانت النفخة الآخرة فإذا هم قيام يتساءلون{5}. (١٠/٦٢٠) ٥٢٠٨٣- عن عبد الله بن عباس -من طريق سعيد بن جبير- أنّه سُئِل عن الآيتين. فقال: أمّا قوله: <q>﴿ولا يتساءلون﴾</q> فهذا في النفخة الأولى حين لا يبقى على الأرض شيء، وأمّا قوله: <q>﴿وأقبل بعضهم على بعض يتساءلون﴾</q> [الصافات:٢٧] فإنّهم لَمّا دخلوا الجنَّةَ أقبل بعضُهم على بعضٍ يتساءلون{6}. (١٠/٦٢٠) ٥٢٠٨٤- عن سعيد بن جبير، قال: قال رجل لابن عباس: إنِّي أجِد في القرآن أشياءَ تختلف عَلَيَّ! قال: <q>﴿فلا أنساب بينهم يومئذ ولا يتساءلون﴾</q>، <q>﴿وأقبل بعضهم على بعض يتساءلون﴾</q> [الصافات:٢٧]. فقال: <q>﴿فلا أنساب بينهم﴾</q> في النفخة الأولى، ثم ينفخ في الصور: <q>﴿فصعق من في السموات ومن في الأرض إلا من شاء الله﴾</q> [الزمر:٦٨] فلا أنساب بينهم عند ذلك ولا يتساءلون، ثم في النفخة الآخرة أقبل بعضهم على بعض يتساءلون{7}. (ز) ٥٢٠٨٥- قال أبو العالية الرِّياحِيِّ: هو كقوله: <q>﴿ولا يَسْأَلُ حَمِيمٌ حَمِيمًا﴾</q> [المعارج: ١٠]{8}. (ز) ٥٢٠٨٦- عن الحسن البصري: <q>﴿فلا أنساب بينهم﴾</q> يَتَعاطَفُون عليها كما كانوا يَتَعاطَفُون عليها في الدنيا، <q>﴿ولا يتساءلون﴾</q> عليها أن يحمل بعضُهم عن بعض كما كانوا يتساءلون في الدنيا بأنسابهم، كقول الرجل: أسألك بالله وبالرَّحِم{9}. (ز) ٥٢٠٨٧- عن قتادة بن دعامة، في الآية، قال: ليس أحدٌ مِن الناس يسأل أحدًا بنسبه، ولا بقرابته شيئًا{10}. (١٠/٦١٩) ٥٢٠٨٨- عن إسماعيل السُّدِّيّ -من طريق سفيان- <q>﴿فلا أنساب بينهم يومئذ ولا يتساءلون﴾</q>، قال: في النفخة الأولى{11}. (١٠/٦١٩) ٥٢٠٨٩- قال مقاتل بن سليمان: <q>﴿فإذا نفخ في الصور﴾</q> يعني: النفخة الثانية؛ <q>﴿فلا أنساب بينهم﴾</q> يعني: لا نسبة بينهم؛ عم، وابن عم، وأخ، وابن أخ، وغيره، <q>﴿يومئذ ولا يتساءلون﴾</q> يقول: ولا يسأل حميمٌ حميمًا{12}. (ز) ٥٢٠٩٠- عن عبد الملك ابن جُرَيْج -من طريق حجّاج- في الآية، قال: لا يُسألُ أحدٌ يومئذ بنَسَب شيئًا، ولا يتساءلون، ولا يَمُتُّ إليه برحم{13}. (١٠/٦١٩) ٥٢٠٩١- قال يحيى بن سلّام: قوله: <q>﴿فإذا نفخ في الصور﴾</q> والصور: قَرْن.= (ز) ٥٢٠٩٢- في تفسير عمرو [بن عبيد]، عن الحسن: أنّ أنسابَهم يومئذٍ قائمةٌ معروفةٌ، قال: <q>﴿يوم يفر المرء من أخيه (٣٤) وأمه وأبيه﴾</q> [عبس:٣٤-٣٥]، وسمعتُ بعضَ الكوفيين يقول: <q>﴿يبصرونهم﴾</q> [المعارج:١١] أي: يرونهم. يقول: يعرفونهم في مواطن، ولا يعرفونهم في مواطن{9}٤٥٧٩. (ز) ٤٥٧٩ اختُلِف في صِفة ارتفاع الأنساب المذكورة في الآية، ومتى يكون ذلك، على قولين: أحدهما: أنّ هذا في النفخة الأولى، وذلك أنّ الناس بأجمعهم يموتون فلا يكون بينهم نسب في ذلك الوقت وهم أموات. والآخر: أنّ هذا عند النفخة الثانية، وقيام الناس من القبور فهم حينئذ لِهَول المطلع واشتغال كل امرئٍ بنفسه، قد انقطعت بينهم الوسائل، وزال انتفاع الأنساب؛ فلذلك نفاها، فالمعنى: فلا أنساب نافعة. وعلَّقَ ابنُ عطية (٦/٣٢١-٣٢٢) على القول الأول بقوله: «هذا التأويل يُزيل ما في الآية مِن ذِكْر هول الحشر». ثم قال: «وكذلك ارتفاع التساؤل لهذه الوجوه التي ذكرناها، ثم يأتي في القيامة مواطن يكون فيها السؤال والتعارف. وهذا التأويل حسن، وهو مرويُّ المعنى عن ابن عباس». <q>﴿فَإِذَا نُفِخَ فِی ٱلصُّورِ فَلَاۤ أَنسَابَ بَیۡنَهُمۡ یَوۡمَىِٕذࣲ وَلَا یَتَسَاۤءَلُونَ ۝١٠١﴾</q> - آثار متعلقة بالآية ٥٢٠٩٣- قال عمر بن الخطاب: سمعتُ رسولَ الله ﷺ يقول: «كُلُّ سَبَبٍ ونَسَبٍ مُنقَطِع يوم القيامة إلّا سَبَبي ونسبي»{15}. (١٠/٦٢١) ٥٢٠٩٤- عن عبد الله بن عمر، قال: قال رسول الله ﷺ: «كُلُّ نَسَب وصِهْر ينقطع يوم القيامة إلا نَسَبي وصِهْري»{16}. (١٠/٦٢٢) ٥٢٠٩٥- عن المِسْور بن مخرمة، قال: قال رسول الله ﷺ: «إنّ الأنساب تنقطع يوم القيامة غير نسبي وسببي وصهري»{17}. (١٠/٦٢١) ٥٢٠٩٦- عن أنس بن مالك، قال: قال رسولُ الله ﷺ: «إذا دخل أهلُ الجنة الجنةَ وأهلُ النار النارَ نادى مُنادٍ مِن أهل العرش: يا أهل التَّظالُم، تَتارَكُوا مظالِمَكم، وادخلوا الجنة»{18}. (ز) ٥٢٠٩٧- عن الحسن البصري، قال: قال رسول الله ﷺ: «ثلاثة مواطن لا يَسْأَلُ فيها أحدٌ أحدًا: إذا وُضِعت الموازين حتى يعلم أيثقل ميزانه أم يخف، وإذا تطايرت الكتب حتى يعلم أيأخذ كتابه بيمينه أم بشماله، وعند الصراط حتى يعلم أيَجُوزُ الصراطَ أم لا يجوز»{19}. (ز) ٥٢٠٩٨- عن قتادة بن دعامة -من طريق حفص بن المغيرة- قال: ليس شيءٌ أبغضَ إلى الانسان يوم القيامة مِن أن يرى مَن يعرفه؛ مخافة أن يَذُوبَ{20} له عليه شيء. ثم قرأ: <q>﴿يوم يفر المرء من أخيه﴾</q> [عبس:٣٤]{21}. (١٠/٦٢١) ",footnotes:1:تفسير الثعلبي ٧/٥٧.أخرجه ابن أبي الدنيا في كتاب الأهوال -موسوعة ابن أبي الدنيا ٦/٢٤٧ (٢٥٩) - مُطَوَّلًا، وابن جرير ١٧/١١٢-١١٣، وأبو نعيم في الحلية ٤/٢٠١-٢٠٢، وابن عساكر ١٨/٢٨٥. وعزاه السيوطي إلى ابن المبارك في الزهد، وابن المنذر، وابن أبي حاتم.تفسير البغوي ٥/٤٢٩.أخرجه ابن جرير ١٧/١١٢. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.عزاه السيوطي إلى سعيد بن منصور، وعبد بن حميد، وابن المنذر، وابن أبي حاتم.أخرجه ابن جرير ١٧/١١١، والحاكم ٢/٣٩٤ من وجه آخر.أخرجه البخاري مطولًا - كتاب التفسير ٤/١٨١٦.تفسير الثعلبي ٧/٥٦.علَّقه يحيى بن سلّام ١/٤١٦.عزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ١٧/١١١-١١٢. وعزاه السيوطي إلى عبد بن حميد.تفسير مقاتل بن سليمان ٣/١٦٦.عزاه السيوطي إلى ابن جرير، وعند ابن جرير ١٧/١١٣ عن حجاج، ولعل فيه سقطًا.علَّقه يحيى بن سلّام ١/٤١٦.أخرجه الحاكم ٣/١٥٣ (٤٦٨٤) بتمامه، والطبراني في الكبير ٣/٤٥ (٢٦٣٤، ٢٦٣٥) واللفظ له. قال الحاكم: «هذا حديث صحيح الإسناد، ولم يُخَرِّجاه». وقال الذهبي في التلخيص: «منقطع». وقال الطبراني في الأوسط ٥/٣٧٦ (٥٦٠٦): «لم يُجَوِّد هذا الحديث عن سفيان بن عيينة إلا الحسن بن سهل، ورواه غيره عن سفيان عن جعفر عن أبيه، ولم يذكروا جابر بن عبد الله». وأورده الدارقطني في العلل ٢/١٩٠ (٢١١). وقال الهيثمي في المجمع ٩/١٧٣ (١٥٠١٩): «رواه الطبراني في الأوسط والكبير باختصار، ورجالهما رجال الصحيح، غير الحسن بن سهل، وهو ثقة». وينظر: الألباني في الصحيحة ٥/٥٨ (٢٠٣٦).أخرجه أبو الفضل الزهري في حديثه ص٣٨٨ (٣٥٩)، وابن عساكر في تاريخه ٦٧/٢١. قال الألباني في الصحيحة ٥/٦٤: «وهذا إسناد ضعيف جِدًّا... وجملة القول: أنّ الحديث بمجموع هذه الطرق صحيح».أخرجه أحمد ٣١/٢٠٧-٢٠٨ (١٨٩٠٧)، ٣١/٢٥٨ (١٨٩٣٠)، والحاكم ٣/١٧٢ (٤٧٤٧). قال الحاكم: «هذا حديث صحيح الإسناد، ولم يخرجاه». وقال ابن كثير في تفسيره ٥/٤٩٥: «هذا الحديث له أصل في الصحيحين عن المسور». وقال ابن الملقن في البدر المنير ٧/٤٨٩: «بإسناد صحيح». وأورده الألباني في الصحيحة ٤/٦٥٠ (١٩٩٥) وقال تعقيبًا على موافقة الذهبي للحاكم: «وهذا عجب منه، فإنّ أُمَّ بكر هذه لا تُعْرَف، بشهادة الذهبي نفسه، فإنّه أوردها في فصل النسوة المجهولات، وقال: تفرَّد عنها ابن أخيها عبد الله بن جعفر». ثم قال: «لَكِنِّي وجدت لها متابعًا قويًّا...» وذكره.أخرجه ابن أبي الدنيا في كتاب حسن الظن بالله ص١٠٧ (١١٦)، والطبراني في الأوسط ٥/٢٢٢ (٥١٤٤)، وابن جرير ١٧/١١٤. قال الطبراني: «لم يروِ هذا الحديثَ عن أنس إلا سدوسٌ، تَفَرَّد به أبو عون». وقال الهيثمي في المجمع ١٠/٣٥٦ (١٨٤٢٦): «رواه الطبراني في الأوسط، وفيه الحكم بن سنان أبو عون، قال أبو حاتم: عنده وهم كثير، وليس بالقوي، ومحله الصدق، يُكْتَب حديثه. وضعّفه غيره، وبقية رجاله ثقات». وقال البوصيري في إتحاف الخيرة ٨/٢٠٥ (٧٧٩١): «رواه أبو يعلى، وفي سنده سدوس صاحب السامري، وهو ضعيف».أخرجه يحيى بن سلّام ١/٤١٦.من قولهم: ذاب لي عليه من الحق كذا، أي: ثبت ووجب. النهاية (ذوب)، واللسان (برد).أخرجه ابن جرير ١٧/١١٤.
23,102," <q>﴿فَمَن ثَقُلَتۡ مَوَ ٰ⁠زِینُهُۥ فَأُو۟لَـٰۤىِٕكَ هُمُ ٱلۡمُفۡلِحُونَ ۝١٠٢ وَمَنۡ خَفَّتۡ مَوَ ٰ⁠زِینُهُۥ فَأُو۟لَـٰۤىِٕكَ ٱلَّذِینَ خَسِرُوۤا۟ أَنفُسَهُمۡ فِی جَهَنَّمَ خَـٰلِدُونَ ۝١٠٣﴾</q> - تفسير ٥٢٠٩٩- قال مقاتل بن سليمان: <q>﴿فمن ثقلت موازينه﴾</q> بالعمل الصالح، يعني: المؤمنين؛ <q>﴿فأولئك هم المفلحون﴾</q> يعني: الفائزين، <q>﴿ومن خفت موازينه﴾</q> يعني: الكفار؛ <q>﴿فأولئك الذين خسروا﴾</q> يعني: غَبَنوا <q>﴿أنفسهم في جهنم خالدون﴾</q> لا يموتون{1}. (ز) ٥٢١٠٠- قال يحيى بن سلّام: قوله: <q>﴿فمن ثقلت موازينه فأولئك هم المفلحون﴾</q> السعداء، وهم أهل الجنة، <q>﴿ومن خفت موازينه فأولئك الذين خسروا أنفسهم﴾</q> أن يغنموها؛ فصاروا في النار. قال: <q>﴿في جهنم خالدون﴾</q> لا يخرجون منها، ولا يموتون{2}. (ز) ",footnotes:1:تفسير مقاتل بن سليمان ٣/١٦٦.تفسير يحيى بن سلّام ١/٤١٦.
  23,103,""
23,104," <q>﴿تَلۡفَحُ وُجُوهَهُمُ ٱلنَّارُ﴾</q> - تفسير ٥٢١٠١- عن أبي الدرداء، قال: قال رسول الله ﷺ في قوله: <q>﴿تلفح وجوههم النار﴾</q>: «تلفحهم لفحةً، فتَسِيل لحومُهم على أعقابهم»{1}. (١٠/٦٢٢) ٥٢١٠٢- عن أبي هريرة، عن النبي ﷺ، قال: «إنّ جَهَنَّم لَمّا سيق إليها أهلُها تَلَقَّتهم بعُنُق، فلفحتهم لفحةً، فلم تدع لحمًا على عظم إلا ألقته على العُرْقوب{2}»{3}. (١٠/٦٢٢) ٥٢١٠٣- عن عبد الله بن مسعود، في قوله: <q>﴿تلفح وجوههم النار﴾</q>، قال: لَفَحَتْهم لفحةً، فما أبْقَتْ لحمًا على عَظْمٍ إلا ألقته على أعقابهم{4}. (١٠/٦٢٣) ٥٢١٠٤- عن عبد الله بن أبي الهذيل -من طريق أبي سِنان-، مثله{5}. (١٠/٦٢٣) ٥٢١٠٥- عن عبد الله بن عباس -من طريق ابن جريج- <q>﴿تلفح وجوههم النار﴾</q>، قال: تَنفَحُ{6}. (١٠/٦٢٢) ٥٢١٠٦- قال مقاتل بن سليمان: <q>﴿تلفح﴾</q> يعني: تنفخ <q>﴿وجوههم النار﴾</q>{7}. (ز) <q>﴿وَهُمۡ فِیهَا كَـٰلِحُونَ ۝١٠٤﴾</q> - تفسير ٥٢١٠٧- عن أبي هريرة، قال: قال رسول الله ﷺ: «شَفَتُه السُّفْلى ساقِطَةٌ على صدره، والعليا قالِصَةٌ قد غطَّتْ وجهَه»{8}. (ز) ٥٢١٠٨- عن أبي سعيد الخدري، عن رسول الله ﷺ، في قوله: <q>﴿تلفح وجوههم النار وهم فيها كالحون﴾</q>، قال: «تشويه النار، فتقلص شفته العليا حتى تبلغ وسط رأسه، وتسترخي شفته السفلى حتى تضرب سُرَّتَه»{9}. (١٠/٦٢٣) ٥٢١٠٩- عن عبد الله بن مسعود -من طريق أبي الأَحْوَص- في قوله: <q>﴿وهم فيها كالحون﴾</q>، قال: ألم [تَرَ] إلى الرأس النَّضِيج؛ قد بَدَت أسنانُه، وقلصت شفتاه؟{10}. (١٠/٦٢٣) ٥٢١١٠- عن عبد الله بن عباس -من طريق علي- في قوله: <q>﴿كالحون﴾</q>، قال: عابسون{11}. (١٠/٦٢٤) ٥٢١١١- قال مقاتل بن سليمان: <q>﴿وهم فيها كالحون﴾</q> عابسين، شفته العليا قالِصَةٌ لا تُغَطَّي أنيابَه، وشفته السفلى تضرب بطنه، وثناياه خارجة مِن فيه، بين شفتيه أربعون ذراعًا بذراع الرجل الطويل مِن الخلق الأول، كل ناب له مثل أحد{12}. (ز) ٥٢١١٢- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿وهم فيها كالحون﴾</q>، قال: ألم تروا إلى الغنم إذا مسَّت النارُ وجوهَها؛ كيف هي؟{13}. (ز) <q>﴿وَهُمۡ فِیهَا كَـٰلِحُونَ ۝١٠٤﴾</q> - آثار متعلقة بالآية ٥٢١١٣- عن أبي هريرة -من طريق الحكم بن الأعرج- قال: يعظم الكافر في النار مسيرةِ سبع ليال، ضِرْسُه مثلُ أحد، شفاههم عند صدرهم، سُودٌ، زُرْق، حُبْنٌ{14}، مفتوحون، يتهافتون في النار، ويقول: هل امتلأتِ؟ وتقول: هل مِن مزيد؟ حتى يضع الرحمن قدمَه فيها، فتقول: ربِّ، قط قط{15}. (ز) ٥٢١١٤- عن مغيث بن سُمَيٍّ، قال: إذا جيء بالرجل إلى النار قيل: انتظر حتى نُتحِفَكَ. فيؤتى بكأس مِن سُمِّ الأفاعي والأَساوِد{16}، إذا أدناها مِن فيه نَثَرَتِ اللحمَ على حِدَة، والعظمَ على حِدَة{17}. (١٠/٦٢٣) ",footnotes:1:أخرجه ابن مردويه -كما في تفسير ابن كثير ٥/٤٩٧-، من طريق سعد بن سعيد المقبري، عن أخيه، عن أبيه، عن أبي الدرداء به. إسناده ضعيف جِدًّا؛ فيه سعد بن سعيد المقبري، قال ابن حجر في التقريب (٢٢٣٦): «ليّن الحديث». وفيه أخوه عبد الله بن سعيد المقبري، قال عنه ابن حجر في التقريب (٣٣٥٦): «متروك».العرقوب: هو الوتر الذي خلف الكعبين بين مفصل القدم والساق من ذوات الأربع، وهو من الإنسان فُوَيق العقب. النهاية (عرقب).أخرجه الطبراني في الأوسط ١/٩٢ (٢٧٨)، ٩/١٤٤ (٩٣٦٥)، وأبو نعيم في الحلية ٤/٣٦٣، ٥/٩٣. ذكر الدارقطني في العلل ١١/٤٦ (٢١١٨) الاختلاف في طرقه بين وصله أو إرساله، ووقفه أو رفعه. وقال المنذري في الترغيب ٤/٢٦٧-٢٦٨ (٥٦١٠): «رواه الطبراني في الأوسط والبيهقي مرفوعًا، ورواه غيرهما موقوفًا عليه، وهو أصح». وقال الهيثمي في المجمع ١٠/٣٨٩ (١٨٥٨٦): «رواه الطبراني في الأوسط، وفيه محمد بن سليمان بن الأصبهاني، وهو ضعيف». وقال الألباني في الضعيفة ١١/٤٧٥ (٥٣٠٢): «ضعيف».عزاه السيوطي إلى أبي نعيم في الحلية.أخرجه ابن أبي شيبة ١٣/١٥٢، وابن أبي الدنيا في كتاب صفة النار -موسوعة ابن أبي الدنيا ٦/٤٢٤ (١١٠)-، وإسحاق البستي في تفسيره ص٤٠٨، وأبو نعيم في الحلية ٤/٣٥٩-٣٦٠. وعزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ١٧/١١٥.تفسير مقاتل بن سليمان ٣/١٦٦، ولعلها «تنفح» تصحفت.أخرجه يحيى بن سلّام في تفسيره ١/٤١٧، من طريق صاحب له، عن يحيى بن عبد الله المزني، عن أبيه، عن أبي هريرة به. إسناده ضعيف؛ لجهالة صاحب يحيى بن سلّام شيخه في الرواية.أخرجه أحمد ١٨/٣٥٠ (١١٨٣٦)، والترمذي ٤/٥٤٣ (٢٧٦٩)، ٥/٣٩٤ (٣٤٥٠)، والحاكم ٢/٢٦٩ (٢٩٧١)، ٢/٤٢٨ (٣٤٩٠). قال الترمذي: «حديث حسن صحيح غريب». وقال الحاكم: «هذا حديث صحيح الإسناد، ولم يخرجاه». وقال البغوي في شرح السنة ١٥/٢٥٢ (٤٤١٦): «هذا حديث حسن غريب».أخرجه الثوري في تفسيره ص٢١٨، وعبد الرزاق ٢/٤٨، وابن أبي شيبة ١٣/١٧٤-١٧٥، وهناد (٣٠٣، ٣٠٤)، وابن أبي الدنيا في كتاب صفة النار -موسوعة ابن أبي الدنيا ٦/٤٢٤ (١١٣)- بنحوه، وابن جرير ١٧/١١٦، والطبراني (٩١٢١)، والحاكم ٢/٣٩٥. وعزاه السيوطي إلى الفريابي، وابن المنذر وابن أبي حاتم بلفظ: كُلوح الرأس النضيج، بدت أسنانهم، وتقلصت شفاههم.أخرجه ابن جرير ١٧/١١٥-١١٦، وابن أبي حاتم -كما في تغليق التعليق ٤/٢٦٣، والإتقان ٢/٣١-. وعزاه السيوطي إلى ابن المنذر.تفسير مقاتل بن سليمان ٣/١٦٦.أخرجه ابن جرير ١٧/١١٦.حُبْنٌ: جمع أحْبَن: وهو المُسْتَسْقي، مِنَ الحَبَن -بالتحريك-، وهو عِظَمُ البطن. اللسان (حبن).أخرجه يحيى بن سلّام ١/٤١٧.الأَساوِد: جمع الأسود، وهي أخبث الحيات وأعظمها. النهاية (سود).أخرجه ابن أبي شيبة ١٣/١٥٣.
