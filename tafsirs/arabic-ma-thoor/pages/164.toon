quran[16]{c,v,t}:
7,105," <q>﴿حَقِیقٌ عَلَىٰۤ أَن لَّاۤ أَقُولَ عَلَى ٱللَّهِ إِلَّا ٱلۡحَقَّۚ قَدۡ جِئۡتُكُم بِبَیِّنَةࣲ مِّن رَّبِّكُمۡ فَأَرۡسِلۡ مَعِیَ بَنِیۤ إِسۡرَ ٰ⁠ۤءِیلَ ۝١٠٥ قَالَ إِن كُنتَ جِئۡتَ بِـَٔایَةࣲ فَأۡتِ بِهَاۤ إِن كُنتَ مِنَ ٱلصَّـٰدِقِینَ ۝١٠٦﴾</q> - قراءات ٢٨٣٨١- عن مجاهد بن جبر أنّه كان يقرأ: ‹حَقِيقٌ عَلَيَّ أن لَّآ أقُولَ›{1}٢٥٩٨. (٦/٤٩٢) ٢٥٩٨ ذكر ابنُ جرير (١٠/٣٤٢) هذه القراءة، ثم عَلَّق عليها بقوله: «المعنى على هذه القراءة: واجبٌ عَلَيَّ أن لا أقول، وحقٌّ علي أن لا أقول». وبنحوه قال ابنُ تيمية (٣/١٩١). وعلّق ابنُ عطية (٤/١٣ بتصرف) على هذه القراءة بقوله: «وإعراب»أنْ«على قراءة مَن فتح الياء مشددة رفعٌ». وقد ذكر ابنُ جرير أيضًا قراءة من قرأ ذلك بإرسال الياء مِن <q>﴿على﴾</q>، ولم يرجح إحداهما على الأخرى، وبيَّن أنّ القراءتين متقاربتا المعنى؛ بأيتهما قرأ القارئ فهو مصيب. <q>﴿حَقِیقٌ عَلَىٰۤ أَن لَّاۤ أَقُولَ عَلَى ٱللَّهِ إِلَّا ٱلۡحَقَّۚ قَدۡ جِئۡتُكُم بِبَیِّنَةࣲ مِّن رَّبِّكُمۡ فَأَرۡسِلۡ مَعِیَ بَنِیۤ إِسۡرَ ٰ⁠ۤءِیلَ ۝١٠٥ قَالَ إِن كُنتَ جِئۡتَ بِـَٔایَةࣲ فَأۡتِ بِهَاۤ إِن كُنتَ مِنَ ٱلصَّـٰدِقِینَ ۝١٠٦﴾</q> - تفسير الآية ٢٨٣٨٢- عن عبد الله بن عباس -من طريق سعيد بن جبير- قال: فقال فرعون لموسى: ما تريد؟ قال: أريد أن تؤمن بالله، وأن ترسل معي بني إسرائيل. فأبى عليه ذلك، وقال: [ائت] بآية إن كنت من الصادقين{2}. (ز) ٢٨٣٨٣- قال مقاتل بن سليمان: <q>﴿حقيق على أن لا أقول على الله إلا الحق﴾</q> فإنّه بعثني رسولًا، <q>﴿قد جئتكم ببينة من ربكم﴾</q> يعني: اليد، والعصا؛ بأنِّي رسول الله، <q>﴿فأرسل معي بني إسرائيل﴾</q> إلى فلسطين. قال فرعون: <q>﴿إن كنت جئت بآية فأت بها إن كنت من الصادقين﴾</q> بأنّك رسول رب العالمين{3}. (ز) ",footnotes:1:عزاه السيوطي إلى أبي الشيخ. وهي قراءة متواترة، قرأ بها نافع، وقرأ بقية العشرة: <q>﴿عَلى﴾</q>. انظر: النشر ٢/٢٧٠، والإتحاف ص٢٨٦.أخرجه ابن أبي حاتم ٥/١٥٣٢.تفسير مقاتل بن سليمان ٢/٥٢.
  7,106,""
7,107," <q>﴿فَأَلۡقَىٰ عَصَاهُ﴾</q> - تفسير ٢٨٣٨٤- عن عبد الله بن عباس -من طريق سعيد بن جبير- قال: عصا موسى اسمُها: ماشا{1}. (٦/٤٩٤) ٢٨٣٨٥- قال مقاتل بن سليمان: وفي يد موسى عصا، فزعم ابن عباس أن مَلَكًا من الملائكة دفعها إليه حين توجه إلى مدين، فقال موسى لفرعون: ما هذه بيدي؟ قال فرعون: عصا. فألقى موسى عصاه مِن يده؛ فإذا هي ثعبان مبين{2}. (ز) ٢٨٣٨٦- عن سعيد بن جبير، قال: كانتْ عصا موسى من عَوْسَجٍ{3} فقط{4}. (ز) ٢٨٣٨٧- عن الحكم [بن عُتَيبة] -من طريق ابن أبي غنية- قال: كانتْ عصا موسى مِن عَوْسَجٍ، ولم يُسَخَّرِ العَوْسَجُ لأحدٍ بعدَه{5}. (٦/٤٩٤) ٢٨٣٨٨- عن قتادة بن دعامة، في قوله: <q>﴿فألقى عصاه﴾</q>، قال: ذُكِر لنا: أنّ تلك العصا عصا آدم، أعطاه إياها مَلَكٌ حين توجَّه إلى مَدْيَن، فكانت تُضِيءُ له بالليل، ويَضْرِبُ بها الأرضَ بالنهار فيَخرُجُ له رزقُه، ويَهُشُّ بها على غنمِه{6}. (٦/٤٩٣) ٢٨٣٨٩- عن مسلم -من طريق حبيب بن حسان- قال: عصا موسى هي الدابَّةُ. يعني: دابة الأرض{7}. (٦/٤٩٤) <q>﴿فَإِذَا هِیَ ثُعۡبَانࣱ مُّبِینࣱ ۝١٠٧﴾</q> - تفسير ٢٨٣٩٠- عن عبد الله بن عباس -من طريق علي- في قوله: <q>﴿فإذا هي ثعبان مبين﴾</q>، قال: الحيَّة الذَّكَر{8}. (٦/٤٩٤) ٢٨٣٩١- عن مجاهد بن جبر -من طريق أبي سعد- في قوله: <q>﴿فألقى عصاه فإذا هي ثعبان مبين﴾</q>، قال: حية تَسْعى{9}. (ز) ٢٨٣٩٢- عن الضحاك بن مُزاحِم -من طريق جُوَيْبِر- <q>﴿فإذا هي ثعبان مبين﴾</q>، قال: الحَيَّة الذَّكَر{10}. (ز) ٢٨٣٩٣- عن وهب بن مُنبِّه -من طريق عيسى بن عبيد بن زرارة- قال: كان بين لَحْيَي الثعبان الذي مِن عصا موسى اثنا عشر ذِراعًا{11}. (٦/٤٩٥) ٢٨٣٩٤- عن قتادة بن دعامة -من طريق مَعْمَر- في قوله: <q>﴿فإذا هي ثعبانٌ مبينٌ﴾</q>، قال: تحوَّلتْ حيَّةً عظيمة.= (ز) ٢٨٣٩٥- قال معمر: قال غيره: مثلَ المدينة{12}. (٦/٤٩٤) ٢٨٣٩٦- عن قتادة بن دعامة -من طريق سعيد- قوله: <q>﴿فإذا هي ثعبان مبين﴾</q>، يقول: فإذا هي حيَّة كاد يَسُورُه، يعني: يَثِب عليه{13}. (٦/٤٩٣) ٢٨٣٩٧- عن إسماعيل السُّدِّيّ -من طريق أسباط- في قوله: <q>﴿فإذا هي ثعبان مبين﴾</q>، قال: الذَّكَرُ مِن الحيّات{14}. (٦/٤٩٥) ٢٨٣٩٨- عن محمد بن السائب الكلبي، قال: حيَّةٌ صفراء ذَكَرٌ{15}. (٦/٤٩٥) ٢٨٣٩٩- قال مقاتل بن سليمان: <q>﴿فإذا هي ثعبان مبين﴾</q>، يعني: حيَّة بَيِّنة{16}. (ز) <q>﴿فَأَلۡقَىٰ عَصَاهُ فَإِذَا هِیَ ثُعۡبَانࣱ مُّبِینࣱ ۝١٠٧﴾</q> - تفسير ٢٨٤٠٠- عن عبد الله بن عباس -من طريق عكرمة- <q>﴿فإذا هي ثعبان مبين﴾</q>، قال: ألقى العصا، فصارت حيَّة، فوضعت فُقْمًا{17} لها أسفلَ القُبَّة، وفُقْمًا لها أعلى القُبَّة -قال عبد الكريم: قال إبراهيم: وأشار سفيان بإصبعه الإبهام والسبابة هكذا شبه الطاقِ-، فلمّا أرادت أن تأخذه قال فرعون: يا موسى، خذها، خذها. فأخذها موسى بيده، فصارت عصا كما كانت أول مرة{18}. (ز) ٢٨٤٠١- عن عبد الله بن عباس -من طريق سعيد بن جبير-: <q>﴿فألقى عصاه﴾</q> فتحوَّلَتْ حيَّة عظيمة فاغرة فاها، مسرعة إلى فرعون، فلما رآها فرعون أنّها قاصدة إليه خافها، فاقتحم على سريره، واستغاث بموسى أن يَكُفَّها عنه، ففعل{19}. (ز) ٢٨٤٠٢- عن عبد الله بن عباس -من طريق سعيد- قال: لقد دخل موسى على فرعون وعليه زُرْمانِقةٌ{20} مِن صوفٍ، ما تُجاوِزُ مِرْفَقَه، فاستُؤْذِن على فرعون، فقال: أدْخِلوه. فدخَل، فقال: إنّ إلهي أرسَلني إليك. فقال للقوم حولَه: ما عَلمتُ لكم من إله غيري، خُذوه. قال: إنِّي قد جِئتُك بآيةٍ. قال: فائتِ بها إن كنتَ من الصادقين. فألقى عصاه، فصارت ثعبانًا، ما بينَ لَحْيَيه ما بين السقف إلى الأرض، وأدخل يدَه في جيبه، فأخرَجَها مثل البرق تَلْتَمِعُ الأبصار، فخَرُّوا على وجوهِهم، وأخَذ موسى عصاه، ثم خرَج، ليس أحدٌ من الناس إلا يَفِرُّ منه، فلما أفاق وذهَب عن فرعون الرَّوْعُ قال للملأ حولَه: ماذا تأْمُرون؟ قالوا: أرْجِئْه وأخاه، لا تَأتِنا به، ولا يَقْرَبُنا، وأرسِلْ في المدائن حاشِرِين. وكانت السحرةُ يَخشَون من فرعون، فلمّا أرسَل إليهم قالوا: قد احتاج إليكم إلهُكم. قال: إنّ هذا فعَل كذا وكذا. قالوا: إنّ هذا ساحرٌ يَسْحرُ، أئنَّ لنا لأجرًا إن كنا نحن الغالبين؟ قال: ساحرٌ يَسْحرُ الناس، ولا يَسْحرُ الساحرُ الساحرَ. قال: نعم، وإنكم إذنْ لمن المقربين{21}. (٦/٤٩٣) ٢٨٤٠٣- عن المنهال -من طريق الأعمش- قال: ارتفعتِ الحيةُ في السماء مِيلًا، فأقبلَتْ إلى فرعون، فجعلت تقولُ: يا موسى، مُرْنِي بما شئتَ. وجعل فرعون يقولُ: يا موسى، أسألُك بالذي أرْسَلك. قال: وأخَذه بَطْنُه{22}. (٦/٤٩٣) ٢٨٤٠٤- عن وهب بن منبه -من طريق عبد الصمد- قال: لَمّا دخل موسى على فرعون قال له موسى: أُعَرِّفُك؟ قال: نعم. قال: <q>﴿ألَمْ نُرَبِّكَ فِينا ولِيدًا﴾</q> [الشعراء: ١٨]؟. قال: فردَّ إليه موسى الذي ردَّ، فقال فرعون: خذوه. فبادره موسى، فألقى عصاه، فإذا هي ثعبان مبين، فحملت على الناس، فانهزموا منها، فمات منهم خمسة وعشرون ألفًا، قتل بعضُهم بعضًا، وقام فرعون منهزمًا حتى دخل البيت{23}٢٥٩٩. (ز) ٢٥٩٩ علّق ابنُ كثير (٦/٣٦٠) على رواية وهب، فقال: «رواه ابن جرير، والإمام أحمد في كتابه الزهد، وابن أبي حاتم، وفيه غرابة في سياقه». ٢٨٤٠٥- عن إسماعيل السُّدِّيّ -من طريق أسباط- في قوله: <q>﴿فإذا هي ثعبان مبين﴾</q>، قال: الذَّكَرُ من الحيّات، فاتحةً فَمَها، واضعةً لَحْيَها الأسفل في الأرض، والأعلى على سُور القصر، ثم توجَّهتْ نحو فرعون لِتأخُذَه، فلمّا رآها ذُعِرَ منها، ووثَب فأحْدَث، ولم يكنْ يُحدِثُ قبل ذلك، وصاح: يا موسى، خُذْها وأنا أومنُ بك وأُرْسلُ معك بني إسرائيل. فأخَذها موسى، فصارت عصًا{14}. (٦/٤٩٥) ٢٨٤٠٦- عن فَرْقَد السَّبخي -من طريق ديلم بن غزوان- قال: كان فرعون إذا كانت له حاجةٌ ذهبت به السَّحرة مسيرةَ خمسين فَرْسخًا، فإذا قضى حاجتَه جاءوا به، حتى كان يومُ عصا موسى، فإنها فَتَحتْ فاها، فكان ما بينَ لَحْيَيْها أربعين ذراعًا؛ فأحْدَث يومئذٍ أربعين مَرَّةً{25}. (٦/٤٩٥) ",footnotes:1:أخرجه ابن أبي حاتم ٥/١٥٣٦، ٩/٢٨٤٨.تفسير مقاتل بن سليمان ٢/٥٢-٥٣.العَوْسَج: شجر من شجر الشوك. لسان العرب (عسج).علقه ابن أبي حاتم ٨/٢٧٥٨.أخرجه ابن أبي حاتم ٥/١٥٣٢، ٨/٢٧٥٨. وعزاه السيوطي إلى ابن المنذر.عزاه السيوطي إلى عبد بن حميد، وأبي الشيخ.أخرجه ابن أبي حاتم ٩/٢٩٧٤.أخرجه ابن جرير ١٠/٣٤٥، وابن أبي حاتم ٥/١٥٣٢، ٨/٢٧٥٨. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وأبي الشيخ.أخرجه ابن جرير ١٠/٣٤٥.أخرجه ابن جرير ١٠/٣٤٦.أخرجه ابن أبي حاتم ٨/٢٧٥٨-٢٧٥٩.أخرجه عبد الرزاق ١/٢٣٣، وابن جرير ١٠/٣٤٣، وابن أبي حاتم ٥/١٥٣٣، ٨/٢٧٥٨. وعزاه السيوطي إلى ابن المنذر، وأبي الشيخ.أخرجه ابن جرير ١٠/٣٤٣. وعزاه السيوطي إلى عبد بن حميد بلفظ: حيةٌ تكاد تُساوِرُه.أخرجه ابن جرير ١٠/٣٤٣-٣٤٤، وابن أبي حاتم ٨/٢٧٥٩.عزاه السيوطي إلى أبي الشيخ.تفسير مقاتل بن سليمان ٢/٥٣.الفَقْم: أحد اللَّحْيَيْن، وهما الفكّان. اللسان (فقم) (فكك).أخرجه ابن جرير ١٠/٣٤٤.أخرجه ابن جرير ١٠/٣٤٤، وابن أبي حاتم ٥/١٥٣٢.الزُّرْمانقة: جُبَّة من صوف. وهي كلمة أعجمية. النهاية (زَرْمَقَ).أخرجه ابن أبي حاتم ٥/١٥٣٤، ٨/٢٧٥٣-٢٧٦٣ وبعضه من طريق مقسم.أخرجه ابن جرير ١٧/٥٦٦. وعزاه السيوطي إلى أبي الشيخ.أخرجه ابن جرير ١٠/٣٤٥، وابن أبي حاتم ٥/١٥٣٢.أخرجه ابن جرير ١٠/٣٤٣-٣٤٤، وابن أبي حاتم ٨/٢٧٥٩.أخرجه ابن جرير ١٠/٣٤٥، وابن أبي حاتم ٨/٢٧٥٩.
7,108," <q>﴿وَنَزَعَ یَدَهُۥ فَإِذَا هِیَ بَیۡضَاۤءُ لِلنَّـٰظِرِینَ ۝١٠٨﴾</q> - تفسير ٢٨٤٠٧- عن عبد الله بن عباس -من طريق سعيد بن جبير- قوله: <q>﴿فإذا هي بيضاء للناظرين﴾</q>، قال: أخرج يده من جيبه، فرآها بيضاء من غير سوء، يعني به: البرص، ثم أعادها في كُمِّه، فصارت إلى لونها الأول{1}. (ز) ٢٨٤٠٨- عن عبد الله بن عباس -من طريق علي-: <q>﴿بَيْضاءُ لِلنّاظِرِينَ﴾</q> من غير بَرَص{2}. (ز) ٢٨٤٠٩- عن مجاهد بن جبر -من طريق أبي سعد- في قوله: <q>﴿ونزع يده﴾</q> قال: نزع يده من جيبه، <q>﴿فإذا هي بيضاء للناظرين﴾</q>، وكان موسى رجلًا آدَمَ، فأخرج يده، فإذا هي بيضاء أشد بياضًا من اللبن، <q>﴿من غير سوء﴾</q> [طه:٢٢] قال: من غير بَرَص، آيةً لفرعون{3}. (ز) ٢٨٤١٠- عن مجاهد بن جبر: <q>﴿ونزع يده﴾</q>، قال: الكَفّ{4}. (٦/٤٩٦) ٢٨٤١١- عن إسماعيل السُّدِّيّ -من طريق أسباط- في قوله: <q>﴿ونَزَعَ يَدَهُ﴾</q> أخرجها من جيبه، <q>﴿فَإذا هِيَ بَيْضاءُ لِلنّاظِرِينَ﴾</q>{5}. (ز) ٢٨٤١٢- قال محمد بن السائب الكلبي: بلغنا: أنّ موسى قال: يا فرعون، ما هذه بيدي؟ قال: هي عصا. فألقاها موسى، فإذا هي ثعبان مبين، قد ملأت الدار من عظمها، ثم أهوت إلى فرعون لتبتلعه، فنادى: يا موسى، يا موسى. فأخذ موسى بذنبها، فإذا هي عصا بيده، فقال فرعون: يا موسى، هل من آية غير هذه؟ قال: نعم. قال: ما هي؟ قال: فأخرج موسى يده، فقال: ما هذه، يا فرعون؟ قال: هذه يدك. فأدخلها موسى في جيبه، ثم أخرجها، <q>﴿فإذا هي بيضاء للناظرين﴾</q>، أي: تغشى البصرَ من بياضها{6}. (ز) ٢٨٤١٣- قال مقاتل بن سليمان: فقال فرعون: فهل من آية غيرها. قال: نعم. فأخرج يده، وقال لفرعون: ما هذه؟ قال: هذه يدك. فأدخل موسى يده في جيبه وعليه مِدْرَعَةٌ من صوف مُضَرِيَّة، ثم أخرجها، فذلك قوله: <q>﴿ونزع يده﴾</q> يعني: أخرج يده من جيبه، <q>﴿فإذا هي بيضاء للناظرين﴾</q> لها شعاع كشعاع الشمس، يغشي البصر من شدة بياضها{7}. (ز) ",footnotes:1:أخرجه ابن جرير ١٠/٣٤٦، وابن أبي حاتم ٥/١٥٣٣.أخرجه ابن جرير ١٠/٣٤٦.تفسير مجاهد ص٣٤٠، وأخرجه ابن جرير ١٠/٣٤٧.عزاه السيوطي إلى أبي الشيخ.أخرجه ابن جرير ١٠/٣٤٧.ذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٢/١٣٥-.تفسير مقاتل بن سليمان ٢/٥٣.
7,109," <q>﴿قَالَ ٱلۡمَلَأُ مِن قَوۡمِ فِرۡعَوۡنَ إِنَّ هَـٰذَا لَسَـٰحِرٌ عَلِیمࣱ ۝١٠٩﴾</q> - تفسير ٢٨٤١٤- قال مقاتل بن سليمان: <q>﴿قال الملأ﴾</q> وهم الكبراء <q>﴿من قوم فرعون إن هذا﴾</q> يعني: موسى <q>﴿لساحر عليم﴾</q> يعني: عالم بالسحر، وذلك أنّ فرعون بدأ بهذه المقالة، فصدَّقه قومه. نظيرُها في الشعراء{1}. (ز) ",footnotes:1:تفسير مقاتل بن سليمان ٢/٥٣. يشير إلى قوله تعالى: <q>﴿قالَ لِلْمَلَإ حَوْلَهُ إنَّ هَذا لَساحِرٌ عَلِيمٌ (٣٤)﴾</q>.
7,110," <q>﴿یُرِیدُ أَن یُخۡرِجَكُم مِّنۡ أَرۡضِكُمۡۖ فَمَاذَا تَأۡمُرُونَ ۝١١٠﴾</q> - تفسير ٢٨٤١٥- عن عبد الله بن عباس -من طريق سعيد بن جبير- قال: فاستشار الملأَ فيما رأى، فقالوا: هذان ساحران، يريدان أن يخرجاكم من أرضكم{1}. (ز) ٢٨٤١٦- عن إسماعيل السُّدِّيّ -من طريق أسباط- في قوله: <q>﴿يريد أن يخرجكم﴾</q>، قال: يَسْتَخرِجَكم من أرضكم{1}. (٦/٤٩٦) ٢٨٤١٧- قال مقاتل بن سليمان: ثُمَّ قال لهم فرعون: <q>﴿يريد أن يخرجكم من أرضكم﴾</q> وهي مصر؛ <q>﴿فماذا تأمرون﴾</q> يعني: تُشِيرون{3}. (ز) ",footnotes:1:أخرجه ابن أبي حاتم ٥/١٥٣٣.أخرجه ابن أبي حاتم ٥/١٥٣٣.تفسير مقاتل بن سليمان ٢/٥٣.
7,111," <q>﴿قَالُوۤا۟ أَرۡجِهۡ وَأَخَاهُ﴾</q> - تفسير ٢٨٤١٨- عن عبد الله بن عباس -من طريق عطاء- في قوله: <q>﴿أرْجِهْ﴾</q>، قال: أخِّرْه{1}. (٦/٤٩٦) ٢٨٤١٩- قال عطاء: <q>﴿أرْجِهْ﴾</q>: احْبِسه{2}٢٦٠٠. (ز) ٢٦٠٠ قال ابنُ جرير (١٠/٣٤٩): «يقول -تعالى ذِكْرُه-: قال الملأ من قوم فرعون لفرعون: <q>﴿أرجه﴾</q>، أي: أخره. وقال بعضهم: معناه: احبس. والإرجاء في كلام العرب: التأخير، يقال منه: أرجيت هذا الأمر وأرجأته إذا أخرته، ومنه قول الله تعالى: <q>﴿ترجي من تشاء منهن﴾</q> [الأحزاب:٥١]: تُؤَخِّر». ٢٨٤٢٠- عن قتادة بن دعامة -من طريق سعيد- <q>﴿قالوا أرجه وأخاه﴾</q>، قال: احْبِسْه وأَخاه{3}. (٦/٤٩٦) ٢٨٤٢١- قال مقاتل بن سليمان: فردَّ عليه كُبراء قومه: <q>﴿قالوا أرجه وأخاه﴾</q> يقول: أرجئ أمرهم، يقول: أوقف أمرهم حتى ننظر في أمرهما، <q>﴿وأرسل في المدائن حاشرين﴾</q>{4}. (ز) <q>﴿وَأَرۡسِلۡ فِی ٱلۡمَدَاۤىِٕنِ حَـٰشِرِینَ ۝١١١﴾</q> - تفسير ٢٨٤٢٢- عن عبد الله بن عباس -من طريق أبي مالك- في قوله: <q>﴿وأرسل في المدائن حاشرين﴾</q>، قال: الشُّرَط{5}. (٦/٤٩٦) ٢٨٤٢٣- عن مجاهد بن جبر -من طريق إبراهيم بن مهاجر، عن أبيه- <q>﴿وابعث في المدائن حاشرين﴾</q> [الشعراء:٣٦]، قال: الشُّرَط{6}. (ز) ٢٨٤٢٤- عن إسماعيل السُّدِّيّ -من طريق قيس- <q>﴿وابعث في المدائن حاشرين﴾</q>، قال: الشُّرَط{6}. (ز) ",footnotes:1:أخرجه ابن جرير ١٠/٣٥٠، وابن أبي حاتم ٥/١٥٣٣، ٨/٢٧٦١. وعزاه السيوطي إلى ابن المنذر، وأبي الشيخ.تفسير الثعلبي ٤/٢٦٨، تفسير البغوي ٣/٢٦٣.أخرجه ابن جرير ١٠/٣٥١، وابن أبي حاتم ٥/١٥٣٣. وعزاه السيوطي إلى عبد بن حميد.تفسير مقاتل بن سليمان ٢/٥٣.أخرجه ابن جرير ١٠/٣٥١-٣٥٢، وابن أبي حاتم ٥/١٥٣٤، ٨/٢٧٦١. وعزاه السيوطي إلى ابن أبي شيبة، وعبد بن حميد، وابن المنذر، وأبي الشيخ.أخرجه ابن جرير ١٠/٣٥١.أخرجه ابن جرير ١٠/٣٥١.
7,112," <q>﴿یَأۡتُوكَ بِكُلِّ سَـٰحِرٍ عَلِیمࣲ ۝١١٢﴾</q> - تفسير ٢٨٤٢٥- عن عبد الله بن عباس -من طريق سعيد بن جبير- يعني: قوله: <q>﴿يَأْتُوكَ بِكُلِّ ساحِرٍ عَلِيمٍ﴾</q>: فحُشِر له كلُّ ساحر مُتعالِم{1}. (ز) ٢٨٤٢٦- عن عبد الله بن عباس -من طريق مقسم-: <q>﴿وأرسل في المدائن حاشرين﴾</q>، وكانت السحرةُ يَخشَون من فرعون، فلمّا أرسَل إليهم قالوا: قد احتاج إليكم إلهُكم. قال: إنّ هذا فعَل كذا وكذا{1}. (٦/٤٩٣) ٢٨٤٢٧- قال عبد الله بن عباس= (ز) ٢٨٤٢٨- وإسماعيل السُّدِّيّ= (ز) ٢٨٤٢٩- ومحمد بن إسحاق: قال فرعون لَمّا رأى مِن سلطان الله في العصا ما رأى: إنّا لا نُغالِب إلا بِمَن هو أعلم منه. فاتَّخذ غلمانًا من بني إسرائيل، فبعث بهم إلى قرية يُقال لها: الفرحاء، يُعَلِّمونهم السحر، فعلَّموهم سحرًا كثيرًا، وواعد فرعونُ موسى موعدًا، فبعث إلى السحرة، فجاءوا ومعلمهم معهم، فقال له: ماذا صنعت؟ قال: قد علَّمْتُهم سِحرًا لا يُطِيقه سَحَرَةُ أهل الأرض، إلا أن يكون أمرًا من السماء، فإنّه لا طاقة لهم به. ثم بعث فرعونُ في مملكته، فلم يترك في سلطانه ساحرًا إلا أتى به{3}. (ز) ٢٨٤٣٠- عن عبد الله بن عباس -من طريق سعيد بن جبير- قال: فأرسل في المدائن حاشرين، فحُشِر له كلُّ ساحر مُتعالِم، فلمّا أتَوْا فرعون قالوا: بِمَ يَعْمَل هذا الساحر؟ قالوا: يعمل بالحيّات. قالوا: واللهِ، ما في الأرض قومٌ يعملون بالسحر والحيات والحبال والعُصِيِّ أعلمَ منا، فما أجرُنا إن غُلِبْنا؟ فقال لهم: أنتم قرابتي وحامتي، وأنا صانع إليكم كلَّ شيء أحببتم{4}. (ز) ٢٨٤٣١- عن محمد بن إسحاق -من طريق سلمة- <q>﴿أرجه وأخاه وأرسل في المدائن حاشرين يأتوك بكل سحار عليم﴾</q> [الشعراء:٣٦-٣٧]، أي: كاثِرْه بالسحرة، لعلَّك أن تجد في السحرة مَن يأتي بمثل ما جاء به، وقد كان موسى وهارون خرجا من عنده حين أراهم مِن سلطان الله ما أراهم، وبعث فرعونُ في مملكته مكانه، فلم يترك في سلطانه ساحر إلا أتى به. فذُكِر لي -والله أعلم-: أنّه جُمِع له خمسة عشر ألف ساحر، فلما اجتمعوا إليه أمرهم أمره، وقال لهم: قد جاءنا ساحرٌ ما رأينا مثله قط، وإنّكم إن غلبتموه أكرمتكم وفضلتكم، وقربتكم على أهل مملكتي، قالوا: وإنّ لنا ذلك إن غلبناه؟ قال: نعم{5}. (ز) ٢٨٤٣٢- قال مقاتل بن سليمان: <q>﴿يأتوك﴾</q> يحشرون عليك، <q>﴿بكل ساحر عليم﴾</q> يَعنُون: عالِم بالسحر{6}. (ز) ",footnotes:1:أخرجه ابن أبي حاتم ٥/١٥٣٤.أخرجه ابن أبي حاتم ٥/١٥٣٤.تفسير الثعلبي ٤/٢٦٨، وتفسير البغوي ٣/٢٦٤.أخرجه ابن جرير ١٠/٣٥٣، وابن أبي حاتم ٥/١٥٣٤.أخرجه ابن جرير ١٠/٣٥٤.تفسير مقاتل بن سليمان ٢/٥٣.
7,113," <q>﴿وَجَاۤءَ ٱلسَّحَرَةُ فِرۡعَوۡنَ﴾</q> - تفسير ٢٨٤٣٣- عن عبد الله بن عباس -من طريق السدي- قال: كان السحرةُ سبعين رجلًا، أصبحوا سَحَرةً، وأمسَوا شهداء. وفي لفظٍ: كانوا سحرة في أول النهار، وشهداءَ آخر النهار حين قُتلوا{1}. (٦/٤٩٦) ٢٨٤٣٤- قال عبد الله بن عباس: كانوا اثنين وسبعين ساحرًا، مع كل واحد منهم حبلٌ و عصًا {2}.(ز) (ز) ٢٨٤٣٥- عن كعب الأحبار -من طريق جرير، عن عبد العزيز بن رفيع، عن خيثمة، عن أبي سودة- قال: كان سَحرةُ فرعون اثني عشر ألفًا{3}. (٦/٤٩٧) ٢٨٤٣٦- عن كعب الأحبار -من طريق عبد العزيز بن رفيع، عن خيثمة- قال: كانت السحرة سبعة عشر ألفا{4}.(ز) (ز) ٢٨٤٣٧- عن كعب الأحبار -من طريق أبي بكر بن عياش، عن عبد العزيز بن رفيع، عن أبي سودة- قال: كانت سَحَرَةُ فرعون تسعة عشر ألفًا{5}. (ز) ٢٨٤٣٨- عن عكرمة مولى ابن عباس -من طريق يزيد- قال: السَّحَرة كانوا سبعين. قال أبو جعفر: أحسبه أنا قال: ألفًا{6}. (ز) ٢٨٤٣٩- عن القاسم بن أبي بزَّة -من طريق هشام الدستوائي- قال: سحرة فرعون كانوا سبعين ألف ساحر{7}. (٦/٤٩٧) ٢٨٤٤٠- عن محمد بن كعب القرظي -من طريق موسى بن عبيدة- قال: كانَتِ السحرةُ الذين تَوفّاهم الله مسلمين ثمانين ألفًا{5}. (٦/٤٩٨) ٢٨٤٤١- عن محمد بن المنكدر، مثل ذلك{9}. (ز) ٢٨٤٤٢- عن إسماعيل السُّدِّيّ -من طريق أسباط- قال: كان السحرةُ بضعةً وثلاثينَ ألفًا، ليس منهم رجلٌ إلا معه حبلٌ أو عصًا، فلمّا ألقَوا سحَروا أعيُنَ الناس واستَرْهبُوهم{10}. (٦/٤٩٧) ٢٨٤٤٣- عن محمد بن المنكدر -من طريق موسى بن عبيدة- قال: كان السحرة ثمانين ألفًا{11}. (ز) ٢٨٤٤٤- عن أبي ثُمامة [الحنّاط] -من طريق عبد العزيز بن رفيع- قال: سحرة فرعون سبعة عشر ألفًا. وفي لفظٍ: تسعةَ عشر ألفًا{12}. (٦/٤٩٧) ٢٨٤٤٥- قال محمد بن السائب الكلبي: كان الذين يُعلِّمونهم رجلين مجوسيين من أهل نينوى، وكانوا سبعين غير رئيسهم{13}. (ز) ٢٨٤٤٦- قال مقاتل: كانوا اثنين وسبعين؛ اثنان من القبط، وهما رأسا القوم، وسبعون من بني إسرائيل{14}. (ز) ٢٨٤٤٧- قال مقاتل: كان رئيس السحرة شمعون{15}. (ز) ٢٨٤٤٨- عن عبد الملك ابن جُرَيْج -من طريق حجّاج- قال: السحرةُ ثلاثُمائة مِن فيُّومَ، ثلاثمائة من العريش، ويشكُّون في ثلاثمائة من الإسْكَندرِيَّة{16}. (٦/٤٩٨) ٢٨٤٤٩- قال عبد الملك ابن جُرَيْج: رئيس السحرة يوحنا{15}. (ز) ٢٨٤٥٠- عن محمد بن إسحاق -من طريق سلمة- قال: جُمِع له خمسة عشر ألف ساحرٍ{18}٢٦٠١. (٦/٤٩٧) ٢٦٠١ ذكر ابنُ عطية (٤/١٣) قول محمد بن إسحاق في عدد السحرة الذين أتي بهم إلى فرعون، وقول ابن جريج، وقول محمد بن المنكدر، وقول السدي، ثم عَلَّق عليها جميعًا بقوله: «وهذه الأقوال ليس لها سند يوقف عنده». <q>﴿قَالُوۤا۟ إِنَّ لَنَا لَأَجۡرًا إِن كُنَّا نَحۡنُ ٱلۡغَـٰلِبِینَ ۝١١٣﴾</q> - تفسير ٢٨٤٥١- عن عبد الله بن عباس -من طريق عكرمة- قال: قال فرعون: لا نُغالِبه -يعني: موسى- إلا بمن هو منه. فأعَدَّ غِلمانًا مِن بني إسرائيل، فبعث بهم إلى قرية بمصر يقال لها: الفَرَما{19}، يُعَلِّمونهم السحر، كما يُعَلَّم الصبيان الكِتاب في الكُتّاب. قال: فعلموهم سحرًا كثيرًا. قال: وواعد موسى فرعون موعدًا، فلمّا كان في ذلك الموعد بعث فرعونُ إلى السحرة، فجاء بهم، وجاء بمعلمهم معهم، فقال له: ماذا صنعت؟ قال: قد علمتهم من السحر سحرًا لا يُطِيقه سحرُ أهل الأرض، إلا أن يكون أمرًا من السماء، فإنّه لا طاقة لهم به، فأمّا سحر أهل الأرض فإنه لن يغلبهم. فلما جاءت السحرة قالوا لفرعون: <q>﴿إن لنا لأجرا إن كنا نحن الغالبين قال نعم وإنكم إذا لمن المقربين﴾</q> [الشعراء:٤١-٤٢]{20}. (ز) ٢٨٤٥٢- عن قتادة بن دعامة، في قوله: <q>﴿قالوا إن لنا لأجرا﴾</q>، أي: أئِنَّ لنا لَعطاءً وفضيلةً{21}. (٦/٤٩٨) ٢٨٤٥٣- عن إسماعيل السدي -من طريق أسباط-: فأرسل فرعون في المدائن حاشرين، فحشروا عليه السحرة، فلما جاء السحرة فرعون <q>﴿قالوا إن لنا لأجرا إن كنا نحن الغالبين﴾</q> يقول: عَطِيَّة تُعطينا <q>﴿إن كنا نحن الغالبين * قال نعم وإنكم لمن المقربين﴾</q>{22}. (ز) ٢٨٤٥٤- قال مقاتل بن سليمان: <q>﴿وجاء السحرة فرعون قالوا إن لنا لأجرا﴾</q> يعنى: جُعْلًا؛ <q>﴿إن كنا نحن الغالبين﴾</q> لموسى{23}. (ز) ",footnotes:1:أخرجه عبد الرزاق ١/٢٣٤، وابن جرير ١٠/٣٦٤، وابن أبي حاتم ٥/١٥٣٨. وعزاه السيوطي إلى ابن المنذر، وأبي الشيخ.تفسير الثعلبي ٦/٢٤٩.أخرجه ابن جرير ١٠/٣٥٥، وابن أبي حاتم ٥/١٥٣٤، ٨/٢٧٦٥. وعزاه السيوطي إلى ابن أبي شيبة، وأبي الشيخ.أخرجه آدم بن أبي إياس -كما في تفسير مجاهد ص٥١٠-.أخرجه ابن أبي حاتم ٥/١٥٣٤، ٨/٢٧٦٥.أخرجه ابن جرير ١٠/٣٥٥ والشكُّ منه.أخرجه ابن جرير ١٦/١٠٧. وعزاه السيوطي إلى أبي الشيخ.أخرجه ابن أبي حاتم ٥/١٥٣٤، ٨/٢٧٦٥.علقه ابن أبي حاتم ٨/٢٧٦٥.أخرجه ابن جرير ١٠/٣٥٦، وابن أبي حاتم ٥/١٥٣٥، ٦/٢٧٦٤، ٨/٢٧٦٦. وعزاه السيوطي إلى أبي الشيخ.أخرجه ابن جرير ١٠/٣٥٥.أخرجه ابن أبي حاتم ٥/١٥٣٥. وعزاه السيوطي إلى ابن المنذر.تفسير الثعلبي ٤/٢٦٩، وتفسير البغوي ٣/٢٦٤.تفسير الثعلبي ٤/٢٦٨، وتفسير البغوي ٣/٢٦٤.تفسير البغوي ٣/٢٦٤.أخرجه ابن جرير ١٦/١٠٨. وعزاه السيوطي إلى أبي الشيخ.تفسير البغوي ٣/٢٦٤.أخرجه ابن جرير ١٠/٣٥٤، وابن أبي حاتم ٨/٢٧٦٢.الفَرَما: مدينة بقرب مصر. لسان العرب (فرم).أخرجه ابن جرير ١٠/٣٥٣.عزاه السيوطي إلى عبد بن حميد، وابن أبي حاتم.أخرجه ابن جرير ١٠/٣٥٤.تفسير مقاتل بن سليمان ٢/٥٣.
7,114," <q>﴿قَالَ نَعَمۡ وَإِنَّكُمۡ لَمِنَ ٱلۡمُقَرَّبِینَ ۝١١٤﴾</q> - تفسير ٢٨٤٥٥- قال محمد بن السائب الكلبي: أول مَن يدخل عَلَيَّ، وآخر مَن يخرج، <q>﴿قالوا﴾</q> يعني: السحرة{1}. (ز) ٢٨٤٥٦- قال مقاتل بن سليمان: <q>﴿قال﴾</q> فرعون: <q>﴿نعم وإنكم لمن المقربين﴾</q> في المنزلة سوى العظمة، كان هذا يوم السبت في المحرم، والسحرة اثنان وسبعون رجلًا{2}. (ز) ",footnotes:1:تفسير الثعلبي ٤/٢٦٩، وتفسير البغوي ٣/٢٦٥.تفسير مقاتل بن سليمان ٢/٥٣-٥٤.
7,115," <q>﴿قَالُوا۟ یَـٰمُوسَىٰۤ إِمَّاۤ أَن تُلۡقِیَ وَإِمَّاۤ أَن نَّكُونَ نَحۡنُ ٱلۡمُلۡقِینَ ۝١١٥﴾</q> - تفسير ٢٨٤٥٧- عن عبد الله بن عباس -من طريق سعيد بن جبير- قال: اليوم الذي أظهر الله فيه موسى على السحرة وفرعون هو يوم عاشوراء، فلما اجتمعوا في صعيدٍ قال الناسُ بعضُهم لبعض: انطلقوا، فلنحضر هذا الأمر، ونتبع السحرة إن كانوا هم الغالبين. يعني بذلك: موسى وهارون صلى الله عليهما وسلم، استهزاءً بهما، <q>﴿قالوا يا موسى﴾</q> لقدرتهم بسحرهم: <q>﴿إما أن تلقي وإما أن نكون نحن الملقين قال: ألْقُوا﴾</q>. <q>﴿فَأَلْقَوْا حِبالَهُمْ وعِصِيَّهُمْ وقالُوا بِعِزَّةِ فِرْعَوْنَ إنّا لَنَحْنُ الغالِبُونَ﴾</q> [الشعراء:٤٤]، فرأى موسى مِن سحرهم ما أوجس في نفسه خيفة، فأوحى الله ﷿ إليه أن ألق العصا{1}. (ز) ٢٨٤٥٨- قال مقاتل بن سليمان: <q>﴿قالوا يا موسى﴾</q> فقالت السحرة لموسى: <q>﴿إما أن تلقي﴾</q> ما في يدك، يعني: عصاه، <q>﴿وإما أن نكون نحن الملقين﴾</q> ما في أيدينا من الحبال والعصي{2}. (ز) ",footnotes:1:أخرجه ابن أبي حاتم ٥/١٥٣٥.تفسير مقاتل بن سليمان ٢/٥٤.
7,116," <q>﴿قَالَ أَلۡقُوا۟ۖ فَلَمَّاۤ أَلۡقَوۡا۟ سَحَرُوۤا۟ أَعۡیُنَ ٱلنَّاسِ وَٱسۡتَرۡهَبُوهُمۡ وَجَاۤءُو بِسِحۡرٍ عَظِیمࣲ ۝١١٦﴾</q> - تفسير ٢٨٤٥٩- عن عبد الله بن عباس -من طريق عكرمة - في قوله: <q>﴿فلما ألقوا﴾</q>، قال: ألقَوْا حِبالًا غِلاظا، وخُشُبًا طِوالًا، فأقبَلتْ تُخَيَّلُ إليه من سحرهم أنها تسعى{1}. (٦/٤٩٨) ٢٨٤٦٠- عن القاسم بن أبي بزَّة -من طريق هشام الدستوائي- قال: سحرة فرعون كانوا سبعين ألف ساحرِ، فألقَوْا سبعين ألف حبل، وسبعين ألف عصا، حتى جعَل موسى يُخيَّلُ إليه من سِحْرِهم أنها تسعى، فأوحى الله إليه: يا موسى، ألْقِ عصاك. فألقى عصاه، فإذا هي ثعبانٌ فاغِرٌ فاهُ، فابتلَع حبالَهم وعصِيَّهم، فأُلقِيَ السحرة عندَ ذلك سُجَّدًا، فما رفَعوا رءُوسَهم حتى رأوُا الجنة والنارَ وثوابَ أهلِها{2}. (٦/٤٩٧) ٢٨٤٦١- عن إسماعيل السُّدِّيّ -من طريق أسباط- قال: <q>﴿قال لهم موسى ألقوا ما أنتم ملقون فألقوا حبالهم وعصيهم﴾</q> [الشعراء:٤٣-٤٤]، وكانوا بضعة وثلاثين ألف رجل، ليس منهم رجل إلا معه حبل وعصا، <q>﴿فلما ألقوا سحروا أعين الناس واسترهبوهم﴾</q> يقول: فَرَقُوهم، <q>﴿فأوجس في نفسه خيفة موسى﴾</q> [طه:٦٧]{3}. (ز) ٢٨٤٦٢- عن محمد بن إسحاق -من طريق سلمة- قال: صَفَّ خمسة عشر ألف ساحر، مع كل ساحر حباله وعِصِيُّه، وخرج موسى معه أخوه يَتَّكِئُ على عصاه، حتى أتى الجمع، وفرعونُ في مجلسه مع أشراف مملكته، ثم قال السحرة: <q>﴿يا موسى إما أن تلقي وإما أن نكون أول من ألقى* قال بل ألقوا فإذا حبالهم وعصيهم يخيل إليه من سحرهم أنها تسعى﴾</q> [طه: ٦٥-٦٦]، فكان أول ما اختطفوا بسحرهم بصر موسى وبصر فرعون، ثم أبصار الناس بعْدُ، ثم ألقى كل رجل منهم ما في يده من العصي والحبال، فإذا هي حيات كأمثال الجبال، قد ملأت الوادي يركب بعضها بعضًا. <q>﴿فأوجس في نفسه خيفة موسى﴾</q> [طه:٦٧]، وقال: واللهِ، إن كانت لَعِصِيًّا في أيديهم، ولقد عادت حيات، وما تعدو عصاي هذا؟ أو كما حدَّث نفسه{1}. (ز) ٢٨٤٦٣- قال مقاتل بن سليمان: <q>﴿قالَ﴾</q> لَهُمْ مُوسى: <q>﴿ألقوا﴾</q> ما أنتم ملقون، <q>﴿فلما ألقوا﴾</q> الحبال والعصي <q>﴿سحروا أعين الناس واسترهبوهم﴾</q> يعنى: وخَوَّفوهم، <q>﴿وجاؤا بسحر عظيم﴾</q>{5}. (ز) ",footnotes:1:أخرجه ابن جرير ١٠/٣٥٧.أخرجه ابن جرير ١٠/٣٥٨-٣٥٩، ١٦/١٠٧. وعزاه السيوطي إلى أبي الشيخ.أخرجه ابن جرير ١٠/٣٥٦.أخرجه ابن جرير ١٠/٣٥٧.تفسير مقاتل بن سليمان ٢/٥٤.
7,117," <q>﴿وَأَوۡحَیۡنَاۤ إِلَىٰ مُوسَىٰۤ أَنۡ أَلۡقِ عَصَاكَۖ﴾</q> - تفسير ٢٨٤٦٤- عن عبد الله بن عباس -من طريق سعيد بن جبير- قوله: <q>﴿وأوحينا إلى موسى أن ألق عصاك﴾</q>، قال: فأوحى الله إليه: أن ألق العصا. فلما ألقاها صارت ثعبانًا عظيمًا فاغرة فاها{1}. (ز) ٢٨٤٦٥- عن قتادة بن دعامة -من طريق مَعْمَر- في قوله: <q>﴿وأوحينا إلى موسى أن ألق عصاك﴾</q>. فألقى عصاه، فتحولتْ حيَّةً، فأكلتْ سحرَهم كلَّه، وعِصِيَّهم، وحبالَهم{2}. (٦/٤٩٨) ٢٨٤٦٦- عن إسماعيل السُّدِّيّ -من طريق أسباط- في قوله: <q>﴿وأوحينا إلى موسى أن ألق عصاك﴾</q>، قال: أوحى الله إلى موسى أن: ألْقِ ما في يمينك. فألْقى عصاه، فأكَلتْ كلَّ حيَّة لهم، فلما رأوا ذلك سَجَدوا{3}. (٦/٤٩٨) ٢٨٤٦٧- قال مقاتل بن سليمان: <q>﴿وأَوْحَيْنا إلى مُوسى أنْ ألْقِ عَصاكَ﴾</q>، فصارت حيَّةً{4}. (ز) <q>﴿فَإِذَا هِیَ تَلۡقَفُ مَا یَأۡفِكُونَ ۝١١٧﴾</q> - قراءات ٢٨٤٦٨- عن سعيد بن جبير أنّه كان يقرأ:(فَإذا هِيَ تَلْقَمُ ما يَأْفِكُونَ){5}. (٦/٤٩٩) <q>﴿فَإِذَا هِیَ تَلۡقَفُ مَا یَأۡفِكُونَ ۝١١٧﴾</q> - تفسير الآية ٢٨٤٦٩- عن مجاهد بن جبر -من طريق ابن أبي نَجِيح- في قوله: <q>﴿تلقف ما يأفكون﴾</q>، قال: يَكْذِبون{6}. (٦/٤٩٩) ٢٨٤٧٠- عن الحسن البصري -من طريق قُرَّة بن خالد- في قوله: <q>﴿تلقف ما يأفكون﴾</q>، قال: تَسْتَرِطُ{7} حبالهم، وعِصيَّهم{8}. (٦/٤٩٩) ٢٨٤٧١- قال مقاتل بن سليمان: <q>﴿فَإذا هِيَ تَلْقَفُ﴾</q> يعني: تلقم <q>﴿ما يَأْفِكُونَ﴾</q> يعني: ما جاءوا به من الكَذِب{4}. (ز) ٢٨٤٧٢- عن محمد بن إسحاق -من طريق سلمة- قال: أوحى اللهُ إليه: أنْ ألق ما في يمينك. فألقى عصاه من يده، فاستعرضت ما ألقوا من حبالهم وعصيهم -وهي حيّات في عين فرعون وأعين الناس تسعى-، فجعلت تلقفها: تبتلعها حيَّة حيَّة، حتى ما يُرى بالوادي قليلٌ ولا كثيرٌ مِمّا ألقوه، ثم أخذها موسى، فإذا هي عصاه في يده كما كانت، ووقع السحرة سُجَّدًا، قالوا: <q>﴿آمنا برب العالمين رب موسى وهارون﴾</q>، لو كان هذا سحرًا ما غَلَبَنا{10}. (ز) ",footnotes:1:أخرجه ابن أبي حاتم ٥/١٥٣٥.أخرجه عبد الرزاق ١/٢٣٤، وابن جرير ١٠/٣٥٨، وابن أبي حاتم ٥/١٥٣٣. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وأبي الشيخ.أخرجه ابن جرير ١٠/٣٥٩، وابن أبي حاتم ٨/٢٧٦٦. وعزاه السيوطي إلى أبي الشيخ.تفسير مقاتل بن سليمان ٢/٥٤.أخرجه ابن أبي داود في المصاحف ص٩٠. وهي قراءة شاذة، تروى أيضًا عن النخعي، وأبي حيوة. انظر: مختصر ابن خالويه ص٥٠.تفسير مجاهد ص٣٤٠، وأخرجه ابن جرير ١٠/٣٥٩-٣٦٠، وابن أبي حاتم ٥/١٥٣٦. وعزاه السيوطي إلى ابن أبي شيبة، وعبد بن حميد، وابن المنذر.استرطه: ابتلعه من غير مضغ. تاج العروس (سرط).أخرجه ابن جرير ١٠/٣٦٠، وابن أبي حاتم ٥/١٥٣٦. وعزاه السيوطي إلى أبي الشيخ.تفسير مقاتل بن سليمان ٢/٥٤.أخرجه ابن جرير ١٠/٣٥٩.
7,118," <q>﴿فَوَقَعَ ٱلۡحَقُّ وَبَطَلَ مَا كَانُوا۟ یَعۡمَلُونَ ۝١١٨﴾</q> - تفسير ٢٨٤٧٣- عن عبد الله بن عباس -من طريق سعيد بن جبير- يعني: قوله: <q>﴿فوقع الحق﴾</q>، قال: ظَهَر الحق{1}. (ز) ٢٨٤٧٤- عن مجاهد بن جبر -من طريق مهاجر- في قوله: <q>﴿فوقع الحق﴾</q> قال: ظهر، <q>﴿وبطل ما كانوا يعملون﴾</q> قال: ذهَب الإفكُ الذي كانوا يعملون{2}. (٦/٥٠٠) ٢٨٤٧٥- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿فوقع الحق﴾</q>، قال: ظَهَر موسى{3}. (ز) ٢٨٤٧٦- قال الحسن البصري: <q>﴿فوقع الحق﴾</q>: ظهر الحق، <q>﴿وبطل ما كانوا يعملون﴾</q> من السحر{4}. (ز) ٢٨٤٧٧- قال محمد بن السائب الكلبي: وقال السحرة بعضُهم لبعض: لو كان هذا سِحْرًا لَبَقِيَتْ حبالنُا وعِصِيُّنا{5}. (ز) ٢٨٤٧٨- قال مقاتل بن سليمان: <q>﴿فَوَقَعَ الحَقُّ﴾</q> يعني: فظهر الحقُّ بأنّه ليس بسِحْر، <q>﴿وبَطَلَ ما كانُوا يَعْمَلُونَ﴾</q> يعني: بطل ما كانوا يعملون من السحر{6}. (ز) ",footnotes:1:أخرجه ابن أبي حاتم ٥/١٥٣٦.تفسير مجاهد ص٣٤٠ بنحوه في شطره الأول، وأخرجه ابن جرير١٠/٣٦٠-٣٦١. وعلَّقه ابن أبي حاتم ٥/١٥٣٦. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وأبي الشيخ.أخرجه ابن جرير١٠/٣٦١.تفسير البغوي ٣/٢٦٥.ذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٢/١٣٦-.تفسير مقاتل بن سليمان ٢/٥٤.
7,119," <q>﴿فَغُلِبُوا۟ هُنَالِكَ وَٱنقَلَبُوا۟ صَـٰغِرِینَ ۝١١٩﴾</q> - تفسير ٢٨٤٧٩- عن عبد الله بن عباس -من طريق سعيد بن جبير- قوله: <q>﴿وبطل ما كانوا يعملون فغلبوا هنالك وانقلبوا صاغرين﴾</q>، فكسر اللهُ ظهر فرعون في ذلك الموطن وأشياعه{1}. (ز) ٢٨٤٨٠- قال مقاتل بن سليمان: <q>﴿فَغُلِبُوا هُنالِكَ﴾</q> يعني: عند ذلك، <q>﴿وانْقَلَبُوا صاغِرِينَ﴾</q> يعني: فرجعوا إلى منازلهم مُذَلِّين{2}. (ز) ",footnotes:1:أخرجه ابن أبي حاتم ٥/١٥٣٦.تفسير مقاتل بن سليمان ٢/٥٤.
7,120," <q>﴿وَأُلۡقِیَ ٱلسَّحَرَةُ سَـٰجِدِینَ ۝١٢٠﴾</q> - تفسير ٢٨٤٨١- عن سعيد بن جبير -من طريق سالم الأفطس- في قوله: <q>﴿وألقي السحرةُ ساجدين﴾</q>، قال: رأوا منازلَهم تُبنى لهم وهم في سُجودهم{1}. (٦/٥٠٠) ٢٨٤٨٢- قال مقاتل: ألقاهم الله{2}. (ز) ٢٨٤٨٣- قال مقاتل بن سليمان: <q>﴿وأُلْقِيَ السَّحَرَةُ ساجِدِينَ﴾</q> لله{3}. (ز) ٢٨٤٨٤- عن الأوزاعي قال: لَمّا خرَّ السحرةُ سُجَّدًا رُفِعت لهم الجنة حتى نظَروا إليها{4}. (٦/٥٠٠) ",footnotes:1:أخرجه ابن أبي حاتم ٥/١٥٣٦، ٨/٢٧٦٦.تفسير البغوي ٣/٢٦٦.تفسير مقاتل بن سليمان ٢/٥٤.عزاه السيوطي إلى ابن أبي حاتم.
