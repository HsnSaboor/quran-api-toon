quran[16]{c,v,t}:
  7,105,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿حَقِیقٌ عَلَىٰۤ أَن لَّاۤ أَقُولَ عَلَى ٱللَّهِ إِلَّا ٱلۡحَقَّۚ قَدۡ جِئۡتُكُم بِبَیِّنَةࣲ مِّن رَّبِّكُمۡ فَأَرۡسِلۡ مَعِیَ بَنِیۤ إِسۡرَ ٰ⁠ۤءِیلَ ۝١٠٥ قَالَ إِن كُنتَ جِئۡتَ بِـَٔایَةࣲ فَأۡتِ بِهَاۤ إِن كُنتَ مِنَ ٱلصَّـٰدِقِینَ ۝١٠٦﴾</span> - قراءات</h3></p><p><div></p><p><p><span class="item-no">٢٨٣٨١<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> أنّه كان يقرأ: ‹حَقِيقٌ عَلَيَّ أن لَّآ أقُولَ›{1}<span class=comment-ref>٢٥٩٨</span>. (٦/٤٩٢)</p></p><p></div></p><p><div><span class=comment-ref>٢٥٩٨</span> ذكر <u>ابنُ جرير</u> (١٠/٣٤٢) هذه القراءة، ثم <span class="comment-type-4">عَلَّق</span> عليها بقوله: «المعنى على هذه القراءة: واجبٌ عَلَيَّ أن لا أقول، وحقٌّ علي أن لا أقول».</p><p>وبنحوه <span class="comment-type-4">قال</span> <u>ابنُ تيمية</u> (٣/١٩١).</p><p>و<span class="comment-type-4">علّق</span> <u>ابنُ عطية</u> (٤/١٣ بتصرف) على هذه القراءة بقوله: «وإعراب»أنْ«على قراءة مَن فتح الياء مشددة رفعٌ».</p><p>وقد ذكر <u>ابنُ جرير</u> أيضًا قراءة من قرأ ذلك بإرسال الياء مِن <span class="qpc-hafs">﴿على﴾</span>، ولم يرجح إحداهما على الأخرى، و<span class="comment-type-4">بيَّن</span> أنّ القراءتين متقاربتا المعنى؛ بأيتهما قرأ القارئ فهو مصيب.</div></p><p><h3><span class="qpc-hafs">﴿حَقِیقٌ عَلَىٰۤ أَن لَّاۤ أَقُولَ عَلَى ٱللَّهِ إِلَّا ٱلۡحَقَّۚ قَدۡ جِئۡتُكُم بِبَیِّنَةࣲ مِّن رَّبِّكُمۡ فَأَرۡسِلۡ مَعِیَ بَنِیۤ إِسۡرَ ٰ⁠ۤءِیلَ ۝١٠٥ قَالَ إِن كُنتَ جِئۡتَ بِـَٔایَةࣲ فَأۡتِ بِهَاۤ إِن كُنتَ مِنَ ٱلصَّـٰدِقِینَ ۝١٠٦﴾</span> - تفسير الآية</h3></p><p><div></p><p><p><span class="item-no">٢٨٣٨٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق سعيد بن جبير- قال: فقال فرعون لموسى: ما تريد؟ قال: أريد أن تؤمن بالله، وأن ترسل معي بني إسرائيل. فأبى عليه ذلك، وقال: [ائت] بآية إن كنت من الصادقين{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٨٣٨٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿حقيق على أن لا أقول على الله إلا الحق﴾</span> فإنّه بعثني رسولًا، <span class="qpc-hafs">﴿قد جئتكم ببينة من ربكم﴾</span> يعني: اليد، والعصا؛ بأنِّي رسول الله، <span class="qpc-hafs">﴿فأرسل معي بني إسرائيل﴾</span> إلى فلسطين. قال فرعون: <span class="qpc-hafs">﴿إن كنت جئت بآية فأت بها إن كنت من الصادقين﴾</span> بأنّك رسول رب العالمين{3}. (ز)</p></p><p></div></p></div>",footnotes:1:عزاه السيوطي إلى أبي الشيخ.</p><p>وهي قراءة متواترة، قرأ بها نافع، وقرأ بقية العشرة: <span class="qpc-hafs">﴿عَلى﴾</span>. انظر: النشر ٢/٢٧٠، والإتحاف ص٢٨٦.|2:أخرجه ابن أبي حاتم ٥/١٥٣٢.|3:تفسير مقاتل بن سليمان ٢/٥٢.
  7,106,"7:105"
  7,107,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿فَأَلۡقَىٰ عَصَاهُ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٢٨٣٨٤<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق سعيد بن جبير- قال: عصا موسى اسمُها: ماشا{1}. (٦/٤٩٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٨٣٨٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: وفي يد موسى عصا، فزعم <span class="name-1">ابن عباس</span> أن مَلَكًا من الملائكة دفعها إليه حين توجه إلى مدين، فقال موسى لفرعون: ما هذه بيدي؟ قال فرعون: عصا. فألقى موسى عصاه مِن يده؛ فإذا هي ثعبان مبين{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٨٣٨٦<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span>، قال: كانتْ عصا موسى من عَوْسَجٍ{3} فقط{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٨٣٨٧<span class="dash">-</span></span> عن <span class="name-2">الحكم [بن عُتَيبة]</span> -من طريق ابن أبي غنية- قال: كانتْ عصا موسى مِن عَوْسَجٍ، ولم يُسَخَّرِ العَوْسَجُ لأحدٍ بعدَه{5}. (٦/٤٩٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٨٣٨٨<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span>، في قوله: <span class="qpc-hafs">﴿فألقى عصاه﴾</span>، قال: ذُكِر لنا: أنّ تلك العصا عصا آدم، أعطاه إياها مَلَكٌ حين توجَّه إلى مَدْيَن، فكانت تُضِيءُ له بالليل، ويَضْرِبُ بها الأرضَ بالنهار فيَخرُجُ له رزقُه، ويَهُشُّ بها على غنمِه{6}. (٦/٤٩٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٨٣٨٩<span class="dash">-</span></span> عن مسلم -من طريق حبيب بن حسان- قال: عصا موسى هي الدابَّةُ. يعني: دابة الأرض{7}. (٦/٤٩٤)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿فَإِذَا هِیَ ثُعۡبَانࣱ مُّبِینࣱ ۝١٠٧﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٢٨٣٩٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- في قوله: <span class="qpc-hafs">﴿فإذا هي ثعبان مبين﴾</span>، قال: الحيَّة الذَّكَر{8}. (٦/٤٩٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٨٣٩١<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق أبي سعد- في قوله: <span class="qpc-hafs">﴿فألقى عصاه فإذا هي ثعبان مبين﴾</span>، قال: حية تَسْعى{9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٨٣٩٢<span class="dash">-</span></span> عن <span class="name-2">الضحاك بن مُزاحِم</span> -من طريق جُوَيْبِر- <span class="qpc-hafs">﴿فإذا هي ثعبان مبين﴾</span>، قال: الحَيَّة الذَّكَر{10}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٨٣٩٣<span class="dash">-</span></span> عن <span class="name-2">وهب بن مُنبِّه</span> -من طريق عيسى بن عبيد بن زرارة- قال: كان بين لَحْيَي الثعبان الذي مِن عصا موسى اثنا عشر ذِراعًا{11}. (٦/٤٩٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٨٣٩٤<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق مَعْمَر- في قوله: <span class="qpc-hafs">﴿فإذا هي ثعبانٌ مبينٌ﴾</span>، قال: تحوَّلتْ حيَّةً عظيمة.= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٨٣٩٥<span class="dash">-</span></span> قال معمر: قال غيره: مثلَ المدينة{12}. (٦/٤٩٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٨٣٩٦<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- قوله: <span class="qpc-hafs">﴿فإذا هي ثعبان مبين﴾</span>، يقول: فإذا هي حيَّة كاد يَسُورُه، يعني: يَثِب عليه{13}. (٦/٤٩٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٨٣٩٧<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- في قوله: <span class="qpc-hafs">﴿فإذا هي ثعبان مبين﴾</span>، قال: الذَّكَرُ مِن الحيّات{14}. (٦/٤٩٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٨٣٩٨<span class="dash">-</span></span> عن <span class="name-3">محمد بن السائب الكلبي</span>، قال: حيَّةٌ صفراء ذَكَرٌ{15}. (٦/٤٩٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٨٣٩٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فإذا هي ثعبان مبين﴾</span>، يعني: حيَّة بَيِّنة{16}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿فَأَلۡقَىٰ عَصَاهُ فَإِذَا هِیَ ثُعۡبَانࣱ مُّبِینࣱ ۝١٠٧﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٢٨٤٠٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عكرمة- <span class="qpc-hafs">﴿فإذا هي ثعبان مبين﴾</span>، قال: ألقى العصا، فصارت حيَّة، فوضعت فُقْمًا{17} لها أسفلَ القُبَّة، وفُقْمًا لها أعلى القُبَّة -قال عبد الكريم: قال إبراهيم: وأشار سفيان بإصبعه الإبهام والسبابة هكذا شبه الطاقِ-، فلمّا أرادت أن تأخذه قال فرعون: يا موسى، خذها، خذها. فأخذها موسى بيده، فصارت عصا كما كانت أول مرة{18}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٨٤٠١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق سعيد بن جبير-: <span class="qpc-hafs">﴿فألقى عصاه﴾</span> فتحوَّلَتْ حيَّة عظيمة فاغرة فاها، مسرعة إلى فرعون، فلما رآها فرعون أنّها قاصدة إليه خافها، فاقتحم على سريره، واستغاث بموسى أن يَكُفَّها عنه، ففعل{19}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٨٤٠٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق سعيد- قال: لقد دخل موسى على فرعون وعليه زُرْمانِقةٌ{20} مِن صوفٍ، ما تُجاوِزُ مِرْفَقَه، فاستُؤْذِن على فرعون، فقال: أدْخِلوه. فدخَل، فقال: إنّ إلهي أرسَلني إليك. فقال للقوم حولَه: ما عَلمتُ لكم من إله غيري، خُذوه. قال: إنِّي قد جِئتُك بآيةٍ. قال: فائتِ بها إن كنتَ من الصادقين. فألقى عصاه، فصارت ثعبانًا، ما بينَ لَحْيَيه ما بين السقف إلى الأرض، وأدخل يدَه في جيبه، فأخرَجَها مثل البرق تَلْتَمِعُ الأبصار، فخَرُّوا على وجوهِهم، وأخَذ موسى عصاه، ثم خرَج، ليس أحدٌ من الناس إلا يَفِرُّ منه، فلما أفاق وذهَب عن فرعون الرَّوْعُ قال للملأ حولَه: ماذا تأْمُرون؟ قالوا: أرْجِئْه وأخاه، لا تَأتِنا به، ولا يَقْرَبُنا، وأرسِلْ في المدائن حاشِرِين. وكانت السحرةُ يَخشَون من فرعون، فلمّا أرسَل إليهم قالوا: قد احتاج إليكم إلهُكم. قال: إنّ هذا فعَل كذا وكذا. قالوا: إنّ هذا ساحرٌ يَسْحرُ، أئنَّ لنا لأجرًا إن كنا نحن الغالبين؟ قال: ساحرٌ يَسْحرُ الناس، ولا يَسْحرُ الساحرُ الساحرَ. قال: نعم، وإنكم إذنْ لمن المقربين{21}. (٦/٤٩٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٨٤٠٣<span class="dash">-</span></span> عن <span class="name-2">المنهال</span> -من طريق الأعمش- قال: ارتفعتِ الحيةُ في السماء مِيلًا، فأقبلَتْ إلى فرعون، فجعلت تقولُ: يا موسى، مُرْنِي بما شئتَ. وجعل فرعون يقولُ: يا موسى، أسألُك بالذي أرْسَلك. قال: وأخَذه بَطْنُه{22}. (٦/٤٩٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٨٤٠٤<span class="dash">-</span></span> عن <span class="name-2">وهب بن منبه</span> -من طريق عبد الصمد- قال: لَمّا دخل موسى على فرعون قال له موسى: أُعَرِّفُك؟ قال: نعم. قال: <span class="qpc-hafs">﴿ألَمْ نُرَبِّكَ فِينا ولِيدًا﴾</span> [الشعراء: ١٨]؟. قال: فردَّ إليه موسى الذي ردَّ، فقال فرعون: خذوه. فبادره موسى، فألقى عصاه، فإذا هي ثعبان مبين، فحملت على الناس، فانهزموا منها، فمات منهم خمسة وعشرون ألفًا، قتل بعضُهم بعضًا، وقام فرعون منهزمًا حتى دخل البيت{23}<span class=comment-ref>٢٥٩٩</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٢٥٩٩</span> <span class="comment-type-4">علّق</span> <u>ابنُ كثير</u> (٦/٣٦٠) على رواية وهب، فقال: «رواه ابن جرير، والإمام أحمد في كتابه الزهد، وابن أبي حاتم، وفيه غرابة في سياقه».</div></p><p><div></p><p><p><span class="item-no">٢٨٤٠٥<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- في قوله: <span class="qpc-hafs">﴿فإذا هي ثعبان مبين﴾</span>، قال: الذَّكَرُ من الحيّات، فاتحةً فَمَها، واضعةً لَحْيَها الأسفل في الأرض، والأعلى على سُور القصر، ثم توجَّهتْ نحو فرعون لِتأخُذَه، فلمّا رآها ذُعِرَ منها، ووثَب فأحْدَث، ولم يكنْ يُحدِثُ قبل ذلك، وصاح: يا موسى، خُذْها وأنا أومنُ بك وأُرْسلُ معك بني إسرائيل. فأخَذها موسى، فصارت عصًا{14}. (٦/٤٩٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٨٤٠٦<span class="dash">-</span></span> عن <span class="name-2">فَرْقَد السَّبخي</span> -من طريق ديلم بن غزوان- قال: كان فرعون إذا كانت له حاجةٌ ذهبت به السَّحرة مسيرةَ خمسين فَرْسخًا، فإذا قضى حاجتَه جاءوا به، حتى كان يومُ عصا موسى، فإنها فَتَحتْ فاها، فكان ما بينَ لَحْيَيْها أربعين ذراعًا؛ فأحْدَث يومئذٍ أربعين مَرَّةً{25}. (٦/٤٩٥)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن أبي حاتم ٥/١٥٣٦، ٩/٢٨٤٨.|2:تفسير مقاتل بن سليمان ٢/٥٢-٥٣.|3:العَوْسَج: شجر من شجر الشوك. لسان العرب (عسج).|4:علقه ابن أبي حاتم ٨/٢٧٥٨.|5:أخرجه ابن أبي حاتم ٥/١٥٣٢، ٨/٢٧٥٨. وعزاه السيوطي إلى ابن المنذر.|6:عزاه السيوطي إلى عبد بن حميد، وأبي الشيخ.|7:أخرجه ابن أبي حاتم ٩/٢٩٧٤.|8:أخرجه ابن جرير ١٠/٣٤٥، وابن أبي حاتم ٥/١٥٣٢، ٨/٢٧٥٨. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وأبي الشيخ.|9:أخرجه ابن جرير ١٠/٣٤٥.|10:أخرجه ابن جرير ١٠/٣٤٦.|11:أخرجه ابن أبي حاتم ٨/٢٧٥٨-٢٧٥٩.|12:أخرجه عبد الرزاق ١/٢٣٣، وابن جرير ١٠/٣٤٣، وابن أبي حاتم ٥/١٥٣٣، ٨/٢٧٥٨. وعزاه السيوطي إلى ابن المنذر، وأبي الشيخ.|13:أخرجه ابن جرير ١٠/٣٤٣. وعزاه السيوطي إلى عبد بن حميد بلفظ: حيةٌ تكاد تُساوِرُه.|14:أخرجه ابن جرير ١٠/٣٤٣-٣٤٤، وابن أبي حاتم ٨/٢٧٥٩.|15:عزاه السيوطي إلى أبي الشيخ.|16:تفسير مقاتل بن سليمان ٢/٥٣.|17:الفَقْم: أحد اللَّحْيَيْن، وهما الفكّان. اللسان (فقم) (فكك).|18:أخرجه ابن جرير ١٠/٣٤٤.|19:أخرجه ابن جرير ١٠/٣٤٤، وابن أبي حاتم ٥/١٥٣٢.|20:الزُّرْمانقة: جُبَّة من صوف. وهي كلمة أعجمية. النهاية (زَرْمَقَ).|21:أخرجه ابن أبي حاتم ٥/١٥٣٤، ٨/٢٧٥٣-٢٧٦٣ وبعضه من طريق مقسم.|22:أخرجه ابن جرير ١٧/٥٦٦. وعزاه السيوطي إلى أبي الشيخ.|23:أخرجه ابن جرير ١٠/٣٤٥، وابن أبي حاتم ٥/١٥٣٢.|24:أخرجه ابن جرير ١٠/٣٤٣-٣٤٤، وابن أبي حاتم ٨/٢٧٥٩.|25:أخرجه ابن جرير ١٠/٣٤٥، وابن أبي حاتم ٨/٢٧٥٩.
  7,108,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَنَزَعَ یَدَهُۥ فَإِذَا هِیَ بَیۡضَاۤءُ لِلنَّـٰظِرِینَ ۝١٠٨﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٢٨٤٠٧<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق سعيد بن جبير- قوله: <span class="qpc-hafs">﴿فإذا هي بيضاء للناظرين﴾</span>، قال: أخرج يده من جيبه، فرآها بيضاء من غير سوء، يعني به: البرص، ثم أعادها في كُمِّه، فصارت إلى لونها الأول{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٨٤٠٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي-: <span class="qpc-hafs">﴿بَيْضاءُ لِلنّاظِرِينَ﴾</span> من غير بَرَص{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٨٤٠٩<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق أبي سعد- في قوله: <span class="qpc-hafs">﴿ونزع يده﴾</span> قال: نزع يده من جيبه، <span class="qpc-hafs">﴿فإذا هي بيضاء للناظرين﴾</span>، وكان موسى رجلًا آدَمَ، فأخرج يده، فإذا هي بيضاء أشد بياضًا من اللبن، <span class="qpc-hafs">﴿من غير سوء﴾</span> [طه:٢٢] قال: من غير بَرَص، آيةً لفرعون{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٨٤١٠<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span>: <span class="qpc-hafs">﴿ونزع يده﴾</span>، قال: الكَفّ{4}. (٦/٤٩٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٨٤١١<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- في قوله: <span class="qpc-hafs">﴿ونَزَعَ يَدَهُ﴾</span> أخرجها من جيبه، <span class="qpc-hafs">﴿فَإذا هِيَ بَيْضاءُ لِلنّاظِرِينَ﴾</span>{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٨٤١٢<span class="dash">-</span></span> قال <span class="name-3">محمد بن السائب الكلبي</span>: بلغنا: أنّ موسى قال: يا فرعون، ما هذه بيدي؟ قال: هي عصا. فألقاها موسى، فإذا هي ثعبان مبين، قد ملأت الدار من عظمها، ثم أهوت إلى فرعون لتبتلعه، فنادى: يا موسى، يا موسى. فأخذ موسى بذنبها، فإذا هي عصا بيده، فقال فرعون: يا موسى، هل من آية غير هذه؟ قال: نعم. قال: ما هي؟ قال: فأخرج موسى يده، فقال: ما هذه، يا فرعون؟ قال: هذه يدك. فأدخلها موسى في جيبه، ثم أخرجها، <span class="qpc-hafs">﴿فإذا هي بيضاء للناظرين﴾</span>، أي: تغشى البصرَ من بياضها{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٨٤١٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: فقال فرعون: فهل من آية غيرها. قال: نعم. فأخرج يده، وقال لفرعون: ما هذه؟ قال: هذه يدك. فأدخل موسى يده في جيبه وعليه مِدْرَعَةٌ من صوف مُضَرِيَّة، ثم أخرجها، فذلك قوله: <span class="qpc-hafs">﴿ونزع يده﴾</span> يعني: أخرج يده من جيبه، <span class="qpc-hafs">﴿فإذا هي بيضاء للناظرين﴾</span> لها شعاع كشعاع الشمس، يغشي البصر من شدة بياضها{7}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ١٠/٣٤٦، وابن أبي حاتم ٥/١٥٣٣.|2:أخرجه ابن جرير ١٠/٣٤٦.|3:تفسير مجاهد ص٣٤٠، وأخرجه ابن جرير ١٠/٣٤٧.|4:عزاه السيوطي إلى أبي الشيخ.|5:أخرجه ابن جرير ١٠/٣٤٧.|6:ذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٢/١٣٥-.|7:تفسير مقاتل بن سليمان ٢/٥٣.
  7,109,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿قَالَ ٱلۡمَلَأُ مِن قَوۡمِ فِرۡعَوۡنَ إِنَّ هَـٰذَا لَسَـٰحِرٌ عَلِیمࣱ ۝١٠٩﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٢٨٤١٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿قال الملأ﴾</span> وهم الكبراء <span class="qpc-hafs">﴿من قوم فرعون إن هذا﴾</span> يعني: موسى <span class="qpc-hafs">﴿لساحر عليم﴾</span> يعني: عالم بالسحر، وذلك أنّ فرعون بدأ بهذه المقالة، فصدَّقه قومه. نظيرُها في الشعراء{1}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٢/٥٣. يشير إلى قوله تعالى: <span class="qpc-hafs">﴿قالَ لِلْمَلَإ حَوْلَهُ إنَّ هَذا لَساحِرٌ عَلِيمٌ (٣٤)﴾</span>.
  7,110,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿یُرِیدُ أَن یُخۡرِجَكُم مِّنۡ أَرۡضِكُمۡۖ فَمَاذَا تَأۡمُرُونَ ۝١١٠﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٢٨٤١٥<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق سعيد بن جبير- قال: فاستشار الملأَ فيما رأى، فقالوا: هذان ساحران، يريدان أن يخرجاكم من أرضكم{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٨٤١٦<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- في قوله: <span class="qpc-hafs">﴿يريد أن يخرجكم﴾</span>، قال: يَسْتَخرِجَكم من أرضكم{1}. (٦/٤٩٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٨٤١٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثُمَّ قال لهم فرعون: <span class="qpc-hafs">﴿يريد أن يخرجكم من أرضكم﴾</span> وهي مصر؛ <span class="qpc-hafs">﴿فماذا تأمرون﴾</span> يعني: تُشِيرون{3}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن أبي حاتم ٥/١٥٣٣.|2:أخرجه ابن أبي حاتم ٥/١٥٣٣.|3:تفسير مقاتل بن سليمان ٢/٥٣.
  7,111,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿قَالُوۤا۟ أَرۡجِهۡ وَأَخَاهُ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٢٨٤١٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطاء- في قوله: <span class="qpc-hafs">﴿أرْجِهْ﴾</span>، قال: أخِّرْه{1}. (٦/٤٩٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٨٤١٩<span class="dash">-</span></span> قال <span class="name-2">عطاء</span>: <span class="qpc-hafs">﴿أرْجِهْ﴾</span>: احْبِسه{2}<span class=comment-ref>٢٦٠٠</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٢٦٠٠</span> <span class="comment-type-4">قال</span> <u>ابنُ جرير</u> (١٠/٣٤٩): «يقول -تعالى ذِكْرُه-: قال الملأ من قوم فرعون لفرعون: <span class="qpc-hafs">﴿أرجه﴾</span>، أي: أخره. وقال بعضهم: معناه: احبس. والإرجاء <span class="mustanad">في كلام العرب</span>: التأخير، يقال منه: أرجيت هذا الأمر وأرجأته إذا أخرته، <span class="mustanad">ومنه قول الله تعالى</span>: <span class="qpc-hafs">﴿ترجي من تشاء منهن﴾</span> [الأحزاب:٥١]: تُؤَخِّر».</div></p><p><div></p><p><p><span class="item-no">٢٨٤٢٠<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿قالوا أرجه وأخاه﴾</span>، قال: احْبِسْه وأَخاه{3}. (٦/٤٩٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٨٤٢١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: فردَّ عليه كُبراء قومه: <span class="qpc-hafs">﴿قالوا أرجه وأخاه﴾</span> يقول: أرجئ أمرهم، يقول: أوقف أمرهم حتى ننظر في أمرهما، <span class="qpc-hafs">﴿وأرسل في المدائن حاشرين﴾</span>{4}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَأَرۡسِلۡ فِی ٱلۡمَدَاۤىِٕنِ حَـٰشِرِینَ ۝١١١﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٢٨٤٢٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق أبي مالك- في قوله: <span class="qpc-hafs">﴿وأرسل في المدائن حاشرين﴾</span>، قال: الشُّرَط{5}. (٦/٤٩٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٨٤٢٣<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق إبراهيم بن مهاجر، عن أبيه- <span class="qpc-hafs">﴿وابعث في المدائن حاشرين﴾</span> [الشعراء:٣٦]، قال: الشُّرَط{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٨٤٢٤<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق قيس- <span class="qpc-hafs">﴿وابعث في المدائن حاشرين﴾</span>، قال: الشُّرَط{6}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ١٠/٣٥٠، وابن أبي حاتم ٥/١٥٣٣، ٨/٢٧٦١. وعزاه السيوطي إلى ابن المنذر، وأبي الشيخ.|2:تفسير الثعلبي ٤/٢٦٨، تفسير البغوي ٣/٢٦٣.|3:أخرجه ابن جرير ١٠/٣٥١، وابن أبي حاتم ٥/١٥٣٣. وعزاه السيوطي إلى عبد بن حميد.|4:تفسير مقاتل بن سليمان ٢/٥٣.|5:أخرجه ابن جرير ١٠/٣٥١-٣٥٢، وابن أبي حاتم ٥/١٥٣٤، ٨/٢٧٦١. وعزاه السيوطي إلى ابن أبي شيبة، وعبد بن حميد، وابن المنذر، وأبي الشيخ.|6:أخرجه ابن جرير ١٠/٣٥١.|7:أخرجه ابن جرير ١٠/٣٥١.
  7,112,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿یَأۡتُوكَ بِكُلِّ سَـٰحِرٍ عَلِیمࣲ ۝١١٢﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٢٨٤٢٥<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق سعيد بن جبير- يعني: قوله: <span class="qpc-hafs">﴿يَأْتُوكَ بِكُلِّ ساحِرٍ عَلِيمٍ﴾</span>: فحُشِر له كلُّ ساحر مُتعالِم{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٨٤٢٦<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق مقسم-: <span class="qpc-hafs">﴿وأرسل في المدائن حاشرين﴾</span>، وكانت السحرةُ يَخشَون من فرعون، فلمّا أرسَل إليهم قالوا: قد احتاج إليكم إلهُكم. قال: إنّ هذا فعَل كذا وكذا{1}. (٦/٤٩٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٨٤٢٧<span class="dash">-</span></span> قال <span class="name-1">عبد الله بن عباس</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٨٤٢٨<span class="dash">-</span></span> و<span class="name-2">إسماعيل السُّدِّيّ</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٨٤٢٩<span class="dash">-</span></span> و<span class="name-3">محمد بن إسحاق</span>: قال فرعون لَمّا رأى مِن سلطان الله في العصا ما رأى: إنّا لا نُغالِب إلا بِمَن هو أعلم منه. فاتَّخذ غلمانًا من بني إسرائيل، فبعث بهم إلى قرية يُقال لها: الفرحاء، يُعَلِّمونهم السحر، فعلَّموهم سحرًا كثيرًا، وواعد فرعونُ موسى موعدًا، فبعث إلى السحرة، فجاءوا ومعلمهم معهم، فقال له: ماذا صنعت؟ قال: قد علَّمْتُهم سِحرًا لا يُطِيقه سَحَرَةُ أهل الأرض، إلا أن يكون أمرًا من السماء، فإنّه لا طاقة لهم به. ثم بعث فرعونُ في مملكته، فلم يترك في سلطانه ساحرًا إلا أتى به{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٨٤٣٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق سعيد بن جبير- قال: فأرسل في المدائن حاشرين، فحُشِر له كلُّ ساحر مُتعالِم، فلمّا أتَوْا فرعون قالوا: بِمَ يَعْمَل هذا الساحر؟ قالوا: يعمل بالحيّات. قالوا: واللهِ، ما في الأرض قومٌ يعملون بالسحر والحيات والحبال والعُصِيِّ أعلمَ منا، فما أجرُنا إن غُلِبْنا؟ فقال لهم: أنتم قرابتي وحامتي، وأنا صانع إليكم كلَّ شيء أحببتم{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٨٤٣١<span class="dash">-</span></span> عن <span class="name-3">محمد بن إسحاق</span> -من طريق سلمة- <span class="qpc-hafs">﴿أرجه وأخاه وأرسل في المدائن حاشرين يأتوك بكل سحار عليم﴾</span> [الشعراء:٣٦-٣٧]، أي: كاثِرْه بالسحرة، لعلَّك أن تجد في السحرة مَن يأتي بمثل ما جاء به، وقد كان موسى وهارون خرجا من عنده حين أراهم مِن سلطان الله ما أراهم، وبعث فرعونُ في مملكته مكانه، فلم يترك في سلطانه ساحر إلا أتى به. فذُكِر لي -والله أعلم-: أنّه جُمِع له خمسة عشر ألف ساحر، فلما اجتمعوا إليه أمرهم أمره، وقال لهم: قد جاءنا ساحرٌ ما رأينا مثله قط، وإنّكم إن غلبتموه أكرمتكم وفضلتكم، وقربتكم على أهل مملكتي، قالوا: وإنّ لنا ذلك إن غلبناه؟ قال: نعم{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٨٤٣٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿يأتوك﴾</span> يحشرون عليك، <span class="qpc-hafs">﴿بكل ساحر عليم﴾</span> يَعنُون: عالِم بالسحر{6}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن أبي حاتم ٥/١٥٣٤.|2:أخرجه ابن أبي حاتم ٥/١٥٣٤.|3:تفسير الثعلبي ٤/٢٦٨، وتفسير البغوي ٣/٢٦٤.|4:أخرجه ابن جرير ١٠/٣٥٣، وابن أبي حاتم ٥/١٥٣٤.|5:أخرجه ابن جرير ١٠/٣٥٤.|6:تفسير مقاتل بن سليمان ٢/٥٣.
  7,113,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَجَاۤءَ ٱلسَّحَرَةُ فِرۡعَوۡنَ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٢٨٤٣٣<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق السدي- قال: كان السحرةُ سبعين رجلًا، أصبحوا سَحَرةً، وأمسَوا شهداء. وفي لفظٍ: كانوا سحرة في أول النهار، وشهداءَ آخر النهار حين قُتلوا{1}. (٦/٤٩٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٨٤٣٤<span class="dash">-</span></span> قال <span class="name-1">عبد الله بن عباس</span>: كانوا اثنين وسبعين ساحرًا، مع كل واحد منهم حبلٌ و عصًا {2}.(ز) (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٨٤٣٥<span class="dash">-</span></span> عن <span class="name-2">كعب الأحبار</span> -من طريق جرير، عن عبد العزيز بن رفيع، عن خيثمة، عن أبي سودة- قال: كان سَحرةُ فرعون اثني عشر ألفًا{3}. (٦/٤٩٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٨٤٣٦<span class="dash">-</span></span> عن <span class="name-2">كعب الأحبار</span> -من طريق عبد العزيز بن رفيع، عن خيثمة- قال: كانت السحرة سبعة عشر ألفا{4}.(ز) (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٨٤٣٧<span class="dash">-</span></span> عن <span class="name-2">كعب الأحبار</span> -من طريق أبي بكر بن عياش، عن عبد العزيز بن رفيع، عن أبي سودة- قال: كانت سَحَرَةُ فرعون تسعة عشر ألفًا{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٨٤٣٨<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span> -من طريق يزيد- قال: السَّحَرة كانوا سبعين. قال أبو جعفر: أحسبه أنا قال: ألفًا{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٨٤٣٩<span class="dash">-</span></span> عن <span class="name-2">القاسم بن أبي بزَّة</span> -من طريق هشام الدستوائي- قال: سحرة فرعون كانوا سبعين ألف ساحر{7}. (٦/٤٩٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٨٤٤٠<span class="dash">-</span></span> عن <span class="name-2">محمد بن كعب القرظي</span> -من طريق موسى بن عبيدة- قال: كانَتِ السحرةُ الذين تَوفّاهم الله مسلمين ثمانين ألفًا{5}. (٦/٤٩٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٨٤٤١<span class="dash">-</span></span> عن <span class="name-2">محمد بن المنكدر</span>، مثل ذلك{9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٨٤٤٢<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- قال: كان السحرةُ بضعةً وثلاثينَ ألفًا، ليس منهم رجلٌ إلا معه حبلٌ أو عصًا، فلمّا ألقَوا سحَروا أعيُنَ الناس واستَرْهبُوهم{10}. (٦/٤٩٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٨٤٤٣<span class="dash">-</span></span> عن <span class="name-2">محمد بن المنكدر</span> -من طريق موسى بن عبيدة- قال: كان السحرة ثمانين ألفًا{11}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٨٤٤٤<span class="dash">-</span></span> عن <span class="name-2">أبي ثُمامة [الحنّاط]</span> -من طريق عبد العزيز بن رفيع- قال: سحرة فرعون سبعة عشر ألفًا. وفي لفظٍ: تسعةَ عشر ألفًا{12}. (٦/٤٩٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٨٤٤٥<span class="dash">-</span></span> قال <span class="name-3">محمد بن السائب الكلبي</span>: كان الذين يُعلِّمونهم رجلين مجوسيين من أهل نينوى، وكانوا سبعين غير رئيسهم{13}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٨٤٤٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل</span>: كانوا اثنين وسبعين؛ اثنان من القبط، وهما رأسا القوم، وسبعون من بني إسرائيل{14}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٨٤٤٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل:</span> كان رئيس السحرة شمعون{15}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٨٤٤٨<span class="dash">-</span></span> عن <span class="name-3">عبد الملك ابن جُرَيْج</span> -من طريق حجّاج- قال: السحرةُ ثلاثُمائة مِن فيُّومَ، ثلاثمائة من العريش، ويشكُّون في ثلاثمائة من الإسْكَندرِيَّة{16}. (٦/٤٩٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٨٤٤٩<span class="dash">-</span></span> قال <span class="name-3">عبد الملك ابن جُرَيْج</span>: رئيس السحرة يوحنا{15}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٨٤٥٠<span class="dash">-</span></span> عن <span class="name-3">محمد بن إسحاق</span> -من طريق سلمة- قال: جُمِع له خمسة عشر ألف ساحرٍ{18}<span class=comment-ref>٢٦٠١</span>. (٦/٤٩٧)</p></p><p></div></p><p><div><span class=comment-ref>٢٦٠١</span> ذكر <u>ابنُ عطية</u> (٤/١٣) قول محمد بن إسحاق في عدد السحرة الذين أتي بهم إلى فرعون، وقول ابن جريج، وقول محمد بن المنكدر، وقول السدي، ثم <span class="comment-type-4">عَلَّق</span> عليها جميعًا بقوله: «وهذه الأقوال ليس لها سند يوقف عنده».</div></p><p><h3><span class="qpc-hafs">﴿قَالُوۤا۟ إِنَّ لَنَا لَأَجۡرًا إِن كُنَّا نَحۡنُ ٱلۡغَـٰلِبِینَ ۝١١٣﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٢٨٤٥١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عكرمة- قال: قال فرعون: لا نُغالِبه -يعني: موسى- إلا بمن هو منه. فأعَدَّ غِلمانًا مِن بني إسرائيل، فبعث بهم إلى قرية بمصر يقال لها: الفَرَما{19}، يُعَلِّمونهم السحر، كما يُعَلَّم الصبيان الكِتاب في الكُتّاب. قال: فعلموهم سحرًا كثيرًا. قال: وواعد موسى فرعون موعدًا، فلمّا كان في ذلك الموعد بعث فرعونُ إلى السحرة، فجاء بهم، وجاء بمعلمهم معهم، فقال له: ماذا صنعت؟ قال: قد علمتهم من السحر سحرًا لا يُطِيقه سحرُ أهل الأرض، إلا أن يكون أمرًا من السماء، فإنّه لا طاقة لهم به، فأمّا سحر أهل الأرض فإنه لن يغلبهم. فلما جاءت السحرة قالوا لفرعون: <span class="qpc-hafs">﴿إن لنا لأجرا إن كنا نحن الغالبين قال نعم وإنكم إذا لمن المقربين﴾</span> [الشعراء:٤١-٤٢]{20}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٨٤٥٢<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span>، في قوله: <span class="qpc-hafs">﴿قالوا إن لنا لأجرا﴾</span>، أي: أئِنَّ لنا لَعطاءً وفضيلةً{21}. (٦/٤٩٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٨٤٥٣<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السدي</span> -من طريق أسباط-: فأرسل فرعون في المدائن حاشرين، فحشروا عليه السحرة، فلما جاء السحرة فرعون <span class="qpc-hafs">﴿قالوا إن لنا لأجرا إن كنا نحن الغالبين﴾</span> يقول: عَطِيَّة تُعطينا <span class="qpc-hafs">﴿إن كنا نحن الغالبين * قال نعم وإنكم لمن المقربين﴾</span>{22}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٨٤٥٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وجاء السحرة فرعون قالوا إن لنا لأجرا﴾</span> يعنى: جُعْلًا؛ <span class="qpc-hafs">﴿إن كنا نحن الغالبين﴾</span> لموسى{23}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه عبد الرزاق ١/٢٣٤، وابن جرير ١٠/٣٦٤، وابن أبي حاتم ٥/١٥٣٨. وعزاه السيوطي إلى ابن المنذر، وأبي الشيخ.|2:تفسير الثعلبي ٦/٢٤٩.|3:أخرجه ابن جرير ١٠/٣٥٥، وابن أبي حاتم ٥/١٥٣٤، ٨/٢٧٦٥. وعزاه السيوطي إلى ابن أبي شيبة، وأبي الشيخ.|4:أخرجه آدم بن أبي إياس -كما في تفسير مجاهد ص٥١٠-.|5:أخرجه ابن أبي حاتم ٥/١٥٣٤، ٨/٢٧٦٥.|6:أخرجه ابن جرير ١٠/٣٥٥ والشكُّ منه.|7:أخرجه ابن جرير ١٦/١٠٧. وعزاه السيوطي إلى أبي الشيخ.|8:أخرجه ابن أبي حاتم ٥/١٥٣٤، ٨/٢٧٦٥.|9:علقه ابن أبي حاتم ٨/٢٧٦٥.|10:أخرجه ابن جرير ١٠/٣٥٦، وابن أبي حاتم ٥/١٥٣٥، ٦/٢٧٦٤، ٨/٢٧٦٦. وعزاه السيوطي إلى أبي الشيخ.|11:أخرجه ابن جرير ١٠/٣٥٥.|12:أخرجه ابن أبي حاتم ٥/١٥٣٥. وعزاه السيوطي إلى ابن المنذر.|13:تفسير الثعلبي ٤/٢٦٩، وتفسير البغوي ٣/٢٦٤.|14:تفسير الثعلبي ٤/٢٦٨، وتفسير البغوي ٣/٢٦٤.|15:تفسير البغوي ٣/٢٦٤.|16:أخرجه ابن جرير ١٦/١٠٨. وعزاه السيوطي إلى أبي الشيخ.|17:تفسير البغوي ٣/٢٦٤.|18:أخرجه ابن جرير ١٠/٣٥٤، وابن أبي حاتم ٨/٢٧٦٢.|19:الفَرَما: مدينة بقرب مصر. لسان العرب (فرم).|20:أخرجه ابن جرير ١٠/٣٥٣.|21:عزاه السيوطي إلى عبد بن حميد، وابن أبي حاتم.|22:أخرجه ابن جرير ١٠/٣٥٤.|23:تفسير مقاتل بن سليمان ٢/٥٣.
  7,114,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿قَالَ نَعَمۡ وَإِنَّكُمۡ لَمِنَ ٱلۡمُقَرَّبِینَ ۝١١٤﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٢٨٤٥٥<span class="dash">-</span></span> قال <span class="name-3">محمد بن السائب الكلبي:</span> أول مَن يدخل عَلَيَّ، وآخر مَن يخرج، <span class="qpc-hafs">﴿قالوا﴾</span> يعني: السحرة{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٨٤٥٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿قال﴾</span> فرعون: <span class="qpc-hafs">﴿نعم وإنكم لمن المقربين﴾</span> في المنزلة سوى العظمة، كان هذا يوم السبت في المحرم، والسحرة اثنان وسبعون رجلًا{2}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير الثعلبي ٤/٢٦٩، وتفسير البغوي ٣/٢٦٥.|2:تفسير مقاتل بن سليمان ٢/٥٣-٥٤.
  7,115,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿قَالُوا۟ یَـٰمُوسَىٰۤ إِمَّاۤ أَن تُلۡقِیَ وَإِمَّاۤ أَن نَّكُونَ نَحۡنُ ٱلۡمُلۡقِینَ ۝١١٥﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٢٨٤٥٧<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق سعيد بن جبير- قال: اليوم الذي أظهر الله فيه موسى على السحرة وفرعون هو يوم عاشوراء، فلما اجتمعوا في صعيدٍ قال الناسُ بعضُهم لبعض: انطلقوا، فلنحضر هذا الأمر، ونتبع السحرة إن كانوا هم الغالبين. يعني بذلك: موسى وهارون صلى الله عليهما وسلم، استهزاءً بهما، <span class="qpc-hafs">﴿قالوا يا موسى﴾</span> لقدرتهم بسحرهم: <span class="qpc-hafs">﴿إما أن تلقي وإما أن نكون نحن الملقين قال: ألْقُوا﴾</span>. <span class="qpc-hafs">﴿فَأَلْقَوْا حِبالَهُمْ وعِصِيَّهُمْ وقالُوا بِعِزَّةِ فِرْعَوْنَ إنّا لَنَحْنُ الغالِبُونَ﴾</span> [الشعراء:٤٤]، فرأى موسى مِن سحرهم ما أوجس في نفسه خيفة، فأوحى الله ﷿ إليه أن ألق العصا{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٨٤٥٨<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿قالوا يا موسى﴾</span> فقالت السحرة لموسى: <span class="qpc-hafs">﴿إما أن تلقي﴾</span> ما في يدك، يعني: عصاه، <span class="qpc-hafs">﴿وإما أن نكون نحن الملقين﴾</span> ما في أيدينا من الحبال والعصي{2}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن أبي حاتم ٥/١٥٣٥.|2:تفسير مقاتل بن سليمان ٢/٥٤.
  7,116,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿قَالَ أَلۡقُوا۟ۖ فَلَمَّاۤ أَلۡقَوۡا۟ سَحَرُوۤا۟ أَعۡیُنَ ٱلنَّاسِ وَٱسۡتَرۡهَبُوهُمۡ وَجَاۤءُو بِسِحۡرٍ عَظِیمࣲ ۝١١٦﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٢٨٤٥٩<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عكرمة - في قوله: <span class="qpc-hafs">﴿فلما ألقوا﴾</span>، قال: ألقَوْا حِبالًا غِلاظا، وخُشُبًا طِوالًا، فأقبَلتْ تُخَيَّلُ إليه من سحرهم أنها تسعى{1}. (٦/٤٩٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٨٤٦٠<span class="dash">-</span></span> عن <span class="name-2">القاسم بن أبي بزَّة</span> -من طريق هشام الدستوائي- قال: سحرة فرعون كانوا سبعين ألف ساحرِ، فألقَوْا سبعين ألف حبل، وسبعين ألف عصا، حتى جعَل موسى يُخيَّلُ إليه من سِحْرِهم أنها تسعى، فأوحى الله إليه: يا موسى، ألْقِ عصاك. فألقى عصاه، فإذا هي ثعبانٌ فاغِرٌ فاهُ، فابتلَع حبالَهم وعصِيَّهم، فأُلقِيَ السحرة عندَ ذلك سُجَّدًا، فما رفَعوا رءُوسَهم حتى رأوُا الجنة والنارَ وثوابَ أهلِها{2}. (٦/٤٩٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٨٤٦١<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- قال: <span class="qpc-hafs">﴿قال لهم موسى ألقوا ما أنتم ملقون فألقوا حبالهم وعصيهم﴾</span> [الشعراء:٤٣-٤٤]، وكانوا بضعة وثلاثين ألف رجل، ليس منهم رجل إلا معه حبل وعصا، <span class="qpc-hafs">﴿فلما ألقوا سحروا أعين الناس واسترهبوهم﴾</span> يقول: فَرَقُوهم، <span class="qpc-hafs">﴿فأوجس في نفسه خيفة موسى﴾</span> [طه:٦٧]{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٨٤٦٢<span class="dash">-</span></span> عن <span class="name-3">محمد بن إسحاق</span> -من طريق سلمة- قال: صَفَّ خمسة عشر ألف ساحر، مع كل ساحر حباله وعِصِيُّه، وخرج موسى معه أخوه يَتَّكِئُ على عصاه، حتى أتى الجمع، وفرعونُ في مجلسه مع أشراف مملكته، ثم قال السحرة: <span class="qpc-hafs">﴿يا موسى إما أن تلقي وإما أن نكون أول من ألقى* قال بل ألقوا فإذا حبالهم وعصيهم يخيل إليه من سحرهم أنها تسعى﴾</span> [طه: ٦٥-٦٦]، فكان أول ما اختطفوا بسحرهم بصر موسى وبصر فرعون، ثم أبصار الناس بعْدُ، ثم ألقى كل رجل منهم ما في يده من العصي والحبال، فإذا هي حيات كأمثال الجبال، قد ملأت الوادي يركب بعضها بعضًا. <span class="qpc-hafs">﴿فأوجس في نفسه خيفة موسى﴾</span> [طه:٦٧]، وقال: واللهِ، إن كانت لَعِصِيًّا في أيديهم، ولقد عادت حيات، وما تعدو عصاي هذا؟ أو كما حدَّث نفسه{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٨٤٦٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿قالَ﴾</span> لَهُمْ مُوسى: <span class="qpc-hafs">﴿ألقوا﴾</span> ما أنتم ملقون، <span class="qpc-hafs">﴿فلما ألقوا﴾</span> الحبال والعصي <span class="qpc-hafs">﴿سحروا أعين الناس واسترهبوهم﴾</span> يعنى: وخَوَّفوهم، <span class="qpc-hafs">﴿وجاؤا بسحر عظيم﴾</span>{5}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ١٠/٣٥٧.|2:أخرجه ابن جرير ١٠/٣٥٨-٣٥٩، ١٦/١٠٧. وعزاه السيوطي إلى أبي الشيخ.|3:أخرجه ابن جرير ١٠/٣٥٦.|4:أخرجه ابن جرير ١٠/٣٥٧.|5:تفسير مقاتل بن سليمان ٢/٥٤.
  7,117,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَأَوۡحَیۡنَاۤ إِلَىٰ مُوسَىٰۤ أَنۡ أَلۡقِ عَصَاكَۖ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٢٨٤٦٤<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق سعيد بن جبير- قوله: <span class="qpc-hafs">﴿وأوحينا إلى موسى أن ألق عصاك﴾</span>، قال: فأوحى الله إليه: أن ألق العصا. فلما ألقاها صارت ثعبانًا عظيمًا فاغرة فاها{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٨٤٦٥<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق مَعْمَر- في قوله: <span class="qpc-hafs">﴿وأوحينا إلى موسى أن ألق عصاك﴾</span>. فألقى عصاه، فتحولتْ حيَّةً، فأكلتْ سحرَهم كلَّه، وعِصِيَّهم، وحبالَهم{2}. (٦/٤٩٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٨٤٦٦<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- في قوله: <span class="qpc-hafs">﴿وأوحينا إلى موسى أن ألق عصاك﴾</span>، قال: أوحى الله إلى موسى أن: ألْقِ ما في يمينك. فألْقى عصاه، فأكَلتْ كلَّ حيَّة لهم، فلما رأوا ذلك سَجَدوا{3}. (٦/٤٩٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٨٤٦٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وأَوْحَيْنا إلى مُوسى أنْ ألْقِ عَصاكَ﴾</span>، فصارت حيَّةً{4}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿فَإِذَا هِیَ تَلۡقَفُ مَا یَأۡفِكُونَ ۝١١٧﴾</span> - قراءات</h3></p><p><div></p><p><p><span class="item-no">٢٨٤٦٨<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span> أنّه كان يقرأ:(فَإذا هِيَ تَلْقَمُ ما يَأْفِكُونَ){5}. (٦/٤٩٩)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿فَإِذَا هِیَ تَلۡقَفُ مَا یَأۡفِكُونَ ۝١١٧﴾</span> - تفسير الآية</h3></p><p><div></p><p><p><span class="item-no">٢٨٤٦٩<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نَجِيح- في قوله: <span class="qpc-hafs">﴿تلقف ما يأفكون﴾</span>، قال: يَكْذِبون{6}. (٦/٤٩٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٨٤٧٠<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق قُرَّة بن خالد- في قوله: <span class="qpc-hafs">﴿تلقف ما يأفكون﴾</span>، قال: تَسْتَرِطُ{7} حبالهم، وعِصيَّهم{8}. (٦/٤٩٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٨٤٧١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فَإذا هِيَ تَلْقَفُ﴾</span> يعني: تلقم <span class="qpc-hafs">﴿ما يَأْفِكُونَ﴾</span> يعني: ما جاءوا به من الكَذِب{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٨٤٧٢<span class="dash">-</span></span> عن <span class="name-3">محمد بن إسحاق</span> -من طريق سلمة- قال: أوحى اللهُ إليه: أنْ ألق ما في يمينك. فألقى عصاه من يده، فاستعرضت ما ألقوا من حبالهم وعصيهم -وهي حيّات في عين فرعون وأعين الناس تسعى-، فجعلت تلقفها: تبتلعها حيَّة حيَّة، حتى ما يُرى بالوادي قليلٌ ولا كثيرٌ مِمّا ألقوه، ثم أخذها موسى، فإذا هي عصاه في يده كما كانت، ووقع السحرة سُجَّدًا، قالوا: <span class="qpc-hafs">﴿آمنا برب العالمين رب موسى وهارون﴾</span>، لو كان هذا سحرًا ما غَلَبَنا{10}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن أبي حاتم ٥/١٥٣٥.|2:أخرجه عبد الرزاق ١/٢٣٤، وابن جرير ١٠/٣٥٨، وابن أبي حاتم ٥/١٥٣٣. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وأبي الشيخ.|3:أخرجه ابن جرير ١٠/٣٥٩، وابن أبي حاتم ٨/٢٧٦٦. وعزاه السيوطي إلى أبي الشيخ.|4:تفسير مقاتل بن سليمان ٢/٥٤.|5:أخرجه ابن أبي داود في المصاحف ص٩٠.</p><p>وهي قراءة شاذة، تروى أيضًا عن النخعي، وأبي حيوة. انظر: مختصر ابن خالويه ص٥٠.|6:تفسير مجاهد ص٣٤٠، وأخرجه ابن جرير ١٠/٣٥٩-٣٦٠، وابن أبي حاتم ٥/١٥٣٦. وعزاه السيوطي إلى ابن أبي شيبة، وعبد بن حميد، وابن المنذر.|7:استرطه: ابتلعه من غير مضغ. تاج العروس (سرط).|8:أخرجه ابن جرير ١٠/٣٦٠، وابن أبي حاتم ٥/١٥٣٦. وعزاه السيوطي إلى أبي الشيخ.|9:تفسير مقاتل بن سليمان ٢/٥٤.|10:أخرجه ابن جرير ١٠/٣٥٩.
  7,118,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿فَوَقَعَ ٱلۡحَقُّ وَبَطَلَ مَا كَانُوا۟ یَعۡمَلُونَ ۝١١٨﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٢٨٤٧٣<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق سعيد بن جبير- يعني: قوله: <span class="qpc-hafs">﴿فوقع الحق﴾</span>، قال: ظَهَر الحق{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٨٤٧٤<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق مهاجر- في قوله: <span class="qpc-hafs">﴿فوقع الحق﴾</span> قال: ظهر، <span class="qpc-hafs">﴿وبطل ما كانوا يعملون﴾</span> قال: ذهَب الإفكُ الذي كانوا يعملون{2}. (٦/٥٠٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٨٤٧٥<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿فوقع الحق﴾</span>، قال: ظَهَر موسى{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٨٤٧٦<span class="dash">-</span></span> قال <span class="name-2">الحسن البصري</span>: <span class="qpc-hafs">﴿فوقع الحق﴾</span>: ظهر الحق، <span class="qpc-hafs">﴿وبطل ما كانوا يعملون﴾</span> من السحر{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٨٤٧٧<span class="dash">-</span></span> قال <span class="name-3">محمد بن السائب الكلبي</span>: وقال السحرة بعضُهم لبعض: لو كان هذا سِحْرًا لَبَقِيَتْ حبالنُا وعِصِيُّنا{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٨٤٧٨<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فَوَقَعَ الحَقُّ﴾</span> يعني: فظهر الحقُّ بأنّه ليس بسِحْر، <span class="qpc-hafs">﴿وبَطَلَ ما كانُوا يَعْمَلُونَ﴾</span> يعني: بطل ما كانوا يعملون من السحر{6}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن أبي حاتم ٥/١٥٣٦.|2:تفسير مجاهد ص٣٤٠ بنحوه في شطره الأول، وأخرجه ابن جرير١٠/٣٦٠-٣٦١. وعلَّقه ابن أبي حاتم ٥/١٥٣٦. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وأبي الشيخ.|3:أخرجه ابن جرير١٠/٣٦١.|4:تفسير البغوي ٣/٢٦٥.|5:ذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٢/١٣٦-.|6:تفسير مقاتل بن سليمان ٢/٥٤.
  7,119,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿فَغُلِبُوا۟ هُنَالِكَ وَٱنقَلَبُوا۟ صَـٰغِرِینَ ۝١١٩﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٢٨٤٧٩<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق سعيد بن جبير- قوله: <span class="qpc-hafs">﴿وبطل ما كانوا يعملون فغلبوا هنالك وانقلبوا صاغرين﴾</span>، فكسر اللهُ ظهر فرعون في ذلك الموطن وأشياعه{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٨٤٨٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فَغُلِبُوا هُنالِكَ﴾</span> يعني: عند ذلك، <span class="qpc-hafs">﴿وانْقَلَبُوا صاغِرِينَ﴾</span> يعني: فرجعوا إلى منازلهم مُذَلِّين{2}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن أبي حاتم ٥/١٥٣٦.|2:تفسير مقاتل بن سليمان ٢/٥٤.
  7,120,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَأُلۡقِیَ ٱلسَّحَرَةُ سَـٰجِدِینَ ۝١٢٠﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٢٨٤٨١<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span> -من طريق سالم الأفطس- في قوله: <span class="qpc-hafs">﴿وألقي السحرةُ ساجدين﴾</span>، قال: رأوا منازلَهم تُبنى لهم وهم في سُجودهم{1}. (٦/٥٠٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٨٤٨٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل</span>: ألقاهم الله{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٨٤٨٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وأُلْقِيَ السَّحَرَةُ ساجِدِينَ﴾</span> لله{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٨٤٨٤<span class="dash">-</span></span> عن <span class="name-3">الأوزاعي</span> قال: لَمّا خرَّ السحرةُ سُجَّدًا رُفِعت لهم الجنة حتى نظَروا إليها{4}. (٦/٥٠٠)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن أبي حاتم ٥/١٥٣٦، ٨/٢٧٦٦.|2:تفسير البغوي ٣/٢٦٦.|3:تفسير مقاتل بن سليمان ٢/٥٤.|4:عزاه السيوطي إلى ابن أبي حاتم.