tafsir[9]{c,v,t}:
22,56," <q>﴿ٱلۡمُلۡكُ یَوۡمَىِٕذࣲ لِّلَّهِ یَحۡكُمُ بَیۡنَهُمۡۚ فَٱلَّذِینَ ءَامَنُوا۟ وَعَمِلُوا۟ ٱلصَّـٰلِحَـٰتِ فِی جَنَّـٰتِ ٱلنَّعِیمِ ۝٥٦﴾</q> - تفسير ٥١٠٨٩- قال مقاتل بن سليمان: ثم قال في التقديم: <q>﴿الملك يومئذ لله﴾</q> يعني: يوم القيامة لا يُنازِعه فيه أحدٌ، واليوم في الدنيا يُنازِعُه غيره في ملكه، <q>﴿يحكم بينهم﴾</q> ثم بيَّن حُكْمَه في كفار مكة، فقال سبحانه: <q>﴿فالذين آمنوا وعملوا الصالحات في جنات النعيم* والذين كفروا وكذبوا بآياتنا فأولئك لهم عذاب مهين﴾</q>{1}. (ز) ٥١٠٩٠- قال يحيى بن سلّام: قوله: <q>﴿الملك يومئذ لله﴾</q> يوم القيامة، <q>﴿يحكم بينهم﴾</q> بين المؤمنين والكافرين{2}٤٥٠٤. (ز) ٤٥٠٤ قال ابنُ عطية (٦/٢٦٦-٢٦٧): «وقوله:<q>﴿المُلْكُ يَوْمَئِذٍ لِلَّهِ﴾</q>، السابق منه أنّه في يوم القيامة مِن حيث لا مُلك فيه لأحد، ويجوز أن يريد به: يوم بدر ونحوه مِن حيث ينفذ فيه قضاء الله وحده، ويبطل ما سواه، ويمضي حكمه فيمن أراد تعذيبه، فأمّا مَن تَأَوَّله في يوم القيامة فاتَّسق له قوله: <q>﴿فالَّذِينَ آمَنُوا﴾</q> إلى قوله: <q>﴿عذاب مهين﴾</q>، ومَن تأوله في يوم بدر ونحوه جعل قوله تعالى: <q>﴿فالذين آمنوا﴾</q> ابتداء خبر عن حالهم المتركبة على حالهم في ذلك اليوم العقيم من الإيمان والكفر». ",footnotes:1:تفسير مقاتل بن سليمان ٣/١٣٤.تفسير يحيى بن سلام ١/٣٨٥.
22,57," <q>﴿وَٱلَّذِینَ كَفَرُوا۟ وَكَذَّبُوا۟ بِـَٔایَـٰتِنَا فَأُو۟لَـٰۤىِٕكَ لَهُمۡ عَذَابࣱ مُّهِینࣱ ۝٥٧﴾</q> - تفسير ٥١٠٩١- قال مقاتل بن سليمان: <q>﴿والذين كفروا﴾</q> بتوحيد الله <q>﴿وكذبوا بآياتنا﴾</q> بالقرآن بأنّه ليس من الله ﷿؛ <q>﴿فأولئك لهم عذاب مهين﴾</q> يعني: الهوان{1}. (ز) ٥١٠٩٢- قال يحيى بن سلّام: قوله: <q>﴿والذين كفروا وكذبوا بآياتنا فأولئك لهم عذاب مهين﴾</q> من الهوان{2}. (ز) ",footnotes:1:تفسير مقاتل بن سليمان ٣/١٣٤.تفسير يحيى بن سلام ١/٣٨٥.
22,58," <q>﴿وَٱلَّذِینَ هَاجَرُوا۟ فِی سَبِیلِ ٱللَّهِ ثُمَّ قُتِلُوۤا۟ أَوۡ مَاتُوا۟ لَیَرۡزُقَنَّهُمُ ٱللَّهُ رِزۡقًا حَسَنࣰاۚ وَإِنَّ ٱللَّهَ لَهُوَ خَیۡرُ ٱلرَّ ٰ⁠زِقِینَ ۝٥٨﴾</q> - نزول الآيتين ٥١٠٩٣- قال مقاتل بن سليمان: <q>﴿والذين هاجروا في سبيل الله ثم قتلوا أو ماتوا ليرزقنهم الله رزقا حسنا وإن الله لهو خير الرازقين﴾</q>، وذلك أنّ نفَرًا مِن المسلمين قالوا للنبي ﷺ: نحن نقاتل المشركين، فنقتل منهم، ولا نستشهد، فما لنا شهادة. فأشركهم الله ﷿ جميعًا في الجنة، فنزلت فيهم آيتان{1}. (ز) <q>﴿وَٱلَّذِینَ هَاجَرُوا۟ فِی سَبِیلِ ٱللَّهِ ثُمَّ قُتِلُوۤا۟ أَوۡ مَاتُوا۟ لَیَرۡزُقَنَّهُمُ ٱللَّهُ رِزۡقًا حَسَنࣰاۚ وَإِنَّ ٱللَّهَ لَهُوَ خَیۡرُ ٱلرَّ ٰ⁠زِقِینَ ۝٥٨﴾</q> - تفسير الآية ٥١٠٩٤- عن سلمان الفارسي، قال: سمعت رسول الله ﷺ يقول: «مَن مات مُرابطًا أجرى الله عليه مثلَ ذلك الأجر، وأَجرى عليه الرزق، وأومن الفتّانين، واقرأوا إن شئتم: <q>﴿والذين هاجروا في سبيل الله ثم قتلوا أو ماتوا﴾</q> إلى قوله: <q>﴿حليم﴾</q>»{2}. (١٠/٥٣٤) ٥١٠٩٥- عن فَضالَة بن عُبيد الأنصاري-من طريق عبد الرحمن بن جَحْدَم الخولاني، وسَلامان بن عامر- أنه كان برُودِس{3}، فمَرُّوا بجنازتين؛ أحدهما قتيل، والآخر متوفًى، فمال الناسُ على القتيل، فقال فضالة: ما لي أرى الناسَ مالوا مع هذا وتركوا هذا؟ فقالوا: هذا القتيل في سبيل الله. فقال: واللهِ، ما أُبالي مِن أيِّ حفرتيهما بُعِثْتُ؛ اسمعوا كتاب الله: <q>﴿والذين هاجروا في سبيل الله ثم قتلوا أو ماتوا﴾</q> الآيتين، فما تبتغي -أيها العبد- إذا أدخلت مدخلًا ترضاه، ورُزِقت رزقًا حسنًا، واللهِ، ما أُبالي مِن أي حفرتيهما بُعِثْتَ{4}. (١٠/٥٣٤) ٥١٠٩٦- قال مقاتل بن سليمان: <q>﴿والذين هاجروا في سبيل الله﴾</q> إلى المدينة، <q>﴿ثم قتلوا أو ماتوا ليرزقنهم الله﴾</q> في الآخرة <q>﴿رزقا حسنا﴾</q> يعني: كريمًا{5}. (ز) ٥١٠٩٧- قال يحيى بن سلّام: قوله: <q>﴿والذين هاجروا في سبيل الله ثم قتلوا﴾</q> في سبيل الله بعد الهجرة، <q>﴿أو ماتوا﴾</q> على فرشهم بعد الهجرة؛ <q>﴿ليرزقنهم الله رزقا حسنا﴾</q> الجنة، <q>﴿وإن الله لهو خير الرازقين﴾</q>{6}. (ز) ",footnotes:1:تفسير مقاتل بن سليمان ٣/١٣٤. وذكر المحقق أن عقبه زيادة في إحدى النسخ: «نظيرها الآية من سورة النساء». يشير إلى قوله تعالى: <q>﴿ومَن يَخْرُجْ مِن بَيْتِهِ مُهاجِرًا إلى اللَّهِ ورَسُولِهِ ثُمَّ يُدْرِكْهُ المَوْتُ فَقَدْ وقَعَ أجْرُهُ عَلى اللَّهِ وكانَ اللَّهُ غَفُورًا رَحِيمًا﴾</q> [النساء:١٠٠].أخرجه ابن المبارك في الجهاد ص١٤٠ (١٧٢)، ومن طريقه ابن أبي حاتم -كما في تفسير ابن كثير ٥/٤٤٨-، من طريق عبد الرحمن بن شريح، قال: سمعت عبد الكريم بن الحارث يحدث عن أبي عبيدة بن عقبة، عن رجل من أهل الشام، عن شرحبيل بن السمط الكندي، عن سلمان به. إسناده ضعيف؛ لجهالة الراوي عن شرحبيل بن السمط، والراوي عنه أبو عبيدة بن عقبة لم يوثقه أحد غير ابن حبان، فذكره في الثقات. وقد أخرجه مسلم دون ذكر الآية ٣/١٥٢٠ (١٩١٣).رُودِس -بضم الراء وفتحها، وكسر الدال-: جزيرة مقابل الإسكندرية، على ليلة منها في البحر. معجم البلدان ٣/٧٨.أخرجه ابن جرير ١٦/٦١٩ دون آخره، وابن أبي حاتم -كما في تفسير ابن كثير ٥/٤٤٤-. وعزاه السيوطي إلى ابن المنذر مختصرًا.تفسير مقاتل بن سليمان ٣/١٣٤.تفسير يحيى بن سلام ١/٣٨٦.
22,59," <q>﴿لَیُدۡخِلَنَّهُم مُّدۡخَلࣰا یَرۡضَوۡنَهُۥۚ﴾</q> - تفسير ٥١٠٩٨- عن إسماعيل السُّدِّيّ، في قوله: <q>﴿مدخلا يرضونه﴾</q>، قال: الجنة{1}. (١٠/٥٣٥) ٥١٠٩٩- قال يحيى بن سلّام: قوله: <q>﴿ليدخلنهم مدخلا يرضونه﴾</q> في الجنة{2}. (ز) <q>﴿وَإِنَّ ٱللَّهَ لَعَلِیمٌ حَلِیمࣱ ۝٥٩﴾</q> - تفسير ٥١١٠٠- قال مقاتل بن سليمان: <q>﴿وإن الله لعليم﴾</q> لقولهم، <q>﴿حليم﴾</q> عنهم، لقولهم: إنا نقاتل ولا نستشهد{3}. (ز) ",footnotes:1:عزاه السيوطي إلى ابن أبي حاتم.تفسير يحيى بن سلام ١/٣٨٦.تفسير مقاتل بن سليمان ٣/١٣٤.
22,60," <q>﴿ذَ ٰ⁠لِكَۖ وَمَنۡ عَاقَبَ بِمِثۡلِ مَا عُوقِبَ بِهِۦ ثُمَّ بُغِیَ عَلَیۡهِ لَیَنصُرَنَّهُ ٱللَّهُۚ إِنَّ ٱللَّهَ لَعَفُوٌّ غَفُورࣱ ۝٦٠﴾</q> - نزول الآية ٥١١٠١- قال مقاتل بن سليمان: <q>﴿ذلك ومن عاقب﴾</q>، وذلك أنّ مشركي مكة لقوا المسلمين لليلة بَقِيَت من المحرم، فقال بعضُهم لبعض: إنّ أصحاب محمد يكرهون القتال في الشهر الحرام، فاحمِلُوا عليهم، فناشدهم المسلمون أن يُقاتلوهم في الشهر الحرام، فأبى المشركون إلا القتال، فبغوا على المسلمين، فقتلوهم، وحملوا عليهم، وثبت المسلمون، فنصر اللهُ ﷿ المسلمين عليهم، فوقع في أنفُس المسلمين مِن القتال في الشهر الحرام؛ فأنزل الله ﷿: <q>﴿ذلك ومن عاقب﴾</q>{1}. (ز) ٥١١٠٢- عن مقاتل [بن حيان]، في قوله: <q>﴿ذلك ومن عاقب﴾</q> الآية، قال: إنّ النبيَّ ﷺ بعث سَرِيَّة في ليلتين بقيتا مِن المحرم، فلقوا المشركين، فقال المشركون بعضُهم لبعض: قاتِلوا أصحاب محمد؛ فإنّهم يُحَرِّمون القتال في الشهر الحرام. وإنّ أصحاب محمد ناشدوهم وذَكَّروهم بالله أن يعرضوا لقتالهم؛ فإنّهم لا يستحلون القتال في الشهر الحرام إلا مَن بادَأَهُم، وإنّ المشركين بدءوا، وقاتلوهم؛ فاسْتَحَلَّ الصحابةُ قتالهم عند ذلك، فقاتلوهم، ونصرهم الله عليهم{2}. (١٠/٥٣٥) <q>﴿ذَ ٰ⁠لِكَۖ وَمَنۡ عَاقَبَ بِمِثۡلِ مَا عُوقِبَ بِهِۦ ثُمَّ بُغِیَ عَلَیۡهِ لَیَنصُرَنَّهُ ٱللَّهُۚ إِنَّ ٱللَّهَ لَعَفُوٌّ غَفُورࣱ ۝٦٠﴾</q> - تفسير الآية ٥١١٠٣- قال الحسن البصري، في قوله: <q>﴿ذلك ومن عاقب بمثل ما عوقب به﴾</q>: يعني: قاتل المشركين كما قاتلوه{3}. (ز) ٥١١٠٤- عن عبد الملك ابن جُرَيْج -من طريق حجّاج- في قوله: <q>﴿ذلك ومن عاقب﴾</q> الآية، قال: تَعاوَنَ المشركون على النبي ﷺ وأصحابِه، فأخرجوه، فوعد الله أن ينصره، وهو في القصاص أيضًا{4}. (١٠/٥٣٥) ٥١١٠٥- قال مقاتل بن سليمان: <q>﴿ذلك ومن عاقب﴾</q> هذا جزاءُ مَن عاقب <q>﴿بمثل ما عوقب به ثم بغي عليه لينصرنه الله إن الله لعفو﴾</q> عنهم، <q>﴿غفور﴾</q> لقتالهم في الشهر الحرام{5}. (ز) ٥١١٠٦- قال يحيى بن سلّام: قوله: <q>﴿ذلك ومن عاقب بمثل ما عوقب به ثم بغي عليه﴾</q>، يعني بذلك: مشركي العرب أنهم عُوقِبوا، فقتلهم الله بجحودهم النبيَّ وظلمِهم إيّاه وأصحابه، وبغيهم عليهم. قال: <q>﴿لينصرنه الله إن الله لعفو غفور﴾</q>، النصر: في الدنيا الظهور على المشركين، والحُجَّة عليهم في الآخرة، كقوله: <q>﴿إنا لننصر رسلنا والذين آمنوا في الحياة الدنيا ويوم يقوم الأشهاد﴾</q> [غافر:٥١] يوم القيامة{6}. (ز) ",footnotes:1:تفسير مقاتل بن سليمان ٣/١٣٥ وهو مرسل.عزاه السيوطي إلى ابن أبي حاتم مرسلًا.تفسير البغوي ٥/٣٩٧.أخرجه ابن جرير ١٦/٦١٦. وعزاه السيوطي إلى ابن المنذر، واللفظ له.تفسير مقاتل بن سليمان ٣/١٣٥.تفسير يحيى بن سلام ١/٣٨٦.
22,61," <q>﴿ذَ ٰ⁠لِكَ بِأَنَّ ٱللَّهَ یُولِجُ ٱلَّیۡلَ فِی ٱلنَّهَارِ وَیُولِجُ ٱلنَّهَارَ فِی ٱلَّیۡلِ وَأَنَّ ٱللَّهَ سَمِیعُۢ بَصِیرࣱ ۝٦١﴾</q> - تفسير ٥١١٠٧- قال مقاتل بن سليمان: <q>﴿ذلك﴾</q> يعني: هذا الذي فعل مِن قُدرته، ثم بَيَّن قُدرتَه جل جلاله، فقال سبحانه: <q>﴿ذلك بأن الله يولج الليل في النهار ويولج النهار في الليل﴾</q> يعني: انتقاص كلِّ واحد منهما مِن الآخر، حتى يكون النهارُ خمس عشرة ساعة، والليل تسع ساعات في كل سنة، <q>﴿وأن الله سميع﴾</q> بأعمالهم، <q>﴿بصير﴾</q> بها{1}. (ز) ٥١١٠٨- قال يحيى بن سلّام: قوله: <q>﴿ذلك بأن الله يولج الليل في النهار ويولج النهار في الليل﴾</q>، هو أخذُ كلِّ واحد منهما مِن صاحبه{2}٤٥٠٥. (ز) ٤٥٠٥ ذكر ابنُ القيم (٢/٢٢٠) ما أفاده قول يحيى بن سلام وقول مقاتل قبله، ثم علّق قائلًا: «وعلى هذا فالآية خاصَّةٌ ببعض ساعات كلِّ مِن الليل والنهار في غير زمن الاعتدال، وفي مقدار ما يَلِجُ في أحدهما من الآخر». ",footnotes:1:تفسير مقاتل بن سليمان ٣/١٣٥.تفسير يحيى بن سلام ١/٣٨٦.
22,62," <q>﴿ذَ ٰ⁠لِكَ بِأَنَّ ٱللَّهَ هُوَ ٱلۡحَقُّ﴾</q> - تفسير ٥١١٠٩- قال مقاتل بن سليمان: <q>﴿ذلك﴾</q> يعني: هذا الذي فعل ذلك يَدُلُّ على توحيده بصنعه؛ <q>﴿بأن الله هو الحق﴾</q>{1}. (ز) ٥١١١٠- قال يحيى بن سلّام: قوله: <q>﴿ذلك بأن الله هو الحق﴾</q>، والحق اسمٌ مِن أسماء الله{2}. (ز) <q>﴿وَأَنَّ مَا یَدۡعُونَ مِن دُونِهِۦ هُوَ ٱلۡبَـٰطِلُ﴾</q> - تفسير ٥١١١١- عن مجاهد بن جبر -من طريق ابن جُرَيْج- في قوله: <q>﴿وأن ما يدعون من دونه هو الباطل﴾</q>، قال: الشيطان{3}. (١٠/٥٣٥) ٥١١١٢- قال الحسن البصري: قوله: <q>﴿وأن ما يدعون من دونه هو الباطل﴾</q>: الأوثان{4}. (ز) ٥١١١٣- قال قتادة بن دعامة: إبليس{4}. (ز) ٥١١١٤- عن عبد الملك ابن جُرَيْج -من طريق حجاج- في قوله: <q>﴿وأن ما يدعون من دونه هو الباطل﴾</q>، قال: الشيطان{6}٤٥٠٦. (ز) ٤٥٠٦ لم يذكر ابنُ جرير (١٦/٦٢٢) غير قول ابن جريج. وذكر ابنُ عطية (٦/٢٦٨) هذا القول، وقول مَن قال: هي الأصنام. ثم مال إلى العموم قائلًا: «والعموم هنا حسن». ٥١١١٥- قال مقاتل بن سليمان: <q>﴿وأن ما يدعون من دونه﴾</q> يعني: يعبدون مِن دونه من الآلهة <q>﴿هو الباطل﴾</q> الذي ليس بشيء، ولا ينفعهم عبادتهم{1}. (ز) <q>﴿وَأَنَّ ٱللَّهَ هُوَ ٱلۡعَلِیُّ ٱلۡكَبِیرُ ۝٦٢﴾</q> - تفسير ٥١١١٦- قال مقاتل بن سليمان: ثم عظَّم نفسه -تبارك اسمه-، فقال: <q>﴿وأن الله هو العلي﴾</q> يعني: الرفيع فوق خلقه، <q>﴿الكبير﴾</q> فلا شيء أعظم منه{1}. (ز) ٥١١١٧- قال يحيى بن سلّام: قوله: <q>﴿وأن الله هو العلي الكبير﴾</q> لا شيء أكبر منه{2}. (ز) ",footnotes:1:تفسير مقاتل بن سليمان ٣/١٣٥.تفسير يحيى بن سلام ١/٣٨٦.أخرجه إسحاق البستي في تفسيره ص٣٧٨. وعزاه السيوطي إلى ابن أبي حاتم.علَّقه يحيى بن سلام ١/٣٨٦.علَّقه يحيى بن سلام ١/٣٨٦.أخرجه ابن جرير ١٦/٦٢٢.تفسير مقاتل بن سليمان ٣/١٣٥.تفسير مقاتل بن سليمان ٣/١٣٥.تفسير يحيى بن سلام ١/٣٨٦.
22,63," <q>﴿أَلَمۡ تَرَ أَنَّ ٱللَّهَ أَنزَلَ مِنَ ٱلسَّمَاۤءِ مَاۤءࣰ فَتُصۡبِحُ ٱلۡأَرۡضُ مُخۡضَرَّةًۚ إِنَّ ٱللَّهَ لَطِیفٌ خَبِیرࣱ ۝٦٣﴾</q> - تفسير ٥١١١٨- قال مقاتل بن سليمان: <q>﴿ألم تر أن الله أنزل من السماء ماء﴾</q> يعني: المطر، <q>﴿فتصبح الأرض مخضرة﴾</q> مِن النبات، <q>﴿إن الله لطيف﴾</q> باستخراج النبت، <q>﴿خبير﴾</q>{1}. (ز) ٥١١١٩- قال يحيى بن سلّام: قوله: <q>﴿ألم تر أن الله أنزل من السماء ماء فتصبح الأرض مخضرة﴾</q> يعني: نباتها، ليس يعني: مِن ليلتها، ولكن إذا أنبتت، <q>﴿إن الله لطيف﴾</q> بخلقه فيما رزقهم، <q>﴿خبير﴾</q> بأعمالهم{2}٤٥٠٧. (ز) ٤٥٠٧ ذكر ابنُ عطية (٦/٢٦٩) عن عكرمة أنه قال في هذه الآية: «هذا لا يكون إلا بمكة أو تهامة». ووجّهه بقوله: «ومعنى هذا: أنّه أخذ قوله: <q>﴿فتصبح﴾</q> مقصودًا به صباح ليلة المطر، وذهب إلى أن ذلك الاخضرار في سائر البلاد يتأخر». ثم علّق قائلًا: «وقد شاهدتُ هذا في السوس الأقصى، نزل المطر بعد قحط، وأصبحت تلك الأرض التي تسقيها الرياح قد اخضرَّتْ بنبات ضعيف دقيق». ",footnotes:1:تفسير مقاتل بن سليمان ٣/١٣٦.تفسير يحيى بن سلام ١/٣٨٦.
22,64," <q>﴿لَّهُۥ مَا فِی ٱلسَّمَـٰوَ ٰ⁠تِ وَمَا فِی ٱلۡأَرۡضِۚ وَإِنَّ ٱللَّهَ لَهُوَ ٱلۡغَنِیُّ ٱلۡحَمِیدُ ۝٦٤﴾</q> - تفسير ٥١١٢٠- قال مقاتل بن سليمان: ثم قال تعالى: <q>﴿له ما في السماوات وما في الأرض﴾</q> عبيده، وفي ملكه، <q>﴿وإن الله لهو الغني﴾</q> عن عبادة خلقه، <q>﴿الحميد﴾</q> عند خلقه في سلطانه{1}. (ز) ٥١١٢١- قال يحيى بن سلّام: قوله: <q>﴿الغني﴾</q> عن خَلْقه، <q>﴿الحميد﴾</q> المستحمد إلى خلقه، استوجب عليهم أن يحمدوه{2}. (ز) ",footnotes:1:تفسير مقاتل بن سليمان ٣/١٣٦.تفسير يحيى بن سلام ١/٣٨٧.
