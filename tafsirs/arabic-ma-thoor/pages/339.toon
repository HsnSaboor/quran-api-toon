quran[9]{c,v,t}:
  22,56,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿ٱلۡمُلۡكُ یَوۡمَىِٕذࣲ لِّلَّهِ یَحۡكُمُ بَیۡنَهُمۡۚ فَٱلَّذِینَ ءَامَنُوا۟ وَعَمِلُوا۟ ٱلصَّـٰلِحَـٰتِ فِی جَنَّـٰتِ ٱلنَّعِیمِ ۝٥٦﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥١٠٨٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثم قال في التقديم: <span class="qpc-hafs">﴿الملك يومئذ لله﴾</span> يعني: يوم القيامة لا يُنازِعه فيه أحدٌ، واليوم في الدنيا يُنازِعُه غيره في ملكه، <span class="qpc-hafs">﴿يحكم بينهم﴾</span> ثم بيَّن حُكْمَه في كفار مكة، فقال سبحانه: <span class="qpc-hafs">﴿فالذين آمنوا وعملوا الصالحات في جنات النعيم* والذين كفروا وكذبوا بآياتنا فأولئك لهم عذاب مهين﴾</span>{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥١٠٩٠<span class="dash">-</span></span> قال <span class="name-3">يحيى بن</span> <span class="name-3">سلّام</span>: قوله: <span class="qpc-hafs">﴿الملك يومئذ لله﴾</span> يوم القيامة، <span class="qpc-hafs">﴿يحكم بينهم﴾</span> بين المؤمنين والكافرين{2}<span class=comment-ref>٤٥٠٤</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٤٥٠٤</span> <span class="comment-type-4">قال</span> <u>ابنُ عطية</u> (٦/٢٦٦-٢٦٧): «وقوله:<span class="qpc-hafs">﴿المُلْكُ يَوْمَئِذٍ لِلَّهِ﴾</span>، السابق منه أنّه في يوم القيامة مِن حيث لا مُلك فيه لأحد، ويجوز أن يريد به: يوم بدر ونحوه مِن حيث ينفذ فيه قضاء الله وحده، ويبطل ما سواه، ويمضي حكمه فيمن أراد تعذيبه، فأمّا مَن تَأَوَّله في يوم القيامة فاتَّسق له قوله: <span class="qpc-hafs">﴿فالَّذِينَ آمَنُوا﴾</span> إلى قوله: <span class="qpc-hafs">﴿عذاب مهين﴾</span>، ومَن تأوله في يوم بدر ونحوه جعل قوله تعالى: <span class="qpc-hafs">﴿فالذين آمنوا﴾</span> ابتداء خبر عن حالهم المتركبة على حالهم في ذلك اليوم العقيم من الإيمان والكفر».</div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٣/١٣٤.تفسير يحيى بن سلام ١/٣٨٥.
  22,57,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَٱلَّذِینَ كَفَرُوا۟ وَكَذَّبُوا۟ بِـَٔایَـٰتِنَا فَأُو۟لَـٰۤىِٕكَ لَهُمۡ عَذَابࣱ مُّهِینࣱ ۝٥٧﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥١٠٩١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿والذين كفروا﴾</span> بتوحيد الله <span class="qpc-hafs">﴿وكذبوا بآياتنا﴾</span> بالقرآن بأنّه ليس من الله ﷿؛ <span class="qpc-hafs">﴿فأولئك لهم عذاب مهين﴾</span> يعني: الهوان{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥١٠٩٢<span class="dash">-</span></span> قال <span class="name-3">يحيى بن</span> <span class="name-3">سلّام</span>: قوله: <span class="qpc-hafs">﴿والذين كفروا وكذبوا بآياتنا فأولئك لهم عذاب مهين﴾</span> من الهوان{2}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٣/١٣٤.تفسير يحيى بن سلام ١/٣٨٥.
  22,58,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَٱلَّذِینَ هَاجَرُوا۟ فِی سَبِیلِ ٱللَّهِ ثُمَّ قُتِلُوۤا۟ أَوۡ مَاتُوا۟ لَیَرۡزُقَنَّهُمُ ٱللَّهُ رِزۡقًا حَسَنࣰاۚ وَإِنَّ ٱللَّهَ لَهُوَ خَیۡرُ ٱلرَّ ٰ⁠زِقِینَ ۝٥٨﴾</span> - نزول الآيتين</h3></p><p><div></p><p><p><span class="item-no">٥١٠٩٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿والذين هاجروا في سبيل الله ثم قتلوا أو ماتوا ليرزقنهم الله رزقا حسنا وإن الله لهو خير الرازقين﴾</span>، وذلك أنّ نفَرًا مِن المسلمين قالوا للنبي ﷺ: نحن نقاتل المشركين، فنقتل منهم، ولا نستشهد، فما لنا شهادة. فأشركهم الله ﷿ جميعًا في الجنة، فنزلت فيهم آيتان{1}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَٱلَّذِینَ هَاجَرُوا۟ فِی سَبِیلِ ٱللَّهِ ثُمَّ قُتِلُوۤا۟ أَوۡ مَاتُوا۟ لَیَرۡزُقَنَّهُمُ ٱللَّهُ رِزۡقًا حَسَنࣰاۚ وَإِنَّ ٱللَّهَ لَهُوَ خَیۡرُ ٱلرَّ ٰ⁠زِقِینَ ۝٥٨﴾</span> - تفسير الآية</h3></p><p><div></p><p><p><span class="item-no">٥١٠٩٤<span class="dash">-</span></span> عن سلمان الفارسي، قال: سمعت رسول الله ﷺ يقول: «<b>مَن مات مُرابطًا أجرى الله عليه مثلَ ذلك الأجر، وأَجرى عليه الرزق، وأومن الفتّانين، واقرأوا إن شئتم</b>: <span class="qpc-hafs">﴿والذين هاجروا في سبيل الله ثم قتلوا أو ماتوا﴾</span> إلى قوله: <span class="qpc-hafs">﴿حليم﴾</span>»{2}. (١٠/٥٣٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥١٠٩٥<span class="dash">-</span></span> عن <span class="name-1">فَضالَة بن عُبيد الأنصاري</span>-من طريق عبد الرحمن بن جَحْدَم الخولاني، وسَلامان بن عامر- أنه كان برُودِس{3}، فمَرُّوا بجنازتين؛ أحدهما قتيل، والآخر متوفًى، فمال الناسُ على القتيل، فقال فضالة: ما لي أرى الناسَ مالوا مع هذا وتركوا هذا؟ فقالوا: هذا القتيل في سبيل الله. فقال: واللهِ، ما أُبالي مِن أيِّ حفرتيهما بُعِثْتُ؛ اسمعوا كتاب الله: <span class="qpc-hafs">﴿والذين هاجروا في سبيل الله ثم قتلوا أو ماتوا﴾</span> الآيتين، فما تبتغي -أيها العبد- إذا أدخلت مدخلًا ترضاه، ورُزِقت رزقًا حسنًا، واللهِ، ما أُبالي مِن أي حفرتيهما بُعِثْتَ{4}. (١٠/٥٣٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥١٠٩٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿والذين هاجروا في سبيل الله﴾</span> إلى المدينة، <span class="qpc-hafs">﴿ثم قتلوا أو ماتوا ليرزقنهم الله﴾</span> في الآخرة <span class="qpc-hafs">﴿رزقا حسنا﴾</span> يعني: كريمًا{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥١٠٩٧<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: قوله: <span class="qpc-hafs">﴿والذين هاجروا في سبيل الله ثم قتلوا﴾</span> في سبيل الله بعد الهجرة، <span class="qpc-hafs">﴿أو ماتوا﴾</span> على فرشهم بعد الهجرة؛ <span class="qpc-hafs">﴿ليرزقنهم الله رزقا حسنا﴾</span> الجنة، <span class="qpc-hafs">﴿وإن الله لهو خير الرازقين﴾</span>{6}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٣/١٣٤. وذكر المحقق أن عقبه زيادة في إحدى النسخ: «نظيرها الآية من سورة النساء». يشير إلى قوله تعالى: <span class="qpc-hafs">﴿ومَن يَخْرُجْ مِن بَيْتِهِ مُهاجِرًا إلى اللَّهِ ورَسُولِهِ ثُمَّ يُدْرِكْهُ المَوْتُ فَقَدْ وقَعَ أجْرُهُ عَلى اللَّهِ وكانَ اللَّهُ غَفُورًا رَحِيمًا﴾</span> [النساء:١٠٠].أخرجه ابن المبارك في الجهاد ص١٤٠ (١٧٢)، ومن طريقه ابن أبي حاتم -كما في تفسير ابن كثير ٥/٤٤٨-، من طريق عبد الرحمن بن شريح، قال: سمعت عبد الكريم بن الحارث يحدث عن أبي عبيدة بن عقبة، عن رجل من أهل الشام، عن شرحبيل بن السمط الكندي، عن سلمان به.</p><p>إسناده ضعيف؛ لجهالة الراوي عن شرحبيل بن السمط، والراوي عنه أبو عبيدة بن عقبة لم يوثقه أحد غير ابن حبان، فذكره في الثقات.</p><p>وقد أخرجه مسلم دون ذكر الآية ٣/١٥٢٠ (١٩١٣).رُودِس -بضم الراء وفتحها، وكسر الدال-: جزيرة مقابل الإسكندرية، على ليلة منها في البحر. معجم البلدان ٣/٧٨.أخرجه ابن جرير ١٦/٦١٩ دون آخره، وابن أبي حاتم -كما في تفسير ابن كثير ٥/٤٤٤-. وعزاه السيوطي إلى ابن المنذر مختصرًا.تفسير مقاتل بن سليمان ٣/١٣٤.تفسير يحيى بن سلام ١/٣٨٦.
  22,59,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿لَیُدۡخِلَنَّهُم مُّدۡخَلࣰا یَرۡضَوۡنَهُۥۚ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥١٠٩٨<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span>، في قوله: <span class="qpc-hafs">﴿مدخلا يرضونه﴾</span>، قال: الجنة{1}. (١٠/٥٣٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥١٠٩٩<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: قوله: <span class="qpc-hafs">﴿ليدخلنهم مدخلا يرضونه﴾</span> في الجنة{2}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَإِنَّ ٱللَّهَ لَعَلِیمٌ حَلِیمࣱ ۝٥٩﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥١١٠٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وإن الله لعليم﴾</span> لقولهم، <span class="qpc-hafs">﴿حليم﴾</span> عنهم، لقولهم: إنا نقاتل ولا نستشهد{3}. (ز)</p></p><p></div></p></div>",footnotes:1:عزاه السيوطي إلى ابن أبي حاتم.تفسير يحيى بن سلام ١/٣٨٦.تفسير مقاتل بن سليمان ٣/١٣٤.
  22,60,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿ذَ ٰ⁠لِكَۖ وَمَنۡ عَاقَبَ بِمِثۡلِ مَا عُوقِبَ بِهِۦ ثُمَّ بُغِیَ عَلَیۡهِ لَیَنصُرَنَّهُ ٱللَّهُۚ إِنَّ ٱللَّهَ لَعَفُوٌّ غَفُورࣱ ۝٦٠﴾</span> - نزول الآية</h3></p><p><div></p><p><p><span class="item-no">٥١١٠١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ذلك ومن عاقب﴾</span>، وذلك أنّ مشركي مكة لقوا المسلمين لليلة بَقِيَت من المحرم، فقال بعضُهم لبعض: إنّ أصحاب محمد يكرهون القتال في الشهر الحرام، فاحمِلُوا عليهم، فناشدهم المسلمون أن يُقاتلوهم في الشهر الحرام، فأبى المشركون إلا القتال، فبغوا على المسلمين، فقتلوهم، وحملوا عليهم، وثبت المسلمون، فنصر اللهُ ﷿ المسلمين عليهم، فوقع في أنفُس المسلمين مِن القتال في الشهر الحرام؛ فأنزل الله ﷿: <span class="qpc-hafs">﴿ذلك ومن عاقب﴾</span>{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥١١٠٢<span class="dash">-</span></span> عن <span class="name-3">مقاتل [بن حيان]</span>، في قوله: <span class="qpc-hafs">﴿ذلك ومن عاقب﴾</span> الآية، قال: إنّ النبيَّ ﷺ بعث سَرِيَّة في ليلتين بقيتا مِن المحرم، فلقوا المشركين، فقال المشركون بعضُهم لبعض: قاتِلوا أصحاب محمد؛ فإنّهم يُحَرِّمون القتال في الشهر الحرام. وإنّ أصحاب محمد ناشدوهم وذَكَّروهم بالله أن يعرضوا لقتالهم؛ فإنّهم لا يستحلون القتال في الشهر الحرام إلا مَن بادَأَهُم، وإنّ المشركين بدءوا، وقاتلوهم؛ فاسْتَحَلَّ الصحابةُ قتالهم عند ذلك، فقاتلوهم، ونصرهم الله عليهم{2}. (١٠/٥٣٥)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿ذَ ٰ⁠لِكَۖ وَمَنۡ عَاقَبَ بِمِثۡلِ مَا عُوقِبَ بِهِۦ ثُمَّ بُغِیَ عَلَیۡهِ لَیَنصُرَنَّهُ ٱللَّهُۚ إِنَّ ٱللَّهَ لَعَفُوٌّ غَفُورࣱ ۝٦٠﴾</span> - تفسير الآية</h3></p><p><div></p><p><p><span class="item-no">٥١١٠٣<span class="dash">-</span></span> قال <span class="name-2">الحسن البصري</span>، في قوله: <span class="qpc-hafs">﴿ذلك ومن عاقب بمثل ما عوقب به﴾</span>: يعني: قاتل المشركين كما قاتلوه{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥١١٠٤<span class="dash">-</span></span> عن <span class="name-3">عبد الملك ابن جُرَيْج</span> -من طريق حجّاج- في قوله: <span class="qpc-hafs">﴿ذلك ومن عاقب﴾</span> الآية، قال: تَعاوَنَ المشركون على النبي ﷺ وأصحابِه، فأخرجوه، فوعد الله أن ينصره، وهو في القصاص أيضًا{4}. (١٠/٥٣٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥١١٠٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ذلك ومن عاقب﴾</span> هذا جزاءُ مَن عاقب <span class="qpc-hafs">﴿بمثل ما عوقب به ثم بغي عليه لينصرنه الله إن الله لعفو﴾</span> عنهم، <span class="qpc-hafs">﴿غفور﴾</span> لقتالهم في الشهر الحرام{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥١١٠٦<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: قوله: <span class="qpc-hafs">﴿ذلك ومن عاقب بمثل ما عوقب به ثم بغي عليه﴾</span>، يعني بذلك: مشركي العرب أنهم عُوقِبوا، فقتلهم الله بجحودهم النبيَّ وظلمِهم إيّاه وأصحابه، وبغيهم عليهم. قال: <span class="qpc-hafs">﴿لينصرنه الله إن الله لعفو غفور﴾</span>، النصر: في الدنيا الظهور على المشركين، والحُجَّة عليهم في الآخرة، كقوله: <span class="qpc-hafs">﴿إنا لننصر رسلنا والذين آمنوا في الحياة الدنيا ويوم يقوم الأشهاد﴾</span> [غافر:٥١] يوم القيامة{6}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٣/١٣٥ وهو مرسل.عزاه السيوطي إلى ابن أبي حاتم مرسلًا.تفسير البغوي ٥/٣٩٧.أخرجه ابن جرير ١٦/٦١٦. وعزاه السيوطي إلى ابن المنذر، واللفظ له.تفسير مقاتل بن سليمان ٣/١٣٥.تفسير يحيى بن سلام ١/٣٨٦.
  22,61,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿ذَ ٰ⁠لِكَ بِأَنَّ ٱللَّهَ یُولِجُ ٱلَّیۡلَ فِی ٱلنَّهَارِ وَیُولِجُ ٱلنَّهَارَ فِی ٱلَّیۡلِ وَأَنَّ ٱللَّهَ سَمِیعُۢ بَصِیرࣱ ۝٦١﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥١١٠٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ذلك﴾</span> يعني: هذا الذي فعل مِن قُدرته، ثم بَيَّن قُدرتَه جل جلاله، فقال سبحانه: <span class="qpc-hafs">﴿ذلك بأن الله يولج الليل في النهار ويولج النهار في الليل﴾</span> يعني: انتقاص كلِّ واحد منهما مِن الآخر، حتى يكون النهارُ خمس عشرة ساعة، والليل تسع ساعات في كل سنة، <span class="qpc-hafs">﴿وأن الله سميع﴾</span> بأعمالهم، <span class="qpc-hafs">﴿بصير﴾</span> بها{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥١١٠٨<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: قوله: <span class="qpc-hafs">﴿ذلك بأن الله يولج الليل في النهار ويولج النهار في الليل﴾</span>، هو أخذُ كلِّ واحد منهما مِن صاحبه{2}<span class=comment-ref>٤٥٠٥</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٤٥٠٥</span> ذكر <u>ابنُ القيم</u> (٢/٢٢٠) ما أفاده قول يحيى بن سلام وقول مقاتل قبله، ثم <span class="comment-type-4">علّق</span> قائلًا: «وعلى هذا فالآية خاصَّةٌ ببعض ساعات كلِّ مِن الليل والنهار في غير زمن الاعتدال، وفي مقدار ما يَلِجُ في أحدهما من الآخر».</div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٣/١٣٥.تفسير يحيى بن سلام ١/٣٨٦.
  22,62,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿ذَ ٰ⁠لِكَ بِأَنَّ ٱللَّهَ هُوَ ٱلۡحَقُّ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥١١٠٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ذلك﴾</span> يعني: هذا الذي فعل ذلك يَدُلُّ على توحيده بصنعه؛ <span class="qpc-hafs">﴿بأن الله هو الحق﴾</span>{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥١١١٠<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: قوله: <span class="qpc-hafs">﴿ذلك بأن الله هو الحق﴾</span>، والحق اسمٌ مِن أسماء الله{2}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَأَنَّ مَا یَدۡعُونَ مِن دُونِهِۦ هُوَ ٱلۡبَـٰطِلُ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥١١١١<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن جُرَيْج- في قوله: <span class="qpc-hafs">﴿وأن ما يدعون من دونه هو الباطل﴾</span>، قال: الشيطان{3}. (١٠/٥٣٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥١١١٢<span class="dash">-</span></span> قال <span class="name-2">الحسن البصري</span>: قوله: <span class="qpc-hafs">﴿وأن ما يدعون من دونه هو الباطل﴾</span>: الأوثان{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥١١١٣<span class="dash">-</span></span> قال <span class="name-2">قتادة بن دعامة</span>: إبليس{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥١١١٤<span class="dash">-</span></span> عن <span class="name-3">عبد الملك ابن جُرَيْج</span> -من طريق حجاج- في قوله: <span class="qpc-hafs">﴿وأن ما يدعون من دونه هو الباطل﴾</span>، قال: الشيطان{6}<span class=comment-ref>٤٥٠٦</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٤٥٠٦</span> لم يذكر <u>ابنُ جرير</u> (١٦/٦٢٢) غير قول ابن جريج.</p><p>وذكر <u>ابنُ عطية</u> (٦/٢٦٨) هذا القول، وقول مَن قال: هي الأصنام. ثم <span class="comment-type-3">مال</span> إلى <span class="mustanad">العموم</span> قائلًا: «والعموم هنا حسن».</div></p><p><div></p><p><p><span class="item-no">٥١١١٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وأن ما يدعون من دونه﴾</span> يعني: يعبدون مِن دونه من الآلهة <span class="qpc-hafs">﴿هو الباطل﴾</span> الذي ليس بشيء، ولا ينفعهم عبادتهم{1}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَأَنَّ ٱللَّهَ هُوَ ٱلۡعَلِیُّ ٱلۡكَبِیرُ ۝٦٢﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥١١١٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثم عظَّم نفسه -تبارك اسمه-، فقال: <span class="qpc-hafs">﴿وأن الله هو العلي﴾</span> يعني: الرفيع فوق خلقه، <span class="qpc-hafs">﴿الكبير﴾</span> فلا شيء أعظم منه{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥١١١٧<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: قوله: <span class="qpc-hafs">﴿وأن الله هو العلي الكبير﴾</span> لا شيء أكبر منه{2}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٣/١٣٥.تفسير يحيى بن سلام ١/٣٨٦.أخرجه إسحاق البستي في تفسيره ص٣٧٨. وعزاه السيوطي إلى ابن أبي حاتم.علَّقه يحيى بن سلام ١/٣٨٦.علَّقه يحيى بن سلام ١/٣٨٦.أخرجه ابن جرير ١٦/٦٢٢.تفسير مقاتل بن سليمان ٣/١٣٥.تفسير مقاتل بن سليمان ٣/١٣٥.تفسير يحيى بن سلام ١/٣٨٦.
  22,63,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿أَلَمۡ تَرَ أَنَّ ٱللَّهَ أَنزَلَ مِنَ ٱلسَّمَاۤءِ مَاۤءࣰ فَتُصۡبِحُ ٱلۡأَرۡضُ مُخۡضَرَّةًۚ إِنَّ ٱللَّهَ لَطِیفٌ خَبِیرࣱ ۝٦٣﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥١١١٨<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ألم تر أن الله أنزل من السماء ماء﴾</span> يعني: المطر، <span class="qpc-hafs">﴿فتصبح الأرض مخضرة﴾</span> مِن النبات، <span class="qpc-hafs">﴿إن الله لطيف﴾</span> باستخراج النبت، <span class="qpc-hafs">﴿خبير﴾</span>{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥١١١٩<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: قوله: <span class="qpc-hafs">﴿ألم تر أن الله أنزل من السماء ماء فتصبح الأرض مخضرة﴾</span> يعني: نباتها، ليس يعني: مِن ليلتها، ولكن إذا أنبتت، <span class="qpc-hafs">﴿إن الله لطيف﴾</span> بخلقه فيما رزقهم، <span class="qpc-hafs">﴿خبير﴾</span> بأعمالهم{2}<span class=comment-ref>٤٥٠٧</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٤٥٠٧</span> ذكر <u>ابنُ عطية</u> (٦/٢٦٩) عن عكرمة أنه قال في هذه الآية: «هذا لا يكون إلا بمكة أو تهامة». و<span class="comment-type-1">وجّهه</span> بقوله: «ومعنى هذا: أنّه أخذ قوله: <span class="qpc-hafs">﴿فتصبح﴾</span> مقصودًا به صباح ليلة المطر، وذهب إلى أن ذلك الاخضرار في سائر البلاد يتأخر». ثم <span class="comment-type-4">علّق</span> قائلًا: «وقد شاهدتُ هذا في السوس الأقصى، نزل المطر بعد قحط، وأصبحت تلك الأرض التي تسقيها الرياح قد اخضرَّتْ بنبات ضعيف دقيق».</div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٣/١٣٦.تفسير يحيى بن سلام ١/٣٨٦.
  22,64,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿لَّهُۥ مَا فِی ٱلسَّمَـٰوَ ٰ⁠تِ وَمَا فِی ٱلۡأَرۡضِۚ وَإِنَّ ٱللَّهَ لَهُوَ ٱلۡغَنِیُّ ٱلۡحَمِیدُ ۝٦٤﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥١١٢٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثم قال تعالى: <span class="qpc-hafs">﴿له ما في السماوات وما في الأرض﴾</span> عبيده، وفي ملكه، <span class="qpc-hafs">﴿وإن الله لهو الغني﴾</span> عن عبادة خلقه، <span class="qpc-hafs">﴿الحميد﴾</span> عند خلقه في سلطانه{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥١١٢١<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: قوله: <span class="qpc-hafs">﴿الغني﴾</span> عن خَلْقه، <span class="qpc-hafs">﴿الحميد﴾</span> المستحمد إلى خلقه، استوجب عليهم أن يحمدوه{2}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٣/١٣٦.تفسير يحيى بن سلام ١/٣٨٧.