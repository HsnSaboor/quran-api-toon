quran[9]{c,v,t}:
10,98," <q>﴿فَلَوۡلَا كَانَتۡ قَرۡیَةٌ ءَامَنَتۡ﴾</q> - قراءات ٣٤٩٣١- عن قتادة، قال: بلغني أنّ في حرف عبد الله بن مسعود: (فَهَلّا كانَتْ قَرْيَةٌ آمَنَتْ){1}٣١٦١. (٧/٧٠٧) ٣١٦١ علق ابنُ عطية (٤/٥٢٨) على القراءتين <q>﴿فلولا﴾</q>، و(فَهَلّا) بقوله: «المعنى فيهما واحد». <q>﴿فَلَوۡلَا كَانَتۡ قَرۡیَةٌ ءَامَنَتۡ﴾</q> - تفسير الآية ٣٤٩٣٢- عن عبد الله بن عباس -من طريق عطاء الخراساني- في قوله: <q>﴿فلولا كانت قريةٌ آمنت﴾</q> الآية، قال: لم تكن قريةٌ آمَنَتْ فنفعها الإيمانُ إذا نزل بها بأسُ الله إلا قريةَ يونس{2}٣١٦٢. (٧/٧٠٨) ٣١٦٢ علَّقَ ابنُ تيمية (٣/٤٩٩) على تفسير ابن عباس <q>﴿فلولا كانت﴾</q>: بمعنى: لم يكن، بقوله: «هذا حقٌّ». ٣٤٩٣٣- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿فلولا كانت قرية آمنت﴾</q>، قال: فلم تكن قريةٌ آمنتْ{3}. (٧/٧٠٧) ٣٤٩٣٤- قال مجاهد بن جبر -من طريق ابن جُرَيْج-: فلم تكن قرية آمنت فنفعها إيمانها كما نفع قوم يونس إيمانهم إلا قوم يونس{4}. (ز) ٣٤٩٣٥- عن أبي مالكٍ [غزوان الغفاري]، قال: كلُّ ما في القرآن <q>﴿فلولا﴾</q> فهو: فهلّا، إلا في حرفين؛ في يونس: <q>﴿فلولا كانتْ قرية آمنتْ﴾</q>، والآخرُ:<q>﴿فلولا كان من القُرُون من قبلكمْ﴾</q> [هود:١١٦]{5}. (٧/٧٠٧) ٣٤٩٣٦- عن أبي مالكٍ [غزوان الغفاري]، في قوله: <q>﴿فلولا كانت قريةٌ آمنت﴾</q>، يقولُ: فما كانت قريةٌ آمَنَتْ{5}. (٧/٧٠٧) ٣٤٩٣٧- قال مقاتل بن سليمان: <q>﴿فَلَوْلا﴾</q>: فهلّا، إلا ما في يونس وهود{7}. (ز) <q>﴿ءَامَنَتۡ فَنَفَعَهَاۤ إِیمَـٰنُهَاۤ إِلَّا قَوۡمَ یُونُسَ لَمَّاۤ ءَامَنُوا۟ كَشَفۡنَا عَنۡهُمۡ عَذَابَ ٱلۡخِزۡیِ فِی ٱلۡحَیَوٰةِ ٱلدُّنۡیَا﴾</q> - تفسير ٣٤٩٣٨- عن عبد الله بن مسعود، أنّ النبيَّ ﷺ قال: «إن يونس دعا قومَه، فلمّا أبَوا أن يُجِيبوه وعَدَهم العذابَ، فقال: إنّه يأتيكم يوم كذا وكذا. ثم خرج عنهم، وكانت الأنبياءُ إذا وعدتْ قومها العذاب خرجت عنهم، فلمّا أظلَّهم العذابُ خرجوا، ففرَّقوا بين المرأة وولدها، وبين السَّخْلَة وأولادها، وخرجوا يَعِجُّون إلى الله، فعَلِم اللهُ منهم الصِّدق، فتاب عليهم، وصرف عنهم العذاب، وقعد يونسُ في الطريق يسألُ عن الخبر، فمرَّ به رجلٌ، فقال: ما فعل قومُ يونس؟ فحدَّثه بما صنعوا، فقال: لا أرجعُ إلى قوم قد كَذَبْتُهم. وانطلق مُغاضبًا يعني: مُراغِمًا»{8}. (٧/٧٠٩) ٣٤٩٣٩- عن عائشة، عن النبي ﷺ في قوله: <q>﴿إلا قوم يُونُس لمّا آمنوا﴾</q>، قال: «لَمّا دَعَوْا»{9}. (٧/٧٠٨) ٣٤٩٤٠- عن عمرو بن ميمون، قال: حدثنا ابن مسعود في بيت المال، قال: إنّ يونس ﵇ كان قد وعَدَ قومَه العذابَ، وأخبرهم أنّه يأتيهم إلى ثلاثة أيام، ففرّقوا بين كلِّ والدة وولدها، ثم خرجوا فجأروا إلى الله، واستَغْفَرُوه، فكفَّ عنهم العذاب، وغدا يونس ينظر العذاب، فلم ير شيئًا، وكان مَن كذب، ولم تكن له بينة قُتل. فانطلق مُغاضِبًا{10}. (ز) ٣٤٩٤١- قال عبد الله بن مسعود: بلغ مِن توبة أهل نِينَوى{11} أن ترادُّوا المظالم بينهم، حتى أن كان الرجل لَيَأْتِي الحجرَ وقد وُضِع عليه أساسٌ فيقلعه ويردُّه{12}. (ز) ٣٤٩٤٢- عن عليِّ بن أبي طالب -من طريق عمير بن سعيد- قال: تِيبَ على قوم يونس يومَ عاشوراءَ{13}. (٧/٧١٠) ٣٤٩٤٣- عن عبد الله بن عباس -من طريق قتادة-: إنّ العذاب كان هبط على قوم يونس، حتى لم يكن بينهم وبينه إلا قدرُ ثُلُثَي ميلٍ، فلمّا دَعَوْا كشف الله عنهم{14}. (٧/٧٠٩) ٣٤٩٤٤- عن عبد الله بن عباس، قال: لَمّا دعا يونسُ على قومه أوحى الله إليه أنّ العذاب مُصَبِّحهم، فقالوا: ما كذبَ يونس، ولَيُصَبِّحنّا العذابُ، فتعالوا حتى نُخْرج سِخال كُلِّ شيءٍ، فنجعلها مع أولادنا؛ لعلَّ الله أن يرحمَهم. فأخرجوا النساء معهنَّ الوِلْدانُ، وأَخْرجوا الإبل معها فُصْلانُها، وأَخْرجوا البقرَ معها عَجاجِيلُها، وأَخْرجوا الغنم معها سِخالهُا، فجعلوه أمامهم، وأقبَل العذابُ، فلمّا أن رأوه جَأَرُوا إلى الله ودَعَوْا، وبكى النساءُ والولدانُ، ورَغَتِ الإبلُ وفُصْلانُها، وخارَتِ البقرُ وعَجاجِيلُها، وثَغَتِ الغنمُ وسِخالهُا، فرحمهم الله، فصرف عنهم العذابَ إلى جبال آمِد، فهُم يُعذَّبون حتى الساعة{15}. (٧/٧١٠) ٣٤٩٤٥- عن عبد الله بن عباس -من طريق سعيد بن جبير- قال: بعثه الله إلى أهل قريةٍ، فردُّوا عليه ما جاءهم به، فامتنعوا منه، فلمّا فعلوا ذلك أوصى الله إليه: إنِّي مرسل عليهم العذاب في يوم كذا، فاخرج مِن بين أظهرهم. فأَعْلَمَ قومَه الذي وعده الله مِن عذابه إيّاهم، فقالوا: ارْمُقُوه، فإن هو خرج مِن بين أظهركم فهو -واللهِ- كائِنٌ ما وعَدَكم. فلمّا كانت الليلة التي وُعِدُوا العذابَ في صبيحتها اندَلَجَ، فرآه القومُ، فحذروا، فخرجوا مِن القرية إلى براز بين أراضيهم، وفرَّقوا بين كل دابة وولدها، ثم عجُّوا إلى الله، وأنابوا، واستقالوا، فأقالهم، وانتظر يونس الخبر عن القرية وأهلها حتى مرَّ به مارٌّ، فقال: ما فعل أهل القرية؟ قال: فعلوا أنّ نبيهم لَمّا خرج مِن بين أظهرهم عرفوا أنّه قد صَدَقَهم ما وعدهم مِن العذاب، فخرجوا مِن قريتهم إلى براز من الأرض، ثم فرَّقوا بين كل ذات والد وولدها، ثم عجُّوا إلى الله وتابوا إليه، فقبل منهم، وأخَّر عنهم العذاب{16}. (ز) ٣٤٩٤٦- عن أبي الجَلْد جِيلان -من طريق أبي عمران الجوني- قال: لَمّا غَشّى قومَ يونسَ العذابُ مشَوا إلى شيخ مِن بَقِيَّة علمائهم، فقالوا له: ما ترى؟ قال: قولوا: يا حيُّ حين لا حيَّ، ويا حيُّ محييَ الموتى، ويا حيُّ لا إله إلا أنت. فقالوا، فكُشِف عنهم العذابُ{17}. (٧/٧١٠) ٣٤٩٤٧- عن سعيد بن جبير -من طريق إسماعيل بن عبد الملك- قال: غَشّى قوم يونس العذابُ، كما يُغَشِّي الثوبُ بالقبرِ إذا أُدخِل فيه صاحبُه، ومَطَرَت السماء دمًا{18}. (٧/٧٠٩) ٣٤٩٤٨- عن سعيد بن جبير -من طريق إسماعيل بن عبد الملك- قال: قال: لَمّا أُرْسِل يونس إلى قومه يدعوهم إلى الإسلام، وترْك ما هم عليه، قال: فدعاهم، فأبَوْا، فقيل له: أخبِرهم أنّ العذاب مُصَبِّحُهم. فقالوا: إنّا لم نُجَرِّب عليه كذبًا، فانظروا، فإن بات فيكم فليس بشيء، وإن لم يبِت فاعلموا أنّ العذاب مُصَبِّحُكم. فلمّا كان في جوف الليل أخذ مخلاته، فتزود فيها شيئًا، ثم خرج، فلما أصبحوا تغشّاهم العذابُ كما يَتَغَشّى الإنسان الثوب في القبر، ففرّقوا بين الإنسان وولده، وبين البهيمة وولدها، ثم عجُّوا إلى الله، فقالوا: آمَنّا بما جاء به يونس، وصدّقنا. فكشف الله عنهم العذاب، فخرج يونس ينظر العذاب، فلم ير شيئًا، قال: جَرَّبوا عَلَيَّ كذِبًا. فذهب مُغاضِبًا لربه حتى أتى البحر{19}. (ز) ٣٤٩٤٩- قال وهب بن مُنَبِّه: غامَتِ السماءُ غيمًا أسودَ هائلًا، يُدَخِّنُ دخانًا شديدًا، وهبط حتى غشى مدينتهم، واسْوَدَّت سُطوحهم، فلمّا رأوا ذلك أيقنوا بالهلاك، فطلبوا نبيَّهم، فلم يجدوه، فقذف اللهُ في قلوبهم التوبة، فخرجوا إلى الصعيد بأنفسهم ونسائهم وصبيانهم ودوابهم، ولبسوا المسوح، وأظهروا الإيمان والتوبة، وأخلصوا النية، وفرّقوا بين كل والدة وولدها مِن الناس والأنعام، فحنَّ بعضهم إلى بعض، وعَلَت أصواتهم، واختلطت أصواتُها بأصواتهم، وحنينُها بحنينهم، وعجُّوا وضجُّوا إلى الله تعالى، وقالوا: آمَنّا بما جاء به يونس. فرحمهم ربُّهم، واستجاب دعاءَهم، وكشف عنهم العذاب بعد ما أظلَّهم، وتدلّى إلى سمعهم، وذلك يوم عاشوراء{20}. (ز) ٣٤٩٥٠- عن قتادة بن دعامة -من طريق سعيد- <q>﴿فلولا كانت قرية آمنت﴾</q> الآية، يقولُ: لم يكن هذا في الأمم قبلَ قومِ يونس، لم ينفع قريةً كفرتْ ثم آمنتْ حين عايَنَتِ العذاب إلا قومَ يونس، فاستثْنى اللهُ قوم يونس٣١٦٣. وذُكِر لنا: أنّ قوم يونس كانوا بنِينَوى من أرض الموصل، فلمّا فقدوا نبيَّهم قذف اللهُ تعالى في قلوبهم التوبةَ، فلَبِسوا المسُوح، وأخْرجوا المواشِيَ، وفرَّقوا بين كلّ بهيمة وولدها، فعجُّوا إلى الله أربعين صباحًا، فلمّا عرف الله الصِّدق من قلوبهم والتوبةَ والنَّدامة على ما مضى منهم؛ كشف عنهم العذاب بعد ما تدلّى عليهم، لم يكنْ بينهم وبين العذاب إلا مِيلٌ{21}. (٧/٧٠٧) ٣١٦٣ اسْتَدْرَكَ ابنُ تيمية (٣/٤٩٩) على قول قتادة هذا مستندًا للغة، فقال: «قتادة ظنّ أن المعنى: أنه نفعهم دون غيرهم. وليس كذلك، بل غيرهم لم يؤمن إيمانًا ينفع، وهؤلاء آمنوا إيمانًا ينفع، والاستثناء حجة لنا؛ لأنه منقطع، ولو اتصل لرفع». وقال ابنُ عطية (٤/٥٣٠) مسْتَدْركًا: «ذهب الطبري إلى أن قوم يونس خُصّوا من بين الأمم بأن تِيب عليهم من بعد معاينة العذاب، ذَكَرَ ذلك عن جماعة من المفسرين. وليس كذلك، والمعاينة التي لا تنفع التوبة معها هي تلبس العذب أو الموت بشخص الإنسان، كقصة فرعون. وأما قوم يونس فلم يصلوا هذا الحد». ٣٤٩٥١- عن قتادة بن دعامة -من طريق مَعْمَر- في قوله: <q>﴿إلا قوم يونس لما آمنوا﴾</q>، قال: بلغنا: أنّهم خرجوا فنَزلوا على تلٍّ، وفرَّقوا بين كل بهيمة وولدها، فدَعَوُا الله أربعين ليلةً حتى تاب عليهم{22}. (٧/٧٠٩) ٣٤٩٥٢- عن قتادة بن دعامة -من طريق خليد- <q>﴿كشفنا عنهم عذاب الخزي﴾</q>، قال: كشف عنهم العذاب بعد أن تَدَلّى عليهم، لم يكن بينهم وبين العذاب إلا مِيل{23}. (ز) ٣٤٩٥٣- عن ابن كثير -من طريق سهل- <q>﴿فلولا كانت قرية آمنت﴾</q>، أي: فلم تكن قرية آمَنَتْ إلا قوم يونس ويوسف{24}. (ز) ٣٤٩٥٤- عن إسماعيل السُّدِّيّ -من طريق أسباط- قال: بُعِث يونسُ إلى قرية يُقالُ لها: نِينَوى، على شاطئ دِجْلَةَ{24}. (٧/٧١٠) ٣٤٩٥٥- عن عبد الله بن أبي نجيح -من طريق شبل- قال: لَمّا رأوا العذاب ينزل فرَّقوا بين كل أنثى وولدها مِن الناس والأنعام، ثم قاموا جميعًا فدعوا الله، وأخلصوا إيمانهم، فرأوا العذاب يُكْشَف عنهم. قال يونس حين كُشِف عنهم العذاب: أرجع إليهم وقد كذبتهم! وكان يونس قد وعدهم العذاب بصبح ثالثة، فعند ذلك خرج مُغْضَبًا، وساء ظنُّه{26}. (ز) ٣٤٩٥٦- عن عطاء الخراساني -من طريق عثمان بن عطاء- في قول الله: <q>﴿فلولا كانت قرية آمنت فنفعها إيمانها﴾</q> إذا نزل بها بأس الله، ولم نفعل ذلك بقرية إلا قرية يونس{13}. (ز) ٣٤٩٥٧- قال الربيع بن أنس: حدَّثَنا رجل قد قرأ القرآن في صدره في إمارة عمر بن الخطاب، فحدّث عن قوم يونس حين أنذر قومه فكذَّبوه، فأخبرهم أنّ العذاب يصيبهم، ففارقهم، فلمّا رأوا ذلك وغشيهم العذاب لكنَّهم خرجوا مِن مساكنهم وصعدوا في مكان رفيع، وإنّهم جَأَرُوا إلى ربِّهم، ودعوه مخلصين له الدين أن يكشف عنهم العذاب، وأن يرجع إليهم رسولُهم. قال: ففي ذلك أنزل: <q>﴿فلولا كانت قرية آمنت فنفعها إيمانها إلا قوم يونس لما آمنوا كشفنا عنهم عذاب الخزي في الحياة الدنيا ومتعناهم إلى حين﴾</q>. فلم تكن قريةٌ غَشِيَها العذابُ ثم أمسك عنها إلا قومُ يونسَ خاصَّة؛ فلما رأى ذلك يونس، لكنَّه ذهب عاتبًا على ربه، وانطلق مُغاضِبًا وظنَّ أن لن نقدر عليه، حتى ركب في سفينة فأصاب أهلها عاصف الريح. فذكر قصة يونس وخبره{28}. (ز) ٣٤٩٥٨- عن محمد بن إسحاق -من طريق سلمة-: وكان مِن حديث يونس بن متّى -فيما بلغني-: أنّ الله -تبارك وتعالى- بعثه إلى أهل قرية أهل نِينَوى، وهي مِن بلاد الموصل{24}. (ز) ٣٤٩٥٩- قال مقاتل بن سليمان: <q>﴿فَلَوْلا كانَتْ قَرْيَةٌ آمَنَتْ فَنَفَعَها إيمانُها﴾</q> الإيمانُ عند نزول العذاب <q>﴿إلّا قَوْمَ يُونُسَ لَمّا آمَنُواْ﴾</q> يعني: صدَّقوا وتابوا، وذلك أنّ قوم يونس ﵇ لَمّا نظروا إلى العذاب فوق رءوسهم على قدر مِيل، وهم في قرية تُسَمّى: نِينَوى، مِن أرض الموصل؛ تابوا، فلبس المسوح بعضهم، ونَثَرُوا الرماد على رءوسهم، وعزلوا الأمهات مِن الأولاد والنساء مِن الزواج، ثم عَجُّوا إلى الله، فكشف اللهُ عنهم العذابَ{30}. (ز) ٣٤٩٦٠- قال يحيى بن سلّام: بلغني: أنّه كان بينهم وبين العذاب أربعة أميال{31}. (ز) ٣٤٩٦١- عن معروف الموصلي، قال: إنّ سحابةً غَشِيَتْهم تنضح عليهم شَرَر النار{23}. (ز) <q>﴿وَمَتَّعۡنَـٰهُمۡ إِلَىٰ حِینࣲ ۝٩٨﴾</q> - تفسير ٣٤٩٦٢- عن إسماعيل السُّدِّيّ -من طريق أسباط- يقول: <q>﴿فآمنوا فمتعناهم إلى حين﴾</q> [الصافات:١٤٨]، يقول: إلى أجلهم{33}٣١٦٤. (ز) ٣١٦٤ قال ابنُ كثير (٧/٤٠٣): «اختلف المفسرون: هل كشف عنهم العذاب الأخروي مع الدنيوي؟ أو إنما كشف عنهم في الدنيا فقط؟ على قولين: أحدهما: إنما كان ذلك في الحياة الدنيا، كما هو مقيد في هذه الآية. والقول الثاني: فيهما؛ لقوله تعالى: <q>﴿وأرسلناه إلى مائة ألف أو يزيدون فآمنوا فمتعناهم إلى حين﴾</q> [الصافات:١٤٧-١٤٨] فأطلق عليهم الإيمان، والإيمان مُنقِذ من العذاب الأخروي، وهذا هو الظاهر». ٣٤٩٦٣- قال مقاتل بن سليمان: <q>﴿ومَتَّعْناهُمْ إلى حِينٍ﴾</q> إلى منتهى آجالهم، فأخبِرهم -يا محمد- أنّ التوبة لا تنفعهم عند نزول العذاب{30}. (ز) <q>﴿وَمَتَّعۡنَـٰهُمۡ إِلَىٰ حِینࣲ ۝٩٨﴾</q> - آثار متعلقة بالآية ٣٤٩٦٤- عن عائشة، قالت: قال رسولُ ﷺ: «لا يُنجِي حَذَرٌ مِن قَدَر، وإنّ الدعاء يَدفعُ مِن البلاء، وقد قال اللهُ في كتابه: <q>﴿إلا قوم يونسَ لمّا ءامنوا كشفنا عنهم عذاب الخزي في الحياة الدنيا ومتعناهم إلى حين﴾</q>»{35}. (٧/٧١٠) ٣٤٩٦٥- عن عليّ بن أبي طالب -من طريق أبي علقمة الهاشمي- قال: إنّ الحَذَر لا يَرُدُّ القَدَر، وإنّ الدعاء يَرُدُّ القَدَر، وذلك في كتاب الله: <q>﴿إلّا قوم يُونُس لمّا آمنوا كشفنا عنهم عذاب الخزي﴾</q>{36}. (٧/٧٠٨) ٣٤٩٦٦- عن عبد الله بن عباس، قال: إنّ الدعاء لَيَرُدُّ القضاءَ وقد نزل مِن السماء، اقرءُوا إن شئتُم: <q>﴿إلا قومَ يونُس لمّا آمنوا﴾</q>، فدَعَوْا، صُرِف عنهم العذابُ{37}. (٧/٧٠٨) ",footnotes:1:أخرجه عبد الرزاق ١/٢٩٨، وابن جرير ١٢/٢٩٦ من قول معمر. وعزاه السيوطي إلى أبي الشيخ. وهي قراءة شاذة، تروى أيضًا عن أُبَيٍّ. انظر: الجامع لأحكام القرآن ١١/٥٣، والبحر المحيط ٥/١٩٢.أخرجه ابن جرير ١٢/٢٩٢-٢٩٣. وعزاه السيوطي إلى ابن المنذر، وأبي الشيخ.أخرجه ابن جرير ١٢/٢٩٣، وابن أبي حاتم ٦/١٩٨٧. وعزاه السيوطي إلى ابن المنذر.تفسير مجاهد ص٣٨٣، وأخرجه ابن جرير ١٢/٢٩٣.عزاه السيوطي إلى ابن أبي حاتم.عزاه السيوطي إلى ابن أبي حاتم.تفسير مقاتل بن سليمان ٢/٢٤٩.عزاه السيوطي إلى ابن مردويه.أخرجه الشهاب القضاعي في مسنده ٢/٤٩ (٨٦٠) مطولًا، من طريق الحكم بن مروان بن الضرير، ثنا محمد بن عبد الله، عن أبيه، عن القاسم، عن عائشة به. وعزاه السيوطي إلى ابن مردويه. إسناده حسن.أخرجه ابن جرير ١٢/٢٩٦.نِينَوى: بكسر أوله، وسكون ثانيه، وفتح النون والواو. وهي قرية يونس بن متّى ﵇ بالموصل. معجم البلدان ٥/٣٣٩.تفسير الثعلبي ٥/١٥٢.أخرجه ابن أبي حاتم ٦/١٩٨٨.أخرجه ابن جرير ١٢/٢٩٤. وعزاه السيوطي إلى أحمد في الزهد.عزاه السيوطي إلى أبي الشيخ.أخرجه ابن أبي حاتم ٦/١٩٨٨-١٩٨٩.أخرجه أحمد ص٣٤، وابن جرير ١٢/٢٩٦، وابن أبي حاتم ٦/١٩٨٩. وعزاه السيوطي إلى أحمد في الزهد، وابن المنذر.أخرجه ابن جرير ١٢/٢٩٣-٢٩٤، وابن أبي حاتم ٦/١٩٨٩. وعزاه السيوطي إلى أحمد في الزهد، وابن المنذر، وأبي الشيخ.أخرجه ابن جرير ١٢/٢٩٥-٢٩٦.تفسير الثعلبي ٥/١٥٢، وتفسير البغوي ٤/١٥١-١٥٢.أخرجه ابن جرير ١٢/٢٩٣، وابن أبي حاتم ٦/١٩٨٨. وذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٢/٢٧٣- بنحوه. وعزاه السيوطي إلى ابن المنذر، وأبي الشيخ.أخرجه عبد الرزاق ١/٢٩٨، وابن جرير ١٢/٢٩٣. وعزاه السيوطي إلى أحمد في الزهد.أخرجه ابن أبي حاتم ٦/١٩٨٩.أخرجه ابن أبي حاتم ٦/١٩٨٧.أخرجه ابن أبي حاتم ٦/١٩٨٧.أخرجه ابن جرير ١٢/٢٩٥.أخرجه ابن أبي حاتم ٦/١٩٨٨.أخرجه ابن جرير ١٢/٢٩٤.أخرجه ابن أبي حاتم ٦/١٩٨٧.تفسير مقاتل بن سليمان ٢/٢٥٠.تفسير ابن أبي زمنين ٢/٢٧٤.أخرجه ابن أبي حاتم ٦/١٩٨٩.أخرجه ابن أبي حاتم ٦/١٩٩٠.تفسير مقاتل بن سليمان ٢/٢٥٠.أخرجه الشهاب القضاعي في مسنده ٢/٤٩ (٨٦٠) بلفظ: «ينفع من البلاء». وعزاه السيوطي إلى ابن النجار.أخرجه ابن أبي حاتم ٦/١٩٨٧، واللالكائي في السنة (١٢١٢).عزاه السيوطي إلى ابن المنذر، وأبي الشيخ.
10,99," <q>﴿وَلَوۡ شَاۤءَ رَبُّكَ لَـَٔامَنَ مَن فِی ٱلۡأَرۡضِ كُلُّهُمۡ جَمِیعًاۚ أَفَأَنتَ تُكۡرِهُ ٱلنَّاسَ حَتَّىٰ یَكُونُوا۟ مُؤۡمِنِینَ ۝٩٩﴾</q> - تفسير ٣٤٩٦٧- عن عبد الله بن عباس -من طريق علي- قوله: <q>﴿ولو شاء ربك لآمن من في الأرض كلهم جميعا﴾</q>، <q>﴿وما كان لنفس أن تؤمن إلا بإذن الله﴾</q>، ونحو هذا في القرآن، فإنّ رسول الله ﷺ كان يحرص أن يؤمن جميعُ الناس، ويتابعوه على الهدى، فأخبره اللهُ أنّه لا يؤمن مِن قومه إلا مَن قد سبق له مِن الله السعادةُ في الذِّكْرِ الأول، ولا يَضِلُّ إلا مَن سَبَقَ له مِن الله الشقاءُ في الذِّكر الأول{1}٣١٦٥. (ز) ٣١٦٥ ذكر ابنُ عطية (٤/٥٣٠-٥٣١) أنّ معنى الآية: أنّ هذا الذي تَقَدَّم إنّما كان جميعه بقضاء الله عليهم ومشيئته فيهم، ولو شاء الله لكان الجميع مؤمنًا، فلا تأسف أنت -يا محمد- على كُفْرِ مَن لم يؤمن بك، وادعُ ولا عليك، فالأمرُ محتوم، أفتريد أنت أن تُكْرِه الناس بإدخال الإيمان في قلوبهم وتضطرهم إلى ذلك والله ﷿ قد شاء غيره. ثم علَّق بقوله: «فهذا التأويل الآيةُ عليه محكمة، أي: ادعُ وقاتِل مَن خالفك، وإيمان مَن آمن مصروف إلى المشيئة». وذكر أنّ فرقة قالت: المعنى: أفأنت تكره الناس بالقتال حتى يدخلوا في الإيمان. وزَعَمَتْ أنّ هذه الآية في صدر الإسلام، وأنها منسوخة بآية السيف، ثم علَّق بقوله: «والآية -على كلا التأويلين- رادَّةٌ على المعتزلة». <q>﴿وَلَوۡ شَاۤءَ رَبُّكَ لَـَٔامَنَ مَن فِی ٱلۡأَرۡضِ كُلُّهُمۡ جَمِیعًاۚ أَفَأَنتَ تُكۡرِهُ ٱلنَّاسَ حَتَّىٰ یَكُونُوا۟ مُؤۡمِنِینَ ۝٩٩﴾</q> - النسخ في الآية ٣٤٩٦٨- قال مقاتل بن سليمان: <q>﴿ولَوْ شاءَ رَبُّكَ لَآمَنَ مَن فِي الأَرْضِ كُلُّهُمْ جَمِيعًا أفَأَنْتَ تُكْرِهُ النّاسَ حَتّى يَكُونُوا مُؤْمِنِينَ﴾</q>، هذا منسوخ، نَسَخَتْها آيةُ السيف في براءة{2}. (ز) ",footnotes:1:أخرجه ابن جرير ١٢/٢٩٨.تفسير مقاتل بن سليمان ٢/٢٥٠.
10,100," <q>﴿وَمَا كَانَ لِنَفۡسٍ أَن تُؤۡمِنَ إِلَّا بِإِذۡنِ ٱللَّهِۚ﴾</q> - تفسير ٣٤٩٦٩- عن عبد الله بن عباس: <q>﴿إلّا بِإذْنِ اللَّهِ﴾</q> بأمر الله{1}. (ز) ٣٤٩٧٠- عن عطاء: <q>﴿إلّا بِإذْنِ اللَّهِ﴾</q> بمشيئة الله{1}. (ز) ٣٤٩٧١- عن سفيان الثوري -من طريق ابن المبارك- في قوله: <q>﴿وما كان لنفس أن تؤمن إلا بإذن الله﴾</q>، قال: بقضاء الله{3}. (ز) ٣٤٩٧٢- قال مقاتل بن سليمان: <q>﴿وما كانَ لِنَفْسٍ أنْ تُؤْمِنَ إلّا بِإذْنِ اللَّهِ﴾</q>، يعني: أن تُصَدِّق بتوحيد الله حتى يأذن الله في ذلك{4}. (ز) <q>﴿وَیَجۡعَلُ ٱلرِّجۡسَ عَلَى ٱلَّذِینَ لَا یَعۡقِلُونَ ۝١٠٠﴾</q> - تفسير ٣٤٩٧٣- عن عبد الله بن عباس -من طريق علي- في قوله: <q>﴿ويجعل الرِّجس﴾</q>، قال: السَّخَطَ{5}. (٧/٧١١) ٣٤٩٧٤- عن سعيد بن جبير -من طريق عطاء بن دينار- قوله: <q>﴿الرجس﴾</q>، يعني: إثمًا{6}. (ز) ٣٤٩٧٥- عن مجاهد بن جبر -من طريق ابن أبي نجيح- <q>﴿الرجس﴾</q>: ما لا خير فيه{6}. (ز) ٣٤٩٧٦- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿ويجعلُ الرجسَ﴾</q>، قال: الرجسُ: الشيطانُ. والرجسُ: العذابُ{8}. (٧/٧١١) ٣٤٩٧٧- قال مقاتل بن سليمان: <q>﴿ويَجْعَلُ الرِّجْسَ﴾</q> يعني: الإثم <q>﴿عَلى الَّذِينَ لا يَعْقِلُونَ﴾</q>{4}. (ز) ",footnotes:1:تفسير الثعلبي ٥/١٥٣، وتفسير البغوي ٤/١٥٣.تفسير الثعلبي ٥/١٥٣، وتفسير البغوي ٤/١٥٣.أخرجه ابن جرير ١٢/٣٠٠.تفسير مقاتل بن سليمان ٢/٢٥٠.أخرجه ابن جرير ١٢/٣٠٠، وابن أبي حاتم ٦/١٩٩٠.أخرجه ابن أبي حاتم ٦/١٩٩٠.أخرجه ابن أبي حاتم ٦/١٩٩٠.أخرجه ابن أبي حاتم ٦/١٩٩٠ بنحوه. وعزاه السيوطي إلى أبي الشيخ.تفسير مقاتل بن سليمان ٢/٢٥٠.
10,101," <q>﴿قُلِ ٱنظُرُوا۟ مَاذَا فِی ٱلسَّمَـٰوَ ٰ⁠تِ وَٱلۡأَرۡضِۚ وَمَا تُغۡنِی ٱلۡـَٔایَـٰتُ وَٱلنُّذُرُ عَن قَوۡمࣲ لَّا یُؤۡمِنُونَ ۝١٠١﴾</q> - تفسير ٣٤٩٧٨- عن مجاهد بن جبر -من طريق ابن أبي نجيح- قوله: <q>﴿لا يؤمنون﴾</q> قال: أوجب عليهم أنهم لا يؤمنون{1}٣١٦٦. (ز) ٣١٦٦ ذكر ابنُ عطية (٤/٥٣١-٥٣٢) أنّ الله أعْلَمَ في آخر هذه الآية أنّ النظر في الآيات والسماع مِن النذر -وهم الأنبياء- لا يُغْنِي إلا بمشيئة الله، وأنّ ذلك غير نافع لقوم قد قضى الله أنهم لا يؤمنون، ثم علَّق بقوله: «وهذا على أن تكون»ما«نافية». ثم بيَّن أنه يجوز أن يُعَدَّ استفهامًا على جهة التقرير الذي في ضمنه نفي وقوع الغناء، ويكون في الآية -على هذا- توبيخٌ لحاضري رسول الله ﷺ من المشركين. ثم قال: «ويحتمل أن تكون»ما«في قوله: <q>﴿وما تغني﴾</q> مفعولة بقوله: <q>﴿انظروا﴾</q>، معطوفة على قوله: <q>﴿ماذا﴾</q>، أي: تأملوا قدر غناء الآيات والنذر عن الكفار إذا قبِلوا ذلك كفعل قوم يونس فإنّه يرفع بالعذاب في الدنيا والآخرة، وينجي من الهلكات، فالآية على هذا تحريض على الإيمان». وبيَّن أنّ تجوز اللفظ -على هذا التأويل- إنّما هو في قوله: <q>﴿لا يؤمنون﴾</q>. ٣٤٩٧٩- قال مقاتل بن سليمان: <q>﴿قُلِ انْظُرُوا ماذا فِي السَّماواتِ﴾</q> يعني: الشمس، والقمر، والنجوم، والسحاب، والمطر، <q>﴿والأَرْضِ﴾</q> والجبال، والأشجار، والأنهار، والثمار، والعيون. ثُمَّ أخبر عن علمه فيهم، فقال: <q>﴿وما تُغْنِي الآياتُ﴾</q> يعنى: العلامات <q>﴿والنُّذُرُ﴾</q> يعني: الرسل <q>﴿عَنْ قَوْمٍ لا يُؤْمِنُونَ﴾</q>{2}. (ز) <q>﴿قُلِ ٱنظُرُوا۟ مَاذَا فِی ٱلسَّمَـٰوَ ٰ⁠تِ وَٱلۡأَرۡضِۚ وَمَا تُغۡنِی ٱلۡـَٔایَـٰتُ وَٱلنُّذُرُ عَن قَوۡمࣲ لَّا یُؤۡمِنُونَ ۝١٠١﴾</q> - النسخ في الآية ٣٤٩٨٠- عن إسماعيل السُّدِّيّ: <q>﴿وما تُغني الآياتُ والنُّذُرُ عن قومٍ﴾</q>، يقولُ: عند قوم لا يؤمنون، نسختْ قولَه: <q>﴿حكمةٌ بالغةٌ فما تُغْنِ النُّذُرُ﴾</q> [القمر:٥]{3}. (٧/٧١١) ",footnotes:1:أخرجه ابن أبي حاتم ٦/١٩٩١. وأخرجه قبل ذلك في تفسير قوله تعالى: <q>﴿وما يُشْعِرُكُمْ أنَّها إذا جاءَتْ لا يُؤْمِنُونَ﴾</q> [الأنعام: ١٠٩].تفسير مقاتل بن سليمان ٢/٢٥٠-٢٥١.عزاه السيوطي إلى أبي الشيخ.
10,102," <q>﴿فَهَلۡ یَنتَظِرُونَ إِلَّا مِثۡلَ أَیَّامِ ٱلَّذِینَ خَلَوۡا۟ مِن قَبۡلِهِمۡۚ قُلۡ فَٱنتَظِرُوۤا۟ إِنِّی مَعَكُم مِّنَ ٱلۡمُنتَظِرِینَ ۝١٠٢ ثُمَّ نُنَجِّی رُسُلَنَا وَٱلَّذِینَ ءَامَنُوا۟ۚ كَذَ ٰ⁠لِكَ حَقًّا عَلَیۡنَا نُنجِ ٱلۡمُؤۡمِنِینَ ۝١٠٣﴾</q> - تفسير ٣٤٩٨١- عن قتادة بن دعامة -من طريق سعيد- <q>﴿فهل ينتظرُون إلّا مثل أيّام الذين خلوْا من قبلهمْ﴾</q>، قال: وقائع الله في الذين خَلوْا من قبلهم؛ قوم نوحٍ، وعادٍ، وثمودَ{1}. (٧/٧١١) ٣٤٩٨٢- عن الرَّبيع بن أنس -من طريق أبي جعفر- في قوله: <q>﴿فهل ينتظرُون إلّا مثل أيّام الذين خلوْا من قبلهم قُلْ فانتظروا إني معكُم من المُنتظرين﴾</q>، قال: خوَّفهم الله عذابَه ونقمتَه وعقوبتَه، ثم أخبرهم أنّه إذا وقع مِن ذلك أمرٌ نجّى الله رسلَه والذين آمنوا، فقال: <q>﴿ثمَّ ننجي رُسلنا والذين آمنوا﴾</q> الآية{2}. (٧/٧١٢) ٣٤٩٨٣- قال مقاتل بن سليمان: <q>﴿فَهَلْ يَنْتَظِرُونَ إلّا مِثْلَ أيّامِ الَّذِينَ خَلَوْا مِن قَبْلِهِمْ﴾</q> يعني: قوم نوح، وعاد، وثمود، والقرون المعذبة، <q>﴿قُلْ فانْتَظِرُواْ﴾</q> الموتَ؛ <q>﴿إنِّي مَعَكُمْ مِنَ المُنْتَظِرِينَ﴾</q> بكم العذاب، <q>﴿ثُمَّ نُنَجِّي رُسُلَنا والَّذِينَ آمَنُواْ﴾</q> معهم، <q>﴿كَذلِكَ﴾</q> يعني: هكذا <q>﴿حَقًّا عَلَيْنا نُنْجِ المُؤْمِنِينَ﴾</q> في الآخرة مِن النار، وفي الدنيا بالظَّفَر{3}. (ز) ",footnotes:1:أخرجه ابن جرير ١٢/٣٠٢، وابن أبي حاتم ٦/١٩٩١. وعزاه السيوطي إلى أبي الشيخ.أخرجه ابن جرير ١٢/٣٠٢. وعزاه السيوطي إلى أبي الشيخ.تفسير مقاتل بن سليمان ٢/٢٥١.
  10,103,""
10,104," <q>﴿قُلۡ یَـٰۤأَیُّهَا ٱلنَّاسُ إِن كُنتُمۡ فِی شَكࣲّ مِّن دِینِی فَلَاۤ أَعۡبُدُ ٱلَّذِینَ تَعۡبُدُونَ مِن دُونِ ٱللَّهِ وَلَـٰكِنۡ أَعۡبُدُ ٱللَّهَ ٱلَّذِی یَتَوَفَّىٰكُمۡۖ وَأُمِرۡتُ أَنۡ أَكُونَ مِنَ ٱلۡمُؤۡمِنِینَ ۝١٠٤﴾</q> - تفسير ٣٤٩٨٤- قال مقاتل بن سليمان: <q>﴿قُلْ يا أيُّها النّاسُ إنْ كُنْتُمْ فِي شَكٍّ مِن دِينِي﴾</q> الإسلام، <q>﴿فَلا أعْبُدُ الَّذِينَ تَعْبُدُونَ مِن دُونِ اللَّهِ﴾</q> مِن الآلهة، <q>﴿ولكِنْ أعْبُدُ اللَّهَ﴾</q> يعني: أُوَحِّدُ الله <q>﴿الَّذِي يَتَوَفّاكُمْ وأُمِرْتُ أنْ أكُونَ مِنَ المُؤْمِنِينَ﴾</q> يعني: المُصَدِّقين{1}. (ز) ",footnotes:1:تفسير مقاتل بن سليمان ٢/٢٥١.
10,105," <q>﴿وَأَنۡ أَقِمۡ وَجۡهَكَ لِلدِّینِ حَنِیفࣰا وَلَا تَكُونَنَّ مِنَ ٱلۡمُشۡرِكِینَ ۝١٠٥﴾</q> - تفسير ٣٤٩٨٥- عن عبد الله بن عباس: <q>﴿وأَنْ أقِمْ وجْهَكَ لِلدِّينِ حَنِيفًا﴾</q>، يعني: عملك{1}. (ز) ٣٤٩٨٦- قال مقاتل بن سليمان: <q>﴿وأَنْ أقِمْ وجْهَكَ لِلدِّينِ حَنِيفًا﴾</q> يعني: مُخْلِصًا، <q>﴿ولا تَكُونَنَّ مِنَ المُشْرِكِينَ﴾</q> بالله{2}٣١٦٧. (ز) ٣١٦٧ قال ابن عطية (٤/٥٣٣): «و<q>﴿حنيفا﴾</q> معناه: مستقيمًا على قول مَن قال: الحنف: الاستقامة. وجَعَل تسمية المعوج القدم: أحنف، على جهة التفاؤل. ومن قال: الحنف: الميل. جعل <q>﴿حنيفا﴾</q> هاهنا: مائلًا عن حال الكَفَرة وطريقهم». ",footnotes:1:تفسير البغوي ٤/١٥٤.تفسير مقاتل بن سليمان ٢/٢٥١.
10,106," <q>﴿وَلَا تَدۡعُ مِن دُونِ ٱللَّهِ مَا لَا یَنفَعُكَ وَلَا یَضُرُّكَۖ فَإِن فَعَلۡتَ فَإِنَّكَ إِذࣰا مِّنَ ٱلظَّـٰلِمِینَ ۝١٠٦﴾</q> - تفسير ٣٤٩٨٧- قال مقاتل بن سليمان: <q>﴿ولا تَدْعُ مِن دُونِ اللَّهِ﴾</q> يعني: ولا تعبد مع الله إلهًا غيره <q>﴿ما لا يَنْفَعُكَ﴾</q> يقول: ما إن احْتَجْتَ إليه لم ينفعك، <q>﴿ولا يَضُرُّكَ﴾</q> يعني: فإن تركت عبادته في الدنيا لا يَضُرُّك وإن لم تعبده، <q>﴿فَإنْ فَعَلْتَ﴾</q> فعبدت غيرَ الله <q>﴿فَإنَّكَ إذًا مِنَ الظّالِمِينَ﴾</q> يعنى: من المشركين{1}. (ز) ٣٤٩٨٨- عن مقاتل بن حيان -من طريق بُكَيْر بن معروف- قوله: <q>﴿الظالمين﴾</q>، يعني: المشركين{2}. (ز) ",footnotes:1:تفسير مقاتل بن سليمان ٢/٢٥١.أخرجه ابن أبي حاتم ٦/١٩٩٢.
