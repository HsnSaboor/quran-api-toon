quran[27]{c,v,t}:
  83,35,""
  83,36,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿هَلۡ ثُوِّبَ ٱلۡكُفَّارُ مَا كَانُوا۟ یَفۡعَلُونَ ۝٣٦﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٨٢١٧٥<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿هَلْ ثُوِّبَ﴾</span>، قال: جُوزِيَ{1}. (١٥/٣١٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢١٧٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿هَلْ ثُوِّبَ الكُفّارُ ما كانُوا يَفْعَلُونَ﴾</span>، يعني: ينظرون مِن الكُوى، فإذا رأوهم يُعذَّبون قالوا: واللهِ، قد ثُوِّب الكفار ما كانوا يفعلون{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢١٧٧<span class="dash">-</span></span> عن <span class="name-3">سفيان [الثوري]</span> -من طريق مهران- <span class="qpc-hafs">﴿هَلْ ثُوِّبَ الكُفّارُ ما كانُوا يَفْعَلُونَ﴾</span>: حين كانوا يسخرون{3}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير مجاهد ص٧١٣، وأخرجه ابن جرير ٢٤/٢٢٩. وعزاه السيوطي إلى الفريابي، وعبد بن حميد، وابن المنذر.|2:تفسير مقاتل بن سليمان ٤/٦٢٦.|3:أخرجه ابن جرير ٢٤/٢٢٩.
  84,1,"<div class=ar lang=ar><p><h3>مقدمة السورة</h3></p><p><div></p><p><p><span class="item-no">٨٢١٧٨<span class="dash">-</span></span> عن عبد الله بن عباس -من طريق مجاهد- قال: نزلت سورة الانشقاق بمكة{1}. (١٥/٣١٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢١٧٩<span class="dash">-</span></span> عن عبد الله بن الزُّبير، مثله{2}. (١٥/٣١٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢١٨٠<span class="dash">-</span></span> عن عبد الله بن عباس -من طريق عطاء الخُراسانيّ-: مكّيّة، وسمّاها: <span class="qpc-hafs">﴿إذا السَّماءُ انْشَقَّتْ﴾</span>، وذكر أنها نزلت بعد <span class="qpc-hafs">﴿إذا السَّماءُ انْفَطَرَتْ﴾</span>{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢١٨١<span class="dash">-</span></span> عن عكرمة مولى ابن عباس= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢١٨٢<span class="dash">-</span></span> والحسن البصري -من طريق يزيد النحوي-: مكّيّة، وسمّياها: <span class="qpc-hafs">﴿إذا السَّماءُ انْشَقَّتْ﴾</span>{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢١٨٣<span class="dash">-</span></span> عن قتادة بن دعامة -من طرق-: مكّيّة{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢١٨٤<span class="dash">-</span></span> عن محمد بن مسلم الزُّهريّ: مكّيّة، ونزلت بعد سورة الانفطار{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢١٨٥<span class="dash">-</span></span> عن علي بن أبي طلحة: مكّيّة{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢١٨٦<span class="dash">-</span></span> قال مقاتل بن سليمان: سورة الانشقاق مكّيّة، عددها خمس وعشرون آية كوفي{8}<span class=comment-ref>٧٠٩١</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٧٠٩١</span> قال <u>ابنُ عطية</u> (٨/٥٦٧): «وهي مكّيّة <span class="mustanad">بلا خلاف بين المتأولين</span>».</div></p><p><div></p><p><p><span class="item-no">٨٢١٨٧<span class="dash">-</span></span> عن ابن عمر، قال: قال رسول الله ﷺ: «<b>مَن سَرَّه أن ينظر إلى يوم القيامة كأنه رأي عين فليقرأ: <span class="qpc-hafs">﴿إذا الشَّمْسُ كُوِّرَتْ﴾</span>، و<span class="qpc-hafs">﴿إذا السَّماءُ انْفَطَرَتْ﴾</span>، و<span class="qpc-hafs">﴿إذا السَّماءُ انْشَقَّتْ﴾</span></b>»{9}. (١٥/٢٥٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢١٨٨<span class="dash">-</span></span> عن صفوان بن عَسّال: أنّ رسول الله ﷺ سجد في: <span class="qpc-hafs">﴿إذا السَّماءُ انْشَقَّتْ﴾</span>{10}. (١٥/٣١٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢١٨٩<span class="dash">-</span></span> عن أبي هريرة، قال: سجدنا مع رسول الله ﷺ في: <span class="qpc-hafs">﴿إذا السَّماءُ انْشَقَّتْ﴾</span>، و<span class="qpc-hafs">﴿اقْرَأْ بِاسْمِ رَبِّكَ﴾</span>{11}. (١٥/٣١٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢١٩٠<span class="dash">-</span></span> عن أبي هريرة -من طريق ابن سيرين- قال: إنّ رجلين اقترآ بـ<span class="qpc-hafs">﴿إذا السَّماءُ انْشَقَّتْ﴾</span>، و<span class="qpc-hafs">﴿اقْرَأْ بِاسْمِ رَبِّكَ﴾</span> .... قال: فسجد أحدهما، ولم يسجد الآخر. قال: الذي سجد أفضلهما أو خيرهما. قال ابن سيرين: إن لم يكن النبي ﵇ وعمر فلا أدري مَن هُما{12}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢١٩١<span class="dash">-</span></span> عن أبي رافع، قال: صلّيتُ مع أبي هريرة العَتمة، فقرأ: <span class="qpc-hafs">﴿إذا السَّماءُ انْشَقَّتْ﴾</span> فسجد، فقلت له، فقال: سجدتُ خلف أبي القاسم ﷺ، فلا أزال أسجد فيها حتى ألقاه{13}. (١٥/٣١٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢١٩٢<span class="dash">-</span></span> عن زرّ، قال: قرأ <span class="name-1">عمّار</span> على المنبر: <span class="qpc-hafs">﴿إذا السماء انشقت﴾</span>، فنزل فسجد{14}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢١٩٣<span class="dash">-</span></span> عن أبي بشر أنه رأى <span class="name-2">عمر بن عبد العزيز</span> صلّى العشاء، فقرأ فيها بـ<span class="qpc-hafs">﴿إذا السَّماءُ انْشَقَّتْ﴾</span>، فسجد فيها، وقرأها مرة أخرى، فلم يسجد.= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢١٩٤<span class="dash">-</span></span> قال: وحدَّثني معاوية بن صالح، عن أبي الزّاهرية، عن جبير بن نفير، عن <span class="name-1">أبي الدّرداء</span> أنه كان مرة يسجد في: <span class="qpc-hafs">﴿إذا السَّماءُ انْشَقَّتْ﴾</span>، ومرة لا يسجد فيها{15}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿إِذَا ٱلسَّمَاۤءُ ٱنشَقَّتۡ ۝١﴾</span> - نزول الآية</h3></p><p><div></p><p><p><span class="item-no">٨٢١٩٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: وذلك أنّ أخوين مِن بني أُميّة -أحدهما اسمه: عبد الله بن عبد الأسد، والآخر اسمه: الأسود بن عبد الأسد-؛ أحدهما مؤمن بالله واسمه عبد الله، وأما الآخر فاسمه الأسود وهو الكافر، فقال لأخيه عبد الله: آمنتُ بمحمد؟ قال: نعم. قال: ويحك! إنّ محمدًا يزعم إذا مِتنا وكُنّا ترابًا فإنّا لمبعوثون في الآخرة، ويزعم أنّ الدنيا تنقطع، فأخبرني ما حال الأرض يومئذ؟ فأنزل الله ﷿: <span class="qpc-hafs">﴿إذا السَّماءُ انْشَقَّتْ﴾</span>{16}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿إِذَا ٱلسَّمَاۤءُ ٱنشَقَّتۡ ۝١﴾</span> - تفسير الآية</h3></p><p><div></p><p><p><span class="item-no">٨٢١٩٦<span class="dash">-</span></span> عن <span class="name-1">علي بن أبي طالب</span>، في قوله: <span class="qpc-hafs">﴿إذا السَّماءُ انْشَقَّتْ﴾</span>، قال: تنشق السماء مِن المجَرَّة{17}. (١٥/٣١٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢١٩٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿إذا السَّماءُ انْشَقَّتْ﴾</span> انشقّتْ لنزول ربّ العزة والملائكة، فإنها تنشق حتى يُرى طرفاها، ثم تُرى خَلْقًا باليًا{16}<span class=comment-ref>٧٠٩٢</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٧٠٩٢</span> قال <u>ابنُ عطية</u> (٨/٥٦٧): «وانشقاق السماء: هو تفطّرها لهول يوم القيامة، <span class="mustanad">كما قال تعالى</span>: <span class="qpc-hafs">﴿وانْشَقَّتِ السَّماءُ فَهِيَ يَوْمَئِذٍ واهِيَةٌ﴾</span> [الحاقة:١٦]، <b>وقال</b> الفراء والزَّجّاج وغيرهما: هو تشقّقها بالغمام. <b>وقال قوم</b>: تشقّقها: تفتُّحها أبوابًا لِنُزول الملائكة وصعودهم في هول يوم القيامة».</div></p></div>",footnotes:1:أخرجه أبو جعفر النحاس في الناسخ والمنسوخ ص٧٥٧ من طريق أبي عمرو بن العلاء عن مجاهد، والبيهقي في دلائل النبوة ٧/١٤٢-١٤٤ من طريق خُصَيف عن مجاهد. وعزاه السيوطي إلى ابن مردويه.|2:عزاه السيوطي إلى ابن مردويه.|3:أخرجه ابن الضريس في فضائل القرآن ١/٣٣-٣٥.|4:أخرجه البيهقي في دلائل النبوة ٧/١٤٢-١٤٣.|5:أخرجه الحارث المحاسبي في فهم القرآن ص٣٩٥-٣٩٦ من طريق سعيد، وأبو بكر ابن الأنباري -كما في الإتقان ١/٥٧- من طريق همام.|6:تنزيل القرآن ص٣٧-٤٢.|7:أخرجه أبو عبيد في فضائله (ت: الخياطي) ٢/٢٠٠.|8:تفسير مقاتل بن سليمان ٤/٦٣١.|9:تقدم تخريجه في مقدمة سورة التكوير.|10:أخرجه الطبراني في الكبير ٨/٦٨ (٧٣٩٣)، وابن نصر في فوائده ص١٠٦، ١٠٧ (١١٣، ١١٤)، من طريق يحيى بن عقبة بن أبي العيزار، عن إدريس الأودي، وابن أبي ليلى، عن عاصم بن أبي النجود، عن زِرّ بن حُبيش، عن صفوان بن عَسّال به.</p><p>قال ابن أبي حاتم في علل الحديث ٢/٥٢٢ (٥٦١): «قال أبو زرعة: هذا حديث منكر خطأ». وقال البغوي في معجم الصحابة ٣/٣٤٢ (١٢٨٣): «وهذا حديث غريب، لا أعلم رواه غير يحيى بن عقبة، وهو ضعيف الحديث». وقال الهيثمي في المجمع ٢/٢٨٦ (٣٧٠٥): «فيه يحيى بن عقبة بن أبي العيزار، وهو ضعيف جدًّا».|11:أخرجه مسلم ١/٤٠٦ (٥٧٨).|12:أخرجه عبد الله بن وهب في الجامع -تفسير القرآن ٣/٩٩ (٢٢٤).|13:أخرجه البخاري (٧٦٦، ٧٦٨، ١٠٧٨)، ومسلم (٥٧٨/١١٠). وعزاه السيوطي إلى ابن مردويه.|14:أخرجه سعيد بن منصور في سننه -التفسير ٨/٣٠٧ (٢٤٣٥).|15:أخرجه عبد الله بن وهب في الجامع -تفسير القرآن٣/٩٧-٩٨ (٢١٩).|16:تفسير مقاتل بن سليمان ٤/٦٣٣.|17:عزاه السيوطي إلى ابن أبي حاتم.|18:تفسير مقاتل بن سليمان ٤/٦٣٣.
  84,2,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَأَذِنَتۡ لِرَبِّهَا﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٨٢١٩٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، في قوله: <span class="qpc-hafs">﴿وأَذِنَتْ﴾</span>، قال: أطاعتْ{1}. (١٥/٣١٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢١٩٩<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، في قوله: <span class="qpc-hafs">﴿وأَذِنَتْ لِرَبِّها﴾</span>، قال: سمعتْ حين كلَّمها{2}. (١٥/٣١٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٢٠٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق مجاهد- في قوله: <span class="qpc-hafs">﴿وأَذِنَتْ لِرَبِّها وحُقَّتْ﴾</span>، قال: سَمِعَتْ، وأطاعتْ{3}. (١٥/٣١٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٢٠١<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جُبَير</span> -من طريق جعفر- في قوله: <span class="qpc-hafs">﴿وأَذِنَتْ لِرَبِّها﴾</span>، قال: سَمِعَتْ، وأطاعتْ{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٢٠٢<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿وأَذِنَتْ لِرَبِّها﴾</span>، قال: سَمِعَتْ{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٢٠٣<span class="dash">-</span></span> عن <span class="name-2">الضَّحّاك بن مُزاحِم</span> -من طريق عبيد- في قوله: <span class="qpc-hafs">﴿وأَذِنَتْ لِرَبِّها﴾</span>، قال: سَمِعَتْ، وأطاعتْ{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٢٠٤<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- <span class="qpc-hafs">﴿وأَذِنَتْ لِرَبِّها وحُقَّتْ﴾</span>، قال: سَمِعَتْ، وأطاعتْ{7}. (١٥/٣١٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٢٠٥<span class="dash">-</span></span> عن <span class="name-2">حبيب بن أبي ثابت</span> -من طريق معروف بن واصل- في قوله: <span class="qpc-hafs">﴿وأذنت لربها وحقت﴾</span>: سَمِعَتْ{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٢٠٦<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span>، في قوله: <span class="qpc-hafs">﴿وأَذِنَتْ لِرَبِّها وحُقَّتْ﴾</span>، قال: أطاعتْ، وحُقَّ لها أن تطيع{9}. (١٥/٣١٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٢٠٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وأَذِنَتْ لِرَبِّها﴾</span> انشقّتْ، وسَمِعَتْ لربّها، وأطاعتْ{10}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَحُقَّتۡ ۝٢﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٨٢٢٠٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، <span class="qpc-hafs">﴿وحُقَّتْ﴾</span>، قال: حُقّتْ بالطاعة{11}<span class=comment-ref>٧٠٩٣</span>. (١٥/٣١٤)</p></p><p></div></p><p><div><span class=comment-ref>٧٠٩٣</span> ذكر <u>ابنُ عطية</u> (٨/٥٦٨) قول ابن عباس، ثم <span class="comment-type-4">ذكر</span> احتمالًا آخر، فقال: «و<b>يحتمل</b> أن يريد: وحُق لها أن تنشق لشدة الهول وخوف الله تعالى».</div></p><p><div></p><p><p><span class="item-no">٨٢٢٠٩<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جُبَير</span> -من طريق جعفر- <span class="qpc-hafs">﴿وحُقَّتْ﴾</span>: وحُقَّ لها{12}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٢١٠<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿وحُقَّتْ﴾</span>، يقول: حُقَّ لها أن تفعل{13}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٢١١<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span>، في قوله: <span class="qpc-hafs">﴿وأَذِنَتْ لِرَبِّها وحُقَّتْ﴾</span>، قال: أطاعتْ، وحُقَّ لها أن تطيع{9}. (١٥/٣١٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٢١٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وحُقَّتْ﴾</span> وكان يحقّ لها ذلك{10}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن أبي حاتم -كما في فتح الباري ٦/٢٩٤-.|2:عزاه السيوطي إلى ابن المنذر. وأخرجه ابن جرير ٢٤/٢٣١ من طريق عطية العَوفيّ بلفظ: سمعت لربها.|3:أخرجه الحاكم ٢/٥١٨.|4:أخرجه ابن جرير ٢٤/٢٣١.|5:تفسير مجاهد ص٧١٤، وأخرجه ابن جرير ٢٤/٢٣١.|6:أخرجه ابن جرير ٢٤/٢٣١.|7:أخرجه عبد الرزاق ٣/٣٥٨، وابن جرير ٢٤/٢٣١، ومن طريق سعيد أيضًا. وعزاه السيوطي إلى عبد بن حميد.|8:أخرجه سعيد بن منصور في سننه -التفسير ٨/٢٩١ (٢٤٢٦).|9:عزاه السيوطي إلى ابن المنذر.|10:تفسير مقاتل بن سليمان ٤/٦٣٣.|11:أخرجه ابن جرير ٢٤/٢٣٢ بنحوه، وابن أبي حاتم -كما في فتح الباري ٦/٢٩٤-.|12:أخرجه ابن جرير ٢٤/٢٣٢.|13:تفسير مجاهد ص٧١٤.|14:عزاه السيوطي إلى ابن المنذر.|15:تفسير مقاتل بن سليمان ٤/٦٣٣.
  84,3,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَإِذَا ٱلۡأَرۡضُ مُدَّتۡ ۝٣ وَأَلۡقَتۡ مَا فِیهَا وَتَخَلَّتۡ ۝٤ وَأَذِنَتۡ لِرَبِّهَا وَحُقَّتۡ ۝٥﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٨٢٢١٣<span class="dash">-</span></span> عن عبد الله بن عمر، عن النبي ﷺ، في قوله: <span class="qpc-hafs">﴿إذا السَّماءُ انْشَقَّتْ﴾</span> الآية، قال: «<b>أنا أول مَن تنشق عنه الأرض يوم القيامة، فأجلس جالسًا في قبري، وإنّ الأرض تحركتْ بي، فقلت لها: ما لكِ؟ فقالت: إنّ ربي أمرني أنْ أُلقي ما في جوفي، وأنْ أتخلّى فأكون كما كنتُ إذ لا شيء فِيّ. وذلك قوله: <span class="qpc-hafs">﴿وأَلْقَتْ ما فِيها وتَخَلَّتْ﴾</span></b>»{1}. (١٥/٣١٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٢١٤<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عمرو بن العاص</span> -من طريق مجاهد- قال: كان البيت قبل الأرض بألفي سنة، وذلك قول الله: <span class="qpc-hafs">﴿وإذا الأَرْضُ مُدَّتْ﴾</span>، قال: مُدَّت مِن تحتِه مَدًّا{2}. (١٥/٣١٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٢١٥<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق مجاهد- في قوله: <span class="qpc-hafs">﴿وإذا الأَرْضُ مُدَّتْ﴾</span> قال: يوم القيامة، <span class="qpc-hafs">﴿وأَلْقَتْ ما فِيها﴾</span> أخرجت ما فيها مِن الموتى، <span class="qpc-hafs">﴿وتَخَلَّتْ﴾</span> عنهم{3}. (١٥/٣١٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٢١٦<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح-، مثله{4}. (١٥/٣١٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٢١٧<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، في قوله: <span class="qpc-hafs">﴿وأَلْقَتْ ما فِيها وتَخَلَّتْ﴾</span>، قال: سواري الذهب{5}. (١٥/٣١٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٢١٨<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- في قوله: <span class="qpc-hafs">﴿وأَلْقَتْ ما فِيها وتَخَلَّتْ﴾</span>، قال: أخرجتْ أثقالها، وما فيها من الكنوز، والناس{6}<span class=comment-ref>٧٠٩٤</span>. (١٥/٣١٦)</p></p><p></div></p><p><div><span class=comment-ref>٧٠٩٤</span> <span class="comment-type-4">ذكر</span> <u>ابنُ عطية</u> (٨/٥٦٨) نحو ما جاء في قول قتادة عن الزَّجّاج، و<span class="comment-type-2">انتقده</span> <span class="mustanad">مستندًا إلى السياق</span>، فقال: «وقال الزَّجّاج: من الكنوز، وهذا ضعيف؛ لأن ذلك يكون وقت خروج الدَّجّال، وإنما تلقي يوم القيامة الموتى».</div></p><p><div></p><p><p><span class="item-no">٨٢٢١٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وإذا الأَرْضُ مُدَّتْ﴾</span> مثل الأديم الممدود، <span class="qpc-hafs">﴿وأَلْقَتْ﴾</span> ما فِيها من الحيوان، <span class="qpc-hafs">﴿وتَخَلَّتْ﴾</span> يقول: سَمِعَتْ لربّها وأطاعتْ، وكان [يحقّ] لها ذلك{7}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَإِذَا ٱلۡأَرۡضُ مُدَّتۡ ۝٣ وَأَلۡقَتۡ مَا فِیهَا وَتَخَلَّتۡ ۝٤ وَأَذِنَتۡ لِرَبِّهَا وَحُقَّتۡ ۝٥﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٨٢٢٢٠<span class="dash">-</span></span> عن جابر بن عبد الله، عن النبي ﷺ، قال: «<b>تمُد الأرضُ يوم القيامة مدَّ الأديمِ، ثم لا يكون لابن آدم منها إلا موضعُ قدميه</b>»{8}. (١٥/٣١٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٢٢١<span class="dash">-</span></span> عن علي بن حسين، أنّ النبي ﷺ قال: «<b>إذا كان يومُ القيامة مَدَّ الله الأرض، حتى لا يكون لبشر مِن الناس إلا موضع قدميه، فأكون أولَ مَن يُدعى، وجبريل عن يمين الرحمن، واللهِِ، ما رآه قبلها، فأقول: يا ربّ، إنّ هذا أخبرني أنكَ أرسلتَه إلَيّ. فيقول: صدق. ثم أشفع فأقول: يا ربّ، عبادك عبدوك في أطراف الأرض</b>». قال: «<b>وهو المقام المحمود</b>»{9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٢٢٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عمرو بن العاص</span> -من طريق أبي المُغيرة- قال: إذا كان يوم القيامة مُدّت الأرض مدَّ الأديم، وحَشر الله الخلائق؛ الإنس والجن والدواب والوحوش، فإذا كان ذلك اليوم جعل الله القِصاص بين الدوابِّ، حتى تقتصَّ الشاة الجَمّاءُ من القرناءِ بنَطْحتِها، فإذا فرغ الله من القصاص بين الدواب قال لها: كوني ترابًا. فيراها الكافر، فيقول: يا ليتني كنتُ ترابًا{10}. (١٥/٣١٥)</p></p><p></div></p></div>",footnotes:1:أخرجه أبو القاسم الخُتَّلي في الديباج ص١٠٢ (٣٤)، من طريق سلام بن سلم الطويل، عن عبد الحميد، عن نافع، عن ابن عمر به.</p><p>وسنده شديد الضعف؛ فيه سلام بن سلم، وهو متروك. الميزان ٢/١٧٥.|2:أخرجه الحاكم ٢/٥١٨، والبيهقي في الدلائل ٢/٤٤. وعزاه السيوطي إلى الفريابي، وعبد بن حميد.|3:أخرجه الحاكم ٢/٥١٨.|4:تفسير مجاهد ص٧١٤ مقتصرًا على الآية الثانية، وأخرجه ابن جرير ٢٤/٢٣٣. وعزاه السيوطي إلى عبد بن حميد.|5:عزاه السيوطي إلى ابن المنذر.|6:أخرجه عبد الرزاق ٢/٣٥٩ بنحوه، وابن جرير ٢٤/٢٣٣ بلفظ: أخرجتْ أثقالها وما فيها. وعزاه السيوطي إلى عبد بن حميد.|7:تفسير مقاتل بن سليمان ٤/٦٣٣-٦٣٤.|8:أخرجه الحاكم ٤/٦١٤ (٨٧٠١) مطولًا بنحوه.</p><p>قال الحاكم: «هذا حديث صحيح الإسناد، على شرط الشيخين، ولم يخرجاه». ووافقه الذهبي في التلخيص. وقال ابن حجر في الفتح ١١/٣٧٦: «ورجاله ثقات، إلا أنه اختُلف على الزُّهريّ في صحابيه». وقال السيوطي: «بسند جيد».|9:أخرجه عبد الرزاق ٣/٤٠٧ بنحوه، وابن جرير ٢٤/٢٣٢ مرسلًا.|10:أخرجه الحاكم ٤/٥٧٥.
  84,4,""
  84,5,""
  84,6,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿یَـٰۤأَیُّهَا ٱلۡإِنسَـٰنُ إِنَّكَ كَادِحٌ إِلَىٰ رَبِّكَ كَدۡحࣰا فَمُلَـٰقِیهِ ۝٦﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٨٢٢٢٣<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق العَوفيّ- في قوله: <span class="qpc-hafs">﴿يا أيُّها الإنْسانُ إنَّكَ كادِحٌ إلى رَبِّكَ كَدْحًا فَمُلاقِيهِ﴾</span>، يقول: تعملُ عملًا تلقى الله به؛ خيرًا كان أو شرًّا{1}. (١٥/٣١٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٢٢٤<span class="dash">-</span></span> عن <span class="name-2">الضَّحّاك بن مُزاحِم</span> -من طريق جويبر- <span class="qpc-hafs">﴿يا أيُّها الإنْسانُ إنَّكَ كادِحٌ إلى رَبِّكَ كَدْحًا﴾</span>، قال: عامِلٌ إلى ربّك عَمَلًا{2}. (١٥/٣١٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٢٢٥<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- في قوله: <span class="qpc-hafs">﴿يا أيُّها الإنْسانُ إنَّكَ كادِحٌ إلى رَبِّكَ كَدْحًا﴾</span>، قال: عامِلٌ له عَمَلًا{3}. (١٥/٣١٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٢٢٦<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله تعالى: <span class="qpc-hafs">﴿إنَّكَ كادِحٌ إلى رَبِّكَ كَدْحًا﴾</span>، قال: إنّ كدحك -يا ابن آدم- لَضعيفٌ، فمَن استطاع أن يكون كدحُه في طاعة الله فليفعل، ولا قوة إلا بالله{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٢٢٧<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span>، <span class="qpc-hafs">﴿إنَّكَ كادِحٌ إلى رَبِّكَ كَدْحًا﴾</span> قال: عامل عملًا، <span class="qpc-hafs">﴿فَمُلاقِيهِ﴾</span> قال: مُلاقٍ عملك{5}. (١٥/٣١٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٢٢٨<span class="dash">-</span></span> قال <span class="name-3">محمد بن السّائِب الكلبي</span>: <span class="qpc-hafs">﴿كادِحٌ إلى رَبِّكَ كَدْحًا﴾</span> عامل لربّك عملًا{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٢٢٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثم قال: <span class="qpc-hafs">﴿يا أيُّها الإنْسانُ﴾</span> يعني بالإنسان: الأسود بن عبد الأسد <span class="qpc-hafs">﴿إنَّكَ كادِحٌ إلى رَبِّكَ كَدْحًا﴾</span> إنّك ساعٍ إلى ربّك سعيًا، <span class="qpc-hafs">﴿فَمُلاقِيهِ﴾</span> بعملك{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٢٣٠<span class="dash">-</span></span> قال <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- <span class="qpc-hafs">﴿إنَّكَ كادِحٌ إلى رَبِّكَ كَدْحًا﴾</span>، قال: عامل إلى ربّك عملًا. قال: <span class="qpc-hafs">﴿كَدْحًا﴾</span> العمل{8}<span class=comment-ref>٧٠٩٥</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٧٠٩٥</span> في عود الضمير من قوله: <span class="qpc-hafs">﴿فملاقيه﴾</span> قولان: <b>الأول</b>: أنه عائد على الرّبّ. <b>الثاني</b>: أنه عائد على العمل والكدح.</p><p>وقد <span class="comment-type-4">علّق</span> <u>ابنُ عطية</u> (٨/٥٦٩) على الأول، فقال: فالفاء على هذا عاطفة <span class="qpc-hafs">﴿ملاق﴾</span> على كادح«. و<span class="comment-type-4">علّق</span> على الثاني، فقال:»فالفاء على هذا عاطفة جملة على التي قبلها، والتقدير: فأنت ملاقيه، والمعنى: ملاقٍ جزاءه خيرًا كان أو شرًّا".</p><p>و<span class="comment-type-4">علّق</span> <u>ابنُ كثير</u> (١٤/٢٩٣ بتصرف) على الأول، فقال: «ومِن الناس مَن يعيد الضمير على قوله: <span class="qpc-hafs">﴿ربك﴾</span>، أي: فملاقٍ ربّك، ومعناه: فيجازيك بعملك ويكافئك على سعيك. وعلى هذا فكلا القولين متلازم». و<span class="comment-type-4">علّق</span> على الثاني، فقال: «ويشهد له ما رواه أبو داود الطيالسي ... عن جابر، قال: <span class="mustanad">قال رسول الله</span> ﷺ: «<b>قال جبريل: يا محمد، عِشْ ما شئتَ فإنك ميت، وأَحبِب ما شئتَ فإنك مفارقه، واعمل ما شئتَ فإنك ملاقيه</b>»».</div></p></div>",footnotes:1:أخرجه ابن جرير ٢٤/٢٣٥.|2:أخرجه ابن أبي شيبة ١٣/٥٨١.|3:أخرجه عبد الرزاق ٢/٣٥٨، وابن جرير ٢٤/٢٣٦. وعزاه السيوطي إلى عبد بن حميد.|4:أخرجه ابن جرير ٢٤/٢٣٥.|5:عزاه السيوطي إلى ابن المنذر.|6:تفسير البغوي ٨/٣٧٤.|7:تفسير مقاتل بن سليمان ٤/٦٣٤.|8:أخرجه ابن جرير ٢٤/٢٣٦.
  84,7,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿فَأَمَّا مَنۡ أُوتِیَ كِتَـٰبَهُۥ بِیَمِینِهِۦ ۝٧ فَسَوۡفَ یُحَاسَبُ حِسَابࣰا یَسِیرࣰا ۝٨﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٨٢٢٣١<span class="dash">-</span></span> عن عائشة، قالت: قال رسول الله ﷺ: «<b>ليس أحد يُحاسب إلا هلك</b>». فقلتُ: أليس الله يقول: <span class="qpc-hafs">﴿فَأَمّا مَن أُوتِيَ كِتابَهُ بِيَمِينِهِ فَسَوْفَ يُحاسَبُ حِسابًا يَسِيرًا﴾</span>؟ قال: «<b>ليس ذلك بالحساب، ولكن ذاك العرض، ومَن نُوقِش الحساب هلك</b>»{1}. (١٥/٣١٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٢٣٢<span class="dash">-</span></span> عن عائشة: سمعتُ رسول الله ﷺ يقول في بعض صلاته: «<b>اللهم، حاسِبني حسابًا يسيرًا</b>». فلما انصرف قلتُ: يا رسول الله، ما الحساب اليسير؟ قال: «<b>أن يُنظر في كتابه فيُتجاوز له عنه؛ إنه مَن نُوقش الحساب هلك</b>»{2}. (١٥/٣١٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٢٣٣<span class="dash">-</span></span> عن عائشة، قالت: يا نبي الله، كيف <span class="qpc-hafs">﴿حِسابًا يَسِيرًا﴾</span>؟ قال: «<b>يُعطى العبد كتابه بيمينه، فيقرأ سيئاته، ويقرأ الناس حسناته، ثم يُحوّل صحيفته، فيُحوّل الله سيئاته حسنات، فيقرأ حسناته، ويقرأ الناس سيئاته حسنات، فيقول الناس: ما كان لهذا العبد سيئة. قال: يُعْرّف بعمله، ثم يغفر الله له. قال: <span class="qpc-hafs">﴿أُولَئِكَ يُبَدِّلُ اللهُ سَيِّئاتِهِمْ حَسَناتٍ وكانَ اللهُ غَفُورًا رَّحِيمًا﴾</span></b>» [الفرقان:٧٠]{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٢٣٤<span class="dash">-</span></span> عن <span class="name-1">عائشة</span>، في قوله: <span class="qpc-hafs">﴿فَسَوْفَ يُحاسَبُ حِسابًا يَسِيرًا﴾</span>، قال: يُعرَّف ذنوبَه، ثم يُتَجاوزُ له عنها{4}. (١٥/٣١٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٢٣٥<span class="dash">-</span></span> عن <span class="name-1">عائشة</span> -من طريق عروة- قالت: مَن حُوسِب يوم القيامة أُدخِل الجنة. وتَلَتْ: <span class="qpc-hafs">﴿فَأَمّا مَن أُوتِيَ كِتابَهُ بِيَمِينِهِ فَسَوْفَ يُحاسَبُ حِسابًا يَسِيرًا﴾</span>، ثم تَلَتْ: <span class="qpc-hafs">﴿يُعْرَفُ المُجْرِمُونَ بِسِيماهُمْ فَيُؤْخَذُ بِالنَّواصِي والأَقْدامِ﴾</span> [الرحمن:٤١]{5}. (١٥/٣١٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٢٣٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثم قال: <span class="qpc-hafs">﴿فَأَمّا مَن أُوتِيَ كِتابَهُ بِيَمِينِهِ﴾</span> وهو عبد الله بن عبد الأسد، ويُكنى: أبا سلمة، <span class="qpc-hafs">﴿فَسَوْفَ يُحاسَبُ حِسابًا يَسِيرًا﴾</span> باليسير؛ بأنّ الله لا يُغيّر حسناته ولا يفضحه، وذلك أنّ الله ﷿ إذا جمع الخلائق يوم القيامة فإنهم يموج بعضُهم في بعض مقدارَ ثلاثمائة سنة، حتى إذا استوى الرّبُّ -جلّ وعزّ- على كرسيّه لِيُحاسب خَلْقه، فإذا جاء الرّبُّ -تبارك وتعالى- والملائكةُ صفًّا صفًّا، فينظرون إلى الجنة وإلى النار، ويُجاء بالنار من مسيرة خمسمائة عام، عليها تسعون ألف زمام، في كلّ زمام سبعون ألف ملك متعلّق، يحبسونها عن الخلائق، طول عنق أحدهم مسيرة سنة، وغِلظها مسيرة سنة، ما بين مَنكِبي أحدهم مسيرة خمسين سنة، وجوههم مثل الجمر، وأعينهم مثل البَرق، إذا تَكلّم أحدهم تناثرتْ مِن فِيه النار، بيد كلّ واحد منهم مرزبة، عليها ثلاثمائة وستون رأسًا كأمثال الجبال، هي أخفّ بيده مِن الريشة، فيجيئون بها، فيسوقونها حتى تقام عن يسار العرش، ويجاء بالجنة يزفونها كما تُزَفُّ العروس إلى زوجها حتى تقام عن يمين العرش، فإذا ما عاين الخلائقُ النارَ، وما أعدّ الله لأهلها، ونظروا إلى ربّهم، وسكتوا؛ فانقطعتْ عند ذلك أصواتهم، فلا يَتكلّم أحدٌ مِنهم مِن فَرَق الله وعظمته، ولما يرون مِن العجائب مِن الملائكة، ومن حملة العرش، ومن أهل السموات، ومن جهنم، ومن خزنتها، فانقطعتْ أصواتهم عند ذلك، وتَرتعد مفاصلهم، فإذا علم الله ما أصاب أولياءَه مِن الخوف، وبلغت القلوب الحناجر، فيقوم منادٍ عن يمين العرش، فينادي: <span class="qpc-hafs">﴿يا عِبادِ، لا خَوْفٌ عَلَيْكُمُ اليَوْمَ ولا أنْتُمْ تَحْزَنُونَ﴾</span> [الزخرف:٦٨]، فيرفع عند ذلك الإنس والجنّ كلُّهم رؤوسَهم والمؤمنون والكفار؛ لأنهم عباده كلّهم، ثم ينادي في الثانية: <span class="qpc-hafs">﴿الَّذِينَ آمَنُوا بِآياتِنا وكانُوا مُسْلِمِينَ﴾</span> [الزخرف:٦٩]، فيَرفع المؤمنون رؤوسَهم، وينكس أهل الأديان كلّهم رؤوسهم، والناس سكوت مقدار أربعين عامًا، فذلك قوله: <span class="qpc-hafs">﴿هَذا يَوْمُ لا يَنْطِقُونَ، ولا يُؤْذَنُ لَهُمْ فَيَعْتَذِرُونَ﴾</span> [المرسلات:٣٥-٣٦]، وقوله: <span class="qpc-hafs">﴿لا يَتَكَلَّمُونَ إلّا مَن أذِنَ لَهُ الرَّحْمنُ وقالَ صَوابًا﴾</span> [النبأ:٣٨]؛ وقال: لا إله إلا الله؛ فذلك الصواب، وقوله: <span class="qpc-hafs">﴿وخَشَعَتِ الأَصْواتُ لِلرَّحْمنِ فَلا تَسْمَعُ إلّا هَمْسًا﴾</span> [طه:١٠٨]، فلا يجيبهم الله، ولا يُكلّمهم، ولا يتكلمون هم مقدار أربعين سنة، يقول بعد ذلك لمَلكٍ من الملائكة وهو جبريل ﵇: نادِ الرسل، وابدأ بالأُمِّي. قال: فيقوم المَلك، فينادي عند ذلك: أين النَّبِي الأُمِّي؟ فتقول الأنبياء عند ذلك: كلّنا نبيّون وأُمّيون؛ فبيِّن بيِّن. فيقول: النبي العربي الأُمّي الحرمي، فيقوم عند ذلك رسول الله ﷺ، فيرفع صوته بالدعاء، فيقول: كم مِن ذنب قد عملتموه ونسيتموه وقد أحصاه الله! ربِّ، لا تفضح أمتي. قال: فلا يزال يدنو مِن الله تعالى حتى يقوم بين يديه؛ أقرب خَلْقه إليه، فيحمد الله، ويثني عليه، ويذكر من الثناء على الله تعالى والحمد حتى تعجب الملائكة منه والخلائق، فيقول الله ﷿: قد رضيتُ عنك، يا محمد، اذهب فنادِ أُمّتك. فينادي، وأول ما يدعو يدعو مِن أُمّته عبد الله بن عبد الأسد أبا سلمة، فلا يزال يدنو، فيقرّبه الله ﷿ منه، فيحاسبه حسابًا يسيرًا، واليسير الذي لا يأخذه بالذنب الذي عمله، ولا يغضب الله ﷿ عليه، فيجعل سيئاته داخل صحيفته، وحسناته ظاهر صحيفته، فيوضع على رأسه التاج مِن ذَهَبٍ عليه تسعون ألف ذؤابة، كلّ ذؤابة دُرّة تساوي مال المشرق والمغرب، ويلبس سبعين حُلّة مِن الإستبرق والسندس، فالذي يلي جسده حريرة بيضاء، فذلك قوله: <span class="qpc-hafs">﴿ولِباسُهُمْ فِيها حَرِيرٌ﴾</span> [الحج:٢٣، فاطر:٣٣]، ويُسوَّر بثلاث أسْوِرة: سوار من فِضّة، وسوار من ذهب، وسوار من لؤلؤ، ويوضع إكليل مُكلّل بالدُّرّ والياقوت، وقد تلألأ في وجهه مِن نور ذلك، فيرجع إلى إخوانه من المؤمنين، فينظرون إليه وهو جاءٍ مِن عند الله، فتقول الملائكة والناس والجنّ: واللهِ، لقد أكرم الله هذا، لقد أعطى الله لهذا. فينظرون إلى كتابه، فإذا سيئاته باطن صحيفته، وإذا حسناته ظاهر كتابه، فتقول عند ذلك الملائكة: ما كان أذنب هذا الآدميُّ ذنبًا قط! واللهِ، لقد اتّقى اللهَ هذا العبدُ، فحُقّ أن يكرم مثل هذا العبد. وهم لا يشعرون أنّ سيئاته باطن كتابه، وذلك لمن أراد الله تعالى أن يُكرمه ولا يفضحه، قال: فيأتي إخوانَه من المسلمين، فلا يعرفونه، فيقول: أتعرفوني؟ فيقولون كلّهم: لا، واللهِ. فيقول: إنما برحتُ الساعة، وقد نسيتموني. فيقول: أنا أبو سلمة، أبشِروا بمثله، يا معشر الإخوان، لقد حاسَبني ربي حسابًا يسيرًا، وأكرمني. فذلك قوله: <span class="qpc-hafs">﴿فَسَوْفَ يُحاسَبُ حِسابًا يَسِيرًا ويَنْقَلِبُ إلى أهْلِهِ﴾</span> يقول إلى قومه: <span class="qpc-hafs">﴿مَسْرُورًا﴾</span> فيُعطى كتابه بيمينه، <span class="qpc-hafs">﴿فَيَقُولُ هاؤُمُ اقْرَؤُا كِتابِيَهْ إنِّي ظَنَنْتُ أنِّي مُلاقٍ حِسابِيَهْ﴾</span> [الحاقة:١٩-٢٠] إلى آخر القصة{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٢٣٧<span class="dash">-</span></span> قال <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿فَسَوْفَ يُحاسَبُ حِسابًا يَسِيرًا﴾</span>، قال: الحساب اليسير: الذي يُغفر ذنوبه، ويُتقبّل حسناته. ويسير الحساب: الذي يُعفى عنه. وقرأ: <span class="qpc-hafs">﴿ويَخافُونَ سُوءَ الحِسابِ﴾</span> [الرعد:٢١]، وقرأ: <span class="qpc-hafs">﴿أُولَئِكَ الَّذِينَ نَتَقَبَّلُ عَنْهُمْ أحْسَنَ ما عَمِلُوا ونَتَجاوَزُ عَنْ سَيِّئاتِهِمْ فِي أصْحابِ الجَنَّةِ﴾</span> [الأحقاف:١٦]{7}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿فَأَمَّا مَنۡ أُوتِیَ كِتَـٰبَهُۥ بِیَمِینِهِۦ ۝٧ فَسَوۡفَ یُحَاسَبُ حِسَابࣰا یَسِیرࣰا ۝٨﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٨٢٢٣٨<span class="dash">-</span></span> عن أبي هريرة، قال: قال رسول الله ﷺ: «<b>ثلاث مَن كُنّ فيه حاسبه الله حسابًا يسيرًا، وأدخله الجنة برحمته: تُعطي مَن حرَمك، وتعفو عمَّن ظلمَك، وتَصِل مَن قطَعك</b>»{8}. (١٥/٣١٨)</p></p><p></div></p></div>",footnotes:1:أخرجه البخاري ١/٣٢ (١٠٣)، ٦/١٦٧-١٦٨ (٤٩٣٩)، ٨/١١١-١١٢ (٦٥٣٦، ٦٥٣٧)، ومسلم ٤/٢٢٠٤-٢٢٠٥ (٢٨٧٦)، وآدم بن أبي إياس -كما في تفسير مجاهد ص٧١٤-، وعبد الرزاق ٣/٦١ (٢٤٠٩)، وابن جرير ٢٤/٢٣٧-٢٣٨، والثعلبي ١٠/١٥٩.|2:أخرجه أحمد ٤٠/٢٦٠ (٢٤٢١٥)، وابن خزيمة ٢/٧١ (٨٤٩)، وابن حبان ١٦/٣٧٢ (٧٣٧٢)، والحاكم ١/١٢٥ (١٩٠)، ١/٣٨٥ (٩٣٦)، ٤/٢٧٨ (٧٦٣٦)، ٤/٦٢٣ (٨٧٢٧)، وابن جرير ٢٤/٢٣٦-٢٣٧.</p><p>قال الحاكم: «هذا حديث صحيح، على شرط مسلم، ولم يخرجاه بهذا اللفظ». ووافقه الذهبي في التلخيص. وقال ابن كثير في تفسيره ٨/٣٥٧: «صحيح، على شرط مسلم». وقال الألباني في ضعيف أبي داود ٢/٤٧٢: «وإسناده حسن».|3:أخرجه عبد الله بن وهب في الجامع ١/٣٤ (٦٩)، من طريق ابن أبي جعفر، أنه بلغه أن عائشة...</p><p>وسنده ضعيف؛ لانقطاعه بين ابن أبي جعفر وعائشة ﵂.|4:عزاه السيوطي إلى ابن المنذر.|5:أخرجه ابن أبي شيبة ١٣/٣٦١. وعزاه السيوطي إلى ابن المنذر.|6:تفسير مقاتل بن سليمان ٤/٦٣٤-٦٣٩.|7:أخرجه ابن جرير ٢٤/٢٣٨.|8:أخرجه الحاكم ٢/٥٦٣ (٣٩١٢)، وفي إسناده سليمان بن داود اليمامي.</p><p>قال البزار -كما في كشف الأستار ٢/٣٨٣ (١٩٠٦)-: «سليمان بن داود ليس بالقوي، ولا يُتابع على حديثه». قال الحاكم: «هذا حديث صحيح الإسناد، ولم يخرجاه». وتعقبه الذهبي في التلخيص بقوله: «سليمان بن داود اليمامي ضعيف». وقال ابن القيسراني في ذخيرة الحفاظ ٢/١١٨٣ (٢٥٢٢): «رواه سليمان بن داود اليمامي أبو الجمل، عن يحيى بن أبي كثير، عن أبي سلمة، عن أبي هريرة. وسليمان هذا ليس بشيء». وقال المنذري الترغيب والترهيب ٣/٢١٠ (٣٧١٨): «رواه الثلاثة -البزار، والطبراني في الأوسط، والحاكم-، من رواية سليمان بن داود اليماني، عن يحيى بن أبي سلمة عنه، وسليمان هذا واهٍ». وقال المناوي في فيض القدير ٣/٢٨٨ (٣٤١٩): «وقال في المهذب: سليمان واه. وفي الميزان [ميزان الاعتدال ٢/٢٠٢ (٣٤٤٩)] قال البخاري [في التاريخ الكبير ٤/١١ (١٧٩٢)]: سليمان منكر الحديث. قال: ومَن قلتُ فيه: منكر الحديث. لا تحلُّ رواية حديثه، ثم ساق له أخبارًا هذا منها. وقال العلائي: فيه سليمان ضعّفه غير واحد. وقال الهيثمي [في مجمع الزوائد ٨/١٥٤ (١٣٤٧٣)]: فيه سليمان متروك».
  84,8,""
  84,9,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَیَنقَلِبُ إِلَىٰۤ أَهۡلِهِۦ مَسۡرُورࣰا ۝٩﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٨٢٢٣٩<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span>، في قوله: <span class="qpc-hafs">﴿ويَنْقَلِبُ إلى أهْلِهِ مَسْرُورًا﴾</span>، قال: إلى أهلٍ له في الجنة{1}. (١٥/٣١٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٢٤٠<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿ويَنْقَلِبُ إلى أهْلِهِ مَسْرُورًا﴾</span>، قال: إلى أهلٍ أعدّ الله لهم الجنةَ{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٢٤١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ويَنْقَلِبُ إلى أهْلِهِ﴾</span> يقول: إلى قومه <span class="qpc-hafs">﴿مَسْرُورًا﴾</span> فيُعطى كتابه بيمينه{3}. (ز)</p></p><p></div></p></div>",footnotes:1:عزاه السيوطي إلى ابن المنذر.|2:أخرجه ابن جرير ٢٤/٢٣٩.|3:تفسير مقاتل بن سليمان ٤/٦٣٧.
  84,10,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَأَمَّا مَنۡ أُوتِیَ كِتَـٰبَهُۥ وَرَاۤءَ ظَهۡرِهِۦ ۝١٠﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٨٢٢٤٢<span class="dash">-</span></span> عن رجل من بني أسد، قال: قال عمر لكعب: ويحك، يا <span class="name-2">كعب</span>! حدِّثنا حديثًا مِن حديث الآخرة. قال: نعم، يا أمير المؤمنين، إذا كان يوم القيامة رفع اللوح المحفوظ، ولم يبق أحد من الخلائق إلا وهو ينظر إلى عمله فيه. قال: ثم يُؤتى بالصحف التي فيها أعمال العباد. قال: فتُنشر حول العرش، فذلك قوله: <span class="qpc-hafs">﴿ووضع الكتاب فترى المجرمين مشفقين مما فيه ويقولون يا ويلتنا ما لهذا الكتاب لا يغادر صغيرة ولا كبيرة إلا أحصاها﴾</span> [الكهف:٤٩]. قال الأسدي: الصغيرة ما دون الشرك، والكبيرة الشّرك، إلا أحصاها. قال كعب: ثم يُدعى المؤمن، فيُعطى كتابه بيمينه، فينظر فيه، فحسناته باديات للناس، وهو يقرأ سيئاته لكي لا يقول: كانت لي حسنات فلم تُذكر. فأَحبّ الله أن يُريه عمله كلّه، حتى إذا استنقص ما في الكتاب وجد في آخر ذلك كلّه أنه مغفور، وإنك مِن أهل الجنة، فعند ذلك يُقبِل إلى أصحابه، ثم يقول: <span class="qpc-hafs">﴿هاؤم اقرءوا كتابيه إني ظننت أني ملاق حسابيه﴾</span> [الحاقة:١٩-٢٠]، ثم يُدعى الكافر، فيُعطى كتابه بشماله، ثم يُلفّ، فيُجعل مِن وراء ظهره، ويُلوى عنقه، فذلك قوله: <span class="qpc-hafs">﴿وأما من أوتي كتابه وراء ظهره﴾</span> يُنظر في كتابه، فسيئاته باديات للناس، وينظر في حسناته، لكي لا يقول: أفأُثاب على السيئات؟{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٢٤٣<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span>، في قوله: <span class="qpc-hafs">﴿وأَمّا مَن أُوتِيَ كِتابَهُ وراءَ ظَهْرِهِ﴾</span>، قال: تُخلَع يده، فتُجعَل مِن وراء ظهره{2}. (١٥/٣١٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٢٤٤<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿وأَمّا مَن أُوتِيَ كِتابَهُ وراءَ ظَهْرِهِ﴾</span>، قال: تُجعل شماله وراء ظهره، فيأخذ بها كتابه{3}. (١٥/٣١٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٢٤٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثم ينادي منادٍ بالأسود بن عبد الأسد؛ أخي عبد الله المؤمن، فيريد الشقي أن يدنوَ، فينتهرونه، ويشقّ صدره حتى يخرج قلبُه مِن وراء ظهره مِن بين كتفيه، ويُعطى كتابه، ويُجعل كلّ حسنة عملها في دهره في باطن صحيفته؛ لأنه لم يؤمن بالإيمان، وتُجعل سيئاته ظاهر صحيفته، ويُحجب عن الله ﷿، فلا يراه، ولكن ينادي منادٍ من عند العرش يذكّره مساوئه، فكلما ذكر مساوئه قال: أنا أعرف هذا، لعنه الله. فتجيء اللعنة من عند الله ﷿ حتى تقع عليه، فيُلطّخ باللعنة، فيصير جسده مسيرة شهر في طول مسيرة ثلاثة أيام ولياليهن، ورأسه مثل الأقرع، وهو جبل عظيم بالشام وأنيابه مثل أُحُد، وحدقتاه مثل جبل حِراء الذي بمكة، ومنخره مثل الورقين{4}، وهما جبلان، وشعره في الكثرة، مثل الأجمة{5}، وفي الطول مثل القصب، وفي الغِلظ مثل الرماح، ويوضع على رأسه تاج مِن نار، ويُلبس جُبّة مِن نحاس ذائب، ويُقلّد حجرًا من كبريت، مثل الجبل تشتعل فيه النار، وتُغلّ يداه إلى عنقه، ويَسودّ وجهه، وهو أشد سوادًا من القبر في ليلة مظلمة، وتزرقّ عيناه، فيرجع إلى إخوانه، فأول ما يرونه يفزع منه الخلائق، حتى يُمسكوا على آنافهم مِن شدة نَتنه، فيقولون: لقد أهان اللهُ هذا العبد، لقد أخزى الله هذا العبد. فينظرون إلى كتابه، فإذا سيئاته ظاهرة، وليس له من الحسنات شيء، يقولون: أما كان لهذا العبد في الله ﷿ حاجة، ولا خافه يومًا قط، ولا ساعة، فحُقّ لهذا العبد إذ أخزاه الله وعذّبه. فتلعنه الملائكة أجمعون، فإذا رجع إلى الموقف لم يعرفه أصحابه، فيقول: أما تعرفوني؟ قالوا: لا، واللهِ. فيقول: أنا الأسود بن عبد الأسد، فينادي بأعلى صوته، فيقول: <span class="qpc-hafs">﴿يا لَيْتَنِي لَمْ أُوتَ كِتابِيَهْ ولَمْ أدْرِ ما حِسابِيَهْ يا لَيْتَها كانَتِ القاضِيَةَ ما أغْنى عَنِّي مالِيَهْ﴾</span> [الحاقة:٢٥-٢٨]. يقول: يا ليت كان الموت أنْ أموت فأستريح من هذا البلاء، هلك عنى حُجّتي اليوم. ثم يقول: الويل. فيُبشّر أخوه المؤمنين، ويُبشّر هذا الكفار، فذلك قوله تعالى: <span class="qpc-hafs">﴿وأَمّا مَن أُوتِيَ كِتابَهُ وراءَ ظَهْرِهِ﴾</span>{6}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن المبارك في الزهد ١/٥١٩.|2:عزاه السيوطي إلى ابن المنذر.|3:تفسير مجاهد ص٧١٤ بنحوه، وأخرجه الفريابي -كما في تغليق التعليق ٤/٣٦٤، وفتح الباري ٨/٦٩٧-، وابن جرير ٢٤/٢٤٠. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، والبيهقي في البعث.|4:كذا في مطبوعة المصدر، والمعروف: جبل ورِقان، وهو جبل أسود على يمين المار من المدينة إلى مكة. ينظر: النهاية، لسان العرب، تاج العروس (ورق).|5:الأجَمَة: الشجر الكثير الملتف. المعجم الوسيط (أجم).|6:تفسير مقاتل بن سليمان ٤/٦٣٤-٦٣٩.
  84,11,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿فَسَوۡفَ یَدۡعُوا۟ ثُبُورࣰا ۝١١ وَیَصۡلَىٰ سَعِیرًا ۝١٢﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٨٢٢٤٦<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، <span class="qpc-hafs">﴿يَدْعُو ثُبُورًا﴾</span>، قال: الويل{1}. (١٥/٣١٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٢٤٧<span class="dash">-</span></span> عن <span class="name-2">الضَّحّاك بن مُزاحِم</span> -من طريق عبيد- قال في قوله: <span class="qpc-hafs">﴿يَدْعُو ثُبُورًا﴾</span>، قال: يدعو بالهلاك{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٢٤٨<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فَسَوْفَ يَدْعُوا ثُبُورًا * ويَصْلى سَعِيرًا﴾</span> يدعو بالويل، ويدخل النار{3}. (ز)</p></p><p></div></p></div>",footnotes:1:عزاه السيوطي إلى ابن المنذر.|2:أخرجه ابن جرير ٢٤/٢٤٠.|3:تفسير مقاتل بن سليمان ٤/٦٣٤-٦٣٩.
  84,12,""
  84,13,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿إِنَّهُۥ كَانَ فِیۤ أَهۡلِهِۦ مَسۡرُورًا ۝١٣﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٨٢٢٤٩<span class="dash">-</span></span> عن <span class="name-2">الضَّحّاك بن مُزاحِم</span>، <span class="qpc-hafs">﴿إنَّهُ كانَ فِي أهْلِهِ مَسْرُورًا﴾</span>، قال: في الدنيا{1}. (١٥/٣١٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٢٥٠<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿إنَّهُ كانَ فِي أهْلِهِ مَسْرُورًا﴾</span> أي: في الدنيا{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٢٥١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: يقول: <span class="qpc-hafs">﴿إنَّهُ كانَ فِي أهْلِهِ مَسْرُورًا﴾</span> في قومه كريمًا، فيُذلّه الله يوم القيامة{3}. (ز)</p></p><p></div></p></div>",footnotes:1:عزاه السيوطي إلى ابن المنذر.|2:أخرجه ابن جرير ٢٤/٢٤١.|3:تفسير مقاتل بن سليمان ٤/٦٣٩.
  84,14,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿إِنَّهُۥ ظَنَّ أَن لَّن یَحُورَ ۝١٤﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٨٢٢٥٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق الضَّحّاك- <span class="qpc-hafs">﴿أنْ لَنْ يَحُورَ﴾</span>، قال: أن لن يرجع{1}. (١٥/٣١٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٢٥٣<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق الضَّحّاك- أنّ نافع بن الأزرق سأله عن قوله: <span class="qpc-hafs">﴿أنْ لَنْ يَحُورَ﴾</span>، قال: أن لن يرجع، بلغة الحبشة. يقول: أن لن يرجع إلى الله في الآخرة. قال: وهل تعرف العرب ذلك؟ قال: نعم، أما سمعتَ قول لبيد:</p><p>وما المرءُ إلا كالشهابِ وضوئِه يحورُ رَمادًا بعدَ إذْ هو ساطعُ؟{2}. (١٥/٣١٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٢٥٤<span class="dash">-</span></span> قال <span class="name-1">عبد الله بن عباس</span>: كنت لا أدري ما معنى <span class="qpc-hafs">﴿يحور﴾</span>، حتى سمعتُ أعرابيّةً تدعو بُنيّة لها فتقول: حُورِي، حُورِي. أي: ارجعي{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٢٥٥<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- في قوله: <span class="qpc-hafs">﴿إنَّهُ ظَنَّ أنْ لَنْ يَحُورَ﴾</span>، قال: لن يُبعَث{4}. (١٥/٣١٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٢٥٦<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر-، مثله{5}. (١٥/٣١٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٢٥٧<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- <span class="qpc-hafs">﴿أنْ لَنْ يَحُورَ﴾</span>: أن لن يرجع إلينا{6}. (١٥/٣١٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٢٥٨<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span>، <span class="qpc-hafs">﴿إنَّهُ ظَنَّ أنْ لَنْ يَحُورَ﴾</span>، قال: أليس تسمع الحبشيَّ إذا قيل له: حُرْ إلى أهلك؟ أي: اذهب{7}. (١٥/٣١٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٢٥٩<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله تعالى: <span class="qpc-hafs">﴿إنَّهُ ظَنَّ أنْ لَنْ يَحُورَ﴾</span>: أن لا معاد له، ولا رجعة{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٢٦٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: قال: <span class="qpc-hafs">﴿إنَّهُ ظَنَّ أنْ لَنْ يَحُورَ﴾</span>، يقول: أن لن يُبعَث{9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٢٦١<span class="dash">-</span></span> عن <span class="name-3">سفيان [الثوري]</span> -من طريق مهران- <span class="qpc-hafs">﴿إنَّهُ ظَنَّ أنْ لَنْ يَحُورَ﴾</span>، قال: يرجِع{10}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٢٦٢<span class="dash">-</span></span> قال <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿أنْ لَنْ يَحُورَ﴾</span>، قال: أن لن ينقلب{10}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿إِنَّهُۥ ظَنَّ أَن لَّن یَحُورَ ۝١٤﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٨٢٢٦٣<span class="dash">-</span></span> عن عبد الله بن سرجس، قال: كان رسول الله ﷺ إذا سافر يتعوذ مِن وعثاء السفر، وكآبة المنقلب، والحَوْر بعد الكَوْر{12}، ودعوة المظلوم، وسوء المنظر في الأهل والمال{13}. (ز)</p></p><p></div></p></div>",footnotes:1:عزاه السيوطي إلى ابن أبي حاتم.|2:أخرجه الطستي في مسائل نافع (٢٤)، والطبراني في المعجم الكبير ١٠/٢٤٨-٢٥٦ (١٠٥٩٧).|3:تفسير الثعلبي ١٠/١٦٠.|4:أخرجه ابن جرير ٢٤/٢٤٢، وابن أبي حاتم -كما في الإتقان ٢/٥٤-. وعزاه السيوطي إلى ابن المنذر.|5:أخرجه عبد الرزاق ٢/٣٥٨، وابن جرير ٢٤/٢٤٣. وعزاه السيوطي إلى عبد بن حميد.|6:تفسير مجاهد ص٧١٤، وأخرجه ابن جرير ٢٤/٢٤٢. وعزاه السيوطي إلى عبد بن حميد.|7:عزاه السيوطي إلى عبد بن حميد.|8:أخرجه ابن جرير ٢٤/٢٤٢.|9:تفسير مقاتل بن سليمان ٤/٦٣٩.|10:أخرجه ابن جرير ٢٤/٢٤٣.|11:أخرجه ابن جرير ٢٤/٢٤٣.|12:استشهد ابن جرير ٢٤/٢٤٢ بقوله: «والحَوْر بعد الكَوْر» في بيان معنى الآية، ثم علق عليه فقال: «يعني بذلك: مِن الرجوع إلى الكفر بعد الإيمان».|13:أخرجه مسلم ٢/٩٧٩ (١٣٤٣).
  84,15,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿بَلَىٰۤۚ إِنَّ رَبَّهُۥ كَانَ بِهِۦ بَصِیرࣰا ۝١٥﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٨٢٢٦٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: يقول الله تعالى: <span class="qpc-hafs">﴿بَلى إنَّ رَبَّهُ﴾</span> الذي خَلَقه <span class="qpc-hafs">﴿كانَ بِهِ بَصِيرًا﴾</span> إنه شهيد لعمله{1}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٤/٦٣٩.
  84,16,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿فَلَاۤ أُقۡسِمُ بِٱلشَّفَقِ ۝١٦﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٨٢٢٦٥<span class="dash">-</span></span> عن <span class="name-1">عمر بن الخطاب</span>، قال: الشَّفَق: الحُمْرَة{1}. (١٥/٣٢٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٢٦٦<span class="dash">-</span></span> عن <span class="name-1">أبي هريرة</span>، قال: الشَّفَق: البياض{2}. (١٥/٣٢٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٢٦٧<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، قال: الشَّفَق: الحُمْرة{3}. (١٥/٣٢٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٢٦٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عمر</span> -من طريق نافع- قال: الشَّفَق: الحُمْرة{4}. (١٥/٣٢٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٢٦٩<span class="dash">-</span></span> عن <span class="name-2">عمر بن عبد العزيز</span> -من طريق جعفر بن برقان- قال: <span class="qpc-hafs">﴿الشَّفَق﴾</span> البياض{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٢٧٠<span class="dash">-</span></span> عن العوام بن حَوْشَب، قال: قلت لـ<span class="name-2">مجاهد</span>: الشَّفَق؟ قال: إنّ الشَّفَق مِن الشمس{6}. (١٥/٣٢٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٢٧١<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿فَلا أُقْسِمُ بِالشَّفَق﴾</span>، قال: الشَّفَق: النهار كلّه{7}<span class=comment-ref>٧٠٩٦</span>. (١٥/٣٢٠)</p></p><p></div></p><p><div><span class=comment-ref>٧٠٩٦</span> <span class="comment-type-4">علّق</span> <u>ابنُ كثير</u> (١٤/٢٩٦ بتصرف) على قول مجاهد، فقال: «صحَّ عن مجاهد أنه قال في هذه الآية: <span class="qpc-hafs">﴿فلا أقسم بالشَّفَق﴾</span> هو النهار كلّه. وإنما <span class="mustanad">حمله على هذا قرنه بقوله تعالى</span>: <span class="qpc-hafs">﴿والليل وما وسق﴾</span> أي: جمع. كأنه أقسم بالضياء والظلام».</div></p><p><div></p><p><p><span class="item-no">٨٢٢٧٢<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span>، مثله{8}. (١٥/٣٢٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٢٧٣<span class="dash">-</span></span> عن <span class="name-2">مكحول الشامي</span> -من طريق محمد بن راشد- قال: <span class="qpc-hafs">﴿الشَّفَق﴾</span> الحُمرة{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٢٧٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثم أقسم الرّبُّ ﷿، فقال: <span class="qpc-hafs">﴿فَلا أُقْسِمُ بِالشَّفَق﴾</span>، فأمّا الشَّفَق: فهو الضوء الذي يكون بعد غروب الشمس إلى أن تغيب{10}<span class=comment-ref>٧٠٩٧</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٧٠٩٧</span> اختُلف في معنى الشَّفَق على قولين: <b>الأول</b>: أنه الحُمرة. <b>الثاني</b>: أنه البياض أو النهار.</p><p>وقد زاد <u>ابنُ جرير</u> (٢٤/٢٤٤) <b>قولًا ثالثًا</b> لم ينسبه: أنه من الأضداد، وهو اسم للحُمرة والبياض.</p><p>وقد <span class="comment-type-3">رجّح</span> <u>ابنُ جرير</u> القول الثاني، فقال: «والصواب من القول في ذلك عندي أن يُقال: إنّ الله أقسم بالنهار مُدبرًا، والليل مُقبلًا. وأمّا الشَّفَق الذي تحلّ به صلاة العشاء، فإنه للحُمرة عندنا؛ للعلّة التي قد بيناها في كتابنا كتاب الصلاة».</p><p>و<span class="comment-type-3">رجّح</span> <u>ابنُ عطية</u> (٨/٥٧٢) أنّ الشَّفَق هو: «الحُمرة التي تعقب غيبوبة الشمس مع البياض التابع لها في الأغلب». ثم <span class="comment-type-2">انتقد</span> قول مَن قال: إنها النهار كلّه. بقوله: «وهذا قول ضعيف».</p><p>و<span class="comment-type-4">قال</span> <u>ابنُ كثير</u> (١٤/٢٩٦): «فالشَّفَق هو: حُمرة الأُفُق إمّا قبل طلوع الشمس -<span class="mustanad">كما قاله مجاهد</span>- وإمّا بعد غروبها -<span class="mustanad">كما هو معروف عند أهل اللغة</span>-. قال الخليل بن أحمد: الشَّفَق: الحُمرة من غروب الشمس إلى وقت العشاء الآخرة. فإذا ذهب قيل: غاب الشَّفَق. وقال الجوهري: الشَّفَق: بقية ضوء الشمس وحُمرتها في أول الليل إلى قريب من العَتمة. وكذا قال عكرمة: الشَّفَق: الذي يكون بين المغرب والعشاء. وفي صحيح مسلم، عن عبد الله بن عمرو، <span class="mustanad">عن رسول الله</span> ﷺ أنه قال: «<b>وقتُ المغرب ما لم يغب الشَّفَق</b>»».</div></p></div>",footnotes:1:عزاه السيوطي إلى سمويه في فوائده.|2:أخرجه عبد الرزاق ٢/٣٥٩ -وفيه: عن معمر، عن ابن خثيم، عن ابن لهيعة!-. وعزاه السيوطي إلى ابن أبي حاتم.|3:عزاه السيوطي إلى ابن أبي حاتم.|4:أخرجه عبد الرزاق (٢١٢٢)، وابن أبي شيبة ١/٣٣٣. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.|5:أخرجه عبد الرزاق ٢/٣٥٩.|6:أخرجه ابن أبي شيبة ١/٣٣٣، وابن جرير ٢٤/٢٤٤ بنحوه.|7:تفسير مجاهد ص٧١٥، وأخرجه عبد الرزاق ٢/٣٥٩، وابن أبي شيبة ٢/٥٣٠، وابن جرير ٢٤/٢٤٤، وكذا أخرجه من طريق منصور بنحوه. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر|8:عزاه السيوطي إلى عبد بن حميد.|9:أخرجه عبد الرزاق ٢/٣٥٩.|10:تفسير مقاتل بن سليمان ٤/٦٣٩.
  84,17,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَٱلَّیۡلِ وَمَا وَسَقَ ۝١٧﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٨٢٢٧٥<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، في قوله: <span class="qpc-hafs">﴿واللَّيْلِ وما وسَقَ﴾</span>، قال: وما دخل فيه{1}. (١٥/٣٢١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٢٧٦<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- في قوله: <span class="qpc-hafs">﴿واللَّيْلِ وما وسَقَ﴾</span>، قال: وما جمع{2}. (١٥/٣٢١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٢٧٧<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>: أنه سُئِل عن قوله: <span class="qpc-hafs">﴿واللَّيْلِ وما وسَقَ﴾</span>. قال: وما جمع، أما سمعتَ قوله:</p><p>إنّ لنا قلائِصًا نقانِقا{3} مستوسقات لو يجدن سائقا؟{4}. (١٥/٣٢٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٢٧٨<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جُبَير</span>، <span class="qpc-hafs">﴿وما وسَقَ﴾</span>، قال: ما عُمل فيه{5}. (١٥/٣٢١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٢٧٩<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جُبَير</span> -من طريق أبي الهيثم- <span class="qpc-hafs">﴿واللَّيْلِ وما وسَقَ﴾</span>: وما جمع{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٢٨٠<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- <span class="qpc-hafs">﴿واللَّيْلِ وما وسَقَ﴾</span>، قال: وما جمع. يقول: ما آوى فيه مِن دابّة{7}. (١٥/٣٢١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٢٨١<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق شيبان، عن منصور- <span class="qpc-hafs">﴿واللَّيْلِ وما وسَقَ﴾</span>، يقول: والليلِ، وما لُفّ عليه{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٢٨٢<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق سفيان، عن منصور- <span class="qpc-hafs">﴿واللَّيْلِ وما وسَقَ﴾</span>، قال: وما أظلم عليه، وما أدخل فيه{9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٢٨٣<span class="dash">-</span></span> عن <span class="name-2">الضَّحّاك بن مُزاحِم</span> -من طريق عبيد- في قوله: <span class="qpc-hafs">﴿واللَّيْلِ وما وسَقَ﴾</span>، قال: ما ساق معه مِن ظُلمةٍ إذا أقبل{10}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٢٨٤<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span>، <span class="qpc-hafs">﴿واللَّيْلِ وما وسَقَ﴾</span>، قال: وما جمع مِن حيّاته، وعقاربه، ودوابّه{11}. (١٥/٣٢١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٢٨٥<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span> -من طريق حسين- أنه سُئل: <span class="qpc-hafs">﴿واللَّيْلِ وما وسَقَ﴾</span>. قال: ما ساق مِن ظُلمة، فإذا كان الليل ذهب كلّ شيء إلى مأواه{10}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٢٨٦<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق أبي رجاء- أنّ حفصًا سأله عن قوله: <span class="qpc-hafs">﴿واللَّيْلِ وما وسَقَ﴾</span>. قال: وما جمع{13}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٢٨٧<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- قوله: <span class="qpc-hafs">﴿واللَّيْلِ وما وسَقَ﴾</span>، يقول: وما جمع مِن نجمٍ، أو دابّة{14}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٢٨٨<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: قال: <span class="qpc-hafs">﴿واللَّيْلِ وما وسَقَ﴾</span> ما ساق مِن الظُّلمة{15}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٢٨٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن حيّان</span>: <span class="qpc-hafs">﴿واللَّيْلِ وما وسَقَ﴾</span> أقبل مِن ظُلمة أو كوكب{16}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٢٩٠<span class="dash">-</span></span> قال <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿واللَّيْلِ وما وسَقَ﴾</span>، قال: وما جَمع، مجتمع فيه الأشياء التي يجمعها الله، التي تأوي إليه، وأشياء تكون في الليل لا تكون في النهار، ما جَمع مما فيه ما يأوي إليه، فهو مما جَمع{6}<span class=comment-ref>٧٠٩٨</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٧٠٩٨</span> <span class="comment-type-4">بيّن</span> <u>ابنُ جرير</u> (٢٤/٢٤٥ بتصرف) -<span class="mustanad">مستندًا إلى اللغة، والسنة، وأقوال السلف</span>- أنّ قوله: <span class="qpc-hafs">﴿وسق﴾</span> معناه: جمع، فقال: «وقوله: <span class="qpc-hafs">﴿والليل وما وسق﴾</span> يقول: والليل وما جمع مما سكن وهدأ فيه مِن ذي روح كان يطير، أو يدبّ نهارًا، يقال منه: وسقته أسقه وسقًا، ومنه: طعام موسوق، وهو المجموع في غرائر أو وعاء، ومنه: الوسق، وهو الطعام المجتمع الكثير، وبه جاء الخبر عن رسول الله ﷺ، وبنحو الذي قلنا في ذلك قال أهل التأويل». وذكر الآثار على ذلك، ثم <span class="comment-type-4">ذكر</span> قول مَن قال معناه: ساق. ولم يعلّق عليه.</div></p></div>",footnotes:1:أخرجه سعيد بن منصور -كما في فتح الباري ٨/٦٩٧-. وعزاه السيوطي إلى ابن أبي حاتم.|2:أخرجه ابن أبي شيبة ٢/٢٣٥، وابن جرير ٢٤/٢٤٥. وعزاه السيوطي إلى أبي عبيد في فضائله، وابن المنذر.|3:النقانق: جمع النقنق، أي: الظليم، وهو الذكر من النعام. التاج (نقق، ظلم).|4:عزاه السيوطي إلى عبد بن حميد، وابن الأنباري، وقال: من طرق. وأخرج نحوه ابن جرير ٢٤/٢٤٧ من طريق ابن أبي مليكة.|5:عزاه السيوطي إلى عبد بن حميد، وابن المنذر.|6:أخرجه ابن جرير ٢٤/٢٤٧.|7:تفسير مجاهد ص٧١٥، وأخرجه ابن جرير ٢٤/٢٤٦. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.|8:تفسير مجاهد ص٧١٥، وأخرجه ابن جرير ٢٤/٢٤٧ من طريق جرير، عن منصور.|9:أخرجه ابن جرير ٢٤/٢٤٦.|10:أخرجه ابن جرير ٢٤/٢٤٨.|11:أخرجه ابن جرير ٢٤/٢٤٧ بنحوه. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.|12:أخرجه ابن جرير ٢٤/٢٤٨.|13:أخرجه آدم بن أبي إياس -كما في تفسير مجاهد ص٧١٥-، وابن جرير ٢٤/٢٤٦.|14:أخرجه ابن جرير ٢٤/٢٤٦، كما أخرجه عبد الرزاق ٢/٣٥٨ من طريق معمر مقتصرًا على قوله: وما جمع.|15:تفسير مقاتل بن سليمان ٤/٦٣٩.|16:تفسير البغوي ٨/٣٧٥.|17:أخرجه ابن جرير ٢٤/٢٤٧.
  84,18,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَٱلۡقَمَرِ إِذَا ٱتَّسَقَ ۝١٨﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٨٢٢٩١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- <span class="qpc-hafs">﴿والقَمَرِ إذا اتَّسَقَ﴾</span>، قال: إذا استوى{1}. (١٥/٣٢١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٢٩٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق الضَّحّاك- أنّ نافع بن الأزرق سأله عن قوله: <span class="qpc-hafs">﴿والقَمَرِ إذا اتَّسَقَ﴾</span>. قال: اتِّساقه: اجتماعه. قال: وهل تعرفُ العربُ ذلك؟ قال: نعم، أما سمعتَ قول ابن صِرْمة:</p><p>إنّ لنا قلائصًا نقانقا مستوسقات لو يجدن سائقا؟{2}. (١٥/٣٢١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٢٩٣<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، <span class="qpc-hafs">﴿والقَمَرِ إذا اتَّسَقَ﴾</span>، قال: ليلة ثلاث عشرة{3}. (١٥/٣٢٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٢٩٤<span class="dash">-</span></span> قال <span class="name-2">مُرّة الهَمداني</span>: <span class="qpc-hafs">﴿والقَمَرِ إذا اتَّسَقَ﴾</span> ارتفع، وهو في الأيام البيض{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٢٩٥<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جُبَير</span> -من طريق جعفر- في قوله: <span class="qpc-hafs">﴿والقَمَرِ إذا اتَّسَقَ﴾</span>، قال: لثلاث عشرة{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٢٩٦<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- <span class="qpc-hafs">﴿إذا اتَّسَقَ﴾</span>، قال: إذا استوى{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٢٩٧<span class="dash">-</span></span> عن <span class="name-2">الضَّحّاك بن مُزاحِم</span> -من طريق عبيد- في قوله: <span class="qpc-hafs">﴿والقَمَرِ إذا اتَّسَقَ﴾</span>، قال: إذا اجتمع فاستوى{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٢٩٨<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span> -من طريق سماك- <span class="qpc-hafs">﴿والقَمَرِ إذا اتَّسَقَ﴾</span>، قال: إذا استوى{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٢٩٩<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق أبي رجاء- أن حفصًا سأله عن قوله: <span class="qpc-hafs">﴿والقَمَرِ إذا اتَّسَقَ﴾</span>. قال: إذا اجتمع؛ إذا امتلأ{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٣٠٠<span class="dash">-</span></span> عن <span class="name-2">عطاء</span> -من طريق ابن شيبة- <span class="qpc-hafs">﴿والقمر إذا اتسق﴾</span>، قال: إذا جمع، واستوى{10}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٣٠١<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- <span class="qpc-hafs">﴿والقَمَرِ إذا اتَّسَقَ﴾</span>، قال: إذا استدار{11}. (١٥/٣٢٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٣٠٢<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span>، مثله{3}. (١٥/٣٢٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٣٠٣<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله تعالى: <span class="qpc-hafs">﴿إذا اتَّسَقَ﴾</span>، قال: إذا استوى{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٣٠٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿والقَمَرِ إذا اتَّسَقَ﴾</span> في ليلة ثلاث عشرة، وأربع عشرة، وخمس عشرة؛ فهُنّ البيض، فهو يستوي في الشهر ثلاث ليال يشتدّ ضوءه، ويجتمع من ثلاث عشرة، فأقسم الله ﷿ بالشَّفَق، والليل وما وسق، والقمر إذا اتسق{14}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٣٠٥<span class="dash">-</span></span> قال <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿والقَمَرِ إذا اتَّسَقَ﴾</span>، قال: إذا استوى{7}<span class=comment-ref>٧٠٩٩</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٧٠٩٩</span> ذكر <u>ابنُ كثير</u> (١٤/٢٩٧) قول مَن فسر <span class="qpc-hafs">﴿اتسق﴾</span> باستوى، ومَن فسره باجتمع، ومَن فسره باستدار. ثم <span class="comment-type-4">علّق</span> قائلًا: «ومعنى كلامهم: أنه إذا تكامل نوره وأبدر، جعله مقابلًا لليل وما وسق».</div></p></div>",footnotes:1:أخرجه ابن جرير ٢٤/٢٤٨-٢٤٩، ومن طريق عطية أيضًا. وعزاه السيوطي إلى عبد بن حميد، وابن أبي حاتم.|2:أخرجه الطستي في مسائل نافع (٩)، والطبراني في المعجم الكبير ١٠/٢٤٨-٢٥٦ (١٠٥٩٧). وعزاه السيوطي إلى ابن الأنباري في الوقف والابتداء. وأخرجه ابن الأنباري في الوقف والابتداء ١/٩٦ (١١٦) لكن بنسبة البيت إلى أبي طالب.|3:عزاه السيوطي إلى عبد بن حميد.|4:تفسير الثعلبي ١٠/١٦١.|5:أخرجه ابن جرير ٢٤/٢٤٩.|6:تفسير مجاهد ص٧١٥، وأخرجه ابن جرير ٢٤/٢٤٩.|7:أخرجه ابن جرير ٢٤/٢٥٠.|8:أخرجه ابن جرير ٢٤/٢٤٩.|9:أخرجه ابن جرير ٢٤/٢٤٩.|10:أخرجه أبو الشيخ في العظمة ٤/١٢٠٢ (٦٧٥).|11:أخرجه عبد الرزاق ٢/٣٥٨، وابن جرير ٢٤/٢٥٠. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.|12:عزاه السيوطي إلى عبد بن حميد.|13:أخرجه ابن جرير ٢٤/٢٥٠.|14:تفسير مقاتل بن سليمان ٤/٦٣٩-٦٤٠.|15:أخرجه ابن جرير ٢٤/٢٥٠.
  84,19,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿لَتَرۡكَبُنَّ طَبَقًا عَن طَبَقࣲ ۝١٩﴾</span> - قراءات</h3></p><p><div></p><p><p><span class="item-no">٨٢٣٠٦<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن مسعود</span> -من طريق الأسود- أنه قرأ: ‹لَتَرْكَبَنَّ طَبَقًا عَن طَبَقٍ› بالنصب{1}. (١٥/٣٢٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٣٠٧<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق مجاهد- أنه كان يقرأ: ‹لَتَرْكَبَنَّ طَبَقًا عَن طَبَقٍ› يعني: بفتح الباء. قال: هذا نبيّكم ﷺ، حالًا بعد حال{2}. (١٥/٣٢٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٣٠٨<span class="dash">-</span></span> عن <span class="name-2">أبي العالية الرِّياحيّ</span> أنه قرأ: ‹لَتَرْكَبَنَّ طَبَقًا› بالنصب{3}. (١٥/٣٢٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٣٠٩<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق أبي عمرو بن العلاء- أنه قرأ: ‹لَتَرْكَبَنَّ طبقًا› بالنصب{3}. (١٥/٣٢٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٣١٠<span class="dash">-</span></span> عن <span class="name-2">عاصم</span> أنه قرأ: <span class="qpc-hafs">﴿لَتَرْكَبُنَّ﴾</span> بالتاء ورفع الباء، على الجماع{3}. (١٥/٣٢٥)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿لَتَرۡكَبُنَّ طَبَقًا عَن طَبَقࣲ ۝١٩﴾</span> - تفسير الآية</h3></p><p><div></p><p><p><span class="item-no">٨٢٣١١<span class="dash">-</span></span> عن <span class="name-1">عمر بن الخطاب</span>، في قوله: <span class="qpc-hafs">﴿لَتَرْكَبُنَّ طَبَقًا عَن طَبَقٍ﴾</span>، قال: حالًا بعد حال{3}. (١٥/٣٢٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٣١٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن مسعود</span> -من طريق الأسود- أنه قرأ: ‹لَتَرْكَبَنَّ طَبَقًا عَن طَبَقٍ› بالنصب{7}: لتَرْكَبَنَّ -يا محمد- سماءً بعد سماء{8}. (١٥/٣٢٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٣١٣<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن مسعود</span> -من طريق علقمة- ‹لَتَرْكَبَنَّ طَبَقًا عَن طَبَقٍ›: يا محمد، حالًا بعد حال{9}. (١٥/٣٢٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٣١٤<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن مسعود</span> -من طريق إبراهيم- في قوله: ‹لَتَرْكَبَنَّ طَبَقًا عَن طَبَقٍ›، قال: يعني: السماء؛ تنفطر، ثم تنشقّ، ثم تحمرّ{10}. (١٥/٣٢٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٣١٥<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن مسعود</span> -من طريق مُرّة- في الآية، قال: السماء تكون ألوانًا؛ كالمُهلِ، وتكون وردةً كالدِّهانِ، وتكون واهيةً، وتشقق فتكون حالًا بعد حال{11}. (١٥/٣٢٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٣١٦<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عمرو بن دينار- <span class="qpc-hafs">﴿لَتَرْكَبُنَّ طَبَقًا عَن طَبَقٍ﴾</span>: الشدائد والأهوال؛ الموت، ثم البعث، ثم العرض{12}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٣١٧<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق مجاهد- أنه كان يقرأ: ‹لَتَرْكَبَنَّ طَبَقًا عَن طَبَقٍ›، يعني: بفتح الباء. قال: هذا نبيُّكم ﷺ، حالًا بعد حال{13}<span class=comment-ref>٧١٠٠</span>. (١٥/٣٢٣)</p></p><p></div></p><p><div><span class=comment-ref>٧١٠٠</span> ذكر <u>ابنُ كثير</u> (١٤/٢٩٧-٢٩٨) قول ابن عباس، و<span class="comment-type-1">وجّهه</span>، فقال: «وهو محتمل أن يكون ابن عباس أسند هذا التفسير عن النبي ﷺ، كأنه قال: سمعتُ هذا من نبيّكم ﷺ، فيكون قوله:»نبيّكم«مرفوعًا على الفاعلية مِن»قال«وهو الأظهر، والله أعلم، كما قال أنس: لا يأتي عام إلا والذي بعده شر منه، سمعته من نبيّكم ﷺ... ويحتمل أنْ يكون المراد: <span class="qpc-hafs">﴿لتركبن طبقا عن طبق﴾</span> حالًا بعد حال. قال: هذا، يعني المراد بهذا: نبيّكم ﷺ، فيكون مرفوعًا على أنّ»هذا«و»نبيّكم«يكونان مبتدأ وخبرًا، والله أعلم. ولعلّ هذا قد يكون هو المتبادر إلى كثير من الرواة، كما قال أبو داود الطيالسي وغندر: حدثنا شعبة، عن أبي بشر، عن سعيد بن جُبَير، عن ابن عباس: <span class="qpc-hafs">﴿لتركبن طبقا عن طبق﴾</span>، قال: محمد ﷺ. <span class="mustanad">ويؤيد هذا المعنى قراءة عمر، وابن مسعود، وابن عباس، وعامة أهل مكة والكوفة</span>: ‹لَتَرْكَبَنَّ› بفتح التاء والباء».</div></p><p><div></p><p><p><span class="item-no">٨٢٣١٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق مجاهد- ‹لَتَرْكَبَنَّ طَبَقًا عَن طَبَقٍ›، قال: يا محمد، السماء طبقًا بعد طبق{14}. (١٥/٣٢٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٣١٩<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطية العَوفيّ- ‹لَتَرْكَبَنَّ طَبَقًا عَن طَبَقٍ›: يعني: منزلًا بعد منزل، ويقال: أمرًا بعد أمر، وحالًا بعد حال{15}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٣٢٠<span class="dash">-</span></span> عن <span class="name-2">مسروق بن الأجْدع الهَمداني</span> -من طريق أبي الضحى- ‹لَتَرْكَبَنَّ طَبَقًا عَن طَبَقٍ›، قال: أنت، يا محمد؛ سماء عن سماء{16}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٣٢١<span class="dash">-</span></span> عن <span class="name-2">مُرّة بن شراحيل الهَمداني</span> -من طريق موسى بن أبي عائشة- أنه سأله عن قوله: ‹لَتَرْكَبَنَّ طَبَقًا عَن طَبَقٍ›، قال: حالًا بعد حال{17}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٣٢٢<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جُبَير</span>، <span class="qpc-hafs">﴿لَتَرْكَبُنَّ طَبَقًا عَنْ طَبَقٍ﴾</span>، قال: قوم كانوا في الدنيا خسيس أمرهم، فارتفعوا في الآخرة، وقوم كانوا في الدنيا أشرافًا فاتَّضعوا في الآخرة{18}. (١٥/٣٢٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٣٢٣<span class="dash">-</span></span> عن <span class="name-2">سعيد [بن جُبَير]</span> -من طريق جعفر- <span class="qpc-hafs">﴿لَتَرْكَبُنَّ طَبَقًا عَن طَبَقٍ﴾</span>، قال: حالًا بعد حال{19}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٣٢٤<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق منصور- في قوله: <span class="qpc-hafs">﴿لَتَرْكَبُنَّ طَبَقًا عَن طَبَقٍ﴾</span>، قال: أمرًا بعد أمر{20}. (١٥/٣٢٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٣٢٥<span class="dash">-</span></span> قال <span class="name-2">مجاهد بن جبر</span>: <span class="qpc-hafs">﴿طَبَقًا عَن طَبَقٍ﴾</span> سماء بعد سماء{21}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٣٢٦<span class="dash">-</span></span> عن <span class="name-2">الضَّحّاك بن مُزاحِم</span> -من طريق عبيد- في قوله: <span class="qpc-hafs">﴿لَتَرْكَبُنَّ طَبَقًا عَن طَبَقٍ﴾</span>: منزلًا بعد منزل، وحالًا بعد حال{22}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٣٢٧<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span> -من طريق سِماك- في قوله: ‹لَتَرْكَبَنَّ طَبَقًا عَن طَبَقٍ›، قال: حالًا بعد حال{19}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٣٢٨<span class="dash">-</span></span> عن <span class="name-2">عامر الشعبي</span> -من طريق إسماعيل- ‹لَتَرْكَبَنَّ طَبَقًا عَن طَبَقٍ›، قال: لتَرْكَبَنّ -يا محمد- سماء بعد سماء{24}. (١٥/٣٢٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٣٢٩<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق أبي رجاء- أنّ حفصًا سأله عن قوله: <span class="qpc-hafs">﴿لَتَرْكَبُنَّ طَبَقًا عَنْ طَبَقٍ﴾</span>. قال: منزلًا عن منزل، وحالًا عن حال{25}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٣٣٠<span class="dash">-</span></span> قال <span class="name-2">الحسن البصري</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٣٣١<span class="dash">-</span></span> و<span class="name-2">أبو العالية الرِّياحيّ</span> -من طريق قتادة-: ‹لَتَرْكَبَنَّ› يعني: محمدًا ﷺ، <span class="qpc-hafs">﴿طَبَقًا عَنْ طَبَقٍ﴾</span> السموات{22}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٣٣٢<span class="dash">-</span></span> قال <span class="name-2">عطاء</span>: <span class="qpc-hafs">﴿لَتَرْكَبُنَّ طَبَقًا عَنْ طَبَقٍ﴾</span> مرةً فقرًا، ومرةً غِنًى{12}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٣٣٣<span class="dash">-</span></span> عن <span class="name-2">مكحول الشامي</span> -من طريق ابن جابر- في قوله: <span class="qpc-hafs">﴿لَتَرْكَبُنَّ طَبَقًا عَنْ طَبَقٍ﴾</span>، قال: في كلّ عشرين عامًا تُحْدِثُون أمرًا لم تكونوا عليه{28}. (١٥/٣٢٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٣٣٤<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في الآية، قال: حالًا عن حال، بينما صاحب الدنيا في رخاء إذ صار في بلاء، وبينما هو في بلاء إذ صار في رخاء{20}. (١٥/٣٢٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٣٣٥<span class="dash">-</span></span> عن <span class="name-2">عطاء الخُراسانيّ</span> -من طريق يونس بن يزيد- في قول الله ﷿: <span class="qpc-hafs">﴿لتركبن طبقا عن طبق﴾</span>: حالًا عبر حال، ومنازلًا عبر منازل{30}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٣٣٦<span class="dash">-</span></span> قال <span class="name-3">محمد بن السّائِب الكلبي</span> -من طريق محمد بن مروان- <span class="qpc-hafs">﴿طَبَقًا عَنْ طَبَقٍ﴾</span>: حالًا بعد حال، وأمرًا بعد أمر في مواقف يوم القيامة{31}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٣٣٧<span class="dash">-</span></span> عن <span class="name-3">محمد بن السّائِب الكلبي</span> -من طريق حيان- <span class="qpc-hafs">﴿لَتَرْكَبُنَّ طَبَقًا عَنْ طَبَقٍ﴾</span>: مرة يَعرفون، ومرة يَجهلون{32}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٣٣٨<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿لَتَرْكَبُنَّ﴾</span> هذا العبد <span class="qpc-hafs">﴿طَبَقًا عَنْ طَبَقٍ﴾</span> حالًا بعد حال؛ خَلْقًا من نُطفة، ثم صارت النُّطفة عَلقة، ثم صارت العَلقة مُضغة، ثم صارت إنسانًا ميتًا في بطن أمه، حتى نُفخ فيه الروح، ثم صار إنسانًا حيًّا، ثم أخرجه الله تعالى مِن بطن أمه، فكان طفلًا، ثم يبلغ أشده، ثم شاخ وكبر، ثم مات ولبث في قبره حتى صار ترابًا، ثم أنشأه الله ﷿ بعد ذلك يوم القيامة{33}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٣٣٩<span class="dash">-</span></span> قال <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: ‹لَتَرْكَبَنَّ طَبَقًا عَن طَبَقٍ›، قال: الآخرة بعد الأولى{34}<span class=comment-ref>٧١٠١</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٧١٠١</span> اختُلف في قراءة قوله: <span class="qpc-hafs">﴿لتركبن طبقا عن طبق﴾</span> وفي المراد به على أقوال:</p><p>- <b>فعلى قراءة مَن قرأ ذلك: ‹لتركبَنَّ›</b> بفتح الباء وفي معناها أربعة أقوال: <b>الأول</b>: لتركبَنَّ -يا محمد- حالًا بعد حال، وأمرًا بعد أمر من الشدائد. <b>الثاني</b>: لتركبَنَّ -يا محمد- سماء بعد سماء. <b>الثالث</b>: لتركبَنَّ الآخرة بعد الأولى. <b>الرابع</b>: أنّ الإشارة إلى السماء، والمراد: أنها تتغير ضروبًا من التغيير، فتارة كالمُهل وتارة كالدّهان.</p><p>و<span class="comment-type-4">ذكر</span> <u>ابنُ القيم</u> (٣/٢٧٤) أنه على الثلاثة الأولى فالتاء للمخاطب، وعلى القول الرابع فالتاء للغيبة.</p><p>وزاد <u>ابنُ عطية</u> (٨/٥٧٣) معنًى آخر على هذه القراءة، و<span class="comment-type-1">وجّهه</span>، فقال: «وقيل: هي عِدة بالنصر، أي: لتركبن أمر العرب قبيلًا بعد قبيل، وفتحًا بعد فتح، كما كان ووجد بعد ذلك».</p><p>وبيّن <u>ابنُ كثير</u> (١٤/٢٩٨-٢٩٩) أنّ قول مَن قال: معناه: سماء بعد سماء. فإنما عنى به ليلة الإسراء.</p><p>و<span class="comment-type-4">علّق</span> <u>ابنُ القيم</u> على القول الرابع بقوله: «ودل على السماء ذِكر الشَّفَق والقمر». ثم <span class="comment-type-1">وجّهه</span> بقوله: «وعلى هذا فيكون قسمًا على المعاد وتغيير العالم».</p><p>- <b>وعلى قراءة مَن قرأ ذلك: <span class="qpc-hafs">﴿لتركبُنَّ﴾</span></b> بضم الباء على وجه الخطاب للناس كافة، يكون المعنى: لتركبُنَّ -أيها الناس- حالًا بعد حال، وأمرًا بعد أمر؛ من الفقر والغنى، أو من الشدائد والموت والبعث والحساب، أو من النُّطفة إلى الهرم، أو منزلة بعد منزلة مِن الرفعة والضّعة.</p><p>وزاد <u>ابنُ عطية</u> معنيين آخرين على هذه القراءة، <b>الأول</b>: أنّ المعنى: لتركبُنَّ هذه الأحوال أُمّة بعد أُمّة. و<span class="comment-type-4">علّق</span> عليه قائلًا: "<span class="mustanad">ومنه قول العباس بن عبد المطلب</span> عن النبي ﵇:</p><p>وأنت لما بُعثتَ أشرقت الأ ... رض وضاءت بنورك الطرق</p><p>تنقل من صالب إلى رحم ... إذا مضى علم بدا طبق".</p><p>و<b>الثاني</b>: «لتركبُنَّ سنن من قبلكم». و<span class="comment-type-4">علّق</span> عليه بقوله: «<span class="mustanad">كما جاء في الحديث</span>: «<b>شبرًا بشبر، وذراعًا بذراع، فهذا هو طبق عن طبق</b>»».</p><p>و<span class="comment-type-4">بنحوه</span> قال <u>ابنُ كثير</u>، وعزاه للسُّدِّيّ.</p><p>وذكر <u>ابنُ عطية</u> أنّ هذا المعنى يلتئم مع قراءة عمر بن الخطاب (لَيَرْكَبُنَّ).</p><p>وقد <span class="comment-type-3">رجّح</span> <u>ابنُ جرير</u> (٢٤/٢٥٦) -<span class="mustanad">مستندًا إلى أقوال السلف</span>- قراءة: ‹لَتَرْكَبَنَّ› وأنّ المعنى: لتركبَن أنت -يا محمد- حالًا بعد حال، وأمرًا بعد أمر من الشدائد. فقال: «وأولى القراءات في ذلك عندي بالصواب: قراءة مَن قرأ بالتاء وبفتح الباء؛ لأن تأويل أهل التأويل من جميعهم بذلك ورد، وإن كان للقراءات الأُخر وجوه مفهومة. وإذا كان الصواب من القراءة في ذلك ما ذكرنا فالصواب من التأويل قول مَن قال: ‹لَتَرْكَبَنَّ› أنت -يا محمد- حالًا بعد حال، وأمرًا بعد أمر من الشدائد». ثم <span class="comment-type-4">بيّن</span> أنه وإن كان الخطاب إلى رسول الله ﷺ، فليس خاصًّا به، بل خوطب به جميع الناس أنهم يَلقون من شدائد يوم القيامة وأهواله أحوالًا؛ <span class="mustanad">وذلك لدلالة السياق</span>، فقال: «وإنما قلنا: عني بذلك ما ذكرنا، أنّ الكلام قبل قوله: <span class="qpc-hafs">﴿لتركبن طبقا عن طبق﴾</span> جرى بخطاب الجميع، وكذلك بعده، فكان أشبه أن يكون ذلك نظير ما قبله وما بعده».</div></p></div>",footnotes:1:أخرجه الطبراني (١٠٠٦٨). وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، والحاكم في الكنى، وابن منده في غرائب شعبة، وابن مردويه.</p><p>وهي قراءة متواترة، قرأ بها ابن كثير، وحمزة، والكسائي، وخلف، وقرأ بقية العشرة: <span class="qpc-hafs">﴿لَتَرْكَبُنَّ﴾</span> بضم الباء. انظر: النشر ٢/٣٩٩، والإتحاف ص٥٧٧.|2:أخرجه أبو عبيد -كما في فتح الباري ٨/٦٩٨-، وابن منيع -كما في المطالب العالية (٤١٧٨)-، وابن جرير ٢٤/٢٥١. وعزاه السيوطي إلى سعيد بن منصور، وعبد بن حميد، وابن المنذر، وابن مردويه.|3:عزاه السيوطي إلى عبد بن حميد.|4:عزاه السيوطي إلى عبد بن حميد.|5:عزاه السيوطي إلى عبد بن حميد.|6:عزاه السيوطي إلى عبد بن حميد.|7:أي: بفتح الباء؛ وهي قراءة ابن كثير وحمزة والكسائي وخلف، وقرأ الباقون بضمها. ينظر: النشر ٢/٢٩٨.|8:أخرجه الطبراني (١٠٠٦٨). وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، والحاكم في الكنى، وابن منده في غرائب شعبة، وابن مردويه.|9:أخرجه البزار (١٦٠٢).|10:أخرجه عبد الرزاق ٢/٣٥٩، وابن جرير ٢٤/٢٥٥، والحاكم ٢/٥١٨. وعزاه السيوطي إلى الفريابي، وسعيد بن منصور، وعبد بن حميد، وابن المنذر، وابن أبي حاتم، وابن مردويه، والبيهقي في البعث.|11:أخرجه آدم ابن إياس -كما في تفسير مجاهد ص٧١٦-. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، والبيهقي.|12:تفسير الثعلبي ١٠/١٦١، وتفسير البغوي ٨/٣٧٦.|13:أخرجه آدم بن أبي إياس -كما في تفسير مجاهد ص٧١٥- من طريق عكرمة، وأبو عبيد -كما في فتح الباري ٨/٦٩٨-، وابن منيع -كما في المطالب العالية (٤١٧٨)-، وابن جرير ٢٤/٢٥١، والبخاري (٤٩٤٠). وعزاه السيوطي إلى سعيد بن منصور، وعبد بن حميد، وابن المنذر، وابن مردويه.|14:أخرجه الطيالسي -كما في تفسير ابن كثير ٨/٣٨١-، والطبراني (١١١٧٣). وعزاه السيوطي إلى عبد بن حميد، وابن أبي حاتم.|15:أخرجه ابن جرير ٢٤/٢٥١، وكذلك من طريق أبي إسحاق، عن رجل حدَّثه.|16:أخرجه آدم ابن أبي إياس -كما في تفسير مجاهد ص٧١٦-، وابن جرير ٢٤/٢٥٣.|17:أخرجه عبد الرزاق ٢/٣٥٩، وابن جرير ٢٤/٢٥٢.|18:عزاه السيوطي إلى ابن المنذر.|19:أخرجه ابن جرير ٢٤/٢٥٢.|20:أخرجه عبد الرزاق ٢/٣٥٩، وابن جرير ٢٤/٢٥٣. وعزاه السيوطي إلى عبد بن حميد.|21:تفسير البغوي ٨/٣٧٥.|22:أخرجه ابن جرير ٢٤/٢٥٣.|23:أخرجه ابن جرير ٢٤/٢٥٢.|24:أخرجه ابن جرير ٢٤/٢٥٤ بنحوه، وابن أبي حاتم -كما في تفسير ابن كثير ٨/٣٨١-. وعزاه السيوطي إلى عبد بن حميد.|25:أخرجه ابن جرير ٢٤/٢٥٢. وذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٥/١١٣-.|26:أخرجه ابن جرير ٢٤/٢٥٣.|27:تفسير الثعلبي ١٠/١٦١، وتفسير البغوي ٨/٣٧٦.|28:أخرجه ابن أبي حاتم -كما في تفسير ابن كثير ٨/٣٨٢-، ونعيم بن حماد (٤٢)، وأبو نعيم في الحلية ٥/١٨٤. وعزاه السيوطي إلى ابن المنذر.|29:أخرجه عبد الرزاق ٢/٣٥٩، وابن جرير ٢٤/٢٥٣. وعزاه السيوطي إلى عبد بن حميد.|30:أخرجه أبو جعفر الرملي في جزئه (تفسير عطاء) ص١٠٠.|31:تفسير الثعلبي ١٠/١٦١، وفي تفسير البغوي ٨/٣٧٥ بلفظ: يعني: تصعد فيها.|32:تفسير الثعلبي ١٠/١٦١.|33:تفسير مقاتل بن سليمان ٤/٦٤٠.|34:أخرجه ابن جرير ٢٤/٢٥٤.
  84,20,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿فَمَا لَهُمۡ لَا یُؤۡمِنُونَ ۝٢٠﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٨٢٣٤٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: قال: <span class="qpc-hafs">﴿فَما لَهُمْ لا يُؤْمِنُونَ﴾</span> بالبعث، <span class="qpc-hafs">﴿و﴾</span>قد كانوا من قبل هذا الذي وصفته <span class="qpc-hafs">﴿إذا قُرِئَ عَلَيْهِمُ القُرْآنُ لا يَسْجُدُونَ﴾</span>{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٣٤١<span class="dash">-</span></span> قال <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿فَما لَهُمْ لا يُؤْمِنُونَ﴾</span>، قال: بهذا الحديث، وبهذا الأمر{2}<span class=comment-ref>٧١٠٢</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٧١٠٢</span> لم يذكر <u>ابنُ جرير</u> (٢٤/٢٥٧) غير قول عبد الرحمن بن زيد.</div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٤/٦٤٠.|2:أخرجه ابن جرير ٢٤/٢٥٧.
  84,21,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَإِذَا قُرِئَ عَلَیۡهِمُ ٱلۡقُرۡءَانُ لَا یَسۡجُدُونَ﴾</span> - نزول الآية</h3></p><p><div></p><p><p><span class="item-no">٨٢٣٤٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وإذا قُرِئَ عَلَيْهِمُ القُرْآنُ لا يَسْجُدُونَ﴾</span> وذلك أنّ رسول الله ﷺ قرأ ذات يوم: <span class="qpc-hafs">﴿واسْجُدْ واقْتَرِبْ﴾</span> [العلق:١٩]، فسجد، وسجد المؤمنون معه، وكانت قريش يُصفِّقون فوق رؤوسهم ويُصفِّرون، وكان الذي يُصفّر قريب القرابة من رسول الله ﷺ، فذلك قوله: <span class="qpc-hafs">﴿وما كانَ صَلاتُهُمْ عِنْدَ البَيْتِ إلّا مُكاءً وتَصْدِيَةً﴾</span> [الأنفال:٣٥]، فلما سجد رسول الله ﷺ لم يسجدوا، وسخروا منه، وكان إذا قرأ آذوه بالصَّفير والتصفيق؛ فأنزل الله ﷿: <span class="qpc-hafs">﴿فَما لَهُمْ لا يُؤْمِنُونَ وإذا قُرِئَ عَلَيْهِمُ القُرْآنُ لا يَسْجُدُونَ﴾</span>{1}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَإِذَا قُرِئَ عَلَیۡهِمُ ٱلۡقُرۡءَانُ لَا یَسۡجُدُونَ﴾</span> - تفسير الآية</h3></p><p><div></p><p><p><span class="item-no">٨٢٣٤٣<span class="dash">-</span></span> قال <span class="name-3">محمد بن السّائِب الكلبي</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٣٤٤<span class="dash">-</span></span> و<span class="name-3">مقاتل</span>: <span class="qpc-hafs">﴿وإذا قُرِئَ عَلَيْهِمُ القُرْآنُ لا يَسْجُدُونَ﴾</span> لا يُصَلُّون{2}<span class=comment-ref>٧١٠٣</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٧١٠٣</span> نقل <u>ابنُ تيمية</u> (٦/٤٩٠) في قوله: <span class="qpc-hafs">﴿لا يسجدون﴾</span> قولين: <b>أحدهما</b>: ما جاء في قول مقاتل. <b>الثاني</b>: أنّ معناه: لا يخضعون له، ولا يستكينون له. و<span class="comment-type-4">علّق</span> على الأول بقوله: «القول الأول هو الذي يذكره كثير من المفسرين، لا يذكرون غيره؛ كالثعلبي، والبغوي، وحكوه عن مقاتل والكلبي، وهو المنقول عن مفسري السلف، وعليه عامة العلماء».</p><p>و<span class="comment-type-4">علّق</span> على الثاني بقوله: «وأما القول الثاني فما علمتُ أحدًا نقله عن أحد من السلف، والذين قالوه إنما قالوه لما رأوا أنه لا يجب على كلّ من سمع شيئًا من القرآن أن يسجد، فأرادوا أن يُفسِّروا الآية بمعنى يجب في كلّ حال، فقالوا: يخضعون، ويستكينون. فإنّ هذا يؤمر به كلّ مَن قُرئ عليه القرآن».</div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٤/٦٤٠.|2:تفسير البغوي ٨/٣٧٦.
  84,22,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿بَلِ ٱلَّذِینَ كَفَرُوا۟ یُكَذِّبُونَ ۝٢٢﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٨٢٣٤٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثم قال: <span class="qpc-hafs">﴿بَلِ الَّذِينَ كَفَرُوا﴾</span> يقول: لكن الذين كفروا <span class="qpc-hafs">﴿يُكَذِّبُونَ﴾</span>{1}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٤/٦٤٠.
  84,23,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَٱللَّهُ أَعۡلَمُ بِمَا یُوعُونَ ۝٢٣﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٨٢٣٤٦<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، في قوله: <span class="qpc-hafs">﴿واللَّهُ أعْلَمُ بِما يُوعُونَ﴾</span>، قال: يُسِرُّون{1}. (١٥/٣٢٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٣٤٧<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- <span class="qpc-hafs">﴿واللَّهُ أعْلَمُ بِما يُوعُونَ﴾</span>، قال: يكتمون{2}. (١٥/٣٢٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٣٤٨<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- <span class="qpc-hafs">﴿بِما يُوعُونَ﴾</span>، قال: في صدورهم{3}. (١٥/٣٢٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٣٤٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿واللَّهُ أعْلَمُ بِما يُوعُونَ﴾</span>، يقول: بما يُجْمِعون عليه من الإثم والفسوق{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٣٥٠<span class="dash">-</span></span> قال <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿واللَّهُ أعْلَمُ بِما يُوعُونَ﴾</span>، قال: المرء يوعي متاعه وماله؛ هذا في هذا، وهذا في هذا، هكذا يعرف الله ما يوعون من الأعمال، والأعمال السيئة مما توعيه قلوبهم، ويجتمع فيها من هذه الأعمال الخير والشر، فالقلوب وعاء هذه الأعمال كلّها الخير والشر، يعلم ما يُسرُّون وما يُعلنون، ولقد وعى لكم ما لا يدري أحد ما هو مِن القرآن وغير ذلك، فاتقوا الله وإيّاكم أن تدخلوا على مكارم هذه الأعمال بعض هذا الخبث ما يُفسدها{5}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن أبي حاتم -كما في فتح الباري ٨/٦٩٧-. وعزاه السيوطي إلى ابن المنذر.|2:تفسير مجاهد ص٧١٦، وأخرجه ابن جرير ٢٤/٢٥٧. وعزاه السيوطي إلى عبد بن حميد.|3:أخرجه عبد الرزاق ٢/٣٦٠، وابن جرير ٢٤/٢٥٨.|4:تفسير مقاتل بن سليمان ٤/٦٤٠.|5:أخرجه ابن جرير ٢٤/٢٥٨.
  84,24,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿فَبَشِّرۡهُم بِعَذَابٍ أَلِیمٍ ۝٢٤﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٨٢٣٥١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فَبَشِّرْهُمْ﴾</span> يا محمد <span class="qpc-hafs">﴿بِعَذابٍ ألِيمٍ﴾</span> يقول: عذاب وجيع لأهل مكة كلّهم{1}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٤/٦٤٠.
  84,25,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿إِلَّا ٱلَّذِینَ ءَامَنُوا۟ وَعَمِلُوا۟ ٱلصَّـٰلِحَـٰتِ لَهُمۡ أَجۡرٌ غَیۡرُ مَمۡنُونِۭ ۝٢٥﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٨٢٣٥٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- قوله: <span class="qpc-hafs">﴿لَهُمْ أجْرٌ غَيْرُ مَمْنُونٍ﴾</span>، يقول: غير منقوص{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٣٥٣<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، أنّ نافع بن الأزرق سأله عن قوله: <span class="qpc-hafs">﴿لَهُمْ أجْرٌ غَيْرُ مَمْنُونٍ﴾</span>. قال: غير منقوص. قال: وهل تعرف العرب ذلك؟ قال: نعم، أما سمعتَ قول زُهير:</p><p>فَضْلَ الجوادِ على الخيلِ البِطاءِ فلا يُعطِي بذلك ممنونًا ولا نَزِقا؟{2}. (١٥/٣٢٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٣٥٤<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن جريج- في قوله: <span class="qpc-hafs">﴿لَهُمْ أجْرٌ غَيْرُ مَمْنُونٍ﴾</span>، قال: غير محسوب{3}<span class=comment-ref>٧١٠٤</span>. (١٥/٣٢٦)</p></p><p></div></p><p><div><span class=comment-ref>٧١٠٤</span> لم يذكر <u>ابنُ جرير</u> (٢٤/٢٥٩) غير قول مجاهد، وابن عباس من طريق علي.</div></p><p><div></p><p><p><span class="item-no">٨٢٣٥٥<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span>، في قوله: <span class="qpc-hafs">﴿لَهُمْ أجْرٌ غَيْرُ مَمْنُونٍ﴾</span>، قال: يُعطون أجورهم، ولا يُمَنّ عليهم{4}. (١٥/٣٢٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٢٣٥٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثم استثنى لعِلْمٍ قَد سَبَق، فقال: <span class="qpc-hafs">﴿إلّا الَّذِينَ آمَنُوا وعَمِلُوا الصّالِحاتِ لَهُمْ أجْرٌ غَيْرُ مَمْنُونٍ﴾</span>{5}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ٢٤/٢٥٩.|2:أخرجه الطستي -كما في الإتقان ٢/١٠٢-.|3:أخرجه ابن جرير ٢٤/٢٥٩. وعزاه السيوطي إلى عبد بن حميد.|4:ذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٥/١١٣-. وعزاه السيوطي إلى عبد بن حميد.|5:تفسير مقاتل بن سليمان ٤/٦٤٠.