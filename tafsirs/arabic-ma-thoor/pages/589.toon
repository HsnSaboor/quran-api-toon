tafsir[27]{c,v,t}:
  83,35,""
83,36," <q>﴿هَلۡ ثُوِّبَ ٱلۡكُفَّارُ مَا كَانُوا۟ یَفۡعَلُونَ ۝٣٦﴾</q> - تفسير ٨٢١٧٥- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿هَلْ ثُوِّبَ﴾</q>، قال: جُوزِيَ{1}. (١٥/٣١٢) ٨٢١٧٦- قال مقاتل بن سليمان: <q>﴿هَلْ ثُوِّبَ الكُفّارُ ما كانُوا يَفْعَلُونَ﴾</q>، يعني: ينظرون مِن الكُوى، فإذا رأوهم يُعذَّبون قالوا: واللهِ، قد ثُوِّب الكفار ما كانوا يفعلون{2}. (ز) ٨٢١٧٧- عن سفيان [الثوري] -من طريق مهران- <q>﴿هَلْ ثُوِّبَ الكُفّارُ ما كانُوا يَفْعَلُونَ﴾</q>: حين كانوا يسخرون{3}. (ز) ",footnotes:1:تفسير مجاهد ص٧١٣، وأخرجه ابن جرير ٢٤/٢٢٩. وعزاه السيوطي إلى الفريابي، وعبد بن حميد، وابن المنذر.تفسير مقاتل بن سليمان ٤/٦٢٦.أخرجه ابن جرير ٢٤/٢٢٩.
84,1," مقدمة السورة ٨٢١٧٨- عن عبد الله بن عباس -من طريق مجاهد- قال: نزلت سورة الانشقاق بمكة{1}. (١٥/٣١٣) ٨٢١٧٩- عن عبد الله بن الزُّبير، مثله{2}. (١٥/٣١٣) ٨٢١٨٠- عن عبد الله بن عباس -من طريق عطاء الخُراسانيّ-: مكّيّة، وسمّاها: <q>﴿إذا السَّماءُ انْشَقَّتْ﴾</q>، وذكر أنها نزلت بعد <q>﴿إذا السَّماءُ انْفَطَرَتْ﴾</q>{3}. (ز) ٨٢١٨١- عن عكرمة مولى ابن عباس= (ز) ٨٢١٨٢- والحسن البصري -من طريق يزيد النحوي-: مكّيّة، وسمّياها: <q>﴿إذا السَّماءُ انْشَقَّتْ﴾</q>{4}. (ز) ٨٢١٨٣- عن قتادة بن دعامة -من طرق-: مكّيّة{5}. (ز) ٨٢١٨٤- عن محمد بن مسلم الزُّهريّ: مكّيّة، ونزلت بعد سورة الانفطار{6}. (ز) ٨٢١٨٥- عن علي بن أبي طلحة: مكّيّة{7}. (ز) ٨٢١٨٦- قال مقاتل بن سليمان: سورة الانشقاق مكّيّة، عددها خمس وعشرون آية كوفي{8}٧٠٩١. (ز) ٧٠٩١ قال ابنُ عطية (٨/٥٦٧): «وهي مكّيّة بلا خلاف بين المتأولين». ٨٢١٨٧- عن ابن عمر، قال: قال رسول الله ﷺ: «مَن سَرَّه أن ينظر إلى يوم القيامة كأنه رأي عين فليقرأ: <q>﴿إذا الشَّمْسُ كُوِّرَتْ﴾</q>، و<q>﴿إذا السَّماءُ انْفَطَرَتْ﴾</q>، و<q>﴿إذا السَّماءُ انْشَقَّتْ﴾</q>»{9}. (١٥/٢٥٧) ٨٢١٨٨- عن صفوان بن عَسّال: أنّ رسول الله ﷺ سجد في: <q>﴿إذا السَّماءُ انْشَقَّتْ﴾</q>{10}. (١٥/٣١٣) ٨٢١٨٩- عن أبي هريرة، قال: سجدنا مع رسول الله ﷺ في: <q>﴿إذا السَّماءُ انْشَقَّتْ﴾</q>، و<q>﴿اقْرَأْ بِاسْمِ رَبِّكَ﴾</q>{11}. (١٥/٣١٣) ٨٢١٩٠- عن أبي هريرة -من طريق ابن سيرين- قال: إنّ رجلين اقترآ بـ<q>﴿إذا السَّماءُ انْشَقَّتْ﴾</q>، و<q>﴿اقْرَأْ بِاسْمِ رَبِّكَ﴾</q> .... قال: فسجد أحدهما، ولم يسجد الآخر. قال: الذي سجد أفضلهما أو خيرهما. قال ابن سيرين: إن لم يكن النبي ﵇ وعمر فلا أدري مَن هُما{12}. (ز) ٨٢١٩١- عن أبي رافع، قال: صلّيتُ مع أبي هريرة العَتمة، فقرأ: <q>﴿إذا السَّماءُ انْشَقَّتْ﴾</q> فسجد، فقلت له، فقال: سجدتُ خلف أبي القاسم ﷺ، فلا أزال أسجد فيها حتى ألقاه{13}. (١٥/٣١٣) ٨٢١٩٢- عن زرّ، قال: قرأ عمّار على المنبر: <q>﴿إذا السماء انشقت﴾</q>، فنزل فسجد{14}. (ز) ٨٢١٩٣- عن أبي بشر أنه رأى عمر بن عبد العزيز صلّى العشاء، فقرأ فيها بـ<q>﴿إذا السَّماءُ انْشَقَّتْ﴾</q>، فسجد فيها، وقرأها مرة أخرى، فلم يسجد.= (ز) ٨٢١٩٤- قال: وحدَّثني معاوية بن صالح، عن أبي الزّاهرية، عن جبير بن نفير، عن أبي الدّرداء أنه كان مرة يسجد في: <q>﴿إذا السَّماءُ انْشَقَّتْ﴾</q>، ومرة لا يسجد فيها{15}. (ز) <q>﴿إِذَا ٱلسَّمَاۤءُ ٱنشَقَّتۡ ۝١﴾</q> - نزول الآية ٨٢١٩٥- قال مقاتل بن سليمان: وذلك أنّ أخوين مِن بني أُميّة -أحدهما اسمه: عبد الله بن عبد الأسد، والآخر اسمه: الأسود بن عبد الأسد-؛ أحدهما مؤمن بالله واسمه عبد الله، وأما الآخر فاسمه الأسود وهو الكافر، فقال لأخيه عبد الله: آمنتُ بمحمد؟ قال: نعم. قال: ويحك! إنّ محمدًا يزعم إذا مِتنا وكُنّا ترابًا فإنّا لمبعوثون في الآخرة، ويزعم أنّ الدنيا تنقطع، فأخبرني ما حال الأرض يومئذ؟ فأنزل الله ﷿: <q>﴿إذا السَّماءُ انْشَقَّتْ﴾</q>{16}. (ز) <q>﴿إِذَا ٱلسَّمَاۤءُ ٱنشَقَّتۡ ۝١﴾</q> - تفسير الآية ٨٢١٩٦- عن علي بن أبي طالب، في قوله: <q>﴿إذا السَّماءُ انْشَقَّتْ﴾</q>، قال: تنشق السماء مِن المجَرَّة{17}. (١٥/٣١٤) ٨٢١٩٧- قال مقاتل بن سليمان: <q>﴿إذا السَّماءُ انْشَقَّتْ﴾</q> انشقّتْ لنزول ربّ العزة والملائكة، فإنها تنشق حتى يُرى طرفاها، ثم تُرى خَلْقًا باليًا{16}٧٠٩٢. (ز) ٧٠٩٢ قال ابنُ عطية (٨/٥٦٧): «وانشقاق السماء: هو تفطّرها لهول يوم القيامة، كما قال تعالى: <q>﴿وانْشَقَّتِ السَّماءُ فَهِيَ يَوْمَئِذٍ واهِيَةٌ﴾</q> [الحاقة:١٦]، وقال الفراء والزَّجّاج وغيرهما: هو تشقّقها بالغمام. وقال قوم: تشقّقها: تفتُّحها أبوابًا لِنُزول الملائكة وصعودهم في هول يوم القيامة». ",footnotes:1:أخرجه أبو جعفر النحاس في الناسخ والمنسوخ ص٧٥٧ من طريق أبي عمرو بن العلاء عن مجاهد، والبيهقي في دلائل النبوة ٧/١٤٢-١٤٤ من طريق خُصَيف عن مجاهد. وعزاه السيوطي إلى ابن مردويه.عزاه السيوطي إلى ابن مردويه.أخرجه ابن الضريس في فضائل القرآن ١/٣٣-٣٥.أخرجه البيهقي في دلائل النبوة ٧/١٤٢-١٤٣.أخرجه الحارث المحاسبي في فهم القرآن ص٣٩٥-٣٩٦ من طريق سعيد، وأبو بكر ابن الأنباري -كما في الإتقان ١/٥٧- من طريق همام.تنزيل القرآن ص٣٧-٤٢.أخرجه أبو عبيد في فضائله (ت: الخياطي) ٢/٢٠٠.تفسير مقاتل بن سليمان ٤/٦٣١.تقدم تخريجه في مقدمة سورة التكوير.أخرجه الطبراني في الكبير ٨/٦٨ (٧٣٩٣)، وابن نصر في فوائده ص١٠٦، ١٠٧ (١١٣، ١١٤)، من طريق يحيى بن عقبة بن أبي العيزار، عن إدريس الأودي، وابن أبي ليلى، عن عاصم بن أبي النجود، عن زِرّ بن حُبيش، عن صفوان بن عَسّال به. قال ابن أبي حاتم في علل الحديث ٢/٥٢٢ (٥٦١): «قال أبو زرعة: هذا حديث منكر خطأ». وقال البغوي في معجم الصحابة ٣/٣٤٢ (١٢٨٣): «وهذا حديث غريب، لا أعلم رواه غير يحيى بن عقبة، وهو ضعيف الحديث». وقال الهيثمي في المجمع ٢/٢٨٦ (٣٧٠٥): «فيه يحيى بن عقبة بن أبي العيزار، وهو ضعيف جدًّا».أخرجه مسلم ١/٤٠٦ (٥٧٨).أخرجه عبد الله بن وهب في الجامع -تفسير القرآن ٣/٩٩ (٢٢٤).أخرجه البخاري (٧٦٦، ٧٦٨، ١٠٧٨)، ومسلم (٥٧٨/١١٠). وعزاه السيوطي إلى ابن مردويه.أخرجه سعيد بن منصور في سننه -التفسير ٨/٣٠٧ (٢٤٣٥).أخرجه عبد الله بن وهب في الجامع -تفسير القرآن٣/٩٧-٩٨ (٢١٩).تفسير مقاتل بن سليمان ٤/٦٣٣.عزاه السيوطي إلى ابن أبي حاتم.تفسير مقاتل بن سليمان ٤/٦٣٣.
84,2," <q>﴿وَأَذِنَتۡ لِرَبِّهَا﴾</q> - تفسير ٨٢١٩٨- عن عبد الله بن عباس، في قوله: <q>﴿وأَذِنَتْ﴾</q>، قال: أطاعتْ{1}. (١٥/٣١٤) ٨٢١٩٩- عن عبد الله بن عباس، في قوله: <q>﴿وأَذِنَتْ لِرَبِّها﴾</q>، قال: سمعتْ حين كلَّمها{2}. (١٥/٣١٤) ٨٢٢٠٠- عن عبد الله بن عباس -من طريق مجاهد- في قوله: <q>﴿وأَذِنَتْ لِرَبِّها وحُقَّتْ﴾</q>، قال: سَمِعَتْ، وأطاعتْ{3}. (١٥/٣١٤) ٨٢٢٠١- عن سعيد بن جُبَير -من طريق جعفر- في قوله: <q>﴿وأَذِنَتْ لِرَبِّها﴾</q>، قال: سَمِعَتْ، وأطاعتْ{4}. (ز) ٨٢٢٠٢- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿وأَذِنَتْ لِرَبِّها﴾</q>، قال: سَمِعَتْ{5}. (ز) ٨٢٢٠٣- عن الضَّحّاك بن مُزاحِم -من طريق عبيد- في قوله: <q>﴿وأَذِنَتْ لِرَبِّها﴾</q>، قال: سَمِعَتْ، وأطاعتْ{4}. (ز) ٨٢٢٠٤- عن قتادة بن دعامة -من طريق معمر- <q>﴿وأَذِنَتْ لِرَبِّها وحُقَّتْ﴾</q>، قال: سَمِعَتْ، وأطاعتْ{7}. (١٥/٣١٦) ٨٢٢٠٥- عن حبيب بن أبي ثابت -من طريق معروف بن واصل- في قوله: <q>﴿وأذنت لربها وحقت﴾</q>: سَمِعَتْ{8}. (ز) ٨٢٢٠٦- عن إسماعيل السُّدِّيّ، في قوله: <q>﴿وأَذِنَتْ لِرَبِّها وحُقَّتْ﴾</q>، قال: أطاعتْ، وحُقَّ لها أن تطيع{9}. (١٥/٣١٤) ٨٢٢٠٧- قال مقاتل بن سليمان: <q>﴿وأَذِنَتْ لِرَبِّها﴾</q> انشقّتْ، وسَمِعَتْ لربّها، وأطاعتْ{10}. (ز) <q>﴿وَحُقَّتۡ ۝٢﴾</q> - تفسير ٨٢٢٠٨- عن عبد الله بن عباس، <q>﴿وحُقَّتْ﴾</q>، قال: حُقّتْ بالطاعة{11}٧٠٩٣. (١٥/٣١٤) ٧٠٩٣ ذكر ابنُ عطية (٨/٥٦٨) قول ابن عباس، ثم ذكر احتمالًا آخر، فقال: «ويحتمل أن يريد: وحُق لها أن تنشق لشدة الهول وخوف الله تعالى». ٨٢٢٠٩- عن سعيد بن جُبَير -من طريق جعفر- <q>﴿وحُقَّتْ﴾</q>: وحُقَّ لها{12}. (ز) ٨٢٢١٠- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿وحُقَّتْ﴾</q>، يقول: حُقَّ لها أن تفعل{13}. (ز) ٨٢٢١١- عن إسماعيل السُّدِّيّ، في قوله: <q>﴿وأَذِنَتْ لِرَبِّها وحُقَّتْ﴾</q>، قال: أطاعتْ، وحُقَّ لها أن تطيع{9}. (١٥/٣١٤) ٨٢٢١٢- قال مقاتل بن سليمان: <q>﴿وحُقَّتْ﴾</q> وكان يحقّ لها ذلك{10}. (ز) ",footnotes:1:أخرجه ابن أبي حاتم -كما في فتح الباري ٦/٢٩٤-.عزاه السيوطي إلى ابن المنذر. وأخرجه ابن جرير ٢٤/٢٣١ من طريق عطية العَوفيّ بلفظ: سمعت لربها.أخرجه الحاكم ٢/٥١٨.أخرجه ابن جرير ٢٤/٢٣١.تفسير مجاهد ص٧١٤، وأخرجه ابن جرير ٢٤/٢٣١.أخرجه ابن جرير ٢٤/٢٣١.أخرجه عبد الرزاق ٣/٣٥٨، وابن جرير ٢٤/٢٣١، ومن طريق سعيد أيضًا. وعزاه السيوطي إلى عبد بن حميد.أخرجه سعيد بن منصور في سننه -التفسير ٨/٢٩١ (٢٤٢٦).عزاه السيوطي إلى ابن المنذر.تفسير مقاتل بن سليمان ٤/٦٣٣.أخرجه ابن جرير ٢٤/٢٣٢ بنحوه، وابن أبي حاتم -كما في فتح الباري ٦/٢٩٤-.أخرجه ابن جرير ٢٤/٢٣٢.تفسير مجاهد ص٧١٤.عزاه السيوطي إلى ابن المنذر.تفسير مقاتل بن سليمان ٤/٦٣٣.
84,3," <q>﴿وَإِذَا ٱلۡأَرۡضُ مُدَّتۡ ۝٣ وَأَلۡقَتۡ مَا فِیهَا وَتَخَلَّتۡ ۝٤ وَأَذِنَتۡ لِرَبِّهَا وَحُقَّتۡ ۝٥﴾</q> - تفسير ٨٢٢١٣- عن عبد الله بن عمر، عن النبي ﷺ، في قوله: <q>﴿إذا السَّماءُ انْشَقَّتْ﴾</q> الآية، قال: «أنا أول مَن تنشق عنه الأرض يوم القيامة، فأجلس جالسًا في قبري، وإنّ الأرض تحركتْ بي، فقلت لها: ما لكِ؟ فقالت: إنّ ربي أمرني أنْ أُلقي ما في جوفي، وأنْ أتخلّى فأكون كما كنتُ إذ لا شيء فِيّ. وذلك قوله: <q>﴿وأَلْقَتْ ما فِيها وتَخَلَّتْ﴾</q>»{1}. (١٥/٣١٦) ٨٢٢١٤- عن عبد الله بن عمرو بن العاص -من طريق مجاهد- قال: كان البيت قبل الأرض بألفي سنة، وذلك قول الله: <q>﴿وإذا الأَرْضُ مُدَّتْ﴾</q>، قال: مُدَّت مِن تحتِه مَدًّا{2}. (١٥/٣١٥) ٨٢٢١٥- عن عبد الله بن عباس -من طريق مجاهد- في قوله: <q>﴿وإذا الأَرْضُ مُدَّتْ﴾</q> قال: يوم القيامة، <q>﴿وأَلْقَتْ ما فِيها﴾</q> أخرجت ما فيها مِن الموتى، <q>﴿وتَخَلَّتْ﴾</q> عنهم{3}. (١٥/٣١٤) ٨٢٢١٦- عن مجاهد بن جبر -من طريق ابن أبي نجيح-، مثله{4}. (١٥/٣١٥) ٨٢٢١٧- عن عبد الله بن عباس، في قوله: <q>﴿وأَلْقَتْ ما فِيها وتَخَلَّتْ﴾</q>، قال: سواري الذهب{5}. (١٥/٣١٥) ٨٢٢١٨- عن قتادة بن دعامة -من طريق معمر- في قوله: <q>﴿وأَلْقَتْ ما فِيها وتَخَلَّتْ﴾</q>، قال: أخرجتْ أثقالها، وما فيها من الكنوز، والناس{6}٧٠٩٤. (١٥/٣١٦) ٧٠٩٤ ذكر ابنُ عطية (٨/٥٦٨) نحو ما جاء في قول قتادة عن الزَّجّاج، وانتقده مستندًا إلى السياق، فقال: «وقال الزَّجّاج: من الكنوز، وهذا ضعيف؛ لأن ذلك يكون وقت خروج الدَّجّال، وإنما تلقي يوم القيامة الموتى». ٨٢٢١٩- قال مقاتل بن سليمان: <q>﴿وإذا الأَرْضُ مُدَّتْ﴾</q> مثل الأديم الممدود، <q>﴿وأَلْقَتْ﴾</q> ما فِيها من الحيوان، <q>﴿وتَخَلَّتْ﴾</q> يقول: سَمِعَتْ لربّها وأطاعتْ، وكان [يحقّ] لها ذلك{7}. (ز) <q>﴿وَإِذَا ٱلۡأَرۡضُ مُدَّتۡ ۝٣ وَأَلۡقَتۡ مَا فِیهَا وَتَخَلَّتۡ ۝٤ وَأَذِنَتۡ لِرَبِّهَا وَحُقَّتۡ ۝٥﴾</q> - آثار متعلقة بالآية ٨٢٢٢٠- عن جابر بن عبد الله، عن النبي ﷺ، قال: «تمُد الأرضُ يوم القيامة مدَّ الأديمِ، ثم لا يكون لابن آدم منها إلا موضعُ قدميه»{8}. (١٥/٣١٥) ٨٢٢٢١- عن علي بن حسين، أنّ النبي ﷺ قال: «إذا كان يومُ القيامة مَدَّ الله الأرض، حتى لا يكون لبشر مِن الناس إلا موضع قدميه، فأكون أولَ مَن يُدعى، وجبريل عن يمين الرحمن، واللهِِ، ما رآه قبلها، فأقول: يا ربّ، إنّ هذا أخبرني أنكَ أرسلتَه إلَيّ. فيقول: صدق. ثم أشفع فأقول: يا ربّ، عبادك عبدوك في أطراف الأرض». قال: «وهو المقام المحمود»{9}. (ز) ٨٢٢٢٢- عن عبد الله بن عمرو بن العاص -من طريق أبي المُغيرة- قال: إذا كان يوم القيامة مُدّت الأرض مدَّ الأديم، وحَشر الله الخلائق؛ الإنس والجن والدواب والوحوش، فإذا كان ذلك اليوم جعل الله القِصاص بين الدوابِّ، حتى تقتصَّ الشاة الجَمّاءُ من القرناءِ بنَطْحتِها، فإذا فرغ الله من القصاص بين الدواب قال لها: كوني ترابًا. فيراها الكافر، فيقول: يا ليتني كنتُ ترابًا{10}. (١٥/٣١٥) ",footnotes:1:أخرجه أبو القاسم الخُتَّلي في الديباج ص١٠٢ (٣٤)، من طريق سلام بن سلم الطويل، عن عبد الحميد، عن نافع، عن ابن عمر به. وسنده شديد الضعف؛ فيه سلام بن سلم، وهو متروك. الميزان ٢/١٧٥.أخرجه الحاكم ٢/٥١٨، والبيهقي في الدلائل ٢/٤٤. وعزاه السيوطي إلى الفريابي، وعبد بن حميد.أخرجه الحاكم ٢/٥١٨.تفسير مجاهد ص٧١٤ مقتصرًا على الآية الثانية، وأخرجه ابن جرير ٢٤/٢٣٣. وعزاه السيوطي إلى عبد بن حميد.عزاه السيوطي إلى ابن المنذر.أخرجه عبد الرزاق ٢/٣٥٩ بنحوه، وابن جرير ٢٤/٢٣٣ بلفظ: أخرجتْ أثقالها وما فيها. وعزاه السيوطي إلى عبد بن حميد.تفسير مقاتل بن سليمان ٤/٦٣٣-٦٣٤.أخرجه الحاكم ٤/٦١٤ (٨٧٠١) مطولًا بنحوه. قال الحاكم: «هذا حديث صحيح الإسناد، على شرط الشيخين، ولم يخرجاه». ووافقه الذهبي في التلخيص. وقال ابن حجر في الفتح ١١/٣٧٦: «ورجاله ثقات، إلا أنه اختُلف على الزُّهريّ في صحابيه». وقال السيوطي: «بسند جيد».أخرجه عبد الرزاق ٣/٤٠٧ بنحوه، وابن جرير ٢٤/٢٣٢ مرسلًا.أخرجه الحاكم ٤/٥٧٥.
  84,4,""
  84,5,""
84,6," <q>﴿یَـٰۤأَیُّهَا ٱلۡإِنسَـٰنُ إِنَّكَ كَادِحٌ إِلَىٰ رَبِّكَ كَدۡحࣰا فَمُلَـٰقِیهِ ۝٦﴾</q> - تفسير ٨٢٢٢٣- عن عبد الله بن عباس -من طريق العَوفيّ- في قوله: <q>﴿يا أيُّها الإنْسانُ إنَّكَ كادِحٌ إلى رَبِّكَ كَدْحًا فَمُلاقِيهِ﴾</q>، يقول: تعملُ عملًا تلقى الله به؛ خيرًا كان أو شرًّا{1}. (١٥/٣١٦) ٨٢٢٢٤- عن الضَّحّاك بن مُزاحِم -من طريق جويبر- <q>﴿يا أيُّها الإنْسانُ إنَّكَ كادِحٌ إلى رَبِّكَ كَدْحًا﴾</q>، قال: عامِلٌ إلى ربّك عَمَلًا{2}. (١٥/٣١٦) ٨٢٢٢٥- عن قتادة بن دعامة -من طريق معمر- في قوله: <q>﴿يا أيُّها الإنْسانُ إنَّكَ كادِحٌ إلى رَبِّكَ كَدْحًا﴾</q>، قال: عامِلٌ له عَمَلًا{3}. (١٥/٣١٦) ٨٢٢٢٦- عن قتادة بن دعامة -من طريق سعيد- في قوله تعالى: <q>﴿إنَّكَ كادِحٌ إلى رَبِّكَ كَدْحًا﴾</q>، قال: إنّ كدحك -يا ابن آدم- لَضعيفٌ، فمَن استطاع أن يكون كدحُه في طاعة الله فليفعل، ولا قوة إلا بالله{1}. (ز) ٨٢٢٢٧- عن إسماعيل السُّدِّيّ، <q>﴿إنَّكَ كادِحٌ إلى رَبِّكَ كَدْحًا﴾</q> قال: عامل عملًا، <q>﴿فَمُلاقِيهِ﴾</q> قال: مُلاقٍ عملك{5}. (١٥/٣١٦) ٨٢٢٢٨- قال محمد بن السّائِب الكلبي: <q>﴿كادِحٌ إلى رَبِّكَ كَدْحًا﴾</q> عامل لربّك عملًا{6}. (ز) ٨٢٢٢٩- قال مقاتل بن سليمان: ثم قال: <q>﴿يا أيُّها الإنْسانُ﴾</q> يعني بالإنسان: الأسود بن عبد الأسد <q>﴿إنَّكَ كادِحٌ إلى رَبِّكَ كَدْحًا﴾</q> إنّك ساعٍ إلى ربّك سعيًا، <q>﴿فَمُلاقِيهِ﴾</q> بعملك{7}. (ز) ٨٢٢٣٠- قال عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- <q>﴿إنَّكَ كادِحٌ إلى رَبِّكَ كَدْحًا﴾</q>، قال: عامل إلى ربّك عملًا. قال: <q>﴿كَدْحًا﴾</q> العمل{8}٧٠٩٥. (ز) ٧٠٩٥ في عود الضمير من قوله: <q>﴿فملاقيه﴾</q> قولان: الأول: أنه عائد على الرّبّ. الثاني: أنه عائد على العمل والكدح. وقد علّق ابنُ عطية (٨/٥٦٩) على الأول، فقال: فالفاء على هذا عاطفة <q>﴿ملاق﴾</q> على كادح«. وعلّق على الثاني، فقال:»فالفاء على هذا عاطفة جملة على التي قبلها، والتقدير: فأنت ملاقيه، والمعنى: ملاقٍ جزاءه خيرًا كان أو شرًّا". وعلّق ابنُ كثير (١٤/٢٩٣ بتصرف) على الأول، فقال: «ومِن الناس مَن يعيد الضمير على قوله: <q>﴿ربك﴾</q>، أي: فملاقٍ ربّك، ومعناه: فيجازيك بعملك ويكافئك على سعيك. وعلى هذا فكلا القولين متلازم». وعلّق على الثاني، فقال: «ويشهد له ما رواه أبو داود الطيالسي ... عن جابر، قال: قال رسول الله ﷺ: «قال جبريل: يا محمد، عِشْ ما شئتَ فإنك ميت، وأَحبِب ما شئتَ فإنك مفارقه، واعمل ما شئتَ فإنك ملاقيه»». ",footnotes:1:أخرجه ابن جرير ٢٤/٢٣٥.أخرجه ابن أبي شيبة ١٣/٥٨١.أخرجه عبد الرزاق ٢/٣٥٨، وابن جرير ٢٤/٢٣٦. وعزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ٢٤/٢٣٥.عزاه السيوطي إلى ابن المنذر.تفسير البغوي ٨/٣٧٤.تفسير مقاتل بن سليمان ٤/٦٣٤.أخرجه ابن جرير ٢٤/٢٣٦.
84,7," <q>﴿فَأَمَّا مَنۡ أُوتِیَ كِتَـٰبَهُۥ بِیَمِینِهِۦ ۝٧ فَسَوۡفَ یُحَاسَبُ حِسَابࣰا یَسِیرࣰا ۝٨﴾</q> - تفسير ٨٢٢٣١- عن عائشة، قالت: قال رسول الله ﷺ: «ليس أحد يُحاسب إلا هلك». فقلتُ: أليس الله يقول: <q>﴿فَأَمّا مَن أُوتِيَ كِتابَهُ بِيَمِينِهِ فَسَوْفَ يُحاسَبُ حِسابًا يَسِيرًا﴾</q>؟ قال: «ليس ذلك بالحساب، ولكن ذاك العرض، ومَن نُوقِش الحساب هلك»{1}. (١٥/٣١٧) ٨٢٢٣٢- عن عائشة: سمعتُ رسول الله ﷺ يقول في بعض صلاته: «اللهم، حاسِبني حسابًا يسيرًا». فلما انصرف قلتُ: يا رسول الله، ما الحساب اليسير؟ قال: «أن يُنظر في كتابه فيُتجاوز له عنه؛ إنه مَن نُوقش الحساب هلك»{2}. (١٥/٣١٧) ٨٢٢٣٣- عن عائشة، قالت: يا نبي الله، كيف <q>﴿حِسابًا يَسِيرًا﴾</q>؟ قال: «يُعطى العبد كتابه بيمينه، فيقرأ سيئاته، ويقرأ الناس حسناته، ثم يُحوّل صحيفته، فيُحوّل الله سيئاته حسنات، فيقرأ حسناته، ويقرأ الناس سيئاته حسنات، فيقول الناس: ما كان لهذا العبد سيئة. قال: يُعْرّف بعمله، ثم يغفر الله له. قال: <q>﴿أُولَئِكَ يُبَدِّلُ اللهُ سَيِّئاتِهِمْ حَسَناتٍ وكانَ اللهُ غَفُورًا رَّحِيمًا﴾</q>» [الفرقان:٧٠]{3}. (ز) ٨٢٢٣٤- عن عائشة، في قوله: <q>﴿فَسَوْفَ يُحاسَبُ حِسابًا يَسِيرًا﴾</q>، قال: يُعرَّف ذنوبَه، ثم يُتَجاوزُ له عنها{4}. (١٥/٣١٧) ٨٢٢٣٥- عن عائشة -من طريق عروة- قالت: مَن حُوسِب يوم القيامة أُدخِل الجنة. وتَلَتْ: <q>﴿فَأَمّا مَن أُوتِيَ كِتابَهُ بِيَمِينِهِ فَسَوْفَ يُحاسَبُ حِسابًا يَسِيرًا﴾</q>، ثم تَلَتْ: <q>﴿يُعْرَفُ المُجْرِمُونَ بِسِيماهُمْ فَيُؤْخَذُ بِالنَّواصِي والأَقْدامِ﴾</q> [الرحمن:٤١]{5}. (١٥/٣١٧) ٨٢٢٣٦- قال مقاتل بن سليمان: ثم قال: <q>﴿فَأَمّا مَن أُوتِيَ كِتابَهُ بِيَمِينِهِ﴾</q> وهو عبد الله بن عبد الأسد، ويُكنى: أبا سلمة، <q>﴿فَسَوْفَ يُحاسَبُ حِسابًا يَسِيرًا﴾</q> باليسير؛ بأنّ الله لا يُغيّر حسناته ولا يفضحه، وذلك أنّ الله ﷿ إذا جمع الخلائق يوم القيامة فإنهم يموج بعضُهم في بعض مقدارَ ثلاثمائة سنة، حتى إذا استوى الرّبُّ -جلّ وعزّ- على كرسيّه لِيُحاسب خَلْقه، فإذا جاء الرّبُّ -تبارك وتعالى- والملائكةُ صفًّا صفًّا، فينظرون إلى الجنة وإلى النار، ويُجاء بالنار من مسيرة خمسمائة عام، عليها تسعون ألف زمام، في كلّ زمام سبعون ألف ملك متعلّق، يحبسونها عن الخلائق، طول عنق أحدهم مسيرة سنة، وغِلظها مسيرة سنة، ما بين مَنكِبي أحدهم مسيرة خمسين سنة، وجوههم مثل الجمر، وأعينهم مثل البَرق، إذا تَكلّم أحدهم تناثرتْ مِن فِيه النار، بيد كلّ واحد منهم مرزبة، عليها ثلاثمائة وستون رأسًا كأمثال الجبال، هي أخفّ بيده مِن الريشة، فيجيئون بها، فيسوقونها حتى تقام عن يسار العرش، ويجاء بالجنة يزفونها كما تُزَفُّ العروس إلى زوجها حتى تقام عن يمين العرش، فإذا ما عاين الخلائقُ النارَ، وما أعدّ الله لأهلها، ونظروا إلى ربّهم، وسكتوا؛ فانقطعتْ عند ذلك أصواتهم، فلا يَتكلّم أحدٌ مِنهم مِن فَرَق الله وعظمته، ولما يرون مِن العجائب مِن الملائكة، ومن حملة العرش، ومن أهل السموات، ومن جهنم، ومن خزنتها، فانقطعتْ أصواتهم عند ذلك، وتَرتعد مفاصلهم، فإذا علم الله ما أصاب أولياءَه مِن الخوف، وبلغت القلوب الحناجر، فيقوم منادٍ عن يمين العرش، فينادي: <q>﴿يا عِبادِ، لا خَوْفٌ عَلَيْكُمُ اليَوْمَ ولا أنْتُمْ تَحْزَنُونَ﴾</q> [الزخرف:٦٨]، فيرفع عند ذلك الإنس والجنّ كلُّهم رؤوسَهم والمؤمنون والكفار؛ لأنهم عباده كلّهم، ثم ينادي في الثانية: <q>﴿الَّذِينَ آمَنُوا بِآياتِنا وكانُوا مُسْلِمِينَ﴾</q> [الزخرف:٦٩]، فيَرفع المؤمنون رؤوسَهم، وينكس أهل الأديان كلّهم رؤوسهم، والناس سكوت مقدار أربعين عامًا، فذلك قوله: <q>﴿هَذا يَوْمُ لا يَنْطِقُونَ، ولا يُؤْذَنُ لَهُمْ فَيَعْتَذِرُونَ﴾</q> [المرسلات:٣٥-٣٦]، وقوله: <q>﴿لا يَتَكَلَّمُونَ إلّا مَن أذِنَ لَهُ الرَّحْمنُ وقالَ صَوابًا﴾</q> [النبأ:٣٨]؛ وقال: لا إله إلا الله؛ فذلك الصواب، وقوله: <q>﴿وخَشَعَتِ الأَصْواتُ لِلرَّحْمنِ فَلا تَسْمَعُ إلّا هَمْسًا﴾</q> [طه:١٠٨]، فلا يجيبهم الله، ولا يُكلّمهم، ولا يتكلمون هم مقدار أربعين سنة، يقول بعد ذلك لمَلكٍ من الملائكة وهو جبريل ﵇: نادِ الرسل، وابدأ بالأُمِّي. قال: فيقوم المَلك، فينادي عند ذلك: أين النَّبِي الأُمِّي؟ فتقول الأنبياء عند ذلك: كلّنا نبيّون وأُمّيون؛ فبيِّن بيِّن. فيقول: النبي العربي الأُمّي الحرمي، فيقوم عند ذلك رسول الله ﷺ، فيرفع صوته بالدعاء، فيقول: كم مِن ذنب قد عملتموه ونسيتموه وقد أحصاه الله! ربِّ، لا تفضح أمتي. قال: فلا يزال يدنو مِن الله تعالى حتى يقوم بين يديه؛ أقرب خَلْقه إليه، فيحمد الله، ويثني عليه، ويذكر من الثناء على الله تعالى والحمد حتى تعجب الملائكة منه والخلائق، فيقول الله ﷿: قد رضيتُ عنك، يا محمد، اذهب فنادِ أُمّتك. فينادي، وأول ما يدعو يدعو مِن أُمّته عبد الله بن عبد الأسد أبا سلمة، فلا يزال يدنو، فيقرّبه الله ﷿ منه، فيحاسبه حسابًا يسيرًا، واليسير الذي لا يأخذه بالذنب الذي عمله، ولا يغضب الله ﷿ عليه، فيجعل سيئاته داخل صحيفته، وحسناته ظاهر صحيفته، فيوضع على رأسه التاج مِن ذَهَبٍ عليه تسعون ألف ذؤابة، كلّ ذؤابة دُرّة تساوي مال المشرق والمغرب، ويلبس سبعين حُلّة مِن الإستبرق والسندس، فالذي يلي جسده حريرة بيضاء، فذلك قوله: <q>﴿ولِباسُهُمْ فِيها حَرِيرٌ﴾</q> [الحج:٢٣، فاطر:٣٣]، ويُسوَّر بثلاث أسْوِرة: سوار من فِضّة، وسوار من ذهب، وسوار من لؤلؤ، ويوضع إكليل مُكلّل بالدُّرّ والياقوت، وقد تلألأ في وجهه مِن نور ذلك، فيرجع إلى إخوانه من المؤمنين، فينظرون إليه وهو جاءٍ مِن عند الله، فتقول الملائكة والناس والجنّ: واللهِ، لقد أكرم الله هذا، لقد أعطى الله لهذا. فينظرون إلى كتابه، فإذا سيئاته باطن صحيفته، وإذا حسناته ظاهر كتابه، فتقول عند ذلك الملائكة: ما كان أذنب هذا الآدميُّ ذنبًا قط! واللهِ، لقد اتّقى اللهَ هذا العبدُ، فحُقّ أن يكرم مثل هذا العبد. وهم لا يشعرون أنّ سيئاته باطن كتابه، وذلك لمن أراد الله تعالى أن يُكرمه ولا يفضحه، قال: فيأتي إخوانَه من المسلمين، فلا يعرفونه، فيقول: أتعرفوني؟ فيقولون كلّهم: لا، واللهِ. فيقول: إنما برحتُ الساعة، وقد نسيتموني. فيقول: أنا أبو سلمة، أبشِروا بمثله، يا معشر الإخوان، لقد حاسَبني ربي حسابًا يسيرًا، وأكرمني. فذلك قوله: <q>﴿فَسَوْفَ يُحاسَبُ حِسابًا يَسِيرًا ويَنْقَلِبُ إلى أهْلِهِ﴾</q> يقول إلى قومه: <q>﴿مَسْرُورًا﴾</q> فيُعطى كتابه بيمينه، <q>﴿فَيَقُولُ هاؤُمُ اقْرَؤُا كِتابِيَهْ إنِّي ظَنَنْتُ أنِّي مُلاقٍ حِسابِيَهْ﴾</q> [الحاقة:١٩-٢٠] إلى آخر القصة{6}. (ز) ٨٢٢٣٧- قال عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿فَسَوْفَ يُحاسَبُ حِسابًا يَسِيرًا﴾</q>، قال: الحساب اليسير: الذي يُغفر ذنوبه، ويُتقبّل حسناته. ويسير الحساب: الذي يُعفى عنه. وقرأ: <q>﴿ويَخافُونَ سُوءَ الحِسابِ﴾</q> [الرعد:٢١]، وقرأ: <q>﴿أُولَئِكَ الَّذِينَ نَتَقَبَّلُ عَنْهُمْ أحْسَنَ ما عَمِلُوا ونَتَجاوَزُ عَنْ سَيِّئاتِهِمْ فِي أصْحابِ الجَنَّةِ﴾</q> [الأحقاف:١٦]{7}. (ز) <q>﴿فَأَمَّا مَنۡ أُوتِیَ كِتَـٰبَهُۥ بِیَمِینِهِۦ ۝٧ فَسَوۡفَ یُحَاسَبُ حِسَابࣰا یَسِیرࣰا ۝٨﴾</q> - آثار متعلقة بالآية ٨٢٢٣٨- عن أبي هريرة، قال: قال رسول الله ﷺ: «ثلاث مَن كُنّ فيه حاسبه الله حسابًا يسيرًا، وأدخله الجنة برحمته: تُعطي مَن حرَمك، وتعفو عمَّن ظلمَك، وتَصِل مَن قطَعك»{8}. (١٥/٣١٨) ",footnotes:1:أخرجه البخاري ١/٣٢ (١٠٣)، ٦/١٦٧-١٦٨ (٤٩٣٩)، ٨/١١١-١١٢ (٦٥٣٦، ٦٥٣٧)، ومسلم ٤/٢٢٠٤-٢٢٠٥ (٢٨٧٦)، وآدم بن أبي إياس -كما في تفسير مجاهد ص٧١٤-، وعبد الرزاق ٣/٦١ (٢٤٠٩)، وابن جرير ٢٤/٢٣٧-٢٣٨، والثعلبي ١٠/١٥٩.أخرجه أحمد ٤٠/٢٦٠ (٢٤٢١٥)، وابن خزيمة ٢/٧١ (٨٤٩)، وابن حبان ١٦/٣٧٢ (٧٣٧٢)، والحاكم ١/١٢٥ (١٩٠)، ١/٣٨٥ (٩٣٦)، ٤/٢٧٨ (٧٦٣٦)، ٤/٦٢٣ (٨٧٢٧)، وابن جرير ٢٤/٢٣٦-٢٣٧. قال الحاكم: «هذا حديث صحيح، على شرط مسلم، ولم يخرجاه بهذا اللفظ». ووافقه الذهبي في التلخيص. وقال ابن كثير في تفسيره ٨/٣٥٧: «صحيح، على شرط مسلم». وقال الألباني في ضعيف أبي داود ٢/٤٧٢: «وإسناده حسن».أخرجه عبد الله بن وهب في الجامع ١/٣٤ (٦٩)، من طريق ابن أبي جعفر، أنه بلغه أن عائشة... وسنده ضعيف؛ لانقطاعه بين ابن أبي جعفر وعائشة ﵂.عزاه السيوطي إلى ابن المنذر.أخرجه ابن أبي شيبة ١٣/٣٦١. وعزاه السيوطي إلى ابن المنذر.تفسير مقاتل بن سليمان ٤/٦٣٤-٦٣٩.أخرجه ابن جرير ٢٤/٢٣٨.أخرجه الحاكم ٢/٥٦٣ (٣٩١٢)، وفي إسناده سليمان بن داود اليمامي. قال البزار -كما في كشف الأستار ٢/٣٨٣ (١٩٠٦)-: «سليمان بن داود ليس بالقوي، ولا يُتابع على حديثه». قال الحاكم: «هذا حديث صحيح الإسناد، ولم يخرجاه». وتعقبه الذهبي في التلخيص بقوله: «سليمان بن داود اليمامي ضعيف». وقال ابن القيسراني في ذخيرة الحفاظ ٢/١١٨٣ (٢٥٢٢): «رواه سليمان بن داود اليمامي أبو الجمل، عن يحيى بن أبي كثير، عن أبي سلمة، عن أبي هريرة. وسليمان هذا ليس بشيء». وقال المنذري الترغيب والترهيب ٣/٢١٠ (٣٧١٨): «رواه الثلاثة -البزار، والطبراني في الأوسط، والحاكم-، من رواية سليمان بن داود اليماني، عن يحيى بن أبي سلمة عنه، وسليمان هذا واهٍ». وقال المناوي في فيض القدير ٣/٢٨٨ (٣٤١٩): «وقال في المهذب: سليمان واه. وفي الميزان [ميزان الاعتدال ٢/٢٠٢ (٣٤٤٩)] قال البخاري [في التاريخ الكبير ٤/١١ (١٧٩٢)]: سليمان منكر الحديث. قال: ومَن قلتُ فيه: منكر الحديث. لا تحلُّ رواية حديثه، ثم ساق له أخبارًا هذا منها. وقال العلائي: فيه سليمان ضعّفه غير واحد. وقال الهيثمي [في مجمع الزوائد ٨/١٥٤ (١٣٤٧٣)]: فيه سليمان متروك».
  84,8,""
84,9," <q>﴿وَیَنقَلِبُ إِلَىٰۤ أَهۡلِهِۦ مَسۡرُورࣰا ۝٩﴾</q> - تفسير ٨٢٢٣٩- عن مجاهد بن جبر، في قوله: <q>﴿ويَنْقَلِبُ إلى أهْلِهِ مَسْرُورًا﴾</q>، قال: إلى أهلٍ له في الجنة{1}. (١٥/٣١٨) ٨٢٢٤٠- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿ويَنْقَلِبُ إلى أهْلِهِ مَسْرُورًا﴾</q>، قال: إلى أهلٍ أعدّ الله لهم الجنةَ{2}. (ز) ٨٢٢٤١- قال مقاتل بن سليمان: <q>﴿ويَنْقَلِبُ إلى أهْلِهِ﴾</q> يقول: إلى قومه <q>﴿مَسْرُورًا﴾</q> فيُعطى كتابه بيمينه{3}. (ز) ",footnotes:1:عزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ٢٤/٢٣٩.تفسير مقاتل بن سليمان ٤/٦٣٧.
84,10," <q>﴿وَأَمَّا مَنۡ أُوتِیَ كِتَـٰبَهُۥ وَرَاۤءَ ظَهۡرِهِۦ ۝١٠﴾</q> - تفسير ٨٢٢٤٢- عن رجل من بني أسد، قال: قال عمر لكعب: ويحك، يا كعب! حدِّثنا حديثًا مِن حديث الآخرة. قال: نعم، يا أمير المؤمنين، إذا كان يوم القيامة رفع اللوح المحفوظ، ولم يبق أحد من الخلائق إلا وهو ينظر إلى عمله فيه. قال: ثم يُؤتى بالصحف التي فيها أعمال العباد. قال: فتُنشر حول العرش، فذلك قوله: <q>﴿ووضع الكتاب فترى المجرمين مشفقين مما فيه ويقولون يا ويلتنا ما لهذا الكتاب لا يغادر صغيرة ولا كبيرة إلا أحصاها﴾</q> [الكهف:٤٩]. قال الأسدي: الصغيرة ما دون الشرك، والكبيرة الشّرك، إلا أحصاها. قال كعب: ثم يُدعى المؤمن، فيُعطى كتابه بيمينه، فينظر فيه، فحسناته باديات للناس، وهو يقرأ سيئاته لكي لا يقول: كانت لي حسنات فلم تُذكر. فأَحبّ الله أن يُريه عمله كلّه، حتى إذا استنقص ما في الكتاب وجد في آخر ذلك كلّه أنه مغفور، وإنك مِن أهل الجنة، فعند ذلك يُقبِل إلى أصحابه، ثم يقول: <q>﴿هاؤم اقرءوا كتابيه إني ظننت أني ملاق حسابيه﴾</q> [الحاقة:١٩-٢٠]، ثم يُدعى الكافر، فيُعطى كتابه بشماله، ثم يُلفّ، فيُجعل مِن وراء ظهره، ويُلوى عنقه، فذلك قوله: <q>﴿وأما من أوتي كتابه وراء ظهره﴾</q> يُنظر في كتابه، فسيئاته باديات للناس، وينظر في حسناته، لكي لا يقول: أفأُثاب على السيئات؟{1}. (ز) ٨٢٢٤٣- عن مجاهد بن جبر، في قوله: <q>﴿وأَمّا مَن أُوتِيَ كِتابَهُ وراءَ ظَهْرِهِ﴾</q>، قال: تُخلَع يده، فتُجعَل مِن وراء ظهره{2}. (١٥/٣١٨) ٨٢٢٤٤- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿وأَمّا مَن أُوتِيَ كِتابَهُ وراءَ ظَهْرِهِ﴾</q>، قال: تُجعل شماله وراء ظهره، فيأخذ بها كتابه{3}. (١٥/٣١٨) ٨٢٢٤٥- قال مقاتل بن سليمان: ثم ينادي منادٍ بالأسود بن عبد الأسد؛ أخي عبد الله المؤمن، فيريد الشقي أن يدنوَ، فينتهرونه، ويشقّ صدره حتى يخرج قلبُه مِن وراء ظهره مِن بين كتفيه، ويُعطى كتابه، ويُجعل كلّ حسنة عملها في دهره في باطن صحيفته؛ لأنه لم يؤمن بالإيمان، وتُجعل سيئاته ظاهر صحيفته، ويُحجب عن الله ﷿، فلا يراه، ولكن ينادي منادٍ من عند العرش يذكّره مساوئه، فكلما ذكر مساوئه قال: أنا أعرف هذا، لعنه الله. فتجيء اللعنة من عند الله ﷿ حتى تقع عليه، فيُلطّخ باللعنة، فيصير جسده مسيرة شهر في طول مسيرة ثلاثة أيام ولياليهن، ورأسه مثل الأقرع، وهو جبل عظيم بالشام وأنيابه مثل أُحُد، وحدقتاه مثل جبل حِراء الذي بمكة، ومنخره مثل الورقين{4}، وهما جبلان، وشعره في الكثرة، مثل الأجمة{5}، وفي الطول مثل القصب، وفي الغِلظ مثل الرماح، ويوضع على رأسه تاج مِن نار، ويُلبس جُبّة مِن نحاس ذائب، ويُقلّد حجرًا من كبريت، مثل الجبل تشتعل فيه النار، وتُغلّ يداه إلى عنقه، ويَسودّ وجهه، وهو أشد سوادًا من القبر في ليلة مظلمة، وتزرقّ عيناه، فيرجع إلى إخوانه، فأول ما يرونه يفزع منه الخلائق، حتى يُمسكوا على آنافهم مِن شدة نَتنه، فيقولون: لقد أهان اللهُ هذا العبد، لقد أخزى الله هذا العبد. فينظرون إلى كتابه، فإذا سيئاته ظاهرة، وليس له من الحسنات شيء، يقولون: أما كان لهذا العبد في الله ﷿ حاجة، ولا خافه يومًا قط، ولا ساعة، فحُقّ لهذا العبد إذ أخزاه الله وعذّبه. فتلعنه الملائكة أجمعون، فإذا رجع إلى الموقف لم يعرفه أصحابه، فيقول: أما تعرفوني؟ قالوا: لا، واللهِ. فيقول: أنا الأسود بن عبد الأسد، فينادي بأعلى صوته، فيقول: <q>﴿يا لَيْتَنِي لَمْ أُوتَ كِتابِيَهْ ولَمْ أدْرِ ما حِسابِيَهْ يا لَيْتَها كانَتِ القاضِيَةَ ما أغْنى عَنِّي مالِيَهْ﴾</q> [الحاقة:٢٥-٢٨]. يقول: يا ليت كان الموت أنْ أموت فأستريح من هذا البلاء، هلك عنى حُجّتي اليوم. ثم يقول: الويل. فيُبشّر أخوه المؤمنين، ويُبشّر هذا الكفار، فذلك قوله تعالى: <q>﴿وأَمّا مَن أُوتِيَ كِتابَهُ وراءَ ظَهْرِهِ﴾</q>{6}. (ز) ",footnotes:1:أخرجه ابن المبارك في الزهد ١/٥١٩.عزاه السيوطي إلى ابن المنذر.تفسير مجاهد ص٧١٤ بنحوه، وأخرجه الفريابي -كما في تغليق التعليق ٤/٣٦٤، وفتح الباري ٨/٦٩٧-، وابن جرير ٢٤/٢٤٠. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، والبيهقي في البعث.كذا في مطبوعة المصدر، والمعروف: جبل ورِقان، وهو جبل أسود على يمين المار من المدينة إلى مكة. ينظر: النهاية، لسان العرب، تاج العروس (ورق).الأجَمَة: الشجر الكثير الملتف. المعجم الوسيط (أجم).تفسير مقاتل بن سليمان ٤/٦٣٤-٦٣٩.
84,11," <q>﴿فَسَوۡفَ یَدۡعُوا۟ ثُبُورࣰا ۝١١ وَیَصۡلَىٰ سَعِیرًا ۝١٢﴾</q> - تفسير ٨٢٢٤٦- عن عبد الله بن عباس، <q>﴿يَدْعُو ثُبُورًا﴾</q>، قال: الويل{1}. (١٥/٣١٩) ٨٢٢٤٧- عن الضَّحّاك بن مُزاحِم -من طريق عبيد- قال في قوله: <q>﴿يَدْعُو ثُبُورًا﴾</q>، قال: يدعو بالهلاك{2}. (ز) ٨٢٢٤٨- قال مقاتل بن سليمان: <q>﴿فَسَوْفَ يَدْعُوا ثُبُورًا * ويَصْلى سَعِيرًا﴾</q> يدعو بالويل، ويدخل النار{3}. (ز) ",footnotes:1:عزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ٢٤/٢٤٠.تفسير مقاتل بن سليمان ٤/٦٣٤-٦٣٩.
  84,12,""
84,13," <q>﴿إِنَّهُۥ كَانَ فِیۤ أَهۡلِهِۦ مَسۡرُورًا ۝١٣﴾</q> - تفسير ٨٢٢٤٩- عن الضَّحّاك بن مُزاحِم، <q>﴿إنَّهُ كانَ فِي أهْلِهِ مَسْرُورًا﴾</q>، قال: في الدنيا{1}. (١٥/٣١٩) ٨٢٢٥٠- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿إنَّهُ كانَ فِي أهْلِهِ مَسْرُورًا﴾</q> أي: في الدنيا{2}. (ز) ٨٢٢٥١- قال مقاتل بن سليمان: يقول: <q>﴿إنَّهُ كانَ فِي أهْلِهِ مَسْرُورًا﴾</q> في قومه كريمًا، فيُذلّه الله يوم القيامة{3}. (ز) ",footnotes:1:عزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ٢٤/٢٤١.تفسير مقاتل بن سليمان ٤/٦٣٩.
84,14," <q>﴿إِنَّهُۥ ظَنَّ أَن لَّن یَحُورَ ۝١٤﴾</q> - تفسير ٨٢٢٥٢- عن عبد الله بن عباس -من طريق الضَّحّاك- <q>﴿أنْ لَنْ يَحُورَ﴾</q>، قال: أن لن يرجع{1}. (١٥/٣١٩) ٨٢٢٥٣- عن عبد الله بن عباس -من طريق الضَّحّاك- أنّ نافع بن الأزرق سأله عن قوله: <q>﴿أنْ لَنْ يَحُورَ﴾</q>، قال: أن لن يرجع، بلغة الحبشة. يقول: أن لن يرجع إلى الله في الآخرة. قال: وهل تعرف العرب ذلك؟ قال: نعم، أما سمعتَ قول لبيد: وما المرءُ إلا كالشهابِ وضوئِه يحورُ رَمادًا بعدَ إذْ هو ساطعُ؟{2}. (١٥/٣١٩) ٨٢٢٥٤- قال عبد الله بن عباس: كنت لا أدري ما معنى <q>﴿يحور﴾</q>، حتى سمعتُ أعرابيّةً تدعو بُنيّة لها فتقول: حُورِي، حُورِي. أي: ارجعي{3}. (ز) ٨٢٢٥٥- عن عبد الله بن عباس -من طريق علي- في قوله: <q>﴿إنَّهُ ظَنَّ أنْ لَنْ يَحُورَ﴾</q>، قال: لن يُبعَث{4}. (١٥/٣١٩) ٨٢٢٥٦- عن قتادة بن دعامة -من طريق معمر-، مثله{5}. (١٥/٣١٩) ٨٢٢٥٧- عن مجاهد بن جبر -من طريق ابن أبي نجيح- <q>﴿أنْ لَنْ يَحُورَ﴾</q>: أن لن يرجع إلينا{6}. (١٥/٣١٩) ٨٢٢٥٨- عن عكرمة مولى ابن عباس، <q>﴿إنَّهُ ظَنَّ أنْ لَنْ يَحُورَ﴾</q>، قال: أليس تسمع الحبشيَّ إذا قيل له: حُرْ إلى أهلك؟ أي: اذهب{7}. (١٥/٣١٩) ٨٢٢٥٩- عن قتادة بن دعامة -من طريق سعيد- في قوله تعالى: <q>﴿إنَّهُ ظَنَّ أنْ لَنْ يَحُورَ﴾</q>: أن لا معاد له، ولا رجعة{8}. (ز) ٨٢٢٦٠- قال مقاتل بن سليمان: قال: <q>﴿إنَّهُ ظَنَّ أنْ لَنْ يَحُورَ﴾</q>، يقول: أن لن يُبعَث{9}. (ز) ٨٢٢٦١- عن سفيان [الثوري] -من طريق مهران- <q>﴿إنَّهُ ظَنَّ أنْ لَنْ يَحُورَ﴾</q>، قال: يرجِع{10}. (ز) ٨٢٢٦٢- قال عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿أنْ لَنْ يَحُورَ﴾</q>، قال: أن لن ينقلب{10}. (ز) <q>﴿إِنَّهُۥ ظَنَّ أَن لَّن یَحُورَ ۝١٤﴾</q> - آثار متعلقة بالآية ٨٢٢٦٣- عن عبد الله بن سرجس، قال: كان رسول الله ﷺ إذا سافر يتعوذ مِن وعثاء السفر، وكآبة المنقلب، والحَوْر بعد الكَوْر{12}، ودعوة المظلوم، وسوء المنظر في الأهل والمال{13}. (ز) ",footnotes:1:عزاه السيوطي إلى ابن أبي حاتم.أخرجه الطستي في مسائل نافع (٢٤)، والطبراني في المعجم الكبير ١٠/٢٤٨-٢٥٦ (١٠٥٩٧).تفسير الثعلبي ١٠/١٦٠.أخرجه ابن جرير ٢٤/٢٤٢، وابن أبي حاتم -كما في الإتقان ٢/٥٤-. وعزاه السيوطي إلى ابن المنذر.أخرجه عبد الرزاق ٢/٣٥٨، وابن جرير ٢٤/٢٤٣. وعزاه السيوطي إلى عبد بن حميد.تفسير مجاهد ص٧١٤، وأخرجه ابن جرير ٢٤/٢٤٢. وعزاه السيوطي إلى عبد بن حميد.عزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ٢٤/٢٤٢.تفسير مقاتل بن سليمان ٤/٦٣٩.أخرجه ابن جرير ٢٤/٢٤٣.أخرجه ابن جرير ٢٤/٢٤٣.استشهد ابن جرير ٢٤/٢٤٢ بقوله: «والحَوْر بعد الكَوْر» في بيان معنى الآية، ثم علق عليه فقال: «يعني بذلك: مِن الرجوع إلى الكفر بعد الإيمان».أخرجه مسلم ٢/٩٧٩ (١٣٤٣).
84,15," <q>﴿بَلَىٰۤۚ إِنَّ رَبَّهُۥ كَانَ بِهِۦ بَصِیرࣰا ۝١٥﴾</q> - تفسير ٨٢٢٦٤- قال مقاتل بن سليمان: يقول الله تعالى: <q>﴿بَلى إنَّ رَبَّهُ﴾</q> الذي خَلَقه <q>﴿كانَ بِهِ بَصِيرًا﴾</q> إنه شهيد لعمله{1}. (ز) ",footnotes:1:تفسير مقاتل بن سليمان ٤/٦٣٩.
84,16," <q>﴿فَلَاۤ أُقۡسِمُ بِٱلشَّفَقِ ۝١٦﴾</q> - تفسير ٨٢٢٦٥- عن عمر بن الخطاب، قال: الشَّفَق: الحُمْرَة{1}. (١٥/٣٢٠) ٨٢٢٦٦- عن أبي هريرة، قال: الشَّفَق: البياض{2}. (١٥/٣٢٠) ٨٢٢٦٧- عن عبد الله بن عباس، قال: الشَّفَق: الحُمْرة{3}. (١٥/٣٢٠) ٨٢٢٦٨- عن عبد الله بن عمر -من طريق نافع- قال: الشَّفَق: الحُمْرة{4}. (١٥/٣٢٠) ٨٢٢٦٩- عن عمر بن عبد العزيز -من طريق جعفر بن برقان- قال: <q>﴿الشَّفَق﴾</q> البياض{5}. (ز) ٨٢٢٧٠- عن العوام بن حَوْشَب، قال: قلت لـمجاهد: الشَّفَق؟ قال: إنّ الشَّفَق مِن الشمس{6}. (١٥/٣٢٠) ٨٢٢٧١- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿فَلا أُقْسِمُ بِالشَّفَق﴾</q>، قال: الشَّفَق: النهار كلّه{7}٧٠٩٦. (١٥/٣٢٠) ٧٠٩٦ علّق ابنُ كثير (١٤/٢٩٦ بتصرف) على قول مجاهد، فقال: «صحَّ عن مجاهد أنه قال في هذه الآية: <q>﴿فلا أقسم بالشَّفَق﴾</q> هو النهار كلّه. وإنما حمله على هذا قرنه بقوله تعالى: <q>﴿والليل وما وسق﴾</q> أي: جمع. كأنه أقسم بالضياء والظلام». ٨٢٢٧٢- عن عكرمة مولى ابن عباس، مثله{8}. (١٥/٣٢٠) ٨٢٢٧٣- عن مكحول الشامي -من طريق محمد بن راشد- قال: <q>﴿الشَّفَق﴾</q> الحُمرة{5}. (ز) ٨٢٢٧٤- قال مقاتل بن سليمان: ثم أقسم الرّبُّ ﷿، فقال: <q>﴿فَلا أُقْسِمُ بِالشَّفَق﴾</q>، فأمّا الشَّفَق: فهو الضوء الذي يكون بعد غروب الشمس إلى أن تغيب{10}٧٠٩٧. (ز) ٧٠٩٧ اختُلف في معنى الشَّفَق على قولين: الأول: أنه الحُمرة. الثاني: أنه البياض أو النهار. وقد زاد ابنُ جرير (٢٤/٢٤٤) قولًا ثالثًا لم ينسبه: أنه من الأضداد، وهو اسم للحُمرة والبياض. وقد رجّح ابنُ جرير القول الثاني، فقال: «والصواب من القول في ذلك عندي أن يُقال: إنّ الله أقسم بالنهار مُدبرًا، والليل مُقبلًا. وأمّا الشَّفَق الذي تحلّ به صلاة العشاء، فإنه للحُمرة عندنا؛ للعلّة التي قد بيناها في كتابنا كتاب الصلاة». ورجّح ابنُ عطية (٨/٥٧٢) أنّ الشَّفَق هو: «الحُمرة التي تعقب غيبوبة الشمس مع البياض التابع لها في الأغلب». ثم انتقد قول مَن قال: إنها النهار كلّه. بقوله: «وهذا قول ضعيف». وقال ابنُ كثير (١٤/٢٩٦): «فالشَّفَق هو: حُمرة الأُفُق إمّا قبل طلوع الشمس -كما قاله مجاهد- وإمّا بعد غروبها -كما هو معروف عند أهل اللغة-. قال الخليل بن أحمد: الشَّفَق: الحُمرة من غروب الشمس إلى وقت العشاء الآخرة. فإذا ذهب قيل: غاب الشَّفَق. وقال الجوهري: الشَّفَق: بقية ضوء الشمس وحُمرتها في أول الليل إلى قريب من العَتمة. وكذا قال عكرمة: الشَّفَق: الذي يكون بين المغرب والعشاء. وفي صحيح مسلم، عن عبد الله بن عمرو، عن رسول الله ﷺ أنه قال: «وقتُ المغرب ما لم يغب الشَّفَق»». ",footnotes:1:عزاه السيوطي إلى سمويه في فوائده.أخرجه عبد الرزاق ٢/٣٥٩ -وفيه: عن معمر، عن ابن خثيم، عن ابن لهيعة!-. وعزاه السيوطي إلى ابن أبي حاتم.عزاه السيوطي إلى ابن أبي حاتم.أخرجه عبد الرزاق (٢١٢٢)، وابن أبي شيبة ١/٣٣٣. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه عبد الرزاق ٢/٣٥٩.أخرجه ابن أبي شيبة ١/٣٣٣، وابن جرير ٢٤/٢٤٤ بنحوه.تفسير مجاهد ص٧١٥، وأخرجه عبد الرزاق ٢/٣٥٩، وابن أبي شيبة ٢/٥٣٠، وابن جرير ٢٤/٢٤٤، وكذا أخرجه من طريق منصور بنحوه. وعزاه السيوطي إلى عبد بن حميد، وابن المنذرعزاه السيوطي إلى عبد بن حميد.أخرجه عبد الرزاق ٢/٣٥٩.تفسير مقاتل بن سليمان ٤/٦٣٩.
84,17," <q>﴿وَٱلَّیۡلِ وَمَا وَسَقَ ۝١٧﴾</q> - تفسير ٨٢٢٧٥- عن عبد الله بن عباس، في قوله: <q>﴿واللَّيْلِ وما وسَقَ﴾</q>، قال: وما دخل فيه{1}. (١٥/٣٢١) ٨٢٢٧٦- عن عبد الله بن عباس -من طريق علي- في قوله: <q>﴿واللَّيْلِ وما وسَقَ﴾</q>، قال: وما جمع{2}. (١٥/٣٢١) ٨٢٢٧٧- عن عبد الله بن عباس: أنه سُئِل عن قوله: <q>﴿واللَّيْلِ وما وسَقَ﴾</q>. قال: وما جمع، أما سمعتَ قوله: إنّ لنا قلائِصًا نقانِقا{3} مستوسقات لو يجدن سائقا؟{4}. (١٥/٣٢٢) ٨٢٢٧٨- عن سعيد بن جُبَير، <q>﴿وما وسَقَ﴾</q>، قال: ما عُمل فيه{5}. (١٥/٣٢١) ٨٢٢٧٩- عن سعيد بن جُبَير -من طريق أبي الهيثم- <q>﴿واللَّيْلِ وما وسَقَ﴾</q>: وما جمع{6}. (ز) ٨٢٢٨٠- عن مجاهد بن جبر -من طريق ابن أبي نجيح- <q>﴿واللَّيْلِ وما وسَقَ﴾</q>، قال: وما جمع. يقول: ما آوى فيه مِن دابّة{7}. (١٥/٣٢١) ٨٢٢٨١- عن مجاهد بن جبر -من طريق شيبان، عن منصور- <q>﴿واللَّيْلِ وما وسَقَ﴾</q>، يقول: والليلِ، وما لُفّ عليه{8}. (ز) ٨٢٢٨٢- عن مجاهد بن جبر -من طريق سفيان، عن منصور- <q>﴿واللَّيْلِ وما وسَقَ﴾</q>، قال: وما أظلم عليه، وما أدخل فيه{9}. (ز) ٨٢٢٨٣- عن الضَّحّاك بن مُزاحِم -من طريق عبيد- في قوله: <q>﴿واللَّيْلِ وما وسَقَ﴾</q>، قال: ما ساق معه مِن ظُلمةٍ إذا أقبل{10}. (ز) ٨٢٢٨٤- عن عكرمة مولى ابن عباس، <q>﴿واللَّيْلِ وما وسَقَ﴾</q>، قال: وما جمع مِن حيّاته، وعقاربه، ودوابّه{11}. (١٥/٣٢١) ٨٢٢٨٥- عن عكرمة مولى ابن عباس -من طريق حسين- أنه سُئل: <q>﴿واللَّيْلِ وما وسَقَ﴾</q>. قال: ما ساق مِن ظُلمة، فإذا كان الليل ذهب كلّ شيء إلى مأواه{10}. (ز) ٨٢٢٨٦- عن الحسن البصري -من طريق أبي رجاء- أنّ حفصًا سأله عن قوله: <q>﴿واللَّيْلِ وما وسَقَ﴾</q>. قال: وما جمع{13}. (ز) ٨٢٢٨٧- عن قتادة بن دعامة -من طريق سعيد- قوله: <q>﴿واللَّيْلِ وما وسَقَ﴾</q>، يقول: وما جمع مِن نجمٍ، أو دابّة{14}. (ز) ٨٢٢٨٨- قال مقاتل بن سليمان: قال: <q>﴿واللَّيْلِ وما وسَقَ﴾</q> ما ساق مِن الظُّلمة{15}. (ز) ٨٢٢٨٩- قال مقاتل بن حيّان: <q>﴿واللَّيْلِ وما وسَقَ﴾</q> أقبل مِن ظُلمة أو كوكب{16}. (ز) ٨٢٢٩٠- قال عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿واللَّيْلِ وما وسَقَ﴾</q>، قال: وما جَمع، مجتمع فيه الأشياء التي يجمعها الله، التي تأوي إليه، وأشياء تكون في الليل لا تكون في النهار، ما جَمع مما فيه ما يأوي إليه، فهو مما جَمع{6}٧٠٩٨. (ز) ٧٠٩٨ بيّن ابنُ جرير (٢٤/٢٤٥ بتصرف) -مستندًا إلى اللغة، والسنة، وأقوال السلف- أنّ قوله: <q>﴿وسق﴾</q> معناه: جمع، فقال: «وقوله: <q>﴿والليل وما وسق﴾</q> يقول: والليل وما جمع مما سكن وهدأ فيه مِن ذي روح كان يطير، أو يدبّ نهارًا، يقال منه: وسقته أسقه وسقًا، ومنه: طعام موسوق، وهو المجموع في غرائر أو وعاء، ومنه: الوسق، وهو الطعام المجتمع الكثير، وبه جاء الخبر عن رسول الله ﷺ، وبنحو الذي قلنا في ذلك قال أهل التأويل». وذكر الآثار على ذلك، ثم ذكر قول مَن قال معناه: ساق. ولم يعلّق عليه. ",footnotes:1:أخرجه سعيد بن منصور -كما في فتح الباري ٨/٦٩٧-. وعزاه السيوطي إلى ابن أبي حاتم.أخرجه ابن أبي شيبة ٢/٢٣٥، وابن جرير ٢٤/٢٤٥. وعزاه السيوطي إلى أبي عبيد في فضائله، وابن المنذر.النقانق: جمع النقنق، أي: الظليم، وهو الذكر من النعام. التاج (نقق، ظلم).عزاه السيوطي إلى عبد بن حميد، وابن الأنباري، وقال: من طرق. وأخرج نحوه ابن جرير ٢٤/٢٤٧ من طريق ابن أبي مليكة.عزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه ابن جرير ٢٤/٢٤٧.تفسير مجاهد ص٧١٥، وأخرجه ابن جرير ٢٤/٢٤٦. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.تفسير مجاهد ص٧١٥، وأخرجه ابن جرير ٢٤/٢٤٧ من طريق جرير، عن منصور.أخرجه ابن جرير ٢٤/٢٤٦.أخرجه ابن جرير ٢٤/٢٤٨.أخرجه ابن جرير ٢٤/٢٤٧ بنحوه. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه ابن جرير ٢٤/٢٤٨.أخرجه آدم بن أبي إياس -كما في تفسير مجاهد ص٧١٥-، وابن جرير ٢٤/٢٤٦.أخرجه ابن جرير ٢٤/٢٤٦، كما أخرجه عبد الرزاق ٢/٣٥٨ من طريق معمر مقتصرًا على قوله: وما جمع.تفسير مقاتل بن سليمان ٤/٦٣٩.تفسير البغوي ٨/٣٧٥.أخرجه ابن جرير ٢٤/٢٤٧.
84,18," <q>﴿وَٱلۡقَمَرِ إِذَا ٱتَّسَقَ ۝١٨﴾</q> - تفسير ٨٢٢٩١- عن عبد الله بن عباس -من طريق علي- <q>﴿والقَمَرِ إذا اتَّسَقَ﴾</q>، قال: إذا استوى{1}. (١٥/٣٢١) ٨٢٢٩٢- عن عبد الله بن عباس -من طريق الضَّحّاك- أنّ نافع بن الأزرق سأله عن قوله: <q>﴿والقَمَرِ إذا اتَّسَقَ﴾</q>. قال: اتِّساقه: اجتماعه. قال: وهل تعرفُ العربُ ذلك؟ قال: نعم، أما سمعتَ قول ابن صِرْمة: إنّ لنا قلائصًا نقانقا مستوسقات لو يجدن سائقا؟{2}. (١٥/٣٢١) ٨٢٢٩٣- عن عبد الله بن عباس، <q>﴿والقَمَرِ إذا اتَّسَقَ﴾</q>، قال: ليلة ثلاث عشرة{3}. (١٥/٣٢٢) ٨٢٢٩٤- قال مُرّة الهَمداني: <q>﴿والقَمَرِ إذا اتَّسَقَ﴾</q> ارتفع، وهو في الأيام البيض{4}. (ز) ٨٢٢٩٥- عن سعيد بن جُبَير -من طريق جعفر- في قوله: <q>﴿والقَمَرِ إذا اتَّسَقَ﴾</q>، قال: لثلاث عشرة{5}. (ز) ٨٢٢٩٦- عن مجاهد بن جبر -من طريق ابن أبي نجيح- <q>﴿إذا اتَّسَقَ﴾</q>، قال: إذا استوى{6}. (ز) ٨٢٢٩٧- عن الضَّحّاك بن مُزاحِم -من طريق عبيد- في قوله: <q>﴿والقَمَرِ إذا اتَّسَقَ﴾</q>، قال: إذا اجتمع فاستوى{7}. (ز) ٨٢٢٩٨- عن عكرمة مولى ابن عباس -من طريق سماك- <q>﴿والقَمَرِ إذا اتَّسَقَ﴾</q>، قال: إذا استوى{5}. (ز) ٨٢٢٩٩- عن الحسن البصري -من طريق أبي رجاء- أن حفصًا سأله عن قوله: <q>﴿والقَمَرِ إذا اتَّسَقَ﴾</q>. قال: إذا اجتمع؛ إذا امتلأ{5}. (ز) ٨٢٣٠٠- عن عطاء -من طريق ابن شيبة- <q>﴿والقمر إذا اتسق﴾</q>، قال: إذا جمع، واستوى{10}. (ز) ٨٢٣٠١- عن قتادة بن دعامة -من طريق معمر- <q>﴿والقَمَرِ إذا اتَّسَقَ﴾</q>، قال: إذا استدار{11}. (١٥/٣٢٢) ٨٢٣٠٢- عن عكرمة مولى ابن عباس، مثله{3}. (١٥/٣٢٢) ٨٢٣٠٣- عن قتادة بن دعامة -من طريق سعيد- في قوله تعالى: <q>﴿إذا اتَّسَقَ﴾</q>، قال: إذا استوى{7}. (ز) ٨٢٣٠٤- قال مقاتل بن سليمان: <q>﴿والقَمَرِ إذا اتَّسَقَ﴾</q> في ليلة ثلاث عشرة، وأربع عشرة، وخمس عشرة؛ فهُنّ البيض، فهو يستوي في الشهر ثلاث ليال يشتدّ ضوءه، ويجتمع من ثلاث عشرة، فأقسم الله ﷿ بالشَّفَق، والليل وما وسق، والقمر إذا اتسق{14}. (ز) ٨٢٣٠٥- قال عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿والقَمَرِ إذا اتَّسَقَ﴾</q>، قال: إذا استوى{7}٧٠٩٩. (ز) ٧٠٩٩ ذكر ابنُ كثير (١٤/٢٩٧) قول مَن فسر <q>﴿اتسق﴾</q> باستوى، ومَن فسره باجتمع، ومَن فسره باستدار. ثم علّق قائلًا: «ومعنى كلامهم: أنه إذا تكامل نوره وأبدر، جعله مقابلًا لليل وما وسق». ",footnotes:1:أخرجه ابن جرير ٢٤/٢٤٨-٢٤٩، ومن طريق عطية أيضًا. وعزاه السيوطي إلى عبد بن حميد، وابن أبي حاتم.أخرجه الطستي في مسائل نافع (٩)، والطبراني في المعجم الكبير ١٠/٢٤٨-٢٥٦ (١٠٥٩٧). وعزاه السيوطي إلى ابن الأنباري في الوقف والابتداء. وأخرجه ابن الأنباري في الوقف والابتداء ١/٩٦ (١١٦) لكن بنسبة البيت إلى أبي طالب.عزاه السيوطي إلى عبد بن حميد.تفسير الثعلبي ١٠/١٦١.أخرجه ابن جرير ٢٤/٢٤٩.تفسير مجاهد ص٧١٥، وأخرجه ابن جرير ٢٤/٢٤٩.أخرجه ابن جرير ٢٤/٢٥٠.أخرجه ابن جرير ٢٤/٢٤٩.أخرجه ابن جرير ٢٤/٢٤٩.أخرجه أبو الشيخ في العظمة ٤/١٢٠٢ (٦٧٥).أخرجه عبد الرزاق ٢/٣٥٨، وابن جرير ٢٤/٢٥٠. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.عزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ٢٤/٢٥٠.تفسير مقاتل بن سليمان ٤/٦٣٩-٦٤٠.أخرجه ابن جرير ٢٤/٢٥٠.
84,19," <q>﴿لَتَرۡكَبُنَّ طَبَقًا عَن طَبَقࣲ ۝١٩﴾</q> - قراءات ٨٢٣٠٦- عن عبد الله بن مسعود -من طريق الأسود- أنه قرأ: ‹لَتَرْكَبَنَّ طَبَقًا عَن طَبَقٍ› بالنصب{1}. (١٥/٣٢٣) ٨٢٣٠٧- عن عبد الله بن عباس -من طريق مجاهد- أنه كان يقرأ: ‹لَتَرْكَبَنَّ طَبَقًا عَن طَبَقٍ› يعني: بفتح الباء. قال: هذا نبيّكم ﷺ، حالًا بعد حال{2}. (١٥/٣٢٣) ٨٢٣٠٨- عن أبي العالية الرِّياحيّ أنه قرأ: ‹لَتَرْكَبَنَّ طَبَقًا› بالنصب{3}. (١٥/٣٢٥) ٨٢٣٠٩- عن مجاهد بن جبر -من طريق أبي عمرو بن العلاء- أنه قرأ: ‹لَتَرْكَبَنَّ طبقًا› بالنصب{3}. (١٥/٣٢٥) ٨٢٣١٠- عن عاصم أنه قرأ: <q>﴿لَتَرْكَبُنَّ﴾</q> بالتاء ورفع الباء، على الجماع{3}. (١٥/٣٢٥) <q>﴿لَتَرۡكَبُنَّ طَبَقًا عَن طَبَقࣲ ۝١٩﴾</q> - تفسير الآية ٨٢٣١١- عن عمر بن الخطاب، في قوله: <q>﴿لَتَرْكَبُنَّ طَبَقًا عَن طَبَقٍ﴾</q>، قال: حالًا بعد حال{3}. (١٥/٣٢٢) ٨٢٣١٢- عن عبد الله بن مسعود -من طريق الأسود- أنه قرأ: ‹لَتَرْكَبَنَّ طَبَقًا عَن طَبَقٍ› بالنصب{7}: لتَرْكَبَنَّ -يا محمد- سماءً بعد سماء{8}. (١٥/٣٢٣) ٨٢٣١٣- عن عبد الله بن مسعود -من طريق علقمة- ‹لَتَرْكَبَنَّ طَبَقًا عَن طَبَقٍ›: يا محمد، حالًا بعد حال{9}. (١٥/٣٢٣) ٨٢٣١٤- عن عبد الله بن مسعود -من طريق إبراهيم- في قوله: ‹لَتَرْكَبَنَّ طَبَقًا عَن طَبَقٍ›، قال: يعني: السماء؛ تنفطر، ثم تنشقّ، ثم تحمرّ{10}. (١٥/٣٢٤) ٨٢٣١٥- عن عبد الله بن مسعود -من طريق مُرّة- في الآية، قال: السماء تكون ألوانًا؛ كالمُهلِ، وتكون وردةً كالدِّهانِ، وتكون واهيةً، وتشقق فتكون حالًا بعد حال{11}. (١٥/٣٢٤) ٨٢٣١٦- عن عبد الله بن عباس -من طريق عمرو بن دينار- <q>﴿لَتَرْكَبُنَّ طَبَقًا عَن طَبَقٍ﴾</q>: الشدائد والأهوال؛ الموت، ثم البعث، ثم العرض{12}. (ز) ٨٢٣١٧- عن عبد الله بن عباس -من طريق مجاهد- أنه كان يقرأ: ‹لَتَرْكَبَنَّ طَبَقًا عَن طَبَقٍ›، يعني: بفتح الباء. قال: هذا نبيُّكم ﷺ، حالًا بعد حال{13}٧١٠٠. (١٥/٣٢٣) ٧١٠٠ ذكر ابنُ كثير (١٤/٢٩٧-٢٩٨) قول ابن عباس، ووجّهه، فقال: «وهو محتمل أن يكون ابن عباس أسند هذا التفسير عن النبي ﷺ، كأنه قال: سمعتُ هذا من نبيّكم ﷺ، فيكون قوله:»نبيّكم«مرفوعًا على الفاعلية مِن»قال«وهو الأظهر، والله أعلم، كما قال أنس: لا يأتي عام إلا والذي بعده شر منه، سمعته من نبيّكم ﷺ... ويحتمل أنْ يكون المراد: <q>﴿لتركبن طبقا عن طبق﴾</q> حالًا بعد حال. قال: هذا، يعني المراد بهذا: نبيّكم ﷺ، فيكون مرفوعًا على أنّ»هذا«و»نبيّكم«يكونان مبتدأ وخبرًا، والله أعلم. ولعلّ هذا قد يكون هو المتبادر إلى كثير من الرواة، كما قال أبو داود الطيالسي وغندر: حدثنا شعبة، عن أبي بشر، عن سعيد بن جُبَير، عن ابن عباس: <q>﴿لتركبن طبقا عن طبق﴾</q>، قال: محمد ﷺ. ويؤيد هذا المعنى قراءة عمر، وابن مسعود، وابن عباس، وعامة أهل مكة والكوفة: ‹لَتَرْكَبَنَّ› بفتح التاء والباء». ٨٢٣١٨- عن عبد الله بن عباس -من طريق مجاهد- ‹لَتَرْكَبَنَّ طَبَقًا عَن طَبَقٍ›، قال: يا محمد، السماء طبقًا بعد طبق{14}. (١٥/٣٢٣) ٨٢٣١٩- عن عبد الله بن عباس -من طريق عطية العَوفيّ- ‹لَتَرْكَبَنَّ طَبَقًا عَن طَبَقٍ›: يعني: منزلًا بعد منزل، ويقال: أمرًا بعد أمر، وحالًا بعد حال{15}. (ز) ٨٢٣٢٠- عن مسروق بن الأجْدع الهَمداني -من طريق أبي الضحى- ‹لَتَرْكَبَنَّ طَبَقًا عَن طَبَقٍ›، قال: أنت، يا محمد؛ سماء عن سماء{16}. (ز) ٨٢٣٢١- عن مُرّة بن شراحيل الهَمداني -من طريق موسى بن أبي عائشة- أنه سأله عن قوله: ‹لَتَرْكَبَنَّ طَبَقًا عَن طَبَقٍ›، قال: حالًا بعد حال{17}. (ز) ٨٢٣٢٢- عن سعيد بن جُبَير، <q>﴿لَتَرْكَبُنَّ طَبَقًا عَنْ طَبَقٍ﴾</q>، قال: قوم كانوا في الدنيا خسيس أمرهم، فارتفعوا في الآخرة، وقوم كانوا في الدنيا أشرافًا فاتَّضعوا في الآخرة{18}. (١٥/٣٢٤) ٨٢٣٢٣- عن سعيد [بن جُبَير] -من طريق جعفر- <q>﴿لَتَرْكَبُنَّ طَبَقًا عَن طَبَقٍ﴾</q>، قال: حالًا بعد حال{19}. (ز) ٨٢٣٢٤- عن مجاهد بن جبر -من طريق منصور- في قوله: <q>﴿لَتَرْكَبُنَّ طَبَقًا عَن طَبَقٍ﴾</q>، قال: أمرًا بعد أمر{20}. (١٥/٣٢٢) ٨٢٣٢٥- قال مجاهد بن جبر: <q>﴿طَبَقًا عَن طَبَقٍ﴾</q> سماء بعد سماء{21}. (ز) ٨٢٣٢٦- عن الضَّحّاك بن مُزاحِم -من طريق عبيد- في قوله: <q>﴿لَتَرْكَبُنَّ طَبَقًا عَن طَبَقٍ﴾</q>: منزلًا بعد منزل، وحالًا بعد حال{22}. (ز) ٨٢٣٢٧- عن عكرمة مولى ابن عباس -من طريق سِماك- في قوله: ‹لَتَرْكَبَنَّ طَبَقًا عَن طَبَقٍ›، قال: حالًا بعد حال{19}. (ز) ٨٢٣٢٨- عن عامر الشعبي -من طريق إسماعيل- ‹لَتَرْكَبَنَّ طَبَقًا عَن طَبَقٍ›، قال: لتَرْكَبَنّ -يا محمد- سماء بعد سماء{24}. (١٥/٣٢٤) ٨٢٣٢٩- عن الحسن البصري -من طريق أبي رجاء- أنّ حفصًا سأله عن قوله: <q>﴿لَتَرْكَبُنَّ طَبَقًا عَنْ طَبَقٍ﴾</q>. قال: منزلًا عن منزل، وحالًا عن حال{25}. (ز) ٨٢٣٣٠- قال الحسن البصري= (ز) ٨٢٣٣١- وأبو العالية الرِّياحيّ -من طريق قتادة-: ‹لَتَرْكَبَنَّ› يعني: محمدًا ﷺ، <q>﴿طَبَقًا عَنْ طَبَقٍ﴾</q> السموات{22}. (ز) ٨٢٣٣٢- قال عطاء: <q>﴿لَتَرْكَبُنَّ طَبَقًا عَنْ طَبَقٍ﴾</q> مرةً فقرًا، ومرةً غِنًى{12}. (ز) ٨٢٣٣٣- عن مكحول الشامي -من طريق ابن جابر- في قوله: <q>﴿لَتَرْكَبُنَّ طَبَقًا عَنْ طَبَقٍ﴾</q>، قال: في كلّ عشرين عامًا تُحْدِثُون أمرًا لم تكونوا عليه{28}. (١٥/٣٢٤) ٨٢٣٣٤- عن قتادة بن دعامة -من طريق سعيد- في الآية، قال: حالًا عن حال، بينما صاحب الدنيا في رخاء إذ صار في بلاء، وبينما هو في بلاء إذ صار في رخاء{20}. (١٥/٣٢٥) ٨٢٣٣٥- عن عطاء الخُراسانيّ -من طريق يونس بن يزيد- في قول الله ﷿: <q>﴿لتركبن طبقا عن طبق﴾</q>: حالًا عبر حال، ومنازلًا عبر منازل{30}. (ز) ٨٢٣٣٦- قال محمد بن السّائِب الكلبي -من طريق محمد بن مروان- <q>﴿طَبَقًا عَنْ طَبَقٍ﴾</q>: حالًا بعد حال، وأمرًا بعد أمر في مواقف يوم القيامة{31}. (ز) ٨٢٣٣٧- عن محمد بن السّائِب الكلبي -من طريق حيان- <q>﴿لَتَرْكَبُنَّ طَبَقًا عَنْ طَبَقٍ﴾</q>: مرة يَعرفون، ومرة يَجهلون{32}. (ز) ٨٢٣٣٨- قال مقاتل بن سليمان: <q>﴿لَتَرْكَبُنَّ﴾</q> هذا العبد <q>﴿طَبَقًا عَنْ طَبَقٍ﴾</q> حالًا بعد حال؛ خَلْقًا من نُطفة، ثم صارت النُّطفة عَلقة، ثم صارت العَلقة مُضغة، ثم صارت إنسانًا ميتًا في بطن أمه، حتى نُفخ فيه الروح، ثم صار إنسانًا حيًّا، ثم أخرجه الله تعالى مِن بطن أمه، فكان طفلًا، ثم يبلغ أشده، ثم شاخ وكبر، ثم مات ولبث في قبره حتى صار ترابًا، ثم أنشأه الله ﷿ بعد ذلك يوم القيامة{33}. (ز) ٨٢٣٣٩- قال عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: ‹لَتَرْكَبَنَّ طَبَقًا عَن طَبَقٍ›، قال: الآخرة بعد الأولى{34}٧١٠١. (ز) ٧١٠١ اختُلف في قراءة قوله: <q>﴿لتركبن طبقا عن طبق﴾</q> وفي المراد به على أقوال: - فعلى قراءة مَن قرأ ذلك: ‹لتركبَنَّ› بفتح الباء وفي معناها أربعة أقوال: الأول: لتركبَنَّ -يا محمد- حالًا بعد حال، وأمرًا بعد أمر من الشدائد. الثاني: لتركبَنَّ -يا محمد- سماء بعد سماء. الثالث: لتركبَنَّ الآخرة بعد الأولى. الرابع: أنّ الإشارة إلى السماء، والمراد: أنها تتغير ضروبًا من التغيير، فتارة كالمُهل وتارة كالدّهان. وذكر ابنُ القيم (٣/٢٧٤) أنه على الثلاثة الأولى فالتاء للمخاطب، وعلى القول الرابع فالتاء للغيبة. وزاد ابنُ عطية (٨/٥٧٣) معنًى آخر على هذه القراءة، ووجّهه، فقال: «وقيل: هي عِدة بالنصر، أي: لتركبن أمر العرب قبيلًا بعد قبيل، وفتحًا بعد فتح، كما كان ووجد بعد ذلك». وبيّن ابنُ كثير (١٤/٢٩٨-٢٩٩) أنّ قول مَن قال: معناه: سماء بعد سماء. فإنما عنى به ليلة الإسراء. وعلّق ابنُ القيم على القول الرابع بقوله: «ودل على السماء ذِكر الشَّفَق والقمر». ثم وجّهه بقوله: «وعلى هذا فيكون قسمًا على المعاد وتغيير العالم». - وعلى قراءة مَن قرأ ذلك: <q>﴿لتركبُنَّ﴾</q> بضم الباء على وجه الخطاب للناس كافة، يكون المعنى: لتركبُنَّ -أيها الناس- حالًا بعد حال، وأمرًا بعد أمر؛ من الفقر والغنى، أو من الشدائد والموت والبعث والحساب، أو من النُّطفة إلى الهرم، أو منزلة بعد منزلة مِن الرفعة والضّعة. وزاد ابنُ عطية معنيين آخرين على هذه القراءة، الأول: أنّ المعنى: لتركبُنَّ هذه الأحوال أُمّة بعد أُمّة. وعلّق عليه قائلًا: "ومنه قول العباس بن عبد المطلب عن النبي ﵇: وأنت لما بُعثتَ أشرقت الأ ... رض وضاءت بنورك الطرق تنقل من صالب إلى رحم ... إذا مضى علم بدا طبق". والثاني: «لتركبُنَّ سنن من قبلكم». وعلّق عليه بقوله: «كما جاء في الحديث: «شبرًا بشبر، وذراعًا بذراع، فهذا هو طبق عن طبق»». وبنحوه قال ابنُ كثير، وعزاه للسُّدِّيّ. وذكر ابنُ عطية أنّ هذا المعنى يلتئم مع قراءة عمر بن الخطاب (لَيَرْكَبُنَّ). وقد رجّح ابنُ جرير (٢٤/٢٥٦) -مستندًا إلى أقوال السلف- قراءة: ‹لَتَرْكَبَنَّ› وأنّ المعنى: لتركبَن أنت -يا محمد- حالًا بعد حال، وأمرًا بعد أمر من الشدائد. فقال: «وأولى القراءات في ذلك عندي بالصواب: قراءة مَن قرأ بالتاء وبفتح الباء؛ لأن تأويل أهل التأويل من جميعهم بذلك ورد، وإن كان للقراءات الأُخر وجوه مفهومة. وإذا كان الصواب من القراءة في ذلك ما ذكرنا فالصواب من التأويل قول مَن قال: ‹لَتَرْكَبَنَّ› أنت -يا محمد- حالًا بعد حال، وأمرًا بعد أمر من الشدائد». ثم بيّن أنه وإن كان الخطاب إلى رسول الله ﷺ، فليس خاصًّا به، بل خوطب به جميع الناس أنهم يَلقون من شدائد يوم القيامة وأهواله أحوالًا؛ وذلك لدلالة السياق، فقال: «وإنما قلنا: عني بذلك ما ذكرنا، أنّ الكلام قبل قوله: <q>﴿لتركبن طبقا عن طبق﴾</q> جرى بخطاب الجميع، وكذلك بعده، فكان أشبه أن يكون ذلك نظير ما قبله وما بعده». ",footnotes:1:أخرجه الطبراني (١٠٠٦٨). وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، والحاكم في الكنى، وابن منده في غرائب شعبة، وابن مردويه. وهي قراءة متواترة، قرأ بها ابن كثير، وحمزة، والكسائي، وخلف، وقرأ بقية العشرة: <q>﴿لَتَرْكَبُنَّ﴾</q> بضم الباء. انظر: النشر ٢/٣٩٩، والإتحاف ص٥٧٧.أخرجه أبو عبيد -كما في فتح الباري ٨/٦٩٨-، وابن منيع -كما في المطالب العالية (٤١٧٨)-، وابن جرير ٢٤/٢٥١. وعزاه السيوطي إلى سعيد بن منصور، وعبد بن حميد، وابن المنذر، وابن مردويه.عزاه السيوطي إلى عبد بن حميد.عزاه السيوطي إلى عبد بن حميد.عزاه السيوطي إلى عبد بن حميد.عزاه السيوطي إلى عبد بن حميد.أي: بفتح الباء؛ وهي قراءة ابن كثير وحمزة والكسائي وخلف، وقرأ الباقون بضمها. ينظر: النشر ٢/٢٩٨.أخرجه الطبراني (١٠٠٦٨). وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، والحاكم في الكنى، وابن منده في غرائب شعبة، وابن مردويه.أخرجه البزار (١٦٠٢).أخرجه عبد الرزاق ٢/٣٥٩، وابن جرير ٢٤/٢٥٥، والحاكم ٢/٥١٨. وعزاه السيوطي إلى الفريابي، وسعيد بن منصور، وعبد بن حميد، وابن المنذر، وابن أبي حاتم، وابن مردويه، والبيهقي في البعث.أخرجه آدم ابن إياس -كما في تفسير مجاهد ص٧١٦-. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، والبيهقي.تفسير الثعلبي ١٠/١٦١، وتفسير البغوي ٨/٣٧٦.أخرجه آدم بن أبي إياس -كما في تفسير مجاهد ص٧١٥- من طريق عكرمة، وأبو عبيد -كما في فتح الباري ٨/٦٩٨-، وابن منيع -كما في المطالب العالية (٤١٧٨)-، وابن جرير ٢٤/٢٥١، والبخاري (٤٩٤٠). وعزاه السيوطي إلى سعيد بن منصور، وعبد بن حميد، وابن المنذر، وابن مردويه.أخرجه الطيالسي -كما في تفسير ابن كثير ٨/٣٨١-، والطبراني (١١١٧٣). وعزاه السيوطي إلى عبد بن حميد، وابن أبي حاتم.أخرجه ابن جرير ٢٤/٢٥١، وكذلك من طريق أبي إسحاق، عن رجل حدَّثه.أخرجه آدم ابن أبي إياس -كما في تفسير مجاهد ص٧١٦-، وابن جرير ٢٤/٢٥٣.أخرجه عبد الرزاق ٢/٣٥٩، وابن جرير ٢٤/٢٥٢.عزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ٢٤/٢٥٢.أخرجه عبد الرزاق ٢/٣٥٩، وابن جرير ٢٤/٢٥٣. وعزاه السيوطي إلى عبد بن حميد.تفسير البغوي ٨/٣٧٥.أخرجه ابن جرير ٢٤/٢٥٣.أخرجه ابن جرير ٢٤/٢٥٢.أخرجه ابن جرير ٢٤/٢٥٤ بنحوه، وابن أبي حاتم -كما في تفسير ابن كثير ٨/٣٨١-. وعزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ٢٤/٢٥٢. وذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٥/١١٣-.أخرجه ابن جرير ٢٤/٢٥٣.تفسير الثعلبي ١٠/١٦١، وتفسير البغوي ٨/٣٧٦.أخرجه ابن أبي حاتم -كما في تفسير ابن كثير ٨/٣٨٢-، ونعيم بن حماد (٤٢)، وأبو نعيم في الحلية ٥/١٨٤. وعزاه السيوطي إلى ابن المنذر.أخرجه عبد الرزاق ٢/٣٥٩، وابن جرير ٢٤/٢٥٣. وعزاه السيوطي إلى عبد بن حميد.أخرجه أبو جعفر الرملي في جزئه (تفسير عطاء) ص١٠٠.تفسير الثعلبي ١٠/١٦١، وفي تفسير البغوي ٨/٣٧٥ بلفظ: يعني: تصعد فيها.تفسير الثعلبي ١٠/١٦١.تفسير مقاتل بن سليمان ٤/٦٤٠.أخرجه ابن جرير ٢٤/٢٥٤.
84,20," <q>﴿فَمَا لَهُمۡ لَا یُؤۡمِنُونَ ۝٢٠﴾</q> - تفسير ٨٢٣٤٠- قال مقاتل بن سليمان: قال: <q>﴿فَما لَهُمْ لا يُؤْمِنُونَ﴾</q> بالبعث، <q>﴿و﴾</q>قد كانوا من قبل هذا الذي وصفته <q>﴿إذا قُرِئَ عَلَيْهِمُ القُرْآنُ لا يَسْجُدُونَ﴾</q>{1}. (ز) ٨٢٣٤١- قال عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿فَما لَهُمْ لا يُؤْمِنُونَ﴾</q>، قال: بهذا الحديث، وبهذا الأمر{2}٧١٠٢. (ز) ٧١٠٢ لم يذكر ابنُ جرير (٢٤/٢٥٧) غير قول عبد الرحمن بن زيد. ",footnotes:1:تفسير مقاتل بن سليمان ٤/٦٤٠.أخرجه ابن جرير ٢٤/٢٥٧.
84,21," <q>﴿وَإِذَا قُرِئَ عَلَیۡهِمُ ٱلۡقُرۡءَانُ لَا یَسۡجُدُونَ﴾</q> - نزول الآية ٨٢٣٤٢- قال مقاتل بن سليمان: <q>﴿وإذا قُرِئَ عَلَيْهِمُ القُرْآنُ لا يَسْجُدُونَ﴾</q> وذلك أنّ رسول الله ﷺ قرأ ذات يوم: <q>﴿واسْجُدْ واقْتَرِبْ﴾</q> [العلق:١٩]، فسجد، وسجد المؤمنون معه، وكانت قريش يُصفِّقون فوق رؤوسهم ويُصفِّرون، وكان الذي يُصفّر قريب القرابة من رسول الله ﷺ، فذلك قوله: <q>﴿وما كانَ صَلاتُهُمْ عِنْدَ البَيْتِ إلّا مُكاءً وتَصْدِيَةً﴾</q> [الأنفال:٣٥]، فلما سجد رسول الله ﷺ لم يسجدوا، وسخروا منه، وكان إذا قرأ آذوه بالصَّفير والتصفيق؛ فأنزل الله ﷿: <q>﴿فَما لَهُمْ لا يُؤْمِنُونَ وإذا قُرِئَ عَلَيْهِمُ القُرْآنُ لا يَسْجُدُونَ﴾</q>{1}. (ز) <q>﴿وَإِذَا قُرِئَ عَلَیۡهِمُ ٱلۡقُرۡءَانُ لَا یَسۡجُدُونَ﴾</q> - تفسير الآية ٨٢٣٤٣- قال محمد بن السّائِب الكلبي= (ز) ٨٢٣٤٤- ومقاتل: <q>﴿وإذا قُرِئَ عَلَيْهِمُ القُرْآنُ لا يَسْجُدُونَ﴾</q> لا يُصَلُّون{2}٧١٠٣. (ز) ٧١٠٣ نقل ابنُ تيمية (٦/٤٩٠) في قوله: <q>﴿لا يسجدون﴾</q> قولين: أحدهما: ما جاء في قول مقاتل. الثاني: أنّ معناه: لا يخضعون له، ولا يستكينون له. وعلّق على الأول بقوله: «القول الأول هو الذي يذكره كثير من المفسرين، لا يذكرون غيره؛ كالثعلبي، والبغوي، وحكوه عن مقاتل والكلبي، وهو المنقول عن مفسري السلف، وعليه عامة العلماء». وعلّق على الثاني بقوله: «وأما القول الثاني فما علمتُ أحدًا نقله عن أحد من السلف، والذين قالوه إنما قالوه لما رأوا أنه لا يجب على كلّ من سمع شيئًا من القرآن أن يسجد، فأرادوا أن يُفسِّروا الآية بمعنى يجب في كلّ حال، فقالوا: يخضعون، ويستكينون. فإنّ هذا يؤمر به كلّ مَن قُرئ عليه القرآن». ",footnotes:1:تفسير مقاتل بن سليمان ٤/٦٤٠.تفسير البغوي ٨/٣٧٦.
84,22," <q>﴿بَلِ ٱلَّذِینَ كَفَرُوا۟ یُكَذِّبُونَ ۝٢٢﴾</q> - تفسير ٨٢٣٤٥- قال مقاتل بن سليمان: ثم قال: <q>﴿بَلِ الَّذِينَ كَفَرُوا﴾</q> يقول: لكن الذين كفروا <q>﴿يُكَذِّبُونَ﴾</q>{1}. (ز) ",footnotes:1:تفسير مقاتل بن سليمان ٤/٦٤٠.
84,23," <q>﴿وَٱللَّهُ أَعۡلَمُ بِمَا یُوعُونَ ۝٢٣﴾</q> - تفسير ٨٢٣٤٦- عن عبد الله بن عباس، في قوله: <q>﴿واللَّهُ أعْلَمُ بِما يُوعُونَ﴾</q>، قال: يُسِرُّون{1}. (١٥/٣٢٥) ٨٢٣٤٧- عن مجاهد بن جبر -من طريق ابن أبي نجيح- <q>﴿واللَّهُ أعْلَمُ بِما يُوعُونَ﴾</q>، قال: يكتمون{2}. (١٥/٣٢٦) ٨٢٣٤٨- عن قتادة بن دعامة -من طريق معمر- <q>﴿بِما يُوعُونَ﴾</q>، قال: في صدورهم{3}. (١٥/٣٢٦) ٨٢٣٤٩- قال مقاتل بن سليمان: <q>﴿واللَّهُ أعْلَمُ بِما يُوعُونَ﴾</q>، يقول: بما يُجْمِعون عليه من الإثم والفسوق{4}. (ز) ٨٢٣٥٠- قال عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿واللَّهُ أعْلَمُ بِما يُوعُونَ﴾</q>، قال: المرء يوعي متاعه وماله؛ هذا في هذا، وهذا في هذا، هكذا يعرف الله ما يوعون من الأعمال، والأعمال السيئة مما توعيه قلوبهم، ويجتمع فيها من هذه الأعمال الخير والشر، فالقلوب وعاء هذه الأعمال كلّها الخير والشر، يعلم ما يُسرُّون وما يُعلنون، ولقد وعى لكم ما لا يدري أحد ما هو مِن القرآن وغير ذلك، فاتقوا الله وإيّاكم أن تدخلوا على مكارم هذه الأعمال بعض هذا الخبث ما يُفسدها{5}. (ز) ",footnotes:1:أخرجه ابن أبي حاتم -كما في فتح الباري ٨/٦٩٧-. وعزاه السيوطي إلى ابن المنذر.تفسير مجاهد ص٧١٦، وأخرجه ابن جرير ٢٤/٢٥٧. وعزاه السيوطي إلى عبد بن حميد.أخرجه عبد الرزاق ٢/٣٦٠، وابن جرير ٢٤/٢٥٨.تفسير مقاتل بن سليمان ٤/٦٤٠.أخرجه ابن جرير ٢٤/٢٥٨.
84,24," <q>﴿فَبَشِّرۡهُم بِعَذَابٍ أَلِیمٍ ۝٢٤﴾</q> - تفسير ٨٢٣٥١- قال مقاتل بن سليمان: <q>﴿فَبَشِّرْهُمْ﴾</q> يا محمد <q>﴿بِعَذابٍ ألِيمٍ﴾</q> يقول: عذاب وجيع لأهل مكة كلّهم{1}. (ز) ",footnotes:1:تفسير مقاتل بن سليمان ٤/٦٤٠.
84,25," <q>﴿إِلَّا ٱلَّذِینَ ءَامَنُوا۟ وَعَمِلُوا۟ ٱلصَّـٰلِحَـٰتِ لَهُمۡ أَجۡرٌ غَیۡرُ مَمۡنُونِۭ ۝٢٥﴾</q> - تفسير ٨٢٣٥٢- عن عبد الله بن عباس -من طريق علي- قوله: <q>﴿لَهُمْ أجْرٌ غَيْرُ مَمْنُونٍ﴾</q>، يقول: غير منقوص{1}. (ز) ٨٢٣٥٣- عن عبد الله بن عباس، أنّ نافع بن الأزرق سأله عن قوله: <q>﴿لَهُمْ أجْرٌ غَيْرُ مَمْنُونٍ﴾</q>. قال: غير منقوص. قال: وهل تعرف العرب ذلك؟ قال: نعم، أما سمعتَ قول زُهير: فَضْلَ الجوادِ على الخيلِ البِطاءِ فلا يُعطِي بذلك ممنونًا ولا نَزِقا؟{2}. (١٥/٣٢٦) ٨٢٣٥٤- عن مجاهد بن جبر -من طريق ابن جريج- في قوله: <q>﴿لَهُمْ أجْرٌ غَيْرُ مَمْنُونٍ﴾</q>، قال: غير محسوب{3}٧١٠٤. (١٥/٣٢٦) ٧١٠٤ لم يذكر ابنُ جرير (٢٤/٢٥٩) غير قول مجاهد، وابن عباس من طريق علي. ٨٢٣٥٥- عن الحسن البصري، في قوله: <q>﴿لَهُمْ أجْرٌ غَيْرُ مَمْنُونٍ﴾</q>، قال: يُعطون أجورهم، ولا يُمَنّ عليهم{4}. (١٥/٣٢٦) ٨٢٣٥٦- قال مقاتل بن سليمان: ثم استثنى لعِلْمٍ قَد سَبَق، فقال: <q>﴿إلّا الَّذِينَ آمَنُوا وعَمِلُوا الصّالِحاتِ لَهُمْ أجْرٌ غَيْرُ مَمْنُونٍ﴾</q>{5}. (ز) ",footnotes:1:أخرجه ابن جرير ٢٤/٢٥٩.أخرجه الطستي -كما في الإتقان ٢/١٠٢-.أخرجه ابن جرير ٢٤/٢٥٩. وعزاه السيوطي إلى عبد بن حميد.ذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٥/١١٣-. وعزاه السيوطي إلى عبد بن حميد.تفسير مقاتل بن سليمان ٤/٦٤٠.
