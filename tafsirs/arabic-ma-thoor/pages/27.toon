tafsir[5]{c,v,t}:
2,177," <q>﴿لَّیۡسَ ٱلۡبِرَّ أَن تُوَلُّوا۟ وُجُوهَكُمۡ قِبَلَ ٱلۡمَشۡرِقِ وَٱلۡمَغۡرِبِ﴾</q> الآية - قراءات ٤٩٧٩- عن ابن مسعود= (ز) ٤٩٨٠- وأبي بن كعب -من طريق هارون- أنّهما قرآ: (لَيْسَ البِرَّ بِأَن تُوَلُّوا){1}. (٢/١٣٩) ٤٩٨١- عن الأعمش -من طريق زائدة- قال: في قراءتنا مكان <q>﴿ليس البر أن تولوا﴾</q>: (ولا تَحْسَبَنَّ أنَّ البِرَّ){2}. (٢/١٤٠) <q>﴿لَّیۡسَ ٱلۡبِرَّ أَن تُوَلُّوا۟ وُجُوهَكُمۡ قِبَلَ ٱلۡمَشۡرِقِ وَٱلۡمَغۡرِبِ﴾</q> الآية - نزول الآية ٤٩٨٢- عن عبد الله بن عباس -من طريق ابن جُرَيْج- قال: هذه الآية نزلت بالمدينة: <q>﴿ليس البر أن تولوا وجوهكم قبل المشرق والمغرب﴾</q>، يعني: الصلاة. يقول: ليس البر أن تُصَلُّوا ولا تعملوا غير ذلك{3}. (٢/١٣٨) ٤٩٨٣- عن قتادة بن دِعامة -من طريق سعيد- في قوله: <q>﴿ليس البر﴾</q> الآية، قال: ذُكِر لنا: أنّ رجلًا سأل النبي ﷺ عن البِرِّ؛ فأنزل الله هذه الآية، فدعا الرجلَ، فتلاها عليه. وقد كان الرجل قبل الفرائض إذا شهد أن لا إله إلا الله وأنّ محمدًا عبده ورسوله، ثم مات على ذلك، يُرْجى له في خير؛ فأنزل الله: <q>﴿ليس البر أن تولوا وجوهكم قبل المشرق والمغرب﴾</q>، وكانت اليهود توجّهت قِبَل المغرب، والنصارى قِبَل المشرق، <q>﴿ولكن البر من آمن بالله الآية﴾</q>{4}. (٢/١٣٩) ٤٩٨٤- عن قتادة بن دِعامة -من طريق مَعْمَر- قال: كانتِ اليهود تُصَلّي قِبَل المغرب، والنصارى قِبَل المشرق؛ فنزلت: <q>﴿ليس البر أن تولوا وجوهكم﴾</q> الآية{5}. (٢/١٣٨) ٤٩٨٥- عن الربيع بن أنس -من طريق أبي جعفر- قال: كانت اليهود تصلي قِبَل المغرب، والنصارى قِبَل المشرق؛ فنزلت: <q>﴿ليس البر أن تُولوا وجوهكم قبل المشرق والمغرب﴾</q>{6}. (ز) ٤٩٨٦- عن مقاتل بن حيان، نحوه{7}٦١٢. (ز) ٦١٢ اختلف أهل التأويل في معنى الآية، والمخاطب بها، على قولين: أحدهما: المسلمون، والمعنى: ليس البرَّ كله في الصلاة، ولكن البر ما في هذه الآية. والثاني: أهل الكتابَيْن، والمعنى: ليس البر صلاة اليهود إلى المغرب وصلاة النصارى إلى المشرق، ولكن البر ما في هذه الآية. ورَجَّحَ ابنُ جرير (٣/٧٦) القولَ الثاني، وهو قول قتادة، والربيع بدلالة السياق، فقال: «الآيات قبلها مَضَتْ بتوبيخهم ولَومهم، والخبر عنهم وعما أُعِدَّ لهم من أليم العذاب، وهذا في سياق ما قبلها». وذَهَبَ ابنُ كثير (٢/١٥٥) أنّها نزلت في «طائفة من أهل الكتاب وبعض المسلمين، شَقَّ عليهم التحول إلى الكعبة؛ فأنزل الله تعالى بيان حكمته في ذلك، وهو أنّ المراد إنما هو طاعة الله ﷿». <q>﴿لَّیۡسَ ٱلۡبِرَّ أَن تُوَلُّوا۟ وُجُوهَكُمۡ قِبَلَ ٱلۡمَشۡرِقِ وَٱلۡمَغۡرِبِ﴾</q> - تفسير ٤٩٨٧- عن أبي ذر -من طريق مجاهد- أنّه سأل رسول الله ﷺ عن الإيمان. فتلا: <q>﴿ليس البر أن تولوا وجوهكم﴾</q>، حتى فرغ منها، ثمّ سأله أيضا فتلاها، ثم سأله فتلاها، وقال: «وإذا عَمِلْتَ حسنةً أحَبَّها قلبُك، وإذا عَمِلْتَ سَيِّئَةً أبْغَضَها قلبُك»{8}. (٢/١٣٧) ٤٩٨٨- عن القاسم بن عبد الرحمن، قال: جاء رجل إلى أبي ذر، فقال: ما الإيمان؟ فتلا عليه هذه الآية: <q>﴿لَيْسَ البِرَّ أنْ تُوَلُّوا وُجُوهَكُمْ قِبَلَ المَشْرِقِ والمَغْرِبِ﴾</q> حتى فرغ منها. فقال الرجل: ليس عن البِرِّ سألتك. فقال أبو ذر: جاء رجل إلى رسول الله ﷺ، فسأله عَمّا سألتني، فقرأ عليه هذه الآية، فأبى أن يرضى كما أبَيْتَ أن ترضى، فقال له رسول الله ﷺ: «ادْنُ». فدنا، فقال: «المؤمنُ إذا عَمِل الحسنةَ سَرَّتْهُ ورَجا ثوابَها، وإذا عمل السَّيِّئَةَ أحْزَنَتْهُ وخافَ عِقابَها»{9}. (٢/١٣٧) ٤٩٨٩- عن مجاهد: أنّ أبا ذرٍّ سأل رسول الله ﷺ عن الإيمان. فقرأ: <q>﴿ليس البر أن تولوا وجوهكم قبل المشرق والمغرب﴾</q> الآية{10}. (٢/١٣٨) ٤٩٩٠- عن عكرمة، قال: سُئِل الحسنُ بن علي مُقْبَلَه من الشام عن الإيمان. فقرأ: <q>﴿ليس البر﴾</q> الآية{11}. (٢/١٣٨) ٤٩٩١- عن عبد الله بن عباس -من طريق العوفي- <q>﴿ليس البر أن تولوا وجوهكم﴾</q>، يعني: في الصلاة. يقول: ليس البِرَّ أن تُصَلُّوا ولا تعملوا. فهذا حين تَحَوَّل من مكة إلى المدينة، ونزلت الفرائض، وحَدَّ الحدود؛ فأمر الله بالفرائض، والعملِ بها{12}. (٢/١٣٨) ٤٩٩٢- عن أبي العالية -من طريق الربيع بن أنس- قال: كانت اليهود تُقْبِل قِبَل المغرب، وكانت النصارى تُقْبِل قِبَل المشرق؛ فقال الله: <q>﴿ليس البر أن تولوا وجوهكم قبل المشرق والمغرب﴾</q>. يقول: هذا كلام الإيمان، وحقيقة العمل{13}. (ز) ٤٩٩٣- عن الحسن البصري، نحو ذلك{14}. (ز) ٤٩٩٤- عن مجاهد بن جَبْر -من طريق ابن أبي نَجِيح-: <q>﴿ليس البرّ أن تُولوا وجوهكم قبَل المشرق والمغرب﴾</q>، ولكِنَّ البر ما ثَبَت في القلوب من طاعة الله{15}. (٢/١٤٠) ٤٩٩٥- عن مجاهد بن جَبْر -من طريق ابن جُرَيْج-، نحوه، وزاد في أوله: يعني: السجود{3}. (ز) ٤٩٩٦- عن الضحاك بن مُزاحِم -من طريق عبيد بن سليمان- أنّه قال فيها، قال: يقول: ليس البِرَّ أن تُصَلُّوا ولا تعملوا غير ذلك. وهذا حين تَحَوَّل من مكة إلى المدينة؛ فأنزل الله الفرائض، وحدَّ الحدود بالمدينة، وأمر بالفرائض أن يؤخذ بها{17}. (ز) ٤٩٩٧- عن مقاتل بن حيان -من طريق بُكَيْر بن معروف-، نحو ذلك{18}. (ز) ٤٩٩٨- قال قتادة بن دِعامة: يقول: ليس البر أن تكونوا نصارى فتُصَلُّوا إلى المشرق، ولا أن تكونوا يهودًا فتُصَلُّوا إلى المغرب إلى بيت المقدس{19}. (ز) ٤٩٩٩- عن مقاتل بن حيان-من طريق بُكَيْر بن معروف-: في قوله: <q>﴿ليس البر﴾</q>، يعني: التقوى{20}. (ز) ٥٠٠٠- قال مقاتل بن سليمان: <q>﴿ليس البر أن تولوا وجوهكم﴾</q>، يعني: ليس التقوى أن تُحَوِّلوا وجوهكم في الصلاة قِبَل -يعني: تِلْقاء- المشرق والمغرب، فلا تفعلوا ذلك{21}. (ز) <q>﴿وَلَـٰكِنَّ ٱلۡبِرَّ مَنۡ ءَامَنَ بِٱللَّهِ وَٱلۡیَوۡمِ ٱلۡـَٔاخِرِ وَٱلۡمَلَـٰۤىِٕكَةِ وَٱلۡكِتَـٰبِ وَٱلنَّبِیِّـۧنَ﴾</q> - تفسير ٥٠٠١- عن سعيد بن جبير -من طريق عطاء بن دينار- في قول الله: <q>﴿ولكن البر من ءامن بالله واليوم الآخر والملائكة والكتاب والنبيين﴾</q> أنّه حق{22}. (ز) ٥٠٠٢- قال مقاتل بن سليمان: <q>﴿ولكن البر من آمن بالله﴾</q> يعني: صدَّق بالله بأنّه واحد لا شريك له، <q>﴿واليوم الآخر﴾</q> يعني: وصدَّق بالبعث الذي فيه جزاء الأعمال بأنّه كائن، <q>﴿والملائكة﴾</q> أي: وصدَّق بالملائكة، <q>﴿والكتاب والنبيين﴾</q>{21}. (ز) ٥٠٠٣- عن سفيان -من طريق ابن أبي عمر- <q>﴿ولكن البر من آمن بالله﴾</q>، قال: أنواع البر كُلّها{24}٦١٣. (ز) ٦١٣ قال ابنُ تيمية (١/٤١٠): «لفظ البِرِّ إذا أُطْلِق تناولَ جميعَ ما أمَرَ اللهُ به... وكان مُسَمّاه مُسَمّى التقوى، والتقوى إذا أُطْلِقَت كان مُسَمّاها مُسَمّى البِرَّ، ثُمَّ قد يُجْمَع بينهما كما في قوله تعالى: <q>﴿وتعاونوا على البر والتقوى﴾</q> [المائدة:٢]». <q>﴿وَلَـٰكِنَّ ٱلۡبِرَّ مَنۡ ءَامَنَ بِٱللَّهِ وَٱلۡیَوۡمِ ٱلۡـَٔاخِرِ وَٱلۡمَلَـٰۤىِٕكَةِ وَٱلۡكِتَـٰبِ وَٱلنَّبِیِّـۧنَ﴾</q> - آثار متعلقة بالآية ٥٠٠٤- عن عمر بن الخطاب، قال: بينما نحن عند رسول الله ﷺ ذات يوم إذ طلع علينا رجلٌ شديدُ بياض الثياب، شديدُ سواد الشعر، لا يُرى عليه أثرُ السَّفَر، ولا يعرفه مِنّا أحد، حتى جلس إلى النبي ﷺ، فأَسْنَد رُكْبَتَيْه إلى رُكْبَتَيْه، ووضع كَفَّيْه على فَخِذَيْه، وقال: يا محمد، أخبِرْني عن الإسلام. فقال رسول الله ﷺ: «الإسلامُ أن تشهدَ أن لا إله إلا الله وأنّ محمدًا رسول الله، وتقيمَ الصلاة، وتؤتيَ الزكاة، وتصومَ رمضان، وتَحُجَّ البيت إن استطعتَ إليه سبيلًا». قال: صدقت. قال: فعَجِبْنا له، يسأله ويصدقه! قال: فأخبِرني عن الإيمان. قال: «أن تؤمنَ بالله، وملائكته، وكتبه، ورسله، واليوم الآخر، وتؤمنَ بالقَدَر خيرِه وشَرِّه». قال: صدقت. قال: فأخبِرني عن الإحسان. قال: «أن تعبد الله كأنّك تراه، فإن لم تكن تراه فإنّه يراك». قال: فأخبِرني عن الساعة. قال: «ما المسئولُ عنها بِأَعْلَمَ من السائل». قال: فأخْبِرني عن أمارَتِها. قال: «أن تَلِدَ الأَمَةُ رَبَّتَها، وأن تَرى الحُفاة العُراة العالَة رِعاءَ الشّاءِ يَتَطاوَلُون في البُنْيان». قال: ثُمَّ انطلق، فلبثتُ مَلِيًّا، ثم قال لي: «يا عمر، أتدري مَنِ السائل؟». قلت: الله ورسوله أعلم. قال: «فإنّه جبريل، أتاكم يُعَلِّمُكم دينَكم»{25}. (٢/١٤٠) <q>﴿وَءَاتَى ٱلۡمَالَ عَلَىٰ حُبِّهِۦ﴾</q> - تفسير ٥٠٠٥- عن المطلب: أنّه قيل: يا رسول الله، ما <q>﴿آتى المال على حبه﴾</q>؟ فكُلُّنا نُحِبُّه! قال رسول الله ﷺ: «تُؤتيه حين تُؤْتِيه ونفسُك تُحَدِّثُك بطُولِ العُمُرِ والفَقْرِ»{26}. (٢/١٤٤) ٥٠٠٦- عن عبد الله بن مسعود -من طريق مُرَّة- <q>﴿وآتى المال على حبه﴾</q>، قال: يُعْطِي وهو صحيحٌ، شحيحٌ٦١٤، يأمل العَيْش، ويخاف الفقر{27}. (٢/١٤٣) ٦١٤ بيَّنَ ابنُ عطية (١/٤٢٠-٤٢١) المقصودَ بالشُحِّ هنا، فقال: «والشُّحُّ في هذا الحديث هو الغَرِيزِيُّ الذي في قوله تعالى: <q>﴿وأحضرت الأنفس الشح﴾</q> [النساء:١٢٨]، وليس المعنى: أن يكون المتصدّق مُتَّصِفًا بالشُّحِّ الذي هو البخل». ٥٠٠٧- عن ابن مسعود مرفوعًا، مثله{28}. (٢/١٤٤) ٥٠٠٨- عن أبي هريرة، قال: قال رسول الله ﷺ: «أفْضَلُ الصَّدَقَةِ أن تَصَدَّق وأنت صحيحٌ، شحيحٌ، تَأْمَلُ البقاءَ، وتخشى الفقر، ولا تُمْهِل حتّى إذا بلغت الحلقومَ قلتَ: لفلان كذا، ولفلان كذا. ألا وقد كان لفلان»{29}. (٢/١٤٤) ٥٠٠٩- عن سعيد بن جبير -من طريق عطاء بن دينار- في قوله: <q>﴿وآتى المال﴾</q> يعني: أعطى المال <q>﴿على حبه﴾</q> يعني: على حُبِّ المال{22}. (٢/١٤٣) ٥٠١٠- عن مقاتل بن حيان-من طريق بُكَيْر بن معروف-، نحو الشطر الأول{22}. (ز) ٥٠١١- قال مقاتل بن سليمان: <q>﴿وآتى المال﴾</q> يعني: وأعطى المال <q>﴿على حُبِّه﴾</q> له{21}٦١٥. (ز) ٦١٥ ذكر ابنُ عطية (١/٤٢٠) أن الضمير في <q>﴿حُبِّهِ﴾</q> عائد على المال، ثم قال: «ويحتمل أن يعود الضمير على الإيتاء، أي: في وقت حاجة من الناس وفاقة، فإيتاء المال حبيب إليهم، ويحتمل أن يعود الضمير على اسم الله تعالى من قوله: <q>﴿مَن آمَنَ بِاللَّهِ﴾</q> أي: مَن تَصَدَّق محبة في الله تعالى وطاعاته. ويحتمل أن يعود على الضمير المستكن في <q>﴿آتى﴾</q> أي: على حبه المال، فالمصدر مضاف إلى الفاعل، والمعنى المقصود: أن يتصدق المرء في هذه الوجوه وهو شحيح صحيح يخشى الفقر ويأمل الغنى، كما قال ﷺ». <q>﴿وَءَاتَى ٱلۡمَالَ عَلَىٰ حُبِّهِۦ﴾</q> - آثار متعلقة بالآية ٥٠١٢- عن فاطمة بنت قيس، قالت: قال رسول الله ﷺ: «في المال حَقٌّ سوى الزكاة». ثم قرأ: <q>﴿ليس البر أن تولوا وجوهكم﴾</q> الآية{33}. (٢/١٥٠) ٥٠١٣- عن إسماعيل بن سالم، عن عامر الشعبي سمِعْتُه سُئِل: هل على الرجل حَقٌّ في ماله سوى الزكاة؟ قال: نعم. وتلا هذه الآية: <q>﴿وآتى المالَ على حُبه ذَوي القربى واليتامى والمساكينَ وابنَ السبيل والسائلين وفي الرقاب وأقام الصلاة وآتى الزكاة﴾</q>{34}. (٢/١٥٠) ٥٠١٤- عن إسماعيل السُّدِّيّ: أنّ هذا شيء واجبٌ في المال، حَقٌّ على صاحب المال أن يفعله سوى الذي عليه من الزكاة{35}٦١٦. (ز) ٦١٦ هل في المال حقّ واجب سوى الزكاة؟ في هذه المسألة قولان لأهل العلم، ذكرهما ابنُ جرير (٣/٨٤-٨٥). وذَهبَ في ظاهر كلامه إلى أنّ فيه حقوقًا تجبُ غير الزكاة استنادًا إلى السياق، وقول أهل التأويل، حيث ذكر أول الآية <q>﴿وآتى المال على حُبّه﴾</q>، ثم قال: «<q>﴿وآتى الزكاة﴾</q>، فلكلّ مالٍ منهما حكمٌ يخصّه، وكلاهما مذكورٌ في سياق ما أوجبه الله على أهل الإيمان». وقال ابنُ كثير (٢/١٦٠-١٦١ بتصرف): «قوله: <q>﴿وآتى الزكاة﴾</q> يحتمل أن يكون المراد به: زكاة النفس، وتخليصها من الأخلاق الدنية الرذيلة، كقوله: <q>﴿قد أفلح من زكاها وقد خاب من دساها﴾</q> [الشمس:٩-١٠]، ويحتمل أن يكون المراد: زكاة المال، ويكون المذكور في قوله: <q>﴿وآتى المال على حبه﴾</q> إنما هو التطوع والبِرُّ والصِّلَة؛ ولهذا تقدم في الحديث عن فاطمة بنت قيس: إنّ في المال حَقًّا سوى الزكاة». وذَهَبَ ابنُ عطية (١/٤٢١) إلى نحو ما ذكره ابنُ جرير مُسْتَنِدًا إلى السياق، فقال: «وذِكْرُ الزكاة هنا دليلٌ على أنّ ما تقدم ليس بالزكاة المفروضة». وذَهَبَ ابنُ تيمية (١/٤١٢) إلى أنّ في المال حقوقًا سوى الزكاة، بها كمال البر، استنادًا إلى السياق، فقال: «وهذه الخصالُ المذكورة في الآية قد دلَّت على وجوبها؛ لأنه أخبر أنّ أهلها هم الذين صَدَقوا في قولهم، وهم المتقون، والصِّدق واجب، والإيمان واجب، ففيها إيجاب حقوق سوى الزكاة». <q>﴿ذَوِی ٱلۡقُرۡبَىٰ﴾</q> - تفسير ٥٠١٥- عن سعيد بن جبير -من طريق عطاء بن دينار- في قوله: <q>﴿ذوي القربى﴾</q>، يعني: قرابته{36}. (٢/١٤٥) <q>﴿ذَوِی ٱلۡقُرۡبَىٰ﴾</q> - آثار متعلقة بالآية ٥٠١٦- عن أم كلثوم بنت عقبة بن أبي مُعَيْط: سمعتُ رسول الله ﷺ يقول: «أفضل الصَّدَقة على ذي الرَّحِم الكاشِح{37}»{38}. (٢/١٤٥) ٥٠١٧- عن سلمان بن عامر الضَّبِّيِّ، قال: قال رسول الله ﷺ: «الصدقةُ على المسكين صدقةٌ، وعلى ذي الرَّحِم اثنتان: صدقةٌ، وصِلَةٌ»{39}. (٢/١٤٦) ٥٠١٨- عن زينب امرأة عبد الله بن مسعود، قالت: سألتُ رسول الله ﷺ: أتُجْزِئُ عَنِّي من الصدقة النفقةُ على زوجي، وأيتامٍ في حِجْرِي؟ قال: «لكِ أجران: أجرُ الصدقة، وأجرُ القرابة»{40}. (٢/١٤٦) <q>﴿وَٱلۡیَتَـٰمَىٰ وَٱلۡمَسَـٰكِینَ وَٱبۡنَ ٱلسَّبِیلِ﴾</q>{41} - تفسير ٥٠١٩- عن عبد الله بن عباس -من طريق علي بن أبي طلحة- قال: ابنُ السبيل: هو الضَّيْفُ الذي ينزِل بالمسلمين{36}. (٢/١٤٧) ٥٠٢٠- عن سعيد بن جبير= (ز) ٥٠٢١- وقتادة بن دعامة، نحو ذلك{43}. (ز) ٥٠٢٢- عن مجاهد بن جبر -من طريق ابن أبي نَجِيح- في قوله: <q>﴿وابن السبيل﴾</q>، قال: الذي يَمُرُّ عليك وهو مسافر{44}. (٢/١٤٧) ٥٠٢٣- عن الضحاك بن مُزاحِم= (ز) ٥٠٢٤- والحسن البصري= (ز) ٥٠٢٥- ومحمد ابن شهاب الزُّهْرِي، نحو ذلك{45}. (ز) ٥٠٢٦- وعن الربيع بن أنس -من طريق أبي جعفر-= (ز) ٥٠٢٧- ومقاتل بن حيان -من طريق بُكَيْر بن معروف-، نحو ذلك{46}. (ز) ٥٠٢٨- عن أبي جعفر محمد بن علي -من طريق جابر- <q>﴿وابن السبيل﴾</q>، قال: المجتاز من أرض إلى أرض{47}. (ز) ٥٠٢٩- عن قتادة بن دِعامة -من طريق مَعْمَر- في قوله: <q>﴿وابن السبيل﴾</q>، قال: الذي يَمُرُّ عليك وهو مسافر{44}٦١٧. (ز) ٦١٧ علَّق ابنُ عطية (١/٤٢١) على هذا القول، بقوله: «وهذا كما يقال: ابن ماء للطائر الملازم للماء، ومنه قول النبي ﷺ: «لا يدخل الجنة ابن زِنا». أي: الملازم له». ٥٠٣٠- عن قتادة بن دِعامة -من طريق سعيد- <q>﴿وابن السبيل﴾</q>، قال: هو الضيف. قال: وذُكِر لنا: أنّ نبي الله ﷺ كان يقول: «مَن كان يؤمن بالله واليوم الآخر فلْيُكْرِم ضيفَه، ومن كان يؤمن بالله واليوم الآخر فلْيَقُل خَيْرًا أو لِيَسْكُت». قال: وكان يُقال: حَقُّ الضيافةِ ثلاثُ ليال، فكُلُّ شيء أصابه بعد ذلك صدقةٌ{49}. (ز) ٥٠٣١- قال مقاتل بن سليمان: أعطى <q>﴿ذوي القربى واليتامى والمساكين وابن السبيل﴾</q>، يعني: والضيف نازل عليك{21}٦١٨. (ز) ٦١٨ قال ابنُ كثير (٢/١٥٩): «<q>﴿وابن السبيل﴾</q>: هو المسافر المجتازُ الذي قد فرغت نفقته، فيُعْطى ما يُوصِله إلى بلده، وكذا الذي يريد سفرًا في طاعة فيُعْطى ما يكفيه في ذهابه وإيابه، ويدخل في ذلك الضيف». <q>﴿وَٱلسَّاۤىِٕلِینَ﴾</q> - تفسير ٥٠٣٢- عن قيس بن كُرْكُم، قال: سألتُ ابن عَبّاس عن السائل. قال: الذي يسأل{46}. (ز) ٥٠٣٣- عن عكرمة مولى ابن عباس -من طريق حصين- في قوله: <q>﴿والسائلين﴾</q>، قال: السائل الذي يسألك{52}. (٢/١٤٧) <q>﴿وَٱلسَّاۤىِٕلِینَ﴾</q> - آثار متعلقة بالآية ٥٠٣٤- عن الحسين بن علي، قال: قال رسول الله ﷺ: «للسائل حَقٌّ، وإن جاء على فرس»{53}. (٢/١٤٧) ٥٠٣٥- عن عبد الرحمن بن بُجَيْد، عن جدته أم بُجَيْد -وكانت مِمَّن بايع رسول الله ﷺ- أنّها قالت: يا رسول الله، إنّ المسكين لَيَقُومُ على بابي، فما أجد شيئًا أعطيه إيّاه. فقال لها: «إن لم تجدي إلا ظِلْفًا مُحْرَقًا فادْفَعِيه إليه»{54}. (٢/١٤٨) <q>﴿وَفِی ٱلرِّقَابِ﴾</q> - تفسير ٥٠٣٦- عن سعيد بن جبير -من طريق عطاء بن دينار- <q>﴿وفي الرقاب﴾</q>، يعني: فِكاك الرِّقاب{46}. (٢/١٤٩) ٥٠٣٧- عن مقاتل بن حَيّان -من طريق بُكَيْر بن مَعْروف- في قول الله: <q>﴿وفي الرقاب﴾</q>، قال: هم المُكاتَبون{46}. (ز) ٥٠٣٨- عن الحسن البصري= (ز) ٥٠٣٩- ومحمد ابن شهاب الزهري، نحو ذلك{57}. (ز) ٥٠٤٠- قال مقاتل بن سليمان: <q>﴿و﴾</q> أعطى <q>﴿السائلين وفي الرقاب﴾</q>، فهذا تَطَوُّعٌ{21}. (ز) <q>﴿وَأَقَامَ ٱلصَّلَوٰةَ وَءَاتَى ٱلزَّكَوٰةَ﴾</q> - تفسير ٥٠٤١- عن سعيد بن جبير -من طريق عطاء بن دينار- في قوله: <q>﴿وأقام الصلاة﴾</q> يعني: وأَتَمَّ الصلاةَ المكتوبة، <q>﴿وآتى الزكاة﴾</q> يعني: الزّكاة المفروضة{46}. (٢/١٤٩) ٥٠٤٢- عن مقاتل بن حَيّان -من طريق بُكَيْر بن معروف-، نحو ذلك{46}. (ز) ٥٠٤٣- قال مقاتل بن سليمان: ثم قال سبحانه: <q>﴿وأقام الصلاة﴾</q> المكتوبة، <q>﴿وآتى﴾</q>: وأعطى <q>﴿الزكاة﴾</q> المفروضة{21}. (ز) <q>﴿وَأَقَامَ ٱلصَّلَوٰةَ وَءَاتَى ٱلزَّكَوٰةَ﴾</q> - آثار متعلقة بالآية ٥٠٤٤- عن ربيعة بن كُلْثُوم، قال: حدّثني أبي، قال لي مُسْلِم بن يَسار: إنّ الصلاة صلاتان، وإن الزَّكاة زكاتان، واللهِ، إنّه لفي كتاب الله، أقرأ عليك به قرآنًا؟ قلت له: اقرأ. قال: فإنّ الله يقول في كتابه: <q>﴿ليس البر أن تولوا وجوهكم﴾</q> إلى قوله: <q>﴿وآتى المال على حبه ذوي القربى واليتامى المساكين وابن السبيل﴾</q> فهذا وما دونه تَطَوُّعٌ كلّه، <q>﴿وأقام الصلاة﴾</q> على الفريضة، <q>﴿وآتى الزكاة﴾</q>، فهاتان فريضتان{62}. (٢/١٥٠) <q>﴿وَٱلۡمُوفُونَ بِعَهۡدِهِمۡ إِذَا عَـٰهَدُوا۟ۖ﴾</q> - تفسير ٥٠٤٥- عن أبي العالية -من طريق الربيع بن أنس- في قوله: <q>﴿والموفون بعهدهم إذا عاهدوا﴾</q>، قال: فمَن أعطى عَهْد الله ثم نقضه فالله ينتقم منه، ومَن أعطى ذِمَّة النبي ﷺ ثُمَّ غدر بها فالنبيُّ ﷺ خَصْمُه يوم القيامة{63}. (٢/١٥١) ٥٠٤٦- عن سعيد بن جبير -من طريق عطاء بن دينار- في قوله: <q>﴿والموفون بعهدهم إذا عاهدوا﴾</q>، يعني: فيما بينهم وبين الناس{64}. (٢/١٥١) ٥٠٤٧- عن الربيع بن أنس -من طريق أبي جعفر- في قوله: <q>﴿والموفون بعهدهم إذا عاهدوا﴾</q>، قال: فمَن أعطى عَهْدَ الله ثُمَّ نقضه فالله ينتقم منه، ومَن أعطى ذِمَّة النبي ﷺ ثُمَّ غَدر بها فالنبيُّ ﷺ خصمُه يوم القيامة{65}. (ز) ٥٠٤٨- قال ⟨مقاتل بن سليمان:⟩{تت} <q>﴿والموفون بعهدهم إذا عاهدوا﴾</q> فيما بينهم وبين الناس{21}. (ز) <q>﴿وَٱلصَّـٰبِرِینَ فِی ٱلۡبَأۡسَاۤءِ وَٱلضَّرَّاۤءِ﴾</q> - تفسير ٥٠٤٩- عن عبد الله بن مسعود -من طريق السُّدِّيِّ، عن مُرَّة الهمداني- في الآية، قال: البَأْساء: الفقر. والضَّرّاء: السُّقْمُ{67}. (٢/١٥١) ٥٠٥٠- عن أبي العالية -من طريق الربيع بن أنس-= (ز) ٥٠٥١- والربيع بن أنس -من طريق أبي جعفر-= (ز) ٥٠٥٢- ومقاتل بن حيان -من طريق بُكَيْر بن معروف-، نحو ذلك{64}. (ز) ٥٠٥٣- وعن مُرَّة الهمداني= (ز) ٥٠٥٤- ومجاهد بن جبر= (ز) ٥٠٥٥- والحسن البصري، نحو ذلك{69}. (ز) ٥٠٥٦- عن سعيد بن جبير، نحو قوله في <q>﴿البأساء﴾</q>{69}. (ز) ٥٠٥٧- عن إسماعيل السدي -من طريق أسباط-، نحو قوله في <q>﴿البأساء﴾</q>{64}. (ز) ٥٠٥٨- عن أبي مالك، نحو قوله في <q>﴿الضراء﴾</q>{69}. (ز) ٥٠٥٩- عن ابن عباس: أنّ نافع بن الأزرق سأله عن: <q>﴿البأساء والضراء﴾</q>. قال: البأساء: الخِصْب. والضَّرّاءُ: الجَدْب. قال: وهل تعرفُ العربُ ذلك؟ قال: نعم، أما سمعتَ قولَ زيد بن عمرو: إنّ الإله عزيز واسع حَكَمُ بكفه الضُّر والبأساء والنِّعَم{73}. (٢/١٥١) ٥٠٦٠- عن سعيد بن جبير -من طريق عطاء بن دينار- في قول الله: <q>﴿والضراء﴾</q>، يعني: حين البلاء والشدة{74}. (ز) ٥٠٦١- عن الضحاك بن مُزاحِم -من طريق عبيد- في قوله: <q>﴿والصابرين في البأساء والضراء﴾</q>، قال: البأساء: الفقر. والضَّرّاء: المرض{75}. (ز) ٥٠٦٢- عن الحسن البصري -من طريق عَبّاد بن منصور- <q>﴿البأساء﴾</q> قال: البلاء، <q>﴿والضراء﴾</q>: هذه الأمراض والجوع، ونحو ذلك{76}. (ز) ٥٠٦٣- عن قتادة بن دِعامة -من طريق سعيد- قال: كنا نُحَدَّث أنّ البأساء: البؤس والفقر، وأنّ الضراء: السُّقم. وقد قال نبيُّ الله أيوبُ ﷺ: <q>﴿أنِّي مَسَّنِيَ الضُّرُّ وأَنْتَ أرْحَمُ الرّاحِمِينَ﴾</q> [الأنبياء:٨٣]{77}. (٢/١٥١) ٥٠٦٤- عن قتادة بن دِعامة -من طريق مَعْمَر- في قوله: <q>﴿والصابرين في البأساء والضراء﴾</q>، قال: البأساء: البُؤْس. والضراء: الزَّمانَةُ في الجسد{78}. (ز) ٥٠٦٥- عن الربيع بن أنس -من طريق أبي جعفر- في قوله: <q>﴿والصابرين في البأساء والضراء﴾</q>، قال: البُؤْس: الفاقة والفقر. والضراء في النَّفْس؛ من وجعٍ، أو مَرَضٍ يُصيبُه في جَسَدِه{79}. (ز) ٥٠٦٦- قال مقاتل بن سليمان: <q>﴿والصابرين في البأساء﴾</q> يعني: الفقر، <q>﴿والضراء﴾</q> يعني: البلاء{21}. (ز) ٥٠٦٧- قال سفيان الثوري: <q>﴿البأساء﴾</q>: الفقر، <q>﴿والضراء﴾</q>: المَضَرَّة{81}. (ز) <q>﴿وَحِینَ ٱلۡبَأۡسِۗ﴾</q> - تفسير ٥٠٦٨- عن عبد الله بن مسعود -من طريق السُّدِّيّ، عن مُرَّة الهَمْدانِيِّ- في قوله تعالى: <q>﴿وحين البأس﴾</q>، قال: حين القتال{82}. (٢/١٥١) ٥٠٦٩- وعن أبي العالية -من طريق الربيع بن أنس-، نحو ذلك{74}. (ز) ٥٠٧٠- وسعيد بن جُبَيْر= (ز) ٥٠٧١- ومُرَّة الهمداني= (ز) ٥٠٧٢- وأبي مالك= (ز) ٥٠٧٣- والحسن البصري، نحو ذلك{84}. (ز) ٥٠٧٤- عن مجاهد بن جبر -من طريق ابن أبي نَجِيح- <q>﴿وحين البأس﴾</q>، قال: حين القتال{85}. (ز) ٥٠٧٥- عن الضحاك بن مُزاحِم -من طريق عبيد- في قوله: <q>﴿وحين البأس﴾</q>، قال: القتال{86}. (ز) ٥٠٧٦- عن قتادة بن دِعامة -من طريق سعيد- قوله: <q>﴿وحين البأس﴾</q>، أي: عند مواطن القتال{87}. (٢/١٥١) ٥٠٧٧- عن الربيع بن أنس -من طريق أبي جعفر- <q>﴿وحين البأس﴾</q>: عند لقاء العدو{88}. (ز) ٥٠٧٨- قال مقاتل بن سليمان: <q>﴿وحين البأس﴾</q>، يعني: وعند القتال هم صابرون{21}. (ز) ٥٠٧٩- عن مُقاتِل بن حيان -من طريق بُكَيْر بن معروف- <q>﴿وحين البأس﴾</q>، قال: حين القتال{74}. (ز) ٥٠٨٠- عن سفيان الثوري، قال: <q>﴿وحين البأس﴾</q>: القتال{81}٦١٩. (ز) ٦١٩ ذَهَبَ ابنُ جرير (٣/٩١)، وابنُ عطية (١/٤٢١)، وابنُ كثير (٢/١٦١) إلى أنّ المراد بقوله: <q>﴿وحين البأس﴾</q>: وقت شدة القتال في الحرب. استنادًا إلى أقوال أهل التأويل، واستند ابن عطية أيضًا إلى اللغة. <q>﴿وَحِینَ ٱلۡبَأۡسِۗ﴾</q> - آثار متعلقة بالآية ٥٠٨١- عن علي -من طريق حارثة بن مُضَرِّب- أنّه قال: كُنّا إذا احْمَرَّ البأسُ، ولقي القوم؛ اتَّقَيْنا برسول الله ﷺ، فما يكون مِنّا أحدٌ أقرب إلى القوم منه{92}. (ز) ٥٠٨٢- عن البراء: كُنّا -والله- إذا احْمَرَّ البأسُ نَتَّقِي به، وإنّ الشجاع مِنّا لَلَّذي يُحاذي به. يعني: النبي ﷺ{93}. (ز) <q>﴿أُو۟لَـٰۤىِٕكَ ٱلَّذِینَ صَدَقُوا۟ۖ وَأُو۟لَـٰۤىِٕكَ هُمُ ٱلۡمُتَّقُونَ ۝١٧٧﴾</q> - تفسير ٥٠٨٣- عن أبي العالية -من طريق الربيع بن أنس- <q>﴿أولئك الذين صدقوا﴾</q>، يقول: تكلّموا بكلام الإيمان، وحَقَّقوا بالعمل{74}. (ز) ٥٠٨٤- عن سعيد بن جبير -من طريق عطاء بن دينار- في قوله: <q>﴿أولئك﴾</q>، يعني: الذين فعلوا ما ذكر الله في هذه الآية هم <q>﴿الذين صدقوا﴾</q>، يعني: المتقون{74}. (٢/١٥٢) ٥٠٨٥- عن الربيع بن أنس -من طريق أبي جعفر- في قوله: <q>﴿أولئك الذين صدقوا﴾</q>، قال: تكلّموا بكلام الإيمان، فكانت حقيقته العمل، صَدَقوا اللهَ.= (ز) ٥٠٨٦- قال: وكان الحسن يقول: هذا كلام الإيمان، وحقيقته العمل، فإن لم يكن مع القول عملٌ فلا شيء{96}. (٢/١٥٢) ٥٠٨٧- عن مقاتل بن حَيّان -من طريق بُكَيْر بن معروف-: <q>﴿أولئك الذين صدقوا﴾</q> إيمانهم، وصبروا على طاعة ربهم. وزاد في رواية: يعني: النبي ﷺ، وأصحابه{74}. (ز) ٥٠٨٨- قال مقاتل بن سليمان: <q>﴿أولئك الذين صدقوا﴾</q> في إيمانهم، <q>﴿وأولئك هم المتقون﴾</q>{21}٦٢٠. (ز) ٦٢٠ قال ابنُ جرير (٣/٩٢): «مَن فعل هذه الأشياء فهم الذين صَدَقوا الله في إيمانهم، وحَقَّقوا قولهم بأفعالهم، لا مَن ولّى وجهه قِبَل المشرق والمغرب وهو يخالف الله في أمره، وينقض عهده وميثاقه، ويكتم الناسَ بَيانَ ما أمره الله ببيانه، ويكذِّب رسله». وقال ابنُ عطية (٢/٤٢٢): «وصف تعالى أهلَ هذه الأفعال البَرَّة بالصدق في أمورهم، أي: هم عند الظن بهم والرجاء فيهم، كما تقول: صدقني المال، وصدقني الربح. ومنه: عود صِدْق. وتحتمل اللفظةُ أيضًا صدق الإخبار». <q>﴿أُو۟لَـٰۤىِٕكَ ٱلَّذِینَ صَدَقُوا۟ۖ وَأُو۟لَـٰۤىِٕكَ هُمُ ٱلۡمُتَّقُونَ ۝١٧٧﴾</q> - آثار متعلقة بالآية ٥٠٨٩- عن أبي مَيْسَرَة -من طريق أبي إسحاق- قال: مَن عَمِل بهذه الآية فقد استكمل الإيمان: <q>﴿ليس البر﴾</q> الآية{99}. (٢/١٣٩) ٥٠٩٠- عن إبراهيم بن أبي شيبان، قال: سألت زيد بن رُفَيع، فقلت: يا أبا جعفر، ما تقول في الخوارج في تكفيرهم الناس؟ قال: كذبوا، يقول الله ﷿: <q>﴿ليس البر أن تولوا وجوهكم﴾</q> الآية. فمَن آمن فهو مؤمن، ومَن كفر بِهِنَّ فهو كافر{100}. (٢/١٥٢) ",footnotes:1:تفسير الثعلبي ٢/٤٩. وعزاه السيوطي إلى أبي عبيد في فضائله. وهي قراءة شاذة. انظر: مختصر ابن خالويه ص١٨، والمحتسب ١/١١٧.أخرجه ابن أبي داود في المصاحف ص٥٧. وهي قراءة شاذة. انظر: البحر المحيط ٢/٤.أخرجه ابن جرير ٣/٧٥.أخرجه ابن جرير ٣/٧٦. وعلَّقه الواحدي في أسباب النزول (ت: الفحل) ص١٥٧. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه عبد الرزاق ١/٦٦، وابن جرير ٣/٧٥.أخرجه ابن جرير ٣/٧٥، وابن أبي حاتم ١/٢٨٧.تفسير الثعلبي ٢/٤٩.أخرجه ابن أبي حاتم ١/٢٨٧ (١٥٣٩)، والحاكم ٢/٢٩٩ (٣٠٧٧). قال الحاكم: «هذا حديث صحيح، على شرط الشيخين، ولم يُخَرِّجاه». وتعقّبه الذهبي في التلخيص بقوله: «كيف وهو منقطع؟!». قال ابن كثير في تفسيره ١/٤٨٥: «وهذا منقطع؛ فإن مجاهدًا لم يُدْرِك أبا ذر؛ فإنّه مات قديمًا».أخرجه إسحاق بن راهويه -كما في المطالب العالية لابن حجر ١٢/٤٢٨ (٢٩٤١)-، والمروزي في تعظيم قدر الصلاة ١/٤١٦ (٤٠٨). قال ابن كثير في تفسيره ١/٤٨٥: «وهذا أيضًا منقطع». وقال ابن حجر: «هذا منقطع».أخرجه عبد الرزاق في جامعه ١١/١٢٨ (٢٠١١٠) عن مَعْمَر، والمروزي في تعظيم قدر الصلاة ١/٤١٧ (٤٠٩). وهذا منقطع؛ فإن مجاهدًا لم يُدْرِك أبا ذر، كما في تفسير ابن كثير ١/٤٨٥، وقال ابن حجر في المطالب العالية ١٤/٤٧٤ (٣٥٣٣): «هذا مرسل، صحيح الإسناد، وله شاهد».أخرجه إسحاق -كما في المطالب (٣٩٠٠)-. وعزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ٣/٧٤، وابن أبي حاتم ١/٢٨٧.أخرجه ابن أبي حاتم ١/٢٨٧. وعزاه السيوطي إلى ابن جرير أيضًا، والذي عند ابن جرير موقوف على الربيع من قوله -كما تقدم- دون آخره.علقه ابن أبي حاتم ١/٢٨٧.أخرجه ابن جرير ٣/٧٤، وابن أبي حاتم ١/٢٨٧. وعزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ٣/٧٥.أخرجه ابن جرير ٣/٧٥. وعلّقه ابن أبي حاتم ١/٢٨٧.أخرجه بن أبي حاتم ١/٢٨٧.ذكره يحيي بن سلام -كما في تفسير ابن أبي زمنين ١/١٩٦-.أخرجه ابن أبي حاتم ١/٢٨٧.تفسير مقاتل بن سليمان ١/١٥٧.أخرجه ابن أبي حاتم ١/٢٨٨.تفسير مقاتل بن سليمان ١/١٥٧.أخرجه ابن أبي حاتم ١/٢٨٨، عن سفيان مهملًا. وقد أورده الثعلبي ٢/١٢٦، وابن كثير ١/٤٨٦ عن سفيان الثوري. ولم يذكر المزي في تهذيب الكمال ٢٦/٦٣٩ في ترجمة محمد بن يحيى بن أبي عمر العدني أن سفيان الثوري من شيوخه، وإنما ذكر سفيان بن عيينة الذي هو من أشهر شيوخه.أخرجه مسلم ١/٣٦-٣٧ (٨). وأورده الثعلبي ١/١٤٦.أخرجه البيهقي في الشعب ٥/١٣٥-١٣٦ (٣١٩٦) مرسلًا.أخرجه ابن المبارك في كتاب الزهد ص٢٤، ووكيع -كما في تفسير ابن كثير ١/٢٩٧-، وعبد الرزاق في تفسيره ١/٦٦، وفي المُصَنَّف ٩/٥٥ (١٦٣٢٤)، وسعيد بن منصور (٢٤٥- تفسير)، وابن أبي شيبة في المصنف ١٣/٢٩٧ (٣٥٦٩٥)، وابن جرير ٣/٧٨-٧٩، وابن أبي حاتم ١١/٢٨٨ (١٥٤٦)، والطبراني (٨٥٠٣)، والحاكم ٢/٢٧٢، والبيهقي ٤/١٩٠. وعزاه السيوطي إلى الفريابي، وعبد بن حميد.أخرجه الحاكم -كما في تفسير ابن كثير ١/٤٨٦-. قال ابن كثير -عَقِب قول الحاكم: «صحيح، على شرط الشيخين، ولم يُخَرِّجاه»-: «وقد رواه وكيع عن الأعمش، وسفيان عن زبيد، عن مُرَّة، عن ابن مسعود، موقوفًا، وهو أصح».أخرجه البخاري ٢/١١٠ (١٤١٩)، ٤/٤ (٢٧٤٨)، ومسلم ٢/٧١٦ (١٠٣٢).أخرجه ابن أبي حاتم ١/٢٨٨.أخرجه ابن أبي حاتم ١/٢٨٨.تفسير مقاتل بن سليمان ١/١٥٧.أخرجه الترمذي ٢/١٩٧-١٩٨ (٦٦٥، ٦٦٦)، وابن ماجه ٣/٩ (١٧٨٩) دون الآية، كما أخرجه ابن جرير ٣/٨١، وابن أبي حاتم ١/٢٨٨ (١٥٤٨). قال الترمذي: «هذا حديث إسناده ليس بذاك، وأبو حمزة ميمون الأعور يُضَعَّف، وروى بيان وإسماعيل عن الشعبي هذا الحديث قوله، وهذا أصح». وقال البيهقي في الكبرى ٤/١٤٢: «فهذا حديث يعرف بأبي حمزة ميمون الأعور كوفي، وقد جَرَّحه أحمد بن حنبل، ويحيى بن معين، فمَن بعدهما من حُفّاظ الحديث». وقال النووي في خلاصة الأحكام ٢/١٠٧٨ (٣٨٣٧): «حديث مُنكَر». وقال العيني في عمدة القاري ٨/٢٣٧: «وقال شيخنا زين الدين: ليس حديث فاطمة هذا بصحيح».أخرجه ابن جرير ٣/٧٩. وعزاه السيوطي إلى عبد بن حميد.علَّقه ابنُ جرير ٣/٧٩.أخرجه ابن أبي حاتم ١/٢٨٩.الكاشح: العدوُّ الذي يُضْمِر عداوتَه، ويطوي عليها كشحه، أي: بطنه، والكشح: الخصر، أو الذي يطوي عنك كشحه ولا يألفك. لسان العرب (كشح).أخرجه ابن خزيمة ٤/١٣١-١٣٢ (٢٣٨٦)، والحاكم ١/٥٦٤ (١٤٧٥). وأورده الثعلبي ٢/٥١. قال الحاكم: «هذا حديث صحيح، على شرط مسلم، ولم يُخَرِّجاه، وله شاهد بإسناد صحيح». ووافقه الذهبي، وأقرّه المنذري. وقال الزيلعي في نصب الراية ٤/٤٠٦: «قال ابن طاهر: سنده صحيح». وقال الهيثمي في المجمع ٣/١١٦ (٤٦٥٠): «رواه الطبراني في الكبير، ورجاله رجال الصحيح». وقال البوصيري في إتحاف الخيرة ٣/٤٢ (٢١٣٩): «رواه الحميدي، وفي سنده راو لم يُسَمَّ،... ورواه الطبراني في الكبير بسند الصحيح». وقال الألباني في الإرواء ٣/٤٠٤ (٨٩٢): «صحيح».أخرجه أحمد ٢٦/١٦٦-١٦٧ (١٦٢٢٧)، ٢٦/١٦٩-١٧٢ (١٦٢٣٢، ١٦٢٣٣، ١٦٢٣٥)، ٢٩/٤١١-٤١٦ (١٧٨٧٢، ١٧٨٧٧، ١٧٨٨٣، ١٧٨٨٤) واللفظ له، والترمذي ٢/١٩٥-١٩٦ (٦٦٤)، والنسائي ٥/٩٢ (٢٥٨٢)، وابن ماجه ٣/٥١ (١٨٤٤)، وابن خزيمة ٣/٤٨١-٤٨٢ (٢٠٦٧)، ٤/١٣٠-١٣١ (٢٣٨٥)، وابن حبان ٨/١٣٢-١٣٣ (٣٣٤٤)، والحاكم ١/٥٦٤ (١٤٧٦). قال الترمذي: «حديث حسن». وصحّح إسناده ابن كثير في تفسيره ٨/٤٠٨. وقال ابن الملقن في البدر ٧/٤١١: «هذا الحديث صحيح». وقال الألباني في الإرواء ٣/٣٨٧ (٨٨٣): «حسن».أخرجه البخاري ٢/١٢١ (١٤٦٦)، ومسلم ٢/٦٩٤ (١٠٠٠).⟨تقدم تفسير اليتامى والمساكين في الآية (٨٣).⟩{ع}أخرجه ابن أبي حاتم ١/٢٨٩.علَّقه ابن أبي حاتم ١/٢٨٩.أخرجه عبد الرزاق ١/١٥٩، وابن جرير ٣/٨٣، وابن أبي حاتم ١/٢٩٠.عَلَّقه ابن أبي حاتم ١/٢٩٠.أخرجه ابن أبي حاتم ١/٢٩٠.أخرجه ابن جرير ٣/٨٣. وعلَّقه ابن أبي حاتم ١/٢٩٠.أخرجه عبد الرزاق ١/١٥٩، وابن جرير ٣/٨٣، وابن أبي حاتم ١/٢٩٠.أخرجه ابن جرير ٣/٨٢-٨٣. وعلَّقه ابن أبي حاتم ١/٢٨٩. وأورده الثعلبي ٢/٥١. قال أحمد شاكر في تحقيقه لتفسير الطبري ٣/٣٤٥: «هو حديث مرسل...، وثبت معناه ضمن حديث رواه مسلم...، ورواه أيضًا أحمد وسائر أصحاب الكتب الستة».تفسير مقاتل بن سليمان ١/١٥٧.أخرجه ابن أبي حاتم ١/٢٩٠.أخرجه ابن جرير ٣/٨٤.أخرجه أحمد ٣/٢٥٤ (١٧٣٠)، وأبو داود ٣/٩٨ (١٦٦٥)، وابن خزيمة ٤/١٨٣-١٨٤ (٢٤٦٨)، وابن أبي حاتم ١/٢٩٠ (١٥٥٦). قال المناوي في فيض القدير ٥/٢٩٠ (٧٣٤٢): «قال العراقي: وقولُ ابن الصلاح عن أحمد: أربعة أحاديث تدور في الأسواق لا أصل لها. منها هذا، لا يصح عن أحمد». وقال السخاوي في المقاصد الحسنة ص٥٣٧ (٨٧٣): «وسنده جيد، كما قال العراقيُّ وغيره». وقال الزرقاني في شرح الموطأ ٤/٦٦٨: «ولكن قال ابن عبد البرّ: سنده ليس بالقوي». وقال الرباعي في فتح الغفار ٢/٨٢٦ (٢٥٦٥): «رواه أحمد، وأبو داود، بإسناد ضعيف». وقال المباركفوري في تحفة الأحوذي ٣/٢٦٩: «وإسناده حسن، إلا أنه مرسل». وقال الألباني في الضعيفة ٣/٥٥٨ (١٣٧٨): «ضعيف».أخرجه أحمد ٤٥/١٢٨ (٢٧١٥٠)، وأبو داود ٣/١٠٠ (١٦٦٧)، والترمذي ٢/٢٠٣ (٦٧١)، والنسائي ٥/٨٦ (٢٥٧٤)، وابن خزيمة ٤/١٨٧ (٢٤٧٣)، وابن حبّان ٨/١٦٦-١٦٧ (٣٣٧٣)، والحاكم ١/٥٧٨ (١٥٢٤). قال الترمذي: «حديث أم بُجَيْد حديث حسن صحيح». وقال الحاكم ١/٥٧٨: «صحيح الإسناد، ولم يُخَرِّجاه». وقال الألباني في صحيح أبي داود ٥/٣٦٠-٣٦١ (١٤٦٧): «إسناده صحيح».أخرجه ابن أبي حاتم ١/٢٩٠.أخرجه ابن أبي حاتم ١/٢٩٠.علَّقه ابن أبي حاتم ١/٢٩٠.تفسير مقاتل بن سليمان ١/١٥٧.أخرجه ابن أبي حاتم ١/٢٩٠.أخرجه ابن أبي حاتم ١/٢٩٠.تفسير مقاتل بن سليمان ١/١٥٧.عزاه السيوطي إلى عبد بن حميد.أخرجه ابن أبي حاتم ١/٢٩١، وعزاه السيوطي إلى ابن جرير، وهو عنده ٣/٨٥ من قول الربيع -كما سيأتي-.أخرجه ابن أبي حاتم ١/٢٩١.أخرجه ابن جرير ٣/٨٥. وعلَّقه ابن أبي حاتم ١/٢٩١.تفسير مقاتل بن سليمان ١/١٥٧.أخرجه ابن جرير ٣/٨٦، وابن أبي حاتم ١/٢٩١، والحاكم ٢/٢٧٣. وعزاه السيوطي إلى وكيع، وابن أبي شيبة، وعبد بن حميد، وابن المنذر، وأبي الشيخ. وفي رواية أخرى عنه عند ابن جرير: قال: البأساء: الجوع. وفي رواية أيضًا له: البأساء: الحاجة.أخرجه ابن أبي حاتم ١/٢٩١.علَّقه ابن أبي حاتم ١/٢٩١.علَّقه ابن أبي حاتم ١/٢٩١.أخرجه ابن أبي حاتم ١/٢٩١.علَّقه ابن أبي حاتم ١/٢٩١.أخرجه الطستي -كما في الإتقان ٢/٧٩-٨٠-.أخرجه ابن أبي حاتم ١/٢٩٢.أخرجه ابن أبي الدنيا في كتاب الصبر -موسوعة الإمام ابن أبي الدنيا ٤/٣٢-، وابن جرير ٣/٨٧. وعلَّقه ابن أبي حاتم ١/٢٩١.أخرجه ابن أبي حاتم ١/٢٩١-٢٩٢.أخرجه ابن جرير ٣/٨٧. وذكره يحيي بن سلام -كما في تفسير ابن أبي زمنين ١/١٩٧- مختصرًا. وعلّق شطره الأول ابن أبي حاتم ١/٢٩١. وعزاه السيوطي إلى عبد بن حميد مختصرًا.أخرجه ابن جرير ٣/٨٧، وابن أبي حاتم في شطره الثاني ١/٢٩١ كلاهما من طريق عبد الرزاق. وفي المطبوع من تفسير عبد الرزاق ١/٦٦ موقوفًا على معمر من قوله، ويبدو أنّ اسم قتادة سقط منه، والله أعلم.أخرجه ابن جرير ٣/٨٧، وابن أبي حاتم ١/٢٩١.تفسير مقاتل بن سليمان ١/١٥٧.تفسير سفيان الثوري ١/٥٥.أخرجه ابن جرير ٣/٩١، وابن أبي حاتم ١/٢٩٢، والحاكم ٢/٢٧٣. وعزاه السيوطي إلى وكيع، وابن أبي شيبة، وعبد بن حميد، وابن المنذر، وأبي الشيخ.أخرجه ابن أبي حاتم ١/٢٩٢.علَّقه ابن أبي حاتم ١/٢٩٢.أخرجه ابن جرير ٣/٩١. وعلَّقه ابن أبي حاتم ١/٢٩٢.أخرجه ابن أبي الدنيا في كتاب الصبر -موسوعة الإمام ابن أبي الدنيا ٤/٣٢-، وابن جرير ٣/٩٢.أخرجه ابن جرير ٣/٩١. وعلَّقه ابن أبي حاتم ١/٢٩١. كما أخرج نحوه ابن جرير ٣/٩٢ من طريق عبد الرزاق عن مَعمر، وهو في المطبوع من تفسير عبد الرزاق ١/٦٦ موقوفًا على معمر من قوله. وعزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ٣/٩٢، وابن أبي حاتم ١/٢٩٢.تفسير مقاتل بن سليمان ١/١٥٧.أخرجه ابن أبي حاتم ١/٢٩٢.تفسير سفيان الثوري ١/٥٥.أخرجه أحمد ٢/٤٥٣، والنسائي في الكبرى ٨/٣٤، وأبو يعلى ١/٣٥٨. وقال محققو هذه الكتب: «إسناده صحيح». ويشهد له حديث البراء بن عازب التالي.أخرجه مسلم ٣/١٤٠١، وأحمد ٣٠/٤٤١.أخرجه ابن أبي حاتم ١/٢٩٢.أخرجه ابن أبي حاتم ١/٢٩٢.أخرجه ابن جرير ٣/٩٣، وابن أبي حاتم ١/٢٩٢.أخرجه ابن أبي حاتم ١/٢٩٢.تفسير مقاتل بن سليمان ١/١٥٧.عزاه السيوطي إلى وكيع، وابن المنذر. وأخرجه ابن أبي شيبة (ت: محمد عوامة) ١٩/٢٨٤ (٣٦٠٥٣) بلفظ: فقد استكمل البِرّ.أخرجه ابن عساكر ٧/٢٤.
2,178," <q>﴿یَـٰۤأَیُّهَا ٱلَّذِینَ ءَامَنُوا۟ كُتِبَ عَلَیۡكُمُ ٱلۡقِصَاصُ فِی ٱلۡقَتۡلَىۖ﴾</q> - نزول الآية ٥٠٩١- عن سعيد بن جبير -من طريق عطاء بن دينار- قال: إنَّ حَيَّيْنِ من العرب اقتتلوا في الجاهلية قبل الإسلام بقليل، فكان بينهم قتل وجراحات، حتى قتلوا العبيد والنساء، فلم يأخذ بعضهم من بعض حتى أسلموا، فكان أحد الحيَّيْنِ يتطاول على الآخر في العُدَّة والأموال، فحلفوا أن لا يرضوا حتى يُقْتَل بالعبد منّا الحُرُّ منهم، وبالمرأة مِنّا الرجلُ منهم؛ فنزل فيهم: <q>﴿يا أيها الذين آمنوا كتب عليكم القصاص في القتلى الحر بالحر والعبد بالعبد والأنثى بالأنثى﴾</q>. وذلك أنهم كانوا لا يقتلون الرجل بالمرأة، ولكن يقتلون الرجل بالرجل، والمرأة بالمرأة؛ فأنزل الله: <q>﴿النفس بالنفس﴾</q> [المائدة:٤٥]، فجعل الأحرار في القصاص سواء فيما بينهم من العمد؛ رجالهم ونساؤهم، في النفس وما دون النفس، وجعل العبيد مستويين في العمد؛ النفس وما دون النفس، رجالهم ونساؤهم{1}. (٢/١٥٣) ٥٠٩٢- عن عامر الشعبي -من طريق داود بن أبي هند- قال: نزلت هذه الآية في قبيلتين من قبائل العرب اقتتلتا قتال عِمِّيَّة{2} على عهد الرسول ﷺ، فقالوا: نقتُل بعبدنا فلانَ بن فلان، ونقتُل بأمَتِنا فلانةَ بنت فلان. فأنزل الله: <q>﴿الحر بالحر والعبد بالعبد والأنثى بالأنثى﴾</q>{3}. (٢/١٥٤) ٥٠٩٣- عن أبي الجوزاء= (ز) ٥٠٩٤- والكلبي= (ز) ٥٠٩٥- ومقاتل بن حيان، نحوه{4}. (ز) ٥٠٩٦- عن أبي مالك -من طريق السدي- قال: كان بين حَيَّيْن من الأنصار قتال، كان لأحدهما على الآخر الطَّوْل، فكأنهم طلبوا الفَضْل، فجاء النبي ﷺ ليصلح بينهم؛ فنزلت الآية: <q>﴿الحر بالحر والعبد بالعبد والأنثى بالأنثى﴾</q>{5}. (٢/١٥٤) ٥٠٩٧- قال الحسن البصري: كان أهل الجاهلية فيهم بَغْيٌ، قد كان إذا قُتِل من الحي منهم مملوكٌ قَتَلَه حيٌّ آخرون، قالوا: لا نَقْتُل به إلا حُرًّا. وإذا قُتِل من الحيِّ منهم امرأةٌ قتَلها حيٌّ آخرون، قالوا: لا نقتل بها إلا رجلًا. فأنزل الله ﷿ هذه الآية، ونهاهم عن البغي{6}. (ز) ٥٠٩٨- عن قتادة بن دِعامة -من طريق مَعْمَر- قال: لم يكن لِمَن كان قبلنا دِيَةٌ، إنما هو القتل أو العفو؛ فنزلت هذه الآية في قوم أكثر من غيرهم، فكانوا إذا قُتِل من الكثير عبدٌ قالوا: لا نَقْتُلُ به إلا حُرًّا. وإذا قُتِلَت منهم امرأةٌ قالوا: لا نَقْتُلُ بها إلا رجلًا. فأنزل الله: <q>﴿الحر بالحر والعبد بالعبد والأنثى بالأنثى﴾</q>{7}. (٢/١٥٤) ٥٠٩٩- قال مقاتل بن سليمان: <q>﴿يا أيها الذين آمنوا كتب عليكم القصاص في القتلى﴾</q>، وذلك أنّ حيَّيْن من العرب اقتتلوا في الجاهلية قبل الإسلام بقليل، وكانت بينهم قتلى وجرحى، حتى قُتِل العبيد والنساء، فلم يأخذ بعضهم من بعضٍ الأموالَ حتى أسلموا، وكان أحد الحيَّيْن له طَوْلٌ على الآخر في العدد والأموال، فحلفوا: ألّا نرضى حتى يُقتل بالعبد منا الحرُّ منهم، وبالمرأة منّا الرجلُ منهم. فأنزل الله ﷿: <q>﴿الحر بالحر والعبد بالعبد والأنثى بالأنثى﴾</q>. فسوّى بينهم في الدماء، وأمرهم بالعدل، فَرَضُوا، فصارت منسوخة، نسختها الآية التي في المائدة [آية:٤٥]{8}. (ز) <q>﴿یَـٰۤأَیُّهَا ٱلَّذِینَ ءَامَنُوا۟ كُتِبَ عَلَیۡكُمُ ٱلۡقِصَاصُ فِی ٱلۡقَتۡلَىۖ﴾</q> - تفسير ٥١٠٠- عن سعيد بن جُبَيْر -من طريق عطاء بن دينار- في قول الله: <q>﴿يا أيها الذين امنوا كتب عليكم القصاص في القتلى﴾</q>، يعني: إذا كان عَمْدًا{1}. (ز) ٥١٠١- عن الحسن البصري، نحو ذلك{10}. (ز) ٥١٠٢- قال مقاتل بن سليمان: <q>﴿يا أيها الذين آمنوا كتب عليكم القصاص في القتلى﴾</q> إذا كان عَمْدًا{8}. (ز) <q>﴿ٱلۡحُرُّ بِٱلۡحُرِّ وَٱلۡعَبۡدُ بِٱلۡعَبۡدِ وَٱلۡأُنثَىٰ بِٱلۡأُنثَىٰۚ﴾</q> - تفسير ٥١٠٣- عن علي بن أبي طالب -من طريق الربيع- في قوله: <q>﴿يا أيها الذين آمنوا كتب عليكم القصاص في القتلى الحر بالحر والعبدُ بالعبد والأنثى بالأنثى﴾</q>، قال: أيُّما حُرٍّ قَتَل عبدًا فهو قَوَدٌ به؛ فإن شاء مَوالي العبدِ أن يقتلوا الحُرَّ قتلوه، وقاصُّوهم بثمن العبد من دِيَة الحُرِّ، وأدَّوا إلى أولياء الحُرِّ بَقِيَّة دِيَتِه. وأيُّ عبد قَتَلَ حرًّا فهو به قَوَدٌ؛ فإن شاء أولياء الحُرِّ قتلوا العبد، وقاصُّوهم بثمن العبد، وأخذوا بقية دِيَة الحُرِّ، وإن شاؤوا أخذوا الديّة كلّها واستحيَوُا العبد. وأيُّ حُرٍّ قَتَل امرأةً فهو بها قَوَدٌ، فإن شاء أولياء المرأة قَتلوه وأدّوا نصفَ الدية إلى أولياء الحرّ. وإن امرأةٌ قتلتْ حُرًّا فهي به قَوَدٌ، فإن شاء أولياء الحر قتلوها وأخذوا نصف الدية، وإن شاؤوا أخذوا الدية كلها واسْتَحْيَوْها، وإن شاؤوا عفَوْا{12}. (ز) ٥١٠٤- عن عليّ -من طريق الحسن- قال في رجل قَتَلَ امرأتَه: إن شاؤوا قتلوه، وغَرِموا نصف الدِّيَة{13}. (ز) ٥١٠٥- عن مجاهد بن جبر -من طريق ابن أبي نجيح- قال: دخل في قول الله -تعالى ذِكْرُه-: <q>﴿الحر بالحر﴾</q> الرجلُ بالمرأة، والمرأةُ بالرجل.= (ز) ٥١٠٦- وقال عطاء: ليس بينهما فَضْل{7}٦٢١. (ز) ٦٢١ رجَّحَ ابنُ جرير (٣/٩٤، ١٠٠-١٠١ بتصرف) أنّ نفس الرجل الحر قَوَد قصاصًا بنفس المرأة الحرة، وأنّ معنى الآية: أن لا يتعدى بالقصاص إلى غير القاتل والجاني، فيؤخذ بالأنثى الذكر، وبالعبد الحر. استنادًا إلى دلالة القرآن، والسُّنَّة، والقياس، فقال: «فإن قال قائل: فإنه -تعالى ذِكْرُه- قال: <q>﴿كُتب عليكم القصاص في القتلى الحر بالحرّ والعبدُ بالعبد والأنثى بالأنثى﴾</q>، فما لنا أن نقتص للحر إلا من الحر، ولا للأنثى إلا من الأنثى؟ قيل: بل لنا أن نقتص للحر من العبد، وللأنثى من الذَّكَر بقول الله -تعالى ذِكْرُه-: <q>﴿ومَن قُتِلَ مَظْلُومًا فَقَدْ جَعَلْنا لِوَلِيِّهِ سُلْطانًا﴾</q> [الإسراء:٣٣]، وبالنقل المستفيض عن رسول الله ﷺ أنه قال: «المسلمون تَتَكافأ دماؤهم»». وقال: «قد تظاهرت الأخبار عن رسول الله ﷺ بالنقل العام أنّ نفس الرجل الحر قَوَدٌ قصاصًا بنفس المرأة الحرة، فإذ كان ذلك كذلك، وكانت الأمَّة مختلفة في التراجع بفضل ما بين دية الرجل والمرأة على ما قد بينّا من قول عليٍّ وغيره، وكان واضحًا فساد قول مَن قال بالقصاص في ذلك والتراجع بفضل ما بين الديتين بإجماع جميع أهل الإسلام على أنّ حرامًا على الرجل أن يتلف من جسده عضوًا بعوض يأخذه على إتلافه -فدع ما جميعه-، وعلى أنّ حرامًا على غيره إتلاف شيء منه مثل الذي حرم من ذلك بِعِوَضٍ يعطيه عليه؛ فالواجب أن تكون نَفْسُ الرجل الحر بنَفْسِ المرأة الحرة قَوَدًا. وإذا كان ذلك كذلك كان بيِّنًا بذلك أنّه لم يُرِد بقوله -تعالى ذِكْرُه-: <q>﴿الحر بالحر والعبد بالعبد والأنثى بالأنثى﴾</q> أن لا يقاد العبد بالحر، وأن لا تقتل الأنثى بالذكر، ولا الذكر بالأنثى. وإذا كان ذلك كذلك كان بَيِّنًا أنّ الآية مَعْنِيٌّ بها أحدُ المعنيين الآخرين: إما قولنا من أن لا يتعدى بالقصاص إلى غير القاتل والجاني، فيؤخذ بالأنثى الذكر، وبالعبد الحر. وإما القول الآخر وهو أن تكون الآية نزلت في قوم بأعيانهم خاصةً، أمر النبي ﷺ أن يجعل ديات قتلاهم قصاصًا بعضها من بعض، كما قاله السدي ومَن ذكرنا قوله. وقد أجمع الجميع لا خلاف بينهم على أن المقاصّة في الحقوق غير واجبة، وأجمعوا على أنّ الله لم يقض في ذلك قضاء ثم نسخه، وإذا كان كذلك، وكان قوله -تعالى ذِكْرُه-: <q>﴿كتب عليكم القصاص﴾</q> يُنبِئُ على أنه فرض؛ كان معلومًا أن القول خلاف ما قاله قائل هذه المقالة؛ لأن ما كان فرضًا على أهل الحقوق أن يفعلوه فلا خيار لهم فيه، والجميع مجمعون على أن لأهل الحقوق الخيار في مقاصّتهم حقوقهم بعضها من بعض، فإذا تبين فساد هذا الوجه الذي ذكرنا؛ فالصحيح من القول في ذلك هو ما قلنا». ٥١٠٧- عن عامر الشعبي -من طريق داود- في هذه الآية: <q>﴿كتب عليكم القصاص في القتلى الحر بالحرّ والعبد بالعبد والأنثى بالأنثى﴾</q>، قال: إنما ذلك في قتال عِمِّيَّة، إذا أصيب من هؤلاء عبدٌ ومن هؤلاء عبدٌ تكافآ، وفي المرأتين كذلك، وفي الحُرَّيْن كذلك. هذا معناه إن شاء الله{7}. (ز) ٥١٠٨- عن عامر الشعبي-من طريق ابن أشْوَع- قال: كان بين حَيَّيْنِ من العرب قتال، فقُتل من هؤلاء ومن هؤلاء، فقال أحد الحَيَّيْن: لا نرضى حتى نَقْتُل بالمرأة الرجل، وبالرجل الرجلين. قال: فأبى عليهم الآخرون، فارتفعوا إلى النبي ﷺ، قال: فقال النبي ﷺ: «القتل بَواءٌ». أي: سواء، قال: فاصطلح القوم بينهم على الدِّيات. قال: فحسبوا للرجل دية الرجل، وللمرأة دية المرأة، وللعبد دية العبد، فقضى لأحد الحيين على الآخر. قال: فهو قوله: <q>﴿يا أيها الذين آمنوا كتب عليكم القصاص في القتلى الحر بالحر، والعبد بالعبد، والأنثى بالأنثى﴾</q>{16}. (ز) ٥١٠٩- عن الحسن البصري -من طريق عوف- قال: لا يُقتل الرجل بالمرأة، حتى يُعطوا نِصْفَ الدِّيَة{12}. (ز) ٥١١٠- عن ابن جُرَيْج، قال: قلتُ لعطاء: ما قول الله ﷿: <q>﴿الحر بالحر والعبد بالعبد﴾</q>؟ قال: العبدُ يقتل العبدَ عَمْدًا فهو به، فإن كان القاتلُ أفضلَ لم يكن لهم إلا قيمةُ المقتول{18}. (ز) ٥١١١- عن إسماعيل السدي -من طريق أسباط- في قوله: <q>﴿كتب عليكم القصاص في القتلى الحر بالحر والعبدُ بالعبد والأنثى بالأنثى﴾</q>، قال: اقْتَتَل أهلُ ماءَيْن من العرب، أحدهما مسلم والآخر مُعاهَد، في بعض ما يكون بين العرب من الأمر، فأصلح بينهم النبيُّ ﷺ -وقد كانوا قَتَلوا الأحرار والعبيد والنساء- على أن يؤدِّي الحرُّ دِيةَ الحُرِّ، والعبدُ ديةَ العبد، والأنثى دية الأنثى، فقاصَّهم بعضَهم من بعض{19}. (ز) ٥١١٢- قال شعبة: قلتُ لأبي بِشْر [جعفر بن إياس]: كيف كان ذلك؟ يعني: قول الله: <q>﴿كتب عليكم القصاص في القتلى الحر بالحر والعبد بالعبد والأنثى بالأنثى﴾</q>. فقال: كان يُقْتَل الرجل -يعني: بالرجل-، ويُتْرَك العبد بالعبد{20}. (ز) <q>﴿ٱلۡحُرُّ بِٱلۡحُرِّ وَٱلۡعَبۡدُ بِٱلۡعَبۡدِ وَٱلۡأُنثَىٰ بِٱلۡأُنثَىٰۚ﴾</q> - النسخ في الآية ٥١١٣- عن عبد الله بن عباس -من طريق جُوَيْبِر، عن الضحاك-: <q>﴿الحر بالحر والعبد بالعبد والأنثى بالأنثى﴾</q>، قال: نسختها <q>﴿وكتبنا عليهم فيها أن النفس بالنفس﴾</q> [المائدة:٤٥] الآية{21}. (٢/١٥٥) ٥١١٤- قال ابن عباس: نسختها <q>﴿النفس بالنفس﴾</q> [المائدة:٤٥]{22}. (٢/١٥٤) ٥١١٥- عن عبد الله بن عباس -من طريق علي بن أبي طلحة- قال: كانوا لا يقتلون الرجل بالمرأة، ولكن يقتلون الرجل بالرجل، والمرأة بالمرأة؛ فأنزل الله: <q>﴿النفس بالنفس﴾</q> [المائدة:٤٥]. فجعل الأحرار في القصاص سواء فيما بينهم في العمد؛ رجالهم ونساؤهم، في النفس وما دون النفس، وجعل العبيد مستوين في العمد؛ في النفس وما دون النفس، رجالهم ونساؤهم{23}. (٢/١٥٣) ٥١١٦- قال الحسن البصري: ... أنزل الله ﷿ هذه الآية، ونهاهم عن البغي، ثم أنزل الله بعد ذلك في المائدة: <q>﴿وكتبنا عليهم فيه أن النفس بالنفس﴾</q> [الآية:٤٥]، يعني: النفس التي قَتَلت بالنفس التي قُتِلت؛ وهذا في الأحرار{24}. (ز) ٥١١٧- عن قتادة بن دِعامة -من طريق شَيْبان- في الآية، قال: كان أهل الجاهلية فيهم بَغْيٌ وطاعة للشيطان، فكان الحيُّ منهم إذا كان فيهم عَدَد وعُدَّة، فقتَل لهم عبدًا عبدُ قومٍ آخرين، فقالوا: لن نقتل به إلا حُرًّا. تعزُّزًا وتفضُّلًا على غيرهم في أنفسهم، وإذا قُتلت لهم أنثى قتلتها امرأة، قالوا: لن نقتل بها إلا رجلًا. فأنزل الله هذه الآية يخبرهم أنّ العبد بالعبد، والحر بالحر، والأنثى بالأنثى، وينهاهم عن البغي. ثم أنزل سورة المائدة فقال: <q>﴿وكتبنا عليهم فيها أن النفس بالنفس﴾</q> [المائدة:٤٥] الآية{25}. (٢/١٥٥) ٥١١٨- قال مقاتل بن سليمان: ... صارت منسوخة، نسختها الآية التي في المائدة [الآية:٤٥ ]قوله سبحانه: <q>﴿وكتبنا﴾</q> فيما قضينا <q>﴿عليهم فيها أن النفس بالنفس﴾</q>، يعني: <q>﴿النفس﴾</q> المسلم الحرّ <q>﴿بالنفس﴾</q> المسلم الحرّ، والمسلمة الحرّة بالمسلمة الحرّة{8}٦٢٢. (ز) ٦٢٢ انتقد ابنُ عطية هذا القول، فقال: «آية المائدة إنما هي إخبار عما كُتِب على بني إسرائيل، فلا يترتب النسخ إلا بما تُلِقِّي عن رسول الله ﷺ، من أن حُكْمنا في شرعنا مثل حُكْمهم». <q>﴿فَمَنۡ عُفِیَ لَهُۥ مِنۡ أَخِیهِ شَیۡءࣱ فَٱتِّبَاعُۢ بِٱلۡمَعۡرُوفِ وَأَدَاۤءٌ إِلَیۡهِ بِإِحۡسَـٰنࣲۗ﴾</q> - تفسير ٥١١٩- عن عبد الله بن عمرو -من طريق مجاهد- <q>﴿وأداء اليه بإحسان﴾</q>، قال: ذلك في الدِّيَة{27}. (ز) ٥١٢٠- عن عبد الله بن عباس -من طريق جابر بن زيد- <q>﴿فمن عفي له﴾</q> قال: هو العَمَد يرضى أهلُه بالدية؛ <q>﴿فاتباع بالمعروف﴾</q> أُمِر به الطالِب، <q>﴿وأداء إليه بإحسان﴾</q> قال: يُؤَدِّي المطلوبَ بإحسان{28}. (٢/١٥٥) ٥١٢١- عن عبد الله بن عباس -من طريق أبي رَوْق، عن الضحاك- في قوله: <q>﴿فمن عفي له﴾</q> يقول: من تُرك له <q>﴿من أخيه شيء﴾</q> بعد أخذ الدية بعد استحقاق الدم، وذلك العفو؛ <q>﴿فاتباع بالمعروف﴾</q> يقول: فعلى الطالب اتِّباعٌ بالمعروف إذا قَبِل الدِّيَة، <q>﴿وأداء إليه بإحسان﴾</q> من القاتل في غير ضرورة ولا مَعْكٍ -يعني: المدافعة-{29}٦٢٣. (٢/١٥٦) ٦٢٣ ذكر ابنُ عطية (١/٤٢٥بتصرف) أنّ الأخ -على هذا القول- هو المقتول، ثم قال: «ويصح أن يكون هو الولي ...، والعفو في هذا القول على بابه». ٥١٢٢- عن إسماعيل السُّدِّيّ -من طريق أسباط-، نحو ذلك{29}. (ز) ٥١٢٣- وعن عطاء الخراساني، نحو ذلك. (ز) ٥١٢٤- وعن جابر بن زيد، نحو الشطر الأول من ذلك. (ز) ٥١٢٥- وعن سعيد بن جبير، نحو الشطر الثاني من ذلك{31}. (ز) ٥١٢٦- عن مقاتل بن حيان -من طريق بُكَيْر بن معروف-، نحو شطره الثاني{29}. (ز) ٥١٢٧- عن عبد الله بن عباس -من طريق مجاهد- قال: كان في بني إسرائيل القصاص، ولم يكن فيهم الدية، فقال الله لهذه الأمة: <q>﴿كتب عليكم القصاص في القتلى﴾</q> إلى قوله: <q>﴿فمن عفي له من أخيه شيء﴾</q> فالعفو أن يَقْبلَ الدية في العمد، <q>﴿فاتباع بالمعروف وأداء إليه بإحسان﴾</q> يتبعُ الطالبَ بالمعروف، ويؤدي إليه المطلوب بإحسان، <q>﴿ذلك تخفيف من ربكم ورحمة﴾</q> مِمّا كُتب على من كان قبلكم، <q>﴿فمن اعتدى بعد ذلك﴾</q> قَتَلَ بعد قَبُول الدية <q>﴿فله عذاب أليم﴾</q>{33}. (٢/١٥٦) ٥١٢٨- عن عبد الله بن عباس -من طريق مجاهد- قال: كانت بنو إسرائيل إذا قُتِل فيهم القتيلُ عمدًا لا يحل لهم إلا القَوَد، وأَحَلَّ الله الدِّيَة لهذه الأمة، فأَمَر هذا أن يَتْبَع بمعروف، وأَمَر هذا أن يُؤدِّي بإحسان، <q>﴿ذلك تخفيف من ربكم﴾</q>{34}. (٢/١٥٧) ٥١٢٩- عن عبد الله بن عباس -من طريق مجاهد- قال: الذي يقبل الدِّيَة، ذلك منه عفوٌ، فاتباعٌ بالمعروف، ويؤدِّي إليه الذي عُفِي له من أخيه بإحسان{35}. (ز) ٥١٣٠- عن عبد الله بن عباس -من طريق العوفي- في قوله: <q>﴿فمن عُفي له من أخيه شيء فاتباع بالمعروف وأداءٌ إليه بإحسان﴾</q> قال: وهي الدية، أن يحسن الطالبُ الطلبَ، <q>﴿وأداء إليه بإحسان﴾</q> وهو أن يحسن المطلوبُ الأداءَ{36}. (ز) ٥١٣١- عن سعيد بن جبير -من طريق عطاء بن دينار- في قوله: <q>﴿فاتباع بالمعروف﴾</q>، يعني: لِيَطْلُبَ وليّ المقتول في الرِّفْقِ{29}. (ز) ٥١٣٢- عن مجاهد بن جبر -من طريق ابن أبي نَجِيح- <q>﴿فمن عُفي له من أخيه شيء فاتباع بالمعروف﴾</q>، قال: العَفُوُّ: الذي يعفو عن الدَّمِ، ويأخذ الدِّيَة{38}. (ز) ٥١٣٣- عن مجاهد بن جبر -من طريق القاسم بن أبي بَزَّة- قال: إذا قَبِل الدِّيَة فقد عفا عن القصاص، فذلك قوله: <q>﴿فمن عُفي له من أخيه شيء﴾</q>{39}. (ز) ٥١٣٤- عن مجاهد بن جبر -من طريق الأعرج-، مثل ذلك، وزاد: فإذا قَبِل الدِّيَة فإن عليه أن يَتَّبِع بالمعروف، وعلى الذي عُفِي عنه أن يُؤَدِّي بإحسان{39}. (ز) ٥١٣٥- عن عامر الشعبي -من طريق داود بن أبي هند- في قوله: <q>﴿فمن عُفي له من أخيه شيء فاتباع بالمعروف وأداء إليه بإحسان﴾</q>، قال: هو العَمْد، يرضى أهلُه بالدِّيَة{41}. (ز) ٥١٣٦- وعن أبي العالية -من طريق الربيع بن أنس-= (ز) ٥١٣٧- ومقاتل بن حيان -من طريق بُكَيْر بن معروف-، نحو ذلك{20}. (ز) ٥١٣٨- وعن جابر بن زيد= (ز) ٥١٣٩- وسعيد بن جبير، نحو ذلك{43}. (ز) ٥١٤٠- عن الحسن البصري -من طريق يزيد بن إبراهيم-: <q>﴿وأداء إليه بإحسان﴾</q>، قال: على هذا الطالب أن يطلبَ بالمعروف، وعلى هذا المطلوب أن يُؤَدِّي بإحسان{44}. (ز) ٥١٤١- عن الحسن البصري -من طريق أبي عقيل-: أخْذُ الدِّيَة عَفْوٌ حَسَنٌ{45}٦٢٤. (ز) ٦٢٤ علَّقَ ابنُ جرير (٣/١٠٩) على قول الحسن قائلًا: «والواجب على تأويل القول الذي روينا عن علي والحسن -في قوله: <q>﴿كُتب عليكم القصاص﴾</q> أنه بمعنى: مُقاصّة دِيَة النفس الذكَر من دية نَفس الأنثى، والعبد من الحر، والتراجع بفضل ما بين ديتي أنفسهما- أن يكون معنى قوله: <q>﴿فمنْ عُفي له من أخيه شيء﴾</q>: فمن عُفي له من الواجب لأخيه عليه من قصاص دية أحدهما بدية نفس الآخر إلى الرِّضا بدية نفس المقتول فاتِّباع من الوليّ بالمعروف، وأداء من القاتل إليه ذلك بإحسان». ٥١٤٢- عن ابن جُرَيْج، قال: قلتُ لعطاء [بن أبي رباح] في قوله: <q>﴿فمن عُفي له من أخيه شيء فاتباع بالمعروف وأداء إليه بإحسان﴾</q>. قال: ذلك إذا أخذ الدية، فهو عَفْوٌ{46}. (ز) ٥١٤٣- عن قتادة بن دِعامة -من طريق مَعْمَر- <q>﴿فمن عفى له من أخيه شيء﴾</q> قال: إذا قتل الرجلُ عمدًا، ثُمَّ أُخِذَت منه الدِّيَة؛ فقد عُفِي له عن القتل، <q>﴿فاتباع بالمعروف﴾</q> قال: يتبع الطالبُ بالمعروف، ويؤدي إليه المطلوبُ بإحسان{47}. (ز) ٥١٤٤- عن قتادة بن دِعامة -من طريق سعيد- في قوله: <q>﴿فمن عُفي له من أخيه شَيء فاتباع بالمعروف وأداء إليه بإحسان﴾</q>، يقول: من قَتَل عمدًا فعُفي عنه، وقُبِلَت منه الدية. يقول: <q>﴿فاتباع بالمعروف﴾</q> فأَمَرَ المُتَّبِعَ أن يَتَّبِع بالمعروف، وأَمَرَ المؤدِّيَ أن يُؤَدِّي بإحسان، والعَمد قَوَدٌ إليه قصاص، لا عَقل فيه، إلا أن يرضَوا بالدية، فإن رضُوا بالدية، فمئة خَلِفَة. فإن قالوا: لا نرضى إلا بكذا وكذا. فذاك لهم{48}. (ز) ٥١٤٥- عن إسماعيل السدي -من طريق أسباط- <q>﴿فمنَ عُفي له من أخيه شيء﴾</q>، يقول: بَقِي له من دية أخيه شَيءٌ، أو من أرْشِ جراحته؛ فَلْيَتِّبِع بمعروف، ولْيُؤَدِّ إليه الآخرُ بإحسان{49}٦٢٥. (ز) ٦٢٥ علَّقَ ابنُ جرير (٣/١٠٩) على قول السّدّيّ بقوله: «هذا قولُ مَن زعم أنّ الآية نزلت في الذين تحاربوا على عهد رسول الله ﷺ، فأُمِر رسول الله ﷺ أن يُصلح بينهم، فيقاصَّ ديات بعضهم من بعض، وأحسب أن قائلي هذا القول وجَّهوا تأويل العفو -في هذا الموضع- إلى الكثرة، من قول الله -تعالى ذكره-: <q>﴿حَتّى عَفَوْا﴾</q> [الأعراف:٩٥]. فكأنّ معنى الكلام عندهم: فمن كَثُرَ له قبَل أخيه القاتل». وبنحوه قال ابن عطية (١/٤٢٥). ٥١٤٦- عن الربيع بن أنس -من طريق أبي جعفر- في قوله: <q>﴿فمن عُفي له من أخيه شيء فاتباع بالمعروف وأداء إليه بإحسان﴾</q> يقول: فمن قَتَل عمدًا فعُفِي عنه، وأُخذت منه الدية، يقول: <q>﴿فاتباع بالمعروف﴾</q> أمَر صاحبَ الدية الذي يأخذها أن يتبع بالمعروف، وأَمَر المؤدِّي أن يؤدي بإحسان{50}. (ز) ٥١٤٧- عن مقاتل بن حيان -من طريق بُكَيْر بن معروف- في قوله: <q>﴿فاتباع بالمعروف﴾</q>، قال: لِيُحْسِن الطَّلَب{29}. (ز) ٥١٤٨- قال مقاتل بن سليمان: <q>﴿فمن عفي له من أخيه شيء﴾</q>، ثم رجع إلى أوّل الآية في قوله سبحانه: <q>﴿كتب عليكم القصاص في القتلى﴾</q> إذا كان عمدًا إذا عفا وليُّ المقتول عن أخيه القاتل ورضِيَ بالدية <q>﴿فاتباع بالمعروف﴾</q> يعني: الطالب ليطلب ذلك في رفق، ثم قال للمطلوب: <q>﴿وأداء إليه بإحسان﴾</q> يقول: ليؤدي الدية إلى الطالب عفوًا في غير مشقة ولا أذًى{52}. (ز) ٥١٤٩- عن سفيان بن حسين -من طريق عباد بن العوام- في قوله تعالى: <q>﴿فمن عفي له من أخيه شيء﴾</q>، قال: فمن فَضُل له على أخيه شيءٌ فليُؤَدِّه بالمعروف، وليَتبعه الطالب بإحسان{53}٦٢٦. (ز) ٦٢٦ رجَّح ابنُ جرير (٣/١٠٩ بتصرف) مستندًا إلى السياق، فقال: «أولى الأقوال عندي بالصواب في قوله: <q>﴿فمن عُفي له من أخيه شيء﴾</q>: فمن صُفِح له -من الواجب كان لأخيه عليه من القود- عن شيء من الواجب، على ديّة يأخذها منه، فاتباعٌ بالمعروف من العافي عن الدم، الراضي بالدية من دم وليّه، وأداء إليه -من القاتل- ذلك بإحسان. لِما قد بيّنّا فيما مضى قبلُ مِن أنّ معنى قول الله -تعالى ذِكْرُه-: <q>﴿كُتب عليكم القصاص﴾</q>: إنما هو القصاص من النفوس القاتلة أو الجارحة أو الشاجَّة عمدًا، كذلك العفو أيضًا عن ذلك». ٥١٥٠- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- <q>﴿وأداء إليه بإحسان﴾</q>، قال: أنتَ أيها المعفوُّ عنه{39}. (ز) <q>﴿ذَ ٰ⁠لِكَ تَخۡفِیفࣱ مِّن رَّبِّكُمۡ وَرَحۡمَةࣱۗ﴾</q> - تفسير ٥١٥١- عن عبد الله بن عباس -من طريق جابر بن زيد-: <q>﴿ذلك تخفيف من ربكم ورحمة﴾</q> مِمّا كان على بني إسرائيل{55}. (٢/١٥٥) ٥١٥٢- عن عبد الله بن عباس -من طريق أبي رَوْق، عن الضحاك- في قوله: <q>﴿ذلك تخفيف من ربكم ورحمة﴾</q>، يقول: رفق{27}. (٢/١٥٦) ٥١٥٣- عن عبد الله بن عباس -من طريق مجاهد- قال: كان على بني إسرائيل قصاص في القتلى، ليس بينهم دية في نَفْس ولا جرح، وذلك قول الله: <q>﴿وكتبنا عليه فيها أن النفس بالنفس﴾</q> [المائدة:٤٥] الآية، وخفَّف الله عن أمّة محمد؛ فقبل منهم الدِّيَة في النفس وفي الجراحة، وذلك قوله: <q>﴿ذلك تخفيف من ربكم﴾</q> بينكم{57}. (٢/١٥٧) ٥١٥٤- قال الشافعي: أخبرنا معاذ بن موسى، عن بُكَير بن معروف، عن مقاتل بن حيان، قال مقاتل: أخذت هذا التفسيرَ عن نفرٍ، حَفِظَ معاذٌ منهم مجاهدًا= (ز) ٥١٥٥- والحسنَ= (ز) ٥١٥٦- والضحاكَ بن مزاحم، في قول الله -تبارك وتعالى-: <q>﴿فمن عفي له من أخيه شيء فاتباعٌ بالمعروف﴾</q> الآية، قالوا: كان على أهل التوراة مَن قَتَل نفسًا بغير نفس أن يُقاد بها، ولا يُعفى عنه، ولا تقبل منه الدية. وفُرِض على أهل الإنجيل أن يُعفى عنه، ولا يُقْتَل. ورُخّص لأمة محمد ﷺ إن شاء قَتَل، وإن شاء أخذ الدية، وإن شاء عفا. فذلك قوله تعالى: <q>﴿ذلك تخفيف من ربكم ورحمة﴾</q> يقول: الدية تخفيف من الله تعالى؛ إذ جعل الدية ولا يقتل، ثم قال: <q>﴿فمن اعتدى بعد ذلك فله عذاب أليم﴾</q>{58}. (ز) ٥١٥٧- عن أبي العالية -من طريق الربيع بن أنس- <q>﴿تخفيف من ربكم ورحمة﴾</q>، يقول: حين أُطعِمتم الدية، ولم تحِلَّ لأهل التوراة، إنما هو قصاص أو عفو، وكان أهل الإنجيل إنما هو عفو وليس غيره، فجعل الله لهذه الأمة القَوَد، والدِّية، والعفو{59}. (١/١٦٠) ٥١٥٨- عن سعيد بن جبير -من طريق عطاء بن دينار- في قوله: <q>﴿ذَلِكَ تَخْفِيفٌ مِن رَبِّكُمْ ورَحْمَةٌ﴾</q>، يعني: ولترحموا{27}. (ز) ٥١٥٩- عن مجاهد بن جبر -من طريق ابن سمعان- يقول: في قوله: <q>﴿ذَلِكَ تَخْفِيفٌ مِن رَبِّكُمْ ورَحْمَةٌ﴾</q>، يقول: في نكاح الإماء، يقول: لا بأس به{61}. (ز) ٥١٦٠- عن قتادة بن دِعامة -من طريق سعيد- في قوله: <q>﴿ورحمة﴾</q>، قال: هي رحمة رَحِم بها الله هذه الأمّة، أطعمهم الديّة، وأحلّها لهم، ولم تَحِلَّ لأحد قبلهم، فكان في أهل التوراة إنما هو القصاص أو العفو، ليس بينهما أرْش، فكان أهل الإنجيل إنما هو عفوٌ أمروا به، وجعل الله لهذه الأمة القتل، والعفو، والدية إن شاؤوا، أحلّها لهم، ولم يكن لأمّة قبلهم{62}. (٢/١٥٧) ٥١٦١- عن الربيع بن أنس -من طريق أبي جعفر- في قوله: <q>﴿ذلك تخفيف من ربكم ورحمة﴾</q>: وإنما هي رحمة رَحِم الله بها هذه الأمة؛ أطعمهم الدِّيَة، وأحلَّها لهم، ولم تَحِلَّ لأحد قبلهم، وكان أهل التوراة إنما هو قصاص أو عفو، ليس بينهما شيء، وكان أهل الإنجيل إنما هو عفوٌ أمروا به، فجعل الله لهذه الأمة القَوَد، والعفو، والدية إن شاءوا، أحلها لهم، ولم تكن لأمة قبلهم{63}. (ز) ٥١٦٢- قال مقاتل بن سليمان: <q>﴿تخفيف من ربكم﴾</q> إذْ جَعَل في قتل العمد العفوَ، والدِّية. ثم قال: <q>﴿ورحمة﴾</q> يعني: وتراحموا، وكان الله ﷿ حَكَم على أهل التوراة أن يُقتَل القاتل، ولا يُعفى عنه، ولا يُقبَل منه الدية، وحَكَم على أهل الإنجيل العفو، ولا يُقتَل القاتل بالقصاص، ولا يَأخُذ ولي المقتول الدية، ثم جعل الله ﷿ التخفيف لأمة محمد ﷺ، إن شاء وليُّ المقتول قَتَل القاتل، وإن شاء عفا عنه، وإن شاء أخَذ منه الدية، فكان لأهل التوراة أن يُقتل قاتل الخطأ والعمد، فرخَّص الله ﷿ لأمة محمد ﷺ، فذلك قوله سبحانه في الأعراف [١٥٧]: <q>﴿ويضع عنهم إصرهم والأغلال التي كانت عليهم﴾</q> من التشديدات، وهي أن يُقتل قاتل العمد، ولا يُعْفى عنه، ولا يُؤخذ منه الدية{64}. (ز) <q>﴿فَمَنِ ٱعۡتَدَىٰ بَعۡدَ ذَ ٰ⁠لِكَ﴾</q> - تفسير ٥١٦٣- عن عبد الله بن عباس -من طريق مجاهد- <q>﴿فمن اعتدى﴾</q> قال: قَتَل بعد قَبول الدِّية <q>﴿فله عذاب أليم﴾</q>{65}. (٢/١٥٦) ٥١٦٤- عن عطاء، نحوه{66}. (ز) ٥١٦٥- عن مقاتل بن حيان -من طريق بُكَيْر بن معروف-، نحوه{67}. (ز) ٥١٦٦- عن أبي العالية -من طريق الربيع بن أنس- <q>﴿فمن اعتدى﴾</q>: قَتَل بعد أخذه الدية{68}. (٢/١٦٠) ٥١٦٧- عن مجاهد بن جبر -من طريق ابن أبي نَجِيح- <q>﴿فمن اعتدى بعد ذلك﴾</q>: فقَتَل بعد أخذه الدية <q>﴿فله عذاب أليم﴾</q>{69}. (ز) ٥١٦٨- قال الشافعي: أخبرنا معاذ بن موسى عن بُكَير بن معروف، عن مقاتل بن حيان، قال مقاتل: أخذت هذا التفسيرَ عن نفرٍ-حَفِظَ معاذ منهم- مجاهدًا= (ز) ٥١٦٩- والحسنَ= (ز) ٥١٧٠- والضحاكَ بن مزاحم، ... <q>﴿فمن اعتدى بعد ذلك فله عذاب أليم﴾</q>، يقول: مَن قتل بعد أخذه الدية فله عذاب أليم{70}. (ز) ٥١٧١- عن الحسن البصري -من طريق يزيد بن إبراهيم- في قوله: <q>﴿فمن اعتدى بعد ذلك فله عذاب أليم﴾</q>، قال: كان الرجلُ في الجاهلِيَّة إذا قتل قتيلًا ينضم إلى قومه، فيجيء قومه فيصالحون عنه بالدِّيَة، فيخرج الفارُّ وقد أمِن في نفسه، فيقتُلُه ويَرمي إليه بالدية، فذلك الاعتداء{71}. (٢/١٥٨) ٥١٧٢- عن الحسن البصري -من طريق أبي عقيل- في هذه الآية: <q>﴿فمن عُفي لهُ من أخيه شيء﴾</q>، قال: القاتلُ إذا طُلِب فلم يُقْدَر عليه، وأُخِذ من أوليائه الدِّيَة، ثم أمِن، فأُخِذ فقُتِل. قال الحسن: ما أكل عُدوانٌ{72}. (ز) ٥١٧٣- عن قتادة بن دِعامة -من طريق مَعْمَر-: <q>﴿فمن اعتدى بعد ذلك﴾</q> بأن قَتَل بعد أخْذِه الدية{73}. (٢/ ١٥٨) ٥١٧٤- عن إسماعيل السدي -من طريق أسباط-: <q>﴿فمن اعتدى بعد ذلك﴾</q> بعد ما يأخذ الدية، فيقتُل <q>﴿فله عذابٌ أليم﴾</q>{74}. (ز) ٥١٧٥- عن الربيع بن أنس -من طريق أبي جعفر- قوله: <q>﴿فمن اعتدى بعد ذلك فله عذاب أليم﴾</q>، يقول: فمن اعتدى بعد أخْذِه الديةَ <q>﴿فله عذاب أليم﴾</q>{75}. (ز) ٥١٧٦- عن سفيان الثوري -من طريق عبد الرزاق- في الَّذي يعفو، أو يأخذ الدية، ثُمَّ يقتل، قال الله تبارك وتعالى: <q>﴿فمن اعتدى بعد ذلك فله عذاب أليم﴾</q>، قال: هو الرجل يَقْتل بعد ما يَأْخُذ الدِّيَة{76}. (ز) ٥١٧٧- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهْب- في قوله: <q>﴿فمن اعتدى بعد ذلك فله عذابٌ أليم﴾</q> قال: أخَذ العَقْل، ثم قَتل -بعد أن أخذ العَقْل- قاتلَ قتيله، <q>﴿فله عذاب أليم﴾</q>{77}. (ز) <q>﴿فَلَهُۥ عَذَابٌ أَلِیمࣱ ۝١٧٨﴾</q> - تفسير ٥١٧٨- عن أبي شُرَيْحٍ الخزاعي، أنّ النبي ﷺ قال: «مَن أُصِيب بقتل أو خَبْل{78}، فإنه يختار إحدى ثلاث: إما أن يَقْتَصَّ، وإما أن يعفو، وإما أن يأخذ الدية، فإن أراد رابعةً فخذوا على يديه، ومن اعتدى بعد ذلك فله نارُ جهنم خالدًا فيها أبدًا»{79}. (١/١٥٨) ٥١٧٩- قال ابن جُرَيْج: أخبرني إسماعيل بن أميّة، عن الثبت -غير أنه لم ينسبه، وقال: ثقة-: أنّ النبي ﷺ أوْجبَ بقَسَمٍ أو غيره أن لا يُعفى عن رَجُلٍ عَفا عن الدّم وأخذ الدية، ثم عَدا فَقَتل. وقال ابن جُرَيْج: أخبرني عبد العزيز بن عمر بن عبد العزيز، قال: في كتاب لعمرَ عن النبي ﷺ قال: «والاعتداء الذي ذَكَر اللهُ: أنّ الرجل يأخذ العقلَ، أو يقتصُّ، أو يقضي السلطانُ فيما بين الجرح، ثم يعتدي بعضُهم من بعد أن يستوعبَ حقه، فمن فعل ذلك فقد اعتدى، والحكم فيه إلى السلطان بالذي يرى فيه من العقوبة». قال: ولو عفا عنه لم يكن لأحد من طلبة الحق أن يعفو؛ لأنّ هذا من الأمر الذي أنزل الله فيه قوله: <q>﴿فَإنْ تَنازَعْتُمْ فِي شَيْءٍ فَرُدُّوهُ إلى اللَّهِ والرَّسُولِ﴾</q> [النساء:٥٩]»{80}٦٢٧. (ز) ٦٢٧ انتَقَدَ ابنُ جرير (٣/١٢٠) قول ابن جريج هذا لمخالفته ما دلّ عليه ظاهر القرآن، وإجماع علماء الأمة، فقال: «أمّا ما قاله ابن جريج: مِن أن حكم من قتل قاتل وليّه بعد عفوه عنه، وأخذه دية وليه المقتول- إلى الإمام دون أولياء المقتول؛ فقولٌ خلاف لِما دَلَّ عليه ظاهر كتاب الله، وأجمع عليه علماء الأمة. وذلك أنّ الله جعل لولي كل مقتول ظُلمًا السلطانَ دون غيره، من غير أن يخصّ من ذلك قتيلًا دون قتيل، فسواء كان ذلك قتيل وليّ من قتله أو غيره، ومن خص مِن ذلك شيئًا سُئِل البرهان عليه من أصلٍ أو نظير، وعُكِس عليه القول فيه، ثُمَّ لن يقول في شيء من ذلك قولًا إلا ألزم في الآخر مثله. ثم في إجماع الحجة على خلاف ما قاله في ذلك مُكْتَفًى في الاستشهاد على فساده بغيره». ٥١٨٠- عن قتادة بن دِعامة -من طريق مَعْمَر- <q>﴿فله عذاب أليم﴾</q>، قال: فعليه القتل، لا يُقْبَل منه الدِّيَة. وذُكِر لنا: أنّ رسول الله ﷺ قال: «لا أُعافِي رجلًا قَتَل بعد أخذ الدِّيَة»{81}. (٢/١٥٨) ٥١٨١- عن جابر بن عبد الله، أنّ رسول الله ﷺ قال: «لا أعفي مَن قَتَل بعد أخْذِه الدِّيَة»{82}. (ز) ٥١٨٢- عن عبد الله بن عباس -من طريق أبي رَوْق، عن الضحاك- في قول الله: <q>﴿عذاب أليم﴾</q>، يقول: نكال مُوجِع، فهذه <q>﴿عذاب أليم﴾</q> منسوخة، نسختها: <q>﴿إنَّ اللَّهَ لا يَغْفِرُ أنْ يُشْرَكَ بِهِ ويَغْفِرُ ما دُونَ ذَلِكَ لِمَن يَشاءُ﴾</q> [النساء:٤٨، ٩٧]{67}. (ز) ٥١٨٣- عن سعيد بن جبير -من طريق عطاء بن دينار- في قول الله: <q>﴿فله عذب أليم﴾</q>، يعني: وجيع. يقول: يُقتل، ولا يُعفى عنه، ولا تُؤخذ منه الدِّيَة{67}. (ز) ٥١٨٤- عن الضحاك بن مُزاحِم -من طريق جُوَيْبِر- في قوله: <q>﴿فمن اعتدى بعد ذلك فله عذاب أليم﴾</q>، قال: يُقتَل، وهو العذاب الأليم. يقول: العذاب المُوجِع{85}. (ز) ٥١٨٥- عن عكرمة مولى ابن عباس -من طريق هارون- في رجل قَتَل بعد أخذ الدية، قال: يُقتل، أما سمعت الله يقول: <q>﴿فله عذاب أليم﴾</q>؟{86}. (٢/١٥٩) ٥١٨٦- عن الحسن البصري -من طريق يونس- في رجل قَتَل، فأُخِذَتْ منه الدِّيَة، ثم إنّ وليَّه قَتل به القاتلَ. قال الحسن: تُؤْخَذ منه الدية التي أخَذ، ولا يُقتل به{87}. (ز) ٥١٨٧- قال مقاتل بن سليمان: ثم قال: <q>﴿فمن اعتدى بعد ذلك فله عذاب أليم﴾</q>، يعني: وجيع؛ فإنّه يُقْتَل، ولا يُؤْخَذُ منه دِيَة؛ قال النبي ﷺ: «لا عَفْوَ عَمَّن قتل القاتل بعد أخذ الدِّيَة». وقد جعل الله له عذابًا أليمًا{88}. (ز) ٥١٨٨- عن عبد الملك ابن جُرَيج: يَتَحَتَّمُ قتلُه، حتى لا يُقْبَل العفو{89}. (ز) ",footnotes:1:أخرجه ابن أبي حاتم ١/٢٩٣.العمية -بكسر العين، وحكي فيها ضم العين-: العصبية والدعوة العمياء. وقيل: الجهالة والضلالة. وقيل: الفتنة. لسان العرب (عمي).أخرجه ابن جرير ٣/٩٥. وعزاه السيوطي إلى عبد بن حميد. وفي رواية لابن جرير ٣/٩٨، وابن أبي حاتم ١/٢٩٣، قال: نزلت في قتال عمِّية. قال شعبة: كأنه في صلح. قال: اصطلحوا على هذا.تفسير الثعلبي ٢/٥٣.أخرجه ابن جرير ٣/٩٨. وعزاه السيوطي إلى ابن مردويه.ذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ١/١٩٧-.أخرجه ابن جرير ٣/٩٦.تفسير مقاتل بن سليمان ١/١٥٧-١٥٨.أخرجه ابن أبي حاتم ١/٢٩٣.علّقه ابن أبي حاتم ١/٢٩٣.تفسير مقاتل بن سليمان ١/١٥٧-١٥٨.أخرجه ابن جرير ٣/٩٩.أخرجه ابن جرير ٣/٩٩. كما أخرج ٣/١٠٠ نحوه من طريق الشعبي.أخرجه ابن جرير ٣/٩٦.أخرجه ابن جرير ٣/٩٦.أخرجه ابن أبي شيبة ٥/٤٦٠ (٢٧٩٧٣) مرسلًا.أخرجه ابن جرير ٣/٩٩.أخرجه عبد الرزاق في المصنف (١٨١٥٨)، وابن أبي حاتم ١/٢٩٤ بنحوه من طريق حجاج عن ابن جريج.أخرجه ابن جرير ٣/٩٧.أخرجه ابن أبي حاتم ١/٢٩٤.أخرجه النحاس في ناسخه ص٨٣.عزاه السيوطي إلى ابن مردويه.أخرجه ابن جرير ٣/١٠٠، وابن أبي حاتم ١/٢٩٤، والبيهقي ٨/٤٠. وعزاه السيوطي إلى ابن المنذر.ذكره يحيي بن سلام -كما في تفسير ابن أبي زمنين ١/١٩٧-.أخرجه البيهقي ٨/٢٨. وعزاه السيوطي إلى عبد بن حميد، وأبي داود في ناسخه، وأبي القاسم الزجاجي في أماليه.تفسير مقاتل بن سليمان ١/١٥٧-١٥٨.أخرجه ابن أبي حاتم ١/٢٩٦.أخرجه ابن جرير ٣/١٠٥، والحاكم ٢/٢٧٣، والبيهقي في سننه ٨/٥٢. وعزاه السيوطي إلى عبد بن حميد.أخرجه ابن أبي حاتم ١/٢٩٥.أخرجه ابن أبي حاتم ١/٢٩٥.علّقه ابن أبي حاتم ١/٢٩٥.أخرجه ابن أبي حاتم ١/٢٩٥.أخرجه عبد الرزاق في تفسيره ١/٦٧، وفي مصنفه (١٨٤٥٠، ١٨٤٥١)، وسعيد بن منصور (٢٣٦- تفسير)، وابن أبي شيبة ٩/٤٣٣، والبخاري (٤٤٩٨، ٦٨٨١)، والنسائي (٤٧٩٥)، وابن جرير ٣/١٠٤، ١١٢، وابن أبي حاتم ١/٢٩٣، ٢٩٤، ٢٩٦ (١٥٧٣، ١٥٧٩، ١٥٨٥)، والنحاس في ناسخه ص٨٦-٨٧، وابن حِبّان (٦٠١٠)، والبيهقي ٨/٥١-٥٢. وعزاه السيوطي إلى ابن المنذر.أخرجه الطبراني (١١١٥٥).تفسير عبد الرزاق ١/٦٧، وابن جرير ٣/١٠٥.أخرجه ابن جرير ٣/١٠٥.أخرجه ابن أبي حاتم ١/٢٩٥.تفسير مجاهد ص٢١٩، وأخرجه ابن جرير ٣/١٠٦.أخرجه ابن جرير ٣/١٠٨.أخرجه ابن جرير ٣/١٠٨.أخرجه ابن جرير ٣/١٠٦.أخرجه ابن أبي حاتم ١/٢٩٤.علّقه ابن أبي حاتم ١/٢٩٤.أخرجه ابن جرير ٣/١٠٦. وعلَّقه ابن أبي حاتم ١/٢٩٥.أخرجه ابن جرير ٣/١٠٨. وعلّق ابن أبي حاتم ١/٢٩٤ نحوه.أخرجه ابن جرير ٣/١٠٧. وعلّقه ابن أبي حاتم ١/٢٩٤.أخرجه عبد الرزاق في تفسيره ١/٦٧، وابن جرير ٣/١٠٧ مختصرًا. وعلّقه ابن أبي حاتم ١/٢٩٥. وذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ١/١٩٨-. وفي مصنف عبد الرزاق (١٨٤٤٩) بلفظ: يُجبَر القاتل على أن يعطي الدية، قال الله ﷿: <q>﴿فمن عفي له من أخيه شيء فاتباع بالمعروف﴾</q>، فالعفو أن يقبل الدية.أخرجه ابن جرير ٣/١٠٧.أخرجه ابن جرير ٣/١٠٩، وابن أبي حاتم ١/٢٩٤.أخرجه ابن جرير ٣/١٠٧. وعلّقه ابن أبي حاتم ١/٢٩٥.أخرجه ابن أبي حاتم ١/٢٩٥.تفسير مقاتل بن سليمان ١/١٥٨.أخرجه ابن أبي شيبة في مصنفه (ت: محمد عوامة) ١٤/٣٢٣-٣٢٤ (٢٨٥٥٢).أخرجه ابن جرير ٣/١٠٨.أخرجه ابن جرير ٣/١١٢، والبيهقي ٨/٥٢، وعُقِّب الأثر عند ابن جرير بقول: يعني: من تحريم الدية عليهم. وعزاه السيوطي إلى عبد بن حميد.أخرجه ابن أبي حاتم ١/٢٩٦.أخرجه ابن جرير ٣/١١٣، وابن أبي حاتم ١/٢٩٦. وعزاه السيوطي إلى أبي الشيخ.أخرجه الشافعي في مسنده ٣/٣٠٣، والبيهقي في السنن ٨/٥١.عزاه السيوطي إلى آدم. وأخرجه البيهقي في سننه ٨/٢٤ من طريقه.أخرجه ابن أبي حاتم ١/٢٩٦.أخرجه عبد الرزاق في المصنف ٧/٢٦٤ (١٣٠٨٦). كذا وردت هذه الآية في هذا الأثر في المطبوع من المصنّف، ويبدو أن في إثباتها خطأ! ولعل المراد قوله تعالى: <q>﴿يُرِيدُ اللَّهُ أنْ يُخَفِّفَ عَنْكُمْ﴾</q> [النساء:٢٨]، فهي في سياق الآيات التي تتحدث عن الترخيص في الزواج من الإماء لمن خشي العنت. ويؤكّده ما ورد في تفسيرها عن مجاهد من طريق ابن أبي نجيح أنه قال: في نكاح الأمة، وفي كل شيء فيه يسر. وسيأتي في تفسير سورة النساء.أخرجه ابن جرير ٣/١١٣. وذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ١/١٩٨-. وعزاه السيوطي إلى الزجاجي في أماليه.أخرجه ابن جرير ٣/١١٣، وابن أبي حاتم ١/٢٩٦.تفسير مقاتل بن سليمان ١/١٥٨-١٥٩.أخرجه البخاري (٤٤٩٨)، وابن أبي حاتم ١/٢٩٧.علّقه ابن أبي حاتم ١/٢٩٧.أخرجه ابن أبي حاتم ١/٢٩٧.أخرجه البيهقي في سننه ٨/٢٤ من طريق آدم. وعزاه السيوطي إلى آدم.أخرجه ابن جرير ٣/١١٣، وفي تفسير مجاهد ص٢١٩ مختصرًا. وعلّقه ابن أبي حاتم ١/٢٩٧.أخرجه البيهقي في السنن ٨/٥١ من طريق الشافعي، ولم يرد تفسير هذه الآية في مسنده ٣/٣٠٣.أخرجه ابن جرير ٣/١١٦. وعزاه السيوطي إلى وكيع، وعبد بن حميد.أخرجه ابن جرير ٣/١١٦.أخرجه ابن جرير ٣/١١٥. وعزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ٣/١١٧، وابن أبي حاتم ١/٢٩٧.أخرجه ابن جرير ٣/١١٦، وابن أبي حاتم ١/٢٩٧.أخرجه عبد الرزاق في المصنف (١٨٢٠١).أخرجه ابن جرير ٣/١١٧.الخبل: الفساد، والمراد به هنا: فساد العضو بقطع أو نحوه. النهاية (خبل).أخرجه أحمد ٢٦/٢٩٦-٢٩٧ (١٦٣٧٥)، وأبو داود ٦/٥٤٦-٥٤٧ (٤٤٩٦)، وابن ماجه ٣/٦٤٤-٦٤٥ (٢٦٢٣)، وابن أبي حاتم ١/٢٩٦ (١٥٨٩). قال ابن حزم في المحلى ١١/١٤: «هذا لا يصح». وقال الذهبي في ميزان الاعتدال ٢/١٧٠ (٣٣٢٦) في ترجمة سفيان بن أبي العوجاء: «هو حديث منكر». وقال الألباني في الإرواء ٧/٢٧٨ بعد أن ذكره من طريق محمد بن إسحاق عن الحارث بن فضيل عن سفيان بن أبي العوجاء: «سفيان ضعيف، وابن إسحاق مدلّس، وقد عنعنه».أخرجه ابن جرير ٣/١١٨.أخرجه عبد الرزاق في تفسيره ١/٣٠٥ (١٦٧)، وابن جرير ٣/١١٥-١١٦ عنه مرسلًا. وينظر: تحقيق أحمد شاكر لتفسير الطبري ٣/٣٧٦.أخرجه أحمد ٢٣/١٨٢ (١٤٩١١)، وأبو داود ٦/٥٥٩-٥٦٠ (٤٥٠٧). قال الألباني في الضعيفة ١٠/٣١٠ (٤٧٦٧): «ضعيف».أخرجه ابن أبي حاتم ١/٢٩٧.أخرجه ابن أبي حاتم ١/٢٩٧.أخرجه ابن جرير ٣/١١٧. وعلّقه ابن أبي حاتم ١/٢٩٧.أخرجه ابن أبي شيبة ٩/٤٦١.أخرجه ابن جرير ٣/١١٩.تفسير مقاتل بن سليمان ١/١٥٩.تفسير البغوي ١/١٩١.
2,179," <q>﴿وَلَكُمۡ فِی ٱلۡقِصَاصِ حَیَوٰةࣱ﴾</q> - قراءات ٥١٨٩- عن أبي الجَوْزاء -من طريق عمرو بن مالك- أنه قرأ: (ولَكُمْ فِي القَصَصِ حَياةٌ)، قال: القصص: القرآن{1}. (٢/١٦٠) <q>﴿وَلَكُمۡ فِی ٱلۡقِصَاصِ حَیَوٰةࣱ﴾</q> - تفسير الآية ٥١٩٠- قال الشافعي: أخبرنا معاذ بن موسى، عن بُكَير بن معروف، عن مقاتل بن حيان، قال مقاتل: أخذت هذا التفسيرَ عن نفرٍ، حَفِظَ معاذ منهم مجاهدًا= (ز) ٥١٩١- والحسنَ= (ز) ٥١٩٢- والضحاكَ بن مزاحم، ... في قوله: <q>﴿ولكم في القصاص حياة﴾</q>: ينتهي بها بعضُكم عن بعضٍ مخافة أن يُقْتَل{2}. (ز) ٥١٩٣- عن أبي العالية -من طريق الربيع بن أنس- <q>﴿ولكم في القصاص حياة﴾</q>، يقول: جعل الله القصاص حياة؛ فكم من رجل يريد أن يَقْتُل فيمنعه منه مخافة أن يُقْتَل{3}. (٢/١٦٠) ٥١٩٤- وعن الحسن البصري= (ز) ٥١٩٥- وأبي مالك، نحو ذلك{4}. (ز) ٥١٩٦- عن مجاهد بن جبر، في قوله: <q>﴿ولكم في القصاص حياة﴾</q>، قال: بُقْيا{5}، يُناهِي بعضهم عن بعض{6}. (٢/١٦٠) ٥١٩٧- عن مجاهد بن جبر -من طريق ابن أبي نَجِيح- في قوله: <q>﴿ولكم في القصاص حياةٌ يا أولي الألباب﴾</q>، قال: نَكالٌ، تَناهٍ{7}. (ز) ٥١٩٨- عن الضحاك بن مُزاحِم -من طريق أبي مصلح نصر بن مُشارِس- في قوله: <q>﴿ولكم في القصاص حياة﴾</q>، يعني بالحياة: الصلاح، والعدل{8}. (ز) ٥١٩٩- عن قتادة بن دِعامة -من طريق مَعْمَر- في قوله: <q>﴿ولكم في القصاص حياة﴾</q>: جعل الله في القصاص حياةً، إذا ذكره الظالمُ المُعْتَدِي كفَّ عن القتل{9}. (٢/١٥٩) ٥٢٠٠- عن قتادة بن دِعامة -من طريق سعيد- قال: جعل الله هذا القصاص حياةً وعبرةً لأولي الألباب، وفيه عظةٌ لأهل الجهل والسَّفَه، كم من رجل قد هَمَّ بداهيةٍ لولا مخافة القصاص لوقَع بها، ولكنَّ الله حجز عباده به بالقصاص بعضهم عن بعض، وما أمَرَ الله بأَمْرٍ قطُّ إلا وهو أمْرُ صلاح في الدنيا والآخرة، وما نهى الله عن أمر إلا وهو أمْرُ فسادٍ في الدنيا والدين، والله كان أعلمَ بالذي يُصلِح خَلْقَه{10}. (٢/١٥٩) ٥٢٠١- عن أبي صالح -من طريق إسماعيل- <q>﴿ولكم في القصاص حياة﴾</q>، قال: بقاء{11}. (ز) ٥٢٠٢- عن سفيان الثوري، نحو ذلك{12}. (ز) ٥٢٠٣- عن إسماعيل السُّدِّيّ -من طريق أسباط- <q>﴿في القصاص حياة﴾</q>، قال: بَقاء، لا يُقتَل إلا القاتلُ بجنايته{13}. (٢/١٥٩) ٥٢٠٤- عن الربيع بن أنس -من طريق أبي جعفر- قوله: <q>﴿ولكم في القصاص حياة﴾</q> الآية، يقول: جعل الله هذا القصاصَ حياةً وعِبْرَةً لكم؛ كم من رجل قد هَمّ بداهية فمنعه مخافة القصاص أن يقع بها، وإن الله قد حَجَز عبادَه بعضهم عن بعض بالقصاص{14}. (ز) ٥٢٠٥- وعن مُقاتِل بن حَيّان -من طريق بُكَيْر بن معروف-، نحو ذلك{15}. (ز) ٥٢٠٦- قال مقاتل بن سليمان: ثُمَّ قال سبحانه: <q>﴿ولكم في القصاص حياة﴾</q>، يعني: بقاء؛ يَحْجُزُ بعضَكم عن بعض{16}. (ز) ٥٢٠٧- عن عبد الملك ابن جُرَيْج -من طريق حَجّاج- قوله: <q>﴿ولكم في القصاص حياة﴾</q>، قال: <q>﴿حَياةٌ﴾</q>: مَنَعَةٌ{17}. (ز) ٥٢٠٨- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهْب- في قوله: <q>﴿ولكم في القصاص حياة﴾</q>، قال: <q>﴿حياةٌ﴾</q>: تَقِيَّةٌ؛ إذا خاف هذا أن يُقتل بي كفَّ عنّي، لعلّه يكون عدوًّا لي يريد قتلي، فيتذكر أنه يُقْتَل في القصاص، فخشي أن يُقْتَل بي، وكفَّ بالقصاص الذي خافَ أن يقتل، لولا ذلك قتل هذا{17}٦٢٨. (ز) ٦٢٨ ذَهَبَ ابنُ جرير (٣/١٢٠) إلى ما ذهب إليه مجاهد، وقتادة، والربيع، وابن زيد، فقال: «يعني بقوله -جلّ ثناؤه-: <q>﴿ولكم في القصاص حياة يا أولي الألباب﴾</q>: ولكم يا أولي العقول، فيما فرضتُ عليكم، وأوجبت لبعضكم على بعض، من القصاص في النفوس والجراح والشجاج، ما مَنع به بعضكم من قتل بعض، ووزَعَ بعضكم عن بعضٍ؛ فحَيِيتُم بذلك، فكان لكم في حكمي بينكم بذلك حياة». <q>﴿یَـٰۤأُو۟لِی ٱلۡأَلۡبَـٰبِ﴾</q> - تفسير ٥٢٠٩- عن سعيد بن جُبَيْر -من طريق عطاء بن دينار- في قوله: <q>﴿ولكم في القصاص حياة يا أولي الألباب﴾</q>، يعني: مَن كان له لُبٌّ أو عَقْلٌ يذكر القِصاص؛ فيَحْجُزُهُ خوْفُ القِصاص عن القتل{8}. (٢/١٦٠) ٥٢١٠- عن أبي مالك= (ز) ٥٢١١- والضحاك بن مزاحم، نحو ذلك{12}. (ز) ٥٢١٢- عن مقاتل بن حيان -من طريق بُكَيْر بن معروف-، نحو ذلك{8}. (ز) ٥٢١٣- قال مقاتل بن سليمان: <q>﴿يا أولي الألباب﴾</q>، يعني: مَن كان له لُبٌّ أو عقل فذكر القصاص؛ فيَحْجُزُهُ الخوْفُ عن القتل{16}٦٢٩. (ز) ٦٢٩ قال ابنُ جرير (٣/١٢٣): «وخصَّ الله -تعالى ذِكْرُه- بالخطاب أهلَ العقول؛ لأنهم هم الذين يعقلون عن الله أمره ونهيه، ويتدبّرون آياته وحججه، دونَ غيرهم». وبنحوه قال ابنُ عطية (٣/٤٢٨). <q>﴿لَعَلَّكُمۡ تَتَّقُونَ ۝١٧٩﴾</q> - تفسير ٥٢١٤- عن سعيد بن جُبَيْر -من طريق عطاء بن دينار- في قوله: <q>﴿لعلكم تتقون﴾</q>: لكي تَتَّقُوا الدِّماءَ مَخافة القِصاص{8}. (٢/١٦٠) ٥٢١٥- وعن أبي مالك، نحو ذلك{12}. (ز) ٥٢١٦- وعن مقاتل بن حيان -من طريق بُكَيْر بن معروف-، نحو ذلك{8}. (ز) ٥٢١٧- عن ربيعة -من طريق الليث بن سعد- أنه قال في قول الله: <q>﴿ولكم في القصاص حياةٌ يا أولي الألباب لعلكم تتقون﴾</q>: يقول: لَعَلَّكم تَتَّقون محارمَكم، وما نهيتُ بعضكَم فيه عن بعض{8}. (ز) ٥٢١٨- قال مقاتل بن سليمان: <q>﴿لعلكم﴾</q> يعني: لكي <q>﴿تتقون﴾</q> الدماءَ؛ مخافةَ القِصاص{16}. (ز) ٥٢١٩- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهْب- في قوله: <q>﴿لعلكم تتقون﴾</q>، قال: لعلك تتَّقي أن تَقْتُلَهُ فَتُقْتَلَ به{17}٦٣٠. (٢/١٦٠) ٦٣٠ ذَهَب ابنُ جرير (٣/١٢٣) إلى ما ذهب إليه ابن زيد، فقال: «أي: تتقون القصاص، فتنتَهون عن القتل». وقال ابنُ عطية (١/٤٢٨): «تتقون القتل؛ فتسلمون من القصاص، ثم يكون ذلك داعية لأنواع التقوى في غير ذلك؛ فإنّ الله تعالى يثيب على الطاعة بالطاعة». وقال ابنُ كثير (١/١٦٦): «لعلكم تنزجرون فتتركون محارم الله ومآثمه، والتقوى: اسم جامع لفعل الطاعات وترك المنكرات». ",footnotes:1:أخرجه ابن أبي حاتم ١/٢٩٧ ووقع فيه <q>﴿القصاص﴾</q>، وهو خطأ. وقراءة (القصص) قراءة شاذة. ينظر: مختصر الشواذ لابن خالويه ص١٩، والبحر المحيط ٢/١٥. وعزاه السيوطي إلى عبد بن حميد.أخرجه الشافعي في مسنده ٣/٣٠٣، والبيهقي في السنن ٨/٥١.أخرجه ابن أبي حاتم ١/٢٩٧، والبيهقي في سننه ٨/٢٤ من طريق آدم. وعزاه السيوطي إلى آدم.علَّقه ابن أبي حاتم ١/٢٩٧ (عَقِب ١٥٩٤).البُقْيا: اسم من البقاء. لسان العرب (بقي).عزاه السيوطي إلى سفيان بن عيينة.تفسير مجاهد ص٢٢٠، وأخرجه ابن جرير ٣/١٢١.أخرجه ابن أبي حاتم ١/٢٩٨.أخرجه عبد الرزاق ١/٦٨، وابن جرير ٣/١٢١.أخرجه ابن جرير ٣/١٢١. وعزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ٣/١٢٢، وابن أبي حاتم ١/٢٩٨.علَّقه ابن أبي حاتم ١/٢٩٨.أخرجه ابن جرير ٣/١٢٣، وابن أبي حاتم ١/٢٩٨.أخرجه ابن جرير ٣/١٢١، وابن أبي حاتم ١/٢٩٧.أخرجه ابن أبي حاتم ١/٢٩٧.تفسير مقاتل بن سليمان ١/١٥٩.أخرجه ابن جرير ٣/١٢٢.أخرجه ابن جرير ٣/١٢٢.أخرجه ابن أبي حاتم ١/٢٩٨.علَّقه ابن أبي حاتم ١/٢٩٨.أخرجه ابن أبي حاتم ١/٢٩٨.تفسير مقاتل بن سليمان ١/١٥٩.أخرجه ابن أبي حاتم ١/٢٩٨.علَّقه ابن أبي حاتم ١/٢٩٨.أخرجه ابن أبي حاتم ١/٢٩٨.أخرجه ابن أبي حاتم ١/٢٩٨.تفسير مقاتل بن سليمان ١/١٥٩.أخرجه ابن جرير ٣/١٢٢.
2,180," <q>﴿كُتِبَ عَلَیۡكُمۡ إِذَا حَضَرَ أَحَدَكُمُ ٱلۡمَوۡتُ﴾</q> - تفسير ٥٢٢٠- قال مقاتل بن سليمان: <q>﴿كتب عليكم﴾</q> يعني: فُرِض عليكم. نظيرها: <q>﴿كتب عليكم القتال﴾</q> [البقرة:٢١٦]، يعني: فُرِض. نظيرها أيضًا: <q>﴿ما كتبناها عليهم﴾</q> [الحديد:٢٧]، يعني: ما فرضناها عليهم، يعني: الرَّهْبانِيَّة{1}. (ز) <q>﴿إِن تَرَكَ خَیۡرًا﴾</q> - تفسير ٥٢٢١- عن عبد الله بن عباس -من طريق علي بن أبي طلحة- في قوله: <q>﴿إن ترك خيرا﴾</q>، قال: مالًا{2}. (٢/١٦١) ٥٢٢٢- عن عبد الله بن عباس -من طريق عكرمة- في قوله: <q>﴿إن ترك خيرا﴾</q>، قال: الخيرُ: المالُ{3}. (٢/١٦١) ٥٢٢٣- عن أبي العالية -من طريق الربيع بن أنس-، نحو ذلك{4}. (ز) ٥٢٢٤- عن سعيد بن جبير، نحو ذلك{5}. (ز) ٥٢٢٥- عن مجاهد بن جَبْر -من طريق ابن أبي نجيح- قال: الخير في القرآن كلِّه: المال؛ <q>﴿إن ترك خيرًا﴾</q>، <q>﴿لحب الخير﴾</q> [العاديات:٨]، <q>﴿أحببت حب الخير﴾</q> [ص:٣٢]، <q>﴿إن علمتم فيهم خيرا﴾</q> [النور:٣٣]{6}. (٢/١٦١) ٥٢٢٦- عن الضحاك بن مُزاحِم -من طريق الحسن بن يحيى- في قوله: <q>﴿إن ترك خيرًا الوصية﴾</q>، قال: المال، ألا ترى أنه يقول: قال شعيب لقومه: <q>﴿إنِّي أراكُمْ بِخَيْرٍ﴾</q>؟ [هود:٨٤]، يعني: الغِنى{7}. (ز) ٥٢٢٧- عن عطاء بن أبي رباح -من طريق ابن جُرَيْج- أنه تلا: <q>﴿كُتب عليكم إذا حَضر أحدكم الموتُ إن ترك خيرًا﴾</q>، قال: الخيرُ فيما يُرى: المالُ{8}. (ز) ٥٢٢٨- عن قتادة بن دِعامة، في الآية، قال: الخيرُ: المالُ{9}. (٢/١٦٦) ٥٢٢٩- عن عطية العوفي= (ز) ٥٢٣٠- وعبدة، نحو ذلك{5}. (ز) ٥٢٣١- عن إسماعيل السُّدِّيّ -من طريق أسباط- <q>﴿إن تَرك خيرًا الوصية﴾</q>، أمّا <q>﴿خيرًا﴾</q>: فالمالُ{11}. (ز) ٥٢٣٢- عن الربيع بن أنس -من طريق أبي جعفر- <q>﴿إن ترك خيرًا﴾</q>، قال: إن ترك مالًا{11}. (ز) ٥٢٣٣- عن مُقاتِل بن حَيّان -من طريق بُكَيْر بن معروف-، نحو ذلك{4}. (ز) ٥٢٣٤- قال مُقاتِل بن سليمان: <q>﴿إن ترك﴾</q> بعد موته <q>﴿خيرا﴾</q> يعني: المال{1}. (ز) ٥٢٣٥- عن الليث بن سعد -من طريق ابن وهْب- في قول الله: <q>﴿إن ترك خيرا الوصية﴾</q>، قال: الخيرُ: المالُ{15}٦٣١. (ز) ٦٣١ ذَهَبَ ابنُ جرير (٣/١٣٤) وابنُ كثير (٣/١٦٩) إلى ما ذهبتْ إليه الآثارُ مِن أنَّ الخير في الآية: المال؛ مستندَين إلى أقوال أهل التأويل، وكذا اختاره ابنُ عطية (١/٤٣٠)، ولم يذكر مستندًا. <q>﴿إِن تَرَكَ خَیۡرًا﴾</q> - (مقدار المال الذي إذا تركه الرجل لَزِمه حكمُ الآية) ٥٢٣٦- عن عُرْوَة أنّ علي بن أبي طالب دخل على مولًى لهم في الموت، وله سبعمائة درهم أو ستمائة درهم، فقال: ألا أُوصِي؟ قال: لا؛ إنّما قال الله: <q>﴿إن ترك خيرا﴾</q>. وليس لك كثير مال، فَدَعْ مالَك لِوَرَثَتِك{16}. (٢/١٦١) ٥٢٣٧- عن عائشة -من طريق ابن أبى مُلَيْكَة- أنّ رجلًا قال لها: إنِّي أريد أن أُوصِي؟ قالتْ: كم مالُك؟ قال: ثلاثة آلاف. قالتْ: كم عيالك؟ قال: أربعة. قالتْ: قال اللهُ: <q>﴿إن ترك خيرا﴾</q>، وهذا شيء يسير، فاترُكْهُ لعيالك؛ فهو أفضل{17}. (٢/١٦٢) ٥٢٣٨- عن عبد الله بن عتبة أو غَنيَّةَ{18} -الشَّكُّ من ابن جرير-: أنّ رجلًا أراد أن يوصي وله ولد كثير، وترك أربعمائة دينار، فقالت عائشة: ما أرى فيه فَضْلًا{19}. (ز) ٥٢٣٩- عن عبد الله بن عباس: في قوله: <q>﴿إن ترك خيرا الوصية﴾</q>، قال: مَن لَمْ يترُك ستين دينارًا لم يترك خيرًا{20}. (٢/١٦١) ٥٢٤٠- عن عبد الله بن عباس -من طريق طاووس- قال: إذا ترك الميتُ سبعمائة درهم فلا يوصي{21}. (٢/١٦٢) ٥٢٤١- عن إبراهيم النَّخَعِيّ -من طريق أبان- في قوله تعالى: <q>﴿إن ترك خيرا﴾</q>، قال: ألفُ درهم إلى خمسمائة درهم{22}. (ز) ٥٢٤٢- عن أبي مِجْلَز، قال: الوصيةُ على مَن ترك خيرًا{20}. (٢/١٦٢) ٥٢٤٣- عن قتادة بن دِعامة، في الآية، قال: الخيرُ: المال، كان يُقال: ألْفٌ فما فوق ذلك{20}. (٢/١٦٦) ٥٢٤٤- عن محمد ابن شهاب الزهري -من طريق مَعْمَر- قال: جعل الله الوصية حَقًّا، مِمّا قَلَّ مِنهُ أو كَثُر{25}٦٣٢. (٢/١٦٢) ٦٣٢ رجَّحَ ابنُ جرير (٣/١٣٨ بتصرف) قولَ الزهري مستندًا إلى العموم، فقال: «أوْلى هذه الأقوال بالصواب ما قال الزهري؛ لأنّ قليلَ المال وكثيره يقع عليه اسمُ»خير«، ولم يحُدَّ اللهُ ذلك بحدٍّ، ولا خصَّ منه شيئًا، فكلّ مَن حَضَرَتْهُ مَنِيَّته وعنده مالٌ -قلّ ذلك أو كثر- فواجبٌ عليه أن يوصي منه». <q>﴿ٱلۡوَصِیَّةُ لِلۡوَ ٰ⁠لِدَیۡنِ وَٱلۡأَقۡرَبِینَ﴾</q> - تفسير ٥٢٤٥- قال ابن مسعود: الوصيَّة للأخَلِّ فالأَخَلِّ{26}. (ز) ٥٢٤٦- عن عبيد الله بن عبد الله بن معمر قاضي البصرة -من طريق محمد بن سيرين- قال: مَن أوْصى فسمّى أعْطَيْنا من سمّى، وإن قال: ضعها حيث أمر الله. أعطيناها قرابتَه{27}. (٢/١٦٣) ٥٢٤٧- عن سعيد بن المسيب -من طريق قتادة- قال: مَن أوْصى وسمّى أعْطَيْنا مَن سَمّى{28}. (٢/١٦٤) ٥٢٤٨- عن مجاهد بن جبر -من طريق ابن أبي نجيح- قال: كان الميراثُ للولد، والوصيةُ للوالدين والأقربين{29}. (ز) ٥٢٤٩- عن طاووس -من طريق ابن طاووس- قال: مَن أوْصى لقوم وسَمّاهم، وترك ذوي قرابته محتاجين؛ انتُزِعت منهم، ورُدَّت على قرابته{30}. (٢/١٦٤) ٥٢٥٠- قال مقاتل بن سليمان: <q>﴿الوصية للوالدين والأقربين بالمعروف﴾</q>، يعني: تفضيل الوالدين على الأقربين في الوصية، ولْيُوصِ للأقربين بالمعروف، والذين لا يرثون{1}. (ز) <q>﴿بِٱلۡمَعۡرُوفِ﴾</q> - تفسير ٥٢٥١- عن سعد بن مالك، قال: جاءني النبي ﷺ يَعُودُني، فقلت: يا رسول الله، أُوصِي بمالي كلِّه؟ قال: «لا». قلت: فالشَّطْرُ؟ قال: «لا». قلت: فالثُّلُث؟ قال: «الثُّلُث، والثُّلُث كثير؛ إنّك أن تَدَعَ ورَثَتَك أغنياءَ خيرٌ مِن أن تَدَعَهم عالةً يَتَكَفَّفون الناسَ بأيديهم»{32}. (ز) ٥٢٥٢- عن عبد الله بن عباس -من طريق عروة- قال: لو أنّ الناس غَضُّوا مِن الثُّلُث إلى الرُّبُع؛ فإنّ رسول الله ﷺ قال: «الثُّلُث، والثُّلُث كثير»{33}. (ز) ٥٢٥٣- قال علي بن أبي طالب: لَأَن أُوصي بالخُمُس أحبُّ إلَيَّ مِن أنْ أُوصِي بالرُّبُع، ولَأَن أُوصِي بالرُّبُع أحبُّ إلَيَّ مِن أنْ أُوصِي بالثُّلُث، فمَن أوْصى بالثُّلُث فَلَمْ يَتْرُكْ{34}. (ز) ٥٢٥٤- عن الحسن البصري -من طريق قتادة- قال: إذا أوْصى في غير أقاربه بالثُّلُث جاز لهم ثُلُثُ الثُّلُث، ويُرَدُّ على أقاربه ثُلُثا الثُّلُث{35}. (٢/١٦٤) ٥٢٥٥- وعن الحسن البصري: يُوصي بالسُّدُس، أو الخُمُس، أو الرُّبُع{34}. (ز) ٥٢٥٦- وعن عامر الشعبي: إنّما كانوا يُوصون بالخُمُس أو الرُّبُع{34}. (ز) <q>﴿حَقًّا عَلَى ٱلۡمُتَّقِینَ ۝١٨٠﴾</q> - تفسير ٥٢٥٧- عن سعيد بن جُبَيْر -من طريق عطاء بن دينار- في قول الله: <q>﴿بالمعروف حَقًّا عَلى المُتَّقِينَ﴾</q>، يقول: تلك الوصية حقٌّ على المتقين{38}. (ز) ٥٢٥٨- عن مقاتل بن حيان -من طريق بُكَيْر بن معروف- قوله: <q>﴿حَقًّا عَلى المُتَّقِينَ﴾</q>، يعني: المؤمنين{38}. (ز) ٥٢٥٩- قال مقاتل بن سليمان: يقول الله ﷿: تلك الوصية <q>﴿حَقًّا عَلى المُتَّقِينَ﴾</q>، فمَن لَمْ يُوصِ لقرابته عند موته فقد خَتَم عملَه بالمعصية{1}. (ز) <q>﴿حَقًّا عَلَى ٱلۡمُتَّقِینَ ۝١٨٠﴾</q> - النسخ في الآية ٥٢٦٠- عن إبراهيم [النخعي] -من طريق الحسن بن عبيد الله-= (ز) ٥٢٦١- أنه ذُكِر عنده طلحة= (ز) ٥٢٦٢- والزبير، فقيل: كانا يُشَدِّدان في الوصية. فقال: وما عليهما ألّا يفعلا، تُوُفِّي النبي ﷺ فما أوصى، وأوصى أبو بكر، فإن أوصى فحَسَن، وإن لم يوصِ فلا بأس{41}. (ز) ٥٢٦٣- عن علي= (ز) ٥٢٦٤- وعائشة: أنّ الآية منسوخة، ولا تجب الوصية، فإن أوصى فحَسَن، وإن لم يوصِ فلا شيء عليه{42}. (ز) ٥٢٦٥- عن أبي موسى الأشعري: أنّ هذه الآية منسوخةٌ، نَسَخَتْها آيةُ الميراث{43}. (ز) ٥٢٦٦- عن محمد بن سيرين، قال: خطب ابنُ عباس، فقرأ سورة البقرة، فبيَّن ما فيها، حتى أتى على هذه الآية: <q>﴿إن ترك خيرًا الوصية للوالدين والأقربين﴾</q>، فقال: نُسِخَت هذه الآية{44}. (٢/١٦٤) ٥٢٦٧- عن عبد الله بن عباس -من طريق عطاء- في قوله: <q>﴿الوصية للوالدين والأقربين﴾</q>، قال: كان ولد الرجل يَرِثُونه، وللوالِدَين والأقربين الوصيةُ، فنَسَخَها: <q>﴿للرجال نصيب مما ترك الوالدان والأقربون﴾</q> الآية [النساء:٧]{45}. (٢/١٦٤) ٥٢٦٨- عن عبد الله بن عباس -من طريق علي بن أبي طلحة- قال: كان لا يَرِثُ مع الوالدين غيرُهما إلا وصيَّة الأقرَبين، فأنزل الله آية الميراث، فبيَّن ميراث الوالِدَيْن، وأقَرَّ وصيَّة الأقربين في ثُلُثِ مال الميت{46}. (٢/١٦٥) ٥٢٦٩- عن عبد الله بن عباس -من طريق يزيد النَّحْوِيِّ، عن عكرمة- في قوله: <q>﴿إن ترك خيرا الوصية للوالدين والأقربين﴾</q>، قال: فكانت الوصية كذلك، حتى نسختها آية الميراث{47}. (٢/١٦٥) ٥٢٧٠- عن عبد الله بن عباس -من طريق ابن جُرَيْج، عن عكرمة- في الآية، قال: نَسَخ مَن يَرِثُ، ولَمْ يَنسَخ الأقربين الذين لا يرثون{48}٦٣٣. (٢/١٦٥) ٦٣٣ علَّقَ ابنُ كثير (١/١٦٨-١٦٩) على قول ابن عباس، ومَن تبعه كالحسن، ومسروق: إنّ الوصيّة منسوخة فيمن يرث، ثابتة فيمن لا يرث. بقوله: «على قول هؤلاء لا يُسَمّى هذا نسخًا في اصطلاحنا المتأخر؛ لأنّ آية المواريث إنما رَفَعَتْ حكمَ بعض أفراد ما دلَّ عليه عموم آية الوصاية؛ لأن الأقربين أعمّ مِمَّن يرث ولا يرث، فرُفِع حكمُ مَن يَرِثُ بما عُيِّنَ له، وبقي الآخرُ على ما دَلَّت عليه الآيةُ الأولى، وهذا إنّما يَتَأَتّى على قول بعضهم: إنّ الوصاية في ابتداء الإسلام إنما كانت نَدْبًا حتى نُسِخَت. فأما من يقول: إنها كانت واجبة -وهو الظاهر من سياق الآية-؛ فيتعين أن تكون منسوخة بآية الميراث، كما قاله أكثر المفسرين والمعتبرين من الفقهاء، فإنّ وجوب الوصيّة للوالدين والأقربين الوارثين منسوخ بالإجماع، بل منهيٌّ عنه للحديث المتقدم: «إن الله قد أعطى كلَّ ذي حَقٍّ حَقَّه؛ فلا وصية لوارث». فآية الميراث حكم مستقل، ووجوب من عند الله لأهل الفروض والعصبات، رفع بها حُكْمَ هذه بالكُلِّيَّة». ٥٢٧١- عن عبد الله بن عمر -من طريق عبد الله بن بدر- أنّه سُئِل عن هذه الآية: <q>﴿الوصية للوالدين والأقربين﴾</q>. قال: نَسَخَتْها آية الميراث{49}. (٢/١٦٥) ٥٢٧٢- عن مسروق -من طريق مسلم-: أنّه حَضَر رجلًا يُوصي بأشياء لا تنبغي، فقال له مسروق: إنّ الله قد قسم بينكم، فَأحْسَنَ القَسْمَ، وإنّه مَن يَرْغَب برأيه عن رَأْيِ الله يَضِلُّ؛ أوصِ لذي قرابتك مِمَّن لا يرثك، ثم دَعِ المالَ على ما قَسَمَه اللهُ عليه{50}. (ز) ٥٢٧٣- عن شُرَيح -من طريق قتادة- في الآية، قال: كان الرجلُ يوصي بماله كلِّه، حتى نزلت آية الميراث{48}. (٢/١٦٦) ٥٢٧٤- عن سعيد بن المسيب= (ز) ٥٢٧٥- وسعيد بن جبير= (ز) ٥٢٧٦- وإبراهيم النَّخَعِيّ: أنّ هذه الآية منسوخةٌ، نَسَخَتْها آيةُ الميراث{43}. (ز) ٥٢٧٧- عن أبي العالية -من طريق الربيع بن أنس- قوله: <q>﴿الوصية للوالدين والأقربين﴾</q>، قال: نَسَخَ الوالدين، فألحقهما بأهل الميراث، وصارت الوصية لأهل القرابة الذين لا يَرِثُون{38}. (ز) ٥٢٧٨- وعن سعيد بن جبير= (ز) ٥٢٧٩- والضحاك بن مزاحم= (ز) ٥٢٨٠- والحسن البصري= (ز) ٥٢٨١- ومحمد ابن شهاب الزهري، نحو ذلك{54}. (ز) ٥٢٨٢- عن الربيع بن أنس -من طريق أبي جعفر-= (ز) ٥٢٨٣- ومقاتل بن حيان -من طريق بكير بن معروف-، نحو ذلك{38}. (ز) ٥٢٨٤- عن جابر بن زيد: في رجلٍ أوْصى لغير ذي قرابة، وله قرابةٌ محتاجون، قال: يُرَدُّ ثُلُثا الثُّلُثِ عليهم، وثُلُثُ الثُّلُثِ لِمَن أوْصى له به{56}. (ز) ٥٢٨٥- عن عطاء بن أبي ميمونة، قال: سألت مسلم بن يَسار= (ز) ٥٢٨٦- والعلاء بن زياد عن قول الله: <q>﴿إن ترك خيرًا الوصيةُ للوالدين والأقربين﴾</q>. قالا: في القرابة{57}. (ز) ٥٢٨٧- عن مجاهد بن جبر، في الآية، قال: كان الميراث للولد، والوصية للوالدين والأقربين، فهي منسوخة{20}. (٢/١٦٦) ٥٢٨٨- عن مجاهد بن جبر: نسخها: <q>﴿يوصيكم الله في أولادكم للذكر مثل حظ الأنثيين﴾</q> [النساء:١١]{59}. (ز) ٥٢٨٩- عن الضحاك بن مُزاحِم -من طريق جُوَيْبِر- أنّه كان يقول: مَن مات ولم يُوصِ لِذي قرابته فقد خَتَم عملَه بمعصية{50}. (ز) ٥٢٩٠- عن الضحاك بن مُزاحِم -من طريق عبيد- قال: لا تجوز وصيةٌ لوارث، ولا يُوصي إلا لذي قرابة، فإن أوصى لغير ذي قرابة فقد عمل بمعصية؛ إلا أن لا يكون قرابة، فيوصي لفقراء المسلمين{50}. (ز) ٥٢٩١- عن الضحاك بن مزاحم= (ز) ٥٢٩٢- ومحمد بن سيرين= (ز) ٥٢٩٣- وعطاء: أنّ هذه الآية منسوخة، نَسَخَتْها آيةُ الميراث{5}. (ز) ٥٢٩٤- عن طاووس، في الآية: أنّ وجوبها صار منسوخًا في حقّ الأقارب الذين يَرِثون، وبقي وجوبها في حق الذين لا يَرِثُون من الوالدين والأقارب{63}. (ز) ٥٢٩٥- عن عكرمة مولى ابن عباس= (ز) ٥٢٩٦- والحسن البصري -من طريق يزيد النحوي- قالا: <q>﴿إن تَرَك خيرًا الوصية للوالدين والأقربين﴾</q>، فكانت الوصية كذلك، حتى نَسَخَتْها آيةُ الميراث{64}. (ز) ٥٢٩٧- عن الحسن البصري -من طريق عَبّاد بن منصور- قوله: <q>﴿كتب عليكم إذا حضر أحدكم الموت﴾</q>، فقال: نعم، الوصيةُ حقٌّ على كل مسلم؛ أن يُوصِي إذا حضر الموتُ بالمعروفِ غيرِ المنكر{65}. (ز) ٥٢٩٨- عن الحسن البصري -من طريق يونس- في قوله ﷿: <q>﴿إذا حضر أحدكم الموت إن ترك خيرا الوصية للوالدين والأقربين﴾</q>، قال: كانت الوصية للوالدين والأقربين، فنَسَخ من ذلك <q>﴿للوالدين﴾</q>، وأثبت لهما نصيبهما في سورة النساء [١١]، ونَسَخ من الأقربين كُلَّ وارث، وبقيت الوصية للأقربين الذين لا يرثون{66}. (ز) ٥٢٩٩- عن قتادة بن دِعامة -من طريق هَمّام- قال: <q>﴿إذا حضر أحدكم الموت إن ترك خيرًا الوصية للوالدين والأقربين بالمعروف حقًّا على المتقين﴾</q>، أمر أن يُوصِي لوالديه وأقاربه، ثم نسخ بعد ذلك في سورة النساء [١١]، فجعل للوالدين نصيبًا معلومًا، وأَلْحَقَ لِكُلِّ ذي ميراث نصيبَه منه، وليست لهم وصية، فصارت الوصية لمن لا يَرِثُ من قريبٍ وغيره{67}. (٢/١٦٦) ٥٣٠٠- عن المُعْتَمِر، قال: سمعتُ أبي قال: زَعَم قتادة: أنّه نَسَخَتْ آيتا المواريث في سورة النساء الآيةَ في سورة البقرةِ في شأن الوصية{68}. (ز) ٥٣٠١- عن محمد ابن شهاب الزهري: قوله تعالى: <q>﴿إن ترك خيرا الوصية للوالدين والأقربين﴾</q> نُسِخَتْ بآية الميراث{69}. (ز) ٥٣٠٢- عن إسماعيل السدي -من طريق أسباط- <q>﴿كُتب عليكم إذا حَضر أحدكم الموت إن ترك خيرًا الوصيةُ للوالدين والأقربين﴾</q>: أمّا <q>﴿الوالدين والأقربين﴾</q> فيوم نزلت هذه الآية كان الناس ليس لهم ميراث معلومٌ، إنما يُوصِي الرجلُ لوالده ولأهله فيَقْسِم بينهم، حتى نسختها النساء [١١]، فقال: <q>﴿يُوصِيكُمُ اللَّهُ فِي أوْلادِكُمْ﴾</q>{70}. (ز) ٥٣٠٣- عن زيد بن أسلم -من طريق القاسم بن عبد الله- أنّه قال: <q>﴿إن ترك خيرا الوصية للوالدين والأقربين﴾</q>، فنَسَخَتْها آيةُ الميراث{71}. (ز) ٥٣٠٤- عن الربيع بن أنس -من طريق أبي جعفر- قوله: <q>﴿كتب عليكم إذا حَضر أحدكم الموتُ إنْ تَرك خيرًا الوصية للوالدين والأقربين بالمعروف﴾</q>، قال: كان هذا من قبل أن تنزل سورة النساء، فلَمّا نزلتْ آيةُ الميراث نَسخَ شأنَ الوالِدَين، فألحقهما بأهل الميراث، وصارتِ الوَصِيَّةُ لأهل القرابة الذين لا يَرِثُون{72}. (ز) ٥٣٠٥- عن مقاتل بن حَيّان -من طريق بُكَيْر بن معروف-: أنّ هذه الآية منسوخة، نَسَخَتْها آيةُ الميراث{4}. (ز) ٥٣٠٦- قال مقاتل بن سليمان: ثم نزلت آية الميراث بعد هذه الآية، فنسخت <q>﴿للوالدين﴾</q>، وبَقِيت الوصية للأقربين الذين لا يَرِثون، ما بينه وبين ثلث ما له{1}. (ز) ٥٣٠٧- عن مالك بن أنس-من طريق يحيى- في هذه الآية: إنّها منسوخة. قول الله تبارك وتعالى: <q>﴿إن ترك خيرا الوصية للوالدين والأقربين﴾</q> نَسَخها ما نزل من قسمة الفرائض في كتاب الله ﷿{75}. (ز) ٥٣٠٨- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهْب- في قوله: <q>﴿إن تَرَك خيرًا الوصية للوالدين والأقربين﴾</q> الآية، قال: فنَسَخ اللهُ ذلك كلَّه، وفرضَ الفرائض{76}٦٣٤. (ز) ٦٣٤ ذَهَب ابنُ جرير (٣/١٢٤) إلى أنّ الآية محكمة غير منسوخة، وفرض على مَن ترك مالًا من المؤمنين الوصية للوالدين والأقربين الذين لا يرثونه. واستدل بأمرين: الأول: عدم الدليل على النسخ، حيث قال: «وإذا كان في نَسْخ ذلك تنازعٌ بين أهل العلم؛ لم يكن لنا القضاءُ عليه بأنه منسوخٌ إلا بحجة يجب التسليم لها». والثاني: إمكان الجمع بين آيتي الوصية والمواريث، قال: «فغيرُ مستحيلٍ اجتماعُ حكمِ هذه الآية وحكمِ آية المواريث في حال واحدةٍ». وذَهَب ابنُ كثير (١/١٦٧-١٦٩) مستندًا إلى السنة، وأقوال السلف، والإجماع إلى أنّها منسوخة بآية المواريث، وقال: «كانت الوصية للوالدين والأقربين واجبة -على أصح القولين- قبل نزول آية المواريث، فلما نزلت آيةُ الفرائض نسخت هذه، وصارت المواريث المُقَدَّرة فريضةً من الله، يأخذها أهلوها حتمًا من غير وصية ولا تحمل مِنّة المُوصِي، ولهذا جاء في الحديث الذي في السنن وغيرها عن عمرو بن خارجة قال: سمعت رسول الله ﷺ يخطب، وهو يقول: «إنّ الله قد أعطى كلَّ ذي حق حَقَّه، فلا وصية لوارث»». وقال بعد ذلك: «أمّا من يقول: إنها كانت واجبة -وهو الظاهر من سياق الآية- فيتعين أن تكون منسوخة بآية الميراث، كما قاله أكثر المفسرين والمعتبرين من الفقهاء، فإنّ وجوب الوصية للوالدين والأقربين الوارثين منسوخ بالإجماع، بل منهي عنه للحديث المتقدم: «إن الله قد أعطى كل ذي حق حقه؛ فلا وصية لوارث». فآية الميراث حكم مستقلّ، ووجوب من عند الله لأهل الفروض والعصبات، رفع بها حكم هذه بالكلية». <q>﴿حَقًّا عَلَى ٱلۡمُتَّقِینَ ۝١٨٠﴾</q> - آثار متعلقة بالآية ٥٣٠٩- عن عمرو بن خارجة: أنّ النبي ﷺ خطبهم على راحلته، فقال: «إنّ الله قد قَسَم لكلِّ إنسان نصيبَه من الميراث؛ فلا تجوز لوارثٍ وصيةٌ»{77}. (٢/١٦٦) ٥٣١٠- عن أبي أمامة الباهلي: سمعتُ رسول الله ﷺ في حَجَّة الوداع في خطبته يقول: «إنَّ الله قد أعطى كلَّ ذي حق حقَّه؛ فلا وصية لوارث»{78}. (٢/١٦٦) ٥٣١١- عن الحسن، قال: قال رسول الله ﷺ: «لا وصية لوارث، إلا أن تُجِيزَه الوَرَثَة»{79}. (٢/١٦٧) ٥٣١٢- عن ابن عمر، قال: سمعتُ رسول الله ﷺ يقول: «ما حقُّ امرئ مسلم تَمُرُّ عليه ثلاثُ ليالٍ إلا وصيته عنده». قال ابن عمر: فما مرت عَلَيَّ ثلاثٌ قطُّ إلا ووصيتي عندي{80}. (٢/١٦٣) ٥٣١٣- عن قتادة، قال: قال رسول الله ﷺ: «أيها الناس، ابتاعوا أنفسكم من ربكم، ألا إنَّه ليس لامرئ شيء، ألا لا أعْرِفَنَّ امرءًا بَخِلَ بَحَقِّ الله عليه، حتى إذا حضَره الموت أخَذ يُدَعْدِع مالَه ههنا وههنا».= (ز) ٥٣١٤- ثم يقول قتادة: ويلك، يا ابن آدم، كنتَ بخيلًا مُمسكًا، حتى إذا حضرك الموتُ أخذت تُدَعْدِعُ مالك وتُفَرِّقه، يا ابن آدم، اتقِ الله، ولا تجمع إساءتين في مالك؛ إساءة في الحياة، وإساءة عند الموت، انظر إلى قرابتك الذين يحتاجون ولا يرِثون؛ فأوصِ لهم من مالك بالمعروف{81}. (٢/١٦٣) ٥٣١٥- عن نافع: أنّ ابنَ عمر لم يُوصِ، وقال: أمّا مالي فالله أعلمُ ما كنت أصنع فيه في الحياة، وأما رِباعي فما أحب أن يَشْرَك ولدي فيها أحد{82}. (ز) ٥٣١٦- قال عَزْرَةُ -يعني: ابن ثابت- لربيع بن خُثيم: أوْصِ لي بمصحفك. قال: فنظر إلى ابنه، فقال: <q>﴿وأُولُو الأرْحامِ بَعْضُهُمْ أوْلى بِبَعْضٍ فِي كِتابِ اللَّهِ﴾</q> [الأنفال:٧٥]{82}. (ز) ٥٣١٧- عن مغيرة= (ز) ٥٣١٨- قال: العَجَبُ لأبي العالية، أعتقته امرأةٌ من بني رياح، وأوصى بماله لبني هاشم{50}. (ز) ٥٣١٩- وعن الشعبي -من طريق جرير، عن رجل- قال: لم يكن له ذاك، ولا كرامة{50}. (ز) ",footnotes:1:تفسير مقاتل بن سليمان ١/١٥٩.أخرجه ابن جرير ٣/١٣٤، وابن أبي حاتم ١/٢٩٩. وعزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ٣/١٣٤.أخرجه ابن أبي حاتم ١/٢٩٩.علَّقه ابن أبي حاتم ١/٢٩٩.أخرجه ابن جرير ٣/١٣٥، وفي تفسير مجاهد ص٢٢٠ مقتصرًا على قوله: <q>﴿إن ترك خيرا﴾</q>، يعني: مالًا.أخرجه ابن جرير ٣/١٣٥. وعلَّقه ابن أبي حاتم ١/٢٩٩.أخرجه ابن جرير ٣/١٣٦. وعلَّقه ابن أبي حاتم ١/٢٩٩.علّقه ابن أبي حاتم ١/٢٩٩. وذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ١/١٩٨-. وعزاه السيوطي إلى عبد بن حميد.علَّقه ابن أبي حاتم ١/٢٩٩.أخرجه ابن جرير ٣/١٣٥، وابن أبي حاتم ١/٢٩٩ (عَقِب ١٦٠٠).أخرجه ابن جرير ٣/١٣٥، وابن أبي حاتم ١/٢٩٩ (عَقِب ١٦٠٠).أخرجه ابن أبي حاتم ١/٢٩٩.تفسير مقاتل بن سليمان ١/١٥٩.أخرجه عبد الله بن وهْب في الجامع - تفسير القرآن ٢/١٥٨-١٥٩ (٣٢٨).أخرجه عبد الرزاق في تفسيره ١/٦٨، وفي مصنفه (١٦٣٥١)، وسعيد بن منصور (٢٥١- تفسير)، وابن أبي شيبة ١١/٢٠٨، وابن جرير ٣/١٣٦-١٣٧، وابن أبي حاتم ١/٢٩٨، والحاكم ٢/٢٧٣-٢٧٤، والبيهقي ٦/٢٧٠. وعزاه السيوطي إلى الفريابي، وعبد بن حميد، وابن المنذر.أخرجه سعيد بن منصور (٢٤٨ - تفسير)، وابن أبي شيبة ١١/٢٠٨، والبيهقي ٦/٢٠٨، ٢٧٠. وعزاه السيوطي إلى ابن المنذر.كذا في مطبوعة تفسير ابن جرير، وفي بعض النسخ: عيينة أو عتبة، والأثر رواه عبد الرزاق في المصنف -كما سيأتي في تخريج الأثر- قال: أخبرنا الثوري، عن منصور بن صفية قال: حدثنا عبد الله بن عبيد بن عمير، أن عائشة سئلت عن رجل مات وله أربعمائة دينار، وله عدة من الولد، فقالت عائشة: ما في هذا فضل عن ولده. وهو طريق ابن جرير نفسه، ومنه يتبين أنّ الراوي الذي شك فيه ابن جرير هو عبد الله بن عبيد، والأقرب أن يشك بأنه عبد الله بن عيينة أو عتبة، أما غنية فبعيد.أخرجه عبد الرزاق في المصنف ٩/٦٣ (١٦٣٥٤)، وابن جرير ٣/١٣٧ واللفظ له.عزاه السيوطي إلى عبد بن حميد.أخرجه سعيد بن منصور (٢٥٠- تفسير)، والبيهقي ٦/٢٧٠. وعزاه السيوطي إلى عبد الرزاق.أخرجه عبد الرزاق ١/٦٩، وابن جرير ٣/١٣٨.عزاه السيوطي إلى عبد بن حميد.عزاه السيوطي إلى عبد بن حميد.أخرجه عبد الرزاق ١/٦٨، وابن جرير ٣/١٣٨. وعزاه السيوطي إلى عبد بن حميد.تفسير الثعلبي ٢/٥٧، وتفسير البغوي ١/١٩٣، وعقّبا على الأثر بقولهما: أي: الأحوج، فالأحوج.أخرجه عبد الرزاق (١٦٤٣٠). وعزاه السيوطي إلى عبد بن حميد.أخرجه عبد الرزاق (١٦٤٣٤). وعزاه السيوطي إلى عبد بن حميد.تفسير مجاهد ص٢٢١.أخرجه عبد الرزاق (١٦٤٢٦، ١٦٤٢٧). وعزاه السيوطي عبد بن حميد.تفسير مقاتل بن سليمان ١/١٥٩.أخرجه البخاري ٤/٣ (٢٧٤٢، ٢٧٤٤)، ٥/٦٨ (٣٩٣٦)، ٥/١٧٨ (٤٤٠٩)، ٧/٦٢ (٥٣٥٤)، ٧/١١٨ (٥٦٥٩)، ومسلم ٣/١٢٥٠-١٢٥٣ (١٦٢٨). وأورده الثعلبي ٢/٦٠.أخرجه البخاري ٤/٣ (٢٧٤٣)، ومسلم ٣/١٢٥٣ (١٦٢٩).تفسير البغوي ١/١٩٣.أخرجه عبد الرزاق (١٦٤٣٣). وعزاه السيوطي عبد بن حميد.تفسير البغوي ١/١٩٣.تفسير البغوي ١/١٩٣.أخرجه ابن أبي حاتم ١/٣٠٠.أخرجه ابن أبي حاتم ١/٣٠٠.تفسير مقاتل بن سليمان ١/١٥٩.أخرجه عبد الرزاق ١/٦٨، وابن جرير ٣/١٣٤.تفسير الثعلبي ٢/٥٧.علّقه ابن أبي حاتم ١/٢٩٩.أخرجه سعيد بن منصور (٢٥٢- تفسير)، وابن جرير ٣/١٣١، والحاكم ٢/٢٧٣، والبيهقي ٦/٢٦٥، ٧/٤٢٧. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي داود.أخرجه النحاس في ناسخه ص٨٨-٨٩، وابن أبي حاتم ١/٢٩٩. وعزاه السيوطي إلى أبي داود في الناسخ، وابن المنذر.أخرجه ابن جرير ٣/١٢٩-١٣٠. وعزاه السيوطي إلى ابن أبي حاتم.أخرجه أبو داود (٢٨٦٩)، والبيهقي ٦/٢٦٥. وعزاه السيوطي إلى أبي داود في ناسخه.أخرجه ابن جرير ٣/١٢٨.أخرجه ابن أبي شيبة ١١/٢٠٩، وابن جرير ٣/١٣١-١٣٢، والبيهقي ٦/٢٦٥. وعزاه السيوطي إلى وكيع، وعبد بن حميد، وابن المنذر.أخرجه ابن جرير ٣/١٢٥.أخرجه ابن جرير ٣/١٢٨.علّقه ابن أبي حاتم ١/٢٩٩.أخرجه ابن أبي حاتم ١/٣٠٠.علَّقه ابن أبي حاتم ١/٣٠٠.أخرجه ابن أبي حاتم ١/٣٠٠.أخرجه ابن جرير ٣/١٢٧.أخرجه ابن جرير ٣/١٣٠.عزاه السيوطي إلى عبد بن حميد.علَّقه النحاس في الناسخ والمنسوخ ١/٤٨٣.أخرجه ابن جرير ٣/١٢٥.أخرجه ابن جرير ٣/١٢٥.علَّقه ابن أبي حاتم ١/٢٩٩.تفسير الثعلبي ٢/٥٧، وتفسير البغوي ١/١٩٢.أخرجه الدارمي في سننه ٢/٥١١، وابن جرير ٣/١٣٢.أخرجه ابن أبي حاتم ١/٢٩٨.أخرجه سعيد بن منصور في سننه (ت: سعد آل حميد) ٢/٦٥٥ (٢٤٧)، والدارمي في سننه ٣/٢٠٦٤ (٣٣٠٦) مختصرًا. وأخرج نحوه ابن جرير ٣/١٢٩ من طريق إسماعيل المكي، كما أخرج ٣/١٢٩ من طريق مبارك بن فضالة بلفظ: نَسَخ الوالدين، وأثبتَ الأقربين الذين يُحرَمون ولا يَرِثون. وعلَّقه ابن أبي حاتم ١/٢٩٩.أخرجه الدارمي في سننه ٣/٢٠٦٣ (٣٣٠٤). وعلّقه ابن أبي حاتم ١/٣٠٠. وعزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ٣/١٣٢. وعلّقه ابن أبي حاتم ١/٢٩٩ (عَقِب ١٦٠٤).الناسخ والمنسوخ للزهري ص٢٠. وعلَّقه ابن أبي حاتم ١/٢٩٩.أخرجه ابن جرير ٣/١٣٣، وابن أبي حاتم ١/٢٩٩ (عَقِب ١٦٠٤).أخرجه عبد الله بن وهب في الجامع - تفسير القرآن ٣/٦٦ (١٤٨). وعلّقه ابن أبي حاتم ١/٢٩٩.أخرجه ابن جرير ٣/١٣٠، وابن أبي حاتم ١/٢٩٩ (عَقِب ١٦٠٤).أخرجه ابن أبي حاتم ١/٢٩٩.تفسير مقاتل بن سليمان ١/١٥٩.أخرجه مالك في الموطأ (ت: د. بشار عواد) ٢/٣١٤ (٢٢٢٤).أخرجه ابن جرير ٣/١٣١.أخرجه أحمد ٢٩/٢١٢-٢١٥، ٢١٧ (١٧٦٦٤، ١٧٦٦٥، ١٧٦٦٦، ١٧٦٦٩، ١٧٦٧٠)، ٢٩/٦٢٢-٦٢٥ (١٨٠٨١، ١٨٠٨٢، ١٨٠٨٣، ١٨٠٨٦، ١٨٠٨٧)، والترمذي ٤/١٩٩-٢٠٠ (٢٢٥٤)، والنسائي ٦/٢٤٧ (٣٦٤٢)، وابن ماجه ٤/١٦-١٧ (٢٧١٢). قال الترمذي: «حديث حسن صحيح».أخرجه أحمد ٣٦/٦٢٨ (٢٢٢٩٤)، وأبو داود ٤/٤٩٢ (٢٨٧٠)، ٥/٤١٧ (٣٥٦٥)، والترمذي ٤/١٩٨-١٩٩ (٢٢٥٣)، وابن ماجه ٤/١٨ (٢٧١٣). قال الترمذي: «حديث حسن». وقال ابن القيسراني في ذخيرة الحفاظ ١/٥٨٥: «وهذا من أفراد إسماعيل، وحيد حديثه». وقال الذهبي في تنقيح التحقيق ٢/١٥٧: «حديث ابن عياش صحيح، خرّجه أحمد». وقال ابن حجر في الفتح ٥/٣٧٢: «في إسناده إسماعيل بن عياش، وقد قوّى حديثَه عن الشاميين جماعةٌ من الأئمة». وقال الألباني في الإرواء (٦/٨٨): «إسناده حسن».عزاه السيوطي إلى عبد بن حميد مرسلًا. ومراسيل الحسن من أوهى المراسيل كما في الموقظة للذهبي ص٤٠. وقد أخرجه الدارقطني ٤/١٥٢ من طريق إسماعيل بن مسلم عن الحسن، عن عمرو بن خارجة، به مرفوعًا.أخرجه البخاري ٤/٢ (٢٧٣٨) بلفظ: ليلتين، ومسلم ٣/١٢٤٩، ١٢٥٠ (١٦٢٧) واللفظ له.أخرجه عبد الرزاق ٩/٦٧ (١٦٣٦٨) عن قتادة مرسلًا. ومراسيله من أوهى المراسيل، بل هي أوهى من مراسيل الحسن البصري، كما في الموقظة للذهبي ص٤٠.أخرجه ابن جرير ٣/١٣٣.أخرجه ابن جرير ٣/١٣٣.أخرجه ابن جرير ٣/١٢٥.أخرجه ابن جرير ٣/١٢٥.
2,181," <q>﴿فَمَنۢ بَدَّلَهُۥ بَعۡدَ مَا سَمِعَهُۥ فَإِنَّمَاۤ إِثۡمُهُۥ عَلَى ٱلَّذِینَ یُبَدِّلُونَهُۥۤۚ إِنَّ ٱللَّهَ سَمِیعٌ عَلِیمࣱ ۝١٨١﴾</q> - تفسير ٥٣٢٠- عن عبد الله بن عباس -من طريق علي بن أبي طلحة- في قوله: <q>﴿فمن بدله بعد ما سمعه فإنما إثمه على الذين يبدلونه﴾</q>: وقد وقع أجرُ الموصي على الله، وبَرِئ من إثمه، وإن كان أوصى في ضِرارٍ لم تَجُزْ وصيتُه، كما قال: <q>﴿غير مضار﴾</q> [النساء:١٢]{1}. (٢/١٦٧) ٥٣٢١- عن سعيد بن جبير -من طريق عطاء بن دينار-: <q>﴿فمن بدله﴾</q> يقول للأوصياء: من بدل وصية الميت <q>﴿بعد ما سمعه﴾</q> يعني: من بعد ما سمع من الميت، فلم يُمْضِ وصيتَه إذا كان عدلًا؛ <q>﴿فإنما إثمه﴾</q> يعني: إثم ذلك <q>﴿على الذين يبدلونه﴾</q> يعني: الوصيَّ، وبرئ منه الميتُ، <q>﴿إن الله سميع﴾</q> يعني: للوصية، <q>﴿عليم﴾</q> بها{2}. (٢/١٦٧) ٥٣٢٢- عن قتادة، عن عطاء= (ز) ٥٣٢٣- وسالم بن عبد الله= (ز) ٥٣٢٤- وسليمان بن يسار أنهم قالوا: تُمضى الوصية لِمَن أوْصى له به.= (ز) ٥٣٢٥- وقال عبيد الله بن عبيد الله بن مَعْمَر: أعجبُ إلَيَّ لَوْ أوْصى لذوي القرابة، وما يعجبني أن أنزعه ممن أوصى له به.= (ز) ٥٣٢٦- قال قتادة: وأعجبه إليّ لمن أوصى له به، قال الله ﷿: <q>﴿فمن بدَّله بعدَ ما سمعه فإنما إثمه على الذين يبدّلونه﴾</q>{3}. (ز) ٥٣٢٧- عن مجاهد بن جبر -من طريق ابن أبي نجيح- <q>﴿فمن بدَّله بَعد ما سمعه﴾</q>، قال: الوصية{4}. (ز) ٥٣٢٨- عن عطاء بن أبي رباح -من طريق قتادة- في قوله: <q>﴿فمن بدَّله بعد ما سمعه فإنما إثمه على الذين يبدّلونه﴾</q>، قال: تُمْضى كما قال{5}. (ز) ٥٣٢٩- عن الحسن البصري -من طريق يزيد بن إبراهيم- في هذه الآية: <q>﴿فمن بدّله بعد ما سمعه فإنما إثمه على الذين يبدِّلونه﴾</q>، قال: هذا في الوصية، مَن بدَّلها من بعد ما سمعها فإنّما إثمه على من بَدَّل{6}. (ز) ٥٣٣٠- عن قتادة بن دِعامة -من طريق مَعْمَر- في قوله: <q>﴿فمن بدله﴾</q>، قال: مَن بدّل الوصيّة بعد ما سمعها فإثمُ ما بُدِّل عليه{7}. (٢/١٦٧) ٥٣٣١- عن إسماعيل السدي -من طريق أسباط- <q>﴿فمن بدَّله بعد ما سمعه فإنما إثمه على الذين يبدلونه﴾</q>: فمن بدَّل الوصية التي أوصى بها، وكانت بمعروف؛ فإنما إثمها على من بدَّلها؛ أنه قد ظلم{5}. (ز) ٥٣٣٢- قال مقاتل بن سليمان: <q>﴿فمن بدله بعد ما سمعه﴾</q> يقول: مَن بدلّ وصيّة الميّت -يعني: الوصي والولي- بعد ما سمعه من الميت، فلم يُمْضِ وصيته <q>﴿فإنما إثمه على الذين يبدلونه﴾</q> يعني: الوصي والولي، وبرئِ منه الميت، <q>﴿إن الله سميع﴾</q>لوصية الميت، <q>﴿عليم﴾</q>بها{9}٦٣٥. (ز) ٦٣٥ قال ابنُ جرير (٣/١٣٩): «معنى الكلام: أوصوا لهم، فمَن بدّل ما أوصيتم به لهم بعد ما سَمعكم توصون لَهم، فإنما إثم ما فعل من ذلك عليه دونكم». وقال ابنُ عطية (١/٤٣٢): «الضمير في <q>﴿بدله﴾</q> عائد على الإيصاء وأمر الميت، وكذلك في <q>﴿سمعه﴾</q>، ويحتمل أن يعود الذي في <q>﴿سمعه﴾</q> على أمر الله تعالى في هذه الآية، والقول الأول أسبق للناظر». وقال ابنُ كثير (١/١٧١): «ويدخل في ذلك الكتمانُ لها بطريق الأَوْلى». <q>﴿فَمَنۢ بَدَّلَهُۥ بَعۡدَ مَا سَمِعَهُۥ فَإِنَّمَاۤ إِثۡمُهُۥ عَلَى ٱلَّذِینَ یُبَدِّلُونَهُۥۤۚ إِنَّ ٱللَّهَ سَمِیعٌ عَلِیمࣱ ۝١٨١﴾</q> - النسخ في الآية ٥٣٣٣- عن الكلبي: كان الأولياء والأوصياء يُمْضُون وصيّة الميّت بعد نزول قوله تعالى: <q>﴿فمن بدّله بعد ما سمعه﴾</q> الآية، وإن استغرق المالَ كلّه، ولم يبق للورثة شيءٌ، ثمّ نسخها قولُه تعالى: <q>﴿فمن خاف من موص جنفا﴾</q> الآية{10}. (ز) ٥٣٣٤- عن عبد الرحمن بن زيد بن أسلم: فعَجز المُوصي أن يوصي للوالدين والأقربين كما أمر الله تعالى، وعَجز الوصيُّ أن يُصْلِح؛ فانتزع الله تعالى ذلك منهم، ففَرَض الفرائض{10}. (ز) ",footnotes:1:أخرجه ابن جرير ٣/١٤٠، وابن أبي حاتم ١/٣٠٠ مختصرًا. وعزاه السيوطي إلى ابن المنذر.أخرجه ابن أبي حاتم ١/٣٠٠-٣٠١.أخرجه ابن جرير ٣/١٤١.أخرجه ابن جرير ٣/١٣٩.أخرجه ابن جرير ٣/١٤٠.أخرجه ابن جرير ٣/١٤١. وعلَّقه ابن أبي حاتم ١/٣٠٠. وذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ١/١٩٨-.أخرجه عبد الرزاق ١/٦٩، وابن جرير ٣/١٤٠، وابن أبي حاتم ١/٣٠٠.أخرجه ابن جرير ٣/١٤٠.تفسير مقاتل بن سليمان ١/١٥٩.تفسير الثعلبي ٢/٦٠، وتفسير البغوي ١/١٩٤.تفسير الثعلبي ٢/٦٠، وتفسير البغوي ١/١٩٤.
