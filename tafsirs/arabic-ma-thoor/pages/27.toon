quran[5]{c,v,t}:
  2,177,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿لَّیۡسَ ٱلۡبِرَّ أَن تُوَلُّوا۟ وُجُوهَكُمۡ قِبَلَ ٱلۡمَشۡرِقِ وَٱلۡمَغۡرِبِ﴾</span> الآية - قراءات</h3></p><p><div></p><p><p><span class="item-no">٤٩٧٩<span class="dash">-</span></span> عن <span class="name-1">ابن مسعود</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٩٨٠<span class="dash">-</span></span> و<span class="name-1">أبي بن كعب</span> -من طريق هارون- أنّهما قرآ: (لَيْسَ البِرَّ بِأَن تُوَلُّوا){1}. (٢/١٣٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٩٨١<span class="dash">-</span></span> عن <span class="name-2">الأعمش</span> -من طريق زائدة- قال: في قراءتنا مكان <span class="qpc-hafs">﴿ليس البر أن تولوا﴾</span>: (ولا تَحْسَبَنَّ أنَّ البِرَّ){2}. (٢/١٤٠)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿لَّیۡسَ ٱلۡبِرَّ أَن تُوَلُّوا۟ وُجُوهَكُمۡ قِبَلَ ٱلۡمَشۡرِقِ وَٱلۡمَغۡرِبِ﴾</span> الآية - نزول الآية</h3></p><p><div></p><p><p><span class="item-no">٤٩٨٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق ابن جُرَيْج- قال: هذه الآية نزلت بالمدينة: <span class="qpc-hafs">﴿ليس البر أن تولوا وجوهكم قبل المشرق والمغرب﴾</span>، يعني: الصلاة. يقول: ليس البر أن تُصَلُّوا ولا تعملوا غير ذلك{3}. (٢/١٣٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٩٨٣<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دِعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿ليس البر﴾</span> الآية، قال: ذُكِر لنا: أنّ رجلًا سأل النبي ﷺ عن البِرِّ؛ فأنزل الله هذه الآية، فدعا الرجلَ، فتلاها عليه. وقد كان الرجل قبل الفرائض إذا شهد أن لا إله إلا الله وأنّ محمدًا عبده ورسوله، ثم مات على ذلك، يُرْجى له في خير؛ فأنزل الله: <span class="qpc-hafs">﴿ليس البر أن تولوا وجوهكم قبل المشرق والمغرب﴾</span>، وكانت اليهود توجّهت قِبَل المغرب، والنصارى قِبَل المشرق، <span class="qpc-hafs">﴿ولكن البر من آمن بالله الآية﴾</span>{4}. (٢/١٣٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٩٨٤<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دِعامة</span> -من طريق مَعْمَر- قال: كانتِ اليهود تُصَلّي قِبَل المغرب، والنصارى قِبَل المشرق؛ فنزلت: <span class="qpc-hafs">﴿ليس البر أن تولوا وجوهكم﴾</span> الآية{5}. (٢/١٣٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٩٨٥<span class="dash">-</span></span> عن <span class="name-2">الربيع بن أنس</span> -من طريق أبي جعفر- قال: كانت اليهود تصلي قِبَل المغرب، والنصارى قِبَل المشرق؛ فنزلت: <span class="qpc-hafs">﴿ليس البر أن تُولوا وجوهكم قبل المشرق والمغرب﴾</span>{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٩٨٦<span class="dash">-</span></span> عن <span class="name-3">مقاتل بن حيان</span>، نحوه{7}<span class=comment-ref>٦١٢</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦١٢</span> اختلف أهل التأويل في معنى الآية، والمخاطب بها، على قولين: <b>أحدهما</b>: المسلمون، والمعنى: ليس البرَّ كله في الصلاة، ولكن البر ما في هذه الآية. و<b>الثاني</b>: أهل الكتابَيْن، والمعنى: ليس البر صلاة اليهود إلى المغرب وصلاة النصارى إلى المشرق، ولكن البر ما في هذه الآية.</p><p>و<span class="comment-type-3">رَجَّحَ</span> <u>ابنُ جرير</u> (٣/٧٦) القولَ الثاني، وهو قول قتادة، والربيع <span class="mustanad">بدلالة السياق</span>، فقال: «الآيات قبلها مَضَتْ بتوبيخهم ولَومهم، والخبر عنهم وعما أُعِدَّ لهم من أليم العذاب، وهذا في سياق ما قبلها».</p><p>و<span class="comment-type-4">ذَهَبَ</span> <u>ابنُ كثير</u> (٢/١٥٥) أنّها نزلت في «طائفة من أهل الكتاب وبعض المسلمين، شَقَّ عليهم التحول إلى الكعبة؛ فأنزل الله تعالى بيان حكمته في ذلك، وهو أنّ المراد إنما هو طاعة الله ﷿».</div></p><p><h3><span class="qpc-hafs">﴿لَّیۡسَ ٱلۡبِرَّ أَن تُوَلُّوا۟ وُجُوهَكُمۡ قِبَلَ ٱلۡمَشۡرِقِ وَٱلۡمَغۡرِبِ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٩٨٧<span class="dash">-</span></span> عن أبي ذر -من طريق مجاهد- أنّه سأل رسول الله ﷺ عن الإيمان. فتلا: <span class="qpc-hafs">﴿<b>ليس البر أن تولوا وجوهكم</b>﴾</span>، حتى فرغ منها، ثمّ سأله أيضا فتلاها، ثم سأله فتلاها، وقال: «<b>وإذا عَمِلْتَ حسنةً أحَبَّها قلبُك، وإذا عَمِلْتَ سَيِّئَةً أبْغَضَها قلبُك</b>»{8}. (٢/١٣٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٩٨٨<span class="dash">-</span></span> عن القاسم بن عبد الرحمن، قال: جاء رجل إلى أبي ذر، فقال: ما الإيمان؟ فتلا عليه هذه الآية: <span class="qpc-hafs">﴿لَيْسَ البِرَّ أنْ تُوَلُّوا وُجُوهَكُمْ قِبَلَ المَشْرِقِ والمَغْرِبِ﴾</span> حتى فرغ منها. فقال الرجل: ليس عن البِرِّ سألتك. فقال أبو ذر: جاء رجل إلى رسول الله ﷺ، فسأله عَمّا سألتني، فقرأ عليه هذه الآية، فأبى أن يرضى كما أبَيْتَ أن ترضى، فقال له رسول الله ﷺ: «<b>ادْنُ</b>». فدنا، فقال: «<b>المؤمنُ إذا عَمِل الحسنةَ سَرَّتْهُ ورَجا ثوابَها، وإذا عمل السَّيِّئَةَ أحْزَنَتْهُ وخافَ عِقابَها</b>»{9}. (٢/١٣٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٩٨٩<span class="dash">-</span></span> عن مجاهد: أنّ أبا ذرٍّ سأل رسول الله ﷺ عن الإيمان. فقرأ: <span class="qpc-hafs">﴿ليس البر أن تولوا وجوهكم قبل المشرق والمغرب﴾</span> الآية{10}. (٢/١٣٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٩٩٠<span class="dash">-</span></span> عن عكرمة، قال: سُئِل <span class="name-1">الحسنُ بن علي</span> مُقْبَلَه من الشام عن الإيمان. فقرأ: <span class="qpc-hafs">﴿ليس البر﴾</span> الآية{11}. (٢/١٣٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٩٩١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق العوفي- <span class="qpc-hafs">﴿ليس البر أن تولوا وجوهكم﴾</span>، يعني: في الصلاة. يقول: ليس البِرَّ أن تُصَلُّوا ولا تعملوا. فهذا حين تَحَوَّل من مكة إلى المدينة، ونزلت الفرائض، وحَدَّ الحدود؛ فأمر الله بالفرائض، والعملِ بها{12}. (٢/١٣٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٩٩٢<span class="dash">-</span></span> عن <span class="name-2">أبي العالية</span> -من طريق الربيع بن أنس- قال: كانت اليهود تُقْبِل قِبَل المغرب، وكانت النصارى تُقْبِل قِبَل المشرق؛ فقال الله: <span class="qpc-hafs">﴿ليس البر أن تولوا وجوهكم قبل المشرق والمغرب﴾</span>. يقول: هذا كلام الإيمان، وحقيقة العمل{13}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٩٩٣<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span>، نحو ذلك{14}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٩٩٤<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جَبْر</span> -من طريق ابن أبي نَجِيح-: <span class="qpc-hafs">﴿ليس البرّ أن تُولوا وجوهكم قبَل المشرق والمغرب﴾</span>، ولكِنَّ البر ما ثَبَت في القلوب من طاعة الله{15}. (٢/١٤٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٩٩٥<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جَبْر</span> -من طريق ابن جُرَيْج-، نحوه، وزاد في أوله: يعني: السجود{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٩٩٦<span class="dash">-</span></span> عن <span class="name-2">الضحاك بن مُزاحِم</span> -من طريق عبيد بن سليمان- أنّه قال فيها، قال: يقول: ليس البِرَّ أن تُصَلُّوا ولا تعملوا غير ذلك. وهذا حين تَحَوَّل من مكة إلى المدينة؛ فأنزل الله الفرائض، وحدَّ الحدود بالمدينة، وأمر بالفرائض أن يؤخذ بها{17}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٩٩٧<span class="dash">-</span></span> عن <span class="name-3">مقاتل بن حيان</span> -من طريق بُكَيْر بن معروف-، نحو ذلك{18}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٩٩٨<span class="dash">-</span></span> قال <span class="name-2">قتادة بن دِعامة</span>: يقول: ليس البر أن تكونوا نصارى فتُصَلُّوا إلى المشرق، ولا أن تكونوا يهودًا فتُصَلُّوا إلى المغرب إلى بيت المقدس{19}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٩٩٩<span class="dash">-</span></span> عن <span class="name-3">مقاتل بن حيان</span>-من طريق بُكَيْر بن معروف-: في قوله: <span class="qpc-hafs">﴿ليس البر﴾</span>، يعني: التقوى{20}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٠٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ليس البر أن تولوا وجوهكم﴾</span>، يعني: ليس التقوى أن تُحَوِّلوا وجوهكم في الصلاة قِبَل -يعني: تِلْقاء- المشرق والمغرب، فلا تفعلوا ذلك{21}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَلَـٰكِنَّ ٱلۡبِرَّ مَنۡ ءَامَنَ بِٱللَّهِ وَٱلۡیَوۡمِ ٱلۡـَٔاخِرِ وَٱلۡمَلَـٰۤىِٕكَةِ وَٱلۡكِتَـٰبِ وَٱلنَّبِیِّـۧنَ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٠٠١<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span> -من طريق عطاء بن دينار- في قول الله: <span class="qpc-hafs">﴿ولكن البر من ءامن بالله واليوم الآخر والملائكة والكتاب والنبيين﴾</span> أنّه حق{22}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٠٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ولكن البر من آمن بالله﴾</span> يعني: صدَّق بالله بأنّه واحد لا شريك له، <span class="qpc-hafs">﴿واليوم الآخر﴾</span> يعني: وصدَّق بالبعث الذي فيه جزاء الأعمال بأنّه كائن، <span class="qpc-hafs">﴿والملائكة﴾</span> أي: وصدَّق بالملائكة، <span class="qpc-hafs">﴿والكتاب والنبيين﴾</span>{21}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٠٣<span class="dash">-</span></span> عن <span class="name-3">سفيان</span> -من طريق ابن أبي عمر- <span class="qpc-hafs">﴿ولكن البر من آمن بالله﴾</span>، قال: أنواع البر كُلّها{24}<span class=comment-ref>٦١٣</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦١٣</span> قال <u>ابنُ تيمية</u> (١/٤١٠): «لفظ البِرِّ إذا أُطْلِق تناولَ جميعَ ما أمَرَ اللهُ به... وكان مُسَمّاه مُسَمّى التقوى، والتقوى إذا أُطْلِقَت كان مُسَمّاها مُسَمّى البِرَّ، ثُمَّ قد يُجْمَع بينهما كما في قوله تعالى: <span class="qpc-hafs">﴿وتعاونوا على البر والتقوى﴾</span> [المائدة:٢]».</div></p><p><h3><span class="qpc-hafs">﴿وَلَـٰكِنَّ ٱلۡبِرَّ مَنۡ ءَامَنَ بِٱللَّهِ وَٱلۡیَوۡمِ ٱلۡـَٔاخِرِ وَٱلۡمَلَـٰۤىِٕكَةِ وَٱلۡكِتَـٰبِ وَٱلنَّبِیِّـۧنَ﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٥٠٠٤<span class="dash">-</span></span> عن عمر بن الخطاب، قال: بينما نحن عند رسول الله ﷺ ذات يوم إذ طلع علينا رجلٌ شديدُ بياض الثياب، شديدُ سواد الشعر، لا يُرى عليه أثرُ السَّفَر، ولا يعرفه مِنّا أحد، حتى جلس إلى النبي ﷺ، فأَسْنَد رُكْبَتَيْه إلى رُكْبَتَيْه، ووضع كَفَّيْه على فَخِذَيْه، وقال: يا محمد، أخبِرْني عن الإسلام. فقال رسول الله ﷺ: «<b>الإسلامُ أن تشهدَ أن لا إله إلا الله وأنّ محمدًا رسول الله، وتقيمَ الصلاة، وتؤتيَ الزكاة، وتصومَ رمضان، وتَحُجَّ البيت إن استطعتَ إليه سبيلًا»</b>. قال: صدقت. قال: فعَجِبْنا له، يسأله ويصدقه! قال: فأخبِرني عن الإيمان. قال: <b>«أن تؤمنَ بالله، وملائكته، وكتبه، ورسله، واليوم الآخر، وتؤمنَ بالقَدَر خيرِه وشَرِّه».</b> قال: صدقت. قال: فأخبِرني عن الإحسان. قال: <b>«أن تعبد الله كأنّك تراه، فإن لم تكن تراه فإنّه يراك».</b> قال: فأخبِرني عن الساعة. قال: <b>«ما المسئولُ عنها بِأَعْلَمَ من السائل».</b> قال: فأخْبِرني عن أمارَتِها. قال: <b>«أن تَلِدَ الأَمَةُ رَبَّتَها، وأن تَرى الحُفاة العُراة العالَة رِعاءَ الشّاءِ يَتَطاوَلُون في البُنْيان».</b> قال: ثُمَّ انطلق، فلبثتُ مَلِيًّا، ثم قال لي: <b>«يا عمر، أتدري مَنِ السائل؟».</b> قلت: الله ورسوله أعلم. قال: <b>«فإنّه جبريل، أتاكم يُعَلِّمُكم دينَكم</b>»{25}. (٢/١٤٠)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَءَاتَى ٱلۡمَالَ عَلَىٰ حُبِّهِۦ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٠٠٥<span class="dash">-</span></span> عن المطلب: أنّه قيل: يا رسول الله، ما <span class="qpc-hafs">﴿آتى المال على حبه﴾</span>؟ فكُلُّنا نُحِبُّه! قال رسول الله ﷺ: «<b>تُؤتيه حين تُؤْتِيه ونفسُك تُحَدِّثُك بطُولِ العُمُرِ والفَقْرِ</b>»{26}. (٢/١٤٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٠٦<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن مسعود</span> -من طريق مُرَّة- <span class="qpc-hafs">﴿وآتى المال على حبه﴾</span>، قال: يُعْطِي وهو صحيحٌ، شحيحٌ<span class=comment-ref>٦١٤</span>، يأمل العَيْش، ويخاف الفقر{27}. (٢/١٤٣)</p></p><p></div></p><p><div><span class=comment-ref>٦١٤</span> <span class="comment-type-4">بيَّنَ</span> <u>ابنُ عطية</u> (١/٤٢٠-٤٢١) المقصودَ بالشُحِّ هنا، فقال: «والشُّحُّ في هذا الحديث هو الغَرِيزِيُّ الذي في قوله تعالى: <span class="qpc-hafs">﴿وأحضرت الأنفس الشح﴾</span> [النساء:١٢٨]، وليس المعنى: أن يكون المتصدّق مُتَّصِفًا بالشُّحِّ الذي هو البخل».</div></p><p><div></p><p><p><span class="item-no">٥٠٠٧<span class="dash">-</span></span> عن ابن مسعود مرفوعًا، مثله{28}. (٢/١٤٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٠٨<span class="dash">-</span></span> عن أبي هريرة، قال: قال رسول الله ﷺ: «<b>أفْضَلُ الصَّدَقَةِ أن تَصَدَّق وأنت صحيحٌ، شحيحٌ، تَأْمَلُ البقاءَ، وتخشى الفقر، ولا تُمْهِل حتّى إذا بلغت الحلقومَ قلتَ: لفلان كذا، ولفلان كذا. ألا وقد كان لفلان</b>»{29}. (٢/١٤٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٠٩<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span> -من طريق عطاء بن دينار- في قوله: <span class="qpc-hafs">﴿وآتى المال﴾</span> يعني: أعطى المال <span class="qpc-hafs">﴿على حبه﴾</span> يعني: على حُبِّ المال{22}. (٢/١٤٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠١٠<span class="dash">-</span></span> عن <span class="name-3">مقاتل بن حيان</span>-من طريق بُكَيْر بن معروف-، نحو الشطر الأول{22}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠١١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وآتى المال﴾</span> يعني: وأعطى المال <span class="qpc-hafs">﴿على حُبِّه﴾</span> له{21}<span class=comment-ref>٦١٥</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦١٥</span> <span class="comment-type-4">ذكر</span> <u>ابنُ عطية</u> (١/٤٢٠) أن الضمير في <span class="qpc-hafs">﴿حُبِّهِ﴾</span> عائد على المال، ثم قال: «<b>ويحتمل</b> أن يعود الضمير على الإيتاء، أي: في وقت حاجة من الناس وفاقة، فإيتاء المال حبيب إليهم، <b>ويحتمل</b> أن يعود الضمير على اسم الله تعالى من قوله: <span class="qpc-hafs">﴿مَن آمَنَ بِاللَّهِ﴾</span> أي: مَن تَصَدَّق محبة في الله تعالى وطاعاته. <b>ويحتمل</b> أن يعود على الضمير المستكن في <span class="qpc-hafs">﴿آتى﴾</span> أي: على حبه المال، فالمصدر مضاف إلى الفاعل، والمعنى المقصود: أن يتصدق المرء في هذه الوجوه وهو شحيح صحيح يخشى الفقر ويأمل الغنى، <span class="mustanad">كما قال</span> ﷺ».</div></p><p><h3><span class="qpc-hafs">﴿وَءَاتَى ٱلۡمَالَ عَلَىٰ حُبِّهِۦ﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٥٠١٢<span class="dash">-</span></span> عن فاطمة بنت قيس، قالت: قال رسول الله ﷺ: «<b>في المال حَقٌّ سوى الزكاة».</b> ثم قرأ: <span class="qpc-hafs">﴿ليس البر أن تولوا وجوهكم﴾</span> الآية{33}. (٢/١٥٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠١٣<span class="dash">-</span></span> عن إسماعيل بن سالم، عن <span class="name-2">عامر الشعبي</span> سمِعْتُه سُئِل: هل على الرجل حَقٌّ في ماله سوى الزكاة؟ قال: نعم. وتلا هذه الآية: <span class="qpc-hafs">﴿وآتى المالَ على حُبه ذَوي القربى واليتامى والمساكينَ وابنَ السبيل والسائلين وفي الرقاب وأقام الصلاة وآتى الزكاة﴾</span>{34}. (٢/١٥٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠١٤<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span>: أنّ هذا شيء واجبٌ في المال، حَقٌّ على صاحب المال أن يفعله سوى الذي عليه من الزكاة{35}<span class=comment-ref>٦١٦</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦١٦</span> هل في المال حقّ واجب سوى الزكاة؟ في هذه المسألة قولان لأهل العلم، ذكرهما <u>ابنُ جرير</u> (٣/٨٤-٨٥).</p><p>و<span class="comment-type-4">ذَهبَ</span> في ظاهر كلامه إلى أنّ فيه حقوقًا تجبُ غير الزكاة <span class="mustanad">استنادًا إلى السياق، وقول أهل التأويل</span>، حيث ذكر أول الآية <span class="qpc-hafs">﴿وآتى المال على حُبّه﴾</span>، ثم قال: «<span class="qpc-hafs">﴿وآتى الزكاة﴾</span>، فلكلّ مالٍ منهما حكمٌ يخصّه، وكلاهما مذكورٌ في سياق ما أوجبه الله على أهل الإيمان».</p><p>وقال <u>ابنُ كثير</u> (٢/١٦٠-١٦١ بتصرف): «قوله: <span class="qpc-hafs">﴿وآتى الزكاة﴾</span> يحتمل أن يكون المراد به: زكاة النفس، وتخليصها من الأخلاق الدنية الرذيلة، كقوله: <span class="qpc-hafs">﴿قد أفلح من زكاها وقد خاب من دساها﴾</span> [الشمس:٩-١٠]، ويحتمل أن يكون المراد: زكاة المال، ويكون المذكور في قوله: <span class="qpc-hafs">﴿وآتى المال على حبه﴾</span> إنما هو التطوع والبِرُّ والصِّلَة؛ ولهذا تقدم في الحديث عن فاطمة بنت قيس: إنّ في المال حَقًّا سوى الزكاة».</p><p>و<span class="comment-type-4">ذَهَبَ</span> <u>ابنُ عطية</u> (١/٤٢١) إلى نحو ما ذكره <u>ابنُ جرير</u> <span class="mustanad">مُسْتَنِدًا إلى السياق</span>، فقال: «وذِكْرُ الزكاة هنا دليلٌ على أنّ ما تقدم ليس بالزكاة المفروضة».</p><p>و<span class="comment-type-4">ذَهَبَ</span> <u>ابنُ تيمية</u> (١/٤١٢) إلى أنّ في المال حقوقًا سوى الزكاة، بها كمال البر، <span class="mustanad">استنادًا إلى السياق</span>، فقال: «وهذه الخصالُ المذكورة في الآية قد دلَّت على وجوبها؛ لأنه أخبر أنّ أهلها هم الذين صَدَقوا في قولهم، وهم المتقون، والصِّدق واجب، والإيمان واجب، ففيها إيجاب حقوق سوى الزكاة».</div></p><p><h3><span class="qpc-hafs">﴿ذَوِی ٱلۡقُرۡبَىٰ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٠١٥<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span> -من طريق عطاء بن دينار- في قوله: <span class="qpc-hafs">﴿ذوي القربى﴾</span>، يعني: قرابته{36}. (٢/١٤٥)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿ذَوِی ٱلۡقُرۡبَىٰ﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٥٠١٦<span class="dash">-</span></span> عن أم كلثوم بنت عقبة بن أبي مُعَيْط: سمعتُ رسول الله ﷺ يقول: «<b>أفضل الصَّدَقة على ذي الرَّحِم الكاشِح</b>{37}»{38}. (٢/١٤٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠١٧<span class="dash">-</span></span> عن سلمان بن عامر الضَّبِّيِّ، قال: قال رسول الله ﷺ: «<b>الصدقةُ على المسكين صدقةٌ، وعلى ذي الرَّحِم اثنتان: صدقةٌ، وصِلَةٌ</b>»{39}. (٢/١٤٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠١٨<span class="dash">-</span></span> عن زينب امرأة عبد الله بن مسعود، قالت: سألتُ رسول الله ﷺ: أتُجْزِئُ عَنِّي من الصدقة النفقةُ على زوجي، وأيتامٍ في حِجْرِي؟ قال: «<b>لكِ أجران: أجرُ الصدقة، وأجرُ القرابة</b>»{40}. (٢/١٤٦)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَٱلۡیَتَـٰمَىٰ وَٱلۡمَسَـٰكِینَ وَٱبۡنَ ٱلسَّبِیلِ﴾</span>{41} - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٠١٩<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي بن أبي طلحة- قال: ابنُ السبيل: هو الضَّيْفُ الذي ينزِل بالمسلمين{36}. (٢/١٤٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٢٠<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٢١<span class="dash">-</span></span> و<span class="name-2">قتادة بن دعامة</span>، نحو ذلك{43}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٢٢<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نَجِيح- في قوله: <span class="qpc-hafs">﴿وابن السبيل﴾</span>، قال: الذي يَمُرُّ عليك وهو مسافر{44}. (٢/١٤٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٢٣<span class="dash">-</span></span> عن <span class="name-2">الضحاك بن مُزاحِم</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٢٤<span class="dash">-</span></span> و<span class="name-2">الحسن البصري</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٢٥<span class="dash">-</span></span> و<span class="name-2">محمد ابن شهاب الزُّهْرِي</span>، نحو ذلك{45}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٢٦<span class="dash">-</span></span> وعن <span class="name-2">الربيع بن أنس</span> -من طريق أبي جعفر-= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٢٧<span class="dash">-</span></span> و<span class="name-3">مقاتل بن حيان</span> -من طريق بُكَيْر بن معروف-، نحو ذلك{46}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٢٨<span class="dash">-</span></span> عن <span class="name-2">أبي جعفر محمد بن علي</span> -من طريق جابر- <span class="qpc-hafs">﴿وابن السبيل﴾</span>، قال: المجتاز من أرض إلى أرض{47}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٢٩<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دِعامة</span> -من طريق مَعْمَر- في قوله: <span class="qpc-hafs">﴿وابن السبيل﴾</span>، قال: الذي يَمُرُّ عليك وهو مسافر{44}<span class=comment-ref>٦١٧</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦١٧</span> <span class="comment-type-4">علَّق</span> <u>ابنُ عطية</u> (١/٤٢١) على هذا القول، بقوله: «وهذا <span class="mustanad">كما يقال</span>: ابن ماء للطائر الملازم للماء، <span class="mustanad">ومنه قول النبي ﷺ</span>: «لا يدخل الجنة ابن زِنا». أي: الملازم له».</div></p><p><div></p><p><p><span class="item-no">٥٠٣٠<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دِعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿وابن السبيل﴾</span>، قال: هو الضيف. قال: وذُكِر لنا: أنّ نبي الله ﷺ كان يقول: «<b>مَن كان يؤمن بالله واليوم الآخر فلْيُكْرِم ضيفَه، ومن كان يؤمن بالله واليوم الآخر فلْيَقُل خَيْرًا أو لِيَسْكُت</b>». قال: وكان يُقال: حَقُّ الضيافةِ ثلاثُ ليال، فكُلُّ شيء أصابه بعد ذلك صدقةٌ{49}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٣١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: أعطى <span class="qpc-hafs">﴿ذوي القربى واليتامى والمساكين وابن السبيل﴾</span>، يعني: والضيف نازل عليك{21}<span class=comment-ref>٦١٨</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦١٨</span> قال <u>ابنُ كثير</u> (٢/١٥٩): «<span class="qpc-hafs">﴿وابن السبيل﴾</span>: هو المسافر المجتازُ الذي قد فرغت نفقته، فيُعْطى ما يُوصِله إلى بلده، وكذا الذي يريد سفرًا في طاعة فيُعْطى ما يكفيه في ذهابه وإيابه، ويدخل في ذلك الضيف».</div></p><p><h3><span class="qpc-hafs">﴿وَٱلسَّاۤىِٕلِینَ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٠٣٢<span class="dash">-</span></span> عن قيس بن كُرْكُم، قال: سألتُ <span class="name-1">ابن عَبّاس</span> عن السائل. قال: الذي يسأل{46}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٣٣<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span> -من طريق حصين- في قوله: <span class="qpc-hafs">﴿والسائلين﴾</span>، قال: السائل الذي يسألك{52}. (٢/١٤٧)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَٱلسَّاۤىِٕلِینَ﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٥٠٣٤<span class="dash">-</span></span> عن الحسين بن علي، قال: قال رسول الله ﷺ: «<b>للسائل حَقٌّ، وإن جاء على فرس</b>»{53}. (٢/١٤٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٣٥<span class="dash">-</span></span> عن عبد الرحمن بن بُجَيْد، عن جدته أم بُجَيْد -وكانت مِمَّن بايع رسول الله ﷺ- أنّها قالت: يا رسول الله، إنّ المسكين لَيَقُومُ على بابي، فما أجد شيئًا أعطيه إيّاه. فقال لها: «<b>إن لم تجدي إلا ظِلْفًا مُحْرَقًا فادْفَعِيه إليه</b>»{54}. (٢/١٤٨)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَفِی ٱلرِّقَابِ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٠٣٦<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span> -من طريق عطاء بن دينار- <span class="qpc-hafs">﴿وفي الرقاب﴾</span>، يعني: فِكاك الرِّقاب{46}. (٢/١٤٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٣٧<span class="dash">-</span></span> عن <span class="name-3">مقاتل بن حَيّان</span> -من طريق بُكَيْر بن مَعْروف- في قول الله: <span class="qpc-hafs">﴿وفي الرقاب﴾</span>، قال: هم المُكاتَبون{46}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٣٨<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٣٩<span class="dash">-</span></span> و<span class="name-2">محمد ابن شهاب الزهري</span>، نحو ذلك{57}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٤٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿و﴾</span> أعطى <span class="qpc-hafs">﴿السائلين وفي الرقاب﴾</span>، فهذا تَطَوُّعٌ{21}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَأَقَامَ ٱلصَّلَوٰةَ وَءَاتَى ٱلزَّكَوٰةَ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٠٤١<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span> -من طريق عطاء بن دينار- في قوله: <span class="qpc-hafs">﴿وأقام الصلاة﴾</span> يعني: وأَتَمَّ الصلاةَ المكتوبة، <span class="qpc-hafs">﴿وآتى الزكاة﴾</span> يعني: الزّكاة المفروضة{46}. (٢/١٤٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٤٢<span class="dash">-</span></span> عن <span class="name-3">مقاتل بن حَيّان</span> -من طريق بُكَيْر بن معروف-، نحو ذلك{46}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٤٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثم قال سبحانه: <span class="qpc-hafs">﴿وأقام الصلاة﴾</span> المكتوبة، <span class="qpc-hafs">﴿وآتى﴾</span>: وأعطى <span class="qpc-hafs">﴿الزكاة﴾</span> المفروضة{21}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَأَقَامَ ٱلصَّلَوٰةَ وَءَاتَى ٱلزَّكَوٰةَ﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٥٠٤٤<span class="dash">-</span></span> عن ربيعة بن كُلْثُوم، قال: حدّثني أبي، قال لي <span class="name-2">مُسْلِم بن يَسار</span>: إنّ الصلاة صلاتان، وإن الزَّكاة زكاتان، واللهِ، إنّه لفي كتاب الله، أقرأ عليك به قرآنًا؟ قلت له: اقرأ. قال: فإنّ الله يقول في كتابه: <span class="qpc-hafs">﴿ليس البر أن تولوا وجوهكم﴾</span> إلى قوله: <span class="qpc-hafs">﴿وآتى المال على حبه ذوي القربى واليتامى المساكين وابن السبيل﴾</span> فهذا وما دونه تَطَوُّعٌ كلّه، <span class="qpc-hafs">﴿وأقام الصلاة﴾</span> على الفريضة، <span class="qpc-hafs">﴿وآتى الزكاة﴾</span>، فهاتان فريضتان{62}. (٢/١٥٠)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَٱلۡمُوفُونَ بِعَهۡدِهِمۡ إِذَا عَـٰهَدُوا۟ۖ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٠٤٥<span class="dash">-</span></span> عن <span class="name-2">أبي العالية</span> -من طريق الربيع بن أنس- في قوله: <span class="qpc-hafs">﴿والموفون بعهدهم إذا عاهدوا﴾</span>، قال: فمَن أعطى عَهْد الله ثم نقضه فالله ينتقم منه، ومَن أعطى ذِمَّة النبي ﷺ ثُمَّ غدر بها فالنبيُّ ﷺ خَصْمُه يوم القيامة{63}. (٢/١٥١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٤٦<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span> -من طريق عطاء بن دينار- في قوله: <span class="qpc-hafs">﴿والموفون بعهدهم إذا عاهدوا﴾</span>، يعني: فيما بينهم وبين الناس{64}. (٢/١٥١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٤٧<span class="dash">-</span></span> عن <span class="name-2">الربيع بن أنس</span> -من طريق أبي جعفر- في قوله: <span class="qpc-hafs">﴿والموفون بعهدهم إذا عاهدوا﴾</span>، قال: فمَن أعطى عَهْدَ الله ثُمَّ نقضه فالله ينتقم منه، ومَن أعطى ذِمَّة النبي ﷺ ثُمَّ غَدر بها فالنبيُّ ﷺ خصمُه يوم القيامة{65}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٤٨<span class="dash">-</span></span> قال <b>⟨مقاتل بن سليمان</b>:⟩{تت} <span class="qpc-hafs">﴿والموفون بعهدهم إذا عاهدوا﴾</span> فيما بينهم وبين الناس{21}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَٱلصَّـٰبِرِینَ فِی ٱلۡبَأۡسَاۤءِ وَٱلضَّرَّاۤءِ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٠٤٩<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن مسعود</span> -من طريق السُّدِّيِّ، عن مُرَّة الهمداني- في الآية، قال: البَأْساء: الفقر. والضَّرّاء: السُّقْمُ{67}. (٢/١٥١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٥٠<span class="dash">-</span></span> عن <span class="name-2">أبي العالية</span> -من طريق الربيع بن أنس-= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٥١<span class="dash">-</span></span> و<span class="name-2">الربيع بن أنس</span> -من طريق أبي جعفر-= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٥٢<span class="dash">-</span></span> و<span class="name-3">مقاتل بن حيان</span> -من طريق بُكَيْر بن معروف-، نحو ذلك{64}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٥٣<span class="dash">-</span></span> وعن <span class="name-2">مُرَّة الهمداني</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٥٤<span class="dash">-</span></span> و<span class="name-2">مجاهد بن جبر</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٥٥<span class="dash">-</span></span> و<span class="name-2">الحسن البصري</span>، نحو ذلك{69}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٥٦<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span>، نحو قوله في <span class="qpc-hafs">﴿البأساء﴾</span>{69}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٥٧<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السدي</span> -من طريق أسباط-، نحو قوله في <span class="qpc-hafs">﴿البأساء﴾</span>{64}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٥٨<span class="dash">-</span></span> عن <span class="name-2">أبي مالك</span>، نحو قوله في <span class="qpc-hafs">﴿الضراء﴾</span>{69}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٥٩<span class="dash">-</span></span> عن <span class="name-1">ابن عباس</span>: أنّ نافع بن الأزرق سأله عن: <span class="qpc-hafs">﴿البأساء والضراء﴾</span>. قال: البأساء: الخِصْب. والضَّرّاءُ: الجَدْب. قال: وهل تعرفُ العربُ ذلك؟ قال: نعم، أما سمعتَ قولَ زيد بن عمرو:</p><p>إنّ الإله عزيز واسع حَكَمُ بكفه الضُّر والبأساء والنِّعَم{73}. (٢/١٥١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٦٠<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span> -من طريق عطاء بن دينار- في قول الله: <span class="qpc-hafs">﴿والضراء﴾</span>، يعني: حين البلاء والشدة{74}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٦١<span class="dash">-</span></span> عن <span class="name-2">الضحاك بن مُزاحِم</span> -من طريق عبيد- في قوله: <span class="qpc-hafs">﴿والصابرين في البأساء والضراء﴾</span>، قال: البأساء: الفقر. والضَّرّاء: المرض{75}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٦٢<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق عَبّاد بن منصور- <span class="qpc-hafs">﴿البأساء﴾</span> قال: البلاء، <span class="qpc-hafs">﴿والضراء﴾</span>: هذه الأمراض والجوع، ونحو ذلك{76}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٦٣<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دِعامة</span> -من طريق سعيد- قال: كنا نُحَدَّث أنّ البأساء: البؤس والفقر، وأنّ الضراء: السُّقم. وقد قال نبيُّ الله أيوبُ ﷺ: <span class="qpc-hafs">﴿أنِّي مَسَّنِيَ الضُّرُّ وأَنْتَ أرْحَمُ الرّاحِمِينَ﴾</span> [الأنبياء:٨٣]{77}. (٢/١٥١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٦٤<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دِعامة</span> -من طريق مَعْمَر- في قوله: <span class="qpc-hafs">﴿والصابرين في البأساء والضراء﴾</span>، قال: البأساء: البُؤْس. والضراء: الزَّمانَةُ في الجسد{78}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٦٥<span class="dash">-</span></span> عن <span class="name-2">الربيع بن أنس</span> -من طريق أبي جعفر- في قوله: <span class="qpc-hafs">﴿والصابرين في البأساء والضراء﴾</span>، قال: البُؤْس: الفاقة والفقر. والضراء في النَّفْس؛ من وجعٍ، أو مَرَضٍ يُصيبُه في جَسَدِه{79}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٦٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿والصابرين في البأساء﴾</span> يعني: الفقر، <span class="qpc-hafs">﴿والضراء﴾</span> يعني: البلاء{21}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٦٧<span class="dash">-</span></span> قال <span class="name-3">سفيان الثوري</span>: <span class="qpc-hafs">﴿البأساء﴾</span>: الفقر، <span class="qpc-hafs">﴿والضراء﴾</span>: المَضَرَّة{81}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَحِینَ ٱلۡبَأۡسِۗ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٠٦٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن مسعود</span> -من طريق السُّدِّيّ، عن مُرَّة الهَمْدانِيِّ- في قوله تعالى: <span class="qpc-hafs">﴿وحين البأس﴾</span>، قال: حين القتال{82}. (٢/١٥١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٦٩<span class="dash">-</span></span> وعن <span class="name-2">أبي العالية</span> -من طريق الربيع بن أنس-، نحو ذلك{74}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٧٠<span class="dash">-</span></span> و<span class="name-2">سعيد بن جُبَيْر</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٧١<span class="dash">-</span></span> و<span class="name-2">مُرَّة الهمداني</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٧٢<span class="dash">-</span></span> و<span class="name-2">أبي مالك</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٧٣<span class="dash">-</span></span> و<span class="name-2">الحسن البصري</span>، نحو ذلك{84}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٧٤<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نَجِيح- <span class="qpc-hafs">﴿وحين البأس﴾</span>، قال: حين القتال{85}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٧٥<span class="dash">-</span></span> عن <span class="name-2">الضحاك بن مُزاحِم</span> -من طريق عبيد- في قوله: <span class="qpc-hafs">﴿وحين البأس﴾</span>، قال: القتال{86}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٧٦<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دِعامة</span> -من طريق سعيد- قوله: <span class="qpc-hafs">﴿وحين البأس﴾</span>، أي: عند مواطن القتال{87}. (٢/١٥١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٧٧<span class="dash">-</span></span> عن <span class="name-2">الربيع بن أنس</span> -من طريق أبي جعفر- <span class="qpc-hafs">﴿وحين البأس﴾</span>: عند لقاء العدو{88}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٧٨<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وحين البأس﴾</span>، يعني: وعند القتال هم صابرون{21}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٧٩<span class="dash">-</span></span> عن <span class="name-3">مُقاتِل بن حيان</span> -من طريق بُكَيْر بن معروف- <span class="qpc-hafs">﴿وحين البأس﴾</span>، قال: حين القتال{74}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٨٠<span class="dash">-</span></span> عن <span class="name-3">سفيان الثوري</span>، قال: <span class="qpc-hafs">﴿وحين البأس﴾</span>: القتال{81}<span class=comment-ref>٦١٩</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦١٩</span> <span class="comment-type-4">ذَهَبَ</span> <u>ابنُ جرير</u> (٣/٩١)، و<u>ابنُ عطية</u> (١/٤٢١)، و<u>ابنُ كثير</u> (٢/١٦١) إلى أنّ المراد بقوله: <span class="qpc-hafs">﴿وحين البأس﴾</span>: وقت شدة القتال في الحرب. <span class="mustanad">استنادًا إلى أقوال أهل التأويل، واستند ابن عطية أيضًا إلى اللغة</span>.</div></p><p><h3><span class="qpc-hafs">﴿وَحِینَ ٱلۡبَأۡسِۗ﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٥٠٨١<span class="dash">-</span></span> عن علي -من طريق حارثة بن مُضَرِّب- أنّه قال: كُنّا إذا احْمَرَّ البأسُ، ولقي القوم؛ اتَّقَيْنا برسول الله ﷺ، فما يكون مِنّا أحدٌ أقرب إلى القوم منه{92}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٨٢<span class="dash">-</span></span> عن البراء: كُنّا -والله- إذا احْمَرَّ البأسُ نَتَّقِي به، وإنّ الشجاع مِنّا لَلَّذي يُحاذي به. يعني: النبي ﷺ{93}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿أُو۟لَـٰۤىِٕكَ ٱلَّذِینَ صَدَقُوا۟ۖ وَأُو۟لَـٰۤىِٕكَ هُمُ ٱلۡمُتَّقُونَ ۝١٧٧﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٠٨٣<span class="dash">-</span></span> عن <span class="name-2">أبي العالية</span> -من طريق الربيع بن أنس- <span class="qpc-hafs">﴿أولئك الذين صدقوا﴾</span>، يقول: تكلّموا بكلام الإيمان، وحَقَّقوا بالعمل{74}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٨٤<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span> -من طريق عطاء بن دينار- في قوله: <span class="qpc-hafs">﴿أولئك﴾</span>، يعني: الذين فعلوا ما ذكر الله في هذه الآية هم <span class="qpc-hafs">﴿الذين صدقوا﴾</span>، يعني: المتقون{74}. (٢/١٥٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٨٥<span class="dash">-</span></span> عن <span class="name-2">الربيع بن أنس</span> -من طريق أبي جعفر- في قوله: <span class="qpc-hafs">﴿أولئك الذين صدقوا﴾</span>، قال: تكلّموا بكلام الإيمان، فكانت حقيقته العمل، صَدَقوا اللهَ.= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٨٦<span class="dash">-</span></span> قال: وكان <span class="name-2">الحسن</span> يقول: هذا كلام الإيمان، وحقيقته العمل، فإن لم يكن مع القول عملٌ فلا شيء{96}. (٢/١٥٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٨٧<span class="dash">-</span></span> عن <span class="name-3">مقاتل بن حَيّان</span> -من طريق بُكَيْر بن معروف-: <span class="qpc-hafs">﴿أولئك الذين صدقوا﴾</span> إيمانهم، وصبروا على طاعة ربهم. وزاد في رواية: يعني: النبي ﷺ، وأصحابه{74}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٨٨<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿أولئك الذين صدقوا﴾</span> في إيمانهم، <span class="qpc-hafs">﴿وأولئك هم المتقون﴾</span>{21}<span class=comment-ref>٦٢٠</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٢٠</span> قال <u>ابنُ جرير</u> (٣/٩٢): «مَن فعل هذه الأشياء فهم الذين صَدَقوا الله في إيمانهم، وحَقَّقوا قولهم بأفعالهم، لا مَن ولّى وجهه قِبَل المشرق والمغرب وهو يخالف الله في أمره، وينقض عهده وميثاقه، ويكتم الناسَ بَيانَ ما أمره الله ببيانه، ويكذِّب رسله».</p><p>وقال <u>ابنُ عطية</u> (٢/٤٢٢): «وصف تعالى أهلَ هذه الأفعال البَرَّة بالصدق في أمورهم، أي: هم عند الظن بهم والرجاء فيهم، كما تقول: صدقني المال، وصدقني الربح. ومنه: عود صِدْق. وتحتمل اللفظةُ أيضًا صدق الإخبار».</div></p><p><h3><span class="qpc-hafs">﴿أُو۟لَـٰۤىِٕكَ ٱلَّذِینَ صَدَقُوا۟ۖ وَأُو۟لَـٰۤىِٕكَ هُمُ ٱلۡمُتَّقُونَ ۝١٧٧﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٥٠٨٩<span class="dash">-</span></span> عن <span class="name-2">أبي مَيْسَرَة</span> -من طريق أبي إسحاق- قال: مَن عَمِل بهذه الآية فقد استكمل الإيمان: <span class="qpc-hafs">﴿ليس البر﴾</span> الآية{99}. (٢/١٣٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٩٠<span class="dash">-</span></span> عن إبراهيم بن أبي شيبان، قال: سألت <span class="name-2">زيد بن رُفَيع</span>، فقلت: يا أبا جعفر، ما تقول في الخوارج في تكفيرهم الناس؟ قال: كذبوا، يقول الله ﷿: <span class="qpc-hafs">﴿ليس البر أن تولوا وجوهكم﴾</span> الآية. فمَن آمن فهو مؤمن، ومَن كفر بِهِنَّ فهو كافر{100}. (٢/١٥٢)</p></p><p></div></p></div>",footnotes:1:تفسير الثعلبي ٢/٤٩. وعزاه السيوطي إلى أبي عبيد في فضائله.</p><p>وهي قراءة شاذة. انظر: مختصر ابن خالويه ص١٨، والمحتسب ١/١١٧.أخرجه ابن أبي داود في المصاحف ص٥٧.</p><p>وهي قراءة شاذة. انظر: البحر المحيط ٢/٤.أخرجه ابن جرير ٣/٧٥.أخرجه ابن جرير ٣/٧٦. وعلَّقه الواحدي في أسباب النزول (ت: الفحل) ص١٥٧. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه عبد الرزاق ١/٦٦، وابن جرير ٣/٧٥.أخرجه ابن جرير ٣/٧٥، وابن أبي حاتم ١/٢٨٧.تفسير الثعلبي ٢/٤٩.أخرجه ابن أبي حاتم ١/٢٨٧ (١٥٣٩)، والحاكم ٢/٢٩٩ (٣٠٧٧).</p><p>قال الحاكم: «هذا حديث صحيح، على شرط الشيخين، ولم يُخَرِّجاه». وتعقّبه الذهبي في التلخيص بقوله: «كيف وهو منقطع؟!». قال ابن كثير في تفسيره ١/٤٨٥: «وهذا منقطع؛ فإن مجاهدًا لم يُدْرِك أبا ذر؛ فإنّه مات قديمًا».أخرجه إسحاق بن راهويه -كما في المطالب العالية لابن حجر ١٢/٤٢٨ (٢٩٤١)-، والمروزي في تعظيم قدر الصلاة ١/٤١٦ (٤٠٨).</p><p>قال ابن كثير في تفسيره ١/٤٨٥: «وهذا أيضًا منقطع». وقال ابن حجر: «هذا منقطع».أخرجه عبد الرزاق في جامعه ١١/١٢٨ (٢٠١١٠) عن مَعْمَر، والمروزي في تعظيم قدر الصلاة ١/٤١٧ (٤٠٩).</p><p>وهذا منقطع؛ فإن مجاهدًا لم يُدْرِك أبا ذر، كما في تفسير ابن كثير ١/٤٨٥، وقال ابن حجر في المطالب العالية ١٤/٤٧٤ (٣٥٣٣): «هذا مرسل، صحيح الإسناد، وله شاهد».أخرجه إسحاق -كما في المطالب (٣٩٠٠)-. وعزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ٣/٧٤، وابن أبي حاتم ١/٢٨٧.أخرجه ابن أبي حاتم ١/٢٨٧. وعزاه السيوطي إلى ابن جرير أيضًا، والذي عند ابن جرير موقوف على الربيع من قوله -كما تقدم- دون آخره.علقه ابن أبي حاتم ١/٢٨٧.أخرجه ابن جرير ٣/٧٤، وابن أبي حاتم ١/٢٨٧. وعزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ٣/٧٥.أخرجه ابن جرير ٣/٧٥. وعلّقه ابن أبي حاتم ١/٢٨٧.أخرجه بن أبي حاتم ١/٢٨٧.ذكره يحيي بن سلام -كما في تفسير ابن أبي زمنين ١/١٩٦-.أخرجه ابن أبي حاتم ١/٢٨٧.تفسير مقاتل بن سليمان ١/١٥٧.أخرجه ابن أبي حاتم ١/٢٨٨.تفسير مقاتل بن سليمان ١/١٥٧.أخرجه ابن أبي حاتم ١/٢٨٨، عن سفيان مهملًا. وقد أورده الثعلبي ٢/١٢٦، وابن كثير ١/٤٨٦ عن سفيان الثوري. ولم يذكر المزي في تهذيب الكمال ٢٦/٦٣٩ في ترجمة محمد بن يحيى بن أبي عمر العدني أن سفيان الثوري من شيوخه، وإنما ذكر سفيان بن عيينة الذي هو من أشهر شيوخه.أخرجه مسلم ١/٣٦-٣٧ (٨). وأورده الثعلبي ١/١٤٦.أخرجه البيهقي في الشعب ٥/١٣٥-١٣٦ (٣١٩٦) مرسلًا.أخرجه ابن المبارك في كتاب الزهد ص٢٤، ووكيع -كما في تفسير ابن كثير ١/٢٩٧-، وعبد الرزاق في تفسيره ١/٦٦، وفي المُصَنَّف ٩/٥٥ (١٦٣٢٤)، وسعيد بن منصور (٢٤٥- تفسير)، وابن أبي شيبة في المصنف ١٣/٢٩٧ (٣٥٦٩٥)، وابن جرير ٣/٧٨-٧٩، وابن أبي حاتم ١١/٢٨٨ (١٥٤٦)، والطبراني (٨٥٠٣)، والحاكم ٢/٢٧٢، والبيهقي ٤/١٩٠. وعزاه السيوطي إلى الفريابي، وعبد بن حميد.أخرجه الحاكم -كما في تفسير ابن كثير ١/٤٨٦-.</p><p>قال ابن كثير -عَقِب قول الحاكم: «صحيح، على شرط الشيخين، ولم يُخَرِّجاه»-: «وقد رواه وكيع عن الأعمش، وسفيان عن زبيد، عن مُرَّة، عن ابن مسعود، موقوفًا، وهو أصح».أخرجه البخاري ٢/١١٠ (١٤١٩)، ٤/٤ (٢٧٤٨)، ومسلم ٢/٧١٦ (١٠٣٢).أخرجه ابن أبي حاتم ١/٢٨٨.أخرجه ابن أبي حاتم ١/٢٨٨.تفسير مقاتل بن سليمان ١/١٥٧.أخرجه الترمذي ٢/١٩٧-١٩٨ (٦٦٥، ٦٦٦)، وابن ماجه ٣/٩ (١٧٨٩) دون الآية، كما أخرجه ابن جرير ٣/٨١، وابن أبي حاتم ١/٢٨٨ (١٥٤٨).</p><p>قال الترمذي: «هذا حديث إسناده ليس بذاك، وأبو حمزة ميمون الأعور يُضَعَّف، وروى بيان وإسماعيل عن الشعبي هذا الحديث قوله، وهذا أصح». وقال البيهقي في الكبرى ٤/١٤٢: «فهذا حديث يعرف بأبي حمزة ميمون الأعور كوفي، وقد جَرَّحه أحمد بن حنبل، ويحيى بن معين، فمَن بعدهما من حُفّاظ الحديث». وقال النووي في خلاصة الأحكام ٢/١٠٧٨ (٣٨٣٧): «حديث مُنكَر». وقال العيني في عمدة القاري ٨/٢٣٧: «وقال شيخنا زين الدين: ليس حديث فاطمة هذا بصحيح».أخرجه ابن جرير ٣/٧٩. وعزاه السيوطي إلى عبد بن حميد.علَّقه ابنُ جرير ٣/٧٩.أخرجه ابن أبي حاتم ١/٢٨٩.الكاشح: العدوُّ الذي يُضْمِر عداوتَه، ويطوي عليها كشحه، أي: بطنه، والكشح: الخصر، أو الذي يطوي عنك كشحه ولا يألفك. لسان العرب (كشح).أخرجه ابن خزيمة ٤/١٣١-١٣٢ (٢٣٨٦)، والحاكم ١/٥٦٤ (١٤٧٥). وأورده الثعلبي ٢/٥١.</p><p>قال الحاكم: «هذا حديث صحيح، على شرط مسلم، ولم يُخَرِّجاه، وله شاهد بإسناد صحيح». ووافقه الذهبي، وأقرّه المنذري. وقال الزيلعي في نصب الراية ٤/٤٠٦: «قال ابن طاهر: سنده صحيح». وقال الهيثمي في المجمع ٣/١١٦ (٤٦٥٠): «رواه الطبراني في الكبير، ورجاله رجال الصحيح». وقال البوصيري في إتحاف الخيرة ٣/٤٢ (٢١٣٩): «رواه الحميدي، وفي سنده راو لم يُسَمَّ،... ورواه الطبراني في الكبير بسند الصحيح». وقال الألباني في الإرواء ٣/٤٠٤ (٨٩٢): «صحيح».أخرجه أحمد ٢٦/١٦٦-١٦٧ (١٦٢٢٧)، ٢٦/١٦٩-١٧٢ (١٦٢٣٢، ١٦٢٣٣، ١٦٢٣٥)، ٢٩/٤١١-٤١٦ (١٧٨٧٢، ١٧٨٧٧، ١٧٨٨٣، ١٧٨٨٤) واللفظ له، والترمذي ٢/١٩٥-١٩٦ (٦٦٤)، والنسائي ٥/٩٢ (٢٥٨٢)، وابن ماجه ٣/٥١ (١٨٤٤)، وابن خزيمة ٣/٤٨١-٤٨٢ (٢٠٦٧)، ٤/١٣٠-١٣١ (٢٣٨٥)، وابن حبان ٨/١٣٢-١٣٣ (٣٣٤٤)، والحاكم ١/٥٦٤ (١٤٧٦).</p><p>قال الترمذي: «حديث حسن». وصحّح إسناده ابن كثير في تفسيره ٨/٤٠٨. وقال ابن الملقن في البدر ٧/٤١١: «هذا الحديث صحيح». وقال الألباني في الإرواء ٣/٣٨٧ (٨٨٣): «حسن».أخرجه البخاري ٢/١٢١ (١٤٦٦)، ومسلم ٢/٦٩٤ (١٠٠٠).⟨تقدم تفسير اليتامى والمساكين في الآية (٨٣).⟩{ع}أخرجه ابن أبي حاتم ١/٢٨٩.علَّقه ابن أبي حاتم ١/٢٨٩.أخرجه عبد الرزاق ١/١٥٩، وابن جرير ٣/٨٣، وابن أبي حاتم ١/٢٩٠.عَلَّقه ابن أبي حاتم ١/٢٩٠.أخرجه ابن أبي حاتم ١/٢٩٠.أخرجه ابن جرير ٣/٨٣. وعلَّقه ابن أبي حاتم ١/٢٩٠.أخرجه عبد الرزاق ١/١٥٩، وابن جرير ٣/٨٣، وابن أبي حاتم ١/٢٩٠.أخرجه ابن جرير ٣/٨٢-٨٣. وعلَّقه ابن أبي حاتم ١/٢٨٩. وأورده الثعلبي ٢/٥١.</p><p>قال أحمد شاكر في تحقيقه لتفسير الطبري ٣/٣٤٥: «هو حديث مرسل...، وثبت معناه ضمن حديث رواه مسلم...، ورواه أيضًا أحمد وسائر أصحاب الكتب الستة».تفسير مقاتل بن سليمان ١/١٥٧.أخرجه ابن أبي حاتم ١/٢٩٠.أخرجه ابن جرير ٣/٨٤.أخرجه أحمد ٣/٢٥٤ (١٧٣٠)، وأبو داود ٣/٩٨ (١٦٦٥)، وابن خزيمة ٤/١٨٣-١٨٤ (٢٤٦٨)، وابن أبي حاتم ١/٢٩٠ (١٥٥٦).</p><p>قال المناوي في فيض القدير ٥/٢٩٠ (٧٣٤٢): «قال العراقي: وقولُ ابن الصلاح عن أحمد: أربعة أحاديث تدور في الأسواق لا أصل لها. منها هذا، لا يصح عن أحمد». وقال السخاوي في المقاصد الحسنة ص٥٣٧ (٨٧٣): «وسنده جيد، كما قال العراقيُّ وغيره». وقال الزرقاني في شرح الموطأ ٤/٦٦٨: «ولكن قال ابن عبد البرّ: سنده ليس بالقوي». وقال الرباعي في فتح الغفار ٢/٨٢٦ (٢٥٦٥): «رواه أحمد، وأبو داود، بإسناد ضعيف». وقال المباركفوري في تحفة الأحوذي ٣/٢٦٩: «وإسناده حسن، إلا أنه مرسل». وقال الألباني في الضعيفة ٣/٥٥٨ (١٣٧٨): «ضعيف».أخرجه أحمد ٤٥/١٢٨ (٢٧١٥٠)، وأبو داود ٣/١٠٠ (١٦٦٧)، والترمذي ٢/٢٠٣ (٦٧١)، والنسائي ٥/٨٦ (٢٥٧٤)، وابن خزيمة ٤/١٨٧ (٢٤٧٣)، وابن حبّان ٨/١٦٦-١٦٧ (٣٣٧٣)، والحاكم ١/٥٧٨ (١٥٢٤).</p><p>قال الترمذي: «حديث أم بُجَيْد حديث حسن صحيح». وقال الحاكم ١/٥٧٨: «صحيح الإسناد، ولم يُخَرِّجاه». وقال الألباني في صحيح أبي داود ٥/٣٦٠-٣٦١ (١٤٦٧): «إسناده صحيح».أخرجه ابن أبي حاتم ١/٢٩٠.أخرجه ابن أبي حاتم ١/٢٩٠.علَّقه ابن أبي حاتم ١/٢٩٠.تفسير مقاتل بن سليمان ١/١٥٧.أخرجه ابن أبي حاتم ١/٢٩٠.أخرجه ابن أبي حاتم ١/٢٩٠.تفسير مقاتل بن سليمان ١/١٥٧.عزاه السيوطي إلى عبد بن حميد.أخرجه ابن أبي حاتم ١/٢٩١، وعزاه السيوطي إلى ابن جرير، وهو عنده ٣/٨٥ من قول الربيع -كما سيأتي-.أخرجه ابن أبي حاتم ١/٢٩١.أخرجه ابن جرير ٣/٨٥. وعلَّقه ابن أبي حاتم ١/٢٩١.تفسير مقاتل بن سليمان ١/١٥٧.أخرجه ابن جرير ٣/٨٦، وابن أبي حاتم ١/٢٩١، والحاكم ٢/٢٧٣. وعزاه السيوطي إلى وكيع، وابن أبي شيبة، وعبد بن حميد، وابن المنذر، وأبي الشيخ. وفي رواية أخرى عنه عند ابن جرير: قال: البأساء: الجوع. وفي رواية أيضًا له: البأساء: الحاجة.أخرجه ابن أبي حاتم ١/٢٩١.علَّقه ابن أبي حاتم ١/٢٩١.علَّقه ابن أبي حاتم ١/٢٩١.أخرجه ابن أبي حاتم ١/٢٩١.علَّقه ابن أبي حاتم ١/٢٩١.أخرجه الطستي -كما في الإتقان ٢/٧٩-٨٠-.أخرجه ابن أبي حاتم ١/٢٩٢.أخرجه ابن أبي الدنيا في كتاب الصبر -موسوعة الإمام ابن أبي الدنيا ٤/٣٢-، وابن جرير ٣/٨٧. وعلَّقه ابن أبي حاتم ١/٢٩١.أخرجه ابن أبي حاتم ١/٢٩١-٢٩٢.أخرجه ابن جرير ٣/٨٧. وذكره يحيي بن سلام -كما في تفسير ابن أبي زمنين ١/١٩٧- مختصرًا. وعلّق شطره الأول ابن أبي حاتم ١/٢٩١. وعزاه السيوطي إلى عبد بن حميد مختصرًا.أخرجه ابن جرير ٣/٨٧، وابن أبي حاتم في شطره الثاني ١/٢٩١ كلاهما من طريق عبد الرزاق. وفي المطبوع من تفسير عبد الرزاق ١/٦٦ موقوفًا على معمر من قوله، ويبدو أنّ اسم قتادة سقط منه، والله أعلم.أخرجه ابن جرير ٣/٨٧، وابن أبي حاتم ١/٢٩١.تفسير مقاتل بن سليمان ١/١٥٧.تفسير سفيان الثوري ١/٥٥.أخرجه ابن جرير ٣/٩١، وابن أبي حاتم ١/٢٩٢، والحاكم ٢/٢٧٣. وعزاه السيوطي إلى وكيع، وابن أبي شيبة، وعبد بن حميد، وابن المنذر، وأبي الشيخ.أخرجه ابن أبي حاتم ١/٢٩٢.علَّقه ابن أبي حاتم ١/٢٩٢.أخرجه ابن جرير ٣/٩١. وعلَّقه ابن أبي حاتم ١/٢٩٢.أخرجه ابن أبي الدنيا في كتاب الصبر -موسوعة الإمام ابن أبي الدنيا ٤/٣٢-، وابن جرير ٣/٩٢.أخرجه ابن جرير ٣/٩١. وعلَّقه ابن أبي حاتم ١/٢٩١. كما أخرج نحوه ابن جرير ٣/٩٢ من طريق عبد الرزاق عن مَعمر، وهو في المطبوع من تفسير عبد الرزاق ١/٦٦ موقوفًا على معمر من قوله. وعزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ٣/٩٢، وابن أبي حاتم ١/٢٩٢.تفسير مقاتل بن سليمان ١/١٥٧.أخرجه ابن أبي حاتم ١/٢٩٢.تفسير سفيان الثوري ١/٥٥.أخرجه أحمد ٢/٤٥٣، والنسائي في الكبرى ٨/٣٤، وأبو يعلى ١/٣٥٨.</p><p>وقال محققو هذه الكتب: «إسناده صحيح». ويشهد له حديث البراء بن عازب التالي.أخرجه مسلم ٣/١٤٠١، وأحمد ٣٠/٤٤١.أخرجه ابن أبي حاتم ١/٢٩٢.أخرجه ابن أبي حاتم ١/٢٩٢.أخرجه ابن جرير ٣/٩٣، وابن أبي حاتم ١/٢٩٢.أخرجه ابن أبي حاتم ١/٢٩٢.تفسير مقاتل بن سليمان ١/١٥٧.عزاه السيوطي إلى وكيع، وابن المنذر. وأخرجه ابن أبي شيبة (ت: محمد عوامة) ١٩/٢٨٤ (٣٦٠٥٣) بلفظ: فقد استكمل البِرّ.أخرجه ابن عساكر ٧/٢٤.
  2,178,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿یَـٰۤأَیُّهَا ٱلَّذِینَ ءَامَنُوا۟ كُتِبَ عَلَیۡكُمُ ٱلۡقِصَاصُ فِی ٱلۡقَتۡلَىۖ﴾</span> - نزول الآية</h3></p><p><div></p><p><p><span class="item-no">٥٠٩١<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span> -من طريق عطاء بن دينار- قال: إنَّ حَيَّيْنِ من العرب اقتتلوا في الجاهلية قبل الإسلام بقليل، فكان بينهم قتل وجراحات، حتى قتلوا العبيد والنساء، فلم يأخذ بعضهم من بعض حتى أسلموا، فكان أحد الحيَّيْنِ يتطاول على الآخر في العُدَّة والأموال، فحلفوا أن لا يرضوا حتى يُقْتَل بالعبد منّا الحُرُّ منهم، وبالمرأة مِنّا الرجلُ منهم؛ فنزل فيهم: <span class="qpc-hafs">﴿يا أيها الذين آمنوا كتب عليكم القصاص في القتلى الحر بالحر والعبد بالعبد والأنثى بالأنثى﴾</span>. وذلك أنهم كانوا لا يقتلون الرجل بالمرأة، ولكن يقتلون الرجل بالرجل، والمرأة بالمرأة؛ فأنزل الله: <span class="qpc-hafs">﴿النفس بالنفس﴾</span> [المائدة:٤٥]، فجعل الأحرار في القصاص سواء فيما بينهم من العمد؛ رجالهم ونساؤهم، في النفس وما دون النفس، وجعل العبيد مستويين في العمد؛ النفس وما دون النفس، رجالهم ونساؤهم{1}. (٢/١٥٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٩٢<span class="dash">-</span></span> عن <span class="name-2">عامر الشعبي</span> -من طريق داود بن أبي هند- قال: نزلت هذه الآية في قبيلتين من قبائل العرب اقتتلتا قتال عِمِّيَّة{2} على عهد الرسول ﷺ، فقالوا: نقتُل بعبدنا فلانَ بن فلان، ونقتُل بأمَتِنا فلانةَ بنت فلان. فأنزل الله: <span class="qpc-hafs">﴿الحر بالحر والعبد بالعبد والأنثى بالأنثى﴾</span>{3}. (٢/١٥٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٩٣<span class="dash">-</span></span> عن <span class="name-2">أبي الجوزاء</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٩٤<span class="dash">-</span></span> و<span class="name-3">الكلبي</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٩٥<span class="dash">-</span></span> و<span class="name-3">مقاتل بن حيان</span>، نحوه{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٩٦<span class="dash">-</span></span> عن <span class="name-2">أبي مالك</span> -من طريق السدي- قال: كان بين حَيَّيْن من الأنصار قتال، كان لأحدهما على الآخر الطَّوْل، فكأنهم طلبوا الفَضْل، فجاء النبي ﷺ ليصلح بينهم؛ فنزلت الآية: <span class="qpc-hafs">﴿الحر بالحر والعبد بالعبد والأنثى بالأنثى﴾</span>{5}. (٢/١٥٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٩٧<span class="dash">-</span></span> قال <span class="name-2">الحسن البصري</span>: كان أهل الجاهلية فيهم بَغْيٌ، قد كان إذا قُتِل من الحي منهم مملوكٌ قَتَلَه حيٌّ آخرون، قالوا: لا نَقْتُل به إلا حُرًّا. وإذا قُتِل من الحيِّ منهم امرأةٌ قتَلها حيٌّ آخرون، قالوا: لا نقتل بها إلا رجلًا. فأنزل الله ﷿ هذه الآية، ونهاهم عن البغي{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٩٨<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دِعامة</span> -من طريق مَعْمَر- قال: لم يكن لِمَن كان قبلنا دِيَةٌ، إنما هو القتل أو العفو؛ فنزلت هذه الآية في قوم أكثر من غيرهم، فكانوا إذا قُتِل من الكثير عبدٌ قالوا: لا نَقْتُلُ به إلا حُرًّا. وإذا قُتِلَت منهم امرأةٌ قالوا: لا نَقْتُلُ بها إلا رجلًا. فأنزل الله: <span class="qpc-hafs">﴿الحر بالحر والعبد بالعبد والأنثى بالأنثى﴾</span>{7}. (٢/١٥٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٩٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿يا أيها الذين آمنوا كتب عليكم القصاص في القتلى﴾</span>، وذلك أنّ حيَّيْن من العرب اقتتلوا في الجاهلية قبل الإسلام بقليل، وكانت بينهم قتلى وجرحى، حتى قُتِل العبيد والنساء، فلم يأخذ بعضهم من بعضٍ الأموالَ حتى أسلموا، وكان أحد الحيَّيْن له طَوْلٌ على الآخر في العدد والأموال، فحلفوا: ألّا نرضى حتى يُقتل بالعبد منا الحرُّ منهم، وبالمرأة منّا الرجلُ منهم. فأنزل الله ﷿: <span class="qpc-hafs">﴿الحر بالحر والعبد بالعبد والأنثى بالأنثى﴾</span>. فسوّى بينهم في الدماء، وأمرهم بالعدل، فَرَضُوا، فصارت منسوخة، نسختها الآية التي في المائدة [آية:٤٥]{8}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿یَـٰۤأَیُّهَا ٱلَّذِینَ ءَامَنُوا۟ كُتِبَ عَلَیۡكُمُ ٱلۡقِصَاصُ فِی ٱلۡقَتۡلَىۖ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥١٠٠<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جُبَيْر</span> -من طريق عطاء بن دينار- في قول الله: <span class="qpc-hafs">﴿يا أيها الذين امنوا كتب عليكم القصاص في القتلى﴾</span>، يعني: إذا كان عَمْدًا{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥١٠١<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span>، نحو ذلك{10}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥١٠٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿يا أيها الذين آمنوا كتب عليكم القصاص في القتلى﴾</span> إذا كان عَمْدًا{8}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿ٱلۡحُرُّ بِٱلۡحُرِّ وَٱلۡعَبۡدُ بِٱلۡعَبۡدِ وَٱلۡأُنثَىٰ بِٱلۡأُنثَىٰۚ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥١٠٣<span class="dash">-</span></span> عن <span class="name-1">علي بن أبي طالب</span> -من طريق الربيع- في قوله: <span class="qpc-hafs">﴿يا أيها الذين آمنوا كتب عليكم القصاص في القتلى الحر بالحر والعبدُ بالعبد والأنثى بالأنثى﴾</span>، قال: أيُّما حُرٍّ قَتَل عبدًا فهو قَوَدٌ به؛ فإن شاء مَوالي العبدِ أن يقتلوا الحُرَّ قتلوه، وقاصُّوهم بثمن العبد من دِيَة الحُرِّ، وأدَّوا إلى أولياء الحُرِّ بَقِيَّة دِيَتِه. وأيُّ عبد قَتَلَ حرًّا فهو به قَوَدٌ؛ فإن شاء أولياء الحُرِّ قتلوا العبد، وقاصُّوهم بثمن العبد، وأخذوا بقية دِيَة الحُرِّ، وإن شاؤوا أخذوا الديّة كلّها واستحيَوُا العبد. وأيُّ حُرٍّ قَتَل امرأةً فهو بها قَوَدٌ، فإن شاء أولياء المرأة قَتلوه وأدّوا نصفَ الدية إلى أولياء الحرّ. وإن امرأةٌ قتلتْ حُرًّا فهي به قَوَدٌ، فإن شاء أولياء الحر قتلوها وأخذوا نصف الدية، وإن شاؤوا أخذوا الدية كلها واسْتَحْيَوْها، وإن شاؤوا عفَوْا{12}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥١٠٤<span class="dash">-</span></span> عن <span class="name-1">عليّ</span> -من طريق الحسن- قال في رجل قَتَلَ امرأتَه: إن شاؤوا قتلوه، وغَرِموا نصف الدِّيَة{13}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥١٠٥<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- قال: دخل في قول الله -تعالى ذِكْرُه-: <span class="qpc-hafs">﴿الحر بالحر﴾</span> الرجلُ بالمرأة، والمرأةُ بالرجل.= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥١٠٦<span class="dash">-</span></span> وقال <span class="name-2">عطاء</span>: ليس بينهما فَضْل{7}<span class=comment-ref>٦٢١</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٢١</span> <span class="comment-type-3">رجَّحَ</span> <u>ابنُ جرير</u> (٣/٩٤، ١٠٠-١٠١ بتصرف) أنّ نفس الرجل الحر قَوَد قصاصًا بنفس المرأة الحرة، وأنّ معنى الآية: أن لا يتعدى بالقصاص إلى غير القاتل والجاني، فيؤخذ بالأنثى الذكر، وبالعبد الحر. <span class="mustanad">استنادًا إلى دلالة القرآن، والسُّنَّة، والقياس</span>، فقال: «فإن قال قائل: فإنه -تعالى ذِكْرُه- قال: <span class="qpc-hafs">﴿كُتب عليكم القصاص في القتلى الحر بالحرّ والعبدُ بالعبد والأنثى بالأنثى﴾</span>، فما لنا أن نقتص للحر إلا من الحر، ولا للأنثى إلا من الأنثى؟ قيل: بل لنا أن نقتص للحر من العبد، وللأنثى من الذَّكَر بقول الله -تعالى ذِكْرُه-: <span class="qpc-hafs">﴿ومَن قُتِلَ مَظْلُومًا فَقَدْ جَعَلْنا لِوَلِيِّهِ سُلْطانًا﴾</span> [الإسراء:٣٣]، وبالنقل المستفيض عن رسول الله ﷺ أنه قال: «المسلمون تَتَكافأ دماؤهم»». وقال: «قد تظاهرت الأخبار عن رسول الله ﷺ بالنقل العام أنّ نفس الرجل الحر قَوَدٌ قصاصًا بنفس المرأة الحرة، فإذ كان ذلك كذلك، وكانت الأمَّة مختلفة في التراجع بفضل ما بين دية الرجل والمرأة على ما قد بينّا من قول عليٍّ وغيره، وكان واضحًا فساد قول مَن قال بالقصاص في ذلك والتراجع بفضل ما بين الديتين بإجماع جميع أهل الإسلام على أنّ حرامًا على الرجل أن يتلف من جسده عضوًا بعوض يأخذه على إتلافه -فدع ما جميعه-، وعلى أنّ حرامًا على غيره إتلاف شيء منه مثل الذي حرم من ذلك بِعِوَضٍ يعطيه عليه؛ فالواجب أن تكون نَفْسُ الرجل الحر بنَفْسِ المرأة الحرة قَوَدًا. وإذا كان ذلك كذلك كان بيِّنًا بذلك أنّه لم يُرِد بقوله -تعالى ذِكْرُه-: <span class="qpc-hafs">﴿الحر بالحر والعبد بالعبد والأنثى بالأنثى﴾</span> أن لا يقاد العبد بالحر، وأن لا تقتل الأنثى بالذكر، ولا الذكر بالأنثى. وإذا كان ذلك كذلك كان بَيِّنًا أنّ الآية مَعْنِيٌّ بها أحدُ المعنيين الآخرين: إما قولنا من أن لا يتعدى بالقصاص إلى غير القاتل والجاني، فيؤخذ بالأنثى الذكر، وبالعبد الحر. وإما القول الآخر وهو أن تكون الآية نزلت في قوم بأعيانهم خاصةً، أمر النبي ﷺ أن يجعل ديات قتلاهم قصاصًا بعضها من بعض، كما قاله السدي ومَن ذكرنا قوله. وقد أجمع الجميع لا خلاف بينهم على أن المقاصّة في الحقوق غير واجبة، وأجمعوا على أنّ الله لم يقض في ذلك قضاء ثم نسخه، وإذا كان كذلك، وكان قوله -تعالى ذِكْرُه-: <span class="qpc-hafs">﴿كتب عليكم القصاص﴾</span> يُنبِئُ على أنه فرض؛ كان معلومًا أن القول خلاف ما قاله قائل هذه المقالة؛ لأن ما كان فرضًا على أهل الحقوق أن يفعلوه فلا خيار لهم فيه، والجميع مجمعون على أن لأهل الحقوق الخيار في مقاصّتهم حقوقهم بعضها من بعض، فإذا تبين فساد هذا الوجه الذي ذكرنا؛ فالصحيح من القول في ذلك هو ما قلنا».</div></p><p><div></p><p><p><span class="item-no">٥١٠٧<span class="dash">-</span></span> عن <span class="name-2">عامر الشعبي</span> -من طريق داود- في هذه الآية: <span class="qpc-hafs">﴿كتب عليكم القصاص في القتلى الحر بالحرّ والعبد بالعبد والأنثى بالأنثى﴾</span>، قال: إنما ذلك في قتال عِمِّيَّة، إذا أصيب من هؤلاء عبدٌ ومن هؤلاء عبدٌ تكافآ، وفي المرأتين كذلك، وفي الحُرَّيْن كذلك. هذا معناه إن شاء الله{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥١٠٨<span class="dash">-</span></span> عن <span class="name-2">عامر الشعبي</span>-من طريق ابن أشْوَع- قال: كان بين حَيَّيْنِ من العرب قتال، فقُتل من هؤلاء ومن هؤلاء، فقال أحد الحَيَّيْن: لا نرضى حتى نَقْتُل بالمرأة الرجل، وبالرجل الرجلين. قال: فأبى عليهم الآخرون، فارتفعوا إلى النبي ﷺ، قال: فقال النبي ﷺ: «<b>القتل بَواءٌ</b>». أي: سواء، قال: فاصطلح القوم بينهم على الدِّيات. قال: فحسبوا للرجل دية الرجل، وللمرأة دية المرأة، وللعبد دية العبد، فقضى لأحد الحيين على الآخر. قال: فهو قوله: <span class="qpc-hafs">﴿يا أيها الذين آمنوا كتب عليكم القصاص في القتلى الحر بالحر، والعبد بالعبد، والأنثى بالأنثى﴾</span>{16}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥١٠٩<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق عوف- قال: لا يُقتل الرجل بالمرأة، حتى يُعطوا نِصْفَ الدِّيَة{12}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥١١٠<span class="dash">-</span></span> عن ابن جُرَيْج، قال: قلتُ <span class="name-2">لعطاء</span>: ما قول الله ﷿: <span class="qpc-hafs">﴿الحر بالحر والعبد بالعبد﴾</span>؟ قال: العبدُ يقتل العبدَ عَمْدًا فهو به، فإن كان القاتلُ أفضلَ لم يكن لهم إلا قيمةُ المقتول{18}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥١١١<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السدي</span> -من طريق أسباط- في قوله: <span class="qpc-hafs">﴿كتب عليكم القصاص في القتلى الحر بالحر والعبدُ بالعبد والأنثى بالأنثى﴾</span>، قال: اقْتَتَل أهلُ ماءَيْن من العرب، أحدهما مسلم والآخر مُعاهَد، في بعض ما يكون بين العرب من الأمر، فأصلح بينهم النبيُّ ﷺ -وقد كانوا قَتَلوا الأحرار والعبيد والنساء- على أن يؤدِّي الحرُّ دِيةَ الحُرِّ، والعبدُ ديةَ العبد، والأنثى دية الأنثى، فقاصَّهم بعضَهم من بعض{19}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥١١٢<span class="dash">-</span></span> قال شعبة: قلتُ <span class="name-2">لأبي بِشْر [جعفر بن إياس]</span>: كيف كان ذلك؟ يعني: قول الله: <span class="qpc-hafs">﴿كتب عليكم القصاص في القتلى الحر بالحر والعبد بالعبد والأنثى بالأنثى﴾</span>. فقال: كان يُقْتَل الرجل -يعني: بالرجل-، ويُتْرَك العبد بالعبد{20}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿ٱلۡحُرُّ بِٱلۡحُرِّ وَٱلۡعَبۡدُ بِٱلۡعَبۡدِ وَٱلۡأُنثَىٰ بِٱلۡأُنثَىٰۚ﴾</span> - النسخ في الآية</h3></p><p><div></p><p><p><span class="item-no">٥١١٣<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق جُوَيْبِر، عن الضحاك-: <span class="qpc-hafs">﴿الحر بالحر والعبد بالعبد والأنثى بالأنثى﴾</span>، قال: نسختها <span class="qpc-hafs">﴿وكتبنا عليهم فيها أن النفس بالنفس﴾</span> [المائدة:٤٥] الآية{21}. (٢/١٥٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥١١٤<span class="dash">-</span></span> قال <span class="name-1">ابن عباس</span>: نسختها <span class="qpc-hafs">﴿النفس بالنفس﴾</span> [المائدة:٤٥]{22}. (٢/١٥٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥١١٥<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي بن أبي طلحة- قال: كانوا لا يقتلون الرجل بالمرأة، ولكن يقتلون الرجل بالرجل، والمرأة بالمرأة؛ فأنزل الله: <span class="qpc-hafs">﴿النفس بالنفس﴾</span> [المائدة:٤٥]. فجعل الأحرار في القصاص سواء فيما بينهم في العمد؛ رجالهم ونساؤهم، في النفس وما دون النفس، وجعل العبيد مستوين في العمد؛ في النفس وما دون النفس، رجالهم ونساؤهم{23}. (٢/١٥٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥١١٦<span class="dash">-</span></span> قال <span class="name-2">الحسن البصري</span>: ... أنزل الله ﷿ هذه الآية، ونهاهم عن البغي، ثم أنزل الله بعد ذلك في المائدة: <span class="qpc-hafs">﴿وكتبنا عليهم فيه أن النفس بالنفس﴾</span> [الآية:٤٥]، يعني: النفس التي قَتَلت بالنفس التي قُتِلت؛ وهذا في الأحرار{24}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥١١٧<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دِعامة</span> -من طريق شَيْبان- في الآية، قال: كان أهل الجاهلية فيهم بَغْيٌ وطاعة للشيطان، فكان الحيُّ منهم إذا كان فيهم عَدَد وعُدَّة، فقتَل لهم عبدًا عبدُ قومٍ آخرين، فقالوا: لن نقتل به إلا حُرًّا. تعزُّزًا وتفضُّلًا على غيرهم في أنفسهم، وإذا قُتلت لهم أنثى قتلتها امرأة، قالوا: لن نقتل بها إلا رجلًا. فأنزل الله هذه الآية يخبرهم أنّ العبد بالعبد، والحر بالحر، والأنثى بالأنثى، وينهاهم عن البغي. ثم أنزل سورة المائدة فقال: <span class="qpc-hafs">﴿وكتبنا عليهم فيها أن النفس بالنفس﴾</span> [المائدة:٤٥] الآية{25}. (٢/١٥٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥١١٨<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ... صارت منسوخة، نسختها الآية التي في المائدة [الآية:٤٥ ]قوله سبحانه: <span class="qpc-hafs">﴿وكتبنا﴾</span> فيما قضينا <span class="qpc-hafs">﴿عليهم فيها أن النفس بالنفس﴾</span>، يعني: <span class="qpc-hafs">﴿النفس﴾</span> المسلم الحرّ <span class="qpc-hafs">﴿بالنفس﴾</span> المسلم الحرّ، والمسلمة الحرّة بالمسلمة الحرّة{8}<span class=comment-ref>٦٢٢</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٢٢</span> <span class="comment-type-2">انتقد</span> <u>ابنُ عطية</u> هذا القول، فقال: «آية المائدة إنما هي إخبار عما كُتِب على بني إسرائيل، فلا يترتب النسخ إلا بما تُلِقِّي عن رسول الله ﷺ، من أن حُكْمنا في شرعنا مثل حُكْمهم».</div></p><p><h3><span class="qpc-hafs">﴿فَمَنۡ عُفِیَ لَهُۥ مِنۡ أَخِیهِ شَیۡءࣱ فَٱتِّبَاعُۢ بِٱلۡمَعۡرُوفِ وَأَدَاۤءٌ إِلَیۡهِ بِإِحۡسَـٰنࣲۗ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥١١٩<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عمرو</span> -من طريق مجاهد- <span class="qpc-hafs">﴿وأداء اليه بإحسان﴾</span>، قال: ذلك في الدِّيَة{27}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥١٢٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق جابر بن زيد- <span class="qpc-hafs">﴿فمن عفي له﴾</span> قال: هو العَمَد يرضى أهلُه بالدية؛ <span class="qpc-hafs">﴿فاتباع بالمعروف﴾</span> أُمِر به الطالِب، <span class="qpc-hafs">﴿وأداء إليه بإحسان﴾</span> قال: يُؤَدِّي المطلوبَ بإحسان{28}. (٢/١٥٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥١٢١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق أبي رَوْق، عن الضحاك- في قوله: <span class="qpc-hafs">﴿فمن عفي له﴾</span> يقول: من تُرك له <span class="qpc-hafs">﴿من أخيه شيء﴾</span> بعد أخذ الدية بعد استحقاق الدم، وذلك العفو؛ <span class="qpc-hafs">﴿فاتباع بالمعروف﴾</span> يقول: فعلى الطالب اتِّباعٌ بالمعروف إذا قَبِل الدِّيَة، <span class="qpc-hafs">﴿وأداء إليه بإحسان﴾</span> من القاتل في غير ضرورة ولا مَعْكٍ -يعني: المدافعة-{29}<span class=comment-ref>٦٢٣</span>. (٢/١٥٦)</p></p><p></div></p><p><div><span class=comment-ref>٦٢٣</span> <span class="comment-type-4">ذكر</span> <u>ابنُ عطية</u> (١/٤٢٥بتصرف) أنّ الأخ -على هذا القول- هو المقتول، ثم قال: «ويصح أن يكون هو الولي ...، والعفو في هذا القول على بابه».</div></p><p><div></p><p><p><span class="item-no">٥١٢٢<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط-، نحو ذلك{29}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥١٢٣<span class="dash">-</span></span> وعن <span class="name-2">عطاء الخراساني</span>، نحو ذلك. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥١٢٤<span class="dash">-</span></span> وعن <span class="name-2">جابر بن زيد</span>، نحو الشطر الأول من ذلك. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥١٢٥<span class="dash">-</span></span> وعن <span class="name-2">سعيد بن جبير</span>، نحو الشطر الثاني من ذلك{31}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥١٢٦<span class="dash">-</span></span> عن <span class="name-3">مقاتل بن حيان</span> -من طريق بُكَيْر بن معروف-، نحو شطره الثاني{29}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥١٢٧<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق مجاهد- قال: كان في بني إسرائيل القصاص، ولم يكن فيهم الدية، فقال الله لهذه الأمة: <span class="qpc-hafs">﴿كتب عليكم القصاص في القتلى﴾</span> إلى قوله: <span class="qpc-hafs">﴿فمن عفي له من أخيه شيء﴾</span> فالعفو أن يَقْبلَ الدية في العمد، <span class="qpc-hafs">﴿فاتباع بالمعروف وأداء إليه بإحسان﴾</span> يتبعُ الطالبَ بالمعروف، ويؤدي إليه المطلوب بإحسان، <span class="qpc-hafs">﴿ذلك تخفيف من ربكم ورحمة﴾</span> مِمّا كُتب على من كان قبلكم، <span class="qpc-hafs">﴿فمن اعتدى بعد ذلك﴾</span> قَتَلَ بعد قَبُول الدية <span class="qpc-hafs">﴿فله عذاب أليم﴾</span>{33}. (٢/١٥٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥١٢٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق مجاهد- قال: كانت بنو إسرائيل إذا قُتِل فيهم القتيلُ عمدًا لا يحل لهم إلا القَوَد، وأَحَلَّ الله الدِّيَة لهذه الأمة، فأَمَر هذا أن يَتْبَع بمعروف، وأَمَر هذا أن يُؤدِّي بإحسان، <span class="qpc-hafs">﴿ذلك تخفيف من ربكم﴾</span>{34}. (٢/١٥٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥١٢٩<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق مجاهد- قال: الذي يقبل الدِّيَة، ذلك منه عفوٌ، فاتباعٌ بالمعروف، ويؤدِّي إليه الذي عُفِي له من أخيه بإحسان{35}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥١٣٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق العوفي- في قوله: <span class="qpc-hafs">﴿فمن عُفي له من أخيه شيء فاتباع بالمعروف وأداءٌ إليه بإحسان﴾</span> قال: وهي الدية، أن يحسن الطالبُ الطلبَ، <span class="qpc-hafs">﴿وأداء إليه بإحسان﴾</span> وهو أن يحسن المطلوبُ الأداءَ{36}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥١٣١<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span> -من طريق عطاء بن دينار- في قوله: <span class="qpc-hafs">﴿فاتباع بالمعروف﴾</span>، يعني: لِيَطْلُبَ وليّ المقتول في الرِّفْقِ{29}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥١٣٢<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نَجِيح- <span class="qpc-hafs">﴿فمن عُفي له من أخيه شيء فاتباع بالمعروف﴾</span>، قال: العَفُوُّ: الذي يعفو عن الدَّمِ، ويأخذ الدِّيَة{38}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥١٣٣<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق القاسم بن أبي بَزَّة- قال: إذا قَبِل الدِّيَة فقد عفا عن القصاص، فذلك قوله: <span class="qpc-hafs">﴿فمن عُفي له من أخيه شيء﴾</span>{39}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥١٣٤<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق الأعرج-، مثل ذلك، وزاد: فإذا قَبِل الدِّيَة فإن عليه أن يَتَّبِع بالمعروف، وعلى الذي عُفِي عنه أن يُؤَدِّي بإحسان{39}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥١٣٥<span class="dash">-</span></span> عن <span class="name-2">عامر الشعبي</span> -من طريق داود بن أبي هند- في قوله: <span class="qpc-hafs">﴿فمن عُفي له من أخيه شيء فاتباع بالمعروف وأداء إليه بإحسان﴾</span>، قال: هو العَمْد، يرضى أهلُه بالدِّيَة{41}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥١٣٦<span class="dash">-</span></span> وعن <span class="name-2">أبي العالية</span> -من طريق الربيع بن أنس-= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥١٣٧<span class="dash">-</span></span> و<span class="name-3">مقاتل بن حيان</span> -من طريق بُكَيْر بن معروف-، نحو ذلك{20}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥١٣٨<span class="dash">-</span></span> وعن <span class="name-2">جابر بن زيد</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥١٣٩<span class="dash">-</span></span> و<span class="name-2">سعيد بن جبير</span>، نحو ذلك{43}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥١٤٠<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق يزيد بن إبراهيم-: <span class="qpc-hafs">﴿وأداء إليه بإحسان﴾</span>، قال: على هذا الطالب أن يطلبَ بالمعروف، وعلى هذا المطلوب أن يُؤَدِّي بإحسان{44}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥١٤١<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق أبي عقيل-: أخْذُ الدِّيَة عَفْوٌ حَسَنٌ{45}<span class=comment-ref>٦٢٤</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٢٤</span> <span class="comment-type-4">علَّقَ</span> <u>ابنُ جرير</u> (٣/١٠٩) على قول الحسن قائلًا: «والواجب على تأويل القول الذي روينا عن علي والحسن -في قوله: <span class="qpc-hafs">﴿كُتب عليكم القصاص﴾</span> أنه بمعنى: مُقاصّة دِيَة النفس الذكَر من دية نَفس الأنثى، والعبد من الحر، والتراجع بفضل ما بين ديتي أنفسهما- أن يكون معنى قوله: <span class="qpc-hafs">﴿فمنْ عُفي له من أخيه شيء﴾</span>: فمن عُفي له من الواجب لأخيه عليه من قصاص دية أحدهما بدية نفس الآخر إلى الرِّضا بدية نفس المقتول فاتِّباع من الوليّ بالمعروف، وأداء من القاتل إليه ذلك بإحسان».</div></p><p><div></p><p><p><span class="item-no">٥١٤٢<span class="dash">-</span></span> عن ابن جُرَيْج، قال: قلتُ <span class="name-2">لعطاء [بن أبي رباح]</span> في قوله: <span class="qpc-hafs">﴿فمن عُفي له من أخيه شيء فاتباع بالمعروف وأداء إليه بإحسان﴾</span>. قال: ذلك إذا أخذ الدية، فهو عَفْوٌ{46}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥١٤٣<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دِعامة</span> -من طريق مَعْمَر- <span class="qpc-hafs">﴿فمن عفى له من أخيه شيء﴾</span> قال: إذا قتل الرجلُ عمدًا، ثُمَّ أُخِذَت منه الدِّيَة؛ فقد عُفِي له عن القتل، <span class="qpc-hafs">﴿فاتباع بالمعروف﴾</span> قال: يتبع الطالبُ بالمعروف، ويؤدي إليه المطلوبُ بإحسان{47}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥١٤٤<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دِعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿فمن عُفي له من أخيه شَيء فاتباع بالمعروف وأداء إليه بإحسان﴾</span>، يقول: من قَتَل عمدًا فعُفي عنه، وقُبِلَت منه الدية. يقول: <span class="qpc-hafs">﴿فاتباع بالمعروف﴾</span> فأَمَرَ المُتَّبِعَ أن يَتَّبِع بالمعروف، وأَمَرَ المؤدِّيَ أن يُؤَدِّي بإحسان، والعَمد قَوَدٌ إليه قصاص، لا عَقل فيه، إلا أن يرضَوا بالدية، فإن رضُوا بالدية، فمئة خَلِفَة. فإن قالوا: لا نرضى إلا بكذا وكذا. فذاك لهم{48}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥١٤٥<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السدي</span> -من طريق أسباط- <span class="qpc-hafs">﴿فمنَ عُفي له من أخيه شيء﴾</span>، يقول: بَقِي له من دية أخيه شَيءٌ، أو من أرْشِ جراحته؛ فَلْيَتِّبِع بمعروف، ولْيُؤَدِّ إليه الآخرُ بإحسان{49}<span class=comment-ref>٦٢٥</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٢٥</span> <span class="comment-type-4">علَّقَ</span> <u>ابنُ جرير</u> (٣/١٠٩) على قول السّدّيّ بقوله: «هذا قولُ مَن زعم أنّ الآية نزلت في الذين تحاربوا على عهد رسول الله ﷺ، فأُمِر رسول الله ﷺ أن يُصلح بينهم، فيقاصَّ ديات بعضهم من بعض، وأحسب أن قائلي هذا القول وجَّهوا تأويل العفو -في هذا الموضع- إلى الكثرة، من قول الله -تعالى ذكره-: <span class="qpc-hafs">﴿حَتّى عَفَوْا﴾</span> [الأعراف:٩٥]. فكأنّ معنى الكلام عندهم: فمن كَثُرَ له قبَل أخيه القاتل».</p><p>و<span class="comment-type-4">بنحوه</span> قال <u>ابن عطية</u> (١/٤٢٥).</div></p><p><div></p><p><p><span class="item-no">٥١٤٦<span class="dash">-</span></span> عن <span class="name-2">الربيع بن أنس</span> -من طريق أبي جعفر- في قوله: <span class="qpc-hafs">﴿فمن عُفي له من أخيه شيء فاتباع بالمعروف وأداء إليه بإحسان﴾</span> يقول: فمن قَتَل عمدًا فعُفِي عنه، وأُخذت منه الدية، يقول: <span class="qpc-hafs">﴿فاتباع بالمعروف﴾</span> أمَر صاحبَ الدية الذي يأخذها أن يتبع بالمعروف، وأَمَر المؤدِّي أن يؤدي بإحسان{50}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥١٤٧<span class="dash">-</span></span> عن <span class="name-3">مقاتل بن حيان</span> -من طريق بُكَيْر بن معروف- في قوله: <span class="qpc-hafs">﴿فاتباع بالمعروف﴾</span>، قال: لِيُحْسِن الطَّلَب{29}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥١٤٨<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فمن عفي له من أخيه شيء﴾</span>، ثم رجع إلى أوّل الآية في قوله سبحانه: <span class="qpc-hafs">﴿كتب عليكم القصاص في القتلى﴾</span> إذا كان عمدًا إذا عفا وليُّ المقتول عن أخيه القاتل ورضِيَ بالدية <span class="qpc-hafs">﴿فاتباع بالمعروف﴾</span> يعني: الطالب ليطلب ذلك في رفق، ثم قال للمطلوب: <span class="qpc-hafs">﴿وأداء إليه بإحسان﴾</span> يقول: ليؤدي الدية إلى الطالب عفوًا في غير مشقة ولا أذًى{52}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥١٤٩<span class="dash">-</span></span> عن <span class="name-3">سفيان بن حسين</span> -من طريق عباد بن العوام- في قوله تعالى: <span class="qpc-hafs">﴿فمن عفي له من أخيه شيء﴾</span>، قال: فمن فَضُل له على أخيه شيءٌ فليُؤَدِّه بالمعروف، وليَتبعه الطالب بإحسان{53}<span class=comment-ref>٦٢٦</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٢٦</span> <span class="comment-type-3">رجَّح</span> <u>ابنُ جرير</u> (٣/١٠٩ بتصرف) <span class="mustanad">مستندًا إلى السياق</span>، فقال: «أولى الأقوال عندي بالصواب في قوله: <span class="qpc-hafs">﴿فمن عُفي له من أخيه شيء﴾</span>: فمن صُفِح له -من الواجب كان لأخيه عليه من القود- عن شيء من الواجب، على ديّة يأخذها منه، فاتباعٌ بالمعروف من العافي عن الدم، الراضي بالدية من دم وليّه، وأداء إليه -من القاتل- ذلك بإحسان. لِما قد بيّنّا فيما مضى قبلُ مِن أنّ معنى قول الله -تعالى ذِكْرُه-: <span class="qpc-hafs">﴿كُتب عليكم القصاص﴾</span>: إنما هو القصاص من النفوس القاتلة أو الجارحة أو الشاجَّة عمدًا، كذلك العفو أيضًا عن ذلك».</div></p><p><div></p><p><p><span class="item-no">٥١٥٠<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- <span class="qpc-hafs">﴿وأداء إليه بإحسان﴾</span>، قال: أنتَ أيها المعفوُّ عنه{39}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿ذَ ٰ⁠لِكَ تَخۡفِیفࣱ مِّن رَّبِّكُمۡ وَرَحۡمَةࣱۗ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥١٥١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق جابر بن زيد-: <span class="qpc-hafs">﴿ذلك تخفيف من ربكم ورحمة﴾</span> مِمّا كان على بني إسرائيل{55}. (٢/١٥٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥١٥٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق أبي رَوْق، عن الضحاك- في قوله: <span class="qpc-hafs">﴿ذلك تخفيف من ربكم ورحمة﴾</span>، يقول: رفق{27}. (٢/١٥٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥١٥٣<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق مجاهد- قال: كان على بني إسرائيل قصاص في القتلى، ليس بينهم دية في نَفْس ولا جرح، وذلك قول الله: <span class="qpc-hafs">﴿وكتبنا عليه فيها أن النفس بالنفس﴾</span> [المائدة:٤٥] الآية، وخفَّف الله عن أمّة محمد؛ فقبل منهم الدِّيَة في النفس وفي الجراحة، وذلك قوله: <span class="qpc-hafs">﴿ذلك تخفيف من ربكم﴾</span> بينكم{57}. (٢/١٥٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥١٥٤<span class="dash">-</span></span> قال الشافعي: أخبرنا معاذ بن موسى، عن بُكَير بن معروف، عن مقاتل بن حيان، قال مقاتل: أخذت هذا التفسيرَ عن نفرٍ، حَفِظَ معاذٌ منهم <span class="name-2">مجاهدًا</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥١٥٥<span class="dash">-</span></span> و<span class="name-2">الحسنَ</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥١٥٦<span class="dash">-</span></span> و<span class="name-2">الضحاكَ بن مزاحم</span>، في قول الله -تبارك وتعالى-: <span class="qpc-hafs">﴿فمن عفي له من أخيه شيء فاتباعٌ بالمعروف﴾</span> الآية، قالوا: كان على أهل التوراة مَن قَتَل نفسًا بغير نفس أن يُقاد بها، ولا يُعفى عنه، ولا تقبل منه الدية. وفُرِض على أهل الإنجيل أن يُعفى عنه، ولا يُقْتَل. ورُخّص لأمة محمد ﷺ إن شاء قَتَل، وإن شاء أخذ الدية، وإن شاء عفا. فذلك قوله تعالى: <span class="qpc-hafs">﴿ذلك تخفيف من ربكم ورحمة﴾</span> يقول: الدية تخفيف من الله تعالى؛ إذ جعل الدية ولا يقتل، ثم قال: <span class="qpc-hafs">﴿فمن اعتدى بعد ذلك فله عذاب أليم﴾</span>{58}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥١٥٧<span class="dash">-</span></span> عن <span class="name-2">أبي العالية</span> -من طريق الربيع بن أنس- <span class="qpc-hafs">﴿تخفيف من ربكم ورحمة﴾</span>، يقول: حين أُطعِمتم الدية، ولم تحِلَّ لأهل التوراة، إنما هو قصاص أو عفو، وكان أهل الإنجيل إنما هو عفو وليس غيره، فجعل الله لهذه الأمة القَوَد، والدِّية، والعفو{59}. (١/١٦٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥١٥٨<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span> -من طريق عطاء بن دينار- في قوله: <span class="qpc-hafs">﴿ذَلِكَ تَخْفِيفٌ مِن رَبِّكُمْ ورَحْمَةٌ﴾</span>، يعني: ولترحموا{27}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥١٥٩<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن سمعان- يقول: في قوله: <span class="qpc-hafs">﴿ذَلِكَ تَخْفِيفٌ مِن رَبِّكُمْ ورَحْمَةٌ﴾</span>، يقول: في نكاح الإماء، يقول: لا بأس به{61}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥١٦٠<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دِعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿ورحمة﴾</span>، قال: هي رحمة رَحِم بها الله هذه الأمّة، أطعمهم الديّة، وأحلّها لهم، ولم تَحِلَّ لأحد قبلهم، فكان في أهل التوراة إنما هو القصاص أو العفو، ليس بينهما أرْش، فكان أهل الإنجيل إنما هو عفوٌ أمروا به، وجعل الله لهذه الأمة القتل، والعفو، والدية إن شاؤوا، أحلّها لهم، ولم يكن لأمّة قبلهم{62}. (٢/١٥٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥١٦١<span class="dash">-</span></span> عن <span class="name-2">الربيع بن أنس</span> -من طريق أبي جعفر- في قوله: <span class="qpc-hafs">﴿ذلك تخفيف من ربكم ورحمة﴾</span>: وإنما هي رحمة رَحِم الله بها هذه الأمة؛ أطعمهم الدِّيَة، وأحلَّها لهم، ولم تَحِلَّ لأحد قبلهم، وكان أهل التوراة إنما هو قصاص أو عفو، ليس بينهما شيء، وكان أهل الإنجيل إنما هو عفوٌ أمروا به، فجعل الله لهذه الأمة القَوَد، والعفو، والدية إن شاءوا، أحلها لهم، ولم تكن لأمة قبلهم{63}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥١٦٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿تخفيف من ربكم﴾</span> إذْ جَعَل في قتل العمد العفوَ، والدِّية. ثم قال: <span class="qpc-hafs">﴿ورحمة﴾</span> يعني: وتراحموا، وكان الله ﷿ حَكَم على أهل التوراة أن يُقتَل القاتل، ولا يُعفى عنه، ولا يُقبَل منه الدية، وحَكَم على أهل الإنجيل العفو، ولا يُقتَل القاتل بالقصاص، ولا يَأخُذ ولي المقتول الدية، ثم جعل الله ﷿ التخفيف لأمة محمد ﷺ، إن شاء وليُّ المقتول قَتَل القاتل، وإن شاء عفا عنه، وإن شاء أخَذ منه الدية، فكان لأهل التوراة أن يُقتل قاتل الخطأ والعمد، فرخَّص الله ﷿ لأمة محمد ﷺ، فذلك قوله سبحانه في الأعراف [١٥٧]: <span class="qpc-hafs">﴿ويضع عنهم إصرهم والأغلال التي كانت عليهم﴾</span> من التشديدات، وهي أن يُقتل قاتل العمد، ولا يُعْفى عنه، ولا يُؤخذ منه الدية{64}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿فَمَنِ ٱعۡتَدَىٰ بَعۡدَ ذَ ٰ⁠لِكَ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥١٦٣<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق مجاهد- <span class="qpc-hafs">﴿فمن اعتدى﴾</span> قال: قَتَل بعد قَبول الدِّية <span class="qpc-hafs">﴿فله عذاب أليم﴾</span>{65}. (٢/١٥٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥١٦٤<span class="dash">-</span></span> عن <span class="name-2">عطاء</span>، نحوه{66}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥١٦٥<span class="dash">-</span></span> عن <span class="name-3">مقاتل بن حيان</span> -من طريق بُكَيْر بن معروف-، نحوه{67}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥١٦٦<span class="dash">-</span></span> عن <span class="name-2">أبي العالية</span> -من طريق الربيع بن أنس- <span class="qpc-hafs">﴿فمن اعتدى﴾</span>: قَتَل بعد أخذه الدية{68}. (٢/١٦٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥١٦٧<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نَجِيح- <span class="qpc-hafs">﴿فمن اعتدى بعد ذلك﴾</span>: فقَتَل بعد أخذه الدية <span class="qpc-hafs">﴿فله عذاب أليم﴾</span>{69}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥١٦٨<span class="dash">-</span></span> قال الشافعي: أخبرنا معاذ بن موسى عن بُكَير بن معروف، عن مقاتل بن حيان، قال مقاتل: أخذت هذا التفسيرَ عن نفرٍ-حَفِظَ معاذ منهم- <span class="name-2">مجاهدًا</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥١٦٩<span class="dash">-</span></span> و<span class="name-2">الحسنَ</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥١٧٠<span class="dash">-</span></span> و<span class="name-2">الضحاكَ بن مزاحم</span>، ... <span class="qpc-hafs">﴿فمن اعتدى بعد ذلك فله عذاب أليم﴾</span>، يقول: مَن قتل بعد أخذه الدية فله عذاب أليم{70}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥١٧١<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق يزيد بن إبراهيم- في قوله: <span class="qpc-hafs">﴿فمن اعتدى بعد ذلك فله عذاب أليم﴾</span>، قال: كان الرجلُ في الجاهلِيَّة إذا قتل قتيلًا ينضم إلى قومه، فيجيء قومه فيصالحون عنه بالدِّيَة، فيخرج الفارُّ وقد أمِن في نفسه، فيقتُلُه ويَرمي إليه بالدية، فذلك الاعتداء{71}. (٢/١٥٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥١٧٢<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق أبي عقيل- في هذه الآية: <span class="qpc-hafs">﴿فمن عُفي لهُ من أخيه شيء﴾</span>، قال: القاتلُ إذا طُلِب فلم يُقْدَر عليه، وأُخِذ من أوليائه الدِّيَة، ثم أمِن، فأُخِذ فقُتِل. قال الحسن: ما أكل عُدوانٌ{72}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥١٧٣<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دِعامة</span> -من طريق مَعْمَر-: <span class="qpc-hafs">﴿فمن اعتدى بعد ذلك﴾</span> بأن قَتَل بعد أخْذِه الدية{73}. (٢/ ١٥٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥١٧٤<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السدي</span> -من طريق أسباط-: <span class="qpc-hafs">﴿فمن اعتدى بعد ذلك﴾</span> بعد ما يأخذ الدية، فيقتُل <span class="qpc-hafs">﴿فله عذابٌ أليم﴾</span>{74}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥١٧٥<span class="dash">-</span></span> عن <span class="name-2">الربيع بن أنس</span> -من طريق أبي جعفر- قوله: <span class="qpc-hafs">﴿فمن اعتدى بعد ذلك فله عذاب أليم﴾</span>، يقول: فمن اعتدى بعد أخْذِه الديةَ <span class="qpc-hafs">﴿فله عذاب أليم﴾</span>{75}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥١٧٦<span class="dash">-</span></span> عن <span class="name-3">سفيان الثوري</span> -من طريق عبد الرزاق- في الَّذي يعفو، أو يأخذ الدية، ثُمَّ يقتل، قال الله تبارك وتعالى: <span class="qpc-hafs">﴿فمن اعتدى بعد ذلك فله عذاب أليم﴾</span>، قال: هو الرجل يَقْتل بعد ما يَأْخُذ الدِّيَة{76}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥١٧٧<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهْب- في قوله: <span class="qpc-hafs">﴿فمن اعتدى بعد ذلك فله عذابٌ أليم﴾</span> قال: أخَذ العَقْل، ثم قَتل -بعد أن أخذ العَقْل- قاتلَ قتيله، <span class="qpc-hafs">﴿فله عذاب أليم﴾</span>{77}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿فَلَهُۥ عَذَابٌ أَلِیمࣱ ۝١٧٨﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥١٧٨<span class="dash">-</span></span> عن أبي شُرَيْحٍ الخزاعي، أنّ النبي ﷺ قال: «<b>مَن أُصِيب بقتل أو خَبْل</b>{78}، <b>فإنه يختار إحدى ثلاث: إما أن يَقْتَصَّ، وإما أن يعفو، وإما أن يأخذ الدية، فإن أراد رابعةً فخذوا على يديه، ومن اعتدى بعد ذلك فله نارُ جهنم خالدًا فيها أبدًا</b>»{79}. (١/١٥٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥١٧٩<span class="dash">-</span></span> قال ابن جُرَيْج: أخبرني إسماعيل بن أميّة، عن الثبت -غير أنه لم ينسبه، وقال: ثقة-: أنّ النبي ﷺ أوْجبَ بقَسَمٍ أو غيره أن لا يُعفى عن رَجُلٍ عَفا عن الدّم وأخذ الدية، ثم عَدا فَقَتل. وقال ابن جُرَيْج: أخبرني عبد العزيز بن عمر بن عبد العزيز، قال: في كتاب لعمرَ عن النبي ﷺ قال: «<b>والاعتداء الذي ذَكَر اللهُ: أنّ الرجل يأخذ العقلَ، أو يقتصُّ، أو يقضي السلطانُ فيما بين الجرح، ثم يعتدي بعضُهم من بعد أن يستوعبَ حقه، فمن فعل ذلك فقد اعتدى، والحكم فيه إلى السلطان بالذي يرى فيه من العقوبة</b>». قال: ولو عفا عنه لم يكن لأحد من طلبة الحق أن يعفو؛ لأنّ هذا من الأمر الذي أنزل الله فيه قوله: <span class="qpc-hafs">﴿فَإنْ تَنازَعْتُمْ فِي شَيْءٍ فَرُدُّوهُ إلى اللَّهِ والرَّسُولِ﴾</span> [النساء:٥٩]»{80}<span class=comment-ref>٦٢٧</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٢٧</span> <span class="comment-type-2">انتَقَدَ</span> <u>ابنُ جرير</u> (٣/١٢٠) قول ابن جريج هذا <span class="mustanad">لمخالفته ما دلّ عليه ظاهر القرآن، وإجماع علماء الأمة</span>، فقال: «أمّا ما قاله ابن جريج: مِن أن حكم من قتل قاتل وليّه بعد عفوه عنه، وأخذه دية وليه المقتول- إلى الإمام دون أولياء المقتول؛ فقولٌ <span class="mustanad">خلاف لِما دَلَّ عليه ظاهر كتاب الله، وأجمع عليه علماء الأمة</span>. وذلك أنّ الله جعل لولي كل مقتول ظُلمًا السلطانَ دون غيره، من غير أن يخصّ من ذلك قتيلًا دون قتيل، فسواء كان ذلك قتيل وليّ من قتله أو غيره، ومن خص مِن ذلك شيئًا سُئِل البرهان عليه من أصلٍ أو نظير، وعُكِس عليه القول فيه، ثُمَّ لن يقول في شيء من ذلك قولًا إلا ألزم في الآخر مثله. ثم في إجماع الحجة على خلاف ما قاله في ذلك مُكْتَفًى في الاستشهاد على فساده بغيره».</div></p><p><div></p><p><p><span class="item-no">٥١٨٠<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دِعامة</span> -من طريق مَعْمَر- <span class="qpc-hafs">﴿فله عذاب أليم﴾</span>، قال: فعليه القتل، لا يُقْبَل منه الدِّيَة. وذُكِر لنا: أنّ رسول الله ﷺ قال: «<b>لا أُعافِي رجلًا قَتَل بعد أخذ الدِّيَة</b>»{81}. (٢/١٥٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥١٨١<span class="dash">-</span></span> عن جابر بن عبد الله، أنّ رسول الله ﷺ قال: «<b>لا أعفي مَن قَتَل بعد أخْذِه الدِّيَة</b>»{82}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥١٨٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق أبي رَوْق، عن الضحاك- في قول الله: <span class="qpc-hafs">﴿عذاب أليم﴾</span>، يقول: نكال مُوجِع، فهذه <span class="qpc-hafs">﴿عذاب أليم﴾</span> منسوخة، نسختها: <span class="qpc-hafs">﴿إنَّ اللَّهَ لا يَغْفِرُ أنْ يُشْرَكَ بِهِ ويَغْفِرُ ما دُونَ ذَلِكَ لِمَن يَشاءُ﴾</span> [النساء:٤٨، ٩٧]{67}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥١٨٣<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span> -من طريق عطاء بن دينار- في قول الله: <span class="qpc-hafs">﴿فله عذب أليم﴾</span>، يعني: وجيع. يقول: يُقتل، ولا يُعفى عنه، ولا تُؤخذ منه الدِّيَة{67}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥١٨٤<span class="dash">-</span></span> عن <span class="name-2">الضحاك بن مُزاحِم</span> -من طريق جُوَيْبِر- في قوله: <span class="qpc-hafs">﴿فمن اعتدى بعد ذلك فله عذاب أليم﴾</span>، قال: يُقتَل، وهو العذاب الأليم. يقول: العذاب المُوجِع{85}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥١٨٥<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span> -من طريق هارون- في رجل قَتَل بعد أخذ الدية، قال: يُقتل، أما سمعت الله يقول: <span class="qpc-hafs">﴿فله عذاب أليم﴾</span>؟{86}. (٢/١٥٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥١٨٦<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق يونس- في رجل قَتَل، فأُخِذَتْ منه الدِّيَة، ثم إنّ وليَّه قَتل به القاتلَ. قال الحسن: تُؤْخَذ منه الدية التي أخَذ، ولا يُقتل به{87}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥١٨٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثم قال: <span class="qpc-hafs">﴿فمن اعتدى بعد ذلك فله عذاب أليم﴾</span>، يعني: وجيع؛ فإنّه يُقْتَل، ولا يُؤْخَذُ منه دِيَة؛ قال النبي ﷺ: «<b>لا عَفْوَ عَمَّن قتل القاتل بعد أخذ الدِّيَة</b>». وقد جعل الله له عذابًا أليمًا{88}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥١٨٨<span class="dash">-</span></span> عن <span class="name-3">عبد الملك ابن جُرَيج</span>: يَتَحَتَّمُ قتلُه، حتى لا يُقْبَل العفو{89}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن أبي حاتم ١/٢٩٣.العمية -بكسر العين، وحكي فيها ضم العين-: العصبية والدعوة العمياء. وقيل: الجهالة والضلالة. وقيل: الفتنة. لسان العرب (عمي).أخرجه ابن جرير ٣/٩٥. وعزاه السيوطي إلى عبد بن حميد. وفي رواية لابن جرير ٣/٩٨، وابن أبي حاتم ١/٢٩٣، قال: نزلت في قتال عمِّية. قال شعبة: كأنه في صلح. قال: اصطلحوا على هذا.تفسير الثعلبي ٢/٥٣.أخرجه ابن جرير ٣/٩٨. وعزاه السيوطي إلى ابن مردويه.ذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ١/١٩٧-.أخرجه ابن جرير ٣/٩٦.تفسير مقاتل بن سليمان ١/١٥٧-١٥٨.أخرجه ابن أبي حاتم ١/٢٩٣.علّقه ابن أبي حاتم ١/٢٩٣.تفسير مقاتل بن سليمان ١/١٥٧-١٥٨.أخرجه ابن جرير ٣/٩٩.أخرجه ابن جرير ٣/٩٩. كما أخرج ٣/١٠٠ نحوه من طريق الشعبي.أخرجه ابن جرير ٣/٩٦.أخرجه ابن جرير ٣/٩٦.أخرجه ابن أبي شيبة ٥/٤٦٠ (٢٧٩٧٣) مرسلًا.أخرجه ابن جرير ٣/٩٩.أخرجه عبد الرزاق في المصنف (١٨١٥٨)، وابن أبي حاتم ١/٢٩٤ بنحوه من طريق حجاج عن ابن جريج.أخرجه ابن جرير ٣/٩٧.أخرجه ابن أبي حاتم ١/٢٩٤.أخرجه النحاس في ناسخه ص٨٣.عزاه السيوطي إلى ابن مردويه.أخرجه ابن جرير ٣/١٠٠، وابن أبي حاتم ١/٢٩٤، والبيهقي ٨/٤٠. وعزاه السيوطي إلى ابن المنذر.ذكره يحيي بن سلام -كما في تفسير ابن أبي زمنين ١/١٩٧-.أخرجه البيهقي ٨/٢٨. وعزاه السيوطي إلى عبد بن حميد، وأبي داود في ناسخه، وأبي القاسم الزجاجي في أماليه.تفسير مقاتل بن سليمان ١/١٥٧-١٥٨.أخرجه ابن أبي حاتم ١/٢٩٦.أخرجه ابن جرير ٣/١٠٥، والحاكم ٢/٢٧٣، والبيهقي في سننه ٨/٥٢. وعزاه السيوطي إلى عبد بن حميد.أخرجه ابن أبي حاتم ١/٢٩٥.أخرجه ابن أبي حاتم ١/٢٩٥.علّقه ابن أبي حاتم ١/٢٩٥.أخرجه ابن أبي حاتم ١/٢٩٥.أخرجه عبد الرزاق في تفسيره ١/٦٧، وفي مصنفه (١٨٤٥٠، ١٨٤٥١)، وسعيد بن منصور (٢٣٦- تفسير)، وابن أبي شيبة ٩/٤٣٣، والبخاري (٤٤٩٨، ٦٨٨١)، والنسائي (٤٧٩٥)، وابن جرير ٣/١٠٤، ١١٢، وابن أبي حاتم ١/٢٩٣، ٢٩٤، ٢٩٦ (١٥٧٣، ١٥٧٩، ١٥٨٥)، والنحاس في ناسخه ص٨٦-٨٧، وابن حِبّان (٦٠١٠)، والبيهقي ٨/٥١-٥٢. وعزاه السيوطي إلى ابن المنذر.أخرجه الطبراني (١١١٥٥).تفسير عبد الرزاق ١/٦٧، وابن جرير ٣/١٠٥.أخرجه ابن جرير ٣/١٠٥.أخرجه ابن أبي حاتم ١/٢٩٥.تفسير مجاهد ص٢١٩، وأخرجه ابن جرير ٣/١٠٦.أخرجه ابن جرير ٣/١٠٨.أخرجه ابن جرير ٣/١٠٨.أخرجه ابن جرير ٣/١٠٦.أخرجه ابن أبي حاتم ١/٢٩٤.علّقه ابن أبي حاتم ١/٢٩٤.أخرجه ابن جرير ٣/١٠٦. وعلَّقه ابن أبي حاتم ١/٢٩٥.أخرجه ابن جرير ٣/١٠٨. وعلّق ابن أبي حاتم ١/٢٩٤ نحوه.أخرجه ابن جرير ٣/١٠٧. وعلّقه ابن أبي حاتم ١/٢٩٤.أخرجه عبد الرزاق في تفسيره ١/٦٧، وابن جرير ٣/١٠٧ مختصرًا. وعلّقه ابن أبي حاتم ١/٢٩٥. وذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ١/١٩٨-. وفي مصنف عبد الرزاق (١٨٤٤٩) بلفظ: يُجبَر القاتل على أن يعطي الدية، قال الله ﷿: <span class="qpc-hafs">﴿فمن عفي له من أخيه شيء فاتباع بالمعروف﴾</span>، فالعفو أن يقبل الدية.أخرجه ابن جرير ٣/١٠٧.أخرجه ابن جرير ٣/١٠٩، وابن أبي حاتم ١/٢٩٤.أخرجه ابن جرير ٣/١٠٧. وعلّقه ابن أبي حاتم ١/٢٩٥.أخرجه ابن أبي حاتم ١/٢٩٥.تفسير مقاتل بن سليمان ١/١٥٨.أخرجه ابن أبي شيبة في مصنفه (ت: محمد عوامة) ١٤/٣٢٣-٣٢٤ (٢٨٥٥٢).أخرجه ابن جرير ٣/١٠٨.أخرجه ابن جرير ٣/١١٢، والبيهقي ٨/٥٢، وعُقِّب الأثر عند ابن جرير بقول: يعني: من تحريم الدية عليهم. وعزاه السيوطي إلى عبد بن حميد.أخرجه ابن أبي حاتم ١/٢٩٦.أخرجه ابن جرير ٣/١١٣، وابن أبي حاتم ١/٢٩٦. وعزاه السيوطي إلى أبي الشيخ.أخرجه الشافعي في مسنده ٣/٣٠٣، والبيهقي في السنن ٨/٥١.عزاه السيوطي إلى آدم. وأخرجه البيهقي في سننه ٨/٢٤ من طريقه.أخرجه ابن أبي حاتم ١/٢٩٦.أخرجه عبد الرزاق في المصنف ٧/٢٦٤ (١٣٠٨٦). كذا وردت هذه الآية في هذا الأثر في المطبوع من المصنّف، ويبدو أن في إثباتها خطأ! ولعل المراد قوله تعالى: <span class="qpc-hafs">﴿يُرِيدُ اللَّهُ أنْ يُخَفِّفَ عَنْكُمْ﴾</span> [النساء:٢٨]، فهي في سياق الآيات التي تتحدث عن الترخيص في الزواج من الإماء لمن خشي العنت. ويؤكّده ما ورد في تفسيرها عن مجاهد من طريق ابن أبي نجيح أنه قال: في نكاح الأمة، وفي كل شيء فيه يسر. وسيأتي في تفسير سورة النساء.أخرجه ابن جرير ٣/١١٣. وذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ١/١٩٨-. وعزاه السيوطي إلى الزجاجي في أماليه.أخرجه ابن جرير ٣/١١٣، وابن أبي حاتم ١/٢٩٦.تفسير مقاتل بن سليمان ١/١٥٨-١٥٩.أخرجه البخاري (٤٤٩٨)، وابن أبي حاتم ١/٢٩٧.علّقه ابن أبي حاتم ١/٢٩٧.أخرجه ابن أبي حاتم ١/٢٩٧.أخرجه البيهقي في سننه ٨/٢٤ من طريق آدم. وعزاه السيوطي إلى آدم.أخرجه ابن جرير ٣/١١٣، وفي تفسير مجاهد ص٢١٩ مختصرًا. وعلّقه ابن أبي حاتم ١/٢٩٧.أخرجه البيهقي في السنن ٨/٥١ من طريق الشافعي، ولم يرد تفسير هذه الآية في مسنده ٣/٣٠٣.أخرجه ابن جرير ٣/١١٦. وعزاه السيوطي إلى وكيع، وعبد بن حميد.أخرجه ابن جرير ٣/١١٦.أخرجه ابن جرير ٣/١١٥. وعزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ٣/١١٧، وابن أبي حاتم ١/٢٩٧.أخرجه ابن جرير ٣/١١٦، وابن أبي حاتم ١/٢٩٧.أخرجه عبد الرزاق في المصنف (١٨٢٠١).أخرجه ابن جرير ٣/١١٧.الخبل: الفساد، والمراد به هنا: فساد العضو بقطع أو نحوه. النهاية (خبل).أخرجه أحمد ٢٦/٢٩٦-٢٩٧ (١٦٣٧٥)، وأبو داود ٦/٥٤٦-٥٤٧ (٤٤٩٦)، وابن ماجه ٣/٦٤٤-٦٤٥ (٢٦٢٣)، وابن أبي حاتم ١/٢٩٦ (١٥٨٩).</p><p>قال ابن حزم في المحلى ١١/١٤: «هذا لا يصح». وقال الذهبي في ميزان الاعتدال ٢/١٧٠ (٣٣٢٦) في ترجمة سفيان بن أبي العوجاء: «هو حديث منكر». وقال الألباني في الإرواء ٧/٢٧٨ بعد أن ذكره من طريق محمد بن إسحاق عن الحارث بن فضيل عن سفيان بن أبي العوجاء: «سفيان ضعيف، وابن إسحاق مدلّس، وقد عنعنه».أخرجه ابن جرير ٣/١١٨.أخرجه عبد الرزاق في تفسيره ١/٣٠٥ (١٦٧)، وابن جرير ٣/١١٥-١١٦ عنه مرسلًا. وينظر: تحقيق أحمد شاكر لتفسير الطبري ٣/٣٧٦.أخرجه أحمد ٢٣/١٨٢ (١٤٩١١)، وأبو داود ٦/٥٥٩-٥٦٠ (٤٥٠٧).</p><p>قال الألباني في الضعيفة ١٠/٣١٠ (٤٧٦٧): «ضعيف».أخرجه ابن أبي حاتم ١/٢٩٧.أخرجه ابن أبي حاتم ١/٢٩٧.أخرجه ابن جرير ٣/١١٧. وعلّقه ابن أبي حاتم ١/٢٩٧.أخرجه ابن أبي شيبة ٩/٤٦١.أخرجه ابن جرير ٣/١١٩.تفسير مقاتل بن سليمان ١/١٥٩.تفسير البغوي ١/١٩١.
  2,179,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَلَكُمۡ فِی ٱلۡقِصَاصِ حَیَوٰةࣱ﴾</span> - قراءات</h3></p><p><div></p><p><p><span class="item-no">٥١٨٩<span class="dash">-</span></span> عن <span class="name-2">أبي الجَوْزاء</span> -من طريق عمرو بن مالك- أنه قرأ: (ولَكُمْ فِي القَصَصِ حَياةٌ)، قال: القصص: القرآن{1}. (٢/١٦٠)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَلَكُمۡ فِی ٱلۡقِصَاصِ حَیَوٰةࣱ﴾</span> - تفسير الآية</h3></p><p><div></p><p><p><span class="item-no">٥١٩٠<span class="dash">-</span></span> قال الشافعي: أخبرنا معاذ بن موسى، عن بُكَير بن معروف، عن مقاتل بن حيان، قال مقاتل: أخذت هذا التفسيرَ عن نفرٍ، حَفِظَ معاذ منهم <span class="name-2">مجاهدًا</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥١٩١<span class="dash">-</span></span> و<span class="name-2">الحسنَ</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥١٩٢<span class="dash">-</span></span> و<span class="name-2">الضحاكَ بن مزاحم</span>، ... في قوله: <span class="qpc-hafs">﴿ولكم في القصاص حياة﴾</span>: ينتهي بها بعضُكم عن بعضٍ مخافة أن يُقْتَل{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥١٩٣<span class="dash">-</span></span> عن <span class="name-2">أبي العالية</span> -من طريق الربيع بن أنس- <span class="qpc-hafs">﴿ولكم في القصاص حياة﴾</span>، يقول: جعل الله القصاص حياة؛ فكم من رجل يريد أن يَقْتُل فيمنعه منه مخافة أن يُقْتَل{3}. (٢/١٦٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥١٩٤<span class="dash">-</span></span> وعن <span class="name-2">الحسن البصري</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥١٩٥<span class="dash">-</span></span> و<span class="name-2">أبي مالك</span>، نحو ذلك{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥١٩٦<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span>، في قوله: <span class="qpc-hafs">﴿ولكم في القصاص حياة﴾</span>، قال: بُقْيا{5}، يُناهِي بعضهم عن بعض{6}. (٢/١٦٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥١٩٧<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نَجِيح- في قوله: <span class="qpc-hafs">﴿ولكم في القصاص حياةٌ يا أولي الألباب﴾</span>، قال: نَكالٌ، تَناهٍ{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥١٩٨<span class="dash">-</span></span> عن <span class="name-2">الضحاك بن مُزاحِم</span> -من طريق أبي مصلح نصر بن مُشارِس- في قوله: <span class="qpc-hafs">﴿ولكم في القصاص حياة﴾</span>، يعني بالحياة: الصلاح، والعدل{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥١٩٩<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دِعامة</span> -من طريق مَعْمَر- في قوله: <span class="qpc-hafs">﴿ولكم في القصاص حياة﴾</span>: جعل الله في القصاص حياةً، إذا ذكره الظالمُ المُعْتَدِي كفَّ عن القتل{9}. (٢/١٥٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٢٠٠<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دِعامة</span> -من طريق سعيد- قال: جعل الله هذا القصاص حياةً وعبرةً لأولي الألباب، وفيه عظةٌ لأهل الجهل والسَّفَه، كم من رجل قد هَمَّ بداهيةٍ لولا مخافة القصاص لوقَع بها، ولكنَّ الله حجز عباده به بالقصاص بعضهم عن بعض، وما أمَرَ الله بأَمْرٍ قطُّ إلا وهو أمْرُ صلاح في الدنيا والآخرة، وما نهى الله عن أمر إلا وهو أمْرُ فسادٍ في الدنيا والدين، والله كان أعلمَ بالذي يُصلِح خَلْقَه{10}. (٢/١٥٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٢٠١<span class="dash">-</span></span> عن <span class="name-2">أبي صالح</span> -من طريق إسماعيل- <span class="qpc-hafs">﴿ولكم في القصاص حياة﴾</span>، قال: بقاء{11}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٢٠٢<span class="dash">-</span></span> عن <span class="name-3">سفيان الثوري</span>، نحو ذلك{12}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٢٠٣<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- <span class="qpc-hafs">﴿في القصاص حياة﴾</span>، قال: بَقاء، لا يُقتَل إلا القاتلُ بجنايته{13}. (٢/١٥٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٢٠٤<span class="dash">-</span></span> عن <span class="name-2">الربيع بن أنس</span> -من طريق أبي جعفر- قوله: <span class="qpc-hafs">﴿ولكم في القصاص حياة﴾</span> الآية، يقول: جعل الله هذا القصاصَ حياةً وعِبْرَةً لكم؛ كم من رجل قد هَمّ بداهية فمنعه مخافة القصاص أن يقع بها، وإن الله قد حَجَز عبادَه بعضهم عن بعض بالقصاص{14}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٢٠٥<span class="dash">-</span></span> وعن <span class="name-3">مُقاتِل بن حَيّان</span> -من طريق بُكَيْر بن معروف-، نحو ذلك{15}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٢٠٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثُمَّ قال سبحانه: <span class="qpc-hafs">﴿ولكم في القصاص حياة﴾</span>، يعني: بقاء؛ يَحْجُزُ بعضَكم عن بعض{16}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٢٠٧<span class="dash">-</span></span> عن <span class="name-3">عبد الملك ابن جُرَيْج</span> -من طريق حَجّاج- قوله: <span class="qpc-hafs">﴿ولكم في القصاص حياة﴾</span>، قال: <span class="qpc-hafs">﴿حَياةٌ﴾</span>: مَنَعَةٌ{17}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٢٠٨<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهْب- في قوله: <span class="qpc-hafs">﴿ولكم في القصاص حياة﴾</span>، قال: <span class="qpc-hafs">﴿حياةٌ﴾</span>: تَقِيَّةٌ؛ إذا خاف هذا أن يُقتل بي كفَّ عنّي، لعلّه يكون عدوًّا لي يريد قتلي، فيتذكر أنه يُقْتَل في القصاص، فخشي أن يُقْتَل بي، وكفَّ بالقصاص الذي خافَ أن يقتل، لولا ذلك قتل هذا{17}<span class=comment-ref>٦٢٨</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٢٨</span> <span class="comment-type-4">ذَهَبَ</span> <u>ابنُ جرير</u> (٣/١٢٠) إلى ما ذهب إليه مجاهد، وقتادة، والربيع، وابن زيد، فقال: «يعني بقوله -جلّ ثناؤه-: <span class="qpc-hafs">﴿ولكم في القصاص حياة يا أولي الألباب﴾</span>: ولكم يا أولي العقول، فيما فرضتُ عليكم، وأوجبت لبعضكم على بعض، من القصاص في النفوس والجراح والشجاج، ما مَنع به بعضكم من قتل بعض، ووزَعَ بعضكم عن بعضٍ؛ فحَيِيتُم بذلك، فكان لكم في حكمي بينكم بذلك حياة».</div></p><p><h3><span class="qpc-hafs">﴿یَـٰۤأُو۟لِی ٱلۡأَلۡبَـٰبِ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٢٠٩<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جُبَيْر</span> -من طريق عطاء بن دينار- في قوله: <span class="qpc-hafs">﴿ولكم في القصاص حياة يا أولي الألباب﴾</span>، يعني: مَن كان له لُبٌّ أو عَقْلٌ يذكر القِصاص؛ فيَحْجُزُهُ خوْفُ القِصاص عن القتل{8}. (٢/١٦٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٢١٠<span class="dash">-</span></span> عن <span class="name-2">أبي مالك</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٢١١<span class="dash">-</span></span> و<span class="name-2">الضحاك بن مزاحم</span>، نحو ذلك{12}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٢١٢<span class="dash">-</span></span> عن <span class="name-3">مقاتل بن حيان</span> -من طريق بُكَيْر بن معروف-، نحو ذلك{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٢١٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿يا أولي الألباب﴾</span>، يعني: مَن كان له لُبٌّ أو عقل فذكر القصاص؛ فيَحْجُزُهُ الخوْفُ عن القتل{16}<span class=comment-ref>٦٢٩</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٢٩</span> قال <u>ابنُ جرير</u> (٣/١٢٣): «وخصَّ الله -تعالى ذِكْرُه- بالخطاب أهلَ العقول؛ لأنهم هم الذين يعقلون عن الله أمره ونهيه، ويتدبّرون آياته وحججه، دونَ غيرهم».</p><p>وبنحوه قال <u>ابنُ عطية</u> (٣/٤٢٨).</div></p><p><h3><span class="qpc-hafs">﴿لَعَلَّكُمۡ تَتَّقُونَ ۝١٧٩﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٢١٤<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جُبَيْر</span> -من طريق عطاء بن دينار- في قوله: <span class="qpc-hafs">﴿لعلكم تتقون﴾</span>: لكي تَتَّقُوا الدِّماءَ مَخافة القِصاص{8}. (٢/١٦٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٢١٥<span class="dash">-</span></span> وعن <span class="name-2">أبي مالك</span>، نحو ذلك{12}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٢١٦<span class="dash">-</span></span> وعن <span class="name-3">مقاتل بن حيان</span> -من طريق بُكَيْر بن معروف-، نحو ذلك{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٢١٧<span class="dash">-</span></span> عن <span class="name-2">ربيعة</span> -من طريق الليث بن سعد- أنه قال في قول الله: <span class="qpc-hafs">﴿ولكم في القصاص حياةٌ يا أولي الألباب لعلكم تتقون﴾</span>: يقول: لَعَلَّكم تَتَّقون محارمَكم، وما نهيتُ بعضكَم فيه عن بعض{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٢١٨<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿لعلكم﴾</span> يعني: لكي <span class="qpc-hafs">﴿تتقون﴾</span> الدماءَ؛ مخافةَ القِصاص{16}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٢١٩<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهْب- في قوله: <span class="qpc-hafs">﴿لعلكم تتقون﴾</span>، قال: لعلك تتَّقي أن تَقْتُلَهُ فَتُقْتَلَ به{17}<span class=comment-ref>٦٣٠</span>. (٢/١٦٠)</p></p><p></div></p><p><div><span class=comment-ref>٦٣٠</span> <span class="comment-type-4">ذَهَب</span> <u>ابنُ جرير</u> (٣/١٢٣) إلى ما ذهب إليه ابن زيد، فقال: «أي: تتقون القصاص، فتنتَهون عن القتل».</p><p>وقال <u>ابنُ عطية</u> (١/٤٢٨): «تتقون القتل؛ فتسلمون من القصاص، ثم يكون ذلك داعية لأنواع التقوى في غير ذلك؛ فإنّ الله تعالى يثيب على الطاعة بالطاعة».</p><p>وقال <u>ابنُ كثير</u> (١/١٦٦): «لعلكم تنزجرون فتتركون محارم الله ومآثمه، والتقوى: اسم جامع لفعل الطاعات وترك المنكرات».</div></p></div>",footnotes:1:أخرجه ابن أبي حاتم ١/٢٩٧ ووقع فيه <span class="qpc-hafs">﴿القصاص﴾</span>، وهو خطأ.</p><p>وقراءة (القصص) قراءة شاذة. ينظر: مختصر الشواذ لابن خالويه ص١٩، والبحر المحيط ٢/١٥. وعزاه السيوطي إلى عبد بن حميد.أخرجه الشافعي في مسنده ٣/٣٠٣، والبيهقي في السنن ٨/٥١.أخرجه ابن أبي حاتم ١/٢٩٧، والبيهقي في سننه ٨/٢٤ من طريق آدم. وعزاه السيوطي إلى آدم.علَّقه ابن أبي حاتم ١/٢٩٧ (عَقِب ١٥٩٤).البُقْيا: اسم من البقاء. لسان العرب (بقي).عزاه السيوطي إلى سفيان بن عيينة.تفسير مجاهد ص٢٢٠، وأخرجه ابن جرير ٣/١٢١.أخرجه ابن أبي حاتم ١/٢٩٨.أخرجه عبد الرزاق ١/٦٨، وابن جرير ٣/١٢١.أخرجه ابن جرير ٣/١٢١. وعزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ٣/١٢٢، وابن أبي حاتم ١/٢٩٨.علَّقه ابن أبي حاتم ١/٢٩٨.أخرجه ابن جرير ٣/١٢٣، وابن أبي حاتم ١/٢٩٨.أخرجه ابن جرير ٣/١٢١، وابن أبي حاتم ١/٢٩٧.أخرجه ابن أبي حاتم ١/٢٩٧.تفسير مقاتل بن سليمان ١/١٥٩.أخرجه ابن جرير ٣/١٢٢.أخرجه ابن جرير ٣/١٢٢.أخرجه ابن أبي حاتم ١/٢٩٨.علَّقه ابن أبي حاتم ١/٢٩٨.أخرجه ابن أبي حاتم ١/٢٩٨.تفسير مقاتل بن سليمان ١/١٥٩.أخرجه ابن أبي حاتم ١/٢٩٨.علَّقه ابن أبي حاتم ١/٢٩٨.أخرجه ابن أبي حاتم ١/٢٩٨.أخرجه ابن أبي حاتم ١/٢٩٨.تفسير مقاتل بن سليمان ١/١٥٩.أخرجه ابن جرير ٣/١٢٢.
  2,180,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿كُتِبَ عَلَیۡكُمۡ إِذَا حَضَرَ أَحَدَكُمُ ٱلۡمَوۡتُ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٢٢٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿كتب عليكم﴾</span> يعني: فُرِض عليكم. نظيرها: <span class="qpc-hafs">﴿كتب عليكم القتال﴾</span> [البقرة:٢١٦]، يعني: فُرِض. نظيرها أيضًا: <span class="qpc-hafs">﴿ما كتبناها عليهم﴾</span> [الحديد:٢٧]، يعني: ما فرضناها عليهم، يعني: الرَّهْبانِيَّة{1}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿إِن تَرَكَ خَیۡرًا﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٢٢١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي بن أبي طلحة- في قوله: <span class="qpc-hafs">﴿إن ترك خيرا﴾</span>، قال: مالًا{2}. (٢/١٦١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٢٢٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عكرمة- في قوله: <span class="qpc-hafs">﴿إن ترك خيرا﴾</span>، قال: الخيرُ: المالُ{3}. (٢/١٦١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٢٢٣<span class="dash">-</span></span> عن <span class="name-2">أبي العالية</span> -من طريق الربيع بن أنس-، نحو ذلك{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٢٢٤<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span>، نحو ذلك{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٢٢٥<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جَبْر</span> -من طريق ابن أبي نجيح- قال: الخير في القرآن كلِّه: المال؛ <span class="qpc-hafs">﴿إن ترك خيرًا﴾</span>، <span class="qpc-hafs">﴿لحب الخير﴾</span> [العاديات:٨]، <span class="qpc-hafs">﴿أحببت حب الخير﴾</span> [ص:٣٢]، <span class="qpc-hafs">﴿إن علمتم فيهم خيرا﴾</span> [النور:٣٣]{6}. (٢/١٦١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٢٢٦<span class="dash">-</span></span> عن <span class="name-2">الضحاك بن مُزاحِم</span> -من طريق الحسن بن يحيى- في قوله: <span class="qpc-hafs">﴿إن ترك خيرًا الوصية﴾</span>، قال: المال، ألا ترى أنه يقول: قال شعيب لقومه: <span class="qpc-hafs">﴿إنِّي أراكُمْ بِخَيْرٍ﴾</span>؟ [هود:٨٤]، يعني: الغِنى{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٢٢٧<span class="dash">-</span></span> عن <span class="name-2">عطاء بن أبي رباح</span> -من طريق ابن جُرَيْج- أنه تلا: <span class="qpc-hafs">﴿كُتب عليكم إذا حَضر أحدكم الموتُ إن ترك خيرًا﴾</span>، قال: الخيرُ فيما يُرى: المالُ{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٢٢٨<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دِعامة</span>، في الآية، قال: الخيرُ: المالُ{9}. (٢/١٦٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٢٢٩<span class="dash">-</span></span> عن <span class="name-2">عطية العوفي</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٢٣٠<span class="dash">-</span></span> و<span class="name-2">عبدة</span>، نحو ذلك{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٢٣١<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- <span class="qpc-hafs">﴿إن تَرك خيرًا الوصية﴾</span>، أمّا <span class="qpc-hafs">﴿خيرًا﴾</span>: فالمالُ{11}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٢٣٢<span class="dash">-</span></span> عن <span class="name-2">الربيع بن أنس</span> -من طريق أبي جعفر- <span class="qpc-hafs">﴿إن ترك خيرًا﴾</span>، قال: إن ترك مالًا{11}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٢٣٣<span class="dash">-</span></span> عن <span class="name-3">مُقاتِل بن حَيّان</span> -من طريق بُكَيْر بن معروف-، نحو ذلك{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٢٣٤<span class="dash">-</span></span> قال <span class="name-3">مُقاتِل بن سليمان</span>: <span class="qpc-hafs">﴿إن ترك﴾</span> بعد موته <span class="qpc-hafs">﴿خيرا﴾</span> يعني: المال{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٢٣٥<span class="dash">-</span></span> عن <span class="name-3">الليث بن سعد</span> -من طريق ابن وهْب- في قول الله: <span class="qpc-hafs">﴿إن ترك خيرا الوصية﴾</span>، قال: الخيرُ: المالُ{15}<span class=comment-ref>٦٣١</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٣١</span> <span class="comment-type-4">ذَهَبَ</span> <u>ابنُ جرير</u> (٣/١٣٤) و<u>ابنُ كثير</u> (٣/١٦٩) إلى ما ذهبتْ إليه الآثارُ مِن أنَّ الخير في الآية: المال؛ <span class="mustanad">مستندَين إلى أقوال أهل التأويل</span>، وكذا اختاره <u>ابنُ عطية</u> (١/٤٣٠)، ولم يذكر مستندًا.</div></p><p><h3><span class="qpc-hafs">﴿إِن تَرَكَ خَیۡرًا﴾</span> - (مقدار المال الذي إذا تركه الرجل لَزِمه حكمُ الآية)</h3></p><p><div></p><p><p><span class="item-no">٥٢٣٦<span class="dash">-</span></span> عن عُرْوَة أنّ <span class="name-1">علي بن أبي طالب</span> دخل على مولًى لهم في الموت، وله سبعمائة درهم أو ستمائة درهم، فقال: ألا أُوصِي؟ قال: لا؛ إنّما قال الله: <span class="qpc-hafs">﴿إن ترك خيرا﴾</span>. وليس لك كثير مال، فَدَعْ مالَك لِوَرَثَتِك{16}. (٢/١٦١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٢٣٧<span class="dash">-</span></span> عن <span class="name-1">عائشة</span> -من طريق ابن أبى مُلَيْكَة- أنّ رجلًا قال لها: إنِّي أريد أن أُوصِي؟ قالتْ: كم مالُك؟ قال: ثلاثة آلاف. قالتْ: كم عيالك؟ قال: أربعة. قالتْ: قال اللهُ: <span class="qpc-hafs">﴿إن ترك خيرا﴾</span>، وهذا شيء يسير، فاترُكْهُ لعيالك؛ فهو أفضل{17}. (٢/١٦٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٢٣٨<span class="dash">-</span></span> عن عبد الله بن عتبة أو غَنيَّةَ{18} -الشَّكُّ من ابن جرير-: أنّ رجلًا أراد أن يوصي وله ولد كثير، وترك أربعمائة دينار، فقالت <span class="name-1">عائشة</span>: ما أرى فيه فَضْلًا{19}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٢٣٩<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>: في قوله: <span class="qpc-hafs">﴿إن ترك خيرا الوصية﴾</span>، قال: مَن لَمْ يترُك ستين دينارًا لم يترك خيرًا{20}. (٢/١٦١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٢٤٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق طاووس- قال: إذا ترك الميتُ سبعمائة درهم فلا يوصي{21}. (٢/١٦٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٢٤١<span class="dash">-</span></span> عن <span class="name-2">إبراهيم النَّخَعِيّ</span> -من طريق أبان- في قوله تعالى: <span class="qpc-hafs">﴿إن ترك خيرا﴾</span>، قال: ألفُ درهم إلى خمسمائة درهم{22}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٢٤٢<span class="dash">-</span></span> عن <span class="name-2">أبي مِجْلَز</span>، قال: الوصيةُ على مَن ترك خيرًا{20}. (٢/١٦٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٢٤٣<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دِعامة</span>، في الآية، قال: الخيرُ: المال، كان يُقال: ألْفٌ فما فوق ذلك{20}. (٢/١٦٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٢٤٤<span class="dash">-</span></span> عن <span class="name-2">محمد ابن شهاب الزهري</span> -من طريق مَعْمَر- قال: جعل الله الوصية حَقًّا، مِمّا قَلَّ مِنهُ أو كَثُر{25}<span class=comment-ref>٦٣٢</span>. (٢/١٦٢)</p></p><p></div></p><p><div><span class=comment-ref>٦٣٢</span> <span class="comment-type-3">رجَّحَ</span> <u>ابنُ جرير</u> (٣/١٣٨ بتصرف) قولَ الزهري <span class="mustanad">مستندًا إلى العموم</span>، فقال: «أوْلى هذه الأقوال بالصواب ما قال الزهري؛ لأنّ قليلَ المال وكثيره يقع عليه اسمُ»خير«، ولم يحُدَّ اللهُ ذلك بحدٍّ، ولا خصَّ منه شيئًا، فكلّ مَن حَضَرَتْهُ مَنِيَّته وعنده مالٌ -قلّ ذلك أو كثر- فواجبٌ عليه أن يوصي منه».</div></p><p><h3><span class="qpc-hafs">﴿ٱلۡوَصِیَّةُ لِلۡوَ ٰ⁠لِدَیۡنِ وَٱلۡأَقۡرَبِینَ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٢٤٥<span class="dash">-</span></span> قال <span class="name-1">ابن مسعود</span>: الوصيَّة للأخَلِّ فالأَخَلِّ{26}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٢٤٦<span class="dash">-</span></span> عن <span class="name-2">عبيد الله بن عبد الله بن معمر</span> قاضي البصرة -من طريق محمد بن سيرين- قال: مَن أوْصى فسمّى أعْطَيْنا من سمّى، وإن قال: ضعها حيث أمر الله. أعطيناها قرابتَه{27}. (٢/١٦٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٢٤٧<span class="dash">-</span></span> عن <span class="name-2">سعيد بن المسيب</span> -من طريق قتادة- قال: مَن أوْصى وسمّى أعْطَيْنا مَن سَمّى{28}. (٢/١٦٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٢٤٨<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- قال: كان الميراثُ للولد، والوصيةُ للوالدين والأقربين{29}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٢٤٩<span class="dash">-</span></span> عن <span class="name-2">طاووس</span> -من طريق ابن طاووس- قال: مَن أوْصى لقوم وسَمّاهم، وترك ذوي قرابته محتاجين؛ انتُزِعت منهم، ورُدَّت على قرابته{30}. (٢/١٦٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٢٥٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿الوصية للوالدين والأقربين بالمعروف﴾</span>، يعني: تفضيل الوالدين على الأقربين في الوصية، ولْيُوصِ للأقربين بالمعروف، والذين لا يرثون{1}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿بِٱلۡمَعۡرُوفِ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٢٥١<span class="dash">-</span></span> عن سعد بن مالك، قال: جاءني النبي ﷺ يَعُودُني، فقلت: يا رسول الله، أُوصِي بمالي كلِّه؟ قال: «<b>لا</b>». قلت: فالشَّطْرُ؟ قال: «<b>لا</b>». قلت: فالثُّلُث؟ قال: «<b>الثُّلُث، والثُّلُث كثير؛ إنّك أن تَدَعَ ورَثَتَك أغنياءَ خيرٌ مِن أن تَدَعَهم عالةً يَتَكَفَّفون الناسَ بأيديهم</b>»{32}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٢٥٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عروة- قال: لو أنّ الناس غَضُّوا مِن الثُّلُث إلى الرُّبُع؛ فإنّ رسول الله ﷺ قال: «<b>الثُّلُث، والثُّلُث كثير</b>»{33}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٢٥٣<span class="dash">-</span></span> قال <span class="name-1">علي بن أبي طالب</span>: لَأَن أُوصي بالخُمُس أحبُّ إلَيَّ مِن أنْ أُوصِي بالرُّبُع، ولَأَن أُوصِي بالرُّبُع أحبُّ إلَيَّ مِن أنْ أُوصِي بالثُّلُث، فمَن أوْصى بالثُّلُث فَلَمْ يَتْرُكْ{34}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٢٥٤<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق قتادة- قال: إذا أوْصى في غير أقاربه بالثُّلُث جاز لهم ثُلُثُ الثُّلُث، ويُرَدُّ على أقاربه ثُلُثا الثُّلُث{35}. (٢/١٦٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٢٥٥<span class="dash">-</span></span> وعن <span class="name-2">الحسن البصري</span>: يُوصي بالسُّدُس، أو الخُمُس، أو الرُّبُع{34}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٢٥٦<span class="dash">-</span></span> وعن <span class="name-2">عامر الشعبي</span>: إنّما كانوا يُوصون بالخُمُس أو الرُّبُع{34}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿حَقًّا عَلَى ٱلۡمُتَّقِینَ ۝١٨٠﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٢٥٧<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جُبَيْر</span> -من طريق عطاء بن دينار- في قول الله: <span class="qpc-hafs">﴿بالمعروف حَقًّا عَلى المُتَّقِينَ﴾</span>، يقول: تلك الوصية حقٌّ على المتقين{38}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٢٥٨<span class="dash">-</span></span> عن <span class="name-3">مقاتل بن حيان</span> -من طريق بُكَيْر بن معروف- قوله: <span class="qpc-hafs">﴿حَقًّا عَلى المُتَّقِينَ﴾</span>، يعني: المؤمنين{38}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٢٥٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: يقول الله ﷿: تلك الوصية <span class="qpc-hafs">﴿حَقًّا عَلى المُتَّقِينَ﴾</span>، فمَن لَمْ يُوصِ لقرابته عند موته فقد خَتَم عملَه بالمعصية{1}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿حَقًّا عَلَى ٱلۡمُتَّقِینَ ۝١٨٠﴾</span> - النسخ في الآية</h3></p><p><div></p><p><p><span class="item-no">٥٢٦٠<span class="dash">-</span></span> عن <span class="name-2">إبراهيم [النخعي]</span> -من طريق الحسن بن عبيد الله-= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٢٦١<span class="dash">-</span></span> أنه ذُكِر عنده <span class="name-1">طلحة</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٢٦٢<span class="dash">-</span></span> و<span class="name-1">الزبير</span>، فقيل: كانا يُشَدِّدان في الوصية. فقال: وما عليهما ألّا يفعلا، تُوُفِّي النبي ﷺ فما أوصى، وأوصى أبو بكر، فإن أوصى فحَسَن، وإن لم يوصِ فلا بأس{41}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٢٦٣<span class="dash">-</span></span> عن <span class="name-1">علي</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٢٦٤<span class="dash">-</span></span> و<span class="name-1">عائشة</span>: أنّ الآية منسوخة، ولا تجب الوصية، فإن أوصى فحَسَن، وإن لم يوصِ فلا شيء عليه{42}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٢٦٥<span class="dash">-</span></span> عن <span class="name-1">أبي موسى الأشعري</span>: أنّ هذه الآية منسوخةٌ، نَسَخَتْها آيةُ الميراث{43}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٢٦٦<span class="dash">-</span></span> عن محمد بن سيرين، قال: خطب <span class="name-1">ابنُ عباس</span>، فقرأ سورة البقرة، فبيَّن ما فيها، حتى أتى على هذه الآية: <span class="qpc-hafs">﴿إن ترك خيرًا الوصية للوالدين والأقربين﴾</span>، فقال: نُسِخَت هذه الآية{44}. (٢/١٦٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٢٦٧<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطاء- في قوله: <span class="qpc-hafs">﴿الوصية للوالدين والأقربين﴾</span>، قال: كان ولد الرجل يَرِثُونه، وللوالِدَين والأقربين الوصيةُ، فنَسَخَها: <span class="qpc-hafs">﴿للرجال نصيب مما ترك الوالدان والأقربون﴾</span> الآية [النساء:٧]{45}. (٢/١٦٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٢٦٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي بن أبي طلحة- قال: كان لا يَرِثُ مع الوالدين غيرُهما إلا وصيَّة الأقرَبين، فأنزل الله آية الميراث، فبيَّن ميراث الوالِدَيْن، وأقَرَّ وصيَّة الأقربين في ثُلُثِ مال الميت{46}. (٢/١٦٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٢٦٩<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق يزيد النَّحْوِيِّ، عن عكرمة- في قوله: <span class="qpc-hafs">﴿إن ترك خيرا الوصية للوالدين والأقربين﴾</span>، قال: فكانت الوصية كذلك، حتى نسختها آية الميراث{47}. (٢/١٦٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٢٧٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق ابن جُرَيْج، عن عكرمة- في الآية، قال: نَسَخ مَن يَرِثُ، ولَمْ يَنسَخ الأقربين الذين لا يرثون{48}<span class=comment-ref>٦٣٣</span>. (٢/١٦٥)</p></p><p></div></p><p><div><span class=comment-ref>٦٣٣</span> <span class="comment-type-4">علَّقَ</span> <u>ابنُ كثير</u> (١/١٦٨-١٦٩) على قول ابن عباس، ومَن تبعه كالحسن، ومسروق: إنّ الوصيّة منسوخة فيمن يرث، ثابتة فيمن لا يرث. بقوله: «على قول هؤلاء لا يُسَمّى هذا نسخًا في اصطلاحنا المتأخر؛ لأنّ آية المواريث إنما رَفَعَتْ حكمَ بعض أفراد ما دلَّ عليه عموم آية الوصاية؛ لأن الأقربين أعمّ مِمَّن يرث ولا يرث، فرُفِع حكمُ مَن يَرِثُ بما عُيِّنَ له، وبقي الآخرُ على ما دَلَّت عليه الآيةُ الأولى، وهذا إنّما يَتَأَتّى على قول بعضهم: إنّ الوصاية في ابتداء الإسلام إنما كانت نَدْبًا حتى نُسِخَت. فأما من يقول: إنها كانت واجبة -وهو الظاهر من سياق الآية-؛ فيتعين أن تكون منسوخة بآية الميراث، كما قاله أكثر المفسرين والمعتبرين من الفقهاء، فإنّ وجوب الوصيّة للوالدين والأقربين الوارثين منسوخ بالإجماع، بل منهيٌّ عنه للحديث المتقدم: «إن الله قد أعطى كلَّ ذي حَقٍّ حَقَّه؛ فلا وصية لوارث». فآية الميراث حكم مستقل، ووجوب من عند الله لأهل الفروض والعصبات، رفع بها حُكْمَ هذه بالكُلِّيَّة».</div></p><p><div></p><p><p><span class="item-no">٥٢٧١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عمر</span> -من طريق عبد الله بن بدر- أنّه سُئِل عن هذه الآية: <span class="qpc-hafs">﴿الوصية للوالدين والأقربين﴾</span>. قال: نَسَخَتْها آية الميراث{49}. (٢/١٦٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٢٧٢<span class="dash">-</span></span> عن <span class="name-2">مسروق</span> -من طريق مسلم-: أنّه حَضَر رجلًا يُوصي بأشياء لا تنبغي، فقال له مسروق: إنّ الله قد قسم بينكم، فَأحْسَنَ القَسْمَ، وإنّه مَن يَرْغَب برأيه عن رَأْيِ الله يَضِلُّ؛ أوصِ لذي قرابتك مِمَّن لا يرثك، ثم دَعِ المالَ على ما قَسَمَه اللهُ عليه{50}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٢٧٣<span class="dash">-</span></span> عن <span class="name-2">شُرَيح</span> -من طريق قتادة- في الآية، قال: كان الرجلُ يوصي بماله كلِّه، حتى نزلت آية الميراث{48}. (٢/١٦٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٢٧٤<span class="dash">-</span></span> عن <span class="name-2">سعيد بن المسيب</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٢٧٥<span class="dash">-</span></span> و<span class="name-2">سعيد بن جبير</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٢٧٦<span class="dash">-</span></span> و<span class="name-2">إبراهيم النَّخَعِيّ</span>: أنّ هذه الآية منسوخةٌ، نَسَخَتْها آيةُ الميراث{43}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٢٧٧<span class="dash">-</span></span> عن <span class="name-2">أبي العالية</span> -من طريق الربيع بن أنس- قوله: <span class="qpc-hafs">﴿الوصية للوالدين والأقربين﴾</span>، قال: نَسَخَ الوالدين، فألحقهما بأهل الميراث، وصارت الوصية لأهل القرابة الذين لا يَرِثُون{38}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٢٧٨<span class="dash">-</span></span> وعن <span class="name-2">سعيد بن جبير</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٢٧٩<span class="dash">-</span></span> و<span class="name-2">الضحاك بن مزاحم</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٢٨٠<span class="dash">-</span></span> و<span class="name-2">الحسن البصري</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٢٨١<span class="dash">-</span></span> و<span class="name-2">محمد ابن شهاب الزهري</span>، نحو ذلك{54}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٢٨٢<span class="dash">-</span></span> عن <span class="name-2">الربيع بن أنس</span> -من طريق أبي جعفر-= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٢٨٣<span class="dash">-</span></span> <span class="name-3">ومقاتل بن حيان</span> -من طريق بكير بن معروف-، نحو ذلك{38}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٢٨٤<span class="dash">-</span></span> عن <span class="name-2">جابر بن زيد</span>: في رجلٍ أوْصى لغير ذي قرابة، وله قرابةٌ محتاجون، قال: يُرَدُّ ثُلُثا الثُّلُثِ عليهم، وثُلُثُ الثُّلُثِ لِمَن أوْصى له به{56}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٢٨٥<span class="dash">-</span></span> عن عطاء بن أبي ميمونة، قال: سألت <span class="name-2">مسلم بن يَسار</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٢٨٦<span class="dash">-</span></span> <span class="name-2">والعلاء بن زياد</span> عن قول الله: <span class="qpc-hafs">﴿إن ترك خيرًا الوصيةُ للوالدين والأقربين﴾</span>. قالا: في القرابة{57}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٢٨٧<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span>، في الآية، قال: كان الميراث للولد، والوصية للوالدين والأقربين، فهي منسوخة{20}. (٢/١٦٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٢٨٨<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span>: نسخها: <span class="qpc-hafs">﴿يوصيكم الله في أولادكم للذكر مثل حظ الأنثيين﴾</span> [النساء:١١]{59}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٢٨٩<span class="dash">-</span></span> عن <span class="name-2">الضحاك بن مُزاحِم</span> -من طريق جُوَيْبِر- أنّه كان يقول: مَن مات ولم يُوصِ لِذي قرابته فقد خَتَم عملَه بمعصية{50}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٢٩٠<span class="dash">-</span></span> عن <span class="name-2">الضحاك بن مُزاحِم</span> -من طريق عبيد- قال: لا تجوز وصيةٌ لوارث، ولا يُوصي إلا لذي قرابة، فإن أوصى لغير ذي قرابة فقد عمل بمعصية؛ إلا أن لا يكون قرابة، فيوصي لفقراء المسلمين{50}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٢٩١<span class="dash">-</span></span> عن <span class="name-2">الضحاك بن مزاحم</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٢٩٢<span class="dash">-</span></span> و<span class="name-2">محمد بن سيرين</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٢٩٣<span class="dash">-</span></span> و<span class="name-2">عطاء</span>: أنّ هذه الآية منسوخة، نَسَخَتْها آيةُ الميراث{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٢٩٤<span class="dash">-</span></span> عن <span class="name-2">طاووس</span>، في الآية: أنّ وجوبها صار منسوخًا في حقّ الأقارب الذين يَرِثون، وبقي وجوبها في حق الذين لا يَرِثُون من الوالدين والأقارب{63}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٢٩٥<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٢٩٦<span class="dash">-</span></span> و<span class="name-2">الحسن البصري</span> -من طريق يزيد النحوي- قالا: <span class="qpc-hafs">﴿إن تَرَك خيرًا الوصية للوالدين والأقربين﴾</span>، فكانت الوصية كذلك، حتى نَسَخَتْها آيةُ الميراث{64}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٢٩٧<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق عَبّاد بن منصور- قوله: <span class="qpc-hafs">﴿كتب عليكم إذا حضر أحدكم الموت﴾</span>، فقال: نعم، الوصيةُ حقٌّ على كل مسلم؛ أن يُوصِي إذا حضر الموتُ بالمعروفِ غيرِ المنكر{65}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٢٩٨<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق يونس- في قوله ﷿: <span class="qpc-hafs">﴿إذا حضر أحدكم الموت إن ترك خيرا الوصية للوالدين والأقربين﴾</span>، قال: كانت الوصية للوالدين والأقربين، فنَسَخ من ذلك <span class="qpc-hafs">﴿للوالدين﴾</span>، وأثبت لهما نصيبهما في سورة النساء [١١]، ونَسَخ من الأقربين كُلَّ وارث، وبقيت الوصية للأقربين الذين لا يرثون{66}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٢٩٩<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دِعامة</span> -من طريق هَمّام- قال: <span class="qpc-hafs">﴿إذا حضر أحدكم الموت إن ترك خيرًا الوصية للوالدين والأقربين بالمعروف حقًّا على المتقين﴾</span>، أمر أن يُوصِي لوالديه وأقاربه، ثم نسخ بعد ذلك في سورة النساء [١١]، فجعل للوالدين نصيبًا معلومًا، وأَلْحَقَ لِكُلِّ ذي ميراث نصيبَه منه، وليست لهم وصية، فصارت الوصية لمن لا يَرِثُ من قريبٍ وغيره{67}. (٢/١٦٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٣٠٠<span class="dash">-</span></span> عن المُعْتَمِر، قال: سمعتُ أبي قال: زَعَم <span class="name-2">قتادة</span>: أنّه نَسَخَتْ آيتا المواريث في سورة النساء الآيةَ في سورة البقرةِ في شأن الوصية{68}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٣٠١<span class="dash">-</span></span> عن <span class="name-2">محمد ابن شهاب الزهري</span>: قوله تعالى: <span class="qpc-hafs">﴿إن ترك خيرا الوصية للوالدين والأقربين﴾</span> نُسِخَتْ بآية الميراث{69}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٣٠٢<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السدي</span> -من طريق أسباط- <span class="qpc-hafs">﴿كُتب عليكم إذا حَضر أحدكم الموت إن ترك خيرًا الوصيةُ للوالدين والأقربين﴾</span>: أمّا <span class="qpc-hafs">﴿الوالدين والأقربين﴾</span> فيوم نزلت هذه الآية كان الناس ليس لهم ميراث معلومٌ، إنما يُوصِي الرجلُ لوالده ولأهله فيَقْسِم بينهم، حتى نسختها النساء [١١]، فقال: <span class="qpc-hafs">﴿يُوصِيكُمُ اللَّهُ فِي أوْلادِكُمْ﴾</span>{70}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٣٠٣<span class="dash">-</span></span> عن <span class="name-2">زيد بن أسلم</span> -من طريق القاسم بن عبد الله- أنّه قال: <span class="qpc-hafs">﴿إن ترك خيرا الوصية للوالدين والأقربين﴾</span>، فنَسَخَتْها آيةُ الميراث{71}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٣٠٤<span class="dash">-</span></span> عن <span class="name-2">الربيع بن أنس</span> -من طريق أبي جعفر- قوله: <span class="qpc-hafs">﴿كتب عليكم إذا حَضر أحدكم الموتُ إنْ تَرك خيرًا الوصية للوالدين والأقربين بالمعروف﴾</span>، قال: كان هذا من قبل أن تنزل سورة النساء، فلَمّا نزلتْ آيةُ الميراث نَسخَ شأنَ الوالِدَين، فألحقهما بأهل الميراث، وصارتِ الوَصِيَّةُ لأهل القرابة الذين لا يَرِثُون{72}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٣٠٥<span class="dash">-</span></span> عن <span class="name-3">مقاتل بن حَيّان</span> -من طريق بُكَيْر بن معروف-: أنّ هذه الآية منسوخة، نَسَخَتْها آيةُ الميراث{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٣٠٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثم نزلت آية الميراث بعد هذه الآية، فنسخت <span class="qpc-hafs">﴿للوالدين﴾</span>، وبَقِيت الوصية للأقربين الذين لا يَرِثون، ما بينه وبين ثلث ما له{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٣٠٧<span class="dash">-</span></span> عن <span class="name-3">مالك بن أنس</span>-من طريق يحيى- في هذه الآية: إنّها منسوخة. قول الله تبارك وتعالى: <span class="qpc-hafs">﴿إن ترك خيرا الوصية للوالدين والأقربين﴾</span> نَسَخها ما نزل من قسمة الفرائض في كتاب الله ﷿{75}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٣٠٨<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهْب- في قوله: <span class="qpc-hafs">﴿إن تَرَك خيرًا الوصية للوالدين والأقربين﴾</span> الآية، قال: فنَسَخ اللهُ ذلك كلَّه، وفرضَ الفرائض{76}<span class=comment-ref>٦٣٤</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٣٤</span> <span class="comment-type-4">ذَهَب</span> <u>ابنُ جرير</u> (٣/١٢٤) إلى أنّ الآية محكمة غير منسوخة، وفرض على مَن ترك مالًا من المؤمنين الوصية للوالدين والأقربين الذين لا يرثونه. واستدل بأمرين: الأول: <span class="mustanad">عدم الدليل على النسخ</span>، حيث قال: «وإذا كان في نَسْخ ذلك تنازعٌ بين أهل العلم؛ لم يكن لنا القضاءُ عليه بأنه منسوخٌ إلا بحجة يجب التسليم لها». والثاني: <span class="mustanad">إمكان الجمع بين آيتي الوصية والمواريث</span>، قال: «فغيرُ مستحيلٍ اجتماعُ حكمِ هذه الآية وحكمِ آية المواريث في حال واحدةٍ».</p><p>و<span class="comment-type-4">ذَهَب</span> <u>ابنُ كثير</u> (١/١٦٧-١٦٩) <span class="mustanad">مستندًا إلى السنة، وأقوال السلف، والإجماع</span> إلى أنّها منسوخة بآية المواريث، وقال: «كانت الوصية للوالدين والأقربين واجبة -على أصح القولين- قبل نزول آية المواريث، فلما نزلت آيةُ الفرائض نسخت هذه، وصارت المواريث المُقَدَّرة فريضةً من الله، يأخذها أهلوها حتمًا من غير وصية ولا تحمل مِنّة المُوصِي، ولهذا جاء في الحديث الذي في السنن وغيرها عن عمرو بن خارجة قال: سمعت رسول الله ﷺ يخطب، وهو يقول: «إنّ الله قد أعطى كلَّ ذي حق حَقَّه، فلا وصية لوارث»». وقال بعد ذلك: «أمّا من يقول: إنها كانت واجبة -وهو الظاهر من سياق الآية- فيتعين أن تكون منسوخة بآية الميراث، كما قاله أكثر المفسرين والمعتبرين من الفقهاء، فإنّ وجوب الوصية للوالدين والأقربين الوارثين <b>منسوخ بالإجماع</b>، بل منهي عنه للحديث المتقدم: «إن الله قد أعطى كل ذي حق حقه؛ فلا وصية لوارث». فآية الميراث حكم مستقلّ، ووجوب من عند الله لأهل الفروض والعصبات، رفع بها حكم هذه بالكلية».</div></p><p><h3><span class="qpc-hafs">﴿حَقًّا عَلَى ٱلۡمُتَّقِینَ ۝١٨٠﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٥٣٠٩<span class="dash">-</span></span> عن عمرو بن خارجة: أنّ النبي ﷺ خطبهم على راحلته، فقال: <b>«إنّ الله قد قَسَم لكلِّ إنسان نصيبَه من الميراث؛ فلا تجوز لوارثٍ وصيةٌ»</b>{77}. (٢/١٦٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٣١٠<span class="dash">-</span></span> عن أبي أمامة الباهلي: سمعتُ رسول الله ﷺ في حَجَّة الوداع في خطبته يقول: «<b>إنَّ الله قد أعطى كلَّ ذي حق حقَّه؛ فلا وصية لوارث»</b>{78}. (٢/١٦٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٣١١<span class="dash">-</span></span> عن الحسن، قال: قال رسول الله ﷺ: <b>«لا وصية لوارث، إلا أن تُجِيزَه الوَرَثَة»</b>{79}. (٢/١٦٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٣١٢<span class="dash">-</span></span> عن ابن عمر، قال: سمعتُ رسول الله ﷺ يقول: <b>«ما حقُّ امرئ مسلم تَمُرُّ عليه ثلاثُ ليالٍ إلا وصيته عنده»</b>. قال ابن عمر: فما مرت عَلَيَّ ثلاثٌ قطُّ إلا ووصيتي عندي{80}. (٢/١٦٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٣١٣<span class="dash">-</span></span> عن قتادة، قال: قال رسول الله ﷺ: «<b>أيها الناس، ابتاعوا أنفسكم من ربكم، ألا إنَّه ليس لامرئ شيء، ألا لا أعْرِفَنَّ امرءًا بَخِلَ بَحَقِّ الله عليه، حتى إذا حضَره الموت أخَذ يُدَعْدِع مالَه ههنا وههنا»</b>.= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٣١٤<span class="dash">-</span></span> ثم يقول <span class="name-2">قتادة</span>: ويلك، يا ابن آدم، كنتَ بخيلًا مُمسكًا، حتى إذا حضرك الموتُ أخذت تُدَعْدِعُ مالك وتُفَرِّقه، يا ابن آدم، اتقِ الله، ولا تجمع إساءتين في مالك؛ إساءة في الحياة، وإساءة عند الموت، انظر إلى قرابتك الذين يحتاجون ولا يرِثون؛ فأوصِ لهم من مالك بالمعروف{81}. (٢/١٦٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٣١٥<span class="dash">-</span></span> عن نافع: أنّ <span class="name-1">ابنَ عمر</span> لم يُوصِ، وقال: أمّا مالي فالله أعلمُ ما كنت أصنع فيه في الحياة، وأما رِباعي فما أحب أن يَشْرَك ولدي فيها أحد{82}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٣١٦<span class="dash">-</span></span> قال عَزْرَةُ -يعني: ابن ثابت- <span class="name-2">لربيع بن خُثيم</span>: أوْصِ لي بمصحفك. قال: فنظر إلى ابنه، فقال: <span class="qpc-hafs">﴿وأُولُو الأرْحامِ بَعْضُهُمْ أوْلى بِبَعْضٍ فِي كِتابِ اللَّهِ﴾</span> [الأنفال:٧٥]{82}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٣١٧<span class="dash">-</span></span> عن <span class="name-2">مغيرة</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٣١٨<span class="dash">-</span></span> قال: العَجَبُ <span class="name-2">لأبي العالية</span>، أعتقته امرأةٌ من بني رياح، وأوصى بماله لبني هاشم{50}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٣١٩<span class="dash">-</span></span> وعن <span class="name-2">الشعبي</span> -من طريق جرير، عن رجل- قال: لم يكن له ذاك، ولا كرامة{50}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ١/١٥٩.أخرجه ابن جرير ٣/١٣٤، وابن أبي حاتم ١/٢٩٩. وعزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ٣/١٣٤.أخرجه ابن أبي حاتم ١/٢٩٩.علَّقه ابن أبي حاتم ١/٢٩٩.أخرجه ابن جرير ٣/١٣٥، وفي تفسير مجاهد ص٢٢٠ مقتصرًا على قوله: <span class="qpc-hafs">﴿إن ترك خيرا﴾</span>، يعني: مالًا.أخرجه ابن جرير ٣/١٣٥. وعلَّقه ابن أبي حاتم ١/٢٩٩.أخرجه ابن جرير ٣/١٣٦. وعلَّقه ابن أبي حاتم ١/٢٩٩.علّقه ابن أبي حاتم ١/٢٩٩. وذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ١/١٩٨-. وعزاه السيوطي إلى عبد بن حميد.علَّقه ابن أبي حاتم ١/٢٩٩.أخرجه ابن جرير ٣/١٣٥، وابن أبي حاتم ١/٢٩٩ (عَقِب ١٦٠٠).أخرجه ابن جرير ٣/١٣٥، وابن أبي حاتم ١/٢٩٩ (عَقِب ١٦٠٠).أخرجه ابن أبي حاتم ١/٢٩٩.تفسير مقاتل بن سليمان ١/١٥٩.أخرجه عبد الله بن وهْب في الجامع - تفسير القرآن ٢/١٥٨-١٥٩ (٣٢٨).أخرجه عبد الرزاق في تفسيره ١/٦٨، وفي مصنفه (١٦٣٥١)، وسعيد بن منصور (٢٥١- تفسير)، وابن أبي شيبة ١١/٢٠٨، وابن جرير ٣/١٣٦-١٣٧، وابن أبي حاتم ١/٢٩٨، والحاكم ٢/٢٧٣-٢٧٤، والبيهقي ٦/٢٧٠. وعزاه السيوطي إلى الفريابي، وعبد بن حميد، وابن المنذر.أخرجه سعيد بن منصور (٢٤٨ - تفسير)، وابن أبي شيبة ١١/٢٠٨، والبيهقي ٦/٢٠٨، ٢٧٠. وعزاه السيوطي إلى ابن المنذر.كذا في مطبوعة تفسير ابن جرير، وفي بعض النسخ: عيينة أو عتبة، والأثر رواه عبد الرزاق في المصنف -كما سيأتي في تخريج الأثر- قال: أخبرنا الثوري، عن منصور بن صفية قال: حدثنا عبد الله بن عبيد بن عمير، أن عائشة سئلت عن رجل مات وله أربعمائة دينار، وله عدة من الولد، فقالت عائشة: ما في هذا فضل عن ولده. وهو طريق ابن جرير نفسه، ومنه يتبين أنّ الراوي الذي شك فيه ابن جرير هو عبد الله بن عبيد، والأقرب أن يشك بأنه عبد الله بن عيينة أو عتبة، أما غنية فبعيد.أخرجه عبد الرزاق في المصنف ٩/٦٣ (١٦٣٥٤)، وابن جرير ٣/١٣٧ واللفظ له.عزاه السيوطي إلى عبد بن حميد.أخرجه سعيد بن منصور (٢٥٠- تفسير)، والبيهقي ٦/٢٧٠. وعزاه السيوطي إلى عبد الرزاق.أخرجه عبد الرزاق ١/٦٩، وابن جرير ٣/١٣٨.عزاه السيوطي إلى عبد بن حميد.عزاه السيوطي إلى عبد بن حميد.أخرجه عبد الرزاق ١/٦٨، وابن جرير ٣/١٣٨. وعزاه السيوطي إلى عبد بن حميد.تفسير الثعلبي ٢/٥٧، وتفسير البغوي ١/١٩٣، وعقّبا على الأثر بقولهما: أي: الأحوج، فالأحوج.أخرجه عبد الرزاق (١٦٤٣٠). وعزاه السيوطي إلى عبد بن حميد.أخرجه عبد الرزاق (١٦٤٣٤). وعزاه السيوطي إلى عبد بن حميد.تفسير مجاهد ص٢٢١.أخرجه عبد الرزاق (١٦٤٢٦، ١٦٤٢٧). وعزاه السيوطي عبد بن حميد.تفسير مقاتل بن سليمان ١/١٥٩.أخرجه البخاري ٤/٣ (٢٧٤٢، ٢٧٤٤)، ٥/٦٨ (٣٩٣٦)، ٥/١٧٨ (٤٤٠٩)، ٧/٦٢ (٥٣٥٤)، ٧/١١٨ (٥٦٥٩)، ومسلم ٣/١٢٥٠-١٢٥٣ (١٦٢٨). وأورده الثعلبي ٢/٦٠.أخرجه البخاري ٤/٣ (٢٧٤٣)، ومسلم ٣/١٢٥٣ (١٦٢٩).تفسير البغوي ١/١٩٣.أخرجه عبد الرزاق (١٦٤٣٣). وعزاه السيوطي عبد بن حميد.تفسير البغوي ١/١٩٣.تفسير البغوي ١/١٩٣.أخرجه ابن أبي حاتم ١/٣٠٠.أخرجه ابن أبي حاتم ١/٣٠٠.تفسير مقاتل بن سليمان ١/١٥٩.أخرجه عبد الرزاق ١/٦٨، وابن جرير ٣/١٣٤.تفسير الثعلبي ٢/٥٧.علّقه ابن أبي حاتم ١/٢٩٩.أخرجه سعيد بن منصور (٢٥٢- تفسير)، وابن جرير ٣/١٣١، والحاكم ٢/٢٧٣، والبيهقي ٦/٢٦٥، ٧/٤٢٧. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي داود.أخرجه النحاس في ناسخه ص٨٨-٨٩، وابن أبي حاتم ١/٢٩٩. وعزاه السيوطي إلى أبي داود في الناسخ، وابن المنذر.أخرجه ابن جرير ٣/١٢٩-١٣٠. وعزاه السيوطي إلى ابن أبي حاتم.أخرجه أبو داود (٢٨٦٩)، والبيهقي ٦/٢٦٥. وعزاه السيوطي إلى أبي داود في ناسخه.أخرجه ابن جرير ٣/١٢٨.أخرجه ابن أبي شيبة ١١/٢٠٩، وابن جرير ٣/١٣١-١٣٢، والبيهقي ٦/٢٦٥. وعزاه السيوطي إلى وكيع، وعبد بن حميد، وابن المنذر.أخرجه ابن جرير ٣/١٢٥.أخرجه ابن جرير ٣/١٢٨.علّقه ابن أبي حاتم ١/٢٩٩.أخرجه ابن أبي حاتم ١/٣٠٠.علَّقه ابن أبي حاتم ١/٣٠٠.أخرجه ابن أبي حاتم ١/٣٠٠.أخرجه ابن جرير ٣/١٢٧.أخرجه ابن جرير ٣/١٣٠.عزاه السيوطي إلى عبد بن حميد.علَّقه النحاس في الناسخ والمنسوخ ١/٤٨٣.أخرجه ابن جرير ٣/١٢٥.أخرجه ابن جرير ٣/١٢٥.علَّقه ابن أبي حاتم ١/٢٩٩.تفسير الثعلبي ٢/٥٧، وتفسير البغوي ١/١٩٢.أخرجه الدارمي في سننه ٢/٥١١، وابن جرير ٣/١٣٢.أخرجه ابن أبي حاتم ١/٢٩٨.أخرجه سعيد بن منصور في سننه (ت: سعد آل حميد) ٢/٦٥٥ (٢٤٧)، والدارمي في سننه ٣/٢٠٦٤ (٣٣٠٦) مختصرًا. وأخرج نحوه ابن جرير ٣/١٢٩ من طريق إسماعيل المكي، كما أخرج ٣/١٢٩ من طريق مبارك بن فضالة بلفظ: نَسَخ الوالدين، وأثبتَ الأقربين الذين يُحرَمون ولا يَرِثون. وعلَّقه ابن أبي حاتم ١/٢٩٩.أخرجه الدارمي في سننه ٣/٢٠٦٣ (٣٣٠٤). وعلّقه ابن أبي حاتم ١/٣٠٠. وعزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ٣/١٣٢. وعلّقه ابن أبي حاتم ١/٢٩٩ (عَقِب ١٦٠٤).الناسخ والمنسوخ للزهري ص٢٠. وعلَّقه ابن أبي حاتم ١/٢٩٩.أخرجه ابن جرير ٣/١٣٣، وابن أبي حاتم ١/٢٩٩ (عَقِب ١٦٠٤).أخرجه عبد الله بن وهب في الجامع - تفسير القرآن ٣/٦٦ (١٤٨). وعلّقه ابن أبي حاتم ١/٢٩٩.أخرجه ابن جرير ٣/١٣٠، وابن أبي حاتم ١/٢٩٩ (عَقِب ١٦٠٤).أخرجه ابن أبي حاتم ١/٢٩٩.تفسير مقاتل بن سليمان ١/١٥٩.أخرجه مالك في الموطأ (ت: د. بشار عواد) ٢/٣١٤ (٢٢٢٤).أخرجه ابن جرير ٣/١٣١.أخرجه أحمد ٢٩/٢١٢-٢١٥، ٢١٧ (١٧٦٦٤، ١٧٦٦٥، ١٧٦٦٦، ١٧٦٦٩، ١٧٦٧٠)، ٢٩/٦٢٢-٦٢٥ (١٨٠٨١، ١٨٠٨٢، ١٨٠٨٣، ١٨٠٨٦، ١٨٠٨٧)، والترمذي ٤/١٩٩-٢٠٠ (٢٢٥٤)، والنسائي ٦/٢٤٧ (٣٦٤٢)، وابن ماجه ٤/١٦-١٧ (٢٧١٢).</p><p>قال الترمذي: «حديث حسن صحيح».أخرجه أحمد ٣٦/٦٢٨ (٢٢٢٩٤)، وأبو داود ٤/٤٩٢ (٢٨٧٠)، ٥/٤١٧ (٣٥٦٥)، والترمذي ٤/١٩٨-١٩٩ (٢٢٥٣)، وابن ماجه ٤/١٨ (٢٧١٣).</p><p>قال الترمذي: «حديث حسن». وقال ابن القيسراني في ذخيرة الحفاظ ١/٥٨٥: «وهذا من أفراد إسماعيل، وحيد حديثه». وقال الذهبي في تنقيح التحقيق ٢/١٥٧: «حديث ابن عياش صحيح، خرّجه أحمد». وقال ابن حجر في الفتح ٥/٣٧٢: «في إسناده إسماعيل بن عياش، وقد قوّى حديثَه عن الشاميين جماعةٌ من الأئمة». وقال الألباني في الإرواء (٦/٨٨): «إسناده حسن».عزاه السيوطي إلى عبد بن حميد مرسلًا.</p><p>ومراسيل الحسن من أوهى المراسيل كما في الموقظة للذهبي ص٤٠.</p><p>وقد أخرجه الدارقطني ٤/١٥٢ من طريق إسماعيل بن مسلم عن الحسن، عن عمرو بن خارجة، به مرفوعًا.أخرجه البخاري ٤/٢ (٢٧٣٨) بلفظ: ليلتين، ومسلم ٣/١٢٤٩، ١٢٥٠ (١٦٢٧) واللفظ له.أخرجه عبد الرزاق ٩/٦٧ (١٦٣٦٨) عن قتادة مرسلًا.</p><p>ومراسيله من أوهى المراسيل، بل هي أوهى من مراسيل الحسن البصري، كما في الموقظة للذهبي ص٤٠.أخرجه ابن جرير ٣/١٣٣.أخرجه ابن جرير ٣/١٣٣.أخرجه ابن جرير ٣/١٢٥.أخرجه ابن جرير ٣/١٢٥.
  2,181,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿فَمَنۢ بَدَّلَهُۥ بَعۡدَ مَا سَمِعَهُۥ فَإِنَّمَاۤ إِثۡمُهُۥ عَلَى ٱلَّذِینَ یُبَدِّلُونَهُۥۤۚ إِنَّ ٱللَّهَ سَمِیعٌ عَلِیمࣱ ۝١٨١﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٣٢٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي بن أبي طلحة- في قوله: <span class="qpc-hafs">﴿فمن بدله بعد ما سمعه فإنما إثمه على الذين يبدلونه﴾</span>: وقد وقع أجرُ الموصي على الله، وبَرِئ من إثمه، وإن كان أوصى في ضِرارٍ لم تَجُزْ وصيتُه، كما قال: <span class="qpc-hafs">﴿غير مضار﴾</span> [النساء:١٢]{1}. (٢/١٦٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٣٢١<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span> -من طريق عطاء بن دينار-: <span class="qpc-hafs">﴿فمن بدله﴾</span> يقول للأوصياء: من بدل وصية الميت <span class="qpc-hafs">﴿بعد ما سمعه﴾</span> يعني: من بعد ما سمع من الميت، فلم يُمْضِ وصيتَه إذا كان عدلًا؛ <span class="qpc-hafs">﴿فإنما إثمه﴾</span> يعني: إثم ذلك <span class="qpc-hafs">﴿على الذين يبدلونه﴾</span> يعني: الوصيَّ، وبرئ منه الميتُ، <span class="qpc-hafs">﴿إن الله سميع﴾</span> يعني: للوصية، <span class="qpc-hafs">﴿عليم﴾</span> بها{2}. (٢/١٦٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٣٢٢<span class="dash">-</span></span> عن قتادة، عن <span class="name-2">عطاء</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٣٢٣<span class="dash">-</span></span> و<span class="name-2">سالم بن عبد الله</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٣٢٤<span class="dash">-</span></span> و<span class="name-2">سليمان بن يسار</span> أنهم قالوا: تُمضى الوصية لِمَن أوْصى له به.= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٣٢٥<span class="dash">-</span></span> وقال <span class="name-2">عبيد الله بن عبيد الله بن مَعْمَر</span>: أعجبُ إلَيَّ لَوْ أوْصى لذوي القرابة، وما يعجبني أن أنزعه ممن أوصى له به.= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٣٢٦<span class="dash">-</span></span> قال <span class="name-2">قتادة</span>: وأعجبه إليّ لمن أوصى له به، قال الله ﷿: <span class="qpc-hafs">﴿فمن بدَّله بعدَ ما سمعه فإنما إثمه على الذين يبدّلونه﴾</span>{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٣٢٧<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- <span class="qpc-hafs">﴿فمن بدَّله بَعد ما سمعه﴾</span>، قال: الوصية{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٣٢٨<span class="dash">-</span></span> عن <span class="name-2">عطاء بن أبي رباح</span> -من طريق قتادة- في قوله: <span class="qpc-hafs">﴿فمن بدَّله بعد ما سمعه فإنما إثمه على الذين يبدّلونه﴾</span>، قال: تُمْضى كما قال{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٣٢٩<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق يزيد بن إبراهيم- في هذه الآية: <span class="qpc-hafs">﴿فمن بدّله بعد ما سمعه فإنما إثمه على الذين يبدِّلونه﴾</span>، قال: هذا في الوصية، مَن بدَّلها من بعد ما سمعها فإنّما إثمه على من بَدَّل{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٣٣٠<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دِعامة</span> -من طريق مَعْمَر- في قوله: <span class="qpc-hafs">﴿فمن بدله﴾</span>، قال: مَن بدّل الوصيّة بعد ما سمعها فإثمُ ما بُدِّل عليه{7}. (٢/١٦٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٣٣١<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السدي</span> -من طريق أسباط- <span class="qpc-hafs">﴿فمن بدَّله بعد ما سمعه فإنما إثمه على الذين يبدلونه﴾</span>: فمن بدَّل الوصية التي أوصى بها، وكانت بمعروف؛ فإنما إثمها على من بدَّلها؛ أنه قد ظلم{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٣٣٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فمن بدله بعد ما سمعه﴾</span> يقول: مَن بدلّ وصيّة الميّت -يعني: الوصي والولي- بعد ما سمعه من الميت، فلم يُمْضِ وصيته <span class="qpc-hafs">﴿فإنما إثمه على الذين يبدلونه﴾</span> يعني: الوصي والولي، وبرئِ منه الميت، <span class="qpc-hafs">﴿إن الله سميع﴾</span>لوصية الميت، <span class="qpc-hafs">﴿عليم﴾</span>بها{9}<span class=comment-ref>٦٣٥</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٣٥</span> قال <u>ابنُ جرير</u> (٣/١٣٩): «معنى الكلام: أوصوا لهم، فمَن بدّل ما أوصيتم به لهم بعد ما سَمعكم توصون لَهم، فإنما إثم ما فعل من ذلك عليه دونكم».</p><p>وقال <u>ابنُ عطية</u> (١/٤٣٢): «الضمير في <span class="qpc-hafs">﴿بدله﴾</span> عائد على الإيصاء وأمر الميت، وكذلك في <span class="qpc-hafs">﴿سمعه﴾</span>، ويحتمل أن يعود الذي في <span class="qpc-hafs">﴿سمعه﴾</span> على أمر الله تعالى في هذه الآية، والقول الأول أسبق للناظر».</p><p>وقال <u>ابنُ كثير</u> (١/١٧١): «ويدخل في ذلك الكتمانُ لها بطريق الأَوْلى».</div></p><p><h3><span class="qpc-hafs">﴿فَمَنۢ بَدَّلَهُۥ بَعۡدَ مَا سَمِعَهُۥ فَإِنَّمَاۤ إِثۡمُهُۥ عَلَى ٱلَّذِینَ یُبَدِّلُونَهُۥۤۚ إِنَّ ٱللَّهَ سَمِیعٌ عَلِیمࣱ ۝١٨١﴾</span> - النسخ في الآية</h3></p><p><div></p><p><p><span class="item-no">٥٣٣٣<span class="dash">-</span></span> عن <span class="name-3">الكلبي</span>: كان الأولياء والأوصياء يُمْضُون وصيّة الميّت بعد نزول قوله تعالى: <span class="qpc-hafs">﴿فمن بدّله بعد ما سمعه﴾</span> الآية، وإن استغرق المالَ كلّه، ولم يبق للورثة شيءٌ، ثمّ نسخها قولُه تعالى: <span class="qpc-hafs">﴿فمن خاف من موص جنفا﴾</span> الآية{10}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٣٣٤<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span>: فعَجز المُوصي أن يوصي للوالدين والأقربين كما أمر الله تعالى، وعَجز الوصيُّ أن يُصْلِح؛ فانتزع الله تعالى ذلك منهم، ففَرَض الفرائض{10}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ٣/١٤٠، وابن أبي حاتم ١/٣٠٠ مختصرًا. وعزاه السيوطي إلى ابن المنذر.أخرجه ابن أبي حاتم ١/٣٠٠-٣٠١.أخرجه ابن جرير ٣/١٤١.أخرجه ابن جرير ٣/١٣٩.أخرجه ابن جرير ٣/١٤٠.أخرجه ابن جرير ٣/١٤١. وعلَّقه ابن أبي حاتم ١/٣٠٠. وذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ١/١٩٨-.أخرجه عبد الرزاق ١/٦٩، وابن جرير ٣/١٤٠، وابن أبي حاتم ١/٣٠٠.أخرجه ابن جرير ٣/١٤٠.تفسير مقاتل بن سليمان ١/١٥٩.تفسير الثعلبي ٢/٦٠، وتفسير البغوي ١/١٩٤.تفسير الثعلبي ٢/٦٠، وتفسير البغوي ١/١٩٤.