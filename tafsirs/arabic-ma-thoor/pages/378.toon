quran[9]{c,v,t}:
  27,14,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَجَحَدُوا۟ بِهَا وَٱسۡتَیۡقَنَتۡهَاۤ أَنفُسُهُمۡ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٦٩٤٩<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطاء الخراساني- <span class="qpc-hafs">﴿واستيقنتها أنفسهم ظلما وعلوا﴾</span>، قال: يقينهم في قلوبهم{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٩٥٠<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طُرُقٍ- في قوله: <span class="qpc-hafs">﴿وجحدوا بها﴾</span>، قال: كذَّبت القومُ بآيات الله بعد ما استيقنتها أنفسُهم أنّها حقٌّ، والجحود لا يكون إلا مِن بعد المعرفة{2}. (١١/٣٣٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٩٥١<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد بن بشير- في قوله: <span class="qpc-hafs">﴿وجحدوا بها﴾</span> قال: كذَّب بها القوم، وقوله: <span class="qpc-hafs">﴿بها﴾</span> بآيات الله ﷿، <span class="qpc-hafs">﴿واستيقنتها أنفسهم﴾</span> وقد أيقنتها أنفسهم أنّ موسى رسول الله ﷺ{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٩٥٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: يقول الله ﷿: <span class="qpc-hafs">﴿وجحدوا بها﴾</span> يعني: بالآيات، يعني: بعد المعرفة، فيها تقديم، <span class="qpc-hafs">﴿واستيقنتها أنفسهم﴾</span> أنّها مِن الله ﷿، وأنّها ليست بسحر{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٩٥٣<span class="dash">-</span></span> عن <span class="name-3">عبد الملك ابن جُرَيْج</span> -من طريق حجّاج- <span class="qpc-hafs">﴿وجحدوا بها﴾</span>، قال: الجحود: التكذيب بها{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٩٥٤<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قول الله: <span class="qpc-hafs">﴿واستيقنتها أنفسهم ظلما وعلوا﴾</span>، قال: استيقنوا أنّ الآيات مِن الله حقٌّ، فلِمَ جحدوا بها؟ قال: <span class="qpc-hafs">﴿ظلما وعلوا﴾</span>{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٩٥٥<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿وجحدوا بها واستيقنتها أنفسهم﴾</span> أنّها مِن عند الله{7}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿ظُلۡمࣰا وَعُلُوࣰّاۚ﴾</span> - قراءات</h3></p><p><div></p><p><p><span class="item-no">٥٦٩٥٦<span class="dash">-</span></span> عن <span class="name-2">عاصم بن أبي النجود</span> أنّه قرأ: <span class="qpc-hafs">﴿وعُلُوًّا﴾</span> برفع العين واللام{8}. (١١/٣٣٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٩٥٧<span class="dash">-</span></span> عن <span class="name-2">سليمان الأعمش</span> أنّه قرأ: (ظُلْمًا وعِلِيًّا){9}. (١١/٣٣٩)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿ظُلۡمࣰا وَعُلُوࣰّاۚ﴾</span> - تفسير الآية</h3></p><p><div></p><p><p><span class="item-no">٥٦٩٥٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، في قوله: <span class="qpc-hafs">﴿ظلما وعلوا﴾</span>، قال: تَعَظُّمًا، واستكبارًا{10}. (١١/٣٣٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٩٥٩<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span> -من طريق يزيد النحوي- قال: العُلُوُّ في كتاب الله: التَّجَبُّر{11}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٩٦٠<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- في قوله: <span class="qpc-hafs">﴿واستيقنتها أنفسهم ظلما وعلوا﴾</span>، قال: تكبَّروا وقد استيقنتها أنفسهم، وهذا مِن التقديم والتأخير{12}. (١١/٣٣٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٩٦١<span class="dash">-</span></span> عن <span class="name-2">عطاء الخراساني</span> -من طريق ابنه عثمان-: أمّا <span class="qpc-hafs">﴿ظلما وعلوا﴾</span>: فظُلمًا وتَعَظُّمًا واستكبارًا{12}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٩٦٢<span class="dash">-</span></span> عن <span class="name-3">عبد الملك ابن جُرَيْج</span> -من طريق حجاج- في قوله: <span class="qpc-hafs">﴿ظلما وعلوا﴾</span>، قال: تَعَظُّمًا واستكبارًا{14}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٩٦٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ظلما﴾</span> شركًا، <span class="qpc-hafs">﴿وعلوا﴾</span> تكبرًا{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٩٦٤<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿ظلما﴾</span> لأنفسهم، وقال في آية أخرى: <span class="qpc-hafs">﴿وما ظلمونا ولكن كانوا أنفسهم يظلمون﴾</span> [الأعراف:١٦٠]{7}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿فَٱنظُرۡ كَیۡفَ كَانَ عَـٰقِبَةُ ٱلۡمُفۡسِدِینَ ۝١٤﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٦٩٦٥<span class="dash">-</span></span> عن <span class="name-2">أبي العالية الرياحي</span> -من طريق الربيع- قال: وكان فسادهم ذلك معصية الله؛ لأنّه مَن عصى الله في الأرض أو أمر بمعصية فقد أفسد في الأرض؛ لأنّه صلاح الأرض والسماء بالطاعة{17}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٩٦٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فانظر كيف كان عاقبة المفسدين﴾</span> في الأرض بالمعاصي، كان عاقبتهم الغرق، وإنّما استيقنوا بالآيات أنّها مِن الله لدعاء موسى ربَّه أن يكشِف عنهم الرِّجْز، فكشفه عنهم. وقد علِموا ذلك{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٩٦٧<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿فانظر كيف كان عاقبة المفسدين﴾</span> المشركين، يعنيهم، كان عاقبتهم أن دَمَّر الله عليهم، ثم صيــــَّرهم إلى النار{7}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ١٨/٢٣.|2:أخرج ابن أبي حاتم ٩/٢٨٥٢-٢٨٥٣ شطره الأول من طريق سعيد بن بشير وشيبان، وشطره الثاني من طريق سعيد بن أبي عروبة. وعلق يحيى بن سلام ٢/٥٣٦ آخره. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.|3:أخرجه ابن أبي حاتم ٩/٢٨٥٢-٢٨٥٣.|4:تفسير مقاتل بن سليمان ٣/٢٩٨.|5:أخرجه ابن جرير ١٨/٢٣.|6:أخرجه ابن جرير ١٨/٢٣، وابن أبي حاتم ٩/٢٨٥٣ من طريق أصبغ.|7:تفسير يحيى بن سلام ٢/٥٣٦.|8:عزاه السيوطي إلى عبد بن حميد.</p><p>وهي قراءة العشرة.|9:عزاه السيوطي إلى عبد بن حميد.</p><p>وهي قراءة شاذة، تروى أيضًا عن ابن مسعود، وطلحة. انظر: مختصر ابن خالويه ص١١٠.|10:عزاه السيوطي إلى ابن المنذر.|11:أخرجه ابن أبي حاتم ٩/٢٨٥٣، وأورده في تفسير (العتو) من قوله تعالى: <span class="qpc-hafs">﴿فلما عتوا عما نهوا عنه﴾</span> [الأعراف:١٦٦]، وقوله تعالى: <span class="qpc-hafs">﴿وعتوا عتوا كبيرا﴾</span> [الفرقان:٢١].|12:أخرجه ابن أبي حاتم ٩/٢٨٥٣.|13:أخرجه ابن أبي حاتم ٩/٢٨٥٣.|14:أخرجه ابن جرير ١٨/٢٢.|15:تفسير مقاتل بن سليمان ٣/٢٩٨.|16:تفسير يحيى بن سلام ٢/٥٣٦.|17:أخرجه ابن أبي حاتم ٩/٢٨٥٣، وتقدم أصله عند تفسير قوله تعالى: <span class="qpc-hafs">﴿وإذا قيل لهم لا تفسدوا﴾</span> الآية [البقرة:١١].|18:تفسير مقاتل بن سليمان ٣/٢٩٨.|19:تفسير يحيى بن سلام ٢/٥٣٦.
  27,15,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَلَقَدۡ ءَاتَیۡنَا دَاوُۥدَ وَسُلَیۡمَـٰنَ عِلۡمࣰاۖ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٦٩٦٨<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق سعيد بن أبي عروبة، عن قتادة- في قول الله ﷿: <span class="qpc-hafs">﴿ولقد آتينا داود وسليمان علما﴾</span>، يعني: التوراة، والزبور، والفقه في الدين، وفصل القضاء، وعِلْم كلام الطير والدواب{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٩٦٩<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد بن أبي عروبة- قوله: <span class="qpc-hafs">﴿داود وسليمان علما﴾</span>، قال: فَهْمًا{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٩٧٠<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد بن بشير- قال: كان داود أعطي ثلاثًا{3}: سُخِّرت له الجبال يُسَبِّحْن معه، وأُلِينَ له الحديد، وعُلِّم منطق الطير، وسُخِّرت له الجن، فلمّا مات عُلِّم سليمان منطق الطير وسُخِّرت له الجن، وكان ذلك مما ورِث عنه، ولم تُسخَّر له الجبال، ولم يُلَنْ له الحديد{2}. (١١/٣٣٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٩٧١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ولقد آتينا﴾</span> يعني: أعطينا <span class="qpc-hafs">﴿داود وسليمان علما﴾</span> بالقضاء، وبكلام الطير، وبكلام الدواب{5}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَقَالَا ٱلۡحَمۡدُ لِلَّهِ ٱلَّذِی فَضَّلَنَا عَلَىٰ كَثِیرࣲ مِّنۡ عِبَادِهِ ٱلۡمُؤۡمِنِینَ ۝١٥﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٦٩٧٢<span class="dash">-</span></span> عن <span class="name-2">عمر بن عبد العزيز</span> -من طريق إبراهيم بن هشام بن يحيى، عن أبيه، عن جده- أنّه كَتَب: إنّ الله لم يُنعِم على عبد نعمةً، فحَمِد الله عليها، إلا كان حمدُه أفضلَ مِن نعمته، لو كنتَ لا تعرف ذلك إلا في كتاب الله المنزل؛ قال الله ﷿: <span class="qpc-hafs">﴿ولقد آتينا داود وسليمان علما وقالا الحمد لله الذي فضلنا على كثير من عباده المؤمنين﴾</span>، وأيُّ نعمةٍ أفضلُ مِمّا أُوتي داود وسليمان؟!{6}. (١١/٣٣٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٩٧٣<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق سعيد بن أبي عروبة، عن قتادة- في قول الله ﷿: <span class="qpc-hafs">﴿وقالا الحمد لله الذي فضلنا على كثير من عباده المؤمنين﴾</span>، يعني بالتفضيل: النبوة مع الملك{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٩٧٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وقالا الحمد لله الذي فضلنا على كثير من عباده المؤمنين﴾</span>، يعني: بالقضاء، والنبوة، والكتاب، وكلام البهائم، والملك الذي أعطاهما الله ﷿، وكان سليمان أعظم ملكًا مِن داود، وأفطن منه، وكان داود أكثرَ تَعَبُّدًا مِن سليمان{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٩٧٥<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: قوله ﷿: <span class="qpc-hafs">﴿ولقد آتينا داود وسليمان علما وقالا الحمد لله الذي فضلنا على كثير من عباده المؤمنين﴾</span>، يعنيان: أهل زمانهم من المؤمنين{9}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن عساكر في تاريخ دمشق ٢٢/٢٣٩.|2:أخرجه ابن أبي حاتم ٩/٢٨٥٤.|3:هكذا في الأصل.|4:أخرجه ابن أبي حاتم ٩/٢٨٥٤.|5:تفسير مقاتل بن سليمان ٣/٢٩٨.|6:أخرجه ابن أبي حاتم ٩/٢٨٥٤، وأبو نعيم في حلية الأولياء ٥/٢٩٣.|7:أخرجه ابن عساكر في تاريخ دمشق ٢٢/٢٣٩.|8:تفسير مقاتل بن سليمان ٣/٢٩٨. ونحو آخره في تفسير الثعلبي ٧/١٩٣، وتفسير البغوي ٦/١٤٨ منسوبًا إلى مقاتل دون تعيينه.|9:تفسير يحيى بن سلام ٢/٥٣٦.
  27,16,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَوَرِثَ سُلَیۡمَـٰنُ دَاوُۥدَۖ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٦٩٧٦<span class="dash">-</span></span> قال أبو بكر الهذلي: قال لي <span class="name-2">شهر بن حوشب</span>: لَمّا مات داود ورِثه سليمان. قال الله تعالى: <span class="qpc-hafs">﴿وورث سليمان داود وقال يا أيها الناس علمنا منطق الطير﴾</span> الآية{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٩٧٧<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق شيبان- في قوله: <span class="qpc-hafs">﴿وورث سليمان داود﴾</span>، قال: ورثه نبوتَه، ومُلكه، وعِلمه{2}. (١١/٣٤٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٩٧٨<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- في قوله تعالى: <span class="qpc-hafs">﴿وورث سليمان داود﴾</span>، قال: نبوته{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٩٧٩<span class="dash">-</span></span> عن <span class="name-2">الربيع بن أنس</span> -من طريق أبي جعفر- في قوله: <span class="qpc-hafs">﴿وورث سليمان داود﴾</span>، قال: ورثه أن سخَّر له الشياطين والرياح إلى ما ورث مما أُعطِي أبوه{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٩٨٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وورث سليمان داود﴾</span>، يعني: ورث سليمانُ عِلْمَ داود، ومُلْكَه{5}<span class=comment-ref>٤٨٤٧</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٤٨٤٧</span> <span class="comment-type-3">رجَّح</span> <u>ابنُ القيم</u> (٢/٢٧٩) أنّ الميراث: هو ميراث العلم والنبوة فقط، <span class="mustanad">مستندًا إلى الإجماع، ودلالة العقل، والسياق، والنظائر</span>، فقال: «هو ميراث العلم والنبوة لا غير، وهذا باتفاق أهل العلم من المفسرين وغيرهم، وهذا لأنّ داود ﵇ كان له أولاد كثير سوى سليمان، فلو كان الموروث هو المال لم يكن سليمان مختصًّا به. وأيضًا فإنّ كلام الله يصان عن الإخبار بمثل هذا؛ فإنه بمنزلة أن يقال: مات فلان وورثه ابنه. ومِن المعلوم أنّ كلَّ أحد يرثه ابنه، وليس في الإخبار بمثل هذا فائدة، وأيضًا فإنّ ما قبل الآية وما بعدها يبين أنّ المراد بهذه الوراثة وراثة العلم والنبوة لا وراثة المال، قال تعالى: <span class="qpc-hafs">﴿ولقد آتينا داوود وسليمان علما وقالا الحمد لله الذي فضلنا على كثير من عباده المؤمنين وورث سليمان داوود﴾</span>، وإنما سيق هذا لبيان فضل سليمان، وما خصَّه الله به من كرامته وميراثه ما كان لأبيه من أعلى المواهب، وهو العلم والنبوة، <span class="qpc-hafs">﴿إن هذا لهو الفضل المبين﴾</span>، وكذلك قول زكريا ﷺ: <span class="qpc-hafs">﴿وإني خفت الموالي من ورائي وكانت امرأتي عاقرا فهب لي من لدنك وليا يرثني ويرث من آل يعقوب واجعله رب رضيا﴾</span> [مريم:٥-٦]، فهذا ميراث العلم والنبوة والدعوة الى الله، وإلا فلا يظن بنبي كريم أنه يخاف عصبته أن يرثوه ماله، فيسأل الله العظيم ولدًا يمنعهم ميراثه، ويكون أحق به منهم! وقد نزه الله أنبياءه ورسله عن هذا وأمثاله».</p><p>و<span class="comment-type-4">بنحوه</span> <u>ابنُ تيمية</u> (٥/٦٤)، إلا أنه <span class="comment-type-2">انتقد</span> الاستدلال بقوله تعالى: <span class="qpc-hafs">﴿فهب من لدنك وليا يرثني﴾</span>، <span class="mustanad">مستندًا إلى اللغة</span>، فذكر أنه: «لا يدل على محل النزاع؛ لأنّ الإرثَ اسمُ جنس تحته أنواع، والدالُّ على ما به الاشتراك لا يدل على ما به الامتياز، فإذا قيل: هذا حيوان. لا يدل على أنه إنسان أو فرس أو بعير، وذلك أنّ لفظ الإرث يستعمل في إرث العلم والنبوة والملك وغير ذلك من أنواع الانتقال، قال تعالى: <span class="qpc-hafs">﴿ثم أورثنا الكتاب الذين اصطفينا من عبادنا﴾</span> [فاطر:٣٢]».</div></p><p><h3><span class="qpc-hafs">﴿وَقَالَ یَـٰۤأَیُّهَا ٱلنَّاسُ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٦٩٨١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وقال﴾</span> سليمان لبني إسرائيل: <span class="qpc-hafs">﴿يا أيها الناس﴾</span>{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٩٨٢<span class="dash">-</span></span> عن <span class="name-3">الأوزاعي</span> -من طريق ضمرة- قال: الناس عندنا: أهلُ العلم{7}. (١١/٣٤٠)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿عُلِّمۡنَا مَنطِقَ ٱلطَّیۡرِ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٦٩٨٣<span class="dash">-</span></span> عن <span class="name-2">محمد بن كعب القرظي</span> -من طريق أبي معشر- <span class="qpc-hafs">﴿وقال يأيها الناس علمنا منطق الطير﴾</span>، قال: بلغنا: أنّ سليمان كان عسكرُه مائة فرسخ؛ خمسة وعشرون منها للإنس، وخمسة وعشرون للجن، وخمسة وعشرون للوحش، وخمسة وعشرون للطير، وكان له ألف بيت من قوارير على الخشب، فيها ثلاثمائة صَرِيحَة{8}، وسبعمائة سُرِّيّة{9}، فأمر الريحَ العاصِفَ فرفعته، وأمر الرَّخاء فسَيَّرَتْه، فأوحى الله إليه وهو يسير بين السماء والأرض: إنِّي قد زدتُ في مُلْكِك أنّه لا يتكلم أحدٌ مِن الخلائق بشيء إلا جاءت الريحُ فأخبرتك به{10}. (١١/٣٤٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٩٨٤<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- في قوله: <span class="qpc-hafs">﴿علمنا منطق الطير﴾</span>، قال: النملة مِن الطير{11}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿عُلِّمۡنَا مَنطِقَ ٱلطَّیۡرِ﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٥٦٩٨٥<span class="dash">-</span></span> عن عبد الله بن مسعود، قال: كنت عند عمر بن الخطاب، فدخل علينا <span class="name-2">كعب الحبر</span>، فقال: يا أمير المؤمنين، ألا أخبرك بأغربِ شيء قرأتُ في كتب الأنبياء! إنّ هامَةً{12} جاءت إلى سليمان، فقالت: السلام عليك، يا نبي الله. فقال: وعليك السلام، يا هامُ، أخبريني كيف لا تأكلين الزرعَ؟ فقالت: يا نبي الله، لأنّ آدم عصى ربَّه في سببه، لذلك لا آكله. قال: فكيف لا تشربين الماء؟ قالت: يا نبي الله، لأنّ الله أغرق بالماء قوم نوح، من أجل ذلك تركت شربها. قال: فكيف تركت العمران وأسكنت الخراب؟ قالت: لأنّ الخراب ميراث الله، وأنا أسكن في ميراث الله. وقد ذكر الله ذلك في كتابه فقال: <span class="qpc-hafs">﴿وكم أهلكنا من قرية بطرت معيشتها﴾</span> إلى قوله: <span class="qpc-hafs">﴿وكنا نحن الوارثين﴾</span> [القصص:٥٨]{13}. (١١/٣٤٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٩٨٦<span class="dash">-</span></span> عن <span class="name-2">أبي الصديق الناجي</span> -من طريق زيد العمي- قال: خرج سليمان بن داود يستسقي بالناس، فمَرَّ على نملة مُسْتَلْقِيَة على قفاها، رافعة قوائمها إلى السماء، وهي تقول: اللهم، إنّا خَلْقٌ مِن خَلْقِك، ليس بنا غِنًى عن رزقك، فإمّا أن تسقينا، وإما أن تهلكنا. فقال سليمان للناس: ارجعوا، فقد سُقِيتم بدعوة غيركم{14}. (١١/٣٤١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٩٨٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل</span>: كان سليمان ﵇ جالِسًا، إذ مرَّ به طائر يُصَوِّت، فقال لجُلسائه: هل تدرون ما يقول الطائر الذي مرَّ بنا؟ قالوا: أنت أعلم. فقال سليمان: إنّه قال لي: السلام عليك، أيها الملِك المسلط على بني إسرائيل، أعطاك اللهُ ﷾ الكرامةَ، وأظهرك على عدوك، إنِّي مُنطلِق إلى فروخي، ثم أمر بك الثانية. وإنّه سيرجع إلينا الثانية، فانظروا إلى رجوعه. قال: فنظر القوم طويلًا، إذ مرَّ بهم، فقال: السلام عليك، أيها الملك، إن شئت أن تأذن لي كيما أُحْسِب فروخي{15} حتى يشبوا ثم آتيك فافعل بي ما شئت. فأخبرهم سليمان بما قال، وأذِن له{16}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَأُوتِینَا مِن كُلِّ شَیۡءٍۖ إِنَّ هَـٰذَا لَهُوَ ٱلۡفَضۡلُ ٱلۡمُبِینُ ۝١٦﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٦٩٨٨<span class="dash">-</span></span> قال <span class="name-1">عبد الله بن عباس</span>: مِن أمر الدنيا والآخرة{17}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٩٨٩<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- قوله: <span class="qpc-hafs">﴿وأوتينا من كل شيء﴾</span>، قال: أوتوا مِن كل شيء كان في بلادهم{18}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٩٩٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وأوتينا من كل شيء﴾</span> يعني: أُعطينا الملكَ، والنبوةَ، والكتابَ، والرياحَ، وسُخِّرَتْ لنا الشياطين، ومنطق الدواب، ومحاريب، وتماثيل، وجفان كالجوابي، وقدور راسيات، وعين القطر -يعني: عين الصُّفْر-، <span class="qpc-hafs">﴿إن هذا﴾</span> الذي أُعْطِينا <span class="qpc-hafs">﴿لهو الفضل المبين﴾</span> يعني: البيِّن{19}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٩٩١<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: قوله ﷿: <span class="qpc-hafs">﴿وقال يأيها الناس علمنا منطق الطير وأوتينا من كل شيء﴾</span> يعني: كل شيء أوتي منه، <span class="qpc-hafs">﴿إن هذا لهو الفضل المبين﴾</span> البيِّن{20}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَأُوتِینَا مِن كُلِّ شَیۡءٍۖ إِنَّ هَـٰذَا لَهُوَ ٱلۡفَضۡلُ ٱلۡمُبِینُ ۝١٦﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٥٦٩٩٢<span class="dash">-</span></span> عن <span class="name-1">أبي الدرداء</span> -من طريق عبد الرحمن بن أبي ليلى- قال: كان داود يقضي بين البهائم يومًا، وبين الناس يومًا، فجاءت بقرةٌ، فوَضَعَتْ قرنها في حلقة الباب، ثم تَبَغَّمَتْ{21} كما تَبْغَمُ الوالدةُ على ولدها، وقالت: كنت شابَّةً، كانوا ينتجوني ويستعملوني، ثم إني كبرت، فأرادوا أن يذبحوني. فقال داود: أحسِنوا إليها، ولا تذبحوها. ثم قرأ: <span class="qpc-hafs">﴿علمنا منطق الطير وأوتينا من كل شيء﴾</span>{7}. (١١/٣٤١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٩٩٣<span class="dash">-</span></span> عن <span class="name-2">وهب بن مُنَبِّه</span>، قال: مرَّ سليمان بن داود وهو في مُلكه قد حملته الريحُ على رجل حرّاث مِن بني إسرائيل، فلمّا رآه قال: سبحان الله، لقد أوتي آل داود ملكًا! فحملتها الريح، فوضعتها في أذنه، فقال: ائتوني بالرجل. فأُتي به، فقال: ماذا قلت؟ فأخبره، فقال سليمان: إنِّي خشيت عليك الفتنة، لَثوابُ «سبحان الله» عند الله يوم القيامة أعظم مِمّا أوتي آل داود. فقال الحرّاث: أذهب اللهُ همَّك كما أذهبت هَمِّي. قال: وكان سليمان رجلًا أبيض، جسيمًا، أشعر، غَزّاءً، لا يسمع بملك إلا أتاه، فقاتله، فدَوَّخَه، يأمر الشياطين فيجعلون له دارًا مِن قوارير، فيحمل ما يريد مِن آلة الحرب فيها، ثم يأمر العاصف، فتحمله مِن الأرض، ثم يأمر الرخاء، فتقدمه حيث شاء{23}. (١١/٣٤٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٩٩٤<span class="dash">-</span></span> عن أبي بكر الهذلي، قال: قال <span class="name-2">شهر بن حوشب</span>: أعَلِمْتَ أو شعرتَ أنّ سليمان بن داود لم يكن يُحْسِن منطق الطير وأبوه حيٌّ! ... كان لداود ثلاثٌ مِن النعم، ولسليمان ثلاث مِن النِّعم: لداود الجبال أوبي معه، والطير، وألنا له الحديد.= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٩٩٥<span class="dash">-</span></span> قال الهذلي: عن <span class="name-2">الحسن</span> قال: كان داود يأخذ الحديد، فيقول له هكذا، فيصير في يده كأنّه العجين.= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٩٩٦<span class="dash">-</span></span> وقال <span class="name-2">شهر بن حوشب</span> في حديثه: ولسليمان عين القطر -وهو الصُّفر- جرى له مِن صنعاء، والشياطين، والرياح، فلما مات داود ورثه سليمان ملكه ونعمته{24}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٩٩٧<span class="dash">-</span></span> عن <span class="name-2">يحيى بن أبي كثير</span>، قال: قال سليمانُ بن داود لبني اسرائيل: ألا أريكم بعض ملكي اليوم؟ قالوا: بلى، يا نبي الله. قال: يا ريحُ، ارفعينا. فرفعتهم الريح، فجعلتهم بين السماء والأرض، ثم قال: يا طيرُ، أظِلِّينا. فأظلتهم الطيرُ بأجنحتها لا يرون الشمس، قال: يا بني إسرائيل، أي ملك ترون؟ قالوا: نرى مُلكًا عظيمًا. قال: فوالذي نفس سليمان بيده، لَقول العبد: لا إله إلا الله وحده لا شريك له، له الملك وله الحمد، وهو على كل شيء قدير. خيرٌ مِن مُلكي هذا، ومِن الدنيا وما فيها، يا بني إسرائيل، مَن خشي الله في السر والعلانية، وقصد في الغنى والفقر، وعدل في الرضا والغضب، وذكر الله على كل حال؛ فقد أُعطي مثل ما أُعطيت{25}. (١١/٣٤٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٩٩٨<span class="dash">-</span></span> عن <span class="name-3">ابن أبي نجيح</span> -من طريق سفيان- قال: قال سليمان بن داود ﵉: أوتينا مما أوتي الناس ومما لم يُؤْتَوْه، وعُلِّمنا مِمّا عُلِّم الناس وما لم يعلموا؛ فلم نجِد شيئًا هو أفضل مِن تقوى الله في السِّرِّ والعلانية، والعدل في الرضا والغضب، والقَصْد في الغِنى والفقر{26}. (٢/٣٩٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٦٩٩٩<span class="dash">-</span></span> عن <span class="name-3">جعفر بن محمد</span> -من طريق ابنه محمد- قال: أُعْطِي سليمان ملك مشارق الأرض ومغاربها، فمُلْك سليمان سبعمائة سنة وستة أشهر، ملك أهل الدنيا كلهم من الجن، والإنس، والدواب، والطير، والسباع، وأُعطي كل شيء، ومنطق كل شيء، وفي زمانه صنعت الصنائع المعجبة، حتى إذا أراد الله أن يقبضه إليه أوحى إليه: أن اسْتودِعْ علم الله وحكمته أخاه، ووَلَدَ داود. وكانوا أربعمائة وثمانين رجلًا؛ أنبياء بلا رسالة{27}. (١١/٣٤٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٠٠٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل</span>: نسجت الشياطينُ لسليمان ﵇ بِساطًا، فرسخًا في فرسخ، ذهبًا في إبريسم، وكان يوضع له منبر من الذهب في وسط البساط، فيقعد عليه، وحوله ثلاثة آلاف كرسي مِن ذهب وفضة، يقعد الأنبياء على كراسي الذهب، والعلماء على كراسي الفضة، وحولهم الناس، وحول الناس الجن والشياطين، وتُظِلُّه الطير بأجنحتها حتى لا تقع عليه الشمس، وترفع ريح الصبا البساط مسيرة شهر، مِن الصباح إلى الرواح، ومن الرواح إلى الصباح{28}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه إسحاق البستي في تفسيره ص٨.|2:أخرجه ابن أبي حاتم ٩/٢٨٥٤. وعلقه يحيى بن سلام ٢/٥٣٦ دون قوله: وعلمه. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.|3:أخرجه إسحاق البستي في تفسيره ص٧.|4:أخرجه ابن أبي حاتم ٩/٢٨٥٤.|5:تفسير مقاتل بن سليمان ٣/٢٩٩.|6:تفسير مقاتل بن سليمان ٣/٢٩٩.|7:أخرجه ابن أبي حاتم ٩/٢٨٥٥.|8:الصّريح: الخالص النسب. النهاية (صرح).|9:السُّرّية: الجارية المتَّخَذة للملك والجماع. اللسان (سرر).|10:أخرجه ابن جرير ١٨/٢٥، والحاكم ٢/٥٨٩.|11:أخرجه عبد الرزاق ٢/٧٩، وابن أبي حاتم ٩/٢٨٥٥.|12:الهامة: اسم طائر من طَيْر اللَّيل. وقيل: هِيَ البُومَة. النهاية (هوم).|13:أخرجه ابن أبي حاتم ٩/٢٩٩٦-٢٩٩٧.|14:أخرجه ابن أبي شيبة ١٠/٣١٢، ١٣/٢٠٧، وأحمد في الزهد ص٨٧، وابن أبي حاتم ٩/٢٨٥٨.|15:أُحْسِب فروخي: أطعمهم وأسقيهم، وأحسَبَ الرجلَ وحسَّبه: أطعمه وسقاه حتى يشبع. ينظر: لسان العرب (حسب).|16:تفسير الثعلبي ٧/١٩٣.|17:تفسير البغوي ٦/١٤٩.|18:أخرجه إسحاق البستي في تفسيره ص٧، وابن أبي حاتم ٩/٢٨٥٥.|19:تفسير مقاتل بن سليمان ٣/٢٩٩. وأوله في تفسير البغوي ٦/١٤٩ منسوبًا إلى مقاتل دون تعيينه.|20:تفسير يحيى بن سلام ٢/٥٣٦.|21:في مطبوعة تفسير ابن أبي حاتم ونسخ الدر: تنغمت بالنون بدل الباء، وقد أثبتنا ما أُثْبِت في مطبوعة الدر. ومعنى تَبَغَّمَتْ: صاحت إلى ولدها بأَرْخَم ما يكون من صوتها. اللسان (بغم).|22:أخرجه ابن أبي حاتم ٩/٢٨٥٥.|23:أخرجه عبد الله بن أحمد في زوائد الزهد ص٣٩-٤٠. وعزاه السيوطي إلى ابن المنذر. وينظر: تفسير الثعلبي ٧/١٩٦.|24:أخرجه إسحاق البستي في تفسيره ص٦.|25:عزاه السيوطي إلى ابن المنذر.|26:أخرجه الأصبهاني في الترغيب والترهيب ١/٤١٢.|27:أخرجه الحاكم في المستدرك ٢/٥٨٨.|28:تفسير الثعلبي ٧/١٩٦.
  27,17,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَحُشِرَ لِسُلَیۡمَـٰنَ جُنُودُهُۥ مِنَ ٱلۡجِنِّ وَٱلۡإِنسِ وَٱلطَّیۡرِ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٧٠٠١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وحشر لسليمان﴾</span> يعني: وجمع لسليمان <span class="qpc-hafs">﴿جنوده من الجن﴾</span> طائفة، <span class="qpc-hafs">﴿و﴾</span>من <span class="qpc-hafs">﴿الإنسِ و﴾</span>من <span class="qpc-hafs">﴿الطَّيـــــْرِ﴾</span> طائفة{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٠٠٢<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: قوله ﷿: <span class="qpc-hafs">﴿وحشر﴾</span>، أي: وجُمِع{2}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَحُشِرَ لِسُلَیۡمَـٰنَ جُنُودُهُۥ مِنَ ٱلۡجِنِّ وَٱلۡإِنسِ وَٱلطَّیۡرِ﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٥٧٠٠٣<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق مجاهد-: أنّ سليمان كان يضع سريره، ثم يضع الكرسيَّ عن يمينه وشماله، فيأذن للإنس، ثم يأذن للجن، فيكونون خلف الإنس، ثم يأذن للشياطين، فيكونون خلف الجن، ثم يرسل إلى الريح، فتأتيه، فتحملهم، وتُظِلُّه الطيرُ فوقَه وهو على سريره وكراسيه، يسير بهم غدوة الراكب، إلى أن يشتهي المنزل شهرًا، ثم تروح بهم مثل ذلك{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٠٠٤<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span> -من طريق سفيان بن عيينة، عن أبي سنان- قال: كان يُوضَع لسليمان ﵇ ثلاثمائة ألف كرسي، فيجلس مؤمنو الإنس مما يليه، ومؤمنو الجن مِن ورائهم، ثم يأمر الطير فتُظِلّه، ثم يأمر الريح فتحمله.= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٠٠٥<span class="dash">-</span></span> قال <span class="name-3">سفيان</span>: فيمُرُّون على السنبلة، فلا يحركونها{4}. (١١/٣٤٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٠٠٦<span class="dash">-</span></span> عن <span class="name-2">وهب بن مُنَبِّه</span> -من طريق محمد بن إسحاق، عن بعض أهل العلم- قال: ورِث سليمان المُلْك، وأحْدَثَ اللهُ إليه النبوةَ، وسأله أن يهب له ملكًا لا ينبغي لأحد من بعده، ففعل -تبارك وتعالى-، فسخَّر له الإنس والجن والطير والريح ...{5}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿فَهُمۡ یُوزَعُونَ ۝١٧﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٧٠٠٧<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، في قوله: <span class="qpc-hafs">﴿فهم يوزعون﴾</span>، قال: يُدْفَعون{6}. (١١/٣٤٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٠٠٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطاء الخراساني- في قوله: <span class="qpc-hafs">﴿فهم يوزعون﴾</span>، قال: جعل على كلِّ صنف منهم وزَعَة، تَرُدُّ أُولاها على أُخراها؛ لِئلّا يتقدَّموا في المسير كما تصنع الملوك{7}. (١١/٣٤٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٠٠٩<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>: أنّ نافع بن الأزرق سأله عن قوله: <span class="qpc-hafs">﴿فهم يوزعون﴾</span>. قال: يُحبَس أولهم على آخرهم حتى تنام الطير. قال: وهل تعرف العرب ذلك؟ قال: نعم، أوَما سمعت قولَ الشاعر:</p><p>وزَعْتُ رَعِيلَها{8} بأقَبِّ{9} نَهْدٍ إذا ما القومُ شدُّوا بعد خمسِ؟{10}. (١١/٣٤٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٠١٠<span class="dash">-</span></span> عن <span class="name-2">أبي الأحوص [عوف بن مالك الأشجعي]</span> -من طريق ابن الأقمر- <span class="qpc-hafs">﴿فهم يوزعون﴾</span>، قال: يُحبَس الأولُ على الآخِر{11}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٠١١<span class="dash">-</span></span> عن <span class="name-2">أبي رَزيِن [مسعود بن مالك الأسدي]</span> -من طريق منصور- في قوله: <span class="qpc-hafs">﴿فهم يوزعون﴾</span>، قال: يُحبَس أولهم على آخرهم{12}. (١١/٣٤٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٠١٢<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن جريج- في قوله: <span class="qpc-hafs">﴿فهم يوزعون﴾</span>، قال: جعل على كل صنف وزَعة، يرُدُّون أوليها على آخريها؛ لِئلّا يتقدموا في المسير، كما تفعل الملوكُ اليومَ{13}. (١١/٣٤٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٠١٣<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق معمر- قال: <span class="qpc-hafs">﴿يوزعون﴾</span>: يَتَقَدَّمون{14}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٠١٤<span class="dash">-</span></span> قال <span class="name-2">الحسن البصري</span>: <span class="qpc-hafs">﴿فهم يوزعون﴾</span> فهم يدفعون، لا يتقدَّمه منهم أحد{15}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٠١٥<span class="dash">-</span></span> قال <span class="name-2">الحسن البصري</span>: كان سليمان إذا أراد أن يركب جاءت الريحُ، فوَضَع سريرَ مملكته عليها، ووُضِعَت الكراسي والمجالس على الريح، وجلس سليمان على سريره، وجلس وُجُوه أصحابه على منازلهم في الدِّين عندَه مِن الجن والإنس، والجنُّ يومئذ ظاهرة للإنس، رجالٌ أمثال الإنس، إلا أنهم أُدْم، يَحُجُّون جميعًا، ويُصَلُّون جميعًا، ويعتمرون جميعًا، والطير تُرَفْرِف على رأسه ورؤوسهم، والشياطين حَرَسُه لا يتركون أحدًا يتقدَّم بين يديه، وهو قوله: <span class="qpc-hafs">﴿فهم يوزعون﴾</span>{16}<span class=comment-ref>٤٨٤٨</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٤٨٤٨</span> <span class="comment-type-4">علَّق</span> <u>ابنُ عطية</u> (٦/٥٢٥) على الخلاف في مقدار جُند سليمان ﵇ بقوله: «واختلف الناس في مقدار جند سليمان ﵇ اختلافًا شديدًا لم أُرِد ذكره لعدم صحته، غير أنّ الصحيح أنّ ملكه كان عظيمًا؛ ملأ الأرض، وانقادت له المعمورة، وكان كرسيه يحمل أجناده من الجن والإنس، وكانت الطير تظله من الشمس، ويبعثها في الأمور، وكان له في الكرسي الأعظم موضعٌ يَخُصُّه».</div></p><p><div></p><p><p><span class="item-no">٥٧٠١٦<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿فهم يوزعون﴾</span>، قال: لكل صنف وزَعَةٌ، يُرَدُّ أولهم على آخرهم{17}. (١١/٣٤٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٠١٧<span class="dash">-</span></span> قال <span class="name-2">إسماعيل السُّدِّيّ</span>: <span class="qpc-hafs">﴿يوزعون﴾</span>، يعني: يُساقون{18}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٠١٨<span class="dash">-</span></span> قال <span class="name-2">إسماعيل السُّدِّيّ</span>: يوقفون{19}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٠١٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فهم يوزعون﴾</span>، يعني: يُساقون، وكان سليمان استعمل عليهم جندًا يرُدُّ الأولَ على الآخر، حتى ينام{20} الناس{21}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٠٢٠<span class="dash">-</span></span> قال <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿وحشر لسليمان جنوده من الجن والإنس والطير فهم يوزعون﴾</span>، قال: <span class="qpc-hafs">﴿يوزعون﴾</span>: يساقون{7}<span class=comment-ref>٤٨٤٩</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٤٨٤٩</span> اختلف في معنى قوله: <span class="qpc-hafs">﴿فهم يوزعون﴾</span> على أقوال خمسة: <b>الأول</b>: معنى ذلك: يحبس أولهم على آخرهم حتى يجتمعوا. <b>الثاني</b>: يساقون. <b>الثالث</b>: يتقدمون. <b>الرابع</b>: يدفعون. <b>الخامس</b>: يوقفون.</p><p>و<span class="comment-type-3">رجح</span> <u>ابنُ جرير</u> (٦/٢٧) <span class="mustanad">مستندًا إلى اللغة</span> القولَ الأول الذي قاله ابن عباس، وقتادة، ومجاهد، وأبو رزين، فقال: «وذلك أنّ الوازع في كلام العرب هو: الكافُّ، يقال منه: وزع فلان فلانًا عن الظلم: إذا كفه عنه».</p><p>و<span class="comment-type-4">علَّق</span> <u>ابنُ عطية</u> (٦/٥٢٥) على القول الأول بقوله: «ومنه قول الحسن البصري حين ولي قضاء البصرة: لا بُدَّ للحاكم مِن وزعة. ومنه قول أبي قحافة حين وصفت له الجارية في يوم الفتح أنّها ترى سوادًا أمامه فارس قد تقدم من الصف، فقال لها: ذلك الوازع».</div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٣/٢٩٩.|2:تفسير يحيى بن سلام ٢/٥٣٧.|3:أخرجه ابن أبي حاتم ٩/٢٨٥٥.|4:أخرجه إسحاق البستي في تفسيره ص٧، وابن أبي حاتم ٩/٢٨٥٥.|5:أخرجه ابن أبي حاتم ٩/٢٨٥٦.|6:أخرجه ابن جرير ١٨/١٢٩، وابن أبي حاتم ٩/٢٩٢٧. وعزاه السيوطي إلى ابن المنذر.|7:أخرجه ابن جرير ١٨/٢٦.|8:الرَّعِيل: اسم كل قطعة متقدمة مِن خيلٍ وجرادٍ وطيرٍ ورجالٍ ونجومٍ وإبِلٍ وغير ذلك. اللسان (رعل).|9:الأَقَبّ: الضامِر. اللسان (قبب).|10:عزاه السيوطي إلى الطستي في مسائله. وأخرجه الطبراني (١٢٠٧٦) من طريق ابن أبي ليلى عن الحكم عن مقسم دون ذكر نافع ومسألته واستشهاد ابن عباس.|11:أخرجه إسحاق البستي في تفسيره ص٩.|12:أخرجه ابن أبي شيبة ١٣/٤١٧. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.|13:أخرجه ابن أبي حاتم ٩/٢٨٥٦، وابن أبي شيبة ١٣/٤١٧، وابن جرير ١٨/١٢٩، وابن أبي حاتم ٩/٢٨٥٦ من طريق ابن جريج بلفظ: يحبس أولهم على آخرهم. وكذا عزاه السيوطي إلى عبد بن حميد، وابن المنذر.|14:أخرجه عبد الرزاق ٢/٧٩، وابن جرير ١٨/٢٧، وابن أبي حاتم ٩/٢٨٥٧.|15:علقه يحيى بن سلام ٢/٥٣٧.|16:علَّقه يحيى بن سلام ٢/٥٣٨.|17:أخرجه ابن أبي حاتم ٩/٢٨٥٧. وعلَّقه يحيى بن سلام ٢/٥٣٧، ٧٤٩. وأخرجه عبد الرزاق ٢/٧٩، وابن جرير ١٨/٢٦ من طريق معمر دون أوله. وكذا عزاه السيوطي إلى عبد بن حميد.|18:علَّقه يحيى بن سلام ٢/٥٣٧.|19:تفسير الثعلبي ٧/١٩٥، وتفسير البغوي ٦/١٥٠.|20:كذا في المطبوع، ولعلها: يتـتام.|21:تفسير مقاتل بن سليمان ٣/٢٩٩. وأوله في تفسير الثعلبي ٧/١٩٥، وتفسير البغوي ٦/١٤٩ منسوبًا إلى مقاتل دون تعيينه.|22:أخرجه ابن جرير ١٨/٢٦.
  27,18,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿حَتَّىٰۤ إِذَاۤ أَتَوۡا۟ عَلَىٰ وَادِ ٱلنَّمۡلِ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٧٠٢١<span class="dash">-</span></span> عن <span class="name-2">كعب الأحبار</span> -من طريق وهب بن منبه- قال: كان سليمان إذا ركب حمل أهله وخدمه وحشمه، وقد اتَّخذ مطابخ ومخابز يحمل فيها تنانير{1} الحديد، وقُدور عظام، يَسَعُ كلُّ قِدْرٍ عشر جزائر{2}، وقد اتخذ ميادين للدواب أمامه، فيطبخ الطباخون، ويخبز الخبازون، وتجري الدواب بين يديه بين السماء والأرض، والريح تهوي بهم، فسار مِن إصْطَخر إلى اليمن، فسلك مدينة رسول الله ﷺ، فقال سليمان: هذه دارُ هجرة نبيٍّ في آخر الزمان، طوبى لِمَن آمن به، وطوبى لمن اتبعه. ورأى حول البيت أصنامًا تُعبَد من دون الله، فلما جاوز سليمان البيت بكى البيت، فأوحى الله إلى البيت: ما يبكيك؟ فقال: يا ربِّ، أبكاني أنّ هذا نبيٌّ مِن أنبيائك وقومٌ مِن أوليائك مرُّوا عَلَيَّ فلم يهبطوا، ولم يُصَلُّوا عندي، والأصنام تُعبَد حولي مِن دونك. فأوحى الله إليه: أن لا تبك، فإني سوف أملؤك وجوهًا سُجَّدًا، وأُنزِل فيك قرآنًا جديدًا، وأبعث منك نبيًّا في آخر الزمان، أحب أنبيائي إلَيَّ، وأجعل فيك عُمّارًا مِن خلقي يعبدونني، وأفرِض على عبادي فريضة يَذِفُّون{3} إليك ذفيف النُّسور إلى وكرها، ويحنون إليك حنين الناقة إلى ولدها، والحمامة إلى بيضتها، وأطهرك من الأوثان، وعبدة الشياطين. ثم مضى سليمان حتى مرَّ بوادي السُّدِّيّر؛ واد من الطائف، فأتى على وادي النمل. هكذا قال كعب: إنّه وادٍ بالطائف{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٠٢٢<span class="dash">-</span></span> عن <span class="name-2">كعب الأحبار</span> -من طريق وهب بن منبه- قال: إنّ سليمان كان إذا ركب حمل أهله وسار. [وذكر الحديث حتى قال]: ثم مضى سليمانُ حتى مرَّ بوادي النسرين من الطائف، فأتى على وادي النمل ...{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٠٢٣<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿حتى إذا أتوا على وادي النمل﴾</span>، قال: ذُكِر لنا: أنّه وادٍ بأرض الشام{6}. (١١/٣٤٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٠٢٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: وقال ﷿: <span class="qpc-hafs">﴿حتى إذا أتوا على واد النمل﴾</span> مِن أرض الشام{7}<span class=comment-ref>٤٨٥٠</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٤٨٥٠</span> <span class="comment-type-4">ذكر</span> <u>ابنُ عطية</u> (٦/٥٢٦) أنّ ظاهر هذه الآية: أنّ سليمان وجنوده كانوا مشاة في الأرض، وأنّه بذلك يتفق حطم النمل بنزولهم في وادي النمل، ثم قال: «ويحتمل أنهم كانوا في الكرسي المحمول بالريح، وأحست النمل بنزولهم في وادي النمل».</div></p><p><h3><span class="qpc-hafs">﴿قَالَتۡ نَمۡلَةࣱ یَـٰۤأَیُّهَا ٱلنَّمۡلُ ٱدۡخُلُوا۟ مَسَـٰكِنَكُمۡ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٧٠٢٥<span class="dash">-</span></span> عن <span class="name-2">كعب الأحبار</span> -من طريق وهب بن منبه- قال: ... أتى على وادي النمل، فقالت نملة تسمى: جيرين، مِن قبيلة تسمى: الشيصبان، وكانت عرجاء تَتَكاوَس{8}، وكانت مثل الذِّئب العظيم، فنادت النملة: <span class="qpc-hafs">﴿يا أيها النمل ادخلوا مساكنكم لا يحطمنكم سليمان وجنوده وهم لا يشعرون﴾</span>، يعني: أنّ سليمان يفهم مقالتها، وكان لا يتكلم خَلْقٌ إلا حَمَلَتِ الريحُ ذلك، فألقته في مسامع سليمان ...{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٠٢٦<span class="dash">-</span></span> عن <span class="name-2">نَوفٍ البِكالي</span> -من طريق الأعمش، عن الحكم بن الوليد- قال: كان النمل في زمن سليمان بن داود أمثال الذباب. وفي لفظ: أمثال الذئاب{10}<span class=comment-ref>٤٨٥١</span>. (١١/٣٤٥)</p></p><p></div></p><p><div><span class=comment-ref>٤٨٥١</span> ساق <u>ابنُ عطية</u> (٦/٥٢٦) هذا القول، وكذا قول مَن قال بأن النمل كان صغيرًا، ثم <span class="comment-type-4">علَّق</span> بقوله: «والذي يُقال في هذا: إن النمل كانت نسبتها من هذا الخلق نسبة هذا النمل منّا، فيحتمل أن كان الخلق كله أكمل».</p><p>و<span class="comment-type-4">علَّق</span> <u>ابنُ كثير</u> (١٠/٣٩٧) على قول نوف بقوله: «هكذا رأيته مضبوطًا بالياء المثناة من تحت، وإنما هو بالباء الموحدة، وذلك تصحيف».</div></p><p><div></p><p><p><span class="item-no">٥٧٠٢٧<span class="dash">-</span></span> عن <span class="name-2">عامر الشعبي</span> -من طُرُق- قال: النملة التي فَقِهَ سليمانُ كلامَها كانت مِن الطير ذات جناحين، ولولا ذلك لم يعرف سليمانُ ما تقول{11}. (١١/٣٤٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٠٢٨<span class="dash">-</span></span> قال <span class="name-2">الضَّحّاك بن مُزاحِم</span> -من طريق أبي رَوْق-: كان اسم تلك النملة: طاحِية{12}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٠٢٩<span class="dash">-</span></span> عن <span class="name-2">الحكم [بن عتيبة]</span>، قال: كان النملُ في زمن سليمان أمثال الذباب{13}. (١١/٣٤٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٠٣٠<span class="dash">-</span></span> عن <span class="name-2">وهب بن مُنَبِّه</span>، قال: أمر اللهُ الريحَ، قال: لا يتكلم أحدٌ مِن الخلائق بشيء في الأرض بينهم إلا حَمَلَتْه فوَضَعَتْه في أُذُنِ سليمان بن داود، فبذلك سَمِع كلامَ النملة{13}. (١١/٣٤٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٠٣١<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- قال: النملة من الطير{15}. (١١/٣٤٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٠٣٢<span class="dash">-</span></span> عن <span class="name-2">أبي رَوْق عطية بن الحارث الهمداني</span>-من طريق ابنه-: كان اسم نملة سليمان: حرمى{16}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٠٣٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿قالت نملة﴾</span> واسمها: الجرمي: <span class="qpc-hafs">﴿يا أيها النمل ادخلوا﴾</span> وهن خارجات، فقالت: ادخلوا <span class="qpc-hafs">﴿مساكنكم﴾</span> يعني: بيوتكم{17}<span class=comment-ref>٤٨٥٢</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٤٨٥٢</span> <span class="comment-type-4">ذكر</span> <u>ابنُ كثير</u> (١٠/٣٩٧) أن الخلاف في تحديد الوادي ووصف النملة لا حاصل له.</div></p><p><h3><span class="qpc-hafs">﴿لَا یَحۡطِمَنَّكُمۡ سُلَیۡمَـٰنُ وَجُنُودُهُۥ وَهُمۡ لَا یَشۡعُرُونَ ۝١٨﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٧٠٣٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿لا يحطمنكم سليمان﴾</span> يعني: لا يهلكنكم سليمان <span class="qpc-hafs">﴿وجنوده وهم لا يشعرون﴾</span> بهلاككم. فسمع سليمانُ قولَها مِن ثلاثة أميال، فانتهى إليها سليمانُ حين قالت: <span class="qpc-hafs">﴿وهم لا يشعرون﴾</span>{17}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٠٣٥<span class="dash">-</span></span> عن <span class="name-3">هارون الأعور</span> -من طريق النَّضر- قال: وزعموا: أنّ الحَطْمَ الغَشَيانُ، حطمتهم الخيل أي: غشيتهم{19}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٠٣٦<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>، في قوله: <span class="qpc-hafs">﴿قالت نملة يأيها النمل ادخلوا مساكنكم لا يحطمنكم سليمان وجنوده﴾</span>: قال الله: <span class="qpc-hafs">﴿وهم لا يشعرون﴾</span>، أي: والنمل لا يشعُرْنَ أنّ سليمان يفهم كلامَهم{20}. (ز)</p></p><p></div></p></div>",footnotes:1:تنانِير: جمع تَنّور: وهو الذي يُطبخ فيه. العين للخليل (تنر).|2:جزائر: جمع جَزُور: وهو البعِير ذكرًا كان أو أنثى. النهاية (جزر).|3:الذَّف: الإسراع. النهاية (ذفف).|4:تفسير الثعلبي ٧/١٩٦، وتفسير البغوي ٦/١٥٠.|5:أخرجه ابن عساكر في تاريخ دمشق ٢٢/٢٦٤-٢٦٦.|6:أخرجه ابن أبي حاتم ٩/٢٨٥٧. وعلقه يحيى بن سلام ٢/٥٣٧.|7:تفسير مقاتل بن سليمان ٣/٢٩٩. ومثله في تفسير الثعلبي ٧/١٩٧، وتفسير البغوي ٦/١٥٠ منسوبًا إلى مقاتل دون تعيينه.|8:الكَوْسُ: المَشي على رِجْلٍ واحِدة، ومِن ذوات الأربع على ثلاث قوائم. لسان العرب (كوس).|9:أخرجه ابن عساكر في تاريخ دمشق ٢٢/٢٦٤-٢٦٦.|10:أخرجه البخاري في تاريخه ١/٦٠، وابن أبي حاتم ٩/٢٨٥٧. وأخرجه سفيان الثوري في تفسيره ص٢٣٢ بلفظ: كانت النملة مثل الذيب من العِظَم، وابن جرير ١٨/٢٨ بلفظ: الذئاب. وعزاه السيوطي إلى ابن أبي شيبة، وابن المنذر.|11:أخرجه ابن أبي حاتم ٩/٢٨٥٧.|12:أخرجه الثعلبي ٧/١٩٧، وينظر: تفسير البغوي ٦/١٥١.|13:عزاه السيوطي إلى ابن المنذر.|14:عزاه السيوطي إلى ابن المنذر.|15:أخرجه عبد الرزاق ٢/٧٩، وابن أبي حاتم ٩/٢٨٥٥. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.|16:أخرجه الثعلبي ٧/١٩٧.|17:تفسير مقاتل بن سليمان ٣/٢٩٩. وبعضه في تفسير الثعلبي ٧/١٩٧، وتفسير البغوي ٦/١٥١ منسوبًا إلى مقاتل دون تعيينه.|18:تفسير مقاتل بن سليمان ٣/٢٩٩. وبعضه في تفسير الثعلبي ٧/١٩٧، وتفسير البغوي ٦/١٥١ منسوبًا إلى مقاتل دون تعيينه.|19:أخرجه إسحاق البستي في تفسيره ص٩.|20:تفسير يحيى بن سلام ٢/٥٣٧.
  27,19,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿فَتَبَسَّمَ ضَاحِكࣰا مِّن قَوۡلِهَا﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٧٠٣٧<span class="dash">-</span></span> عن <span class="name-2">كعب الأحبار</span> -من طريق وهب بن منبه- قال: ... <span class="qpc-hafs">﴿فتبسم﴾</span> سليمانُ <span class="qpc-hafs">﴿ضاحكا من قولها﴾</span>{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٠٣٨<span class="dash">-</span></span> عن <span class="name-2">محمد بن سيرين</span> -من طريق الحكم بن عطية- أنّه سُئِل عن التَّبَسُّم في الصلاة. فقرأ هذه الآية: <span class="qpc-hafs">﴿فتبسم ضاحكا من قولها﴾</span>، وقال: لا أعلم التَّبَسُّم إلا ضحِكًا{2}. (١١/٣٤٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٠٣٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فتبسم ضاحكا من قولها﴾</span> ضحك مِن ثنائها على سليمان بعدله في ملكه؛ أنّه لو يشعر بكم لم يحطمكم، يعني بالضحك: الكشر، وقال سليمان: لقد علمت النملُ أنّه مُلك لا بَغْيٌ فيه ولا فَخْر، ولئن عَلِم بنا قبل أن يغشانا لم نُوطَأ{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٠٤٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل</span>: كان ضحِكُ سليمان مِن قول النملة تعجُّبًا؛ لأنّ الإنسان إذا رأى ما لا عهد له به تعجب وضحك{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٠٤١<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿فتبسم﴾</span> سليمان <span class="qpc-hafs">﴿ضاحكا من قولها﴾</span>{5}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَقَالَ رَبِّ أَوۡزِعۡنِیۤ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٧٠٤٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- في قوله: <span class="qpc-hafs">﴿أوْزِعْنِي﴾</span>، يقول: اجعلني{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٠٤٣<span class="dash">-</span></span> عن <span class="name-2">كعب الأحبار</span> -من طريق وهب بن منبه- قال: <span class="qpc-hafs">﴿وقال رب أوزعني﴾</span>، يعني: ألْهِمْنِي{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٠٤٤<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span>، قال: <span class="qpc-hafs">﴿أوزعني﴾</span>، قال: ألهمني{8}. (١١/٣٤٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٠٤٥<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿أوزعني﴾</span>، قال: ألهمني{9}. (١١/٣٤٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٠٤٦<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span>، مثل ذلك{10}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٠٤٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثم وقف سليمان بمن معه مِن الجنود ليدخل النملُ مساكنهم، ثم حمد ربَّه ﷿ حين علَّمه منطقَ كلِّ شيء، فسمع كلام النملة، <span class="qpc-hafs">﴿وقال رب أوزعني﴾</span> يعني: ألْهِمْني{11}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٠٤٨<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قول الله: <span class="qpc-hafs">﴿رب أوزعني أن أشكر نعمتك التي أنعمت علي﴾</span>، قال: في كلام العرب تقول: أوزع فلانٌ بفلان، يقول: حرَّضه عليه. وقال ابن زيد: <span class="qpc-hafs">﴿أوزعني﴾</span>: ألْهِمني وحرِّضني على أن أشكر نعمتك التي أنعمت عَلَيَّ، وعلى والِدَيَّ{12}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٠٤٩<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿وقال رب أوزعني﴾</span>، يقول: ألْهِمني{5}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿أَنۡ أَشۡكُرَ نِعۡمَتَكَ ٱلَّتِیۤ أَنۡعَمۡتَ عَلَیَّ وَعَلَىٰ وَ ٰ⁠لِدَیَّ وَأَنۡ أَعۡمَلَ صَـٰلِحࣰا تَرۡضَىٰهُ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٧٠٥٠<span class="dash">-</span></span> قال <span class="name-1">عبد الله بن عباس</span>: يريد: مع إبراهيم، وإسماعيل، وإسحاق، ويعقوب، ومَن بعدهم مِن النبيين{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٠٥١<span class="dash">-</span></span> عن <span class="name-2">كعب الأحبار</span> -من طريق وهب بن منبه- قال: <span class="qpc-hafs">﴿أن أشكر نعمتك﴾</span> يعني: أن أُؤَدِّي شكرَ ما أنعمت <span class="qpc-hafs">﴿علي وعلى والديَّ وأن أعمل صالحا ترضاه﴾</span>{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٠٥٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿أن أشكر نعمتك التي أنعمت عليَّ وعلى والديَّ﴾</span> مِن قبلي، يعني: أبويه: داود، وأمه بتشايع بنت الياثن، <span class="qpc-hafs">﴿و﴾</span> ألهمني <span class="qpc-hafs">﴿أنْ أعمل صالحًا ترضاه﴾</span>{11}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿أَنۡ أَشۡكُرَ نِعۡمَتَكَ ٱلَّتِیۤ أَنۡعَمۡتَ عَلَیَّ وَعَلَىٰ وَ ٰ⁠لِدَیَّ وَأَنۡ أَعۡمَلَ صَـٰلِحࣰا تَرۡضَىٰهُ﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٥٧٠٥٣<span class="dash">-</span></span> قال <span class="name-3">سفيان بن عيينة</span> -من طريق ابن أبي عمر-: لو أنّ سليمان بن داود لم يقبله بالذي ينبغي لَساخَت به الأرضُ خمسمائة قامَةٍ حين قالت النملة: <span class="qpc-hafs">﴿قالَتْ نَمْلَةٌ يا أيُّها النَّمْلُ ادْخُلُوا مَساكِنَكُمْ﴾</span>. قال: <span class="qpc-hafs">﴿فتبسم ضاحكا من قولها وقالَ رَبِّ أوْزِعْنِي أنْ أشْكُرَ نِعْمَتَكَ الَّتِي أنْعَمْتَ﴾</span> الآية. فقال له رجلٌ حرّاث مِن الحرّاثين: لأنا بقدري أشكر لله منك. قال: فخرَّ عن فرسه ساجدًا. وقال: لولا أن يكون- قال ابن أبي عمر: ثم تكلم سفيان بكلمة لم أفهمها- لقلت: انزع مِنِّي ما أعطيتني. قال: وكان يشغله ذِكْرُ الله عن أن يتكلم{17}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَأَدۡخِلۡنِی بِرَحۡمَتِكَ فِی عِبَادِكَ ٱلصَّـٰلِحِینَ ۝١٩﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٧٠٥٤<span class="dash">-</span></span> عن <span class="name-2">كَعْب الأحبار</span> -من طريق وهْب بن مُنَبِّه- قال: <span class="qpc-hafs">﴿وأدخلني برحمتك في عبادك الصالحين﴾</span>، يعني: مع الصالحين{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٠٥٥<span class="dash">-</span></span> تفسير <span class="name-2">إسماعيل السُّدِّيّ</span>: <span class="qpc-hafs">﴿الصالحين﴾</span>، يعني: المؤمنين{19}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٠٥٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وأدخلني برحمتك﴾</span> يعني: بنعمتك <span class="qpc-hafs">﴿في﴾</span> يعني: مع <span class="qpc-hafs">﴿عبادك الصالحين﴾</span> الجنة{11}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٠٥٧<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿وأدخلني برحمتك في عبادك الصالحين﴾</span>، قال: مع عبادك الصالحين؛ الأنبياء والمؤمنين{21}. (١١/٣٤٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٠٥٨<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿وأدخلني برحمتك في عبادك الصالحين﴾</span> يعني: مع عبادك <span class="qpc-hafs">﴿الصالحين﴾</span> يعني: المؤمنين، وهم أهل الجنة{5}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن عساكر في تاريخ دمشق ٢٢/٢٦٤-٢٦٦.|2:أخرجه ابن أبي شيبة ١/٣٨٧، وابن أبي حاتم ٩/٢٨٥٨.|3:تفسير مقاتل بن سليمان ٣/٣٠٠، وذكر محققه أنه كذا جاء في بعض النسخ.|4:تفسير البغوي ٦/١٥٢.|5:تفسير يحيى بن سلام ٢/٥٣٧.|6:أخرجه ابن جرير ١٨/٢٨، وابن أبي حاتم ٩/٢٨٥٨. وعلَّقه البخاري ٤/١٧٨٨. وينظر: تغليق التعليق ٤/٢٧٦.|7:أخرجه ابن عساكر في تاريخ دمشق ٢٢/٢٦٤-٢٦٦.|8:عزاه السيوطي إلى عبد بن حميد.|9:أخرجه ابن أبي حاتم ٩/٢٨٥٨. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.|10:علَّقه ابن أبي حاتم ٩/٢٨٥٨.|11:تفسير مقاتل بن سليمان ٣/٣٠٠.|12:أخرجه ابن جرير ١٨/٢٨، وابن أبي حاتم ٩/٢٨٥٨ من طريق أصبغ.|13:تفسير يحيى بن سلام ٢/٥٣٧.|14:تفسير البغوي ٦/١٥٢.|15:أخرجه ابن عساكر في تاريخ دمشق ٢٢/٢٦٤-٢٦٦.|16:تفسير مقاتل بن سليمان ٣/٣٠٠.|17:أخرجه إسحاق البستي في تفسيره ص٩-١٠ دون آخره، وابن أبي حاتم ٩/٢٨٥٩.|18:أخرجه ابن عساكر في تاريخ دمشق ٢٢/٢٦٤-٢٦٦.|19:علقه يحيى بن سلام ٢/٥٣٧.|20:تفسير مقاتل بن سليمان ٣/٣٠٠.|21:أخرجه ابن جرير ١٨/٢٩، وابن أبي حاتم ٩/٢٨٥٩ من طريق أصبغ.|22:تفسير يحيى بن سلام ٢/٥٣٧.
  27,20,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَتَفَقَّدَ ٱلطَّیۡرَ فَقَالَ مَا لِیَ لَاۤ أَرَى ٱلۡهُدۡهُدَ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٧٠٥٩<span class="dash">-</span></span> عن أبي مجلز، قال: جلس ابنُ عباس إلى عبد الله بن سلام، فسأله عن الهدهد: لِمَ تفقَّده سليمان مِن بين الطير؟ فقال <span class="name-1">عبد الله بن سلام</span>: إنّ سليمان نزل منزلة في مسير له، فلم يَدْرِ ما بُعْدُ الماء، فقال: مَن يعلمُ بُعْدَ الماء؟ قالوا: الهدهد. فذاك حين تفقَّده{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٠٦٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طرق- أنّه سُئِل: كيف تَفَقَّد سليمانُ الهدهدَ من بين الطير؟ قال: إنّ سليمان نزل منزلًا، فلم يدر ما بُعْدُ الماء، وكان الهدهد يدل سليمان على الماء -وفي رواية عكرمة عند ابن أبي حاتم: وكان الهدهد مهندسًا{2}-، فأراد أن يسأله عنه، ففقده. قيل: كيف ذاك والهدهد ينصب له الفخ يلقي عليه التراب، ويضع له الصبي الحبالة فيغيبها فيصيده؟ فقال: إذا جاء القضاء ذهب البصر{3}. (١١/٣٤٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٠٦١<span class="dash">-</span></span> عن يوسف بن ماهَك، أنّه حدثهم: أن نافع بن الأزرق صاحب الأزارِقة كان يأتي <span class="name-1">عبد الله بن عباس</span>، فإذا أفتى ابنُ عباس يرى هو أنّه ليس بمستقيم، يقول له: قِف، مِن أين أفتيت بكذا وكذا، ومِن أين كان؟ فيقول ابن عباس: أومأت مِن كذا وكذا. حتى ذكر يومًا الهدهد، فقال: يعرف بعد مسافة الماء في الأرض. فقال له ابن الأزرق: قِف قف، يا ابن العباس، كيف تزعم أنّ الهدهد يرى مسافة الماء من تحت الأرض، وهو يُنصَب له الفخ، فيذر عليه التراب، فيصطاد؟ فقال ابن عباس: لولا أن يذهب هذا فيقول: كذا وكذا؛ لم أقل له شيئًا، إنّ البصر ينفع ما لم يأت القدر، فإذا جاء القدر حال دون البصر. فقال ابن الأزرق: لا أُجادِلُك بعدها في شيء{4}. (١١/٣٤٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٠٦٢<span class="dash">-</span></span> عن <span class="name-2">عبد الله بن شداد بن الهاد</span> -من طريق حصين - قال: كان سليمان بن داود إذا أراد أن يسير وضع كرسيه، ويأتي مَن أراد مِن الجن والإنس، ثم يأمر الريح، فتحملهم، ثم يأمر الطير، فأظلَّتْهم، قال: وبينا هو يسير إذ عطشوا، فقال: ما ترون بُعْدَ الماء؟ قالوا: لا ندري. فتفقد الهدهد، وكان له منه منزلة وليس بها طير غيره، <span class="qpc-hafs">﴿فقال مالي لا أرى الهدهد أم كان من الغائبين﴾</span>{5}. (١١/٣٨٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٠٦٣<span class="dash">-</span></span> عن <span class="name-2">عبد الله بن شداد بن الهاد</span> -من طريق عبد الله بن حبيب السلمي- قال: إنّ الهدهد كان إذا سافر سليمان خرج به معه، كان يدله على الماء، ينظر إلى الماء كما ينظر بعضنا إلى بعض، وإنه فَقَدَه؛ فقال ما قال{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٠٦٤<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span> -من طريق عطاء بن السائب، وكلثوم بن جبر- قال: كان سليمان إذا أراد أن ينزل منزلًا دعا الهدهدَ ليخبره عن الماء، فكان إذا قال: ههنا. شَقَّقَتِ الشياطينُ الصخور، وفجرت العيون من قبل أن يضربوا أبنيتهم، فأراد أن ينزل منزلًا، فتفقد الهدهد فلم يره، فقال: <span class="qpc-hafs">﴿ما لي لا أرى الهدهد أم كان من الغائبين﴾</span>{5}. (١١/٣٤٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٠٦٥<span class="dash">-</span></span> عن <span class="name-2">وهب بن مُنَبِّه</span> -من طريق ابن إسحاق، عن بعض أهل العلم- قال: كان سليمان بن داود إذا خرج من بيته إلى مجلسه عَكَفَتْ عليه الطير، وقام له الجنُّ والإنسُ حتى يجلس على سريره، حتى إذا كان ذات غداة في بعض زمانه غدا إلى مجلسه الذي كان يجلس فيه، فتفقد الطير. وكان فيما يزعمون: يأتيه نوبًا، من كل صنف من الطير طائر، فنظر، فرأى مِن أصناف الطير كلها قد حضره إلا الهدهد، فقال: ما لي لا أرى الهدهد؟{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٠٦٦<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد بن عروبة- في الآية، قال: ذُكِر لنا: أنّ سليمان أراد أن يأخذ مفازةً، فدعا بالهدهد -وكان سيِّد الهداهِد- ليعلم مسافة الماء، وكان قد أُعْطِي مِن البصر بذلك شيئًا لم يُعْطَه شيءٌ مِن الطير. لقد ذُكِر لنا: أنّه كان يُبصِر الماءَ في الأرض، كما يُبصِر أحدُكم الخيالَ مِن وراء الزجاجة{9}. (١١/٣٤٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٠٦٧<span class="dash">-</span></span> قال <span class="name-3">محمد بن السائب الكلبي</span>: كان يَدُلُّه على الماء إذا نزل الناس، وكان ينقر بمنقاره في الأرض، فيخبر سليمانَ كم بينه وبين الماء مِن قامة{10}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٠٦٨<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وتفقد الطير﴾</span> يعني: الهدهد، حين سار من بيت المقدس قِبَل اليمن، فلما مرَّ بالمدينة وقف، فقال: إنّ الله ﷿ سيبعث مِن هاهنا نبيًّا، طوبى لِمَن تبعه. فلما أراد أن ينزل <span class="qpc-hafs">﴿فقال ما لي لا أرى الهدهد أم﴾</span> -والميم ها هنا صلة، كقوله تعالى: <span class="qpc-hafs">﴿أم عندهم﴾</span> يعني: أعندهم <span class="qpc-hafs">﴿الغيب فهم يكتبون﴾</span> [الطور:٤١، القلم:٤٧]- <span class="qpc-hafs">﴿كان من الغائبين﴾</span>{11}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٠٦٩<span class="dash">-</span></span> قال <span class="name-3">سفيان بن عيينة</span> -من طريق ابن أبي عمر-: كان سليمانُ إذا جلس صَفَّت الطيرُ على رأسه تُظِلُّه مِن الشمس، وكان الهدهدُ فوقَها، كان يسير هذا المكان منه -يعني: المنكب الأيمن-، فوجد حرَّ الشمس قد دخلت عليه مِن ذلك الموضع، فرفع رأسَه، فتفقد الهدهد، فسأل عنه: <span class="qpc-hafs">﴿فقال ما لي لا أرى الهدهد أم كان من الغائبين﴾</span>{12}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٠٧٠<span class="dash">-</span></span> قال <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب-: أول ما فقد سليمانُ الهدهدَ نزل بِوادٍ، فسأل الإنسَ عن مائه، فقالوا: ما نعلم له ماء، فإن يكن أحدٌ مِن جنودك يعلم له ماء فالجن. فدعا الجنَّ، فسألهم، فقالوا: ما نعلم له ماء، وإن يكن أحدٌ مِن جنودك يعلم له ماء فالطير. فدعا الطير، فسألهم، فقالوا: ما نعلم له ماء، وإن يكن أحد مِن جنودك يعلمه فالهدهد. فلم يجده. قال: فذاك أول ما فقد الهدهد{13}<span class=comment-ref>٤٨٥٣</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٤٨٥٣</span> اختُلِف في سبب تفقد سليمان للهدهد وسؤاله عنه؛ <b>فقال قوم</b>: تفقده ليستخبره عن بُعد الماء في الوادي الذي نزل به في مسيره. <b>وقال آخرون</b>: لإخلاله بالنوبة التي كان ينوبها. <b>وقال غيرهم</b>: إنما طلبه لأن الطَّير كانت تُظِلُّهم من الشمس، فأخلَّ الهدهد بمكانه، فطلعت الشمس عليهم من الخلل.</p><p>وذكر <u>ابنُ جرير</u> (١٨/٣٢) القولين الأولين، و<span class="comment-type-3">رجح</span> اندراجهما في العموم دون القطع بأحدهما؛ لعدم وجود الدليل القاطع، فقال: «والله أعلم بأي ذلك كان؛ إذ لم يأتنا بأي ذلك كان تنزيل، ولا خبر عن رسول الله ﷺ؛ فالصواب من القول في ذلك أن يُقال: إنّ الله أخبر عن سليمان أنه تفقد الطير؛ إمّا للنوبة التي كانت عليها وأخلت بها، وإما لحاجة كانت إليها عن بعد الماء».</p><p>وذكر <u>ابنُ عطية</u> (٦/٥٢٨) في الآية أقوالًا أخرى، منها قوله: «<b>قالت فرقة</b>: ذلك بحسب ما تقتضيه العناية بأمور الملك والتهمم بكل جزء منها». ثم <span class="comment-type-4">علَّق</span> بقوله: «وظاهر الآية أنه تفقد جميع الطير».</div></p><p><div></p><p><p><span class="item-no">٥٧٠٧١<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: قوله ﷿: <span class="qpc-hafs">﴿وتفقد الطير فقال ما لي لا أرى الهدهد أم كان من الغائبين﴾</span> أم هو غائب{14}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَتَفَقَّدَ ٱلطَّیۡرَ فَقَالَ مَا لِیَ لَاۤ أَرَى ٱلۡهُدۡهُدَ﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٥٧٠٧٢<span class="dash">-</span></span> عن ابن عباس، قال: نهى رسولُ الله ﷺ عن قتل أربعةٍ مِن الدوابِّ: النملة، والنحلة، والهدهد، والصرد{15}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٠٧٣<span class="dash">-</span></span> عن أنس بن مالك، قال: قال رسول الله ﷺ: «<b>أنهاكم عن قتل الهدهد؛ فإنّه كان دليلَ سليمان على قُرْب الماء من بُعْده، وأحبَّ أن يُعبَد الله في الأرض حيث يقول</b>: <span class="qpc-hafs">﴿وجئتك من سبأ بنبأ يقين إني وجدت امرأة﴾</span>»{16}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٠٧٤<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق عباد بن ميسرة المنقري- قال: اسم هدهد سليمان: عنبر{17}. (١١/٣٤٩)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿مَا لِیَ لَاۤ أَرَى ٱلۡهُدۡهُدَ أَمۡ كَانَ مِنَ ٱلۡغَاۤىِٕبِینَ ۝٢٠﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٧٠٧٥<span class="dash">-</span></span> عن <span class="name-2">وهب بن مُنَبِّه</span> -من طريق ابن إسحاق، عن بعض أهل العلم- <span class="qpc-hafs">﴿مالي لا أرى الهدهد أم كان من الغائبين﴾</span>: أخطأه بصري في الطير، أم غاب فلم يحضر؟{18}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن أبي شيبة ١١/٥٦٦، وابن جرير ١٨/٣٠.|2:المُهَندِس: المُقَدِّر لِمَجاري المياه واحتِفارِها حيث تُحْفَرُ، وهو مشتق من الهِنْدازِ، وهي فارسية. اللسان (هندس).|3:أخرجه ابن جرير ١٨/٣٠ من طريق سعيد بن جبير بنحوه مطولًا، وابن أبي حاتم ٩/٢٨٥٩ من طريق سعيد وعكرمة ومجاهد، والحاكم ٢/٤٠٥ من طريق سعيد بن جبير. وعزاه السيوطي إلى ابن أبي شيبة، وعبد بن حميد، وابن المنذر.|4:أخرجه يحيى بن سلام ٢/٥٣٨ بنحوه، وابن جرير ١٨/٣٠ من طريق سعيد بنحوه، وابن أبي حاتم ٩/٢٨٥٩-٢٨٦٠. وعزاه السيوطي إلى سعيد بن منصور.|5:أخرجه ابن أبي حاتم ٩/٢٨٦٠.|6:أخرجه ابن أبي حاتم ٩/٢٨٦٠.|7:أخرجه ابن أبي حاتم ٩/٢٨٦٠.|8:أخرجه ابن جرير ١٨/٣١، وابن أبي حاتم ٩/٢٨٦٢ موقوفًا على ابن إسحاق من قوله.|9:أخرجه يحيى بن سلام ٢/٥٣٧ مختصرًا، وابن أبي حاتم ٩/٢٨٦١، وأخرجه بنحوه من طريق سعيد بن بشير، وفي أوله: ذُكِر لنا: أنه كان قد أعطي من علمه شيئًا لم يعطه شيء من الطير، يعلم قدر مسافة الماء. وعزاه السيوطي إلى عبد بن حميد.|10:علَّقه يحيى بن سلام ٢/٥٣٨.|11:تفسير مقاتل بن سليمان ٣/٣٠٠.|12:أخرجه إسحاق البستي في تفسيره ص١٠، وابن أبي حاتم ٩/٢٨٦١.|13:أخرجه ابن جرير ١٨/٣١.|14:تفسير يحيى بن سلام ٢/٥٣٧.|15:أخرجه أحمد ٥/١٩٢ (٣٠٦٦)، ٥/٢٩٤-٢٩٥ (٣٢٤٢)، وأبو داود ٧/٥٣٩ (٥٢٦٧)، وابن ماجه ٤/٣٧٧ (٣٢٢٤)، وابن حبان ١٢/٤٦٢ (٥٦٤٦)، والثعلبي ٧/١٩٨.</p><p>قال أبو حاتم كما في عِلَل الحديث لابنه ٦/١٢٣-١٢٤ (٢٣٧٤): «هذا حديث مضطرب». وقال البيهقي في السنن الكبرى ٩/٥٣٣: «... أقوى ما ورد في هذا الباب». وقال النووي في شرح مسلم ١٤/٢٣٩: «رواه أبو داود بإسناد صحيح على شرط البخاري ومسلم». وقال ابن دقيق العيد في الإلمام في أحاديث الأحكام ٢/٤٤٤: «أخرجه أبو داود عن رجال الصحيح». وقال ابن الملقن في البدر المنير ٦/٣٤٥: «إسناده صحيح». وقال الألباني في الإرواء ٨/١٤٢ (٢٤٩٠): «وهذا إسناد صحيح على شرط الشيخين».|16:أورده الثعلبي في تفسيره ٧/١٩٩.|17:أخرجه ابن أبي حاتم ٩/٢٨٦١.|18:أخرجه ابن جرير ١٨/٣٢، وابن أبي حاتم ٩/٢٨٦٢ موقوفًا على ابن إسحاق من قوله.
  27,21,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿لَأُعَذِّبَنَّهُۥ عَذَابࣰا شَدِیدًا أَوۡ لَأَا۟ذۡبَحَنَّهُۥۤ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٧٠٧٦<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق سعيد بن جبير- في قوله: <span class="qpc-hafs">﴿لأعذبنه عذابا شديدا﴾</span>، قال: نَتْف رِيشه{1}. (١١/٣٤٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٠٧٧<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق مجاهد- في: <span class="qpc-hafs">﴿لأعذبنه عذابا شديدا﴾</span>: عذابه: نَتْفُه، وتَشْمِيسُه{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٠٧٨<span class="dash">-</span></span> عن <span class="name-2">عبد الله بن شداد بن الهاد</span> -من طريق حصين- قال: نَتْفُه وتشميسه، <span class="qpc-hafs">﴿أو لأذبحنه﴾</span> يقول: أو لأقتلنه{3}. (١١/٣٨٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٠٧٩<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- <span class="qpc-hafs">﴿لأعذبنه عذابا شديدا﴾</span>، قال: نَتْف ريشه كله{4}. (١١/٣٤٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٠٨٠<span class="dash">-</span></span> عن <span class="name-2">الضحاك بن مزاحم</span> -من طريق عبيد- في قوله: <span class="qpc-hafs">﴿لأعذبنه عذابا شديدا﴾</span> يقول: أنتِفُ ريشَه، <span class="qpc-hafs">﴿أو لأذبحنه﴾</span> يقول: لأقتلنه{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٠٨١<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span>، قال: نَتْف ريشه، وإلقاؤه للنمل في الشمس{6}. (١١/٣٥٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٠٨٢<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق مَعْمَر- يقول: نتف ريشه{7}. (١١/٣٤٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٠٨٣<span class="dash">-</span></span> عن <span class="name-2">يزيد بن رومان</span> -من طريق ابن إسحاق- قال: إنّ عذابه الذي كان يعذب به الطير: نتف ريش جناحه{8}. (١١/٣٥٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٠٨٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿لأعذبنه عذابا شديدا﴾</span> يعني: لأنتِفَنَّ ريشَه، فلا يطير مع الطير حولًا، <span class="qpc-hafs">﴿أو لأذبحنه﴾</span> يعني: لأقتلنه{9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٠٨٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن حيان</span>: لأطْلِيَنَّه بالقَطِران، ولَأُشَمِّسَنَّه{10}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٠٨٦<span class="dash">-</span></span> قال <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب-: قيل لبعض أهل العلم: هذا الذبحُ، فما العذابُ الشديد؟ قال: ينتف ريشه، يتركه بِضْعَةً تَنزو{11}{12}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٠٨٧<span class="dash">-</span></span> عن أبي الأسمر -من طريق خلف بن خليفة- <span class="qpc-hafs">﴿لأعذبنه عذابا شديدا﴾</span>، قال: أن ينتف ريشه، ويضربه بسوط{13}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿أَوۡ لَیَأۡتِیَنِّی بِسُلۡطَـٰنࣲ مُّبِینࣲ ۝٢١﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٧٠٨٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عكرمة- قال: كلُّ سلطان في القرآن: حُجَّة. ونزع الآية التي في سورة «سليمان»: <span class="qpc-hafs">﴿أو ليأتيني بسلطان﴾</span>. قال: وأي سلطان كان للهدهد؟!{14}. (١١/٣٥٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٠٨٩<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق سعيد بن جبير- في قوله: <span class="qpc-hafs">﴿أو ليأتيني بسلطان مبين﴾</span>، قال: خبر الحق الصدق البَيِّن{15}. (١١/٣٥٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٠٩٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق العوفي- قوله: <span class="qpc-hafs">﴿أو ليأتيني بسلطان مبين﴾</span>، يقول: ببينة أعذره بها، وهو مثل قوله: <span class="qpc-hafs">﴿الذين يجادلون في آيات الله بغير سلطان﴾</span> [غافر:٣٥]، يقول: بغير بينة{16}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٠٩١<span class="dash">-</span></span> عن <span class="name-2">عبد الله بن شداد بن الهاد</span> -من طريق حصين- <span class="qpc-hafs">﴿أو ليأتيني بسلطان مبين﴾</span>: يعني: بعُذْر بيِّن. فلما جاء الهدهد استقبلته الطير، [فأخبرته]، فقال: ألم يستثن؟ فقالوا: نعم، قد قال: إلا أن يجيء بعذر بيِّن. فجاءه بالعذر الذي في القرآن{17}. (١١/٣٨٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٠٩٢<span class="dash">-</span></span> عن <span class="name-2">الضحاك بن مزاحم</span> -من طريق عبيد- في قوله: <span class="qpc-hafs">﴿أو ليأتيني بسلطان مبين﴾</span>، قال: ببينة، وهو قول الله: <span class="qpc-hafs">﴿الذين يجادلون في آيات الله بغير سلطان﴾</span> [غافر:٣٥] بغير بينة{18}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٠٩٣<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span> -من طريق سفيان، عن رجل- قال: كل شيء في القرآن سلطان: فهو حجة{19}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٠٩٤<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق يونس- <span class="qpc-hafs">﴿أو ليأتيني بسلطان مبين﴾</span>: بعذر بيِّن أعذره به، يقول: <span class="qpc-hafs">﴿فمكث غير بعيد﴾</span>{20}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٠٩٥<span class="dash">-</span></span> عن <span class="name-2">وهب بن مُنَبِّه</span> -من طريق ابن إسحاق، عن بعض أهل العلم- <span class="qpc-hafs">﴿أو ليأتيني بسلطان مبين﴾</span>: أي: بحُجَّة؛ عذر له في غيبته{19}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٠٩٦<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- في قوله: <span class="qpc-hafs">﴿أو ليأتيني بسلطان مبين﴾</span>، قال: بعذر بَيِّن{22}. (١١/٣٥٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٠٩٧<span class="dash">-</span></span> قال <span class="name-2">إسماعيل السُّدِّيّ</span>: بحجة بيِّنة أعذره بها{23}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٠٩٨<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿أو ليأتيني بسلطان مبين﴾</span>، يعني: حجة بينة أعذره بها{9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧٠٩٩<span class="dash">-</span></span> قال <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿أو ليأتيني بسلطان مبين﴾</span>، قال: بعذر أعذره فيه{19}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧١٠٠<span class="dash">-</span></span> قال <span class="name-3">سفيان بن عيينة</span> -من طريق ابن أبي عمر-: وتفقد سليمان الهدهد، فقال: أين هو؟ <span class="qpc-hafs">﴿لأعذبنه عذابا شديدا أو لأذبحنه﴾</span> الآية. فلما جاء الهدهد قيل له: ويحك، ماذا قال فيك نبيُّ الله ﵇؟! قال: فما قال؟ قالوا: قال: <span class="qpc-hafs">﴿لأعذبنه عذابا شديدا﴾</span>. قال: فهل استثنى؟ قالوا: نعم، <span class="qpc-hafs">﴿أو ليأتيني بسلطان مبين﴾</span>. قال: فقد نجوتُ إذًا{26}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿أَوۡ لَیَأۡتِیَنِّی بِسُلۡطَـٰنࣲ مُّبِینࣲ ۝٢١﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٥٧١٠١<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ليث- في الآية، قال: إنّما دفع الله عن الهدهد ببِرِّه والدته{27}. (١١/٣٥٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧١٠٢<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span> -من طريق الزبير بن خريت- قال: إنّما صرف الله عذاب سليمان عن الهدهد لأنّه كان بارًّا بوالديه{28}. (١١/٣٥١)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ١٨/٣٣، وابن أبي حاتم ٩/٢٨٦٢، والحاكم ٢/٤٠٥. وأخرجه عبد الرزاق ٢/٨٠ من طريق عمرو بن دينار، وكذلك إسحاق البستي في تفسيره ص١١. وعزاه السيوطي إلى الفريابي، وسعيد بن منصور، وعبد بن حميد، وابن المنذر.|2:أخرجه ابن جرير ١٨/٣٣.|3:أخرجه ابن جرير ١٨/٣٤، وابن أبي حاتم ٩/٢٨٦٢، وأخرج شطره الأول عبد الرزاق ٢/٨٠، وإسحاق البستي في تفسيره ص١١، وقال: وزاد داود الطائي: وأطرحه للنمل فيأكله.|4:أخرجه ابن جرير ١٨/٣٣. وعزاه السيوطي إلى الفريابي، وعبد بن حميد. وأخرجه ابن جرير ١٨/٣٣ من طريق ابن جريج، وزاد: فلا يعفو سنة، أي: لا ينمو ويكثر.|5:أخرجه ابن جرير ١٨/٣٤-٣٥، وإسحاق البستي في تفسيره ص١٣، وابن أبي حاتم ٩/٢٨٦٣.|6:عزاه السيوطي إلى ابن أبي شيبة، وعبد بن حميد، وابن المنذر.|7:أخرجه عبد الرزاق ٢/٧٩، وابن جرير ١٨/٣٤، وابن أبي حاتم ٩/٢٨٦٢ من طريق سعيد، ولفظه: كنا نحدث: أنّ عذابه ذلك نتف ريشه، فيذره في المنزل حتى تأكله الذر والنمل. وعلقه يحيى بن سلام ٢/٥٣٨ بنحو لفظ ابن أبي حاتم. وعزاه السيوطي إلى عبد بن حميد.|8:أخرجه ابن جرير ١٨/٣٤، وابن أبي حاتم ٩/٢٨٦٢.|9:تفسير مقاتل بن سليمان ٣/٣٠٠.|10:تفسير الثعلبي ٧/١٩٨، وتفسير البغوي ٦/١٥٣.|11:بضعة تنزو: قطعة لحم تقفز لا يستطيع الطيران. النهاية (نزا).|12:أخرجه ابن جرير ١٨/٣٤.|13:علقه ابن أبي حاتم ٩/٢٨٦٢. وكذا جاء فيه عن أبي الأسمر، ولم يتبين لنا من هو، ولم نجد في شيوخ خلف بن خليفة من يعرف بذلك؛ فلعل ما وقع في مطبوعة تفسير ابن أبي حاتم تحريف.|14:عزاه السيوطي إلى عبد بن حميد. وأخرجه يحيى بن سلام ٢/٥٣٨ بمعناه، وابن جرير ١٨/٣٥-٣٦ من طريق سعيد وعكرمة، وإسحاق البستي في تفسيره ص١٣ مختصرًا، وابن أبي حاتم ٩/٢٨٦٣. وليس فيها قوله: سورة سليمان.|15:أخرجه ابن أبي حاتم ٩/٢٨٦٣. وعزاه السيوطي إلى ابن أبي شيبة، وابن المنذر.|16:أخرجه ابن جرير ١٨/٣٥.|17:أخرجه ابن جرير ١٨/٣٥ إلى قوله: ألم يستثن؟، وابن أبي حاتم ٩/٢٨٦٣ إلا قوله: ألم يستثن؟.|18:أخرجه ابن جرير ١٨/٣٦، وإسحاق البستي في تفسيره ص١٣.|19:أخرجه ابن جرير ١٨/٣٦.|20:أخرجه ابن أبي حاتم ٩/٢٨٦٣.|21:أخرجه ابن جرير ١٨/٣٦.|22:أخرجه عبد الرزاق ٢/٨٠، وابن جرير ١٨/٣٦. وعلقه يحيى بن سلام ٢/٥٣٨. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.|23:علقه يحيى بن سلام ٢/٥٣٩.|24:تفسير مقاتل بن سليمان ٣/٣٠٠.|25:أخرجه ابن جرير ١٨/٣٦.|26:أخرجه إسحاق البستي في تفسيره ص١٢، وابن أبي حاتم ٩/٢٨٦٣.|27:أخرجه ابن أبي حاتم ٩/٢٨٦٢.|28:أخرجه أبو الشيخ في العظمة (١٢٨٧). وعزاه السيوطي إلى الحكيم الترمذي.
  27,22,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿فَمَكَثَ غَیۡرَ بَعِیدࣲ فَقَالَ أَحَطتُ بِمَا لَمۡ تُحِطۡ بِهِۦ﴾</span> - قراءات</h3></p><p><div></p><p><p><span class="item-no">٥٧١٠٣<span class="dash">-</span></span> عن الأعمش: قراءة <span class="name-1">عبد الله [بن مسعود]</span>: (فَيَمْكُثُ غَيْرَ بَعِيدٍ){1}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿فَمَكَثَ غَیۡرَ بَعِیدࣲ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٧١٠٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فمكث غير بعيد﴾</span> يقول: لم يلبث إلا قليلًا حتى جاء الهدهدُ، فوقع بين يدي سليمان ﵇، فجعل ينكث بمنقاره، ويُومِئ برأسه إلى سليمان، فقال لسليمان: <span class="qpc-hafs">﴿أحطت بما لم تحط به﴾</span>{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧١٠٥<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: قوله ﷿: <span class="qpc-hafs">﴿فمكث غير بعيد﴾</span> رجع مِن ساعته{3}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿فَقَالَ أَحَطتُ بِمَا لَمۡ تُحِطۡ بِهِۦ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٧١٠٦<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق مجاهد- في قوله: <span class="qpc-hafs">﴿أحطت بما لم تحط به﴾</span>، قال: اطَّلَعتُ على ما لم تَطَّلِع عليه{4}. (١١/٣٥١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧١٠٧<span class="dash">-</span></span> عن <span class="name-2">وهب بن مُنَبِّه</span> -من طريق ابن إسحاق، عن بعض أهل العلم- <span class="qpc-hafs">﴿فمكث غير بعيد﴾</span>: ثم جاء الهدهد، فقال له سليمان: ما خلَّفك عن نوبتك؟ قال: أحطت بما لم تحط به{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧١٠٨<span class="dash">-</span></span> قال <span class="name-2">الحسن البصري</span>: علمت ما لم تعلم{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧١٠٩<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- قوله: <span class="qpc-hafs">﴿أحطت بما لم تحط به﴾</span>، أي: بلغت ما لم تبلغ أنت ولا جنودك{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧١١٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿أحطت بما لم تحط به﴾</span>، يقول: علِمتُ ما لم تعلم به، وجئتك بأمر لم تخبرك به الجن، ولم تنصحك فيه، ولم يعلم به الإنس، وبلغتُ ما لم تبلغه أنت ولا جنودك{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧١١١<span class="dash">-</span></span> عن <span class="name-3">سفيان [الثوري]</span> -من طريق مهران- <span class="qpc-hafs">﴿أحطت بما لم تحط به﴾</span>، يقول: علمتُ ما لم تُحِط به، وما لم تعلم به{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧١١٢<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿أحطت بما لم تحط به﴾</span>، قال: ما لم تَعْلَمْ{5}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَجِئۡتُكَ مِن سَبَإِۭ﴾</span> - قراءات</h3></p><p><div></p><p><p><span class="item-no">٥٧١١٣<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق إسماعيل- أنّه قرأ: ‹مِن سَبَأَ بِنَبَإٍ يَقِينٍ›، قال: يجعلها أرضًا{11}<span class=comment-ref>٤٨٥٤</span>. (١١/٣٥٢)</p></p><p></div></p><p><div><span class=comment-ref>٤٨٥٤</span> <span class="comment-type-4">ذكر</span> <u>ابنُ عطية</u> (٦/٥٣٠) هذه القراءة، ثم قال: «لكن رُوِي عن رسول الله ﷺ من حديث فروة بن مسيك وغيره: أنه اسم رجل ولَد عشرة من الولد، تيامن منهم ستة، وتشامَّ أربعة».</div></p><p><h3><span class="qpc-hafs">﴿وَجِئۡتُكَ مِن سَبَإِۭ﴾</span> - تفسير الآية</h3></p><p><div></p><p><p><span class="item-no">٥٧١١٤<span class="dash">-</span></span> عن علقمة بن وعلة، أنّه سمع ابن عباس يقول: سُئِل رسولُ الله ﷺ عن سبإ، أرجل أم امرأة، أم أرض؟ فقال: «<b>بل هو رجل ولد عشرة، فسكن اليمن منهم ستة، وبالشام منهم أربعة، فأمّا اليمانيون فمَذْحِج وكِندة والأزد والأشعريون وأنمار وحِمْيَر، عربًا كلها، وأما الشامية فلَخَم وجُذام وعاملة وغسّان</b>»{12}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧١١٥<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق إسماعيل- أنه قرأ: ‹مِن سَبَأَ بِنَبَإٍ يَقِينٍ›، قال: يجعلها أرضًا{13}. (١١/٣٥٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧١١٦<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- أنّه قرأ: <span class="qpc-hafs">﴿من سبإٍ بنبإ﴾</span>، قال: يجعله رجلًا{14}. (١١/٣٥٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧١١٧<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿وجئتك من سبإ﴾</span>، قال: سبأ بأرض اليمن، يُقال لها: مأرب، بينها وبين صنعاء مسيرة ثلاث ليال{15}. (١١/٣٥١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧١١٨<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span>، قال: بُعِث إلى سبأ اثنا عشر نبيًّا، منهم: تُبَّع{4}. (١١/٣٥٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧١١٩<span class="dash">-</span></span> عن الرؤاسي أنّه سأل <span class="name-2">أبا عمرو بن العلاء</span>: كيف لم تُجْرِ{17} سبأ؟ قال: لست أدري ما هو{18}<span class=comment-ref>٤٨٥٥</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٤٨٥٥</span> <span class="comment-type-4">علَّق</span> <u>ابن جرير</u> (١٨/٣٨) على قول أبي عمرو بقوله: «فكأن أبا عمرو ترك إجراءه إذ لم يدر ما هو، <span class="mustanad">كما تفعل العرب</span> بالأسماء المجهولة التي لا تعرفها من ترك الإجراء. حكي عن بعضهم: هذا أبو صعرورَ قد جاء. فترك إجراءه إذ لم يعرفه في أسمائهم. وإن كان سبأ»جبلًا«أجري لأنه يُراد به الجبل بعينه، وإن لم يجر فلأنه يجعل اسمًا للجبل وما حوله من البقعة».</div></p><p><div></p><p><p><span class="item-no">٥٧١٢٠<span class="dash">-</span></span> عن <span class="name-3">ابن لهيعة</span>، قال: يقولون: إنّ مأرب مدينة بلقيس، لم يكن بينها وبين بيت المقدس إلا ميل، فلمّا غضب الله عليها بَعَّدَها، فهي اليوم باليمن، وهي التي ذكر الله في القرآن: <span class="qpc-hafs">﴿لقد كان لسبإ في مساكنهم﴾</span> [سبأ:١٥]{19}. (١١/٣٥١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧١٢١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وجئتك من﴾</span> أرض <span class="qpc-hafs">﴿سبإ﴾</span> باليمن <span class="qpc-hafs">﴿بنبإ يقين﴾</span> يقول: بحديث يقين لا شكَّ فيه{2}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿بِنَبَإࣲ یَقِینٍ ۝٢٢﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٧١٢٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق سعيد بن جبير، ومجاهد- في قوله: <span class="qpc-hafs">﴿وجئتك من سبإ بنبإ يقين﴾</span>، قال: خبر حق{21}. (١١/٣٥١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧١٢٣<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span>، في قوله: <span class="qpc-hafs">﴿بنبإ يقين﴾</span>، قال: بخبر حق{22}. (١١/٣٥١)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَجِئۡتُكَ مِن سَبَإِۭ بِنَبَإࣲ یَقِینٍ ۝٢٢﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٧١٢٤<span class="dash">-</span></span> عن <span class="name-2">وهب بن مُنَبِّه</span> -من طريق ابن إسحاق، عن بعض أهل العلم- <span class="qpc-hafs">﴿وجئتك من سبإ بنبإ يقين﴾</span>: أي: أدركت مُلْكًا لم يَبْلُغْهُ مُلْكُك{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٧١٢٥<span class="dash">-</span></span> عن <span class="name-2">يزيد بن رومان</span> -من طريق محمد بن إسحاق- <span class="qpc-hafs">﴿وجئتك من سبإ بنبإ يقين﴾</span>: أي: أدركت ملكًا لم يبلغه ملكك{4}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن أبي داود في المصاحف ١/٣٢٦.</p><p>وهي قراءة شاذة. انظر: البحر المحيط ٧/٦٢.|2:تفسير مقاتل بن سليمان ٣/٣٠١.|3:تفسير يحيى بن سلام ٢/٥٣٩.|4:أخرجه ابن أبي حاتم ٩/٢٨٦٤.|5:أخرجه ابن جرير ١٨/٣٧.|6:علقه يحيى بن سلام ٢/٥٣٩.|7:أخرجه ابن أبي حاتم ٩/٢٨٦٤. وعلقه يحيى بن سلام ٢/٥٣٩.|8:تفسير مقاتل بن سليمان ٣/٣٠١.|9:أخرجه ابن أبي حاتم ٩/٢٨٦٤.|10:أخرجه ابن جرير ١٨/٣٧.|11:أخرجه ابن أبي حاتم ٩/٢٨٦٥. وعلقه يحيى بن سلام ٢/٥٣٩.</p><p>و‹مِن سَبَأَ› بفتح الهمزة غير منونة قراءة متواترة، قرأ بها أبو عمرو، والبزي، وقرأ قنبل: ‹مِن سَبَأْ› بإسكان الهمزة، وقرأ بقية العشرة: <span class="qpc-hafs">﴿مِن سَبَأٍ﴾</span> بالخفض والتنوين. انظر: النشر ٢/٣٣٧، والإتحاف ص٤٢٧.|12:أخرجه أحمد ٥/٧٥ (٢٨٩٨)، والحاكم ٢/٤٥٩ (٣٥٨٥)، ويحيى بن سلام ٢/٥٣٩، ٧٥٢.</p><p>قال الحاكم: «هذا حديث صحيح الإسناد، ولم يخرجاه». وقال الهيثمي في المجمع ٧/٩٤ (١١٢٨٦): «رواه أحمد والطبراني، وفيه ابن لهيعة، وفيه ضعف، وبقية رجالهما ثقات».|13:أخرجه ابن أبي حاتم ٩/٢٨٦٥. وعلقه يحيى بن سلام ٢/٥٣٩.|14:أخرجه ابن أبي حاتم ٩/٢٨٦٥.|15:أخرجه ابن أبي حاتم ٩/٢٨٦٤. وعلقه يحيى بن سلام ٢/٥٣٩. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.|16:أخرجه ابن أبي حاتم ٩/٢٨٦٤.|17:لم تُجْرِ: لم تُنَوِّن.|18:أخرجه ابن جرير ١٨/٣٨.|19:أخرجه ابن أبي حاتم ٩/٢٨٦٤. وهي قراءة العشرة؛ عدا حمزة والكسائي وحفص عن عاصم وخلف فقد قرؤوا <span class="qpc-hafs">﴿مسكنهم﴾</span> على التوحيد، غير أن الكسائي وخلفًا قرآ بكسر الكاف. النشر ٢٢/٢٦٢.|20:تفسير مقاتل بن سليمان ٣/٣٠١.|21:أخرجه ابن أبي حاتم ٩/ ٢٨٦٥. وعزاه السيوطي إلى ابن المنذر.|22:علقه يحيى بن سلام ٢/٥٣٩. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.|23:أخرجه ابن جرير ١٨/٣٧.|24:أخرجه ابن أبي حاتم ٩/٢٨٦٤.