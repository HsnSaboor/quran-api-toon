quran[9]{c,v,t}:
27,14," <q>﴿وَجَحَدُوا۟ بِهَا وَٱسۡتَیۡقَنَتۡهَاۤ أَنفُسُهُمۡ﴾</q> - تفسير ٥٦٩٤٩- عن عبد الله بن عباس -من طريق عطاء الخراساني- <q>﴿واستيقنتها أنفسهم ظلما وعلوا﴾</q>، قال: يقينهم في قلوبهم{1}. (ز) ٥٦٩٥٠- عن قتادة بن دعامة -من طُرُقٍ- في قوله: <q>﴿وجحدوا بها﴾</q>، قال: كذَّبت القومُ بآيات الله بعد ما استيقنتها أنفسُهم أنّها حقٌّ، والجحود لا يكون إلا مِن بعد المعرفة{2}. (١١/٣٣٨) ٥٦٩٥١- عن قتادة بن دعامة -من طريق سعيد بن بشير- في قوله: <q>﴿وجحدوا بها﴾</q> قال: كذَّب بها القوم، وقوله: <q>﴿بها﴾</q> بآيات الله ﷿، <q>﴿واستيقنتها أنفسهم﴾</q> وقد أيقنتها أنفسهم أنّ موسى رسول الله ﷺ{3}. (ز) ٥٦٩٥٢- قال مقاتل بن سليمان: يقول الله ﷿: <q>﴿وجحدوا بها﴾</q> يعني: بالآيات، يعني: بعد المعرفة، فيها تقديم، <q>﴿واستيقنتها أنفسهم﴾</q> أنّها مِن الله ﷿، وأنّها ليست بسحر{4}. (ز) ٥٦٩٥٣- عن عبد الملك ابن جُرَيْج -من طريق حجّاج- <q>﴿وجحدوا بها﴾</q>، قال: الجحود: التكذيب بها{1}. (ز) ٥٦٩٥٤- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قول الله: <q>﴿واستيقنتها أنفسهم ظلما وعلوا﴾</q>، قال: استيقنوا أنّ الآيات مِن الله حقٌّ، فلِمَ جحدوا بها؟ قال: <q>﴿ظلما وعلوا﴾</q>{6}. (ز) ٥٦٩٥٥- قال يحيى بن سلّام: <q>﴿وجحدوا بها واستيقنتها أنفسهم﴾</q> أنّها مِن عند الله{7}. (ز) <q>﴿ظُلۡمࣰا وَعُلُوࣰّاۚ﴾</q> - قراءات ٥٦٩٥٦- عن عاصم بن أبي النجود أنّه قرأ: <q>﴿وعُلُوًّا﴾</q> برفع العين واللام{8}. (١١/٣٣٩) ٥٦٩٥٧- عن سليمان الأعمش أنّه قرأ: (ظُلْمًا وعِلِيًّا){9}. (١١/٣٣٩) <q>﴿ظُلۡمࣰا وَعُلُوࣰّاۚ﴾</q> - تفسير الآية ٥٦٩٥٨- عن عبد الله بن عباس، في قوله: <q>﴿ظلما وعلوا﴾</q>، قال: تَعَظُّمًا، واستكبارًا{10}. (١١/٣٣٨) ٥٦٩٥٩- عن عكرمة مولى ابن عباس -من طريق يزيد النحوي- قال: العُلُوُّ في كتاب الله: التَّجَبُّر{11}. (ز) ٥٦٩٦٠- عن إسماعيل السُّدِّيّ -من طريق أسباط- في قوله: <q>﴿واستيقنتها أنفسهم ظلما وعلوا﴾</q>، قال: تكبَّروا وقد استيقنتها أنفسهم، وهذا مِن التقديم والتأخير{12}. (١١/٣٣٨) ٥٦٩٦١- عن عطاء الخراساني -من طريق ابنه عثمان-: أمّا <q>﴿ظلما وعلوا﴾</q>: فظُلمًا وتَعَظُّمًا واستكبارًا{12}. (ز) ٥٦٩٦٢- عن عبد الملك ابن جُرَيْج -من طريق حجاج- في قوله: <q>﴿ظلما وعلوا﴾</q>، قال: تَعَظُّمًا واستكبارًا{14}. (ز) ٥٦٩٦٣- قال مقاتل بن سليمان: <q>﴿ظلما﴾</q> شركًا، <q>﴿وعلوا﴾</q> تكبرًا{4}. (ز) ٥٦٩٦٤- قال يحيى بن سلّام: <q>﴿ظلما﴾</q> لأنفسهم، وقال في آية أخرى: <q>﴿وما ظلمونا ولكن كانوا أنفسهم يظلمون﴾</q> [الأعراف:١٦٠]{7}. (ز) <q>﴿فَٱنظُرۡ كَیۡفَ كَانَ عَـٰقِبَةُ ٱلۡمُفۡسِدِینَ ۝١٤﴾</q> - تفسير ٥٦٩٦٥- عن أبي العالية الرياحي -من طريق الربيع- قال: وكان فسادهم ذلك معصية الله؛ لأنّه مَن عصى الله في الأرض أو أمر بمعصية فقد أفسد في الأرض؛ لأنّه صلاح الأرض والسماء بالطاعة{17}. (ز) ٥٦٩٦٦- قال مقاتل بن سليمان: <q>﴿فانظر كيف كان عاقبة المفسدين﴾</q> في الأرض بالمعاصي، كان عاقبتهم الغرق، وإنّما استيقنوا بالآيات أنّها مِن الله لدعاء موسى ربَّه أن يكشِف عنهم الرِّجْز، فكشفه عنهم. وقد علِموا ذلك{4}. (ز) ٥٦٩٦٧- قال يحيى بن سلّام: <q>﴿فانظر كيف كان عاقبة المفسدين﴾</q> المشركين، يعنيهم، كان عاقبتهم أن دَمَّر الله عليهم، ثم صيــــَّرهم إلى النار{7}. (ز) ",footnotes:1:أخرجه ابن جرير ١٨/٢٣.أخرج ابن أبي حاتم ٩/٢٨٥٢-٢٨٥٣ شطره الأول من طريق سعيد بن بشير وشيبان، وشطره الثاني من طريق سعيد بن أبي عروبة. وعلق يحيى بن سلام ٢/٥٣٦ آخره. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه ابن أبي حاتم ٩/٢٨٥٢-٢٨٥٣.تفسير مقاتل بن سليمان ٣/٢٩٨.أخرجه ابن جرير ١٨/٢٣.أخرجه ابن جرير ١٨/٢٣، وابن أبي حاتم ٩/٢٨٥٣ من طريق أصبغ.تفسير يحيى بن سلام ٢/٥٣٦.عزاه السيوطي إلى عبد بن حميد. وهي قراءة العشرة.عزاه السيوطي إلى عبد بن حميد. وهي قراءة شاذة، تروى أيضًا عن ابن مسعود، وطلحة. انظر: مختصر ابن خالويه ص١١٠.عزاه السيوطي إلى ابن المنذر.أخرجه ابن أبي حاتم ٩/٢٨٥٣، وأورده في تفسير (العتو) من قوله تعالى: <q>﴿فلما عتوا عما نهوا عنه﴾</q> [الأعراف:١٦٦]، وقوله تعالى: <q>﴿وعتوا عتوا كبيرا﴾</q> [الفرقان:٢١].أخرجه ابن أبي حاتم ٩/٢٨٥٣.أخرجه ابن أبي حاتم ٩/٢٨٥٣.أخرجه ابن جرير ١٨/٢٢.تفسير مقاتل بن سليمان ٣/٢٩٨.تفسير يحيى بن سلام ٢/٥٣٦.أخرجه ابن أبي حاتم ٩/٢٨٥٣، وتقدم أصله عند تفسير قوله تعالى: <q>﴿وإذا قيل لهم لا تفسدوا﴾</q> الآية [البقرة:١١].تفسير مقاتل بن سليمان ٣/٢٩٨.تفسير يحيى بن سلام ٢/٥٣٦.
27,15," <q>﴿وَلَقَدۡ ءَاتَیۡنَا دَاوُۥدَ وَسُلَیۡمَـٰنَ عِلۡمࣰاۖ﴾</q> - تفسير ٥٦٩٦٨- عن الحسن البصري -من طريق سعيد بن أبي عروبة، عن قتادة- في قول الله ﷿: <q>﴿ولقد آتينا داود وسليمان علما﴾</q>، يعني: التوراة، والزبور، والفقه في الدين، وفصل القضاء، وعِلْم كلام الطير والدواب{1}. (ز) ٥٦٩٦٩- عن قتادة بن دعامة -من طريق سعيد بن أبي عروبة- قوله: <q>﴿داود وسليمان علما﴾</q>، قال: فَهْمًا{2}. (ز) ٥٦٩٧٠- عن قتادة بن دعامة -من طريق سعيد بن بشير- قال: كان داود أعطي ثلاثًا{3}: سُخِّرت له الجبال يُسَبِّحْن معه، وأُلِينَ له الحديد، وعُلِّم منطق الطير، وسُخِّرت له الجن، فلمّا مات عُلِّم سليمان منطق الطير وسُخِّرت له الجن، وكان ذلك مما ورِث عنه، ولم تُسخَّر له الجبال، ولم يُلَنْ له الحديد{2}. (١١/٣٣٩) ٥٦٩٧١- قال مقاتل بن سليمان: <q>﴿ولقد آتينا﴾</q> يعني: أعطينا <q>﴿داود وسليمان علما﴾</q> بالقضاء، وبكلام الطير، وبكلام الدواب{5}. (ز) <q>﴿وَقَالَا ٱلۡحَمۡدُ لِلَّهِ ٱلَّذِی فَضَّلَنَا عَلَىٰ كَثِیرࣲ مِّنۡ عِبَادِهِ ٱلۡمُؤۡمِنِینَ ۝١٥﴾</q> - تفسير ٥٦٩٧٢- عن عمر بن عبد العزيز -من طريق إبراهيم بن هشام بن يحيى، عن أبيه، عن جده- أنّه كَتَب: إنّ الله لم يُنعِم على عبد نعمةً، فحَمِد الله عليها، إلا كان حمدُه أفضلَ مِن نعمته، لو كنتَ لا تعرف ذلك إلا في كتاب الله المنزل؛ قال الله ﷿: <q>﴿ولقد آتينا داود وسليمان علما وقالا الحمد لله الذي فضلنا على كثير من عباده المؤمنين﴾</q>، وأيُّ نعمةٍ أفضلُ مِمّا أُوتي داود وسليمان؟!{6}. (١١/٣٣٩) ٥٦٩٧٣- عن الحسن البصري -من طريق سعيد بن أبي عروبة، عن قتادة- في قول الله ﷿: <q>﴿وقالا الحمد لله الذي فضلنا على كثير من عباده المؤمنين﴾</q>، يعني بالتفضيل: النبوة مع الملك{1}. (ز) ٥٦٩٧٤- قال مقاتل بن سليمان: <q>﴿وقالا الحمد لله الذي فضلنا على كثير من عباده المؤمنين﴾</q>، يعني: بالقضاء، والنبوة، والكتاب، وكلام البهائم، والملك الذي أعطاهما الله ﷿، وكان سليمان أعظم ملكًا مِن داود، وأفطن منه، وكان داود أكثرَ تَعَبُّدًا مِن سليمان{8}. (ز) ٥٦٩٧٥- قال يحيى بن سلّام: قوله ﷿: <q>﴿ولقد آتينا داود وسليمان علما وقالا الحمد لله الذي فضلنا على كثير من عباده المؤمنين﴾</q>، يعنيان: أهل زمانهم من المؤمنين{9}. (ز) ",footnotes:1:أخرجه ابن عساكر في تاريخ دمشق ٢٢/٢٣٩.أخرجه ابن أبي حاتم ٩/٢٨٥٤.هكذا في الأصل.أخرجه ابن أبي حاتم ٩/٢٨٥٤.تفسير مقاتل بن سليمان ٣/٢٩٨.أخرجه ابن أبي حاتم ٩/٢٨٥٤، وأبو نعيم في حلية الأولياء ٥/٢٩٣.أخرجه ابن عساكر في تاريخ دمشق ٢٢/٢٣٩.تفسير مقاتل بن سليمان ٣/٢٩٨. ونحو آخره في تفسير الثعلبي ٧/١٩٣، وتفسير البغوي ٦/١٤٨ منسوبًا إلى مقاتل دون تعيينه.تفسير يحيى بن سلام ٢/٥٣٦.
27,16," <q>﴿وَوَرِثَ سُلَیۡمَـٰنُ دَاوُۥدَۖ﴾</q> - تفسير ٥٦٩٧٦- قال أبو بكر الهذلي: قال لي شهر بن حوشب: لَمّا مات داود ورِثه سليمان. قال الله تعالى: <q>﴿وورث سليمان داود وقال يا أيها الناس علمنا منطق الطير﴾</q> الآية{1}. (ز) ٥٦٩٧٧- عن قتادة بن دعامة -من طريق شيبان- في قوله: <q>﴿وورث سليمان داود﴾</q>، قال: ورثه نبوتَه، ومُلكه، وعِلمه{2}. (١١/٣٤٠) ٥٦٩٧٨- عن إسماعيل السُّدِّيّ -من طريق أسباط- في قوله تعالى: <q>﴿وورث سليمان داود﴾</q>، قال: نبوته{3}. (ز) ٥٦٩٧٩- عن الربيع بن أنس -من طريق أبي جعفر- في قوله: <q>﴿وورث سليمان داود﴾</q>، قال: ورثه أن سخَّر له الشياطين والرياح إلى ما ورث مما أُعطِي أبوه{4}. (ز) ٥٦٩٨٠- قال مقاتل بن سليمان: <q>﴿وورث سليمان داود﴾</q>، يعني: ورث سليمانُ عِلْمَ داود، ومُلْكَه{5}٤٨٤٧. (ز) ٤٨٤٧ رجَّح ابنُ القيم (٢/٢٧٩) أنّ الميراث: هو ميراث العلم والنبوة فقط، مستندًا إلى الإجماع، ودلالة العقل، والسياق، والنظائر، فقال: «هو ميراث العلم والنبوة لا غير، وهذا باتفاق أهل العلم من المفسرين وغيرهم، وهذا لأنّ داود ﵇ كان له أولاد كثير سوى سليمان، فلو كان الموروث هو المال لم يكن سليمان مختصًّا به. وأيضًا فإنّ كلام الله يصان عن الإخبار بمثل هذا؛ فإنه بمنزلة أن يقال: مات فلان وورثه ابنه. ومِن المعلوم أنّ كلَّ أحد يرثه ابنه، وليس في الإخبار بمثل هذا فائدة، وأيضًا فإنّ ما قبل الآية وما بعدها يبين أنّ المراد بهذه الوراثة وراثة العلم والنبوة لا وراثة المال، قال تعالى: <q>﴿ولقد آتينا داوود وسليمان علما وقالا الحمد لله الذي فضلنا على كثير من عباده المؤمنين وورث سليمان داوود﴾</q>، وإنما سيق هذا لبيان فضل سليمان، وما خصَّه الله به من كرامته وميراثه ما كان لأبيه من أعلى المواهب، وهو العلم والنبوة، <q>﴿إن هذا لهو الفضل المبين﴾</q>، وكذلك قول زكريا ﷺ: <q>﴿وإني خفت الموالي من ورائي وكانت امرأتي عاقرا فهب لي من لدنك وليا يرثني ويرث من آل يعقوب واجعله رب رضيا﴾</q> [مريم:٥-٦]، فهذا ميراث العلم والنبوة والدعوة الى الله، وإلا فلا يظن بنبي كريم أنه يخاف عصبته أن يرثوه ماله، فيسأل الله العظيم ولدًا يمنعهم ميراثه، ويكون أحق به منهم! وقد نزه الله أنبياءه ورسله عن هذا وأمثاله». وبنحوه ابنُ تيمية (٥/٦٤)، إلا أنه انتقد الاستدلال بقوله تعالى: <q>﴿فهب من لدنك وليا يرثني﴾</q>، مستندًا إلى اللغة، فذكر أنه: «لا يدل على محل النزاع؛ لأنّ الإرثَ اسمُ جنس تحته أنواع، والدالُّ على ما به الاشتراك لا يدل على ما به الامتياز، فإذا قيل: هذا حيوان. لا يدل على أنه إنسان أو فرس أو بعير، وذلك أنّ لفظ الإرث يستعمل في إرث العلم والنبوة والملك وغير ذلك من أنواع الانتقال، قال تعالى: <q>﴿ثم أورثنا الكتاب الذين اصطفينا من عبادنا﴾</q> [فاطر:٣٢]». <q>﴿وَقَالَ یَـٰۤأَیُّهَا ٱلنَّاسُ﴾</q> - تفسير ٥٦٩٨١- قال مقاتل بن سليمان: <q>﴿وقال﴾</q> سليمان لبني إسرائيل: <q>﴿يا أيها الناس﴾</q>{5}. (ز) ٥٦٩٨٢- عن الأوزاعي -من طريق ضمرة- قال: الناس عندنا: أهلُ العلم{7}. (١١/٣٤٠) <q>﴿عُلِّمۡنَا مَنطِقَ ٱلطَّیۡرِ﴾</q> - تفسير ٥٦٩٨٣- عن محمد بن كعب القرظي -من طريق أبي معشر- <q>﴿وقال يأيها الناس علمنا منطق الطير﴾</q>، قال: بلغنا: أنّ سليمان كان عسكرُه مائة فرسخ؛ خمسة وعشرون منها للإنس، وخمسة وعشرون للجن، وخمسة وعشرون للوحش، وخمسة وعشرون للطير، وكان له ألف بيت من قوارير على الخشب، فيها ثلاثمائة صَرِيحَة{8}، وسبعمائة سُرِّيّة{9}، فأمر الريحَ العاصِفَ فرفعته، وأمر الرَّخاء فسَيَّرَتْه، فأوحى الله إليه وهو يسير بين السماء والأرض: إنِّي قد زدتُ في مُلْكِك أنّه لا يتكلم أحدٌ مِن الخلائق بشيء إلا جاءت الريحُ فأخبرتك به{10}. (١١/٣٤٢) ٥٦٩٨٤- عن قتادة بن دعامة -من طريق معمر- في قوله: <q>﴿علمنا منطق الطير﴾</q>، قال: النملة مِن الطير{11}. (ز) <q>﴿عُلِّمۡنَا مَنطِقَ ٱلطَّیۡرِ﴾</q> - آثار متعلقة بالآية ٥٦٩٨٥- عن عبد الله بن مسعود، قال: كنت عند عمر بن الخطاب، فدخل علينا كعب الحبر، فقال: يا أمير المؤمنين، ألا أخبرك بأغربِ شيء قرأتُ في كتب الأنبياء! إنّ هامَةً{12} جاءت إلى سليمان، فقالت: السلام عليك، يا نبي الله. فقال: وعليك السلام، يا هامُ، أخبريني كيف لا تأكلين الزرعَ؟ فقالت: يا نبي الله، لأنّ آدم عصى ربَّه في سببه، لذلك لا آكله. قال: فكيف لا تشربين الماء؟ قالت: يا نبي الله، لأنّ الله أغرق بالماء قوم نوح، من أجل ذلك تركت شربها. قال: فكيف تركت العمران وأسكنت الخراب؟ قالت: لأنّ الخراب ميراث الله، وأنا أسكن في ميراث الله. وقد ذكر الله ذلك في كتابه فقال: <q>﴿وكم أهلكنا من قرية بطرت معيشتها﴾</q> إلى قوله: <q>﴿وكنا نحن الوارثين﴾</q> [القصص:٥٨]{13}. (١١/٣٤٠) ٥٦٩٨٦- عن أبي الصديق الناجي -من طريق زيد العمي- قال: خرج سليمان بن داود يستسقي بالناس، فمَرَّ على نملة مُسْتَلْقِيَة على قفاها، رافعة قوائمها إلى السماء، وهي تقول: اللهم، إنّا خَلْقٌ مِن خَلْقِك، ليس بنا غِنًى عن رزقك، فإمّا أن تسقينا، وإما أن تهلكنا. فقال سليمان للناس: ارجعوا، فقد سُقِيتم بدعوة غيركم{14}. (١١/٣٤١) ٥٦٩٨٧- قال مقاتل: كان سليمان ﵇ جالِسًا، إذ مرَّ به طائر يُصَوِّت، فقال لجُلسائه: هل تدرون ما يقول الطائر الذي مرَّ بنا؟ قالوا: أنت أعلم. فقال سليمان: إنّه قال لي: السلام عليك، أيها الملِك المسلط على بني إسرائيل، أعطاك اللهُ ﷾ الكرامةَ، وأظهرك على عدوك، إنِّي مُنطلِق إلى فروخي، ثم أمر بك الثانية. وإنّه سيرجع إلينا الثانية، فانظروا إلى رجوعه. قال: فنظر القوم طويلًا، إذ مرَّ بهم، فقال: السلام عليك، أيها الملك، إن شئت أن تأذن لي كيما أُحْسِب فروخي{15} حتى يشبوا ثم آتيك فافعل بي ما شئت. فأخبرهم سليمان بما قال، وأذِن له{16}. (ز) <q>﴿وَأُوتِینَا مِن كُلِّ شَیۡءٍۖ إِنَّ هَـٰذَا لَهُوَ ٱلۡفَضۡلُ ٱلۡمُبِینُ ۝١٦﴾</q> - تفسير ٥٦٩٨٨- قال عبد الله بن عباس: مِن أمر الدنيا والآخرة{17}. (ز) ٥٦٩٨٩- عن إسماعيل السُّدِّيّ -من طريق أسباط- قوله: <q>﴿وأوتينا من كل شيء﴾</q>، قال: أوتوا مِن كل شيء كان في بلادهم{18}. (ز) ٥٦٩٩٠- قال مقاتل بن سليمان: <q>﴿وأوتينا من كل شيء﴾</q> يعني: أُعطينا الملكَ، والنبوةَ، والكتابَ، والرياحَ، وسُخِّرَتْ لنا الشياطين، ومنطق الدواب، ومحاريب، وتماثيل، وجفان كالجوابي، وقدور راسيات، وعين القطر -يعني: عين الصُّفْر-، <q>﴿إن هذا﴾</q> الذي أُعْطِينا <q>﴿لهو الفضل المبين﴾</q> يعني: البيِّن{19}. (ز) ٥٦٩٩١- قال يحيى بن سلّام: قوله ﷿: <q>﴿وقال يأيها الناس علمنا منطق الطير وأوتينا من كل شيء﴾</q> يعني: كل شيء أوتي منه، <q>﴿إن هذا لهو الفضل المبين﴾</q> البيِّن{20}. (ز) <q>﴿وَأُوتِینَا مِن كُلِّ شَیۡءٍۖ إِنَّ هَـٰذَا لَهُوَ ٱلۡفَضۡلُ ٱلۡمُبِینُ ۝١٦﴾</q> - آثار متعلقة بالآية ٥٦٩٩٢- عن أبي الدرداء -من طريق عبد الرحمن بن أبي ليلى- قال: كان داود يقضي بين البهائم يومًا، وبين الناس يومًا، فجاءت بقرةٌ، فوَضَعَتْ قرنها في حلقة الباب، ثم تَبَغَّمَتْ{21} كما تَبْغَمُ الوالدةُ على ولدها، وقالت: كنت شابَّةً، كانوا ينتجوني ويستعملوني، ثم إني كبرت، فأرادوا أن يذبحوني. فقال داود: أحسِنوا إليها، ولا تذبحوها. ثم قرأ: <q>﴿علمنا منطق الطير وأوتينا من كل شيء﴾</q>{7}. (١١/٣٤١) ٥٦٩٩٣- عن وهب بن مُنَبِّه، قال: مرَّ سليمان بن داود وهو في مُلكه قد حملته الريحُ على رجل حرّاث مِن بني إسرائيل، فلمّا رآه قال: سبحان الله، لقد أوتي آل داود ملكًا! فحملتها الريح، فوضعتها في أذنه، فقال: ائتوني بالرجل. فأُتي به، فقال: ماذا قلت؟ فأخبره، فقال سليمان: إنِّي خشيت عليك الفتنة، لَثوابُ «سبحان الله» عند الله يوم القيامة أعظم مِمّا أوتي آل داود. فقال الحرّاث: أذهب اللهُ همَّك كما أذهبت هَمِّي. قال: وكان سليمان رجلًا أبيض، جسيمًا، أشعر، غَزّاءً، لا يسمع بملك إلا أتاه، فقاتله، فدَوَّخَه، يأمر الشياطين فيجعلون له دارًا مِن قوارير، فيحمل ما يريد مِن آلة الحرب فيها، ثم يأمر العاصف، فتحمله مِن الأرض، ثم يأمر الرخاء، فتقدمه حيث شاء{23}. (١١/٣٤٢) ٥٦٩٩٤- عن أبي بكر الهذلي، قال: قال شهر بن حوشب: أعَلِمْتَ أو شعرتَ أنّ سليمان بن داود لم يكن يُحْسِن منطق الطير وأبوه حيٌّ! ... كان لداود ثلاثٌ مِن النعم، ولسليمان ثلاث مِن النِّعم: لداود الجبال أوبي معه، والطير، وألنا له الحديد.= (ز) ٥٦٩٩٥- قال الهذلي: عن الحسن قال: كان داود يأخذ الحديد، فيقول له هكذا، فيصير في يده كأنّه العجين.= (ز) ٥٦٩٩٦- وقال شهر بن حوشب في حديثه: ولسليمان عين القطر -وهو الصُّفر- جرى له مِن صنعاء، والشياطين، والرياح، فلما مات داود ورثه سليمان ملكه ونعمته{24}. (ز) ٥٦٩٩٧- عن يحيى بن أبي كثير، قال: قال سليمانُ بن داود لبني اسرائيل: ألا أريكم بعض ملكي اليوم؟ قالوا: بلى، يا نبي الله. قال: يا ريحُ، ارفعينا. فرفعتهم الريح، فجعلتهم بين السماء والأرض، ثم قال: يا طيرُ، أظِلِّينا. فأظلتهم الطيرُ بأجنحتها لا يرون الشمس، قال: يا بني إسرائيل، أي ملك ترون؟ قالوا: نرى مُلكًا عظيمًا. قال: فوالذي نفس سليمان بيده، لَقول العبد: لا إله إلا الله وحده لا شريك له، له الملك وله الحمد، وهو على كل شيء قدير. خيرٌ مِن مُلكي هذا، ومِن الدنيا وما فيها، يا بني إسرائيل، مَن خشي الله في السر والعلانية، وقصد في الغنى والفقر، وعدل في الرضا والغضب، وذكر الله على كل حال؛ فقد أُعطي مثل ما أُعطيت{25}. (١١/٣٤٣) ٥٦٩٩٨- عن ابن أبي نجيح -من طريق سفيان- قال: قال سليمان بن داود ﵉: أوتينا مما أوتي الناس ومما لم يُؤْتَوْه، وعُلِّمنا مِمّا عُلِّم الناس وما لم يعلموا؛ فلم نجِد شيئًا هو أفضل مِن تقوى الله في السِّرِّ والعلانية، والعدل في الرضا والغضب، والقَصْد في الغِنى والفقر{26}. (٢/٣٩٦) ٥٦٩٩٩- عن جعفر بن محمد -من طريق ابنه محمد- قال: أُعْطِي سليمان ملك مشارق الأرض ومغاربها، فمُلْك سليمان سبعمائة سنة وستة أشهر، ملك أهل الدنيا كلهم من الجن، والإنس، والدواب، والطير، والسباع، وأُعطي كل شيء، ومنطق كل شيء، وفي زمانه صنعت الصنائع المعجبة، حتى إذا أراد الله أن يقبضه إليه أوحى إليه: أن اسْتودِعْ علم الله وحكمته أخاه، ووَلَدَ داود. وكانوا أربعمائة وثمانين رجلًا؛ أنبياء بلا رسالة{27}. (١١/٣٤٢) ٥٧٠٠٠- قال مقاتل: نسجت الشياطينُ لسليمان ﵇ بِساطًا، فرسخًا في فرسخ، ذهبًا في إبريسم، وكان يوضع له منبر من الذهب في وسط البساط، فيقعد عليه، وحوله ثلاثة آلاف كرسي مِن ذهب وفضة، يقعد الأنبياء على كراسي الذهب، والعلماء على كراسي الفضة، وحولهم الناس، وحول الناس الجن والشياطين، وتُظِلُّه الطير بأجنحتها حتى لا تقع عليه الشمس، وترفع ريح الصبا البساط مسيرة شهر، مِن الصباح إلى الرواح، ومن الرواح إلى الصباح{28}. (ز) ",footnotes:1:أخرجه إسحاق البستي في تفسيره ص٨.أخرجه ابن أبي حاتم ٩/٢٨٥٤. وعلقه يحيى بن سلام ٢/٥٣٦ دون قوله: وعلمه. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه إسحاق البستي في تفسيره ص٧.أخرجه ابن أبي حاتم ٩/٢٨٥٤.تفسير مقاتل بن سليمان ٣/٢٩٩.تفسير مقاتل بن سليمان ٣/٢٩٩.أخرجه ابن أبي حاتم ٩/٢٨٥٥.الصّريح: الخالص النسب. النهاية (صرح).السُّرّية: الجارية المتَّخَذة للملك والجماع. اللسان (سرر).أخرجه ابن جرير ١٨/٢٥، والحاكم ٢/٥٨٩.أخرجه عبد الرزاق ٢/٧٩، وابن أبي حاتم ٩/٢٨٥٥.الهامة: اسم طائر من طَيْر اللَّيل. وقيل: هِيَ البُومَة. النهاية (هوم).أخرجه ابن أبي حاتم ٩/٢٩٩٦-٢٩٩٧.أخرجه ابن أبي شيبة ١٠/٣١٢، ١٣/٢٠٧، وأحمد في الزهد ص٨٧، وابن أبي حاتم ٩/٢٨٥٨.أُحْسِب فروخي: أطعمهم وأسقيهم، وأحسَبَ الرجلَ وحسَّبه: أطعمه وسقاه حتى يشبع. ينظر: لسان العرب (حسب).تفسير الثعلبي ٧/١٩٣.تفسير البغوي ٦/١٤٩.أخرجه إسحاق البستي في تفسيره ص٧، وابن أبي حاتم ٩/٢٨٥٥.تفسير مقاتل بن سليمان ٣/٢٩٩. وأوله في تفسير البغوي ٦/١٤٩ منسوبًا إلى مقاتل دون تعيينه.تفسير يحيى بن سلام ٢/٥٣٦.في مطبوعة تفسير ابن أبي حاتم ونسخ الدر: تنغمت بالنون بدل الباء، وقد أثبتنا ما أُثْبِت في مطبوعة الدر. ومعنى تَبَغَّمَتْ: صاحت إلى ولدها بأَرْخَم ما يكون من صوتها. اللسان (بغم).أخرجه ابن أبي حاتم ٩/٢٨٥٥.أخرجه عبد الله بن أحمد في زوائد الزهد ص٣٩-٤٠. وعزاه السيوطي إلى ابن المنذر. وينظر: تفسير الثعلبي ٧/١٩٦.أخرجه إسحاق البستي في تفسيره ص٦.عزاه السيوطي إلى ابن المنذر.أخرجه الأصبهاني في الترغيب والترهيب ١/٤١٢.أخرجه الحاكم في المستدرك ٢/٥٨٨.تفسير الثعلبي ٧/١٩٦.
27,17," <q>﴿وَحُشِرَ لِسُلَیۡمَـٰنَ جُنُودُهُۥ مِنَ ٱلۡجِنِّ وَٱلۡإِنسِ وَٱلطَّیۡرِ﴾</q> - تفسير ٥٧٠٠١- قال مقاتل بن سليمان: <q>﴿وحشر لسليمان﴾</q> يعني: وجمع لسليمان <q>﴿جنوده من الجن﴾</q> طائفة، <q>﴿و﴾</q>من <q>﴿الإنسِ و﴾</q>من <q>﴿الطَّيـــــْرِ﴾</q> طائفة{1}. (ز) ٥٧٠٠٢- قال يحيى بن سلّام: قوله ﷿: <q>﴿وحشر﴾</q>، أي: وجُمِع{2}. (ز) <q>﴿وَحُشِرَ لِسُلَیۡمَـٰنَ جُنُودُهُۥ مِنَ ٱلۡجِنِّ وَٱلۡإِنسِ وَٱلطَّیۡرِ﴾</q> - آثار متعلقة بالآية ٥٧٠٠٣- عن عبد الله بن عباس -من طريق مجاهد-: أنّ سليمان كان يضع سريره، ثم يضع الكرسيَّ عن يمينه وشماله، فيأذن للإنس، ثم يأذن للجن، فيكونون خلف الإنس، ثم يأذن للشياطين، فيكونون خلف الجن، ثم يرسل إلى الريح، فتأتيه، فتحملهم، وتُظِلُّه الطيرُ فوقَه وهو على سريره وكراسيه، يسير بهم غدوة الراكب، إلى أن يشتهي المنزل شهرًا، ثم تروح بهم مثل ذلك{3}. (ز) ٥٧٠٠٤- عن سعيد بن جبير -من طريق سفيان بن عيينة، عن أبي سنان- قال: كان يُوضَع لسليمان ﵇ ثلاثمائة ألف كرسي، فيجلس مؤمنو الإنس مما يليه، ومؤمنو الجن مِن ورائهم، ثم يأمر الطير فتُظِلّه، ثم يأمر الريح فتحمله.= (ز) ٥٧٠٠٥- قال سفيان: فيمُرُّون على السنبلة، فلا يحركونها{4}. (١١/٣٤٤) ٥٧٠٠٦- عن وهب بن مُنَبِّه -من طريق محمد بن إسحاق، عن بعض أهل العلم- قال: ورِث سليمان المُلْك، وأحْدَثَ اللهُ إليه النبوةَ، وسأله أن يهب له ملكًا لا ينبغي لأحد من بعده، ففعل -تبارك وتعالى-، فسخَّر له الإنس والجن والطير والريح ...{5}. (ز) <q>﴿فَهُمۡ یُوزَعُونَ ۝١٧﴾</q> - تفسير ٥٧٠٠٧- عن عبد الله بن عباس، في قوله: <q>﴿فهم يوزعون﴾</q>، قال: يُدْفَعون{6}. (١١/٣٤٤) ٥٧٠٠٨- عن عبد الله بن عباس -من طريق عطاء الخراساني- في قوله: <q>﴿فهم يوزعون﴾</q>، قال: جعل على كلِّ صنف منهم وزَعَة، تَرُدُّ أُولاها على أُخراها؛ لِئلّا يتقدَّموا في المسير كما تصنع الملوك{7}. (١١/٣٤٤) ٥٧٠٠٩- عن عبد الله بن عباس: أنّ نافع بن الأزرق سأله عن قوله: <q>﴿فهم يوزعون﴾</q>. قال: يُحبَس أولهم على آخرهم حتى تنام الطير. قال: وهل تعرف العرب ذلك؟ قال: نعم، أوَما سمعت قولَ الشاعر: وزَعْتُ رَعِيلَها{8} بأقَبِّ{9} نَهْدٍ إذا ما القومُ شدُّوا بعد خمسِ؟{10}. (١١/٣٤٤) ٥٧٠١٠- عن أبي الأحوص [عوف بن مالك الأشجعي] -من طريق ابن الأقمر- <q>﴿فهم يوزعون﴾</q>، قال: يُحبَس الأولُ على الآخِر{11}. (ز) ٥٧٠١١- عن أبي رَزيِن [مسعود بن مالك الأسدي] -من طريق منصور- في قوله: <q>﴿فهم يوزعون﴾</q>، قال: يُحبَس أولهم على آخرهم{12}. (١١/٣٤٥) ٥٧٠١٢- عن مجاهد بن جبر -من طريق ابن جريج- في قوله: <q>﴿فهم يوزعون﴾</q>، قال: جعل على كل صنف وزَعة، يرُدُّون أوليها على آخريها؛ لِئلّا يتقدموا في المسير، كما تفعل الملوكُ اليومَ{13}. (١١/٣٤٥) ٥٧٠١٣- عن الحسن البصري -من طريق معمر- قال: <q>﴿يوزعون﴾</q>: يَتَقَدَّمون{14}. (ز) ٥٧٠١٤- قال الحسن البصري: <q>﴿فهم يوزعون﴾</q> فهم يدفعون، لا يتقدَّمه منهم أحد{15}. (ز) ٥٧٠١٥- قال الحسن البصري: كان سليمان إذا أراد أن يركب جاءت الريحُ، فوَضَع سريرَ مملكته عليها، ووُضِعَت الكراسي والمجالس على الريح، وجلس سليمان على سريره، وجلس وُجُوه أصحابه على منازلهم في الدِّين عندَه مِن الجن والإنس، والجنُّ يومئذ ظاهرة للإنس، رجالٌ أمثال الإنس، إلا أنهم أُدْم، يَحُجُّون جميعًا، ويُصَلُّون جميعًا، ويعتمرون جميعًا، والطير تُرَفْرِف على رأسه ورؤوسهم، والشياطين حَرَسُه لا يتركون أحدًا يتقدَّم بين يديه، وهو قوله: <q>﴿فهم يوزعون﴾</q>{16}٤٨٤٨. (ز) ٤٨٤٨ علَّق ابنُ عطية (٦/٥٢٥) على الخلاف في مقدار جُند سليمان ﵇ بقوله: «واختلف الناس في مقدار جند سليمان ﵇ اختلافًا شديدًا لم أُرِد ذكره لعدم صحته، غير أنّ الصحيح أنّ ملكه كان عظيمًا؛ ملأ الأرض، وانقادت له المعمورة، وكان كرسيه يحمل أجناده من الجن والإنس، وكانت الطير تظله من الشمس، ويبعثها في الأمور، وكان له في الكرسي الأعظم موضعٌ يَخُصُّه». ٥٧٠١٦- عن قتادة بن دعامة -من طريق سعيد- <q>﴿فهم يوزعون﴾</q>، قال: لكل صنف وزَعَةٌ، يُرَدُّ أولهم على آخرهم{17}. (١١/٣٤٥) ٥٧٠١٧- قال إسماعيل السُّدِّيّ: <q>﴿يوزعون﴾</q>، يعني: يُساقون{18}. (ز) ٥٧٠١٨- قال إسماعيل السُّدِّيّ: يوقفون{19}. (ز) ٥٧٠١٩- قال مقاتل بن سليمان: <q>﴿فهم يوزعون﴾</q>، يعني: يُساقون، وكان سليمان استعمل عليهم جندًا يرُدُّ الأولَ على الآخر، حتى ينام{20} الناس{21}. (ز) ٥٧٠٢٠- قال عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿وحشر لسليمان جنوده من الجن والإنس والطير فهم يوزعون﴾</q>، قال: <q>﴿يوزعون﴾</q>: يساقون{7}٤٨٤٩. (ز) ٤٨٤٩ اختلف في معنى قوله: <q>﴿فهم يوزعون﴾</q> على أقوال خمسة: الأول: معنى ذلك: يحبس أولهم على آخرهم حتى يجتمعوا. الثاني: يساقون. الثالث: يتقدمون. الرابع: يدفعون. الخامس: يوقفون. ورجح ابنُ جرير (٦/٢٧) مستندًا إلى اللغة القولَ الأول الذي قاله ابن عباس، وقتادة، ومجاهد، وأبو رزين، فقال: «وذلك أنّ الوازع في كلام العرب هو: الكافُّ، يقال منه: وزع فلان فلانًا عن الظلم: إذا كفه عنه». وعلَّق ابنُ عطية (٦/٥٢٥) على القول الأول بقوله: «ومنه قول الحسن البصري حين ولي قضاء البصرة: لا بُدَّ للحاكم مِن وزعة. ومنه قول أبي قحافة حين وصفت له الجارية في يوم الفتح أنّها ترى سوادًا أمامه فارس قد تقدم من الصف، فقال لها: ذلك الوازع». ",footnotes:1:تفسير مقاتل بن سليمان ٣/٢٩٩.تفسير يحيى بن سلام ٢/٥٣٧.أخرجه ابن أبي حاتم ٩/٢٨٥٥.أخرجه إسحاق البستي في تفسيره ص٧، وابن أبي حاتم ٩/٢٨٥٥.أخرجه ابن أبي حاتم ٩/٢٨٥٦.أخرجه ابن جرير ١٨/١٢٩، وابن أبي حاتم ٩/٢٩٢٧. وعزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ١٨/٢٦.الرَّعِيل: اسم كل قطعة متقدمة مِن خيلٍ وجرادٍ وطيرٍ ورجالٍ ونجومٍ وإبِلٍ وغير ذلك. اللسان (رعل).الأَقَبّ: الضامِر. اللسان (قبب).عزاه السيوطي إلى الطستي في مسائله. وأخرجه الطبراني (١٢٠٧٦) من طريق ابن أبي ليلى عن الحكم عن مقسم دون ذكر نافع ومسألته واستشهاد ابن عباس.أخرجه إسحاق البستي في تفسيره ص٩.أخرجه ابن أبي شيبة ١٣/٤١٧. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه ابن أبي حاتم ٩/٢٨٥٦، وابن أبي شيبة ١٣/٤١٧، وابن جرير ١٨/١٢٩، وابن أبي حاتم ٩/٢٨٥٦ من طريق ابن جريج بلفظ: يحبس أولهم على آخرهم. وكذا عزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه عبد الرزاق ٢/٧٩، وابن جرير ١٨/٢٧، وابن أبي حاتم ٩/٢٨٥٧.علقه يحيى بن سلام ٢/٥٣٧.علَّقه يحيى بن سلام ٢/٥٣٨.أخرجه ابن أبي حاتم ٩/٢٨٥٧. وعلَّقه يحيى بن سلام ٢/٥٣٧، ٧٤٩. وأخرجه عبد الرزاق ٢/٧٩، وابن جرير ١٨/٢٦ من طريق معمر دون أوله. وكذا عزاه السيوطي إلى عبد بن حميد.علَّقه يحيى بن سلام ٢/٥٣٧.تفسير الثعلبي ٧/١٩٥، وتفسير البغوي ٦/١٥٠.كذا في المطبوع، ولعلها: يتـتام.تفسير مقاتل بن سليمان ٣/٢٩٩. وأوله في تفسير الثعلبي ٧/١٩٥، وتفسير البغوي ٦/١٤٩ منسوبًا إلى مقاتل دون تعيينه.أخرجه ابن جرير ١٨/٢٦.
27,18," <q>﴿حَتَّىٰۤ إِذَاۤ أَتَوۡا۟ عَلَىٰ وَادِ ٱلنَّمۡلِ﴾</q> - تفسير ٥٧٠٢١- عن كعب الأحبار -من طريق وهب بن منبه- قال: كان سليمان إذا ركب حمل أهله وخدمه وحشمه، وقد اتَّخذ مطابخ ومخابز يحمل فيها تنانير{1} الحديد، وقُدور عظام، يَسَعُ كلُّ قِدْرٍ عشر جزائر{2}، وقد اتخذ ميادين للدواب أمامه، فيطبخ الطباخون، ويخبز الخبازون، وتجري الدواب بين يديه بين السماء والأرض، والريح تهوي بهم، فسار مِن إصْطَخر إلى اليمن، فسلك مدينة رسول الله ﷺ، فقال سليمان: هذه دارُ هجرة نبيٍّ في آخر الزمان، طوبى لِمَن آمن به، وطوبى لمن اتبعه. ورأى حول البيت أصنامًا تُعبَد من دون الله، فلما جاوز سليمان البيت بكى البيت، فأوحى الله إلى البيت: ما يبكيك؟ فقال: يا ربِّ، أبكاني أنّ هذا نبيٌّ مِن أنبيائك وقومٌ مِن أوليائك مرُّوا عَلَيَّ فلم يهبطوا، ولم يُصَلُّوا عندي، والأصنام تُعبَد حولي مِن دونك. فأوحى الله إليه: أن لا تبك، فإني سوف أملؤك وجوهًا سُجَّدًا، وأُنزِل فيك قرآنًا جديدًا، وأبعث منك نبيًّا في آخر الزمان، أحب أنبيائي إلَيَّ، وأجعل فيك عُمّارًا مِن خلقي يعبدونني، وأفرِض على عبادي فريضة يَذِفُّون{3} إليك ذفيف النُّسور إلى وكرها، ويحنون إليك حنين الناقة إلى ولدها، والحمامة إلى بيضتها، وأطهرك من الأوثان، وعبدة الشياطين. ثم مضى سليمان حتى مرَّ بوادي السُّدِّيّر؛ واد من الطائف، فأتى على وادي النمل. هكذا قال كعب: إنّه وادٍ بالطائف{4}. (ز) ٥٧٠٢٢- عن كعب الأحبار -من طريق وهب بن منبه- قال: إنّ سليمان كان إذا ركب حمل أهله وسار. [وذكر الحديث حتى قال]: ثم مضى سليمانُ حتى مرَّ بوادي النسرين من الطائف، فأتى على وادي النمل ...{5}. (ز) ٥٧٠٢٣- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿حتى إذا أتوا على وادي النمل﴾</q>، قال: ذُكِر لنا: أنّه وادٍ بأرض الشام{6}. (١١/٣٤٥) ٥٧٠٢٤- قال مقاتل بن سليمان: وقال ﷿: <q>﴿حتى إذا أتوا على واد النمل﴾</q> مِن أرض الشام{7}٤٨٥٠. (ز) ٤٨٥٠ ذكر ابنُ عطية (٦/٥٢٦) أنّ ظاهر هذه الآية: أنّ سليمان وجنوده كانوا مشاة في الأرض، وأنّه بذلك يتفق حطم النمل بنزولهم في وادي النمل، ثم قال: «ويحتمل أنهم كانوا في الكرسي المحمول بالريح، وأحست النمل بنزولهم في وادي النمل». <q>﴿قَالَتۡ نَمۡلَةࣱ یَـٰۤأَیُّهَا ٱلنَّمۡلُ ٱدۡخُلُوا۟ مَسَـٰكِنَكُمۡ﴾</q> - تفسير ٥٧٠٢٥- عن كعب الأحبار -من طريق وهب بن منبه- قال: ... أتى على وادي النمل، فقالت نملة تسمى: جيرين، مِن قبيلة تسمى: الشيصبان، وكانت عرجاء تَتَكاوَس{8}، وكانت مثل الذِّئب العظيم، فنادت النملة: <q>﴿يا أيها النمل ادخلوا مساكنكم لا يحطمنكم سليمان وجنوده وهم لا يشعرون﴾</q>، يعني: أنّ سليمان يفهم مقالتها، وكان لا يتكلم خَلْقٌ إلا حَمَلَتِ الريحُ ذلك، فألقته في مسامع سليمان ...{5}. (ز) ٥٧٠٢٦- عن نَوفٍ البِكالي -من طريق الأعمش، عن الحكم بن الوليد- قال: كان النمل في زمن سليمان بن داود أمثال الذباب. وفي لفظ: أمثال الذئاب{10}٤٨٥١. (١١/٣٤٥) ٤٨٥١ ساق ابنُ عطية (٦/٥٢٦) هذا القول، وكذا قول مَن قال بأن النمل كان صغيرًا، ثم علَّق بقوله: «والذي يُقال في هذا: إن النمل كانت نسبتها من هذا الخلق نسبة هذا النمل منّا، فيحتمل أن كان الخلق كله أكمل». وعلَّق ابنُ كثير (١٠/٣٩٧) على قول نوف بقوله: «هكذا رأيته مضبوطًا بالياء المثناة من تحت، وإنما هو بالباء الموحدة، وذلك تصحيف». ٥٧٠٢٧- عن عامر الشعبي -من طُرُق- قال: النملة التي فَقِهَ سليمانُ كلامَها كانت مِن الطير ذات جناحين، ولولا ذلك لم يعرف سليمانُ ما تقول{11}. (١١/٣٤٥) ٥٧٠٢٨- قال الضَّحّاك بن مُزاحِم -من طريق أبي رَوْق-: كان اسم تلك النملة: طاحِية{12}. (ز) ٥٧٠٢٩- عن الحكم [بن عتيبة]، قال: كان النملُ في زمن سليمان أمثال الذباب{13}. (١١/٣٤٦) ٥٧٠٣٠- عن وهب بن مُنَبِّه، قال: أمر اللهُ الريحَ، قال: لا يتكلم أحدٌ مِن الخلائق بشيء في الأرض بينهم إلا حَمَلَتْه فوَضَعَتْه في أُذُنِ سليمان بن داود، فبذلك سَمِع كلامَ النملة{13}. (١١/٣٤٦) ٥٧٠٣١- عن قتادة بن دعامة -من طريق معمر- قال: النملة من الطير{15}. (١١/٣٤٥) ٥٧٠٣٢- عن أبي رَوْق عطية بن الحارث الهمداني-من طريق ابنه-: كان اسم نملة سليمان: حرمى{16}. (ز) ٥٧٠٣٣- قال مقاتل بن سليمان: <q>﴿قالت نملة﴾</q> واسمها: الجرمي: <q>﴿يا أيها النمل ادخلوا﴾</q> وهن خارجات، فقالت: ادخلوا <q>﴿مساكنكم﴾</q> يعني: بيوتكم{17}٤٨٥٢. (ز) ٤٨٥٢ ذكر ابنُ كثير (١٠/٣٩٧) أن الخلاف في تحديد الوادي ووصف النملة لا حاصل له. <q>﴿لَا یَحۡطِمَنَّكُمۡ سُلَیۡمَـٰنُ وَجُنُودُهُۥ وَهُمۡ لَا یَشۡعُرُونَ ۝١٨﴾</q> - تفسير ٥٧٠٣٤- قال مقاتل بن سليمان: <q>﴿لا يحطمنكم سليمان﴾</q> يعني: لا يهلكنكم سليمان <q>﴿وجنوده وهم لا يشعرون﴾</q> بهلاككم. فسمع سليمانُ قولَها مِن ثلاثة أميال، فانتهى إليها سليمانُ حين قالت: <q>﴿وهم لا يشعرون﴾</q>{17}. (ز) ٥٧٠٣٥- عن هارون الأعور -من طريق النَّضر- قال: وزعموا: أنّ الحَطْمَ الغَشَيانُ، حطمتهم الخيل أي: غشيتهم{19}. (ز) ٥٧٠٣٦- قال يحيى بن سلّام، في قوله: <q>﴿قالت نملة يأيها النمل ادخلوا مساكنكم لا يحطمنكم سليمان وجنوده﴾</q>: قال الله: <q>﴿وهم لا يشعرون﴾</q>، أي: والنمل لا يشعُرْنَ أنّ سليمان يفهم كلامَهم{20}. (ز) ",footnotes:1:تنانِير: جمع تَنّور: وهو الذي يُطبخ فيه. العين للخليل (تنر).جزائر: جمع جَزُور: وهو البعِير ذكرًا كان أو أنثى. النهاية (جزر).الذَّف: الإسراع. النهاية (ذفف).تفسير الثعلبي ٧/١٩٦، وتفسير البغوي ٦/١٥٠.أخرجه ابن عساكر في تاريخ دمشق ٢٢/٢٦٤-٢٦٦.أخرجه ابن أبي حاتم ٩/٢٨٥٧. وعلقه يحيى بن سلام ٢/٥٣٧.تفسير مقاتل بن سليمان ٣/٢٩٩. ومثله في تفسير الثعلبي ٧/١٩٧، وتفسير البغوي ٦/١٥٠ منسوبًا إلى مقاتل دون تعيينه.الكَوْسُ: المَشي على رِجْلٍ واحِدة، ومِن ذوات الأربع على ثلاث قوائم. لسان العرب (كوس).أخرجه ابن عساكر في تاريخ دمشق ٢٢/٢٦٤-٢٦٦.أخرجه البخاري في تاريخه ١/٦٠، وابن أبي حاتم ٩/٢٨٥٧. وأخرجه سفيان الثوري في تفسيره ص٢٣٢ بلفظ: كانت النملة مثل الذيب من العِظَم، وابن جرير ١٨/٢٨ بلفظ: الذئاب. وعزاه السيوطي إلى ابن أبي شيبة، وابن المنذر.أخرجه ابن أبي حاتم ٩/٢٨٥٧.أخرجه الثعلبي ٧/١٩٧، وينظر: تفسير البغوي ٦/١٥١.عزاه السيوطي إلى ابن المنذر.عزاه السيوطي إلى ابن المنذر.أخرجه عبد الرزاق ٢/٧٩، وابن أبي حاتم ٩/٢٨٥٥. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه الثعلبي ٧/١٩٧.تفسير مقاتل بن سليمان ٣/٢٩٩. وبعضه في تفسير الثعلبي ٧/١٩٧، وتفسير البغوي ٦/١٥١ منسوبًا إلى مقاتل دون تعيينه.تفسير مقاتل بن سليمان ٣/٢٩٩. وبعضه في تفسير الثعلبي ٧/١٩٧، وتفسير البغوي ٦/١٥١ منسوبًا إلى مقاتل دون تعيينه.أخرجه إسحاق البستي في تفسيره ص٩.تفسير يحيى بن سلام ٢/٥٣٧.
27,19," <q>﴿فَتَبَسَّمَ ضَاحِكࣰا مِّن قَوۡلِهَا﴾</q> - تفسير ٥٧٠٣٧- عن كعب الأحبار -من طريق وهب بن منبه- قال: ... <q>﴿فتبسم﴾</q> سليمانُ <q>﴿ضاحكا من قولها﴾</q>{1}. (ز) ٥٧٠٣٨- عن محمد بن سيرين -من طريق الحكم بن عطية- أنّه سُئِل عن التَّبَسُّم في الصلاة. فقرأ هذه الآية: <q>﴿فتبسم ضاحكا من قولها﴾</q>، وقال: لا أعلم التَّبَسُّم إلا ضحِكًا{2}. (١١/٣٤٦) ٥٧٠٣٩- قال مقاتل بن سليمان: <q>﴿فتبسم ضاحكا من قولها﴾</q> ضحك مِن ثنائها على سليمان بعدله في ملكه؛ أنّه لو يشعر بكم لم يحطمكم، يعني بالضحك: الكشر، وقال سليمان: لقد علمت النملُ أنّه مُلك لا بَغْيٌ فيه ولا فَخْر، ولئن عَلِم بنا قبل أن يغشانا لم نُوطَأ{3}. (ز) ٥٧٠٤٠- قال مقاتل: كان ضحِكُ سليمان مِن قول النملة تعجُّبًا؛ لأنّ الإنسان إذا رأى ما لا عهد له به تعجب وضحك{4}. (ز) ٥٧٠٤١- قال يحيى بن سلّام: <q>﴿فتبسم﴾</q> سليمان <q>﴿ضاحكا من قولها﴾</q>{5}. (ز) <q>﴿وَقَالَ رَبِّ أَوۡزِعۡنِیۤ﴾</q> - تفسير ٥٧٠٤٢- عن عبد الله بن عباس -من طريق علي- في قوله: <q>﴿أوْزِعْنِي﴾</q>، يقول: اجعلني{6}. (ز) ٥٧٠٤٣- عن كعب الأحبار -من طريق وهب بن منبه- قال: <q>﴿وقال رب أوزعني﴾</q>، يعني: ألْهِمْنِي{1}. (ز) ٥٧٠٤٤- عن الحسن البصري، قال: <q>﴿أوزعني﴾</q>، قال: ألهمني{8}. (١١/٣٤٦) ٥٧٠٤٥- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿أوزعني﴾</q>، قال: ألهمني{9}. (١١/٣٤٦) ٥٧٠٤٦- عن إسماعيل السُّدِّيّ، مثل ذلك{10}. (ز) ٥٧٠٤٧- قال مقاتل بن سليمان: ثم وقف سليمان بمن معه مِن الجنود ليدخل النملُ مساكنهم، ثم حمد ربَّه ﷿ حين علَّمه منطقَ كلِّ شيء، فسمع كلام النملة، <q>﴿وقال رب أوزعني﴾</q> يعني: ألْهِمْني{11}. (ز) ٥٧٠٤٨- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قول الله: <q>﴿رب أوزعني أن أشكر نعمتك التي أنعمت علي﴾</q>، قال: في كلام العرب تقول: أوزع فلانٌ بفلان، يقول: حرَّضه عليه. وقال ابن زيد: <q>﴿أوزعني﴾</q>: ألْهِمني وحرِّضني على أن أشكر نعمتك التي أنعمت عَلَيَّ، وعلى والِدَيَّ{12}. (ز) ٥٧٠٤٩- قال يحيى بن سلّام: <q>﴿وقال رب أوزعني﴾</q>، يقول: ألْهِمني{5}. (ز) <q>﴿أَنۡ أَشۡكُرَ نِعۡمَتَكَ ٱلَّتِیۤ أَنۡعَمۡتَ عَلَیَّ وَعَلَىٰ وَ ٰ⁠لِدَیَّ وَأَنۡ أَعۡمَلَ صَـٰلِحࣰا تَرۡضَىٰهُ﴾</q> - تفسير ٥٧٠٥٠- قال عبد الله بن عباس: يريد: مع إبراهيم، وإسماعيل، وإسحاق، ويعقوب، ومَن بعدهم مِن النبيين{4}. (ز) ٥٧٠٥١- عن كعب الأحبار -من طريق وهب بن منبه- قال: <q>﴿أن أشكر نعمتك﴾</q> يعني: أن أُؤَدِّي شكرَ ما أنعمت <q>﴿علي وعلى والديَّ وأن أعمل صالحا ترضاه﴾</q>{1}. (ز) ٥٧٠٥٢- قال مقاتل بن سليمان: <q>﴿أن أشكر نعمتك التي أنعمت عليَّ وعلى والديَّ﴾</q> مِن قبلي، يعني: أبويه: داود، وأمه بتشايع بنت الياثن، <q>﴿و﴾</q> ألهمني <q>﴿أنْ أعمل صالحًا ترضاه﴾</q>{11}. (ز) <q>﴿أَنۡ أَشۡكُرَ نِعۡمَتَكَ ٱلَّتِیۤ أَنۡعَمۡتَ عَلَیَّ وَعَلَىٰ وَ ٰ⁠لِدَیَّ وَأَنۡ أَعۡمَلَ صَـٰلِحࣰا تَرۡضَىٰهُ﴾</q> - آثار متعلقة بالآية ٥٧٠٥٣- قال سفيان بن عيينة -من طريق ابن أبي عمر-: لو أنّ سليمان بن داود لم يقبله بالذي ينبغي لَساخَت به الأرضُ خمسمائة قامَةٍ حين قالت النملة: <q>﴿قالَتْ نَمْلَةٌ يا أيُّها النَّمْلُ ادْخُلُوا مَساكِنَكُمْ﴾</q>. قال: <q>﴿فتبسم ضاحكا من قولها وقالَ رَبِّ أوْزِعْنِي أنْ أشْكُرَ نِعْمَتَكَ الَّتِي أنْعَمْتَ﴾</q> الآية. فقال له رجلٌ حرّاث مِن الحرّاثين: لأنا بقدري أشكر لله منك. قال: فخرَّ عن فرسه ساجدًا. وقال: لولا أن يكون- قال ابن أبي عمر: ثم تكلم سفيان بكلمة لم أفهمها- لقلت: انزع مِنِّي ما أعطيتني. قال: وكان يشغله ذِكْرُ الله عن أن يتكلم{17}. (ز) <q>﴿وَأَدۡخِلۡنِی بِرَحۡمَتِكَ فِی عِبَادِكَ ٱلصَّـٰلِحِینَ ۝١٩﴾</q> - تفسير ٥٧٠٥٤- عن كَعْب الأحبار -من طريق وهْب بن مُنَبِّه- قال: <q>﴿وأدخلني برحمتك في عبادك الصالحين﴾</q>، يعني: مع الصالحين{1}. (ز) ٥٧٠٥٥- تفسير إسماعيل السُّدِّيّ: <q>﴿الصالحين﴾</q>، يعني: المؤمنين{19}. (ز) ٥٧٠٥٦- قال مقاتل بن سليمان: <q>﴿وأدخلني برحمتك﴾</q> يعني: بنعمتك <q>﴿في﴾</q> يعني: مع <q>﴿عبادك الصالحين﴾</q> الجنة{11}. (ز) ٥٧٠٥٧- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿وأدخلني برحمتك في عبادك الصالحين﴾</q>، قال: مع عبادك الصالحين؛ الأنبياء والمؤمنين{21}. (١١/٣٤٦) ٥٧٠٥٨- قال يحيى بن سلّام: <q>﴿وأدخلني برحمتك في عبادك الصالحين﴾</q> يعني: مع عبادك <q>﴿الصالحين﴾</q> يعني: المؤمنين، وهم أهل الجنة{5}. (ز) ",footnotes:1:أخرجه ابن عساكر في تاريخ دمشق ٢٢/٢٦٤-٢٦٦.أخرجه ابن أبي شيبة ١/٣٨٧، وابن أبي حاتم ٩/٢٨٥٨.تفسير مقاتل بن سليمان ٣/٣٠٠، وذكر محققه أنه كذا جاء في بعض النسخ.تفسير البغوي ٦/١٥٢.تفسير يحيى بن سلام ٢/٥٣٧.أخرجه ابن جرير ١٨/٢٨، وابن أبي حاتم ٩/٢٨٥٨. وعلَّقه البخاري ٤/١٧٨٨. وينظر: تغليق التعليق ٤/٢٧٦.أخرجه ابن عساكر في تاريخ دمشق ٢٢/٢٦٤-٢٦٦.عزاه السيوطي إلى عبد بن حميد.أخرجه ابن أبي حاتم ٩/٢٨٥٨. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.علَّقه ابن أبي حاتم ٩/٢٨٥٨.تفسير مقاتل بن سليمان ٣/٣٠٠.أخرجه ابن جرير ١٨/٢٨، وابن أبي حاتم ٩/٢٨٥٨ من طريق أصبغ.تفسير يحيى بن سلام ٢/٥٣٧.تفسير البغوي ٦/١٥٢.أخرجه ابن عساكر في تاريخ دمشق ٢٢/٢٦٤-٢٦٦.تفسير مقاتل بن سليمان ٣/٣٠٠.أخرجه إسحاق البستي في تفسيره ص٩-١٠ دون آخره، وابن أبي حاتم ٩/٢٨٥٩.أخرجه ابن عساكر في تاريخ دمشق ٢٢/٢٦٤-٢٦٦.علقه يحيى بن سلام ٢/٥٣٧.تفسير مقاتل بن سليمان ٣/٣٠٠.أخرجه ابن جرير ١٨/٢٩، وابن أبي حاتم ٩/٢٨٥٩ من طريق أصبغ.تفسير يحيى بن سلام ٢/٥٣٧.
27,20," <q>﴿وَتَفَقَّدَ ٱلطَّیۡرَ فَقَالَ مَا لِیَ لَاۤ أَرَى ٱلۡهُدۡهُدَ﴾</q> - تفسير ٥٧٠٥٩- عن أبي مجلز، قال: جلس ابنُ عباس إلى عبد الله بن سلام، فسأله عن الهدهد: لِمَ تفقَّده سليمان مِن بين الطير؟ فقال عبد الله بن سلام: إنّ سليمان نزل منزلة في مسير له، فلم يَدْرِ ما بُعْدُ الماء، فقال: مَن يعلمُ بُعْدَ الماء؟ قالوا: الهدهد. فذاك حين تفقَّده{1}. (ز) ٥٧٠٦٠- عن عبد الله بن عباس -من طرق- أنّه سُئِل: كيف تَفَقَّد سليمانُ الهدهدَ من بين الطير؟ قال: إنّ سليمان نزل منزلًا، فلم يدر ما بُعْدُ الماء، وكان الهدهد يدل سليمان على الماء -وفي رواية عكرمة عند ابن أبي حاتم: وكان الهدهد مهندسًا{2}-، فأراد أن يسأله عنه، ففقده. قيل: كيف ذاك والهدهد ينصب له الفخ يلقي عليه التراب، ويضع له الصبي الحبالة فيغيبها فيصيده؟ فقال: إذا جاء القضاء ذهب البصر{3}. (١١/٣٤٧) ٥٧٠٦١- عن يوسف بن ماهَك، أنّه حدثهم: أن نافع بن الأزرق صاحب الأزارِقة كان يأتي عبد الله بن عباس، فإذا أفتى ابنُ عباس يرى هو أنّه ليس بمستقيم، يقول له: قِف، مِن أين أفتيت بكذا وكذا، ومِن أين كان؟ فيقول ابن عباس: أومأت مِن كذا وكذا. حتى ذكر يومًا الهدهد، فقال: يعرف بعد مسافة الماء في الأرض. فقال له ابن الأزرق: قِف قف، يا ابن العباس، كيف تزعم أنّ الهدهد يرى مسافة الماء من تحت الأرض، وهو يُنصَب له الفخ، فيذر عليه التراب، فيصطاد؟ فقال ابن عباس: لولا أن يذهب هذا فيقول: كذا وكذا؛ لم أقل له شيئًا، إنّ البصر ينفع ما لم يأت القدر، فإذا جاء القدر حال دون البصر. فقال ابن الأزرق: لا أُجادِلُك بعدها في شيء{4}. (١١/٣٤٨) ٥٧٠٦٢- عن عبد الله بن شداد بن الهاد -من طريق حصين - قال: كان سليمان بن داود إذا أراد أن يسير وضع كرسيه، ويأتي مَن أراد مِن الجن والإنس، ثم يأمر الريح، فتحملهم، ثم يأمر الطير، فأظلَّتْهم، قال: وبينا هو يسير إذ عطشوا، فقال: ما ترون بُعْدَ الماء؟ قالوا: لا ندري. فتفقد الهدهد، وكان له منه منزلة وليس بها طير غيره، <q>﴿فقال مالي لا أرى الهدهد أم كان من الغائبين﴾</q>{5}. (١١/٣٨٣) ٥٧٠٦٣- عن عبد الله بن شداد بن الهاد -من طريق عبد الله بن حبيب السلمي- قال: إنّ الهدهد كان إذا سافر سليمان خرج به معه، كان يدله على الماء، ينظر إلى الماء كما ينظر بعضنا إلى بعض، وإنه فَقَدَه؛ فقال ما قال{5}. (ز) ٥٧٠٦٤- عن سعيد بن جبير -من طريق عطاء بن السائب، وكلثوم بن جبر- قال: كان سليمان إذا أراد أن ينزل منزلًا دعا الهدهدَ ليخبره عن الماء، فكان إذا قال: ههنا. شَقَّقَتِ الشياطينُ الصخور، وفجرت العيون من قبل أن يضربوا أبنيتهم، فأراد أن ينزل منزلًا، فتفقد الهدهد فلم يره، فقال: <q>﴿ما لي لا أرى الهدهد أم كان من الغائبين﴾</q>{5}. (١١/٣٤٨) ٥٧٠٦٥- عن وهب بن مُنَبِّه -من طريق ابن إسحاق، عن بعض أهل العلم- قال: كان سليمان بن داود إذا خرج من بيته إلى مجلسه عَكَفَتْ عليه الطير، وقام له الجنُّ والإنسُ حتى يجلس على سريره، حتى إذا كان ذات غداة في بعض زمانه غدا إلى مجلسه الذي كان يجلس فيه، فتفقد الطير. وكان فيما يزعمون: يأتيه نوبًا، من كل صنف من الطير طائر، فنظر، فرأى مِن أصناف الطير كلها قد حضره إلا الهدهد، فقال: ما لي لا أرى الهدهد؟{8}. (ز) ٥٧٠٦٦- عن قتادة بن دعامة -من طريق سعيد بن عروبة- في الآية، قال: ذُكِر لنا: أنّ سليمان أراد أن يأخذ مفازةً، فدعا بالهدهد -وكان سيِّد الهداهِد- ليعلم مسافة الماء، وكان قد أُعْطِي مِن البصر بذلك شيئًا لم يُعْطَه شيءٌ مِن الطير. لقد ذُكِر لنا: أنّه كان يُبصِر الماءَ في الأرض، كما يُبصِر أحدُكم الخيالَ مِن وراء الزجاجة{9}. (١١/٣٤٩) ٥٧٠٦٧- قال محمد بن السائب الكلبي: كان يَدُلُّه على الماء إذا نزل الناس، وكان ينقر بمنقاره في الأرض، فيخبر سليمانَ كم بينه وبين الماء مِن قامة{10}. (ز) ٥٧٠٦٨- قال مقاتل بن سليمان: <q>﴿وتفقد الطير﴾</q> يعني: الهدهد، حين سار من بيت المقدس قِبَل اليمن، فلما مرَّ بالمدينة وقف، فقال: إنّ الله ﷿ سيبعث مِن هاهنا نبيًّا، طوبى لِمَن تبعه. فلما أراد أن ينزل <q>﴿فقال ما لي لا أرى الهدهد أم﴾</q> -والميم ها هنا صلة، كقوله تعالى: <q>﴿أم عندهم﴾</q> يعني: أعندهم <q>﴿الغيب فهم يكتبون﴾</q> [الطور:٤١، القلم:٤٧]- <q>﴿كان من الغائبين﴾</q>{11}. (ز) ٥٧٠٦٩- قال سفيان بن عيينة -من طريق ابن أبي عمر-: كان سليمانُ إذا جلس صَفَّت الطيرُ على رأسه تُظِلُّه مِن الشمس، وكان الهدهدُ فوقَها، كان يسير هذا المكان منه -يعني: المنكب الأيمن-، فوجد حرَّ الشمس قد دخلت عليه مِن ذلك الموضع، فرفع رأسَه، فتفقد الهدهد، فسأل عنه: <q>﴿فقال ما لي لا أرى الهدهد أم كان من الغائبين﴾</q>{12}. (ز) ٥٧٠٧٠- قال عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب-: أول ما فقد سليمانُ الهدهدَ نزل بِوادٍ، فسأل الإنسَ عن مائه، فقالوا: ما نعلم له ماء، فإن يكن أحدٌ مِن جنودك يعلم له ماء فالجن. فدعا الجنَّ، فسألهم، فقالوا: ما نعلم له ماء، وإن يكن أحدٌ مِن جنودك يعلم له ماء فالطير. فدعا الطير، فسألهم، فقالوا: ما نعلم له ماء، وإن يكن أحد مِن جنودك يعلمه فالهدهد. فلم يجده. قال: فذاك أول ما فقد الهدهد{13}٤٨٥٣. (ز) ٤٨٥٣ اختُلِف في سبب تفقد سليمان للهدهد وسؤاله عنه؛ فقال قوم: تفقده ليستخبره عن بُعد الماء في الوادي الذي نزل به في مسيره. وقال آخرون: لإخلاله بالنوبة التي كان ينوبها. وقال غيرهم: إنما طلبه لأن الطَّير كانت تُظِلُّهم من الشمس، فأخلَّ الهدهد بمكانه، فطلعت الشمس عليهم من الخلل. وذكر ابنُ جرير (١٨/٣٢) القولين الأولين، ورجح اندراجهما في العموم دون القطع بأحدهما؛ لعدم وجود الدليل القاطع، فقال: «والله أعلم بأي ذلك كان؛ إذ لم يأتنا بأي ذلك كان تنزيل، ولا خبر عن رسول الله ﷺ؛ فالصواب من القول في ذلك أن يُقال: إنّ الله أخبر عن سليمان أنه تفقد الطير؛ إمّا للنوبة التي كانت عليها وأخلت بها، وإما لحاجة كانت إليها عن بعد الماء». وذكر ابنُ عطية (٦/٥٢٨) في الآية أقوالًا أخرى، منها قوله: «قالت فرقة: ذلك بحسب ما تقتضيه العناية بأمور الملك والتهمم بكل جزء منها». ثم علَّق بقوله: «وظاهر الآية أنه تفقد جميع الطير». ٥٧٠٧١- قال يحيى بن سلّام: قوله ﷿: <q>﴿وتفقد الطير فقال ما لي لا أرى الهدهد أم كان من الغائبين﴾</q> أم هو غائب{14}. (ز) <q>﴿وَتَفَقَّدَ ٱلطَّیۡرَ فَقَالَ مَا لِیَ لَاۤ أَرَى ٱلۡهُدۡهُدَ﴾</q> - آثار متعلقة بالآية ٥٧٠٧٢- عن ابن عباس، قال: نهى رسولُ الله ﷺ عن قتل أربعةٍ مِن الدوابِّ: النملة، والنحلة، والهدهد، والصرد{15}. (ز) ٥٧٠٧٣- عن أنس بن مالك، قال: قال رسول الله ﷺ: «أنهاكم عن قتل الهدهد؛ فإنّه كان دليلَ سليمان على قُرْب الماء من بُعْده، وأحبَّ أن يُعبَد الله في الأرض حيث يقول: <q>﴿وجئتك من سبأ بنبأ يقين إني وجدت امرأة﴾</q>»{16}. (ز) ٥٧٠٧٤- عن الحسن البصري -من طريق عباد بن ميسرة المنقري- قال: اسم هدهد سليمان: عنبر{17}. (١١/٣٤٩) <q>﴿مَا لِیَ لَاۤ أَرَى ٱلۡهُدۡهُدَ أَمۡ كَانَ مِنَ ٱلۡغَاۤىِٕبِینَ ۝٢٠﴾</q> - تفسير ٥٧٠٧٥- عن وهب بن مُنَبِّه -من طريق ابن إسحاق، عن بعض أهل العلم- <q>﴿مالي لا أرى الهدهد أم كان من الغائبين﴾</q>: أخطأه بصري في الطير، أم غاب فلم يحضر؟{18}. (ز) ",footnotes:1:أخرجه ابن أبي شيبة ١١/٥٦٦، وابن جرير ١٨/٣٠.المُهَندِس: المُقَدِّر لِمَجاري المياه واحتِفارِها حيث تُحْفَرُ، وهو مشتق من الهِنْدازِ، وهي فارسية. اللسان (هندس).أخرجه ابن جرير ١٨/٣٠ من طريق سعيد بن جبير بنحوه مطولًا، وابن أبي حاتم ٩/٢٨٥٩ من طريق سعيد وعكرمة ومجاهد، والحاكم ٢/٤٠٥ من طريق سعيد بن جبير. وعزاه السيوطي إلى ابن أبي شيبة، وعبد بن حميد، وابن المنذر.أخرجه يحيى بن سلام ٢/٥٣٨ بنحوه، وابن جرير ١٨/٣٠ من طريق سعيد بنحوه، وابن أبي حاتم ٩/٢٨٥٩-٢٨٦٠. وعزاه السيوطي إلى سعيد بن منصور.أخرجه ابن أبي حاتم ٩/٢٨٦٠.أخرجه ابن أبي حاتم ٩/٢٨٦٠.أخرجه ابن أبي حاتم ٩/٢٨٦٠.أخرجه ابن جرير ١٨/٣١، وابن أبي حاتم ٩/٢٨٦٢ موقوفًا على ابن إسحاق من قوله.أخرجه يحيى بن سلام ٢/٥٣٧ مختصرًا، وابن أبي حاتم ٩/٢٨٦١، وأخرجه بنحوه من طريق سعيد بن بشير، وفي أوله: ذُكِر لنا: أنه كان قد أعطي من علمه شيئًا لم يعطه شيء من الطير، يعلم قدر مسافة الماء. وعزاه السيوطي إلى عبد بن حميد.علَّقه يحيى بن سلام ٢/٥٣٨.تفسير مقاتل بن سليمان ٣/٣٠٠.أخرجه إسحاق البستي في تفسيره ص١٠، وابن أبي حاتم ٩/٢٨٦١.أخرجه ابن جرير ١٨/٣١.تفسير يحيى بن سلام ٢/٥٣٧.أخرجه أحمد ٥/١٩٢ (٣٠٦٦)، ٥/٢٩٤-٢٩٥ (٣٢٤٢)، وأبو داود ٧/٥٣٩ (٥٢٦٧)، وابن ماجه ٤/٣٧٧ (٣٢٢٤)، وابن حبان ١٢/٤٦٢ (٥٦٤٦)، والثعلبي ٧/١٩٨. قال أبو حاتم كما في عِلَل الحديث لابنه ٦/١٢٣-١٢٤ (٢٣٧٤): «هذا حديث مضطرب». وقال البيهقي في السنن الكبرى ٩/٥٣٣: «... أقوى ما ورد في هذا الباب». وقال النووي في شرح مسلم ١٤/٢٣٩: «رواه أبو داود بإسناد صحيح على شرط البخاري ومسلم». وقال ابن دقيق العيد في الإلمام في أحاديث الأحكام ٢/٤٤٤: «أخرجه أبو داود عن رجال الصحيح». وقال ابن الملقن في البدر المنير ٦/٣٤٥: «إسناده صحيح». وقال الألباني في الإرواء ٨/١٤٢ (٢٤٩٠): «وهذا إسناد صحيح على شرط الشيخين».أورده الثعلبي في تفسيره ٧/١٩٩.أخرجه ابن أبي حاتم ٩/٢٨٦١.أخرجه ابن جرير ١٨/٣٢، وابن أبي حاتم ٩/٢٨٦٢ موقوفًا على ابن إسحاق من قوله.
27,21," <q>﴿لَأُعَذِّبَنَّهُۥ عَذَابࣰا شَدِیدًا أَوۡ لَأَا۟ذۡبَحَنَّهُۥۤ﴾</q> - تفسير ٥٧٠٧٦- عن عبد الله بن عباس -من طريق سعيد بن جبير- في قوله: <q>﴿لأعذبنه عذابا شديدا﴾</q>، قال: نَتْف رِيشه{1}. (١١/٣٤٩) ٥٧٠٧٧- عن عبد الله بن عباس -من طريق مجاهد- في: <q>﴿لأعذبنه عذابا شديدا﴾</q>: عذابه: نَتْفُه، وتَشْمِيسُه{2}. (ز) ٥٧٠٧٨- عن عبد الله بن شداد بن الهاد -من طريق حصين- قال: نَتْفُه وتشميسه، <q>﴿أو لأذبحنه﴾</q> يقول: أو لأقتلنه{3}. (١١/٣٨٣) ٥٧٠٧٩- عن مجاهد بن جبر -من طريق ابن أبي نجيح- <q>﴿لأعذبنه عذابا شديدا﴾</q>، قال: نَتْف ريشه كله{4}. (١١/٣٤٩) ٥٧٠٨٠- عن الضحاك بن مزاحم -من طريق عبيد- في قوله: <q>﴿لأعذبنه عذابا شديدا﴾</q> يقول: أنتِفُ ريشَه، <q>﴿أو لأذبحنه﴾</q> يقول: لأقتلنه{5}. (ز) ٥٧٠٨١- عن عكرمة مولى ابن عباس، قال: نَتْف ريشه، وإلقاؤه للنمل في الشمس{6}. (١١/٣٥٠) ٥٧٠٨٢- عن قتادة بن دعامة -من طريق مَعْمَر- يقول: نتف ريشه{7}. (١١/٣٤٩) ٥٧٠٨٣- عن يزيد بن رومان -من طريق ابن إسحاق- قال: إنّ عذابه الذي كان يعذب به الطير: نتف ريش جناحه{8}. (١١/٣٥٠) ٥٧٠٨٤- قال مقاتل بن سليمان: <q>﴿لأعذبنه عذابا شديدا﴾</q> يعني: لأنتِفَنَّ ريشَه، فلا يطير مع الطير حولًا، <q>﴿أو لأذبحنه﴾</q> يعني: لأقتلنه{9}. (ز) ٥٧٠٨٥- قال مقاتل بن حيان: لأطْلِيَنَّه بالقَطِران، ولَأُشَمِّسَنَّه{10}. (ز) ٥٧٠٨٦- قال عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب-: قيل لبعض أهل العلم: هذا الذبحُ، فما العذابُ الشديد؟ قال: ينتف ريشه، يتركه بِضْعَةً تَنزو{11}{12}. (ز) ٥٧٠٨٧- عن أبي الأسمر -من طريق خلف بن خليفة- <q>﴿لأعذبنه عذابا شديدا﴾</q>، قال: أن ينتف ريشه، ويضربه بسوط{13}. (ز) <q>﴿أَوۡ لَیَأۡتِیَنِّی بِسُلۡطَـٰنࣲ مُّبِینࣲ ۝٢١﴾</q> - تفسير ٥٧٠٨٨- عن عبد الله بن عباس -من طريق عكرمة- قال: كلُّ سلطان في القرآن: حُجَّة. ونزع الآية التي في سورة «سليمان»: <q>﴿أو ليأتيني بسلطان﴾</q>. قال: وأي سلطان كان للهدهد؟!{14}. (١١/٣٥٠) ٥٧٠٨٩- عن عبد الله بن عباس -من طريق سعيد بن جبير- في قوله: <q>﴿أو ليأتيني بسلطان مبين﴾</q>، قال: خبر الحق الصدق البَيِّن{15}. (١١/٣٥٠) ٥٧٠٩٠- عن عبد الله بن عباس -من طريق العوفي- قوله: <q>﴿أو ليأتيني بسلطان مبين﴾</q>، يقول: ببينة أعذره بها، وهو مثل قوله: <q>﴿الذين يجادلون في آيات الله بغير سلطان﴾</q> [غافر:٣٥]، يقول: بغير بينة{16}. (ز) ٥٧٠٩١- عن عبد الله بن شداد بن الهاد -من طريق حصين- <q>﴿أو ليأتيني بسلطان مبين﴾</q>: يعني: بعُذْر بيِّن. فلما جاء الهدهد استقبلته الطير، [فأخبرته]، فقال: ألم يستثن؟ فقالوا: نعم، قد قال: إلا أن يجيء بعذر بيِّن. فجاءه بالعذر الذي في القرآن{17}. (١١/٣٨٣) ٥٧٠٩٢- عن الضحاك بن مزاحم -من طريق عبيد- في قوله: <q>﴿أو ليأتيني بسلطان مبين﴾</q>، قال: ببينة، وهو قول الله: <q>﴿الذين يجادلون في آيات الله بغير سلطان﴾</q> [غافر:٣٥] بغير بينة{18}. (ز) ٥٧٠٩٣- عن عكرمة مولى ابن عباس -من طريق سفيان، عن رجل- قال: كل شيء في القرآن سلطان: فهو حجة{19}. (ز) ٥٧٠٩٤- عن الحسن البصري -من طريق يونس- <q>﴿أو ليأتيني بسلطان مبين﴾</q>: بعذر بيِّن أعذره به، يقول: <q>﴿فمكث غير بعيد﴾</q>{20}. (ز) ٥٧٠٩٥- عن وهب بن مُنَبِّه -من طريق ابن إسحاق، عن بعض أهل العلم- <q>﴿أو ليأتيني بسلطان مبين﴾</q>: أي: بحُجَّة؛ عذر له في غيبته{19}. (ز) ٥٧٠٩٦- عن قتادة بن دعامة -من طريق معمر- في قوله: <q>﴿أو ليأتيني بسلطان مبين﴾</q>، قال: بعذر بَيِّن{22}. (١١/٣٥٠) ٥٧٠٩٧- قال إسماعيل السُّدِّيّ: بحجة بيِّنة أعذره بها{23}. (ز) ٥٧٠٩٨- قال مقاتل بن سليمان: <q>﴿أو ليأتيني بسلطان مبين﴾</q>، يعني: حجة بينة أعذره بها{9}. (ز) ٥٧٠٩٩- قال عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿أو ليأتيني بسلطان مبين﴾</q>، قال: بعذر أعذره فيه{19}. (ز) ٥٧١٠٠- قال سفيان بن عيينة -من طريق ابن أبي عمر-: وتفقد سليمان الهدهد، فقال: أين هو؟ <q>﴿لأعذبنه عذابا شديدا أو لأذبحنه﴾</q> الآية. فلما جاء الهدهد قيل له: ويحك، ماذا قال فيك نبيُّ الله ﵇؟! قال: فما قال؟ قالوا: قال: <q>﴿لأعذبنه عذابا شديدا﴾</q>. قال: فهل استثنى؟ قالوا: نعم، <q>﴿أو ليأتيني بسلطان مبين﴾</q>. قال: فقد نجوتُ إذًا{26}. (ز) <q>﴿أَوۡ لَیَأۡتِیَنِّی بِسُلۡطَـٰنࣲ مُّبِینࣲ ۝٢١﴾</q> - آثار متعلقة بالآية ٥٧١٠١- عن مجاهد بن جبر -من طريق ليث- في الآية، قال: إنّما دفع الله عن الهدهد ببِرِّه والدته{27}. (١١/٣٥٠) ٥٧١٠٢- عن عكرمة مولى ابن عباس -من طريق الزبير بن خريت- قال: إنّما صرف الله عذاب سليمان عن الهدهد لأنّه كان بارًّا بوالديه{28}. (١١/٣٥١) ",footnotes:1:أخرجه ابن جرير ١٨/٣٣، وابن أبي حاتم ٩/٢٨٦٢، والحاكم ٢/٤٠٥. وأخرجه عبد الرزاق ٢/٨٠ من طريق عمرو بن دينار، وكذلك إسحاق البستي في تفسيره ص١١. وعزاه السيوطي إلى الفريابي، وسعيد بن منصور، وعبد بن حميد، وابن المنذر.أخرجه ابن جرير ١٨/٣٣.أخرجه ابن جرير ١٨/٣٤، وابن أبي حاتم ٩/٢٨٦٢، وأخرج شطره الأول عبد الرزاق ٢/٨٠، وإسحاق البستي في تفسيره ص١١، وقال: وزاد داود الطائي: وأطرحه للنمل فيأكله.أخرجه ابن جرير ١٨/٣٣. وعزاه السيوطي إلى الفريابي، وعبد بن حميد. وأخرجه ابن جرير ١٨/٣٣ من طريق ابن جريج، وزاد: فلا يعفو سنة، أي: لا ينمو ويكثر.أخرجه ابن جرير ١٨/٣٤-٣٥، وإسحاق البستي في تفسيره ص١٣، وابن أبي حاتم ٩/٢٨٦٣.عزاه السيوطي إلى ابن أبي شيبة، وعبد بن حميد، وابن المنذر.أخرجه عبد الرزاق ٢/٧٩، وابن جرير ١٨/٣٤، وابن أبي حاتم ٩/٢٨٦٢ من طريق سعيد، ولفظه: كنا نحدث: أنّ عذابه ذلك نتف ريشه، فيذره في المنزل حتى تأكله الذر والنمل. وعلقه يحيى بن سلام ٢/٥٣٨ بنحو لفظ ابن أبي حاتم. وعزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ١٨/٣٤، وابن أبي حاتم ٩/٢٨٦٢.تفسير مقاتل بن سليمان ٣/٣٠٠.تفسير الثعلبي ٧/١٩٨، وتفسير البغوي ٦/١٥٣.بضعة تنزو: قطعة لحم تقفز لا يستطيع الطيران. النهاية (نزا).أخرجه ابن جرير ١٨/٣٤.علقه ابن أبي حاتم ٩/٢٨٦٢. وكذا جاء فيه عن أبي الأسمر، ولم يتبين لنا من هو، ولم نجد في شيوخ خلف بن خليفة من يعرف بذلك؛ فلعل ما وقع في مطبوعة تفسير ابن أبي حاتم تحريف.عزاه السيوطي إلى عبد بن حميد. وأخرجه يحيى بن سلام ٢/٥٣٨ بمعناه، وابن جرير ١٨/٣٥-٣٦ من طريق سعيد وعكرمة، وإسحاق البستي في تفسيره ص١٣ مختصرًا، وابن أبي حاتم ٩/٢٨٦٣. وليس فيها قوله: سورة سليمان.أخرجه ابن أبي حاتم ٩/٢٨٦٣. وعزاه السيوطي إلى ابن أبي شيبة، وابن المنذر.أخرجه ابن جرير ١٨/٣٥.أخرجه ابن جرير ١٨/٣٥ إلى قوله: ألم يستثن؟، وابن أبي حاتم ٩/٢٨٦٣ إلا قوله: ألم يستثن؟.أخرجه ابن جرير ١٨/٣٦، وإسحاق البستي في تفسيره ص١٣.أخرجه ابن جرير ١٨/٣٦.أخرجه ابن أبي حاتم ٩/٢٨٦٣.أخرجه ابن جرير ١٨/٣٦.أخرجه عبد الرزاق ٢/٨٠، وابن جرير ١٨/٣٦. وعلقه يحيى بن سلام ٢/٥٣٨. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.علقه يحيى بن سلام ٢/٥٣٩.تفسير مقاتل بن سليمان ٣/٣٠٠.أخرجه ابن جرير ١٨/٣٦.أخرجه إسحاق البستي في تفسيره ص١٢، وابن أبي حاتم ٩/٢٨٦٣.أخرجه ابن أبي حاتم ٩/٢٨٦٢.أخرجه أبو الشيخ في العظمة (١٢٨٧). وعزاه السيوطي إلى الحكيم الترمذي.
27,22," <q>﴿فَمَكَثَ غَیۡرَ بَعِیدࣲ فَقَالَ أَحَطتُ بِمَا لَمۡ تُحِطۡ بِهِۦ﴾</q> - قراءات ٥٧١٠٣- عن الأعمش: قراءة عبد الله [بن مسعود]: (فَيَمْكُثُ غَيْرَ بَعِيدٍ){1}. (ز) <q>﴿فَمَكَثَ غَیۡرَ بَعِیدࣲ﴾</q> - تفسير ٥٧١٠٤- قال مقاتل بن سليمان: <q>﴿فمكث غير بعيد﴾</q> يقول: لم يلبث إلا قليلًا حتى جاء الهدهدُ، فوقع بين يدي سليمان ﵇، فجعل ينكث بمنقاره، ويُومِئ برأسه إلى سليمان، فقال لسليمان: <q>﴿أحطت بما لم تحط به﴾</q>{2}. (ز) ٥٧١٠٥- قال يحيى بن سلّام: قوله ﷿: <q>﴿فمكث غير بعيد﴾</q> رجع مِن ساعته{3}. (ز) <q>﴿فَقَالَ أَحَطتُ بِمَا لَمۡ تُحِطۡ بِهِۦ﴾</q> - تفسير ٥٧١٠٦- عن عبد الله بن عباس -من طريق مجاهد- في قوله: <q>﴿أحطت بما لم تحط به﴾</q>، قال: اطَّلَعتُ على ما لم تَطَّلِع عليه{4}. (١١/٣٥١) ٥٧١٠٧- عن وهب بن مُنَبِّه -من طريق ابن إسحاق، عن بعض أهل العلم- <q>﴿فمكث غير بعيد﴾</q>: ثم جاء الهدهد، فقال له سليمان: ما خلَّفك عن نوبتك؟ قال: أحطت بما لم تحط به{5}. (ز) ٥٧١٠٨- قال الحسن البصري: علمت ما لم تعلم{6}. (ز) ٥٧١٠٩- عن قتادة بن دعامة -من طريق سعيد- قوله: <q>﴿أحطت بما لم تحط به﴾</q>، أي: بلغت ما لم تبلغ أنت ولا جنودك{7}. (ز) ٥٧١١٠- قال مقاتل بن سليمان: <q>﴿أحطت بما لم تحط به﴾</q>، يقول: علِمتُ ما لم تعلم به، وجئتك بأمر لم تخبرك به الجن، ولم تنصحك فيه، ولم يعلم به الإنس، وبلغتُ ما لم تبلغه أنت ولا جنودك{2}. (ز) ٥٧١١١- عن سفيان [الثوري] -من طريق مهران- <q>﴿أحطت بما لم تحط به﴾</q>، يقول: علمتُ ما لم تُحِط به، وما لم تعلم به{4}. (ز) ٥٧١١٢- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿أحطت بما لم تحط به﴾</q>، قال: ما لم تَعْلَمْ{5}. (ز) <q>﴿وَجِئۡتُكَ مِن سَبَإِۭ﴾</q> - قراءات ٥٧١١٣- عن الحسن البصري -من طريق إسماعيل- أنّه قرأ: ‹مِن سَبَأَ بِنَبَإٍ يَقِينٍ›، قال: يجعلها أرضًا{11}٤٨٥٤. (١١/٣٥٢) ٤٨٥٤ ذكر ابنُ عطية (٦/٥٣٠) هذه القراءة، ثم قال: «لكن رُوِي عن رسول الله ﷺ من حديث فروة بن مسيك وغيره: أنه اسم رجل ولَد عشرة من الولد، تيامن منهم ستة، وتشامَّ أربعة». <q>﴿وَجِئۡتُكَ مِن سَبَإِۭ﴾</q> - تفسير الآية ٥٧١١٤- عن علقمة بن وعلة، أنّه سمع ابن عباس يقول: سُئِل رسولُ الله ﷺ عن سبإ، أرجل أم امرأة، أم أرض؟ فقال: «بل هو رجل ولد عشرة، فسكن اليمن منهم ستة، وبالشام منهم أربعة، فأمّا اليمانيون فمَذْحِج وكِندة والأزد والأشعريون وأنمار وحِمْيَر، عربًا كلها، وأما الشامية فلَخَم وجُذام وعاملة وغسّان»{12}. (ز) ٥٧١١٥- عن الحسن البصري -من طريق إسماعيل- أنه قرأ: ‹مِن سَبَأَ بِنَبَإٍ يَقِينٍ›، قال: يجعلها أرضًا{13}. (١١/٣٥٢) ٥٧١١٦- عن قتادة بن دعامة -من طريق سعيد- أنّه قرأ: <q>﴿من سبإٍ بنبإ﴾</q>، قال: يجعله رجلًا{14}. (١١/٣٥٢) ٥٧١١٧- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿وجئتك من سبإ﴾</q>، قال: سبأ بأرض اليمن، يُقال لها: مأرب، بينها وبين صنعاء مسيرة ثلاث ليال{15}. (١١/٣٥١) ٥٧١١٨- عن إسماعيل السُّدِّيّ، قال: بُعِث إلى سبأ اثنا عشر نبيًّا، منهم: تُبَّع{4}. (١١/٣٥٢) ٥٧١١٩- عن الرؤاسي أنّه سأل أبا عمرو بن العلاء: كيف لم تُجْرِ{17} سبأ؟ قال: لست أدري ما هو{18}٤٨٥٥. (ز) ٤٨٥٥ علَّق ابن جرير (١٨/٣٨) على قول أبي عمرو بقوله: «فكأن أبا عمرو ترك إجراءه إذ لم يدر ما هو، كما تفعل العرب بالأسماء المجهولة التي لا تعرفها من ترك الإجراء. حكي عن بعضهم: هذا أبو صعرورَ قد جاء. فترك إجراءه إذ لم يعرفه في أسمائهم. وإن كان سبأ»جبلًا«أجري لأنه يُراد به الجبل بعينه، وإن لم يجر فلأنه يجعل اسمًا للجبل وما حوله من البقعة». ٥٧١٢٠- عن ابن لهيعة، قال: يقولون: إنّ مأرب مدينة بلقيس، لم يكن بينها وبين بيت المقدس إلا ميل، فلمّا غضب الله عليها بَعَّدَها، فهي اليوم باليمن، وهي التي ذكر الله في القرآن: <q>﴿لقد كان لسبإ في مساكنهم﴾</q> [سبأ:١٥]{19}. (١١/٣٥١) ٥٧١٢١- قال مقاتل بن سليمان: <q>﴿وجئتك من﴾</q> أرض <q>﴿سبإ﴾</q> باليمن <q>﴿بنبإ يقين﴾</q> يقول: بحديث يقين لا شكَّ فيه{2}. (ز) <q>﴿بِنَبَإࣲ یَقِینٍ ۝٢٢﴾</q> - تفسير ٥٧١٢٢- عن عبد الله بن عباس -من طريق سعيد بن جبير، ومجاهد- في قوله: <q>﴿وجئتك من سبإ بنبإ يقين﴾</q>، قال: خبر حق{21}. (١١/٣٥١) ٥٧١٢٣- عن قتادة بن دعامة، في قوله: <q>﴿بنبإ يقين﴾</q>، قال: بخبر حق{22}. (١١/٣٥١) <q>﴿وَجِئۡتُكَ مِن سَبَإِۭ بِنَبَإࣲ یَقِینٍ ۝٢٢﴾</q> - تفسير ٥٧١٢٤- عن وهب بن مُنَبِّه -من طريق ابن إسحاق، عن بعض أهل العلم- <q>﴿وجئتك من سبإ بنبإ يقين﴾</q>: أي: أدركت مُلْكًا لم يَبْلُغْهُ مُلْكُك{5}. (ز) ٥٧١٢٥- عن يزيد بن رومان -من طريق محمد بن إسحاق- <q>﴿وجئتك من سبإ بنبإ يقين﴾</q>: أي: أدركت ملكًا لم يبلغه ملكك{4}. (ز) ",footnotes:1:أخرجه ابن أبي داود في المصاحف ١/٣٢٦. وهي قراءة شاذة. انظر: البحر المحيط ٧/٦٢.تفسير مقاتل بن سليمان ٣/٣٠١.تفسير يحيى بن سلام ٢/٥٣٩.أخرجه ابن أبي حاتم ٩/٢٨٦٤.أخرجه ابن جرير ١٨/٣٧.علقه يحيى بن سلام ٢/٥٣٩.أخرجه ابن أبي حاتم ٩/٢٨٦٤. وعلقه يحيى بن سلام ٢/٥٣٩.تفسير مقاتل بن سليمان ٣/٣٠١.أخرجه ابن أبي حاتم ٩/٢٨٦٤.أخرجه ابن جرير ١٨/٣٧.أخرجه ابن أبي حاتم ٩/٢٨٦٥. وعلقه يحيى بن سلام ٢/٥٣٩. و‹مِن سَبَأَ› بفتح الهمزة غير منونة قراءة متواترة، قرأ بها أبو عمرو، والبزي، وقرأ قنبل: ‹مِن سَبَأْ› بإسكان الهمزة، وقرأ بقية العشرة: <q>﴿مِن سَبَأٍ﴾</q> بالخفض والتنوين. انظر: النشر ٢/٣٣٧، والإتحاف ص٤٢٧.أخرجه أحمد ٥/٧٥ (٢٨٩٨)، والحاكم ٢/٤٥٩ (٣٥٨٥)، ويحيى بن سلام ٢/٥٣٩، ٧٥٢. قال الحاكم: «هذا حديث صحيح الإسناد، ولم يخرجاه». وقال الهيثمي في المجمع ٧/٩٤ (١١٢٨٦): «رواه أحمد والطبراني، وفيه ابن لهيعة، وفيه ضعف، وبقية رجالهما ثقات».أخرجه ابن أبي حاتم ٩/٢٨٦٥. وعلقه يحيى بن سلام ٢/٥٣٩.أخرجه ابن أبي حاتم ٩/٢٨٦٥.أخرجه ابن أبي حاتم ٩/٢٨٦٤. وعلقه يحيى بن سلام ٢/٥٣٩. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه ابن أبي حاتم ٩/٢٨٦٤.لم تُجْرِ: لم تُنَوِّن.أخرجه ابن جرير ١٨/٣٨.أخرجه ابن أبي حاتم ٩/٢٨٦٤. وهي قراءة العشرة؛ عدا حمزة والكسائي وحفص عن عاصم وخلف فقد قرؤوا <q>﴿مسكنهم﴾</q> على التوحيد، غير أن الكسائي وخلفًا قرآ بكسر الكاف. النشر ٢٢/٢٦٢.تفسير مقاتل بن سليمان ٣/٣٠١.أخرجه ابن أبي حاتم ٩/ ٢٨٦٥. وعزاه السيوطي إلى ابن المنذر.علقه يحيى بن سلام ٢/٥٣٩. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.أخرجه ابن جرير ١٨/٣٧.أخرجه ابن أبي حاتم ٩/٢٨٦٤.
