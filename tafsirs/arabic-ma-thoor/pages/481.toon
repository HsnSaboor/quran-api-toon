tafsir[8]{c,v,t}:
41,39," <q>﴿وَمِنۡ ءَایَـٰتِهِۦۤ أَنَّكَ تَرَى ٱلۡأَرۡضَ خَـٰشِعَةࣰ﴾</q> - تفسير ٦٨٦٣١- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿ومِن آياتِهِ أنَّكَ تَرى الأَرْضَ خاشِعَةً﴾</q>، قال: غبراء مُتَهَشِّمة{1}. (١٣/١١٩) ٦٨٦٣٢- عن إسماعيل السُّدّيّ -من طريق أسباط- <q>﴿ومِن آياتِهِ أنَّكَ تَرى الأَرْضَ خاشِعَةً﴾</q>، قال: يابسة مُهشّمة{2}. (ز) ٦٨٦٣٣- قال مقاتل بن سليمان: <q>﴿ومِن آياتِهِ﴾</q> أن يُعرَف التوحيدُ بصنعه وإن لم تروه <q>﴿أنَّكَ تَرى الأَرْضَ خاشِعَةً﴾</q> متهشِّمة، غبراء لا نبْت فيها{3}. (ز) <q>﴿فَإِذَاۤ أَنزَلۡنَا عَلَیۡهَا ٱلۡمَاۤءَ ٱهۡتَزَّتۡ وَرَبَتۡۚ﴾</q> - تفسير ٦٨٦٣٤- عن مجاهد بن جبر -من طريق ابن أبي نجيح- <q>﴿اهْتَزَّتْ﴾</q> قال: بالنبات، <q>﴿ورَبَتْ﴾</q> قال: ارتفعت قبل أن تُنبِت{4}. (١٣/١١٩) ٦٨٦٣٥- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿فَإذا أنْزَلْنا عَلَيْها الماءَ اهْتَزَّتْ ورَبَتْ﴾</q>، قال: تعرف الغيثَ في سحْتِها وربْوها إذا ما أصابها{5}. (١٣/١١٩) ٦٨٦٣٦- عن إسماعيل السُّدّيّ -من طريق أسباط- <q>﴿ورَبَتْ﴾</q>: انتفخت{2}. (ز) ٦٨٦٣٧- قال مقاتل بن سليمان: <q>﴿فَإذا أنْزَلْنا عَلَيْها الماءَ﴾</q> يعني: على الأرض المطر، فصارت حيَّة فأنبتت، <q>﴿واهْتَزَّتْ﴾</q> بالخضرة، <q>﴿ورَبَتْ﴾</q> يقول: وأضْعَفَتْ النبات{3}. (ز) <q>﴿إِنَّ ٱلَّذِیۤ أَحۡیَاهَا لَمُحۡیِ ٱلۡمَوۡتَىٰۤۚ إِنَّهُۥ عَلَىٰ كُلِّ شَیۡءࣲ قَدِیرٌ ۝٣٩﴾</q> - تفسير ٦٨٦٣٨- عن إسماعيل السُّدّيّ -من طريق أسباط-: كما يُحيي الأرض بالمطر، كذلك يُحيي الموتى بالماء يوم القيامة بين النفختين. يعني بذلك: تأويل قوله: <q>﴿إنَّ الَّذِي أحْياها لَمُحْيِ المَوْتى﴾</q>{8}. (ز) ٦٨٦٣٩- قال مقاتل بن سليمان: ثم قال: <q>﴿إنَّ الَّذِي أحْياها﴾</q> بعد موتها <q>﴿لَمُحْيِ المَوْتى﴾</q> في الآخرة ليعتبر مَن يشكّ في البعث، <q>﴿إنَّهُ عَلى كُلِّ شَيْءٍ قَدِيرٌ﴾</q> مِن البعث وغيره{3}. (ز) ",footnotes:1:أخرجه عبد الرزاق ٢/١٨٨من طريق معمر، وابن جرير ٢٠/٤٣٨. وعزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ٢٠/٤٣٨.تفسير مقاتل بن سليمان ٣/٧٤٤.تفسير مجاهد ص٥٨٦، وأخرجه الفريابي -كما في التغليق ٤/٣٠٢-٣٠٣-، وابن جرير ٢٠/٤٣٨-٤٣٩ بنحوه. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه ابن جرير ٢٠/٤٣٨. وعزاه السيوطي إلى عبد الرزاق، وعبد بن حميد.أخرجه ابن جرير ٢٠/٤٣٨.تفسير مقاتل بن سليمان ٣/٧٤٤.أخرجه ابن جرير ٢٠/٤٣٩.تفسير مقاتل بن سليمان ٣/٧٤٤.
41,40," <q>﴿إِنَّ ٱلَّذِینَ یُلۡحِدُونَ فِیۤ ءَایَـٰتِنَا لَا یَخۡفَوۡنَ عَلَیۡنَاۤۗ﴾</q> - تفسير ٦٨٦٤٠- عن عبد الله بن عباس -من طريق عطية العَوفيّ- في قوله: <q>﴿إنَّ الَّذِينَ يُلْحِدُونَ فِي آياتِنا﴾</q>، قال: هو أن يُوضَع الكلامُ على غير موضعه{1}. (١٣/١١٩) ٦٨٦٤١- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿إنَّ الَّذِينَ يُلْحِدُونَ فِي آياتِنا﴾</q>، قال: المُكاء، وما ذُكر معه{2}. (١٣/١١٩) ٦٨٦٤٢- عن قتادة بن دعامة -من طريق سعيد- <q>﴿إنَّ الَّذِينَ يُلْحِدُونَ فِي آياتِنا﴾</q>: الإلحاد: التكذيب{3}. (١٣/١١٩) ٦٨٦٤٣- عن إسماعيل السُّدّيّ -من طريق أسباط- <q>﴿إنَّ الَّذِينَ يُلْحِدُونَ فِي آياتِنا﴾</q>، قال: يشاقّون، يُعانِدون{4}. (ز) ٦٨٦٤٤- قال مقاتل بن سليمان: قوله: <q>﴿إنَّ الَّذِينَ يُلْحِدُونَ فِي آياتِنا﴾</q> يعني: أبا جهل، يميل عن الإيمان بالقرآن بالأشعار والباطل، <q>﴿لا يَخْفَوْنَ عَلَيْنا﴾</q> يعني: أبا جهل{5}. (ز) ٦٨٦٤٥- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿إنَّ الَّذِينَ يُلْحِدُونَ فِي آياتِنا لا يَخْفَوْنَ عَلَيْنا﴾</q>، قال: هؤلاء أهل الشرك. وقال: الإلحاد: الكفر والشرك{4}٥٧٦٤. (ز) ٥٧٦٤ اختلف المفسرون في الإلحاد على أقوال: الأول: معارضة المشركين القرآن باللغط والصفير استهزاء به. الثاني: كذبهم في آيات الله. الثالث: معاندتهم. الرابع: تبديلهم معاني كتاب الله. الخامس: الكفر والشرك. ورأى ابنُ جرير (٢٠/٤٤١-٤٤٢) تقارب الاقوال، فقال: «وكل هذه الأقوال التي ذكرناها في تأويل ذلك قريبات المعاني، وذلك أنّ اللحد والإلحاد: هو الميل، وقد يكون ميلًا عن آيات الله وعدولًا عنها بالتكذيب بها، ويكون بالاستهزاء مُكاء وتصدية، ويكون مفارقة لها وعنادًا، ويكون تحريفًا لها وتغييرًا لمعانيها». ثم رجَّح العموم (٢٠/٤٤٢) فقال: «ولا قول أولى بالصحة في ذلك مما قلنا، وأن يعم الخبر عنهم بأنهم ألحدوا في آيات الله، كما عمَّ ذلك ربنا -تبارك وتعالى-». وبنحوه ابنُ عطية (٧/٤٨٨)، فقال: «ولفظة الإلحاد تعمّ هذا كله». <q>﴿أَفَمَن یُلۡقَىٰ فِی ٱلنَّارِ خَیۡرٌ أَم مَّن یَأۡتِیۤ ءَامِنࣰا یَوۡمَ ٱلۡقِیَـٰمَةِۚ﴾</q> - نزول الآية، وتفسيرها ٦٨٦٤٦- عن عبد الله بن عباس، في قوله: <q>﴿أفَمَن يُلْقى فِي النّارِ خَيْرٌ﴾</q> قال: أبو جهل بن هشام، <q>﴿أمْ مَن يَأْتِي آمِنًا يَوْمَ القِيامَةِ﴾</q> قال: أبو بكر الصّدِّيق{7}. (١٣/١٢٠) ٦٨٦٤٧- عن عبد الله بن عباس، قال: ينطلق به إلى النار مكتوفًا، ثم يرمى به فيها، فأول ما يمس وجهه النار{8}. (ز) ٦٨٦٤٨- عن عكرمة مولى ابن عباس -من طريق بشير بن تيم عمن حدّثه- في قوله: <q>﴿أفَمَن يُلْقى فِي النّارِ خَيْرٌ أمْ مَن يَأْتِي آمِنًا يَوْمَ القِيامَةِ﴾</q>، قال: نزلت في عمّار بن ياسر، وفي أبي جهل{9}. (١٣/١٢٠) ٦٨٦٤٩- عن بشير بن تميم، قال: نزلت هذه الآية في أبي جهل وعمّار بن ياسر، <q>﴿أفَمَن يُلْقى فِي النّارِ﴾</q> أبو جهل، <q>﴿أمْ مَن يَأْتِي آمِنًا يَوْمَ القِيامَةِ﴾</q> عمار{10}. (١٣/١٢٠) ٦٨٦٥٠- قال مقاتل: <q>﴿أفَمَن يُلْقى فِي النّارِ خَيْرٌ أمْ مَن يَأْتِي آمِنًا يَوْمَ القِيامَةِ﴾</q> نزلت في أبي جهل{11}. (ز) ٦٨٦٥١- قال مقاتل بن سليمان: وأخبر الله تعالى بمستقرِّه في الآخرة، فقال: <q>﴿أفَمَن يُلْقى فِي النّارِ﴾</q> يعني: أبا جهل <q>﴿خير أمْ مَن يَأْتِي آمِنًا يَوْمَ القِيامَةِ﴾</q> يعني: النبي ﷺ{5}. (ز) <q>﴿ٱعۡمَلُوا۟ مَا شِئۡتُمۡ إِنَّهُۥ بِمَا تَعۡمَلُونَ بَصِیرٌ ۝٤٠﴾</q> - تفسير ٦٨٦٥٢- عن عبد الله بن عباس، في قوله: <q>﴿اعْمَلُوا ما شِئْتُمْ﴾</q>، قال: هذا لأهل بدر خاصة{7}. (١٣/١٢١) ٦٨٦٥٣- عن إبراهيم النَّخعي، قال: ذُكِر: أنّ السماء فُرجت يوم بدر، فقيل: اعملوا ما شئتم{14}. (١٣/١٢١) ٦٨٦٥٤- عن مجاهد بن جبر -من طريق ابن أبي نجيح- <q>﴿اعْمَلُوا ما شِئْتُمْ﴾</q>: هذا وعيد{15}. (١٣/١٢٠) ٦٨٦٥٥- عن الحسن البصري، قال: <q>﴿اعْمَلُوا ما شِئْتُمْ﴾</q> فأُبيحت -واللهِ- لهم الأعمال{14}. (١٣/١٢١) ٦٨٦٥٦- عن قتادة بن دعامة، <q>﴿اعْمَلُوا ما شِئْتُمْ﴾</q>، قال: خيَّركم، وأمرَكم بالعمل، واتخذ الحُجَّة، وبعث رسوله، وأنزل كتابه، وشرع شرائعه حجةً وتقدِمة إلى خلْقه{14}. (١٣/١٢١) ٦٨٦٥٧- قال مقاتل بن سليمان: ثم قال لكفار مكة: <q>﴿اعْمَلُوا ما شِئْتُمْ﴾</q> هذا وعيد، <q>﴿إنَّهُ بِما تَعْمَلُونَ بَصِيرٌ﴾</q> من الشرك وغيره{5}. (ز) ",footnotes:1:أخرجه ابن جرير ٢٠/٤٤١. وعزاه السيوطي إلى ابن أبي حاتم.تفسير مجاهد ص٥٨٦، وأخرجه ابن جرير ٢٠/٤٤٠. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه عبد الرزاق ٢/١٨٨ من طريق معمر، وابن جرير ٢٠/٤٤٠ بلفظ: يكذبون في آياتنا. وعزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ٢٠/٤٤١.تفسير مقاتل بن سليمان ٣/٧٤٤.أخرجه ابن جرير ٢٠/٤٤١.عزاه السيوطي إلى ابن مردويه.ذكره ابن جرير ٢٣/٢١٢.أخرجه إسحاق البستي ص٢٩٥ دون الإشارة للنزول من طريق بشير، وابن عساكر ٤٣/٣٧٧-٣٧٨.أخرجه عبد الرزاق ٢/١٨٨. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.تفسير الثعلبي ٨/٢٩٨، وتفسير البغوي ٧/١٧٦.تفسير مقاتل بن سليمان ٣/٧٤٤.عزاه السيوطي إلى ابن مردويه.عزاه السيوطي إلى عبد بن حميد.أخرجه عبد الرزاق ٢/١٨٩، وعبد بن حميد -كما في التغليق ٤/٣٠٣-، وابن جرير ١١/١١٤. وعلقه البخاري في صحيحه ٤/١٨١٧. وعزاه السيوطي إلى سعيد بن منصور، وابن المنذر.عزاه السيوطي إلى عبد بن حميد.عزاه السيوطي إلى عبد بن حميد.تفسير مقاتل بن سليمان ٣/٧٤٤.
41,41," <q>﴿إِنَّ ٱلَّذِینَ كَفَرُوا۟ بِٱلذِّكۡرِ لَمَّا جَاۤءَهُمۡۖ﴾</q> - تفسير ٦٨٦٥٨- عن عقبة بن عامر: أنّ رسول الله ﷺ تلا: <q>﴿إنَّ الَّذِينَ كَفَرُوا بِالذِّكْرِ لَمّا جاءَهُمْ﴾</q> إلى قوله: <q>﴿حَمِيدٍ﴾</q>، فقال: «إنّكم لا ترجعوا إلى الله بشيء أحبَّ إليه مِن شيء خرج منه». يعني: القرآن{1}. (١٣/١٢٢) ٦٨٦٥٩- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿إنَّ الَّذِينَ كَفَرُوا بِالذِّكْرِ﴾</q>، قال: بالقرآن{2}٥٧٦٥. (١٣/١٢٢) ٥٧٦٥ ذكر ابنُ عطية (٧/٤٨٩) أن الذكر هنا: هو القرآن بإجماع. ٦٨٦٦٠- عن عيسى بن عمر أنّه سأل عمرو بن عبيد: <q>﴿إنَّ الَّذِينَ كَفَرُوا بِالذِّكْرِ لَمّا جاءَهُمْ﴾</q> أين خبره؟ فقال عمرو: معناه في التفسير: إنّ الذين كفروا بالذكر لما جاءهم كفروا به، <q>﴿وإنَّهُ لِكِتابٌ عَزِيزٌ﴾</q>.= (ز) ٦٨٦٦١- فقال عيسى: أجدْتَ، يا أبا عثمان{3}٥٧٦٦. (ز) ٥٧٦٦ اختُلف في خبر قوله تعالى: <q>﴿إن الذين كفروا بالذكر لما جاءهم﴾</q>؛ فذكر ابنُ عطية (٧/٤٨٩) أن فرقة قالت: إن الخبر في قوله: <q>﴿أُولئِكَ يُنادَوْنَ مِن مَكانٍ بَعِيدٍ﴾</q>. ونقل عن النقاش أنه ذكر أن بلال بن أبي بردة سأل عن هذا في مجلسه، وقال: لم أجد لها نفاذًا. فقال له أبو عمرو بن العلاء: إنه منك لقريب <q>﴿أُولئِكَ يُنادَوْنَ﴾</q>. وانتقده، فقال: «ويردّ هذا النظر كثرةُ الحائل، وإن هنالك قومًا قد ذكروا يحسُن ردّ قوله: <q>﴿أُولئِكَ يُنادَوْنَ﴾</q> عليهم». ثم ذكر أن فرقة قالت: إن الخبر مضمر، تقديره: إن الذين كفروا بالذكر لما جاءهم هلكوا أو ضلوا. وذكر أيضًا عن بعض نحاة الكوفة أنهم قالوا: إن الجواب في قوله: <q>﴿وإنَّهُ لَكِتابٌ عَزِيزٌ﴾</q>. وانتقده بقوله: «وهو ضعيف لا يتجه». ثم ساق قول عيسى بن عمر. ورجَّح مسلك إضمار الخبر، فقال: «والذي يحسن في هذا هو إضمار الخبر». ولم يذكر مستندًا، ثم ذكر تقديرًا آخر غير المذكور في هذا القول، فقال: «ولكنه عند قوم في غير هذا الموضع الذي قدّره هؤلاء فيه، وإنما هو بعد <q>﴿حَكِيمٍ حَمِيدٍ﴾</q>، وهو أشد إظهارًا لمذمّة الكفار به؛ وذلك أن قوله: <q>﴿وإنَّهُ لَكِتابٌ﴾</q> داخل في صفة الذكر المكذَّب به، فلم يتم ذكر المخبر عنه إلا بعد استيفاء وصفه، وهذا كما تقول: تخالف زيدًا وهو العالم الودود، الذي من شأنه ومن أمره. فهذه كلها أوصاف». وذكر ابنُ جرير (٢٠/٤٥٣) نحو هذه الأقوال، ثم رجَّح -مستندًا للغة- أن الأَولى في الخبر أن يكون مما تُرك ذكره اكتفاءً بمعرفة السامعين بمعناه لَمّا تطاول الكلام. ٦٨٦٦٢- قال مقاتل بن سليمان: <q>﴿إنَّ الَّذِينَ كَفَرُوا﴾</q> يعني: أبا جهل <q>﴿بِالذِّكْرِ لَمّا جاءَهُمْ﴾</q> يعني به: القرآن حين جاءهم، وهو أبو جهل وكفار مكة{4}. (ز) <q>﴿وَإِنَّهُۥ لَكِتَـٰبٌ عَزِیزࣱ ۝٤١﴾</q> - تفسير ٦٨٦٦٣- عن عبد الله بن عباس: <q>﴿وإنَّهُ لَكِتابٌ عَزِيزٌ﴾</q> كريم على الله{5}. (ز) ٦٨٦٦٤- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿وإنَّهُ لَكِتابٌ عَزِيزٌ﴾</q> أعزّه الله؛ لأنه كلامه، وحفظه من الباطل{6}. (١٣/١٢٣) ٦٨٦٦٥- عن إسماعيل السُّدّيّ -من طريق أسباط- <q>﴿وإنَّهُ لَكِتابٌ عَزِيزٌ﴾</q>، قال: عزيز من الشيطان{7}. (ز) ٦٨٦٦٦- قال إسماعيل السُّدّيّ: <q>﴿وإنَّهُ لَكِتابٌ عَزِيزٌ﴾</q> غير مخلوق{8}. (ز) ٦٨٦٦٧- قال مقاتل بن سليمان: <q>﴿وإنَّهُ لَكِتابٌ عَزِيزٌ﴾</q>، يقول: وإنه لقرآن منيع من الباطل، فلا يستذل؛ لأنه كلام الله{4}. (ز) <q>﴿وَإِنَّهُۥ لَكِتَـٰبٌ عَزِیزࣱ ۝٤١﴾</q> - آثار متعلقة بالآية ٦٨٦٦٨- عن أبي سعيد الخُدري -لا أحسبه إلا أسنده إلى رسول الله ﷺ- قال: «مَثَلُ القرآن ومَثَلُ الناس كمَثَلِ الأرض والغيث، بينما الأرض ميّتة هامدة، ثم يرسل الوابل فتهتزّ وتربو، ثم لا يزال يرسل الأودية حتى تَبْذر وتُنبت، ويتمّ شأنها، ويُخرج اللهُ ما فيها مِن زينتها ومعايش الناس، وكذلك فعل الله بهذا القرآن والناس»{10}. (١٣/١٢١) ٦٨٦٦٩- عن عمر بن الخطاب –من طريق ابن شهاب- قال: إنّ هذا القرآنَ كلامُ الله، فضَعوه على مواضعه، ولا تتّبعوا فيه أهواءكم{11}. (١٣/١٢٠) ",footnotes:1:أخرجه الحاكم ٢/٤٧٩ (٣٦٥١). قال الحاكم: «هذا حديث صحيح الإسناد، ولم يخرجاه»، ووافقه الذهبي. وقال الألباني في الضعيفة ٤/٤٢٦ تعقيبًا على كلام الحاكم والذهبي: «وفيه أنّ عبد الله بن صالح فيه ضعف، فلا يُحتج به إذا تفرد، فكيف إذا خالف؟! فكيف إذا كان المخالف الحافظ الثقة ابن مهدي؟! فقد أرسله كما رأيت، فأنى له الصحة؟! ولا سيما أن مداره موصولًا ومرسلًا على العلاء، وقد عرفت حاله، وقد قال الإمام البخاري في خلق أفعال العباد بعد أن ذكر الحديث معلقًا: لا يصح؛ لإرساله وانقطاعه».أخرجه عبد الرزاق ٢/١٨٨ من طريق معمر، وابن جرير ٢٠/٤٤٣. وعزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ٢٠/٤٥٢.تفسير مقاتل بن سليمان ٣/٧٤٤.تفسير الثعلبي ٨/٢٩٨، وتفسير البغوي ٧/١٧٦.أخرجه ابن الضريس (١٢٢، ١٢٣)، وابن جرير ٢٠/٤٤٣. وعزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ٢٠/٤٤٣.تفسير الثعلبي ٨/٢٩٨.تفسير مقاتل بن سليمان ٣/٧٤٤.أخرجه أبو الشيخ الأصبهاني في أمثال الحديث ص٤٠١ (٣٤٩) بنحوه، من طريق أبي بشر محمد بن عمران بن الجنيد، ثنا يحيى بن محمد أبو بشر، ثنا يحيى بن أبي الحجاج، عن عوف، عن أبي نضرة، عن أبي سعيد به. وأورده الديلمي في الفردوس ٤/١٣٩ (٦٤٢٩). وعزاه السيوطي إلى ابن مردويه. إسناده ضعيف؛ فيه يحيى بن محمد أبو بشر، قال عنه الذهبي في المغني في الضعفاء (٧٠٤٧): «نهى عنه أبو زرعة». وفيه أيضًا يحيى ابن أبي الحجاج، قال عنه ابن حجر في التقريب (٧٥٢٧): «ليّن الحديث».أخرجه أحمد في الزهد ص٣٥.
41,42," <q>﴿لَّا یَأۡتِیهِ ٱلۡبَـٰطِلُ مِنۢ بَیۡنِ یَدَیۡهِ وَلَا مِنۡ خَلۡفِهِۦۖ تَنزِیلࣱ مِّنۡ حَكِیمٍ حَمِیدࣲ ۝٤٢﴾</q> - تفسير ٦٨٦٧٠- عن علي بن أبي طالب، قال: قيل لرسول الله ﷺ: إنّ أُمَّتك ستُفْتَنُ مِن بعدك. فسأل رسولُ ﷺ –أو سُئل-: ما المخرج منها؟ فقال: «كتاب الله العزيز، الذي لا يأتيه الباطل من بين يديه ولا من خلفه <q>﴿تَنْزِيلٌ مِن حَكِيمٍ حَمِيدٍ﴾</q>»{1}. (١٣/١٢١) ٦٨٦٧١- عن سعيد بن جبير -من طريق جعفر- <q>﴿لا يَأْتِيهِ الباطِلُ مِن بَيْنِ يَدَيْهِ ولا مِن خَلْفِهِ﴾</q>، قال: النكير من بين يديه، ولا من خلفه{2}. (ز) ٦٨٦٧٢- عن مجاهد بن جبر، في قوله: <q>﴿لا يَأْتِيهِ الباطِلُ﴾</q>، قال: الشيطان{3}. (١٣/١٢٢) ٦٨٦٧٣- عن مجاهد بن جبر، <q>﴿لا يَأْتِيهِ الباطِلُ مِن بَيْنِ يَدَيْهِ ولا مِن خَلْفِهِ﴾</q>، قال: لا يُدخِل فيه الشيطانُ ما ليس منه، ولا أحد من الكفرة{4}. (١٣/١٢٢) ٦٨٦٧٤- عن الحسن البصري -من طريق قتادة- في قوله: <q>﴿وإنه لكتاب عزيز لا يأتيه الباطل من بين يديه ولا من خلفه﴾</q>، قال: حفظه الله مِن الشيطان، فلا يزيد فيه باطلًا، ولا ينقص منه حقًّا. ثم قرأ: <q>﴿إنا نحن نزلنا الذكر وإنا له لحافظون﴾</q> [الحجر:٩]، قال: هذه نظيرتها{5}. (ز) ٦٨٦٧٥- عن قتادة بن دعامة -من طريق سعيد- <q>﴿لا يَأْتِيهِ الباطِلُ مِن بَيْنِ يَدَيْهِ ولا مِن خَلْفِهِ﴾</q>، قال: والباطل إبليس، لا يستطيع أن يُنقِص منه حقًّا، ولا يزيد فيه باطلًا{6}. (١٣/١٢٣) ٦٨٦٧٦- عن إسماعيل السُّدّيّ -من طريق أسباط- <q>﴿لا يَأْتِيهِ الباطِلُ مِن بَيْنِ يَدَيْهِ ولا مِن خَلْفِهِ﴾</q>، قال: الباطل: هو الشيطان، لا يستطيع أن يزيد فيه حرفًا ولا ينقص{7}. (ز) ٦٨٦٧٧- قال محمد بن السّائِب الكلبي: <q>﴿لا يَأْتِيهِ الباطِلُ مِن بَيْنِ يَدَيْهِ﴾</q>، يعني: من قِبَل{8}. (ز) ٦٨٦٧٨- قال محمد بن السّائِب الكلبي: لا يأتيه ما يُبطله ويُكَذِّبه مِن الكتب المتقدمة، بل هو مُوافِق لها مُصَدِّق، ولا يجيء بعده كتاب يبطله وينسخه، بل هو موافق لها مصدق{9}. (ز) ٦٨٦٧٩- قال مقاتل بن سليمان: <q>﴿لا يَأْتِيهِ الباطِلُ مِن بَيْنِ يَدَيْهِ﴾</q> يقول: لا يأتي القرآن بالتكذيب، بل يصدِّق هذا القرآن الكتب التي كانت قبله: التوراة والإنجيل والزبور، ثم قال: <q>﴿ولا يأتيه﴾</q> الباطل <q>﴿مِن خَلْفِهِ﴾</q> يقول: لا يجيئه من بعده كتاب يبطله فيكذّبه، <q>﴿تَنْزِيلٌ﴾</q> يعني: وحي <q>﴿مِن حَكِيمٍ﴾</q> في أمره، <q>﴿حَمِيدٍ﴾</q> عند خلقه{10}٥٧٦٧. (ز) ٥٧٦٧ اختُلف في معنى قوله: <q>﴿لا يأتيه الباطل من بين يديه ولا من خلفه﴾</q> على أقوال: الأول: لا يأتيه النكير من بين يديه ولا من خلفه. الثاني: لا يستطيع الشيطان أن ينقص منه حقًّا، ولا يزيد فيه باطلًا، والباطل هو الشيطان، وقوله: <q>﴿من بين يديه﴾</q> من قبل الحق <q>﴿ولا من خلفه﴾</q> من قبل الباطل. الثالث: إنّ الباطل لا يطيق أن يزيد فيه شيئًا من الحروف ولا ينقص منه شيئًا منها. ورجَّح ابنُ جرير (٢٠/٤٤٥) العموم، فقال: «وأولى الأقوال في ذلك عندنا بالصواب أن يُقال: معناه: لا يستطيع ذو باطل بكيده تغييره، وتبديل شيء من معانيه عمّا هو به، وذلك هو الإتيان من بين يديه، ولا إلحاق ما ليس منه فيه، وذلك إتيانه من خلفه». ولم يذكر مستندًا. وكذا رجَّحه ابنُ عطية (٧/٤٩٠) مستندًا لظاهر اللفظ، فقال: «وظاهر اللفظ يعم الشيطان، وأن يجيء أمر يبطل منه شيئًا». ",footnotes:1:عزاه السيوطي إلى ابن مردويه.أخرجه ابن جرير ٢٠/٤٤٤.عزاه السيوطي إلى عبد بن حميد، وابن المنذر.عزاه السيوطي إلى عبد بن حميد.أخرجه البيهقي في دلائل النبوة ٦/١٥٩.أخرجه عبد الرزاق ٢/١٨٨ من طريق معمر بنحوه، وابن الضريس (١٢٢، ١٢٣)، وابن جرير ٢٠/٤٤٤. وعزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ٢٠/٤٤٥.أخرجه يحيى بن سلام -كما في تفسير ابن أبي زمنين ٤/١٥٥-.تفسير الثعلبي ٨/٢٩٨.تفسير مقاتل بن سليمان ٣/٧٤٤-٧٤٥.
41,43," <q>﴿مَّا یُقَالُ لَكَ إِلَّا مَا قَدۡ قِیلَ لِلرُّسُلِ مِن قَبۡلِكَۚ﴾</q> - تفسير ٦٨٦٨٠- عن أبي صالح باذام، في قوله: <q>﴿ما يُقالُ لَكَ إلّا ما قَدْ قِيلَ لِلرُّسُلِ مِن قَبْلِكَ﴾</q>، قال: مِن الأذى{1}. (١٣/١٢٣) ٦٨٦٨١- عن قتادة بن دعامة، في قوله: <q>﴿ما يُقالُ لَكَ﴾</q> من التكذيب <q>﴿إلّا ما قَدْ قِيلَ لِلرُّسُلِ مِن قَبْلِكَ﴾</q> فكما كُذِّبت فقد كُذِّبوا، وكما صبروا على أذى قومهم لهم فاصبر أنت على أذى قومك لك{2}. (١٣/١٢٣) ٦٨٦٨٢- عن قتادة بن دعامة -من طريق معمر- في قوله تعالى: <q>﴿ما يُقالُ لَكَ إلّا ما قَدْ قِيلَ لِلرُّسُلِ مِن قَبْلِكَ﴾</q>، قال: يُعَزِّيه. قال: يقول: قد قيل للأنبياء: ساحر، وشبه ذلك{3}. (١٣/١٢٣) ٦٨٦٨٣- عن قتادة بن دعامة -من طريق سعيد-: يُعَزّي نبيَّه ﷺ كما تسمعون، يقول: <q>﴿كَذَلِكَ ما أتى الَّذِينَ مِن قَبْلِهِمْ مِن رَسُولٍ إلاَّ قالُوا ساحِرٌ أومَجْنُونٌ﴾</q> [الذاريات:٥٢]{4}. (ز) ٦٨٦٨٤- عن إسماعيل السُّدّيّ -من طريق أسباط- في قوله: <q>﴿ما يُقالُ لَكَ إلّا ما قَدْ قِيلَ لِلرُّسُلِ مِن قَبْلِكَ﴾</q>، قال: ما يقولون إلا ما قد قال المشركون للرسل من قبلك{4}. (ز) ٦٨٦٨٥- قال مقاتل بن سليمان: ثم قال: <q>﴿ما يُقالُ لَكَ﴾</q> يا محمد من التكذيب بالقرآن أنّه ليس بنازل عليك <q>﴿إلّا ما قَدْ قِيلَ لِلرُّسُلِ مِن قَبْلِكَ﴾</q> مِن قومهم مِن التكذيب لهم أنّه ليس العذاب بنازل بهم، يعزِّي نبيَّه ﷺ ليصبر على الأذى والتكذيب{6}٥٧٦٨. (ز) ٥٧٦٨ ذكر ابنُ عطية (٧/٤٩٠) أن قوله: <q>﴿ما يُقالُ لَكَ إلّا ما قَدْ قِيلَ لِلرُّسُلِ مِن قَبْلِكَ﴾</q> يحتمل معنيين: أحدهما: أن يكون تسلية للنبي ﷺ عن مقالات قومه، أي ما تلقى -يا محمدُ- من المكروه منهم، ولا يقولون لك من الأقوال المؤلمة، إلا ما قد قيل ولُقي به مَن تقدمك مِن الرسل، فلتتأسّ بهم، ولتمض لأمر الله تعالى، ولا يهمك شأنهم. والثاني: أن تكون الآية تلخيصًا لمعاني الشرع، أي: ما يقال لك من الوحي، وتخاطب به من جهة الله تعالى، إلا ما قد قيل للرسل من قبلك، ثم فسَّر الله تعالى ذلك الذي قيل لجميعهم وهو <q>﴿إنَّ رَبَّكَ لَذُو مَغْفِرَة﴾</q> للطائعين، <q>﴿وذُو عِقابٍ﴾</q> للكافرين. وفي هذه الكلمات جماع النهي والزجر الموعظة، وإليها يرجع كل نظر. <q>﴿إِنَّ رَبَّكَ لَذُو مَغۡفِرَةࣲ وَذُو عِقَابٍ أَلِیمࣲ ۝٤٣﴾</q> - نزول الآية، وتفسيرها ٦٨٦٨٦- عن سعيد بن المسيّب، قال: لَمّا نزلت هذه الآية: <q>﴿إن ربك لذو مغفرة﴾</q> قال رسول الله ﷺ: «لولا عفوُ اللهِ وتجاوزُه ما هنأ أحدًا العيش، ولولا وعيدُه وعقابُه لاتَّكل كلُّ أحد»{7}. (ز) ٦٨٦٨٧- قال مقاتل بن سليمان: <q>﴿إنَّ رَبَّكَ لَذُو مَغْفِرَةٍ﴾</q> يقول: ذو تَجاوُزٍ في تأخير العذاب عنهم إلى الوقت، حين سألوا العذاب في الدنيا وإذا جاء الوقت، <q>﴿وذُو عِقابٍ﴾</q> فهو ذو عقاب <q>﴿ألِيمٍ﴾</q> يعني: وجيع. كقوله: <q>﴿إنْ تَكُونُوا تَأْلَمُونَ﴾</q> [النساء:١٠٤] إن كنتم تتوجعون{6}. (ز) ",footnotes:1:عزاه السيوطي إلى عبد بن حميد، وابن المنذر.عزاه السيوطي إلى ابن أبي حاتم.أخرجه عبد الرزاق ٢/١٨٨. وعزاه السيوطي إلى عبد بن حميد مختصرًا.أخرجه ابن جرير ٢٠/٤٤٦.أخرجه ابن جرير ٢٠/٤٤٦.تفسير مقاتل بن سليمان ٣/٧٤٥.أخرجه ابن أبي حاتم -كما في تفسير ابن كثير ٧/١٨٣-.تفسير مقاتل بن سليمان ٣/٧٤٥.
41,44," <q>﴿وَلَوۡ جَعَلۡنَـٰهُ قُرۡءَانًا أَعۡجَمِیࣰّا لَّقَالُوا۟ لَوۡلَا فُصِّلَتۡ ءَایَـٰتُهُۥۤۖ ءَا۬عۡجَمِیࣱّ وَعَرَبِیࣱّۗ قُلۡ هُوَ لِلَّذِینَ ءَامَنُوا۟ هُدࣰى وَشِفَاۤءࣱۚ وَٱلَّذِینَ لَا یُؤۡمِنُونَ فِیۤ ءَاذَانِهِمۡ وَقۡرࣱ وَهُوَ عَلَیۡهِمۡ عَمًىۚ أُو۟لَـٰۤىِٕكَ یُنَادَوۡنَ مِن مَّكَانِۭ بَعِیدࣲ ۝٤٤﴾</q> - قراءات ٦٨٦٨٨- عن عبد الله بن عباس -من طريق سليمان بن قتّة- أنّه كان يقرأ: (أعْمى أُولَئِكَ){1}. (١٣/١٢٥) ٦٨٦٨٩- عن الحسن البصري -من طريق داود بن أبي هند- ‹ولَوْ جَعَلْناهُ قُرْآنًا أعْجَمِيًّا لَّقالُوا لَوْلا فُصِّلَتْ آياتُهُ أعْجَمِيٌّ وعَرَبِيٌّ›، يقول: فيه أعجمي وعربي، لا يَسْتَفْهِم= (ز) ٦٨٦٩٠- قال: وقال أبو الأسْود الدُّؤلي مثله{2}٥٧٦٩. (ز) ٥٧٦٩ اختلف في قراءة قوله: <q>﴿أأعجمي وعربي﴾</q>؛ فقرأ الجمهور: <q>﴿أأعجمي وعربي﴾</q> على وجه الاستفهام، وقرأ غيرهم ذلك: ‹أعْجَمِيٌّ › بهمزة واحدة على غير مذهب الاستفهام. وذكر ابنُ عطية (٧/٤٩١) أن المعنى على القراءة الثانية كأنهم قالوا: عجمة وإعراب؟! إنّ هذا لشاذ. أو كأنهم قالوا لولا فصل فصلين، فكان بعضه أعجميًّا يفهمه العجم، وبعضه عربيًّا يفهمه العرب. وبنحوه ابنُ جرير (٢٠/٤٤٨-٤٤٩). ورجَّح ابنُ جرير (٢٠/٤٤٩) قراءة الجمهور مستندًا إلى إجماع القراء، فقال: «والصواب من القراءة في ذلك عندنا القراءة التي عليها قراء الأمصار؛ لإجماع الحجة عليها على مذهب الاستفهام». <q>﴿وَلَوۡ جَعَلۡنَـٰهُ قُرۡءَانًا أَعۡجَمِیࣰّا لَّقَالُوا۟ لَوۡلَا فُصِّلَتۡ ءَایَـٰتُهُۥۤۖ ءَا۬عۡجَمِیࣱّ وَعَرَبِیࣱّۗ قُلۡ هُوَ لِلَّذِینَ ءَامَنُوا۟ هُدࣰى وَشِفَاۤءࣱۚ وَٱلَّذِینَ لَا یُؤۡمِنُونَ فِیۤ ءَاذَانِهِمۡ وَقۡرࣱ وَهُوَ عَلَیۡهِمۡ عَمًىۚ أُو۟لَـٰۤىِٕكَ یُنَادَوۡنَ مِن مَّكَانِۭ بَعِیدࣲ ۝٤٤﴾</q> - نزول الآية ٦٨٦٩١- عن سعيد بن جُبير -من طريق جعفر- قال: قالت قريش: لولا أُنزِل هذا القرآن أعجميًّا وعربيًّا؟ فأنزل الله: <q>﴿لَقالُوا لَوْلا فُصِّلَتْ آياتُهُ أأَعْجَمِيٌّ وعَرَبِيٌّ﴾</q>. وأنزل الله بعد هذه الآية فيه بكلّ لسان؛ <q>﴿حِجارَةً مِن سِجِّيلٍ﴾</q> [الحجر:٧٤] قال: فارسية أُعرِبت: سنكَك وكَل{3}. (١٣/١٢٤) ٦٨٦٩٢- قال مقاتل بن سليمان: <q>﴿ولَو جَعَلْناهُ قُرْآنًا أعْجَمِيًّا﴾</q> وذلك أنّ كفار قريش كانوا إذا رأوا النبيَّ ﷺ يدخل على يسار أبي فُكَيْهَة اليهودي، وكان أعجميّ اللسان غلام عامر بن الحضرمي القرشي يحدّثه؛ قالوا: ما يعلّمه إلا يسار أبو فُكَيْهَة. فأخذه سيدُه، فضربه، وقال له: إنّك تعلِّم محمدًا ﷺ. فقال يسار: بل هو يعلّمني. فأنزل الله ﷿: <q>﴿ولَو جَعَلْناهُ قُرْآنًا أعْجَمِيًّا﴾</q>{4}. (ز) <q>﴿وَلَوۡ جَعَلۡنَـٰهُ قُرۡءَانًا أَعۡجَمِیࣰّا لَّقَالُوا۟ لَوۡلَا فُصِّلَتۡ ءَایَـٰتُهُۥۤۖ ءَا۬عۡجَمِیࣱّ وَعَرَبِیࣱّۗ قُلۡ هُوَ لِلَّذِینَ ءَامَنُوا۟ هُدࣰى وَشِفَاۤءࣱۚ وَٱلَّذِینَ لَا یُؤۡمِنُونَ فِیۤ ءَاذَانِهِمۡ وَقۡرࣱ وَهُوَ عَلَیۡهِمۡ عَمًىۚ أُو۟لَـٰۤىِٕكَ یُنَادَوۡنَ مِن مَّكَانِۭ بَعِیدࣲ ۝٤٤﴾</q> - تفسير الآية ٦٨٦٩٣- عن عبد الله بن عباس، في قوله: <q>﴿ولَو جَعَلْناهُ قُرْآنًا أعْجَمِيًّا﴾</q> يقول: لو جعلنا القرآنَ أعجميًّا، ولسانك يا محمد عربي؛ لقالوا: أأعجمي وعربي يأتينا به مختلِفًا أو مختلِطًا <q>﴿لَقالُوا لَوْلا فُصِّلَتْ آياتُهُ﴾</q> هلا بُيِّنتْ آياته، فكان القرآن مثل اللسان. يقول: فلم يفعل لئلّا يقولوا، فكانت حجة عليهم{5}. (١٣/١٢٣) ٦٨٦٩٤- عن أبي مَيْسرة [عمرو بن شرحبيل] -من طريق أبي إسحاق- قال: <q>﴿ولَوجَعَلْناهُ قُرْآنًا أعْجَمِيًّا﴾</q> في القرآن بكلّ لسان{6}. (١٣/١٢٤) ٦٨٦٩٥- عن سعيد بن جُبير -من طريق أبي بشر- أنه قال في هذه الآية: <q>﴿لَوْلا فُصِّلَتْ آياتُهُ أأَعْجَمِيٌّ وعَرَبِيٌّ﴾</q>، قال: لو كان هذا القرآن أعجميًّا لقالوا: القرآن أعجمي، ومحمد عربي{7}. (١٣/١٢٤) ٦٨٦٩٦- عن عبد الله بن مُطِيع -من طريق محمد بن أبي موسى-، بنحوه{8}. (ز) ٦٨٦٩٧- عن سعيد بن جُبير -من طريق داود بن أبي هند- <q>﴿لولا فصلت ءاياته ءاعجمي وعربي﴾</q>: يقول: كتاب أعجمي ورسول عربي؟! يَسْتفهِم{9}. (ز) ٦٨٦٩٨- عن مجاهد بن جبر -من طريق ابن أبي نَجِيح- في قوله: <q>﴿لَوْلا فُصِّلَتْ آياتُهُ﴾</q>: فجُعِل عربيًّا، أعجمي الكلام وعربي الرجل؟!{10}. (ز) ٦٨٦٩٩- عن قتادة بن دعامة -من طريق معمر- في قوله تعالى: <q>﴿لَوْلا فُصِّلَتْ آياتُهُ أأَعْجَمِيٌّ﴾</q>، قال: يقول: لولا بُيِّنت آياته أعجمي وعربي، لقالوا: هذا القرآن أعجمي وهذا النبي عربي، فيقول: لكان ذلك أشد لتكذيبهم{11}. (ز) ٦٨٧٠٠- عن إسماعيل السُّدّيّ -من طريق أسباط- في قوله: <q>﴿ولَوجَعَلْناهُ قُرْآنًا أعْجَمِيًّا لَقالُوا لَوْلا فُصِّلَتْ آياتُهُ أأَعْجَمِيٌّ وعَرَبِيٌّ﴾</q>: يقول: بُيِّنت آياته أأعجمي وعربي، نحن قوم عرب ما لنا وللعُجْمة؟!{12}. (ز) ٦٨٧٠١- عن عطاء الخُراساني -من طريق يونس بن يزيد- في قوله ﷿: <q>﴿قرآنا أعجميا﴾</q>: قال تعالى: لو أنزلناه أعجميًّا لقالوا: فصِّلوه لنا بالعربية{13}. (ز) ٦٨٧٠٢- قال مقاتل بن سليمان: <q>﴿ولَو جَعَلْناهُ قُرْآنًا أعْجَمِيًّا﴾</q> يقول: بلسان العجم <q>﴿لَقالُوا﴾</q> لقال كفار مكة: <q>﴿لَوْلا فُصِّلَتْ﴾</q> يقول: هلا بُيِّنت <q>﴿آياتُهُ﴾</q> بالعربية؛ حتى نفقه ونعلم ما يقول محمد <q>﴿أعْجَمِيٌّ﴾</q> ولقالوا: إنّ القرآن أعجمي أُنزل على محمد، وهو <q>﴿عَرَبِيٌّ قُلْ﴾</q> نزّله الله عربيًّا لكي يفقهوه، ولا يكون لهم علة{14}. (ز) <q>﴿قُلۡ هُوَ لِلَّذِینَ ءَامَنُوا۟ هُدࣰى وَشِفَاۤءࣱۚ﴾</q> - تفسير ٦٨٧٠٣- عن قتادة بن دعامة -من طريق سعيد- <q>﴿قُلْ هُولِلَّذِينَ آمَنُوا هُدًى وشِفاءٌ﴾</q>، قال: جعله الله نورًا، وبركة، وشفاء للمؤمنين{15}. (ز) ٦٨٧٠٤- عن إسماعيل السُّدّيّ -من طريق أسباط- <q>﴿قُلْ هُو لِلَّذِينَ آمَنُوا هُدًى وشِفاءٌ﴾</q>، قال: القرآن{15}. (ز) ٦٨٧٠٥- قال مقاتل بن سليمان: يقول الله تعالى: <q>﴿هُولِلَّذِينَ آمَنُوا هُدىً﴾</q> مِن الضلالة، <q>﴿وشِفاءٌ﴾</q> لما في القلوب؛ لِلَّذي فيه مِن التبيان{17}. (ز) <q>﴿وَٱلَّذِینَ لَا یُؤۡمِنُونَ فِیۤ ءَاذَانِهِمۡ وَقۡرࣱ وَهُوَ عَلَیۡهِمۡ عَمًىۚ﴾</q> - تفسير ٦٨٧٠٦- عن قتادة بن دعامة -من طريق معمر- <q>﴿وهُوعَلَيْهِمْ عَمًى﴾</q>، قال: عَمُوا عن القرآن، وصمُّوا عنه{18}. (١٣/١٢٥) ٦٨٧٠٧- عن إسماعيل السُّدّيّ -من طريق أسباط- <q>﴿والَّذِينَ لا يُؤْمِنُونَ فِي آذانِهِمْ وقْرٌ﴾</q> قال: صَمم، <q>﴿وهُو عَلَيْهِمْ عَمًى﴾</q> قال: عَمِيَت قلوبُهم عنه{19}. (ز) ٦٨٧٠٨- قال مقاتل بن سليمان: ثم قال: <q>﴿والَّذِينَ لا يُؤْمِنُونَ﴾</q> بالآخرة، يعني: لا يُصَدِّقون بالبعث الذي فيه جزاء الأعمال <q>﴿فِي آذانِهِمْ وقْر﴾</q> يعني: ثِقَل؛ فلا يسمعون الإيمان بالقرآن، <q>﴿وهُوعَلَيْهِمْ عَمًى﴾</q> يعني: عمُوا عنه، يعني: القرآن؛ فلم يُبْصِروه، ولم يفقهوه{17}٥٧٧٠. (ز) ٥٧٧٠ ذكر ابنُ عطية (٧/٤٩١) هذا القول، ثم ذكر أنّ قومًا قالوا بأن المراد بـ«هو»: الوَقر. ٦٨٧٠٩- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿وهُوعَلَيْهِمْ عَمًى﴾</q>، قال: العمى: الكفر{19}. (ز) <q>﴿أُو۟لَـٰۤىِٕكَ یُنَادَوۡنَ مِن مَّكَانِۭ بَعِیدࣲ ۝٤٤﴾</q> - تفسير ٦٨٧١٠- عن مجاهد بن جبر -من طريق ابن جُريْج- في قوله: <q>﴿أُولَئِكَ يُنادَوْنَ مِن مَكانٍ بَعِيدٍ﴾</q>، قال: بعيد مِن قلوبهم{22}٥٧٧١. (١٣/١٢٥) ٥٧٧١ ساق ابنُ كثير (١٢/٢٤٧) هذا القول الذي قاله مجاهد، وابن زيد، ومقاتل، ثم قال: «وهذا كقوله: <q>﴿ومثل الذين كفروا كمثل الذي ينعق بما لا يسمع إلا دعاء ونداء صم بكم عمي فهم لا يعقلون﴾</q> [البقرة:١٧١]». ٦٨٧١١- عن الضَّحّاك بن مُزاحِم -من طريق أجلح- في قوله: <q>﴿أُولَئِكَ يُنادَوْنَ مِن مَكانٍ بَعِيدٍ﴾</q>، قال: يُنادون يوم القيامة بأشنع أسمائهم{23}. (١٣/١٢٥) ٦٨٧١٢- عن طاووس -من طريق ابن جُريْج- <q>﴿أولئك ينادون من مكان بعيد﴾</q>، قال: بعيد من قلوبهم{24}. (ز) ٦٨٧١٣- قال مقاتل بن سليمان: <q>﴿أُولئِكَ يُنادَوْنَ مِن مَكانٍ بَعِيدٍ﴾</q> إلى الإيمان بأنّه غير كائن؛ لأنهم صمٌّ عنه، وعُمْيٌ، وفي آذانهم وقر{17}. (ز) ٦٨٧١٤- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿أُولَئِكَ يُنادَوْنَ مِن مَكانٍ بَعِيدٍ﴾</q>، قال: ضيّعوا أن يقبلوا الأمرَ مِن قريب؛ يتوبون ويؤمنون، فيُقبل منهم، فأبوا{26}٥٧٧٢. (ز) ٥٧٧٢ ذكر ابنُ عطية (٧/٤٩١) أن قوله تعالى: <q>﴿أُولئِكَ يُنادَوْنَ﴾</q> يحتمل معنيين، وكلاهما مقول للمفسرين: أحدهما: أنها استعارة لقلة فهمهم، شبّههم بالرجل ينادى على بعد يُسمع منه الصوت ولا يفهم تفاصيله ولا معانيه. وهذا تأويل مجاهد. والآخر: أن الكلام على الحقيقة، وأن معناه: أنهم يوم القيامة يُنادون بكفرهم وقبيح أعمالهم من بُعْد، حتى يسمع ذلك أهل الموقف، فتعظم السمعة عليهم، ويحل المصاب. وهذا تأويل الضّحّاك بن مزاحم. ",footnotes:1:أخرجه سعيد بن منصور في سننه -التفسير ٧/٢٤٨ (١٩٠٤). وهي قراءة شاذة.أخرجه إسحاق البستي ص٢٩٦. وهي قراءة متواترة، قرأ بها هشام في وجه، وقرأ بقية العشرة: <q>﴿أأَعْجَمِيٌّ﴾</q> بهمزتين على الاستفهام، وهم على أصولهم في التحقيق وعدمه، والإدخال وعدمه. انظر: الإتحاف ص٤٨٩.أخرجه ابن جرير ٢٠/٤٤٨. وعزاه السيوطي إلى عبد بن حميد.تفسير مقاتل بن سليمان ٣/٧٤٥.عزاه السيوطي إلى ابن أبي حاتم، وابن مردويه.أخرجه ابن جرير ١/١٥. وعزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ٢٠/٤٤٧، كما أخرج نحوه من طريق جعفر، وأبي داود. وعزا السيوطيُّ إلى عبد بن حميد نحوه.أخرجه ابن جرير ٢٠/٤٤٧.أخرجه إسحاق البستي ص٢٩٧.تفسير مجاهد ص٥٨٦، وأخرجه ابن جرير ٢٠/٤٤٧.أخرجه عبد الرزاق ٢/١٨٨.أخرجه ابن جرير ٢٠/٤٤٨.أخرجه أبوجعفر الرملي في جزئه (تفسير عطاء) ص٩١.تفسير مقاتل بن سليمان ٣/٧٤٥-٧٤٦.أخرجه ابن جرير ٢٠/٤٤٩.أخرجه ابن جرير ٢٠/٤٤٩.تفسير مقاتل بن سليمان ٣/٧٤٦.أخرجه عبد الرزاق ٢/١٨٩، وابن جرير ٢٠/٤٥٠ بزيادة: فلا ينتفعون به، ولا يرغبون فيه. وعزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ٢٠/٤٥٠.تفسير مقاتل بن سليمان ٣/٧٤٦.أخرجه ابن جرير ٢٠/٤٥٠.أخرجه ابن جرير ٢٠/٤٥١ من طريق ابن جريج عن بعض أصحابه. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه ابن جرير ٢٠/٤٥١ بنحوه. وعزاه السيوطي إلى سعيد بن منصور.أخرجه أبو نعيم في حلية الأولياء ٤/١١، وفيه: عن ابن جريج، عن مجاهد، عن طاووس. ولعله: عن مجاهد، وعن طاووس.تفسير مقاتل بن سليمان ٣/٧٤٦.أخرجه ابن جرير ٢٠/٤٥١.
41,45," <q>﴿وَلَقَدۡ ءَاتَیۡنَا مُوسَى ٱلۡكِتَـٰبَ فَٱخۡتُلِفَ فِیهِۚ﴾</q> - تفسير ٦٨٧١٥- قال مقاتل بن سليمان: قوله: <q>﴿ولَقَدْ آتَيْنا مُوسى الكِتابَ﴾</q> يقول: أعطينا موسى التوراة <q>﴿فاخْتُلِفَ فِيهِ﴾</q> يقول: فكَفَر به بعضُهم{1}. (ز) <q>﴿وَلَوۡلَا كَلِمَةࣱ سَبَقَتۡ مِن رَّبِّكَ لَقُضِیَ بَیۡنَهُمۡۚ وَإِنَّهُمۡ لَفِی شَكࣲّ مِّنۡهُ مُرِیبࣲ ۝٤٥﴾</q> - تفسير ٦٨٧١٦- عن قتادة بن دعامة، في قوله: <q>﴿ولَوْلا كَلِمَةٌ سَبَقَتْ مِن رَبِّكَ﴾</q>، قال: سبق لهم مِن الله حينٌ وأجلٌ هم بالِغوه{2}. (١٣/١٢٥) ٦٨٧١٧- عن إسماعيل السُّدّيّ -من طريق أسباط- في قوله: <q>﴿ولَوْلا كَلِمَةٌ سَبَقَتْ مِن رَبِّكَ﴾</q>، قال: أُخِّروا إلى يوم القيامة{3}. (ز) ٦٨٧١٨- قال مقاتل بن سليمان: <q>﴿ولَوْلا كَلِمَةٌ سَبَقَتْ مِن رَبِّكَ﴾</q> وهي كلمة الفصل بتأخير العذاب عنهم إلى أجل مسمى، يعني: يوم القيامة، يقول: لولا ذلك الأجل <q>﴿لَقُضِيَ بَيْنَهُمْ﴾</q> يعني: بين الذين آمنوا وبين الذين اختلفوا وكفروا بالكتاب، لولا ذلك الأجل لنزل بهم العذاب في الدنيا، <q>﴿وإنَّهُمْ لَفِي شَكٍّ مِنهُ﴾</q> يعني: من الكتاب <q>﴿مُرِيبٍ﴾</q> يعني: أنّهم لا يعرفون شكّهم{1}٥٧٧٣. (ز) ٥٧٧٣ ذكر ابنُ عطية (٧/٤٩٢) أن الضمير في قوله: <q>﴿لَفِي شَكٍّ مِنهُ﴾</q> يحتمل أن يعود على موسى، أو على كتابه. ",footnotes:1:تفسير مقاتل بن سليمان ٣/٧٤٦-٧٤٧.عزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ٢٠/٤٥٣.تفسير مقاتل بن سليمان ٣/٧٤٦-٧٤٧.
41,46," <q>﴿مَّنۡ عَمِلَ صَـٰلِحࣰا فَلِنَفۡسِهِۦۖ وَمَنۡ أَسَاۤءَ فَعَلَیۡهَاۗ وَمَا رَبُّكَ بِظَلَّـٰمࣲ لِّلۡعَبِیدِ ۝٤٦﴾</q> - تفسير ٦٨٧١٩- قال مقاتل بن سليمان: <q>﴿مَن عَمِلَ صالِحًا فَلِنَفْسِهِ ومَن أساءَ العمل فَعَلَيْها﴾</q> يقول: إساءته على نفسه، <q>﴿وما رَبُّكَ بِظَلّامٍ لِلْعَبِيدِ﴾</q>{1}. (ز) ",footnotes:1:تفسير مقاتل بن سليمان ٣/٧٤٧.
