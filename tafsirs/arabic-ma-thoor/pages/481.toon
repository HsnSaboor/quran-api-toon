quran[8]{c,v,t}:
  41,39,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَمِنۡ ءَایَـٰتِهِۦۤ أَنَّكَ تَرَى ٱلۡأَرۡضَ خَـٰشِعَةࣰ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٨٦٣١<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿ومِن آياتِهِ أنَّكَ تَرى الأَرْضَ خاشِعَةً﴾</span>، قال: غبراء مُتَهَشِّمة{1}. (١٣/١١٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٨٦٣٢<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدّيّ</span> -من طريق أسباط- <span class="qpc-hafs">﴿ومِن آياتِهِ أنَّكَ تَرى الأَرْضَ خاشِعَةً﴾</span>، قال: يابسة مُهشّمة{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٨٦٣٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ومِن آياتِهِ﴾</span> أن يُعرَف التوحيدُ بصنعه وإن لم تروه <span class="qpc-hafs">﴿أنَّكَ تَرى الأَرْضَ خاشِعَةً﴾</span> متهشِّمة، غبراء لا نبْت فيها{3}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿فَإِذَاۤ أَنزَلۡنَا عَلَیۡهَا ٱلۡمَاۤءَ ٱهۡتَزَّتۡ وَرَبَتۡۚ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٨٦٣٤<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- <span class="qpc-hafs">﴿اهْتَزَّتْ﴾</span> قال: بالنبات، <span class="qpc-hafs">﴿ورَبَتْ﴾</span> قال: ارتفعت قبل أن تُنبِت{4}. (١٣/١١٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٨٦٣٥<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿فَإذا أنْزَلْنا عَلَيْها الماءَ اهْتَزَّتْ ورَبَتْ﴾</span>، قال: تعرف الغيثَ في سحْتِها وربْوها إذا ما أصابها{5}. (١٣/١١٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٨٦٣٦<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدّيّ</span> -من طريق أسباط- <span class="qpc-hafs">﴿ورَبَتْ﴾</span>: انتفخت{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٨٦٣٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فَإذا أنْزَلْنا عَلَيْها الماءَ﴾</span> يعني: على الأرض المطر، فصارت حيَّة فأنبتت، <span class="qpc-hafs">﴿واهْتَزَّتْ﴾</span> بالخضرة، <span class="qpc-hafs">﴿ورَبَتْ﴾</span> يقول: وأضْعَفَتْ النبات{3}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿إِنَّ ٱلَّذِیۤ أَحۡیَاهَا لَمُحۡیِ ٱلۡمَوۡتَىٰۤۚ إِنَّهُۥ عَلَىٰ كُلِّ شَیۡءࣲ قَدِیرٌ ۝٣٩﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٨٦٣٨<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدّيّ</span> -من طريق أسباط-: كما يُحيي الأرض بالمطر، كذلك يُحيي الموتى بالماء يوم القيامة بين النفختين. يعني بذلك: تأويل قوله: <span class="qpc-hafs">﴿إنَّ الَّذِي أحْياها لَمُحْيِ المَوْتى﴾</span>{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٨٦٣٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثم قال: <span class="qpc-hafs">﴿إنَّ الَّذِي أحْياها﴾</span> بعد موتها <span class="qpc-hafs">﴿لَمُحْيِ المَوْتى﴾</span> في الآخرة ليعتبر مَن يشكّ في البعث، <span class="qpc-hafs">﴿إنَّهُ عَلى كُلِّ شَيْءٍ قَدِيرٌ﴾</span> مِن البعث وغيره{3}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه عبد الرزاق ٢/١٨٨من طريق معمر، وابن جرير ٢٠/٤٣٨. وعزاه السيوطي إلى عبد بن حميد.|2:أخرجه ابن جرير ٢٠/٤٣٨.|3:تفسير مقاتل بن سليمان ٣/٧٤٤.|4:تفسير مجاهد ص٥٨٦، وأخرجه الفريابي -كما في التغليق ٤/٣٠٢-٣٠٣-، وابن جرير ٢٠/٤٣٨-٤٣٩ بنحوه. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.|5:أخرجه ابن جرير ٢٠/٤٣٨. وعزاه السيوطي إلى عبد الرزاق، وعبد بن حميد.|6:أخرجه ابن جرير ٢٠/٤٣٨.|7:تفسير مقاتل بن سليمان ٣/٧٤٤.|8:أخرجه ابن جرير ٢٠/٤٣٩.|9:تفسير مقاتل بن سليمان ٣/٧٤٤.
  41,40,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿إِنَّ ٱلَّذِینَ یُلۡحِدُونَ فِیۤ ءَایَـٰتِنَا لَا یَخۡفَوۡنَ عَلَیۡنَاۤۗ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٨٦٤٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطية العَوفيّ- في قوله: <span class="qpc-hafs">﴿إنَّ الَّذِينَ يُلْحِدُونَ فِي آياتِنا﴾</span>، قال: هو أن يُوضَع الكلامُ على غير موضعه{1}. (١٣/١١٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٨٦٤١<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿إنَّ الَّذِينَ يُلْحِدُونَ فِي آياتِنا﴾</span>، قال: المُكاء، وما ذُكر معه{2}. (١٣/١١٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٨٦٤٢<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿إنَّ الَّذِينَ يُلْحِدُونَ فِي آياتِنا﴾</span>: الإلحاد: التكذيب{3}. (١٣/١١٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٨٦٤٣<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدّيّ</span> -من طريق أسباط- <span class="qpc-hafs">﴿إنَّ الَّذِينَ يُلْحِدُونَ فِي آياتِنا﴾</span>، قال: يشاقّون، يُعانِدون{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٨٦٤٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: قوله: <span class="qpc-hafs">﴿إنَّ الَّذِينَ يُلْحِدُونَ فِي آياتِنا﴾</span> يعني: أبا جهل، يميل عن الإيمان بالقرآن بالأشعار والباطل، <span class="qpc-hafs">﴿لا يَخْفَوْنَ عَلَيْنا﴾</span> يعني: أبا جهل{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٨٦٤٥<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿إنَّ الَّذِينَ يُلْحِدُونَ فِي آياتِنا لا يَخْفَوْنَ عَلَيْنا﴾</span>، قال: هؤلاء أهل الشرك. وقال: الإلحاد: الكفر والشرك{4}<span class=comment-ref>٥٧٦٤</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٥٧٦٤</span> اختلف المفسرون في الإلحاد على أقوال: <b>الأول</b>: معارضة المشركين القرآن باللغط والصفير استهزاء به. <b>الثاني</b>: كذبهم في آيات الله. <b>الثالث</b>: معاندتهم. <b>الرابع</b>: تبديلهم معاني كتاب الله. <b>الخامس</b>: الكفر والشرك.</p><p>و<span class="comment-type-4">رأى</span> <u>ابنُ جرير</u> (٢٠/٤٤١-٤٤٢) تقارب الاقوال، فقال: «وكل هذه الأقوال التي ذكرناها في تأويل ذلك قريبات المعاني، وذلك أنّ اللحد والإلحاد: هو الميل، وقد يكون ميلًا عن آيات الله وعدولًا عنها بالتكذيب بها، ويكون بالاستهزاء مُكاء وتصدية، ويكون مفارقة لها وعنادًا، ويكون تحريفًا لها وتغييرًا لمعانيها».</p><p>ثم <span class="comment-type-3">رجَّح</span> <span class="mustanad">العموم</span> (٢٠/٤٤٢) فقال: «ولا قول أولى بالصحة في ذلك مما قلنا، وأن يعم الخبر عنهم بأنهم ألحدوا في آيات الله، كما عمَّ ذلك ربنا -تبارك وتعالى-».</p><p>و<span class="comment-type-4">بنحوه</span> <u>ابنُ عطية</u> (٧/٤٨٨)، فقال: «ولفظة الإلحاد تعمّ هذا كله».</div></p><p><h3><span class="qpc-hafs">﴿أَفَمَن یُلۡقَىٰ فِی ٱلنَّارِ خَیۡرٌ أَم مَّن یَأۡتِیۤ ءَامِنࣰا یَوۡمَ ٱلۡقِیَـٰمَةِۚ﴾</span> - نزول الآية، وتفسيرها</h3></p><p><div></p><p><p><span class="item-no">٦٨٦٤٦<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، في قوله: <span class="qpc-hafs">﴿أفَمَن يُلْقى فِي النّارِ خَيْرٌ﴾</span> قال: أبو جهل بن هشام، <span class="qpc-hafs">﴿أمْ مَن يَأْتِي آمِنًا يَوْمَ القِيامَةِ﴾</span> قال: أبو بكر الصّدِّيق{7}. (١٣/١٢٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٨٦٤٧<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، قال: ينطلق به إلى النار مكتوفًا، ثم يرمى به فيها، فأول ما يمس وجهه النار{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٨٦٤٨<span class="dash">-</span></span> عن عكرمة مولى ابن عباس -من طريق بشير بن تيم عمن حدّثه- في قوله: <span class="qpc-hafs">﴿أفَمَن يُلْقى فِي النّارِ خَيْرٌ أمْ مَن يَأْتِي آمِنًا يَوْمَ القِيامَةِ﴾</span>، قال: نزلت في عمّار بن ياسر، وفي أبي جهل{9}. (١٣/١٢٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٨٦٤٩<span class="dash">-</span></span> عن بشير بن تميم، قال: نزلت هذه الآية في أبي جهل وعمّار بن ياسر، <span class="qpc-hafs">﴿أفَمَن يُلْقى فِي النّارِ﴾</span> أبو جهل، <span class="qpc-hafs">﴿أمْ مَن يَأْتِي آمِنًا يَوْمَ القِيامَةِ﴾</span> عمار{10}. (١٣/١٢٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٨٦٥٠<span class="dash">-</span></span> قال مقاتل: <span class="qpc-hafs">﴿أفَمَن يُلْقى فِي النّارِ خَيْرٌ أمْ مَن يَأْتِي آمِنًا يَوْمَ القِيامَةِ﴾</span> نزلت في أبي جهل{11}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٨٦٥١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: وأخبر الله تعالى بمستقرِّه في الآخرة، فقال: <span class="qpc-hafs">﴿أفَمَن يُلْقى فِي النّارِ﴾</span> يعني: أبا جهل <span class="qpc-hafs">﴿خير أمْ مَن يَأْتِي آمِنًا يَوْمَ القِيامَةِ﴾</span> يعني: النبي ﷺ{5}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿ٱعۡمَلُوا۟ مَا شِئۡتُمۡ إِنَّهُۥ بِمَا تَعۡمَلُونَ بَصِیرٌ ۝٤٠﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٨٦٥٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، في قوله: <span class="qpc-hafs">﴿اعْمَلُوا ما شِئْتُمْ﴾</span>، قال: هذا لأهل بدر خاصة{7}. (١٣/١٢١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٨٦٥٣<span class="dash">-</span></span> عن <span class="name-2">إبراهيم النَّخعي</span>، قال: ذُكِر: أنّ السماء فُرجت يوم بدر، فقيل: اعملوا ما شئتم{14}. (١٣/١٢١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٨٦٥٤<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- <span class="qpc-hafs">﴿اعْمَلُوا ما شِئْتُمْ﴾</span>: هذا وعيد{15}. (١٣/١٢٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٨٦٥٥<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span>، قال: <span class="qpc-hafs">﴿اعْمَلُوا ما شِئْتُمْ﴾</span> فأُبيحت -واللهِ- لهم الأعمال{14}. (١٣/١٢١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٨٦٥٦<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span>، <span class="qpc-hafs">﴿اعْمَلُوا ما شِئْتُمْ﴾</span>، قال: خيَّركم، وأمرَكم بالعمل، واتخذ الحُجَّة، وبعث رسوله، وأنزل كتابه، وشرع شرائعه حجةً وتقدِمة إلى خلْقه{14}. (١٣/١٢١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٨٦٥٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثم قال لكفار مكة: <span class="qpc-hafs">﴿اعْمَلُوا ما شِئْتُمْ﴾</span> هذا وعيد، <span class="qpc-hafs">﴿إنَّهُ بِما تَعْمَلُونَ بَصِيرٌ﴾</span> من الشرك وغيره{5}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ٢٠/٤٤١. وعزاه السيوطي إلى ابن أبي حاتم.|2:تفسير مجاهد ص٥٨٦، وأخرجه ابن جرير ٢٠/٤٤٠. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.|3:أخرجه عبد الرزاق ٢/١٨٨ من طريق معمر، وابن جرير ٢٠/٤٤٠ بلفظ: يكذبون في آياتنا. وعزاه السيوطي إلى عبد بن حميد.|4:أخرجه ابن جرير ٢٠/٤٤١.|5:تفسير مقاتل بن سليمان ٣/٧٤٤.|6:أخرجه ابن جرير ٢٠/٤٤١.|7:عزاه السيوطي إلى ابن مردويه.|8:ذكره ابن جرير ٢٣/٢١٢.|9:أخرجه إسحاق البستي ص٢٩٥ دون الإشارة للنزول من طريق بشير، وابن عساكر ٤٣/٣٧٧-٣٧٨.|10:أخرجه عبد الرزاق ٢/١٨٨. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.|11:تفسير الثعلبي ٨/٢٩٨، وتفسير البغوي ٧/١٧٦.|12:تفسير مقاتل بن سليمان ٣/٧٤٤.|13:عزاه السيوطي إلى ابن مردويه.|14:عزاه السيوطي إلى عبد بن حميد.|15:أخرجه عبد الرزاق ٢/١٨٩، وعبد بن حميد -كما في التغليق ٤/٣٠٣-، وابن جرير ١١/١١٤. وعلقه البخاري في صحيحه ٤/١٨١٧. وعزاه السيوطي إلى سعيد بن منصور، وابن المنذر.|16:عزاه السيوطي إلى عبد بن حميد.|17:عزاه السيوطي إلى عبد بن حميد.|18:تفسير مقاتل بن سليمان ٣/٧٤٤.
  41,41,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿إِنَّ ٱلَّذِینَ كَفَرُوا۟ بِٱلذِّكۡرِ لَمَّا جَاۤءَهُمۡۖ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٨٦٥٨<span class="dash">-</span></span> عن عقبة بن عامر: أنّ رسول الله ﷺ تلا: <span class="qpc-hafs">﴿إنَّ الَّذِينَ كَفَرُوا بِالذِّكْرِ لَمّا جاءَهُمْ﴾</span> إلى قوله: <span class="qpc-hafs">﴿حَمِيدٍ﴾</span>، فقال: «<b>إنّكم لا ترجعوا إلى الله بشيء أحبَّ إليه مِن شيء خرج منه</b>». يعني: القرآن{1}. (١٣/١٢٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٨٦٥٩<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿إنَّ الَّذِينَ كَفَرُوا بِالذِّكْرِ﴾</span>، قال: بالقرآن{2}<span class=comment-ref>٥٧٦٥</span>. (١٣/١٢٢)</p></p><p></div></p><p><div><span class=comment-ref>٥٧٦٥</span> <span class="comment-type-4">ذكر</span> <u>ابنُ عطية</u> (٧/٤٨٩) أن الذكر هنا: هو القرآن <span class="mustanad">بإجماع</span>.</div></p><p><div></p><p><p><span class="item-no">٦٨٦٦٠<span class="dash">-</span></span> عن <span class="name-3">عيسى بن عمر</span> أنّه سأل <span class="name-3">عمرو بن عبيد</span>: <span class="qpc-hafs">﴿إنَّ الَّذِينَ كَفَرُوا بِالذِّكْرِ لَمّا جاءَهُمْ﴾</span> أين خبره؟ فقال <span class="name-3">عمرو</span>: معناه في التفسير: إنّ الذين كفروا بالذكر لما جاءهم كفروا به، <span class="qpc-hafs">﴿وإنَّهُ لِكِتابٌ عَزِيزٌ﴾</span>.= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٨٦٦١<span class="dash">-</span></span> فقال <span class="name-3">عيسى</span>: أجدْتَ، يا أبا عثمان{3}<span class=comment-ref>٥٧٦٦</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٥٧٦٦</span> اختُلف في خبر قوله تعالى: <span class="qpc-hafs">﴿إن الذين كفروا بالذكر لما جاءهم﴾</span>؛ <span class="comment-type-4">فذكر</span> <u>ابنُ عطية</u> (٧/٤٨٩) أن <b>فرقة</b> قالت: إن الخبر في قوله: <span class="qpc-hafs">﴿أُولئِكَ يُنادَوْنَ مِن مَكانٍ بَعِيدٍ﴾</span>. ونقل عن النقاش أنه ذكر أن بلال بن أبي بردة سأل عن هذا في مجلسه، وقال: لم أجد لها نفاذًا. فقال له أبو عمرو بن العلاء: إنه منك لقريب <span class="qpc-hafs">﴿أُولئِكَ يُنادَوْنَ﴾</span>. و<span class="comment-type-2">انتقده</span>، فقال: «ويردّ هذا النظر كثرةُ الحائل، وإن هنالك قومًا قد ذكروا يحسُن ردّ قوله: <span class="qpc-hafs">﴿أُولئِكَ يُنادَوْنَ﴾</span> عليهم». ثم ذكر أن <b>فرقة</b> قالت: إن الخبر مضمر، تقديره: إن الذين كفروا بالذكر لما جاءهم هلكوا أو ضلوا. وذكر أيضًا عن <b>بعض نحاة الكوفة</b> أنهم قالوا: إن الجواب في قوله: <span class="qpc-hafs">﴿وإنَّهُ لَكِتابٌ عَزِيزٌ﴾</span>. و<span class="comment-type-2">انتقده</span> بقوله: «وهو ضعيف لا يتجه». ثم ساق قول عيسى بن عمر.</p><p>و<span class="comment-type-3">رجَّح</span> مسلك إضمار الخبر، فقال: «والذي يحسن في هذا هو إضمار الخبر». ولم يذكر مستندًا، ثم <span class="comment-type-4">ذكر</span> تقديرًا آخر غير المذكور في هذا القول، فقال: «ولكنه عند قوم في غير هذا الموضع الذي قدّره هؤلاء فيه، وإنما هو بعد <span class="qpc-hafs">﴿حَكِيمٍ حَمِيدٍ﴾</span>، وهو أشد إظهارًا لمذمّة الكفار به؛ وذلك أن قوله: <span class="qpc-hafs">﴿وإنَّهُ لَكِتابٌ﴾</span> داخل في صفة الذكر المكذَّب به، فلم يتم ذكر المخبر عنه إلا بعد استيفاء وصفه، وهذا كما تقول: تخالف زيدًا وهو العالم الودود، الذي من شأنه ومن أمره. فهذه كلها أوصاف».</p><p>و<span class="comment-type-4">ذكر</span> <u>ابنُ جرير</u> (٢٠/٤٥٣) نحو هذه الأقوال، ثم <span class="comment-type-3">رجَّح</span> -<span class="mustanad">مستندًا للغة</span>- أن الأَولى في الخبر أن يكون مما تُرك ذكره اكتفاءً بمعرفة السامعين بمعناه لَمّا تطاول الكلام.</div></p><p><div></p><p><p><span class="item-no">٦٨٦٦٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿إنَّ الَّذِينَ كَفَرُوا﴾</span> يعني: أبا جهل <span class="qpc-hafs">﴿بِالذِّكْرِ لَمّا جاءَهُمْ﴾</span> يعني به: القرآن حين جاءهم، وهو أبو جهل وكفار مكة{4}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَإِنَّهُۥ لَكِتَـٰبٌ عَزِیزࣱ ۝٤١﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٨٦٦٣<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>: <span class="qpc-hafs">﴿وإنَّهُ لَكِتابٌ عَزِيزٌ﴾</span> كريم على الله{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٨٦٦٤<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿وإنَّهُ لَكِتابٌ عَزِيزٌ﴾</span> أعزّه الله؛ لأنه كلامه، وحفظه من الباطل{6}. (١٣/١٢٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٨٦٦٥<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدّيّ</span> -من طريق أسباط- <span class="qpc-hafs">﴿وإنَّهُ لَكِتابٌ عَزِيزٌ﴾</span>، قال: عزيز من الشيطان{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٨٦٦٦<span class="dash">-</span></span> قال <span class="name-2">إسماعيل السُّدّيّ</span>: <span class="qpc-hafs">﴿وإنَّهُ لَكِتابٌ عَزِيزٌ﴾</span> غير مخلوق{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٨٦٦٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وإنَّهُ لَكِتابٌ عَزِيزٌ﴾</span>، يقول: وإنه لقرآن منيع من الباطل، فلا يستذل؛ لأنه كلام الله{4}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَإِنَّهُۥ لَكِتَـٰبٌ عَزِیزࣱ ۝٤١﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٦٨٦٦٨<span class="dash">-</span></span> عن أبي سعيد الخُدري -لا أحسبه إلا أسنده إلى رسول الله ﷺ- قال: «<b>مَثَلُ القرآن ومَثَلُ الناس كمَثَلِ الأرض والغيث، بينما الأرض ميّتة هامدة، ثم يرسل الوابل فتهتزّ وتربو، ثم لا يزال يرسل الأودية حتى تَبْذر وتُنبت، ويتمّ شأنها، ويُخرج اللهُ ما فيها مِن زينتها ومعايش الناس، وكذلك فعل الله بهذا القرآن والناس</b>»{10}. (١٣/١٢١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٨٦٦٩<span class="dash">-</span></span> عن <span class="name-1">عمر بن الخطاب</span> –من طريق ابن شهاب- قال: إنّ هذا القرآنَ كلامُ الله، فضَعوه على مواضعه، ولا تتّبعوا فيه أهواءكم{11}. (١٣/١٢٠)</p></p><p></div></p></div>",footnotes:1:أخرجه الحاكم ٢/٤٧٩ (٣٦٥١).</p><p>قال الحاكم: «هذا حديث صحيح الإسناد، ولم يخرجاه»، ووافقه الذهبي. وقال الألباني في الضعيفة ٤/٤٢٦ تعقيبًا على كلام الحاكم والذهبي: «وفيه أنّ عبد الله بن صالح فيه ضعف، فلا يُحتج به إذا تفرد، فكيف إذا خالف؟! فكيف إذا كان المخالف الحافظ الثقة ابن مهدي؟! فقد أرسله كما رأيت، فأنى له الصحة؟! ولا سيما أن مداره موصولًا ومرسلًا على العلاء، وقد عرفت حاله، وقد قال الإمام البخاري في خلق أفعال العباد بعد أن ذكر الحديث معلقًا: لا يصح؛ لإرساله وانقطاعه».|2:أخرجه عبد الرزاق ٢/١٨٨ من طريق معمر، وابن جرير ٢٠/٤٤٣. وعزاه السيوطي إلى عبد بن حميد.|3:أخرجه ابن جرير ٢٠/٤٥٢.|4:تفسير مقاتل بن سليمان ٣/٧٤٤.|5:تفسير الثعلبي ٨/٢٩٨، وتفسير البغوي ٧/١٧٦.|6:أخرجه ابن الضريس (١٢٢، ١٢٣)، وابن جرير ٢٠/٤٤٣. وعزاه السيوطي إلى عبد بن حميد.|7:أخرجه ابن جرير ٢٠/٤٤٣.|8:تفسير الثعلبي ٨/٢٩٨.|9:تفسير مقاتل بن سليمان ٣/٧٤٤.|10:أخرجه أبو الشيخ الأصبهاني في أمثال الحديث ص٤٠١ (٣٤٩) بنحوه، من طريق أبي بشر محمد بن عمران بن الجنيد، ثنا يحيى بن محمد أبو بشر، ثنا يحيى بن أبي الحجاج، عن عوف، عن أبي نضرة، عن أبي سعيد به. وأورده الديلمي في الفردوس ٤/١٣٩ (٦٤٢٩). وعزاه السيوطي إلى ابن مردويه.</p><p>إسناده ضعيف؛ فيه يحيى بن محمد أبو بشر، قال عنه الذهبي في المغني في الضعفاء (٧٠٤٧): «نهى عنه أبو زرعة». وفيه أيضًا يحيى ابن أبي الحجاج، قال عنه ابن حجر في التقريب (٧٥٢٧): «ليّن الحديث».|11:أخرجه أحمد في الزهد ص٣٥.
  41,42,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿لَّا یَأۡتِیهِ ٱلۡبَـٰطِلُ مِنۢ بَیۡنِ یَدَیۡهِ وَلَا مِنۡ خَلۡفِهِۦۖ تَنزِیلࣱ مِّنۡ حَكِیمٍ حَمِیدࣲ ۝٤٢﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٨٦٧٠<span class="dash">-</span></span> عن علي بن أبي طالب، قال: قيل لرسول الله ﷺ: إنّ أُمَّتك ستُفْتَنُ مِن بعدك. فسأل رسولُ ﷺ –أو سُئل-: ما المخرج منها؟ فقال: «<b>كتاب الله العزيز، الذي لا يأتيه الباطل من بين يديه ولا من خلفه <span class="qpc-hafs">﴿تَنْزِيلٌ مِن حَكِيمٍ حَمِيدٍ﴾</span></b>»{1}. (١٣/١٢١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٨٦٧١<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span> -من طريق جعفر- <span class="qpc-hafs">﴿لا يَأْتِيهِ الباطِلُ مِن بَيْنِ يَدَيْهِ ولا مِن خَلْفِهِ﴾</span>، قال: النكير من بين يديه، ولا من خلفه{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٨٦٧٢<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span>، في قوله: <span class="qpc-hafs">﴿لا يَأْتِيهِ الباطِلُ﴾</span>، قال: الشيطان{3}. (١٣/١٢٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٨٦٧٣<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span>، <span class="qpc-hafs">﴿لا يَأْتِيهِ الباطِلُ مِن بَيْنِ يَدَيْهِ ولا مِن خَلْفِهِ﴾</span>، قال: لا يُدخِل فيه الشيطانُ ما ليس منه، ولا أحد من الكفرة{4}. (١٣/١٢٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٨٦٧٤<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق قتادة- في قوله: <span class="qpc-hafs">﴿وإنه لكتاب عزيز لا يأتيه الباطل من بين يديه ولا من خلفه﴾</span>، قال: حفظه الله مِن الشيطان، فلا يزيد فيه باطلًا، ولا ينقص منه حقًّا. ثم قرأ: <span class="qpc-hafs">﴿إنا نحن نزلنا الذكر وإنا له لحافظون﴾</span> [الحجر:٩]، قال: هذه نظيرتها{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٨٦٧٥<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿لا يَأْتِيهِ الباطِلُ مِن بَيْنِ يَدَيْهِ ولا مِن خَلْفِهِ﴾</span>، قال: والباطل إبليس، لا يستطيع أن يُنقِص منه حقًّا، ولا يزيد فيه باطلًا{6}. (١٣/١٢٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٨٦٧٦<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدّيّ</span> -من طريق أسباط- <span class="qpc-hafs">﴿لا يَأْتِيهِ الباطِلُ مِن بَيْنِ يَدَيْهِ ولا مِن خَلْفِهِ﴾</span>، قال: الباطل: هو الشيطان، لا يستطيع أن يزيد فيه حرفًا ولا ينقص{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٨٦٧٧<span class="dash">-</span></span> قال <span class="name-3">محمد بن السّائِب الكلبي</span>: <span class="qpc-hafs">﴿لا يَأْتِيهِ الباطِلُ مِن بَيْنِ يَدَيْهِ﴾</span>، يعني: من قِبَل{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٨٦٧٨<span class="dash">-</span></span> قال <span class="name-3">محمد بن السّائِب الكلبي</span>: لا يأتيه ما يُبطله ويُكَذِّبه مِن الكتب المتقدمة، بل هو مُوافِق لها مُصَدِّق، ولا يجيء بعده كتاب يبطله وينسخه، بل هو موافق لها مصدق{9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٨٦٧٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿لا يَأْتِيهِ الباطِلُ مِن بَيْنِ يَدَيْهِ﴾</span> يقول: لا يأتي القرآن بالتكذيب، بل يصدِّق هذا القرآن الكتب التي كانت قبله: التوراة والإنجيل والزبور، ثم قال: <span class="qpc-hafs">﴿ولا يأتيه﴾</span> الباطل <span class="qpc-hafs">﴿مِن خَلْفِهِ﴾</span> يقول: لا يجيئه من بعده كتاب يبطله فيكذّبه، <span class="qpc-hafs">﴿تَنْزِيلٌ﴾</span> يعني: وحي <span class="qpc-hafs">﴿مِن حَكِيمٍ﴾</span> في أمره، <span class="qpc-hafs">﴿حَمِيدٍ﴾</span> عند خلقه{10}<span class=comment-ref>٥٧٦٧</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٥٧٦٧</span> اختُلف في معنى قوله: <span class="qpc-hafs">﴿لا يأتيه الباطل من بين يديه ولا من خلفه﴾</span> على أقوال: <b>الأول</b>: لا يأتيه النكير من بين يديه ولا من خلفه. <b>الثاني</b>: لا يستطيع الشيطان أن ينقص منه حقًّا، ولا يزيد فيه باطلًا، والباطل هو الشيطان، وقوله: <span class="qpc-hafs">﴿من بين يديه﴾</span> من قبل الحق <span class="qpc-hafs">﴿ولا من خلفه﴾</span> من قبل الباطل. <b>الثالث</b>: إنّ الباطل لا يطيق أن يزيد فيه شيئًا من الحروف ولا ينقص منه شيئًا منها.</p><p>و<span class="comment-type-3">رجَّح</span> <u>ابنُ جرير</u> (٢٠/٤٤٥) العموم، فقال: «وأولى الأقوال في ذلك عندنا بالصواب أن يُقال: معناه: لا يستطيع ذو باطل بكيده تغييره، وتبديل شيء من معانيه عمّا هو به، وذلك هو الإتيان من بين يديه، ولا إلحاق ما ليس منه فيه، وذلك إتيانه من خلفه». ولم يذكر مستندًا.</p><p>وكذا <span class="comment-type-3">رجَّحه</span> <u>ابنُ عطية</u> (٧/٤٩٠) <span class="mustanad">مستندًا لظاهر اللفظ</span>، فقال: «وظاهر اللفظ يعم الشيطان، وأن يجيء أمر يبطل منه شيئًا».</div></p></div>",footnotes:1:عزاه السيوطي إلى ابن مردويه.|2:أخرجه ابن جرير ٢٠/٤٤٤.|3:عزاه السيوطي إلى عبد بن حميد، وابن المنذر.|4:عزاه السيوطي إلى عبد بن حميد.|5:أخرجه البيهقي في دلائل النبوة ٦/١٥٩.|6:أخرجه عبد الرزاق ٢/١٨٨ من طريق معمر بنحوه، وابن الضريس (١٢٢، ١٢٣)، وابن جرير ٢٠/٤٤٤. وعزاه السيوطي إلى عبد بن حميد.|7:أخرجه ابن جرير ٢٠/٤٤٥.|8:أخرجه يحيى بن سلام -كما في تفسير ابن أبي زمنين ٤/١٥٥-.|9:تفسير الثعلبي ٨/٢٩٨.|10:تفسير مقاتل بن سليمان ٣/٧٤٤-٧٤٥.
  41,43,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿مَّا یُقَالُ لَكَ إِلَّا مَا قَدۡ قِیلَ لِلرُّسُلِ مِن قَبۡلِكَۚ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٨٦٨٠<span class="dash">-</span></span> عن <span class="name-2">أبي صالح باذام</span>، في قوله: <span class="qpc-hafs">﴿ما يُقالُ لَكَ إلّا ما قَدْ قِيلَ لِلرُّسُلِ مِن قَبْلِكَ﴾</span>، قال: مِن الأذى{1}. (١٣/١٢٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٨٦٨١<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span>، في قوله: <span class="qpc-hafs">﴿ما يُقالُ لَكَ﴾</span> من التكذيب <span class="qpc-hafs">﴿إلّا ما قَدْ قِيلَ لِلرُّسُلِ مِن قَبْلِكَ﴾</span> فكما كُذِّبت فقد كُذِّبوا، وكما صبروا على أذى قومهم لهم فاصبر أنت على أذى قومك لك{2}. (١٣/١٢٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٨٦٨٢<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- في قوله تعالى: <span class="qpc-hafs">﴿ما يُقالُ لَكَ إلّا ما قَدْ قِيلَ لِلرُّسُلِ مِن قَبْلِكَ﴾</span>، قال: يُعَزِّيه. قال: يقول: قد قيل للأنبياء: ساحر، وشبه ذلك{3}. (١٣/١٢٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٨٦٨٣<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد-: يُعَزّي نبيَّه ﷺ كما تسمعون، يقول: <span class="qpc-hafs">﴿كَذَلِكَ ما أتى الَّذِينَ مِن قَبْلِهِمْ مِن رَسُولٍ إلاَّ قالُوا ساحِرٌ أومَجْنُونٌ﴾</span> [الذاريات:٥٢]{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٨٦٨٤<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدّيّ</span> -من طريق أسباط- في قوله: <span class="qpc-hafs">﴿ما يُقالُ لَكَ إلّا ما قَدْ قِيلَ لِلرُّسُلِ مِن قَبْلِكَ﴾</span>، قال: ما يقولون إلا ما قد قال المشركون للرسل من قبلك{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٨٦٨٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثم قال: <span class="qpc-hafs">﴿ما يُقالُ لَكَ﴾</span> يا محمد من التكذيب بالقرآن أنّه ليس بنازل عليك <span class="qpc-hafs">﴿إلّا ما قَدْ قِيلَ لِلرُّسُلِ مِن قَبْلِكَ﴾</span> مِن قومهم مِن التكذيب لهم أنّه ليس العذاب بنازل بهم، يعزِّي نبيَّه ﷺ ليصبر على الأذى والتكذيب{6}<span class=comment-ref>٥٧٦٨</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٥٧٦٨</span> <span class="comment-type-4">ذكر</span> <u>ابنُ عطية</u> (٧/٤٩٠) أن قوله: <span class="qpc-hafs">﴿ما يُقالُ لَكَ إلّا ما قَدْ قِيلَ لِلرُّسُلِ مِن قَبْلِكَ﴾</span> يحتمل معنيين: <b>أحدهما</b>: أن يكون تسلية للنبي ﷺ عن مقالات قومه، أي ما تلقى -يا محمدُ- من المكروه منهم، ولا يقولون لك من الأقوال المؤلمة، إلا ما قد قيل ولُقي به مَن تقدمك مِن الرسل، فلتتأسّ بهم، ولتمض لأمر الله تعالى، ولا يهمك شأنهم. <b>والثاني</b>: أن تكون الآية تلخيصًا لمعاني الشرع، أي: ما يقال لك من الوحي، وتخاطب به من جهة الله تعالى، إلا ما قد قيل للرسل من قبلك، ثم فسَّر الله تعالى ذلك الذي قيل لجميعهم وهو <span class="qpc-hafs">﴿إنَّ رَبَّكَ لَذُو مَغْفِرَة﴾</span> للطائعين، <span class="qpc-hafs">﴿وذُو عِقابٍ﴾</span> للكافرين. وفي هذه الكلمات جماع النهي والزجر الموعظة، وإليها يرجع كل نظر.</div></p><p><h3><span class="qpc-hafs">﴿إِنَّ رَبَّكَ لَذُو مَغۡفِرَةࣲ وَذُو عِقَابٍ أَلِیمࣲ ۝٤٣﴾</span> - نزول الآية، وتفسيرها</h3></p><p><div></p><p><p><span class="item-no">٦٨٦٨٦<span class="dash">-</span></span> عن سعيد بن المسيّب، قال: لَمّا نزلت هذه الآية: <span class="qpc-hafs">﴿إن ربك لذو مغفرة﴾</span> قال رسول الله ﷺ: «<b>لولا عفوُ اللهِ وتجاوزُه ما هنأ أحدًا العيش، ولولا وعيدُه وعقابُه لاتَّكل كلُّ أحد</b>»{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٨٦٨٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿إنَّ رَبَّكَ لَذُو مَغْفِرَةٍ﴾</span> يقول: ذو تَجاوُزٍ في تأخير العذاب عنهم إلى الوقت، حين سألوا العذاب في الدنيا وإذا جاء الوقت، <span class="qpc-hafs">﴿وذُو عِقابٍ﴾</span> فهو ذو عقاب <span class="qpc-hafs">﴿ألِيمٍ﴾</span> يعني: وجيع. كقوله: <span class="qpc-hafs">﴿إنْ تَكُونُوا تَأْلَمُونَ﴾</span> [النساء:١٠٤] إن كنتم تتوجعون{6}. (ز)</p></p><p></div></p></div>",footnotes:1:عزاه السيوطي إلى عبد بن حميد، وابن المنذر.|2:عزاه السيوطي إلى ابن أبي حاتم.|3:أخرجه عبد الرزاق ٢/١٨٨. وعزاه السيوطي إلى عبد بن حميد مختصرًا.|4:أخرجه ابن جرير ٢٠/٤٤٦.|5:أخرجه ابن جرير ٢٠/٤٤٦.|6:تفسير مقاتل بن سليمان ٣/٧٤٥.|7:أخرجه ابن أبي حاتم -كما في تفسير ابن كثير ٧/١٨٣-.|8:تفسير مقاتل بن سليمان ٣/٧٤٥.
  41,44,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَلَوۡ جَعَلۡنَـٰهُ قُرۡءَانًا أَعۡجَمِیࣰّا لَّقَالُوا۟ لَوۡلَا فُصِّلَتۡ ءَایَـٰتُهُۥۤۖ ءَا۬عۡجَمِیࣱّ وَعَرَبِیࣱّۗ قُلۡ هُوَ لِلَّذِینَ ءَامَنُوا۟ هُدࣰى وَشِفَاۤءࣱۚ وَٱلَّذِینَ لَا یُؤۡمِنُونَ فِیۤ ءَاذَانِهِمۡ وَقۡرࣱ وَهُوَ عَلَیۡهِمۡ عَمًىۚ أُو۟لَـٰۤىِٕكَ یُنَادَوۡنَ مِن مَّكَانِۭ بَعِیدࣲ ۝٤٤﴾</span> - قراءات</h3></p><p><div></p><p><p><span class="item-no">٦٨٦٨٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق سليمان بن قتّة- أنّه كان يقرأ: (أعْمى أُولَئِكَ){1}. (١٣/١٢٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٨٦٨٩<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق داود بن أبي هند- ‹ولَوْ جَعَلْناهُ قُرْآنًا أعْجَمِيًّا لَّقالُوا لَوْلا فُصِّلَتْ آياتُهُ أعْجَمِيٌّ وعَرَبِيٌّ›، يقول: فيه أعجمي وعربي، لا يَسْتَفْهِم= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٨٦٩٠<span class="dash">-</span></span> قال: وقال <span class="name-2">أبو الأسْود الدُّؤلي</span> مثله{2}<span class=comment-ref>٥٧٦٩</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٥٧٦٩</span> اختلف في قراءة قوله: <span class="qpc-hafs">﴿أأعجمي وعربي﴾</span>؛ <b>فقرأ الجمهور</b>: <span class="qpc-hafs">﴿أأعجمي وعربي﴾</span> على وجه الاستفهام، و<b>قرأ غيرهم</b> ذلك: ‹أعْجَمِيٌّ › بهمزة واحدة على غير مذهب الاستفهام.</p><p>و<span class="comment-type-4">ذكر</span> <u>ابنُ عطية</u> (٧/٤٩١) أن المعنى على القراءة الثانية كأنهم قالوا: عجمة وإعراب؟! إنّ هذا لشاذ. أو كأنهم قالوا لولا فصل فصلين، فكان بعضه أعجميًّا يفهمه العجم، وبعضه عربيًّا يفهمه العرب.</p><p>وبنحوه <u>ابنُ جرير</u> (٢٠/٤٤٨-٤٤٩).</p><p>و<span class="comment-type-3">رجَّح</span> <u>ابنُ جرير</u> (٢٠/٤٤٩) قراءة الجمهور <span class="mustanad">مستندًا إلى إجماع القراء</span>، فقال: «والصواب من القراءة في ذلك عندنا القراءة التي عليها قراء الأمصار؛ لإجماع الحجة عليها على مذهب الاستفهام».</div></p><p><h3><span class="qpc-hafs">﴿وَلَوۡ جَعَلۡنَـٰهُ قُرۡءَانًا أَعۡجَمِیࣰّا لَّقَالُوا۟ لَوۡلَا فُصِّلَتۡ ءَایَـٰتُهُۥۤۖ ءَا۬عۡجَمِیࣱّ وَعَرَبِیࣱّۗ قُلۡ هُوَ لِلَّذِینَ ءَامَنُوا۟ هُدࣰى وَشِفَاۤءࣱۚ وَٱلَّذِینَ لَا یُؤۡمِنُونَ فِیۤ ءَاذَانِهِمۡ وَقۡرࣱ وَهُوَ عَلَیۡهِمۡ عَمًىۚ أُو۟لَـٰۤىِٕكَ یُنَادَوۡنَ مِن مَّكَانِۭ بَعِیدࣲ ۝٤٤﴾</span> - نزول الآية</h3></p><p><div></p><p><p><span class="item-no">٦٨٦٩١<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جُبير</span> -من طريق جعفر- قال: قالت قريش: لولا أُنزِل هذا القرآن أعجميًّا وعربيًّا؟ فأنزل الله: <span class="qpc-hafs">﴿لَقالُوا لَوْلا فُصِّلَتْ آياتُهُ أأَعْجَمِيٌّ وعَرَبِيٌّ﴾</span>. وأنزل الله بعد هذه الآية فيه بكلّ لسان؛ <span class="qpc-hafs">﴿حِجارَةً مِن سِجِّيلٍ﴾</span> [الحجر:٧٤] قال: فارسية أُعرِبت: سنكَك وكَل{3}. (١٣/١٢٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٨٦٩٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ولَو جَعَلْناهُ قُرْآنًا أعْجَمِيًّا﴾</span> وذلك أنّ كفار قريش كانوا إذا رأوا النبيَّ ﷺ يدخل على يسار أبي فُكَيْهَة اليهودي، وكان أعجميّ اللسان غلام عامر بن الحضرمي القرشي يحدّثه؛ قالوا: ما يعلّمه إلا يسار أبو فُكَيْهَة. فأخذه سيدُه، فضربه، وقال له: إنّك تعلِّم محمدًا ﷺ. فقال يسار: بل هو يعلّمني. فأنزل الله ﷿: <span class="qpc-hafs">﴿ولَو جَعَلْناهُ قُرْآنًا أعْجَمِيًّا﴾</span>{4}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَلَوۡ جَعَلۡنَـٰهُ قُرۡءَانًا أَعۡجَمِیࣰّا لَّقَالُوا۟ لَوۡلَا فُصِّلَتۡ ءَایَـٰتُهُۥۤۖ ءَا۬عۡجَمِیࣱّ وَعَرَبِیࣱّۗ قُلۡ هُوَ لِلَّذِینَ ءَامَنُوا۟ هُدࣰى وَشِفَاۤءࣱۚ وَٱلَّذِینَ لَا یُؤۡمِنُونَ فِیۤ ءَاذَانِهِمۡ وَقۡرࣱ وَهُوَ عَلَیۡهِمۡ عَمًىۚ أُو۟لَـٰۤىِٕكَ یُنَادَوۡنَ مِن مَّكَانِۭ بَعِیدࣲ ۝٤٤﴾</span> - تفسير الآية</h3></p><p><div></p><p><p><span class="item-no">٦٨٦٩٣<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، في قوله: <span class="qpc-hafs">﴿ولَو جَعَلْناهُ قُرْآنًا أعْجَمِيًّا﴾</span> يقول: لو جعلنا القرآنَ أعجميًّا، ولسانك يا محمد عربي؛ لقالوا: أأعجمي وعربي يأتينا به مختلِفًا أو مختلِطًا <span class="qpc-hafs">﴿لَقالُوا لَوْلا فُصِّلَتْ آياتُهُ﴾</span> هلا بُيِّنتْ آياته، فكان القرآن مثل اللسان. يقول: فلم يفعل لئلّا يقولوا، فكانت حجة عليهم{5}. (١٣/١٢٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٨٦٩٤<span class="dash">-</span></span> عن <span class="name-2">أبي مَيْسرة [عمرو بن شرحبيل]</span> -من طريق أبي إسحاق- قال: <span class="qpc-hafs">﴿ولَوجَعَلْناهُ قُرْآنًا أعْجَمِيًّا﴾</span> في القرآن بكلّ لسان{6}. (١٣/١٢٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٨٦٩٥<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جُبير</span> -من طريق أبي بشر- أنه قال في هذه الآية: <span class="qpc-hafs">﴿لَوْلا فُصِّلَتْ آياتُهُ أأَعْجَمِيٌّ وعَرَبِيٌّ﴾</span>، قال: لو كان هذا القرآن أعجميًّا لقالوا: القرآن أعجمي، ومحمد عربي{7}. (١٣/١٢٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٨٦٩٦<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن مُطِيع</span> -من طريق محمد بن أبي موسى-، بنحوه{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٨٦٩٧<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جُبير</span> -من طريق داود بن أبي هند- <span class="qpc-hafs">﴿لولا فصلت ءاياته ءاعجمي وعربي﴾</span>: يقول: كتاب أعجمي ورسول عربي؟! يَسْتفهِم{9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٨٦٩٨<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نَجِيح- في قوله: <span class="qpc-hafs">﴿لَوْلا فُصِّلَتْ آياتُهُ﴾</span>: فجُعِل عربيًّا، أعجمي الكلام وعربي الرجل؟!{10}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٨٦٩٩<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- في قوله تعالى: <span class="qpc-hafs">﴿لَوْلا فُصِّلَتْ آياتُهُ أأَعْجَمِيٌّ﴾</span>، قال: يقول: لولا بُيِّنت آياته أعجمي وعربي، لقالوا: هذا القرآن أعجمي وهذا النبي عربي، فيقول: لكان ذلك أشد لتكذيبهم{11}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٨٧٠٠<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدّيّ</span> -من طريق أسباط- في قوله: <span class="qpc-hafs">﴿ولَوجَعَلْناهُ قُرْآنًا أعْجَمِيًّا لَقالُوا لَوْلا فُصِّلَتْ آياتُهُ أأَعْجَمِيٌّ وعَرَبِيٌّ﴾</span>: يقول: بُيِّنت آياته أأعجمي وعربي، نحن قوم عرب ما لنا وللعُجْمة؟!{12}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٨٧٠١<span class="dash">-</span></span> عن <span class="name-2">عطاء الخُراساني</span> -من طريق يونس بن يزيد- في قوله ﷿: <span class="qpc-hafs">﴿قرآنا أعجميا﴾</span>: قال تعالى: لو أنزلناه أعجميًّا لقالوا: فصِّلوه لنا بالعربية{13}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٨٧٠٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ولَو جَعَلْناهُ قُرْآنًا أعْجَمِيًّا﴾</span> يقول: بلسان العجم <span class="qpc-hafs">﴿لَقالُوا﴾</span> لقال كفار مكة: <span class="qpc-hafs">﴿لَوْلا فُصِّلَتْ﴾</span> يقول: هلا بُيِّنت <span class="qpc-hafs">﴿آياتُهُ﴾</span> بالعربية؛ حتى نفقه ونعلم ما يقول محمد <span class="qpc-hafs">﴿أعْجَمِيٌّ﴾</span> ولقالوا: إنّ القرآن أعجمي أُنزل على محمد، وهو <span class="qpc-hafs">﴿عَرَبِيٌّ قُلْ﴾</span> نزّله الله عربيًّا لكي يفقهوه، ولا يكون لهم علة{14}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿قُلۡ هُوَ لِلَّذِینَ ءَامَنُوا۟ هُدࣰى وَشِفَاۤءࣱۚ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٨٧٠٣<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿قُلْ هُولِلَّذِينَ آمَنُوا هُدًى وشِفاءٌ﴾</span>، قال: جعله الله نورًا، وبركة، وشفاء للمؤمنين{15}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٨٧٠٤<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدّيّ</span> -من طريق أسباط- <span class="qpc-hafs">﴿قُلْ هُو لِلَّذِينَ آمَنُوا هُدًى وشِفاءٌ﴾</span>، قال: القرآن{15}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٨٧٠٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: يقول الله تعالى: <span class="qpc-hafs">﴿هُولِلَّذِينَ آمَنُوا هُدىً﴾</span> مِن الضلالة، <span class="qpc-hafs">﴿وشِفاءٌ﴾</span> لما في القلوب؛ لِلَّذي فيه مِن التبيان{17}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَٱلَّذِینَ لَا یُؤۡمِنُونَ فِیۤ ءَاذَانِهِمۡ وَقۡرࣱ وَهُوَ عَلَیۡهِمۡ عَمًىۚ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٨٧٠٦<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- <span class="qpc-hafs">﴿وهُوعَلَيْهِمْ عَمًى﴾</span>، قال: عَمُوا عن القرآن، وصمُّوا عنه{18}. (١٣/١٢٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٨٧٠٧<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدّيّ</span> -من طريق أسباط- <span class="qpc-hafs">﴿والَّذِينَ لا يُؤْمِنُونَ فِي آذانِهِمْ وقْرٌ﴾</span> قال: صَمم، <span class="qpc-hafs">﴿وهُو عَلَيْهِمْ عَمًى﴾</span> قال: عَمِيَت قلوبُهم عنه{19}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٨٧٠٨<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثم قال: <span class="qpc-hafs">﴿والَّذِينَ لا يُؤْمِنُونَ﴾</span> بالآخرة، يعني: لا يُصَدِّقون بالبعث الذي فيه جزاء الأعمال <span class="qpc-hafs">﴿فِي آذانِهِمْ وقْر﴾</span> يعني: ثِقَل؛ فلا يسمعون الإيمان بالقرآن، <span class="qpc-hafs">﴿وهُوعَلَيْهِمْ عَمًى﴾</span> يعني: عمُوا عنه، يعني: القرآن؛ فلم يُبْصِروه، ولم يفقهوه{17}<span class=comment-ref>٥٧٧٠</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٥٧٧٠</span> <span class="comment-type-4">ذكر</span> <u>ابنُ عطية</u> (٧/٤٩١) هذا القول، ثم <span class="comment-type-4">ذكر</span> أنّ قومًا قالوا بأن المراد بـ«هو»: الوَقر.</div></p><p><div></p><p><p><span class="item-no">٦٨٧٠٩<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿وهُوعَلَيْهِمْ عَمًى﴾</span>، قال: العمى: الكفر{19}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿أُو۟لَـٰۤىِٕكَ یُنَادَوۡنَ مِن مَّكَانِۭ بَعِیدࣲ ۝٤٤﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٨٧١٠<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن جُريْج- في قوله: <span class="qpc-hafs">﴿أُولَئِكَ يُنادَوْنَ مِن مَكانٍ بَعِيدٍ﴾</span>، قال: بعيد مِن قلوبهم{22}<span class=comment-ref>٥٧٧١</span>. (١٣/١٢٥)</p></p><p></div></p><p><div><span class=comment-ref>٥٧٧١</span> ساق <u>ابنُ كثير</u> (١٢/٢٤٧) هذا القول الذي قاله مجاهد، وابن زيد، ومقاتل، ثم قال: «وهذا <span class="mustanad">كقوله</span>: <span class="qpc-hafs">﴿ومثل الذين كفروا كمثل الذي ينعق بما لا يسمع إلا دعاء ونداء صم بكم عمي فهم لا يعقلون﴾</span> [البقرة:١٧١]».</div></p><p><div></p><p><p><span class="item-no">٦٨٧١١<span class="dash">-</span></span> عن <span class="name-2">الضَّحّاك بن مُزاحِم</span> -من طريق أجلح- في قوله: <span class="qpc-hafs">﴿أُولَئِكَ يُنادَوْنَ مِن مَكانٍ بَعِيدٍ﴾</span>، قال: يُنادون يوم القيامة بأشنع أسمائهم{23}. (١٣/١٢٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٨٧١٢<span class="dash">-</span></span> عن <span class="name-2">طاووس</span> -من طريق ابن جُريْج- <span class="qpc-hafs">﴿أولئك ينادون من مكان بعيد﴾</span>، قال: بعيد من قلوبهم{24}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٨٧١٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿أُولئِكَ يُنادَوْنَ مِن مَكانٍ بَعِيدٍ﴾</span> إلى الإيمان بأنّه غير كائن؛ لأنهم صمٌّ عنه، وعُمْيٌ، وفي آذانهم وقر{17}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٨٧١٤<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿أُولَئِكَ يُنادَوْنَ مِن مَكانٍ بَعِيدٍ﴾</span>، قال: ضيّعوا أن يقبلوا الأمرَ مِن قريب؛ يتوبون ويؤمنون، فيُقبل منهم، فأبوا{26}<span class=comment-ref>٥٧٧٢</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٥٧٧٢</span> <span class="comment-type-4">ذكر</span> <u>ابنُ عطية</u> (٧/٤٩١) أن قوله تعالى: <span class="qpc-hafs">﴿أُولئِكَ يُنادَوْنَ﴾</span> يحتمل معنيين، وكلاهما مقول للمفسرين: <b>أحدهما</b>: أنها استعارة لقلة فهمهم، شبّههم بالرجل ينادى على بعد يُسمع منه الصوت ولا يفهم تفاصيله ولا معانيه. وهذا تأويل مجاهد. <b>والآخر</b>: أن الكلام على الحقيقة، وأن معناه: أنهم يوم القيامة يُنادون بكفرهم وقبيح أعمالهم من بُعْد، حتى يسمع ذلك أهل الموقف، فتعظم السمعة عليهم، ويحل المصاب. وهذا تأويل الضّحّاك بن مزاحم.</div></p></div>",footnotes:1:أخرجه سعيد بن منصور في سننه -التفسير ٧/٢٤٨ (١٩٠٤).</p><p>وهي قراءة شاذة.|2:أخرجه إسحاق البستي ص٢٩٦.</p><p>وهي قراءة متواترة، قرأ بها هشام في وجه، وقرأ بقية العشرة: <span class="qpc-hafs">﴿أأَعْجَمِيٌّ﴾</span> بهمزتين على الاستفهام، وهم على أصولهم في التحقيق وعدمه، والإدخال وعدمه. انظر: الإتحاف ص٤٨٩.|3:أخرجه ابن جرير ٢٠/٤٤٨. وعزاه السيوطي إلى عبد بن حميد.|4:تفسير مقاتل بن سليمان ٣/٧٤٥.|5:عزاه السيوطي إلى ابن أبي حاتم، وابن مردويه.|6:أخرجه ابن جرير ١/١٥. وعزاه السيوطي إلى عبد بن حميد.|7:أخرجه ابن جرير ٢٠/٤٤٧، كما أخرج نحوه من طريق جعفر، وأبي داود. وعزا السيوطيُّ إلى عبد بن حميد نحوه.|8:أخرجه ابن جرير ٢٠/٤٤٧.|9:أخرجه إسحاق البستي ص٢٩٧.|10:تفسير مجاهد ص٥٨٦، وأخرجه ابن جرير ٢٠/٤٤٧.|11:أخرجه عبد الرزاق ٢/١٨٨.|12:أخرجه ابن جرير ٢٠/٤٤٨.|13:أخرجه أبوجعفر الرملي في جزئه (تفسير عطاء) ص٩١.|14:تفسير مقاتل بن سليمان ٣/٧٤٥-٧٤٦.|15:أخرجه ابن جرير ٢٠/٤٤٩.|16:أخرجه ابن جرير ٢٠/٤٤٩.|17:تفسير مقاتل بن سليمان ٣/٧٤٦.|18:أخرجه عبد الرزاق ٢/١٨٩، وابن جرير ٢٠/٤٥٠ بزيادة: فلا ينتفعون به، ولا يرغبون فيه. وعزاه السيوطي إلى عبد بن حميد.|19:أخرجه ابن جرير ٢٠/٤٥٠.|20:تفسير مقاتل بن سليمان ٣/٧٤٦.|21:أخرجه ابن جرير ٢٠/٤٥٠.|22:أخرجه ابن جرير ٢٠/٤٥١ من طريق ابن جريج عن بعض أصحابه. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.|23:أخرجه ابن جرير ٢٠/٤٥١ بنحوه. وعزاه السيوطي إلى سعيد بن منصور.|24:أخرجه أبو نعيم في حلية الأولياء ٤/١١، وفيه: عن ابن جريج، عن مجاهد، عن طاووس. ولعله: عن مجاهد، وعن طاووس.|25:تفسير مقاتل بن سليمان ٣/٧٤٦.|26:أخرجه ابن جرير ٢٠/٤٥١.
  41,45,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَلَقَدۡ ءَاتَیۡنَا مُوسَى ٱلۡكِتَـٰبَ فَٱخۡتُلِفَ فِیهِۚ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٨٧١٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: قوله: <span class="qpc-hafs">﴿ولَقَدْ آتَيْنا مُوسى الكِتابَ﴾</span> يقول: أعطينا موسى التوراة <span class="qpc-hafs">﴿فاخْتُلِفَ فِيهِ﴾</span> يقول: فكَفَر به بعضُهم{1}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَلَوۡلَا كَلِمَةࣱ سَبَقَتۡ مِن رَّبِّكَ لَقُضِیَ بَیۡنَهُمۡۚ وَإِنَّهُمۡ لَفِی شَكࣲّ مِّنۡهُ مُرِیبࣲ ۝٤٥﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٨٧١٦<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span>، في قوله: <span class="qpc-hafs">﴿ولَوْلا كَلِمَةٌ سَبَقَتْ مِن رَبِّكَ﴾</span>، قال: سبق لهم مِن الله حينٌ وأجلٌ هم بالِغوه{2}. (١٣/١٢٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٨٧١٧<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدّيّ</span> -من طريق أسباط- في قوله: <span class="qpc-hafs">﴿ولَوْلا كَلِمَةٌ سَبَقَتْ مِن رَبِّكَ﴾</span>، قال: أُخِّروا إلى يوم القيامة{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٨٧١٨<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ولَوْلا كَلِمَةٌ سَبَقَتْ مِن رَبِّكَ﴾</span> وهي كلمة الفصل بتأخير العذاب عنهم إلى أجل مسمى، يعني: يوم القيامة، يقول: لولا ذلك الأجل <span class="qpc-hafs">﴿لَقُضِيَ بَيْنَهُمْ﴾</span> يعني: بين الذين آمنوا وبين الذين اختلفوا وكفروا بالكتاب، لولا ذلك الأجل لنزل بهم العذاب في الدنيا، <span class="qpc-hafs">﴿وإنَّهُمْ لَفِي شَكٍّ مِنهُ﴾</span> يعني: من الكتاب <span class="qpc-hafs">﴿مُرِيبٍ﴾</span> يعني: أنّهم لا يعرفون شكّهم{1}<span class=comment-ref>٥٧٧٣</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٥٧٧٣</span> <span class="comment-type-4">ذكر</span> <u>ابنُ عطية</u> (٧/٤٩٢) أن الضمير في قوله: <span class="qpc-hafs">﴿لَفِي شَكٍّ مِنهُ﴾</span> يحتمل أن يعود على موسى، أو على كتابه.</div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٣/٧٤٦-٧٤٧.|2:عزاه السيوطي إلى عبد بن حميد.|3:أخرجه ابن جرير ٢٠/٤٥٣.|4:تفسير مقاتل بن سليمان ٣/٧٤٦-٧٤٧.
  41,46,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿مَّنۡ عَمِلَ صَـٰلِحࣰا فَلِنَفۡسِهِۦۖ وَمَنۡ أَسَاۤءَ فَعَلَیۡهَاۗ وَمَا رَبُّكَ بِظَلَّـٰمࣲ لِّلۡعَبِیدِ ۝٤٦﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٨٧١٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿مَن عَمِلَ صالِحًا فَلِنَفْسِهِ ومَن أساءَ العمل فَعَلَيْها﴾</span> يقول: إساءته على نفسه، <span class="qpc-hafs">﴿وما رَبُّكَ بِظَلّامٍ لِلْعَبِيدِ﴾</span>{1}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٣/٧٤٧.