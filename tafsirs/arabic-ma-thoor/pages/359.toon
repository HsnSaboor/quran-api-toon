quran[5]{c,v,t}:
24,62," <q>﴿إِنَّمَا ٱلۡمُؤۡمِنُونَ ٱلَّذِینَ ءَامَنُوا۟ بِٱللَّهِ وَرَسُولِهِۦ وَإِذَا كَانُوا۟ مَعَهُۥ عَلَىٰۤ أَمۡرࣲ جَامِعࣲ لَّمۡ یَذۡهَبُوا۟ حَتَّىٰ یَسۡتَـٔۡذِنُوهُۚ إِنَّ ٱلَّذِینَ یَسۡتَـٔۡذِنُونَكَ أُو۟لَـٰۤىِٕكَ ٱلَّذِینَ یُؤۡمِنُونَ بِٱللَّهِ وَرَسُولِهِۦۚ فَإِذَا ٱسۡتَـٔۡذَنُوكَ لِبَعۡضِ شَأۡنِهِمۡ فَأۡذَن لِّمَن شِئۡتَ مِنۡهُمۡ وَٱسۡتَغۡفِرۡ لَهُمُ ٱللَّهَۚ إِنَّ ٱللَّهَ غَفُورࣱ رَّحِیمࣱ ۝٦٢﴾</q> - نزول الآية ٥٤١٩١- عن عروة بن الزبير= (ز) ٥٤١٩٢- ومحمد بن كعب القرظي، قالا: لَمّا أقبلت قريشٌ عامَ الأحزاب نزلوا بمَجْمَع الأَسْيال{1} مِن رُومة -بئر بالمدينة-، قائدها أبو سفيان، وأقبلت غطفان حتى نزلوا بنقمين{2} إلى جانب أحد، وجاء رسولَ الله ﷺ الخبرُ، فضرب الخندق على المدينة، وعمل فيه، وعمل المسلمون فيه، وأبطأ رجال مِن المنافقين، وجعلوا يُوَرُّون بالضعيف مِن العمل، فيتسللون إلى أهليهم بغير علم من رسول الله ﷺ ولا إذن، وجعل الرجلُ مِن المسلمين إذا نابته النّائبة من الحاجة التي لا بُدَّ منها يذكر ذلك لرسول الله ﷺ، ويستأذنه في اللحوق لحاجته، فيأذن له، فإذا قضى حاجته رجع؛ فأنزل الله في أولئك المؤمنين: <q>﴿انما المؤمنون الذين آمنوا بالله ورسوله واذا كانوا معه على أمر جامع﴾</q> إلى قوله: <q>﴿والله بكل شيء عليم﴾</q>{3}. (١١/١٢٥) ٥٤١٩٣- عن الضحاك بن مزاحم، في قوله: <q>﴿لا يستأذنك الذين يؤمنون بالله﴾</q> الآية [التوبة:٤٤]، قال: كان لا يستأذنه إذا غزا إلا المنافقون، فكان لا يحل لأحد أن يستأذن رسول الله ﷺ أو يتخلف بعده إذا غزا، ولا تنطلق سرية إلا بإذنه، ولم يجعل الله للنبي ﷺ أن يأذن لأحد، حتى نزلت الآية: <q>﴿انما المؤمنون الذين آمنوا بالله ورسوله واذا كانوا معه على أمر جامع﴾</q> يقول: أمر طاعة؛ <q>﴿لم يذهبوا حتى يستأذنوه﴾</q> الآية، فجعل الإذن إليه، يأذن لمن يشاء، فكان إذا جمع رسول الله ﷺ الناسَ لأمر يأمرهم وينهاهم صبر المؤمنون في مجالسهم، وأحبُّوا ما أحدث لهم رسول الله ﷺ بما يُوحى إليه، وبما أحبوا وكرهوا، فإذا كان شيء مما يكره المنافقون خرجوا يتسللون، يلوذ الرجل بالرجل، يستتر لكي لا يراه النبي ﷺ، فقال الله تعالى: إنّ الله يُبصِر الذين يتسللون منكم لِواذًا{4}. (١١/١٣٢) ٥٤١٩٤- قال مقاتل بن سليمان: نزلت في عمر بن الخطاب، في غزاة تبوك، وذلك أنّه استأذن النبيَّ ﷺ في الرجعة{5} إلى أهله، فقال النبي ﷺ: «انطلق، فواللهِ، ما أنت بمنافق». يُريد أن يُسمع المنافقين، فلمّا سمعوا ذلك قالوا: ما بال محمد إذا استأذنه أصحابه أذِن لهم، فإذا استأذنّاه لم يأذن لنا، فواللاتِ، ما نراه يعدل، وإنّما زعم أنه جاء ليعدل{6}. (ز) <q>﴿إِنَّمَا ٱلۡمُؤۡمِنُونَ ٱلَّذِینَ ءَامَنُوا۟ بِٱللَّهِ وَرَسُولِهِۦ وَإِذَا كَانُوا۟ مَعَهُۥ عَلَىٰۤ أَمۡرࣲ جَامِعࣲ لَّمۡ یَذۡهَبُوا۟ حَتَّىٰ یَسۡتَـٔۡذِنُوهُۚ﴾</q> - تفسير ٥٤١٩٥- عن عبد الله بن عباس -من طريق عكرمة-: قوله ﷿: <q>﴿إنما المؤمنون الذين آمنوا بالله ورسوله وإذا كانوا معه على أمر جامع لم يذهبوا﴾</q> أي: لم يمضوا <q>﴿حتى يستأذنوه﴾</q>{7}. (ز) ٥٤١٩٦- عن عبد الله بن عباس -من طريق العوفي- في قوله: <q>﴿على أمر جامع﴾</q>، قال: مِن طاعة الله{8}. (١١/١٢٦) ٥٤١٩٧- عن قتادة بن دعامة= (ز) ٥٤١٩٨- والضحاك بن مزاحم، نحو ذلك{9}. (ز) ٥٤١٩٩- عن سعيد بن جبير= (ز) ٥٤٢٠٠- وابن أبي مليكة -من طريق ثابت بن العجلان- في الآية، قال: هي في الجهاد، والجمعة، والعيدين{10}. (١١/١٢٦) ٥٤٢٠١- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿واذا كانوا معه على أمر جامع لم يذهبوا حتى يستأذنوه﴾</q>، قال: ذلك في الغزو والجمعة، وإذن الإمام يوم الجمعة أن يشير بيده{11}. (١١/١٢٦) ٥٤٢٠٢- ذكر يحيى بن سلّام عن قتادة: أنّ الآية عنده في الجهاد.= (ز) ٥٤٢٠٣- وعن مجاهد: <q>﴿وإذا كانوا معه على أمر جامع﴾</q> على أمر طاعة. قال يحيى بن سلّام: وهو واحد{12}. (ز) ٥٤٢٠٤- عن مكحول الشامي، في قوله: <q>﴿واذا كانوا معه على أمر جامع﴾</q>، قال: إذا جمعهم لأمر حَزَبَهم مِن الحرب ونحوه؛ لم يذهبوا حتى يستأذنوه{13}. (١١/١٢٦) ٥٤٢٠٥- عن مكحول الشامي -من طريق ابن جريج- في الآية، قال: يعمل بها الآن في الجمعة والزحف وفي كل أمر جامع، قد أمر أن لا يذهب أحد في يوم جمعة حتى يستأذن الإمام، وكذلك في كل جامع، ألا ترى أنه يقول: <q>﴿وإذا كانوا معه على أمر جامع﴾</q>{14}. (١١/١٢٧) ٥٤٢٠٦- عن مكحول الشامي -من طريق ابن جريج-: كانت الجمعة مِن تلك الأمور الجامعة التي يستأذن الرجل فيها. قال: إذا كان ذلك وضع الرجل يده اليسرى على أنفه، ثم يأتي فيشير بيده اليمنى إلى الإمام، فيشير إليه الإمام، فيذهب{15}. (١١/١٢٧) ٥٤٢٠٧- عن ابن جريج، [نحو ذلك، وعطاء بن أبي رباح يسمع]= (ز) ٥٤٢٠٨- فقال عطاء عند ذلك: قد أدركتُ -لَعَمْري- الناسَ فيما مضى يستأذنون الإمام إذا قاموا وهو يخطب. قلتُ: كيف رأيتهم يستأذنون؟ قال: يشير الرجل بيده. فأشار لي عطاء بيده اليمنى، قلت: يشير ولا يتكلم؟ قال: نعم. قلت: الإمام إذًا أذِن؟ قال: يشير ولا يتكلم. قلت: ولا يضع الإنسان يده على أنفه، ولا على ثوبه؟ قال: لا{16}. (ز) ٥٤٢٠٩- قال معمر: وقد سمعت قتادة يقول: في الجمعة، وفي الغزو أيضًا{17}. (ز) ٥٤٢١٠- عن محمد ابن شهاب الزهري -من طريق مَعْمَر- في قوله: <q>﴿وإذا كانوا معه على أمر جامع﴾</q>، قال: هو الجمعة، إذا كانوا معه فيها لم يذهبوا حتى يستأذنوه{18}. (ز) ٥٤٢١١- عن أبي حمزة الثمالي -من طريق علي بن علي- في هذه الآية، قال: هو يوم الجمعة، وكان رسول الله ﷺ إذا صعِد المنبر يوم الجمعة، وأراد الرجل أن يقضي الحاجة، والرجل به العلّة، لم يخرج من المسجد حتى يقوم بحيال رسول الله ﷺ حيث يراه، فيعرف رسول الله ﷺ أنّه إنّما قام ليستأذن، فيأذن لمن شاء منهم{19}. (ز) ٥٤٢١٢- قال صفوان بن عمرو: أنّ أبا اليمان الهوزني أخبرني: أنه لا يخرج أحد من تحت رايته في المُصافِّ{20} والمسالح{21} إلا بإذن إمامه، وفي ذلك يقول -جلَّ وعزَّ-: <q>﴿وإذا كانوا معه على أمر جامع لم يذهبوا حتى يستأذنوه﴾</q>{22}. (ز) ٥٤٢١٣- قال محمد بن السائب الكلبي -من طريق مَعْمَر-: كان ذلك مع رسول الله ﷺ، فأمّا اليوم فإنّ إذنه أن يأخذ بأنفه، وينصرف{23}. (ز) ٥٤٢١٤- قال مقاتل بن سليمان: <q>﴿إنما المؤمنون الذين آمنوا بالله ورسوله وإذا كانوا معه﴾</q> أي: النبي ﷺ <q>﴿على أمر جامع﴾</q> يقول: إذا اجتمعوا على أمر هو لله ﷿ طاعة؛ <q>﴿لم يذهبوا﴾</q> يعني: لم يُفارِقوا النبي ﷺ <q>﴿حتى يستأذنوه﴾</q>{24}. (ز) ٥٤٢١٥- عن مقاتل بن حيان -من طريق بكير بن معروف- قوله: <q>﴿واذا كانوا معه على أمر جامع﴾</q>، يقول: على أمر طاعة يجتمعون عليها، نحو الجمعة، والنحر، والفطر، والجهاد، وأشباه ذلك مما ينفعهم الله به{15}. (ز) ٥٤٢١٦- قال عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿إنما المؤمنون الذين آمنوا بالله ورسوله وإذا كانوا معه على أمر جامع لم يذهبوا حتى يستأذنوه﴾</q>، قال: الأمر الجامع حين يكونون معه في جماعة الحرب أو جمعة. قال: والجمعة من الأمر الجامع، لا ينبغي لأحد أن يخرج إذا قعد الإمام على المنبر يوم الجمعة إلا بإذن سلطان، إذا كان حيث يراه أو يقدر عليه، ولا يخرج إلا بإذن، وإذا كان حيث لا يراه ولا يقدر عليه ولا يصل إليه فاللهُ أوْلى بالعُذْر{26}. (ز) ٥٤٢١٧- قال يحيى بن سلّام: <q>﴿إنما المؤمنون الذين آمنوا بالله ورسوله وإذا كانوا معه على أمر جامع﴾</q> الجمعة، والعيدين، والاستسقاء، وكل شيء تكون فيه الخطبة؛ <q>﴿لم يذهبوا حتى يستأذنوه﴾</q>{27}. (ز) <q>﴿إِنَّ ٱلَّذِینَ یَسۡتَـٔۡذِنُونَكَ أُو۟لَـٰۤىِٕكَ ٱلَّذِینَ یُؤۡمِنُونَ بِٱللَّهِ وَرَسُولِهِۦۚ فَإِذَا ٱسۡتَـٔۡذَنُوكَ لِبَعۡضِ شَأۡنِهِمۡ فَأۡذَن لِّمَن شِئۡتَ مِنۡهُمۡ وَٱسۡتَغۡفِرۡ لَهُمُ ٱللَّهَۚ إِنَّ ٱللَّهَ غَفُورࣱ رَّحِیمࣱ ۝٦٢﴾</q> - تفسير ٥٤٢١٨- عن عبد الله بن عباس -من طريق عطاء الخراساني، عن عكرمة-: قوله ﷿: <q>﴿فإذا استأذنوك لبعض شأنهم فأذن لمن شئت منهم واستغفر لهم الله إن الله غفور رحيم﴾</q>، فجعل رسولُ الله ﷺ بأعلى النظرين؛ مَن غزا غزا مِن فضله، ومَن قعد قعد مِن غير حَرَجٍ -إن شاء الله-{28}. (ز) ٥٤٢١٩- عن سعيد بن جبير -من طريق عطاء- في قوله: <q>﴿أولئك﴾</q>، يعني: الذين فعلوا ما ذُكِر في هذه الآية. وفي قوله: <q>﴿يؤمنون بالله ورسوله﴾</q>، يعني: يُصَدِّقون بتوحيد الله. وفي قوله: <q>﴿إن الله غفور﴾</q> لِما كان منهم، <q>﴿رحيم﴾</q> بهم بعد التوبة{29}. (ز) ٥٤٢٢٠- قال مقاتل بن سليمان: <q>﴿فإذا استأذنوك لبعض شأنهم﴾</q> يعني: لبعض أمرهم؛ <q>﴿فأذن لمن شئت منهم﴾</q> يعني: مِن المؤمنين، <q>﴿واستغفر لهم﴾</q> يعني: للمؤمنين <q>﴿الله إن الله غفور رحيم﴾</q>{24}. (ز) ٥٤٢٢١- قال يحيى بن سلّام: <q>﴿إن الذين يستأذنونك أولئك الذين يؤمنون بالله ورسوله﴾</q> أي: مخلصين غير منافقين، <q>﴿فإذا استأذنوك لبعض شأنهم﴾</q> كما أمر الله عن الغائط والبول؛ <q>﴿فأذن لمن شئت منهم﴾</q> وقد أوجب الله على النبيِّ والإمام بعده أن يأذن لهم؛ ولكن زاد الله بذلك إكرام النبي ﵇ وإعظام منزلته. فإذا كانت لرجل حاجةٌ قام حيال الإمام، وأمسك بأنفه، وأشار بيده{27}. (ز) <q>﴿إِنَّ ٱلَّذِینَ یَسۡتَـٔۡذِنُونَكَ أُو۟لَـٰۤىِٕكَ ٱلَّذِینَ یُؤۡمِنُونَ بِٱللَّهِ وَرَسُولِهِۦۚ فَإِذَا ٱسۡتَـٔۡذَنُوكَ لِبَعۡضِ شَأۡنِهِمۡ فَأۡذَن لِّمَن شِئۡتَ مِنۡهُمۡ وَٱسۡتَغۡفِرۡ لَهُمُ ٱللَّهَۚ إِنَّ ٱللَّهَ غَفُورࣱ رَّحِیمࣱ ۝٦٢﴾</q> - النسخ في الآية ٥٤٢٢٢- عن عبد الله بن عباس -من طريق عطاء الخراساني، عن عكرمة- قوله ﷿: <q>﴿لا يستأذنك الذين يؤمنون بالله واليوم الآخر أن يجاهدوا بأموالهم وأنفسهم والله عليم بالمتقين﴾</q> [التوبة:٤٤]، وقال: <q>﴿إنما يستأذنك الذين لا يؤمنون بالله واليوم الآخر وارتابت قلوبهم فهم في ريبهم يترددون﴾</q> [التوبة:٤٥]، فنسختها الآية التي في سورة النور، فقال: <q>﴿إنما المؤمنون الذين آمنوا بالله ورسوله وإذا كانوا معه على أمر جامع لم يذهبوا﴾</q>{32}. (ز) ٥٤٢٢٣- عن قتادة بن دعامة -من طريق سعيد-: أنها نَسَخَت الآيةَ في براءة: <q>﴿عفا الله عنك لم أذنت لهم حتى يتبين لك الذين صدقوا وتعلم الكاذبين﴾</q> [التوبة:٤٣]، وهي عنده في الجهاد؛ لأن المنافقين كانوا يستأذنونه في المقام عن الغزو بالعِلَل، فرَخَّص الله للمؤمنين أن يستأذنوا إذا كان لهم عذر{33}. (ز) ٥٤٢٢٤- قال محمد ابن شهاب الزهري: وقال تعالى: <q>﴿لا يستأذنك الذين يؤمنون بالله واليوم الآخر﴾</q> إلى قوله: <q>﴿يترددون﴾</q> [التوبة:٤٤-٤٥]، نسخها قوله تعالى: <q>﴿فإذا استأذنوك لبعض شأنهم﴾</q> إلى قوله: <q>﴿غفور رحيم﴾</q>{34}. (ز) ٥٤٢٢٥- عن زيد بن أسلم -من طريق القاسم بن عبد الله- أنه قال: وقال: <q>﴿لا يستأذنك الذين يؤمنون بالله واليوم الآخر أن يجاهدوا بأموالهم وأنفسهم والله عليم بالمتقين(٤٤) إنما يستأذنك الذين لا يؤمنون بالله واليوم الآخر وارتابت قلوبهم فهم في ريبهم يترددون﴾</q> [التوبة:٤٤-٤٥]، فنسختها الآية التي في النور: <q>﴿فإذا استأذنوك لبعض شأنهم فأذن لمن شئت منهم واستغفر لهم الله إن الله غفور رحيم﴾</q>{35}. (ز) <q>﴿إِنَّ ٱلَّذِینَ یَسۡتَـٔۡذِنُونَكَ أُو۟لَـٰۤىِٕكَ ٱلَّذِینَ یُؤۡمِنُونَ بِٱللَّهِ وَرَسُولِهِۦۚ فَإِذَا ٱسۡتَـٔۡذَنُوكَ لِبَعۡضِ شَأۡنِهِمۡ فَأۡذَن لِّمَن شِئۡتَ مِنۡهُمۡ وَٱسۡتَغۡفِرۡ لَهُمُ ٱللَّهَۚ إِنَّ ٱللَّهَ غَفُورࣱ رَّحِیمࣱ ۝٦٢﴾</q> - آثار متعلقة بالآية ٥٤٢٢٦- عن إسماعيل بن عيّاش، قال: رأيت عمرو بن قيس السَّكُونيَّ يخطب الناس يوم الجمعة، فقام إليه أبو المُدِلَّةِ اليحصبي في شيء وجده في بطنه، فأشار إليه عمرو: أن انصرف. فسألت عمرًا أو أبا المُدِلَّةِ، فقال: هكذا كان أصحابُ رسول الله ﷺ يصنعون{36}. (١١/١٢٧) ٥٤٢٢٧- عن محمد بن سيرين، قال: كان الناسُ يستأذنون في الجمعة، ويقولون هكذا، ويشيرون بثلاث أصابع، فلمّا كان زيادٌ كَثُر عليه، فاغْتَمَّ، فقال: مَن أمسك على أنفه فهو إذْنُه{37}. (١١/١٢٦) ٥٤٢٢٨- عن الحسن البصري -من طريق هشام بن حسان- قال: كان الرجل إذا كانت له حاجة والإمام يخطب قام فأمسك بأنفه، فأشار إليه الإمام أن يخرج.= (ز) ٥٤٢٢٩- قال: فكان رجل قد أراد الرجوع إلى أهله، فقام إلى هرم بن حيان وهو يخطب، فأخذ بأنفه، فأشار إليه هرم أن يذهب، فخرج إلى أهله، فأقام فيهم، ثم قدم، قال له هرم: أين كنت؟ قال: في أهلي. قال: أبإذنٍ ذهبت؟ قال: نعم، قمت إليك وأنت تخطب، فأخذت بأنفي، فأشرت إلَيَّ أن اذهب، فذهبتُ. فقال: أفاتَّخَذْتَ هذا دغلًا؟! أو كلمة نحوها. ثم قال: اللَّهُمَّ، أخِّر رجال السوء إلى زمان السوء{38}. (ز) ٥٤٢٣٠- عن سعيد بن غُنيم الكَلاعي، قال: قام أبو الفرات الأودي يوم الجمعة يستأذن الإمام، وهو على المنبر -في خلافة عبد الملك بن مروان-، فأشار إليه بإصبعه، فأشار إليه بيده، أي: انصرف{39}. (ز) ",footnotes:1:مَجْمع الأسيال: موضع بين الجُرْف والغابة. والجُرْف والغابة: موضعان قرب المدينة نحو الشام، كانت بهما أموال لأهل المدينة. معجم البلدان ٢/١٢٨، ٣/١٤١، ٤/١٨٢.في معجم البلدان ٥/٣٠٠: «نَقَمى -بالتحريك، والقصر-: مِن النِّقْمة وهي العقوبة، مثل الجَمَزى من الجَمْز: موضع من أعراض المدينة كان لآل أبي طالب، قال ابن إسحاق: وأقبلت غطفان يوم الخندق ومن تبعها من أهل نجد حتى نزلوا بذنب نقمى إلى جنب أحد، ويروى: نَقَم».أخرجه ابن إسحاق ٢/٢١٦، ٢١٩، ٢٢٠ -سيرة ابن هشام-، والبيهقي في الدلائل ٣/٤٠٩ مرسلًا. وعزاه السيوطي إلى ابن المنذر.عزاه السيوطي إلى أبي الشيخ، وهو مرسل.وقع في المصدر في هذا الموضع: أن يسمع المنافقين. ويبدو أن كتابتها هنا سبق نظر؛ لأنها ذكرت تحته في السطر التالي.تفسير مقاتل بن سليمان ٣/٢١٠-٢١١.أخرجه الطبراني في مسند الشاميين (٢٤١٤).أخرجه ابن جرير ١٧/٣٨٥ كذلك من طريق ابن جريج بلفظ: أمرٌ من طاعة الله عامٌّ، وابن أبي حاتم ٨/٢٦٥٣. وعزاه السيوطي إلى ابن المنذر.علَّقه ابن أبي حاتم ٨/٢٦٥٣.أخرجه ابن أبي حاتم ٨/٢٦٥٢ (١٤٩١٢). وعزاه السيوطي إلى عبد بن حميد، ولم يذكر ابن أبي مليكة.أخرجه عبد الرزاق في تفسيره ٣/٢٤٣-٢٤٤، وفي المصنف (٥٥١١)، وابن أبي شيبة ٢/١١٦، وإسحاق البستي في تفسيره ص٤٩٣، وابن أبي حاتم ٨/٢٦٥٢-٢٦٥٣. وعزاه السيوطي إلى الفريابي، وسعيد بن منصور، وعبد بن حميد، وابن المنذر.علقه يحيى بن سلّام ١/٤٦٦.عزاه السيوطي إلى الفريابي.أخرجه ابن وهب في الجامع ١/٤٨-٤٩ (١٠٥)، وابن جرير ١٧/٣٨٥. وعزاه السيوطي إلى عبد بن حميد.أخرجه ابن أبي حاتم ٨/٢٦٥٣.أخرجه عبد الرزاق ٣/٢٤٢-٢٤٣ (٥٥٠٧).أخرجه عبد الرزاق ٣/٢٤٣ (٥٥٠٨).أخرجه عبد الرزاق في تفسيره ٢/٦٦، وفي مصنفه ٣/٢٤٣ (٥٥٠٨)، وابن جرير ١٧/٣٨٦ دون كلمة: فيها.أخرجه الثعلبي ٧/١٢١.في الأصل: الصاف. والمُصاف -بفتح الميم وتشديد الفاء-: جمع مَصَف، وهو موضع الحرب الذي يكون فيه الصفوف. النهاية (صفف) ٣/٣٨.المَسالح: جمع مسلحة، والمسلحة: القوم الذين يحفظون الثغور من العدو، وسموا مسلحة لأنهم يكونون ذوي سلاح؛ أو لأنهم يسكنون المسلحة، وهي كالثغر والمرقب يكون فيه أقوام يرقبون العدو لئلا يطرقهم على غفلة، فإذا رأوه أعلموا أصحابهم؛ ليتأهبوا له. النهاية (سلح) ٢/٣٨٨.أخرجه إسحاق البستي في تفسيره ص٤٩٤.أخرجه عبد الرزاق ٢/٦٦.تفسير مقاتل بن سليمان ٣/٢١٠.أخرجه ابن أبي حاتم ٨/٢٦٥٣.أخرجه ابن جرير ١٧/٣٨٧، وابن أبي حاتم ٨/٢٦٥٤ من طريق أصبغ.تفسير يحيى بن سلّام ١/٤٦٦.أخرجه ابن أبي حاتم ٨/٢٦٥٤، والطبراني في مسند الشاميين (٢٤١٤).أخرجه ابن أبي حاتم ٨/٢٦٥٤.تفسير مقاتل بن سليمان ٣/٢١٠.تفسير يحيى بن سلّام ١/٤٦٦.أخرجه ابن أبي حاتم ٨/٢٦٥٣-٢٦٥٤.أخرجه يحيى بن سلّام ١/٤٦٦.الناسخ والمنسوخ للزهري ص٢٨-٢٩.أخرجه ابن وهب في الجامع - تفسير القرآن ٣/٧٥ (١٦٤).عزاه السيوطي إلى سعيد بن منصور.أخرجه ابن أبي شيبة ٢/١١٦. وعزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ١٧/٣٨٦.أخرجه سعيد بن منصور في سننه - التفسير ٦/٤٥٨ (١٦٢١).
24,63," <q>﴿لَّا تَجۡعَلُوا۟ دُعَاۤءَ ٱلرَّسُولِ بَیۡنَكُمۡ كَدُعَاۤءِ بَعۡضِكُم بَعۡضࣰاۚ﴾</q> - نزول الآية، وتفسيرها ٥٤٢٣١- عن عبد الله بن عباس -من طريق الضحاك- في قوله: <q>﴿لا تجعلوا دعاء الرسول بينكم كدعاء بعضكم بعضا﴾</q>، قال: كانوا يقولون: يا محمد، يا أبا القاسم. فنهاهم الله عن ذلك إعظامًا لنبيه ﷺ، فقالوا: يا نبي الله، يا رسول الله{1}. (١١/١٢٧) ٥٤٢٣٢- عن عبد الله بن عباس، في قوله: <q>﴿لا تجعلوا دعاء الرسول بينكم كدعاء بعضكم بعضا﴾</q>: يعني: كدعاء أحدكم اذا دعا أخاه باسمه، ولكن وقِّروه وعَظِّموه، وقولوا له: يا رسول الله، ويا نبيَّ الله{2}. (١١/١٢٨) ٥٤٢٣٣- عن عبد الله بن عباس -من طريق ابن جُرَيْج- في قوله: <q>﴿لا تجعلوا دعاء الرسول بينكم كدعاء بعضكم بعضا﴾</q>: يريد: ولا تصيحوا به مِن بعيد: يا أبا القاسم. ولكن كما قال الله في الحجرات [٣]: <q>﴿إن الذين يغضون أصواتهم عند رسول الله﴾</q>{3}. (١١/١٢٨) ٥٤٢٣٤- عن عبد الله بن عباس -من طريق العوفي- في قوله: <q>﴿لا تجعلوا دعاء الرسول بينكم﴾</q> الآية، يقول: دعوة الرسول عليكم موجبة؛ فاحذَروها{4}. (١١/١٢٩) ٥٤٢٣٥- عن عطية العوفي، نحو ذلك{5}. (ز) ٥٤٢٣٦- عن علقمة [بن قيس النخعي]= (ز) ٥٤٢٣٧- والأسود [بن يزيد بن قيس النخعي] -من طريق أبي إسحاق- في قول الله ﷿: <q>﴿لا تجعلوا دعاء الرسول بينكم كدعاء بعضكم بعضا﴾</q>، قال: لا تقولوا: يا محمد. ولكن قولوا: يا رسول الله، أو: يا نبي الله{6}. (ز) ٥٤٢٣٨- عن سعيد بن جبير -من طريق سالم الأفطس- <q>﴿لا تجعلوا دعاء الرسول بينكم كدعاء بعضكم بعضا﴾</q>، قال: لا تقولوا: يا محمد. قولوا: يا رسول الله، يا نبي الله، بأبي أنت وأمي{7}. (١١/١٢٩) ٥٤٢٣٩- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في الآية، قال: أمرهم اللهُ أن يدعوه: يا رسول الله. في لين وتواضع، ولا يقولوا: يا محمد. في تَجَهُّم{8}. (١١/١٢٨) ٥٤٢٤٠- عن عامر الشعبي، في الآية، قال: لا تجعلوا دعاء الرسول عليكم كدعاء بعضكم على بعض{9}. (١١/١٢٩) ٥٤٢٤١- عن عكرمة مولى ابن عباس، في الآية، قال: لا تقولوا: يا محمد. ولكن قولوا: يا رسول الله{10}. (١١/١٢٩) ٥٤٢٤٢- عن الحسن البصري، مثله{10}. (١١/١٢٩) ٥٤٢٤٣- عن الحسن البصري -من طريق عاصم- قال: <q>﴿لا تجعلوا دعاء الرسول﴾</q> إذا دعا <q>﴿كدعاء بعضكم بعضًا﴾</q>{12}. (ز) ٥٤٢٤٤- عن قتادة بن دعامة -من طريق مَعْمَر- في الآية، قال: أمر الله أن يُهاب نبيُّه، وأن يُبَجَّل، وأن يُعَظَّم، وأن يُفَخَّم، ويُشرَّف{13}. (١١/١٢٨) ٥٤٢٤٥- قال مقاتل بن سليمان: <q>﴿لا تجعلوا دعاء الرسول بينكم كدعاء بعضكم بعضا﴾</q>، يقول الله ﷿: لا تَدْعُوا النبيَّ ﷺ باسمه: يا محمد، ويا ابن عبد الله. إذا كلَّمتموه كما يدعو بعضُكم بعضًا باسمه: يا فلان، ويا ابن فلان. ولكن عظِّموه وشرِّفوه ﷺ، وقولوا: يا رسول الله، يا نبي الله ﷺ. نظيرُها في الحجرات{14}. (ز) ٥٤٢٤٦- عن مقاتل بن حيّان -من طريق بكير بن معروف- <q>﴿لا تجعلوا دعاء الرسول بينكم كدعاء بعضكم بعضًا﴾</q>، يقول: لا تُسَمُّوه إذا دعوتموه: يا محمد. ولا تقولوا: يا ابن عبد الله. ولكن شرِّفوه، فقولوا: يا رسول الله، يا نبي الله{12}٤٧٠١. (ز) ٤٧٠١ أفادت الآثارُ اختلافَ المفسرين في معنى قوله تعالى: <q>﴿لا تَجْعَلُوا دُعاءَ الرَّسُولِ بَيْنَكُمْ كَدُعاءِ بَعْضِكُمْ بَعْضًا﴾</q>؛ فقيل: نهيٌ من الله عن دعاء رسول الله ﷺ بالغِلْظة والجفاء، وأمرٌ أن يُدعا بلين وتواضع. وقيل: نهيٌ من الله عن التعرض لإسخاط الرسول ﷺ، فإنّه إذا دعا على شخص فدعوته موجِبة. ورجَّح ابنُ جرير (١٧/٣٨٩) مستندًا إلى السياق القول الثاني، وهو قول ابن عباس من طريق العوفي، وعلَّل ذلك بقوله: «أن الذي قبْل قوله: <q>﴿لا تَجْعَلُوا دُعاءَ الرَّسُولِ بَيْنَكُمْ كَدُعاءِ بَعْضِكُمْ بَعْضًا﴾</q> نهيٌ مِن الله المؤمنين أن يأتوا من الانصراف عنه في الأمر الذي يجمع جميعهم ما يكرهه، والذي بعده وعيدٌ للمنصرفين عنه بغير إذنه، فالذي بينهما بأن يكون تحذيرًا لهم سُخْطَه أن يضطرَّه إلى الدعاء عليهم أشبهُ مِن أن يكون أمرًا لهم بما لم يَجْرِ له ذِكْرٌ من تعظيمه وتوقيره بالقول والدعاء». ورجَّح ابنُ عطية (٦/٤١٤)، وابنُ كثير (١٠/٢٨٠) مستندًا إلى السياق القول الأول، فقال ابنُ عطية بعد أن ذَكَر القولين: «والأول أصحّ». ولم يذكر مستندًا. وقال ابنُ كثير: «وهو الظاهر من السياق». وانتقد ابنُ عطية القول الثاني مستندًا إلى ظاهر لفظ الآية قائلًا: «ولفظ الآية يدفع هذا المعنى». <q>﴿قَدۡ یَعۡلَمُ ٱللَّهُ ٱلَّذِینَ یَتَسَلَّلُونَ مِنكُمۡ لِوَاذࣰاۚ﴾</q> - نزول الآية ٥٤٢٤٧- عن الضحاك بن مُزاحِم، قال: كان إذا جمع رسول الله ﷺ الناسَ لأمر يأمرهم وينهاهم صبر المؤمنون في مجالسهم، وأحبُّوا ما أحدث لهم رسولُ الله ﷺ بما يُوحى إليه، وبما أحبوا وكرهوا، فإذا كان شيءٌ مما يكره المنافقون خرجوا يتسللون، يلوذ الرجل بالرجل، يستتر لكي لا يراه النبيُّ ﷺ، فقال الله تعالى: إن الله يبصر الذين يتسللون منكم لواذًا{16}. (١١/١٣٢) ٥٤٢٤٨- عن إسماعيل بن أمية القرشي، عن مكحول، قال: إنما كانت الحربة تُحمَل مع رسول الله ﷺ لأنه كان يصلي إليها، وأخَّر الصلاة، فكان لا يخرج أحدٌ لِرُعاف أو لحدث بعد النهي حتى يستأذن النبيَّ ﷺ؛ يُشِير إليه بالإصبع التي تلي الإبهام، فيأذن له ﷺ، ثم يشير إليه بيده، فكان مِن المنافقين مَن ثَقُل عليه الخطبة والجلوس في المسجد، فكان إذا استأذن رجل من المسلمين قام المنافق إلى جنبه مستترًا به حتى يخرج؛ فأنزل الله تعالى: <q>﴿قد يعلم الله الذين يتسللون منكم لواذا﴾</q> الآية{17}. (ز) ٥٤٢٤٩- قال مقاتل بن سليمان: <q>﴿قد يعلم الله الذين يتسللون منكم لواذا﴾</q>، وذلك أنّ المنافقين كان يَثْقُل عليهم يومَ الجمعة قولُ النبي ﷺ وحديثُه إذا كانوا معه على أمر جامع، فيقوم المنافق وينسلُّ، ويلوذ بالرجال وبالسارية لِئَلّا يراه النبيُّ ﷺ حتى يخرج من المسجد، ويدعوه باسمه: يا محمد، ويا ابن عبد الله. فنزلت هؤلاء الآيات{18}. (ز) ٥٤٢٥٠- عن مقاتل بن حيان -من طريق بكير بن معروف- في قوله: <q>﴿قد يعلم الله الذين يتسللون منكم لواذا﴾</q>، قال: هم المنافقون، كان يثقل عليهم الحديث في يوم الجمعة، ويعني بالحديث: الخطبة، فيلوذون ببعض الصحابة حتى يخرجوا من المسجد، وكان لا يصلح للرجل أن يخرج من المسجد إلا بإذن من النبي ﷺ في يوم الجمعة بعدما يأخذ في الخطبة، وكان إذا أراد أحدهم الخروج أشار بإصبعه إلى النبي ﷺ، فيأذن له مِن غير أن يتكلم الرجل؛ لأن الرجل منهم كان إذا تكلم والنبي ﷺ يخطب بَطَلَتْ جمعتُه{19}. (١١/١٢٩) <q>﴿قَدۡ یَعۡلَمُ ٱللَّهُ ٱلَّذِینَ یَتَسَلَّلُونَ مِنكُمۡ لِوَاذࣰاۚ﴾</q> - تفسير الآية ٥٤٢٥١- قال عبد الله بن عباس: <q>﴿لواذا﴾</q>، أي: يلوذ بعضهم ببعض، وذلك أنّ المنافقين كان يثقل عليهم المقام في المسجد يوم الجمعة واستماع خطبة النبي ﷺ، فكانوا يلوذون ببعض أصحابه، فيخرجون من المسجد في استتار{20}. (ز) ٥٤٢٥٢- عن مجاهد بن جبر -من طريق حجاج، عن ابن جريج- في قوله: <q>﴿لواذا﴾</q>، قال: خِلافًا{21}. (١١/١٣٠) ٥٤٢٥٣- عن عبد الملك ابن جُرَيج -من طريق المبارك بن عبد الله-، مثله{22}. (ز) ٥٤٢٥٤- قال يحيى بن سلّام: وقال مجاهد: خَلْفًا، يعني: التخلف، أي: فرارًا من الجهاد في سبيل الله. يعني: المنافقين يلوذ بعضهم ببعض استتارًا مِن النبي حتى يذهبوا{23}. (ز) ٥٤٢٥٥- عن الضحاك بن مُزاحِم -من طريق جُوَيْبِر- في قول الله: <q>﴿قد يعلم الله الذين يتسللون منكم لواذا﴾</q>، قال: كانوا يستتر بعضهم ببعض، فيقومون{24}. (١١/١٣١) ٥٤٢٥٦- عن قتادة بن دعامة -من طريق سعيد- <q>﴿قد يعلم الله الذين يتسللون منكم لواذا﴾</q>، قال: يتسللون عن نبي الله، وعن كتابه، وعن ذِكْرِه{25}. (١١/١٣٠) ٥٤٢٥٧- عن إسماعيل السُّدِّيّ -من طريق أسباط- قوله: <q>﴿قد يعلم الله الذين يتسللون منكم لواذا﴾</q>، قال: كانوا إذا كانوا معه في جماعة لاذ بعضُهم ببعضهم حتى يتغيبوا عنه فلا يراهم{26}. (ز) ٥٤٢٥٨- عن إسماعيل السُّدِّيّ -من طريق أسباط- <q>﴿قد يعلم الله الذين يتسللون منكم لواذا﴾</q>، قال: يلوذ بالشيء: يستتر به مِن النبي ﷺ{27}. (ز) ٥٤٢٥٩- عن سفيان [الثوري] -من طريق مهران- <q>﴿قد يعلم الله الذين يتسللون منكم لواذا﴾</q>، قال: يتسللون مِن الصف في القتال. <q>﴿لواذا﴾</q> قال: فِرارًا{28}. (١١/١٣٠) ٥٤٢٦٠- قال عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿قد يعلم الله الذين يتسللون منكم لواذا﴾</q>، قال: هؤلاء المنافقون الذين يرجعون بغير إذن رسول الله ﷺ. قال: اللواذ: يلوذ عنه، ويروغ، ويذهب بغير إذن النبي ﷺ{29}. (ز) <q>﴿قَدۡ یَعۡلَمُ ٱللَّهُ ٱلَّذِینَ یَتَسَلَّلُونَ مِنكُمۡ لِوَاذࣰاۚ﴾</q> - آثار متعلقة بالآية ٥٤٢٦١- عن مكحول الشامي -من طريق يزيد بن مرثد- قال: مَن خرج في تَطَرُّفٍ{30} أو طلبٍ بغير إذن رسول الله، وأبي بكر، وعمر؛ معصية، ويرون أنه مَن خرج بغير إذنٍ وجبت له النار{31}. (ز) ٥٤٢٦٢- عن الوليد بن مسلم، عن أبي دحية مولى قريش، عن عمير بن هانئ، قال: مَن كفل للمسلمين بمصافة ...{32} منها، وتسلل منها لواذًا دخل أو حَلَّ كرجل في وادي من أودية النار، إذا سار سار فيه، وإن مات مات فيه. وقال: من لم يتسلل منها لواذًا فهو في وادي مِن أودية الجنة، إن سار سار فيه، وإن مات مات فيه{31}. (ز) <q>﴿فَلۡیَحۡذَرِ ٱلَّذِینَ یُخَالِفُونَ عَنۡ أَمۡرِهِۦۤ﴾</q> - تفسير ٥٤٢٦٣- قال مقاتل بن سليمان: فخوَّفهم عقوبتَه، فقال سبحانه: <q>﴿فليحذر الذين يخالفون عن أمره﴾</q>، يعني: عن أمر الله ﷿{18}. (ز) ٥٤٢٦٤- عن مقاتل بن حيّان -من طريق بكير بن معروف- قوله: <q>﴿فليحذر الذين يخالفون عن أمره﴾</q>: يعني: المنافقين{35}. (ز) ٥٤٢٦٥- قال عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿فليحذر الذين يخالفون عن أمره﴾</q>: الذين يصنعون هذا{36}. (ز) ٥٤٢٦٦- قال يحيى بن سلّام: <q>﴿فليحذر الذين يخالفون عن أمره﴾</q> عن أمر الله، يعني: المنافقين{37}. (ز) <q>﴿أَن تُصِیبَهُمۡ فِتۡنَةٌ﴾</q> - تفسير ٥٤٢٦٧- عن عبد الله بن عباس، في قوله: <q>﴿فليحذر الذين يخالفون عن أمره أن تصيبهم فتنة﴾</q>، قال: أي: قَتْل{38}. (ز) ٥٤٢٦٨- عن مجاهد بن جبر، في قوله: <q>﴿فليحذر الذين يخالفون عن أمره أن تصيبهم فتنة﴾</q>، قال: بلاء في الدنيا{20}. (ز) ٥٤٢٦٩- عن الضحاك بن مُزاحِم -من طريق جُوَيْبِر- في قول الله: <q>﴿فليحذر الذين يخالفون عن أمره أن تصيبهم فتنة﴾</q>، قال: يطبع على قلبه، فلا يُؤمَنُ أن يُظهر الكفر بلسانه، فتُضرب عنقه{40}. (ز) ٥٤٢٧٠- عن عطاء، في قوله: <q>﴿فليحذر الذين يخالفون عن أمره أن تصيبهم فتنة﴾</q>، قال: الزلازل، والأهوال{38}. (ز) ٥٤٢٧١- عن الحسن البصري، في قوله: <q>﴿فليحذر الذين يخالفون عن أمره أن تصيبهم فتنة﴾</q>، قال: بلية تظهر ما في قلوبهم مِن النفاق{38}. (ز) ٥٤٢٧٢- عن إسماعيل السُّدِّيّ -من طريق أسباط- <q>﴿فليحذر الذين يخالفون عن أمره أن تصيبهم فتنة﴾</q>: الشرك{43}. (ز) ٥٤٢٧٣- عن جعفر بن محمد، في قوله: <q>﴿فليحذر الذين يخالفون عن أمره أن تصيبهم فتنة﴾</q>، قال: سلطان جائِر يُسَلَّط عليهم{38}. (ز) ٥٤٢٧٤- قال مقاتل بن سليمان: <q>﴿أن تصيبهم فتنة﴾</q>، يعني: الكفر{18}. (ز) ٥٤٢٧٥- عن مقاتل بن حيّان -من طريق بُكَيْر بن معروف- قوله: <q>﴿أن تصيبهم فتنة﴾</q>: يعني بالفتنة: الكفر{35}. (ز) ٥٤٢٧٦- عن سفيان، <q>﴿فليحذر الذين يخالفون عن أمره أن تصيبهم فتنة﴾</q>، قال: أن يطبع على قلوبهم{10}. (١١/١٣٠) ٥٤٢٧٧- قال عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿أن تصيبهم فتنة أو يصيبهم عذاب أليم﴾</q>: الفتنة هاهنا الكفر{48}. (ز) ٥٤٢٧٨- قال يحيى بن سلّام: <q>﴿أن تصيبهم فتنة﴾</q> بلية، يقول: فليحذروا أن تصيبهم فتنة؛ بلية{37}. (ز) <q>﴿أَوۡ یُصِیبَهُمۡ عَذَابٌ أَلِیمٌ ۝٦٣﴾</q> - تفسير ٥٤٢٧٩- عن إسماعيل السُّدِّيّ -من طريق أسباط- <q>﴿أو يصيبهم عذاب أليم﴾</q>، قال: القتل بالسيف مِن النبي ﷺ{27}. (ز) ٥٤٢٨٠- قال مقاتل بن سليمان: <q>﴿أو يصيبهم عذاب أليم﴾</q>، يعني: وجيعًا، يعني: القتل في الدنيا{18}. (ز) ٥٤٢٨١- عن مقاتل بن حيّان -من طريق بُكَيْر بن معروف- قوله: <q>﴿أو يصيبهم عذاب أليم﴾</q>: يعني: القتل في الدنيا{35}. (ز) ٥٤٢٨٢- قال يحيى بن سلّام: <q>﴿أو يصيبهم عذاب أليم﴾</q>، أي: يستخرج الله ما في قلوبهم مِن النفاق حتى يظهروه شركًا؛ فيصيبهم بذلك العذاب الأليم؛ القتل{37}. (ز) <q>﴿أَوۡ یُصِیبَهُمۡ عَذَابٌ أَلِیمٌ ۝٦٣﴾</q> - آثار متعلقة بالآية ٥٤٢٨٣- عن مجاهد، قال: أشدُّ حديثٍ سمعناه عن النبي ﷺ قولُه في سعد بن معاذ في أمر القبر، ولَمّا كانت غزوة تبوك قال: «لا يخرج معنا إلا رجل مُقْوٍ{54}». فخرج رجل على بَكر له صعب، فصرعه، فمات، فقال الناس: الشهيد، الشهيد. فأمر النبيُّ ﷺ بلالًا أن يُنادي في الناس: «لا يدخل الجنةَ إلا نفسٌ مؤمنة، ولا يدخل الجنةَ عاصٍ»{55}. (١١/١٣١) ٥٤٢٨٤- عن يحيى بن أبي كثير، قال: نهى رسولُ الله ﷺ أصحابَه أن يُقاتِلوا ناحيةً مِن خيبر، فانصرف الرجال عنهم، وبقي رجل، فقاتلهم، فرموه، فقتلوه، فجيء به إلى النبيِّ ﷺ يُصَلّى عليه، فقال: «أبعد ما نُهينا عن القتال؟». فقالوا: نعم. فتركه، ولم يُصَلِّ عليه{56}. (١١/١٣٠) ٥٤٢٨٥- عن زيد بن أسلم: أنّ رسول الله ﷺ قال لأصحابه ذاتَ يوم وهو مستقبلٌ العدوَّ: «لا يقاتل أحدٌ منكم». فعَمَد رجل منهم ورمى العدوَّ، وقاتلهم، فقتلوه، فقيل للنبي ﷺ: اسشتهد فلان. فقال: «أبعد ما نهيتُ عن القتال؟». قالوا: نعم. قال: «لا يدخل الجنة عاص»{57}. (١١/١٣١) ٥٤٢٨٦- عن الحسن بن صالح -من طريق عبد الصمد بن صبيح- قال: إني لَخائف على مَن ترك المسح على الخفين أن يكون داخلًا في هذه الآية: <q>﴿فليحذر الذين يخالفون عن أمره أن تصيبهم فتنة أو يصيبهم عذاب أليم﴾</q>{35}. (١١/١٣٠) ",footnotes:1:أخرجه ابن أبي حاتم ٨/٢٦٥٤-٢٦٥٥، وأبو نعيم في الدلائل (٤). وعزاه السيوطي إلى ابن مردويه.عزاه السيوطي إلى أبي نعيم في الدلائل.أخرجه أبو نعيم في الدلائل (٥). وعزاه السيوطي إلى عبد الغني بن سعيد في تفسيره.أخرجه ابن جرير ١٧/٣٨٨، وابن أبي حاتم ٨/٢٦٥٥، وعزاه السيوطي إلى ابن مردويه.علَّقه ابن أبي حاتم ٨/٢٦٥٥.أخرجه البيهقي في دلائل النبوة ٥/٤٩٠.أخرجه ابن أبي حاتم ٨/٢٦٥٥. وعزاه السيوطي إلى عبد بن حميد.أخرجه يحيى بن سلّام ١/٤٦٦ من طريق ابن مجاهد، وابن جرير ١٧/٣٨٩، ومن طريق ابن جريج أيضًا، وابن أبي حاتم ٨/٢٦٥٥. وعزاه السيوطي إلى ابن أبي شيبة، وعبد بن حميد، وابن المنذر.عزاه السيوطي إلى سعيد بن منصور.عزاه السيوطي إلى عبد بن حميد.عزاه السيوطي إلى عبد بن حميد.أخرجه ابن أبي حاتم ٨/٢٦٥٥.أخرجه عبد الرزاق ٢/٦٦، وابن جرير ١٧/٣٨٩ مختصرًا، وابن أبي حاتم ٨/٢٦٥٥. وعلقه يحيى بن سلّام ١/٤٦٦. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.تفسير مقاتل بن سليمان ٣/٢١١. يشير إلى قوله تعالى: <q>﴿يا أيُّها الَّذِينَ آمَنُوا لا تَرْفَعُوا أصْواتَكُمْ فَوْقَ صَوْتِ النَّبِيِّ ولا تَجْهَرُوا لَهُ بِالقَوْلِ كَجَهْرِ بَعْضِكُمْ لِبَعْضٍ أنْ تَحْبَطَ أعْمالُكُمْ وأَنْتُمْ لا تَشْعُرُونَ﴾</q> [الحجرات:٢].أخرجه ابن أبي حاتم ٨/٢٦٥٥.عزاه السيوطي إلى أبي الشيخ.أخرجه أبو داود في المراسيل ص٩٥.تفسير مقاتل بن سليمان ٣/٢١١.أخرجه أبو داود في مراسيله ص٩٥، وابن أبي حاتم ٨/٢٦٥٦ واللفظ له. وذكر السيوطي هذا الأثر منسوبًا إلى مقاتل بن حيان، وعزاه إلى ابن حاتم، ثم تلاه بأثر مشابه نسبه إلى مقاتل دون تعيينه، وعزاه إلى أبي داود في مراسيله، وهو نفس الأثر السابق عن مقاتل بن حيان الذي أخرجه ابن أبي حاتم، وقد صرح أبو داود بأنه مقاتل بن حيان.تفسير البغوي ٦/٦٨.أخرجه ابن جرير ١٧/٣٩١، وإسحاق البستي في تفسيره ص٤٩٤، وابن أبي حاتم ٨/٢٦٥٦.أخرجه آدم بن أبي إياس -كما في تفسير مجاهد ص٤٩٥-.علَّقه يحيى بن سلّام ١/٤٦٧.أخرجه ابن جرير ١٧/٣٩٠ واللفظ له. وعزاه السيوطي إلى أبي الشيخ.أخرجه يحيى بن سلّام ١/٤٦٧، وابن أبي حاتم ٨/٢٦٥٦. وعزاه السيوطي إلى عبد بن حميد.أخرجه ابن أبي حاتم ٨/٢٦٥٦.أخرجه المروزي في تعظيم قدر الصلاة ٢/٦٦٥.أخرجه ابن أبي حاتم ٨/٢٦٥٦. وعزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ١٧/٣٨٦.طَرَّفَ فلانٌ: إذا قاتل حول العسكر لأنه يحمل على طَرَفٍ منهم فيردُّهم إلى الجمهور، وتَطَرَّف عليهم: أغار. اللسان (طرف).أخرجه إسحاق البستي في تفسيره ص٤٩٥.قال محقق المصدر: كلمتان لم أتمكن من قراءتهما.أخرجه إسحاق البستي في تفسيره ص٤٩٥.تفسير مقاتل بن سليمان ٣/٢١١.أخرجه ابن أبي حاتم ٨/٢٦٥٧.أي: الذهاب بغير إذن النبي ﷺ. والأثر تتمة للأثر السابق عن ابن زيد، أخرجه ابن جرير ١٧/٣٨٦، وابن أبي حاتم ٨/٢٦٥٧.تفسير يحيى بن سلّام ١/٤٦٧.تفسير الثعلبي ٧/١٢١.تفسير البغوي ٦/٦٨.أخرجه ابن جرير ١٧/٣٩١.تفسير الثعلبي ٧/١٢١.تفسير الثعلبي ٧/١٢١.أخرجه المروزي في تعظيم قدر الصلاة ٢/٦٦٥. وعلَّق ابن أبي حاتم ٨/٢٦٥٧ نحوه.تفسير الثعلبي ٧/١٢١.تفسير مقاتل بن سليمان ٣/٢١١.أخرجه ابن أبي حاتم ٨/٢٦٥٧.عزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ١٧/٣٨٦. وعلقه ابن أبي حاتم ٨/٢٦٥٧.تفسير يحيى بن سلّام ١/٤٦٧.أخرجه المروزي في تعظيم قدر الصلاة ٢/٦٦٥.تفسير مقاتل بن سليمان ٣/٢١١.أخرجه ابن أبي حاتم ٨/٢٦٥٧.تفسير يحيى بن سلّام ١/٤٦٧.مُقْوٍ: ذو دابَّة قَويَّة. النهاية (قوا).أخرجه سعيد بن منصور سننه ٢/٢٣٢-٢٣٣ (٢٤٩٤)، وفي التفسير من سننه ٥/٢٦٩-٢٧٠ (١٠٣٢)، وعبد الرزاق في مصنفه ٥/١٧٧ (٩٢٩٤). قال ابن حجر في الفتح ٦/٩٠ عن إسناد سعيد بن منصور: «بإسناد صحيح».أخرجه عبد الرزاق ٥/١٧٦ (٩٢٩١) مرسلًا.أخرجه عبد الرزاق ٥/١٧٩ (٩٢٩٦) مرسلًا.أخرجه ابن أبي حاتم ٨/٢٦٥٧.
24,64," <q>﴿أَلَاۤ إِنَّ لِلَّهِ مَا فِی ٱلسَّمَـٰوَ ٰ⁠تِ وَٱلۡأَرۡضِۖ﴾</q> - تفسير ٥٤٢٨٧- قال مقاتل بن سليمان: ثم عظَّم نفسه جل جلاله، فقال تعالى: <q>﴿ألا إن لله ما في السماوات والأرض﴾</q> مِن الخلق؛ عبيدُه، وفي مُلكِه{1}. (ز) <q>﴿قَدۡ یَعۡلَمُ مَاۤ أَنتُمۡ عَلَیۡهِ﴾</q> - تفسير ٥٤٢٨٨- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿قد يعلم ما أنتم عليه﴾</q> الآية، قال: ما كان قومٌ قطُّ على أمرٍ ولا على حالٍ إلا كانوا بعين الله، وإلا كان عليهم شاهد مِن الله{2}. (١١/١٣٢) ٥٤٢٨٩- قال مقاتل بن سليمان: <q>﴿قد يعلم ما أنتم عليه﴾</q> مِن الإيمان، والنفاق{1}. (ز) ٥٤٢٩٠- قال عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿قد يعلم ما أنتم عليه﴾</q>: صنيعكم هذا أيضًا{4}٤٧٠٢. (ز) ٤٧٠٢ لم يذكر ابنُ جرير (١٧/٣٩٢) في معنى: <q>﴿قَدْ يَعْلَمُ ما أنْتُمْ عَلَيْهِ﴾</q> سوى قول ابن زيد. ٥٤٢٩١- قال يحيى بن سلّام: قوله: <q>﴿قد يعلم ما أنتم عليه﴾</q> مِن النفاق، يعني: المنافقين{5}. (ز) <q>﴿وَیَوۡمَ یُرۡجَعُونَ إِلَیۡهِ فَیُنَبِّئُهُم بِمَا عَمِلُوا۟ۗ﴾</q> - تفسير ٥٤٢٩٢- عن أبي العالية الرِّياحيِّ -من طريق الربيع- <q>﴿يرجعون إليه﴾</q>، قال: يرجعون إليه بعد الحياة{6}. (ز) ٥٤٢٩٣- قال مقاتل بن سليمان: <q>﴿ويوم يرجعون إليه﴾</q> أي: إلى الله في الآخرة، <q>﴿فينبئهم بما عملوا﴾</q> مِن خير أو شر{1}. (ز) ٥٤٢٩٤- قال يحيى بن سلّام: <q>﴿ويوم يرجعون إليه﴾</q> يقول للنبي: يوم يرجع المنافقون إليه يوم القيامة، <q>﴿فينبئهم بما عملوا﴾</q> مِن النفاق والكفر{5}. (ز) <q>﴿وَٱللَّهُ بِكُلِّ شَیۡءٍ عَلِیمُۢ ۝٦٤﴾</q> - تفسير ٥٤٢٩٥- عن عقبة بن عامر، قال: رأيتُ رسول الله ﷺ وهو يقرأ هذه الآية -يعني: خاتمة سورة النور-، وهو جاعل إصبعيه تحت عينيه، يقول: «بكل شيء بصير»{9}. (١١/١٣٢) ٥٤٢٩٦- قال مقاتل بن سليمان: <q>﴿والله بكل شيء﴾</q> مِن أعمالكم <q>﴿عليم﴾</q> به ﷿{1}. (ز) ",footnotes:1:تفسير مقاتل بن سليمان ٣/٢١١.أخرجه ابن أبي حاتم ٨/٢٦٥٧. وعزاه السيوطي إلى عبد بن حميد.تفسير مقاتل بن سليمان ٣/٢١١.أخرجه ابن جرير ١٧/٣٩٢، وابن أبي حاتم ٨/٢٦٥٨ من طريق أصبغ.تفسير يحيى بن سلّام ١/٤٦٧.أخرجه ابن أبي حاتم ٨/٢٦٥٨.تفسير مقاتل بن سليمان ٣/٢١١.تفسير يحيى بن سلّام ١/٤٦٧.أخرجه القاسم بن سلّام في فضائل القرآن ص٣٠٨، والطبراني في الكبير ١٧/٢٨٢ (٧٧٦)، ويحيى بن سلّام ١/٤٦٧. قال الهيثمي في المجمع ٧/٨٤ (١١٢٣٩): «هكذا وقع، فإن كانت قراءة شاذة، وإلا فالتلاوة: <q>﴿بكل شيء عليم﴾</q>. رواه الطبراني، وفيه ابن لهيعة، وهو سيئ الحفظ، وفيه ضعف، وبقية رجاله ثقات». وقال السيوطي: «سند حسن».تفسير مقاتل بن سليمان ٣/٢١١.
25,1," مقدمة السورة ٥٤٢٩٧- عن عبد الله بن عباس -من طريق مجاهد- قال: نزلت سورة الفرقان بمكة{1}. (١١/١٣٣) ٥٤٢٩٨- عن عبد الله بن عباس -من طريق عطاء الخراساني- قال: مكية، ونزلت بعد <q>﴿يس والقرآن﴾</q>{2}. (ز) ٥٤٢٩٩- عن عبد الله بن الزبير، قال: نزلت بمكة سورة الفرقان{3}. (١١/١٣٣) ٥٤٣٠٠- عن عكرمة مولى ابن عباس= (ز) ٥٤٣٠١- والحسن البصري -من طريق يزيد النحوي-: مكية{4}. (ز) ٥٤٣٠٢- عن قتادة بن دعامة -من طرق-: مكية{5}. (ز) ٥٤٣٠٣- عن إسماعيل السُّدِّيّ -من طريق الثوري-في قوله: <q>﴿وإذا مروا باللغو مروا كراما﴾</q> قال: هي مكية{6}. (١١/٢٢٧) ٥٤٣٠٤- عن محمد ابن شهاب الزهري: مكية، ونزلت بعد يس{7}. (ز) ٥٤٣٠٥- عن علي بن أبي طلحة: مكية{8}. (ز) ٥٤٣٠٦- قال مقاتل بن سليمان: مكية، وهي سبع وسبعون آية كوفية{9}. (ز) ٥٤٣٠٧- قال يحيى بن سلَّام: مكية كلها{10}. (ز) ٥٤٣٠٨- عن عمر بن الخطاب، قال: سمعت هشام بن حكيم يقرأ سورة الفرقان في حياة رسول الله ﷺ، فاستمعت لقراءته، فإذا هو يقرأ على حروفٍ كثيرة لم يُقرئنيها رسولُ الله ﷺ، فكِدتُ أُساوِرُه في الصلاة، فتصَبَّرْتُ حتى سلَّم، فلَببْتُه بردائه، فقلت: مَن أقرأك هذه السورة التي سمعتك تقرأ؟ قال: أقرأنيها رسولُ الله ﷺ. فقلت: كذبتَ؛ فإنّ رسول الله ﷺ أقرأنيها على غير ما قرأتَ. فانطلقتُ به أقوده إلى رسول الله ﷺ، فقلت: إني سمعت هذا يقرأ سورة الفرقان على حروفٍ لم تُقْرِئْنِيها. فقال رسول الله ﷺ: «أرسله، اقرأْ، يا هشام». فقرأ عليه القراءةَ التي سمعتُه يقرأ، فقال رسول الله ﷺ: «كذلك أُنزلت». ثم قال: «اقرأ، يا عمر». فقرأتُ القراءة التي أقرأني، فقال رسول الله ﷺ: «كذلك أُنزلت، إنّ هذا القرآن أُنزِل على سبعة أحرف، فاقرءوا ما تَيَسَّر منه»{11}. (١١/١٣٣-١٣٤) <q>﴿تَبَارَكَ﴾</q> - تفسير ٥٤٣٠٩- عن عبد الله بن عباس -من طريق الضَّحّاك- قال: <q>﴿تبارك﴾</q> تَفاعل مِن البَرَكة{12}. (١١/١٣٤) ٥٤٣١٠- عن أبي مالك غزوان الغفاري، نحو ذلك{13}. (ز) ٥٤٣١١- قال الحسن البصري: مجيء البركة مِن قِبَلِه{14}. (ز) ٥٤٣١٢- قال الضحاك بن مزاحم: تَعَظَّم{14}. (ز) ٥٤٣١٣- قال مقاتل بن سليمان: في قوله ﷿: <q>﴿تبارك﴾</q>، يقول: افتعل البركة{16}. (ز) ٥٤٣١٤- قال يحيى بن سلَّام: قوله: <q>﴿تبارك﴾</q>، وهو مِن باب البركة، كقوله: تعالى، ارتفع{10}٤٧٠٣. (ز) ٤٧٠٣ ذكر ابنُ القيم (٢/٢٥١) أن لفظة <q>﴿تبارك﴾</q> جاءت على «بناء السعة والمبالغة؛ كتعالى، وتعاظم، ونحوهما، فجاء بناء <q>﴿تبارك﴾</q> على بناء»تعالى«الذي هو دالٌّ على كمال العلوِّ ونهايته، فكذلك <q>﴿تبارك﴾</q> دالٌّ على كمال بركته وعظمها وسعتها، وهذا معنى قول مَن قال مِن السلف: <q>﴿تبارك﴾</q>: تعاظم». ثم ذكر أقوال المفسرين في معنى: <q>﴿تبارك﴾</q>، ثم علَّق عليها بقوله: «وحقيقة اللفظة: أنّ البركة: كثرة الخير ودوامه، ولا أحد أحق بذلك وصفًا وفعلًا منه -تبارك وتعالى-، وتفسير السلف يدور على هذين المعنيين، وهما متلازمان، لكن الأليق باللفظة معنى الوصف لا الفعل، فإنّه فِعل لازم مثل:»تعالى«و»تقدس«و»تعاظم«. ومثل هذه الألفاظ ليس معناها أنه جعل غيره عاليًا ولا قدوسًا ولا عظيمًا، هذا مما لا يحتمله اللفظ بوجه، وإنما معناها في نفس من نسبت إليه؛ فهو المتعالي المتقدس، فكذلك <q>﴿تبارك﴾</q> لا يصح أن يكون معناها: بارك في غيره، وأين أحدهما مِن الآخر لفظًا ومعنىً؛ هذا لازم وهذا متعد؟! فعلمت أنّ من فسر <q>﴿تبارك﴾</q> بمعنى: ألقى البركة، وبارك في غيره. لم يُصِب معناها، وإن كان هذا مِن لوازم كونه متباركًا». ووجَّه قول الحسن قائلًا: «وبارك من باب: أعطى وأنعم، ولما كان المتعدي في ذلك يستلزم اللازم مِن غير عكس فسَّر مَن فسَّر مِن السلف اللفظة بالمتعدي؛ لينتظم المعنيين، فقال: مجيء البركة كلها من عنده، أو البركة كلها من قِبَلِه، وهذا فَرْعٌ على تبارك في نفسه». <q>﴿ٱلَّذِی نَزَّلَ ٱلۡفُرۡقَانَ﴾</q> - تفسير ٥٤٣١٥- عن سعيد بن جبير -من طريق عطاء بن السائب- في قوله: <q>﴿نزل الفرقان﴾</q>، قال: خواتيم سورة البقرة مِن كنزٍ تحت العرش{18}. (ز) ٥٤٣١٦- عن مجاهد بن جبر -من طريق سفيان، عن رجل- قال: إنّما سُمي: الفرقان؛ لأنّه فرَّق بين الحق والباطل{18}. (ز) ٥٤٣١٧- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿تبارك الذي نزل الفرقان على عبده﴾</q>، قال: هو القرآن، فيه حلالُ الله وحرامُه، وشرائعه ودينه، فرَّق الله به بين الحق والباطل{20}. (١١/١٣٥) ٥٤٣١٨- عن الربيع بن أنس -من طريق أبي جعفر- في قوله: <q>﴿نزل الفرقان﴾</q>، قال: الفرقان: فَرَق بين الحق والباطل{18}. (ز) ٥٤٣١٩- قال مقاتل بن سليمان: <q>﴿الذي نزل الفرقان على عبده﴾</q>، يعني: القرآن، وهو المخرج من الشبهات{16}. (ز) <q>﴿عَلَىٰ عَبۡدِهِۦ﴾</q> - تفسير ٥٤٣٢٠- قال مقاتل بن سليمان: <q>﴿على عبده﴾</q> محمد ﷺ{16}. (ز) ٥٤٣٢١- عن محمد بن إسحاق -من طريق يونس بن بكير- قوله: <q>﴿على عبده﴾</q>: يعني: محمدًا ﷺ{24}. (ز) ٥٤٣٢٢- قال يحيى بن سلَّام: <q>﴿على عبده﴾</q> محمد ﷺ{10}. (ز) <q>﴿لِیَكُونَ لِلۡعَـٰلَمِینَ نَذِیرًا ۝١﴾</q> - تفسير ٥٤٣٢٣- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿ليكون للعالمين نذيرا﴾</q>، قال: بعث الله محمدًا ﷺ نذيرًا مِن الله؛ لينذر الناسَ بأسَ الله ووقائعَه بمن خلا قبلكم{26}. (١١/١٣٥) ٥٤٣٢٤- قال مقاتل بن سليمان: <q>﴿ليكون﴾</q> محمد ﷺ بالقرآن <q>﴿للعالمين نذيرا﴾</q> يعني: للإنس والجن نذيرًا. نظيرُها في فاتحة الكتاب [٢]: <q>﴿رب العالمين﴾</q>{16}. (ز) ٥٤٣٢٥- قال عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿تبارك الذي نزل الفرقان على عبده ليكون للعالمين نذيرا﴾</q>، قال: النبي النذير. وقرأ: <q>﴿وإن من أمة إلا خلا فيها نذير﴾</q> [فاطر:٢٤]، وقرأ: <q>﴿وما أهلكنا من قرية إلا لها منذرون﴾</q> [الشعراء:٢٠٨]، قال: رُسُل. قال: المنذرون: الرُّسُل. قال: وكان نذيرًا واحدًا بلغ ما بين المشرق والمغرب؛ ذو القرنين، ثم بلغ السدين، وكان نذيرًا، ولم أسمع أحدًا يُحِقُّ أنّه كان نبيًّا. <q>﴿وأوحي إلي هذا القرآن لأنذركم به ومن بلغ﴾</q> [الأنعام:١٩]، قال: مَن بلغه القرآنُ مِن الخلق، فرسول الله نذيره. وقرأ: <q>﴿يا أيها الناس إني رسول الله إليكم جميعا﴾</q> [الأعراف:١٥٨]، وقال: لم يرسل الله رسولًا إلى الناس عامَّة إلا نوحًا، بدأ به الخلق، فكان رسولَ أهل الأرض كلهم، ومحمد ﷺ ختم به{28}. (ز) ٥٤٣٢٦- قال يحيى بن سلَّام: <q>﴿نذيرا﴾</q> ينذرهم النارَ وعذابَ الدنيا قبل عذاب النار في الآخرة؛ إن لم يؤمنوا{10}. (ز) <q>﴿لِیَكُونَ لِلۡعَـٰلَمِینَ نَذِیرًا ۝١﴾</q> - آثار متعلقة بالآية ٥٤٣٢٧- عن المقداد بن الأسود، قال: لقد بعث اللهُ النبيَّ ﷺ على أشد حالٍ بعث عليها نبيًّا من الأنبياء، في فترةٍ مِن جاهلية، ما يرون أنّ دِينًا أفضل من عبادة الأوثان، فجاء بفُرقانٍ فرق به بين الحق والباطل، وفرق به بين الوالد وولده، حتى إن كان الرجلُ ليرى والدَه أو ولدَه أو أخاه كافرًا، وقد فتح الله قفل قلبه بالإيمان، ويعلم أنّه إن هلك دخل النار، فلا تَقَرُّ عينُه وهو يعلم أنّ حبيبه في النار، وإنها لَلَّتي قال اللهُ: <q>﴿والذين يقولون ربنا هب لنا من أزواجنا وذريتنا قرة أعين﴾</q> [الفرقان:٧٤]{30}. (١١/٢٣١) ",footnotes:1:أخرجه النحاس ص٦٠٣ من طريق أبي عمرو بن العلاء عن مجاهد، والبيهقي في الدلائل ٧/١٤٢-١٤٤ من طريق خُصَيف عن مجاهد. وعزاه السيوطي إلى ابن مردويه.أخرجه ابن الضريس في فضائل القرآن (١٧، ١٨).عزاه السيوطي إلى ابن مردويه.أخرجه البيهقي في دلائل النبوة ٧/١٤٢-١٤٣.أخرجه الحارث المحاسبي في فهم القرآن ص٣٩٥-٣٩٦ من طريق سعيد، وأبو بكر بن الأنباري -كما في الإتقان في علوم القرآن ١/٥٧- من طريق همام.أخرجه ابن جرير ١٧/٥٢٦، وإسحاق البستي في تفسيره ص٥٢٤. وعزاه السيوطي إلى عبد بن حميد، وابن أبي حاتم.تنزيل القرآن ص٣٧-٤٢.أخرجه أبو عبيد في فضائله (ت: الخياطي) ٢/٢٠٠.تفسير مقاتل بن سليمان ٣/٢٢٣.تفسير يحيى بن سلام ١/٤٦٨.أخرجه البخاري ٣/١٢٢ (٢٤١٩)، ٦/١٨٤-١٨٥ (٤٩٩٢)، ٦/١٩٤ (٥٠٤١)، ٩/١٧-١٨ (٦٩٣٦)، ٩/١٥٩ (٧٥٥٠)، ومسلم ١/٥٦٠ (٨١٨)، وابن جرير ١/٢٤-٢٥.أخرجه ابن جرير ١٧/٣٩٤، وابن أبي حاتم ٨/٢٦٥٩.علَّقه ابن أبي حاتم ٨/٢٦٥٩.تفسير الثعلبي ٧/١٢٣، وتفسير البغوي ٦/٧١.تفسير الثعلبي ٧/١٢٣، وتفسير البغوي ٦/٧١.تفسير مقاتل بن سليمان ٣/٢٢٥.تفسير يحيى بن سلام ١/٤٦٨.أخرجه ابن أبي حاتم ٨/٢٦٥٩.أخرجه ابن أبي حاتم ٨/٢٦٥٩.أخرجه ابن أبي حاتم ٨/٢٦٦٠، ٢٦٦٢-٢٦٦٤، ٢٦٦٦. وعلَّقه يحيى بن سلام ١/٤٦٨ مختصرًا. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه ابن أبي حاتم ٨/٢٦٥٩.تفسير مقاتل بن سليمان ٣/٢٢٥.تفسير مقاتل بن سليمان ٣/٢٢٥.أخرجه ابن أبي حاتم ٨/٢٦٦٠.تفسير يحيى بن سلام ١/٤٦٨.أخرجه ابن أبي حاتم ٨/٢٦٦٠، ٢٦٦٢-٢٦٦٤، ٢٦٦٦. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.تفسير مقاتل بن سليمان ٣/٢٢٥.أخرجه ابن جرير ١٧/٣٩٤، وابن أبي حاتم ٨/٢٦٦٠ شطره الأول من طريق أصبغ.تفسير يحيى بن سلام ١/٤٦٨.أخرجه أحمد ٣٩/٢٣٠، والبخاري في الأدب المفرد (٨٧)، وابن جرير ١٧/٥٣١، وابن أبي حاتم ٨/٢٧٤١ من طريق جبير بن نفير، والطبراني ٢٠/٢٥٣-٢٥٤، وأبو نعيم في الحلية ١/١٧٥. وعزاه السيوطي إلى ابن مردويه. وسيأتي الأثر في آخر السورة عند قوله تعالى: <q>﴿ربنا هب لنا من أزواجنا وذرياتنا قرة أعين﴾</q>.
25,2," <q>﴿ٱلَّذِی لَهُۥ مُلۡكُ ٱلسَّمَـٰوَ ٰ⁠تِ وَٱلۡأَرۡضِ﴾</q> - تفسير ٥٤٣٢٨- قال مقاتل بن سليمان: ثم عظَّم الربُّ ﷿ نفسَه عن شِرْكِهم، فقال سبحانه: <q>﴿الذي له ملك السماوات والأرض﴾</q> وحده{1}. (ز) <q>﴿وَلَمۡ یَتَّخِذۡ وَلَدࣰا﴾</q> - تفسير ٥٤٣٢٩- عن عكرمة مولى ابن عباس -من طريق الحكم بن أبان- قال: قالت اليهود: عزيرٌ ابن الله. وقالت النصارى: المسيحُ ابن الله. وقالت الصّابِئَة: نحن نعبد الملائكةَ مِن دون الله. وقالت المجوس: نحن نعبد الشمس والقمر من دون الله. وقال أهل الأوثان: نحن نعبد الأوثان من دون الله. فأوحى الله إلى نبيِّه ﷺ ليكذِّبَ قولَهم: <q>﴿ولم يتخذ ولدًا﴾</q>{2}. (ز) ٥٤٣٣٠- قال مقاتل بن سليمان: <q>﴿ولم يتخذ ولدا﴾</q> لقول اليهود والنصارى: [عزير] ابن الله، والمسيح ابن الله{1}. (ز) <q>﴿وَلَمۡ یَكُن لَّهُۥ شَرِیكࣱ فِی ٱلۡمُلۡكِ﴾</q> - تفسير ٥٤٣٣١- عن محمد بن كعب القُرَظِيِّ -من طريق أبي صخر- في هذه الآية: <q>﴿ولم يكن له شريك في الملك﴾</q>، قال: قالت اليهود والنصارى: اتَّخذ اللهُ ولدًا. وقالت العرب: لبيك اللهم لبيك لا شريك لك إلا شريكًا هو لك. وقالت الصابئة والمجوس: لولا أولياء الله لذلَّ الله. فأنزل الله ﷿: <q>﴿لم يتخذ ولدًا ولم يكن له شريك في الملك﴾</q>{2}. (ز) ٥٤٣٣٢- قال مقاتل بن سليمان: <q>﴿ولم يكن له شريك في الملك﴾</q> مِن الملائكة، وذلك أنّ العرب قالوا: إنّ لله ﷿ شريكًا مِن الملائكة، فعبدوهم، فأكذبهم الله ﷿. نظيرُها في آخر «بني إسرائيل»{5}. (ز) <q>﴿وَخَلَقَ كُلَّ شَیۡءࣲ فَقَدَّرَهُۥ تَقۡدِیرࣰا ۝٢﴾</q> - تفسير ٥٤٣٣٣- عن علي [بن أبي طالب] -من طريق سعيد بن جبير- قال: <q>﴿وخلق كل شيء فقدره تقديرا﴾</q>، قال: كل شيء بقَدَرٍ، حتى هذه. ووضع طرف إصبعه السبابة على طرف لسانه، ثم وضعها على ظِفْر إبهامه اليسرى{6}. (ز) ٥٤٣٣٤- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿وخلق كل شيء فقدره تقديرا﴾</q>، قال: بيَّن لكل شيءٍ مِن خلقه صلاحَه، وجعل ذلك بقَدَر معلوم{7}. (١١/١٣٥) ٥٤٣٣٥- قال مقاتل بن سليمان: <q>﴿وخلق كل شيء فقدره تقديرا﴾</q> كما ينبغي أن يخلقه{1}. (ز) ",footnotes:1:تفسير مقاتل بن سليمان ٣/٢٢٥.أخرجه ابن أبي حاتم ٨/٢٦٦١.تفسير مقاتل بن سليمان ٣/٢٢٥.أخرجه ابن أبي حاتم ٨/٢٦٦١.تفسير مقاتل بن سليمان ٣/٢٢٥. يشير إلى قوله تعالى: <q>﴿وقُلِ الحَمْدُ لِلَّهِ الَّذِي لَمْ يَتَّخِذْ ولَدًا ولَمْ يَكُنْ لَهُ شَرِيكٌ فِي المُلْكِ ولَمْ يَكُنْ لَهُ ولِيٌّ مِنَ الذُّلِّ وكَبِّرْهُ تَكْبِيرًا﴾</q> [الإسراء:١١١].أخرجه يحيى بن سلام ١/٤٦٨.أخرجه ابن أبي حاتم ٨/٢٦٦٢. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.تفسير مقاتل بن سليمان ٣/٢٢٥.
