quran[7]{c,v,t}:
  4,128,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَإِنِ ٱمۡرَأَةٌ خَافَتۡ مِنۢ بَعۡلِهَا نُشُوزًا أَوۡ إِعۡرَاضࣰا فَلَا جُنَاحَ عَلَیۡهِمَاۤ أَن یُصۡلِحَا بَیۡنَهُمَا صُلۡحࣰاۚ وَٱلصُّلۡحُ خَیۡرࣱۗ وَأُحۡضِرَتِ ٱلۡأَنفُسُ ٱلشُّحَّۚ وَإِن تُحۡسِنُوا۟ وَتَتَّقُوا۟ فَإِنَّ ٱللَّهَ كَانَ بِمَا تَعۡمَلُونَ خَبِیرࣰا ۝١٢٨﴾</span> - قراءات</h3></p><p><div></p><p><p><span class="item-no">٢٠٤٧١<span class="dash">-</span></span> عن <span class="name-2">عاصم بن أبي النجود</span> أنّه قرأ: <span class="qpc-hafs">﴿يُصْلِحا بينهما﴾</span> مُخَفَّفة، مرفوعة الياء، بغير ألف{1}<span class=comment-ref>١٨٧٣</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>١٨٧٣</span> اختُلِف في قراءة <span class="qpc-hafs">﴿يصلحا﴾</span>؛ <b>فقرأ قوم</b>: ‹يَصّالَحا› بفتح الياء وتشديد الصاد، <b>وقرأ آخرون</b> بضم الياء وتخفيف الصاد. وذكر <u>ابنُ جرير</u> (٧/٥٦٠) أن قراءة التشديد بمعنى: أن يتصالحا بينهما صلحًا، ثم أدغمت التاء في الصاد، فَصُيِّرتا صادًا مشددة. وأن قراءة التخفيف بمعنى: أصلح الزوج والمرأة بينهما.</p><p>و<span class="comment-type-3">رجَّح</span> <u>ابنُ جرير</u> (٧/٥٦٠-٥٦١) قراءة التشديد <span class="mustanad">مستندًا إلى الأكثر الأفصح في اللغة</span>، فقال: «لأنّ التصالح في هذا الموضع أشهر وأوضح معنى، وأفصح وأكثرُ على ألسن العرب من الإصلاح، والإصلاح في خلاف الإفساد أشهر منه في معنى التصالح. فإن ظنَّ ظانٌّ أنّ في قوله: <span class="qpc-hafs">﴿صلحًا﴾</span> دلالة على أنّ قراءة من قرأ ذلك <span class="qpc-hafs">﴿يُصْلِحا﴾</span> بضم الياء أولى بالصواب، فإنّ الأمر في ذلك بخلاف ما ظنَّ، وذلك أنّ الصلح اسم وليس بفعل، فيُستدلّ به على أولى القراءتين بالصواب في قوله: <span class="qpc-hafs">﴿يصلحا بينهما صلحًا﴾</span>».</p><p>وذكر <u>ابنُ عطية</u> (٣/٣٦) أن قوله: <span class="qpc-hafs">﴿صلحًا﴾</span> ليس الصلح فيه مصدرًا على واحد من الأفعال التي قُرِئ بها، فالذي يحتمل أن يكون اسمًا كالعطاء مع أعطيت والكرامة مع أكرمت. ثم قال: «فمن قرأ: <span class="qpc-hafs">﴿يصلحا﴾</span> كان تَعَدِّيه إلى الصلح كتَعَدِّيه إلى الأسماء، كما تقول: أصلحت ثوبًا، ومن قرأ: ‹يَصّالَحا› من تفاعل، وعُرف تفاعل أنه لا يَتَعَدّى، فوجهه أنّ تفاعل قد جاء متعديًا».</div></p><p><h3><span class="qpc-hafs">﴿وَإِنِ ٱمۡرَأَةٌ خَافَتۡ مِنۢ بَعۡلِهَا نُشُوزًا أَوۡ إِعۡرَاضࣰا فَلَا جُنَاحَ عَلَیۡهِمَاۤ أَن یُصۡلِحَا بَیۡنَهُمَا صُلۡحࣰاۚ وَٱلصُّلۡحُ خَیۡرࣱۗ وَأُحۡضِرَتِ ٱلۡأَنفُسُ ٱلشُّحَّۚ وَإِن تُحۡسِنُوا۟ وَتَتَّقُوا۟ فَإِنَّ ٱللَّهَ كَانَ بِمَا تَعۡمَلُونَ خَبِیرࣰا ۝١٢٨﴾</span> - نزول الآية</h3></p><p><div></p><p><p><span class="item-no">٢٠٤٧٢<span class="dash">-</span></span> عن <span class="name-1">عائشة</span>، قالت: كان رسول الله ﷺ لا يُفَضِّل بعضَنا على بعض في مُكْثِه عندنا، وكان قلَّ إلا وهو يطوف علينا، فيدنو مِن كل امرأة مِن غير مسيس، حتى يبلغ إلى مَن هو يومُها، فيبيت عندها، ولقد قالت سودة بنت زمعة حين أسنَّت وفَرِقَتْ{2} أن يفارقها رسول الله ﷺ: يا رسول الله، يومي هو لعائشة. فقَبِل ذلك رسول الله ﷺ، قالت عائشة: ففِيَّ أنزل الله: <span class="qpc-hafs">﴿وإن امرأة خافت من بعلها نشوزا أو إعراضا﴾</span> الآية{3}. (٥/٦٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٠٤٧٣<span class="dash">-</span></span> عن <span class="name-1">عائشة</span>، قالت: نزلت هذه الآية: <span class="qpc-hafs">﴿والصلح خير﴾</span> في رجل كانت تحته امرأة، قد طالت صحبتها، وولدت منه أولادًا، فأراد أن يستبدل بها، فراضته على أن يقيم عندها ولا يقيم لها{4}. (٥/٦٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٠٤٧٤<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عكرمة- قال: خَشِيَت سودةُ أن يطلقها رسول الله ﷺ، فقالت: يا رسول الله، لا تطلقني، واجعل يومي لعائشة. ففعل، ونزلت هذه الآية: <span class="qpc-hafs">﴿وإن امرأة خافت من بعلها نشوزا﴾</span> الآية.= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٠٤٧٥<span class="dash">-</span></span> قال <span class="name-1">ابن عباس</span>: فما اصطلحا عليه من شيء فهو جائز{5}. (٥/٦٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٠٤٧٦<span class="dash">-</span></span> عن <span class="name-2">سعيد بن المسيب</span>: أنّ ابنة محمد بن مسلمة كانت عند رافع بن خديج، فكرِه منها أمرًا، إمّا كبرًا أو غيره، فأراد طلاقها، فقالت: لا تطلقني، واقسِم لي ما بدا لك. فاصطلحا على صلح، فجَرَتِ السُّنَّة بذلك، ونزل القرآن: <span class="qpc-hafs">﴿وإن امرأة خافت من بعلها﴾</span> الآية{6}<span class=comment-ref>١٨٧٤</span>. (٥/٦٧)</p></p><p></div></p><p><div><span class=comment-ref>١٨٧٤</span> <span class="comment-type-4">علَّق</span> <u>ابنُ كثير</u> (٤/٣٠٣) على هذا الأثر بقوله: «وقد رواه الحاكم في مستدركه، من طريق عبد الرزاق، عن مَعْمَر، عن الزهري، عن سعيد بن المسيب وسليمان بن يسار، بأطول من هذا السياق».</div></p><p><div></p><p><p><span class="item-no">٢٠٤٧٧<span class="dash">-</span></span> عن <span class="name-2">سعيد بن المسيب</span>، وسليمان بن يسار: أنّ رافع بن خديج كانت تحته امرأةٌ قد خَلا مِن سِنِّها، فتزوج عليها شابَّةً، فآثرها عليها، فأَبَتِ الأولى أن تُقِرَّ، فطلقها تطليقة، حتى إذا بقي من أجلها يسير قال: إن شئتِ راجعتُكِ وصَبَرْتِ على الأَثَرَة، وإن شئت تركتك. قالت: بل راجعني. فراجعها، فلم تصبر على الأَثَرَة، فطلَّقها أخرى، وآثر عليها الشابة، فذلك الصلح الذي بلغنا أنّ الله أنزل فيه: <span class="qpc-hafs">﴿وإن امرأة خافت من بعلها نشوزا أو إعراضا﴾</span> الآية{7}. (٥/٦٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٠٤٧٨<span class="dash">-</span></span> عن عَبيدة السلماني بمثله، وزاد فيه: فإن أضَرَّ بها الثالثة فإنّ عليه أن يوفيها حقَّها، أو يُطَلِّقها{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٠٤٧٩<span class="dash">-</span></span> عن <span class="name-2">سعيد بن المسيب</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٠٤٨٠<span class="dash">-</span></span> وسليمان بن يسار -من طريق الزهري-: أنّ السُّنَّة في هاتين الآيتين اللتين ذكر الله فيهما نشوزَ المرء، وإعراضَه عن امرأته، في قوله: <span class="qpc-hafs">﴿وإن امرأة خافت من بعلها نشوزا أو إعراضا﴾</span> إلى تمام الآيتين؛ أنّ المرء إذا نَشَز عن امرأته، وآثر عليها، فإنّ من الحق أن يعرض عليها أن يطلقها، أو تستقر عنده على ما كانت مِن أثَرَةٍ في القسم مِن ماله ونفسه، فإن استقرت عنده على ذلك، وكرهت أن يطلقها، فلا حرج عليه فيما آثر عليها من ذلك، فإن لم يعرض عليها الطلاق، وصالحها على أن يعطيها من ماله ما ترضاه وتَقَرَّ عنده على الأَثَرَةِ في القسم من ماله ونفسه صلح له ذلك، وجاز صلحها عليه. كذلك ذكر سعيد بن المسيب وسليمان الصلح الذي قال الله ﷿: <span class="qpc-hafs">﴿فلا جناح عليهما أن يصلحا بينهما صلحا والصلح خير﴾</span>.= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٠٤٨١<span class="dash">-</span></span> وقد ذكر لي: أنّ رافع بن خديج الأنصاري -وكان من أصحاب النبي ﷺ-كانت عنده امرأة، حتى إذا كبرت تزوَّج عليها فتاة شابة، وآثر عليها الشابة، فناشدته الطلاق، فطلقها تطليقة، ثم أمهلها، حتى إذا كادت تحل راجعها، ثم عاد فآثر الشابة عليها، فناشدته الطلاق، فطلقها تطليقة أخرى، ثم أمهلها، حتى إذا كادت تحل راجعها، ثم عاد فآثر الشابة عليها، فناشدته الطلاق، فقال لها: ما شئت، إنما بقيت لك تطليقة واحدة، فإن شئت استقررت على ما ترين مِن الأَثَرَة، وإن شئت فارقتك. فقالت: لا، بل أسْتَقِرُّ على الأَثَرَة. فأمسكها على ذلك، فكان ذلك صلحهما، ولم ير رافع عليه إثمًا حين رضيت أن تستقر عنده على الأَثَرَة فيما أثر به عليها{9}<span class=comment-ref>١٨٧٥</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>١٨٧٥</span> <span class="comment-type-4">علَّق</span> <u>ابنُ كثير</u> (٤/٣٠٤) على هذا الأثر بقوله: «وهذا رواه بتمامه عبد الرحمن بن أبي حاتم، عن أبيه، عن أبي اليمان، عن شعيب، عن الزهري، عن سعيد بن المسيب، وسليمان بن يسار، فذكره بطوله».</div></p><p><div></p><p><p><span class="item-no">٢٠٤٨٢<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span> -من طريق سالم- قال: جاءت المرأة حين نزلت هذه الآية: <span class="qpc-hafs">﴿وإن امرأة خافت من بعلها نشوزا أو إعراضا﴾</span>، قالت: إني أريد أن تَقْسِم لي من نفسك. وقد كانت رَضِيَت أن يدعها فلا يُطَلِّقها، ولا يأتيها؛ فأنزل الله: <span class="qpc-hafs">﴿وأحضرت الأنفس الشح﴾</span>{10}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٠٤٨٣<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span>، في الآية، قال: نزلت في أبي السنابل بن بَعْكَكٍ{11}. (٥/٦٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٠٤٨٤<span class="dash">-</span></span> عن ابن جُرَيْج، قال: قلت ل<span class="name-2">عطاء</span>: الرجل يخطب المرأة وعنده امرأة، فيخطبها على أنّ لكِ يومًا ولفلانة يومين عند الخطبة قبل النكاح؟ قال: جائز ذلك قبل النكاح، وبعد أن اصطلحا على ذلك. قلتُ: أفي ذلك نزلت: <span class="qpc-hafs">﴿وإن امرأة خافت من بعلها نشوزا أو إعراضا﴾</span>؟ قال: نعم. قلت: أصَنَع ذلك النبي ﷺ ببعض نسائه؟ قال: نعم. قال: قلت: ما <span class="qpc-hafs">﴿وأحضرت الأنفس الشح﴾</span>؟ قال: في النفقة، زعموا أنّ تلك المرأة سودة{12}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٠٤٨٥<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السدي</span>، في الآية، قال: نزلت في رسول الله ﷺ وفي سودة بنت زمعة{13}. (٥/٦٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٠٤٨٦<span class="dash">-</span></span> عن جرير بن حازم، قال: سمعت قيس [بن سعد المكى]، في قول الله: <span class="qpc-hafs">﴿وإن امرأة خافت من بعلها نشوزا أو إعراضا﴾</span>، قال: نزلت في أبي السنابل بن بَعْكَكٍ أخي بني عبد الدار{14}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٠٤٨٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وإن امرأة خافت من بعلها نشوزا أو إعراضا﴾</span> نزلت في رافع بن خديج الأنصاري، وفي امرأته خويلة بنت محمد بن مسلمة الأنصاري، وذلك أنّ رافعًا طلَّقها، ثم راجعها، وتزوج عليها أشبَّ منها، وكان يأتي الشابَّة ما لا يأتي الكبيرة{15}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَإِنِ ٱمۡرَأَةٌ خَافَتۡ مِنۢ بَعۡلِهَا نُشُوزًا أَوۡ إِعۡرَاضࣰا فَلَا جُنَاحَ عَلَیۡهِمَاۤ أَن یُصۡلِحَا بَیۡنَهُمَا صُلۡحࣰاۚ وَٱلصُّلۡحُ خَیۡرࣱۗ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٢٠٤٨٨<span class="dash">-</span></span> عن <span class="name-1">عمر بن الخطاب</span>: أن رجلًا سأله عن آية، فكره ذلك، وضربه بالدِّرَّة، فسأله آخر عن هذه الآية: <span class="qpc-hafs">﴿وإن امرأة خافت من بعلها نشوزا﴾</span>. فقال: عن مثل هذا فسلوا. ثم قال: هذه المرأة تكون عند الرجل قد خلا مِن سِنِّها، فيتزوج المرأة الثانية يلتمس ولدها، فما اصطلحا عليه من شيء فهو جائز{16}. (٥/٦٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٠٤٨٩<span class="dash">-</span></span> عن <span class="name-1">علي بن أبي طالب</span> -من طريق خالد بن عَرْعَرَة- أنّه سُئِل عن هذه الآية. فقال: هو الرجل عنده امرأتان، فتكون إحداهما قد عجزت، أو تكون دميمة، فيريد فراقها، فتصالحه على أن يكون عندها ليلة، وعند الأخرى ليالي، ولا يفارقها، فما طابت به نفسه فلا بأس به، فإن رجعت سوّى بينهما{17}. (٥/٦٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٠٤٩٠<span class="dash">-</span></span> عن <span class="name-1">عائشة</span> -من طريق عروة- <span class="qpc-hafs">﴿وإن امرأة خافت من بعلها نشوزا أو إعراضا﴾</span>، قالت: الرجل تكون عنده المرأة ليس مُسْتَكْثِرًا منها، يريد أن يفارقها، فتقول: أجعلك من شأني في حِلٍّ. فنَزلت هذه الآية{18}<span class=comment-ref>١٨٧٦</span>. (٥/٦٦)</p></p><p></div></p><p><div><span class=comment-ref>١٨٧٦</span> <span class="comment-type-4">علَّق</span> <u>ابنُ كثير</u> (٤/٣٠٣) على هذا القول بقوله: «ولا أعلم في ذلك خلافًا في أن المراد بهذه الآية هذا».</div></p><p><div></p><p><p><span class="item-no">٢٠٤٩١<span class="dash">-</span></span> عن <span class="name-1">عائشة</span> -من طريق عروة- في قوله: <span class="qpc-hafs">﴿وإن امرأة خافت من بعلها نشوزا أو إعراضا﴾</span> الآية، قالت: هي المرأة عند الرجل لا يستكثر منها، فيريد أن يطلقها ويتزوج غيرها، فتقول: احبسني ولا تطلقني، فأنت في حِلٍّ من النفقة عَلَيَّ والقسمة لي. فذلك قوله: <span class="qpc-hafs">﴿لا جناح عليهما أن يصلحا بينهما صلحا والصلح خير﴾</span>{19}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٠٤٩٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق سعيد بن جبير- في الآية، قال: هي المرأة تكون عند الرجل حتى تكبر، فيريد أن يتزوج عليها، فيتصالحان بينهما صلحًا على أن لها يومًا، ولهذه يومان أو ثلاثة{20}. (٥/٦٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٠٤٩٣<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق العوفي- في الآية، قال: هو الرجل تكون تحته المرأة الكبيرة، فينكح عليها المرأة الشابة، ويكره أن يُفارِق أُمَّ ولده، فيصالحها على عطية من ماله ونفسه، فيطيب له ذلك الصلح{21}. (٥/٦٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٠٤٩٤<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- في الآية، قال: تلك المرأة تكون عند الرجل لا يرى منها كثيرًا مما يُحِبُّ، وله امرأة غيرها أحبُّ إليه منها، فيؤثرها عليها، فأمر الله إذا كان ذلك أن يقول لها: يا هذه، إن شئت أن تقيمي على ما ترين من الأَثَرَة فأُواسيك وأُنفِق عليك فأقيمي، وإن كرهتِ خَلَّيْتُ سبيلك. فإن هي رضيت أن تقيم بعد أن يخبرها فلا جناح عليه، وهو قوله: <span class="qpc-hafs">﴿والصلح خير﴾</span>. يعني: أنّ تخيير الزوج لها بين الإقامة والفراق خيرٌ من تمادي الزوج على أثَرَةِ غيرها عليها{22}. (٥/٦٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٠٤٩٥<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي بن أبي طلحة- قوله: <span class="qpc-hafs">﴿وإن امرأة خافت من بعلها نشوزا أو إعراضا﴾</span>، يعني: البُغْض{23}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٠٤٩٦<span class="dash">-</span></span> قال <span class="name-1">عبد الله بن عباس</span> -من طريق سليمان بن يسار- في هذه الآية: فإن صالَحَتْه عن بعض حقِّها مِن القَسْم والنَّفقة فذلك جائزٌ ما رَضِيَتْ، فإن أنكرت بعد الصلح فذلك لها، ولها حقُّها{24}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٠٤٩٧<span class="dash">-</span></span> عن <span class="name-2">عَبيدة السلماني</span>، -من طريق محمد بن سيرين- قال: سألته عن قول الله: <span class="qpc-hafs">﴿وإن امرأة خافت من بعلها نشوزا أو إعراضا﴾</span>. قال: هي المرأة تكون مع زوجها، فيريد أن يتزوج عليها، فتصالحه من يومها على صلح. قال: فهما على ما اصطلحا عليه، فإن انتقضت به فعليه أن يعدِل عليها، أو يفارقها{25}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٠٤٩٨<span class="dash">-</span></span> عن <span class="name-2">إبراهيم النخعي</span> -من طريق مغيرة- أنّه كان يقول ذلك{26}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٠٤٩٩<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق حجّاج- أنّه كان يقول ذلك{27}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٠٥٠٠<span class="dash">-</span></span> عن ابن شهاب، أخبرني <span class="name-2">سعيد بن المسيب</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٠٥٠١<span class="dash">-</span></span> و<span class="name-2">سليمان بن يسار</span> أنّ السُّنَّة في الآية التي ذكر الله فيها نشوزَ المرء وإعراضَه عن امرأته: أنّ المرء إذا نشز عن امرأته، أو أعرض عنها؛ فإنّ من الحق عليه أن يعرض عليها أن يطلقها، أو تستقر عنده على ما رأت مِن أثَرَة في القسم من نفسه وماله{28}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٠٥٠٢<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span> -من طريق عطاء- قال: هي المرأة تكون عند الرجل، قد طالت صحبتُها، وكبرت، فيريد أن يتبدل بها، فتكره أن تفارقه، فيتزوج عليها، فيصالحا على أن يجعل لها أيامًا، وللأخرى الأيام والشهر{29}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٠٥٠٣<span class="dash">-</span></span> قال <span class="name-2">إبراهيم النخعي</span> -من طريق مغيرة-: إذا شاءت كانت على حقِّها، وإن شاءت أبَتْ فرَدَّت الصلح، فذاك بيدها؛ فإن شاء طلَّقها، وإن شاء أمسكها على حقِّها{30}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٠٥٠٤<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- قال: هذا في الرجل يكون عنده المرأة الكبيرة، فيقول لها: أنت كبيرة، وأنا أريد أن استبدل بك امرأة شابة. فإن شئتِ فاستقرِّي على ولدِك، فلا أقْسِم لكِ مِن نفسي شيئًا، فإن رضيت فهو الصلح الذي قال الله ﷿: <span class="qpc-hafs">﴿والصلح خير﴾</span>. نزلت في أبي السنابل ابن بعكك{31}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٠٥٠٥<span class="dash">-</span></span> عن <span class="name-2">ابن أبي نجيح</span> -من طريق شبل- <span class="qpc-hafs">﴿من بعلها نشوزا أو إعراضا﴾</span>، ثم ذكر نحوه. قال شبل: فقلت له: فإن كانت لك امرأةٌ فتقسم لها، ولم تقسم لهذه؟ قال: إذا صالَحَتْه على ذلك فليس عليه شيء{32}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٠٥٠٦<span class="dash">-</span></span> عن <span class="name-2">الضحاك بن مُزاحِم</span> -من طريق عبيد بن سليمان- يقول في قوله: <span class="qpc-hafs">﴿وإن امرأة خافت من بعلها نشوزا أو إعراضا﴾</span>: فهو الرجل تكون تحته المرأة الكبيرة، فيتزوج عليها المرأة الشابة، فيميل إليها، وتكون أعجب إليه من الكبيرة، فيصالح الكبيرة على أن يعطيها من ماله، ويقسم لها من نفسه نصيبًا معلومًا{33}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٠٥٠٧<span class="dash">-</span></span> عن جبار، قال: سألت <span class="name-2">عامرًا [الشعبي]</span> عن الرجل تكون عنده المرأة يريد أن يطلقها، فتقول: لا تطلقني، واقسم لي يوًما، وللتي تزوج يومين. قال: لا بأس به، هو صلح{32}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٠٥٠٨<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق هشام- أنّه كان يقول: الصلح جائز بينهما، فإذا نَقَضَت ذلك بعد ما صالحت ورَضِيَت فليس لها أن تنقض، الصلح جائز بينهما{35}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٠٥٠٩<span class="dash">-</span></span> عن <span class="name-2">عطاء [بن أبي رباح]</span> -من طريق ابن جريج- قال: النشوز: أن تحب فراقه، وإن لم يَهْوَ في ذلك{36}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٠٥١٠<span class="dash">-</span></span> عن <span class="name-2">الحكم [بن عتيبة]</span> -من طريق يحيى بن عبد الملك، عن أبيه- <span class="qpc-hafs">﴿وإن امرأة خافت من بعلها نشوزا أو إعراضا﴾</span> قال: هي المرأة تكون عند الرجل، فيريد أن يخلي سبيلها، فإذا خافت ذلك منه <span class="qpc-hafs">﴿فلا جناح عليهما أن يصلحا بينهما صلحا﴾</span>، تدع من أيامها إذا تزوج{37}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٠٥١١<span class="dash">-</span></span> وعن <span class="name-2">الحسن البصري</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٠٥١٢<span class="dash">-</span></span> و<span class="name-2">عطية العوفي</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٠٥١٣<span class="dash">-</span></span> و<span class="name-2">عطاء بن أبي رباح</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٠٥١٤<span class="dash">-</span></span> و<span class="name-2">مكحول الشامي</span>، نحو ذلك{38}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٠٥١٥<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دِعامة</span> -من طريق سعيد- قوله: <span class="qpc-hafs">﴿وإن امرأة خافت من بعلها نشوزا أو إعراضا﴾</span> فقرأ حتى بلغ: <span class="qpc-hafs">﴿فإن الله كان بما تعملون خبيرا﴾</span>، قال: وهذا في الرجل تكون عنده المرأة قد خلا مِن سِنِّها، وهان عليه بعضُ أمرها، فيقول: إن كنتِ راضية من نفسي ومالي بدون ما كنت ترضين به قبل اليوم. فإن اصطلحا من ذلك على أمر الله فقد أحلَّ لهما ذلك، وإن أبَتْ فإنّه لا يصلح له أن يحبسها على الخَسْف{39}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٠٥١٦<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- <span class="qpc-hafs">﴿وإن امرأة خافت من بعلها نشوزا أو إعراضا فلا جناح عليهما أن يصلحا بينهما صلحا والصلح خير﴾</span>، قال: المرأة ترى من زوجها بعض الجفاء، وتكون قد كبرت، أو لا تلد، فيريد زوجها أن ينكح غيرها، فيأتيها فيقول: إني أريد أن أنكح امرأةً شابَّةً أشبَّ منك، لعلها أن تلد لي، وأوثرها في الأيام والنفقة. فإن رَضِيَت بذلك وإلا طلقها، فيصطلحان على ما أحَبّا{32}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٠٥١٧<span class="dash">-</span></span> قال <span class="name-3">محمد بن السائب الكلبي</span>: <span class="qpc-hafs">﴿نشوزا﴾</span>، يعني: ترك مضاجعتها{41}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٠٥١٨<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وإن امرأة﴾</span> واسمها خويلة بنت محمد بن مسلمة <span class="qpc-hafs">﴿خافت﴾</span> يعني: علمت <span class="qpc-hafs">﴿من بعلها نشوزا﴾</span> يعني: زوجها، <span class="qpc-hafs">﴿أو إعراضا﴾</span> عنها لِما بها مِن العِلَّة إلى الأخرى؛ <span class="qpc-hafs">﴿فلا جناح عليهما﴾</span> الزوج، والمرأة الكبيرة <span class="qpc-hafs">﴿أن يصلحا بينهما صلحا﴾</span> أن ترضى المرأة الكبير بما له، على أن يأتي الشابة ما لا يأتي الكبيرة. يقول: فلا بأس بذلك في القسمة، فذلك قوله ﷿: <span class="qpc-hafs">﴿والصلح خير﴾</span> من المفارقة{15}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٠٥١٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن حيان</span>، في هذه الآية: هو أنّ الرجل يكون تحته المرأة الكبيرة، فيتزوج عليها الشابَّة، فيقول للكبيرة: أعطيتكِ من مالي نصيبًا على أن أقسِم لهذه الشابة أكثرَ مما أقسم لكِ. فترضى بما اصطلحا عليه، فإن أبت أن ترضى فعليه أن يعدِل بينهما في القَسْم{24}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٠٥٢٠<span class="dash">-</span></span> عن <span class="name-3">مَعْمَر بن راشد</span> -من طريق عبد الرزاق- في رجل تزوج امرأةً، وشرط عليها أنه يؤثر عليها امرأة له، ثم بدا له بعد. فقال: لها ذلك، ليس شرطهم بشيء. وذكر مثل حديث عَبيدة <span class="qpc-hafs">﴿وإن امرأة خافت من بعلها نشوزا أو إعراضا﴾</span>{44}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٠٥٢١<span class="dash">-</span></span> قال <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿وإن امرأة خافت من بعلها نشوزا أو إعراضا﴾</span>، قال: <span class="qpc-hafs">﴿نشوزا﴾</span> عنها، عَرَّضَ بها -الرجل تكون له المرأتان-، <span class="qpc-hafs">﴿أو إعراضا﴾</span> بتركها؛ <span class="qpc-hafs">﴿فلا جناح عليهما أن يصلحا بينهما صلحا﴾</span> إمّا أن يرضيها فتُحَلِّله، وإمّا أن ترضيه فتَعْطِفَه على نفسها{33}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَإِنِ ٱمۡرَأَةٌ خَافَتۡ مِنۢ بَعۡلِهَا نُشُوزًا أَوۡ إِعۡرَاضࣰا فَلَا جُنَاحَ عَلَیۡهِمَاۤ أَن یُصۡلِحَا بَیۡنَهُمَا صُلۡحࣰاۚ وَٱلصُّلۡحُ خَیۡرࣱۗ﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٢٠٥٢٢<span class="dash">-</span></span> عن القاسم بن أبي بزَّة، قال: بعث النبي ﷺ إلى سودة بنت زمعة بطلاقها، فلمّا أن أتاها جلست له على طريق عائشة، فلمّا رأته قالت له: أنشدك بالذي أنزل عليك كلامه، واصطفاك على خلقه؛ لَما راجعتني، فإني قد كبرت، ولا حاجة لي في الرجال، لكن أريد أن أُبعَث مع نسائك يوم القيامة. فراجعها، فقالت: إنِّي جعلتُ يومي وليلتي لحِبَّة رسول الله ﷺ{46}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٠٥٢٣<span class="dash">-</span></span> عن كثير بن عبد الله، عن أبيه، عن جدِّه: سمعت رسول الله ﷺ يقول: «<b>الصلح جائز بين المسلمين، إلا صلحًا حرَّم حلالًا أو أحلَّ حرامًا، والمسلمون على شروطهم، إلا شرطًا حرَّم حلالًا</b>»{47}. (٥/٦٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٠٥٢٤<span class="dash">-</span></span> عن عبد الله بن عمر، قال: قال رسول الله ﷺ: «<b>أبغضُ الحلال إلى الله الطلاقُ</b>»{48}. (٥/٦٩)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَأُحۡضِرَتِ ٱلۡأَنفُسُ ٱلشُّحَّۚ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٢٠٥٢٥<span class="dash">-</span></span> عن <span class="name-1">علي بن أبي طالب</span> -من طريق خالد بن عرعرة- في قوله: <span class="qpc-hafs">﴿وأحضرت الأنفس الشح﴾</span>، قال: أحضرت المرأة الشح على زوجها من نفسه وماله{49}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٠٥٢٦<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق سعيد بن جبير- في قوله: <span class="qpc-hafs">﴿وأحضرت الأنفس الشح﴾</span>، قال: تشحُّ عند الصلح على نصيبها من زوجها{50}. (٥/٦٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٠٥٢٧<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق سعيد بن جبير- <span class="qpc-hafs">﴿وأحضرت الأنفس الشح﴾</span>، قال: منها، ومنه{49}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٠٥٢٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- في قوله: <span class="qpc-hafs">﴿وأحضرت الأنفس الشح﴾</span>، قال: هواه في الشيء يحرص عليه{52}. (٥/٦٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٠٥٢٩<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span> -من طريق الشيباني- <span class="qpc-hafs">﴿وأحضرت الأنفس الشح﴾</span>، قال: في الأيام، والنفقة{53}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٠٥٣٠<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span> -من طريق أبي بشر- في هذه الآية: <span class="qpc-hafs">﴿وأحضرت الأنفس الشح﴾</span>، قال: نفس المرأة على نصيبها من زوجها من نفسه، وماله{54}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٠٥٣١<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span> -من طريق أبي بشر- في قوله: <span class="qpc-hafs">﴿وأحضرت الأنفس الشح﴾</span>، قال: المرأة تشح على مال زوجها، ونفسه{55}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٠٥٣٢<span class="dash">-</span></span> عن <span class="name-2">الضحاك بن مزاحم</span> -من طريق أبي سنان- قوله: <span class="qpc-hafs">﴿وأحضرت الأنفس الشح﴾</span>، قال: أُلْزِمت{19}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٠٥٣٣<span class="dash">-</span></span> عن <span class="name-2">عطية العوفي</span> -من طريق الفضل، يعني: ابن مرزوق- في قوله: <span class="qpc-hafs">﴿وأحضرت الأنفس الشح﴾</span>، قال: في الجماع{49}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٠٥٣٤<span class="dash">-</span></span> عن <span class="name-2">عطاء [بن أبي رباح]</span> -من طريق ابن جريج- قال: في النفقة{58}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٠٥٣٥<span class="dash">-</span></span> عن <span class="name-2">عطاء [بن أبي رباح]</span> -من طريق ابن جريج- <span class="qpc-hafs">﴿وأحضرت الأنفس الشح﴾</span>، قال: في الأيام{59}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٠٥٣٦<span class="dash">-</span></span> عن <span class="name-2">عطاء [بن أبي رباح]</span> -من طريق ابن جريج- <span class="qpc-hafs">﴿وأحضرت الأنفس الشح﴾</span>، قال: في الأيام، والنفقة{60}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٠٥٣٧<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- <span class="qpc-hafs">﴿وأحضرت الأنفس الشح﴾</span>، قال: تَتَطَلَّعُ نفسها إلى زوجها وإلى نفقته. قال: وزعم أنها نزلت في رسول الله ﷺ، وفي سودة بنت زمعة، كانت قد كبرت، فأراد رسول الله ﷺ أن يطلقها، فاصطلحا على أن يمسكها، ويجعل يومها لعائشة، فشحَّت بمكانها من رسول الله ﷺ{10}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٠٥٣٨<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وأحضرت الأنفس الشح﴾</span>، يعني: الحرص على المال، يعني: الكبيرة يرضيها الزوج من بعض ماله، فتحرص على المال، وتدع نصيبها من زوجها{15}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٠٥٣٩<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- يقول في قوله: <span class="qpc-hafs">﴿وأحضرت الأنفس الشح﴾</span>، قال: لا تطيب نفسُه أن يعطيها شيئًا فتُحَلِّله، ولا تطيب نفسُها أن تعطيه شيئًا من مالها فتعطفه عليها{63}<span class=comment-ref>١٨٧٧</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>١٨٧٧</span> اختُلِف في تفسير قوله: <span class="qpc-hafs">﴿وأحضرت الأنفس الشح﴾</span> على قولين: <b>الأول</b>: وأحضرت أنفُسُ النساء الشح على أنصبائهن من أنفُس أزواجهن، وأموالهم. و<b>الثاني</b>: وأحضرت نفسُ كل واحدٍ من الرجل والمرأة الشحَّ بحقه قِبَل صاحبه.</p><p>و<span class="comment-type-3">رجَّح</span> <u>ابنُ جرير</u> (٧/٥٦٤-٥٦٦ بتصرف) القول الأول، و<span class="comment-type-2">انتَقَد</span> الثاني <span class="mustanad">مستندًا إلى أقوال السلف، والدلالات العقلية</span>، فقال: «لأن مصالحة الرجل امرأته بإعطائه إياها من ماله جُعْلًا على أن تصفح له عن القَسْم لها غير جائزة؛ وذلك أنه غير معتاض عوضًا من جُعْله الذي بذله لها، والجُعْل لا يصح إلا على عِوض: إما عين، وإما منفعة. والرجل متى جعل للمرأة جُعْلًا على أن تصفح له عن يومها وليلتها فلم يملك عليها عينًا ولا منفعة. وإذْ كان ذلك كذلك كان ذلك من معاني أكل المال بالباطل، وإذْ كان ذلك كذلك، فمعلوم أنه لا وجه لقول مَن قال: عنى بذلك الرجل والمرأة. فإن ظن ظانٌّ أن ذلك إذْ كان حقًّا للمرأة، ولها المطالبة به، فللرجل افتداؤه منها بجُعل، فإنّ شُفْعَة المستشفِع في حِصَّة من دارٍ اشتراها رجل من شريكٍ له فيها حقُّ المطالبة بها، فقد يجب أن يكون للمطلوب افتداءُ ذلك منه بجُعل. وفي إجماع الجميع على أن الصلح في ذلك على عِوض غيرُ جائز؛ إذ كان غير مُعتاض منه المطلوب في الشُّفْعة عينًا ولا نفعًا ما يدل على بُطول صلح الرجل امرأته على عوض، على أن تصفح عن مطالبتها إياه بالقسمة لها».</p><p>و<span class="comment-type-3">رجَّح</span> <u>ابنُ عطية</u> (٣/٣٧) قول ابن زيد <span class="mustanad">مستندًا لدلالة العقل</span> بقوله: «وهذا أحسن، فإنّ الغالب على المرأة الشح بنصيبها من زوجها، والغالب على الرجل الشح بنصيبه من الشابة».</div></p><p><div></p><p><p><span class="item-no">٢٠٥٤٠<span class="dash">-</span></span> عن <span class="name-3">سفيان بن عيينة</span> -من طريق ابن أبي عمر- في قوله: <span class="qpc-hafs">﴿وأحضرت الأنفس الشح﴾</span>، قال: يريد أن يأخذ منها، وتأبى أن تعطيه، يعني: في الخُلْع{49}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَإِن تُحۡسِنُوا۟ وَتَتَّقُوا۟ فَإِنَّ ٱللَّهَ كَانَ بِمَا تَعۡمَلُونَ خَبِیرࣰا ۝١٢٨﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٢٠٥٤١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وإن تحسنوا﴾</span> الفعل فلا تفارقها، <span class="qpc-hafs">﴿وتتقوا﴾</span> المَيْل والجور؛ <span class="qpc-hafs">﴿فإن الله كان بما تعملون خبيرا﴾</span> في أمرهن من الإحسان والجور{15}. (ز)</p></p><p></div></p></div>",footnotes:1:ذكره عبد بن حميد كما في قطعة من تفسيره ص١٢٢.</p><p>وهي قراءة متواترة، قرأ بها عاصم، وحمزة، والكسائي، وخلف العاشر، وقرأ بقية العشرة: ‹أن يَصّالَحا› بفتح الياء، وتشديد الصاد، بعدها ألف. ينظر: النشر ٢/٢٥٢.|2:فرقت: خافت. النهاية (فرق).|3:أخرجه أبو داود ٣/٤٧٠-٤٧١ (٢١٣٥)، والحاكم ٢/٢٠٣ (٢٧٦٠).</p><p>قال الحاكم: «هذا حديث صحيح الإسناد، ولم يخرجاه». وقال الطبراني في الاوسط ٥/٢٥٨ (٥٢٥٤): «لم يرو هذا الحديث عن هشام بن عروة إلا عبد الرحمن بن أبي الزناد». وقال ابن عبدالهادي في المحرَّر ١/٥٦٤: «إسناده جيد». وقال ابن الملقن في البدر المنير ٨/٤٠: «في إسناده عبد الرحمن بن أبي الزناد، وقد تكلم فيه غير واحد، ووثَّقه مالك، واستشهد به البخاري». وقال الألباني في صحيح أبي داود ٦/٣٥٢ (١٨٥٢): «إسناده حسن صحيح».|4:أخرجه ابن ماجه ٣/١٤٥-١٤٦ (١٩٧٤)، والحاكم ٢/٦٨ (٢٣٥٢).</p><p>قال الحاكم: «هذا حديث صحيح، على شرط الشيخين، ولم يخرجاه». وقال البوصيري في مصباح الزجاجة ٢/١١٦ (٧٠٤): «هذا إسناد موقوف صحيح، وحكمه الرفع».|5:أخرجه الترمذي ٥/٢٨٤-٢٨٥ (٣٢٨٩)، وابن جرير ٧/٥٦٠، وابن أبي حاتم ٤/١٠٧٩-١٠٨٠ (٦٠٣٦)، ٤/١٠٨٠ (٦٠٤٣).</p><p>قال الترمذي: «هذا حديث حسن غريب». وقال ابن حجر في الفتح ٨/٢٦٦: «وله شاهد في الصحيحين من حديث عائشة بدون ذكر نزول الآية». وقال في الإصابة ٧/٧٢٠: «بسند حسن». وأقرّه الألباني في الصحيحة ٣/٤٦٨.|6:أخرجه الشافعي كما في المسند ٣/٨٣ (١٢١٥)، والبيهقي في الكبرى ٧/٤٨٣ (١٤٧٣٠).|7:أخرجه الحاكم ٢/٣٣٨ (٣٢٠٥)، وعبد الرزاق ١/٤٨١-٤٨٢ (٦٤٨)، وابن جرير ٧/٥٥٦-٥٥٧.</p><p>قال الحاكم: «هذا حديث صحيح، على شرط الشيخين، ولم يخرجاه».|8:أخرجه عبد الرزاق ١/١٧٥، وابن جرير ٧/٥٥٧.|9:أخرجه البيهقي في سننه ٧/٢٩٦.|10:أخرجه ابن جرير ٧/٥٦٣.|11:تفسير مجاهد ص٢٩٤، وأخرجه ابن جرير ٧/٥٥٧-٥٥٨.|12:أخرجه عبد الرزاق في مصنفه ٦/٢٣٧-٢٣٨ (١٠٦٥١).|13:أخرجه ابن جرير ٧/٥٦٣-٥٦٤.|14:أخرجه ابن أبي حاتم ٤/١٠٧٩.|15:تفسير مقاتل بن سليمان ١/٤١٢.|16:أخرجه ابن جرير ٧/٥٥٠.|17:أخرجه الطيالسي -كما في تفسير ابن كثير ٢/٣٨٠-، وابن أبي شيبة ٤/٢٠٣-٢٠٤، وابن راهويه -كما في المطالب العالية (٣٩٤٠)-، وابن جرير ٧/٥٤٩-٥٥٠ بنحوه، والبيهقي ٧/٢٩٧. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر. وفي رواية عند ابن جرير ٧/٥٤٩: فإن وضعت له من مهرها شيئًا حَلَّ له، وإن جعلت له من أيامها شيئًا فلا حرج.|18:أخرجه ابن أبي شيبة ٤/٢٠٢-٢٠٣، والبخاري (٤٦٠١، ٥٢٠٦)، وابن جرير ٧/٥٥٢. وعزاه السيوطي إلى ابن المنذر.|19:أخرجه ابن أبي حاتم ٤/١٠٨١.|20:أخرجه ابن جرير ٧/٥٥٠-٥٥١. وعلَّقه ابن أبي حاتم ٤/١٠٨١. وعزاه السيوطي إلى ابن المنذر.|21:أخرجه ابن جرير ٧/٥٥٦.|22:أخرجه ابن جرير ٧/٥٥٣. وعزاه السيوطي إلى ابن المنذر.|23:أخرجه ابن جرير ٧/٥٥٩، وابن أبي حاتم ٤/١٠٨٠.|24:تفسير الثعلبي ٣/٣٩٥، وتفسير البغوي ٢/٢٩٥.|25:أخرجه ابن جرير ٧/٥٥٤. وأخرج نحوه ابن أبي شيبة في مصنفه (ت: محمد عوامة) ٩/١٦١ (١٦٧٣٠)، وعبد بن حميد كما في قطعة من تفسيره ص٢١٢.|26:أخرجه ابن جرير ٧/٥٥٤.|27:أخرجه ابن جرير ٧/٥٥٤. وعلَّقه ابن أبي حاتم ٤/١٠٨١.|28:أخرجه ابن أبي حاتم ٤/١٠٨٠، والبيهقي في سننه ٧/٢٩٦.|29:أخرجه ابن جرير ٧/٥٥١. وعلَّقه ابن أبي حاتم ٤/١٠٨١.|30:أخرجه ابن جرير ٧/٥٥٥.|31:تفسير مجاهد ص٢٩٤، وأخرجه عبد بن حميد كما في قطعة من تفسيره ص١٢١، وابن جرير ٧/٥٥٧.|32:أخرجه ابن جرير ٧/٥٥٨.|33:أخرجه ابن جرير ٧/٥٥٩.|34:أخرجه ابن جرير ٧/٥٥٨.|35:أخرجه عبد بن حميد كما في قطعة من تفسيره ص١٢١.|36:أخرجه ابن أبي حاتم ٤/١٠٨٠.|37:أخرجه ابن جرير ٧/٥٥٥. وعلقه ابن أبي حاتم ٤/١٠٨١.|38:علقه ابن أبي حاتم ٤/١٠٨١.|39:أخرجه ابن جرير ٧/٥٥٦. كما أخرج عبد بن حميد كما في قطعة من تفسيره ص١٢١ نحوه من طريق شيبان.</p><p>والخسف: الإهانة، وأن يُحمل المرءُ ما يكره. النهاية (خسف).|40:أخرجه ابن جرير ٧/٥٥٨.|41:تفسير الثعلبي ٣/٣٩٤، و تفسير البغوي ٢/٢٩٤.|42:تفسير مقاتل بن سليمان ١/٤١٢.|43:تفسير الثعلبي ٣/٣٩٥، وتفسير البغوي ٢/٢٩٥.|44:أخرجه عبد الرزاق في مصنفه ٦/٢٤٠ (١٠٦٦٠).|45:أخرجه ابن جرير ٧/٥٥٩.|46:أخرجه ابن سعد في الطبقات ٨/٥٤.</p><p>وقال ابن كثير في تفسيره ٢/٤٢٨: «وهذا غريب مرسل».|47:أخرجه الترمذي ٣/١٨٥ (١٤٠٢)، وابن ماجه ٣/٤٤٠ (٣٢٥٣)، والحاكم ٤/١١٣ (٧٠٥٩) وفيه كثير بن عمرو.</p><p>قال الترمذي: «هذا حديث حسن صحيح». وقال الذهبي في التلخيص: «واه». وقال ابن الملقن في البدر المنير ٦/٦٨٨: «بل واهٍ بمرَّة بسبب كثير هذا». وقال المناوي في فيض القدير ٤/٢٤٠ (٥١٥٦) على كثير بن عمرو: «قال ابن حبان: كان يسرق الحديث. وتعقب ابن القطان الأول بأن كثيرًا فيه كلام كثير. وقال البلقيني: في الاحتجاج به خلاف. وفي الميزان عن ابن حبان: له عن أبيه عن جده نسخة موضوعة. قال: ولهذا لا يعتمد العلماء على تصحيح الترمذي؛ لكونه صحح حديثه. وقد قال الشافعي وأبو داود: هو ركن من أركان الكذب». وينظر الإرواء للألباني ٥/١٤٤.|48:أخرجه أبو داود ٣/٥٠٥ (٢١٧٨)، وابن ماجه ٣/١٨٠ (٢٠١٨)، والحاكم ٢/٢١٤ (٢٧٩٤)، والثعلبي ٩/٣٣٣.</p><p>قال الحاكم: «هذا حديث صحيح الإسناد، ولم يخرجاه». وقال ابن كثير في تفسيره ٤/٣٠٥: «رواه أبو داود عن أحمد بن يونس، عن مُعَرِّف بن محارب، قال: قال رسول الله ﷺ ... فذكر معناه مرسلًا». وقال ابن حجر في الفتح ٩/٣٥٦: «أعل بالإرسال». وقال المناوي في التيسير بشرح الجامع الصغير ١/١٦: «روى مرسلًا، ورُجِّح على المسند». وضعّفه الألباني في الإرواء ٧/١٠٦ (٢٠٤٠).|49:أخرجه ابن أبي حاتم ٤/١٠٨٢.|50:أخرجه ابن جرير ٧/٥٦١ مختصرًا. وعزاه السيوطي إلى ابن المنذر.|51:أخرجه ابن أبي حاتم ٤/١٠٨٢.|52:أخرجه ابن جرير ٧/٥٦٤، وابن أبي حاتم ٤/١٠٨٢، والبيهقي ٧/٢٩٨. وعزاه السيوطي إلى ابن المنذر.|53:أخرجه ابن أبي حاتم ٤/١٠٨٢. وأخرجه ابن أبي شيبة في مصنفه (ت: محمد عوامة) ٩/٤١٥ (١٧٧٣١) من طريق سفيان عن رجل. وأخرجه ابن جرير ٧/٥٦١ من طريق عطاء بن السائب بلفظ: الأيام.|54:أخرجه ابن أبي شيبة في مصنفه (ت: محمد عوامة) ٩/٤١٥ (١٧٧٣٠)، وابن جرير ٧/٥٦٢.|55:أخرجه ابن جرير ٧/٥٦٣، وابن أبي حاتم ٤/١٠٨٢ وعنده: على مال زوجها وبنيه.|56:أخرجه ابن أبي حاتم ٤/١٠٨١.|57:أخرجه ابن أبي حاتم ٤/١٠٨٢.|58:أخرجه ابن أبي شيبة في مصنفه (ت: محمد عوامة) ٩/٤١٥ (١٧٧٢٩)، وابن جرير ٧/٥٦٢. وعلقه ابن أبي حاتم ٤/١٠٨٢.|59:أخرجه ابن جرير ٧/٥٦٢.|60:أخرجه عبد الرزاق في مصنفه ٦/٢٣٧-٢٣٨ (١٠٦٥١)، وابن جرير ٧/٥٦١.|61:أخرجه ابن جرير ٧/٥٦٣.|62:تفسير مقاتل بن سليمان ١/٤١٢.|63:أخرجه ابن جرير ٧/٥٦٤.|64:أخرجه ابن أبي حاتم ٤/١٠٨٢.|65:تفسير مقاتل بن سليمان ١/٤١٢.
  4,129,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَلَن تَسۡتَطِیعُوۤا۟ أَن تَعۡدِلُوا۟ بَیۡنَ ٱلنِّسَاۤءِ وَلَوۡ حَرَصۡتُمۡۖ فَلَا تَمِیلُوا۟ كُلَّ ٱلۡمَیۡلِ فَتَذَرُوهَا كَٱلۡمُعَلَّقَةِۚ وَإِن تُصۡلِحُوا۟ وَتَتَّقُوا۟ فَإِنَّ ٱللَّهَ كَانَ غَفُورࣰا رَّحِیمࣰا ۝١٢٩﴾</span> - نزول الآية</h3></p><p><div></p><p><p><span class="item-no">٢٠٥٤٢<span class="dash">-</span></span> عن ابن أبي مليكة -من طريق عبد العزيز بن رُفيع- قال: نزلت هذه الآية: <span class="qpc-hafs">﴿ولن تستطيعوا أن تعدلوا بين النساء﴾</span> في عائشة، يعني: أنّ النبي ﷺ كان يحبها أكثر من غيرها{1}. (٥/٧٠)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَلَن تَسۡتَطِیعُوۤا۟ أَن تَعۡدِلُوا۟ بَیۡنَ ٱلنِّسَاۤءِ وَلَوۡ حَرَصۡتُمۡۖ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٢٠٥٤٣<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن مسعود</span>، في قوله: <span class="qpc-hafs">﴿ولن تستطيعوا أن تعدلوا بين النساء﴾</span>، قال: في الجماع{2}. (٥/٧١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٠٥٤٤<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي بن أبي طلحة- قوله: <span class="qpc-hafs">﴿ولن تستطيعوا أن تعدلوا بين النساء ولو حرصتم﴾</span>، يعني: في الحُبِّ، والجماع. يقول: لا تستطيع أن تعدل بالشهوة فيما بينهن، ولو حرصت{3}. (٥/٦٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٠٥٤٥<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي بن أبي طلحة- <span class="qpc-hafs">﴿ولن تستطيعوا أن تعدلوا بين النساء ولو حرصتم﴾</span>، يقول: لا تستطيع أن تعدل بالشهوة فيما بينهن، ولو حرصت{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٠٥٤٦<span class="dash">-</span></span> عن <span class="name-2">عَبِيدة السلماني</span> -من طريق ابن سيرين- في قوله: <span class="qpc-hafs">﴿ولن تستطيعوا أن تعدلوا بين النساء﴾</span>، قال: في المودة، كأنه يعني: الحب{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٠٥٤٧<span class="dash">-</span></span> عن <span class="name-2">عَبِيدة السلماني</span> -من طريق ابن سيرين- في قوله: <span class="qpc-hafs">﴿ولن تستطيعوا أن تعدلوا بين النساء﴾</span>، قال: في الحُبِّ، والجماع{6}. (٥/٧١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٠٥٤٨<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن جريج- في قوله: <span class="qpc-hafs">﴿ولن تستطيعوا أن تعدلوا بين النساء﴾</span>، يعني: في الحب{7}. (٥/٧٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٠٥٤٩<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿ولن تستطيعوا أن تعدلوا بين النساء ولو حرصتم﴾</span>، قال: واجبًا لن تستطيعوا العدل بينهن{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٠٥٥٠<span class="dash">-</span></span> عن <span class="name-2">الضحاك بن مُزاحِم</span> -من طريق جُوَيْبِر- قال: في الشهوة، والجماع{9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٠٥٥١<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق مبارك- <span class="qpc-hafs">﴿ولن تستطيعوا أن تعدلوا بين النساء ولو حرصتم﴾</span>، قال: بقلبه، وهواه، ولكن في القسمة{10}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٠٥٥٢<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق عمرو- في قوله: <span class="qpc-hafs">﴿ولن تستطيعوا أن تعدلوا بين النساء﴾</span>، قال: في الحب{11}. (٥/٧١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٠٥٥٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثم قال ﷿: <span class="qpc-hafs">﴿ولن تستطيعوا أن تعدلوا بين النساء﴾</span> في الحب أن يستوي حبُّهن في قلوبكم، <span class="qpc-hafs">﴿ولو حرصتم﴾</span> فلا تقدرون على ذلك{12}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٠٥٥٤<span class="dash">-</span></span> قال <span class="name-3">سفيان [الثوري]</span>-من طريق زيد بن أبي الزرقاء- في قوله: <span class="qpc-hafs">﴿ولن تستطيعوا أن تعدلوا بين النساء ولو حرصتم﴾</span>، قال: في الحب، والجماع{13}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٠٥٥٥<span class="dash">-</span></span> قال <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿ولن تستطيعوا أن تعدلوا بين النساء ولو حرصتم﴾</span>، قال: ما يكون بين يديه وقلبه، فذلك شيء لا يستطيع يملكه{13}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَلَن تَسۡتَطِیعُوۤا۟ أَن تَعۡدِلُوا۟ بَیۡنَ ٱلنِّسَاۤءِ وَلَوۡ حَرَصۡتُمۡۖ﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٢٠٥٥٦<span class="dash">-</span></span> عن عائشة، قالت: كان النبي ﷺ يَقْسِم بين نسائه فيعدل، ثم يقول: «<b>اللَّهُمَّ، هذا قسمي فيما أملك، فلا تلمني فيما تملك ولا أملك</b>»{15}. (٥/٧٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٠٥٥٧<span class="dash">-</span></span> عن أبي قِلابة: أنّ النبي صلى الله عليه و سلم كان يقسم بين نسائه فيعدل، ويقول: «<b>اللهم، هذا قسمي فيما أملك، فلا تلمني فيما تملك ولا أملك</b>»{16}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٠٥٥٨<span class="dash">-</span></span> عن قتادة، قال: ذُكِر لنا: أنّ <span class="name-1">عمر بن الخطاب</span> كان يقول: اللهم، هذا قلبي فلا أملك، وأرجو أن أعدل فيما سوى ذلك{8}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿فَلَا تَمِیلُوا۟ كُلَّ ٱلۡمَیۡلِ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٢٠٥٥٩<span class="dash">-</span></span> عن محمد بن سيرين -من طريق ابن عون- قال: سألت <span class="name-2">عَبِيدة السلماني</span> عن قول الله: <span class="qpc-hafs">﴿فلا تميلوا كل الميل﴾</span>، قال: بنفسه{18}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٠٥٦٠<span class="dash">-</span></span> عن محمد بن سيرين -من طريق هشام- عن <span class="name-2">عَبِيدة السلماني</span>: <span class="qpc-hafs">﴿فلا تميلوا كل الميل﴾</span>، قال هشام: أظنه قال: في الحُبِّ، والجماع{19}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٠٥٦١<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> –من طريق ابن أبي نجيح-في قوله:<span class="qpc-hafs">﴿فلا تميلوا كل الميل﴾</span>. قال: لا تعمدوا الإساءة {20}. (٥/٧٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٠٥٦٢<span class="dash">-</span></span> قال <span class="name-2">مجاهد بن جبر</span> -من طريق ابن جريج- <span class="qpc-hafs">﴿فلا تميلوا كل الميل﴾</span>، قال: لا يتعمد الإساءة، يقول: لا تميلوا كل الميل. قال: بلغني: أنّه الجماع{21}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٠٥٦٣<span class="dash">-</span></span> عن <span class="name-2">الضحاك بن مزاحم</span> -من طريق جوبير- في قوله: <span class="qpc-hafs">﴿فلا تميلوا كل الميل﴾</span>، يقول: فلا تَمِلْ إلى التي تُحِبُّ كُلَّ الميل، ولكن اعدل في قسمة الليالي والنهار، والنفقة{10}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٠٥٦٤<span class="dash">-</span></span> عن <span class="name-2">الضحاك بن مزاحم</span>، في الآية، يقول: إن أحببت واحدةً وأبغضت واحدةً فاعدل بينهما{23}. (٥/٧٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٠٥٦٥<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق عمرو- في قوله: <span class="qpc-hafs">﴿فلا تميلوا كل الميل﴾</span>، قال: في الغشيان{24}. (٥/٧١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٠٥٦٦<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق عمرو- <span class="qpc-hafs">﴿فلا تميلوا كل الميل﴾</span>، قال: في الغشيان، والقَسْم{25}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٠٥٦٧<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- في الآية، يقول: لا تَمِل عليها، فلا تُنفِق عليها، ولا تَقْسِم لها يومًا{26}. (٥/٧٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٠٥٦٨<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثم قال ﷿: <span class="qpc-hafs">﴿فلا تميلوا كل الميل﴾</span> إلى التي تحب، وهي الشابة{12}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٠٥٦٩<span class="dash">-</span></span> عن <span class="name-3">مقاتل بن حيّان</span> -من طريق بُكَيْر بن معروف- قوله: <span class="qpc-hafs">﴿فلا تميلوا كل الميل﴾</span>، يقول: لا تَمِل إلى الشابَّةِ كل الميل{28}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٠٥٧٠<span class="dash">-</span></span> قال <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿فلا تميلوا كل الميل﴾</span>، قال: هذا في العمل في مبيته عندها، وفيما تصيب من خيره{21}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿فَتَذَرُوهَا كَٱلۡمُعَلَّقَةِۚ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٢٠٥٧١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- في قوله: <span class="qpc-hafs">﴿فلا تميلوا كل الميل فتذروها كالمعلقة﴾</span>، قال: لا هي أيِّمٌ، ولا هي ذات زوج{30}. (٥/٦٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٠٥٧٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عكرمة- في قوله: <span class="qpc-hafs">﴿فتذروها كالمعلقة﴾</span>، قال: لا مُطَلَّقة، ولا ذات بَعْل{31}. (٥/٧٢)، (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٠٥٧٣<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span> -من طريق جعفر- <span class="qpc-hafs">﴿فتذروها كالمعلقة﴾</span>، قال: لا أيِّمًا، ولا ذات بعل{32}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٠٥٧٤<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن جريج- <span class="qpc-hafs">﴿فتذروها كالمعلقة﴾</span>، قال: لا أيِّمًا، ولا ذات بَعْل{33}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٠٥٧٥<span class="dash">-</span></span> عن <span class="name-2">الضحاك بن مُزاحِم</span> -من طريق جُوَيْبِر- قال: لا تدعها كأنها ليس لها زوج{33}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٠٥٧٦<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق عمرو- في قوله: <span class="qpc-hafs">﴿فتذروها كالمعلقة﴾</span>، قال: لا أيِّم، ولا ذات زوج{35}. (٥/٧١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٠٥٧٧<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دِعامة</span> -من طريق معمر- في قوله: <span class="qpc-hafs">﴿كالمعلقة﴾</span>، قال: كالمسجونة، كالمحبوسة{36}. (٥/٧٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٠٥٧٨<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- <span class="qpc-hafs">﴿فتذروها كالمعلقة﴾</span>، قال: لا أيِّمًا، ولا ذات بَعْل{37}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٠٥٧٩<span class="dash">-</span></span> عن <span class="name-2">ابن أبي نجيح</span> -من طريق شبل- <span class="qpc-hafs">﴿فتذروها كالمعلقة﴾</span>، قال: ليست بأيِّم، ولا ذات زوج{38}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٠٥٨٠<span class="dash">-</span></span> عن <span class="name-2">الربيع بن أنس</span> -من طريق أبي جعفر- في قوله: <span class="qpc-hafs">﴿فتذروها كالمعلقة﴾</span>، يقول: لا مُطَلَّقة، ولا ذات بَعْل{32}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٠٥٨١<span class="dash">-</span></span> وعن <span class="name-3">مقاتل بن حيان</span>، نحو ذلك{40}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٠٥٨٢<span class="dash">-</span></span> عن <span class="name-3">محمد بن السائب الكلبي</span>، <span class="qpc-hafs">﴿كالمعلقة﴾</span>، قال: كالمحبوسة{41}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٠٥٨٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فتذروها كالمعلقة﴾</span>، أي: فتأتيها وتذر الأخرى، يعني: الكبيرة كالمعلقة، لا أيِّم ولا ذات بعل، ولكن اعدلوا في القسمة{12}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٠٥٨٤<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿فتذروها كالمعلقة﴾</span>، قال: المعلقة: التي ليست بمُخَلّاة ونفسها فتبتغي لها، وليست متهيئة كهيئة المرأة من زوجها، لا هي عند زوجها، ولا مفارقة فتبتغي لنفسها، فتلك المعلقة{38}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَإِن تُصۡلِحُوا۟ وَتَتَّقُوا۟ فَإِنَّ ٱللَّهَ كَانَ غَفُورࣰا رَّحِیمࣰا ۝١٢٩﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٢٠٥٨٥<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span> -من طريق عطاء بن دينار- قوله: <span class="qpc-hafs">﴿وإن تصلحوا وتتقوا﴾</span>، قال: تصلحوا بين الناس{28}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٠٥٨٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وإن تصلحوا﴾</span> أمرَهُنَّ، <span class="qpc-hafs">﴿وتتقوا﴾</span> الميل والجور؛ <span class="qpc-hafs">﴿فإن الله كان غفورا﴾</span> حين مِلْت إلى الشابة برِضا الكبيرة، <span class="qpc-hafs">﴿رحيما﴾</span> بك حين رخَّص لك في الصلح، فإن أبت الكبيرةُ الصلح إلا أن تُسَوِّي بينها وبين الشابة أو تطلقها كان ذلك لها{12}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَإِن تُصۡلِحُوا۟ وَتَتَّقُوا۟ فَإِنَّ ٱللَّهَ كَانَ غَفُورࣰا رَّحِیمࣰا ۝١٢٩﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٢٠٥٨٧<span class="dash">-</span></span> عن أبي هريرة، قال: قال رسول الله ﷺ: «<b>مَن كانت له امرأتان، فمال إلى إحداهما؛ جاء يوم القيامة وأحدُ شِقِّيَهْ ساقِط</b>»{46}. (٥/٧٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٠٥٨٨<span class="dash">-</span></span> عن <span class="name-2">أبي الشعثاء جابر بن زيد</span> -من طريق عبيد أبي الحرم- قال: كانت لي امرأتان، فلقد كنت أعدِل بينهما حتى أعُدّ القُبَل{47}. (٥/٧١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٠٥٨٩<span class="dash">-</span></span> عن <span class="name-2">إبراهيم النخعي</span> -من طريق أبي معشر- قال: إن كانوا لَيُسَوُّون بين الضرائر، حتى تبقى الفضلة مِمّا لا يُكال من السَّوِيق والطعام، فيقسمونه كفًّا كفًّا إذا كان مِمّا لا يُسْتَطاع كَيْلُه{48}. (٥/٧١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٠٥٩٠<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ليث- قال:كانوا يستحبون أن يُسَوُّوا بين الضرائر، حتى في الطِّيب؛ يَتَطَيَّب لهذه كما يَتَطَيَّب لهذه{47}. (٥/٧٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٠٥٩١<span class="dash">-</span></span> عن <span class="name-2">محمد بن سيرين</span> -من طريق هارون بن إبراهيم- في الذي له امرأتان، قال: يكره أن يتوضأ في بيت إحداهما دون الأخرى{48}. (٥/٧١)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن أبي شيبة ٤/٢٣٣، وابن جرير ٧/٥٧٠، وابن أبي حاتم ٤/١٠٨٣. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.|2:عزاه السيوطي إلى ابن المنذر.|3:أخرجه ابن أبي حاتم ٤/١٠٨٣، وابن جرير ٧/٥٦٩ مختصرًا.|4:أخرجه ابن جرير ٧/٥٦٩.|5:أخرجه عبد الرزاق ١/١٧٦.|6:أخرجه ابن أبي شيبة ٤/٢٣٣، وابن جرير ٧/٥٦٧، والبيهقي ٧/٢٩٨. وعلقه ابن أبي حاتم ٤/١٠٨٣.|7:أخرجه ابن جرير ٧/٥٧٢، والبيهقي ٧/٢٩٨. وعزاه السيوطي إلى ابن المنذر.|8:أخرجه عبد بن حميد كما في قطعة من تفسيره ص١٢٢.|9:أخرجه ابن جرير ٧/٥٧٠. وعلقه ابن أبي حاتم ٤/١٠٨٣.|10:أخرجه ابن أبي حاتم ٤/١٠٨٣.|11:أخرجه ابن أبي شيبة ٤/٢٣٣. وعلقه ابن أبي حاتم ٤/١٠٨٣ بلفظ: في الحب والجماع.|12:تفسير مقاتل بن سليمان ١/٤١٢.|13:أخرجه ابن جرير ٧/٥٧٠.|14:أخرجه ابن جرير ٧/٥٧٠.|15:أخرجه أحمد ٤٢/٤٦ (٢٥١١١)، وأبو داود ٣/٤٦٩-٤٧٠ (٢١٣٤)، والترمذي ٢/٦١٠-٦١١ (١١٧٢)، وابن ماجه ٣/١٤٤ (١٩٧١)، والنسائي ٧/٦٣ (٣٩٤٣)، وابن حبان ١٠/٥ (٤٢٠٥)، والحاكم ٢/٢٠٤ (٢٧٦١)</p><p>قال الدارقطني في العلل الواردة في الأحاديث النبوية ١٣/٢٧٨-٢٧٩ (٣١٧٦): «المرسل أقرب إلى الصواب». وقال الحاكم: «هذا حديث صحيح على شرط مسلم، ولم يخرجاه». وقال الذهبي في التلخيص: «على شرط مسلم». وقال ابن الملقن في البدر المنير ٧/٤٨١: «حديث صحيح». وقال ابن كثير في تفسيره ٢/٤٣٠: «وهذا إسناد صحيح». وقال الألباني في الإرواء ٧/٨١-٨٢ (٢٠١٨): «ضعيف».|16:أخرجه ابن جرير ٧/٥٦٩. وأورده الترمذي في سننه ٢/٦١٠-٦١١.</p><p>قال الترمذي: «مرسلًا، وهو أصح من حديث حماد بن سلمة». وقال الدارقطني في العلل الواردة في الأحاديث النبوية ١٣/٢٧٨-٢٧٩ (٣١٧٦): «المرسل أقرب إلى الصواب». وقال ابن كثير عن هذا الحديث ٤/٣٠٦: «لفظ أبي داود، وهذا إسناد صحيح، لكن قال الترمذي: رواه حماد بن زيد وغير واحد، عن أيوب، عن أبي قلابة مرسلًا. قال: وهذا أصح». وقال ابن حجر في الفتح ٩/٣١٣: «مرسلًا، وهو أصح من رواية حماد بن سلمة».|17:أخرجه عبد بن حميد كما في قطعة من تفسيره ص١٢٢.|18:أخرجه ابن جرير ٧/٥٧١، وابن أبي حاتم ٤/١٠٨٣.|19:أخرجه ابن جرير٧/٥٧١.|20:أخرجه عبد بن حميد كما في قطعة من تفسيره ص١٢٢، وابن جرير ٧/٥٧١، والبيهقي ٧/٢٩٨. وعلقه ابن أبي حاتم ٤/١٠٨٣. وعزاه السيوطي إلى ابن المنذر.|21:أخرجه ابن جرير ٧/٥٧٢.|22:أخرجه ابن أبي حاتم ٤/١٠٨٣.|23:وعزاه السيوطي إلى ابن المنذر.|24:أخرجه ابن أبي شيبة ٤/٢٣٣. وذكر يحيى بن سلام -كما في تفسير ابن أبي زمنين ١/٤١١- نحوه، ولفظه: فتأتي واحدة، وتدع الأخرى.|25:أخرجه ابن جرير ٧/٥٧١.|26:أخرجه ابن جرير ٧/٥٧٢، وابن أبي حاتم ٤/١٠٨٣.|27:تفسير مقاتل بن سليمان ١/٤١٢.|28:أخرجه ابن أبي حاتم ٤/١٠٨٤.|29:أخرجه ابن جرير ٧/٥٧٢.|30:أخرجه ابن جرير ٧/٥٧٣-٥٧٤، والبيهقي ٧/٢٩٨. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.|31:أخرجه ابن أبي شيبة ٤/٢٣٣-٢٣٤، وابن جرير ٧/٥٧٣-٥٧٤، وابن أبي حاتم ٤/١٠٨٤. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.|32:أخرجه ابن جرير ٧/٥٧٤. وعلَّقه ابن أبي حاتم ٤/١٠٨٤.|33:أخرجه ابن جرير ٧/٥٧٥. وعلقه ابن أبي حاتم ٤/١٠٨٤.|34:أخرجه ابن جرير ٧/٥٧٥. وعلقه ابن أبي حاتم ٤/١٠٨٤.|35:أخرجه ابن أبي شيبة ٤/٢٣٣. وذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ١/٤١١-٤١٢-. وعلَّقه ابن أبي حاتم ٤/١٠٨٤.|36:أخرجه عبد الرزاق ١/١٧٦، وابن جرير ٧/٥٧٤ كذلك من طريق سعيد، وابن أبي حاتم ٤/١٠٨٤ وفيه: كالمسجونة المشحونة. وينظر: تحقيق د. حكمت بشير ٤/١٦٣٨ (مرقومة بالآلة الكاتبة). وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.|37:أخرجه ابن جرير ٧/٥٧٥. وعلَّقه ابن أبي حاتم ٤/١٠٨٤.|38:أخرجه ابن جرير ٧/٥٧٥.|39:أخرجه ابن جرير ٧/٥٧٤. وعلَّقه ابن أبي حاتم ٤/١٠٨٤.|40:علَّقه ابن أبي حاتم ٤/١٠٨٤.|41:تفسير الثعلبي ٣/٣٩٦.|42:تفسير مقاتل بن سليمان ١/٤١٢.|43:أخرجه ابن جرير ٧/٥٧٥.|44:أخرجه ابن أبي حاتم ٤/١٠٨٤.|45:تفسير مقاتل بن سليمان ١/٤١٢.|46:أخرجه أحمد ١٣/٣٢٠ (٧٩٣٦)، ١٤/٢٣٧ (٨٥٦٨)، ١٦/١٠٧ (١٠٠٩٠)، وأبو داود ٣/٤٦٩ (٢١٣٣)، والترمذي ٢/٦١١ (١١٧٣) واللفظ له، وابن ماجه ٣/١٤٣ (١٩٦٩)، والنسائي ٧/٦٣ (٣٩٤٢)، وابن حبان ١٠/٧ (٤٢٠٧)، والحاكم ٢/٢٠٣ (٢٧٥٩)، وابن جرير ٧/٥٧٣.</p><p>قال الحاكم: «هذا حديث صحيح، على شرط الشيخين، ولم يخرجاه». وقال ابن الملقن في البدر المنير ٨/٣٧: «الحديث صحيح». ونقله تصحيحه على شرطهما عن ابن دقيق العيد. وقال ابن كثير ٤/٣٠١ عن هذا الحديث: «وهكذا رواه الإمام أحمد وأهل السنن، من حديث همّام بن يحيى، عن قتادة، به. وقال الترمذي: إنما أسنده همّام، ورواه هشام الدستوائي عن قتادة، قال:»كان يقال«. ولا نعرف هذا الحديث مرفوعًا إلا من حديث همّام».|47:أخرجه ابن أبي شيبة ٤/٣٨٧. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.|48:أخرجه ابن أبي شيبة ٤/٣٨٧.|49:أخرجه ابن أبي شيبة ٤/٣٨٧. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.|50:أخرجه ابن أبي شيبة ٤/٣٨٧.
  4,130,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَإِن یَتَفَرَّقَا یُغۡنِ ٱللَّهُ كُلࣰّا مِّن سَعَتِهِۦۚ وَكَانَ ٱللَّهُ وَ ٰ⁠سِعًا حَكِیمࣰا ۝١٣٠﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٢٠٥٩٢<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نَجِيح- في قوله: <span class="qpc-hafs">﴿وإن يتفرقا﴾</span>، قال: الطلاق{1}. (٥/٧٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٠٥٩٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثم إنّه طلَّقها، فنزلت: <span class="qpc-hafs">﴿وإن يتفرقا﴾</span> يعني: رافع وخويلة المرأة الكبيرة <span class="qpc-hafs">﴿يغني الله كلا﴾</span> يعني: الزوج والكبيرة <span class="qpc-hafs">﴿من سعته﴾</span> يعني: من فضله الواسع، <span class="qpc-hafs">﴿وكان الله واسعا﴾</span> لهما في الرزق جميعًا، <span class="qpc-hafs">﴿حكيما﴾</span> حين حكم فرقتهما{2}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ٧/٥٧٨، وابن أبي حاتم ٤/١٠٨٤. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.|2:تفسير مقاتل بن سليمان ١/٤١٣.
  4,131,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَلِلَّهِ مَا فِی ٱلسَّمَـٰوَ ٰ⁠تِ وَمَا فِی ٱلۡأَرۡضِۗ وَلَقَدۡ وَصَّیۡنَا ٱلَّذِینَ أُوتُوا۟ ٱلۡكِتَـٰبَ مِن قَبۡلِكُمۡ وَإِیَّاكُمۡ أَنِ ٱتَّقُوا۟ ٱللَّهَۚ وَإِن تَكۡفُرُوا۟ فَإِنَّ لِلَّهِ مَا فِی ٱلسَّمَـٰوَ ٰ⁠تِ وَمَا فِی ٱلۡأَرۡضِۚ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٢٠٥٩٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ولله ما في السماوات وما في الأرض﴾</span> من الخلق عبيده، وفي ملكه{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٠٥٩٥<span class="dash">-</span></span> عن محمد بن الحسين، أنّه كتب ل<span class="name-3">سفيان الثوري</span>، فأملى عليه: من أبي عبد الله إلى أبي فلان، أما بعد، فإني أوصيك بتقوى الله، فإنها وصية الله خلقه، يقول الله تبارك وتعالى: <span class="qpc-hafs">﴿ولقد وصينا الذين أوتوا الكتاب من قبلكم وإياكم أن اتقوا الله وإن تكفروا فإن لله ما في السموات وما في الأرض وكان الله غنيا حميدا﴾</span>. إنّك إن اتَّقَيْت اللهَ كفاك اللهُ ما هَمَّك، وإن اتَّقَيْت الناس لم يُغْنُوا عنك من الله شيئًا{2}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَكَانَ ٱللَّهُ غَنِیًّا حَمِیدࣰا ۝١٣١﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٢٠٥٩٦<span class="dash">-</span></span> عن <span class="name-1">علي بن أبي طالب</span> -من طريق أبي رَوْق- في قوله: <span class="qpc-hafs">﴿وكان الله غنيا﴾</span> قال: غنيًّا عن خلقه، <span class="qpc-hafs">﴿حميدا﴾</span> قال: مُسْتَحْمَدًا إليهم{3}. (٥/٧٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٠٥٩٧<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، مثله{4}. (٥/٧٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٠٥٩٨<span class="dash">-</span></span> عن <span class="name-1">البراء بن عازب</span> -من طريق عدي بن ثابت- <span class="qpc-hafs">﴿وكان الله غنيا﴾</span>، يعني قال: عن صدقاتكم{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٠٥٩٩<span class="dash">-</span></span> عن <span class="name-3">مقاتل بن حيّان</span> -من طريق بُكَيْر بن معروف- في قول الله تعالى: <span class="qpc-hafs">﴿وكان الله غنيا﴾</span>، قال: في سلطانه عَمّا عندكم{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٠٦٠٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وكان الله غنيا﴾</span> عن عباده وخلقه، <span class="qpc-hafs">﴿حميدا﴾</span> عند خلقه في سلطانه{1}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ١/٤١٣.|2:أخرجه ابن أبي حاتم ٤/١٠٨٥.|3:أخرجه ابن جرير ٧/٥٧٩-٥٨٠، وابن أبي حاتم ٤/١٠٨٥.|4:عزاه السيوطي إلى ابن جرير، وابن أبي حاتم.|5:أخرجه ابن أبي حاتم ٤/١٠٨٥ عند تفسير هذه الآية، وأيضًا عند تفسير قوله تعالى: <span class="qpc-hafs">﴿قَوْلٌ مَعْرُوفٌ ومَغْفِرَةٌ خَيْرٌ مِن صَدَقَةٍ يَتْبَعُها أذًى واللَّهُ غَنِيٌّ حَلِيمٌ﴾</span> [البقرة:٢٦٣]، وقوله تعالى: <span class="qpc-hafs">﴿يا أيُّها الَّذِينَ آمَنُوا أنْفِقُوا مِن طَيِّباتِ ما كَسَبْتُمْ ومِمّا أخْرَجْنا لَكُمْ مِنَ الأَرْضِ ولا تَيَمَّمُوا الخَبِيثَ مِنهُ تُنْفِقُونَ ولَسْتُمْ بِآخِذِيهِ إلّا أنْ تُغْمِضُوا فِيهِ واعْلَمُوا أنَّ اللَّهَ غَنِيٌّ حَمِيدٌ﴾</span> [البقرة:٢٦٧]، وهو أشبه بتفسير آيتي البقرة لموافقته سياقهما.|6:أخرجه ابن أبي حاتم ٤/١٠٨٥.|7:تفسير مقاتل بن سليمان ١/٤١٣.
  4,132,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَلِلَّهِ مَا فِی ٱلسَّمَـٰوَ ٰ⁠تِ وَمَا فِی ٱلۡأَرۡضِۚ وَكَفَىٰ بِٱللَّهِ وَكِیلًا ۝١٣٢﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٢٠٦٠١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عكرمة- في قوله: <span class="qpc-hafs">﴿وكفى بالله وكيلا﴾</span>، قال: يعني: شهيدًا أنّ فيها عبيدًا{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٠٦٠٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق الضحاك- في قوله: <span class="qpc-hafs">﴿وكفى بالله وكيلا﴾</span>، قال: يعني: دافِعًا مُجيرًا{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٠٦٠٣<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دِعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿وكفى بالله وكيلا﴾</span>، قال: حفيظًا{3}. (٥/٧٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٠٦٠٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ولله ما في السماوات وما في الأرض وكفى بالله وكيلا﴾</span>، يعني: شهيدًا، فلا شاهد أفضل مِن الله ﷿ أنّ مَن فيهما عباده، وفي ملكه{4}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير الثعلبي ٣/٣٩٩، وتفسير البغوي ٢/٢٩٧.|2:تفسير الثعلبي ٣/٣٩٩.|3:أخرجه ابن جرير ٧/٥٨٠.|4:تفسير مقاتل بن سليمان ١/٤١٣.
  4,133,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿إِن یَشَأۡ یُذۡهِبۡكُمۡ أَیُّهَا ٱلنَّاسُ وَیَأۡتِ بِـَٔاخَرِینَۚ وَكَانَ ٱللَّهُ عَلَىٰ ذَ ٰ⁠لِكَ قَدِیرࣰا ۝١٣٣﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٢٠٦٠٥<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دِعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿إن يشأ يذهبكم أيها الناس ويأت بآخرين﴾</span>، قال: قادر -واللهِ- ربُّنا على ذلك؛ أن يُهْلِك مِن خلقه ما شاء، ويأت بآخرين من بعدهم{1}. (٥/٧٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٠٦٠٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثم قال ﷿: <span class="qpc-hafs">﴿إن يشأ يذهبكم﴾</span> بالموت <span class="qpc-hafs">﴿أيها الناس ويأت بآخرين﴾</span> يعني: بخلقٍ غيرِكم أطوعَ منكم، <span class="qpc-hafs">﴿وكان الله على ذلك قديرا﴾</span> أن يُذْهِبكم ويأت بغيركم إذا عصيتموه{2}<span class=comment-ref>١٨٧٨</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>١٨٧٨</span> أفاد هذا القول أنّ قوله: <span class="qpc-hafs">﴿بآخرين﴾</span> يعني: من نوعكم. وذكر <u>ابنُ عطية</u> (٣/٤١) هذا القول، وساق بعده حديث سلمان، ثم ذكر <b>احتمالًا آخر</b>، وهو أن تكون الآية وعيدًا لجميع بني آدم، ويكون الآخرون من غير نوعهم، كما روي أنه كان في الأرض ملائكة يعبدون الله قبل آدم. ثم قال: «وقدرة الله على ما ذكر تقضي العقول بداهتها».</p><p>و<span class="comment-type-4">ذكر</span> <u>ابنُ جرير</u> (٧/٥٨١) أنّ هذا الوعيد والتوبيخ في الآية هو للقوم الذين شفعوا في طعمة بن أبيرق، وخاصموا عنه في أمر خيانته في الدرع والدقيق.</p><p>و<span class="comment-type-2">انتقده</span> <u>ابنُ عطية</u> (٣/٤١) <span class="mustanad">مستندًا لدلالة العموم</span>، فقال: «هذا تأويل بعيد، واللفظ إنما يظهر حُسْن رَصْفه بعمومه،وانسحابه على العالم جملة، أو العالم الحاضر».</div></p><p><h3><span class="qpc-hafs">﴿إِن یَشَأۡ یُذۡهِبۡكُمۡ أَیُّهَا ٱلنَّاسُ وَیَأۡتِ بِـَٔاخَرِینَۚ وَكَانَ ٱللَّهُ عَلَىٰ ذَ ٰ⁠لِكَ قَدِیرࣰا ۝١٣٣﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٢٠٦٠٧<span class="dash">-</span></span> عن أبي هريرة، قال: تلا رسول الله ﷺ هذه الآية: <span class="qpc-hafs">﴿وإنْ تَتَوَلَّوْا يَسْتَبْدِلْ قَوْمًا غَيْرَكُمْ ثُمَّ لا يَكُونُوا أمْثالَكُم﴾</span> محمد:٣٨]. فقالوا: يا رسول الله، مَن هؤلاء الذين إن تَوَلَّيْنا اسْتُبْدِلوا بنا، ثم لا يكونوا أمثالنا؟ فضرب رسول الله ﷺ على منكب سلمان، ثم قال: «<b>هذا وقومُه</b>»{3}<span class=comment-ref>١٨٧٩</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>١٨٧٩</span> <span class="comment-type-4">علَّق</span> <u>ابنُ جرير</u> (٧/٥٨٢) على هذا الحديث بقوله: «يعني: عَجَم الفُرس».</div></p></div>",footnotes:1:أخرجه ابن جرير ٧/٥٨٢. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.|2:تفسير مقاتل بن سليمان ١/٤١٣.|3:أخرجه ابن جرير ٧/٥٨٢. وسيأتي بتمامه في تفسير سورة محمد، وينظر: تخريجه هناك.
  4,134,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿مَّن كَانَ یُرِیدُ ثَوَابَ ٱلدُّنۡیَا فَعِندَ ٱللَّهِ ثَوَابُ ٱلدُّنۡیَا وَٱلۡـَٔاخِرَةِۚ وَكَانَ ٱللَّهُ سَمِیعَۢا بَصِیرࣰا ۝١٣٤﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٢٠٦٠٨<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿من كان يريد ثواب الدنيا﴾</span> بعمله فليعمل لآخرته <span class="qpc-hafs">﴿فعند الله ثواب الدنيا﴾</span> يعني: الرزق في الدنيا، <span class="qpc-hafs">﴿و﴾</span>ثواب <span class="qpc-hafs">﴿الآخرة﴾</span> يعني: الجنة، <span class="qpc-hafs">﴿وكان الله سميعا بصيرا﴾</span> بأعمالكم{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٠٦٠٩<span class="dash">-</span></span> عن <span class="name-3">محمد بن إسحاق</span> -من طريق سلمة- قوله: <span class="qpc-hafs">﴿من كان يريد ثواب الدنيا﴾</span> أي: مَن كان منكم يريد الدنيا ليست له رغبة في الآخرة نؤته ما قُسِم له فيها من رزق، ولا حَظَّ له في الآخرة، <span class="qpc-hafs">﴿وكان الله سميعا﴾</span> أي: سميع ما تقولون{2}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿مَّن كَانَ یُرِیدُ ثَوَابَ ٱلدُّنۡیَا فَعِندَ ٱللَّهِ ثَوَابُ ٱلدُّنۡیَا وَٱلۡـَٔاخِرَةِۚ وَكَانَ ٱللَّهُ سَمِیعَۢا بَصِیرࣰا ۝١٣٤﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٢٠٦١٠<span class="dash">-</span></span> عن سهل بن سعد، قال: قال رسول الله ﷺ: «<b>نِيَّةُ المؤمن خيرٌ من عمله، وعمل المنافق خيرٌ من نِيَّته، وكلٌّ يعمل على نيته، فإذا عمل المؤمنُ عملًا نارَ في قلبه نورٌ</b>»{3}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ١/٤١٣.|2:أخرجه ابن أبي حاتم ٤/١٠٨٦.|3:أخرجه الطبراني في الكبير ٦/١٨٥ (٥٩٤٢)، وأبو نعيم في الحلية ٣/٢٥٥. وأورده الثعلبي ٣/٣٩٩.</p><p>قال أبو نعيم: «هذا حديث غريب من حديث أبي حازم وسهل، لم نكتبه إلا من هذا الوجه». وقال العراقي في تخريج الإحياء ص١٧٣٥: «ضعيف». وقال الهيثمي في المجمع ١/٦١ (٢١٢): «رجاله موثقون». وقال الألباني في الضعيفة ١٣/١٢١ (٦٠٤٥): «ضعيف».