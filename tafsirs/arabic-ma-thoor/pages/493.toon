quran[13]{c,v,t}:
43,48," <q>﴿وَمَا نُرِیهِم مِّنۡ ءَایَةٍ إِلَّا هِیَ أَكۡبَرُ مِنۡ أُخۡتِهَاۖ﴾</q> - تفسير ٦٩٥٧٧- قال الحسن البصري: <q>﴿وما نُرِيهِمْ مِن آيَةٍ إلّا هِيَ أكْبَرُ مِن أُخْتِها﴾</q> كانت اليدُ أكبرَ من العصا{1}٥٨٧٤. (ز) ٥٨٧٤ قال ابنُ عطية (٧/٥٥٣): "قوله: <q>﴿إلّا هِيَ أكْبَرُ مِن أُخْتِها﴾</q> عبارة عن شِدّة موقعها في نفوسهم بجِدِّة أمرها وحدوثه، وذلك أنّ أول آية عرضها موسى هي: العصا واليد، وكانت أكبر آية، ثم كل آية بعد ذلك كانت تقع فتعظم عندهم لحينها وتكبر؛ لأنهم قد كانوا أُنسُوا التي قبلها، فهذا كما قال الشاعر: على أنها تعفو الكلوم وإنما تُوكّل بالأدنى وإن جل ما يقضى". ٦٩٥٧٨- قال مقاتل بن سليمان: يقول الله تعالى: <q>﴿وما نُرِيهِمْ مِن آيَةٍ إلّا هِيَ أكْبَرُ مِن أُخْتِها﴾</q> يعني: اليد بيضاء لها شعاع مثل شعاع الشمس، يغشي البصر، فكانت اليد أكبر من العصا، وكان موسى ﵇ بدأ بالعصا فألقاها، وأخرج يده فلم يؤمنوا{2}. (ز) ٦٩٥٧٩- عن عبد الملك ابن جُريْج، في قوله: <q>﴿وما نُرِيهِمْ مِن آيَةٍ إلّا هِيَ أكْبَرُ مِن أُخْتِها﴾</q>، قال: هي الطوفان، وما معه مِن الآيات{3}. (١٣/٢١٥) <q>﴿وَأَخَذۡنَـٰهُم بِٱلۡعَذَابِ﴾</q> - تفسير ٦٩٥٨٠- عن عكرمة مولى ابن عباس، <q>﴿وأَخَذْناهُمْ بِالعَذابِ﴾</q>، قال: هو عام السَّنَة{4}. (١٣/٢١٥) ٦٩٥٨١- قال مقاتل بن سليمان: يقول الله تعالى: <q>﴿وأَخَذْناهُمْ بِالعَذابِ﴾</q>، يعني: الطوفان، والجراد، والقُمّل، والضفادع، والدّم، والطّمس، والسّنين{2}. (ز) <q>﴿لَعَلَّهُمۡ یَرۡجِعُونَ ۝٤٨﴾</q> - تفسير ٦٩٥٨٢- عن قتادة بن دعامة، <q>﴿وأَخَذْناهُمْ بِالعَذابِ لَعَلَّهُمْ يَرْجِعُونَ﴾</q>، قال: يتوبون، أو يذَّكَّرون{4}. (١٣/٢١٥) ٦٩٥٨٣- قال مقاتل بن سليمان: <q>﴿لَعَلَّهُمْ يَرْجِعُونَ﴾</q>، يعني: لكي يرجعوا مِن الكفر إلى الإيمان{2}. (ز) ",footnotes:1:ذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٤/١٨٨-.تفسير مقاتل بن سليمان ٣/٧٩٦-٧٩٧.عزاه السيوطي إلى ابن المنذر.عزاه السيوطي إلى عبد بن حميد.تفسير مقاتل بن سليمان ٣/٧٩٦-٧٩٧.عزاه السيوطي إلى عبد بن حميد.تفسير مقاتل بن سليمان ٣/٧٩٦-٧٩٧.
43,49," <q>﴿وَقَالُوا۟ یَـٰۤأَیُّهَ ٱلسَّاحِرُ ٱدۡعُ لَنَا رَبَّكَ بِمَا عَهِدَ عِندَكَ إِنَّنَا لَمُهۡتَدُونَ ۝٤٩﴾</q> - تفسير ٦٩٥٨٤- عن مجاهد بن جبر -من طريق ابن أبي نجيح- <q>﴿ادْعُ لَنا رَبَّكَ بِما عَهِدَ عِنْدَكَ﴾</q>: لئن آمَنّا ليُكشَفَنَّ عنّا العذاب{1}. (١٣/٢١٥) ٦٩٥٨٥- عن قتادة بن دعامة -من طريق سعيد- قوله: <q>﴿يا أيُّهَ السّاحِرُ ادْعُ لَنا رَبَّكَ بِما عَهِدَ عِنْدَكَ إنَّنا لَمُهْتَدُونَ﴾</q>، قال: قالوا: يا موسى، ادعُ لنا ربك، لئن كشفتَ عنا الرّجز لنؤمننّ لك{2}. (ز) ٦٩٥٨٦- قال مقاتل بن سليمان: <q>﴿وقالُوا﴾</q> لموسى: <q>﴿يا أيُّهَ السّاحِرُ ادْعُ﴾</q> يقول: سل <q>﴿لَنا رَبَّكَ﴾</q>. فلم يفعل، وقال: تسمّوني ساحرًا! وقال في سورة الأعراف [١٣٤]: <q>﴿ادْعُ لَنا رَبَّكَ بِما عَهِدَ عِنْدَكَ﴾</q> أن يكشف عنا العذاب <q>﴿إنَّنا لَمُهْتَدُونَ﴾</q> يعني: مؤمنين لك. وكان الله تعالى عهد إلى موسى ﵇ لئن آمنوا كشف عنهم، فذلك قوله: <q>﴿بِما عَهِدَ عِنْدَكَ﴾</q> إنْ آمنّا كشف عنا العذاب، فلما دعا موسى ربَّه كشف عنهم، فلم يؤمنوا{3}٥٨٧٥. (ز) ٥٨٧٥ ذكر ابنُ عطية (٧/٥٥٣) أن قوله تعالى: <q>﴿وقالُوا يا أيُّها السّاحِرُ﴾</q> يحتمل احتمالين: الأول: أن يكون قائل ذلك من أعلمهم بكفر السحرة؛ فيكون قوله استهزاء، وهو يعلم قدر السحر وانحطاط منزلته، ويكون قوله: <q>﴿عِنْدَكَ﴾</q> بمعنى: في زعمك وعلى قولك. الثاني: أن يكون القائل ليس من المتمردين الحذّاق منهم، ويطلق لفظة الساحر لأحد وجهين: إمّا لأن السحر كان عند عامتهم علم الوقت، فكأنه قال: يا أيه العالم. وإما لأنّ هذه الاسمية قد كانت انطلقت عندهم على موسى ﵇ لأول ظهوره، فاستصحبها هذا القائل في مخاطبة قلة تحرير وغباوة، ويكون القول -على هذا التأويل- جدًّا من القائل، ويكون قوله: <q>﴿إنَّنا لَمُهْتَدُونَ﴾</q> بمعنى: إن نفعتنا دعوتك. ثم رجَّح (٧/٥٥٣-٥٥٤ بتصرف) الاحتمال الثاني مستندًا إلى الدلالة العقلية، فقال: «وهذا التأويل أرجح، أعني: أن كلام هذا القائل مقترن بالجدّ. ثم أخبر عنهم أنه لما كشف عنهم العذاب نكثوا، ولو كان الكلام هزلًا مِن أوله لما وقع نكث». ",footnotes:1:تفسير مجاهد ص٥٩٤، وأخرجه ابن جرير ٢٠/٦٠٩. وعزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ٢٠/٦٠٩-٦١٠.تفسير مقاتل بن سليمان ٣/٧٩٧.
43,50," <q>﴿فَلَمَّا كَشَفۡنَا عَنۡهُمُ ٱلۡعَذَابَ إِذَا هُمۡ یَنكُثُونَ ۝٥٠﴾</q> - تفسير ٦٩٥٨٧- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿إذا هُمْ يَنْكُثُونَ﴾</q>، قال: يغدرون{1}. (١٣/٢١٥) ٦٩٥٨٨- قال مقاتل بن سليمان: <q>﴿فَلَمّا كَشَفْنا عَنْهُمُ العَذابَ إذا هُمْ يَنْكُثُونَ﴾</q> الذي عاهدوا عليه موسى ﵇: <q>﴿لَئِنْ كَشَفْتَ عَنّا الرِّجْزَ لَنُؤْمِنَنَّ﴾</q> [الأعراف:١٣٤]، فلم يؤمنوا{2}. (ز) ",footnotes:1:أخرجه ابن جرير ٢٠/٦١٠. وعزاه السيوطي إلى عَبد بن حُمَيد.تفسير مقاتل بن سليمان ٣/٧٩٧.
43,51," <q>﴿وَنَادَىٰ فِرۡعَوۡنُ فِی قَوۡمِهِۦ﴾</q> - تفسير ٦٩٥٨٩- عن عبد الملك ابن جُريْج، في قوله: <q>﴿ونادى فِرْعَوْنُ فِي قَوْمِهِ﴾</q>، قال: ليس هو نفسه، ولكن أمر أن يُنادى{1}. (١٣/٢١٥) ٦٩٥٩٠- قال مقاتل بن سليمان: قوله: <q>﴿ونادى فِرْعَوْنُ﴾</q> القِبطيُّ <q>﴿فِي قَوْمِهِ﴾</q> القِبط، وكان نداؤه أنّه: <q>﴿قالَ يا قَوْمِ ألَيْسَ لِي مُلْكُ مِصْر وهذِهِ الأَنْهارُ تَجْرِي مِن تَحْتِي أفَلا تُبْصِرُونَ﴾</q>{2}٥٨٧٦. (ز) ٥٨٧٦ ذكر ابنُ عطية (٧/٥٥٤) أن نداء فرعون يحتمل أن يكون بلسانه في ناديه، ويحتمل أن يكون بأن أمر مَن ينادي في الناس. <q>﴿قَالَ یَـٰقَوۡمِ أَلَیۡسَ لِی مُلۡكُ مِصۡرَ وَهَـٰذِهِ ٱلۡأَنۡهَـٰرُ تَجۡرِی مِن تَحۡتِیۤۚ أَفَلَا تُبۡصِرُونَ ۝٥١﴾</q> - تفسير ٦٩٥٩١- قال عبد الله بن عباس: <q>﴿وهَذِهِ الأَنْهارُ تَجْرِي مِن تَحْتِي﴾</q> حولي{3}. (ز) ٦٩٥٩٢- عن عطاء: <q>﴿وهَذِهِ الأَنْهارُ تَجْرِي مِن تَحْتِي﴾</q> في قبضتي ومُلكي{3}. (ز) ٦٩٥٩٣- قال الحسن البصري: <q>﴿وهَذِهِ الأَنْهارُ تَجْرِي مِن تَحْتِي﴾</q> بأمري{5}. (ز) ٦٩٥٩٤- عن قتادة بن دعامة -من طريق سعيد- <q>﴿ألَيْسَ لِي مُلْكُ مِصْرَ وهَذِهِ الأَنْهارُ تَجْرِي مِن تَحْتِي﴾</q>، قال: قد كان لهم جِنان وأنهار{6}. (١٣/٢١٦) ٦٩٥٩٥- قال مقاتل بن سليمان: <q>﴿قالَ يا قَوْمِ ألَيْسَ لِي مُلْكُ مِصْرَ﴾</q> أربعين فرسخًا في أربعين فرسخًا، <q>﴿وهذِهِ الأَنْهارُ تَجْرِي مِن تَحْتِي﴾</q> مِن أسفل مِنِّي، <q>﴿أفَلا﴾</q> يعني: فهلّا <q>﴿تُبْصِرُونَ﴾</q> ألهم جنان وأنهار مثلها؟!{2}. (ز) ",footnotes:1:عزاه السيوطي إلى ابن المنذر.تفسير مقاتل بن سليمان ٣/٧٩٧.تفسير الثعلبي ٨/٣٣٩.تفسير الثعلبي ٨/٣٣٩.تفسير الثعلبي ٨/٣٣٩، وتفسير البغوي ٧/٢١٧.أخرجه عبد بن حميد -كما في التغليق ٤/٣٠٨-، وابن جرير ٢٠/٦١٠. وعزاه السيوطي إلى عبد الرزاق.تفسير مقاتل بن سليمان ٣/٧٩٧.
43,52," <q>﴿أَمۡ أَنَا۠ خَیۡرࣱ مِّنۡ هَـٰذَا﴾</q> - تفسير ٦٩٥٩٦- عن النضر، عن هارون، قال: وحدّثني المعتمر بن سليمان التيمي، عن أبيه، عن مجاهد، قال: <q>﴿أنا خير من هذا الذي هو مهين﴾</q> أم لا. قال النضر: <q>﴿أم﴾</q> مفتاح الكلام{1}. (ز) ٦٩٥٩٧- عن إسماعيل السُّدّيّ -من طريق أسباط- <q>﴿أمْ أنا خَيْرٌ مِن هَذا الَّذِي هُوَ مَهِينٌ﴾</q>، قال: بل أنا خيرٌ مِن هذا{2}. (ز) ٦٩٥٩٨- قال مقاتل بن سليمان: ثم قال فرعون: <q>﴿أمْ أنا خَيْرٌ﴾</q> يقول: أنا خير <q>﴿مِن هذا﴾</q> يعني: موسى{3}٥٨٧٧. (ز) ٥٨٧٧ اختُلف في معنى قوله: <q>﴿أم﴾</q> على قولين: الأول: أنها بمعنى: بل، وأن ذلك خبر لا استفهام. الثاني: أنها للاستفهام، ونسبه ابنُ جرير (٢٠/٦١٢) لبعض نحاة الكوفيين. ورجَّحه مستندًا إلى السياق، فقال: «وأولى التأويلات بالكلام إذ كان ذلك كذلك تأويل من جعل <q>﴿أم أنا خير﴾</q> مِن الاستفهام الذي جُعل بـ<q>﴿أم﴾</q>، لاتصاله بما قبله من الكلام، ووجهه إلى أنه بمعنى: أأنا خير من هذا الذي هو مهين أم هو؟ ثم ترك ذكر: أم هو؛ لما في الكلام من الدليل عليه». وذكر عن بعض القراء أنه كان يقرأ ذلك: (أمّا أنا خَيْرٌ) بما يوافقه، ولكنه انتقد هذه القراءة مستندًا لمخالفتها قراءة الجمهور، ورجَّح قراءة الجمهور <q>﴿أم أنا خير﴾</q>، فقال: «ولو كانت هذه القراءة قراءة مستفيضة في قراءة الأمصار لكانت صحيحة، وكان معناها حسنًا، غير أنها خلاف ما عليه قراء الأمصار، فلا أستجيز القراءة بها». <q>﴿ٱلَّذِی هُوَ مَهِینࣱ﴾</q> - تفسير ٦٩٥٩٩- عن قتادة بن دعامة -من طريق سعيد- <q>﴿أمْ أنا خَيْرٌ مِن هَذا الَّذِي هُوَ مَهِينٌ﴾</q>، قال: ضعيف{4}. (١٣/٢١٦) ٦٩٦٠٠- قال مقاتل بن سليمان: <q>﴿الَّذِي هُوَ مَهِينٌ﴾</q>، يعني: ضعيف ذليل{3}. (ز) <q>﴿وَلَا یَكَادُ یُبِینُ ۝٥٢﴾</q> - تفسير ٦٩٦٠١- عن عبد الله بن عباس، في قوله: <q>﴿ولا يَكادُ يُبِينُ﴾</q>، قال: كانت لموسى لثْغَة في لسانه{6}. (١٣/٢١٦) ٦٩٦٠٢- عن قتادة بن دعامة -من طريق سعيد- <q>﴿ولا يَكادُ يُبِينُ﴾</q>، قال: عَيِيُّ اللسان{4}. (١٣/٢١٦) ٦٩٦٠٣- عن إسماعيل السُّدّيّ -من طريق أسباط-: <q>﴿ولا يَكادُ يُبِينُ﴾</q> الكلام{8}. (ز) ٦٩٦٠٤- قال مقاتل بن سليمان: <q>﴿ولا يَكادُ يُبِينُ﴾</q> حجّته، يعني: لسانه؛ لأنّ الله تعالى كان أذهب عُقدة لسانه في طه [٢٧] حين قال: <q>﴿واحْلُلْ عُقْدَةً مِن لِسانِي﴾</q>. قال الله تعالى: <q>﴿قَدْ أُوتِيتَ سُؤْلَكَ يا مُوسى﴾</q> [طه:٣٦]{3}. (ز) ",footnotes:1:أخرجه إسحاق البستي ص٣١٨.أخرجه ابن جرير ٢٠/٦١١.تفسير مقاتل بن سليمان ٣/٧٩٧.أخرجه عبد بن حميد -كما في التغليق ٤/٣٠٨-، وابن جرير ٢٠/٦١٣. وعزاه السيوطي إلى عبد الرزاق.تفسير مقاتل بن سليمان ٣/٧٩٧.عزاه السيوطي إلى ابن المنذر.أخرجه عبد بن حميد -كما في التغليق ٤/٣٠٨-، وابن جرير ٢٠/٦١٣. وعزاه السيوطي إلى عبد الرزاق.أخرجه ابن جرير ٢٠/٦١٣.تفسير مقاتل بن سليمان ٣/٧٩٧.
43,53," <q>﴿فَلَوۡلَاۤ أُلۡقِیَ عَلَیۡهِ أَسۡوِرَةࣱ مِّن ذَهَبٍ﴾</q> - قراءات ٦٩٦٠٥- قال سفيان الثوري: كان أصحابُ عبد الله يقرءونها: ‹أساوِرَةٌ مِّن ذَهَبٍ›{1}٥٨٧٨. (ز) ٥٨٧٨ اختُلف في قراءة قوله: <q>﴿أسورة﴾</q>؛ فقرأ قوم: ‹أساوِرَةٌ›. وقرأ غيرهم: <q>﴿أسورة﴾</q>. ورجَّح ابنُ جرير (٢٠/٦١٤) القراءة الثانية مستندًا لما عليه قرأةُ الأمصار، فقال: «وأولى القراءتين في ذلك بالصواب عندي ما عليه قرأة الأمصار، وإن كانت الأخرى صحيحة المعنى». وذكر (٢٠/٦١٥) عن بعض نحاة البصرة أنهم قالوا: الأسورة جمع إسوار، والأساورة جمع الأسورة، وأنّ من قرأ ذلك ‹أساوِرَةٌ› فإنه أراد: أساوير، فجعل الهاء عِوضًا من الياء، مثل: الزنادقة، صارت الهاء فيها عِوضًا من الياء التي في زناديق. ونقل عن بعض نحاة الكوفة أن مَن قرأ ‹أساوِرَةٌ› جعل واحدها: إسوار، ومن قرأ <q>﴿أسورة﴾</q> جعل واحدها: سوار، وأنه قد تكون الأساورة جمع أسورة، كما يقال في جمع الأسقية: الأساقي، وفي جمع الأكرع: الأكارع. ونقل عن بعضهم أنه قال: قد قيل في سوار اليد: يجوز فيه أسوار وإسوار؛ فيجوز على هذه اللغة أن يكون أساورة جمعه، وأنه حكي عن أبي عمرو ابن العلاء أنه كان يقول: واحد الأساورة: إسوار؛ وتصديقه في قراءة أُبي بن كعب: ‹فَلَوْلَآ أُلْقِيَ عَلَيْهِ أساوِرَةٌ مِّن ذَهَبٍ›. ثم انتقد ابنُ جرير القراءة الأولى مستندًا لمخالفتها لغة العرب، فقال: «فإن كان ما حكي من الرواية من أنه يجوز أن يقال في سوار اليد: إسوار، فلا مؤنة في جمعه: أساورة، ولست أعلم ذلك صحيحًا عن العرب برواية عنها، وذلك أن المعروف في كلامهم من معنى الإسوار: الرجل الرامي، الحاذق بالرمي من رجال العجم. وأما الذي يلبس في اليد فإن المعروف من أسمائه عندهم: سِوارٌ، فإذا كان ذلك كذلك فالذي هو أولى بالأساورة أن يكون جمع أسورة، على ما قاله الذي ذكرنا قوله في ذلك». <q>﴿فَلَوۡلَاۤ أُلۡقِیَ عَلَیۡهِ أَسۡوِرَةࣱ مِّن ذَهَبٍ﴾</q> - تفسير الآية ٦٩٦٠٦- عن عبد الله بن عباس -من طريق عطية- قوله: <q>﴿أسْوِرَةٌ مِن ذَهَبٍ﴾</q>، يقول: أقْلِبة من ذهب{2}. (ز) ٦٩٦٠٧- قال مجاهد بن جبر: <q>﴿فَلَوْلا أُلْقِيَ عَلَيْهِ أسْوِرَةٌ مِن ذَهَبٍ﴾</q> كانوا إذا سوّدوا رجلًا سوّروه بسوار، وطوّقوه بطَوْقٍ من ذهب؛ ليكون ذلك دلالةً لسيادته، وعلامةً لرياسته، فقال فرعون: هلّا ألقى ربُّ موسى عليه أسورة من ذهب إن كان سيّدًا تجب علينا طاعته{3}. (ز) ٦٩٦٠٨- قال الحسن البصري: <q>﴿أسْوِرَةٌ مِن ذَهَبٍ﴾</q> مال من الذّهب{4}. (ز) ٦٩٦٠٩- عن قتادة بن دعامة -من طريق سعيد- ‹فَلَوْلَآ أُلْقِيَ عَلَيْهِ أساوِرَةٌ مِّن ذَهَبٍ›، قال: أقلِبة من ذهب{5}. (١٣/٢١٦) ٦٩٦١٠- قال مقاتل بن سليمان: ثم قال فرعون: <q>﴿فَلَوْلا أُلْقِيَ عَلَيْهِ أسْوِرَةٌ مِن ذَهَبٍ﴾</q> يقول: فهلّا ألقى عليه ربُّه الذي أرسله <q>﴿أسْوِرَةٌ مِن ذهب﴾</q> إن كان صادقًا أنّه رسول{6}. (ز) <q>﴿أَوۡ جَاۤءَ مَعَهُ ٱلۡمَلَـٰۤىِٕكَةُ مُقۡتَرِنِینَ ۝٥٣﴾</q> - تفسير ٦٩٦١١- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿أوْ جاءَ مَعَهُ المَلائِكَةُ مُقْتَرِنِينَ﴾</q>، قال: يمشون معًا{7}. (١٣/٢١٦) ٦٩٦١٢- عن قتادة بن دعامة -من طريق سعيد- <q>﴿أوْ جاءَ مَعَهُ المَلائِكَةُ مُقْتَرِنِينَ﴾</q>: أي: متتابعين{8}. (١٣/٢١٦) ٦٩٦١٣- عن إسماعيل السُّدّيّ -من طريق أسباط- <q>﴿أوْ جاءَ مَعَهُ المَلائِكَةُ مُقْتَرِنِينَ﴾</q>، قال: يُقارِن بعضُهم بعضًا{9}. (ز) ٦٩٦١٤- قال مقاتل بن سليمان: <q>﴿أوْ جاءَ مَعَهُ المَلائِكَةُ مُقْتَرِنِينَ﴾</q>، يعني: متعاونين، يعينونه على أمره الذي بُعث إليه{6}٥٨٧٩. (ز) ٥٨٧٩ ذكر ابنُ جرير (٢٠/٦١٥) أن معنى قوله: <q>﴿أو جاء معه الملائكة مقترنين﴾</q>: أو هلّا إن كان صادقًا جاء معه الملائكة مقترنين قد اقترن بعضهم ببعض، فتتابعوا يشهدون له بأنه لله رسول إليهم. ثم قال (٢٠/٦١٦): «وبنحو الذي قلنا في ذلك قال أهل التأويل على اختلاف منهم في العبارة على تأويله». وساق الأقوال. ",footnotes:1:تفسير سفيان الثوري ص٢٧٢. وهي قراءة متواترة، قرأ بها العشرة، ما عدا يعقوب وحفصًا، فإنهما قرآ: <q>﴿أسْوِرَةٌ﴾</q>. انظر: النشر ٢/٣٦٩، والإتحاف ص٤٩٦.أخرجه ابن جرير ٢٠/٦١٤.تفسير الثعلبي ٨/٣٣٩، وتفسير البغوي ٧/٢١٧.ذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٤/١٨٨-.أخرجه عبد بن حميد -كما في التغليق ٤/٣٠٨-، وابن جرير ٢٠/٦١٤. وعزاه السيوطي إلى عبد الرزاق.تفسير مقاتل بن سليمان ٣/٧٩٨.تفسير مجاهد ص٥٩٤، وأخرجه ابن جرير ٢٠/٦١٦، والفريابي -كما في تغليق التعليق ٤/٣٠٧، والفتح ٨/٥٦٧-. وعزاه السيوطي إلى عَبد بن حُمَيد.أخرجه عبد الرزاق ٢/١٩٧ من طريق معمر، وعبد بن حميد -كما في التغليق ٤/٣٠٨-، وابن جرير ٢٠/٦١٦ من طريق معمر أيضًا.أخرجه ابن جرير ٢٠/٦١٦.تفسير مقاتل بن سليمان ٣/٧٩٨.
43,54," <q>﴿فَٱسۡتَخَفَّ قَوۡمَهُۥ فَأَطَاعُوهُۚ إِنَّهُمۡ كَانُوا۟ قَوۡمࣰا فَـٰسِقِینَ ۝٥٤﴾</q> - تفسير ٦٩٦١٥- عن عكرمة مولى ابن عباس -من طريق أبي سعيد- قال: لم يُخرج فرعون مَن زاد على الأربعين سنة ومَن دون العشرين، فذلك قوله: <q>﴿فاسْتَخَفَّ قَوْمَهُ فَأَطاعُوهُ﴾</q>، يعني: استخفّ قومه في طلب موسى ﵇{1}. (١٣/٢١٧) ٦٩٦١٦- قال مقاتل بن سليمان: <q>﴿فاسْتَخَفَّ قَوْمَهُ﴾</q> يقول: استفزّ قومَه القِبط، <q>﴿فَأَطاعُوهُ﴾</q> في الذي قال لهم على التكذيب، حين قال لهم: <q>﴿ما أُرِيكُمْ إلّا ما أرى وما أهْدِيكُمْ إلّا سَبِيلَ الرَّشادِ﴾</q> [غافر:٢٩] فأطاعوه في الذي قال لهم، <q>﴿إنَّهُمْ كانُوا قَوْمًا فاسِقِينَ﴾</q> يعني: عاصين{2}. (ز) <q>﴿فَٱسۡتَخَفَّ قَوۡمَهُۥ فَأَطَاعُوهُۚ إِنَّهُمۡ كَانُوا۟ قَوۡمࣰا فَـٰسِقِینَ ۝٥٤﴾</q> - آثار متعلقة بالآية ٦٩٦١٧- قال أبو الدَّرداء -من طريق بلال بن سعد-: لو كانت الدّنيا تَزِنُ عند الله جناحَ ذباب ما سقى فرعونَ منها شرابًا{3}. (ز) ٦٩٦١٨- عن الأسود بن يزيد، قال: قلت لعائشة: ألا تعجبين مِن رجل من الطُّلقاء ينازع أصحاب محمد في الخلافة؟! قالت: وما تعجب مِن ذلك، هو سلطان الله يؤتيه البرّ والفاجر، وقد مَلك فرعون أهل مصر أربعمائة سنة{4}. (١٣/٢١٥) ",footnotes:1:أخرجه عبد الحكم في فتوح مصر ص٢٣.تفسير مقاتل بن سليمان ٣/٧٩٨.أخرجه الثعلبي ٨/٣٣٩.عزاه السيوطي إلى ابن أبي حاتم.
43,55," <q>﴿فَلَمَّاۤ ءَاسَفُونَا ٱنتَقَمۡنَا مِنۡهُمۡ فَأَغۡرَقۡنَـٰهُمۡ أَجۡمَعِینَ ۝٥٥﴾</q> - تفسير ٦٩٦١٩- عن عبد الله بن عباس -من طريق علي- في قوله: <q>﴿فَلَمّا آسَفُونا﴾</q>، قال: أسْخَطونا{1}. (١٣/٢١٧) ٦٩٦٢٠- عن عبد الله بن عباس -من طريق عطية- في قوله: <q>﴿آسَفُونا﴾</q>، قال: أغضبونا{2}. (١٣/٢١٧) ٦٩٦٢١- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿فَلَمّا آسَفُونا﴾</q>، قال: أغضبونا{3}. (١٣/٢١٧) ٦٩٦٢٢- عن عكرمة مولى ابن عباس، <q>﴿فَلَمّا آسَفُونا﴾</q>، قال: أغضبونا{4}. (١٣/٢١٧) ٦٩٦٢٣- عن الحسن البصري -من طريق المبارك بن فَضالة- في قوله: <q>﴿فلما آسفونا﴾</q>، قال: أغضبونا{5}. (ز) ٦٩٦٢٤- عن وهْب بن مُنَبِّه -من طريق سماك بن الفضل- في قوله: <q>﴿فلما آسفونا انتقمنا منهم﴾</q>، قال: أغضبونا{6}. (ز) ٦٩٦٢٥- عن قتادة بن دعامة -من طريق معمر- <q>﴿فَلَمّا آسَفُونا﴾</q>، قال: أغضبونا{7}. (١٣/٢١٦) ٦٩٦٢٦- عن إسماعيل السُّدّيّ -من طريق أسباط- <q>﴿فلما آسفونا﴾</q> قال: أغضبونا، وهو على قول يعقوب: <q>﴿يا أسَفى عَلى يُوسُفَ﴾</q> [يوسف:٨٤]، قال: يا حَزني على يوسف{8}. (ز) ٦٩٦٢٧- قال مقاتل بن سليمان: <q>﴿فَلَمّا آسَفُونا﴾</q> يعني: أغضبونا <q>﴿انْتَقَمْنا مِنهُمْ فَأَغْرَقْناهُمْ أجْمَعِينَ﴾</q> لَم ينجُ منهم أحدٌ{9}. (ز) ٦٩٦٢٨- قال سفيان الثوري: <q>﴿فَلَمّا آسَفُونا﴾</q> أغضبونا{10}. (ز) ٦٩٦٢٩- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿فَلَمّا آسَفُونا انْتَقَمْنا مِنهُمْ﴾</q>، قال: أغضبونا{8}٥٨٨٠. (ز) ٥٨٨٠ ذكر ابنُ عطية (٧/٥٥٦) أن هذا هو تفسير قوله: <q>﴿آسفونا﴾</q> بلا خلاف. <q>﴿فَلَمَّاۤ ءَاسَفُونَا ٱنتَقَمۡنَا مِنۡهُمۡ فَأَغۡرَقۡنَـٰهُمۡ أَجۡمَعِینَ ۝٥٥﴾</q> - آثار متعلقة بالآية ٦٩٦٣٠- عن عُقبة بن عامر، أنّ رسول الله ﷺ قال: «إذا رأيتَ الله يُعطي العبدَ ما شاء وهو مُقيم على معاصيه؛ فإنّما ذلك استِدْراجٌ مِنه له». ثم تلا: <q>﴿فَلَمّا آسَفُونا انْتَقَمْنا مِنهُمْ فَأَغْرَقْناهُمْ أجْمَعِينَ﴾</q>{12}. (١٣/٢١٨) ٦٩٦٣١- عن طارق بن شهاب، قال: كنت عند عبد الله، فذُكر عنده موت الفَجأة، فقال: تخفيف على المؤمن، وحسرة على الكافر؛ <q>﴿فَلَمّا آسَفُونا انْتَقَمْنا مِنهُمْ﴾</q>{13}. (١٣/٢١٨) ٦٩٦٣٢- عن محمد بن كناسة، قال: سمعتُ عمر بن ذر يقول: آنَسَك جانبُ حِلمه فتوثّبتَ على معاصيه، أفأسَفه تريد؟ أما سمعَته يقول: <q>﴿فلما آسفونا انتقمنا منهم فأغرقناهم﴾</q>؟ أيها الناس، أجِلُّوا مقامَ الله بالتنُزُّه عما لا يحلّ، فإنّ الله لا يُؤمَن إذا عُصي{14}. (ز) ",footnotes:1:أخرجه ابن جرير ٢٠/٦١٧، وابن أبي حاتم -كما في تغليق التعليق ٤/٣٠٦، والفتح ٨/٥٦٦-.أخرجه ابن جرير ٢٠/٦١٧. وعزاه السيوطي إلى ابن أبي حاتم.تفسير مجاهد ص٥٩٤، وأخرجه ابن جرير ٢٠/٦١٧-٦١٨، والفريابي -كما في تغليق التعليق ٤/٣٠٧، والفتح ٨/٥٦٧-. وعزاه السيوطي إلى عَبد بن حُمَيد، وابن المنذر.عزاه السيوطي إلى عبد بن حميد.أخرجه أبو حاتم الرازي في الزهد ص٤٢.أخرجه ابن عساكر في تاريخ دمشق ٤٠/٢٩٢.أخرجه عبد الرزاق ٢/١٩٧، وعبد بن حميد -كما في التغليق ٤/٣٠٨-، وابن جرير ٢٠/٦١٨، ومن طريق سعيد بلفظ: أغضبوا ربهم.أخرجه ابن جرير ٢٠/٦١٨.تفسير مقاتل بن سليمان ٣/٧٩٨.تفسير سفيان الثوري ص٢٧٢.أخرجه ابن جرير ٢٠/٦١٨.أخرجه الروياني في مسنده ١/١٩٥ (٢٦٠)، وابن أبي حاتم ١٠/٣٢٨٣، من طريق عبد الله بن لهيعة، عن عقبة بن مسلم التجيبي، عن عقبة بن عامر به، وفيه ابن لهيعة، وهو ضعيف. لكنه توبع بما رواه الخرائطي في فضيلة شكر الله ص٥٧، من طريق حرملة بن عمران، عن عقبة بن مسلم، عن عقبة بن عامر به؛ فالحديث حسن لغيره.عزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.أخرجه أبو نعيم في حلية الأولياء ٥/١١١.
43,56," <q>﴿فَجَعَلۡنَـٰهُمۡ سَلَفࣰا﴾</q> - قراءات ٦٩٦٣٣- عن سعد بن عياض، أنّه قرأ: ‹سُلُفًا› برفع السين واللام{1}. (١٣/٢١٨) ٦٩٦٣٤- عن عاصم، أنه كان يقرأ: <q>﴿فَجَعَلْناهُمْ سَلَفًا﴾</q> بنصب السين واللام{2}٥٨٨١. (١٣/٢١٨) ٥٨٨١ اختُلف في في قراءة قوله: <q>﴿سلفا﴾</q>؛ فقرأ قوم: ‹سُلُفًا›، وقرأ آخرون: <q>﴿سَلَفًا﴾</q>، وقرأ غيرهم: (سُلَفًا). وذكر ابنُ جرير (٢٠/٦١٩) أن قراءة ضم السين واللام هي: جمع سليف من الناس، وهو المتقدم أمام القوم، وأن القراءة بفتح السين واللام يحتمل أن يكون مرادًا بها الجماعة والواحد والذكر والأنثى، لأنه يقال للقوم: أنتم لنا سلف، وقد يجمع فيقال: هم أسلاف، ومنه الخبر الذي روي عن رسول الله ﷺ أنه قال: «يذهب الصالحون أسلافًا». وذكر أنّ قراءة ضم السين وفتح اللام هي: جمع سُلْفة من الناس، مثل أمّة منهم وقِطعة. وبنحوه قال ابنُ عطية (٧/٥٥٦). ورجَّح ابنُ جرير قراءة فتح السين واللام مستندًا إلى أنها الأجود في لغة العرب، فقال: «وأولى القراءات في ذلك بالصواب قراءةُ مَن قرأه بفتح السين واللام؛ لأنها اللغة الجُودى، والكلام المعروف عند العرب، وأحقُّ اللغات أن يقرأ بها كتاب الله من لغات العرب أفصحها وأشهرها فيهم». <q>﴿فَجَعَلۡنَـٰهُمۡ سَلَفࣰا﴾</q> - تفسير الآية ٦٩٦٣٥- عن عبد الله بن عباس -من طريق عطية- في قوله: <q>﴿سَلَفًا﴾</q>، قال: أهواء مختلفة{3}. (١٣/٢١٧) ٦٩٦٣٦- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿فَجَعَلْناهُمْ سَلَفًا﴾</q>، قال: هم قوم فرعون، كفارهم سلفًا لكفار أمة محمد{4}. (١٣/٢١٧) ٦٩٦٣٧- عن قتادة بن دعامة -من طريق معمر- <q>﴿فَجَعَلْناهُمْ سَلَفًا﴾</q>، قال: إلى النار{5}. (١٣/٢١٦) ٦٩٦٣٨- عن عطاء الخُراساني -من طريق يونس بن يزيد- في قوله تعالى: <q>﴿فجعلناهم سلفا ومثلا للآخرين﴾</q>، قال: جُعِلوا سلفًا في الناس{6}. (ز) ٦٩٦٣٩- قال مقاتل بن سليمان: <q>﴿فَجَعَلْناهُمْ سَلَفًا﴾</q>، يعني: مَضَوا في العذاب{7}. (ز) <q>﴿وَمَثَلࣰا لِّلۡـَٔاخِرِینَ ۝٥٦﴾</q> - تفسير ٦٩٦٤٠- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿ومَثَلًا لِلْآخِرِينَ﴾</q>، قال: عِبرةً لِمَن بعدهم{8}. (١٣/٢١٧) ٦٩٦٤١- عن قتادة بن دعامة -من طريق سعيد- <q>﴿ومَثَلًا لِلْآخِرِينَ﴾</q>، قال: عِظَةً لِمَن بعدهم{9}. (١٣/٢١٦) ٦٩٦٤٢- عن إسماعيل السُّدّيّ -من طريق أسباط- <q>﴿فَجَعَلْناهُمْ سَلَفًا ومَثَلًا﴾</q>، قال: عبرةً{10}. (ز) ٦٩٦٤٣- عن عطاء الخُراساني -من طريق يونس بن يزيد- في قوله تعالى: <q>﴿ومثلا للآخرين﴾</q>، قال: ومَثلًا لِمَن بعدهم مِن القرون{6}. (ز) ٦٩٦٤٤- قال مقاتل بن سليمان: <q>﴿ومَثَلًا لِلْآخِرِينَ﴾</q>، يعني: عِبرةً لِمَن بعدهم{7}. (ز) ",footnotes:1:عزاه السيوطي إلى عبد بن حميد. وهي قراءة متواترة، قرأ بها حمزة، والكسائي، وقرأ بقية العشرة: <q>﴿سَلَفًا﴾</q> بفتح السين واللام. انظر: النشر ٢/٣٦٩، والإتحاف ص٤٩٦.عزاه السيوطي إلى عبد بن حميد.عزاه السيوطي إلى ابن جرير، وابن أبي حاتم.تفسير مجاهد ص٥٩٤، وأخرجه الفريابي -كما في تغليق التعليق ٤/٣٠٧، والفتح ٨/٥٦٧-، وابن جرير ٢٠/٦٢٠. وذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٤/١٨٨-. وعزاه السيوطي إلى عَبد بن حُمَيد، وابن المنذر.أخرجه عبد الرزاق ٢/١٩٧، وعبد بن حميد -كما في التغليق ٤/٣٠٨-، وابن جرير ٢٠/٦٢٠.أخرجه أبو جعفر الرملي في جزئه (تفسير عطاء) ص٩٢.تفسير مقاتل بن سليمان ٣/٧٩٨.تفسير مجاهد ص٥٩٤، وأخرجه الفريابي -كما في تغليق التعليق ٤/٣٠٧، والفتح ٨/٥٦٧-، وابن جرير ٢٠/٦٢٠. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه عبد الرزاق ٢/١٩٧ من طريق معمر بنحوه، وعبد بن حميد -كما في التغليق ٤/٣٠٨-، وابن جرير ٢٠/٦٢١، ومن طريق معمر أيضًا.أخرجه ابن جرير ٢٠/٦٢١.أخرجه أبو جعفر الرملي في جزئه (تفسير عطاء) ص٩٢.تفسير مقاتل بن سليمان ٣/٧٩٨.
43,57," <q>﴿وَلَمَّا ضُرِبَ ٱبۡنُ مَرۡیَمَ مَثَلًا إِذَا قَوۡمُكَ مِنۡهُ یَصِدُّونَ ۝٥٧﴾</q> - قراءات ٦٩٦٤٥- عن علي بن أبي طالب: سمعتُ النبيَّ يقرأ: <q>﴿يَصِدُّونَ﴾</q> بالكسر{1}. (١٣/٢٢١) ٦٩٦٤٦- عن عبد الله بن عباس –من طريق أبي يحيى- أنه كان يقرؤها: <q>﴿يَصِدُّونَ﴾</q>، يعني: بكسر الصاد{2}. (١٣/٢٢٠) ٦٩٦٤٧- عن أبي عبد الرحمن السُّلَمِيّ، أنّه قرأ: ‹يَصُدُّونَ› بضم الصاد{3}. (١٣/٢٢٠) ٦٩٦٤٨- عن سعيد بن معبد ابن أخي عُبيد بن عمير الليثي= (ز) ٦٩٦٤٩- قال: قال لي ابن عباس: ما لِعمِّك يقرأ هذه الآية: ‹إذا قَوْمُكَ مِنهُ يَصُدُّونَ›؟! إنها ليست كذا، إنما هي <q>﴿إذا قَوْمُكَ مِنهُ يَصِدُّونَ﴾</q> إذا هم يعجّون، إذا هم يصيحون{4}٥٨٨٢. (١٣/٢٢٠) ٥٨٨٢ اختُلف في قراءة قوله: <q>﴿يصدون﴾</q>؛ فقرأ قوم: بضم الصاد، وقرأ غيرهم بكسرها. وذكر ابنُ جرير (٢٠/٦٢٣) أنه اختلف في الفرق بين الضم والكسر، فذهب قوم إلى أنهما لغتان بمعنى واحد، مثل يشُد ويشِد، وقال غيرهم بأن مَن كَسر الصاد فمجازها: يضجون، ومن ضمها فمجازها: يعدلون. وذهب قوم إلى أن من كسرها فإنه أراد: يضجون، ومن ضمها فإنه أراد: الصدود عن الحق. وبنحوه قال ابنُ عطية (٧/٥٥٧). ثم رجَّح ابنُ جرير (٢٠/٦٢٤) صحة كلتا القراءتين مستندًا إلى شهرتهما، واتحاد معناهما، فقال: «والصواب من القول في ذلك أنهما قراءتان معروفتان، ولغتان مشهورتان بمعنًى واحد، ولم نجد أهل التأويل فرّقوا بين معنى ذلك إذا قُرئ بالضم والكسر، ولو كان مختلفًا معناه لقد كان الاختلاف في تأويله بين أهله موجودًا وجود اختلاف القراءة فيه باختلاف اللغتين، ولكن لما لم يكن مختلف المعنى لم يختلفوا في أن تأويله: يضجون ويجزعون، فبأي القراءتين قرأ القارئ فمصيب». <q>﴿وَلَمَّا ضُرِبَ ٱبۡنُ مَرۡیَمَ مَثَلًا إِذَا قَوۡمُكَ مِنۡهُ یَصِدُّونَ ۝٥٧﴾</q> - نزول الآية ٦٩٦٥٠- عن أبي يحيى مولى ابن عقيل الأنصاري، عن عبد الله بن عباس، أنّ رسول الله ﷺ قال لقريش: «إنّه ليس أحد يُعبَد من دون الله فيه خير». فقالوا: ألست تزعم أنّ عيسى كان نبيًّا وعبدًا مِن عباد الله صالحًا وقد عَبَدَتْهُ النصارى! فإن كنتَ صادقًا فإنه كآلهتهم. فأنزل الله: <q>﴿ولَمّا ضُرِبَ ابْنُ مَرْيَمَ مَثَلًا إذا قَوْمُكَ مِنهُ يَصِدُّونَ﴾</q>. قلت: ما يصدون؟ قال: يضجّون{5}. (١٣/٢١٩) ٦٩٦٥١- قال محمد بن السّائِب الكلبي: لما نزلت: <q>﴿إنَّكُمْ وما تَعْبُدُونَ مِن دُونِ اللَّهِ حَصَبُ جَهَنَّمَ أنْتُمْ لَها وارِدُونَ﴾</q> [الأنبياء:٩٨] قام رسول الله مقابل باب الكعبة، ثم اقترأ هذه الآية، فوجد منها أهل مكة وجْدًا شديدًا، فدخل عليهم ابن الزِّبَعْرى الشاعر وقريشٌ يخوضون في ذِكر هذه الآية، فقال: أمحمد تكلّم بهذه؟ قالوا: نعم. قال: واللهِ، إن اعترف لي بهذا لأخصمنه. فلَقِيه، فقال: يا محمد، أرأيتَ الآية التي قرأتَ آنفًا، أفينا وفي آلهتنا نزلت خاصّة أم في الأمم وآلهتهم؟ قال: «لا، بل فيكم وفي آلهتكم، وفي الأمم وآلهتهم». فقال: خصمتُك، وربِّ الكعبة، أليس تُثْنِي على عيسى ومريم والملائكة خيرًا، وقد علمتَ أنّ النصارى تعبد عيسى وأمه، وأنّ طائفة من الناس يعبدون الملائكة، أفليس هؤلاء مع آلهتنا في النار؟! فسكتَ رسولُ الله، وضحكتْ قريش وضجّوا{6}. (ز) ٦٩٦٥٢- وعن محمد بن إسحاق، نحوه{7}. (ز) ٦٩٦٥٣- قال مقاتل بن سليمان: <q>﴿ولَمّا ضُرِبَ ابْنُ مَرْيَمَ مَثَلًا﴾</q> المثل: حين زعموا أنّ الملائكة بنات الله، وذلك أنّ النبي ﷺ دخل المسجد وحول الكعبة ثلاثمائة وستون صنمًا، وفي المسجد العاص بن وائل السهمي، والحارث وعدي ابنا قيس، كلهم مِن قريش من بني سهم، فقال لهم النبي ﷺ: <q>﴿إنَّكُمْ وما تَعْبُدُونَ مِن دُونِ اللَّهِ حَصَبُ جَهَنَّمَ أنْتُمْ لَها وارِدُونَ﴾</q> [الأنبياء:٩٨] إلى آيتين. ثم خرج إلى باب الصفا، فخاض المشركون في ذلك، فدخل عبد الله بن الزِّبَعْرى السهمي، فقال: تخوضون في ذكر الآلهة! فذكروا له ما قال النبيُّ ﷺ لهم ولآلهتهم، فقال عبد الله بن الزبعرى: يا محمد، أخاصّة لنا ولآلهتنا؟ أم لنا ولآلهتنا ولجميع الأمم وآلهتهم؟ فقال النبي ﷺ: «بل هي لكم ولآلهتكم، ولجميع الأمم ولآلهتهم». فقال عبد الله: خصمتُك، وربِّ الكعبة؛ ألست تزعم أنّ عيسى ابن مريم نبيٌّ وتُثْنِي عليه وعلى أُمّه خيرًا، وقد علمتَ أنّ النصارى يعبدونهما؟! وعُزير يُعبد، والملائكة تُعبد، فإن كان هؤلاء في النار فقد رضينا أن نكون معهم. فقال النبي ﷺ: «لا». فقال عبد الله: أليس قد زعمتَ أنها لنا ولآلهتنا ولجميع الأمم وآلهتهم؟! خصمتُك، وربّ الكعبة. فضجّوا من ذلك؛ فأنزل الله تعالى: <q>﴿إنَّ الَّذِينَ سَبَقَتْ لَهُمْ مِنّا الحُسْنى﴾</q> يعني: الملائكة، وعُزيز، وعيسى، ومريم <q>﴿أُولئِكَ عَنْها مُبْعَدُونَ﴾</q>. وأنزل: <q>﴿ولَمّا ضُرِبَ ابْنُ مَرْيَمَ مَثَلًا إذا قَوْمُكَ مِنهُ يَصِدُّونَ﴾</q>{8}. (ز) ٦٩٦٥٤- عن عيسى بن عبد الله بن محمد بن عمر بن علي بن أبي طالب، عن أبيه، عن جَده، عن عليٍّ، قال: جئتُ رسولَ الله ﷺ يومًا في ملأٍ مِن قريش، فنظر إلَيَّ، وقال: «يا علي، إنما مَثلك في هذه الأمة كمَثل عيسى ابن مريم؛ أحبّه قومٌ فأفرطوا فيه، وأبغضه قوم فأفرطوا فيه». قال: فضحك الملأُ الذين عنده، وقالوا: انظروا كيف يشبّه ابنَ عمه بعيسى! فأنزل الله القرآن: <q>﴿ولما ضرب ابن مريم مثلا اذا قومك منه يصدون﴾</q>{9}. (ز) <q>﴿وَلَمَّا ضُرِبَ ٱبۡنُ مَرۡیَمَ مَثَلًا إِذَا قَوۡمُكَ مِنۡهُ یَصِدُّونَ ۝٥٧﴾</q> - تفسير الآية ٦٩٦٥٥- عن عبد الله بن عباس -من طريق علي- <q>﴿يَصِدُّونَ﴾</q>: يضجّون{10}. (١٣/٢٢٠) ٦٩٦٥٦- عن عبد الله بن عباس -من طريق سعيد بن معبد- قال: <q>﴿إذا قَوْمُكَ مِنهُ يَصِدُّونَ﴾</q> إذا هم يَعِجُّون، إذا هم يصيحون{4}. (١٣/٢٢٠) ٦٩٦٥٧- عن عبد الله بن عباس -من طريق أبي رَزين- <q>﴿يَصِدُّونَ﴾</q>: يضحكون{12}. (ز) ٦٩٦٥٨- قال سعيد بن المسيّب: <q>﴿يَصِدُّونَ﴾</q> يصيحون{13}. (ز) ٦٩٦٥٩- عن سعيد بن جبير، <q>﴿إذا قَوْمُكَ مِنهُ يَصِدُّونَ﴾</q>، قال: يصيحون{14}. (١٣/٢٢٠) ٦٩٦٦٠- عن مجاهد بن جبر= (ز) ٦٩٦٦١- والحسن البصري= (ز) ٦٩٦٦٢- وقتادة بن دعامة، مثله{14}. (١٣/٢٢٠) ٦٩٦٦٣- عن إبراهيم النَّخْعي، <q>﴿يَصِدُّونَ﴾</q>، قال: يُعرضون{4}. (١٣/٢٢٠) ٦٩٦٦٤- عن مجاهد بن جبر -من طريق ابن أبي نجيح- قال: <q>﴿يَصِدُّونَ﴾</q> يضِجُّون{17}. (ز) ٦٩٦٦٥- قال الضَّحّاك بن مُزاحِم: <q>﴿إذا قَوْمُكَ مِنهُ يَصِدُّونَ﴾</q> يَعِجُّون{13}. (ز) ٦٩٦٦٦- عن الضَّحّاك بن مُزاحِم -من طريق عبيد- <q>﴿يَصِدُّونَ﴾</q>، قال: يضِجُّون{19}. (ز) ٦٩٦٦٧- عن يحيى بن وثّاب -من طريق الأعمش- قال: <q>﴿يَصِدُّونَ﴾</q> يُعرضون{12}. (ز) ٦٩٦٦٨- عن قتادة بن دعامة -من طريق سعيد- <q>﴿إذا قَوْمُكَ مِنهُ يَصِدُّونَ﴾</q>: أي: يجزعون، ويضجّون{21}. (ز) ٦٩٦٦٩- قال محمد بن كعب القُرَظي: <q>﴿إذا قَوْمُكَ مِنهُ يَصِدُّونَ﴾</q> يضجرون{13}. (ز) ٦٩٦٧٠- عن إسماعيل السُّدّيّ -من طريق أسباط- <q>﴿إذا قَوْمُكَ مِنهُ يَصِدُّونَ﴾</q>، قال: يضِجُّون{19}. (ز) ٦٩٦٧١- قال مقاتل بن سليمان: <q>﴿إذا قَوْمُكَ مِنهُ يَصِدُّونَ﴾</q>، يعني: يضجّون تعجّبًا لذكر عيسى ﵇؛ عبد الله ابن الزِّبَعْرى وأصحابه، هم هؤلاء النفر{24}. (ز) ٦٩٦٧٢- عن سفيان بن عُيَينة -من طريق ابن أبي عمر- في قوله: <q>﴿يصِدّون﴾</q>، قال: يضِجُّون{25}. (ز) ",footnotes:1:عزاه السيوطي إلى ابن مردويه. وهي قراءة متواترة، قرأ بها ابن كثير، وأبو عمرو، ويعقوب، وعاصم، وحمزة، وقرأ بقية العشرة: ‹يَصُدُّونَ› بضم الصاد. انظر: النشر ٢/٣٦٩، والإتحاف ص٤٩٦.أخرجه عبد الرزاق ٢/١٩٨ من طريق أبي رزين، وابن جرير ٢٠/٦٢٤. وعزاه السيوطي إلى الفريابي، وسعيد بن منصور، وعَبد بن حُمَيد، وابن المنذر، وابن مردويه.أخرجه عبد الرزاق ٢/١٩٧-١٩٨. وعزاه السيوطي إلى عَبد بن حُمَيد.عزاه السيوطي إلى عَبد بن حُمَيد، وابن المنذر.أخرجه أحمد ٥/٨٥-٨٦ (٢٩١٨)، وابن أبي حاتم -كما في تفسير ابن كثير ٧/٢٣٤-. قال الهيثمي في المجمع ٧/١٠٤ (١١٣٣١): «رواه أحمد والطبراني ... وفيه عاصم بن بهدلة، وثّقه أحمد وغيره، وهو سيّئ الحفظ، وبقيّة رجاله رجال الصحيح». وأورده الألباني في الصحيحة ٧/٦٣٢ (٣٢٠٨).ذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٤/١٨٩-١٩٠-.سيرة ابن هشام ١/٣٥٩.تفسير مقاتل بن سليمان ٣/٧٩٨-٧٩٩.أخرجه ابن حبان في المجروحين ٢/١٢١، وابن الجوزي في العلل المتناهية ١/٢٢٤ (٣٥٨)، وفيه عيسى بن عبد الله بن محمد بن عمر بن علي بن أبي طالب. قال ابن حبان في ترجمة عيسى بن عبد الله: «يروي عن أبيه عن آبائه أشياء موضوعة، لا يَحِلُّ الاحتجاج به». قال ابن القيسراني في تذكرة الحفاظ ص١٤١ (٣٢٨): «عيسى هذا عنده نسخة موضوعة بهذا الإسناد».أخرجه عبد الرزاق ٢/١٩٨ من طريق أبي رزين، وابن جرير ٢٠/٦٢٤، ٦٢٥، ٦٢٦، ومن طريق العوفي، وأبي يحيى، وأبي رزين، والصعب بن عثمان، وأبي صالح. وعزاه السيوطي إلى الفريابي، وسعيد بن منصور، وعَبد بن حُمَيد، وابن المنذر، وابن مردويه.عزاه السيوطي إلى عَبد بن حُمَيد، وابن المنذر.أخرجه سفيان الثوري ص٢٧٣.تفسير الثعلبي ٨/٣٤٠، وتفسير البغوي ٧/٢١٨.عزاه السيوطي إلى عَبد بن حُمَيد.عزاه السيوطي إلى عَبد بن حُمَيد.عزاه السيوطي إلى عَبد بن حُمَيد، وابن المنذر.تفسير مجاهد ص٥٩٤، وأخرجه سفيان الثوري ص٢٧٣، والفريابي -كما في تغليق التعليق ٤/٣٠٧-، وابن جرير ٢٠/٦٢٤.تفسير الثعلبي ٨/٣٤٠، وتفسير البغوي ٧/٢١٨.أخرجه ابن جرير ٢٠/٦٢٦.أخرجه سفيان الثوري ص٢٧٣.أخرجه ابن جرير ٢٠/٦٢٥.تفسير الثعلبي ٨/٣٤٠، وتفسير البغوي ٧/٢١٨.أخرجه ابن جرير ٢٠/٦٢٦.تفسير مقاتل بن سليمان ٣/٧٩٩.أخرجه إسحاق البستي ص٣١٩.
43,58," <q>﴿وَقَالُوۤا۟ ءَأَ ٰ⁠لِهَتُنَا خَیۡرٌ أَمۡ هُوَۚ مَا ضَرَبُوهُ لَكَ إِلَّا جَدَلَۢاۚ بَلۡ هُمۡ قَوۡمٌ خَصِمُونَ ۝٥٨﴾</q> - قراءات ٦٩٦٧٣- عن قتادة: أنّ في حرف أُبَيّ بن كعب: (وقالُواْ أآلِهَتُنا خَيْرٌ أمْ هَذا)، يعنون: محمدًا ﷺ{1}. (ز) <q>﴿وَقَالُوۤا۟ ءَأَ ٰ⁠لِهَتُنَا خَیۡرٌ أَمۡ هُوَۚ مَا ضَرَبُوهُ لَكَ إِلَّا جَدَلَۢاۚ بَلۡ هُمۡ قَوۡمٌ خَصِمُونَ ۝٥٨﴾</q> - نزول الآية، وتفسيرها ٦٩٦٧٤- عن عبد الله بن عباس -من طريق عطية- <q>﴿ولَمّا ضُرِبَ ابْنُ مَرْيَمَ مَثَلًا إذا قَوْمُكَ مِنهُ يَصِدُّونَ﴾</q>، قال: يعني: قريشًا؛ لَمّا قيل لهم: <q>﴿إنَّكُمْ وما تَعْبُدُونَ مِن دُونِ اللَّهِ حَصَبُ جَهَنَّمَ أنْتُمْ لَها وارِدُونَ﴾</q> [الأنبياء:٩٨] فقالت له قريش: فما ابن مريم؟ قال: «ذاك عبدُ الله ورسوله». فقالوا: واللهِ، ما يريد هذا إلا أن نتَّخِذه ربًّا، كما اتخذت النصارى عيسى ابنَ مريم ربًّا. فقال الله ﷿: <q>﴿ما ضَرَبُوهُ لَكَ إلّا جَدَلًا بَلْ هُمْ قَوْمٌ خَصِمُونَ﴾</q>{2}. (ز) ٦٩٦٧٥- عن قتادة بن دعامة -من طريق معمر- قال: لَمّا ذُكِر عيسى ابن مريم جزعت قريش، وقالوا: ما ذِكرُ محمدٍ عيسى ابنَ مريم! ما يريد محمدٌ إلا أن يُصنَع به كما صنعت النصارى بعيسى ابن مريم. فقال الله: <q>﴿ما ضَرَبُوهُ لَكَ إلّا جَدَلًا﴾</q>{3}. (١٣/٢١٩) ٦٩٦٧٦- عن قتادة بن دعامة -من طريق سعيد- قال: لَمّا ذَكر الله عيسى في القرآن قال مشركو مكة: إنّما أراد محمدٌ أن نُحِبَّه كما أحبَّ النصارى عيسى. قال: <q>﴿ما ضَرَبُوهُ لَكَ إلّا جَدَلًا﴾</q>، قال: ما قالوا هذا القول إلا ليجادلوا{4}. (١٣/٢٢٢) ٦٩٦٧٧- عن إسماعيل السُّدّيّ -من طريق أسباط- في قوله: <q>﴿وقالُوا أآلِهَتُنا خَيْرٌ أمْ هُوَ ما ضَرَبُوهُ لَكَ إلّا جَدَلًا بَلْ هُمْ قَوْمٌ خَصِمُونَ﴾</q>، قال: خاصموه. فقالوا: تزعم أنّ كلَّ مِن عُبِد مِن دون الله في النار! فنحن نرضى أن تكون آلهتنا مع عيسى، وعُزير، والملائكة، هؤلاء قد عُبِدوا من دون الله. قال: فأنزل الله براءة عيسى{5}. (ز) ٦٩٦٧٨- عن عطاء الخُراسانيّ -من طريق يونس بن يزيد- في قول الله سبحانه: <q>﴿ءآلهتنا خير أم هو﴾</q>، قال: يعنون: عيسى ﵇{6}. (ز) ٦٩٦٧٩- قال مقاتل بن سليمان: <q>﴿وقالُوا أآلِهَتُنا خَيْرٌ أمْ هُوَ﴾</q> يعني: عيسى. وقالوا: ليس آلهتنا إنْ عُذِّبت خيرًا مِن عيسى بأنه يُعبد. يقول الله تعالى: <q>﴿ما ضَرَبُوهُ لَكَ إلّا جَدَلًا﴾</q> يقول: ما ذكروا لك عيسى إلا ليجادلونك به{7}. (ز) ٦٩٦٨٠- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿أآلِهَتُنا خَيْرٌ﴾</q> قال: عَبَدَ هؤلاء عيسى، ونحن نعبد الملائكة. وقرأ: <q>﴿ما ضَرَبُوهُ لَكَ إلّا جَدَلًا بَلْ هُمْ قَوْمٌ خَصِمُونَ﴾</q> إلى قوله: <q>﴿فِي الأَرْضِ يَخْلُفُونَ﴾</q>{5}٥٨٨٣. (ز) ٥٨٨٣ قوله تعالى: <q>﴿أمْ هُوَ﴾</q> فيه قولان: الأول: أنه النبي ﷺ. الثاني: أنه عيسىﷺ. ورجَّح ابنُ عطية (٧/٥٥٨) القول الثاني الذي قاله السُّدّيّ، وابن زيد، ومقاتل، فقال: «وهذا هو المترجح». ولم يذكر سندًا. <q>﴿وَقَالُوۤا۟ ءَأَ ٰ⁠لِهَتُنَا خَیۡرٌ أَمۡ هُوَۚ مَا ضَرَبُوهُ لَكَ إِلَّا جَدَلَۢاۚ بَلۡ هُمۡ قَوۡمٌ خَصِمُونَ ۝٥٨﴾</q> - آثار متعلقة بالآية ٦٩٦٨١- عن أبي أُمامة، قال: قال رسول الله ﷺ: «ما ضلَّ قومٌ بعد هُدىً كانوا عليه إلا أُوتوا الجدل». ثم قرأ: <q>﴿ما ضَرَبُوهُ لَكَ إلّا جَدَلًا﴾</q> الآية{9}. (١٣/٢٢١) ٦٩٦٨٢- عن أبي أُمامة، أنّ رسول الله ﷺ خرج على الناس وهم يتنازعون في القرآن، فغضِب غضبًا شديدًا، كأنما صُبَّ على وجهه الخلّ، ثم قال: «لا تضربوا كتاب الله بعضه ببعض؛ فإنه ما ضلّ قومٌ قطّ إلا أُوتوا الجدل». ثم تلا: <q>﴿ما ضَرَبُوهُ لَكَ إلّا جَدَلًا﴾</q> الآية{10}. (١٣/٢٢١) ٦٩٦٨٣- عن أبي أُمامة، قال: ما ضلَّت أُمّةٌ بعد نبيِّها إلا أُعطوا الجدل. ثم قرأ: <q>﴿ما ضَرَبُوهُ لَكَ إلّا جَدَلًا﴾</q>{11}. (١٣/٢٢١) ",footnotes:1:أخرجه ابن جرير ٢٠/٦٢٧. وهي قراءة شاذة. انظر: الجامع لأحكام القرآن ١٩/٦٨.أخرجه ابن جرير ٢٠/٦٢٣، من طريق محمد بن سعد العوفي، عن أبيه، قال: حدثني عمي الحسين بن الحسن، عن أبيه، عن جده عطية العوفي، عن ابن عباس به. إسناده ضعيف، لكنها صحيفة صالحة ما لم تأت بمنكر أو مخالفة. وينظر: مقدمة الموسوعة.أخرجه عبد الرزاق ٢/١٩٨، وابن جرير ٢٠/٦٢٢. وعزاه السيوطي إلى ابن جرير، وابن المنذر.أخرجه عبد الرزاق ٢/١٩٨ من طريق معمر، وابن جرير ٢٠/٦٢٢ بنحوه. وعزاه السيوطي إلى عبد بن حُمَيد.أخرجه ابن جرير ٢٠/٦٢٧.أخرجه أبو جعفر الرملي في جزئه (تفسير عطاء) ص٩٢.تفسير مقاتل بن سليمان ٣/٧٩٩.أخرجه ابن جرير ٢٠/٦٢٧.أخرجه أحمد ٣٦/٤٩٣ (٢٢١٦٤)، ٣٦/٥٤٠ (٢٢٢٠٤)، والترمذي ٥/٤٥٦-٤٥٧ (٣٥٣٥)، وابن ماجه ١/٣٣ (٤٨)، والحاكم ٢/٤٨٦ (٣٦٧٤)، وابن جرير ٢٠/٦٢٨. قال الترمذي: «هذا حديث حسن صحيح». وقال الحاكم: «هذا حديث صحيح الإسناد، ولم يخرجاه».أخرجه ابن بطة في الإبانة الكبرى ٢/٤٨٦ (٥٢٧)، وابن جرير ٢٠/٦٢٨، من طريق عبّاد بن عبّاد، عن جعفر، عن القاسم، عن أبي أمامة به. إسناده ضعيف جدًّا؛ فيه جعفر، وهو ابن الزبير الحنفي أو الباهلي، قال ابن حجر في التقريب (٩٣٩): «متروك الحديث، وكان صالحًا في نفسه».أخرجه ابن أبي حاتم -كما في تفسير ابن كثير ٧/٢٢٢-، وعنده: قال حماد: لا أدري رفعه أم لا؟.
43,59," <q>﴿إِنۡ هُوَ إِلَّا عَبۡدٌ أَنۡعَمۡنَا عَلَیۡهِ وَجَعَلۡنَـٰهُ مَثَلࣰا لِّبَنِیۤ إِسۡرَ ٰ⁠ۤءِیلَ ۝٥٩﴾</q> - نزول الآية ٦٩٦٨٤- عن عبد الله بن عباس: أنّ المشركين أتَوا رسول الله ﷺ، فقالوا له: أرأيتَ ما يُعبَد مِن دون الله أين هم؟ قال: «في النار». قالوا: والشمس والقمر؟ قال: «والشمس والقمر». قالوا: فعيسى ابن مريم؟ فأنزل الله: <q>﴿إنْ هُوَ إلّا عَبْدٌ أنْعَمْنا عَلَيْهِ وجَعَلْناهُ مَثَلًا لِبَنِي إسْرائِيلَ﴾</q>{1}. (١٣/٢٢٣) <q>﴿إِنۡ هُوَ إِلَّا عَبۡدٌ أَنۡعَمۡنَا عَلَیۡهِ وَجَعَلۡنَـٰهُ مَثَلࣰا لِّبَنِیۤ إِسۡرَ ٰ⁠ۤءِیلَ ۝٥٩﴾</q> - تفسير الآية ٦٩٦٨٥- عن قتادة بن دعامة -من طريق سعيد- <q>﴿إنْ هُوَ إلّا عَبْدٌ أنْعَمْنا عَلَيْهِ﴾</q> قال: ما عدا ذلك نبي الله عيسى؛ أنْ كان عبدًا صالحًا أنعم الله عليه، <q>﴿وجَعَلْناهُ مَثَلًا لِبَنِي إسْرائِيلَ﴾</q> آية لبني إسرائيل{2}. (١٣/٢٢٢) ٦٩٦٨٦- قال مقاتل بن سليمان: <q>﴿إنْ هُوَ إلّا عَبْدٌ﴾</q> يعني: عيسى ﵇، يقول: ما هو إلا عبد <q>﴿أنْعَمْنا عَلَيْهِ﴾</q> بالنّبوة، <q>﴿وجَعَلْناهُ مَثَلًا لِبَنِي إسْرائِيلَ﴾</q> يقول الله تعالى: حين وُلِد مِن غير أب، يعني: آيةً وعبرةً ليعتبروا{3}. (ز) ",footnotes:1:عزاه السيوطي إلى ابن مردويه.أخرجه ابن جرير ٢٠/٦٢٩ بنحوه. وأخرجه عبد الرزاق ٢/١٩٨ من طريق معمر مقتصرًا على الشطر الثاني، وكذا ابن جرير. وعزاه السيوطي إلى عبد بن حُمَيد.تفسير مقاتل بن سليمان ٣/٧٩٩-٨٠٠.
43,60," <q>﴿وَلَوۡ نَشَاۤءُ لَجَعَلۡنَا مِنكُم مَّلَـٰۤىِٕكَةࣰ فِی ٱلۡأَرۡضِ یَخۡلُفُونَ ۝٦٠﴾</q> - تفسير ٦٩٦٨٧- عن عبد الله بن عباس -من طريق علي- <q>﴿ولَوْ نَشاءُ لَجَعَلْنا مِنكُمْ مَلائِكَةً فِي الأَرْضِ يَخْلُفُونَ﴾</q>، قال: يخلُفُ بعضُهم بعضًا{1}. (ز) ٦٩٦٨٨- عن مجاهد بن جبر -من طريق ابن أبي نجيح- <q>﴿ولَوْ نَشاءُ لَجَعَلْنا مِنكُمْ مَلائِكَةً فِي الأَرْضِ يَخْلُفُونَ﴾</q>، قال: يعمُرون الأرض بدلًا منكم{2}. (١٣/٢٢٣) ٦٩٦٨٩- عن قتادة بن دعامة -من طريق معمر- <q>﴿ولَوْ نَشاءُ لَجَعَلْنا مِنكُمْ مَلائِكَةً فِي الأَرْضِ يَخْلُفُونَ﴾</q>: يخلُف بعضُهم بعضًا مكان بني آدم{3}. (١٣/٢٢٢) ٦٩٦٩٠- عن قتادة بن دعامة -من طريق سعيد- <q>﴿ولَوْ نَشاءُ لَجَعَلْنا مِنكُمْ مَلائِكَةً فِي الأَرْضِ يَخْلُفُونَ﴾</q>: لو شاء اللهُ لَجعل في الأرض ملائكةً يخلُف بعضهم بعضًا{1}. (ز) ٦٩٦٩١- عن إسماعيل السُّدّيّ -من طريق أسباط- <q>﴿ولَوْ نَشاءُ لَجَعَلْنا مِنكُمْ مَلائِكَةً فِي الأَرْضِ يَخْلُفُونَ﴾</q>، قال: خلفًا منكم{5}. (ز) ٦٩٦٩٢- قال مقاتل بن سليمان: قوله: <q>﴿ولَوْ نَشاءُ لَجَعَلْنا مِنكُمْ مَلائِكَةً فِي الأَرْضِ يَخْلُفُونَ﴾</q> مكانكم، فكانوا خلفًا منكم{6}٥٨٨٤. (ز) ٥٨٨٤ اختُلف في معنى قوله: <q>﴿يخلفون﴾</q> على أقوال: الأول: يخلُفونكم ليكونوا بدلًا منكم. الثاني: يخلُف بعضُهم بعضًا. والثالث: يخلُفون الرُّسل فيكونون رسلًا إليكم بدلًا منهم. الرابع: يعمرون الارض بدلكم. وذكر ابنُ كثير (١٢/٣٢٢) أنّ القول الثاني الذي قاله ابن عباس، وقتادة، يستلزم القول الأول الذي قاله السُّدّيّ، ومقاتل. ",footnotes:1:أخرجه ابن جرير ٢٠/٦٣٠.تفسير مجاهد ص٥٩٤، وأخرجه ابن جرير ٢٠/٦٣٠. وعزاه السيوطي إلى عبد بن حُمَيد.أخرجه عبد الرزاق ٢/١٩٨، وابن جرير ٢٠/٦٣٠. وعزاه السيوطي إلى عبد بن حُمَيد.أخرجه ابن جرير ٢٠/٦٣٠.أخرجه ابن جرير ٢٠/٦٣١.تفسير مقاتل بن سليمان ٣/٨٠٠.
