quran[13]{c,v,t}:
  43,48,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَمَا نُرِیهِم مِّنۡ ءَایَةٍ إِلَّا هِیَ أَكۡبَرُ مِنۡ أُخۡتِهَاۖ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٩٥٧٧<span class="dash">-</span></span> قال <span class="name-2">الحسن البصري</span>: <span class="qpc-hafs">﴿وما نُرِيهِمْ مِن آيَةٍ إلّا هِيَ أكْبَرُ مِن أُخْتِها﴾</span> كانت اليدُ أكبرَ من العصا{1}<span class=comment-ref>٥٨٧٤</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٥٨٧٤</span> <span class="comment-type-4">قال</span> <u>ابنُ عطية</u> (٧/٥٥٣): "قوله: <span class="qpc-hafs">﴿إلّا هِيَ أكْبَرُ مِن أُخْتِها﴾</span> عبارة عن شِدّة موقعها في نفوسهم بجِدِّة أمرها وحدوثه، وذلك أنّ أول آية عرضها موسى هي: العصا واليد، وكانت أكبر آية، ثم كل آية بعد ذلك كانت تقع فتعظم عندهم لحينها وتكبر؛ لأنهم قد كانوا أُنسُوا التي قبلها، فهذا <span class="mustanad">كما قال الشاعر</span>:</p><p>على أنها تعفو الكلوم وإنما تُوكّل بالأدنى وإن جل ما يقضى".</div></p><p><div></p><p><p><span class="item-no">٦٩٥٧٨<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: يقول الله تعالى: <span class="qpc-hafs">﴿وما نُرِيهِمْ مِن آيَةٍ إلّا هِيَ أكْبَرُ مِن أُخْتِها﴾</span> يعني: اليد بيضاء لها شعاع مثل شعاع الشمس، يغشي البصر، فكانت اليد أكبر من العصا، وكان موسى ﵇ بدأ بالعصا فألقاها، وأخرج يده فلم يؤمنوا{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٩٥٧٩<span class="dash">-</span></span> عن <span class="name-3">عبد الملك ابن جُريْج</span>، في قوله: <span class="qpc-hafs">﴿وما نُرِيهِمْ مِن آيَةٍ إلّا هِيَ أكْبَرُ مِن أُخْتِها﴾</span>، قال: هي الطوفان، وما معه مِن الآيات{3}. (١٣/٢١٥)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَأَخَذۡنَـٰهُم بِٱلۡعَذَابِ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٩٥٨٠<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span>، <span class="qpc-hafs">﴿وأَخَذْناهُمْ بِالعَذابِ﴾</span>، قال: هو عام السَّنَة{4}. (١٣/٢١٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٩٥٨١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: يقول الله تعالى: <span class="qpc-hafs">﴿وأَخَذْناهُمْ بِالعَذابِ﴾</span>، يعني: الطوفان، والجراد، والقُمّل، والضفادع، والدّم، والطّمس، والسّنين{2}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿لَعَلَّهُمۡ یَرۡجِعُونَ ۝٤٨﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٩٥٨٢<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span>، <span class="qpc-hafs">﴿وأَخَذْناهُمْ بِالعَذابِ لَعَلَّهُمْ يَرْجِعُونَ﴾</span>، قال: يتوبون، أو يذَّكَّرون{4}. (١٣/٢١٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٩٥٨٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿لَعَلَّهُمْ يَرْجِعُونَ﴾</span>، يعني: لكي يرجعوا مِن الكفر إلى الإيمان{2}. (ز)</p></p><p></div></p></div>",footnotes:1:ذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٤/١٨٨-.تفسير مقاتل بن سليمان ٣/٧٩٦-٧٩٧.عزاه السيوطي إلى ابن المنذر.عزاه السيوطي إلى عبد بن حميد.تفسير مقاتل بن سليمان ٣/٧٩٦-٧٩٧.عزاه السيوطي إلى عبد بن حميد.تفسير مقاتل بن سليمان ٣/٧٩٦-٧٩٧.
  43,49,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَقَالُوا۟ یَـٰۤأَیُّهَ ٱلسَّاحِرُ ٱدۡعُ لَنَا رَبَّكَ بِمَا عَهِدَ عِندَكَ إِنَّنَا لَمُهۡتَدُونَ ۝٤٩﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٩٥٨٤<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- <span class="qpc-hafs">﴿ادْعُ لَنا رَبَّكَ بِما عَهِدَ عِنْدَكَ﴾</span>: لئن آمَنّا ليُكشَفَنَّ عنّا العذاب{1}. (١٣/٢١٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٩٥٨٥<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- قوله: <span class="qpc-hafs">﴿يا أيُّهَ السّاحِرُ ادْعُ لَنا رَبَّكَ بِما عَهِدَ عِنْدَكَ إنَّنا لَمُهْتَدُونَ﴾</span>، قال: قالوا: يا موسى، ادعُ لنا ربك، لئن كشفتَ عنا الرّجز لنؤمننّ لك{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٩٥٨٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وقالُوا﴾</span> لموسى: <span class="qpc-hafs">﴿يا أيُّهَ السّاحِرُ ادْعُ﴾</span> يقول: سل <span class="qpc-hafs">﴿لَنا رَبَّكَ﴾</span>. فلم يفعل، وقال: تسمّوني ساحرًا! وقال في سورة الأعراف [١٣٤]: <span class="qpc-hafs">﴿ادْعُ لَنا رَبَّكَ بِما عَهِدَ عِنْدَكَ﴾</span> أن يكشف عنا العذاب <span class="qpc-hafs">﴿إنَّنا لَمُهْتَدُونَ﴾</span> يعني: مؤمنين لك. وكان الله تعالى عهد إلى موسى ﵇ لئن آمنوا كشف عنهم، فذلك قوله: <span class="qpc-hafs">﴿بِما عَهِدَ عِنْدَكَ﴾</span> إنْ آمنّا كشف عنا العذاب، فلما دعا موسى ربَّه كشف عنهم، فلم يؤمنوا{3}<span class=comment-ref>٥٨٧٥</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٥٨٧٥</span> <span class="comment-type-4">ذكر</span> <u>ابنُ عطية</u> (٧/٥٥٣) أن قوله تعالى: <span class="qpc-hafs">﴿وقالُوا يا أيُّها السّاحِرُ﴾</span> يحتمل احتمالين: <b>الأول</b>: أن يكون قائل ذلك من أعلمهم بكفر السحرة؛ فيكون قوله استهزاء، وهو يعلم قدر السحر وانحطاط منزلته، ويكون قوله: <span class="qpc-hafs">﴿عِنْدَكَ﴾</span> بمعنى: في زعمك وعلى قولك. <b>الثاني</b>: أن يكون القائل ليس من المتمردين الحذّاق منهم، ويطلق لفظة الساحر لأحد وجهين: <b>إمّا لأن</b> السحر كان عند عامتهم علم الوقت، فكأنه قال: يا أيه العالم. <b>وإما لأنّ</b> هذه الاسمية قد كانت انطلقت عندهم على موسى ﵇ لأول ظهوره، فاستصحبها هذا القائل في مخاطبة قلة تحرير وغباوة، ويكون القول -على هذا التأويل- جدًّا من القائل، ويكون قوله: <span class="qpc-hafs">﴿إنَّنا لَمُهْتَدُونَ﴾</span> بمعنى: إن نفعتنا دعوتك.</p><p>ثم <span class="comment-type-3">رجَّح</span> (٧/٥٥٣-٥٥٤ بتصرف) الاحتمال الثاني <span class="mustanad">مستندًا إلى الدلالة العقلية</span>، فقال: «وهذا التأويل أرجح، أعني: أن كلام هذا القائل مقترن بالجدّ. ثم أخبر عنهم أنه لما كشف عنهم العذاب نكثوا، ولو كان الكلام هزلًا مِن أوله لما وقع نكث».</div></p></div>",footnotes:1:تفسير مجاهد ص٥٩٤، وأخرجه ابن جرير ٢٠/٦٠٩. وعزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ٢٠/٦٠٩-٦١٠.تفسير مقاتل بن سليمان ٣/٧٩٧.
  43,50,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿فَلَمَّا كَشَفۡنَا عَنۡهُمُ ٱلۡعَذَابَ إِذَا هُمۡ یَنكُثُونَ ۝٥٠﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٩٥٨٧<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿إذا هُمْ يَنْكُثُونَ﴾</span>، قال: يغدرون{1}. (١٣/٢١٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٩٥٨٨<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فَلَمّا كَشَفْنا عَنْهُمُ العَذابَ إذا هُمْ يَنْكُثُونَ﴾</span> الذي عاهدوا عليه موسى ﵇: <span class="qpc-hafs">﴿لَئِنْ كَشَفْتَ عَنّا الرِّجْزَ لَنُؤْمِنَنَّ﴾</span> [الأعراف:١٣٤]، فلم يؤمنوا{2}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ٢٠/٦١٠. وعزاه السيوطي إلى عَبد بن حُمَيد.تفسير مقاتل بن سليمان ٣/٧٩٧.
  43,51,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَنَادَىٰ فِرۡعَوۡنُ فِی قَوۡمِهِۦ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٩٥٨٩<span class="dash">-</span></span> عن <span class="name-3">عبد الملك ابن جُريْج</span>، في قوله: <span class="qpc-hafs">﴿ونادى فِرْعَوْنُ فِي قَوْمِهِ﴾</span>، قال: ليس هو نفسه، ولكن أمر أن يُنادى{1}. (١٣/٢١٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٩٥٩٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: قوله: <span class="qpc-hafs">﴿ونادى فِرْعَوْنُ﴾</span> القِبطيُّ <span class="qpc-hafs">﴿فِي قَوْمِهِ﴾</span> القِبط، وكان نداؤه أنّه: <span class="qpc-hafs">﴿قالَ يا قَوْمِ ألَيْسَ لِي مُلْكُ مِصْر وهذِهِ الأَنْهارُ تَجْرِي مِن تَحْتِي أفَلا تُبْصِرُونَ﴾</span>{2}<span class=comment-ref>٥٨٧٦</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٥٨٧٦</span> <span class="comment-type-4">ذكر</span> <u>ابنُ عطية</u> (٧/٥٥٤) أن نداء فرعون <b>يحتمل</b> أن يكون بلسانه في ناديه، و<b>يحتمل</b> أن يكون بأن أمر مَن ينادي في الناس.</div></p><p><h3><span class="qpc-hafs">﴿قَالَ یَـٰقَوۡمِ أَلَیۡسَ لِی مُلۡكُ مِصۡرَ وَهَـٰذِهِ ٱلۡأَنۡهَـٰرُ تَجۡرِی مِن تَحۡتِیۤۚ أَفَلَا تُبۡصِرُونَ ۝٥١﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٩٥٩١<span class="dash">-</span></span> قال <span class="name-1">عبد الله بن عباس</span>: <span class="qpc-hafs">﴿وهَذِهِ الأَنْهارُ تَجْرِي مِن تَحْتِي﴾</span> حولي{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٩٥٩٢<span class="dash">-</span></span> عن <span class="name-2">عطاء</span>: <span class="qpc-hafs">﴿وهَذِهِ الأَنْهارُ تَجْرِي مِن تَحْتِي﴾</span> في قبضتي ومُلكي{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٩٥٩٣<span class="dash">-</span></span> قال <span class="name-2">الحسن البصري</span>: <span class="qpc-hafs">﴿وهَذِهِ الأَنْهارُ تَجْرِي مِن تَحْتِي﴾</span> بأمري{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٩٥٩٤<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿ألَيْسَ لِي مُلْكُ مِصْرَ وهَذِهِ الأَنْهارُ تَجْرِي مِن تَحْتِي﴾</span>، قال: قد كان لهم جِنان وأنهار{6}. (١٣/٢١٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٩٥٩٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿قالَ يا قَوْمِ ألَيْسَ لِي مُلْكُ مِصْرَ﴾</span> أربعين فرسخًا في أربعين فرسخًا، <span class="qpc-hafs">﴿وهذِهِ الأَنْهارُ تَجْرِي مِن تَحْتِي﴾</span> مِن أسفل مِنِّي، <span class="qpc-hafs">﴿أفَلا﴾</span> يعني: فهلّا <span class="qpc-hafs">﴿تُبْصِرُونَ﴾</span> ألهم جنان وأنهار مثلها؟!{2}. (ز)</p></p><p></div></p></div>",footnotes:1:عزاه السيوطي إلى ابن المنذر.تفسير مقاتل بن سليمان ٣/٧٩٧.تفسير الثعلبي ٨/٣٣٩.تفسير الثعلبي ٨/٣٣٩.تفسير الثعلبي ٨/٣٣٩، وتفسير البغوي ٧/٢١٧.أخرجه عبد بن حميد -كما في التغليق ٤/٣٠٨-، وابن جرير ٢٠/٦١٠. وعزاه السيوطي إلى عبد الرزاق.تفسير مقاتل بن سليمان ٣/٧٩٧.
  43,52,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿أَمۡ أَنَا۠ خَیۡرࣱ مِّنۡ هَـٰذَا﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٩٥٩٦<span class="dash">-</span></span> عن النضر، عن هارون، قال: وحدّثني المعتمر بن سليمان التيمي، عن أبيه، عن <span class="name-2">مجاهد</span>، قال: <span class="qpc-hafs">﴿أنا خير من هذا الذي هو مهين﴾</span> أم لا. قال النضر: <span class="qpc-hafs">﴿أم﴾</span> مفتاح الكلام{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٩٥٩٧<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدّيّ</span> -من طريق أسباط- <span class="qpc-hafs">﴿أمْ أنا خَيْرٌ مِن هَذا الَّذِي هُوَ مَهِينٌ﴾</span>، قال: بل أنا خيرٌ مِن هذا{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٩٥٩٨<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثم قال فرعون: <span class="qpc-hafs">﴿أمْ أنا خَيْرٌ﴾</span> يقول: أنا خير <span class="qpc-hafs">﴿مِن هذا﴾</span> يعني: موسى{3}<span class=comment-ref>٥٨٧٧</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٥٨٧٧</span> اختُلف في معنى قوله: <span class="qpc-hafs">﴿أم﴾</span> على قولين: <b>الأول</b>: أنها بمعنى: بل، وأن ذلك خبر لا استفهام. <b>الثاني</b>: أنها للاستفهام، ونسبه <u>ابنُ جرير</u> (٢٠/٦١٢) لبعض نحاة الكوفيين. و<span class="comment-type-3">رجَّحه</span> <span class="mustanad">مستندًا إلى السياق</span>، فقال: «وأولى التأويلات بالكلام إذ كان ذلك كذلك تأويل من جعل <span class="qpc-hafs">﴿أم أنا خير﴾</span> مِن الاستفهام الذي جُعل بـ<span class="qpc-hafs">﴿أم﴾</span>، لاتصاله بما قبله من الكلام، ووجهه إلى أنه بمعنى: أأنا خير من هذا الذي هو مهين أم هو؟ ثم ترك ذكر: أم هو؛ لما في الكلام من الدليل عليه».</p><p>و<span class="comment-type-4">ذكر</span> عن بعض القراء أنه كان يقرأ ذلك: (أمّا أنا خَيْرٌ) بما يوافقه، ولكنه <span class="comment-type-2">انتقد</span> هذه القراءة <span class="mustanad">مستندًا لمخالفتها قراءة الجمهور</span>، و<span class="comment-type-3">رجَّح</span> قراءة الجمهور <span class="qpc-hafs">﴿أم أنا خير﴾</span>، فقال: «ولو كانت هذه القراءة قراءة مستفيضة في قراءة الأمصار لكانت صحيحة، وكان معناها حسنًا، غير أنها خلاف ما عليه قراء الأمصار، فلا أستجيز القراءة بها».</div></p><p><h3><span class="qpc-hafs">﴿ٱلَّذِی هُوَ مَهِینࣱ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٩٥٩٩<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿أمْ أنا خَيْرٌ مِن هَذا الَّذِي هُوَ مَهِينٌ﴾</span>، قال: ضعيف{4}. (١٣/٢١٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٩٦٠٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿الَّذِي هُوَ مَهِينٌ﴾</span>، يعني: ضعيف ذليل{3}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَلَا یَكَادُ یُبِینُ ۝٥٢﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٩٦٠١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، في قوله: <span class="qpc-hafs">﴿ولا يَكادُ يُبِينُ﴾</span>، قال: كانت لموسى لثْغَة في لسانه{6}. (١٣/٢١٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٩٦٠٢<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿ولا يَكادُ يُبِينُ﴾</span>، قال: عَيِيُّ اللسان{4}. (١٣/٢١٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٩٦٠٣<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدّيّ</span> -من طريق أسباط-: <span class="qpc-hafs">﴿ولا يَكادُ يُبِينُ﴾</span> الكلام{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٩٦٠٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ولا يَكادُ يُبِينُ﴾</span> حجّته، يعني: لسانه؛ لأنّ الله تعالى كان أذهب عُقدة لسانه في طه [٢٧] حين قال: <span class="qpc-hafs">﴿واحْلُلْ عُقْدَةً مِن لِسانِي﴾</span>. قال الله تعالى: <span class="qpc-hafs">﴿قَدْ أُوتِيتَ سُؤْلَكَ يا مُوسى﴾</span> [طه:٣٦]{3}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه إسحاق البستي ص٣١٨.أخرجه ابن جرير ٢٠/٦١١.تفسير مقاتل بن سليمان ٣/٧٩٧.أخرجه عبد بن حميد -كما في التغليق ٤/٣٠٨-، وابن جرير ٢٠/٦١٣. وعزاه السيوطي إلى عبد الرزاق.تفسير مقاتل بن سليمان ٣/٧٩٧.عزاه السيوطي إلى ابن المنذر.أخرجه عبد بن حميد -كما في التغليق ٤/٣٠٨-، وابن جرير ٢٠/٦١٣. وعزاه السيوطي إلى عبد الرزاق.أخرجه ابن جرير ٢٠/٦١٣.تفسير مقاتل بن سليمان ٣/٧٩٧.
  43,53,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿فَلَوۡلَاۤ أُلۡقِیَ عَلَیۡهِ أَسۡوِرَةࣱ مِّن ذَهَبٍ﴾</span> - قراءات</h3></p><p><div></p><p><p><span class="item-no">٦٩٦٠٥<span class="dash">-</span></span> قال سفيان الثوري: كان <span class="name-2">أصحابُ عبد الله</span> يقرءونها: ‹أساوِرَةٌ مِّن ذَهَبٍ›{1}<span class=comment-ref>٥٨٧٨</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٥٨٧٨</span> اختُلف في قراءة قوله: <span class="qpc-hafs">﴿أسورة﴾</span>؛ <b>فقرأ قوم</b>: ‹أساوِرَةٌ›. <b>وقرأ غيرهم</b>: <span class="qpc-hafs">﴿أسورة﴾</span>.</p><p>و<span class="comment-type-3">رجَّح</span> <u>ابنُ جرير</u> (٢٠/٦١٤) القراءة الثانية <span class="mustanad">مستندًا لما عليه قرأةُ الأمصار</span>، فقال: «وأولى القراءتين في ذلك بالصواب عندي ما عليه قرأة الأمصار، وإن كانت الأخرى صحيحة المعنى».</p><p>و<span class="comment-type-4">ذكر</span> (٢٠/٦١٥) عن بعض نحاة البصرة أنهم قالوا: الأسورة جمع إسوار، والأساورة جمع الأسورة، وأنّ من قرأ ذلك ‹أساوِرَةٌ› فإنه أراد: أساوير، فجعل الهاء عِوضًا من الياء، مثل: الزنادقة، صارت الهاء فيها عِوضًا من الياء التي في زناديق. ونقل عن بعض نحاة الكوفة أن مَن قرأ ‹أساوِرَةٌ› جعل واحدها: إسوار، ومن قرأ <span class="qpc-hafs">﴿أسورة﴾</span> جعل واحدها: سوار، وأنه قد تكون الأساورة جمع أسورة، كما يقال في جمع الأسقية: الأساقي، وفي جمع الأكرع: الأكارع. ونقل عن بعضهم أنه قال: قد قيل في سوار اليد: يجوز فيه أسوار وإسوار؛ فيجوز على هذه اللغة أن يكون أساورة جمعه، وأنه حكي عن أبي عمرو ابن العلاء أنه كان يقول: واحد الأساورة: إسوار؛ وتصديقه في قراءة أُبي بن كعب: ‹فَلَوْلَآ أُلْقِيَ عَلَيْهِ أساوِرَةٌ مِّن ذَهَبٍ›.</p><p>ثم <span class="comment-type-2">انتقد</span> <u>ابنُ جرير</u> القراءة الأولى <span class="mustanad">مستندًا لمخالفتها لغة العرب</span>، فقال: «فإن كان ما حكي من الرواية من أنه يجوز أن يقال في سوار اليد: إسوار، فلا مؤنة في جمعه: أساورة، ولست أعلم ذلك صحيحًا عن العرب برواية عنها، وذلك أن المعروف في كلامهم من معنى الإسوار: الرجل الرامي، الحاذق بالرمي من رجال العجم. وأما الذي يلبس في اليد فإن المعروف من أسمائه عندهم: سِوارٌ، فإذا كان ذلك كذلك فالذي هو أولى بالأساورة أن يكون جمع أسورة، على ما قاله الذي ذكرنا قوله في ذلك».</div></p><p><h3><span class="qpc-hafs">﴿فَلَوۡلَاۤ أُلۡقِیَ عَلَیۡهِ أَسۡوِرَةࣱ مِّن ذَهَبٍ﴾</span> - تفسير الآية</h3></p><p><div></p><p><p><span class="item-no">٦٩٦٠٦<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطية- قوله: <span class="qpc-hafs">﴿أسْوِرَةٌ مِن ذَهَبٍ﴾</span>، يقول: أقْلِبة من ذهب{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٩٦٠٧<span class="dash">-</span></span> قال <span class="name-2">مجاهد بن جبر</span>: <span class="qpc-hafs">﴿فَلَوْلا أُلْقِيَ عَلَيْهِ أسْوِرَةٌ مِن ذَهَبٍ﴾</span> كانوا إذا سوّدوا رجلًا سوّروه بسوار، وطوّقوه بطَوْقٍ من ذهب؛ ليكون ذلك دلالةً لسيادته، وعلامةً لرياسته، فقال فرعون: هلّا ألقى ربُّ موسى عليه أسورة من ذهب إن كان سيّدًا تجب علينا طاعته{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٩٦٠٨<span class="dash">-</span></span> قال <span class="name-2">الحسن البصري</span>: <span class="qpc-hafs">﴿أسْوِرَةٌ مِن ذَهَبٍ﴾</span> مال من الذّهب{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٩٦٠٩<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- ‹فَلَوْلَآ أُلْقِيَ عَلَيْهِ أساوِرَةٌ مِّن ذَهَبٍ›، قال: أقلِبة من ذهب{5}. (١٣/٢١٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٩٦١٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثم قال فرعون: <span class="qpc-hafs">﴿فَلَوْلا أُلْقِيَ عَلَيْهِ أسْوِرَةٌ مِن ذَهَبٍ﴾</span> يقول: فهلّا ألقى عليه ربُّه الذي أرسله <span class="qpc-hafs">﴿أسْوِرَةٌ مِن ذهب﴾</span> إن كان صادقًا أنّه رسول{6}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿أَوۡ جَاۤءَ مَعَهُ ٱلۡمَلَـٰۤىِٕكَةُ مُقۡتَرِنِینَ ۝٥٣﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٩٦١١<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿أوْ جاءَ مَعَهُ المَلائِكَةُ مُقْتَرِنِينَ﴾</span>، قال: يمشون معًا{7}. (١٣/٢١٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٩٦١٢<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿أوْ جاءَ مَعَهُ المَلائِكَةُ مُقْتَرِنِينَ﴾</span>: أي: متتابعين{8}. (١٣/٢١٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٩٦١٣<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدّيّ</span> -من طريق أسباط- <span class="qpc-hafs">﴿أوْ جاءَ مَعَهُ المَلائِكَةُ مُقْتَرِنِينَ﴾</span>، قال: يُقارِن بعضُهم بعضًا{9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٩٦١٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿أوْ جاءَ مَعَهُ المَلائِكَةُ مُقْتَرِنِينَ﴾</span>، يعني: متعاونين، يعينونه على أمره الذي بُعث إليه{6}<span class=comment-ref>٥٨٧٩</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٥٨٧٩</span> <span class="comment-type-4">ذكر</span> <u>ابنُ جرير</u> (٢٠/٦١٥) أن معنى قوله: <span class="qpc-hafs">﴿أو جاء معه الملائكة مقترنين﴾</span>: أو هلّا إن كان صادقًا جاء معه الملائكة مقترنين قد اقترن بعضهم ببعض، فتتابعوا يشهدون له بأنه لله رسول إليهم. ثم قال (٢٠/٦١٦): «<span class="mustanad">وبنحو الذي قلنا في ذلك قال أهل التأويل</span> على اختلاف منهم في العبارة على تأويله». وساق الأقوال.</div></p></div>",footnotes:1:تفسير سفيان الثوري ص٢٧٢.</p><p>وهي قراءة متواترة، قرأ بها العشرة، ما عدا يعقوب وحفصًا، فإنهما قرآ: <span class="qpc-hafs">﴿أسْوِرَةٌ﴾</span>. انظر: النشر ٢/٣٦٩، والإتحاف ص٤٩٦.أخرجه ابن جرير ٢٠/٦١٤.تفسير الثعلبي ٨/٣٣٩، وتفسير البغوي ٧/٢١٧.ذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٤/١٨٨-.أخرجه عبد بن حميد -كما في التغليق ٤/٣٠٨-، وابن جرير ٢٠/٦١٤. وعزاه السيوطي إلى عبد الرزاق.تفسير مقاتل بن سليمان ٣/٧٩٨.تفسير مجاهد ص٥٩٤، وأخرجه ابن جرير ٢٠/٦١٦، والفريابي -كما في تغليق التعليق ٤/٣٠٧، والفتح ٨/٥٦٧-. وعزاه السيوطي إلى عَبد بن حُمَيد.أخرجه عبد الرزاق ٢/١٩٧ من طريق معمر، وعبد بن حميد -كما في التغليق ٤/٣٠٨-، وابن جرير ٢٠/٦١٦ من طريق معمر أيضًا.أخرجه ابن جرير ٢٠/٦١٦.تفسير مقاتل بن سليمان ٣/٧٩٨.
  43,54,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿فَٱسۡتَخَفَّ قَوۡمَهُۥ فَأَطَاعُوهُۚ إِنَّهُمۡ كَانُوا۟ قَوۡمࣰا فَـٰسِقِینَ ۝٥٤﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٩٦١٥<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span> -من طريق أبي سعيد- قال: لم يُخرج فرعون مَن زاد على الأربعين سنة ومَن دون العشرين، فذلك قوله: <span class="qpc-hafs">﴿فاسْتَخَفَّ قَوْمَهُ فَأَطاعُوهُ﴾</span>، يعني: استخفّ قومه في طلب موسى ﵇{1}. (١٣/٢١٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٩٦١٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فاسْتَخَفَّ قَوْمَهُ﴾</span> يقول: استفزّ قومَه القِبط، <span class="qpc-hafs">﴿فَأَطاعُوهُ﴾</span> في الذي قال لهم على التكذيب، حين قال لهم: <span class="qpc-hafs">﴿ما أُرِيكُمْ إلّا ما أرى وما أهْدِيكُمْ إلّا سَبِيلَ الرَّشادِ﴾</span> [غافر:٢٩] فأطاعوه في الذي قال لهم، <span class="qpc-hafs">﴿إنَّهُمْ كانُوا قَوْمًا فاسِقِينَ﴾</span> يعني: عاصين{2}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿فَٱسۡتَخَفَّ قَوۡمَهُۥ فَأَطَاعُوهُۚ إِنَّهُمۡ كَانُوا۟ قَوۡمࣰا فَـٰسِقِینَ ۝٥٤﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٦٩٦١٧<span class="dash">-</span></span> قال <span class="name-1">أبو الدَّرداء</span> -من طريق بلال بن سعد-: لو كانت الدّنيا تَزِنُ عند الله جناحَ ذباب ما سقى فرعونَ منها شرابًا{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٩٦١٨<span class="dash">-</span></span> عن الأسود بن يزيد، قال: قلت <span class="name-1">لعائشة</span>: ألا تعجبين مِن رجل من الطُّلقاء ينازع أصحاب محمد في الخلافة؟! قالت: وما تعجب مِن ذلك، هو سلطان الله يؤتيه البرّ والفاجر، وقد مَلك فرعون أهل مصر أربعمائة سنة{4}. (١٣/٢١٥)</p></p><p></div></p></div>",footnotes:1:أخرجه عبد الحكم في فتوح مصر ص٢٣.تفسير مقاتل بن سليمان ٣/٧٩٨.أخرجه الثعلبي ٨/٣٣٩.عزاه السيوطي إلى ابن أبي حاتم.
  43,55,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿فَلَمَّاۤ ءَاسَفُونَا ٱنتَقَمۡنَا مِنۡهُمۡ فَأَغۡرَقۡنَـٰهُمۡ أَجۡمَعِینَ ۝٥٥﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٩٦١٩<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- في قوله: <span class="qpc-hafs">﴿فَلَمّا آسَفُونا﴾</span>، قال: أسْخَطونا{1}. (١٣/٢١٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٩٦٢٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطية- في قوله: <span class="qpc-hafs">﴿آسَفُونا﴾</span>، قال: أغضبونا{2}. (١٣/٢١٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٩٦٢١<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿فَلَمّا آسَفُونا﴾</span>، قال: أغضبونا{3}. (١٣/٢١٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٩٦٢٢<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span>، <span class="qpc-hafs">﴿فَلَمّا آسَفُونا﴾</span>، قال: أغضبونا{4}. (١٣/٢١٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٩٦٢٣<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق المبارك بن فَضالة- في قوله: <span class="qpc-hafs">﴿فلما آسفونا﴾</span>، قال: أغضبونا{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٩٦٢٤<span class="dash">-</span></span> عن <span class="name-2">وهْب بن مُنَبِّه</span> -من طريق سماك بن الفضل- في قوله: <span class="qpc-hafs">﴿فلما آسفونا انتقمنا منهم﴾</span>، قال: أغضبونا{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٩٦٢٥<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- <span class="qpc-hafs">﴿فَلَمّا آسَفُونا﴾</span>، قال: أغضبونا{7}. (١٣/٢١٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٩٦٢٦<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدّيّ</span> -من طريق أسباط- <span class="qpc-hafs">﴿فلما آسفونا﴾</span> قال: أغضبونا، وهو على قول يعقوب: <span class="qpc-hafs">﴿يا أسَفى عَلى يُوسُفَ﴾</span> [يوسف:٨٤]، قال: يا حَزني على يوسف{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٩٦٢٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فَلَمّا آسَفُونا﴾</span> يعني: أغضبونا <span class="qpc-hafs">﴿انْتَقَمْنا مِنهُمْ فَأَغْرَقْناهُمْ أجْمَعِينَ﴾</span> لَم ينجُ منهم أحدٌ{9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٩٦٢٨<span class="dash">-</span></span> قال <span class="name-3">سفيان الثوري</span>: <span class="qpc-hafs">﴿فَلَمّا آسَفُونا﴾</span> أغضبونا{10}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٩٦٢٩<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿فَلَمّا آسَفُونا انْتَقَمْنا مِنهُمْ﴾</span>، قال: أغضبونا{8}<span class=comment-ref>٥٨٨٠</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٥٨٨٠</span> <span class="comment-type-4">ذكر</span> <u>ابنُ عطية</u> (٧/٥٥٦) أن هذا هو تفسير قوله: <span class="qpc-hafs">﴿آسفونا﴾</span> بلا خلاف.</div></p><p><h3><span class="qpc-hafs">﴿فَلَمَّاۤ ءَاسَفُونَا ٱنتَقَمۡنَا مِنۡهُمۡ فَأَغۡرَقۡنَـٰهُمۡ أَجۡمَعِینَ ۝٥٥﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٦٩٦٣٠<span class="dash">-</span></span> عن عُقبة بن عامر، أنّ رسول الله ﷺ قال: «<b>إذا رأيتَ الله يُعطي العبدَ ما شاء وهو مُقيم على معاصيه؛ فإنّما ذلك استِدْراجٌ مِنه له»</b>. ثم تلا: <b><span class="qpc-hafs">﴿فَلَمّا آسَفُونا انْتَقَمْنا مِنهُمْ فَأَغْرَقْناهُمْ أجْمَعِينَ﴾</span></b>{12}. (١٣/٢١٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٩٦٣١<span class="dash">-</span></span> عن طارق بن شهاب، قال: كنت عند <span class="name-1">عبد الله</span>، فذُكر عنده موت الفَجأة، فقال: تخفيف على المؤمن، وحسرة على الكافر؛ <span class="qpc-hafs">﴿فَلَمّا آسَفُونا انْتَقَمْنا مِنهُمْ﴾</span>{13}. (١٣/٢١٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٩٦٣٢<span class="dash">-</span></span> عن محمد بن كناسة، قال: سمعتُ <span class="name-3">عمر بن ذر</span> يقول: آنَسَك جانبُ حِلمه فتوثّبتَ على معاصيه، أفأسَفه تريد؟ أما سمعَته يقول: <span class="qpc-hafs">﴿فلما آسفونا انتقمنا منهم فأغرقناهم﴾</span>؟ أيها الناس، أجِلُّوا مقامَ الله بالتنُزُّه عما لا يحلّ، فإنّ الله لا يُؤمَن إذا عُصي{14}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ٢٠/٦١٧، وابن أبي حاتم -كما في تغليق التعليق ٤/٣٠٦، والفتح ٨/٥٦٦-.أخرجه ابن جرير ٢٠/٦١٧. وعزاه السيوطي إلى ابن أبي حاتم.تفسير مجاهد ص٥٩٤، وأخرجه ابن جرير ٢٠/٦١٧-٦١٨، والفريابي -كما في تغليق التعليق ٤/٣٠٧، والفتح ٨/٥٦٧-. وعزاه السيوطي إلى عَبد بن حُمَيد، وابن المنذر.عزاه السيوطي إلى عبد بن حميد.أخرجه أبو حاتم الرازي في الزهد ص٤٢.أخرجه ابن عساكر في تاريخ دمشق ٤٠/٢٩٢.أخرجه عبد الرزاق ٢/١٩٧، وعبد بن حميد -كما في التغليق ٤/٣٠٨-، وابن جرير ٢٠/٦١٨، ومن طريق سعيد بلفظ: أغضبوا ربهم.أخرجه ابن جرير ٢٠/٦١٨.تفسير مقاتل بن سليمان ٣/٧٩٨.تفسير سفيان الثوري ص٢٧٢.أخرجه ابن جرير ٢٠/٦١٨.أخرجه الروياني في مسنده ١/١٩٥ (٢٦٠)، وابن أبي حاتم ١٠/٣٢٨٣، من طريق عبد الله بن لهيعة، عن عقبة بن مسلم التجيبي، عن عقبة بن عامر به، وفيه ابن لهيعة، وهو ضعيف.</p><p>لكنه توبع بما رواه الخرائطي في فضيلة شكر الله ص٥٧، من طريق حرملة بن عمران، عن عقبة بن مسلم، عن عقبة بن عامر به؛ فالحديث حسن لغيره.عزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.أخرجه أبو نعيم في حلية الأولياء ٥/١١١.
  43,56,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿فَجَعَلۡنَـٰهُمۡ سَلَفࣰا﴾</span> - قراءات</h3></p><p><div></p><p><p><span class="item-no">٦٩٦٣٣<span class="dash">-</span></span> عن <span class="name-2">سعد بن عياض</span>، أنّه قرأ: ‹سُلُفًا› برفع السين واللام{1}. (١٣/٢١٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٩٦٣٤<span class="dash">-</span></span> عن <span class="name-2">عاصم</span>، أنه كان يقرأ: <span class="qpc-hafs">﴿فَجَعَلْناهُمْ سَلَفًا﴾</span> بنصب السين واللام{2}<span class=comment-ref>٥٨٨١</span>. (١٣/٢١٨)</p></p><p></div></p><p><div><span class=comment-ref>٥٨٨١</span> اختُلف في في قراءة قوله: <span class="qpc-hafs">﴿سلفا﴾</span>؛ <b>فقرأ قوم</b>: ‹سُلُفًا›، <b>وقرأ آخرون</b>: <span class="qpc-hafs">﴿سَلَفًا﴾</span>، <b>وقرأ غيرهم</b>: (سُلَفًا).</p><p>و<span class="comment-type-4">ذكر</span> <u>ابنُ جرير</u> (٢٠/٦١٩) أن قراءة ضم السين واللام هي: جمع سليف من الناس، وهو المتقدم أمام القوم، وأن القراءة بفتح السين واللام يحتمل أن يكون مرادًا بها الجماعة والواحد والذكر والأنثى، لأنه يقال للقوم: أنتم لنا سلف، وقد يجمع فيقال: هم أسلاف، <span class="mustanad">ومنه الخبر الذي روي عن رسول الله</span> ﷺ أنه قال: «<b>يذهب الصالحون أسلافًا</b>». و<span class="comment-type-4">ذكر</span> أنّ قراءة ضم السين وفتح اللام هي: جمع سُلْفة من الناس، مثل أمّة منهم وقِطعة.</p><p>و<span class="comment-type-4">بنحوه</span> قال <u>ابنُ عطية</u> (٧/٥٥٦).</p><p>و<span class="comment-type-3">رجَّح</span> <u>ابنُ جرير</u> قراءة فتح السين واللام <span class="mustanad">مستندًا إلى أنها الأجود في لغة العرب</span>، فقال: «وأولى القراءات في ذلك بالصواب قراءةُ مَن قرأه بفتح السين واللام؛ لأنها اللغة الجُودى، والكلام المعروف عند العرب، وأحقُّ اللغات أن يقرأ بها كتاب الله من لغات العرب أفصحها وأشهرها فيهم».</div></p><p><h3><span class="qpc-hafs">﴿فَجَعَلۡنَـٰهُمۡ سَلَفࣰا﴾</span> - تفسير الآية</h3></p><p><div></p><p><p><span class="item-no">٦٩٦٣٥<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطية- في قوله: <span class="qpc-hafs">﴿سَلَفًا﴾</span>، قال: أهواء مختلفة{3}. (١٣/٢١٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٩٦٣٦<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿فَجَعَلْناهُمْ سَلَفًا﴾</span>، قال: هم قوم فرعون، كفارهم سلفًا لكفار أمة محمد{4}. (١٣/٢١٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٩٦٣٧<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- <span class="qpc-hafs">﴿فَجَعَلْناهُمْ سَلَفًا﴾</span>، قال: إلى النار{5}. (١٣/٢١٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٩٦٣٨<span class="dash">-</span></span> عن <span class="name-2">عطاء الخُراساني</span> -من طريق يونس بن يزيد- في قوله تعالى: <span class="qpc-hafs">﴿فجعلناهم سلفا ومثلا للآخرين﴾</span>، قال: جُعِلوا سلفًا في الناس{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٩٦٣٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فَجَعَلْناهُمْ سَلَفًا﴾</span>، يعني: مَضَوا في العذاب{7}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَمَثَلࣰا لِّلۡـَٔاخِرِینَ ۝٥٦﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٩٦٤٠<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿ومَثَلًا لِلْآخِرِينَ﴾</span>، قال: عِبرةً لِمَن بعدهم{8}. (١٣/٢١٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٩٦٤١<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿ومَثَلًا لِلْآخِرِينَ﴾</span>، قال: عِظَةً لِمَن بعدهم{9}. (١٣/٢١٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٩٦٤٢<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدّيّ</span> -من طريق أسباط- <span class="qpc-hafs">﴿فَجَعَلْناهُمْ سَلَفًا ومَثَلًا﴾</span>، قال: عبرةً{10}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٩٦٤٣<span class="dash">-</span></span> عن <span class="name-2">عطاء الخُراساني</span> -من طريق يونس بن يزيد- في قوله تعالى: <span class="qpc-hafs">﴿ومثلا للآخرين﴾</span>، قال: ومَثلًا لِمَن بعدهم مِن القرون{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٩٦٤٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ومَثَلًا لِلْآخِرِينَ﴾</span>، يعني: عِبرةً لِمَن بعدهم{7}. (ز)</p></p><p></div></p></div>",footnotes:1:عزاه السيوطي إلى عبد بن حميد.</p><p>وهي قراءة متواترة، قرأ بها حمزة، والكسائي، وقرأ بقية العشرة: <span class="qpc-hafs">﴿سَلَفًا﴾</span> بفتح السين واللام. انظر: النشر ٢/٣٦٩، والإتحاف ص٤٩٦.عزاه السيوطي إلى عبد بن حميد.عزاه السيوطي إلى ابن جرير، وابن أبي حاتم.تفسير مجاهد ص٥٩٤، وأخرجه الفريابي -كما في تغليق التعليق ٤/٣٠٧، والفتح ٨/٥٦٧-، وابن جرير ٢٠/٦٢٠. وذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٤/١٨٨-. وعزاه السيوطي إلى عَبد بن حُمَيد، وابن المنذر.أخرجه عبد الرزاق ٢/١٩٧، وعبد بن حميد -كما في التغليق ٤/٣٠٨-، وابن جرير ٢٠/٦٢٠.أخرجه أبو جعفر الرملي في جزئه (تفسير عطاء) ص٩٢.تفسير مقاتل بن سليمان ٣/٧٩٨.تفسير مجاهد ص٥٩٤، وأخرجه الفريابي -كما في تغليق التعليق ٤/٣٠٧، والفتح ٨/٥٦٧-، وابن جرير ٢٠/٦٢٠. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه عبد الرزاق ٢/١٩٧ من طريق معمر بنحوه، وعبد بن حميد -كما في التغليق ٤/٣٠٨-، وابن جرير ٢٠/٦٢١، ومن طريق معمر أيضًا.أخرجه ابن جرير ٢٠/٦٢١.أخرجه أبو جعفر الرملي في جزئه (تفسير عطاء) ص٩٢.تفسير مقاتل بن سليمان ٣/٧٩٨.
  43,57,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَلَمَّا ضُرِبَ ٱبۡنُ مَرۡیَمَ مَثَلًا إِذَا قَوۡمُكَ مِنۡهُ یَصِدُّونَ ۝٥٧﴾</span> - قراءات</h3></p><p><div></p><p><p><span class="item-no">٦٩٦٤٥<span class="dash">-</span></span> عن علي بن أبي طالب: سمعتُ النبيَّ يقرأ: <span class="qpc-hafs">﴿يَصِدُّونَ﴾</span> بالكسر{1}. (١٣/٢٢١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٩٦٤٦<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> –من طريق أبي يحيى- أنه كان يقرؤها: <span class="qpc-hafs">﴿يَصِدُّونَ﴾</span>، يعني: بكسر الصاد{2}. (١٣/٢٢٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٩٦٤٧<span class="dash">-</span></span> عن <span class="name-2">أبي عبد الرحمن السُّلَمِيّ</span>، أنّه قرأ: ‹يَصُدُّونَ› بضم الصاد{3}. (١٣/٢٢٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٩٦٤٨<span class="dash">-</span></span> عن سعيد بن معبد ابن أخي <span class="name-2">عُبيد بن عمير الليثي</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٩٦٤٩<span class="dash">-</span></span> قال: قال لي <span class="name-1">ابن عباس</span>: ما لِعمِّك يقرأ هذه الآية: ‹إذا قَوْمُكَ مِنهُ يَصُدُّونَ›؟! إنها ليست كذا، إنما هي <span class="qpc-hafs">﴿إذا قَوْمُكَ مِنهُ يَصِدُّونَ﴾</span> إذا هم يعجّون، إذا هم يصيحون{4}<span class=comment-ref>٥٨٨٢</span>. (١٣/٢٢٠)</p></p><p></div></p><p><div><span class=comment-ref>٥٨٨٢</span> اختُلف في قراءة قوله: <span class="qpc-hafs">﴿يصدون﴾</span>؛ <b>فقرأ قوم</b>: بضم الصاد، و<b>قرأ غيرهم</b> بكسرها.</p><p>و<span class="comment-type-4">ذكر</span> <u>ابنُ جرير</u> (٢٠/٦٢٣) أنه اختلف في الفرق بين الضم والكسر، فذهب قوم إلى أنهما لغتان بمعنى واحد، مثل يشُد ويشِد، وقال غيرهم بأن مَن كَسر الصاد فمجازها: يضجون، ومن ضمها فمجازها: يعدلون. وذهب قوم إلى أن من كسرها فإنه أراد: يضجون، ومن ضمها فإنه أراد: الصدود عن الحق.</p><p>وبنحوه قال <u>ابنُ عطية</u> (٧/٥٥٧).</p><p>ثم <span class="comment-type-3">رجَّح</span> <u>ابنُ جرير</u> (٢٠/٦٢٤) صحة كلتا القراءتين <span class="mustanad">مستندًا إلى شهرتهما، واتحاد معناهما</span>، فقال: «والصواب من القول في ذلك أنهما قراءتان معروفتان، ولغتان مشهورتان بمعنًى واحد، ولم نجد أهل التأويل فرّقوا بين معنى ذلك إذا قُرئ بالضم والكسر، ولو كان مختلفًا معناه لقد كان الاختلاف في تأويله بين أهله موجودًا وجود اختلاف القراءة فيه باختلاف اللغتين، ولكن لما لم يكن مختلف المعنى لم يختلفوا في أن تأويله: يضجون ويجزعون، فبأي القراءتين قرأ القارئ فمصيب».</div></p><p><h3><span class="qpc-hafs">﴿وَلَمَّا ضُرِبَ ٱبۡنُ مَرۡیَمَ مَثَلًا إِذَا قَوۡمُكَ مِنۡهُ یَصِدُّونَ ۝٥٧﴾</span> - نزول الآية</h3></p><p><div></p><p><p><span class="item-no">٦٩٦٥٠<span class="dash">-</span></span> عن أبي يحيى مولى ابن عقيل الأنصاري، عن عبد الله بن عباس، أنّ رسول الله ﷺ قال لقريش: «<b>إنّه ليس أحد يُعبَد من دون الله فيه خير»</b>. فقالوا: ألست تزعم أنّ عيسى كان نبيًّا وعبدًا مِن عباد الله صالحًا وقد عَبَدَتْهُ النصارى! فإن كنتَ صادقًا فإنه كآلهتهم. فأنزل الله: <span class="qpc-hafs">﴿ولَمّا ضُرِبَ ابْنُ مَرْيَمَ مَثَلًا إذا قَوْمُكَ مِنهُ يَصِدُّونَ﴾</span>. قلت: ما يصدون؟ قال: يضجّون{5}. (١٣/٢١٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٩٦٥١<span class="dash">-</span></span> قال <span class="name-3">محمد بن السّائِب الكلبي</span>: لما نزلت: <span class="qpc-hafs">﴿إنَّكُمْ وما تَعْبُدُونَ مِن دُونِ اللَّهِ حَصَبُ جَهَنَّمَ أنْتُمْ لَها وارِدُونَ﴾</span> [الأنبياء:٩٨] قام رسول الله مقابل باب الكعبة، ثم اقترأ هذه الآية، فوجد منها أهل مكة وجْدًا شديدًا، فدخل عليهم ابن الزِّبَعْرى الشاعر وقريشٌ يخوضون في ذِكر هذه الآية، فقال: أمحمد تكلّم بهذه؟ قالوا: نعم. قال: واللهِ، إن اعترف لي بهذا لأخصمنه. فلَقِيه، فقال: يا محمد، أرأيتَ الآية التي قرأتَ آنفًا، أفينا وفي آلهتنا نزلت خاصّة أم في الأمم وآلهتهم؟ قال: «<b>لا، بل فيكم وفي آلهتكم، وفي الأمم وآلهتهم»</b>. فقال: خصمتُك، وربِّ الكعبة، أليس تُثْنِي على عيسى ومريم والملائكة خيرًا، وقد علمتَ أنّ النصارى تعبد عيسى وأمه، وأنّ طائفة من الناس يعبدون الملائكة، أفليس هؤلاء مع آلهتنا في النار؟! فسكتَ رسولُ الله، وضحكتْ قريش وضجّوا{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٩٦٥٢<span class="dash">-</span></span> وعن <span class="name-3">محمد بن إسحاق</span>، نحوه{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٩٦٥٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ولَمّا ضُرِبَ ابْنُ مَرْيَمَ مَثَلًا﴾</span> المثل: حين زعموا أنّ الملائكة بنات الله، وذلك أنّ النبي ﷺ دخل المسجد وحول الكعبة ثلاثمائة وستون صنمًا، وفي المسجد العاص بن وائل السهمي، والحارث وعدي ابنا قيس، كلهم مِن قريش من بني سهم، فقال لهم النبي ﷺ: <span class="qpc-hafs">﴿إنَّكُمْ وما تَعْبُدُونَ مِن دُونِ اللَّهِ حَصَبُ جَهَنَّمَ أنْتُمْ لَها وارِدُونَ﴾</span> [الأنبياء:٩٨] إلى آيتين. ثم خرج إلى باب الصفا، فخاض المشركون في ذلك، فدخل عبد الله بن الزِّبَعْرى السهمي، فقال: تخوضون في ذكر الآلهة! فذكروا له ما قال النبيُّ ﷺ لهم ولآلهتهم، فقال عبد الله بن الزبعرى: يا محمد، أخاصّة لنا ولآلهتنا؟ أم لنا ولآلهتنا ولجميع الأمم وآلهتهم؟ فقال النبي ﷺ: «<b>بل هي لكم ولآلهتكم، ولجميع الأمم ولآلهتهم»</b>. فقال عبد الله: خصمتُك، وربِّ الكعبة؛ ألست تزعم أنّ عيسى ابن مريم نبيٌّ وتُثْنِي عليه وعلى أُمّه خيرًا، وقد علمتَ أنّ النصارى يعبدونهما؟! وعُزير يُعبد، والملائكة تُعبد، فإن كان هؤلاء في النار فقد رضينا أن نكون معهم. فقال النبي ﷺ: «<b>لا»</b>. فقال عبد الله: أليس قد زعمتَ أنها لنا ولآلهتنا ولجميع الأمم وآلهتهم؟! خصمتُك، وربّ الكعبة. فضجّوا من ذلك؛ فأنزل الله تعالى: <span class="qpc-hafs">﴿إنَّ الَّذِينَ سَبَقَتْ لَهُمْ مِنّا الحُسْنى﴾</span> يعني: الملائكة، وعُزيز، وعيسى، ومريم <span class="qpc-hafs">﴿أُولئِكَ عَنْها مُبْعَدُونَ﴾</span>. وأنزل: <span class="qpc-hafs">﴿ولَمّا ضُرِبَ ابْنُ مَرْيَمَ مَثَلًا إذا قَوْمُكَ مِنهُ يَصِدُّونَ﴾</span>{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٩٦٥٤<span class="dash">-</span></span> عن عيسى بن عبد الله بن محمد بن عمر بن علي بن أبي طالب، عن أبيه، عن جَده، عن عليٍّ، قال: جئتُ رسولَ الله ﷺ يومًا في ملأٍ مِن قريش، فنظر إلَيَّ، وقال: «<b>يا علي، إنما مَثلك في هذه الأمة كمَثل عيسى ابن مريم؛ أحبّه قومٌ فأفرطوا فيه، وأبغضه قوم فأفرطوا فيه»</b>. قال: فضحك الملأُ الذين عنده، وقالوا: انظروا كيف يشبّه ابنَ عمه بعيسى! فأنزل الله القرآن: <span class="qpc-hafs">﴿ولما ضرب ابن مريم مثلا اذا قومك منه يصدون﴾</span>{9}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَلَمَّا ضُرِبَ ٱبۡنُ مَرۡیَمَ مَثَلًا إِذَا قَوۡمُكَ مِنۡهُ یَصِدُّونَ ۝٥٧﴾</span> - تفسير الآية</h3></p><p><div></p><p><p><span class="item-no">٦٩٦٥٥<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- <span class="qpc-hafs">﴿يَصِدُّونَ﴾</span>: يضجّون{10}. (١٣/٢٢٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٩٦٥٦<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق سعيد بن معبد- قال: <span class="qpc-hafs">﴿إذا قَوْمُكَ مِنهُ يَصِدُّونَ﴾</span> إذا هم يَعِجُّون، إذا هم يصيحون{4}. (١٣/٢٢٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٩٦٥٧<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق أبي رَزين- <span class="qpc-hafs">﴿يَصِدُّونَ﴾</span>: يضحكون{12}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٩٦٥٨<span class="dash">-</span></span> قال <span class="name-2">سعيد بن المسيّب</span>: <span class="qpc-hafs">﴿يَصِدُّونَ﴾</span> يصيحون{13}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٩٦٥٩<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span>، <span class="qpc-hafs">﴿إذا قَوْمُكَ مِنهُ يَصِدُّونَ﴾</span>، قال: يصيحون{14}. (١٣/٢٢٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٩٦٦٠<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٩٦٦١<span class="dash">-</span></span> و<span class="name-2">الحسن البصري</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٩٦٦٢<span class="dash">-</span></span> و<span class="name-2">قتادة بن دعامة</span>، مثله{14}. (١٣/٢٢٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٩٦٦٣<span class="dash">-</span></span> عن <span class="name-2">إبراهيم النَّخْعي</span>، <span class="qpc-hafs">﴿يَصِدُّونَ﴾</span>، قال: يُعرضون{4}. (١٣/٢٢٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٩٦٦٤<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- قال: <span class="qpc-hafs">﴿يَصِدُّونَ﴾</span> يضِجُّون{17}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٩٦٦٥<span class="dash">-</span></span> قال <span class="name-2">الضَّحّاك بن مُزاحِم</span>: <span class="qpc-hafs">﴿إذا قَوْمُكَ مِنهُ يَصِدُّونَ﴾</span> يَعِجُّون{13}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٩٦٦٦<span class="dash">-</span></span> عن <span class="name-2">الضَّحّاك بن مُزاحِم</span> -من طريق عبيد- <span class="qpc-hafs">﴿يَصِدُّونَ﴾</span>، قال: يضِجُّون{19}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٩٦٦٧<span class="dash">-</span></span> عن <span class="name-2">يحيى بن وثّاب</span> -من طريق الأعمش- قال: <span class="qpc-hafs">﴿يَصِدُّونَ﴾</span> يُعرضون{12}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٩٦٦٨<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿إذا قَوْمُكَ مِنهُ يَصِدُّونَ﴾</span>: أي: يجزعون، ويضجّون{21}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٩٦٦٩<span class="dash">-</span></span> قال <span class="name-2">محمد بن كعب القُرَظي</span>: <span class="qpc-hafs">﴿إذا قَوْمُكَ مِنهُ يَصِدُّونَ﴾</span> يضجرون{13}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٩٦٧٠<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدّيّ</span> -من طريق أسباط- <span class="qpc-hafs">﴿إذا قَوْمُكَ مِنهُ يَصِدُّونَ﴾</span>، قال: يضِجُّون{19}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٩٦٧١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿إذا قَوْمُكَ مِنهُ يَصِدُّونَ﴾</span>، يعني: يضجّون تعجّبًا لذكر عيسى ﵇؛ عبد الله ابن الزِّبَعْرى وأصحابه، هم هؤلاء النفر{24}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٩٦٧٢<span class="dash">-</span></span> عن <span class="name-3">سفيان بن عُيَينة</span> -من طريق ابن أبي عمر- في قوله: <span class="qpc-hafs">﴿يصِدّون﴾</span>، قال: يضِجُّون{25}. (ز)</p></p><p></div></p></div>",footnotes:1:عزاه السيوطي إلى ابن مردويه.</p><p>وهي قراءة متواترة، قرأ بها ابن كثير، وأبو عمرو، ويعقوب، وعاصم، وحمزة، وقرأ بقية العشرة: ‹يَصُدُّونَ› بضم الصاد. انظر: النشر ٢/٣٦٩، والإتحاف ص٤٩٦.أخرجه عبد الرزاق ٢/١٩٨ من طريق أبي رزين، وابن جرير ٢٠/٦٢٤. وعزاه السيوطي إلى الفريابي، وسعيد بن منصور، وعَبد بن حُمَيد، وابن المنذر، وابن مردويه.أخرجه عبد الرزاق ٢/١٩٧-١٩٨. وعزاه السيوطي إلى عَبد بن حُمَيد.عزاه السيوطي إلى عَبد بن حُمَيد، وابن المنذر.أخرجه أحمد ٥/٨٥-٨٦ (٢٩١٨)، وابن أبي حاتم -كما في تفسير ابن كثير ٧/٢٣٤-.</p><p>قال الهيثمي في المجمع ٧/١٠٤ (١١٣٣١): «رواه أحمد والطبراني ... وفيه عاصم بن بهدلة، وثّقه أحمد وغيره، وهو سيّئ الحفظ، وبقيّة رجاله رجال الصحيح». وأورده الألباني في الصحيحة ٧/٦٣٢ (٣٢٠٨).ذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٤/١٨٩-١٩٠-.سيرة ابن هشام ١/٣٥٩.تفسير مقاتل بن سليمان ٣/٧٩٨-٧٩٩.أخرجه ابن حبان في المجروحين ٢/١٢١، وابن الجوزي في العلل المتناهية ١/٢٢٤ (٣٥٨)، وفيه عيسى بن عبد الله بن محمد بن عمر بن علي بن أبي طالب.</p><p>قال ابن حبان في ترجمة عيسى بن عبد الله: «يروي عن أبيه عن آبائه أشياء موضوعة، لا يَحِلُّ الاحتجاج به». قال ابن القيسراني في تذكرة الحفاظ ص١٤١ (٣٢٨): «عيسى هذا عنده نسخة موضوعة بهذا الإسناد».أخرجه عبد الرزاق ٢/١٩٨ من طريق أبي رزين، وابن جرير ٢٠/٦٢٤، ٦٢٥، ٦٢٦، ومن طريق العوفي، وأبي يحيى، وأبي رزين، والصعب بن عثمان، وأبي صالح. وعزاه السيوطي إلى الفريابي، وسعيد بن منصور، وعَبد بن حُمَيد، وابن المنذر، وابن مردويه.عزاه السيوطي إلى عَبد بن حُمَيد، وابن المنذر.أخرجه سفيان الثوري ص٢٧٣.تفسير الثعلبي ٨/٣٤٠، وتفسير البغوي ٧/٢١٨.عزاه السيوطي إلى عَبد بن حُمَيد.عزاه السيوطي إلى عَبد بن حُمَيد.عزاه السيوطي إلى عَبد بن حُمَيد، وابن المنذر.تفسير مجاهد ص٥٩٤، وأخرجه سفيان الثوري ص٢٧٣، والفريابي -كما في تغليق التعليق ٤/٣٠٧-، وابن جرير ٢٠/٦٢٤.تفسير الثعلبي ٨/٣٤٠، وتفسير البغوي ٧/٢١٨.أخرجه ابن جرير ٢٠/٦٢٦.أخرجه سفيان الثوري ص٢٧٣.أخرجه ابن جرير ٢٠/٦٢٥.تفسير الثعلبي ٨/٣٤٠، وتفسير البغوي ٧/٢١٨.أخرجه ابن جرير ٢٠/٦٢٦.تفسير مقاتل بن سليمان ٣/٧٩٩.أخرجه إسحاق البستي ص٣١٩.
  43,58,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَقَالُوۤا۟ ءَأَ ٰ⁠لِهَتُنَا خَیۡرٌ أَمۡ هُوَۚ مَا ضَرَبُوهُ لَكَ إِلَّا جَدَلَۢاۚ بَلۡ هُمۡ قَوۡمٌ خَصِمُونَ ۝٥٨﴾</span> - قراءات</h3></p><p><div></p><p><p><span class="item-no">٦٩٦٧٣<span class="dash">-</span></span> عن قتادة: أنّ في حرف <span class="name-1">أُبَيّ بن كعب</span>: (وقالُواْ أآلِهَتُنا خَيْرٌ أمْ هَذا)، يعنون: محمدًا ﷺ{1}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَقَالُوۤا۟ ءَأَ ٰ⁠لِهَتُنَا خَیۡرٌ أَمۡ هُوَۚ مَا ضَرَبُوهُ لَكَ إِلَّا جَدَلَۢاۚ بَلۡ هُمۡ قَوۡمٌ خَصِمُونَ ۝٥٨﴾</span> - نزول الآية، وتفسيرها</h3></p><p><div></p><p><p><span class="item-no">٦٩٦٧٤<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطية- <span class="qpc-hafs">﴿ولَمّا ضُرِبَ ابْنُ مَرْيَمَ مَثَلًا إذا قَوْمُكَ مِنهُ يَصِدُّونَ﴾</span>، قال: يعني: قريشًا؛ لَمّا قيل لهم: <span class="qpc-hafs">﴿إنَّكُمْ وما تَعْبُدُونَ مِن دُونِ اللَّهِ حَصَبُ جَهَنَّمَ أنْتُمْ لَها وارِدُونَ﴾</span> [الأنبياء:٩٨] فقالت له قريش: فما ابن مريم؟ قال: «<b>ذاك عبدُ الله ورسوله»</b>. فقالوا: واللهِ، ما يريد هذا إلا أن نتَّخِذه ربًّا، كما اتخذت النصارى عيسى ابنَ مريم ربًّا. فقال الله ﷿: <span class="qpc-hafs">﴿ما ضَرَبُوهُ لَكَ إلّا جَدَلًا بَلْ هُمْ قَوْمٌ خَصِمُونَ﴾</span>{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٩٦٧٥<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- قال: لَمّا ذُكِر عيسى ابن مريم جزعت قريش، وقالوا: ما ذِكرُ محمدٍ عيسى ابنَ مريم! ما يريد محمدٌ إلا أن يُصنَع به كما صنعت النصارى بعيسى ابن مريم. فقال الله: <span class="qpc-hafs">﴿ما ضَرَبُوهُ لَكَ إلّا جَدَلًا﴾</span>{3}. (١٣/٢١٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٩٦٧٦<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- قال: لَمّا ذَكر الله عيسى في القرآن قال مشركو مكة: إنّما أراد محمدٌ أن نُحِبَّه كما أحبَّ النصارى عيسى. قال: <span class="qpc-hafs">﴿ما ضَرَبُوهُ لَكَ إلّا جَدَلًا﴾</span>، قال: ما قالوا هذا القول إلا ليجادلوا{4}. (١٣/٢٢٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٩٦٧٧<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدّيّ</span> -من طريق أسباط- في قوله: <span class="qpc-hafs">﴿وقالُوا أآلِهَتُنا خَيْرٌ أمْ هُوَ ما ضَرَبُوهُ لَكَ إلّا جَدَلًا بَلْ هُمْ قَوْمٌ خَصِمُونَ﴾</span>، قال: خاصموه. فقالوا: تزعم أنّ كلَّ مِن عُبِد مِن دون الله في النار! فنحن نرضى أن تكون آلهتنا مع عيسى، وعُزير، والملائكة، هؤلاء قد عُبِدوا من دون الله. قال: فأنزل الله براءة عيسى{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٩٦٧٨<span class="dash">-</span></span> عن <span class="name-2">عطاء الخُراسانيّ</span> -من طريق يونس بن يزيد- في قول الله سبحانه: <span class="qpc-hafs">﴿ءآلهتنا خير أم هو﴾</span>، قال: يعنون: عيسى ﵇{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٩٦٧٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وقالُوا أآلِهَتُنا خَيْرٌ أمْ هُوَ﴾</span> يعني: عيسى. وقالوا: ليس آلهتنا إنْ عُذِّبت خيرًا مِن عيسى بأنه يُعبد. يقول الله تعالى: <span class="qpc-hafs">﴿ما ضَرَبُوهُ لَكَ إلّا جَدَلًا﴾</span> يقول: ما ذكروا لك عيسى إلا ليجادلونك به{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٩٦٨٠<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿أآلِهَتُنا خَيْرٌ﴾</span> قال: عَبَدَ هؤلاء عيسى، ونحن نعبد الملائكة. وقرأ: <span class="qpc-hafs">﴿ما ضَرَبُوهُ لَكَ إلّا جَدَلًا بَلْ هُمْ قَوْمٌ خَصِمُونَ﴾</span> إلى قوله: <span class="qpc-hafs">﴿فِي الأَرْضِ يَخْلُفُونَ﴾</span>{5}<span class=comment-ref>٥٨٨٣</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٥٨٨٣</span> قوله تعالى: <span class="qpc-hafs">﴿أمْ هُوَ﴾</span> فيه قولان: <b>الأول</b>: أنه النبي ﷺ. <b>الثاني</b>: أنه عيسىﷺ.</p><p>و<span class="comment-type-3">رجَّح</span> <u>ابنُ عطية</u> (٧/٥٥٨) القول الثاني الذي قاله السُّدّيّ، وابن زيد، ومقاتل، فقال: «وهذا هو المترجح». ولم يذكر سندًا.</div></p><p><h3><span class="qpc-hafs">﴿وَقَالُوۤا۟ ءَأَ ٰ⁠لِهَتُنَا خَیۡرٌ أَمۡ هُوَۚ مَا ضَرَبُوهُ لَكَ إِلَّا جَدَلَۢاۚ بَلۡ هُمۡ قَوۡمٌ خَصِمُونَ ۝٥٨﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٦٩٦٨١<span class="dash">-</span></span> عن أبي أُمامة، قال: قال رسول الله ﷺ: «<b>ما ضلَّ قومٌ بعد هُدىً كانوا عليه إلا أُوتوا الجدل».</b> ثم قرأ: <span class="qpc-hafs">﴿ما ضَرَبُوهُ لَكَ إلّا جَدَلًا﴾</span> الآية{9}. (١٣/٢٢١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٩٦٨٢<span class="dash">-</span></span> عن أبي أُمامة، أنّ رسول الله ﷺ خرج على الناس وهم يتنازعون في القرآن، فغضِب غضبًا شديدًا، كأنما صُبَّ على وجهه الخلّ، ثم قال: «<b>لا تضربوا كتاب الله بعضه ببعض؛ فإنه ما ضلّ قومٌ قطّ إلا أُوتوا الجدل»</b>. ثم تلا: <span class="qpc-hafs">﴿ما ضَرَبُوهُ لَكَ إلّا جَدَلًا﴾</span> الآية{10}. (١٣/٢٢١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٩٦٨٣<span class="dash">-</span></span> عن <span class="name-1">أبي أُمامة</span>، قال: ما ضلَّت أُمّةٌ بعد نبيِّها إلا أُعطوا الجدل. ثم قرأ: <span class="qpc-hafs">﴿ما ضَرَبُوهُ لَكَ إلّا جَدَلًا﴾</span>{11}. (١٣/٢٢١)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ٢٠/٦٢٧.</p><p>وهي قراءة شاذة. انظر: الجامع لأحكام القرآن ١٩/٦٨.أخرجه ابن جرير ٢٠/٦٢٣، من طريق محمد بن سعد العوفي، عن أبيه، قال: حدثني عمي الحسين بن الحسن، عن أبيه، عن جده عطية العوفي، عن ابن عباس به.</p><p>إسناده ضعيف، لكنها صحيفة صالحة ما لم تأت بمنكر أو مخالفة. وينظر: مقدمة الموسوعة.أخرجه عبد الرزاق ٢/١٩٨، وابن جرير ٢٠/٦٢٢. وعزاه السيوطي إلى ابن جرير، وابن المنذر.أخرجه عبد الرزاق ٢/١٩٨ من طريق معمر، وابن جرير ٢٠/٦٢٢ بنحوه. وعزاه السيوطي إلى عبد بن حُمَيد.أخرجه ابن جرير ٢٠/٦٢٧.أخرجه أبو جعفر الرملي في جزئه (تفسير عطاء) ص٩٢.تفسير مقاتل بن سليمان ٣/٧٩٩.أخرجه ابن جرير ٢٠/٦٢٧.أخرجه أحمد ٣٦/٤٩٣ (٢٢١٦٤)، ٣٦/٥٤٠ (٢٢٢٠٤)، والترمذي ٥/٤٥٦-٤٥٧ (٣٥٣٥)، وابن ماجه ١/٣٣ (٤٨)، والحاكم ٢/٤٨٦ (٣٦٧٤)، وابن جرير ٢٠/٦٢٨.</p><p>قال الترمذي: «هذا حديث حسن صحيح». وقال الحاكم: «هذا حديث صحيح الإسناد، ولم يخرجاه».أخرجه ابن بطة في الإبانة الكبرى ٢/٤٨٦ (٥٢٧)، وابن جرير ٢٠/٦٢٨، من طريق عبّاد بن عبّاد، عن جعفر، عن القاسم، عن أبي أمامة به.</p><p>إسناده ضعيف جدًّا؛ فيه جعفر، وهو ابن الزبير الحنفي أو الباهلي، قال ابن حجر في التقريب (٩٣٩): «متروك الحديث، وكان صالحًا في نفسه».أخرجه ابن أبي حاتم -كما في تفسير ابن كثير ٧/٢٢٢-، وعنده: قال حماد: لا أدري رفعه أم لا؟.
  43,59,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿إِنۡ هُوَ إِلَّا عَبۡدٌ أَنۡعَمۡنَا عَلَیۡهِ وَجَعَلۡنَـٰهُ مَثَلࣰا لِّبَنِیۤ إِسۡرَ ٰ⁠ۤءِیلَ ۝٥٩﴾</span> - نزول الآية</h3></p><p><div></p><p><p><span class="item-no">٦٩٦٨٤<span class="dash">-</span></span> عن عبد الله بن عباس: أنّ المشركين أتَوا رسول الله ﷺ، فقالوا له: أرأيتَ ما يُعبَد مِن دون الله أين هم؟ قال: «<b>في النار»</b>. قالوا: والشمس والقمر؟ قال: «<b>والشمس والقمر»</b>. قالوا: فعيسى ابن مريم؟ فأنزل الله: <span class="qpc-hafs">﴿إنْ هُوَ إلّا عَبْدٌ أنْعَمْنا عَلَيْهِ وجَعَلْناهُ مَثَلًا لِبَنِي إسْرائِيلَ﴾</span>{1}. (١٣/٢٢٣)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿إِنۡ هُوَ إِلَّا عَبۡدٌ أَنۡعَمۡنَا عَلَیۡهِ وَجَعَلۡنَـٰهُ مَثَلࣰا لِّبَنِیۤ إِسۡرَ ٰ⁠ۤءِیلَ ۝٥٩﴾</span> - تفسير الآية</h3></p><p><div></p><p><p><span class="item-no">٦٩٦٨٥<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿إنْ هُوَ إلّا عَبْدٌ أنْعَمْنا عَلَيْهِ﴾</span> قال: ما عدا ذلك نبي الله عيسى؛ أنْ كان عبدًا صالحًا أنعم الله عليه، <span class="qpc-hafs">﴿وجَعَلْناهُ مَثَلًا لِبَنِي إسْرائِيلَ﴾</span> آية لبني إسرائيل{2}. (١٣/٢٢٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٩٦٨٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿إنْ هُوَ إلّا عَبْدٌ﴾</span> يعني: عيسى ﵇، يقول: ما هو إلا عبد <span class="qpc-hafs">﴿أنْعَمْنا عَلَيْهِ﴾</span> بالنّبوة، <span class="qpc-hafs">﴿وجَعَلْناهُ مَثَلًا لِبَنِي إسْرائِيلَ﴾</span> يقول الله تعالى: حين وُلِد مِن غير أب، يعني: آيةً وعبرةً ليعتبروا{3}. (ز)</p></p><p></div></p></div>",footnotes:1:عزاه السيوطي إلى ابن مردويه.أخرجه ابن جرير ٢٠/٦٢٩ بنحوه. وأخرجه عبد الرزاق ٢/١٩٨ من طريق معمر مقتصرًا على الشطر الثاني، وكذا ابن جرير. وعزاه السيوطي إلى عبد بن حُمَيد.تفسير مقاتل بن سليمان ٣/٧٩٩-٨٠٠.
  43,60,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَلَوۡ نَشَاۤءُ لَجَعَلۡنَا مِنكُم مَّلَـٰۤىِٕكَةࣰ فِی ٱلۡأَرۡضِ یَخۡلُفُونَ ۝٦٠﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٩٦٨٧<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- <span class="qpc-hafs">﴿ولَوْ نَشاءُ لَجَعَلْنا مِنكُمْ مَلائِكَةً فِي الأَرْضِ يَخْلُفُونَ﴾</span>، قال: يخلُفُ بعضُهم بعضًا{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٩٦٨٨<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- <span class="qpc-hafs">﴿ولَوْ نَشاءُ لَجَعَلْنا مِنكُمْ مَلائِكَةً فِي الأَرْضِ يَخْلُفُونَ﴾</span>، قال: يعمُرون الأرض بدلًا منكم{2}. (١٣/٢٢٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٩٦٨٩<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- <span class="qpc-hafs">﴿ولَوْ نَشاءُ لَجَعَلْنا مِنكُمْ مَلائِكَةً فِي الأَرْضِ يَخْلُفُونَ﴾</span>: يخلُف بعضُهم بعضًا مكان بني آدم{3}. (١٣/٢٢٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٩٦٩٠<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿ولَوْ نَشاءُ لَجَعَلْنا مِنكُمْ مَلائِكَةً فِي الأَرْضِ يَخْلُفُونَ﴾</span>: لو شاء اللهُ لَجعل في الأرض ملائكةً يخلُف بعضهم بعضًا{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٩٦٩١<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدّيّ</span> -من طريق أسباط- <span class="qpc-hafs">﴿ولَوْ نَشاءُ لَجَعَلْنا مِنكُمْ مَلائِكَةً فِي الأَرْضِ يَخْلُفُونَ﴾</span>، قال: خلفًا منكم{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٩٦٩٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: قوله: <span class="qpc-hafs">﴿ولَوْ نَشاءُ لَجَعَلْنا مِنكُمْ مَلائِكَةً فِي الأَرْضِ يَخْلُفُونَ﴾</span> مكانكم، فكانوا خلفًا منكم{6}<span class=comment-ref>٥٨٨٤</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٥٨٨٤</span> اختُلف في معنى قوله: <span class="qpc-hafs">﴿يخلفون﴾</span> على أقوال: <b>الأول</b>: يخلُفونكم ليكونوا بدلًا منكم. <b>الثاني</b>: يخلُف بعضُهم بعضًا. <b>والثالث</b>: يخلُفون الرُّسل فيكونون رسلًا إليكم بدلًا منهم. <b>الرابع</b>: يعمرون الارض بدلكم.</p><p>و<span class="comment-type-4">ذكر</span> <u>ابنُ كثير</u> (١٢/٣٢٢) أنّ القول الثاني الذي قاله ابن عباس، وقتادة، يستلزم القول الأول الذي قاله السُّدّيّ، ومقاتل.</div></p></div>",footnotes:1:أخرجه ابن جرير ٢٠/٦٣٠.تفسير مجاهد ص٥٩٤، وأخرجه ابن جرير ٢٠/٦٣٠. وعزاه السيوطي إلى عبد بن حُمَيد.أخرجه عبد الرزاق ٢/١٩٨، وابن جرير ٢٠/٦٣٠. وعزاه السيوطي إلى عبد بن حُمَيد.أخرجه ابن جرير ٢٠/٦٣٠.أخرجه ابن جرير ٢٠/٦٣١.تفسير مقاتل بن سليمان ٣/٨٠٠.