tafsir[11]{c,v,t}:
40,67," <q>﴿هُوَ ٱلَّذِی خَلَقَكُم مِّن تُرَابࣲ ثُمَّ مِن نُّطۡفَةࣲ ثُمَّ مِنۡ عَلَقَةࣲ ثُمَّ یُخۡرِجُكُمۡ طِفۡلࣰا﴾</q> - تفسير ٦٨٢١١- عن قتادة بن دعامة، في قوله: <q>﴿هُوَ الَّذِي خَلَقَكُمْ مِن تُرابٍ ثُمَّ مِن نُطْفَةٍ﴾</q>، قال: خلَق آدم من تراب، ثم خلق نسْله من نطفة{1}. (١٣/٧٤) ٦٨٢١٢- قال مقاتل بن سليمان: <q>﴿هُوَ الَّذِي خَلَقَكُمْ مِن تُرابٍ﴾</q> وذلك أنّ كفار مكة كذّبوا بالبعث، فأخبرهم الله عن بدءِ خلْقهم ليعتبروا في البعث، فقال تعالى: <q>﴿هُوَ الَّذِي خَلَقَكُمْ مِن تُرابٍ﴾</q> يعني: آدم ﵇، <q>﴿ثُمَّ مِن نُطْفَةٍ﴾</q> يعني: ذريته، <q>﴿ثُمَّ مِن عَلَقَةٍ﴾</q> يعني: مثل الدم، <q>﴿ثُمَّ يُخْرِجُكُمْ طِفْلًا﴾</q>{2}. (ز) <q>﴿ثُمَّ لِتَبۡلُغُوۤا۟ أَشُدَّكُمۡ ثُمَّ لِتَكُونُوا۟ شُیُوخࣰاۚ﴾</q> - تفسير ٦٨٢١٣- عن عامر الشعبي، قال: يُثْغِر{3} الغلام لسبع، ويحتلم لأربع عشرة، وينتهي طوله لإحدى وعشرين، وينتهي عقله لثمانٍ وعشرين، ويبلغ أشدّه لثلاث وثلاثين{4}. (١٣/٧٤) ٦٨٢١٤- قال مقاتل بن سليمان: <q>﴿ثُمَّ لِتَبْلُغُوا أشُدَّكُمْ﴾</q> يعني: ثماني عشرة سنة، فهو في الأشُدّ ما بين الثماني عشرة إلى الأربعين سنة، <q>﴿ثُمَّ لِتَكُونُوا شُيُوخًا﴾</q> يعني: لكي تكونوا شيوخًا{2}٥٧١١. (ز) ٥٧١١ ذكر ابنُ عطية (٧/٤٥٥) أنه اختُلف في بلوغ الأشد؛ فقيل: ثلاثون. وقيل: ستة وثلاثون. وقيل: أربعون. وقيل: ستة وأربعون. وقيل: عشرون، وقيل: ثمانية عشر. وقيل: خمسة عشر. وانتقد الثلاثة الأخيرة بقوله: «وهذه الأقوال الأخيرة ضعيفة في الأشد». ولم يذكر مستندًا. <q>﴿وَمِنكُم مَّن یُتَوَفَّىٰ مِن قَبۡلُۖ وَلِتَبۡلُغُوۤا۟ أَجَلࣰا مُّسَمࣰّى وَلَعَلَّكُمۡ تَعۡقِلُونَ ۝٦٧﴾</q> - تفسير ٦٨٢١٥- قال مقاتل بن سليمان: <q>﴿ومِنكُمْ مَن يُتَوَفّى مِن قَبْلُ﴾</q> أن يكون شيخًا، <q>﴿ولِتَبْلُغُوا أجَلًا مُسَمًّى﴾</q> يعني: الشيخ والشابّ جميعًا، <q>﴿ولَعَلَّكُمْ﴾</q> يعني: ولكي <q>﴿تَعْقِلُونَ﴾</q> يقول: لكي تعقلوا آثار ربكم في خلْقكم بأنّه قادر على أن يبعثكم كما خلَقكم{6}. (ز) ٦٨٢١٦- عن عبد الملك ابن جُرَيْج، <q>﴿ومِنكُمْ مَن يُتَوَفّى مِن قَبْلُ﴾</q> قال: مِن قبل أن يكون شيخًا، <q>﴿ولِتَبْلُغُوا أجَلًا مُسَمًّى﴾</q> الشيخ والشابّ، <q>﴿ولَعَلَّكُمْ تَعْقِلُونَ﴾</q> عن ربكم أنّه يحييكم كما أماتكم، وهذه لأهل مكة، كانوا يُكَذِّبون بالبعث{7}. (١٣/٧٤) ",footnotes:1:عزاه السيوطي إلى عبد بن حميد.تفسير مقاتل بن سليمان ٣/٧١٩-٧٢٠.الإثغار: سقوط سن الصبي ونباتها. النهاية (ثغر).عزاه السيوطي إلى ابن أبي حاتم.تفسير مقاتل بن سليمان ٣/٧١٩-٧٢٠.تفسير مقاتل بن سليمان ٣/٧٢٠.عزاه السيوطي إلى ابن المنذر.
40,68," <q>﴿هُوَ ٱلَّذِی یُحۡیِۦ وَیُمِیتُۖ فَإِذَا قَضَىٰۤ أَمۡرࣰا فَإِنَّمَا یَقُولُ لَهُۥ كُن فَیَكُونُ ۝٦٨﴾</q> - تفسير ٦٨٢١٧- قال مقاتل بن سليمان: ثم قال: <q>﴿هُوَ﴾</q> الله <q>﴿الَّذِي يُحْيِي﴾</q> الموتى <q>﴿ويُمِيتُ﴾</q> الأحياء، <q>﴿فَإذا قَضى أمْرًا﴾</q> كان في علمه، يعني: البعث <q>﴿فَإنَّما يَقُولُ لَهُ كُنْ فَيَكُونُ﴾</q> مرة واحدة لا يثني قوله{1}. (ز) ",footnotes:1:تفسير مقاتل بن سليمان ٣/٧٢٠.
40,69," <q>﴿أَلَمۡ تَرَ إِلَى ٱلَّذِینَ یُجَـٰدِلُونَ فِیۤ ءَایَـٰتِ ٱللَّهِ﴾</q> - تفسير ٦٨٢١٨- عن محمد بن سيرين -من طريق داود بن أبي هند- قال: إن لم تكن هذه الآية نزلت في القَدَرية فإني لا أدري فيمن نزلت: <q>﴿ألَمْ تَرَ إلى الَّذِينَ يُجادِلُونَ فِي آياتِ اللَّهِ أنّى يُصْرَفُونَ﴾</q> إلى قوله: <q>﴿لَمْ نَكُنْ نَدْعُو مِن قَبْلُ شَيْئًا كَذَلِكَ يُضِلُّ اللَّهُ الكافِرِين﴾</q>{1}. (ز) ٦٨٢١٩- عن أبي قبيل، قال: أخبرني عقبة بن عامر الجهني أنّ رسول الله ﷺ قال: «سيهْلَك مِن أمتي أهل الكتاب، وأهل اللَّبَن». فقال عقبة: يا رسول الله، وما أهل الكتاب؟ قال: «قوم يتعلّمون كتاب الله يجادلون الذين آمنوا». فقال عقبة: يا رسول الله، وما أهل اللَّبَن؟ قال: «قوم يتّبعون الشهوات، ويضيِّعون الصلوات». قال أبو قبيل: لا أحسب المكذِّبين بالقَدَر إلّا الذين يجادلون الذين آمنوا، وأما أهل اللَّبَن فلا أحسبهم إلّا أهل العمود، ليس عليهم إمام جماعة، ولا يعرفون شهر رمضان{2}. (ز) ٦٨٢٢٠- قال مقاتل بن سليمان: <q>﴿ألَمْ تَرَ إلى الَّذِينَ يُجادِلُونَ فِي آياتِ اللَّهِ﴾</q>، يعني: آيات القرآن، أنه ليس من الله ﷿ ... يعني: كفار مكة{3}. (ز) ٦٨٢٢١- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿ألَمْ تَرَ إلى الَّذِينَ يُجادِلُونَ فِي آياتِ اللَّهِ أنّى يُصْرَفُونَ﴾</q>، قال: هؤلاء المشركون{4}٥٧١٢. (ز) ٥٧١٢ اختُلف في الذين عُنوا بهذه الآية على قولين: الأول: أنهم أهل القدر. الثاني: أنهم أهل الشرك. ورجَّح ابنُ جرير (٢٠/٣٦٢) مستندًا إلى السياق القول الثاني الذي قاله ابن زيد، ومقاتل، فقال: «والصواب من القول في ذلك ما قاله ابن زيد؛ وقد بيّن الله حقيقة ذلك بقوله: <q>﴿الذين كذبوا بالكتاب وبما أرسلنا به رسلنا﴾</q>». وكذا رجَّحه ابنُ عطية (٧/٤٥٦) مستندًا إلى السياق، فقال: «ظاهر الآية أنها في الكفار المجادلين في رسالة محمد ﷺ والكتاب الذي جاء به، بدليل قوله: <q>﴿الَّذِينَ كَذَّبُوا بِالكِتابِ﴾</q>، وهذا قول ابن زيد والجمهور من المفسرين». وعلَّق على القول الثاني بقوله: «ويلزم قائلي هذه المقالة أن يجعلوا قوله تعالى: <q>﴿الَّذِينَ كَذَّبُوا﴾</q> الآية ... كلامًا مقطوعًا مستأنفًا في الكفار». وذكر أنهم رووا حديثًا في نحو ما قالوا من أنّهم أهل القدر. <q>﴿أَنَّىٰ یُصۡرَفُونَ ۝٦٩﴾</q> - تفسير ٦٨٢٢٢- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿أنّى يُصْرَفُونَ﴾</q>، قال: أنى يكذِّبون ويعدلون؟!{5}. (١٣/٧٤) ٦٨٢٢٣- قال مقاتل بن سليمان: <q>﴿أنّى يُصْرَفُونَ﴾</q>، يقول: مِن أين يعدلون عنه إلى غيره؟! يعني: كفار مكة{3}. (ز) ٦٨٢٢٤- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿أنّى يُصْرَفُون﴾</q>، قال: يُصرَفون عن الحق{4}. (ز) ",footnotes:1:أخرجه ابن جرير ٢٠/٣٦٠-٣٦١، وفي لفظ: إن لم يكن أهل القدر الذين يخوضون في آيات الله فلا علم لنا به.أخرجه أحمد ٢٨/٥٥٥-٥٥٦ (١٧٣١٨)، ٢٨/٦٣٢ (١٧٤١٥)، ٢٨/٦٣٦ (١٧٤٢١) بنحوه، والحاكم ٢/٤٠٦ (٣٤١٧)، وابن جرير ٢٠/٣٦١ واللفظ له، والثعلبي ٨/٢٨١. قال الحاكم: «هذا حديث صحيح الإسناد، ولم يخرجاه».تفسير مقاتل بن سليمان ٣/٧٢٠.أخرجه ابن جرير ٢٠/٣٦٠، ٣٦٢.أخرجه ابن جرير ٢٠/٣٦٠. وعزاه السيوطي إلى عبد بن حميد.تفسير مقاتل بن سليمان ٣/٧٢٠.أخرجه ابن جرير ٢٠/٣٦٠، ٣٦٢.
40,70," <q>﴿ٱلَّذِینَ كَذَّبُوا۟ بِٱلۡكِتَـٰبِ وَبِمَاۤ أَرۡسَلۡنَا بِهِۦ رُسُلَنَاۖ فَسَوۡفَ یَعۡلَمُونَ ۝٧٠﴾</q> - تفسير ٦٨٢٢٥- قال مقاتل بن سليمان: ثم أخبر عنهم، فقال تعالى: <q>﴿الَّذِينَ كَذَّبُوا بِالكِتابِ﴾</q> يعني: بالقرآن، <q>﴿وبِما أرْسَلْنا بِهِ رُسُلَنا﴾</q> يعني: محمدًا ﷺ، أُرسل بالتوحيد، فأوعدهم في الآخرة فقال: <q>﴿فَسَوْفَ يَعْلَمُونَ﴾</q> هذا وعيد{1}٥٧١٣. (ز) ٥٧١٣ ذكر ابنُ عطية (٧/٤٥٦) أن «الذين» ابتداء وخبره: <q>﴿فَسَوْفَ يَعْلَمُونَ﴾</q>، ثم ساق احتمالًا آخر، فقال: «ويحتمل أن يكون خبر الابتداء محذوفًا، والفاء متعلقة به». ",footnotes:1:تفسير مقاتل بن سليمان ٣/٧٢٠.
40,71," <q>﴿إِذِ ٱلۡأَغۡلَـٰلُ فِیۤ أَعۡنَـٰقِهِمۡ وَٱلسَّلَـٰسِلُ یُسۡحَبُونَ ۝٧١ فِی ٱلۡحَمِیمِ﴾</q> - قراءات ٦٨٢٢٦- قال هارون: وفي قراءة أُبي: (إذِ الأَغْلالُ فِي أعْناقِهِمْ وبِالسَّلاسِلِ يُسْحَبُونَ){1}. (ز) ٦٨٢٢٧- عن عبد الله بن عباس -من طريق أبي الجوزاء- أنه قرأ: (والسَّلاسِلَ) بنصب، (يَسْحَبُونَ) بنصب الياء، وذلك أشد عليهم وهم يَسحبون السلاسل{2}٥٧١٤. (١٣/٧٥) ٥٧١٤ اختُلف في قراءة قوله: <q>﴿والسلاسل يسحبون﴾</q>؛ فقرأ قوم: <q>﴿والسلاسلُ﴾</q> بالرفع. وقرأ غيرهم بنصبها وفتح <q>﴿يسحبون﴾</q>. وذكر ابنُ جرير (٢٠/٣٦٣) أن الأولى جاءت بالرفع عطفًا على <q>﴿الأغلال﴾</q>. وأن القراءة الثانية بمعنى: ويسحبون السلاسل. وبنحوه قال ابنُ عطية (٧/٤٥٦). ورجَّح ابنُ جرير (٢٠/٣٦٤) قراءة الرفع مستندًا إلى إجماع القراء، فقال: «والصواب من القراءة عندنا في ذلك ما عليه قراء الأمصار؛ لإجماع الحجة عليه، وهو رفع»السلاسل«عطفًا بها على ما في قوله: <q>﴿في أعناقهم﴾</q> من ذكر الأغلال». ٦٨٢٢٨- قال هارون: وقال الحسن البصري= (ز) ٦٨٢٢٩- وأبو عمرو= (ز) ٦٨٢٣٠- والأعرج: <q>﴿إذِ الأَغْلالُ فِي أعْناقِهِمْ والسَّلاسِلُ يُسْحَبُونَ﴾</q>، يقول: يُفعل بهم ذلك{3}. (ز) <q>﴿إِذِ ٱلۡأَغۡلَـٰلُ فِیۤ أَعۡنَـٰقِهِمۡ وَٱلسَّلَـٰسِلُ یُسۡحَبُونَ ۝٧١ فِی ٱلۡحَمِیمِ﴾</q> - تفسير الآية ٦٨٢٣١- عن عبد الله بن عمرو، قال: تلا رسول الله ﷺ: <q>﴿إذِ الأَغْلالُ فِي أعْناقِهِمْ والسَّلاسِلُ﴾</q> إلى قوله: <q>﴿يُسْجَرُونَ﴾</q>، فقال: «لو أنّ رَصاصة مثل هذه -وأشار إلى جُمجمة- أُرسلت مِن السماء إلى الأرض، وهي مسيرة خمسمائة سنة، لبَلغَت الأرضَ قبل الليل، ولو أنها أُرسلت مِن رأس السلسلة لسارت أربعين خريفًا الليلَ والنهارَ قبل أن تبلغ أصلها -أو قال: قعرها-»{4}. (١٣/٧٤) ٦٨٢٣٢- عن عبد الله بن عباس -من طريق أبي منصور مولى سليم- قال: <q>﴿يُسْحَبُونَ فِي الحَمِيمِ﴾</q>: فيُسلَخ كل شيء عليهم؛ من جِلد ولحم وعِرْق، حتى يصير في عقبه، حتى إنّ لحمه قدْر طوله، وطوله ستون ذراعًا، ثم يُكسى جلدًا آخر، ثم يُسجر في الحميم{5}. (١٣/٧٦) ٦٨٢٣٣- قال مقاتل بن سليمان: ثم أخبر عن الوعيد، فقال: <q>﴿إذِ الأَغْلالُ فِي أعْناقِهِمْ والسَّلاسِلُ يُسْحَبُونَ﴾</q> على الوجوه، <q>﴿فِي الحَمِيمِ﴾</q> يعني: حرّ النار{6}. (ز) <q>﴿ثُمَّ فِی ٱلنَّارِ یُسۡجَرُونَ ۝٧٢﴾</q> - تفسير ٦٨٢٣٤- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿يُسْجَرُونَ﴾</q>، قال: تُوقد بهم النار{7}٥٧١٥. (١٣/٧٦) ٥٧١٥ ساق ابنُ عطية (٧/٤٥٧) هذا القول، ثم علَّق بقوله: «والعرب تقول: سجرت التنّور: إذا ملأتها». ٦٨٢٣٥- عن إسماعيل السُّدّيّ -من طريق أسباط- في قوله: <q>﴿ثُمَّ فِي النّارِ يُسْجَرُون﴾</q>، قال: يُحرَقون في النار{8}. (ز) ٦٨٢٣٦- قال مقاتل بن سليمان: <q>﴿ثُمَّ فِي النّارِ يُسْجَرُونَ﴾</q>، يعني: يُوقدون، فصاروا وقودها{6}. (ز) ٦٨٢٣٧- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿ثُمَّ فِي النّارِ يُسْجَرُونَ﴾</q>: يُسجرون في النار؛ يُوقد عليهم فيها{8}. (ز) <q>﴿ثُمَّ فِی ٱلنَّارِ یُسۡجَرُونَ ۝٧٢﴾</q> - آثار متعلقة بالآية ٦٨٢٣٨- عن يعلى بن مُنْيَة، رفع الحديث إلى رسول الله ﷺ، قال: «ينشىء الله سحابةً لأهل النار سوداء مظلمة، ويُقال لأهل النار: أيَّ شيء تطلبون؟ فيذْكُرون بها سحاب الدنيا، فيقولون: يا ربَّنا، الشراب. فتُمْطِرُهم أغلالًا تزيد في أغلالهم، وسلاسل تزيد في سلاسلهم، وجمرًا يُلهب عليهم»{11}. (١٣/٧٥) ٦٨٢٣٩- عن سعيد بن عبيد، قال: كان سعيد بن جُبير إذا أتى على هذه الآية: <q>﴿فسوف يعلمون إذ الأغلال في أعناقهم والسلاسل يسحبون في الحميم ثم في النار يسجرون﴾</q> رجّع فيها، وردّدها مرتين أو ثلاثًا{12}. (ز) ٦٨٢٤٠- عن التيمي -من طريق ابنه- قال: لو أنّ غُلًّا مِن أغلال جهنم وُضِع على جبلٍ لَوَهَصَهُ{13} حتى يبلغ الماء الأسود{14}. (ز) ",footnotes:1:أخرجه إسحاق البستي ص٢٨٥. وهي قراءة شاذة. انظر: البحر المحيط ٧/٤٥٤.أخرجه إسحاق البستي ص٢٨٥، والثعلبي ٨/٢٨٢. وعزاه السيوطي إلى ابن أبي حاتم. وهي قراءة شاذة، تروى أيضًا عن ابن مسعود، ويحيى بن وثاب. انظر: مختصر ابن خالويه ص١٣٣، والمحتسب ٢/٢٤٤.أخرجه إسحاق البستي ص٢٨٥. وهي قراءة العشرة.أخرجه الحاكم ٢/٤٧٦ (٣٦٤٠)، وأخرجه أحمد ١١/٤٤٣-٤٤٥ (٦٨٥٦، ٦٨٥٧)، والترمذي ٤/٥٤٣-٥٤٤ (٢٧٧٠)، وابن جرير ٢٣/٢٣٨ دون ذكر الآية. قال الترمذي: «هذا حديث إسناده حسن». وقال الحاكم: «هذا حديث صحيح الإسناد، ولم يخرجاه». وقال البغوي في شرح السنة ١٥/٢٤٨-٢٤٩ (٤٤١١): «حديث حسن».أخرجه ابن أبي الدنيا في صفة النار -موسوعة الإمام ابن أبي الدنيا ٦/٤٢٤ (١١١)-.تفسير مقاتل بن سليمان ٣/٧٢٠.تفسير مجاهد ص٥٨٤، وأخرجه الفريابي -كما في تغليق التعليق ٤/٣٠٠-، وابن جرير ٢٠/٣٦٤. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.أخرجه ابن جرير ٢٠/٣٦٤.تفسير مقاتل بن سليمان ٣/٧٢٠.أخرجه ابن جرير ٢٠/٣٦٤.أخرجه ابن أبي الدنيا في كتاب صفة النار ص٥٢-٥٣ (٦٢) ولم يذكر الرفع، والطبراني في الأوسط ٤/٢٤٧-٢٤٨ (٤١٠٣)، وابن أبي حاتم -كما في تفسير ابن كثير ٧/١٥٨-. قال الطبراني: «لا يُروى هذا الحديث عن يعلى إلا بهذا الإسناد، تفرّد به منصور». وقال ابن كثير: «هذا حديث غريب». وقال الهيثمي في المجمع ١٠/٣٩٠ (١٨٥٩٨): «رواه الطبراني في الأوسط، وفيه مَن فيه ضعفٌ قليل، ومَن لم أعرفه». وقال الألباني في الضعيفة ١١/٦٧٦ (٥٤٠٣): «ضعيف».أخرجه إسحاق البستي ص٢٨٦.وهصه: كسره ودقّه. لسان العرب (وهـص).أخرجه عبد الرزاق ٢/١٨٣.
  40,72,""
40,73," <q>﴿ثُمَّ قِیلَ لَهُمۡ أَیۡنَ مَا كُنتُمۡ تُشۡرِكُونَ ۝٧٣ مِن دُونِ ٱللَّهِۖ قَالُوا۟ ضَلُّوا۟ عَنَّا بَل لَّمۡ نَكُن نَّدۡعُوا۟ مِن قَبۡلُ شَیۡـࣰٔاۚ كَذَ ٰ⁠لِكَ یُضِلُّ ٱللَّهُ ٱلۡكَـٰفِرِینَ ۝٧٤﴾</q> - تفسير ٦٨٢٤١- قال مقاتل بن سليمان: <q>﴿ثُمَّ قِيلَ لَهُمْ﴾</q> قبل دخول النار، يعني: تقول لهم الخزنة: <q>﴿أيْنَ ما كُنْتُمْ تُشْرِكُونَ﴾</q> يعني: تعبدون <q>﴿مِن دُونِ اللَّهِ﴾</q> فهل يمنعونكم مِن النار؟! يعني: الآلهة، <q>﴿قالُوا ضَلُّوا عَنّا﴾</q> ضلّت عنا الآلهة، <q>﴿بَلْ لَمْ نَكُنْ نَدْعُوا مِن قَبْلُ شَيْئًا﴾</q> يعني: لم نكن نعبد من قبل في الدنيا شيئًا، إن الذي كنا نعبد كان باطلًا، لم يكن شيئًا، <q>﴿كَذلِكَ﴾</q> يعني: هكذا <q>﴿يُضِلُّ اللَّهُ الكافِرِينَ﴾</q>{1}. (ز) ٦٨٢٤٢- عن يحيى بن سلّام -من طريق أحمد- في قوله: <q>﴿بل لم نكن ندعو من قبل شيئًا﴾</q> أي: ينفعنا ولا يضرّنا، قال الله ﷿: <q>﴿كذلك يضل الله الكافرين﴾</q>. ثم رجع إلى قصتهم، فقال: <q>﴿ذلكم بما كنتم تفرحون في الأرض بغير الحق﴾</q> الآية{2}. (ز) ",footnotes:1:تفسير مقاتل بن سليمان ٣/٧٢٠-٧٢١.أخرجه أبو عمرو الداني في المكتفى ص١٨٥ (٢٩).
  40,74,""
40,75," <q>﴿ذَ ٰ⁠لِكُم بِمَا كُنتُمۡ تَفۡرَحُونَ فِی ٱلۡأَرۡضِ بِغَیۡرِ ٱلۡحَقِّ وَبِمَا كُنتُمۡ تَمۡرَحُونَ ۝٧٥﴾</q> - تفسير ٦٨٢٤٣- عن عبد الله بن عباس -من طريق عطية العَوفيّ- في قوله: <q>﴿بِما كُنْتُمْ تَفْرَحُونَ فِي الأَرْضِ بِغَيْرِ الحَقِّ وبِما كُنْتُمْ تَمْرَحُونَ﴾</q> إلى <q>﴿فَبِئْسَ مَثْوى المُتَكَبِّرِينَ﴾</q>، قال: الفَرح والمَرح: الفخر والخُيلاء، والعمل في الأرض بالخطيئة، وكان ذلك في الشرك، وهو مِثل قوله لقارون: <q>﴿إذْ قالَ لَهُ قَوْمُهُ لا تَفْرَحْ إنَّ اللَّهَ لا يُحِبُّ الفَرِحِينَ﴾</q> [القصص:٧٦]، وذلك في الشرك{1}. (ز) ٦٨٢٤٤- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿بِما كُنْتُمْ تَفْرَحُونَ فِي الأَرْضِ بِغَيْرِ الحَقِّ وبِما كُنْتُمْ تَمْرَحُونَ﴾</q>، قال: تبْطَرُون، وتأْشَرون{2}. (ز) ٦٨٢٤٥- عن إسماعيل السُّدّيّ -من طريق أسباط- في قوله: <q>﴿تَمْرَحُونَ﴾</q>، قال: تبْطَرُون{1}. (ز) ٦٨٢٤٦- قال مقاتل بن سليمان: <q>﴿ذلِكُمْ﴾</q> السلاسل والأغلال والسَّحْب <q>﴿بِما كُنْتُمْ تَفْرَحُونَ فِي الأَرْضِ﴾</q> يعني: تبْطَرون مِن الخُيلاء والكبرياء <q>﴿بِغَيْرِ الحَقِّ وبِما كُنْتُمْ تَمْرَحُونَ﴾</q> يعني: تعصون في الأرض{4}. (ز) ",footnotes:1:أخرجه ابن جرير ٢٠/٣٦٦.تفسير مجاهد ص٥٨٤، وأخرجه الفريابي -كما في تغليق التعليق ٤/٣٠٠-، وابن جرير ٢٠/٣٦٦.أخرجه ابن جرير ٢٠/٣٦٦.تفسير مقاتل بن سليمان ٣/٧٢١.
40,76," <q>﴿ٱدۡخُلُوۤا۟ أَبۡوَ ٰ⁠بَ جَهَنَّمَ خَـٰلِدِینَ فِیهَاۖ فَبِئۡسَ مَثۡوَى ٱلۡمُتَكَبِّرِینَ ۝٧٦﴾</q> - تفسير ٦٨٢٤٧- قال مقاتل بن سليمان: <q>﴿ادْخُلُوا أبْوابَ جَهَنَّمَ﴾</q> السبع <q>﴿خالِدِينَ فِيها﴾</q> لا تموتون، <q>﴿فَبِئْسَ مَثْوى﴾</q> يعني: فبئس مأوى <q>﴿المُتَكَبِّرِينَ﴾</q> عن الإيمان{1}. (ز) ",footnotes:1:تفسير مقاتل بن سليمان ٣/٧٢١.
40,77," <q>﴿فَٱصۡبِرۡ إِنَّ وَعۡدَ ٱللَّهِ حَقࣱّۚ فَإِمَّا نُرِیَنَّكَ بَعۡضَ ٱلَّذِی نَعِدُهُمۡ أَوۡ نَتَوَفَّیَنَّكَ فَإِلَیۡنَا یُرۡجَعُونَ ۝٧٧﴾</q> - نزول الآية ٦٨٢٤٨- قال مقاتل بن سليمان: <q>﴿فاصْبِرْ إنَّ وعْدَ اللَّهِ حَقٌّ﴾</q>، وذلك أنّ النبيَّ ﷺ أخبر كفار مكة أنّ العذاب نازِل بهم، فكذّبوه، فأنزل الله ﷿ يعزِّي نبيه ﷺ ليصبر على تكذيبهم إيّاه بالعذاب، فقال: <q>﴿فاصْبِرْ إنَّ وعْدَ اللَّهِ حَقٌّ﴾</q>{1}. (ز) <q>﴿فَٱصۡبِرۡ إِنَّ وَعۡدَ ٱللَّهِ حَقࣱّۚ فَإِمَّا نُرِیَنَّكَ بَعۡضَ ٱلَّذِی نَعِدُهُمۡ أَوۡ نَتَوَفَّیَنَّكَ فَإِلَیۡنَا یُرۡجَعُونَ ۝٧٧﴾</q> - تفسير الآية ٦٨٢٤٩- قال مقاتل بن سليمان: <q>﴿فاصْبِرْ إنَّ وعْدَ اللَّهِ حَقٌّ﴾</q> في العذاب أنّه نازل بهم ببدر، <q>﴿فَإمّا نُرِيَنَّكَ﴾</q> في حياتك <q>﴿بَعْضَ الَّذِي نَعِدُهُمْ﴾</q> من العذاب في الدنيا؛ القتل ببدر، وسائر العذاب بعد الموت نازل بهم، <q>﴿أوْ نَتَوَفَّيَنَّكَ﴾</q> يا محمد قبل عذابهم في الدنيا <q>﴿فَإلَيْنا﴾</q> في الآخرة <q>﴿يُرْجَعُونَ﴾</q> يعني: يُردُّون؛ فنجزيهم بأعمالهم{1}. (ز) ",footnotes:1:تفسير مقاتل بن سليمان ٣/٧٢١.تفسير مقاتل بن سليمان ٣/٧٢١.
