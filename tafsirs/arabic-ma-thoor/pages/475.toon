quran[11]{c,v,t}:
  40,67,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿هُوَ ٱلَّذِی خَلَقَكُم مِّن تُرَابࣲ ثُمَّ مِن نُّطۡفَةࣲ ثُمَّ مِنۡ عَلَقَةࣲ ثُمَّ یُخۡرِجُكُمۡ طِفۡلࣰا﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٨٢١١<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span>، في قوله: <span class="qpc-hafs">﴿هُوَ الَّذِي خَلَقَكُمْ مِن تُرابٍ ثُمَّ مِن نُطْفَةٍ﴾</span>، قال: خلَق آدم من تراب، ثم خلق نسْله من نطفة{1}. (١٣/٧٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٨٢١٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿هُوَ الَّذِي خَلَقَكُمْ مِن تُرابٍ﴾</span> وذلك أنّ كفار مكة كذّبوا بالبعث، فأخبرهم الله عن بدءِ خلْقهم ليعتبروا في البعث، فقال تعالى: <span class="qpc-hafs">﴿هُوَ الَّذِي خَلَقَكُمْ مِن تُرابٍ﴾</span> يعني: آدم ﵇، <span class="qpc-hafs">﴿ثُمَّ مِن نُطْفَةٍ﴾</span> يعني: ذريته، <span class="qpc-hafs">﴿ثُمَّ مِن عَلَقَةٍ﴾</span> يعني: مثل الدم، <span class="qpc-hafs">﴿ثُمَّ يُخْرِجُكُمْ طِفْلًا﴾</span>{2}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿ثُمَّ لِتَبۡلُغُوۤا۟ أَشُدَّكُمۡ ثُمَّ لِتَكُونُوا۟ شُیُوخࣰاۚ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٨٢١٣<span class="dash">-</span></span> عن <span class="name-2">عامر الشعبي</span>، قال: يُثْغِر{3} الغلام لسبع، ويحتلم لأربع عشرة، وينتهي طوله لإحدى وعشرين، وينتهي عقله لثمانٍ وعشرين، ويبلغ أشدّه لثلاث وثلاثين{4}. (١٣/٧٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٨٢١٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ثُمَّ لِتَبْلُغُوا أشُدَّكُمْ﴾</span> يعني: ثماني عشرة سنة، فهو في الأشُدّ ما بين الثماني عشرة إلى الأربعين سنة، <span class="qpc-hafs">﴿ثُمَّ لِتَكُونُوا شُيُوخًا﴾</span> يعني: لكي تكونوا شيوخًا{2}<span class=comment-ref>٥٧١١</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٥٧١١</span> <span class="comment-type-4">ذكر</span> <u>ابنُ عطية</u> (٧/٤٥٥) أنه اختُلف في بلوغ الأشد؛ <b>فقيل</b>: ثلاثون. <b>وقيل</b>: ستة وثلاثون. <b>وقيل:</b> أربعون. <b>وقيل</b>: ستة وأربعون. <b>وقيل</b>: عشرون، <b>وقيل</b>: ثمانية عشر. <b>وقيل:</b> خمسة عشر.</p><p>و<span class="comment-type-2">انتقد</span> الثلاثة الأخيرة بقوله: «وهذه الأقوال الأخيرة ضعيفة في الأشد». ولم يذكر مستندًا.</div></p><p><h3><span class="qpc-hafs">﴿وَمِنكُم مَّن یُتَوَفَّىٰ مِن قَبۡلُۖ وَلِتَبۡلُغُوۤا۟ أَجَلࣰا مُّسَمࣰّى وَلَعَلَّكُمۡ تَعۡقِلُونَ ۝٦٧﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٨٢١٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ومِنكُمْ مَن يُتَوَفّى مِن قَبْلُ﴾</span> أن يكون شيخًا، <span class="qpc-hafs">﴿ولِتَبْلُغُوا أجَلًا مُسَمًّى﴾</span> يعني: الشيخ والشابّ جميعًا، <span class="qpc-hafs">﴿ولَعَلَّكُمْ﴾</span> يعني: ولكي <span class="qpc-hafs">﴿تَعْقِلُونَ﴾</span> يقول: لكي تعقلوا آثار ربكم في خلْقكم بأنّه قادر على أن يبعثكم كما خلَقكم{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٨٢١٦<span class="dash">-</span></span> عن <span class="name-3">عبد الملك ابن جُرَيْج</span>، <span class="qpc-hafs">﴿ومِنكُمْ مَن يُتَوَفّى مِن قَبْلُ﴾</span> قال: مِن قبل أن يكون شيخًا، <span class="qpc-hafs">﴿ولِتَبْلُغُوا أجَلًا مُسَمًّى﴾</span> الشيخ والشابّ، <span class="qpc-hafs">﴿ولَعَلَّكُمْ تَعْقِلُونَ﴾</span> عن ربكم أنّه يحييكم كما أماتكم، وهذه لأهل مكة، كانوا يُكَذِّبون بالبعث{7}. (١٣/٧٤)</p></p><p></div></p></div>",footnotes:1:عزاه السيوطي إلى عبد بن حميد.تفسير مقاتل بن سليمان ٣/٧١٩-٧٢٠.الإثغار: سقوط سن الصبي ونباتها. النهاية (ثغر).عزاه السيوطي إلى ابن أبي حاتم.تفسير مقاتل بن سليمان ٣/٧١٩-٧٢٠.تفسير مقاتل بن سليمان ٣/٧٢٠.عزاه السيوطي إلى ابن المنذر.
  40,68,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿هُوَ ٱلَّذِی یُحۡیِۦ وَیُمِیتُۖ فَإِذَا قَضَىٰۤ أَمۡرࣰا فَإِنَّمَا یَقُولُ لَهُۥ كُن فَیَكُونُ ۝٦٨﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٨٢١٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثم قال: <span class="qpc-hafs">﴿هُوَ﴾</span> الله <span class="qpc-hafs">﴿الَّذِي يُحْيِي﴾</span> الموتى <span class="qpc-hafs">﴿ويُمِيتُ﴾</span> الأحياء، <span class="qpc-hafs">﴿فَإذا قَضى أمْرًا﴾</span> كان في علمه، يعني: البعث <span class="qpc-hafs">﴿فَإنَّما يَقُولُ لَهُ كُنْ فَيَكُونُ﴾</span> مرة واحدة لا يثني قوله{1}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٣/٧٢٠.
  40,69,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿أَلَمۡ تَرَ إِلَى ٱلَّذِینَ یُجَـٰدِلُونَ فِیۤ ءَایَـٰتِ ٱللَّهِ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٨٢١٨<span class="dash">-</span></span> عن <span class="name-2">محمد بن سيرين</span> -من طريق داود بن أبي هند- قال: إن لم تكن هذه الآية نزلت في القَدَرية فإني لا أدري فيمن نزلت: <span class="qpc-hafs">﴿ألَمْ تَرَ إلى الَّذِينَ يُجادِلُونَ فِي آياتِ اللَّهِ أنّى يُصْرَفُونَ﴾</span> إلى قوله: <span class="qpc-hafs">﴿لَمْ نَكُنْ نَدْعُو مِن قَبْلُ شَيْئًا كَذَلِكَ يُضِلُّ اللَّهُ الكافِرِين﴾</span>{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٨٢١٩<span class="dash">-</span></span> عن أبي قبيل، قال: أخبرني عقبة بن عامر الجهني أنّ رسول الله ﷺ قال: «<b>سيهْلَك مِن أمتي أهل الكتاب، وأهل اللَّبَن</b>». فقال عقبة: يا رسول الله، وما أهل الكتاب؟ قال: «<b>قوم يتعلّمون كتاب الله يجادلون الذين آمنوا</b>». فقال عقبة: يا رسول الله، وما أهل اللَّبَن؟ قال: «<b>قوم يتّبعون الشهوات، ويضيِّعون الصلوات</b>». قال <span class="name-2">أبو قبيل</span>: لا أحسب المكذِّبين بالقَدَر إلّا الذين يجادلون الذين آمنوا، وأما أهل اللَّبَن فلا أحسبهم إلّا أهل العمود، ليس عليهم إمام جماعة، ولا يعرفون شهر رمضان{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٨٢٢٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ألَمْ تَرَ إلى الَّذِينَ يُجادِلُونَ فِي آياتِ اللَّهِ﴾</span>، يعني: آيات القرآن، أنه ليس من الله ﷿ ... يعني: كفار مكة{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٨٢٢١<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿ألَمْ تَرَ إلى الَّذِينَ يُجادِلُونَ فِي آياتِ اللَّهِ أنّى يُصْرَفُونَ﴾</span>، قال: هؤلاء المشركون{4}<span class=comment-ref>٥٧١٢</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٥٧١٢</span> اختُلف في الذين عُنوا بهذه الآية على قولين: <b>الأول</b>: أنهم أهل القدر. <b>الثاني</b>: أنهم أهل الشرك.</p><p>و<span class="comment-type-3">رجَّح</span> <u>ابنُ جرير</u> (٢٠/٣٦٢) <span class="mustanad">مستندًا إلى السياق</span> القول الثاني الذي قاله ابن زيد، ومقاتل، فقال: «والصواب من القول في ذلك ما قاله ابن زيد؛ وقد بيّن الله حقيقة ذلك بقوله: <span class="qpc-hafs">﴿الذين كذبوا بالكتاب وبما أرسلنا به رسلنا﴾</span>».</p><p>وكذا <span class="comment-type-3">رجَّحه</span> <u>ابنُ عطية</u> (٧/٤٥٦) <span class="mustanad">مستندًا إلى السياق</span>، فقال: «ظاهر الآية أنها في الكفار المجادلين في رسالة محمد ﷺ والكتاب الذي جاء به، بدليل قوله: <span class="qpc-hafs">﴿الَّذِينَ كَذَّبُوا بِالكِتابِ﴾</span>، وهذا قول ابن زيد والجمهور من المفسرين».</p><p>و<span class="comment-type-4">علَّق</span> على القول الثاني بقوله: «ويلزم قائلي هذه المقالة أن يجعلوا قوله تعالى: <span class="qpc-hafs">﴿الَّذِينَ كَذَّبُوا﴾</span> الآية ... كلامًا مقطوعًا مستأنفًا في الكفار». و<span class="comment-type-4">ذكر</span> أنهم رووا حديثًا في نحو ما قالوا من أنّهم أهل القدر.</div></p><p><h3><span class="qpc-hafs">﴿أَنَّىٰ یُصۡرَفُونَ ۝٦٩﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٨٢٢٢<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿أنّى يُصْرَفُونَ﴾</span>، قال: أنى يكذِّبون ويعدلون؟!{5}. (١٣/٧٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٨٢٢٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿أنّى يُصْرَفُونَ﴾</span>، يقول: مِن أين يعدلون عنه إلى غيره؟! يعني: كفار مكة{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٨٢٢٤<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿أنّى يُصْرَفُون﴾</span>، قال: يُصرَفون عن الحق{4}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ٢٠/٣٦٠-٣٦١، وفي لفظ: إن لم يكن أهل القدر الذين يخوضون في آيات الله فلا علم لنا به.أخرجه أحمد ٢٨/٥٥٥-٥٥٦ (١٧٣١٨)، ٢٨/٦٣٢ (١٧٤١٥)، ٢٨/٦٣٦ (١٧٤٢١) بنحوه، والحاكم ٢/٤٠٦ (٣٤١٧)، وابن جرير ٢٠/٣٦١ واللفظ له، والثعلبي ٨/٢٨١.</p><p>قال الحاكم: «هذا حديث صحيح الإسناد، ولم يخرجاه».تفسير مقاتل بن سليمان ٣/٧٢٠.أخرجه ابن جرير ٢٠/٣٦٠، ٣٦٢.أخرجه ابن جرير ٢٠/٣٦٠. وعزاه السيوطي إلى عبد بن حميد.تفسير مقاتل بن سليمان ٣/٧٢٠.أخرجه ابن جرير ٢٠/٣٦٠، ٣٦٢.
  40,70,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿ٱلَّذِینَ كَذَّبُوا۟ بِٱلۡكِتَـٰبِ وَبِمَاۤ أَرۡسَلۡنَا بِهِۦ رُسُلَنَاۖ فَسَوۡفَ یَعۡلَمُونَ ۝٧٠﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٨٢٢٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثم أخبر عنهم، فقال تعالى: <span class="qpc-hafs">﴿الَّذِينَ كَذَّبُوا بِالكِتابِ﴾</span> يعني: بالقرآن، <span class="qpc-hafs">﴿وبِما أرْسَلْنا بِهِ رُسُلَنا﴾</span> يعني: محمدًا ﷺ، أُرسل بالتوحيد، فأوعدهم في الآخرة فقال: <span class="qpc-hafs">﴿فَسَوْفَ يَعْلَمُونَ﴾</span> هذا وعيد{1}<span class=comment-ref>٥٧١٣</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٥٧١٣</span> <span class="comment-type-4">ذكر</span> <u>ابنُ عطية</u> (٧/٤٥٦) أن «الذين» ابتداء وخبره: <span class="qpc-hafs">﴿فَسَوْفَ يَعْلَمُونَ﴾</span>، ثم ساق <b>احتمالًا آخر</b>، فقال: «ويحتمل أن يكون خبر الابتداء محذوفًا، والفاء متعلقة به».</div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٣/٧٢٠.
  40,71,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿إِذِ ٱلۡأَغۡلَـٰلُ فِیۤ أَعۡنَـٰقِهِمۡ وَٱلسَّلَـٰسِلُ یُسۡحَبُونَ ۝٧١ فِی ٱلۡحَمِیمِ﴾</span> - قراءات</h3></p><p><div></p><p><p><span class="item-no">٦٨٢٢٦<span class="dash">-</span></span> قال هارون: وفي قراءة <span class="name-1">أُبي</span>: (إذِ الأَغْلالُ فِي أعْناقِهِمْ وبِالسَّلاسِلِ يُسْحَبُونَ){1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٨٢٢٧<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق أبي الجوزاء- أنه قرأ: (والسَّلاسِلَ) بنصب، (يَسْحَبُونَ) بنصب الياء، وذلك أشد عليهم وهم يَسحبون السلاسل{2}<span class=comment-ref>٥٧١٤</span>. (١٣/٧٥)</p></p><p></div></p><p><div><span class=comment-ref>٥٧١٤</span> اختُلف في قراءة قوله: <span class="qpc-hafs">﴿والسلاسل يسحبون﴾</span>؛ <b>فقرأ قوم</b>: <span class="qpc-hafs">﴿والسلاسلُ﴾</span> بالرفع. <b>وقرأ غيرهم</b> بنصبها وفتح <span class="qpc-hafs">﴿يسحبون﴾</span>.</p><p>و<span class="comment-type-4">ذكر</span> <u>ابنُ جرير</u> (٢٠/٣٦٣) أن الأولى جاءت بالرفع عطفًا على <span class="qpc-hafs">﴿الأغلال﴾</span>. وأن القراءة الثانية بمعنى: ويسحبون السلاسل.</p><p>و<span class="comment-type-4">بنحوه</span> قال <u>ابنُ عطية</u> (٧/٤٥٦).</p><p>و<span class="comment-type-3">رجَّح</span> <u>ابنُ جرير</u> (٢٠/٣٦٤) قراءة الرفع <span class="mustanad">مستندًا إلى إجماع القراء</span>، فقال: «والصواب من القراءة عندنا في ذلك ما عليه قراء الأمصار؛ لإجماع الحجة عليه، وهو رفع»السلاسل«عطفًا بها على ما في قوله: <span class="qpc-hafs">﴿في أعناقهم﴾</span> من ذكر الأغلال».</div></p><p><div></p><p><p><span class="item-no">٦٨٢٢٨<span class="dash">-</span></span> قال هارون: وقال <span class="name-2">الحسن البصري</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٨٢٢٩<span class="dash">-</span></span> و<span class="name-2">أبو عمرو</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٨٢٣٠<span class="dash">-</span></span> و<span class="name-2">الأعرج</span>: <span class="qpc-hafs">﴿إذِ الأَغْلالُ فِي أعْناقِهِمْ والسَّلاسِلُ يُسْحَبُونَ﴾</span>، يقول: يُفعل بهم ذلك{3}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿إِذِ ٱلۡأَغۡلَـٰلُ فِیۤ أَعۡنَـٰقِهِمۡ وَٱلسَّلَـٰسِلُ یُسۡحَبُونَ ۝٧١ فِی ٱلۡحَمِیمِ﴾</span> - تفسير الآية</h3></p><p><div></p><p><p><span class="item-no">٦٨٢٣١<span class="dash">-</span></span> عن عبد الله بن عمرو، قال: تلا رسول الله ﷺ: <span class="qpc-hafs">﴿إذِ الأَغْلالُ فِي أعْناقِهِمْ والسَّلاسِلُ﴾</span> إلى قوله: <span class="qpc-hafs">﴿يُسْجَرُونَ﴾</span>، فقال: «<b>لو أنّ رَصاصة مثل هذه -وأشار إلى جُمجمة- أُرسلت مِن السماء إلى الأرض، وهي مسيرة خمسمائة سنة، لبَلغَت الأرضَ قبل الليل، ولو أنها أُرسلت مِن رأس السلسلة لسارت أربعين خريفًا الليلَ والنهارَ قبل أن تبلغ أصلها -</b>أو قال: <b>قعرها-</b>»{4}. (١٣/٧٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٨٢٣٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق أبي منصور مولى سليم- قال: <span class="qpc-hafs">﴿يُسْحَبُونَ فِي الحَمِيمِ﴾</span>: فيُسلَخ كل شيء عليهم؛ من جِلد ولحم وعِرْق، حتى يصير في عقبه، حتى إنّ لحمه قدْر طوله، وطوله ستون ذراعًا، ثم يُكسى جلدًا آخر، ثم يُسجر في الحميم{5}. (١٣/٧٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٨٢٣٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثم أخبر عن الوعيد، فقال: <span class="qpc-hafs">﴿إذِ الأَغْلالُ فِي أعْناقِهِمْ والسَّلاسِلُ يُسْحَبُونَ﴾</span> على الوجوه، <span class="qpc-hafs">﴿فِي الحَمِيمِ﴾</span> يعني: حرّ النار{6}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿ثُمَّ فِی ٱلنَّارِ یُسۡجَرُونَ ۝٧٢﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٨٢٣٤<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿يُسْجَرُونَ﴾</span>، قال: تُوقد بهم النار{7}<span class=comment-ref>٥٧١٥</span>. (١٣/٧٦)</p></p><p></div></p><p><div><span class=comment-ref>٥٧١٥</span> ساق <u>ابنُ عطية</u> (٧/٤٥٧) هذا القول، ثم <span class="comment-type-4">علَّق</span> بقوله: «والعرب تقول: سجرت التنّور: إذا ملأتها».</div></p><p><div></p><p><p><span class="item-no">٦٨٢٣٥<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدّيّ</span> -من طريق أسباط- في قوله: <span class="qpc-hafs">﴿ثُمَّ فِي النّارِ يُسْجَرُون﴾</span>، قال: يُحرَقون في النار{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٨٢٣٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ثُمَّ فِي النّارِ يُسْجَرُونَ﴾</span>، يعني: يُوقدون، فصاروا وقودها{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٨٢٣٧<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿ثُمَّ فِي النّارِ يُسْجَرُونَ﴾</span>: يُسجرون في النار؛ يُوقد عليهم فيها{8}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿ثُمَّ فِی ٱلنَّارِ یُسۡجَرُونَ ۝٧٢﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٦٨٢٣٨<span class="dash">-</span></span> عن يعلى بن مُنْيَة، رفع الحديث إلى رسول الله ﷺ، قال: «<b>ينشىء الله سحابةً لأهل النار سوداء مظلمة، ويُقال لأهل النار: أيَّ شيء تطلبون؟ فيذْكُرون بها سحاب الدنيا، فيقولون: يا ربَّنا، الشراب. فتُمْطِرُهم أغلالًا تزيد في أغلالهم، وسلاسل تزيد في سلاسلهم، وجمرًا يُلهب عليهم</b>»{11}. (١٣/٧٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٨٢٣٩<span class="dash">-</span></span> عن سعيد بن عبيد، قال: كان <span class="name-2">سعيد بن جُبير</span> إذا أتى على هذه الآية: <span class="qpc-hafs">﴿فسوف يعلمون إذ الأغلال في أعناقهم والسلاسل يسحبون في الحميم ثم في النار يسجرون﴾</span> رجّع فيها، وردّدها مرتين أو ثلاثًا{12}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٨٢٤٠<span class="dash">-</span></span> عن <span class="name-2">التيمي</span> -من طريق ابنه- قال: لو أنّ غُلًّا مِن أغلال جهنم وُضِع على جبلٍ لَوَهَصَهُ{13} حتى يبلغ الماء الأسود{14}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه إسحاق البستي ص٢٨٥.</p><p>وهي قراءة شاذة. انظر: البحر المحيط ٧/٤٥٤.أخرجه إسحاق البستي ص٢٨٥، والثعلبي ٨/٢٨٢. وعزاه السيوطي إلى ابن أبي حاتم.</p><p>وهي قراءة شاذة، تروى أيضًا عن ابن مسعود، ويحيى بن وثاب. انظر: مختصر ابن خالويه ص١٣٣، والمحتسب ٢/٢٤٤.أخرجه إسحاق البستي ص٢٨٥.</p><p>وهي قراءة العشرة.أخرجه الحاكم ٢/٤٧٦ (٣٦٤٠)، وأخرجه أحمد ١١/٤٤٣-٤٤٥ (٦٨٥٦، ٦٨٥٧)، والترمذي ٤/٥٤٣-٥٤٤ (٢٧٧٠)، وابن جرير ٢٣/٢٣٨ دون ذكر الآية.</p><p>قال الترمذي: «هذا حديث إسناده حسن». وقال الحاكم: «هذا حديث صحيح الإسناد، ولم يخرجاه». وقال البغوي في شرح السنة ١٥/٢٤٨-٢٤٩ (٤٤١١): «حديث حسن».أخرجه ابن أبي الدنيا في صفة النار -موسوعة الإمام ابن أبي الدنيا ٦/٤٢٤ (١١١)-.تفسير مقاتل بن سليمان ٣/٧٢٠.تفسير مجاهد ص٥٨٤، وأخرجه الفريابي -كما في تغليق التعليق ٤/٣٠٠-، وابن جرير ٢٠/٣٦٤. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.أخرجه ابن جرير ٢٠/٣٦٤.تفسير مقاتل بن سليمان ٣/٧٢٠.أخرجه ابن جرير ٢٠/٣٦٤.أخرجه ابن أبي الدنيا في كتاب صفة النار ص٥٢-٥٣ (٦٢) ولم يذكر الرفع، والطبراني في الأوسط ٤/٢٤٧-٢٤٨ (٤١٠٣)، وابن أبي حاتم -كما في تفسير ابن كثير ٧/١٥٨-.</p><p>قال الطبراني: «لا يُروى هذا الحديث عن يعلى إلا بهذا الإسناد، تفرّد به منصور». وقال ابن كثير: «هذا حديث غريب». وقال الهيثمي في المجمع ١٠/٣٩٠ (١٨٥٩٨): «رواه الطبراني في الأوسط، وفيه مَن فيه ضعفٌ قليل، ومَن لم أعرفه». وقال الألباني في الضعيفة ١١/٦٧٦ (٥٤٠٣): «ضعيف».أخرجه إسحاق البستي ص٢٨٦.وهصه: كسره ودقّه. لسان العرب (وهـص).أخرجه عبد الرزاق ٢/١٨٣.
  40,72,""
  40,73,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿ثُمَّ قِیلَ لَهُمۡ أَیۡنَ مَا كُنتُمۡ تُشۡرِكُونَ ۝٧٣ مِن دُونِ ٱللَّهِۖ قَالُوا۟ ضَلُّوا۟ عَنَّا بَل لَّمۡ نَكُن نَّدۡعُوا۟ مِن قَبۡلُ شَیۡـࣰٔاۚ كَذَ ٰ⁠لِكَ یُضِلُّ ٱللَّهُ ٱلۡكَـٰفِرِینَ ۝٧٤﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٨٢٤١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ثُمَّ قِيلَ لَهُمْ﴾</span> قبل دخول النار، يعني: تقول لهم الخزنة: <span class="qpc-hafs">﴿أيْنَ ما كُنْتُمْ تُشْرِكُونَ﴾</span> يعني: تعبدون <span class="qpc-hafs">﴿مِن دُونِ اللَّهِ﴾</span> فهل يمنعونكم مِن النار؟! يعني: الآلهة، <span class="qpc-hafs">﴿قالُوا ضَلُّوا عَنّا﴾</span> ضلّت عنا الآلهة، <span class="qpc-hafs">﴿بَلْ لَمْ نَكُنْ نَدْعُوا مِن قَبْلُ شَيْئًا﴾</span> يعني: لم نكن نعبد من قبل في الدنيا شيئًا، إن الذي كنا نعبد كان باطلًا، لم يكن شيئًا، <span class="qpc-hafs">﴿كَذلِكَ﴾</span> يعني: هكذا <span class="qpc-hafs">﴿يُضِلُّ اللَّهُ الكافِرِينَ﴾</span>{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٨٢٤٢<span class="dash">-</span></span> عن <span class="name-3">يحيى بن سلّام</span> -من طريق أحمد- في قوله: <span class="qpc-hafs">﴿بل لم نكن ندعو من قبل شيئًا﴾</span> أي: ينفعنا ولا يضرّنا، قال الله ﷿: <span class="qpc-hafs">﴿كذلك يضل الله الكافرين﴾</span>. ثم رجع إلى قصتهم، فقال: <span class="qpc-hafs">﴿ذلكم بما كنتم تفرحون في الأرض بغير الحق﴾</span> الآية{2}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٣/٧٢٠-٧٢١.أخرجه أبو عمرو الداني في المكتفى ص١٨٥ (٢٩).
  40,74,""
  40,75,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿ذَ ٰ⁠لِكُم بِمَا كُنتُمۡ تَفۡرَحُونَ فِی ٱلۡأَرۡضِ بِغَیۡرِ ٱلۡحَقِّ وَبِمَا كُنتُمۡ تَمۡرَحُونَ ۝٧٥﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٨٢٤٣<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطية العَوفيّ- في قوله: <span class="qpc-hafs">﴿بِما كُنْتُمْ تَفْرَحُونَ فِي الأَرْضِ بِغَيْرِ الحَقِّ وبِما كُنْتُمْ تَمْرَحُونَ﴾</span> إلى <span class="qpc-hafs">﴿فَبِئْسَ مَثْوى المُتَكَبِّرِينَ﴾</span>، قال: الفَرح والمَرح: الفخر والخُيلاء، والعمل في الأرض بالخطيئة، وكان ذلك في الشرك، وهو مِثل قوله لقارون: <span class="qpc-hafs">﴿إذْ قالَ لَهُ قَوْمُهُ لا تَفْرَحْ إنَّ اللَّهَ لا يُحِبُّ الفَرِحِينَ﴾</span> [القصص:٧٦]، وذلك في الشرك{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٨٢٤٤<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿بِما كُنْتُمْ تَفْرَحُونَ فِي الأَرْضِ بِغَيْرِ الحَقِّ وبِما كُنْتُمْ تَمْرَحُونَ﴾</span>، قال: تبْطَرُون، وتأْشَرون{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٨٢٤٥<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدّيّ</span> -من طريق أسباط- في قوله: <span class="qpc-hafs">﴿تَمْرَحُونَ﴾</span>، قال: تبْطَرُون{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٨٢٤٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ذلِكُمْ﴾</span> السلاسل والأغلال والسَّحْب <span class="qpc-hafs">﴿بِما كُنْتُمْ تَفْرَحُونَ فِي الأَرْضِ﴾</span> يعني: تبْطَرون مِن الخُيلاء والكبرياء <span class="qpc-hafs">﴿بِغَيْرِ الحَقِّ وبِما كُنْتُمْ تَمْرَحُونَ﴾</span> يعني: تعصون في الأرض{4}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ٢٠/٣٦٦.تفسير مجاهد ص٥٨٤، وأخرجه الفريابي -كما في تغليق التعليق ٤/٣٠٠-، وابن جرير ٢٠/٣٦٦.أخرجه ابن جرير ٢٠/٣٦٦.تفسير مقاتل بن سليمان ٣/٧٢١.
  40,76,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿ٱدۡخُلُوۤا۟ أَبۡوَ ٰ⁠بَ جَهَنَّمَ خَـٰلِدِینَ فِیهَاۖ فَبِئۡسَ مَثۡوَى ٱلۡمُتَكَبِّرِینَ ۝٧٦﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٨٢٤٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ادْخُلُوا أبْوابَ جَهَنَّمَ﴾</span> السبع <span class="qpc-hafs">﴿خالِدِينَ فِيها﴾</span> لا تموتون، <span class="qpc-hafs">﴿فَبِئْسَ مَثْوى﴾</span> يعني: فبئس مأوى <span class="qpc-hafs">﴿المُتَكَبِّرِينَ﴾</span> عن الإيمان{1}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٣/٧٢١.
  40,77,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿فَٱصۡبِرۡ إِنَّ وَعۡدَ ٱللَّهِ حَقࣱّۚ فَإِمَّا نُرِیَنَّكَ بَعۡضَ ٱلَّذِی نَعِدُهُمۡ أَوۡ نَتَوَفَّیَنَّكَ فَإِلَیۡنَا یُرۡجَعُونَ ۝٧٧﴾</span> - نزول الآية</h3></p><p><div></p><p><p><span class="item-no">٦٨٢٤٨<span class="dash">-</span></span> قال مقاتل بن سليمان: <span class="qpc-hafs">﴿فاصْبِرْ إنَّ وعْدَ اللَّهِ حَقٌّ﴾</span>، وذلك أنّ النبيَّ ﷺ أخبر كفار مكة أنّ العذاب نازِل بهم، فكذّبوه، فأنزل الله ﷿ يعزِّي نبيه ﷺ ليصبر على تكذيبهم إيّاه بالعذاب، فقال: <span class="qpc-hafs">﴿فاصْبِرْ إنَّ وعْدَ اللَّهِ حَقٌّ﴾</span>{1}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿فَٱصۡبِرۡ إِنَّ وَعۡدَ ٱللَّهِ حَقࣱّۚ فَإِمَّا نُرِیَنَّكَ بَعۡضَ ٱلَّذِی نَعِدُهُمۡ أَوۡ نَتَوَفَّیَنَّكَ فَإِلَیۡنَا یُرۡجَعُونَ ۝٧٧﴾</span> - تفسير الآية</h3></p><p><div></p><p><p><span class="item-no">٦٨٢٤٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فاصْبِرْ إنَّ وعْدَ اللَّهِ حَقٌّ﴾</span> في العذاب أنّه نازل بهم ببدر، <span class="qpc-hafs">﴿فَإمّا نُرِيَنَّكَ﴾</span> في حياتك <span class="qpc-hafs">﴿بَعْضَ الَّذِي نَعِدُهُمْ﴾</span> من العذاب في الدنيا؛ القتل ببدر، وسائر العذاب بعد الموت نازل بهم، <span class="qpc-hafs">﴿أوْ نَتَوَفَّيَنَّكَ﴾</span> يا محمد قبل عذابهم في الدنيا <span class="qpc-hafs">﴿فَإلَيْنا﴾</span> في الآخرة <span class="qpc-hafs">﴿يُرْجَعُونَ﴾</span> يعني: يُردُّون؛ فنجزيهم بأعمالهم{1}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٣/٧٢١.تفسير مقاتل بن سليمان ٣/٧٢١.