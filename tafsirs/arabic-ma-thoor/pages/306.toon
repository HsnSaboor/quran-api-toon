quran[14]{c,v,t}:
19,12," <q>﴿یَـٰیَحۡیَىٰ خُذِ ٱلۡكِتَـٰبَ بِقُوَّةࣲۖ﴾</q> - تفسير ٤٦٢١٥- قال عبد الله بن عباس -من طريق مقاتل وجويبر عن الضحاك-: فَوُلِد له يحيى على ما بشَّره الله نبيًّا تقيًّا صالِحًا، <q>﴿يا يحيى خذ الكتاب بقوة﴾</q>، يعني: بجِدٍّ، وطاعة، واجتهاد، وشكر، وبالعمل بما فيه{1}. (١٠/٢٥) ٤٦٢١٦- عن سعيد بن جبير، في قوله: <q>﴿خذ الكتاب بقوة﴾</q>، يقول: اعمل بما فيه من فرائضه{2}. (١٠/٢١) ٤٦٢١٧- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿يا يحيى خذ الكتاب بقوة﴾</q>، قال: بجِدٍّ{3}. (١٠/٢١) ٤٦٢١٨- عن قتادة بن دعامة -من طريق معمر- في قوله: <q>﴿خذ الكتاب بقوة﴾</q>، قال: بجِدٍّ{4}. (ز) ٤٦٢١٩- قال إسماعيل السُّدِّيّ: يعني: بالجِدِّ، والمُواظَبَة{5}. (ز) ٤٦٢٢٠- قال مقاتل بن سليمان: <q>﴿يا يحيى خذ الكتاب﴾</q> يعني: التوراة <q>﴿بقوة﴾</q> يعني: بجِدٍّ، ومواظبة عليه{6}. (ز) ٤٦٢٢١- قال عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿يا يحيى خذ الكتاب بقوة﴾</q>: أن يعمل بما أمره الله، ويُجانِبَ فيه ما نهاه الله{7}. (ز) <q>﴿وَءَاتَیۡنَـٰهُ ٱلۡحُكۡمَ صَبِیࣰّا ۝١٢﴾</q> - تفسير ٤٦٢٢٢- عن عبد الله بن عباس، عن النبي ﷺ، في قوله: <q>﴿وآتيناه الحكم صبيا﴾</q>، قال: «أُعْطِي الفَهْم والعِبادة وهو ابن سبع سنين»{8}. (١٠/٢١) ٤٦٢٢٣- عن الضحاك، عن ابن عباس، قال: قال رسول الله ﷺ: «قال الغِلمان ليحيى بن زكريا: اذهب بنا نلعب. فقال يحيى: ما لِلَّعِب خُلِقْنا، اذهبوا نُصَلِّي. فهو قول الله تعالى: <q>﴿وآتيناه الحكم صبيا﴾</q>»{9}. (١٠/٢٢) ٤٦٢٢٤- عن قتادة بن دعامة -من طريق معمر- قال: جاء الغِلمان إلى يحيى بن زكريا، فقالوا: اخرج بنا نلعب. فقال: ما لِلَّعِب خُلِقْتُ. قال: فأنزل الله: <q>﴿وآتيناه الحكم صبيا﴾</q>{10}. (١٠/٢٢) ٤٦٢٢٥- عن معاذ بن جبل، مرفوعًا{11}. (١٠/٢٢) ٤٦٢٢٦- قال عبد الله بن عباس: النبوة{12}٤١٣٧. (ز) ٤١٣٧ ذكر ابنُ عطية (٦/١٣) هذا القول منسوبًا للحسن، وعلَّق بقوله: «وفي لفظة»صبي«على هذا تَجَوُّز، واستصحاب حال». ٤٦٢٢٧- عن عبد الله بن عباس -من طريق مقاتل وجويبر عن الضحاك- في قوله: <q>﴿وآتيناه الحكم﴾</q> يعني: الفهم، <q>﴿صبيا﴾</q> يعني: [صغيرًا]. وذلك أنه مرَّ على صِبية أتْرابٍ له يلعبون على شاطِئ نهر بطِينٍ وبماء، فقالوا: يا يحيى، تعال حتى نلعب. فقال: سبحان الله! أوَلِلَّعِبِ خُلِقْنا؟!{1}. (١٠/٢٥) ٤٦٢٢٨- عن مجاهد بن جبر، في قوله: <q>﴿وآتيناه الحكم صبيا﴾</q>، قال: الفَهْم{14}. (١٠/٢١) ٤٦٢٢٩- عن مجاهد بن جبر -من طريق سفيان، عن رجل- <q>﴿وآتيناه الحكم صبيا﴾</q>، قال: القرآن{15}. (ز) ٤٦٢٣٠- عن مالك بن دينار، قال: سألنا عكرمة عن قوله: <q>﴿وآتيناه الحكم صبيا﴾</q>. قال: اللُّبَّ{16}. (١٠/٢١) ٤٦٢٣١- عن قتادة بن دعامة، في قوله: <q>﴿وآتيناه الحكم صبيا﴾</q>، قال: وهو ابن ثلاث سنين{17}. (١٠/٢٢) ٤٦٢٣٢- عن إسماعيل السُّدِّيّ: <q>﴿وآتيناه الحكم صبيا﴾</q>، يعني: الفهم، والعقل{18}. (ز) ٤٦٢٣٣- قال مقاتل بن سليمان: <q>﴿وآتيناه الحكم صبيا﴾</q>، يعني: وأعطينا يحيى العلم والفهم، وهو ابن ثلاث سنين{6}. (ز) ٤٦٢٣٤- قال ابن وهب: وقال لي مالك [بن أنس]، وذكر قول الله ﷿ في يحيى: <q>﴿وآتيناه الحكم صبيا﴾</q>، وقوله في عيسى: <q>﴿قد جئتكم بالحكمة﴾</q> [الزخرف:٦٣]، وقوله: <q>﴿ويعلمه الكتاب والحكمة﴾</q> [آل عمران:٤٨]، وقوله: <q>﴿واذكرن ما يتلى في بيوتكن من آيات الله والحكمة﴾</q> [الأحزاب:٣٤]، قال مالك: الحِكمة في هذا كلِّه: طاعةُ الله، والاتباع لها، والفقه في دين الله، والعملُ به{20}. (ز) ٤٦٢٣٥- عن مَعْمَر بن راشد -من طريق ابن المبارك- في قوله: <q>﴿وآتيناه الحكم صبيا﴾</q>، قال: بلغني: أنّ الصبيان قالوا ليحيى بن زكريا: اذهب بنا نلعب. قال: ما لِلَّعِب خُلِقْتُ. فهو قوله: <q>﴿وآتيناه الحكم صبيا﴾</q>{21}. (١٠/٢٢) ٤٦٢٣٦- قال يحيى بن سلّام: وبلغنا: أنّه كان في صِغَرِه يقول له الصبيان: يا يحيى، تعال نلعبْ. فيقول: ليس لِلَّعِب خُلِقْنا{22}. (ز) <q>﴿وَءَاتَیۡنَـٰهُ ٱلۡحُكۡمَ صَبِیࣰّا ۝١٢﴾</q> - آثار متعلقة بالآية ٤٦٢٣٧- عن ابن عباس، قال: قال رسول الله ﷺ: «مَن قرأ القرآن قبل أن يَحْتَلِم فقد أُوتِي الحُكْم صَبِيًّا»{23}. (١٠/٢٣) ٤٦٢٣٨- وعن عبد الله بن عباس، موقوفًا{2}. (١٠/٢٣) ",footnotes:1:أخرجه ابن عساكر ٦٤/١٦٩-١٧٣. وعزاه السيوطي إلى إسحاق بن بشر.عزاه السيوطي إلى ابن أبي حاتم.تفسير مجاهد ص٤٥٤ بلفظ: بجِدٍّ في طاعة الله ﷿، وأخرجه باللفظ المختصر المثبت في المتن ابن جرير ١٥/٤٧٤، وإسحاق البستي في تفسيره ص١٧٦ من طريق ابن جريج. وعلقه يحيى بن سلام ١/٢١٦. وعزاه السيوطي إلى ابن أبي شيبة، وعبد بن حميد، وابن المنذر، وابن أبي حاتم.أخرجه ابن جرير ١٥/٤٧٣.علقه يحيى بن سلام ١/٢١٦.تفسير مقاتل بن سليمان ٢/٦٢٢.أخرجه ابن جرير ١٥/٤٧٤.أورده الديلمي في الفردوس ٤/٤٠٢ (٧١٦٨).عزاه السيوطي إلى الحاكم في تاريخه من طريق نهشل بن سعيد. قال المناوي في فيض القدير ٤/٢٨ (٤٤٣٩) «بسند واه».عزاه السيوطي إلى عبد الرزاق، وعبد بن حميد.أخرجه ابن عساكر في تاريخه ٦٤/١٨٣ بنحوه. قال العجلوني في كشف الخفاء ١/٥١٥: «رواه ابن عساكر بإسناد ضعيف عن معاذ».تفسير البغوي ٥/٢٢١.أخرجه ابن عساكر ٦٤/١٦٩-١٧٣. وعزاه السيوطي إلى إسحاق بن بشر.عزاه السيوطي إلى ابن أبي شيبة، وعبد بن حميد، وابن المنذر، وابن أبي حاتم.أخرجه ابن أبي شيبة في مصنفه (ت: محمد عوامة) ١٦/٥٦٦ (٣٢٥٦٦).أخرجه ابن أبي شيبة في مصنفه (ت: محمد عوامة) ١٦/٥٦٦ (٣٢٥٦٥) قال: حدثنا وكيع، عن إسماعيل بن سليمان العبدي، عن رجل مِنهم يُقال له: مهدي، عن عكرمة به. وعزاه السيوطي إلى ابن المنذر من طريق مالك بن دينار المذكور في المتن.عزاه السيوطي إلى عبد الله بن أحمد في زوائد الزهد، وابن أبي حاتم.علقه يحيى بن سلام ١/٢١٧.تفسير مقاتل بن سليمان ٢/٦٢٢.أخرجه ابن وهب في الجامع ٢/١٣٠-١٣١ (٢٥٧) بنحوه، وعنه ابن عبد البر في جامع بيان العلم وفضله ١/٨٣ بزيادة -وهي في جامع ابن وهب بنحوها-: قال مالك: ومما يبين ذلك أنك تجد رجلًا عاقلًا في أمر الدنيا ذا نظر فيها وبصرٍ بها ولا علم له بدينه-، وتجد آخر ضعيفًا في أمر دنياه، عالِمًا بأمر دينه، بصيرًا به، يؤتيه الله إياه ويحرمه هذا؛ فالحكمة: الفقه في دين الله.أخرجه أحمد في الزهد ص٧٦، ٩٠، وابن أبي الدنيا في كتاب الرقة والبكاء -موسوعة ابن أبي الدنيا ٣/٢٥١ (٤٠٣)- من طريق ابن المبارك، وابن جرير ١٥/٤٧٤، وابن عساكر ٦٤/١٨٣. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم، والخرائطي.تفسير يحيى بن سلام ١/٢١٧.أخرجه البيهقي في شعب الإيمان ٣/٣٤٣ (١٧٩٨)، من طريق مسلم بن إبراهيم، قال: حدثنا الحسن بن أبي جعفر، حدثنا أبو الصهباء، عن سعيد بن جبير، عن ابن عباس به. إسناده ضعيف؛ فيه الحسن بن أبي جعفر، وهو الجُفْري البصري، قال عنه ابن حجر في التقريب (١٢٢٢): «ضعيف الحديث مع عبادته وفضله».عزاه السيوطي إلى ابن أبي حاتم.
19,13," <q>﴿وَحَنَانࣰا مِّن لَّدُنَّا﴾</q> - تفسير ٤٦٢٣٩- عن عبد الله بن عباس -من طريق عكرمة- في قوله: <q>﴿وحنانا﴾</q>، قال: لا أدري ما هو، إلا أنِّي أظنُّه تَعَطُّف اللهِ على عبده بالرحمة{1}. (١٠/٢٣) ٤٦٢٤٠- عن سعيد بن جبير، قال: سألتُ عبد الله بن عباس عن قوله: <q>﴿وحنانا﴾</q>. فلم يُحِر فيها شيئًا{2}. (١٠/٢٣) ٤٦٢٤١- عن عبد الله بن عباس -من طريق علي بن أبي طلحة- في قوله: <q>﴿وحنانا من لدنا﴾</q>، قال: رحمة مِن عندنا{3}٤١٣٨. (١٠/٢٣) ٤١٣٨ ذكر ابنُ عطية (٦/١٣) أنّ هذا قول جمهور المفسرين، وأنّه تفسير على اللغة. ٤٦٢٤٢- عن عبد الله بن عباس: أنّ نافع بن الأزرق قال له: أخبِرني عن قوله: <q>﴿وحنانا من لدنا﴾</q>. قال: رحمة من عندنا. قال: وهل تعرف العرب ذلك؟ قال: نعم، أما سمعت طَرَفَة بن العبد البكري وهو يقول: أبا منذر، أفْنَيْتَ فاسْتَبْقِ بعضنا حنانيك بعضُ الشرِّ أهونُ مِن بعض؟{4}. (١٠/٢٤) ٤٦٢٤٣- عن عبد الله بن عباس -من طريق مقاتل وجويبر عن الضحاك- في قوله: <q>﴿وحنانا﴾</q>: يعني: ورحمة منا، وعطفًا{5}. (١٠/٢٥) ٤٦٢٤٤- عن جابر [بن عبد الله] -من طريق عمرو- <q>﴿وحنانًا﴾</q>، قال: ورحمة{6}. (ز) ٤٦٢٤٥- عن معبد الجهني -من طريق عوف- في قوله: <q>﴿وحنانا من لدنا﴾</q>، قال: الحنان: المحبة{7}. (١٠/٢٤) ٤٦٢٤٦- عن مجاهد بن جبر -من طريق ابن أبي نجيح- <q>﴿وحنانا من لدنا﴾</q>، قال: تَعَطُّفًا من ربه عليه{8}. (١٠/٢٤) ٤٦٢٤٧- عن الضحاك بن مزاحم -من طريق جُوَيْبِر- قوله: <q>﴿وحنانا من لدنا﴾</q>، قال: رحمة من عندنا، لا يملِكُ عطاءَها أحدٌ غيرنا{9}. (ز) ٤٦٢٤٨- عن عكرمة مولى ابن عباس -من طريق سماك- في هذه الآية: <q>﴿وحنانا من لدنا﴾</q>، قال: رحمة{9}. (ز) ٤٦٢٤٩- عن عكرمة مولى ابن عباس -من طريق يحيى بن سعيد- <q>﴿وحنانا من لدنا﴾</q>، قال: مَحَبَّة عليه{11}. (ز) ٤٦٢٥٠- عن الحسن البصري، <q>﴿وحنانا من لدنا﴾</q>، قال: الرحمة{12}. (١٠/٢٤) ٤٦٢٥١- عن عطاء بن أبي رباح -من طريق جابر- <q>﴿وحنانا من لدنا﴾</q>، قال: تعظيمًا مِن لدُنّا{11}. (ز) ٤٦٢٥٢- عن قتادة بن دعامة -من طريق مَعْمَر- <q>﴿وحنانا من لدنا﴾</q>، قال: رحمة مِن عندنا{14}. (١٠/٢٤) ٤٦٢٥٣- عن أبي حفص -من طريق جابر- في قوله: <q>﴿وحنانا﴾</q>، قال: رحمة{15}. (ز) ٤٦٢٥٤- عن الربيع [بن أنس]، <q>﴿وحنانا من لدنا﴾</q>، قال: رحمة مِن عندنا، لا يملِكُ عطاءَها أحدٌ غيرنا{16}. (١٠/٢٤) ٤٦٢٥٥- قال محمد بن السائب الكلبي: الحنان: الرحمة{17}. (ز) ٤٦٢٥٦- قال مقاتل بن سليمان: <q>﴿وحنانا من لدنا﴾</q>، يقول: رحمة من عندنا{18}. (ز) ٤٦٢٥٧- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿وحنانا﴾</q>، قال: أمّا الحنان: فالمحبة{9}. (ز) ٤٦٢٥٨- قال يحيى بن سلّام، في قوله: <q>﴿وحنانا من لدنا﴾</q>: أي: مِن عندنا، أي: وأعطيناه حنانًا من لدُنّا{20}. (ز) <q>﴿وَزَكَوٰةࣰۖ﴾</q> - تفسير ٤٦٢٥٩- عن عبد الله بن عباس، في قوله: <q>﴿وزكاة﴾</q>، قال: بركة{21}. (١٠/٢٥) ٤٦٢٦٠- قال عبد الله بن عباس، في قوله: <q>﴿وزكاة﴾</q>: يعني بالزكاة: طاعة الله، والإخلاص{22}. (ز) ٤٦٢٦١- عن عبد الله بن عباس -من طريق مقاتل وجويبر عن الضحاك- في قوله: <q>﴿وزكاة﴾</q>: يعني: وصدقة على زكريا{5}. (١٠/٢٥) ٤٦٢٦٢- عن جابر [بن عبد الله] -من طريق عمرو- <q>﴿وزكاة﴾</q>، قال: طاهرًا من الذنوب{6}. (ز) ٤٦٢٦٣- عن الضَّحّاك بن مُزاحِم، في قوله: <q>﴿وزكاة﴾</q>: يعني: العمل الصالح الزاكي{25}. (ز) ٤٦٢٦٤- قال الحسن البصري: زكاة لِمَن قُبِل عنه حتى يكونوا أزكياء{26}. (ز) ٤٦٢٦٥- عن قتادة بن دعامة -من طريق معمر- <q>﴿وزكاة﴾</q>، قال: صَدَقة{27}. (١٠/٢٤) ٤٦٢٦٦- عن قتادة بن دعامة -من طريق سعيد- قوله: <q>﴿وزكاة﴾</q>، قال: الزكاة: العمل الصالح. قال يحيى بن سلام: رويت أنّه أخذه من هذه الآية في طه [٧٥-٧٦]: <q>﴿ومن يأته مؤمنا قد عمل الصالحات فأولئك لهم الدرجات العلى ٧٥ جنات عدن تجري من تحتها الأنهار خالدين فيها وذلك جزاء من تزكى (٧٦)﴾</q>{28}. (ز) ٤٦٢٦٧- عن أبي حفص -من طريق جابر- في قوله: <q>﴿وزكاة﴾</q>، قال: طاهِرًا من الذنوب{15}. (ز) ٤٦٢٦٨- قال محمد بن السائب الكلبي: الزكاة: الصدقة{30}. (ز) ٤٦٢٦٩- قال مقاتل بن سليمان: <q>﴿وزكاة﴾</q>، يعني: جعله صالِحًا، وطهَّره من الذنوب{18}. (ز) ٤٦٢٧٠- عن عبد الملك ابن جُرَيج -من طريق حجاج- في قوله: <q>﴿وزكاة﴾</q>: يعني: العمل الصالح الزَّكِيّ{25}. (ز) ٤٦٢٧١- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿وزكاة وكان تقيا﴾</q>، قال: أمّا الزكاة والتقوى فقد عرفهما الناس{25}. (ز) <q>﴿وَكَانَ تَقِیࣰّا ۝١٣﴾</q> - تفسير ٤٦٢٧٢- عن عبد الله بن عباس، قال: كُنّا في حلقة في مسجد النبي ﷺ نتذاكر فضائل الأنبياء، فذكرنا نوحًا وطولَ عبادته، وذكرنا إبراهيم وموسى وعيسى ورسول الله ﷺ، فخرج علينا رسول الله ﷺ، فقال: «ما تَذاكَرُون بينكم؟». فذكرنا له، فقال: «أما إنّه لا ينبغي أن يكون أحدٌ خيرًا من يحيى بن زكريا؛ أما سمعتم الله كيف وصفه في القرآن: <q>﴿يا يحيى خذ الكتاب بقوة﴾</q> -إلى قوله-: <q>﴿وكان تقيا﴾</q>، لم يعمل سيئة قطُّ، ولم يهم بها»{34}. (١٠/٢٨) ٤٦٢٧٣- عن عبد الله بن عباس -من طريق العوفي- وفي قوله: <q>﴿وكان تقيا﴾</q>، قال: طهُرَ فلم يعمل بذنب{35}. (١٠/٢٥) ٤٦٢٧٤- عن عبد الله بن عباس، في قوله: <q>﴿وكان تقيا﴾</q>: يعني: مُطَهَّرًا، مُطيعًا لله{5}. (١٠/٢٥) ٤٦٢٧٥- قال المبارك بن فضالة: ما مِن آدمي إلا قد عَمِل خطيئة، أو همَّ بها، إلا يحيى بن زكريا{37}. (ز) ٤٦٢٧٦- قال مقاتل بن سليمان: <q>﴿وكان تقيا﴾</q>، يعني: مُسْلِمًا{18}. (ز) ٤٦٢٧٧- عن سفيان بن عيينة أنّه سُئِل عن قوله: <q>﴿وكان تقيا﴾</q>. قال:لم يعمل بمعصية، ولم يَهمَّ بها{21}. (١٠/٢٥) ",footnotes:1:أخرجه ابن جرير ١٥/٤٧٧ دون قوله: إلا أني أظنه تعطف الله على عبده بالرحمة، وإسحاق البستي في تفسيره ص١٧٧، والحاكم ٢/٣٧٢، والبيهقي في الأسماء والصفات (١٤١). وعزاه السيوطي إلى عبد الرزاق، والفريابي، وابن أبي شيبة، وعبد بن حميد، وابن المنذر، وابن أبي حاتم، والزجاجي في أماليه.أخرجه ابن جرير ١٥/٤٧٨.أخرجه ابن جرير ١٥/٤٧٥، وابن أبي حاتم -كما في الإتقان ٢/٢٦-. وعزاه السيوطي إلى ابن المنذر.أخرجه الطستي-كما في الإتقان ٢/٧٠.أخرجه ابن عساكر ٦٤/١٦٩-١٧٣. وعزاه السيوطي إلى إسحاق بن بشر.أخرجه ابن عساكر في تاريخ دمشق ٤٧/٣٦٠.أخرجه الحكيم الترمذي في نوادر الأصول (ت: إسماعيل إبراهيم عوض) ١/٦٣٧ (٨٩٢). وعزاه السيوطي إليه بلفظ: الحنان: المحبب.أخرجه ابن جرير ١٥/٤٧٦، وإسحاق البستي في تفسيره ص١٧٧ من طريق ابن جريج. وعلَّقه يحيى بن سلام ١/٢١٧. وعزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ١٥/٤٧٥.أخرجه ابن جرير ١٥/٤٧٥.أخرجه ابن جرير ١٥/٤٧٧.علَّقه يحيى بن سلام ١/٢١٧. وعزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ١٥/٤٧٧.أخرجه عبد الرزاق ٢/٤، ٥، وابن جرير ١٥/٤٧٥. وعلَّقه يحيى بن سلام ١/٢١٧. وعزاه السيوطي إلى عبد بن حميد. وأخرجه ابن جرير ١٥/٤٧٦ من طريق سعيد بلفظ: رحمة من عندنا رحم الله بها زكريا.أخرجه ابن عدي في الكامل ٦/٢٢٨، وابن عساكر في تاريخ دمشق ٤٧/٣٦٠.عزاه السيوطي إلى عبد بن حميد.علَّقه يحيى بن سلام ١/٢١٧، وعقّب على تفسير الحنان بالتعطف والرحمة بقوله: وهو نَحْوٌ واحِدٌ.تفسير مقاتل بن سليمان ٢/٦٢٢.أخرجه ابن جرير ١٥/٤٧٥.تفسير يحيى بن سلام ١/٢١٧.عزاه السيوطي إلى ابن أبي حاتم.تفسير الثعلبي ٦/٢٠٨.أخرجه ابن عساكر ٦٤/١٦٩-١٧٣. وعزاه السيوطي إلى إسحاق بن بشر.أخرجه ابن عساكر في تاريخ دمشق ٤٧/٣٦٠.أخرجه ابن جرير ١٥/٤٨٠.علَّقه يحيى بن سلام ١/٢١٧.أخرجه عبد الرزاق ٢/٥. وعزاه السيوطي إلى عبد بن حميد.أخرج قول قتادة يحيى بن سلام ١/٢١٧، وابن جرير ١٥/٤٧٩.أخرجه ابن عدي في الكامل ٦/٢٢٨، وابن عساكر في تاريخ دمشق ٤٧/٣٦٠.علَّقه يحيى بن سلام ١/٢١٧. وفي تفسير البغوي ٥/٢٢٢: يعني: صدقة تصدق الله بها على أبويه.تفسير مقاتل بن سليمان ٢/٦٢٢.أخرجه ابن جرير ١٥/٤٨٠.أخرجه ابن جرير ١٥/٤٨٠.أخرجه البزار -كما في كشف الأستار ٣/١٠٨ (٢٣٥٨)-، والطبراني في الكبير ١٢/٢١٨ (١٢٩٣٨). قال الهيثمي المجمع ٨/٢٠٨-٢٠٩ (١٣٨٠١): «رواه البزار، والطبراني، وفيه علي بن زيد بن جدعان، وضعَّفه الجمهور، وبَقِيَّة رجاله ثقات».أخرجه ابن جرير ١٥/٤٨٠. وعزاه السيوطي إلى ابن أبي حاتم.أخرجه ابن عساكر ٦٤/١٦٩-١٧٣. وعزاه السيوطي إلى إسحاق بن بشر.علقه يحيى بن سلام ١/٢١٧.تفسير مقاتل بن سليمان ٢/٦٢٢.عزاه السيوطي إلى ابن أبي حاتم.
19,14," <q>﴿وَبَرَّۢا بِوَ ٰ⁠لِدَیۡهِ﴾</q> - تفسير ٤٦٢٧٨- عن عبد الله بن عباس، في قوله: <q>﴿وبرا بوالديه﴾</q>: كان لا يعصيهما{1}. (١٠/٢٥) ٤٦٢٧٩- تفسير إسماعيل السُّدِّيّ: قوله: <q>﴿وبرا بوالديه﴾</q>، يعني: مطيعًا لوالديه{2}. (ز) ٤٦٢٨٠- قال مقاتل بن سليمان: <q>﴿وبرا بوالديه﴾</q>، يقول: وجعلناه مُطيعًا لوالديه{3}. (ز) <q>﴿وَلَمۡ یَكُن جَبَّارًا﴾</q> - تفسير ٤٦٢٨١- عن عبد الله بن عباس -من طريق مقاتل وجويبر عن الضحاك- في قوله: <q>﴿ولم يكن جبارا﴾</q>: يعني: قَتّال النفسِ التي حرَّم الله قتلها{1}. (١٠/٢٥) ٤٦٢٨٢- عن إسماعيل السُّدِّيّ: قوله: <q>﴿ولم يكن جبارا عصيا﴾</q> مُسْتَكْبِرًا عن عبادة الله{5}. (ز) ٤٦٢٨٣- قال مقاتل بن سليمان: <q>﴿ولم يكن جبارا﴾</q>، يعني: مُتَكَبِّرًا عن عبادة الله ﷿{3}. (ز) <q>﴿عَصِیࣰّا ۝١٤﴾</q> - تفسير ٤٦٢٨٤- عن قتادة، في قوله: <q>﴿ولم يكن جبارا عصيا﴾</q>، قال: كان سعيد بن المسيب يقول: قال النبي ﷺ: «ما مِن أحد يلقى الله يوم القيامة إلا ذا ذَنب، إلا يحيى بن زكريا». قال قتادة: وقال الحسن: قال النبي ﷺ: «ما أذنب يحيى بن زكريا قط، ولا همَّ بامرأة»{7}. (١٠/٢٥) ٤٦٢٨٥- عن عبد الله بن عباس -من طريق مقاتل وجويبر عن الضحاك- في قوله: <q>﴿عصيا﴾</q>: يعني: عاصيًا لربه{1}. (١٠/٢٥) ٤٦٢٨٦- قال مقاتل بن سليمان: <q>﴿عصيا﴾</q>، يعني: ولا عاصٍ لربه{3}. (ز) <q>﴿عَصِیࣰّا ۝١٤﴾</q> - آثار متعلقة بالآية ٤٦٢٨٧- عن ابن شهاب: أنّ النبي ﷺ خرج على أصحابه يومًا، وهم يتذاكرون فضل الأنبياء، فقال قائل: موسى كلَّمه الله تكليمًا. وقال قائل: عيسى روح الله وكلمته. وقال قائل: إبراهيم خليل الله. فقال النبي ﷺ: «وأين الشهيدُ ابنُ الشهيد؟! يلبس الوَبَر، ويأكل الشجر مخافة الذنب؛ يحيى بن زكريا»{10}. (١٠/٢٨) ٤٦٢٨٨- عن عبد الله بن عباس، أنّ النبي ﷺ قال: «ما مِن أحد مِن ولد آدم إلا وقد أخطأ، أو همَّ بخطيئة، إلا يحيى بن زكريا، لم يهمَّ بخطيئة، ولم يعملها»{11}. (١٠/٢٩) ٤٦٢٨٩- عن عمرو بن العاص، قال: قال رسول الله ﷺ: «كلُّ بني آدم يأتي يوم القيامة وله ذَنب، إلا ما كان مِن يحيى بن زكريا»{12}. (١٠/٢٩) ٤٦٢٩٠- عن يحيى بن جعدة، قال: قال رسول الله ﷺ: «لا ينبغي لأحد أن يقول: أنا خيرٌ مِن يحيى بن زكريا؛ ما همَّ بخطيئة، ولا حكَّت{13} في صدره امرأة»{14}. (١٠/٣٠) ٤٦٢٩١- عن كعب الأحبار -من طريق سمرة- قال:كان يحيى لا يَقْرَب النساء، ولا يشتهِيهِنَّ، وكان شابًّا حسن الوجه، ليِّن الجناح، قليل الشعر، قصير الأصابع، طويل الأنف، أقرن الحاجبين، دقيق الصوت،كثير العبادة، قَوِيًّا في الطاعة{15}. (١٠/٣١) ",footnotes:1:أخرجه ابن عساكر ٦٤/١٦٩-١٧٣. وعزاه السيوطي إلى إسحاق بن بشر.علقه يحيى بن سلام ١/٢١٨.تفسير مقاتل بن سليمان ٢/٦٢٢.أخرجه ابن عساكر ٦٤/١٦٩-١٧٣. وعزاه السيوطي إلى إسحاق بن بشر.علَّقه يحيى بن سلام ١/٢١٨.تفسير مقاتل بن سليمان ٢/٦٢٢.أخرجه عبد الرزاق في تفسيره ٢/٣٥٥ (١٧٥١، ١٧٥٢)، وابن جرير ١٥/٤٨١. وعلق يحيى بن سلام ١/٢١٧ نحو حديث الحسن. قال ابن كثير في تفسيره ٩/٢٢٣ عن حديث الحسن: «مرسل».أخرجه ابن عساكر ٦٤/١٦٩-١٧٣. وعزاه السيوطي إلى إسحاق بن بشر.تفسير مقاتل بن سليمان ٢/٦٢٢.أخرجه ابن عساكر في تاريخه ٦٤/١٩٠. قال ابن عساكر: «هذا مرسل».أخرجه أحمد ٤/١٤٤-١٤٥ (٢٢٩٤)، ٤/٤٠٠ (٢٦٥٤)، والحاكم ٢/٦٤٧ (٤١٤٩). قال الذهبي في التلخيص: «إسناده جيد». وقال الهيثمي في المجمع ٨/٢٠٩ (١٣٨٠٢): «رواه أحمد، وأبو يعلى، والبزار، وزاد: «فإنه لم يهم بها، ولم يعملها». والطبراني، وفيه علي بن زيد، وضعَّفه الجمهور، وقد وُثِّق، وبقية رجال أحمد رجال الصحيح». وأورده الألباني في الصحيحة ٦/١٢٠٦ (٢٩٨٤).أخرجه الحاكم ٢/٤٠٤ (٣٤١١)، ٤/٢٧٣ (٧٦١٨)، وابن جرير ٥/٣٧٧، ١٥/٤٨١. قال الحاكم: «هذا حديث صحيح، على شرط مسلم، ولم يخرجاه». وقال ابن كثير في تفسيره ٥/٢١٨ بعد عزوه لابن إسحاق: «ابن إسحاق هذا مُدَلِّس، وقد عنعن هذا الحديث».يقال: ما حكَّ في صدري كذا. أي: لم ينشرح له صدري. قال: ومن المجاز: حك في صدري وأحك واحتك. وهو ما يقع في خلدك من وساوس الشيطان. التاج (حكك).أخرجه أحمد في كتاب الزهد ص٦٥ (٣٩٩)، وابن عساكر في تاريخه ٦٤/١٩١. قال ابن عساكر: «وهذا مرسل». وقال الألباني في الصحيحة ٦/١٢١١: «أخرجه ابن عساكر ... والسند صحيح، ولكنه مرسل».أخرجه الحاكم ٢/٥٩١.
19,15," <q>﴿وَسَلَـٰمٌ عَلَیۡهِ یَوۡمَ وُلِدَ وَیَوۡمَ یَمُوتُ وَیَوۡمَ یُبۡعَثُ حَیࣰّا ۝١٥﴾</q> - تفسير ٤٦٢٩٢- عن عبد الله بن عباس -من طريق مقاتل وجويبر عن الضحاك - في قوله: <q>﴿وسلام عليه﴾</q> يعني: حين سلم الله عليه، <q>﴿يوم ولد ويوم يموت ويوم يبعث حيا﴾</q>{1}. (١٠/٢٥) ٤٦٢٩٣- عن الحسن البصري -من طريق قتادة- قال: إنّ عيسى ويحيى التقيا، فقال يحيى لعيسى: استغفِر لي؛ أنت خيرٌ مِنِّي. فقال له عيسى: بل أنت خير مِنِّي؛ سلَّم الله عليك، وسلَّمت أنا على نفسي. فعرف -واللهِ- فضلها{2}. (١٠/٣٠) ٤٦٢٩٤- عن السُّدِّيّ: <q>﴿وسلام عليه يوم ولد﴾</q> يعني: حين ولد، <q>﴿ويوم يموت﴾</q> يعني: وحين يموت، <q>﴿ويوم يبعث حيا﴾</q> يوم القيامة{3}. (ز) ٤٦٢٩٥- قال مقاتل بن سليمان: <q>﴿وسلام عليه﴾</q> يعني: على يحيى ﵇ <q>﴿يوم ولد﴾</q> يعني: حين وُلِد، مثل قوله سبحانه: <q>﴿في كتاب الله يوم خلق السماوات﴾</q> [التوبة:٣٦]، يعني: حين خلق السموات، قال عيسى ﷺ: <q>﴿ويوم أموت ويوم أبعث حيا﴾</q>{4} [مريم:٣٣] يعني: حين أموت، وحين أبعث، <q>﴿وسلام عليه يوم ولد ويوم يموت ويوم يبعث حيا﴾</q> يعني: حين يُبعَث بعد الموت{5}. (ز) ٤٦٢٩٦- عن سفيان بن عيينة -من طريق صَدَقَةُ بن الفضل- قال: أوْحَشُ ما يكون الخلقُ في ثلاثة مواطن: يوم يُولَد فيرى نفسه خارجًا مِمّا كان فيه، ويوم يموت فيرى قومًا لم يكن عاينهم، ويوم يُبْعَث فيرى نفسه في محشر عظيم. قال: فأكرم الله فيها يحيى بن زكريا، فخصَّه بالسلام عليه، فقال: <q>﴿وسلام عليه يوم ولد ويوم يموت ويوم يبعث حيا﴾</q>{6}٤١٣٩. (ز) ٤١٣٩ ذكر ابنُ جرير (١٥/٤٨١-٤٨٢) أنّ السلام بمعنى: الأمان، وساق أثر ابن عيينة، وأثر الحسن البصري السابق. ورجَّح ابنُ عطية (٦/١٥) أنّه التحية المعروفة، فقال: «والأظهر عندي أنّها التحية المتعارفة، فهي أشرف وأشبه من الأمان؛ لأنّ الأمان مُتَحَصِّل له بنفي العصيان، وهي أقلّ درجاته، وإنما الشرف في أن سلّم الله عليه وحيّاه في المواطن التي الإنسان فيها في غاية الضعف والحاجة وقلة الحيلة والفقر إلى الله وعظيم الهول». ثم علَّق (٦/١٥-١٦) على ما أورده ابن جرير في أثر الحسن، فقال: «قال أبي ﵁: انتزع بعض العلماء من هذه الآية في التسليم فضل عيسى بأن قال: إدْلاله في التسليم على نفسه ومكانته من الله التي اقتضت ذلك حين قرَّر وحكى في محكم التنزيل أعظم في المنزلة مِن أن يُسلّم عليه ﵇. ولكلٍّ وجْه». <q>﴿وَسَلَـٰمٌ عَلَیۡهِ یَوۡمَ وُلِدَ وَیَوۡمَ یَمُوتُ وَیَوۡمَ یُبۡعَثُ حَیࣰّا ۝١٥﴾</q> - آثار متعلقة بالآية ٤٦٢٩٧- عن عبد الرحمن بن القاسم، قال: قال ⟨مالك:⟩{تت} بلغني: أنّ عيسى ابن مريم ويحيى بن زكريا ﵉ ابنا خالة، وكان حملهما جميعًا معًا. فبلغني: أن أمَّ يحيى قالت لمريم: إنِّي أرى أنّ ما في بطني يسجد لِما في بطنك. قال مالك: أُرى ذلك لتفضيل الله عيسى؛ لأنّ الله جعله يُحْيِي الموتى، ويُبْرِئ الأكْمَهَ والأبرص، ولم يكن ليحيى عيشة إلا عُشْب الأرض، وإن كان لَيبكي من خشية الله، حتى لو كان على خَدِّه القارَ لأذابه، ولقد كان الدمع اتخذ في خَدِّه مَجْرًى{7}. (١٠/٢٨) ",footnotes:1:أخرجه ابن عساكر ٦٤/١٦٩-١٧٣. وعزاه السيوطي إلى إسحاق بن بشر.أخرجه يحيى بن سلام ١/٢١٨ وعقّب عليه بقوله: يعني: قول الله تعالى في يحيى: <q>﴿وسلام عليه يوم ولد ويوم يموت ويوم يبعث حيا﴾</q>، وقال عيسى: <q>﴿قال إني عبد الله آتاني الكتاب وجعلني نبيا (٣٠) وجعلني مباركا أين ما كنت﴾</q> إلى قوله: <q>﴿والسلام علي يوم ولدت ويوم أموت ويوم أبعث حيا﴾</q>، وأخرجه أيضًا عبد الرزاق في تفسيره ٢/٤، وأحمد في الزهد ص٧٦، وابن جرير ١٥/٤٨٢. وعزاه السيوطي إلى عبد بن حميد، وابن أبي حاتم.علَّقه يحيى بن سلام ١/٢١٨.في المطبوع: <q>﴿ويوم يموت ويوم يبعث حيا﴾</q>.تفسير مقاتل بن سليمان ٢/٦٢٢.أخرجه ابن جرير ١٥/٤٨٢.عزاه السيوطي إلى ابن أبي حاتم. وقد أورد السيوطي ١٠/٣١-٣٨ آثارًا كثيرة عن فضائل يحيى ﵇ وبعض أخباره.
19,16," <q>﴿وَٱذۡكُرۡ فِی ٱلۡكِتَـٰبِ مَرۡیَمَ﴾</q> - تفسير ٤٦٢٩٨- قال إسماعيل السُّدِّيّ: يقول: اذكر لأهل مكة أمر مريم{1}. (ز) ٤٦٢٩٩- قال مقاتل بن سليمان: <q>﴿واذكر﴾</q> لأهل مكة <q>﴿في الكتاب مريم﴾</q> يعني: في القرآن ابنة عمران بن ماثان، ويعقوب بن ماثان، مِن نسل سليمان بن داود ﵈{2}. (ز) ٤٦٣٠٠- قال يحيى بن سلّام: قوله: <q>﴿واذكر في الكتاب مريم﴾</q>، يقول للنبي: أي: اقرأه عليهم، يعني: أمر مريم{3}. (ز) <q>﴿إِذِ ٱنتَبَذَتۡ مِنۡ أَهۡلِهَا مَكَانࣰا شَرۡقِیࣰّا ۝١٦﴾</q> - تفسير ٤٦٣٠١- عن عبد الله بن عباس -من طريق العوفي- في قوله: <q>﴿انتبذت من أهلها مكانا شرقيا﴾</q>، قال: مكانًا أظَلَّتها الشمس؛ أن يراها أحدٌ منهم{4}. (١٠/٣٨) ٤٦٣٠٢- عن عبد الله بن عباس -من طريق الشعبي- قال: إنِّي لَأَعْلَمُ خَلْقِ اللهِ لِأَيِّ شيء اتخذت النصارى المشرقَ قِبلَةً؛ لقول الله: فـ<q>﴿انتبذت من أهلها مكانا شرقيا﴾</q>، فاتخذوا ميلاد عيسى قبلة{5}. (١٠/٣٩) ٤٦٣٠٣- عن عبد الله بن عباس -من طريق قابوس، عن أبيه- قال: إنّ أهل الكتاب كُتِب عليهم الصلاة إلى البيت والحج إليه، وما صرفهم عنه إلا قيل ربك: <q>﴿إذ انتبذت من أهلها مكانا شرقيا﴾</q>. قال: خرجت منهم مكانًا شرقِيًّا، فصلُّوا قبل مطلع الشمس{6}. (١٠/٤٠) ٤٦٣٠٤- قال الحسن البصري: اتّخذت النصارى المشرق قبلة لأنّ مريم انتبذت مكانًا شرقيًّا {7}. (ز) ٤٦٣٠٥- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿إذا انتبذت﴾</q> أي: انفردت <q>﴿من أهلها مكانا شرقيا﴾</q> قال: قِبَل المشرق، شاسِعًا مُتَنَحِّيًا{8}. (١٠/٣٩) ٤٦٣٠٦- عن إسماعيل السُّدِّيّ -من طريق أسباط- قال: خرجت مريم إلى جانب المحراب لِحَيضٍ أصابها، وهو قوله: فـ<q>﴿انتبذت من أهلها مكانا شرقيا﴾</q> في شَرْقِيِّ المحراب{9}٤١٤٠. (ز) ٤١٤٠ ساق ابنُ عطية (٦/١٦) هذا القول، ثم ذكر قولًا آخر بأنها انتبذت لتعبد الله، ورجَّحه مستندًا إلى الدلالة العقلية، فقال: «وهذا أحسن، وذلك أن مريم كانت وقْفًا على سدانة المتَعَبد وخدمته والعبادة فيه، فتَنَحَّت من الناس لذلك». ٤٦٣٠٧- قال مقاتل بن سليمان: <q>﴿إذ انتبذت﴾</q> يعني: إذ انفردت <q>﴿من أهلها مكانا شرقيا﴾</q> فجلست فى المشرقة؛ لأنه كان الشتاء{2}. (ز) ",footnotes:1:علقه يحيى بن سلام ١/٢١٨.تفسير مقاتل بن سليمان ٢/٦٢٣.تفسير يحيى بن سلام ١/٢١٨.أخرجه ابن جرير ١٥/٤٨٥. وعزاه السيوطي إلى ابن أبي حاتم.أخرجه ابن جرير ١٠/٥٤٣، ١٥/٤٨٤، وإسحاق البستي في تفسيره ص١٧٨ مختصًرا، وابن أبي حاتم ٥/١٦١١. وعزاه السيوطي إلى الفريابي، وابن أبي شيبة، وعبد بن حميد، وابن المنذر.أخرجه ابن جرير ١٥/٤٨٣-٤٨٤. وعزاه السيوطي إلى ابن أبي حاتم.تفسير الثعلبي ٦/٢٠٩، وتفسير البغوي ٥/٢٢٣ بنحوه.أخرج أوله يحيى بن سلام ١/٢١٨، وعبد الرزاق ٢/٦، وابن جرير ١٥/٤٨٣-٤٨٤، وبعضه من طريق معمر. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم. وقد وقع في مطبوعة الدر وبعض المصادر: منتحيًا بدل متنحيًا.أخرجه ابن جرير ١٥/٤٨٣.تفسير مقاتل بن سليمان ٢/٦٢٣.
19,17," <q>﴿فَٱتَّخَذَتۡ مِن دُونِهِمۡ حِجَابࣰا فَأَرۡسَلۡنَاۤ إِلَیۡهَا رُوحَنَا فَتَمَثَّلَ لَهَا بَشَرࣰا سَوِیࣰّا ۝١٧﴾</q> - سياق القصة ٤٦٣٠٨- عن عبد الله بن مسعود -من طريق السدي، عن مُرَّة الهمداني-= (ز) ٤٦٣٠٩- وعبد الله بن عباس -من طريق السدي، عن أبي مالك- قالا: خرجت مريم إلى جانب المحراب لِحَيض أصابها، فلمّا طهرت إذ هي برَجُلٍ معها، <q>﴿فتمثل لها بشرا﴾</q>، ففزعت، وقالت: <q>﴿إني أعوذ بالرحمن منك إن كنت تقيا﴾</q>. فخرجت وعليها جلبابها، فأخذ بكُمِّها، فنفخ في جيب دِرْعِها، وكان مشقوقًا مِن قُدّامِها، فدخلت النفخة صدرها، فحملت، فأتتها أختُها امرأةُ زكريا ليلةً تزورها، فلمّا فتحت لها الباب التزمتها، فقالت امرأة زكريا: يا مريم، أُشْعِرْتُ أنِّي حبلى. قالت مريم: أُشْعِرْتُ أيضًا أنِّي حُبْلى. فقالت امرأة زكريا: فإنِّي وجدتُ ما في بطني يسجد للذي في بطنك. فذاك قوله: <q>﴿مصدقا بكلمة من الله﴾</q>. فولدت امرأةُ زكريا يحيى، ولَمّا بلغ أن تضع مريمُ خرجت إلى جانب المحراب، <q>﴿فأجاءها المخاض إلى جذع النخلة قالت﴾</q> استحياءً من الناس: <q>﴿يا ليتني مت قبل هذا﴾</q> الآية، <q>﴿فناداها﴾</q> جبريل <q>﴿من تحتها أن لا تحزني قد جعل ربك تحتك سريا * وهزي إليك بجذع النخلة تساقط عليك رطبا جنيا﴾</q>. فهزَّتْهُ، فأجرى لها في المحراب نهرًا -والسَّرِيُّ: النهر-، فتساقطت النخلة رطبًا جنِيًّا، فلما ولدته ذهب الشيطان، فأخبر بني إسرائيل: أنّ مريم ولدت. فلما أرادوها على الكلام أشارت إلى عيسى، فتكلَّم، فقال: <q>﴿إني عبد الله آتاني الكتاب وجعلني نبيا وجعلني مباركا﴾</q>. فلمّا وُلِد لم يبق في الأرض صنمٌ يُعْبَد من دون الله إلا خرَّ -وقع ساجدًا- لوجهه{1}٤١٤١. (١٠/٤١) ٤١٤١ انتقد ابنُ عطية (٦/٢١) ما رُوِي من قصص حمل عيسى ﵇، فقال: «وفي هذا كله ضَعْف». ٤٦٣١٠- عن عبد الله بن عباس -من طريق داود بن أبي هند، عن سعيد بن جبير- قال: لَمّا بلغت مريم، فبينما هي في بيتها مُتَفَضِّلة{2} إذ دخل عليها رجلٌ بغير إذن، فخشيت أن يكون دخل عليها لِيَغْتالَها، فقالت: <q>﴿إني أعوذ بالرحمن منك إن كنت تقيا قال إنما أنا رسول ربك لأهب لك غلاما زكيا قالت أنى يكون لي غلام ولم يمسسني بشر ولم أك بغيا قال كذلك قال ربك﴾</q>. فجعل جبريل يردد ذلك عليها، وتقول: <q>﴿أنى يكون لي غلام﴾</q>. وتَغَفَّلَها جبريل، فنفخ في جَيْب دِرْعِها، ونهض عنها، واستمرَّ بها حملُها، فقالت: إن خَرَجْتُ نحو المغرب فالقوم يصلون نحو المغرب، ولكن أخْرُجُ نحو المشرق حيث لا يراني أحد. فخَرَجَتْ نحو المشرق، فبينما هي تمشي إذ فجأها المخاض، فنظرت هل تجد شيئًا تستر به، فلم ترَ إلا جِذْعَ النخلة، فقالت: أستترُ بهذا الجذع مِن الناس. وكان تحت الجذع نهر يجري، فانضمَّت إلى النخلة، فلمّا وضَعَتْهُ خَرَّ كل شيء يعبد من دون الله في مشارق الأرض ومغاربها ساجدًا لوجهه، وفزع إبليس، فخرج، فصعد، فلم ير شيئًا ينكره، وأتى المشرق فلم ير شيئًا يُنكره، ودخل الأرض فلم ير شيئًا يُنكره، وجعل لا يصبر، فأتى المغرب لينظر، فلم ير شيئًا ينكره، فبينا هو يطوف إذ مَرَّ بالنخلة، فإذا هو بامرأة معها غلام قد ولدته، وإذا بالملائكة قد أحْدَقُوا بها وبابنها وبالنخلة، فقال: ههنا حَدَث الأمر. فمال إليهم، فقال: أيُّ شيء هذا الذي حدث؟ فكلَّمَتْه الملائكة، فقالوا: نبيٌّ وُلِد بغير ذَكَر. قال: نبيٌّ وُلِد بغير ذَكَر! قالوا: نعم. قال: أما -واللهِ- لَأُضِلَّنَّ به أكثر العالمين. أضلَّ اليهود فكفروا به، وأضلَّ النصارى فقالوا: هو ابن الله. قال: وناداها مَلَك مِن تحتها: <q>﴿قد جعل ربك تحتك سريا﴾</q>. قال إبليس: ما حَمِلَتْ أُنثى إلا بعلمي، ولا وضعته إلا على كَفِّي، ليس هذا الغلام، لم أعلم به حين حَمَلَتْهُ أمه، ولم أعلم به حين وضعته{3}. (١٠/٤٠) ٤٦٣١١- عن عبد الله بن عباس -من طريق جويبر، عن الضحاك- في قوله: <q>﴿واذكر في الكتاب مريم﴾</q> يقول: قُصَّ ذكرَها على اليهود والنصارى ومشركي العرب <q>﴿إذا انتبذت﴾</q> يعني: خرجت <q>﴿من أهلها مكانا شرقيا﴾</q> قال: كانت خرجت من بيت المقدس مما يلي المشرق، <q>﴿فاتخذت من دونهم حجابا﴾</q> وذلك أنّ الله لَمّا أراد أن يبتدئها بالكرامة، ويُبَشِّرها بعيسى، وكانت قد اغتسلت من المحيض، فتَشَرَّفت، وجعلت بينها وبين قومها <q>﴿حجابا﴾</q> يعني: جبلًا، فكان الجبل بين مجلسها وبين بيت المقدس، <q>﴿فأرسلنا إليها روحنا﴾</q> يعني: جبريل، <q>﴿فتمثل لها بشرا﴾</q> في صورة الآدميين، <q>﴿سويا﴾</q> يعني: مُعْتَدِلًا، شابًّا، أبيض الوجه، جَعْدًا قَطَطًا{4}، حين اخضرَّ شاربُه، فلما نظرت إليه قائمًا بين يديها <q>﴿قالت إني أعوذ بالرحمن منك إن كنت تقيا﴾</q>، وذلك أنها شبَّهته بشابٍّ كان يراها ونشأ معها، يُقال له: يوسف، من بني إسرائيل، وكان مِن خَدَمِ بيت المقدس، فخافت أن يكون الشيطان قد استَزَلَّه، فمِن ثَمَّ قالت: <q>﴿إني أعوذ بالرحمن منك إن كنت تقيا﴾</q> يعني: إن كنتَ تخاف الله. <q>﴿قال﴾</q> جبريلُ وتَبَسَّم: <q>﴿إنما أنا رسول ربك لأهب لك غلاما زكيا﴾</q> يعني: لله مطيعًا، من غير بشر. <q>﴿قالت أنى يكون لي غلام ولم يمسسني بشر﴾</q> يعني: زوجًا، <q>﴿ولم أك بغيا﴾</q> أي: مُومِسَة. <q>﴿قال﴾</q> جبريل: <q>﴿كذلك﴾</q> يعني: هكذا <q>﴿قال ربك هو علي هين﴾</q> يعني: خَلْقُه مِن غير بشر، <q>﴿ولنجعله آية للناس﴾</q> يعني: عِبرة، والناس هنا: للمؤمنين خاصة، <q>﴿ورحمة منا﴾</q> لِمَن صدَّق بأنه رسول الله، <q>﴿وكان أمرا مقضيا﴾</q> يعني: كائنًا أن يكون مِن غير بشر. فَدَنا جبريلُ، فنفخ في جيبها، فدخلت النفخةُ جَوْفَها، فاحتملت كما تحمل النساء في الرَّحِم والمشِيمَة، ووضعته كما تضع النساء، فأصابها العَطَش، فأجرى الله لها جدولًا من الأردن، فذلك قوله: <q>﴿قد جعل ربك من تحتك سريا﴾</q>. والسَّرِيُّ: الجدول. وحمل الجذِعُ من ساعته <q>﴿رطبا جنيا﴾</q>، <q>﴿فناداها من تحتها﴾</q> جبريل: <q>﴿وهزي إليك بجذع النخلة﴾</q>. لم يكن على رأسها سعف، وكانت قد يبست منذ دهر طويل، فأحياها الله لها، وحملت، فذلك قوله: <q>﴿تساقط عليك رطبا جنيا﴾</q> يعني: طريًّا بغباره، <q>﴿فكلي﴾</q> مِن الرُّطَب، <q>﴿واشربي﴾</q> من الجدول، <q>﴿وقري عينا﴾</q> بولدك. فقالت: فكيف بي إذا سألوني: من أين هذا؟ قال لها جبريل: <q>﴿فإما ترين﴾</q> يعني: فإذا رأيت <q>﴿من البشر أحدا﴾</q> فأَعْنَتَكِ في أمرك؛ <q>﴿فقولي إني نذرت للرحمن صوما﴾</q> يعني: صمتًا في أمر عيسى، <q>﴿فلن أكلم اليوم إنسيا﴾</q> في أمره، حتى يكون هو الذي يُعَبِّر عنِّي وعن نفسه. قال: ففقدوا مريم مِن محرابها، فسألوا يوسف، فقال: لا عِلْمَ لي بها، وإنّ مفتاح محرابها مع زكريا. فطلبوا زكريا، وفتحوا الباب وليست فيه، فاتهموه، فأخذوه، ووَبَّخوه، فقال رجل: إنِّي رأيتها في موضع كذا. فخرجوا في طلبها، فسمعوا صوت عقعق{5} في رأس الجذع الذي مريم مِن تحته، فانطلقوا إليه، فذلك قول الله: <q>﴿فأتت به قومها تحمله﴾</q>. قال ابن عباس: لَمّا رأت بأنّ قومها قد أقبلوا إليها احتملت الولد إليهم حتى تلقتهم به، فذلك قوله: <q>﴿فأتت به قومها تحمله﴾</q> أي: لا تخاف رِيبة ولا تُهمة، فلما نظروا إليها شقَّ أبوها مدرعته، وجعل التراب على رأسه، وإخوتها، وآل زكريا، فـ<q>﴿قالوا يا مريم لقد جئت شيئا فريا﴾</q> يعني: عظيمًا، <q>﴿يا أخت هرون﴾</q> كانت من آل هارون، <q>﴿ما كان أبوك امرأ سوء وما كانت أمك بغيا﴾</q> يعني: زانية، فأنّى أتيتِ هذا الأمر مع هذا الأخ الصالح، والأب الصالح، والأم الصالحة؟! <q>﴿فأشارت إليه﴾</q> تقول لهم: أن كلِّموه، فإنه سيخبركم، فـ<q>﴿إني نذرت للرحمن صوما﴾</q> أن لا أكلمكم في أمره، فإنّه سيُعَبِّر عَنِّي، ويكون لكم آية وعبرة. <q>﴿قالوا﴾</q>: يا عجبنا، <q>﴿كيف نكلم من كان في المهد صبيا﴾</q>؟! يعني: مَن هو في الخِرَقِ طفلًا لا ينطق! إذ أنطقه الله، فعبَّر عن أُمِّه، وكان عبرة لهم، فقال: <q>﴿إني عبد الله﴾</q>. فلما أن قالها ابتدأ يحيى، وهو ابن ثلاث سنين، فكان أولَ مَن صدق به، فقال: إنِّي أشهد أنك عبد الله ورسوله. لتصديق قول الله: <q>﴿مصدقا بكلمة من الله﴾</q> [آل عمران:٣٩]. فقال عيسى: <q>﴿آتاني الكتاب وجعلني نبيا﴾</q> إليكم، <q>﴿وجعلني مباركا أينما كنت﴾</q>. قال ابن عباس: قال رسول الله ﷺ: «البركة التي جعلها الله لعيسى أنّه كان مُعَلِّمًا مُؤَدِّبًا حيثما توجه». <q>﴿وأوصاني بالصلاة والزكاة﴾</q> يعني: وأمرني، <q>﴿وبرا بوالدتي﴾</q> فلا أعُقُّها. قال ابن عباس: حين قال: <q>﴿وبرا بوالدتي﴾</q> قال زكريا: الله أكبر. فأخذه، فضَمَّه إلى صدره، فعلموا أنّه خُلِق مِن غير بشر، <q>﴿ولم يجعلني جبارا شقيا﴾</q> يعني: مُتَعَظِّمًا سفّاكًا للدم، <q>﴿والسلام علي يوم ولدت ويوم أموت ويوم أبعث حيا﴾</q>. يقول الله: <q>﴿ذلك عيسى ابن مريم قول الحق الذي فيه يمترون﴾</q> يعني: يَشُكُّون. يقوله لليهود، ثم أمسك عيسى عن الكلام حتى بلغ مبلغ الناس{6}. (١٠/٤٢) ٤٦٣١٢- عن نوف البِكاليّ -من طريق أبي عمران الجَوْنِيِّ- قال: كانت مريم ﵍ فتاة بتولًا، وكان زكريا زوج أختها كفلها، فكانت معه، فكان يدخل عليها يُسَلِّمُ عليها، فتُقَرِّبُ إليه فاكهة الشتاء في الصيف، وفاكهة الصيف في الشتاء، فدخل عليها زكريا مرَّة، فقرَّبت إليه بعض ما كانت تُقَرِّب، <q>﴿قال يا مريم أنى لك هذا قالت هو من عند الله إن الله يرزق من يشاء بغير حساب هنالك دعا زكريا ربه﴾</q> إلى قوله: <q>﴿آيتك أن لا تكلم الناس ثلاثة أيام إلا زمرا﴾</q> [آل عمران:٣٧-٤١]. قال: يُخْتَمُ على لسانك فلا تكلِّمُ الناس <q>﴿ثلاث ليال سويا﴾</q>: صحيحًا. <q>﴿فخرج على قومه من المحراب فأوحى إليهم﴾</q> كتب لهم <q>﴿أن سبحوا بكرة وعشيا﴾</q>. قال: فبينما هي جالسة في منزلها إذا رجل قائم بين يديها قد هَتَكَ الحُجُبَ، فلمّا رأته قالت: <q>﴿إني أعوذ بالرحمن منك إن كنت تقيا﴾</q>. قال: فلما ذكرت الرحمن فزع جبريل ﵇، قال: <q>﴿إنما أنا رسول ربك لأهب لك غلاما زكيا﴾</q> إلى قوله: <q>﴿وكان أمر مقضيا﴾</q>. فنفخ في جيبها جبريلُ، فحملت، حتى إذا أثْقَلَتْ وجِعَتْ ما توجع النساء، وكانت في بيت النبوة، فاستحيت، وهربت حياءً مِن قومها، فأخذت نحو المشرق، وخرج قومها في طلبها، فجعلوا يسألون: رأيتم فتاة كذا وكذا؟ فلا يخبرهم أحد، وأخذها <q>﴿المخاض إلى جذع النخلة﴾</q> فتساندت إلى النخلة، قالت: <q>﴿يا ليتني مت قبل هذا وكنت نسيا منسيا﴾</q> قال: حيضة من حيضة، <q>﴿فناداها من تحتها﴾</q> قال: جبريل مِن أقصى الوادي: <q>﴿أن لا تحزني قد جعل ربك تحتك سريا﴾</q> قال: جدولًا، <q>﴿وهزي إليك بجذع النخلة تساقط عليك رطبا جنيا﴾</q>. فلمّا قال لها جبريلُ اشتدَّ ظهرها، وطابت نفسها، فقطعت سَرَرَه{7}، ولفَّته في خِرْقَة، وحملته، فلقي قومها راعي بقر وهم في طلبها، قالوا: يا راعي، هل رأيت فتاة كذا وكذا؟ قال: لا، ولكن رأيت الليلة مِن بقري شيئًا لم أره منها قطُّ فيما خلا. قال: وما رأيتها منها؟ قال: رأيتها باتت سُجَّدًا نحو هذا الوادي. فانطلقوا حيث وصف لهم، فلما رأتهم مريم جلست، وجعلت تُرضِع عيسى، فجاؤوا حتى وقفوا عليها، فقالوا: <q>﴿يا مريم لقد جئت شيئا فريا﴾</q> قال: أمرًا عظيمًا، <q>﴿فأشارت إليه﴾</q> أن كلِّموه، فعجبوا منها، <q>﴿قالوا كيف نكلم من كان في المهد صبي﴾</q>؟! والمهد: حِجْرُها. فلما قالوا ذلك ترك عيسى ثديَها، واتَّكأ على يساره، ثم تكلم، <q>﴿قال إني عبد الله آتاني الكتاب وجعلني نبيا وجعلني مباركا أينما كنت وأوصاني بالصلاة والزكاة ما دمت حيا وبرا بوالدتي ولم يجعلني جبارا شقيا والسلام علي يوم ولدت ويوم أموت ويوم أبعث حيا﴾</q>. قال: واختلف الناس فيه{8}. (١٠/٤٦) <q>﴿فَٱتَّخَذَتۡ مِن دُونِهِمۡ حِجَابࣰا﴾</q> - تفسير ٤٦٣١٣- عن عبد الله بن عباس -من طريق جُوَيْبِر، عن الضحاك- قال: جعلت بينها وبين قومها حجابًا، يعني: جبلًا. فكان الجبل بين مجلسها وبين بيت المقدس{6}. (١٠/٤٢) ٤٦٣١٤- قال عبد الله بن عباس: سِتْرًا{10}. (ز) ٤٦٣١٥- عن إسماعيل السُّدِّيّ -من طريق أسباط-: <q>﴿فاتخذت من دونهم حجابا﴾</q> مِن الجدران{11}. (ز) ٤٦٣١٦- قال مقاتل بن سليمان: <q>﴿فاتخذت من دونهم حجابا﴾</q>، يعني: جبلًا، فجعلت الجبل بينها وبينهم، فلم يرها أحد منهم، كقوله في ص [٣٢]: <q>﴿حتى توارت بالحجاب﴾</q>، يعني: الجبل، وهو دون «ق» بمسيرة سنة، والشمس تغرب من ورائه{12}. (ز) <q>﴿فَٱتَّخَذَتۡ مِن دُونِهِمۡ حِجَابࣰا﴾</q> - آثار متعلقة بالآية ٤٦٣١٧- عن ابن عباس أنّه قال لعمر بن الخطاب: بِمَ استحب النَّصارى الحُجُب على مذابحهم؟ قال: إنما يستحب النصارى الحجب على مذابحهم ومناسكهم لقول الله: <q>﴿فاتخذت من دونهم حجابا﴾</q>{13}. (١٠/٤٨) <q>﴿فَأَرۡسَلۡنَاۤ إِلَیۡهَا رُوحَنَا﴾</q> - تفسير ٤٦٣١٨- عن أُبَيّ بن كعب -من طريق أبي العالية- في قوله: إنّ روح عيسى ﵇ مِن جُمْلَة الأرواح التي أُخِذ عليها العهدُ في زمان آدم، <q>﴿فتمثل لها بشرا سويا﴾</q> قال: تَمَثَّل لها روح عيسى في صورة بشر، <q>﴿فحملته﴾</q> قال: حملت الذي خاطبها، دخل في فِيها{14}. (١٠/٤٩) ٤٦٣١٩- عن عبد الله بن عباس -من طريق جويبر، عن الضحاك- في قوله: <q>﴿فأرسلنا إليها روحنا﴾</q>، يعني: جبريل{15}. (١٠/٤٢) ٤٦٣٢٠- عن سعيد بن جبير، في قوله: <q>﴿فأرسلنا إليها روحنا﴾</q> الآية، قال: نفخ جبريلُ في دِرْعِها، فبلغت حيث شاء الله{16}. (١٠/٤٩) ٤٦٣٢١- عن الضحاك بن مُزاحِم -من طريق عبيد- في قوله: <q>﴿فأرسلنا إليها روحنا﴾</q>: يعني: جبريل{17}. (ز) ٤٦٣٢٢- قال عكرمة مولى ابن عباس: إنّ مريم الصدِّيقة كانت تكون في المسجد ما دامت طاهرًا، فإذا حاضت تحوَّلَتْ إلى بيت خالتها، حتى إذا طهرت عادت إلى المسجد، فبينا هي تغتسل مِن الحيض إذ عرض لها جبريلُ ﵇ في صورة شابٍّ أمرد، وضِيء الوجه، جعد الشعر، سَوِيِّ الخَلْق، فذلك قوله: <q>﴿فأرسلنا إليها روحنا﴾</q>يعني جبريل ﵇{10}. (ز) ٤٦٣٢٣- عن عطاء بن يسار: أنّ جبريل أتاها في صورة رجل، فكشف الحجاب، فلمّا رأته تَعَوَّذَتْ منه، فنفخ في صَنِفَةِ دِرْعِها{19}، فبلغت، فذُكِر ذلك في المدينة، فهُجِر زكريا وتُرِك، وكان قبل ذلك يُسْتَفْتى، ويأتيه الناس، حتى إنّ كان لَيُسَلِّم على الرجل فما يُكَلِّمه{13}. (١٠/٤٩) ٤٦٣٢٤- عن أبي صالح باذام، في قوله: <q>﴿فأرسلنا إليها روحنا﴾</q>، قال: بعث الله إليها ملَكًا، فنفخ في جيبها، فدخل في الفَرْج{21}. (١٠/٤٨) ٤٦٣٢٥- عن وهب بن مُنَبِّه -من طريق عبد الصمد بن معقل- قال: أرسل الله جبريلَ إلى مريم، دخل في فيها{22}. (ز) ٤٦٣٢٦- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿فأرسلنا إليها روحنا﴾</q>، قال: جبريل{23}. (١٠/٤٩) ٤٦٣٢٧- عن إسماعيل السُّدِّيّ -من طريق أسباط- قال: فلمّا طَهُرَت -يعني: مريم- مِن حيضها، إذا هي برجل معها، وهو قوله: <q>﴿فأرسلنا إليها روحنا﴾</q>، وهو جبريل{24}. (ز) ٤٦٣٢٨- قال محمد بن السائب الكلبي: كان زكريا كَفِل مريم، وكانت أختُها تحته، وكانت تكون في المحراب، فلمّا أدركت كانت إذا حاضت أخرجها إلى منزلِهِ إلى أختها، فإذا طهرت رجعت إلى المحراب. فطَهُرَت مرة، فلما فرغت مِن غُسْلِها قعدت في مشرقة في ناحية الدار، وعلَّقت عليها ثوبًا سترةً، فجاء جبريل إليها في ذلك الموضع، فلمّا رأته <q>﴿قالت إني أعوذ بالرحمن منك إن كنت تقيا﴾</q>{25}. (ز) ٤٦٣٢٩- قال مقاتل بن سليمان: <q>﴿فأرسلنا إليها روحنا﴾</q>، يعني: جبريل ﵇{26}. (ز) ٤٦٣٣٠- عن عبد الملك ابن جُرَيْج -من طريق حجاج- قوله: <q>﴿فأرسلنا إليها روحنا﴾</q>، قال: جبريل{22}. (ز) ٤٦٣٣١- قال يحيى بن سلّام، في قوله: <q>﴿فأرسلنا إليها روحنا﴾</q>: يعني: جبريل{28}٤١٤٢. (ز) ٤١٤٢ اختُلِف في الروح الذي تمثل لمريم؛ فقال قوم: هو جبريل. وقال غيرهم: عيسى. ورجَّح ابنُ كثير (٩/٢٢٦) مستندًا إلى دلالة القرآن القولَ الأولَ الذي قاله قتادة، والضحاك، ومجاهد، والسدي، وابن جريج، ووهب بن منبه، فقال: «وهذا الذي قالوه هو ظاهر القرآن؛ فإنّه تعالى قد قال في الآية الأخرى: <q>﴿نزل به الروح الأمين على قلبك لتكون من المنذرين﴾</q> [الشعراء:١٩٣-١٩٤]». وانتقد (٩/٢٢٦) القولَ الثاني الذي قاله أبي، فقال: «وهذا في غاية الغرابة والنكارة، وكأنه إسرائيلي». وذكر ابنُ عطية (٦/١٦-١٧) أنّ مَن قال بالقول الأول قَدَّر الكلام: فتمثل هو لها. ومن قال بالثاني قدَّر الكلام: فتمثل المَلَك لها. <q>﴿فَتَمَثَّلَ لَهَا بَشَرࣰا سَوِیࣰّا ۝١٧﴾</q> - تفسير ٤٦٣٣٢- عن عبد الله بن عباس -من طريق سعيد بن جبير- قال: لَمّا بلغت مريم، فبينا هي في بيتها مُتَفَضِّلة إذ دخل عليها رجلٌ بغير إذن، فخشيت أن يكون دخل عليها ليغتالها، فقالت: <q>﴿إني أعوذ بالرحمن منك إن كنت تقيا﴾</q>{29}. (١٠/٤٠) ٤٦٣٣٣- عن عبد الله بن عباس -من طريق جويبر، عن الضَّحّاك- في قوله: <q>﴿فتمثل لها بشرا﴾</q> في صورة الآدَمِيِّين، <q>﴿سويا﴾</q> يعني: مُعْتَدِلًا، شابًّا، أبيض الوجه، جعدًا قَطَطًا، حين اخْضَرَّ شاربُه{15}. (١٠/٤٢) ٤٦٣٣٤- عن قتادة بن دعامة -من طريق سعيد-: أرسل إليها -فيما يذكر- جبريل في صورة آدم{31}. (ز) ٤٦٣٣٥- عن إسماعيل السُّدِّيّ: <q>﴿فتمثل لها بشرا سويا﴾</q>، يعني: سَوِيّ الخَلْق، بشرًا في صورة البشر وخلْقِهم{25}. (ز) ٤٦٣٣٦- قال مقاتل بن سليمان: <q>﴿فتمثل لها بشرا سويا﴾</q>، يعني: إنسانًا سَوِيًّا، يعني: سويَّ الخَلْق، على صورة شابٍّ أمْرَد، جعد الرأس{26}. (ز) ",footnotes:1:أخرجه الحاكم ٢/٥٩٣، والبيهقي في الأسماء والصفات (٧٧٣)، وابن عساكر في تاريخ دمشق ٧٠/٨٦.أي: لابسة الثياب التي يلبسها الإنسان في البيت للراحة مِن قميص ونحوه، دون ثياب التصرف والثياب التي يلقى بها الناس. لسان العرب (فضل).أخرجه ابن عساكر ٧٠/٨١-٨٣.والقطط: الشديد الجعودة، وقيل: الحسن الجعودة. وجعودة الشعر: عدم انبساطه واسترساله. النهاية ٤/٨١.العقعق: طائر ذو لونين أبيض وأسود، طويل الذنب، من نوع الغربان. النهاية ٣/٢٧٦.أخرج ابن عساكر في تاريخه بعضه مفرقًا ٤٧/٣٤٨-٣٤٩، ٧٠/٩٥-٩٦، وعزاه السيوطي إلى إسحاق بن بشر.سَرَرَه: ما يقطع من النقرة التي في وسط بطن الوليد، وهي السُّرة. لسان العرب (سرر).عزاه السيوطي إلى عبد الله بن أحمد في زوائد الزهد. وأخرج آخره ابن أبي حاتم -كما في تفسير ابن كثير ٣/٢٢٦-، كما أخرج ابن عساكر في تاريخ دمشق ٧٠/٨٥ نحوه.أخرج ابن عساكر في تاريخه بعضه مفرقًا ٤٧/٣٤٨-٣٤٩، ٧٠/٩٥-٩٦، وعزاه السيوطي إلى إسحاق بن بشر.تفسير الثعلبي ٦/٢٠٩، وتفسير البغوي ٥/٢٢٣.أخرجه ابن جرير ١٥/٤٨٥.تفسير مقاتل بن سليمان ٢/٦٢٣. وفي تفسير الثعلبي ٦/٢٠٩، وتفسير البغوي ٥/٢٢٣ نحو أوله مختصرًا منسوبًا إلى مقاتل دون تعيينه.عزاه السيوطي إلى ابن أبي حاتم.أخرجه الحاكم ٢/٣٧٣ مطولًا، والبيهقي في الأسماء والصفات (٧٨٥)، وابن عساكر ٤٧/٣٤٩. وعزاه السيوطي إلى ابن أبي حاتم.أخرجه ابن عساكر في تاريخه ٤٧/٣٤٨-٣٤٩. وعزاه السيوطي في الدر إلى إسحاق بن بشر. وتقدم بتمامه مطولًا في سياق القصة.عزاه السيوطي إلى سعيد بن منصور، وابن المنذر.أخرجه إسحاق البستي في تفسيره ص١٧٨.تفسير الثعلبي ٦/٢٠٩، وتفسير البغوي ٥/٢٢٣.صَنِفَةِ درعها: طرفه وزاويته. لسان العرب (صنف).عزاه السيوطي إلى ابن أبي حاتم.عزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.أخرجه ابن جرير ١٥/٤٨٦.أخرجه يحيى بن سلام ١/٢١٩، وابن جرير ١٥/٤٨٥. وعزاه السيوطي إلى ابن أبي حاتم.أخرجه ابن جرير ١٥/٤٨٦. وعلَّقه يحيى بن سلام ١/٢١٩.علقه يحيى بن سلام ١/٢١٩.تفسير مقاتل بن سليمان ٢/٦٢٣.أخرجه ابن جرير ١٥/٤٨٦.تفسير يحيى بن سلام ١/٢١٨.أخرجه ابن عساكر ٧٠/٨١-٨٣ من طريق داود بن أبي هند.أخرجه ابن عساكر في تاريخه ٤٧/٣٤٨-٣٤٩. وعزاه السيوطي في الدر إلى إسحاق بن بشر. وتقدم بتمامه مطولًا في سياق القصة.أخرجه ابن جرير ١٥/٤٨٥. وعلَّقه يحيى بن سلام ١/٢١٩. وعزاه السيوطي إلى ابن أبي حاتم.علقه يحيى بن سلام ١/٢١٩.تفسير مقاتل بن سليمان ٢/٦٢٣.
19,18," <q>﴿قَالَتۡ إِنِّیۤ أَعُوذُ بِٱلرَّحۡمَـٰنِ مِنكَ إِن كُنتَ تَقِیࣰّا ۝١٨﴾</q> - تفسير ٤٦٣٣٧- عن عبد الله بن عباس -من طريق جُوَيْبِر، عن الضحاك-: لَمّا نَظَرَتْ إليه قائمًا بين يديها قالت: <q>﴿إني أعوذ بالرحمن منك إن كنت تقيا﴾</q>. وذلك أنّها شَبَّهته بشابٍّ كان يراها، ونشأ معها، يقال له: يوسف، مِن بني إسرائيل، وكان مِن خَدَم بيت المقدس، فخافت أن يكون الشيطانُ قد اسْتَزَلَّه، فمِن ثَمَّ قالت: <q>﴿إني أعوذ بالرحمن منك إن كنت تقيا﴾</q>. يعني: إن كنت تخاف الله{1}. (١٠/٤٢) ٤٦٣٣٨- عن أبي وائل شقيق بن سلمة -من طريق عاصم بن أبي النجود- في قوله: <q>﴿قالت إني أعوذ بالرحمن منك إن كنت تقيا﴾</q>، قال: لقد عَلِمَتْ مريمُ أنّ التَّقِيَّ ذو نُهْيَة{2}{3}. (١٠/٥٠) ٤٦٣٣٩- عن مجاهد بن جبر، في قوله: <q>﴿قالت إني أعوذ بالرحمن منك إن كنت تقيا﴾</q>، قال: إنما خَشِيَتْ أن يكون إنما يريدها عن نفسها{4}. (١٠/٥٠) ٤٦٣٤٠- عن وهب بن مُنَبِّه -من طريق ابن إسحاق، عمَّن لا يتَّهم- <q>﴿قالت إني أعوذ بالرحمن منك إن كنت تقيا﴾</q>: ولا ترى إلا أنّه رجل من بني آدم{5}٤١٤٣. (ز) ٤١٤٣ ذكر ابنُ عطية (٦/١٧) عن وهب أنه «رجل فاجر، كان في ذلك الزمن في قومها، فلمّا رأته مُتَسَوِّرًا عليها ظَنَّتْهُ إيّاه؛ فاستعاذت بالرحمن منه». وقال: «حكى هذا مكيٌّ وغيرُه». ثم انتقده مستندًا إلى عدم الدليل، فقال: «وهو ضعيف ذاهب مع التخرُّص». وانتقده ابنُ تيمية (٤/٢٧٥)، فقال: «وما يقوله بعض الجهال ... فهو نوع مِن الهذيان، وهو من الكذب الظاهر الذي لا يقوله إلا جاهل». ٤٦٣٤١- قال الحسن البصري: أي: إن كنت تقيًّا له فاجتنبني{6}. (ز) ٤٦٣٤٢- عن إسماعيل السُّدِّيّ -من طريق أسباط-: <q>﴿فتمثل لها بشرا سويا﴾</q> فلمّا رأته فَزِعت منه، وقالت: <q>﴿إني أعوذ بالرحمن منك إن كنت تقيا﴾</q>{5}. (ز) ٤٦٣٤٣- قال مقاتل بن سليمان: فلما رأته حسبته إنسانًا، <q>﴿قالت إني أعوذ بالرحمن منك إن كنت تقيا﴾</q>، يعني: مُخْلِصًا لله ﷿ تَعَبُّدَه{8}. (ز) ٤٦٣٤٤- عن عبد الملك ابن جُرَيْج -من طريق حجاج- قوله: <q>﴿قالت إني أعوذ بالرحمن منك إن كنت تقيا﴾</q>، قال: خَشِيَتْ أن يكون إنّما يريدها على نفسها{9}. (ز) ",footnotes:1:أخرجه ابن عساكر في تاريخه ٤٧/٣٤٨-٣٤٩. وعزاه السيوطي إلى إسحاق بن بشر. وتقدم بتمامه مطولًا في سياق القصة.ذو نُهْية: ذو عقل وانتهاء عن فعل القبيح. الفتح ٦/٤٧٩.أخرجه عبد بن حميد -كما في فتح الباري ٦/٤٧٩، والتغليق ٤/٣٧-، وابن جرير ١٥/٤٨٧، وإسحاق البستي في تفسيره ص١٧٩، وابن أبي حاتم -كما في التغليق ٤/٣٧-. وعزاه السيوطي إلى ابن المنذر.عزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ١٥/٤٨٧.علقه يحيى بن سلام ١/٢١٩.أخرجه ابن جرير ١٥/٤٨٧.تفسير مقاتل بن سليمان ٢/٦٢٣.أخرجه ابن جرير ١٥/٤٨٦.
19,19," <q>﴿قَالَ إِنَّمَاۤ أَنَا۠ رَسُولُ رَبِّكِ لِأَهَبَ لَكِ غُلَـٰمࣰا زَكِیࣰّا ۝١٩﴾</q> - قراءات ٤٦٣٤٥- عن عاصم بن أبي النجود أنّه قرأ: <q>﴿لِأَهَبَ لَكِ﴾</q> مهموزة بالألف، وفي قراءة عبد الله: ‹لِيَهَبَ لَكِ› بالياء{1}٤١٤٤. (١٠/٥٠) ٤١٤٤ اختُلِف في قراءة قوله: <q>﴿لأهب﴾</q>؛ فقرأ قوم: <q>﴿لأهب﴾</q>، وقرا آخرون: ‹ليَهَبَ›. وذكر ابنُ جرير (١٥/٤٨٨) أنّ الأولى على الحكاية، والثانية بمعنى: ليهب الله لك. وبنحوه ابنُ عطية (٦/١٧). ورجَّح ابنُ جرير (١٥/٤٨٨) القراءة الأولى بالألف دون الياء مستندًا إلى رسم المصحف، والإجماع، فقال: «لأنّ ذلك كذلك في مصاحف المسلمين، وعليه قراءة قديمهم وحديثهم، غير أبي عمرو، وغير جائز خلافهم فيما أجمعوا عليه، ولا سائغ لأحد خلاف مصاحفهم». وذكر ابنُ كثير (٩/٢٢٧) أن كلتا القراءتين لها وجه حسن، ومعنى صحيح، وأنّ كلًّا منهما تستلزم الأخرى. <q>﴿قَالَ إِنَّمَاۤ أَنَا۠ رَسُولُ رَبِّكِ لِأَهَبَ لَكِ غُلَـٰمࣰا زَكِیࣰّا ۝١٩﴾</q> - تفسير الآية ٤٦٣٤٦- عن عبد الله بن عباس -من طريق جويبر، عن الضحاك-: قال جبريل وتبسم: <q>﴿إنما أنا رسول ربك لأهب لك غلاما زكيا﴾</q>، يعني: لله مطيعًا، مِن غير بشر{2}. (١٠/٤٢) ٤٦٣٤٧- عن مجاهد بن جبر، في قوله: <q>﴿قال إنما أنا رسول ربك لأهب لك غلاما﴾</q>: زعموا نَفَخَ في جيب دِرْعِها وكُمِّها{3}. (١٠/٥٠) ٤٦٣٤٨- عن قتادة بن دعامة، في قوله: <q>﴿غلاما زكيا﴾</q>، قال: صالِحًا{4}. (١٠/٥٠) ٤٦٣٤٩- قال مقاتل بن سليمان: <q>﴿قال﴾</q> جبريل ﵇: <q>﴿إنما أنا رسول ربك لاهب لك﴾</q> بأمر الله ﷿ <q>﴿غلاما زكيا﴾</q> يعني: مُخْلِصًا، يقول: صالحًا{5}. (ز) ٤٦٣٥٠- قال يحيى بن سلّام: <q>﴿قال إنما أنا رسول ربك لأهب لك غلاما زكيا﴾</q>، أي: صالحًا{6}. (ز) ",footnotes:1:عزاه السيوطي إلى عبد بن حميد. و<q>﴿لِأَهَبَ لَكِ﴾</q> قراءة العشرة ما عدا أبا عمرو، ويعقوب، وورشًا؛ فإنهم قرؤوا: ‹ليَهَبَ لَكِ› بالياء بدل الهمزة. انظر: النشر ٢/٣١٧، والإتحاف ص٣٧٦.أخرجه ابن عساكر في تاريخه ٤٧/٣٤٨-٣٤٩. وعزاه السيوطي إلى إسحاق بن بشر. وتقدم بتمامه مطولًا في سياق القصة.عزاه السيوطي إلى ابن المنذر.عزاه السيوطي إلى عبد الله بن أحمد في زوائد الزهد، وابن أبي حاتم.تفسير مقاتل بن سليمان ٢/٦٢٣.تفسير يحيى بن سلام ١/٢١٩.
19,20," <q>﴿قَالَتۡ أَنَّىٰ یَكُونُ لِی غُلَـٰمࣱ﴾</q> - تفسير ٤٦٣٥١- قال مقاتل بن سليمان: <q>﴿قالت﴾</q> مريم: <q>﴿أنى﴾</q> مِن أين <q>﴿يكون لي غلام ولم يمسسني بشر﴾</q>؟!{1}. (ز) ٤٦٣٥٢- قال يحيى بن سلّام: <q>﴿قالت أنى يكون لي غلام﴾</q>: مِن أين يكون لي غلام{2}. (ز) <q>﴿وَلَمۡ یَمۡسَسۡنِی بَشَرࣱ﴾</q> - تفسير ٤٦٣٥٣- عن عبد الله بن عباس -من طريق جويبر، عن الضحاك- <q>﴿قالت أنى يكون لي غلام ولم يمسسني بشر﴾</q>: يعني: زوجًا{3}. (١٠/٤٢) ٤٦٣٥٤- عن إسماعيل السُّدِّيّ: <q>﴿ولم يمسسني بشر﴾</q>: ولم يُجامِعْنِي زوجٌ{4}. (ز) <q>﴿وَلَمۡ أَكُ بَغِیࣰّا ۝٢٠﴾</q> - تفسير ٤٦٣٥٥- عن عبد الله بن عباس -من طريق جويبر، عن الضحاك- <q>﴿ولم أك بغيا﴾</q>: أي: مُومِسَة{5}. (١٠/٤٢) ٤٦٣٥٦- عن سعيد بن جبير، في قوله: <q>﴿ولم أك بغيا﴾</q>، قال: زانِيَة{6}. (١٠/٥٠) ٤٦٣٥٧- عن إسماعيل السُّدِّيّ -من طريق أسباط- <q>﴿ولم أك بغيا﴾</q>، يقول: زانية{7}. (ز) ٤٦٣٥٨- قال مقاتل بن سليمان: <q>﴿ولم أك بغيا﴾</q>، يعني: ولم أركب فاحشة{1}. (ز) ٤٦٣٥٩- قال يحيى بن سلّام، في قوله: <q>﴿ولم أك بغيا﴾</q>: أي: ولم أكُ زانية{2}. (ز) ",footnotes:1:تفسير مقاتل بن سليمان ٢/٦٢٣.تفسير يحيى بن سلام ١/٢١٩.أخرجه ابن عساكر في تاريخه ٤٧/٣٤٨-٣٤٩. وعزاه السيوطي إلى إسحاق بن بشر. وتقدم بتمامه مطولًا في سياق القصة.علقه يحيى بن سلام ١/٢١٩.أخرجه ابن عساكر في تاريخه ٤٧/٣٤٨-٣٤٩، وعزاه السيوطي إلى إسحاق بن بشر. وتقدم بتمامه مطولًا في سياق القصة.عزاه السيوطي إلى ابن أبي حاتم.أخرجه ابن جرير ١٥/٤٨٩.تفسير مقاتل بن سليمان ٢/٦٢٣.تفسير يحيى بن سلام ١/٢١٩.
19,21," <q>﴿قَالَ كَذَ ٰ⁠لِكِ قَالَ رَبُّكِ هُوَ عَلَیَّ هَیِّنࣱۖ﴾</q> - تفسير ٤٦٣٦٠- عن عبد الله بن عباس -من طريق جويبر، عن الضحاك-: <q>﴿قال﴾</q> جبريل: <q>﴿كذلك﴾</q> يعني: هكذا <q>﴿قال ربك هو علي هين﴾</q> يعني: خَلْقهُ مِن غير بشر{1}. (١٠/٤٢) ٤٦٣٦١- قال مقاتل بن سليمان: <q>﴿قال﴾</q> جبريل ﵇: <q>﴿كذلك﴾</q> يعني: هكذا <q>﴿قال ربك﴾</q> إنّه يكون لك ولد من غير زوج، <q>﴿هو علي﴾</q> على الله <q>﴿هين﴾</q> يعني: يسير أن يخلق فى بطنك ولدًا مِن غير بشر{2}٤١٤٥. (ز) ٤١٤٥ ذكر ابنُ عطية (٦/١٨) أن المعنى: قال لها المَلَك: كذلِك هو كما وصَفْتِ، ولكن قالَ رَبُّكِ. ثم ذكر أن قد يحتمل أن يريد: على هذه الحال قالَ رَبُّكِ، ثم قال: «والمعنى متقارب». ٤٦٣٦٢- قال يحيى بن سلّام، في قوله: <q>﴿قال كذلك قال ربك هو علي هين﴾</q>: أن أخلقه{3}. (ز) <q>﴿وَلِنَجۡعَلَهُۥۤ ءَایَةࣰ لِّلنَّاسِ﴾</q> - تفسير ٤٦٣٦٣- عن عبد الله بن عباس -من طريق جويبر، عن الضحاك- <q>﴿ولنجعله آية للناس﴾</q>: يعني: عِبْرة، والناس هنا للمؤمنين خاصة{1}. (١٠/٤٢) ٤٦٣٦٤- قال مقاتل بن سليمان: <q>﴿ولنجعله آية﴾</q> يقول: ولكي نجعله عبرة <q>﴿للناس﴾</q> يعني: في بني إسرائيل{2}. (ز) <q>﴿وَرَحۡمَةࣰ مِّنَّاۚ﴾</q> - تفسير ٤٦٣٦٥- عن عبد الله بن عباس -من طريق جويبر، عن الضحاك- <q>﴿ورحمة منا﴾</q>: لِمَن صدَّق بأنه رسول الله{1}. (١٠/٤٢) ٤٦٣٦٦- عن إسماعيل السُّدِّيّ: <q>﴿ورحمة منا﴾</q> لِمَن قَبِلَ عنه دينه{7}. (ز) ٤٦٣٦٧- قال مقاتل بن سليمان: <q>﴿ورحمة﴾</q> يعني: ونعمة <q>﴿منا﴾</q> لِمَن تَبِعَه على دينه. مثل قوله سبحانه: <q>﴿وما أرسلناك إلا رحمة للعالمين﴾</q> [الأنبياء:١٠٧]، يعني بالرحمة: النعمة لِمَن اتَّبعه على دينه{2}. (ز) <q>﴿وَكَانَ أَمۡرࣰا مَّقۡضِیࣰّا ۝٢١﴾</q> - تفسير ٤٦٣٦٨- عن عبد الله بن عباس -من طريق جويبر، عن الضحاك- <q>﴿وكان أمرا مقضيا﴾</q>: يعني: كائنًا أن يكون مِن غير بشر{1}. (١٠/٤٢) ٤٦٣٦٩- عن وهب بن مُنَبِّه -من طريق ابن إسحاق، عمَّن لا يتهم- <q>﴿وكان أمرا مقضيا﴾</q>: أي: أن الله قد عزم على ذلك، فليس منه بُدٌّ{10}. (ز) ٤٦٣٧٠- قال إسماعيل السُّدِّيّ: يعني: كان عيسى أمرًا مِن الله مكتوبًا في اللوح المحفوظ أنه يكون؛ فأخذ جبريل جيبَها بأصبعه، فنفخ فيه، فصار إلى بطنها، فحَمَلَتْ{11}. (ز) ٤٦٣٧١- قال مقاتل بن سليمان: <q>﴿وكان﴾</q> عيسى ﷺ مِن غير بشر <q>﴿أمرا مقضيا﴾</q>، قد قضى الله ﷿ فى اللوح المحفوظ أنّه كائن لا بُدّ{2}. (ز) ٤٦٣٧٢- قال يحيى بن سلّام: <q>﴿وكان أمرا مقضيا﴾</q> كائِنًا{3}٤١٤٦. (ز) ٤١٤٦ ذكر ابنُ كثير (٩/٢٢٨) أن قوله: <q>﴿وكان أمرا مقضيا﴾</q> يحتمل أمرين: أحدهما: أن يكون مِن تمام كلام جبريل لمريم، يخبرها أن هذا أمر مقدر في علم الله تعالى وقدره ومشيئته. والآخر: أن يكون مِن خبر الله تعالى لرسوله محمد ﷺ، وأنه كنّى بهذا عن النفخ في فرجها، كما قال تعالى: <q>﴿ومريم ابنت عمران التي أحصنت فرجها فنفخنا فيه من روحنا﴾</q> [التحريم:١٢]. ",footnotes:1:أخرجه ابن عساكر في تاريخه ٤٧/٣٤٨-٣٤٩، وعزاه السيوطي إلى إسحاق بن بشر. وتقدم بتمامه مطولًا في سياق القصة.تفسير مقاتل بن سليمان ٢/٦٢٣.تفسير يحيى بن سلام ١/٢١٩.أخرجه ابن عساكر في تاريخه ٤٧/٣٤٨-٣٤٩، وعزاه السيوطي إلى إسحاق بن بشر. وتقدم بتمامه مطولًا في سياق القصة.تفسير مقاتل بن سليمان ٢/٦٢٣.أخرجه ابن عساكر في تاريخه ٤٧/٣٤٨-٣٤٩، وعزاه السيوطي إلى إسحاق بن بشر. وتقدم بتمامه مطولًا في سياق القصة.علَّقه يحيى بن سلام ١/٢١٩.تفسير مقاتل بن سليمان ٢/٦٢٣.أخرجه ابن عساكر في تاريخه ٤٧/٣٤٨-٣٤٩، وعزاه السيوطي إلى إسحاق بن بشر. وتقدم بتمامه مطولًا في سياق القصة.أخرجه ابن جرير ١٥/٤٨٩.علقه يحيى بن سلام ١/٢١٩.تفسير مقاتل بن سليمان ٢/٦٢٣.تفسير يحيى بن سلام ١/٢١٩.
19,22," <q>﴿فَحَمَلَتۡهُ﴾</q> - تفسير ٤٦٣٧٣- عن عبد الله بن عباس -من طريق المغيرة بن عثمان- قال: ما هي إلا أن حَمَلَتْ فوَضَعَتْ{1}٤١٤٧. (١٠/٤٥) ٤١٤٧ وجَّهَ ابنُ كثير (٩/٢٣٠ بتصرف) قول ابن عباس بقوله: «كأنّه أخذه من ظاهر قوله تعالى: <q>﴿فحملته فانتبذت به مكانا قصيا فأجاءها المخاض إلى جذع النخلة﴾</q>». ثم انتقده مستندًا للغة، فقال: «وهذا غريب ... فالفاء وإن كانت للتعقيب، ولكن تعقيب كل شيء بحسبه، كما قال تعالى: <q>﴿ولقد خلقنا الإنسان من سلالة من طين ثم جعلناه نطفة في قرار مكين ثم خلقنا النطفة علقة فخلقنا العلقة مضغة فخلقنا المضغة عظاما﴾</q> [المؤمنون:١٢-١٤]، فهذه الفاء للتعقيب بحسبها، وقد ثبت في الصحيحين: أن بين كل صفتين أربعين يومًا. وقال تعالى: <q>﴿ألم تر أن الله أنزل من السماء ماء فتصبح الأرض مخضرة﴾</q> [الحج:٦٣]». ٤٦٣٧٤- عن عبد الله بن عباس -من طريق عكرمة- قال: وضَعَتْ مريمُ لثمانية أشهر؛ ولذلك لا يُولَد مولود لثمانية أشهر إلا مات، لِئَلّا تُسَبَّ مريمُ بعيسى{2}. (١٠/٤٦) ٤٦٣٧٥- عن عبد الله بن عباس -من طريق داود بن أبي هند، عن سعيد بن جبير- قال: تَغَفَّلها جبريل، فنفخ في جيب درعها، ونهض عنها، واستمرَّ بها حملُها{3}. (١٠/٤٠) ٤٦٣٧٦- عن عبد الله بن عباس -من طريق جويبر، عن الضحاك-: ... دنا جبريل، فنفخ في جيبها، فدخلت النفخةُ جوفَها، فاحتملت كما تحمل النساء في الرَّحِم والمشِيمَة، ووضعته كما تَضَعُ النساء{4}. (١٠/٤٢) ٤٦٣٧٧- عن مجاهد بن جبر -من طريق العلاء بن الحارث الكوفي- قال: قالت مريم: كنتُ إذا خَلَوْتُ حدَّثني عيسى وكلَّمني وهو في بطني، وإذا كنتُ مع النّاس سَبَّح في بطني وكَبَّر، وأنا أسمع{5}. (١٠/٤٥) ٤٦٣٧٨- عن الحسن البصري، قال: بلغني: أنّ مريم حَمَلَتْ لسبع أو تسع ساعات، ووَضَعَتْهُ مِن يومِها{6}. (١٠/٤٦) ٤٦٣٧٩- قال الحسن البصري: <q>﴿فحملته﴾</q> تسعة أشهر في بطنها{7}. (ز) ٤٦٣٨٠- عن وهب بن مُنَبِّه -من طريق ابن إسحاق، عمَّن لا يتهم- قال: لَمّا قال ذلك -يعني: لما قال جبريل <q>﴿قال كذلك قال ربك هو علي هين﴾</q> الآية- اسْتَسْلَمَتْ لأمر الله، فنفخ في جيبها، ثم انصرف عنها{8}. (ز) ٤٦٣٨١- عن إسماعيل السُّدِّيّ -من طريق أسباط- قال: طَرَحَتْ عليها جلبابَها لَمّا قال جبريلُ ذلك لها، فأخذ جبريلُ بِكُمَّيْها، فنفخ في جَيْبِ دِرْعِها، وكان مشقوقًا مِن قُدّامها، فدخلت النفخةُ صدرَها، فحملت، فأتتها أختُها امرأةُ زكريا ليلةً تزورها، فلمّا فتحت لها الباب التزمتها، فقالت امرأة زكريا: يا مريم، أُشْعِرتُ أني حبلى. قالت مريم: أُشْعِرتُ أيضًا أنِّي حُبْلى. قالت امرأة زكريا: إنِّي وجدتُ ما في بطني يسجد لما في بطنك. فذلك قوله: <q>﴿مصدقا بكلمة من الله﴾</q> [آل عمران:٣٩]{8}. (ز) ٤٦٣٨٢- قال عبد الملك ابن جُرَيْج -من طريق حجاج-: يقولون: إنّه إنما نَفَخ في جَيْبِ دِرْعِها وكُمِّها{10}. (ز) ٤٦٣٨٣- قال مقاتل بن سليمان: <q>﴿فحملته﴾</q> أمُّه مريمُ ﵍ وهي ابنة ثلاث عشرة سنة، ومكثت مع عيسى ﵇ ثلاثًا وثلاثين سنة، وعاشت بعد ما رُفِع عيسى سِتَّ سنين، فماتت ولها اثنتان وخمسون سنة، فحملته أمه في ساعة واحدة، وصُوِّر في ساعة واحدة، وأَرْضَعَتْه في ساعةٍ حين زالت الشمسُ مِن يومها، وقد كانت حاضت حيضتين قبل حملِه{11}٤١٤٨. (ز) ٤١٤٨ أفادت الآثارُ الاختلاف في مدة حمل عيسى. ورجَّح ابنُ كثير (٩/٢٣٠) أنها تسعة أشهر كما قال الحسن مستندًا إلى ظاهر القرآن، فقال: «فالمشهور الظاهر -والله على كل شيء قدير- أنها حملت به كما تحمل النساء بأولادهن؛ ولهذا لَمّا ظهرت مَخايِلُ الحملِ عليها، وكان معها في المسجد رجلٌ صالح مِن قَراباتها يخدم معها البيت المقدس، يُقال له: يوسف النجار، فلمّا رأى ثِقَل بطنها وكِبَرِه أنكر ذلك مِن أمرها، ثُمَّ صرفه ما يعلم مِن براءتها ونزاهتها ودينها وعبادتها ...». وذكر (٩/٢٢٩) أنّ هذا هو رأي الجمهور. وكذا ذكر ابنُ عطية (٦/٢١). وذكر ابنُ عطية أن ظاهر قوله: <q>﴿فأجاءها المخاض﴾</q> يقتضي أنها حملت على عُرْف البشر. <q>﴿فَٱنتَبَذَتۡ بِهِۦ مَكَانࣰا قَصِیࣰّا ۝٢٢﴾</q> - تفسير ٤٦٣٨٤- عن عبد الله بن مسعود -من طريق السدي، عن مُرَّة الهمداني-= (ز) ٤٦٣٨٥- وعبد الله بن عباس -من طريق السدي، عن أبي مالك- قالا: ولَمّا بلغ أن تضع مريمُ خرجت إلى جانب المحراب، <q>﴿فأجاءها المخاض إلى جذع النخلة قالت يا ليتني مت قبل هذا﴾</q> الآية{12}. (ز) ٤٦٣٨٦- عن عبد الله بن عباس -من طريق العوفي- في قوله: <q>﴿مكانا قصيا﴾</q>، قال: نائِيًا{13}. (١٠/٥١) ٤٦٣٨٧- قال عبد الله بن عباس: أقصى الوادي{14}. (ز) ٤٦٣٨٨- عن عبد الله بن عباس -من طريق داود بن أبي هند، عن سعيد بن جبير- قال: اسْتَمَرَّ بها حَمْلُها، فقالت: إن خرجتُ نحو المغرب فالقوم يُصَلُّون نحوَ المغرب، ولكن أخْرُجُ نحوَ المشرق حيث لا يراني أحد. فخرجت نحوَ المشرق، فبينما هي تمشي إذ فَجَأَها المخاضُ، فنظرت هل تجد شيئًا تَسْتَتِرُ به، فلم تَرَ إلا جذع النخلة، فقال: أستتر بهذا الجِذْع من الناس{3}. (١٠/٤٠) ٤٦٣٨٩- عن مجاهد بن جبر -من طريق ابن أبي نَجِيحٍ- في قوله: <q>﴿مكانا قصيا﴾</q>، قال: قاصيًا{16}. (١٠/٥١) ٤٦٣٩٠- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿فانتبذت به مكانا قصيا﴾</q>، قال: أي: فانفردت به مكانًا شاسِعًا مُنتَحِيًا{17}. (ز) ٤٦٣٩١- عن وهب بن مُنَبِّه -من طريق عبد الصمد بن معقل- قال: لَمّا اشتملت مريمُ على الحمل كان معها قَرابَةٌ لها، يقال له: يوسف النجار، وكانا مُنطَلِقَيْن إلى المسجد الذي عند جبل صهيون، وكان ذلك المسجدُ يومئذٍ مِن أعظم مساجدهم، فكانت مريم ويوسف يخدمان في ذلك المسجد، في ذلك الزمان، وكان لخدمته فضل عظيم، فرَغِبا في ذلك، فكانا يَلِيان معالجته بأنفسهما؛ تَحْبِيرَه{18} وكُناسَتَه وطهوره وكل عمل يُعْمَل فيه، وكان لا يُعْلَم مِن أهل زمانهما أحدٌ أشدُّ اجتهادًا وعبادةً منهما، فكان أول مَن أنكر حمل مريم صاحبها يوسف، فلمّا رأى الذي بها اسْتَعْظَمَهُ، وعظم عليه، وفظع به، فلم يدرِ على ماذا يضع أمرها، فإذا أراد يوسف أن يتهمها ذكر صلاحها وبراءتها، وأنها لم تغب عنه ساعةً قط، وإذا أراد أن يُبَرِّئها رأى الذي ظَهَر عليها، فلمّا اشْتَدَّ عليه ذلك كَلَّمَها، فكان أول كلامه إيّاها أن قال لها: إنّه قد حَدَث في نفسي مِن أمْرِكِ أمْرٌ قد خشيته، وقد حرصت على أن أُميْتَه وأكتمه في نفسي، فغلبني ذلك، فرأيت الكلام فيه أشفى لصدري. قالت: فقُل قولًا جميلًا. قال: ما كنتُ لِأقول لكِ إلا ذلك، فحدِّثيني، هل ينبت زرعٌ بغير بَذْرٍ؟ قالت: نعم. قال: فهل تنبت شجرةٌ مِن غير غَيْثٍ يُصيبها؟ قالت: نعم. قال: فهل يكون ولد مِن غير ذَكَر؟ قالت: نعم؛ ألم تعلم أنّ الله -تبارك وتعالى- أنبَتَ الزَّرْعَ يوم خلقه مِن غير بِذْر، والبِذْرُ يومئذٍ إنّما صار مِن الزَّرع الذي أنبته الله مِن غير بذر؟ أوَلَم تعلم أنّ الله بقدرته أنبت الشجر بغير غيث، وأنّه جعل بتلك القدرة الغيثَ حياةً للشجر بعد ما خلق كلَّ واحدٍ منهما وحده، أم تقول: لن يقدر الله على أن ينبت الشجر حتى استعان عليه بالماء، ولولا ذلك لم يقدر على إنباته؟ قال يوسف لها: لا أقول هذا، ولكنِّي أعلم أن الله -تبارك وتعالى- بقدرته على ما يشاء يقول لذلك: كن. فيكون. قالت مريم: أوَلَم تعلم أنّ الله -تبارك وتعالى- خلق آدمَ وامرأتَه من غير أنثى ولا ذَكَر؟ قال: بلى. فلمّا قالت له ذلك وقع في نفسه أنّ الذي بها شيءٌ من الله -تبارك وتعالى-، وأنّه لا يَسَعُهُ أن يسألها عنه، وذلك لِما رأى مِن كتمانها لذلك، ثُمَّ تَوَلّى يوسفُ خِدمة المسجد، وكفاها كلَّ عمل كانت تعمل فيه، وذلك لِما رأى مِن رِقَّة جِسمها، واصفرار لونها، وكَلَفِ وجهِها، ونُتُوِّ بطنِها، وضعف قوتها، ودأبِ نظرها، ولم تكن مريم قبل ذلك كذلك، فلمّا دنا نِفاسُها أوحى الله إليها أن اخرجي مِن أرض قومك، فإنّهم إن ظَفِرُوا بك عيَّروك، وقتلوا ولدك، فأفضت ذلك إلى أختها، وأختُها حينئذ حُبْلى، وقد بُشِّرَت بيحيى، فلمّا التقيا وجدت أمُّ يحيى ما في بطنها خرَّ لوجهه ساجدًا مُعْتَرِفًا بعيسى، فاحتملها يوسفُ إلى أرض مصر على حمارٍ له ليس بينها حين ركبت الحمار وبين الإكافِ{19} شيء، فانطلق يوسف بها حتى إذا كان مُتاخِمًا لأرض مصر في منقطع بلاد قومها أدرك مريمَ النفاسُ، فألجأها إلى آريِّ حمار -يعني: مِذْودَ الحمار{20}- وأصل نخلة، وذلك في زمان بردٍ أو حَرٍّ -الشك من أبي جعفر-، فاشتد على مريم المخاض، فلمّا وجدت منه شِدَّةً التجأت إلى النخلة، فاحتضنتها، واحْتَوَشَتْها الملائكةُ{21}، قاموا صفوفًا مُحْدِقِين بها{22}٤١٤٩. (ز) ٤١٤٩ ذكر ابنُ عطية (٦/٢١) أنه على هذه الرواية فإن مريم حملت واستمر حملها على عرف البشر. ٤٦٣٩٢- عن وهب بن مُنَبِّه -من طريق ابن إسحاق، عمَّن لا يتَّهم- قال: لَمّا حضر ولادها، يعني: مريم، ووجدت ما تجد المرأةُ مِن الطَّلق؛ خرجت من المدينة مُغَرِّبَةً مِن إيلياء، حتى تدركها الولادة إلى قرية مِن إيلياء على سِتَّة أميال يُقال لها: بيت لحم، فأجاءها المخاض إلى أصل نخلة إليها مِذْود بقرة، تحتها ربيعٌ من الماء، فوَضَعَتْه عندها{23}. (ز) ٤٦٣٩٣- عن إسماعيل السُّدِّيّ -من طريق أسباط- قال: لَمّا بلغ أن تضع مريمُ خرجت إلى جانب المحراب الشرقيِّ منه، فأتت أقصاه{13}. (ز) ٤٦٣٩٤- قال مقاتل بن سليمان: <q>﴿فانتبذت به﴾</q> يعني: فانفردت بعيسى ﷺ <q>﴿مكانا قصيا﴾</q> يعني: نائيًا مِن أهلها مِن وراء الجبل{25}٤١٥٠. (ز) ٤١٥٠ أفادت الآثار الاختلاف في مكان ولادة عيسى؛ فقال قوم: كان شرقيَّ محرابها الذي تُصَلِّي فيه من بيت المقدس. وقال آخرون: لما كانت بين الشام وبلاد مصر ضربها الطَّلق. وقال غيرهم: كان ذلك على ثمانية أميال من بيت المقدس، في قرية هناك يقال لها: بيت لحم. ورجَّح ابنُ كثير (٩/٢٣١-٢٣٢) مستندًا إلى الإسرائيليات، والسنة القولَ الأخير الذي قاله وهب بن منبه من طريق ابن إسحاق، فقال: «وهذا هو المشهور الذي تلقّاه الناسُ بعضُهم عن بعض، ولا يَشُكُّ فيه النصارى أنّه ببيت لحم، وقد تلقاه الناس. وقد ورد به الحديث إن صَحَّ». <q>﴿فَٱنتَبَذَتۡ بِهِۦ مَكَانࣰا قَصِیࣰّا ۝٢٢﴾</q> - آثار متعلقة بالآية ٤٦٣٩٥- في حديث شداد بن أوس عن الإسراء، قال الرسول ﷺ: «ثم بلغنا أرضًا بَدَتْ لنا قصورُها، فقال: انزل. فنَزَلْتُ، ثم قال: صلِّ. فصَلَّيْتُ، ثم ركبنا، فقال: أتدري أين صَلَّيْتَ؟ قلت: الله أعلم. قال: صَلَّيْتَ ببيت لحمٍ حيث وُلِد عيسى المسيح ابن مريم»{26}. (٩/١٥٣-١٥٧) ٤٦٣٩٦- عن زيد العَمِّيِّ، قال: وُلِد عيسى يوم عاشوراء{27}. (١٠/٤٦) ",footnotes:1:أخرجه عبد الرزاق ٢/٧ من طريق الثوري عن رجل عمن سمع ابن عباس، وابن جرير ١٥/٤٩٧، وإسحاق البستي في تفسيره ص١٨٠. وعزاه السيوطي إلى الفريابي، وابن المنذر، وابن أبي حاتم.أخرجه ابن عساكر ٧٠/٩٢.أخرجه ابن عساكر ٧٠/٨١-٨٣. وتقدم بتمامه في سياق القصة.أخرجه ابن عساكر في تاريخه ٤٧/٣٤٨-٣٤٩، ٧٠/٩٥-٩٦، وعزاه السيوطي إلى إسحاق بن بشر. وتقدم بتمامه في سياق القصة.أخرجه ابن أبي شيبة ١١/٥٤٤، ١٣/١٩٦، وابن أبي حاتم -كما في تفسير ابن كثير ٣/٢٢١-، وأبو نعيم ٣/٢٩٤.أخرجه ابن عساكر ٤٧/٣٥٢.علَّقه يحيى بن سلام ١/٢٢٠.أخرجه ابن جرير ١٥/٤٩٠.أخرجه ابن جرير ١٥/٤٩٠.أخرجه ابن جرير ١٥/٤٩١.تفسير مقاتل بن سليمان ٢/٦٢٤. ونحوه في تفسير الثعلبي ٦/٢١٠، وتفسير البغوي ٥/٢٢٥ عن مقاتل بن سليمان، إلا أن فيه: وهي بنت عشر سنين.أخرجه الحاكم ٢/٥٩٣، والبيهقي في الأسماء والصفات (٧٧٣)، وابن عساكر في تاريخ دمشق ٧٠/٨٦. وتقدم بتمامه في سياق القصة.أخرجه ابن جرير ١٥/٤٩٢.تفسير البغوي ٥/٢٢٤.أخرجه ابن عساكر ٧٠/٨١-٨٣. وتقدم بتمامه في سياق القصة.أخرجه ابن جرير ١٥/٤٩٢. وعزاه السيوطي إلى عبد الرزاق، وعبد بن حميد، وابن أبي شيبة، وابن المنذر، وابن أبي حاتم.أخرجه يحيى بن سلام ١/٢٢٠، وعبد الرزاق ٢/٦ من طريق معمر بلفظ: متنحيّا.تَحْبِيرَه: تحسينه. لسان العرب (حبر).الإكاف للحمار كالسرج للفرس. تفسير غريب ما في الصحيحين للحميدي ص١٨٣.مِذْوَدُ الحمار: مكان علفه. لسان العرب (ذود).احْتَوَشَتْها الملائكة: جعلوها وسَطهم. لسان العرب (حوش).أخرجه ابن جرير ١٥/٤٩٤.أخرجه ابن جرير ١٥/٤٨٦.أخرجه ابن جرير ١٥/٤٩٢.تفسير مقاتل بن سليمان٢/٦٢٤.أخرجه البزار في مسنده ٨/٤٠٩-٤١١ (٣٤٨٤)، والطبراني في الكبير ٧/٢٨٢- ٢٨٣ (٧١٤٢). قال البزار: «لا نعلمه يُرْوى عن شداد بن أوس عن النبي ﷺ إلا بهذا الإسناد». وقال البيهقي في دلائل النبوة ٢/٣٥٧: «هذا إسناد صحيح». وقال إسماعيل الأصبهاني في دلائل النبوة ص١٤٤ (١٥٦): «هذا حديث شاميُّ الطريق، واضح الإسناد». وقال ابن كثير في تفسيره ٥/٢٧: «ولا شك أن هذا الحديث -أعني: الحديث المروي عن شداد بن أوس- مشتمل على أشياء، منها ما هو صحيح كما ذكره البيهقي، ومنها ما هو منكر؛ كالصلاة في بيت لحم، وسؤال الصديق عن نعت بيت المقدس، وغير ذلك». وقال الهيثمي في المجمع ١/٧٤ (٢٣٦): «وفيه إسحاق بن إبراهيم بن العلاء، وثّقه يحيى بن معين، وضعّفه النسائي». وقد ورد الحديث بتمامه مطولًا في الآثار المتعلقة بتفسير قوله تعالى: <q>﴿سُبْحانَ الَّذِي أسْرى بِعَبْدِهِ لَيْلًا مِنَ المَسْجِدِ الحَرامِ إلى المَسْجِدِ الأَقْصى الَّذِي بارَكْنا حَوْلَهُ لِنُرِيَهُ مِن آياتِنا﴾</q> [الإسراء:١].أخرجه الحاكم ٢/٥٩٣.
19,23," <q>﴿فَأَجَاۤءَهَا ٱلۡمَخَاضُ﴾</q> - تفسير ٤٦٣٩٧- عن عبد الله بن عباس: أن نافع بن الأزرق قال له: أخبِرني عن قوله ﷿: <q>﴿فأجاءها المخاض﴾</q>. قال: ألْجَأَها. قال: وهل تعرف العرب ذلك؟ قال: نعم، أما سمعت حسان بن ثابت وهو يقول: إذا شَدَدْنا شَدَّةً صادقة فَأَجَأْناكم إلى سفح الجبل؟{1}. (١٠/٥١) ٤٦٣٩٨- عن مجاهد بن جبر -من طريق ابن أبي نَجِيحٍ- في قوله: <q>﴿فأجاءها المخاض﴾</q>، قال: ألْجَأَها{2}. (١٠/٥١) ٤٦٣٩٩- عن الضحاك بن مُزاحِم، في قوله: <q>﴿فأجاءها المخاض﴾</q>، قال: فأدّاها{3}. (١٠/٥١) ٤٦٤٠٠- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿فأجاءها المخاض﴾</q>، قال: اضْطَّرَّها إلى جِذع نخلة{4}. (١٠/٥١) ٤٦٤٠١- عن إسماعيل السُّدِّيّ -من طريق أسباط- <q>﴿فأجاءها المخاض إلى جذع النخلة﴾</q>، يقول: ألْجَأها المخاضُ إلى جِذع النخلة{5}. (ز) ٤٦٤٠٢- قال مقاتل بن سليمان: <q>﴿فأجاءها المخاض﴾</q>، يعني: فأَلْجَأَها{6}. (ز) <q>﴿إِلَىٰ جِذۡعِ ٱلنَّخۡلَةِ﴾</q> - تفسير ٤٦٤٠٣- عن عبد الله بن عباس -من طريق العوفي- في قوله: <q>﴿فأجاءها المخاض إلى جذع النخلة﴾</q>، قال: كان جِذْعًا يابِسًا{7}. (١٠/٥٢) ٤٦٤٠٤- عن مجاهد بن جبر -من طريق جابر- في قوله: <q>﴿إلى جذع النخلة﴾</q>، قال: كانت عجوة{8}. (ز) ٤٦٤٠٥- قال مقاتل بن سليمان: <q>﴿إلى جذع النخلة﴾</q>، ولم يكن لها سَعَفٌ{6}. (ز) ٤٦٤٠٦- عن أبي عبيد الله -من طريق هلال بن خباب- <q>﴿فأجاءها المخاض﴾</q>، قال: إلى جذع نخلة يابس، قد جِيء به لِيُبْنى به بيتٌ يُقال له: بيت لحم، فَحَرَّكَتْهُ، فإذا هو نخلة{10}. (١٠/٥٢) ٤٦٤٠٧- عن أبي قدامة، قال: أُنْبِتَتْ لمريم نخلةٌ تَعَلَّقُ بها كما تَعَلَّقُ المرأة بالمرأة عند الولادة{11}. (١٠/٥٢، ٥٩) <q>﴿قَالَتۡ یَـٰلَیۡتَنِی مِتُّ قَبۡلَ هَـٰذَا وَكُنتُ نَسۡیࣰا مَّنسِیࣰّا ۝٢٣﴾</q> - تفسير ٤٦٤٠٨- عن عبد الله بن عباس -من طريق عطاء الخراساني- في قوله: <q>﴿وكنت نسيا منسيا﴾</q>، قال: لم أُخْلَق، ولم أك شيئًا{12}. (١٠/٥٢) ٤٦٤٠٩- عن نوف البِكالِيِّ -من طريق أبي عمران الجوني- قال: وكنتُ حيضة نسيتها{13}. (١٠/٥٢) ٤٦٤١٠- عن مجاهد بن جبر، في قوله: <q>﴿وكنت نسيا منسيا﴾</q>، قال: حيضة{14}. (١٠/٥٢) ٤٦٤١١- عن مجاهد بن جبر -من طريق جابر- في قوله: <q>﴿يا ليتني مت قبل هذا وكنت نسيا منسيا﴾</q>، قال: يا ليتني كنت حيضة مُلْقاةً على عَقِبَي أُمِّي{15}. (ز) ٤٦٤١٢- عن سعيد بن جبير -من طريق أبي سنان-، مثله{8}. (ز) ٤٦٤١٣- عن الضحاك بن مزاحم، في قوله: <q>﴿وكنت نسيا منسيا﴾</q>، قال: حيضة مُلْقاة{17}. (١٠/٥٢) ٤٦٤١٤- عن عكرمة مولى ابن عباس، في قوله: <q>﴿وكنت نسيا منسيا﴾</q>، قال:حيضة مُلْقاة{18}. (١٠/٥٢) ٤٦٤١٥- قال الحسن البصري: <q>﴿قالت يا ليتني مت قبل هذا﴾</q> مِمّا خَشِيَتْ مِن الفضيحة{19}. (ز) ٤٦٤١٦- عن قتادة بن دعامة -من طريق معمر- في قوله: <q>﴿كنت نسيا منسيا﴾</q>، قال: تقول: لا أُعْرَفُ، ولا أدري مَن أنا{20}. (١٠/٥٢) ٤٦٤١٧- عن قتادة بن دعامة -من طريق سعيد- أي: شيء لا يُعرَف، ولا يُذكَر{21}. (ز) ٤٦٤١٨- عن إسماعيل السُّدِّيّ -من طريق أسباط- قال: قالت وهي تَطْلَقُ مِن الحَبَل استحياءً مِن الناس: <q>﴿يا ليتني مت قبل هذا وكنت نسيا منسيا﴾</q>. يقول: <q>﴿نسيًا﴾</q>: نُسِيَ ذِكْرِي. و<q>﴿منسيا﴾</q> يقول: نُسِيَ أثَرِي، فلا يُرى لِي أثَرٌ ولا عَيْنٌ{22}. (ز) ٤٦٤١٩- عن الربيع بن أنس -من طريق أبي جعفر- في قوله: <q>﴿وكنت نسيا منسيا﴾</q>، قال: هو السَّقْطُ{23}. (١٠/٥٣) ٤٦٤٢٠- قال محمد بن السائب الكلبي: <q>﴿وكنت نسيا منسيا﴾</q>، قال: القوم ينزلون المنزل ثم يرتحلون، وينسون الشيءَ، فيُسمّى ذلك الشيء: النَّسا{24}. (ز) ٤٦٤٢١- قال مقاتل بن سليمان: <q>﴿قالت﴾</q> مريم: <q>﴿يا ليتني مت قبل هذا﴾</q> الولدِ؛ حياءً مِن الناس، ثم قالت: <q>﴿وكنت نسيا منسيا﴾</q> يعني: كالشيء الهالك الذي لا يُذْكَرُ فَيُنسى{6}. (ز) ٤٦٤٢٢- قال يحيى بن سلام: وذكر حماد بن سلمة المرأة النَّسُوءُ، وقال: النَّسُوءُ التي يُظَنُّ بها حَمْلٌ فلا يكون كذلك{24}. (ز) ٤٦٤٢٣- قال عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿يا ليتني مت قبل هذا وكنت نسيا منسيا﴾</q>: لم أكن في الأرض شيئًا قطُّ{27}. (ز) ٤٦٤٢٤- قال يحيى بن سلّام: <q>﴿وكنت نسيا﴾</q> لا أُذكَر، <q>﴿منسيا﴾</q> لم أُذْكَرْ{28}. (ز) ",footnotes:1:أخرجه الطستي -كما في الإتقان ٢/٧١-.أخرجه يحيى بن سلام ١/٢٢٠ من طريق عاصم بن حكيم، وابن جرير ١٥/٤٩٣، وإسحاق البستي في تفسيره (رسالة جامعية، تحقيق: عوض العمري) ص١٨١ من طريق ابن جريج. وعزاه السيوطي إلى عبد الرزاق، وعبد بن حميد، وابن أبي شيبة، وابن المنذر، وابن أبي حاتم.عزاه السيوطي إلى ابن أبي شيبة، وابن المنذر، وابن أبي حاتم.أخرجه ابن جرير ١٥/٤٩٤. وعزاه السيوطي إلى ابن أبي حاتم.أخرجه ابن جرير ١٥/٤٩٤.تفسير مقاتل بن سليمان ٢/٦٢٤.أخرجه ابن جرير ١٥/٥١١. وعزاه السيوطي إلى ابن أبي حاتم.أخرجه الثوري في تفسيره ص١٨٣.تفسير مقاتل بن سليمان ٢/٦٢٤.عزاه السيوطي إلى عبد بن حميد.عزاه السيوطي إلى عبد الله بن أحمد في زوائد الزهد، وابن أبي حاتم.أخرجه ابن جرير ١٥/٤٩٩. وعزاه السيوطي إلى ابن المنذر.أخرجه يحيى بن سلام ١/٢٢٠. وعزاه السيوطي إلى عبد بن حميد بلفظ: حيضة ملقاة.عزاه السيوطي إلى عبد بن حميد، وابن المنذر. وورد في تفسير الثعلبي ٦/٢١١ بلفظ: حيضة ملقاة، وفي تفسير البغوي ٥/٢٢٥: جيفة ملقاة.أخرجه الثوري في تفسيره ص١٨٣، وإسحاق البستي في تفسيره ص١٨٢من طريق سفيان عن رجل، بلفظ: حيضة ملقاة.أخرجه الثوري في تفسيره ص١٨٣.عزاه السيوطي إلى عبد بن حميد. وأخرجه إسحاق البستي في تفسيره ص١٨٢ من طريق أبي سنان، بلفظ:حيضة على عقبي. وفي تفسير الثعلبي ٦/٢١١: حيضة ملقاة، وفي تفسير البغوي ٥/٢٢٥: جيفة ملقاة.عزاه السيوطي إلى ابن أبي شيبة، وعبد بن حميد، وابن المنذر، وابن أبي حاتم. وفي تفسير الثعلبي ٦/٢١١، وتفسير البغوي ٥/٢٢٥: جيفة ملقاة.علَّقه يحيى بن سلام ١/٢٢٠.أخرجه عبد الرزاق ٢/٦، وابن جرير ١٥/٥٠٠. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.أخرجه يحيى بن سلام ١/٢٢٠، وابن جرير ١٥/٤٩٩.أخرجه ابن جرير ١٥/٤٩٨-٤٩٩.أخرجه ابن جرير ١٥/٥٠٠. وعزاه السيوطي إلى عبد بن حميد، وابن أبي حاتم.علقه يحيى بن سلام ١/٢٢٠.تفسير مقاتل بن سليمان ٢/٦٢٤.علقه يحيى بن سلام ١/٢٢٠.أخرجه ابن جرير ١٥/٥٠٠.تفسير يحيى بن سلام ١/٢٢٠.
19,24," <q>﴿فَنَادَىٰهَا مِن تَحۡتِهَاۤ أَلَّا تَحۡزَنِی﴾</q> - قراءات ٤٦٤٢٥- عن علقمة بن قيس النخعي -من طريق إبراهيم- أنه قرأ: (فَخاطَبَها مَن تَحْتَها){1}٤١٥١. (١٠/٥٣) ٤١٥١ علَّق ابنُ جرير (١٥/٥٠١) على قراءة علقمة بقوله: «والصواب <q>﴿مِن﴾</q>، ولكن كذا قال ابن بشار: (مَن) هنا». ٤٦٤٢٦- عن علقمة بن قيس النخعي -من طريق إبراهيم- أنه قرأ: (فَخاطَبَها مِن تَحْتِها){2}. (ز) ٤٦٤٢٧- عن زِرِّ بن حُبَيْش أنّه قرأ: ‹فَناداها مَن تَحْتَها›{3}. (١٠/٥٤) ٤٦٤٢٨- عن الحسن البصري، قال: مَن قرأ: <q>﴿مِن تَحْتِها﴾</q> فهو جبريل، ومَن قرأ:‹مَن تَحْتَها› فهو عيسى{4}. (١٠/٥٤) ٤٦٤٢٩- عن أبي بكر بن عياش، قال: قرأ عاصم [بن أبي النجود]: ‹فَناداها مَن تَحْتَها› بالنصب. قال: وقال عاصم: مَن قرأ بالنصب فهو عيسى، ومَن قرأها بالخفض فهو جبريل{5}٤١٥٢. (١٠/٥٤) ٤١٥٢ اختُلِف في قراءة قوله: <q>﴿فناداها من تحتها﴾</q>؛ فقرأ قوم: ‹مَن›، وقرأ آخرون: <q>﴿مِن﴾</q>. وذكر ابنُ عطية (٦/٢١-٢٢) أن القراءة الأولى بالفتح على أن ‹مَن› فاعل «نادى»، والمراد بـ‹مَن› عيسى. وأنّ قراءة كسر الميم تأتي على أنها لابتداء الغاية، وأنهم اختلفوا في التفسير؛ فقال بعضهم: المراد: عيسى. وقال آخرون: المراد: جبريل المجاور لها قبل. وبنحوه ابنُ جرير (١٥/٥٠٠-٥٠١). وذكر ابنُ كثير (٩/٢٣٣) أنّ قراءة الفتح بمعنى: الذي تحتها. وقراءة الكسر على أن <q>﴿مِن﴾</q> حرف جر. ورجَّح ابنُ جرير (١٥/٥٠٥) أن المنادِي عيسى، ثم رجَّح صحة كلتا القراءتين مستندًا إلى المعنى، فقال: «وذلك أنه إذا قرئ بالكسر كان في قوله <q>﴿فناداها﴾</q> ذِكرٌ من عيسى، وإذا قرئ ‹مَن تَحْتَها› بالفتح كان الفعل لـ‹مَن›، وهو عيسى». <q>﴿فَنَادَىٰهَا مِن تَحۡتِهَاۤ أَلَّا تَحۡزَنِی﴾</q> - تفسير الآية ٤٦٤٣٠- عن أبي بن كعب، قال: الذي خاطبها هو الذي حَمَلَتْه في جوفها، دخل مِن فيها{6}. (١٠/٥٤) ٤٦٤٣١- عن عبد الله بن عباس -من طريق العوفي- في قوله: <q>﴿فناداها من تحتها﴾</q>، قال: جبريل، ولم يتكلَّم عيسى حتى أتَتْ به قومَها{7}. (١٠/٥٣) ٤٦٤٣٢- عن البراء بن عازِب، <q>﴿فناداها من تحتها﴾</q>، قال: مَلَك{4}. (١٠/٥٣) ٤٦٤٣٣- عن سعيد بن جبير، في قوله: <q>﴿فناداها من تحتها﴾</q>، قال: جبريلُ مِن أسفلِ الوادي{6}. (١٠/٥٣) ٤٦٤٣٤- عن سعيد بن جبير -من طريق ثابت بن عجلان- قوله: <q>﴿فناداها من تحتها﴾</q>، قال: عيسى، أما تسمعُ اللهَ يقول: <q>﴿فأشارت إليه﴾</q>؟{10}. (ز) ٤٦٤٣٥- عن إبراهيم النخعي -من طريق مغيرة- قال: عيسى{11}. (ز) ٤٦٤٣٦- عن عكرمة مولى ابن عباس، قال: الذي ناداها هو جبريل{5}. (١٠/٥٣) ٤٦٤٣٧- عن عمرو بن ميمون -من طريق حُصَيْنٍ- قال: الذي ناداها الملَك{13}. (١٠/٥٣) ٤٦٤٣٨- عن مجاهد بن جبر -من طريق ابن أبي نَجِيحٍ- في قوله: <q>﴿فناداها من تحتها﴾</q>، قال: عيسى ابن مريم{14}. (١٠/٥٤) ٤٦٤٣٩- عن الضَّحّاك بن مُزاحِم -من طريق عبيد بن سليمان- <q>﴿فناداها من تحتها﴾</q> قال: يعني: جبريل، <q>﴿من تحتها﴾</q> قال: كان أسفل منها{15}. (١٠/٥٣) ٤٦٤٤٠- عن الحسن البصري -من طريق قتادة- <q>﴿فناداها من تحتها﴾</q>، قال: ابنُها{16}. (١٠/٥٤) ٤٦٤٤١- عن وهب بن مُنَبِّه -من طريق ابن إسحاق، عمَّن لا يتَّهم- <q>﴿فناداها﴾</q>: عيسى{10}. (ز) ٤٦٤٤٢- عن قتادة بن دعامة -من طريق سعيد- <q>﴿فناداها من تحتها﴾</q>: أي: الملَك مِن تحت النخلة{18}. (١٠/٥٤) ٤٦٤٤٣- عن إسماعيل السُّدِّيّ -من طريق أسباط- <q>﴿فناداها﴾</q>: جبريل{19}. (ز) ٤٦٤٤٤- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- <q>﴿فناداها من تحتها﴾</q> قال: عيسى ناداها: <q>﴿أن لا تحزني قد جعل ربك تحتك سريا﴾</q>. قالت: وكيف لا أحزن وأنتَ معي؟! لا ذات زوج فأقول: مِن زوج، ولا مملوكة فأقول: مِن سيد، أيُّ شيء عُذْري عند الناس؟! <q>﴿يا ليتني مت قبل هذا وكنت نسيا منسيا﴾</q>. فقال لها عيسى: أنا أكفيكِ الكلامَ{20}. (ز) ٤٦٤٤٥- قال مقاتل بن سليمان: <q>﴿فناداها﴾</q> جبريل ﵇ <q>﴿من تحتها﴾</q> يعني: مِن أسفل منها في الأرض، وهي فوقه على رابية، وجبريل ﵇ يناديها بهذا الكلام: <q>﴿ألا تحزني﴾</q>. ذلك حين تَمَنَّتِ الموتَ{21}. (ز) ٤٦٤٤٦- عن يحيى بن سلّام، في قوله: <q>﴿تحتها﴾</q>، قال: سَمِعَتْ مَن يقول: تحتها من الأرض. وقال بعضهم: <q>﴿تحتِها﴾</q> يعني: عيسى{22}٤١٥٣. (ز) ٤١٥٣ اختلف في مَن ناداها؛ فقال قوم: عيسى. وقال آخرون: جبريل. ورجَّح ابنُ جرير (١٥/٥٠٥) مستندًا إلى اللغة، والسياق، والدلالات العقلية القولَ الأول الذي قاله مجاهد، والحسن، ووهب بن منبه، وسعيد بن جبير، وابن زيد، وأبي بن كعب، فقال: «وذلك أنّه من كناية ذِكْرِه أقرب منه مِن ذكر جبريل، فردُّه على الذي هو أقرب إليه أولى مِن ردِّه على الذي هو أبعد منه، ألا ترى في سياق قوله: <q>﴿فحملته فانتبذت به مكانا قصيا﴾</q> يعني به: فحملت عيسى فانتبذت به، ثم قيل: <q>﴿فناداها﴾</q> نسقًا على ذلك مِن ذكر عيسى والخبر عنه. ولِعِلَّةٍ أخرى، وهي قوله: <q>﴿فأشارت إليه﴾</q> ولم تشر إليه -إن شاء الله- إلا وقد علمت أنّه ناطِقٌ في حاله تلك، ولِلَّذي كانت قد عرفت ووثقت به منه بمخاطبته إياها بقوله لها: <q>﴿أن لا تحزني قد جعل ربك تحتك سريا﴾</q>، وما أخبر الله عنه أنّه قال لها: أشيري للقوم إليه. ولو كان ذلك قولًا مِن جبريل لكان خَلِيقًا أن يكون في ظاهر الخبر مُبَيَّنًا أنّ عيسى سينطق، ويَحْتَجُّ عنها للقوم، وأمر منه لها بأن تشير إليه للقوم إذا سألوها عن حالها وحاله». وكذا رجَّحه ابنُ عطية (٦/٢٢)، فقال: «والأوَّلُ أظهر، وعليه كان الحسن يُقسِم». <q>﴿قَدۡ جَعَلَ رَبُّكِ تَحۡتَكِ سَرِیࣰّا ۝٢٤﴾</q> - تفسير ٤٦٤٤٧- عن ابن عمر: سمعتُ رسول الله ﷺ يقول: «إنّ السَّرِيَّ الذي قال الله لمريم: <q>﴿قد جعل ربك تحتك سريا﴾</q> نَهْرٌ أخرجه الله لها لِتَشْرَبَ مِنهُ»{23}. (١٠/٥٥) ٤٦٤٤٨- عن البراء بن عازب، عن النبي ﷺ، في قوله: <q>﴿قد جعل ربك تحتك سريا﴾</q>، قال: «النهر»{24}. (١٠/٥٥) ٤٦٤٤٩- عن عبد الله بن عباس -من طريق علي- في قوله: <q>﴿قد جعل ربك تحتك سريا﴾</q>، قال: نهر عيسى{25}. (١٠/٥٦) ٤٦٤٥٠- عن عثمان بن مِحْصَنٍ، قال: سُئِل عبد الله بن عباس عن قوله: <q>﴿سريا﴾</q>. قال: هو الجدول، أما سمعت قولَ الشاعر: سَلْمٌ ترى الدّاليَّ منه أزوَرا إذا يعُجُّ في السَّرِيِّ هرهرا؟{26}. (١٠/٥٦) ٤٦٤٥١- عن عبد الله بن عباس: أنّ نافع بن الأزرق قال: أخبِرني عن قوله ﷿: <q>﴿تحتك سريا﴾</q>. قال: السَّرِيُّ: النهر الصغير، وهو الجدول. قال: وهل تعرف العرب ذلك؟ قال: نعم، أما سمعت قول الشاعر: سهل الخليقة ماجد ذو نائل مثل السَّرِيِّ تَمُدُّه الأنهارُ؟{27}. (١٠/٥٦) ٤٦٤٥٢- عن عبد الله بن عباس -من طريق سعيد بن أبي صالح- في قول الله: <q>﴿قد جعل ربك تحتك سريا﴾</q>، قال: الماءُ الذي كان تحتها{28}. (ز) ٤٦٤٥٣- قال عبد الله بن عباس: ضرب جبريل ﵇وقيل: عيسى عليه الصلاة والسلام- برجله الأرضَ، فظَهَرَتْ عينُ ماءٍ عَذْبٍ، وجَرى فحَيِيَت النخلة بعد يبسها فأورقت وأثمرت وأرطبت{29}. (ز) ٤٦٤٥٤- عن البراء بن عازب -من طريق أبي إسحاق- في قوله: <q>﴿قد جعل ربك تحتك سريا﴾</q>، قال: هو الجدول، وهو النهر الصغير{30}. (١٠/٥٦) ٤٦٤٥٥- عن الضَّحّاك بن مُزاحِم -من طريق سلمة بن نُبيط- في قوله: <q>﴿سريا﴾</q>، قال: الجدول{31}. (١٠/٥٧) ٤٦٤٥٦- عن عمرو بن ميمون -من طريق حُصين- قال في هذه الآية: <q>﴿قد جعل ربك تحتك سريا﴾</q>، قال: السري: نهر يشرب منه. وفي لفظ: هو الجدول{32}. (١٠/٥٧) ٤٦٤٥٧- عن سعيد بن جبير -من طريق حصين- في قوله: <q>﴿سريا﴾</q>، قال: نهرًا، بالقِبْطِيَّة{33}. (١٠/٥٧) ٤٦٤٥٨- عن إبراهيم النخعي -من طريق مغيرة- أنه قال: هو النهر الصغير؛ يعني: الجدول، يعني: قوله: <q>﴿قد جعل ربك تحتك سريا﴾</q> {34}. (١٠/٥٧) ٤٦٤٥٩- عن مجاهد بن جبر -من طريق ابن أبي نَجِيحٍ- في قوله: <q>﴿سريا﴾</q>. قال: نهرًا بالسُّريانية{35}. (١٠/٥٧) ٤٦٤٦٠- عن عكرمة مولى ابن عباس، قال: السري: الماء{5}. (١٠/٥٧) ٤٦٤٦١- عن وهب بن مُنَبِّه -من طريق ابن إسحاق، عمَّن لا يتَّهم- <q>﴿قد جعل ربك تحتك سريا﴾</q>: يعني: ربيع الماء{37}. (ز) ٤٦٤٦٢- عن الحسن البصري، في قوله: <q>﴿قد جعل ربك تحتك سريا﴾</q>، قال: نبيًّا، وهو عيسى{38}. (١٠/٥٥) ٤٦٤٦٣- عن قتادة: أنّ الحسن [البصري] تلا هذه الآية وإلى جنبه حميد بن عبد الرحمن الحميري: <q>﴿قد جعل ربك تحتك سريا﴾</q>. قال: إن كان لَسَرِيًّا، وإن كان لكريمًا.= (ز) ٤٦٤٦٤- فقال حميد: يا أبا سعيد، إنّه الجدول. فقال له: مِن ثَمَّ تُعْجِبُنا مجالستُك، ولكن غَلَبَتْنا عليك الأمراءُ{5}. (١٠/٥٧) ٤٦٤٦٥- عن سفيان بن حسين، عن الحسن البصري في قوله: <q>﴿قد جعل ربك تحتك سريا﴾</q>، قال: كان -واللهِ- سريًّا. يعني: عيسى ﵇.= (ز) ٤٦٤٦٦- فقال له خالد بن صفوان: يا أبا سعيد، إنّ العرب تُسَمِّي الجدول: السَّرِي. فقال: صدقتَ{40}. (١٠/٥٧) ٤٦٤٦٧- عن جرير بن حازم، قال: سألني محمد بن عباد بن جعفر: ما يقول أصحابُكم في قوله: <q>﴿قد جعل ربك تحتك سريا﴾</q>؟ قال: فقلت له: سمعت قتادةَ يقول: الجدول.= (ز) ٤٦٤٦٨- قال [محمد بن عباد بن جعفر]: فأخْبِرْ قتادةَ عنِّي -فإنما نزل القرآن بلغتنا-: أنّه الرَّجلُ السَّرِيُّ{41}. (١٠/٥٥) ٤٦٤٦٩- عن قتادة بن دعامة -من طريق سعيد- <q>﴿قد جعل ربك تحتك سريا﴾</q>: والسري: هو الجدول، تُسَمِّيه أهلُ الحجاز{37}. (ز) ٤٦٤٧٠- عن قتادة بن دعامة -من طريق معمر- <q>﴿قد جعل ربك تحتك سريا﴾</q>، قال: هو الجدول، يعني: النهر الصغير{43}. (ز) ٤٦٤٧١- عن إسماعيل السُّدِّيّ -من طريق أسباط- <q>﴿قد جعل ربك تحتك سريا﴾</q>: والسريُّ: هو النهر{37}. (ز) ٤٦٤٧٢- قال مقاتل بن سليمان: <q>﴿قد جعل ربك تحتك سريا﴾</q>، يعني: الجدول الصغير مِن الأنهار{45}. (ز) ٤٦٤٧٣- قال عبد الملك ابن جُرَيْج -من طريق حجاج-: نهرًا إلى جنبها{46}. (ز) ٤٦٤٧٤- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿قد جعل ربك تحتك سريا﴾</q>: يريد نفسه، وأيُّ شيء أسْرى منه؟ قال: والذين يقولون: السري هو النهر. ليس كذلك النهر، لو كان النهر لكان إنما يكون إلى جنبها، ولا يكون النهر تحتها{47}. (١٠/٥٥) ٤٦٤٧٥- قال يحيى بن سلّام: والسري: هو الجدول، وهو النهر. وهو بالسريانية: سريًّا{48}٤١٥٤. (ز) ٤١٥٤ اختُلِف في السّري؛ فقال قوم: النهر الصغير. وقال آخرون: عيسى. ورجَّح ابنُ جرير (١٥/٥١٠) مستندًا إلى اللغة، والسياق القولَ الأول، فقال: «وذلك أنه أعلمها ما قد أعطاها الله من الماء الذي جعله عندها، وقال لها: <q>﴿وهزي إليك بجذع النخلة تساقط عليك رطبا جنيا فكلي﴾</q> من هذا الرطب <q>﴿واشربي﴾</q> من هذا الماء <q>﴿وقري عينا﴾</q> بولدك، والسري معروف من كلام العرب: أنه النهر الصغير». وبنحوه ابنُ كثير (٩/٢٣٥). ",footnotes:1:أخرجه أبو عبيد في فضائل القرآن ص١٧٦، وابن جرير ١٥/٥٠١. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم. و(فَخاطَبَها) قراءة شاذة. انظر: مختصر ابن خالويه ص٨٧.أخرجه ابن جرير ١٥/٥٠١.عزاه السيوطي إلى أبي عبيد، وابن المنذر. و<q>﴿مِن تَحْتِها﴾</q> بكسر الميم وخفض التاء قراءة متواترة، قرأ بها نافع، وأبو جعفر، وحمزة، والكسائي، وخلف العاشر، وحفص، وروح، وقرأ بقية العشرة: ‹مَن تَحْتَها› بفتح الميم، ونصب التاء. انظر: النشر ٢/٣١٨، والإتحاف ص٣٧٧.عزاه السيوطي إلى ابن أبي حاتم.عزاه السيوطي إلى عبد بن حميد.عزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ١٥/٥٠٢. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم، وابن مردويه.عزاه السيوطي إلى ابن أبي حاتم.عزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ١٥/٥٠٤.أخرجه سعيد بن منصور في سننه - التفسير ٦/٢١٩ (١٣٨٣).عزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ١٥/٥٠١-٥٠٢. وعزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ١٥/٥٠٣، وإسحاق البستي في تفسيره ص١٨٣ من طريق ابن جُرَيج. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.أخرجه ابن جرير ١٥/٥٠١-٥٠٢، وإسحاق البستي في تفسيره ص١٨٥، كما أخرجاه مختصرًا من طريق جويبر. وعزاه السيوطي إلى عبد بن حميد.أخرجه عبد الرزاق ٢/٦، وابن جرير ١٥/٥٠٣. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم. بلفظ هو عيسى.أخرجه ابن جرير ١٥/٥٠٤.أخرجه يحيى بن سلام ١/٢٢٠ من طريق سعيد بلفظ: كنا نُحَدَّث أنه الملَك، يعني: جبريل، وعبد الرزاق ٢/٦ من طريق معمر، وابن جرير ١٥/٥٠٢. وعزاه السيوطي إلى عبد بن حميد، وابن أبي حاتم.أخرجه ابن جرير ١٥/٥٠٢.أخرجه ابن جرير ١٥/٥٠٤-٥٠٥.تفسير مقاتل بن سليمان ٢/٦٢٤.تفسير يحيى بن سلام ١/٢٢٠.أخرجه الطبراني ١٢/٣٤٦ (١٣٣٠٣)، وأبو نعيم في الحلية ٣/٣٤٦. قال أبو نعيم: «غريب من حديث عكرمة، لم يروه عنه إلا أيوب بن نَهِيك، ولا عنه فيما أعلم إلا يحيى». وقال ابن كثير في تفسيره ٥/٢٢٤: «وهذا حديث غريب جدًّا من هذا الوجه. وأيوب بن نَهيك هذا هو الحُبُلي، قال فيه أبو حاتم الرازي: ضعيف. وقال أبو زرعة: منكر الحديث. وقال أبو الفتح الأزدي: متروك الحديث». وقال الهيثمي في المجمع ٧/٥٤-٥٥ (١١١٥٦): «رواه الطبراني، وفيه يحيى بن عبد الله البابلتي، وهو ضعيف». وقال السيوطي في الإتقان ٤/٢٧١: «أخرج الطبراني بسند ضعيف». وقال الألباني في الصحيحة بعد إيراد سند الطبراني ٣/١٨٩: «إسناد ضعيف».أخرجه الطبراني في الصغير ٢/٩ (٦٨٥)، وابن شاهين في الخامس من الأفراد ص٢٧٥ (٧٦). قال ابن شاهين: «وهذا حديث غريب، لا أعلم رواه عن أبي إسحاق إلا أبو سنان هذا، وسمعت عبد الله بن سليمان يقول: هو أبو سنان سعد بن سنان الشيباني من أهل قزوين». وقال الهيثمي في المجمع ٧/٥٤ (١١١٥٥): «رواه الطبراني في الصغير، وفيه معاوية بن يحيى الصدفي، وهو ضعيف».أخرجه ابن جرير ١٥/٥٠٦. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.عزاه السيوطي إلى سعيد بن منصور، وعبد بن حميد، وابن المنذر.أخرجه الطستي -كما في الإتقان ٢/٨٥-. وعزاه السيوطي إلى ابن الأنباري في الوقف.أخرجه عبد الله بن وهب في الجامع ١/٢٠ (٤٠).تفسير الثعلبي ٦/٢١١، وتفسير البغوي ٥/٢٢٦.أخرجه يحيى بن سلّام ١/٢٢١، وعبد الرزاق ٢/٦-٧، وابن جرير ١٥/٥٠٦، وإسحاق البستي في تفسيره ص١٨٥، والحاكم ٢/٣٧٣، وابن مردويه -كما في تخريج الكشاف ٢/٣٢٢، وفتح الباري ٦/٤٧٩، والتغليق ٤/٣٨-. وعزاه السيوطي إلى الفريابي، وسعيد بن منصور، وعبد بن حميد، وابن المنذر. وعلَّقه البخاري ٤/ ١٦٥ وزاد: بالسريانية. وأخرجه كذلك ابن أبي حاتم -كما في فتح الباري ٦/٤٧٩-.أخرجه ابن جرير ١٥/٥٠٨، ومن طريق عبيد أيضًا، وإسحاق البستي في تفسيره ص١٨٧من طريق عبيد بلفظ: الجدول الصغير من الأنهار. وعزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ١٥/٥٠٧، وإسحاق البستي في تفسيره ص١٨٦. وعزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ١٥/٥٠٨، وابن أبي حاتم -كما في الإتقان ٢/١٣٤-.أخرجه ابن جرير ١٥/٥٠٨. وعزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ١٥/٥٠٧، إسحاق البستي في تفسيره -من طريق ابن جريج- ص١٨٥، وابن أبي حاتم –كما في الإتقان ٢/١٣٤. وعزاه السيوطي إلى ابن المنذر.عزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ١٥/٥٠٩.عزاه السيوطي إلى ابن أبي حاتم. وأخرجه ابن جرير ١٥/٥٠٩ من طريق قتادة بلفظ: يعني: عيسى نفسه. وفي تفسير الثعلبي ٦/٢١١: يعني: عيسى كان -واللهِ- عبدًا سريًّا؛ أي: رفيعًا.عزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ١٥/٥٠٧ من طريق قتادة بنحوه وزاد في آخره: غلبتنا عليك الأمراء، وإسحاق البستي في تفسيره ص١٨٦، وابن عساكر ١٦/١٠٤.عزاه السيوطي إلى ابن أبي شيبة، وابن المنذر، وابن أبي حاتم.أخرجه ابن جرير ١٥/٥٠٩.أخرجه عبد الرزاق ٢/٦، ومن طريقه ابن جرير ١٥/ ٥٠٩ مختصرًا.أخرجه ابن جرير ١٥/٥٠٩.تفسير مقاتل بن سليمان ٢/٦٢٥.أخرجه ابن جرير ١٥/٥٠٧.أخرجه ابن جرير ١٥/٥١٠. وعزاه السيوطي إلى ابن أبي حاتم.تفسير يحيى بن سلام١/٢٢١.
19,25," <q>﴿وَهُزِّیۤ إِلَیۡكِ بِجِذۡعِ ٱلنَّخۡلَةِ﴾</q> - تفسير ٤٦٤٧٦- عن مجاهد بن جبر -من طريق عيسى بن ميمون- <q>﴿وهزي إليك بجذع النخلة﴾</q>، قال: النخلة{1}. (ز) ٤٦٤٧٧- عن مجاهد بن جبر -من طريق عيسى بن ميمون- <q>﴿وهزي إليك بجذع النخلة﴾</q>، قال: كانت عجوةً{2}. (١٠/٥٨) ٤٦٤٧٨- عن وهب بن مُنَبِّه -من طريق عبد الصمد بن معقل- في قوله: <q>﴿وهزي إليك بجذع النخلة﴾</q>، قال: فكان الرُّطَب يتساقط عليها، وذلك في الشتاء{3}. (ز) ٤٦٤٧٩- عن عبد المؤمن، قال: سمعتُ أبا نهيك [عثمان بن نهيك البصري] يقول: كانت نخلةً يابسةً{3}. (ز) ٤٦٤٨٠- عن قتادة بن دعامة -من طريق سعيد- قوله: <q>﴿وهزي إليك بجذع النخلة﴾</q>، قال: كانت عجوةً{5}. (ز) ٤٦٤٨١- عن إسماعيل السُّدِّيّ -من طريق أسباط- <q>﴿وهزي إليك بجذع النخلة﴾</q>، قال: وكان جِذْعًا منها مقطوعًا، فهَزَّتْهُ، فإذا هو نخلة، وأُجْرِي لها في المحراب نهر، فتساقطت النخلة رُطَبًا جَنِيًّا، فقال لها: كلي واشربي وقري عينا{3}. (ز) ٤٦٤٨٢- عن أبي رَوْق، قال: انتهت مريمُ إلى جذعٍ ليس له رأس، فأنبت الله له رأسًا، وأنبت فيه رُطَبًا، وبُسْرًا مُذَنِّبًا{7}، ومَوْزًا، فلمّا هزَّت النخلةُ سَقَط عليها مِن جميع ما فيها{8}. (١٠/٥٩) ٤٦٤٨٣- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿وهزي إليك بجذع النخلة﴾</q>، قال: حَرِّكيها{9}. (١٠/٥٨) ٤٦٤٨٤- قال مقاتل بن سليمان: وقال جبريل ﵇ لها: <q>﴿وهزى إليك﴾</q> يعني: وحَرِّكي إليك <q>﴿بجذع النخلة﴾</q> ...، وكانت شجرةً يابسة، فاخْضَرَّت وهي تنظُر، ثم أجرى الله ﷿ لها نهرا مِن الأُرْدُنِّ حتى جاءها، فكان بينهما وبين جبريل ﵇، وهذا كلام جبريل لها، وإنما جعل الله ﷿ ذلك لِتؤمن بأمر عيسى ﷺ، ولا تَعْجَب منه{10}. (ز) ٤٦٤٨٥- قال يحيى ين سلّام: كان جذع النخلة يابسًا{11}٤١٥٥. (ز) ٤١٥٥ اختُلِف في الجذع؛ فقال قوم: كانت نخلة مُطَعَّمة رُطَبًا. وقال آخرون: كانت يابسة. ورجّح ابنُ جرير (١٥/٥١٢) مستندًا لأقوال السلف القول الثاني الذي قاله ابن عباس من طريق العوفي، وأبو نهيك، ووهب بن منبه، والسدي، وقال: «ذُكِر أن الجذع كان جذعًا يابسًا، فأمرها أن تهزّه، وذلك في أيام الشتاء». ورجَّح مثلَه ابنُ عطية (٦/٢٣) مستندًا إلى ظاهر الآية، فقال: «والظاهر من الآية: أنّ عيسى هو المُكَلِّم لها، وأنّ الجِذع كان يابسًا؛ وعلى هذا تكون آيةً تُسَلِّيها، وتسكن إليها». وبمثله قال ابنُ كثير (٩/٢٣٥-٢٣٦)، وذكر أنها كانت شجرة في غير إبّان ثمرها؛ ولذا امْتَنَّ الله عليها بذلك بأن جعل لها طعامًا وشرابًا. ونسبه لوهب. <q>﴿تُسَـٰقِطۡ عَلَیۡكِ رُطَبࣰا جَنِیࣰّا ۝٢٥﴾</q> - قراءات ٤٦٤٨٦- عن البراء بن عازب -من طريق أبي إسحاق- أنّه قرأ: ‹يَسّاقَطْ عَلَيْكِ› بالياء{12}. (١٠/٥٨) ٤٦٤٨٧- عن مسروق بن الأجدع أنّه قرأ: ‹تَساقَطْ عَلَيْكِ رُطَبًا جَنِيًّا› بالتاء{13}. (١٠/٥٨) ٤٦٤٨٨- عن الحسن البصري أنّه قرأ: ‹يَسّاقَطْ عَلَيْكِ› بالياء، يعني: الجِذع{8}. (١٠/٥٨) ٤٦٤٨٩- عن [عثمان بن نهيك البصري] أنه قرأ: (تُسْقِطْ عَلَيْكِ رُطَبًا){15}. (١٠/٥٩) ٤٦٤٩٠- عن طلحة اليامي أنه قرأ: ‹تَساقَطْ عَلَيْكِ رُطَبًا› مُثَقَّلة{16}. (١٠/٥٩) ٤٦٤٩١- عن عاصم بن أبي النجود أنّه قرأ:‹تَسّاقَطْ› مُثَقَّلة بالتاء{13}. (١٠/٥٩) ٤٦٤٩٢- قال يحيى بن سلّام: ومَن قرأها: <q>﴿تُساقِطْ﴾</q> يقول: النخلة{18}٤١٥٦. (ز) ٤١٥٦ اختلف القراء في قراءة قوله: <q>﴿تساقط﴾</q>. وذكر ابنُ جرير (١٥/٥١٣-٥١٤) من قرأ: ‹تَسّاقَطْ› بالتشديد فهي بمعنى: تتساقط عليك النخلة رطبًا جنيًا، ثم تدغم إحدى التاءين في الأخرى فتشدد. وأن مَن قرأوا ‹تَساقَطْ› وجهوا معنى الكلام إلى مثل ما وجه إليه مُشَدِّدوها. وذكر أن من قرأ: (تُسْقِط) فقد وجَّه معنى الكلام إلى: تسقط النخلة عليك رطبًا جنيًّا. وذكر ابنُ عطية (٦/٢٣) أنّ مَن قرأ: <q>﴿تَسّاقَطْ﴾</q> يريد: النخلة. ومن قرأ ‹يَسّاقَطْ› يريد: الجذع. وبيّن ابنُ جرير (١٥/٥١٤ بتصرف) أنّ القراءات الثلاث الأُول متقاربات المعاني، والقراءة بهنّ صواب؛ لقراءة علماء القراءة بهنّ، فقال: «والصواب من القول في ذلك عندي أن يقال: إن هذه القراءات الثلاث قراءات متقاربات المعاني، قد قرأ بكل واحدة منهن قراءٌ أهل معرفة بالقرآن، فبأي ذلك قرأ القارئ فمصيب الصواب فيه، وذلك أن الجذع إذا تساقط رطبًا وهو ثابت غير مقطوع فقد تساقطت النخلة رطبًا، وإذا تساقطت النخلة رطبًا فقد تساقطت النخلة بأجمعها جذعها وغير جذعها، وذلك أن النخلة ما دامت قائمة على أصلها فإنما هي جذع وجريد وسعف، فإذا قطعت صارت جذعًا، فالجذع الذي أمرت مريم بهزه لم يذكر أحد نعلمه أنه كان جذعًا مقطوعًا غير السدي، وقد زعم أنه عاد بهزها إياه نخلة، فقد صار معناه ومعنى من قال: كان المتساقط عليها رطبًا؛ نخلة؛ واحدًا، فبيِّنةٌ بذلك صحة ما قلنا». وذكر ابنُ كثير (٩/٢٣٦) أنّ جميع القراءات متقاربة المعنى. <q>﴿تُسَـٰقِطۡ عَلَیۡكِ رُطَبࣰا جَنِیࣰّا ۝٢٥﴾</q> - تفسير الآية ٤٦٤٩٣- عن عبد الله بن عباس، في قوله: <q>﴿رُطَبًا جَنِيًّا﴾</q>، قال: طَرِيًّا{8}. (١٠/٥٩) ٤٦٤٩٤- عن عبد الله بن عباس، في قوله: <q>﴿تُساقِطْ عَلَيْكِ رُطَبًا جَنِيًّا﴾</q>، قال: بغُباره{20}. (١٠/٥٩) ٤٦٤٩٥- عن أبي جناب [يحيى بن أبي حيَّة الكلبي]، مثله{21}. (١٠/٥٩) ٤٦٤٩٦- قال مقاتل بن سليمان: <q>﴿تُساقِطْ عَلَيْكِ رُطَبًا جَنِيًّا﴾</q>، يعني بالجَنِيِّ: ما ترطب به مِن البُسْر{10}. (ز) ٤٦٤٩٧- قال يحيى بن سلّام: ‹يساقَطْ عَلَيْكِ› الجذعُ <q>﴿رطبا جنيا﴾</q>، وكان جِذْعُ النخلة يابِسًا ...، <q>﴿تساقط عليك رطبا جنيا﴾</q> حين اجْتُنِي{11}. (ز) <q>﴿تُسَـٰقِطۡ عَلَیۡكِ رُطَبࣰا جَنِیࣰّا ۝٢٥﴾</q> - آثار متعلقة بالآية ٤٦٤٩٨- عن علي، قال: قال رسول الله ﷺ: «... أطْعِموا نساءَكم الوُلَّدَ الرُّطَبَ، فإن لم يكن رُطَب فتمر، فليس مِن الشجرِ شجرةٌ أكرم على الله مِن شجرة نزلت تحتها مريمُ بنت عمران»{24}. (١٠/٦٠) ٤٦٤٩٩- عن سلمة بن قيس، قال: قال رسول الله ﷺ: «أطعِموا نساءَكم في نفاسِهِنَّ التمر؛ فإنّه مَن كان طعامُها في نفاسها التمرَ خرج ولدُها ولدًا حليمًا، فإنّه كان طعام مريم حيث ولدت عيسى، ولو علم الله طعامًا هو خيرٌ لها مِن التمر لأطعمها إياه»{25}. (١٠/٦٠) ٤٦٥٠٠- عن عامر الشعبي، قال: كتب قيصر إلى عمر بن الخطاب: إنّ رُسُلي أتتني مِن قِبَلِك، فزَعَمَتْ أنّ قِبَلَكم شجرةً ليست بِخَلِيقَةٍ لِشَيء مِن الخير! تُخْرِج مثلَ آذان الحمير، ثم تَشَقَّق عن مِثل اللؤلؤ الأبيض، ثم تصير مِثْلَ الزُمُرُّد الأخضر، ثم تصير مثل الياقوت الأحمر، ثم تَيْنَعُ وتنضج، فتكون كأطيب فالوذَج أُكِل، ثم تيبس فتكون عِصْمَةً للمقيم، وزادًا للمسافر، فإن تكن رسلي صدَّقتني فلا أرى هذه الشجرة إلا مِن شجر الجنة. فكتب إليه عمر: أن رسلك قد صدَّقَتْك، هذه الشجرة عندنا، هي الشجرة التي أنبتها الله على مريم حين نَفِسَت بعيسى{26}. (١٠/٦١) ٤٦٥٠١- عن الربيع بن خثيم، قال: ليس للنفساء عندي دواءٌ مثل الرُّطبِ، ولا للمريض مثل العسل{27}. (١٠/٦١) ٤٦٥٠٢- عن شقيق [بن سلمة] -من طريق عاصم- قال: لو علِم اللهُ أنّ شيئًا للنفساء خيرٌ مِن الرُّطَب لأمر مريم به{28}. (١٠/٦١) ٤٦٥٠٣- عن عمرو بن ميمون -من طريق حُصين- قال: ليس للنفساء خيرٌ مِن الرُّطَب أو التمر. وقال: إنّ الله قال: <q>﴿وهزي إليك بجذع النخلة تساقط عليك رطبا جنيا﴾</q>{29}. (١٠/٦١) ",footnotes:1:أخرجه ابن جرير ١٥/٥١٢.أخرجه ابن جرير ١٥/٥١٢. وعزاه السيوطي إلى ابن أبي شيبة، وابن المنذر، وابن أبي حاتم، وابن الأنباري في المصاحف.أخرجه ابن جرير ١٥/٥١١.أخرجه ابن جرير ١٥/٥١١.أخرجه يحيى بن سلام ١/٢٢١.أخرجه ابن جرير ١٥/٥١١.البُسْر: مرتبة من مراتب التمر قبل أن يصير تمرًا؛ فالتمر أوَّله طَلْعٌ ثم خَلالٌ ثم بَلَحٌ ثم بُسْرٌ ثم رُطَبٌ ثم تمر، والبُسْر المُذَنَّب: الذي قد بدا فيه الإرطابُ من قِبَلِ ذَنَبِه، وذنَبُ البُسْرة وغيرِها من التَّمْرِ مؤَخَّرُها. لسان العرب (بسر) (ذنب).عزاه السيوطي إلى ابن أبي حاتم.أخرجه ابن جرير ١٥/٥١٠-٥١١. وعزاه السيوطي إلى ابن أبي حاتم.تفسير مقاتل بن سليمان ٢/٦٢٥.تفسير يحيى بن سلام ١/٢٢١.أخرجه ابن جرير ١٥/ ٥١٣. وعزاه السيوطي إلى عبد بن حميد. ‹يَسّاقَطْ› بالياء، وتشديد السين، وفتح القاف قراءة متواترة، قرأ بها أبوبكر عن عاصم بخلاف عنه، ويعقوب، وقرأ حفص عن عاصم: <q>﴿تُساقِطْ﴾</q> بضم التاء، وتخفيف السين، وكسر القاف، وقرأ حمزة: ‹تَساقَطْ› بفتح القاف، وتخفيف السين، وفتح القاف، وقرأ بقية العشرة: ‹تَسّاقَطْ› بفتح التاء، وتشديد السين، وفتح القاف. انظر: النشر ٢/٣١٨، والإتحاف ص٣٧٧.عزاه السيوطي إلى عبد بن حميد.عزاه السيوطي إلى ابن أبي حاتم.أخرجه ابن جرير ١٥/٥١٤، وعزاه السيوطي إلى ابن أبي حاتم. وهي قراءة شاذة. انظر: مختصر ابن خالويه ص٨٧.عزاه السيوطي إلى عبد الله بن أحمد في زوائد الزهد.عزاه السيوطي إلى عبد بن حميد.تفسير يحيى بن سلام١/٢٢١.عزاه السيوطي إلى ابن أبي حاتم.أخرجه الخطيب في تالي التلخيص ١/٢٦٣.أخرجه الخطيب في تاريخ بغداد ١٣/٢٨٥. وعزاه السيوطي إلى ابن الأنباري.تفسير مقاتل بن سليمان ٢/٦٢٥.تفسير يحيى بن سلام ١/٢٢١.أخرجه أبو يعلى ١/٣٥٣ (٤٥٥)، وأبو الشيخ في أمثال الحديث ص٣٠٩ (٢٦٣). قال ابن حبان في المجروحين ٣/٤٤ (١٠٩٩) ترجمة مسرور بن سعيد التميمي: «يروي عن الأوزاعي المناكير التي لا يجوز الاحتجاج بمَن يرويها». وقال ابن عدي في الكامل ٨/١٨١ (١٩١٠): «وهذا حديث عن الأوزاعي منكر، وعروة بن رويم عن علي ليس بالمُتَّصل، ومسرور بن سعيد غير معروف، لم أسمع بذكره إلا في هذا الحديث». وقال ابن كثير في تفسيره ٥/٢٢٥: «هذا حديث منكر جدًّا، ورواه أبو يعلى عن شيبان به». وقال الهيثمي في المجمع ٥/٣٩ (٨٠٠٥): «رواه أبو يعلى، وفيه مسرور بن سعيد، وهو ضعيف». وقال القاري في الأسرار المرفوعة ص٤٣٩: «هذا لا يصح». وقال الشوكاني في الفوائد المجموعة ص٤٨٩ (٦٠): «رواه أبو نعيم عن علي مرفوعًا، وفي إسناده مسرور بن سعيد التميمي، وهو منكر الحديث، وقال ابن عدي: إنه غير معروف».أخرجه أبو نعيم في الطب النبوي ٢/٧٢٧ (٨٢٦)، وابن عساكر في تاريخه ٧٠/٩٣-٩٤. قال ابن الجوزي في الموضوعات ٣/٢٧: «هذا حديث لا يصِحُّ». وقال القاري في الأسرار المرفوعة ص٤٣٩: «هذا لا يصح». وقال الشوكاني في الفوائد المجموعة ص١٨١ (٦٤): «رواه الخطيب عن مسلم بن قيس مرفوعًا، وفي إسناده سليمان النخعي وداود بن سليمان، كذّابان». وقال الألباني في الضعيفة ١/٤٠٧ (٢٣٤): «موضوع».أخرجه ابن عساكر ٤٧/٣٥٣.عزاه السيوطي إلى سعيد بن منصور، وعبد بن حميد، وابن المنذر.أخرجه عبد الرزاق ٢/٧. وعزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ١٥/٥١٢، وعبد الرزاق ٢/٧، وإسحاق البستي في تفسيره ص١٨٦ كلاهما بلفظ: إني لأحسب خير الطعام للنساء التمر. وعزاه السيوطي إلى عبد بن حميد.
