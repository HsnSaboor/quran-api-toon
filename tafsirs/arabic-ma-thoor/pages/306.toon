quran[14]{c,v,t}:
  19,12,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿یَـٰیَحۡیَىٰ خُذِ ٱلۡكِتَـٰبَ بِقُوَّةࣲۖ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٦٢١٥<span class="dash">-</span></span> قال <span class="name-1">عبد الله بن عباس</span> -من طريق مقاتل وجويبر عن الضحاك-: فَوُلِد له يحيى على ما بشَّره الله نبيًّا تقيًّا صالِحًا، <span class="qpc-hafs">﴿يا يحيى خذ الكتاب بقوة﴾</span>، يعني: بجِدٍّ، وطاعة، واجتهاد، وشكر، وبالعمل بما فيه{1}. (١٠/٢٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٢١٦<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span>، في قوله: <span class="qpc-hafs">﴿خذ الكتاب بقوة﴾</span>، يقول: اعمل بما فيه من فرائضه{2}. (١٠/٢١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٢١٧<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿يا يحيى خذ الكتاب بقوة﴾</span>، قال: بجِدٍّ{3}. (١٠/٢١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٢١٨<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- في قوله: <span class="qpc-hafs">﴿خذ الكتاب بقوة﴾</span>، قال: بجِدٍّ{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٢١٩<span class="dash">-</span></span> قال <span class="name-2">إسماعيل السُّدِّيّ</span>: يعني: بالجِدِّ، والمُواظَبَة{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٢٢٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿يا يحيى خذ الكتاب﴾</span> يعني: التوراة <span class="qpc-hafs">﴿بقوة﴾</span> يعني: بجِدٍّ، ومواظبة عليه{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٢٢١<span class="dash">-</span></span> قال <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿يا يحيى خذ الكتاب بقوة﴾</span>: أن يعمل بما أمره الله، ويُجانِبَ فيه ما نهاه الله{7}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَءَاتَیۡنَـٰهُ ٱلۡحُكۡمَ صَبِیࣰّا ۝١٢﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٦٢٢٢<span class="dash">-</span></span> عن عبد الله بن عباس، عن النبي ﷺ، في قوله: <span class="qpc-hafs">﴿وآتيناه الحكم صبيا﴾</span>، قال: «<b>أُعْطِي الفَهْم والعِبادة وهو ابن سبع سنين</b>»{8}. (١٠/٢١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٢٢٣<span class="dash">-</span></span> عن الضحاك، عن ابن عباس، قال: قال رسول الله ﷺ: «<b>قال الغِلمان ليحيى بن زكريا: اذهب بنا نلعب. فقال يحيى: ما لِلَّعِب خُلِقْنا، اذهبوا نُصَلِّي. فهو قول الله تعالى</b>: <span class="qpc-hafs">﴿وآتيناه الحكم صبيا﴾</span>»{9}. (١٠/٢٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٢٢٤<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- قال: جاء الغِلمان إلى يحيى بن زكريا، فقالوا: اخرج بنا نلعب. فقال: ما لِلَّعِب خُلِقْتُ. قال: فأنزل الله: <span class="qpc-hafs">﴿وآتيناه الحكم صبيا﴾</span>{10}. (١٠/٢٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٢٢٥<span class="dash">-</span></span> عن معاذ بن جبل، مرفوعًا{11}. (١٠/٢٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٢٢٦<span class="dash">-</span></span> قال <span class="name-1">عبد الله بن عباس</span>: النبوة{12}<span class=comment-ref>٤١٣٧</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٤١٣٧</span> <span class="comment-type-4">ذكر</span> <u>ابنُ عطية</u> (٦/١٣) هذا القول منسوبًا للحسن، و<span class="comment-type-4">علَّق</span> بقوله: «وفي لفظة»صبي«على هذا تَجَوُّز، واستصحاب حال».</div></p><p><div></p><p><p><span class="item-no">٤٦٢٢٧<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق مقاتل وجويبر عن الضحاك- في قوله: <span class="qpc-hafs">﴿وآتيناه الحكم﴾</span> يعني: الفهم، <span class="qpc-hafs">﴿صبيا﴾</span> يعني: [صغيرًا]. وذلك أنه مرَّ على صِبية أتْرابٍ له يلعبون على شاطِئ نهر بطِينٍ وبماء، فقالوا: يا يحيى، تعال حتى نلعب. فقال: سبحان الله! أوَلِلَّعِبِ خُلِقْنا؟!{1}. (١٠/٢٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٢٢٨<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span>، في قوله: <span class="qpc-hafs">﴿وآتيناه الحكم صبيا﴾</span>، قال: الفَهْم{14}. (١٠/٢١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٢٢٩<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق سفيان، عن رجل- <span class="qpc-hafs">﴿وآتيناه الحكم صبيا﴾</span>، قال: القرآن{15}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٢٣٠<span class="dash">-</span></span> عن مالك بن دينار، قال: سألنا <span class="name-2">عكرمة</span> عن قوله: <span class="qpc-hafs">﴿وآتيناه الحكم صبيا﴾</span>. قال: اللُّبَّ{16}. (١٠/٢١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٢٣١<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span>، في قوله: <span class="qpc-hafs">﴿وآتيناه الحكم صبيا﴾</span>، قال: وهو ابن ثلاث سنين{17}. (١٠/٢٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٢٣٢<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span>: <span class="qpc-hafs">﴿وآتيناه الحكم صبيا﴾</span>، يعني: الفهم، والعقل{18}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٢٣٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وآتيناه الحكم صبيا﴾</span>، يعني: وأعطينا يحيى العلم والفهم، وهو ابن ثلاث سنين{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٢٣٤<span class="dash">-</span></span> قال ابن وهب: وقال لي <span class="name-3">مالك [بن أنس]</span>، وذكر قول الله ﷿ في يحيى: <span class="qpc-hafs">﴿وآتيناه الحكم صبيا﴾</span>، وقوله في عيسى: <span class="qpc-hafs">﴿قد جئتكم بالحكمة﴾</span> [الزخرف:٦٣]، وقوله: <span class="qpc-hafs">﴿ويعلمه الكتاب والحكمة﴾</span> [آل عمران:٤٨]، وقوله: <span class="qpc-hafs">﴿واذكرن ما يتلى في بيوتكن من آيات الله والحكمة﴾</span> [الأحزاب:٣٤]، قال مالك: الحِكمة في هذا كلِّه: طاعةُ الله، والاتباع لها، والفقه في دين الله، والعملُ به{20}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٢٣٥<span class="dash">-</span></span> عن <span class="name-3">مَعْمَر بن راشد</span> -من طريق ابن المبارك- في قوله: <span class="qpc-hafs">﴿وآتيناه الحكم صبيا﴾</span>، قال: بلغني: أنّ الصبيان قالوا ليحيى بن زكريا: اذهب بنا نلعب. قال: ما لِلَّعِب خُلِقْتُ. فهو قوله: <span class="qpc-hafs">﴿وآتيناه الحكم صبيا﴾</span>{21}. (١٠/٢٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٢٣٦<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: وبلغنا: أنّه كان في صِغَرِه يقول له الصبيان: يا يحيى، تعال نلعبْ. فيقول: ليس لِلَّعِب خُلِقْنا{22}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَءَاتَیۡنَـٰهُ ٱلۡحُكۡمَ صَبِیࣰّا ۝١٢﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٤٦٢٣٧<span class="dash">-</span></span> عن ابن عباس، قال: قال رسول الله ﷺ: «<b>مَن قرأ القرآن قبل أن يَحْتَلِم فقد أُوتِي الحُكْم صَبِيًّا</b>»{23}. (١٠/٢٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٢٣٨<span class="dash">-</span></span> وعن <span class="name-1">عبد الله بن عباس</span>، موقوفًا{2}. (١٠/٢٣)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن عساكر ٦٤/١٦٩-١٧٣. وعزاه السيوطي إلى إسحاق بن بشر.عزاه السيوطي إلى ابن أبي حاتم.تفسير مجاهد ص٤٥٤ بلفظ: بجِدٍّ في طاعة الله ﷿، وأخرجه باللفظ المختصر المثبت في المتن ابن جرير ١٥/٤٧٤، وإسحاق البستي في تفسيره ص١٧٦ من طريق ابن جريج. وعلقه يحيى بن سلام ١/٢١٦. وعزاه السيوطي إلى ابن أبي شيبة، وعبد بن حميد، وابن المنذر، وابن أبي حاتم.أخرجه ابن جرير ١٥/٤٧٣.علقه يحيى بن سلام ١/٢١٦.تفسير مقاتل بن سليمان ٢/٦٢٢.أخرجه ابن جرير ١٥/٤٧٤.أورده الديلمي في الفردوس ٤/٤٠٢ (٧١٦٨).عزاه السيوطي إلى الحاكم في تاريخه من طريق نهشل بن سعيد.</p><p>قال المناوي في فيض القدير ٤/٢٨ (٤٤٣٩) «بسند واه».عزاه السيوطي إلى عبد الرزاق، وعبد بن حميد.أخرجه ابن عساكر في تاريخه ٦٤/١٨٣ بنحوه.</p><p>قال العجلوني في كشف الخفاء ١/٥١٥: «رواه ابن عساكر بإسناد ضعيف عن معاذ».تفسير البغوي ٥/٢٢١.أخرجه ابن عساكر ٦٤/١٦٩-١٧٣. وعزاه السيوطي إلى إسحاق بن بشر.عزاه السيوطي إلى ابن أبي شيبة، وعبد بن حميد، وابن المنذر، وابن أبي حاتم.أخرجه ابن أبي شيبة في مصنفه (ت: محمد عوامة) ١٦/٥٦٦ (٣٢٥٦٦).أخرجه ابن أبي شيبة في مصنفه (ت: محمد عوامة) ١٦/٥٦٦ (٣٢٥٦٥) قال: حدثنا وكيع، عن إسماعيل بن سليمان العبدي، عن رجل مِنهم يُقال له: مهدي، عن عكرمة به. وعزاه السيوطي إلى ابن المنذر من طريق مالك بن دينار المذكور في المتن.عزاه السيوطي إلى عبد الله بن أحمد في زوائد الزهد، وابن أبي حاتم.علقه يحيى بن سلام ١/٢١٧.تفسير مقاتل بن سليمان ٢/٦٢٢.أخرجه ابن وهب في الجامع ٢/١٣٠-١٣١ (٢٥٧) بنحوه، وعنه ابن عبد البر في جامع بيان العلم وفضله ١/٨٣ بزيادة -وهي في جامع ابن وهب بنحوها-: قال مالك: ومما يبين ذلك أنك تجد رجلًا عاقلًا في أمر الدنيا ذا نظر فيها وبصرٍ بها ولا علم له بدينه-، وتجد آخر ضعيفًا في أمر دنياه، عالِمًا بأمر دينه، بصيرًا به، يؤتيه الله إياه ويحرمه هذا؛ فالحكمة: الفقه في دين الله.أخرجه أحمد في الزهد ص٧٦، ٩٠، وابن أبي الدنيا في كتاب الرقة والبكاء -موسوعة ابن أبي الدنيا ٣/٢٥١ (٤٠٣)- من طريق ابن المبارك، وابن جرير ١٥/٤٧٤، وابن عساكر ٦٤/١٨٣. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم، والخرائطي.تفسير يحيى بن سلام ١/٢١٧.أخرجه البيهقي في شعب الإيمان ٣/٣٤٣ (١٧٩٨)، من طريق مسلم بن إبراهيم، قال: حدثنا الحسن بن أبي جعفر، حدثنا أبو الصهباء، عن سعيد بن جبير، عن ابن عباس به.</p><p>إسناده ضعيف؛ فيه الحسن بن أبي جعفر، وهو الجُفْري البصري، قال عنه ابن حجر في التقريب (١٢٢٢): «ضعيف الحديث مع عبادته وفضله».عزاه السيوطي إلى ابن أبي حاتم.
  19,13,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَحَنَانࣰا مِّن لَّدُنَّا﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٦٢٣٩<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عكرمة- في قوله: <span class="qpc-hafs">﴿وحنانا﴾</span>، قال: لا أدري ما هو، إلا أنِّي أظنُّه تَعَطُّف اللهِ على عبده بالرحمة{1}. (١٠/٢٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٢٤٠<span class="dash">-</span></span> عن سعيد بن جبير، قال: سألتُ <span class="name-1">عبد الله بن عباس</span> عن قوله: <span class="qpc-hafs">﴿وحنانا﴾</span>. فلم يُحِر فيها شيئًا{2}. (١٠/٢٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٢٤١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي بن أبي طلحة- في قوله: <span class="qpc-hafs">﴿وحنانا من لدنا﴾</span>، قال: رحمة مِن عندنا{3}<span class=comment-ref>٤١٣٨</span>. (١٠/٢٣)</p></p><p></div></p><p><div><span class=comment-ref>٤١٣٨</span> <span class="comment-type-4">ذكر</span> <u>ابنُ عطية</u> (٦/١٣) أنّ هذا قول جمهور المفسرين، وأنّه تفسير على اللغة.</div></p><p><div></p><p><p><span class="item-no">٤٦٢٤٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>: أنّ نافع بن الأزرق قال له: أخبِرني عن قوله: <span class="qpc-hafs">﴿وحنانا من لدنا﴾</span>. قال: رحمة من عندنا. قال: وهل تعرف العرب ذلك؟ قال: نعم، أما سمعت طَرَفَة بن العبد البكري وهو يقول:</p><p>أبا منذر، أفْنَيْتَ فاسْتَبْقِ بعضنا حنانيك بعضُ الشرِّ أهونُ مِن بعض؟{4}. (١٠/٢٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٢٤٣<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق مقاتل وجويبر عن الضحاك- في قوله: <span class="qpc-hafs">﴿وحنانا﴾</span>: يعني: ورحمة منا، وعطفًا{5}. (١٠/٢٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٢٤٤<span class="dash">-</span></span> عن <span class="name-1">جابر [بن عبد الله]</span> -من طريق عمرو- <span class="qpc-hafs">﴿وحنانًا﴾</span>، قال: ورحمة{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٢٤٥<span class="dash">-</span></span> عن <span class="name-2">معبد الجهني</span> -من طريق عوف- في قوله: <span class="qpc-hafs">﴿وحنانا من لدنا﴾</span>، قال: الحنان: المحبة{7}. (١٠/٢٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٢٤٦<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- <span class="qpc-hafs">﴿وحنانا من لدنا﴾</span>، قال: تَعَطُّفًا من ربه عليه{8}. (١٠/٢٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٢٤٧<span class="dash">-</span></span> عن <span class="name-2">الضحاك بن مزاحم</span> -من طريق جُوَيْبِر- قوله: <span class="qpc-hafs">﴿وحنانا من لدنا﴾</span>، قال: رحمة من عندنا، لا يملِكُ عطاءَها أحدٌ غيرنا{9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٢٤٨<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span> -من طريق سماك- في هذه الآية: <span class="qpc-hafs">﴿وحنانا من لدنا﴾</span>، قال: رحمة{9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٢٤٩<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span> -من طريق يحيى بن سعيد- <span class="qpc-hafs">﴿وحنانا من لدنا﴾</span>، قال: مَحَبَّة عليه{11}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٢٥٠<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span>، <span class="qpc-hafs">﴿وحنانا من لدنا﴾</span>، قال: الرحمة{12}. (١٠/٢٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٢٥١<span class="dash">-</span></span> عن <span class="name-2">عطاء بن أبي رباح</span> -من طريق جابر- <span class="qpc-hafs">﴿وحنانا من لدنا﴾</span>، قال: تعظيمًا مِن لدُنّا{11}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٢٥٢<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق مَعْمَر- <span class="qpc-hafs">﴿وحنانا من لدنا﴾</span>، قال: رحمة مِن عندنا{14}. (١٠/٢٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٢٥٣<span class="dash">-</span></span> عن <span class="name-2">أبي حفص</span> -من طريق جابر- في قوله: <span class="qpc-hafs">﴿وحنانا﴾</span>، قال: رحمة{15}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٢٥٤<span class="dash">-</span></span> عن <span class="name-2">الربيع [بن أنس]</span>، <span class="qpc-hafs">﴿وحنانا من لدنا﴾</span>، قال: رحمة مِن عندنا، لا يملِكُ عطاءَها أحدٌ غيرنا{16}. (١٠/٢٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٢٥٥<span class="dash">-</span></span> قال <span class="name-3">محمد بن السائب الكلبي</span>: الحنان: الرحمة{17}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٢٥٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وحنانا من لدنا﴾</span>، يقول: رحمة من عندنا{18}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٢٥٧<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿وحنانا﴾</span>، قال: أمّا الحنان: فالمحبة{9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٢٥٨<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>، في قوله: <span class="qpc-hafs">﴿وحنانا من لدنا﴾</span>: أي: مِن عندنا، أي: وأعطيناه حنانًا من لدُنّا{20}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَزَكَوٰةࣰۖ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٦٢٥٩<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، في قوله: <span class="qpc-hafs">﴿وزكاة﴾</span>، قال: بركة{21}. (١٠/٢٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٢٦٠<span class="dash">-</span></span> قال <span class="name-1">عبد الله بن عباس</span>، في قوله: <span class="qpc-hafs">﴿وزكاة﴾</span>: يعني بالزكاة: طاعة الله، والإخلاص{22}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٢٦١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق مقاتل وجويبر عن الضحاك- في قوله: <span class="qpc-hafs">﴿وزكاة﴾</span>: يعني: وصدقة على زكريا{5}. (١٠/٢٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٢٦٢<span class="dash">-</span></span> عن <span class="name-1">جابر [بن عبد الله]</span> -من طريق عمرو- <span class="qpc-hafs">﴿وزكاة﴾</span>، قال: طاهرًا من الذنوب{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٢٦٣<span class="dash">-</span></span> عن <span class="name-2">الضَّحّاك بن مُزاحِم</span>، في قوله: <span class="qpc-hafs">﴿وزكاة﴾</span>: يعني: العمل الصالح الزاكي{25}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٢٦٤<span class="dash">-</span></span> قال <span class="name-2">الحسن البصري</span>: زكاة لِمَن قُبِل عنه حتى يكونوا أزكياء{26}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٢٦٥<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- <span class="qpc-hafs">﴿وزكاة﴾</span>، قال: صَدَقة{27}. (١٠/٢٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٢٦٦<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- قوله: <span class="qpc-hafs">﴿وزكاة﴾</span>، قال: الزكاة: العمل الصالح. قال <span class="name-3">يحيى بن سلام</span>: رويت أنّه أخذه من هذه الآية في طه [٧٥-٧٦]: <span class="qpc-hafs">﴿ومن يأته مؤمنا قد عمل الصالحات فأولئك لهم الدرجات العلى ٧٥ جنات عدن تجري من تحتها الأنهار خالدين فيها وذلك جزاء من تزكى (٧٦)﴾</span>{28}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٢٦٧<span class="dash">-</span></span> عن <span class="name-2">أبي حفص</span> -من طريق جابر- في قوله: <span class="qpc-hafs">﴿وزكاة﴾</span>، قال: طاهِرًا من الذنوب{15}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٢٦٨<span class="dash">-</span></span> قال <span class="name-3">محمد بن السائب الكلبي</span>: الزكاة: الصدقة{30}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٢٦٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وزكاة﴾</span>، يعني: جعله صالِحًا، وطهَّره من الذنوب{18}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٢٧٠<span class="dash">-</span></span> عن <span class="name-3">عبد الملك ابن جُرَيج</span> -من طريق حجاج- في قوله: <span class="qpc-hafs">﴿وزكاة﴾</span>: يعني: العمل الصالح الزَّكِيّ{25}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٢٧١<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿وزكاة وكان تقيا﴾</span>، قال: أمّا الزكاة والتقوى فقد عرفهما الناس{25}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَكَانَ تَقِیࣰّا ۝١٣﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٦٢٧٢<span class="dash">-</span></span> عن عبد الله بن عباس، قال: كُنّا في حلقة في مسجد النبي ﷺ نتذاكر فضائل الأنبياء، فذكرنا نوحًا وطولَ عبادته، وذكرنا إبراهيم وموسى وعيسى ورسول الله ﷺ، فخرج علينا رسول الله ﷺ، فقال: «<b>ما تَذاكَرُون بينكم</b>؟». فذكرنا له، فقال: «<b>أما إنّه لا ينبغي أن يكون أحدٌ خيرًا من يحيى بن زكريا؛ أما سمعتم الله كيف وصفه في القرآن</b>: <span class="qpc-hafs">﴿يا يحيى خذ الكتاب بقوة﴾</span> -إلى قوله-: <span class="qpc-hafs">﴿وكان تقيا﴾</span>، <b>لم يعمل سيئة قطُّ، ولم يهم بها</b>»{34}. (١٠/٢٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٢٧٣<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق العوفي- وفي قوله: <span class="qpc-hafs">﴿وكان تقيا﴾</span>، قال: طهُرَ فلم يعمل بذنب{35}. (١٠/٢٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٢٧٤<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، في قوله: <span class="qpc-hafs">﴿وكان تقيا﴾</span>: يعني: مُطَهَّرًا، مُطيعًا لله{5}. (١٠/٢٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٢٧٥<span class="dash">-</span></span> قال <span class="name-3">المبارك بن فضالة</span>: ما مِن آدمي إلا قد عَمِل خطيئة، أو همَّ بها، إلا يحيى بن زكريا{37}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٢٧٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وكان تقيا﴾</span>، يعني: مُسْلِمًا{18}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٢٧٧<span class="dash">-</span></span> عن <span class="name-3">سفيان بن عيينة</span> أنّه سُئِل عن قوله: <span class="qpc-hafs">﴿وكان تقيا﴾</span>. قال:لم يعمل بمعصية، ولم يَهمَّ بها{21}. (١٠/٢٥)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ١٥/٤٧٧ دون قوله: إلا أني أظنه تعطف الله على عبده بالرحمة، وإسحاق البستي في تفسيره ص١٧٧، والحاكم ٢/٣٧٢، والبيهقي في الأسماء والصفات (١٤١). وعزاه السيوطي إلى عبد الرزاق، والفريابي، وابن أبي شيبة، وعبد بن حميد، وابن المنذر، وابن أبي حاتم، والزجاجي في أماليه.أخرجه ابن جرير ١٥/٤٧٨.أخرجه ابن جرير ١٥/٤٧٥، وابن أبي حاتم -كما في الإتقان ٢/٢٦-. وعزاه السيوطي إلى ابن المنذر.أخرجه الطستي-كما في الإتقان ٢/٧٠.أخرجه ابن عساكر ٦٤/١٦٩-١٧٣. وعزاه السيوطي إلى إسحاق بن بشر.أخرجه ابن عساكر في تاريخ دمشق ٤٧/٣٦٠.أخرجه الحكيم الترمذي في نوادر الأصول (ت: إسماعيل إبراهيم عوض) ١/٦٣٧ (٨٩٢). وعزاه السيوطي إليه بلفظ: الحنان: المحبب.أخرجه ابن جرير ١٥/٤٧٦، وإسحاق البستي في تفسيره ص١٧٧ من طريق ابن جريج. وعلَّقه يحيى بن سلام ١/٢١٧. وعزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ١٥/٤٧٥.أخرجه ابن جرير ١٥/٤٧٥.أخرجه ابن جرير ١٥/٤٧٧.علَّقه يحيى بن سلام ١/٢١٧. وعزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ١٥/٤٧٧.أخرجه عبد الرزاق ٢/٤، ٥، وابن جرير ١٥/٤٧٥. وعلَّقه يحيى بن سلام ١/٢١٧. وعزاه السيوطي إلى عبد بن حميد. وأخرجه ابن جرير ١٥/٤٧٦ من طريق سعيد بلفظ: رحمة من عندنا رحم الله بها زكريا.أخرجه ابن عدي في الكامل ٦/٢٢٨، وابن عساكر في تاريخ دمشق ٤٧/٣٦٠.عزاه السيوطي إلى عبد بن حميد.علَّقه يحيى بن سلام ١/٢١٧، وعقّب على تفسير الحنان بالتعطف والرحمة بقوله: وهو نَحْوٌ واحِدٌ.تفسير مقاتل بن سليمان ٢/٦٢٢.أخرجه ابن جرير ١٥/٤٧٥.تفسير يحيى بن سلام ١/٢١٧.عزاه السيوطي إلى ابن أبي حاتم.تفسير الثعلبي ٦/٢٠٨.أخرجه ابن عساكر ٦٤/١٦٩-١٧٣. وعزاه السيوطي إلى إسحاق بن بشر.أخرجه ابن عساكر في تاريخ دمشق ٤٧/٣٦٠.أخرجه ابن جرير ١٥/٤٨٠.علَّقه يحيى بن سلام ١/٢١٧.أخرجه عبد الرزاق ٢/٥. وعزاه السيوطي إلى عبد بن حميد.أخرج قول قتادة يحيى بن سلام ١/٢١٧، وابن جرير ١٥/٤٧٩.أخرجه ابن عدي في الكامل ٦/٢٢٨، وابن عساكر في تاريخ دمشق ٤٧/٣٦٠.علَّقه يحيى بن سلام ١/٢١٧. وفي تفسير البغوي ٥/٢٢٢: يعني: صدقة تصدق الله بها على أبويه.تفسير مقاتل بن سليمان ٢/٦٢٢.أخرجه ابن جرير ١٥/٤٨٠.أخرجه ابن جرير ١٥/٤٨٠.أخرجه البزار -كما في كشف الأستار ٣/١٠٨ (٢٣٥٨)-، والطبراني في الكبير ١٢/٢١٨ (١٢٩٣٨).</p><p>قال الهيثمي المجمع ٨/٢٠٨-٢٠٩ (١٣٨٠١): «رواه البزار، والطبراني، وفيه علي بن زيد بن جدعان، وضعَّفه الجمهور، وبَقِيَّة رجاله ثقات».أخرجه ابن جرير ١٥/٤٨٠. وعزاه السيوطي إلى ابن أبي حاتم.أخرجه ابن عساكر ٦٤/١٦٩-١٧٣. وعزاه السيوطي إلى إسحاق بن بشر.علقه يحيى بن سلام ١/٢١٧.تفسير مقاتل بن سليمان ٢/٦٢٢.عزاه السيوطي إلى ابن أبي حاتم.
  19,14,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَبَرَّۢا بِوَ ٰ⁠لِدَیۡهِ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٦٢٧٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، في قوله: <span class="qpc-hafs">﴿وبرا بوالديه﴾</span>: كان لا يعصيهما{1}. (١٠/٢٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٢٧٩<span class="dash">-</span></span> تفسير <span class="name-2">إسماعيل السُّدِّيّ</span>: قوله: <span class="qpc-hafs">﴿وبرا بوالديه﴾</span>، يعني: مطيعًا لوالديه{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٢٨٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وبرا بوالديه﴾</span>، يقول: وجعلناه مُطيعًا لوالديه{3}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَلَمۡ یَكُن جَبَّارًا﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٦٢٨١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق مقاتل وجويبر عن الضحاك- في قوله: <span class="qpc-hafs">﴿ولم يكن جبارا﴾</span>: يعني: قَتّال النفسِ التي حرَّم الله قتلها{1}. (١٠/٢٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٢٨٢<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span>: قوله: <span class="qpc-hafs">﴿ولم يكن جبارا عصيا﴾</span> مُسْتَكْبِرًا عن عبادة الله{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٢٨٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ولم يكن جبارا﴾</span>، يعني: مُتَكَبِّرًا عن عبادة الله ﷿{3}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿عَصِیࣰّا ۝١٤﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٦٢٨٤<span class="dash">-</span></span> عن قتادة، في قوله: <span class="qpc-hafs">﴿ولم يكن جبارا عصيا﴾</span>، قال: كان سعيد بن المسيب يقول: قال النبي ﷺ: «<b>ما مِن أحد يلقى الله يوم القيامة إلا ذا ذَنب، إلا يحيى بن زكريا</b>». قال قتادة: وقال الحسن: قال النبي ﷺ: «<b>ما أذنب يحيى بن زكريا قط، ولا همَّ بامرأة</b>»{7}. (١٠/٢٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٢٨٥<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق مقاتل وجويبر عن الضحاك- في قوله: <span class="qpc-hafs">﴿عصيا﴾</span>: يعني: عاصيًا لربه{1}. (١٠/٢٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٢٨٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿عصيا﴾</span>، يعني: ولا عاصٍ لربه{3}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿عَصِیࣰّا ۝١٤﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٤٦٢٨٧<span class="dash">-</span></span> عن ابن شهاب: أنّ النبي ﷺ خرج على أصحابه يومًا، وهم يتذاكرون فضل الأنبياء، فقال قائل: موسى كلَّمه الله تكليمًا. وقال قائل: عيسى روح الله وكلمته. وقال قائل: إبراهيم خليل الله. فقال النبي ﷺ: «<b>وأين الشهيدُ ابنُ الشهيد؟! يلبس الوَبَر، ويأكل الشجر مخافة الذنب؛ يحيى بن زكريا</b>»{10}. (١٠/٢٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٢٨٨<span class="dash">-</span></span> عن عبد الله بن عباس، أنّ النبي ﷺ قال: «<b>ما مِن أحد مِن ولد آدم إلا وقد أخطأ، أو همَّ بخطيئة، إلا يحيى بن زكريا، لم يهمَّ بخطيئة، ولم يعملها</b>»{11}. (١٠/٢٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٢٨٩<span class="dash">-</span></span> عن عمرو بن العاص، قال: قال رسول الله ﷺ: «<b>كلُّ بني آدم يأتي يوم القيامة وله ذَنب، إلا ما كان مِن يحيى بن زكريا</b>»{12}. (١٠/٢٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٢٩٠<span class="dash">-</span></span> عن يحيى بن جعدة، قال: قال رسول الله ﷺ: «<b>لا ينبغي لأحد أن يقول: أنا خيرٌ مِن يحيى بن زكريا؛ ما همَّ بخطيئة، ولا حكَّت</b>{13} <b>في صدره امرأة</b>»{14}. (١٠/٣٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٢٩١<span class="dash">-</span></span> عن <span class="name-2">كعب الأحبار</span> -من طريق سمرة- قال:كان يحيى لا يَقْرَب النساء، ولا يشتهِيهِنَّ، وكان شابًّا حسن الوجه، ليِّن الجناح، قليل الشعر، قصير الأصابع، طويل الأنف، أقرن الحاجبين، دقيق الصوت،كثير العبادة، قَوِيًّا في الطاعة{15}. (١٠/٣١)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن عساكر ٦٤/١٦٩-١٧٣. وعزاه السيوطي إلى إسحاق بن بشر.علقه يحيى بن سلام ١/٢١٨.تفسير مقاتل بن سليمان ٢/٦٢٢.أخرجه ابن عساكر ٦٤/١٦٩-١٧٣. وعزاه السيوطي إلى إسحاق بن بشر.علَّقه يحيى بن سلام ١/٢١٨.تفسير مقاتل بن سليمان ٢/٦٢٢.أخرجه عبد الرزاق في تفسيره ٢/٣٥٥ (١٧٥١، ١٧٥٢)، وابن جرير ١٥/٤٨١. وعلق يحيى بن سلام ١/٢١٧ نحو حديث الحسن.</p><p>قال ابن كثير في تفسيره ٩/٢٢٣ عن حديث الحسن: «مرسل».أخرجه ابن عساكر ٦٤/١٦٩-١٧٣. وعزاه السيوطي إلى إسحاق بن بشر.تفسير مقاتل بن سليمان ٢/٦٢٢.أخرجه ابن عساكر في تاريخه ٦٤/١٩٠.</p><p>قال ابن عساكر: «هذا مرسل».أخرجه أحمد ٤/١٤٤-١٤٥ (٢٢٩٤)، ٤/٤٠٠ (٢٦٥٤)، والحاكم ٢/٦٤٧ (٤١٤٩).</p><p>قال الذهبي في التلخيص: «إسناده جيد». وقال الهيثمي في المجمع ٨/٢٠٩ (١٣٨٠٢): «رواه أحمد، وأبو يعلى، والبزار، وزاد: «<b>فإنه لم يهم بها، ولم يعملها</b>». والطبراني، وفيه علي بن زيد، وضعَّفه الجمهور، وقد وُثِّق، وبقية رجال أحمد رجال الصحيح». وأورده الألباني في الصحيحة ٦/١٢٠٦ (٢٩٨٤).أخرجه الحاكم ٢/٤٠٤ (٣٤١١)، ٤/٢٧٣ (٧٦١٨)، وابن جرير ٥/٣٧٧، ١٥/٤٨١.</p><p>قال الحاكم: «هذا حديث صحيح، على شرط مسلم، ولم يخرجاه». وقال ابن كثير في تفسيره ٥/٢١٨ بعد عزوه لابن إسحاق: «ابن إسحاق هذا مُدَلِّس، وقد عنعن هذا الحديث».يقال: ما حكَّ في صدري كذا. أي: لم ينشرح له صدري. قال: ومن المجاز: حك في صدري وأحك واحتك. وهو ما يقع في خلدك من وساوس الشيطان. التاج (حكك).أخرجه أحمد في كتاب الزهد ص٦٥ (٣٩٩)، وابن عساكر في تاريخه ٦٤/١٩١.</p><p>قال ابن عساكر: «وهذا مرسل». وقال الألباني في الصحيحة ٦/١٢١١: «أخرجه ابن عساكر ... والسند صحيح، ولكنه مرسل».أخرجه الحاكم ٢/٥٩١.
  19,15,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَسَلَـٰمٌ عَلَیۡهِ یَوۡمَ وُلِدَ وَیَوۡمَ یَمُوتُ وَیَوۡمَ یُبۡعَثُ حَیࣰّا ۝١٥﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٦٢٩٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق مقاتل وجويبر عن الضحاك - في قوله: <span class="qpc-hafs">﴿وسلام عليه﴾</span> يعني: حين سلم الله عليه، <span class="qpc-hafs">﴿يوم ولد ويوم يموت ويوم يبعث حيا﴾</span>{1}. (١٠/٢٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٢٩٣<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق قتادة- قال: إنّ عيسى ويحيى التقيا، فقال يحيى لعيسى: استغفِر لي؛ أنت خيرٌ مِنِّي. فقال له عيسى: بل أنت خير مِنِّي؛ سلَّم الله عليك، وسلَّمت أنا على نفسي. فعرف -واللهِ- فضلها{2}. (١٠/٣٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٢٩٤<span class="dash">-</span></span> عن <span class="name-2">السُّدِّيّ</span>: <span class="qpc-hafs">﴿وسلام عليه يوم ولد﴾</span> يعني: حين ولد، <span class="qpc-hafs">﴿ويوم يموت﴾</span> يعني: وحين يموت، <span class="qpc-hafs">﴿ويوم يبعث حيا﴾</span> يوم القيامة{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٢٩٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وسلام عليه﴾</span> يعني: على يحيى ﵇ <span class="qpc-hafs">﴿يوم ولد﴾</span> يعني: حين وُلِد، مثل قوله سبحانه: <span class="qpc-hafs">﴿في كتاب الله يوم خلق السماوات﴾</span> [التوبة:٣٦]، يعني: حين خلق السموات، قال عيسى ﷺ: <span class="qpc-hafs">﴿ويوم أموت ويوم أبعث حيا﴾</span>{4} [مريم:٣٣] يعني: حين أموت، وحين أبعث، <span class="qpc-hafs">﴿وسلام عليه يوم ولد ويوم يموت ويوم يبعث حيا﴾</span> يعني: حين يُبعَث بعد الموت{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٢٩٦<span class="dash">-</span></span> عن <span class="name-3">سفيان بن عيينة</span> -من طريق صَدَقَةُ بن الفضل- قال: أوْحَشُ ما يكون الخلقُ في ثلاثة مواطن: يوم يُولَد فيرى نفسه خارجًا مِمّا كان فيه، ويوم يموت فيرى قومًا لم يكن عاينهم، ويوم يُبْعَث فيرى نفسه في محشر عظيم. قال: فأكرم الله فيها يحيى بن زكريا، فخصَّه بالسلام عليه، فقال: <span class="qpc-hafs">﴿وسلام عليه يوم ولد ويوم يموت ويوم يبعث حيا﴾</span>{6}<span class=comment-ref>٤١٣٩</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٤١٣٩</span> <span class="comment-type-4">ذكر</span> <u>ابنُ جرير</u> (١٥/٤٨١-٤٨٢) أنّ السلام بمعنى: الأمان، وساق أثر ابن عيينة، وأثر الحسن البصري السابق.</p><p>و<span class="comment-type-3">رجَّح</span> <u>ابنُ عطية</u> (٦/١٥) أنّه التحية المعروفة، فقال: «والأظهر عندي أنّها التحية المتعارفة، فهي أشرف وأشبه من الأمان؛ لأنّ الأمان مُتَحَصِّل له بنفي العصيان، وهي أقلّ درجاته، وإنما الشرف في أن سلّم الله عليه وحيّاه في المواطن التي الإنسان فيها في غاية الضعف والحاجة وقلة الحيلة والفقر إلى الله وعظيم الهول». ثم <span class="comment-type-4">علَّق</span> (٦/١٥-١٦) على ما أورده <u>ابن جرير</u> في أثر الحسن، فقال: «قال أبي ﵁: انتزع بعض العلماء من هذه الآية في التسليم فضل عيسى بأن قال: إدْلاله في التسليم على نفسه ومكانته من الله التي اقتضت ذلك حين قرَّر وحكى في محكم التنزيل أعظم في المنزلة مِن أن يُسلّم عليه ﵇. ولكلٍّ وجْه».</div></p><p><h3><span class="qpc-hafs">﴿وَسَلَـٰمٌ عَلَیۡهِ یَوۡمَ وُلِدَ وَیَوۡمَ یَمُوتُ وَیَوۡمَ یُبۡعَثُ حَیࣰّا ۝١٥﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٤٦٢٩٧<span class="dash">-</span></span> عن عبد الرحمن بن القاسم، قال: قال <b>⟨مالك</b>:⟩{تت} بلغني: أنّ عيسى ابن مريم ويحيى بن زكريا ﵉ ابنا خالة، وكان حملهما جميعًا معًا. فبلغني: أن أمَّ يحيى قالت لمريم: إنِّي أرى أنّ ما في بطني يسجد لِما في بطنك. قال مالك: أُرى ذلك لتفضيل الله عيسى؛ لأنّ الله جعله يُحْيِي الموتى، ويُبْرِئ الأكْمَهَ والأبرص، ولم يكن ليحيى عيشة إلا عُشْب الأرض، وإن كان لَيبكي من خشية الله، حتى لو كان على خَدِّه القارَ لأذابه، ولقد كان الدمع اتخذ في خَدِّه مَجْرًى{7}. (١٠/٢٨)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن عساكر ٦٤/١٦٩-١٧٣. وعزاه السيوطي إلى إسحاق بن بشر.أخرجه يحيى بن سلام ١/٢١٨ وعقّب عليه بقوله: يعني: قول الله تعالى في يحيى: <span class="qpc-hafs">﴿وسلام عليه يوم ولد ويوم يموت ويوم يبعث حيا﴾</span>، وقال عيسى: <span class="qpc-hafs">﴿قال إني عبد الله آتاني الكتاب وجعلني نبيا (٣٠) وجعلني مباركا أين ما كنت﴾</span> إلى قوله: <span class="qpc-hafs">﴿والسلام علي يوم ولدت ويوم أموت ويوم أبعث حيا﴾</span>، وأخرجه أيضًا عبد الرزاق في تفسيره ٢/٤، وأحمد في الزهد ص٧٦، وابن جرير ١٥/٤٨٢. وعزاه السيوطي إلى عبد بن حميد، وابن أبي حاتم.علَّقه يحيى بن سلام ١/٢١٨.في المطبوع: <span class="qpc-hafs">﴿ويوم يموت ويوم يبعث حيا﴾</span>.تفسير مقاتل بن سليمان ٢/٦٢٢.أخرجه ابن جرير ١٥/٤٨٢.عزاه السيوطي إلى ابن أبي حاتم.</p><p><b>وقد أورد السيوطي ١٠/٣١-٣٨ آثارًا كثيرة عن فضائل يحيى ﵇ وبعض أخباره.</b>
  19,16,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَٱذۡكُرۡ فِی ٱلۡكِتَـٰبِ مَرۡیَمَ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٦٢٩٨<span class="dash">-</span></span> قال <span class="name-2">إسماعيل السُّدِّيّ</span>: يقول: اذكر لأهل مكة أمر مريم{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٢٩٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿واذكر﴾</span> لأهل مكة <span class="qpc-hafs">﴿في الكتاب مريم﴾</span> يعني: في القرآن ابنة عمران بن ماثان، ويعقوب بن ماثان، مِن نسل سليمان بن داود ﵈{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٣٠٠<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: قوله: <span class="qpc-hafs">﴿واذكر في الكتاب مريم﴾</span>، يقول للنبي: أي: اقرأه عليهم، يعني: أمر مريم{3}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿إِذِ ٱنتَبَذَتۡ مِنۡ أَهۡلِهَا مَكَانࣰا شَرۡقِیࣰّا ۝١٦﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٦٣٠١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق العوفي- في قوله: <span class="qpc-hafs">﴿انتبذت من أهلها مكانا شرقيا﴾</span>، قال: مكانًا أظَلَّتها الشمس؛ أن يراها أحدٌ منهم{4}. (١٠/٣٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٣٠٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق الشعبي- قال: إنِّي لَأَعْلَمُ خَلْقِ اللهِ لِأَيِّ شيء اتخذت النصارى المشرقَ قِبلَةً؛ لقول الله: فـ<span class="qpc-hafs">﴿انتبذت من أهلها مكانا شرقيا﴾</span>، فاتخذوا ميلاد عيسى قبلة{5}. (١٠/٣٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٣٠٣<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق قابوس، عن أبيه- قال: إنّ أهل الكتاب كُتِب عليهم الصلاة إلى البيت والحج إليه، وما صرفهم عنه إلا قيل ربك: <span class="qpc-hafs">﴿إذ انتبذت من أهلها مكانا شرقيا﴾</span>. قال: خرجت منهم مكانًا شرقِيًّا، فصلُّوا قبل مطلع الشمس{6}. (١٠/٤٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٣٠٤<span class="dash">-</span></span> قال <span class="name-2">الحسن البصري</span>: اتّخذت النصارى المشرق قبلة لأنّ مريم انتبذت مكانًا شرقيًّا {7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٣٠٥<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿إذا انتبذت﴾</span> أي: انفردت <span class="qpc-hafs">﴿من أهلها مكانا شرقيا﴾</span> قال: قِبَل المشرق، شاسِعًا مُتَنَحِّيًا{8}. (١٠/٣٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٣٠٦<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- قال: خرجت مريم إلى جانب المحراب لِحَيضٍ أصابها، وهو قوله: فـ<span class="qpc-hafs">﴿انتبذت من أهلها مكانا شرقيا﴾</span> في شَرْقِيِّ المحراب{9}<span class=comment-ref>٤١٤٠</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٤١٤٠</span> ساق <u>ابنُ عطية</u> (٦/١٦) هذا القول، ثم ذكر <b>قولًا آخر</b> بأنها انتبذت لتعبد الله، و<span class="comment-type-3">رجَّحه</span> <span class="mustanad">مستندًا إلى الدلالة العقلية</span>، فقال: «وهذا أحسن، وذلك أن مريم كانت وقْفًا على سدانة المتَعَبد وخدمته والعبادة فيه، فتَنَحَّت من الناس لذلك».</div></p><p><div></p><p><p><span class="item-no">٤٦٣٠٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿إذ انتبذت﴾</span> يعني: إذ انفردت <span class="qpc-hafs">﴿من أهلها مكانا شرقيا﴾</span> فجلست فى المشرقة؛ لأنه كان الشتاء{2}. (ز)</p></p><p></div></p></div>",footnotes:1:علقه يحيى بن سلام ١/٢١٨.تفسير مقاتل بن سليمان ٢/٦٢٣.تفسير يحيى بن سلام ١/٢١٨.أخرجه ابن جرير ١٥/٤٨٥. وعزاه السيوطي إلى ابن أبي حاتم.أخرجه ابن جرير ١٠/٥٤٣، ١٥/٤٨٤، وإسحاق البستي في تفسيره ص١٧٨ مختصًرا، وابن أبي حاتم ٥/١٦١١. وعزاه السيوطي إلى الفريابي، وابن أبي شيبة، وعبد بن حميد، وابن المنذر.أخرجه ابن جرير ١٥/٤٨٣-٤٨٤. وعزاه السيوطي إلى ابن أبي حاتم.تفسير الثعلبي ٦/٢٠٩، وتفسير البغوي ٥/٢٢٣ بنحوه.أخرج أوله يحيى بن سلام ١/٢١٨، وعبد الرزاق ٢/٦، وابن جرير ١٥/٤٨٣-٤٨٤، وبعضه من طريق معمر. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم. وقد وقع في مطبوعة الدر وبعض المصادر: منتحيًا بدل متنحيًا.أخرجه ابن جرير ١٥/٤٨٣.تفسير مقاتل بن سليمان ٢/٦٢٣.
  19,17,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿فَٱتَّخَذَتۡ مِن دُونِهِمۡ حِجَابࣰا فَأَرۡسَلۡنَاۤ إِلَیۡهَا رُوحَنَا فَتَمَثَّلَ لَهَا بَشَرࣰا سَوِیࣰّا ۝١٧﴾</span> - سياق القصة</h3></p><p><div></p><p><p><span class="item-no">٤٦٣٠٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن مسعود</span> -من طريق السدي، عن مُرَّة الهمداني-= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٣٠٩<span class="dash">-</span></span> و<span class="name-1">عبد الله بن عباس</span> -من طريق السدي، عن أبي مالك- قالا: خرجت مريم إلى جانب المحراب لِحَيض أصابها، فلمّا طهرت إذ هي برَجُلٍ معها، <span class="qpc-hafs">﴿فتمثل لها بشرا﴾</span>، ففزعت، وقالت: <span class="qpc-hafs">﴿إني أعوذ بالرحمن منك إن كنت تقيا﴾</span>. فخرجت وعليها جلبابها، فأخذ بكُمِّها، فنفخ في جيب دِرْعِها، وكان مشقوقًا مِن قُدّامِها، فدخلت النفخة صدرها، فحملت، فأتتها أختُها امرأةُ زكريا ليلةً تزورها، فلمّا فتحت لها الباب التزمتها، فقالت امرأة زكريا: يا مريم، أُشْعِرْتُ أنِّي حبلى. قالت مريم: أُشْعِرْتُ أيضًا أنِّي حُبْلى. فقالت امرأة زكريا: فإنِّي وجدتُ ما في بطني يسجد للذي في بطنك. فذاك قوله: <span class="qpc-hafs">﴿مصدقا بكلمة من الله﴾</span>. فولدت امرأةُ زكريا يحيى، ولَمّا بلغ أن تضع مريمُ خرجت إلى جانب المحراب، <span class="qpc-hafs">﴿فأجاءها المخاض إلى جذع النخلة قالت﴾</span> استحياءً من الناس: <span class="qpc-hafs">﴿يا ليتني مت قبل هذا﴾</span> الآية، <span class="qpc-hafs">﴿فناداها﴾</span> جبريل <span class="qpc-hafs">﴿من تحتها أن لا تحزني قد جعل ربك تحتك سريا * وهزي إليك بجذع النخلة تساقط عليك رطبا جنيا﴾</span>. فهزَّتْهُ، فأجرى لها في المحراب نهرًا -والسَّرِيُّ: النهر-، فتساقطت النخلة رطبًا جنِيًّا، فلما ولدته ذهب الشيطان، فأخبر بني إسرائيل: أنّ مريم ولدت. فلما أرادوها على الكلام أشارت إلى عيسى، فتكلَّم، فقال: <span class="qpc-hafs">﴿إني عبد الله آتاني الكتاب وجعلني نبيا وجعلني مباركا﴾</span>. فلمّا وُلِد لم يبق في الأرض صنمٌ يُعْبَد من دون الله إلا خرَّ -وقع ساجدًا- لوجهه{1}<span class=comment-ref>٤١٤١</span>. (١٠/٤١)</p></p><p></div></p><p><div><span class=comment-ref>٤١٤١</span> <span class="comment-type-2">انتقد</span> <u>ابنُ عطية</u> (٦/٢١) ما رُوِي من قصص حمل عيسى ﵇، فقال: «وفي هذا كله ضَعْف».</div></p><p><div></p><p><p><span class="item-no">٤٦٣١٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق داود بن أبي هند، عن سعيد بن جبير- قال: لَمّا بلغت مريم، فبينما هي في بيتها مُتَفَضِّلة{2} إذ دخل عليها رجلٌ بغير إذن، فخشيت أن يكون دخل عليها لِيَغْتالَها، فقالت: <span class="qpc-hafs">﴿إني أعوذ بالرحمن منك إن كنت تقيا قال إنما أنا رسول ربك لأهب لك غلاما زكيا قالت أنى يكون لي غلام ولم يمسسني بشر ولم أك بغيا قال كذلك قال ربك﴾</span>. فجعل جبريل يردد ذلك عليها، وتقول: <span class="qpc-hafs">﴿أنى يكون لي غلام﴾</span>. وتَغَفَّلَها جبريل، فنفخ في جَيْب دِرْعِها، ونهض عنها، واستمرَّ بها حملُها، فقالت: إن خَرَجْتُ نحو المغرب فالقوم يصلون نحو المغرب، ولكن أخْرُجُ نحو المشرق حيث لا يراني أحد. فخَرَجَتْ نحو المشرق، فبينما هي تمشي إذ فجأها المخاض، فنظرت هل تجد شيئًا تستر به، فلم ترَ إلا جِذْعَ النخلة، فقالت: أستترُ بهذا الجذع مِن الناس. وكان تحت الجذع نهر يجري، فانضمَّت إلى النخلة، فلمّا وضَعَتْهُ خَرَّ كل شيء يعبد من دون الله في مشارق الأرض ومغاربها ساجدًا لوجهه، وفزع إبليس، فخرج، فصعد، فلم ير شيئًا ينكره، وأتى المشرق فلم ير شيئًا يُنكره، ودخل الأرض فلم ير شيئًا يُنكره، وجعل لا يصبر، فأتى المغرب لينظر، فلم ير شيئًا ينكره، فبينا هو يطوف إذ مَرَّ بالنخلة، فإذا هو بامرأة معها غلام قد ولدته، وإذا بالملائكة قد أحْدَقُوا بها وبابنها وبالنخلة، فقال: ههنا حَدَث الأمر. فمال إليهم، فقال: أيُّ شيء هذا الذي حدث؟ فكلَّمَتْه الملائكة، فقالوا: نبيٌّ وُلِد بغير ذَكَر. قال: نبيٌّ وُلِد بغير ذَكَر! قالوا: نعم. قال: أما -واللهِ- لَأُضِلَّنَّ به أكثر العالمين. أضلَّ اليهود فكفروا به، وأضلَّ النصارى فقالوا: هو ابن الله. قال: وناداها مَلَك مِن تحتها: <span class="qpc-hafs">﴿قد جعل ربك تحتك سريا﴾</span>. قال إبليس: ما حَمِلَتْ أُنثى إلا بعلمي، ولا وضعته إلا على كَفِّي، ليس هذا الغلام، لم أعلم به حين حَمَلَتْهُ أمه، ولم أعلم به حين وضعته{3}. (١٠/٤٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٣١١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق جويبر، عن الضحاك- في قوله: <span class="qpc-hafs">﴿واذكر في الكتاب مريم﴾</span> يقول: قُصَّ ذكرَها على اليهود والنصارى ومشركي العرب <span class="qpc-hafs">﴿إذا انتبذت﴾</span> يعني: خرجت <span class="qpc-hafs">﴿من أهلها مكانا شرقيا﴾</span> قال: كانت خرجت من بيت المقدس مما يلي المشرق، <span class="qpc-hafs">﴿فاتخذت من دونهم حجابا﴾</span> وذلك أنّ الله لَمّا أراد أن يبتدئها بالكرامة، ويُبَشِّرها بعيسى، وكانت قد اغتسلت من المحيض، فتَشَرَّفت، وجعلت بينها وبين قومها <span class="qpc-hafs">﴿حجابا﴾</span> يعني: جبلًا، فكان الجبل بين مجلسها وبين بيت المقدس، <span class="qpc-hafs">﴿فأرسلنا إليها روحنا﴾</span> يعني: جبريل، <span class="qpc-hafs">﴿فتمثل لها بشرا﴾</span> في صورة الآدميين، <span class="qpc-hafs">﴿سويا﴾</span> يعني: مُعْتَدِلًا، شابًّا، أبيض الوجه، جَعْدًا قَطَطًا{4}، حين اخضرَّ شاربُه، فلما نظرت إليه قائمًا بين يديها <span class="qpc-hafs">﴿قالت إني أعوذ بالرحمن منك إن كنت تقيا﴾</span>، وذلك أنها شبَّهته بشابٍّ كان يراها ونشأ معها، يُقال له: يوسف، من بني إسرائيل، وكان مِن خَدَمِ بيت المقدس، فخافت أن يكون الشيطان قد استَزَلَّه، فمِن ثَمَّ قالت: <span class="qpc-hafs">﴿إني أعوذ بالرحمن منك إن كنت تقيا﴾</span> يعني: إن كنتَ تخاف الله. <span class="qpc-hafs">﴿قال﴾</span> جبريلُ وتَبَسَّم: <span class="qpc-hafs">﴿إنما أنا رسول ربك لأهب لك غلاما زكيا﴾</span> يعني: لله مطيعًا، من غير بشر. <span class="qpc-hafs">﴿قالت أنى يكون لي غلام ولم يمسسني بشر﴾</span> يعني: زوجًا، <span class="qpc-hafs">﴿ولم أك بغيا﴾</span> أي: مُومِسَة. <span class="qpc-hafs">﴿قال﴾</span> جبريل: <span class="qpc-hafs">﴿كذلك﴾</span> يعني: هكذا <span class="qpc-hafs">﴿قال ربك هو علي هين﴾</span> يعني: خَلْقُه مِن غير بشر، <span class="qpc-hafs">﴿ولنجعله آية للناس﴾</span> يعني: عِبرة، والناس هنا: للمؤمنين خاصة، <span class="qpc-hafs">﴿ورحمة منا﴾</span> لِمَن صدَّق بأنه رسول الله، <span class="qpc-hafs">﴿وكان أمرا مقضيا﴾</span> يعني: كائنًا أن يكون مِن غير بشر. فَدَنا جبريلُ، فنفخ في جيبها، فدخلت النفخةُ جَوْفَها، فاحتملت كما تحمل النساء في الرَّحِم والمشِيمَة، ووضعته كما تضع النساء، فأصابها العَطَش، فأجرى الله لها جدولًا من الأردن، فذلك قوله: <span class="qpc-hafs">﴿قد جعل ربك من تحتك سريا﴾</span>. والسَّرِيُّ: الجدول. وحمل الجذِعُ من ساعته <span class="qpc-hafs">﴿رطبا جنيا﴾</span>، <span class="qpc-hafs">﴿فناداها من تحتها﴾</span> جبريل: <span class="qpc-hafs">﴿وهزي إليك بجذع النخلة﴾</span>. لم يكن على رأسها سعف، وكانت قد يبست منذ دهر طويل، فأحياها الله لها، وحملت، فذلك قوله: <span class="qpc-hafs">﴿تساقط عليك رطبا جنيا﴾</span> يعني: طريًّا بغباره، <span class="qpc-hafs">﴿فكلي﴾</span> مِن الرُّطَب، <span class="qpc-hafs">﴿واشربي﴾</span> من الجدول، <span class="qpc-hafs">﴿وقري عينا﴾</span> بولدك. فقالت: فكيف بي إذا سألوني: من أين هذا؟ قال لها جبريل: <span class="qpc-hafs">﴿فإما ترين﴾</span> يعني: فإذا رأيت <span class="qpc-hafs">﴿من البشر أحدا﴾</span> فأَعْنَتَكِ في أمرك؛ <span class="qpc-hafs">﴿فقولي إني نذرت للرحمن صوما﴾</span> يعني: صمتًا في أمر عيسى، <span class="qpc-hafs">﴿فلن أكلم اليوم إنسيا﴾</span> في أمره، حتى يكون هو الذي يُعَبِّر عنِّي وعن نفسه. قال: ففقدوا مريم مِن محرابها، فسألوا يوسف، فقال: لا عِلْمَ لي بها، وإنّ مفتاح محرابها مع زكريا. فطلبوا زكريا، وفتحوا الباب وليست فيه، فاتهموه، فأخذوه، ووَبَّخوه، فقال رجل: إنِّي رأيتها في موضع كذا. فخرجوا في طلبها، فسمعوا صوت عقعق{5} في رأس الجذع الذي مريم مِن تحته، فانطلقوا إليه، فذلك قول الله: <span class="qpc-hafs">﴿فأتت به قومها تحمله﴾</span>.</p><p>قال <span class="name-1">ابن عباس</span>: لَمّا رأت بأنّ قومها قد أقبلوا إليها احتملت الولد إليهم حتى تلقتهم به، فذلك قوله: <span class="qpc-hafs">﴿فأتت به قومها تحمله﴾</span> أي: لا تخاف رِيبة ولا تُهمة، فلما نظروا إليها شقَّ أبوها مدرعته، وجعل التراب على رأسه، وإخوتها، وآل زكريا، فـ<span class="qpc-hafs">﴿قالوا يا مريم لقد جئت شيئا فريا﴾</span> يعني: عظيمًا، <span class="qpc-hafs">﴿يا أخت هرون﴾</span> كانت من آل هارون، <span class="qpc-hafs">﴿ما كان أبوك امرأ سوء وما كانت أمك بغيا﴾</span> يعني: زانية، فأنّى أتيتِ هذا الأمر مع هذا الأخ الصالح، والأب الصالح، والأم الصالحة؟! <span class="qpc-hafs">﴿فأشارت إليه﴾</span> تقول لهم: أن كلِّموه، فإنه سيخبركم، فـ<span class="qpc-hafs">﴿إني نذرت للرحمن صوما﴾</span> أن لا أكلمكم في أمره، فإنّه سيُعَبِّر عَنِّي، ويكون لكم آية وعبرة. <span class="qpc-hafs">﴿قالوا﴾</span>: يا عجبنا، <span class="qpc-hafs">﴿كيف نكلم من كان في المهد صبيا﴾</span>؟! يعني: مَن هو في الخِرَقِ طفلًا لا ينطق! إذ أنطقه الله، فعبَّر عن أُمِّه، وكان عبرة لهم، فقال: <span class="qpc-hafs">﴿إني عبد الله﴾</span>. فلما أن قالها ابتدأ يحيى، وهو ابن ثلاث سنين، فكان أولَ مَن صدق به، فقال: إنِّي أشهد أنك عبد الله ورسوله. لتصديق قول الله: <span class="qpc-hafs">﴿مصدقا بكلمة من الله﴾</span> [آل عمران:٣٩]. فقال عيسى: <span class="qpc-hafs">﴿آتاني الكتاب وجعلني نبيا﴾</span> إليكم، <span class="qpc-hafs">﴿وجعلني مباركا أينما كنت﴾</span>.</p><p>قال <span class="name-1">ابن عباس</span>: قال رسول الله ﷺ: «<b>البركة التي جعلها الله لعيسى أنّه كان مُعَلِّمًا مُؤَدِّبًا حيثما توجه</b>». <span class="qpc-hafs">﴿وأوصاني بالصلاة والزكاة﴾</span> يعني: وأمرني، <span class="qpc-hafs">﴿وبرا بوالدتي﴾</span> فلا أعُقُّها.</p><p>قال <span class="name-1">ابن عباس</span>: حين قال: <span class="qpc-hafs">﴿وبرا بوالدتي﴾</span> قال زكريا: الله أكبر. فأخذه، فضَمَّه إلى صدره، فعلموا أنّه خُلِق مِن غير بشر، <span class="qpc-hafs">﴿ولم يجعلني جبارا شقيا﴾</span> يعني: مُتَعَظِّمًا سفّاكًا للدم، <span class="qpc-hafs">﴿والسلام علي يوم ولدت ويوم أموت ويوم أبعث حيا﴾</span>. يقول الله: <span class="qpc-hafs">﴿ذلك عيسى ابن مريم قول الحق الذي فيه يمترون﴾</span> يعني: يَشُكُّون. يقوله لليهود، ثم أمسك عيسى عن الكلام حتى بلغ مبلغ الناس{6}. (١٠/٤٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٣١٢<span class="dash">-</span></span> عن <span class="name-2">نوف البِكاليّ</span> -من طريق أبي عمران الجَوْنِيِّ- قال: كانت مريم ﵍ فتاة بتولًا، وكان زكريا زوج أختها كفلها، فكانت معه، فكان يدخل عليها يُسَلِّمُ عليها، فتُقَرِّبُ إليه فاكهة الشتاء في الصيف، وفاكهة الصيف في الشتاء، فدخل عليها زكريا مرَّة، فقرَّبت إليه بعض ما كانت تُقَرِّب، <span class="qpc-hafs">﴿قال يا مريم أنى لك هذا قالت هو من عند الله إن الله يرزق من يشاء بغير حساب هنالك دعا زكريا ربه﴾</span> إلى قوله: <span class="qpc-hafs">﴿آيتك أن لا تكلم الناس ثلاثة أيام إلا زمرا﴾</span> [آل عمران:٣٧-٤١]. قال: يُخْتَمُ على لسانك فلا تكلِّمُ الناس <span class="qpc-hafs">﴿ثلاث ليال سويا﴾</span>: صحيحًا. <span class="qpc-hafs">﴿فخرج على قومه من المحراب فأوحى إليهم﴾</span> كتب لهم <span class="qpc-hafs">﴿أن سبحوا بكرة وعشيا﴾</span>. قال: فبينما هي جالسة في منزلها إذا رجل قائم بين يديها قد هَتَكَ الحُجُبَ، فلمّا رأته قالت: <span class="qpc-hafs">﴿إني أعوذ بالرحمن منك إن كنت تقيا﴾</span>. قال: فلما ذكرت الرحمن فزع جبريل ﵇، قال: <span class="qpc-hafs">﴿إنما أنا رسول ربك لأهب لك غلاما زكيا﴾</span> إلى قوله: <span class="qpc-hafs">﴿وكان أمر مقضيا﴾</span>. فنفخ في جيبها جبريلُ، فحملت، حتى إذا أثْقَلَتْ وجِعَتْ ما توجع النساء، وكانت في بيت النبوة، فاستحيت، وهربت حياءً مِن قومها، فأخذت نحو المشرق، وخرج قومها في طلبها، فجعلوا يسألون: رأيتم فتاة كذا وكذا؟ فلا يخبرهم أحد، وأخذها <span class="qpc-hafs">﴿المخاض إلى جذع النخلة﴾</span> فتساندت إلى النخلة، قالت: <span class="qpc-hafs">﴿يا ليتني مت قبل هذا وكنت نسيا منسيا﴾</span> قال: حيضة من حيضة، <span class="qpc-hafs">﴿فناداها من تحتها﴾</span> قال: جبريل مِن أقصى الوادي: <span class="qpc-hafs">﴿أن لا تحزني قد جعل ربك تحتك سريا﴾</span> قال: جدولًا، <span class="qpc-hafs">﴿وهزي إليك بجذع النخلة تساقط عليك رطبا جنيا﴾</span>. فلمّا قال لها جبريلُ اشتدَّ ظهرها، وطابت نفسها، فقطعت سَرَرَه{7}، ولفَّته في خِرْقَة، وحملته، فلقي قومها راعي بقر وهم في طلبها، قالوا: يا راعي، هل رأيت فتاة كذا وكذا؟ قال: لا، ولكن رأيت الليلة مِن بقري شيئًا لم أره منها قطُّ فيما خلا. قال: وما رأيتها منها؟ قال: رأيتها باتت سُجَّدًا نحو هذا الوادي. فانطلقوا حيث وصف لهم، فلما رأتهم مريم جلست، وجعلت تُرضِع عيسى، فجاؤوا حتى وقفوا عليها، فقالوا: <span class="qpc-hafs">﴿يا مريم لقد جئت شيئا فريا﴾</span> قال: أمرًا عظيمًا، <span class="qpc-hafs">﴿فأشارت إليه﴾</span> أن كلِّموه، فعجبوا منها، <span class="qpc-hafs">﴿قالوا كيف نكلم من كان في المهد صبي﴾</span>؟! والمهد: حِجْرُها. فلما قالوا ذلك ترك عيسى ثديَها، واتَّكأ على يساره، ثم تكلم، <span class="qpc-hafs">﴿قال إني عبد الله آتاني الكتاب وجعلني نبيا وجعلني مباركا أينما كنت وأوصاني بالصلاة والزكاة ما دمت حيا وبرا بوالدتي ولم يجعلني جبارا شقيا والسلام علي يوم ولدت ويوم أموت ويوم أبعث حيا﴾</span>. قال: واختلف الناس فيه{8}. (١٠/٤٦)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿فَٱتَّخَذَتۡ مِن دُونِهِمۡ حِجَابࣰا﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٦٣١٣<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق جُوَيْبِر، عن الضحاك- قال: جعلت بينها وبين قومها حجابًا، يعني: جبلًا. فكان الجبل بين مجلسها وبين بيت المقدس{6}. (١٠/٤٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٣١٤<span class="dash">-</span></span> قال <span class="name-1">عبد الله بن عباس</span>: سِتْرًا{10}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٣١٥<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط-: <span class="qpc-hafs">﴿فاتخذت من دونهم حجابا﴾</span> مِن الجدران{11}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٣١٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فاتخذت من دونهم حجابا﴾</span>، يعني: جبلًا، فجعلت الجبل بينها وبينهم، فلم يرها أحد منهم، كقوله في ص [٣٢]: <span class="qpc-hafs">﴿حتى توارت بالحجاب﴾</span>، يعني: الجبل، وهو دون «ق» بمسيرة سنة، والشمس تغرب من ورائه{12}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿فَٱتَّخَذَتۡ مِن دُونِهِمۡ حِجَابࣰا﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٤٦٣١٧<span class="dash">-</span></span> عن ابن عباس أنّه قال ل<span class="name-1">عمر بن الخطاب</span>: بِمَ استحب النَّصارى الحُجُب على مذابحهم؟ قال: إنما يستحب النصارى الحجب على مذابحهم ومناسكهم لقول الله: <span class="qpc-hafs">﴿فاتخذت من دونهم حجابا﴾</span>{13}. (١٠/٤٨)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿فَأَرۡسَلۡنَاۤ إِلَیۡهَا رُوحَنَا﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٦٣١٨<span class="dash">-</span></span> عن <span class="name-1">أُبَيّ بن كعب</span> -من طريق أبي العالية- في قوله: إنّ روح عيسى ﵇ مِن جُمْلَة الأرواح التي أُخِذ عليها العهدُ في زمان آدم، <span class="qpc-hafs">﴿فتمثل لها بشرا سويا﴾</span> قال: تَمَثَّل لها روح عيسى في صورة بشر، <span class="qpc-hafs">﴿فحملته﴾</span> قال: حملت الذي خاطبها، دخل في فِيها{14}. (١٠/٤٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٣١٩<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق جويبر، عن الضحاك- في قوله: <span class="qpc-hafs">﴿فأرسلنا إليها روحنا﴾</span>، يعني: جبريل{15}. (١٠/٤٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٣٢٠<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span>، في قوله: <span class="qpc-hafs">﴿فأرسلنا إليها روحنا﴾</span> الآية، قال: نفخ جبريلُ في دِرْعِها، فبلغت حيث شاء الله{16}. (١٠/٤٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٣٢١<span class="dash">-</span></span> عن <span class="name-2">الضحاك بن مُزاحِم</span> -من طريق عبيد- في قوله: <span class="qpc-hafs">﴿فأرسلنا إليها روحنا﴾</span>: يعني: جبريل{17}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٣٢٢<span class="dash">-</span></span> قال <span class="name-2">عكرمة مولى ابن عباس</span>: إنّ مريم الصدِّيقة كانت تكون في المسجد ما دامت طاهرًا، فإذا حاضت تحوَّلَتْ إلى بيت خالتها، حتى إذا طهرت عادت إلى المسجد، فبينا هي تغتسل مِن الحيض إذ عرض لها جبريلُ ﵇ في صورة شابٍّ أمرد، وضِيء الوجه، جعد الشعر، سَوِيِّ الخَلْق، فذلك قوله: <span class="qpc-hafs">﴿فأرسلنا إليها روحنا﴾</span>يعني جبريل ﵇{10}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٣٢٣<span class="dash">-</span></span> عن <span class="name-2">عطاء بن يسار</span>: أنّ جبريل أتاها في صورة رجل، فكشف الحجاب، فلمّا رأته تَعَوَّذَتْ منه، فنفخ في صَنِفَةِ دِرْعِها{19}، فبلغت، فذُكِر ذلك في المدينة، فهُجِر زكريا وتُرِك، وكان قبل ذلك يُسْتَفْتى، ويأتيه الناس، حتى إنّ كان لَيُسَلِّم على الرجل فما يُكَلِّمه{13}. (١٠/٤٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٣٢٤<span class="dash">-</span></span> عن <span class="name-2">أبي صالح باذام</span>، في قوله: <span class="qpc-hafs">﴿فأرسلنا إليها روحنا﴾</span>، قال: بعث الله إليها ملَكًا، فنفخ في جيبها، فدخل في الفَرْج{21}. (١٠/٤٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٣٢٥<span class="dash">-</span></span> عن <span class="name-2">وهب بن مُنَبِّه</span> -من طريق عبد الصمد بن معقل- قال: أرسل الله جبريلَ إلى مريم، دخل في فيها{22}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٣٢٦<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿فأرسلنا إليها روحنا﴾</span>، قال: جبريل{23}. (١٠/٤٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٣٢٧<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- قال: فلمّا طَهُرَت -يعني: مريم- مِن حيضها، إذا هي برجل معها، وهو قوله: <span class="qpc-hafs">﴿فأرسلنا إليها روحنا﴾</span>، وهو جبريل{24}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٣٢٨<span class="dash">-</span></span> قال <span class="name-3">محمد بن السائب الكلبي</span>: كان زكريا كَفِل مريم، وكانت أختُها تحته، وكانت تكون في المحراب، فلمّا أدركت كانت إذا حاضت أخرجها إلى منزلِهِ إلى أختها، فإذا طهرت رجعت إلى المحراب. فطَهُرَت مرة، فلما فرغت مِن غُسْلِها قعدت في مشرقة في ناحية الدار، وعلَّقت عليها ثوبًا سترةً، فجاء جبريل إليها في ذلك الموضع، فلمّا رأته <span class="qpc-hafs">﴿قالت إني أعوذ بالرحمن منك إن كنت تقيا﴾</span>{25}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٣٢٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فأرسلنا إليها روحنا﴾</span>، يعني: جبريل ﵇{26}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٣٣٠<span class="dash">-</span></span> عن <span class="name-3">عبد الملك ابن جُرَيْج</span> -من طريق حجاج- قوله: <span class="qpc-hafs">﴿فأرسلنا إليها روحنا﴾</span>، قال: جبريل{22}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٣٣١<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>، في قوله: <span class="qpc-hafs">﴿فأرسلنا إليها روحنا﴾</span>: يعني: جبريل{28}<span class=comment-ref>٤١٤٢</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٤١٤٢</span> اختُلِف في الروح الذي تمثل لمريم؛ <b>فقال قوم</b>: هو جبريل. <b>وقال غيرهم</b>: عيسى.</p><p>و<span class="comment-type-3">رجَّح</span> <u>ابنُ كثير</u> (٩/٢٢٦) <span class="mustanad">مستندًا إلى دلالة القرآن</span> القولَ الأولَ الذي قاله قتادة، والضحاك، ومجاهد، والسدي، وابن جريج، ووهب بن منبه، فقال: «وهذا الذي قالوه هو ظاهر القرآن؛ فإنّه تعالى قد قال في الآية الأخرى: <span class="qpc-hafs">﴿نزل به الروح الأمين على قلبك لتكون من المنذرين﴾</span> [الشعراء:١٩٣-١٩٤]».</p><p>و<span class="comment-type-2">انتقد</span> (٩/٢٢٦) القولَ الثاني الذي قاله أبي، فقال: «وهذا في غاية الغرابة والنكارة، وكأنه إسرائيلي».</p><p>و<span class="comment-type-4">ذكر</span> <u>ابنُ عطية</u> (٦/١٦-١٧) أنّ مَن قال بالقول الأول قَدَّر الكلام: فتمثل هو لها. ومن قال بالثاني قدَّر الكلام: فتمثل المَلَك لها.</div></p><p><h3><span class="qpc-hafs">﴿فَتَمَثَّلَ لَهَا بَشَرࣰا سَوِیࣰّا ۝١٧﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٦٣٣٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق سعيد بن جبير- قال: لَمّا بلغت مريم، فبينا هي في بيتها مُتَفَضِّلة إذ دخل عليها رجلٌ بغير إذن، فخشيت أن يكون دخل عليها ليغتالها، فقالت: <span class="qpc-hafs">﴿إني أعوذ بالرحمن منك إن كنت تقيا﴾</span>{29}. (١٠/٤٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٣٣٣<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق جويبر، عن الضَّحّاك- في قوله: <span class="qpc-hafs">﴿فتمثل لها بشرا﴾</span> في صورة الآدَمِيِّين، <span class="qpc-hafs">﴿سويا﴾</span> يعني: مُعْتَدِلًا، شابًّا، أبيض الوجه، جعدًا قَطَطًا، حين اخْضَرَّ شاربُه{15}. (١٠/٤٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٣٣٤<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد-: أرسل إليها -فيما يذكر- جبريل في صورة آدم{31}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٣٣٥<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span>: <span class="qpc-hafs">﴿فتمثل لها بشرا سويا﴾</span>، يعني: سَوِيّ الخَلْق، بشرًا في صورة البشر وخلْقِهم{25}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٣٣٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فتمثل لها بشرا سويا﴾</span>، يعني: إنسانًا سَوِيًّا، يعني: سويَّ الخَلْق، على صورة شابٍّ أمْرَد، جعد الرأس{26}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه الحاكم ٢/٥٩٣، والبيهقي في الأسماء والصفات (٧٧٣)، وابن عساكر في تاريخ دمشق ٧٠/٨٦.أي: لابسة الثياب التي يلبسها الإنسان في البيت للراحة مِن قميص ونحوه، دون ثياب التصرف والثياب التي يلقى بها الناس. لسان العرب (فضل).أخرجه ابن عساكر ٧٠/٨١-٨٣.والقطط: الشديد الجعودة، وقيل: الحسن الجعودة. وجعودة الشعر: عدم انبساطه واسترساله. النهاية ٤/٨١.العقعق: طائر ذو لونين أبيض وأسود، طويل الذنب، من نوع الغربان. النهاية ٣/٢٧٦.أخرج ابن عساكر في تاريخه بعضه مفرقًا ٤٧/٣٤٨-٣٤٩، ٧٠/٩٥-٩٦، وعزاه السيوطي إلى إسحاق بن بشر.سَرَرَه: ما يقطع من النقرة التي في وسط بطن الوليد، وهي السُّرة. لسان العرب (سرر).عزاه السيوطي إلى عبد الله بن أحمد في زوائد الزهد. وأخرج آخره ابن أبي حاتم -كما في تفسير ابن كثير ٣/٢٢٦-، كما أخرج ابن عساكر في تاريخ دمشق ٧٠/٨٥ نحوه.أخرج ابن عساكر في تاريخه بعضه مفرقًا ٤٧/٣٤٨-٣٤٩، ٧٠/٩٥-٩٦، وعزاه السيوطي إلى إسحاق بن بشر.تفسير الثعلبي ٦/٢٠٩، وتفسير البغوي ٥/٢٢٣.أخرجه ابن جرير ١٥/٤٨٥.تفسير مقاتل بن سليمان ٢/٦٢٣. وفي تفسير الثعلبي ٦/٢٠٩، وتفسير البغوي ٥/٢٢٣ نحو أوله مختصرًا منسوبًا إلى مقاتل دون تعيينه.عزاه السيوطي إلى ابن أبي حاتم.أخرجه الحاكم ٢/٣٧٣ مطولًا، والبيهقي في الأسماء والصفات (٧٨٥)، وابن عساكر ٤٧/٣٤٩. وعزاه السيوطي إلى ابن أبي حاتم.أخرجه ابن عساكر في تاريخه ٤٧/٣٤٨-٣٤٩. وعزاه السيوطي في الدر إلى إسحاق بن بشر. وتقدم بتمامه مطولًا في سياق القصة.عزاه السيوطي إلى سعيد بن منصور، وابن المنذر.أخرجه إسحاق البستي في تفسيره ص١٧٨.تفسير الثعلبي ٦/٢٠٩، وتفسير البغوي ٥/٢٢٣.صَنِفَةِ درعها: طرفه وزاويته. لسان العرب (صنف).عزاه السيوطي إلى ابن أبي حاتم.عزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.أخرجه ابن جرير ١٥/٤٨٦.أخرجه يحيى بن سلام ١/٢١٩، وابن جرير ١٥/٤٨٥. وعزاه السيوطي إلى ابن أبي حاتم.أخرجه ابن جرير ١٥/٤٨٦. وعلَّقه يحيى بن سلام ١/٢١٩.علقه يحيى بن سلام ١/٢١٩.تفسير مقاتل بن سليمان ٢/٦٢٣.أخرجه ابن جرير ١٥/٤٨٦.تفسير يحيى بن سلام ١/٢١٨.أخرجه ابن عساكر ٧٠/٨١-٨٣ من طريق داود بن أبي هند.أخرجه ابن عساكر في تاريخه ٤٧/٣٤٨-٣٤٩. وعزاه السيوطي في الدر إلى إسحاق بن بشر. وتقدم بتمامه مطولًا في سياق القصة.أخرجه ابن جرير ١٥/٤٨٥. وعلَّقه يحيى بن سلام ١/٢١٩. وعزاه السيوطي إلى ابن أبي حاتم.علقه يحيى بن سلام ١/٢١٩.تفسير مقاتل بن سليمان ٢/٦٢٣.
  19,18,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿قَالَتۡ إِنِّیۤ أَعُوذُ بِٱلرَّحۡمَـٰنِ مِنكَ إِن كُنتَ تَقِیࣰّا ۝١٨﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٦٣٣٧<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق جُوَيْبِر، عن الضحاك-: لَمّا نَظَرَتْ إليه قائمًا بين يديها قالت: <span class="qpc-hafs">﴿إني أعوذ بالرحمن منك إن كنت تقيا﴾</span>. وذلك أنّها شَبَّهته بشابٍّ كان يراها، ونشأ معها، يقال له: يوسف، مِن بني إسرائيل، وكان مِن خَدَم بيت المقدس، فخافت أن يكون الشيطانُ قد اسْتَزَلَّه، فمِن ثَمَّ قالت: <span class="qpc-hafs">﴿إني أعوذ بالرحمن منك إن كنت تقيا﴾</span>. يعني: إن كنت تخاف الله{1}. (١٠/٤٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٣٣٨<span class="dash">-</span></span> عن <span class="name-2">أبي وائل شقيق بن سلمة</span> -من طريق عاصم بن أبي النجود- في قوله: <span class="qpc-hafs">﴿قالت إني أعوذ بالرحمن منك إن كنت تقيا﴾</span>، قال: لقد عَلِمَتْ مريمُ أنّ التَّقِيَّ ذو نُهْيَة{2}{3}. (١٠/٥٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٣٣٩<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span>، في قوله: <span class="qpc-hafs">﴿قالت إني أعوذ بالرحمن منك إن كنت تقيا﴾</span>، قال: إنما خَشِيَتْ أن يكون إنما يريدها عن نفسها{4}. (١٠/٥٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٣٤٠<span class="dash">-</span></span> عن <span class="name-2">وهب بن مُنَبِّه</span> -من طريق ابن إسحاق، عمَّن لا يتَّهم- <span class="qpc-hafs">﴿قالت إني أعوذ بالرحمن منك إن كنت تقيا﴾</span>: ولا ترى إلا أنّه رجل من بني آدم{5}<span class=comment-ref>٤١٤٣</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٤١٤٣</span> ذكر <u>ابنُ عطية</u> (٦/١٧) عن وهب أنه «رجل فاجر، كان في ذلك الزمن في قومها، فلمّا رأته مُتَسَوِّرًا عليها ظَنَّتْهُ إيّاه؛ فاستعاذت بالرحمن منه». وقال: «حكى هذا مكيٌّ وغيرُه». ثم <span class="comment-type-2">انتقده</span> <span class="mustanad">مستندًا إلى عدم الدليل</span>، فقال: «وهو ضعيف ذاهب مع التخرُّص».</p><p>و<span class="comment-type-2">انتقده</span> <u>ابنُ تيمية</u> (٤/٢٧٥)، فقال: «وما يقوله بعض الجهال ... فهو نوع مِن الهذيان، وهو من الكذب الظاهر الذي لا يقوله إلا جاهل».</div></p><p><div></p><p><p><span class="item-no">٤٦٣٤١<span class="dash">-</span></span> قال <span class="name-2">الحسن البصري</span>: أي: إن كنت تقيًّا له فاجتنبني{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٣٤٢<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط-: <span class="qpc-hafs">﴿فتمثل لها بشرا سويا﴾</span> فلمّا رأته فَزِعت منه، وقالت: <span class="qpc-hafs">﴿إني أعوذ بالرحمن منك إن كنت تقيا﴾</span>{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٣٤٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: فلما رأته حسبته إنسانًا، <span class="qpc-hafs">﴿قالت إني أعوذ بالرحمن منك إن كنت تقيا﴾</span>، يعني: مُخْلِصًا لله ﷿ تَعَبُّدَه{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٣٤٤<span class="dash">-</span></span> عن <span class="name-3">عبد الملك ابن جُرَيْج</span> -من طريق حجاج- قوله: <span class="qpc-hafs">﴿قالت إني أعوذ بالرحمن منك إن كنت تقيا﴾</span>، قال: خَشِيَتْ أن يكون إنّما يريدها على نفسها{9}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن عساكر في تاريخه ٤٧/٣٤٨-٣٤٩. وعزاه السيوطي إلى إسحاق بن بشر. وتقدم بتمامه مطولًا في سياق القصة.ذو نُهْية: ذو عقل وانتهاء عن فعل القبيح. الفتح ٦/٤٧٩.أخرجه عبد بن حميد -كما في فتح الباري ٦/٤٧٩، والتغليق ٤/٣٧-، وابن جرير ١٥/٤٨٧، وإسحاق البستي في تفسيره ص١٧٩، وابن أبي حاتم -كما في التغليق ٤/٣٧-. وعزاه السيوطي إلى ابن المنذر.عزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ١٥/٤٨٧.علقه يحيى بن سلام ١/٢١٩.أخرجه ابن جرير ١٥/٤٨٧.تفسير مقاتل بن سليمان ٢/٦٢٣.أخرجه ابن جرير ١٥/٤٨٦.
  19,19,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿قَالَ إِنَّمَاۤ أَنَا۠ رَسُولُ رَبِّكِ لِأَهَبَ لَكِ غُلَـٰمࣰا زَكِیࣰّا ۝١٩﴾</span> - قراءات</h3></p><p><div></p><p><p><span class="item-no">٤٦٣٤٥<span class="dash">-</span></span> عن <span class="name-2">عاصم بن أبي النجود</span> أنّه قرأ: <span class="qpc-hafs">﴿<b>لِأَهَبَ لَكِ</b>﴾</span> مهموزة بالألف، وفي قراءة <span class="name-1">عبد الله</span>: ‹لِيَهَبَ لَكِ› بالياء{1}<span class=comment-ref>٤١٤٤</span>. (١٠/٥٠)</p></p><p></div></p><p><div><span class=comment-ref>٤١٤٤</span> اختُلِف في قراءة قوله: <span class="qpc-hafs">﴿لأهب﴾</span>؛ <b>فقرأ قوم</b>: <span class="qpc-hafs">﴿لأهب﴾</span>، <b>وقرا آخرون</b>: ‹ليَهَبَ›. و<span class="comment-type-4">ذكر</span> <u>ابنُ جرير</u> (١٥/٤٨٨) أنّ الأولى على الحكاية، والثانية بمعنى: ليهب الله لك.</p><p>و<span class="comment-type-4">بنحوه</span> <u>ابنُ عطية</u> (٦/١٧).</p><p>و<span class="comment-type-3">رجَّح</span> <u>ابنُ جرير</u> (١٥/٤٨٨) القراءة الأولى بالألف دون الياء <span class="mustanad">مستندًا إلى رسم المصحف، والإجماع</span>، فقال: «لأنّ ذلك كذلك في مصاحف المسلمين، وعليه قراءة قديمهم وحديثهم، غير أبي عمرو، وغير جائز خلافهم فيما أجمعوا عليه، ولا سائغ لأحد خلاف مصاحفهم».</p><p>و<span class="comment-type-4">ذكر</span> <u>ابنُ كثير</u> (٩/٢٢٧) أن كلتا القراءتين لها وجه حسن، ومعنى صحيح، وأنّ كلًّا منهما تستلزم الأخرى.</div></p><p><h3><span class="qpc-hafs">﴿قَالَ إِنَّمَاۤ أَنَا۠ رَسُولُ رَبِّكِ لِأَهَبَ لَكِ غُلَـٰمࣰا زَكِیࣰّا ۝١٩﴾</span> - تفسير الآية</h3></p><p><div></p><p><p><span class="item-no">٤٦٣٤٦<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق جويبر، عن الضحاك-: قال جبريل وتبسم: <span class="qpc-hafs">﴿إنما أنا رسول ربك لأهب لك غلاما زكيا﴾</span>، يعني: لله مطيعًا، مِن غير بشر{2}. (١٠/٤٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٣٤٧<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span>، في قوله: <span class="qpc-hafs">﴿قال إنما أنا رسول ربك لأهب لك غلاما﴾</span>: زعموا نَفَخَ في جيب دِرْعِها وكُمِّها{3}. (١٠/٥٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٣٤٨<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span>، في قوله: <span class="qpc-hafs">﴿غلاما زكيا﴾</span>، قال: صالِحًا{4}. (١٠/٥٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٣٤٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿قال﴾</span> جبريل ﵇: <span class="qpc-hafs">﴿إنما أنا رسول ربك لاهب لك﴾</span> بأمر الله ﷿ <span class="qpc-hafs">﴿غلاما زكيا﴾</span> يعني: مُخْلِصًا، يقول: صالحًا{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٣٥٠<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿قال إنما أنا رسول ربك لأهب لك غلاما زكيا﴾</span>، أي: صالحًا{6}. (ز)</p></p><p></div></p></div>",footnotes:1:عزاه السيوطي إلى عبد بن حميد.</p><p>و<span class="qpc-hafs">﴿لِأَهَبَ لَكِ﴾</span> قراءة العشرة ما عدا أبا عمرو، ويعقوب، وورشًا؛ فإنهم قرؤوا: ‹ليَهَبَ لَكِ› بالياء بدل الهمزة. انظر: النشر ٢/٣١٧، والإتحاف ص٣٧٦.أخرجه ابن عساكر في تاريخه ٤٧/٣٤٨-٣٤٩. وعزاه السيوطي إلى إسحاق بن بشر. وتقدم بتمامه مطولًا في سياق القصة.عزاه السيوطي إلى ابن المنذر.عزاه السيوطي إلى عبد الله بن أحمد في زوائد الزهد، وابن أبي حاتم.تفسير مقاتل بن سليمان ٢/٦٢٣.تفسير يحيى بن سلام ١/٢١٩.
  19,20,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿قَالَتۡ أَنَّىٰ یَكُونُ لِی غُلَـٰمࣱ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٦٣٥١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿قالت﴾</span> مريم: <span class="qpc-hafs">﴿أنى﴾</span> مِن أين <span class="qpc-hafs">﴿يكون لي غلام ولم يمسسني بشر﴾</span>؟!{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٣٥٢<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿قالت أنى يكون لي غلام﴾</span>: مِن أين يكون لي غلام{2}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَلَمۡ یَمۡسَسۡنِی بَشَرࣱ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٦٣٥٣<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق جويبر، عن الضحاك- <span class="qpc-hafs">﴿قالت أنى يكون لي غلام ولم يمسسني بشر﴾</span>: يعني: زوجًا{3}. (١٠/٤٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٣٥٤<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span>: <span class="qpc-hafs">﴿ولم يمسسني بشر﴾</span>: ولم يُجامِعْنِي زوجٌ{4}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَلَمۡ أَكُ بَغِیࣰّا ۝٢٠﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٦٣٥٥<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق جويبر، عن الضحاك- <span class="qpc-hafs">﴿ولم أك بغيا﴾</span>: أي: مُومِسَة{5}. (١٠/٤٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٣٥٦<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span>، في قوله: <span class="qpc-hafs">﴿ولم أك بغيا﴾</span>، قال: زانِيَة{6}. (١٠/٥٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٣٥٧<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- <span class="qpc-hafs">﴿ولم أك بغيا﴾</span>، يقول: زانية{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٣٥٨<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ولم أك بغيا﴾</span>، يعني: ولم أركب فاحشة{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٣٥٩<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>، في قوله: <span class="qpc-hafs">﴿ولم أك بغيا﴾</span>: أي: ولم أكُ زانية{2}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٢/٦٢٣.تفسير يحيى بن سلام ١/٢١٩.أخرجه ابن عساكر في تاريخه ٤٧/٣٤٨-٣٤٩. وعزاه السيوطي إلى إسحاق بن بشر. وتقدم بتمامه مطولًا في سياق القصة.علقه يحيى بن سلام ١/٢١٩.أخرجه ابن عساكر في تاريخه ٤٧/٣٤٨-٣٤٩، وعزاه السيوطي إلى إسحاق بن بشر. وتقدم بتمامه مطولًا في سياق القصة.عزاه السيوطي إلى ابن أبي حاتم.أخرجه ابن جرير ١٥/٤٨٩.تفسير مقاتل بن سليمان ٢/٦٢٣.تفسير يحيى بن سلام ١/٢١٩.
  19,21,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿قَالَ كَذَ ٰ⁠لِكِ قَالَ رَبُّكِ هُوَ عَلَیَّ هَیِّنࣱۖ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٦٣٦٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق جويبر، عن الضحاك-: <span class="qpc-hafs">﴿قال﴾</span> جبريل: <span class="qpc-hafs">﴿كذلك﴾</span> يعني: هكذا <span class="qpc-hafs">﴿قال ربك هو علي هين﴾</span> يعني: خَلْقهُ مِن غير بشر{1}. (١٠/٤٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٣٦١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿قال﴾</span> جبريل ﵇: <span class="qpc-hafs">﴿كذلك﴾</span> يعني: هكذا <span class="qpc-hafs">﴿قال ربك﴾</span> إنّه يكون لك ولد من غير زوج، <span class="qpc-hafs">﴿هو علي﴾</span> على الله <span class="qpc-hafs">﴿هين﴾</span> يعني: يسير أن يخلق فى بطنك ولدًا مِن غير بشر{2}<span class=comment-ref>٤١٤٥</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٤١٤٥</span> <span class="comment-type-4">ذكر</span> <u>ابنُ عطية</u> (٦/١٨) أن المعنى: قال لها المَلَك: كذلِك هو كما وصَفْتِ، ولكن قالَ رَبُّكِ. ثم <span class="comment-type-4">ذكر</span> أن قد يحتمل أن يريد: على هذه الحال قالَ رَبُّكِ، ثم قال: «والمعنى متقارب».</div></p><p><div></p><p><p><span class="item-no">٤٦٣٦٢<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>، في قوله: <span class="qpc-hafs">﴿قال كذلك قال ربك هو علي هين﴾</span>: أن أخلقه{3}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَلِنَجۡعَلَهُۥۤ ءَایَةࣰ لِّلنَّاسِ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٦٣٦٣<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق جويبر، عن الضحاك- <span class="qpc-hafs">﴿ولنجعله آية للناس﴾</span>: يعني: عِبْرة، والناس هنا للمؤمنين خاصة{1}. (١٠/٤٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٣٦٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ولنجعله آية﴾</span> يقول: ولكي نجعله عبرة <span class="qpc-hafs">﴿للناس﴾</span> يعني: في بني إسرائيل{2}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَرَحۡمَةࣰ مِّنَّاۚ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٦٣٦٥<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق جويبر، عن الضحاك- <span class="qpc-hafs">﴿ورحمة منا﴾</span>: لِمَن صدَّق بأنه رسول الله{1}. (١٠/٤٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٣٦٦<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span>: <span class="qpc-hafs">﴿ورحمة منا﴾</span> لِمَن قَبِلَ عنه دينه{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٣٦٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ورحمة﴾</span> يعني: ونعمة <span class="qpc-hafs">﴿منا﴾</span> لِمَن تَبِعَه على دينه. مثل قوله سبحانه: <span class="qpc-hafs">﴿وما أرسلناك إلا رحمة للعالمين﴾</span> [الأنبياء:١٠٧]، يعني بالرحمة: النعمة لِمَن اتَّبعه على دينه{2}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَكَانَ أَمۡرࣰا مَّقۡضِیࣰّا ۝٢١﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٦٣٦٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق جويبر، عن الضحاك- <span class="qpc-hafs">﴿وكان أمرا مقضيا﴾</span>: يعني: كائنًا أن يكون مِن غير بشر{1}. (١٠/٤٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٣٦٩<span class="dash">-</span></span> عن <span class="name-2">وهب بن مُنَبِّه</span> -من طريق ابن إسحاق، عمَّن لا يتهم- <span class="qpc-hafs">﴿وكان أمرا مقضيا﴾</span>: أي: أن الله قد عزم على ذلك، فليس منه بُدٌّ{10}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٣٧٠<span class="dash">-</span></span> قال <span class="name-2">إسماعيل السُّدِّيّ</span>: يعني: كان عيسى أمرًا مِن الله مكتوبًا في اللوح المحفوظ أنه يكون؛ فأخذ جبريل جيبَها بأصبعه، فنفخ فيه، فصار إلى بطنها، فحَمَلَتْ{11}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٣٧١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وكان﴾</span> عيسى ﷺ مِن غير بشر <span class="qpc-hafs">﴿أمرا مقضيا﴾</span>، قد قضى الله ﷿ فى اللوح المحفوظ أنّه كائن لا بُدّ{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٣٧٢<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿وكان أمرا مقضيا﴾</span> كائِنًا{3}<span class=comment-ref>٤١٤٦</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٤١٤٦</span> <span class="comment-type-4">ذكر</span> <u>ابنُ كثير</u> (٩/٢٢٨) أن قوله: <span class="qpc-hafs">﴿وكان أمرا مقضيا﴾</span> يحتمل أمرين: <b>أحدهما</b>: أن يكون مِن تمام كلام جبريل لمريم، يخبرها أن هذا أمر مقدر في علم الله تعالى وقدره ومشيئته. <b>والآخر</b>: أن يكون مِن خبر الله تعالى لرسوله محمد ﷺ، وأنه كنّى بهذا عن النفخ في فرجها، <span class="mustanad">كما قال تعالى</span>: <span class="qpc-hafs">﴿ومريم ابنت عمران التي أحصنت فرجها فنفخنا فيه من روحنا﴾</span> [التحريم:١٢].</div></p></div>",footnotes:1:أخرجه ابن عساكر في تاريخه ٤٧/٣٤٨-٣٤٩، وعزاه السيوطي إلى إسحاق بن بشر. وتقدم بتمامه مطولًا في سياق القصة.تفسير مقاتل بن سليمان ٢/٦٢٣.تفسير يحيى بن سلام ١/٢١٩.أخرجه ابن عساكر في تاريخه ٤٧/٣٤٨-٣٤٩، وعزاه السيوطي إلى إسحاق بن بشر. وتقدم بتمامه مطولًا في سياق القصة.تفسير مقاتل بن سليمان ٢/٦٢٣.أخرجه ابن عساكر في تاريخه ٤٧/٣٤٨-٣٤٩، وعزاه السيوطي إلى إسحاق بن بشر. وتقدم بتمامه مطولًا في سياق القصة.علَّقه يحيى بن سلام ١/٢١٩.تفسير مقاتل بن سليمان ٢/٦٢٣.أخرجه ابن عساكر في تاريخه ٤٧/٣٤٨-٣٤٩، وعزاه السيوطي إلى إسحاق بن بشر. وتقدم بتمامه مطولًا في سياق القصة.أخرجه ابن جرير ١٥/٤٨٩.علقه يحيى بن سلام ١/٢١٩.تفسير مقاتل بن سليمان ٢/٦٢٣.تفسير يحيى بن سلام ١/٢١٩.
  19,22,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿فَحَمَلَتۡهُ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٦٣٧٣<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق المغيرة بن عثمان- قال: ما هي إلا أن حَمَلَتْ فوَضَعَتْ{1}<span class=comment-ref>٤١٤٧</span>. (١٠/٤٥)</p></p><p></div></p><p><div><span class=comment-ref>٤١٤٧</span> <span class="comment-type-1">وجَّهَ</span> <u>ابنُ كثير</u> (٩/٢٣٠ بتصرف) قول ابن عباس بقوله: «كأنّه أخذه من ظاهر قوله تعالى: <span class="qpc-hafs">﴿فحملته فانتبذت به مكانا قصيا فأجاءها المخاض إلى جذع النخلة﴾</span>».</p><p>ثم <span class="comment-type-2">انتقده</span> <span class="mustanad">مستندًا للغة</span>، فقال: «وهذا غريب ... فالفاء وإن كانت للتعقيب، ولكن تعقيب كل شيء بحسبه، <span class="mustanad">كما قال تعالى</span>: <span class="qpc-hafs">﴿ولقد خلقنا الإنسان من سلالة من طين ثم جعلناه نطفة في قرار مكين ثم خلقنا النطفة علقة فخلقنا العلقة مضغة فخلقنا المضغة عظاما﴾</span> [المؤمنون:١٢-١٤]، فهذه الفاء للتعقيب بحسبها، وقد ثبت في الصحيحين: أن بين كل صفتين أربعين يومًا. <span class="mustanad">وقال تعالى</span>: <span class="qpc-hafs">﴿ألم تر أن الله أنزل من السماء ماء فتصبح الأرض مخضرة﴾</span> [الحج:٦٣]».</div></p><p><div></p><p><p><span class="item-no">٤٦٣٧٤<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عكرمة- قال: وضَعَتْ مريمُ لثمانية أشهر؛ ولذلك لا يُولَد مولود لثمانية أشهر إلا مات، لِئَلّا تُسَبَّ مريمُ بعيسى{2}. (١٠/٤٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٣٧٥<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق داود بن أبي هند، عن سعيد بن جبير- قال: تَغَفَّلها جبريل، فنفخ في جيب درعها، ونهض عنها، واستمرَّ بها حملُها{3}. (١٠/٤٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٣٧٦<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق جويبر، عن الضحاك-: ... دنا جبريل، فنفخ في جيبها، فدخلت النفخةُ جوفَها، فاحتملت كما تحمل النساء في الرَّحِم والمشِيمَة، ووضعته كما تَضَعُ النساء{4}. (١٠/٤٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٣٧٧<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق العلاء بن الحارث الكوفي- قال: قالت مريم: كنتُ إذا خَلَوْتُ حدَّثني عيسى وكلَّمني وهو في بطني، وإذا كنتُ مع النّاس سَبَّح في بطني وكَبَّر، وأنا أسمع{5}. (١٠/٤٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٣٧٨<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span>، قال: بلغني: أنّ مريم حَمَلَتْ لسبع أو تسع ساعات، ووَضَعَتْهُ مِن يومِها{6}. (١٠/٤٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٣٧٩<span class="dash">-</span></span> قال <span class="name-2">الحسن البصري</span>: <span class="qpc-hafs">﴿فحملته﴾</span> تسعة أشهر في بطنها{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٣٨٠<span class="dash">-</span></span> عن <span class="name-2">وهب بن مُنَبِّه</span> -من طريق ابن إسحاق، عمَّن لا يتهم- قال: لَمّا قال ذلك -يعني: لما قال جبريل <span class="qpc-hafs">﴿قال كذلك قال ربك هو علي هين﴾</span> الآية- اسْتَسْلَمَتْ لأمر الله، فنفخ في جيبها، ثم انصرف عنها{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٣٨١<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- قال: طَرَحَتْ عليها جلبابَها لَمّا قال جبريلُ ذلك لها، فأخذ جبريلُ بِكُمَّيْها، فنفخ في جَيْبِ دِرْعِها، وكان مشقوقًا مِن قُدّامها، فدخلت النفخةُ صدرَها، فحملت، فأتتها أختُها امرأةُ زكريا ليلةً تزورها، فلمّا فتحت لها الباب التزمتها، فقالت امرأة زكريا: يا مريم، أُشْعِرتُ أني حبلى. قالت مريم: أُشْعِرتُ أيضًا أنِّي حُبْلى. قالت امرأة زكريا: إنِّي وجدتُ ما في بطني يسجد لما في بطنك. فذلك قوله: <span class="qpc-hafs">﴿مصدقا بكلمة من الله﴾</span> [آل عمران:٣٩]{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٣٨٢<span class="dash">-</span></span> قال <span class="name-3">عبد الملك ابن جُرَيْج</span> -من طريق حجاج-: يقولون: إنّه إنما نَفَخ في جَيْبِ دِرْعِها وكُمِّها{10}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٣٨٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فحملته﴾</span> أمُّه مريمُ ﵍ وهي ابنة ثلاث عشرة سنة، ومكثت مع عيسى ﵇ ثلاثًا وثلاثين سنة، وعاشت بعد ما رُفِع عيسى سِتَّ سنين، فماتت ولها اثنتان وخمسون سنة، فحملته أمه في ساعة واحدة، وصُوِّر في ساعة واحدة، وأَرْضَعَتْه في ساعةٍ حين زالت الشمسُ مِن يومها، وقد كانت حاضت حيضتين قبل حملِه{11}<span class=comment-ref>٤١٤٨</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٤١٤٨</span> أفادت الآثارُ الاختلاف في مدة حمل عيسى. و<span class="comment-type-3">رجَّح</span> <u>ابنُ كثير</u> (٩/٢٣٠) أنها تسعة أشهر كما قال الحسن <span class="mustanad">مستندًا إلى ظاهر القرآن</span>، فقال: «فالمشهور الظاهر -والله على كل شيء قدير- أنها حملت به كما تحمل النساء بأولادهن؛ ولهذا لَمّا ظهرت مَخايِلُ الحملِ عليها، وكان معها في المسجد رجلٌ صالح مِن قَراباتها يخدم معها البيت المقدس، يُقال له: يوسف النجار، فلمّا رأى ثِقَل بطنها وكِبَرِه أنكر ذلك مِن أمرها، ثُمَّ صرفه ما يعلم مِن براءتها ونزاهتها ودينها وعبادتها ...». و<span class="comment-type-4">ذكر</span> (٩/٢٢٩) أنّ هذا هو رأي الجمهور.</p><p>وكذا ذكر <u>ابنُ عطية</u> (٦/٢١). و<span class="comment-type-4">ذكر</span> <u>ابنُ عطية</u> أن ظاهر قوله: <span class="qpc-hafs">﴿فأجاءها المخاض﴾</span> يقتضي أنها حملت على عُرْف البشر.</div></p><p><h3><span class="qpc-hafs">﴿فَٱنتَبَذَتۡ بِهِۦ مَكَانࣰا قَصِیࣰّا ۝٢٢﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٦٣٨٤<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن مسعود</span> -من طريق السدي، عن مُرَّة الهمداني-= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٣٨٥<span class="dash">-</span></span> و<span class="name-1">عبد الله بن عباس</span> -من طريق السدي، عن أبي مالك- قالا: ولَمّا بلغ أن تضع مريمُ خرجت إلى جانب المحراب، <span class="qpc-hafs">﴿فأجاءها المخاض إلى جذع النخلة قالت يا ليتني مت قبل هذا﴾</span> الآية{12}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٣٨٦<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق العوفي- في قوله: <span class="qpc-hafs">﴿مكانا قصيا﴾</span>، قال: نائِيًا{13}. (١٠/٥١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٣٨٧<span class="dash">-</span></span> قال <span class="name-1">عبد الله بن عباس</span>: أقصى الوادي{14}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٣٨٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق داود بن أبي هند، عن سعيد بن جبير- قال: اسْتَمَرَّ بها حَمْلُها، فقالت: إن خرجتُ نحو المغرب فالقوم يُصَلُّون نحوَ المغرب، ولكن أخْرُجُ نحوَ المشرق حيث لا يراني أحد. فخرجت نحوَ المشرق، فبينما هي تمشي إذ فَجَأَها المخاضُ، فنظرت هل تجد شيئًا تَسْتَتِرُ به، فلم تَرَ إلا جذع النخلة، فقال: أستتر بهذا الجِذْع من الناس{3}. (١٠/٤٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٣٨٩<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نَجِيحٍ- في قوله: <span class="qpc-hafs">﴿مكانا قصيا﴾</span>، قال: قاصيًا{16}. (١٠/٥١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٣٩٠<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿فانتبذت به مكانا قصيا﴾</span>، قال: أي: فانفردت به مكانًا شاسِعًا مُنتَحِيًا{17}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٣٩١<span class="dash">-</span></span> عن <span class="name-2">وهب بن مُنَبِّه</span> -من طريق عبد الصمد بن معقل- قال: لَمّا اشتملت مريمُ على الحمل كان معها قَرابَةٌ لها، يقال له: يوسف النجار، وكانا مُنطَلِقَيْن إلى المسجد الذي عند جبل صهيون، وكان ذلك المسجدُ يومئذٍ مِن أعظم مساجدهم، فكانت مريم ويوسف يخدمان في ذلك المسجد، في ذلك الزمان، وكان لخدمته فضل عظيم، فرَغِبا في ذلك، فكانا يَلِيان معالجته بأنفسهما؛ تَحْبِيرَه{18} وكُناسَتَه وطهوره وكل عمل يُعْمَل فيه، وكان لا يُعْلَم مِن أهل زمانهما أحدٌ أشدُّ اجتهادًا وعبادةً منهما، فكان أول مَن أنكر حمل مريم صاحبها يوسف، فلمّا رأى الذي بها اسْتَعْظَمَهُ، وعظم عليه، وفظع به، فلم يدرِ على ماذا يضع أمرها، فإذا أراد يوسف أن يتهمها ذكر صلاحها وبراءتها، وأنها لم تغب عنه ساعةً قط، وإذا أراد أن يُبَرِّئها رأى الذي ظَهَر عليها، فلمّا اشْتَدَّ عليه ذلك كَلَّمَها، فكان أول كلامه إيّاها أن قال لها: إنّه قد حَدَث في نفسي مِن أمْرِكِ أمْرٌ قد خشيته، وقد حرصت على أن أُميْتَه وأكتمه في نفسي، فغلبني ذلك، فرأيت الكلام فيه أشفى لصدري. قالت: فقُل قولًا جميلًا. قال: ما كنتُ لِأقول لكِ إلا ذلك، فحدِّثيني، هل ينبت زرعٌ بغير بَذْرٍ؟ قالت: نعم. قال: فهل تنبت شجرةٌ مِن غير غَيْثٍ يُصيبها؟ قالت: نعم. قال: فهل يكون ولد مِن غير ذَكَر؟ قالت: نعم؛ ألم تعلم أنّ الله -تبارك وتعالى- أنبَتَ الزَّرْعَ يوم خلقه مِن غير بِذْر، والبِذْرُ يومئذٍ إنّما صار مِن الزَّرع الذي أنبته الله مِن غير بذر؟ أوَلَم تعلم أنّ الله بقدرته أنبت الشجر بغير غيث، وأنّه جعل بتلك القدرة الغيثَ حياةً للشجر بعد ما خلق كلَّ واحدٍ منهما وحده، أم تقول: لن يقدر الله على أن ينبت الشجر حتى استعان عليه بالماء، ولولا ذلك لم يقدر على إنباته؟ قال يوسف لها: لا أقول هذا، ولكنِّي أعلم أن الله -تبارك وتعالى- بقدرته على ما يشاء يقول لذلك: كن. فيكون. قالت مريم: أوَلَم تعلم أنّ الله -تبارك وتعالى- خلق آدمَ وامرأتَه من غير أنثى ولا ذَكَر؟ قال: بلى. فلمّا قالت له ذلك وقع في نفسه أنّ الذي بها شيءٌ من الله -تبارك وتعالى-، وأنّه لا يَسَعُهُ أن يسألها عنه، وذلك لِما رأى مِن كتمانها لذلك، ثُمَّ تَوَلّى يوسفُ خِدمة المسجد، وكفاها كلَّ عمل كانت تعمل فيه، وذلك لِما رأى مِن رِقَّة جِسمها، واصفرار لونها، وكَلَفِ وجهِها، ونُتُوِّ بطنِها، وضعف قوتها، ودأبِ نظرها، ولم تكن مريم قبل ذلك كذلك، فلمّا دنا نِفاسُها أوحى الله إليها أن اخرجي مِن أرض قومك، فإنّهم إن ظَفِرُوا بك عيَّروك، وقتلوا ولدك، فأفضت ذلك إلى أختها، وأختُها حينئذ حُبْلى، وقد بُشِّرَت بيحيى، فلمّا التقيا وجدت أمُّ يحيى ما في بطنها خرَّ لوجهه ساجدًا مُعْتَرِفًا بعيسى، فاحتملها يوسفُ إلى أرض مصر على حمارٍ له ليس بينها حين ركبت الحمار وبين الإكافِ{19} شيء، فانطلق يوسف بها حتى إذا كان مُتاخِمًا لأرض مصر في منقطع بلاد قومها أدرك مريمَ النفاسُ، فألجأها إلى آريِّ حمار -يعني: مِذْودَ الحمار{20}- وأصل نخلة، وذلك في زمان بردٍ أو حَرٍّ -الشك من أبي جعفر-، فاشتد على مريم المخاض، فلمّا وجدت منه شِدَّةً التجأت إلى النخلة، فاحتضنتها، واحْتَوَشَتْها الملائكةُ{21}، قاموا صفوفًا مُحْدِقِين بها{22}<span class=comment-ref>٤١٤٩</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٤١٤٩</span> <span class="comment-type-4">ذكر</span> <u>ابنُ عطية</u> (٦/٢١) أنه على هذه الرواية فإن مريم حملت واستمر حملها على عرف البشر.</div></p><p><div></p><p><p><span class="item-no">٤٦٣٩٢<span class="dash">-</span></span> عن <span class="name-2">وهب بن مُنَبِّه</span> -من طريق ابن إسحاق، عمَّن لا يتَّهم- قال: لَمّا حضر ولادها، يعني: مريم، ووجدت ما تجد المرأةُ مِن الطَّلق؛ خرجت من المدينة مُغَرِّبَةً مِن إيلياء، حتى تدركها الولادة إلى قرية مِن إيلياء على سِتَّة أميال يُقال لها: بيت لحم، فأجاءها المخاض إلى أصل نخلة إليها مِذْود بقرة، تحتها ربيعٌ من الماء، فوَضَعَتْه عندها{23}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٣٩٣<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- قال: لَمّا بلغ أن تضع مريمُ خرجت إلى جانب المحراب الشرقيِّ منه، فأتت أقصاه{13}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٣٩٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فانتبذت به﴾</span> يعني: فانفردت بعيسى ﷺ <span class="qpc-hafs">﴿مكانا قصيا﴾</span> يعني: نائيًا مِن أهلها مِن وراء الجبل{25}<span class=comment-ref>٤١٥٠</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٤١٥٠</span> أفادت الآثار الاختلاف في مكان ولادة عيسى؛ <b>فقال قوم</b>: كان شرقيَّ محرابها الذي تُصَلِّي فيه من بيت المقدس. <b>وقال آخرون</b>: لما كانت بين الشام وبلاد مصر ضربها الطَّلق. <b>وقال غيرهم</b>: كان ذلك على ثمانية أميال من بيت المقدس، في قرية هناك يقال لها: بيت لحم.</p><p>و<span class="comment-type-3">رجَّح</span> <u>ابنُ كثير</u> (٩/٢٣١-٢٣٢) <span class="mustanad">مستندًا إلى الإسرائيليات، والسنة</span> القولَ الأخير الذي قاله وهب بن منبه من طريق ابن إسحاق، فقال: «وهذا هو المشهور الذي تلقّاه الناسُ بعضُهم عن بعض، ولا يَشُكُّ فيه النصارى أنّه ببيت لحم، وقد تلقاه الناس. وقد ورد به الحديث إن صَحَّ».</div></p><p><h3><span class="qpc-hafs">﴿فَٱنتَبَذَتۡ بِهِۦ مَكَانࣰا قَصِیࣰّا ۝٢٢﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٤٦٣٩٥<span class="dash">-</span></span> في حديث شداد بن أوس عن الإسراء، قال الرسول ﷺ: <b>«ثم بلغنا أرضًا بَدَتْ لنا قصورُها، فقال: انزل. فنَزَلْتُ، ثم قال: صلِّ. فصَلَّيْتُ، ثم ركبنا، فقال: أتدري أين صَلَّيْتَ؟ قلت: الله أعلم. قال: صَلَّيْتَ ببيت لحمٍ حيث وُلِد عيسى المسيح ابن مريم</b>»{26}. (٩/١٥٣-١٥٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٣٩٦<span class="dash">-</span></span> عن <span class="name-2">زيد العَمِّيِّ</span>، قال: وُلِد عيسى يوم عاشوراء{27}. (١٠/٤٦)</p></p><p></div></p></div>",footnotes:1:أخرجه عبد الرزاق ٢/٧ من طريق الثوري عن رجل عمن سمع ابن عباس، وابن جرير ١٥/٤٩٧، وإسحاق البستي في تفسيره ص١٨٠. وعزاه السيوطي إلى الفريابي، وابن المنذر، وابن أبي حاتم.أخرجه ابن عساكر ٧٠/٩٢.أخرجه ابن عساكر ٧٠/٨١-٨٣. وتقدم بتمامه في سياق القصة.أخرجه ابن عساكر في تاريخه ٤٧/٣٤٨-٣٤٩، ٧٠/٩٥-٩٦، وعزاه السيوطي إلى إسحاق بن بشر. وتقدم بتمامه في سياق القصة.أخرجه ابن أبي شيبة ١١/٥٤٤، ١٣/١٩٦، وابن أبي حاتم -كما في تفسير ابن كثير ٣/٢٢١-، وأبو نعيم ٣/٢٩٤.أخرجه ابن عساكر ٤٧/٣٥٢.علَّقه يحيى بن سلام ١/٢٢٠.أخرجه ابن جرير ١٥/٤٩٠.أخرجه ابن جرير ١٥/٤٩٠.أخرجه ابن جرير ١٥/٤٩١.تفسير مقاتل بن سليمان ٢/٦٢٤. ونحوه في تفسير الثعلبي ٦/٢١٠، وتفسير البغوي ٥/٢٢٥ عن مقاتل بن سليمان، إلا أن فيه: وهي بنت عشر سنين.أخرجه الحاكم ٢/٥٩٣، والبيهقي في الأسماء والصفات (٧٧٣)، وابن عساكر في تاريخ دمشق ٧٠/٨٦. وتقدم بتمامه في سياق القصة.أخرجه ابن جرير ١٥/٤٩٢.تفسير البغوي ٥/٢٢٤.أخرجه ابن عساكر ٧٠/٨١-٨٣. وتقدم بتمامه في سياق القصة.أخرجه ابن جرير ١٥/٤٩٢. وعزاه السيوطي إلى عبد الرزاق، وعبد بن حميد، وابن أبي شيبة، وابن المنذر، وابن أبي حاتم.أخرجه يحيى بن سلام ١/٢٢٠، وعبد الرزاق ٢/٦ من طريق معمر بلفظ: متنحيّا.تَحْبِيرَه: تحسينه. لسان العرب (حبر).الإكاف للحمار كالسرج للفرس. تفسير غريب ما في الصحيحين للحميدي ص١٨٣.مِذْوَدُ الحمار: مكان علفه. لسان العرب (ذود).احْتَوَشَتْها الملائكة: جعلوها وسَطهم. لسان العرب (حوش).أخرجه ابن جرير ١٥/٤٩٤.أخرجه ابن جرير ١٥/٤٨٦.أخرجه ابن جرير ١٥/٤٩٢.تفسير مقاتل بن سليمان٢/٦٢٤.أخرجه البزار في مسنده ٨/٤٠٩-٤١١ (٣٤٨٤)، والطبراني في الكبير ٧/٢٨٢- ٢٨٣ (٧١٤٢).</p><p>قال البزار: «لا نعلمه يُرْوى عن شداد بن أوس عن النبي ﷺ إلا بهذا الإسناد». وقال البيهقي في دلائل النبوة ٢/٣٥٧: «هذا إسناد صحيح». وقال إسماعيل الأصبهاني في دلائل النبوة ص١٤٤ (١٥٦): «هذا حديث شاميُّ الطريق، واضح الإسناد». وقال ابن كثير في تفسيره ٥/٢٧: «ولا شك أن هذا الحديث -أعني: الحديث المروي عن شداد بن أوس- مشتمل على أشياء، منها ما هو صحيح كما ذكره البيهقي، ومنها ما هو منكر؛ كالصلاة في بيت لحم، وسؤال الصديق عن نعت بيت المقدس، وغير ذلك». وقال الهيثمي في المجمع ١/٧٤ (٢٣٦): «وفيه إسحاق بن إبراهيم بن العلاء، وثّقه يحيى بن معين، وضعّفه النسائي». وقد ورد الحديث بتمامه مطولًا في الآثار المتعلقة بتفسير قوله تعالى: <span class="qpc-hafs">﴿سُبْحانَ الَّذِي أسْرى بِعَبْدِهِ لَيْلًا مِنَ المَسْجِدِ الحَرامِ إلى المَسْجِدِ الأَقْصى الَّذِي بارَكْنا حَوْلَهُ لِنُرِيَهُ مِن آياتِنا﴾</span> [الإسراء:١].أخرجه الحاكم ٢/٥٩٣.
  19,23,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿فَأَجَاۤءَهَا ٱلۡمَخَاضُ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٦٣٩٧<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>: أن نافع بن الأزرق قال له: أخبِرني عن قوله ﷿: <span class="qpc-hafs">﴿فأجاءها المخاض﴾</span>. قال: ألْجَأَها. قال: وهل تعرف العرب ذلك؟ قال: نعم، أما سمعت حسان بن ثابت وهو يقول:</p><p>إذا شَدَدْنا شَدَّةً صادقة فَأَجَأْناكم إلى سفح الجبل؟{1}. (١٠/٥١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٣٩٨<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نَجِيحٍ- في قوله: <span class="qpc-hafs">﴿فأجاءها المخاض﴾</span>، قال: ألْجَأَها{2}. (١٠/٥١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٣٩٩<span class="dash">-</span></span> عن <span class="name-2">الضحاك بن مُزاحِم</span>، في قوله: <span class="qpc-hafs">﴿فأجاءها المخاض﴾</span>، قال: فأدّاها{3}. (١٠/٥١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٤٠٠<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿فأجاءها المخاض﴾</span>، قال: اضْطَّرَّها إلى جِذع نخلة{4}. (١٠/٥١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٤٠١<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- <span class="qpc-hafs">﴿فأجاءها المخاض إلى جذع النخلة﴾</span>، يقول: ألْجَأها المخاضُ إلى جِذع النخلة{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٤٠٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فأجاءها المخاض﴾</span>، يعني: فأَلْجَأَها{6}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿إِلَىٰ جِذۡعِ ٱلنَّخۡلَةِ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٦٤٠٣<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق العوفي- في قوله: <span class="qpc-hafs">﴿فأجاءها المخاض إلى جذع النخلة﴾</span>، قال: كان جِذْعًا يابِسًا{7}. (١٠/٥٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٤٠٤<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق جابر- في قوله: <span class="qpc-hafs">﴿إلى جذع النخلة﴾</span>، قال: كانت عجوة{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٤٠٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿إلى جذع النخلة﴾</span>، ولم يكن لها سَعَفٌ{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٤٠٦<span class="dash">-</span></span> عن <span class="name-3">أبي عبيد الله</span> -من طريق هلال بن خباب- <span class="qpc-hafs">﴿فأجاءها المخاض﴾</span>، قال: إلى جذع نخلة يابس، قد جِيء به لِيُبْنى به بيتٌ يُقال له: بيت لحم، فَحَرَّكَتْهُ، فإذا هو نخلة{10}. (١٠/٥٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٤٠٧<span class="dash">-</span></span> عن <span class="name-3">أبي قدامة</span>، قال: أُنْبِتَتْ لمريم نخلةٌ تَعَلَّقُ بها كما تَعَلَّقُ المرأة بالمرأة عند الولادة{11}. (١٠/٥٢، ٥٩)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿قَالَتۡ یَـٰلَیۡتَنِی مِتُّ قَبۡلَ هَـٰذَا وَكُنتُ نَسۡیࣰا مَّنسِیࣰّا ۝٢٣﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٦٤٠٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطاء الخراساني- في قوله: <span class="qpc-hafs">﴿وكنت نسيا منسيا﴾</span>، قال: لم أُخْلَق، ولم أك شيئًا{12}. (١٠/٥٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٤٠٩<span class="dash">-</span></span> عن <span class="name-2">نوف البِكالِيِّ</span> -من طريق أبي عمران الجوني- قال: وكنتُ حيضة نسيتها{13}. (١٠/٥٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٤١٠<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span>، في قوله: <span class="qpc-hafs">﴿وكنت نسيا منسيا﴾</span>، قال: حيضة{14}. (١٠/٥٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٤١١<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق جابر- في قوله: <span class="qpc-hafs">﴿يا ليتني مت قبل هذا وكنت نسيا منسيا﴾</span>، قال: يا ليتني كنت حيضة مُلْقاةً على عَقِبَي أُمِّي{15}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٤١٢<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span> -من طريق أبي سنان-، مثله{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٤١٣<span class="dash">-</span></span> عن <span class="name-2">الضحاك بن مزاحم</span>، في قوله: <span class="qpc-hafs">﴿وكنت نسيا منسيا﴾</span>، قال: حيضة مُلْقاة{17}. (١٠/٥٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٤١٤<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span>، في قوله: <span class="qpc-hafs">﴿وكنت نسيا منسيا﴾</span>، قال:حيضة مُلْقاة{18}. (١٠/٥٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٤١٥<span class="dash">-</span></span> قال <span class="name-2">الحسن البصري</span>: <span class="qpc-hafs">﴿قالت يا ليتني مت قبل هذا﴾</span> مِمّا خَشِيَتْ مِن الفضيحة{19}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٤١٦<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- في قوله: <span class="qpc-hafs">﴿كنت نسيا منسيا﴾</span>، قال: تقول: لا أُعْرَفُ، ولا أدري مَن أنا{20}. (١٠/٥٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٤١٧<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- أي: شيء لا يُعرَف، ولا يُذكَر{21}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٤١٨<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- قال: قالت وهي تَطْلَقُ مِن الحَبَل استحياءً مِن الناس: <span class="qpc-hafs">﴿يا ليتني مت قبل هذا وكنت نسيا منسيا﴾</span>. يقول: <span class="qpc-hafs">﴿نسيًا﴾</span>: نُسِيَ ذِكْرِي. و<span class="qpc-hafs">﴿منسيا﴾</span> يقول: نُسِيَ أثَرِي، فلا يُرى لِي أثَرٌ ولا عَيْنٌ{22}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٤١٩<span class="dash">-</span></span> عن <span class="name-2">الربيع بن أنس</span> -من طريق أبي جعفر- في قوله: <span class="qpc-hafs">﴿وكنت نسيا منسيا﴾</span>، قال: هو السَّقْطُ{23}. (١٠/٥٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٤٢٠<span class="dash">-</span></span> قال <span class="name-3">محمد بن السائب الكلبي</span>: <span class="qpc-hafs">﴿وكنت نسيا منسيا﴾</span>، قال: القوم ينزلون المنزل ثم يرتحلون، وينسون الشيءَ، فيُسمّى ذلك الشيء: النَّسا{24}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٤٢١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿قالت﴾</span> مريم: <span class="qpc-hafs">﴿يا ليتني مت قبل هذا﴾</span> الولدِ؛ حياءً مِن الناس، ثم قالت: <span class="qpc-hafs">﴿وكنت نسيا منسيا﴾</span> يعني: كالشيء الهالك الذي لا يُذْكَرُ فَيُنسى{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٤٢٢<span class="dash">-</span></span> قال يحيى بن سلام: وذكر <span class="name-3">حماد بن سلمة</span> المرأة النَّسُوءُ، وقال: النَّسُوءُ التي يُظَنُّ بها حَمْلٌ فلا يكون كذلك{24}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٤٢٣<span class="dash">-</span></span> قال <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿يا ليتني مت قبل هذا وكنت نسيا منسيا﴾</span>: لم أكن في الأرض شيئًا قطُّ{27}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٤٢٤<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿وكنت نسيا﴾</span> لا أُذكَر، <span class="qpc-hafs">﴿منسيا﴾</span> لم أُذْكَرْ{28}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه الطستي -كما في الإتقان ٢/٧١-.أخرجه يحيى بن سلام ١/٢٢٠ من طريق عاصم بن حكيم، وابن جرير ١٥/٤٩٣، وإسحاق البستي في تفسيره (رسالة جامعية، تحقيق: عوض العمري) ص١٨١ من طريق ابن جريج. وعزاه السيوطي إلى عبد الرزاق، وعبد بن حميد، وابن أبي شيبة، وابن المنذر، وابن أبي حاتم.عزاه السيوطي إلى ابن أبي شيبة، وابن المنذر، وابن أبي حاتم.أخرجه ابن جرير ١٥/٤٩٤. وعزاه السيوطي إلى ابن أبي حاتم.أخرجه ابن جرير ١٥/٤٩٤.تفسير مقاتل بن سليمان ٢/٦٢٤.أخرجه ابن جرير ١٥/٥١١. وعزاه السيوطي إلى ابن أبي حاتم.أخرجه الثوري في تفسيره ص١٨٣.تفسير مقاتل بن سليمان ٢/٦٢٤.عزاه السيوطي إلى عبد بن حميد.عزاه السيوطي إلى عبد الله بن أحمد في زوائد الزهد، وابن أبي حاتم.أخرجه ابن جرير ١٥/٤٩٩. وعزاه السيوطي إلى ابن المنذر.أخرجه يحيى بن سلام ١/٢٢٠. وعزاه السيوطي إلى عبد بن حميد بلفظ: حيضة ملقاة.عزاه السيوطي إلى عبد بن حميد، وابن المنذر. وورد في تفسير الثعلبي ٦/٢١١ بلفظ: حيضة ملقاة، وفي تفسير البغوي ٥/٢٢٥: جيفة ملقاة.أخرجه الثوري في تفسيره ص١٨٣، وإسحاق البستي في تفسيره ص١٨٢من طريق سفيان عن رجل، بلفظ: حيضة ملقاة.أخرجه الثوري في تفسيره ص١٨٣.عزاه السيوطي إلى عبد بن حميد. وأخرجه إسحاق البستي في تفسيره ص١٨٢ من طريق أبي سنان، بلفظ:حيضة على عقبي. وفي تفسير الثعلبي ٦/٢١١: حيضة ملقاة، وفي تفسير البغوي ٥/٢٢٥: جيفة ملقاة.عزاه السيوطي إلى ابن أبي شيبة، وعبد بن حميد، وابن المنذر، وابن أبي حاتم. وفي تفسير الثعلبي ٦/٢١١، وتفسير البغوي ٥/٢٢٥: جيفة ملقاة.علَّقه يحيى بن سلام ١/٢٢٠.أخرجه عبد الرزاق ٢/٦، وابن جرير ١٥/٥٠٠. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.أخرجه يحيى بن سلام ١/٢٢٠، وابن جرير ١٥/٤٩٩.أخرجه ابن جرير ١٥/٤٩٨-٤٩٩.أخرجه ابن جرير ١٥/٥٠٠. وعزاه السيوطي إلى عبد بن حميد، وابن أبي حاتم.علقه يحيى بن سلام ١/٢٢٠.تفسير مقاتل بن سليمان ٢/٦٢٤.علقه يحيى بن سلام ١/٢٢٠.أخرجه ابن جرير ١٥/٥٠٠.تفسير يحيى بن سلام ١/٢٢٠.
  19,24,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿فَنَادَىٰهَا مِن تَحۡتِهَاۤ أَلَّا تَحۡزَنِی﴾</span> - قراءات</h3></p><p><div></p><p><p><span class="item-no">٤٦٤٢٥<span class="dash">-</span></span> عن <span class="name-2">علقمة بن قيس النخعي</span> -من طريق إبراهيم- أنه قرأ: (فَخاطَبَها مَن تَحْتَها){1}<span class=comment-ref>٤١٥١</span>. (١٠/٥٣)</p></p><p></div></p><p><div><span class=comment-ref>٤١٥١</span> <span class="comment-type-4">علَّق</span> <u>ابنُ جرير</u> (١٥/٥٠١) على قراءة علقمة بقوله: «والصواب <span class="qpc-hafs">﴿مِن﴾</span>، ولكن كذا قال ابن بشار: (مَن) هنا».</div></p><p><div></p><p><p><span class="item-no">٤٦٤٢٦<span class="dash">-</span></span> عن <span class="name-2">علقمة بن قيس النخعي</span> -من طريق إبراهيم- أنه قرأ: (فَخاطَبَها مِن تَحْتِها){2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٤٢٧<span class="dash">-</span></span> عن <span class="name-2">زِرِّ بن حُبَيْش</span> أنّه قرأ: ‹فَناداها مَن تَحْتَها›{3}. (١٠/٥٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٤٢٨<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span>، قال: مَن قرأ: <span class="qpc-hafs">﴿مِن تَحْتِها﴾</span> فهو جبريل، ومَن قرأ:‹مَن تَحْتَها› فهو عيسى{4}. (١٠/٥٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٤٢٩<span class="dash">-</span></span> عن أبي بكر بن عياش، قال: قرأ <span class="name-2">عاصم [بن أبي النجود]</span>: ‹فَناداها مَن تَحْتَها› بالنصب. قال: وقال عاصم: مَن قرأ بالنصب فهو عيسى، ومَن قرأها بالخفض فهو جبريل{5}<span class=comment-ref>٤١٥٢</span>. (١٠/٥٤)</p></p><p></div></p><p><div><span class=comment-ref>٤١٥٢</span> اختُلِف في قراءة قوله: <span class="qpc-hafs">﴿فناداها من تحتها﴾</span>؛ <b>فقرأ قوم</b>: ‹مَن›، و<b>قرأ آخرون</b>: <span class="qpc-hafs">﴿مِن﴾</span>. و<span class="comment-type-4">ذكر</span> <u>ابنُ عطية</u> (٦/٢١-٢٢) أن القراءة الأولى بالفتح على أن ‹مَن› فاعل «نادى»، والمراد بـ‹مَن› عيسى. وأنّ قراءة كسر الميم تأتي على أنها لابتداء الغاية، وأنهم اختلفوا في التفسير؛ <b>فقال بعضهم</b>: المراد: عيسى. و<b>قال آخرون</b>: المراد: جبريل المجاور لها قبل.</p><p>و<span class="comment-type-4">بنحوه</span> <u>ابنُ جرير</u> (١٥/٥٠٠-٥٠١).</p><p>و<span class="comment-type-4">ذكر</span> <u>ابنُ كثير</u> (٩/٢٣٣) أنّ قراءة الفتح بمعنى: الذي تحتها. وقراءة الكسر على أن <span class="qpc-hafs">﴿مِن﴾</span> حرف جر.</p><p>و<span class="comment-type-3">رجَّح</span> <u>ابنُ جرير</u> (١٥/٥٠٥) أن المنادِي عيسى، ثم <span class="comment-type-3">رجَّح</span> صحة كلتا القراءتين <span class="mustanad">مستندًا إلى المعنى</span>، فقال: «وذلك أنه إذا قرئ بالكسر كان في قوله <span class="qpc-hafs">﴿فناداها﴾</span> ذِكرٌ من عيسى، وإذا قرئ ‹مَن تَحْتَها› بالفتح كان الفعل لـ‹مَن›، وهو عيسى».</div></p><p><h3><span class="qpc-hafs">﴿فَنَادَىٰهَا مِن تَحۡتِهَاۤ أَلَّا تَحۡزَنِی﴾</span> - تفسير الآية</h3></p><p><div></p><p><p><span class="item-no">٤٦٤٣٠<span class="dash">-</span></span> عن <span class="name-1">أبي بن كعب</span>، قال: الذي خاطبها هو الذي حَمَلَتْه في جوفها، دخل مِن فيها{6}. (١٠/٥٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٤٣١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق العوفي- في قوله: <span class="qpc-hafs">﴿فناداها من تحتها﴾</span>، قال: جبريل، ولم يتكلَّم عيسى حتى أتَتْ به قومَها{7}. (١٠/٥٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٤٣٢<span class="dash">-</span></span> عن <span class="name-1">البراء بن عازِب</span>، <span class="qpc-hafs">﴿فناداها من تحتها﴾</span>، قال: مَلَك{4}. (١٠/٥٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٤٣٣<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span>، في قوله: <span class="qpc-hafs">﴿فناداها من تحتها﴾</span>، قال: جبريلُ مِن أسفلِ الوادي{6}. (١٠/٥٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٤٣٤<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span> -من طريق ثابت بن عجلان- قوله: <span class="qpc-hafs">﴿فناداها من تحتها﴾</span>، قال: عيسى، أما تسمعُ اللهَ يقول: <span class="qpc-hafs">﴿فأشارت إليه﴾</span>؟{10}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٤٣٥<span class="dash">-</span></span> عن <span class="name-2">إبراهيم النخعي</span> -من طريق مغيرة- قال: عيسى{11}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٤٣٦<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span>، قال: الذي ناداها هو جبريل{5}. (١٠/٥٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٤٣٧<span class="dash">-</span></span> عن <span class="name-2">عمرو بن ميمون</span> -من طريق حُصَيْنٍ- قال: الذي ناداها الملَك{13}. (١٠/٥٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٤٣٨<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نَجِيحٍ- في قوله: <span class="qpc-hafs">﴿فناداها من تحتها﴾</span>، قال: عيسى ابن مريم{14}. (١٠/٥٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٤٣٩<span class="dash">-</span></span> عن <span class="name-2">الضَّحّاك بن مُزاحِم</span> -من طريق عبيد بن سليمان- <span class="qpc-hafs">﴿فناداها من تحتها﴾</span> قال: يعني: جبريل، <span class="qpc-hafs">﴿من تحتها﴾</span> قال: كان أسفل منها{15}. (١٠/٥٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٤٤٠<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق قتادة- <span class="qpc-hafs">﴿فناداها من تحتها﴾</span>، قال: ابنُها{16}. (١٠/٥٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٤٤١<span class="dash">-</span></span> عن <span class="name-2">وهب بن مُنَبِّه</span> -من طريق ابن إسحاق، عمَّن لا يتَّهم- <span class="qpc-hafs">﴿فناداها﴾</span>: عيسى{10}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٤٤٢<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿فناداها من تحتها﴾</span>: أي: الملَك مِن تحت النخلة{18}. (١٠/٥٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٤٤٣<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- <span class="qpc-hafs">﴿فناداها﴾</span>: جبريل{19}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٤٤٤<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- <span class="qpc-hafs">﴿فناداها من تحتها﴾</span> قال: عيسى ناداها: <span class="qpc-hafs">﴿أن لا تحزني قد جعل ربك تحتك سريا﴾</span>. قالت: وكيف لا أحزن وأنتَ معي؟! لا ذات زوج فأقول: مِن زوج، ولا مملوكة فأقول: مِن سيد، أيُّ شيء عُذْري عند الناس؟! <span class="qpc-hafs">﴿يا ليتني مت قبل هذا وكنت نسيا منسيا﴾</span>. فقال لها عيسى: أنا أكفيكِ الكلامَ{20}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٤٤٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فناداها﴾</span> جبريل ﵇ <span class="qpc-hafs">﴿من تحتها﴾</span> يعني: مِن أسفل منها في الأرض، وهي فوقه على رابية، وجبريل ﵇ يناديها بهذا الكلام: <span class="qpc-hafs">﴿ألا تحزني﴾</span>. ذلك حين تَمَنَّتِ الموتَ{21}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٤٤٦<span class="dash">-</span></span> عن <span class="name-3">يحيى بن سلّام</span>، في قوله: <span class="qpc-hafs">﴿تحتها﴾</span>، قال: سَمِعَتْ مَن يقول: تحتها من الأرض. وقال بعضهم: <span class="qpc-hafs">﴿تحتِها﴾</span> يعني: عيسى{22}<span class=comment-ref>٤١٥٣</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٤١٥٣</span> اختلف في مَن ناداها؛ <b>فقال قوم</b>: عيسى. <b>وقال آخرون</b>: جبريل.</p><p>و<span class="comment-type-3">رجَّح</span> <u>ابنُ جرير</u> (١٥/٥٠٥) <span class="mustanad">مستندًا إلى اللغة، والسياق، والدلالات العقلية</span> القولَ الأول الذي قاله مجاهد، والحسن، ووهب بن منبه، وسعيد بن جبير، وابن زيد، وأبي بن كعب، فقال: «وذلك أنّه من كناية ذِكْرِه أقرب منه مِن ذكر جبريل، فردُّه على الذي هو أقرب إليه أولى مِن ردِّه على الذي هو أبعد منه، ألا ترى في سياق قوله: <span class="qpc-hafs">﴿فحملته فانتبذت به مكانا قصيا﴾</span> يعني به: فحملت عيسى فانتبذت به، ثم قيل: <span class="qpc-hafs">﴿فناداها﴾</span> نسقًا على ذلك مِن ذكر عيسى والخبر عنه. ولِعِلَّةٍ أخرى، وهي قوله: <span class="qpc-hafs">﴿فأشارت إليه﴾</span> ولم تشر إليه -إن شاء الله- إلا وقد علمت أنّه ناطِقٌ في حاله تلك، ولِلَّذي كانت قد عرفت ووثقت به منه بمخاطبته إياها بقوله لها: <span class="qpc-hafs">﴿أن لا تحزني قد جعل ربك تحتك سريا﴾</span>، وما أخبر الله عنه أنّه قال لها: أشيري للقوم إليه. ولو كان ذلك قولًا مِن جبريل لكان خَلِيقًا أن يكون في ظاهر الخبر مُبَيَّنًا أنّ عيسى سينطق، ويَحْتَجُّ عنها للقوم، وأمر منه لها بأن تشير إليه للقوم إذا سألوها عن حالها وحاله».</p><p>وكذا <span class="comment-type-3">رجَّحه</span> <u>ابنُ عطية</u> (٦/٢٢)، فقال: «والأوَّلُ أظهر، وعليه كان الحسن يُقسِم».</div></p><p><h3><span class="qpc-hafs">﴿قَدۡ جَعَلَ رَبُّكِ تَحۡتَكِ سَرِیࣰّا ۝٢٤﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٦٤٤٧<span class="dash">-</span></span> عن ابن عمر: سمعتُ رسول الله ﷺ يقول: «<b>إنّ السَّرِيَّ الذي قال الله لمريم</b>: <span class="qpc-hafs">﴿قد جعل ربك تحتك سريا﴾</span> <b>نَهْرٌ أخرجه الله لها لِتَشْرَبَ مِنهُ</b>»{23}. (١٠/٥٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٤٤٨<span class="dash">-</span></span> عن البراء بن عازب، عن النبي ﷺ، في قوله: <span class="qpc-hafs">﴿قد جعل ربك تحتك سريا﴾</span>، قال: «<b>النهر</b>»{24}. (١٠/٥٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٤٤٩<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- في قوله: <span class="qpc-hafs">﴿قد جعل ربك تحتك سريا﴾</span>، قال: نهر عيسى{25}. (١٠/٥٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٤٥٠<span class="dash">-</span></span> عن عثمان بن مِحْصَنٍ، قال: سُئِل <span class="name-1">عبد الله بن عباس</span> عن قوله: <span class="qpc-hafs">﴿سريا﴾</span>. قال: هو الجدول، أما سمعت قولَ الشاعر:</p><p>سَلْمٌ ترى الدّاليَّ منه أزوَرا إذا يعُجُّ في السَّرِيِّ هرهرا؟{26}. (١٠/٥٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٤٥١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>: أنّ نافع بن الأزرق قال: أخبِرني عن قوله ﷿: <span class="qpc-hafs">﴿تحتك سريا﴾</span>. قال: السَّرِيُّ: النهر الصغير، وهو الجدول. قال: وهل تعرف العرب ذلك؟ قال: نعم، أما سمعت قول الشاعر:</p><p>سهل الخليقة ماجد ذو نائل مثل السَّرِيِّ تَمُدُّه الأنهارُ؟{27}. (١٠/٥٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٤٥٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق سعيد بن أبي صالح- في قول الله: <span class="qpc-hafs">﴿قد جعل ربك تحتك سريا﴾</span>، قال: الماءُ الذي كان تحتها{28}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٤٥٣<span class="dash">-</span></span> قال <span class="name-1">عبد الله بن عباس</span>: ضرب جبريل ﵇وقيل: عيسى عليه الصلاة والسلام- برجله الأرضَ، فظَهَرَتْ عينُ ماءٍ عَذْبٍ، وجَرى فحَيِيَت النخلة بعد يبسها فأورقت وأثمرت وأرطبت{29}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٤٥٤<span class="dash">-</span></span> عن <span class="name-1">البراء بن عازب</span> -من طريق أبي إسحاق- في قوله: <span class="qpc-hafs">﴿قد جعل ربك تحتك سريا﴾</span>، قال: هو الجدول، وهو النهر الصغير{30}. (١٠/٥٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٤٥٥<span class="dash">-</span></span> عن <span class="name-2">الضَّحّاك بن مُزاحِم</span> -من طريق سلمة بن نُبيط- في قوله: <span class="qpc-hafs">﴿سريا﴾</span>، قال: الجدول{31}. (١٠/٥٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٤٥٦<span class="dash">-</span></span> عن <span class="name-2">عمرو بن ميمون</span> -من طريق حُصين- قال في هذه الآية: <span class="qpc-hafs">﴿قد جعل ربك تحتك سريا﴾</span>، قال: السري: نهر يشرب منه. وفي لفظ: هو الجدول{32}. (١٠/٥٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٤٥٧<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span> -من طريق حصين- في قوله: <span class="qpc-hafs">﴿سريا﴾</span>، قال: نهرًا، بالقِبْطِيَّة{33}. (١٠/٥٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٤٥٨<span class="dash">-</span></span> عن <span class="name-2">إبراهيم النخعي</span> -من طريق مغيرة- أنه قال: هو النهر الصغير؛ يعني: الجدول، يعني: قوله: <span class="qpc-hafs">﴿قد جعل ربك تحتك سريا﴾</span> {34}. (١٠/٥٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٤٥٩<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نَجِيحٍ- في قوله: <span class="qpc-hafs">﴿سريا﴾</span>. قال: نهرًا بالسُّريانية{35}. (١٠/٥٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٤٦٠<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span>، قال: السري: الماء{5}. (١٠/٥٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٤٦١<span class="dash">-</span></span> عن <span class="name-2">وهب بن مُنَبِّه</span> -من طريق ابن إسحاق، عمَّن لا يتَّهم- <span class="qpc-hafs">﴿قد جعل ربك تحتك سريا﴾</span>: يعني: ربيع الماء{37}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٤٦٢<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span>، في قوله: <span class="qpc-hafs">﴿قد جعل ربك تحتك سريا﴾</span>، قال: نبيًّا، وهو عيسى{38}. (١٠/٥٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٤٦٣<span class="dash">-</span></span> عن قتادة: أنّ <span class="name-2">الحسن [البصري]</span> تلا هذه الآية وإلى جنبه <span class="name-2">حميد بن عبد الرحمن الحميري</span>: <span class="qpc-hafs">﴿قد جعل ربك تحتك سريا﴾</span>. قال: إن كان لَسَرِيًّا، وإن كان لكريمًا.= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٤٦٤<span class="dash">-</span></span> فقال <span class="name-2">حميد</span>: يا أبا سعيد، إنّه الجدول. فقال له: مِن ثَمَّ تُعْجِبُنا مجالستُك، ولكن غَلَبَتْنا عليك الأمراءُ{5}. (١٠/٥٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٤٦٥<span class="dash">-</span></span> عن سفيان بن حسين، عن <span class="name-2">الحسن البصري</span> في قوله: <span class="qpc-hafs">﴿قد جعل ربك تحتك سريا﴾</span>، قال: كان -واللهِ- سريًّا. يعني: عيسى ﵇.= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٤٦٦<span class="dash">-</span></span> فقال له <span class="name-2">خالد بن صفوان</span>: يا أبا سعيد، إنّ العرب تُسَمِّي الجدول: السَّرِي. فقال: صدقتَ{40}. (١٠/٥٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٤٦٧<span class="dash">-</span></span> عن جرير بن حازم، قال: سألني <span class="name-2">محمد بن عباد بن جعفر</span>: ما يقول أصحابُكم في قوله: <span class="qpc-hafs">﴿قد جعل ربك تحتك سريا﴾</span>؟ قال: فقلت له: سمعت <span class="name-2">قتادةَ</span> يقول: الجدول.= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٤٦٨<span class="dash">-</span></span> قال [<span class="name-2">محمد بن عباد بن جعفر</span>]: فأخْبِرْ قتادةَ عنِّي -فإنما نزل القرآن بلغتنا-: أنّه الرَّجلُ السَّرِيُّ{41}. (١٠/٥٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٤٦٩<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿قد جعل ربك تحتك سريا﴾</span>: والسري: هو الجدول، تُسَمِّيه أهلُ الحجاز{37}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٤٧٠<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- <span class="qpc-hafs">﴿قد جعل ربك تحتك سريا﴾</span>، قال: هو الجدول، يعني: النهر الصغير{43}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٤٧١<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- <span class="qpc-hafs">﴿قد جعل ربك تحتك سريا﴾</span>: والسريُّ: هو النهر{37}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٤٧٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿قد جعل ربك تحتك سريا﴾</span>، يعني: الجدول الصغير مِن الأنهار{45}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٤٧٣<span class="dash">-</span></span> قال <span class="name-3">عبد الملك ابن جُرَيْج</span> -من طريق حجاج-: نهرًا إلى جنبها{46}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٤٧٤<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿قد جعل ربك تحتك سريا﴾</span>: يريد نفسه، وأيُّ شيء أسْرى منه؟ قال: والذين يقولون: السري هو النهر. ليس كذلك النهر، لو كان النهر لكان إنما يكون إلى جنبها، ولا يكون النهر تحتها{47}. (١٠/٥٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٤٧٥<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: والسري: هو الجدول، وهو النهر. وهو بالسريانية: سريًّا{48}<span class=comment-ref>٤١٥٤</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٤١٥٤</span> اختُلِف في السّري؛ <b>فقال قوم</b>: النهر الصغير. <b>وقال آخرون</b>: عيسى.</p><p>و<span class="comment-type-3">رجَّح</span> <u>ابنُ جرير</u> (١٥/٥١٠) <span class="mustanad">مستندًا إلى اللغة، والسياق</span> القولَ الأول، فقال: «وذلك أنه أعلمها ما قد أعطاها الله من الماء الذي جعله عندها، وقال لها: <span class="qpc-hafs">﴿وهزي إليك بجذع النخلة تساقط عليك رطبا جنيا فكلي﴾</span> من هذا الرطب <span class="qpc-hafs">﴿واشربي﴾</span> من هذا الماء <span class="qpc-hafs">﴿وقري عينا﴾</span> بولدك، والسري معروف من كلام العرب: أنه النهر الصغير».</p><p>و<span class="comment-type-4">بنحوه</span> <u>ابنُ كثير</u> (٩/٢٣٥).</div></p></div>",footnotes:1:أخرجه أبو عبيد في فضائل القرآن ص١٧٦، وابن جرير ١٥/٥٠١. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.</p><p>و(فَخاطَبَها) قراءة شاذة. انظر: مختصر ابن خالويه ص٨٧.أخرجه ابن جرير ١٥/٥٠١.عزاه السيوطي إلى أبي عبيد، وابن المنذر.</p><p>و<span class="qpc-hafs">﴿مِن تَحْتِها﴾</span> بكسر الميم وخفض التاء قراءة متواترة، قرأ بها نافع، وأبو جعفر، وحمزة، والكسائي، وخلف العاشر، وحفص، وروح، وقرأ بقية العشرة: ‹مَن تَحْتَها› بفتح الميم، ونصب التاء. انظر: النشر ٢/٣١٨، والإتحاف ص٣٧٧.عزاه السيوطي إلى ابن أبي حاتم.عزاه السيوطي إلى عبد بن حميد.عزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ١٥/٥٠٢. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم، وابن مردويه.عزاه السيوطي إلى ابن أبي حاتم.عزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ١٥/٥٠٤.أخرجه سعيد بن منصور في سننه - التفسير ٦/٢١٩ (١٣٨٣).عزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ١٥/٥٠١-٥٠٢. وعزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ١٥/٥٠٣، وإسحاق البستي في تفسيره ص١٨٣ من طريق ابن جُرَيج. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.أخرجه ابن جرير ١٥/٥٠١-٥٠٢، وإسحاق البستي في تفسيره ص١٨٥، كما أخرجاه مختصرًا من طريق جويبر. وعزاه السيوطي إلى عبد بن حميد.أخرجه عبد الرزاق ٢/٦، وابن جرير ١٥/٥٠٣. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم. بلفظ هو عيسى.أخرجه ابن جرير ١٥/٥٠٤.أخرجه يحيى بن سلام ١/٢٢٠ من طريق سعيد بلفظ: كنا نُحَدَّث أنه الملَك، يعني: جبريل، وعبد الرزاق ٢/٦ من طريق معمر، وابن جرير ١٥/٥٠٢. وعزاه السيوطي إلى عبد بن حميد، وابن أبي حاتم.أخرجه ابن جرير ١٥/٥٠٢.أخرجه ابن جرير ١٥/٥٠٤-٥٠٥.تفسير مقاتل بن سليمان ٢/٦٢٤.تفسير يحيى بن سلام ١/٢٢٠.أخرجه الطبراني ١٢/٣٤٦ (١٣٣٠٣)، وأبو نعيم في الحلية ٣/٣٤٦.</p><p>قال أبو نعيم: «غريب من حديث عكرمة، لم يروه عنه إلا أيوب بن نَهِيك، ولا عنه فيما أعلم إلا يحيى». وقال ابن كثير في تفسيره ٥/٢٢٤: «وهذا حديث غريب جدًّا من هذا الوجه. وأيوب بن نَهيك هذا هو الحُبُلي، قال فيه أبو حاتم الرازي: ضعيف. وقال أبو زرعة: منكر الحديث. وقال أبو الفتح الأزدي: متروك الحديث». وقال الهيثمي في المجمع ٧/٥٤-٥٥ (١١١٥٦): «رواه الطبراني، وفيه يحيى بن عبد الله البابلتي، وهو ضعيف». وقال السيوطي في الإتقان ٤/٢٧١: «أخرج الطبراني بسند ضعيف». وقال الألباني في الصحيحة بعد إيراد سند الطبراني ٣/١٨٩: «إسناد ضعيف».أخرجه الطبراني في الصغير ٢/٩ (٦٨٥)، وابن شاهين في الخامس من الأفراد ص٢٧٥ (٧٦).</p><p>قال ابن شاهين: «وهذا حديث غريب، لا أعلم رواه عن أبي إسحاق إلا أبو سنان هذا، وسمعت عبد الله بن سليمان يقول: هو أبو سنان سعد بن سنان الشيباني من أهل قزوين». وقال الهيثمي في المجمع ٧/٥٤ (١١١٥٥): «رواه الطبراني في الصغير، وفيه معاوية بن يحيى الصدفي، وهو ضعيف».أخرجه ابن جرير ١٥/٥٠٦. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.عزاه السيوطي إلى سعيد بن منصور، وعبد بن حميد، وابن المنذر.أخرجه الطستي -كما في الإتقان ٢/٨٥-. وعزاه السيوطي إلى ابن الأنباري في الوقف.أخرجه عبد الله بن وهب في الجامع ١/٢٠ (٤٠).تفسير الثعلبي ٦/٢١١، وتفسير البغوي ٥/٢٢٦.أخرجه يحيى بن سلّام ١/٢٢١، وعبد الرزاق ٢/٦-٧، وابن جرير ١٥/٥٠٦، وإسحاق البستي في تفسيره ص١٨٥، والحاكم ٢/٣٧٣، وابن مردويه -كما في تخريج الكشاف ٢/٣٢٢، وفتح الباري ٦/٤٧٩، والتغليق ٤/٣٨-. وعزاه السيوطي إلى الفريابي، وسعيد بن منصور، وعبد بن حميد، وابن المنذر. وعلَّقه البخاري ٤/ ١٦٥ وزاد: بالسريانية. وأخرجه كذلك ابن أبي حاتم -كما في فتح الباري ٦/٤٧٩-.أخرجه ابن جرير ١٥/٥٠٨، ومن طريق عبيد أيضًا، وإسحاق البستي في تفسيره ص١٨٧من طريق عبيد بلفظ: الجدول الصغير من الأنهار. وعزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ١٥/٥٠٧، وإسحاق البستي في تفسيره ص١٨٦. وعزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ١٥/٥٠٨، وابن أبي حاتم -كما في الإتقان ٢/١٣٤-.أخرجه ابن جرير ١٥/٥٠٨. وعزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ١٥/٥٠٧، إسحاق البستي في تفسيره -من طريق ابن جريج- ص١٨٥، وابن أبي حاتم –كما في الإتقان ٢/١٣٤. وعزاه السيوطي إلى ابن المنذر.عزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ١٥/٥٠٩.عزاه السيوطي إلى ابن أبي حاتم. وأخرجه ابن جرير ١٥/٥٠٩ من طريق قتادة بلفظ: يعني: عيسى نفسه. وفي تفسير الثعلبي ٦/٢١١: يعني: عيسى كان -واللهِ- عبدًا سريًّا؛ أي: رفيعًا.عزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ١٥/٥٠٧ من طريق قتادة بنحوه وزاد في آخره: غلبتنا عليك الأمراء، وإسحاق البستي في تفسيره ص١٨٦، وابن عساكر ١٦/١٠٤.عزاه السيوطي إلى ابن أبي شيبة، وابن المنذر، وابن أبي حاتم.أخرجه ابن جرير ١٥/٥٠٩.أخرجه عبد الرزاق ٢/٦، ومن طريقه ابن جرير ١٥/ ٥٠٩ مختصرًا.أخرجه ابن جرير ١٥/٥٠٩.تفسير مقاتل بن سليمان ٢/٦٢٥.أخرجه ابن جرير ١٥/٥٠٧.أخرجه ابن جرير ١٥/٥١٠. وعزاه السيوطي إلى ابن أبي حاتم.تفسير يحيى بن سلام١/٢٢١.
  19,25,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَهُزِّیۤ إِلَیۡكِ بِجِذۡعِ ٱلنَّخۡلَةِ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٦٤٧٦<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق عيسى بن ميمون- <span class="qpc-hafs">﴿وهزي إليك بجذع النخلة﴾</span>، قال: النخلة{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٤٧٧<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق عيسى بن ميمون- <span class="qpc-hafs">﴿وهزي إليك بجذع النخلة﴾</span>، قال: كانت عجوةً{2}. (١٠/٥٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٤٧٨<span class="dash">-</span></span> عن <span class="name-2">وهب بن مُنَبِّه</span> -من طريق عبد الصمد بن معقل- في قوله: <span class="qpc-hafs">﴿وهزي إليك بجذع النخلة﴾</span>، قال: فكان الرُّطَب يتساقط عليها، وذلك في الشتاء{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٤٧٩<span class="dash">-</span></span> عن عبد المؤمن، قال: سمعتُ <span class="name-2">أبا نهيك [عثمان بن نهيك البصري]</span> يقول: كانت نخلةً يابسةً{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٤٨٠<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- قوله: <span class="qpc-hafs">﴿وهزي إليك بجذع النخلة﴾</span>، قال: كانت عجوةً{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٤٨١<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- <span class="qpc-hafs">﴿وهزي إليك بجذع النخلة﴾</span>، قال: وكان جِذْعًا منها مقطوعًا، فهَزَّتْهُ، فإذا هو نخلة، وأُجْرِي لها في المحراب نهر، فتساقطت النخلة رُطَبًا جَنِيًّا، فقال لها: كلي واشربي وقري عينا{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٤٨٢<span class="dash">-</span></span> عن <span class="name-2">أبي رَوْق</span>، قال: انتهت مريمُ إلى جذعٍ ليس له رأس، فأنبت الله له رأسًا، وأنبت فيه رُطَبًا، وبُسْرًا مُذَنِّبًا{7}، ومَوْزًا، فلمّا هزَّت النخلةُ سَقَط عليها مِن جميع ما فيها{8}. (١٠/٥٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٤٨٣<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿وهزي إليك بجذع النخلة﴾</span>، قال: حَرِّكيها{9}. (١٠/٥٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٤٨٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: وقال جبريل ﵇ لها: <span class="qpc-hafs">﴿وهزى إليك﴾</span> يعني: وحَرِّكي إليك <span class="qpc-hafs">﴿بجذع النخلة﴾</span> ...، وكانت شجرةً يابسة، فاخْضَرَّت وهي تنظُر، ثم أجرى الله ﷿ لها نهرا مِن الأُرْدُنِّ حتى جاءها، فكان بينهما وبين جبريل ﵇، وهذا كلام جبريل لها، وإنما جعل الله ﷿ ذلك لِتؤمن بأمر عيسى ﷺ، ولا تَعْجَب منه{10}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٤٨٥<span class="dash">-</span></span> قال <span class="name-3">يحيى ين سلّام</span>: كان جذع النخلة يابسًا{11}<span class=comment-ref>٤١٥٥</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٤١٥٥</span> اختُلِف في الجذع؛ <b>فقال قوم</b>: كانت نخلة مُطَعَّمة رُطَبًا. و<b>قال آخرون</b>: كانت يابسة.</p><p>و<span class="comment-type-3">رجّح</span> <u>ابنُ جرير</u> (١٥/٥١٢) <span class="mustanad">مستندًا لأقوال السلف</span> القول الثاني الذي قاله ابن عباس من طريق العوفي، وأبو نهيك، ووهب بن منبه، والسدي، وقال: «ذُكِر أن الجذع كان جذعًا يابسًا، فأمرها أن تهزّه، وذلك في أيام الشتاء».</p><p>و<span class="comment-type-3">رجَّح</span> مثلَه <u>ابنُ عطية</u> (٦/٢٣) <span class="mustanad">مستندًا إلى ظاهر الآية</span>، فقال: «والظاهر من الآية: أنّ عيسى هو المُكَلِّم لها، وأنّ الجِذع كان يابسًا؛ وعلى هذا تكون آيةً تُسَلِّيها، وتسكن إليها».</p><p>وبمثله <span class="comment-type-4">قال</span> <u>ابنُ كثير</u> (٩/٢٣٥-٢٣٦)، وذكر أنها كانت شجرة في غير إبّان ثمرها؛ ولذا امْتَنَّ الله عليها بذلك بأن جعل لها طعامًا وشرابًا. ونسبه لوهب.</div></p><p><h3><span class="qpc-hafs">﴿تُسَـٰقِطۡ عَلَیۡكِ رُطَبࣰا جَنِیࣰّا ۝٢٥﴾</span> - قراءات</h3></p><p><div></p><p><p><span class="item-no">٤٦٤٨٦<span class="dash">-</span></span> عن <span class="name-1">البراء بن عازب</span> -من طريق أبي إسحاق- أنّه قرأ: ‹يَسّاقَطْ عَلَيْكِ› بالياء{12}. (١٠/٥٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٤٨٧<span class="dash">-</span></span> عن <span class="name-2">مسروق بن الأجدع</span> أنّه قرأ: ‹تَساقَطْ عَلَيْكِ رُطَبًا جَنِيًّا› بالتاء{13}. (١٠/٥٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٤٨٨<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> أنّه قرأ: ‹يَسّاقَطْ عَلَيْكِ› بالياء، يعني: الجِذع{8}. (١٠/٥٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٤٨٩<span class="dash">-</span></span> عن [<span class="name-2">عثمان بن نهيك البصري</span>] أنه قرأ: (تُسْقِطْ عَلَيْكِ رُطَبًا){15}. (١٠/٥٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٤٩٠<span class="dash">-</span></span> عن <span class="name-2">طلحة اليامي</span> أنه قرأ: ‹تَساقَطْ عَلَيْكِ رُطَبًا› مُثَقَّلة{16}. (١٠/٥٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٤٩١<span class="dash">-</span></span> عن <span class="name-2">عاصم بن أبي النجود</span> أنّه قرأ:‹تَسّاقَطْ› مُثَقَّلة بالتاء{13}. (١٠/٥٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٤٩٢<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: ومَن قرأها: <span class="qpc-hafs">﴿تُساقِطْ﴾</span> يقول: النخلة{18}<span class=comment-ref>٤١٥٦</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٤١٥٦</span> اختلف القراء في قراءة قوله: <span class="qpc-hafs">﴿تساقط﴾</span>. و<span class="comment-type-4">ذكر</span> <u>ابنُ جرير</u> (١٥/٥١٣-٥١٤) من قرأ: ‹تَسّاقَطْ› بالتشديد فهي بمعنى: تتساقط عليك النخلة رطبًا جنيًا، ثم تدغم إحدى التاءين في الأخرى فتشدد. وأن مَن قرأوا ‹تَساقَطْ› وجهوا معنى الكلام إلى مثل ما وجه إليه مُشَدِّدوها. وذكر أن من قرأ: (تُسْقِط) فقد وجَّه معنى الكلام إلى: تسقط النخلة عليك رطبًا جنيًّا.</p><p>و<span class="comment-type-4">ذكر</span> <u>ابنُ عطية</u> (٦/٢٣) أنّ مَن قرأ: <span class="qpc-hafs">﴿تَسّاقَطْ﴾</span> يريد: النخلة. ومن قرأ ‹يَسّاقَطْ› يريد: الجذع.</p><p>و<span class="comment-type-4">بيّن</span> <u>ابنُ جرير</u> (١٥/٥١٤ بتصرف) أنّ القراءات الثلاث الأُول متقاربات المعاني، والقراءة بهنّ صواب؛ <span class="mustanad">لقراءة علماء القراءة بهنّ</span>، فقال: «والصواب من القول في ذلك عندي أن يقال: إن هذه القراءات الثلاث قراءات متقاربات المعاني، قد قرأ بكل واحدة منهن قراءٌ أهل معرفة بالقرآن، فبأي ذلك قرأ القارئ فمصيب الصواب فيه، وذلك أن الجذع إذا تساقط رطبًا وهو ثابت غير مقطوع فقد تساقطت النخلة رطبًا، وإذا تساقطت النخلة رطبًا فقد تساقطت النخلة بأجمعها جذعها وغير جذعها، وذلك أن النخلة ما دامت قائمة على أصلها فإنما هي جذع وجريد وسعف، فإذا قطعت صارت جذعًا، فالجذع الذي أمرت مريم بهزه لم يذكر أحد نعلمه أنه كان جذعًا مقطوعًا غير السدي، وقد زعم أنه عاد بهزها إياه نخلة، فقد صار معناه ومعنى من قال: كان المتساقط عليها رطبًا؛ نخلة؛ واحدًا، فبيِّنةٌ بذلك صحة ما قلنا».</p><p>و<span class="comment-type-4">ذكر</span> <u>ابنُ كثير</u> (٩/٢٣٦) أنّ جميع القراءات متقاربة المعنى.</div></p><p><h3><span class="qpc-hafs">﴿تُسَـٰقِطۡ عَلَیۡكِ رُطَبࣰا جَنِیࣰّا ۝٢٥﴾</span> - تفسير الآية</h3></p><p><div></p><p><p><span class="item-no">٤٦٤٩٣<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، في قوله: <span class="qpc-hafs">﴿رُطَبًا جَنِيًّا﴾</span>، قال: طَرِيًّا{8}. (١٠/٥٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٤٩٤<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، في قوله: <span class="qpc-hafs">﴿تُساقِطْ عَلَيْكِ رُطَبًا جَنِيًّا﴾</span>، قال: بغُباره{20}. (١٠/٥٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٤٩٥<span class="dash">-</span></span> عن <span class="name-3">أبي جناب [يحيى بن أبي حيَّة الكلبي]</span>، مثله{21}. (١٠/٥٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٤٩٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿تُساقِطْ عَلَيْكِ رُطَبًا جَنِيًّا﴾</span>، يعني بالجَنِيِّ: ما ترطب به مِن البُسْر{10}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٤٩٧<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: ‹يساقَطْ عَلَيْكِ› الجذعُ <span class="qpc-hafs">﴿رطبا جنيا﴾</span>، وكان جِذْعُ النخلة يابِسًا ...، <span class="qpc-hafs">﴿تساقط عليك رطبا جنيا﴾</span> حين اجْتُنِي{11}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿تُسَـٰقِطۡ عَلَیۡكِ رُطَبࣰا جَنِیࣰّا ۝٢٥﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٤٦٤٩٨<span class="dash">-</span></span> عن علي، قال: قال رسول الله ﷺ: «<b>... أطْعِموا نساءَكم الوُلَّدَ الرُّطَبَ، فإن لم يكن رُطَب فتمر، فليس مِن الشجرِ شجرةٌ أكرم على الله مِن شجرة نزلت تحتها مريمُ بنت عمران</b>»{24}. (١٠/٦٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٤٩٩<span class="dash">-</span></span> عن سلمة بن قيس، قال: قال رسول الله ﷺ: «<b>أطعِموا نساءَكم في نفاسِهِنَّ التمر؛ فإنّه مَن كان طعامُها في نفاسها التمرَ خرج ولدُها ولدًا حليمًا، فإنّه كان طعام مريم حيث ولدت عيسى، ولو علم الله طعامًا هو خيرٌ لها مِن التمر لأطعمها إياه</b>»{25}. (١٠/٦٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٥٠٠<span class="dash">-</span></span> عن عامر الشعبي، قال: كتب قيصر إلى <span class="name-1">عمر بن الخطاب</span>: إنّ رُسُلي أتتني مِن قِبَلِك، فزَعَمَتْ أنّ قِبَلَكم شجرةً ليست بِخَلِيقَةٍ لِشَيء مِن الخير! تُخْرِج مثلَ آذان الحمير، ثم تَشَقَّق عن مِثل اللؤلؤ الأبيض، ثم تصير مِثْلَ الزُمُرُّد الأخضر، ثم تصير مثل الياقوت الأحمر، ثم تَيْنَعُ وتنضج، فتكون كأطيب فالوذَج أُكِل، ثم تيبس فتكون عِصْمَةً للمقيم، وزادًا للمسافر، فإن تكن رسلي صدَّقتني فلا أرى هذه الشجرة إلا مِن شجر الجنة. فكتب إليه عمر: أن رسلك قد صدَّقَتْك، هذه الشجرة عندنا، هي الشجرة التي أنبتها الله على مريم حين نَفِسَت بعيسى{26}. (١٠/٦١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٥٠١<span class="dash">-</span></span> عن <span class="name-2">الربيع بن خثيم</span>، قال: ليس للنفساء عندي دواءٌ مثل الرُّطبِ، ولا للمريض مثل العسل{27}. (١٠/٦١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٥٠٢<span class="dash">-</span></span> عن <span class="name-2">شقيق [بن سلمة]</span> -من طريق عاصم- قال: لو علِم اللهُ أنّ شيئًا للنفساء خيرٌ مِن الرُّطَب لأمر مريم به{28}. (١٠/٦١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٥٠٣<span class="dash">-</span></span> عن <span class="name-2">عمرو بن ميمون</span> -من طريق حُصين- قال: ليس للنفساء خيرٌ مِن الرُّطَب أو التمر. وقال: إنّ الله قال: <span class="qpc-hafs">﴿وهزي إليك بجذع النخلة تساقط عليك رطبا جنيا﴾</span>{29}. (١٠/٦١)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ١٥/٥١٢.أخرجه ابن جرير ١٥/٥١٢. وعزاه السيوطي إلى ابن أبي شيبة، وابن المنذر، وابن أبي حاتم، وابن الأنباري في المصاحف.أخرجه ابن جرير ١٥/٥١١.أخرجه ابن جرير ١٥/٥١١.أخرجه يحيى بن سلام ١/٢٢١.أخرجه ابن جرير ١٥/٥١١.البُسْر: مرتبة من مراتب التمر قبل أن يصير تمرًا؛ فالتمر أوَّله طَلْعٌ ثم خَلالٌ ثم بَلَحٌ ثم بُسْرٌ ثم رُطَبٌ ثم تمر، والبُسْر المُذَنَّب: الذي قد بدا فيه الإرطابُ من قِبَلِ ذَنَبِه، وذنَبُ البُسْرة وغيرِها من التَّمْرِ مؤَخَّرُها. لسان العرب (بسر) (ذنب).عزاه السيوطي إلى ابن أبي حاتم.أخرجه ابن جرير ١٥/٥١٠-٥١١. وعزاه السيوطي إلى ابن أبي حاتم.تفسير مقاتل بن سليمان ٢/٦٢٥.تفسير يحيى بن سلام ١/٢٢١.أخرجه ابن جرير ١٥/ ٥١٣. وعزاه السيوطي إلى عبد بن حميد.</p><p>‹يَسّاقَطْ› بالياء، وتشديد السين، وفتح القاف قراءة متواترة، قرأ بها أبوبكر عن عاصم بخلاف عنه، ويعقوب، وقرأ حفص عن عاصم: <span class="qpc-hafs">﴿تُساقِطْ﴾</span> بضم التاء، وتخفيف السين، وكسر القاف، وقرأ حمزة: ‹تَساقَطْ› بفتح القاف، وتخفيف السين، وفتح القاف، وقرأ بقية العشرة: ‹تَسّاقَطْ› بفتح التاء، وتشديد السين، وفتح القاف. انظر: النشر ٢/٣١٨، والإتحاف ص٣٧٧.عزاه السيوطي إلى عبد بن حميد.عزاه السيوطي إلى ابن أبي حاتم.أخرجه ابن جرير ١٥/٥١٤، وعزاه السيوطي إلى ابن أبي حاتم.</p><p>وهي قراءة شاذة. انظر: مختصر ابن خالويه ص٨٧.عزاه السيوطي إلى عبد الله بن أحمد في زوائد الزهد.عزاه السيوطي إلى عبد بن حميد.تفسير يحيى بن سلام١/٢٢١.عزاه السيوطي إلى ابن أبي حاتم.أخرجه الخطيب في تالي التلخيص ١/٢٦٣.أخرجه الخطيب في تاريخ بغداد ١٣/٢٨٥. وعزاه السيوطي إلى ابن الأنباري.تفسير مقاتل بن سليمان ٢/٦٢٥.تفسير يحيى بن سلام ١/٢٢١.أخرجه أبو يعلى ١/٣٥٣ (٤٥٥)، وأبو الشيخ في أمثال الحديث ص٣٠٩ (٢٦٣).</p><p>قال ابن حبان في المجروحين ٣/٤٤ (١٠٩٩) ترجمة مسرور بن سعيد التميمي: «يروي عن الأوزاعي المناكير التي لا يجوز الاحتجاج بمَن يرويها». وقال ابن عدي في الكامل ٨/١٨١ (١٩١٠): «وهذا حديث عن الأوزاعي منكر، وعروة بن رويم عن علي ليس بالمُتَّصل، ومسرور بن سعيد غير معروف، لم أسمع بذكره إلا في هذا الحديث». وقال ابن كثير في تفسيره ٥/٢٢٥: «هذا حديث منكر جدًّا، ورواه أبو يعلى عن شيبان به». وقال الهيثمي في المجمع ٥/٣٩ (٨٠٠٥): «رواه أبو يعلى، وفيه مسرور بن سعيد، وهو ضعيف». وقال القاري في الأسرار المرفوعة ص٤٣٩: «هذا لا يصح». وقال الشوكاني في الفوائد المجموعة ص٤٨٩ (٦٠): «رواه أبو نعيم عن علي مرفوعًا، وفي إسناده مسرور بن سعيد التميمي، وهو منكر الحديث، وقال ابن عدي: إنه غير معروف».أخرجه أبو نعيم في الطب النبوي ٢/٧٢٧ (٨٢٦)، وابن عساكر في تاريخه ٧٠/٩٣-٩٤.</p><p>قال ابن الجوزي في الموضوعات ٣/٢٧: «هذا حديث لا يصِحُّ». وقال القاري في الأسرار المرفوعة ص٤٣٩: «هذا لا يصح». وقال الشوكاني في الفوائد المجموعة ص١٨١ (٦٤): «رواه الخطيب عن مسلم بن قيس مرفوعًا، وفي إسناده سليمان النخعي وداود بن سليمان، كذّابان». وقال الألباني في الضعيفة ١/٤٠٧ (٢٣٤): «موضوع».أخرجه ابن عساكر ٤٧/٣٥٣.عزاه السيوطي إلى سعيد بن منصور، وعبد بن حميد، وابن المنذر.أخرجه عبد الرزاق ٢/٧. وعزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ١٥/٥١٢، وعبد الرزاق ٢/٧، وإسحاق البستي في تفسيره ص١٨٦ كلاهما بلفظ: إني لأحسب خير الطعام للنساء التمر. وعزاه السيوطي إلى عبد بن حميد.