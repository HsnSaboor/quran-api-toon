quran[5]{c,v,t}:
13,1," مقدمة السورة ٣٨٥٠٩- عن عبد الله بن عباس -من طريق أبي عمرو بن العلاء، عن مجاهد- قال: سورةُ الرعد نزَلت بمكة{1}. (٨/٣٥٩) ٣٨٥١٠- عن عبد الله بن عباس -من طريق خُصيف، عن مجاهد- قال: نزلت سورةُ الرعد بالمدينة{2}. (٨/٣٥٩) ٣٨٥١١- عن عبد الله بن عباس -من طريق عطاء الخراساني-: مَدَنِيَّة، ونزلت بعد محمد{3}. (ز) ٣٨٥١٢- عن عبد الله بن الزبير، قال: نزل بالمدينة الرعدُ{4}. (٨/٣٥٩) ٣٨٥١٣- عن سعيد بن جبير، قال: سورةُ الرعد مكيةٌ{5}. (٨/٣٥٩) ٣٨٥١٤- عن عكرمة مولى ابن عباس= (ز) ٣٨٥١٥- والحسن البصري -من طريق يزيد النحوي-: مدنية{6}. (ز) ٣٨٥١٦- عن قتادة بن دعامة -من طرق-: مدنية{7}. (٨/٣٥٩) ٣٨٥١٧- عن قتادة بن دعامة، قال: سورةُ الرعد مدنيةٌ، إلا آيةً مكيةً: <q>﴿ولا يزالُ الَّذين كفرُوا تُصيبهُمُ بما صنعُوا قارعةٌ﴾</q> [٣١]{8}. (٨/٣٥٩) ٣٨٥١٨- عن قتادة بن دعامة –من طريق سعيد-: أنّ هذه الآية: <q>﴿ولو أنّ قرآنًا سيرتْ به الجبالُ أو قطعتْ به الأرضُ أو كُلمَ به الموتى﴾</q> [٣١] مكيَّةٌ{9}٣٤٧٣. (٨/٤٥٥) ٣٤٧٣ ذكر ابنُ عطية (٥/١٦٨) قول سعيد بن جبير، وقتادة، ونقل عن قتادة قولًا حكاه عنه المهدوي: أنّ السورة مكية إلا قوله تعالى: <q>﴿ولا يَزالُ الَّذِينَ كَفَرُوا تُصِيبُهُمْ بِما صَنَعُوا قارِعَةٌ أوْ تَحُلُّ قَرِيبًا مِن دارِهِمْ﴾</q> [٣١]، وقوله: <q>﴿ومَن عِنْدَهُ عِلْمُ الكِتابِ﴾</q> [٤٣]، ثم علَّق بقوله: «والظاهر عندي أنّ المدني فيها كثير، وكل ما نزل في شأن عامر بن الطفيل وإربد بن ربيعة فهو مدني». ٣٨٥١٩- عن محمد ابن شهاب الزهري: مدنية، ونزلت بعد محمد{10}. (ز) ٣٨٥٢٠- عن علي بن أبي طلحة: مكية{11}. (ز) ٣٨٥٢١- قال مقاتل بن سليمان: مكية. ويُقال: مدنية. وهي ثلاث وأربعون آيةً كوفية{12}. (ز) <q>﴿الۤمۤرۚ﴾</q> - تفسير ٣٨٥٢٢- عن عبد الله بن عباس -من طريق سعيد بن جبير- في قوله: <q>﴿المر﴾</q>، قال: أنا اللهُ أرى{13}. (٨/٣٦٠) ٣٨٥٢٣- عن عبد الله بن عباس، في قوله: <q>﴿المر﴾</q>، قال: أنا اللهُ أعلم وأرى{14}٣٤٧٤. (ز) ٣٤٧٤ ذكر ابنُ عطية (٥/١٦٨-١٦٩) أنّ مَن قال بأنّ حروف أوائل السور هي مثال لحروف المعجم، قال: الإشارة هنا بـ<q>﴿تلك﴾</q> هي إلى حروف المعجم، ثم وجَّه قولهم بقوله: «ويَصِحُّ على هذا أن يكون <q>﴿الكِتابِ﴾</q> يراد به: القرآن، ويصح أن يراد به: التوراة والإنجيل. و<q>﴿المر﴾</q> على هذا ابتداءٌ، و<q>﴿تِلْكَ﴾</q> ابتداء ثان، و<q>﴿آياتُ﴾</q> خبر الثاني، والجملة خبر الأول ... قوله تعالى: <q>﴿والَّذِي أُنْزِلَ إلَيْكَ مِن رَبِّكَ الحَقُّ﴾</q>: <q>﴿الَّذِي﴾</q> رفع بالابتداء، و<q>﴿الحَقُّ﴾</q> خبره». ثم وجَّه قول ابن عباس بقوله: «وعلى قول ابن عباس في <q>﴿المر﴾</q> تكون <q>﴿تِلْكَ﴾</q> ابتداء، و<q>﴿آياتُ﴾</q> بدلًا منه، ويصح في <q>﴿الكِتابِ﴾</q> التأويلان اللذان تقدَّما ... وعلى قول ابن عباس يكون <q>﴿الذي﴾</q> عطفًا على <q>﴿تلكَ﴾</q>، و<q>﴿الحقُّ﴾</q> خبر <q>﴿تلكَ﴾</q>». ٣٨٥٢٤- عن مجاهد بن جبر -من طريق سفيان-: <q>﴿المر﴾</q> فواتح يفتتحُ بها كلامه{15}. (٨/٣٦٠) ٣٨٥٢٥- عن مطر الورّاق -من طريق الحسين بن واقد- في قوله:<q>﴿المر﴾</q> قال: <q>﴿المر﴾</q> التوراة{16}.(ز) (ز) <q>﴿تِلۡكَ ءَایَـٰتُ ٱلۡكِتَـٰبِۗ﴾</q> - تفسير ٣٨٥٢٦- قال عبد الله بن عباس: أراد بالكتاب: القرآن{17}. (ز) ٣٨٥٢٧- عن مجاهد بن جبر -من طريق سفيان- في قوله: <q>﴿تلك آياتُ الكتابِ﴾</q>، قال: التوراة، والإنجيل{18}. (٨/٣٦٠) ٣٨٥٢٨- عن الحسن [البصري] -من طريق أبي بكر- في هذه الآية: <q>﴿المر تلك آيات الكتاب﴾</q>، قال: التوراة، والزَّبُور{19}. (ز) ٣٨٥٢٩- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿تلك آياتُ الكتابِ﴾</q>، قال: الكتب التي كانت قبل القرآن{20}. (٨/٣٦٠) ٣٨٥٣٠- عن قتادة بن دعامة -من طريق خالد بن قيس- في قوله: <q>﴿المر تلك آيات الكتاب﴾</q>، قال: التوراة، والإنجيل، والزَّبور{16}٣٤٧٥. (ز) ٣٤٧٥ انتَقَد ابنُ كثير (٨/١٠١) قول مجاهد، وقتادة أن الكتاب في قوله تعالى: <q>﴿تِلْكَ آياتُ الكِتابِ﴾</q>: التوراة والإنجيل، فقال: «وفيه نظر، بل هو بعيد». ٣٨٥٣١- عن مَطَر الوَرّاق -من طريق الحسين بن واقد- في قوله: <q>﴿تلك آيات﴾</q>، قال: الزَّبور{16}. (ز) <q>﴿وَٱلَّذِیۤ أُنزِلَ إِلَیۡكَ مِن رَّبِّكَ ٱلۡحَقُّ﴾</q> - نزول الآية ٣٨٥٣٢- قال مقاتل: نزلت في مشركي مكة حين قالوا: إنّ محمدًا يقوله مِن تلقاء نفسه{23}. (ز) <q>﴿وَٱلَّذِیۤ أُنزِلَ إِلَیۡكَ مِن رَّبِّكَ ٱلۡحَقُّ﴾</q> - تفسير الآية ٣٨٥٣٣- عن مجاهد بن جبر -من طريق سفيان- في قوله: <q>﴿والذي أُنزل إليك من ربك الحقُّ﴾</q>، قال: القرآن{24}. (٨/٣٦٠) ٣٨٥٣٤- عن الحسن [البصري] -من طريق أبي بكر- في قوله: <q>﴿والذي أُنزل إليك من ربك الحق﴾</q>، قال: القرآن الحقُّ كله{25}. (ز) ٣٨٥٣٥- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿والذي أنزلَ إليكَ من ربك الحقُّ﴾</q>، أي: هذا القرآنُ{26}٣٤٧٦. (٨/٣٦٠) ٣٤٧٦ وجَّه ابنُ جرير (١٣/٤٠٧) قول مجاهد وقتادة من جهة الإعراب، بأنّ قوله تعالى: <q>﴿والَّذِي أُنْزِلَ إلَيْكَ مِن رَبِّكَ الحَقُّ﴾</q> مرفوع على أنه كلام مبتدأ، فيكون مرفوعًا بـ<q>﴿الحَقُّ﴾</q>، و<q>﴿الحَقُّ﴾</q> مرفوعٌ به. وبنحوه ابنُ كثير (٨/١٠١)، ثم علَّق على هذا الوجْه بقوله: «هذا هو الصحيح المطابق لتفسير مجاهد، وقتادة». وذكر ابنُ جرير وجْهًا آخر لإعراب الآية، وهو «الخفض على العطف به على <q>﴿الكِتابِ﴾</q>، فيكون معنى الكلام حينئذٍ: تلك آيات التوراة والإنجيل والقرآن، ثم يَبْتَدئ <q>﴿الحَقُّ﴾</q>، بمعنى: ذلك الحقُّ، فيكون رفعه بمضمر ٍمن الكلام قد استُغْنِىَ بدلالة الظاهر عليه منه». ٣٨٥٣٦- قال مقاتل بن سليمان: <q>﴿والذي أنزل إليك من ربك الحق﴾</q> لِقول كُفّار مكة: إنّ محمدًا تَقَوَّلَ القرآن مِن تلقاء نفسه{27}. (ز) <q>﴿وَلَـٰكِنَّ أَكۡثَرَ ٱلنَّاسِ لَا یُؤۡمِنُونَ ۝١﴾</q> - تفسير ٣٨٥٣٧- قال مقاتل بن سليمان: <q>﴿ولكن أكثر الناس﴾</q> يعني: أكثر الكفار <q>﴿لا يؤمنون﴾</q> بالقرآن أنّه مِن الله{27}. (ز) ",footnotes:1:أخرجه النحاس في ناسخه ص٣٥٣.أخرجه البيهقي في دلائل النبوة ٧/١٤٣-١٤٤. وعزاه السيوطي إلى أبي الشيخ، وابن مردُويه.أخرجه ابن الضريس في فضائل القرآن ١/٣٣-٣٥.عزاه السيوطي إلى ابن مردُويه.عزاه السيوطي إلى سعيد بن منصور، وابن المنذر.أخرجه البيهقي في دلائل النبوة ٧/١٤٢-١٤٣.أخرجه الحارث المحاسبي في فهم القرآن ص٣٩٥-٣٩٦ من طريق سعيد ومعمر، وأبو بكر بن الأنباري -كما في الإتقان في علوم القرآن ١/٥٧- من طريق همام.عزاه السيوطي إلى ابن المنذر، وأبي الشيخ.أخرجه الحارث المحاسبي في «فهم القرآن» ص٣٩٥، وعزاه السيوطي إلى أبي الشيخ.تنزيل القرآن ص٣٧-٤٢.أخرجه أبو عبيد في فضائله (ت: الخياطي) ٢/٢٠٠.تفسير مقاتل بن سليمان ٢/٣٦٥.أخرجه ابن جرير ١٣/٤٠٥، ومن طريق أبي الضحى أيضًا. وعزاه السيوطي إلى أبي الشيخ.تفسير الثعلبي ٥/٢٦٧، وتفسير البغوي ٤/٢٩١.أخرجه ابن جرير ١٣/٤٠٦.أخرجه ابن أبي حاتم ٧/٢٢١٥.تفسير الثعلبي ٥/٢٦٨.أخرجه ابن جرير ١٣/٤٠٦. وعزاه السيوطي إلى ابن المنذر.أخرجه ابن أبي حاتم ٧/٢٢١٥. وفيه: عن الحسين. وهو تحريف.أخرجه ابن جرير ١٣/٤٠٦. وعزاه السيوطي إلى أبي الشيخ.أخرجه ابن أبي حاتم ٧/٢٢١٥.أخرجه ابن أبي حاتم ٧/٢٢١٥.تفسير الثعلبي ٥/٢٦٨، وتفسير البغوي ٤/٢٩٢.أخرجه ابن جرير ١٣/٤٠٧. وعزاه السيوطي إلى ابن المنذر.أخرجه ابن أبي حاتم ٧/٢٢١٥. وفيه: عن الحسين، وهو تحريف.أخرجه ابن جرير ١٣/٤٠٧، وابن أبي حاتم ٧/٢٢١٥. وعزاه السيوطي إلى أبي الشيخ.تفسير مقاتل بن سليمان ٢/٣٦٦.تفسير مقاتل بن سليمان ٢/٣٦٦.
13,2," <q>﴿ٱللَّهُ ٱلَّذِی رَفَعَ ٱلسَّمَـٰوَ ٰ⁠تِ بِغَیۡرِ عَمَدࣲ تَرَوۡنَهَاۖ ثُمَّ ٱسۡتَوَىٰ عَلَى ٱلۡعَرۡشِۖ وَسَخَّرَ ٱلشَّمۡسَ وَٱلۡقَمَرَۖ كُلࣱّ یَجۡرِی لِأَجَلࣲ مُّسَمࣰّىۚ یُدَبِّرُ ٱلۡأَمۡرَ یُفَصِّلُ ٱلۡـَٔایَـٰتِ لَعَلَّكُم بِلِقَاۤءِ رَبِّكُمۡ تُوقِنُونَ ۝٢﴾</q> - قراءات ٣٨٥٣٨- عن معاذ، قال: في مصحف أُبيِّ بن كعب: (بِغَيْرِ عَمَدٍ تَرَوْنَهُ){1}. (٨/٣٦٢) <q>﴿ٱللَّهُ ٱلَّذِی رَفَعَ ٱلسَّمَـٰوَ ٰ⁠تِ بِغَیۡرِ عَمَدࣲ تَرَوۡنَهَاۖ﴾</q> - تفسير ٣٨٥٣٩- عن عبد الله بن عباس -من طريق عكرمة- في قوله: <q>﴿رفع السماواتِ بغيرِ عمدِ ترونها﴾</q>، قال: وما يُدْرِيك، لعلها بعمدٍ لا ترونها{2}. (٨/٣٦٠) ٣٨٥٤٠- عن عكرمة، قال: قلتُ لابن عباس: إنّ فلانًا يقولُ: إنها على عمدٍ. يعني: السماء، فقال: اقرأها: <q>﴿بغير عَمَدٍ ترونها﴾</q>، أي: لا تَرَوْنها{3}. (٨/٣٦٠) ٣٨٥٤١- عن عبد الله بن عباس -من طريق قتادة- في قوله: <q>﴿بغير عمدٍ ترونها﴾</q>، يقولُ: لها عَمَدٌ، ولكن لا ترونها. يعني: الأعمادَ{4}. (٨/٣٦١) ٣٨٥٤٢- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿بغيرِ عمدٍ ترونها﴾</q>، قال: هي بعمد لا ترونها{5}. (٨/٣٦١) ٣٨٥٤٣- عن عامر الشعبي -من طريق عبد الملك بن أبجر-: أنّ رجلًا ذكر أنّ السماء على عمود على مَنكِبِ{6} مَلَكٍ، فقال له: أكْذَبَك كتابُ الله، قال الله ﷿: <q>﴿الذي رفع السموات بغير عمد ترونها﴾</q>{7}. (ز) ٣٨٥٤٤- عن الحسن البصري= (ز) ٣٨٥٤٥- وقتادة بن دعامة -من طريق مَعْمَر- في قوله: <q>﴿رفع السماواتِ بغيرِ عمدِ﴾</q>، قالا: رفعها بغير عمد ترونها{8}. (ز) ٣٨٥٤٦- عن الحسن البصري= (ز) ٣٨٥٤٧- وقتادة بن دعامة -من طريق سعيد- أنهما كانا يقولان: خلقها بغير عمدٍ، قال لها: قُومي. فقامت{9}. (٨/٣٦١) ٣٨٥٤٨- عن إياس بن معاوية -من طريق حماد بن سلمة- في قوله: <q>﴿رفَعَ السمواتِ بغيرِ عمدٍ ترونها﴾</q>، قال: السماءُ مُقَبَّبَة على الأرض مثلُ القُبَّة{10}٣٤٧٧. (٨/٣٦١) ٣٤٧٧ وجَّه ابنُ كثير (٨/١٠٢) قول إياس بن معاوية بقوله: «يعني: بلا عَمَد». ٣٨٥٤٩- قال مقاتل بن سليمان: <q>﴿الله الذي رفع السموات بغير عمدٍ ترونها﴾</q>، فيها تقديم{11}٣٤٧٨. (ز) ٣٤٧٨ اختُلِف في معنى: <q>﴿رَفَعَ السَّماواتِ بِغَيْرِ عَمَدٍ تَرَوْنَها﴾</q> في هذه الآية على قولين: الأول: الله الذي رفع السماوات بِعَمَدٍ لا ترونها. الثاني: رفع السماوات بغير عَمَد. ورجَّح ابنُ جرير (١٣/٤١١) مستندًا إلى دلالة ظاهر لفظ الآية: «أن يُقال كما قال الله -جلَّ ثناؤه-: <q>﴿اللَّهُ الَّذِي رَفَعَ السَّماواتِ بِغَيْرِ عَمَدٍ تَرَوْنَها﴾</q>، فهي مرفوعةٌ بغير عَمَدٍ نراها، كما قال ربُّنا -جلَّ ثناؤه-، ولا خبر بغير ذلك، ولا حجة يجب التسليم لها بقول سواه». ووجَّه ابنُ عطية (٥/١٦٩) عود الضمير في قوله تعالى: <q>﴿تَرَونَها﴾</q> بأنه على القول الأول يعود على «العَمَد»، وعلى القول الثاني يعود على «السماوات». ورجَّح (٥/١٧٠) مستندًا إلى القرآن، والدلالة العقلية القول الثاني، وهو قول قتادة، وإياس بن معاوية، قائلًا: «والحق ألا عَمَد جملة، إذ العمد تحتاج إلى عمد، ويتسلسل الأمر، فلا بد من وقوفه على القدرة، وهذا هو الظاهر من قوله تعالى: <q>﴿ويُمْسِكُ السَّماءَ أنْ تَقَعَ عَلى الأَرْضِ إلا بِإذْنِهِ﴾</q> [الحج:٦٥]، ونحو هذا من الآيات». وكذا ابنُ كثير (٨/١٠٢)، وزاد فقال: «وهذا هو اللائق بالسياق، ... فعلى هذا يكون قوله: <q>﴿تَرَوْنَها﴾</q> تأكيدًا لنفي ذلك، أي: هي مرفوعة بغير عمد كما ترونها، وهذا هو الأكمل في القدرة». وانتقد ابنُ عطية (٥/١٧٠) القول الأول، سواء فيه قول مَن قال بأنها عَمَد غير مرئية، ومَن قال إن العَمَد جبل قاف المحيط بالأرض، والسماء عليه كالقبة، قائلًا: «وهذا كله ضعيف». <q>﴿ٱللَّهُ ٱلَّذِی رَفَعَ ٱلسَّمَـٰوَ ٰ⁠تِ بِغَیۡرِ عَمَدࣲ تَرَوۡنَهَاۖ﴾</q> - آثار متعلقة بالآية ٣٨٥٥٠- عن عبد الله بن عباس -من طريق عكرمة- قال: السماءُ على أربعة أملاك، كلُّ زاويةٍ موكلٌ بها مَلَكٌ{12}. (٨/٣٦١) ٣٨٥٥١- عن الشعبي، قال: كتب ابن عباس إلى أبي الجَلْد يسأله عن السماء: مِن أيِّ شيء هي؟ فكتب إليه: أن السماء مِن موج مَكْفُوف{13}. (ز) <q>﴿ثُمَّ ٱسۡتَوَىٰ عَلَى ٱلۡعَرۡشِۖ﴾</q> - تفسير ٣٨٥٥٢- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله:<q>﴿استوى﴾</q>، قال: عَلا على العرشِ{14}٣٤٧٩. (٦/٤٢١) ٣٤٧٩ نقل ابنُ عطية (٥/١٧١) عن مجاهد أنّه قال في معنى: <q>﴿اسْتَوى عَلى العَرْشِ﴾</q> أي: علا على العرش، ثم انتقده قائلًا: «والنظر الصحيح يرفع هذه العبارة» أ.هـ. وتعقيب ابن عطية باطل، والحق إثبات الاستواء لله تعالى على ما يليق بجلاله وكماله وعظمته، وهو إجماع السلف من الصحابة والتابعين وتابعيهم. ينظر: الشريعة ٣/١٠٨١-١١٠٧، الإبانة الكبرى ٣/ ١٣٦-١٦٨، شرح أصول اعتقاد أهل السنة والجماعة ٢/٤٢٩-٤٤٧. ٣٨٥٥٣- قال مقاتل بن سليمان: <q>﴿ثم استوى على العرش﴾</q> قبل خلقهما{15}. (ز) <q>﴿وَسَخَّرَ ٱلشَّمۡسَ وَٱلۡقَمَرَۖ كُلࣱّ یَجۡرِی لِأَجَلࣲ مُّسَمࣰّىۚ﴾</q> - تفسير ٣٨٥٥٤- قال عبد الله بن عباس: أراد بالأجل المسمى: درجاتهما، ومنازلهما، ينتهيان إليها لا يُجاوِزانها{16}. (ز) ٣٨٥٥٥- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿كلٌ يجري لأجلٍ مسمىً﴾</q>، قال: الدنيا{17}٣٤٨٠. (٨/٣٦٢) ٣٤٨٠ لم يذكر ابنُ جرير (١٣/٤١٢) في معنى: <q>﴿كُلٌّ يَجْرِي لأَجَلٍ مُسَمًّى﴾</q> سوى قول مجاهد. ٣٨٥٥٦- عن قتادة بن دعامة، في قوله: <q>﴿وسخَّر الشَّمس والقمر كلٌ يجري لأجلٍ مسمى﴾</q>، قال: أجل معلوم، وحدٌّ لا يُقصرُ دونَه، ولا يُتَعَدّى{18}. (٨/٣٦٢) ٣٨٥٥٧- قال مقاتل بن سليمان: <q>﴿وسخر الشمس والقمر كل يجري لأجل مسمى﴾</q>، يعني: إلى يوم القيامة{11}. (ز) <q>﴿وَسَخَّرَ ٱلشَّمۡسَ وَٱلۡقَمَرَۖ كُلࣱّ یَجۡرِی لِأَجَلࣲ مُّسَمࣰّىۚ﴾</q> - آثار متعلقة بالآية ٣٨٥٥٨- عن عكرمة مولى ابن عباس -من طريق الحكم بن أبان- قال: سعة الشمس سعة الأرض كلها وزيادة ثُلُث، وسعة القمر سعة الأرض مرَّة، وإنّ الشمس إذا غربت دخلت تحت العرش، فسبَّحت لله، حتى إذا هي أصبحت اسْتَعْفَتْ ربَّها مِن الخروج، فقال لها الرب: ولِمَ ذاك؟ والربُّ أعلم، فقالت: إنِّي إذا خرجت عُبِدتُ. فقال لها الرب: اخرجي، فليس عليكِ مِن ذلك شيء، حسبهم جهنم أبعثها عليهم مع ثلاثة عشر ألف ملك يقودونها حتى يُدْخِلوهم فيها{20}. (ز) <q>﴿یُدَبِّرُ ٱلۡأَمۡرَ یُفَصِّلُ ٱلۡـَٔایَـٰتِ﴾</q> - تفسير ٣٨٥٥٩- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿يدبر الأمر﴾</q>، قال: يَقْضِيه وحدَه{21}. (٨/٣٦٢) ٣٨٥٦٠- قال مقاتل بن سليمان: <q>﴿يدبر الأمر﴾</q> يقضي القضاء، <q>﴿يفصل الآيات﴾</q> يعني: يُبَيِّن صنعه الذي ذكره في هذه الآية{11}. (ز) <q>﴿لَعَلَّكُم بِلِقَاۤءِ رَبِّكُمۡ تُوقِنُونَ ۝٢﴾</q> - تفسير ٣٨٥٦١- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿لعلَّكم بلقاءِ ربكُم توقنونَ﴾</q>، قال: إنّ الله إنّما أنزل كتابه وبعث رسله لِيُؤْمَن بوعده، وليُسْتَيْقَنَ بلقائه{23}. (٨/٣٦٢) ٣٨٥٦٢- قال مقاتل بن سليمان: <q>﴿لعلكم بلقاء ربكم توقنون﴾</q> بالبعث إذا رأيتم صنعه في الدنيا، فتعتبروا في البعث{11}. (ز) ",footnotes:1:عزاه السيوطي إلى ابن أبي شيبة، وابن المنذر. وهي قراءة شاذة. انظر: البحر المحيط ٥/٣٥٣.أخرجه ابن جرير ١٣/٤١٠. وعزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ١٣/٤٠٩، وابن أبي حاتم ٧/٢٢١٦. وعزاه السيوطي إلى ابن أبي شيبة، وابن المنذر.أخرجه عبد الرزاق ١/٣٣١. وعزاه السيوطي إلى ابن المنذر، وأبي الشيخ.أخرجه ابن جرير ١٣/٤٠٩، وابن أبي حاتم ٧/٢٢١٦.المنكب: ما بين الكتف والعنق. النهاية (نكب).أخرجه سعيد بن منصور في سننه - التفسير ٧/٢١٧-٢١٩ (١٨٧٥).أخرجه عبد الرزاق ١/٣٣١. وأورد عقبه: وقال قتادة: قال ابن عباس: رفع السماء بغير عمد ترونها، يقول: لها عمد ولكن لا ترونها، يعني الأعماد.أخرجه ابن أبي حاتم ٧/٢٢١٦. كما أخرجه ابن جرير ١٣/٤١١ مختصرًا عن قتادة. وعزاه السيوطي إلى عبد الرزاق، وابن جرير، وابن المنذر، وأبي الشيخ.أخرجه ابن جرير ١٣/٤١١. وعزاه السيوطي إليه بلفظ: مُقْبِيَّةٌ.تفسير مقاتل بن سليمان ٢/٣٦٦.أخرجه ابن أبي حاتم ٧/٢٢١٥-٢٢١٦.أخرجه ابن أبي حاتم ٧/٢٢١٦.أخرجه الفريابي -كما في الفتح ١٣/٤٠٥-. وعلَّقه البخاري في صحيحه ٩/١٢٤.تفسير مقاتل بن سليمان ٢/٣٦٦. وتقدمت الآثار في تفسير الآية عند نظيرها من سورة الأعراف [٥٤]، وقد أحال ابن جرير ١٣/٤١٢ إلى ذلك، بينما أعاده ابن أبي حاتم ٧/٢٢١٦.تفسير الثعلبي ٥/٢٦٩، وتفسير البغوي ٤/٢٩٣.أخرجه ابن جرير ١٣/٤١٢. وعزاه السيوطي إلى أبي الشيخ.عزاه السيوطي إلى ابن أبي حاتم.تفسير مقاتل بن سليمان ٢/٣٦٦.أخرجه ابن أبي حاتم ٧/٢٢١٧.أخرجه ابن جرير ١٣/٤١٢، وابن أبي حاتم ٧/٢٢١٧ من طريق ابن أبي نجيح. وعزاه السيوطي إلى أبي الشيخ.تفسير مقاتل بن سليمان ٢/٣٦٦.أخرجه ابن جرير ١٣/٤١٣، وابن أبي حاتم ٧/٢٢١٧. وعزاه السيوطي إلى أبي الشيخ.تفسير مقاتل بن سليمان ٢/٣٦٦.
13,3," <q>﴿وَهُوَ ٱلَّذِی مَدَّ ٱلۡأَرۡضَ﴾</q> - تفسير ٣٨٥٦٣- قال مقاتل بن سليمان: <q>﴿وهو الذي مد الأرض﴾</q>، يعني: بَسَط الأرضَ مِن تحت الكعبة، فبسطها بعد الكعبة بقدر ألفي سنة، فجعل طولها مسيرة خمسمائة عام، وعشرها{1} مسيرة خمسمائة عام{2}. (ز) <q>﴿وَهُوَ ٱلَّذِی مَدَّ ٱلۡأَرۡضَ﴾</q> - آثار متعلقة بالآية ٣٨٥٦٤- عن عبد الله بن عباس، قال: الأرض سبعةُ أجزاءٍ؛ ستةُ أجزاءٍ فيها يأجوجُ ومأجوجُ، وجزءٌ فيه سائرُ الخلق{3}. (٨/٣٦٣) ٣٨٥٦٥- عن عبد الله بن عمرو -من طريق الأوزاعي-: الدنيا مسيرةُ خمسمائة عامٍ؛ أربعمائة عامٍ خرابٌ، ومائةٌ عمرانٌ، في أيدي المسلمين من ذلك مسيرة سنةٍ{4}. (٨/٣٦٣) ٣٨٥٦٦- عن عمرَ بن عبد الله مولى غُفْرة، أنّ كعب الأحبار قال لعمر بن الخطاب: إنّ الله جعل مسيرة ما بين المشرق والمغرب خمسمائة سنة؛ فمائة سنة في المشرق لا يسكنها شيءٌ من الحيوان؛ لا جنٌّ، ولا إنسٌ، ولا دابةٌ، ولا شجرةٌ، ومائة سنةٍ في المغرب بتلك المنزلة، وثلاثمائةٍ فيما بين المشرق والمغرب يسكنُها الحيوانُ{4}. (٨/٣٦٢) ٣٨٥٦٧- عن أبي الجَلْدِ -من طريق قتادة- قال: الأرض أربعةٌ وعشرون ألف فرسخ؛ فالسودانُ اثنا عشر ألفًا، والرومُ ثمانيةٌ، ولفارس ثلاثةٌ، وللعرب ألفٌ{4}. (٨/٣٦٣) ٣٨٥٦٨- عن وهب بن مُنَبِّه -من طريق أبي سنان- قال: ما العمارةُ في الدنيا في الخراب إلا كفسطاط في الصحْراء{7}. (٨/٣٦٣) ٣٨٥٦٩- عن قتادة بن دعامة، قال: ذُكر لي: أنّ الأرض أربعةٌ وعشرون ألف فرسخ؛ اثنا عشر ألفًا منه أرضُ الهند، وثمانيةُ آلافٍ الصينُ، وثلاثةُ آلافٍ المغربُ، وألفٌ العرب{3}. (٨/٣٦٣) ٣٨٥٧٠- عن حسّان بن عطية، قال: سَعةُ الأرض مسيرةُ خمسمائة سنةٍ؛ البحارُ ثلاثمائةٍ، ومائة خرابٌ، ومائةٌ عمرانٌ{9}. (٨/٣٦٣) ٣٨٥٧١- عن مُغيث بن سُمَيٍّ، قال: الأرضُ ثلاثةُ أثلاثٍ: ثلثٌ فيه الناس والشجر، وثلثٌ فيه البحورُ، وثلثٌ هواءٌ{10}. (٨/٣٦٤) ٣٨٥٧٢- عن خالد بن مضرِّب، قال: الأرضُ مسيرةُ خمسمائة سنةٍ؛ ثلاثمائة عُمرانٌ، ومائتان خرابٌ{3}. (٨/٣٦٣) <q>﴿وَجَعَلَ فِیهَا رَوَ ٰ⁠سِیَ﴾</q> - تفسير ٣٨٥٧٣- عن أنس بن مالك، عن النبي ﷺ، قال: «لَمّا خلق اللهُ الأرض جَعَلَت تَمِيد، فجعل الجبال، فألقاها عليها، فاسْتَقَرَّت، فعَجِبَتُ الملائكة مِن خلق الجبال، فقالت: هل مِن خلقِك -يا رب- أشدُّ مِن الجبال؟ فقال: الحديد. فقالت: يا رب، فهل مِن خلقك أشدُّ مِن الحديد؟ قال: نعم، النار. فقالت: فهل مِن خلقك أشدُّ مِن النار؟ قال: نعم، الماء. فقالت: يا رب، فهل مِن خلقك شيء أشدُّ مِن الماء؟ قال: نعم، الريح. قالت: يا رب، فهل مِن خلقك شيءٌ أشَدُّ مِن الريح؟ قال: نعم، ابنُ آدم يتصدق بيمينه يخفيها مِن شماله»{12}. (ز) ٣٨٥٧٤- عن علي بن أبي طالب -من طريق عبد الله بن حبيب- قال: لَمّا خلق الله الأرض قَمَصَتْ{13}، وقالت: أي ربِّ، تجعلُ عَلَيَّ بني آدم يعملون عَلَيَّ الخطايا، ويجعلون عَلَيَّ الخَبَث؟ فأرسل الله فيها من الجبال ما ترون وما لا ترون، فكان إقرارها كاللحم تَرَجْرَجُ{14}. (٨/٣٦٤) ٣٨٥٧٥- عن عبد الله بن عباس، قال: إنّ الله -تبارك وتعالى- حين أراد أن يخلُقَ الخلق خلق الريح، فتسحَّبت الريحُ الماء، فأبْدَتْ عن حَشَفَةٍ{15}، فهي تحت الأرض، ومنها دُحِيت الأرض حيث ما شاء في العرض والطول، فكانت تميدُ، فجعل الجبال الرواسي{16}. (٨/٣٦٤) ٣٨٥٧٦- قال عبد الله بن عباس: كان أبو قُبَيْس أولَ جبلٍ وُضِع على الأرض{17}. (ز) ٣٨٥٧٧- عن عطاء [بن أبي رباح] -من طريق الحارث بن زياد- قال: أوَّلُ جبلٍ وُضِع في الأرض أبو قُبَيسٍ{18}. (٨/٣٦٥) ٣٨٥٧٨- عن قتادة بن دعامة -من طريق سعيد- قوله: <q>﴿رواسي﴾</q>، أي: جبال{19}. (ز) ٣٨٥٧٩- قال مقاتل بن سليمان: <q>﴿وجعل فيها رواسي﴾</q>، يعني: الجبال أثْبَتَ بِهِنَّ الأرضَ؛ لِئَلّا تزول بِمَن عليها{2}. (ز) <q>﴿وَأَنۡهَـٰرࣰاۖ وَمِن كُلِّ ٱلثَّمَرَ ٰ⁠تِ جَعَلَ فِیهَا زَوۡجَیۡنِ ٱثۡنَیۡنِۖ﴾</q> - تفسير ٣٨٥٨٠- عن مجاهد بن جبر، في قوله: <q>﴿جعل فيها زوجين اثنين﴾</q>، قال: ذكرٌ وأنثى مِن كلِّ صنفٍ{16}. (٨/٣٦٥) ٣٨٥٨١- قال مقاتل بن سليمان: <q>﴿ومن كل الثمرات جعل فيها﴾</q> مِن كل <q>﴿زوجين اثنين﴾</q>{2}. (ز) <q>﴿وَأَنۡهَـٰرࣰاۖ وَمِن كُلِّ ٱلثَّمَرَ ٰ⁠تِ جَعَلَ فِیهَا زَوۡجَیۡنِ ٱثۡنَیۡنِۖ﴾</q> - آثار متعلقة بالآية ٣٨٥٨٢- عن عبد الله بن عباس -من طريق عكرمة- قال: ليس في الأرض ماءٌ إلا ما نزل مِن السماء، ولكن عروقٌ في الأرض تُغَيِّرُه، فمَن أراد أن يعود الملحُ عَذْبًا فليُصْعِد الماءَ مِن الأرض{19}. (٨/٣٦٥) <q>﴿یُغۡشِی ٱلَّیۡلَ ٱلنَّهَارَۚ﴾</q> - تفسير ٣٨٥٨٣- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿يُغْشي الليل النَّهار﴾</q>، أي: يُلبِسُ الليلَ النهارَ{24}. (٨/٣٦٥) ٣٨٥٨٤- قال مقاتل بن سليمان: <q>﴿يغشى اليل النهار﴾</q>، يعني: ظُلْمَة الليل، وضوء النهار{2}. (ز) <q>﴿إِنَّ فِی ذَ ٰ⁠لِكَ لَـَٔایَـٰتࣲ لِّقَوۡمࣲ یَتَفَكَّرُونَ ۝٣﴾</q> - تفسير ٣٨٥٨٥- قال مقاتل بن سليمان: <q>﴿إن فى ذلك لآيات﴾</q> يعني: فيما ذُكِر مِن صُنْعِه عِبْرَة <q>﴿لقوم يتفكرون﴾</q> في صُنْعِ الله، فيُوَحِّدونه{2}. (ز) ",footnotes:1:كذا في المطبوع.تفسير مقاتل بن سليمان ٢/٣٦٦.عزاه السيوطي إلى ابن أبي حاتم.أخرجه ابن أبي حاتم ٧/٢٢١٨.أخرجه ابن أبي حاتم ٧/٢٢١٨.أخرجه ابن أبي حاتم ٧/٢٢١٨.أخرجه ابن أبي حاتم ٧/٢٢١٨، وأبو نعيم في الحلية ٤/٧٠.عزاه السيوطي إلى ابن أبي حاتم.عزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.عزاه السيوطي إلى ابن المنذر.عزاه السيوطي إلى ابن أبي حاتم.أخرجه أحمد ١٩/٢٧٦-٢٧٧ (١٢٢٥٣)، والترمذي ٥/٥٥٢-٥٥٣ (٣٦٦٤)، وابن أبي حاتم ٧/٢٢١٨ (١٢١٠٥)، ٩/٢٩٠٨-٢٩٠٩ (١٦٥١٢)، من طريق العوام بن حوشب، عن سليمان بن أبي سليمان، عن أنس به. في إسناده سليمان بن أبي سليمان، وهو مجهول، لذا فقد قال الترمذي: «هذا حديث غريب، لا نعرفه مرفوعًا إلا من هذا الوجه».قمصت: نفرت وأعرضت. لسان العرب (قمص).أخرجه ابن جرير ٢٤/٩٦.الحَشفة: صخرة رِخْوة في سَهل من الأرض ... ويقال للجزيرة في البحر لا يعلوها الماء: حَشَفَةٌ، وجمعها حِشافٌ إذا كانت صغيرة مستديرة. لسان العرب (حشف).عزاه السيوطي إلى أبي الشيخ.تفسير الثعلبي ٥/٢٦٩، وتفسير البغوي ٤/٢٩٣.أخرجه ابن أبى شيبة ١٤/٩١، وابن أبي حاتم ٧/٢٢١٨ من طريق طلحة بن عمرو.أخرجه ابن أبي حاتم ٧/٢٢١٩.تفسير مقاتل بن سليمان ٢/٣٦٦.عزاه السيوطي إلى أبي الشيخ.تفسير مقاتل بن سليمان ٢/٣٦٦.أخرجه ابن أبي حاتم ٧/٢٢١٩.أخرجه ابن جرير ١٣/٤١٥، وابن أبي حاتم ٧/٢٢١٩. وعزاه السيوطي إلى أبي الشيخ.تفسير مقاتل بن سليمان ٢/٣٦٦.تفسير مقاتل بن سليمان ٢/٣٦٦.
13,4," <q>﴿وَفِی ٱلۡأَرۡضِ قِطَعࣱ مُّتَجَـٰوِرَ ٰ⁠تࣱ﴾</q> - تفسير ٣٨٥٨٦- عن عبد الله بن عباس -من طريق عكرمة- في قوله: <q>﴿وفي الأرض قطع متجاوراتٌ﴾</q>، قال: يريدُ: الأرض الطيبة العَذِيَة{1} التي تُخرج نباتها بإذن ربِّها، تُجاورها السَّبخة القبيحةُ المالحةُ التي لا تُخْرِجُ، وهما أرضٌ واحدة، وماؤهما شيءٌ ملحٌ وعذبٌ، ففُضِّلت إحداهما على الأخرى في الأُكل{2}. (٨/٣٦٥) ٣٨٥٨٧- عن عبد الله بن عباس -من طريق سعيد بن جبير- في قوله: <q>﴿وفي الأرض قطعٌ متجاوراتٌ﴾</q>، قال: الأرض تُنبِتُ حُلوًا، والأرض تُنبِتُ حامضًا، وهي مُتجاوِراتٌ، تُسقى بماءٍ واحدٍ{3}. (٨/٣٦٦) ٣٨٥٨٨- عن عبد الله بن عباس -من طريق ابن جريج- <q>﴿قطع متجاورات﴾</q> قال: العَذِيَة والسبخة متجاورات جميعًا، تنبت هذه، وهذه إلى جنبها لا تنبت{4}. (ز) ٣٨٥٨٩- عن سعيد بن جبير -من طريق عطاء بن السائب- <q>﴿وفي الأرض قطعٌ متجاوراتٌ﴾</q>، قال: الأرضُ الواحدةُ يكون فيها الخوخ، والكُمَّثْرى، والعِنَبُ الأبيض والأسودُ، وبعضُه أكثرُ حملًا مِن بعضٍ، وبعضه حلوٌ وبعضُه حامضٌ، وبعضه أفضلُ مِن بعض{5}. (٨/٣٦٦) ٣٨٥٩٠- عن مجاهد بن جبر -من طريق ليث- في قوله: <q>﴿وفي الأرض قطع متجاورات﴾</q>، قال: سِباخ، وجَدْوَل{6}. (ز) ٣٨٥٩١- عن مجاهد بن جبر -من طريق ليث- في قوله: <q>﴿وفي الأرض قطعٌ متجاوراتٌ﴾</q>، قال: السَّبخة، والعَذِيَة، والمالحُ، والطيِّبُ{7}. (٨/٣٦٦) ٣٨٥٩٢- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿وفي الأرض قطع متجاورات﴾</q>، قال: طيِّبُها، وعَذِيُها، وخبيثُها السِّباخُ{8}. (٨/٣٦٧) ٣٨٥٩٣- عن الضحاك بن مزاحم -من طريق عبيد بن سليمان- في قوله: <q>﴿وفي الأرض قطع متجاورات﴾</q>، قال: يعني: الأرض السبخة، والأرض العذية، متجاورات بعضها عند بعض{9}. (ز) ٣٨٥٩٤- عن الحسن البصري، <q>﴿وفي الأرض قطعٌ متجاوراتٌ﴾</q>، قال: فارسُ، والأهواز، والكوفة، والبصرة{10}. (٨/٣٦٦) ٣٨٥٩٥- عن أبي عياض -من طريق قتادة- <q>﴿قطع متجاورات﴾</q>، قال: قُرًى مُتواصِلة{11}. (ز) ٣٨٥٩٦- عن قتادة بن دعامة -من طريق معمر- <q>﴿وفي الأرض قطعٌ متجاوراتٌ﴾</q>، قال: قُرًى متجاوراتٌ، قريبٌ بعضُها مِن بعضٍ{12}٣٤٨١. (٨/٣٦٦) ٣٤٨١ ذكر ابنُ عطية (٥/١٧٥) قول ابن عباس من طريق عكرمة، وقتادة، ثم وجَّهه بقوله: «وهذا وجْه من العبرة، كأنه قال: وفي الأرض قطع مختلفات بتخصيص الله لها بمعان فهي تسقى بماءٍ واحد، ولكن تختلف فيما تخرجه». ثم علَّق بقوله: «والذي يظهر من وصفه لها بالتجاور إنما هو: أنّها مِن تربة واحدة ونوع واحد، والعبرة في هذا أبْيَن؛ لأنها مع اتفاقها في التربة والماء تفضل القدرة والإرادة بعض أكلها على بعض، كما قال النبي عليه الصلاة والسلام حين سُئِل عن هذه الآية فقال: «الدَّقَل، والفارسي، والحلو، والحامض»». ٣٨٥٩٧- عن عطاء الخراساني -من طريق يونس بن يزيد- في قوله: <q>﴿قطع متجاورات﴾</q>، قال: يُقال: الأرض العذبة والسَّبِخة متجاورات{13}. (ز) ٣٨٥٩٨- قال مقاتل بن سليمان: <q>﴿وفى الأرض قطع﴾</q> يعني بالقطع: الأرض السبخة، والأرض العذبة، <q>﴿متجاورات﴾</q> يعني: قريب بعضها مِن بعض{14}. (ز) ٣٨٥٩٩- عن [عبد الله] بن شوذب -من طريق ضمرة بن ربيعة- في قوله: <q>﴿وفي الأرض قطع متجاورات﴾</q>، قال: عذية، ومالحة{15}. (ز) <q>﴿وَجَنَّـٰتࣱ مِّنۡ أَعۡنَـٰبࣲ وَزَرۡعࣱ﴾</q> - تفسير ٣٨٦٠٠- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿وجناتٌ من أعنابٍ﴾</q>، قال: جناتٌ وما معها{16}. (٨/٣٦٧) ٣٨٦٠١- قال مقاتل بن سليمان: <q>﴿وجنات من أعناب﴾</q>، يعني: الكَرْم{14}. (ز) <q>﴿وَنَخِیلࣱ صِنۡوَانࣱ وَغَیۡرُ صِنۡوَانࣲ﴾</q> - تفسير ٣٨٦٠٢- عن عبد الله بن عباس -من طريق سعيد بن جبير- <q>﴿صنوانٌ﴾</q> قال: مجتمعُ النخيل في أصلٍ واحدٍ، <q>﴿وغير صنوانٍ﴾</q> قال: النخلُ المُتَفَرِّق{18}. (٨/٣٦٧) ٣٨٦٠٣- عن البراءِ بن عازب، في قوله: <q>﴿صنوانٌ وغير صنوانٍ﴾</q>، قال: الصِّنوانُ: ما كان أصله واحدًا وهو متفرِّقٌ. وغيرُ صنوانٍ: التي تَنبُتُ وحدها. وفي لفظٍ: <q>﴿صنوانٌ﴾</q>: النخلةُ في النخلة ملتصقةٌ. <q>﴿وغيرُ صنوانٍ﴾</q>: النخلُ المتفرِّقُ{19}٣٤٨٢. (٨/٣٦٦) ٣٤٨٢ نقل ابنُ عطية (٥/١٧٤) عن البراء بن عازب ﵄ قوله: «الصِّنوان: المجتمع. وغير صنوان: المتفرق فردًا فردًا». ثم علَّق عليه بقوله: «ومنه قول النبي ﷺ: «العمُّ صِنْوُ الأب»». ٣٨٦٠٤- عن سعيد بن جبير -من طريق عطاء بن السائب- في قوله: <q>﴿صنوانٌ وغير صنوانٍ﴾</q>، قال: مُجْتَمِعٌ، وغيرُ مُجْتَمِع{20}. (٨/٣٦٨) ٣٨٦٠٥- عن الضَّحّاك بن مُزاحِم -من طريق سلمة بن نبيط- <q>﴿صنوان وغير صنوان﴾</q>، قال: الصنوان: المجتمع، أصله واحد. <q>﴿وغير صنوان﴾</q>: المُتَفَرِّق أصلُه{21}. (ز) ٣٨٦٠٦- عن الضحاك بن مزاحم -من طريق جُوَيْبِر- <q>﴿صنوان﴾</q> قال: يقول: إذا كان الخمسُ والسِّتُّ أصلُهُنَّ واحد، وفروعهن شتّى، وطلعهن مختلف، <q>﴿وغير صنوان﴾</q>: النخلة غير المنفردة{11}. (ز) ٣٨٦٠٧- وعن عكرمة مولى ابن عباس= (ز) ٣٨٦٠٨- وعطاء الخراساني، مثل أوله{23}. (ز) ٣٨٦٠٩- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿صنوانٌ﴾</q> قال: النخلتان وأكثرُ في أصلٍ واحدٍ، <q>﴿وغيرُ صنوانٍ﴾</q> وحدَها{24}. (٨/٣٦٧) ٣٨٦١٠- عن مجاهد بن جبر -من طريق القاسم بن أبي بزَّة- <q>﴿صنوانٌ﴾</q>، قال: ثلاثُ نخلاتٍ في أصلٍ واحدٍ، كمثلِ ثلاثةٍ مِن بني أبٍ وأمٍّ يتفاضلون في العمل، كما يتفاضل ثمرُ هذه النخلات الثلاث في أصلٍ واحدٍ{25}. (٨/٣٦٨) ٣٨٦١١- عن الحسن البصري -من طريق أبي بكر بن عبد الله- في الآية، قال: هذا مَثَلٌ ضربه الله ﷿ لقلوب بني آم، كانت الأرضُ في يد الرحمن طينةً واحدةً، فسطَحها وبطَحها، فصارتِ الأرضُ قِطعًا متجاورةً، فينزِلُ عليها الماءُ من السماء، فتُخْرِج هذه زهرتَها وثمرَها وشجرَها، وتُخرج نباتها، وتُحْيِي موتاها، وتُخْرِج هذه سبَخَها ومِلْحها وخَبثَها، وكلتاهما تُسقى بماءٍ واحد، فلو كان الماءُ مالحًا قيل: إنّما اسْتَسْبَخَتْ هذه مِن قِبَل الماء. كذلك الناسُ خُلِقوا مِن آدم، فينزِلُ عليهم من السماء تذكرةٌ؛ فترِقُّ قلوبٌ فتخشع وتخضع، وتقسو قلوبٌ فتلهو وتسهُو وتجفُو. قال الحسنُ: واللهِ، ما جالس القرآن أحد إلا قام مِن عنده بزيادة أو نقصانٍ؛ قال الله تعالى:<q>﴿وننزلُ من القرآنِ ما هُو شفاءٌ ورحمةٌ للمؤمنينَ ولا يزيدُ الظالمينَ إلا خسارًا﴾</q> [الإسراء:٨٢]{26}. (٨/٣٦٨) ٣٨٦١٢- عن قتادة بن دعامة -من طريق معمر- في قوله: <q>﴿صنوانٌ﴾</q>، قال: الصِّنوانُ: النخلةُ التي يكون فيها نخلتان أو ثلاثٌ أصلهن واحدٌ. قال: وحدَّثني رجلٌ أنّه كان بين عمر بن الخطاب وبين العباس قولٌ، فأسرع إليه العباسُ، فجاء عمرُ إلى النبيِّ ﷺ، فقال: يا نبيَّ الله، ألم تر عباسًا فعل بي وفعل، فأردتُ أن أجيَبه، فذكرتُ مكانه منك، فكففتُ عنه. فقال: «يرحمُك الله، إنّ عمَّ الرجل صِنْوُ أبيه»{27}. (٨/٣٦٩) ٣٨٦١٣- عن خُصيف بن عبد الرحمن -من طريق محمد بن سلمة- في قوله:<q>﴿صنوان﴾</q>، قال: الصنوان: ما كان مِن الشجر مُتَشَعِّب{11}. (ز) ٣٨٦١٤- عن عطاء الخراساني -من طريق يونس بن يزيد- في قول الله ﷿: <q>﴿صنوان وغير صنوان﴾</q>، قال: النخلة فرد وجمعًا{13}. (ز) ٣٨٦١٥- قال مقاتل بن سليمان: <q>﴿ونخيل صنوان﴾</q> يعني: النخيل التي رءوسها متفرقة، وأصلها في الأرض واحد، <q>﴿وغير صنوان﴾</q>: وهي النخلة أصلها، وفرعها واحد{14}. (ز) ٣٨٦١٦- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- قال في قوله: <q>﴿ونخيل صنوان وغير صنوان﴾</q>، قال: الصنوان النخلتان أو الثلاث يكُن في أصل واحد، فذلك يَعُدُّه الناس صنوانًا{21}. (ز) <q>﴿یُسۡقَىٰ بِمَاۤءࣲ وَ ٰ⁠حِدࣲ﴾</q> - قراءات، وتفسير الآية ٣٨٦١٧- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: ‹تُسْقى بِمَآءٍ واحِدٍ›{32}، قال: ماء السماء، كمثل صالح بني آدم وخبيثهم، أبوهم واحدٌ، وكذلك النخلةُ، أصلها واحدٌ وطعامُها مختلِفٌ، وهو يشربُ بماءٍ واحدٍ{33}. (٨/٣٦٧) ٣٨٦١٨- عن الضَّحّاك بن مُزاحِم -من طريق أبي إسحاق الكوفي- ‹تُسْقى بِمَآءٍ واحِدٍ›، قال: ماء المطر{34}. (ز) ٣٨٦١٩- قال مقاتل بن سليمان: <q>﴿يسقى﴾</q> هذا كلُّه <q>﴿بماء واحد﴾</q>{14}. (ز) ٣٨٦٢٠- عن [عبد الله] بن شَوْذَب -من طريق ضَمْرَة بن ربيعة- ‹تُسْقى بِمَآءٍ واحِدٍ›، قال: بماء السماء{34}. (ز) <q>﴿وَنُفَضِّلُ بَعۡضَهَا عَلَىٰ بَعۡضࣲ فِی ٱلۡأُكُلِۚ﴾</q> - قراءات ٣٨٦٢١- عن أبي هريرة، عن النبي ﷺ أنّه قرأ: <q>﴿ونُفَضِّلُ بَعْضَها عَلى بَعْضٍ﴾</q> بالنون{37}. (٨/٣٧٠) <q>﴿وَنُفَضِّلُ بَعۡضَهَا عَلَىٰ بَعۡضࣲ فِی ٱلۡأُكُلِۚ﴾</q> - تفسير الآية ٣٨٦٢٢- عن أبي هريرة، عن النبي ﷺ في قوله: <q>﴿ونفضل بعضها على بعض في الأكلِ﴾</q>، قال: الدَّقَلُ{38}، والفارسيُّ{39}، والحُلوُ، والحامضُ{40}. (٨/٣٧٠) ٣٨٦٢٣- عن عبد الله بن عباس -من طريق سعيد بن جبير- في قوله: <q>﴿ونفضلُ بعضها على بعض في الأكلِ﴾</q>، قال: هذا حامضٌ، وهذا حلوٌ، وهذا دَقَلٌ، وهذا فارسيٌّ{41}. (٨/٣٧٠) ٣٨٦٢٤- عن عبد الله بن عباس -من طريق سعيد بن جبير- قال: <q>﴿وفي الأرض قطع متجاورات﴾</q>، قال: حتى بلغ: <q>﴿ونفضل بعضها على بعض في الأكل﴾</q>، قال: العِنَب الأبيض، والأسود، والتين، والخوخ، والقوثياء، والدَّقَلُ في أرض واحدة، وتسقى بماء واحد، حلو وحامض، وأمّا النخل الصنوان: الخمس نخلات يكون أصلها واحدًا{42}. (ز) ٣٨٦٢٥- عن سعيد بن جبير -من طريق عطاء بن السائب- <q>﴿ونفضل بعضها على بعض في الأكل﴾</q>، قال: بَرْنِيٌّ{43} وكذا وكذا، وهذا بعضُه أفضلُ مِن بعض{44}. (ز) ٣٨٦٢٦- عن سعيد بن جبير -من طريق عطاء بن السائب- في قوله: <q>﴿تُسقى بماء واحدٍ ونفضلُ بعضها على بعض في الأكُل﴾</q>، قال: الأرض الواحدة يكون فيها الخوخ، والكُمَّثْرى، والعنب الأبيض، والأسود، وبعضها أكثر حملًا مِن بعض، وبعضه حلو، وبعضه حامض، وبعضه أفضلُ مِن بعض{45}. (٨/٣٦٨) ٣٨٦٢٧- عن مجاهد بن جبر، <q>﴿ونفضل بعضها على بعض في الأكل﴾</q>، قال: هذا حلوٌ، وهذا مرٌّ، وهذا حامضٌ، كذلك بنو آدم؛ أبوهم واحدٌ، ومنهم المؤمن والكافر{10}. (٨/٣٧٠) ٣٨٦٢٨- قال مقاتل بن سليمان: <q>﴿ونفضل بعضها على بعض فى الأُكل﴾</q>، يعني: في الحمل، فبعضها أكبرُ حملًا مِن بعض{14}. (ز) <q>﴿إِنَّ فِی ذَ ٰ⁠لِكَ لَـَٔایَـٰتࣲ لِّقَوۡمࣲ یَعۡقِلُونَ ۝٤﴾</q> - تفسير ٣٨٦٢٩- عن الضحاك بن مُزاحِم -من طريق علي بن الحكم- <q>﴿صنوان وغير صنوان﴾</q>، فيقول: تسقى بماء واحد، بعضُها أفضلُ مِن بعض حملًا، ففي ذلك آية لقوم يعقلون{11}. (ز) ٣٨٦٣٠- قال مقاتل بن سليمان: <q>﴿إن فى ذلك لآيات﴾</q> يعني: ما ذكر من صنعه لعبرة <q>﴿لقوم يعقلون﴾</q> فيُوَحِّدون ربَّهم{14}. (ز) <q>﴿إِنَّ فِی ذَ ٰ⁠لِكَ لَـَٔایَـٰتࣲ لِّقَوۡمࣲ یَعۡقِلُونَ ۝٤﴾</q> - آثار متعلقة بالآية ٣٨٦٣١- عن عطاء، وابن أبي مليكة، أنّ رسول الله ﷺ قال لعمر بن الخطاب: «يا عمرُ، أما علمتَ أنّ عمَّ الرجل صِنْوُ أبيه؟»{50}. (٨/٣٦٩) ٣٨٦٣٢- عن جابر بن عبد الله، قال: سمعتُ رسولَ الله ﷺ يقولُ: «يا عليُّ، الناسُ مِن شجرٍ شتّى، وأنا وأنت -يا علي- من شجرةٍ واحدةٍ». ثم قرأ النبيُّ ﷺ: <q>﴿وجناتٌ من أعنابٍ وزرعٌ ونخيلٌ صنوانٌ وغيرُ صنوانٍ﴾</q>{51}. (٨/٣٦٩) ",footnotes:1:العَذِيَة: الأرض الطيبة التربة البعيدة من المياه والسباخ. لسان العرب (عذا).أخرجه ابن جرير ١٣/٤١٧ من طريق العوفي بنحوه، وابن أبي حاتم ٧/٢٢١٩ واللفظ له. وعزاه السيوطي إلى ابن المنذر، وأبي الشيخ.أخرجه ابن جرير ١٣/٤١٨، وابن أبي حاتم ٧/٢٢١٩ مختصرًا.أخرجه ابن جرير ١٣/٤١٧. كما أخرج أوله من طريق أبي سنان.أخرجه ابن جرير ١٣/٤١٩. وعزاه السيوطي إلى أبي الشيخ.تفسير الثوري ص١٥٠.أخرجه ابن جرير ١٣/٤١٦ واللفظ له، وابن أبي حاتم ٧/٢٢١٩ من طريق ليث بلفظ: ملح وعذوبة. وعزاه السيوطي إلى أبي الشيخ.أخرجه ابن جرير ١٣/٤١٧، وابن أبي حاتم ٧/٢٢٢٠-٢٢٢١. وعزاه السيوطي إلى ابن أبي شيبة، وابن المنذر، وأبي الشيخ.أخرجه ابن جرير ١٣/٤١٨. كما أخرجه من طريق أبي إسحاق الكوفي بلفظ: الأرض السبخة بينها الأرض العذية.عزاه السيوطي إلى أبي الشيخ.أخرجه ابن أبي حاتم ٧/٢٢٢٠.أخرجه ابن جرير ١٣/٤١٨ من طريق معمر وسعيد، وابن أبي حاتم ٧/٢٢٢٠ من طريق سعيد، بدون لفظ: قرى متجاورات. وعزاه السيوطي إلى أبي الشيخ.أخرجه أبو جعفر الرملي في جزئه ص١٠٤ (تفسير عطاء الخراساني).تفسير مقاتل بن سليمان ٢/٣٦٧.أخرجه ابن جرير ١٣/٤١٩.أخرجه ابن جرير ١٣/٤١٧، ٤٢٠، ٤٢٣، ٤٢٨، ٤٢٩، وابن أبي حاتم ٧/٢٢٢٠-٢٢٢١ من طريق ابن أبي نجيح. وعزاه السيوطي إلى ابن أبي شيبة، وابن المنذر، وأبي الشيخ.تفسير مقاتل بن سليمان ٢/٣٦٧.أخرجه ابن جرير ١٣/٤٢٣، وابن أبي حاتم ٧/٢٢٢٠ من طريق الضحاك مختصرًا. وعزاه السيوطي إلى ابن المنذر.أخرجه سعيد بن منصور (١١٥٣ - تفسير)، وابن جرير ١٣/٤٢٢، وابن أبي حاتم ٧/٢٢٢٠-٢٢٢١ من طريق أبي إسحاق مختصرًا. وعزاه السيوطي إلى الفريابيّ، وابن المنذر، وأبي الشيخ، وابن مردويه.أخرجه ابن جرير ١٣/٤١٩، ٤٢٣. وعزاه السيوطي إلى عَبد بن حُمَيد، وابن المنذر.أخرجه ابن جرير ١٣/٤٢٤.أخرجه ابن أبي حاتم ٧/٢٢٢٠.علَّقه ابن أبي حاتم ٧/٢٢٢٠.أخرجه ابن جرير ١٣/٤٢٣، وابن أبي حاتم ٧/٢٢٢٠-٢٢٢١. وعزاه السيوطي إلى ابن أبي شيبة، وابن المنذر، وأبي الشيخ.أخرجه ابن جرير ١٣/٤٢٦. وعزاه السيوطي إلى أبي الشيخ.أخرجه ابن جرير ١٣/٤٢٦.أخرجه ابن سعد في الطبقات الكبرى ٤/١٩، وعبد الرزاق في تفسيره ٢/٢٢٧ (١٣٥٠)، وابن جرير ١٣/٤٢٥.أخرجه ابن أبي حاتم ٧/٢٢٢٠.أخرجه أبو جعفر الرملي في جزئه ص١٠٤ (تفسير عطاء الخراساني).تفسير مقاتل بن سليمان ٢/٣٦٧.أخرجه ابن جرير ١٣/٤٢٤.قرأ ابن كثير ونافع وأبو عمرو وحمزة والكسائي وخلف وأبو جعفر: ‹تُسْقى› بالتاء، وقرأ عاصم وابن عامر ويعقوب: <q>﴿يسقى﴾</q> بالياء. النشر ٢/٢٢٣.أخرجه ابن جرير ١٣/٤٢٨-٤٢٩ ومن طريق ابن أبي نجيح وابن جريج مختصرًا، وابن أبي حاتم ٧/٢٢٢٠-٢٢٢١ من طريق ابن أبي نجيح. وعلَّقه البخاري ٤/١٧٣٣ مختصرًا. وعزاه السيوطي إلى ابن أبي شيبة،، وابن المنذر، وأبي الشيخ.أخرجه ابن جرير ١٣/٤٢٩.تفسير مقاتل بن سليمان ٢/٣٦٧.أخرجه ابن جرير ١٣/٤٢٩.أخرجه الحاكم ٢/٢٦٤ (٢٩٥٠). قال الحاكم: «هذا حديث صحيح على شرط الشيخين، ولم يخرجاه». وهي قراءة العشرة ما عدا حمزة، والكسائي، وخلفا العاشر، فإنهم قرؤوا: ‹يُفَضِّلُ› بالياء. انظر: النشر ٢/٢٩٧، والإتحاف ص٣٣٨.الدقل: رديء التمر ويابسه. النهاية (دقل).الفارسي: نوع من التمر. تحفة الأحوذي ٤/١٢٩، ١٣٠.أخرجه الترمذى ٥/٣٤٩ (٣٣٨١)، وابن جرير ١٣/٤٣١. قال الترمذي: «هذا حديث حسن غريب». وقال ابن أبي حاتم في العلل ٤/٦٨٢-٦٨٣ (١٧٣٣): «حدثنا به سيف بن محمد ابن أخت سفيان، أخو عمار، سيف ضعيف الحديث». وقال ابن القيسراني في تذكرة الحفاظ ص٣٧٣ (٩٥٤): «سيف هذا كذاب خبيث، قاله ابن معين». وقال ابن الجوزي في العلل المتناهية ٢/١٦٩ (١٠٩٢): «هذا حديث لا يصِحُّ عن رسول الله ﷺ، وسيف متفق على كذبه. قال أحمد بن حنبل: كان يضع الحديث».أخرجه ابن جرير ١٣/٤٣٠، وابن أبي حاتم ٧/٢٢٢١.أخرجه عبد الله بن وهب في الجامع ١/٤٣-٤٤ (٩٠).البرني: ضرب من التمر أصفر مدور، وهو أجود التمر. لسان العرب (برن).أخرجه ابن جرير ١٣/٤٣٠. وأخرج سفيان الثوري ص١٥٠ نحوه، ولفظه: فارسي ودقل وألوان.أخرجه ابن جرير ١٣/٤٣٠. وعزاه السيوطي إليه وإلى عبد بن حُمَيد، وابن المنذر بلفظ: العنبُ الأبيض والأسود والأحمر، والتين الأبيض والأسود، والنخل الأحمر والأصفر.عزاه السيوطي إلى أبي الشيخ.تفسير مقاتل بن سليمان ٢/٣٦٧.أخرجه ابن أبي حاتم ٧/٢٢٢٠.تفسير مقاتل بن سليمان ٢/٣٦٧.أخرجه ابن جرير ١٣/٤٢٥-٤٢٦.أخرجه الحاكم ٢/٢٦٣ (٢٩٤٩)، وأورده الثعلبي ٥/٢٧٠. قال الحاكم: «هذا حديث صحيح الإسناد، ولم يخرجاه». وتعقبه الذهبي في التلخيص بقوله: «لا والله، هارون هالك». وقال الهيثمي في المجمع ٩/١٠٠ (١٤٥٨٢): «رواه الطبراني في الأوسط، وفيه مَن لم أعرفه، ومَن اختلف فيه».
13,5," <q>﴿وَإِن تَعۡجَبۡ فَعَجَبࣱ قَوۡلُهُمۡ﴾</q> - تفسير ٣٨٦٣٣- عن الحسن البصري -من طريق قتادة- في قوله: <q>﴿وإن تعجب فعجب قولهم﴾</q>، قال: إن تعجبْ -يا محمدُ- مِن تكذيبهم إيّاك فعجبٌ قولهُم{1}. (٨/٣٧١) ٣٨٦٣٤- عن قتادة بن دعامة -من طريق سعيد- قوله: <q>﴿وإن تعجب فعجب﴾</q>: إن عجبتَ -يا محمد- فعجبٌ قولهم: <q>﴿أئذا كنا ترابا أئنا لفي خلق جديد﴾</q>. عجب الرحمن -تبارك وتعالى- مِن تكذيبهم بالبعث بعد الموت{2}. (٨/٣٧١) ٣٨٦٣٥- قال مقاتل بن سليمان: <q>﴿وإن تعجب﴾</q> يا محمد بما أوحينا إليك من القرآن، كقوله في الصافات: <q>﴿بل عجبت ويسخرون﴾</q> [الصافات:١٢]، ثم قال: <q>﴿فعجب قولهم﴾</q> يعني: كفار مكة، يقول لقولهم: عجب، فعجبه مِن قولهم، يعني: ومِن تكذيبهم بالبعث حين قالوا: <q>﴿أءذا كنا ترابًا أءنا لفي خلق جديدٍ﴾</q>{3}. (ز) ٣٨٦٣٦- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في الآية، قال: إن تعجب من تكذيبهم، وهم رأَوا من قدرة الله وأمره، وما ضرَب لهم مِن الأمثال، وأراهم من حياة الموتى والأرض الميتة؛ فتعجَّب من قولهم: <q>﴿أئذا كنّا ترابًا أئنا لفي خلقٍ جديدٍ﴾</q>. أو لا يرون أنّه خلقهم مِن نطفةٍ؟ فالخلقُ مِن نطفةٍ أشدُّ مِن الخلقِ من ترابٍ وعظامٍ{4}. (٨/٣٧١) <q>﴿أَءِذَا كُنَّا تُرَ ٰ⁠بًا أَءِنَّا لَفِی خَلۡقࣲ جَدِیدٍۗ﴾</q> - تفسير ٣٨٦٣٧- عن إسماعيل السُّدِّيّ -من طريق أسباط-: <q>﴿أإذا كنا ترابًا﴾</q> فكانت اللحوم رُفاتًا{5}. (ز) ٣٨٦٣٨- قال مقاتل بن سليمان: <q>﴿أءذا كنا ترابًا أءنا لفي خلق جديدٍ﴾</q> تكذيبًا بالبعث. ثُمَّ نَعَتَهم، فقال: <q>﴿أولئك الذين كفرو بربهم وأولئك الأغلال فى أعناقهم وأولئك أصحاب النار﴾</q>{3}. (ز) <q>﴿أُو۟لَـٰۤىِٕكَ ٱلَّذِینَ كَفَرُوا۟ بِرَبِّهِمۡۖ وَأُو۟لَـٰۤىِٕكَ ٱلۡأَغۡلَـٰلُ فِیۤ أَعۡنَاقِهِمۡۖ﴾</q> - تفسير ٣٨٦٣٩- عن الحسن البصري -من طريق عيينة- قال: إنّ الأغلال لم تجعلْ في أعناق أهل النار لأنّهم أعْجزوا الربَّ، ولكنها جُعِلت في أعناقهم لكي إذا طغى بهم اللهبُ أرْسَبَتْهم في النار{7}٣٤٨٣. (٨/٣٧١) ٣٤٨٣ ذكر ابنُ عطية (٥/١٧٧) في معنى: <q>﴿وأُولَئِكَ الأَغْلالُ فِي أعْناقِهِمْ﴾</q> احتمالين: الأول: «الحقيقة، وأنه أخبر عن كون الأغلال في أعناقهم في الآخرة، فهي كقوله تعالى: <q>﴿إذِ الأَغْلالُ فِي أعْناقِهِمْ والسَّلاسِلُ﴾</q> [غافر:٧١]». والثاني: «أن يكون مجازًا، وأنّه أخبر عن كونهم مغللين عن الإيمان، فهي إذًا تجري مجرى الطبع والختم على القلوب، وهي كقوله تعالى: <q>﴿إنّا جَعَلْنا فِي أعْناقِهِمْ أغْلالًا فَهِيَ إلى الأَذْقانِ فَهُمْ مُقْمَحُونَ﴾</q> [يس:٨]». ثم نقل عن بعض الناس أن: «الأَغْلالُ هنا عبارة عن الأعمال، أي: أعمالهم الفاسدة في أعناقهم كالأغلال». ثم علَّق عليه بقوله: «وتحرير هذا هو في التأويل الثاني الذي ذكرناه». <q>﴿وَأُو۟لَـٰۤىِٕكَ أَصۡحَـٰبُ ٱلنَّارِۖ هُمۡ فِیهَا خَـٰلِدُونَ ۝٥﴾</q> - تفسير ٣٨٦٤٠- عن أبي مالك غزوان الغفاري -من طريق السدي- قوله: <q>﴿أصحاب النار﴾</q> يُعَذَّبون فيها{5}. (ز) ٣٨٦٤١- قال مقاتل بن سليمان: <q>﴿وأولئك أصحاب النار هم فيها خالدون﴾</q>، لا يموتون{3}. (ز) ",footnotes:1:أخرجه ابن أبي حاتم ٧/٢٢٢١. وعزاه السيوطي إلى أبي الشيخ.أخرجه ابن جرير ١٣/٤٣٢، وابن أبي حاتم ٧/٢٢٢٢ من طريق سعيد. وعزاه السيوطي إلى أبي الشيخ.تفسير مقاتل بن سليمان ٢/٣٦٧.أخرجه ابن جرير ١٣/٤٣٢-٤٣٣ وابن أبي حاتم ٧/٢٢٢١ من طريق أصبغ. وعزاه السيوطي إلى أبي الشيخ.أخرجه ابن أبي حاتم ٧/٢٢٢٢.تفسير مقاتل بن سليمان ٢/٣٦٧.أخرجه ابن أبى شيبة ١٣/١٧٠، وابن أبي حاتم ٧/٢٢٢٢. وعزاه السيوطي إلى الخطيب.أخرجه ابن أبي حاتم ٧/٢٢٢٢.تفسير مقاتل بن سليمان ٢/٣٦٧.
