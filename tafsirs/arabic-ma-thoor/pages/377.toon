tafsir[13]{c,v,t}:
27,1," مقدمة السورة ٥٦٧٩٥- عن عبد الله بن عباس -من طريق مجاهد-: مكية{1}. (١١/٣٣٣) ٥٦٧٩٦- عن عبد الله بن عباس، قال: أُنزلت سورة النمل بمكة{2}. (١١/٣٣٣) ٥٦٧٩٧- عن عبد الله بن الزبير، مثله{2}. (١١/٣٣٣) ٥٦٧٩٨- عن عبد الله بن عباس -من طريق عطاء الخراساني-: مكية، ونزلت بعد «طس» الشعراء{4}. (ز) ٥٦٧٩٩- عن عكرمة مولى ابن عباس= (ز) ٥٦٨٠٠- والحسن البصري -من طريق يزيد النحوي-: مكية. وسمَّياها: «طس»{5}. (ز) ٥٦٨٠١- عن قتادة بن دعامة -من طرق-: مكية{6}. (ز) ٥٦٨٠٢- عن محمد ابن شهاب الزهري: مكية، ونزلت بعد الشعراء{7}. (ز) ٥٦٨٠٣- عن علي بن أبي طلحة: مكية{8}. (ز) ٥٦٨٠٤- قال مقاتل بن سليمان: مكية، وهي ثلاث وتسعون آية كوفية{9}. (ز) ٥٦٨٠٥- قال يحيى بن سلّام: مكية كلها{10}. (ز) ٥٦٨٠٦- عن عبد الله بن عباس -من طريق عكرمة- قال: كلُّ سُلطان في القرآن حجة. ونزع الآية التي في سورة «سليمان»: <q>﴿أو ليأتيني بسلطان﴾</q>. قال: وأيُّ سلطان كان للهدهد؟!{11}. (١١/٣٥٠) <q>﴿طسۤۚ تِلۡكَ ءَایَـٰتُ ٱلۡقُرۡءَانِ وَكِتَابࣲ مُّبِینٍ ۝١﴾</q> - تفسير ٥٦٨٠٧- عن عبد الله بن عباس -من طريق علي-: أنّ قوله: <q>﴿طس﴾</q> قَسَم أقسمه الله، هو مِن أسماء الله{12}٤٨٣٧. (ز) ٤٨٣٧ وجَّهَ ابنُ جرير (١٨/٥-٦) المعنى على هذا القول، فقال: «الواجب على هذا القول أن يكون معناه: والسميعِ اللطيفِ، إنّ هذه الآيات التي أنزلتها إليك -يا محمد- لآيات القرآن، وآيات كتاب مبين. يقول: يبين لِمَن تدبره وفكر فيه بفهم أنه من عند الله، أنزله إليك، لم تتخرصه أنت، ولم تتقوله، ولا أحد سواك مِن خلق الله؛ لأنّه لا يقدر أحد من الخلق أن يأتي بمثله، ولو تظاهر عليه الجن والإنس». وبنحوه ابنُ عطية (٦/٥١٥). ثم ذكر ابنُ عطية أنّ القول بأن الحروف المقطعة إشارة إلى نوع حروف المعجم؛ أبين الأقوال. ٥٦٨٠٨- عن عبد الله بن عباس، في قوله <q>﴿طس﴾</q>، قال: هو اسم الله الأعظم{13}. (١١/٣٣٣) ٥٦٨٠٩- عن مجاهد بن جبر: أنّه هِجاء مقطوع{14}. (ز) ٥٦٨١٠- عن محمد بن كعب القرظي -من طريق ابن إسحاق- <q>﴿طسم﴾</q>، قال: الطاء مِن الطَّوْل، والسين مِن القدوس{15}. (ز) ٥٦٨١١- عن قتادة بن دعامة -من طريق معمر- في قوله: <q>﴿طس﴾</q>، قال: هو اسم مِن أسماء القرآن{16}. (١١/٣٣٣) ٥٦٨١٢- قال شعبة: سألت السُّدِّيّ عن قوله ﷿: <q>﴿طس﴾</q>. قال: اسم مِن أسماء الله{17}. (ز) ٥٦٨١٣- عن الحسن البصري -من طريق أبي بكر الهذلي- في قول الله: <q>﴿طسم﴾</q>، قال: فواتِحُ افتتح الله بها كتابَه أو القرآنَ{15}. (ز) ٥٦٨١٤- قال مقاتل بن سليمان: قوله: <q>﴿طس تلك آيات القرآن وكتاب مبين﴾</q> يعني: بيِّنٌ ما فيه مِن أمره ونهيه{19}. (ز) ",footnotes:1:أخرجه أبو جعفر النحاس في الناسخ والمنسوخ ٢/٥٧٤ من طريق أبي عمرو بن العلاء عن مجاهد، والبيهقي في دلائل النبوة ٧/١٤٣-١٤٤ من طريق خصيف عن مجاهد.عزاه السيوطي إلى ابن مردويه.عزاه السيوطي إلى ابن مردويه.أخرجه ابن الضريس في فضائل القرآن ١/٣٣-٣٥.أخرجه البيهقي في دلائل النبوة ٧/١٤٢-١٤٣.أخرجه الحارث المحاسبي في فهم القرآن ص٣٩٥-٣٩٦ من طريق سعيد، وأبو بكر بن الأنباري -كما في الإتقان في علوم القرآن ١/٥٧- من طريق همام.تنزيل القرآن ص٣٧-٤٢.أخرجه أبو عبيد في فضائله (ت: الخياطي) ٢/٢٠٠.تفسير مقاتل ٣/٢٩٥.تفسير يحيى بن سلام ٢/٥٣٢.عزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ١٨/٥، وابن أبي حاتم ٩/٢٨٣٨.أخرجه ابن أبي حاتم ٩/٢٨٣٨، وسقط من هذه المطبوعة الراوي عن ابن عباس.علَّقه ابن أبي حاتم ٩/٢٨٣٨.أخرجه ابن أبي حاتم ٩/٢٨٣٨.أخرجه عبد الرزاق ٢/٧٩، وابن أبي حاتم ٩/٢٨٣٨ من طريق سعيد، وزاد فيه: أقسم به ربك. وعزاه السيوطي إلى عبد بن حميد.أخرجه إسحاق البستي في تفسيره ص١. وعلقه ابن أبي حاتم ٩/٢٨٣٨ بلفظ: هذه حروف مِن الهجاء من الأسماء المقطعة.أخرجه ابن أبي حاتم ٩/٢٨٣٨.تفسير مقاتل بن سليمان ٣/٢٩٦.
27,2," <q>﴿هُدࣰى وَبُشۡرَىٰ لِلۡمُؤۡمِنِینَ ۝٢﴾</q> - تفسير ٥٦٨١٥- عن قتادة بن دعامة -من طريق سعيد بن بشير- يعني: <q>﴿هدى وبشرى للمؤمنين﴾</q>: إي، واللهِ، إنّه لَمبين؛ هُداه، وبركته، ورشده{1}. (ز) ٥٦٨١٦- قال مقاتل بن سليمان: <q>﴿هدى﴾</q> يعني: بيان مِن الضلالة لِمَن عمِل به، <q>﴿وبشرى﴾</q> لِما فيه مِن الثواب <q>﴿للمؤمنين﴾</q> يعني: للمُصَدِّقين بالقرآن بأنّه مِن الله ﷿. ثم نعتهم، فقال سبحانه: <q>﴿الذين يقيمون الصلاة ويؤتون الزكاة هم يوقنون﴾</q>{2}. (ز) ٥٦٨١٧- قال يحيى بن سلّام: قوله ﷿: <q>﴿هدى﴾</q> يهتدون به -بالقرآن- إلى الجنة، <q>﴿وبشرى للمؤمنين﴾</q> بالجنة{3}. (ز) ",footnotes:1:أخرجه ابن أبي حاتم ٩/٢٨٣٩.تفسير مقاتل بن سليمان ٣/٢٩٦.تفسير يحيى بن سلام ٢/٥٣٢.
27,3," <q>﴿ٱلَّذِینَ یُقِیمُونَ ٱلصَّلَوٰةَ وَیُؤۡتُونَ ٱلزَّكَوٰةَ وَهُم بِٱلۡـَٔاخِرَةِ هُمۡ یُوقِنُونَ ۝٣﴾</q> - تفسير ٥٦٨١٨- قال مقاتل بن سليمان: <q>﴿الذين يقيمون الصلاة﴾</q> يعني: يُتِمُّون الصلاة المكتوبة، <q>﴿ويؤتون الزكاة﴾</q> يعني: ويُعطون الزكاة المفروضة، <q>﴿وهم بالآخرة﴾</q> يعني: بالبعث الذي فيه جزاء الأعمال <q>﴿هم يوقنون﴾</q>{1}. (ز) ٥٦٨١٩- عن مقاتل بن حيان -من طريق بُكَيْر بن معروف- قوله: <q>﴿ويؤتون الزكاة﴾</q>: أمَرَهم أن يؤتوا الزكاة، ويدفعوها إلى النبي ﷺ{2}. (ز) ٥٦٨٢٠- قال يحيى بن سلّام: <q>﴿الذين يقيمون الصلاة﴾</q> الصلوات الخمس على وُضوئها، ومواقيتها، وركوعها، وسجودها. قوله ﷿: <q>﴿ويؤتون الزكاة﴾</q> المفروضة، <q>﴿وهم بالآخرة هم يوقنون﴾</q> يُصَدِّقون{3}٤٨٣٨. (ز) ٤٨٣٨ ذكر ابنُ عطية (٦/٥١٥) أن الزَّكاة هنا يحتمل أن تكون غير المفروضة؛ لأن السورة مكية قديمة، ويحتمل أن تكون المفروضة من غير تفسير، ثم ذكر أنه قيل بأن الزَّكاةَ هنا بمعنى: الطهارة مِن النقائص، وملازمة مكارم الأخلاق. ",footnotes:1:تفسير مقاتل بن سليمان ٣/٢٩٦.أخرجه ابن أبي حاتم ٩/٢٨٤٠.تفسير يحيى بن سلام ٢/٥٣٢.
27,4," <q>﴿إِنَّ ٱلَّذِینَ لَا یُؤۡمِنُونَ بِٱلۡـَٔاخِرَةِ زَیَّنَّا لَهُمۡ أَعۡمَـٰلَهُمۡ فَهُمۡ یَعۡمَهُونَ ۝٤﴾</q> - تفسير ٥٦٨٢١- قال مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿يعمهون﴾</q>، قال: فهم في ضلالتهم يَتَرَدَّدون{1}. (ز) ٥٦٨٢٢- قال الحسن البصري: يَتَمادَوْن{2}. (ز) ٥٦٨٢٣- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿إن الذين لا يؤمنون بالآخرة﴾</q>، قال: لا يُقِرُّون بها، ولا يؤمنون بها، <q>﴿فهم يعمهون﴾</q>، قال: في ضلالتهم{3}. (١١/٣٣٣) ٥٦٨٢٤- عن قتادة بن دعامة، قوله ﷿: <q>﴿فهم يعمهون﴾</q>، قال: في ضلالتهم يلعبون{4}. (ز) ٥٦٨٢٥- قال إسماعيل السُّدِّيّ: في ضلالتهم يعمهون؛ يترددون{5}. (ز) ٥٦٨٢٦- قال مقاتل بن سليمان: <q>﴿إن الذين لا يؤمنون بالآخرة﴾</q> يعني: لا يُصَدِّقون بالبعث <q>﴿زينا لهم أعمالهم﴾</q> يعني: ضلالتهم، <q>﴿فهم يعمهون﴾</q> يعني: يَتَرَدَّدون فيها{6}٤٨٣٩. (ز) ٤٨٣٩ قال ابنُ عطية (٦/٥١٥-٥١٦): «قوله: <q>﴿زَيَّنّا لَهُمْ أعْمالَهُمْ﴾</q> يحتمل: أنه تعالى حتم عليهم الكفر، وحبّب إليهم الشرك، وزيَّنه بأن خلقه واخترعه في نفوسهم، ومع ذلك اكتسابهم وحرصهم على كفرهم، وهذا على أن تكون الأعمال المزينة كفرهم وطغيانهم. ويحتمل: أن الأعمال المزينة هي الشريعة التي كان الواجب أن تكون أعمالهم، فأخبر الله تعالى على جهة الذِّكْر لنقصهم أنه بفضله ونعمته زين الدين وبينه، ورسم الأعمال والتوحيد، لكن هؤلاء <q>﴿يَعْمَهُونَ﴾</q> أي: يُعْرِضون». ",footnotes:1:تفسير مجاهد ص٥١٦، وأخرجه إسحاق البستي في تفسيره ص٢ من طريق ابن جريج بلفظ: «ترددوا في الضلالة».علَّقه يحيى بن سلام ٢/٥٣٣.أخرجه ابن أبي حاتم ٩/٢٨٤١-٢٨٤٢. وعزاه السيوطي إلى عبد الرزاق موصولًا مع الأثر المتقدم في قوله تعالى: <q>﴿طس﴾</q>، وليس فيه. وعزاه السيوطي إلى عبد بن حميد.علقه يحيى بن سلام ٢/٥٣٢.علقه يحيى بن سلام ٢/٥٣٣.تفسير مقاتل بن سليمان ٣/٢٩٦.
27,5," <q>﴿أُو۟لَـٰۤىِٕكَ ٱلَّذِینَ لَهُمۡ سُوۤءُ ٱلۡعَذَابِ وَهُمۡ فِی ٱلۡـَٔاخِرَةِ هُمُ ٱلۡأَخۡسَرُونَ ۝٥﴾</q> - تفسير ٥٦٨٢٧- عن أبي خميصة عبيد الله بن قيس، يقول: سمعت علي بن أبي طالب يقول -يعني: في هذه الآية <q>﴿الأخسرون﴾</q>-: أنهم الرهبان الذين حبسوا أنفسهم في السَّواري{1}. (ز) ٥٦٨٢٨- عن سعيد بن جبير -من طريق عطاء- في قول الله: <q>﴿أولئك﴾</q>: يعني: الذين ذَكَر اللهُ في هذه الآية{2}. (ز) ٥٦٨٢٩- قال مقاتل بن سليمان: <q>﴿أولئك الذين لهم سوء﴾</q> يعني: شدة العذاب في الآخرة، <q>﴿وهم في الآخرة هم الأخسرون﴾</q>{3}. (ز) ٥٦٨٣٠- قال يحيى بن سلّام: قال: <q>﴿أولئك الذين لهم سوء العذاب﴾</q> شدة العذاب، <q>﴿وهم في الآخرة هم الأخسرون﴾</q> خسروا أنفسهم أن يغنموها، فصاروا في النار، وخسروا الجنة{4}. (ز) ",footnotes:1:أخرجه ابن أبي حاتم ٩/٢٨٤١. وأخرجه قبلُ في تفسير قوله تعالى: <q>﴿قُلْ هَلْ نُنَبِّئُكُمْ بِالأَخْسَرِينَ أعْمالًا﴾</q> [الكهف:١٠٣]، وهو أشبه.أخرجه ابن أبي حاتم ٩/٢٨٤١.تفسير مقاتل بن سليمان ٣/٢٩٦.تفسير يحيى بن سلام ٢/٥٣٣.
27,6," <q>﴿وَإِنَّكَ لَتُلَقَّى ٱلۡقُرۡءَانَ﴾</q> - تفسير ٥٦٨٣١- تفسير الحسن البصري: <q>﴿وإنك لتلقى القرآن﴾</q> لتقبل القرآن{1}٤٨٤٠. (ز) ٤٨٤٠ علَّق ابنُ عطية (٦/٥١٦) على قول الحسن بقوله: «ولا شك أنه يفيض عليه فضل الله، فيقبله ﷺ». ٥٦٨٣٢- عن قتادة بن دعامة -من طريق شيبان- في قوله: <q>﴿وإنك لتلقى القرآن﴾</q>، يقول: تأخذ القرآن{2}. (١١/٣٣٣) ٥٦٨٣٣- قال إسماعيل السُّدِّيّ: وإنّك لَتُؤْتى القرآن{3}. (ز) ٥٦٨٣٤- عن إسماعيل السُّدِّيّ -من طريق أسباط- قوله: <q>﴿وإنك لتلقى القرآن﴾</q>، يقول: يُلْقى عليك الوحي{4}. (ز) ٥٦٨٣٥- قال مقاتل بن سليمان: <q>﴿وإنك لتلقى﴾</q> يعني: لتؤتى <q>﴿القرآن﴾</q>، كقوله سبحانه: <q>﴿وما يلقاها﴾</q> [فصلت:٣٥]، يعني: وما يُؤْتاها{5}. (ز) <q>﴿مِن لَّدُنۡ حَكِیمٍ عَلِیمٍ ۝٦﴾</q> - تفسير ٥٦٨٣٦- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿مِن لَدُنْ حَكِيمٍ عَلِيمٍ﴾</q>: مِن عند حكيم عليم{6}. (١١/٣٣٣) ٥٦٨٣٧- عن محمد بن جعفر بن الزبير -من طريق محمد بن إسحاق- قوله: <q>﴿حكيم﴾</q>، قال: حكيم في عُذره وحُجَّته إلى عباده{4}. (ز) ٥٦٨٣٨- قال مقاتل بن سليمان: ثم قال: <q>﴿من لدن حكيم﴾</q> في أمره، <q>﴿عليم﴾</q> بأعمال الخَلْق{5}. (ز) ٥٦٨٣٩- قال يحيى بن سلّام: قال: <q>﴿من لدن﴾</q> أي: مِن عند <q>﴿حكيم عليم﴾</q> يعني: نفسه؛ حكيم في أمره، عليم بخلقه{9}. (ز) ",footnotes:1:علقه يحيى بن سلام ٢/٥٣٣.أخرجه ابن أبي حاتم ٩/٢٨٤١-٢٨٤٢. وعلقه يحيى بن سلام ٢/٥٣٣. وعزاه السيوطي إلى عبد الرزاق، وعبد بن حميد.علَّقه يحيى بن سلام ٢/٥٣٣.أخرجه ابن أبي حاتم ٩/٢٨٤٢.تفسير مقاتل بن سليمان ٣/٢٩٦.أخرجه ابن أبي حاتم ٩/٢٨٤٢. وعزاه السيوطي إلى عبد الرزاق، وعبد بن حميد.أخرجه ابن أبي حاتم ٩/٢٨٤٢.تفسير مقاتل بن سليمان ٣/٢٩٦.تفسير يحيى بن سلام ٢/٥٣٣.
27,7," <q>﴿إِذۡ قَالَ مُوسَىٰ لِأَهۡلِهِۦۤ إِنِّیۤ ءَانَسۡتُ نَارࣰا﴾</q> - تفسير ٥٦٨٤٠- عن عبد الله بن عباس -من طريق يزيد بن الأصم- في قوله: <q>﴿إني آنست نارا سآتيكم منها بخبر أو آتيكم بشهاب قبس لعلكم تصطلون﴾</q>، قال: كانوا شاتِين، فلمّا جاءوا النارَ -وكان قد أخطأ الطريق- قال لأهله: <q>﴿امْكُثُوا إنِّي آنَسْتُ نارًا﴾</q> [طه:١٠، القصص:٢٩]{1}. (ز) ٥٦٨٤١- عن قتادة بن دعامة -من طريق سعيد- قوله: <q>﴿إني آنست نارا﴾</q>: إنِّي أحْسَسْتُ نارًا، سار في{2} الله حين سار وهو شابٌّ{3}. (ز) ٥٦٨٤٢- عن جعفر بن أبي المغيرة -من طريق أشعث بن إسحاق- في قوله: <q>﴿إذ قال موسى لأهله إني آنست نارا﴾</q>، قال: تركهم أربعين سنة في المكان الذي نُودِي به، ومضى لأمر الله، حتى قضى ما أُمِر به{4}. (ز) ٥٦٨٤٣- تفسير إسماعيل السُّدِّيّ: <q>﴿إني آنست نارا﴾</q>، يعني: إنِّي رأيتُ نورًا{5}. (ز) ٥٦٨٤٤- قال مقاتل بن سليمان: <q>﴿إذ قال موسى لأهله﴾</q> يعني: امرأته، حين رأى النار: <q>﴿إني آنست نارا﴾</q> يقول: إني رأيت نارًا. وهو نور ربِّ العزة -جلَّ ثناؤه-، رآه ليلةَ الجمعة عن يمين الجبل بالأرض المقدسة{6}. (ز) ٥٦٨٤٥- قال يحيى بن سلّام: وقال في آية أخرى: <q>﴿إذ رأى نارا﴾</q> [طه: ١٠]، رآها نارًا عند نفسه، وإنما كانت نورًا{7}. (ز) <q>﴿سَـَٔاتِیكُم مِّنۡهَا بِخَبَرٍ أَوۡ ءَاتِیكُم بِشِهَابࣲ قَبَسࣲ﴾</q> - تفسير ٥٦٨٤٦- عن عبد الله بن عباس: أنّ نافع بن الأزرق قال له: أخبِرني عن قوله ﷿: <q>﴿بشهاب قبس﴾</q>. قال: شُعْلَة مِن نار يقتبسون منه. قال: وهل تعرف العربُ ذلك؟ قال: نعم، أما سمعت قول طرفة: هَمٌّ عراني فبتُّ أدفعُه دون سُهادي كشعلةِ القبسِ؟{8}. (١١/٣٣٣) ٥٦٨٤٧- قال مقاتل بن سليمان: <q>﴿سآتيكم منها بخبر﴾</q> أين الطريق. وقد كان تَحَيَّر وترك الطريق، ثم قال: فإن لم أجد مَن يخبرني الطريق، <q>﴿أو آتيكم بشهاب قبس﴾</q> يقول: آتيكم بنار قبسة مضيئة{9}. (ز) ٥٦٨٤٨- قال يحيى بن سلّام: <q>﴿سآتيكم منها بخبر﴾</q> الطريق. وكان على غير طريق، وقال في آية أخرى: <q>﴿أو أجد على النار هدى﴾</q> [طه:١٠]، أي: هُداة يهدون إلى الطريق، <q>﴿أو آتيكم بشهاب قبس﴾</q> وقال في آية أخرى: <q>﴿أو جذوة من النار﴾</q> [القصص:٢٩]، وهو أصل الشجرة{7}٤٨٤١. (ز) ٤٨٤١ ذكر ابنُ عطية (٦/٥١٨) أن أصل «الشهاب»: الكوكب المنقض في أثر مسترق السمع. وأن كل مَن يُقال له: شهاب -من المنيرات-؛ فعلى التشبيه. ونقل أنّ الزجاج قال: كل أبيض ذي نور فهو شهاب. وانتقده بقوله: و«كلامه معترَض». ولم يذكر مستندًا. <q>﴿لَّعَلَّكُمۡ تَصۡطَلُونَ ۝٧﴾</q> - تفسير ٥٦٨٤٩- عن عمرو بن ميمون -من طريق أبي إسحاق- قال: <q>﴿لعلكم تصطلون﴾</q>، قال: تجدون البرد{11}. (ز) ٥٦٨٥٠- عن إسماعيل السُّدِّيّ -من طريق أسباط- <q>﴿لعلكم تصطلون﴾</q>، قال: مِن البرد{12}. (ز) ٥٦٨٥١- قال مقاتل بن سليمان: <q>﴿لعلكم تصطلون﴾</q> مِن البرد{9}. (ز) ٥٦٨٥٢- عن محمد بن إسحاق -من طريق عبد الرحمن بن سلمة- <q>﴿آتيكم بشهاب قبس﴾</q>، قال: بقبس تَصْطَلون به{11}. (ز) ٥٦٨٥٣- قال يحيى بن سلّام: <q>﴿لعلكم تصطلون﴾</q> لكي تصطلوا. قال قتادة: وكان شاتِيًا{15}. (ز) ",footnotes:1:أخرجه إسحاق البستي في تفسيره ص٣.كذا في المصدر.أخرجه ابن أبي حاتم ٩/٢٨٤٢. وعلقه يحيى بن سلام ٢/٥٣٣.أخرجه ابن أبي حاتم ٩/٢٨٤٢.علقه يحيى بن سلام ٢/٥٣٣.تفسير مقاتل بن سليمان ٣/٢٩٦.تفسير يحيى بن سلام ٢/٥٣٣.أخرجه الطستي -كما في الإتقان ٢/٧٧-.تفسير مقاتل بن سليمان ٣/٢٩٧.تفسير يحيى بن سلام ٢/٥٣٣.أخرجه ابن أبي حاتم ٩/٢٨٤٣.أخرجه ابن جرير ١٨/٩، وابن أبي حاتم ٩/٢٨٤٣.تفسير مقاتل بن سليمان ٣/٢٩٧.أخرجه ابن أبي حاتم ٩/٢٨٤٣.تفسير يحيى بن سلام ٢/٥٣٤.
27,8," <q>﴿فَلَمَّا جَاۤءَهَا نُودِیَ أَنۢ بُورِكَ مَن فِی ٱلنَّارِ وَمَنۡ حَوۡلَهَا﴾</q> - قراءات ٥٦٨٥٤- عن قتادة، قال: في مصحف أبي بن كعب: (بُورِكَتِ النّارُ ومَن حَوْلَها){1}. (١١/٣٣٥) ٥٦٨٥٥- عن عبد الله بن عباس -من طريق ابن جبير- قال: سمعت أُبيًّا يقرأ: (أن بُورِكَتِ النّارُ ومَن حَوْلَها){2}. (ز) ٥٦٨٥٦- عن عكرمة مولى ابن عباس أنّه كان يقرأ: (أن بُورِكَتِ النّارُ){3}. (١١/٣٣٥) <q>﴿فَلَمَّا جَاۤءَهَا نُودِیَ أَنۢ بُورِكَ﴾</q> - تفسير ٥٦٨٥٧- عن عبد الله بن عباس -من طريق علي- قوله: <q>﴿نودي أن بورك من في النار﴾</q>، يقول: قُدِّس{4}. (١١/٣٣٦) ٥٦٨٥٨- عن سعيد بن جبير= (ز) ٥٦٨٥٩- والحسن البصري، مثله{5}. (ز) ٥٦٨٦٠- قال مقاتل بن سليمان: <q>﴿فلما جاءها﴾</q> يعني: النار، وهو نور ربِّ العِزَّة -تبارك وتعالى-؛ <q>﴿نودي أن بورك من في النار ومن حولها﴾</q>{6}. (ز) ٥٦٨٦١- قال يحيى بن سلّام: قوله ﷿: <q>﴿فلما جاءها﴾</q> جاء إلى النار عند نفسه{7}. (ز) <q>﴿مَن فِی ٱلنَّارِ﴾</q> - تفسير ٥٦٨٦٢- عن عبد الله بن عباس -من طريق العوفي- في قوله: <q>﴿فلما جاءها نودي أن بورك من في النار﴾</q>: يعني -تبارك وتعالى-: نفسه، كان نورُ رب العالمين في الشجرة{8}٤٨٤٢. (١١/٣٣٤) ٤٨٤٢ وجَّه ابنُ عطية (٦/٥١٩) هذا القول الذي قاله ابن عباس من طريق العوفي، وسعيد بن جبير، والحسن، وقتادة من طريق معمر، وعكرمة، وابن سلام، فقال: «فأما قول الحسن وغيره فإنّما يتخرَّج على حذف مضاف، بمعنى: بورك مَن قدرته وسلطانه في النار، والمعنى: في النار على ظنِّك وما حسبت». وذكر أنّ بعض القائلين بهذا القول عبَّروا عنه بعبارات مردودة شنيعة. وما قاله ابن عطية باطل، والحق إثبات ما أثبته الله لنفسه من أسماء وصفات وأفعال على ما يليق بجلاله وعظمته وكماله، وهو إجماع السلف من الصحابة والتابعين وتابعيهم. ينظر: الشريعة ٣/١١٤٧-١١٧٧، والإبانة الكبرى ٣/٩١-١٣١، وشرح أصول اعتقاد أهل السنة والجماعة ٢/٤٥١-٤٨٠. ٥٦٨٦٣- عن عبد الله بن عباس -من طريق سعيد بن جبير- في قوله: <q>﴿نودي أن بورك من في النار﴾</q>، قال: كان الله في النور، ونُودِي مِن النور{9}. (١١/٣٣٤) ٥٦٨٦٤- عن عبد الله بن عباس -من طريق عكرمة- في الآية، قال: كانت تلك النار نورًا، أن بُورِك مَن في النار ومَن حول النار{10}. (١١/٣٣٥) ٥٦٨٦٥- عن عبد الله بن عباس -من طريق مجاهد- <q>﴿أن بورك من في النار﴾</q>، قال: بُورِكت النار{11}. (١١/٣٣٥) ٥٦٨٦٦- عن مجاهد بن جبر -من طريق ابن أبي نجيح-، مثله{12}. (١١/٣٣٥) ٥٦٨٦٧- عن سعيد بن جبير -من طريق عطاء- <q>﴿أن بورك من في النار﴾</q>، قال: الله{10}. (ز) ٥٦٨٦٨- عن سعيد بن جبير -من طريق عطاء بن السائب- <q>﴿نودي أن بورك من في النار ومن حولها﴾</q>، يقول: بُورِكت النارُ، ناداه الله، وهو في النور{14}. (١١/٣٣٤) ٥٦٨٦٩- عن سعيد بن جبير -من طريق ابن جريج- أنّه قال: حِجاب العِزَّة، وحِجاب الملك، وحِجاب السلطان، وحِجاب النار، وهي تلك النار التي نودي منها. قال: وحِجاب النور، وحِجاب الغَمام، وحِجاب الماء{15}. (ز) ٥٦٨٧٠- عن عكرمة مولى ابن عباس -من طريق أبي شيبان- <q>﴿أن بورك من في النار ومن حولها﴾</q>، قال: كان الله في نوره{10}. (ز) ٥٦٨٧١- عن الحسن البصري -من طريق مَعْمَر- في قوله: <q>﴿نودي أن بورك من في النار ومن حولها﴾</q>، قال: هو النور{17}. (ز) ٥٦٨٧٢- عن محمد بن كعب القُرَظِي -من طريق موسى بن عبيدة- في الآية، قال: النار نور الرحمن، والنور هو الله، سبحان الله رب العالمين{18}٤٨٤٣. (١١/٣٣٥) ٤٨٤٣ وجَّهَ ابنُ عطية (٦/٥١٩) هذا القول بقوله: «وأما القول بأنّ <q>﴿مَن في النار﴾</q> للنور؛ فهذا على أن يُعَبَّر عن النور مِن حيث كان أنّه مِن نور الله تعالى. ويحتمل أن يكون مِن الملائكة؛ لأنّ ذلك النور الذي حسبه موسى نارًا لم يخْلُ من ملائكة. <q>﴿ومَن حَوْلَها﴾</q> يكون موسى ﵇ والملائكة المطيفين به». والحق إثبات ما أثبته الله لنفسه من أسماء وصفات وأفعال على ما يليق بجلاله وعظمته وكماله، وهو إجماع السلف من الصحابة والتابعين وتابعيهم. ينظر: الشريعة ٣/١١٤٧-١١٧٧، والإبانة الكبرى ٣/٩١-١٣١، وشرح أصول اعتقاد أهل السنة والجماعة ٢/٤٥١-٤٨٠. ٥٦٨٧٣- عن قتادة بن دعامة -من طريق معمر- <q>﴿بورك من في النار﴾</q>، قال: نور الله بُورِك{17}. (ز) ٥٦٨٧٤- عن قتادة بن دعامة -من طريق سعيد- قال: في مصحف أبي بن كعب: (بُورِكَتِ النّارُ ومَن حَوْلَها)، أمّا النار فيزعمون أنّها نور رب العالمين{20}. (١١/٣٣٥) ٥٦٨٧٥- عن إسماعيل السُّدِّيّ -من طريق سفيان- في قوله: <q>﴿أن بورك من في النار﴾</q>، قال: كان في النار ملائكة{21}. (١١/٣٣٥) ٥٦٨٧٦- عن أبي صخر [الخرّاط] -من طريق مفضل بن فضالة- في قوله: <q>﴿فلما جاءها نودي أن بورك من في النار ومن حولها﴾</q>، قال: إنّ موسى ﷺ كان على شاطئ الوادي يرعى غنمَه، فلمّا رأت الغنمُ النارَ نفرت، فقام موسى، فصاح بها، فاجتمعت، ثم نفرت الثانية، ثم قام، فصاح بها، فاجتمعت، ثم نفرت الثالثة، فلمّا قام أبصر النارَ، فسار إليها، فلمّا أتاها <q>﴿نودي أن بورك من في النار ومن حولها﴾</q>، قال: إنّها لم تكن نارًا، ولكنه كان نور الله ﷿، وهو الذي كان في ذلك النور{21}. (ز) ٥٦٨٧٧- قال يحيى بن سلّام: <q>﴿نودي أن بورك من في النار﴾</q> أي: أنها عند موسى نار، يعني بقوله: <q>﴿بورك من في النار﴾</q>: نفسه، وإنما كان ضوء نور رب العالمين، في تفسير سعيد عن قتادة{7}. (ز) <q>﴿وَمَنۡ حَوۡلَهَا﴾</q> - تفسير ٥٦٨٧٨- عن عبد الله بن عباس -من طريق العوفي- في قوله: <q>﴿ومن حولها﴾</q>، يعني: الملائكة{24}. (١١/٣٣٤) ٥٦٨٧٩- عن سعيد بن جبير= (ز) ٥٦٨٨٠- وعكرمة مولى ابن عباس، مثل ذلك{25}. (ز) ٥٦٨٨١- عن الحسن البصري -من طريق معمر-، مثله{26}. (ز) ٥٦٨٨٢- عن محمد بن كعب القرظي -من طريق موسى بن عبيدة- قال: <q>﴿ومن حولها﴾</q> موسى النبي، والملائكة{27}. (١١/٣٣٥) ٥٦٨٨٣- عن قتادة بن دعامة، في قوله: <q>﴿ومن حولها﴾</q>، قال: الملائكة{28}. (١١/٣٣٥) ٥٦٨٨٤- عن أبي صخر [الخراط] -من طريق مفضل بن فضالة- <q>﴿أن بورك من في النار ومن حولها﴾</q>، قال: كان نورَ الله ﷿، وهو الذي كان في ذلك النور، وإنما كان ذلك النور منه وموسى حولَه{29}. (ز) ٥٦٨٨٥- قال مقاتل بن سليمان: <q>﴿نودي أن بورك من في النار ومن حولها﴾</q> يعني: الملائكة، <q>﴿وسبحان الله رب العالمين﴾</q> في التقديم{6}. (ز) <q>﴿وَسُبۡحَـٰنَ ٱللَّهِ رَبِّ ٱلۡعَـٰلَمِینَ ۝٨﴾</q> - تفسير ٥٦٨٨٦- عن إسماعيل السُّدِّيّ -من طريق أسباط- <q>﴿أن بورك من في النار ومن حولها﴾</q>: فلمّا سمِع موسى النداءَ فزِع، فقال: سبحان الله رب العالمين؛ نودي: يا موسى، إني أنا الله رب العالمين{29}. (ز) <q>﴿وَسُبۡحَـٰنَ ٱللَّهِ رَبِّ ٱلۡعَـٰلَمِینَ ۝٨﴾</q> - آثار متعلقة بالآية ٥٦٨٨٧- عن أبي عبيدة [بن عبد الله بن مسعود]، عن أبي موسى الأشعري، قال: قام فينا رسول الله ﷺ، فقال: «إنّ الله ﷿ لا ينام، ولا ينبغي له أن ينام، يخفض القسط ويرفعه، يرفع إليه عمل الليل قبل عمل النهار، وعمل النهار قبل عمل الليل، حجابه النور -وفي رواية أبي بكر: النار-، لو كشفه لأحْرَقَتْ سُبُحاتِ وجهِه ما انتهى إليه بصرُه مِن خلقه». ثم قرأ أبو عبيدة: <q>﴿أن بورك من في النار ومن حولها وسبحان الله رب العالمين﴾</q>{32}. (١١/٣٣٦) ",footnotes:1:أخرجه ابن أبي حاتم ٩/٢٨٤٦. وعلقه يحيى بن سلام ٢/٥٣٤. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر. وهي قراءة شاذة، تروى أيضًا عن ابن عباس، وعكرمة، ومجاهد. انظر: الجامع لأحكام القرآن ١٦/١٠٤.تفسير البغوي ٦/١٤٥.عزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ١٨/١٠، وابن أبي حاتم ٩/٢٨٤٥.تفسير الثعلبي ٧/١٨٩، وتفسير البغوي ٦/١٤٥.تفسير مقاتل بن سليمان ٣/٢٩٧.تفسير يحيى بن سلام ٢/٥٣٤.أخرجه ابن جرير ١٨/١٠، وابن أبي حاتم ٩/٢٨٤٥. وعزاه السيوطي إلى ابن مردويه.أخرجه ابن أبي حاتم ٩/٢٨٤٥. وعزاه السيوطي إلى ابن جرير، وابن المنذر.أخرجه ابن أبي حاتم ٩/٢٨٤٥.أخرجه ابن جرير ١٨/١١. وعزاه السيوطي إلى الفريابي، وعبد بن حميد، وابن المنذر.تفسير مجاهد ص٥١٦، وأخرجه ابن جرير ١٨/١١، وابن أبي حاتم ٩/٢٨٤٥. وعزاه السيوطي إلى الفريابي، وعبد بن حميد.أخرجه ابن أبي حاتم ٩/٢٨٤٥.عزاه السيوطي إلى ابن أبي شيبة، وابن جرير، وابن المنذر، كما عزاه إلى ابن مردويه عن سعيد عن ابن عباس. وأخرجه ابن أبي حاتم ٩/٢٨٤٦ عن سعيد دون أوله، وكذلك ابن جرير ١٨/١٠، وعنده: ناداه وهو في النار.أخرجه ابن جرير ١٨/١٢، وأبو الشيخ في العظمة ص١١٦. وفي تفسير الثعلبي ٧/١٨٩، وتفسير البغوي ٦/١٤٥: كانت النار بعينها، والنار إحدى حُجُبِ الله تعالى.أخرجه ابن أبي حاتم ٩/٢٨٤٥.أخرجه عبد الرزاق ٢/٧٩، وابن جرير ١٨/١٠.أخرجه ابن جرير ١٨/١١، وابن أبي حاتم ٩/٢٨٤٦ بلفظ: النار نور الرحيم، ضوء مِن نور الله ﷿. وعزاه السيوطي إلى ابن المنذر.أخرجه عبد الرزاق ٢/٧٩، وابن جرير ١٨/١٠.أخرجه ابن أبي حاتم ٩/٢٨٤٦. وعلقه يحيى بن سلام ٢/٥٣٤. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه ابن أبي حاتم ٩/٢٨٤٦.أخرجه ابن أبي حاتم ٩/٢٨٤٦.تفسير يحيى بن سلام ٢/٥٣٤.أخرجه ابن جرير ١٨/١٢، وابن أبي حاتم ٩/٢٨٤٧ من طريق سعيد بن جبير. وعزاه السيوطي إلى ابن مردويه.علقه ابن أبي حاتم ٩/٢٨٤٧.أخرجه عبد الرزاق ٣/٧٩، وابن جرير ١٨/١٣ من طريق ابن جريج. وعلَّقه ابن أبي حاتم ٩/٢٨٤٧.أخرجه ابن جرير ١٨/١١، وابن أبي حاتم ٩/٢٨٤٦. وعزاه السيوطي إلى ابن المنذر.علَّقه يحيى بن سلام ٢/٥٣٤، وابن أبي حاتم ٩/٢٨٤٦. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه ابن أبي حاتم ٩/٢٨٤٧.تفسير مقاتل بن سليمان ٣/٢٩٧.أخرجه ابن أبي حاتم ٩/٢٨٤٧.أخرجه مسلم ١/١٦١ (١٧٩) دون قراءة أبي عبيدة للآية، وابن أبي حاتم ٩/٢٨٤٤، والبيهقي في الأسماء والصفات ١/٤٦٥-٤٦٦ (٣٩٤).
27,9," <q>﴿یَـٰمُوسَىٰۤ إِنَّهُۥۤ أَنَا ٱللَّهُ ٱلۡعَزِیزُ ٱلۡحَكِیمُ ۝٩﴾</q> - تفسير ٥٦٨٨٨- قال مقاتل بن سليمان: ثم قال: <q>﴿يا موسى إنه أنا الله﴾</q> يقول: إنّ النور الذي رأيت أنا <q>﴿العزيز الحكيم﴾</q>{1}. (ز) ٥٦٨٨٩- عن أبي سنان، عن أبي بكر الثقفي، قال: أتى موسى الشجرةَ ليلًا وهي خضراء، والنار تَتَرَدَّد فيها، فذهب يتناول النار، فمالت عنه، فذعر وفزع، فنُودي مِن شاطئ الواد الأيمن -قال: عن يمين الشجرة-: يا موسى. فاستأنس بالصوت، فقال: أين أنت؟ أين أنت؟ قِبَل الصوت، قال: أنا فوقك. قال: ربي؟ قال: نعم{2}. (ز) ",footnotes:1:تفسير مقاتل بن سليمان ٣/٢٩٧.أخرجه ابن أبي حاتم ٩/٢٨٤٧.
27,10," <q>﴿وَأَلۡقِ عَصَاكَۚ فَلَمَّا رَءَاهَا تَهۡتَزُّ كَأَنَّهَا جَاۤنࣱّ﴾</q> - تفسير ٥٦٨٩٠- قال محمد بن السائب الكلبي: لا صغيرة، ولا كبيرة{1}. (ز) ٥٦٨٩١- قال مقاتل بن سليمان: <q>﴿وألق عصاك فلما رآها تهتز﴾</q> يعني: تَحَرَّك، <q>﴿كأنها جان﴾</q> يعني: كأنها كانت حيَّة{2}. (ز) ٥٦٨٩٢- عن عبد الملك ابن جريج -من طريق حجّاج- في قوله: <q>﴿فلما رآها تهتز كأنها جان﴾</q>، قال: حين تَحَوَّلت حيَّةً تسعى{3}. (١١/٣٣٦) ٥٦٨٩٣- قال يحيى بن سلّام: <q>﴿وألق عصاك﴾</q> فألقاها، <q>﴿فلما رآها تهتز كأنها جان﴾</q> كأنها حيَّة. وقال في آية أخرى: <q>﴿فإذا هي حية تسعى﴾</q> [طه:٢٠]{4}٤٨٤٤. (ز) ٤٨٤٤ علَّق ابنُ عطية (٦/٥٢٠) على هذا القول بقوله: «لأنها تخفي أنفسها، أي: تسترها». ثم ذكر أنّ فرقة قالت: إنّ الجانَّ صغار الحيات، وإنّ عصا موسى صارت ثعبانًا، وهو العظيم، وإنها شبهت بـ«الجانّ» في سرعة الاضطراب، لأن الصغار أكثر حركة من الكبار، ثم قال: «وعلى كل قول فإن الله خلق في العصا حياة، وغيَّر أوصافها وأعراضها؛ فصارت حية». <q>﴿وَلَّىٰ مُدۡبِرࣰا﴾</q> - تفسير ٥٦٨٩٤- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿ولى مدبرا﴾</q>، قال: فارًّا{5}. (١١/٣٣٧) ٥٦٨٩٥- قال مقاتل بن سليمان: <q>﴿ولى مدبرا﴾</q> مِن الخوف مِن الحيَّة{2}. (ز) ٥٦٨٩٦- قال يحيى بن سلّام: <q>﴿ولى مدبرا﴾</q> مِن الفَرَقِ{4}. (ز) <q>﴿وَلَمۡ یُعَقِّبۡۚ﴾</q> - تفسير ٥٦٨٩٧- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿ولم يعقب﴾</q>، قال: لم يَرْجِع{8}. (١١/٣٣٦) ٥٦٨٩٨- عن قتادة بن دعامة -من طريق مَعْمَر- في قوله: <q>﴿ولم يعقب﴾</q>، قال: لم يَلْتَفِت{9}. (١١/٣٣٧) ٥٦٨٩٩- عن إسماعيل السُّدِّيّ -من طريق أسباط- <q>﴿ولم يعقب﴾</q>: لم ينتظر{10}. (ز) ٥٦٩٠٠- قال مقاتل بن سليمان: <q>﴿ولم يعقب﴾</q>، يعني: ولم يرجع{2}. (ز) ٥٦٩٠١- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿ولم يعقب﴾</q>، قال: لم يرجع{12}. (ز) <q>﴿یَـٰمُوسَىٰ لَا تَخَفۡ إِنِّی لَا یَخَافُ لَدَیَّ ٱلۡمُرۡسَلُونَ ۝١٠﴾</q> - تفسير ٥٦٩٠٢- تفسير الحسن البصري: <q>﴿لا يخاف لدي المرسلون﴾</q> في الآخرة وفي الدنيا؛ لأنهم أهل الولاية وأهل المحبة{13}. (ز) ٥٦٩٠٣- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿لا يخاف لدي﴾</q>، قال: عندي{14}. (١١/٣٣٧) ٥٦٩٠٤- عن عبد الملك ابن جُرَيْج -من طريق حجاج- قال: قوله: <q>﴿يا موسى لا تخف إني لا يخاف لدي المرسلون﴾</q>، قال: لا يُخيف اللهُ الأنبياءَ إلا بذَنب يُصيبه أحدُهم، فإن أصابه أخافه حتى يأخذه منه{15}. (ز) ٥٦٩٠٥- قال عبد الملك ابن جريج: قال الله سبحانه: يا موسى، إنّما أخفتُك لِقتلك النفس{16}. (ز) ٥٦٩٠٦- قال مقاتل بن سليمان: يقول الله ﷿: <q>﴿يا موسى لا تخف﴾</q> مِن الحيَّة، <q>﴿إني لا يخاف لدي﴾</q> يعني: عندي <q>﴿المرسلون﴾</q>{2}. (ز) ٥٦٩٠٧- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- قال: لَمّا ألقى العصا صارت حيَّةً، فرعب منها وجزع، فقال الله: <q>﴿إني لا يخاف لدي المرسلون﴾</q>. قال: فلم يرعوِ لذلك. قال: فقال الله له: <q>﴿أقبل ولا تخف، إنك من الآمنين﴾</q> [القصص:٣١]. قال: فلم يقِف أيضًا على شيء مِن هذا حتى قال: <q>﴿سنعيدها سيرتها الأولى﴾</q> [طه: ٢١]. قال: فالتَفَتَ، فإذا هي عصا كما كانت، فرجع، فأخذها، ثم قوي بعد ذلك عليها، حتى صار يُرسِلها على فرعون ويأخذها{18}. (ز) ",footnotes:1:تفسير الثعلبي ٧/١٩١.تفسير مقاتل بن سليمان ٣/٢٩٧.أخرجه ابن جرير ١٨/١٤. وعزاه السيوطي إلى ابن المنذر.تفسير يحيى بن سلام ٢/٥٣٤.أخرجه ابن أبي حاتم ٩/٢٨٤٨، ٢٩٧٥. وعلقه يحيى بن سلام ٢/٥٣٤. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.تفسير مقاتل بن سليمان ٣/٢٩٧.تفسير يحيى بن سلام ٢/٥٣٤.أخرجه ابن جرير ١٨/١٥، ٢٠، وإسحاق البستي في تفسيره ص٥ من طريق ابن جريج، وابن أبي حاتم ٩/٢٨٤٨-٢٨٤٩. وعلَّقه يحيى بن سلام ٢/٥٣٥. وعزاه السيوطي إلى الفريابي، وابن أبي شيبة، وعبد بن حميد، وابن المنذر.أخرجه عبد الرزاق ٢/٧٩، وابن جرير ١٨/١٥، وابن أبي حاتم ٩/٢٨٤٨، ٢٩٧٥ من طريق سعيد. وعلقه يحيى بن سلام ٢/٥٣٤. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه ابن أبي حاتم ٩/٢٨٤٨.تفسير مقاتل بن سليمان ٣/٢٩٧.أخرجه ابن جرير ١٨/١٥.علقه يحيى بن سلام ٢/٥٣٥.أخرجه ابن أبي حاتم ٩/٢٨٤٩. وعلقه يحيى بن سلام ٢/٥٣٥. وعزاه السيوطي إلى عبد الرزاق، وعبد بن حميد، وابن جرير، وابن المنذر.أخرجه ابن جرير ١٨/١٦.تفسير الثعلبي ٧/١٩٢.تفسير مقاتل بن سليمان ٣/٢٩٧.أخرجه ابن جرير ١٨/١٥، وابن أبي حاتم ٩/٢٨٤٩ من طريق أصبغ.
27,11," <q>﴿إِلَّا مَن ظَلَمَ ثُمَّ بَدَّلَ حُسۡنَۢا بَعۡدَ سُوۤءࣲ﴾</q> - قراءات ٥٦٩٠٨- عن زيد بن أسلم أنّه قرأ: (ألا مَن ظَلَمَ){1}٤٨٤٥. (١١/٣٣٧) ٤٨٤٥ ذكر ابنُ عطية (٦/٥٢١-٥٢٢) أن هذه القراءة على الاستفتاح. <q>﴿إِلَّا مَن ظَلَمَ ثُمَّ بَدَّلَ حُسۡنَۢا بَعۡدَ سُوۤءࣲ﴾</q> - تفسير الآية ٥٦٩٠٩- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿إلا من ظلم ثم بدل حسنا بعد سوء﴾</q>، قال: ثم تاب مِن بعد ظُلمه وإساءته{2}. (١١/٣٣٦) ٥٦٩١٠- عن مجاهد بن جبر -من طريق ابن جريج-: إلا مَن ظلم، ثم بدَّل بعد إساءة{3}. (ز) ٥٦٩١١- عن الحسن البصري -من طريق أبي بكر- قال: قوله: <q>﴿يا موسى لا تخف إني لا يخاف لدي المرسلون. إلا من ظلم﴾</q>. قال: إنِّي إنما أخفتُك لقتلك النفسَ. قال الحسن: كانت الأنبياء تُذنِب فتُعاقَب، ثم تُذنِب -واللهِ- فتُعاقَب{4}. (ز) ٥٦٩١٢- تفسير الحسن البصري: <q>﴿إلا من ظلم ثم بدل حسنا بعد سوء﴾</q> فإنّه لا يخاف عندي، وكان موسى مِمَّن ظلم ثم بدَّل حسنًا بعد سوء، فغفر الله له، وهو قَتْلُ ذلك القبطي، لم يتعمد قتله، ولكن تعمد وكْزه{5}. (ز) ٥٦٩١٣- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿إلا من ظلم﴾</q> قال: إنّ الله لم يُجِز ظالمًا. ثم عاد الله بعائدته وبرحمته، فقال: <q>﴿ثم بدل حسنا بعد سوء﴾</q> أي: فعمِل عملًا صالحًا بعد عمل سيء عمله؛ <q>﴿فإني غفور رحيم﴾</q>{6}. (١١/٣٣٧) ٥٦٩١٤- عن ميمون، قال: إنّ الله قال لموسى: إنّه لا يخاف لَدَيَّ المرسلون إلا من ظلم، فليس للظالم عندي أمان حتى يتوب{7}. (١١/٣٣٧) ٥٦٩١٥- قال مقاتل بن سليمان: <q>﴿إلا من ظلم﴾</q> نفسَه مِن الرسل فإنّه يخاف، فكان منهم آدم ويونس وسليمان وإخوة يوسف وموسى بقتله النفس ﵈، <q>﴿ثم بدل حسنا بعد سوء﴾</q> يعني: فمن بدَّل إحسانًا بعد إساءته؛ <q>﴿فإني غفور رحيم﴾</q>{8}٤٨٤٦. (ز) ٤٨٤٦ اختُلِف هل الاستثناء متصل أو منقطع؛ فقال قوم: الاستثناء متصل، وهو إخبار عن الأنبياء. وقال آخرون: منقطع، وهو إخبار عن غير الأنبياء، كأنه قال: لكن مَن ظلم مِن الناس ثم تاب فإني غفور رحيم. ونسب ابنُ جرير (١٨/١٨-١٩) القول الثاني لبعض أهل اللغة، ورجح الأول، وانتقد الثاني مستندًا إلى اللغة، فقال: «والصواب مِن القول في قوله: <q>﴿إلا من ظلم ثم بدل﴾</q> عندي غيرُ ما قاله هؤلاء الذين حكينا قولهم مِن أهل العربية، بل هو القول الذي قاله الحسن البصري وابن جريج ومَن قال قولهما، وهو أن قوله: <q>﴿إلا من ظلم﴾</q> استثناء صحيح مِن قوله: <q>﴿لا يخاف لدي المرسلون إلا من ظلم﴾</q> منهم فأتى ذنبًا، فإنه خائف لديه مِن عقوبته. وقد بيَّن الحسن ﵀ معنى قيل الله لموسى ذلك، وهو قوله: قال: إني إنما أخفتك لقتلك النفس. فإن قال قائل: فما وجه قيله إن كان قوله: <q>﴿إلا من ظلم﴾</q> استثناء صحيحًا، وخارجًا مِن عِداد مَن لا يخاف لديه مِن المرسلين؟ وكيف يكون خائفًا مَن كان قد وعد الغفران والرحمة؟ قيل: إن قوله: <q>﴿ثم بدل حسنا بعد سوء﴾</q> كلام آخر بعد الأول، وقد تناهى الخبر عن الرسل من ظلم منهم، ومن لم يظلم عند قوله: <q>﴿إلا من ظلم﴾</q> ثم ابتدأ الخبر عمَّن ظلم مِن الرسل وسائر الناس غيرهم. وقيل: فمن ظلم ثم بدَّل حسنًا بعد سوء فإني له غفور رحيم. فإن قال قائل: فعلامَ تعطف -إن كان الأمر كما قلت- بـ<q>﴿ثم﴾</q> إن لم يكن عطفًا على قوله: <q>﴿ظلم﴾</q>؟ قيل: على متروك استغنى -بدلالة قوله: <q>﴿ثم بدل حسنا بعد سوء﴾</q> عليه- عن إظهاره، إذ كان قد جرى قبل ذلك من الكلام نظيره، وهو: فمن ظلم مِن الخلق. وأما الذين ذكرنا قولهم من أهل العربية فقد قالوا على مذهب العربية، غير أنهم أغفلوا معنى الكلمة، وحملوها على غير وجهها من التأويل، وإنما ينبغي أن يُحمَل الكلام على وجهه مِن التأويل، ويلتمس له على ذلك الوجه للإعراب في الصحة مخرج، لا على إحالة الكلمة عن معناها ووجهها الصحيح من التأويل». وساق ابنُ عطية (٦/٥٢١) القول الأول، ثم علَّق بقوله: «وأجمع العلماء أنّ الأنبياء ﵈ معصومون من الكبائر، ومن الصغائر التي هي رذائل، واختُلِف فيما عدا هذا، فعسى أن يشير الحسن وابن جريج إلى ما عدا ذلك، وفي الآية -على هذا التأويل- حذفٌ اقتضى الإيجاز والفصاحة، ترك نصه، تقديره: فمن ظلم ثم بدل حسنًا بعد سوء». وذكر أنّ فرقة قالت: <q>﴿إلا﴾</q> بمعنى الواو. وانتقده بقوله: «وهذا قول لا وجه له». <q>﴿فَإِنِّی غَفُورࣱ رَّحِیمࣱ ۝١١﴾</q> - تفسير ٥٦٩١٦- عن سعيد بن جبير -من طريق عطاء بن دينار- قوله: <q>﴿غفور﴾</q> لِما كان منه قبل التوبة، <q>﴿رحيم﴾</q> لِمَن تاب{9}. (ز) ",footnotes:1:عزاه السيوطي إلى سعيد بن منصور. وهي قراءة شاذة، تروى أيضًا عن أبي جعفر. انظر: مختصر ابن خالويه ص١١٠، والمحتسب ٢/١٣٦.أخرجه ابن جرير ١٨/٢٠، وابن أبي حاتم ٩/٢٨٤٩. وعزاه السيوطي إلى الفريابي، وابن أبي شيبة، وعبد بن حميد، وابن المنذر.أخرجه إسحاق البستي في تفسيره ص٥.أخرجه ابن جرير ١٨/١٦.علقه يحيى بن سلام ٢/٥٣٥.أخرجه ابن أبي حاتم ٩/٢٨٤٩. وعزاه السيوطي إلى عبد الرزاق، وعبد بن حميد، وابن جرير، وابن المنذر موصولًا مع الأثر السابق.عزاه السيوطي إلى ابن المنذر.تفسير مقاتل بن سليمان ٣/٢٩٧.أخرجه ابن أبي حاتم ٩/٢٨٤٨، وتقدم في تفسير قوله تعالى: <q>﴿أنَّهُ مَن عَمِلَ مِنكُمْ سُوءًا بِجَهالَةٍ ثُمَّ تابَ مِن بَعْدِهِ وأَصْلَحَ فَأَنَّهُ غَفُورٌ رَحِيمٌ﴾</q> [الأنعام:٥٤].
27,12," <q>﴿وَأَدۡخِلۡ یَدَكَ﴾</q> - تفسير ٥٦٩١٧- عن مجاهد بن جبر -من طريق ابن جريج- قال: <q>﴿وأدخل يدك﴾</q> الكفَّ قَط{1}. (ز) ٥٦٩١٨- قال إسماعيل السُّدِّيّ: يعني: يده بعينها{2}. (ز) ٥٦٩١٩- قال مقاتل بن سليمان: <q>﴿وأدخل يدك﴾</q> اليمنى{3}. (ز) ٥٦٩٢٠- عن عبد الملك ابن جُرَيج -من طريق حجاج- <q>﴿يدك﴾</q>: الكف{4}. (ز) <q>﴿فِی جَیۡبِكَ﴾</q> - تفسير ٥٦٩٢١- عن عبد الله بن مسعود -من طريق عمرو بن ميمون- قال: إنّ موسى أتى فرعون حين أتاه في زُرْمانِقَةٍ -يعني: جُبَّة صوف-{5}. (ز) ٥٦٩٢٢- عن عبد الله بن عباس -من طريق مقسم- قال: كانت على موسى جُبَّة مِن صوف لا تبلغ مِرْفَقَيْه، فقال له: <q>﴿وأدخل يدك في جيبك﴾</q>. فأدخلها{4}. (١١/٣٣٧) ٥٦٩٢٣- عن عبد الله بن عباس -من طريق يزيد بن أبي زياد الهاشمي- في قوله: <q>﴿وأدخل يدك في جيبك تخرج بيضاء من غير سوء﴾</q>، قال: كانت رداؤه مِن صوفٍ، كمّيها إلى مرفقيه، ولم يكن لها أزرار، فأدخل يده في جيبه{7}. (ز) ٥٦٩٢٤- عن مِقْسَم، قال: إنّما قيل له: <q>﴿وأدخل يدك في جيبك﴾</q>؛ لأنه لم يكن لها كُمٌّ{8}. (١١/٣٣٧) ٥٦٩٢٥- عن مجاهد بن جبر -من طريق ابن جريج- قال: <q>﴿في جيبك﴾</q>، كانت عليه مِدْرَعَة إلى بعض يده، ولو كان لها كُمٌّ أمره أن يدخل يده في كمه{9}. (١١/٣٣٧) ٥٦٩٢٦- عن قتادة بن دعامة، <q>﴿وأدخل يدك في جيبك﴾</q>، قال: في جيب قميصك{10}. (١١/٣٣٨) ٥٦٩٢٧- عن إسماعيل السُّدِّيّ -من طريق أسباط- في قوله: <q>﴿وأدخل يدك في جيبك﴾</q>، قال: جيب القميص{4}. (١١/٣٣٨) ٥٦٩٢٨- قال مقاتل بن سليمان: <q>﴿في جيبك﴾</q>، يعني: جيب المِدْرَعة من قِبَل صدره، وهي مُضَرَّبَة{3}. (ز) <q>﴿تَخۡرُجۡ بَیۡضَاۤءَ﴾</q> - تفسير ٥٦٩٢٩- عن عبد الله بن عباس -من طريق مِقْسَم- في قوله: <q>﴿تخرج بيضاء﴾</q>، قال: فأدخلها، ثم أخرجها بيضاء من غير سوء، كأنها فرو{4}. (ز) ٥٦٩٣٠- عن عبد الله بن عباس -من طريق يزيد بن أبي زياد الهاشمي- في قوله: <q>﴿وأدخل يدك في جيبك تخرج بيضاء من غير سوء﴾</q>، قال: ... فأدخل يده في جيبه، فأخرجها، فإذا هي تبرق مثل البرق{7}. (ز) ٥٦٩٣١- عن الحسن البصري -من طريق قرة بن خالد- <q>﴿بيضاء من غير سوء﴾</q>، قال: أخرجها -واللهِ- كأنها مصابيح، فعَلِم -والله- موسى قد لقي ربَّه ﷿{15}. (ز) ٥٦٩٣٢- قال مقاتل بن سليمان: <q>﴿تخرج﴾</q> اليد مِن المِدْرَعة <q>﴿بيضاء﴾</q> لها شُعاع كشُعاع الشمس{3}. (ز) <q>﴿مِنۡ غَیۡرِ سُوۤءࣲۖ﴾</q> - تفسير ٥٦٩٣٣- عن عبد الله بن عباس -من طريق سعيد بن جبير- قال: أخرج يده بيضاء من غير سوء، يعني: البرص{17}. (ز) ٥٦٩٣٤- عن مجاهد بن جبر= (ز) ٥٦٩٣٥- والضحاك بن مزاحم= (ز) ٥٦٩٣٦- وعكرمة مولى ابن عباس، مثل ذلك{18}. (ز) ٥٦٩٣٧- عن قتادة بن دعامة، <q>﴿تخرج بيضاء من غير سوء﴾</q>، قال: مِن غير بَرَص{19}. (١١/٣٣٨) ٥٦٩٣٨- عن إسماعيل السُّدِّيّ: من غير برص{20}. (ز) ٥٦٩٣٩- عن عطاء الخراساني= (ز) ٥٦٩٤٠- والربيع بن أنس، مثل ذلك{18}. (ز) ٥٦٩٤١- قال مقاتل بن سليمان: <q>﴿من غير سوء﴾</q>، يعني: مِن غير بَرَص، ثم انقطع الكلام{3}. (ز) <q>﴿فِی تِسۡعِ ءَایَـٰتٍ إِلَىٰ فِرۡعَوۡنَ وَقَوۡمِهِۦۤۚ إِنَّهُمۡ كَانُوا۟ قَوۡمࣰا فَـٰسِقِینَ ۝١٢﴾</q> - تفسير ٥٦٩٤٢- عن قتادة بن دعامة، في قوله: <q>﴿في تسع آيات﴾</q>، قال: يقول هاتان الآيتان؛ يد موسى، وعصاه، والطوفان، والجراد، والقمل، والضفادع، والدم، والسنين في بواديهم ومواشيهم، ونقص من الثمرات في أمصارهم{23}. (١١/٣٣٨) ٥٦٩٤٣- عن إسماعيل السُّدِّيّ، في قوله: <q>﴿في تسع آيات﴾</q>، قال: مع تسع آيات{2}. (ز) ٥٦٩٤٤- قال مقاتل بن سليمان: يقول الله -تبارك وتعالى- لمحمد ﷺ: <q>﴿في تسع آيات﴾</q>، يعني: أعطي تسع آيات؛ اليد، والعصا، والطوفان، والجراد، والقمل، والضفادع، والدم، والسنين، والطمس، فآيتان منهما أعطي موسى ﵇ بالأرض المقدسة؛ اليد والعصا حين أرسل إلى فرعون، وأعطي سبع آيات بأرض مصر حين كذَّبوه، فكان أولها اليد، وآخرها الطمس، يقول: <q>﴿إلى فرعون﴾</q> واسمه: فيطوس، <q>﴿وقومه﴾</q> أهل مصر؛ <q>﴿إنهم كانوا قوما فاسقين﴾</q> يعني: عاصين{25}. (ز) ٥٦٩٤٥- قال عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿تسع آيات إلى فرعون وقومه﴾</q>، قال: هي التي ذكر الله في القرآن؛ العصا، واليد، والجراد، والقمل، والضفادع، والطوفان، والدم، والحجر، والطمس الذي أصاب آل فرعون في أموالهم{26}. (ز) ",footnotes:1:أخرجه ابن جرير ١٨/٢٠.علقه يحيى بن سلام ٢/٥٣٥.تفسير مقاتل بن سليمان ٣/٢٩٧.أخرجه ابن أبي حاتم ٩/٢٨٥٠.أخرجه ابن جرير ١٨/٢١.أخرجه ابن أبي حاتم ٩/٢٨٥٠.أخرجه إسحاق البستي في تفسيره ص٥.عزاه السيوطي إلى ابن أبي شيبة، وابن المنذر.أخرجه ابن جرير ١٨/٢٠-٢١، وابن أبي حاتم ٩/٢٨٥٠.علقه يحيى بن سلام ٢/٥٣٥. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.أخرجه ابن أبي حاتم ٩/٢٨٥٠.تفسير مقاتل بن سليمان ٣/٢٩٧.أخرجه ابن أبي حاتم ٩/٢٨٥٠.أخرجه إسحاق البستي في تفسيره ص٥.أخرجه يحيى بن سلام ٢/٥٣٥، وابن أبي حاتم ٩/٢٨٥٠.تفسير مقاتل بن سليمان ٣/٢٩٧.أخرجه ابن أبي حاتم ٩/٢٨٥١.علقه ابن أبي حاتم ٩/٢٨٥١.علقه يحيى بن سلام ٢/٥٣٥، وابن أبي حاتم ٩/٢٨٥١. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.علَّقه يحيى بن سلام ٢/٥٣٥، وابن أبي حاتم ٩/٢٨٥١.علقه ابن أبي حاتم ٩/٢٨٥١.تفسير مقاتل بن سليمان ٣/٢٩٧.عزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم. ولم نجده في المطبوع من تفسير ابن أبي حاتم.علقه يحيى بن سلام ٢/٥٣٥.تفسير مقاتل بن سليمان ٣/٢٩٨.أخرجه ابن جرير ١٨/٢١. وتقدم اختلاف السلف في تعيين الآيات التسع، ومناقشة ابن عطية وابن كثير لذلك، عند تفسير قوله تعالى: <q>﴿ولَقَدْ آتَيْنا مُوسى تِسْعَ آياتٍ بَيِّناتٍ﴾</q> [الإسراء:١٠١].
27,13," <q>﴿فَلَمَّا جَاۤءَتۡهُمۡ ءَایَـٰتُنَا مُبۡصِرَةࣰ قَالُوا۟ هَـٰذَا سِحۡرࣱ مُّبِینࣱ ۝١٣﴾</q> - تفسير ٥٦٩٤٦- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿فلما جاءتهم آياتنا مبصرة﴾</q>، قال: بيِّنة{1}. (١١/٣٣٨) ٥٦٩٤٧- قال مقاتل بن سليمان: <q>﴿فلما جاءتهم آياتنا مبصرة﴾</q> يعني: مبيَّنة معايَنة يرونها؛ <q>﴿قالوا﴾</q>: يا موسى، هذا الذي جئت به <q>﴿سحر مبين﴾</q> يعني: بيِّن{2}. (ز) ٥٦٩٤٨- عن عبد الملك ابن جُرَيْج -من طريق حجاج- <q>﴿فلما جاءتهم آياتنا مبصرة﴾</q> قال: بيِّنة؛ <q>﴿قالوا هذا سحر مبين﴾</q> يقول: قال فرعون وقومه: هذا الذي جاءنا به موسى سحر مبين. يقول: يُبِين للناظر إليه أنّه سحر{3}. (ز) ",footnotes:1:أخرجه ابن أبي حاتم ٩/٢٨٥٢. وعلقه يحيى بن سلام ٢/٥٣٦. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.تفسير مقاتل بن سليمان ٣/٢٩٨.أخرجه ابن جرير ١٨/٢٢.
