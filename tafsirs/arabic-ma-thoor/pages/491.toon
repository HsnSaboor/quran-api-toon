quran[11]{c,v,t}:
43,23," <q>﴿وَكَذَ ٰ⁠لِكَ مَاۤ أَرۡسَلۡنَا مِن قَبۡلِكَ فِی قَرۡیَةࣲ مِّن نَّذِیرٍ إِلَّا قَالَ مُتۡرَفُوهَاۤ﴾</q> - تفسير ٦٩٣٨٨- عن قتادة بن دعامة -من طريق سعيد- قوله: <q>﴿وكَذَلِكَ ما أرْسَلْنا مِن قَبْلِكَ فِي قَرْيَةٍ مِن نَذِيرٍ إلّا قالَ مُتْرَفُوها﴾</q>: قادتهم ورءوسهم في الشرك{1}. (ز) ٦٩٣٨٩- قال مقاتل بن سليمان: <q>﴿وكَذَلِكَ﴾</q> يقول: وهكذا <q>﴿ما أرْسَلْنا مِن قَبْلِكَ فِي قَرْيَةٍ مِن نَذِيرٍ﴾</q> يعني: من رسول فيما خلا <q>﴿إلّا قالَ مُتْرَفُوها﴾</q> يعني: جبّاريها وكبراءها{2}. (ز) <q>﴿إِنَّا وَجَدۡنَاۤ ءَابَاۤءَنَا عَلَىٰۤ أُمَّةࣲ وَإِنَّا عَلَىٰۤ ءَاثَـٰرِهِم مُّقۡتَدُونَ ۝٢٣﴾</q> - تفسير ٦٩٣٩٠- عن مجاهد بن جبر -من طريق ابن أبي نجيح- <q>﴿إنّا وجَدْنا آباءَنا عَلى أُمَّةٍ﴾</q> قال: على مِلّة، <q>﴿وإنّا عَلى آثارِهِمْ مُقْتَدُونَ﴾</q> قال: بفعلهم{3}. (١٣/١٩٧) ٦٩٣٩١- عن قتادة بن دعامة -من طريق سعيد- قوله: <q>﴿وإنّا عَلى آثارِهِمْ مُقْتَدُونَ﴾</q>: فاتّبعوهم على ذلك{4}. (ز) ٦٩٣٩٢- قال مقاتل بن سليمان: <q>﴿إنّا وجَدْنا آباءَنا عَلى أُمَّةٍ﴾</q> يعني: على مِلّة، <q>﴿وإنّا عَلى آثارِهِمْ مُقْتَدُونَ﴾</q> بأعمالهم، كما قال كفار مكة{2}. (ز) ",footnotes:1:أخرجه عبد الرزاق ٢/١٩٥ من طريق معمر، وابن جرير ٢٠/٥٧٢، ومن طريق معمر أيضًا.تفسير مقاتل بن سليمان ٣/٧٩٢.تفسير مجاهد ص٥٩٣، وأخرجه ابن جرير ٢٠/٥٧٠، ٥٧٣، وأخرج شطره الأول عبد بن حميد -كما في تغليق التعليق ٤/٣٠٥-. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه ابن جرير ٢٠/٥٧٣.تفسير مقاتل بن سليمان ٣/٧٩٢.
43,24," <q>﴿قَـٰلَ أَوَلَوۡ جِئۡتُكُم بِأَهۡدَىٰ مِمَّا وَجَدتُّمۡ عَلَیۡهِ ءَابَاۤءَكُمۡۖ قَالُوۤا۟ إِنَّا بِمَاۤ أُرۡسِلۡتُم بِهِۦ كَـٰفِرُونَ ۝٢٤﴾</q> - قراءات ٦٩٣٩٣- قرأ عاصم: ‹قُلْ أوَلَوْ جِئْتُكُم› بغير ألف، وبالتاء{1}٥٨٥١. (١٣/١٩٨) ٥٨٥١ اختُلف في قراءة قوله: <q>﴿أولو جئتكم﴾</q>؛ فقرأ الجمهور: <q>﴿أولو جئتكم﴾</q> بالتاء، وقرأ غيرهم: ‹أوَلَوْ جِئْناكُمْ› بالنون والألف. ورجَّح ابنُ جرير (٢٠/٥٧٤) قراءة التاء مستندًا إلى إجماع القراء، فقال: «والقراءة عندنا ما عليه قراء الأمصار؛ لإجماع الحجة مِن القرأة عليه». <q>﴿قَـٰلَ أَوَلَوۡ جِئۡتُكُم بِأَهۡدَىٰ مِمَّا وَجَدتُّمۡ عَلَیۡهِ ءَابَاۤءَكُمۡۖ قَالُوۤا۟ إِنَّا بِمَاۤ أُرۡسِلۡتُم بِهِۦ كَـٰفِرُونَ ۝٢٤﴾</q> - تفسير الآية ٦٩٣٩٤- قال مقاتل بن سليمان: <q>﴿قالَ أوَلَوْ جِئْتُكُمْ بِأَهْدى مِمّا وجَدْتُمْ عَلَيْهِ آباءَكُمْ﴾</q> من الدِّين ألا تتّبعوني. فردّوا على النبي ﷺ، فـ<q>﴿قالُوا إنّا بِما أُرْسِلْتُمْ بِهِ كافِرُونَ﴾</q> يعني: بالتوحيد كافرون{2}. (ز) ",footnotes:1:عزاه السيوطي إلى عَبد بن حُمَيد. وهي قراءة متواترة، قرأ بها العشرة، ما عدا ابن عامر، وحفصًا عن عاصم؛ فإنهما قرآ: <q>﴿قالَ أوَلَوْ جِئْتُكُم﴾</q>. انظر: النشر ٢/٣٦٩، والإتحاف ص٤٩٥.تفسير مقاتل بن سليمان ٣/٧٩٢.
43,25," <q>﴿فَٱنتَقَمۡنَا مِنۡهُمۡۖ فَٱنظُرۡ كَیۡفَ كَانَ عَـٰقِبَةُ ٱلۡمُكَذِّبِینَ ۝٢٥﴾</q> - تفسير ٦٩٣٩٥- عن قتادة بن دعامة -من طريق سعيد- <q>﴿فانْتَقَمْنا مِنهُمْ فانْظُرْ كَيْفَ كانَ عاقِبَةُ المُكَذِّبِينَ﴾</q>، قال: شرّ -واللهِ- كان عاقبتهم؛ أخذهم بخسْفٍ وغرَقٍ، فأهلكهم الله، ثم أدخلهم النار{1}. (١٣/١٩٨) ٦٩٣٩٦- قال مقاتل بن سليمان: ثم رجع إلى الأمم الخالية، فيها تقديم، ثم قال: <q>﴿فانْتَقَمْنا مِنهُمْ﴾</q> بالعذاب، <q>﴿فانْظُرْ كَيْفَ كانَ عاقِبَةُ المُكَذِّبِينَ﴾</q> بالعذاب، يُخَوِّف كُفّار مكة بعذاب الأمم الخالية؛ لئلا يكذِّبوا محمدًا ﷺ{2}. (ز) ",footnotes:1:أخرجه ابن جرير ٢٠/٥٧٤-٥٧٥ بنحوه. وعزاه السيوطي إلى عَبد بن حُمَيد.تفسير مقاتل بن سليمان ٣/٧٩٣.
43,26," <q>﴿وَإِذۡ قَالَ إِبۡرَ ٰ⁠هِیمُ لِأَبِیهِ وَقَوۡمِهِۦۤ إِنَّنِی بَرَاۤءࣱ مِّمَّا تَعۡبُدُونَ ۝٢٦﴾</q> - قراءات ٦٩٣٩٧- عن عبد الله بن مسعود، أنّه قرأ: (إنَّنِي بَرِيءٌ مِّمّا تَعْبُدُونَ) بالياء{1}. (١٣/١٩٨) <q>﴿وَإِذۡ قَالَ إِبۡرَ ٰ⁠هِیمُ لِأَبِیهِ وَقَوۡمِهِۦۤ إِنَّنِی بَرَاۤءࣱ مِّمَّا تَعۡبُدُونَ ۝٢٦﴾</q> - تفسير الآية ٦٩٣٩٨- عن قتادة بن دعامة -من طريق سعيد- <q>﴿إنَّنِي بَراءٌ مِمّا تَعْبُدُونَ إلّا الَّذِي فَطَرَنِي فَإنَّهُ سَيَهْدِينِ﴾</q>، قال: كايَدهم، كانوا يقولون: إنّ الله ربنا، <q>﴿ولَئِنْ سَأَلْتَهُمْ مَن خَلَقَ السموات والأرض لَيَقُولُنَّ اللَّهُ﴾</q> [لقمان:٢٥]، فلم يبرأ مِن ربِّه{2}. (١٣/١٩٩) ٦٩٣٩٩- قال مقاتل بن سليمان: <q>﴿وإذْ قالَ إبْراهِيمُ لِأَبِيهِ﴾</q> آزَر <q>﴿وقَوْمِهِ إنَّنِي بَراءٌ مِمّا تَعْبُدُونَ﴾</q> ثم استثنى الرَّبّ نفسه؛ لأنهم يعلمون أن الله ربهم، فقال: <q>﴿إلّا الَّذِي فَطَرَنِي﴾</q>{3}. (ز) ",footnotes:1:عزاه السيوطي إلى الفضل بن شاذان في كتاب القراءات بسنده. وهي قراءة شاذة، تروى أيضًا عن الأعمش. انظر: مختصر ابن خالويه ص١٣٦.أخرجه ابن جرير ٢٠/٥٧٧. وعزاه السيوطي إلى عبد بن حميد.تفسير مقاتل بن سليمان ٣/٧٩٣.
43,27," <q>﴿إِلَّا ٱلَّذِی فَطَرَنِی فَإِنَّهُۥ سَیَهۡدِینِ ۝٢٧﴾</q> - تفسير ٦٩٤٠٠- عن قتادة بن دعامة -من طريق معمر- <q>﴿إلّا الَّذِي فَطَرَنِي﴾</q>، قال: خَلقني{1}. (١٣/١٩٩) ٦٩٤٠١- عن إسماعيل السُّدّيّ -من طريق أسباط- <q>﴿إلّا الَّذِي فَطَرَنِي﴾</q>، قال: خلقني{2}. (ز) ٦٩٤٠٢- قال مقاتل بن سليمان: <q>﴿إلّا الَّذِي فَطَرَنِي﴾</q> يقول: خلقني، فإنِّي لا أتبرأ منه، <q>﴿فَإنَّهُ سَيَهْدِينِ﴾</q> لدينه{3}٥٨٥٢. (ز) ٥٨٥٢ ذكر ابنُ عطية (٧/٥٤٢) أن فرقة قالت: قوله: <q>﴿إلّا الَّذِي فَطَرَنِي﴾</q> الاستثناء متصل، وكانوا يعرفون الله ويعظّمونه، إلا أنهم كانوا يشركون معه أصنامهم، فكأن إبراهيم قال لهم: أنا لا أوافقكم إلا على عبادة الله الفاطر. ثم ذكر قولًا آخر، فقال: «وقالت فرقة:الاستثناء منقطع، والمعنى: لكن الذي فطرني معبودي، وعلى هذا فلم يكونوا يعبدون الله لا قليلًا ولا كثيرًا». ",footnotes:1:أخرجه عبد الرزاق ٢/١٩٥، وابن جرير ٢٠/٥٧٦.أخرجه ابن جرير ٢٠/٥٧٦.تفسير مقاتل بن سليمان ٣/٧٩٣.
43,28," <q>﴿وَجَعَلَهَا كَلِمَةَۢ بَاقِیَةࣰ﴾</q> - تفسير ٦٩٤٠٣- عن عبد الله بن عباس، <q>﴿وجَعَلَها كَلِمَةً باقِيَةً﴾</q>، قال: لا إله إلا الله{1}. (١٣/٢٠٠) ٦٩٤٠٤- عن مجاهد بن جبر -من طريق ليث- <q>﴿وجَعَلَها كَلِمَةً باقِيَةً فِي عَقِبِهِ﴾</q>، قال: لا إله إلا الله{2}٥٨٥٣. (١٣/١٩٩) ٥٨٥٣ ذكر ابنُ عطية (٧/٥٤٣) أن الضمير في قوله: <q>﴿وجعلها﴾</q> عائد على كلمة التوحيد -على هذا القول الذي قاله ابن عباس، وعكرمة من طريق ليث، ومجاهد، والسُّدّيّ، وقتادة، ومقاتل-، ثم علَّق بقوله: «وعاد الضمير عليها وإن كانت لم يجرِ لها ذكر؛ لأنّ اللفظ يتضمنها». ٦٩٤٠٥- عن عكرمة مولى ابن عباس -من طريق ليث- <q>﴿وجَعَلَها كَلِمَةً باقِيَةً﴾</q>، قال: لا إله إلا الله{3}. (ز) ٦٩٤٠٦- عن عكرمة مولى ابن عباس، <q>﴿وجَعَلَها كَلِمَةً باقِيَةً فِي عَقِبِهِ﴾</q>، قال: هي الإسلام، أوصى بها ولده{4}. (١٣/١٩٩) ٦٩٤٠٧- قال محمد بن كعب القُرَظي: <q>﴿وجَعَلَها كَلِمَةً باقِيَةً فِي عَقِبِهِ﴾</q>، يعني: وجعَل وصيّة إبراهيم التي أوصى بها بَنيه باقيةً في نَسْله وذرّيته{5}. (ز) ٦٩٤٠٨- عن قتادة بن دعامة -من طريق سعيد- <q>﴿وجَعَلَها كَلِمَةً باقِيَةً فِي عَقِبِهِ﴾</q>، قال: شهادة أن لا إله إلا الله، والتوحيد، لا يزال في ذُرّيته مَن يقولها مِن بعدِه{6}. (١٣/١٩٩) ٦٩٤٠٩- عن قتادة بن دعامة -من طريق معمر- <q>﴿وجَعَلَها كَلِمَةً باقِيَةً فِي عَقِبِهِ﴾</q>، قال: الإخلاص والتوحيد، لا يزال في ذُرّيته مَن يُوحّد اللهَ ويعبده{7}. (١٣/١٩٩) ٦٩٤١٠- عن إسماعيل السُّدّيّ -من طريق أسباط- <q>﴿وجَعَلَها كَلِمَةً باقِيَةً﴾</q>، قال: لا إله إلا الله{8}. (ز) ٦٩٤١١- قال مقاتل بن سليمان: قوله تعالى: <q>﴿وجَعَلَها كَلِمَةً باقِيَةً﴾</q> لا تزال ببقاء التوحيد{9}. (ز) ٦٩٤١٢- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿وجَعَلَها كَلِمَةً باقِيَةً فِي عَقِبِهِ﴾</q> قال: الإسلام. وقرأ: <q>﴿أسْلَمْتُ لِرَبِّ العالَمِينَ﴾</q> [البقرة:١٣١]، قال: جعل هذه باقية في عَقِبه، وقال: الإسلام. وقرأ: <q>﴿هُوَ سَمّاكُمُ المُسْلِمِينَ مِن قَبْلُ﴾</q> [الحج:٧٨]، وقرأ: <q>﴿واجْعَلْنا مُسْلِمَيْنِ لَكَ﴾</q> [البقرة:١٢٨]{8}٥٨٥٤. (ز) ٥٨٥٤ ذكر ابنُ كثير (٧/٣٠٩) أن هذا القول الذي قاله ابن زيد وعكرمة راجع إلى قول الجماعة بأن الكلمة هي كلمة التوحيد. <q>﴿فِی عَقِبِهِۦ﴾</q> - تفسير ٦٩٤١٣- عن عبد الله بن عباس، <q>﴿فِي عَقِبِهِ﴾</q>، قال: عَقِب إبراهيم: ولده{1}. (١٣/٢٠٠) ٦٩٤١٤- عن عبد الله بن عباس -من طريق عطية العَوفيّ- <q>﴿وجَعَلَها كَلِمَةً باقِيَةً فِي عَقِبِهِ﴾</q>: يعني: مَن خَلَفه{12}. (ز) ٦٩٤١٥- عن مجاهد بن جبر -من طريق ابن أبي نجيح- <q>﴿فِي عَقِبِهِ﴾</q>، قال: ولده{13}. (١٣/١٩٩) ٦٩٤١٦- عن زيد بن علي، قال: ... <q>﴿وجعلها كلمة باقية في عقبه﴾</q>، فمحمد ﷺ وآله مِن عَقِب إبراهيم{14}. (٨/١٠٢) ٦٩٤١٧- عن إسماعيل السُّدّيّ -من طريق أسباط- <q>﴿فِي عَقِبِهِ﴾</q>، قال: في عقِب إبراهيم؛ آل محمد ﷺ{12}. (ز) ٦٩٤١٨- قال مقاتل بن سليمان: قوله تعالى: <q>﴿فِي عَقِبِهِ﴾</q> يعني: ذُرّيته، يعني: ذُرّية إبراهيم{9}. (ز) ٦٩٤١٩- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿فِي عَقِبِهِ﴾</q>، قال: عَقِبه: ذُرّيته{17}. (ز) <q>﴿فِی عَقِبِهِۦ﴾</q> - آثار متعلقة بالآية ٦٩٤٢٠- عن عَبِيدة، قال: قلت لإبراهيم: ما العَقِب؟ قال: ولده الذكَر{1}. (١٣/٢٠٠) ٦٩٤٢١- عن عطاء، في رجل أسكنه رجل له ولعقِبه من بعده، أتكون امرأته مِن عَقِبه؟ قال: لا، ولكن ولده عَصَبته{1}. (١٣/٢٠٠) ٦٩٤٢٢- عن محمد بن شهاب الزّهري، قال: عَقِب الرجل: ولده الذّكور والإناث، وأولاد الذّكور{20}. (١٣/٢٠٠) <q>﴿لَعَلَّهُمۡ یَرۡجِعُونَ ۝٢٨﴾</q> - تفسير ٦٩٤٢٣- عن قتادة بن دعامة -من طريق سعيد- <q>﴿لعلهم يرجعون﴾</q>، قال: يتوبون، أو يذكّرون{21}. (١٣/١٩٩) ٦٩٤٢٤- قال إسماعيل السُّدّيّ: <q>﴿لَعَلَّهُمْ يَرْجِعُونَ﴾</q> لعلهم يتوبون ويرجعون إلى طاعة الله ﷿{22}. (ز) ٦٩٤٢٥- قال مقاتل بن سليمان: <q>﴿لَعَلَّهُمْ﴾</q> يعني: لكي <q>﴿يَرْجِعُونَ﴾</q> من الكفر إلى الإيمان، يقول: التوحيد إلى يوم القيامة يبقى في ذُرّية إبراهيم ﵇، <q>﴿لَعَلَّهُمْ يَرْجِعُونَ﴾</q> يقول: لكي يرجعوا من الكفر إلى الإيمان{9}. (ز) ",footnotes:1:عزاه السيوطي إلى عَبد بن حُمَيد.أخرجه سفيان الثوري ص٢٧٠، وابن جرير ٢٠/٥٧٦. وعزاه السيوطي إلى عَبد بن حُمَيد، وابن المنذر.أخرجه سفيان الثوري ص٢٧٠، كما أخرجه الطبراني في الدعاء ٣/١٥٠٧ من طريق الحكم بن أبان.عزاه السيوطي إلى ابن أبي حاتم.تفسير الثعلبي ٨/٣٣٢، وتفسير البغوي ٧/٢١٠.أخرجه ابن جرير ٢٠/٥٧٧، والبيهقي في الأسماء والصفات (٢٠٩). وعزاه السيوطي إلى عَبد بن حُمَيد.أخرجه عبد الرزاق ٢/١٩٦، وابن جرير ٢٠/٥٧٧ بنحوه. وعزاه السيوطي إلى ابن المنذرأخرجه ابن جرير ٢٠/٥٧٧.تفسير مقاتل بن سليمان ٣/٧٩٣.أخرجه ابن جرير ٢٠/٥٧٧.عزاه السيوطي إلى عَبد بن حُمَيد.أخرجه ابن جرير ٢٠/٥٧٨.أخرجه ابن جرير ٢٠/٥٧٨، وعبد بن حميد -كما في الفتح ٨/٥٦٧-. وذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٤/١٨٢-. وعزاه السيوطي إلى عَبد بن حُمَيد، وابن المنذر.عزاه السيوطي إلى أبي الشيخ.أخرجه ابن جرير ٢٠/٥٧٨.تفسير مقاتل بن سليمان ٣/٧٩٣.أخرجه ابن جرير ٢٠/٥٧٧-٥٧٨.عزاه السيوطي إلى عَبد بن حُمَيد.عزاه السيوطي إلى عَبد بن حُمَيد.عزاه السيوطي إلى عَبد بن حُمَيد. وأخرجه ابن جرير ٢٠/٥٨٧ من طريق ابن أبي ذئب، بلفظ: الولد، وولد الولد.أخرجه ابن جرير ٢٠/٥٧٩، والبيهقي في الأسماء والصفات (٢٠٩). وعزاه السيوطي إلى عَبد بن حُمَيد.تفسير البغوي ٧/٢١١.تفسير مقاتل بن سليمان ٣/٧٩٣.
43,29," <q>﴿بَلۡ مَتَّعۡتُ هَـٰۤؤُلَاۤءِ وَءَابَاۤءَهُمۡ حَتَّىٰ جَاۤءَهُمُ ٱلۡحَقُّ وَرَسُولࣱ مُّبِینࣱ ۝٢٩﴾</q> - قراءات ٦٩٤٢٦- عن قتادة بن دعامة، أنّه كان يقرؤها: (بَلْ مَتَّعْتَ هَؤُلَآءِ) بنصب التاء{1}. (١٣/٢٠٠) ٦٩٤٢٧- عن عاصم، أنّه قرأ: <q>﴿بَلْ مَتَّعْتُ﴾</q> برفع التاء{2}٥٨٥٥. (١٣/٢٠٠) ٥٨٥٥ اختُلف في قراءة قوله: <q>﴿متعت﴾</q>؛ فقرأ الجمهور بضم التاء، وقرأ غيرهم بفتحها. وذكر ابنُ عطية (٧/٥٤٣) أن الأعمش قرأ: (بَلْ مَتَّعْنا)، ثم علَّق بقوله: «وهي تعضد قراءة الجمهور». <q>﴿بَلۡ مَتَّعۡتُ هَـٰۤؤُلَاۤءِ وَءَابَاۤءَهُمۡ حَتَّىٰ جَاۤءَهُمُ ٱلۡحَقُّ وَرَسُولࣱ مُّبِینࣱ ۝٢٩﴾</q> - تفسير الآية ٦٩٤٢٨- قال الضَّحّاك بن مُزاحِم: <q>﴿حَتّى جاءَهُمُ الحَقُّ﴾</q> الإسلام{3}. (ز) ٦٩٤٢٩- عن قتادة بن دعامة: (بَلْ مَتَّعْتَ هَؤُلاءِ وآباءَهُمْ حَتّى جاءَهُمُ الحَقُّ ورَسُولٌ مُبِينٌ)، قال: هذا قول أهل الكتاب لهذه الأمة{4}. (١٣/٢٠٠) ٦٩٤٣٠- قال مقاتل بن سليمان: قوله: <q>﴿بَلْ مَتَّعْتُ هؤُلاءِ﴾</q> يعني: كفار مكة <q>﴿وآباءَهُمْ حَتّى جاءَهُمُ الحَقُّ﴾</q> يعني: القرآن، <q>﴿ورَسُولٌ مُبِينٌ﴾</q> يعني: محمدًا ﷺ بيِّنٌ أمره{5}. (ز) ",footnotes:1:عزاه السيوطي إلى عَبد بن حُمَيد، وابن المنذر. وهي قراءة شاذة، تروى أيضًا عن الأعمش، وقراءة العشرة: <q>﴿بَلْ مَتَّعْتُ﴾</q> برفع التاء. انظر: المحرر الوجيز ٥/٥٢، والبحر المحيط ٨/١٤.عزاه السيوطي إلى عَبد بن حُمَيد.تفسير الثعلبي ٨/٣٣٢، وتفسير البغوي ٧/٢١١.عزاه السيوطي إلى عَبد بن حُمَيد، وابن المنذر.تفسير مقاتل بن سليمان ٣/٧٩٣.
43,30," <q>﴿وَلَمَّا جَاۤءَهُمُ ٱلۡحَقُّ قَالُوا۟ هَـٰذَا سِحۡرࣱ وَإِنَّا بِهِۦ كَـٰفِرُونَ ۝٣٠﴾</q> - نزول الآية ٦٩٤٣١- قال مقاتل بن سليمان: نزلت في [أبي] سفيان بن حرب، وأبي جهل بن هشام، وعُتبة، وشيبة ...{1}. (ز) <q>﴿وَلَمَّا جَاۤءَهُمُ ٱلۡحَقُّ قَالُوا۟ هَـٰذَا سِحۡرࣱ وَإِنَّا بِهِۦ كَـٰفِرُونَ ۝٣٠﴾</q> - تفسير الآية ٦٩٤٣٢- عن إسماعيل السُّدّيّ -من طريق أسباط- <q>﴿ولَمّا جاءَهُمُ الحَقُّ قالُوا هَذا سِحْرٌ﴾</q>، قال: هؤلاء قريش، قالوا للقرآنِ الذي جاء به محمدٌ ﷺ: هذا سحر{2}. (١٣/٢٠١) ٦٩٤٣٣- قال مقاتل بن سليمان: <q>﴿ولَمّا جاءَهُمُ الحَقُّ﴾</q> يعني: القرآن <q>﴿قالُوا هَذا﴾</q> القرآن <q>﴿سِحْرٌ﴾</q>، <q>﴿وإنّا بِهِ كافِرُونَ﴾</q> لا نؤمن به ...{1}. (ز) ",footnotes:1:تفسير مقاتل بن سليمان ٣/٧٩٣.أخرجه ابن جرير ٢٠/٥٨٠.تفسير مقاتل بن سليمان ٣/٧٩٣.
43,31," <q>﴿وَقَالُوا۟ لَوۡلَا نُزِّلَ هَـٰذَا ٱلۡقُرۡءَانُ عَلَىٰ رَجُلࣲ مِّنَ ٱلۡقَرۡیَتَیۡنِ عَظِیمٍ ۝٣١﴾</q> - نزول الآية ٦٩٤٣٤- عن قتادة بن دعامة -من طريق معمر- قال: قال الوليد بن المُغيرة: لو كان ما يقول محمد حقًّا أُنزل عَلَيَّ هذا القرآن، أو على عُروة بن مسعود الثَّقفي. فنزلت: <q>﴿لَوْلا نُزِّلَ هَذا القُرْآنُ عَلى رَجُلٍ مِنَ القَرْيَتَيْنِ عَظِيمٍ﴾</q>{1}. (١٣/٢٠٢) ٦٩٤٣٥- قال مقاتل بن سليمان: .... قال الوليد بن المُغيرة: لو كان هذا القرآنُ حقًّا أُنزل عليَّ أو على أبي مسعود الثَّقفي -واسمه: عمرو بن عمير بن عوف جدّ المختار-. فأنزل الله تعالى في قول الوليد بن المُغيرة: <q>﴿وقالُوا لَوْلا نُزِّلَ هذا القُرْآنُ عَلى رَجُلٍ مِنَ القَرْيَتَيْنِ عَظِيمٍ﴾</q>{2}. (ز) <q>﴿وَقَالُوا۟ لَوۡلَا نُزِّلَ هَـٰذَا ٱلۡقُرۡءَانُ عَلَىٰ رَجُلࣲ مِّنَ ٱلۡقَرۡیَتَیۡنِ عَظِیمٍ ۝٣١﴾</q> - تفسير الآية ٦٩٤٣٦- عن عبد الله بن عباس، أنّه سُئِل عن قول الله: <q>﴿لَوْلا نُزِّلَ هَذا القُرْآنُ عَلى رَجُلٍ مِنَ القَرْيَتَيْنِ عَظِيمٍ﴾</q>، ما القريتان؟ قال: الطائف ومكة. قيل: فمَن الرجلان؟ قال: عروة بن مسعود، وجبّار قريش{3}. (١٣/٢٠١) ٦٩٤٣٧- عن عبد الله بن عباس -من طريق عطية- أنّه سُئِل عن قول الله: <q>﴿لَوْلا نُزِّلَ هَذا القُرْآنُ عَلى رَجُلٍ مِنَ القَرْيَتَيْنِ عَظِيمٍ﴾</q>. قال: يعني بالقريتين: مكة، والطائف. والعظيم: الوليد بن المغيرة القُرشي، وحبيب بن عمرو الثَّقفي{4}. (١٣/٢٠١) ٦٩٤٣٨- عن عبد الله بن عباس، في قوله: <q>﴿لَوْلا نُزِّلَ هَذا القُرْآنُ عَلى رَجُلٍ مِنَ القَرْيَتَيْنِ عَظِيمٍ﴾</q>، قال: يعنون: أشرفَ من محمد؛ الوليد بن المُغيرة مِن أهل مكة؛ ومسعود بن عمرو الثَّقفي من أهل الطائف{5}. (١٣/٢٠٢) ٦٩٤٣٩- عن عبد الله بن عباس -من طريق عمران الطائفي، عن خاله- في قول الله: <q>﴿لَوْلا نُزِّلَ هَذا القُرْآنُ عَلى رَجُلٍ مِنَ القَرْيَتَيْنِ عَظِيمٍ﴾</q>، قال: الطائف، ومكة. قال: العظيم: أحدهما المختار ابن أبي عبيد{6}، والآخر من عظماء قريش{7}. (ز) ٦٩٤٤٠- عن عبد الله بن عباس -من طريق أبي روْق، عن الضَّحّاك- قال: لَمّا بعث اللهُ محمدًا رسولًا أنكرت العربُ ذلك –أو مَن أنكر منهم-، فقالوا: اللهُ أعظمُ مِن أن يكون رسولُه بشرًا مثل محمد. قال: فأنزل الله ﷿: <q>﴿أكانَ لِلنّاسِ عَجَبًا أنْ أوْحَيْنا إلى رَجُلٍ مِنهُمْ أنْ أنْذِرِ النّاسَ﴾</q> [يونس:٢]، وقال: <q>﴿وما أرْسَلْنا مِن قَبْلِكَ إلّا رِجالًا نُوحِي إلَيْهِمْ فاسْأَلُوا أهْلَ الذِّكْرِ﴾</q> [النحل:٤٣]. يعني: أهل الكتب الماضية: أبشرًا كانت الرسل التي أتَتْكم أم ملائكة؟ فإن كانوا ملائكة أتَتْكم، وإن كانوا بشرًا فلا تنكرون أن يكون محمدٌ رسولًا. قال: ثم قال: <q>﴿وما أرْسَلْنا مِن قَبْلِكَ إلّا رِجالًا نُوحِي إلَيْهِمْ مِن أهْلِ القُرى﴾</q> [يوسف:١٠٩]، أي: ليسوا مِن أهل السماء كما قلتم. قال: فلما كرّر الله عليهم الحُجَج قالوا: فإذ كان بشرًا فغيرُ محمد كان أحقَّ بالرسالة، و<q>﴿لَوْلا نُزِّلَ هَذا القُرْآنُ عَلى رَجُلٍ مِنَ القَرْيَتَيْنِ عَظِيمٍ﴾</q>. يقولون: أشرفُ مِن محمد ﷺ، يعنون: الوليد بن المُغيرة المخزومي، وكان يُسمّى ريحانة قريش، هذا مِن مكة، ومسعود بن عمرو بن عبيد الله الثَّقفي مِن أهل الطائف. قال: يقول الله ﷿ ردًّا عليهم: <q>﴿أهُمْ يَقْسِمُونَ رَحْمَتَ رَبِّكَ﴾</q>؟! أنا أفعل ما شئتُ{8}. (ز) ٦٩٤٤١- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿عَلى رَجُلٍ مِنَ القَرْيَتَيْنِ عَظِيمٍ﴾</q>، قال: عُتبة بن ربيعة من مكة، وابن عبد ياليل بن كنانة الثَّقفي من الطائف. وفي لفظ: وعمير بن مسعود الثَّقفي. وفي لفظ: وأبو مسعود الثَّقفي{9}. (١٣/٢٠٢) ٦٩٤٤٢- عن مجاهد بن جبر -من طريق ابن جُريْج- في قوله: <q>﴿وقالُوا لَوْلا نُزِّلَ هَذا القُرْآنُ عَلى رَجُلٍ مِنَ القَرْيَتَيْنِ عَظِيمٍ﴾</q>، قال: هو عُتبة بن ربيعة، وكان ريحانة قريش يومئذ{10}. (١٣/٢٠٣) ٦٩٤٤٣- قال مجاهد بن جبر: يعني: كنانة{11}. (ز) ٦٩٤٤٤- عن عامر الشعبي، في قوله: <q>﴿عَلى رَجُلٍ مِنَ القَرْيَتَيْنِ عَظِيمٍ﴾</q>، قال: هو الوليد بن المُغيرة المخزومي، وعبد ياليل بن عمرو الثَّقفي{12}. (١٣/٢٠٣) ٦٩٤٤٥- عن قتادة بن دعامة -من طريق سعيد- <q>﴿وقالُوا لَوْلا نُزِّلَ هَذا القُرْآنُ عَلى رَجُلٍ مِنَ القَرْيَتَيْنِ عَظِيمٍ﴾</q>، قال: القريتان: مكة، والطائف، قال ذلك مشركو قريش. قال: بلغنا: أنّه ليس فَخِذٌ من قريش إلا قد ادّعته، فقالوا: هو مِنّا. وكنا نُحَدَّث: أنه الوليد بن المُغيرة، وعُروة بن مسعود الثَّقفي. قال: يقولون: فهلّا كان أُنزِل على أحد هذين الرجلين، ليس على محمد{13}. (١٣/٢٠٢) ٦٩٤٤٦- عن إسماعيل السُّدّيّ -من طريق أسباط- <q>﴿عَلى رَجُلٍ مِنَ القَرْيَتَيْنِ عَظِيمٍ﴾</q>، قال: الوليد بن المغيرة القرشي، أو كنانة بن عبد عمرو بن عمير عظيم أهل الطائف{14}. (١٣/٢٠٣) ٦٩٤٤٧- عن عطاء الخُراساني -من طريق يونس بن يزيد- في قوله ﷿: <q>﴿من القريتين عظيم﴾</q>، قال: مكة، والطائف{15}. (ز) ٦٩٤٤٨- قال مقاتل بن سليمان: <q>﴿وقالُوا لَوْلا﴾</q> يعني: هلّا <q>﴿نُزِّلَ هذا القُرْآنُ عَلى رَجُلٍ مِنَ القَرْيَتَيْنِ عَظِيمٍ﴾</q> القريتان: مكة، والطائف، وكان عظمة{16} أنّ الوليد عظيم أهل مكة في الشرف، وأبا مسعود عظيم أهل الطائف في الشرف{17}. (ز) ٦٩٤٤٩- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿لَوْلا نُزِّلَ هَذا القُرْآنُ عَلى رَجُلٍ مِنَ القَرْيَتَيْنِ عَظِيمٍ﴾</q>، قال: كان أحد العظيمين عروة بن مسعود الثَّقفي، كان عظيم أهل الطائف{14}٥٨٥٦. (ز) ٥٨٥٦ اختُلف في عظيم مكة على قولين: أحدهما: أنه الوليد بن المغيرة. الثاني: عُتبة بن ربيعة. وأما عظيم الطائف ففيه أقوال: الأول: أنه حبيب بن عمر الثَّقفي. الثاني: عمير بن عبد ياليل الثقفي. الثالث: عروة بن مسعود. الرابع: أنه كنانة بن عبد بن عمرو. ورجَّح ابنُ جرير (٢٠/٥٨٢-٥٨٣) العموم فقال: «وأولى الأقوال في ذلك بالصواب أن يقال كما قال -جل ثناؤه- مخبرًا عن هؤلاء المشركين: <q>﴿وقالوا لولا نزل هذا القرآن على رجل من القريتين عظيم﴾</q> إذ كان جائزًا أن يكون بعض هؤلاء، ولم يضع الله -تبارك وتعالى- لنا الدلالةَ على الذين عُنوا منهم في كتابه، ولا على لسان رسوله ﷺ». وساق ابنُ عطية (٧/٥٤٤) الأقوال، ثم علَّق بقوله: «وإنما قصدوا إلى مَن عظُم ذكره بالسِّنِّ والقِدم، وإلا فرسول الله ﷺ كان حينئذٍ أعظمَ مِن هؤلاء، لكن لما عظُم أولئك قبل مدة النبي ﷺ وفي صباه استمر ذلك لهم». وساق ابنُ كثير (١٢/٣١٠) الأقوال، ثم علَّق بقوله: «والظاهر: أنّ مرادهم رجلٌ كبيرٌ مِن أي البلدتين كان». ",footnotes:1:عزاه السيوطي إلى ابن المنذر، وابن أبي حاتم. كما أخرجه كل من عبد الرزاق ٢/١٩٦، وابن جرير ٢٠/٥٨١ دون لفظ: «فنزلت: <q>﴿لولا نزل ...﴾</q>».تفسير مقاتل بن سليمان ٣/٧٩٣.عزاه السيوطي إلى عَبد بن حميد، وابن المنذر، وابن مردويه.أخرجه ابن جرير ٢٠/٥٨٠-٥٨١. وعزاه السيوطي إلى ابن أبي حاتم، وابن مردويه.عزاه السيوطي إلى ابن أبي حاتم.كذا وقع في النسخة! ولعل المراد: جد المختار، كما في قول مقاتل السابق.أخرجه سفيان الثوري ص٢٧٠.أخرجه ابن جرير ٢٠/٥٨٣-٥٨٤.أخرجه ابن جرير ٢٠/٥٨١ مختصرًا، وعبد بن حميد -كما في الفتح ٦/٣١٥- مصرحًا بلفظ النُّزول. وعزاه السيوطي إلى عَبد بن حُمَيد، وابن المنذر، وابن أبى حاتم.أخرجه سفيان الثوري ص٢٧١ بنحوه، وإسحاق البستي ص٣١٥، وابن عساكر ٣٨/٢٣٩-٢٤٠.أخرجه ابن أبي حاتم -كما في الفتح ٦/٣١٥-.عزاه السيوطي إلى سعيد بن منصور، وابن المنذر.أخرجه ابن جرير ٢٠/٥٨٢. وذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٤/١٨٢-١٨٣-. وعزاه السيوطي إلى عَبد بن حُمَيد.أخرجه ابن جرير ٢٠/٥٨٢.أخرجه أبو جعفر الرملي في جزئه (تفسير عطاء) ص٩١.كذا في مطبوعة المصدر.تفسير مقاتل بن سليمان ٣/٧٩٤.أخرجه ابن جرير ٢٠/٥٨٢.
43,32," <q>﴿أَهُمۡ یَقۡسِمُونَ رَحۡمَتَ رَبِّكَۚ﴾</q> - تفسير ٦٩٤٥٠- عن ابن مسعود، في قوله: <q>﴿أهُمْ يَقْسِمُونَ رَحْمَتَ رَبِّكَ﴾</q>، قال: سمعت رسول الله ﷺ يقول: «إنّ الله قسَم بينكم أخلاقَكم كما قسَم بينكم أرزاقكم، وإنّ الله يعطي الدنيا مَن يحب ومَن لا يحب، ولا يعطي الدين إلا مَن أحبّ، فمَن أعطاه الدين فقد أحبّه»{1}. (١٣/٢٠٥) ٦٩٤٥١- قال مقاتل بن سليمان: يقول الله تعالى: <q>﴿أهُمْ يَقْسِمُونَ رَحْمَتَ رَبِّكَ﴾</q>، يقول: أبأيديهم مفاتيح الرسالة فيضعونها حيث شاءوا؟! ولكنها بيدي أختار مَن أشاء من عبادي للرسالة{2}. (ز) <q>﴿نَحۡنُ قَسَمۡنَا بَیۡنَهُم مَّعِیشَتَهُمۡ فِی ٱلۡحَیَوٰةِ ٱلدُّنۡیَاۚ وَرَفَعۡنَا بَعۡضَهُمۡ فَوۡقَ بَعۡضࣲ دَرَجَـٰتࣲ﴾</q> - تفسير ٦٩٤٥٢- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿نَحْنُ قَسَمْنا بَيْنَهُمْ مَعِيشَتَهُمْ فِي الحَياةِ الدُّنْيا﴾</q> قال: قسَم بينهم معيشتَهم في الحياة الدنيا كما قسَم بينهم صورهم وأخلاقهم، فتعالى -ربّنا وتبارك-، <q>﴿ورَفَعْنا بَعْضَهُمْ فَوْقَ بَعْضٍ دَرَجاتٍ﴾</q> قال: فتَلْقاه ضعيف الحيلة، عييّ اللسان، وهو مبسوط له في الرزق، وتلْقاه شديدَ الحيلة، سَلِيط اللسان{3}، وهو مقتور عليه{4}. (١٣/٢٠٣) ٦٩٤٥٣- قال مقاتل بن سليمان: ثم قال: <q>﴿نَحْنُ قَسَمْنا بَيْنَهُمْ مَعِيشَتَهُمْ فِي الحَياةِ الدُّنْيا﴾</q>، يقول: لم نُعط الوليد وأبا مسعود الذي أعطيناهما مِن الغنى لكرامتهما على الله، ولكنه قسم من الله بينهم{2}. (ز) <q>﴿لِّیَتَّخِذَ بَعۡضُهُم بَعۡضࣰا سُخۡرِیࣰّاۗ﴾</q> - تفسير ٦٩٤٥٤- عن الضَّحّاك بن مُزاحِم -من طريق عبيد بن سليمان- في قوله: <q>﴿لِيَتَّخِذَ بَعْضُهُمْ بَعْضًا سُخْرِيًّا﴾</q>: يعني بذلك: العبيد والخدم، سخّرهم لهم{6}. (ز) ٦٩٤٥٥- عن قتادة بن دعامة -من طريق سعيد- <q>﴿لِيَتَّخِذَ بَعْضُهُمْ بَعْضًا سُخْرِيًّا﴾</q>، قال: ملَكَةً، يتسخّر بعضهم بعضًا، بلاء يبتلي الله به عباده، فاللهَ اللهَ فيما ملكت يمينك!{7}. (١٣/٢٠٣) ٦٩٤٥٦- عن إسماعيل السُّدّيّ -من طريق أسباط- في قوله: <q>﴿لِيَتَّخِذَ بَعْضُهُمْ بَعْضًا سُخْرِيًّا﴾</q>، قال: يستخدم بعضهم بعضًا في السُّخرة{8}. (ز) ٦٩٤٥٧- قال مقاتل بن سليمان: ثم قال: <q>﴿ورَفَعْنا بَعْضَهُمْ فَوْقَ بَعْضٍ دَرَجاتٍ﴾</q> يعني: فضائل في الغنى؛ <q>﴿لِيَتَّخِذَ بَعْضُهُمْ﴾</q> يعني: الأحرار <q>﴿بَعْضًا﴾</q> يعني: الخَدَم <q>﴿سُخْرِيًّا﴾</q> يعني: العبيد والخَدَم، سخّره الله لهم{2}. (ز) ٦٩٤٥٨- عن سفيان الثوري، قال: في قراءة عبد الله [بن مسعود]: <q>﴿لِيَتَّخِذَ بَعْضُهُمْ بَعْضًا سُخْرِيًّا﴾</q>، قال: الخَدَم{10}. (ز) ٦٩٤٥٩- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿لِيَتَّخِذَ بَعْضُهُمْ بَعْضًا سُخْرِيًّا﴾</q>، قال: هم بنو آدم جميعًا. قال: وهذا عبد هذا، ورفع الله هذا على هذا درجة؛ فهو يسخّره بالعمل، يستعمله به، كما يقال: سخّر فلان فلانًا{8}٥٨٥٧. (ز) ٥٨٥٧ اختُلف في معنى قوله: <q>﴿ليتخذ بعضهم بعضا سخريًّا﴾</q> على قولين: الأول: ليستخدم الأغنياء الفقراء بأموالهم، فيلتَئِم قِوامَ العالم. الثاني: ليملك بعضُهم بعضًا. وذكر ابنُ كثير (١٢/٣١٠) أن القول الثاني الذي قاله قتادة، ومقاتل، والضَّحّاك راجع إلى الأول. <q>﴿وَرَحۡمَتُ رَبِّكَ خَیۡرࣱ مِّمَّا یَجۡمَعُونَ ۝٣٢﴾</q> - تفسير ٦٩٤٦٠- عن قتادة بن دعامة -من طريق سعيد- <q>﴿ورَحْمَتُ رَبِّكَ خَيْرٌ مِمّا يَجْمَعُونَ﴾</q>، قال: الجنة{7}٥٨٥٨. (١٣/٢٠٣) ٥٨٥٨ ساق ابنُ عطية (٧/٥٤٥) هذا القول، ثم علَّق بقوله: «ولا شك أن الجنة هي الغاية، ورحمة الله في الدنيا بالهداية والايمان خيرٌ مِن كل مال». ٦٩٤٦١- قال مقاتل بن سليمان: <q>﴿ورَحْمَتُ رَبِّكَ يعني الجنة خَيْرٌ مِمّا يَجْمَعُونَ﴾</q>، يعني: الأموال، يعني: الكفار{2}. (ز) ",footnotes:1:أخرجه أحمد ٦/١٨٩ (٣٦٧٢)، والحاكم ٢/٤٨٥ (٣٦٧١). وقال الحاكم: «هذا حديث صحيح الإسناد، ولم يخرجاه». قال الهيثمي في المجمع ١/٥٣ (١٦٤): «رواه أحمد، ورجال إسناده بعضهم مستور، وأكثرهم ثقات». وقال البوصيري في إتحاف الخيرة ١/٨٢ (٣٣): «هذا ضعيف، الصباح بن محمد أبو حازم البجلي الكوفي مجهول». وأورده الألباني في الصحيحة ٦/٤٨٢ (٢٧١٤).تفسير مقاتل بن سليمان ٣/٧٩٤.رجل سَلِيط: فصيح حديد اللسان. لسان العرب (سلط).أخرجه ابن جرير ٢٠/٥٨٤-٥٨٥. وعزاه السيوطي إلى عَبد بن حُمَيد، وابن المنذر.تفسير مقاتل بن سليمان ٣/٧٩٤.أخرجه ابن جرير ٢٠/٥٨٦.أخرجه ابن جرير ٢٠/٥٨٦. وعزاه السيوطي إلى عَبد بن حُمَيد، وابن المنذر.أخرجه ابن جرير ٢٠/٥٨٥.تفسير مقاتل بن سليمان ٣/٧٩٤.تفسير سفيان الثوري ص٢٧١.أخرجه ابن جرير ٢٠/٥٨٥.أخرجه ابن جرير ٢٠/٥٨٦. وعزاه السيوطي إلى عَبد بن حُمَيد، وابن المنذر.تفسير مقاتل بن سليمان ٣/٧٩٤.
43,33," <q>﴿وَلَوۡلَاۤ أَن یَكُونَ ٱلنَّاسُ أُمَّةࣰ وَ ٰ⁠حِدَةࣰ﴾</q> - تفسير ٦٩٤٦٢- عن عبد الله بن عباس -من طريق علي- <q>﴿ولَوْلا أنْ يَكُونَ النّاسُ أُمَّةً واحِدَةً﴾</q> الآية، يقول: لولا أن أجعل الناسَ كلهم كفّارًا لجعلت لبيوت الكفار سُقُفًا مِن فِضّة{1}. (١٣/٢٠٤) ٦٩٤٦٣- عن مجاهد بن جبر، <q>﴿ولَوْلا أنْ يَكُونَ النّاسُ أُمَّةً واحِدَةً﴾</q>، قال: لولا أن يكفروا{2}. (١٣/٢٠٥) ٦٩٤٦٤- عن الحسن البصري -من طريق عوف- في قوله: <q>﴿ولَوْلا أنْ يَكُونَ النّاسُ أُمَّةً واحِدَةً﴾</q>، قال: لولا أن يكون الناسُ أجمعون كُفّارًا، فيميلون إلى الدنيا، لجعل الله لهم الذي قال، قال: وقد مالت الدنيا بأكثر أهلها، وما فعل ذلك، فكيف لو فعله؟!{3}. (١٣/٢٠٥) ٦٩٤٦٥- عن قتادة بن دعامة -من طريق معمر- <q>﴿ولَوْلا أنْ يَكُونَ النّاسُ أُمَّةً واحِدَةً﴾</q>، قال: لولا أن يكون الناس كفّارًا{4}. (١٣/٢٠٥) ٦٩٤٦٦- عن إسماعيل السُّدّيّ -من طريق أسباط- <q>﴿ولَوْلا أنْ يَكُونَ النّاسُ أُمَّةً واحِدَةً﴾</q>، يقول: كفّارًا، على دين واحد{5}. (ز) ٦٩٤٦٧- قال مقاتل بن سليمان: ثم ذكّرهم هوان الدنيا عليه، فقال: <q>﴿ولَوْلا أنْ يَكُونَ النّاسُ أُمَّةً واحِدَةً﴾</q> يعني: مِلّة واحدة، يعني: على الكفر، يقول: لولا أن ترغب الناس في الكفر إذا رأوا الكفار في سَعَةٍ مِن الخير والرزق{6}٥٨٥٩. (ز) ٥٨٥٩ ساق ابنُ عطية (٧/٥٤٥) هذا القول الذي قاله ابن عباس، والسُّدّيّ، وقتادة، ومقاتل، والحسن، ومجاهد، ثم علَّق بقوله: «ومن هذا المعنى قول النبي ﷺ: «لو كانت الدنيا تزن عند الله جناح بعوضة ما سقى كافرًا منها شربة ماء». ثم يتركّب معنى الآية على معنى هذا الحديث». ٦٩٤٦٨- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿ولَوْلا أنْ يَكُونَ النّاسُ أُمَّةً واحِدَةً﴾</q>، قال: لولا أن يختار الناس دنياهم على دينهم لجعَلنا هذا لأهل الكفر{7}. (ز) <q>﴿لَّجَعَلۡنَا لِمَن یَكۡفُرُ بِٱلرَّحۡمَـٰنِ لِبُیُوتِهِمۡ سُقُفࣰا مِّن فِضَّةࣲ﴾</q> - تفسير ٦٩٤٦٩- عن ابن عباس، قال: قال رسول الله ﷺ: «يقول الله: لولا أن يجزع عبدي المؤمن لَعصبْتُ الكافر عصابة من حديد، فلا يشتكي شيئًا أبدًا، ولصببتُ عليه الدنيا صبًّا». قال ابن عباس: قد أنزل اللهُ شبه ذلك في كتابه في قوله: <q>﴿ولَوْلا أنْ يَكُونَ النّاسُ أُمَّةً واحِدَةً لَجَعَلْنا لِمَن يَكْفُرُ بِالرَّحْمَنِ﴾</q> الآية{8}. (١٣/٢٠٤) ٦٩٤٧٠- عن مجاهد بن جبر -من طريق شبل- قال: كلُّ شيء مِن بيوت أهل الدنيا فهو سُقُف، وما كان من السماء فهو سَقْف{9}. (ز) ٦٩٤٧١- عن عامر الشعبي -من طريق إسماعيل بن سالم- في قوله: <q>﴿سُقُفًا﴾</q>، قال: الجذوع{10}. (١٣/٢٠٥) ٦٩٤٧٢- عن قتادة بن دعامة -من طريق سعيد- <q>﴿لَجَعَلْنا لِمَن يَكْفُرُ بِالرَّحْمَنِ لِبُيُوتِهِمْ سُقُفًا مِن فِضَّةٍ﴾</q>، قال: السُّقُف: أعالي البيوت{11}. (١٣/٢٠٥) ٦٩٤٧٣- قال مقاتل بن سليمان: <q>﴿لَجَعَلْنا لِمَن يَكْفُرُ بِالرَّحْمنِ﴾</q> لهوان الدنيا عليه <q>﴿لِبُيُوتِهِمْ سُقُفًا مِن فِضَّةٍ﴾</q> يعني بالسُّقُف: سماء البيت{6}. (ز) ٦٩٤٧٤- قال سفيان الثوري، في قوله: <q>﴿لَجَعَلْنا لِمَن يَكْفُرُ بِالرَّحْمَنِ لِبُيُوتِهِمْ سُقُفًا مِن فِضَّةٍ﴾</q>، قال: الجذوع{13}. (ز) <q>﴿وَمَعَارِجَ عَلَیۡهَا یَظۡهَرُونَ ۝٣٣﴾</q> - تفسير ٦٩٤٧٥- عن عبد الله بن عباس -من طريق علي- <q>﴿ومَعارِجَ﴾</q>: ومعارج من فضة، وهي دَرج، <q>﴿عَلَيْها يَظْهَرُونَ﴾</q> يصعدون إلى الغُرف{14}. (١٣/٢٠٤) ٦٩٤٧٦- قال سفيان [بن عُيينة]: في تفسير مجاهد: <q>﴿ومعارج عليها يظهرون﴾</q>، قال: مثل الدّرَج{15}. (ز) ٦٩٤٧٧- عن عامر الشعبي -من طريق إسماعيل بن سالم- في قوله: <q>﴿ومَعارِجَ﴾</q>، قال: الدَّرَج{16}. (١٣/٢٠٥) ٦٩٤٧٨- عن قتادة بن دعامة -من طريق معمر- <q>﴿ومَعارِجَ عَلَيْها يَظْهَرُونَ﴾</q>، قال: دَرج عليها يصعدون{17}. (١٣/٢٠٥) ٦٩٤٧٩- عن إسماعيل السُّدّيّ -من طريق أسباط- <q>﴿ومَعارِجَ عَلَيْها يَظْهَرُونَ﴾</q>، قال: المعارج: المراقي{18}. (ز) ٦٩٤٨٠- قال مقاتل بن سليمان: <q>﴿ومَعارِجَ عَلَيْها يَظْهَرُونَ﴾</q>، يقول: دَرجًا على ظهور بيوتهم يَرْتَقون{6}. (ز) ٦٩٤٨١- قال سفيان الثوري، في قوله: <q>﴿ومَعارِجَ عَلَيْها يَظْهَرُونَ﴾</q>، قال: الدَّرج{13}. (ز) ٦٩٤٨٢- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿ومَعارِجَ عَلَيْها يَظْهَرُونَ﴾</q>، قال: المعارج: درَج من فِضّة{7}. (ز) ",footnotes:1:أخرجه ابن جرير ٢٠/٥٨٧، وابن أبي حاتم -كما في تغليق التعليق ٤/٣٠٥، والفتح ٨/٥٦٦-. وعزاه السيوطي إلى ابن المنذر.عزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ٢٠/٥٨٧ بنحوه. وعزاه السيوطي إلى عَبد بن حُمَيد، وابن المنذر. وذكر أوله يحيى بن سلام -كما في تفسير ابن أبي زمنين ٤/١٨٣-.أخرجه عبد الرزاق ٢/١٩٦، وابن جرير ٢٠/٥٨٨. وعزاه السيوطي إلى عَبد بن حُمَيد.أخرجه ابن جرير ٢٠/٥٨٨.تفسير مقاتل بن سليمان ٣/٧٩٤.أخرجه ابن جرير ٢٠/٥٨٨، ٥٩١.أخرجه ابن عدي في الكامل ٣/١٨١. قال ابن عدي: «ليس بمحفوظ، يرويه حسن بن الحسين، وللحسن بن الحسين أحاديث كثيرة، ولا يشبه حديثه حديث الثقات». وأخرج نحوه إسحاق البستي ص٣١٥ عن سفيان بن عُيَينة، عن مالك بن مغول، عن رجل موقوفًا عليه.أخرجه إسحاق البستي ص٣١٦.عزاه السيوطي إلى عَبد بن حُمَيد، وابن المنذر. وأخرجه إسحاق البستي ص٣١٥ من طريق إسماعيل بن سالم، وجاء في نسخة: الجدوع -دون إعجام-.أخرجه ابن جرير ٢٠/٥٨٨. وعزاه السيوطي إلى عبد الرزاق، وعَبد بن حُمَيد.تفسير مقاتل بن سليمان ٣/٧٩٤.تفسير سفيان الثوري ص٢٧١.أخرج ابن جرير ٢٠/٥٩٠-٥٩١ أوَّله من طريق علي، والشطر الثاني من طريق العوفي، وابن أبي حاتم -كما في تغليق التعليق ٤/٣٠٥، والفتح ٨/٥٦٦-. وعزاه السيوطي إلى ابن المنذر.أخرجه إسحاق البستي ص٣١٥.أخرجه إسحاق البستي ص٣١٥. وعزاه السيوطي إلى عَبد بن حُمَيد، وابن المنذر.أخرجه عبد الرزاق ٢/١٩٦، وابن جرير ٢٠/٥٩١. وعزاه السيوطي إلى عَبد بن حُمَيد.أخرجه ابن جرير ٢٠/٥٩١.تفسير مقاتل بن سليمان ٣/٧٩٤.تفسير سفيان الثوري ص٢٧١.أخرجه ابن جرير ٢٠/٥٨٨، ٥٩١.
