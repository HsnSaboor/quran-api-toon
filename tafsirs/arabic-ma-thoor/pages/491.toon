quran[11]{c,v,t}:
  43,23,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَكَذَ ٰ⁠لِكَ مَاۤ أَرۡسَلۡنَا مِن قَبۡلِكَ فِی قَرۡیَةࣲ مِّن نَّذِیرٍ إِلَّا قَالَ مُتۡرَفُوهَاۤ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٩٣٨٨<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- قوله: <span class="qpc-hafs">﴿وكَذَلِكَ ما أرْسَلْنا مِن قَبْلِكَ فِي قَرْيَةٍ مِن نَذِيرٍ إلّا قالَ مُتْرَفُوها﴾</span>: قادتهم ورءوسهم في الشرك{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٩٣٨٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وكَذَلِكَ﴾</span> يقول: وهكذا <span class="qpc-hafs">﴿ما أرْسَلْنا مِن قَبْلِكَ فِي قَرْيَةٍ مِن نَذِيرٍ﴾</span> يعني: من رسول فيما خلا <span class="qpc-hafs">﴿إلّا قالَ مُتْرَفُوها﴾</span> يعني: جبّاريها وكبراءها{2}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿إِنَّا وَجَدۡنَاۤ ءَابَاۤءَنَا عَلَىٰۤ أُمَّةࣲ وَإِنَّا عَلَىٰۤ ءَاثَـٰرِهِم مُّقۡتَدُونَ ۝٢٣﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٩٣٩٠<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- <span class="qpc-hafs">﴿إنّا وجَدْنا آباءَنا عَلى أُمَّةٍ﴾</span> قال: على مِلّة، <span class="qpc-hafs">﴿وإنّا عَلى آثارِهِمْ مُقْتَدُونَ﴾</span> قال: بفعلهم{3}. (١٣/١٩٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٩٣٩١<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- قوله: <span class="qpc-hafs">﴿وإنّا عَلى آثارِهِمْ مُقْتَدُونَ﴾</span>: فاتّبعوهم على ذلك{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٩٣٩٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿إنّا وجَدْنا آباءَنا عَلى أُمَّةٍ﴾</span> يعني: على مِلّة، <span class="qpc-hafs">﴿وإنّا عَلى آثارِهِمْ مُقْتَدُونَ﴾</span> بأعمالهم، كما قال كفار مكة{2}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه عبد الرزاق ٢/١٩٥ من طريق معمر، وابن جرير ٢٠/٥٧٢، ومن طريق معمر أيضًا.تفسير مقاتل بن سليمان ٣/٧٩٢.تفسير مجاهد ص٥٩٣، وأخرجه ابن جرير ٢٠/٥٧٠، ٥٧٣، وأخرج شطره الأول عبد بن حميد -كما في تغليق التعليق ٤/٣٠٥-. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه ابن جرير ٢٠/٥٧٣.تفسير مقاتل بن سليمان ٣/٧٩٢.
  43,24,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿قَـٰلَ أَوَلَوۡ جِئۡتُكُم بِأَهۡدَىٰ مِمَّا وَجَدتُّمۡ عَلَیۡهِ ءَابَاۤءَكُمۡۖ قَالُوۤا۟ إِنَّا بِمَاۤ أُرۡسِلۡتُم بِهِۦ كَـٰفِرُونَ ۝٢٤﴾</span> - قراءات</h3></p><p><div></p><p><p><span class="item-no">٦٩٣٩٣<span class="dash">-</span></span> قرأ <span class="name-2">عاصم</span>: ‹قُلْ أوَلَوْ جِئْتُكُم› بغير ألف، وبالتاء{1}<span class=comment-ref>٥٨٥١</span>. (١٣/١٩٨)</p></p><p></div></p><p><div><span class=comment-ref>٥٨٥١</span> اختُلف في قراءة قوله: <span class="qpc-hafs">﴿أولو جئتكم﴾</span>؛ <b>فقرأ الجمهور</b>: <span class="qpc-hafs">﴿أولو جئتكم﴾</span> بالتاء، و<b>قرأ غيرهم</b>: ‹أوَلَوْ جِئْناكُمْ› بالنون والألف.</p><p>و<span class="comment-type-3">رجَّح</span> <u>ابنُ جرير</u> (٢٠/٥٧٤) قراءة التاء <span class="mustanad">مستندًا إلى إجماع القراء</span>، فقال: «والقراءة عندنا ما عليه قراء الأمصار؛ لإجماع الحجة مِن القرأة عليه».</div></p><p><h3><span class="qpc-hafs">﴿قَـٰلَ أَوَلَوۡ جِئۡتُكُم بِأَهۡدَىٰ مِمَّا وَجَدتُّمۡ عَلَیۡهِ ءَابَاۤءَكُمۡۖ قَالُوۤا۟ إِنَّا بِمَاۤ أُرۡسِلۡتُم بِهِۦ كَـٰفِرُونَ ۝٢٤﴾</span> - تفسير الآية</h3></p><p><div></p><p><p><span class="item-no">٦٩٣٩٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿قالَ أوَلَوْ جِئْتُكُمْ بِأَهْدى مِمّا وجَدْتُمْ عَلَيْهِ آباءَكُمْ﴾</span> من الدِّين ألا تتّبعوني. فردّوا على النبي ﷺ، فـ<span class="qpc-hafs">﴿قالُوا إنّا بِما أُرْسِلْتُمْ بِهِ كافِرُونَ﴾</span> يعني: بالتوحيد كافرون{2}. (ز)</p></p><p></div></p></div>",footnotes:1:عزاه السيوطي إلى عَبد بن حُمَيد.</p><p>وهي قراءة متواترة، قرأ بها العشرة، ما عدا ابن عامر، وحفصًا عن عاصم؛ فإنهما قرآ: <span class="qpc-hafs">﴿قالَ أوَلَوْ جِئْتُكُم﴾</span>. انظر: النشر ٢/٣٦٩، والإتحاف ص٤٩٥.تفسير مقاتل بن سليمان ٣/٧٩٢.
  43,25,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿فَٱنتَقَمۡنَا مِنۡهُمۡۖ فَٱنظُرۡ كَیۡفَ كَانَ عَـٰقِبَةُ ٱلۡمُكَذِّبِینَ ۝٢٥﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٩٣٩٥<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿فانْتَقَمْنا مِنهُمْ فانْظُرْ كَيْفَ كانَ عاقِبَةُ المُكَذِّبِينَ﴾</span>، قال: شرّ -واللهِ- كان عاقبتهم؛ أخذهم بخسْفٍ وغرَقٍ، فأهلكهم الله، ثم أدخلهم النار{1}. (١٣/١٩٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٩٣٩٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثم رجع إلى الأمم الخالية، فيها تقديم، ثم قال: <span class="qpc-hafs">﴿فانْتَقَمْنا مِنهُمْ﴾</span> بالعذاب، <span class="qpc-hafs">﴿فانْظُرْ كَيْفَ كانَ عاقِبَةُ المُكَذِّبِينَ﴾</span> بالعذاب، يُخَوِّف كُفّار مكة بعذاب الأمم الخالية؛ لئلا يكذِّبوا محمدًا ﷺ{2}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ٢٠/٥٧٤-٥٧٥ بنحوه. وعزاه السيوطي إلى عَبد بن حُمَيد.تفسير مقاتل بن سليمان ٣/٧٩٣.
  43,26,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَإِذۡ قَالَ إِبۡرَ ٰ⁠هِیمُ لِأَبِیهِ وَقَوۡمِهِۦۤ إِنَّنِی بَرَاۤءࣱ مِّمَّا تَعۡبُدُونَ ۝٢٦﴾</span> - قراءات</h3></p><p><div></p><p><p><span class="item-no">٦٩٣٩٧<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن مسعود</span>، أنّه قرأ: (إنَّنِي بَرِيءٌ مِّمّا تَعْبُدُونَ) بالياء{1}. (١٣/١٩٨)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَإِذۡ قَالَ إِبۡرَ ٰ⁠هِیمُ لِأَبِیهِ وَقَوۡمِهِۦۤ إِنَّنِی بَرَاۤءࣱ مِّمَّا تَعۡبُدُونَ ۝٢٦﴾</span> - تفسير الآية</h3></p><p><div></p><p><p><span class="item-no">٦٩٣٩٨<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿إنَّنِي بَراءٌ مِمّا تَعْبُدُونَ إلّا الَّذِي فَطَرَنِي فَإنَّهُ سَيَهْدِينِ﴾</span>، قال: كايَدهم، كانوا يقولون: إنّ الله ربنا، <span class="qpc-hafs">﴿ولَئِنْ سَأَلْتَهُمْ مَن خَلَقَ السموات والأرض لَيَقُولُنَّ اللَّهُ﴾</span> [لقمان:٢٥]، فلم يبرأ مِن ربِّه{2}. (١٣/١٩٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٩٣٩٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وإذْ قالَ إبْراهِيمُ لِأَبِيهِ﴾</span> آزَر <span class="qpc-hafs">﴿وقَوْمِهِ إنَّنِي بَراءٌ مِمّا تَعْبُدُونَ﴾</span> ثم استثنى الرَّبّ نفسه؛ لأنهم يعلمون أن الله ربهم، فقال: <span class="qpc-hafs">﴿إلّا الَّذِي فَطَرَنِي﴾</span>{3}. (ز)</p></p><p></div></p></div>",footnotes:1:عزاه السيوطي إلى الفضل بن شاذان في كتاب القراءات بسنده.</p><p>وهي قراءة شاذة، تروى أيضًا عن الأعمش. انظر: مختصر ابن خالويه ص١٣٦.أخرجه ابن جرير ٢٠/٥٧٧. وعزاه السيوطي إلى عبد بن حميد.تفسير مقاتل بن سليمان ٣/٧٩٣.
  43,27,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿إِلَّا ٱلَّذِی فَطَرَنِی فَإِنَّهُۥ سَیَهۡدِینِ ۝٢٧﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٩٤٠٠<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- <span class="qpc-hafs">﴿إلّا الَّذِي فَطَرَنِي﴾</span>، قال: خَلقني{1}. (١٣/١٩٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٩٤٠١<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدّيّ</span> -من طريق أسباط- <span class="qpc-hafs">﴿إلّا الَّذِي فَطَرَنِي﴾</span>، قال: خلقني{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٩٤٠٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿إلّا الَّذِي فَطَرَنِي﴾</span> يقول: خلقني، فإنِّي لا أتبرأ منه، <span class="qpc-hafs">﴿فَإنَّهُ سَيَهْدِينِ﴾</span> لدينه{3}<span class=comment-ref>٥٨٥٢</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٥٨٥٢</span> <span class="comment-type-4">ذكر</span> <u>ابنُ عطية</u> (٧/٥٤٢) أن <b>فرقة قالت</b>: قوله: <span class="qpc-hafs">﴿إلّا الَّذِي فَطَرَنِي﴾</span> الاستثناء متصل، وكانوا يعرفون الله ويعظّمونه، إلا أنهم كانوا يشركون معه أصنامهم، فكأن إبراهيم قال لهم: أنا لا أوافقكم إلا على عبادة الله الفاطر. ثم <span class="comment-type-4">ذكر</span> قولًا آخر، فقال: «<b>وقالت فرقة</b>:الاستثناء منقطع، والمعنى: لكن الذي فطرني معبودي، وعلى هذا فلم يكونوا يعبدون الله لا قليلًا ولا كثيرًا».</div></p></div>",footnotes:1:أخرجه عبد الرزاق ٢/١٩٥، وابن جرير ٢٠/٥٧٦.أخرجه ابن جرير ٢٠/٥٧٦.تفسير مقاتل بن سليمان ٣/٧٩٣.
  43,28,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَجَعَلَهَا كَلِمَةَۢ بَاقِیَةࣰ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٩٤٠٣<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، <span class="qpc-hafs">﴿وجَعَلَها كَلِمَةً باقِيَةً﴾</span>، قال: لا إله إلا الله{1}. (١٣/٢٠٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٩٤٠٤<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ليث- <span class="qpc-hafs">﴿وجَعَلَها كَلِمَةً باقِيَةً فِي عَقِبِهِ﴾</span>، قال: لا إله إلا الله{2}<span class=comment-ref>٥٨٥٣</span>. (١٣/١٩٩)</p></p><p></div></p><p><div><span class=comment-ref>٥٨٥٣</span> <span class="comment-type-4">ذكر</span> <u>ابنُ عطية</u> (٧/٥٤٣) أن الضمير في قوله: <span class="qpc-hafs">﴿وجعلها﴾</span> عائد على كلمة التوحيد -على هذا القول الذي قاله ابن عباس، وعكرمة من طريق ليث، ومجاهد، والسُّدّيّ، وقتادة، ومقاتل-، ثم <span class="comment-type-4">علَّق</span> بقوله: «وعاد الضمير عليها وإن كانت لم يجرِ لها ذكر؛ لأنّ اللفظ يتضمنها».</div></p><p><div></p><p><p><span class="item-no">٦٩٤٠٥<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span> -من طريق ليث- <span class="qpc-hafs">﴿وجَعَلَها كَلِمَةً باقِيَةً﴾</span>، قال: لا إله إلا الله{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٩٤٠٦<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span>، <span class="qpc-hafs">﴿وجَعَلَها كَلِمَةً باقِيَةً فِي عَقِبِهِ﴾</span>، قال: هي الإسلام، أوصى بها ولده{4}. (١٣/١٩٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٩٤٠٧<span class="dash">-</span></span> قال <span class="name-2">محمد بن كعب القُرَظي</span>: <span class="qpc-hafs">﴿وجَعَلَها كَلِمَةً باقِيَةً فِي عَقِبِهِ﴾</span>، يعني: وجعَل وصيّة إبراهيم التي أوصى بها بَنيه باقيةً في نَسْله وذرّيته{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٩٤٠٨<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿وجَعَلَها كَلِمَةً باقِيَةً فِي عَقِبِهِ﴾</span>، قال: شهادة أن لا إله إلا الله، والتوحيد، لا يزال في ذُرّيته مَن يقولها مِن بعدِه{6}. (١٣/١٩٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٩٤٠٩<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- <span class="qpc-hafs">﴿وجَعَلَها كَلِمَةً باقِيَةً فِي عَقِبِهِ﴾</span>، قال: الإخلاص والتوحيد، لا يزال في ذُرّيته مَن يُوحّد اللهَ ويعبده{7}. (١٣/١٩٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٩٤١٠<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدّيّ</span> -من طريق أسباط- <span class="qpc-hafs">﴿وجَعَلَها كَلِمَةً باقِيَةً﴾</span>، قال: لا إله إلا الله{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٩٤١١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: قوله تعالى: <span class="qpc-hafs">﴿وجَعَلَها كَلِمَةً باقِيَةً﴾</span> لا تزال ببقاء التوحيد{9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٩٤١٢<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿وجَعَلَها كَلِمَةً باقِيَةً فِي عَقِبِهِ﴾</span> قال: الإسلام. وقرأ: <span class="qpc-hafs">﴿أسْلَمْتُ لِرَبِّ العالَمِينَ﴾</span> [البقرة:١٣١]، قال: جعل هذه باقية في عَقِبه، وقال: الإسلام. وقرأ: <span class="qpc-hafs">﴿هُوَ سَمّاكُمُ المُسْلِمِينَ مِن قَبْلُ﴾</span> [الحج:٧٨]، وقرأ: <span class="qpc-hafs">﴿واجْعَلْنا مُسْلِمَيْنِ لَكَ﴾</span> [البقرة:١٢٨]{8}<span class=comment-ref>٥٨٥٤</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٥٨٥٤</span> <span class="comment-type-4">ذكر</span> <u>ابنُ كثير</u> (٧/٣٠٩) أن هذا القول الذي قاله ابن زيد وعكرمة راجع إلى قول الجماعة بأن الكلمة هي كلمة التوحيد.</div></p><p><h3><span class="qpc-hafs">﴿فِی عَقِبِهِۦ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٩٤١٣<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، <span class="qpc-hafs">﴿فِي عَقِبِهِ﴾</span>، قال: عَقِب إبراهيم: ولده{1}. (١٣/٢٠٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٩٤١٤<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطية العَوفيّ- <span class="qpc-hafs">﴿وجَعَلَها كَلِمَةً باقِيَةً فِي عَقِبِهِ﴾</span>: يعني: مَن خَلَفه{12}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٩٤١٥<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- <span class="qpc-hafs">﴿فِي عَقِبِهِ﴾</span>، قال: ولده{13}. (١٣/١٩٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٩٤١٦<span class="dash">-</span></span> عن <span class="name-2">زيد بن علي</span>، قال: ... <span class="qpc-hafs">﴿وجعلها كلمة باقية في عقبه﴾</span>، فمحمد ﷺ وآله مِن عَقِب إبراهيم{14}. (٨/١٠٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٩٤١٧<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدّيّ</span> -من طريق أسباط- <span class="qpc-hafs">﴿فِي عَقِبِهِ﴾</span>، قال: في عقِب إبراهيم؛ آل محمد ﷺ{12}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٩٤١٨<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: قوله تعالى: <span class="qpc-hafs">﴿فِي عَقِبِهِ﴾</span> يعني: ذُرّيته، يعني: ذُرّية إبراهيم{9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٩٤١٩<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿فِي عَقِبِهِ﴾</span>، قال: عَقِبه: ذُرّيته{17}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿فِی عَقِبِهِۦ﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٦٩٤٢٠<span class="dash">-</span></span> عن عَبِيدة، قال: قلت <span class="name-2">لإبراهيم</span>: ما العَقِب؟ قال: ولده الذكَر{1}. (١٣/٢٠٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٩٤٢١<span class="dash">-</span></span> عن <span class="name-2">عطاء</span>، في رجل أسكنه رجل له ولعقِبه من بعده، أتكون امرأته مِن عَقِبه؟ قال: لا، ولكن ولده عَصَبته{1}. (١٣/٢٠٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٩٤٢٢<span class="dash">-</span></span> عن <span class="name-2">محمد بن شهاب الزّهري</span>، قال: عَقِب الرجل: ولده الذّكور والإناث، وأولاد الذّكور{20}. (١٣/٢٠٠)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿لَعَلَّهُمۡ یَرۡجِعُونَ ۝٢٨﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٩٤٢٣<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿لعلهم يرجعون﴾</span>، قال: يتوبون، أو يذكّرون{21}. (١٣/١٩٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٩٤٢٤<span class="dash">-</span></span> قال <span class="name-2">إسماعيل السُّدّيّ</span>: <span class="qpc-hafs">﴿لَعَلَّهُمْ يَرْجِعُونَ﴾</span> لعلهم يتوبون ويرجعون إلى طاعة الله ﷿{22}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٩٤٢٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿لَعَلَّهُمْ﴾</span> يعني: لكي <span class="qpc-hafs">﴿يَرْجِعُونَ﴾</span> من الكفر إلى الإيمان، يقول: التوحيد إلى يوم القيامة يبقى في ذُرّية إبراهيم ﵇، <span class="qpc-hafs">﴿لَعَلَّهُمْ يَرْجِعُونَ﴾</span> يقول: لكي يرجعوا من الكفر إلى الإيمان{9}. (ز)</p></p><p></div></p></div>",footnotes:1:عزاه السيوطي إلى عَبد بن حُمَيد.أخرجه سفيان الثوري ص٢٧٠، وابن جرير ٢٠/٥٧٦. وعزاه السيوطي إلى عَبد بن حُمَيد، وابن المنذر.أخرجه سفيان الثوري ص٢٧٠، كما أخرجه الطبراني في الدعاء ٣/١٥٠٧ من طريق الحكم بن أبان.عزاه السيوطي إلى ابن أبي حاتم.تفسير الثعلبي ٨/٣٣٢، وتفسير البغوي ٧/٢١٠.أخرجه ابن جرير ٢٠/٥٧٧، والبيهقي في الأسماء والصفات (٢٠٩). وعزاه السيوطي إلى عَبد بن حُمَيد.أخرجه عبد الرزاق ٢/١٩٦، وابن جرير ٢٠/٥٧٧ بنحوه. وعزاه السيوطي إلى ابن المنذرأخرجه ابن جرير ٢٠/٥٧٧.تفسير مقاتل بن سليمان ٣/٧٩٣.أخرجه ابن جرير ٢٠/٥٧٧.عزاه السيوطي إلى عَبد بن حُمَيد.أخرجه ابن جرير ٢٠/٥٧٨.أخرجه ابن جرير ٢٠/٥٧٨، وعبد بن حميد -كما في الفتح ٨/٥٦٧-. وذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٤/١٨٢-. وعزاه السيوطي إلى عَبد بن حُمَيد، وابن المنذر.عزاه السيوطي إلى أبي الشيخ.أخرجه ابن جرير ٢٠/٥٧٨.تفسير مقاتل بن سليمان ٣/٧٩٣.أخرجه ابن جرير ٢٠/٥٧٧-٥٧٨.عزاه السيوطي إلى عَبد بن حُمَيد.عزاه السيوطي إلى عَبد بن حُمَيد.عزاه السيوطي إلى عَبد بن حُمَيد. وأخرجه ابن جرير ٢٠/٥٨٧ من طريق ابن أبي ذئب، بلفظ: الولد، وولد الولد.أخرجه ابن جرير ٢٠/٥٧٩، والبيهقي في الأسماء والصفات (٢٠٩). وعزاه السيوطي إلى عَبد بن حُمَيد.تفسير البغوي ٧/٢١١.تفسير مقاتل بن سليمان ٣/٧٩٣.
  43,29,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿بَلۡ مَتَّعۡتُ هَـٰۤؤُلَاۤءِ وَءَابَاۤءَهُمۡ حَتَّىٰ جَاۤءَهُمُ ٱلۡحَقُّ وَرَسُولࣱ مُّبِینࣱ ۝٢٩﴾</span> - قراءات</h3></p><p><div></p><p><p><span class="item-no">٦٩٤٢٦<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span>، أنّه كان يقرؤها: (بَلْ مَتَّعْتَ هَؤُلَآءِ) بنصب التاء{1}. (١٣/٢٠٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٩٤٢٧<span class="dash">-</span></span> عن <span class="name-2">عاصم</span>، أنّه قرأ: <span class="qpc-hafs">﴿بَلْ مَتَّعْتُ﴾</span> برفع التاء{2}<span class=comment-ref>٥٨٥٥</span>. (١٣/٢٠٠)</p></p><p></div></p><p><div><span class=comment-ref>٥٨٥٥</span> اختُلف في قراءة قوله: <span class="qpc-hafs">﴿متعت﴾</span>؛ <b>فقرأ الجمهور</b> بضم التاء، <b>وقرأ غيرهم</b> بفتحها. و<span class="comment-type-4">ذكر</span> <u>ابنُ عطية</u> (٧/٥٤٣) أن الأعمش قرأ: (بَلْ مَتَّعْنا)، ثم <span class="comment-type-4">علَّق</span> بقوله: «وهي تعضد قراءة الجمهور».</div></p><p><h3><span class="qpc-hafs">﴿بَلۡ مَتَّعۡتُ هَـٰۤؤُلَاۤءِ وَءَابَاۤءَهُمۡ حَتَّىٰ جَاۤءَهُمُ ٱلۡحَقُّ وَرَسُولࣱ مُّبِینࣱ ۝٢٩﴾</span> - تفسير الآية</h3></p><p><div></p><p><p><span class="item-no">٦٩٤٢٨<span class="dash">-</span></span> قال <span class="name-2">الضَّحّاك بن مُزاحِم</span>: <span class="qpc-hafs">﴿حَتّى جاءَهُمُ الحَقُّ﴾</span> الإسلام{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٩٤٢٩<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span>: (بَلْ مَتَّعْتَ هَؤُلاءِ وآباءَهُمْ حَتّى جاءَهُمُ الحَقُّ ورَسُولٌ مُبِينٌ)، قال: هذا قول أهل الكتاب لهذه الأمة{4}. (١٣/٢٠٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٩٤٣٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: قوله: <span class="qpc-hafs">﴿بَلْ مَتَّعْتُ هؤُلاءِ﴾</span> يعني: كفار مكة <span class="qpc-hafs">﴿وآباءَهُمْ حَتّى جاءَهُمُ الحَقُّ﴾</span> يعني: القرآن، <span class="qpc-hafs">﴿ورَسُولٌ مُبِينٌ﴾</span> يعني: محمدًا ﷺ بيِّنٌ أمره{5}. (ز)</p></p><p></div></p></div>",footnotes:1:عزاه السيوطي إلى عَبد بن حُمَيد، وابن المنذر.</p><p>وهي قراءة شاذة، تروى أيضًا عن الأعمش، وقراءة العشرة: <span class="qpc-hafs">﴿بَلْ مَتَّعْتُ﴾</span> برفع التاء. انظر: المحرر الوجيز ٥/٥٢، والبحر المحيط ٨/١٤.عزاه السيوطي إلى عَبد بن حُمَيد.تفسير الثعلبي ٨/٣٣٢، وتفسير البغوي ٧/٢١١.عزاه السيوطي إلى عَبد بن حُمَيد، وابن المنذر.تفسير مقاتل بن سليمان ٣/٧٩٣.
  43,30,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَلَمَّا جَاۤءَهُمُ ٱلۡحَقُّ قَالُوا۟ هَـٰذَا سِحۡرࣱ وَإِنَّا بِهِۦ كَـٰفِرُونَ ۝٣٠﴾</span> - نزول الآية</h3></p><p><div></p><p><p><span class="item-no">٦٩٤٣١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: نزلت في [أبي] سفيان بن حرب، وأبي جهل بن هشام، وعُتبة، وشيبة ...{1}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَلَمَّا جَاۤءَهُمُ ٱلۡحَقُّ قَالُوا۟ هَـٰذَا سِحۡرࣱ وَإِنَّا بِهِۦ كَـٰفِرُونَ ۝٣٠﴾</span> - تفسير الآية</h3></p><p><div></p><p><p><span class="item-no">٦٩٤٣٢<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدّيّ</span> -من طريق أسباط- <span class="qpc-hafs">﴿ولَمّا جاءَهُمُ الحَقُّ قالُوا هَذا سِحْرٌ﴾</span>، قال: هؤلاء قريش، قالوا للقرآنِ الذي جاء به محمدٌ ﷺ: هذا سحر{2}. (١٣/٢٠١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٩٤٣٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ولَمّا جاءَهُمُ الحَقُّ﴾</span> يعني: القرآن <span class="qpc-hafs">﴿قالُوا هَذا﴾</span> القرآن <span class="qpc-hafs">﴿سِحْرٌ﴾</span>، <span class="qpc-hafs">﴿وإنّا بِهِ كافِرُونَ﴾</span> لا نؤمن به ...{1}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٣/٧٩٣.أخرجه ابن جرير ٢٠/٥٨٠.تفسير مقاتل بن سليمان ٣/٧٩٣.
  43,31,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَقَالُوا۟ لَوۡلَا نُزِّلَ هَـٰذَا ٱلۡقُرۡءَانُ عَلَىٰ رَجُلࣲ مِّنَ ٱلۡقَرۡیَتَیۡنِ عَظِیمٍ ۝٣١﴾</span> - نزول الآية</h3></p><p><div></p><p><p><span class="item-no">٦٩٤٣٤<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- قال: قال الوليد بن المُغيرة: لو كان ما يقول محمد حقًّا أُنزل عَلَيَّ هذا القرآن، أو على عُروة بن مسعود الثَّقفي. فنزلت: <span class="qpc-hafs">﴿لَوْلا نُزِّلَ هَذا القُرْآنُ عَلى رَجُلٍ مِنَ القَرْيَتَيْنِ عَظِيمٍ﴾</span>{1}. (١٣/٢٠٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٩٤٣٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: .... قال الوليد بن المُغيرة: لو كان هذا القرآنُ حقًّا أُنزل عليَّ أو على أبي مسعود الثَّقفي -واسمه: عمرو بن عمير بن عوف جدّ المختار-. فأنزل الله تعالى في قول الوليد بن المُغيرة: <span class="qpc-hafs">﴿وقالُوا لَوْلا نُزِّلَ هذا القُرْآنُ عَلى رَجُلٍ مِنَ القَرْيَتَيْنِ عَظِيمٍ﴾</span>{2}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَقَالُوا۟ لَوۡلَا نُزِّلَ هَـٰذَا ٱلۡقُرۡءَانُ عَلَىٰ رَجُلࣲ مِّنَ ٱلۡقَرۡیَتَیۡنِ عَظِیمٍ ۝٣١﴾</span> - تفسير الآية</h3></p><p><div></p><p><p><span class="item-no">٦٩٤٣٦<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، أنّه سُئِل عن قول الله: <span class="qpc-hafs">﴿لَوْلا نُزِّلَ هَذا القُرْآنُ عَلى رَجُلٍ مِنَ القَرْيَتَيْنِ عَظِيمٍ﴾</span>، ما القريتان؟ قال: الطائف ومكة. قيل: فمَن الرجلان؟ قال: عروة بن مسعود، وجبّار قريش{3}. (١٣/٢٠١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٩٤٣٧<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطية- أنّه سُئِل عن قول الله: <span class="qpc-hafs">﴿لَوْلا نُزِّلَ هَذا القُرْآنُ عَلى رَجُلٍ مِنَ القَرْيَتَيْنِ عَظِيمٍ﴾</span>. قال: يعني بالقريتين: مكة، والطائف. والعظيم: الوليد بن المغيرة القُرشي، وحبيب بن عمرو الثَّقفي{4}. (١٣/٢٠١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٩٤٣٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، في قوله: <span class="qpc-hafs">﴿لَوْلا نُزِّلَ هَذا القُرْآنُ عَلى رَجُلٍ مِنَ القَرْيَتَيْنِ عَظِيمٍ﴾</span>، قال: يعنون: أشرفَ من محمد؛ الوليد بن المُغيرة مِن أهل مكة؛ ومسعود بن عمرو الثَّقفي من أهل الطائف{5}. (١٣/٢٠٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٩٤٣٩<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عمران الطائفي، عن خاله- في قول الله: <span class="qpc-hafs">﴿لَوْلا نُزِّلَ هَذا القُرْآنُ عَلى رَجُلٍ مِنَ القَرْيَتَيْنِ عَظِيمٍ﴾</span>، قال: الطائف، ومكة. قال: العظيم: أحدهما المختار ابن أبي عبيد{6}، والآخر من عظماء قريش{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٩٤٤٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق أبي روْق، عن الضَّحّاك- قال: لَمّا بعث اللهُ محمدًا رسولًا أنكرت العربُ ذلك –أو مَن أنكر منهم-، فقالوا: اللهُ أعظمُ مِن أن يكون رسولُه بشرًا مثل محمد. قال: فأنزل الله ﷿: <span class="qpc-hafs">﴿أكانَ لِلنّاسِ عَجَبًا أنْ أوْحَيْنا إلى رَجُلٍ مِنهُمْ أنْ أنْذِرِ النّاسَ﴾</span> [يونس:٢]، وقال: <span class="qpc-hafs">﴿وما أرْسَلْنا مِن قَبْلِكَ إلّا رِجالًا نُوحِي إلَيْهِمْ فاسْأَلُوا أهْلَ الذِّكْرِ﴾</span> [النحل:٤٣]. يعني: أهل الكتب الماضية: أبشرًا كانت الرسل التي أتَتْكم أم ملائكة؟ فإن كانوا ملائكة أتَتْكم، وإن كانوا بشرًا فلا تنكرون أن يكون محمدٌ رسولًا. قال: ثم قال: <span class="qpc-hafs">﴿وما أرْسَلْنا مِن قَبْلِكَ إلّا رِجالًا نُوحِي إلَيْهِمْ مِن أهْلِ القُرى﴾</span> [يوسف:١٠٩]، أي: ليسوا مِن أهل السماء كما قلتم. قال: فلما كرّر الله عليهم الحُجَج قالوا: فإذ كان بشرًا فغيرُ محمد كان أحقَّ بالرسالة، و<span class="qpc-hafs">﴿لَوْلا نُزِّلَ هَذا القُرْآنُ عَلى رَجُلٍ مِنَ القَرْيَتَيْنِ عَظِيمٍ﴾</span>. يقولون: أشرفُ مِن محمد ﷺ، يعنون: الوليد بن المُغيرة المخزومي، وكان يُسمّى ريحانة قريش، هذا مِن مكة، ومسعود بن عمرو بن عبيد الله الثَّقفي مِن أهل الطائف. قال: يقول الله ﷿ ردًّا عليهم: <span class="qpc-hafs">﴿أهُمْ يَقْسِمُونَ رَحْمَتَ رَبِّكَ﴾</span>؟! أنا أفعل ما شئتُ{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٩٤٤١<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿عَلى رَجُلٍ مِنَ القَرْيَتَيْنِ عَظِيمٍ﴾</span>، قال: عُتبة بن ربيعة من مكة، وابن عبد ياليل بن كنانة الثَّقفي من الطائف. وفي لفظ: وعمير بن مسعود الثَّقفي. وفي لفظ: وأبو مسعود الثَّقفي{9}. (١٣/٢٠٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٩٤٤٢<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن جُريْج- في قوله: <span class="qpc-hafs">﴿وقالُوا لَوْلا نُزِّلَ هَذا القُرْآنُ عَلى رَجُلٍ مِنَ القَرْيَتَيْنِ عَظِيمٍ﴾</span>، قال: هو عُتبة بن ربيعة، وكان ريحانة قريش يومئذ{10}. (١٣/٢٠٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٩٤٤٣<span class="dash">-</span></span> قال <span class="name-2">مجاهد بن جبر</span>: يعني: كنانة{11}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٩٤٤٤<span class="dash">-</span></span> عن <span class="name-2">عامر الشعبي</span>، في قوله: <span class="qpc-hafs">﴿عَلى رَجُلٍ مِنَ القَرْيَتَيْنِ عَظِيمٍ﴾</span>، قال: هو الوليد بن المُغيرة المخزومي، وعبد ياليل بن عمرو الثَّقفي{12}. (١٣/٢٠٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٩٤٤٥<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿وقالُوا لَوْلا نُزِّلَ هَذا القُرْآنُ عَلى رَجُلٍ مِنَ القَرْيَتَيْنِ عَظِيمٍ﴾</span>، قال: القريتان: مكة، والطائف، قال ذلك مشركو قريش. قال: بلغنا: أنّه ليس فَخِذٌ من قريش إلا قد ادّعته، فقالوا: هو مِنّا. وكنا نُحَدَّث: أنه الوليد بن المُغيرة، وعُروة بن مسعود الثَّقفي. قال: يقولون: فهلّا كان أُنزِل على أحد هذين الرجلين، ليس على محمد{13}. (١٣/٢٠٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٩٤٤٦<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدّيّ</span> -من طريق أسباط- <span class="qpc-hafs">﴿عَلى رَجُلٍ مِنَ القَرْيَتَيْنِ عَظِيمٍ﴾</span>، قال: الوليد بن المغيرة القرشي، أو كنانة بن عبد عمرو بن عمير عظيم أهل الطائف{14}. (١٣/٢٠٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٩٤٤٧<span class="dash">-</span></span> عن <span class="name-2">عطاء الخُراساني</span> -من طريق يونس بن يزيد- في قوله ﷿: <span class="qpc-hafs">﴿من القريتين عظيم﴾</span>، قال: مكة، والطائف{15}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٩٤٤٨<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وقالُوا لَوْلا﴾</span> يعني: هلّا <span class="qpc-hafs">﴿نُزِّلَ هذا القُرْآنُ عَلى رَجُلٍ مِنَ القَرْيَتَيْنِ عَظِيمٍ﴾</span> القريتان: مكة، والطائف، وكان عظمة{16} أنّ الوليد عظيم أهل مكة في الشرف، وأبا مسعود عظيم أهل الطائف في الشرف{17}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٩٤٤٩<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿لَوْلا نُزِّلَ هَذا القُرْآنُ عَلى رَجُلٍ مِنَ القَرْيَتَيْنِ عَظِيمٍ﴾</span>، قال: كان أحد العظيمين عروة بن مسعود الثَّقفي، كان عظيم أهل الطائف{14}<span class=comment-ref>٥٨٥٦</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٥٨٥٦</span> اختُلف في عظيم مكة على قولين: <b>أحدهما</b>: أنه الوليد بن المغيرة. <b>الثاني</b>: عُتبة بن ربيعة. وأما عظيم الطائف ففيه أقوال: <b>الأول</b>: أنه حبيب بن عمر الثَّقفي. <b>الثاني</b>: عمير بن عبد ياليل الثقفي. <b>الثالث</b>: عروة بن مسعود. <b>الرابع</b>: أنه كنانة بن عبد بن عمرو.</p><p><span class="comment-type-3">ورجَّح</span> <u>ابنُ جرير</u> (٢٠/٥٨٢-٥٨٣) العموم فقال: «وأولى الأقوال في ذلك بالصواب أن يقال كما قال -جل ثناؤه- مخبرًا عن هؤلاء المشركين: <span class="qpc-hafs">﴿وقالوا لولا نزل هذا القرآن على رجل من القريتين عظيم﴾</span> إذ كان جائزًا أن يكون بعض هؤلاء، ولم يضع الله -تبارك وتعالى- لنا الدلالةَ على الذين عُنوا منهم في كتابه، ولا على لسان رسوله ﷺ».</p><p>وساق <u>ابنُ عطية</u> (٧/٥٤٤) الأقوال، ثم <span class="comment-type-4">علَّق</span> بقوله: «وإنما قصدوا إلى مَن عظُم ذكره بالسِّنِّ والقِدم، وإلا فرسول الله ﷺ كان حينئذٍ أعظمَ مِن هؤلاء، لكن لما عظُم أولئك قبل مدة النبي ﷺ وفي صباه استمر ذلك لهم».</p><p>وساق <u>ابنُ كثير</u> (١٢/٣١٠) الأقوال، ثم <span class="comment-type-4">علَّق</span> بقوله: «والظاهر: أنّ مرادهم رجلٌ كبيرٌ مِن أي البلدتين كان».</div></p></div>",footnotes:1:عزاه السيوطي إلى ابن المنذر، وابن أبي حاتم. كما أخرجه كل من عبد الرزاق ٢/١٩٦، وابن جرير ٢٠/٥٨١ دون لفظ: «فنزلت: <span class="qpc-hafs">﴿لولا نزل ...﴾</span>».تفسير مقاتل بن سليمان ٣/٧٩٣.عزاه السيوطي إلى عَبد بن حميد، وابن المنذر، وابن مردويه.أخرجه ابن جرير ٢٠/٥٨٠-٥٨١. وعزاه السيوطي إلى ابن أبي حاتم، وابن مردويه.عزاه السيوطي إلى ابن أبي حاتم.كذا وقع في النسخة! ولعل المراد: جد المختار، كما في قول مقاتل السابق.أخرجه سفيان الثوري ص٢٧٠.أخرجه ابن جرير ٢٠/٥٨٣-٥٨٤.أخرجه ابن جرير ٢٠/٥٨١ مختصرًا، وعبد بن حميد -كما في الفتح ٦/٣١٥- مصرحًا بلفظ النُّزول. وعزاه السيوطي إلى عَبد بن حُمَيد، وابن المنذر، وابن أبى حاتم.أخرجه سفيان الثوري ص٢٧١ بنحوه، وإسحاق البستي ص٣١٥، وابن عساكر ٣٨/٢٣٩-٢٤٠.أخرجه ابن أبي حاتم -كما في الفتح ٦/٣١٥-.عزاه السيوطي إلى سعيد بن منصور، وابن المنذر.أخرجه ابن جرير ٢٠/٥٨٢. وذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٤/١٨٢-١٨٣-. وعزاه السيوطي إلى عَبد بن حُمَيد.أخرجه ابن جرير ٢٠/٥٨٢.أخرجه أبو جعفر الرملي في جزئه (تفسير عطاء) ص٩١.كذا في مطبوعة المصدر.تفسير مقاتل بن سليمان ٣/٧٩٤.أخرجه ابن جرير ٢٠/٥٨٢.
  43,32,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿أَهُمۡ یَقۡسِمُونَ رَحۡمَتَ رَبِّكَۚ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٩٤٥٠<span class="dash">-</span></span> عن ابن مسعود، في قوله: <span class="qpc-hafs">﴿أهُمْ يَقْسِمُونَ رَحْمَتَ رَبِّكَ﴾</span>، قال: سمعت رسول الله ﷺ يقول: «<b>إنّ الله قسَم بينكم أخلاقَكم كما قسَم بينكم أرزاقكم، وإنّ الله يعطي الدنيا مَن يحب ومَن لا يحب، ولا يعطي الدين إلا مَن أحبّ، فمَن أعطاه الدين فقد أحبّه</b>»{1}. (١٣/٢٠٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٩٤٥١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: يقول الله تعالى: <span class="qpc-hafs">﴿أهُمْ يَقْسِمُونَ رَحْمَتَ رَبِّكَ﴾</span>، يقول: أبأيديهم مفاتيح الرسالة فيضعونها حيث شاءوا؟! ولكنها بيدي أختار مَن أشاء من عبادي للرسالة{2}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿نَحۡنُ قَسَمۡنَا بَیۡنَهُم مَّعِیشَتَهُمۡ فِی ٱلۡحَیَوٰةِ ٱلدُّنۡیَاۚ وَرَفَعۡنَا بَعۡضَهُمۡ فَوۡقَ بَعۡضࣲ دَرَجَـٰتࣲ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٩٤٥٢<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿نَحْنُ قَسَمْنا بَيْنَهُمْ مَعِيشَتَهُمْ فِي الحَياةِ الدُّنْيا﴾</span> قال: قسَم بينهم معيشتَهم في الحياة الدنيا كما قسَم بينهم صورهم وأخلاقهم، فتعالى -ربّنا وتبارك-، <span class="qpc-hafs">﴿ورَفَعْنا بَعْضَهُمْ فَوْقَ بَعْضٍ دَرَجاتٍ﴾</span> قال: فتَلْقاه ضعيف الحيلة، عييّ اللسان، وهو مبسوط له في الرزق، وتلْقاه شديدَ الحيلة، سَلِيط اللسان{3}، وهو مقتور عليه{4}. (١٣/٢٠٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٩٤٥٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثم قال: <span class="qpc-hafs">﴿نَحْنُ قَسَمْنا بَيْنَهُمْ مَعِيشَتَهُمْ فِي الحَياةِ الدُّنْيا﴾</span>، يقول: لم نُعط الوليد وأبا مسعود الذي أعطيناهما مِن الغنى لكرامتهما على الله، ولكنه قسم من الله بينهم{2}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿لِّیَتَّخِذَ بَعۡضُهُم بَعۡضࣰا سُخۡرِیࣰّاۗ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٩٤٥٤<span class="dash">-</span></span> عن <span class="name-2">الضَّحّاك بن مُزاحِم</span> -من طريق عبيد بن سليمان- في قوله: <span class="qpc-hafs">﴿لِيَتَّخِذَ بَعْضُهُمْ بَعْضًا سُخْرِيًّا﴾</span>: يعني بذلك: العبيد والخدم، سخّرهم لهم{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٩٤٥٥<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿لِيَتَّخِذَ بَعْضُهُمْ بَعْضًا سُخْرِيًّا﴾</span>، قال: ملَكَةً، يتسخّر بعضهم بعضًا، بلاء يبتلي الله به عباده، فاللهَ اللهَ فيما ملكت يمينك!{7}. (١٣/٢٠٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٩٤٥٦<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدّيّ</span> -من طريق أسباط- في قوله: <span class="qpc-hafs">﴿لِيَتَّخِذَ بَعْضُهُمْ بَعْضًا سُخْرِيًّا﴾</span>، قال: يستخدم بعضهم بعضًا في السُّخرة{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٩٤٥٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثم قال: <span class="qpc-hafs">﴿ورَفَعْنا بَعْضَهُمْ فَوْقَ بَعْضٍ دَرَجاتٍ﴾</span> يعني: فضائل في الغنى؛ <span class="qpc-hafs">﴿لِيَتَّخِذَ بَعْضُهُمْ﴾</span> يعني: الأحرار <span class="qpc-hafs">﴿بَعْضًا﴾</span> يعني: الخَدَم <span class="qpc-hafs">﴿سُخْرِيًّا﴾</span> يعني: العبيد والخَدَم، سخّره الله لهم{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٩٤٥٨<span class="dash">-</span></span> عن <span class="name-3">سفيان الثوري</span>، قال: في قراءة <span class="name-1">عبد الله [بن مسعود]</span>: <span class="qpc-hafs">﴿لِيَتَّخِذَ بَعْضُهُمْ بَعْضًا سُخْرِيًّا﴾</span>، قال: الخَدَم{10}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٩٤٥٩<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿لِيَتَّخِذَ بَعْضُهُمْ بَعْضًا سُخْرِيًّا﴾</span>، قال: هم بنو آدم جميعًا. قال: وهذا عبد هذا، ورفع الله هذا على هذا درجة؛ فهو يسخّره بالعمل، يستعمله به، كما يقال: سخّر فلان فلانًا{8}<span class=comment-ref>٥٨٥٧</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٥٨٥٧</span> اختُلف في معنى قوله: <span class="qpc-hafs">﴿ليتخذ بعضهم بعضا سخريًّا﴾</span> على قولين: <b>الأول</b>: ليستخدم الأغنياء الفقراء بأموالهم، فيلتَئِم قِوامَ العالم. <b>الثاني</b>: ليملك بعضُهم بعضًا.</p><p>و<span class="comment-type-4">ذكر</span> <u>ابنُ كثير</u> (١٢/٣١٠) أن القول الثاني الذي قاله قتادة، ومقاتل، والضَّحّاك راجع إلى الأول.</div></p><p><h3><span class="qpc-hafs">﴿وَرَحۡمَتُ رَبِّكَ خَیۡرࣱ مِّمَّا یَجۡمَعُونَ ۝٣٢﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٩٤٦٠<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿ورَحْمَتُ رَبِّكَ خَيْرٌ مِمّا يَجْمَعُونَ﴾</span>، قال: الجنة{7}<span class=comment-ref>٥٨٥٨</span>. (١٣/٢٠٣)</p></p><p></div></p><p><div><span class=comment-ref>٥٨٥٨</span> ساق <u>ابنُ عطية</u> (٧/٥٤٥) هذا القول، ثم <span class="comment-type-4">علَّق</span> بقوله: «ولا شك أن الجنة هي الغاية، ورحمة الله في الدنيا بالهداية والايمان خيرٌ مِن كل مال».</div></p><p><div></p><p><p><span class="item-no">٦٩٤٦١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ورَحْمَتُ رَبِّكَ يعني الجنة خَيْرٌ مِمّا يَجْمَعُونَ﴾</span>، يعني: الأموال، يعني: الكفار{2}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه أحمد ٦/١٨٩ (٣٦٧٢)، والحاكم ٢/٤٨٥ (٣٦٧١).</p><p>وقال الحاكم: «هذا حديث صحيح الإسناد، ولم يخرجاه». قال الهيثمي في المجمع ١/٥٣ (١٦٤): «رواه أحمد، ورجال إسناده بعضهم مستور، وأكثرهم ثقات». وقال البوصيري في إتحاف الخيرة ١/٨٢ (٣٣): «هذا ضعيف، الصباح بن محمد أبو حازم البجلي الكوفي مجهول». وأورده الألباني في الصحيحة ٦/٤٨٢ (٢٧١٤).تفسير مقاتل بن سليمان ٣/٧٩٤.رجل سَلِيط: فصيح حديد اللسان. لسان العرب (سلط).أخرجه ابن جرير ٢٠/٥٨٤-٥٨٥. وعزاه السيوطي إلى عَبد بن حُمَيد، وابن المنذر.تفسير مقاتل بن سليمان ٣/٧٩٤.أخرجه ابن جرير ٢٠/٥٨٦.أخرجه ابن جرير ٢٠/٥٨٦. وعزاه السيوطي إلى عَبد بن حُمَيد، وابن المنذر.أخرجه ابن جرير ٢٠/٥٨٥.تفسير مقاتل بن سليمان ٣/٧٩٤.تفسير سفيان الثوري ص٢٧١.أخرجه ابن جرير ٢٠/٥٨٥.أخرجه ابن جرير ٢٠/٥٨٦. وعزاه السيوطي إلى عَبد بن حُمَيد، وابن المنذر.تفسير مقاتل بن سليمان ٣/٧٩٤.
  43,33,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَلَوۡلَاۤ أَن یَكُونَ ٱلنَّاسُ أُمَّةࣰ وَ ٰ⁠حِدَةࣰ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٩٤٦٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- <span class="qpc-hafs">﴿ولَوْلا أنْ يَكُونَ النّاسُ أُمَّةً واحِدَةً﴾</span> الآية، يقول: لولا أن أجعل الناسَ كلهم كفّارًا لجعلت لبيوت الكفار سُقُفًا مِن فِضّة{1}. (١٣/٢٠٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٩٤٦٣<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span>، <span class="qpc-hafs">﴿ولَوْلا أنْ يَكُونَ النّاسُ أُمَّةً واحِدَةً﴾</span>، قال: لولا أن يكفروا{2}. (١٣/٢٠٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٩٤٦٤<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق عوف- في قوله: <span class="qpc-hafs">﴿ولَوْلا أنْ يَكُونَ النّاسُ أُمَّةً واحِدَةً﴾</span>، قال: لولا أن يكون الناسُ أجمعون كُفّارًا، فيميلون إلى الدنيا، لجعل الله لهم الذي قال، قال: وقد مالت الدنيا بأكثر أهلها، وما فعل ذلك، فكيف لو فعله؟!{3}. (١٣/٢٠٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٩٤٦٥<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- <span class="qpc-hafs">﴿ولَوْلا أنْ يَكُونَ النّاسُ أُمَّةً واحِدَةً﴾</span>، قال: لولا أن يكون الناس كفّارًا{4}. (١٣/٢٠٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٩٤٦٦<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدّيّ</span> -من طريق أسباط- <span class="qpc-hafs">﴿ولَوْلا أنْ يَكُونَ النّاسُ أُمَّةً واحِدَةً﴾</span>، يقول: كفّارًا، على دين واحد{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٩٤٦٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثم ذكّرهم هوان الدنيا عليه، فقال: <span class="qpc-hafs">﴿ولَوْلا أنْ يَكُونَ النّاسُ أُمَّةً واحِدَةً﴾</span> يعني: مِلّة واحدة، يعني: على الكفر، يقول: لولا أن ترغب الناس في الكفر إذا رأوا الكفار في سَعَةٍ مِن الخير والرزق{6}<span class=comment-ref>٥٨٥٩</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٥٨٥٩</span> ساق <u>ابنُ عطية</u> (٧/٥٤٥) هذا القول الذي قاله ابن عباس، والسُّدّيّ، وقتادة، ومقاتل، والحسن، ومجاهد، ثم <span class="comment-type-4">علَّق</span> بقوله: «<span class="mustanad">ومن هذا المعنى قول النبي</span> ﷺ: «<b>لو كانت الدنيا تزن عند الله جناح بعوضة ما سقى كافرًا منها شربة ماء</b>». ثم يتركّب معنى الآية على معنى هذا الحديث».</div></p><p><div></p><p><p><span class="item-no">٦٩٤٦٨<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿ولَوْلا أنْ يَكُونَ النّاسُ أُمَّةً واحِدَةً﴾</span>، قال: لولا أن يختار الناس دنياهم على دينهم لجعَلنا هذا لأهل الكفر{7}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿لَّجَعَلۡنَا لِمَن یَكۡفُرُ بِٱلرَّحۡمَـٰنِ لِبُیُوتِهِمۡ سُقُفࣰا مِّن فِضَّةࣲ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٩٤٦٩<span class="dash">-</span></span> عن ابن عباس، قال: قال رسول الله ﷺ: «<b>يقول الله: لولا أن يجزع عبدي المؤمن لَعصبْتُ الكافر عصابة من حديد، فلا يشتكي شيئًا أبدًا، ولصببتُ عليه الدنيا صبًّا»</b>. قال <span class="name-1">ابن عباس</span>: قد أنزل اللهُ شبه ذلك في كتابه في قوله: <span class="qpc-hafs">﴿ولَوْلا أنْ يَكُونَ النّاسُ أُمَّةً واحِدَةً لَجَعَلْنا لِمَن يَكْفُرُ بِالرَّحْمَنِ﴾</span> الآية{8}. (١٣/٢٠٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٩٤٧٠<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق شبل- قال: كلُّ شيء مِن بيوت أهل الدنيا فهو سُقُف، وما كان من السماء فهو سَقْف{9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٩٤٧١<span class="dash">-</span></span> عن <span class="name-2">عامر الشعبي</span> -من طريق إسماعيل بن سالم- في قوله: <span class="qpc-hafs">﴿سُقُفًا﴾</span>، قال: الجذوع{10}. (١٣/٢٠٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٩٤٧٢<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿لَجَعَلْنا لِمَن يَكْفُرُ بِالرَّحْمَنِ لِبُيُوتِهِمْ سُقُفًا مِن فِضَّةٍ﴾</span>، قال: السُّقُف: أعالي البيوت{11}. (١٣/٢٠٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٩٤٧٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿لَجَعَلْنا لِمَن يَكْفُرُ بِالرَّحْمنِ﴾</span> لهوان الدنيا عليه <span class="qpc-hafs">﴿لِبُيُوتِهِمْ سُقُفًا مِن فِضَّةٍ﴾</span> يعني بالسُّقُف: سماء البيت{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٩٤٧٤<span class="dash">-</span></span> قال <span class="name-3">سفيان الثوري</span>، في قوله: <span class="qpc-hafs">﴿لَجَعَلْنا لِمَن يَكْفُرُ بِالرَّحْمَنِ لِبُيُوتِهِمْ سُقُفًا مِن فِضَّةٍ﴾</span>، قال: الجذوع{13}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَمَعَارِجَ عَلَیۡهَا یَظۡهَرُونَ ۝٣٣﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٩٤٧٥<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- <span class="qpc-hafs">﴿ومَعارِجَ﴾</span>: ومعارج من فضة، وهي دَرج، <span class="qpc-hafs">﴿عَلَيْها يَظْهَرُونَ﴾</span> يصعدون إلى الغُرف{14}. (١٣/٢٠٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٩٤٧٦<span class="dash">-</span></span> قال سفيان [بن عُيينة]: في تفسير <span class="name-2">مجاهد</span>: <span class="qpc-hafs">﴿ومعارج عليها يظهرون﴾</span>، قال: مثل الدّرَج{15}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٩٤٧٧<span class="dash">-</span></span> عن <span class="name-2">عامر الشعبي</span> -من طريق إسماعيل بن سالم- في قوله: <span class="qpc-hafs">﴿ومَعارِجَ﴾</span>، قال: الدَّرَج{16}. (١٣/٢٠٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٩٤٧٨<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- <span class="qpc-hafs">﴿ومَعارِجَ عَلَيْها يَظْهَرُونَ﴾</span>، قال: دَرج عليها يصعدون{17}. (١٣/٢٠٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٩٤٧٩<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدّيّ</span> -من طريق أسباط- <span class="qpc-hafs">﴿ومَعارِجَ عَلَيْها يَظْهَرُونَ﴾</span>، قال: المعارج: المراقي{18}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٩٤٨٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ومَعارِجَ عَلَيْها يَظْهَرُونَ﴾</span>، يقول: دَرجًا على ظهور بيوتهم يَرْتَقون{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٩٤٨١<span class="dash">-</span></span> قال <span class="name-3">سفيان الثوري</span>، في قوله: <span class="qpc-hafs">﴿ومَعارِجَ عَلَيْها يَظْهَرُونَ﴾</span>، قال: الدَّرج{13}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٩٤٨٢<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿ومَعارِجَ عَلَيْها يَظْهَرُونَ﴾</span>، قال: المعارج: درَج من فِضّة{7}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ٢٠/٥٨٧، وابن أبي حاتم -كما في تغليق التعليق ٤/٣٠٥، والفتح ٨/٥٦٦-. وعزاه السيوطي إلى ابن المنذر.عزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ٢٠/٥٨٧ بنحوه. وعزاه السيوطي إلى عَبد بن حُمَيد، وابن المنذر. وذكر أوله يحيى بن سلام -كما في تفسير ابن أبي زمنين ٤/١٨٣-.أخرجه عبد الرزاق ٢/١٩٦، وابن جرير ٢٠/٥٨٨. وعزاه السيوطي إلى عَبد بن حُمَيد.أخرجه ابن جرير ٢٠/٥٨٨.تفسير مقاتل بن سليمان ٣/٧٩٤.أخرجه ابن جرير ٢٠/٥٨٨، ٥٩١.أخرجه ابن عدي في الكامل ٣/١٨١.</p><p>قال ابن عدي: «ليس بمحفوظ، يرويه حسن بن الحسين، وللحسن بن الحسين أحاديث كثيرة، ولا يشبه حديثه حديث الثقات».</p><p>وأخرج نحوه إسحاق البستي ص٣١٥ عن سفيان بن عُيَينة، عن مالك بن مغول، عن رجل موقوفًا عليه.أخرجه إسحاق البستي ص٣١٦.عزاه السيوطي إلى عَبد بن حُمَيد، وابن المنذر. وأخرجه إسحاق البستي ص٣١٥ من طريق إسماعيل بن سالم، وجاء في نسخة: الجدوع -دون إعجام-.أخرجه ابن جرير ٢٠/٥٨٨. وعزاه السيوطي إلى عبد الرزاق، وعَبد بن حُمَيد.تفسير مقاتل بن سليمان ٣/٧٩٤.تفسير سفيان الثوري ص٢٧١.أخرج ابن جرير ٢٠/٥٩٠-٥٩١ أوَّله من طريق علي، والشطر الثاني من طريق العوفي، وابن أبي حاتم -كما في تغليق التعليق ٤/٣٠٥، والفتح ٨/٥٦٦-. وعزاه السيوطي إلى ابن المنذر.أخرجه إسحاق البستي ص٣١٥.أخرجه إسحاق البستي ص٣١٥. وعزاه السيوطي إلى عَبد بن حُمَيد، وابن المنذر.أخرجه عبد الرزاق ٢/١٩٦، وابن جرير ٢٠/٥٩١. وعزاه السيوطي إلى عَبد بن حُمَيد.أخرجه ابن جرير ٢٠/٥٩١.تفسير مقاتل بن سليمان ٣/٧٩٤.تفسير سفيان الثوري ص٢٧١.أخرجه ابن جرير ٢٠/٥٨٨، ٥٩١.