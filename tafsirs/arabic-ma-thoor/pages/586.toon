81,22," <q>﴿وَمَا صَاحِبُكُم بِمَجۡنُونࣲ ۝٢٢﴾</q> - تفسير ٨١٧٩٧- عن عبد الله بن عباس، <q>﴿وما صاحِبُكُمْ بِمَجْنُونٍ﴾</q>، قال: محمد ﷺ{1}. (١٥/٢٧٤) ٨١٧٩٨- عن أبي صالح [باذام] -من طريق إسماعيل- <q>﴿وما صاحِبُكُمْ بِمَجْنُونٍ﴾</q>، قال: محمد ﷺ{2}. (١٥/٢٧٤) ٨١٧٩٩- عن ميمون بن مهران -من طريق معقل- <q>﴿وما صاحِبُكُمْ بِمَجْنُونٍ﴾</q>، قال: ذاكم محمد ﷺ{3}. (ز) ٨١٨٠٠- قال مقاتل بن سليمان: <q>﴿وما صاحِبُكُمْ بِمَجْنُونٍ﴾</q> يعني: النبي ﷺ، وذلك أنّ كفار مكة قالوا: إنّ محمدًا مجنون، وإنما تقوّله من تلقاء نفسه{4}٧٠٦٣. (ز) ٧٠٦٣ قال ابنُ عطية (٨/٥٥١): «وأجمع المفسرون على أنّ قوله: <q>﴿وما صاحبكم﴾</q> يراد به: محمد ﷺ». ",footnotes:1:عزاه السيوطي إلى ابن المنذر.أخرجه أبو الشيخ في العظمة (٥٠٠). وعزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ٢٤/١٦٥.تفسير مقاتل بن سليمان ٤/.٦٠٤
81,23," <q>﴿وَلَقَدۡ رَءَاهُ بِٱلۡأُفُقِ ٱلۡمُبِینِ ۝٢٣﴾</q> - تفسير ٨١٨٠١- عن عبد الله بن مسعود، <q>﴿ولَقَدْ رَآهُ بِالأُفُقِ المُبِينِ﴾</q>، قال: جبريل في رفرفٍ أخضر قد سَدّ الأُفُق{1}. (١٥/٢٧٥) ٨١٨٠٢- عن عبد الله بن مسعود -من طريق زِرّ بن حُبَيش- <q>﴿ولَقَدْ رَآهُ بِالأُفُقِ المُبِينِ﴾</q>، قال: رأى جبريلَ، له ستمائة جناح، قد سَدّ الأُفُق{2}. (١٥/٢٧٥) ٨١٨٠٣- عن عبد الله بن عباس -من طريق الشعبي- <q>﴿ولَقَدْ رَآهُ بِالأُفُقِ المُبِينِ﴾</q>، قال: إنما عنى جبريل أنّ محمدًا رآه في صورته عند سِدرة المنتهى{3}. (١٥/٢٧٥) ٨١٨٠٤- عن عبد الله بن عباس، <q>﴿ولَقَدْ رَآهُ بِالأُفُقِ المُبِينِ﴾</q>، قال: السماء السابعة{4}. (١٥/٢٧٥) ٨١٨٠٥- عن أبي الأحوص -من طريق الوليد بن العيزار- <q>﴿ولَقَدْ رَآهُ بِالأُفُقِ المُبِينِ﴾</q>، قال: رأى جبريلَ له ستمائة جناح في صورته{5}. (ز) ٨١٨٠٦- عن مجاهد بن جبر -من طريق ابن أبي نجيح- قوله: <q>﴿بِالأُفُقِ المُبِينِ﴾</q> الأعلى. قال: بأفق من نحو أجياد{5}. (ز) ٨١٨٠٧- عن عكرمة مولى ابن عباس، <q>﴿ولَقَدْ رَآهُ بِالأُفُقِ المُبِينِ﴾</q>، قال: هو رسول الله ﷺ، رأى جبريل بالأُفُق، والأُفُق: الصبح{7}. (١٥/٢٧٥) ٨١٨٠٨- عن عامر الشعبي -من طريق عطاء- قال: ما رأى جبريلُ النبيَّ ﷺ في صورته إلا مرة واحدة، وكان يأتيه في صورة رجل يُقال له: دِحية، فأتاه يوم رآه في صورته قد سَدّ الأُفُق كلّه، عليه سُندسٌ أخضر مُعلّق الدُّر؛ فذلك قول الله: <q>﴿ولَقَدْ رَآهُ بِالأُفُقِ المُبِينِ﴾</q>{8}. (ز) ٨١٨٠٩- عن قتادة بن دعامة -من طريق معمر- <q>﴿ولَقَدْ رَآهُ بِالأُفُقِ المُبِينِ﴾</q>، قال: كُنّا نحدّث: أنه الأُفُق الذي يجيء منه النهار. وفي لفظ: أنّ الأُفُق من حيث تطلع الشمس{9}٧٠٦٤. (١٥/٢٧٤) ٧٠٦٤ ذكر ابنُ عطية (٨/٥٥١) قول قتادة، ثم علّق قائلًا: «وأيضًا فكلّ أُفُق فهو في غاية البيان». ٨١٨١٠- قال مقاتل بن سليمان: <q>﴿ولَقَدْ رَآهُ بِالأُفُقِ المُبِينِ﴾</q>، يعني: مِن قِبل المطلع، وذلك أنّ النبيَّ ﷺ رأى جبريل ﵇ في صورته مِن قِبل المشرق بجبال مكة قد ملأ الأفق؛ رجلاه في الأرض، ورأسه في السماء، وجناح له مِن قِبل المشرق، وجناح له من قِبل المغرب، فغُشي على النبي ﷺ، فتحوّل جبريل ﵇ في صورة البشر، فقال: أنا جبريل. وجعل يمسح عن وجهه، ويقول: أنا أخوك؛ أنا جبريل. حتى أفاق، فقال المؤمنون: ما رأيناك منذ بُعثتَ أحسن منك اليوم. فقال النبي ﷺ: «أتاني جبريل ﵇ في صورته، فعلقني هذا مِن حُسنه»{10}. (ز) ٨١٨١١- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- <q>﴿ولَقَدْ رَآهُ بِالأُفُقِ المُبِينِ﴾</q>، قال: رأى جبريلَ بالأُفُق المبين{5}٧٠٦٥. (ز) ٧٠٦٥ لم يذكر ابنُ جرير (٢٤/١٦٦) في قوله: <q>﴿بالأفق المبين﴾</q> غير قول عبد الرحمن بن زيد، وقول قتادة، ومجاهد. <q>﴿وَلَقَدۡ رَءَاهُ بِٱلۡأُفُقِ ٱلۡمُبِینِ ۝٢٣﴾</q> - آثار متعلقة بالآية ٨١٨١٢- عن ابن عباس، قال: قال رسول الله ﷺ لجبريل: «إني أُحبّ أنْ أراك في صورتك التي تكون فيها في السماء». قال: لن تقوى على ذلك. قال: «بلى». قال: فأين تشاء أنْ أتخيّل لك؟ قال: «بالأبطح». قال: لا يسعني. قال: «فبمنى». قال: لا يسعني. قال: «فبعرفات». قال: ذلك بالحرى أن يسعني. فواعده، فخرج النبي ﷺ للوقت، فإذا هو بجبريل ﵇ قد أقبل من جبال عرفات بخشخشة{12} وكلكلة، قد ملأ ما بين المشرق والمغرب، ورأسه في السماء، ورجلاه في الأرض، فلما رآه النبي ﷺ خَرّ مغشيًا عليه. قال: فتحوّل جبريل في صورته، فضمَّه إلى صدره. وقال: يا محمد، لا تَخفْ، فكيف لو رأيت إسرافيل ورأسه من تحت العرش ورجلاه في التخوم السابعة، وإنّ العرش لَعَلى كاهله، وإنّه لَيتضاءل أحيانًا مِن مخافة الله ﷿ حتى يصير مثل الوصع -يعني: العصفور-، حتى ما يحمل عرش ربّك إلا عظمته{13}. (ز) ",footnotes:1:عزاه السيوطي إلى ابن مردويه، وأبي نعيم في الدلائل.أخرجه عبد الرزاق ٢/٣٥٢ بلفظ: خمسمائة جناح. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن مردويه.أخرجه الطبراني (١٢٥٦٥). وعزاه السيوطي إلى ابن مردويه.عزاه السيوطي إلى ابن مردويه.أخرجه ابن جرير ٢٤/١٦٦.أخرجه ابن جرير ٢٤/١٦٦.عزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه آدم بن أبي إياس -كما في تفسير مجاهد ص٧٠٩- بنحوه، وابن جرير ٢٤/١٦٧.أخرجه عبد الرزاق ٢/٣٥٢، وابن جرير ٢٤/١٦٦، وكذلك من طريق سعيد بنحوه. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.تفسير مقاتل بن سليمان ٤/٦٠٤.أخرجه ابن جرير ٢٤/١٦٦.الخشخشة: حركة لها صوت كصوت السلاح. النهاية (خشخش).أخرجه الثعلبي ١٠/١٤٢، والبغوي ٨/٣٥٠-٣٥١، من طريق إسحاق بن بشر، عن ابن جُرَيْج، عن عكرمة بن خالد، ومقاتل، عن عكرمة، عن ابن عباس به. سنده شديد الضعف؛ فيه إسحاق بن بشر أبو حذيفة البخاري، وهو متروك. الميزان ١/١٨٤.
81,24," <q>﴿وَمَا هُوَ عَلَى ٱلۡغَیۡبِ بِضَنِینࣲ ۝٢٤﴾</q> - قراءات ٨١٨١٣- عن عائشة، أنّ النبي ﷺ كان يقرؤها: ‹وما هُوَ عَلى الغَيْبِ بِظَنِينٍ› بالظاء{1}. (١٥/٢٧٦) ٨١٨١٤- عن عبد الله بن الزُّبير، أن النبي ﷺ كان يقرؤها: ‹وما هُوَ عَلى الغَيْبِ بِظَنِينٍ›. وفي لفظ لابن مردويه: <q>﴿بِضَنِينٍ﴾</q> بالضاد{2}. (١٥/٢٧٦) ٨١٨١٥- في حرف أُبيّ بن كعب -من طريق مجاهد-: <q>﴿بِضَنِينٍ﴾</q>، يعني: بالضاد{3}. (١٥/٢٧٧) ٨١٨١٦- عن عبد الله بن مسعود أنه قرأها: ‹وما هُوَ عَلى الغَيْبِ بِظَنِينٍ›{4}. (١٥/٢٧٧) ٨١٨١٧- عن مجاهد، قال: سمعتُ ابن الزُّبير: يقرؤها: <q>﴿وما هُوَ عَلى الغَيْبِ بِضَنِينٍ﴾</q>= (ز) ٨١٨١٨- فسألتُ ابن عباس فقال: ضنين.= (ز) ٨١٨١٩- قال: وكان ابن مسعود يقرؤها: ‹بِظَنِينٍ›{5}. (ز) ٨١٨٢٠- عن عبد الله بن عباس -من طريق الضَّحّاك- أنه كان يقرأ: ‹وما هُوَ عَلى الغَيْبِ بِظَنِينٍ›{6}. (١٥/٢٧٨) ٨١٨٢١- عن عبد الله بن عباس -من طريق عطاء- أنه كان يقرأها: ‹وما هُوَ عَلى الغَيْبِ بِظَنِينٍ›{7}. (ز) ٨١٨٢٢- عن عبد الله بن عباس أنه كان يقرأ: <q>﴿بِضَنِينٍ﴾</q>{8}. (١٥/٢٧٦) ٨١٨٢٣- عن عبد الله بن الزُّبير أنه كان يقرأ: ‹وما هُوَ عَلى الغَيْبِ بِظَنِينٍ›{4}. (١٥/٢٧٦) ٨١٨٢٤- عن عطاء بن يسار، قال: زعموا أنها في المصاحف، وفي مصحف عثمان: ‹بِظَنِينٍ›{10}. (١٥/٢٧٧) ٨١٨٢٥- عن سعيد بن جُبَير -من طريق أبي المُعلّى- أنه كان يقرأ هذا الحرف ‹وما هُوَ عَلى الغَيْبِ بِظَنِينٍ›{11}. (ز) ٨١٨٢٦- عن هشام بن عروة، قال: كان أبي يقرؤها: ‹وما هُوَ عَلى الغَيْبِ بِظَنِينٍ› فقيل له في ذلك، فقال: قالت عائشة: إنّ الكُتّاب يُخطئون في المصاحف{10}. (١٥/٢٧٦) ٨١٨٢٧- عن ابن الهاد: أنّ إنسانًا سأل عبد الرحمن الأعرج عن قول الله: <q>﴿وما هُوَ عَلى الغَيْبِ بِضَنِينٍ﴾</q>. فقال عبد الرحمن: ما أبالي بأيهما قرأتُ{13}٧٠٦٦. (ز) ٧٠٦٦ اتفق الأئمة على أنه إذا قُرئ: <q>﴿بضنين﴾</q> كان معناه: غير بخيل. وإذا قُرئ: ‹بِظَنِينٍ› كان معناه: غير مُتّهم. وزاد ابنُ عطية (٨/٥٥١) معلقًا على قراءة الظاء، فقال: «وهذا في المعنى نظير وصفه بـ<q>﴿أمين﴾</q>، وقيل: معناه: بضعف القوة عن التبليغ من قولهم: بئر ظنون إذا كانت قليلة الماء. ورجّح أبو عبيد قراءة الظاء مشالة؛ لأن قريشًا لم تبخل محمدًا ﷺ فيما يأتي به، وإنما كذّبته، فقيل: ما هو بمُتّهم». وأضاف ابنُ القيم (٣/٢٦٣): «وليس من الظن الذي هو الشعور والإدراك؛ فإن ذاك يتعدى إلى مفعولين». ورجّح ابنُ جرير (٢٤/١٧٠) -مستندًا لموافقتها مصاحف المسلمين- قراءة الضاد، فقال: «وأولى القراءتين في ذلك عندي بالصواب: ما عليه خطوط مصاحف المسلمين متفقة، وإن اختلفت قراءتهم به، وذلك <q>﴿بضنين﴾</q> بالضاد؛ لأنّ ذلك كله كذلك في خطوطها. فإذا كان ذلك كذلك فأولى التأويلين بالصواب في ذلك: تأويل مَن تأوله، وما محمد على ما علمه الله من وحيه وتنزيله ببخيل بتعليمكموه -أيها الناس-، بل هو حريص على أن تؤمنوا به وتتعلموه». ورجّح ابنُ تيمية (٦/٤٧٩) قراءة الظاء بقوله: «وهو المناسب». وبنحوه ابنُ القيم (٣/٢٦٤) مستندًا إلى ظاهر الآية، والدلالة العقلية، فقال: «قلت: ويرجحه أنه وصفه بما وصف به رسوله المَلكيّ مِن الأمانة، فنفى عنه التُّهمة، كما وصف جبريل بأنه أمين. ويرجّحه أيضًا أنه سبحانه نفى أقسام الكذب كلّها عما جاء به من الغيب، فإنّ ذلك لو كان كذبًا فإمّا أن يكون منه، أو ممن علّمه، وإن كان منه فإمّا أن يكون تَعمَّده أو لم يَتعمّده، فإن كان مِن مُعلِّمه فليس هو بشيطان رجيم، وإن كان منه مع التعمد فهو المتهم ضد الأمين، وإن كان عن غير تعمُّد فهو المجنون، فنفى سبحانه عن رسوله ذلك كله». وعلّق ابنُ كثير (١٤/٢٧١) على القراءتين، فقال: «قلت: وكلاهما متواتر، ومعناه صحيح». <q>﴿وَمَا هُوَ عَلَى ٱلۡغَیۡبِ بِضَنِینࣲ ۝٢٤﴾</q> - تفسير الآية ٨١٨٢٨- عن عبد الله بن مسعود أنه قرأها: ‹وما هُوَ عَلى الغَيْبِ بِظَنِينٍ›، قال: ما هو على القرآن بمُتّهم{4}. (١٥/٢٧٧) ٨١٨٢٩- عن عبد الله بن عباس أنه كان يقرأ: <q>﴿بِضَنِينٍ﴾</q>، وقال: ببخيل{8}. (١٥/٢٧٦) ٨١٨٣٠- عن عبد الله بن عباس -من طريق الضَّحّاك- أنه كان يقرأ: ‹وما هُوَ عَلى الغَيْبِ بِظَنِينٍ›، قال: ليس بمُتّهم{16}. (١٥/٢٧٨) ٨١٨٣١- عن عبد الله بن عباس -من طريق عطية العَوفيّ- قوله: ‹وما هُوَ عَلى الغَيْبِ بِظَنِينٍ›، يقول: ليس بمُتّهم على ما جاء به، وليس يُظَنُّ بما أوتي{17}. (١٥/٢٧٨) ٨١٨٣٢- عن زِرّ بن حُبَيش، قال: <q>﴿الغَيْبِ﴾</q>: القرآن{10}. (١٥/٢٧٨) ٨١٨٣٣- عن زِرّ بن حُبَيش -من طريق عاصم- قال: في قراءتنا: ‹بِظَنِينٍ› مُتّهم، وفي قراءتكم: <q>﴿بِضَنِينٍ﴾</q> ببخيل{19}. (١٥/٢٧٨) ٨١٨٣٤- عن سعيد بن جُبَير -من طريق أبي المُعَلّى- أنه كان يقرأ هذا الحرف: ‹وما هُوَ عَلى الغَيْبِ بِظَنِينٍ›، فقال أبو المُعَلّى لسعيد بن جُبَير: ما الظّنين؟ قال: ليس بمُتّهم{20}. (ز) ٨١٨٣٥- عن إبراهيم النَّخْعي -من طريق مغيرة- قال: الظنين: المُتّهم. والضنين: البخيل{21}. (١٥/٢٧٨) ٨١٨٣٦- عن مجاهد بن جبر -من طريق ابن أبي نجيح- <q>﴿وما هُوَ عَلى الغَيْبِ بِضَنِينٍ﴾</q>، يقول: ما كان يَضِنُّ عليكم بما يعلم{22}. (١٥/٢٧٧) ٨١٨٣٧- عن الضَّحّاك بن مُزاحِم -من طريق عبيد- ‹بِظَنِينٍ›، قال: ليس على ما أنزل الله بمُتّهم{23}. (ز) ٨١٨٣٨- عن عكرمة مولى ابن عباس، <q>﴿وما هُوَ عَلى الغَيْبِ بِضَنِينٍ﴾</q>، قال: إنّ النبي ﷺ لم يَضِنّ بما أنزل الله عليه{10}. (١٥/٢٧٧) ٨١٨٣٩- عن عامر الشعبي -من طريق عطاء- <q>﴿وما هُوَ عَلى الغَيْبِ بِضَنِينٍ﴾</q>، يعني: النبي ﷺ{25}. (ز) ٨١٨٤٠- عن محمد ابن شهاب الزّهري، <q>﴿وما هُوَ عَلى الغَيْبِ بِضَنِينٍ﴾</q>، قال: لا يَضِنُّ بما أُوحي إليه{26}. (١٥/٢٧٧) ٨١٨٤١- عن قتادة بن دعامة -من طريق سعيد- <q>﴿وما هُوَ عَلى الغَيْبِ بِضَنِينٍ﴾</q>، قال: كان هذا القرآن غيبًا، أعطاه الله تعالى محمدًا، فبذله وعلمه، ودعا إليه، وما ضَنَّ به{27}. (١٥/٢٧٧) ٨١٨٤٢- قال مقاتل بن سليمان: ‹وما هُوَ عَلى الغَيْبِ بِظَنِينٍ› يعني: وما محمد ﷺ على القرآن بمُتّهم، ومَن قرأ: <q>﴿بضنين﴾</q> يعني: ببخيل{28}. (ز) ٨١٨٤٣- عن سفيان [الثوري] -من طريق مهران- <q>﴿وما هُوَ عَلى الغَيْبِ بِضَنِينٍ﴾</q>، قال: ببخيل{29}. (ز) ٨١٨٤٤- قال سفيان [بن عيينة]: تفسير «ضنين» و«ظنين» سواء، ويقول: ما هو بكاذب، وما هو بفاجر، والظنين: المُتّهم، والضنين: البخيل{30}. (ز) ٨١٨٤٥- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- <q>﴿وما هُوَ عَلى الغَيْبِ بِضَنِينٍ﴾</q>: الغيب: القرآن، لم يَضِنّ به على أحد من الناس أدّاه وبلّغه، بعث الله به الروح الأمين جبريل إلى رسول الله ﷺ، فأدّى جبريل ما استودعه الله إلى محمد، وأدّى محمد ما استودعه الله وجبريل إلى العباد، ليس أحد منهم ضَنَّ، ولا كَتم، ولا تخَرَّص{11}٧٠٦٧. (ز) ٧٠٦٧ قال ابنُ القيم (٣/٢٦٣): «وأجمع المفسرون على أنّ الغيب هاهنا: القرآن، والوحي». ",footnotes:1:أخرجه الحاكم ٢/٢٧٦ (٢٩٩٦)، من طريق إسحاق بن عبد الله بن أبي فروة، عن يحيى بن عروة بن الزُّبير، عن عروة، عن عائشة به. قال الحاكم: «هذا حديث صحيح الإسناد، ولم يخرجاه». وقال الذهبي في التلخيص: «إسحاق متروك». وقال ابن حجر في إتحاف المهرة ١٧/٣٩١ (٢٢٤٦٤): «إسحاق ضعيف جدًّا». و‹بِظَنِينٍ› قراءة متواترة، قرأ بها ابن كثير، وأبو عمرو، والكسائي، ورويس، وقرأ بقية العشرة: <q>﴿بِضَنِينٍ﴾</q> بالضاد. انظر: النشر ٢/٣٩٩، والإتحاف ص٥٧٣.أخرجه عبد الرزاق ٣/٤٠٠ (٣٥٢٤) بلفظ: ‹بِظَنِينٍ›، من طريق إسحاق بن عبد الله بن أبي فروة، عن ابن الزُّبير به. وعزاه السيوطي إلى ابن مردويه بلفظ: <q>﴿بِضَنِينٍ﴾</q>. وسنده شديد الضعف من أجل إسحاق بن أبي فروة؛ فهو متروك. الميزان ١/١٩٣.عزاه السيوطي إلى أبي عبيد، وابن المنذر.عزاه السيوطي إلى سعيد بن منصور، وعبد بن حميد، وابن المنذر، وابن مردويه.أخرجه عبد الرزاق ٢/٣٥٣.أخرجه ابن جرير ٢٤/١٦٩، ومن طريق العَوفيّ أيضًا. وعزاه السيوطي إلى عبد بن حميد.أخرجه عبد الله بن وهب في الجامع -تفسير القرآن ٣/٤٦ (٩١).أخرجه ابن أبي حاتم -كما في فتح الباري ٨/٦٩٤-. وعزاه السيوطي إلى سعيد بن منصور، وعبد بن حميد، وابن جرير، وابن المنذر، وابن مردويه.عزاه السيوطي إلى سعيد بن منصور، وعبد بن حميد، وابن المنذر، وابن مردويه.عزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ٢٤/١٦٩.عزاه السيوطي إلى عبد بن حميد.أخرجه عبد الله بن وهب في الجامع -تفسير القرآن ٣/٤٥-٤٦ (٩٠).عزاه السيوطي إلى سعيد بن منصور، وعبد بن حميد، وابن المنذر، وابن مردويه.أخرجه ابن أبي حاتم -كما في فتح الباري ٨/٦٩٤-. وعزاه السيوطي إلى سعيد بن منصور، وعبد بن حميد، وابن جرير، وابن المنذر، وابن مردويه.أخرجه ابن جرير ٢٤/١٦٩. وعزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ٢٤/١٦٩. وعزاه السيوطي إلى ابن مردويه.عزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ٢٤/١٦٧. وعزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ٢٤/١٦٩ بألفاظ متعددة.أخرجه عبد الرزاق ٢/٣٥٣، وابن جرير ٢٤/١٦٨، ١٧٠. وعزاه السيوطي إلى سعيد بن منصور، وعبد بن حميد، وابن المنذر.تفسير مجاهد ص٧٠٩، وأخرجه ابن جرير ٢٤/١٦٨. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه ابن جرير ٢٤/١٧٠.عزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ٢٤/١٦٧.عزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ٢٤/١٦٨. وعزاه السيوطي إلى عبد بن حميد.تفسير مقاتل بن سليمان ٤/٦٠٥.أخرجه ابن جرير ٢٤/١٦٨.أخرجه عبد الله بن وهب في الجامع -تفسير القرآن ٣/٤٦ (٩٢). وأورد قبله عن سفيان بن عيينة بسنده عن ابن عباس أنه كان يقرأها: ‹ بِظَنِينٍ›.أخرجه ابن جرير ٢٤/١٦٩.
81,25," <q>﴿وَمَا هُوَ بِقَوۡلِ شَیۡطَـٰنࣲ رَّجِیمࣲ ۝٢٥﴾</q> - تفسير ٨١٨٤٦- قال محمد بن السّائِب الكلبي: <q>﴿وما هُوَ بِقَوْلِ شَيْطانٍ رَجِيمٍ﴾</q>، يقول: إنّ القرآن ليس بشعرٍ ولا كهانة كما قالت قريش{1}. (ز) ٨١٨٤٧- قال مقاتل بن سليمان: <q>﴿وما هُوَ بِقَوْلِ شَيْطانٍ رَجِيمٍ﴾</q>، يعني: ملعون، وذلك أنّ كفار مكة قالوا: إنما يجيء به الري -وهو الشيطان، واسمه: الري-، فيُلقيه على لسان محمد ﷺ{2}. (ز) ",footnotes:1:تفسير البغوي ٨/٣٥١.تفسير مقاتل بن سليمان ٤/٦٠٥.
81,26," <q>﴿فَأَیۡنَ تَذۡهَبُونَ ۝٢٦﴾</q> - تفسير ٨١٨٤٨- عن قتادة بن دعامة -من طريق سعيد- <q>﴿فَأَيْنَ تَذْهَبُونَ﴾</q>، قال: أين تعدلون عن كتابي وطاعتي؟!{1}. (١٥/٢٧٨) ٨١٨٤٩- قال مقاتل بن سليمان: <q>﴿فَأَيْنَ تَذْهَبُونَ﴾</q>، يعني: أين تعجلون عن كتابي وأمري؟! لقولهم: إنّ محمدًا مجنون{2}. (ز) ",footnotes:1:أخرجه ابن جرير ٢٤/١٧١. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.تفسير مقاتل بن سليمان ٤/٦٠٥.
81,27," <q>﴿إِنۡ هُوَ إِلَّا ذِكۡرࣱ لِّلۡعَـٰلَمِینَ ۝٢٧﴾</q> - تفسير ٨١٨٥٠- قال مقاتل بن سليمان: <q>﴿إنْ هُوَ إلّا ذِكْرٌ لِلْعالَمِينَ﴾</q>، يعني: ما في القرآن إلا تذكرة وتفكُّر للعالمين{1}. (ز) ",footnotes:1:تفسير مقاتل بن سليمان ٤/٦٠٥.
81,28," <q>﴿لِمَن شَاۤءَ مِنكُمۡ أَن یَسۡتَقِیمَ ۝٢٨﴾</q> - تفسير ٨١٨٥١- عن مجاهد بن جبر -من طريق ابن أبي نجيح- <q>﴿لِمَن شاءَ مِنكُمْ أنْ يَسْتَقِيمَ﴾</q>، قال: أن يتّبع الحق{1}. (١٥/٢٧٨) ٨١٨٥٢- قال مقاتل بن سليمان: <q>﴿لِمَن شاءَ مِنكُمْ﴾</q> يا أهل مكة <q>﴿أنْ يَسْتَقِيمَ﴾</q> على الحق{2}. (ز) ",footnotes:1:تفسير مجاهد ص٧٠٩، وأخرجه ابن جرير ٢٤/١٧٢. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.تفسير مقاتل بن سليمان ٤/٦٠٥.
81,29," <q>﴿وَمَا تَشَاۤءُونَ إِلَّاۤ أَن یَشَاۤءَ ٱللَّهُ رَبُّ ٱلۡعَـٰلَمِینَ ۝٢٩﴾</q> - نزول الآية ٨١٨٥٣- عن أبي هريرة، قال: لَمّا نزلت: <q>﴿لِمَن شاءَ مِنكُمْ أنْ يَسْتَقِيمَ﴾</q> قالوا: الأمر إلينا؛ إن شئنا استقمنا، وإن شئنا لم نستقم. فهبط جبريلُ على رسول الله ﷺ، فقال: كذبوا، يا محمد، <q>﴿وما تَشاءُونَ إلّا أنْ يَشاءَ اللَّهُ رَبُّ العالَمِينَ﴾</q>. ففرح بذلك رسول الله ﷺ{1}. (١٥/٢٧٩) ٨١٨٥٤- عن القاسم بن مُخَيْمرة، قال: لما نزلت: <q>﴿لِمَن شاءَ مِنكُمْ أنْ يَسْتَقِيمَ﴾</q> قال أبو جهل: أرى الأمرَ إلينا. فنزلت: <q>﴿وما تَشاءُونَ إلّا أنْ يَشاءَ اللَّهُ رَبُّ العالَمِينَ﴾</q>{2}. (١٥/٢٧٩) ٨١٨٥٥- عن سليمان بن موسى -من طريق سعيد بن عبد العزيز- قال: لما نزلت: <q>﴿لِمَن شاءَ مِنكُمْ أنْ يَسْتَقِيمَ﴾</q>؛ قال أبو جهل: جَعل الأمر إلينا؛ إن شئنا استقمنا، وإن شئنا لم نستقم. فأنزل الله: <q>﴿وما تَشاءُونَ إلّا أنْ يَشاءَ اللَّهُ رَبُّ العالَمِينَ﴾</q>{3}. (١٥/٢٧٩) <q>﴿وَمَا تَشَاۤءُونَ إِلَّاۤ أَن یَشَاۤءَ ٱللَّهُ رَبُّ ٱلۡعَـٰلَمِینَ ۝٢٩﴾</q> - تفسير الآية ٨١٨٥٦- قال مقاتل بن سليمان: <q>﴿وما تَشاؤُنَ إلّا أنْ يَشاءَ اللَّهُ رَبُّ العالَمِينَ﴾</q> ردَّ المشيئة إلى نفسه{4}. (ز) <q>﴿وَمَا تَشَاۤءُونَ إِلَّاۤ أَن یَشَاۤءَ ٱللَّهُ رَبُّ ٱلۡعَـٰلَمِینَ ۝٢٩﴾</q> - آثار متعلقة بالآية ٨١٨٥٧- عن وهْب بن مُنَبِّه -من طريق عبد الصمد- قال: قرأتُ اثنين وتسعين كتابًا، كلّها أُنزلت من السماء، وجدتُ في كلّها أنّ مَن أضاف إلى نفسه شيئًا مِن المشيئة فقد كفر{5}. (١٥/٢٧٩) ",footnotes:1:أخرجه الفريابي في القدر ص٢٦٩ (٤٢٣، ٤٢٤)، والثعلبي ١٠/١٤٤، من طريق مالك بن سليمان، عن بقية، عن عمر بن محمد، عن زيد بن أسلم، عن أبيه، عن أبي هريرة به. وسنده ضعيف؛ فيه مالك بن سليمان، وهو ضعيف. تاريخ الإسلام ٥/٩٠٦.أخرجه عبد الرزاق ٢/٣٥٣. وعزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ٢٤/١٧٢-١٧٣. وعزاه السيوطي إلى عبد بن حميد، وابن أبي حاتم.تفسير مقاتل بن سليمان ٤/٦٠٥.أخرجه ابن سعد ٥/٥٤٣، والبيهقي في الأسماء والصفات (٣٧٥) وعنده: سبعين.
