tafsir[29]{c,v,t}:
81,1," مقدمة السورة ٨١٥٩٣- عن عبد الله بن عباس -من طريق عطاء الخُراسانيّ-: مكّيّة، وسمّاها <q>﴿إذا الشَّمْسُ كُوِّرَتْ﴾</q>، وذَكر أنها نزلت بعد <q>﴿تَبَّتْ يَدا أبِي لَهَبٍ﴾</q>{1}. (ز) ٨١٥٩٤- عن عبد الله بن عباس -من طريق مجاهد- قال: مكّيّة{2}. (١٥/٢٥٧) ٨١٥٩٥- عن عبد الله بن الزُّبير= (ز) ٨١٥٩٦- وعن عائشة، مثله{3}. (١٥/٢٥٧) ٨١٥٩٧- عن عكرمة مولى ابن عباس= (ز) ٨١٥٩٨- والحسن البصري -من طريق يزيد النحوي-: مكّيّة، وسمّياها <q>﴿إذا الشَّمْسُ كُوِّرَتْ﴾</q>{4}. (ز) ٨١٥٩٩- عن قتادة بن دعامة -من طرق-: مكّيّة{5}. (ز) ٨١٦٠٠- عن محمد بن مسلم الزّهري: مكّيّة، وسمّاها: <q>﴿إذا الشَّمْسُ كُوِّرَتْ﴾</q>، وذكر أنها نزلت بعد <q>﴿تَبَّتْ يَدا أبِي لَهَبٍ﴾</q>{6}. (ز) ٨١٦٠١- عن علي بن أبي طلحة: مكّيّة{7}. (ز) ٨١٦٠٢- قال مقاتل بن سليمان: سورة التكوير مكّيّة، عددها تسع وعشرون آية كوفي{8}. (ز) ٨١٦٠٣- عن محمد بن إسحاق في قصة إسلام عمر: أنّه طلب الصحيفة من أخته، فدَفعتْها إليه، وكان عمر يقرأ الكتاب، فقرأ طه حتى إذا بلغ: <q>﴿إن الساعة آتية أكاد أخفيها لتجزى كل نفس بما تسعى﴾</q> إلى قوله: <q>﴿فتردى﴾</q> [طه:١٥-١٦]، وقرأ: <q>﴿إذا الشمس كورت﴾</q> حتى بلغ: <q>﴿علمت نفس ما أحضرت﴾</q> فأسلم عند ذلك عمر{9}. (ز) ٨١٦٠٤- عن ابن عمر، قال: قال رسول الله ﷺ: «مَن سَرَّه أنْ ينظر إلى يوم القيامة كأنه رأيُ عين فليقرأ: <q>﴿إذا الشَّمْسُ كُوِّرَتْ﴾</q>، و<q>﴿إذا السَّماءُ انْفَطَرَتْ﴾</q>، و<q>﴿إذا السَّماءُ انْشَقَّتْ﴾</q>»{10}. (١٥/٢٥٧) <q>﴿إِذَا ٱلشَّمۡسُ كُوِّرَتۡ ۝١﴾</q> - تفسير ٨١٦٠٥- عن أبي مريم، أنّ النبي ﷺ في قول الله: <q>﴿إذا الشَّمْسُ كُوِّرَتْ﴾</q> قال: «كُوِّرت في جهنم». <q>﴿وإذا النُّجُومُ انْكَدَرَتْ﴾</q> قال: «انكدرت في جهنم، وكلّ مَن عُبِد مِن دون الله فهو في جهنم، إلا ما كان من عيسى ابن مريم وأُمّه، ولو رضيا أن يُعبدا لدخلاها»{11}. (١٥/٢٥٩) ٨١٦٠٦- عن أبي هريرة، عن النبي ﷺ، قال: «الشمس والقمر يُكوّران يوم القيامة». زاد البزار في مسنده: «في النار»{12}. (١٥/٢٥٩) ٨١٦٠٧- عن أبى ذرّ الغفاري، قال: كنتُ آخذًا بيد رسول الله ﷺ، ونحن نتماشى جميعًا نحو المغرب، وقد طفلت الشمسُ، فما زلنا ننظر إليها حتى غابتْ، قال: قلت: يا رسول الله، أين تغرب؟ قال: «تغرب في السماء، ثم تُرفع مِن سماء إلى سماء، حتى تُرفع إلى السماء السابعة العليا، حتى تكون تحت العرش، فتخرّ ساجدة، فتسجد معها الملائكة المُوكَّلون بها، ثم تقول: يا رب، مِن أين تأمرني أن أطلع؟ أمن مغربي أم من مطلعي؟». قال: «فذلك قوله ﷿: <q>﴿والشمس تجرى لمستقر لها﴾</q> حيث تُحبس تحت العرش، <q>﴿ذلك تقدير العزيز العليم﴾</q> [يس:٣٨]». قال: «يعني: ذلك صنع الرّبّ العزيز في مُلكه العليم بخَلْقه». قال: «فيأتيها جبرائيل ﵇ بحُلّة ضوء مِن نور العرش، على مقادير ساعات النهار في طوله في الصيف، أو قِصره في الشتاء، أو ما بين ذلك في الخريف والربيع». قال: «فتلبس تلك الحُلّة كما يلبس أحدُكم ثيابه، ثم ينطلق بها في جوِّ السماء حتى تطلع من مطالعها». قال النبيُّ ﷺ: «فكأنها قد حُبستْ مقدار ثلاث ليالٍ، ثم لا تُكسى ضوءًا، وتؤمر أن تطلع مِن مغربها، فذلك قوله ﷿: <q>﴿إذا الشمس كورت﴾</q>»{13}. (ز) ٨١٦٠٨- عن أُبيّ بن كعب -من طريق أبي العالية- قال: ستُّ آيات قبل يوم القيامة؛ بينما الناس في أسواقهم إذ ذهب ضوء الشمس، فبينما هم كذلك إذ وقعت الجبال على وجه الأرض، فتحرّكتْ واضطربتْ واختلطتْ، ففَزعت الجنُّ إلى الإنس والإنس إلى الجن، واختلطت الدوابّ والطير والوحش، فماجوا بعضهم في بعض: <q>﴿وإذا الوُحُوشُ حُشِرَتْ﴾</q> قال: اختلطت، <q>﴿وإذا العِشارُ عُطِّلَتْ﴾</q> أهملها أهلُها، <q>﴿وإذا البِحارُ سُجِّرَتْ﴾</q> قال الجنُّ للإنس: نحن نأتيكم بالخبر. فانطلقوا إلى البحر، فإذا هي نار تَأَجَّج، فبينما هم كذلك إذ تصدّعت الأرض صدعةً واحدة إلى الأرض السابعة وإلى السماء السابعة، فبينما هم كذلك إذ جاءتهم ريح فأماتتهم{14}. (١٥/٢٥٩) ٨١٦٠٩- عن عبد الله بن عباس -من طريق علي- <q>﴿إذا الشَّمْسُ كُوِّرَتْ﴾</q>، قال: أظْلَمَتْ{15}. (١٥/٢٥٧) ٨١٦١٠- عن عبد الله بن عباس -من طريق سعيد بن جُبَير- <q>﴿إذا الشَّمْسُ كُوِّرَتْ﴾</q>، قال: أُغْوِرَت{16}. (١٥/٢٥٨) ٨١٦١١- عن عبد الله بن عباس -من طريق العَوفيّ- <q>﴿إذا الشَّمْسُ كُوِّرَتْ﴾</q>: يعني: ذهبت{17}. (ز) ٨١٦١٢- عن عبد الله بن عباس -من طريق بيان- في قوله: <q>﴿إذا الشَّمْسُ كُوِّرَتْ﴾</q>، قال: يُكَوِّرُ الله الشمسَ والقمرَ والنجومَ يومَ القيامة في البحر، ويبعث الله ريحًا دبورًا فتنفخه حتى يرجع نارًا{18}. (١٥/٢٥٩) ٨١٦١٣- عن الربيع بن خُثَيْم -من طريق سفيان، عن أبيه، عن منذر الثوري- <q>﴿إذا الشَّمْسُ كُوِّرَتْ﴾</q>، قال: رُمِيَ بها{19}. (١٥/٢٦٢) ٨١٦١٤- عن أبي العالية الرِّياحيّ، قال: سِتُّ آياتٍ مِن هذه السورة في الدنيا والناس ينظرون إليه، وستّ في الآخرة: <q>﴿إذا الشَّمْسُ كُوِّرَتْ﴾</q> إلى: <q>﴿وإذا البِحارُ سُجِّرَتْ﴾</q> هذه الدنيا والناس ينظرون إليه. <q>﴿وإذا النُّفُوسُ زُوِّجَتْ﴾</q> إلى: <q>﴿وإذا الجَنَّةُ أُزْلِفَتْ﴾</q> هذه الآخرة{20}. (١٥/٢٥٩) ٨١٦١٥- عن سعيد بن جُبَير -من طريق جعفر- <q>﴿إذا الشَّمْسُ كُوِّرَتْ﴾</q>، قال: هي بالفارسية: كُور{21}. (١٥/٢٥٨) ٨١٦١٦- عن سعيد بن جُبَير -من طريق يعقوب القمي، عن جعفر- <q>﴿كُوِّرَتْ﴾</q>، قال: غُوِّرتْ، وهي بالفارسية: كُور تكور{22}. (١٥/٢٥٨) ٨١٦١٧- عن مجاهد بن جبر، <q>﴿إذا الشَّمْسُ كُوِّرَتْ﴾</q>، قال: دُهْوِرَت{20}. (١٥/٢٥٨) ٨١٦١٨- عن مجاهد بن جبر -من طريق أبي يحيى- <q>﴿إذا الشَّمْسُ كُوِّرَتْ﴾</q>، قال: اضْمَحلَّتْ{24}. (١٥/٢٦٠) ٨١٦١٩- عن الضَّحّاك بن مُزاحِم -من طريق عبيد- <q>﴿إذا الشَّمْسُ كُوِّرَتْ﴾</q>، قال: ذهب ضوؤها{25}. (١٥/٢٦٠) ٨١٦٢٠- عن الحسن البصري -من طريق المبارك بن فَضالة- <q>﴿إذا الشَّمْسُ كُوِّرَتْ﴾</q>، يقول: تُكوّر حتى يذهب ضوؤها، فلا يبقى لها ضوءٌ{26}. (ز) ٨١٦٢١- عن أبي صالح [باذام] -من طريق إسماعيل بن أبي خالد- <q>﴿إذا الشَّمْسُ كُوِّرَتْ﴾</q>، قال: نُكِّسَتْ. وفي رواية: أُلْقِيَتْ{27}. (١٥/٢٦٠) ٨١٦٢٢- عن قتادة بن دعامة -من طريق سعيد- <q>﴿إذا الشَّمْسُ كُوِّرَتْ﴾</q>: ذهب ضوؤها، فلا ضوء لها{28}. (١٥/٢٦١) ٨١٦٢٣- قال محمد بن السّائِب الكلبي -من طريق مسلم الزنجي- <q>﴿إذا الشَّمْسُ كُوِّرَتْ﴾</q>: ذهب ضوؤها{29}. (ز) ٨١٦٢٤- قال مقاتل بن سليمان: <q>﴿إذا الشَّمْسُ كُوِّرَتْ﴾</q> فذهب ضوؤها{30}٧٠٥٠. (ز) ٧٠٥٠ في قوله: <q>﴿كورت﴾</q> قولان: الأول: ذهب ضوؤها. الثاني: رُمي بها. وقد جمع بينهما ابنُ جرير (٢٤/١٣١) مستندًا إلى اللغة، فقال: «والصواب من القول في ذلك عندنا: أن يُقال: <q>﴿كورت﴾</q> كما قال الله -جلّ ثناؤه-، والتكوير في كلام العرب: جَمْع بعض الشيء إلى بعض، وذلك كتكوير العمامة، وهو لفّها على الرأس، وكتكوير الكارة، وهي جمع الثياب بعضها إلى بعض، ولفّها. وكذلك قوله: <q>﴿إذا الشمس كورت﴾</q> إنما معناه: جمْع بعضها إلى بعض، ثم لُفّتْ فرُمي بها، وإذا فُعل ذلك بها ذهب ضوؤها. فعلى التأويل الذي تأولناه وبيّناه لكلا القولين اللذين ذكرتُ عن أهل التأويل وجه صحيح، وذلك أنها إذا كُوّرتْ ورُمي بها: ذهب ضوؤها». وبنحوه قال ابنُ عطية (٨/٥٤٤)،: «وتكوير الشمس: هو أن تدار ويُذهب بها إلى حيث شاء الله كما يدار كور العمامة، وعبّر المفسِّرون عن ذلك بعبارات؛ فمنهم مَن قال: ذهب نورها. ومنهم مَن قال: رُمي بها. قاله الربيع بن خثيم. وغير ذلك مما هو أشياء تابعة لتكويرها». ",footnotes:1:أخرجه ابن الضريس في فضائل القرآن ١/٣٣-٣٥.أخرجه أبو جعفر النحاس في الناسخ والمنسوخ ص٧٥٧ من طريق أبي عمرو بن العلاء عن مجاهد، والبيهقي في دلائل النبوة ٧/١٤٢-١٤٤ من طريق خُصَيف عن مجاهد. وعزاه السيوطي إلى ابن مردويه.عزاه السيوطي إلى ابن مردويه.أخرجه البيهقي في دلائل النبوة ٧/١٤٢-١٤٣.أخرجه الحارث المحاسبي في فهم القرآن ص٣٩٥-٣٩٦ من طريق سعيد، وأبو بكر ابن الأنباري -كما في الإتقان ١/٥٧- من طريق همام.تنزيل القرآن ص٣٧-٤٢.أخرجه أبو عبيد في فضائله (ت: الخياطي) ٢/٢٠٠.تفسير مقاتل بن سليمان ٤/٥٩٩.الأثر في سيرة ابن إسحاق ص١٦٠-١٦٣ مطولًا.أخرجه أحمد ٨/٤٢٣-٤٢٤ (٤٨٠٦)، ٨/٥٢٨ (٤٩٣٤)، ٩/١٠-١١ (٤٩٤١)، ١٠/٤٢ (٥٧٥٥)، والترمذي ٥/٥٢٥-٥٢٦ (٣٦٢٣)، والحاكم ٢/٥٦٠ (٣٩٠٠)، ٤/٦٢٠ (٨٧١٩)، والثعلبي ١٠/١٣٦ مختصرًا. قال الترمذي: «هذا حديث غريب». وقال الحاكم: «هذا حديث صحيح الإسناد، ولم يخرجاه». ووافقه الذهبي في التلخيص. وقال ابن القيسراني في تذكرة الحفاظ ص٣٢٩ (٨٢٩): «رواه عبد الله بن بجير الصنعاني، عن عبد الرحمن بن يزيد الصنعاني، عن ابن عمر. وعبد الله متروك الحديث، وليس هذا بابن ريسان، ذاك ثقة». وقال عبد الغني المقدسي في ذكر النار ص٨٧-٨٨ (٨٠): «هذا حديث حسن غريب». وقال الهيثمي في المجمع ٧/١٣٤ (١١٤٦٨): «رواه أحمد بإسنادين، ورجالهما ثقات». وقال ابن حجر في الفتح ٨/٦٩٥: «حديث جيد».أخرجه ابن أبي حاتم -كما في تفسير ابن كثير ٨/٣٥٢-. وعزاه السيوطي إلى الديلمي.أخرجه البخاري ٤/١٠٨ (٣٢٠٠) بلفظ: «مُكوّران»، والبزار -كما في تفسير ابن كثير ٨/٣٢٩-.أخرجه ابن جرير في تاريخه ١/٦٣-٦٥، من طريق خلف بن واصل، عن عمر بن صبح أبي نعيم البلخي، عن مقاتل بن حيّان، عن عبد الرحمن بن أبْزى، عن أبي ذرّ الغفاري به. وسنده شديد الضعف؛ فيه خلف بن واصل، اتهمه ابن حجر بالوضع. لسان الميزان ٣/٣٧٣. وفيه عمر بن صبح، وهو متروك. كما في الميزان ٣/٢٠٦.أخرجه ابن أبي الدنيا في الأهوال (٢٣)، وابن جرير ٢٤/١٢٨، وابن أبي حاتم -كما في تفسير ابن كثير ٨/٣٥٣-.أخرجه ابن جرير ٢٤/١٢٩، وابن أبي حاتم -كما في الإتقان ٢/٥٣- دون آخره. وعزاه السيوطي إلى ابن المنذر، والبيهقي في الشعب.عزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ٢٤/١٢٩.أخرجه ابن أبي حاتم -كما في تفسير ابن كثير ٨/٣٥٢-، وأبو الشيخ (٦٤٥). وعزاه السيوطي إلى ابن أبي الدنيا في الأهوال.أخرجه سعيد بن منصور ٨/٢٦١ (٢٣٩٩)، وابن جرير ٢٤/١٤٣، كما أخرجه عبد الرزاق ٢/٣٥٠-٣٥١ من طريق سفيان عن أبيه عن الربيع. وعزاه السيوطي إلى ابن أبي شيبة، وعبد بن حميد، وابن المنذر.عزاه السيوطي إلى عبد بن حميد، وابن المنذر.كذا في النسخ. وقال الجواليقي: «وهو بالفارسية: كُورْبُور». وفي اللسان: «وهو بالفارسية: كُورْبِكرِه». المعرب ص٣٣٥، واللسان (كور)، وينظر: تعليق الشيخ أحمد شاكر على المعرب. والأثر أخرجه ابن جرير ٢٤/١٣٠. وعزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ٢٤/١٣٠. وعزاه السيوطي إلى ابن أبي حاتم بلفظ: كور سود، وأنه من قول يعقوب. كما عزا السيوطي نحوه إلى عبد بن حميد بلفظ: هي كور بالفارسية، دون بيانها. وذكر محققو الدر أنها كذا في نسخه. وقال الجواليقي في المعرب ص٣٣٥: «وهو بالفارسية: كُورْبُور». وفي اللسان (كور): «وهو بالفارسية: كُورْبِكرِه».عزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه ابن جرير ٢٤/١٢٩. وعزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ٢٤/١٣٠ بنحوه. وعزاه السيوطي إلى عبد بن حميد.أخرجه آدم بن أبي إياس -كما في تفسير مجاهد ص٧٠٧-. وذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٥/٩٨-.أخرجه ابن جرير ٢٤/١٣٠. وعزاه السيوطي إلى عبد بن حميد.أخرجه عبد الرزاق ٢/٣٥٠ من طريق معمر، وابن جرير ٢٤/١٢٩ من طريق شعبة ومعمر أيضًا. وعزاه السيوطي إلى عبد بن حميد، وابن أبي حاتم.أخرجه أبو جعفر الرملي في جزئه ص٦٦ (تفسير مسلم الزنجي). وينظر: تفسير البغوي ٨/٣٤٢.تفسير مقاتل بن سليمان ٤/٦٠١.
81,2," <q>﴿وَإِذَا ٱلنُّجُومُ ٱنكَدَرَتۡ ۝٢﴾</q> - تفسير ٨١٦٢٥- عن أبي مريم، أنّ النبي ﷺ قال في قول الله: <q>﴿وإذا النُّجُومُ انْكَدَرَتْ﴾</q>، قال: «انكدرت في جهنم، وكُلُّ مَن عُبد من دون الله فهو في جهنم، إلا ما كان من عيسى ابن مريم وأُمّه، ولو رضيا أن يُعبدا لَدخلاها»{1}. (١٥/٢٥٩) ٨١٦٢٦- عن عبد الله بن عباس -من طريق علي- <q>﴿وإذا النُّجُومُ انْكَدَرَتْ﴾</q>، قال: تغيّرتْ{2}. (١٥/٢٥٨) ٨١٦٢٧- عن الربيع بن خُثَيْم -من طريق سفيان، عن أبيه، عن منذر الثوري- <q>﴿وإذا النُّجُومُ انْكَدَرَتْ﴾</q>، قال: تناثرتْ{3}. (١٥/٢٦٢) ٨١٦٢٨- عن مجاهد بن جبر -من طريق أبي يحيى- <q>﴿وإذا النُّجُومُ انْكَدَرَتْ﴾</q>، قال: تناثَرَتْ{4}. (١٥/٢٥٨) ٨١٦٢٩- عن الضَّحّاك بن مُزاحِم، <q>﴿وإذا النُّجُومُ انْكَدَرَتْ﴾</q>، قال: تساقطتْ{5}. (١٥/٢٦٠) ٨١٦٣٠- عن أبي صالح [باذام] -من طريق إسماعيل- <q>﴿وإذا النُّجُومُ انْكَدَرَتْ﴾</q>، قال: انتثَرَتْ{6}. (ز) ٨١٦٣١- عن قتادة بن دعامة -من طريق سعيد- <q>﴿وإذا النُّجُومُ انْكَدَرَتْ﴾</q>، قال: تساقطتْ، وتهافتتْ{7}. (١٥/٢٦١) ٨١٦٣٢- قال عطاء= (ز) ٨١٦٣٣- ومحمد بن السّائِب الكلبي: <q>﴿وإذا النُّجُومُ انْكَدَرَتْ﴾</q> تُمطِر السماء يومئذ نجومًا، فلا يبقى نجمٌ إلا وقع{8}. (ز) ٨١٦٣٤- قال مقاتل بن سليمان: <q>﴿وإذا النُّجُومُ انْكَدَرَتْ﴾</q>، يعني: اكدارّت الكواكب، وتناثرتْ{9}. (ز) ٨١٦٣٥- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- <q>﴿وإذا النُّجُومُ انْكَدَرَتْ﴾</q>، قال: رُمِي بها مِن السماء إلى الأرض{10}٧٠٥١. (ز) ٧٠٥١ بيّن ابنُ جرير (٢٤/١٣٢) أنّ قوله: <q>﴿انكدرت﴾</q> يعني: تناثرت وتساقطت، فقال: "وقوله: <q>﴿وإذا النجوم انكدرت﴾</q> يقول: وإذا النجوم تناثرتْ مِن السماء فتساقطتْ، وأصل الانكدار: الانصباب، كما قال العجاج: أبصر خربان فضاء فانكدر يعني بقوله: انكدر: انصب". وذكر أقوال السلف على ذلك، ثم ذكر قول ابن عباس أنّ <q>﴿انكدرت﴾</q> معناه: تغيَّرتْ، ولم يعلّق عليه. وعلّق ابنُ عطية (٨/٥٤٥) على قول ابن عباس، فقال: «وقال ابن عباس: <q>﴿انكَدَرَتْ﴾</q>: تغيَّرتْ، من قولهم: ماء كدر، أي: متغير اللون». ",footnotes:1:تقدم تخريجه في تفسير الآية السابقة.أخرجه ابن جرير ٢٤/١٣٣، وابن أبي حاتم -كما في الإتقان ٢/٥٣- دون آخره. وعزاه السيوطي إلى ابن المنذر، والبيهقي في الشعب.أخرجه سعيد بن منصور ٨/٢٦١ (٢٣٩٩)، وابن جرير ٢٤/١٣٢. كما أخرجه عبد الرزاق ٢/٣٥٠-٣٥١ من طريق سفيان، عن أبيه، عن الربيع. وعزاه السيوطي إلى ابن أبي شيبة، وعبد بن حميد، وابن المنذر.أخرجه ابن جرير ٢٤/١٣٢. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر. وأخرجه ابن أبي الدنيا في كتاب الأهوال -موسوعة الإمام ابن أبي الدنيا ٦/١٣٨ (٢١)- بلفظ: تساقطت.عزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ٢٤/١٣٢.أخرجه ابن جرير ٢٤/١٣٣. وعزاه السيوطي إلى عبد بن حميد، وابن أبي حاتم. كما أخرجه عبد الرزاق ٢/٣٥٠–٣٥١ من طريق معمر بلفظ: تناثرت.تفسير البغوي ٨/٣٤٦.تفسير مقاتل بن سليمان ٤/٦٠١.أخرجه ابن جرير ٢٤/١٣٣.
81,3," <q>﴿وَإِذَا ٱلۡجِبَالُ سُیِّرَتۡ ۝٣﴾</q> - تفسير ٨١٦٣٦- عن الربيع بن خُثَيْم، <q>﴿وإذا الجِبالُ سُيِّرَتْ﴾</q>، قال: سارَتْ{1}. (١٥/٢٦٢) ٨١٦٣٧- عن مجاهد بن جبر -من طريق أبي يحيى- <q>﴿وإذا الجِبالُ سُيِّرَتْ﴾</q>، قال: ذهبتْ{2}. (١٥/٢٥٨) ٨١٦٣٨- قال مقاتل بن سليمان: <q>﴿وإذا الجِبالُ سُيِّرَتْ﴾</q> مِن أماكنها، واستوتْ بالأرض كما كانت أول مرة{3}. (ز) ",footnotes:1:عزاه السيوطي إلى سعيد بن منصور، وابن أبي شيبة، وعبد بن حميد، وابن المنذر.أخرجه ابن أبي الدنيا في كتاب الأهوال -موسوعة الإمام ابن أبي الدنيا ٦/١٣٨ (٢١)-، وابن جرير ٢٤/١٣٣. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.تفسير مقاتل بن سليمان ٤/٦٠١.
81,4," <q>﴿وَإِذَا ٱلۡعِشَارُ عُطِّلَتۡ ۝٤﴾</q> - تفسير ٨١٦٣٩- عن أُبيّ بن كعب -من طريق أبي العالية- <q>﴿وإذا العِشارُ عُطِّلَتْ﴾</q>، قال: إذا أهملها أهلُها{1}. (١٥/٢٥٩) ٨١٦٤٠- عن الربيع بن خُثَيْم -من طريق سفيان، عن أبيه، عن منذر الثوري- <q>﴿عُطِّلَتْ﴾</q>، قال: لم تُحلَب، ولم تُصرّ، وتخلّى منها أهلُها{2}. (١٥/٢٦٢) ٨١٦٤١- عن مجاهد بن جبر -من طريق ابن أبي نجيح-: <q>﴿وإذا العِشارُ﴾</q> عشار الإبل <q>﴿عُطِّلَتْ﴾</q> لا راعي لها{3}. (١٥/٢٥٨) ٨١٦٤٢- عن مجاهد بن جبر -من طريق أبي يحيى- <q>﴿عُطِّلَتْ﴾</q>، قال: سُيِّبتْ، وتُرِكَتْ{4}. (ز) ٨١٦٤٣- عن الضَّحّاك بن مُزاحِم -من طريق عبيد- <q>﴿عُطِّلَتْ﴾</q>، يقول: لا راعي لها{4}. (ز) ٨١٦٤٤- عن عكرمة مولى ابن عباس، <q>﴿وإذا العِشارُ﴾</q>، قال: هي الإبل{6}. (١٥/٢٦٢) ٨١٦٤٥- عن الحسن البصري -من طريق عوف- <q>﴿وإذا العِشارُ عُطِّلَتْ﴾</q>، قال: سيّبها أهلها فلم تُصرّ، ولم تُحلب، ولم يكن في الدنيا مال أعجب إليهم منها{4}. (ز) ٨١٦٤٦- عن قتادة بن دعامة -من طريق معمر- <q>﴿عُطِّلَتْ﴾</q>، قال: سيَّبها أهلوها؛ أتاهم ما شغلهم عنها، فلم تُصرّ، ولم تُحلب، ولم يكن في الدنيا مال أعجب إليهم منها{8}٧٠٥٢. (١٥/٢٦١) ٧٠٥٢ لم يذكر ابنُ جرير (٢٤/١٣٤-١٣٥) غير قول قتادة، وما في معناه. ٨١٦٤٧- قال مقاتل بن سليمان: <q>﴿وإذا العِشارُ عُطِّلَتْ﴾</q> يعني: وإذا النُّوق الحوامل أُهملتْ، يعني: الناقة الحاملة نسيها أربابها، وذلك أنّه ليس شيء أحبَّ إلى الأعراب من الناقة الحاملة، يقول: أهملها أربابها للأمر الذي عاينوه{9}٧٠٥٣. (ز) ٧٠٥٣ ذكر ابنُ كثير (١٤/٢٦٠) عبارات السلف في قوله: <q>﴿عطلت﴾</q>، ثم علّق قائلًا: «والمعنى في هذا كله متقارب». وبيّن أنّ العِشار هي النُّوق الحوامل، كما جاء في أقوال السلف، ثم ذكر فيها عدة أقوال أخر، فقال: «وقد قيل في العِشار: إنها السحاب يُعطّل عن المسير بين السماء والأرض لخراب الدنيا. وقد قيل: إنها الأرض التي تعشر. وقيل: إنها الديار التي كانت تُسكن، تُعطَّل لذهاب أهلها. حكى هذه الأقوال كلها الإمام أبو عبد الله القرطبي في كتابه التذكرة، ورجّح أنها الإبل. وعزاه إلى أكثر الناس». ثم علّق قائلًا: «قلتُ: بل لا يُعرف عن السلف والأئمة سواه». ٨١٦٤٨- عن الليث [بن سعد] -من طريق ابن وهب- قال: كان بعض مَن مضى يقول في قول الله: <q>﴿وإذا العِشارُ عُطِّلَتْ﴾</q>: العِشار: اللقاح عُطِّلتْ{10}. (ز) <q>﴿وَإِذَا ٱلۡعِشَارُ عُطِّلَتۡ ۝٤﴾</q> - آثار متعلقة بالآية ٨١٦٤٩- عن سفيان بن عُيينة، قال: قال عمر بن ذرّ: ... مَن جاء يلتمس الخبرَ فقد وجد الخبر، هذا تقويض الدنيا. ثم قرأ: <q>﴿إذا الشمس كورت﴾</q>، فكان ابن ذرّ يقول: هيهات العِشار وأهل العِشار، عطّلها أهلُها بعد الضَّنِّ بها{11}. (ز) ",footnotes:1:أخرجه ابن أبي الدنيا في الأهوال (٢٣)، وابن جرير ٢٤/١٣٤، وابن أبي حاتم -كما في تفسير ابن كثير ٨/٣٥٣-.أخرجه سعيد بن منصور ٨/٢٦١ (٢٣٩٩)، وابن جرير ٢٤/١٣٤. كما أخرجه عبد الرزاق ٢/٣٥٠-٣٥١ من طريق سفيان، عن أبيه، عن الربيع. وعزاه السيوطي إلى ابن أبي شيبة، وعبد بن حميد، وابن المنذر.تفسير مجاهد ص٧٠٧ بلفظ: العشار: هي الإبل عطلها أربابها، وأخرجه ابن جرير ٢٤/١٣٥. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه ابن جرير ٢٤/١٣٥.أخرجه ابن جرير ٢٤/١٣٥.عزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.أخرجه ابن جرير ٢٤/١٣٥.أخرجه عبد الرزاق ٢/٣٥٠، وابن جرير ٢٤/١٣٥ بلفظ: عشار الإبل سُيِّبت. وعزاه السيوطي إلى عبد بن حميد، وابن أبي حاتم.تفسير مقاتل بن سليمان ٤/٦٠١.أخرجه عبد الله بن وهب في الجامع -تفسير القرآن ٢/١٥٧ (٣٢٤).أخرجه أبو نعيم في حلية الأولياء ٥/١١٠.
81,5," <q>﴿وَإِذَا ٱلۡوُحُوشُ حُشِرَتۡ ۝٥﴾</q> - تفسير ٨١٦٥٠- عن أُبيّ بن كعب -من طريق أبي العالية- <q>﴿وإذا الوُحُوشُ حُشِرَتْ﴾</q>، قال: اختلطتْ{1}. (١٥/٢٥٩) ٨١٦٥١- عن عبد الله بن عباس -من طريق عكرمة- <q>﴿وإذا الوُحُوشُ حُشِرَتْ﴾</q>، قال: حشْر البهائم: موتها، وحشْر كلّ شيء: الموت، غير الجن والإنس؛ فإنهما يوافيان يوم القيامة{2}. (١٥/٢٦٣) ٨١٦٥٢- عن عبد الله بن عباس -من طريق الضَّحّاك بن قيس- <q>﴿وإذا الوُحُوشُ حُشِرَتْ﴾</q>، قال: يُحشَر كلُّ شيء يوم القيامة، حتى إنّ الذباب ليُحشر{3}. (١٥/٢٦٣) ٨١٦٥٣- عن الربيع بن خُثَيْم -من طريق منذر الثوري- <q>﴿وإذا الوُحُوشُ حُشِرَتْ﴾</q>، قال: أتى عليها أمْرُ الله{4}. (١٥/٢٦٢) ٨١٦٥٤- عن الضَّحّاك بن مُزاحِم، <q>﴿وإذا الوُحُوشُ حُشِرَتْ﴾</q>، قال: حشْرها: موتها{5}. (١٥/٢٦٠) ٨١٦٥٥- عن عكرمة مولى ابن عباس، <q>﴿وإذا الوُحُوشُ حُشِرَتْ﴾</q>، قال: حشْر البهائم: موتها{6}. (١٥/٢٦٢) ٨١٦٥٦- عن قتادة بن دعامة -من طريق سعيد- <q>﴿وإذا الوُحُوشُ حُشِرَتْ﴾</q>، قال: إنّ هذه الخلائق موافية يوم القيامة، فيقضي الله فيها ما يشاء{7}. (١٥/٢٦١) ٨١٦٥٧- قال مقاتل بن سليمان: <q>﴿وإذا الوُحُوشُ حُشِرَتْ﴾</q>، يعني: جُمِعَتْ{8}٧٠٥٤. (ز) ٧٠٥٤ اختُلف في قوله: <q>﴿حشرت﴾</q> على أقوال: الأول: ماتت: الثاني: جُمعت. الثالث: اختلطت. وقد جمع ابنُ جرير (٢٤/١٣٧) بين القول الأول والثاني مستندًا إلى اللغة، والنظائر، فقال: «وأولى الأقوال في ذلك بالصواب قولُ مَن قال: معنى <q>﴿حشرت﴾</q>: جُمعت، فأُميتت. لأنّ المعروف في كلام العرب من معنى الحشْر: الجمع، ومنه قول الله: <q>﴿والطير محشورة﴾</q> [ص:١٩] يعني: مجموعة، وقوله: <q>﴿فحشر فنادى﴾</q> [النازعات:٢٣]، وإنما يُحمل تأويل القرآن على الأغلب الظاهر مِن تأويله، لا على الأنكر المجهول». ",footnotes:1:أخرجه ابن أبي الدنيا في الأهوال (٢٣)، وابن جرير ٢٤/١٣٦-١٣٧، وابن أبي حاتم -كما في تفسير ابن كثير ٨/٣٥٣-.أخرجه ابن جرير ٢٤/١٣٦، والحاكم ٢/٥١٥. وعزاه السيوطي إلى الفريابي، وسعيد بن منصور، وعبد بن حميد، وابن المنذر، وابن مردويه.أخرجه ابن أبي حاتم -كما في تفسير ابن كثير ٨/٣٥٤-، والخطيب في المتفق والمفترق (٧٦٨). وعزاه السيوطي إلى ابن المنذر.أخرجه سعيد بن منصور ٨/٢٦١ (٢٣٩٩)، وابن جرير ٢٤/١٣٦. وعزاه السيوطي إلى ابن أبي شيبة، وعبد بن حميد، وابن المنذر.عزاه السيوطي إلى عبد بن حميد.عزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.أخرجه ابن جرير ٢٤/١٣٧. وعزاه السيوطي إلى عبد بن حميد، وابن أبي حاتم.تفسير مقاتل بن سليمان ٤/٦٠١.
81,6," <q>﴿وَإِذَا ٱلۡبِحَارُ سُجِّرَتۡ ۝٦﴾</q> - تفسير ٨١٦٥٨- عن أُبيّ بن كعب -من طريق أبي العالية- <q>﴿وإذا البِحارُ سُجِّرَتْ﴾</q>، قال: قالت الجن للإنس: نحن نأتيكم بالخبر. فانطلقوا إلى البحار، فإذا هي تأجّج نارًا {1}. (١٥/٢٥٩) ٨١٦٥٩- عن علي بن أبي طالب -من طريق سعيد بن المسيّب- أنه سأل رجلًا مِن اليهود: أين جهنم؟ فقال: البحر. فقال: ما أراه إلا صادقًا، <q>﴿والبَحْرِ المَسْجُورِ﴾</q> [الطور:٦]، ‹وإذا البِحارُ سُجِرَتْ› مُخفّفة{2}٧٠٥٥. (ز) ٧٠٥٥ ذكر ابنُ جرير (٢٤/١٤٠) قراءة التخفيف والتثقيل في قوله: <q>﴿سجرت﴾</q>، ثم علّق عليهما قائلًا: «والصواب من القول في ذلك: أنهما قراءتان معروفتان متقاربتا المعنى، فبأيتهما قرأ القارئ فمصيب». ورجّح ابنُ عطية (٨/٥٤٦) -مستندًا إلى الدلالة العقلية- قراءة التثقيل بقوله: «وهي مترجحة بكون البحار جمعًا، كما قال: <q>﴿كِتابًا يَلْقاهُ مَنشُورًا﴾</q> [الإسراء:١٣]، وكما قال: <q>﴿صُحُفًا مُنَشَّرَةً﴾</q> [المدثر:٥٢]، ومثله: <q>﴿قَصْرٍ مَشِيدٍ﴾</q> [الحج:٤٥]، و<q>﴿بُرُوجٍ مُشَيَّدَةٍ﴾</q> [النساء:٧٨] لأنها جماعة». ٨١٦٦٠- عن عبد الله بن عباس -من طريق مجالد، عن شيخ من بَجِيلة- في قوله: <q>﴿إذا الشَّمْسُ كُوِّرَتْ﴾</q>، قال: كوَّر الله الشمسَ والقمرَ والنجومَ في البحر، فيبعث عليها ريحًا دبورًا، فتنفخه حتى يصير نارًا، فذلك قوله: <q>﴿وإذا البِحارُ سُجِّرَتْ﴾</q>{2}. (ز) ٨١٦٦١- عن عبد الله بن عباس -من طريق الضَّحّاك- أنّ نافع بن الأزرق سأله عن قوله: <q>﴿وإذا البِحارُ سُجِّرَتْ﴾</q>. قال: اختلط ماؤها بماء الأرض. قال: وهل تعرف العرب ذلك؟ قال: نعم، أما سمعتْ زُهير بن أبي سُلمى وهو يقول: لقد نازعتُمُ حسبًا قديمًا وقد سجَرَت بحارُهُمُ بحاري؟{4}. (١٥/٢٦٣) ٨١٦٦٢- عن عبد الله بن عباس -من طريق عكرمة- <q>﴿وإذا البِحارُ سُجِّرَتْ﴾</q>، قال: تسجَّر حتى تصير نارًا{5}. (١٥/٢٦٤) ٨١٦٦٣- عن الربيع بن خُثَيْم -من طريق سفيان، عن أبيه، عن أبي يعلى- <q>﴿وإذا البِحارُ سُجِّرَتْ﴾</q>، قال: فاضتْ{6}. (١٥/٢٦٢) ٨١٦٦٤- عن مجاهد بن جبر -من طريق جابر- <q>﴿وإذا البِحارُ سُجِّرَتْ﴾</q>، قال: أُوقِدَتْ{7}. (١٥/٢٥٨) ٨١٦٦٥- عن الضَّحّاك بن مُزاحِم -من طريق عبيد- <q>﴿وإذا البِحارُ سُجِّرَتْ﴾</q>، قال: ذهب ماؤها؛ غار ماؤها. قال: سُجّرتْ وفُجِّرتْ سواء{8}. (١٥/٢٦٠، ٢٦٤) ٨١٦٦٦- عن عكرمة مولى ابن عباس -من طريق جابر- في قوله: <q>﴿وإذا البحار سُجِّرَتْ﴾</q>، قال: أُوقِدَتْ{9}. (ز) ٨١٦٦٧- عن الحسن البصري، في قوله: <q>﴿وإذا البِحارُ سُجِّرَتْ﴾</q>، قال: غار ماؤها، فذهب{10}. (١٥/٢٦٤) ٨١٦٦٨- عن الحسن البصري -من طريق سليمان التيمي، وأبي رجاء- في هذا الحرف: <q>﴿وإذا البِحارُ سُجِّرَتْ﴾</q>، قال: يَبستْ{11}. (ز) ٨١٦٦٩- قال الحسن البصري: <q>﴿وإذا البِحارُ سُجِّرَتْ﴾</q>، يعني: فاضتْ{12}. (ز) ٨١٦٧٠- عن وهب بن مُنبِّه -من طريق أبي الهذيل- <q>﴿وإذا البِحارُ سُجِّرَتْ﴾</q>، قال: سُجّرت البحار نارًا{13}. (ز) ٨١٦٧١- عن قتادة بن دعامة -من طريق سعيد- <q>﴿وإذا البِحارُ سُجِّرَتْ﴾</q>، قال: ذهب ماؤها، ولم يبقَ منها قطرة{14}. (١٥/٢٦١) ٨١٦٧٢- عن إسماعيل السُّدِّيّ، <q>﴿وإذا البِحارُ سُجِّرَتْ﴾</q>، قال: فُتِحتْ وسُيِّرتْ{15}. (١٥/٢٦٤) ٨١٦٧٣- عن شِمْر بن عطية -من طريق حفص بن حميد- <q>﴿وإذا البِحارُ سُجِّرَتْ﴾</q>، قال: تُسجّر كما يُسجّر التّنُّور{16}. (١٥/٢٦٤) ٨١٦٧٤- عن محمد بن السّائِب الكلبي -من طريق معمر- <q>﴿وإذا البِحارُ سُجِّرَتْ﴾</q>، قال: مُلئتْ، ألا تراه يقول: <q>﴿والبَحْرِ المَسْجُورِ﴾</q> [الطور:٦]؟{17}. (ز) ٨١٦٧٥- قال مقاتل بن سليمان: <q>﴿وإذا البِحارُ سُجِّرَتْ﴾</q>، يعني: فُجِّرتْ بعضها في جوف بعض، العَذْب والمالح، فصارت البحور كلّها بحرًا واحدًا، مثل طشتٍ فيه ماء{18}. (ز) ٨١٦٧٦- عن سفيان [الثوري] -من طريق مهران- <q>﴿وإذا البِحارُ سُجِّرَتْ﴾</q>، قال: أُوقِدَتْ{2}. (ز) ٨١٦٧٧- قال عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿وإذا البِحارُ سُجِّرَتْ﴾</q>، قال: إنها تُوقَد يوم القيامة، زعموا ذلك التسجير في كلام العرب{2}٧٠٥٦. (ز) ٧٠٥٦ اختُلف في قوله: <q>﴿سجرت﴾</q> على أقوال: الأول: أي: اشتعلتْ نارًا وحميتْ. الثاني: أي: فاضتْ. الثالث: أي: ذهب ماؤها. وقد رجّح ابنُ جرير (٢٤/١٤٠) -مستندًا إلى النظائر، وإلى اللغة- أنّ المعنى: "مُلئتْ حتى فاضتْ، فانفجرتْ وسالتْ كما وصفها اللهُ به في الموضع الآخر، فقال: <q>﴿وإذا البحار فجرت﴾</q> [الانفطار:٣]، والعرب تقول للنهر أو للركي المملوء: ماء مسجور، ومنه قول لبيد: فَتَوَسَّطا عُرْضَ السَّرِيِّ وصَدَّعا مَسْجُورةً مُتَجاوِرًا قُلّامُها ويعني بالمسجورة: المملوءة ماء". وذكر ابنُ عطية (٨/٥٤٦) هذه الأقوال، ثم علّق قائلًا: «ويحتمل أن يكون المعنى: مُلكتْ، وقُيِّد اضطرابها حتى لا تخرج على الأرض بسبب الهول، فتكون اللفظة مأخوذة من ساجور الكلب». ",footnotes:1:أخرجه ابن أبي الدنيا في الأهوال (٢٣)، وابن جرير ٢٤/١٣٧، وابن أبي حاتم -كما في تفسير ابن كثير ٨/٣٥٣-.أخرجه ابن جرير ٢٤/١٣٨.أخرجه ابن جرير ٢٤/١٣٨.أخرجه الطبراني في المعجم الكبير ١٠/٢٤٨-٢٥٦ (١٠٥٩٧) مطولًا.أخرجه آدم بن أبي إياس -كما في تفسير مجاهد ص٧٠٧- من طريق كثير أبي محمد. وعزاه السيوطي إلى البيهقي في البعث.أخرجه ابن جرير ٢٤/١٣٩، كما أخرجه عبد الرزاق ٢/٣٥٠-٣٥١ من طريق سفيان، عن أبيه، عن الربيع. وعزاه السيوطي إلى سعيد بن منصور، وابن أبي شيبة، وعبد بن حميد، وابن المنذر.تفسير مجاهد ص٧٠٧. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه ابن جرير ٢٤/١٣٩ بنحوه. وعزاه السيوطي إلى عبد بن حميد، كما عزا نحوه إلى ابن المنذر.أخرجه آدم بن أبي إياس -كما في تفسير مجاهد ص٧٠٧-.عزاه السيوطي إلى عبد بن حميد، وابن جرير، وابن المنذر. وعند ابن جرير ٢٤/١٤٠ بلفظ: يبست، وعلق البخاري في صحيحه ٤/١٨٨٣ نحوه.أخرجه ابن جرير ٢٤/١٤٠.ذكره يحيى بن سلام –كما في تفسير ابن أبي زمنين ٥/٩٩-.أخرجه عبد الرزاق ٢/٣٥٠.أخرجه ابن جرير ٢٤/١٣٩-١٤٠، وأخرجه عبد الرزاق ٢/٣٥٠ من طريق معمر بنحوه، وكذلك ابن جرير. وعزاه السيوطي إلى عبد بن حميد، وابن أبي حاتم.أخرجه ابن أبي حاتم -كما في فتح الباري ٨/٦٩٣-.أخرجه ابن جرير ٢٤/١٣٨ بنحوه. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه عبد الرزاق ٢/٣٥٠، وابن جرير ٢٤/١٣٩.تفسير مقاتل بن سليمان ٤/٦٠١.أخرجه ابن جرير ٢٤/١٣٨.أخرجه ابن جرير ٢٤/١٣٨.
81,7," <q>﴿وَإِذَا ٱلنُّفُوسُ زُوِّجَتۡ ۝٧﴾</q> - تفسير ٨١٦٧٨- عن النُّعمان بن بشير: سمعتُ رسول الله ﷺ يقول: <q>﴿وإذا النُّفُوسُ زُوِّجَتْ﴾</q>، قال: «هما الرجلان يعملان العمل، يدخلان الجنة والنار». وقال: <q>﴿احْشُرُوا الَّذِينَ ظَلَمُوا وأَزْواجَهُمْ﴾</q> [الصافات:٢٢]{1}. (١٥/٢٦٥) ٨١٦٧٩- عن النعمان بن بشير أنه قال: قال رسول الله ﷺ: <q>﴿وإذا النُّفُوسُ زُوِّجَتْ﴾</q>، قال: «الضُّرَباء؛ كل رجل مع كل قوم كانوا يعملون عمله، وذلك بأن الله ﷿ يقول: <q>﴿وكنتم أزواجا ثلاثة فأصحاب الميمنة ما أصحاب الميمنة وأصحاب المشأمة ما أصحاب المشأمة والسابقون السابقون﴾</q> [الواقعة:٧-١٠]، قال: هم الضُّرَباء»{2}. (ز) ٨١٦٨٠- عن عمر بن الخطاب -من طريق سماك بن حرب، عن النُّعمان بن بشير- <q>﴿وإذا النُّفُوسُ زُوِّجَتْ﴾</q>، قال: هو الرجل يُزوّج نظيره من أهل الجنة، والرجل يُزوّج نظيره من أهل النار يوم القيامة. ثم قرأ: <q>﴿احْشُرُوا الَّذِينَ ظَلَمُوا وأَزْواجَهُمْ﴾</q> [الصافات:٢٢]{3}. (١٥/٢٦٥) ٨١٦٨١- عن عمر بن الخطاب، <q>﴿وإذا النُّفُوسُ زُوِّجَتْ﴾</q>، قال: تزويجها: أن يؤلّف كلّ قوم إلى شبههم{4}. (١٥/٢٦٥) ٨١٦٨٢- عن عمر بن الخطاب -من طريق سماك بن حرب، عن النُّعمان بن بشير- <q>﴿وإذا النفوس زوجت﴾</q>، قال: هما الرجلان يعملان العمل، فيدخلان به الجنة. وقال: <q>﴿احشروا الذين ظلموا وأزواجهم﴾</q> [الصافات:٢٢]، قال: ضرباءهم{5}. (ز) ٨١٦٨٣- عن عمر بن الخطاب -من طريق النُّعمان بن بشير- أنه سُئِل عن قوله: <q>﴿وإذا النُّفُوسُ زُوِّجَتْ﴾</q>. قال: يُقرَن بين الرجل الصالح مع الصالح في الجنة، ويُقرَن بين الرجل السوء مع السوء في النار، فذلك تزويج الأنفس{6}. (١٥/٢٦٤) ٨١٦٨٤- عن عبد الله بن عباس -من طريق سعيد- قال: يسيل وادٍ مِن أصل العرش مِن ماءٍ فيما بين الصيحتين، ومقدار ما بينهما أربعون عامًا، فيَنبتُ منه كلُّ خَلْقٍ بَلِي مِن الإنسان أو طير أو دابة، ولو مرّ عليهم مارٌّ قد عرفهم قبل ذلك لَعرفهم على وجه الأرض قد نبتوا، ثم تُرسل الأرواح فتُزَوّج الأجساد، فذلك قول الله: <q>﴿وإذا النُّفُوسُ زُوِّجَتْ﴾</q>{7}. (١٥/٢٦٥) ٨١٦٨٥- عن عبد الله بن عباس -من طريق عطية العَوفيّ- قوله: <q>﴿وإذا النُّفُوسُ زُوِّجَتْ﴾</q>، قال: ذلك حين يكون الناس أزواجًا ثلاثة{8}. (ز) ٨١٦٨٦- عن الربيع بن خُثَيْم -من طريق سفيان، عن أبيه، عن منذر الثوري- <q>﴿وإذا النُّفُوسُ زُوِّجَتْ﴾</q>، قال: كلّ رجل مع صاحب عمله{9}. (١٥/٢٦٢) ٨١٦٨٧- عن أبي العالية الرِّياحيّ، <q>﴿وإذا النُّفُوسُ زُوِّجَتْ﴾</q>، قال: زوّج الروح للجسد{10}. (١٥/٢٦٦) ٨١٦٨٨- عن سعيد [بن جُبَير] -من طريق جعفر- في قوله ﷿: <q>﴿وإذا النفوس زوجت﴾</q>، قال: زُوِّجت الأرواحُ الأبدان{11}. (ز) ٨١٦٨٩- قال مجاهد بن جبر -من طريق ابن أبي نجيح- <q>﴿وإذا النُّفُوسُ زُوِّجَتْ﴾</q>، قال: الأمثال للناس جُمِع بينهم{12}. (١٥/٢٥٨) ٨١٦٩٠- عن الضَّحّاك بن مُزاحِم، <q>﴿وإذا النُّفُوسُ زُوِّجَتْ﴾</q>، قال: زُوِّجت الأرواح الأجساد{13}. (١٥/٢٦٠) ٨١٦٩١- عن عكرمة مولى ابن عباس -من طريق أبي عمرو- <q>﴿وإذا النُّفُوسُ زُوِّجَتْ﴾</q>، قال: ترجع الأرواح إلى أجسادها{14}. (١٥/٢٦٢) ٨١٦٩٢- عن عكرمة مولى ابن عباس -من طريق سعيد- <q>﴿وإذا النُّفُوسُ زُوِّجَتْ﴾</q>، قال: يُقرن الرجل في الجنة بقرينه الصالح في الدنيا، ويُقرن الرجل الذي كان يعمل السوء في الدنيا بقرينه الذي كان يعينه في النار{15}. (١٥/٢٦٦) ٨١٦٩٣- عن عامر الشعبي -من طريق داود- <q>﴿وإذا النُّفُوسُ زُوِّجَتْ﴾</q>، قال: زُوّج الروح بالجسد، وأُعيدت الأرواح في الأجساد{16}. (١٥/٢٦٦) ٨١٦٩٤- عن الحسن البصري -من طريق عوف- <q>﴿وإذا النُّفُوسُ زُوِّجَتْ﴾</q>، قال: أُلحِق كلُّ امرئٍ بشِيعته{17}. (ز) ٨١٦٩٥- عن قتادة بن دعامة -من طريق سعيد- <q>﴿وإذا النُّفُوسُ زُوِّجَتْ﴾</q>، قال: أُلْحِقَ كلُّ إنسان بشيعته؛ اليهود باليهود، والنصراني بالنصراني{18}. (١٥/٢٦١) ٨١٦٩٦- عن قتادة بن دعامة -من طريق معمر- <q>﴿وإذا النُّفُوسُ زُوِّجَتْ﴾</q>، قال: أشكالهم{19}. (ز) ٨١٦٩٧- قال عطاء [بن أبي رباح]: <q>﴿وإذا النُّفُوسُ زُوِّجَتْ﴾</q> زُوِّجتْ نفوس المؤمنين بالحُور العين، وقُرنتْ نفوس الكافرين بالشياطين{20}. (ز) ٨١٦٩٨- عن محمد بن السّائِب الكلبي، <q>﴿وإذا النُّفُوسُ زُوِّجَتْ﴾</q>، قال: زُوِّج المؤمنون الحُورَ العين، والكفارُ الشياطينَ{21}. (١٥/٢٦٦) ٨١٦٩٩- قال مقاتل بن سليمان: <q>﴿وإذا النُّفُوسُ زُوِّجَتْ﴾</q> أُزوجتْ أنفس المؤمنين مع الحُور العين، وأُزوجتْ أنفس الكافرين مع الشياطين، يعني: ابن آدم وشيطانه مقرونًا في السلسلة الواحدة زوجان. نظيرها في سورة الصافات [٢٢] قوله ﷿: <q>﴿احْشُرُوا الَّذِينَ ظَلَمُوا وأَزْواجَهُمْ﴾</q> يعني: قرناءهم{22}٧٠٥٧. (ز) ٧٠٥٧ اختُلف في قوله: <q>﴿وإذا النفوس زوجت﴾</q> على أقوال: الأول: أُلحِق كلّ إنسان بشكله، وقُرِن بين الضرباء والأمثال. الثاني: عني بذلك: أنّ الأرواح رُدَّتْ إلى الأجساد، فزُوِّجتْ بها، أي: جُعلتْ لها زوجًا. الثالث: زُوِّجتْ أنفس المؤمنين الحُور العين، وأنفس المشركين الشياطين. وعلّق ابنُ عطية (٨/٥٤٧) على القول الأول بقوله: «وفي الآية على هذا حضٌّ على دليل الخير، فقد قال ﵇: «المرء مع من أحب». وقال: «فلينظر أحدكم مَن يُخالِل». وقال الله تعالى: <q>﴿الأَخِلّاءُ يَوْمَئِذٍ بَعْضُهُمْ لِبَعْضٍ عَدُوٌّ إلّا المُتَّقِينَ﴾</q> [الزخرف:٦٧]». ورجّح ابنُ جرير (٢٤/١٤٤) -مستندًا إلى النظائر- القول الأول، وهو قول عمر وغيره، فقال: «وأولى التأويلين في ذلك بالصحة: الذي تأوله عمر بن الخطاب ﵁؛ للعلّة التي اعتل بها، وذلك قول الله -تعالى ذِكره-: <q>﴿وكُنْتُمْ أزْواجًا ثَلاثَةً﴾</q> [الواقعة:٧]، وقوله: <q>﴿احْشُرُوا الَّذِينَ ظَلَمُوا وأَزْواجَهُمْ﴾</q> [الصافات:٢٢]، وذلك لا شك الأمثال والأشكال في الخير والشر، وكذلك قوله: <q>﴿وإذا النفوس زوجت﴾</q> بالقرناء والأمثال في الخير والشر». ولم يذكر ابنُ القيم (٣/٢٥٦-٢٥٧) غير القول الأول والثالث، ورجّح الأول مستندًا إلى قول النبي ﷺ: «لا يحب المرء قومًا إلا حُشِر معهم». ثم علّق على القول الثالث بقوله: «وهو راجع إلى القول الأول». ",footnotes:1:أخرجه ابن مردويه -كما في الفتح ٨/٦٩٤-.أخرجه ابن أبي حاتم -كما في تفسير ابن كثير ٨/ ٣٣٢-، من طريق أبيه، عن محمد بن الصباح البزار، عن الوليد بن أبي ثور، عن سماك به.أخرجه آدم بن أبي إياس -كما في تفسير مجاهد ص٧٠٧-، وابن مردويه -كما في تغليق التعليق ٤/٣٦١-٣٦٢-.أخرجه ابن منيع -كما في المطالب العالية (٤١٧٦)-.أخرجه ابن جرير ٢٤/١٤١.أخرجه عبد الرزاق ٢/٣٥٠ بنحوه، وابن أبي شيبة ١٣/٢٧٩، وعبد بن حميد -كما في تغليق التعليق ٤/٣٦٢-، وابن جرير ٢٤/١٤٢ بنحوه، وابن أبي حاتم -كما في تفسير ابن كثير ٨/٣٥٥-، والحاكم ٢/٥١٥-٥١٦ بنحوه، وابن مردويه -كما في تغليق التعليق ٤/٣٦١-، وأبو نعيم في الحلية -كما في فتح الباري ٦/٦٩٤-. وعزاه السيوطي إلى الفريابي، وسعيد بن منصور، وابن المنذر، والبيهقي في البعث.أخرجه ابن أبي حاتم -كما في تفسير ابن كثير ٨/٣٥٥-.أخرجه ابن جرير ٢٤/١٤٣.أخرجه سعيد بن منصور ٨/٢٦١ (٢٣٩٩)، وابن جرير ٢٤/١٤٣. كما أخرجه عبد الرزاق ٢/٣٥٠-٣٥١ من طريق سفيان، عن أبيه، عن الربيع. وعزاه السيوطي إلى ابن أبي شيبة، وعبد بن حميد، وابن المنذر.عزاه السيوطي إلى سعيد بن منصور، وابن المنذر.أخرجه أبو جعفر الرملي في جزئه ص٣٦ (تفسير يحيى بن يمان).تفسير مجاهد ص٧٠٧، وأخرجه ابن أبي الدنيا في كتاب الأهوال -موسوعة الإمام ابن أبي الدنيا ٦/١٣٨ (٢١)-، وابن جرير ٢٤/١٤٣. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر. وزاد ابن أبي الدنيا: الزُّناة مع الزُّناة، وأَكَلة الربا مع أكَلة الربا، وقَتَلة النفس مع قَتَلة النفس.عزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ٢٤/١٤٤، ومن طريق محمد أيضًا. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.أخرجه الفراء في معاني القرآن ٣/٢٣٩-٢٤٠.أخرجه ابن جرير ٢٤/١٤٤. وعزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ٢٤/١٤٣. وذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٥/٩٩- بنحوه.أخرجه ابن جرير ٢٤/١٤٣. وعزاه السيوطي إلى عبد بن حميد، وابن أبي حاتم.أخرجه عبد الرزاق ٢/٣٥٠.تفسير البغوي ٨/٣٤٧.عزاه السيوطي إلى عبد بن حميد، وابن المنذر.تفسير مقاتل بن سليمان ٤/٦٠١.
81,8," <q>﴿وَإِذَا ٱلۡمَوۡءُۥدَةُ سُىِٕلَتۡ ۝٨ بِأَیِّ ذَنۢبࣲ قُتِلَتۡ ۝٩﴾</q> - قراءات ٨١٧٠٠- عن أبي الضُّحى مُسلم بن صُبيح -من طريق الأعمش- أنه قرأ: (وإذا المَوْءُودَةُ سَأَلَتْ)، قال: طلبتْ قاتلَها بدمائها{1}. (١٥/٢٦٧) ٨١٧٠١- عن قتادة بن دعامة -من طريق سعيد- <q>﴿وإذا المَوْءُودَةُ سُئِلَتْ﴾</q>، قال: هي في بعض القراءة: (سَأَلَتْ بِأَيِّ ذَنبٍ قُتِلْتُ){2}٧٠٥٨. (١٥/٢٦١) ٧٠٥٨ ذكر ابنُ جرير (٢٤/١٤٥، ١٤٧-١٤٨) قراءة: (سَأَلَتْ)، ووجّهها، فقال: «قرأه أبو الضُّحى مُسلم بن صُبيح: (وإذا المَوْءُودَةُ سَأَلَتْ بِأَيِّ ذَنبٍ قُتِلْتُ) بمعنى: سألت الموءودة الوائدين: بأي ذنب قتلوها». ثم علّق عليها قائلًا: «ولو قرأ قارئ ممن قرأ: (سَأَلَتْ بِأَيِّ ذَنبٍ قُتِلْتُ) كان له وجه، وكان يكون معنى ذلك مَن قرأ: <q>﴿بأي ذنب قتلت﴾</q> غير أنه إذا كان حكاية جاز فيه الوجهان». ووجّه قراءة <q>﴿سُئلت﴾</q> بقوله: «وقرأ ذلك بعض عامة قراء الأمصار: <q>﴿وإذا الموءودة سئلت بأي ذنب قتلت﴾</q> بمعنى: سُئلت الموءودة بأي ذنبٍ قُتلتْ، ومعنى <q>﴿قتلت﴾</q> قُتلتْ غير أنّ ذلك ردٌّ إلى الخبر على وجه الحكاية على نحو القول الماضي قبل، وقد يتوجه معنى ذلك إلى أن يكون: وإذا الموءودة سألتْ قَتَلتَها ووائديها، بأي ذنبٍ قتلوها؟ ثم ردّ ذلك إلى ما لم يُسمّ فاعله، فقيل: بأي ذنبٍ قُتلتْ». وعلّق عليها ابنُ عطية (٨/٥٤٨) بقوله: «وهذا على وجه التوبيخ للعرب الفاعلين ذلك؛ لأنها تسأل ليصير الأمر إلى سؤال الفاعلين، ويحتمل أن تكون مسؤولًا عنها مطلوبًا الجواب منهم. كما قال تعالى: <q>﴿إن العهد كان مسؤلا﴾</q> [الإسراء:٣٤]، وكما سُئل التراث والحقوق». ثم رجّح ابنُ جرير قراءة: <q>﴿سئلت﴾</q> مستندًا إلى إجماع الحجة من القراء، فقال: «وأولى القراءتين في ذلك عندنا بالصواب قراءة مَن قرأ ذلك <q>﴿سُئلت﴾</q> بضم السين <q>﴿بأي ذنب قتلت﴾</q> على وجه الخبر؛ لإجماع الحجّة من القراء عليه». <q>﴿وَإِذَا ٱلۡمَوۡءُۥدَةُ سُىِٕلَتۡ ۝٨ بِأَیِّ ذَنۢبࣲ قُتِلَتۡ ۝٩﴾</q> - تفسير الآية ٨١٧٠٢- عن جُدامة بنت وهب، قالت: سُئِل رسول الله ﷺ عن العَزْل. فقال: «ذاك الوَأْدُ الخفي، وهي: <q>﴿وإذا المَوْءُودَةُ سُئِلَتْ﴾</q>»{3}. (١٥/٢٦٧) ٨١٧٠٣- عن عبد الله بن عباس -من طريق علي- <q>﴿وإذا المَوْءُودَةُ سُئِلَتْ﴾</q>، يقول: سألت{4}. (١٥/٢٥٨) ٨١٧٠٤- عن عكرمة مولى ابن عباس، <q>﴿وإذا المَوْءُودَةُ سُئِلَتْ﴾</q>، قال: أطفال المشركين.= (ز) ٨١٧٠٥- قال ابن عباس: الموءودة هي المدفونة، كانت المرأة في الجاهلية إذا هي حَملتْ فكان أوان ولادها حَفرتْ حفرة، فتمخّضتْ على رأس تلك الحفرة، فإن ولدت جارية رَمتْ بها في تلك الحفرة، وإن ولدتْ غلامًا حبستْه. قال ابن عباس: فمَن زعم أنهم في النار فقد كذب، بل هم في الجنة{5}. (١٥/٢٦٢) ٨١٧٠٦- عن الربيع بن خُثَيْم -من طريق منذر الثوري- <q>﴿وإذا المَوْءُودَةُ سُئِلَتْ﴾</q>، قال: كانت العرب مِن أفعل الناس لذلك{6}. (١٥/٢٦٢) ٨١٧٠٧- قال الحسن البصري: <q>﴿بِأَيِّ ذَنْبٍ قُتِلَتْ﴾</q> أراد الله أن يُوَبِّخ قاتلها؛ لأنها قُتلتْ بغير ذنب{7}. (ز) ٨١٧٠٨- عن قتادة بن دعامة -من طريق سعيد- <q>﴿وإذا المَوْءُودَةُ سُئِلَتْ﴾</q>، قال: هي في بعض القراءة: (سَأَلَتْ بِأَيِّ ذَنبٍ قُتِلْتُ). قال: لا بذنب. قال: وكان أهل الجاهلية يقتل أحدهم ابنته، ويغذو كلبه؛ فعاب اللهُ ذلك عليهم{2}. (١٥/٢٦١) ٨١٧٠٩- قال مقاتل بن سليمان: <q>﴿وإذا المَوْؤُدَةُ سُئِلَتْ﴾</q> يعني: دفْن البنات، وذلك أنّ أهل الجاهلية كان أحدهم إذا وُلدت له الابنة دفنها في التراب وهي حيّة، <q>﴿بِأَيِّ ذَنْبٍ قُتِلَتْ﴾</q> سُئل قاتلها بأي ذنبٍ قَتلها وهي حيّة لم تُذنب قط{9}. (ز) ٨١٧١٠- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- <q>﴿وإذا المَوْءُودَةُ سُئِلَتْ﴾</q> قال: البنات التي كانت طوائف يقتلونهن. وقرأ: <q>﴿بِأَيِّ ذَنْبٍ قُتِلَتْ﴾</q>{10}. (ز) <q>﴿وَإِذَا ٱلۡمَوۡءُۥدَةُ سُىِٕلَتۡ ۝٨ بِأَیِّ ذَنۢبࣲ قُتِلَتۡ ۝٩﴾</q> - آثار متعلقة بالآية ٨١٧١١- عن عمر بن الخطاب، في قوله: <q>﴿وإذا المَوْءُودَةُ سُئِلَتْ﴾</q>، قال: جاء قيس بن عاصم التميمي إلى رسول الله ﷺ، فقال: إنِّي وأدتُ ثمان بنات لي في الجاهلية. فقال له النبي ﷺ: «أعتِقْ عن كلّ واحدة رقبة». قال: إني صاحب إبل. قال: «فأهدِ عن كلّ واحدة بَدَنة»{11}. (١٥/٢٦٨) ٨١٧١٢- عن سلمة بن يزيد الجُعْفيّ، عن رسول الله ﷺ، قال: «الوائدة والموءودة في النار، إلا أن تُدرك الوائدة الإسلام؛ فيعفو الله عنها»{12}. (١٥/٢٦٦) ٨١٧١٣- عن صَعْصَعة بن ناجية المجاشعِيّ -وهو جدّ الفرزدق- قال: قلتُ: يا رسول الله، إنِّي عملتُ أعمالًا في الجاهلية، فهل لي فيها مِن أجر؟ قال: «وما عملتَ؟». قال: أحييتُ ثلاثمائة وستين من الموءودة؛ أشتري كلّ واحد منهن بناقتين عشراوين وجمل، فهل لي في ذلك مِن أجر؟ فقال النبي ﷺ: «لك أجره إذ منَّ الله عليك بالإسلام»{13}. (١٥/٢٦٧) ",footnotes:1:أخرجه ابن جرير ٢٤/١٤٥. وعزاه السيوطي إلى سعيد بن منصور، وعبد بن حميد، وابن المنذر، وابن أبي حاتم. وهي قراءة شاذة، تروى أيضًا عن علي بن أبي طالب، وابن مسعود، وابن عباس، وغيرهم. انظر: مختصر ابن خالويه ص١٦٩.أخرجه ابن جرير ٢٤/١٤٧. وعزاه السيوطي إلى عبد بن حميد، وابن أبي حاتم.أخرجه مسلم ٢/١٠٦٧ (١٤٤٢).أخرجه ابن أبي حاتم -كما في الإتقان ٢/٥٣- دون آخره. وعزاه السيوطي إلى ابن جرير، وابن المنذر، والبيهقي في الشعب.عزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.أخرجه سعيد بن منصور ٨/٢٦٢ (٢٣٩٩). وعزاه السيوطي ابن أبي شيبة، وعبد بن حميد، وابن المنذر.ذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٥/٩٩-.أخرجه ابن جرير ٢٤/١٤٧. وعزاه السيوطي إلى عبد بن حميد، وابن أبي حاتم.تفسير مقاتل بن سليمان ٤/٦٠١-٦٠٢.أخرجه ابن جرير ٢٤/١٤٨.أخرجه البزار ١/٣٥٥ (٢٣٨)، والطبراني في الكبير ١٨/٣٣٧ (٨٦٣)، وابن أبي حاتم -كما في تفسير ابن كثير ٨/٣٣٥-، والثعلبي ١٠/١٣٩، من طريق عبد الرزاق، عن إسرائيل، عن سماك بن حرب، عن النعمان بن بشير، عن عمر بن الخطاب به. قال الهيثمي في المجمع ٧/١٣٤ (١١٤٦٩): «رجال البزار رجال الصحيح، غير حسين بن مهدي الأيلي، وهو ثقة». وقال الألباني في الصحيحة ٧/٨٧٧ (٣٢٩٨): «ورجاله ثقات؛ رجال مسلم، غير الحسين شيخ البزار، وهو ابن مهدي الأبُلِّي، وهو ثقة عند ابن حبان، صدوق عند أبي حاتم».أخرجه أحمد ٢٥/٢٦٨ (١٥٩٢٣)، والنسائي في الكبرى ١٠/٣٢٥ (١١٥٨٥)، والواحدي في التفسير الوسيط ٤/٤٣٠، من طريق داود بن أبي هند، عن الشعبي، عن علقمة، عن سلمة بن يزيد الجُعْفيّ به. وعند الواحدي: داود عن علقمة، بدون ذكر الشعبي. قال ابن عبد البر في التمهيد ١٨/١٢٠: «ليس لهذا الحديث إسناد أقوى وأحسن من هذا الإسناد». وقال الهيثمي في المجمع ١/١١٩ (٤٦٦): «رجاله رجال الصحيح». وقال البوصيري في إتحاف الخيرة المهرة ٨/٢١٧ (٧٨١٩): «سند رواته ثقات».أخرجه الطبراني في الكبير ٨/٧٦ (٧٤١٢)، والحاكم ٣/٧٠٧ (٦٥٦٢) مطولًا، من طريق عباد بن كسيب العنبري، عن طفيل بن عمرو الربعي، عن صَعْصَعَة بن ناجية به. قال الهيثمي في المجمع ١/٩٤-٩٥ (٣٣٨): «فيه الطفيل بن عمرو التميمي، قال البخاري: لا يصحّ حديثه». وقال العقيلي في الضعفاء الكبير ٢/٢٢٨ (٧٧٥): «لا يُتابع عليه».
  81,9,""
81,10," <q>﴿وَإِذَا ٱلصُّحُفُ نُشِرَتۡ ۝١٠﴾</q> - تفسير ٨١٧١٤- عن قتادة بن دعامة -من طريق سعيد- <q>﴿وإذا الصُّحُفُ نُشِرَتْ﴾</q>، قال: صحيفتك -يا ابن آدم- يُملى ما فيها، ثم تُطوى، ثم تُنشر عليك يوم القيامة، فينظر الرجل ما يُملى في صحيفته{1}. (١٥/٢٦١) ٨١٧١٥- قال مقاتل بن سليمان: <q>﴿وإذا الصُّحُفُ نُشِرَتْ﴾</q> وذلك أنّ المرء إذا مات طُويتْ صحيفته، فإذا كان يوم القيامة نُشرتْ للجن والإنس، فيُعطَون كتبهم، فتعطيهم الحفَظة منشورًا بأيمانهم وشمائلهم{2}. (ز) ٨١٧١٦- عن عبد الملك ابن جُرَيْج، <q>﴿وإذا الصُّحُفُ نُشِرَتْ﴾</q>، قال: إذا مات الإنسان طُويتْ صحيفته، ثم تُنشر يوم القيامة، فيُحاسب بما فيها{3}. (١٥/٢٦٨) ",footnotes:1:أخرجه ابن جرير ٢٤/١٤٨-١٤٩. وعزاه السيوطي إلى عبد بن حميد، وابن أبي حاتم.تفسير مقاتل بن سليمان ٤/٦٠٢.عزاه السيوطي إلى ابن المنذر.
81,11," <q>﴿وَإِذَا ٱلسَّمَاۤءُ كُشِطَتۡ ۝١١﴾</q> - تفسير ٨١٧١٧- عن مجاهد بن جبر -من طريق ابن أبي نجيح- <q>﴿وإذا السَّماءُ كُشِطَتْ﴾</q>، قال: اجْتُبِذَتْ{1}. (١٥/٢٥٨) ٨١٧١٨- قال مقاتل بن سليمان: <q>﴿وإذا السَّماءُ كُشِطَتْ﴾</q> عن مَن فيها لِنُزول الرّبّ والملائكة، ثم طُويتْ{2}. (ز) ",footnotes:1:تفسير مجاهد ص٧٠٨، وأخرجه ابن جرير ٢٤/١٤٩ بلفظ: «جُذبت». وذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٥/١٠٠-. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.تفسير مقاتل بن سليمان ٤/٦٠٢
81,12," <q>﴿وَإِذَا ٱلۡجَحِیمُ سُعِّرَتۡ ۝١٢﴾</q> - تفسير ٨١٧١٩- عن الربيع بن خُثَيْم، <q>﴿وإذا الجَحِيمُ سُعِّرَتْ﴾</q>، قال: أُوقدتْ{1}. (١٥/٢٦٢) ٨١٧٢٠- عن قتادة بن دعامة -من طريق معمر- <q>﴿وإذا الجَحِيمُ سُعِّرَتْ﴾</q>، قال: أُوقِدَتْ{2}. (١٥/٢٦١) ٨١٧٢١- عن قتادة بن دعامة -من طريق سعيد-<q>﴿وإذا الجَحِيمُ سُعِّرَتْ﴾</q>: سعرها غضب الله وخطايا بني آدم{3}. (ز) ٨١٧٢٢- قال مقاتل بن سليمان: <q>﴿وإذا الجَحِيمُ سُعِّرَتْ﴾</q>، يعني: أُوقِدَتْ لأعدائه{4}. (ز) ",footnotes:1:عزاه السيوطي إلى سعيد بن منصور، وابن أبي شيبة، وعبد بن حميد، وابن المنذر.أخرجه عبد الرزاق ٢/٣٥١. وعزاه السيوطي إلى عبد بن حميد، وابن أبي حاتم.أخرجه ابن جرير ٢٤/١٥٠.تفسير مقاتل بن سليمان ٤/٦٠٢.
81,13," <q>﴿وَإِذَا ٱلۡجَنَّةُ أُزۡلِفَتۡ ۝١٣﴾</q> - تفسير ٨١٧٢٣- عن عبد الله بن عباس، <q>﴿وإذا الجَنَّةُ أُزْلِفَتْ﴾</q>، قال: قُرِّبتْ{1}. (١٥/٢٦٨) ٨١٧٢٤- عن الربيع بن خُثَيْم -من طريق سفيان، عن أبيه، عن منذر الثوري- <q>﴿وإذا الجَنَّةُ أُزْلِفَتْ﴾</q>، قال: قُرِّبتْ، إلى هنا انتهى الحديث، فريق في الجنة وفريق في السعير{2}. (١٥/٢٦٢) ٨١٧٢٥- عن قتادة بن دعامة -من طريق معمر- <q>﴿وإذا الجَنَّةُ أُزْلِفَتْ﴾</q>، قال: قُرِّبتْ{3}. (١٥/٢٦١) ٨١٧٢٦- قال مقاتل بن سليمان: <q>﴿وإذا الجَنَّةُ أُزْلِفَتْ﴾</q>، يعني: قُرِّبتْ لأوليائه{4}. (ز) ",footnotes:1:عزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ٢٤/١٤٣. كما أخرجه عبد الرزاق ٢/٣٥٠-٣٥١ من طريق سفيان، عن أبيه، عن الربيع. وعزاه السيوطي إلى سعيد بن منصور، وابن أبي شيبة، وعبد بن حميد، وابن المنذر.أخرجه عبد الرزاق ٢/٣٥١. وعزاه السيوطي إلى عبد بن حميد، وابن أبي حاتم.تفسير مقاتل بن سليمان ٤/٦٠٢.
81,14," <q>﴿عَلِمَتۡ نَفۡسࣱ مَّاۤ أَحۡضَرَتۡ ۝١٤﴾</q> - تفسير ٨١٧٢٧- عن زيد بن أسلم، قال: لما نزلت: <q>﴿إذا الشَّمْسُ كُوِّرَتْ﴾</q> قال عمر لما بلغ: <q>﴿عَلِمَتْ نَفْسٌ ما أحْضَرَتْ﴾</q>، قال: لهذا أُجْرِيَ الحديثُ{1}. (١٥/٢٦٨) ٨١٧٢٨- عن قتادة بن دعامة -من طريق سعيد- <q>﴿عَلِمَتْ نَفْسٌ ما أحْضَرَتْ﴾</q>، قال: مِن عمل{2}. (١٥/٢٦١) ٨١٧٢٩- قال مقاتل بن سليمان: <q>﴿عَلِمَتْ نَفْسٌ ما أحْضَرَتْ﴾</q>، يعني: عَلِمتْ ما عَمِلتْ، فاستيقنتْ من خير أو شر تُجزى به{3}. (ز) ",footnotes:1:عزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم، وابن مردويه.أخرجه ابن جرير ٢٤/١٥١-١٥٢ بنحوه. وعزاه السيوطي إلى عبد بن حميد، وابن أبي حاتم.تفسير مقاتل بن سليمان ٤/٦٠٢.
81,15," <q>﴿فَلَاۤ أُقۡسِمُ بِٱلۡخُنَّسِ ۝١٥ ٱلۡجَوَارِ ٱلۡكُنَّسِ ۝١٦﴾</q> - تفسير ٨١٧٣٠- عن أبي العَدَبَّس، قال: كُنّا عند عمر بن الخطاب، فأتاه رجل، فقال: يا أمير المؤمنين، ما الجواري الكُنّس؟ فطَعن عمر بمخْصَرة معه في عمامة الرجل، فألقاها عن رأسه، فقال عمر: أحَرُوريٌّ؟! والذي نفس عمر بن الخطاب بيده، لو وجدتك محلوقًا لأنحيتُ القمل عن رأسك{1}. (١٥/٢٧٢) ٨١٧٣١- عن عبد الله بن مسعود -من طريق أبي ميسرة- <q>﴿فَلا أُقْسِمُ بِالخُنَّسِ الجَوارِ الكُنَّسِ﴾</q>، قال: هي بقر الوحش{2}. (١٥/٢٦٩) ٨١٧٣٢- عن علي بن أبي طالب -من طريق أبي إسحاق، عن رجل مِن مراد- في قوله: <q>﴿فَلا أُقْسِمُ بِالخُنَّسِ﴾</q>، قال: هي الكواكب تكنِس بالليل، وتخنِس بالنهار؛ فلا تُرى{3}. (١٥/٢٦٨) ٨١٧٣٣- عن علي بن أبي طالب -من طريق الأصبغ بن نباتة- في قوله: <q>﴿فَلا أُقْسِمُ بِالخُنَّسِ﴾</q>، قال: خمسة أنجم: زُحَل، وعُطارِد، والمُشْتَري، وبَهْرام، والزُّهرة، ليس في الكواكب شيء يقطع المجرَّة غيرها{4}. (١٥/٢٦٩) ٨١٧٣٤- عن علي بن أبي طالب -من طريق خالد- <q>﴿الجَوارِ الكُنَّسِ﴾</q>، قال: هي الكواكب{5}. (١٥/٢٧٠) ٨١٧٣٥- عن عبد الله بن عباس -من طريق عكرمة- قال: الخُنَّس: نجوم تجري يقطعْنَ المجرَّة كما يقطع الفرس{6}. (١٥/٢٦٩) ٨١٧٣٦- عن عبد الله بن عباس -من طريق خُصَيف- <q>﴿الجَوارِ الكُنَّسِ﴾</q>، قال: هي الوحش، تَكنس لأنفسها في أصول الشجر تتوارى فيه{7}. (١٥/٢٧٠) ٨١٧٣٧- عن عبد الله بن عباس -من طريق العَوفيّ- <q>﴿فَلا أُقْسِمُ بِالخُنَّسِ﴾</q>، قال: الظِّباء{8}. (١٥/٢٧٠) ٨١٧٣٨- عن عبد الله بن عباس -من طريق أبي صالح- في قوله: <q>﴿فَلا أُقْسِمُ بِالخُنَّسِ الجَوارِ الكُنَّسِ﴾</q>، قال: هي النجوم السبعة: زُحَل، وبَهْرام، وعُطارِد، والمُشتري، والزُّهرة، والشمس، والقمر، خنوسها: رجوعها، وكنوسها: تغيّبها بالنهار{9}٧٠٥٩. (١٥/٢٦٩) ٧٠٥٩ وجَّه ابنُ عطية (٨/٥٤٩) قول ابن عباس وما في معناه بقوله: «وذلك أنّ هذه الكواكب تَخْنِس في جريها، أي: تتقهقر فيما ترى العين، وهي جوارٍ في السماء». ٨١٧٣٩- عن عبد الله بن عباس -من طريق سعيد بن جُبَير- <q>﴿الجَوارِ الكُنَّسِ﴾</q>، قال: هي البقر، تَكنس إلى الظل{4}. (١٥/٢٦٩) ٨١٧٤٠- عن عبد الله بن عباس: الخُنّس: البقر، و<q>﴿الجَوارِ الكُنَّسِ﴾</q> قال: هي الظباء، ألم ترها إذا كانت في الظِّل كيف تَكنس بأعناقها ومدَّتْ نظرها؟{11}. (١٥/٢٧١) ٨١٧٤١- عن أبي ميسرة -من طريق ابن اسحاق الهمذاني- <q>﴿الجَوارِ الكُنَّسِ﴾</q>، قال: بقر الوحش{12}. (١٥/٢٧١) ٨١٧٤٢- عن أبي الشّعثاء جابر بن زيد، <q>﴿الجَوارِ الكُنَّسِ﴾</q>، قال: هي البقر، والظِّباء{11}. (١٥/٢٧١) ٨١٧٤٣- عن الحجاج بن المنذر، قال: سألتُ أبا الشّعثاء عن الجواري الكُنّس. قال: هي البقر إذا كَنستْ كوانسها.= (ز) ٨١٧٤٤- قال يونس: قال لي عبد الله بن وهب: هي البقر إذا فرَّتْ مِن الذئاب، فذلك الذي أراد بقوله: كَنستْ كوانسها{14}. (ز) ٨١٧٤٥- عن سعيد بن جُبَير-من طريق جعفر- <q>﴿فَلا أُقْسِمُ بِالخُنَّسِ﴾</q>، قال: الظِّباء{8}. (ز) ٨١٧٤٦- عن إبراهيم النَّخْعي -من طريق الأعمش- في قوله: <q>﴿الجَوارِ الكُنَّسِ﴾</q>، قال: هي بقر الوحش{16}. (ز) ٨١٧٤٧- عن إبراهيم النَّخْعي -من طريق المُغيرة-= (ز) ٨١٧٤٨- أنه سأل مجاهدًا عن قول الله: <q>﴿فَلا أُقْسِمُ بِالخُنَّسِ الجَوارِ الكُنَّسِ﴾</q>. قال: لا أدري. قال إبراهيم: ولم لا تدري؟ قال: إنكم تقولون عن علي: إنها النجوم. فقال: كذبوا. فقال مجاهد: هي بقر الوحش، والخُنّس الجواري حجرتها. فقال إبراهيم: هو كما قلت{17}. (١٥/٢٧٠) ٨١٧٤٩- عن مجاهد بن جبر، <q>﴿فَلا أُقْسِمُ بِالخُنَّسِ﴾</q>، قال: لم أسمع فيها شيئًا{11}. (١٥/٢٧٠) ٨١٧٥٠- عن مجاهد بن جبر -من طريق الأعمش- <q>﴿فَلا أُقْسِمُ بِالخُنَّسِ﴾</q>، قال: النجوم تَخنس بالنهار{19}. (١٥/٢٧٠) ٨١٧٥١- عن مجاهد بن جبر، <q>﴿الجَوارِ الكُنَّسِ﴾</q>، قال: هي الظِّباء إذا كَنستْ كوانسها{11}. (١٥/٢٧١) ٨١٧٥٢- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿فَلا أُقْسِمُ بِالخُنَّسِ الجَوارِ الكُنَّسِ﴾</q>، قال: كُنّا نقول: أظنه قال: الظباء= (ز) ٨١٧٥٣- حتى زعم سعيد بن جُبَير أنه سأل ابن عباس عنها، فأعاد عليه قراءتها{8}. (ز) ٨١٧٥٤- عن الضَّحّاك بن مُزاحِم -من طريق عبيد- <q>﴿الجَوارِ الكُنَّسِ﴾</q>: يعني: الظباء{22}. (ز) ٨١٧٥٥- عن بكر بن عبد الله المُزنيّ -من طريق عوف- <q>﴿فَلا أُقْسِمُ بِالخُنَّسِ الجَوارِ الكُنَّسِ﴾</q>، قال: هي النجوم الدّراري التي تجري تستقبل المشرق{23}. (١٥/٢٧١) ٨١٧٥٦- عن الحسن البصري، <q>﴿الجَوارِ الكُنَّسِ﴾</q>، قال: البقر{11}. (١٥/٢٧١) ٨١٧٥٧- عن الحسن البصري -من طريق جرير بن حازم- أنه سئل: يا أبا سعيد، ما <q>﴿الجَوارِ الكُنَّسِ﴾</q>؟ قال: النجوم{25}. (ز) ٨١٧٥٨- عن الحسن البصري -من طريق معمر- <q>﴿فَلا أُقْسِمُ بِالخُنَّسِ﴾</q> قال: هي النجوم تَخنس بالنهار، <q>﴿الجَوارِ الكُنَّسِ﴾</q> قال: سَيرهنّ إذا غِبن{26}. (ز) ٨١٧٥٩- عن الحسن البصري -من طريق المبارك بن فَضالة- <q>﴿فَلا أُقْسِمُ بِالخُنَّسِ الجَوارِ الكُنَّسِ﴾</q>، قال: هي الكواكب{27}. (ز) ٨١٧٦٠- عن قتادة بن دعامة -من طريق سعيد- قال: <q>﴿فَلا أُقْسِمُ بِالخُنَّسِ الجَوارِ الكُنَّسِ﴾</q> هي النجوم تبدو بالليل، وتخفى بالنهار؛ تَكنس{28}. (١٥/٢٧٠) ٨١٧٦١- قال مقاتل بن سليمان: ثم أقسم الرّبُّ، فقال: <q>﴿فَلا أُقْسِمُ﴾</q> يعني: أقسم <q>﴿بِالخُنَّسِ﴾</q> وهي خمس مِن الكواكب: بَهْرام، والزُّهرة، وزُحَل، والبرجهس -يعني: المُشتري-، وعُطارِد، والخُنّس التي خَنستْ بالنهار فلا تُرى، وظهرتْ بالليل فتُرى <q>﴿الجَوارِ الكُنَّسِ﴾</q>، الجوار: لأنهن يجرين في السماء، الكُنّس يعني: تتوارى كما تتوارى الظباء في كناسهن{29}. (ز) ٨١٧٦٢- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- قال: النجوم الخُنّس؛ إنها تَخنس تتأخّر عن مطالعها، هي تتأخّر كلّ عام، لها في كلّ عام تأخر عن تعجيل ذلك الطلوع تخنس عنه. والكُنّس: تَكنس بالنهار فلا تُرى، والجواري: تجري بعد، فهذا الخُنّس الجوار الكُنّس{30}٧٠٦٠. (ز) ٧٠٦٠ اختُلف في قوله: <q>﴿الخنس الجواري الكنس﴾</q> على ثلاثة أقوال: الأول: أنها هي النجوم. الثاني: أنها بقر الوحش التي تَكنس في كناسها. الثالث: أنها الظباء. وعلّق ابنُ القيم (٣/٢٥٧-٢٥٩ بتصرف) على القول الأول، فقال: «ومعنى تَخنس على هذا القول: تتأخّر عن البصر، وتتوارى عنه بإخفاء النهار لها. وفيه قول آخر: وهو أنّ خُنوسها رجوعها، وهي حركتها الشرقية، فإنّ لها حركتين، حركة بفعلها، وحركة بنفسها، فخُنوسها حركتها بنفسها راجعة، وعلى هذا فهو قسم بنوع من الكواكب، وهي السيارة. وهذا قول الفراء. وفيه قول ثالث: وهو أنّ خُنوسها وكُنوسها اختفاؤها وقت مغيبها، فتغيب في مواضعها التي تغيب فيها. وهذا قول الزجاج». وقد رجّح ابنُ جرير (٢٤/١٥٨ بتصرف) كلا القولين مستندًا إلى اللغة، والعموم، فقال: "وأولى الأقوال في ذلك بالصواب: أن يُقال: إنّ الله -تعالى ذِكْره- أقسم بأشياء تَخنس أحيانًا، أي: تغيب، وتجري أحيانًا وتَكنس أخرى، وكُنوسها: أن تأوي في مكانسها، والمكانس عند العرب: هي المواضع التي تأوي إليها بقر الوحش والظباء ... وأما الدلالة على أنّ الكناس قد يكون للظباء فقول أوس بن حجر: ألم ترَ أنّ الله أنزلَ مُزْنَة وعُفْرُ الظِّباء في الكِناس تَقَمَّع فالكناس في كلام العرب ما وصفت، وغير منكر أن يُستعار ذلك في المواضع التي تكون بها النجوم من السماء، فإذا كان ذلك كذلك، ولم يكن في الآية دلالة على أنّ المراد بذلك النجوم دون البقر، ولا البقر دون الظباء؛ فالصواب أن يعمّ بذلك كل ما كانت صفته الخنوس أحيانًا والجري أخرى، والكنوس بآنات على ما وصف -جلّ ثناؤه- من صفتها". ورجّح ابنُ القيم -مستندًا إلى الدلالة العقلية- القول الأول، فقال: «أقسم سبحانه بالنجوم في أحوالها الثلاثة؛ من طلوعها، وجريانها، وغروبها. هذا قول علي وابن عباس وعامة المفسرين وهو الصواب؛ إذ لما كان للنجوم حال ظهور وحال اختفاء وحال جريان وحال غروب أقسم سبحانه بها في أحوالها كلّها، ونبّه بخنوسها على حال ظهورها؛ لأنّ الخُنوس هو الاختفاء بعد الظهور، ولا يُقال لِما لا يزال مختفيًا أنه قد خنس، فذكر سبحانه جريانها وغروبها صريحًا وخُنوسها وظهورها، واكتفى من ذكر طلوعها بجريانها الذي مبدؤه الطلوع، فالطلوع أول جريانها. فتضمّن القسم طلوعها، وغروبها، وجريانها، واختفاءها، وذلك من آياته ودلائل ربوبيته». ثم انتقد -مستندًا إلى السياق، وظاهر القرآن، والدلالة العقلية، واللغة- القولين الآخرين من وجوه: الأول: أنّ هذه الأحوال في الكواكب السيارة أعظم آية وعبرة. الثاني: اشتراك أهل الأرض في معرفته بالمشاهدة والعيان. الثالث: أنّ البقر والظباء ليست لها حالة تختفي فيها عن العيان مطلقًا، بل لا تزال ظاهرة في الفلوات. الرابع: إنّ الذين فسّروا الآية بذلك قالوا ليس خنوسها من الاختفاء. قال الواحدي: هو من الخُنّس في الأنف، وهو تأخر الأرنبة وقِصر القصبة، والبقر والظباء أنوفهنّ خُنّس، ومعلوم أنّ هذا أمر خفيٌّ يحتاج إلى تأمل، وأكثر الناس لا يعرفونه، وآيات الرّبّ التي يُقسم بها لا تكون إلا ظاهرة جليّة يشترك في معرفتها الخلائق. الخامس: أنّ كُنوسها في أكنّتها ليس بأعظم من دخول الطير وسائر الحيوانات في بيته الذي يأوي فيه ولا أظهر منه حتى يتعين للقسم. السادس: أنه لو كان جمعًا للظبي لقال الخُنس بالتسكين؛ لأنه جمع أخنس، فهو كأحمر وحمر، ولو أريد به جمع بقرة خنساء لكان على وزن فعلاء أيضًا كحمراء وحمر، فلما جاء جمعه على فُعّل –بالتشديد- استحال أن يكون جمعًا لواحد من الظباء والبقر، وتعيّن أن يكون جمعًا لخانس؛ كشاهد وشهد، وصائم وصوم، وقائم وقوم، ونظائرها. السابع: أنّ اقتران القسم بالليل والصبح يدل على أنها النجوم، وإلا فليس باللائق اقتران البقر والغزلان والليل والصبح في قسم واحد. الثامن: أنّ الارتباط الذي بين النجوم التي هي هداية للسالكين، ورجوم للشياطين، وبين المُقسم عليه وهو القرآن الذي هو هدى للعالمين وزينة للقلوب وداحض لشبهات الشيطان أعظم من الارتباط الذي بين البقر والظباء والقرآن". ",footnotes:1:عزاه السيوطي إلى أبي أحمد الحاكم في الكنى.أخرجه عبد الرزاق ٢/٣٥١-٣٥٢، وابن سعد ٦/١٠٦، وابن جرير ٢٤/١٥٤-١٥٥، والطبراني (٩٠٦٣)، والحاكم ٢/٥١٦. وعزاه السيوطي إلى الفريابي، وسعيد بن منصور، وعبد بن حميد، وابن المنذر، وابن أبي حاتم.أخرجه آدم بن أبي إياس-كما في تفسير مجاهد ص٧٠٨-، وسعيد بن منصور -كما في فتح الباري ٨/٦٩٤-، وابن جرير ٢٤/١٥٢ من طريق خالد بن عرعرة أيضًا، والحاكم ٢/٥١٦. وعزاه السيوطي إلى الفريابي، وعبد بن حميد، وابن أبي حاتم.عزاه السيوطي إلى ابن أبي حاتم.أخرجه ابن راهويه -كما في المطالب العالية (٤١٧٥)-، والبيهقي في شعب الإيمان (٣٩٩١). وعزاه السيوطي إلى عبد بن حميد. وقد ذكر ابن كثير ١٤/٢٦٨ هذا الأثر من طريق أبي كريب، عن وكيع، عن إسرائيل، عن سماك، عن خالد، عن علي، ثم قال: «وهذا إسناد جيد صحيح إلى خالد بن عرعرة، وهو السهمي الكوفي، قال أبو حاتم الرازي: روى عن علي، وروى عنه سماك والقاسم بن عوف الشيباني، ولم يذكر فيه جرحًا ولا تعديلًا».أخرجه أبو الشيخ في العظمة (٦٨٦). وعزاه السيوطي إلى أبي حاتم.عزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ٢٤/١٥٧.أخرجه ابن مردويه -كما في فتح الباري ٨/٦٩٤- بلفظ: خمسة، والخطيب في كتاب النجوم ص١٤٠.عزاه السيوطي إلى ابن أبي حاتم.عزاه السيوطي إلى عبد بن حميد.أخرجه آدم بن أبي إياس -كما في تفسير مجاهد ص٧٠٨-، وابن جرير ٢٤/١٥٤. وعزاه السيوطي إلى عبد بن حميد.عزاه السيوطي إلى عبد بن حميد.أخرجه عبد الله بن وهب في الجامع -تفسير القرآن ٢/٨٥ (١٦٠)، وابن جرير ٢٤/١٥٥.أخرجه ابن جرير ٢٤/١٥٧.أخرجه ابن جرير ٢٤/١٥٦.عزاه السيوطي إلى عبد بن حميد. وأخرج نحوه ابن جرير ٢٤/١٥٦ بروايات تختلف قليلًا.عزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ٢٤/١٥٣ بنحوه. وعزاه السيوطي إلى عبد بن حميد.عزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ٢٤/١٥٧.أخرجه ابن جرير ٢٤/١٥٨.أخرجه ابن جرير ٢٤/١٥٣. وعزاه السيوطي إلى عبد بن حميد.عزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ٢٤/١٥٣.أخرجه عبد الرزاق ٢/٣٥٢، وابن جرير ٢٤/١٥٤.أخرجه آدم بن أبي إياس -كما في تفسير مجاهد ص٧٠٨-.أخرجه ابن جرير ٢٤/١٥٤. وعزاه السيوطي إلى عبد بن حميد.تفسير مقاتل بن سليمان ٤/٦٠٢.أخرجه ابن جرير ٢٤/١٥٤.
  81,16,""
81,17," <q>﴿وَٱلَّیۡلِ إِذَا عَسۡعَسَ ۝١٧﴾</q> - تفسير ٨١٧٦٣- عن علي بن أبي طالب -من طريق أبي عبد الرحمن- أنه خرج حين طلع الفجر، فقال: نِعمَ ساعة الوتر هذه. ثم تلا: <q>﴿واللَّيْلِ إذا عَسْعَسَ والصُّبْحِ إذا تَنَفَّسَ﴾</q>{1}. (١٥/٢٧٣) ٨١٧٦٤- عن أبي ظَبْيان، قال: كنتُ أتبع علي بن أبي طالب ﵁ وهو خارج نحو المشرق، فاستقبل الفجر؛ فقرأ هذه الآية: <q>﴿والليل إذا عسعس﴾</q>{2}. (ز) ٨١٧٦٥- عن عبد الله بن عباس -من طريق علي- <q>﴿واللَّيْلِ إذا عَسْعَسَ﴾</q>، قال: إذا أدبر{3}. (١٥/٢٧٢) ٨١٧٦٦- عن عبد الله بن عباس -من طريق مجاهد- <q>﴿واللَّيْلِ إذا عَسْعَسَ﴾</q>، قال: إذا أقبل{4}. (١٥/٢٧٣) ٨١٧٦٧- عن عبد الله بن عباس -من طريق الضَّحّاك- أنّ نافع بن الأزرق سأله عن قوله: <q>﴿واللَّيْلِ إذا عَسْعَسَ﴾</q>. قال: إقبال سواده. قال: وهل تعرف العرب ذلك؟ قال: نعم، أما سمعتَ قول امرئ القيس: عَسعَسَ حتى لو شاء ادَّنا كان له من ضوئِه مَقبَسُ؟{5}. (١٥/٢٧٣) ٨١٧٦٨- عن مجاهد بن جبر، <q>﴿واللَّيْلِ إذا عَسْعَسَ﴾</q>، قال: أظلم{6}. (١٥/٢٧٢) ٨١٧٦٩- عن مجاهد بن جبر -من طريق ابن أبي نجيح- <q>﴿واللَّيْلِ إذا عَسْعَسَ﴾</q>، قال: إقباله، ويُقال: إدباره{7}. (١٥/٢٧٢) ٨١٧٧٠- عن الضَّحّاك بن مُزاحِم -من طريق عبيد- <q>﴿واللَّيْلِ إذا عَسْعَسَ﴾</q>: إذا أدبر{8}. (ز) ٨١٧٧١- قال الحسن البصري: <q>﴿واللَّيْلِ إذا عَسْعَسَ﴾</q> إذا أظلم{9}. (ز) ٨١٧٧٢- عن الحسن البصري -من طريق معمر- <q>﴿واللَّيْلِ إذا عَسْعَسَ﴾</q>، قال: إذا غشِيَ الناسَ{10}. (ز) ٨١٧٧٣- عن عطية العَوفيّ -من طريق الفضيل- <q>﴿واللَّيْلِ إذا عَسْعَسَ﴾</q>، قال: أشار بيده إلى المغرب{11}. (ز) ٨١٧٧٤- عن قتادة بن دعامة -من طريق معمر- <q>﴿واللَّيْلِ إذا عَسْعَسَ﴾</q>، قال: إذا أدبر{12}. (١٥/٢٧٢) ٨١٧٧٥- عن زيد بن أسلم -من طريق ابنه عبد الرحمن- <q>﴿واللَّيْلِ إذا عَسْعَسَ﴾</q>، قال: إذا ذهب. وفي قول الله: <q>﴿واللَّيْلِ إذا سَجى﴾</q> [الضحى:٢]، قال: سجْوه: سكونه{13}. (ز) ٨١٧٧٦- قال مقاتل بن سليمان: <q>﴿واللَّيْلِ إذا عَسْعَسَ﴾</q>، يعني: إذا أظلم{14}. (ز) ٨١٧٧٧- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- <q>﴿واللَّيْلِ إذا عَسْعَسَ﴾</q>، قال: <q>﴿عَسعس﴾</q>: تولّى. وقال: تنفّس الصبح من هاهنا. وأشار إلى المشرق اطلاع الفجر{11}٧٠٦١. (ز) ٧٠٦١ اختُلف في قوله: <q>﴿والليل إذا عسعس﴾</q> على قولين: الأول: أدبر. الثاني: أقبل بظلامه. وقد رجّح ابنُ جرير (٢٤/١٦١-١٦٢) -مستندًا إلى دلالة العقل واللغة- القول الأول، فقال: «وأولى التأويلين في ذلك بالصواب عندي قول مَن قال: معنى ذلك: إذا أدبر، وذلك لقوله: <q>﴿والصبح إذا تنفس﴾</q> فدلّ بذلك على أنّ القسم بالليل مدبرًا، وبالنهار مقبلًا، والعرب تقول: عَسعس الليل. وسعسع الليل: إذا أدبر، ولم يبق منه إلا اليسير». وبنحوه قال ابنُ عطية (٨/٥٥٠). وكذا ابنُ القيم (٣/٢٥٩-٢٦٠) مستندًا إلى السياق، وإلى ظاهر القرآن، فقال: «والأحسن أنْ يكون القَسم بانصرام الليل وإقبال النهار؛ فإنه عقيبه مِن غير فصل، فهذا أعظم في الدلالة والعبرة، بخلاف إقبال الليل وإقبال النهار، فإنه لم يُعرف القَسم في القرآن بهما، ولأنّ بينهما زمنًا طويلًا، فالآية في انصرام هذا ومجيء الآخر عقيبه بغير فصل أبلغ، فذكر سبحانه حالة ضعف هذا وإدباره، وحالة قوة هذا وتنفّسه، وإقباله يطرد ظلمة الليل بتنفّسه، فكلما تنفّس هرب الليل وأدبر بين يديه، وهذا هو القول». ورجّح ابنُ كثير (١٤/٢٦٩-٢٧٠) -مستندًا إلى الدلالة العقلية، والنظائر- القول الثاني، فقال: «وعندي أنّ المراد بقوله: <q>﴿عسعس﴾</q> إذا أقبل، وإن كان يصحّ استعماله في الإدبار، لكن الإقبال هاهنا أنسب؛ كأنه أقسم تعالى بالليل وظلامه إذا أقبل، وبالفجر وضيائه إذا أشرق، كما قال: <q>﴿والليل إذا يغشى والنهار إذا تجلى﴾</q> [الليل:١-٢]، وقال: <q>﴿والضحى والليل إذا سجى﴾</q> [الضحى:١-٢]، وقال <q>﴿فالق الإصباح وجعل الليل سكنًا﴾</q> [الأنعام:٩٦]، وغير ذلك من الآيات». ثم قال: «وقال كثير من علماء الأصول: إنّ لفظة <q>﴿عسعس﴾</q> تُستعمل في الإقبال والإدبار على وجه الاشتراك، فعلى هذا يصح أن يراد كل منهما». وبنحوه وجّهه ابنُ القيم. ",footnotes:1:أخرجه عبد الرزاق في مصنفه ٣/١٨ (٤٦٣٠، ٤٦٣١)، والطحاوي ١/٣٤٠، وابن جرير ٢٤/١٦٠، والطبراني في الأوسط (١٤٥١)، والحاكم ٢/٥١٦، والبيهقي في سننه ٢/٤٩٧. كما أخرجه الشافعي في كتاب الأم ٨/٤١١ بلفظ: أنّ عليًا ﵇ خرج حين ثوَّب المؤذن، فقال: أين السائل عن الوِتر؟ نِعْمَ ساعة الوتر هذه. ثم قرأ: <q>﴿والليل إذا عسعس الصبح إذا تنفس﴾</q>.أخرجه ابن جرير ٢٤/١٥٩.أخرجه ابن جرير ٢٤/١٥٩، وكذلك من طريق العَوفيّ، وابن أبي حاتم -كما في الإتقان ٢/٥٣-. وعزاه السيوطي إلى ابن المنذر.أخرجه عبد الرزاق ٢/٣٥٢.أخرجه الطبراني في المعجم الكبير ١٠/٢٤٨-٢٥٦ (١٠٥٩٧) مطولًا.عزاه السيوطي إلى عبد بن حميد.تفسير مجاهد ص٧٠٨ بلفظ: إذا أدبر، وأخرجه ابن جرير ٢٤/١٦٠. وعزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ٢٤/١٦٠.ذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٥/١٠٠-.أخرجه عبد الرزاق ٢/٣٥٢، وابن جرير ٢٤/١٦١.أخرجه ابن جرير ٢٤/١٦١.أخرجه عبد الرزاق ٢/٣٥٢، وابن جرير ٢٤/١٦٠، وكذلك من طريق سعيد. وعزاه السيوطي إلى عبد بن حميد.أخرجه عبد الله بن وهب في الجامع -تفسير القرآن ١/١٦ (٣٠).تفسير مقاتل بن سليمان ٤/٦٠٢.أخرجه ابن جرير ٢٤/١٦١.
81,18," <q>﴿وَٱلصُّبۡحِ إِذَا تَنَفَّسَ ۝١٨﴾</q> - تفسير ٨١٧٧٨- عن عبد الله بن عباس، <q>﴿والصُّبْحِ إذا تَنَفَّسَ﴾</q>، قال: إذا بدا النهارُ حين طلوع الفجر{1}. (١٥/٢٧٢) ٨١٧٧٩- عن سعيد [بن جُبَير] -من طريق جعفر- <q>﴿والصُّبْحِ إذا تَنَفَّسَ﴾</q>، قال: إذا نشأ{2}. (ز) ٨١٧٨٠- عن قتادة بن دعامة -من طريق سعيد- <q>﴿والصُّبْحِ إذا تَنَفَّسَ﴾</q>، قال: إذا أضاء، وأقبل{3}. (١٥/٢٧٢) ٨١٧٨١- قال مقاتل بن سليمان: <q>﴿والصُّبْحِ إذا تَنَفَّسَ﴾</q> يعني: إذا أضاء لونُه، فأقسم الله تعالى بهؤلاء الآيات أنّ هذا القرآن <q>﴿إنَّهُ لَقَوْلُ رَسُولٍ كَرِيمٍ﴾</q>{4}. (ز) ",footnotes:1:أخرجه ابن أبي حاتم -كما في الإتقان ٢/٥٣-. وعزاه السيوطي إلى ابن جرير، وابن المنذر.أخرجه ابن جرير ٢٤/١٦٢.أخرجه ابن جرير ٢٤/١٦٣. وعزاه السيوطي إلى عبد الرزاق، وعبد بن حميد.تفسير مقاتل بن سليمان ٤/٦٠٢.
81,19," <q>﴿إِنَّهُۥ لَقَوۡلُ رَسُولࣲ كَرِیمࣲ ۝١٩﴾</q> - تفسير ٨١٧٨٢- عن عبد الله بن عباس، في قوله: <q>﴿إنَّهُ لَقَوْلُ رَسُولٍ كَرِيمٍ﴾</q>، قال: جبريل{1}. (١٥/٢٧٣) ٨١٧٨٣- عن عامرالشعبي -من طريق عطاء- <q>﴿إنَّهُ لَقَوْلُ رَسُولٍ كَرِيمٍ﴾</q>، قال: جبريل{2}. (ز) ٨١٧٨٤- عن أبي صالح [باذام] – من طريق إسماعيل- <q>﴿إنَّهُ لَقَوْلُ رَسُولٍ كَرِيمٍ﴾</q>، قال: جبريل{3}. (١٥/٢٧٤) ٨١٧٨٥- عن قتادة بن دعامة -من طريق سعيد- <q>﴿إنَّهُ لَقَوْلُ رَسُولٍ كَرِيمٍ﴾</q>، قال: هو جبريل{4}. (١٥/٢٧٣) ٨١٧٨٦- قال مقاتل بن سليمان: <q>﴿إنَّهُ لَقَوْلُ رَسُولٍ كَرِيمٍ﴾</q> على الله، يعني: جبريل ﵇، هو علَّم محمدًا ﷺ{5}٧٠٦٢. (ز) ٧٠٦٢ أفادت آثار السلف أنّ المراد بالرسول الكريم جبريل ﵇. وقد ذكره ابنُ عطية (٨/٥٥٠-٥٥١)، وذكر قولًا آخر أنه محمد ﷺ، ثم رجّح الأول بقوله: «والقول الأول أصح». ولم يذكر مستندًا. ",footnotes:1:عزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ٢٤/١٦٧.أخرجه أبو الشيخ في العظمة (٥٠٠). وعزاه السيوطي إلى ابن المنذر.أخرجه عبد الرزاق ٢/٣٥٢، وابن جرير ٢٤/١٦٣، ومن طريق سعيد أيضًا. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.تفسير مقاتل بن سليمان ٤/٦٠٢.
81,20," <q>﴿ذِی قُوَّةٍ عِندَ ذِی ٱلۡعَرۡشِ مَكِینࣲ ۝٢٠ مُّطَاعࣲ ثَمَّ أَمِینࣲ ۝٢١﴾</q> - تفسير ٨١٧٨٧- عن معاوية بن قُرّة، قال: قال رسول الله ﷺ لجبريل: «ما أحسن ما أثنى عليك ربّك؛ <q>﴿ذِي قُوَّةٍ عِنْدَ ذِي العَرْشِ مَكِينٍ مُطاعٍ ثَمَّ أمِينٍ﴾</q>! فما كانت قوتك؟ وما كانت أمانتك؟». قال: أمّا قوتي فإني بُعثتُ إلى مدائن لوط، وهي أربع مدائن، وفي كلّ مدينة أربعمائة ألف مقاتل سوى الذّراري، فحملتُهم مِن الأرض السُّفلى حتى سمع أهلُ السماء أصوات الدجاج ونباح الكلاب، ثم هويتُ بهم، فقلبتهنّ، وأمّا أمانتي فلم أومر بشيء فعدوتُه إلى غيره{1}. (١٥/٢٧٤) ٨١٧٨٨- عن عبد الله بن عباس، قال: قال النبي ﷺ لجبريل ليلة أسري به: «اكشف عن النار». فكشف عنها، فنظر إليها، فذلك قوله: <q>﴿مُطاعٍ ثَمَّ أمِينٍ﴾</q>{2}. (١٥/٢٧٤) ٨١٧٨٩- عن عبد الله بن عباس، قال: <q>﴿أمِينٍ﴾</q> على الوحي{2}. (١٥/٢٧٤) ٨١٧٩٠- عن عبد الله بن عباس -من طريق عطية العَوفيّ- في قوله: <q>﴿ذِي قُوَّةٍ عِنْدَ ذِي العَرْشِ مَكِينٍ مُطاعٍ ثَمَّ أمِينٍ﴾</q>، قال: يعني: جبريل{4}. (ز) ٨١٧٩١- عن الضَّحّاك بن مُزاحِم -من طريق عبيد- <q>﴿مُطاعٍ ثَمَّ أمِينٍ﴾</q>: يعني: جبريل ﵇{4}. (ز) ٨١٧٩٢- قال الحسن البصري: <q>﴿مُطاعٍ ثَمَّ﴾</q> أمر الله أهل السماء بطاعة جبريل، كما أمر أهل الأرض أن يُطيعوا محمدًا{6}. (ز) ٨١٧٩٣- عن أبي صالح [باذام] -من طريق إسماعيل- <q>﴿مُطاعٍ ثَمَّ أمِينٍ﴾</q>، قال: أمين على سبعين حجابًا يدخلها بغير إذن{7}. (١٥/٢٧٤) ٨١٧٩٤- عن ميمون بن مهران -من طريق معقل- <q>﴿مُطاعٍ ثَمَّ أمِينٍ﴾</q>، قال: ذاكم جبريل ﵇{8}. (ز) ٨١٧٩٥- عن قتادة بن دعامة -من طريق سعيد- <q>﴿مُطاعٍ ثَمَّ﴾</q>: مطاع عند الله{4}. (ز) ٨١٧٩٦- قال مقاتل بن سليمان: <q>﴿ذِي قُوَّةٍ﴾</q> يعني: ذا بطش، وذلك أنّ النبي ﷺ حين بُعِث قال إبليس: مَن لهذا النبي الذي خرج مِن أرض تِهامة؟ فقال شيطان -واسمه: الأبيض- هو صاحب الأنبياء: أنا له. فأتى النبيَّ ﷺ، فوجده في بيت الصفا، فلما انصرف قام الأبيض في صورة جبريل ﷺ ليوحي إليه، فنزل جبريلُ ﵇، فقام بينه وبين النبي ﷺ، فدفعه جبريل ﷺ بيده دفعة هَيّنة، فوقع مِن مكة بأقصى الهند مِن فَرَقه، <q>﴿عِنْدَ ذِي العَرْشِ مَكِينٍ﴾</q> يقول: جبريل ﵇ وجيهٌ عند الله، <q>﴿مُطاعٍ ثَمَّ﴾</q> يعني: هنالك في السموات، وذلك أنّ النبي ﷺ ليلة عُرج به إلى السموات رأى إبراهيم ﷺ وموسى ﵉، فصافحوه، وأداره جبريل على الملائكة في السموات، فاستبشروا به، وصافحوه، ورأى مالكًا خازن النار، فلم يُكلّمه، ولم يُسلّم عليه، فقال النبي ﷺ لجبريل ﵇: «مَن هذا؟». قال: هذا مالك، خازن جهنم، لم يَتكلّم قط، وهؤلاء النفر معه، فخزنة جهنم نُزعتْ منهم الرأفة والرحمة، وأُلقي عليهم العبوس والغضب على أهل جهنم، أما إنهم لو كلّموا أحدًا منذ خُلقوا لكلّموك؛ لكرامتك على الله ﷿. فقال النبي ﷺ: «قل له فليكشف عن بابٍ منها». فكشف عن مثل منخَر الثور منها، فتَخَلْخَلَتْ فجاءتْ بأمر عظيم، حسبت أنها الساعة حتى أهيل منها النبي ﷺ، فقال لجبريل: مُره فليردّها. فأمره جبريل ﵇، فأطاعه مالك ﵇، فردّها، فذلك قوله: <q>﴿مُطاعٍ ثَمَّ﴾</q>، <q>﴿أمِينٍ﴾</q> يُسمّى أمينًا لما استودعه ﷿ من أمْره في خَلْقه{10}. (ز) ",footnotes:1:أخرجه ابن عساكر في تاريخ دمشق ٥٠/٣٢٥-٣٢٦، والواحدي في التفسير الوسيط ٤/٤٣١ (١٢٨٥)، من طريق المسيّب بن شريك، عن يزيد بن أبي زياد، عن معاوية بن قرة به. وسنده شديد الضعف؛ فيه المسيّب بن شريك، وهو متروك. كما في الميزان ٤/١١٤.عزاه السيوطي إلى ابن المنذر.عزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ٢٤/١٦٥.أخرجه ابن جرير ٢٤/١٦٥.ذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٥/١٠١-.أخرجه ابن جرير ٢٤/١٦٤، وأبو الشيخ في العظمة (٥٠٠). وعزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ٢٤/١٦٤.أخرجه ابن جرير ٢٤/١٦٥.تفسير مقاتل بن سليمان ٤/٦٠٢-٦٠٤.
