quran[15]{c,v,t}:
  20,99,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿كَذَ ٰ⁠لِكَ نَقُصُّ عَلَیۡكَ مِنۡ أَنۢبَاۤءِ مَا قَدۡ سَبَقَۚ وَقَدۡ ءَاتَیۡنَـٰكَ مِن لَّدُنَّا ذِكۡرࣰا ۝٩٩﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٨٢٦٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿كذلك﴾</span> يعني: هكذا <span class="qpc-hafs">﴿نقص عليك﴾</span> يا محمد <span class="qpc-hafs">﴿من أنباء﴾</span> يعني: مِن أحاديث <span class="qpc-hafs">﴿ما قد سبق﴾</span> مِن قبلك مِن الأمم الخالية، <span class="qpc-hafs">﴿وقد آتيناك من لدنا ذكرا﴾</span> يقول: قد أعطيناك مِن عندنا تبيانًا، يعني: القرآن{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٢٦٦<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span>، في قوله: <span class="qpc-hafs">﴿وقد آتيناك من لدنا ذكرا﴾</span>، قال: القرآن{2}. (١٠/٢٣٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٢٦٧<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: قوله: <span class="qpc-hafs">﴿كذلك نقص عليك من أنباء ما قد سبق﴾</span> مِن أخبار ما قد مضى، <span class="qpc-hafs">﴿وقد آتيناك﴾</span> أي: وقد أعطيناك <span class="qpc-hafs">﴿من لدنا﴾</span> مِن عندنا <span class="qpc-hafs">﴿ذكرا﴾</span> القرآن{3}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٣/٤٠.|2:عزاه السيوطي إلى ابن أبي حاتم.|3:تفسير يحيى بن سلّام ١/٢٧٦.
  20,100,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿مَّنۡ أَعۡرَضَ عَنۡهُ فَإِنَّهُۥ یَحۡمِلُ یَوۡمَ ٱلۡقِیَـٰمَةِ وِزۡرًا ۝١٠٠﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٨٢٦٨<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن جريج- في قوله: <span class="qpc-hafs">﴿يحمل يوم القيامة وزرا﴾</span>، قال: إثْمًا{1}. (١٠/٢٣٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٢٦٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿من أعرض عنه﴾</span> يعني: عن إيمانٍ بالقرآن؛ <span class="qpc-hafs">﴿فإنه يحمل يوم القيامة وزرا﴾</span> يعني: إثمًا بإعراضه عن القرآن يحمله على ظهره ... والوزر: هو الخطأ الكبير{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٢٧٠<span class="dash">-</span></span> عن <span class="name-3">سفيان الثوري</span>، في قوله: <span class="qpc-hafs">﴿من أعرض عنه فإنه يحمل يوم القيامة وزرا﴾</span>، قال: الوِزر: هو الشِّرْك{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٢٧١<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: قوله: <span class="qpc-hafs">﴿من أعرض عنه﴾</span> عن القرآن، ولم يؤمن به؛ <span class="qpc-hafs">﴿فإنه يحمل يوم القيامة وزرا﴾</span>{4}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه إسحاق البستي في تفسيره ص٢٧١. وعلَّقه يحيى بن سلّام ١/٢٧٧. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.|2:تفسير مقاتل بن سليمان ٣/٤١.|3:تفسير الثوري ص١٩٥.|4:تفسير يحيى بن سلّام ١/٢٧٦.
  20,101,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿خَـٰلِدِینَ فِیهِۖ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٨٢٧٢<span class="dash">-</span></span> قال <span class="name-2">الحسن البصري</span>: <span class="qpc-hafs">﴿خالدين فيه﴾</span> في ثواب ذلك الوِزر، وهي النار{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٢٧٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿خالدين فيه﴾</span>، يعني: في الوِزر؛ في النار{2}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَسَاۤءَ لَهُمۡ یَوۡمَ ٱلۡقِیَـٰمَةِ حِمۡلࣰا ۝١٠١﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٨٢٧٤<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- في قوله: <span class="qpc-hafs">﴿وساء لهم يوم القيامة حملا﴾</span>، يقول: بِئسَ ما حملوا{3}. (١٠/٢٣٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٢٧٥<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق العوفي- في قوله: <span class="qpc-hafs">﴿وساء لهم يوم القيامة حملا﴾</span>: يعني بذلك: ذنوبهم{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٢٧٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وساء لهم﴾</span> يعني: وبئس لهم <span class="qpc-hafs">﴿يوم القيامة حملا﴾</span> يعني: إثمًا{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٢٧٧<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span>، في قوله: <span class="qpc-hafs">﴿وساء لهم يوم القيامة حملا﴾</span>، قال: ليس هي «وساءلهم» موصولة، ينبغي أن تقطع؛ فإنك إنّ وصلت لم يفهم، وليس بها خفاء؛ ساء لهم بها حملًا خالدين فيه، <span class="qpc-hafs">﴿وساء لهم يوم القيامة حملا﴾</span> قال: حمل السوء، ويورد صاحبه النار. قال: وإنما هي: <span class="qpc-hafs">﴿وساء لهم﴾</span> مقطوعة، <span class="qpc-hafs">﴿وساء﴾</span> بعدها <span class="qpc-hafs">﴿لهم﴾</span>{6}. (١٠/٢٣٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٢٧٨<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿وساء لهم﴾</span> أي: وبئس لهم <span class="qpc-hafs">﴿يوم القيامة حملا﴾</span> ما يحملون على ظهورهم مِن الوِزر، وهو قوله: <span class="qpc-hafs">﴿وهم يحملون أوزارهم على ظهورهم ألا ساء ما يزرون﴾</span> [الأنعام:٣١]{7}. (ز)</p></p><p></div></p></div>",footnotes:1:علَّقه يحيى بن سلّام ١/٢٧٧.|2:تفسير مقاتل بن سليمان ٣/٤١.|3:أخرجه ابن جرير ١٦/١٦٠، وابن أبي حاتم -كما في الإتقان ٢/٢٨-. وعزاه السيوطي إلى ابن المنذر.|4:أخرجه ابن جرير ١٦/١٦٠.|5:تفسير مقاتل بن سليمان ٣/٤١.|6:عزاه السيوطي إلى ابن أبي حاتم.|7:تفسير يحيى بن سلّام ١/٢٧٧.
  20,102,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿یَوۡمَ یُنفَخُ فِی ٱلصُّورِۚ وَنَحۡشُرُ ٱلۡمُجۡرِمِینَ یَوۡمَىِٕذࣲ زُرۡقࣰا ۝١٠٢﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٨٢٧٩<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، أنّ رجلًا أتاه، فقال: أرأيتَ قوله: <span class="qpc-hafs">﴿ونحشر المجرمين يومئذ زرقا﴾</span>، وأخرى: <span class="qpc-hafs">﴿عميا﴾</span> [الإسراء:٩٧]. قال: إنّ يوم القيامة فيه حالات؛ يكونون في حال زُرْقًا، وفي حال عُمْيًا{1}. (١٠/٢٣٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٢٨٠<span class="dash">-</span></span> قال <span class="name-2">إسماعيل السُّدِّيّ</span>: <span class="qpc-hafs">﴿ونحشر المجرمين﴾</span> يعني: بعد الحساب، نسوق المشركين إلى النار <span class="qpc-hafs">﴿زرقا﴾</span> قال: مُسْوَدَّة وجوههم كالِحة{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٢٨١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿يوم ينفخ في الصور ونحشر المجرمين﴾</span> يعني: المشركين إلى النار <span class="qpc-hafs">﴿يومئذ زرقا﴾</span> زرق الأعين{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٢٨٢<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: قوله: <span class="qpc-hafs">﴿يوم ينفخ في الصور﴾</span> والصور: قَرْنٌ ينفُخ فيه صاحبُ الصور، فينطلق كل روحٍ إلى جسده، تجعل الأرواح كلها في الصور، فإذا نفخ فيه خرجت الأرواح مثل النحل، كل روح إلى جسده، <span class="qpc-hafs">﴿ونحشر المجرمين﴾</span> يعني: المشركين، هذا حشر إلى النار، <span class="qpc-hafs">﴿يومئذ زرقا﴾</span>{4}. (ز)</p></p><p></div></p></div>",footnotes:1:عزاه السيوطي إلى ابن أبي حاتم.|2:علَّقه يحيى بن سلّام ١/٢٧٨.|3:تفسير مقاتل بن سليمان ٣/٤١.|4:تفسير يحيى بن سلّام ١/٢٧٧.
  20,103,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿یَتَخَـٰفَتُونَ بَیۡنَهُمۡ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٨٢٨٣<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- في قوله: <span class="qpc-hafs">﴿يتخافتون بينهم﴾</span>، قال: يَتَسارُّون{1}. (١٠/٢٣٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٢٨٤<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- قوله: <span class="qpc-hafs">﴿يتخافتون بينهم﴾</span>: أي: يتسارُّون بينهم، يُسارُّ بعضُهم بعضًا{2}<span class=comment-ref>٤٣٠٨</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٤٣٠٨</span> لم يذكر <u>ابنُ جرير</u> (١٦/١٦١) في معنى: <span class="qpc-hafs">﴿يَتَخافَتُونَ بَيْنَهُمْ﴾</span> سوى قول ابن عباس، وقتادة.</div></p><p><div></p><p><p><span class="item-no">٤٨٢٨٥<span class="dash">-</span></span> عن <span class="name-2">عطاء الخراساني</span> -من طريق يونس- في قول الله ﷿: <span class="qpc-hafs">﴿يتخافتون بينهم﴾</span>، قال: الكلام الخَفِيُّ{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٢٨٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿يتخافتون﴾</span> يعني: يتساءلون <span class="qpc-hafs">﴿بينهم﴾</span> يقول بعضُهم لبعض{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٢٨٧<span class="dash">-</span></span> عن <span class="name-3">سفيان بن عيينة</span> -من طريق ابن أبي عمر- وسُئِل عن قوله: <span class="qpc-hafs">﴿يتخافتون بينهم إن لبثتم﴾</span>. قال: أسَرُّوا في أنفسهم{5}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿إِن لَّبِثۡتُمۡ إِلَّا عَشۡرࣰا ۝١٠٣﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٨٢٨٨<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿إن﴾</span> يعني: ما <span class="qpc-hafs">﴿لبثتم إلا عشرا﴾</span> يعني: عشر ليال{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٢٨٩<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿إن لبثتم﴾</span> في الدنيا <span class="qpc-hafs">﴿إلا عشرا﴾</span>، يُقَلِّلون لُبثَهم في الدنيا، تَصاغَرَتِ الدنيا عندهم{7}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ١٦/١٦١، وابن أبي حاتم -كما في الإتقان ٢/٢٨-. وعزاه السيوطي إلى ابن المنذر.|2:أخرجه ابن جرير ١٦/١٦١. وعلقه يحيى بن سلّام ١/٢٧٨.|3:أخرجه أبو جعفر الرملي في جزئه ص١٢١ (تفسير عطاء الخراساني).|4:تفسير مقاتل بن سليمان ٣/٤١.|5:أخرجه إسحاق البستي في تفسيره ص٢٧١.|6:تفسير مقاتل بن سليمان ٣/٤١.|7:تفسير يحيى بن سلّام ١/٢٧٨.
  20,104,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿نَّحۡنُ أَعۡلَمُ بِمَا یَقُولُونَ إِذۡ یَقُولُ أَمۡثَلُهُمۡ طَرِیقَةً إِن لَّبِثۡتُمۡ إِلَّا یَوۡمࣰا ۝١٠٤﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٨٢٩٠<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span> -من طريق أشعث، عن جعفر- في قوله: <span class="qpc-hafs">﴿إذ يقول أمثلهم طريقة﴾</span>، قال: أوْفاهُم عَقْلًا{1}. (١٠/٢٣٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٢٩١<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span> -من طريق يعقوب، عن جعفر- في قوله: <span class="qpc-hafs">﴿إذ يقول أمثلهم طريقة﴾</span>، قال: أعلمهم في نفسِه{2}. (١٠/٢٣٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٢٩٢<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span>، في قوله: <span class="qpc-hafs">﴿إذ يقول أمثلهم طريقة﴾</span> قال: أعدلهم مِن الكفار: <span class="qpc-hafs">﴿إن لبثتم﴾</span> أي: في الدنيا <span class="qpc-hafs">﴿إلا يوما﴾</span>؛ لَمّا تقاصرت الدنيا في أنفسهم{3}. (١٠/٢٣٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٢٩٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿نحن أعلم بما يقولون إذ يقول أمثلهم طريقة﴾</span> يعني: أمثلهم نجوى ورأيًا: <span class="qpc-hafs">﴿إن لبثتم﴾</span> في القبور <span class="qpc-hafs">﴿إلا يوما﴾</span> واحدًا{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٢٩٤<span class="dash">-</span></span> قال <span class="name-3">سفيان بن عيينة</span> -من طريق ابن أبي عمر-: <span class="qpc-hafs">﴿أمثلهم﴾</span>: أعدلهم طريقة{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٢٩٥<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: قال الله: <span class="qpc-hafs">﴿نحن أعلم بما يقولون إذ يقول أمثلهم طريقة﴾</span> وقال في آية أخرى: <span class="qpc-hafs">﴿ويذهبا بطريقتكم المثلى﴾</span> [طه:٦٣]. قال <span class="name-2">قتادة</span>: كانوا أكثر عددًا وأموالًا. وقال بعضهم: <span class="qpc-hafs">﴿نحن أعلم بما يقولون إذ يقول أمثلهم طريقة﴾</span> أعقلهم: <span class="qpc-hafs">﴿إنْ لَبِثْتُمْ إلا يَوْمًا﴾</span>. وهي مواطن، قالوا: <span class="qpc-hafs">﴿إلا يوما﴾</span>، و<span class="qpc-hafs">﴿إلا عشرا﴾</span>، و<span class="qpc-hafs">﴿قالوا لبثنا يوما أو بعض يوم﴾</span> [الكهف:١٩]، وقال: <span class="qpc-hafs">﴿كأنهم يوم يرونها لم يلبثوا إلا عشية أو ضحاها﴾</span> [النازعات:٤٦]، وقال: <span class="qpc-hafs">﴿كأنهم يوم يرون ما يوعدون لم يلبثوا إلا ساعة من نهار﴾</span> [الأحقاف:٣٥]، وقال: <span class="qpc-hafs">﴿ويوم تقوم الساعة يقسم المجرمون﴾</span> [الروم:٥٥] يحلف المجرمون المشركون: <span class="qpc-hafs">﴿ما لبثوا غير ساعة﴾</span> [الروم:٥٥] أي: في الدنيا؛ وذلك لتصاغر الدنيا عندهم، وقِلَّتها في طول الآخرة{6}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ١٦/١٦٢. وعزاه السيوطي إلى ابن أبي شيبة، وعبد بن حميد، وابن المنذر، وابن أبي حاتم.|2:أخرجه ابن جرير ١٦/١٦٢. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.|3:علَّق يحيى بن سلّام ١/٢٧٩ بعضه. وعزاه السيوطي إلى ابن أبي حاتم.|4:تفسير مقاتل بن سليمان ٣/٣١.|5:أخرجه إسحاق البستي في تفسيره ص٢٧٣. وعلَّقه البخاري كتاب التفسير- باب تفسير سورة طه ٤/١٧٦٣.|6:تفسير يحيى بن سلّام ١/٢٧٩.
  20,105,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَیَسۡـَٔلُونَكَ عَنِ ٱلۡجِبَالِ فَقُلۡ یَنسِفُهَا رَبِّی نَسۡفࣰا ۝١٠٥﴾</span> - نزول الآية، وتفسيرها</h3></p><p><div></p><p><p><span class="item-no">٤٨٢٩٦<span class="dash">-</span></span> قال ابن عباس: سأل رجلٌ مِن ثَقيف رسولَ الله ﷺ، فقال: كيف تكون الجبال يوم القيامة؟ فأنزل الله هذه الآية{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٢٩٧<span class="dash">-</span></span> عن عبد الملك ابن جُرَيج، قال: قالت قريش: يا محمد، كيف يفعل ربُّك بهذه الجبال يوم القيامة؟ فنزلت: <span class="qpc-hafs">﴿ويسألونك عن الجبال﴾</span> الآية{2}. (١٠/٢٣٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٢٩٨<span class="dash">-</span></span> قال مقاتل بن سليمان: <span class="qpc-hafs">﴿ويسألونك عن الجبال﴾</span> نزلت في رجل من ثقيف، <span class="qpc-hafs">﴿فقل ينسفها ربي نسفا﴾</span> مِن الأرض مِن أصولها{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٢٩٩<span class="dash">-</span></span> قال يحيى بن سلّام: قوله: <span class="qpc-hafs">﴿ويسألونك عن الجبال﴾</span> سأل المشركون النبيَّ، فقالوا: يا محمد، كيف هذه الجبال في ذلك اليوم الذي تذكر؟ فقال الله: <span class="qpc-hafs">﴿ويسألونك عن الجبال فقل ينسفها ربي نسفا﴾</span> مِن أصولها{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٣٠٠<span class="dash">-</span></span> عن <span class="name-2">عروة</span>، قال: كُنّا قُعودًا عند عبد الملك بن مروان حين قال: قال كعب: إنّ الصخرة موضع قدم الرحمن يوم القيامة. فقال: كذب كعب، إنما الصخرة جبل من الجبال، إن الله يقول: <span class="qpc-hafs">﴿ويسألونك عن الجبال فقل ينسفها ربي نسفا﴾</span>. فسكت عبد الملك{5}. (ز)</p></p><p></div></p></div>",footnotes:1:أورده الواحدي في التفسير الوسيط ٣/٢٢١، والبغوي في تفسيره ٥/٢٩٤.|2:عزاه السيوطي إلى ابن المنذر.|3:تفسير مقاتل بن سليمان ٣/٤١.|4:تفسير يحيى بن سلّام ١/٢٧٩.|5:أخرجه ابن جرير ١٦/١٦٣.
  20,106,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿فَیَذَرُهَا قَاعࣰا صَفۡصَفࣰا ۝١٠٦﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٨٣٠١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- في قوله: <span class="qpc-hafs">﴿فيذرها قاعا﴾</span> قال: مستويًا، <span class="qpc-hafs">﴿صفصفا﴾</span> قال: لا نبات فيه{1}<span class=comment-ref>٤٣٠٩</span>. (١٠/٢٣٩)</p></p><p></div></p><p><div><span class=comment-ref>٤٣٠٩</span> ذكر <u>ابن كثير</u> (٩/٣٦٧) بأنّ معنى القاع: المستوي من الأرض. والصفصف تأكيد لمعنى ذلك، وذكر <b>قولًا آخر</b> في معنى الصفصف: وهو الذي لا نبات فيه. ثم <span class="comment-type-3">رجَّح</span> قائلًا: «والأوَّل أوْلى، وإن كان الآخر مرادًا أيضًا باللازم». ولم يذكر مستندًا.</div></p><p><div></p><p><p><span class="item-no">٤٨٣٠٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>: أنّ نافع بن الأزرق قال له: أخبِرني عن قوله ﷿: <span class="qpc-hafs">﴿فيذرها قاعا صفصفا﴾</span>. قال: القاع: الأملس. والصفصف: المستوي. قال: وهل تعرف العرب ذلك؟ قال: نعم، أما سمعت الشاعر وهو يقول:</p><p>بِمَلْمُومَةٍ{2} شهباء{3} لو قذفوا بها شَمارِيخ{4} مِن رَضْوى{5} إذَنْ عاد صفصفا؟{6}. (١٠/٢٤٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٣٠٣<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نَجِيح- في قوله: <span class="qpc-hafs">﴿قاعا صفصفا﴾</span>، قال: مُسْتَوِيًا{7}. (١٠/٢٤٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٣٠٤<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- في قوله: <span class="qpc-hafs">﴿صفصفا﴾</span>، قال: القاع: الأرض. والصفصف: المستوية{8}. (١٠/٢٤٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٣٠٥<span class="dash">-</span></span> عن <span class="name-2">الضحاك بن مُزاحِم</span> -من طريق جُوَيْبِر- قوله: <span class="qpc-hafs">﴿فيذرها قاعا صفصفا﴾</span>، قال: القاع: الأرض المستوية. والصفصف: يقول: ليس فيها نبات{9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٣٠٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فيذرها قاعا﴾</span> لا تراب فيها، <span class="qpc-hafs">﴿صفصفا﴾</span> لا نبت فيها{10}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٣٠٧<span class="dash">-</span></span> عن <span class="name-3">سفيان الثوري</span>، في قوله: <span class="qpc-hafs">﴿فيذرها قاعا صفصفا﴾</span>، قال: ترى الأرض كلها مستوية{11}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٣٠٨<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿فيذرها قاعا صفصفا﴾</span>، قال: مستويًا؛ الصفصف: المستوي{12}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٣٠٩<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿فيذرها﴾</span> فيذر الأرض <span class="qpc-hafs">﴿قاعا صفصفا﴾</span> القاع: الذي لا ثَرى عليه، وهي القَرْقَرة{13}. والصفصف: الذي ليس عليه نبات{14}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ١٦/١٦٣، وابن أبي حاتم -كما في تغليق التغليق ٤/٢٥٥، والإتقان ٢/٢٩-. وعزاه السيوطي إلى ابن المنذر.|2:هي: الكتيبة المجتمعة، المضموم بعضها إلى بعض. اللسان (لمم).|3:أي: كثيرة السلاح، سميت شهباء لما فيها مِن بياض السلاح والحديد. اللسان (شهب).|4:الشماريخ: رؤوس الجبال. اللسان (شمرخ).|5:رَضْوى: جبل بالمدينة. وقيل: بين مكة والمدينة. معجم البلدان ٣/٥١.|6:أخرجه الطستي -كما في الإتقان ٢/٧١-.|7:أخرجه إسحاق البستي في تفسيره ص٢٧٣ من طريق ابن جريج، وابن جرير ١٦/١٦٣. وعلَّقه يحيى بن سلّام ١/٢٧٩. وعزاه السيوطي إلى عبد بن حميد.|8:أخرجه عبد الرزاق ٢/٢٠ من طريق معمر. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.|9:أخرجه إسحاق البستي في تفسيره ص٢٧٣.|10:تفسير مقاتل بن سليمان ٣/٤١.|11:تفسير الثوري ص١٩٦.|12:أخرجه ابن جرير ١٦/١٦٣.|13:القَرْقَر: الأرض المستوية. النهاية (قرقر).|14:تفسير يحيى بن سلّام ١/٢٧٩.
  20,107,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿لَّا تَرَىٰ فِیهَا عِوَجࣰا وَلَاۤ أَمۡتࣰا ۝١٠٧﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٨٣١٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- في قوله: <span class="qpc-hafs">﴿لا ترى فيها عوجا﴾</span> قال: واديًا، <span class="qpc-hafs">﴿ولا أمتا﴾</span> قال: رابيةً{1}{2}. (١٠/٢٣٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٣١١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق العوفي- في قوله: <span class="qpc-hafs">﴿لا ترى فيها عوجا﴾</span> قال: ميلًا، <span class="qpc-hafs">﴿ولا أمتا﴾</span> قال: الأمت: الأثر مثل الشِراك{3}. (١٠/٢٤٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٣١٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>: أنّ نافع بن الأزرق قال له: أخبِرني عن قوله: <span class="qpc-hafs">﴿لا ترى فيها عوجا ولا أمتا﴾</span>، ما الأَمْت؟ قال: الشيءُ الشاخص مِن الأرض، قال فيه كعب بن زهير:</p><p>فأبصرت لمحةً مِن رأسِ عِكْرِشَةٍ{4} في كافِر{5} ما به أمْتٌ ولا شَرَفُ{6}. (١٠/٢٤١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٣١٣<span class="dash">-</span></span> عن عكرمة، أنّه سُئِل عن قوله: <span class="qpc-hafs">﴿لا ترى فيها عوجا ولا أمتا﴾</span>. قال: كان <span class="name-1">ابنُ عباس</span> يقول: هي الأرض الملساء التي ليس فيها رابية مرتفعة ولا انخفاض{7}. (١٠/٢٤٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٣١٤<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نَجِيح- في قوله: <span class="qpc-hafs">﴿لا ترى فيها عوجا﴾</span> قال: خَفْضًا، <span class="qpc-hafs">﴿ولا أمتا﴾</span> قال: ارتفاعًا{8}. (١٠/٢٤٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٣١٥<span class="dash">-</span></span> عن <span class="name-2">الضحاك بن مزاحم</span>، في الآية، قال: العِوَج: الارتفاع. والأَمْت: الهبوط{9}. (١٠/٢٤١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٣١٦<span class="dash">-</span></span> عن <span class="name-2">الضحاك بن مزاحم</span> -من طريق جويبر- قوله: <span class="qpc-hafs">﴿لا ترى فيها عوجا﴾</span> قال: العوج: يقول: لا ترى فيها وادِيًا، <span class="qpc-hafs">﴿ولا أمتا﴾</span> الأمت: النَّبْكُ{10}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٣١٧<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span> في الآية قال: يعني: بالأمت حُفَرًا{11}. (١٠/٢٤١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٣١٨<span class="dash">-</span></span> قال <span class="name-2">الحسن البصري</span>: غمار البحور ورؤوس الجبال سواء{12}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٣١٩<span class="dash">-</span></span> قال <span class="name-2">الحسن البصري</span>: العِوَج: ما انخفض مِن الأرض. والأَمْت: ما نَشَزَ مِن الرَّوابي{13}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٣٢٠<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- في قوله: <span class="qpc-hafs">﴿لا ترى فيها عوجا﴾</span> قال: صَدْعًا، <span class="qpc-hafs">﴿ولا أمتا﴾</span> قال: أكَمَة{14}. (١٠/٢٤٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٣٢١<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- قال: الأَمْت: الحدَب{15}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٣٢٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿لا ترى فيها عوجا﴾</span> يعني: خفضًا، <span class="qpc-hafs">﴿ولا أمتا﴾</span> يعني: رفعًا{16}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٣٢٣<span class="dash">-</span></span> عن <span class="name-3">سفيان الثوري</span>، في قوله: <span class="qpc-hafs">﴿لا ترى فيها عوجا ولا أمتا﴾</span>، قال: العوج: الشق. والأمت: المكان المرتفع{17}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٣٢٤<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿لا ترى فيها عوجا ولا أمتا﴾</span>، قال: لا تَعادِيَ{18}، الأمت: التَّعادي{19}<span class=comment-ref>٤٣١٠</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٤٣١٠</span> أفادت الآثارُ اختلاف المفسرين في معنى: «العِوَجِ» و«الأمْتِ» على أقوال: <b>الأول:</b> عوجًا: واديًا. ولا أمتًا: رابية. <b>الثاني:</b> عوجًا: صدعًا. ولا أمتا: أكَمة. <b>الثالث:</b> عوجًا: ميلًا. ولا أمتًا: أثرًا. <b>الرابع:</b> الأمت: المَحاني والحِداب.</p><p>و<span class="comment-type-3">رجَّح</span> <u>ابنُ جرير</u> (١٦/١٦٦) <span class="mustanad">مستندًا إلى لغة العرب، ودلالة العقل</span> أنّ معنى <span class="qpc-hafs">﴿عوجًا﴾</span>: ميلًا، وأن معنى <span class="qpc-hafs">﴿ولا أمتا﴾</span>: ولا ارتفاع ولا انخفاض؛ لأن الانخفاض لم يكن إلا عن ارتفاع. وأن تأويل الكلام: لا ترى فيها ميلًا عن الاستواء، ولا ارتفاعًا، ولا انخفاضًا، ولكنها مستوية ملساء.</p><p>و<span class="comment-type-4">وافقه</span> <u>ابنُ عطية</u> (٦/١٣٣)، ولم يذكر مستندًا.</div></p></div>",footnotes:1:رابِيَة: هي كل ما ارتفعَ من الأرض. اللسان (ربا).|2:أخرجه ابن جرير ١٦/١٦٤، وابن أبي حاتم -كما في تغليق التغليق ٤/٢٥٥، والإتقان ٢/٢٩-. وأخرج يحيى بن سلّام ١/٢٨٠ شطره الأول من طريق أبي حازم. وعزاه السيوطي إلى ابن المنذر.|3:أخرجه ابن جرير ١٦/١٦٦. وعزاه السيوطي إلى ابن أبي حاتم.|4:عِكْرِشَة: أنثى الأرنب. النهاية (عكرش).|5:كل شيء غَطّى شيئًا؛ يجوز أن يكون الظلام، وأن يكون مكانًا. لسان العرب (كفر).|6:عزاه السيوطي إلى ابن الأنباري في الوقف.|7:عزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم. وأخرجه ابن جرير ١٦/١٦٤ بلفظ: هي الأرض البيضاء -أو قال: الملساء- التي ليس فيها لبِنة مرتفعة.|8:أخرجه ابن جرير ١٦/١٦٥. وعلَّقه يحيى بن سلّام ١/٢٨٠. وعزاه السيوطي إلى عبد بن حميد.|9:عزاه السيوطي إلى عبد بن حميد، وابن أبي حاتم.|10:أخرجه إسحاق البستي في تفسيره ص٢٧٤.</p><p>والنبكة -محركة وتسكن-: أكمة محددة الرأس، وربما كانت حمراء، أو أرض فيها صعود وهبوط، أو التل الصغير. ينظر: القاموس المحيط (نبك).|11:عزاه السيوطي إلى عبد بن حميد.|12:علَّقه يحيى بن سلّام ١/٢٨٠.|13:تفسير البغوي ٥/٢٩٥.|14:تفسير عبد الرزاق ٢/١٩، وابن جرير ١٦/١٦٥. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.|15:أخرجه ابن جرير ١٦/١٦٦. وعلَّقه يحيى بن سلّام ١/٢٨٠.|16:تفسير مقاتل بن سليمان ٣/٤١.|17:تفسير الثوري ص١٩٦.|18:تعادي: التعادي: أمكنة غير مستوية. لسان العرب (عدا).|19:أخرجه ابن جرير ١٦/١٦٥.
  20,108,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿یَوۡمَىِٕذࣲ یَتَّبِعُونَ ٱلدَّاعِیَ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٨٣٢٥<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: قوله: <span class="qpc-hafs">﴿يومئذ يتبعون الداعي﴾</span> يوم تكون الأرض والجبال كذلك، <span class="qpc-hafs">﴿يومئذ يتبعون الداعي﴾</span> صاحب الصُّور، يُسرِعون إليه حين يخرجون مِن قبورهم إلى بيت المقدس.= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٣٢٦<span class="dash">-</span></span> قال <span class="name-1">عبد الله بن مسعود</span>: يقوم ملَك بين السماء والأرض بالصور، فينفخ فيه.= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٣٢٧<span class="dash">-</span></span> وقال <span class="name-2">قتادة</span>: مِن الصخرة مِن بيت المقدس{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٣٢٨<span class="dash">-</span></span> عن <span class="name-2">محمد بن كعب القرظي</span>، قال: يحشر اللهُ الناسَ يوم القيامة في ظُلْمَة؛ تطوى السماء، وتتناثر النجوم، وتذهب الشمس والقمر، ويُنادي منادٍ، فيسمع الناس الصوتَ يَؤُمُّونَه، فذلك قول الله: <span class="qpc-hafs">﴿يومئذ يتبعون الداعي لا عوج له﴾</span>{2}. (١٠/٢٤١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٣٢٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿يومئذ يتبعون الداعي﴾</span>، يعني: صوت الملَك الذى هو قائم على صخرة بيت المقدس، وهو إسرافيل ﵇ حين ينفخ في الصور، يعني: في القرن{3}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿لَا عِوَجَ لَهُۥۖ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٨٣٣٠<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق عاصم- قوله: <span class="qpc-hafs">﴿لا عوج له﴾</span>: لا مَعْدِل عنه، لا يتعوجون -أي: عن إجابته- يمينًا ولا شمالًا{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٣٣١<span class="dash">-</span></span> عن <span class="name-2">أبي صالح باذام</span>، في قوله: <span class="qpc-hafs">﴿يتبعون الداعي لا عوج له﴾</span>، قال: لا عِوَج عنه{2}. (١٠/٢٤١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٣٣٢<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span>، في قوله: <span class="qpc-hafs">﴿لا عوج له﴾</span>: لا يميلون عنه{2}. (١٠/٢٤١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٣٣٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: لا يزيغون ولا يروغون عنه يمينًا ولا شمالًا، يعني: لا يميلون عنه، كقوله سبحانه: <span class="qpc-hafs">﴿تبغونها عوجا﴾</span> [آل عمران:٩٩]، يعني: زيغًا، وهو الميل، <span class="qpc-hafs">﴿لا عوج له﴾</span> يعني: عنه، يستقيمون قِبَل الصوت، نظيرها: <span class="qpc-hafs">﴿ولم يجعل له عوجا﴾</span> [الكهف:١]{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٣٣٤<span class="dash">-</span></span> عن <span class="name-3">سفيان الثوري</span>، في قوله: <span class="qpc-hafs">﴿الداعي لا عوج له﴾</span>، قال: لا عِوَج عنه{8}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَخَشَعَتِ ٱلۡأَصۡوَاتُ لِلرَّحۡمَـٰنِ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٨٣٣٥<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- قوله: <span class="qpc-hafs">﴿وخشعت الأصوات للرحمن﴾</span>، يقول: سَكَنَتْ{9}. (١٠/٢٤٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٣٣٦<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: قوله: <span class="qpc-hafs">﴿وخشعت الأصوات للرحمن﴾</span> يعني: سكنت؛ لقوله: <span class="qpc-hafs">﴿لا يتكلمون﴾</span> [النبأ:٣٨]{1}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿فَلَا تَسۡمَعُ إِلَّا هَمۡسࣰا ۝١٠٨﴾</span> - قراءات</h3></p><p><div></p><p><p><span class="item-no">٤٨٣٣٧<span class="dash">-</span></span> عن قتادة، قال: في قراءة <span class="name-1">أُبَيّ بن كعب</span>: (لا يَنطِقُونَ إلّا هَمْسًا){11}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿فَلَا تَسۡمَعُ إِلَّا هَمۡسࣰا ۝١٠٨﴾</span> - تفسير الآية</h3></p><p><div></p><p><p><span class="item-no">٤٨٣٣٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- في قوله: <span class="qpc-hafs">﴿لا تسمع إلا همسا﴾</span>، قال: الصوت الخفِيّ{12}. (١٠/٢٤٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٣٣٩<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طُرُق- في قوله: <span class="qpc-hafs">﴿فلا تسمع إلا همسا﴾</span>، قال: صَوْتُ وطْءِ الأقدام{13}. (١٠/٢٤٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٣٤٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق سعيد بن جبير- قال: تحريك الشِّفاه مِن غير نطق{14}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٣٤١<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span> -من طريق عطاء بن السائب- في قوله: <span class="qpc-hafs">﴿فلا تسمع إلا همسا﴾</span>، قال: وطْء الأقدام{15}. (١٠/٢٤٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٣٤٢<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span>، في قوله: <span class="qpc-hafs">﴿إلا همسا﴾</span>، قال: سِرُّ الحديث، وصوت الأقدام{2}<span class=comment-ref>٤٣١١</span>. (١٠/٢٤٣)</p></p><p></div></p><p><div><span class=comment-ref>٤٣١١</span> ذكر <u>ابنُ كثير</u> (٩/٣٦٨) قولين في معنى: <span class="qpc-hafs">﴿فَلا تَسْمَعُ إلا هَمْسًا﴾</span>: <b>الأول:</b> وطء الأقدام. <b>والثاني:</b> الصوت الخفي. ثم <span class="comment-type-4">علَّق</span> على قول سعيد بن جبير بقوله: «فقد جمع سعيد كلا القولين، وهو محتَمَل؛ أمّا وطء الأقدام فالمراد: سعي الناس إلى المحشر، وهو مشْيُهم في سكون وخضوع. وأما الكلام الخفي فقد يكون في حال دون حال، فقد قال تعالى: <span class="qpc-hafs">﴿يَوْمَ يَأْتِ لا تَكَلَّمُ نَفْسٌ إلا بِإذْنِهِ فَمِنهُمْ شَقِيٌّ وسَعِيدٌ﴾</span> [هود:١٠٥]».</div></p><p><div></p><p><p><span class="item-no">٤٨٣٤٣<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن جريج- في قوله: <span class="qpc-hafs">﴿فلا تسمع إلا همسا﴾</span>، قال: هو خفض الصوت بالكلام؛ يُحَرِّك لسانه وشفتيه، ولا يُسْمِع{17}. (١٠/٢٤٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٣٤٤<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نَجِيح- في قوله: <span class="qpc-hafs">﴿وخشعت الأصوات للرحمن فلا تسمع إلا همسا﴾</span>، قال: حِسُّ الأقدام{18}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٣٤٥<span class="dash">-</span></span> عن <span class="name-2">الضحاك بن مزاحم</span>، في قوله: <span class="qpc-hafs">﴿فلا تسمع إلا همسا﴾</span>، قال: أصوات أقدامهم{19}. (١٠/٢٤٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٣٤٦<span class="dash">-</span></span> عن <span class="name-2">الضَّحّاك بن مُزاحِم</span> -من طريق عبيد- في قوله: <span class="qpc-hafs">﴿فلا تسمع إلا همسا﴾</span>، قال: الكلام الخفيُّ{20}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٣٤٧<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span> -من طريق عبد الرحمن بن الأصبهاني- في قوله: <span class="qpc-hafs">﴿فلا تسمع إلا همسا﴾</span>، قال: وطْء الأقدام{21}. (١٠/٢٤٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٣٤٨<span class="dash">-</span></span> عن حُصَين بن عبد الرحمن، قال: كنت قاعدًا مع <span class="name-2">الشعبي</span>، فمَرَّتْ علينا إبلٌ قد كان عليها جِصٌّ{22}، فطَرَحَتْهُ، فسمعت صوت أخفافها، فقال: هذا الهمس{23}. (١٠/٢٤٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٣٤٩<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طرق- في قوله: <span class="qpc-hafs">﴿فلا تسمع إلا همسا﴾</span>، قال: وطء الأقدام{24}. (١٠/٢٤٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٣٥٠<span class="dash">-</span></span> عن أبي عمرو الأوزاعي، أنه سمع <span class="name-2">بلال بن سعد</span> قال: يفزع يوم القيامة فزعة فيزولون، قال الأوزاعي: وقرأ: <span class="qpc-hafs">﴿وخشعت الأصوات للرحمن فلا تسمع إلا همسا﴾</span>، قال: همس الأقدام{25}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٣٥١<span class="dash">-</span></span> عن <span class="name-3">محمد بن السائب الكلبي</span> -من طريق خلف بن خليفة- قال: هو ذاك مِن الكلام الخَفِيِّ{26}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٣٥٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وخشعت الأصوات للرحمن فلا تسمع إلا همسا﴾</span> إلا خَفِيًّا من الأصوات؛ مثل: وطْءِ الأقدام{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٣٥٣<span class="dash">-</span></span> عن <span class="name-3">سفيان الثوري</span>، في قوله: <span class="qpc-hafs">﴿فلا تسمع إلا همسا﴾</span>، قال: وطء الأقدام{28}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٣٥٤<span class="dash">-</span></span> عن <span class="name-3">مالك بن أنس</span> -من طريق ابن وهب- في قول الله: <span class="qpc-hafs">﴿فلا تسمع إلا همسا﴾</span>، قال: وطء الأقدام{29}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٣٥٥<span class="dash">-</span></span> قال <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- قوله: <span class="qpc-hafs">﴿فلا تسمع إلا همسا﴾</span>، يقول: لا تسمع إلا مشيًا. قال: المشي: الهمس؛ وطء الأقدام{30}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير يحيى بن سلّام ١/٢٨٠.|2:عزاه السيوطي إلى ابن أبي حاتم.|3:تفسير مقاتل بن سليمان ٣/٤٢.|4:أخرجه يحيى بن سلّام ١/٢٨٠.|5:عزاه السيوطي إلى ابن أبي حاتم.|6:عزاه السيوطي إلى ابن أبي حاتم.|7:تفسير مقاتل بن سليمان ٣/٤٢.|8:تفسير الثوري ص١٩٦.|9:أخرجه ابن جرير ١٦/١٦٧، وابن أبي حاتم -كما في الإتقان ٢/٢٩-. وعزاه السيوطي إلى ابن المنذر.|10:تفسير يحيى بن سلّام ١/٢٨٠.|11:أخرجه يحيى بن سلّام ١/٢٨٠.</p><p>وهي قراءة شاذة. انظر: الجامع لأحكام القرآن ١٤/١٤٠، والبحر المحيط ٦/٢٦٠.|12:أخرجه ابن جرير ١٦/١٦٧. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.|13:أخرجه يحيى بن سلّام ١/٢٨٠ من طريق أبي العالية، وابن جرير ١٦/١٦٨ من طريق علي والعوفي، وابن أبي حاتم -كما في الإتقان ٢/٢٩-. وعزاه السيوطي إلى ابن المنذر.|14:تفسير البغوي ٥/٢٩٥.|15:أخرجه ابن أبي الدنيا في كتاب الأهوال ٦/٢٠٨ (١٨٠). وعزاه السيوطي إلى عبد بن حميد.|16:عزاه السيوطي إلى ابن أبي حاتم.|17:أخرجه ابن جرير ١٦/١٦٩، وبنحوه من طريق عبد الله بن كثير، كما أخرجه من طريق ابن أبي نجيح بلفظ: تهافتا. أوقال: تخافت الكلام. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر. وجاء في تفسير إسحاق البستي ص٢٧٤ من طريق ابن جريج بلفظ: كلام الإنسان لا يحرك شفتيه.|18:أخرجه أبو جعفر الرملي في جزئه ص ٥٤ (تفسير مسلم الزنجي). وعلقه البخاري ٤/١٧٦٣. وأخرجه إسحاق البستي في تفسيره ص٢٧٥ من طريق سفيان عن رجل، بلفظ: نقل الأقدام.|19:أخرجه إسحاق البستي في تفسيره ص٢٧٦ من طريق جويبر بلفظ: مِن الناس من يقول: وقع القدام، ومنهم من يقول: الكلام الخفي. وعزاه السيوطي إلى عبد بن حميد.|20:أخرجه إسحاق البستي في تفسيره ص٢٧٥.|21:أخرجه ابن جرير ١٦/١٦٩. وعزاه السيوطي إلى عبد بن حميد.|22:الجِصُّ والجَصُّ: الجِير، ويعرف حديثًا بالجِبْس. النهاية (جير)، واللسان (جصص)، والمعجم الوسيط (جبس).|23:عزاه السيوطي إلى عبد بن حميد.|24:أخرجه يحيى بن سلّام ١/٢٨٠ من طريق الحسن بن دينار، وابن أبي الدنيا في كتاب الأهوال -موسوعة ابن أبي الدنيا ٦/٢٠٨-٢٠٩ (١٨١)- من طريق منصور بن زاذان بلفظ: نقل أقدامهم، وابن جرير ١٦/١٦٩ من طريق حميد بلفظ: همس الأقدام، ومن طريق قتادة بلفظ: وقع أقدام القوم. وعزاه السيوطي إلى عبد بن حميد.|25:أخرجه ابن أبي الدنيا في كتاب الأهوال - موسوعة ابن أبي الدنيا ٦/١٩٧ (١٤٦).|26:أخرجه سعيد بن منصور في سننه - التفسير ٦/٢٧١ (١٤٣١) بلفظ: الكلام الخفي وذاك، وابن أبي الدنيا في كتاب الأهوال -موسوعة ابن أبي الدنيا ٦/٢٠٩ (١٨٢)- بلفظ: هو ذاك من الكلام الخفي.|27:تفسير مقاتل بن سليمان ٣/٤٢.|28:تفسير سفيان الثوري ص١٩٦، وأخرجه عبد الرزاق ٢/١٩ بلفظ: صوت الأقدام.|29:أخرجه عبد الله بن وهب في الجامع ٢/١٣٤ (٢٦٦).|30:أخرجه ابن جرير ١٦/١٦٩.
  20,109,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿یَوۡمَىِٕذࣲ لَّا تَنفَعُ ٱلشَّفَـٰعَةُ إِلَّا مَنۡ أَذِنَ لَهُ ٱلرَّحۡمَـٰنُ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٨٣٥٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿يومئذ لا تنفع الشفاعة﴾</span> يعني: شفاعة الملائكة <span class="qpc-hafs">﴿إلا من أذن له الرحمن﴾</span> أن يُشْفَع له{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٣٥٧<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: إنّ الكُفّار ليست لهم شفاعة، لا يُشفع لهم، كقوله: <span class="qpc-hafs">﴿ولا يشفعون إلا لمن ارتضى﴾</span> [الأنبياء:٢٨]{2}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَرَضِیَ لَهُۥ قَوۡلࣰا ۝١٠٩﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٨٣٥٨<span class="dash">-</span></span> قال <span class="name-1">عبد الله بن عباس</span>: يعني: قال: لا إله إلا الله{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٣٥٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ورضي له قولا﴾</span>، يعني: التوحيد{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٣٦٠<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: قوله: <span class="qpc-hafs">﴿يومئذ لا تنفع الشفاعة إلا من أذن له الرحمن ورضي له قولا﴾</span> التوحيد ... كقوله: <span class="qpc-hafs">﴿يوم يقوم الروح﴾</span> روح كل شيء في جسده، <span class="qpc-hafs">﴿والملائكة صفا لا يتكلمون إلا من أذن له الرحمن وقال صوابا﴾</span> [النبأ:٣٨] التوحيد{2}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٣/٤٢.|2:تفسير يحيى بن سلّام ١/٢٨١.|3:تفسير البغوي ٥/٢٩٦.|4:تفسير مقاتل بن سليمان ٣/٤٢.|5:تفسير يحيى بن سلّام ١/٢٨١.
  20,110,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿یَعۡلَمُ مَا بَیۡنَ أَیۡدِیهِمۡ وَمَا خَلۡفَهُمۡ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٨٣٦١<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿يعلم ما بين أيديهم﴾</span> يقول: يعلم ما بين أيديهم من أمر الساعة، <span class="qpc-hafs">﴿وما خلفهم﴾</span> مِن أمر الدنيا{1}<span class=comment-ref>٤٣١٢</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٤٣١٢</span> لم يذكر <u>ابنُ جرير</u> (١٦/١٧٠) في معنى: <span class="qpc-hafs">﴿يَعْلَمُ ما بَيْنَ أيْدِيهِمْ وما خَلْفَهُمْ﴾</span> سوى قول قتادة.</div></p><p><div></p><p><p><span class="item-no">٤٨٣٦٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿يعلم﴾</span> الله ﷿ <span class="qpc-hafs">﴿ما بين أيديهم وما خلفهم﴾</span> يقول: ما كان قبل أن يخلق الملائكة، وما كان بعد خلقهم{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٣٦٣<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: قوله: <span class="qpc-hafs">﴿يعلم ما بين أيديهم﴾</span> مِن أمر الآخرة، <span class="qpc-hafs">﴿وما خلفهم﴾</span> مِن أمر الدنيا، أي: إذا صاروا في الآخرة{3}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَلَا یُحِیطُونَ بِهِۦ عِلۡمࣰا ۝١١٠﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٨٣٦٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ولا يحيطون به علما﴾</span>، يعني: بالله ﷿ علمًا، هو أعظم من ذلك{2}<span class=comment-ref>٤٣١٣</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٤٣١٣</span> ذكر <u>ابنُ القيم</u> (٢/١٨٨) قولين لمرجع الضمير في <span class="qpc-hafs">﴿به﴾</span>: <b>الأول</b>: هو الله تعالى، أي: ولا يحيطون بالله علمًا. <b>والثاني</b>: هو ما بين أيديهم وما خلفهم. و<span class="comment-type-1">وجَّه</span> كلا القولين، فقال: «فعلى الأول: يرجع إلى العالم، وعلى الثاني: يرجع إلى المعلوم، وهذا القول يستلزم الأول مِن غير عكس؛ لأنهم إذا لم يحيطوا ببعض معلوماته المتعلقة بهم فأن لا يحيطوا علمًا به سبحانه أوْلى».</p><p>و<span class="comment-type-3">رجَّح</span> <u>ابنُ تيمية</u> (٤/٣٣٨) -ولم يذكر مستندًا- أن الضمير عائد إلى <span class="qpc-hafs">﴿ما بَيْنَ أيْدِيهِمْ وما خَلْفَهُمْ﴾</span>. ثم <span class="comment-type-4">بيَّن</span> استلزامه للقول الأول بنحو ما ذكر <u>ابنُ القيم</u>.</div></p><p><div></p><p><p><span class="item-no">٤٨٣٦٥<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿ولا يحيطون به علما﴾</span>، ويعلم ما لا يحيطون به علمًا. تبع للكلام الأول. أي: ويعلم ما لا يحيطون به علمًا ما لا يعلمون{3}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ١٦/١٧٠. وعلَّقه يحيى بن سلّام ١/٢٨١.|2:تفسير مقاتل بن سليمان ٣/٤٢.|3:تفسير يحيى بن سلّام ١/٢٨١.|4:تفسير مقاتل بن سليمان ٣/٤٢.|5:تفسير يحيى بن سلّام ١/٢٨١.
  20,111,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَعَنَتِ ٱلۡوُجُوهُ لِلۡحَیِّ ٱلۡقَیُّومِۖ﴾</span>{1} - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٨٣٦٦<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- في قوله: <span class="qpc-hafs">﴿وعنت الوجوه﴾</span>، قال: ذَلَّت{2}. (١٠/٢٤٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٣٦٧<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق العوفي- قوله: <span class="qpc-hafs">﴿وعنت الوجوه للحي القيوم﴾</span>: يعني: استسلمَتْ إلَيَّ{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٣٦٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>: أنّ نافع بن الأزرق قال له: أخبِرني عن قوله ﷿: <span class="qpc-hafs">﴿وعنت الوجوه للحي القيوم﴾</span>. قال: استسلَمَتْ وخضعَتْ يوم القيامة. قال: وهل تعرف العرب ذلك؟ قال: نعم، أما سمعت الشاعر وهو يقول:</p><p>ليَبْكِ عليكَ كلُ عانٍ بِكُرْبَةٍ وآلُ قُصَيٍّ مِن مُقِلٍّ وذي وفْرِ؟{4}. (١٠/٢٤٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٣٦٩<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، في قوله: <span class="qpc-hafs">﴿وعنت الوجوه﴾</span>، قال: الركوع، والسجود{5}. (١٠/٢٤٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٣٧٠<span class="dash">-</span></span> عن <span class="name-2">أبي العالية الرياحي</span>، <span class="qpc-hafs">﴿وعنت الوجوه﴾</span>، قال: خَضَعَتْ{6}. (١٠/٢٤٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٣٧١<span class="dash">-</span></span> عن <span class="name-2">طَلْق بن حبيب</span> -من طريق سليمان التيمي، وعمرو بن مُرَّة- في قوله: <span class="qpc-hafs">﴿وعنت الوجوه للحي القيوم﴾</span>، قال: هو وضْعُك جبهتَك وكفيك وركبتيك وأطرافَ قدميك في السجود{7}<span class=comment-ref>٤٣١٤</span>. (١٠/٢٤٤)</p></p><p></div></p><p><div><span class=comment-ref>٤٣١٤</span> <span class="comment-type-1">وجَّه</span> <u>ابنُ عطية</u> (٦/١٣٥) قول طلق بن حبيب قائلًا: «إن كان رَوى هذا أنّ للناس يوم القيامة سجودًا، وجعل هذه الآية إخبارًا عنه؛ فقوله مستقيم، وإن كان أراد سجود الدنيا فقد أفسد المعنى».</div></p><p><div></p><p><p><span class="item-no">٤٨٣٧٢<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نَجِيح- في قوله: <span class="qpc-hafs">﴿وعنت الوجوه﴾</span>، قال: خَشَعَت{8}. (١٠/٢٤٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٣٧٣<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span>، <span class="qpc-hafs">﴿وعنت الوجوه﴾</span>، قال: خَضَعَتْ{9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٣٧٤<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق مَعْمَر- في قوله: <span class="qpc-hafs">﴿وعنت الوجوه﴾</span>، قال: ذَلَّت الوجوه{10}. (١٠/٢٤٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٣٧٥<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿وعنت الوجوه﴾</span>، قال: ذَلَّتْ{11}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٣٧٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وعنت الوجوه﴾</span> يعني: استسلمت الوجوه <span class="qpc-hafs">﴿للحي﴾</span> الذى لا يموت، <span class="qpc-hafs">﴿القيوم﴾</span> يعني: القائم على كل شيء{12}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٣٧٧<span class="dash">-</span></span> عن <span class="name-3">سفيان الثوري</span>، في قوله: <span class="qpc-hafs">﴿وعنت الوجوه﴾</span>، قال: خَشَعَتْ وذَلَّتْ{13}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٣٧٨<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿وعنت الوجوه﴾</span>، قال: اسْتَأْسَرَت؛ صاروا أسارى كلهم [له. قال: والعاني: الأسير]{14}. (١٠/٢٤٣)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَقَدۡ خَابَ مَنۡ حَمَلَ ظُلۡمࣰا ۝١١١﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٨٣٧٩<span class="dash">-</span></span> قال <span class="name-1">عبد الله بن عباس</span>: خَسِر مَن أشرك بالله، والظُّلْم هو الشرك{15}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٣٨٠<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق مَعْمَر- في قول: <span class="qpc-hafs">﴿وقد خاب من حمل ظلما﴾</span>، قال: شِرْكًا{16}. (١٠/٢٤٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٣٨١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وقد خاب من حمل ظلما﴾</span>، يقول: وقد خسِر مَن حمل شِرْكًا يومَ القيامة على ظهره{12}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٣٨٢<span class="dash">-</span></span> عن <span class="name-3">عبد الملك ابن جريج</span>، في قوله: <span class="qpc-hafs">﴿وقد خاب من حمل ظلما﴾</span>، قال: شِرْكًا{18}. (١٠/٢٤٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٣٨٣<span class="dash">-</span></span> عن <span class="name-3">سفيان الثوري</span>، في قوله: <span class="qpc-hafs">﴿وقد خاب من حمل ظلما﴾</span>، قال: الظُّلْم: الشِّرْك{13}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٣٨٤<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿وقد خاب من حمل ظلما﴾</span>، قال: مَن حَمَل شِرْكًا، الظلم هاهنا: الشرك{20}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٣٨٥<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: قوله: <span class="qpc-hafs">﴿وقد خاب من حمل ظلما﴾</span> مَن حمل شِرْكًا{21}. (ز)</p></p><p></div></p></div>",footnotes:1:تقدم تفسير <span class="qpc-hafs">﴿الحي القيوم﴾</span> في سورة آل عمران [٢].|2:أخرجه ابن جرير ١٦/١٧٢، وابن أبي حاتم -كما في الإتقان ٢/٢٩-. وعزاه السيوطي إلى ابن المنذر.|3:أخرجه ابن جرير ١٦/١٧٣.|4:أخرجه الطستي -كما في الإتقان ٢/٩٣-.|5:عزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.|6:عزاه السيوطي إلى عبد بن حميد.|7:أخرجه ابن أبي شيبة ١/٢٦١، وابن جرير ١٦/١٧٣-١٧٤. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.|8:تفسير مجاهد ص٤٣٠، وأخرجه ابن جرير ١٦/١٧٣. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.|9:أخرجه ابن المنذر -كما في الفتح ٥/٣٩٤-.|10:أخرجه عبد الرزاق ٢/١٩، وابن جرير ١٦/١٧٣، كما أخرجه يحيى بن سلّام ١/٢٨١، وابن أبي الدنيا في كتاب الأهوال -موسوعة ابن أبي الدنيا ٦/٢٠٩ (١٨٣)-، وابن جرير ١٦/١٧٣ من طريق سعيد. وعزاه السيوطي إلى عبد بن حميد.|11:أخرجه ابن أبي الدنيا في كتاب الأهوال -موسوعة ابن أبي الدنيا ٦/٢٠٩ (١٨٣)-.|12:تفسير مقاتل بن سليمان ٣/٤٢.|13:أخرجه الثوري في تفسيره ص١٩٦.|14:أخرجه ابن جرير ١٦/١٧٤.|15:تفسير البغوي ٥/٢٩٦.|16:أخرجه عبد الرزاق ٢/١٩، وابن جرير ١٦/١٧٥. وعزاه السيوطي إلى عبد بن حميد.|17:تفسير مقاتل بن سليمان ٣/٤٢.|18:عزاه السيوطي إلى ابن المنذر.|19:أخرجه الثوري في تفسيره ص١٩٦.|20:أخرجه ابن جرير ١٦/١٧٥.|21:تفسير يحيى بن سلّام ١/٢٨١.
  20,112,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَمَن یَعۡمَلۡ مِنَ ٱلصَّـٰلِحَـٰتِ وَهُوَ مُؤۡمِنࣱ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٨٣٨٦<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق مَعْمَر- قوله: <span class="qpc-hafs">﴿ومن يعمل من الصالحات وهو مؤمن﴾</span>: وإنما يقبل الله مِن العمل ما كان في إيمان{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٣٨٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ومن يعمل من الصالحات وهو مؤمن﴾</span> مُصَدِّق بتوحيد الله ﷿{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٣٨٨<span class="dash">-</span></span> عن <span class="name-3">عبد الملك ابن جريج</span> -من طريق حجّاج- قوله: <span class="qpc-hafs">﴿ومن يعمل من الصالحات وهو مؤمن﴾</span>، قال: زعموا أنها الفرائض{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٣٨٩<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: قوله: <span class="qpc-hafs">﴿ومن يعمل من الصالحات وهو مؤمن فلا يخاف ظلما ولا هضما﴾</span> لا يجزى بالعمل الصالح في الآخرة إلا المؤمن، ويجزى به الكافر في الدنيا{4}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿فَلَا یَخَافُ ظُلۡمࣰا وَلَا هَضۡمࣰا ۝١١٢﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٨٣٩٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- في قوله: <span class="qpc-hafs">﴿فلا يخاف ظلما ولا هضما﴾</span>، قال: لا يخاف أن يُظلَم فيُزاد في سيئاته، ولا يُهضَم مِن حسناته{5}. (١٠/٢٤٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٣٩١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق العوفي- قوله: <span class="qpc-hafs">﴿ومن يعمل من الصالحات وهو مؤمن فلا يخاف ظلما ولا هضما﴾</span>: يقول: أنا قاهِرٌ لكم اليومَ، آخُذُكم بقُوَّتي وشِدَّتي، وأنا قادِرٌ على قهركم وهضمكم، فإنّما بيني وبينكم العدل، وذلك يوم القيامة{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٣٩٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، في قوله: <span class="qpc-hafs">﴿ولا هضما﴾</span>، قال: غصبًا{7}. (١٠/٢٤٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٣٩٣<span class="dash">-</span></span> عن <span class="name-2">أبي العالية الرِّياحِيِّ</span>، في قول الله تعالى: <span class="qpc-hafs">﴿فلا يخاف ظلما ولا هضما﴾</span>، قال: لا ينقص من ثواب حسناته شيئًا، ولا يحمل عليه ذنبُ مسيءٍ{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٣٩٤<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق أبي يحيى- في قوله: <span class="qpc-hafs">﴿فلا يخاف ظلما﴾</span> قال: أن يُزاد عليه أكثر من ذنوبه، <span class="qpc-hafs">﴿ولا هضما﴾</span> قال: أن يُنتقص مِن حسناته شيئًا{9}. (١٠/٢٤٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٣٩٥<span class="dash">-</span></span> عن <span class="name-2">الضحاك بن مُزاحِم</span> -من طريق عُبيد بن سليمان- في قوله: <span class="qpc-hafs">﴿فلا يخاف ظلما ولا هضما﴾</span>، قال: أما <span class="qpc-hafs">﴿هضما﴾</span>: فهو أن يقهر الرجلُ الرجلَ بقوته، يقول الله: يومَ القيامة لا آخذكم بقُوَّتي وشِدَّتي، ولكن العدل بيني وبينكم، ولا ظُلْمَ عليكم{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٣٩٦<span class="dash">-</span></span> عن <span class="name-2">الضحاك بن مُزاحِم</span> -من طريق جُوَيْبِر- في قوله: <span class="qpc-hafs">﴿لا يخاف ظلما ولا هضما﴾</span> قال: الهضم: لا يخاف أن يُنقَص مِن عمله الصالح شيء، <span class="qpc-hafs">﴿ولا هضما﴾</span>: لا يخاف أن يُؤاخَذ بما لم يعمل{11}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٣٩٧<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق ميمون بن سياه- في قول الله تعالى: <span class="qpc-hafs">﴿فلا يخاف ظلما ولا هضما﴾</span>، قال: لا ينتقص الله مِن حسناته شيئًا، ولا يحمل عليه ذنب مسيء{12}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٣٩٨<span class="dash">-</span></span> تفسير <span class="name-2">الحسن البصري</span>، قال: <span class="qpc-hafs">﴿فلا يخاف ظلما﴾</span> أن يُزاد عليه سيئاته{13}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٣٩٩<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق مَعْمَر- في قوله: <span class="qpc-hafs">﴿فلا يخاف ظلما ولا هضما﴾</span>، قال: <span class="qpc-hafs">﴿ظلما﴾</span> أن يزاد في سيئاته، <span class="qpc-hafs">﴿ولا هضما﴾</span> قال: لا يُنقص مِن حسناته{14}. (١٠/٢٤٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٤٠٠<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- قوله: <span class="qpc-hafs">﴿فلا يخاف ظلما ولا هضما﴾</span>: أي: لا يخاف أن يُحمَل عليه ذنبُ غيرِه، ولا يُهضَم مِن حسابه{15}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٤٠١<span class="dash">-</span></span> عن <span class="name-2">حبيب بن أبي ثابت</span> -من طريق مسعر- يقول في قوله: <span class="qpc-hafs">﴿ولا هضما﴾</span>، قال: الهضم: الانتقاص{16}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٤٠٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فلا يخاف ظلما﴾</span> في الآخرة، يعني: أن تُظلَم حسناته كلها حتى لا يُجازى بحسناته كلها، <span class="qpc-hafs">﴿ولا هضما﴾</span> يعني: ولا ينقص منها شيئًا. مثل قوله ﷿: <span class="qpc-hafs">﴿فلا يخاف بخسا ولا رهقا﴾</span> [الجن:١٣]{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٤٠٣<span class="dash">-</span></span> عن <span class="name-3">سفيان الثوري</span>، في قوله: <span class="qpc-hafs">﴿فلا يخاف ظلما ولا هضما﴾</span>، قال: الظلم: أن يُظلَم حقُّه، والهضم: أن يهضم بعض حقه{18}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٤٠٤<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿فلا يخاف ظلما ولا هضما﴾</span>، قال: لا يخاف أن يظلم فلا يُجزى بعمله، ولا يخاف أن يُنتَقص من حقِّه فلا يُوَفّى عمله{16}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٤٠٥<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿ولا هضما﴾</span>: لا ينقص من حسناته{4}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ١٦/١٧٥.|2:تفسير مقاتل بن سليمان ٣/٤٢.|3:أخرجه ابن جرير ١٦/١٧٦.|4:تفسير يحيى بن سلّام ١/٢٨٢.|5:أخرجه ابن جرير ١٦/١٦٧، وابن أبي حاتم -كما في الإتقان ٢/٢٩-. وعزاه السيوطي إلى ابن المنذر.|6:أخرجه ابن جرير ١٦/١٧٦.|7:عزاه السيوطي إلى الفريابي، وعبد بن حميد، وابن أبي حاتم.|8:تفسير الثعلبي ٦/٢٦١.|9:أخرجه يحيى بن سلّام ١/٢٨٢ بنحوه. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.|10:أخرجه ابن جرير ١٦/١٧٦.|11:أخرجه إسحاق البستي في تفسيره ص٢٧٧.|12:أخرجه ابن جرير ١٦/١٧٨.|13:علَّقه يحيى بن سلّام ١/٢٨٢.|14:أخرجه عبد الرزاق ٢/١٩، وابن جرير ١٦/١٧٧. وعزاه السيوطي إلى عبد بن حميد.|15:أخرجه ابن جرير ١٦/١٧٧. وعلَّقه يحيى بن سلّام ١/٢٨٢.|16:أخرجه ابن جرير ١٦/١٧٧.|17:تفسير مقاتل بن سليمان ٣/٤٢.|18:تفسير الثوري ص١٩٧.|19:أخرجه ابن جرير ١٦/١٧٧.|20:تفسير يحيى بن سلّام ١/٢٨٢.
  20,113,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَكَذَ ٰ⁠لِكَ أَنزَلۡنَـٰهُ قُرۡءَانًا عَرَبِیࣰّا وَصَرَّفۡنَا فِیهِ مِنَ ٱلۡوَعِیدِ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٨٤٠٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿كذلك﴾</span> يعني: وهكذا <span class="qpc-hafs">﴿أنزلناه قرآنا عربيا﴾</span> ليفقهوه، <span class="qpc-hafs">﴿وصرفنا﴾</span> يعني: وصَنَّفنا <span class="qpc-hafs">﴿فيه﴾</span> يعني: لَوَّنّا فيه، يعني: في القرآن <span class="qpc-hafs">﴿من﴾</span> ألوان <span class="qpc-hafs">﴿الوعيد﴾</span> للأُمَمِ الخالية في الدنيا مِن الحَصْب، والخَسْف، والغَرَق، والصَّيْحة{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٤٠٧<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: قوله: <span class="qpc-hafs">﴿وكذلك أنزلناه قرآنا عربيا وصرفنا فيه من الوعيد﴾</span> مَن يعمل كذا فله كذا، فذكره في هذه السورة، ثم في سورة أخرى{2}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿لَعَلَّهُمۡ یَتَّقُونَ أَوۡ یُحۡدِثُ لَهُمۡ ذِكۡرࣰا ۝١١٣﴾</span> - قراءات</h3></p><p><div></p><p><p><span class="item-no">٤٨٤٠٨<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: وهي تُقْرَأ بالياء والتاء. فمَن قرأها بالياء يقول: أو يحدث لهم القرآن ذكرًا، أي: جِدًّا وورعًا في تفسير <span class="name-2">قتادة</span>. ومَن قرأها بالتاء يقول: أو تُحدث لهم -يا محمدُ- ذِكْرًا{3}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿لَعَلَّهُمۡ یَتَّقُونَ أَوۡ یُحۡدِثُ لَهُمۡ ذِكۡرࣰا ۝١١٣﴾</span> - تفسير الآية</h3></p><p><div></p><p><p><span class="item-no">٤٨٤٠٩<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿وكذلك أنزلناه قرآنا عربيا وصرفنا فيه من الوعيد لعلهم يتقون﴾</span>: ما حذروا به مِن أمر الله وعذابه ووقائعه بالأمم قبلهم، <span class="qpc-hafs">﴿أو يحدث لهم﴾</span> أي: جِدًّا وورعًا{4}. (ز) (١٠/٢٤٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٤١٠<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: تفسير <span class="name-2">السُّدِّيّ</span>: <span class="qpc-hafs">﴿لعلهم يتقون أو يحدث لهم ذكرا﴾</span>: لعلهم يتقون ويحدث لهم ذكرًا، يعني: القرون الأولى. والألف هاهنا صلة{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٤١١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: فهذا الوعيد لهم؛ <span class="qpc-hafs">﴿لعلهم﴾</span> يعني: لكي <span class="qpc-hafs">﴿يتقون﴾</span> يعني: لكي يُخْلِصوا التوحيد بوعيدنا في القرآن، <span class="qpc-hafs">﴿أو يحدث لهم﴾</span> يعني: الوعيد <span class="qpc-hafs">﴿ذكرا﴾</span> عظة فيخافون فيؤمنون{1}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٣/٤٢.|2:تفسير يحيى بن سلّام ١/٢٨٢.|3:تفسير يحيى بن سلّام ١/٢٨٢.</p><p>و<span class="qpc-hafs">﴿أوْ يُحْدِثُ﴾</span> بالياء هي قراءة العشرة، وأما (أوْ تُحْدِثُ) بالتاء فشاذة، وتروى عن مجاهد. انظر: مختصر ابن خالويه ص٩٢.|4:أخرجه بتمامه ابن جرير ١٦/١٧٩. وأخرج شطره الثاني من طريق معمر عبد الرزاق ٢/١٩، وابن جرير ١٦/١٧٩. وعلَّقه يحيى بن سلّام ١/٢٨٢. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.|5:تفسير يحيى بن سلّام ١/٢٨٢.|6:تفسير مقاتل بن سليمان ٣/٤٢.