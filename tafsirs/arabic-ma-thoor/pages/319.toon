quran[15]{c,v,t}:
20,99," <q>﴿كَذَ ٰ⁠لِكَ نَقُصُّ عَلَیۡكَ مِنۡ أَنۢبَاۤءِ مَا قَدۡ سَبَقَۚ وَقَدۡ ءَاتَیۡنَـٰكَ مِن لَّدُنَّا ذِكۡرࣰا ۝٩٩﴾</q> - تفسير ٤٨٢٦٥- قال مقاتل بن سليمان: <q>﴿كذلك﴾</q> يعني: هكذا <q>﴿نقص عليك﴾</q> يا محمد <q>﴿من أنباء﴾</q> يعني: مِن أحاديث <q>﴿ما قد سبق﴾</q> مِن قبلك مِن الأمم الخالية، <q>﴿وقد آتيناك من لدنا ذكرا﴾</q> يقول: قد أعطيناك مِن عندنا تبيانًا، يعني: القرآن{1}. (ز) ٤٨٢٦٦- عن عبد الرحمن بن زيد بن أسلم، في قوله: <q>﴿وقد آتيناك من لدنا ذكرا﴾</q>، قال: القرآن{2}. (١٠/٢٣٨) ٤٨٢٦٧- قال يحيى بن سلّام: قوله: <q>﴿كذلك نقص عليك من أنباء ما قد سبق﴾</q> مِن أخبار ما قد مضى، <q>﴿وقد آتيناك﴾</q> أي: وقد أعطيناك <q>﴿من لدنا﴾</q> مِن عندنا <q>﴿ذكرا﴾</q> القرآن{3}. (ز) ",footnotes:1:تفسير مقاتل بن سليمان ٣/٤٠.عزاه السيوطي إلى ابن أبي حاتم.تفسير يحيى بن سلّام ١/٢٧٦.
20,100," <q>﴿مَّنۡ أَعۡرَضَ عَنۡهُ فَإِنَّهُۥ یَحۡمِلُ یَوۡمَ ٱلۡقِیَـٰمَةِ وِزۡرًا ۝١٠٠﴾</q> - تفسير ٤٨٢٦٨- عن مجاهد بن جبر -من طريق ابن جريج- في قوله: <q>﴿يحمل يوم القيامة وزرا﴾</q>، قال: إثْمًا{1}. (١٠/٢٣٨) ٤٨٢٦٩- قال مقاتل بن سليمان: <q>﴿من أعرض عنه﴾</q> يعني: عن إيمانٍ بالقرآن؛ <q>﴿فإنه يحمل يوم القيامة وزرا﴾</q> يعني: إثمًا بإعراضه عن القرآن يحمله على ظهره ... والوزر: هو الخطأ الكبير{2}. (ز) ٤٨٢٧٠- عن سفيان الثوري، في قوله: <q>﴿من أعرض عنه فإنه يحمل يوم القيامة وزرا﴾</q>، قال: الوِزر: هو الشِّرْك{3}. (ز) ٤٨٢٧١- قال يحيى بن سلّام: قوله: <q>﴿من أعرض عنه﴾</q> عن القرآن، ولم يؤمن به؛ <q>﴿فإنه يحمل يوم القيامة وزرا﴾</q>{4}. (ز) ",footnotes:1:أخرجه إسحاق البستي في تفسيره ص٢٧١. وعلَّقه يحيى بن سلّام ١/٢٧٧. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.تفسير مقاتل بن سليمان ٣/٤١.تفسير الثوري ص١٩٥.تفسير يحيى بن سلّام ١/٢٧٦.
20,101," <q>﴿خَـٰلِدِینَ فِیهِۖ﴾</q> - تفسير ٤٨٢٧٢- قال الحسن البصري: <q>﴿خالدين فيه﴾</q> في ثواب ذلك الوِزر، وهي النار{1}. (ز) ٤٨٢٧٣- قال مقاتل بن سليمان: <q>﴿خالدين فيه﴾</q>، يعني: في الوِزر؛ في النار{2}. (ز) <q>﴿وَسَاۤءَ لَهُمۡ یَوۡمَ ٱلۡقِیَـٰمَةِ حِمۡلࣰا ۝١٠١﴾</q> - تفسير ٤٨٢٧٤- عن عبد الله بن عباس -من طريق علي- في قوله: <q>﴿وساء لهم يوم القيامة حملا﴾</q>، يقول: بِئسَ ما حملوا{3}. (١٠/٢٣٨) ٤٨٢٧٥- عن عبد الله بن عباس -من طريق العوفي- في قوله: <q>﴿وساء لهم يوم القيامة حملا﴾</q>: يعني بذلك: ذنوبهم{4}. (ز) ٤٨٢٧٦- قال مقاتل بن سليمان: <q>﴿وساء لهم﴾</q> يعني: وبئس لهم <q>﴿يوم القيامة حملا﴾</q> يعني: إثمًا{2}. (ز) ٤٨٢٧٧- عن عبد الرحمن بن زيد بن أسلم، في قوله: <q>﴿وساء لهم يوم القيامة حملا﴾</q>، قال: ليس هي «وساءلهم» موصولة، ينبغي أن تقطع؛ فإنك إنّ وصلت لم يفهم، وليس بها خفاء؛ ساء لهم بها حملًا خالدين فيه، <q>﴿وساء لهم يوم القيامة حملا﴾</q> قال: حمل السوء، ويورد صاحبه النار. قال: وإنما هي: <q>﴿وساء لهم﴾</q> مقطوعة، <q>﴿وساء﴾</q> بعدها <q>﴿لهم﴾</q>{6}. (١٠/٢٣٨) ٤٨٢٧٨- قال يحيى بن سلّام: <q>﴿وساء لهم﴾</q> أي: وبئس لهم <q>﴿يوم القيامة حملا﴾</q> ما يحملون على ظهورهم مِن الوِزر، وهو قوله: <q>﴿وهم يحملون أوزارهم على ظهورهم ألا ساء ما يزرون﴾</q> [الأنعام:٣١]{7}. (ز) ",footnotes:1:علَّقه يحيى بن سلّام ١/٢٧٧.تفسير مقاتل بن سليمان ٣/٤١.أخرجه ابن جرير ١٦/١٦٠، وابن أبي حاتم -كما في الإتقان ٢/٢٨-. وعزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ١٦/١٦٠.تفسير مقاتل بن سليمان ٣/٤١.عزاه السيوطي إلى ابن أبي حاتم.تفسير يحيى بن سلّام ١/٢٧٧.
20,102," <q>﴿یَوۡمَ یُنفَخُ فِی ٱلصُّورِۚ وَنَحۡشُرُ ٱلۡمُجۡرِمِینَ یَوۡمَىِٕذࣲ زُرۡقࣰا ۝١٠٢﴾</q> - تفسير ٤٨٢٧٩- عن عبد الله بن عباس، أنّ رجلًا أتاه، فقال: أرأيتَ قوله: <q>﴿ونحشر المجرمين يومئذ زرقا﴾</q>، وأخرى: <q>﴿عميا﴾</q> [الإسراء:٩٧]. قال: إنّ يوم القيامة فيه حالات؛ يكونون في حال زُرْقًا، وفي حال عُمْيًا{1}. (١٠/٢٣٨) ٤٨٢٨٠- قال إسماعيل السُّدِّيّ: <q>﴿ونحشر المجرمين﴾</q> يعني: بعد الحساب، نسوق المشركين إلى النار <q>﴿زرقا﴾</q> قال: مُسْوَدَّة وجوههم كالِحة{2}. (ز) ٤٨٢٨١- قال مقاتل بن سليمان: <q>﴿يوم ينفخ في الصور ونحشر المجرمين﴾</q> يعني: المشركين إلى النار <q>﴿يومئذ زرقا﴾</q> زرق الأعين{3}. (ز) ٤٨٢٨٢- قال يحيى بن سلّام: قوله: <q>﴿يوم ينفخ في الصور﴾</q> والصور: قَرْنٌ ينفُخ فيه صاحبُ الصور، فينطلق كل روحٍ إلى جسده، تجعل الأرواح كلها في الصور، فإذا نفخ فيه خرجت الأرواح مثل النحل، كل روح إلى جسده، <q>﴿ونحشر المجرمين﴾</q> يعني: المشركين، هذا حشر إلى النار، <q>﴿يومئذ زرقا﴾</q>{4}. (ز) ",footnotes:1:عزاه السيوطي إلى ابن أبي حاتم.علَّقه يحيى بن سلّام ١/٢٧٨.تفسير مقاتل بن سليمان ٣/٤١.تفسير يحيى بن سلّام ١/٢٧٧.
20,103," <q>﴿یَتَخَـٰفَتُونَ بَیۡنَهُمۡ﴾</q> - تفسير ٤٨٢٨٣- عن عبد الله بن عباس -من طريق علي- في قوله: <q>﴿يتخافتون بينهم﴾</q>، قال: يَتَسارُّون{1}. (١٠/٢٣٨) ٤٨٢٨٤- عن قتادة بن دعامة -من طريق سعيد- قوله: <q>﴿يتخافتون بينهم﴾</q>: أي: يتسارُّون بينهم، يُسارُّ بعضُهم بعضًا{2}٤٣٠٨. (ز) ٤٣٠٨ لم يذكر ابنُ جرير (١٦/١٦١) في معنى: <q>﴿يَتَخافَتُونَ بَيْنَهُمْ﴾</q> سوى قول ابن عباس، وقتادة. ٤٨٢٨٥- عن عطاء الخراساني -من طريق يونس- في قول الله ﷿: <q>﴿يتخافتون بينهم﴾</q>، قال: الكلام الخَفِيُّ{3}. (ز) ٤٨٢٨٦- قال مقاتل بن سليمان: <q>﴿يتخافتون﴾</q> يعني: يتساءلون <q>﴿بينهم﴾</q> يقول بعضُهم لبعض{4}. (ز) ٤٨٢٨٧- عن سفيان بن عيينة -من طريق ابن أبي عمر- وسُئِل عن قوله: <q>﴿يتخافتون بينهم إن لبثتم﴾</q>. قال: أسَرُّوا في أنفسهم{5}. (ز) <q>﴿إِن لَّبِثۡتُمۡ إِلَّا عَشۡرࣰا ۝١٠٣﴾</q> - تفسير ٤٨٢٨٨- قال مقاتل بن سليمان: <q>﴿إن﴾</q> يعني: ما <q>﴿لبثتم إلا عشرا﴾</q> يعني: عشر ليال{4}. (ز) ٤٨٢٨٩- قال يحيى بن سلّام: <q>﴿إن لبثتم﴾</q> في الدنيا <q>﴿إلا عشرا﴾</q>، يُقَلِّلون لُبثَهم في الدنيا، تَصاغَرَتِ الدنيا عندهم{7}. (ز) ",footnotes:1:أخرجه ابن جرير ١٦/١٦١، وابن أبي حاتم -كما في الإتقان ٢/٢٨-. وعزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ١٦/١٦١. وعلقه يحيى بن سلّام ١/٢٧٨.أخرجه أبو جعفر الرملي في جزئه ص١٢١ (تفسير عطاء الخراساني).تفسير مقاتل بن سليمان ٣/٤١.أخرجه إسحاق البستي في تفسيره ص٢٧١.تفسير مقاتل بن سليمان ٣/٤١.تفسير يحيى بن سلّام ١/٢٧٨.
20,104," <q>﴿نَّحۡنُ أَعۡلَمُ بِمَا یَقُولُونَ إِذۡ یَقُولُ أَمۡثَلُهُمۡ طَرِیقَةً إِن لَّبِثۡتُمۡ إِلَّا یَوۡمࣰا ۝١٠٤﴾</q> - تفسير ٤٨٢٩٠- عن سعيد بن جبير -من طريق أشعث، عن جعفر- في قوله: <q>﴿إذ يقول أمثلهم طريقة﴾</q>، قال: أوْفاهُم عَقْلًا{1}. (١٠/٢٣٩) ٤٨٢٩١- عن سعيد بن جبير -من طريق يعقوب، عن جعفر- في قوله: <q>﴿إذ يقول أمثلهم طريقة﴾</q>، قال: أعلمهم في نفسِه{2}. (١٠/٢٣٩) ٤٨٢٩٢- عن قتادة بن دعامة، في قوله: <q>﴿إذ يقول أمثلهم طريقة﴾</q> قال: أعدلهم مِن الكفار: <q>﴿إن لبثتم﴾</q> أي: في الدنيا <q>﴿إلا يوما﴾</q>؛ لَمّا تقاصرت الدنيا في أنفسهم{3}. (١٠/٢٣٩) ٤٨٢٩٣- قال مقاتل بن سليمان: <q>﴿نحن أعلم بما يقولون إذ يقول أمثلهم طريقة﴾</q> يعني: أمثلهم نجوى ورأيًا: <q>﴿إن لبثتم﴾</q> في القبور <q>﴿إلا يوما﴾</q> واحدًا{4}. (ز) ٤٨٢٩٤- قال سفيان بن عيينة -من طريق ابن أبي عمر-: <q>﴿أمثلهم﴾</q>: أعدلهم طريقة{5}. (ز) ٤٨٢٩٥- قال يحيى بن سلّام: قال الله: <q>﴿نحن أعلم بما يقولون إذ يقول أمثلهم طريقة﴾</q> وقال في آية أخرى: <q>﴿ويذهبا بطريقتكم المثلى﴾</q> [طه:٦٣]. قال قتادة: كانوا أكثر عددًا وأموالًا. وقال بعضهم: <q>﴿نحن أعلم بما يقولون إذ يقول أمثلهم طريقة﴾</q> أعقلهم: <q>﴿إنْ لَبِثْتُمْ إلا يَوْمًا﴾</q>. وهي مواطن، قالوا: <q>﴿إلا يوما﴾</q>، و<q>﴿إلا عشرا﴾</q>، و<q>﴿قالوا لبثنا يوما أو بعض يوم﴾</q> [الكهف:١٩]، وقال: <q>﴿كأنهم يوم يرونها لم يلبثوا إلا عشية أو ضحاها﴾</q> [النازعات:٤٦]، وقال: <q>﴿كأنهم يوم يرون ما يوعدون لم يلبثوا إلا ساعة من نهار﴾</q> [الأحقاف:٣٥]، وقال: <q>﴿ويوم تقوم الساعة يقسم المجرمون﴾</q> [الروم:٥٥] يحلف المجرمون المشركون: <q>﴿ما لبثوا غير ساعة﴾</q> [الروم:٥٥] أي: في الدنيا؛ وذلك لتصاغر الدنيا عندهم، وقِلَّتها في طول الآخرة{6}. (ز) ",footnotes:1:أخرجه ابن جرير ١٦/١٦٢. وعزاه السيوطي إلى ابن أبي شيبة، وعبد بن حميد، وابن المنذر، وابن أبي حاتم.أخرجه ابن جرير ١٦/١٦٢. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.علَّق يحيى بن سلّام ١/٢٧٩ بعضه. وعزاه السيوطي إلى ابن أبي حاتم.تفسير مقاتل بن سليمان ٣/٣١.أخرجه إسحاق البستي في تفسيره ص٢٧٣. وعلَّقه البخاري كتاب التفسير- باب تفسير سورة طه ٤/١٧٦٣.تفسير يحيى بن سلّام ١/٢٧٩.
20,105," <q>﴿وَیَسۡـَٔلُونَكَ عَنِ ٱلۡجِبَالِ فَقُلۡ یَنسِفُهَا رَبِّی نَسۡفࣰا ۝١٠٥﴾</q> - نزول الآية، وتفسيرها ٤٨٢٩٦- قال ابن عباس: سأل رجلٌ مِن ثَقيف رسولَ الله ﷺ، فقال: كيف تكون الجبال يوم القيامة؟ فأنزل الله هذه الآية{1}. (ز) ٤٨٢٩٧- عن عبد الملك ابن جُرَيج، قال: قالت قريش: يا محمد، كيف يفعل ربُّك بهذه الجبال يوم القيامة؟ فنزلت: <q>﴿ويسألونك عن الجبال﴾</q> الآية{2}. (١٠/٢٣٩) ٤٨٢٩٨- قال مقاتل بن سليمان: <q>﴿ويسألونك عن الجبال﴾</q> نزلت في رجل من ثقيف، <q>﴿فقل ينسفها ربي نسفا﴾</q> مِن الأرض مِن أصولها{3}. (ز) ٤٨٢٩٩- قال يحيى بن سلّام: قوله: <q>﴿ويسألونك عن الجبال﴾</q> سأل المشركون النبيَّ، فقالوا: يا محمد، كيف هذه الجبال في ذلك اليوم الذي تذكر؟ فقال الله: <q>﴿ويسألونك عن الجبال فقل ينسفها ربي نسفا﴾</q> مِن أصولها{4}. (ز) ٤٨٣٠٠- عن عروة، قال: كُنّا قُعودًا عند عبد الملك بن مروان حين قال: قال كعب: إنّ الصخرة موضع قدم الرحمن يوم القيامة. فقال: كذب كعب، إنما الصخرة جبل من الجبال، إن الله يقول: <q>﴿ويسألونك عن الجبال فقل ينسفها ربي نسفا﴾</q>. فسكت عبد الملك{5}. (ز) ",footnotes:1:أورده الواحدي في التفسير الوسيط ٣/٢٢١، والبغوي في تفسيره ٥/٢٩٤.عزاه السيوطي إلى ابن المنذر.تفسير مقاتل بن سليمان ٣/٤١.تفسير يحيى بن سلّام ١/٢٧٩.أخرجه ابن جرير ١٦/١٦٣.
20,106," <q>﴿فَیَذَرُهَا قَاعࣰا صَفۡصَفࣰا ۝١٠٦﴾</q> - تفسير ٤٨٣٠١- عن عبد الله بن عباس -من طريق علي- في قوله: <q>﴿فيذرها قاعا﴾</q> قال: مستويًا، <q>﴿صفصفا﴾</q> قال: لا نبات فيه{1}٤٣٠٩. (١٠/٢٣٩) ٤٣٠٩ ذكر ابن كثير (٩/٣٦٧) بأنّ معنى القاع: المستوي من الأرض. والصفصف تأكيد لمعنى ذلك، وذكر قولًا آخر في معنى الصفصف: وهو الذي لا نبات فيه. ثم رجَّح قائلًا: «والأوَّل أوْلى، وإن كان الآخر مرادًا أيضًا باللازم». ولم يذكر مستندًا. ٤٨٣٠٢- عن عبد الله بن عباس: أنّ نافع بن الأزرق قال له: أخبِرني عن قوله ﷿: <q>﴿فيذرها قاعا صفصفا﴾</q>. قال: القاع: الأملس. والصفصف: المستوي. قال: وهل تعرف العرب ذلك؟ قال: نعم، أما سمعت الشاعر وهو يقول: بِمَلْمُومَةٍ{2} شهباء{3} لو قذفوا بها شَمارِيخ{4} مِن رَضْوى{5} إذَنْ عاد صفصفا؟{6}. (١٠/٢٤٠) ٤٨٣٠٣- عن مجاهد بن جبر -من طريق ابن أبي نَجِيح- في قوله: <q>﴿قاعا صفصفا﴾</q>، قال: مُسْتَوِيًا{7}. (١٠/٢٤٠) ٤٨٣٠٤- عن قتادة بن دعامة -من طريق معمر- في قوله: <q>﴿صفصفا﴾</q>، قال: القاع: الأرض. والصفصف: المستوية{8}. (١٠/٢٤٠) ٤٨٣٠٥- عن الضحاك بن مُزاحِم -من طريق جُوَيْبِر- قوله: <q>﴿فيذرها قاعا صفصفا﴾</q>، قال: القاع: الأرض المستوية. والصفصف: يقول: ليس فيها نبات{9}. (ز) ٤٨٣٠٦- قال مقاتل بن سليمان: <q>﴿فيذرها قاعا﴾</q> لا تراب فيها، <q>﴿صفصفا﴾</q> لا نبت فيها{10}. (ز) ٤٨٣٠٧- عن سفيان الثوري، في قوله: <q>﴿فيذرها قاعا صفصفا﴾</q>، قال: ترى الأرض كلها مستوية{11}. (ز) ٤٨٣٠٨- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿فيذرها قاعا صفصفا﴾</q>، قال: مستويًا؛ الصفصف: المستوي{12}. (ز) ٤٨٣٠٩- قال يحيى بن سلّام: <q>﴿فيذرها﴾</q> فيذر الأرض <q>﴿قاعا صفصفا﴾</q> القاع: الذي لا ثَرى عليه، وهي القَرْقَرة{13}. والصفصف: الذي ليس عليه نبات{14}. (ز) ",footnotes:1:أخرجه ابن جرير ١٦/١٦٣، وابن أبي حاتم -كما في تغليق التغليق ٤/٢٥٥، والإتقان ٢/٢٩-. وعزاه السيوطي إلى ابن المنذر.هي: الكتيبة المجتمعة، المضموم بعضها إلى بعض. اللسان (لمم).أي: كثيرة السلاح، سميت شهباء لما فيها مِن بياض السلاح والحديد. اللسان (شهب).الشماريخ: رؤوس الجبال. اللسان (شمرخ).رَضْوى: جبل بالمدينة. وقيل: بين مكة والمدينة. معجم البلدان ٣/٥١.أخرجه الطستي -كما في الإتقان ٢/٧١-.أخرجه إسحاق البستي في تفسيره ص٢٧٣ من طريق ابن جريج، وابن جرير ١٦/١٦٣. وعلَّقه يحيى بن سلّام ١/٢٧٩. وعزاه السيوطي إلى عبد بن حميد.أخرجه عبد الرزاق ٢/٢٠ من طريق معمر. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه إسحاق البستي في تفسيره ص٢٧٣.تفسير مقاتل بن سليمان ٣/٤١.تفسير الثوري ص١٩٦.أخرجه ابن جرير ١٦/١٦٣.القَرْقَر: الأرض المستوية. النهاية (قرقر).تفسير يحيى بن سلّام ١/٢٧٩.
20,107," <q>﴿لَّا تَرَىٰ فِیهَا عِوَجࣰا وَلَاۤ أَمۡتࣰا ۝١٠٧﴾</q> - تفسير ٤٨٣١٠- عن عبد الله بن عباس -من طريق علي- في قوله: <q>﴿لا ترى فيها عوجا﴾</q> قال: واديًا، <q>﴿ولا أمتا﴾</q> قال: رابيةً{1}{2}. (١٠/٢٣٩) ٤٨٣١١- عن عبد الله بن عباس -من طريق العوفي- في قوله: <q>﴿لا ترى فيها عوجا﴾</q> قال: ميلًا، <q>﴿ولا أمتا﴾</q> قال: الأمت: الأثر مثل الشِراك{3}. (١٠/٢٤٠) ٤٨٣١٢- عن عبد الله بن عباس: أنّ نافع بن الأزرق قال له: أخبِرني عن قوله: <q>﴿لا ترى فيها عوجا ولا أمتا﴾</q>، ما الأَمْت؟ قال: الشيءُ الشاخص مِن الأرض، قال فيه كعب بن زهير: فأبصرت لمحةً مِن رأسِ عِكْرِشَةٍ{4} في كافِر{5} ما به أمْتٌ ولا شَرَفُ{6}. (١٠/٢٤١) ٤٨٣١٣- عن عكرمة، أنّه سُئِل عن قوله: <q>﴿لا ترى فيها عوجا ولا أمتا﴾</q>. قال: كان ابنُ عباس يقول: هي الأرض الملساء التي ليس فيها رابية مرتفعة ولا انخفاض{7}. (١٠/٢٤٠) ٤٨٣١٤- عن مجاهد بن جبر -من طريق ابن أبي نَجِيح- في قوله: <q>﴿لا ترى فيها عوجا﴾</q> قال: خَفْضًا، <q>﴿ولا أمتا﴾</q> قال: ارتفاعًا{8}. (١٠/٢٤٠) ٤٨٣١٥- عن الضحاك بن مزاحم، في الآية، قال: العِوَج: الارتفاع. والأَمْت: الهبوط{9}. (١٠/٢٤١) ٤٨٣١٦- عن الضحاك بن مزاحم -من طريق جويبر- قوله: <q>﴿لا ترى فيها عوجا﴾</q> قال: العوج: يقول: لا ترى فيها وادِيًا، <q>﴿ولا أمتا﴾</q> الأمت: النَّبْكُ{10}. (ز) ٤٨٣١٧- عن عكرمة مولى ابن عباس في الآية قال: يعني: بالأمت حُفَرًا{11}. (١٠/٢٤١) ٤٨٣١٨- قال الحسن البصري: غمار البحور ورؤوس الجبال سواء{12}. (ز) ٤٨٣١٩- قال الحسن البصري: العِوَج: ما انخفض مِن الأرض. والأَمْت: ما نَشَزَ مِن الرَّوابي{13}. (ز) ٤٨٣٢٠- عن قتادة بن دعامة -من طريق معمر- في قوله: <q>﴿لا ترى فيها عوجا﴾</q> قال: صَدْعًا، <q>﴿ولا أمتا﴾</q> قال: أكَمَة{14}. (١٠/٢٤٠) ٤٨٣٢١- عن قتادة بن دعامة -من طريق سعيد- قال: الأَمْت: الحدَب{15}. (ز) ٤٨٣٢٢- قال مقاتل بن سليمان: <q>﴿لا ترى فيها عوجا﴾</q> يعني: خفضًا، <q>﴿ولا أمتا﴾</q> يعني: رفعًا{16}. (ز) ٤٨٣٢٣- عن سفيان الثوري، في قوله: <q>﴿لا ترى فيها عوجا ولا أمتا﴾</q>، قال: العوج: الشق. والأمت: المكان المرتفع{17}. (ز) ٤٨٣٢٤- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿لا ترى فيها عوجا ولا أمتا﴾</q>، قال: لا تَعادِيَ{18}، الأمت: التَّعادي{19}٤٣١٠. (ز) ٤٣١٠ أفادت الآثارُ اختلاف المفسرين في معنى: «العِوَجِ» و«الأمْتِ» على أقوال: الأول: عوجًا: واديًا. ولا أمتًا: رابية. الثاني: عوجًا: صدعًا. ولا أمتا: أكَمة. الثالث: عوجًا: ميلًا. ولا أمتًا: أثرًا. الرابع: الأمت: المَحاني والحِداب. ورجَّح ابنُ جرير (١٦/١٦٦) مستندًا إلى لغة العرب، ودلالة العقل أنّ معنى <q>﴿عوجًا﴾</q>: ميلًا، وأن معنى <q>﴿ولا أمتا﴾</q>: ولا ارتفاع ولا انخفاض؛ لأن الانخفاض لم يكن إلا عن ارتفاع. وأن تأويل الكلام: لا ترى فيها ميلًا عن الاستواء، ولا ارتفاعًا، ولا انخفاضًا، ولكنها مستوية ملساء. ووافقه ابنُ عطية (٦/١٣٣)، ولم يذكر مستندًا. ",footnotes:1:رابِيَة: هي كل ما ارتفعَ من الأرض. اللسان (ربا).أخرجه ابن جرير ١٦/١٦٤، وابن أبي حاتم -كما في تغليق التغليق ٤/٢٥٥، والإتقان ٢/٢٩-. وأخرج يحيى بن سلّام ١/٢٨٠ شطره الأول من طريق أبي حازم. وعزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ١٦/١٦٦. وعزاه السيوطي إلى ابن أبي حاتم.عِكْرِشَة: أنثى الأرنب. النهاية (عكرش).كل شيء غَطّى شيئًا؛ يجوز أن يكون الظلام، وأن يكون مكانًا. لسان العرب (كفر).عزاه السيوطي إلى ابن الأنباري في الوقف.عزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم. وأخرجه ابن جرير ١٦/١٦٤ بلفظ: هي الأرض البيضاء -أو قال: الملساء- التي ليس فيها لبِنة مرتفعة.أخرجه ابن جرير ١٦/١٦٥. وعلَّقه يحيى بن سلّام ١/٢٨٠. وعزاه السيوطي إلى عبد بن حميد.عزاه السيوطي إلى عبد بن حميد، وابن أبي حاتم.أخرجه إسحاق البستي في تفسيره ص٢٧٤. والنبكة -محركة وتسكن-: أكمة محددة الرأس، وربما كانت حمراء، أو أرض فيها صعود وهبوط، أو التل الصغير. ينظر: القاموس المحيط (نبك).عزاه السيوطي إلى عبد بن حميد.علَّقه يحيى بن سلّام ١/٢٨٠.تفسير البغوي ٥/٢٩٥.تفسير عبد الرزاق ٢/١٩، وابن جرير ١٦/١٦٥. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه ابن جرير ١٦/١٦٦. وعلَّقه يحيى بن سلّام ١/٢٨٠.تفسير مقاتل بن سليمان ٣/٤١.تفسير الثوري ص١٩٦.تعادي: التعادي: أمكنة غير مستوية. لسان العرب (عدا).أخرجه ابن جرير ١٦/١٦٥.
20,108," <q>﴿یَوۡمَىِٕذࣲ یَتَّبِعُونَ ٱلدَّاعِیَ﴾</q> - تفسير ٤٨٣٢٥- قال يحيى بن سلّام: قوله: <q>﴿يومئذ يتبعون الداعي﴾</q> يوم تكون الأرض والجبال كذلك، <q>﴿يومئذ يتبعون الداعي﴾</q> صاحب الصُّور، يُسرِعون إليه حين يخرجون مِن قبورهم إلى بيت المقدس.= (ز) ٤٨٣٢٦- قال عبد الله بن مسعود: يقوم ملَك بين السماء والأرض بالصور، فينفخ فيه.= (ز) ٤٨٣٢٧- وقال قتادة: مِن الصخرة مِن بيت المقدس{1}. (ز) ٤٨٣٢٨- عن محمد بن كعب القرظي، قال: يحشر اللهُ الناسَ يوم القيامة في ظُلْمَة؛ تطوى السماء، وتتناثر النجوم، وتذهب الشمس والقمر، ويُنادي منادٍ، فيسمع الناس الصوتَ يَؤُمُّونَه، فذلك قول الله: <q>﴿يومئذ يتبعون الداعي لا عوج له﴾</q>{2}. (١٠/٢٤١) ٤٨٣٢٩- قال مقاتل بن سليمان: <q>﴿يومئذ يتبعون الداعي﴾</q>، يعني: صوت الملَك الذى هو قائم على صخرة بيت المقدس، وهو إسرافيل ﵇ حين ينفخ في الصور، يعني: في القرن{3}. (ز) <q>﴿لَا عِوَجَ لَهُۥۖ﴾</q> - تفسير ٤٨٣٣٠- عن مجاهد بن جبر -من طريق عاصم- قوله: <q>﴿لا عوج له﴾</q>: لا مَعْدِل عنه، لا يتعوجون -أي: عن إجابته- يمينًا ولا شمالًا{4}. (ز) ٤٨٣٣١- عن أبي صالح باذام، في قوله: <q>﴿يتبعون الداعي لا عوج له﴾</q>، قال: لا عِوَج عنه{2}. (١٠/٢٤١) ٤٨٣٣٢- عن قتادة بن دعامة، في قوله: <q>﴿لا عوج له﴾</q>: لا يميلون عنه{2}. (١٠/٢٤١) ٤٨٣٣٣- قال مقاتل بن سليمان: لا يزيغون ولا يروغون عنه يمينًا ولا شمالًا، يعني: لا يميلون عنه، كقوله سبحانه: <q>﴿تبغونها عوجا﴾</q> [آل عمران:٩٩]، يعني: زيغًا، وهو الميل، <q>﴿لا عوج له﴾</q> يعني: عنه، يستقيمون قِبَل الصوت، نظيرها: <q>﴿ولم يجعل له عوجا﴾</q> [الكهف:١]{3}. (ز) ٤٨٣٣٤- عن سفيان الثوري، في قوله: <q>﴿الداعي لا عوج له﴾</q>، قال: لا عِوَج عنه{8}. (ز) <q>﴿وَخَشَعَتِ ٱلۡأَصۡوَاتُ لِلرَّحۡمَـٰنِ﴾</q> - تفسير ٤٨٣٣٥- عن عبد الله بن عباس -من طريق علي- قوله: <q>﴿وخشعت الأصوات للرحمن﴾</q>، يقول: سَكَنَتْ{9}. (١٠/٢٤٢) ٤٨٣٣٦- قال يحيى بن سلّام: قوله: <q>﴿وخشعت الأصوات للرحمن﴾</q> يعني: سكنت؛ لقوله: <q>﴿لا يتكلمون﴾</q> [النبأ:٣٨]{1}. (ز) <q>﴿فَلَا تَسۡمَعُ إِلَّا هَمۡسࣰا ۝١٠٨﴾</q> - قراءات ٤٨٣٣٧- عن قتادة، قال: في قراءة أُبَيّ بن كعب: (لا يَنطِقُونَ إلّا هَمْسًا){11}. (ز) <q>﴿فَلَا تَسۡمَعُ إِلَّا هَمۡسࣰا ۝١٠٨﴾</q> - تفسير الآية ٤٨٣٣٨- عن عبد الله بن عباس -من طريق علي- في قوله: <q>﴿لا تسمع إلا همسا﴾</q>، قال: الصوت الخفِيّ{12}. (١٠/٢٤٢) ٤٨٣٣٩- عن عبد الله بن عباس -من طُرُق- في قوله: <q>﴿فلا تسمع إلا همسا﴾</q>، قال: صَوْتُ وطْءِ الأقدام{13}. (١٠/٢٤٢) ٤٨٣٤٠- عن عبد الله بن عباس -من طريق سعيد بن جبير- قال: تحريك الشِّفاه مِن غير نطق{14}. (ز) ٤٨٣٤١- عن سعيد بن جبير -من طريق عطاء بن السائب- في قوله: <q>﴿فلا تسمع إلا همسا﴾</q>، قال: وطْء الأقدام{15}. (١٠/٢٤٢) ٤٨٣٤٢- عن سعيد بن جبير، في قوله: <q>﴿إلا همسا﴾</q>، قال: سِرُّ الحديث، وصوت الأقدام{2}٤٣١١. (١٠/٢٤٣) ٤٣١١ ذكر ابنُ كثير (٩/٣٦٨) قولين في معنى: <q>﴿فَلا تَسْمَعُ إلا هَمْسًا﴾</q>: الأول: وطء الأقدام. والثاني: الصوت الخفي. ثم علَّق على قول سعيد بن جبير بقوله: «فقد جمع سعيد كلا القولين، وهو محتَمَل؛ أمّا وطء الأقدام فالمراد: سعي الناس إلى المحشر، وهو مشْيُهم في سكون وخضوع. وأما الكلام الخفي فقد يكون في حال دون حال، فقد قال تعالى: <q>﴿يَوْمَ يَأْتِ لا تَكَلَّمُ نَفْسٌ إلا بِإذْنِهِ فَمِنهُمْ شَقِيٌّ وسَعِيدٌ﴾</q> [هود:١٠٥]». ٤٨٣٤٣- عن مجاهد بن جبر -من طريق ابن جريج- في قوله: <q>﴿فلا تسمع إلا همسا﴾</q>، قال: هو خفض الصوت بالكلام؛ يُحَرِّك لسانه وشفتيه، ولا يُسْمِع{17}. (١٠/٢٤٣) ٤٨٣٤٤- عن مجاهد بن جبر -من طريق ابن أبي نَجِيح- في قوله: <q>﴿وخشعت الأصوات للرحمن فلا تسمع إلا همسا﴾</q>، قال: حِسُّ الأقدام{18}. (ز) ٤٨٣٤٥- عن الضحاك بن مزاحم، في قوله: <q>﴿فلا تسمع إلا همسا﴾</q>، قال: أصوات أقدامهم{19}. (١٠/٢٤٢) ٤٨٣٤٦- عن الضَّحّاك بن مُزاحِم -من طريق عبيد- في قوله: <q>﴿فلا تسمع إلا همسا﴾</q>، قال: الكلام الخفيُّ{20}. (ز) ٤٨٣٤٧- عن عكرمة مولى ابن عباس -من طريق عبد الرحمن بن الأصبهاني- في قوله: <q>﴿فلا تسمع إلا همسا﴾</q>، قال: وطْء الأقدام{21}. (١٠/٢٤٢) ٤٨٣٤٨- عن حُصَين بن عبد الرحمن، قال: كنت قاعدًا مع الشعبي، فمَرَّتْ علينا إبلٌ قد كان عليها جِصٌّ{22}، فطَرَحَتْهُ، فسمعت صوت أخفافها، فقال: هذا الهمس{23}. (١٠/٢٤٢) ٤٨٣٤٩- عن الحسن البصري -من طرق- في قوله: <q>﴿فلا تسمع إلا همسا﴾</q>، قال: وطء الأقدام{24}. (١٠/٢٤٢) ٤٨٣٥٠- عن أبي عمرو الأوزاعي، أنه سمع بلال بن سعد قال: يفزع يوم القيامة فزعة فيزولون، قال الأوزاعي: وقرأ: <q>﴿وخشعت الأصوات للرحمن فلا تسمع إلا همسا﴾</q>، قال: همس الأقدام{25}. (ز) ٤٨٣٥١- عن محمد بن السائب الكلبي -من طريق خلف بن خليفة- قال: هو ذاك مِن الكلام الخَفِيِّ{26}. (ز) ٤٨٣٥٢- قال مقاتل بن سليمان: <q>﴿وخشعت الأصوات للرحمن فلا تسمع إلا همسا﴾</q> إلا خَفِيًّا من الأصوات؛ مثل: وطْءِ الأقدام{3}. (ز) ٤٨٣٥٣- عن سفيان الثوري، في قوله: <q>﴿فلا تسمع إلا همسا﴾</q>، قال: وطء الأقدام{28}. (ز) ٤٨٣٥٤- عن مالك بن أنس -من طريق ابن وهب- في قول الله: <q>﴿فلا تسمع إلا همسا﴾</q>، قال: وطء الأقدام{29}. (ز) ٤٨٣٥٥- قال عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- قوله: <q>﴿فلا تسمع إلا همسا﴾</q>، يقول: لا تسمع إلا مشيًا. قال: المشي: الهمس؛ وطء الأقدام{30}. (ز) ",footnotes:1:تفسير يحيى بن سلّام ١/٢٨٠.عزاه السيوطي إلى ابن أبي حاتم.تفسير مقاتل بن سليمان ٣/٤٢.أخرجه يحيى بن سلّام ١/٢٨٠.عزاه السيوطي إلى ابن أبي حاتم.عزاه السيوطي إلى ابن أبي حاتم.تفسير مقاتل بن سليمان ٣/٤٢.تفسير الثوري ص١٩٦.أخرجه ابن جرير ١٦/١٦٧، وابن أبي حاتم -كما في الإتقان ٢/٢٩-. وعزاه السيوطي إلى ابن المنذر.تفسير يحيى بن سلّام ١/٢٨٠.أخرجه يحيى بن سلّام ١/٢٨٠. وهي قراءة شاذة. انظر: الجامع لأحكام القرآن ١٤/١٤٠، والبحر المحيط ٦/٢٦٠.أخرجه ابن جرير ١٦/١٦٧. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.أخرجه يحيى بن سلّام ١/٢٨٠ من طريق أبي العالية، وابن جرير ١٦/١٦٨ من طريق علي والعوفي، وابن أبي حاتم -كما في الإتقان ٢/٢٩-. وعزاه السيوطي إلى ابن المنذر.تفسير البغوي ٥/٢٩٥.أخرجه ابن أبي الدنيا في كتاب الأهوال ٦/٢٠٨ (١٨٠). وعزاه السيوطي إلى عبد بن حميد.عزاه السيوطي إلى ابن أبي حاتم.أخرجه ابن جرير ١٦/١٦٩، وبنحوه من طريق عبد الله بن كثير، كما أخرجه من طريق ابن أبي نجيح بلفظ: تهافتا. أوقال: تخافت الكلام. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر. وجاء في تفسير إسحاق البستي ص٢٧٤ من طريق ابن جريج بلفظ: كلام الإنسان لا يحرك شفتيه.أخرجه أبو جعفر الرملي في جزئه ص ٥٤ (تفسير مسلم الزنجي). وعلقه البخاري ٤/١٧٦٣. وأخرجه إسحاق البستي في تفسيره ص٢٧٥ من طريق سفيان عن رجل، بلفظ: نقل الأقدام.أخرجه إسحاق البستي في تفسيره ص٢٧٦ من طريق جويبر بلفظ: مِن الناس من يقول: وقع القدام، ومنهم من يقول: الكلام الخفي. وعزاه السيوطي إلى عبد بن حميد.أخرجه إسحاق البستي في تفسيره ص٢٧٥.أخرجه ابن جرير ١٦/١٦٩. وعزاه السيوطي إلى عبد بن حميد.الجِصُّ والجَصُّ: الجِير، ويعرف حديثًا بالجِبْس. النهاية (جير)، واللسان (جصص)، والمعجم الوسيط (جبس).عزاه السيوطي إلى عبد بن حميد.أخرجه يحيى بن سلّام ١/٢٨٠ من طريق الحسن بن دينار، وابن أبي الدنيا في كتاب الأهوال -موسوعة ابن أبي الدنيا ٦/٢٠٨-٢٠٩ (١٨١)- من طريق منصور بن زاذان بلفظ: نقل أقدامهم، وابن جرير ١٦/١٦٩ من طريق حميد بلفظ: همس الأقدام، ومن طريق قتادة بلفظ: وقع أقدام القوم. وعزاه السيوطي إلى عبد بن حميد.أخرجه ابن أبي الدنيا في كتاب الأهوال - موسوعة ابن أبي الدنيا ٦/١٩٧ (١٤٦).أخرجه سعيد بن منصور في سننه - التفسير ٦/٢٧١ (١٤٣١) بلفظ: الكلام الخفي وذاك، وابن أبي الدنيا في كتاب الأهوال -موسوعة ابن أبي الدنيا ٦/٢٠٩ (١٨٢)- بلفظ: هو ذاك من الكلام الخفي.تفسير مقاتل بن سليمان ٣/٤٢.تفسير سفيان الثوري ص١٩٦، وأخرجه عبد الرزاق ٢/١٩ بلفظ: صوت الأقدام.أخرجه عبد الله بن وهب في الجامع ٢/١٣٤ (٢٦٦).أخرجه ابن جرير ١٦/١٦٩.
20,109," <q>﴿یَوۡمَىِٕذࣲ لَّا تَنفَعُ ٱلشَّفَـٰعَةُ إِلَّا مَنۡ أَذِنَ لَهُ ٱلرَّحۡمَـٰنُ﴾</q> - تفسير ٤٨٣٥٦- قال مقاتل بن سليمان: <q>﴿يومئذ لا تنفع الشفاعة﴾</q> يعني: شفاعة الملائكة <q>﴿إلا من أذن له الرحمن﴾</q> أن يُشْفَع له{1}. (ز) ٤٨٣٥٧- قال يحيى بن سلّام: إنّ الكُفّار ليست لهم شفاعة، لا يُشفع لهم، كقوله: <q>﴿ولا يشفعون إلا لمن ارتضى﴾</q> [الأنبياء:٢٨]{2}. (ز) <q>﴿وَرَضِیَ لَهُۥ قَوۡلࣰا ۝١٠٩﴾</q> - تفسير ٤٨٣٥٨- قال عبد الله بن عباس: يعني: قال: لا إله إلا الله{3}. (ز) ٤٨٣٥٩- قال مقاتل بن سليمان: <q>﴿ورضي له قولا﴾</q>، يعني: التوحيد{1}. (ز) ٤٨٣٦٠- قال يحيى بن سلّام: قوله: <q>﴿يومئذ لا تنفع الشفاعة إلا من أذن له الرحمن ورضي له قولا﴾</q> التوحيد ... كقوله: <q>﴿يوم يقوم الروح﴾</q> روح كل شيء في جسده، <q>﴿والملائكة صفا لا يتكلمون إلا من أذن له الرحمن وقال صوابا﴾</q> [النبأ:٣٨] التوحيد{2}. (ز) ",footnotes:1:تفسير مقاتل بن سليمان ٣/٤٢.تفسير يحيى بن سلّام ١/٢٨١.تفسير البغوي ٥/٢٩٦.تفسير مقاتل بن سليمان ٣/٤٢.تفسير يحيى بن سلّام ١/٢٨١.
20,110," <q>﴿یَعۡلَمُ مَا بَیۡنَ أَیۡدِیهِمۡ وَمَا خَلۡفَهُمۡ﴾</q> - تفسير ٤٨٣٦١- عن قتادة بن دعامة -من طريق سعيد- <q>﴿يعلم ما بين أيديهم﴾</q> يقول: يعلم ما بين أيديهم من أمر الساعة، <q>﴿وما خلفهم﴾</q> مِن أمر الدنيا{1}٤٣١٢. (ز) ٤٣١٢ لم يذكر ابنُ جرير (١٦/١٧٠) في معنى: <q>﴿يَعْلَمُ ما بَيْنَ أيْدِيهِمْ وما خَلْفَهُمْ﴾</q> سوى قول قتادة. ٤٨٣٦٢- قال مقاتل بن سليمان: <q>﴿يعلم﴾</q> الله ﷿ <q>﴿ما بين أيديهم وما خلفهم﴾</q> يقول: ما كان قبل أن يخلق الملائكة، وما كان بعد خلقهم{2}. (ز) ٤٨٣٦٣- قال يحيى بن سلّام: قوله: <q>﴿يعلم ما بين أيديهم﴾</q> مِن أمر الآخرة، <q>﴿وما خلفهم﴾</q> مِن أمر الدنيا، أي: إذا صاروا في الآخرة{3}. (ز) <q>﴿وَلَا یُحِیطُونَ بِهِۦ عِلۡمࣰا ۝١١٠﴾</q> - تفسير ٤٨٣٦٤- قال مقاتل بن سليمان: <q>﴿ولا يحيطون به علما﴾</q>، يعني: بالله ﷿ علمًا، هو أعظم من ذلك{2}٤٣١٣. (ز) ٤٣١٣ ذكر ابنُ القيم (٢/١٨٨) قولين لمرجع الضمير في <q>﴿به﴾</q>: الأول: هو الله تعالى، أي: ولا يحيطون بالله علمًا. والثاني: هو ما بين أيديهم وما خلفهم. ووجَّه كلا القولين، فقال: «فعلى الأول: يرجع إلى العالم، وعلى الثاني: يرجع إلى المعلوم، وهذا القول يستلزم الأول مِن غير عكس؛ لأنهم إذا لم يحيطوا ببعض معلوماته المتعلقة بهم فأن لا يحيطوا علمًا به سبحانه أوْلى». ورجَّح ابنُ تيمية (٤/٣٣٨) -ولم يذكر مستندًا- أن الضمير عائد إلى <q>﴿ما بَيْنَ أيْدِيهِمْ وما خَلْفَهُمْ﴾</q>. ثم بيَّن استلزامه للقول الأول بنحو ما ذكر ابنُ القيم. ٤٨٣٦٥- قال يحيى بن سلّام: <q>﴿ولا يحيطون به علما﴾</q>، ويعلم ما لا يحيطون به علمًا. تبع للكلام الأول. أي: ويعلم ما لا يحيطون به علمًا ما لا يعلمون{3}. (ز) ",footnotes:1:أخرجه ابن جرير ١٦/١٧٠. وعلَّقه يحيى بن سلّام ١/٢٨١.تفسير مقاتل بن سليمان ٣/٤٢.تفسير يحيى بن سلّام ١/٢٨١.تفسير مقاتل بن سليمان ٣/٤٢.تفسير يحيى بن سلّام ١/٢٨١.
20,111," <q>﴿وَعَنَتِ ٱلۡوُجُوهُ لِلۡحَیِّ ٱلۡقَیُّومِۖ﴾</q>{1} - تفسير ٤٨٣٦٦- عن عبد الله بن عباس -من طريق علي- في قوله: <q>﴿وعنت الوجوه﴾</q>، قال: ذَلَّت{2}. (١٠/٢٤٣) ٤٨٣٦٧- عن عبد الله بن عباس -من طريق العوفي- قوله: <q>﴿وعنت الوجوه للحي القيوم﴾</q>: يعني: استسلمَتْ إلَيَّ{3}. (ز) ٤٨٣٦٨- عن عبد الله بن عباس: أنّ نافع بن الأزرق قال له: أخبِرني عن قوله ﷿: <q>﴿وعنت الوجوه للحي القيوم﴾</q>. قال: استسلَمَتْ وخضعَتْ يوم القيامة. قال: وهل تعرف العرب ذلك؟ قال: نعم، أما سمعت الشاعر وهو يقول: ليَبْكِ عليكَ كلُ عانٍ بِكُرْبَةٍ وآلُ قُصَيٍّ مِن مُقِلٍّ وذي وفْرِ؟{4}. (١٠/٢٤٤) ٤٨٣٦٩- عن عبد الله بن عباس، في قوله: <q>﴿وعنت الوجوه﴾</q>، قال: الركوع، والسجود{5}. (١٠/٢٤٤) ٤٨٣٧٠- عن أبي العالية الرياحي، <q>﴿وعنت الوجوه﴾</q>، قال: خَضَعَتْ{6}. (١٠/٢٤٣) ٤٨٣٧١- عن طَلْق بن حبيب -من طريق سليمان التيمي، وعمرو بن مُرَّة- في قوله: <q>﴿وعنت الوجوه للحي القيوم﴾</q>، قال: هو وضْعُك جبهتَك وكفيك وركبتيك وأطرافَ قدميك في السجود{7}٤٣١٤. (١٠/٢٤٤) ٤٣١٤ وجَّه ابنُ عطية (٦/١٣٥) قول طلق بن حبيب قائلًا: «إن كان رَوى هذا أنّ للناس يوم القيامة سجودًا، وجعل هذه الآية إخبارًا عنه؛ فقوله مستقيم، وإن كان أراد سجود الدنيا فقد أفسد المعنى». ٤٨٣٧٢- عن مجاهد بن جبر -من طريق ابن أبي نَجِيح- في قوله: <q>﴿وعنت الوجوه﴾</q>، قال: خَشَعَت{8}. (١٠/٢٤٣) ٤٨٣٧٣- عن مجاهد بن جبر، <q>﴿وعنت الوجوه﴾</q>، قال: خَضَعَتْ{9}. (ز) ٤٨٣٧٤- عن قتادة بن دعامة -من طريق مَعْمَر- في قوله: <q>﴿وعنت الوجوه﴾</q>، قال: ذَلَّت الوجوه{10}. (١٠/٢٤٣) ٤٨٣٧٥- عن قتادة بن دعامة -من طريق سعيد- <q>﴿وعنت الوجوه﴾</q>، قال: ذَلَّتْ{11}. (ز) ٤٨٣٧٦- قال مقاتل بن سليمان: <q>﴿وعنت الوجوه﴾</q> يعني: استسلمت الوجوه <q>﴿للحي﴾</q> الذى لا يموت، <q>﴿القيوم﴾</q> يعني: القائم على كل شيء{12}. (ز) ٤٨٣٧٧- عن سفيان الثوري، في قوله: <q>﴿وعنت الوجوه﴾</q>، قال: خَشَعَتْ وذَلَّتْ{13}. (ز) ٤٨٣٧٨- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿وعنت الوجوه﴾</q>، قال: اسْتَأْسَرَت؛ صاروا أسارى كلهم [له. قال: والعاني: الأسير]{14}. (١٠/٢٤٣) <q>﴿وَقَدۡ خَابَ مَنۡ حَمَلَ ظُلۡمࣰا ۝١١١﴾</q> - تفسير ٤٨٣٧٩- قال عبد الله بن عباس: خَسِر مَن أشرك بالله، والظُّلْم هو الشرك{15}. (ز) ٤٨٣٨٠- عن قتادة بن دعامة -من طريق مَعْمَر- في قول: <q>﴿وقد خاب من حمل ظلما﴾</q>، قال: شِرْكًا{16}. (١٠/٢٤٤) ٤٨٣٨١- قال مقاتل بن سليمان: <q>﴿وقد خاب من حمل ظلما﴾</q>، يقول: وقد خسِر مَن حمل شِرْكًا يومَ القيامة على ظهره{12}. (ز) ٤٨٣٨٢- عن عبد الملك ابن جريج، في قوله: <q>﴿وقد خاب من حمل ظلما﴾</q>، قال: شِرْكًا{18}. (١٠/٢٤٤) ٤٨٣٨٣- عن سفيان الثوري، في قوله: <q>﴿وقد خاب من حمل ظلما﴾</q>، قال: الظُّلْم: الشِّرْك{13}. (ز) ٤٨٣٨٤- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿وقد خاب من حمل ظلما﴾</q>، قال: مَن حَمَل شِرْكًا، الظلم هاهنا: الشرك{20}. (ز) ٤٨٣٨٥- قال يحيى بن سلّام: قوله: <q>﴿وقد خاب من حمل ظلما﴾</q> مَن حمل شِرْكًا{21}. (ز) ",footnotes:1:تقدم تفسير <q>﴿الحي القيوم﴾</q> في سورة آل عمران [٢].أخرجه ابن جرير ١٦/١٧٢، وابن أبي حاتم -كما في الإتقان ٢/٢٩-. وعزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ١٦/١٧٣.أخرجه الطستي -كما في الإتقان ٢/٩٣-.عزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.عزاه السيوطي إلى عبد بن حميد.أخرجه ابن أبي شيبة ١/٢٦١، وابن جرير ١٦/١٧٣-١٧٤. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.تفسير مجاهد ص٤٣٠، وأخرجه ابن جرير ١٦/١٧٣. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.أخرجه ابن المنذر -كما في الفتح ٥/٣٩٤-.أخرجه عبد الرزاق ٢/١٩، وابن جرير ١٦/١٧٣، كما أخرجه يحيى بن سلّام ١/٢٨١، وابن أبي الدنيا في كتاب الأهوال -موسوعة ابن أبي الدنيا ٦/٢٠٩ (١٨٣)-، وابن جرير ١٦/١٧٣ من طريق سعيد. وعزاه السيوطي إلى عبد بن حميد.أخرجه ابن أبي الدنيا في كتاب الأهوال -موسوعة ابن أبي الدنيا ٦/٢٠٩ (١٨٣)-.تفسير مقاتل بن سليمان ٣/٤٢.أخرجه الثوري في تفسيره ص١٩٦.أخرجه ابن جرير ١٦/١٧٤.تفسير البغوي ٥/٢٩٦.أخرجه عبد الرزاق ٢/١٩، وابن جرير ١٦/١٧٥. وعزاه السيوطي إلى عبد بن حميد.تفسير مقاتل بن سليمان ٣/٤٢.عزاه السيوطي إلى ابن المنذر.أخرجه الثوري في تفسيره ص١٩٦.أخرجه ابن جرير ١٦/١٧٥.تفسير يحيى بن سلّام ١/٢٨١.
20,112," <q>﴿وَمَن یَعۡمَلۡ مِنَ ٱلصَّـٰلِحَـٰتِ وَهُوَ مُؤۡمِنࣱ﴾</q> - تفسير ٤٨٣٨٦- عن قتادة بن دعامة -من طريق مَعْمَر- قوله: <q>﴿ومن يعمل من الصالحات وهو مؤمن﴾</q>: وإنما يقبل الله مِن العمل ما كان في إيمان{1}. (ز) ٤٨٣٨٧- قال مقاتل بن سليمان: <q>﴿ومن يعمل من الصالحات وهو مؤمن﴾</q> مُصَدِّق بتوحيد الله ﷿{2}. (ز) ٤٨٣٨٨- عن عبد الملك ابن جريج -من طريق حجّاج- قوله: <q>﴿ومن يعمل من الصالحات وهو مؤمن﴾</q>، قال: زعموا أنها الفرائض{3}. (ز) ٤٨٣٨٩- قال يحيى بن سلّام: قوله: <q>﴿ومن يعمل من الصالحات وهو مؤمن فلا يخاف ظلما ولا هضما﴾</q> لا يجزى بالعمل الصالح في الآخرة إلا المؤمن، ويجزى به الكافر في الدنيا{4}. (ز) <q>﴿فَلَا یَخَافُ ظُلۡمࣰا وَلَا هَضۡمࣰا ۝١١٢﴾</q> - تفسير ٤٨٣٩٠- عن عبد الله بن عباس -من طريق علي- في قوله: <q>﴿فلا يخاف ظلما ولا هضما﴾</q>، قال: لا يخاف أن يُظلَم فيُزاد في سيئاته، ولا يُهضَم مِن حسناته{5}. (١٠/٢٤٤) ٤٨٣٩١- عن عبد الله بن عباس -من طريق العوفي- قوله: <q>﴿ومن يعمل من الصالحات وهو مؤمن فلا يخاف ظلما ولا هضما﴾</q>: يقول: أنا قاهِرٌ لكم اليومَ، آخُذُكم بقُوَّتي وشِدَّتي، وأنا قادِرٌ على قهركم وهضمكم، فإنّما بيني وبينكم العدل، وذلك يوم القيامة{3}. (ز) ٤٨٣٩٢- عن عبد الله بن عباس، في قوله: <q>﴿ولا هضما﴾</q>، قال: غصبًا{7}. (١٠/٢٤٥) ٤٨٣٩٣- عن أبي العالية الرِّياحِيِّ، في قول الله تعالى: <q>﴿فلا يخاف ظلما ولا هضما﴾</q>، قال: لا ينقص من ثواب حسناته شيئًا، ولا يحمل عليه ذنبُ مسيءٍ{8}. (ز) ٤٨٣٩٤- عن مجاهد بن جبر -من طريق أبي يحيى- في قوله: <q>﴿فلا يخاف ظلما﴾</q> قال: أن يُزاد عليه أكثر من ذنوبه، <q>﴿ولا هضما﴾</q> قال: أن يُنتقص مِن حسناته شيئًا{9}. (١٠/٢٤٥) ٤٨٣٩٥- عن الضحاك بن مُزاحِم -من طريق عُبيد بن سليمان- في قوله: <q>﴿فلا يخاف ظلما ولا هضما﴾</q>، قال: أما <q>﴿هضما﴾</q>: فهو أن يقهر الرجلُ الرجلَ بقوته، يقول الله: يومَ القيامة لا آخذكم بقُوَّتي وشِدَّتي، ولكن العدل بيني وبينكم، ولا ظُلْمَ عليكم{3}. (ز) ٤٨٣٩٦- عن الضحاك بن مُزاحِم -من طريق جُوَيْبِر- في قوله: <q>﴿لا يخاف ظلما ولا هضما﴾</q> قال: الهضم: لا يخاف أن يُنقَص مِن عمله الصالح شيء، <q>﴿ولا هضما﴾</q>: لا يخاف أن يُؤاخَذ بما لم يعمل{11}. (ز) ٤٨٣٩٧- عن الحسن البصري -من طريق ميمون بن سياه- في قول الله تعالى: <q>﴿فلا يخاف ظلما ولا هضما﴾</q>، قال: لا ينتقص الله مِن حسناته شيئًا، ولا يحمل عليه ذنب مسيء{12}. (ز) ٤٨٣٩٨- تفسير الحسن البصري، قال: <q>﴿فلا يخاف ظلما﴾</q> أن يُزاد عليه سيئاته{13}. (ز) ٤٨٣٩٩- عن قتادة بن دعامة -من طريق مَعْمَر- في قوله: <q>﴿فلا يخاف ظلما ولا هضما﴾</q>، قال: <q>﴿ظلما﴾</q> أن يزاد في سيئاته، <q>﴿ولا هضما﴾</q> قال: لا يُنقص مِن حسناته{14}. (١٠/٢٤٤) ٤٨٤٠٠- عن قتادة بن دعامة -من طريق سعيد- قوله: <q>﴿فلا يخاف ظلما ولا هضما﴾</q>: أي: لا يخاف أن يُحمَل عليه ذنبُ غيرِه، ولا يُهضَم مِن حسابه{15}. (ز) ٤٨٤٠١- عن حبيب بن أبي ثابت -من طريق مسعر- يقول في قوله: <q>﴿ولا هضما﴾</q>، قال: الهضم: الانتقاص{16}. (ز) ٤٨٤٠٢- قال مقاتل بن سليمان: <q>﴿فلا يخاف ظلما﴾</q> في الآخرة، يعني: أن تُظلَم حسناته كلها حتى لا يُجازى بحسناته كلها، <q>﴿ولا هضما﴾</q> يعني: ولا ينقص منها شيئًا. مثل قوله ﷿: <q>﴿فلا يخاف بخسا ولا رهقا﴾</q> [الجن:١٣]{2}. (ز) ٤٨٤٠٣- عن سفيان الثوري، في قوله: <q>﴿فلا يخاف ظلما ولا هضما﴾</q>، قال: الظلم: أن يُظلَم حقُّه، والهضم: أن يهضم بعض حقه{18}. (ز) ٤٨٤٠٤- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿فلا يخاف ظلما ولا هضما﴾</q>، قال: لا يخاف أن يظلم فلا يُجزى بعمله، ولا يخاف أن يُنتَقص من حقِّه فلا يُوَفّى عمله{16}. (ز) ٤٨٤٠٥- قال يحيى بن سلّام: <q>﴿ولا هضما﴾</q>: لا ينقص من حسناته{4}. (ز) ",footnotes:1:أخرجه ابن جرير ١٦/١٧٥.تفسير مقاتل بن سليمان ٣/٤٢.أخرجه ابن جرير ١٦/١٧٦.تفسير يحيى بن سلّام ١/٢٨٢.أخرجه ابن جرير ١٦/١٦٧، وابن أبي حاتم -كما في الإتقان ٢/٢٩-. وعزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ١٦/١٧٦.عزاه السيوطي إلى الفريابي، وعبد بن حميد، وابن أبي حاتم.تفسير الثعلبي ٦/٢٦١.أخرجه يحيى بن سلّام ١/٢٨٢ بنحوه. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.أخرجه ابن جرير ١٦/١٧٦.أخرجه إسحاق البستي في تفسيره ص٢٧٧.أخرجه ابن جرير ١٦/١٧٨.علَّقه يحيى بن سلّام ١/٢٨٢.أخرجه عبد الرزاق ٢/١٩، وابن جرير ١٦/١٧٧. وعزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ١٦/١٧٧. وعلَّقه يحيى بن سلّام ١/٢٨٢.أخرجه ابن جرير ١٦/١٧٧.تفسير مقاتل بن سليمان ٣/٤٢.تفسير الثوري ص١٩٧.أخرجه ابن جرير ١٦/١٧٧.تفسير يحيى بن سلّام ١/٢٨٢.
20,113," <q>﴿وَكَذَ ٰ⁠لِكَ أَنزَلۡنَـٰهُ قُرۡءَانًا عَرَبِیࣰّا وَصَرَّفۡنَا فِیهِ مِنَ ٱلۡوَعِیدِ﴾</q> - تفسير ٤٨٤٠٦- قال مقاتل بن سليمان: <q>﴿كذلك﴾</q> يعني: وهكذا <q>﴿أنزلناه قرآنا عربيا﴾</q> ليفقهوه، <q>﴿وصرفنا﴾</q> يعني: وصَنَّفنا <q>﴿فيه﴾</q> يعني: لَوَّنّا فيه، يعني: في القرآن <q>﴿من﴾</q> ألوان <q>﴿الوعيد﴾</q> للأُمَمِ الخالية في الدنيا مِن الحَصْب، والخَسْف، والغَرَق، والصَّيْحة{1}. (ز) ٤٨٤٠٧- قال يحيى بن سلّام: قوله: <q>﴿وكذلك أنزلناه قرآنا عربيا وصرفنا فيه من الوعيد﴾</q> مَن يعمل كذا فله كذا، فذكره في هذه السورة، ثم في سورة أخرى{2}. (ز) <q>﴿لَعَلَّهُمۡ یَتَّقُونَ أَوۡ یُحۡدِثُ لَهُمۡ ذِكۡرࣰا ۝١١٣﴾</q> - قراءات ٤٨٤٠٨- قال يحيى بن سلّام: وهي تُقْرَأ بالياء والتاء. فمَن قرأها بالياء يقول: أو يحدث لهم القرآن ذكرًا، أي: جِدًّا وورعًا في تفسير قتادة. ومَن قرأها بالتاء يقول: أو تُحدث لهم -يا محمدُ- ذِكْرًا{3}. (ز) <q>﴿لَعَلَّهُمۡ یَتَّقُونَ أَوۡ یُحۡدِثُ لَهُمۡ ذِكۡرࣰا ۝١١٣﴾</q> - تفسير الآية ٤٨٤٠٩- عن قتادة بن دعامة -من طريق سعيد- <q>﴿وكذلك أنزلناه قرآنا عربيا وصرفنا فيه من الوعيد لعلهم يتقون﴾</q>: ما حذروا به مِن أمر الله وعذابه ووقائعه بالأمم قبلهم، <q>﴿أو يحدث لهم﴾</q> أي: جِدًّا وورعًا{4}. (ز) (١٠/٢٤٥) ٤٨٤١٠- قال يحيى بن سلّام: تفسير السُّدِّيّ: <q>﴿لعلهم يتقون أو يحدث لهم ذكرا﴾</q>: لعلهم يتقون ويحدث لهم ذكرًا، يعني: القرون الأولى. والألف هاهنا صلة{2}. (ز) ٤٨٤١١- قال مقاتل بن سليمان: فهذا الوعيد لهم؛ <q>﴿لعلهم﴾</q> يعني: لكي <q>﴿يتقون﴾</q> يعني: لكي يُخْلِصوا التوحيد بوعيدنا في القرآن، <q>﴿أو يحدث لهم﴾</q> يعني: الوعيد <q>﴿ذكرا﴾</q> عظة فيخافون فيؤمنون{1}. (ز) ",footnotes:1:تفسير مقاتل بن سليمان ٣/٤٢.تفسير يحيى بن سلّام ١/٢٨٢.تفسير يحيى بن سلّام ١/٢٨٢. و<q>﴿أوْ يُحْدِثُ﴾</q> بالياء هي قراءة العشرة، وأما (أوْ تُحْدِثُ) بالتاء فشاذة، وتروى عن مجاهد. انظر: مختصر ابن خالويه ص٩٢.أخرجه بتمامه ابن جرير ١٦/١٧٩. وأخرج شطره الثاني من طريق معمر عبد الرزاق ٢/١٩، وابن جرير ١٦/١٧٩. وعلَّقه يحيى بن سلّام ١/٢٨٢. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.تفسير يحيى بن سلّام ١/٢٨٢.تفسير مقاتل بن سليمان ٣/٤٢.
