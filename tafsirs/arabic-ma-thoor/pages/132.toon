quran[9]{c,v,t}:
6,36," <q>﴿إِنَّمَا یَسۡتَجِیبُ ٱلَّذِینَ یَسۡمَعُونَۘ وَٱلۡمَوۡتَىٰ یَبۡعَثُهُمُ ٱللَّهُ ثُمَّ إِلَیۡهِ یُرۡجَعُونَ ۝٣٦﴾</q> - تفسير ٢٤٧٨٨- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿إنما يستجيب الذين يسمعون﴾</q> قال: المؤمنون للذِّكر، <q>﴿والموتى﴾</q> قال: الكفار حينَ يبعثُهم اللهُ مع الموتى{1}٢٢٥٩. (٦/٤٤) ٢٢٥٩ علَّق ابنُ عطية (٣/٣٥٦ بتصرف) على قول مجاهد وقتادة بقوله: «وقال مجاهد وقتادة: <q>﴿والمَوْتى﴾</q> يريد: الكفار، أي: هم بمثابة الموتى حين لا يرون هدًى، ولا يسمعون فيعون. وقرأت هذه الطائفة: <q>﴿يرجعون﴾</q> بياء، والواو على هذا عاطفة جملة كلام على جملة، <q>﴿والمَوْتى﴾</q> مبتدأ، و<q>﴿يَبْعَثُهُمُ اللَّهُ﴾</q> خبره، فكأنّ معنى الآية: إنّما يستجيب الذين يسمعون فيَعُون، والكفار سيبعثهم الله ويردهم إلى عقابه، فالآية على هذا متضمنة الوعيد للكفار، والعائد على الَّذِينَ هو الضمير في <q>﴿يَسْمَعُونَ﴾</q>». ٢٤٧٨٩- عن الحسن البصري -من طريق محمد بن جُحادة- في قوله: <q>﴿إنما يستجيب الذين يسمعون﴾</q> قال: المؤمنون، <q>﴿والموتى﴾</q> قال: الكفار{2}٢٢٦٠. (٦/٤٤) ٢٢٦٠ ذكر ابنُ عطية (٣/٣٥٦) أنّ البعث يحتمل معنيين، ثم ذكر قولًا للحسن مفاده أنّ المعنى: يبعثهم الله بأن يؤمنوا حين يوقفهم. ثم علَّق عليه بقوله: «فتجيء الاستعارة في هذا التأويل في الوجهين؛ في تسميتهم موتى، وفي تسمية إيمانهم وهدايتهم بعثًا، والواو على هذا مشركة في العامل عطفت المَوْتى على <q>﴿الَّذِينَ﴾</q>، <q>﴿ويَبْعَثُهُمُ اللَّهُ﴾</q> في موضع الحال، وكأن معنى الآية: إنما يستجيب الذين يرشدون حين يسمعون فيؤمنون، والكفار حين يرشدهم الله بمشيئته، فلا تتأسف أنت ولا تستعجل ما لم يُقَدِّر. وقرأ الحسن: (ثُمَّ إلَيْهِ يَرْجِعُونَ) فتناسبت الآية». ٢٤٧٩٠- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿إنما يستجيب الذين يسمعون﴾</q>، قال: هذا مثلُ المؤمن، سَمِع كتابَ الله فانتفَع به، وأخَذ به، وعقله، فهو حيُّ القلب، حيُّ البصر{3}. (٦/٤٤) ٢٤٧٩١- قال مقاتل بن سليمان: <q>﴿إنما يستجيب الذين يسمعون﴾</q> الهدى، يعني: القرآن. ثم قال: <q>﴿والموتى يبعثهم الله﴾</q> يعني: كفار مكة يبعثهم الله في الآخرة، <q>﴿ثم إليه يرجعون﴾</q> يعني: يُرَدُّون، فيجزيهم{4}. (ز) ",footnotes:1:تفسير مجاهد ص٣٢١، وأخرجه ابن جرير ٩/٢٣٠. وعلَّقه ابن أبي حاتم ٤/١٢٨٥. وعزاه السيوطي إلى عبد بن حميد، وابن أبي شيبة، وابن المنذر، وأبي الشيخ.أخرجه ابن جرير ٩/٢٣٠، وابن أبي حاتم ٤/١٢٨٥. وعزاه السيوطي إلى ابن أبي شيبة، وابن المنذر، وأبي الشيخ.أخرجه ابن جرير ٩/٢٣٠، وابن أبي حاتم ٤/١٢٨٥. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وأبي الشيخ.تفسير مقاتل بن سليمان ١/٥٥٩.
6,37," <q>﴿وَقَالُوا۟ لَوۡلَا نُزِّلَ عَلَیۡهِ ءَایَةࣱ مِّن رَّبِّهِۦۚ قُلۡ إِنَّ ٱللَّهَ قَادِرٌ عَلَىٰۤ أَن یُنَزِّلَ ءَایَةࣰ وَلَـٰكِنَّ أَكۡثَرَهُمۡ لَا یَعۡلَمُونَ ۝٣٧﴾</q> - تفسير ٢٤٧٩٢- قال مقاتل بن سليمان: <q>﴿وقالوا لولا﴾</q> يعني: هلّا <q>﴿نزل عليه﴾</q> محمد، كما أنزل على الأنبياء <q>﴿آيةٌ من ربه قل﴾</q> للكفار: <q>﴿إن الله قادر على أن ينزل آية ولكن أكثرهم لا يعلمون﴾</q> بأنّ الله قادر على أن ينزلها{1}. (ز) ",footnotes:1:تفسير مقاتل بن سليمان ١/٥٥٩.
6,38," <q>﴿وَمَا مِن دَاۤبَّةࣲ فِی ٱلۡأَرۡضِ وَلَا طَـٰۤىِٕرࣲ یَطِیرُ بِجَنَاحَیۡهِ إِلَّاۤ أُمَمٌ أَمۡثَالُكُمۚ﴾</q> - تفسير ٢٤٧٩٣- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿إلا أمم أمثالكم﴾</q>، قال: أصنافًا مُصَنَّفةً تُعرَفُ باسمها{1}. (٦/٤٤) ٢٤٧٩٤- قال عطاء: <q>﴿أمثالكم﴾</q> في التوحيد، والمعرفة{2}. (ز) ٢٤٧٩٥- عن قتادة بن دعامة -من طريق معمر- في قوله: <q>﴿وما من دابة في الأرض ولا طائر يطير بجناحيه إلا أمم أمثالكم﴾</q>، يقول: الطيرُ أمةٌ، والإنسُ أمةٌ، والجنُّ أمةٌ{3}. (٦/٤٥) ٢٤٧٩٦- عن إسماعيل السُّدِّيّ -من طريق أسباط- في قوله: <q>﴿إلا أمم أمثالكم﴾</q>، قال: خلقٌ أمثالُكم{4}. (٦/٤٥) ٢٤٧٩٧- قال مقاتل بن سليمان: <q>﴿وما من دابة في الأرض﴾</q> ولا في بَرٍّ، ولا في بحر، <q>﴿ولا طائر يطير بجناحيه إلا أمم أمثالكم﴾</q> يعني: خلقًا أصنافًا مُصَنَّفة تعرف بأسمائهم{5}. (ز) ٢٤٧٩٨- عن عبد الملك ابن جُرَيْج -من طريق حجاج- قال: <q>﴿وما مِن دابَّةٍ فِي الأَرْضِ ولا طائِرٍ يَطِيرُ بِجَناحَيْهِ إلّا أُمَمٌ أمْثالُكُمْ﴾</q> الذَرَّةُ فما فوقها مِن ألوان ما خلَق اللهُ مِن الدواب{6}٢٢٦١. (٦/٤٥) ٢٢٦١ ذكر ابنُ عطية (٣/٣٥٧) أنّ قوله: <q>﴿أمم امثالكم﴾</q> معناه: جماعات مماثلة للناس في الخلق، والرزق، والحياة، والموت، والحشر، ثم بَيَّن أنه يحتمل أن يريد بالمماثلة أنها في كونها أممًا لا غير، كما تريد بقولك: مررت برجل مثلك. أي: في رجل، ثم قال: «ويصح في غير ذلك من الأوصاف، إلا أنّ الفائدة في هذه الآية إنما تقع بأن تكون المماثلة في أوصاف غير كونها أممًا». ثم نقل أنّ مكيًّا قال بأنّ المماثلة في أنها تعرف الله وتعبده، ثم علَّق بقوله: «وهذا قول خلف». <q>﴿وَمَا مِن دَاۤبَّةࣲ فِی ٱلۡأَرۡضِ وَلَا طَـٰۤىِٕرࣲ یَطِیرُ بِجَنَاحَیۡهِ إِلَّاۤ أُمَمٌ أَمۡثَالُكُمۚ﴾</q> - آثار متعلقة بالآية ٢٤٧٩٩- عن جابر بن عبد الله -من طريق محمد بن المنكدر- قال: قَلَّ الجراد في سنة من سِنِي عمر ﵁ التي ولِي فيها، فسأل عنه، فلم يخُبَر بشيء، فاغتمَّ لذلك، فأرسل راكبًا إلى كذا، وآخر إلى الشام، وآخر إلى العراق يسأل: هل رُؤِي من الجراد شيء أم لا؟ فأتاه الراكب الذي من قِبَل اليمن بقبضة جراد، فألقاها بين يديه، فلما رآها كبَّر ثلاثًا، ثم قال: سمعت رسول الله ﷺ يقول: «خلق الله ﷿ ألفَ أُمَّة، منها ستمائة في البحر، وأربعمائة في البر. وأولُ شيء يهلك من هذه الأمم الجراد، فإذا هلكت تتابعت مثلَ النظام إذا قُطِع سِلْكُه»{7}. (ز) ٢٤٨٠٠- عن عُبيد الله بن زيادة البَكري، قال: دخلتُ على ابنَي بُسْرٍ المازِنيَّين صاحبي رسول الله ﷺ، فقلتُ: يرحمكما الله، الرجلُ يركبُ مِنّا الدابَّةَ، فيضرِبُها بالسوط، أو يكبَحُها باللِّجام، فهل سمِعتُما من رسول الله ﷺ في ذلك شيئًا؟ فقالا: لا. قال عبيد الله: فنادتني امرأةٌ مِن الداخل، فقالت: يا هذا، إنّ الله يقولُ في كتابه: <q>﴿وما من دابة في الأرض ولا طائر يطير بجناحيه إلا أمم أمثالكم ما فرطنا في الكتاب من شيء ثم إلى ربهم يحشرون﴾</q>. فقالا: هذه أختُنا، وهي أكبرُ مِنّا، وقد أدركَتْ رسول الله ﷺ{8}. (٦/٤٥) ٢٤٨٠١- عن أنس بن مالك أنّه سُئِل: مَن يقبِضُ أرواح البهائم؟ فقال: مَلَكُ الموت.= (ز) ٢٤٨٠٢- فبلغ الحسن البصري، فقال: صدَق، إنّ ذلك في كتاب الله. ثم تلا: <q>﴿وما من دابة في الأرض ولا طائر يطير بجناحيه إلا أمم أمثالكم﴾</q>{9}. (٦/٤٦) <q>﴿مَّا فَرَّطۡنَا فِی ٱلۡكِتَـٰبِ مِن شَیۡءࣲۚ﴾</q> - تفسير ٢٤٨٠٣- عن عبد الله بن عباس -من طريق علي بن أبي طلحة- <q>﴿ما فرطنا في الكتاب من شيء﴾</q>، يعني: ما تَرَكنا شيئًا إلا وقد كتَبناه في أُمِّ الكتاب{10}. (٦/٤٥) ٢٤٨٠٤- عن قتادة بن دعامة -من طريق مَعْمَر- <q>﴿ما فرطنا في الكتاب من شيء﴾</q>، قال: مِن الكتاب الذي عنده{11}. (٦/٤٥) ٢٤٨٠٥- قال مقاتل بن سليمان: <q>﴿ما فرطنا في الكتاب﴾</q>، يعني: ما ضَيَّعنا في اللوح المحفوظ من شيء{5}. (ز) ٢٤٨٠٦- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿ما فرطنا في الكتاب من شيء﴾</q>، قال: لم نُغفِلِ الكتاب، ما من شيءٍ إلا وهو في ذلك الكتاب{13}٢٢٦٢. (٦/٤٦) ٢٢٦٢ ذكر ابنُ عطية (٣/٣٥٨) في المراد بالكتاب هنا قولين: أحدهما: أنه القرآن. والآخر: أنه اللوح المحفوظ. ورجَّح القولَ الأول مستندًا إلى السياق، فقال: «و<q>﴿الكتاب﴾</q>: القرآن، وهو الذي يقتضيه نظام المعنى في هذه الآيات». وبيَّن ابنُ القيم (١/٣٤٦-٣٤٨) أنّ القول بكونه القرآن؛ إما أن يكون من العام المراد به الخاص، أي: ما فرطنا فيه من شيء يحتاجون إلى ذكره وبيانه، كقوله: <q>﴿ونَزَّلْنا عَلَيْكَ الكِتابَ تِبْيانًا لِكُلِّ شَيْءٍ﴾</q>، وإما أن يكون من العام المراد به عمومه، والمراد: أنّ كل شيء ذُكِرَ فيه مجملًا ومفصلًا. ورجَّح ابنُ القيم أنّه اللوح المحفوظ مستندًا إلى السياق، فقال: «وكأن هذا القول أظهر في الآية، والسياق يدل عليه؛ فإنه قال: <q>﴿وما مِن دابَّةٍ فِي الأَرْضِ ولا طائِرٍ يَطِيرُ بِجَناحَيْهِ إلّا أُمَمٌ أمْثالُكُم﴾</q>، وهذا يتضمن أنها أممٌ أمثالنا في الخلق والرزق والأكل والتقدير الأول، قد قُدِّر خلقها وأجلها ورزقها وما تصير إليه، ثم ذكر عاقبتها ومصيرها بعد فنائها، ثم قال: <q>﴿إلى ربهم يحشرون﴾</q>، فذكر مبدأها ونهايتها، وأدخَلَ بين هاتين الحالتين قوله: <q>﴿ما فَرَّطْنا فِي الكِتابِ مِن شَيْءٍ﴾</q>، أي: كلها قد كُتبت وقُدِّرت وأُحصيت، فلا يناسب هذا ذكر كتاب الأمر والنهي، وإنما يناسبه ذكر الكتاب الأول». وبنحوه رجَّح ابنُ تيمية (٣/٢٣) مستندًا إلى السياق. ووجَّه ابنُ عطية معنى قوله تعالى: <q>﴿من شيء﴾</q> على القول الثاني بأنّها عامة في جميع الأشياء، وأنها خاصة في الأشياء التي فيها منافع للمخاطبين وطرائق هدايتهم على القول الأول. ثم ذكر ابنُ القيم أنّ من قال بكونه القرآن يمكنه الاستناد إلى نفس الآية المستدل بها أصحاب القول الآخر، ذلك أنّ القرآن تضمن الإخبار عن كل ما كان وما هو كائن جملة وتفصيلًا، وأنه يشهد لكونه القرآن أنّ هذا ذُكر عقيب قوله تعالى: <q>﴿وقالُوا لَوْلا نُزِّلَ عَلَيْهِ آيَةٌ مِن رَبِّهِ قُلْ إنَّ اللَّهَ قادِرٌ عَلى أنْ يُنَزِّلَ آيَةً ولَكِنَّ أكْثَرَهُمْ لا يَعْلَمُونَ﴾</q>، فنبههم على أعظم الآيات وأدلها على صدق رسول الله ﷺ، وهو الكتاب الذي يتضمن بيان كل شيء، ولم يفرط فيه من شيء، ثم نبههم بأنهم أمة من جملة الأمم التي في السماوات والأرض، وهذا يتضمن التعريف بوجود الخالق، وكمال قدرته وعلمه وسعة ملكه. فهذا دليل على وحدانيته وصفات كماله من جهة خلقه وقدره، وإنزال الكتاب الذي لم يفرط فيه من شيء دليل من جهة أمره وكلامه، فهذا استدلال بأمره، وذاك بخلقه. ثم ذكر أنّ مَن قال إن الكتاب اللوح المحفوظ يمكنه أيضًا الاستدلال بقوله تعالى: <q>﴿وقالُوا لَوْلا نُزِّلَ عَلَيْهِ آيَةٌ مِن رَبِّهِ قُلْ إنَّ اللَّهَ قادِرٌ عَلى أنْ يُنَزِّلَ آيَةً ولَكِنَّ أكْثَرَهُمْ لا يَعْلَمُونَ﴾</q>، ذلك أنهم لما سألوا آية أخبرهم سبحانه بأنه لم يترك إنزالها لعدم قدرته على ذلك، فإنّه قادر على ذلك، وإنما لم ينزلها لحكمته ورحمته بهم وإحسانه إليهم؛ إذ لو أنزلها على وفق اقتراحهم لعوجلوا بالعقوبة إن لم يؤمنوا، ثم ذكر ما يدل على كمال قدرته بخلق الأمم العظيمة التي لا يحصي عددها إلا هو، فمن قدر على خلق هذه الأمم مع اختلاف أجناسها وأنواعها وصفاتها وهيئاتها كيف يعجز عن إنزال آية؟! ثم أخبر عن كمال قدرته وعلمه بأن هؤلاء الأمم قد أحصاهم وكتبهم وقدر أرزاقهم وآجالهم وأحوالهم في كتاب لم يفرط فيه من شيء ثم يميتهم ثم يحشرهم إليه... فهو أظهر القولين. <q>﴿ثُمَّ إِلَىٰ رَبِّهِمۡ یُحۡشَرُونَ ۝٣٨﴾</q> - تفسير ٢٤٨٠٧- عن أبي هريرة -من طريق يزيد بن الأصم- قال: ما من دابة ولا طائر إلا سيُحشَرُ يومَ القيامة، ثم يُقتَصُّ لبعضِها من بعض، حتى يُقتَصَّ للجَلْحاء من ذات القَرْن، ثم يقالُ لها: كوني ترابًا. فعند ذلك يقولُ الكافر: <q>﴿يا ليتني كنت ترابا﴾</q> [النبأ:٤٠]. وإن شئتُم فاقرءوا: <q>﴿وما من دابة في الأرض ولا طائر يطير بجناحيه إلا أمم أمثالكم﴾</q> إلى قوله: <q>﴿يحشرون﴾</q>{14}. (٦/٤٧) ٢٤٨٠٨- عن عبد الله بن عباس -من طريق عكرمة- في قوله: <q>﴿ثم إلى ربهم يحشرون﴾</q>، قال: موتُ البهائم حَشرُها. وفي لفظ قال: يعني بالحشر: الموت{15}. (٦/٤٦) ٢٤٨٠٩- وعن مجاهد بن جبر، مثل ذلك{16}. (ز) ٢٤٨١٠- عن الضحاك بن مزاحم -من طريق عبيد بن سليمان- يقول في قوله: <q>﴿ثم إلى ربهم يحشرون﴾</q>: يعني بالحشر: الموت{17}. (ز) ٢٤٨١١- عن القاسم بن أبي بَزَّة -من طريق ليث- في قوله: <q>﴿وما من دابة في الأرض ولا طائر يطير بجناحيه إلا أمم أمثالكم ما فرطنا في الكتاب من شيء ثم إلى ربهم يحشرون﴾</q>، قال: يُؤْتى بهم، والناس وقوف، فيقضى بينهم، حتى إنّه لَيُؤْخَذ للجَمّاء من القرناء لقهرها إياها، وحتى يُقاد للذَرَّة من الذرَّة، ثم يقال لهم: كونوا ترابًا. قال: ثم يقول الكافر: <q>﴿يا ليتني كنت ترابا﴾</q> [النبأ:٤٠]{18}. (ز) ٢٤٨١٢- قال مقاتل بن سليمان: <q>﴿ثم إلى ربهم يحشرون﴾</q> في الآخرة، ثم يصيرون من بعد ما يَقْتَصُّ بعضُهم من بعض ترابًا، يُقال لهم: كونوا ترابًا{5}٢٢٦٣. (ز) ٢٢٦٣ اختُلِف في معنى حشر البهائم؛ فقال قوم: حشرها: موتها. وقال آخرون: حشرها: بعثها. ورجَّح ابنُ جرير (٩/٢٣٧-٢٣٨) العموم في الآية مستندًا إلى اللغة، فقال: «وجائز أن يكون معنيًّا به: حشر الموت، وجائز أن يكون معنيًّا به: الحشران جميعًا. ولا دلالة في ظاهر التنزيل ولا في خبر عن النبي ﷺ أي ذلك المراد بقوله: <q>﴿ثم إلى ربهم يحشرون﴾</q>، إذ كان الحشر في كلام العرب: الجمع، ومن ذلك قول الله تعالى: <q>﴿والطير محشورة كل له أواب﴾</q> [ص:١٩]، يعني: مجموعة. فإذ كان الجمع هو الحشر، وكان الله تعالى جامعًا خلقه إليه يوم القيامة وجامعهم بالموت؛ كان أصوب القول في ذلك أن يعم بمعنى الآية ما عمه الله بظاهرها، وأن يُقال: كل دابة وكل طائر محشور إلى الله بعد الفناء وبعد بعث القيامة، إذ كان الله تعالى قد عم بقوله: <q>﴿ثم إلى ربهم يحشرون﴾</q>، ولم يخصص به حشرًا دون حشر». وعلَّق ابنُ كثير (٣٣/٦) على القول الثاني بقوله: «والقول الثاني... كما قال تعالى: <q>﴿وإذا الوحوش حشرت﴾</q> [التكوير:٥]». وذكر ابنُ عطية (٣/٣٥٨) أنّ القائلين بالقول الثاني احتجوا بالأحاديث المتضمنة أنّ الله يقتص للجماء من القرناء. وانتقد من تأوَّل الأحاديث بأنها كناية عن العدل لا الحقيقة، فقال: «وهو قول مردود ينحو إلى الرموز ونحوها». <q>﴿ثُمَّ إِلَىٰ رَبِّهِمۡ یُحۡشَرُونَ ۝٣٨﴾</q> - آثار متعلقة بالآية ٢٤٨١٣- عن أبي ذرٍّ، قال: انتَطَحتْ شاتان عند النبي ﷺ، فقال لي: «يا أبا ذرٍّ، أتدري فيما انتطحتا؟». قلتُ: لا. قال: «لكنَّ اللهَ يدري، وسيَقضي بينهما».= (ز) ٢٤٨١٤- قال أبو ذر: لقد تَرَكَنا رسول الله ﷺ وما يُقلِّبُ طائرٌ جَناحَيه في السماء إلا ذكَّرنا منه علمًا{20}. (٦/٤٧) ",footnotes:1:أخرجه ابن جرير ٩/٢٣٣، وابن أبي حاتم ٤/١٢٨٥. وعزاه السيوطي إلى الفريابي، وعبد بن حميد، وابن المنذر، وأبي الشيخ.تفسير الثعلبي ٤/١٤٦.أخرجه عبد الرزاق ١/٢٠٨، وابن جرير ٩/٢٣٣، وابن أبي حاتم ٤/١٢٨٥-١٢٨٦. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه ابن جرير ٩/٢٣٣، وابن أبي حاتم ٤/١٢٨٦.تفسير مقاتل بن سليمان ١/٥٦٠.أخرجه ابن جرير ٩/٢٣٣-٢٣٤. وعزاه السيوطي إلى أبي الشيخ.أخرجه أبو الشيخ في العظمة ٥/١٧٨٣، والبيهقي في الشعب ١٢/٤١٢-٤١٣ (٩٦٥٩، ٩٦٦٠). قال ابن حبان في المجروحين ٢/٢٥٦-٢٥٧ (٩٣٢): «وهذا شيء لا شكَّ أنه موضوع، ليس هذا من كلام رسول الله ﷺ». وقال ابن كثير في تفسيره ١/١٣٣: «محمد بن عيسى -وهو الهلالي- ضعيف». وقال في مسند الفاروق ٢/٥٨٠: «هذا حديث غريب». وقال ابن القيسراني في تذكرة الحفاظ ص١٨٣ (٤٣٣): «محمد بن عيسى هذا يتهم بوضع هذا الحديث». وقال الهيثمي في المجمع ٧/٣٢٢ (١٢٤٣٣): «رواه أبو يعلى في الكبير، وفيه عبيد بن واقد القيسي، وهو ضعيف». وقال البوصيري في إتحاف الخيرة ٥/٣٠٦ (٤٧٢٨): «هذا إسناد ضعيف؛ لضعف محمد بن عيسى بن كيسان». وقال السيوطي في اللآلىء المصنوعة ١/٧٥: «موضوع».أخرجه أحمد في مسنده ٢٩/٢٣٠ (١٧٦٨٥)، والبيهقي في شعب الإيمان (١١٠٦٦)، والخطيب في تالي التلخيص ٢/٤٨٥، وابن عساكر ٣٧/٤٣١.عزاه السيوطي إلى أبي الشيخ.أخرجه ابن جرير ٩/٢٣٤، وابن أبي حاتم ٤/١٢٨٦. وعزاه السيوطي إلى ابن المنذر.أخرجه عبد الرزاق ١/٢٠٧. وعزاه السيوطي إلى أبي الشيخ.تفسير مقاتل بن سليمان ١/٥٦٠.أخرجه ابن جرير ٩/٢٣٤، وابن أبي حاتم ٤/١٢٨٦ من طريق أصبغ بن الفرج. كذلك أخرجه ابن جرير ٩/٢٣٤ بلفظ آخر، فقال: كلهم مكتوب في أم الكتاب.أخرجه ابن جرير ٩/٢٣٥-٢٣٦، وابن أبي حاتم ٤/١٢٨٦، والحاكم ٢/٣١٦. وعزاه السيوطي إلى أبي عبيد، وابن المنذر.أخرجه ابن جرير ٩/٢٣٤-٢٣٥، وابن أبي حاتم ٤/١٢٨٦. وعزاه السيوطي إلى أبي الشيخ.علَّقه ابن أبي حاتم ٤/١٢٨٦، وهو في تفسير ابن كثير ٣/٢٥٤.أخرجه ابن جرير ٩/٢٣٥. وعلَّقه ابن أبي حاتم ٤/١٢٨٦. وذكره الثعلبي ٤/١٤٧ وعقَّب عليه بقول عطاء: فإذا رأوا بني آدم وما هم فيه من الجزع قالت: الحمد لله الذي لم يجعلنا مثلكم، فلا جنة نرجو، ولا نارًا نخاف. فيقول الله ﷿ لهن: كن ترابًا. فحينئذ يتمنى الكافر أن يكون ترابًا.أخرجه ابن أبي الدنيا في كتاب الأهوال -موسوعة الإمام ابن أبي الدنيا ٦/٢٣١ (٢٢٤)-.تفسير مقاتل بن سليمان ١/٥٦٠.أخرجه أحمد ٣٥/٣٤٥ (٢١٤٣٨)، وابن جرير ٩/٢٣٦ واللفظ له. قال الهيثمي في المجمع ١٠/٣٥٢ (١٨٤٠٤): «ورجال الرواية... رجال الصحيح، وفيها راوٍ لم يُسَمّ». وقال الألباني في الصحيحة ٤/٦١٠: «وهذا إسناد صحيح عندي».
6,39," <q>﴿وَٱلَّذِینَ كَذَّبُوا۟ بِـَٔایَـٰتِنَا صُمࣱّ وَبُكۡمࣱ فِی ٱلظُّلُمَـٰتِۗ مَن یَشَإِ ٱللَّهُ یُضۡلِلۡهُ وَمَن یَشَأۡ یَجۡعَلۡهُ عَلَىٰ صِرَ ٰ⁠طࣲ مُّسۡتَقِیمࣲ ۝٣٩﴾</q> - نزول الآية ٢٤٨١٥- قال مقاتل بن سليمان: <q>﴿من يشأ الله يضلله﴾</q> عن الهُدى، نزلت في بني عبد الدار ابن قصي، <q>﴿ومن يشأ يجعله على صراط مستقيم﴾</q> يعني: على دين الإسلام، منهم علي بن أبي طالب، والعباس، وحمزة، وجعفر{1}٢٢٦٤. (ز) ٢٢٦٤ رجَّح ابنُ عطية (٣/٣٥٩) العموم مستندًا لظاهر الآية، فقال: «وظاهر الآية أنها تَعُمُّ كُلَّ مُكَذِّب». <q>﴿وَٱلَّذِینَ كَذَّبُوا۟ بِـَٔایَـٰتِنَا صُمࣱّ وَبُكۡمࣱ فِی ٱلظُّلُمَـٰتِۗ مَن یَشَإِ ٱللَّهُ یُضۡلِلۡهُ وَمَن یَشَأۡ یَجۡعَلۡهُ عَلَىٰ صِرَ ٰ⁠طࣲ مُّسۡتَقِیمࣲ ۝٣٩﴾</q> - النسخ في الآية ٢٤٨١٦- عن أبي يوسف المدني، قال: كلُّ مشيئةٍ في القرآن إلى ابن آدمَ منسوخةٌ نسخَتها: <q>﴿من يشإ الله يضلله ومن يشأ يجعله على صراط مستقيم﴾</q>{2}. (٦/٤٨) <q>﴿وَٱلَّذِینَ كَذَّبُوا۟ بِـَٔایَـٰتِنَا صُمࣱّ وَبُكۡمࣱ فِی ٱلظُّلُمَـٰتِۗ مَن یَشَإِ ٱللَّهُ یُضۡلِلۡهُ﴾</q> - تفسير ٢٤٨١٧- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿والذين كذبوا بآياتنا صم وبكم﴾</q> قال: هذا مَثَلُ الكافر أصمُّ أبكمُ، لا يُبصِر هُدًى، ولا ينتفِع به، صُمٌّ عن الحقِّ، <q>﴿في الظلمات﴾</q> لا يستطيعُ منها خروجًا، مُتَسَكِّعٌ{3} فيها{4}. (٦/٤٧) ٢٤٨١٨- قال مقاتل بن سليمان: <q>﴿والذين كذبوا بآياتنا﴾</q> يعني: القرآن، <q>﴿صمٌّ﴾</q> لا يسمعون الهدى، <q>﴿وبُكْمٌ﴾</q> لا يتكلمون به <q>﴿في الظلمات﴾</q> يعني: الشرك، <q>﴿من يشأ الله يضلله﴾</q> عن الهدى{1}. (ز) <q>﴿وَمَن یَشَأۡ یَجۡعَلۡهُ عَلَىٰ صِرَ ٰ⁠طࣲ مُّسۡتَقِیمࣲ ۝٣٩﴾</q> - تفسير ٢٤٨١٩- عن مجاهد بن جبر -من طريق عمر بن ذر- في قوله: <q>﴿صراط مستقيم﴾</q>، قال: الحق{6}. (ز) ٢٤٨٢٠- قال مقاتل بن سليمان: <q>﴿ومن يشأ يجعله على صراط مستقيم﴾</q>، يعني: على دين الإسلام {1}. (ز) ",footnotes:1:تفسير مقاتل بن سليمان ١/٥٦٠.عزاه السيوطي إلى أبي الشيخ.مُتَسَكِّع: مُتَحَيِّر. النهاية (سكع).أخرجه ابن جرير ٩/٢٣٨، وابن أبي حاتم ٤/١٢٨٦، ١٢٨٧. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.تفسير مقاتل بن سليمان ١/٥٦٠.أخرجه ابن أبي حاتم ٤/١٢٨٧.تفسير مقاتل بن سليمان ١/٥٦٠.
6,40," <q>﴿قُلۡ أَرَءَیۡتَكُمۡ إِنۡ أَتَىٰكُمۡ عَذَابُ ٱللَّهِ أَوۡ أَتَتۡكُمُ ٱلسَّاعَةُ أَغَیۡرَ ٱللَّهِ تَدۡعُونَ إِن كُنتُمۡ صَـٰدِقِینَ ۝٤٠﴾</q> - تفسير ٢٤٨٢١- قال عبد الله بن عباس: قل -يا محمد- لهؤلاء المشركين: أرأيتكم{1}. (ز) ٢٤٨٢٢- قال الحسن البصري: <q>﴿قل أرأيتكم إن أتاكم عذاب الله﴾</q> يعني: في الدنيا بالاسْتِئْصال، <q>﴿أو أتتكم الساعة﴾</q> بالعذاب{2}. (ز) ٢٤٨٢٣- قال مقاتل بن سليمان: خوَّفهم الله ﷿، فقال للنبي ﷺ: <q>﴿قل أرأيتكم إن أتاكم عذاب الله﴾</q> في الدنيا، كما أتى الأمم الخالية، <q>﴿أو أتتكم الساعة﴾</q>. ثم رجع إلى عذاب الدنيا، فقال: <q>﴿أغير الله﴾</q> من الآلهة <q>﴿تدعون﴾</q> أن يكشف عنكم العذاب في الدنيا <q>﴿إن كنتم صادقين﴾</q> بأنّ معه آلهة{3}٢٢٦٥. (ز) ٢٢٦٥ ذكر ابنُ عطية (٣/٣٦٠) أنّ قوله: <q>﴿أتاكُمْ عَذابُ اللَّهِ﴾</q> معناه: أتاكم خوفُه وأماراتُه وأوائلُه؛ مثل: الجدب، والبأساء، والأمراض ونحوها التي يخاف منها الهلاك. وانتَقَد قولَ مقاتل، والحسن مستندًا إلى الدلالات العقلية، وذلك أنّه لو قُدِّر إتيان العذاب وحلوله لم يترتب أن يقول بعد ذلك: <q>﴿فَيَكْشِفُ ما تَدْعُونَ﴾</q>؛ لأن ما قد صَحَّ حلوله ومضى على البشر لا يَصِحُّ كشفُه. ",footnotes:1:تفسير البغوي ٣/١٤٣.ذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٢/٦٧-.تفسير مقاتل بن سليمان ١/٥٦٠.
6,41," <q>﴿بَلۡ إِیَّاهُ تَدۡعُونَ فَیَكۡشِفُ مَا تَدۡعُونَ إِلَیۡهِ إِن شَاۤءَ وَتَنسَوۡنَ مَا تُشۡرِكُونَ ۝٤١﴾</q> - تفسير ٢٤٨٢٤- قال مقاتل بن سليمان: ثم رجع إلى نفسه، فقال: <q>﴿بل إياه تدعون فيكشف ما تدعون إليه إن شاء وتنسون﴾</q> يعني: وتتركون <q>﴿ما تشركون﴾</q> بالله من الآلهة، فلا تدعونهم أن يكشفوا عنكم، ولكنكم تدعون الله{1}٢٢٦٦. (ز) ٢٢٦٦ ذكر ابنُ عطية (٣/٣٦٠-٣٦١) أنّ الضمير في <q>﴿إليه﴾</q> يحتمل احتمالين: الأول: أن يعود إلى الله تعالى، بتقدير: فيكشف ما تدعون فيه إلى الله تعالى. الثاني: أن يعود إلى <q>﴿ما﴾</q>، بتقدير: فيكشف ما تدعون إليه. ",footnotes:1:تفسير مقاتل بن سليمان ١/٥٦٠.
6,42," <q>﴿وَلَقَدۡ أَرۡسَلۡنَاۤ إِلَىٰۤ أُمَمࣲ مِّن قَبۡلِكَ﴾</q> - تفسير ٢٤٨٢٥- قال مقاتل بن سليمان: <q>﴿ولقد أرسلنا﴾</q> الرسل <q>﴿إلى أمم من قبلك﴾</q> فكذَّب بهم قومُهم، كما كذَّب بك كفار مكة، <q>﴿فأخذناهم بالبأساء والضراء﴾</q>{1}. (ز) <q>﴿فَأَخَذۡنَـٰهُم بِٱلۡبَأۡسَاۤءِ وَٱلضَّرَّاۤءِ﴾</q> - تفسير ٢٤٨٢٦- عن سعيد بن جبير، في قوله: <q>﴿فأخذناهم بالبأساء والضراء﴾</q>، قال: خَوْفِ السلطان، وغلاءِ السِّعر{2}. (٦/٤٨) ٢٤٨٢٧- عن الحسن البصري -من طريق عبّاد بن منصور- <q>﴿بالبأساء﴾</q> قال: البلاء، <q>﴿والضراء﴾</q> قال: هذه الأمراض، والجوع، ونحو ذلك{3}٢٢٦٧. (ز) ٢٢٦٧ ذكر ابنُ عطية (٣/٣٦١) أن البأساء: المصائب في الأموال. والضراء: مصائب الأبدان. ثم علَّق بقوله: «وهذا قول الأكثر». ثم قال: «وقيل: قد يُوضَع كل واحد بدل الآخر، ويؤدب الله تعالى عباده بالبأساء والضراء، ومن هنالك أدَّب العباد نفوسهم بالبأساء في تفريق المال، والضراء في الحمل على البدن في جوع وعري». <q>﴿لَعَلَّهُمۡ یَتَضَرَّعُونَ ۝٤٢﴾</q> - تفسير ٢٤٨٢٨- عن أبي مالك غزوان الغفاري -من طريق السدي- قوله: <q>﴿لعلهم﴾</q>، يعني: كي{4}. (ز) ٢٤٨٢٩- قال مقاتل بن سليمان: <q>﴿لعلهم﴾</q> لكي <q>﴿يتضرعون﴾</q> إلى ربهم، فيتوبون إليه{1}. (ز) ",footnotes:1:تفسير مقاتل بن سليمان ١/٥٦٠.عزاه السيوطي إلى أبي الشيخ.أخرجه ابن أبي حاتم ٤/١٢٨٩. وقد تقدم تفسير ذلك بأوسع منه عند قوله تعالى: <q>﴿والصّابِرِينَ فِي البَأْساءِ والضَّرّاءِ﴾</q> [البقرة:١٧٧].أخرجه ابن أبي حاتم ٤/١٢٨٩.تفسير مقاتل بن سليمان ١/٥٦٠.
6,43," <q>﴿فَلَوۡلَاۤ إِذۡ جَاۤءَهُم بَأۡسُنَا تَضَرَّعُوا۟ وَلَـٰكِن قَسَتۡ قُلُوبُهُمۡ وَزَیَّنَ لَهُمُ ٱلشَّیۡطَـٰنُ مَا كَانُوا۟ یَعۡمَلُونَ ۝٤٣﴾</q> - تفسير ٢٤٨٣٠- عن قتادة بن دعامة -من طريق شيبان بن عبد الرحمن- في قوله: <q>﴿فلولا إذ جاءهم بأسنا تضرعوا ولكن قست قلوبهم﴾</q>، قال: عاب اللهُ عليهم القسوةَ عند ذلك. فتَضَعْضَعوا{1} لعقوبة الله -بارك اللهُ فيكم-، ولا تَعرَّضوا لعقوبةِ الله بالقسوة؛ فإنّه عاب ذلك على قومٍ قبلَكم{2}. (٦/٤٨) ٢٤٨٣١- قال مقاتل بن سليمان: يقول: <q>﴿فلولا إذ جاءهم بأسنا﴾</q> يعني: الشدة والبلاء <q>﴿تضرعوا﴾</q> إلى الله، وتابوا إليه؛ لكشف ما نزل بهم من البلاء، <q>﴿ولكن قست﴾</q> يعني: جَفَّت <q>﴿قلوبهم﴾</q>، فلم تَلِن، <q>﴿وزين لهم الشيطان ما كانوا يعملون﴾</q> من الشرك، والتكذيب{3}. (ز) ",footnotes:1:الضَّعْضَعة: الخضوع والتذلل والفقر. لسان العرب (ضعع).أخرجه ابن أبي حاتم ٤/١٢٨٩. وعزاه السيوطي إلى عبد بن حميد، وأبي الشيخ.تفسير مقاتل بن سليمان ١/٥٦٠-٥٦١.
6,44," <q>﴿فَلَمَّا نَسُوا۟ مَا ذُكِّرُوا۟ بِهِۦ﴾</q> - تفسير ٢٤٨٣٢- عن عبد الله بن عباس -من طريق علي بن أبي طلحة- في قوله: <q>﴿فلما نسوا ما ذكروا به﴾</q>، قال: يعني: تركوا ما ذُكِّروا به{1}. (٦/٤٨) ٢٤٨٣٣- قال جعفر الصادق: <q>﴿فلما نسوا ما ذكروا به﴾</q> من التعظيم{2}. (ز) ٢٤٨٣٤- قال مقاتل بن سليمان: <q>﴿فلما نسوا ما ذكروا به﴾</q>، يعني: فلمّا تركوا ما أُمِروا به، يعني: وُعِظُوا به، يعني: الأمم الخالية مِمّا دعاهم الرسل فكذَّبوهم{3}. (ز) ٢٤٨٣٥- عن عبد الملك ابن جُرَيْج -من طريق حجّاج- في قوله: <q>﴿فلما نسوا ما ذكروا به﴾</q>، قال: ما دعاهم اللهُ إليه ورسلُه، أبَوه وردُّوه عليهم{4}. (٦/٤٩) <q>﴿فَتَحۡنَا عَلَیۡهِمۡ أَبۡوَ ٰ⁠بَ كُلِّ شَیۡءٍ﴾</q> - تفسير ٢٤٨٣٦- عن عقبة بن عامر، عن النبي ﷺ، قال: «إذا رأيتَ اللهَ يُعطِي العبدَ في الدنيا -وهو مقيمٌ على معاصيه- ما يحِبُّ؛ فإنّما هو اسْتِدْراجٌ». ثم تلا رسول الله ﷺ: <q>﴿فلما نسوا ما ذكروا به فتحنا عليهم أبواب كل شيء﴾</q> الآية والآيةَ التي بعدَها{5}. (٦/٥٠) ٢٤٨٣٧- عن عبادة بن الصامت، أنّ رسول الله ﷺ قال: «إنّ الله -تبارك وتعالى- إذا أراد بقومٍ بقاءً أو نماءً رزَقهم القصدَ والعفاف، وإذا أراد بقومٍ اقتطاعًا فتَح لهم أو فتَح عليهم باب خيانة: <q>﴿حتى إذا فرحوا بما أوتوا أخذناهم بغتة فإذا هم مبلسون * فقطع دابر القوم الذين ظلموا والحمد لله رب العالمين﴾</q>»{6}. (٦/٥٠) ٢٤٨٣٨- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿فتحنا عليهم أبواب كل شيء﴾</q>، قال: رخاء الدنيا ويسرها على القرون الأولى{7}. (٦/٤٩) ٢٤٨٣٩- عن الحسن البصري -من طريق مروان بن معاوية، عن رجل- قال: مَن وُسِّع عليه فلم يَرَ أنّه يُمكَرُ به فلا رأيَ له، ومن قُتِر عليه فلم يَرَ أنه يُنظَرُ له فلا رأيَ له. ثم قرأ: <q>﴿فلما نسوا ما ذكروا به فتحنا عليهم أبواب كل شيء﴾</q> الآية. وقال الحسن: مُكِر بالقوم، وربِّ الكعبة؛ أُعطُوا حاجاتِهم ثم أُخِذوا{8}. (٦/٥١) ٢٤٨٤٠- عن قتادة بن دعامة -من طريق مَعْمَر- في قوله: <q>﴿فتحنا عليهم أبواب كل شيء﴾</q>، قال: يعني: الرخاء، وسَعَة الرزق{9}. (٦/٤٩) ٢٤٨٤١- عن إسماعيل السُّدِّيّ -من طريق أسباط- في قوله: <q>﴿فتحنا عليهم أبواب كل شيء﴾</q>، قال: مِن الرِّزق{10}. (ز) ٢٤٨٤٢- عن أبي سنان [سعيد بن سنان] الشيباني-من طريق شجاع بن الوليد- أنّه قال في قوله: <q>﴿فتحنا عليهم أبواب كل شيء﴾</q>، قال: فتح عليهم أربعين سنة{11}. (ز) ٢٤٨٤٣- قال جعفر الصادق: <q>﴿فتحنا عليهم أبواب كل شيء﴾</q> من النعيم{2}. (ز) ٢٤٨٤٤- قال مقاتل بن سليمان: <q>﴿فتحنا عليهم﴾</q> يعني: أرسلنا عليهم <q>﴿أبواب كل شيء﴾</q> يعني: أنواع الخير من كلِّ شيء بعد الضر الذي كان نزل بهم. نظيرها في الأعراف{13}. (ز) ٢٤٨٤٥- عن سفيان [بن عيينة] -من طريق سعيد بن منصور- <q>﴿فلما نسوا ما ذكروا به فتحنا عليهم أبواب كل شيء﴾</q> قال: رخاء الدنيا ويسرها، <q>﴿حتى إذا فرحوا بما أوتوا أخذناهم بغتة﴾</q>{14}. (ز) <q>﴿حَتَّىٰۤ إِذَا فَرِحُوا۟ بِمَاۤ أُوتُوۤا۟﴾</q> - تفسير ٢٤٨٤٦- عن إسماعيل السُّدِّيّ -من طريق أسباط- في قوله: <q>﴿حتى إذا فرحوا بما أوتوا﴾</q>، قال: مِن الرِّزق{15}. (٦/٤٩) ٢٤٨٤٧- قال جعفر الصادق: <q>﴿حتى إذا فرحوا بما أوتوا﴾</q> مِن التَّرفيه والنعيم <q>﴿أخذناهم بغتة﴾</q>إلى سواء الجحيم{2}. (ز) ٢٤٨٤٨- قال مقاتل بن سليمان: <q>﴿حتى إذا فرحوا بما أوتوا﴾</q>، يعني: بما أُعْطُوا من أنواع الخير، وأعجبهم ما هم فيه{3}. (ز) <q>﴿أَخَذۡنَـٰهُم بَغۡتَةࣰ﴾</q> - تفسير ٢٤٨٤٩- عن مجاهد بن جبر -من طريق ابن أبي نجيح- <q>﴿أخذناهم بغتة﴾</q>، قال: فَجْأَة آمنين{18}. (ز) ٢٤٨٥٠- عن قتادة بن دعامة، في قوله: <q>﴿حتى إذا فرحوا بما أوتوا أخذناهم بغتة﴾</q>، قال: بغَت القومَ أمرُ الله، ما أخَذ اللهُ قومًا قطُّ إلا عندَ سُلوَتِهم وغِرَّتِهم ونعيمِهم، فلا تغترُّوا بالله؛ فإنّه لا يغترُّ بالله إلا القومُ الفاسقون{19}. (٦/٥١) ٢٤٨٥١- عن إسماعيل السُّدِّيّ -من طريق أسباط- <q>﴿أخذناهم بغتة﴾</q>، يقول: أخذهم العذاب بغتة{18}. (ز) ٢٤٨٥٢- قال مقاتل بن سليمان: <q>﴿أخذناهم بغتة﴾</q>، يعني: أصبناهم بالعذاب بغتة، يعني: فجأةً، أعزَّ ما كانوا{3}. (ز) ٢٤٨٥٣- عن عبد الملك ابن جُرَيْج -من طريق حجاج- <q>﴿حتى إذا فرحوا بما أوتوا أخذناهم بغتة﴾</q>، قال: أعجب ما كانت إليهم، وأغرّها لهم{18}. (ز) ٢٤٨٥٤- عن محمد بن النضر الحارثي -من طريق عبد الله بن المبارك- في قوله: <q>﴿أخذناهم بغتة﴾</q>، قال: أُمهِلوا عشرين سنة{23}. (٦/٤٩) ٢٤٨٥٥- عن سفيان [الثوري]-من طريق مهران- قوله: <q>﴿أخذناهم بغتة﴾</q>، قال: سِتِّين سنة{24}. (ز) <q>﴿أَخَذۡنَـٰهُم بَغۡتَةࣰ﴾</q> - آثار متعلقة بالآية ٢٤٨٥٦- عن الربيع بن أنس -من طريق ابن أبي جعفر، عن أبيه- قال: إنّ البعوضةَ تحيا ما جاعت، فإذا شَبِعَتْ ماتت، وكذلك ابنُ آدمَ إذا امتلأ مِن الدنيا أخذه اللهُ عند ذلك. ثم تلا: <q>﴿حتى إذا فرحوا بما أوتوا أخذناهم بغتة﴾</q>{25}. (٦/٥٢) ٢٤٨٥٧- عن أبي حازم -من طريق عمر بن سعيد- قال: إذا رأيتَ اللهَ يُتابِعُ نِعمَه عليك وأنت تعصِيه فاحذره. قال: وكلُّ نعمةٍ لا تُقَرِّبُ من الله ﷿ فهي بَلِيَّةٌ{26}. (٦/٥١) ٢٤٨٥٨- عن جعفر، قال: أوحى الله إلى داود: خَفني على كلِّ حال، وأخوفُ ما تكونُ عندَ تظاهرِ النِّعم عليك؛ لا أصْرعُك عندَها ثم لا أنظُرُ إليك{27}. (٦/٥١) ٢٤٨٥٩- عن حماد بن زيد، قال: كان رجل يقول: رحم الله رجلًا تلا هذه الآية، ثم فكَّر فيها ماذا أُرِيد بها: <q>﴿حتى إذا فرحوا بما أوتوا أخذناهم بغتة﴾</q>{28}. (ز) <q>﴿فَإِذَا هُم مُّبۡلِسُونَ ۝٤٤﴾</q> - تفسير ٢٤٨٦٠- عن عبد الله بن عباس -من طريق علي بن أبي طلحة- قوله: أُبْلِسوا، يقول: أيِسُوا{24}. (ز) ٢٤٨٦١- عن مجاهد بن جبر -من طريق شيخ- <q>﴿فإذا هم مبلسون﴾</q>، قال: الاكْتِئابُ. وفي لفظ قال: آيِسون{30}. (٦/٥٠) ٢٤٨٦٢- عن عكرمة مولى ابن عباس -من طريق الحكم بن أبان- قال: <q>﴿فإذا هم مبلسون﴾</q>، قال: عامَ الفتح{24}. (ز) ٢٤٨٦٣- قال الحسن البصري: <q>﴿فإذا هم مبلسون﴾</q>: مُبصبصون{32}. (ز) ٢٤٨٦٤- عن إسماعيل السُّدِّيّ -من طريق إسماعيل- قال: الإبلاسُ: تغييُر الوجوه. وإنّما سُمِّي: إبليسَ؛ لأنّ الله نكَس وجهَه وغيَّره{24}. (٦/٥٠) ٢٤٨٦٥- عن إسماعيل السُّدِّيّ -من طريق أسباط- في قوله: <q>﴿فإذا هم مبلسون﴾</q>، قال: مُهلَكون، مُتَغيِّرٌ حالُهم{34}. (٦/٤٩) ٢٤٨٦٦- قال مقاتل بن سليمان: <q>﴿فإذا هم مبلسون﴾</q>، يعني: فإذا هم مُرْتَهَنُون، آيِسُون من كل خير{3}. (ز) ٢٤٨٦٧- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿فإذا هم مبلسون﴾</q>، قال: المبلِسُ: المجهودُ المكروبُ الذي قد نزَل به الشرُّ الذي لا يَدفعُه، والمبلِسُ أشدُّ مِن المستكين{36}. (٦/٥٠) ",footnotes:1:أخرجه ابن جرير ٩/٢٤٤، وابن أبي حاتم ٤/١٢٩٠. وعزاه السيوطي إلى ابن المنذر.تفسير الثعلبي ٤/١٤٨.تفسير مقاتل بن سليمان ١/٥٦١.أخرجه ابن جرير ٩/٢٤٤. وعزاه السيوطي إلى ابن المنذر.أخرجه أحمد ٢٨/٥٤٧ (١٧٣١١) واللفظ له، وابن جرير ٩/٢٤٨-٢٤٩، وابن أبي حاتم ٤/١٢٩٠-١٢٩١ (٧٢٨٨)، (١٨٥١٢). وأورده الثعلبي ٤/١٤٨. قال الهيثمي في المجمع ١٠/٢٤٥ (١٧٧٩٦): «رواه الطبراني في الأوسط، عن شيخه الوليد بن العباس المصري، وهو ضعيف». وقال المناوي في فيض القدير ١/٣٥٤ (٦٢٩): «وقال العراقي: إسناده حسن. وتبعه المؤلف -أي: السيوطي-، فرمز لحسنه». وأورده الألباني في الصحيحة ١/٧٧٣ (٤١٣).أخرجه الطبراني في مسند الشاميين ١/١٣٦، وابن عساكر ٤٠/١٦٥، وابن أبي حاتم ٤/١٢٩٠ (٧٢٨٣)، من طريق عراك بن خالد بن يزيد، حدثني أبي، قال: سمعت إبراهيم بن أبي عبلة يُحَدِّث عن عبادة بن الصامت. فقد أعلّ أبو حاتم حديثًا روي بهذا الإسناد فقال كما في العلل لابنه ١/٢٢٠: «هذا حديث منكر، وإبراهيم لم يدرك عبادة، وعراك منكر الحديث، وأبوه خالد بن يزيد أوثق منه وهو صدوق». وقال الألباني في الضعيفة ١٣/٣٦٩ (٦١٦٣): «منكر» وأعلَّه بالعلَّتين السابقتين.تفسير مجاهد ص٣٢١، وأخرجه ابن جرير ٩/٢٤٤، وابن أبي حاتم ٤/١٢٩٠. وعزاه السيوطي إلى ابن أبي شيبة، وعبد بن حميد، وابن المنذر، وأبي الشيخ.أخرجه ابن أبي حاتم ٤/١٢٩١، وابن أبي الدنيا في كتاب ذم الدنيا -موسوعة الإمام ابن أبي الدنيا ٥/٣٦-٣٧ (٤٣)-، وعزاه السيوطي إلى أبي الشيخ.أخرجه عبد الرزاق ١/٢٠٩، وابن جرير ٩/٢٤٥، وابن أبي حاتم ٤/١٢٩٠.أخرجه ابن جرير ٩/٢٤٥.أخرجه ابن أبي حاتم ٤/١٢٩٠.تفسير الثعلبي ٤/١٤٨.تفسير مقاتل بن سليمان ١/٥٦١. لعله يشير إلى قوله تعالى: <q>﴿فَلَمّا نَسُوا ما ذُكِّرُوا بِهِ أنْجَيْنا الَّذِينَ يَنْهَوْنَ عَنِ السُّوءِ وأَخَذْنا الَّذِينَ ظَلَمُوا بِعَذابٍ بَئِيسٍ بِما كانُوا يَفْسُقُونَ (١٦٥)﴾</q>.أخرجه سعيد بن منصور في سننه (ت: سعد آل حميد) ٥/٢٠ (٨٧٨).أخرجه ابن جرير ٩/٢٤٦، وابن أبي حاتم ٤/١٢٩١. وعزاه السيوطي إلى أبي الشيخ.تفسير الثعلبي ٤/١٤٨.تفسير مقاتل بن سليمان ١/٥٦١.أخرجه ابن جرير ٩/٢٤٧.عزاه السيوطي إلى عبد بن حميد، وأبي الشيخ.أخرجه ابن جرير ٩/٢٤٧.تفسير مقاتل بن سليمان ١/٥٦١.أخرجه ابن جرير ٩/٢٤٧.أخرجه ابن جرير ٩/٢٤٦-٢٤٧، وابن أبي حاتم ٤/١٢٩٢. وعزاه السيوطي إلى ابن المنذر، وأبي الشيخ.أخرجه ابن أبي حاتم ٤/١٢٩٢.أخرجه ابن جرير ١/٤٢٣. وعزاه السيوطي إلى أبي الشيخ.أخرجه البيهقي في شعب الإيمان (٤٥٣٨).عزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ٩/٢٤٦.أخرجه ابن أبي حاتم ٤/١٢٩٢.أخرجه ابن جرير ٩/٢٤٨ مقتصرًا على اللفظ الأول. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه ابن أبي حاتم ٤/١٢٩٢.تفسير الثعلبي ٤/١٤٧. وفي النهاية (بصبص): يقال: بصبص الكلب بذنبه؛ إذا حركه، وإنما يفعل ذلك من طمع أو خوف.أخرجه ابن أبي حاتم ٤/١٢٩٢.أخرجه ابن جرير ٩/٢٤٧، وابن أبي حاتم ٤/١٢٩٢. وعزاه السيوطي إلى أبي الشيخ.تفسير مقاتل بن سليمان ١/٥٦١.أخرجه ابن جرير ٩/٢٤٨، وابن أبي حاتم ٤/١٢٩٢-١٢٩٣ من طريق أصبغ بن الفرج.
