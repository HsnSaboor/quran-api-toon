tafsir[7]{c,v,t}:
12,31," <q>﴿فَلَمَّا سَمِعَتۡ بِمَكۡرِهِنَّ﴾</q> - تفسير ٣٧١٩٨- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿فلما سمعت بمكرهن﴾</q>، قال: بحدِيثِهِنَّ{1}. (٨/٢٣٧) ٣٧١٩٩- عن إسماعيل السُّدِّيّ -من طريق أسباط- قال: <q>﴿فلما سمعت بمكرهن﴾</q>، يقول: بقَوْلِهِنَّ{2}. (٨/١٩١) ٣٧٢٠٠- قال مقاتل بن سليمان: <q>﴿فلما سمعتْ﴾</q> زليخا <q>﴿بمكرهن﴾</q> يعني: بِقَوْلِهِنَّ لها{3}. (ز) ٣٧٢٠١- عن محمد بن إسحاق -من طريق سلمة- قال: لَمّا أظهر النساءُ ذلك مِن قولهن: تُراوِدُ عبدَها. مكرًا بها؛ لِتُرِيَهُنَّ يوسفَ، وكان يُوصَفُ لِهُنَّ بحسنه وجماله، <q>﴿فلما سمعت بمكرهن أرسلت إليهن وأعتدت لهن متكئا﴾</q>{4}. (ز) ٣٧٢٠٢- عن سفيان [بن عيينة] -من طريق ابن أبي عمر- في قوله: <q>﴿سمعت بمكرهن﴾</q>، قال: بِعَمَلِهِنَّ، وقال: كُلُّ مَكْر في القرآن فهو عمل{5}٣٣٥٠. (٨/٢٣٧) ٣٣٥٠ ذَكَر ابنُ عطية (٥/٧٧) أنّ قولهن سُمِّي مكرًا مِن حيث أظهرن إنكار منكرٍ، وقصدن إثارةَ غيظها عليهن. ثم أورد قولًا آخر، فقال: «وقيل: مكْرُهُنَّ أنهن أفشين ذلك عنها، وقد كانت أطْلَعَتْهُنَّ على ذلك، واسْتَكْتَمَتْهُنَّ إيّاه». وعلَّق عليه بقوله: «وهذا لا يكون مكرًا إلا بأن يُظْهِرن لها خلاف ذلك، ويقصدن بالإفشاء أذاها». <q>﴿أَرۡسَلَتۡ إِلَیۡهِنَّ﴾</q> - تفسير ٣٧٢٠٣- قال وهب [بن مُنَبِّه]، في قوله: <q>﴿أرسلت إليهن﴾</q>: اتَّخَذَتْ مأدبة، ودَعَتْ أربعين امرأة، مِنهُنَّ هؤلاء اللاتي عَيَّرْنَها{6}. (ز) ٣٧٢٠٤- قال مقاتل بن سليمان: <q>﴿أرسلت إليهن﴾</q> فجِئْنَها{3}. (ز) <q>﴿وَأَعۡتَدَتۡ لَهُنَّ مُتَّكَـࣰٔا﴾</q> - قراءات، وتفسيرها ٣٧٢٠٥- عن عبد الله بن عباس -من طريق عوف- أنّه كان يقرؤها: (مُتْكًا) مخففة، ويقول: هو الأُتْرُجُّ{8}. (ز) ٣٧٢٠٦- عن عبد الله بن عباس، قال: المتكأ: الأُتْرُنجُ. وكان يقرؤها خفيفةً{9}. (٨/٢٣٨) ٣٧٢٠٧- عن مجاهد بن جبر -من طريق منصور- قال: مَن قرأ: <q>﴿مُتَّكَأً﴾</q> شَدَّها؛ فهو الطعام، ومَن قرأ: (مُتْكًا) خفَّفها؛ فهو الأُتْرُنج{10}. (٨/٢٣٩) ٣٧٢٠٨- عن الحسن البصري -من طريق أبي الأشهب- أنّه كان يقرأ: (مُتَّكَآءً)، ويقول: هو المجلس والطعام{11}. (ز) ٣٧٢٠٩- عن أبان بن تغلب أنّه كان يقرأ: (وأَعْتَدَتْ لَهُنَّ مُتْكًا) مُخَفَّفة، قال: الأُترُنج{12}. (٨/٢٣٩) ٣٧٢١٠- عن عبد الله بن يزيد -من طريق إسحاق-: مَن قرأ: (مُتْكًا) خفيفة يعني: طعامًا، ومَن قرأ: <q>﴿مُتَّكَأً﴾</q> يعني: المُتَّكأَ{13}. (ز) <q>﴿وَأَعۡتَدَتۡ لَهُنَّ مُتَّكَـࣰٔا﴾</q> - تفسير الآية ٣٧٢١١- عن عبد الله بن عباس -من طريق علي- في قوله: <q>﴿وأعتدت لهن متكأ﴾</q>، قال: هَيَّأَتْ لَهُنَّ مجلسًا{14}. (٨/٢٣٨) ٣٧٢١٢- عن عبد الله بن عباس -من طريق مجاهد- <q>﴿وأعتدت لهن متكأ﴾</q>، قال: أعْطَتْهُنَّ أُتْرُنجًا{15}. (٨/٢٣٨) ٣٧٢١٣- قال عبد الله بن عباس: <q>﴿متكأ﴾</q>، أي: طعامًا{16}. (ز) ٣٧٢١٤- عن سعيد بن جبير -من طريق جعفر- في قوله: <q>﴿وأعتدت لهن متكأ﴾</q>، قال: طعامًا وشرابًا ومُتَّكَأً{17}. (٨/٢٣٩) ٣٧٢١٥- عن سعيد بن جبير -من طريق أبي بشر- في قوله: <q>﴿وأعتدت لهن متكأ﴾</q>، قال: طعامًا{18}. (ز) ٣٧٢١٦- عن مجاهد بن جبر -من طريق ليث- في قوله: <q>﴿متكأ﴾</q>، قال: طعامًا{19}. (٨/٢٣٩) ٣٧٢١٧- قال مجاهد بن جبر، في قوله: <q>﴿لهن متكئا﴾</q>، يعني: مجلسًا وتكأة{20}. (ز) ٣٧٢١٨- عن مجاهد بن جبر، في قوله: <q>﴿متكئا﴾</q>، قال: هو الأُترُنج{21}. (٨/٢٣٩) ٣٧٢١٩- عن مجاهد بن جبر -من طريق ابن عيينة، عن رجل-: (مُتْكًا)، قال: كل شيء قُطِع بالسكين{22}. (ز) ٣٧٢٢٠- عن الضحاك بن مزاحم -من طريق أبي رَوْق- في قوله: <q>﴿وأعتدت لهن متكأ﴾</q>، قال: البَزْماوَرْدُ{23}{24}. (ز) ٣٧٢٢١- عن الضحاك بن مُزاحِم -من طريق عبد الواحد بن زياد، عن أبي رَوْق- في قوله: <q>﴿وأعتدت لهن متكأ﴾</q>، قال: أُترُنجًا بعد الغِذاء{25}. (ز) ٣٧٢٢٢- عن عكرمة مولى ابن عباس -من طريق الحكم- في قوله: <q>﴿متكأ﴾</q>، قال: كل شيء يُقطَع بالسكين{25}. (٨/٢٤٠) ٣٧٢٢٣- عن الضَّحّاك بن مُزاحم -من طريق عبيد-، مثله{27}. (٨/٢٤٠) ٣٧٢٢٤- عن عكرمة مولى ابن عباس -من طريق أبي رجاء- في قوله: <q>﴿متكأ﴾</q>، قال: طعامًا{28}. (ز) ٣٧٢٢٥- عن الحسن البصري -من طريق أبي الأشهب- أنّه كان يقرأ: <q>﴿متكأ﴾</q>، ويقول: هو المَجْلِس، والطَّعام{13}. (ز) ٣٧٢٢٦- عن الحسن البصري -من طريق أبي رجاء- في قوله: <q>﴿وأعتدت لهن متكأ﴾</q>، قال: طعامًا{30}. (ز) ٣٧٢٢٧- عن إسماعيل السُّدِّيّ، مثل ذلك{31}. (ز) ٣٧٢٢٨- عن عطية [العوفي] -من طريق ابن إدريس، عن أبيه- <q>﴿وأعتدت لهن متكئا﴾</q>، قال: الطَّعام{32}. (ز) ٣٧٢٢٩- عن قتادة بن دعامة -من طريق سعيد- <q>﴿وأعتدت لهن متكأ﴾</q>، أي: طعامًا{33}. (ز) ٣٧٢٣٠- عن إسماعيل السُّدِّيّ -من طريق أسباط- قال: <q>﴿أرسلت إليهن وأَعتَدَت لهن متكئًا﴾</q> يَتَّكِئْنَ عليه{34}. (٨/١٩١) ٣٧٢٣١- عن سلمة بن تمام أبي عبد الله الشَّقَريِّ، قال: <q>﴿متكأ﴾</q> بكلام الحبش؛ يسمون التُّرُنجَ: مُتُكًا{35}. (٨/٢٣٩) ٣٧٢٣٢- عن ليث [بن أبي سليم] -من طريق جرير- قال: سَمِعتُ بعضَهم يقول: الأترج{36}. (ز) ٣٧٢٣٣- قال مقاتل بن سليمان: <q>﴿وأعتدت لهن متكأ﴾</q>، وهو الأُتْرُج، وكُلُّ شيء يُحَزُّ بالسكين فهو مُتَّكأ{3}. (ز) ٣٧٢٣٤- عن محمد بن إسحاق -من طريق سلمة- قال: <q>﴿وأعتدت لهن متكأ﴾</q>، والمُتَّكأ: الطَّعام{28}. (ز) ٣٧٢٣٥- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- قال: أعْطَتْهُنَّ تُرُنجًا وعسلًا ...{39}. (٨/٢٤٠) ٣٧٢٣٦- قال عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- <q>﴿متكأ﴾</q>: طعامًا{28}. (ز) ٣٧٢٣٧- قال يحيى بن سلّام: وهي تقرأ (مُتكًا)، قال بعضهم: هو الأُتْرُج{41}٣٣٥١. (ز) ٣٣٥١ ذكر ابنُ جرير (١٣/١٢٣) أنّ المتكأ يعني: ما يُتَّكأ عليه من النمارق والوسائد. ثم وجَّه (١٣/١٢٤) تفسير المتكأ بالطعام بقوله: «فسّر بعضهم المتكأ بأنّه: الطعام، على وجه الخبر عن الذي أُعِدَّ من أجله المتكأ، وبعضهم عن الخبر عن الأترج، إذ كان في الكلام: وآتت كلَّ واحدة منهن سكينًا؛ لأنّ السكين إنما تعد للأترج وما أشبهه مما يقطع به. وبعضهم على البزماورد». وبنحوه قال ابنُ عطية (٥/٧٧). <q>﴿وَءَاتَتۡ كُلَّ وَ ٰ⁠حِدَةࣲ مِّنۡهُنَّ سِكِّینࣰا﴾</q> - تفسير ٣٧٢٣٨- عن عبد الله بن عباس -من طريق علي- في قوله: <q>﴿وأعتدت لهن متكأ﴾</q>، قال: هيَّأت لَهُنَّ مجلسًا، وكان سُنَّتُهم إذا وضعوا المائدة أعْطَوا كُلَّ إنسان سِكِّينًا يأكل بها{42}. (٨/٢٣٨) ٣٧٢٣٩- عن عبد الله بن عباس -من طريق مجاهد- <q>﴿وأعتدت لهن متكأ﴾</q>، قال: أعْطَتْهُنَّ أُتْرُنجًا، وأَعْطَتْ كُلَّ واحدةٍ مِنهُنَّ سكينًا، فلمّا رأين يوسفَ أكْبَرْنَه، وجَعَلْنَ يُقَطِّعنَّ أيديَهن، وهُنَّ يَحسبنَ أنّهُنَّ يُقَطِّعن الأُترُنجَ{43}. (٨/٢٣٨) ٣٧٢٤٠- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿وآتت كل واحدة منهن سكينا﴾</q>، قال: أعْطَتْ كُلَّ واحدةٍ مِنهُنَّ سكينًا{44}. (ز) ٣٧٢٤١- عن إسماعيل السُّدِّيّ -من طريق أسباط- قال: <q>﴿وآتت كل واحدة منهن سكينًا﴾</q>، وأُترُجًا يَأْكُلْنَه{45}. (٨/١٩١) ٣٧٢٤٢- قال مقاتل بن سليمان: <q>﴿وآتت﴾</q> يعني: وأَعْطَتْ <q>﴿كل واحدة منهن سكينا﴾</q>، وأمرت يوسفَ ﵇ فتَزَيَّنَ، وتَرَجَّل{3}. (ز) ٣٧٢٤٣- عن محمد بن إسحاق -من طريق سلمة-: <q>﴿وآتت كل واحدة منهن سكينا﴾</q> لِيَحْتَزِزْن به مِن طعامِهِنَّ{47}. (ز) ٣٧٢٤٤- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- قال: أعْطَتْهُنَّ تُرُنجًا وعَسَلًا، فكُنَّ يَحْزُزْن التُّرُنجَ بالسكين، ويأكلن بالعسل ...{39}. (٨/٢٤٠) <q>﴿وَقَالَتِ ٱخۡرُجۡ عَلَیۡهِنَّۖ فَلَمَّا رَأَیۡنَهُۥۤ أَكۡبَرۡنَهُۥ﴾</q> - تفسير ٣٧٢٤٥- عن عبد الله بن عباس -من طريق علي- في قوله: <q>﴿فلما رأينه﴾</q> قال: فلمّا خرج عليهن يوسف <q>﴿أكبرنه﴾</q> قال: أعْظَمْنَه، ونظرن إليه، وأقبَلن يَحْزُزنَ أيديَهن بالسكاكين وهُنَّ يَحْسَبْنَ أنّهُنَّ يُقَطِّعنَ الطعام{49}. (٨/٢٣٨) ٣٧٢٤٦- عن عبد الله بن عباس -من طريق عبد الصمد بن علي بن عبد الله بن عباس، عن أبيه، عن جدِّه- في قوله: <q>﴿فلما رأينه أكبرنه﴾</q>، قال: لَمّا خرج عليهن يوسف حِضْنَ مِن الفرح، وقال الشاعر: نأتي النساء لدى إطهارِهنَّ ولا نأتي النساء إذا أكْبرنَ إكبارا{50}٣٣٥٢. (٨/٢٤١) ٣٣٥٢ انتَقَد ابنُ جرير (١٣/١٣٢) هذا القول مستندًا إلى اللغة، والدلالة العقلية، بقوله: «وهذا القول، ... إن لم يكن عُني به أنّهُنَّ حِضْنَ مِن إجلالهن يوسف وإعظامهن لِما كان الله قَسَمَ له مِن البهاء والجمال، ولِما يجد مِن مثل ذلك النساء عند معاينتهن إياه؛ فقولٌ لا معنى له؛ لأن تأويل ذلك: فلما رأين يوسف أكبرنه. فالهاء التي في <q>﴿أكبرنه﴾</q> مِن ذكر يوسف، ولا شكَّ أنّ مِن المحال أن يَحِضْنَ يوسفَ»، ثم وجّهه بقوله: «ولكن الخبر إن كان صحيحًا عن ابن عباس على ما رُوِي فخليقٌ أن يكون كان معناه في ذلك: أنّهُنَّ حِضْنَ لِما أكبرن مِن حسن يوسف وجماله في أنفسهن، ووجدن ما يجد النساء من مثل ذلك». ثم بيَّن أنّ البيت المروي في ذلك لا أصل له، لأنه ليس بالمعروف عند الرواة. وانتقده ابنُ عطية (٥/٧٩) مستندًا إلى اللغة، فقال: «وهذا قول ضعيف، ومعناه منكور، والبيت مصنوع مختلق، كذلك قال الطبري وغيره من المحققين، وليس عبد الصمد مِن رواة العِلم». ٣٧٢٤٧- قال أبو العالية الرياحي، في قوله: <q>﴿فلما رأينه أكبرنه﴾</q>: هالَهُنَّ أمرُه، وبُهِتْنَ{51}. (ز) ٣٧٢٤٨- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿فلما رأينه أكبرنه﴾</q>، قال: أعْظَمْنه{52}. (٨/٢٤١) ٣٧٢٤٩- عن قتادة بن دعامة -من طريق سعيد- <q>﴿فلما رأينه أكبرنه﴾</q>، أي: أعْظَمْنَه{53}. (ز) ٣٧٢٥٠- عن إسماعيل السُّدِّيّ -من طريق أسباط- قال: وقالت ليوسف: <q>﴿اخرج عليهن﴾</q>. فلمّا خرج ورأى النسوةُ يوسفَ أعْظَمْنَه{54}. (٨/١٩١) ٣٧٢٥١- عن عبد العزيز بن الوزير بن الكُمَيتِ بن زيد بن الكُمَيتِ الشاعر قال: حدَّثني أبي، عن جدِّي، قال: سمعت جدِّي الكُمَيت يقول في قوله: <q>﴿فلما رأينه أكبرنه﴾</q>، قال: أمْنَيْنَ، وأنشَدَ في ذلك: لَمّا رأته الخيلُ مِن رأس شاهِقٍ صَهَلن وأمَنين المَنِيَّ الـمُدَفَّقا{12}. (٨/٢٤١) ٣٧٢٥٢- قال مقاتل بن سليمان: <q>﴿وقالت﴾</q> أي: ثُمَّ قالت: يا يوسف، <q>﴿اخرج عليهن﴾</q> مِن البيت. <q>﴿فلما رأينه أكبرنه﴾</q> يعني: أعْظَمْنَه{56}. (ز) ٣٧٢٥٣- عن محمد بن إسحاق -من طريق سلمة- قال: قالت ليوسف: <q>﴿اخرج عليهن﴾</q>. فخرج عليهن، <q>﴿فلما رأينه أكبرنه﴾</q>، وغُلِبَت عقولُهُنَّ عجبًا حين رأينه، فجعلن يقطعن أيديهن بالسكاكين التي مَعَهُنَّ، ما يَعْقِلْنَ شيئًا مِمّا يَصْنَعْنَ، وقلن: <q>﴿حاش لله ما هذا بشرا﴾</q>{57}. (ز) ٣٧٢٥٤- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- قال: فلما قيل له: <q>﴿اخرج عليهن﴾</q>. خرج، <q>﴿فلما رأينه﴾</q> أعْظَمْنَه، وتَهَيَّمْنَ به{58}. (٨/٢٤٠) ٣٧٢٥٥- عن دريد بن مجاشع، عن بعض أشياخه، قال: قالت للقَيِّم: أدْخِلْهُ عليهِنَّ، وألبسه ثيابًا بيضًا؛ فإنّ الجميل أحسنُ ما يكون في البياض ...{59}. (٨/٢٤٠) <q>﴿وَقَطَّعۡنَ أَیۡدِیَهُنَّ﴾</q> - تفسير ٣٧٢٥٦- عن عبد الله بن عباس -من طريق مجاهد- في قوله: <q>﴿وقطعن أيديهن﴾</q>، قال: لَمّا رَأَيْن يوسف جَعَلْنَ يُقطِّعْنَ أيديَهُنَّ، وهُنَّ يَحْسَبْنَ أنّهُنَّ يُقطعْنَ الأُترُجَّ{60}. (٨/٢٣٨) ٣٧٢٥٧- عن مجاهد بن جبر -من طريق ورقاء عن ابن أبي نَجِيح- قوله: <q>﴿وقطعن أيديهن﴾</q>: حزًّا حزًّا بالسكين حتى ألْقَيْنها{61}. (٨/٢٤١) ٣٧٢٥٨- عن مجاهد بن جبر -من طريق معمر عن ابن أبي نجيح- في قوله: <q>﴿وقطعن أيديهن﴾</q>، قال: قطعن أيديهن حتى ألْقَيْنها{62}. (ز) ٣٧٢٥٩- قال مجاهد بن جبر: فما أحْسَسْنَ إلا بالدَّم{51}. (ز) ٣٧٢٦٠- قال وهب [بن مُنَبِّه]: وبلغني: أنّ تِسعًا مِن الأربعين مُتْنَ في ذلك المجلس وجْدًا بيوسف{64}. (ز) ٣٧٢٦١- عن مُنَبِّه، عن أبيه، قال: مات مِن النسوة اللّاتي قَطَّعْنَ أيديهنَّ تسع عشرة امرأة كَمَدًا{12}. (٨/٢٤٣) ٣٧٢٦٢- عن قتادة بن دعامة -من طريق محمد بن ثور، عن مَعْمَر- <q>﴿وقطعن أيديهن﴾</q>، قال: جَعَلْنَ يَحْزُزْنَ أيديَهُنَّ، ولا يَشْعُرْن بذلك{66}. (ز) ٣٧٢٦٣- عن قتادة بن دعامة -من طريق عبد الرزاق، عن مَعْمَر- في قوله: <q>﴿وقطعن أيديهن﴾</q>، قال: قَطَّعن أيديهن حتى ألْقَيْنَها{67}. (ز) ٣٧٢٦٤- عن إسماعيل السُّدِّيّ -من طريق أسباط- قال: وجَعَلْنَ يَحزُزْنَ أيديَهُنَّ وهنَّ يحسبن أنّهُنَّ يُقَطِّعن الأُتْرُجَّ، ويَقُلْن: <q>﴿حاش لله ما هذا بشرًا إن هذا إلا ملك كريم﴾</q>{68}. (٨/١٩١) ٣٧٢٦٥- عن إسماعيل السُّدِّيّ -من طريق علي بن عابس- قال: كانت في أيديهن سكاكين مع الأُتْرُج، فقطعن أيديهن، وسالت الدماء، فقُلْنَ: نحن نلومُكِ على حُبِّ هذا الرجل، ونحن قد قطعنا أيدينا وسالت الدماء!{69}. (ز) ٣٧٢٦٦- عن زيد بن أسلم -من طريق يحيى بن العلاء- قال: لَمّا قرَرْنَ وطابت أنفُسُهُنَّ قالت لقيِّمِها: آتِهن تُرُنجًا وسكاكين. فأتاهُنَّ بِهِنَّ، فجعلْنَ يُقطعن ويأكلن، فقالت لهن: هل لَكُنَّ في النظر إلى يوسف؟ قلن: ما شئتِ. فأمَرَتْ قَيِّمَها، فأدخله عليهِنَّ، فلما رأينه جعَلن يقطعن أصابعهن مع الأُترُنجِ وهُنَّ لا يَشْعُرْن، ولا يجدن ألَمًا مِمّا رأين مِن حُسنه، فلمّا ولّى عَنْهُنَ قالت: هذا الذي لُمْتُنّنِي فيه، فلقد رأيتُكُنَّ تُقَطِّعْنَ أيديكُنَّ وما تَشْعُرْنَ. قال: فنظَرن إلى أيديهن، فجَعَلْنَ يصِحْنَ ويبكينَ. قالت: فكيف أصنع أنا؟! فقلن: <q>﴿حاش لله ما هذا بشرًا إن هذا إلا ملك كريم﴾</q>، وما نرى عليكِ مِن لَوْمٍ بعد الذى رأينا{70}. (٨/٢٤٢) ٣٧٢٦٧- قال مقاتل بن سليمان، في قوله: <q>﴿وقطعن أيديهن﴾</q>، يعني: وحَزَزْنَ أصابعهن بالسكين حين نَظَرْنَ إليه{56}. (ز) ٣٧٢٦٨- عن محمد بن إسحاق -من طريق سلمة- قال: قالتْ ليوسف: <q>﴿اخرج عليهن﴾</q>. فخرج عليهن، <q>﴿فلما رأينه أكبرنه﴾</q>، وغُلِبَتْ عقولهن عجبًا حين رأينه، فجعلن يقطعن أيديهن بالسكاكين التي معهن، ما يعقلن شيئًا مِمّا يصنعن، وقلن: <q>﴿حاش لله ما هذا بشرا﴾</q>{66}. (ز) ٣٧٢٦٩- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- قال: حتى جعلن يحززن أيديهن بالسكين، وفيها التُّرُنج، ولا يَعْقِلْنَ، لا يحسبن إلا أنّهُنَّ يَحْزُزْنَ الأُترُنج، قد ذَهَبَتْ عُقُولُهُنَّ مِمّا رَأَيْنَ{73}. (٨/٢٤٠) ٣٧٢٧٠- عن دريد بن مجاشع، عن بعض أشياخه، قال:... فأدخله عليهِنَّ وهُنَّ يَحْزُزْنَ ما في أيديهن، فلمّا رأينه حَزَزْن أيديهن وهُنَّ لا يَشْعُرْنَ مِن النظر إليه، فنظرن إليه مُقْبِلًا، ثم أومَأت إليه: أن ارجع. فنظَرن إليه مُدْبِرًا وهُنَّ يحززن أيديهن بالسكاكين، لا يَشْعُرْنَ بالوَجَع مِن نظرِهِنَّ إليه، فلمّا خرج نَظَرْن إلى أيدِيهن، وجاء الوَجَعُ، فجَعَلْنَ يُوَلْوِلْنَ، وقالت لهن: أنتُنَّ مِن ساعة واحدة هكذا صنَعتُنَّ، فكيف أصنع أنا؟! <q>﴿وقلن حاش لله ما هذا بشرًا إن هذا إلا ملك كريم﴾</q>{74}٣٣٥٣. (٨/٢٤٠) ٣٣٥٣ اختُلِف في المراد بقوله: <q>﴿وقطعن أيديهن﴾</q> على قولين: الأول: أنّ المعنى: أنهن جرحن، وهن يحسبن أنهن يقطعن الأترج. الثاني: أنهن قطعن أيديهن حتى أبنّها وألقينها. ورجَّح ابنُ جرير (١٣/١٣٥) جوازهما، مع عدم القطع بأحدهما؛ لعدم الدليل على تعيين أحدهما، فقال: «والصواب من القول في ذلك أن يُقال: إنّ الله أخبر عنهن أنهن قطعن أيديهن وهن لا يشعرن لإعظام يوسف، وجائز أن يكون ذلك كان قطعًا بإبانة، وجائز أن يكون كان قطعَ حزٍّ وخَدْش، ولا قول في ذلك أصوب من التسليم لظاهر التنزيل». وانتقد ابنُ عطية (٥/٧٩) القول الثاني الذي قاله مجاهد، وقتادة مستندًا للدلالة العقلية، فقال: «وذلك ضعيف من معناه، وذلك أنّ قطع العظم لا يكون إلا بشدة، ومحال أن يسهو أحدٌ عنها، والقطع على المفصل لا يتهيأ إلا بتلطف لا بد أن يُقصد». ورجَّح القولَ الأول، فقال: «والذي يُشْبِه أنّهُنَّ حملن على أيديهن الحملَ الذي كُنَّ يحملنه قبل المتْك، فكان ذلك حزًّا، وهذا قول الجماعة». <q>﴿وَقُلۡنَ حَـٰشَ لِلَّهِ مَا هَـٰذَا بَشَرًا إِنۡ هَـٰذَاۤ إِلَّا مَلَكࣱ كَرِیمࣱ ۝٣١﴾</q> - قراءات ٣٧٢٧١- عن أسِيدِ بن يزيد: أنّ في مصحف عثمان: <q>﴿وقُلْنَ حاشَ للهِ﴾</q>، ليس فيها ألف{75}. (٨/٢٤٢) <q>﴿وَقُلۡنَ حَـٰشَ لِلَّهِ﴾</q> - تفسير ٣٧٢٧٢- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿وقُلن حاش لله﴾</q>، قال: مَعاذ الله{76}. (٨/٢٤١) ٣٧٢٧٣- عن الحسن البصري -من طريق عمرو- <q>﴿حاش لله﴾</q>: مَعاذ الله{77}. (ز) ٣٧٢٧٤- قال مقاتل بن سليمان: <q>﴿وقلن حاش لله﴾</q>، يعني: مَعاذ الله{56}. (ز) <q>﴿مَا هَـٰذَا بَشَرًا إِنۡ هَـٰذَاۤ إِلَّا مَلَكࣱ كَرِیمࣱ ۝٣١﴾</q> - قراءات ٣٧٢٧٥- عن أبي الحُوَيْرِث الحنفي -من طريق دعامة بن رجاء التيمي- أنّه قرأها: (ما هَذا بِشِرًى). أي: ما هذا بِمُشْتَرًى{79}٣٣٥٤. (٨/٢٤٢) ٣٣٥٤ اختُلِف في قراءة قوله: <q>﴿ما هذا بشرا﴾</q>؛ فقرأ قوم: <q>﴿بشرا﴾</q>. وقرأ آخرون: <q>﴿بشرى﴾</q>. وذكر ابنُ جرير (١٣/١٤٠) أنّ القراءة الأولى قرأ بها عامة قراء الأمصار، وانتقد القراءة الثانية مستندًا لإجماع القراء، فقال: «وهذه القراءة لا أستجيز القراءة بها؛ لإجماع قُرّاء الأمصار على خلافها». <q>﴿مَا هَـٰذَا بَشَرًا إِنۡ هَـٰذَاۤ إِلَّا مَلَكࣱ كَرِیمࣱ ۝٣١﴾</q> - تفسير الآية ٣٧٢٧٦- عن قتادة بن دِعامة -من طريق مَعْمَر- في قوله: <q>﴿إن هذا إلا ملك كريم﴾</q>، قال: قلن: مَلَكٌ مِن الملائكة. مِن حُسْنِه{80}. (٨/٢٤٢) ٣٧٢٧٧- قال مقاتل بن سليمان: <q>﴿ما هذا بشرا﴾</q> إنسانًا، <q>﴿إن هذا إلا ملك كريم﴾</q> يعني: حَسَن. فأعجبها ما صَنَعْنَ، وما قُلْنَ{56}. (ز) ٣٧٢٧٨- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- قال: وقُلْنَ: <q>﴿حاش لله ما هذا بشرًا﴾</q>: ما هكذا يكون البشر؛ ما هذا إلا مَلَك كريم{82}٣٣٥٥. (٨/٢٤٠) ٣٣٥٥ ذكر ابنُ عطية (٥/٧٨) أنّ مكيًّا والمهدوي ذكرا أنّه قيل: إنّ في الآية تقديمًا وتأخيرًا في القصص، وذلك أنّ قصة النسوة كانت قبل فضيحتها في القميص للسيِّد، وباشتهار الأمر للسيد انقطع ما بينها وبين يوسف. وعلَّق عليه بقوله: «وهذا مُحْتَمَل، إلا أنّه لا يلزم مِن ألفاظ الآية، بل يحتمل أن كانت قصة النساء بعد قصة القميص، وذلك أنّ العزيز كان قليل الغيرة، بل قومه أجمعون، ألا ترى أنّ الإنكار في وقت القميص إنما كان بأن قيل: <q>﴿إنه من كيدكن إن كيدكن عظيم﴾</q>. وهذا يَدُلُّ على قلة الغيرة، ثم سكن الأمر بأن قال: <q>﴿يوسف أعرض عن هذا﴾</q>، وأنت <q>﴿واستغفري﴾</q>، وهي لم تبق حينئذ إلا على إنكارها، وإظهار الصِّحَّة، فلذلك تُغُوفِل عنها بعد ذلك؛ لأنّ دليل القميص لم يكن قاطعًا، وإنّما كان أمارةً ما، هذا إن لم يكن المتكلم طفلًا». <q>﴿مَا هَـٰذَا بَشَرًا إِنۡ هَـٰذَاۤ إِلَّا مَلَكࣱ كَرِیمࣱ ۝٣١﴾</q> - آثار متعلقة بالآية ٣٧٢٧٩- عن أنس، عن النبي ﷺ، قال: «أُعطِيَ يوسف وأمُّه شَطْرَ الحُسْن»{83}. (٨/٢٤٣) ٣٧٢٨٠- عن الحسن، أنّ النبي ﷺ قال: «أُعطِيَ يوسف وأمه ثُلُث حُسْن أهل الدنيا، وأُعطِيَ الناس الثلثين»{84}٣٣٥٦. (٨/٢٤٤) ٣٣٥٦ ساق ابنُ عطية (٥/٨٢) هذه الآثار، ثم علَّق بقوله: «هذا على جهة التمثيل، أي: لو كان الحسن مما يُقْسَم لكان حُسْن يوسف يقع في نصفه، فالقصد: أن يقع في نفس السامع عظم حُسْنِه، على نحو التشبيه برؤوس الشياطين، وأنياب الأغوال». ٣٧٢٨١- عن أبي سعيد الخدري، قال: قال رسول الله ﷺ: «رأيتُ ليلة أسري بي إلى السماءِ يوسفَ كالقَمَر ليلة البدر»{85}. (ز) ٣٧٢٨٢- عن عبد الله بن مسعود -من طريق أبي الأَحْوَص- قال: أُعطِيَ يوسف وأمُّه ثُلُث الحُسْن{86}. (٨/٢٤٣) ٣٧٢٨٣- عن عبد الله بن مسعود -من طريق أبي الأحوص- قال: كان وجهُ يوسف مثلَ البَرْق، وكانت المرأةُ إذا أتته لِحاجة غَطّى وجهَه مخافة أن تُفْتَن به{87}. (٨/٢٤٣) ٣٧٢٨٤- عن عبد الله بن مسعود -من طريق أبي الأحوص- قال: أُوتِي يوسف ﵇ وأمُّه ثُلُثَ حُسْن خلق الناس؛ في الوجه، والبياض، وغير ذلك{88}. (٨/٢٤٤) ٣٧٢٨٥- عن عبد الله بن عباس -من طريق مُقاتِل- قال: قسم الله الحُسْنَ عشرة أجزاء؛ فجعل منها ثلاثةَ أجزاء في حوّاء، وثلاثة أجزاء في سارة، وثلاثة أجزاء في يوسف، وجزءًا في سائر الخلق، وكانت سارةُ مِن أحْسَنِ نِساء أهل الأرض، وكانت مِن أشد النساء غيرةً{89}. (٨/٢٤٤) ٣٧٢٨٦- عن كعب الأحبار -من طريق الحسن، عن سمرة- قال: قسَم اللهُ ليوسف مِن الجمال الثلثين، وقسَم بين عباده الثُّلُث، وكان يُشبِهُ آدمَ يوم خلقه الله، فلمّا عصى آدمُ نُزِع منه النور والبهاء والحسن، ووهُبِ له ثلث مِن الجمال مع التوبة، فأعطى الله ليوسف ذلك الثلثين، وأعطاه تأويل الرُّؤْيا، وإذا تبسَّم رأيتَ النور في ضواحِكه{90}. (٨/٢٤٥) ٣٧٢٨٧- عن ربيعة الجُرَشي -من طريق مجاهد- قال: قُسِم الحُسْنُ نصفين؛ فجُعِل ليوسف وسارة النصف، وقُسِم النصف الآخر بين سائر الناس{91}. (٨/٢٤٥) ٣٧٢٨٨- عن عكرمة مولى ابن عباس، قال: كان فضلُ حُسْنِ يوسف على الناس كفضل القمر ليلة البدر على نجوم السماء{92}. (٨/٢٤٥) ٣٧٢٨٩- عن الحسن البصري -من طريق يونس- قال: قُسِم الحُسنُ ثلاثة أثلاثٍ؛ فأُعطِيَ يوسف الثُّلُث، وقُسِم الثُلُثان بين الناس، فكان أحسنَ الناس{93}. (٨/٢٤٥) ٣٧٢٩٠- عن إسحاق بن عبد الله، قال: كان يوسفَ ﵇ إذا سار في أزِقَّةِ مصر يُرى تَلَأْلُؤُ وجهه على الجدران، كما يُرى تَلَأْلُؤُ الماءِ والشمسِ على الجدران{12}. (٨/٢٤٤) ٣٧٢٩١- قال مقاتل بن سليمان: كان أُعْطِي يوسفُ في زمانه ثُلُث الحُسْن، وأتاه الحُسْنُ مِن قِبَل جدِّه إسحاق، مِن قِبَل أُمِّه سارة، ووَرِثَتْ سارة حُسْنَها مِن قِبَل حواء امرأة آدم ﵇، وحُسْنُ حواء مِن آدم؛ لأنّها خُلِقَت منه. وقال مقاتل: كلُّ ذكر أحسن مِن الأنثى، من الأشياء كلها، وفضلُ يوسف في زمانه بحُسْنِه على الناس كفضل القمر ليلة البدر على الكواكب{3}. (ز) ٣٧٢٩٢- قال محمد بن إسحاق: ذهب يوسفُ وأمُّه بثُلُثِي الحُسْن{96}. (ز) ",footnotes:1:أخرجه ابن جرير ١٣/١٢٢، وابن أبي حاتم ٧/٢١٣٢.أخرجه ابن جرير ١٣/١٢٢، وابن أبي حاتم ٧/٢١٣٣.تفسير مقاتل بن سليمان ٢/٣٣١.أخرجه ابن جرير ١٣/١٢٢.أخرجه ابن أبي حاتم ٧/٢١٣٢.تفسير الثعلبي ٥/٢١٧، وتفسير البغوي ٤/٢٣٧.تفسير مقاتل بن سليمان ٢/٣٣١.أخرجه ابن جرير ١٣/١٢٦. وعزاه الحافظ ابن حجر في الفتح ٨/٣٥٩ إلى عبد بن حميد. وهي قراءة شاذة، تروى أيضًا عن ابن عمر، والجحدريّ وغيرهما. انظر: المحتسب ١/٣٣٩.أخرجه مسدد -كما في المطالب العالية (٤٠١٨)-، وابن جرير ١٣/١٢٦ من طريق مجاهد بلفظ: الترنج، دون الإشارة للقراءة، وابن أبي حاتم ٧/٢١٣٢. وعزاه السيوطي إلى ابن المنذر، وأبي الشيخ، وابن مردويه.أخرجه ابن جرير ١٣/١٢٧ بلفظ: الأترج، وابن أبي حاتم ٧/٢١٣٣. وعزاه السيوطي إلى أبي عبيد، وابن المنذر، وأبي الشيخ. و<q>﴿مُتَّكَأً﴾</q> بالتشديد هي قراءة العشرة.أخرجه ابن جرير ١٣/١٢٣، وابن أبي حاتم ٧/٢١٣٣ من طريق أبي رجاء. وهي قراءة شاذة. انظر: مختصر ابن خالويه ص٦٨، والمحتسب ١/٣٣٩.عزاه السيوطي إلى أبي الشيخ.أخرجه ابن جرير ١٣/١٢٣.أخرجه ابن جرير ١٣/١٢٣. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم، وأبي الشيخ. وهو عند ابن أبي حاتم ٧/٢١٣٢ من طريق الضحاك بلفظ: وهَيَّأت لهن متكأ. وفي تفسير الثعلبي ٥/٢١٧ بلفظ: مجلسًا للطعام وما يَتَّكِئْنَ عليه مِن النمارق والوسائد.أخرجه ابن جرير ١٣/١٢٥، ١٣٤ بلفظ: أعطتهن أُتْرُجًَّا. وعزاه السيوطي إلى ابن مردويه.تفسير البغوي ٤/٢٣٧.أخرجه ابن جرير ١٣/١٢٣، ١٢٦. وعزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ١٣/١٢٦. وعلَّقه ابن أبي حاتم ٧/٢١٣٣.أخرجه ابن جرير ١٣/١٢٧. وعلَّقه ابن أبي حاتم ٧/٢١٣٣. وعزاه السيوطي إلى ابن أبي شيبة، وابن المنذر.ذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٢/٣٢٣-.عزاه السيوطي إلى أبي عبيد، وابن المنذر.أخرجه سفيان بن عيينة في تفسيره -كما في الفتح ٨/٣٥٨-. وعلَّقه البخاري ٤/١٧٢٧.قال في القاموس: الزُّماوَرْدُ -بالضمّ-: طعام من البيض واللحم، والعامة تقول: بَزْماوَرْد. (ورد).أخرجه ابن جرير ١٣/١٢٤ من طريق إبراهيم بن الزبرقان عن أبي رَوْق، وابن أبي حاتم ٧/٢١٣٣ من طريق معاوية بن حفص عن أبي رَوْق.أخرجه ابن أبي حاتم ٧/٢١٣٣.أخرجه ابن أبي حاتم ٧/٢١٣٣.أخرجه ابن جرير ١٣/١٢٨. وعزاه السيوطي إلى أبي الشيخ.أخرجه ابن جرير ١٣/١٢٨.أخرجه ابن جرير ١٣/١٢٣.أخرجه ابن جرير ١٣/١٢٦، وابن أبي حاتم ٧/٢١٣٣.علَّقه ابن أبي حاتم ٧/٢١٣٣.أخرجه ابن جرير ١٣/١٢٦، وابن أبي حاتم ٧/٢١٣٣ بلفظ: طعامًا وشرابًا وتكًا.أخرجه عبد الرزاق ١/٣٢٢ من طريق مَعْمَر، وابن جرير ١٣/١٢٨. وعلَّقه ابن أبي حاتم ٧/٢١٣٣.أخرجه ابن جرير ١٣/١٢٣، وابن أبي حاتم ٧/٢١٣٣.أخرجه ابن أبي حاتم ٧/٢١٣٢-٢١٣٣. وعزاه السيوطي إلى أبي الشيخ.أخرجه ابن جرير ١٣/١٢٧.تفسير مقاتل بن سليمان ٢/٣٣١.أخرجه ابن جرير ١٣/١٢٨.أخرجه ابن جرير ١٣/١٢٩، وابن أبي حاتم ٧/٢١٣٤ من طريق أصبغ. وعزاه السيوطي إلى أبي الشيخ.أخرجه ابن جرير ١٣/١٢٨.تفسير ابن أبي زمنين ٢/٣٢٣.أخرجه ابن جرير ١٣/١٣٢، ١٣٤ بنحوه، وابن أبي حاتم ٧/٢١٣٢، ٢١٣٤-٢١٣٦. وعزاه السيوطي إلى ابن المنذر، وأبي الشيخ.أخرجه ابن جرير ١٣/١٢٥، ١٣٤ بلفظ: الأترج. وعزاه السيوطي إلى ابن مردويه.تفسير مجاهد ص٣٩٥.أخرجه ابن جرير ١٣/١٢٩، وابن أبي حاتم ٧/٢١٣٤.تفسير مقاتل بن سليمان ٢/٣٣١.أخرجه ابن جرير ١٣/١٢٩.أخرجه ابن جرير ١٣/١٢٩، وابن أبي حاتم ٧/٢١٣٤ من طريق أصبغ. وعزاه السيوطي إلى أبي الشيخ.أخرجه ابن جرير ١٣/١٣٢، ١٣٤، وابن أبي حاتم ٧/٢١٣٢، ٢١٣٤-٢١٣٦. وعزاه السيوطي إلى ابن المنذر، وأبي الشيخ.أخرجه ابن جرير ١٣/١٣٢، وابن أبي حاتم ٧/٢١٣٤-٢١٣٥. وعزاه السيوطي إلى ابن المنذر.تفسير الثعلبي ٥/٢١٨، وتفسير البغوي ٤/٢٣٨.أخرجه ابن جرير ١٣/١٣٠-١٣١، وابن أبي حاتم ٧/٢١٣٦. وعزاه السيوطي إلى ابن أبي شيبة، وابن المنذر، وأبي الشيخ.أخرجه ابن جرير ١٣/١٣١.أخرجه ابن جرير ١٣/١٣١ مختصرًا بلفظ: عَظَّمْنه، مِن طريق أسباط، وبلفظ: أعظمنه، مِن طريق علي بن عابس، وابن أبي حاتم ٧/٢١٣٥.عزاه السيوطي إلى أبي الشيخ.تفسير مقاتل بن سليمان ٢/٣٣٢.أخرجه ابن جرير ١٣/١٣٤، وابن أبي حاتم ٧/٢١٣٥ مختصرًا.أخرجه ابن جرير ١٣/١٣١ بلفظ: أعظمنه وبُهِتْنَ، وابن أبي حاتم ٧/٢١٣٥ من طريق أصبغ بلفظ: أعظمنه وبُهِتْنَ. وعزاه السيوطي إلى أبي الشيخ.أخرجه ابن أبي حاتم ٧/٢١٣٤-٢١٣٥.أخرجه ابن جرير ١٣/١٣٤. وعزاه السيوطي إلى ابن مردويه.أخرجه ابن جرير ١٣/١٣٥، وابن أبي حاتم ٧/٢١٣٦. وعزاه السيوطي إلى ابن أبي شيبة، وابن المنذر، وأبي الشيخ.أخرجه عبد الرزاق ١/ ٣٢٢، وابن جرير ١٣/١٣٥.تفسير الثعلبي ٥/٢١٨، وتفسير البغوي ٤/٢٣٨.تفسير الثعلبي ٥/٢١٨. وفي تفسير البغوي ٤/٢٣٨: ماتت جماعة منهن.عزاه السيوطي إلى أبي الشيخ.أخرجه ابن جرير ١٣/١٣٤.أخرجه عبد الرزاق في تفسيره ١/٣٢٢، وابن جرير ١٣/١٣٥.أخرجه ابن جرير ١٣/١٣٣، وابن أبي حاتم ٧/٢١٣٧.أخرجه ابن جرير ١٣/١٣٣.أخرجه ابن أبي حاتم ٧/٢١٣٧.تفسير مقاتل بن سليمان ٢/٣٣٢.أخرجه ابن جرير ١٣/١٣٤.أخرجه ابن جرير ١٣/١٣٤ بلفظ: الترنج. وعزاه السيوطي إلى أبي الشيخ، وابن أبي حاتم.أخرجه ابن أبي حاتم ٧/٢١٣٥.أخرجه ابن أبي داود في المصاحف ص٣٨. وعزاه السيوطي إلى الخطيب في تالي التلخيص. وهي قراءة العشرة ما عدا أبا عمرو، فإنه قرأ: ‹حاشا› بألف بعد الشين. انظر: النشر ٢/٢٩٥، والإتحاف ص٣٣١.أخرجه ابن جرير ١٣/١٣٩، وابن أبي حاتم ٧/٢١٣٦. وعزاه السيوطي إلى ابن أبي شيبة، وابن المنذر، وأبي الشيخ.أخرجه ابن جرير ١٣/١٣٩.تفسير مقاتل بن سليمان ٢/٣٣٢.أخرجه ابن جرير ١٣/١٤٠. وهي قراءة شاذة، تروى أيضًا عن ابن مسعود. انظر: مختصر ابن خالويه ص٦٨، والمحتسب ١/٣٤٢.أخرجه عبد الرزاق ١/٣٢٢-٣٢٣، وابن جرير ١٣/١٤١، وابن أبي حاتم ٧/٢١٣٧. وعزاه السيوطي إلى ابن المنذر، وأبي الشيخ.تفسير مقاتل بن سليمان ٢/٣٣٢.أخرجه ابن جرير ١٣/١٤٠، وابن أبي حاتم ٧/٢١٣٧ من طريق أصبغ وفي آخره: فأقَرَّت لَهُنَّ. وعزاه السيوطي إلى أبي الشيخ.أخرجه أحمد ٢١/٤٤١ (١٤٠٥٠)، والحاكم ٢/٦٢٢ (٤٠٨٢)، وابن جرير ١٣/١٣٦، وابن أبي حاتم ٧/٢١٣٦ (١١٥٥٩). وأصله في مسلم ١/١٤٥-١٤٦ (١٦٢) مطولًا. قال الحاكم: «هذا حديث صحيح على شرط مسلم ولم يخرجاه». ووافقه الذهبي في التلخيص. وقال ابن عدي في الكامل ٧/١٠٥ (١٥٥٠) في ترجمة: عفان بن مسلم أبو عثمان الصغار: «وهذا الحديث ما أعلم رفعه أحد غير عفان وغيره أوقفه عن حماد بن سلمة، وعفان أشهر وأوثق وأصدق وأوثق من أن يقال فيه شيء مما ينسب إلى الضعف». وقال ابن القيسراني في ذخيرة الحفاظ ١/٤٢١ (٥٥٨): «رواه عفان بن مسلم الصفار: عن حماد بن سلمة، عن ثابت، عن أنس. وهذا لا أعلم رفعه غير عفان، وغيره وقفه على حماد بن سلمة، وعفان ثقة ربما وهم، وهذا لا ينقصه». وقال الهيثمي في المجمع ٨/٢٠٣ (١٣٧٧٥): «رواه أبو يعلى ورجاله رجال الصحيح». وقال الألباني في الصحيحة ٣/٤٧٠ (١٤٨١): «وهذا سند صحيح على شرط مسلم».أخرجه ابن جرير ١٣/١٣٦.أخرجه الحاكم ٢/٦٢٣ (٤٠٨٧) بنحوه، ومحمد بن عبد الواحد الدقاق في معجمه ص٢٨٧ (١٥). وأورده الثعلبي ٥/٢١٨، والبغوي في تفسيره ٤/٢٣٧. وأخرجه ابن عدي في الكامل ٧/٢٦٨. وقال ابن القيسراني في ذخيرة الحفاظ ٤/١٩٧٧-١٩٧٨ (٤٥٤٧): «رواه إبراهيم بن سعد، عن محمد بن إسحاق، فقال: عمَّن لا أتهمه، عن أبي سعيد الخدري. فذكر حديث المعراج، فأفسد إبراهيم إسناده».أخرجه ابن جرير ١٣/١٣٥، وابن أبي حاتم ٧/٢١٣٦، والطبراني (٨٥٥٥-٨٥٥٧). وعزاه السيوطي إلى ابن سعد، وابن المنذر، وأبي الشيخ.أخرجه الحكيم الترمذي في نوادر الأصول ١/٢٧٩، وابن أبي حاتم ٧/٢١٣٦ مختصرًا، والطبراني (٨٥٥٧). وعزاه السيوطي إلى ابن المنذر، وأبي الشيخ.أخرجه ابن أبي حاتم ٧/٢١٣٦ مختصرًا، والطبراني (٨٥٥٧). وعزاه السيوطي إلى ابن المنذر.أخرجه ابن عساكر ٦٩/١٨١.أخرجه الحاكم ٢/٥٧٢-٥٧٣، وهذا اللفظ عند الذهبي في مختصر المستدرك، ولفظ الحاكم أطول منه.أخرجه ابن جرير ١٣/١٣٦-١٣٧، وابن أبي حاتم ٧/٢١٣٦. وعزاه السيوطي إلى ابن المنذر.عزاه السيوطي إلى عبد بن حميد، وابن المنذر، وأبي الشيخ.أخرجه ابن جرير ١٣/١٣٧ بنحوه من طريق عيسى بن يونس، وابن أبي حاتم ٧/٢١٣٦. وعزاه السيوطي إلى ابن المنذر.عزاه السيوطي إلى أبي الشيخ.تفسير مقاتل بن سليمان ٢/٣٣١.تفسير البغوي ٤/٢٢٤.
12,32," <q>﴿قَالَتۡ فَذَ ٰ⁠لِكُنَّ ٱلَّذِی لُمۡتُنَّنِی فِیهِۖ﴾</q> - تفسير ٣٧٢٩٣- عن زيد بن أسلم -من طريق يحيى بن العلاء- قال: ... فلمّا ولّى عنهُنَّ قالت: هذا الذي لُمْتُنَّنِي فيه، فلقد رأيتُكُنَّ تُقَطِّعْنَ أيديَكُنَّ وما تَشْعُرْنَ. قال: فنظَرْنَ إلى أيديهن، فجعلن يصِحْن ويبكين. قالت: فكيف أصنع أنا؟! فقلن: <q>﴿حاش لله ما هذا بشرًا إن هذا إلا ملك كريم﴾</q>، وما نرى عليك مِن لوم بعد الذي رأينا{1}. (٨/٢٤٢) ٣٧٢٩٤- قال مقاتل بن سليمان: قالتْ زليخا: <q>﴿فذلكن الذي لمتنني فيه﴾</q> الذي افْتُتِنتُنَّ به{2}٣٣٥٧. (ز) ٣٣٥٧ ذكر ابنُ عطية (٥/٨٢) أنّ الضمير في <q>﴿فيه﴾</q> يحتمل احتمالين: الأول: أن يكون عائدًا على يوسف. الثاني: أن تكون الإشارة إلى حُبِّ يوسف، والضمير عائد على الحُبِّ. وعلَّق عليه بقوله: «فيكون ذلك إشارةً إلى غائب على بابه». <q>﴿وَلَقَدۡ رَ ٰ⁠وَدتُّهُۥ عَن نَّفۡسِهِۦ فَٱسۡتَعۡصَمَۖ﴾</q> - تفسير ٣٧٢٩٥- عن عبد الله بن عباس -من طريق علي- في قوله: <q>﴿فاستعصم﴾</q>، قال: امْتَنَع{3}. (٨/٢٤٦) ٣٧٢٩٦- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿فاستعصم﴾</q>، قال: فاسْتَعْصى{4}. (٨/٢٤٦) ٣٧٢٩٧- عن إسماعيل السُّدِّيّ -من طريق أسباط- قال: قالت: <q>﴿ولقد راودته عن نفسه فاستعصم﴾</q>: بعد ما حَلَّ سراويلَه استعصى، لا أدري ما بَدا لَهُ{5}. (٨/١٩١) ٣٧٢٩٨- قال مقاتل بن سليمان: <q>﴿ولقد راودته عن نفسه فاستعصم﴾</q>، يعني: فامتنع عن الجِماع{2}. (ز) <q>﴿وَلَىِٕن لَّمۡ یَفۡعَلۡ مَاۤ ءَامُرُهُۥ لَیُسۡجَنَنَّ وَلَیَكُونࣰا مِّنَ ٱلصَّـٰغِرِینَ ۝٣٢﴾</q> - تفسير ٣٧٢٩٩- عن سعيد بن جبير -من طريق عطاء بن دينار- في قول الله: <q>﴿الصاغرين﴾</q>، يعني: المُذَلِّين{7}. (ز) ٣٧٣٠٠- قال مقاتل بن سليمان: <q>﴿ولئن لم يفعل ما آمره ليسجنن وليكونا من الصاغرين﴾</q>، يعني: المُذَلِّين{2}. (ز) ",footnotes:1:أخرجه ابن أبي حاتم ٧/٢١٣٧.تفسير مقاتل بن سليمان ٢/٣٣٢.أخرجه ابن جرير ١٣/١٤٢، وابن أبي حاتم ٧/٢١٣٧. وعزاه السيوطي إلى ابن المنذر، وأبي الشيخ.أخرجه ابن جرير ١٣/١٤٢. وعزاه السيوطي إلى أبي الشيخ.أخرجه ابن جرير ١٣/١٤٢، وابن أبي حاتم ٧/٢١٣٨.تفسير مقاتل بن سليمان ٢/٣٣٢.أخرجه ابن أبي حاتم ٧/٢١٣٨.تفسير مقاتل بن سليمان ٢/٣٣٢.
12,33," <q>﴿قَالَ رَبِّ ٱلسِّجۡنُ أَحَبُّ إِلَیَّ مِمَّا یَدۡعُونَنِیۤ إِلَیۡهِۖ﴾</q> - تفسير ٣٧٣٠١- عن إسماعيل السُّدِّيّ -من طريق أسباط- قال: قال يوسف: <q>﴿رب السجن أحب إلى مما يدعوننى إليه﴾</q>، يقول: الحبس أحبُّ إلَيَّ مِمّا يدعوننى إليه مِن الزِّنا{1}. (٨/١٩١) ٣٧٣٠٢- قال مقاتل بن سليمان: قالت النسوة: يا يوسف، ما يمنعك أن تقضي لها حاجتَها. فدعا يوسفُ ربَّه: <q>﴿قال رب السجن أحب إلي مما يدعونني إليه﴾</q> مِن الزِّنا. حين قُلْنَ ليوسف: ما يَحْمِلُك على ألّا تقضي لها حاجتَها{2}. (ز) ٣٧٣٠٣- عن محمد بن إسحاق -من طريق سلمة- قال: قال يوسف -وأضاف إلى ربِّه، واستعانَه على ما نَزَل به-: <q>﴿رب السجن أحب إلى مما يدعونني إليه﴾</q>، أي: السِّجْنُ أحَبُّ إلَيَّ مِن أن آتي ما تكره{1}. (ز) ٣٧٣٠٤- عن سفيان بن عيينة -من طريق سُنَيد- قال: إنّما يُوَفَّق مِن الدُّعاء لِلْمُقَدَّر، أما ترى يوسف قال: <q>﴿رب السجن أحب إلىَّ﴾</q>؟ قال: فلمّا قال: <q>﴿اذكرني عند ربك﴾</q>. أتاه جبريلُ، فكشف لَهُ عن الصخرة، فقال: ما ترى؟ قال: أرى نملةً تَقْضِم. قال: يقول ربك: أنا لم أنسَ هذه، أنساك؟! أنا حبستُك! أنت قلت: <q>﴿رب السجن أحب إلي﴾</q>{4}. (٨/٢٤٦) <q>﴿وَإِلَّا تَصۡرِفۡ عَنِّی كَیۡدَهُنَّ﴾</q> - تفسير ٣٧٣٠٥- قال الحسن البصري، <q>﴿وإلا تصرف عني كيدهن﴾</q>: قد كان مِن النِّسْوَة عَوْنٌ لَها عليه{5}. (ز) ٣٧٣٠٦- عن محمد بن إسحاق -من طريق سلمة-: <q>﴿وإلا تصرف عني كيدهن﴾</q> أي: ما أتَخَوَّفُ منهن <q>﴿أصب إليهن﴾</q>{6}. (ز) ٣٧٣٠٧- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿وإلّا تَصْرِفْ عنى كَيدَهُنَّ﴾</q>، قال: إلّا يكن منك أنتَ القُوى والمَنَعَةُ؛ لا تكُن مِنِّي ولا عندي{7}. (٨/٢٤٦) <q>﴿أَصۡبُ إِلَیۡهِنَّ﴾</q> - تفسير ٣٧٣٠٨- عن عبد الله بن عباس، <q>﴿أصب إليهن﴾</q>، قال: أُطاوِعهُنَّ{8}. (٨/٢٤٧) ٣٧٣٠٩- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿أصبُ إليهنَّ﴾</q>، يقول: اتَّبِعْهُنَّ{9}. (٨/٢٤٦) ٣٧٣١٠- قال مقاتل بن سليمان: <q>﴿وإلا تصرف عني كيدهن أصب إليهن﴾</q>، يقول: أُفْضِي إليهِنَّ{2}. (ز) <q>﴿وَأَكُن مِّنَ ٱلۡجَـٰهِلِینَ ۝٣٣﴾</q> - تفسير ٣٧٣١١- عن عمرو بن مُرَّة، قال: مَن أتى ذنبًا عمدًا أو خَطَأً فهو جاهلٌ حين يأتيه، ألا ترى إلى قول يوسف: <q>﴿أصب إليهن وأكن من الجاهلين﴾</q>؟! قال: فقد عرَف يوسفُ أنّ الزِّنا حرام، وإن أتاه كان جاهلًا{8}. (٨/٢٤٧) ٣٧٣١٢- قال مقاتل بن سليمان: <q>﴿وأكن من الجاهلين﴾</q>، يعني: مِن المُذْنِبين{2}. (ز) ٣٧٣١٣- عن محمد بن إسحاق -من طريق سلمة- <q>﴿وأكن من الجاهلين﴾</q>، أي: جاهِلًا إذا رَكِبْتُ معصيتَك{13}. (ز) ",footnotes:1:أخرجه ابن جرير ١٣/١٤٤، وابن أبي حاتم ٧/٢١٣٨.تفسير مقاتل بن سليمان ٢/٣٣٢.أخرجه ابن جرير ١٣/١٤٤، وابن أبي حاتم ٧/٢١٣٨.أخرجه ابن أبي حاتم ٧/٢١٣٨. وعزاه السيوطي إلى سُنَيد في تفسيره.ذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٢/٣٢٤-.أخرجه ابن جرير ١٣/١٤٥، وابن أبي حاتم ٧/٢١٣٨.أخرجه ابن جرير ١٣/١٤٥ بلفظ: العون والمنعة، وابن أبي حاتم ٧/٢١٣٨. وعزاه السيوطي إلى أبي الشيخ.عزاه السيوطي إلى أبي الشيخ.أخرجه ابن جرير ١٣/١٤٥ بلفظ: أُتابِعهن، وابن أبي حاتم ٧/٢١٣٨. وعزاه السيوطي إلى أبي الشيخ.تفسير مقاتل بن سليمان ٢/٣٣٢.عزاه السيوطي إلى أبي الشيخ.تفسير مقاتل بن سليمان ٢/٣٣٢.أخرجه ابن جرير ١٣/١٤٥، وابن أبي حاتم ٧/٢١٣٩.
12,34," <q>﴿فَٱسۡتَجَابَ لَهُۥ رَبُّهُۥ فَصَرَفَ عَنۡهُ كَیۡدَهُنَّۚ إِنَّهُۥ هُوَ ٱلسَّمِیعُ ٱلۡعَلِیمُ ۝٣٤﴾</q> - تفسير ٣٧٣١٤- قال مقاتل بن سليمان: <q>﴿فاستجاب له ربه فصرف عنه كيدهن﴾</q> يعني: مكرَهُنَّ وشَرَّهُنَّ، <q>﴿إنه هو السميع﴾</q> لدعاء يوسف، <q>﴿العليم﴾</q> به{1}. (ز) ٣٧٣١٥- عن محمد بن إسحاق -من طريق سلمة- <q>﴿فاستجاب له ربه فصرف عنه كيدهن إنه هو السميع العليم﴾</q>، أي: نَجّاه مِن أن يركب المعصية فيهِنَّ، وقد نزل به بعضُ ما حَذِر منهُنَّ{2}. (ز) ",footnotes:1:تفسير مقاتل بن سليمان ٢/٣٣٢.أخرجه ابن جرير ١٣/١٤٦، وابن أبي حاتم ٧/٢١٣٩.
12,35," <q>﴿ثُمَّ بَدَا لَهُم مِّنۢ بَعۡدِ مَا رَأَوُا۟ ٱلۡـَٔایَـٰتِ لَیَسۡجُنُنَّهُۥ حَتَّىٰ حِینࣲ ۝٣٥﴾</q> - قراءات ٣٧٣١٦- عن عبد الرحمن بن كعب بن مالك، عن أبيه، قال: سمِع عمرُ رجلًا يقرأ هذا الحرف: (لَيَسْجُنُنَّهُ عَتّى حِينٍ). فقال له عمر: مَن أقرأك هذا؟ قال: ابن مسعود.= (ز) ٣٧٣١٧- فقال عمر: <q>﴿لَيَسْجُنُنَّهُ حَتّى حِينٍ﴾</q>. ثم كتب إلى ابن مسعود: سلامٌ عليك، أمّا بعد، فإنّ الله أنزل القرآن فجعله قرآنًا عربيًّا مبينًا، وأنزله بلغة هذا الحيِّ مِن قريش، فإذا أتاك كتابي هذا فأقرِئِ الناسَ بلغة قريش، ولا تُقرِئْهم بلغة هُذَيلٍ{1}. (٨/٢٤٩) <q>﴿ثُمَّ بَدَا لَهُم مِّنۢ بَعۡدِ مَا رَأَوُا۟ ٱلۡـَٔایَـٰتِ﴾</q> - تفسير ٣٧٣١٨- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿ثم بدا لهم من بعد ما رأوا الآيات﴾</q>، قال: قَدّ القميصِ مِن دُبُر{2}. (٨/٢٤٧) ٣٧٣١٩- عن عكرمة، قال: سألتُ ابن عباس عن قوله: <q>﴿ثم بدا لهم من بعد ما رأوا الآيات﴾</q>. قال: ما سألني عنها أحدٌ قبلك، من الآيات: قدُّ القميص، وأثرُها في جسده، وأَثَرُ السكين. وقالت امرأة العزيز: إن أنت لم تَسْجُنه لَيُصَدِّقَنَّه الناسُ{3}. (٨/٢٤٧) ٣٧٣٢٠- عن عكرمة مولى ابن عباس -من طريق نضر- قال: مِن الآيات: شقٌّ في القميص، وخَمْشٌ في الوَجْه{4}. (٨/٢٤٧) ٣٧٣٢١- عن عكرمة مولى ابن عباس، قال: قال رجلٌ ذو رأي منهم للعزيز: إنّك متى تركت هذا العبدَ يعتذرُ إلى الناس ويقصُّ عليهم أمْرَه، وامرأةٌ في بيتها لا تخرج إلى الناس، عذَروه وفضَحوا أهلك. فأمَر به فسُجِن{5}. (٨/٢٤٨) ٣٧٣٢٢- عن قتادة بن دعامة -من طريق مَعْمَر- قال: الآيات: حَزُّهن أيديَهن، وقدُّ القميصِ{6}. (٨/٢٤٨) ٣٧٣٢٣- عن إسماعيل السُّدِّيّ -من طريق أسباط- قال: <q>﴿ثم بدا لهم من بعد ما رأوا الآيات﴾</q>، وهو شقُّ القميص، وقطع الأيدي <q>﴿ليسجننه حتى حين﴾</q>{7}. (٨/١٩١) ٣٧٣٢٤- قال مقاتل بن سليمان: <q>﴿ثم بدا لهم﴾</q> يعني: ثم بدا للزوج <q>﴿من بعد ما رأوا الآيات﴾</q> يعني: مِن بعد ما رأوا العلاماتِ في تمزيق القميص مِن دُبُرٍ أنّه بريء <q>﴿ليسجننه حتى حين﴾</q>{8}. (ز) ٣٧٣٢٥- عن محمد بن إسحاق -من طريق سلمة-: <q>﴿ثم بدا لهم من بعد ما رأوا الآيات﴾</q> ببراءته مِمّا اتُّهِم به مِن شَقِّ قميصه مِن دُبُرٍ <q>﴿ليسجننه حتى حين﴾</q>{9}. (ز) ٣٧٣٢٦- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿من بعد ما رأوا الآيات﴾</q>، قال: مِن الآيات كلامُ الصَّبِيِّ{5}٣٣٥٨. (٨/٢٤٨) ٣٣٥٨ ساق ابنُ عطية (٥/٨٥) ما أورده المفسرون في الآيات، ثم علَّق بقوله: «ومقصد الكلام إنما هو: أنّهم رأوا سجنَه بعد بُدُوِّ الآيات المُبَرِّئَةِ له مِن التُّهمة، فهكذا يبين ظلمهم له. وخمش الوجهِ، وحزُّ النساء أيديهن؛ ليس فيهما تبرية ليوسف، ولا تتصور تبرية إلا في خبر القميص، فإن كان المتكلم طفلًا -على ما رُوِي- فهي آية عظيمة، وإن كان رجلًا فهي آية فيها استدلال ما. والعادة أنه لا يُعَبَّر بآيةٍ إلا فيما ظهوره في غاية الوضوح، وقد تقع الآيات أيضًا على المبينات كانت في أي حد اتَّفق من الوضوح». ثم أورد احتمالًا آخر، فقال: «ويحتمل أن يكون معنى قوله: <q>﴿من بعد ما رأوا الآيات﴾</q> أي: مِن بعد ما ظهر لهم مِن وجوه الأمر وقرائنه أنّ يوسف بريء، فلم يرد تعيين آية، بل قرائن جميع القصة». <q>﴿لَیَسۡجُنُنَّهُۥ﴾</q> - تفسير ٣٧٣٢٧- عن إسماعيل السُّدِّيّ -من طريق أسباط- قال: ثم إنّ المرأةَ قالت لزوجها: إنّ هذا العبدَ العبراني قد فضحني في الناس؛ إنّه يعتذر إليهم، ويُخبِرُهم أنِّي راودتُه عن نفسه، ولست أُطيق أن أعتذر بعذري، فإمّا أن تأذن لي فأخرج فأعتذر كما يعتذر، وإمّا أن تحبسه كما حبستني. فذلك قوله: <q>﴿ثم بدا لهم من بعد ما رأوا الآيات ليسجننه حتى حين﴾</q>{11}. (٨/١٩١) ٣٧٣٢٨- قال محمد بن السائب الكلبي، في قوله: <q>﴿ليسجننه حتى حين﴾</q>: بلغنا: أنّها قالت لزوجها: صَدَّقْتَه وكذَّبْتَنِي، وفضحتني في المدينة، فأنا غير ساعيةٍ فِي رِضاك إن لم تسجن يوسف، وتُسَمِّع به، وتعذرني. فأمر بيوسف يُحْمل على حمار، ثم ضرب بالطَّبل: هذا يوسف العبراني، أراد سيِّدتَه على نفسِها. فطُوِّف به أسواق مصر كلها، ثم أدخل السجن{12}. (ز) ٣٧٣٢٩- قال مقاتل بن سليمان: <q>﴿ليسجننه حتى حين﴾</q>، وذلك أنّها قالت لزوجها حين لم يُطاوِعها يوسف: احبِس يوسفَ في السجن لا يَلِجْ عَلَيَّ. فصَدَّقها، فحَبَسَتْهُ{8}. (ز) <q>﴿حَتَّىٰ حِینࣲ ۝٣٥﴾</q> - تفسير ٣٧٣٣٠- عن عبد الله بن عباس -من طريق أبي ظبيان- قال: الحين قد يكون غُدْوَةً وعَشِيَّةً{14}. (ز) ٣٧٣٣١- عن سعيد بن جبير -من طريق طارق-= (ز) ٣٧٣٣٢- وعكرمة مولى ابن عباس -من طريق ابن الأصبهاني- قالا: الحين: سِتَّةُ أشهر{15}. (ز) ٣٧٣٣٣- عن يزيد النحوي، قال: وسألتُه -يعني: عكرمة مولى ابن عباس- عن رجلٍ نذر لَيَسْجُنَنَّ غلامه حينًا، فإن لم يسجنه حينًا فهو عتيق؟ فقال عكرمة: إنّ من الأحيان حينًا يُدْرَك، وحينًا لا يُدْرَك؛ فأمّا الحينُ الذي لا يُدْرك قال الله تعالى: <q>﴿ليسجننه حتى حين﴾</q>{16}. (ز) ٣٧٣٣٤- عن عكرمة مولى ابن عباس -من طريق أبي مكين-: أنّه نذر [رجلٌ] أن يقطع يد غلامه، أو يحبسه حينًا. قال: فسألني عمر بن عبد العزيز. فقلتُ: لا تقطع يده، ويحبسه سنةً، والحين سنة. ثم قرأ: <q>﴿ليسجننه حتى حين﴾</q>. وقرأ: <q>﴿تؤتي أكلها كل حين بإذن ربها﴾</q> [إبراهيم:٢٥]{17}. (ز) ٣٧٣٣٥- عن عكرمة مولى ابن عباس -من طريق داود- في قوله: <q>﴿لَيَسْجُنُنَّهُ حتى حين﴾</q>، قال: سبع سنين{18}. (٨/٢٤٨) ٣٧٣٣٦- قال عطاء: إلى أن تنقطِع مقالةُ الناس{19}. (ز) ٣٧٣٣٧- عن محمد بن علي بن الحسين [أبي جعفر الباقر] -من طريق عن محمد بن عبد الله الأنصاري-: أنّه سُئِل في رجلٍ حَلَف على امرأته أن لا تفعل فِعلًا ما إلى حين. فقال: أيُّ الأحيانِ أردتَ؟ فإنّ الأحيان ثلاثة: قال الله ﷿: <q>﴿تؤتي أكلها كل حين بإذن ربها﴾</q> [إبراهيم:٢٥]: كل ستة أشهر، وقوله تعالى: <q>﴿ليسجننه حتى حين﴾</q>، فذلك ثلاثة عشر عامًا، وقوله تعالى: <q>﴿ولتعلمن نبأه بعد حين﴾</q> [ص:٨٨]، فذلك إلى يوم القيامة{20}. (ز) ٣٧٣٣٨- قال محمد بن السائب الكلبي: خمس سنين{21}. (ز) ٣٧٣٣٩- قال مقاتل بن سليمان: <q>﴿وقال﴾</q> يوسف <q>﴿لِلَّذي ظنَّ أنه ناج مِنهما﴾</q> مِن القتل، إضمار، وهو الساقي: <q>﴿اذكرني عند ربك﴾</q> يعني: سيِّدك؛ فإنّه يسرني أن يخرجني من السجن. يقول الله: <q>﴿فأنساه الشيطان ذكر ربه﴾</q> يعني: يوسف دعاء ربه، فلم يدع يوسف ربَّه الذي في السماء ليخرجه من السجن، واستغاث بعبدٍ مثلَه، يعني: الملك، فأقرَّه الله في السجن عقوبةً حين رجا أن يخرجه غيرُ الله ﷿، فذلك قوله: <q>﴿فلبث في السجن بضع سنين﴾</q>، يعني: خمس سنين، حتى رأى الملكُ الرُّؤيا، وكان في السجن قبل ذلك سبعَ سنين، وعُوقِب ببضع سنين، يعني: خمس سنين، فكان في السجن اثنتا عشرة سنة، فذلك قوله: <q>﴿ثم بدا لهم من بعد ما رأوا الآيات ليسجننه حتى حين﴾</q>{22}. (ز) ٣٧٣٤٠- قال سفيان الثوري، في قوله: <q>﴿حتى حين﴾</q>: سبع سنين{23}٣٣٥٩. (ز) ٣٣٥٩ ذكر ابنُ عطية (٥/٨٥-٨٦) أنّ «الحين» في كلام العرب وفي هذه الآية: الوقت مِن الزمن غير محدود، يقع للقليل والكثير، وذلك بيّن موارده في القرآن. ثُمَّ استدرك على تحديد «الحين» بقوله: «وهذا بحسب ما كشف الغيب في سجن يوسف». ",footnotes:1:أخرجه الخطيب في تاريخه ٣/٤٠٦. وعزاه السيوطي إلى ابن الأنباري في كتاب الوقف والابتداء. (عَتّى حِينٍ) بالعين قراءة شاذة، وقراءة الجمهور: <q>﴿حتى حين﴾</q>. انظر: مختصر ابن خالويه ص٦٨، والمحتسب ١/٣٤٣.ذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٢/٣٢٥-، وأخرجه ابن جرير ١٣/١٤٨. وعزاه السيوطي إلى ابن المنذر.أخرجه ابن أبي حاتم ٧/٢١٣٩. وعزاه السيوطي إلى أبي الشيخ.أخرجه ابن جرير ١٣/١٤٨، وابن أبي حاتم ٧/٢١٣٩. وعزاه السيوطي إلى ابن أبي شيبة، وابن المنذر.عزاه السيوطي إلى أبي الشيخ.أخرجه ابن جرير ١٣/١٤٨.أخرجه ابن جرير ١٣/١٤٩، وابن أبي حاتم ٧/٢١٣٩.تفسير مقاتل بن سليمان ٢/٣٣٢.أخرجه ابن جرير ١٣/١٤٩، وابن أبي حاتم ٧/٢١٤٠.عزاه السيوطي إلى أبي الشيخ.أخرجه ابن جرير ١٣/١٥٠، وابن أبي حاتم ٧/٢١٣٩. وفي تفسير الثعلبي ٥/٢٢٠، وتفسير البغوي ٤/٢٣٩ نحوه، وزادا في آخره: وذكر أنّ الله تعالى جعل ذلك الحبس تطهيرًا ليوسف ﵇ من هَمِّه بالمرأة.ذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٢/٣٢٥-.تفسير مقاتل بن سليمان ٢/٣٣٢.أخرجه ابن أبي حاتم ٧/٢١٤١. وبنحو هذا اللفظ أخرج ابن جرير ١٣/٦٤٤ عن ابن عباس من طريق أبي ظبيان في تفسير قوله تعالى: <q>﴿تُؤْتِي أُكُلَها كُلَّ حِينٍ بِإذْنِ رَبِّها﴾</q> [إبراهيم:٢٥]. وعزاه السيوطي إلى ابن أبي حاتم وغيره، وسيأتي.أخرجه ابن أبي حاتم ٧/٢١٤١.أخرجه ابن أبي حاتم ٧/٢١٤١. وسيأتي في تفسير قوله تعالى: <q>﴿تُؤْتِي أُكُلَها كُلَّ حِينٍ بِإذْنِ رَبِّها﴾</q> [إبراهيم:٢٥] عند ابن جرير، وابن أبي حاتم من طريق أيوب عن عكرمة أنّ الحين الذي لا يدرك هو قوله تعالى: <q>﴿ولتعلمنَّ نبأهُ بعدَ حين﴾</q> [ص:٨٨]، وفي رواية عند ابن جرير من طريق ابن غَسيل أنه قوله تعالى: <q>﴿هل أتى على الانسان حينٌ من الدَّهر لم يكن شيئا مذكورًا﴾</q> [الإنسان:١].أخرجه ابن جرير ١٣/٦٤٨، وابن أبي حاتم ٧/٢١٤١ دون ذكر آية سورة إبراهيم، وما بين المعقوفين إضافة مهمة منه.أخرجه ابن جرير ١٣/١٥١، وابن أبي حاتم ٧/٢١٤١ من طريق عاصم. وعزاه السيوطي إلى ابن المنذر.تفسير البغوي ٤/٢٣٩.أخرجه ابن حزم في المحلى ٨/٥٨.تفسير الثعلبي ٥/٢٢٠، وتفسير البغوي ٤/٢٣٩.تفسير مقاتل بن سليمان ٢/٣٣٥-٣٣٦.تفسير سفيان الثوري ص١٤٢.
12,36," <q>﴿وَدَخَلَ مَعَهُ ٱلسِّجۡنَ فَتَیَانِۖ قَالَ أَحَدُهُمَاۤ إِنِّیۤ أَرَىٰنِیۤ أَعۡصِرُ خَمۡرࣰاۖ وَقَالَ ٱلۡـَٔاخَرُ إِنِّیۤ أَرَىٰنِیۤ أَحۡمِلُ فَوۡقَ رَأۡسِی خُبۡزࣰا تَأۡكُلُ ٱلطَّیۡرُ مِنۡهُۖ نَبِّئۡنَا بِتَأۡوِیلِهِۦۤۖ إِنَّا نَرَىٰكَ مِنَ ٱلۡمُحۡسِنِینَ ۝٣٦﴾</q> - قراءات ٣٧٣٤١- عن عبد الله بن مسعود -من طريق محمد بن الحنفية- أنّه قرأ: (إنِّي أرانِي أعْصِرُ عِنَبًا). وقال: واللهِ، لقد أخذتُها مِن رسول الله ﷺ هكذا{1}. (٨/٢٥١) ٣٧٣٤٢- عن يحيى بن سلّام: قوله: <q>﴿أحْمِلُ فَوْقَ رَأْسِي خُبْزًا﴾</q> في قراءة عبد الله بن مسعود: (ثَرِيدًا)، أي: قصعة مِن ثريد{2}. (ز) <q>﴿وَدَخَلَ مَعَهُ ٱلسِّجۡنَ فَتَیَانِۖ﴾</q> - تفسير ٣٧٣٤٣- عن عبد الله بن عباس -من طريق سعيد بن جبير- في قوله: <q>﴿ودخل معه السجن فتيان﴾</q>، قال: أحدُهما: خازنُ الملك على طعامه، والآخَرُ: ساقيه على شرابه{3}. (٨/٢٤٩) ٣٧٣٤٤- عن قتادة بن دعامة -من طريق سعيد-، مثله{4}. (٨/٢٤٩) ٣٧٣٤٥- عن إسماعيل السُّدِّيّ -من طريق أسباط- قال: <q>﴿ودخل معه السجن فتيان﴾</q>: غَضِبَ الملِكُ على خبّازِه؛ بلغه أنّه يريد أن يَسُمَّه، فحبسه، وحبس الساقيَ، وظنَّ أنّه مالأه على السم{5}. (٨/١٩١) ٣٧٣٤٦- عن محمد بن إسحاق -من طريق سلمة- قال في قوله: <q>﴿ودخل معه السجن فتيان﴾</q>، قال: غلامان كانا للملِك الأكبر الريّانِ بن الوليد؛ كان أحدُهما على شرابه، والآخر على بعض أمره، في سخطةٍ سخِطَها عليهما، اسم أحدِهما: مجلثُ، والآخر: نبو، ونبو الذي كان على الشراب، فلمّا رأياه قالا: يا فتى، واللهِ، لقد أحببناك حين رأيناك{6}. (٨/٢٤٩) ٣٧٣٤٧- قال مقاتل بن سليمان: كان يوسف في السجن يُؤنِس الحزين، ويُطَمْئِنُ الخائف، ويقوم على المريض، ويُعَبِّر لهم الرؤيا. ورُقِي إلى الملكِ أنّ غلامَه الخباز يريد أن يجعل في طعامه سُمًّا، ورقى إليه في غلامه الساقي مثل ذلك، فذلك قوله: <q>﴿ودخل معه السجن فتيان﴾</q> الخبّاز والساقي، اسم أحدهما: شرهم أقم، وهو الساقي، واسم الخباز: شرهم أشم{7}٣٣٦٠. (ز) ٣٣٦٠ ذكر ابنُ عطية (٥/٨٦) أنّ «مع» تحتمل احتمالين: الأول: أن تكون باقتران وقت الدخول. الثاني: أن لا تكون، بل دخلوا أفذاذًا. وبيَّن أنّ لفظة «الفتى» تعني: الشاب، وأنّها قد تقع على المملوك، وعلى الخادم الحُرِّ، ثم قال: «ويحتمل أن يتَّصف هذان بجميع ذلك». <q>﴿قَالَ أَحَدُهُمَاۤ إِنِّیۤ أَرَىٰنِیۤ أَعۡصِرُ خَمۡرࣰاۖ﴾</q> - تفسير ٣٧٣٤٨- عن عبد الله بن عباس -من طريق ابن جريج- في قوله: <q>﴿إني أراني أعْصِرُ خمرًا﴾</q>، قال: عِنَبًا{8}. (٨/٢٥١) ٣٧٣٤٩- عن الضحاك بن مُزاحِم -من طريق عبيد- في قوله: <q>﴿إني أراني أعصر خمرًا﴾</q>، يقول: أعْصِر عِنَبًا، وهو بلغة أهل عمان، يسمُّون العِنَب: خمرًا{9}. (٨/٢٥١) ٣٧٣٥٠- عن قتادة بن دعامة، في قوله: <q>﴿إني أراني أعصر خمرًا﴾</q>، قال: هو بلغة أهل عمان{10}. (٨/٢٥٢) ٣٧٣٥١- قال مقاتل بن سليمان: قال أحدهما: <q>﴿إنِّي أراني﴾</q> في المنام كأني <q>﴿أعصر خمرا﴾</q> يعني: عِنَبًا. قال: كأنِّي دخلت البستانَ، فإذا فيه أصل كرم، وعليه ثلاث عناقيد، فكأنِّي أعصرهن، وأسقي المَلِك{7}. (ز) <q>﴿وَقَالَ ٱلۡـَٔاخَرُ إِنِّیۤ أَرَىٰنِیۤ أَحۡمِلُ فَوۡقَ رَأۡسِی خُبۡزࣰا تَأۡكُلُ ٱلطَّیۡرُ مِنۡهُۖ﴾</q> - تفسير ٣٧٣٥٢- قال مقاتل بن سليمان: <q>﴿وقال الآخَر: إني أراني﴾</q> رأيتُ في المنام كأني <q>﴿أحمل فوق رأسي خبزا﴾</q> ثلاثَ سِلال، وأعلاهن جَفْنَةٌ مِن خبز <q>﴿فوق رأسي﴾</q> -مثل قوله: <q>﴿فاضربوا فوق الأعناق﴾</q> [الأنفال:١٢]، ومثل قوله: <q>﴿اجتثت من فوق الأرض﴾</q> [إبراهيم:٢٦] يعني: أعلى الأرض- <q>﴿تأكل الطير منه﴾</q>{7}. (ز) <q>﴿نَبِّئۡنَا بِتَأۡوِیلِهِۦۤۖ﴾</q> - تفسير ٣٧٣٥٣- عن مجاهد بن جبر -من طريق ابن أبي نجيح-: أنّ يوسف قال لهما حين قالا له ذلك: أنشُدُكما اللهَ ألّا تُحِبّاني، فواللهِ، ما أحَبَّني أحدٌ قطُّ إلا دخل عَلَيَّ مِن حُبِّه بلاءٌ؛ لقد أحَبَّتني عَمَّتي فدخل عَلَيَّ مِن حُبِّها بلاءٌ، ثم أحبني أبي فدخل عَلَيَّ بحبِّه بلاءٌ، ثم أحبَّتني زوجةُ صاحبي هذا فدخل عليَّ بحُبِّها إيّاي بلاءٌ، فلا تُحِبّاني، بارك الله فيكما. فأبيا إلا حُبَّه وإلْفَه حيث كان، وجعلا يعجبهما ما يريان مِن فهمه وعقله، وقد كانا رأيا حين أُدخلا السجن رؤيا؛ فرأى مجلث أنّه يحمل فوق رأسه خبزًا تأكل الطير منه، ورأى نبو أنه يعصِرُ خمرًا، فاسْتَفْتَياه فيهما، وقالا له: <q>﴿نبئنا بتأويله إنا نراك من المحسنين﴾</q>{13}. (٨/٢٤٩) ٣٧٣٥٤- عن إسماعيل السُّدِّيّ -من طريق أسباط- قال: فلمّا دخل يوسفُ السجنَ قال: إنِّي أُعَبِّر الأحلام. فقال أحد الفتيين لصاحبه: هَلُمَّ، فلْنُجَرِّب قولَ هذا العبد العبراني. فتراءيا مِن غير أن يكونا رأيا شيئًا، ولكنهما خرصا، فعبَّر لهما يوسفُ خَرْصَهُما، فقال الساقي: رأيتُني أعصر خمرًا. وقال الخباز: رأيتني أحمل فوق رأسي خبزًا تأكل الطير منه{14}. (٨/١٩٢) ٣٧٣٥٥- عن محمد بن إسحاق -من طريق سلمة- قال: اسْتَفْتَياه في رؤياهما، وقالا له: <q>﴿نبئنا بتأويله إنا نراك من المحسنين﴾</q>{15}٣٣٦١. (ز) ٣٣٦١ اختُلِف هل سأل الفَتيان يوسف عن رؤيا حقيقة؟ أم أرادا تجربته؟ ذكر ابنُ كثير (٨/٤١) أنّ المشهور عند الأكثرين هو القول الأول الذي قاله ابن إسحاق، ومجاهد. <q>﴿بِتَأۡوِیلِهِۦۤۖ﴾</q> - تفسير ٣٧٣٥٦- عن مجاهد بن جبر، <q>﴿نبئنا بتأويله﴾</q>، قال: عِبارَته{16}. (٨/٢٥١) ٣٧٣٥٧- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿نبئنا بتأويله﴾</q>، يعني: تأويل ما رأينا{17}. (ز) ٣٧٣٥٨- قال مقاتل بن سليمان: <q>﴿نبئنا بتأويله﴾</q>، يقول: أخبِرنا بتفسير ما رأينا في المنام{7}. (ز) <q>﴿إِنَّا نَرَىٰكَ مِنَ ٱلۡمُحۡسِنِینَ ۝٣٦﴾</q> - تفسير ٣٧٣٥٩- عن مجاهد بن جبر -من طريق ابن أبي نجيح-: <q>﴿نبئنا بتأويله إنا نراك من المحسنين﴾</q> إن فعلتَ ...{13}. (٨/٢٤٩) ٣٧٣٦٠- عن الضحاك بن مُزاحِم -من طريق سلمة بن نبيط- أنّه سُئِل عن قوله: <q>﴿إنا نراك من المحسنين﴾</q>: ما كان إحسان يوسف؟ قال: كان إذا مرِض إنسانٌ في السجن قام عليه، وإذا ضاق عليه المكانُ أوْسَع له، وإذا احتاجَ جَمَعَ له{20}. (٨/٢٥٣) ٣٧٣٦١- عن قتادة بن دعامة -من طريق أبي بكر بن عبد الله- في قوله: <q>﴿إنا نراك من المحسنين﴾</q>، قال: كان إحسانُه -فيما ذُكِر لنا- أنّه كان يُعزِّي حزينَهم، ويُداوي مريضَهم، ورأوا منه عبادًة واجتهادًا، فأحبُّوه. وقال: لَمّا انتهى يوسفُ إلى السجن وجد فيه قومًا قد انقَطَع رجاؤُهم، واشْتَدَّ بلاؤُهم، وطال حُزنُهم، فجعل يقول: أبشِروا، اصبِرُوا تُؤْجَروا، إنّ لِهذا أجرًا، إنّ لِهذا ثوابًا. فقالوا: يا فتى، بارك الله فيك، ما أحسن وجهكَ، وأحسن خَلْقَك، وأحسن خُلُقَك! لقد بُورك لنا في جِوارك، ما نُحِبُّ أنّا كُنّا في غير هذا منذ حُبِسنا؛ لِما تُخْبِرُنا مِن الأجر والكفّارة والطهارة، فمَن أنت، يا فتى؟ قال: أنا يوسف، ابن صَفِيِّ الله يعقوب، ابن ذبيح الله إسحاق، ابن خليل الله إبراهيم -عليهم الصلاة والسلام-. وكانت عليه مَحَبَّة، وقال له عامل السجن: يا فتى، واللهِ، لو استطعتُ لَخَلَّيْتُ سبيلَك، ولكن سأُحْسِن جِوارك، وأُحْسِنُ إسارَك، فكُن في أيِّ بيوت السِّجن شئت{21}. (٨/٢٥٢) ٣٧٣٦٢- قال مقاتل بن سليمان: <q>﴿إنا نراك من المحسنين﴾</q>، وكان إحسانُه في السجن أنّه كان يعودُ مرضاهم، ويُداويهم، ويُعَزِّي مكروبَهم، ورآه مُتَعَبِّدًا لربِّه، فهذا إحسانه{7}. (ز) ٣٧٣٦٣- عن محمد بن إسحاق -من طريق سلمة-: <q>﴿نبئنا بتأويله إنا نراك من المحسنين﴾</q> إن فعلتَ{15}٣٣٦٢. (ز) ٣٣٦٢ اختُلِف في معنى الإحسان الذي وصف به الفَتيان يوسف على قولين: الأول: أنّه كان يعود مريضهم، ويعزي حزينهم. الثاني: أنّ المعنى: إذ نبأتنا بتأويل رؤيانا هذه تكون من المحسنين. ورجَّح ابنُ جرير (١٣/١٥٨) مستندًا إلى الدلالة العقلية القولَ الأول الذي قاله الضحاك، وقتادة، ومقاتل، فقال: «وأَوْلى الأقوال في ذلك عندنا بالصواب القولُ الذي ذكرناه عن الضحاك وقتادة». ثم قال: «فإن قال قائل: وما وجه الكلام إن كان الأمر إذن كما قلت، وقد علمتَ أن مسألتهما يوسفُ أن ينبئهما بتأويل رؤياهما ليست مِن الخبر عن صفته بأنّه يعود المريض ويقوم عليه ويحسن إلى من احتاج في شيء، وإنما يقال للرجل: نبِّئنا بتأويل هذا فإنك عالم. وهذا مِن المواضع التي تَحسن بالوصف بالعلم لا بغيره؟ قيل: إنّ وجه ذلك أنهما قالا له: نبِّئنا بتأويل رؤيانا محسنًا إلينا في إخبارك إيّانا بذلك، كما نراك تحسن في سائر أفعالك، إنا نراك من المحسنين». <q>﴿إِنَّا نَرَىٰكَ مِنَ ٱلۡمُحۡسِنِینَ ۝٣٦﴾</q> - آثار متعلقة بالآية ٣٧٣٦٤- عن عبد الله بن عباس، قال: دعا يوسفُ لأهل السجن، فقال: اللَّهُمَّ، لا تُعَمِّ عليهم الأخبار، وهوِّن عليهم مَرَّ الأيام{10}. (٨/٢٥٢) ٣٧٣٦٥- عن عمرو بن دينار، قال: قال يوسف ﵇: ما لَقِيَ أحدٌ في الحُبِّ ما لَقِيتُ؛ أحَبَّني أبي فأُلْقِيتُ في الجُبِّ، وأحبَّتني امرأةُ العزيز فأُلْقِيتُ في السِّجن{25}. (٨/٢٥١) ٣٧٣٦٦- عن مقاتل بن سليمان: [أنّ يوسف ﵇ لَمّا سُجِن] قال له صاحِبُ السجن: مَن أنت؟ قال: ولِم تسألني: مَن أنا؟ قال: لأنِّي أُحِبُّك. قال: أعوذ بالله مِن حُبِّك، أحَبَّني والدي فلقيت من إخوتي ما لقيت، وأحبَّتني امرأةُ العزيز فلقيت مِن حبها ما لقيت، فلا حاجة لي في حُبِّ أحدٍ إلا في إلهي الذي في السماء. قال: أخبِرني مَن أنت؟ قال: أنا يوسف نبي الله، ابن يعقوب صفي الله، ابن إسحاق ذبيح الله، ابن إبراهيم خليل الله{26}. (ز) ٣٧٣٦٧- عن عبد الصمد بن محمد العباداني، قال: سمعتُ أبي يقول: قال رجلٌ ليوسف: إنِّي أُحِبُّك. فقال له يوسف: لا أريد أن يُحِبَّني أحدٌ غير الله؛ مِن حُبِّ أبي أُلِقيتُ في الجُبِّ، ومِن حُبِّ امرأة العزيز أُلقِيتُ في السِّجن{27}. (٨/٢٣٦) ",footnotes:1:أخرجه البخاري في تاريخه ١/٢٧٤-٢٧٥ (٨٨٥) في ترجمة إبراهيم بن بشير الأنصاري، وابن جرير ١٣/١٥٤، وابن أبي حاتم ٧/٢١٤٢. وذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٢/٣٢٦-. جميعهم دون قوله: وقال: واللهِ، لقد أخذتها من رسول الله ﷺ هكذا. وقال ابن حجر في الفتح ١٢/٣٨٢: «أخرجه بن أبي حاتم بسند حسن، وكأنه أراد التفسير». وهي قراءة شاذة. انظر: المحتسب ١/٣٤٣.تفسير ابن أبي زمنين ٢/٣٢٦. وهي قراءة شاذة.أخرجه ابن أبي حاتم ٧/٢١٤١.أخرجه ابن جرير ١٣/١٥٢ بلفظ: خباز الملك على طعامه، وابن أبي حاتم ٧/٢١٤١. وذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٢/٣٢٦- بلفظ: خباز الملك على طعامه.أخرجه ابن جرير ١٣/١٥٢، وابن أبي حاتم ٧/٢١٤٢-٢١٤٣.أخرجه ابن جرير ١٣/١٥١، ١٥٢، ١٥٣، وابن أبي حاتم ٧/٢١٤٢.تفسير مقاتل بن سليمان ٢/٣٣٣.أخرجه ابن جرير ١٣/١٥٥.أخرجه ابن جرير ١٣/١٥٥، وابن أبي حاتم ٧/٢١٤٢. وعزاه السيوطي إلى ابن المنذر.عزاه السيوطي إلى أبي الشيخ.تفسير مقاتل بن سليمان ٢/٣٣٣.تفسير مقاتل بن سليمان ٢/٣٣٣.أخرجه ابن جرير ١٣/١٥٤، وابن أبي حاتم ٧/٢١٤٢.أخرجه ابن جرير ١٣/١٥٣، وابن أبي حاتم ٧/٢١٤٣.أخرجه ابن جرير ١٣/١٥٨.أخرجه ابن جرير ١٣/١٥٦ من طريق ابن أبي نجيح بلفظ: به. وعزاه السيوطي إلى أبي الشيخ.تفسير مجاهد ص٣٩٦.تفسير مقاتل بن سليمان ٢/٣٣٣.أخرجه ابن جرير ١٣/١٥٤، وابن أبي حاتم ٧/٢١٤٢.أخرجه سعيد بن منصور (١١٢٤ - تفسير)، وابن جرير ١٣/١٥٦-١٥٧، وابن أبي حاتم ٧/٢١٤٣، والبيهقي في شعب الإيمان (٩٥٧٩). وعزاه السيوطي إلى ابن المنذر، وأبي الشيخ. وفي تفسير الثعلبي ٥/٢٤١، وتفسير البغوي ٤/٢٤١ نحوه، وزادا في آخره: وكان مع هذا يجتهد في العبادة، ويقوم الليل كله للصلاة.أخرجه ابن جرير ١٣/١٥٧-١٥٨، وابن أبي حاتم ٧/٢١٤٣. وذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٢/٣٢٦- مختصرًا. وعزاه السيوطي إلى أبي الشيخ.تفسير مقاتل بن سليمان ٢/٣٣٣.أخرجه ابن جرير ١٣/١٥٨.عزاه السيوطي إلى أبي الشيخ.عزاه السيوطي إلى وكيع في الغُرر.تفسير مقاتل بن سليمان ٢/٣٣٢.أخرجه ابن أبي حاتم ٧/٢١٣٢.
12,37," <q>﴿قَالَ لَا یَأۡتِیكُمَا طَعَامࣱ تُرۡزَقَانِهِۦۤ إِلَّا نَبَّأۡتُكُمَا بِتَأۡوِیلِهِۦ قَبۡلَ أَن یَأۡتِیَكُمَاۚ ذَ ٰ⁠لِكُمَا مِمَّا عَلَّمَنِی رَبِّیۤۚ إِنِّی تَرَكۡتُ مِلَّةَ قَوۡمࣲ لَّا یُؤۡمِنُونَ بِٱللَّهِ وَهُم بِٱلۡـَٔاخِرَةِ هُمۡ كَـٰفِرُونَ ۝٣٧﴾</q> - قراءات ٣٧٣٦٨- عن أبي يوسف، قال: قال لي أبو حنيفة: إنّهم يقرؤون حرفًا في يوسف يَلْحَنُون فيه؟ قلت: ما هو؟ قال: قوله: <q>﴿لا يَأْتِيكُما طَعامٌ تُرْزَقانِهِ﴾</q> فقلت: فكيف هو؟ قال: (تُرْزَقانُهُ){1}. (ز) <q>﴿قَالَ لَا یَأۡتِیكُمَا طَعَامࣱ تُرۡزَقَانِهِۦۤ إِلَّا نَبَّأۡتُكُمَا بِتَأۡوِیلِهِۦ قَبۡلَ أَن یَأۡتِیَكُمَاۚ ذَ ٰ⁠لِكُمَا مِمَّا عَلَّمَنِی رَبِّیۤۚ إِنِّی تَرَكۡتُ مِلَّةَ قَوۡمࣲ لَّا یُؤۡمِنُونَ بِٱللَّهِ وَهُم بِٱلۡـَٔاخِرَةِ هُمۡ كَـٰفِرُونَ ۝٣٧﴾</q> - تفسير الآية ٣٧٣٦٩- عن مجاهد بن جبر -من طريق ابن أبي نجيح-: ... فقال لهما: <q>﴿لا يأتيكما طعام ترزقانه﴾</q>. يقول: في نومكما <q>﴿إلا نبأتكما بتأويله قبل أن يأتيكما﴾</q>{2}. (٨/٢٤٩) ٣٧٣٧٠- عن إسماعيل السُّدِّيّ -من طريق أسباط- قال: <q>﴿قال﴾</q> يوسف: <q>﴿لا يأتيكما طعام تُرْزَقانِهِ﴾</q> في النوم <q>﴿إلا نبأتكما بتأويله﴾</q> في اليَقَظَة{3}. (٨/١٩٢) ٣٧٣٧١- عن محمد بن إسحاق -من طريق سلمة-، بنحوه{4}. (ز) ٣٧٣٧٢- قال مقاتل بن سليمان: قال يوسف: ألا أُخْبِرُكما بأعجبَ مِن الرُّؤيا التي رأيتما، <q>﴿قال لا يأتيكما طعام ترزقانه إلا نبأتكما بتأويله﴾</q>: إلا أخبرتكما بألوانه قبل أن يأتيكما الطعام. فقالوا ليوسف: إنّما يعلم هذا الكَهَنَةُ، والسَّحَرَةُ، وأنت لست في هيئة ذلك. فقال يوسف لهما: <q>﴿ذلكما مما علمني ربي إني تركت ملة قوم﴾</q> أولئك الكهنة، والسحرة، يعني: أهل مصر <q>﴿لا يؤمنون بالله﴾</q> يعني: لا يُصَدِّقون بتوحيد الله، ولا بالبعث الذي فيه جزاء الأعمال، <q>﴿وهم بالآخرة هم كافرون﴾</q>{5}. (ز) ٣٧٣٧٣- عن عبد الملك ابن جُرَيْج -من طريق حجّاج- في قوله: <q>﴿لا يأتيكما طعام ترزقانه﴾</q>، قال: كَرِه العبارةَ كُلَّها، فأجابهما بغير جوابهما؛ لِيُريَهما أنّ عنده عِلْمًا، وكان المَلِك إذا أراد قتل إنسان صنع له طعامًا معلومًا، فأرسل به إليه، فقال يوسف: <q>﴿لا يأتيكما طعام ترزقانه﴾</q> إلى قوله: <q>﴿يشكرون﴾</q>. فلم يَدَعْه صاحبُ الرؤيا حتى يَعبُر لهما، فكرِهَ العبارة، فقال: <q>﴿يا صاحبى السجن ءأرباب﴾</q> إلى قوله: <q>﴿ولكن أكثر الناس لا يعلمون﴾</q>. قال: فلم يدعاه، فعَبَّر لهما{6}٣٣٦٣. (٨/٢٥٣) ٣٣٦٣ اختُلِف هل كان الطعام الذي يأتيهما في اليقظة أم المنام؟ وأثَر ابن جريج مصرِّح بأنه في اليقظة، وهو ما علَّق عليه ابنُ جرير (١٣/١٦٢) بقوله: «وعلى هذا التأويل الذي تأوله ابن جريج فقوله: <q>﴿لا يأتيكما طعام ترزقانه﴾</q> في اليقظة، لا في النوم. وإنّما أعلمهما على هذا القول أنّ عنده علم ما يَؤُول إليه أمرُ الطعام الذي يأتيهما مِن عند الملك ومِن عند غيره؛ لأنّه قد علم النوع الذي إذا أتاهما كان علامةً لقتل مَن أتاه ذلك منهما، والنوع الذي إذا أتاه كان علامةً لغير ذلك، فأخبرهما أنّه عنده علم ذلك». وعلَّق عليه ابنُ عطية (٥/٨٨بتصرف) بقوله: «فعلى هذا إنّما أعْلَمَهم بأنّه يعلم مُغَيَّبات لا تعلق لها برؤيا. وقصد بذلك أحد وجهين: الأول: تَنسِيَتَهما أمرَ تعبيرِ ما سألا عنه؛ إذ في ذلك النذارة بقتل أحدهما. الثاني: الطماعية في إيمانهما. ليأخذ المقتول بحظِّه من الإيمان، وتسلم له آخرته. ثم قال:»وهذا على ما رُوِي مِن أنّه نُبِّئ في السجن، فإخباره كإخبار عيسى ﵇". وانتقد ما جاء مِن أنّ إرسال الملك للطعام يؤذن بقتل المرسَل إليه مستندًا لدلالة اللفظ، وعدم الدليل النقليّ، فقال: «وهذا كله لا يقتضيه اللفظ، ولا ينهض به إسناد». وانتقده ابنُ كثير (٤/٣٩٠ دار طيبة) قولَ ابن جريج مستندًا للسياق، فقال: «وفي هذا الذي قاله نظر؛ لأنّه قد وعدهما أولًا بتعبيرها، ولكن جعل سؤالهما له على وجه التعظيم والاحترام وُصْلَةً وسببًا إلى دعائهما إلى التوحيد والإسلام، لما رأى في سجيتهما مِن قبول الخير، والإقبال عليه، والإنصات إليه، ولهذا لَمّا فرغ مِن دعوتهما شرع في تعبير رؤياهما، مِن غير تكرار سؤال». ",footnotes:1:أخرجه الخطيب في تاريخ بغداد ١٥/٤٥٦. <q>﴿تُرْزَقانِهِ﴾</q> بكسر النون قراءة العشرة، وأما (تُرْزَقانُهُ) بضم النون فهي شاذة. انظر: شرح الرضي على الكافية ٣/٣٥٠.أخرجه ابن جرير ١٣/١٥٤، ١٦٤، ١٦٨، وابن أبي حاتم ٧/٢١٤٢-٢١٤٤، ٢١٤٦، ٢١٤٧.أخرجه ابن جرير ١٣/١٥٩، وابن أبي حاتم ٧/٢١٤٤.أخرجه ابن جرير ١٣/١٥٩.تفسير مقاتل بن سليمان ٢/٣٣٤.أخرجه ابن جرير ١٣/١٦١، وابن أبي حاتم ٧/٢١٤٧ من طريق هشام بن يوسف، قال: زعم محمد بن عباس. فذكر نحوه. وعزاه السيوطي إلى أبي عبيد، وابن المنذر.
