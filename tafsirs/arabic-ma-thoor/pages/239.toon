quran[7]{c,v,t}:
  12,31,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿فَلَمَّا سَمِعَتۡ بِمَكۡرِهِنَّ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٧١٩٨<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿فلما سمعت بمكرهن﴾</span>، قال: بحدِيثِهِنَّ{1}. (٨/٢٣٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧١٩٩<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- قال: <span class="qpc-hafs">﴿فلما سمعت بمكرهن﴾</span>، يقول: بقَوْلِهِنَّ{2}. (٨/١٩١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٢٠٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فلما سمعتْ﴾</span> زليخا <span class="qpc-hafs">﴿بمكرهن﴾</span> يعني: بِقَوْلِهِنَّ لها{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٢٠١<span class="dash">-</span></span> عن <span class="name-3">محمد بن إسحاق</span> -من طريق سلمة- قال: لَمّا أظهر النساءُ ذلك مِن قولهن: تُراوِدُ عبدَها. مكرًا بها؛ لِتُرِيَهُنَّ يوسفَ، وكان يُوصَفُ لِهُنَّ بحسنه وجماله، <span class="qpc-hafs">﴿فلما سمعت بمكرهن أرسلت إليهن وأعتدت لهن متكئا﴾</span>{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٢٠٢<span class="dash">-</span></span> عن <span class="name-3">سفيان [بن عيينة]</span> -من طريق ابن أبي عمر- في قوله: <span class="qpc-hafs">﴿سمعت بمكرهن﴾</span>، قال: بِعَمَلِهِنَّ، وقال: كُلُّ مَكْر في القرآن فهو عمل{5}<span class=comment-ref>٣٣٥٠</span>. (٨/٢٣٧)</p></p><p></div></p><p><div><span class=comment-ref>٣٣٥٠</span> <span class="comment-type-4">ذَكَر</span> <u>ابنُ عطية</u> (٥/٧٧) أنّ قولهن سُمِّي مكرًا مِن حيث أظهرن إنكار منكرٍ، وقصدن إثارةَ غيظها عليهن. ثم أورد قولًا آخر، فقال: «وقيل: مكْرُهُنَّ أنهن أفشين ذلك عنها، وقد كانت أطْلَعَتْهُنَّ على ذلك، واسْتَكْتَمَتْهُنَّ إيّاه». و<span class="comment-type-4">علَّق</span> عليه بقوله: «وهذا لا يكون مكرًا إلا بأن يُظْهِرن لها خلاف ذلك، ويقصدن بالإفشاء أذاها».</div></p><p><h3><span class="qpc-hafs">﴿أَرۡسَلَتۡ إِلَیۡهِنَّ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٧٢٠٣<span class="dash">-</span></span> قال <span class="name-2">وهب [بن مُنَبِّه]</span>، في قوله: <span class="qpc-hafs">﴿أرسلت إليهن﴾</span>: اتَّخَذَتْ مأدبة، ودَعَتْ أربعين امرأة، مِنهُنَّ هؤلاء اللاتي عَيَّرْنَها{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٢٠٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿أرسلت إليهن﴾</span> فجِئْنَها{3}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَأَعۡتَدَتۡ لَهُنَّ مُتَّكَـࣰٔا﴾</span> - قراءات، وتفسيرها</h3></p><p><div></p><p><p><span class="item-no">٣٧٢٠٥<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عوف- أنّه كان يقرؤها: (مُتْكًا) مخففة، ويقول: هو الأُتْرُجُّ{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٢٠٦<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، قال: المتكأ: الأُتْرُنجُ. وكان يقرؤها خفيفةً{9}. (٨/٢٣٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٢٠٧<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق منصور- قال: مَن قرأ: <span class="qpc-hafs">﴿مُتَّكَأً﴾</span> شَدَّها؛ فهو الطعام، ومَن قرأ: (مُتْكًا) خفَّفها؛ فهو الأُتْرُنج{10}. (٨/٢٣٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٢٠٨<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق أبي الأشهب- أنّه كان يقرأ: (مُتَّكَآءً)، ويقول: هو المجلس والطعام{11}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٢٠٩<span class="dash">-</span></span> عن <span class="name-3">أبان بن تغلب</span> أنّه كان يقرأ: (وأَعْتَدَتْ لَهُنَّ مُتْكًا) مُخَفَّفة، قال: الأُترُنج{12}. (٨/٢٣٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٢١٠<span class="dash">-</span></span> عن عبد الله بن يزيد -من طريق إسحاق-: مَن قرأ: (مُتْكًا) خفيفة يعني: طعامًا، ومَن قرأ: <span class="qpc-hafs">﴿مُتَّكَأً﴾</span> يعني: المُتَّكأَ{13}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَأَعۡتَدَتۡ لَهُنَّ مُتَّكَـࣰٔا﴾</span> - تفسير الآية</h3></p><p><div></p><p><p><span class="item-no">٣٧٢١١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- في قوله: <span class="qpc-hafs">﴿وأعتدت لهن متكأ﴾</span>، قال: هَيَّأَتْ لَهُنَّ مجلسًا{14}. (٨/٢٣٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٢١٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق مجاهد- <span class="qpc-hafs">﴿وأعتدت لهن متكأ﴾</span>، قال: أعْطَتْهُنَّ أُتْرُنجًا{15}. (٨/٢٣٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٢١٣<span class="dash">-</span></span> قال <span class="name-1">عبد الله بن عباس</span>: <span class="qpc-hafs">﴿متكأ﴾</span>، أي: طعامًا{16}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٢١٤<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span> -من طريق جعفر- في قوله: <span class="qpc-hafs">﴿وأعتدت لهن متكأ﴾</span>، قال: طعامًا وشرابًا ومُتَّكَأً{17}. (٨/٢٣٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٢١٥<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span> -من طريق أبي بشر- في قوله: <span class="qpc-hafs">﴿وأعتدت لهن متكأ﴾</span>، قال: طعامًا{18}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٢١٦<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ليث- في قوله: <span class="qpc-hafs">﴿متكأ﴾</span>، قال: طعامًا{19}. (٨/٢٣٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٢١٧<span class="dash">-</span></span> قال <span class="name-2">مجاهد بن جبر</span>، في قوله: <span class="qpc-hafs">﴿لهن متكئا﴾</span>، يعني: مجلسًا وتكأة{20}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٢١٨<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span>، في قوله: <span class="qpc-hafs">﴿متكئا﴾</span>، قال: هو الأُترُنج{21}. (٨/٢٣٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٢١٩<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن عيينة، عن رجل-: (مُتْكًا)، قال: كل شيء قُطِع بالسكين{22}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٢٢٠<span class="dash">-</span></span> عن <span class="name-2">الضحاك بن مزاحم</span> -من طريق أبي رَوْق- في قوله: <span class="qpc-hafs">﴿وأعتدت لهن متكأ﴾</span>، قال: البَزْماوَرْدُ{23}{24}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٢٢١<span class="dash">-</span></span> عن <span class="name-2">الضحاك بن مُزاحِم</span> -من طريق عبد الواحد بن زياد، عن أبي رَوْق- في قوله: <span class="qpc-hafs">﴿وأعتدت لهن متكأ﴾</span>، قال: أُترُنجًا بعد الغِذاء{25}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٢٢٢<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span> -من طريق الحكم- في قوله: <span class="qpc-hafs">﴿متكأ﴾</span>، قال: كل شيء يُقطَع بالسكين{25}. (٨/٢٤٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٢٢٣<span class="dash">-</span></span> عن <span class="name-2">الضَّحّاك بن مُزاحم</span> -من طريق عبيد-، مثله{27}. (٨/٢٤٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٢٢٤<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span> -من طريق أبي رجاء- في قوله: <span class="qpc-hafs">﴿متكأ﴾</span>، قال: طعامًا{28}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٢٢٥<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق أبي الأشهب- أنّه كان يقرأ: <span class="qpc-hafs">﴿متكأ﴾</span>، ويقول: هو المَجْلِس، والطَّعام{13}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٢٢٦<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق أبي رجاء- في قوله: <span class="qpc-hafs">﴿وأعتدت لهن متكأ﴾</span>، قال: طعامًا{30}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٢٢٧<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span>، مثل ذلك{31}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٢٢٨<span class="dash">-</span></span> عن <span class="name-2">عطية [العوفي]</span> -من طريق ابن إدريس، عن أبيه- <span class="qpc-hafs">﴿وأعتدت لهن متكئا﴾</span>، قال: الطَّعام{32}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٢٢٩<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿وأعتدت لهن متكأ﴾</span>، أي: طعامًا{33}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٢٣٠<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- قال: <span class="qpc-hafs">﴿أرسلت إليهن وأَعتَدَت لهن متكئًا﴾</span> يَتَّكِئْنَ عليه{34}. (٨/١٩١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٢٣١<span class="dash">-</span></span> عن <span class="name-2">سلمة بن تمام أبي عبد الله الشَّقَريِّ</span>، قال: <span class="qpc-hafs">﴿متكأ﴾</span> بكلام الحبش؛ يسمون التُّرُنجَ: مُتُكًا{35}. (٨/٢٣٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٢٣٢<span class="dash">-</span></span> عن ليث [بن أبي سليم] -من طريق جرير- قال: سَمِعتُ بعضَهم يقول: الأترج{36}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٢٣٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وأعتدت لهن متكأ﴾</span>، وهو الأُتْرُج، وكُلُّ شيء يُحَزُّ بالسكين فهو مُتَّكأ{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٢٣٤<span class="dash">-</span></span> عن <span class="name-3">محمد بن إسحاق</span> -من طريق سلمة- قال: <span class="qpc-hafs">﴿وأعتدت لهن متكأ﴾</span>، والمُتَّكأ: الطَّعام{28}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٢٣٥<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- قال: أعْطَتْهُنَّ تُرُنجًا وعسلًا ...{39}. (٨/٢٤٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٢٣٦<span class="dash">-</span></span> قال <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- <span class="qpc-hafs">﴿متكأ﴾</span>: طعامًا{28}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٢٣٧<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: وهي تقرأ (مُتكًا)، قال بعضهم: هو الأُتْرُج{41}<span class=comment-ref>٣٣٥١</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٣٣٥١</span> <span class="comment-type-4">ذكر</span> <u>ابنُ جرير</u> (١٣/١٢٣) أنّ المتكأ يعني: ما يُتَّكأ عليه من النمارق والوسائد. ثم <span class="comment-type-1">وجَّه</span> (١٣/١٢٤) تفسير المتكأ بالطعام بقوله: «فسّر بعضهم المتكأ بأنّه: الطعام، على وجه الخبر عن الذي أُعِدَّ من أجله المتكأ، وبعضهم عن الخبر عن الأترج، إذ كان في الكلام: وآتت كلَّ واحدة منهن سكينًا؛ لأنّ السكين إنما تعد للأترج وما أشبهه مما يقطع به. وبعضهم على البزماورد».</p><p>و<span class="comment-type-4">بنحوه</span> قال <u>ابنُ عطية</u> (٥/٧٧).</div></p><p><h3><span class="qpc-hafs">﴿وَءَاتَتۡ كُلَّ وَ ٰ⁠حِدَةࣲ مِّنۡهُنَّ سِكِّینࣰا﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٧٢٣٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- في قوله: <span class="qpc-hafs">﴿وأعتدت لهن متكأ﴾</span>، قال: هيَّأت لَهُنَّ مجلسًا، وكان سُنَّتُهم إذا وضعوا المائدة أعْطَوا كُلَّ إنسان سِكِّينًا يأكل بها{42}. (٨/٢٣٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٢٣٩<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق مجاهد- <span class="qpc-hafs">﴿وأعتدت لهن متكأ﴾</span>، قال: أعْطَتْهُنَّ أُتْرُنجًا، وأَعْطَتْ كُلَّ واحدةٍ مِنهُنَّ سكينًا، فلمّا رأين يوسفَ أكْبَرْنَه، وجَعَلْنَ يُقَطِّعنَّ أيديَهن، وهُنَّ يَحسبنَ أنّهُنَّ يُقَطِّعن الأُترُنجَ{43}. (٨/٢٣٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٢٤٠<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿وآتت كل واحدة منهن سكينا﴾</span>، قال: أعْطَتْ كُلَّ واحدةٍ مِنهُنَّ سكينًا{44}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٢٤١<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- قال: <span class="qpc-hafs">﴿وآتت كل واحدة منهن سكينًا﴾</span>، وأُترُجًا يَأْكُلْنَه{45}. (٨/١٩١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٢٤٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وآتت﴾</span> يعني: وأَعْطَتْ <span class="qpc-hafs">﴿كل واحدة منهن سكينا﴾</span>، وأمرت يوسفَ ﵇ فتَزَيَّنَ، وتَرَجَّل{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٢٤٣<span class="dash">-</span></span> عن <span class="name-3">محمد بن إسحاق</span> -من طريق سلمة-: <span class="qpc-hafs">﴿وآتت كل واحدة منهن سكينا﴾</span> لِيَحْتَزِزْن به مِن طعامِهِنَّ{47}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٢٤٤<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- قال: أعْطَتْهُنَّ تُرُنجًا وعَسَلًا، فكُنَّ يَحْزُزْن التُّرُنجَ بالسكين، ويأكلن بالعسل ...{39}. (٨/٢٤٠)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَقَالَتِ ٱخۡرُجۡ عَلَیۡهِنَّۖ فَلَمَّا رَأَیۡنَهُۥۤ أَكۡبَرۡنَهُۥ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٧٢٤٥<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- في قوله: <span class="qpc-hafs">﴿فلما رأينه﴾</span> قال: فلمّا خرج عليهن يوسف <span class="qpc-hafs">﴿أكبرنه﴾</span> قال: أعْظَمْنَه، ونظرن إليه، وأقبَلن يَحْزُزنَ أيديَهن بالسكاكين وهُنَّ يَحْسَبْنَ أنّهُنَّ يُقَطِّعنَ الطعام{49}. (٨/٢٣٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٢٤٦<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عبد الصمد بن علي بن عبد الله بن عباس، عن أبيه، عن جدِّه- في قوله: <span class="qpc-hafs">﴿فلما رأينه أكبرنه﴾</span>، قال: لَمّا خرج عليهن يوسف حِضْنَ مِن الفرح، وقال الشاعر:</p><p>نأتي النساء لدى إطهارِهنَّ ولا نأتي النساء إذا أكْبرنَ إكبارا{50}<span class=comment-ref>٣٣٥٢</span>. (٨/٢٤١)</p></p><p></div></p><p><div><span class=comment-ref>٣٣٥٢</span> <span class="comment-type-2">انتَقَد</span> <u>ابنُ جرير</u> (١٣/١٣٢) هذا القول <span class="mustanad">مستندًا إلى اللغة، والدلالة العقلية</span>، بقوله: «وهذا القول، ... إن لم يكن عُني به أنّهُنَّ حِضْنَ مِن إجلالهن يوسف وإعظامهن لِما كان الله قَسَمَ له مِن البهاء والجمال، ولِما يجد مِن مثل ذلك النساء عند معاينتهن إياه؛ فقولٌ لا معنى له؛ لأن تأويل ذلك: فلما رأين يوسف أكبرنه. فالهاء التي في <span class="qpc-hafs">﴿أكبرنه﴾</span> مِن ذكر يوسف، ولا شكَّ أنّ مِن المحال أن يَحِضْنَ يوسفَ»، ثم <span class="comment-type-1">وجّهه</span> بقوله: «ولكن الخبر إن كان صحيحًا عن ابن عباس على ما رُوِي فخليقٌ أن يكون كان معناه في ذلك: أنّهُنَّ حِضْنَ لِما أكبرن مِن حسن يوسف وجماله في أنفسهن، ووجدن ما يجد النساء من مثل ذلك». ثم <span class="comment-type-4">بيَّن</span> أنّ البيت المروي في ذلك لا أصل له، لأنه ليس بالمعروف عند الرواة.</p><p>و<span class="comment-type-2">انتقده</span> <u>ابنُ عطية</u> (٥/٧٩) <span class="mustanad">مستندًا إلى اللغة</span>، فقال: «وهذا قول ضعيف، ومعناه منكور، والبيت مصنوع مختلق، كذلك قال الطبري وغيره من المحققين، وليس عبد الصمد مِن رواة العِلم».</div></p><p><div></p><p><p><span class="item-no">٣٧٢٤٧<span class="dash">-</span></span> قال <span class="name-2">أبو العالية الرياحي</span>، في قوله: <span class="qpc-hafs">﴿فلما رأينه أكبرنه﴾</span>: هالَهُنَّ أمرُه، وبُهِتْنَ{51}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٢٤٨<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿فلما رأينه أكبرنه﴾</span>، قال: أعْظَمْنه{52}. (٨/٢٤١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٢٤٩<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿فلما رأينه أكبرنه﴾</span>، أي: أعْظَمْنَه{53}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٢٥٠<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- قال: وقالت ليوسف: <span class="qpc-hafs">﴿اخرج عليهن﴾</span>. فلمّا خرج ورأى النسوةُ يوسفَ أعْظَمْنَه{54}. (٨/١٩١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٢٥١<span class="dash">-</span></span> عن عبد العزيز بن الوزير بن الكُمَيتِ بن زيد بن الكُمَيتِ الشاعر قال: حدَّثني أبي، عن جدِّي، قال: سمعت جدِّي <span class="name-2">الكُمَيت</span> يقول في قوله: <span class="qpc-hafs">﴿فلما رأينه أكبرنه﴾</span>، قال: أمْنَيْنَ، وأنشَدَ في ذلك:</p><p>لَمّا رأته الخيلُ مِن رأس شاهِقٍ صَهَلن وأمَنين المَنِيَّ الـمُدَفَّقا{12}. (٨/٢٤١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٢٥٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وقالت﴾</span> أي: ثُمَّ قالت: يا يوسف، <span class="qpc-hafs">﴿اخرج عليهن﴾</span> مِن البيت. <span class="qpc-hafs">﴿فلما رأينه أكبرنه﴾</span> يعني: أعْظَمْنَه{56}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٢٥٣<span class="dash">-</span></span> عن <span class="name-3">محمد بن إسحاق</span> -من طريق سلمة- قال: قالت ليوسف: <span class="qpc-hafs">﴿اخرج عليهن﴾</span>. فخرج عليهن، <span class="qpc-hafs">﴿فلما رأينه أكبرنه﴾</span>، وغُلِبَت عقولُهُنَّ عجبًا حين رأينه، فجعلن يقطعن أيديهن بالسكاكين التي مَعَهُنَّ، ما يَعْقِلْنَ شيئًا مِمّا يَصْنَعْنَ، وقلن: <span class="qpc-hafs">﴿حاش لله ما هذا بشرا﴾</span>{57}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٢٥٤<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- قال: فلما قيل له: <span class="qpc-hafs">﴿اخرج عليهن﴾</span>. خرج، <span class="qpc-hafs">﴿فلما رأينه﴾</span> أعْظَمْنَه، وتَهَيَّمْنَ به{58}. (٨/٢٤٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٢٥٥<span class="dash">-</span></span> عن دريد بن مجاشع، عن بعض أشياخه، قال: قالت للقَيِّم: أدْخِلْهُ عليهِنَّ، وألبسه ثيابًا بيضًا؛ فإنّ الجميل أحسنُ ما يكون في البياض ...{59}. (٨/٢٤٠)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَقَطَّعۡنَ أَیۡدِیَهُنَّ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٧٢٥٦<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق مجاهد- في قوله: <span class="qpc-hafs">﴿وقطعن أيديهن﴾</span>، قال: لَمّا رَأَيْن يوسف جَعَلْنَ يُقطِّعْنَ أيديَهُنَّ، وهُنَّ يَحْسَبْنَ أنّهُنَّ يُقطعْنَ الأُترُجَّ{60}. (٨/٢٣٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٢٥٧<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ورقاء عن ابن أبي نَجِيح- قوله: <span class="qpc-hafs">﴿وقطعن أيديهن﴾</span>: حزًّا حزًّا بالسكين حتى ألْقَيْنها{61}. (٨/٢٤١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٢٥٨<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق معمر عن ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿وقطعن أيديهن﴾</span>، قال: قطعن أيديهن حتى ألْقَيْنها{62}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٢٥٩<span class="dash">-</span></span> قال <span class="name-2">مجاهد بن جبر</span>: فما أحْسَسْنَ إلا بالدَّم{51}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٢٦٠<span class="dash">-</span></span> قال <span class="name-2">وهب [بن مُنَبِّه]</span>: وبلغني: أنّ تِسعًا مِن الأربعين مُتْنَ في ذلك المجلس وجْدًا بيوسف{64}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٢٦١<span class="dash">-</span></span> عن مُنَبِّه، عن أبيه، قال: مات مِن النسوة اللّاتي قَطَّعْنَ أيديهنَّ تسع عشرة امرأة كَمَدًا{12}. (٨/٢٤٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٢٦٢<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق محمد بن ثور، عن مَعْمَر- <span class="qpc-hafs">﴿وقطعن أيديهن﴾</span>، قال: جَعَلْنَ يَحْزُزْنَ أيديَهُنَّ، ولا يَشْعُرْن بذلك{66}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٢٦٣<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق عبد الرزاق، عن مَعْمَر- في قوله: <span class="qpc-hafs">﴿وقطعن أيديهن﴾</span>، قال: قَطَّعن أيديهن حتى ألْقَيْنَها{67}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٢٦٤<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- قال: وجَعَلْنَ يَحزُزْنَ أيديَهُنَّ وهنَّ يحسبن أنّهُنَّ يُقَطِّعن الأُتْرُجَّ، ويَقُلْن: <span class="qpc-hafs">﴿حاش لله ما هذا بشرًا إن هذا إلا ملك كريم﴾</span>{68}. (٨/١٩١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٢٦٥<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق علي بن عابس- قال: كانت في أيديهن سكاكين مع الأُتْرُج، فقطعن أيديهن، وسالت الدماء، فقُلْنَ: نحن نلومُكِ على حُبِّ هذا الرجل، ونحن قد قطعنا أيدينا وسالت الدماء!{69}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٢٦٦<span class="dash">-</span></span> عن <span class="name-2">زيد بن أسلم</span> -من طريق يحيى بن العلاء- قال: لَمّا قرَرْنَ وطابت أنفُسُهُنَّ قالت لقيِّمِها: آتِهن تُرُنجًا وسكاكين. فأتاهُنَّ بِهِنَّ، فجعلْنَ يُقطعن ويأكلن، فقالت لهن: هل لَكُنَّ في النظر إلى يوسف؟ قلن: ما شئتِ. فأمَرَتْ قَيِّمَها، فأدخله عليهِنَّ، فلما رأينه جعَلن يقطعن أصابعهن مع الأُترُنجِ وهُنَّ لا يَشْعُرْن، ولا يجدن ألَمًا مِمّا رأين مِن حُسنه، فلمّا ولّى عَنْهُنَ قالت: هذا الذي لُمْتُنّنِي فيه، فلقد رأيتُكُنَّ تُقَطِّعْنَ أيديكُنَّ وما تَشْعُرْنَ. قال: فنظَرن إلى أيديهن، فجَعَلْنَ يصِحْنَ ويبكينَ. قالت: فكيف أصنع أنا؟! فقلن: <span class="qpc-hafs">﴿حاش لله ما هذا بشرًا إن هذا إلا ملك كريم﴾</span>، وما نرى عليكِ مِن لَوْمٍ بعد الذى رأينا{70}. (٨/٢٤٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٢٦٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>، في قوله: <span class="qpc-hafs">﴿وقطعن أيديهن﴾</span>، يعني: وحَزَزْنَ أصابعهن بالسكين حين نَظَرْنَ إليه{56}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٢٦٨<span class="dash">-</span></span> عن <span class="name-3">محمد بن إسحاق</span> -من طريق سلمة- قال: قالتْ ليوسف: <span class="qpc-hafs">﴿اخرج عليهن﴾</span>. فخرج عليهن، <span class="qpc-hafs">﴿فلما رأينه أكبرنه﴾</span>، وغُلِبَتْ عقولهن عجبًا حين رأينه، فجعلن يقطعن أيديهن بالسكاكين التي معهن، ما يعقلن شيئًا مِمّا يصنعن، وقلن: <span class="qpc-hafs">﴿حاش لله ما هذا بشرا﴾</span>{66}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٢٦٩<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- قال: حتى جعلن يحززن أيديهن بالسكين، وفيها التُّرُنج، ولا يَعْقِلْنَ، لا يحسبن إلا أنّهُنَّ يَحْزُزْنَ الأُترُنج، قد ذَهَبَتْ عُقُولُهُنَّ مِمّا رَأَيْنَ{73}. (٨/٢٤٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٢٧٠<span class="dash">-</span></span> عن دريد بن مجاشع، عن بعض أشياخه، قال:... فأدخله عليهِنَّ وهُنَّ يَحْزُزْنَ ما في أيديهن، فلمّا رأينه حَزَزْن أيديهن وهُنَّ لا يَشْعُرْنَ مِن النظر إليه، فنظرن إليه مُقْبِلًا، ثم أومَأت إليه: أن ارجع. فنظَرن إليه مُدْبِرًا وهُنَّ يحززن أيديهن بالسكاكين، لا يَشْعُرْنَ بالوَجَع مِن نظرِهِنَّ إليه، فلمّا خرج نَظَرْن إلى أيدِيهن، وجاء الوَجَعُ، فجَعَلْنَ يُوَلْوِلْنَ، وقالت لهن: أنتُنَّ مِن ساعة واحدة هكذا صنَعتُنَّ، فكيف أصنع أنا؟! <span class="qpc-hafs">﴿وقلن حاش لله ما هذا بشرًا إن هذا إلا ملك كريم﴾</span>{74}<span class=comment-ref>٣٣٥٣</span>. (٨/٢٤٠)</p></p><p></div></p><p><div><span class=comment-ref>٣٣٥٣</span> اختُلِف في المراد بقوله: <span class="qpc-hafs">﴿وقطعن أيديهن﴾</span> على قولين: <b>الأول</b>: أنّ المعنى: أنهن جرحن، وهن يحسبن أنهن يقطعن الأترج. <b>الثاني</b>: أنهن قطعن أيديهن حتى أبنّها وألقينها.</p><p>و<span class="comment-type-3">رجَّح</span> <u>ابنُ جرير</u> (١٣/١٣٥) جوازهما، مع عدم القطع بأحدهما؛ <span class="mustanad">لعدم الدليل على تعيين أحدهما</span>، فقال: «والصواب من القول في ذلك أن يُقال: إنّ الله أخبر عنهن أنهن قطعن أيديهن وهن لا يشعرن لإعظام يوسف، وجائز أن يكون ذلك كان قطعًا بإبانة، وجائز أن يكون كان قطعَ حزٍّ وخَدْش، ولا قول في ذلك أصوب من التسليم لظاهر التنزيل».</p><p>و<span class="comment-type-2">انتقد</span> <u>ابنُ عطية</u> (٥/٧٩) القول الثاني الذي قاله مجاهد، وقتادة <span class="mustanad">مستندًا للدلالة العقلية</span>، فقال: «وذلك ضعيف من معناه، وذلك أنّ قطع العظم لا يكون إلا بشدة، ومحال أن يسهو أحدٌ عنها، والقطع على المفصل لا يتهيأ إلا بتلطف لا بد أن يُقصد».</p><p>و<span class="comment-type-3">رجَّح</span> القولَ الأول، فقال: «والذي يُشْبِه أنّهُنَّ حملن على أيديهن الحملَ الذي كُنَّ يحملنه قبل المتْك، فكان ذلك حزًّا، وهذا قول الجماعة».</div></p><p><h3><span class="qpc-hafs">﴿وَقُلۡنَ حَـٰشَ لِلَّهِ مَا هَـٰذَا بَشَرًا إِنۡ هَـٰذَاۤ إِلَّا مَلَكࣱ كَرِیمࣱ ۝٣١﴾</span> - قراءات</h3></p><p><div></p><p><p><span class="item-no">٣٧٢٧١<span class="dash">-</span></span> عن أسِيدِ بن يزيد: أنّ في مصحف <span class="name-1">عثمان</span>: <span class="qpc-hafs">﴿وقُلْنَ حاشَ للهِ﴾</span>، ليس فيها ألف{75}. (٨/٢٤٢)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَقُلۡنَ حَـٰشَ لِلَّهِ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٧٢٧٢<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿وقُلن حاش لله﴾</span>، قال: مَعاذ الله{76}. (٨/٢٤١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٢٧٣<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق عمرو- <span class="qpc-hafs">﴿حاش لله﴾</span>: مَعاذ الله{77}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٢٧٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وقلن حاش لله﴾</span>، يعني: مَعاذ الله{56}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿مَا هَـٰذَا بَشَرًا إِنۡ هَـٰذَاۤ إِلَّا مَلَكࣱ كَرِیمࣱ ۝٣١﴾</span> - قراءات</h3></p><p><div></p><p><p><span class="item-no">٣٧٢٧٥<span class="dash">-</span></span> عن أبي الحُوَيْرِث الحنفي -من طريق دعامة بن رجاء التيمي- أنّه قرأها: (ما هَذا بِشِرًى). أي: ما هذا بِمُشْتَرًى{79}<span class=comment-ref>٣٣٥٤</span>. (٨/٢٤٢)</p></p><p></div></p><p><div><span class=comment-ref>٣٣٥٤</span> اختُلِف في قراءة قوله: <span class="qpc-hafs">﴿ما هذا بشرا﴾</span>؛ <b>فقرأ قوم</b>: <span class="qpc-hafs">﴿بشرا﴾</span>. <b>وقرأ آخرون</b>: <span class="qpc-hafs">﴿بشرى﴾</span>.</p><p>و<span class="comment-type-4">ذكر</span> <u>ابنُ جرير</u> (١٣/١٤٠) أنّ القراءة الأولى قرأ بها عامة قراء الأمصار، و<span class="comment-type-2">انتقد</span> القراءة الثانية <span class="mustanad">مستندًا لإجماع القراء</span>، فقال: «وهذه القراءة لا أستجيز القراءة بها؛ لإجماع قُرّاء الأمصار على خلافها».</div></p><p><h3><span class="qpc-hafs">﴿مَا هَـٰذَا بَشَرًا إِنۡ هَـٰذَاۤ إِلَّا مَلَكࣱ كَرِیمࣱ ۝٣١﴾</span> - تفسير الآية</h3></p><p><div></p><p><p><span class="item-no">٣٧٢٧٦<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دِعامة</span> -من طريق مَعْمَر- في قوله: <span class="qpc-hafs">﴿إن هذا إلا ملك كريم﴾</span>، قال: قلن: مَلَكٌ مِن الملائكة. مِن حُسْنِه{80}. (٨/٢٤٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٢٧٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ما هذا بشرا﴾</span> إنسانًا، <span class="qpc-hafs">﴿إن هذا إلا ملك كريم﴾</span> يعني: حَسَن. فأعجبها ما صَنَعْنَ، وما قُلْنَ{56}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٢٧٨<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- قال: وقُلْنَ: <span class="qpc-hafs">﴿حاش لله ما هذا بشرًا﴾</span>: ما هكذا يكون البشر؛ ما هذا إلا مَلَك كريم{82}<span class=comment-ref>٣٣٥٥</span>. (٨/٢٤٠)</p></p><p></div></p><p><div><span class=comment-ref>٣٣٥٥</span> <span class="comment-type-4">ذكر</span> <u>ابنُ عطية</u> (٥/٧٨) أنّ مكيًّا والمهدوي ذكرا أنّه قيل: إنّ في الآية تقديمًا وتأخيرًا في القصص، وذلك أنّ قصة النسوة كانت قبل فضيحتها في القميص للسيِّد، وباشتهار الأمر للسيد انقطع ما بينها وبين يوسف. و<span class="comment-type-4">علَّق</span> عليه بقوله: «وهذا مُحْتَمَل، إلا أنّه لا يلزم مِن ألفاظ الآية، بل يحتمل أن كانت قصة النساء بعد قصة القميص، وذلك أنّ العزيز كان قليل الغيرة، بل قومه أجمعون، ألا ترى أنّ الإنكار في وقت القميص إنما كان بأن قيل: <span class="qpc-hafs">﴿إنه من كيدكن إن كيدكن عظيم﴾</span>. وهذا يَدُلُّ على قلة الغيرة، ثم سكن الأمر بأن قال: <span class="qpc-hafs">﴿يوسف أعرض عن هذا﴾</span>، وأنت <span class="qpc-hafs">﴿واستغفري﴾</span>، وهي لم تبق حينئذ إلا على إنكارها، وإظهار الصِّحَّة، فلذلك تُغُوفِل عنها بعد ذلك؛ لأنّ دليل القميص لم يكن قاطعًا، وإنّما كان أمارةً ما، هذا إن لم يكن المتكلم طفلًا».</div></p><p><h3><span class="qpc-hafs">﴿مَا هَـٰذَا بَشَرًا إِنۡ هَـٰذَاۤ إِلَّا مَلَكࣱ كَرِیمࣱ ۝٣١﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٣٧٢٧٩<span class="dash">-</span></span> عن أنس، عن النبي ﷺ، قال: «<b>أُعطِيَ يوسف وأمُّه شَطْرَ الحُسْن</b>»{83}. (٨/٢٤٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٢٨٠<span class="dash">-</span></span> عن الحسن، أنّ النبي ﷺ قال: «<b>أُعطِيَ يوسف وأمه ثُلُث حُسْن أهل الدنيا، وأُعطِيَ الناس الثلثين</b>»{84}<span class=comment-ref>٣٣٥٦</span>. (٨/٢٤٤)</p></p><p></div></p><p><div><span class=comment-ref>٣٣٥٦</span> ساق <u>ابنُ عطية</u> (٥/٨٢) هذه الآثار، ثم <span class="comment-type-4">علَّق</span> بقوله: «هذا على جهة التمثيل، أي: لو كان الحسن مما يُقْسَم لكان حُسْن يوسف يقع في نصفه، فالقصد: أن يقع في نفس السامع عظم حُسْنِه، على نحو التشبيه برؤوس الشياطين، وأنياب الأغوال».</div></p><p><div></p><p><p><span class="item-no">٣٧٢٨١<span class="dash">-</span></span> عن أبي سعيد الخدري، قال: قال رسول الله ﷺ: «<b>رأيتُ ليلة أسري بي إلى السماءِ يوسفَ كالقَمَر ليلة البدر</b>»{85}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٢٨٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن مسعود</span> -من طريق أبي الأَحْوَص- قال: أُعطِيَ يوسف وأمُّه ثُلُث الحُسْن{86}. (٨/٢٤٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٢٨٣<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن مسعود</span> -من طريق أبي الأحوص- قال: كان وجهُ يوسف مثلَ البَرْق، وكانت المرأةُ إذا أتته لِحاجة غَطّى وجهَه مخافة أن تُفْتَن به{87}. (٨/٢٤٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٢٨٤<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن مسعود</span> -من طريق أبي الأحوص- قال: أُوتِي يوسف ﵇ وأمُّه ثُلُثَ حُسْن خلق الناس؛ في الوجه، والبياض، وغير ذلك{88}. (٨/٢٤٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٢٨٥<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق مُقاتِل- قال: قسم الله الحُسْنَ عشرة أجزاء؛ فجعل منها ثلاثةَ أجزاء في حوّاء، وثلاثة أجزاء في سارة، وثلاثة أجزاء في يوسف، وجزءًا في سائر الخلق، وكانت سارةُ مِن أحْسَنِ نِساء أهل الأرض، وكانت مِن أشد النساء غيرةً{89}. (٨/٢٤٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٢٨٦<span class="dash">-</span></span> عن <span class="name-2">كعب الأحبار</span> -من طريق الحسن، عن سمرة- قال: قسَم اللهُ ليوسف مِن الجمال الثلثين، وقسَم بين عباده الثُّلُث، وكان يُشبِهُ آدمَ يوم خلقه الله، فلمّا عصى آدمُ نُزِع منه النور والبهاء والحسن، ووهُبِ له ثلث مِن الجمال مع التوبة، فأعطى الله ليوسف ذلك الثلثين، وأعطاه تأويل الرُّؤْيا، وإذا تبسَّم رأيتَ النور في ضواحِكه{90}. (٨/٢٤٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٢٨٧<span class="dash">-</span></span> عن <span class="name-2">ربيعة الجُرَشي</span> -من طريق مجاهد- قال: قُسِم الحُسْنُ نصفين؛ فجُعِل ليوسف وسارة النصف، وقُسِم النصف الآخر بين سائر الناس{91}. (٨/٢٤٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٢٨٨<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span>، قال: كان فضلُ حُسْنِ يوسف على الناس كفضل القمر ليلة البدر على نجوم السماء{92}. (٨/٢٤٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٢٨٩<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق يونس- قال: قُسِم الحُسنُ ثلاثة أثلاثٍ؛ فأُعطِيَ يوسف الثُّلُث، وقُسِم الثُلُثان بين الناس، فكان أحسنَ الناس{93}. (٨/٢٤٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٢٩٠<span class="dash">-</span></span> عن إسحاق بن عبد الله، قال: كان يوسفَ ﵇ إذا سار في أزِقَّةِ مصر يُرى تَلَأْلُؤُ وجهه على الجدران، كما يُرى تَلَأْلُؤُ الماءِ والشمسِ على الجدران{12}. (٨/٢٤٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٢٩١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: كان أُعْطِي يوسفُ في زمانه ثُلُث الحُسْن، وأتاه الحُسْنُ مِن قِبَل جدِّه إسحاق، مِن قِبَل أُمِّه سارة، ووَرِثَتْ سارة حُسْنَها مِن قِبَل حواء امرأة آدم ﵇، وحُسْنُ حواء مِن آدم؛ لأنّها خُلِقَت منه. وقال مقاتل: كلُّ ذكر أحسن مِن الأنثى، من الأشياء كلها، وفضلُ يوسف في زمانه بحُسْنِه على الناس كفضل القمر ليلة البدر على الكواكب{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٢٩٢<span class="dash">-</span></span> قال <span class="name-3">محمد بن إسحاق</span>: ذهب يوسفُ وأمُّه بثُلُثِي الحُسْن{96}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ١٣/١٢٢، وابن أبي حاتم ٧/٢١٣٢.أخرجه ابن جرير ١٣/١٢٢، وابن أبي حاتم ٧/٢١٣٣.تفسير مقاتل بن سليمان ٢/٣٣١.أخرجه ابن جرير ١٣/١٢٢.أخرجه ابن أبي حاتم ٧/٢١٣٢.تفسير الثعلبي ٥/٢١٧، وتفسير البغوي ٤/٢٣٧.تفسير مقاتل بن سليمان ٢/٣٣١.أخرجه ابن جرير ١٣/١٢٦. وعزاه الحافظ ابن حجر في الفتح ٨/٣٥٩ إلى عبد بن حميد.</p><p>وهي قراءة شاذة، تروى أيضًا عن ابن عمر، والجحدريّ وغيرهما. انظر: المحتسب ١/٣٣٩.أخرجه مسدد -كما في المطالب العالية (٤٠١٨)-، وابن جرير ١٣/١٢٦ من طريق مجاهد بلفظ: الترنج، دون الإشارة للقراءة، وابن أبي حاتم ٧/٢١٣٢. وعزاه السيوطي إلى ابن المنذر، وأبي الشيخ، وابن مردويه.أخرجه ابن جرير ١٣/١٢٧ بلفظ: الأترج، وابن أبي حاتم ٧/٢١٣٣. وعزاه السيوطي إلى أبي عبيد، وابن المنذر، وأبي الشيخ.</p><p>و<span class="qpc-hafs">﴿مُتَّكَأً﴾</span> بالتشديد هي قراءة العشرة.أخرجه ابن جرير ١٣/١٢٣، وابن أبي حاتم ٧/٢١٣٣ من طريق أبي رجاء.</p><p>وهي قراءة شاذة. انظر: مختصر ابن خالويه ص٦٨، والمحتسب ١/٣٣٩.عزاه السيوطي إلى أبي الشيخ.أخرجه ابن جرير ١٣/١٢٣.أخرجه ابن جرير ١٣/١٢٣. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم، وأبي الشيخ. وهو عند ابن أبي حاتم ٧/٢١٣٢ من طريق الضحاك بلفظ: وهَيَّأت لهن متكأ. وفي تفسير الثعلبي ٥/٢١٧ بلفظ: مجلسًا للطعام وما يَتَّكِئْنَ عليه مِن النمارق والوسائد.أخرجه ابن جرير ١٣/١٢٥، ١٣٤ بلفظ: أعطتهن أُتْرُجًَّا. وعزاه السيوطي إلى ابن مردويه.تفسير البغوي ٤/٢٣٧.أخرجه ابن جرير ١٣/١٢٣، ١٢٦. وعزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ١٣/١٢٦. وعلَّقه ابن أبي حاتم ٧/٢١٣٣.أخرجه ابن جرير ١٣/١٢٧. وعلَّقه ابن أبي حاتم ٧/٢١٣٣. وعزاه السيوطي إلى ابن أبي شيبة، وابن المنذر.ذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٢/٣٢٣-.عزاه السيوطي إلى أبي عبيد، وابن المنذر.أخرجه سفيان بن عيينة في تفسيره -كما في الفتح ٨/٣٥٨-. وعلَّقه البخاري ٤/١٧٢٧.قال في القاموس: الزُّماوَرْدُ -بالضمّ-: طعام من البيض واللحم، والعامة تقول: بَزْماوَرْد. (ورد).أخرجه ابن جرير ١٣/١٢٤ من طريق إبراهيم بن الزبرقان عن أبي رَوْق، وابن أبي حاتم ٧/٢١٣٣ من طريق معاوية بن حفص عن أبي رَوْق.أخرجه ابن أبي حاتم ٧/٢١٣٣.أخرجه ابن أبي حاتم ٧/٢١٣٣.أخرجه ابن جرير ١٣/١٢٨. وعزاه السيوطي إلى أبي الشيخ.أخرجه ابن جرير ١٣/١٢٨.أخرجه ابن جرير ١٣/١٢٣.أخرجه ابن جرير ١٣/١٢٦، وابن أبي حاتم ٧/٢١٣٣.علَّقه ابن أبي حاتم ٧/٢١٣٣.أخرجه ابن جرير ١٣/١٢٦، وابن أبي حاتم ٧/٢١٣٣ بلفظ: طعامًا وشرابًا وتكًا.أخرجه عبد الرزاق ١/٣٢٢ من طريق مَعْمَر، وابن جرير ١٣/١٢٨. وعلَّقه ابن أبي حاتم ٧/٢١٣٣.أخرجه ابن جرير ١٣/١٢٣، وابن أبي حاتم ٧/٢١٣٣.أخرجه ابن أبي حاتم ٧/٢١٣٢-٢١٣٣. وعزاه السيوطي إلى أبي الشيخ.أخرجه ابن جرير ١٣/١٢٧.تفسير مقاتل بن سليمان ٢/٣٣١.أخرجه ابن جرير ١٣/١٢٨.أخرجه ابن جرير ١٣/١٢٩، وابن أبي حاتم ٧/٢١٣٤ من طريق أصبغ. وعزاه السيوطي إلى أبي الشيخ.أخرجه ابن جرير ١٣/١٢٨.تفسير ابن أبي زمنين ٢/٣٢٣.أخرجه ابن جرير ١٣/١٣٢، ١٣٤ بنحوه، وابن أبي حاتم ٧/٢١٣٢، ٢١٣٤-٢١٣٦. وعزاه السيوطي إلى ابن المنذر، وأبي الشيخ.أخرجه ابن جرير ١٣/١٢٥، ١٣٤ بلفظ: الأترج. وعزاه السيوطي إلى ابن مردويه.تفسير مجاهد ص٣٩٥.أخرجه ابن جرير ١٣/١٢٩، وابن أبي حاتم ٧/٢١٣٤.تفسير مقاتل بن سليمان ٢/٣٣١.أخرجه ابن جرير ١٣/١٢٩.أخرجه ابن جرير ١٣/١٢٩، وابن أبي حاتم ٧/٢١٣٤ من طريق أصبغ. وعزاه السيوطي إلى أبي الشيخ.أخرجه ابن جرير ١٣/١٣٢، ١٣٤، وابن أبي حاتم ٧/٢١٣٢، ٢١٣٤-٢١٣٦. وعزاه السيوطي إلى ابن المنذر، وأبي الشيخ.أخرجه ابن جرير ١٣/١٣٢، وابن أبي حاتم ٧/٢١٣٤-٢١٣٥. وعزاه السيوطي إلى ابن المنذر.تفسير الثعلبي ٥/٢١٨، وتفسير البغوي ٤/٢٣٨.أخرجه ابن جرير ١٣/١٣٠-١٣١، وابن أبي حاتم ٧/٢١٣٦. وعزاه السيوطي إلى ابن أبي شيبة، وابن المنذر، وأبي الشيخ.أخرجه ابن جرير ١٣/١٣١.أخرجه ابن جرير ١٣/١٣١ مختصرًا بلفظ: عَظَّمْنه، مِن طريق أسباط، وبلفظ: أعظمنه، مِن طريق علي بن عابس، وابن أبي حاتم ٧/٢١٣٥.عزاه السيوطي إلى أبي الشيخ.تفسير مقاتل بن سليمان ٢/٣٣٢.أخرجه ابن جرير ١٣/١٣٤، وابن أبي حاتم ٧/٢١٣٥ مختصرًا.أخرجه ابن جرير ١٣/١٣١ بلفظ: أعظمنه وبُهِتْنَ، وابن أبي حاتم ٧/٢١٣٥ من طريق أصبغ بلفظ: أعظمنه وبُهِتْنَ. وعزاه السيوطي إلى أبي الشيخ.أخرجه ابن أبي حاتم ٧/٢١٣٤-٢١٣٥.أخرجه ابن جرير ١٣/١٣٤. وعزاه السيوطي إلى ابن مردويه.أخرجه ابن جرير ١٣/١٣٥، وابن أبي حاتم ٧/٢١٣٦. وعزاه السيوطي إلى ابن أبي شيبة، وابن المنذر، وأبي الشيخ.أخرجه عبد الرزاق ١/ ٣٢٢، وابن جرير ١٣/١٣٥.تفسير الثعلبي ٥/٢١٨، وتفسير البغوي ٤/٢٣٨.تفسير الثعلبي ٥/٢١٨. وفي تفسير البغوي ٤/٢٣٨: ماتت جماعة منهن.عزاه السيوطي إلى أبي الشيخ.أخرجه ابن جرير ١٣/١٣٤.أخرجه عبد الرزاق في تفسيره ١/٣٢٢، وابن جرير ١٣/١٣٥.أخرجه ابن جرير ١٣/١٣٣، وابن أبي حاتم ٧/٢١٣٧.أخرجه ابن جرير ١٣/١٣٣.أخرجه ابن أبي حاتم ٧/٢١٣٧.تفسير مقاتل بن سليمان ٢/٣٣٢.أخرجه ابن جرير ١٣/١٣٤.أخرجه ابن جرير ١٣/١٣٤ بلفظ: الترنج. وعزاه السيوطي إلى أبي الشيخ، وابن أبي حاتم.أخرجه ابن أبي حاتم ٧/٢١٣٥.أخرجه ابن أبي داود في المصاحف ص٣٨. وعزاه السيوطي إلى الخطيب في تالي التلخيص.</p><p>وهي قراءة العشرة ما عدا أبا عمرو، فإنه قرأ: ‹حاشا› بألف بعد الشين. انظر: النشر ٢/٢٩٥، والإتحاف ص٣٣١.أخرجه ابن جرير ١٣/١٣٩، وابن أبي حاتم ٧/٢١٣٦. وعزاه السيوطي إلى ابن أبي شيبة، وابن المنذر، وأبي الشيخ.أخرجه ابن جرير ١٣/١٣٩.تفسير مقاتل بن سليمان ٢/٣٣٢.أخرجه ابن جرير ١٣/١٤٠.</p><p>وهي قراءة شاذة، تروى أيضًا عن ابن مسعود. انظر: مختصر ابن خالويه ص٦٨، والمحتسب ١/٣٤٢.أخرجه عبد الرزاق ١/٣٢٢-٣٢٣، وابن جرير ١٣/١٤١، وابن أبي حاتم ٧/٢١٣٧. وعزاه السيوطي إلى ابن المنذر، وأبي الشيخ.تفسير مقاتل بن سليمان ٢/٣٣٢.أخرجه ابن جرير ١٣/١٤٠، وابن أبي حاتم ٧/٢١٣٧ من طريق أصبغ وفي آخره: فأقَرَّت لَهُنَّ. وعزاه السيوطي إلى أبي الشيخ.أخرجه أحمد ٢١/٤٤١ (١٤٠٥٠)، والحاكم ٢/٦٢٢ (٤٠٨٢)، وابن جرير ١٣/١٣٦، وابن أبي حاتم ٧/٢١٣٦ (١١٥٥٩). وأصله في مسلم ١/١٤٥-١٤٦ (١٦٢) مطولًا.</p><p>قال الحاكم: «هذا حديث صحيح على شرط مسلم ولم يخرجاه». ووافقه الذهبي في التلخيص.</p><p>وقال ابن عدي في الكامل ٧/١٠٥ (١٥٥٠) في ترجمة: عفان بن مسلم أبو عثمان الصغار: «وهذا الحديث ما أعلم رفعه أحد غير عفان وغيره أوقفه عن حماد بن سلمة، وعفان أشهر وأوثق وأصدق وأوثق من أن يقال فيه شيء مما ينسب إلى الضعف». وقال ابن القيسراني في ذخيرة الحفاظ ١/٤٢١ (٥٥٨): «رواه عفان بن مسلم الصفار: عن حماد بن سلمة، عن ثابت، عن أنس. وهذا لا أعلم رفعه غير عفان، وغيره وقفه على حماد بن سلمة، وعفان ثقة ربما وهم، وهذا لا ينقصه». وقال الهيثمي في المجمع ٨/٢٠٣ (١٣٧٧٥): «رواه أبو يعلى ورجاله رجال الصحيح». وقال الألباني في الصحيحة ٣/٤٧٠ (١٤٨١): «وهذا سند صحيح على شرط مسلم».أخرجه ابن جرير ١٣/١٣٦.أخرجه الحاكم ٢/٦٢٣ (٤٠٨٧) بنحوه، ومحمد بن عبد الواحد الدقاق في معجمه ص٢٨٧ (١٥). وأورده الثعلبي ٥/٢١٨، والبغوي في تفسيره ٤/٢٣٧.</p><p>وأخرجه ابن عدي في الكامل ٧/٢٦٨. وقال ابن القيسراني في ذخيرة الحفاظ ٤/١٩٧٧-١٩٧٨ (٤٥٤٧): «رواه إبراهيم بن سعد، عن محمد بن إسحاق، فقال: عمَّن لا أتهمه، عن أبي سعيد الخدري. فذكر حديث المعراج، فأفسد إبراهيم إسناده».أخرجه ابن جرير ١٣/١٣٥، وابن أبي حاتم ٧/٢١٣٦، والطبراني (٨٥٥٥-٨٥٥٧). وعزاه السيوطي إلى ابن سعد، وابن المنذر، وأبي الشيخ.أخرجه الحكيم الترمذي في نوادر الأصول ١/٢٧٩، وابن أبي حاتم ٧/٢١٣٦ مختصرًا، والطبراني (٨٥٥٧). وعزاه السيوطي إلى ابن المنذر، وأبي الشيخ.أخرجه ابن أبي حاتم ٧/٢١٣٦ مختصرًا، والطبراني (٨٥٥٧). وعزاه السيوطي إلى ابن المنذر.أخرجه ابن عساكر ٦٩/١٨١.أخرجه الحاكم ٢/٥٧٢-٥٧٣، وهذا اللفظ عند الذهبي في مختصر المستدرك، ولفظ الحاكم أطول منه.أخرجه ابن جرير ١٣/١٣٦-١٣٧، وابن أبي حاتم ٧/٢١٣٦. وعزاه السيوطي إلى ابن المنذر.عزاه السيوطي إلى عبد بن حميد، وابن المنذر، وأبي الشيخ.أخرجه ابن جرير ١٣/١٣٧ بنحوه من طريق عيسى بن يونس، وابن أبي حاتم ٧/٢١٣٦. وعزاه السيوطي إلى ابن المنذر.عزاه السيوطي إلى أبي الشيخ.تفسير مقاتل بن سليمان ٢/٣٣١.تفسير البغوي ٤/٢٢٤.
  12,32,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿قَالَتۡ فَذَ ٰ⁠لِكُنَّ ٱلَّذِی لُمۡتُنَّنِی فِیهِۖ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٧٢٩٣<span class="dash">-</span></span> عن <span class="name-2">زيد بن أسلم</span> -من طريق يحيى بن العلاء- قال: ... فلمّا ولّى عنهُنَّ قالت: هذا الذي لُمْتُنَّنِي فيه، فلقد رأيتُكُنَّ تُقَطِّعْنَ أيديَكُنَّ وما تَشْعُرْنَ. قال: فنظَرْنَ إلى أيديهن، فجعلن يصِحْن ويبكين. قالت: فكيف أصنع أنا؟! فقلن: <span class="qpc-hafs">﴿حاش لله ما هذا بشرًا إن هذا إلا ملك كريم﴾</span>، وما نرى عليك مِن لوم بعد الذي رأينا{1}. (٨/٢٤٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٢٩٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: قالتْ زليخا: <span class="qpc-hafs">﴿فذلكن الذي لمتنني فيه﴾</span> الذي افْتُتِنتُنَّ به{2}<span class=comment-ref>٣٣٥٧</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٣٣٥٧</span> <span class="comment-type-4">ذكر</span> <u>ابنُ عطية</u> (٥/٨٢) أنّ الضمير في <span class="qpc-hafs">﴿فيه﴾</span> يحتمل احتمالين: <b>الأول</b>: أن يكون عائدًا على يوسف. <b>الثاني</b>: أن تكون الإشارة إلى حُبِّ يوسف، والضمير عائد على الحُبِّ. و<span class="comment-type-4">علَّق</span> عليه بقوله: «فيكون ذلك إشارةً إلى غائب على بابه».</div></p><p><h3><span class="qpc-hafs">﴿وَلَقَدۡ رَ ٰ⁠وَدتُّهُۥ عَن نَّفۡسِهِۦ فَٱسۡتَعۡصَمَۖ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٧٢٩٥<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- في قوله: <span class="qpc-hafs">﴿فاستعصم﴾</span>، قال: امْتَنَع{3}. (٨/٢٤٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٢٩٦<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿فاستعصم﴾</span>، قال: فاسْتَعْصى{4}. (٨/٢٤٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٢٩٧<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- قال: قالت: <span class="qpc-hafs">﴿ولقد راودته عن نفسه فاستعصم﴾</span>: بعد ما حَلَّ سراويلَه استعصى، لا أدري ما بَدا لَهُ{5}. (٨/١٩١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٢٩٨<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ولقد راودته عن نفسه فاستعصم﴾</span>، يعني: فامتنع عن الجِماع{2}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَلَىِٕن لَّمۡ یَفۡعَلۡ مَاۤ ءَامُرُهُۥ لَیُسۡجَنَنَّ وَلَیَكُونࣰا مِّنَ ٱلصَّـٰغِرِینَ ۝٣٢﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٧٢٩٩<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span> -من طريق عطاء بن دينار- في قول الله: <span class="qpc-hafs">﴿الصاغرين﴾</span>، يعني: المُذَلِّين{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٣٠٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ولئن لم يفعل ما آمره ليسجنن وليكونا من الصاغرين﴾</span>، يعني: المُذَلِّين{2}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن أبي حاتم ٧/٢١٣٧.تفسير مقاتل بن سليمان ٢/٣٣٢.أخرجه ابن جرير ١٣/١٤٢، وابن أبي حاتم ٧/٢١٣٧. وعزاه السيوطي إلى ابن المنذر، وأبي الشيخ.أخرجه ابن جرير ١٣/١٤٢. وعزاه السيوطي إلى أبي الشيخ.أخرجه ابن جرير ١٣/١٤٢، وابن أبي حاتم ٧/٢١٣٨.تفسير مقاتل بن سليمان ٢/٣٣٢.أخرجه ابن أبي حاتم ٧/٢١٣٨.تفسير مقاتل بن سليمان ٢/٣٣٢.
  12,33,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿قَالَ رَبِّ ٱلسِّجۡنُ أَحَبُّ إِلَیَّ مِمَّا یَدۡعُونَنِیۤ إِلَیۡهِۖ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٧٣٠١<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- قال: قال يوسف: <span class="qpc-hafs">﴿رب السجن أحب إلى مما يدعوننى إليه﴾</span>، يقول: الحبس أحبُّ إلَيَّ مِمّا يدعوننى إليه مِن الزِّنا{1}. (٨/١٩١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٣٠٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: قالت النسوة: يا يوسف، ما يمنعك أن تقضي لها حاجتَها. فدعا يوسفُ ربَّه: <span class="qpc-hafs">﴿قال رب السجن أحب إلي مما يدعونني إليه﴾</span> مِن الزِّنا. حين قُلْنَ ليوسف: ما يَحْمِلُك على ألّا تقضي لها حاجتَها{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٣٠٣<span class="dash">-</span></span> عن <span class="name-3">محمد بن إسحاق</span> -من طريق سلمة- قال: قال يوسف -وأضاف إلى ربِّه، واستعانَه على ما نَزَل به-: <span class="qpc-hafs">﴿رب السجن أحب إلى مما يدعونني إليه﴾</span>، أي: السِّجْنُ أحَبُّ إلَيَّ مِن أن آتي ما تكره{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٣٠٤<span class="dash">-</span></span> عن <span class="name-3">سفيان بن عيينة</span> -من طريق سُنَيد- قال: إنّما يُوَفَّق مِن الدُّعاء لِلْمُقَدَّر، أما ترى يوسف قال: <span class="qpc-hafs">﴿رب السجن أحب إلىَّ﴾</span>؟ قال: فلمّا قال: <span class="qpc-hafs">﴿اذكرني عند ربك﴾</span>. أتاه جبريلُ، فكشف لَهُ عن الصخرة، فقال: ما ترى؟ قال: أرى نملةً تَقْضِم. قال: يقول ربك: أنا لم أنسَ هذه، أنساك؟! أنا حبستُك! أنت قلت: <span class="qpc-hafs">﴿رب السجن أحب إلي﴾</span>{4}. (٨/٢٤٦)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَإِلَّا تَصۡرِفۡ عَنِّی كَیۡدَهُنَّ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٧٣٠٥<span class="dash">-</span></span> قال <span class="name-2">الحسن البصري</span>، <span class="qpc-hafs">﴿وإلا تصرف عني كيدهن﴾</span>: قد كان مِن النِّسْوَة عَوْنٌ لَها عليه{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٣٠٦<span class="dash">-</span></span> عن <span class="name-3">محمد بن إسحاق</span> -من طريق سلمة-: <span class="qpc-hafs">﴿وإلا تصرف عني كيدهن﴾</span> أي: ما أتَخَوَّفُ منهن <span class="qpc-hafs">﴿أصب إليهن﴾</span>{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٣٠٧<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿وإلّا تَصْرِفْ عنى كَيدَهُنَّ﴾</span>، قال: إلّا يكن منك أنتَ القُوى والمَنَعَةُ؛ لا تكُن مِنِّي ولا عندي{7}. (٨/٢٤٦)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿أَصۡبُ إِلَیۡهِنَّ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٧٣٠٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، <span class="qpc-hafs">﴿أصب إليهن﴾</span>، قال: أُطاوِعهُنَّ{8}. (٨/٢٤٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٣٠٩<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿أصبُ إليهنَّ﴾</span>، يقول: اتَّبِعْهُنَّ{9}. (٨/٢٤٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٣١٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وإلا تصرف عني كيدهن أصب إليهن﴾</span>، يقول: أُفْضِي إليهِنَّ{2}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَأَكُن مِّنَ ٱلۡجَـٰهِلِینَ ۝٣٣﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٧٣١١<span class="dash">-</span></span> عن <span class="name-2">عمرو بن مُرَّة</span>، قال: مَن أتى ذنبًا عمدًا أو خَطَأً فهو جاهلٌ حين يأتيه، ألا ترى إلى قول يوسف: <span class="qpc-hafs">﴿أصب إليهن وأكن من الجاهلين﴾</span>؟! قال: فقد عرَف يوسفُ أنّ الزِّنا حرام، وإن أتاه كان جاهلًا{8}. (٨/٢٤٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٣١٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وأكن من الجاهلين﴾</span>، يعني: مِن المُذْنِبين{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٣١٣<span class="dash">-</span></span> عن <span class="name-3">محمد بن إسحاق</span> -من طريق سلمة- <span class="qpc-hafs">﴿وأكن من الجاهلين﴾</span>، أي: جاهِلًا إذا رَكِبْتُ معصيتَك{13}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ١٣/١٤٤، وابن أبي حاتم ٧/٢١٣٨.تفسير مقاتل بن سليمان ٢/٣٣٢.أخرجه ابن جرير ١٣/١٤٤، وابن أبي حاتم ٧/٢١٣٨.أخرجه ابن أبي حاتم ٧/٢١٣٨. وعزاه السيوطي إلى سُنَيد في تفسيره.ذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٢/٣٢٤-.أخرجه ابن جرير ١٣/١٤٥، وابن أبي حاتم ٧/٢١٣٨.أخرجه ابن جرير ١٣/١٤٥ بلفظ: العون والمنعة، وابن أبي حاتم ٧/٢١٣٨. وعزاه السيوطي إلى أبي الشيخ.عزاه السيوطي إلى أبي الشيخ.أخرجه ابن جرير ١٣/١٤٥ بلفظ: أُتابِعهن، وابن أبي حاتم ٧/٢١٣٨. وعزاه السيوطي إلى أبي الشيخ.تفسير مقاتل بن سليمان ٢/٣٣٢.عزاه السيوطي إلى أبي الشيخ.تفسير مقاتل بن سليمان ٢/٣٣٢.أخرجه ابن جرير ١٣/١٤٥، وابن أبي حاتم ٧/٢١٣٩.
  12,34,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿فَٱسۡتَجَابَ لَهُۥ رَبُّهُۥ فَصَرَفَ عَنۡهُ كَیۡدَهُنَّۚ إِنَّهُۥ هُوَ ٱلسَّمِیعُ ٱلۡعَلِیمُ ۝٣٤﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٧٣١٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فاستجاب له ربه فصرف عنه كيدهن﴾</span> يعني: مكرَهُنَّ وشَرَّهُنَّ، <span class="qpc-hafs">﴿إنه هو السميع﴾</span> لدعاء يوسف، <span class="qpc-hafs">﴿العليم﴾</span> به{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٣١٥<span class="dash">-</span></span> عن <span class="name-3">محمد بن إسحاق</span> -من طريق سلمة- <span class="qpc-hafs">﴿فاستجاب له ربه فصرف عنه كيدهن إنه هو السميع العليم﴾</span>، أي: نَجّاه مِن أن يركب المعصية فيهِنَّ، وقد نزل به بعضُ ما حَذِر منهُنَّ{2}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٢/٣٣٢.أخرجه ابن جرير ١٣/١٤٦، وابن أبي حاتم ٧/٢١٣٩.
  12,35,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿ثُمَّ بَدَا لَهُم مِّنۢ بَعۡدِ مَا رَأَوُا۟ ٱلۡـَٔایَـٰتِ لَیَسۡجُنُنَّهُۥ حَتَّىٰ حِینࣲ ۝٣٥﴾</span> - قراءات</h3></p><p><div></p><p><p><span class="item-no">٣٧٣١٦<span class="dash">-</span></span> عن عبد الرحمن بن كعب بن مالك، عن أبيه، قال: سمِع عمرُ رجلًا يقرأ هذا الحرف: (لَيَسْجُنُنَّهُ عَتّى حِينٍ). فقال له عمر: مَن أقرأك هذا؟ قال: <span class="name-1">ابن مسعود</span>.= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٣١٧<span class="dash">-</span></span> فقال <span class="name-1">عمر</span>: <span class="qpc-hafs">﴿لَيَسْجُنُنَّهُ حَتّى حِينٍ﴾</span>. ثم كتب إلى ابن مسعود: سلامٌ عليك، أمّا بعد، فإنّ الله أنزل القرآن فجعله قرآنًا عربيًّا مبينًا، وأنزله بلغة هذا الحيِّ مِن قريش، فإذا أتاك كتابي هذا فأقرِئِ الناسَ بلغة قريش، ولا تُقرِئْهم بلغة هُذَيلٍ{1}. (٨/٢٤٩)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿ثُمَّ بَدَا لَهُم مِّنۢ بَعۡدِ مَا رَأَوُا۟ ٱلۡـَٔایَـٰتِ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٧٣١٨<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿ثم بدا لهم من بعد ما رأوا الآيات﴾</span>، قال: قَدّ القميصِ مِن دُبُر{2}. (٨/٢٤٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٣١٩<span class="dash">-</span></span> عن عكرمة، قال: سألتُ <span class="name-1">ابن عباس</span> عن قوله: <span class="qpc-hafs">﴿ثم بدا لهم من بعد ما رأوا الآيات﴾</span>. قال: ما سألني عنها أحدٌ قبلك، من الآيات: قدُّ القميص، وأثرُها في جسده، وأَثَرُ السكين. وقالت امرأة العزيز: إن أنت لم تَسْجُنه لَيُصَدِّقَنَّه الناسُ{3}. (٨/٢٤٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٣٢٠<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span> -من طريق نضر- قال: مِن الآيات: شقٌّ في القميص، وخَمْشٌ في الوَجْه{4}. (٨/٢٤٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٣٢١<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span>، قال: قال رجلٌ ذو رأي منهم للعزيز: إنّك متى تركت هذا العبدَ يعتذرُ إلى الناس ويقصُّ عليهم أمْرَه، وامرأةٌ في بيتها لا تخرج إلى الناس، عذَروه وفضَحوا أهلك. فأمَر به فسُجِن{5}. (٨/٢٤٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٣٢٢<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق مَعْمَر- قال: الآيات: حَزُّهن أيديَهن، وقدُّ القميصِ{6}. (٨/٢٤٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٣٢٣<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- قال: <span class="qpc-hafs">﴿ثم بدا لهم من بعد ما رأوا الآيات﴾</span>، وهو شقُّ القميص، وقطع الأيدي <span class="qpc-hafs">﴿ليسجننه حتى حين﴾</span>{7}. (٨/١٩١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٣٢٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ثم بدا لهم﴾</span> يعني: ثم بدا للزوج <span class="qpc-hafs">﴿من بعد ما رأوا الآيات﴾</span> يعني: مِن بعد ما رأوا العلاماتِ في تمزيق القميص مِن دُبُرٍ أنّه بريء <span class="qpc-hafs">﴿ليسجننه حتى حين﴾</span>{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٣٢٥<span class="dash">-</span></span> عن <span class="name-3">محمد بن إسحاق</span> -من طريق سلمة-: <span class="qpc-hafs">﴿ثم بدا لهم من بعد ما رأوا الآيات﴾</span> ببراءته مِمّا اتُّهِم به مِن شَقِّ قميصه مِن دُبُرٍ <span class="qpc-hafs">﴿ليسجننه حتى حين﴾</span>{9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٣٢٦<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿من بعد ما رأوا الآيات﴾</span>، قال: مِن الآيات كلامُ الصَّبِيِّ{5}<span class=comment-ref>٣٣٥٨</span>. (٨/٢٤٨)</p></p><p></div></p><p><div><span class=comment-ref>٣٣٥٨</span> ساق <u>ابنُ عطية</u> (٥/٨٥) ما أورده المفسرون في الآيات، ثم <span class="comment-type-4">علَّق</span> بقوله: «ومقصد الكلام إنما هو: أنّهم رأوا سجنَه بعد بُدُوِّ الآيات المُبَرِّئَةِ له مِن التُّهمة، فهكذا يبين ظلمهم له. وخمش الوجهِ، وحزُّ النساء أيديهن؛ ليس فيهما تبرية ليوسف، ولا تتصور تبرية إلا في خبر القميص، فإن كان المتكلم طفلًا -على ما رُوِي- فهي آية عظيمة، وإن كان رجلًا فهي آية فيها استدلال ما. والعادة أنه لا يُعَبَّر بآيةٍ إلا فيما ظهوره في غاية الوضوح، وقد تقع الآيات أيضًا على المبينات كانت في أي حد اتَّفق من الوضوح». ثم أورد <b>احتمالًا آخر</b>، فقال: «ويحتمل أن يكون معنى قوله: <span class="qpc-hafs">﴿من بعد ما رأوا الآيات﴾</span> أي: مِن بعد ما ظهر لهم مِن وجوه الأمر وقرائنه أنّ يوسف بريء، فلم يرد تعيين آية، بل قرائن جميع القصة».</div></p><p><h3><span class="qpc-hafs">﴿لَیَسۡجُنُنَّهُۥ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٧٣٢٧<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- قال: ثم إنّ المرأةَ قالت لزوجها: إنّ هذا العبدَ العبراني قد فضحني في الناس؛ إنّه يعتذر إليهم، ويُخبِرُهم أنِّي راودتُه عن نفسه، ولست أُطيق أن أعتذر بعذري، فإمّا أن تأذن لي فأخرج فأعتذر كما يعتذر، وإمّا أن تحبسه كما حبستني. فذلك قوله: <span class="qpc-hafs">﴿ثم بدا لهم من بعد ما رأوا الآيات ليسجننه حتى حين﴾</span>{11}. (٨/١٩١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٣٢٨<span class="dash">-</span></span> قال <span class="name-3">محمد بن السائب الكلبي</span>، في قوله: <span class="qpc-hafs">﴿ليسجننه حتى حين﴾</span>: بلغنا: أنّها قالت لزوجها: صَدَّقْتَه وكذَّبْتَنِي، وفضحتني في المدينة، فأنا غير ساعيةٍ فِي رِضاك إن لم تسجن يوسف، وتُسَمِّع به، وتعذرني. فأمر بيوسف يُحْمل على حمار، ثم ضرب بالطَّبل: هذا يوسف العبراني، أراد سيِّدتَه على نفسِها. فطُوِّف به أسواق مصر كلها، ثم أدخل السجن{12}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٣٢٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ليسجننه حتى حين﴾</span>، وذلك أنّها قالت لزوجها حين لم يُطاوِعها يوسف: احبِس يوسفَ في السجن لا يَلِجْ عَلَيَّ. فصَدَّقها، فحَبَسَتْهُ{8}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿حَتَّىٰ حِینࣲ ۝٣٥﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٧٣٣٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق أبي ظبيان- قال: الحين قد يكون غُدْوَةً وعَشِيَّةً{14}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٣٣١<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span> -من طريق طارق-= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٣٣٢<span class="dash">-</span></span> و<span class="name-2">عكرمة مولى ابن عباس</span> -من طريق ابن الأصبهاني- قالا: الحين: سِتَّةُ أشهر{15}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٣٣٣<span class="dash">-</span></span> عن يزيد النحوي، قال: وسألتُه -يعني: <span class="name-2">عكرمة مولى ابن عباس</span>- عن رجلٍ نذر لَيَسْجُنَنَّ غلامه حينًا، فإن لم يسجنه حينًا فهو عتيق؟ فقال عكرمة: إنّ من الأحيان حينًا يُدْرَك، وحينًا لا يُدْرَك؛ فأمّا الحينُ الذي لا يُدْرك قال الله تعالى: <span class="qpc-hafs">﴿ليسجننه حتى حين﴾</span>{16}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٣٣٤<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span> -من طريق أبي مكين-: أنّه نذر [رجلٌ] أن يقطع يد غلامه، أو يحبسه حينًا. قال: فسألني عمر بن عبد العزيز. فقلتُ: لا تقطع يده، ويحبسه سنةً، والحين سنة. ثم قرأ: <span class="qpc-hafs">﴿ليسجننه حتى حين﴾</span>. وقرأ: <span class="qpc-hafs">﴿تؤتي أكلها كل حين بإذن ربها﴾</span> [إبراهيم:٢٥]{17}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٣٣٥<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span> -من طريق داود- في قوله: <span class="qpc-hafs">﴿لَيَسْجُنُنَّهُ حتى حين﴾</span>، قال: سبع سنين{18}. (٨/٢٤٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٣٣٦<span class="dash">-</span></span> قال <span class="name-2">عطاء</span>: إلى أن تنقطِع مقالةُ الناس{19}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٣٣٧<span class="dash">-</span></span> عن <span class="name-2">محمد بن علي بن الحسين [أبي جعفر الباقر]</span> -من طريق عن محمد بن عبد الله الأنصاري-: أنّه سُئِل في رجلٍ حَلَف على امرأته أن لا تفعل فِعلًا ما إلى حين. فقال: أيُّ الأحيانِ أردتَ؟ فإنّ الأحيان ثلاثة: قال الله ﷿: <span class="qpc-hafs">﴿تؤتي أكلها كل حين بإذن ربها﴾</span> [إبراهيم:٢٥]: كل ستة أشهر، وقوله تعالى: <span class="qpc-hafs">﴿ليسجننه حتى حين﴾</span>، فذلك ثلاثة عشر عامًا، وقوله تعالى: <span class="qpc-hafs">﴿ولتعلمن نبأه بعد حين﴾</span> [ص:٨٨]، فذلك إلى يوم القيامة{20}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٣٣٨<span class="dash">-</span></span> قال <span class="name-3">محمد بن السائب الكلبي</span>: خمس سنين{21}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٣٣٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وقال﴾</span> يوسف <span class="qpc-hafs">﴿لِلَّذي ظنَّ أنه ناج مِنهما﴾</span> مِن القتل، إضمار، وهو الساقي: <span class="qpc-hafs">﴿اذكرني عند ربك﴾</span> يعني: سيِّدك؛ فإنّه يسرني أن يخرجني من السجن. يقول الله: <span class="qpc-hafs">﴿فأنساه الشيطان ذكر ربه﴾</span> يعني: يوسف دعاء ربه، فلم يدع يوسف ربَّه الذي في السماء ليخرجه من السجن، واستغاث بعبدٍ مثلَه، يعني: الملك، فأقرَّه الله في السجن عقوبةً حين رجا أن يخرجه غيرُ الله ﷿، فذلك قوله: <span class="qpc-hafs">﴿فلبث في السجن بضع سنين﴾</span>، يعني: خمس سنين، حتى رأى الملكُ الرُّؤيا، وكان في السجن قبل ذلك سبعَ سنين، وعُوقِب ببضع سنين، يعني: خمس سنين، فكان في السجن اثنتا عشرة سنة، فذلك قوله: <span class="qpc-hafs">﴿ثم بدا لهم من بعد ما رأوا الآيات ليسجننه حتى حين﴾</span>{22}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٣٤٠<span class="dash">-</span></span> قال <span class="name-3">سفيان الثوري</span>، في قوله: <span class="qpc-hafs">﴿حتى حين﴾</span>: سبع سنين{23}<span class=comment-ref>٣٣٥٩</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٣٣٥٩</span> <span class="comment-type-4">ذكر</span> <u>ابنُ عطية</u> (٥/٨٥-٨٦) أنّ «الحين» <span class="mustanad">في كلام العرب</span> وفي هذه الآية: الوقت مِن الزمن غير محدود، يقع للقليل والكثير، وذلك بيّن موارده في القرآن. ثُمَّ <span class="comment-type-2">استدرك</span> على تحديد «الحين» بقوله: «وهذا بحسب ما كشف الغيب في سجن يوسف».</div></p></div>",footnotes:1:أخرجه الخطيب في تاريخه ٣/٤٠٦. وعزاه السيوطي إلى ابن الأنباري في كتاب الوقف والابتداء.</p><p>(عَتّى حِينٍ) بالعين قراءة شاذة، وقراءة الجمهور: <span class="qpc-hafs">﴿حتى حين﴾</span>. انظر: مختصر ابن خالويه ص٦٨، والمحتسب ١/٣٤٣.ذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٢/٣٢٥-، وأخرجه ابن جرير ١٣/١٤٨. وعزاه السيوطي إلى ابن المنذر.أخرجه ابن أبي حاتم ٧/٢١٣٩. وعزاه السيوطي إلى أبي الشيخ.أخرجه ابن جرير ١٣/١٤٨، وابن أبي حاتم ٧/٢١٣٩. وعزاه السيوطي إلى ابن أبي شيبة، وابن المنذر.عزاه السيوطي إلى أبي الشيخ.أخرجه ابن جرير ١٣/١٤٨.أخرجه ابن جرير ١٣/١٤٩، وابن أبي حاتم ٧/٢١٣٩.تفسير مقاتل بن سليمان ٢/٣٣٢.أخرجه ابن جرير ١٣/١٤٩، وابن أبي حاتم ٧/٢١٤٠.عزاه السيوطي إلى أبي الشيخ.أخرجه ابن جرير ١٣/١٥٠، وابن أبي حاتم ٧/٢١٣٩. وفي تفسير الثعلبي ٥/٢٢٠، وتفسير البغوي ٤/٢٣٩ نحوه، وزادا في آخره: وذكر أنّ الله تعالى جعل ذلك الحبس تطهيرًا ليوسف ﵇ من هَمِّه بالمرأة.ذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٢/٣٢٥-.تفسير مقاتل بن سليمان ٢/٣٣٢.أخرجه ابن أبي حاتم ٧/٢١٤١. وبنحو هذا اللفظ أخرج ابن جرير ١٣/٦٤٤ عن ابن عباس من طريق أبي ظبيان في تفسير قوله تعالى: <span class="qpc-hafs">﴿تُؤْتِي أُكُلَها كُلَّ حِينٍ بِإذْنِ رَبِّها﴾</span> [إبراهيم:٢٥]. وعزاه السيوطي إلى ابن أبي حاتم وغيره، وسيأتي.أخرجه ابن أبي حاتم ٧/٢١٤١.أخرجه ابن أبي حاتم ٧/٢١٤١. وسيأتي في تفسير قوله تعالى: <span class="qpc-hafs">﴿تُؤْتِي أُكُلَها كُلَّ حِينٍ بِإذْنِ رَبِّها﴾</span> [إبراهيم:٢٥] عند ابن جرير، وابن أبي حاتم من طريق أيوب عن عكرمة أنّ الحين الذي لا يدرك هو قوله تعالى: <span class="qpc-hafs">﴿ولتعلمنَّ نبأهُ بعدَ حين﴾</span> [ص:٨٨]، وفي رواية عند ابن جرير من طريق ابن غَسيل أنه قوله تعالى: <span class="qpc-hafs">﴿هل أتى على الانسان حينٌ من الدَّهر لم يكن شيئا مذكورًا﴾</span> [الإنسان:١].أخرجه ابن جرير ١٣/٦٤٨، وابن أبي حاتم ٧/٢١٤١ دون ذكر آية سورة إبراهيم، وما بين المعقوفين إضافة مهمة منه.أخرجه ابن جرير ١٣/١٥١، وابن أبي حاتم ٧/٢١٤١ من طريق عاصم. وعزاه السيوطي إلى ابن المنذر.تفسير البغوي ٤/٢٣٩.أخرجه ابن حزم في المحلى ٨/٥٨.تفسير الثعلبي ٥/٢٢٠، وتفسير البغوي ٤/٢٣٩.تفسير مقاتل بن سليمان ٢/٣٣٥-٣٣٦.تفسير سفيان الثوري ص١٤٢.
  12,36,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَدَخَلَ مَعَهُ ٱلسِّجۡنَ فَتَیَانِۖ قَالَ أَحَدُهُمَاۤ إِنِّیۤ أَرَىٰنِیۤ أَعۡصِرُ خَمۡرࣰاۖ وَقَالَ ٱلۡـَٔاخَرُ إِنِّیۤ أَرَىٰنِیۤ أَحۡمِلُ فَوۡقَ رَأۡسِی خُبۡزࣰا تَأۡكُلُ ٱلطَّیۡرُ مِنۡهُۖ نَبِّئۡنَا بِتَأۡوِیلِهِۦۤۖ إِنَّا نَرَىٰكَ مِنَ ٱلۡمُحۡسِنِینَ ۝٣٦﴾</span> - قراءات</h3></p><p><div></p><p><p><span class="item-no">٣٧٣٤١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن مسعود</span> -من طريق محمد بن الحنفية- أنّه قرأ: (إنِّي أرانِي أعْصِرُ عِنَبًا). وقال: واللهِ، لقد أخذتُها مِن رسول الله ﷺ هكذا{1}. (٨/٢٥١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٣٤٢<span class="dash">-</span></span> عن يحيى بن سلّام: قوله: <span class="qpc-hafs">﴿أحْمِلُ فَوْقَ رَأْسِي خُبْزًا﴾</span> في قراءة <span class="name-1">عبد الله بن مسعود</span>: (ثَرِيدًا)، أي: قصعة مِن ثريد{2}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَدَخَلَ مَعَهُ ٱلسِّجۡنَ فَتَیَانِۖ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٧٣٤٣<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق سعيد بن جبير- في قوله: <span class="qpc-hafs">﴿ودخل معه السجن فتيان﴾</span>، قال: أحدُهما: خازنُ الملك على طعامه، والآخَرُ: ساقيه على شرابه{3}. (٨/٢٤٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٣٤٤<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد-، مثله{4}. (٨/٢٤٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٣٤٥<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- قال: <span class="qpc-hafs">﴿ودخل معه السجن فتيان﴾</span>: غَضِبَ الملِكُ على خبّازِه؛ بلغه أنّه يريد أن يَسُمَّه، فحبسه، وحبس الساقيَ، وظنَّ أنّه مالأه على السم{5}. (٨/١٩١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٣٤٦<span class="dash">-</span></span> عن <span class="name-3">محمد بن إسحاق</span> -من طريق سلمة- قال في قوله: <span class="qpc-hafs">﴿ودخل معه السجن فتيان﴾</span>، قال: غلامان كانا للملِك الأكبر الريّانِ بن الوليد؛ كان أحدُهما على شرابه، والآخر على بعض أمره، في سخطةٍ سخِطَها عليهما، اسم أحدِهما: مجلثُ، والآخر: نبو، ونبو الذي كان على الشراب، فلمّا رأياه قالا: يا فتى، واللهِ، لقد أحببناك حين رأيناك{6}. (٨/٢٤٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٣٤٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: كان يوسف في السجن يُؤنِس الحزين، ويُطَمْئِنُ الخائف، ويقوم على المريض، ويُعَبِّر لهم الرؤيا. ورُقِي إلى الملكِ أنّ غلامَه الخباز يريد أن يجعل في طعامه سُمًّا، ورقى إليه في غلامه الساقي مثل ذلك، فذلك قوله: <span class="qpc-hafs">﴿ودخل معه السجن فتيان﴾</span> الخبّاز والساقي، اسم أحدهما: شرهم أقم، وهو الساقي، واسم الخباز: شرهم أشم{7}<span class=comment-ref>٣٣٦٠</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٣٣٦٠</span> <span class="comment-type-4">ذكر</span> <u>ابنُ عطية</u> (٥/٨٦) أنّ «مع» تحتمل احتمالين: <b>الأول</b>: أن تكون باقتران وقت الدخول. <b>الثاني</b>: أن لا تكون، بل دخلوا أفذاذًا.</p><p>و<span class="comment-type-4">بيَّن</span> أنّ لفظة «الفتى» تعني: الشاب، وأنّها قد تقع على المملوك، وعلى الخادم الحُرِّ، ثم قال: «ويحتمل أن يتَّصف هذان بجميع ذلك».</div></p><p><h3><span class="qpc-hafs">﴿قَالَ أَحَدُهُمَاۤ إِنِّیۤ أَرَىٰنِیۤ أَعۡصِرُ خَمۡرࣰاۖ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٧٣٤٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق ابن جريج- في قوله: <span class="qpc-hafs">﴿إني أراني أعْصِرُ خمرًا﴾</span>، قال: عِنَبًا{8}. (٨/٢٥١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٣٤٩<span class="dash">-</span></span> عن <span class="name-2">الضحاك بن مُزاحِم</span> -من طريق عبيد- في قوله: <span class="qpc-hafs">﴿إني أراني أعصر خمرًا﴾</span>، يقول: أعْصِر عِنَبًا، وهو بلغة أهل عمان، يسمُّون العِنَب: خمرًا{9}. (٨/٢٥١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٣٥٠<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span>، في قوله: <span class="qpc-hafs">﴿إني أراني أعصر خمرًا﴾</span>، قال: هو بلغة أهل عمان{10}. (٨/٢٥٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٣٥١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: قال أحدهما: <span class="qpc-hafs">﴿إنِّي أراني﴾</span> في المنام كأني <span class="qpc-hafs">﴿أعصر خمرا﴾</span> يعني: عِنَبًا. قال: كأنِّي دخلت البستانَ، فإذا فيه أصل كرم، وعليه ثلاث عناقيد، فكأنِّي أعصرهن، وأسقي المَلِك{7}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَقَالَ ٱلۡـَٔاخَرُ إِنِّیۤ أَرَىٰنِیۤ أَحۡمِلُ فَوۡقَ رَأۡسِی خُبۡزࣰا تَأۡكُلُ ٱلطَّیۡرُ مِنۡهُۖ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٧٣٥٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وقال الآخَر: إني أراني﴾</span> رأيتُ في المنام كأني <span class="qpc-hafs">﴿أحمل فوق رأسي خبزا﴾</span> ثلاثَ سِلال، وأعلاهن جَفْنَةٌ مِن خبز <span class="qpc-hafs">﴿فوق رأسي﴾</span> -مثل قوله: <span class="qpc-hafs">﴿فاضربوا فوق الأعناق﴾</span> [الأنفال:١٢]، ومثل قوله: <span class="qpc-hafs">﴿اجتثت من فوق الأرض﴾</span> [إبراهيم:٢٦] يعني: أعلى الأرض- <span class="qpc-hafs">﴿تأكل الطير منه﴾</span>{7}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿نَبِّئۡنَا بِتَأۡوِیلِهِۦۤۖ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٧٣٥٣<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح-: أنّ يوسف قال لهما حين قالا له ذلك: أنشُدُكما اللهَ ألّا تُحِبّاني، فواللهِ، ما أحَبَّني أحدٌ قطُّ إلا دخل عَلَيَّ مِن حُبِّه بلاءٌ؛ لقد أحَبَّتني عَمَّتي فدخل عَلَيَّ مِن حُبِّها بلاءٌ، ثم أحبني أبي فدخل عَلَيَّ بحبِّه بلاءٌ، ثم أحبَّتني زوجةُ صاحبي هذا فدخل عليَّ بحُبِّها إيّاي بلاءٌ، فلا تُحِبّاني، بارك الله فيكما. فأبيا إلا حُبَّه وإلْفَه حيث كان، وجعلا يعجبهما ما يريان مِن فهمه وعقله، وقد كانا رأيا حين أُدخلا السجن رؤيا؛ فرأى مجلث أنّه يحمل فوق رأسه خبزًا تأكل الطير منه، ورأى نبو أنه يعصِرُ خمرًا، فاسْتَفْتَياه فيهما، وقالا له: <span class="qpc-hafs">﴿نبئنا بتأويله إنا نراك من المحسنين﴾</span>{13}. (٨/٢٤٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٣٥٤<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- قال: فلمّا دخل يوسفُ السجنَ قال: إنِّي أُعَبِّر الأحلام. فقال أحد الفتيين لصاحبه: هَلُمَّ، فلْنُجَرِّب قولَ هذا العبد العبراني. فتراءيا مِن غير أن يكونا رأيا شيئًا، ولكنهما خرصا، فعبَّر لهما يوسفُ خَرْصَهُما، فقال الساقي: رأيتُني أعصر خمرًا. وقال الخباز: رأيتني أحمل فوق رأسي خبزًا تأكل الطير منه{14}. (٨/١٩٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٣٥٥<span class="dash">-</span></span> عن <span class="name-3">محمد بن إسحاق</span> -من طريق سلمة- قال: اسْتَفْتَياه في رؤياهما، وقالا له: <span class="qpc-hafs">﴿نبئنا بتأويله إنا نراك من المحسنين﴾</span>{15}<span class=comment-ref>٣٣٦١</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٣٣٦١</span> اختُلِف هل سأل الفَتيان يوسف عن رؤيا حقيقة؟ أم أرادا تجربته؟ <span class="comment-type-4">ذكر</span> <u>ابنُ كثير</u> (٨/٤١) أنّ المشهور عند الأكثرين هو القول الأول الذي قاله ابن إسحاق، ومجاهد.</div></p><p><h3><span class="qpc-hafs">﴿بِتَأۡوِیلِهِۦۤۖ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٧٣٥٦<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span>، <span class="qpc-hafs">﴿نبئنا بتأويله﴾</span>، قال: عِبارَته{16}. (٨/٢٥١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٣٥٧<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿نبئنا بتأويله﴾</span>، يعني: تأويل ما رأينا{17}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٣٥٨<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿نبئنا بتأويله﴾</span>، يقول: أخبِرنا بتفسير ما رأينا في المنام{7}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿إِنَّا نَرَىٰكَ مِنَ ٱلۡمُحۡسِنِینَ ۝٣٦﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٧٣٥٩<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح-: <span class="qpc-hafs">﴿نبئنا بتأويله إنا نراك من المحسنين﴾</span> إن فعلتَ ...{13}. (٨/٢٤٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٣٦٠<span class="dash">-</span></span> عن <span class="name-2">الضحاك بن مُزاحِم</span> -من طريق سلمة بن نبيط- أنّه سُئِل عن قوله: <span class="qpc-hafs">﴿إنا نراك من المحسنين﴾</span>: ما كان إحسان يوسف؟ قال: كان إذا مرِض إنسانٌ في السجن قام عليه، وإذا ضاق عليه المكانُ أوْسَع له، وإذا احتاجَ جَمَعَ له{20}. (٨/٢٥٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٣٦١<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق أبي بكر بن عبد الله- في قوله: <span class="qpc-hafs">﴿إنا نراك من المحسنين﴾</span>، قال: كان إحسانُه -فيما ذُكِر لنا- أنّه كان يُعزِّي حزينَهم، ويُداوي مريضَهم، ورأوا منه عبادًة واجتهادًا، فأحبُّوه. وقال: لَمّا انتهى يوسفُ إلى السجن وجد فيه قومًا قد انقَطَع رجاؤُهم، واشْتَدَّ بلاؤُهم، وطال حُزنُهم، فجعل يقول: أبشِروا، اصبِرُوا تُؤْجَروا، إنّ لِهذا أجرًا، إنّ لِهذا ثوابًا. فقالوا: يا فتى، بارك الله فيك، ما أحسن وجهكَ، وأحسن خَلْقَك، وأحسن خُلُقَك! لقد بُورك لنا في جِوارك، ما نُحِبُّ أنّا كُنّا في غير هذا منذ حُبِسنا؛ لِما تُخْبِرُنا مِن الأجر والكفّارة والطهارة، فمَن أنت، يا فتى؟ قال: أنا يوسف، ابن صَفِيِّ الله يعقوب، ابن ذبيح الله إسحاق، ابن خليل الله إبراهيم -عليهم الصلاة والسلام-. وكانت عليه مَحَبَّة، وقال له عامل السجن: يا فتى، واللهِ، لو استطعتُ لَخَلَّيْتُ سبيلَك، ولكن سأُحْسِن جِوارك، وأُحْسِنُ إسارَك، فكُن في أيِّ بيوت السِّجن شئت{21}. (٨/٢٥٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٣٦٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿إنا نراك من المحسنين﴾</span>، وكان إحسانُه في السجن أنّه كان يعودُ مرضاهم، ويُداويهم، ويُعَزِّي مكروبَهم، ورآه مُتَعَبِّدًا لربِّه، فهذا إحسانه{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٣٦٣<span class="dash">-</span></span> عن <span class="name-3">محمد بن إسحاق</span> -من طريق سلمة-: <span class="qpc-hafs">﴿نبئنا بتأويله إنا نراك من المحسنين﴾</span> إن فعلتَ{15}<span class=comment-ref>٣٣٦٢</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٣٣٦٢</span> اختُلِف في معنى الإحسان الذي وصف به الفَتيان يوسف على قولين: <b>الأول</b>: أنّه كان يعود مريضهم، ويعزي حزينهم. <b>الثاني</b>: أنّ المعنى: إذ نبأتنا بتأويل رؤيانا هذه تكون من المحسنين.</p><p>و<span class="comment-type-3">رجَّح</span> <u>ابنُ جرير</u> (١٣/١٥٨) <span class="mustanad">مستندًا إلى الدلالة العقلية</span> القولَ الأول الذي قاله الضحاك، وقتادة، ومقاتل، فقال: «وأَوْلى الأقوال في ذلك عندنا بالصواب القولُ الذي ذكرناه عن الضحاك وقتادة». ثم قال: «فإن قال قائل: وما وجه الكلام إن كان الأمر إذن كما قلت، وقد علمتَ أن مسألتهما يوسفُ أن ينبئهما بتأويل رؤياهما ليست مِن الخبر عن صفته بأنّه يعود المريض ويقوم عليه ويحسن إلى من احتاج في شيء، وإنما يقال للرجل: نبِّئنا بتأويل هذا فإنك عالم. وهذا مِن المواضع التي تَحسن بالوصف بالعلم لا بغيره؟ قيل: إنّ وجه ذلك أنهما قالا له: نبِّئنا بتأويل رؤيانا محسنًا إلينا في إخبارك إيّانا بذلك، كما نراك تحسن في سائر أفعالك، إنا نراك من المحسنين».</div></p><p><h3><span class="qpc-hafs">﴿إِنَّا نَرَىٰكَ مِنَ ٱلۡمُحۡسِنِینَ ۝٣٦﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٣٧٣٦٤<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، قال: دعا يوسفُ لأهل السجن، فقال: اللَّهُمَّ، لا تُعَمِّ عليهم الأخبار، وهوِّن عليهم مَرَّ الأيام{10}. (٨/٢٥٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٣٦٥<span class="dash">-</span></span> عن <span class="name-2">عمرو بن دينار</span>، قال: قال يوسف ﵇: ما لَقِيَ أحدٌ في الحُبِّ ما لَقِيتُ؛ أحَبَّني أبي فأُلْقِيتُ في الجُبِّ، وأحبَّتني امرأةُ العزيز فأُلْقِيتُ في السِّجن{25}. (٨/٢٥١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٣٦٦<span class="dash">-</span></span> عن <span class="name-3">مقاتل بن سليمان</span>: [أنّ يوسف ﵇ لَمّا سُجِن] قال له صاحِبُ السجن: مَن أنت؟ قال: ولِم تسألني: مَن أنا؟ قال: لأنِّي أُحِبُّك. قال: أعوذ بالله مِن حُبِّك، أحَبَّني والدي فلقيت من إخوتي ما لقيت، وأحبَّتني امرأةُ العزيز فلقيت مِن حبها ما لقيت، فلا حاجة لي في حُبِّ أحدٍ إلا في إلهي الذي في السماء. قال: أخبِرني مَن أنت؟ قال: أنا يوسف نبي الله، ابن يعقوب صفي الله، ابن إسحاق ذبيح الله، ابن إبراهيم خليل الله{26}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٣٦٧<span class="dash">-</span></span> عن عبد الصمد بن محمد العباداني، قال: سمعتُ أبي يقول: قال رجلٌ ليوسف: إنِّي أُحِبُّك. فقال له يوسف: لا أريد أن يُحِبَّني أحدٌ غير الله؛ مِن حُبِّ أبي أُلِقيتُ في الجُبِّ، ومِن حُبِّ امرأة العزيز أُلقِيتُ في السِّجن{27}. (٨/٢٣٦)</p></p><p></div></p></div>",footnotes:1:أخرجه البخاري في تاريخه ١/٢٧٤-٢٧٥ (٨٨٥) في ترجمة إبراهيم بن بشير الأنصاري، وابن جرير ١٣/١٥٤، وابن أبي حاتم ٧/٢١٤٢. وذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٢/٣٢٦-. جميعهم دون قوله: وقال: واللهِ، لقد أخذتها من رسول الله ﷺ هكذا.</p><p>وقال ابن حجر في الفتح ١٢/٣٨٢: «أخرجه بن أبي حاتم بسند حسن، وكأنه أراد التفسير».</p><p>وهي قراءة شاذة. انظر: المحتسب ١/٣٤٣.تفسير ابن أبي زمنين ٢/٣٢٦.</p><p>وهي قراءة شاذة.أخرجه ابن أبي حاتم ٧/٢١٤١.أخرجه ابن جرير ١٣/١٥٢ بلفظ: خباز الملك على طعامه، وابن أبي حاتم ٧/٢١٤١. وذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٢/٣٢٦- بلفظ: خباز الملك على طعامه.أخرجه ابن جرير ١٣/١٥٢، وابن أبي حاتم ٧/٢١٤٢-٢١٤٣.أخرجه ابن جرير ١٣/١٥١، ١٥٢، ١٥٣، وابن أبي حاتم ٧/٢١٤٢.تفسير مقاتل بن سليمان ٢/٣٣٣.أخرجه ابن جرير ١٣/١٥٥.أخرجه ابن جرير ١٣/١٥٥، وابن أبي حاتم ٧/٢١٤٢. وعزاه السيوطي إلى ابن المنذر.عزاه السيوطي إلى أبي الشيخ.تفسير مقاتل بن سليمان ٢/٣٣٣.تفسير مقاتل بن سليمان ٢/٣٣٣.أخرجه ابن جرير ١٣/١٥٤، وابن أبي حاتم ٧/٢١٤٢.أخرجه ابن جرير ١٣/١٥٣، وابن أبي حاتم ٧/٢١٤٣.أخرجه ابن جرير ١٣/١٥٨.أخرجه ابن جرير ١٣/١٥٦ من طريق ابن أبي نجيح بلفظ: به. وعزاه السيوطي إلى أبي الشيخ.تفسير مجاهد ص٣٩٦.تفسير مقاتل بن سليمان ٢/٣٣٣.أخرجه ابن جرير ١٣/١٥٤، وابن أبي حاتم ٧/٢١٤٢.أخرجه سعيد بن منصور (١١٢٤ - تفسير)، وابن جرير ١٣/١٥٦-١٥٧، وابن أبي حاتم ٧/٢١٤٣، والبيهقي في شعب الإيمان (٩٥٧٩). وعزاه السيوطي إلى ابن المنذر، وأبي الشيخ. وفي تفسير الثعلبي ٥/٢٤١، وتفسير البغوي ٤/٢٤١ نحوه، وزادا في آخره: وكان مع هذا يجتهد في العبادة، ويقوم الليل كله للصلاة.أخرجه ابن جرير ١٣/١٥٧-١٥٨، وابن أبي حاتم ٧/٢١٤٣. وذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٢/٣٢٦- مختصرًا. وعزاه السيوطي إلى أبي الشيخ.تفسير مقاتل بن سليمان ٢/٣٣٣.أخرجه ابن جرير ١٣/١٥٨.عزاه السيوطي إلى أبي الشيخ.عزاه السيوطي إلى وكيع في الغُرر.تفسير مقاتل بن سليمان ٢/٣٣٢.أخرجه ابن أبي حاتم ٧/٢١٣٢.
  12,37,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿قَالَ لَا یَأۡتِیكُمَا طَعَامࣱ تُرۡزَقَانِهِۦۤ إِلَّا نَبَّأۡتُكُمَا بِتَأۡوِیلِهِۦ قَبۡلَ أَن یَأۡتِیَكُمَاۚ ذَ ٰ⁠لِكُمَا مِمَّا عَلَّمَنِی رَبِّیۤۚ إِنِّی تَرَكۡتُ مِلَّةَ قَوۡمࣲ لَّا یُؤۡمِنُونَ بِٱللَّهِ وَهُم بِٱلۡـَٔاخِرَةِ هُمۡ كَـٰفِرُونَ ۝٣٧﴾</span> - قراءات</h3></p><p><div></p><p><p><span class="item-no">٣٧٣٦٨<span class="dash">-</span></span> عن أبي يوسف، قال: قال لي <span class="name-3">أبو حنيفة</span>: إنّهم يقرؤون حرفًا في يوسف يَلْحَنُون فيه؟ قلت: ما هو؟ قال: قوله: <span class="qpc-hafs">﴿لا يَأْتِيكُما طَعامٌ تُرْزَقانِهِ﴾</span> فقلت: فكيف هو؟ قال: (تُرْزَقانُهُ){1}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿قَالَ لَا یَأۡتِیكُمَا طَعَامࣱ تُرۡزَقَانِهِۦۤ إِلَّا نَبَّأۡتُكُمَا بِتَأۡوِیلِهِۦ قَبۡلَ أَن یَأۡتِیَكُمَاۚ ذَ ٰ⁠لِكُمَا مِمَّا عَلَّمَنِی رَبِّیۤۚ إِنِّی تَرَكۡتُ مِلَّةَ قَوۡمࣲ لَّا یُؤۡمِنُونَ بِٱللَّهِ وَهُم بِٱلۡـَٔاخِرَةِ هُمۡ كَـٰفِرُونَ ۝٣٧﴾</span> - تفسير الآية</h3></p><p><div></p><p><p><span class="item-no">٣٧٣٦٩<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح-: ... فقال لهما: <span class="qpc-hafs">﴿لا يأتيكما طعام ترزقانه﴾</span>. يقول: في نومكما <span class="qpc-hafs">﴿إلا نبأتكما بتأويله قبل أن يأتيكما﴾</span>{2}. (٨/٢٤٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٣٧٠<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- قال: <span class="qpc-hafs">﴿قال﴾</span> يوسف: <span class="qpc-hafs">﴿لا يأتيكما طعام تُرْزَقانِهِ﴾</span> في النوم <span class="qpc-hafs">﴿إلا نبأتكما بتأويله﴾</span> في اليَقَظَة{3}. (٨/١٩٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٣٧١<span class="dash">-</span></span> عن <span class="name-3">محمد بن إسحاق</span> -من طريق سلمة-، بنحوه{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٣٧٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: قال يوسف: ألا أُخْبِرُكما بأعجبَ مِن الرُّؤيا التي رأيتما، <span class="qpc-hafs">﴿قال لا يأتيكما طعام ترزقانه إلا نبأتكما بتأويله﴾</span>: إلا أخبرتكما بألوانه قبل أن يأتيكما الطعام. فقالوا ليوسف: إنّما يعلم هذا الكَهَنَةُ، والسَّحَرَةُ، وأنت لست في هيئة ذلك. فقال يوسف لهما: <span class="qpc-hafs">﴿ذلكما مما علمني ربي إني تركت ملة قوم﴾</span> أولئك الكهنة، والسحرة، يعني: أهل مصر <span class="qpc-hafs">﴿لا يؤمنون بالله﴾</span> يعني: لا يُصَدِّقون بتوحيد الله، ولا بالبعث الذي فيه جزاء الأعمال، <span class="qpc-hafs">﴿وهم بالآخرة هم كافرون﴾</span>{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٣٧٣<span class="dash">-</span></span> عن <span class="name-3">عبد الملك ابن جُرَيْج</span> -من طريق حجّاج- في قوله: <span class="qpc-hafs">﴿لا يأتيكما طعام ترزقانه﴾</span>، قال: كَرِه العبارةَ كُلَّها، فأجابهما بغير جوابهما؛ لِيُريَهما أنّ عنده عِلْمًا، وكان المَلِك إذا أراد قتل إنسان صنع له طعامًا معلومًا، فأرسل به إليه، فقال يوسف: <span class="qpc-hafs">﴿لا يأتيكما طعام ترزقانه﴾</span> إلى قوله: <span class="qpc-hafs">﴿يشكرون﴾</span>. فلم يَدَعْه صاحبُ الرؤيا حتى يَعبُر لهما، فكرِهَ العبارة، فقال: <span class="qpc-hafs">﴿يا صاحبى السجن ءأرباب﴾</span> إلى قوله: <span class="qpc-hafs">﴿ولكن أكثر الناس لا يعلمون﴾</span>. قال: فلم يدعاه، فعَبَّر لهما{6}<span class=comment-ref>٣٣٦٣</span>. (٨/٢٥٣)</p></p><p></div></p><p><div><span class=comment-ref>٣٣٦٣</span> اختُلِف هل كان الطعام الذي يأتيهما في اليقظة أم المنام؟ وأثَر ابن جريج مصرِّح بأنه في اليقظة، وهو ما <span class="comment-type-4">علَّق</span> عليه <u>ابنُ جرير</u> (١٣/١٦٢) بقوله: «وعلى هذا التأويل الذي تأوله ابن جريج فقوله: <span class="qpc-hafs">﴿لا يأتيكما طعام ترزقانه﴾</span> في اليقظة، لا في النوم. وإنّما أعلمهما على هذا القول أنّ عنده علم ما يَؤُول إليه أمرُ الطعام الذي يأتيهما مِن عند الملك ومِن عند غيره؛ لأنّه قد علم النوع الذي إذا أتاهما كان علامةً لقتل مَن أتاه ذلك منهما، والنوع الذي إذا أتاه كان علامةً لغير ذلك، فأخبرهما أنّه عنده علم ذلك».</p><p>و<span class="comment-type-4">علَّق</span> عليه <u>ابنُ عطية</u> (٥/٨٨بتصرف) بقوله: «فعلى هذا إنّما أعْلَمَهم بأنّه يعلم مُغَيَّبات لا تعلق لها برؤيا. وقصد بذلك أحد وجهين: <b>الأول</b>: تَنسِيَتَهما أمرَ تعبيرِ ما سألا عنه؛ إذ في ذلك النذارة بقتل أحدهما. <b>الثاني</b>: الطماعية في إيمانهما. ليأخذ المقتول بحظِّه من الإيمان، وتسلم له آخرته. ثم قال:»وهذا على ما رُوِي مِن أنّه نُبِّئ في السجن، فإخباره كإخبار عيسى ﵇".</p><p>و<span class="comment-type-2">انتقد</span> ما جاء مِن أنّ إرسال الملك للطعام يؤذن بقتل المرسَل إليه <span class="mustanad">مستندًا لدلالة اللفظ، وعدم الدليل النقليّ</span>، فقال: «وهذا كله لا يقتضيه اللفظ، ولا ينهض به إسناد».</p><p>و<span class="comment-type-2">انتقده</span> <u>ابنُ كثير</u> (٤/٣٩٠ دار طيبة) قولَ ابن جريج <span class="mustanad">مستندًا للسياق</span>، فقال: «وفي هذا الذي قاله نظر؛ لأنّه قد وعدهما أولًا بتعبيرها، ولكن جعل سؤالهما له على وجه التعظيم والاحترام وُصْلَةً وسببًا إلى دعائهما إلى التوحيد والإسلام، لما رأى في سجيتهما مِن قبول الخير، والإقبال عليه، والإنصات إليه، ولهذا لَمّا فرغ مِن دعوتهما شرع في تعبير رؤياهما، مِن غير تكرار سؤال».</div></p></div>",footnotes:1:أخرجه الخطيب في تاريخ بغداد ١٥/٤٥٦.</p><p><span class="qpc-hafs">﴿تُرْزَقانِهِ﴾</span> بكسر النون قراءة العشرة، وأما (تُرْزَقانُهُ) بضم النون فهي شاذة. انظر: شرح الرضي على الكافية ٣/٣٥٠.أخرجه ابن جرير ١٣/١٥٤، ١٦٤، ١٦٨، وابن أبي حاتم ٧/٢١٤٢-٢١٤٤، ٢١٤٦، ٢١٤٧.أخرجه ابن جرير ١٣/١٥٩، وابن أبي حاتم ٧/٢١٤٤.أخرجه ابن جرير ١٣/١٥٩.تفسير مقاتل بن سليمان ٢/٣٣٤.أخرجه ابن جرير ١٣/١٦١، وابن أبي حاتم ٧/٢١٤٧ من طريق هشام بن يوسف، قال: زعم محمد بن عباس. فذكر نحوه. وعزاه السيوطي إلى أبي عبيد، وابن المنذر.