tafsir[8]{c,v,t}:
31,12," <q>﴿وَلَقَدۡ ءَاتَیۡنَا لُقۡمَـٰنَ ٱلۡحِكۡمَةَ أَنِ ٱشۡكُرۡ لِلَّهِۚ وَمَن یَشۡكُرۡ فَإِنَّمَا یَشۡكُرُ لِنَفۡسِهِۦۖ وَمَن كَفَرَ فَإِنَّ ٱللَّهَ غَنِیٌّ حَمِیدࣱ ۝١٢﴾</q> - تفسير ٦٠٩٢١- عن عبد الله بن عباس، في قوله: <q>﴿ولَقَدْ آتَيْنا لُقْمانَ الحِكْمَةَ﴾</q>، قال: يعني: العقل، والفهم، والفِطنة، في غير نُبُوَّة{1}. (١١/٦٢٧) ٦٠٩٢٢- عن مجاهد بن جبر -من طريق يونس- في قوله: <q>﴿ولَقَدْ آتَيْنا لُقْمانَ الحِكْمَةَ﴾</q>، قال: الحكمة: الصواب{2}. (ز) ٦٠٩٢٣- عن مجاهد بن جبر -من طريق سفيان، عن رجل- <q>﴿ولَقَدْ آتَيْنا لُقْمانَ الحِكْمَةَ﴾</q>، قال: القرآن{3}. (ز) ٦٠٩٢٤- عن مجاهد بن جبر -من طريق ابن أبي نجيح- قال: الحكمة: الأمانة{4}. (ز) ٦٠٩٢٥- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿ولَقَدْ آتَيْنا لُقْمانَ الحِكْمَةَ﴾</q>، قال: العقل، والفقه، والإصابة في القول، في غير نبوة{5}. (١١/٦٢٨) ٦٠٩٢٦- عن مجاهد بن جبر -من طريق ابن جريج- في قوله: <q>﴿ولقد ءاتينا لقمان الحكمة﴾</q>، قال: الفقه، والعلم، والإصابة في غير نبوة. <q>﴿ومن يؤت الحكمة فقد أوتي خيرًا كثيرًا﴾</q> [البقرة:٢٦٩]، قال: الإصابة{6}. (ز) ٦٠٩٢٧- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿ولَقَدْ آتَيْنا لُقْمانَ الحِكْمَةَ﴾</q>، قال: الفقه في الإسلام، ولم يكن نبيًّا، ولم يُوحَ إليه{7}. (١١/٦٢٨) ٦٠٩٢٨- قال مقاتل بن سليمان: <q>﴿ولَقَدْ آتَيْنا لُقْمانَ الحِكْمَةَ﴾</q> أعطيناه العلم والفهم مِن غير نبوة، فهذه نعمة، فقلنا له: <q>﴿أنِ اشْكُرْ لِلَّهِ﴾</q> ﷿ في نِعَمه فيما أعطاك مِن الحكمة، <q>﴿ومَن يَشْكُرْ﴾</q> لله تعالى في نعمه؛ فيوحده <q>﴿فَإنَّما يَشْكُرُ﴾</q> يعني: فإنما يعمل الخير <q>﴿لِنَفْسِهِ ومَن كَفَرَ﴾</q> النِّعَم؛ فلم يُوَحِّد ربه ﷿ <q>﴿فَإنَّ اللَّهَ غَنِيٌّ﴾</q> عن عبادة خلقه، <q>﴿حَمِيدٌ﴾</q> عن خلقه في سُلْطانه{8}. (ز) <q>﴿وَلَقَدۡ ءَاتَیۡنَا لُقۡمَـٰنَ ٱلۡحِكۡمَةَ أَنِ ٱشۡكُرۡ لِلَّهِۚ وَمَن یَشۡكُرۡ فَإِنَّمَا یَشۡكُرُ لِنَفۡسِهِۦۖ وَمَن كَفَرَ فَإِنَّ ٱللَّهَ غَنِیٌّ حَمِیدࣱ ۝١٢﴾</q> - آثار متعلقة بالآية ٦٠٩٢٩- عن أبي هريرة، قال: قال رسول الله ﷺ: «أتدرون ما كان لقمان؟». قالوا: الله ورسوله أعلم. قال: «كان حبشيًّا»{1}. (١١/٦٢٤) ٦٠٩٣٠- عن ابن عباس، قال: قال رسول الله ﷺ: «اتخذوا السودان؛ فإن ثلاثة منهم سادات أهل الجنة: لقمان الحكيم، والنجاشي، وبلال المؤذن»{10}. (١١/٦٢٤) ٦٠٩٣١- عن ابن عمر، قال: سمعت رسول الله ﷺ يقول: «حقًّا أقول: لم يكن لقمان نبيًّا، ولكن عبد صَمْصامة{11}، كثير التفكير، حسن اليقين، أحب الله فأحبه، ومنَّ عليه بالحكمة»{12}. (ز) ٦٠٩٣٢- عن أبي موسى الأشعري، قال: قال رسول الله ﷺ: «قال لقمان لابنه، وهو يعظه: يا بني، إياك والتَقَنّع{13}؛ فإنها مَخُوفة بالليل، ومَذَلَّة بالنهار»{14}. (١١/٦٣١) ٦٠٩٣٣- عن أبي مسلم الخولاني، قال: قال رسول الله ﷺ: «إنّ لقمان كان عبدًا كثير التفكر، حسن الظن، كثير الصمت، أحبَّ الله فأحبه الله، فمَنّ عليه بالحكمة، نودي بالخلافة قبل داود ﵇، فقيل له: يا لقمان، هل لك أن يجعلك اللهُ خليفة في الأرض تحكم بين الناس بالحق؟ قال لقمان: إن أجبرني ربي قبلتُ؛ فإنِّي أعلم أنّه إن فعل ذلك أعانني وعلّمني وعصمني، وان خيّرني ربي قبلتُ العافية، ولم أسأل البلاء. فقالت الملائكة: يا لقمان، لِمَ؟ قال: لأن الحاكم بأشد المنازل وأكدرها؛ يغشاه الظلم من كل مكان، فيُخذل أو يُعان، فإن أصاب فبالحري أن ينجو، وإن أخطأ أخطأ طريق الجنة، ومَن يكون في الدنيا ذليلًا خير من أن يكون شريفًا ضائعًا، ومَن يختار الدنيا على الآخرة فاتته الدنيا، ولا يصير إلى ملك الآخرة. فعجبت الملائكة من حسن منطقه، فنام نومة، فغطَّ بالحكمة غطًّا، فانتبه، فتكلم بها، ثم نودي داود بعده بالخلافة فقبلها، ولم يشترط شرط لقمان، فأهوى في الخطيئة، فصفح الله عنه وتجاوز، وكان لقمان يؤازره بعلمه وحكمته، فقال داود ﵇: طوبى لك، يا لقمان، أوتيت الحكمة فصُرفت عنك البلية، وأوتي داود الخلافة فابتُلِي بالذنب والفتنة»{15}. (١١/٦٢٧) ٦٠٩٣٤- عن عبد الرحمن بن يزيد بن جابر قال: قال رسول الله ﷺ: «سادات السودان أربعة: لقمان الحبشي، والنجاشي، وبلال، ومهجع»{16}. (١١/٦٢٥) ٦٠٩٣٥- عن أبي الدرداء، أنه ذَكر لقمان الحكيم، فقال: ما أُوتي ما أُوتي عن أهل ولا مال ولا حسب ولا خصال، ولكنه كان رجلًا صمصامة، سكِّيتًا، طويل التفكر، عميق النظر، لم ينم نهارًا قط، ولم يره أحد يبزُق، ولا يتنخم، ولا يبول، ولا يتغوّط، ولا يغتسل، ولا يعبث، ولا يضحك، وكان لا يعيد منطقًا نطقه، إلا أن يقول حكمة يستعيدها إياه، وكان قد تزوج ووُلد له أولاد فماتوا فلم يبكِ عليهم، وكان يغشى السلطان، ويأتي الحكماء؛ لينظر ويتفكر ويعتبر، فبذلك أوتي ما أوتي{17}. (١١/٦٣٠) ٦٠٩٣٦- عن عبد الله بن عباس، قال: كان لقمانُ عبدًا أسود{18}. (١١/٦٢٥) ٦٠٩٣٧- عن عبد الله بن عباس -من طريق عكرمة- قال: كان لقمان عبدًا حبشيًّا نجارًا{19}. (١١/٦٢٤) ٦٠٩٣٨- عن عبد الله بن الزبير، قال: قلت لجابر بن عبد الله: ما انتهى إليكم مِن شأن لقمان؟ قال: كان قصيرًا، أفطس، مِن النوبة{20}. (١١/٦٢٤) ٦٠٩٣٩- عن عبيد بن عمير، قال: قال لقمان لابنه وهو يعظه: يا بني، اختر المجالس على عينك، فإذا رأيت المجلس يُذكر فيه الله ﷿ فاجلس معهم، فإنّك إن تكُ عالمًا ينفعك علمك، وإن تكُ عيِيًّا يُعَلِّموك، وإن يطلع الله ﷿ إليهم برحمة تصبك معهم. يا بني، لا تجلس في المجلس الذي لا يُذكر فيه الله، فإنّك إن تك عالمًا لا ينفعك علمك، وإن تك عيِيًّا يزيدوك عيًّا، وإن يطلع الله عليهم بعد ذلك بسخط يصبك معهم. يا بني، لا يغيظنك امرؤ رَحْبُ الذراعين{21} يسفك دماء المؤمنين، فإن له عند الله قاتلًا لا يموت{22}. (١١/٦٣٩) ٦٠٩٤٠- عن سعيد بن المسيب: أن لقمان كان أسود من سودان مصر، ذا مَشافِر{23}، أعطاه الله الحكمة، ومنعه النبوة{24}. (١١/٦٢٥) ٦٠٩٤١- عن عبد الرحمن بن حرملة، قال: جاء أسود يسأل سعيدَ بنَ المسيب، فقال له سعيد: لا تحزن مِن أجل أنك أسود، فإنّه كان مِن أخير الناس ثلاثة من السودان: بلال، ومهجع مولى عمر بن الخطاب، ولقمان الحكيم كان أسود نوبيًّا مِن سودان مصر، ذا مشافر{25}. (١١/٦٢٥) ٦٠٩٤٢- عن سعيد بن المسيب -من طريق علي بن زيد-: أن لقمان كان خياطًا{26}. (١١/٦٢٦) ٦٠٩٤٣- عن مجاهد بن جبر -من طريق سعيد الزبيدي- قال: كان لقمان الحكيم عبدًا حبشيًّا، غليظ الشفتين، مصفح{27} القدمين، قاضيًا لبني إسرائيل{28}. (١١/٦٢٦) ٦٠٩٤٤- عن مجاهد بن جبر-من طريق الحكم- قال: كان لقمان رجلًا صالحًا، ولم يكن نبيًّا{29}. (١١/٦٢٩) ٦٠٩٤٥- عن عكرمة مولى ابن عباس -من طريق جابر- قال: كان لقمان نبيًّا{30}. (١١/٦٢٩) ٦٠٩٤٦- قال وهب بن مُنَبِّه: كان لقمان ابن أخت أيوب{31}. (ز) ٦٠٩٤٧- عن قتادة بن دعامة -من طريق سعيد بن بشير- قال: كان لقمان رجلًا أفطس، مِن أرض الحبشة{32}. (ز) ٦٠٩٤٨- عن قتادة بن دعامة، قال: خيّر الله تعالى لقمان بين الحكمة والنبوة، فاختار الحكمة على النبوة، فأتاه جبريل وهو نائم، فذرَّ عليه الحكمة، فأصبح ينطق بها، فقيل له: كيف اخترت الحكمة على النبوة، وقد خيّرك ربك؟ فقال: إنه لو أرسل إليَّ بالنبوة عزمة لرجوت فيها الفوز منه، ولكنت أرجو أن أقوم بها، ولكنه خيّرني فخفتُ أن أضعف عن النبوة، فكانت الحكمة أحب إليَّ{33}. (١١/٦٢٨) ٦٠٩٤٩- قال مقاتل بن سليمان: ذُكر أنّه كان ابن خالة أيوب{31}. (ز) ٦٠٩٥٠- قال محمد بن إسحاق: هو لقمان بن ناعور بن ناحور بن تارخ، وهو آزر{31}. (ز) ٦٠٩٥١- عن ليث، قال: كانت حكمة لقمان نبوة{20}. (١١/٦٢٩) ٦٠٩٥٢- قال الواقدي: كان قاضيًا في بني إسرائيل{37}. (ز) ٦٠٩٥٣- عن الفضل الرَّقاشي، قال: ما زال لقمانُ يَعِظُ ابنَه حتى انشقت مرارتُه، فمات{38}. (١١/٦٣١) ",footnotes:1:عزاه السيوطي إلى ابن مردويه.أخرجه ابن جرير ١٨/٥٤٦ وزاد: وقال غير أبي بشر: الصواب في غير النبوة.أخرجه ابن جرير ١٨/٥٤٨.أخرجه ابن جرير ١٨/٥٤٩.تفسير مجاهد (٥٤١)، وأخرجه أحمد في الزهد (٤٨-٤٩)، وابن جرير ١٨/٥٤٦. وأخرجه إسحاق البستي في تفسيره ص٨٦ من طريق ابن جريج وزاد: والعفة. وعزاه السيوطي إلى الفريابي، وابن أبي حاتم.أخرجه إسحاق البستي ص٨٦.أخرجه ابن جرير ١٨/٥٤٦، وابن أبي حاتم -كما في تفسير ابن كثير ٦/٣٣٨-.تفسير مقاتل بن سليمان ٣/٤٣٤.عزاه السيوطي إلى ابن مردويه.أخرجه الطبراني في الكبير ١١/١٩٨ (١١٤٨٢)، وابن عساكر في تاريخه ١٠/٤٦٢ (٢٦٦٢)، من طريق عثمان بن عبد الرحمن الطرائفي، عن أبين بن سفيان المقدسي، عن خليفة بن سلام، عن عطاء بن أبي رباح، عن ابن عباس به. قال ابن حبان في المجروحين ١/١٧٩-١٨٠ (١١٦): «أبين بن سفيان المقدسي شيخ يقلب الأخبار، وأكثر رواته الضعفاء، يجب التنكب عن أخباره... هذا متن باطل لا أصل له». وقال ابن القيسراني في تذكرة الحفاظ ص١٢(١٣): «وأبين هذا -ابن سفيان- قال ابن حبان: يجب التنكب عن أخباره، وفرق بينه وبين أبان بن سفيان المقدسي، ولا أراهما إلا واحدًا. وأبين مصغر أبان -والله أعلم-، قال البخاري: لا يكتب حديث أبين بن سفيان». وقال ابن الجوزي في الموضوعات ٢/٢٣٢: «هذا حديث لا يصح، والمتهم به أبين». وقال ابن كثير في البداية ٣/١٦: «هذا حديث غريب، بل منكر». وقال الهيثمي في المجمع ٤/٢٣٥-٢٣٦ (٧٢٠٩): «فيه أبين بن سفيان، وهو ضعيف». وقال ابن عراق في تنزيه الشريعة ٢/٣٣ (٢٠): «من حديث ابن عباس، من طريق أبين بن سفيان وعثمان الطرايفي (تعقب) بأن الطرايفي وثق كما مر، وللحديث شاهد من حديث واثلة مرفوعًا: «خير السودان: لقمان، وبلال، ومهجع مولى رسول الله». أخرجه الحاكم في المستدرك وصحح إسناده، ومن حديث عبد الرحمن بن جابر مرسلًا: «سادة السودان أربعة: لقمان الحبشي، والنجاشي، وبلال، ومهجع». أخرجه ابن عساكر. وقال الفتني في تذكرة الموضوعات ص١١٣-١١٤:»فيه عثمان الطرائفي لا يحتج به عن أبين، لا يكتب حديثه. قلت: عثمان صدقه أبو حاتم، وللحديث شاهدان«. وقال المناوي في التيسير ١/٢٣:»ضعيف لضعف عثمان الطرائفي«. وقال في فيض القدير ١/١١١ (١٠٠):»إن سلم عدم وضعه فهو شديد الضعف جِدًّا«. وقال المغربي في جمع الفوائد ٢/٢٦٩ (٥٠١٦):»للكبير بضعف«. وقال الألباني في الضعيفة ٢/١٣١ (٦٨٧):»ضعيف جِدًّا".صَمْصامة: الشَّديد الصُلب. اللسان (صمم).أخرجه ابن عساكر في تاريخه ١٧/٨٥-٨٦ مطولًا، من طريق نوفل بن سليمان الهناني، عن عبيد الله بن عمر، عن نافع، عن ابن عمر به. وأورده الديلمي في مسند الفردوس ٣/٤٥٠ (٥٣٨٤)، والثعلبي ٧/٣١٢. قال ابن عراق في تنزيه الشريعة ١/٢٤٤: «وفيه نوفل بن سليمان الهنائي».التقنُّع بقاف ونون ثقيلة: تغطية الرأس وأكثر الوجه برداء أو غيره. فتح الباري ١٠/٢٧٤.أخرجه الحاكم ٢/٤٤٦(٣٥٤٣)، وابن أبي حاتم – كما في تفسير ابن كثير ٦/٣٤٠. قال الحاكم: «هذا متن شاهده إسناد صحيح والله أعلم». وقال الذهبي في التلخيص: «صحيح». وقال الشوكاني في فتح القدير ٤/٢٧٦: «وقد ذكر جماعة من أهل الحديث روايات عن جماعة من الصحابة، والتابعين تتضمن كلمات من مواعظ لقمان، وحكمه، ولم يصح عن رسول الله ﷺ من ذلك شيء، ولا ثبت إسناد صحيح إلى لقمان بشيء منها حتى نقبله».أورده الحكيم الترمذي في نوادر الأصول ١/٣٧٣-٣٧٤ دون ذكر الراوي. وورد الحديث من طريق ابن عمر، أخرجه ابن عساكر في تاريخه ١٧/٨٥، قال ابن عراق في تنزيه الشريعة ١/٢٤٤: «وفيه نوفل بن سليمان الهنائي».أخرجه ابن عساكر في تاريخه ١٠/٤٦٢ (٢٦٦٣)، وهو مرسل.أخرجه ابن أبي حاتم -كما في تفسير ابن كثير ٦/٣٣٧-.عزاه السيوطي إلى ابن أبي شيبة، وابن المنذر.أخرجه ابن جرير ١٨/٥٤٧. وعزاه السيوطي إلى ابن أبي شيبة، وأحمد في الزهد، وابن أبي الدنيا في كتاب المملوكين، وابن المنذر، وابن أبي حاتم.عزاه السيوطي إلى ابن أبي حاتم.رَحْبُ الذراعين: واسع القوة والقدرة والبطش. النهاية (ذرع) و(رحب).أخرجه ابن أبي شيبة ١٣/٢١٣-٢١٤ مختصرًا. وعزاه السيوطي إلى أحمد.مَشافِر: جمع مِشْفَر، وهو للبعير: كالشَّفَة للإنسان، وقد يُقال للإنسان مشافر على الاستعارة. اللسان (شفر).عزاه السيوطي إلى ابن جرير، وابن المنذر، وابن أبي حاتم.أخرجه ابن جرير ١٨/٥٤٧، والثعلبي ٧/٣١٣.تفسير مجاهد (٥٤٣)، وأخرجه أحمد في الزهد (٤٩). وعزاه السيوطي إلى ابن أبي شيبة، وابن المنذر.مصفح: عريض. لسان العرب (صفح).أخرجه ابن أبي شيبة ١٣/٢١٣، وأحمد في الزهد (٤٨)، وابن جرير ١٨/٥٤٧، كما أخرجه ابن جرير من طريق الأعمش قريبًا منه. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.أخرجه ابن جرير ١٨/٥٤٦.أخرجه ابن جرير ١٨/٥٤٩، وابن أبي حاتم -كما في تفسير ابن كثير ٦/٣٣٧-.تفسير البغوي ٦/٢٨٦.أخرجه الهذيل بن حبيب -تفسير مقاتل بن سليمان ٣/٤٣٤-.أخرجه ابن أبي حاتم -كما في تفسير ابن كثير ٦/٣٣٧-٣٣٨-.تفسير البغوي ٦/٢٨٦.تفسير البغوي ٦/٢٨٦.عزاه السيوطي إلى ابن أبي حاتم.تفسير الثعلبي ٧/٣١٢، وتفسير البغوي ٦/٢٨٦.عزاه السيوطي إلى ابن أبي الدنيا في نعت الخائفين. وقد ذكر السيوطي ١١/٦٢٩-٦٤٦ آثارًا كثيرةً مما أُثر من حِكَم لقمان وأخباره.
31,13," <q>﴿وَإِذۡ قَالَ لُقۡمَـٰنُ لِٱبۡنِهِۦ وَهُوَ یَعِظُهُۥ یَـٰبُنَیَّ لَا تُشۡرِكۡ بِٱللَّهِۖ إِنَّ ٱلشِّرۡكَ لَظُلۡمٌ عَظِیمࣱ ۝١٣﴾</q> - نزول الآية ٦٠٩٥٤- عن عبد الله بن مسعود -من طريق علقمة- قال: لما نزلت: <q>﴿الَّذِينَ آمَنُوا ولَمْ يَلْبِسُوا إيمانَهُمْ بِظُلْمٍ﴾</q> [الأنعام:٨٢] قال أصحابه: وأيُّنا لم يظلِم؟ فنزلت: <q>﴿إنَّ الشِّرْكَ لَظُلْمٌ عَظِيمٌ﴾</q>{1}٥١٣٤. (ز) ٥١٣٤ قوّى ابنُ عطية (٧/٤٦) بهذا الأثر أن قوله تعالى: <q>﴿إن الشرك لظلم عظيم﴾</q> هو من قول الله تعالى، وليس من كلام لقمان ﵇، فقال: «وظاهر قوله: <q>﴿إنَّ الشِّرْكَ لَظُلْمٌ عَظِيمٌ﴾</q> أنه من كلام لقمان، ويحتمل أن يكون خبرًا من الله تعالى منقطعًا من كلام لقمان، متصلًا به في تأكيد المعنى، ويؤيد هذا الحديث المأثور أنه لما نزلت: <q>﴿ولَمْ يَلْبِسُوا إيمانَهُمْ بِظُلْمٍ﴾</q> أشفق أصحاب رسول الله ﷺ، وقالوا: أينا لم يظلم نفسه؟ فأنزل الله تعالى: <q>﴿إنَّ الشِّرْكَ لَظُلْمٌ عَظِيمٌ﴾</q> فسكن إشفاقهم. وإنما يسكن إشفاقهم بأن يكون ذلك خبرًا من الله تعالى، وقد يسكن الإشفاق بأن يذكر الله ذلك عن عبدٍ قد وصفه بالحكمة والسداد». <q>﴿وَإِذۡ قَالَ لُقۡمَـٰنُ لِٱبۡنِهِۦ وَهُوَ یَعِظُهُۥ یَـٰبُنَیَّ لَا تُشۡرِكۡ بِٱللَّهِۖ إِنَّ ٱلشِّرۡكَ لَظُلۡمٌ عَظِیمࣱ ۝١٣﴾</q> - تفسير الآية ٦٠٩٥٥- قال الحسن البصري: <q>﴿لَظُلْمٌ عَظِيمٌ﴾</q> يُنقِص به نفسه{2}. (ز) ٦٠٩٥٦- قال إسماعيل السُّدِّيّ: <q>﴿لَظُلْمٌ عَظِيمٌ﴾</q> لذنب عظيم{2}. (ز) ٦٠٩٥٧- قال مقاتل بن سليمان: <q>﴿وإذْ قالَ لُقْمانُ لِابْنِهِ﴾</q> واسم ابنه: أنعم <q>﴿وهُوَ يَعِظُهُ﴾</q> يعني: يُؤَدِّبه: <q>﴿يا بُنَيَّ لا تُشْرِكْ بِاللَّهِ﴾</q> معه غيره؛ <q>﴿إنَّ الشِّرْكَ لَظُلْمٌ عَظِيمٌ﴾</q> كان ابنه وامرأتُه كفّارًا، فما زال بهما حتى أسلما. وزعموا: أنّ لقمان كان ابن خالة أيوب ﵇{4}. (ز) ٦٠٩٥٨- قال يحيى بن سلّام: <q>﴿وإذْ قالَ لُقْمانُ لِابْنِهِ وهُوَ يَعِظُهُ يا بُنَيَّ لا تُشْرِكْ بِاللَّهِ إنَّ الشِّرْكَ لَظُلْمٌ عَظِيمٌ﴾</q> يظلم المشركُ به نفسَه، ويَضُرُّ به نفسَه{5}. (ز) <q>﴿وَإِذۡ قَالَ لُقۡمَـٰنُ لِٱبۡنِهِۦ وَهُوَ یَعِظُهُۥ یَـٰبُنَیَّ لَا تُشۡرِكۡ بِٱللَّهِۖ إِنَّ ٱلشِّرۡكَ لَظُلۡمٌ عَظِیمࣱ ۝١٣﴾</q> - آثار متعلقة بالآية ٦٠٩٥٩- عن الحسن البصري، قال: قال الله ﷿: يا ابن آدم، خلقتُك وتعبدُ غيري! وتدعو إليَّ وتفرُّ مني! وتُذكّر بي وتنساني! هذا أظلم ظلم في الأرض. ثم يتلو الحسن: <q>﴿إنَّ الشِّرْكَ لَظُلْمٌ عَظِيمٌ﴾</q>{6}. (١١/٦٤٦) ٦٠٩٦٠- عن الحسن، قال: قال النبي ﷺ: «الظلم ثلاثة: فظلم لا يغفره الله تبارك وتعالى، وظلم يغفره الله، وظلم لا يدعه الله؛ فأما الظلم الذي لا يغفره الله فالإشراك، وأما الظلم الذي يغفره الله فذنوب العباد فيما بينهم وبين الله، وأما الظلم الذي لا يدعه الله فظلم العباد بعضُهم بعضًا، لا يدعه الله حتى يقص بعضهم من بعض»{7}. (ز) ",footnotes:1:أخرجه البخاري ٦/٥٦-٥٧ (٤٦٢٩)، ٤/١٦٣ (٣٤٢٨)، ويحيى بن سلّام ٢/٦٧٣. كما أخرجه البخاري في مواضع أخرى دون قوله: «فنزلت» ١/١٥-١٦ (٣٢)، ٤/١٤١ (٣٣٦٠)، ٦/١١٥ (٤٧٧٦)، ٩/١٣ (٦٩١٨)، ٩/١٨ (٦٩٣٧)، وكذلك مسلم ١/١١٤ (١٢٤).علقه يحيى بن سلّام ٢/٦٧٣.علقه يحيى بن سلّام ٢/٦٧٣.تفسير مقاتل بن سليمان ٣/٤٣٤.تفسير يحيى بن سلّام ٢/٦٧٣.أخرجه عبد الله بن أحمد في زوائد الزهد (٨٥).أخرجه معمر بن راشد في جامعه ١١/١٨٣ (٢٠٢٧٦)، ويحيى بن سلّام ٢/٦٧٣-٦٧٤ مرسلًا.
31,14," <q>﴿وَوَصَّیۡنَا ٱلۡإِنسَـٰنَ بِوَ ٰ⁠لِدَیۡهِ﴾</q> - تفسير ٦٠٩٦١- عن إسماعيل السُّدِّيّ: <q>﴿ووَصَّيْنا الإنْسانَ بِوالِدَيْهِ﴾</q>، يعني: بِرًّا بوالديه{1}. (ز) ٦٠٩٦٢- قال مقاتل بن سليمان: <q>﴿ووَصَّيْنا الإنْسانَ﴾</q> سعد بن أبي وقاص <q>﴿بِوالِدَيْهِ﴾</q> يعني: أباه اسمه مالك، وأمه حمنة بنت سفيان بن أمية بن عبد شمس بن عبد مناف{2}. (ز) <q>﴿حَمَلَتۡهُ أُمُّهُۥ وَهۡنًا عَلَىٰ وَهۡنࣲ﴾</q> - تفسير ٦٠٩٦٣- عن عبد الله بن عباس -من طريق عطية العوفي- في قوله: <q>﴿وهْنًا عَلى وهْنٍ﴾</q>، قال: شِدَّة بعد شدة، وخَلْقًا بعد خَلْق{3}. (١١/٦٤٨) ٦٠٩٦٤- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿وهْنًا عَلى وهْنٍ﴾</q>، قال: مشقة، وهو الولد{4}. (١١/٦٤٨) ٦٠٩٦٥- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿وهْنًا﴾</q> قال: وهن الولد <q>﴿عَلى وهْنٍ﴾</q> قال: الوالدة وضعفها{5}. (١١/٦٤٩) ٦٠٩٦٦- تفسير مجاهد بن جبر -في حديث عاصم بن حكيم- <q>﴿وهْنًا عَلى وهْنٍ﴾</q>: وهن الولد على وهن الولد{6}٥١٣٥. (ز) ٥١٣٥ قال ابنُ عطية (٧/٤٧): «<q>﴿وهْنًا عَلى وهْنٍ﴾</q> معناه: ضعفًا على ضعف. وقيل: إشارة إلى مشقة الحمل، ومشقة الولادة بعده. وقيل: إشارة إلى ضعف الولد، وضعف الأم معه. ويحتمل أنه أشار إلى تدرج حالها في زيادة الضعف، كأنه لم يُعَيِّن ضعفين، بل كأنه قال: حملته أمه، والضعف يتزيد بعد الضعف إلى أن ينقضي أمدُه». ٦٠٩٦٧- عن الضحاك بن مزاحم -من طريق عبيد- في قوله: <q>﴿وهْنًا عَلى وهْنٍ﴾</q>، يقول: ضعفًا على ضعف{3}. (ز) ٦٠٩٦٨- قال الحسن البصري: <q>﴿حَمَلَتْهُ أُمُّهُ وهْنًا عَلى وهْنٍ﴾</q> ضعفًا على ضعف{1}. (ز) ٦٠٩٦٩- عن قتادة بن دعامة -من طريق سعيد- <q>﴿حَمَلَتْهُ أُمُّهُ وهْنًا عَلى وهْنٍ﴾</q>: أي: جَهْدًا على جَهْد{9}. (ز) ٦٠٩٧٠- عن عطاء الخراساني، في قوله: <q>﴿وهْنًا عَلى وهْنٍ﴾</q>، قال: ضعفًا على ضعف{10}. (١١/٦٤٨) ٦٠٩٧١- قال مقاتل بن سليمان: <q>﴿حَمَلَتْهُ أُمُّهُ وهْنًا عَلى وهْنٍ﴾</q>، يعني: ضَعفًا على ضعف{2}. (ز) ٦٠٩٧٢- قال يحيى بن سلّام: <q>﴿وهْنًا عَلى وهْنٍ﴾</q>، والوهن: الضَّعْف{12}. (ز) <q>﴿وَفِصَـٰلُهُۥ فِی عَامَیۡنِ أَنِ ٱشۡكُرۡ لِی وَلِوَ ٰ⁠لِدَیۡكَ إِلَیَّ ٱلۡمَصِیرُ ۝١٤﴾</q> - تفسير ٦٠٩٧٣- قال مقاتل بن سليمان: <q>﴿وفِصالُهُ فِي عامَيْن أنِ اشْكُرْ لِي﴾</q> يعني: لله ﷿ أن هداه للإسلام، <q>﴿و﴾</q> اشكر <q>﴿لِوالِدَيْكَ﴾</q> النِّعَم فيما أوْلَياك، <q>﴿إلَيَّ المَصِيرُ﴾</q> فأجزيك بعملك{2}. (ز) ٦٠٩٧٤- قال يحيى بن سلّام: <q>﴿وفِصالُهُ﴾</q> أي: وفطامه <q>﴿فِي عامَيْنِ أنِ اشْكُرْ لِي ولِوالِدَيْكَ إلَيَّ المَصِيرُ﴾</q> البعث{12}. (ز) <q>﴿وَفِصَـٰلُهُۥ فِی عَامَیۡنِ أَنِ ٱشۡكُرۡ لِی وَلِوَ ٰ⁠لِدَیۡكَ إِلَیَّ ٱلۡمَصِیرُ ۝١٤﴾</q> - آثار متعلقة بالآية ٦٠٩٧٥- عن سفيان بن عيينة -من طريق نصير بن يحيى- قال: مَن صلّى الصلوات الخمس فقد شكر الله، ومَن دعا للوالدين في أدبار الصلوات فقد شَكَر للوالدين{15}. (ز) ",footnotes:1:علَّقه يحيى بن سلّام ٢/٦٧٤.تفسير مقاتل بن سليمان ٣/٤٣٤.أخرجه ابن جرير ١٨/٥٥٠.تفسير مجاهد (٥٤١). وعزاه السيوطي إلى الفريابي، وابن أبي شيبة، وابن جرير، وابن المنذر، وابن أبي حاتم.أخرجه ابن جرير ١٨/٥٥١، كما أخرجه يحيى بن سلّام ٢/٦٧٤، من طريق ابن مجاهد. وعزاه السيوطي إلى ابن أبي حاتم.تفسير يحيى بن سلّام ٢/٦٧٤، وكذا وقع فيه تفسير مجاهد، ولعله: وهن الولد على وهن الوالدة. كما في طريق ابن أبي نجيح.أخرجه ابن جرير ١٨/٥٥٠.علَّقه يحيى بن سلّام ٢/٦٧٤.أخرجه ابن جرير ١٨/٥٥٦. وعلقه يحيى بن سلّام ٢/٦٧٤.عزاه السيوطي إلى ابن أبي حاتم.تفسير مقاتل بن سليمان ٣/٤٣٤.تفسير يحيى بن سلّام ٢/٦٧٤.تفسير مقاتل بن سليمان ٣/٤٣٤.تفسير يحيى بن سلّام ٢/٦٧٤.أخرجه الثعلبي ٧/٣١٣، تفسير البغوي ٦/٢٨٧.
31,15," <q>﴿وَإِن جَـٰهَدَاكَ عَلَىٰۤ أَن تُشۡرِكَ بِی مَا لَیۡسَ لَكَ بِهِۦ عِلۡمࣱ فَلَا تُطِعۡهُمَاۖ وَصَاحِبۡهُمَا فِی ٱلدُّنۡیَا مَعۡرُوفࣰاۖ وَٱتَّبِعۡ سَبِیلَ مَنۡ أَنَابَ إِلَیَّۚ ثُمَّ إِلَیَّ مَرۡجِعُكُمۡ فَأُنَبِّئُكُم بِمَا كُنتُمۡ تَعۡمَلُونَ ۝١٥﴾</q> - نزول الآية ٦٠٩٧٦- عن سعد بن أبي وقاص، قال: نزلت فِيَّ أربع آيات: الأنفال، و<q>﴿صاحِبْهُما فِي الدُّنْيا مَعْرُوفًا﴾</q>، والوصية، والخمر{1}. (١١/٦٤٧) ٦٠٩٧٧- عن سعد بن أبي وقاص -من طريق مصعب- قال: نزلت فِيَّ هذه الآية: <q>﴿وإنْ جاهَداكَ عَلى أنْ تُشْرِكَ بِي ما لَيْسَ لَكَ بِهِ عِلْمٌ فَلا تُطِعْهُما وصاحِبْهُما فِي الدُّنْيا مَعْرُوفًا﴾</q>، كُنتُ رجلًا بَرًّا بأمي، فلمّا أسلمتُ قالتْ: يا سعد، ما هذا الذي أراك قد أحدثتَ؟! لَتَدَعَنَّ دينك هذا أو لا آكل ولا أشرب حتى أموت فتُعَيَّر بي، فيُقال: يا قاتلَ أُمِّه. قلتُ: لا تفعلي، يا أُمَّه؛ فإنِّي لا أدعُ ديني هذا لشيء. فمكثتْ يومًا آخر وليلة لا تأكل، فأصبحتْ قد جهدتْ، فمكثت يومًا آخر وليلة لا تأكل، فأصبحت وقد اشتد جهدُها، فلما رأيتُ ذلك قلتُ: يا أُمَّه، تعلمين -واللهِ- لو كانت لك مائة نفس، فخرجت نفسًا نفسًا، ما تركت ديني هذا لشيء، فإن شئتِ فكلي، وإن شئت فلا تأكلي. فلمّا رأت ذلك أكلت؛ فنزلت هذه الآية{2}. (١١/٦٤٧) ٦٠٩٧٨- عن سعد بن أبي وقاص -من طريق عامر- قال: جئتُ من الرَّمْيِ، فإذا الناس مجتمعون على أُمِّي حمنة بنت سفيان بن أمية بن عبد شمس، وعلى أخي عامر حين أسلم، فقلت: ما شأنُ الناس؟ قالوا: هذه أمك قد أخذت أخاك عامرًا تعطي الله عهدًا أن لا يُظلّها ظِلٌّ، ولا تأكل طعامًا، ولا تشرب شرابًا؛ حتى يدع الصباوة. فأقبل سعد حتى تخلص إليها، فقال: عَليَّ -يا أُمَّه- فاحلفي. قالت: لِمَ؟ قال: لِئَّلا تَسْتَظِلِّي في ظلٍّ، ولا تأكلي طعامًا، ولا تشربي شرابًا، حتى تري مقعدك من النار. فقالت: إنما أحلف على ابني البَرِّ. فأنزل الله: <q>﴿وإنْ جاهَداكَ عَلى أنْ تُشْرِكَ بِي ما لَيْسَ لَكَ بِهِ عِلْمٌ فَلا تُطِعْهُما وصاحِبْهُما فِي الدُّنْيا مَعْرُوفًا﴾</q> إلى آخر الآية{3}. (١١/٦٤٨) ٦٠٩٧٩- عن أبي هريرة -من طريق أبي إسحاق- قال: نزلت هذه الآية في سعد بن أبي وقاص: <q>﴿وإنْ جاهَداكَ عَلى أنْ تُشْرِكَ بِي﴾</q> الآية{4}. (١/٦٤٧) ٦٠٩٨٠- عن مصعب بن سعد -من طريق سماك ابن حرب- قال: حلفتْ أمُّ سعد أن لا تأكل ولا تشرب حتى يتحول سعدٌ عن دينه. قال: فأبى عليها، فلم تزل كذلك حتى غشي عليها. قال: فأتاها بنوها، فَسَقوها. قال: فلمّا أفاقت دعت الله عليه؛ فنزلت هذه الآية: <q>﴿ووَصَّيْنا الإنْسانَ بِوالِدَيْهِ﴾</q> إلى قوله: <q>﴿فِي الدُّنْيا مَعْرُوفًا﴾</q>{5}. (ز) ٦٠٩٨١- عن هبيرة -من طريق أبي إسحاق- قال: نزلت هذه الآية في سعد بن أبي وقاص: <q>﴿وإنْ جاهَداكَ عَلى أنْ تُشْرِكَ بِي ما لَيْسَ لَكَ بِهِ عِلْمٌ فَلا تُطِعْهُما﴾</q> الآية{6}. (ز) <q>﴿وَإِن جَـٰهَدَاكَ عَلَىٰۤ أَن تُشۡرِكَ بِی مَا لَیۡسَ لَكَ بِهِۦ عِلۡمࣱ فَلَا تُطِعۡهُمَاۖ﴾</q> - تفسير ٦٠٩٨٢- قال مقاتل بن سليمان: <q>﴿وإنْ جاهَداكَ عَلى أنْ تُشْرِكَ بِي ما لَيْسَ لَكَ بِهِ عِلْمٌ﴾</q> لا تعلم بأنّ معي شريكًا؛ <q>﴿فَلا تُطِعْهُما﴾</q> في الشِّرْك{7}. (ز) ٦٠٩٨٣- قال يحيى بن سلّام: <q>﴿وإنْ جاهَداكَ﴾</q> يعني: أراداك <q>﴿عَلى أنْ تُشْرِكَ بِي ما لَيْسَ لَكَ بِهِ عِلْمٌ﴾</q> أي: أنّك لا تعلم أنّ لي شريكًا، يعني: المؤمن{8}. (ز) <q>﴿وَإِن جَـٰهَدَاكَ عَلَىٰۤ أَن تُشۡرِكَ بِی مَا لَیۡسَ لَكَ بِهِۦ عِلۡمࣱ فَلَا تُطِعۡهُمَاۖ﴾</q> - آثار متعلقة بالآية ٦٠٩٨٤- عن ميمون بن مهران -من طريق جعفر بن برقان- قال: ثلاثٌ المؤمنُ والكافرُ فيهن سواء: الأمانة تؤديها إلى مَن ائتمنك [عليها] من مسلم وكافر، وبِرُّ الوالدين؛ قال الله تعالى: <q>﴿وإن جاهداك على أن تشرك بي ما ليس لك به علم فلا تطعهما﴾</q> الآية، والعهدُ تَفِي به لِمَن عاهدت مِن مسلم أو كافر{9}. (ز) <q>﴿وَصَاحِبۡهُمَا فِی ٱلدُّنۡیَا مَعۡرُوفࣰاۖ﴾</q> - تفسير ٦٠٩٨٥- عن قتادة -من طريق سعيد- في قوله: <q>﴿وصاحِبْهُما فِي الدُّنْيا مَعْرُوفًا﴾</q>، قال: تَعُودُهما إذا مرِضا، وتتبعهما إذا ماتا، وتُواسِيهما مِمّا أعطاك الله{10}. (١١/٦٤٩) ٦٠٩٨٦- قال مقاتل بن سليمان: <q>﴿وصاحِبْهُما فِي الدُّنْيا مَعْرُوفًا﴾</q>، يعني: بإحسان{7}. (ز) <q>﴿وَٱتَّبِعۡ سَبِیلَ مَنۡ أَنَابَ إِلَیَّۚ ثُمَّ إِلَیَّ مَرۡجِعُكُمۡ فَأُنَبِّئُكُم بِمَا كُنتُمۡ تَعۡمَلُونَ ۝١٥﴾</q> - نزول الآية، وتفسيرها ٦٠٩٨٧- عن عبد الله بن عباس -من طريق عطاء- قال: يريد: أبا بكر، وذلك أنه حين أسلم أتاه عبدُ الرحمن بن عوف، وسعدُ بن أبي وقاص، وسعيد بن زيد، وعثمان، وطلحة، والزبير، فقالوا لأبي بكر ﵁: آمنتَ وصدّقتَ محمدًا عليه الصلاة والسلام؟ فقال أبو بكر: نعم. فأتوا رسول الله ﷺ، فآمنوا وصدّقوا؛ فأنزل الله تعالى يقول لسعد: <q>﴿واتَّبِعْ سَبِيلَ مَن أنابَ إلَيَّ﴾</q>، يعني: أبا بكر ﵁{12}. (ز) ٦٠٩٨٨- عن قتادة -من طريق سعيد- في قوله: <q>﴿واتَّبِعْ سَبِيلَ مَن أنابَ إلَيَّ﴾</q>، قال: مَن أقبل إلَيَّ{13}. (١١/٦٤٩) ٦٠٩٨٩- عن عبد الملك ابن جُرَيج، في قوله: <q>﴿واتَّبِعْ سَبِيلَ مَن أنابَ إلَيَّ﴾</q>، قال: محمد ﷺ{14}. (١١/٦٤٩) ٦٠٩٩٠- قال مقاتل بن سليمان: <q>﴿واتَّبِعْ سَبِيلَ مَن أنابَ إلَيَّ﴾</q> يعني: دين مَن أقبل إلَيَّ، يعني: النبي ﷺ، <q>﴿ثُمَّ إلَيَّ مَرْجِعُكُمْ﴾</q> في الآخرة <q>﴿فَأُنَبِّئُكُمْ بِما كُنْتُمْ تَعْمَلُونَ﴾</q>{7}. (ز) ٦٠٩٩١- قال يحيى بن سلّام: <q>﴿واتَّبِعْ سَبِيلَ﴾</q> أي: طريق <q>﴿مَن أنابَ إلَيَّ﴾</q> مَن أقبل إلَيَّ بقلبه مُخلِصًا، يعني: النبي ﷺ والمؤمنين، <q>﴿ثُمَّ إلَيَّ مَرْجِعُكُمْ﴾</q> يوم القيامة <q>﴿فَأُنَبِّئُكُمْ بِما كُنْتُمْ تَعْمَلُونَ﴾</q>{8}. (ز) ",footnotes:1:أخرجه مسلم ٣/١٣٦٧ (١٧٤٨)، وابن عساكر ٢٠/٣٣١ واللفظ له.أخرجه ابن عساكر ٢٠/٣٣٠-٣٣١، والواحدي في أسباب النزول ص٣٤١-٣٤٢، وفي التفسير الوسيط ٣/٤١٤ من طريق أحمد بن أيوب بن راشد الضبي، عن مسلمة بن علقمة، عن داود بن أبي هند، عن أبي عثمان النهدي، عن سعد بن مالك به. وسنده ضعيف؛ فيه أحمد بن أيوب بن راشد الضبي، قال عنه ابن حجر في تقريب التهذيب (١١): «مقبول».أخرجه ابن سعد في الطبقات الكبرى ٤/١٢٣-١٢٤، وابن عساكر في تاريخ دمشق ٢٦/٩٥، من طريق محمد بن عمر، عن عبد الله بن جعفر، عن إسماعيل بن محمد بن سعد، عن عامر بن سعد، عن أبيه به. وسنده ضعيف جدًّا؛ فيه محمد بن عمر الواقدي، قال عنه ابن حجر في تقريب التهذيب (٦١٧٥): «متروك مع سعة علمه».روي نحوه من حديث أبي هبيرة، أخرجه ابن جرير ١٨/٥٥٣ من طريق ابن المثنى، عن محمد بن جعفر، عن شعبة، عن أبي إسحاق، عن أبي هبيرة به. وسنده صحيح.أخرجه ابن جرير ١٨/٥٥٢، وهذا لفظ آخر: قال: قالت أم سعد لسعد: أليس الله قد أمر بالبر، فواللهِ لا أطعم طعامًا، ولا أشرب شرابًا حتى أموت أو تكفر. قال: فكانوا إذا أرادوا أن يطعموها شَجَروا فاها بعصا، ثم أوجروها؛ فنزلت هذه الآية: <q>﴿ووَصَّيْنا الإنْسانَ بِوالِدَيْهِ﴾</q>.أخرجه ابن جرير ١٨/٥٥٣.تفسير مقاتل بن سليمان ٣/٤٣٤.تفسير يحيى بن سلّام ٢/٦٧٤-٦٧٥.أخرجه أبو نعيم في حلية الأولياء ٤/٨٧.عزاه السيوطي إلى ابن جرير، وابن أبي حاتم.تفسير مقاتل بن سليمان ٣/٤٣٤.أورده الواحدي في أسباب النزول ص٣٤٦، والبغوي ٦/٢٨٨.أخرجه ابن جرير ١٨/٥٥٤. وعزاه السيوطي إلى ابن أبي حاتم.عزاه السيوطي إلى ابن المنذر.تفسير مقاتل بن سليمان ٣/٤٣٤.تفسير يحيى بن سلّام ٢/٦٧٤-٦٧٥.
31,16," <q>﴿یَـٰبُنَیَّ إِنَّهَاۤ إِن تَكُ مِثۡقَالَ حَبَّةࣲ مِّنۡ خَرۡدَلࣲ﴾</q> - تفسير ٦٠٩٩٢- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿إنها إنْ تَكُ مِثْقالَ حَبَّةٍ مِن خَرْدَلٍ﴾</q>، قال: مِن خير أو شر{1}٥١٣٦. (١١/٦٤٩) ٥١٣٦ قال ابن عطية (٧/٤٩-٥٠): «وقوله:<q>﴿مِثْقالَ حَبَّةٍ﴾</q> عبارة تصلح للجواهر، أي قدر حبة، وتصلح للأعمال، أي ما زنته على جهة المماثلة قدر حبة، فظاهر الآية أنه أراد شيئًا من الأشياء خفيًا قدر حبة، ويؤيد ذلك ما روي من أن ابن لقمان سأل أباه عن الحبة تقع في مثل البحر، أيعلمها الله؟ فراجعه لقمان بهذه الآية. وذكر كثير من المفسرين أنه أراد الأعمال المعاصي والطاعات، ويؤيد ذلك قوله: <q>﴿يَأْتِ بِها اللَّهُ﴾</q> أي: لا تفوت، وبهذا المعنى يتحصل في الموعظة ترجية وتخويف. فيضاف ذلك إلى تبيين قدرة الله تعالى، وفي القول الآخر ليس ترجية ولا تخويف. ومما يؤيد قول من قال: هي من الجواهر قراءة عبد الكريم الجزري»فتكِنّ«بكسر الكاف وشد النون من الكِنّ الذي هو الشيء المغطى، وقرأ جمهور القراء»إن تك«بالتاء من فوق،»مثقال«بالنصب على خبر»كان«، واسمها مضمر تقديره: مسألتك، على ما روي، أو المعصية أو الطاعة على القول الثاني». ٦٠٩٩٣- قال مقاتل بن سليمان: قال ابن لقمان أنعم لأبيه: يا أبتِ، إن عمِلتُ بالخطيئة حيثُ لا يراني أحدٌ كيف يعلمه الله ﷿؟ فردَّ عليه لقمان: <q>﴿يا بُنَيّ إنَّها إنْ تَكُ مِثْقالَ حَبَّةٍ﴾</q>، يعني: وزن ذَرَّة{2}٥١٣٧. (ز) ٥١٣٧ ذكر ابنُ جرير (١٨/٥٥٤-٥٥٦) في عود الهاء من قوله: <q>﴿إنها﴾</q> قولًا لبعض أهل اللغة البصريين -وهو قول مقاتل-: أنها الخطيئة. وذكر قولًا آخر فقال: «وقال بعض نحويي الكوفة: وهذه الهاء عماد. وقال: أنّث <q>﴿تك﴾</q> لأنه يُراد بها الحبة، فذهب بالتأنيث إليها». ثم رجّح مستندًا إلى الدلالة العقلية هذا القول، فقال: «وأولى القولين بالصواب عندي القول الثاني؛ لأن الله -تعالى ذِكْرُه- لم يعد عباده أن يوفيهم جزاء سيئاتهم دون جزاء حسناتهم، فيقال: إنّ المعصية إن تك مثقال حبة من خردل يأتِ الله بها، بل وعد كِلا العاملين أن يوفيه جزاء أعمالهما. فإذا كان ذلك كذلك كانت الهاء في قوله: <q>﴿إنها﴾</q> بأن تكون عمادًا أشبه منها بأن تكون كناية عن الخطيئة والمعصية». واستدل على ذلك بقول قتادة. ورجّح ابنُ كثير (١١/٥٥) القول الأول بقوله: «والأول أولى». ولم يذكر مستندًا. ٦٠٩٩٤- قال يحيى بن سلّام: <q>﴿يا بُنَيَّ﴾</q> رجع إلى كلام لقمان، يعني: الكلام الأول: <q>﴿وإذْ قالَ لُقْمانُ لِابْنِه وهُوَ يَعِظُهُ يا بُنَيَّ لا تُشْرِكْ بِاللَّهِ﴾</q> [لقمان:١٣]، <q>﴿إنَّها إنْ تَكُ مِثْقالَ حَبَّةٍ مِن خَرْدَلٍ﴾</q> أي: وزن حبة مِن خردل{3}. (ز) <q>﴿فَتَكُن فِی صَخۡرَةٍ أَوۡ فِی ٱلسَّمَـٰوَ ٰ⁠تِ أَوۡ فِی ٱلۡأَرۡضِ یَأۡتِ بِهَا ٱللَّهُۚ﴾</q> - تفسير ٦٠٩٩٥- عن عبد الله بن مسعود، وناس من أصحاب النبي ﷺ -من طريق السُّدِّيّ، عن مُرَّة الهمداني-= (ز) ٦٠٩٩٦- وعبد الله بن عباس -من طريق السُّدِّيّ، عن أبي مالك وأبي صالح-: قال: خلق الله الأرض على حُوت، والحُوت هو النُّون الذي ذكر الله في القرآن: <q>﴿نوَن والقَلَمِ وما يَسْطُرُونَ﴾</q> [القلم:١]، والحوت في الماء، والماء على ظهر صَفاة، والصَّفاة على ظهر مَلَك، والمَلَك على صخرة، والصخرة في الريح، وهي الصخرة التي ذكر لقمان، ليست في السماء ولا في الأرض{4}٥١٣٨. (ز) ٥١٣٨ علّق ابنُ كثير (١١/٥٥-٥٦) على أثر ابن عباس، فقال: «وهذا -والله أعلم- كأنه مُتَلَقًّى من الإسرائيليات التي لا تُصَدَّق ولا تُكَذَّب. والظاهر -والله أعلم- أنّ المراد: أن هذه الحبة في حقارتها لو كانت داخل صخرة، فإن الله سيبديها ويظهرها بلطيف علمه». ٦٠٩٩٧- عن عبد الله بن عباس: <q>﴿فَتَكُنْ فِي صَخْرَةٍ﴾</q> في صخرة تحت الأرضين السبع، وهي التي تُكتب فيها أعمال الفجار، وخضرة السماء منها{5}. (ز) ٦٠٩٩٨- عن عبد الله بن الحارث – من طريق المنهال-، قال: الصخرة خضراء على ظهر حوت{6}. (ز) ٦٠٩٩٩- عن أبي مالك [الغفاري] -من طريق السُّدِّيّ- <q>﴿يَأْتِ بِها اللَّهُ﴾</q>، قال: يعلمها اللهُ{7}٥١٣٩. (١١/٦٥٠) ٥١٣٩ علّق ابنُ جرير (١٨/٥٥٧) على هذا القول، فقال: «ولا أعرف»يأتي به«بمعنى: يعلمه، إلا أن يكون قائل ذلك أراد أن لقمان إنما وصف الله بذلك؛ لأن الله يعلم أماكنه، لا يخفى عليه مكان شيء منه؛ فيكون وجهًا». ٦١٠٠٠- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿فَتَكُنْ فِي صَخْرَةٍ﴾</q>، قال: في جبل{8}. (١١/٦٤٩) ٦١٠٠١- عن محمد بن السائب الكلبي -من طريق معمر- في قوله تعالى: <q>﴿فَتَكُنْ فِي صَخْرَةٍ﴾</q> قال: الصخرة التي الأرض عليها، ثم قال: <q>﴿أوْ فِي السَّماواتِ أوْ فِي الأَرْضِ يَأْتِ بِها اللَّهُ﴾</q> يقول: إن يكن مثقال حبة من خردل مِن خير أو شرٍّ يأتِ بها الله{9}. (ز) ٦١٠٠٢- قال مقاتل بن سليمان: <q>﴿فَتَكُنْ فِي صَخْرَةٍ﴾</q> التي في الأرض السفلى، وهي خضراء مجوفة، لها ثلاث شُعَب، على لون السماء <q>﴿أوْ﴾</q> تكن الحبة <q>﴿فِي السَّماواتِ﴾</q> السبع <q>﴿أوْ فِي الأَرْضِ يَأْتِ بِها اللَّهُ﴾</q> يعني: بتلك الحبة{2}٥١٤٠. (ز) ٥١٤٠ قال ابنُ عطية (٧/٥١): «وقوله <q>﴿يَأْتِ بِها اللَّهُ﴾</q> إن أراد: الجواهر؛ فالمعنى: يأت بها إن احتيج إلى ذلك، إن كانت رزقًا ونحو هذا. وإن أراد: الأعمال؛ فمعناه: يأت بذكرها وحفظها ليجازي عليها بثواب أو عقاب». ٦١٠٠٣- عن سفيان الثوري -من طريق عبد الرزاق- قال: <q>﴿فَتَكُنْ فِي صَخْرَةٍ﴾</q> هي صخرة تحت الأرضين، بلغنا: أنّ خضرة السماء من تلك الصخرة{11}. (ز) ٦١٠٠٤- قال يحيى بن سلّام: <q>﴿فَتَكُنْ فِي صَخْرَةٍ﴾</q> بلغنا: أنّها الصخرة التي عليها الحوت، التي عليها قرار الأرضين، <q>﴿أوْ فِي السَّماواتِ أوْ فِي الأَرْضِ يَأْتِ بِها اللَّهُ﴾</q>، أي: احذر، فإنّه سيحصي عليك عملك، ويعلمه كما عَلِم هذه الحبة من الخردل. لقمان يقوله لابنه{3}٥١٤١. (ز) ٥١٤١ أشار ابنُ عطية (٧/٥٠) إلى نحو ما جاء في قول يحيى بن سلّام وغيره، وانتقده فقال: «وقوله: <q>﴿فَتَكُنْ فِي صَخْرَةٍ﴾</q>، قيل: أراد: الصخرة التي عليها الأرض والحوت والماء، وهي على ظهر ملك. وقيل: هي صخرة في الريح. وهذا كله ضعيف لا يثبته سند، وإنما معنى الكلام المبالغة والانتهاء في التفهيم، أي: أن قدرته تنال ما يكون في تضاعيف صخرة، وما يكون في السماء وفي الأرض». <q>﴿إِنَّ ٱللَّهَ لَطِیفٌ خَبِیرࣱ ۝١٦﴾</q> - تفسير ٦١٠٠٥- عن أبي العالية الرِّياحي -من طريق الربيع- قال: <q>﴿إنْ تَكُ مِثْقالَ حَبَّةٍ مِن خَرْدَلٍ فَتَكُنْ فِي صَخْرَةٍ أوْ فِي السَّمَواتِ أوْ فِي الأَرْضِ يَأْتِ بِها اللَّهُ إنَّ اللَّهَ لَطِيفٌ خَبِيرٌ﴾</q>، قال: لطيف باستخراجها، خبير بإتيانها{13}. (ز) ٦١٠٠٦- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿إنَّ اللَّهَ لَطِيفٌ﴾</q> قال: باستخراجها، <q>﴿خَبِير﴾</q> قال: بإتيانها{14}. (ز) ٦١٠٠٧- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿إنَّ اللَّهَ لَطِيفٌ﴾</q> قال: باستخراجها، <q>﴿خَبِير﴾</q> قال: بمستقرها{15}. (١١/٦٤٩) ٦١٠٠٨- قال مقاتل بن سليمان: <q>﴿إنَّ اللَّهَ لَطِيفٌ﴾</q> باستخراجها، <q>﴿خَبِيرٌ﴾</q> بمكانها{2}. (ز) ٦١٠٠٩- قال يحيى بن سلّام: <q>﴿إنَّ اللَّهَ لَطِيفٌ﴾</q> باستخراجها، <q>﴿خَبِيرٌ﴾</q> بمكانها{3}. (ز) <q>﴿إِنَّ ٱللَّهَ لَطِیفٌ خَبِیرࣱ ۝١٦﴾</q> - آثار متعلقة بالآية ٦١٠١٠- عن علي بن رباح اللخمي: إنّه لَمّا وعظ لقمانُ ابنَه قال: <q>﴿إنها إنْ تَكُ﴾</q> الآية؛ أخذ حبَّةً مِن خردل، فأتى بها إلى اليرموك، فألقاها في عرضه، ثم مكث ما شاء الله، ثم ذكرها، وبسط يده، فأقبل بها ذبابٌ حتّى وضعها في راحته{18}. (١١/٦٣٥) ",footnotes:1:أخرجه ابن جرير ١٨/٥٥٦. وعزاه السيوطي إلى ابن أبي حاتم.تفسير مقاتل بن سليمان ٣/٤٣٥.تفسير يحيى بن سلّام ٢/٦٧٥.أخرجه ابن جرير ١٨/٥٦٠. وفي تفسير الثعلبي ٧/٣١٤، وتفسير البغوي ٦/٢٨٨-٢٨٩ بنحوه موقوفًا على السدي.تفسير الثعلبي ٧/٣١٤، وتفسير البغوي ٦/٢٨٨.أخرجه ابن جرير ١٨/٥٥٦.أخرجه ابن جرير ١٨/٥٥٧. وعزاه السيوطي إلى الفريابي.أخرجه ابن جرير ١٨/٥٥٧. وعزاه السيوطي إلى ابن أبي حاتم.أخرجه عبد الرزاق ٢/١٠٥-١٠٦.تفسير مقاتل بن سليمان ٣/٤٣٥.أخرجه عبد الرزاق ٢/١٠٦.تفسير يحيى بن سلّام ٢/٦٧٥.أخرجه آدم بن أبي إياس -كما في تفسير مجاهد (٥٤٢)-. وعلقه يحيى بن سلّام ٢/٦٧٦.تفسير مجاهد (٥٤٢).أخرجه ابن جرير ١٨/٥٥٨. وعزاه السيوطي إلى ابن أبي حاتم.تفسير مقاتل بن سليمان ٣/٤٣٥.تفسير يحيى بن سلّام ٢/٦٧٥.أخرجه عبد الله بن وهب في الجامع- تفسير القرآن ١/٨١-٨٢ (١٨٣). وعزاه السيوطي إلى ابن أبي حاتم.
31,17," <q>﴿یَـٰبُنَیَّ أَقِمِ ٱلصَّلَوٰةَ وَأۡمُرۡ بِٱلۡمَعۡرُوفِ وَٱنۡهَ عَنِ ٱلۡمُنكَرِ﴾</q> - تفسير ٦١٠١١- عن أبي العالية الرِّياحي -من طريق الربيع- قال: <q>﴿وأْمُرْ بِالمَعْرُوفِ وانْهَ عَنِ المُنْكَرِ﴾</q> مَن أمَر بعبادة الله، ونَهى عن عبادة الأوثان؛ فقد أمر بالمعروف ونهى عن المنكر{1}. (ز) ٦١٠١٢- عن سعيد بن جبير، في قوله: <q>﴿وأْمُرْ بِالمَعْرُوفِ﴾</q> يعني: بالتوحيد، <q>﴿وانه عَنِ المُنْكَرِ﴾</q> يعني: عن الشرك{2}. (١١/٦٥٠) ٦١٠١٣- عن إسماعيل السُّدِّيّ: <q>﴿يا بُنَيَّ أقِمِ الصَّلاةَ وأْمُرْ بِالمَعْرُوفِ﴾</q>، يعني: بالتوحيد{3}. (ز) ٦١٠١٤- قال مقاتل بن سليمان: <q>﴿يا بُنَيَّ أقِم الصَّلاةَ وأْمُرْ بِالمَعْرُوفِ﴾</q> يعني: التوحيد، <q>﴿وانْهَ عَنِ المُنْكَرِ﴾</q> يعني: الشر الذي لا يُعرف{4}. (ز) ٦١٠١٥- قال يحيى بن سلّام: <q>﴿وانْهَ عَن المُنْكَرِ﴾</q>، يعني: الشرك بالله{5}. (ز) <q>﴿وَٱصۡبِرۡ عَلَىٰ مَاۤ أَصَابَكَۖ﴾</q> - تفسير ٦١٠١٦- عن سعيد بن جبير، في قوله: <q>﴿واصْبِرْ عَلى ما أصابَكَ﴾</q>: في أمرهما. يقول: إذا أمرت بمعروف أو نهيت عن منكر، وأصابك في ذلك أذًى وشدة؛ فاصبِر عليه{2}. (١١/٦٥٠) ٦١٠١٧- قال مقاتل بن سليمان: <q>﴿واصْبِرْ عَلى ما أصابَكَ﴾</q> فيهما مِن الأذى{4}. (ز) ٦١٠١٨- عن عبد الملك ابن جُرَيج -من طريق حجاج- في قوله: <q>﴿واصْبِرْ عَلى ما أصابَكَ﴾</q>: مِن الأذى في ذلك{8}. (١١/٦٥٠) <q>﴿إِنَّ ذَ ٰ⁠لِكَ مِنۡ عَزۡمِ ٱلۡأُمُورِ ۝١٧﴾</q> - تفسير ٦١٠١٩- قال عبد الله بن عباس: <q>﴿مِن عَزْمِ الأُمُورِ﴾</q> حَزْم الأمور{9}. (ز) ٦١٠٢٠- عن سعيد بن جبير، في قوله: <q>﴿إنَّ ذَلِكَ﴾</q>: يعني: هذا الصبر على الأذى في الأمر بالمعروف والنهي عن المنكر <q>﴿مِن عَزْمِ الأُمُورِ﴾</q> يعني: مِن حقِّ الأمور التي أمر الله تعالى{2}. (١١/٦٥٠) ٦١٠٢١- قال مقاتل بن سليمان: <q>﴿إنَّ ذَلِكَ مِن عَزْمِ الأُمُورِ﴾</q> إنّ ذلك الصبر على الأذى في الأمر بالمعروف والنهي عن المنكر مِن حقِّ الأمور التي أمر الله ﷿ بها، وعزم عليها{4}. (ز) ٦١٠٢٢- عن عبد الملك ابن جُرَيج -من طريق حجاج- في قوله: <q>﴿إنَّ ذَلِكَ مِن عَزْمِ الأُمُورِ﴾</q>، يقول: مِمّا عزم الله عليه من الأمور، ومِمّا أمر الله به من الأمور{8}. (١١/٦٥٠-٦٥١) ٦١٠٢٣- قال يحيى بن سلّام: <q>﴿واصْبِرْ عَلى ما أصابَكَ إنَّ ذَلِكَ مِن عَزْم الأُمُورِ﴾</q> العزم: أن تصبر{5}٥١٤٢. (ز) ٥١٤٢ اختلف السلف في قوله:<q>﴿إن ذلك من عزم الأمور﴾</q> على قولين، الأول: أن معناه: ذلك من حزم الأمور. الثاني: أن معناه: ذلك مما عزمه الله وأمر به. وقد رجّح ابن عطية (٧/٥١) القول الثاني، ولم يذكر مستندًا. <q>﴿إِنَّ ذَ ٰ⁠لِكَ مِنۡ عَزۡمِ ٱلۡأُمُورِ ۝١٧﴾</q> - آثار متعلقة بالآية ٦١٠٢٤- عن عمير بن حبيب، وكانت له صحبة -من طريق أبي جعفر الخطمي- أوصى بنيه، قال: يا بَنِيَّ، إيّاكم ومجالسةَ السفهاء، فإنّ مجالستهم داء، إنّه من يحلم عن السفيه يُسَرُّ بحلمه، ومن يجبه يندم، ومن لا يقرُّ بقليل ما يأتي به السفيه يقرُّ بالكثير، ومن يصبر على ما يكره يدرك ما يحب، وإذا أراد أحدُكم أن يأمر الناس بالمعروف وينهاهم عن المنكر فليوطِّن نفسه على الصبر على الأذى، ولْيَثِقْ بالثواب من الله، ومَن يَثِقْ بالثواب مِن الله لا يجد مسَّ الأذى{14}. (١١/٦٥١) ",footnotes:1:أخرجه آدم بن أبي إياس -كما في تفسير مجاهد (٥٤٢)-. وعلقه يحيى بن سلّام ٢/٦٧٦.عزاه السيوطي إلى ابن أبي حاتم.علَّقه يحيى بن سلّام ٢/٦٧٦.تفسير مقاتل بن سليمان ٣/٤٣٥.تفسير يحيى بن سلّام ٢/٦٧٦.عزاه السيوطي إلى ابن أبي حاتم.تفسير مقاتل بن سليمان ٣/٤٣٥.أخرجه ابن جرير ١٨/٥٥٨. وعزاه السيوطي إلى ابن المنذر.تفسير الثعلبي ٧/٣١٤.عزاه السيوطي إلى ابن أبي حاتم.تفسير مقاتل بن سليمان ٣/٤٣٥.أخرجه ابن جرير ١٨/٥٥٨. وعزاه السيوطي إلى ابن المنذر.تفسير يحيى بن سلّام ٢/٦٧٦.أخرجه ابن أبي شيبة ٨/٤٠٠، وأحمد في الزهد (١٨٦)، والخطيب في تالي التلخيص (١٢٢). وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.
31,18," <q>﴿وَلَا تُصَعِّرۡ خَدَّكَ لِلنَّاسِ﴾</q> - تفسير ٦١٠٢٥- عن أبي أيوب الأنصاري: أنّ رسول الله ﷺ سُئِل عن قول الله: <q>﴿ولا تُصَعِّرْ خَدَّكَ لِلنّاسِ﴾</q>. قال: «لَيُّ الشِّدْق{1}»{2}. (١١/٦٥١) ٦١٠٢٦- عن عبد الله بن عباس -من طريق علي- في قوله: <q>﴿ولا تُصَعِّرْ خَدَّكَ لِلنّاسِ﴾</q>، يقول: لا تَتَكَبَّر فتَحْقِر عباد الله، وتُعْرِض عنهم بوجهك إذا كلَّموك{3}. (١١/٦٥٢) ٦١٠٢٧- عن عبد الله بن عباس، في قوله: <q>﴿ولا تُصَعِّرْ خَدَّكَ لِلنّاسِ﴾</q>، قال: هو الذي إذا سُلِّم عليه لوى عنقَه كالمستكبر{4}. (١١/٦٥٢) ٦١٠٢٨- عن أبي العالية -من طريق الربيع بن أنس- في قوله ﷿: <q>﴿ولا تصعر خدك للناس﴾</q>، قال: يكون الغنيُّ والفقيرُ عندك في العلم سواء{5}. (ز) ٦١٠٢٩- عن سعيد بن جبير، في قوله: <q>﴿ولا تُصَعِّرْ خَدَّكَ لِلنّاسِ﴾</q>، يقول: لا تُعرِض بوجهك عن فقراء الناس تكبُّرًا{6}. (١١/٦٥٢) ٦١٠٣٠- عن إبراهيم النخعي -من طريق مغيرة، ومنصور- قال: <q>﴿ولا تُصَعِّرْ خَدَّكَ لِلنّاسِ﴾</q> هو التَّشْدِيق{7}. (ز) ٦١٠٣١- عن يزيد بن الأصم -من طريق جعفر بن برقان- في هذه الآية: <q>﴿ولا تُصَعِّرْ خَدَّكَ لِلنّاسِ﴾</q>، قال: إذا كلَّمك الإنسانُ لَوَيْت وجهك، وأعرضت عنه محقِّرًا له{8}. (ز) ٦١٠٣٢- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿ولا تُصَعِّرْ خَدَّكَ لِلنّاسِ﴾</q>، قال: الصدود والإعراض بالوجه عن الناس{9}. (١١/٦٥٢) ٦١٠٣٣- عن مجاهد بن جبر -من طريق منصور- <q>﴿ولا تُصَعِّرْ خَدَّكَ لِلنّاسِ﴾</q>، قال: الرجلُ يكونُ بينه وبين أخيه الحِنَة{10}، فيراه، فيُعرض عنه{11}. (ز) ٦١٠٣٤- عن الضحاك بن مُزاحِم -من طريق عبيد- في قوله: <q>﴿ولا تُصَعِّرْ خَدَّكَ لِلنّاسِ﴾</q>، يقول: لا تُعرِض عن الناس. يقول: أقبِل على الناسِ بوجهك، وحسِّن خُلقَك{12}. (ز) ٦١٠٣٥- قال عكرمة مولى ابن عباس: <q>﴿ولا تُصَعِّرْ خَدَّكَ لِلنّاسِ﴾</q> هو الذي إذا سُلِّم عليه لوى عنقه تكبُّرًا{13}. (ز) ٦١٠٣٦- عن عكرمة مولى ابن عباس -من طريق أبي مكين- في قوله: <q>﴿ولا تُصَعِّرْ خَدَّكَ لِلنّاسِ﴾</q>، قال: لا تُعرِض بوجهك{12}. (ز) ٦١٠٣٧- قال عطاء: <q>﴿ولا تُصَعِّرْ خَدَّكَ لِلنّاسِ﴾</q> هو الذي يَلْوِي شِدْقَه{15}. (ز) ٦١٠٣٨- عن ميمون بن مهران -من طريق جعفر- قال: <q>﴿ولا تُصَعِّرْ خَدَّكَ لِلنّاسِ﴾</q> هو الرجل يُكَلِّم الرجل، فيلوي وجهَه{12}. (ز) ٦١٠٣٩- عن مكحول -من طريق النعمان- في قوله تعالى: <q>﴿ولا تصعر خدك للناس﴾</q>، قال: التَّصْعِير: أن ينفخ الرجل خَدَّه، ويُعرِض بوجهه عن الناس{17}. (ز) ٦١٠٤٠- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿ولا تُصَعِّرْ خَدَّكَ لِلنّاسِ ولا تَمْشِ فِي الأَرْضِ مَرَحًا إنَّ اللَّهَ لا يُحِبُّ كُلَّ مُخْتالٍ فَخُورٍ﴾</q>، قال: نهاه عن التَّكَبُّر{7}. (ز) ٦١٠٤١- عن قتادة بن دعامة -من طريق معمر- <q>﴿ولا تُصَعِّرْ خَدَّكَ لِلنّاسِ﴾</q>، قال: هو الإعراض؛ أن يُكَلِّمك الرجلُ وأنت مُعْرِضٌ عنه{19}. (ز) ٦١٠٤٢- قال قتادة بن دعامة: <q>﴿ولا تُصَعِّرْ خَدَّكَ لِلنّاسِ﴾</q> لا تحتقر الفقراء، لِيَكُنِ الفقير والغنيُّ عندك سواء{13}. (ز) ٦١٠٤٣- قال الربيع بن أنس -من طريق أبي جعفر- في قوله: <q>﴿ولا تُصَعِّرْ خَدَّكَ لِلنّاسِ﴾</q>، قال: ليكن الفقير والغني عندك في العلم سواء، وقد عُوتِب النبيُّ ﷺ: <q>﴿عَبَسَ وتَوَلّى﴾</q> [عبس:١]{21}. (١١/٦٥٢) ٦١٠٤٤- قال مقاتل بن سليمان: <q>﴿ولا تُصَعِّرْ خَدَّكَ لِلنّاسِ﴾</q> لا تُعْرِض بوجهك عن فقراء الناس إذا كلَّموك فخرًا بالخُيلاء والعظمة{22}. (ز) ٦١٠٤٥- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿ولا تُصَعِّرْ خَدَّكَ لِلنّاسِ﴾</q>، قال: تصعير الخد: التجبُّر، والتكبُّر على الناس، ومَحْقَرتهم{11}٥١٤٣. (ز) ٥١٤٣ اختلف السلف في معنى: <q>﴿ولا تصعر خدك﴾</q> على أقوال: الأول: أنّه الإعراض بالوجه تكبُّرًا. الثاني: أنه التشديق. الثالث: أنّه الإعراض عمَّن بينك وبينه خصومة وإحنة. وقد رجّح ابنُ جرير (١٨/٥٥٩) مستندًا إلى اللغة القولَ الأول، فقال: "وأصل الصعر: داء يأخذ الإبل في أعناقها أو رؤوسها حتى تلفت أعناقها عن رؤوسها، فيشبه به الرجل المتكبر على الناس. ومنه قول عمرو بن كلثوم التغلبي: وكنّا إذا الجبّار صعَّر خدَّه... أقمْنا له من مَيلِه فتقوَّما". وبنحوه ابنُ كثير (٦/٣٣٩). وذكر ابنُ عطية (٧/٥٢) في الآية قولًا آخر، فقال: «ويحتمل أن يريد أيضًا الضد، أي: ولا سؤالًا ولا ضراعة بالفقر». ثم رجّح مستندًا إلى السياق القول الأول، فقال: «والأول أظهر؛ بدلالة ذكر الاختيال والفخر بعد». <q>﴿وَلَا تَمۡشِ فِی ٱلۡأَرۡضِ مَرَحًاۖ إِنَّ ٱللَّهَ لَا یُحِبُّ كُلَّ مُخۡتَالࣲ فَخُورࣲ ۝١٨﴾</q> - تفسير ٦١٠٤٦- عن مجاهد بن جبر -من طريق ابن أبي نجيح- <q>﴿كُلَّ مُخْتالٍ﴾</q> قال: مُتَكَبِّر، <q>﴿فَخُورٍ﴾</q> يُعَدِّد ما أعطى الله، وهو لا يشكر الله{24}٥١٤٤. (ز) ٥١٤٤ ذكر ابنُ عطية (٧/٥٣) قول مجاهد، ثم علّق قائلًا: «وفي اللفظ الفخر بالنسب وغير ذلك». ٦١٠٤٧- عن الضحاك بن مُزاحِم -من طريق عبيد- في قوله: <q>﴿ولا تَمْشِ فِي الأَرْضِ مَرَحًا﴾</q>، يقول: بالخُيلاء{7}. (ز) ٦١٠٤٨- قال مقاتل بن سليمان: <q>﴿ولا تَمْشِ فِي الأَرْضِ مَرَحًا إنَّ اللَّهَ لا يُحِبُّ كُلَّ مُخْتالٍ فَخُورٍ﴾</q>، يعني ﷿: كل بَطِرٍ مَرِحٍ فخورٍ في نعم الله تعالى لا يأخذها بالشُّكر{22}. (ز) ٦١٠٤٩- قال يحيى بن سلّام: <q>﴿ولا تَمْشِ فِي الأَرْض مَرَحًا﴾</q> بالعظمة، <q>﴿فَخُورٍ﴾</q> يَعُدُّ ما أُعْطِي زهوًا، لا يشكر الله{27}. (ز) <q>﴿وَلَا تَمۡشِ فِی ٱلۡأَرۡضِ مَرَحًاۖ إِنَّ ٱللَّهَ لَا یُحِبُّ كُلَّ مُخۡتَالࣲ فَخُورࣲ ۝١٨﴾</q> - آثار متعلقة بالآية ٦١٠٥٠- عن أبي ذرٍّ، قال: سمعتُ رسول الله ﷺ يقول: «ثلاثةٌ يُحِبُّهم الله، وثلاثة يبغضهم الله». قال: نعم، فما أخالني أكذب على خليلي محمد ﷺ. ثلاثًا يقولها، قال: قلت: مَنِ الثلاثةُ الِّذين يحبهم الله ﷿؟ قال: «رجل غزا في سبيل الله، فلقي العدوَّ مجاهدًا محتسبًا فقاتل حتى قُتل، وأنتم تجدون في كتاب الله ﷿: <q>﴿إنَّ اللَّهَ يُحِبُّ الَّذِين َيُقاتِلُونَ فِي سَبِيلِهِ صَفًّا﴾</q> [الصف:٤]، ورجل له جارٍ يؤذيه، فيصبر على أذاه ويحتسبه، حتى يكفيه الله إيّاه بموت أو حياة، ورجل يكون مع قوم فيسيرون حتى يشق عليهم الكرى والنعاس، فينزلون في آخر الليل، فيقوم إلى وضوئه وصلاته». قال: قلت: مَن الثلاثة الذين يبغضهم الله؟ قال: «الفخور المختال، وأنتم تجدون في كتاب الله ﷿: <q>﴿إنَّ اللَّهَ لا يُحِبُّ كُلَّ مُخْتالٍ فَخُورٍ﴾</q> [لقمان:١٨]، والبخيل المنّان، والتاجر -أو البَيّاع- الحلّاف»{28}. (ز) ",footnotes:1:الشِّدْق: جانب الفم. اللسان (شدق).أخرجه ابن عدي في الكامل ٨/٣٧١ (٢٠٠٩)، وأخرجه بدون ذكر الآية وإنما بلفظ التصعير الطبراني في الكبير ٤/١٧٩ (٤٠٧٢)، من طريق واصل بن السائب، عن أبي سورة، عن أبي أيوب به. قال ابن القيسراني في ذخيرة الحفاظ ٢/٧٤٤-٧٤٥ (١٣٩٤): «رواه واصل بن السائب الرقاشي، عن أبي سورة ابن أخي أبي أيوب، عن عمه أبي أيوب الأنصاري، وواصل متروك الحديث». وقال الهيثمي في المجمع ٨/١١٤ (١٣٢٦٨): «فيه واصل بن السائب، وهو متروك».أخرجه ابن جرير ١٨/٥٥٩، كما أخرجه من طريق عطية العوفي أيضًا، وابن أبي حاتم -كما في الإتقان ٢/٣٦-. وعزاه السيوطي إلى ابن المنذر.عزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.أخرجه الآجري في أخلاق أهل القرآن ص١١٣ (٤٥).عزاه السيوطي إلى ابن أبي حاتم.أخرجه ابن جرير ١٨/٥٦٢.أخرجه ابن جرير ١٨/٥٦٠، وإسحاق البستي ص٨٩.تفسير مجاهد (٥٤٢)، وأخرجه ابن جرير ١٨/٥٦٠. وعلقه يحيى بن سلّام ٢/٦٧٦. وعزاه السيوطي إلى الفريابي.الحِنة: العداوة. النهاية ١/٤٥٣.أخرجه ابن جرير ١٨/٥٦١.أخرجه ابن جرير ١٨/٥٦٠.تفسير البغوي ٦/٢٨٩.أخرجه ابن جرير ١٨/٥٦٠.تفسير الثعلبي ٧/٣١٤.أخرجه ابن جرير ١٨/٥٦٠.أخرجه ابن عساكر في تاريخ دمشق ١٨/١٣١.أخرجه ابن جرير ١٨/٥٦٢.أخرجه ابن أبي الدنيا في التواضع والخمول ٣/٥٧٨ (٢٢٢).تفسير البغوي ٦/٢٨٩.أخرجه البيهقي في شعب الإيمان (٨١٧٩). وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.تفسير مقاتل بن سليمان ٣/٤٣٥.أخرجه ابن جرير ١٨/٥٦١.تفسير مجاهد (٥٤٢)، وأخرجه ابن جرير ١٨/٥٦٤. وعلَّقه يحيى بن سلّام ٢/٦٧٦.أخرجه ابن جرير ١٨/٥٦٢.تفسير مقاتل بن سليمان ٣/٤٣٥.تفسير يحيى بن سلّام ٢/٦٧٦.أخرجه أحمد ٣٥/٢٨٥ (٢١٣٥٥)، والترمذي ٤/٥٣١-٥٣٢ (٢٧٥٠-٢٧٥١)، والنسائي ٣/٢٠٧ (١٦١٥)، ٥/٨٤ (٢٥٧٠)، وابن خزيمة ٤/١٧٥ (٢٤٥٦)، ٤/٢٥٤ (٢٥٦٤)، وابن حبان ٨/١٣٦-١٣٧ (٣٣٤٩)، ٨/١٣٨ (٣٣٥٠)، ١١/٩١ (٤٧٧١)، والحاكم ١/٥٧٧ (١٥٢٠)، ٢/١٢٣ (٢٥٣٢)،من طريق منصور، عن ربعي بن حراش، عن زيد بن ظبيان، عن أبي ذر به. وأخرجه أحمد ٣٥/٢٦٨-٢٦٩ (٢١٣٤٠)، من طريق إسماعيل، عن الجريري، عن أبي العلاء بن الشخير، عن ابن الأحمسي، عن أبي ذر به. وأخرجه أحمد من طرق أخرى عن أبي ذر ﵁. قال الترمذي: «هذا حديث صحيح». وقال الحاكم: «هذا حديث صحيح على شرط الشيخين، ولم يخرجاه». ووافقه الذهبي في التلخيص. وقال ابن كثير في تفسيره ٢/٦٣ عن رواية أحمد: «غريب من هذا الوجه». وقال العراقي في تخريج الإحياء ص١٠٢٥ (١٠): «أخرجه أحمد واللفظ له، وفيه ابن الأحمس ولا يعرف حاله، ورواه هو والنسائي بلفظ آخر بإسناد جيد».
31,19," <q>﴿وَٱقۡصِدۡ فِی مَشۡیِكَ﴾</q> - تفسير ٦١٠٥١- عن سعيد بن جبير، في قوله: <q>﴿واقْصِدْ فِي مَشْيِكَ﴾</q>، يقول: لا تَخْتَلْ{1}. (١١/٦٥٣) ٦١٠٥٢- عن مجاهد بن جبر -من طريق جابر- في قوله: <q>﴿واقْصِدْ فِي مَشْيِكَ﴾</q>، قال: تَواضَعْ{2}. (١١/٦٥٢) ٦١٠٥٣- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿واقْصِدْ فِي مَشْيِكَ﴾</q>، قال: نهاه عن الخُيَلاء{3}. (١١/٦٥٣) ٦١٠٥٤- عن يزيد بن أبي حبيب -من طريق عبد الله بن عقبة- في قوله: <q>﴿واقصد في مشيك﴾</q>، قال: مِن السُّرْعة{4}٥١٤٥. (١١/٦٥٣) ٥١٤٥ جمع ابنُ جرير (١٨/٥٦٢) بين قول يزيد وقول قتادة ومجاهد، فقال: «قوله تعالى: <q>﴿واقصد في مشيك﴾</q> يقول: وتواضع في مشيك إذا مشيت، ولا تستكبر، ولا تستعجل، ولكن اتَّئِدْ. وبنحو الذي قلنا في ذلك قال أهل التأويل، غير أن منهم من قال: أمره بالتواضع في مشيه. ومنهم مَن قال: أمره بترك السرعة فيه». ٦١٠٥٥- قال مقاتل بن سليمان: <q>﴿واقْصِدْ فِي مَشْيِكَ﴾</q> لا تَخْتل في مشيك، ولا تبطر حيث لا يحل{5}. (ز) ٦١٠٥٦- قال يحيى بن سلّام: <q>﴿واقْصِدْ فِي مَشْيِكَ﴾</q>، وقال في آية أخرى: <q>﴿ولا تَمْشِ فِي الأَرْضِ مَرَحًا إنَّكَ لَنْ تَخْرِقَ الأَرْضَ ولَنْ تَبْلُغَ الجِبالَ طُولًا﴾</q> [الإسراء:٣٧]{6}. (ز) <q>﴿وَٱغۡضُضۡ مِن صَوۡتِكَۚ﴾</q> - تفسير ٦١٠٥٧- عن سعيد بن جبير، في قوله: <q>﴿واغْضُضْ مِن صَوْتِكَ﴾</q>، قال: اخفِض مِن صوتك عند الملأ{1}. (١١/٦٥٣) ٦١٠٥٨- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿واغْضُضْ مِن صَوْتِكَ﴾</q>، قال: أمره بالاقتصاد في صوته{8}. (١١/٦٥٣) ٦١٠٥٩- قال مقاتل بن سليمان: <q>﴿واغْضُضْ﴾</q> يعني: واخفِض <q>﴿مِن صَوْتِكَ﴾</q> يعني: مِن كلامك. يأمُرُ لقمانُ ابنَه بالاقتصاد في المشي والمنطق{5}. (ز) ٦١٠٦٠- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- <q>﴿واغْضُضْ مِن صَوْتِكَ إنَّ أنْكَرَ الأَصْواتِ لَصَوْتُ الحَمِيرِ﴾</q>، قال: اخفِض من صوتك{10}. (ز) <q>﴿إِنَّ أَنكَرَ ٱلۡأَصۡوَ ٰ⁠تِ لَصَوۡتُ ٱلۡحَمِیرِ ۝١٩﴾</q> - تفسير ٦١٠٦١- عن سعيد بن جبير، في قوله: <q>﴿إنَّ أنْكَرَ الأَصْواتِ﴾</q> قال: أقبح الأصوات <q>﴿لَصَوْتُ الحَمِيرِ﴾</q>{1}. (١١/٦٥٣) ٦١٠٦٢- عن مجاهد بن جبر، في قوله: <q>﴿إنَّ أنْكَرَ الأَصْواتِ لَصَوْتُ الحَمِيرِ﴾</q>، قال: أنكرها على السمع{12}. (١١/٦٥٣) ٦١٠٦٣- عن مجاهد بن جبر -من طريق أبان بن تغلب- في قوله: <q>﴿إن أنكر الأصوات لصوت الحمير﴾</q>، قال: <q>﴿أنكر﴾</q>: أقبح{13}. (ز) ٦١٠٦٤- عن الضحاك بن مزاحم -من طريق جويبر- <q>﴿إنَّ أنْكَرَ الأَصْواتِ﴾</q>، قال: إنّ أقبح الأصوات <q>﴿لَصَوْتُ الحَمِيرِ﴾</q>{10}. (ز) ٦١٠٦٥- قال الضحاك بن مزاحم: <q>﴿إنَّ أنْكَرَ الأَصْواتِ لَصَوْتُ الحَمِيرِ﴾</q> أقبح؛ لأن أوله زفيرٌ وآخره شهيق، أمره بالاقتصاد في صوته{15}. (ز) ٦١٠٦٦- عن عكرمة مولى ابن عباس= (ز) ٦١٠٦٧- والحكم بن عتيبة -من طريق جابر- <q>﴿إنَّ أنْكَرَ الأَصْواتِ﴾</q>: أشرَّ الأصوات{16}. (ز) ٦١٠٦٨- عن الحسن بن مسلم -من طريق جابر- <q>﴿إنَّ أنْكَرَ الأَصْواتِ لَصَوْتُ الحَمِيرِ﴾</q>: أشد الأصوات{17}. (ز) ٦١٠٦٩- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿إنَّ أنْكَرَ الأَصْواتِ﴾</q> قال: أقبح الأصوات <q>﴿لَصَوْتُ الحَمِيرِ﴾</q> قال: أوله زفير وآخره شهيق{18}. (١١/٦٥٣) ٦١٠٧٠- عن سليمان بن مهران الأعمش -من طريق سفيان- <q>﴿إنَّ أنْكَرَ الأَصْواتِ لَصَوْتُ الحَمِيرِ﴾</q>: أقبح الأصوات صوت الحمير{19}. (ز) ٦١٠٧١- عن محمد بن السائب الكلبي -من طريق معمر- في قوله تعالى: <q>﴿إنَّ أنْكَرَ الأَصْواتِ لَصَوْتُ الحَمِيرِ﴾</q>، قال: أقبح الأصوات لصوت الحمار{20}. (ز) ٦١٠٧٢- قال جعفر الصادق، في قوله: <q>﴿إنَّ أنْكَرَ الأَصْواتِ لَصَوْتُ الحَمِيرِ﴾</q>، قال: هي العَطْسَة القبيحة المنكرة{21}. (ز) ٦١٠٧٣- قال مقاتل بن سليمان: <q>﴿إنَّ أنْكَرَ الأَصْواتِ لَصَوْتُ الحَمِيرِ﴾</q> يعني: أقبح الأصوات لصوت الحمير، لشدة صوتهن {5}. (ز) ٦١٠٧٤- قال يحيى بن سلّام: <q>﴿إنَّ أنْكَرَ الأَصْواتِ﴾</q> يعني: أقبح الأصوات <q>﴿لَصَوْتُ الحَمِيرِ﴾</q>، وإنّما كانت صوت الحمير ولم يكن لَأَصوات الحمير؛ لأنه عنى صوتها الذي هو صوتها{6}٥١٤٦. (ز) ٥١٤٦ اختلف السلف في تفسير قوله: <q>﴿إن أنكر الأصوات لصوت الحمير﴾</q> على أقوال: الأول: أقبح. الثاني: أشر. وقد جمع ابنُ جرير (١٨/٥٦٥) بينهما مستندًا إلى اللغة، فقال: «وأولى الأقوال في ذلك بالصواب قول من قال: معناه: إن أقبح أو أشر الأصوات. وذلك نظير قولهم إذا رأوا وجهًا قبيحًا أو منظرًا شنيعًا: ما أنكر وجه فلان، وما أنكر منظره». <q>﴿إِنَّ أَنكَرَ ٱلۡأَصۡوَ ٰ⁠تِ لَصَوۡتُ ٱلۡحَمِیرِ ۝١٩﴾</q> - آثار متعلقة بالآية ٦١٠٧٥- عن جابر بن عبد الله ﵄من طريق نبيح العنزي- وتلا قول لقمان لابنه: <q>﴿واقْصِدْ فِي مَشْيِكَ واغْضُضْ مِن صَوْتِكَ﴾</q>، قال: كان رسول الله ﷺ إذا خرج مشوا بين يديه، وخلَّوْا ظهرَه للملائكة{24}. (ز) ٦١٠٧٦- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- قال: لو كان رفعُ الصوت خيرًا ما جعله الله للحمير{25}. (١١/٦٥٤) ",footnotes:1:عزاه السيوطي إلى ابن أبي حاتم.أخرجه ابن جرير ١٨/٥٦٣. وعزاه السيوطي إلى ابن أبي حاتم.أخرجه ابن جرير ١٨/٥٦٣. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، ابن أبي حاتم.أخرجه إسحاق البستي ص٩١ من طريق حيوة، وابن جرير ١٨/٥٦٣، والبيهقي في شعب الإيمان (٨١٦٨). وعزاه السيوطي إلى سعيد ابن منصور، وابن المنذر، وابن أبي حاتم.تفسير مقاتل بن سليمان ٣/٤٣٥.تفسير يحيى بن سلّام ٢/٦٧٧.عزاه السيوطي إلى ابن أبي حاتم.أخرجه ابن جرير ١٨/٥٦٤. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.تفسير مقاتل بن سليمان ٣/٤٣٥.أخرجه ابن جرير ١٨/٥٦٤.عزاه السيوطي إلى ابن أبي حاتم.عزاه السيوطي إلى سعيد بن منصور، وابن جرير، وابن المنذر.أخرجه إسحاق البستي ص٩١. وأورده الثعلبي ٧/٣١٥ بأتمَّ من ذلك كما في أثر الضحاك بعد التالي.أخرجه ابن جرير ١٨/٥٦٤.تفسير الثعلبي ٧/٣١٥.أخرجه ابن جرير ١٨/٥٦٥.أخرجه ابن جرير ١٨/٥٦٨.أخرجه ابن جرير ١٨/٥٦٣-٥٦٤. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.أخرجه سفيان الثوري في تفسيره (٢٣٨)، وابن جرير ١٨/٥٦٥.أخرجه عبد الرزاق ٢/١٠٦.تفسير البغوي ٦/٢٩٠.تفسير مقاتل بن سليمان ٣/٤٣٥.تفسير يحيى بن سلّام ٢/٦٧٧.أخرجه الحاكم ٢/٤٤٦ (٣٥٤٤)، ٤/٣١٣ (٧٧٥٢)، وأخرجه من غير ذكر الآية أحمد ٢٢/١٣٩-١٤٠ (١٤٢٣٦)، ٢٢/٤٢٠-٤٢١ (١٤٥٥٦)، وابن ماجه ١/١٦٦ (٢٤٦)، وابن حبان ١٤/٢١٨ (٦٣١٢)، من طريق سفيان، عن الأسود بن قيس، عن نبيح العنزي، عن جابر بن عبد الله به. قال الحاكم: «هذا حديث صحيح الإسناد، ولم يخرجاه». ووافقه الذهبي في التلخيص. وقال البوصيري في مصباح الزجاجة ١/٣٦ (٩٧): «هذا إسناد صحيح، رجاله ثقات». وأورده الألباني في الصحيحة ١/٧٩٧ (٤٣٦)، ٥/١٢٣ (٢٠٨٧).أخرجه ابن جرير ١٨/٥٦٥. وعزاه السيوطي إلى ابن أبي حاتم.
