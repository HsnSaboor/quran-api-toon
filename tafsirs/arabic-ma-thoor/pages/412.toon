quran[8]{c,v,t}:
  31,12,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَلَقَدۡ ءَاتَیۡنَا لُقۡمَـٰنَ ٱلۡحِكۡمَةَ أَنِ ٱشۡكُرۡ لِلَّهِۚ وَمَن یَشۡكُرۡ فَإِنَّمَا یَشۡكُرُ لِنَفۡسِهِۦۖ وَمَن كَفَرَ فَإِنَّ ٱللَّهَ غَنِیٌّ حَمِیدࣱ ۝١٢﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٠٩٢١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، في قوله: <span class="qpc-hafs">﴿ولَقَدْ آتَيْنا لُقْمانَ الحِكْمَةَ﴾</span>، قال: يعني: العقل، والفهم، والفِطنة، في غير نُبُوَّة{1}. (١١/٦٢٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٠٩٢٢<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق يونس- في قوله: <span class="qpc-hafs">﴿ولَقَدْ آتَيْنا لُقْمانَ الحِكْمَةَ﴾</span>، قال: الحكمة: الصواب{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٠٩٢٣<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق سفيان، عن رجل- <span class="qpc-hafs">﴿ولَقَدْ آتَيْنا لُقْمانَ الحِكْمَةَ﴾</span>، قال: القرآن{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٠٩٢٤<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- قال: الحكمة: الأمانة{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٠٩٢٥<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿ولَقَدْ آتَيْنا لُقْمانَ الحِكْمَةَ﴾</span>، قال: العقل، والفقه، والإصابة في القول، في غير نبوة{5}. (١١/٦٢٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٠٩٢٦<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن جريج- في قوله: <span class="qpc-hafs">﴿ولقد ءاتينا لقمان الحكمة﴾</span>، قال: الفقه، والعلم، والإصابة في غير نبوة. <span class="qpc-hafs">﴿ومن يؤت الحكمة فقد أوتي خيرًا كثيرًا﴾</span> [البقرة:٢٦٩]، قال: الإصابة{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٠٩٢٧<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿ولَقَدْ آتَيْنا لُقْمانَ الحِكْمَةَ﴾</span>، قال: الفقه في الإسلام، ولم يكن نبيًّا، ولم يُوحَ إليه{7}. (١١/٦٢٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٠٩٢٨<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ولَقَدْ آتَيْنا لُقْمانَ الحِكْمَةَ﴾</span> أعطيناه العلم والفهم مِن غير نبوة، فهذه نعمة، فقلنا له: <span class="qpc-hafs">﴿أنِ اشْكُرْ لِلَّهِ﴾</span> ﷿ في نِعَمه فيما أعطاك مِن الحكمة، <span class="qpc-hafs">﴿ومَن يَشْكُرْ﴾</span> لله تعالى في نعمه؛ فيوحده <span class="qpc-hafs">﴿فَإنَّما يَشْكُرُ﴾</span> يعني: فإنما يعمل الخير <span class="qpc-hafs">﴿لِنَفْسِهِ ومَن كَفَرَ﴾</span> النِّعَم؛ فلم يُوَحِّد ربه ﷿ <span class="qpc-hafs">﴿فَإنَّ اللَّهَ غَنِيٌّ﴾</span> عن عبادة خلقه، <span class="qpc-hafs">﴿حَمِيدٌ﴾</span> عن خلقه في سُلْطانه{8}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَلَقَدۡ ءَاتَیۡنَا لُقۡمَـٰنَ ٱلۡحِكۡمَةَ أَنِ ٱشۡكُرۡ لِلَّهِۚ وَمَن یَشۡكُرۡ فَإِنَّمَا یَشۡكُرُ لِنَفۡسِهِۦۖ وَمَن كَفَرَ فَإِنَّ ٱللَّهَ غَنِیٌّ حَمِیدࣱ ۝١٢﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٦٠٩٢٩<span class="dash">-</span></span> عن أبي هريرة، قال: قال رسول الله ﷺ: «<b>أتدرون ما كان لقمان</b>؟». قالوا: الله ورسوله أعلم. قال: «<b>كان حبشيًّا</b>»{1}. (١١/٦٢٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٠٩٣٠<span class="dash">-</span></span> عن ابن عباس، قال: قال رسول الله ﷺ: «<b>اتخذوا السودان؛ فإن ثلاثة منهم سادات أهل الجنة: لقمان الحكيم، والنجاشي، وبلال المؤذن</b>»{10}. (١١/٦٢٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٠٩٣١<span class="dash">-</span></span> عن ابن عمر، قال: سمعت رسول الله ﷺ يقول: «<b>حقًّا أقول: لم يكن لقمان نبيًّا، ولكن عبد صَمْصامة</b>{11}، <b>كثير التفكير، حسن اليقين، أحب الله فأحبه، ومنَّ عليه بالحكمة</b>»{12}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٠٩٣٢<span class="dash">-</span></span> عن أبي موسى الأشعري، قال: قال رسول الله ﷺ: «<b>قال لقمان لابنه، وهو يعظه: يا بني، إياك والتَقَنّع</b>{13}؛ <b>فإنها مَخُوفة بالليل، ومَذَلَّة بالنهار</b>»{14}. (١١/٦٣١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٠٩٣٣<span class="dash">-</span></span> عن أبي مسلم الخولاني، قال: قال رسول الله ﷺ: «<b>إنّ لقمان كان عبدًا كثير التفكر، حسن الظن، كثير الصمت، أحبَّ الله فأحبه الله، فمَنّ عليه بالحكمة، نودي بالخلافة قبل داود ﵇، فقيل له: يا لقمان، هل لك أن يجعلك اللهُ خليفة في الأرض تحكم بين الناس بالحق؟ قال لقمان: إن أجبرني ربي قبلتُ؛ فإنِّي أعلم أنّه إن فعل ذلك أعانني وعلّمني وعصمني، وان خيّرني ربي قبلتُ العافية، ولم أسأل البلاء. فقالت الملائكة: يا لقمان، لِمَ؟ قال: لأن الحاكم بأشد المنازل وأكدرها؛ يغشاه الظلم من كل مكان، فيُخذل أو يُعان، فإن أصاب فبالحري أن ينجو، وإن أخطأ أخطأ طريق الجنة، ومَن يكون في الدنيا ذليلًا خير من أن يكون شريفًا ضائعًا، ومَن يختار الدنيا على الآخرة فاتته الدنيا، ولا يصير إلى ملك الآخرة. فعجبت الملائكة من حسن منطقه، فنام نومة، فغطَّ بالحكمة غطًّا، فانتبه، فتكلم بها، ثم نودي داود بعده بالخلافة فقبلها، ولم يشترط شرط لقمان، فأهوى في الخطيئة، فصفح الله عنه وتجاوز، وكان لقمان يؤازره بعلمه وحكمته، فقال داود ﵇: طوبى لك، يا لقمان، أوتيت الحكمة فصُرفت عنك البلية، وأوتي داود الخلافة فابتُلِي بالذنب والفتنة</b>»{15}. (١١/٦٢٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٠٩٣٤<span class="dash">-</span></span> عن عبد الرحمن بن يزيد بن جابر قال: قال رسول الله ﷺ: «<b>سادات السودان أربعة: لقمان الحبشي، والنجاشي، وبلال، ومهجع</b>»{16}. (١١/٦٢٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٠٩٣٥<span class="dash">-</span></span> عن <span class="name-1">أبي الدرداء</span>، أنه ذَكر لقمان الحكيم، فقال: ما أُوتي ما أُوتي عن أهل ولا مال ولا حسب ولا خصال، ولكنه كان رجلًا صمصامة، سكِّيتًا، طويل التفكر، عميق النظر، لم ينم نهارًا قط، ولم يره أحد يبزُق، ولا يتنخم، ولا يبول، ولا يتغوّط، ولا يغتسل، ولا يعبث، ولا يضحك، وكان لا يعيد منطقًا نطقه، إلا أن يقول حكمة يستعيدها إياه، وكان قد تزوج ووُلد له أولاد فماتوا فلم يبكِ عليهم، وكان يغشى السلطان، ويأتي الحكماء؛ لينظر ويتفكر ويعتبر، فبذلك أوتي ما أوتي{17}. (١١/٦٣٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٠٩٣٦<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، قال: كان لقمانُ عبدًا أسود{18}. (١١/٦٢٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٠٩٣٧<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عكرمة- قال: كان لقمان عبدًا حبشيًّا نجارًا{19}. (١١/٦٢٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٠٩٣٨<span class="dash">-</span></span> عن عبد الله بن الزبير، قال: قلت <span class="name-1">لجابر بن عبد الله</span>: ما انتهى إليكم مِن شأن لقمان؟ قال: كان قصيرًا، أفطس، مِن النوبة{20}. (١١/٦٢٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٠٩٣٩<span class="dash">-</span></span> عن <span class="name-2">عبيد بن عمير</span>، قال: قال لقمان لابنه وهو يعظه: يا بني، اختر المجالس على عينك، فإذا رأيت المجلس يُذكر فيه الله ﷿ فاجلس معهم، فإنّك إن تكُ عالمًا ينفعك علمك، وإن تكُ عيِيًّا يُعَلِّموك، وإن يطلع الله ﷿ إليهم برحمة تصبك معهم. يا بني، لا تجلس في المجلس الذي لا يُذكر فيه الله، فإنّك إن تك عالمًا لا ينفعك علمك، وإن تك عيِيًّا يزيدوك عيًّا، وإن يطلع الله عليهم بعد ذلك بسخط يصبك معهم. يا بني، لا يغيظنك امرؤ رَحْبُ الذراعين{21} يسفك دماء المؤمنين، فإن له عند الله قاتلًا لا يموت{22}. (١١/٦٣٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٠٩٤٠<span class="dash">-</span></span> عن <span class="name-2">سعيد بن المسيب</span>: أن لقمان كان أسود من سودان مصر، ذا مَشافِر{23}، أعطاه الله الحكمة، ومنعه النبوة{24}. (١١/٦٢٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٠٩٤١<span class="dash">-</span></span> عن عبد الرحمن بن حرملة، قال: جاء أسود يسأل <span class="name-2">سعيدَ بنَ المسيب</span>، فقال له سعيد: لا تحزن مِن أجل أنك أسود، فإنّه كان مِن أخير الناس ثلاثة من السودان: بلال، ومهجع مولى عمر بن الخطاب، ولقمان الحكيم كان أسود نوبيًّا مِن سودان مصر، ذا مشافر{25}. (١١/٦٢٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٠٩٤٢<span class="dash">-</span></span> عن <span class="name-2">سعيد بن المسيب</span> -من طريق علي بن زيد-: أن لقمان كان خياطًا{26}. (١١/٦٢٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٠٩٤٣<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق سعيد الزبيدي- قال: كان لقمان الحكيم عبدًا حبشيًّا، غليظ الشفتين، مصفح{27} القدمين، قاضيًا لبني إسرائيل{28}. (١١/٦٢٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٠٩٤٤<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span>-من طريق الحكم- قال: كان لقمان رجلًا صالحًا، ولم يكن نبيًّا{29}. (١١/٦٢٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٠٩٤٥<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span> -من طريق جابر- قال: كان لقمان نبيًّا{30}. (١١/٦٢٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٠٩٤٦<span class="dash">-</span></span> قال <span class="name-2">وهب بن مُنَبِّه</span>: كان لقمان ابن أخت أيوب{31}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٠٩٤٧<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد بن بشير- قال: كان لقمان رجلًا أفطس، مِن أرض الحبشة{32}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٠٩٤٨<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span>، قال: خيّر الله تعالى لقمان بين الحكمة والنبوة، فاختار الحكمة على النبوة، فأتاه جبريل وهو نائم، فذرَّ عليه الحكمة، فأصبح ينطق بها، فقيل له: كيف اخترت الحكمة على النبوة، وقد خيّرك ربك؟ فقال: إنه لو أرسل إليَّ بالنبوة عزمة لرجوت فيها الفوز منه، ولكنت أرجو أن أقوم بها، ولكنه خيّرني فخفتُ أن أضعف عن النبوة، فكانت الحكمة أحب إليَّ{33}. (١١/٦٢٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٠٩٤٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ذُكر أنّه كان ابن خالة أيوب{31}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٠٩٥٠<span class="dash">-</span></span> قال <span class="name-3">محمد بن إسحاق</span>: هو لقمان بن ناعور بن ناحور بن تارخ، وهو آزر{31}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٠٩٥١<span class="dash">-</span></span> عن <span class="name-3">ليث</span>، قال: كانت حكمة لقمان نبوة{20}. (١١/٦٢٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٠٩٥٢<span class="dash">-</span></span> قال <span class="name-3">الواقدي</span>: كان قاضيًا في بني إسرائيل{37}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٠٩٥٣<span class="dash">-</span></span> عن <span class="name-3">الفضل الرَّقاشي</span>، قال: ما زال لقمانُ يَعِظُ ابنَه حتى انشقت مرارتُه، فمات{38}. (١١/٦٣١)</p></p><p></div></p></div>",footnotes:1:عزاه السيوطي إلى ابن مردويه.أخرجه ابن جرير ١٨/٥٤٦ وزاد: وقال غير أبي بشر: الصواب في غير النبوة.أخرجه ابن جرير ١٨/٥٤٨.أخرجه ابن جرير ١٨/٥٤٩.تفسير مجاهد (٥٤١)، وأخرجه أحمد في الزهد (٤٨-٤٩)، وابن جرير ١٨/٥٤٦. وأخرجه إسحاق البستي في تفسيره ص٨٦ من طريق ابن جريج وزاد: والعفة. وعزاه السيوطي إلى الفريابي، وابن أبي حاتم.أخرجه إسحاق البستي ص٨٦.أخرجه ابن جرير ١٨/٥٤٦، وابن أبي حاتم -كما في تفسير ابن كثير ٦/٣٣٨-.تفسير مقاتل بن سليمان ٣/٤٣٤.عزاه السيوطي إلى ابن مردويه.أخرجه الطبراني في الكبير ١١/١٩٨ (١١٤٨٢)، وابن عساكر في تاريخه ١٠/٤٦٢ (٢٦٦٢)، من طريق عثمان بن عبد الرحمن الطرائفي، عن أبين بن سفيان المقدسي، عن خليفة بن سلام، عن عطاء بن أبي رباح، عن ابن عباس به.</p><p>قال ابن حبان في المجروحين ١/١٧٩-١٨٠ (١١٦): «أبين بن سفيان المقدسي شيخ يقلب الأخبار، وأكثر رواته الضعفاء، يجب التنكب عن أخباره... هذا متن باطل لا أصل له». وقال ابن القيسراني في تذكرة الحفاظ ص١٢(١٣): «وأبين هذا -ابن سفيان- قال ابن حبان: يجب التنكب عن أخباره، وفرق بينه وبين أبان بن سفيان المقدسي، ولا أراهما إلا واحدًا. وأبين مصغر أبان -والله أعلم-، قال البخاري: لا يكتب حديث أبين بن سفيان». وقال ابن الجوزي في الموضوعات ٢/٢٣٢: «هذا حديث لا يصح، والمتهم به أبين». وقال ابن كثير في البداية ٣/١٦: «هذا حديث غريب، بل منكر». وقال الهيثمي في المجمع ٤/٢٣٥-٢٣٦ (٧٢٠٩): «فيه أبين بن سفيان، وهو ضعيف». وقال ابن عراق في تنزيه الشريعة ٢/٣٣ (٢٠): «من حديث ابن عباس، من طريق أبين بن سفيان وعثمان الطرايفي (تعقب) بأن الطرايفي وثق كما مر، وللحديث شاهد من حديث واثلة مرفوعًا: «<b>خير السودان: لقمان، وبلال، ومهجع مولى رسول الله</b>». أخرجه الحاكم في المستدرك وصحح إسناده، ومن حديث عبد الرحمن بن جابر مرسلًا: «<b>سادة السودان أربعة: لقمان الحبشي، والنجاشي، وبلال، ومهجع</b>». أخرجه ابن عساكر. وقال الفتني في تذكرة الموضوعات ص١١٣-١١٤:»فيه عثمان الطرائفي لا يحتج به عن أبين، لا يكتب حديثه. قلت: عثمان صدقه أبو حاتم، وللحديث شاهدان«. وقال المناوي في التيسير ١/٢٣:»ضعيف لضعف عثمان الطرائفي«. وقال في فيض القدير ١/١١١ (١٠٠):»إن سلم عدم وضعه فهو شديد الضعف جِدًّا«. وقال المغربي في جمع الفوائد ٢/٢٦٩ (٥٠١٦):»للكبير بضعف«. وقال الألباني في الضعيفة ٢/١٣١ (٦٨٧):»ضعيف جِدًّا".صَمْصامة: الشَّديد الصُلب. اللسان (صمم).أخرجه ابن عساكر في تاريخه ١٧/٨٥-٨٦ مطولًا، من طريق نوفل بن سليمان الهناني، عن عبيد الله بن عمر، عن نافع، عن ابن عمر به. وأورده الديلمي في مسند الفردوس ٣/٤٥٠ (٥٣٨٤)، والثعلبي ٧/٣١٢.</p><p>قال ابن عراق في تنزيه الشريعة ١/٢٤٤: «وفيه نوفل بن سليمان الهنائي».التقنُّع بقاف ونون ثقيلة: تغطية الرأس وأكثر الوجه برداء أو غيره. فتح الباري ١٠/٢٧٤.أخرجه الحاكم ٢/٤٤٦(٣٥٤٣)، وابن أبي حاتم – كما في تفسير ابن كثير ٦/٣٤٠.</p><p>قال الحاكم: «هذا متن شاهده إسناد صحيح والله أعلم». وقال الذهبي في التلخيص: «صحيح». وقال الشوكاني في فتح القدير ٤/٢٧٦: «وقد ذكر جماعة من أهل الحديث روايات عن جماعة من الصحابة، والتابعين تتضمن كلمات من مواعظ لقمان، وحكمه، ولم يصح عن رسول الله ﷺ من ذلك شيء، ولا ثبت إسناد صحيح إلى لقمان بشيء منها حتى نقبله».أورده الحكيم الترمذي في نوادر الأصول ١/٣٧٣-٣٧٤ دون ذكر الراوي.</p><p>وورد الحديث من طريق ابن عمر، أخرجه ابن عساكر في تاريخه ١٧/٨٥، قال ابن عراق في تنزيه الشريعة ١/٢٤٤: «وفيه نوفل بن سليمان الهنائي».أخرجه ابن عساكر في تاريخه ١٠/٤٦٢ (٢٦٦٣)، وهو مرسل.أخرجه ابن أبي حاتم -كما في تفسير ابن كثير ٦/٣٣٧-.عزاه السيوطي إلى ابن أبي شيبة، وابن المنذر.أخرجه ابن جرير ١٨/٥٤٧. وعزاه السيوطي إلى ابن أبي شيبة، وأحمد في الزهد، وابن أبي الدنيا في كتاب المملوكين، وابن المنذر، وابن أبي حاتم.عزاه السيوطي إلى ابن أبي حاتم.رَحْبُ الذراعين: واسع القوة والقدرة والبطش. النهاية (ذرع) و(رحب).أخرجه ابن أبي شيبة ١٣/٢١٣-٢١٤ مختصرًا. وعزاه السيوطي إلى أحمد.مَشافِر: جمع مِشْفَر، وهو للبعير: كالشَّفَة للإنسان، وقد يُقال للإنسان مشافر على الاستعارة. اللسان (شفر).عزاه السيوطي إلى ابن جرير، وابن المنذر، وابن أبي حاتم.أخرجه ابن جرير ١٨/٥٤٧، والثعلبي ٧/٣١٣.تفسير مجاهد (٥٤٣)، وأخرجه أحمد في الزهد (٤٩). وعزاه السيوطي إلى ابن أبي شيبة، وابن المنذر.مصفح: عريض. لسان العرب (صفح).أخرجه ابن أبي شيبة ١٣/٢١٣، وأحمد في الزهد (٤٨)، وابن جرير ١٨/٥٤٧، كما أخرجه ابن جرير من طريق الأعمش قريبًا منه. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.أخرجه ابن جرير ١٨/٥٤٦.أخرجه ابن جرير ١٨/٥٤٩، وابن أبي حاتم -كما في تفسير ابن كثير ٦/٣٣٧-.تفسير البغوي ٦/٢٨٦.أخرجه الهذيل بن حبيب -تفسير مقاتل بن سليمان ٣/٤٣٤-.أخرجه ابن أبي حاتم -كما في تفسير ابن كثير ٦/٣٣٧-٣٣٨-.تفسير البغوي ٦/٢٨٦.تفسير البغوي ٦/٢٨٦.عزاه السيوطي إلى ابن أبي حاتم.تفسير الثعلبي ٧/٣١٢، وتفسير البغوي ٦/٢٨٦.عزاه السيوطي إلى ابن أبي الدنيا في نعت الخائفين.</p><p><b>وقد ذكر السيوطي ١١/٦٢٩-٦٤٦ آثارًا كثيرةً مما أُثر من حِكَم لقمان وأخباره.</b>
  31,13,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَإِذۡ قَالَ لُقۡمَـٰنُ لِٱبۡنِهِۦ وَهُوَ یَعِظُهُۥ یَـٰبُنَیَّ لَا تُشۡرِكۡ بِٱللَّهِۖ إِنَّ ٱلشِّرۡكَ لَظُلۡمٌ عَظِیمࣱ ۝١٣﴾</span> - نزول الآية</h3></p><p><div></p><p><p><span class="item-no">٦٠٩٥٤<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن مسعود</span> -من طريق علقمة- قال: لما نزلت: <span class="qpc-hafs">﴿الَّذِينَ آمَنُوا ولَمْ يَلْبِسُوا إيمانَهُمْ بِظُلْمٍ﴾</span> [الأنعام:٨٢] قال أصحابه: وأيُّنا لم يظلِم؟ فنزلت: <span class="qpc-hafs">﴿إنَّ الشِّرْكَ لَظُلْمٌ عَظِيمٌ﴾</span>{1}<span class=comment-ref>٥١٣٤</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٥١٣٤</span> <span class="comment-type-3">قوّى</span> <u>ابنُ عطية</u> (٧/٤٦) <span class="mustanad">بهذا الأثر</span> أن قوله تعالى: <span class="qpc-hafs">﴿إن الشرك لظلم عظيم﴾</span> هو من قول الله تعالى، وليس من كلام لقمان ﵇، فقال: «وظاهر قوله: <span class="qpc-hafs">﴿إنَّ الشِّرْكَ لَظُلْمٌ عَظِيمٌ﴾</span> أنه من كلام لقمان، ويحتمل أن يكون خبرًا من الله تعالى منقطعًا من كلام لقمان، متصلًا به في تأكيد المعنى، ويؤيد هذا الحديث المأثور أنه لما نزلت: <span class="qpc-hafs">﴿ولَمْ يَلْبِسُوا إيمانَهُمْ بِظُلْمٍ﴾</span> أشفق أصحاب رسول الله ﷺ، وقالوا: أينا لم يظلم نفسه؟ فأنزل الله تعالى: <span class="qpc-hafs">﴿إنَّ الشِّرْكَ لَظُلْمٌ عَظِيمٌ﴾</span> فسكن إشفاقهم. وإنما يسكن إشفاقهم بأن يكون ذلك خبرًا من الله تعالى، وقد يسكن الإشفاق بأن يذكر الله ذلك عن عبدٍ قد وصفه بالحكمة والسداد».</div></p><p><h3><span class="qpc-hafs">﴿وَإِذۡ قَالَ لُقۡمَـٰنُ لِٱبۡنِهِۦ وَهُوَ یَعِظُهُۥ یَـٰبُنَیَّ لَا تُشۡرِكۡ بِٱللَّهِۖ إِنَّ ٱلشِّرۡكَ لَظُلۡمٌ عَظِیمࣱ ۝١٣﴾</span> - تفسير الآية</h3></p><p><div></p><p><p><span class="item-no">٦٠٩٥٥<span class="dash">-</span></span> قال <span class="name-2">الحسن البصري</span>: <span class="qpc-hafs">﴿لَظُلْمٌ عَظِيمٌ﴾</span> يُنقِص به نفسه{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٠٩٥٦<span class="dash">-</span></span> قال <span class="name-2">إسماعيل السُّدِّيّ</span>: <span class="qpc-hafs">﴿لَظُلْمٌ عَظِيمٌ﴾</span> لذنب عظيم{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٠٩٥٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وإذْ قالَ لُقْمانُ لِابْنِهِ﴾</span> واسم ابنه: أنعم <span class="qpc-hafs">﴿وهُوَ يَعِظُهُ﴾</span> يعني: يُؤَدِّبه: <span class="qpc-hafs">﴿يا بُنَيَّ لا تُشْرِكْ بِاللَّهِ﴾</span> معه غيره؛ <span class="qpc-hafs">﴿إنَّ الشِّرْكَ لَظُلْمٌ عَظِيمٌ﴾</span> كان ابنه وامرأتُه كفّارًا، فما زال بهما حتى أسلما. وزعموا: أنّ لقمان كان ابن خالة أيوب ﵇{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٠٩٥٨<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿وإذْ قالَ لُقْمانُ لِابْنِهِ وهُوَ يَعِظُهُ يا بُنَيَّ لا تُشْرِكْ بِاللَّهِ إنَّ الشِّرْكَ لَظُلْمٌ عَظِيمٌ﴾</span> يظلم المشركُ به نفسَه، ويَضُرُّ به نفسَه{5}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَإِذۡ قَالَ لُقۡمَـٰنُ لِٱبۡنِهِۦ وَهُوَ یَعِظُهُۥ یَـٰبُنَیَّ لَا تُشۡرِكۡ بِٱللَّهِۖ إِنَّ ٱلشِّرۡكَ لَظُلۡمٌ عَظِیمࣱ ۝١٣﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٦٠٩٥٩<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span>، قال: قال الله ﷿: يا ابن آدم، خلقتُك وتعبدُ غيري! وتدعو إليَّ وتفرُّ مني! وتُذكّر بي وتنساني! هذا أظلم ظلم في الأرض. ثم يتلو <span class="name-2">الحسن</span>: <span class="qpc-hafs">﴿إنَّ الشِّرْكَ لَظُلْمٌ عَظِيمٌ﴾</span>{6}. (١١/٦٤٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٠٩٦٠<span class="dash">-</span></span> عن الحسن، قال: قال النبي ﷺ: «<b>الظلم ثلاثة: فظلم لا يغفره الله تبارك وتعالى، وظلم يغفره الله، وظلم لا يدعه الله؛ فأما الظلم الذي لا يغفره الله فالإشراك، وأما الظلم الذي يغفره الله فذنوب العباد فيما بينهم وبين الله، وأما الظلم الذي لا يدعه الله فظلم العباد بعضُهم بعضًا، لا يدعه الله حتى يقص بعضهم من بعض</b>»{7}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه البخاري ٦/٥٦-٥٧ (٤٦٢٩)، ٤/١٦٣ (٣٤٢٨)، ويحيى بن سلّام ٢/٦٧٣.</p><p>كما أخرجه البخاري في مواضع أخرى دون قوله: «فنزلت» ١/١٥-١٦ (٣٢)، ٤/١٤١ (٣٣٦٠)، ٦/١١٥ (٤٧٧٦)، ٩/١٣ (٦٩١٨)، ٩/١٨ (٦٩٣٧)، وكذلك مسلم ١/١١٤ (١٢٤).علقه يحيى بن سلّام ٢/٦٧٣.علقه يحيى بن سلّام ٢/٦٧٣.تفسير مقاتل بن سليمان ٣/٤٣٤.تفسير يحيى بن سلّام ٢/٦٧٣.أخرجه عبد الله بن أحمد في زوائد الزهد (٨٥).أخرجه معمر بن راشد في جامعه ١١/١٨٣ (٢٠٢٧٦)، ويحيى بن سلّام ٢/٦٧٣-٦٧٤ مرسلًا.
  31,14,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَوَصَّیۡنَا ٱلۡإِنسَـٰنَ بِوَ ٰ⁠لِدَیۡهِ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٠٩٦١<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span>: <span class="qpc-hafs">﴿ووَصَّيْنا الإنْسانَ بِوالِدَيْهِ﴾</span>، يعني: بِرًّا بوالديه{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٠٩٦٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ووَصَّيْنا الإنْسانَ﴾</span> سعد بن أبي وقاص <span class="qpc-hafs">﴿بِوالِدَيْهِ﴾</span> يعني: أباه اسمه مالك، وأمه حمنة بنت سفيان بن أمية بن عبد شمس بن عبد مناف{2}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿حَمَلَتۡهُ أُمُّهُۥ وَهۡنًا عَلَىٰ وَهۡنࣲ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٠٩٦٣<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطية العوفي- في قوله: <span class="qpc-hafs">﴿وهْنًا عَلى وهْنٍ﴾</span>، قال: شِدَّة بعد شدة، وخَلْقًا بعد خَلْق{3}. (١١/٦٤٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٠٩٦٤<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿وهْنًا عَلى وهْنٍ﴾</span>، قال: مشقة، وهو الولد{4}. (١١/٦٤٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٠٩٦٥<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿وهْنًا﴾</span> قال: وهن الولد <span class="qpc-hafs">﴿عَلى وهْنٍ﴾</span> قال: الوالدة وضعفها{5}. (١١/٦٤٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٠٩٦٦<span class="dash">-</span></span> تفسير <span class="name-2">مجاهد بن جبر</span> -في حديث عاصم بن حكيم- <span class="qpc-hafs">﴿وهْنًا عَلى وهْنٍ﴾</span>: وهن الولد على وهن الولد{6}<span class=comment-ref>٥١٣٥</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٥١٣٥</span> <span class="comment-type-4">قال</span> <u>ابنُ عطية</u> (٧/٤٧): «<span class="qpc-hafs">﴿وهْنًا عَلى وهْنٍ﴾</span> معناه: ضعفًا على ضعف. وقيل: إشارة إلى مشقة الحمل، ومشقة الولادة بعده. وقيل: إشارة إلى ضعف الولد، وضعف الأم معه. ويحتمل أنه أشار إلى تدرج حالها في زيادة الضعف، كأنه لم يُعَيِّن ضعفين، بل كأنه قال: حملته أمه، والضعف يتزيد بعد الضعف إلى أن ينقضي أمدُه».</div></p><p><div></p><p><p><span class="item-no">٦٠٩٦٧<span class="dash">-</span></span> عن <span class="name-2">الضحاك بن مزاحم</span> -من طريق عبيد- في قوله: <span class="qpc-hafs">﴿وهْنًا عَلى وهْنٍ﴾</span>، يقول: ضعفًا على ضعف{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٠٩٦٨<span class="dash">-</span></span> قال <span class="name-2">الحسن البصري</span>: <span class="qpc-hafs">﴿حَمَلَتْهُ أُمُّهُ وهْنًا عَلى وهْنٍ﴾</span> ضعفًا على ضعف{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٠٩٦٩<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿حَمَلَتْهُ أُمُّهُ وهْنًا عَلى وهْنٍ﴾</span>: أي: جَهْدًا على جَهْد{9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٠٩٧٠<span class="dash">-</span></span> عن <span class="name-2">عطاء الخراساني</span>، في قوله: <span class="qpc-hafs">﴿وهْنًا عَلى وهْنٍ﴾</span>، قال: ضعفًا على ضعف{10}. (١١/٦٤٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٠٩٧١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿حَمَلَتْهُ أُمُّهُ وهْنًا عَلى وهْنٍ﴾</span>، يعني: ضَعفًا على ضعف{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٠٩٧٢<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿وهْنًا عَلى وهْنٍ﴾</span>، والوهن: الضَّعْف{12}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَفِصَـٰلُهُۥ فِی عَامَیۡنِ أَنِ ٱشۡكُرۡ لِی وَلِوَ ٰ⁠لِدَیۡكَ إِلَیَّ ٱلۡمَصِیرُ ۝١٤﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٠٩٧٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وفِصالُهُ فِي عامَيْن أنِ اشْكُرْ لِي﴾</span> يعني: لله ﷿ أن هداه للإسلام، <span class="qpc-hafs">﴿و﴾</span> اشكر <span class="qpc-hafs">﴿لِوالِدَيْكَ﴾</span> النِّعَم فيما أوْلَياك، <span class="qpc-hafs">﴿إلَيَّ المَصِيرُ﴾</span> فأجزيك بعملك{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٠٩٧٤<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿وفِصالُهُ﴾</span> أي: وفطامه <span class="qpc-hafs">﴿فِي عامَيْنِ أنِ اشْكُرْ لِي ولِوالِدَيْكَ إلَيَّ المَصِيرُ﴾</span> البعث{12}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَفِصَـٰلُهُۥ فِی عَامَیۡنِ أَنِ ٱشۡكُرۡ لِی وَلِوَ ٰ⁠لِدَیۡكَ إِلَیَّ ٱلۡمَصِیرُ ۝١٤﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٦٠٩٧٥<span class="dash">-</span></span> عن <span class="name-3">سفيان بن عيينة</span> -من طريق نصير بن يحيى- قال: مَن صلّى الصلوات الخمس فقد شكر الله، ومَن دعا للوالدين في أدبار الصلوات فقد شَكَر للوالدين{15}. (ز)</p></p><p></div></p></div>",footnotes:1:علَّقه يحيى بن سلّام ٢/٦٧٤.تفسير مقاتل بن سليمان ٣/٤٣٤.أخرجه ابن جرير ١٨/٥٥٠.تفسير مجاهد (٥٤١). وعزاه السيوطي إلى الفريابي، وابن أبي شيبة، وابن جرير، وابن المنذر، وابن أبي حاتم.أخرجه ابن جرير ١٨/٥٥١، كما أخرجه يحيى بن سلّام ٢/٦٧٤، من طريق ابن مجاهد. وعزاه السيوطي إلى ابن أبي حاتم.تفسير يحيى بن سلّام ٢/٦٧٤، وكذا وقع فيه تفسير مجاهد، ولعله: وهن الولد على وهن الوالدة. كما في طريق ابن أبي نجيح.أخرجه ابن جرير ١٨/٥٥٠.علَّقه يحيى بن سلّام ٢/٦٧٤.أخرجه ابن جرير ١٨/٥٥٦. وعلقه يحيى بن سلّام ٢/٦٧٤.عزاه السيوطي إلى ابن أبي حاتم.تفسير مقاتل بن سليمان ٣/٤٣٤.تفسير يحيى بن سلّام ٢/٦٧٤.تفسير مقاتل بن سليمان ٣/٤٣٤.تفسير يحيى بن سلّام ٢/٦٧٤.أخرجه الثعلبي ٧/٣١٣، تفسير البغوي ٦/٢٨٧.
  31,15,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَإِن جَـٰهَدَاكَ عَلَىٰۤ أَن تُشۡرِكَ بِی مَا لَیۡسَ لَكَ بِهِۦ عِلۡمࣱ فَلَا تُطِعۡهُمَاۖ وَصَاحِبۡهُمَا فِی ٱلدُّنۡیَا مَعۡرُوفࣰاۖ وَٱتَّبِعۡ سَبِیلَ مَنۡ أَنَابَ إِلَیَّۚ ثُمَّ إِلَیَّ مَرۡجِعُكُمۡ فَأُنَبِّئُكُم بِمَا كُنتُمۡ تَعۡمَلُونَ ۝١٥﴾</span> - نزول الآية</h3></p><p><div></p><p><p><span class="item-no">٦٠٩٧٦<span class="dash">-</span></span> عن <span class="name-1">سعد بن أبي وقاص</span>، قال: نزلت فِيَّ أربع آيات: الأنفال، و<span class="qpc-hafs">﴿صاحِبْهُما فِي الدُّنْيا مَعْرُوفًا﴾</span>، والوصية، والخمر{1}. (١١/٦٤٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٠٩٧٧<span class="dash">-</span></span> عن <span class="name-1">سعد بن أبي وقاص</span> -من طريق مصعب- قال: نزلت فِيَّ هذه الآية: <span class="qpc-hafs">﴿وإنْ جاهَداكَ عَلى أنْ تُشْرِكَ بِي ما لَيْسَ لَكَ بِهِ عِلْمٌ فَلا تُطِعْهُما وصاحِبْهُما فِي الدُّنْيا مَعْرُوفًا﴾</span>، كُنتُ رجلًا بَرًّا بأمي، فلمّا أسلمتُ قالتْ: يا سعد، ما هذا الذي أراك قد أحدثتَ؟! لَتَدَعَنَّ دينك هذا أو لا آكل ولا أشرب حتى أموت فتُعَيَّر بي، فيُقال: يا قاتلَ أُمِّه. قلتُ: لا تفعلي، يا أُمَّه؛ فإنِّي لا أدعُ ديني هذا لشيء. فمكثتْ يومًا آخر وليلة لا تأكل، فأصبحتْ قد جهدتْ، فمكثت يومًا آخر وليلة لا تأكل، فأصبحت وقد اشتد جهدُها، فلما رأيتُ ذلك قلتُ: يا أُمَّه، تعلمين -واللهِ- لو كانت لك مائة نفس، فخرجت نفسًا نفسًا، ما تركت ديني هذا لشيء، فإن شئتِ فكلي، وإن شئت فلا تأكلي. فلمّا رأت ذلك أكلت؛ فنزلت هذه الآية{2}. (١١/٦٤٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٠٩٧٨<span class="dash">-</span></span> عن سعد بن أبي وقاص -من طريق عامر- قال: جئتُ من الرَّمْيِ، فإذا الناس مجتمعون على أُمِّي حمنة بنت سفيان بن أمية بن عبد شمس، وعلى أخي عامر حين أسلم، فقلت: ما شأنُ الناس؟ قالوا: هذه أمك قد أخذت أخاك عامرًا تعطي الله عهدًا أن لا يُظلّها ظِلٌّ، ولا تأكل طعامًا، ولا تشرب شرابًا؛ حتى يدع الصباوة. فأقبل سعد حتى تخلص إليها، فقال: عَليَّ -يا أُمَّه- فاحلفي. قالت: لِمَ؟ قال: لِئَّلا تَسْتَظِلِّي في ظلٍّ، ولا تأكلي طعامًا، ولا تشربي شرابًا، حتى تري مقعدك من النار. فقالت: إنما أحلف على ابني البَرِّ. فأنزل الله: <span class="qpc-hafs">﴿وإنْ جاهَداكَ عَلى أنْ تُشْرِكَ بِي ما لَيْسَ لَكَ بِهِ عِلْمٌ فَلا تُطِعْهُما وصاحِبْهُما فِي الدُّنْيا مَعْرُوفًا﴾</span> إلى آخر الآية{3}. (١١/٦٤٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٠٩٧٩<span class="dash">-</span></span> عن أبي هريرة -من طريق أبي إسحاق- قال: نزلت هذه الآية في سعد بن أبي وقاص: <span class="qpc-hafs">﴿وإنْ جاهَداكَ عَلى أنْ تُشْرِكَ بِي﴾</span> الآية{4}. (١/٦٤٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٠٩٨٠<span class="dash">-</span></span> عن مصعب بن سعد -من طريق سماك ابن حرب- قال: حلفتْ أمُّ سعد أن لا تأكل ولا تشرب حتى يتحول سعدٌ عن دينه. قال: فأبى عليها، فلم تزل كذلك حتى غشي عليها. قال: فأتاها بنوها، فَسَقوها. قال: فلمّا أفاقت دعت الله عليه؛ فنزلت هذه الآية: <span class="qpc-hafs">﴿ووَصَّيْنا الإنْسانَ بِوالِدَيْهِ﴾</span> إلى قوله: <span class="qpc-hafs">﴿فِي الدُّنْيا مَعْرُوفًا﴾</span>{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٠٩٨١<span class="dash">-</span></span> عن هبيرة -من طريق أبي إسحاق- قال: نزلت هذه الآية في سعد بن أبي وقاص: <span class="qpc-hafs">﴿وإنْ جاهَداكَ عَلى أنْ تُشْرِكَ بِي ما لَيْسَ لَكَ بِهِ عِلْمٌ فَلا تُطِعْهُما﴾</span> الآية{6}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَإِن جَـٰهَدَاكَ عَلَىٰۤ أَن تُشۡرِكَ بِی مَا لَیۡسَ لَكَ بِهِۦ عِلۡمࣱ فَلَا تُطِعۡهُمَاۖ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٠٩٨٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وإنْ جاهَداكَ عَلى أنْ تُشْرِكَ بِي ما لَيْسَ لَكَ بِهِ عِلْمٌ﴾</span> لا تعلم بأنّ معي شريكًا؛ <span class="qpc-hafs">﴿فَلا تُطِعْهُما﴾</span> في الشِّرْك{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٠٩٨٣<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿وإنْ جاهَداكَ﴾</span> يعني: أراداك <span class="qpc-hafs">﴿عَلى أنْ تُشْرِكَ بِي ما لَيْسَ لَكَ بِهِ عِلْمٌ﴾</span> أي: أنّك لا تعلم أنّ لي شريكًا، يعني: المؤمن{8}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَإِن جَـٰهَدَاكَ عَلَىٰۤ أَن تُشۡرِكَ بِی مَا لَیۡسَ لَكَ بِهِۦ عِلۡمࣱ فَلَا تُطِعۡهُمَاۖ﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٦٠٩٨٤<span class="dash">-</span></span> عن <span class="name-2">ميمون بن مهران</span> -من طريق جعفر بن برقان- قال: ثلاثٌ المؤمنُ والكافرُ فيهن سواء: الأمانة تؤديها إلى مَن ائتمنك [عليها] من مسلم وكافر، وبِرُّ الوالدين؛ قال الله تعالى: <span class="qpc-hafs">﴿وإن جاهداك على أن تشرك بي ما ليس لك به علم فلا تطعهما﴾</span> الآية، والعهدُ تَفِي به لِمَن عاهدت مِن مسلم أو كافر{9}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَصَاحِبۡهُمَا فِی ٱلدُّنۡیَا مَعۡرُوفࣰاۖ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٠٩٨٥<span class="dash">-</span></span> عن <span class="name-2">قتادة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿وصاحِبْهُما فِي الدُّنْيا مَعْرُوفًا﴾</span>، قال: تَعُودُهما إذا مرِضا، وتتبعهما إذا ماتا، وتُواسِيهما مِمّا أعطاك الله{10}. (١١/٦٤٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٠٩٨٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وصاحِبْهُما فِي الدُّنْيا مَعْرُوفًا﴾</span>، يعني: بإحسان{7}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَٱتَّبِعۡ سَبِیلَ مَنۡ أَنَابَ إِلَیَّۚ ثُمَّ إِلَیَّ مَرۡجِعُكُمۡ فَأُنَبِّئُكُم بِمَا كُنتُمۡ تَعۡمَلُونَ ۝١٥﴾</span> - نزول الآية، وتفسيرها</h3></p><p><div></p><p><p><span class="item-no">٦٠٩٨٧<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطاء- قال: يريد: أبا بكر، وذلك أنه حين أسلم أتاه عبدُ الرحمن بن عوف، وسعدُ بن أبي وقاص، وسعيد بن زيد، وعثمان، وطلحة، والزبير، فقالوا لأبي بكر ﵁: آمنتَ وصدّقتَ محمدًا عليه الصلاة والسلام؟ فقال أبو بكر: نعم. فأتوا رسول الله ﷺ، فآمنوا وصدّقوا؛ فأنزل الله تعالى يقول لسعد: <span class="qpc-hafs">﴿واتَّبِعْ سَبِيلَ مَن أنابَ إلَيَّ﴾</span>، يعني: أبا بكر ﵁{12}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٠٩٨٨<span class="dash">-</span></span> عن <span class="name-2">قتادة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿واتَّبِعْ سَبِيلَ مَن أنابَ إلَيَّ﴾</span>، قال: مَن أقبل إلَيَّ{13}. (١١/٦٤٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٠٩٨٩<span class="dash">-</span></span> عن <span class="name-3">عبد الملك ابن جُرَيج</span>، في قوله: <span class="qpc-hafs">﴿واتَّبِعْ سَبِيلَ مَن أنابَ إلَيَّ﴾</span>، قال: محمد ﷺ{14}. (١١/٦٤٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٠٩٩٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿واتَّبِعْ سَبِيلَ مَن أنابَ إلَيَّ﴾</span> يعني: دين مَن أقبل إلَيَّ، يعني: النبي ﷺ، <span class="qpc-hafs">﴿ثُمَّ إلَيَّ مَرْجِعُكُمْ﴾</span> في الآخرة <span class="qpc-hafs">﴿فَأُنَبِّئُكُمْ بِما كُنْتُمْ تَعْمَلُونَ﴾</span>{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٠٩٩١<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿واتَّبِعْ سَبِيلَ﴾</span> أي: طريق <span class="qpc-hafs">﴿مَن أنابَ إلَيَّ﴾</span> مَن أقبل إلَيَّ بقلبه مُخلِصًا، يعني: النبي ﷺ والمؤمنين، <span class="qpc-hafs">﴿ثُمَّ إلَيَّ مَرْجِعُكُمْ﴾</span> يوم القيامة <span class="qpc-hafs">﴿فَأُنَبِّئُكُمْ بِما كُنْتُمْ تَعْمَلُونَ﴾</span>{8}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه مسلم ٣/١٣٦٧ (١٧٤٨)، وابن عساكر ٢٠/٣٣١ واللفظ له.أخرجه ابن عساكر ٢٠/٣٣٠-٣٣١، والواحدي في أسباب النزول ص٣٤١-٣٤٢، وفي التفسير الوسيط ٣/٤١٤ من طريق أحمد بن أيوب بن راشد الضبي، عن مسلمة بن علقمة، عن داود بن أبي هند، عن أبي عثمان النهدي، عن سعد بن مالك به.</p><p>وسنده ضعيف؛ فيه أحمد بن أيوب بن راشد الضبي، قال عنه ابن حجر في تقريب التهذيب (١١): «مقبول».أخرجه ابن سعد في الطبقات الكبرى ٤/١٢٣-١٢٤، وابن عساكر في تاريخ دمشق ٢٦/٩٥، من طريق محمد بن عمر، عن عبد الله بن جعفر، عن إسماعيل بن محمد بن سعد، عن عامر بن سعد، عن أبيه به.</p><p>وسنده ضعيف جدًّا؛ فيه محمد بن عمر الواقدي، قال عنه ابن حجر في تقريب التهذيب (٦١٧٥): «متروك مع سعة علمه».روي نحوه من حديث أبي هبيرة، أخرجه ابن جرير ١٨/٥٥٣ من طريق ابن المثنى، عن محمد بن جعفر، عن شعبة، عن أبي إسحاق، عن أبي هبيرة به.</p><p>وسنده صحيح.أخرجه ابن جرير ١٨/٥٥٢، وهذا لفظ آخر: قال: قالت أم سعد لسعد: أليس الله قد أمر بالبر، فواللهِ لا أطعم طعامًا، ولا أشرب شرابًا حتى أموت أو تكفر. قال: فكانوا إذا أرادوا أن يطعموها شَجَروا فاها بعصا، ثم أوجروها؛ فنزلت هذه الآية: <span class="qpc-hafs">﴿ووَصَّيْنا الإنْسانَ بِوالِدَيْهِ﴾</span>.أخرجه ابن جرير ١٨/٥٥٣.تفسير مقاتل بن سليمان ٣/٤٣٤.تفسير يحيى بن سلّام ٢/٦٧٤-٦٧٥.أخرجه أبو نعيم في حلية الأولياء ٤/٨٧.عزاه السيوطي إلى ابن جرير، وابن أبي حاتم.تفسير مقاتل بن سليمان ٣/٤٣٤.أورده الواحدي في أسباب النزول ص٣٤٦، والبغوي ٦/٢٨٨.أخرجه ابن جرير ١٨/٥٥٤. وعزاه السيوطي إلى ابن أبي حاتم.عزاه السيوطي إلى ابن المنذر.تفسير مقاتل بن سليمان ٣/٤٣٤.تفسير يحيى بن سلّام ٢/٦٧٤-٦٧٥.
  31,16,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿یَـٰبُنَیَّ إِنَّهَاۤ إِن تَكُ مِثۡقَالَ حَبَّةࣲ مِّنۡ خَرۡدَلࣲ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٠٩٩٢<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿إنها إنْ تَكُ مِثْقالَ حَبَّةٍ مِن خَرْدَلٍ﴾</span>، قال: مِن خير أو شر{1}<span class=comment-ref>٥١٣٦</span>. (١١/٦٤٩)</p></p><p></div></p><p><div><span class=comment-ref>٥١٣٦</span> <span class="comment-type-4">قال</span> <u>ابن عطية</u> (٧/٤٩-٥٠): «وقوله:<span class="qpc-hafs">﴿مِثْقالَ حَبَّةٍ﴾</span> عبارة تصلح للجواهر، أي قدر حبة، وتصلح للأعمال، أي ما زنته على جهة المماثلة قدر حبة، <b>فظاهر الآية</b> أنه أراد شيئًا من الأشياء خفيًا قدر حبة، <span class="mustanad">ويؤيد ذلك</span> ما روي من أن ابن لقمان سأل أباه عن الحبة تقع في مثل البحر، أيعلمها الله؟ فراجعه لقمان بهذه الآية. <b>وذكر كثير من المفسرين</b> أنه أراد الأعمال المعاصي والطاعات، <span class="mustanad">ويؤيد ذلك</span> قوله: <span class="qpc-hafs">﴿يَأْتِ بِها اللَّهُ﴾</span> أي: لا تفوت، وبهذا المعنى يتحصل في الموعظة ترجية وتخويف. فيضاف ذلك إلى تبيين قدرة الله تعالى، وفي القول الآخر ليس ترجية ولا تخويف. ومما يؤيد قول من قال: هي من الجواهر <span class="mustanad">قراءة عبد الكريم الجزري</span>»فتكِنّ«بكسر الكاف وشد النون من الكِنّ الذي هو الشيء المغطى، وقرأ جمهور القراء»إن تك«بالتاء من فوق،»مثقال«بالنصب على خبر»كان«، واسمها مضمر تقديره: مسألتك، على ما روي، أو المعصية أو الطاعة على القول الثاني».</div></p><p><div></p><p><p><span class="item-no">٦٠٩٩٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: قال ابن لقمان أنعم لأبيه: يا أبتِ، إن عمِلتُ بالخطيئة حيثُ لا يراني أحدٌ كيف يعلمه الله ﷿؟ فردَّ عليه لقمان: <span class="qpc-hafs">﴿يا بُنَيّ إنَّها إنْ تَكُ مِثْقالَ حَبَّةٍ﴾</span>، يعني: وزن ذَرَّة{2}<span class=comment-ref>٥١٣٧</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٥١٣٧</span> <span class="comment-type-4">ذكر</span> <u>ابنُ جرير</u> (١٨/٥٥٤-٥٥٦) في عود الهاء من قوله: <span class="qpc-hafs">﴿إنها﴾</span> <b>قولًا</b> لبعض أهل اللغة البصريين -وهو قول مقاتل-: أنها الخطيئة. وذكر <b>قولًا آخر</b> فقال: «وقال بعض نحويي الكوفة: وهذه الهاء عماد. وقال: أنّث <span class="qpc-hafs">﴿تك﴾</span> لأنه يُراد بها الحبة، فذهب بالتأنيث إليها». ثم <span class="comment-type-3">رجّح</span> <span class="mustanad">مستندًا إلى الدلالة العقلية</span> هذا القول، فقال: «وأولى القولين بالصواب عندي القول الثاني؛ لأن الله -تعالى ذِكْرُه- لم يعد عباده أن يوفيهم جزاء سيئاتهم دون جزاء حسناتهم، فيقال: إنّ المعصية إن تك مثقال حبة من خردل يأتِ الله بها، بل وعد كِلا العاملين أن يوفيه جزاء أعمالهما. فإذا كان ذلك كذلك كانت الهاء في قوله: <span class="qpc-hafs">﴿إنها﴾</span> بأن تكون عمادًا أشبه منها بأن تكون كناية عن الخطيئة والمعصية». واستدل على ذلك بقول قتادة.</p><p>و<span class="comment-type-3">رجّح</span> <u>ابنُ كثير</u> (١١/٥٥) القول الأول بقوله: «والأول أولى». ولم يذكر مستندًا.</div></p><p><div></p><p><p><span class="item-no">٦٠٩٩٤<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿يا بُنَيَّ﴾</span> رجع إلى كلام لقمان، يعني: الكلام الأول: <span class="qpc-hafs">﴿وإذْ قالَ لُقْمانُ لِابْنِه وهُوَ يَعِظُهُ يا بُنَيَّ لا تُشْرِكْ بِاللَّهِ﴾</span> [لقمان:١٣]، <span class="qpc-hafs">﴿إنَّها إنْ تَكُ مِثْقالَ حَبَّةٍ مِن خَرْدَلٍ﴾</span> أي: وزن حبة مِن خردل{3}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿فَتَكُن فِی صَخۡرَةٍ أَوۡ فِی ٱلسَّمَـٰوَ ٰ⁠تِ أَوۡ فِی ٱلۡأَرۡضِ یَأۡتِ بِهَا ٱللَّهُۚ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٠٩٩٥<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن مسعود، وناس من أصحاب النبي</span> ﷺ -من طريق السُّدِّيّ، عن مُرَّة الهمداني-= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٠٩٩٦<span class="dash">-</span></span> و<span class="name-1">عبد الله بن عباس</span> -من طريق السُّدِّيّ، عن أبي مالك وأبي صالح-: قال: خلق الله الأرض على حُوت، والحُوت هو النُّون الذي ذكر الله في القرآن: <span class="qpc-hafs">﴿نوَن والقَلَمِ وما يَسْطُرُونَ﴾</span> [القلم:١]، والحوت في الماء، والماء على ظهر صَفاة، والصَّفاة على ظهر مَلَك، والمَلَك على صخرة، والصخرة في الريح، وهي الصخرة التي ذكر لقمان، ليست في السماء ولا في الأرض{4}<span class=comment-ref>٥١٣٨</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٥١٣٨</span> <span class="comment-type-4">علّق</span> <u>ابنُ كثير</u> (١١/٥٥-٥٦) على أثر ابن عباس، فقال: «وهذا -والله أعلم- كأنه مُتَلَقًّى من الإسرائيليات التي لا تُصَدَّق ولا تُكَذَّب. والظاهر -والله أعلم- أنّ المراد: أن هذه الحبة في حقارتها لو كانت داخل صخرة، فإن الله سيبديها ويظهرها بلطيف علمه».</div></p><p><div></p><p><p><span class="item-no">٦٠٩٩٧<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>: <span class="qpc-hafs">﴿فَتَكُنْ فِي صَخْرَةٍ﴾</span> في صخرة تحت الأرضين السبع، وهي التي تُكتب فيها أعمال الفجار، وخضرة السماء منها{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٠٩٩٨<span class="dash">-</span></span> عن <span class="name-2">عبد الله بن الحارث</span> – من طريق المنهال-، قال: الصخرة خضراء على ظهر حوت{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٠٩٩٩<span class="dash">-</span></span> عن <span class="name-2">أبي مالك [الغفاري]</span> -من طريق السُّدِّيّ- <span class="qpc-hafs">﴿يَأْتِ بِها اللَّهُ﴾</span>، قال: يعلمها اللهُ{7}<span class=comment-ref>٥١٣٩</span>. (١١/٦٥٠)</p></p><p></div></p><p><div><span class=comment-ref>٥١٣٩</span> <span class="comment-type-4">علّق</span> <u>ابنُ جرير</u> (١٨/٥٥٧) على هذا القول، فقال: «ولا أعرف»يأتي به«بمعنى: يعلمه، إلا أن يكون قائل ذلك أراد أن لقمان إنما وصف الله بذلك؛ لأن الله يعلم أماكنه، لا يخفى عليه مكان شيء منه؛ فيكون وجهًا».</div></p><p><div></p><p><p><span class="item-no">٦١٠٠٠<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿فَتَكُنْ فِي صَخْرَةٍ﴾</span>، قال: في جبل{8}. (١١/٦٤٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦١٠٠١<span class="dash">-</span></span> عن <span class="name-3">محمد بن السائب الكلبي</span> -من طريق معمر- في قوله تعالى: <span class="qpc-hafs">﴿فَتَكُنْ فِي صَخْرَةٍ﴾</span> قال: الصخرة التي الأرض عليها، ثم قال: <span class="qpc-hafs">﴿أوْ فِي السَّماواتِ أوْ فِي الأَرْضِ يَأْتِ بِها اللَّهُ﴾</span> يقول: إن يكن مثقال حبة من خردل مِن خير أو شرٍّ يأتِ بها الله{9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦١٠٠٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فَتَكُنْ فِي صَخْرَةٍ﴾</span> التي في الأرض السفلى، وهي خضراء مجوفة، لها ثلاث شُعَب، على لون السماء <span class="qpc-hafs">﴿أوْ﴾</span> تكن الحبة <span class="qpc-hafs">﴿فِي السَّماواتِ﴾</span> السبع <span class="qpc-hafs">﴿أوْ فِي الأَرْضِ يَأْتِ بِها اللَّهُ﴾</span> يعني: بتلك الحبة{2}<span class=comment-ref>٥١٤٠</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٥١٤٠</span> قال <u>ابنُ عطية</u> (٧/٥١): «وقوله <span class="qpc-hafs">﴿يَأْتِ بِها اللَّهُ﴾</span> إن أراد: الجواهر؛ فالمعنى: يأت بها إن احتيج إلى ذلك، إن كانت رزقًا ونحو هذا. وإن أراد: الأعمال؛ فمعناه: يأت بذكرها وحفظها ليجازي عليها بثواب أو عقاب».</div></p><p><div></p><p><p><span class="item-no">٦١٠٠٣<span class="dash">-</span></span> عن <span class="name-3">سفيان الثوري</span> -من طريق عبد الرزاق- قال: <span class="qpc-hafs">﴿فَتَكُنْ فِي صَخْرَةٍ﴾</span> هي صخرة تحت الأرضين، بلغنا: أنّ خضرة السماء من تلك الصخرة{11}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦١٠٠٤<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿فَتَكُنْ فِي صَخْرَةٍ﴾</span> بلغنا: أنّها الصخرة التي عليها الحوت، التي عليها قرار الأرضين، <span class="qpc-hafs">﴿أوْ فِي السَّماواتِ أوْ فِي الأَرْضِ يَأْتِ بِها اللَّهُ﴾</span>، أي: احذر، فإنّه سيحصي عليك عملك، ويعلمه كما عَلِم هذه الحبة من الخردل. لقمان يقوله لابنه{3}<span class=comment-ref>٥١٤١</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٥١٤١</span> أشار <u>ابنُ عطية</u> (٧/٥٠) إلى نحو ما جاء في قول يحيى بن سلّام وغيره، و<span class="comment-type-2">انتقده</span> فقال: «وقوله: <span class="qpc-hafs">﴿فَتَكُنْ فِي صَخْرَةٍ﴾</span>، قيل: أراد: الصخرة التي عليها الأرض والحوت والماء، وهي على ظهر ملك. وقيل: هي صخرة في الريح. وهذا كله ضعيف لا يثبته سند، وإنما معنى الكلام المبالغة والانتهاء في التفهيم، أي: أن قدرته تنال ما يكون في تضاعيف صخرة، وما يكون في السماء وفي الأرض».</div></p><p><h3><span class="qpc-hafs">﴿إِنَّ ٱللَّهَ لَطِیفٌ خَبِیرࣱ ۝١٦﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦١٠٠٥<span class="dash">-</span></span> عن <span class="name-2">أبي العالية الرِّياحي</span> -من طريق الربيع- قال: <span class="qpc-hafs">﴿إنْ تَكُ مِثْقالَ حَبَّةٍ مِن خَرْدَلٍ فَتَكُنْ فِي صَخْرَةٍ أوْ فِي السَّمَواتِ أوْ فِي الأَرْضِ يَأْتِ بِها اللَّهُ إنَّ اللَّهَ لَطِيفٌ خَبِيرٌ﴾</span>، قال: لطيف باستخراجها، خبير بإتيانها{13}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦١٠٠٦<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿إنَّ اللَّهَ لَطِيفٌ﴾</span> قال: باستخراجها، <span class="qpc-hafs">﴿خَبِير﴾</span> قال: بإتيانها{14}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦١٠٠٧<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿إنَّ اللَّهَ لَطِيفٌ﴾</span> قال: باستخراجها، <span class="qpc-hafs">﴿خَبِير﴾</span> قال: بمستقرها{15}. (١١/٦٤٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦١٠٠٨<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿إنَّ اللَّهَ لَطِيفٌ﴾</span> باستخراجها، <span class="qpc-hafs">﴿خَبِيرٌ﴾</span> بمكانها{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦١٠٠٩<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿إنَّ اللَّهَ لَطِيفٌ﴾</span> باستخراجها، <span class="qpc-hafs">﴿خَبِيرٌ﴾</span> بمكانها{3}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿إِنَّ ٱللَّهَ لَطِیفٌ خَبِیرࣱ ۝١٦﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٦١٠١٠<span class="dash">-</span></span> عن <span class="name-2">علي بن رباح اللخمي</span>: إنّه لَمّا وعظ لقمانُ ابنَه قال: <span class="qpc-hafs">﴿إنها إنْ تَكُ﴾</span> الآية؛ أخذ حبَّةً مِن خردل، فأتى بها إلى اليرموك، فألقاها في عرضه، ثم مكث ما شاء الله، ثم ذكرها، وبسط يده، فأقبل بها ذبابٌ حتّى وضعها في راحته{18}. (١١/٦٣٥)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ١٨/٥٥٦. وعزاه السيوطي إلى ابن أبي حاتم.تفسير مقاتل بن سليمان ٣/٤٣٥.تفسير يحيى بن سلّام ٢/٦٧٥.أخرجه ابن جرير ١٨/٥٦٠. وفي تفسير الثعلبي ٧/٣١٤، وتفسير البغوي ٦/٢٨٨-٢٨٩ بنحوه موقوفًا على السدي.تفسير الثعلبي ٧/٣١٤، وتفسير البغوي ٦/٢٨٨.أخرجه ابن جرير ١٨/٥٥٦.أخرجه ابن جرير ١٨/٥٥٧. وعزاه السيوطي إلى الفريابي.أخرجه ابن جرير ١٨/٥٥٧. وعزاه السيوطي إلى ابن أبي حاتم.أخرجه عبد الرزاق ٢/١٠٥-١٠٦.تفسير مقاتل بن سليمان ٣/٤٣٥.أخرجه عبد الرزاق ٢/١٠٦.تفسير يحيى بن سلّام ٢/٦٧٥.أخرجه آدم بن أبي إياس -كما في تفسير مجاهد (٥٤٢)-. وعلقه يحيى بن سلّام ٢/٦٧٦.تفسير مجاهد (٥٤٢).أخرجه ابن جرير ١٨/٥٥٨. وعزاه السيوطي إلى ابن أبي حاتم.تفسير مقاتل بن سليمان ٣/٤٣٥.تفسير يحيى بن سلّام ٢/٦٧٥.أخرجه عبد الله بن وهب في الجامع- تفسير القرآن ١/٨١-٨٢ (١٨٣). وعزاه السيوطي إلى ابن أبي حاتم.
  31,17,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿یَـٰبُنَیَّ أَقِمِ ٱلصَّلَوٰةَ وَأۡمُرۡ بِٱلۡمَعۡرُوفِ وَٱنۡهَ عَنِ ٱلۡمُنكَرِ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦١٠١١<span class="dash">-</span></span> عن أبي <span class="name-2">العالية الرِّياحي</span> -من طريق الربيع- قال: <span class="qpc-hafs">﴿وأْمُرْ بِالمَعْرُوفِ وانْهَ عَنِ المُنْكَرِ﴾</span> مَن أمَر بعبادة الله، ونَهى عن عبادة الأوثان؛ فقد أمر بالمعروف ونهى عن المنكر{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦١٠١٢<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span>، في قوله: <span class="qpc-hafs">﴿وأْمُرْ بِالمَعْرُوفِ﴾</span> يعني: بالتوحيد، <span class="qpc-hafs">﴿وانه عَنِ المُنْكَرِ﴾</span> يعني: عن الشرك{2}. (١١/٦٥٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦١٠١٣<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span>: <span class="qpc-hafs">﴿يا بُنَيَّ أقِمِ الصَّلاةَ وأْمُرْ بِالمَعْرُوفِ﴾</span>، يعني: بالتوحيد{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦١٠١٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿يا بُنَيَّ أقِم الصَّلاةَ وأْمُرْ بِالمَعْرُوفِ﴾</span> يعني: التوحيد، <span class="qpc-hafs">﴿وانْهَ عَنِ المُنْكَرِ﴾</span> يعني: الشر الذي لا يُعرف{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦١٠١٥<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿وانْهَ عَن المُنْكَرِ﴾</span>، يعني: الشرك بالله{5}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَٱصۡبِرۡ عَلَىٰ مَاۤ أَصَابَكَۖ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦١٠١٦<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span>، في قوله: <span class="qpc-hafs">﴿واصْبِرْ عَلى ما أصابَكَ﴾</span>: في أمرهما. يقول: إذا أمرت بمعروف أو نهيت عن منكر، وأصابك في ذلك أذًى وشدة؛ فاصبِر عليه{2}. (١١/٦٥٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦١٠١٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿واصْبِرْ عَلى ما أصابَكَ﴾</span> فيهما مِن الأذى{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦١٠١٨<span class="dash">-</span></span> عن <span class="name-3">عبد الملك ابن جُرَيج</span> -من طريق حجاج- في قوله: <span class="qpc-hafs">﴿واصْبِرْ عَلى ما أصابَكَ﴾</span>: مِن الأذى في ذلك{8}. (١١/٦٥٠)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿إِنَّ ذَ ٰ⁠لِكَ مِنۡ عَزۡمِ ٱلۡأُمُورِ ۝١٧﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦١٠١٩<span class="dash">-</span></span> قال <span class="name-1">عبد الله بن عباس</span>: <span class="qpc-hafs">﴿مِن عَزْمِ الأُمُورِ﴾</span> حَزْم الأمور{9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦١٠٢٠<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span>، في قوله: <span class="qpc-hafs">﴿إنَّ ذَلِكَ﴾</span>: يعني: هذا الصبر على الأذى في الأمر بالمعروف والنهي عن المنكر <span class="qpc-hafs">﴿مِن عَزْمِ الأُمُورِ﴾</span> يعني: مِن حقِّ الأمور التي أمر الله تعالى{2}. (١١/٦٥٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦١٠٢١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿إنَّ ذَلِكَ مِن عَزْمِ الأُمُورِ﴾</span> إنّ ذلك الصبر على الأذى في الأمر بالمعروف والنهي عن المنكر مِن حقِّ الأمور التي أمر الله ﷿ بها، وعزم عليها{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦١٠٢٢<span class="dash">-</span></span> عن <span class="name-3">عبد الملك ابن جُرَيج</span> -من طريق حجاج- في قوله: <span class="qpc-hafs">﴿إنَّ ذَلِكَ مِن عَزْمِ الأُمُورِ﴾</span>، يقول: مِمّا عزم الله عليه من الأمور، ومِمّا أمر الله به من الأمور{8}. (١١/٦٥٠-٦٥١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦١٠٢٣<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿واصْبِرْ عَلى ما أصابَكَ إنَّ ذَلِكَ مِن عَزْم الأُمُورِ﴾</span> العزم: أن تصبر{5}<span class=comment-ref>٥١٤٢</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٥١٤٢</span> اختلف السلف في قوله:<span class="qpc-hafs">﴿إن ذلك من عزم الأمور﴾</span> على قولين، <b>الأول</b>: أن معناه: ذلك من حزم الأمور. <b>الثاني</b>: أن معناه: ذلك مما عزمه الله وأمر به. وقد <span class="comment-type-3">رجّح</span> <u>ابن عطية</u> (٧/٥١) القول الثاني، ولم يذكر مستندًا.</div></p><p><h3><span class="qpc-hafs">﴿إِنَّ ذَ ٰ⁠لِكَ مِنۡ عَزۡمِ ٱلۡأُمُورِ ۝١٧﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٦١٠٢٤<span class="dash">-</span></span> عن <span class="name-1">عمير بن حبيب</span>، وكانت له صحبة -من طريق أبي جعفر الخطمي- أوصى بنيه، قال: يا بَنِيَّ، إيّاكم ومجالسةَ السفهاء، فإنّ مجالستهم داء، إنّه من يحلم عن السفيه يُسَرُّ بحلمه، ومن يجبه يندم، ومن لا يقرُّ بقليل ما يأتي به السفيه يقرُّ بالكثير، ومن يصبر على ما يكره يدرك ما يحب، وإذا أراد أحدُكم أن يأمر الناس بالمعروف وينهاهم عن المنكر فليوطِّن نفسه على الصبر على الأذى، ولْيَثِقْ بالثواب من الله، ومَن يَثِقْ بالثواب مِن الله لا يجد مسَّ الأذى{14}. (١١/٦٥١)</p></p><p></div></p></div>",footnotes:1:أخرجه آدم بن أبي إياس -كما في تفسير مجاهد (٥٤٢)-. وعلقه يحيى بن سلّام ٢/٦٧٦.عزاه السيوطي إلى ابن أبي حاتم.علَّقه يحيى بن سلّام ٢/٦٧٦.تفسير مقاتل بن سليمان ٣/٤٣٥.تفسير يحيى بن سلّام ٢/٦٧٦.عزاه السيوطي إلى ابن أبي حاتم.تفسير مقاتل بن سليمان ٣/٤٣٥.أخرجه ابن جرير ١٨/٥٥٨. وعزاه السيوطي إلى ابن المنذر.تفسير الثعلبي ٧/٣١٤.عزاه السيوطي إلى ابن أبي حاتم.تفسير مقاتل بن سليمان ٣/٤٣٥.أخرجه ابن جرير ١٨/٥٥٨. وعزاه السيوطي إلى ابن المنذر.تفسير يحيى بن سلّام ٢/٦٧٦.أخرجه ابن أبي شيبة ٨/٤٠٠، وأحمد في الزهد (١٨٦)، والخطيب في تالي التلخيص (١٢٢). وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.
  31,18,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَلَا تُصَعِّرۡ خَدَّكَ لِلنَّاسِ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦١٠٢٥<span class="dash">-</span></span> عن أبي أيوب الأنصاري: أنّ رسول الله ﷺ سُئِل عن قول الله: <span class="qpc-hafs">﴿ولا تُصَعِّرْ خَدَّكَ لِلنّاسِ﴾</span>. قال: «<b>لَيُّ الشِّدْق</b>{1}»{2}. (١١/٦٥١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦١٠٢٦<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- في قوله: <span class="qpc-hafs">﴿ولا تُصَعِّرْ خَدَّكَ لِلنّاسِ﴾</span>، يقول: لا تَتَكَبَّر فتَحْقِر عباد الله، وتُعْرِض عنهم بوجهك إذا كلَّموك{3}. (١١/٦٥٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦١٠٢٧<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، في قوله: <span class="qpc-hafs">﴿ولا تُصَعِّرْ خَدَّكَ لِلنّاسِ﴾</span>، قال: هو الذي إذا سُلِّم عليه لوى عنقَه كالمستكبر{4}. (١١/٦٥٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦١٠٢٨<span class="dash">-</span></span> عن <span class="name-2">أبي العالية</span> -من طريق الربيع بن أنس- في قوله ﷿: <span class="qpc-hafs">﴿ولا تصعر خدك للناس﴾</span>، قال: يكون الغنيُّ والفقيرُ عندك في العلم سواء{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦١٠٢٩<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span>، في قوله: <span class="qpc-hafs">﴿ولا تُصَعِّرْ خَدَّكَ لِلنّاسِ﴾</span>، يقول: لا تُعرِض بوجهك عن فقراء الناس تكبُّرًا{6}. (١١/٦٥٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦١٠٣٠<span class="dash">-</span></span> عن <span class="name-2">إبراهيم النخعي</span> -من طريق مغيرة، ومنصور- قال: <span class="qpc-hafs">﴿ولا تُصَعِّرْ خَدَّكَ لِلنّاسِ﴾</span> هو التَّشْدِيق{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦١٠٣١<span class="dash">-</span></span> عن <span class="name-2">يزيد بن الأصم</span> -من طريق جعفر بن برقان- في هذه الآية: <span class="qpc-hafs">﴿ولا تُصَعِّرْ خَدَّكَ لِلنّاسِ﴾</span>، قال: إذا كلَّمك الإنسانُ لَوَيْت وجهك، وأعرضت عنه محقِّرًا له{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦١٠٣٢<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿ولا تُصَعِّرْ خَدَّكَ لِلنّاسِ﴾</span>، قال: الصدود والإعراض بالوجه عن الناس{9}. (١١/٦٥٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦١٠٣٣<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق منصور- <span class="qpc-hafs">﴿ولا تُصَعِّرْ خَدَّكَ لِلنّاسِ﴾</span>، قال: الرجلُ يكونُ بينه وبين أخيه الحِنَة{10}، فيراه، فيُعرض عنه{11}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦١٠٣٤<span class="dash">-</span></span> عن <span class="name-2">الضحاك بن مُزاحِم</span> -من طريق عبيد- في قوله: <span class="qpc-hafs">﴿ولا تُصَعِّرْ خَدَّكَ لِلنّاسِ﴾</span>، يقول: لا تُعرِض عن الناس. يقول: أقبِل على الناسِ بوجهك، وحسِّن خُلقَك{12}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦١٠٣٥<span class="dash">-</span></span> قال <span class="name-2">عكرمة مولى ابن عباس</span>: <span class="qpc-hafs">﴿ولا تُصَعِّرْ خَدَّكَ لِلنّاسِ﴾</span> هو الذي إذا سُلِّم عليه لوى عنقه تكبُّرًا{13}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦١٠٣٦<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span> -من طريق أبي مكين- في قوله: <span class="qpc-hafs">﴿ولا تُصَعِّرْ خَدَّكَ لِلنّاسِ﴾</span>، قال: لا تُعرِض بوجهك{12}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦١٠٣٧<span class="dash">-</span></span> قال <span class="name-2">عطاء</span>: <span class="qpc-hafs">﴿ولا تُصَعِّرْ خَدَّكَ لِلنّاسِ﴾</span> هو الذي يَلْوِي شِدْقَه{15}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦١٠٣٨<span class="dash">-</span></span> عن <span class="name-2">ميمون بن مهران</span> -من طريق جعفر- قال: <span class="qpc-hafs">﴿ولا تُصَعِّرْ خَدَّكَ لِلنّاسِ﴾</span> هو الرجل يُكَلِّم الرجل، فيلوي وجهَه{12}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦١٠٣٩<span class="dash">-</span></span> عن <span class="name-2">مكحول</span> -من طريق النعمان- في قوله تعالى: <span class="qpc-hafs">﴿ولا تصعر خدك للناس﴾</span>، قال: التَّصْعِير: أن ينفخ الرجل خَدَّه، ويُعرِض بوجهه عن الناس{17}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦١٠٤٠<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿ولا تُصَعِّرْ خَدَّكَ لِلنّاسِ ولا تَمْشِ فِي الأَرْضِ مَرَحًا إنَّ اللَّهَ لا يُحِبُّ كُلَّ مُخْتالٍ فَخُورٍ﴾</span>، قال: نهاه عن التَّكَبُّر{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦١٠٤١<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- <span class="qpc-hafs">﴿ولا تُصَعِّرْ خَدَّكَ لِلنّاسِ﴾</span>، قال: هو الإعراض؛ أن يُكَلِّمك الرجلُ وأنت مُعْرِضٌ عنه{19}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦١٠٤٢<span class="dash">-</span></span> قال <span class="name-2">قتادة بن دعامة</span>: <span class="qpc-hafs">﴿ولا تُصَعِّرْ خَدَّكَ لِلنّاسِ﴾</span> لا تحتقر الفقراء، لِيَكُنِ الفقير والغنيُّ عندك سواء{13}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦١٠٤٣<span class="dash">-</span></span> قال <span class="name-2">الربيع بن أنس</span> -من طريق أبي جعفر- في قوله: <span class="qpc-hafs">﴿ولا تُصَعِّرْ خَدَّكَ لِلنّاسِ﴾</span>، قال: ليكن الفقير والغني عندك في العلم سواء، وقد عُوتِب النبيُّ ﷺ: <span class="qpc-hafs">﴿عَبَسَ وتَوَلّى﴾</span> [عبس:١]{21}. (١١/٦٥٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦١٠٤٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ولا تُصَعِّرْ خَدَّكَ لِلنّاسِ﴾</span> لا تُعْرِض بوجهك عن فقراء الناس إذا كلَّموك فخرًا بالخُيلاء والعظمة{22}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦١٠٤٥<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿ولا تُصَعِّرْ خَدَّكَ لِلنّاسِ﴾</span>، قال: تصعير الخد: التجبُّر، والتكبُّر على الناس، ومَحْقَرتهم{11}<span class=comment-ref>٥١٤٣</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٥١٤٣</span> اختلف السلف في معنى: <span class="qpc-hafs">﴿ولا تصعر خدك﴾</span> على أقوال: <b>الأول</b>: أنّه الإعراض بالوجه تكبُّرًا. <b>الثاني</b>: أنه التشديق. <b>الثالث</b>: أنّه الإعراض عمَّن بينك وبينه خصومة وإحنة.</p><p>وقد <span class="comment-type-3">رجّح</span> <u>ابنُ جرير</u> (١٨/٥٥٩) <span class="mustanad">مستندًا إلى اللغة</span> القولَ الأول، فقال: "وأصل الصعر: داء يأخذ الإبل في أعناقها أو رؤوسها حتى تلفت أعناقها عن رؤوسها، فيشبه به الرجل المتكبر على الناس. <span class="mustanad">ومنه قول عمرو بن كلثوم التغلبي</span>:</p><p>وكنّا إذا الجبّار صعَّر خدَّه... أقمْنا له من مَيلِه فتقوَّما".</p><p>و<span class="comment-type-4">بنحوه</span> <u>ابنُ كثير</u> (٦/٣٣٩).</p><p>وذكر <u>ابنُ عطية</u> (٧/٥٢) في الآية <b>قولًا آخر</b>، فقال: «ويحتمل أن يريد أيضًا الضد، أي: ولا سؤالًا ولا ضراعة بالفقر». ثم <span class="comment-type-3">رجّح</span> <span class="mustanad">مستندًا إلى السياق</span> القول الأول، فقال: «والأول أظهر؛ بدلالة ذكر الاختيال والفخر بعد».</div></p><p><h3><span class="qpc-hafs">﴿وَلَا تَمۡشِ فِی ٱلۡأَرۡضِ مَرَحًاۖ إِنَّ ٱللَّهَ لَا یُحِبُّ كُلَّ مُخۡتَالࣲ فَخُورࣲ ۝١٨﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦١٠٤٦<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- <span class="qpc-hafs">﴿كُلَّ مُخْتالٍ﴾</span> قال: مُتَكَبِّر، <span class="qpc-hafs">﴿فَخُورٍ﴾</span> يُعَدِّد ما أعطى الله، وهو لا يشكر الله{24}<span class=comment-ref>٥١٤٤</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٥١٤٤</span> ذكر <u>ابنُ عطية</u> (٧/٥٣) قول مجاهد، ثم <span class="comment-type-4">علّق</span> قائلًا: «وفي اللفظ الفخر بالنسب وغير ذلك».</div></p><p><div></p><p><p><span class="item-no">٦١٠٤٧<span class="dash">-</span></span> عن <span class="name-2">الضحاك بن مُزاحِم</span> -من طريق عبيد- في قوله: <span class="qpc-hafs">﴿ولا تَمْشِ فِي الأَرْضِ مَرَحًا﴾</span>، يقول: بالخُيلاء{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦١٠٤٨<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ولا تَمْشِ فِي الأَرْضِ مَرَحًا إنَّ اللَّهَ لا يُحِبُّ كُلَّ مُخْتالٍ فَخُورٍ﴾</span>، يعني ﷿: كل بَطِرٍ مَرِحٍ فخورٍ في نعم الله تعالى لا يأخذها بالشُّكر{22}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦١٠٤٩<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿ولا تَمْشِ فِي الأَرْض مَرَحًا﴾</span> بالعظمة، <span class="qpc-hafs">﴿فَخُورٍ﴾</span> يَعُدُّ ما أُعْطِي زهوًا، لا يشكر الله{27}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَلَا تَمۡشِ فِی ٱلۡأَرۡضِ مَرَحًاۖ إِنَّ ٱللَّهَ لَا یُحِبُّ كُلَّ مُخۡتَالࣲ فَخُورࣲ ۝١٨﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٦١٠٥٠<span class="dash">-</span></span> عن أبي ذرٍّ، قال: سمعتُ رسول الله ﷺ يقول: «<b>ثلاثةٌ يُحِبُّهم الله، وثلاثة يبغضهم الله</b>». قال: نعم، فما أخالني أكذب على خليلي محمد ﷺ. ثلاثًا يقولها، قال: قلت: مَنِ الثلاثةُ الِّذين يحبهم الله ﷿؟ قال: «<b>رجل غزا في سبيل الله، فلقي العدوَّ مجاهدًا محتسبًا فقاتل حتى قُتل، وأنتم تجدون في كتاب الله ﷿: <span class="qpc-hafs">﴿إنَّ اللَّهَ يُحِبُّ الَّذِين َيُقاتِلُونَ فِي سَبِيلِهِ صَفًّا﴾</span> [الصف:٤]، ورجل له جارٍ يؤذيه، فيصبر على أذاه ويحتسبه، حتى يكفيه الله إيّاه بموت أو حياة، ورجل يكون مع قوم فيسيرون حتى يشق عليهم الكرى والنعاس، فينزلون في آخر الليل، فيقوم إلى وضوئه وصلاته</b>». قال: قلت: مَن الثلاثة الذين يبغضهم الله؟ قال: «<b>الفخور المختال، وأنتم تجدون في كتاب الله ﷿: <span class="qpc-hafs">﴿إنَّ اللَّهَ لا يُحِبُّ كُلَّ مُخْتالٍ فَخُورٍ﴾</span> [لقمان:١٨]، والبخيل المنّان، والتاجر</b> -<b>أو البَيّاع</b>- <b>الحلّاف</b>»{28}. (ز)</p></p><p></div></p></div>",footnotes:1:الشِّدْق: جانب الفم. اللسان (شدق).أخرجه ابن عدي في الكامل ٨/٣٧١ (٢٠٠٩)، وأخرجه بدون ذكر الآية وإنما بلفظ التصعير الطبراني في الكبير ٤/١٧٩ (٤٠٧٢)، من طريق واصل بن السائب، عن أبي سورة، عن أبي أيوب به.</p><p>قال ابن القيسراني في ذخيرة الحفاظ ٢/٧٤٤-٧٤٥ (١٣٩٤): «رواه واصل بن السائب الرقاشي، عن أبي سورة ابن أخي أبي أيوب، عن عمه أبي أيوب الأنصاري، وواصل متروك الحديث». وقال الهيثمي في المجمع ٨/١١٤ (١٣٢٦٨): «فيه واصل بن السائب، وهو متروك».أخرجه ابن جرير ١٨/٥٥٩، كما أخرجه من طريق عطية العوفي أيضًا، وابن أبي حاتم -كما في الإتقان ٢/٣٦-. وعزاه السيوطي إلى ابن المنذر.عزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.أخرجه الآجري في أخلاق أهل القرآن ص١١٣ (٤٥).عزاه السيوطي إلى ابن أبي حاتم.أخرجه ابن جرير ١٨/٥٦٢.أخرجه ابن جرير ١٨/٥٦٠، وإسحاق البستي ص٨٩.تفسير مجاهد (٥٤٢)، وأخرجه ابن جرير ١٨/٥٦٠. وعلقه يحيى بن سلّام ٢/٦٧٦. وعزاه السيوطي إلى الفريابي.الحِنة: العداوة. النهاية ١/٤٥٣.أخرجه ابن جرير ١٨/٥٦١.أخرجه ابن جرير ١٨/٥٦٠.تفسير البغوي ٦/٢٨٩.أخرجه ابن جرير ١٨/٥٦٠.تفسير الثعلبي ٧/٣١٤.أخرجه ابن جرير ١٨/٥٦٠.أخرجه ابن عساكر في تاريخ دمشق ١٨/١٣١.أخرجه ابن جرير ١٨/٥٦٢.أخرجه ابن أبي الدنيا في التواضع والخمول ٣/٥٧٨ (٢٢٢).تفسير البغوي ٦/٢٨٩.أخرجه البيهقي في شعب الإيمان (٨١٧٩). وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.تفسير مقاتل بن سليمان ٣/٤٣٥.أخرجه ابن جرير ١٨/٥٦١.تفسير مجاهد (٥٤٢)، وأخرجه ابن جرير ١٨/٥٦٤. وعلَّقه يحيى بن سلّام ٢/٦٧٦.أخرجه ابن جرير ١٨/٥٦٢.تفسير مقاتل بن سليمان ٣/٤٣٥.تفسير يحيى بن سلّام ٢/٦٧٦.أخرجه أحمد ٣٥/٢٨٥ (٢١٣٥٥)، والترمذي ٤/٥٣١-٥٣٢ (٢٧٥٠-٢٧٥١)، والنسائي ٣/٢٠٧ (١٦١٥)، ٥/٨٤ (٢٥٧٠)، وابن خزيمة ٤/١٧٥ (٢٤٥٦)، ٤/٢٥٤ (٢٥٦٤)، وابن حبان ٨/١٣٦-١٣٧ (٣٣٤٩)، ٨/١٣٨ (٣٣٥٠)، ١١/٩١ (٤٧٧١)، والحاكم ١/٥٧٧ (١٥٢٠)، ٢/١٢٣ (٢٥٣٢)،من طريق منصور، عن ربعي بن حراش، عن زيد بن ظبيان، عن أبي ذر به.</p><p>وأخرجه أحمد ٣٥/٢٦٨-٢٦٩ (٢١٣٤٠)، من طريق إسماعيل، عن الجريري، عن أبي العلاء بن الشخير، عن ابن الأحمسي، عن أبي ذر به.</p><p>وأخرجه أحمد من طرق أخرى عن أبي ذر ﵁.</p><p>قال الترمذي: «هذا حديث صحيح». وقال الحاكم: «هذا حديث صحيح على شرط الشيخين، ولم يخرجاه». ووافقه الذهبي في التلخيص. وقال ابن كثير في تفسيره ٢/٦٣ عن رواية أحمد: «غريب من هذا الوجه». وقال العراقي في تخريج الإحياء ص١٠٢٥ (١٠): «أخرجه أحمد واللفظ له، وفيه ابن الأحمس ولا يعرف حاله، ورواه هو والنسائي بلفظ آخر بإسناد جيد».
  31,19,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَٱقۡصِدۡ فِی مَشۡیِكَ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦١٠٥١<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span>، في قوله: <span class="qpc-hafs">﴿واقْصِدْ فِي مَشْيِكَ﴾</span>، يقول: لا تَخْتَلْ{1}. (١١/٦٥٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦١٠٥٢<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق جابر- في قوله: <span class="qpc-hafs">﴿واقْصِدْ فِي مَشْيِكَ﴾</span>، قال: تَواضَعْ{2}. (١١/٦٥٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦١٠٥٣<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿واقْصِدْ فِي مَشْيِكَ﴾</span>، قال: نهاه عن الخُيَلاء{3}. (١١/٦٥٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦١٠٥٤<span class="dash">-</span></span> عن <span class="name-2">يزيد بن أبي حبيب</span> -من طريق عبد الله بن عقبة- في قوله: <span class="qpc-hafs">﴿واقصد في مشيك﴾</span>، قال: مِن السُّرْعة{4}<span class=comment-ref>٥١٤٥</span>. (١١/٦٥٣)</p></p><p></div></p><p><div><span class=comment-ref>٥١٤٥</span> <span class="comment-type-4">جمع</span> <u>ابنُ جرير</u> (١٨/٥٦٢) بين قول يزيد وقول قتادة ومجاهد، فقال: «قوله تعالى: <span class="qpc-hafs">﴿واقصد في مشيك﴾</span> يقول: وتواضع في مشيك إذا مشيت، ولا تستكبر، ولا تستعجل، ولكن اتَّئِدْ. <span class="mustanad">وبنحو الذي قلنا في ذلك قال أهل التأويل</span>، غير أن منهم من قال: أمره بالتواضع في مشيه. ومنهم مَن قال: أمره بترك السرعة فيه».</div></p><p><div></p><p><p><span class="item-no">٦١٠٥٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿واقْصِدْ فِي مَشْيِكَ﴾</span> لا تَخْتل في مشيك، ولا تبطر حيث لا يحل{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦١٠٥٦<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿واقْصِدْ فِي مَشْيِكَ﴾</span>، وقال في آية أخرى: <span class="qpc-hafs">﴿ولا تَمْشِ فِي الأَرْضِ مَرَحًا إنَّكَ لَنْ تَخْرِقَ الأَرْضَ ولَنْ تَبْلُغَ الجِبالَ طُولًا﴾</span> [الإسراء:٣٧]{6}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَٱغۡضُضۡ مِن صَوۡتِكَۚ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦١٠٥٧<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span>، في قوله: <span class="qpc-hafs">﴿واغْضُضْ مِن صَوْتِكَ﴾</span>، قال: اخفِض مِن صوتك عند الملأ{1}. (١١/٦٥٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦١٠٥٨<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿واغْضُضْ مِن صَوْتِكَ﴾</span>، قال: أمره بالاقتصاد في صوته{8}. (١١/٦٥٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦١٠٥٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿واغْضُضْ﴾</span> يعني: واخفِض <span class="qpc-hafs">﴿مِن صَوْتِكَ﴾</span> يعني: مِن كلامك. يأمُرُ لقمانُ ابنَه بالاقتصاد في المشي والمنطق{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦١٠٦٠<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- <span class="qpc-hafs">﴿واغْضُضْ مِن صَوْتِكَ إنَّ أنْكَرَ الأَصْواتِ لَصَوْتُ الحَمِيرِ﴾</span>، قال: اخفِض من صوتك{10}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿إِنَّ أَنكَرَ ٱلۡأَصۡوَ ٰ⁠تِ لَصَوۡتُ ٱلۡحَمِیرِ ۝١٩﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦١٠٦١<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span>، في قوله: <span class="qpc-hafs">﴿إنَّ أنْكَرَ الأَصْواتِ﴾</span> قال: أقبح الأصوات <span class="qpc-hafs">﴿لَصَوْتُ الحَمِيرِ﴾</span>{1}. (١١/٦٥٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦١٠٦٢<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span>، في قوله: <span class="qpc-hafs">﴿إنَّ أنْكَرَ الأَصْواتِ لَصَوْتُ الحَمِيرِ﴾</span>، قال: أنكرها على السمع{12}. (١١/٦٥٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦١٠٦٣<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق أبان بن تغلب- في قوله: <span class="qpc-hafs">﴿إن أنكر الأصوات لصوت الحمير﴾</span>، قال: <span class="qpc-hafs">﴿أنكر﴾</span>: أقبح{13}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦١٠٦٤<span class="dash">-</span></span> عن <span class="name-2">الضحاك بن مزاحم</span> -من طريق جويبر- <span class="qpc-hafs">﴿إنَّ أنْكَرَ الأَصْواتِ﴾</span>، قال: إنّ أقبح الأصوات <span class="qpc-hafs">﴿لَصَوْتُ الحَمِيرِ﴾</span>{10}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦١٠٦٥<span class="dash">-</span></span> قال <span class="name-2">الضحاك بن مزاحم</span>: <span class="qpc-hafs">﴿إنَّ أنْكَرَ الأَصْواتِ لَصَوْتُ الحَمِيرِ﴾</span> أقبح؛ لأن أوله زفيرٌ وآخره شهيق، أمره بالاقتصاد في صوته{15}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦١٠٦٦<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦١٠٦٧<span class="dash">-</span></span> و<span class="name-2">الحكم بن عتيبة</span> -من طريق جابر- <span class="qpc-hafs">﴿إنَّ أنْكَرَ الأَصْواتِ﴾</span>: أشرَّ الأصوات{16}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦١٠٦٨<span class="dash">-</span></span> عن <span class="name-2">الحسن بن مسلم</span> -من طريق جابر- <span class="qpc-hafs">﴿إنَّ أنْكَرَ الأَصْواتِ لَصَوْتُ الحَمِيرِ﴾</span>: أشد الأصوات{17}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦١٠٦٩<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿إنَّ أنْكَرَ الأَصْواتِ﴾</span> قال: أقبح الأصوات <span class="qpc-hafs">﴿لَصَوْتُ الحَمِيرِ﴾</span> قال: أوله زفير وآخره شهيق{18}. (١١/٦٥٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦١٠٧٠<span class="dash">-</span></span> عن <span class="name-2">سليمان بن مهران الأعمش</span> -من طريق سفيان- <span class="qpc-hafs">﴿إنَّ أنْكَرَ الأَصْواتِ لَصَوْتُ الحَمِيرِ﴾</span>: أقبح الأصوات صوت الحمير{19}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦١٠٧١<span class="dash">-</span></span> عن <span class="name-3">محمد بن السائب الكلبي</span> -من طريق معمر- في قوله تعالى: <span class="qpc-hafs">﴿إنَّ أنْكَرَ الأَصْواتِ لَصَوْتُ الحَمِيرِ﴾</span>، قال: أقبح الأصوات لصوت الحمار{20}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦١٠٧٢<span class="dash">-</span></span> قال <span class="name-3">جعفر الصادق</span>، في قوله: <span class="qpc-hafs">﴿إنَّ أنْكَرَ الأَصْواتِ لَصَوْتُ الحَمِيرِ﴾</span>، قال: هي العَطْسَة القبيحة المنكرة{21}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦١٠٧٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿إنَّ أنْكَرَ الأَصْواتِ لَصَوْتُ الحَمِيرِ﴾</span> يعني: أقبح الأصوات لصوت الحمير، لشدة صوتهن {5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦١٠٧٤<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿إنَّ أنْكَرَ الأَصْواتِ﴾</span> يعني: أقبح الأصوات <span class="qpc-hafs">﴿لَصَوْتُ الحَمِيرِ﴾</span>، وإنّما كانت صوت الحمير ولم يكن لَأَصوات الحمير؛ لأنه عنى صوتها الذي هو صوتها{6}<span class=comment-ref>٥١٤٦</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٥١٤٦</span> اختلف السلف في تفسير قوله: <span class="qpc-hafs">﴿إن أنكر الأصوات لصوت الحمير﴾</span> على أقوال: <b>الأول</b>: أقبح. <b>الثاني</b>: أشر.</p><p>وقد <span class="comment-type-4">جمع</span> <u>ابنُ جرير</u> (١٨/٥٦٥) بينهما <span class="mustanad">مستندًا إلى اللغة</span>، فقال: «وأولى الأقوال في ذلك بالصواب قول من قال: معناه: إن أقبح أو أشر الأصوات. وذلك نظير قولهم إذا رأوا وجهًا قبيحًا أو منظرًا شنيعًا: ما أنكر وجه فلان، وما أنكر منظره».</div></p><p><h3><span class="qpc-hafs">﴿إِنَّ أَنكَرَ ٱلۡأَصۡوَ ٰ⁠تِ لَصَوۡتُ ٱلۡحَمِیرِ ۝١٩﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٦١٠٧٥<span class="dash">-</span></span> عن جابر بن عبد الله ﵄من طريق نبيح العنزي- وتلا قول لقمان لابنه: <span class="qpc-hafs">﴿واقْصِدْ فِي مَشْيِكَ واغْضُضْ مِن صَوْتِكَ﴾</span>، قال: كان رسول الله ﷺ إذا خرج مشوا بين يديه، وخلَّوْا ظهرَه للملائكة{24}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦١٠٧٦<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- قال: لو كان رفعُ الصوت خيرًا ما جعله الله للحمير{25}. (١١/٦٥٤)</p></p><p></div></p></div>",footnotes:1:عزاه السيوطي إلى ابن أبي حاتم.أخرجه ابن جرير ١٨/٥٦٣. وعزاه السيوطي إلى ابن أبي حاتم.أخرجه ابن جرير ١٨/٥٦٣. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، ابن أبي حاتم.أخرجه إسحاق البستي ص٩١ من طريق حيوة، وابن جرير ١٨/٥٦٣، والبيهقي في شعب الإيمان (٨١٦٨). وعزاه السيوطي إلى سعيد ابن منصور، وابن المنذر، وابن أبي حاتم.تفسير مقاتل بن سليمان ٣/٤٣٥.تفسير يحيى بن سلّام ٢/٦٧٧.عزاه السيوطي إلى ابن أبي حاتم.أخرجه ابن جرير ١٨/٥٦٤. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.تفسير مقاتل بن سليمان ٣/٤٣٥.أخرجه ابن جرير ١٨/٥٦٤.عزاه السيوطي إلى ابن أبي حاتم.عزاه السيوطي إلى سعيد بن منصور، وابن جرير، وابن المنذر.أخرجه إسحاق البستي ص٩١. وأورده الثعلبي ٧/٣١٥ بأتمَّ من ذلك كما في أثر الضحاك بعد التالي.أخرجه ابن جرير ١٨/٥٦٤.تفسير الثعلبي ٧/٣١٥.أخرجه ابن جرير ١٨/٥٦٥.أخرجه ابن جرير ١٨/٥٦٨.أخرجه ابن جرير ١٨/٥٦٣-٥٦٤. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.أخرجه سفيان الثوري في تفسيره (٢٣٨)، وابن جرير ١٨/٥٦٥.أخرجه عبد الرزاق ٢/١٠٦.تفسير البغوي ٦/٢٩٠.تفسير مقاتل بن سليمان ٣/٤٣٥.تفسير يحيى بن سلّام ٢/٦٧٧.أخرجه الحاكم ٢/٤٤٦ (٣٥٤٤)، ٤/٣١٣ (٧٧٥٢)، وأخرجه من غير ذكر الآية أحمد ٢٢/١٣٩-١٤٠ (١٤٢٣٦)، ٢٢/٤٢٠-٤٢١ (١٤٥٥٦)، وابن ماجه ١/١٦٦ (٢٤٦)، وابن حبان ١٤/٢١٨ (٦٣١٢)، من طريق سفيان، عن الأسود بن قيس، عن نبيح العنزي، عن جابر بن عبد الله به.</p><p>قال الحاكم: «هذا حديث صحيح الإسناد، ولم يخرجاه». ووافقه الذهبي في التلخيص. وقال البوصيري في مصباح الزجاجة ١/٣٦ (٩٧): «هذا إسناد صحيح، رجاله ثقات». وأورده الألباني في الصحيحة ١/٧٩٧ (٤٣٦)، ٥/١٢٣ (٢٠٨٧).أخرجه ابن جرير ١٨/٥٦٥. وعزاه السيوطي إلى ابن أبي حاتم.