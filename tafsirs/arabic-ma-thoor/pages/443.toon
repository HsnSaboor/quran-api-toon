quran[14]{c,v,t}:
  36,41,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَءَایَةࣱ لَّهُمۡ أَنَّا حَمَلۡنَا ذُرِّیَّتَهُمۡ فِی ٱلۡفُلۡكِ ٱلۡمَشۡحُونِ ۝٤١﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٤٦٧٣<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق سعيد بن جبير- <span class="qpc-hafs">﴿فِي الفُلْكِ المَشْحُونِ﴾</span>، قال: أتدرون ما الفُلك المشحون؟ قلنا: لا. قال: هو المُوقر{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٦٧٤<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- قوله: <span class="qpc-hafs">﴿أنّا حَمَلْنا ذُرِّيَّتَهُمْ فِي الفُلْكِ المَشْحُونِ﴾</span>، يقول: المُمْتَلِئ{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٦٧٥<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطية- قوله: <span class="qpc-hafs">﴿فِي الفُلْكِ المَشْحُونِ﴾</span>: يعني: المُثقل{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٦٧٦<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span> -من طريق عطاء- <span class="qpc-hafs">﴿الفُلْكِ المَشْحُونِ﴾</span>، قال: الموقر{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٦٧٧<span class="dash">-</span></span> عن <span class="name-2">الضحاك بن مزاحم</span> -من طريق عبيد- يقول في قوله: <span class="qpc-hafs">﴿أنّا حَمَلْنا ذُرِّيَّتَهُمْ فِي الفُلْكِ المَشْحُونِ﴾</span>: يعني: سفينة نوح ﵇{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٦٧٨<span class="dash">-</span></span> عن <span class="name-2">الضَّحّاك بن مُزاحِم</span> -من طريق جُوَيْبِر- في قوله: <span class="qpc-hafs">﴿الفُلْكِ المَشْحُونِ﴾</span>، قال: المُوقر{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٦٧٩<span class="dash">-</span></span> عن <span class="name-2">أبي مالك غزوان الغفاري</span>، في قوله: <span class="qpc-hafs">﴿وآيَةٌ لَهُمْ أنّا حَمَلْنا ذُرِّيَّتَهُمْ فِي الفُلْكِ المَشْحُونِ﴾</span>، قال: سفينة نوح؛ حمل فيها من كل زوجين اثنين{7}. (١٢/٣٥٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٦٨٠<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق يونس- في قوله: <span class="qpc-hafs">﴿المَشْحُونِ﴾</span>، قال: المحمول{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٦٨١<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق الحسن بن دينار- <span class="qpc-hafs">﴿المَشْحُونِ﴾</span>: المُوقر بحمله، يقول: مما حمل نوح معه في السفينة{9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٦٨٢<span class="dash">-</span></span> عن <span class="name-2">أبي صالح باذام</span>، في قوله: <span class="qpc-hafs">﴿حَمَلْنا ذُرِّيَّتَهُمْ فِي الفُلْكِ المَشْحُونِ﴾</span>، قال: سفينة نوح{10}. (١٢/٣٥٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٦٨٣<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- قوله: <span class="qpc-hafs">﴿وآيَةٌ لَهُمْ أنّا حَمَلْنا ذُرِّيَّتَهُمْ فِي الفُلْكِ المَشْحُونِ﴾</span>: المُوقر، يعني: سفينة نوح{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٦٨٤<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُدِّيّ</span>: <span class="qpc-hafs">﴿وآيَةٌ لَهُمُ﴾</span>، يعني: وعلامة لهم{12}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٦٨٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وآيَةٌ لَهُمُ﴾</span> وعلامة لهم، يعني: كفار مكة <span class="qpc-hafs">﴿أنّا حَمَلْنا ذُرِّيَّتَهُمْ﴾</span> ذرية أهل مكة في أصلاب آبائهم <span class="qpc-hafs">﴿فِي الفُلْكِ المَشْحُونِ﴾</span> يعني: المُوقر مِن الناس والدواب{13}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٦٨٦<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿الفُلْكِ المَشْحُونِ﴾</span>، قال: الفُلك المشحون: المركب الذي كان فيه نوح، والذرية التي كانت في ذلك المركب. قال: والمشحون: الذي قد شُحِن؛ الذي قد جعل فيه ليركبه أهله، جعلوا فيه ما يريدون، فربما امتلأ، وربما لم يمتلئ{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٦٨٧<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿أنّا حَمَلْنا ذُرِّيَّتَهُمْ فِي الفُلْكِ المَشْحُونِ﴾</span>، يعني: نوحًا وبنيه الثلاثة: سام، وحام، ويافث، منهم ذُرِي الخلقُ بعد ما غرِق قومُ نوح{15}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ١٩/٤٤٣.|2:أخرجه ابن جرير ١٩/٤٤٢.|3:أخرجه ابن جرير ١٩/٤٤٢.|4:أخرجه ابن جرير ١٩/٤٤٢.|5:أخرجه ابن جرير ١٩/٤٤٣.|6:أخرجه ابن جرير ١٩/٤٤٣.|7:عزاه السيوطي إلى عبد بن حميد، وابن أبي حاتم.|8:أخرجه ابن جرير ١٩/٤٤٢.|9:أخرجه يحيى بن سلّام ٢/٨١٠.|10:عزاه السيوطي إلى عبد بن حميد، وابن المنذر.|11:أخرجه ابن جرير ١٩/٤٤٣.|12:علقه يحيى بن سلّام ٢/٨١٠.|13:تفسير مقاتل بن سليمان ٣/٥٨٠.|14:أخرجه ابن جرير ١٩/٤٤٣.|15:تفسير يحيى بن سلّام ٢/٨١٠.
  36,42,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَخَلَقۡنَا لَهُم مِّن مِّثۡلِهِۦ مَا یَرۡكَبُونَ ۝٤٢﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٤٦٨٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق سعيد بن جبير- <span class="qpc-hafs">﴿وخَلَقْنا لَهُمْ مِن مِثْلِهِ ما يَرْكَبُونَ﴾</span>، قال: هي السفن، جُعِلَت مِن بعد سفينة نوحٍ على مِثلها{1}. (١٢/٣٥٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٦٨٩<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطية العوفي- <span class="qpc-hafs">﴿وخَلَقْنا لَهُمْ مِن مِثْلِهِ ما يَرْكَبُونَ﴾</span>: يعني: الإبل؛ خلقها الله كما رأيتَ، فهي سُفُن البر، يحملون عليها ويركبونها{2}. (١٢/٣٥٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٦٩٠<span class="dash">-</span></span> عن <span class="name-2">عبد الله بن شداد</span> -من طريق السُدِّيّ- في قوله: <span class="qpc-hafs">﴿وخَلَقْنا لَهُمْ مِن مِثْلِهِ ما يَرْكَبُونَ﴾</span>، قال: هي الإبل{3}. (١٢/٣٥٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٦٩١<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿وخَلَقْنا لَهُمْ مِن مِثْلِهِ ما يَرْكَبُونَ﴾</span>، قال: الأنعام{4}. (١٢/٣٥٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٦٩٢<span class="dash">-</span></span> عن <span class="name-2">الضحاك بن مزاحم</span> -من طريق عبيد- يقول في قوله: <span class="qpc-hafs">﴿وخَلَقْنا لَهُمْ مِن مِثْلِهِ ما يَرْكَبُونَ﴾</span>: يعني: السفن التي اتخذت بعدها، يعني: بعد سفينة نوح{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٦٩٣<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span>، في قوله: <span class="qpc-hafs">﴿وخَلَقْنا لَهُمْ مِن مِثْلِهِ ما يَرْكَبُونَ﴾</span>، قال: هي الإبل{6}. (١٢/٣٥٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٦٩٤<span class="dash">-</span></span> عن <span class="name-2">أبي مالك غزوان الغفاري</span>، في قوله: <span class="qpc-hafs">﴿وخَلَقْنا لَهُمْ مِن مِثْلِهِ ما يَرْكَبُونَ﴾</span>، قال: السفن التي في البحر، والأنهار التي يركب الناس فيها{7}. (١٢/٣٥٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٦٩٥<span class="dash">-</span></span> عن <span class="name-2">أبي مالك غزوان الغفاري</span> -من طريق السُدِّيّ- في قوله: <span class="qpc-hafs">﴿وخَلَقْنا لَهُمْ مِن مِثْلِهِ ما يَرْكَبُونَ﴾</span>، قال: السفن الصغار، ألا ترى أنه قال: <span class="qpc-hafs">﴿وإنْ نَشَأْ نُغْرِقْهُمْ فَلا صَرِيخَ لَهُمْ﴾</span>؟!{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٦٩٦<span class="dash">-</span></span> قال <span class="name-2">الحسن البصري</span> -من طريق قتادة- <span class="qpc-hafs">﴿وخَلَقْنا لَهُمْ مِن مِثْلِهِ ما يَرْكَبُونَ﴾</span>: هي الإبل{9}. (١٢/٣٥٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٦٩٧<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق منصور بن زاذان- في هذه الآية: <span class="qpc-hafs">﴿وخَلَقْنا لَهُمْ مِن مِثْلِهِ ما يَرْكَبُونَ﴾</span>، قال: السفن الصغار{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٦٩٨<span class="dash">-</span></span> عن <span class="name-2">أبي صالح باذام</span>، في قوله: <span class="qpc-hafs">﴿حَمَلْنا ذُرِّيَّتَهُمْ فِي الفُلْكِ المَشْحُونِ﴾</span> قال: سفينة نوح، <span class="qpc-hafs">﴿وخَلَقْنا لَهُمْ مِن مِثْلِهِ ما يَرْكَبُونَ﴾</span> هذه السفن مثل خشبها وصنعتها{11}. (١٢/٣٥٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٦٩٩<span class="dash">-</span></span> عن <span class="name-2">أبي صالح باذام</span> -من طريق شعبة، عن إسماعيل- في قوله: <span class="qpc-hafs">﴿وخَلَقْنا لَهُمْ مِن مِثْلِهِ ما يَرْكَبُونَ﴾</span>، قال: السفن الصغار{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٧٠٠<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span>، <span class="qpc-hafs">﴿وخَلَقْنا لَهُمْ مِن مِثْلِهِ ما يَرْكَبُونَ﴾</span>، قال: يعني: السفن الصغار{13}. (١٢/٣٥٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٧٠١<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿وخَلَقْنا لَهُمْ مِن مِثْلِهِ ما يَرْكَبُونَ﴾</span>، قال: هي السُّفُن التي يُنتَفَع بها{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٧٠٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وخَلَقْنا لَهُمْ مِن مِثْلِهِ﴾</span> وجعلنا لهم مِن شبه سفينة نوح <span class="qpc-hafs">﴿ما يَرْكَبُونَ﴾</span> فيها{15}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٧٠٣<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿وخَلَقْنا لَهُمْ مِن مِثْلِهِ ما يَرْكَبُونَ﴾</span>، قال: وهي هذه الفلك{16}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٧٠٤<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: قال: <span class="qpc-hafs">﴿وخَلَقْنا لَهُمْ مِن مِثْلِه﴾</span> مِن مثل الفلك <span class="qpc-hafs">﴿ما يَرْكَبُونَ﴾</span> يعني: الإبل، ويقال: هي سفن البر، وقال في آية أخرى: <span class="qpc-hafs">﴿وجَعَلَ لَكُمْ مِنَ الفُلْكِ والأَنْعامِ ما تَرْكَبُونَ﴾</span> [الزخرف:١٢]{17}<span class=comment-ref>٥٤٣٣</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٥٤٣٣</span> اختلف السلف في قوله: <span class="qpc-hafs">﴿وخلقنا لهم من مثله ما يركبون﴾</span> على قولين: <b>الأول</b>: أنه السفن. <b>الثاني</b>: أنه الإبل.</p><p>وقد <span class="comment-type-3">رجّح</span> <u>ابنُ جرير</u> (١٩/٤٤٦-٤٤٧) <span class="mustanad">مستندًا إلى السياق، والدلالة العقلية</span> القول الأول، فقال: «وأشبه القولين بتأويل ذلك قولُ مَن قال: عني بذلك: السفن، وذلك لدلالة قوله: <span class="qpc-hafs">﴿وإن نشأ نغرقهم فلا صريخ لهم﴾</span> [يس:٤٣]، على أن ذلك كذلك، وذلك أنّ الغرق معلوم أن لا يكون إلا في الماء، ولا غرق في البر».</p><p>وذكر <u>ابنُ عطية</u> (٧/٢٥٠-٢٥١) في معنى: <span class="qpc-hafs">﴿حملنا ذريتهم﴾</span> وفي معنى: <span class="qpc-hafs">﴿من مثله﴾</span> احتمالين، فقال: «وأمّا معنى الآية فيحتمل تأويلين: أحدهما قاله ابن عباس وجماعة، وهو أن يريد بالذريات المحمولين: أصحاب نوح في السفينة، ويريد بقوله: <span class="qpc-hafs">﴿مِن مِثْلِهِ﴾</span>: السفن الموجودة في جنس بني آدم إلى يوم القيامة، وإيّاها أراد الله تعالى بقوله: <span class="qpc-hafs">﴿وإنْ نَشَأْ نُغْرِقْهُمْ﴾</span>، والتأويل الثاني قاله مجاهد والسُدِّيّ، وروي عن ابن عباس أيضًا، هو أن يريد بقوله: <span class="qpc-hafs">﴿أنّا حَمَلْنا ذُرِّيَّتَهُمْ فِي الفُلْكِ المَشْحُونِ﴾</span>: السفن الموجودة في بني آدم إلى يوم القيامة، ويريد بقوله: <span class="qpc-hafs">﴿وخَلَقْنا لَهُمْ مِن مِثْلِهِ ما يَرْكَبُونَ﴾</span>: الإبل وسائر ما يركب، فتكون المماثلة في أنه مركوب مُبَلِّغٌ إلى الأقطار فقط، ويعود قوله: <span class="qpc-hafs">﴿وإن نشأ نغرقهم﴾</span> على السفن الموجودة في الناس، وأما من خلط القولين فجعل الذرية في الفلك في قوم نوح في سفينة، وجعل <span class="qpc-hafs">﴿من مثله﴾</span> في الإبل؛ فإن هذا نظرٌ فاسد يقطع به قوله تعالى: <span class="qpc-hafs">﴿وإن نشأ نغرقهم﴾</span>. فتأمله».</div></p></div>",footnotes:1:أخرجه ابن جرير ١٩/٤٤٤. وعزاه السيوطي إلى ابن أبي حاتم.|2:أخرجه ابن جرير ١٩/٤٤٦. وعزاه السيوطي إلى ابن أبي حاتم.|3:أخرجه ابن جرير ١٩/٤٤٦. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.|4:تفسير مجاهد (٥٦٠)، وأخرجه ابن جرير ١٩/٤٤٦ بنحوه. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.|5:أخرجه ابن جرير ١٩/٤٤٥.|6:عزاه السيوطي إلى ابن أبي شيبة، وعبد بن حميد، وابن المنذر، وابن أبي حاتم.|7:عزاه السيوطي إلى عبد بن حميد، وابن أبي حاتم.|8:أخرجه ابن جرير ١٩/٤٤٤.|9:أخرجه ابن جرير ١٩/٤٤٦. وعزاه السيوطي إلى عبد بن حميد.|10:أخرجه ابن جرير ١٩/٤٤٤.|11:عزاه السيوطي إلى عبد بن حميد، وابن المنذر. وعند ابن جرير ١٩/٤٤٥ نحو شطره الثاني من طريق محمد بن عبيد عن إسماعيل بن أبي خالد بلفظ: نِعَمٌ من مثل سفينة نوح.|12:أخرجه ابن جرير ١٩/٤٤٥.|13:عزاه السيوطي إلى عبد بن حميد.|14:أخرجه ابن جرير ١٩/٤٤٥.|15:تفسير مقاتل بن سليمان ٣/٥٨٠.|16:أخرجه ابن جرير ١٩/٤٤٥، وفيه (ط: هجر): الفلوك.|17:تفسير يحيى بن سلّام ٢/٨١٠.
  36,43,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَإِن نَّشَأۡ نُغۡرِقۡهُمۡ فَلَا صَرِیخَ لَهُمۡ وَلَا هُمۡ یُنقَذُونَ ۝٤٣﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٤٧٠٥<span class="dash">-</span></span> قال <span class="name-1">عبد الله بن عباس</span>: <span class="qpc-hafs">﴿وإنْ نَشَأْ نُغْرِقْهُمْ فَلا صَرِيخَ لَهُمْ ولا هُمْ يُنْقَذُونَ﴾</span> ولا أحد ينقذهم من عذابي{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٧٠٦<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span>، في قوله: <span class="qpc-hafs">﴿وإنْ نَشَأْ نُغْرِقْهُمْ فَلا صَرِيخَ لَهُمْ﴾</span>، قال: لا مغيث لهم يستغيثون به{2}. (١٢/٣٥٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٧٠٧<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿فَلا صَرِيخَ لَهُمْ﴾</span>، قال: لا مُغيث لهم{3}. (١٢/٣٥٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٧٠٨<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وإنْ نَشَأْ نُغْرِقْهُمْ﴾</span> في الماء؛ <span class="qpc-hafs">﴿فَلا صَرِيخَ لَهُمْ﴾</span> لا مغيث لهم، <span class="qpc-hafs">﴿ولا هُمْ يُنْقَذُونَ﴾</span> مِن الغرق{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٧٠٩<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: قال: <span class="qpc-hafs">﴿وإنْ نَشَأْ نُغْرِقْهُمْ فَلا صَرِيخَ لَهُمْ﴾</span> فلا مغيث لهم، <span class="qpc-hafs">﴿ولا هُمْ يُنْقَذُونَ﴾</span> مِن العذاب{5}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير البغوي ٧/١٩.|2:عزاه السيوطي إلى عبد بن حميد، وابن جرير، وابن المنذر، وابن أبي حاتم.|3:أخرجه عبد الرزاق ٢/١٤٤ من طريق معمر، وابن جرير ١٩/٤٤٧. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.|4:تفسير مقاتل بن سليمان ٣/٥٨٠.|5:تفسير يحيى بن سلّام ٢/٨١٠-٨١١.
  36,44,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿إِلَّا رَحۡمَةࣰ مِّنَّا وَمَتَـٰعًا إِلَىٰ حِینࣲ ۝٤٤﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٤٧١٠<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿ومَتاعًا إلى حِينٍ﴾</span>، قال: إلى الموت{1}. (١٢/٣٥٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٧١١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿إلّا رَحْمَةً مِنّا﴾</span> إلا نعمة منا حين لا نغرقهم، <span class="qpc-hafs">﴿ومَتاعًا إلى حِينٍ﴾</span> وبلاغًا إلى آجالهم{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٧١٢<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: قال: <span class="qpc-hafs">﴿إلّا رَحْمَةً مِنّا ومَتاعًا إلى حِينٍ﴾</span> فبرحمته يُمتِّعهم إلى يوم القيامة، ولم يهلكهم بعذاب الاستئصال، وسيهلك كفار آخر هذه الأمة بالنفخة الأولى{3}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ١٩/٤٤٧. وعزاه السيوطي إلى عبد الرزاق، وعبد بن حميد، وابن المنذر، وابن أبي حاتم.|2:تفسير مقاتل بن سليمان ٣/٥٨٠.|3:تفسير يحيى بن سلّام ٢/٨١٠-٨١١.
  36,45,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَإِذَا قِیلَ لَهُمُ ٱتَّقُوا۟ مَا بَیۡنَ أَیۡدِیكُمۡ وَمَا خَلۡفَكُمۡ لَعَلَّكُمۡ تُرۡحَمُونَ ۝٤٥﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٤٧١٣<span class="dash">-</span></span> قال <span class="name-1">عبد الله بن عباس</span>: <span class="qpc-hafs">﴿ما بَيْنَ أيْدِيكُمْ﴾</span> يعني: الآخرة؛ فاعملوا لها، <span class="qpc-hafs">﴿وما خَلْفَكُمْ﴾</span> يعني: الدنيا؛ فاحذروها، ولا تغترُّوا بها{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٧١٤<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿وإذا قِيلَ لَهُمُ اتَّقُوا ما بَيْنَ أيْدِيكُمْ وما خَلْفَكُمْ لَعَلَّكُمْ تُرْحَمُونَ﴾</span>، قال: ما مضى وما بقي من الذنوب{2}. (١٢/٣٥٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٧١٥<span class="dash">-</span></span> قال <span class="name-2">الحسن البصري</span>: <span class="qpc-hafs">﴿ما بَيْنَ أيْدِيكُمْ﴾</span> مِن وقائع الله بالكفار، أي: لا ينزل بكم ما نزل بهم، <span class="qpc-hafs">﴿وما خَلْفَكُمْ﴾</span> عذاب الآخرة بعد عذاب الدنيا، يقوله النبي ﵇ للمشركين{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٧١٦<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿وإذا قِيلَ لَهُمُ اتَّقُوا ما بَيْنَ أيْدِيكُمْ﴾</span> قال: من الوقائع التي قد خلت فيمَن كان قبلكم، والعقوبات التي أصابت عادًا وثمودًا والأمم، <span class="qpc-hafs">﴿وما خَلْفَكُمْ﴾</span> قال: من أمر الساعة{4}<span class=comment-ref>٥٤٣٤</span>. (١٢/٣٥٤)</p></p><p></div></p><p><div><span class=comment-ref>٥٤٣٤</span> قال <u>ابنُ جرير</u> (١٩/٤٤٧): «قوله تعالى: <span class="qpc-hafs">﴿وإذا قيل لهم اتقوا ما بين أيديكم وما خلفكم لعلكم ترحمون وما تأتيهم من آية من آيات ربهم إلا كانوا عنها معرضين﴾</span> يقول -تعالى ذكره-: وإذا قيل لهؤلاء المشركين بالله، المكذبين رسوله محمدًا ﷺ: احذروا ما مضى بين أيديكم مِن نقم الله ومثلاته بِمَن حلَّ ذلك به مِن الأمم قبلكم أن يحل مثله بكم، بشرككم وتكذيبكم رسوله <span class="qpc-hafs">﴿وما خلفكم﴾</span> يقول: وما بعد هلاككم مما أنتم لاقوه إن هلكتم على كفركم الذي أنتم عليه». <span class="mustanad">واستدل بقول قتادة</span>.</p><p>وذكر <u>ابنُ جرير</u> قول مجاهد، ثم <span class="comment-type-1">وجّهه</span> (١٩/٤٤٩) بقوله: «وهذا القول قريب المعنى مِن القول الذي قلنا؛ لأن معناه: اتقوا عقوبة ما بين أيديكم من ذنوبكم، وما خلفكم مما تعملون من الذنوب، ولم تعملوه بعد، فذلك بعد تخويف لهم العقاب على كفرهم».</p><p>وذكر <u>ابنُ عطية</u> (٧/٢٥١-٢٥٢) نحو قول مجاهد، وعزاه للحسن، و<span class="comment-type-1">وجّهه</span> على النحو الذي وجهه عليه <u>ابن جرير</u>.</p><p>وذكر <u>ابنُ عطية</u> (٤/٤٥٥) قول مقاتل وقول قتادة في معناه، و<span class="comment-type-3">رجّحهما</span> بقوله: «هذا هو النظر». ولم يذكر مستندًا. ثم ذكر قولًا عن مجاهد أنه قال: «<span class="qpc-hafs">﴿ما بين أيديهم﴾</span> هو الآخرة، و<span class="qpc-hafs">﴿ما خلفهم﴾</span> عذاب الأمم». ثم <span class="comment-type-4">علّق</span> عليه قائلًا: «فجعل الترتيب كأنهم يسيرون مِن شيء إلى شيء، ولم يعتبر وجود الأشياء في الزمن». ثم <span class="comment-type-2">انتقده</span> <span class="mustanad">مستندًا إلى النظائر</span> بقوله: «وهذا النظر يكسره عليه قوله تعالى: <span class="qpc-hafs">﴿مُصَدِّقًا لِما بَيْنَ يَدَيْهِ مِنَ التَّوْراةِ وآتَيْناهُ الإنْجِيلَ﴾</span> [المائدة:٤٦]، وإنما المطرد أن يقاس ما بين اليد والخلف بما يسوقه الزمن، فتأمله».</div></p><p><div></p><p><p><span class="item-no">٦٤٧١٧<span class="dash">-</span></span> قال <span class="name-2">إسماعيل السُدِّيّ</span>: <span class="qpc-hafs">﴿اتَّقُوا ما بَيْنَ أيْدِيكُمْ وما خَلْفَكُمْ﴾</span> عذاب الدنيا وعذاب الآخرة؛ <span class="qpc-hafs">﴿لَعَلَّكُمْ تُرْحَمُونَ﴾</span> لكي تُرحموا{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٧١٨<span class="dash">-</span></span> قال <span class="name-3">محمد بن السائب الكلبي</span>: <span class="qpc-hafs">﴿ما بَيْنَ أيْدِيكُمْ﴾</span> من أمر الآخرة، اتقوها واعملوا لها، <span class="qpc-hafs">﴿وما خَلْفَكُمْ﴾</span> الدنيا إذا كنتم في الآخرة، فلا تغتروا بالدنيا، فإنكم تأتون الآخرة{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٧١٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span> <span class="qpc-hafs">﴿وإذا قِيلَ لَهُمُ اتَّقُوا ما بَيْنَ أيْدِيكُمْ﴾</span> يقول: لا يصيبكم مِنّا عذاب الأمم الخالية قبلكم، <span class="qpc-hafs">﴿وما خَلْفَكُمْ﴾</span> واتَّقوا ما بعدكم مِن عذاب الأمم؛ فلا تكذِّبوا محمدًا ﷺ؛ <span class="qpc-hafs">﴿لَعَلَّكُمْ تُرْحَمُونَ﴾</span> لكي تُرحموا{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٧٢٠<span class="dash">-</span></span> عن <span class="name-3">سفيان بن عيينة</span> -من طريق ابن أبي عمر- في قوله: <span class="qpc-hafs">﴿اتقوا مابين أيديكم وماخلفكم﴾</span>: من الآخرة{8}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير الثعلبي ٨/١٢٩، وتفسير البغوي ٧/١٩.|2:تفسير مجاهد (٥٦٠)، وأخرجه ابن جرير ١٩/٤٤٨ بنحوه. وعلقه يحيى بن سلّام ٢/٨١١. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.|3:علقه يحيى بن سلّام ٢/٨١١.|4:أخرجه عبد الرزاق ٢/١٤٤ بنحوه من طريق معمر، وابن جرير ١٩/٤٤٨ بنحوه. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.|5:علقه يحيى بن سلّام ٢/٨١١.|6:علقه يحيى بن سلّام ٢/٨١١.|7:تفسير مقاتل بن سليمان ٣/٥٨٠.|8:أخرجه إسحاق البستي ص١٨٨.
  36,46,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَمَا تَأۡتِیهِم مِّنۡ ءَایَةࣲ مِّنۡ ءَایَـٰتِ رَبِّهِمۡ إِلَّا كَانُوا۟ عَنۡهَا مُعۡرِضِینَ ۝٤٦﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٤٧٢١<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span>: <span class="qpc-hafs">﴿وما تَأْتِيهِمْ مِن آيَةٍ مِن آياتِ رَبِّهِمْ﴾</span> ما يأتيهم من رسول{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٧٢٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وما تَأْتِيهِمْ مِن آيَةٍ مِن آياتِ رَبِّهِمْ إلّا كانُوا عَنْها مُعْرِضِينَ﴾</span> فلا يتفكروا{2}. (ز)</p></p><p></div></p></div>",footnotes:1:علقه يحيى بن سلّام ٢/٨١١.|2:تفسير مقاتل بن سليمان ٣/٥٨٠.
  36,47,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَإِذَا قِیلَ لَهُمۡ أَنفِقُوا۟ مِمَّا رَزَقَكُمُ ٱللَّهُ قَالَ ٱلَّذِینَ كَفَرُوا۟ لِلَّذِینَ ءَامَنُوۤا۟ أَنُطۡعِمُ مَن لَّوۡ یَشَاۤءُ ٱللَّهُ أَطۡعَمَهُۥۤ إِنۡ أَنتُمۡ إِلَّا فِی ضَلَـٰلࣲ مُّبِینࣲ ۝٤٧﴾</span> - نزول الآية، وتفسيرها</h3></p><p><div></p><p><p><span class="item-no">٦٤٧٢٣<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span>، في قوله: <span class="qpc-hafs">﴿أنُطْعِمُ مَن لَوْ يَشاءُ اللَّهُ أطْعَمَهُ﴾</span>، قال: اليهود تقوله{1}. (١٢/٣٥٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٧٢٤<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿وإذا قِيلَ لَهُمْ أنْفِقُوا مِمّا رَزَقَكُمُ اللَّهُ﴾</span>، قال: نزلت في الزنادقة، كانوا لا يُطعمون فقيرًا، فعاب اللهُ ذلك عليهم وعيّرهم{2}. (١٢/٣٥٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٧٢٥<span class="dash">-</span></span> عن <span class="name-2">إسماعيل بن أبي خالد</span>، في قوله: <span class="qpc-hafs">﴿أنُطْعِمُ مَن لَوْ يَشاءُ اللَّهُ أطْعَمَهُ﴾</span>، قال: يهود تقوله{3}. (١٢/٣٥٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٧٢٦<span class="dash">-</span></span> عن <span class="name-3">محمد بن السائب الكلبي</span> -من طريق معمر- في قوله تعالى: <span class="qpc-hafs">﴿وإذا قِيلَ لَهُمْ أنْفِقُوا مِمّا رَزَقَكُمُ اللَّهُ﴾</span>، قال: نزلت في الزنادقة{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٧٢٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وإذا قِيلَ لَهُمْ أنْفِقُوا﴾</span> وذلك أنّ المؤمنين قالوا بمكة لكفار قريش لأبي سفيان وغيره: أنفِقوا على المساكين مِن الذي زعمتم أنه لله. وذلك أنهم كانوا يجعلون نصيبًا لله من الحرث والأنعام بمكة للمساكين، فيقولون هذا لله بزعمهم، ويجعلون للآلهة نصيبًا، فإن لم يَزكُ ما جعلوه للآلهة من الحرث والأنعام، وزكا ما جعلوه لله ﷿، ليس للآلهة شيء، وهي تحتاج إلى نفقة، فأخذوا ما جعلوه لله، قالوا: لو شاء الله لأزكى نصيبه. ولا يعطون المساكين شيئًا مما زكى لآلهتهم، فقال المؤمنون لكفار قريش: <span class="qpc-hafs">﴿أنْفِقُوا مِمّا رَزَقَكُمُ اللَّهُ قالَ الَّذِينَ كَفَرُوا لِلَّذِينَ آمَنُوا﴾</span> فقالت كفار قريش: <span class="qpc-hafs">﴿أنُطْعِم﴾</span> المساكين الذي للآلهة <span class="qpc-hafs">﴿مَن لو يشاء الله أطعمه﴾</span>؟! يعني: رزقه، لو شاء الله لأطعمه، وقالوا لأصحاب النبي ﷺ: <span class="qpc-hafs">﴿إنْ أنْتُمْ إلّا فِي ضَلالٍ مُبِينٍ﴾</span>{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٧٢٨<span class="dash">-</span></span> عن <span class="name-3">مقاتل بن حيان</span>: <span class="qpc-hafs">﴿إنْ أنْتُمْ إلّا فِي ضَلالٍ مُبِينٍ﴾</span> في اتِّباعكم محمدًا، ومخالفتكم ديننا{6}<span class=comment-ref>٥٤٣٥</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٥٤٣٥</span> <span class="comment-type-4">ذكر</span> <u>ابنُ جرير</u> (١٩/٤٥٠) في قوله: <span class="qpc-hafs">﴿إن أنتم إلا في ضلال مبين﴾</span> وجهين، <span class="comment-type-3">رجّح</span> الأول منهما، فقال: «وفي قوله: <span class="qpc-hafs">﴿إن أنتم إلا في ضلال مبين﴾</span> وجهان: <b>أحدهما</b>: أن يكون مِن قيل الكفار للمؤمنين، فيكون تأويل الكلام حينئذ: ما أنتم -أيها القوم- في قيلكم لنا: أنفقوا مما رزقكم الله على مساكينكم. إلا في ذهاب عن الحق، وجَور عن الرشد، مبين لمن تأمله وتدبره أنه في ضلال. وهذا أولى وجهيه بتأويله. <b>والوجه الآخر</b>: أن يكون ذلك مِن قيل الله للمشركين، فيكون تأويله حينئذ: ما أنتم -أيها الكافرون- في قيلكم للمؤمنين: أنطعم من لو يشاء الله أطعمه. إلا في ضلال مبين عن أنّ قيلكم ذلك لهم ضلال».</p><p>و<span class="comment-type-4">بنحوه</span> <u>ابنُ عطية</u> (٧/٢٥٣)، ولم يذكرا مستندًا.</p><p>و<span class="comment-type-2">انتقد</span> <u>ابنُ كثير</u> (١١/٣٦٧) الوجه الثاني من هذين الوجهين بقوله: «وفي هذا نظر».</div></p><p><div></p><p><p><span class="item-no">٦٤٧٢٩<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: قوله ﷿: <span class="qpc-hafs">﴿وإذا قِيلَ لَهُمْ أنْفِقُوا مِمّا رَزَقَكُمُ اللَّهُ﴾</span> وهذا تطوع؛ <span class="qpc-hafs">﴿قالَ الَّذِينَ كَفَرُوا لِلَّذِينَ آمَنُوا أنُطْعِمُ مَن لَوْ يَشاءُ اللَّهُ أطْعَمَهُ﴾</span> فإذا لم يشأ الله أن يُطْعِمَه لِمَ تُطْعمه، <span class="qpc-hafs">﴿إنْ أنْتُمْ إلّا فِي ضَلالٍ مُبِينٍ﴾</span> يقوله المشركون للمؤمنين{7}<span class=comment-ref>٥٤٣٦</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٥٤٣٦</span> <span class="comment-type-4">ذكر</span> <u>ابنُ عطية</u> (٧/٢٥٢-٢٥٣) في معنى الآية احتمالين، فقال: «وقولهم يحتمل معنيين من التأويل: <b>أحدهما</b> يخرج على اختبارات لجهال العرب، فقد رُوِي أنّ أعرابيًا كان يرعى إبله، فيجعل السمان في الخصب، والمهازيل في المكان الجدب، فقيل له في ذلك، فقال: أُكْرِمُ ما أكرم الله، وأُهين ما أهان الله. فيُخَرَّج قولُ قريش على هذا المعنى، كأنهم رأوا الإمساك عمن أمسك الله عنه رزقه، ومن أمثالهم: كن مع الله على المدْبِر». <b>والتأويل الثاني: «</b>أن يكون كلامهم بمعنى الاستهزاء بقول محمد ﷺ: إن ثَمَّ إلهًا هو الرزاق. فكأنهم قالوا: لِمَ لا يرزقك إلهك الذي تزعم؟ أي: نحن لا نطعم من لو يشاء هذا الإله الذي زعمت لأطعمه. وهذا كما يدعي إنسان أنه غني، ثم يحتاج إلى معونتك في مال، فتقول له على جهة الاحتجاج والهزء به: أتطلب معونتي وأنت غني؟! أي: على قولك».</div></p></div>",footnotes:1:عزاه السيوطي إلى ابن أبي حاتم.|2:عزاه السيوطي إلى عبد الرزاق، وعبد بن حميد، وابن جرير، وابن المنذر، وابن أبي حاتم.|3:عزاه السيوطي إلى عبد بن حميد، وابن المنذر.|4:أخرجه عبد الرزاق ٢/١٤٤.|5:تفسير مقاتل بن سليمان ٣/٥٨٠-٥٨١.|6:تفسير الثعلبي ٨/١٣٠.|7:تفسير يحيى بن سلّام ٢/٨١١.
  36,48,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَیَقُولُونَ مَتَىٰ هَـٰذَا ٱلۡوَعۡدُ إِن كُنتُمۡ صَـٰدِقِینَ ۝٤٨﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٤٧٣٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ويَقُولُونَ مَتى هذا الوَعْدُ إنْ كُنْتُمْ صادِقِينَ﴾</span> بأنّ العذاب نازِل بنا في الدنيا{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٧٣١<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: قال: <span class="qpc-hafs">﴿ويَقُولُونَ مَتى هَذا الوَعْدُ﴾</span> أي: هذا العذاب <span class="qpc-hafs">﴿إنْ كُنْتُمْ صادِقِينَ﴾</span> يُكَذِّبون به{2}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٣/٥٨٠.|2:تفسير يحيى بن سلّام ٢/٨١١.
  36,49,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿مَا یَنظُرُونَ إِلَّا صَیۡحَةࣰ وَ ٰ⁠حِدَةࣰ تَأۡخُذُهُمۡ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٤٧٣٢<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُدِّيّ</span>: <span class="qpc-hafs">﴿إلّا صَيْحَةً واحِدَةً﴾</span> يعني: النفخة الأولى مِن إسرافيل، بها يكون هلاكهم{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٧٣٣<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿ما يَنْظُرُونَ إلّا صَيْحَةً واحِدَةً﴾</span>، قال: النفخة نفخة واحدة{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٧٣٤<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: قال الله: <span class="qpc-hafs">﴿ما يَنْظُرُونَ﴾</span> ما ينظر كفارُ آخر هذه الأمة الدائنين بدين أبي جهل وأصحابه <span class="qpc-hafs">﴿إلّا صَيْحَةً واحِدَةً﴾</span> يعني: النفخة الأولى مِن إسرافيل، بها يكون هلاكُهم{3}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿تَأۡخُذُهُمۡ وَهُمۡ یَخِصِّمُونَ ۝٤٩﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٤٧٣٥<span class="dash">-</span></span> عن محمد بن زياد مولى بني جمح -من طريق معمر- في قوله تعالى: <span class="qpc-hafs">﴿صَيْحَةً واحِدَةً تَأْخُذُهُمْ﴾</span>، قال: سمعتُ <span class="name-1">أبا هريرة</span> يقول: إنّ الساعة لَتقوم على الرجلين وهما ينشران الثوبَ يتبايعانه{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٧٣٦<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عمرو</span> -من طريق أبي المغيرة- قال: لَيُنفَخَنَّ في الصور والناسُ في طرقهم وأسواقهم ومجالسهم، حتى إنّ الثوب ليكون بين الرجلين يتساومان، فما يُرسله أحدهما مِن يده حتى ينفخ في الصور، فيصعق به، وحتى إنّ الرجل لَيغدو من بيته فلا يرجع حتى يُنفخ في الصور، وهي التي قال الله: <span class="qpc-hafs">﴿ما يَنْظُرُونَ إلّا صَيْحَةً واحِدَةً تَأْخُذُهُمْ وهُمْ يَخِصِّمُونَ * فَلا يَسْتَطِيعُونَ تَوْصِيَةً ولا إلى أهْلِهِمْ يَرْجِعُونَ﴾</span>{5}. (١٢/٣٥٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٧٣٧<span class="dash">-</span></span> عن <span class="name-2">الضحاك بن مزاحم</span>، في قوله: <span class="qpc-hafs">﴿تَأْخُذُهُمْ وهُمْ يَخِصِّمُونَ﴾</span>، قال: تَذَرُهم في أسواقهم وطرقهم{6}. (١٢/٣٥٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٧٣٨<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span>، في قوله: <span class="qpc-hafs">﴿ما يَنْظُرُونَ إلّا صَيْحَةً واحِدَةً تَأْخُذُهُمْ وهُمْ يَخِصِّمُونَ﴾</span>، قال: ذُكِر لنا: أنّ نبيَّ الله ﷺ كان يقول: «<b>تهيج الساعةُ بالناسِ والرجلُ يسقي ماشيته، والرجل يُصلِحُ حوضَه، والرجل يُقِيم سلعته في سوقه، والرجل يخفض ميزانه ويرفعه، فتهيج بهم وهم كذلك</b>»{7}. (١٢/٣٥٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٧٣٩<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُدِّيّ</span>، في قوله: <span class="qpc-hafs">﴿وهُمْ يَخِصِّمُونَ﴾</span>، قال: يتكلمون{8}. (١٢/٣٥٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٧٤٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: يقول الله ﷿: <span class="qpc-hafs">﴿ما يَنْظُرُونَ إلّا صَيْحَةً واحِدَةً﴾</span> لا مثنوية لها، <span class="qpc-hafs">﴿تَأْخُذُهُمْ وهُمْ يَخِصِّمُونَ﴾</span> وهم يتكلمون في الأسواق والمجالس، وهم أعَزُّ ما كانوا{9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٧٤١<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿تَأْخُذُهُمْ وهُمْ يَخِصِّمُونَ﴾</span> في أسواقهم، يتبايعون، يذرعون الثياب، ويخفض أحدُهم ميزانَه ويرفعه، ويحلبون اللقاح، وغير ذلك مِن حوائجهم{3}. (ز)</p></p><p></div></p></div>",footnotes:1:علقه يحيى بن سلّام ٢/٨١١.|2:أخرجه ابن جرير ١٩/٤٥١.|3:تفسير يحيى بن سلّام ٢/٨١١.|4:أخرجه عبد الرزاق ٢/١٤٤.|5:أخرجه يحيى بن سلّام ٢/٨١٢، وابن جرير ١٩/٤٥١ بدون: فيصعق به. وعزاه السيوطي إلى ابن أبي حاتم.|6:عزاه السيوطي إلى سعيد بن منصور، وابن المنذر.|7:أخرجه ابن جرير ١٩/٤٥١ بنحوه. وعزاه السيوطي إلى عبد بن حميد، وابن أبي حاتم.|8:عزاه السيوطي إلى ابن أبي حاتم.|9:تفسير مقاتل بن سليمان ٣/٥٨١.|10:تفسير يحيى بن سلّام ٢/٨١١.
  36,50,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿فَلَا یَسۡتَطِیعُونَ تَوۡصِیَةࣰ وَلَاۤ إِلَىٰۤ أَهۡلِهِمۡ یَرۡجِعُونَ ۝٥٠﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٤٧٤٢<span class="dash">-</span></span> عن <span class="name-1">الزبير بن العوام</span>، قال: إنّ الساعة تقوم والرجل يذرع الثوب، والرجل يحلب الناقة. ثم قرأ: <span class="qpc-hafs">﴿فَلا يَسْتَطِيعُونَ تَوْصِيَةً﴾</span> الآية{1}. (١٢/٣٥٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٧٤٣<span class="dash">-</span></span> عن <span class="name-1">أبي هريرة</span>، قال: تقوم الساعة والناس في أسواقهم يتبايعون، ويذرعون الثياب، ويحلبون اللقاح، وفي حوائجهم، <span class="qpc-hafs">﴿فَلا يَسْتَطِيعُونَ تَوْصِيَةً ولا إلى أهْلِهِمْ يَرْجِعُونَ﴾</span>{2}. (١٢/٣٥٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٧٤٤<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق أبي صالح- <span class="qpc-hafs">﴿فلا يستطيعون﴾</span>: لا يقدرون. <span class="qpc-hafs">﴿توصية﴾</span>: كلامًا{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٧٤٥<span class="dash">-</span></span> عن <span class="name-2">الضحاك بن مزاحم</span>، في قوله: <span class="qpc-hafs">﴿فَلا يَسْتَطِيعُونَ تَوْصِيَةً﴾</span>، قال: لا يُوصِي بعضُهم إلى بعض{4}. (١٢/٣٥٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٧٤٦<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿فَلا يَسْتَطِيعُونَ تَوْصِيَةً﴾</span>: أي: فيما في أيديهم، <span class="qpc-hafs">﴿ولا إلى أهْلِهِمْ يَرْجِعُونَ﴾</span> قال: أُعجِلُوا عن ذلك{5}. (١٢/٣٥٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٧٤٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فَلا يَسْتَطِيعُونَ تَوْصِيَةً﴾</span> يقول: أُعجِلوا عن التوصية، فماتوا، <span class="qpc-hafs">﴿ولا إلى أهْلِهِمْ يَرْجِعُونَ﴾</span> يقول: ولا إلى منازلهم يرجعون مِن الأسواق، فأخبر الله ﷿ بما يلقون في الأولى، ثم أخبر بما يلقون في الثانية إذا بُعثوا، فذلك قوله ﷿: <span class="qpc-hafs">﴿ونُفِخَ فِي الصُّورِ فَإذا هُمْ مِنَ الأَجْداثِ من القبور إلى رَبِّهِمْ يَنْسِلُونَ﴾</span>{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٧٤٨<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿ما يَنْظُرُونَ إلّا صَيْحَةً واحِدَةً تَأْخُذُهُمْ وهُمْ يَخِصِّمُونَ﴾</span> قال: هذا مبتدأ يوم القيامة. وقرأ: <span class="qpc-hafs">﴿فَلا يَسْتَطِيعُونَ تَوْصِيَةً﴾</span> حتى بلغ <span class="qpc-hafs">﴿إلى رَبِّهِمْ يَنْسِلُونَ﴾</span>{7}. (١٢/٣٥٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٧٤٩<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: قوله ﷿: <span class="qpc-hafs">﴿فَلا يَسْتَطِيعُونَ تَوْصِيَةً﴾</span> أن يوصوا، <span class="qpc-hafs">﴿ولا إلى أهْلِهِمْ يَرْجِعُونَ﴾</span> مِن أسواقهم، وحيث كانوا{8}<span class=comment-ref>٥٤٣٧</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٥٤٣٧</span> <span class="comment-type-4">قال</span> <u>ابنُ عطية</u> (٧/٢٥٤): «وقوله تعالى: <span class="qpc-hafs">﴿ولا إلى أهْلِهِمْ يَرْجِعُونَ﴾</span> يحتمل تأويلات: <b>أحدها</b>: ولا يرجع أحد إلى منزله وأهله؛ لإعجال الأمر، بل تفيض نفسه حيثما أخذته الصيحة. <b>والثاني</b>: معناه: <span class="qpc-hafs">﴿ولا إلى أهْلِهِمْ يَرْجِعُونَ﴾</span> قولًا، وهذا أبلغ في الاستعجال، وخص الأهل بالذكر لأنّ القول معهم في ذلك الوقت أهم على الإنسان من الأجنبيين، وأوكد في نفوس البشر. و<b>الثالث</b>: تقديره: <span class="qpc-hafs">﴿ولا إلى أهْلِهِمْ يَرْجِعُونَ﴾</span> أبدًا، فخرج هذا عن معنى وصف الاستعجال إلى معنى ذكر انقطاعهم وانبتارهم من دنياهم».</div></p><p><h3><span class="qpc-hafs">﴿فَلَا یَسۡتَطِیعُونَ تَوۡصِیَةࣰ وَلَاۤ إِلَىٰۤ أَهۡلِهِمۡ یَرۡجِعُونَ ۝٥٠﴾</span> - آثار متعلقة بالآيتين</h3></p><p><div></p><p><p><span class="item-no">٦٤٧٥٠<span class="dash">-</span></span> عن أبي هريرة، قال: قال رسول الله ﷺ: «<b>لَتَقُومَنَّ الساعةُ وقد نشر الرجلان ثوبهما بينهما، فلا يتبايعانه، ولا يطويانه، ولتقومن الساعة وهو يليط حوضه</b>{9}، <b>فلا يسقي فيه، ولتقومن الساعة وقد انصرف الرجلُ بلبن لقحته، فلا يطعمه، ولتقومن الساعة وقد رفع أكلته إلى فيه، فلا يطعمها</b>»{10}. (١٢/٣٥٧)</p></p><p></div></p></div>",footnotes:1:عزاه السيوطي إلى عبد الله بن أحمد في زوائد الزهد، وعبد بن حميد، وابن المنذر.|2:عزاه السيوطي إلى عبد الرزاق، والفريابي، وعبد بن حميد، وابن المنذر، وابن مردويه. وأخرج نحوه يحيى بن سلّام في تفسيره ٢/٨١٢ من طريق أبي المُهَزِّم دون ذكر الآية بلفظ: تقوم الساعة والرجلان في السوق وميزانهما في أيديهما.|3:أخرجه البيهقي في شعب الإيمان ٢/٢٠٦-٢٠٧ (٣٥٠).|4:عزاه السيوطي إلى سعيد بن منصور، وابن المنذر.|5:أخرجه ابن جرير ١٩/٤٥١. وعزاه السيوطي إلى عبد بن حميد، وابن أبي حاتم.|6:تفسير مقاتل بن سليمان ٣/٥٨١.|7:أخرجه ابن جرير ١٩/٤٥٤ -وأورده تحت تفسير هذه الآية-. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.|8:تفسير يحيى بن سلّام ٢/٨١٢.|9:يُليط حوضه: جمع حجارة فصيَّرها كالحوض، ثم سد ما بينها من الفُرَج بالمدر ونحوه لينحبس الماء. فتح الباري ١١/٣٥٧.|10:أخرجه البخاري ٨/١٠٦ (٦٥٠٦)، ٩/٥٩ (٧١٢١)، ومسلم ٤/٢٢٧٠(٢٩٥٤)، ويحيى بن سلام في تفسيره ٢/٨١٢.
  36,51,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَنُفِخَ فِی ٱلصُّورِ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٤٧٥١<span class="dash">-</span></span> عن <span class="name-3">عبد الملك ابن جريج</span>، في قوله: <span class="qpc-hafs">﴿ونُفِخَ فِي الصُّورِ فَإذا هُمْ مِنَ الأَجْداثِ﴾</span>، قال: النفخة الأخيرة{1}. (١٢/٣٥٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٧٥٢<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: قوله ﷿: <span class="qpc-hafs">﴿ونُفِخَ فِي الصُّورِ﴾</span> وهذه النفخة الآخرة. والصور: قرن{2}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿فَإِذَا هُم مِّنَ ٱلۡأَجۡدَاثِ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٤٧٥٣<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي-: <span class="qpc-hafs">﴿فَإذا هُمْ مِنَ الأَجْداثِ﴾</span>، يعني: مِن القبور{3}. (١٢/٣٥٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٧٥٤<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد-، مثله{4}. (١٢/٣٥٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٧٥٥<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، أنّ نافع بن الأزرق سأله عن قوله: <span class="qpc-hafs">﴿مِنَ الأَجْداثِ﴾</span>. قال: القبور. قال: وهل تعرف العرب ذلك؟ قال: نعم، أما سمعت قول ابن رواحة:</p><p>حينًا يقولون إذ مرُّوا على جَدَثي أرشده يا رب مِن عانٍ وقد رشدا{5}. (١٢/٣٥٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٧٥٦<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق ميمون المرائي- يقول: <span class="qpc-hafs">﴿ونُفِخَ فِي الصُّورِ فَإذا هُمْ مِنَ الأَجْداثِ إلى رَبِّهِمْ يَنْسِلُونَ﴾</span>، قال: وثَبَ القومُ مِن قبورهم لَمّا سمعوا الصيحة، ينفضون التراب عن رؤوسهم، ويقول المؤمنون: سبحانك وبحمدك، ما عبدناك حقَّ عبادتك{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٧٥٧<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- قال: <span class="qpc-hafs">﴿ونُفِخَ فِي الصُّورِ﴾</span> في الخلق <span class="qpc-hafs">﴿فَإذا هُمْ مِنَ الأَجْداثِ إلى رَبِّهِمْ يَنْسِلُونَ﴾</span> فإذا هم مِن القبور إلى ربِّهم يخرجون، يعني: جميع الخلق{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٧٥٨<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ونُفِخَ فِي الصُّورِ فَإذا هُمْ مِنَ الأَجْداثِ من القبور إلى رَبِّهِمْ يَنْسِلُونَ﴾</span> يخرجون إلى الله ﷿ مِن قبورهم أحياءً، فلمّا رأوا العذابَ ذكروا قولَ الرسل في الدنيا: إنّ البعث حقٌّ{8}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿إِلَىٰ رَبِّهِمۡ یَنسِلُونَ ۝٥١﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٤٧٥٩<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- <span class="qpc-hafs">﴿إلى رَبِّهِمْ يَنْسِلُونَ﴾</span>، قال: يخرجون{3}. (١٢/٣٥٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٧٦٠<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد-، مثله{10}. (١٢/٣٥٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٧٦١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، أنّ نافع بن الأزرق سأله عن قوله: <span class="qpc-hafs">﴿إلى رَبِّهِمْ يَنْسِلُونَ﴾</span>. قال: النسل: المشي الخَبَب{11}. قال: وهل تعرف العرب ذلك؟ قال: نعم، أما سمعت نابغة بني جعدة وهو يقول:</p><p>عَسَلانَ{12} الذئب أمسى قاربًا{13} بَرَدَ الليلُ عليه فنَسَلْ{14}. (١٢/٣٥٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٧٦٢<span class="dash">-</span></span> عن <span class="name-3">محمد بن السائب الكلبي</span> -من طريق معمر- في قوله تعالى: <span class="qpc-hafs">﴿يَنْسِلُونَ﴾</span>، قال: يزفون على أقدامهم{15}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٧٦٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ونُفِخَ فِي الصُّورِ فَإذا هُمْ مِنَ الأَجْداثِ من القبور إلى رَبِّهِمْ يَنْسِلُونَ﴾</span> يخرجون{8}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿إِلَىٰ رَبِّهِمۡ یَنسِلُونَ ۝٥١﴾</span> - آثار متعلقة بتفسير الآية</h3></p><p><div></p><p><p><span class="item-no">٦٤٧٦٤<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span> -من طريق الجريري- قال: النفخة الأولى مِن الدنيا، والنفخة الثانية من الآخرة{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٧٦٥<span class="dash">-</span></span> قال <span class="name-2">الحسن البصري</span>: القيامة: اسم جامع يجمع النفختين جميعًا{18}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٧٦٦<span class="dash">-</span></span> عن مَعَدِّيِّ بن سليمان، قال: كان <span class="name-3">أبو محلم الحري</span> يجتمع إليه إخوانُه، وكان حكيمًا، فكان إذا تلا هذه الآية: <span class="qpc-hafs">﴿ونُفِخَ فِي الصُّورِ فَإذا هُمْ مِنَ الأَجْداثِ إلى رَبِّهِمْ يَنْسِلُونَ﴾</span> بكى، ثم قال: إنّ القيامة في كتاب الله لَمَعاريض، صِفَةٌ ذهبت فظاعتُها بأوهام العقول، أما -واللهِ- لئن كان القومُ في رقدة مثل ظاهر قولهم لَما دَعَوا بالويل عند أول وهْلة مِن بعْثهم، ولم يوقفوا بعد موقف عرض ولا مسألة إلا وقد عاينوا خطرًا عظيمًا، وحققت عليهم القيامة بالجلائل مِن أمرها، ولئن كانوا في طول الإقامة في البرزخ يألمون ويُعذَّبون في قبورهم فما دعَوا بالويل عند انقطاع ذلك عنهم إلا وقد نُقلوا إلى ظلمة هي أعظم منه، ولولا أنّ الأمر على ذلك لما استصغر القومُ ما كانوا فيه؛ فسَمَّوه: رُقادًا، وإنّ في القرآن دليلًا على ذلك حين يقول: <span class="qpc-hafs">﴿فَإذا جاءَتِ الطّامَّةُ الكُبْرى﴾</span> [النازعات:٣٤]. قال: ثم يبكي حتى تبلَّ لحيته{19}. (ز)</p></p><p></div></p></div>",footnotes:1:عزاه السيوطي إلى ابن المنذر.|2:تفسير يحيى بن سلّام ٢/٨١٢.|3:أخرجه ابن جرير ١٩/٤٥٥. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.|4:أخرجه ابن جرير ١٩/٤٥٥. وعزاه السيوطي إلى عبد بن حميد.|5:أخرجه الطستي -كما في الإتقان ٢/٩٧-.|6:أخرجه ابن أبي الدنيا في كتاب القبور -موسوعة الإمام ابن أبي الدنيا ٦/٧١ (٨٠)-. وأخرجه في كتاب الأهوال ٦/١٧١ (٨٥) إلى قوله: ينفضون التراب.|7:أخرجه يحيى بن سلّام ٢/٨١٣.|8:تفسير مقاتل بن سليمان ٣/٥٨١.|9:أخرجه ابن جرير ١٩/٤٥٥. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.|10:أخرجه يحيى بن سلّام ٢/٨١٣، وابن جرير ١٩/٤٥٥-٤٥٦. وعزاه السيوطي إلى عبد بن حميد.|11:الخَبَبُ: ضرب من العَدْوِ، أي: الإسراع في المشي. التاج (خبب).|12:عسل الذئب عسلًا، وعسلانًا: مضى مسرعًا واضطرب عدوه وهز رأسه. اللسان (عسل).|13:قارب الخَطْو: داناه، والتقريب: أن يرفع الفرس يديه معًا ويضعهما معًا. اللسان (قرب).|14:عزاه السيوطي إلى الطستي.|15:أخرجه عبد الرزاق ٢/١٤٤.|16:تفسير مقاتل بن سليمان ٣/٥٨١.|17:أخرجه يحيى بن سلّام ٢/٨١٣.|18:علقه يحيى بن سلّام ٢/٨١٤.|19:أخرجه ابن أبي الدنيا في كتاب الأهوال -موسوعة الإمام ابن أبي الدنيا ٦/١٧٢ (٨٧)-.
  36,52,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿قَالُوا۟ یَـٰوَیۡلَنَا مَنۢ بَعَثَنَا مِن مَّرۡقَدِنَاۜۗ﴾</span> - قراءات</h3></p><p><div></p><p><p><span class="item-no">٦٤٧٦٧<span class="dash">-</span></span> عن <span class="name-1">أُبَيّ بن كعب</span>، أنه قرأ: (يا ويْلَنا مَن هَبَّنا مِن مَّرْقَدِنا){1}<span class=comment-ref>٥٤٣٨</span>. (١٢/٣٥٩)</p></p><p></div></p><p><div><span class=comment-ref>٥٤٣٨</span> <span class="comment-type-4">ذكر</span> <u>ابنُ عطية</u> (٧/٢٥٦) قراءة أبي بن كعب، ونقل تعليق أبي الفتح عليها، فقال: «وفي قراءة أبي بن كعب (مَن هَبَّنا) قال أبو الفتح: ولم أر لها في اللغة أصلًا، ولا مرَّ بنا: مهبوب».</div></p><p><div></p><p><p><span class="item-no">٦٤٧٦٨<span class="dash">-</span></span> قال سفيان: كان <span class="name-1">عبد الله [بن مسعود]</span> يقرؤها: (مَن أهَبَّنا مِن مَّرْقَدِنا){2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٧٦٩<span class="dash">-</span></span> في قراءة <span class="name-1">عبد الله بن مسعود</span>: (مِن مِّيتَتِنا){3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٧٧٠<span class="dash">-</span></span> عن <span class="name-1">علي بن أبي طالب</span>، أنه قرأ: (يا ويْلَنا مِن بَعْثِنا مِن مَّرْقَدِنا){4}. (١٢/٣٥٩)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿قَالُوا۟ یَـٰوَیۡلَنَا مَنۢ بَعَثَنَا مِن مَّرۡقَدِنَاۜۗ﴾</span> - تفسير الآية</h3></p><p><div></p><p><p><span class="item-no">٦٤٧٧١<span class="dash">-</span></span> عن <span class="name-1">أُبَيّ بن كعب</span>، قال: ينامون نومةً قبل البعث، فيجدون لذلك راحة، فيقولون: (يا ويْلَنا مَن هَبَّنا مِن مَّرْقَدِنا)؟!{5}. (١٢/٣٥٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٧٧٢<span class="dash">-</span></span> عن <span class="name-1">أُبَيّ بن كعب</span> -من طريق الحسن- في قوله: <span class="qpc-hafs">﴿يا ويْلَنا مَن بَعَثَنا مِن مَرْقَدِنا﴾</span>، قال: ينامون قبل البعث نَوْمَةً{6}<span class=comment-ref>٥٤٣٩</span>. (١٢/٣٥٩)</p></p><p></div></p><p><div><span class=comment-ref>٥٤٣٩</span> ذكر <u>ابنُ عطية</u> (٧/٢٥٦) قول أبي بن كعب ونحوه عن قتادة ومجاهد، ثم <span class="comment-type-2">انتقده</span> <span class="mustanad">مستندًا إلى ضعف إسناده</span>، فقال: «ويروى عن أبي بن كعب، وقتادة، ومجاهد: أنّ جميع البشر ينامون نومة قبل الحشر. وهذا غير صحيح الإسناد». <span class="comment-type-3">ورجّح</span> <span class="mustanad">مستندًا إلى اللغة</span> أن ذلك على سبيل الاستعارة والتشبيه، فقال: «وإنما الوجه في قولهم: <span class="qpc-hafs">﴿مِن مَرْقَدِنا﴾</span> أنها استعارة وتشبيه، كما تقول في قتيلٍ: هذا مرقده إلى يوم القيامة».</div></p><p><div></p><p><p><span class="item-no">٦٤٧٧٣<span class="dash">-</span></span> قال <span class="name-1">أُبَيّ بن كعب</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٧٧٤<span class="dash">-</span></span> و<span class="name-1">عبد الله بن عباس</span>: <span class="qpc-hafs">﴿يا ويْلَنا مَن بَعَثَنا مِن مَرْقَدِنا﴾</span> إنّما يقولون هذا لأنّ الله تعالى يرفع عنهم العذاب بين النفختين، فيرقدون، فإذا بُعِثوا بعد النفخة الأخيرة وعاينوا القيامة دَعَوْا بالويل{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٧٧٥<span class="dash">-</span></span> عن <span class="name-2">أبي صالح باذام</span> -من طريق الأعمش- <span class="qpc-hafs">﴿يا ويْلَنا مَن بَعَثَنا مِن مَرْقَدِنا﴾</span> قال: كانوا يرون أنّ العذاب يُخَفَّف عنهم ما بين النفختين، فلمّا كانت النفخة الثانية قالوا: <span class="qpc-hafs">﴿يا ويْلَنا مَن بَعَثَنا مِن مَرْقَدِنا﴾</span>{8}. (١٢/٣٦٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٧٧٦<span class="dash">-</span></span> قال <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد بن بشير-: إنّه لا يُفَتَّر عن أهل القبور عذابُ القبر إلا فيما بين نفخة الصعق ونفخة البعث، فلذلك يقول الكافر حين يبعث: <span class="qpc-hafs">﴿يا ويْلَنا مَن بَعَثَنا مِن مَرْقَدِنا﴾</span> يعني: تلك الفترة، فيقول المؤمن: <span class="qpc-hafs">﴿هَذا ما وعَدَ الرَّحْمَنُ وصَدَقَ المُرْسَلُونَ﴾</span>{9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٧٧٧<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد بن أبي عروبة- قال: الكافر إلى جنب المؤمن، فإذا أصابته النفخةُ قال الكافر: <span class="qpc-hafs">﴿يا ويلنا من بعثنا من مرقدنا هذا ما وعد الرحمن وصدق المرسلون﴾</span>{10}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٧٧٨<span class="dash">-</span></span> عن منصور، عن رجل يُقال له: خيثمة، في قوله: <span class="qpc-hafs">﴿قالوا يا ويلنا من بعثنا من مرقدنا هذا﴾</span>، قال: ينامون نومة قبل البعث{11}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٧٧٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿قالُوا يا ويْلَنا مَن بَعَثَنا مِن مَرْقَدِنا﴾</span>، وذلك أنّ أرواح الكفار كانوا يُعرَضون على منازلهم مِن النار طَرَفَي النهار كلَّ يوم، فلما كان بين النفختين رُفِع عنهم العذاب، فرقدت تلك الأرواح بين النفختين، فلمّا بُعِثوا في النفخة الأخرى وعاينوا في القيامة ما كذَّبوا به في الدنيا من البعث والحساب فدَعَوْا بالويل، <span class="qpc-hafs">﴿قالُوا يا ويْلَنا مَن بَعَثَنا مِن مَرْقَدِنا﴾</span>{12}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٧٨٠<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: وقولهم: <span class="qpc-hafs">﴿مَن بَعَثَنا مِن مَرْقَدِنا﴾</span> وهو ما بين النفختين، لا يُعذّبون في قبورهم بين النفختين، ويُقال: إنها أربعون سنة، فلذلك قالوا: <span class="qpc-hafs">﴿يا ويْلَنا مَن بَعَثَنا مِن مَرْقَدِنا﴾</span>. وذلك أنه إذا نفخ النفخة الأولى قيل له: اخمد. فيخمد إلى النفخة الآخرة{13}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿قَالُوا۟ یَـٰوَیۡلَنَا مَنۢ بَعَثَنَا مِن مَّرۡقَدِنَاۜۗ هَـٰذَا مَا وَعَدَ ٱلرَّحۡمَـٰنُ وَصَدَقَ ٱلۡمُرۡسَلُونَ ۝٥٢﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٤٧٨١<span class="dash">-</span></span> عن <span class="name-2">عبد الرحمن بن أبي ليلى</span> -من طريق ثابت- قال: يقول المشركون: <span class="qpc-hafs">﴿يا ويْلَنا مَن بَعَثَنا مِن مَرْقَدِنا﴾</span>؟! فيقول المؤمن: <span class="qpc-hafs">﴿هَذا ما وعَدَ الرَّحْمَنُ وصَدَقَ المُرْسَلُونَ﴾</span>{14}. (١٢/٣٥٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٧٨٢<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- قوله: <span class="qpc-hafs">﴿يا ويْلَنا مَن بَعَثَنا مِن مَرْقَدِنا﴾</span> قال: الكافرون يقولونه، <span class="qpc-hafs">﴿هَذا ما وعَدَ الرَّحْمَنُ﴾</span> مما سرَّ المؤمنون، يقولون هذا حين البعث{15}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٧٨٣<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ليث- قال: للكفار هجْعة يجدون فيها طعم النوم قبل يوم القيامة، فإذا صِيح بأهل القبور يقول الكافر: <span class="qpc-hafs">﴿يا ويْلَنا مَن بَعَثَنا مِن مَرْقَدِنا﴾</span>؟ فيقول المؤمن إلى جنبه: <span class="qpc-hafs">﴿هَذا ما وعَدَ الرَّحْمَنُ وصَدَقَ المُرْسَلُونَ﴾</span>{16}. (١٢/٣٥٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٧٨٤<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span>، قال: ينامون قبل البعث نومة، فإذا بُعِثوا قال الكفار: <span class="qpc-hafs">﴿يا ويْلَنا مَن بَعَثَنا مِن مَرْقَدِنا﴾</span>؟ قال: فتجيبهم الملائكة: <span class="qpc-hafs">﴿هَذا ما وعَدَ الرَّحْمَنُ وصَدَقَ المُرْسَلُونَ﴾</span>{17}. (١٢/٣٦٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٧٨٥<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿يا ويْلَنا مَن بَعَثَنا مِن مَرْقَدِنا﴾</span> قال: أولها للكفار، وآخرها للمسلمين؛ قال الكفار: <span class="qpc-hafs">﴿يا ويْلَنا مَن بَعَثَنا مِن مَرْقَدِنا﴾</span>؟ وقال المسلمون: <span class="qpc-hafs">﴿هَذا ما وعَدَ الرَّحْمَنُ وصَدَقَ المُرْسَلُونَ﴾</span>{18}. (١٢/٣٦٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٧٨٦<span class="dash">-</span></span> وعن <span class="name-1">أُبَيّ بن كعب</span> -من طريق الحسن-، مثل ذلك{19}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٧٨٧<span class="dash">-</span></span> عن <span class="name-2">زيد بن أسلم</span> -من طريق عثمان- قال: قال الكفار: <span class="qpc-hafs">﴿يا ويْلَنا مَن بَعَثَنا مِن مَرْقَدِنا﴾</span>؟ قالت الملائكة: <span class="qpc-hafs">﴿هَذا ما وعَدَ الرَّحْمَنُ وصَدَقَ المُرْسَلُونَ﴾</span>{20}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٧٨٨<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: فلمّا بُعثوا في النفخة الأخرى وعاينوا في القيامة ما كذَّبوا به في الدنيا مِن البعث والحساب فَدَعَوا بالويل، <span class="qpc-hafs">﴿قالُوا يا ويْلَنا مَن بَعَثَنا مِن مَرْقَدِنا﴾</span>؟ قال حفظتهم من الملائكة: <span class="qpc-hafs">﴿هَذا ما وعَدَ الرَّحْمنُ﴾</span> على ألسنة الرسل. فذلك قوله ﷿: <span class="qpc-hafs">﴿وصَدَقَ المُرْسَلُونَ﴾</span>{12}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٧٨٩<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿يا ويْلَنا مَن بَعَثَنا مِن مَرْقَدِنا﴾</span>: ثم قال بعضهم لبعض: <span class="qpc-hafs">﴿هَذا ما وعَدَ الرَّحْمَنُ وصَدَقَ المُرْسَلُونَ﴾</span> كانوا أخبرونا أنّا نُبعث بعد الموت، ونُحاسب، ونُجازى{22}<span class=comment-ref>٥٤٤٠</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٥٤٤٠</span> اختُلف في قائل هذه المقالة: <span class="qpc-hafs">﴿هذا ما وعد الرحمن وصدق المرسلون﴾</span> على أقوال: <b>الأول</b>: أنهم المؤمنون. <b>الثاني</b>: أنهم الكفار. <b>الثالث</b>: أنهم الملائكة.</p><p>وقد <span class="comment-type-3">رجّح</span> <u>ابنُ جرير</u> (١٩/٤٥٨) <span class="mustanad">مستندًا إلى الدلالة العقلية</span> القولَ الأول، فقال: «والقول الأول أشبه بظاهر التنزيل، وهو أن يكون من كلام المؤمنين؛ لأن الكفار في قيلهم: <span class="qpc-hafs">﴿من بعثنا من مرقدنا﴾</span> دليل على أنهم كانوا بمن بعثهم من مرقدهم جهالًا، ولذلك مِن جهلهم استثبتوا، ومحال أن يكونوا استثبتوا ذلك إلا مِن غيرهم مِمَّن خالفت صفتُه صفتَهم في ذلك».</p><p>وكذا <span class="comment-type-3">رجّح</span> <u>ابنُ كثير</u> (١١/٣٦٨) <span class="mustanad">مستندًا إلى النظائر</span> القول الأول بقوله: «وهو أصح، وذلك كقوله تعالى في الصافات: <span class="qpc-hafs">﴿وقالوا يا ويلنا هذا يوم الدين هذا يوم الفصل الذي كنتم به تكذبون﴾</span> [الصافات:٢٠-٢١]، وقال الله تعالى: <span class="qpc-hafs">﴿ويوم تقوم الساعة يقسم المجرمون ما لبثوا غير ساعة كذلك كانوا يؤفكون * وقال الذين أوتوا العلم والإيمان لقد لبثتم في كتاب الله إلى يوم البعث فهذا يوم البعث ولكنكم كنتم لا تعلمون﴾</span> [الروم:٥٥-٥٦]».</p><p>وذكر <u>ابنُ كثير</u> القول الأول والثالث، و<span class="comment-type-4">علّق</span> عليهما قائلًا: «ولا منافاة؛ إذ الجمع ممكن».</div></p><p><div></p><p><p><span class="item-no">٦٤٧٩٠<span class="dash">-</span></span> قال <span class="name-3">سفيان</span> -من طريق إسحاق بن إسماعيل-: هذا موصول مفصول{23}. (ز)</p></p><p></div></p></div>",footnotes:1:عزاه السيوطي إلى ابن الأنباري.</p><p>وهي قراءة شاذة. انظر: المحتسب ٢/٢١٣.|2:تفسير سفيان الثوري (٢٥٠)، وذكره ابن جرير في تفسيره ١٩/٤٥٧.</p><p>وهي قراءة شاذة. انظر: المحتسب ٢/٢١٣.|3:تفسير مقاتل بن سليمان ٣/٥٨٢. وقد وقعت فيه القراءة كما أثبتنا، والظاهر أنها مصحَّفة عن (هبَّنا)، كما نسب إليه في مختصر ابن خالويه ص١٢٥.|4:عزاه السيوطي إلى ابن الأنباري في المصاحف.</p><p>وهي قراءة شاذة، تروى أيضًا عن الضحاك، وأبي نهيك. انظر: المحتسب ٢/٢١٣، ومختصر ابن خالويه ص١٢٦.|5:عزاه السيوطي إلى ابن الأنباري.|6:أخرجه ابن جرير ١٩/٤٥٦، وإسحاق البستي ص١٩١ من طريق خيثمة. وعزاه السيوطي إلى الفريابي، وعبد بن حميد، وابن المنذر، وابن أبي حاتم.|7:تفسير البغوي ٧/٢١.|8:أخرجه ابن أبي شيبة في مصنفه (ت: محمد عوامة) ١٩/٤١١ (٣٦٥١٣). وعزاه السيوطي إلى ابن المنذر.|9:أخرجه ابن أبي الدنيا في كتاب الأهوال -موسوعة الإمام ابن أبي الدنيا ٦/١٧٢-١٧٣ (٨٨)-.|10:أخرجه إسحاق البستي ص١٩١.|11:أخرجه إسحاق البستي ص١٩١، وابن جرير ١٩/٤٥٦.|12:تفسير مقاتل بن سليمان ٣/٥٨٢.|13:تفسير يحيى بن سلّام ٢/٨١٣.|14:أخرجه ابن أبي شيبة ١٣/٤٢٧.|15:تفسير مجاهد (٥٦٠)، وأخرجه ابن جرير ١٩/٤٥٧-٤٥٨.|16:أخرجه هناد في الزهد (٣١٧). وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم، وابن الأنباري.|17:عزاه السيوطي إلى ابن أبي حاتم.|18:أخرجه يحيى بن سلام ٢/٨١٣ بنحوه -وينظر: المكتفى ص١٧٥ (٢٨)-، وعبد الرزاق ٢/١٤٤-١٤٥ من طريق معمر، وابن أبي الدنيا في كتاب الأهوال -موسوعة الإمام ابن أبي الدنيا ٦/١٧١-١٧٢ (٨٦)-، وابن جرير ١٩/٤٥٦، ٤٥٨ بنحوه. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.|19:أخرجه يحيى بن سلّام ٢/٨١٣.|20:أخرجه يحيى بن سلّام ٢/٨١٣، وعقَّب عليه بقوله: وبعضهم يقول: هم الملائكة الذين كانوا يكتبون أعمالهم.|21:تفسير مقاتل بن سليمان ٣/٥٨٢.|22:أخرجه ابن جرير ١٩/٤٥٨.|23:أخرجه ابن أبي الدنيا في كتاب الأهوال -موسوعة الإمام ابن أبي الدنيا ٦/١٧١-١٧٢ (٨٦)-. ونصه: هذا موصول مفضول. والظاهر أن «مفضول» تصحيف عن «مفصول»، وأن المراد: أن الآية مِن الموصول لفظًا المفصول معنى. ينظر في بيان هذا النوع من أنواع علوم القرآن: الإتقان ١/٢٣٦.
  36,53,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿إِن كَانَتۡ إِلَّا صَیۡحَةࣰ وَ ٰ⁠حِدَةࣰ فَإِذَا هُمۡ جَمِیعࣱ لَّدَیۡنَا مُحۡضَرُونَ ۝٥٣﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٤٧٩١<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿فَإذا هُمْ جَمِيعٌ لَدَيْنا مُحْضَرُونَ﴾</span>، قال: عند الحساب{1}. (١٢/٣٦٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٧٩٢<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُدِّيّ</span>: <span class="qpc-hafs">﴿إنْ كانَتْ﴾</span> يعني: ما كانت <span class="qpc-hafs">﴿إلّا صَيْحَةً واحِدَةً﴾</span> قال: وكذلك كل «إن» خفيفة تستقبلها «إلا»{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٧٩٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: وذكر النفخة الثانية، فقال سبحانه: <span class="qpc-hafs">﴿إنْ﴾</span> يعني: ما <span class="qpc-hafs">﴿كانَتْ إلّا صَيْحَةً واحِدَةً﴾</span> مِن إسرافيل؛ <span class="qpc-hafs">﴿فَإذا هُمْ جَمِيعٌ﴾</span> الخلق كلهم <span class="qpc-hafs">﴿لَدَيْنا﴾</span> عندنا <span class="qpc-hafs">﴿مُحْضَرُونَ﴾</span> بالأرض المقدسة فلسطين؛ لنحاسبهم{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٧٩٤<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: قوله ﷿: <span class="qpc-hafs">﴿إنْ كانَتْ إلّا صَيْحَةً واحِدَةً﴾</span> مِن إسرافيل، يعني: النفخة الثانية، يعني: القيامة؛ <span class="qpc-hafs">﴿فَإذا هُمْ جَمِيعٌ﴾</span> المؤمنون والكافرون <span class="qpc-hafs">﴿لَدَيْنا﴾</span> عندنا <span class="qpc-hafs">﴿مُحْضَرُونَ﴾</span>{4}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه الفريابي -كما في التغليق ٣/٥١٤-. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.|2:علقه يحيى بن سلّام ٢/٨١٤.|3:تفسير مقاتل بن سليمان ٣/٥٨٢.|4:تفسير يحيى بن سلّام ٢/٨١٤.
  36,54,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿فَٱلۡیَوۡمَ لَا تُظۡلَمُ نَفۡسࣱ شَیۡـࣰٔا وَلَا تُجۡزَوۡنَ إِلَّا مَا كُنتُمۡ تَعۡمَلُونَ ۝٥٤﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٤٧٩٥<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُدِّيّ</span>: <span class="qpc-hafs">﴿فاليَوْمَ﴾</span> يعني: في الآخرة، يقوله يومئذ{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٤٧٩٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فاليَوْمَ﴾</span> في الآخرة <span class="qpc-hafs">﴿لا تُظْلَمُ نَفْسٌ شَيْئًا ولا تُجْزَوْنَ إلّا ما كُنْتُمْ تَعْمَلُونَ﴾</span> مِن الكُفْر، جزاء الكافر النار{2}. (ز)</p></p><p></div></p></div>",footnotes:1:علقه يحيى بن سلّام ٢/٨١٤.|2:تفسير مقاتل بن سليمان ٣/٥٨٢.