tafsir[14]{c,v,t}:
36,41," <q>﴿وَءَایَةࣱ لَّهُمۡ أَنَّا حَمَلۡنَا ذُرِّیَّتَهُمۡ فِی ٱلۡفُلۡكِ ٱلۡمَشۡحُونِ ۝٤١﴾</q> - تفسير ٦٤٦٧٣- عن عبد الله بن عباس -من طريق سعيد بن جبير- <q>﴿فِي الفُلْكِ المَشْحُونِ﴾</q>، قال: أتدرون ما الفُلك المشحون؟ قلنا: لا. قال: هو المُوقر{1}. (ز) ٦٤٦٧٤- عن عبد الله بن عباس -من طريق علي- قوله: <q>﴿أنّا حَمَلْنا ذُرِّيَّتَهُمْ فِي الفُلْكِ المَشْحُونِ﴾</q>، يقول: المُمْتَلِئ{2}. (ز) ٦٤٦٧٥- عن عبد الله بن عباس -من طريق عطية- قوله: <q>﴿فِي الفُلْكِ المَشْحُونِ﴾</q>: يعني: المُثقل{2}. (ز) ٦٤٦٧٦- عن سعيد بن جبير -من طريق عطاء- <q>﴿الفُلْكِ المَشْحُونِ﴾</q>، قال: الموقر{2}. (ز) ٦٤٦٧٧- عن الضحاك بن مزاحم -من طريق عبيد- يقول في قوله: <q>﴿أنّا حَمَلْنا ذُرِّيَّتَهُمْ فِي الفُلْكِ المَشْحُونِ﴾</q>: يعني: سفينة نوح ﵇{1}. (ز) ٦٤٦٧٨- عن الضَّحّاك بن مُزاحِم -من طريق جُوَيْبِر- في قوله: <q>﴿الفُلْكِ المَشْحُونِ﴾</q>، قال: المُوقر{1}. (ز) ٦٤٦٧٩- عن أبي مالك غزوان الغفاري، في قوله: <q>﴿وآيَةٌ لَهُمْ أنّا حَمَلْنا ذُرِّيَّتَهُمْ فِي الفُلْكِ المَشْحُونِ﴾</q>، قال: سفينة نوح؛ حمل فيها من كل زوجين اثنين{7}. (١٢/٣٥٢) ٦٤٦٨٠- عن الحسن البصري -من طريق يونس- في قوله: <q>﴿المَشْحُونِ﴾</q>، قال: المحمول{2}. (ز) ٦٤٦٨١- عن الحسن البصري -من طريق الحسن بن دينار- <q>﴿المَشْحُونِ﴾</q>: المُوقر بحمله، يقول: مما حمل نوح معه في السفينة{9}. (ز) ٦٤٦٨٢- عن أبي صالح باذام، في قوله: <q>﴿حَمَلْنا ذُرِّيَّتَهُمْ فِي الفُلْكِ المَشْحُونِ﴾</q>، قال: سفينة نوح{10}. (١٢/٣٥٣) ٦٤٦٨٣- عن قتادة بن دعامة -من طريق سعيد- قوله: <q>﴿وآيَةٌ لَهُمْ أنّا حَمَلْنا ذُرِّيَّتَهُمْ فِي الفُلْكِ المَشْحُونِ﴾</q>: المُوقر، يعني: سفينة نوح{1}. (ز) ٦٤٦٨٤- عن إسماعيل السُدِّيّ: <q>﴿وآيَةٌ لَهُمُ﴾</q>، يعني: وعلامة لهم{12}. (ز) ٦٤٦٨٥- قال مقاتل بن سليمان: <q>﴿وآيَةٌ لَهُمُ﴾</q> وعلامة لهم، يعني: كفار مكة <q>﴿أنّا حَمَلْنا ذُرِّيَّتَهُمْ﴾</q> ذرية أهل مكة في أصلاب آبائهم <q>﴿فِي الفُلْكِ المَشْحُونِ﴾</q> يعني: المُوقر مِن الناس والدواب{13}. (ز) ٦٤٦٨٦- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿الفُلْكِ المَشْحُونِ﴾</q>، قال: الفُلك المشحون: المركب الذي كان فيه نوح، والذرية التي كانت في ذلك المركب. قال: والمشحون: الذي قد شُحِن؛ الذي قد جعل فيه ليركبه أهله، جعلوا فيه ما يريدون، فربما امتلأ، وربما لم يمتلئ{1}. (ز) ٦٤٦٨٧- قال يحيى بن سلّام: <q>﴿أنّا حَمَلْنا ذُرِّيَّتَهُمْ فِي الفُلْكِ المَشْحُونِ﴾</q>، يعني: نوحًا وبنيه الثلاثة: سام، وحام، ويافث، منهم ذُرِي الخلقُ بعد ما غرِق قومُ نوح{15}. (ز) ",footnotes:1:أخرجه ابن جرير ١٩/٤٤٣.أخرجه ابن جرير ١٩/٤٤٢.أخرجه ابن جرير ١٩/٤٤٢.أخرجه ابن جرير ١٩/٤٤٢.أخرجه ابن جرير ١٩/٤٤٣.أخرجه ابن جرير ١٩/٤٤٣.عزاه السيوطي إلى عبد بن حميد، وابن أبي حاتم.أخرجه ابن جرير ١٩/٤٤٢.أخرجه يحيى بن سلّام ٢/٨١٠.عزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه ابن جرير ١٩/٤٤٣.علقه يحيى بن سلّام ٢/٨١٠.تفسير مقاتل بن سليمان ٣/٥٨٠.أخرجه ابن جرير ١٩/٤٤٣.تفسير يحيى بن سلّام ٢/٨١٠.
36,42," <q>﴿وَخَلَقۡنَا لَهُم مِّن مِّثۡلِهِۦ مَا یَرۡكَبُونَ ۝٤٢﴾</q> - تفسير ٦٤٦٨٨- عن عبد الله بن عباس -من طريق سعيد بن جبير- <q>﴿وخَلَقْنا لَهُمْ مِن مِثْلِهِ ما يَرْكَبُونَ﴾</q>، قال: هي السفن، جُعِلَت مِن بعد سفينة نوحٍ على مِثلها{1}. (١٢/٣٥٣) ٦٤٦٨٩- عن عبد الله بن عباس -من طريق عطية العوفي- <q>﴿وخَلَقْنا لَهُمْ مِن مِثْلِهِ ما يَرْكَبُونَ﴾</q>: يعني: الإبل؛ خلقها الله كما رأيتَ، فهي سُفُن البر، يحملون عليها ويركبونها{2}. (١٢/٣٥٣) ٦٤٦٩٠- عن عبد الله بن شداد -من طريق السُدِّيّ- في قوله: <q>﴿وخَلَقْنا لَهُمْ مِن مِثْلِهِ ما يَرْكَبُونَ﴾</q>، قال: هي الإبل{3}. (١٢/٣٥٤) ٦٤٦٩١- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿وخَلَقْنا لَهُمْ مِن مِثْلِهِ ما يَرْكَبُونَ﴾</q>، قال: الأنعام{4}. (١٢/٣٥٤) ٦٤٦٩٢- عن الضحاك بن مزاحم -من طريق عبيد- يقول في قوله: <q>﴿وخَلَقْنا لَهُمْ مِن مِثْلِهِ ما يَرْكَبُونَ﴾</q>: يعني: السفن التي اتخذت بعدها، يعني: بعد سفينة نوح{5}. (ز) ٦٤٦٩٣- عن عكرمة مولى ابن عباس، في قوله: <q>﴿وخَلَقْنا لَهُمْ مِن مِثْلِهِ ما يَرْكَبُونَ﴾</q>، قال: هي الإبل{6}. (١٢/٣٥٤) ٦٤٦٩٤- عن أبي مالك غزوان الغفاري، في قوله: <q>﴿وخَلَقْنا لَهُمْ مِن مِثْلِهِ ما يَرْكَبُونَ﴾</q>، قال: السفن التي في البحر، والأنهار التي يركب الناس فيها{7}. (١٢/٣٥٣) ٦٤٦٩٥- عن أبي مالك غزوان الغفاري -من طريق السُدِّيّ- في قوله: <q>﴿وخَلَقْنا لَهُمْ مِن مِثْلِهِ ما يَرْكَبُونَ﴾</q>، قال: السفن الصغار، ألا ترى أنه قال: <q>﴿وإنْ نَشَأْ نُغْرِقْهُمْ فَلا صَرِيخَ لَهُمْ﴾</q>؟!{8}. (ز) ٦٤٦٩٦- قال الحسن البصري -من طريق قتادة- <q>﴿وخَلَقْنا لَهُمْ مِن مِثْلِهِ ما يَرْكَبُونَ﴾</q>: هي الإبل{9}. (١٢/٣٥٣) ٦٤٦٩٧- عن الحسن البصري -من طريق منصور بن زاذان- في هذه الآية: <q>﴿وخَلَقْنا لَهُمْ مِن مِثْلِهِ ما يَرْكَبُونَ﴾</q>، قال: السفن الصغار{8}. (ز) ٦٤٦٩٨- عن أبي صالح باذام، في قوله: <q>﴿حَمَلْنا ذُرِّيَّتَهُمْ فِي الفُلْكِ المَشْحُونِ﴾</q> قال: سفينة نوح، <q>﴿وخَلَقْنا لَهُمْ مِن مِثْلِهِ ما يَرْكَبُونَ﴾</q> هذه السفن مثل خشبها وصنعتها{11}. (١٢/٣٥٣) ٦٤٦٩٩- عن أبي صالح باذام -من طريق شعبة، عن إسماعيل- في قوله: <q>﴿وخَلَقْنا لَهُمْ مِن مِثْلِهِ ما يَرْكَبُونَ﴾</q>، قال: السفن الصغار{5}. (ز) ٦٤٧٠٠- عن قتادة بن دعامة، <q>﴿وخَلَقْنا لَهُمْ مِن مِثْلِهِ ما يَرْكَبُونَ﴾</q>، قال: يعني: السفن الصغار{13}. (١٢/٣٥٣) ٦٤٧٠١- عن قتادة بن دعامة -من طريق سعيد- <q>﴿وخَلَقْنا لَهُمْ مِن مِثْلِهِ ما يَرْكَبُونَ﴾</q>، قال: هي السُّفُن التي يُنتَفَع بها{5}. (ز) ٦٤٧٠٢- قال مقاتل بن سليمان: <q>﴿وخَلَقْنا لَهُمْ مِن مِثْلِهِ﴾</q> وجعلنا لهم مِن شبه سفينة نوح <q>﴿ما يَرْكَبُونَ﴾</q> فيها{15}. (ز) ٦٤٧٠٣- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿وخَلَقْنا لَهُمْ مِن مِثْلِهِ ما يَرْكَبُونَ﴾</q>، قال: وهي هذه الفلك{16}. (ز) ٦٤٧٠٤- قال يحيى بن سلّام: قال: <q>﴿وخَلَقْنا لَهُمْ مِن مِثْلِه﴾</q> مِن مثل الفلك <q>﴿ما يَرْكَبُونَ﴾</q> يعني: الإبل، ويقال: هي سفن البر، وقال في آية أخرى: <q>﴿وجَعَلَ لَكُمْ مِنَ الفُلْكِ والأَنْعامِ ما تَرْكَبُونَ﴾</q> [الزخرف:١٢]{17}٥٤٣٣. (ز) ٥٤٣٣ اختلف السلف في قوله: <q>﴿وخلقنا لهم من مثله ما يركبون﴾</q> على قولين: الأول: أنه السفن. الثاني: أنه الإبل. وقد رجّح ابنُ جرير (١٩/٤٤٦-٤٤٧) مستندًا إلى السياق، والدلالة العقلية القول الأول، فقال: «وأشبه القولين بتأويل ذلك قولُ مَن قال: عني بذلك: السفن، وذلك لدلالة قوله: <q>﴿وإن نشأ نغرقهم فلا صريخ لهم﴾</q> [يس:٤٣]، على أن ذلك كذلك، وذلك أنّ الغرق معلوم أن لا يكون إلا في الماء، ولا غرق في البر». وذكر ابنُ عطية (٧/٢٥٠-٢٥١) في معنى: <q>﴿حملنا ذريتهم﴾</q> وفي معنى: <q>﴿من مثله﴾</q> احتمالين، فقال: «وأمّا معنى الآية فيحتمل تأويلين: أحدهما قاله ابن عباس وجماعة، وهو أن يريد بالذريات المحمولين: أصحاب نوح في السفينة، ويريد بقوله: <q>﴿مِن مِثْلِهِ﴾</q>: السفن الموجودة في جنس بني آدم إلى يوم القيامة، وإيّاها أراد الله تعالى بقوله: <q>﴿وإنْ نَشَأْ نُغْرِقْهُمْ﴾</q>، والتأويل الثاني قاله مجاهد والسُدِّيّ، وروي عن ابن عباس أيضًا، هو أن يريد بقوله: <q>﴿أنّا حَمَلْنا ذُرِّيَّتَهُمْ فِي الفُلْكِ المَشْحُونِ﴾</q>: السفن الموجودة في بني آدم إلى يوم القيامة، ويريد بقوله: <q>﴿وخَلَقْنا لَهُمْ مِن مِثْلِهِ ما يَرْكَبُونَ﴾</q>: الإبل وسائر ما يركب، فتكون المماثلة في أنه مركوب مُبَلِّغٌ إلى الأقطار فقط، ويعود قوله: <q>﴿وإن نشأ نغرقهم﴾</q> على السفن الموجودة في الناس، وأما من خلط القولين فجعل الذرية في الفلك في قوم نوح في سفينة، وجعل <q>﴿من مثله﴾</q> في الإبل؛ فإن هذا نظرٌ فاسد يقطع به قوله تعالى: <q>﴿وإن نشأ نغرقهم﴾</q>. فتأمله». ",footnotes:1:أخرجه ابن جرير ١٩/٤٤٤. وعزاه السيوطي إلى ابن أبي حاتم.أخرجه ابن جرير ١٩/٤٤٦. وعزاه السيوطي إلى ابن أبي حاتم.أخرجه ابن جرير ١٩/٤٤٦. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.تفسير مجاهد (٥٦٠)، وأخرجه ابن جرير ١٩/٤٤٦ بنحوه. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.أخرجه ابن جرير ١٩/٤٤٥.عزاه السيوطي إلى ابن أبي شيبة، وعبد بن حميد، وابن المنذر، وابن أبي حاتم.عزاه السيوطي إلى عبد بن حميد، وابن أبي حاتم.أخرجه ابن جرير ١٩/٤٤٤.أخرجه ابن جرير ١٩/٤٤٦. وعزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ١٩/٤٤٤.عزاه السيوطي إلى عبد بن حميد، وابن المنذر. وعند ابن جرير ١٩/٤٤٥ نحو شطره الثاني من طريق محمد بن عبيد عن إسماعيل بن أبي خالد بلفظ: نِعَمٌ من مثل سفينة نوح.أخرجه ابن جرير ١٩/٤٤٥.عزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ١٩/٤٤٥.تفسير مقاتل بن سليمان ٣/٥٨٠.أخرجه ابن جرير ١٩/٤٤٥، وفيه (ط: هجر): الفلوك.تفسير يحيى بن سلّام ٢/٨١٠.
36,43," <q>﴿وَإِن نَّشَأۡ نُغۡرِقۡهُمۡ فَلَا صَرِیخَ لَهُمۡ وَلَا هُمۡ یُنقَذُونَ ۝٤٣﴾</q> - تفسير ٦٤٧٠٥- قال عبد الله بن عباس: <q>﴿وإنْ نَشَأْ نُغْرِقْهُمْ فَلا صَرِيخَ لَهُمْ ولا هُمْ يُنْقَذُونَ﴾</q> ولا أحد ينقذهم من عذابي{1}. (ز) ٦٤٧٠٦- عن مجاهد بن جبر، في قوله: <q>﴿وإنْ نَشَأْ نُغْرِقْهُمْ فَلا صَرِيخَ لَهُمْ﴾</q>، قال: لا مغيث لهم يستغيثون به{2}. (١٢/٣٥٤) ٦٤٧٠٧- عن قتادة بن دعامة -من طريق سعيد- <q>﴿فَلا صَرِيخَ لَهُمْ﴾</q>، قال: لا مُغيث لهم{3}. (١٢/٣٥٤) ٦٤٧٠٨- قال مقاتل بن سليمان: <q>﴿وإنْ نَشَأْ نُغْرِقْهُمْ﴾</q> في الماء؛ <q>﴿فَلا صَرِيخَ لَهُمْ﴾</q> لا مغيث لهم، <q>﴿ولا هُمْ يُنْقَذُونَ﴾</q> مِن الغرق{4}. (ز) ٦٤٧٠٩- قال يحيى بن سلّام: قال: <q>﴿وإنْ نَشَأْ نُغْرِقْهُمْ فَلا صَرِيخَ لَهُمْ﴾</q> فلا مغيث لهم، <q>﴿ولا هُمْ يُنْقَذُونَ﴾</q> مِن العذاب{5}. (ز) ",footnotes:1:تفسير البغوي ٧/١٩.عزاه السيوطي إلى عبد بن حميد، وابن جرير، وابن المنذر، وابن أبي حاتم.أخرجه عبد الرزاق ٢/١٤٤ من طريق معمر، وابن جرير ١٩/٤٤٧. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.تفسير مقاتل بن سليمان ٣/٥٨٠.تفسير يحيى بن سلّام ٢/٨١٠-٨١١.
36,44," <q>﴿إِلَّا رَحۡمَةࣰ مِّنَّا وَمَتَـٰعًا إِلَىٰ حِینࣲ ۝٤٤﴾</q> - تفسير ٦٤٧١٠- عن قتادة بن دعامة -من طريق سعيد- <q>﴿ومَتاعًا إلى حِينٍ﴾</q>، قال: إلى الموت{1}. (١٢/٣٥٤) ٦٤٧١١- قال مقاتل بن سليمان: <q>﴿إلّا رَحْمَةً مِنّا﴾</q> إلا نعمة منا حين لا نغرقهم، <q>﴿ومَتاعًا إلى حِينٍ﴾</q> وبلاغًا إلى آجالهم{2}. (ز) ٦٤٧١٢- قال يحيى بن سلّام: قال: <q>﴿إلّا رَحْمَةً مِنّا ومَتاعًا إلى حِينٍ﴾</q> فبرحمته يُمتِّعهم إلى يوم القيامة، ولم يهلكهم بعذاب الاستئصال، وسيهلك كفار آخر هذه الأمة بالنفخة الأولى{3}. (ز) ",footnotes:1:أخرجه ابن جرير ١٩/٤٤٧. وعزاه السيوطي إلى عبد الرزاق، وعبد بن حميد، وابن المنذر، وابن أبي حاتم.تفسير مقاتل بن سليمان ٣/٥٨٠.تفسير يحيى بن سلّام ٢/٨١٠-٨١١.
36,45," <q>﴿وَإِذَا قِیلَ لَهُمُ ٱتَّقُوا۟ مَا بَیۡنَ أَیۡدِیكُمۡ وَمَا خَلۡفَكُمۡ لَعَلَّكُمۡ تُرۡحَمُونَ ۝٤٥﴾</q> - تفسير ٦٤٧١٣- قال عبد الله بن عباس: <q>﴿ما بَيْنَ أيْدِيكُمْ﴾</q> يعني: الآخرة؛ فاعملوا لها، <q>﴿وما خَلْفَكُمْ﴾</q> يعني: الدنيا؛ فاحذروها، ولا تغترُّوا بها{1}. (ز) ٦٤٧١٤- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿وإذا قِيلَ لَهُمُ اتَّقُوا ما بَيْنَ أيْدِيكُمْ وما خَلْفَكُمْ لَعَلَّكُمْ تُرْحَمُونَ﴾</q>، قال: ما مضى وما بقي من الذنوب{2}. (١٢/٣٥٥) ٦٤٧١٥- قال الحسن البصري: <q>﴿ما بَيْنَ أيْدِيكُمْ﴾</q> مِن وقائع الله بالكفار، أي: لا ينزل بكم ما نزل بهم، <q>﴿وما خَلْفَكُمْ﴾</q> عذاب الآخرة بعد عذاب الدنيا، يقوله النبي ﵇ للمشركين{3}. (ز) ٦٤٧١٦- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿وإذا قِيلَ لَهُمُ اتَّقُوا ما بَيْنَ أيْدِيكُمْ﴾</q> قال: من الوقائع التي قد خلت فيمَن كان قبلكم، والعقوبات التي أصابت عادًا وثمودًا والأمم، <q>﴿وما خَلْفَكُمْ﴾</q> قال: من أمر الساعة{4}٥٤٣٤. (١٢/٣٥٤) ٥٤٣٤ قال ابنُ جرير (١٩/٤٤٧): «قوله تعالى: <q>﴿وإذا قيل لهم اتقوا ما بين أيديكم وما خلفكم لعلكم ترحمون وما تأتيهم من آية من آيات ربهم إلا كانوا عنها معرضين﴾</q> يقول -تعالى ذكره-: وإذا قيل لهؤلاء المشركين بالله، المكذبين رسوله محمدًا ﷺ: احذروا ما مضى بين أيديكم مِن نقم الله ومثلاته بِمَن حلَّ ذلك به مِن الأمم قبلكم أن يحل مثله بكم، بشرككم وتكذيبكم رسوله <q>﴿وما خلفكم﴾</q> يقول: وما بعد هلاككم مما أنتم لاقوه إن هلكتم على كفركم الذي أنتم عليه». واستدل بقول قتادة. وذكر ابنُ جرير قول مجاهد، ثم وجّهه (١٩/٤٤٩) بقوله: «وهذا القول قريب المعنى مِن القول الذي قلنا؛ لأن معناه: اتقوا عقوبة ما بين أيديكم من ذنوبكم، وما خلفكم مما تعملون من الذنوب، ولم تعملوه بعد، فذلك بعد تخويف لهم العقاب على كفرهم». وذكر ابنُ عطية (٧/٢٥١-٢٥٢) نحو قول مجاهد، وعزاه للحسن، ووجّهه على النحو الذي وجهه عليه ابن جرير. وذكر ابنُ عطية (٤/٤٥٥) قول مقاتل وقول قتادة في معناه، ورجّحهما بقوله: «هذا هو النظر». ولم يذكر مستندًا. ثم ذكر قولًا عن مجاهد أنه قال: «<q>﴿ما بين أيديهم﴾</q> هو الآخرة، و<q>﴿ما خلفهم﴾</q> عذاب الأمم». ثم علّق عليه قائلًا: «فجعل الترتيب كأنهم يسيرون مِن شيء إلى شيء، ولم يعتبر وجود الأشياء في الزمن». ثم انتقده مستندًا إلى النظائر بقوله: «وهذا النظر يكسره عليه قوله تعالى: <q>﴿مُصَدِّقًا لِما بَيْنَ يَدَيْهِ مِنَ التَّوْراةِ وآتَيْناهُ الإنْجِيلَ﴾</q> [المائدة:٤٦]، وإنما المطرد أن يقاس ما بين اليد والخلف بما يسوقه الزمن، فتأمله». ٦٤٧١٧- قال إسماعيل السُدِّيّ: <q>﴿اتَّقُوا ما بَيْنَ أيْدِيكُمْ وما خَلْفَكُمْ﴾</q> عذاب الدنيا وعذاب الآخرة؛ <q>﴿لَعَلَّكُمْ تُرْحَمُونَ﴾</q> لكي تُرحموا{3}. (ز) ٦٤٧١٨- قال محمد بن السائب الكلبي: <q>﴿ما بَيْنَ أيْدِيكُمْ﴾</q> من أمر الآخرة، اتقوها واعملوا لها، <q>﴿وما خَلْفَكُمْ﴾</q> الدنيا إذا كنتم في الآخرة، فلا تغتروا بالدنيا، فإنكم تأتون الآخرة{3}. (ز) ٦٤٧١٩- قال مقاتل بن سليمان <q>﴿وإذا قِيلَ لَهُمُ اتَّقُوا ما بَيْنَ أيْدِيكُمْ﴾</q> يقول: لا يصيبكم مِنّا عذاب الأمم الخالية قبلكم، <q>﴿وما خَلْفَكُمْ﴾</q> واتَّقوا ما بعدكم مِن عذاب الأمم؛ فلا تكذِّبوا محمدًا ﷺ؛ <q>﴿لَعَلَّكُمْ تُرْحَمُونَ﴾</q> لكي تُرحموا{7}. (ز) ٦٤٧٢٠- عن سفيان بن عيينة -من طريق ابن أبي عمر- في قوله: <q>﴿اتقوا مابين أيديكم وماخلفكم﴾</q>: من الآخرة{8}. (ز) ",footnotes:1:تفسير الثعلبي ٨/١٢٩، وتفسير البغوي ٧/١٩.تفسير مجاهد (٥٦٠)، وأخرجه ابن جرير ١٩/٤٤٨ بنحوه. وعلقه يحيى بن سلّام ٢/٨١١. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.علقه يحيى بن سلّام ٢/٨١١.أخرجه عبد الرزاق ٢/١٤٤ بنحوه من طريق معمر، وابن جرير ١٩/٤٤٨ بنحوه. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.علقه يحيى بن سلّام ٢/٨١١.علقه يحيى بن سلّام ٢/٨١١.تفسير مقاتل بن سليمان ٣/٥٨٠.أخرجه إسحاق البستي ص١٨٨.
36,46," <q>﴿وَمَا تَأۡتِیهِم مِّنۡ ءَایَةࣲ مِّنۡ ءَایَـٰتِ رَبِّهِمۡ إِلَّا كَانُوا۟ عَنۡهَا مُعۡرِضِینَ ۝٤٦﴾</q> - تفسير ٦٤٧٢١- عن الحسن البصري: <q>﴿وما تَأْتِيهِمْ مِن آيَةٍ مِن آياتِ رَبِّهِمْ﴾</q> ما يأتيهم من رسول{1}. (ز) ٦٤٧٢٢- قال مقاتل بن سليمان: <q>﴿وما تَأْتِيهِمْ مِن آيَةٍ مِن آياتِ رَبِّهِمْ إلّا كانُوا عَنْها مُعْرِضِينَ﴾</q> فلا يتفكروا{2}. (ز) ",footnotes:1:علقه يحيى بن سلّام ٢/٨١١.تفسير مقاتل بن سليمان ٣/٥٨٠.
36,47," <q>﴿وَإِذَا قِیلَ لَهُمۡ أَنفِقُوا۟ مِمَّا رَزَقَكُمُ ٱللَّهُ قَالَ ٱلَّذِینَ كَفَرُوا۟ لِلَّذِینَ ءَامَنُوۤا۟ أَنُطۡعِمُ مَن لَّوۡ یَشَاۤءُ ٱللَّهُ أَطۡعَمَهُۥۤ إِنۡ أَنتُمۡ إِلَّا فِی ضَلَـٰلࣲ مُّبِینࣲ ۝٤٧﴾</q> - نزول الآية، وتفسيرها ٦٤٧٢٣- عن الحسن البصري، في قوله: <q>﴿أنُطْعِمُ مَن لَوْ يَشاءُ اللَّهُ أطْعَمَهُ﴾</q>، قال: اليهود تقوله{1}. (١٢/٣٥٥) ٦٤٧٢٤- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿وإذا قِيلَ لَهُمْ أنْفِقُوا مِمّا رَزَقَكُمُ اللَّهُ﴾</q>، قال: نزلت في الزنادقة، كانوا لا يُطعمون فقيرًا، فعاب اللهُ ذلك عليهم وعيّرهم{2}. (١٢/٣٥٤) ٦٤٧٢٥- عن إسماعيل بن أبي خالد، في قوله: <q>﴿أنُطْعِمُ مَن لَوْ يَشاءُ اللَّهُ أطْعَمَهُ﴾</q>، قال: يهود تقوله{3}. (١٢/٣٥٥) ٦٤٧٢٦- عن محمد بن السائب الكلبي -من طريق معمر- في قوله تعالى: <q>﴿وإذا قِيلَ لَهُمْ أنْفِقُوا مِمّا رَزَقَكُمُ اللَّهُ﴾</q>، قال: نزلت في الزنادقة{4}. (ز) ٦٤٧٢٧- قال مقاتل بن سليمان: <q>﴿وإذا قِيلَ لَهُمْ أنْفِقُوا﴾</q> وذلك أنّ المؤمنين قالوا بمكة لكفار قريش لأبي سفيان وغيره: أنفِقوا على المساكين مِن الذي زعمتم أنه لله. وذلك أنهم كانوا يجعلون نصيبًا لله من الحرث والأنعام بمكة للمساكين، فيقولون هذا لله بزعمهم، ويجعلون للآلهة نصيبًا، فإن لم يَزكُ ما جعلوه للآلهة من الحرث والأنعام، وزكا ما جعلوه لله ﷿، ليس للآلهة شيء، وهي تحتاج إلى نفقة، فأخذوا ما جعلوه لله، قالوا: لو شاء الله لأزكى نصيبه. ولا يعطون المساكين شيئًا مما زكى لآلهتهم، فقال المؤمنون لكفار قريش: <q>﴿أنْفِقُوا مِمّا رَزَقَكُمُ اللَّهُ قالَ الَّذِينَ كَفَرُوا لِلَّذِينَ آمَنُوا﴾</q> فقالت كفار قريش: <q>﴿أنُطْعِم﴾</q> المساكين الذي للآلهة <q>﴿مَن لو يشاء الله أطعمه﴾</q>؟! يعني: رزقه، لو شاء الله لأطعمه، وقالوا لأصحاب النبي ﷺ: <q>﴿إنْ أنْتُمْ إلّا فِي ضَلالٍ مُبِينٍ﴾</q>{5}. (ز) ٦٤٧٢٨- عن مقاتل بن حيان: <q>﴿إنْ أنْتُمْ إلّا فِي ضَلالٍ مُبِينٍ﴾</q> في اتِّباعكم محمدًا، ومخالفتكم ديننا{6}٥٤٣٥. (ز) ٥٤٣٥ ذكر ابنُ جرير (١٩/٤٥٠) في قوله: <q>﴿إن أنتم إلا في ضلال مبين﴾</q> وجهين، رجّح الأول منهما، فقال: «وفي قوله: <q>﴿إن أنتم إلا في ضلال مبين﴾</q> وجهان: أحدهما: أن يكون مِن قيل الكفار للمؤمنين، فيكون تأويل الكلام حينئذ: ما أنتم -أيها القوم- في قيلكم لنا: أنفقوا مما رزقكم الله على مساكينكم. إلا في ذهاب عن الحق، وجَور عن الرشد، مبين لمن تأمله وتدبره أنه في ضلال. وهذا أولى وجهيه بتأويله. والوجه الآخر: أن يكون ذلك مِن قيل الله للمشركين، فيكون تأويله حينئذ: ما أنتم -أيها الكافرون- في قيلكم للمؤمنين: أنطعم من لو يشاء الله أطعمه. إلا في ضلال مبين عن أنّ قيلكم ذلك لهم ضلال». وبنحوه ابنُ عطية (٧/٢٥٣)، ولم يذكرا مستندًا. وانتقد ابنُ كثير (١١/٣٦٧) الوجه الثاني من هذين الوجهين بقوله: «وفي هذا نظر». ٦٤٧٢٩- قال يحيى بن سلّام: قوله ﷿: <q>﴿وإذا قِيلَ لَهُمْ أنْفِقُوا مِمّا رَزَقَكُمُ اللَّهُ﴾</q> وهذا تطوع؛ <q>﴿قالَ الَّذِينَ كَفَرُوا لِلَّذِينَ آمَنُوا أنُطْعِمُ مَن لَوْ يَشاءُ اللَّهُ أطْعَمَهُ﴾</q> فإذا لم يشأ الله أن يُطْعِمَه لِمَ تُطْعمه، <q>﴿إنْ أنْتُمْ إلّا فِي ضَلالٍ مُبِينٍ﴾</q> يقوله المشركون للمؤمنين{7}٥٤٣٦. (ز) ٥٤٣٦ ذكر ابنُ عطية (٧/٢٥٢-٢٥٣) في معنى الآية احتمالين، فقال: «وقولهم يحتمل معنيين من التأويل: أحدهما يخرج على اختبارات لجهال العرب، فقد رُوِي أنّ أعرابيًا كان يرعى إبله، فيجعل السمان في الخصب، والمهازيل في المكان الجدب، فقيل له في ذلك، فقال: أُكْرِمُ ما أكرم الله، وأُهين ما أهان الله. فيُخَرَّج قولُ قريش على هذا المعنى، كأنهم رأوا الإمساك عمن أمسك الله عنه رزقه، ومن أمثالهم: كن مع الله على المدْبِر». والتأويل الثاني: «أن يكون كلامهم بمعنى الاستهزاء بقول محمد ﷺ: إن ثَمَّ إلهًا هو الرزاق. فكأنهم قالوا: لِمَ لا يرزقك إلهك الذي تزعم؟ أي: نحن لا نطعم من لو يشاء هذا الإله الذي زعمت لأطعمه. وهذا كما يدعي إنسان أنه غني، ثم يحتاج إلى معونتك في مال، فتقول له على جهة الاحتجاج والهزء به: أتطلب معونتي وأنت غني؟! أي: على قولك». ",footnotes:1:عزاه السيوطي إلى ابن أبي حاتم.عزاه السيوطي إلى عبد الرزاق، وعبد بن حميد، وابن جرير، وابن المنذر، وابن أبي حاتم.عزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه عبد الرزاق ٢/١٤٤.تفسير مقاتل بن سليمان ٣/٥٨٠-٥٨١.تفسير الثعلبي ٨/١٣٠.تفسير يحيى بن سلّام ٢/٨١١.
36,48," <q>﴿وَیَقُولُونَ مَتَىٰ هَـٰذَا ٱلۡوَعۡدُ إِن كُنتُمۡ صَـٰدِقِینَ ۝٤٨﴾</q> - تفسير ٦٤٧٣٠- قال مقاتل بن سليمان: <q>﴿ويَقُولُونَ مَتى هذا الوَعْدُ إنْ كُنْتُمْ صادِقِينَ﴾</q> بأنّ العذاب نازِل بنا في الدنيا{1}. (ز) ٦٤٧٣١- قال يحيى بن سلّام: قال: <q>﴿ويَقُولُونَ مَتى هَذا الوَعْدُ﴾</q> أي: هذا العذاب <q>﴿إنْ كُنْتُمْ صادِقِينَ﴾</q> يُكَذِّبون به{2}. (ز) ",footnotes:1:تفسير مقاتل بن سليمان ٣/٥٨٠.تفسير يحيى بن سلّام ٢/٨١١.
36,49," <q>﴿مَا یَنظُرُونَ إِلَّا صَیۡحَةࣰ وَ ٰ⁠حِدَةࣰ تَأۡخُذُهُمۡ﴾</q> - تفسير ٦٤٧٣٢- عن إسماعيل السُدِّيّ: <q>﴿إلّا صَيْحَةً واحِدَةً﴾</q> يعني: النفخة الأولى مِن إسرافيل، بها يكون هلاكهم{1}. (ز) ٦٤٧٣٣- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿ما يَنْظُرُونَ إلّا صَيْحَةً واحِدَةً﴾</q>، قال: النفخة نفخة واحدة{2}. (ز) ٦٤٧٣٤- قال يحيى بن سلّام: قال الله: <q>﴿ما يَنْظُرُونَ﴾</q> ما ينظر كفارُ آخر هذه الأمة الدائنين بدين أبي جهل وأصحابه <q>﴿إلّا صَيْحَةً واحِدَةً﴾</q> يعني: النفخة الأولى مِن إسرافيل، بها يكون هلاكُهم{3}. (ز) <q>﴿تَأۡخُذُهُمۡ وَهُمۡ یَخِصِّمُونَ ۝٤٩﴾</q> - تفسير ٦٤٧٣٥- عن محمد بن زياد مولى بني جمح -من طريق معمر- في قوله تعالى: <q>﴿صَيْحَةً واحِدَةً تَأْخُذُهُمْ﴾</q>، قال: سمعتُ أبا هريرة يقول: إنّ الساعة لَتقوم على الرجلين وهما ينشران الثوبَ يتبايعانه{4}. (ز) ٦٤٧٣٦- عن عبد الله بن عمرو -من طريق أبي المغيرة- قال: لَيُنفَخَنَّ في الصور والناسُ في طرقهم وأسواقهم ومجالسهم، حتى إنّ الثوب ليكون بين الرجلين يتساومان، فما يُرسله أحدهما مِن يده حتى ينفخ في الصور، فيصعق به، وحتى إنّ الرجل لَيغدو من بيته فلا يرجع حتى يُنفخ في الصور، وهي التي قال الله: <q>﴿ما يَنْظُرُونَ إلّا صَيْحَةً واحِدَةً تَأْخُذُهُمْ وهُمْ يَخِصِّمُونَ * فَلا يَسْتَطِيعُونَ تَوْصِيَةً ولا إلى أهْلِهِمْ يَرْجِعُونَ﴾</q>{5}. (١٢/٣٥٦) ٦٤٧٣٧- عن الضحاك بن مزاحم، في قوله: <q>﴿تَأْخُذُهُمْ وهُمْ يَخِصِّمُونَ﴾</q>، قال: تَذَرُهم في أسواقهم وطرقهم{6}. (١٢/٣٥٧) ٦٤٧٣٨- عن قتادة بن دعامة، في قوله: <q>﴿ما يَنْظُرُونَ إلّا صَيْحَةً واحِدَةً تَأْخُذُهُمْ وهُمْ يَخِصِّمُونَ﴾</q>، قال: ذُكِر لنا: أنّ نبيَّ الله ﷺ كان يقول: «تهيج الساعةُ بالناسِ والرجلُ يسقي ماشيته، والرجل يُصلِحُ حوضَه، والرجل يُقِيم سلعته في سوقه، والرجل يخفض ميزانه ويرفعه، فتهيج بهم وهم كذلك»{7}. (١٢/٣٥٥) ٦٤٧٣٩- عن إسماعيل السُدِّيّ، في قوله: <q>﴿وهُمْ يَخِصِّمُونَ﴾</q>، قال: يتكلمون{8}. (١٢/٣٥٦) ٦٤٧٤٠- قال مقاتل بن سليمان: يقول الله ﷿: <q>﴿ما يَنْظُرُونَ إلّا صَيْحَةً واحِدَةً﴾</q> لا مثنوية لها، <q>﴿تَأْخُذُهُمْ وهُمْ يَخِصِّمُونَ﴾</q> وهم يتكلمون في الأسواق والمجالس، وهم أعَزُّ ما كانوا{9}. (ز) ٦٤٧٤١- قال يحيى بن سلّام: <q>﴿تَأْخُذُهُمْ وهُمْ يَخِصِّمُونَ﴾</q> في أسواقهم، يتبايعون، يذرعون الثياب، ويخفض أحدُهم ميزانَه ويرفعه، ويحلبون اللقاح، وغير ذلك مِن حوائجهم{3}. (ز) ",footnotes:1:علقه يحيى بن سلّام ٢/٨١١.أخرجه ابن جرير ١٩/٤٥١.تفسير يحيى بن سلّام ٢/٨١١.أخرجه عبد الرزاق ٢/١٤٤.أخرجه يحيى بن سلّام ٢/٨١٢، وابن جرير ١٩/٤٥١ بدون: فيصعق به. وعزاه السيوطي إلى ابن أبي حاتم.عزاه السيوطي إلى سعيد بن منصور، وابن المنذر.أخرجه ابن جرير ١٩/٤٥١ بنحوه. وعزاه السيوطي إلى عبد بن حميد، وابن أبي حاتم.عزاه السيوطي إلى ابن أبي حاتم.تفسير مقاتل بن سليمان ٣/٥٨١.تفسير يحيى بن سلّام ٢/٨١١.
36,50," <q>﴿فَلَا یَسۡتَطِیعُونَ تَوۡصِیَةࣰ وَلَاۤ إِلَىٰۤ أَهۡلِهِمۡ یَرۡجِعُونَ ۝٥٠﴾</q> - تفسير ٦٤٧٤٢- عن الزبير بن العوام، قال: إنّ الساعة تقوم والرجل يذرع الثوب، والرجل يحلب الناقة. ثم قرأ: <q>﴿فَلا يَسْتَطِيعُونَ تَوْصِيَةً﴾</q> الآية{1}. (١٢/٣٥٦) ٦٤٧٤٣- عن أبي هريرة، قال: تقوم الساعة والناس في أسواقهم يتبايعون، ويذرعون الثياب، ويحلبون اللقاح، وفي حوائجهم، <q>﴿فَلا يَسْتَطِيعُونَ تَوْصِيَةً ولا إلى أهْلِهِمْ يَرْجِعُونَ﴾</q>{2}. (١٢/٣٥٦) ٦٤٧٤٤- عن عبد الله بن عباس -من طريق أبي صالح- <q>﴿فلا يستطيعون﴾</q>: لا يقدرون. <q>﴿توصية﴾</q>: كلامًا{3}. (ز) ٦٤٧٤٥- عن الضحاك بن مزاحم، في قوله: <q>﴿فَلا يَسْتَطِيعُونَ تَوْصِيَةً﴾</q>، قال: لا يُوصِي بعضُهم إلى بعض{4}. (١٢/٣٥٧) ٦٤٧٤٦- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿فَلا يَسْتَطِيعُونَ تَوْصِيَةً﴾</q>: أي: فيما في أيديهم، <q>﴿ولا إلى أهْلِهِمْ يَرْجِعُونَ﴾</q> قال: أُعجِلُوا عن ذلك{5}. (١٢/٣٥٥) ٦٤٧٤٧- قال مقاتل بن سليمان: <q>﴿فَلا يَسْتَطِيعُونَ تَوْصِيَةً﴾</q> يقول: أُعجِلوا عن التوصية، فماتوا، <q>﴿ولا إلى أهْلِهِمْ يَرْجِعُونَ﴾</q> يقول: ولا إلى منازلهم يرجعون مِن الأسواق، فأخبر الله ﷿ بما يلقون في الأولى، ثم أخبر بما يلقون في الثانية إذا بُعثوا، فذلك قوله ﷿: <q>﴿ونُفِخَ فِي الصُّورِ فَإذا هُمْ مِنَ الأَجْداثِ من القبور إلى رَبِّهِمْ يَنْسِلُونَ﴾</q>{6}. (ز) ٦٤٧٤٨- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿ما يَنْظُرُونَ إلّا صَيْحَةً واحِدَةً تَأْخُذُهُمْ وهُمْ يَخِصِّمُونَ﴾</q> قال: هذا مبتدأ يوم القيامة. وقرأ: <q>﴿فَلا يَسْتَطِيعُونَ تَوْصِيَةً﴾</q> حتى بلغ <q>﴿إلى رَبِّهِمْ يَنْسِلُونَ﴾</q>{7}. (١٢/٣٥٦) ٦٤٧٤٩- قال يحيى بن سلّام: قوله ﷿: <q>﴿فَلا يَسْتَطِيعُونَ تَوْصِيَةً﴾</q> أن يوصوا، <q>﴿ولا إلى أهْلِهِمْ يَرْجِعُونَ﴾</q> مِن أسواقهم، وحيث كانوا{8}٥٤٣٧. (ز) ٥٤٣٧ قال ابنُ عطية (٧/٢٥٤): «وقوله تعالى: <q>﴿ولا إلى أهْلِهِمْ يَرْجِعُونَ﴾</q> يحتمل تأويلات: أحدها: ولا يرجع أحد إلى منزله وأهله؛ لإعجال الأمر، بل تفيض نفسه حيثما أخذته الصيحة. والثاني: معناه: <q>﴿ولا إلى أهْلِهِمْ يَرْجِعُونَ﴾</q> قولًا، وهذا أبلغ في الاستعجال، وخص الأهل بالذكر لأنّ القول معهم في ذلك الوقت أهم على الإنسان من الأجنبيين، وأوكد في نفوس البشر. والثالث: تقديره: <q>﴿ولا إلى أهْلِهِمْ يَرْجِعُونَ﴾</q> أبدًا، فخرج هذا عن معنى وصف الاستعجال إلى معنى ذكر انقطاعهم وانبتارهم من دنياهم». <q>﴿فَلَا یَسۡتَطِیعُونَ تَوۡصِیَةࣰ وَلَاۤ إِلَىٰۤ أَهۡلِهِمۡ یَرۡجِعُونَ ۝٥٠﴾</q> - آثار متعلقة بالآيتين ٦٤٧٥٠- عن أبي هريرة، قال: قال رسول الله ﷺ: «لَتَقُومَنَّ الساعةُ وقد نشر الرجلان ثوبهما بينهما، فلا يتبايعانه، ولا يطويانه، ولتقومن الساعة وهو يليط حوضه{9}، فلا يسقي فيه، ولتقومن الساعة وقد انصرف الرجلُ بلبن لقحته، فلا يطعمه، ولتقومن الساعة وقد رفع أكلته إلى فيه، فلا يطعمها»{10}. (١٢/٣٥٧) ",footnotes:1:عزاه السيوطي إلى عبد الله بن أحمد في زوائد الزهد، وعبد بن حميد، وابن المنذر.عزاه السيوطي إلى عبد الرزاق، والفريابي، وعبد بن حميد، وابن المنذر، وابن مردويه. وأخرج نحوه يحيى بن سلّام في تفسيره ٢/٨١٢ من طريق أبي المُهَزِّم دون ذكر الآية بلفظ: تقوم الساعة والرجلان في السوق وميزانهما في أيديهما.أخرجه البيهقي في شعب الإيمان ٢/٢٠٦-٢٠٧ (٣٥٠).عزاه السيوطي إلى سعيد بن منصور، وابن المنذر.أخرجه ابن جرير ١٩/٤٥١. وعزاه السيوطي إلى عبد بن حميد، وابن أبي حاتم.تفسير مقاتل بن سليمان ٣/٥٨١.أخرجه ابن جرير ١٩/٤٥٤ -وأورده تحت تفسير هذه الآية-. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.تفسير يحيى بن سلّام ٢/٨١٢.يُليط حوضه: جمع حجارة فصيَّرها كالحوض، ثم سد ما بينها من الفُرَج بالمدر ونحوه لينحبس الماء. فتح الباري ١١/٣٥٧.أخرجه البخاري ٨/١٠٦ (٦٥٠٦)، ٩/٥٩ (٧١٢١)، ومسلم ٤/٢٢٧٠(٢٩٥٤)، ويحيى بن سلام في تفسيره ٢/٨١٢.
36,51," <q>﴿وَنُفِخَ فِی ٱلصُّورِ﴾</q> - تفسير ٦٤٧٥١- عن عبد الملك ابن جريج، في قوله: <q>﴿ونُفِخَ فِي الصُّورِ فَإذا هُمْ مِنَ الأَجْداثِ﴾</q>، قال: النفخة الأخيرة{1}. (١٢/٣٥٧) ٦٤٧٥٢- قال يحيى بن سلّام: قوله ﷿: <q>﴿ونُفِخَ فِي الصُّورِ﴾</q> وهذه النفخة الآخرة. والصور: قرن{2}. (ز) <q>﴿فَإِذَا هُم مِّنَ ٱلۡأَجۡدَاثِ﴾</q> - تفسير ٦٤٧٥٣- عن عبد الله بن عباس -من طريق علي-: <q>﴿فَإذا هُمْ مِنَ الأَجْداثِ﴾</q>، يعني: مِن القبور{3}. (١٢/٣٥٧) ٦٤٧٥٤- عن قتادة بن دعامة -من طريق سعيد-، مثله{4}. (١٢/٣٥٨) ٦٤٧٥٥- عن عبد الله بن عباس، أنّ نافع بن الأزرق سأله عن قوله: <q>﴿مِنَ الأَجْداثِ﴾</q>. قال: القبور. قال: وهل تعرف العرب ذلك؟ قال: نعم، أما سمعت قول ابن رواحة: حينًا يقولون إذ مرُّوا على جَدَثي أرشده يا رب مِن عانٍ وقد رشدا{5}. (١٢/٣٥٨) ٦٤٧٥٦- عن الحسن البصري -من طريق ميمون المرائي- يقول: <q>﴿ونُفِخَ فِي الصُّورِ فَإذا هُمْ مِنَ الأَجْداثِ إلى رَبِّهِمْ يَنْسِلُونَ﴾</q>، قال: وثَبَ القومُ مِن قبورهم لَمّا سمعوا الصيحة، ينفضون التراب عن رؤوسهم، ويقول المؤمنون: سبحانك وبحمدك، ما عبدناك حقَّ عبادتك{6}. (ز) ٦٤٧٥٧- عن قتادة بن دعامة -من طريق سعيد- قال: <q>﴿ونُفِخَ فِي الصُّورِ﴾</q> في الخلق <q>﴿فَإذا هُمْ مِنَ الأَجْداثِ إلى رَبِّهِمْ يَنْسِلُونَ﴾</q> فإذا هم مِن القبور إلى ربِّهم يخرجون، يعني: جميع الخلق{7}. (ز) ٦٤٧٥٨- قال مقاتل بن سليمان: <q>﴿ونُفِخَ فِي الصُّورِ فَإذا هُمْ مِنَ الأَجْداثِ من القبور إلى رَبِّهِمْ يَنْسِلُونَ﴾</q> يخرجون إلى الله ﷿ مِن قبورهم أحياءً، فلمّا رأوا العذابَ ذكروا قولَ الرسل في الدنيا: إنّ البعث حقٌّ{8}. (ز) <q>﴿إِلَىٰ رَبِّهِمۡ یَنسِلُونَ ۝٥١﴾</q> - تفسير ٦٤٧٥٩- عن عبد الله بن عباس -من طريق علي- <q>﴿إلى رَبِّهِمْ يَنْسِلُونَ﴾</q>، قال: يخرجون{3}. (١٢/٣٥٧) ٦٤٧٦٠- عن قتادة بن دعامة -من طريق سعيد-، مثله{10}. (١٢/٣٥٨) ٦٤٧٦١- عن عبد الله بن عباس، أنّ نافع بن الأزرق سأله عن قوله: <q>﴿إلى رَبِّهِمْ يَنْسِلُونَ﴾</q>. قال: النسل: المشي الخَبَب{11}. قال: وهل تعرف العرب ذلك؟ قال: نعم، أما سمعت نابغة بني جعدة وهو يقول: عَسَلانَ{12} الذئب أمسى قاربًا{13} بَرَدَ الليلُ عليه فنَسَلْ{14}. (١٢/٣٥٨) ٦٤٧٦٢- عن محمد بن السائب الكلبي -من طريق معمر- في قوله تعالى: <q>﴿يَنْسِلُونَ﴾</q>، قال: يزفون على أقدامهم{15}. (ز) ٦٤٧٦٣- قال مقاتل بن سليمان: <q>﴿ونُفِخَ فِي الصُّورِ فَإذا هُمْ مِنَ الأَجْداثِ من القبور إلى رَبِّهِمْ يَنْسِلُونَ﴾</q> يخرجون{8}. (ز) <q>﴿إِلَىٰ رَبِّهِمۡ یَنسِلُونَ ۝٥١﴾</q> - آثار متعلقة بتفسير الآية ٦٤٧٦٤- عن عكرمة مولى ابن عباس -من طريق الجريري- قال: النفخة الأولى مِن الدنيا، والنفخة الثانية من الآخرة{7}. (ز) ٦٤٧٦٥- قال الحسن البصري: القيامة: اسم جامع يجمع النفختين جميعًا{18}. (ز) ٦٤٧٦٦- عن مَعَدِّيِّ بن سليمان، قال: كان أبو محلم الحري يجتمع إليه إخوانُه، وكان حكيمًا، فكان إذا تلا هذه الآية: <q>﴿ونُفِخَ فِي الصُّورِ فَإذا هُمْ مِنَ الأَجْداثِ إلى رَبِّهِمْ يَنْسِلُونَ﴾</q> بكى، ثم قال: إنّ القيامة في كتاب الله لَمَعاريض، صِفَةٌ ذهبت فظاعتُها بأوهام العقول، أما -واللهِ- لئن كان القومُ في رقدة مثل ظاهر قولهم لَما دَعَوا بالويل عند أول وهْلة مِن بعْثهم، ولم يوقفوا بعد موقف عرض ولا مسألة إلا وقد عاينوا خطرًا عظيمًا، وحققت عليهم القيامة بالجلائل مِن أمرها، ولئن كانوا في طول الإقامة في البرزخ يألمون ويُعذَّبون في قبورهم فما دعَوا بالويل عند انقطاع ذلك عنهم إلا وقد نُقلوا إلى ظلمة هي أعظم منه، ولولا أنّ الأمر على ذلك لما استصغر القومُ ما كانوا فيه؛ فسَمَّوه: رُقادًا، وإنّ في القرآن دليلًا على ذلك حين يقول: <q>﴿فَإذا جاءَتِ الطّامَّةُ الكُبْرى﴾</q> [النازعات:٣٤]. قال: ثم يبكي حتى تبلَّ لحيته{19}. (ز) ",footnotes:1:عزاه السيوطي إلى ابن المنذر.تفسير يحيى بن سلّام ٢/٨١٢.أخرجه ابن جرير ١٩/٤٥٥. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.أخرجه ابن جرير ١٩/٤٥٥. وعزاه السيوطي إلى عبد بن حميد.أخرجه الطستي -كما في الإتقان ٢/٩٧-.أخرجه ابن أبي الدنيا في كتاب القبور -موسوعة الإمام ابن أبي الدنيا ٦/٧١ (٨٠)-. وأخرجه في كتاب الأهوال ٦/١٧١ (٨٥) إلى قوله: ينفضون التراب.أخرجه يحيى بن سلّام ٢/٨١٣.تفسير مقاتل بن سليمان ٣/٥٨١.أخرجه ابن جرير ١٩/٤٥٥. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.أخرجه يحيى بن سلّام ٢/٨١٣، وابن جرير ١٩/٤٥٥-٤٥٦. وعزاه السيوطي إلى عبد بن حميد.الخَبَبُ: ضرب من العَدْوِ، أي: الإسراع في المشي. التاج (خبب).عسل الذئب عسلًا، وعسلانًا: مضى مسرعًا واضطرب عدوه وهز رأسه. اللسان (عسل).قارب الخَطْو: داناه، والتقريب: أن يرفع الفرس يديه معًا ويضعهما معًا. اللسان (قرب).عزاه السيوطي إلى الطستي.أخرجه عبد الرزاق ٢/١٤٤.تفسير مقاتل بن سليمان ٣/٥٨١.أخرجه يحيى بن سلّام ٢/٨١٣.علقه يحيى بن سلّام ٢/٨١٤.أخرجه ابن أبي الدنيا في كتاب الأهوال -موسوعة الإمام ابن أبي الدنيا ٦/١٧٢ (٨٧)-.
36,52," <q>﴿قَالُوا۟ یَـٰوَیۡلَنَا مَنۢ بَعَثَنَا مِن مَّرۡقَدِنَاۜۗ﴾</q> - قراءات ٦٤٧٦٧- عن أُبَيّ بن كعب، أنه قرأ: (يا ويْلَنا مَن هَبَّنا مِن مَّرْقَدِنا){1}٥٤٣٨. (١٢/٣٥٩) ٥٤٣٨ ذكر ابنُ عطية (٧/٢٥٦) قراءة أبي بن كعب، ونقل تعليق أبي الفتح عليها، فقال: «وفي قراءة أبي بن كعب (مَن هَبَّنا) قال أبو الفتح: ولم أر لها في اللغة أصلًا، ولا مرَّ بنا: مهبوب». ٦٤٧٦٨- قال سفيان: كان عبد الله [بن مسعود] يقرؤها: (مَن أهَبَّنا مِن مَّرْقَدِنا){2}. (ز) ٦٤٧٦٩- في قراءة عبد الله بن مسعود: (مِن مِّيتَتِنا){3}. (ز) ٦٤٧٧٠- عن علي بن أبي طالب، أنه قرأ: (يا ويْلَنا مِن بَعْثِنا مِن مَّرْقَدِنا){4}. (١٢/٣٥٩) <q>﴿قَالُوا۟ یَـٰوَیۡلَنَا مَنۢ بَعَثَنَا مِن مَّرۡقَدِنَاۜۗ﴾</q> - تفسير الآية ٦٤٧٧١- عن أُبَيّ بن كعب، قال: ينامون نومةً قبل البعث، فيجدون لذلك راحة، فيقولون: (يا ويْلَنا مَن هَبَّنا مِن مَّرْقَدِنا)؟!{5}. (١٢/٣٥٩) ٦٤٧٧٢- عن أُبَيّ بن كعب -من طريق الحسن- في قوله: <q>﴿يا ويْلَنا مَن بَعَثَنا مِن مَرْقَدِنا﴾</q>، قال: ينامون قبل البعث نَوْمَةً{6}٥٤٣٩. (١٢/٣٥٩) ٥٤٣٩ ذكر ابنُ عطية (٧/٢٥٦) قول أبي بن كعب ونحوه عن قتادة ومجاهد، ثم انتقده مستندًا إلى ضعف إسناده، فقال: «ويروى عن أبي بن كعب، وقتادة، ومجاهد: أنّ جميع البشر ينامون نومة قبل الحشر. وهذا غير صحيح الإسناد». ورجّح مستندًا إلى اللغة أن ذلك على سبيل الاستعارة والتشبيه، فقال: «وإنما الوجه في قولهم: <q>﴿مِن مَرْقَدِنا﴾</q> أنها استعارة وتشبيه، كما تقول في قتيلٍ: هذا مرقده إلى يوم القيامة». ٦٤٧٧٣- قال أُبَيّ بن كعب= (ز) ٦٤٧٧٤- وعبد الله بن عباس: <q>﴿يا ويْلَنا مَن بَعَثَنا مِن مَرْقَدِنا﴾</q> إنّما يقولون هذا لأنّ الله تعالى يرفع عنهم العذاب بين النفختين، فيرقدون، فإذا بُعِثوا بعد النفخة الأخيرة وعاينوا القيامة دَعَوْا بالويل{7}. (ز) ٦٤٧٧٥- عن أبي صالح باذام -من طريق الأعمش- <q>﴿يا ويْلَنا مَن بَعَثَنا مِن مَرْقَدِنا﴾</q> قال: كانوا يرون أنّ العذاب يُخَفَّف عنهم ما بين النفختين، فلمّا كانت النفخة الثانية قالوا: <q>﴿يا ويْلَنا مَن بَعَثَنا مِن مَرْقَدِنا﴾</q>{8}. (١٢/٣٦٠) ٦٤٧٧٦- قال قتادة بن دعامة -من طريق سعيد بن بشير-: إنّه لا يُفَتَّر عن أهل القبور عذابُ القبر إلا فيما بين نفخة الصعق ونفخة البعث، فلذلك يقول الكافر حين يبعث: <q>﴿يا ويْلَنا مَن بَعَثَنا مِن مَرْقَدِنا﴾</q> يعني: تلك الفترة، فيقول المؤمن: <q>﴿هَذا ما وعَدَ الرَّحْمَنُ وصَدَقَ المُرْسَلُونَ﴾</q>{9}. (ز) ٦٤٧٧٧- عن قتادة بن دعامة -من طريق سعيد بن أبي عروبة- قال: الكافر إلى جنب المؤمن، فإذا أصابته النفخةُ قال الكافر: <q>﴿يا ويلنا من بعثنا من مرقدنا هذا ما وعد الرحمن وصدق المرسلون﴾</q>{10}. (ز) ٦٤٧٧٨- عن منصور، عن رجل يُقال له: خيثمة، في قوله: <q>﴿قالوا يا ويلنا من بعثنا من مرقدنا هذا﴾</q>، قال: ينامون نومة قبل البعث{11}. (ز) ٦٤٧٧٩- قال مقاتل بن سليمان: <q>﴿قالُوا يا ويْلَنا مَن بَعَثَنا مِن مَرْقَدِنا﴾</q>، وذلك أنّ أرواح الكفار كانوا يُعرَضون على منازلهم مِن النار طَرَفَي النهار كلَّ يوم، فلما كان بين النفختين رُفِع عنهم العذاب، فرقدت تلك الأرواح بين النفختين، فلمّا بُعِثوا في النفخة الأخرى وعاينوا في القيامة ما كذَّبوا به في الدنيا من البعث والحساب فدَعَوْا بالويل، <q>﴿قالُوا يا ويْلَنا مَن بَعَثَنا مِن مَرْقَدِنا﴾</q>{12}. (ز) ٦٤٧٨٠- قال يحيى بن سلّام: وقولهم: <q>﴿مَن بَعَثَنا مِن مَرْقَدِنا﴾</q> وهو ما بين النفختين، لا يُعذّبون في قبورهم بين النفختين، ويُقال: إنها أربعون سنة، فلذلك قالوا: <q>﴿يا ويْلَنا مَن بَعَثَنا مِن مَرْقَدِنا﴾</q>. وذلك أنه إذا نفخ النفخة الأولى قيل له: اخمد. فيخمد إلى النفخة الآخرة{13}. (ز) <q>﴿قَالُوا۟ یَـٰوَیۡلَنَا مَنۢ بَعَثَنَا مِن مَّرۡقَدِنَاۜۗ هَـٰذَا مَا وَعَدَ ٱلرَّحۡمَـٰنُ وَصَدَقَ ٱلۡمُرۡسَلُونَ ۝٥٢﴾</q> - تفسير ٦٤٧٨١- عن عبد الرحمن بن أبي ليلى -من طريق ثابت- قال: يقول المشركون: <q>﴿يا ويْلَنا مَن بَعَثَنا مِن مَرْقَدِنا﴾</q>؟! فيقول المؤمن: <q>﴿هَذا ما وعَدَ الرَّحْمَنُ وصَدَقَ المُرْسَلُونَ﴾</q>{14}. (١٢/٣٥٩) ٦٤٧٨٢- عن مجاهد بن جبر -من طريق ابن أبي نجيح- قوله: <q>﴿يا ويْلَنا مَن بَعَثَنا مِن مَرْقَدِنا﴾</q> قال: الكافرون يقولونه، <q>﴿هَذا ما وعَدَ الرَّحْمَنُ﴾</q> مما سرَّ المؤمنون، يقولون هذا حين البعث{15}. (ز) ٦٤٧٨٣- عن مجاهد بن جبر -من طريق ليث- قال: للكفار هجْعة يجدون فيها طعم النوم قبل يوم القيامة، فإذا صِيح بأهل القبور يقول الكافر: <q>﴿يا ويْلَنا مَن بَعَثَنا مِن مَرْقَدِنا﴾</q>؟ فيقول المؤمن إلى جنبه: <q>﴿هَذا ما وعَدَ الرَّحْمَنُ وصَدَقَ المُرْسَلُونَ﴾</q>{16}. (١٢/٣٥٩) ٦٤٧٨٤- عن الحسن البصري، قال: ينامون قبل البعث نومة، فإذا بُعِثوا قال الكفار: <q>﴿يا ويْلَنا مَن بَعَثَنا مِن مَرْقَدِنا﴾</q>؟ قال: فتجيبهم الملائكة: <q>﴿هَذا ما وعَدَ الرَّحْمَنُ وصَدَقَ المُرْسَلُونَ﴾</q>{17}. (١٢/٣٦٠) ٦٤٧٨٥- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿يا ويْلَنا مَن بَعَثَنا مِن مَرْقَدِنا﴾</q> قال: أولها للكفار، وآخرها للمسلمين؛ قال الكفار: <q>﴿يا ويْلَنا مَن بَعَثَنا مِن مَرْقَدِنا﴾</q>؟ وقال المسلمون: <q>﴿هَذا ما وعَدَ الرَّحْمَنُ وصَدَقَ المُرْسَلُونَ﴾</q>{18}. (١٢/٣٦٠) ٦٤٧٨٦- وعن أُبَيّ بن كعب -من طريق الحسن-، مثل ذلك{19}. (ز) ٦٤٧٨٧- عن زيد بن أسلم -من طريق عثمان- قال: قال الكفار: <q>﴿يا ويْلَنا مَن بَعَثَنا مِن مَرْقَدِنا﴾</q>؟ قالت الملائكة: <q>﴿هَذا ما وعَدَ الرَّحْمَنُ وصَدَقَ المُرْسَلُونَ﴾</q>{20}. (ز) ٦٤٧٨٨- قال مقاتل بن سليمان: فلمّا بُعثوا في النفخة الأخرى وعاينوا في القيامة ما كذَّبوا به في الدنيا مِن البعث والحساب فَدَعَوا بالويل، <q>﴿قالُوا يا ويْلَنا مَن بَعَثَنا مِن مَرْقَدِنا﴾</q>؟ قال حفظتهم من الملائكة: <q>﴿هَذا ما وعَدَ الرَّحْمنُ﴾</q> على ألسنة الرسل. فذلك قوله ﷿: <q>﴿وصَدَقَ المُرْسَلُونَ﴾</q>{12}. (ز) ٦٤٧٨٩- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿يا ويْلَنا مَن بَعَثَنا مِن مَرْقَدِنا﴾</q>: ثم قال بعضهم لبعض: <q>﴿هَذا ما وعَدَ الرَّحْمَنُ وصَدَقَ المُرْسَلُونَ﴾</q> كانوا أخبرونا أنّا نُبعث بعد الموت، ونُحاسب، ونُجازى{22}٥٤٤٠. (ز) ٥٤٤٠ اختُلف في قائل هذه المقالة: <q>﴿هذا ما وعد الرحمن وصدق المرسلون﴾</q> على أقوال: الأول: أنهم المؤمنون. الثاني: أنهم الكفار. الثالث: أنهم الملائكة. وقد رجّح ابنُ جرير (١٩/٤٥٨) مستندًا إلى الدلالة العقلية القولَ الأول، فقال: «والقول الأول أشبه بظاهر التنزيل، وهو أن يكون من كلام المؤمنين؛ لأن الكفار في قيلهم: <q>﴿من بعثنا من مرقدنا﴾</q> دليل على أنهم كانوا بمن بعثهم من مرقدهم جهالًا، ولذلك مِن جهلهم استثبتوا، ومحال أن يكونوا استثبتوا ذلك إلا مِن غيرهم مِمَّن خالفت صفتُه صفتَهم في ذلك». وكذا رجّح ابنُ كثير (١١/٣٦٨) مستندًا إلى النظائر القول الأول بقوله: «وهو أصح، وذلك كقوله تعالى في الصافات: <q>﴿وقالوا يا ويلنا هذا يوم الدين هذا يوم الفصل الذي كنتم به تكذبون﴾</q> [الصافات:٢٠-٢١]، وقال الله تعالى: <q>﴿ويوم تقوم الساعة يقسم المجرمون ما لبثوا غير ساعة كذلك كانوا يؤفكون * وقال الذين أوتوا العلم والإيمان لقد لبثتم في كتاب الله إلى يوم البعث فهذا يوم البعث ولكنكم كنتم لا تعلمون﴾</q> [الروم:٥٥-٥٦]». وذكر ابنُ كثير القول الأول والثالث، وعلّق عليهما قائلًا: «ولا منافاة؛ إذ الجمع ممكن». ٦٤٧٩٠- قال سفيان -من طريق إسحاق بن إسماعيل-: هذا موصول مفصول{23}. (ز) ",footnotes:1:عزاه السيوطي إلى ابن الأنباري. وهي قراءة شاذة. انظر: المحتسب ٢/٢١٣.تفسير سفيان الثوري (٢٥٠)، وذكره ابن جرير في تفسيره ١٩/٤٥٧. وهي قراءة شاذة. انظر: المحتسب ٢/٢١٣.تفسير مقاتل بن سليمان ٣/٥٨٢. وقد وقعت فيه القراءة كما أثبتنا، والظاهر أنها مصحَّفة عن (هبَّنا)، كما نسب إليه في مختصر ابن خالويه ص١٢٥.عزاه السيوطي إلى ابن الأنباري في المصاحف. وهي قراءة شاذة، تروى أيضًا عن الضحاك، وأبي نهيك. انظر: المحتسب ٢/٢١٣، ومختصر ابن خالويه ص١٢٦.عزاه السيوطي إلى ابن الأنباري.أخرجه ابن جرير ١٩/٤٥٦، وإسحاق البستي ص١٩١ من طريق خيثمة. وعزاه السيوطي إلى الفريابي، وعبد بن حميد، وابن المنذر، وابن أبي حاتم.تفسير البغوي ٧/٢١.أخرجه ابن أبي شيبة في مصنفه (ت: محمد عوامة) ١٩/٤١١ (٣٦٥١٣). وعزاه السيوطي إلى ابن المنذر.أخرجه ابن أبي الدنيا في كتاب الأهوال -موسوعة الإمام ابن أبي الدنيا ٦/١٧٢-١٧٣ (٨٨)-.أخرجه إسحاق البستي ص١٩١.أخرجه إسحاق البستي ص١٩١، وابن جرير ١٩/٤٥٦.تفسير مقاتل بن سليمان ٣/٥٨٢.تفسير يحيى بن سلّام ٢/٨١٣.أخرجه ابن أبي شيبة ١٣/٤٢٧.تفسير مجاهد (٥٦٠)، وأخرجه ابن جرير ١٩/٤٥٧-٤٥٨.أخرجه هناد في الزهد (٣١٧). وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم، وابن الأنباري.عزاه السيوطي إلى ابن أبي حاتم.أخرجه يحيى بن سلام ٢/٨١٣ بنحوه -وينظر: المكتفى ص١٧٥ (٢٨)-، وعبد الرزاق ٢/١٤٤-١٤٥ من طريق معمر، وابن أبي الدنيا في كتاب الأهوال -موسوعة الإمام ابن أبي الدنيا ٦/١٧١-١٧٢ (٨٦)-، وابن جرير ١٩/٤٥٦، ٤٥٨ بنحوه. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.أخرجه يحيى بن سلّام ٢/٨١٣.أخرجه يحيى بن سلّام ٢/٨١٣، وعقَّب عليه بقوله: وبعضهم يقول: هم الملائكة الذين كانوا يكتبون أعمالهم.تفسير مقاتل بن سليمان ٣/٥٨٢.أخرجه ابن جرير ١٩/٤٥٨.أخرجه ابن أبي الدنيا في كتاب الأهوال -موسوعة الإمام ابن أبي الدنيا ٦/١٧١-١٧٢ (٨٦)-. ونصه: هذا موصول مفضول. والظاهر أن «مفضول» تصحيف عن «مفصول»، وأن المراد: أن الآية مِن الموصول لفظًا المفصول معنى. ينظر في بيان هذا النوع من أنواع علوم القرآن: الإتقان ١/٢٣٦.
36,53," <q>﴿إِن كَانَتۡ إِلَّا صَیۡحَةࣰ وَ ٰ⁠حِدَةࣰ فَإِذَا هُمۡ جَمِیعࣱ لَّدَیۡنَا مُحۡضَرُونَ ۝٥٣﴾</q> - تفسير ٦٤٧٩١- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿فَإذا هُمْ جَمِيعٌ لَدَيْنا مُحْضَرُونَ﴾</q>، قال: عند الحساب{1}. (١٢/٣٦٠) ٦٤٧٩٢- عن إسماعيل السُدِّيّ: <q>﴿إنْ كانَتْ﴾</q> يعني: ما كانت <q>﴿إلّا صَيْحَةً واحِدَةً﴾</q> قال: وكذلك كل «إن» خفيفة تستقبلها «إلا»{2}. (ز) ٦٤٧٩٣- قال مقاتل بن سليمان: وذكر النفخة الثانية، فقال سبحانه: <q>﴿إنْ﴾</q> يعني: ما <q>﴿كانَتْ إلّا صَيْحَةً واحِدَةً﴾</q> مِن إسرافيل؛ <q>﴿فَإذا هُمْ جَمِيعٌ﴾</q> الخلق كلهم <q>﴿لَدَيْنا﴾</q> عندنا <q>﴿مُحْضَرُونَ﴾</q> بالأرض المقدسة فلسطين؛ لنحاسبهم{3}. (ز) ٦٤٧٩٤- قال يحيى بن سلّام: قوله ﷿: <q>﴿إنْ كانَتْ إلّا صَيْحَةً واحِدَةً﴾</q> مِن إسرافيل، يعني: النفخة الثانية، يعني: القيامة؛ <q>﴿فَإذا هُمْ جَمِيعٌ﴾</q> المؤمنون والكافرون <q>﴿لَدَيْنا﴾</q> عندنا <q>﴿مُحْضَرُونَ﴾</q>{4}. (ز) ",footnotes:1:أخرجه الفريابي -كما في التغليق ٣/٥١٤-. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.علقه يحيى بن سلّام ٢/٨١٤.تفسير مقاتل بن سليمان ٣/٥٨٢.تفسير يحيى بن سلّام ٢/٨١٤.
36,54," <q>﴿فَٱلۡیَوۡمَ لَا تُظۡلَمُ نَفۡسࣱ شَیۡـࣰٔا وَلَا تُجۡزَوۡنَ إِلَّا مَا كُنتُمۡ تَعۡمَلُونَ ۝٥٤﴾</q> - تفسير ٦٤٧٩٥- عن إسماعيل السُدِّيّ: <q>﴿فاليَوْمَ﴾</q> يعني: في الآخرة، يقوله يومئذ{1}. (ز) ٦٤٧٩٦- قال مقاتل بن سليمان: <q>﴿فاليَوْمَ﴾</q> في الآخرة <q>﴿لا تُظْلَمُ نَفْسٌ شَيْئًا ولا تُجْزَوْنَ إلّا ما كُنْتُمْ تَعْمَلُونَ﴾</q> مِن الكُفْر، جزاء الكافر النار{2}. (ز) ",footnotes:1:علقه يحيى بن سلّام ٢/٨١٤.تفسير مقاتل بن سليمان ٣/٥٨٢.
