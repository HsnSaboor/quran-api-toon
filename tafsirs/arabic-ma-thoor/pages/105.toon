quran[5]{c,v,t}:
4,171," <q>﴿یَـٰۤأَهۡلَ ٱلۡكِتَـٰبِ لَا تَغۡلُوا۟ فِی دِینِكُمۡ وَلَا تَقُولُوا۟ عَلَى ٱللَّهِ إِلَّا ٱلۡحَقَّۚ إِنَّمَا ٱلۡمَسِیحُ عِیسَى ٱبۡنُ مَرۡیَمَ رَسُولُ ٱللَّهِ وَكَلِمَتُهُۥۤ أَلۡقَىٰهَاۤ إِلَىٰ مَرۡیَمَ وَرُوحࣱ مِّنۡهُۖ فَـَٔامِنُوا۟ بِٱللَّهِ وَرُسُلِهِۦۖ وَلَا تَقُولُوا۟ ثَلَـٰثَةٌۚ ٱنتَهُوا۟ خَیۡرࣰا لَّكُمۡۚ إِنَّمَا ٱللَّهُ إِلَـٰهࣱ وَ ٰ⁠حِدࣱۖ سُبۡحَـٰنَهُۥۤ أَن یَكُونَ لَهُۥ وَلَدࣱۘ لَّهُۥ مَا فِی ٱلسَّمَـٰوَ ٰ⁠تِ وَمَا فِی ٱلۡأَرۡضِۗ وَكَفَىٰ بِٱللَّهِ وَكِیلࣰا ۝١٧١﴾</q> - نزول الآية ٢١٠٨١- قال الحسن البصري: يجوز أن تكون نزلت في اليهود والنصارى، فإنّهم جميعًا غَلَوْا في أمر عيسى، فاليهود بالتقصير، والنصارى بمجاوزة الحد{1}. (ز) <q>﴿یَـٰۤأَهۡلَ ٱلۡكِتَـٰبِ لَا تَغۡلُوا۟ فِی دِینِكُمۡ وَلَا تَقُولُوا۟ عَلَى ٱللَّهِ إِلَّا ٱلۡحَقَّۚ﴾</q> - تفسير ٢١٠٨٢- عن الحسن البصري -من طريق خُلَيْدٍ بنِ دَعْلَجٍ- في قوله: <q>﴿لا تغلوا في دينكم﴾</q>، قال: لا تعتدوا{2}. (ز) ٢١٠٨٣- عن قتادة بن دعامة -من طريق خُلَيْدٍ بنِ دَعْلَجٍ- في قوله: <q>﴿لا تغلوا﴾</q>، قال: لا تبتدعوا{3}. (٥/١٤٠) ٢١٠٨٤- عن الربيع بن أنس -من طريق أبي جعفر- قال: صاروا فريقين: فريق غلوا في الدين، فكان غلوهم فيه الشكَّ فيه والرغبةَ عنه، وفريق منهم قَصَّروا عنه، ففسقوا عن أمر ربهم{4}. (ز) ٢١٠٨٥- قال مقاتل بن سليمان: <q>﴿ياأهل الكتاب﴾</q> يعني: النصارى، <q>﴿لا تغلوا في دينكم﴾</q> يعني: الإسلام، فالغلو فى الدِّين أن تقولوا على الله غيرَ الحق فى أمر عيسى ابن مريم ﷺ، <q>﴿ولا تقولوا على الله إلا الحق إنما المسيح عيسى ابن مريم رسول الله﴾</q> وليس لله تبارك وتعالى ولدًا{5}. (ز) ٢١٠٨٦- قال أصبغ بن الفرج: سمعت عبد الرحمن بن زيد بن أسلم يقول في قوله: <q>﴿لا تغلوا في دينكم﴾</q> قال: الغُلُوُّ فِراقُ الحق، وكان مِمّا غَلَوْا فيه أن دَعَوا لله صاحبة وولدًا{2}. (ز) <q>﴿إِنَّمَا ٱلۡمَسِیحُ عِیسَى ٱبۡنُ مَرۡیَمَ رَسُولُ ٱللَّهِ وَكَلِمَتُهُۥۤ أَلۡقَىٰهَاۤ إِلَىٰ مَرۡیَمَ وَرُوحࣱ مِّنۡهُۖ فَـَٔامِنُوا۟ بِٱللَّهِ وَرُسُلِهِۦۖ وَلَا تَقُولُوا۟ ثَلَـٰثَةٌۚ ٱنتَهُوا۟ خَیۡرࣰا لَّكُمۡۚ إِنَّمَا ٱللَّهُ إِلَـٰهࣱ وَ ٰ⁠حِدࣱۖ﴾</q> - تفسير ٢١٠٨٧- عن أُبَيِّ بن كعب -من طريق أبي العالية- في قوله: <q>﴿وإذ أخذ ربك من بني آدم من ظهورهم ذريتهم﴾</q> [الأعراف:١٧٢]، قال: أخذهم فجعلهم أرواحًا، ثُمَّ صوَّرهم، ثم استنطقهم، فكان روح عيسى مِن تلك الأرواح التي أُخِذ عليها العهد والميثاق، فأرسل ذلك الروح إلى مريم، فدخل في فيها، فحملت الذي خاطبها، وهو روح عيسى ﵇{7}. (ز) ٢١٠٨٨- عن مجاهد بن جبر -من طريق ليث- <q>﴿وكلمته ألقاها إلى مريم وروح منه﴾</q>، قال: رسول منه{8}١٩٠٩. (ز) ١٩٠٩ عَلَّق ابنُ تيمية (٢/٣٧٨) قائلًا: «يريد مجاهد قولَه: <q>﴿فَأَرْسَلْنا إلَيْها رُوحَنا فَتَمَثَّلَ لَها بَشَرًا سَوِيًّا * قالَتْ إنِّي أعُوذُ بِالرَّحْمَنِ مِنكَ إنْ كُنْتَ تَقِيًّا * قالَ إنَّما أنا رَسُولُ رَبِّكِ﴾</q> [مريم:١٧-١٩]». ٢١٠٨٩- عن قتادة بن دِعامة -من طريق مَعْمَر- في قوله: <q>﴿وكلمته ألقاها إلى مريم﴾</q>، قال: كلمته أن قال: كن. فكان{9}. (٥/١٤٠) ٢١٠٩٠- قال إسماعيل السُّدِّيِّ: <q>﴿وروح منه﴾</q>، أي: مخلوقًا مِن عنده{10}١٩١٠. (ز) ١٩١٠ رجَّح ابنُ كثير (٤/٣٨٩) مستندًا إلى النظائر أنّ معنى: <q>﴿ورُوحٌ مِنهُ﴾</q>: «أنّه مخلوق مِن روح مخلوقة، وأضيفت الروح إلى الله على وجْه التشريف، كما أضيفت الناقة والبيت إلى الله في قوله: <q>﴿هَذِهِ ناقَةُ اللَّهِ﴾</q> [هود:٦٤]، وفي قوله: <q>﴿وطَهِّرْ بَيْتِيَ لِلطّائِفِينَ﴾</q> [الحج:٢٦]، وكما ورد في الحديث الصحيح: «فأدخل على ربي في داره»، أضافها إليه إضافة تشريف لها، وهذا كله من قبيلٍ واحد، ونمط واحد». ٢١٠٩١- عن أحمد بن سنان الواسطي، قال: سمعت شاذ بن يحيى يقول في قوله تعالى: <q>﴿وكلمته ألقاها إلى مريم وروح منه﴾</q>، قال: ليس الكلمة صارت عيسى، ولكن بالكلمة صار عيسى{8}١٩١١. (ز) ١٩١١ عَلَّق ابنُ كثير (٤/٣٨٨) على أثر شاذ بن يحيى، فقال: «وهذا أحسن مما ادَّعاه ابن جرير في قوله: <q>﴿ألْقاها إلى مَرْيَمَ﴾</q> أي: أعلمها بها. كما زعمه في قوله: <q>﴿إذْ قالَتِ المَلائِكَةُ يا مَرْيَمُ إنَّ اللَّهَ يُبَشِّرُكِ بِكَلِمَةٍ مِنهُ﴾</q> [آل عمران:٤٥]، أي: يعلمك بكلمة منه، ويجعل ذلك كقوله تعالى: <q>﴿وما كُنْتَ تَرْجُو أنْ يُلْقى إلَيْكَ الكِتابُ إلا رَحْمَةً مِن رَبِّكَ﴾</q> [القصص:٨٦]». ورَجَّح، فقال: «بل الصحيح أنّها الكلمةُ التي جاء بها جبريل إلى مريم، فنفخ فيها بإذن الله، فكان عيسى ﵇». ولم يذكر مستندًا. ٢١٠٩٢- عن شاذ بن يحيى، قال: قلتُ ليزيد بن هارون: أي شيء أحلها؟ قال: روح الله بين عباده، قال: تحاب الناس. ثم قرأ يزيد: <q>﴿وكلمته ألقاها إلى مريم وروح منه﴾</q>، قال: محبة{8}. (ز) ٢١٠٩٣- قال مقاتل بن سليمان: <q>﴿وكلمته﴾</q> يعنى بالكلمة قال: كن. فكان، <q>﴿ألقاها إلى مريم وروح منه﴾</q> يعني: بالروح أنّه كان من غير بشر. نزلت فى نصارى نجران في السيد والعاقب ومن معهما. ثم قال سبحانه: <q>﴿فآمنوا﴾</q> يعني: صَدِّقوا <q>﴿بالله﴾</q> ﷿ بأنّه واحد لا شريك له، <q>﴿ورسله﴾</q> يعني: محمدًا ﷺ بأنّه نبي ورسول، <q>﴿ولا تقولوا ثلاثة﴾</q> يعني: لا تقولوا: إنّ الله ﷿ ثالث ثلاثة، <q>﴿انتهوا خيرا لكم إنما الله إله واحد﴾</q>{5}. (ز) <q>﴿إِنَّمَا ٱلۡمَسِیحُ عِیسَى ٱبۡنُ مَرۡیَمَ رَسُولُ ٱللَّهِ وَكَلِمَتُهُۥۤ أَلۡقَىٰهَاۤ إِلَىٰ مَرۡیَمَ وَرُوحࣱ مِّنۡهُۖ فَـَٔامِنُوا۟ بِٱللَّهِ وَرُسُلِهِۦۖ وَلَا تَقُولُوا۟ ثَلَـٰثَةٌۚ ٱنتَهُوا۟ خَیۡرࣰا لَّكُمۡۚ إِنَّمَا ٱللَّهُ إِلَـٰهࣱ وَ ٰ⁠حِدࣱۖ﴾</q> - آثار متعلقة بالآية ٢١٠٩٤- عن عمر بن الخطاب، قال: قال رسول الله ﷺ: «لا تُطْروني كما أطْرَتِ النصارى عيسى بن مريم، فإنما أنا عبد، فقولوا: عبد الله ورسوله»{14}. (٥/١٤١) ٢١٠٩٥- عن عبد الله بن مسعود، قال: بعثنا رسول الله ﷺ إلى النجاشي، ونحن ثمانون رجلًا، ومعنا جعفر بن أبي طالب، وبعثت قريشُ عمارة وعمرو بن العاص، ومعهما هديةٌ إلى النجاشي، فلمّا دخلا عليه سجدا له، وبَعَثا إليه بالهدية، وقالا: إنّ ناسا من قومنا رَغِبوا عن ديننا، وقد نزلوا أرضك. قال: أين هم؟ قالا: هم في أرضك. فبعث إليهم، حتى دخلوا عليه، فلم يسجدوا له، فقالوا: ما لكم لم تسجدوا للملك؟ فقال جعفر: إنّ الله بعث إلينا نبيه، فأمرنا ألا نسجد إلا لله. فقال عمرو بن العاص: إنّهم يخالفونك في عيسى وأُمِّه. قال: فما يقولون في عيسى وأمه؟ قالوا: نقول كما قال الله، هو روح الله، وكلمته ألقاها إلى العذراء البتول التي لم يمسسها بشر. فتناول النجاشيُّ عودًا، فقال: يا معشر القسيسين والرهبان، ما تزيدون على ما يقول هؤلاء ما يَزِنُ هذه، مرحبًا بكم وبمن جئتم من عنده، فأنا أشهد أنّه نبي، ولوددت أنِّي عنده فأحْمِل نعليه، فانزلوا حيث شئتم مِن أرضي{15}. (٥/١٤٠) ٢١٠٩٦- عن أبي موسى الأشعري: أنّ النجاشي قال لجعفر: ما يقول صاحبُك في ابن مريم؟ قال: يقول فيه قول الله: روحُ الله، وكلمته، أخرجه من البتول العذراء، لم يقربها بشر. فتناول عودًا من الأرض، فرفعه، فقال: يا معشر القِسِّيسين والرهبان، ما يزيد هؤلاء على ما تقولون في ابن مريم ما يَزِنُ هذه{16}. (٥/١٤٠) ٢١٠٩٧- عن عبادة بن الصامت، عن النبي ﷺ، قال: «مَن شهد أن لا إله إلا الله وحده لا شريك له، وأنّ محمدًا عبده ورسوله، وأنّ عيسى عبد الله ورسوله، وكلمته ألقاها إلى مريم، وروح منه، والجنة حقٌّ، والنار حقٌّ؛ أدخله الله مِن أبواب الجنة الثمانية مِن أيِّها شاء على ما كان من العمل»{17}. (٥/١٤١) <q>﴿سُبۡحَـٰنَهُۥۤ أَن یَكُونَ لَهُۥ وَلَدࣱۘ لَّهُۥ مَا فِی ٱلسَّمَـٰوَ ٰ⁠تِ وَمَا فِی ٱلۡأَرۡضِۗ وَكَفَىٰ بِٱللَّهِ وَكِیلࣰا ۝١٧١﴾</q> - تفسير ٢١٠٩٨- قال مقاتل بن سليمان: <q>﴿سبحانه أن يكون له ولد﴾</q> يعني: عيسى ﷺ، <q>﴿له ما في السماوات وما في الأرض﴾</q> مِن الخلق عبيده، وفى ملكه عيسى وغيره، <q>﴿وكفى بالله وكيلا﴾</q> يعني: شهيدًا بذلك{5}. (ز) ",footnotes:1:تفسير البغوي ٢/٣١٤.أخرجه ابن أبي حاتم ٤/١١٢٢.أخرجه ابن أبي حاتم ٤/١١٢٢. وعزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ٧/٧٠١.تفسير مقاتل بن سليمان ١/٤٢٤-٤٢٥.أخرجه ابن أبي حاتم ٤/١١٢٢.أخرجه ابن جرير ٧/٧٠٥.أخرجه ابن أبي حاتم ٤/١١٢٣.أخرجه عبد الرزاق ١/١٧٧، وابن جرير ٥/٤٠٧، ٧/٧٠٣. وعزاه السيوطي إلى ابن المنذر.تفسير الثعلبي ٣/٤١٩.أخرجه ابن أبي حاتم ٤/١١٢٣.أخرجه ابن أبي حاتم ٤/١١٢٣.تفسير مقاتل بن سليمان ١/٤٢٤-٤٢٥.أخرجه البخاري ٤/١٦٧ (٣٤٤٥).أخرجه أحمد ٧/٤٠٨-٤٠٩ (٤٤٠٠)، والطيالسي١/٢٧٠-٢٧١ (٣٤٤) بلفظ مقارب. قال ابن كثير في البداية والنهاية ٤/١٧٤: «هذا إسناد جيد قوي، وسياق حسن». وقال الهيثمي في المجمع ٦/٢٤ (٩٨٤١): «رواه الطبراني، وفيه حديج بن معاوية، وثقه أبو حاتم، وقال: في بعض حديثه ضعف. وضعفه ابن معين وغيره، وبقية رجاله ثقات». وقال ابن حجر في الفتح ٧/١٨٩: «بإسناد حسن».أخرجه الحاكم ٢/٣٣٨ (٣٢٠٨) مطولًا. قال الحاكم: «هذا حديث صحيح، على شرط الشيخين، ولم يخرجاه». وقال البيهقي في دلائل النبوة ٢/٣٠٠: «هذا إسناد صحيح». وقال البوصيري في إتحاف الخيرة ٥/٧٧-٧٨ (٤٢٦١): «هذا إسناد رواته ثقات».أخرجه البخاري ٤/١٦٥ (٣٤٣٥)، ومسلم ١/٥٧ (٢٨).تفسير مقاتل بن سليمان ١/٤٢٤-٤٢٥.
4,172," <q>﴿لَّن یَسۡتَنكِفَ ٱلۡمَسِیحُ أَن یَكُونَ عَبۡدࣰا لِّلَّهِ وَلَا ٱلۡمَلَـٰۤىِٕكَةُ ٱلۡمُقَرَّبُونَۚ وَمَن یَسۡتَنكِفۡ عَنۡ عِبَادَتِهِۦ وَیَسۡتَكۡبِرۡ فَسَیَحۡشُرُهُمۡ إِلَیۡهِ جَمِیعࣰا ۝١٧٢﴾</q> - نزول الآية ٢١٠٩٩- قال محمد بن السائب الكلبي: إنّ وفد نجران قالوا: يا محمدُ، تَعِيبُ صاحبَنا؟ قال: «ومَن صاحبكم؟». قالوا: عيسى. قال: «وأي شئ أقول فيه؟». قالوا: تقول: إنّه عبد الله ورسوله. فقال لهم: «إنّه ليس بعارٍ لعيسى أن يكون عبدًا لله». قالوا: بلى. فنزلت: <q>﴿لن يستنكف المسيح أن يكون عبدًا لله﴾</q> الآية{1}. (ز) <q>﴿لَّن یَسۡتَنكِفَ ٱلۡمَسِیحُ أَن یَكُونَ عَبۡدࣰا لِّلَّهِ﴾</q> - تفسير ٢١١٠٠- عن عبد الله بن عباس -من طريق عطاء- في قوله: <q>﴿لن يستنكف﴾</q>، قال: لن يستكبر{2}. (٥/١٤١) ٢١١٠١- وعن عطاء الخراساني، نحو ذلك{3}. (ز) ٢١١٠٢- عن قتادة بن دِعامة -من طريق سعيد- <q>﴿لن يستنكف المسيح أن يكون عبدا لله ولا الملائكة المقربون﴾</q>، قال: لن يحتشم المسيح أن يكون عبدًا لله، ولا الملائكة المقربين{4}. (ز) ٢١١٠٣- قال مقاتل بن سليمان: ثُمَّ قال ﷿: <q>﴿لن يستنكف المسيح﴾</q> يعني: لن يَأْنَفَ <q>﴿أن يكون عبدًا لله﴾</q>{5}. (ز) <q>﴿وَلَا ٱلۡمَلَـٰۤىِٕكَةُ ٱلۡمُقَرَّبُونَۚ﴾</q> - تفسير ٢١١٠٤- عن الأجلح، قال: قلتُ للضحاك بن مُزاحِم: ما المُقَرَّبون؟ قال: أقربهم إلى السماء الثانية{6}. (ز) ٢١١٠٥- قال مقاتل بن سليمان: <q>﴿ولا﴾</q> يستنكف <q>﴿الملائكة المقربون﴾</q> أن يكونوا عبيدًا لله؛ ليعتبروا بكون الملائكة أقربَ إلى الله ﷿ منزلةً مِن عيسى ابن مريم وغيره، فإنّ عيسى عبدٌ مِن عباده{5}. (ز) <q>﴿وَمَن یَسۡتَنكِفۡ عَنۡ عِبَادَتِهِۦ وَیَسۡتَكۡبِرۡ فَسَیَحۡشُرُهُمۡ إِلَیۡهِ جَمِیعࣰا ۝١٧٢﴾</q> - تفسير ٢١١٠٦- عن الضحاك بن مُزاحِم -من طريق أبي سنان- في قوله: <q>﴿جميعا﴾</q>، قال: البَرُّ، والفاجِر{2}. (ز) ٢١١٠٧- قال مقاتل بن سليمان: ثُمَّ أوعد النصارى، فقال: <q>﴿ومن يستنكف﴾</q> يعني: ومن يأْنَف <q>﴿عن عبادته ويستكبر﴾</q> يعني: مَن يأنف عن عبادة الله، يعني: التوحيد، <q>﴿ويستكبر﴾</q> يعني: ويتكبر عن العبادة؛ <q>﴿فسيحشرهم إليه جميعا﴾</q>، فلم يستنكف ويستكبر غير إبليس{5}. (ز) ",footnotes:1:أورده الواحدي في أسباب النزول ص١٨٧.أخرجه ابن أبي حاتم ٤/١١٢٤.علَّقه ابن أبي حاتم ٤/١١٢٤.أخرجه ابن جرير ٧/٧٠٨، وابن أبي حاتم ٤/١١٢٤.تفسير مقاتل بن سليمان ١/٤٢٥.أخرجه ابن جرير ٧/٧٠٨.تفسير مقاتل بن سليمان ١/٤٢٥.أخرجه ابن أبي حاتم ٤/١١٢٤.تفسير مقاتل بن سليمان ١/٤٢٥.
4,173," <q>﴿فَأَمَّا ٱلَّذِینَ ءَامَنُوا۟ وَعَمِلُوا۟ ٱلصَّـٰلِحَـٰتِ فَیُوَفِّیهِمۡ أُجُورَهُمۡ وَیَزِیدُهُم مِّن فَضۡلِهِۦۖ﴾</q> - تفسير ٢١١٠٨- عن عبد الله بن مسعود، قال: قال رسول الله ﷺ في قوله: <q>﴿فيوفيهم أجورهم ويزيدهم من فضله﴾</q>، قال: «<q>﴿أجورهم﴾</q> يدخلهم الجنة، <q>﴿ويزيدهم من فضله﴾</q> الشفاعة في مَن وجبت لهم النار مِمَّن صنع إليهم المعروفَ في الدنيا»{1}. (٥/١٤٢) ٢١١٠٩- عن سليمان بن مِهران الأعمش -من طريق إسماعيل بن عبد الله الكندي- في قوله: <q>﴿يوفيهم أجورهم﴾</q> قال: أجورهم أن يدخلهم الجنة، <q>﴿ويزيدهم من فضله﴾</q> قال: الشفاعة لِمَن وجبت له النارُ مِمَّن صنع إليهم المعروف في الدنيا{2}. (ز) ٢١١١٠- قال مقاتل بن سليمان: وأخبر المؤمنين بمنزلتهم فى الآخرة ومنزلة المستنكفين، فقال: <q>﴿فأما الذين آمنوا وعملوا الصالحات فيوفيهم أجورهم﴾</q> يعني: فيوفي لهم جزاءهم، <q>﴿ويزيدهم﴾</q> على أعمالهم <q>﴿من فضله﴾</q> الجنة{3}١٩١٢. (ز) ١٩١٢ ذكر ابنُ عطية (٢/٧٥) احتمالين لهذه الزيادة: الأول: «أن تكون المخبر عنها في أنّ الحسنة بعشر إلى سبعمائة ضعف». والثاني: «أن يكون التضعيف الذي هو غير مُصَرَّدٍ محسوب، وهو المشار إليه في قوله تعالى: <q>﴿واللَّهُ يُضاعِفُ لِمَن يَشاءُ﴾</q> [البقرة:٢٦١]». <q>﴿وَأَمَّا ٱلَّذِینَ ٱسۡتَنكَفُوا۟ وَٱسۡتَكۡبَرُوا۟ فَیُعَذِّبُهُمۡ عَذَابًا أَلِیمࣰا﴾</q> - تفسير ٢١١١١- قال مقاتل بن سليمان: <q>﴿وأما الذين استنكفوا﴾</q> يعني: أنِفُوا، <q>﴿واستكبروا﴾</q> عن عبادة الله بالتوحيد؛ <q>﴿فيعذبهم عذابا أليما﴾</q>، يعني: وجيعًا{3}. (ز) <q>﴿وَلَا یَجِدُونَ لَهُم مِّن دُونِ ٱللَّهِ وَلِیࣰّا وَلَا نَصِیرࣰا ۝١٧٣﴾</q> - تفسير ٢١١١٢- عن عبد الله بن عباس -من طريق علي بن أبي طلحة- قوله: <q>﴿ولا يجدون لهم من دون الله وليا ولا نصيرا﴾</q>، قال: إلا أن يتوب قبل موته فيتوب الله عليه{5}. (ز) ٢١١١٣- قال مقاتل بن سليمان: <q>﴿ولا يجدون لهم من دون الله وليا﴾</q> يعني: قريبًا ينفعهم، <q>﴿ولا نصيرا﴾</q> يعني: مانِعًا يمنعهم مِن الله ﷿{3}. (ز) ",footnotes:1:أخرجه الطبراني في الكبير١٠/٢٠١ (١٠٤٦٢)، وأبو نعيم في الحلية ٤/١٠٨-١٠٩، ٧/١٢٨. قال الطبراني في الأوسط: «لم يرو هذا الحديثَ عن الأعمش إلا إسماعيلُ الكندي، تفرد به بقية». وقال أبو نعيم في الموضع الأول: «غريب من حديث الأعمش، عزيز عجيب من حديث الثوري، تفرد به إسماعيل بن عبيد الله الكندي عن الأعمش، وعن إسماعيل بقية بن الوليد، وحديث الثوري لم نكتبه إلا عن هذا الشيخ». وفي الموضع الآخر: «غريب من حديث الثوري، تفرد به ابن حمير، ورواه بقية، عن إسماعيل بن عبد الله الكندي، عن الأعمش، مثله». وقال ابن كثير في تفسيره ٢/٤٨٠-٤٨١: «هذا إسناد لا يثبت، وإذا روي عن ابن مسعود موقوفًا فهو جيد». وقال الذهبي في إثبات الشفاعة ص٥٠ (٥٥): «إسماعيل من شيوخ بقية الذين لا يعرفون». وقال الهيثمي في المجمع ٧/١٣ (١٠٩٦٠): «رواه الطبراني في الأوسط والكبير، وفيه إسماعيل بن عبد الله الكندي، ضعَّفه الذهبي من عند نفسه، فقال: أتى بخبر منكر، وبقية رجاله وثقوا». وقال السيوطي: «بسند ضعيف».أخرجه ابن أبي حاتم ٤/١١٢٤-١١٢٥.تفسير مقاتل بن سليمان ١/٤٢٥.تفسير مقاتل بن سليمان ١/٤٢٥.أخرجه ابن أبي حاتم ٤/١١٢٥.تفسير مقاتل بن سليمان ١/٤٢٥.
4,174," <q>﴿یَـٰۤأَیُّهَا ٱلنَّاسُ قَدۡ جَاۤءَكُم بُرۡهَـٰنࣱ مِّن رَّبِّكُمۡ﴾</q> - تفسير ٢١١١٤- عن عبد الله بن مسعود -من طريق أبي الأحوص- أنّه كان إذا تَحَرَّك من الليل قال: <q>﴿يا أيها الناس قد جاءكم برهان من ربكم وأنزلنا إليكم نورا مبينا﴾</q>{1}. (٥/١٤٢) ٢١١١٥- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿برهان من ربكم﴾</q>، قال: حُجَّةٌ{2}. (٥/١٤٣) ٢١١١٦- عن قتادة بن دِعامة -من طريق سعيد- في قوله: <q>﴿قد جاءكم برهان من ربكم﴾</q>، قال: بَيِّنةٌ{3}. (٥/١٤٣) ٢١١١٧- عن إسماعيل السُّدِّيِّ -من طريق أسباط- <q>﴿قد جاءكم برهان من ربكم﴾</q>، يقول: حُجَّة{4}. (ز) ٢١١١٨- عن عبد الملك ابن جُرَيْج -من طريق حجّاج- <q>﴿برهان﴾</q>، قال: بيِّنة{5}. (ز) ٢١١١٩- عن سفيان الثوري، عن أبيه، عن رجل لا يحفظ اسمه، في قوله: <q>﴿قد جاءكم برهان من ربكم﴾</q>، قال: محمد ﷺ{6}. (٥/١٤٢) ٢١١٢٠- قال سفيان -من طريق الفريابي- في قوله: <q>﴿قد جاءكم برهان من ربكم﴾</q>، قال: النبي ﷺ{7}. (ز) <q>﴿وَأَنزَلۡنَاۤ إِلَیۡكُمۡ نُورࣰا مُّبِینࣰا ۝١٧٤﴾</q> - تفسير ٢١١٢١- عن مجاهد بن جبر، في قوله: <q>﴿وأنزلنا إليكم نورا مبينا﴾</q>، قال: بيِّنًا. يعني: القرآن{8}. (ز) ٢١١٢٢- عن قتادة بن دِعامة -من طريق سعيد- في قوله: <q>﴿وأنزلنا إليكم نورا مبينا﴾</q>، قال: هذا القرآن{9}. (٥/١٤٣) ٢١١٢٣- عن قتادة بن دِعامة، في قوله: <q>﴿وأنزلنا إليكم نورا مبينا﴾</q>، قال: هذا هو القرآن، نبوة من الله، وهدًى، وضياء، وعِصْمَةٌ لِمَن اعتصم به{10}. (ز) ٢١١٢٤- قال مقاتل بن سليمان: <q>﴿وأنزلنا إليكم نورا مبينا﴾</q>، يعني: ضياء بيِّنًا مِن العمى، وهو القرآن{11}. (ز) ٢١١٢٥- عن عبد الملك ابن جُرَيْج -من طريق حجّاج- <q>﴿وأنزلنا إليكم نورا مبينا﴾</q>، قال: القرآن{5}. (ز) ٢١١٢٦- عن سفيان الثوري، عن أبيه، عن رجل لا يحفظ اسمه، في قوله: <q>﴿وأنزلنا إليكم نورا مبينا﴾</q>، قال: الكتاب{6}. (٥/١٤٢) ",footnotes:1:أخرجه ابن أبي شيبة ١٠/٢٢٤.أخرجه ابن جرير ٧/٧١١، وابن أبي حاتم ٤/١١٢٥. وذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ١/٤٢٦-. وعزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ٧/٧١١-٧١٢، وابن أبي حاتم ٤/١١٢٥. وعزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ٧/٧١٢. وعلَّقه ابن أبي حاتم ٤/١١٢٥.أخرجه ابن جرير ٧/٧١٢.عزاه السيوطي إلى ابن عساكر.أخرجه ابن أبي حاتم ٤/١١٢٥.ذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ١/٤٢٦.أخرجه ابن جرير ٧/٧١١-٧١٢. وعزاه السيوطي إلى ابن المنذر.ذكره عبد بن حميد كما في قطعة من تفسيره ص١٣٣.تفسير مقاتل بن سليمان ١/٤٢٥-٤٢٦.أخرجه ابن جرير ٧/٧١٢.عزاه السيوطي إلى ابن عساكر.
4,175," <q>﴿فَأَمَّا ٱلَّذِینَ ءَامَنُوا۟ بِٱللَّهِ وَٱعۡتَصَمُوا۟ بِهِۦ فَسَیُدۡخِلُهُمۡ فِی رَحۡمَةࣲ مِّنۡهُ وَفَضۡلࣲ وَیَهۡدِیهِمۡ إِلَیۡهِ صِرَ ٰ⁠طࣰا مُّسۡتَقِیمࣰا ۝١٧٥﴾</q> - تفسير ٢١١٢٧- قال مقاتل بن سليمان: <q>﴿فأما الذين آمنوا بالله﴾</q> يعني: صدَّقوا بالله ﷿ بأنّه واحد لا شريك له، <q>﴿واعتصموا به﴾</q> يعني: احترزوا به، يعني: بالله ﷿، <q>﴿فسيدخلهم في رحمة منه﴾</q> يعني: الجنة، <q>﴿وفضل﴾</q> يعني: الرزق في الجنة{1}. (ز) ٢١١٢٨- عن عبد الملك ابن جُرَيْج -من طريق حجّاج- في قوله: <q>﴿واعتصموا به﴾</q>، قال: بالقرآن{2}١٩١٣. (٥/١٤٣) ١٩١٣ لم يذكر ابنُ جرير (٧/٧١٢) في معنى: <q>﴿واعْتَصَمُوا بِهِ﴾</q> سوى قول ابن جريج. ",footnotes:1:تفسير مقاتل بن سليمان ١/٤٢٦.أخرجه ابن جرير ٧/٧١٢. وعزاه السيوطي إلى ابن المنذر.
