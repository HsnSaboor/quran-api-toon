quran[5]{c,v,t}:
  4,171,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿یَـٰۤأَهۡلَ ٱلۡكِتَـٰبِ لَا تَغۡلُوا۟ فِی دِینِكُمۡ وَلَا تَقُولُوا۟ عَلَى ٱللَّهِ إِلَّا ٱلۡحَقَّۚ إِنَّمَا ٱلۡمَسِیحُ عِیسَى ٱبۡنُ مَرۡیَمَ رَسُولُ ٱللَّهِ وَكَلِمَتُهُۥۤ أَلۡقَىٰهَاۤ إِلَىٰ مَرۡیَمَ وَرُوحࣱ مِّنۡهُۖ فَـَٔامِنُوا۟ بِٱللَّهِ وَرُسُلِهِۦۖ وَلَا تَقُولُوا۟ ثَلَـٰثَةٌۚ ٱنتَهُوا۟ خَیۡرࣰا لَّكُمۡۚ إِنَّمَا ٱللَّهُ إِلَـٰهࣱ وَ ٰ⁠حِدࣱۖ سُبۡحَـٰنَهُۥۤ أَن یَكُونَ لَهُۥ وَلَدࣱۘ لَّهُۥ مَا فِی ٱلسَّمَـٰوَ ٰ⁠تِ وَمَا فِی ٱلۡأَرۡضِۗ وَكَفَىٰ بِٱللَّهِ وَكِیلࣰا ۝١٧١﴾</span> - نزول الآية</h3></p><p><div></p><p><p><span class="item-no">٢١٠٨١<span class="dash">-</span></span> قال <span class="name-2">الحسن البصري</span>: يجوز أن تكون نزلت في اليهود والنصارى، فإنّهم جميعًا غَلَوْا في أمر عيسى، فاليهود بالتقصير، والنصارى بمجاوزة الحد{1}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿یَـٰۤأَهۡلَ ٱلۡكِتَـٰبِ لَا تَغۡلُوا۟ فِی دِینِكُمۡ وَلَا تَقُولُوا۟ عَلَى ٱللَّهِ إِلَّا ٱلۡحَقَّۚ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٢١٠٨٢<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق خُلَيْدٍ بنِ دَعْلَجٍ- في قوله: <span class="qpc-hafs">﴿لا تغلوا في دينكم﴾</span>، قال: لا تعتدوا{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢١٠٨٣<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق خُلَيْدٍ بنِ دَعْلَجٍ- في قوله: <span class="qpc-hafs">﴿لا تغلوا﴾</span>، قال: لا تبتدعوا{3}. (٥/١٤٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢١٠٨٤<span class="dash">-</span></span> عن <span class="name-2">الربيع بن أنس</span> -من طريق أبي جعفر- قال: صاروا فريقين: فريق غلوا في الدين، فكان غلوهم فيه الشكَّ فيه والرغبةَ عنه، وفريق منهم قَصَّروا عنه، ففسقوا عن أمر ربهم{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢١٠٨٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ياأهل الكتاب﴾</span> يعني: النصارى، <span class="qpc-hafs">﴿لا تغلوا في دينكم﴾</span> يعني: الإسلام، فالغلو فى الدِّين أن تقولوا على الله غيرَ الحق فى أمر عيسى ابن مريم ﷺ، <span class="qpc-hafs">﴿ولا تقولوا على الله إلا الحق إنما المسيح عيسى ابن مريم رسول الله﴾</span> وليس لله تبارك وتعالى ولدًا{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢١٠٨٦<span class="dash">-</span></span> قال أصبغ بن الفرج: سمعت <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> يقول في قوله: <span class="qpc-hafs">﴿لا تغلوا في دينكم﴾</span> قال: الغُلُوُّ فِراقُ الحق، وكان مِمّا غَلَوْا فيه أن دَعَوا لله صاحبة وولدًا{2}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿إِنَّمَا ٱلۡمَسِیحُ عِیسَى ٱبۡنُ مَرۡیَمَ رَسُولُ ٱللَّهِ وَكَلِمَتُهُۥۤ أَلۡقَىٰهَاۤ إِلَىٰ مَرۡیَمَ وَرُوحࣱ مِّنۡهُۖ فَـَٔامِنُوا۟ بِٱللَّهِ وَرُسُلِهِۦۖ وَلَا تَقُولُوا۟ ثَلَـٰثَةٌۚ ٱنتَهُوا۟ خَیۡرࣰا لَّكُمۡۚ إِنَّمَا ٱللَّهُ إِلَـٰهࣱ وَ ٰ⁠حِدࣱۖ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٢١٠٨٧<span class="dash">-</span></span> عن <span class="name-1">أُبَيِّ بن كعب</span> -من طريق أبي العالية- في قوله: <span class="qpc-hafs">﴿وإذ أخذ ربك من بني آدم من ظهورهم ذريتهم﴾</span> [الأعراف:١٧٢]، قال: أخذهم فجعلهم أرواحًا، ثُمَّ صوَّرهم، ثم استنطقهم، فكان روح عيسى مِن تلك الأرواح التي أُخِذ عليها العهد والميثاق، فأرسل ذلك الروح إلى مريم، فدخل في فيها، فحملت الذي خاطبها، وهو روح عيسى ﵇{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢١٠٨٨<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ليث- <span class="qpc-hafs">﴿وكلمته ألقاها إلى مريم وروح منه﴾</span>، قال: رسول منه{8}<span class=comment-ref>١٩٠٩</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>١٩٠٩</span> <span class="comment-type-4">عَلَّق</span> <u>ابنُ تيمية</u> (٢/٣٧٨) قائلًا: «يريد مجاهد قولَه: <span class="qpc-hafs">﴿فَأَرْسَلْنا إلَيْها رُوحَنا فَتَمَثَّلَ لَها بَشَرًا سَوِيًّا * قالَتْ إنِّي أعُوذُ بِالرَّحْمَنِ مِنكَ إنْ كُنْتَ تَقِيًّا * قالَ إنَّما أنا رَسُولُ رَبِّكِ﴾</span> [مريم:١٧-١٩]».</div></p><p><div></p><p><p><span class="item-no">٢١٠٨٩<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دِعامة</span> -من طريق مَعْمَر- في قوله: <span class="qpc-hafs">﴿وكلمته ألقاها إلى مريم﴾</span>، قال: كلمته أن قال: كن. فكان{9}. (٥/١٤٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢١٠٩٠<span class="dash">-</span></span> قال <span class="name-2">إسماعيل السُّدِّيِّ</span>: <span class="qpc-hafs">﴿وروح منه﴾</span>، أي: مخلوقًا مِن عنده{10}<span class=comment-ref>١٩١٠</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>١٩١٠</span> <span class="comment-type-3">رجَّح</span> <u>ابنُ كثير</u> (٤/٣٨٩) <span class="mustanad">مستندًا إلى النظائر</span> أنّ معنى: <span class="qpc-hafs">﴿ورُوحٌ مِنهُ﴾</span>: «أنّه مخلوق مِن روح مخلوقة، وأضيفت الروح إلى الله على وجْه التشريف، كما أضيفت الناقة والبيت إلى الله في قوله: <span class="qpc-hafs">﴿هَذِهِ ناقَةُ اللَّهِ﴾</span> [هود:٦٤]، وفي قوله: <span class="qpc-hafs">﴿وطَهِّرْ بَيْتِيَ لِلطّائِفِينَ﴾</span> [الحج:٢٦]، وكما ورد في الحديث الصحيح: «فأدخل على ربي في داره»، أضافها إليه إضافة تشريف لها، وهذا كله من قبيلٍ واحد، ونمط واحد».</div></p><p><div></p><p><p><span class="item-no">٢١٠٩١<span class="dash">-</span></span> عن أحمد بن سنان الواسطي، قال: سمعت <span class="name-3">شاذ بن يحيى</span> يقول في قوله تعالى: <span class="qpc-hafs">﴿وكلمته ألقاها إلى مريم وروح منه﴾</span>، قال: ليس الكلمة صارت عيسى، ولكن بالكلمة صار عيسى{8}<span class=comment-ref>١٩١١</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>١٩١١</span> <span class="comment-type-4">عَلَّق</span> <u>ابنُ كثير</u> (٤/٣٨٨) على أثر شاذ بن يحيى، فقال: «وهذا أحسن مما ادَّعاه ابن جرير في قوله: <span class="qpc-hafs">﴿ألْقاها إلى مَرْيَمَ﴾</span> أي: أعلمها بها. كما زعمه في قوله: <span class="qpc-hafs">﴿إذْ قالَتِ المَلائِكَةُ يا مَرْيَمُ إنَّ اللَّهَ يُبَشِّرُكِ بِكَلِمَةٍ مِنهُ﴾</span> [آل عمران:٤٥]، أي: يعلمك بكلمة منه، ويجعل ذلك كقوله تعالى: <span class="qpc-hafs">﴿وما كُنْتَ تَرْجُو أنْ يُلْقى إلَيْكَ الكِتابُ إلا رَحْمَةً مِن رَبِّكَ﴾</span> [القصص:٨٦]».</p><p>و<span class="comment-type-3">رَجَّح</span>، فقال: «بل الصحيح أنّها الكلمةُ التي جاء بها جبريل إلى مريم، فنفخ فيها بإذن الله، فكان عيسى ﵇». ولم يذكر مستندًا.</div></p><p><div></p><p><p><span class="item-no">٢١٠٩٢<span class="dash">-</span></span> عن شاذ بن يحيى، قال: قلتُ ل<span class="name-3">يزيد بن هارون</span>: أي شيء أحلها؟ قال: روح الله بين عباده، قال: تحاب الناس. ثم قرأ يزيد: <span class="qpc-hafs">﴿وكلمته ألقاها إلى مريم وروح منه﴾</span>، قال: محبة{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢١٠٩٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وكلمته﴾</span> يعنى بالكلمة قال: كن. فكان، <span class="qpc-hafs">﴿ألقاها إلى مريم وروح منه﴾</span> يعني: بالروح أنّه كان من غير بشر. نزلت فى نصارى نجران في السيد والعاقب ومن معهما. ثم قال سبحانه: <span class="qpc-hafs">﴿فآمنوا﴾</span> يعني: صَدِّقوا <span class="qpc-hafs">﴿بالله﴾</span> ﷿ بأنّه واحد لا شريك له، <span class="qpc-hafs">﴿ورسله﴾</span> يعني: محمدًا ﷺ بأنّه نبي ورسول، <span class="qpc-hafs">﴿ولا تقولوا ثلاثة﴾</span> يعني: لا تقولوا: إنّ الله ﷿ ثالث ثلاثة، <span class="qpc-hafs">﴿انتهوا خيرا لكم إنما الله إله واحد﴾</span>{5}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿إِنَّمَا ٱلۡمَسِیحُ عِیسَى ٱبۡنُ مَرۡیَمَ رَسُولُ ٱللَّهِ وَكَلِمَتُهُۥۤ أَلۡقَىٰهَاۤ إِلَىٰ مَرۡیَمَ وَرُوحࣱ مِّنۡهُۖ فَـَٔامِنُوا۟ بِٱللَّهِ وَرُسُلِهِۦۖ وَلَا تَقُولُوا۟ ثَلَـٰثَةٌۚ ٱنتَهُوا۟ خَیۡرࣰا لَّكُمۡۚ إِنَّمَا ٱللَّهُ إِلَـٰهࣱ وَ ٰ⁠حِدࣱۖ﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٢١٠٩٤<span class="dash">-</span></span> عن عمر بن الخطاب، قال: قال رسول الله ﷺ: «<b>لا تُطْروني كما أطْرَتِ النصارى عيسى بن مريم، فإنما أنا عبد، فقولوا: عبد الله ورسوله</b>»{14}. (٥/١٤١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢١٠٩٥<span class="dash">-</span></span> عن عبد الله بن مسعود، قال: بعثنا رسول الله ﷺ إلى النجاشي، ونحن ثمانون رجلًا، ومعنا جعفر بن أبي طالب، وبعثت قريشُ عمارة وعمرو بن العاص، ومعهما هديةٌ إلى النجاشي، فلمّا دخلا عليه سجدا له، وبَعَثا إليه بالهدية، وقالا: إنّ ناسا من قومنا رَغِبوا عن ديننا، وقد نزلوا أرضك. قال: أين هم؟ قالا: هم في أرضك. فبعث إليهم، حتى دخلوا عليه، فلم يسجدوا له، فقالوا: ما لكم لم تسجدوا للملك؟ فقال جعفر: إنّ الله بعث إلينا نبيه، فأمرنا ألا نسجد إلا لله. فقال عمرو بن العاص: إنّهم يخالفونك في عيسى وأُمِّه. قال: فما يقولون في عيسى وأمه؟ قالوا: نقول كما قال الله، هو روح الله، وكلمته ألقاها إلى العذراء البتول التي لم يمسسها بشر. فتناول النجاشيُّ عودًا، فقال: يا معشر القسيسين والرهبان، ما تزيدون على ما يقول هؤلاء ما يَزِنُ هذه، مرحبًا بكم وبمن جئتم من عنده، فأنا أشهد أنّه نبي، ولوددت أنِّي عنده فأحْمِل نعليه، فانزلوا حيث شئتم مِن أرضي{15}. (٥/١٤٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢١٠٩٦<span class="dash">-</span></span> عن أبي موسى الأشعري: أنّ النجاشي قال لجعفر: ما يقول صاحبُك في ابن مريم؟ قال: يقول فيه قول الله: روحُ الله، وكلمته، أخرجه من البتول العذراء، لم يقربها بشر. فتناول عودًا من الأرض، فرفعه، فقال: يا معشر القِسِّيسين والرهبان، ما يزيد هؤلاء على ما تقولون في ابن مريم ما يَزِنُ هذه{16}. (٥/١٤٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢١٠٩٧<span class="dash">-</span></span> عن عبادة بن الصامت، عن النبي ﷺ، قال: «<b>مَن شهد أن لا إله إلا الله وحده لا شريك له، وأنّ محمدًا عبده ورسوله، وأنّ عيسى عبد الله ورسوله، وكلمته ألقاها إلى مريم، وروح منه، والجنة حقٌّ، والنار حقٌّ؛ أدخله الله مِن أبواب الجنة الثمانية مِن أيِّها شاء على ما كان من العمل</b>»{17}. (٥/١٤١)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿سُبۡحَـٰنَهُۥۤ أَن یَكُونَ لَهُۥ وَلَدࣱۘ لَّهُۥ مَا فِی ٱلسَّمَـٰوَ ٰ⁠تِ وَمَا فِی ٱلۡأَرۡضِۗ وَكَفَىٰ بِٱللَّهِ وَكِیلࣰا ۝١٧١﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٢١٠٩٨<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿سبحانه أن يكون له ولد﴾</span> يعني: عيسى ﷺ، <span class="qpc-hafs">﴿له ما في السماوات وما في الأرض﴾</span> مِن الخلق عبيده، وفى ملكه عيسى وغيره، <span class="qpc-hafs">﴿وكفى بالله وكيلا﴾</span> يعني: شهيدًا بذلك{5}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير البغوي ٢/٣١٤.أخرجه ابن أبي حاتم ٤/١١٢٢.أخرجه ابن أبي حاتم ٤/١١٢٢. وعزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ٧/٧٠١.تفسير مقاتل بن سليمان ١/٤٢٤-٤٢٥.أخرجه ابن أبي حاتم ٤/١١٢٢.أخرجه ابن جرير ٧/٧٠٥.أخرجه ابن أبي حاتم ٤/١١٢٣.أخرجه عبد الرزاق ١/١٧٧، وابن جرير ٥/٤٠٧، ٧/٧٠٣. وعزاه السيوطي إلى ابن المنذر.تفسير الثعلبي ٣/٤١٩.أخرجه ابن أبي حاتم ٤/١١٢٣.أخرجه ابن أبي حاتم ٤/١١٢٣.تفسير مقاتل بن سليمان ١/٤٢٤-٤٢٥.أخرجه البخاري ٤/١٦٧ (٣٤٤٥).أخرجه أحمد ٧/٤٠٨-٤٠٩ (٤٤٠٠)، والطيالسي١/٢٧٠-٢٧١ (٣٤٤) بلفظ مقارب.</p><p>قال ابن كثير في البداية والنهاية ٤/١٧٤: «هذا إسناد جيد قوي، وسياق حسن». وقال الهيثمي في المجمع ٦/٢٤ (٩٨٤١): «رواه الطبراني، وفيه حديج بن معاوية، وثقه أبو حاتم، وقال: في بعض حديثه ضعف. وضعفه ابن معين وغيره، وبقية رجاله ثقات». وقال ابن حجر في الفتح ٧/١٨٩: «بإسناد حسن».أخرجه الحاكم ٢/٣٣٨ (٣٢٠٨) مطولًا.</p><p>قال الحاكم: «هذا حديث صحيح، على شرط الشيخين، ولم يخرجاه». وقال البيهقي في دلائل النبوة ٢/٣٠٠: «هذا إسناد صحيح». وقال البوصيري في إتحاف الخيرة ٥/٧٧-٧٨ (٤٢٦١): «هذا إسناد رواته ثقات».أخرجه البخاري ٤/١٦٥ (٣٤٣٥)، ومسلم ١/٥٧ (٢٨).تفسير مقاتل بن سليمان ١/٤٢٤-٤٢٥.
  4,172,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿لَّن یَسۡتَنكِفَ ٱلۡمَسِیحُ أَن یَكُونَ عَبۡدࣰا لِّلَّهِ وَلَا ٱلۡمَلَـٰۤىِٕكَةُ ٱلۡمُقَرَّبُونَۚ وَمَن یَسۡتَنكِفۡ عَنۡ عِبَادَتِهِۦ وَیَسۡتَكۡبِرۡ فَسَیَحۡشُرُهُمۡ إِلَیۡهِ جَمِیعࣰا ۝١٧٢﴾</span> - نزول الآية</h3></p><p><div></p><p><p><span class="item-no">٢١٠٩٩<span class="dash">-</span></span> قال <span class="name-3">محمد بن السائب الكلبي</span>: إنّ وفد نجران قالوا: يا محمدُ، تَعِيبُ صاحبَنا؟ قال: «<b>ومَن صاحبكم؟</b>». قالوا: عيسى. قال: «<b>وأي شئ أقول فيه؟</b>». قالوا: تقول: إنّه عبد الله ورسوله. فقال لهم: «<b>إنّه ليس بعارٍ لعيسى أن يكون عبدًا لله</b>». قالوا: بلى. فنزلت: <span class="qpc-hafs">﴿لن يستنكف المسيح أن يكون عبدًا لله﴾</span> الآية{1}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿لَّن یَسۡتَنكِفَ ٱلۡمَسِیحُ أَن یَكُونَ عَبۡدࣰا لِّلَّهِ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٢١١٠٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطاء- في قوله: <span class="qpc-hafs">﴿لن يستنكف﴾</span>، قال: لن يستكبر{2}. (٥/١٤١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢١١٠١<span class="dash">-</span></span> وعن <span class="name-2">عطاء الخراساني</span>، نحو ذلك{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢١١٠٢<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دِعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿لن يستنكف المسيح أن يكون عبدا لله ولا الملائكة المقربون﴾</span>، قال: لن يحتشم المسيح أن يكون عبدًا لله، ولا الملائكة المقربين{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢١١٠٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثُمَّ قال ﷿: <span class="qpc-hafs">﴿لن يستنكف المسيح﴾</span> يعني: لن يَأْنَفَ <span class="qpc-hafs">﴿أن يكون عبدًا لله﴾</span>{5}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَلَا ٱلۡمَلَـٰۤىِٕكَةُ ٱلۡمُقَرَّبُونَۚ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٢١١٠٤<span class="dash">-</span></span> عن الأجلح، قال: قلتُ ل<span class="name-2">لضحاك بن مُزاحِم</span>: ما المُقَرَّبون؟ قال: أقربهم إلى السماء الثانية{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢١١٠٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ولا﴾</span> يستنكف <span class="qpc-hafs">﴿الملائكة المقربون﴾</span> أن يكونوا عبيدًا لله؛ ليعتبروا بكون الملائكة أقربَ إلى الله ﷿ منزلةً مِن عيسى ابن مريم وغيره، فإنّ عيسى عبدٌ مِن عباده{5}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَمَن یَسۡتَنكِفۡ عَنۡ عِبَادَتِهِۦ وَیَسۡتَكۡبِرۡ فَسَیَحۡشُرُهُمۡ إِلَیۡهِ جَمِیعࣰا ۝١٧٢﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٢١١٠٦<span class="dash">-</span></span> عن <span class="name-2">الضحاك بن مُزاحِم</span> -من طريق أبي سنان- في قوله: <span class="qpc-hafs">﴿جميعا﴾</span>، قال: البَرُّ، والفاجِر{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢١١٠٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثُمَّ أوعد النصارى، فقال: <span class="qpc-hafs">﴿ومن يستنكف﴾</span> يعني: ومن يأْنَف <span class="qpc-hafs">﴿عن عبادته ويستكبر﴾</span> يعني: مَن يأنف عن عبادة الله، يعني: التوحيد، <span class="qpc-hafs">﴿ويستكبر﴾</span> يعني: ويتكبر عن العبادة؛ <span class="qpc-hafs">﴿فسيحشرهم إليه جميعا﴾</span>، فلم يستنكف ويستكبر غير إبليس{5}. (ز)</p></p><p></div></p></div>",footnotes:1:أورده الواحدي في أسباب النزول ص١٨٧.أخرجه ابن أبي حاتم ٤/١١٢٤.علَّقه ابن أبي حاتم ٤/١١٢٤.أخرجه ابن جرير ٧/٧٠٨، وابن أبي حاتم ٤/١١٢٤.تفسير مقاتل بن سليمان ١/٤٢٥.أخرجه ابن جرير ٧/٧٠٨.تفسير مقاتل بن سليمان ١/٤٢٥.أخرجه ابن أبي حاتم ٤/١١٢٤.تفسير مقاتل بن سليمان ١/٤٢٥.
  4,173,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿فَأَمَّا ٱلَّذِینَ ءَامَنُوا۟ وَعَمِلُوا۟ ٱلصَّـٰلِحَـٰتِ فَیُوَفِّیهِمۡ أُجُورَهُمۡ وَیَزِیدُهُم مِّن فَضۡلِهِۦۖ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٢١١٠٨<span class="dash">-</span></span> عن عبد الله بن مسعود، قال: قال رسول الله ﷺ في قوله: <span class="qpc-hafs">﴿فيوفيهم أجورهم ويزيدهم من فضله﴾</span>، قال: «<b><span class="qpc-hafs">﴿أجورهم﴾</span> يدخلهم الجنة، <span class="qpc-hafs">﴿ويزيدهم من فضله﴾</span> الشفاعة في مَن وجبت لهم النار مِمَّن صنع إليهم المعروفَ في الدنيا</b>»{1}. (٥/١٤٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢١١٠٩<span class="dash">-</span></span> عن <span class="name-2">سليمان بن مِهران الأعمش</span> -من طريق إسماعيل بن عبد الله الكندي- في قوله: <span class="qpc-hafs">﴿يوفيهم أجورهم﴾</span> قال: أجورهم أن يدخلهم الجنة، <span class="qpc-hafs">﴿ويزيدهم من فضله﴾</span> قال: الشفاعة لِمَن وجبت له النارُ مِمَّن صنع إليهم المعروف في الدنيا{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢١١١٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: وأخبر المؤمنين بمنزلتهم فى الآخرة ومنزلة المستنكفين، فقال: <span class="qpc-hafs">﴿فأما الذين آمنوا وعملوا الصالحات فيوفيهم أجورهم﴾</span> يعني: فيوفي لهم جزاءهم، <span class="qpc-hafs">﴿ويزيدهم﴾</span> على أعمالهم <span class="qpc-hafs">﴿من فضله﴾</span> الجنة{3}<span class=comment-ref>١٩١٢</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>١٩١٢</span> <span class="comment-type-4">ذكر</span> <u>ابنُ عطية</u> (٢/٧٥) احتمالين لهذه الزيادة: <b>الأول:</b> «أن تكون المخبر عنها في أنّ الحسنة بعشر إلى سبعمائة ضعف». <b>والثاني:</b> «أن يكون التضعيف الذي هو غير مُصَرَّدٍ محسوب، وهو المشار إليه <span class="mustanad">في قوله تعالى</span>: <span class="qpc-hafs">﴿واللَّهُ يُضاعِفُ لِمَن يَشاءُ﴾</span> [البقرة:٢٦١]».</div></p><p><h3><span class="qpc-hafs">﴿وَأَمَّا ٱلَّذِینَ ٱسۡتَنكَفُوا۟ وَٱسۡتَكۡبَرُوا۟ فَیُعَذِّبُهُمۡ عَذَابًا أَلِیمࣰا﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٢١١١١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وأما الذين استنكفوا﴾</span> يعني: أنِفُوا، <span class="qpc-hafs">﴿واستكبروا﴾</span> عن عبادة الله بالتوحيد؛ <span class="qpc-hafs">﴿فيعذبهم عذابا أليما﴾</span>، يعني: وجيعًا{3}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَلَا یَجِدُونَ لَهُم مِّن دُونِ ٱللَّهِ وَلِیࣰّا وَلَا نَصِیرࣰا ۝١٧٣﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٢١١١٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي بن أبي طلحة- قوله: <span class="qpc-hafs">﴿ولا يجدون لهم من دون الله وليا ولا نصيرا﴾</span>، قال: إلا أن يتوب قبل موته فيتوب الله عليه{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢١١١٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ولا يجدون لهم من دون الله وليا﴾</span> يعني: قريبًا ينفعهم، <span class="qpc-hafs">﴿ولا نصيرا﴾</span> يعني: مانِعًا يمنعهم مِن الله ﷿{3}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه الطبراني في الكبير١٠/٢٠١ (١٠٤٦٢)، وأبو نعيم في الحلية ٤/١٠٨-١٠٩، ٧/١٢٨.</p><p>قال الطبراني في الأوسط: «لم يرو هذا الحديثَ عن الأعمش إلا إسماعيلُ الكندي، تفرد به بقية». وقال أبو نعيم في الموضع الأول: «غريب من حديث الأعمش، عزيز عجيب من حديث الثوري، تفرد به إسماعيل بن عبيد الله الكندي عن الأعمش، وعن إسماعيل بقية بن الوليد، وحديث الثوري لم نكتبه إلا عن هذا الشيخ». وفي الموضع الآخر: «غريب من حديث الثوري، تفرد به ابن حمير، ورواه بقية، عن إسماعيل بن عبد الله الكندي، عن الأعمش، مثله». وقال ابن كثير في تفسيره ٢/٤٨٠-٤٨١: «هذا إسناد لا يثبت، وإذا روي عن ابن مسعود موقوفًا فهو جيد». وقال الذهبي في إثبات الشفاعة ص٥٠ (٥٥): «إسماعيل من شيوخ بقية الذين لا يعرفون». وقال الهيثمي في المجمع ٧/١٣ (١٠٩٦٠): «رواه الطبراني في الأوسط والكبير، وفيه إسماعيل بن عبد الله الكندي، ضعَّفه الذهبي من عند نفسه، فقال: أتى بخبر منكر، وبقية رجاله وثقوا». وقال السيوطي: «بسند ضعيف».أخرجه ابن أبي حاتم ٤/١١٢٤-١١٢٥.تفسير مقاتل بن سليمان ١/٤٢٥.تفسير مقاتل بن سليمان ١/٤٢٥.أخرجه ابن أبي حاتم ٤/١١٢٥.تفسير مقاتل بن سليمان ١/٤٢٥.
  4,174,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿یَـٰۤأَیُّهَا ٱلنَّاسُ قَدۡ جَاۤءَكُم بُرۡهَـٰنࣱ مِّن رَّبِّكُمۡ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٢١١١٤<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن مسعود</span> -من طريق أبي الأحوص- أنّه كان إذا تَحَرَّك من الليل قال: <span class="qpc-hafs">﴿يا أيها الناس قد جاءكم برهان من ربكم وأنزلنا إليكم نورا مبينا﴾</span>{1}. (٥/١٤٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢١١١٥<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿برهان من ربكم﴾</span>، قال: حُجَّةٌ{2}. (٥/١٤٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢١١١٦<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دِعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿قد جاءكم برهان من ربكم﴾</span>، قال: بَيِّنةٌ{3}. (٥/١٤٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢١١١٧<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيِّ</span> -من طريق أسباط- <span class="qpc-hafs">﴿قد جاءكم برهان من ربكم﴾</span>، يقول: حُجَّة{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢١١١٨<span class="dash">-</span></span> عن <span class="name-3">عبد الملك ابن جُرَيْج</span> -من طريق حجّاج- <span class="qpc-hafs">﴿برهان﴾</span>، قال: بيِّنة{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢١١١٩<span class="dash">-</span></span> عن سفيان الثوري، عن أبيه، عن رجل لا يحفظ اسمه، في قوله: <span class="qpc-hafs">﴿قد جاءكم برهان من ربكم﴾</span>، قال: محمد ﷺ{6}. (٥/١٤٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢١١٢٠<span class="dash">-</span></span> قال <span class="name-3">سفيان</span> -من طريق الفريابي- في قوله: <span class="qpc-hafs">﴿قد جاءكم برهان من ربكم﴾</span>، قال: النبي ﷺ{7}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَأَنزَلۡنَاۤ إِلَیۡكُمۡ نُورࣰا مُّبِینࣰا ۝١٧٤﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٢١١٢١<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span>، في قوله: <span class="qpc-hafs">﴿وأنزلنا إليكم نورا مبينا﴾</span>، قال: بيِّنًا. يعني: القرآن{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢١١٢٢<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دِعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿وأنزلنا إليكم نورا مبينا﴾</span>، قال: هذا القرآن{9}. (٥/١٤٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢١١٢٣<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دِعامة</span>، في قوله: <span class="qpc-hafs">﴿وأنزلنا إليكم نورا مبينا﴾</span>، قال: هذا هو القرآن، نبوة من الله، وهدًى، وضياء، وعِصْمَةٌ لِمَن اعتصم به{10}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢١١٢٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وأنزلنا إليكم نورا مبينا﴾</span>، يعني: ضياء بيِّنًا مِن العمى، وهو القرآن{11}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢١١٢٥<span class="dash">-</span></span> عن <span class="name-3">عبد الملك ابن جُرَيْج</span> -من طريق حجّاج- <span class="qpc-hafs">﴿وأنزلنا إليكم نورا مبينا﴾</span>، قال: القرآن{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢١١٢٦<span class="dash">-</span></span> عن سفيان الثوري، عن أبيه، عن رجل لا يحفظ اسمه، في قوله: <span class="qpc-hafs">﴿وأنزلنا إليكم نورا مبينا﴾</span>، قال: الكتاب{6}. (٥/١٤٢)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن أبي شيبة ١٠/٢٢٤.أخرجه ابن جرير ٧/٧١١، وابن أبي حاتم ٤/١١٢٥. وذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ١/٤٢٦-. وعزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ٧/٧١١-٧١٢، وابن أبي حاتم ٤/١١٢٥. وعزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ٧/٧١٢. وعلَّقه ابن أبي حاتم ٤/١١٢٥.أخرجه ابن جرير ٧/٧١٢.عزاه السيوطي إلى ابن عساكر.أخرجه ابن أبي حاتم ٤/١١٢٥.ذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ١/٤٢٦.أخرجه ابن جرير ٧/٧١١-٧١٢. وعزاه السيوطي إلى ابن المنذر.ذكره عبد بن حميد كما في قطعة من تفسيره ص١٣٣.تفسير مقاتل بن سليمان ١/٤٢٥-٤٢٦.أخرجه ابن جرير ٧/٧١٢.عزاه السيوطي إلى ابن عساكر.
  4,175,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿فَأَمَّا ٱلَّذِینَ ءَامَنُوا۟ بِٱللَّهِ وَٱعۡتَصَمُوا۟ بِهِۦ فَسَیُدۡخِلُهُمۡ فِی رَحۡمَةࣲ مِّنۡهُ وَفَضۡلࣲ وَیَهۡدِیهِمۡ إِلَیۡهِ صِرَ ٰ⁠طࣰا مُّسۡتَقِیمࣰا ۝١٧٥﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٢١١٢٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فأما الذين آمنوا بالله﴾</span> يعني: صدَّقوا بالله ﷿ بأنّه واحد لا شريك له، <span class="qpc-hafs">﴿واعتصموا به﴾</span> يعني: احترزوا به، يعني: بالله ﷿، <span class="qpc-hafs">﴿فسيدخلهم في رحمة منه﴾</span> يعني: الجنة، <span class="qpc-hafs">﴿وفضل﴾</span> يعني: الرزق في الجنة{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢١١٢٨<span class="dash">-</span></span> عن <span class="name-3">عبد الملك ابن جُرَيْج</span> -من طريق حجّاج- في قوله: <span class="qpc-hafs">﴿واعتصموا به﴾</span>، قال: بالقرآن{2}<span class=comment-ref>١٩١٣</span>. (٥/١٤٣)</p></p><p></div></p><p><div><span class=comment-ref>١٩١٣</span> لم يذكر <u>ابنُ جرير</u> (٧/٧١٢) في معنى: <span class="qpc-hafs">﴿واعْتَصَمُوا بِهِ﴾</span> سوى قول ابن جريج.</div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ١/٤٢٦.أخرجه ابن جرير ٧/٧١٢. وعزاه السيوطي إلى ابن المنذر.