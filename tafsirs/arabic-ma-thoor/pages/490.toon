quran[12]{c,v,t}:
  43,11,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَٱلَّذِی نَزَّلَ مِنَ ٱلسَّمَاۤءِ مَاۤءَۢ بِقَدَرࣲ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٩٣٠٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿والَّذِي نَزَّلَ مِنَ السَّماءِ ماءً بِقَدَرٍ﴾</span> وهو المطر{1}<span class=comment-ref>٥٨٤٣</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٥٨٤٣</span> <span class="comment-type-4">ذكر</span> <u>ابن عطية</u> (٧/٥٣٥) أن المراد بالماء: المطر <span class="mustanad">بإجماع</span>.</div></p><p><h3><span class="qpc-hafs">﴿وَٱلَّذِی نَزَّلَ مِنَ ٱلسَّمَاۤءِ مَاۤءَۢ بِقَدَرࣲ﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٦٩٣٠٥<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق الحسن بن مسلم- قال: ما عامٌ بأكثر مطرًا مِن عام -أو قال: ماء-، ولكنَّ الله يصرّفه حيث يشاء{2}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿فَأَنشَرۡنَا بِهِۦ بَلۡدَةࣰ مَّیۡتࣰاۚ كَذَ ٰ⁠لِكَ تُخۡرَجُونَ ۝١١﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٩٣٠٦<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿والَّذِي نَزَّلَ مِنَ السَّماءِ ماءً بِقَدَرٍ﴾</span>: كما أحيا الله هذه الأرض الميتة بهذا الماء، فكذلك تُبعَثون يوم القيامة{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٩٣٠٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فَأَنْشَرْنا بِهِ بَلْدَةً مَيْتًا﴾</span> يقول: فأحيينا به، يعني: بالماء <span class="qpc-hafs">﴿بَلْدَةً مَيْتًا﴾</span> لا نبْت فيها، فلمّا أصابها الماء أنبتَتْ، <span class="qpc-hafs">﴿كَذَلِكَ﴾</span> يقول: هكذا <span class="qpc-hafs">﴿تُخْرَجُونَ﴾</span> من الأرض بالماء كما يخرج النّبْت{1}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٣/٧٩٠.|2:أخرجه يحيى بن سلام -كما في تفسير ابن أبي زمنين ٤/١٧٦-١٧٧-، وأخرجه ابن جرير ١٧/٤٦٨، وابن أبي حاتم ٨/٢٧٠٦، والحاكم ٢/٤٠٣، والبيهقي في سننه ٣/٣٦٣ بنحوه من طريق سعيد بن جُبير، عند تفسير قوله تعالى: <span class="qpc-hafs">﴿ولَقَدْ صَرَّفْناهُ بَيْنَهُمْ لِيَذَّكَّرُوا﴾</span> [الفرقان:٥٠].|3:أخرجه ابن جرير ٢٠/٥٥٥.|4:تفسير مقاتل بن سليمان ٣/٧٩٠.
  43,12,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَٱلَّذِی خَلَقَ ٱلۡأَزۡوَ ٰ⁠جَ كُلَّهَا وَجَعَلَ لَكُم مِّنَ ٱلۡفُلۡكِ وَٱلۡأَنۡعَـٰمِ مَا تَرۡكَبُونَ ۝١٢﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٩٣٠٨<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span>: <span class="qpc-hafs">﴿والَّذِي خَلَقَ الأَزْواجَ كُلَّها﴾</span> يعني: الشتاء والصيف، والليل والنهار، والسماء والأرض، وكلّ اثنين، فالواحد منهما زوج{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٩٣٠٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثم قال: <span class="qpc-hafs">﴿والَّذِي خَلَقَ الأَزْواجَ كُلَّها﴾</span> يعني: الأصناف كلّها <span class="qpc-hafs">﴿وجَعَلَ لَكُمْ مِنَ الفُلْكِ﴾</span> يعني: السُّفن <span class="qpc-hafs">﴿والأَنْعام﴾</span> يعني: الإبل والبقر <span class="qpc-hafs">﴿ما تَرْكَبُونَ﴾</span> يعني: الذي تركبون{2}. (ز)</p></p><p></div></p></div>",footnotes:1:ذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٤/١٧٧-.|2:تفسير مقاتل بن سليمان ٣/٧٩٠.
  43,13,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿لِتَسۡتَوُۥا۟ عَلَىٰ ظُهُورِهِۦ ثُمَّ تَذۡكُرُوا۟ نِعۡمَةَ رَبِّكُمۡ إِذَا ٱسۡتَوَیۡتُمۡ عَلَیۡهِ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٩٣١٠<span class="dash">-</span></span> عن عائشة، أنّها سمعت النبيَّ ﷺ يقرأ هذه الآية: «<b><span class="qpc-hafs">﴿وجَعَلَ لَكُمْ مِنَ الفُلْكِ والأَنْعامِ ما تَرْكَبُونَ لِتَسْتَوُوا عَلى ظُهُورِهِ ثُمَّ تَذْكُرُوا نِعْمَةَ رَبِّكُمْ إذا اسْتَوَيْتُمْ عَلَيْهِ﴾</span> أن تقولوا: الحمد لله الذي مَنَّ علينا بمحمد عبده ورسوله. ثم تقولوا: <span class="qpc-hafs">﴿سُبْحانَ الَّذِي سَخَّرَ لَنا هَذا وما كُنّا لَهُ مُقْرِنِينَ﴾</span>»</b>{1}. (١٣/١٨٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٩٣١١<span class="dash">-</span></span> عن <span class="name-2">شَهْر بن حَوْشَب</span>، <span class="qpc-hafs">﴿ثُمَّ تَذْكُرُوا نِعْمَةَ رَبِّكُمْ إذا اسْتَوَيْتُمْ عَلَيْهِ﴾</span>، قال: نِعمة الإسلام{2}. (١٣/١٩٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٩٣١٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿لِتَسْتَوُوا﴾</span> يعني: لكي تستووا <span class="qpc-hafs">﴿عَلى ظُهُورِهِ﴾</span>يعني: ذكورًا وإناثًا مِن الإبل، <span class="qpc-hafs">﴿ثُمَّ تَذْكُرُوا نِعْمَةَ رَبِّكُمْ إذا اسْتَوَيْتُمْ عَلَيْهِ﴾</span> على ظهورها، يعني: يقولون: الحمد لله{3}. (ز)</p></p><p></div></p></div>",footnotes:1:عزاه السيوطي إلى ابن مردويه.|2:عزاه السيوطي إلى ابن المنذر.|3:تفسير مقاتل بن سليمان ٣/٧٩٠.
  43,14,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَتَقُولُوا۟ سُبۡحَـٰنَ ٱلَّذِی سَخَّرَ لَنَا هَـٰذَا وَمَا كُنَّا لَهُۥ مُقۡرِنِینَ ۝١٣ وَإِنَّاۤ إِلَىٰ رَبِّنَا لَمُنقَلِبُونَ ۝١٤﴾</span> - قراءات</h3></p><p><div></p><p><p><span class="item-no">٦٩٣١٣<span class="dash">-</span></span> عن <span class="name-1">علي بن أبي طالب</span>، أنّه كان يقرأ: (سُبْحانَ مَن سَخَّرَ لَنا هَذا){1}. (١٣/١٩١)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَتَقُولُوا۟ سُبۡحَـٰنَ ٱلَّذِی سَخَّرَ لَنَا هَـٰذَا﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٩٣١٤<span class="dash">-</span></span> عن علي بن ربيعة، قال: رأيتُ عليًّا أُتِي بدابَّة، فلما وضع رِجله في الرِّكاب قال: باسم الله. فلمّا استوى على ظهرها قال: الحمد لله -ثلاثًا-، والله أكبر -ثلاثًا-، <span class="qpc-hafs">﴿سُبْحانَ الَّذِي سَخَّرَ لَنا هَذا وما كُنّا لَهُ مُقْرِنِينَ وإنّا إلى رَبِّنا لَمُنْقَلِبُونَ﴾</span>، سبحانك لا إله إلا أنت، قد ظلمتُ نفسي فاغفر لي ذنوبي، إنه لا يغفر الذُّنوب إلا أنت. ثم ضحك، فقلتُ: مِمَّ ضحكتَ، يا أمير المؤمنين؟ قال: رأيتُ رسول الله ﷺ فعل كما فعلتُ، ثم ضحك، فقلتُ: يا رسول الله، مِمَّ ضحكتَ؟ فقال: «<b>يعجب الرّبُّ مِن عبده إذا قال: ربّ اغفر لي. ويقول: علِم عبدي أنّه لا يغفر الذُّنوب غيري»</b>{2}. (١٣/١٨٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٩٣١٥<span class="dash">-</span></span> عن عبد الله بن عباس: أنّ رسول الله ﷺ أرْدَفَه على دابّته، فلمّا استوى عليها كبّر ثلاثًا، وسبّح ثلاثًا، وهلّل الله وحمده، ثم ضحك، ثم قال: «<b>ما مِن امرئ مسلم يركب دابّته، فيصنع كما صنعتُ؛ إلا أقبل الله فضحك إليه كما ضحكتُ إليك</b>»{3}. (١٣/١٨٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٩٣١٦<span class="dash">-</span></span> عن ابن عمر: أنّ رسول الله ﷺ كان إذا استوى على بعيره خارجًا إلى سفَرٍ كبّر ثلاثًا، ثم قال: «<span class="qpc-hafs">﴿<b>سُبْحانَ الَّذِي سَخَّرَ لَنا هَذا وما كُنّا لَهُ مُقْرِنِينَ وإنّا إلى رَبِّنا لَمُنْقَلِبُونَ﴾</span>، اللهم، إنّا نسألك في سَفَرنا هذا البِرَّ والتقوى، ومِن العمل ما ترضى، اللهم، هوِّن علينا سَفَرنا هذا، واطْوِ عنا بُعْدَه، اللهم، أنتَ الصاحب في السّفر، والخليفة في الأهل، اللهم، إنِّي أعوذُ بك مِن وعْثاءِ</b>{4} <b>السّفر، وكآبة المنظر، وسوء المُنقلب في المال والأهل</b>». وإذا رجع قالَهُنَّ وزاد فيهن: «<b>آيبون، تائبون، عابدون، لربنا حامدون</b>»{5}. (١٣/١٨٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٩٣١٧<span class="dash">-</span></span> عن أبي مِجْلَز، قال: رأى <span class="name-1">الحسنُ بنُ علي</span> رجلًا يركب دابّة، فقال: <span class="qpc-hafs">﴿سُبْحانَ الَّذِي سَخَّرَ لَنا هَذا وما كُنّا لَهُ مُقْرِنِينَ وإنّا إلى رَبِّنا لَمُنْقَلِبُونَ﴾</span>. قال: أوَبذلك أمرتَ؟! قال: فكيف أقول؟ قال: قل: الحمد لله الذي هدانا للإسلام، الحمد لله الذي مَنَّ علينا بمحمد ﷺ، الحمد لله الذي جعلني في خير أُمّة أُخرجت للناس، ثم تقول: <span class="qpc-hafs">﴿سُبْحانَ الَّذِي سَخَّرَ لَنا هَذا وما كُنّا لَهُ مُقْرِنِينَ﴾</span>{6}<span class=comment-ref>٥٨٤٤</span>. (١٣/١٩٠)</p></p><p></div></p><p><div><span class=comment-ref>٥٨٤٤</span> <span class="comment-type-4">ذكر</span> <u>ابنُ عطية</u> (٧/٥٣٦) أن السُّنة للراكب إذا ركب أن يقول: الحمد لله على نعمة الإسلام، أو على النعمة بمحمد ﵄، أو على النعمة في كل حال. وساق هذا الأثر، ثم قال (٧/٥٣٧): «وإن قدّرنا أنّ ذكر النعمة هو بالقلب والتذكير بدأ الراكب بـ<span class="qpc-hafs">﴿سبحان الذي سخر﴾</span>، وهو يرى نعمة الله في ذلك وفي سواه».</div></p><p><div></p><p><p><span class="item-no">٦٩٣١٨<span class="dash">-</span></span> عن إبراهيم النَّخْعي، قال: وضع <span class="name-2">علْقمة بن قيس</span> رِجله في الغرْز، فقال: بسم الله. فلمّا قعد على ظهرها قال: الحمد لله. فلمّا نهض قال: <span class="qpc-hafs">﴿سُبْحانَ الَّذِي سَخَّرَ لَنا هَذا وما كُنّا لَهُ مُقْرِنِينَ وإنّا إلى رَبِّنا لَمُنْقَلِبُونَ﴾</span>{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٩٣١٩<span class="dash">-</span></span> عَن <span class="name-2">طاووس بن كيسان</span> -من طريق ابنه- أنّه كان إذ ركب دابَّةً قال: بسم الله، اللهم، هذا من منك، وفضلك علينا، فلك الحمد، ربّنا، <span class="qpc-hafs">﴿سُبْحانَ الَّذِي سَخَّرَ لَنا هَذا وما كُنّا لَهُ مُقْرِنِينَ وإنّا إلى رَبِّنا لَمُنْقَلِبُونَ﴾</span>{8}. (١٣/١٩١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٩٣٢٠<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿لِتَسْتَوُوا عَلى ظُهُورِهِ ثُمَّ تَذْكُرُوا نِعْمَةَ رَبِّكُمْ إذا اسْتَوَيْتُمْ عَلَيْهِ﴾</span>: يُعَلّمكم كيف تقولون إذا ركبتم؛ في الفلك تقولون: <span class="qpc-hafs">﴿بِسْمِ اللَّهِ مَجْراها ومُرْساها إنَّ رَبِّي لَغَفُورٌ رَحِيمٌ﴾</span> [هود:٤١]، وإذا ركبتم الإبل قلتم: <span class="qpc-hafs">﴿سُبْحانَ الَّذِي سَخَّرَ لَنا هَذا وما كُنّا لَهُ مُقْرِنِينَ وإنّا إلى رَبِّنا لَمُنْقَلِبُونَ﴾</span>. ويعلّمكم ما تقولون إذا نزلتم مِن الفُلك والأنعام جميعًا، تقولون: اللهم، أنزِلنا مُنزلًا مباركًا وأنت خير المنزلين{9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٩٣٢١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿و﴾</span>لكي <span class="qpc-hafs">﴿تَقُولُوا سُبْحانَ الَّذِي سَخَّرَ لَنا هَذا﴾</span>، يعني: ذلَّل لنا هذا المركب{10}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَمَا كُنَّا لَهُۥ مُقۡرِنِینَ ۝١٣ وَإِنَّاۤ إِلَىٰ رَبِّنَا لَمُنقَلِبُونَ ۝١٤﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٩٣٢٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- في قوله: <span class="qpc-hafs">﴿وما كُنّا لَهُ مُقْرِنِينَ﴾</span>، قال: مُطيقين{11}. (١٣/١٩٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٩٣٢٣<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿وما كُنّا لَهُ مُقْرِنِينَ﴾</span>، قال: الإبل، والخيل، والبِغال، والحَمير{12}. (١٣/١٩١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٩٣٢٤<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿وما كُنّا لَهُ مُقْرِنِينَ﴾</span>، قال: لا في الأيدي، ولا في القوة{13}. (١٣/١٩٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٩٣٢٥<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدّيّ</span> -من طريق أسباط- <span class="qpc-hafs">﴿وما كُنّا لَهُ مُقْرِنِينَ﴾</span>، قال: مُطيقين{14}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٩٣٢٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وما كُنّا لَهُ مُقْرِنِينَ﴾</span> يعني: مُطيقين، ولكي تقولوا: <span class="qpc-hafs">﴿وإنّا إلى رَبِّنا لَمُنْقَلِبُونَ﴾</span> يعني: لراجعون{10}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٩٣٢٧<span class="dash">-</span></span> قال <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿سُبْحانَ الَّذِي سَخَّرَ لَنا هَذا وما كُنّا لَهُ مُقْرِنِينَ﴾</span>، قال: لسنا له مُطيقين. قال: لا نطيقها إلا بك، لولا أنت ما قوينا عليها، ولا أطقناها{14}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَمَا كُنَّا لَهُۥ مُقۡرِنِینَ ۝١٣ وَإِنَّاۤ إِلَىٰ رَبِّنَا لَمُنقَلِبُونَ ۝١٤﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٦٩٣٢٨<span class="dash">-</span></span> عن محمد بن حمزة بن عمرو الأسلمي، عن أبيه، قال: قال رسول الله ﷺ: «<b>فوق ظهر كلِّ بعير شيطانٌ، فإذا ركبتموه فاذكروا اسم الله، ثم لا تُقصِّروا عن حاجاتكم</b>»{17}. (١٣/١٩٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٩٣٢٩<span class="dash">-</span></span> عن أبي لاس الخزاعي، عن رسول الله ﷺ، قال: «<b>ما مِن بعير إلا في ذُرْوته شيطان، فاذكروا اسمَ الله عليها إذا ركبتموها كما أمركم، ثم امتهنوها لأنفسكم، فإنما يحملُ اللهُ</b>»{18}. (١٣/١٩٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٩٣٣٠<span class="dash">-</span></span> عن <span class="name-2">سليمان بن يسار</span>: أنّ قومًا كانوا في سَفر، فكانوا إذا ركبوا قالوا: <span class="qpc-hafs">﴿سُبْحانَ الَّذِي سَخَّرَ لَنا هَذا وما كُنّا لَهُ مُقْرِنِينَ﴾</span>. وكان فيهم رجل له ناقة رازِمٌ{19}، فقال: أمّا أنا فأنا لهذه مُقْرِنٌ. فقَمَصَتْ{20} به، فصرعتْه، فاندقّت عنقه{21}. (١٣/١٩٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٩٣٣١<span class="dash">-</span></span> عن عبد الملك، عن <span class="name-2">عطاء [بن أبي رباح]</span> أنه سُئِل: أيبدأ الرجل بالتلبية، أو يقول: <span class="qpc-hafs">﴿سبحان الذي سخّر لنا هذا وما كنا له مقرنين﴾</span>؟ قال: يبدأ بـ<span class="qpc-hafs">﴿سبحان الذي سخّر لنا هذا﴾</span>{22}. (ز)</p></p><p></div></p></div>",footnotes:1:عزاه السيوطي إلى ابن الأنباري في المصاحف.</p><p>وهي قراءة شاذة. انظر: الجامع لأحكام القرآن ١٩/١٢.|2:أخرجه أحمد ٢/١٤٨ (٧٥٣)، ٢/٢٤٨ (٩٣٠)، ٢/٣١٤ (١٠٥٦)، وأبو داود ٤/٢٤٣-٢٤٤ (٢٦٠٢)، والترمذي ٦/٦٧-٦٨ (٣٧٤٩)، وابن حبان ٦/٤١٥ (٢٦٩٨)، والحاكم ٢/١٠٨-١٠٩ (٢٤٨٢، ٢٤٨٣)، وعبد الرزاق ٣/١٦٥ (٢٧٥٤).</p><p>قال الترمذي: «هذا حديث حسن صحيح». وقال الحاكم: «هذا حديث صحيح، على شرط مسلم، ولم يخرجاه».|3:أخرجه أحمد ٥/١٧٦ (٣٠٥٧).</p><p>قال ابن كثير ٧/٢٢١: «تفرد به أحمد». وقال الهيثمي في المجمع ١٠/١٣١ (١٧٠٩٨): «وفيه أبو بكر بن أبي مريم، وهو ضعيف».|4:أي: شدته ومشقته. النهاية (وعث).|5:أخرجه مسلم ٢/٩٧٨ (١٣٤٢).|6:أخرجه ابن جرير ٢٠/٥٥٨. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.|7:أخرجه آدم ابن أبي إياس -كما في تفسير مجاهد ص٥٩٢-.|8:أخرجه عبد الرزاق ٢/١٩٥، وابن جرير ٢٠/٥٥٩. وعزاه السيوطي إلى عبد بن حميد.|9:أخرجه ابن جرير ٢٠/٥٥٨-٥٥٩. وذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٤/١٧٨- بنحوه.|10:تفسير مقاتل بن سليمان ٣/٧٩٠.|11:أخرجه ابن جرير ٢٠/٥٥٩، وابن أبي حاتم -كما في تغليق التعليق ٤/٣٠٦-. وعزاه السيوطي إلى ابن المنذر.|12:تفسير مجاهد ص٥٩٢، وأخرجه ابن جرير ٢٠/٥٥٩-٥٦٠، والأثر عند الفريابي -كما في تغليق التعليق٤/٣٠٦، وفتح الباري ٨/٥٦٧-. وعزاه السيوطي إلى عَبد بن حُمَيد.|13:أخرجه عبد الرزاق ٢/١٩٤ من طريق معمر، وابن جرير ٢٠/٥٦٠ بنحوه كذلك من طريق معمر. وعزاه السيوطي إلى ابن المنذر.|14:أخرجه ابن جرير ٢٠/٥٦٠.|15:تفسير مقاتل بن سليمان ٣/٧٩٠.|16:أخرجه ابن جرير ٢٠/٥٦٠.|17:أخرجه أحمد ٢٥/٤٢٦ (١٦٠٣٩)، وابن خزيمة ٤/٢٤٣ (٢٥٤٦)، وابن حبان ٤/٦٠٢-٦٠٣ (١٧٠٣)، ٦/٤١١-٤١٢ (٢٦٩٤)، والحاكم ١/٦١٢ (١٦٢٦).</p><p>قال الحاكم: «هذا حديث صحيح، على شرط مسلم، ولم يخرجاه، وله شاهد على شرطه». وقال المنذري في الترغيب ٤/٣٨ (٤٧٠٧): «رواه أحمد، والطبراني، وإسنادهما جيد». وقال الهيثمي في المجمع ١٠/١٣١ (١٧٠٩٤): «رواه أحمد، والطبراني في الكبير، والأوسط، ورجالهما رجال الصحيح غير محمد بن حمزة، وهو ثقة». وقال المناوي في التيسير ٢/١٣٤: «وإسناده جيد».|18:أخرجه أحمد ٢٩/٤٥٨-٤٥٩ (١٧٩٣٨-١٧٩٣٩)، وابن خزيمة ٤/٢٤١ (٢٥٤٣)، والحاكم ١/٦١٢ (١٦٢٤).</p><p>قال الحاكم: «هذا حديث صحيح، على شرط مسلم، ولم يخرجاه، وله شاهد صحيح». وقال الهيثمي في المجمع ١٠/١٣١ (١٧٠٩٣): «رواه أحمد والطبراني بأسانيد، ورجال أحدها رجال الصحيح غير محمد بن إسحاق، وقد صرّح بالسماع في إحداهما». وقال البوصيري في إتحاف الخيرة ٣/١٤٧ (٢٤٠٧): «رواه أبو بكر بن أبي شيبة واللفظ له، وأبو يعلى، والبخاري -حدّث به تعليقًا-، والحاكم، وعنه البيهقي بسند ضعيف؛ لتدليس محمد ابن إسحاق». وقال الألباني في الصحيحة ٥/٣٤٢ (٢٢٧١): «وهذا إسناد حسن، رجاله ثقات، وابن إسحاق وإن كان قد عنعنه فقد صرّح بالتحديث في رواية الحربي».|19:أي: لا تتحرك من الهزال. النهاية (رزم).|20:أي: وثبَت ونفرت فألقته. النهاية (قمص).|21:عزاه السيوطي إلى عَبد بن حُمَيد، وابن المنذر.|22:أخرجه سعيد بن منصور في سننه -التفسير ٧/٢٨٨ (١٩٣٥)، وأخرجه ابن أبي شيبة في مصنفه ٨/٥٢ (١٢٨٩٨) بلفظ: إن شئتَ ففي دبر الصلاة، وإن شئتَ فإذا انبعثت بك الناقة تبدأ حين تركب، فتقول: <span class="qpc-hafs">﴿سبحان الذي سخر لنا هذا وما كنا له مقرنين﴾</span>.
  43,15,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَجَعَلُوا۟ لَهُۥ مِنۡ عِبَادِهِۦ جُزۡءًاۚ إِنَّ ٱلۡإِنسَـٰنَ لَكَفُورࣱ مُّبِینٌ ۝١٥﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٩٣٣٢<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿وجَعَلُوا لَهُ مِن عِبادِهِ جُزْءًا﴾</span>، قال: ولَدًا، وبنات من الملائكة{1}. (١٣/١٩٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٩٣٣٣<span class="dash">-</span></span> قال <span class="name-2">مجاهد بن جبر</span>: <span class="qpc-hafs">﴿مِن عِبادِهِ جُزْءًا﴾</span>، يعني: الملائكة، حيث جعلوهم بنات الله{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٩٣٣٤<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿وجَعَلُوا لَهُ مِن عِبادِهِ جُزْءًا﴾</span>، قال: عِدلًا{3}. (١٣/١٩٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٩٣٣٥<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدّيّ</span> -من طريق أسباط- <span class="qpc-hafs">﴿وجَعَلُوا لَهُ مِن عِبادِهِ جُزْءًا﴾</span>، قال: البنات{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٩٣٣٦<span class="dash">-</span></span> عن <span class="name-2">عطاء الخُراساني</span> -من طريق يونس بن يزيد- في قوله ﷿: <span class="qpc-hafs">﴿وجعلوا له من عباده جزءا﴾</span>، قال: جعلوا له نصيبًا وشريكًا مِن عباده{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٩٣٣٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: قوله: <span class="qpc-hafs">﴿وجَعَلُوا لَهُ﴾</span> يقول: وصَفوا له <span class="qpc-hafs">﴿مِن عِبادِهِ﴾</span> من الملائكة <span class="qpc-hafs">﴿جُزْءًا﴾</span> يعني: عِدلًا، هو الولد؛ فقالوا: إنّ الملائكة بنات الله تعالى، يقول الله: <span class="qpc-hafs">﴿إنَّ الإنْسانَ﴾</span> في قوله <span class="qpc-hafs">﴿لَكَفُورٌ مُبِينٌ﴾</span> يقول: بيِّن الكفر{6}<span class=comment-ref>٥٨٤٥</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٥٨٤٥</span> اختُلف في معنى الجزء على قولين: <b>الأول</b>: أنه النصيب والحظّ، وذلك قولهم للملائكة: هم بنات الله. <b>الثاني</b>: أنه عُني به: العِدْل.</p><p>و<span class="comment-type-3">رجَّح</span> <u>ابنُ جرير</u> (٢٠/٥٦١-٥٦٢) -<span class="mustanad">مستندًا إلى السياق</span>- القول الأول الذي قاله مجاهد، والسُّدّيّ، ومقاتل، فقال: «لأن الله -جل ثناؤه- أتبع ذلك قوله: <span class="qpc-hafs">﴿أم اتخذ مما يخلق بنات وأصفاكم بالبنين﴾</span> توبيخًا لهم على قولهم ذلك، فكان معلومًا أنّ توبيخه إيّاهم بذلك إنّما هو عما أخبر عنهم من قيلهم ما قالوا في إضافة البنات إلى الله -جل ثناؤه-».</p><p>وساق <u>ابنُ عطية</u> (٥/٤٣ ط: دار الكتب العلمية) القول الثاني الذي قاله قتادة، ثم علّق بقوله: «فعلى هذا فتعنيف الكفرة في فصلين: في أمر الأصنام، وفي أمر الملائكة، وعلى هذا التأويل الأول فالآية كلها في أمر الملائكة».</p><p>وساق <u>ابنُ تيمية</u> (٥/٥١٨-٥١٩) القولين، ثم <span class="comment-type-4">علَّق</span> بقوله: «وكلا القولين صحيح؛ فإنهم يجعلون له ولدًا، والولد يشبه أباه؛ <span class="mustanad">ولهذا قال</span>: <span class="qpc-hafs">﴿وإذا بُشِّرَ أحَدُهُم بِما ضَرَبَ لِلرَّحْمَنِ مَثَلًا ظَلَّ وجْهُهُ مُسْوَدًّا﴾</span> [الزخرف:١٧] أي: البنات، <span class="mustanad">كما قال في الآية الأخرى</span>: <span class="qpc-hafs">﴿وإذا بُشِّرَ أحَدُهُمْ بِالأُنثى﴾</span> [النحل:٥٨]، فقد جعلوها للرحمن مثلًا، وجعلوا له من عباده جزءًا، فإنّ الولد جزء من الوالد كما تقدم، <span class="comment-type-4">قال</span> ﷺ: «إنما فاطمة بضعة مني». <span class="mustanad">وقوله</span>: <span class="qpc-hafs">﴿وجَعَلُواْ لِلّهِ شُرَكاء الجِنَّ وخَلَقَهُمْ وخَرَقُواْ لَهُ بَنِينَ وبَناتٍ بِغَيْرِ عِلْمٍ﴾</span> [الأنعام:١٠٠]. قال الكلبي: نزلت في الزنادقة، قالوا: إنّ الله وإبليس شريكان؛ فالله خالق النور والناس والدواب والأنعام، وإبليس خالق الظلمة والسّباع والحيّات والعقارب».</div></p></div>",footnotes:1:تفسير مجاهد ص٥٩٢، وأخرجه ابن جرير ٢٠/٥٦١. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.|2:ذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٤/١٧٩-.|3:أخرجه عبد الرزاق ٢/١٩٥ من طريق معمر، وعبد بن حميد -كما في تغليق التعليق ٤/٣٠٩-، وابن جرير ٢٠/٥٦١ بنحوه، ومن طريق معمر أيضًا. وبعده في حاشية١: «وأخرج عبد بن حميد، وابن جرير، وابن المنذر، عن مجاهد في قوله: <span class="qpc-hafs">﴿وجَعَلُوا لَهُ مِن عِبادِهِ جُزْءًا﴾</span> قال: عِدلًا». وعزاه السيوطي إلى ابن المنذر.|4:أخرجه ابن جرير ٢٠/٥٦١.|5:أخرجه أبو جعفر الرملي في جزئه (تفسير عطاء) ص٩١.|6:تفسير مقاتل بن سليمان ٣/٧٩٠.
  43,16,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿أَمِ ٱتَّخَذَ مِمَّا یَخۡلُقُ بَنَاتࣲ وَأَصۡفَىٰكُم بِٱلۡبَنِینَ ۝١٦﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٩٣٣٨<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: يقول الله تعالى ردًّا عليهم: <span class="qpc-hafs">﴿أمِ﴾</span> يقول: <span class="qpc-hafs">﴿اتَّخَذَ﴾</span> الرَّبّ لنفسه <span class="qpc-hafs">﴿مِمّا يَخْلُقُ بَناتٍ﴾</span> فيها تقديم واستفهام، اتخذ مما يخلق مِن <span class="qpc-hafs">﴿مَن يُنَشَّأُ فِي الحِلْيَةِ وهُوَ فِي الخِصامِ غَيْرُ مُبِينٍ﴾</span> بنات <span class="qpc-hafs">﴿وأَصْفاكُمْ بِالبَنِينَ﴾</span> يقول: واختصكم بالبنين{1}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٣/٧٩٠-٧٩١.
  43,17,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَإِذَا بُشِّرَ أَحَدُهُم بِمَا ضَرَبَ لِلرَّحۡمَـٰنِ مَثَلࣰا ظَلَّ وَجۡهُهُۥ مُسۡوَدࣰّا وَهُوَ كَظِیمٌ ۝١٧﴾</span> - قراءات</h3></p><p><div></p><p><p><span class="item-no">٦٩٣٣٩<span class="dash">-</span></span> قرأ <span class="name-2">عاصم</span>: <span class="qpc-hafs">﴿بِما ضَرَبَ لِلرَّحْمَنِ مَثَلًا﴾</span> بنصب الضاد{1}. (١٣/١٩٣)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَإِذَا بُشِّرَ أَحَدُهُم بِمَا ضَرَبَ لِلرَّحۡمَـٰنِ مَثَلࣰا ظَلَّ وَجۡهُهُۥ مُسۡوَدࣰّا وَهُوَ كَظِیمٌ ۝١٧﴾</span> - تفسير الآية</h3></p><p><div></p><p><p><span class="item-no">٦٩٣٤٠<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر ﻿</span>-من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿وإذا بُشِّرَ أحَدُهُمْ بِما ضَرَبَ لِلرَّحْمَنِ مَثَلًا﴾</span>، قال: ولدًا{2}. (١٣/١٩٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٩٣٤١<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿وإذا بُشِّرَ أحَدُهُمْ بِما ضَرَبَ لِلرَّحْمَنِ مَثَلًا﴾</span> قال: بما جعل لله <span class="qpc-hafs">﴿ظَلَّ وجْهُهُ مُسْوَدًّا وهُوَ كَظِيمٌ﴾</span> قال: حزين{3}. (١٣/١٩٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٩٣٤٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثم أخبر عنهم في التقديم، فقال: <span class="qpc-hafs">﴿وإذا بُشِّرَ أحَدُهُمْ بِما ضَرَبَ لِلرَّحْمَنِ مَثَلًا﴾</span> يعني: شبهًا، والمثل -زعموا- أنّ الملائكة بنات الله تعالى. <span class="qpc-hafs">﴿وإذا بُشِّرَ أحَدُهُمْ بِالأُنْثى ظَلَّ وجْهُهُ مُسْوَدًّا﴾</span> يعني: متغيّرًا <span class="qpc-hafs">﴿وهُوَ كَظِيمٌ﴾</span> [النحل:٥٨] يعني: مكروب{4}. (ز)</p></p><p></div></p></div>",footnotes:1:عزاه السيوطي إلى عبد بن حميد.</p><p>وهي قراءة العشرة.|2:تفسير مجاهد ص٥٩٢، وأخرجه ابن جرير ٢٠/٥٦٢. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.|3:أخرجه ابن جرير ٢٠/٥٦٣. وعزاه السيوطي إلى عبد بن حميد.|4:تفسير مقاتل بن سليمان ٣/٧٩١.
  43,18,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿أَوَمَن یُنَشَّؤُا۟ فِی ٱلۡحِلۡیَةِ وَهُوَ فِی ٱلۡخِصَامِ غَیۡرُ مُبِینࣲ ۝١٨﴾</span> - قراءات</h3></p><p><div></p><p><p><span class="item-no">٦٩٣٤٣<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، أنّه كان يقرأ: ‹أوَمَن يَنشَؤُاْ فِي الحِلْيَةِ› مُخفّفًا{1}. (١٣/١٩٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٩٣٤٤<span class="dash">-</span></span> قرأ <span class="name-2">عاصم</span>: ‹أوَمَن يَنشَؤُاْ› مخفّفة الياء مهموزة{2}<span class=comment-ref>٥٨٤٦</span>. (١٣/١٩٤)</p></p><p></div></p><p><div><span class=comment-ref>٥٨٤٦</span> اختُلف في قراءة قوله: <span class="qpc-hafs">﴿أومن ينشأ﴾</span>؛ <b>فقرأ قوم</b>: ‹أوَمَن يَنشَؤُاْ› بفتح الياء والتخفيف. <b>وقرأ آخرون</b>: <span class="qpc-hafs">﴿يُنشّأ﴾</span> بضم الياء وتشديد الشين.</p><p>و<span class="comment-type-4">ذكر</span> <u>ابنُ جرير</u> (٢٠/٥٦٥-٥٦٦) أنّ الأولى من: نشَأ ينشأ، وأن الثانية من: نشَّأته فهو يُنشّأ.</p><p>ثم <span class="comment-type-3">رجَّح</span> (٢٠/٥٦٦) صحة كلتا القراءتين <span class="mustanad">مستندًا إلى شهرتهما، وتقارب معناهما</span>، فقال: «والصواب من القول في ذلك عندنا أن يُقال: إنهما قراءتان معروفتان في قرأة الأمصار، متقاربتا المعنى؛ لأن المُنشّأ من الإنشاء ناشئ، والناشئ مُنشأ، فبأيتهما قرأ القارئ فمصيب».</div></p><p><h3><span class="qpc-hafs">﴿أَوَمَن یُنَشَّؤُا۟ فِی ٱلۡحِلۡیَةِ وَهُوَ فِی ٱلۡخِصَامِ غَیۡرُ مُبِینࣲ ۝١٨﴾</span> - تفسير الآية</h3></p><p><div></p><p><p><span class="item-no">٦٩٣٤٥<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، <span class="qpc-hafs">﴿أوَمَن يُنَشَّأُ فِي الحِلْيَةِ﴾</span>، قال: هُنّ النساء، فرّق بين زيِّهن وزيِّ الرجال، ونقْصهن من الميراث والشهادة، وأمرهن بالقَعْدة، وسمّاهن الخوالف{2}. (١٣/١٩٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٩٣٤٦<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطية العَوفيّ- قوله: <span class="qpc-hafs">﴿أوَمَن يُنَشَّأُ فِي الحِلْيَةِ وهُوَ فِي الخِصامِ غَيْرُ مُبِينٍ﴾</span>، قال: يعني: المرأة{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٩٣٤٧<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- <span class="qpc-hafs">﴿أوَمَن يُنَشَّأُ فِي الحِلْيَةِ﴾</span>، قال: الجواري، جعلتموهن للرحمن ولدًا، فكيف تحكمون؟!{5}. (١٣/١٩٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٩٣٤٨<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- في قوله: <span class="qpc-hafs">﴿أوَمَن يُنَشَّأُ فِي الحِلْيَةِ﴾</span> قال: جعلوا لله البنات، وإذا بُشِّر أحدهم بهنَّ <span class="qpc-hafs">﴿ظَلَّ وجْهُهُ مُسْوَدًّا وهُوَ كَظِيمٌ﴾</span> حزين، <span class="qpc-hafs">﴿وهُوَ فِي الخِصامِ غَيْرُ مُبِينٍ﴾</span> قال: قلّما تكلّمت امرأةٌ تريد أن تتكلم بحجّتها إلا تكلّمت بالحُجَّة عليها{6}. (١٣/١٩٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٩٣٤٩<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- قوله: <span class="qpc-hafs">﴿أوَمَن يُنَشَّأُ فِي الحِلْيَةِ وهُوَ فِي الخِصامِ غَيْرُ مُبِينٍ﴾</span> قال: الجواري يُسَفِّههن بذلك، <span class="qpc-hafs">﴿وهُوَ فِي الخِصامِ غَيْرُ مُبِينٍ﴾</span> بضعفهنّ{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٩٣٥٠<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدّيّ</span> –من طريق أسباط- <span class="qpc-hafs">﴿أوَمَن يُنَشَّأُ فِي الحِلْيَةِ وهُوَ فِي الخِصامِ غَيْرُ مُبِينٍ﴾</span>، قال: النساء{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٩٣٥١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿أوَمَن يُنَشَّأُ فِي الحِلْيَةِ﴾</span> يعني: ينبتُ في الزينة، يعني: الحلي، مع النساء، يعني: البنات <span class="qpc-hafs">﴿وهُوَ فِي الخِصامِ غَيْرُ مُبِينٍ﴾</span> يقول: هذا الولد الأُنثى ضعيفٌ، قليل الحيلة، وهو عند الخصومة والمحاربة غير بيّن، ضعيف عنها{9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٩٣٥٢<span class="dash">-</span></span> قال <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿أوَمَن يُنَشَّأُ فِي الحِلْيَةِ وهُوَ فِي الخِصامِ غَيْرُ مُبِينٍ﴾</span> الآية، قال: هذه تماثيلهم التي يضربونها مِن فِضّة وذهب، يعبدونها، هم الذين أنشأوها، ضربوها مِن تلك الحلية، ثم عبدوها، <span class="qpc-hafs">﴿وهُوَ فِي الخِصامِ غَيْرُ مُبِينٍ﴾</span> قال: لا يتكلّم. وقرأ: <span class="qpc-hafs">﴿فَإذا هُوَ خَصِيمٌ مُبِينٌ﴾</span> [يس:٧٧]{10}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٩٣٥٣<span class="dash">-</span></span> عن <span class="name-3">سفيان بن عُيَينة</span> -من طريق ابن أبي عمر- في قوله: <span class="qpc-hafs">﴿أومن ينشأ في الحلية وهو في الخصام غير مبين﴾</span>، قال: هو في النساء{11}<span class=comment-ref>٥٨٤٧</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٥٨٤٧</span> اختُلف في المراد بـ<span class="qpc-hafs">﴿مَن﴾</span> على قولين: <b>الأول</b>: النساء والجواري. <b>الثاني</b>: الأصنام.</p><p>و<span class="comment-type-3">رجَّح</span> <u>ابنُ جرير</u> (٢٠/٥٦٥) -<span class="mustanad">مستندًا إلى السياق</span>- القول الأول الذي قاله ابن عباس، ومجاهد، وقتادة، والسُّدّيّ، ومقاتل، فقال: «لأنّ ذلك عقيب خبر الله عن إضافة المشركين إليه ما يكرهونه لأنفسهم من البنات، وقلّة معرفتهم بحقّه، ونُحلتهم إياه مِن الصفات والنِّحَل، وهو خالقهم ومالكهم ورازقهم، والمنعم عليهم النِّعَم التي عدّدها في أول هذه السورة -ما لا يرضونه لأنفسهم-؛ فإتباع ذلك مِن الكلام ما كان نظيرًا له أشبه وأولى مِن إتباعه ما لم يجْر له ذِكر».</div></p><p><h3><span class="qpc-hafs">﴿أَوَمَن یُنَشَّؤُا۟ فِی ٱلۡحِلۡیَةِ وَهُوَ فِی ٱلۡخِصَامِ غَیۡرُ مُبِینࣲ ۝١٨﴾</span> - من أحكام الآية</h3></p><p><div></p><p><p><span class="item-no">٦٩٣٥٤<span class="dash">-</span></span> عن أبي موسى الأشعري، قال: قال رسول الله ﷺ: <b>«الذّهب والحرير حرامٌ على ذكور أمتي، وحِلٌّ لإناثهم»</b>{12}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٩٣٥٥<span class="dash">-</span></span> عن <span class="name-2">أبي العالية الرِّياحي</span>، أنّه سُئِل: عن الذّهب للنساء. فقال: لا بأس به، يقول الله: <span class="qpc-hafs">﴿أوَمَن يُنَشَّأُ فِي الحِلْيَةِ﴾</span>{2}. (١٣/١٩٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٩٣٥٦<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق علقمة بن مرثد- قال: رُخِّص للنساء في الحرير والذّهب. وقرأ: <span class="qpc-hafs">﴿أوَمَن يُنَشَّأُ فِي الحِلْيَةِ وهُوَ فِي الخِصامِ غَيْرُ مُبِين﴾</span>{14}. (ز)</p></p><p></div></p></div>",footnotes:1:عزاه السيوطي إلى عبد بن حميد.</p><p>وهي قراءة متواترة، قرأ بها العشرة، ما عدا حمزة، والكسائي، وخلفًا العاشر، وحفصًا عن عاصم؛ فإنهم قرؤوا: <span class="qpc-hafs">﴿أوَمَن يُنشَّؤُاْ﴾</span> بضمّ الياء وتشديد الشين. انظر: النشر ٢/٣٦٨، والإتحاف ص٤٩٤.|2:عزاه السيوطي إلى عبد بن حميد.|3:عزاه السيوطي إلى عبد بن حميد.|4:أخرجه ابن جرير ٢٠/٥٦٣.|5:تفسير مجاهد ص٥٩٣، وأخرجه الفريابي -كما في تغليق التعليق ٤/٣٠٦، وفتح الباري ٨/٥٦٧-، وابن جرير ٢٠/٥٦٤ بنحوه. وعزاه السيوطي إلى عبد بن حميد.|6:أخرجه عبد الرزاق ٢/١٩٥، وابن جرير ٢٠/٥٦٤ بنحوه. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.|7:أخرجه ابن جرير ٢٠/٥٦٤.|8:أخرجه ابن جرير ٢٠/٥٦٤.|9:تفسير مقاتل بن سليمان ٣/٧٩١.|10:أخرجه ابن جرير ٢٠/٥٦٥.|11:أخرجه إسحاق البستي ص٣١٣.|12:أخرجه أحمد ٣٢/٢٧٦ (١٩٥١٥)، والترمذي ٣/٥١٥ (١٨١٧)، والثعلبي ٨/٣٣٠.</p><p>قال الترمذي: «حديث حسن صحيح». وقال العراقي في تخريج الإحياء ص٤٤٨: «الظاهر انقطاعه بين سعيد بن أبي هند وأبي موسى، فأدخل أحمد بينهما رجلًا لم يُسَمّ». وقال ابن حجر في الفتح ١٠/٢٩٦: «أعلّه ابن حبان وغيره بالانقطاع». وقال الألباني في إرواء الغليل ١/٣٠٥ (٢٧٧): «صحيح».|13:عزاه السيوطي إلى عبد بن حميد.|14:أخرجه عبد الرزاق ٢/١٩٥ مطولًا، وابن جرير ٢٠/٥٦٤.
  43,19,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَجَعَلُوا۟ ٱلۡمَلَـٰۤىِٕكَةَ ٱلَّذِینَ هُمۡ عِبَـٰدُ ٱلرَّحۡمَـٰنِ إِنَـٰثًاۚ﴾</span> - قراءات</h3></p><p><div></p><p><p><span class="item-no">٦٩٣٥٧<span class="dash">-</span></span> عن هارون، قال: في قراءة <span class="name-1">أُبَيّ بن كعب</span>: (وجَعَلُواْ المَلَآئِكَةَ عِندَ الرَّحْمَنِ إناثًا) ليس فيه: <span class="qpc-hafs">﴿الَّذِينَ هُمْ﴾</span>{1}. (١٣/١٩٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٩٣٥٨<span class="dash">-</span></span> عن هارون: في قراءة <span class="name-1">ابن مسعود</span>: (وعِبادُ الرَّحْمَنِ{2}).= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٩٣٥٩<span class="dash">-</span></span> وفي قراءة <span class="name-1">أُبي بن كعب</span>: (عِندَ) معجمة مكتوبة، وليس فيها: <span class="qpc-hafs">﴿الَّذِينَ هُمْ﴾</span> وإذا لم يكن فيها <span class="qpc-hafs">﴿الَّذِينَ هُمْ﴾</span> لم يجز أن يكون (عِندَ){3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٩٣٦٠<span class="dash">-</span></span> قرأ <span class="name-1">عبد الله بن عباس</span>: <span class="qpc-hafs">﴿الَّذِينَ هُمْ عِبادُ الرَّحْمَنِ﴾</span>، كقوله سبحانه: <span class="qpc-hafs">﴿بَلْ عِبادٌ مُكْرَمُونَ﴾</span> [الأنبياء:٢٦]{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٩٣٦١<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جُبير</span> -من طريق أبي بشر- قال: كنت أقرأ هذا الحرف: ‹الَّذِينَ هُمْ عِندَ الرَّحْمَنِ إناثًا›= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٩٣٦٢<span class="dash">-</span></span> فسألتُ <span class="name-1">ابنَ عباس</span>، فقال: <span class="qpc-hafs">﴿عِبادُ الرَّحْمَنِ﴾</span>. قلت: فإنّها في مصحفي: ‹عِندَ الرَّحْمَنِ›. قال: فامحُها، واكتبها: <span class="qpc-hafs">﴿عِبادُ الرَّحْمَنِ﴾</span>{5}. (١٣/١٩٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٩٣٦٣<span class="dash">-</span></span> عن <span class="name-2">علقمة</span>، أنه قرأ: <span class="qpc-hafs">﴿الَّذِينَ هُمْ عِبادُ الرَّحْمَنِ﴾</span> بالألف والباء، وقال: أتاني رجلٌ اليومَ وددتُ أنه لم يأتني. فقال: كيف تقرأ هذا الحرف: <span class="qpc-hafs">﴿وجَعَلُوا المَلَآئِكَةَ الَّذِينَ هُمْ عِبادُ الرَّحْمَنِ إناثًا﴾</span>؟ فقال: إن أناسًا يقرءون: ‹الَّذِينَ هُمْ عِندَ الرَّحْمَنِ›. فسكتُّ عنه، فقلتُ: اذهب إلى أهلك{6}. (١٣/١٩٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٩٣٦٤<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span>، أنّه قرأها: ‹المَلَآئِكَةَ الَّذِينَ هُمْ عِندَ الرَّحْمَنِ› بالنون{6}. (١٣/١٩٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٩٣٦٥<span class="dash">-</span></span> عن <span class="name-2">عاصم</span>، أنّه قرأ: <span class="qpc-hafs">﴿عِبادُ الرَّحْمَنِ﴾</span> بالألف والباء{6}<span class=comment-ref>٥٨٤٨</span>. (١٣/١٩٦)</p></p><p></div></p><p><div><span class=comment-ref>٥٨٤٨</span> اختُلف في قراءة قوله: <span class="qpc-hafs">﴿الذين هم عباد الرحمن﴾</span>؛ <b>فقرأ قوم</b>: ‹الَّذِينَ هُمْ عِندَ الرَّحْمَنِ›، و<b>قرأ غيرهم</b>: <span class="qpc-hafs">﴿الَّذِينَ هُمْ عِبادُ الرَّحْمَنِ﴾</span>.</p><p>و<span class="comment-type-4">ذكر</span> <u>ابنُ جرير</u> (٢٠/٥٦٦-٥٦٧) أنّ من قرأوا بالنون كأنهم <span class="mustanad">تأولوا في ذلك قول الله -جل ثناؤه-</span>: <span class="qpc-hafs">﴿إن الذين عند ربك لا يستكبرون﴾</span> [الأعراف:٢٠٦]، وأن تفسير الكلام على هذه القراءة: وجعلوا ملائكة الله الذين هم عنده يسبّحونه إناثًا، فقالوا: هم بنات الله جهلًا منهم بحقِّ الله، وجرأة منهم على قيل الكذب والباطل، وأن القراءة الثانية بمعنى: جمع عبْد، وأنّ معنى الكلام عليها: وجعلوا ملائكة الله الذين هم خلْقه وعباده بنات الله، فأنّثوهم بوصفهم إياهم بأنهم إناث.</p><p>و<span class="comment-type-4">ذكر</span> <u>ابنُ عطية</u> (٧/٥٣٩) أن القراءة الأولى أدلُّ على رفع المنزلة وقُربها في التكرمة، كما قيل: مَلَك مقرّب.</p><p>و<span class="comment-type-3">رجَّح</span> <u>ابنُ جرير</u> (٢٠/٥٦٧) صحة كلتا القراءتين <span class="mustanad">مستندًا إلى شهرتهما، وصحة معناهما</span>، فقال: «والصواب من القول في ذلك عندي أنهما قراءتان معروفتان في قراءة الأمصار صحيحتا المعنى، فبأيتهما قرأ القارئ فمصيب، وذلك أن الملائكة عباد الله، وعنده».</p><p>و<span class="comment-type-4">علَّق</span> <u>ابنُ عطية</u> (٧/٥٣٩) عليهما بقوله: «وقد <span class="mustanad">تصرّف المعنيان في كتاب الله تعالى في وصف الملائكة في غير هذه الآية</span>، فقال تعالى: <span class="qpc-hafs">﴿بل عباد مكرمون﴾</span> [الأنبياء:٢٦]، وقال سبحانه في أخرى: <span class="qpc-hafs">﴿فالذين عند ربك﴾</span> [فصلت:٣٨]».</div></p><p><h3><span class="qpc-hafs">﴿وَجَعَلُوا۟ ٱلۡمَلَـٰۤىِٕكَةَ ٱلَّذِینَ هُمۡ عِبَـٰدُ ٱلرَّحۡمَـٰنِ إِنَـٰثًاۚ﴾</span> - تفسير الآية</h3></p><p><div></p><p><p><span class="item-no">٦٩٣٦٦<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span>، <span class="qpc-hafs">﴿وجَعَلُوا المَلائِكَةَ الَّذِينَ هُمْ عِبادُ الرَّحْمَنِ إناثًا﴾</span>، قال: قد قال ذلك أناسٌ مِن الناس، ولا نعلمهم إلا اليهود: إنّ الله ﷿ صاهَرَ الجن، فخرجت مِن بيْنهم الملائكة{9}. (١٣/١٩٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٩٣٦٧<span class="dash">-</span></span> قال <span class="name-2">إسماعيل السُّدّيّ</span>: <span class="qpc-hafs">﴿وجَعَلُوا المَلائِكَةَ﴾</span>، يعني: وصَفوا{10}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٩٣٦٨<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثم أخبر عنهم، فقال: <span class="qpc-hafs">﴿وجَعَلُوا﴾</span> يقول: ووصفوا <span class="qpc-hafs">﴿المَلائِكَةَ الَّذِينَ هُمْ عِبادُ الرَّحْمَنِ إناثًا﴾</span> لقولهم: إنّ الملائكة بنات الله{11}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿أَشَهِدُوا۟ خَلۡقَهُمۡۚ سَتُكۡتَبُ شَهَـٰدَتُهُمۡ وَیُسۡـَٔلُونَ ۝١٩﴾</span> - قراءات</h3></p><p><div></p><p><p><span class="item-no">٦٩٣٦٩<span class="dash">-</span></span> قرأ <span class="name-2">عاصم</span>: <span class="qpc-hafs">﴿أشَهِدُواْ خَلْقَهُمْ﴾</span> بنصب الألف والشين، <span class="qpc-hafs">﴿سَتُكْتَبُ شَهادَتُهُمْ﴾</span> بالتاء، ورفع التاء{12}<span class=comment-ref>٥٨٤٩</span>. (١٣/١٩٦)</p></p><p></div></p><p><div><span class=comment-ref>٥٨٤٩</span> اختُلف في قراءة قوله: <span class="qpc-hafs">﴿أشهدوا خلقهم﴾</span>؛ <b>فقرأ قوم</b>: ‹أُشْهِدُوا› بضم الألف. <b>وقرأ آخرون</b>: <span class="qpc-hafs">﴿أشهدوا﴾</span> بفتح الألف.</p><p>و<span class="comment-type-4">ذكر</span> <u>ابنُ جرير</u> (٢٠/٥٦٧) أن الأولى على وجه ما لم يُسم فاعله، بمعنى: أأْشْهَد الله هؤلاء المشركين الجاعلين ملائكة الله إناثًا خلق ملائكته الذين هم عنده، فعلموا ما هم، وأنهم إناث، فوصفوهم بذلك؛ لعلمهم بهم، وبرؤيتهم إياهم؟! ثم ردّ ذلك إلى ما لم يُسمّ فاعله، وأن القراءة الثانية بمعنى: أشهدوا هم ذلك فعلموه؟! ثم <span class="comment-type-3">رجَّح</span> صحة كلتا القراءتين <span class="mustanad">مستندًا إلى شهرتهما</span>، فقال: «والصواب من القول في ذلك عندي أنهما قراءتان معروفتان، فبأيتهما قرأ القارئ فمصيب».</div></p><p><h3><span class="qpc-hafs">﴿أَشَهِدُوا۟ خَلۡقَهُمۡۚ سَتُكۡتَبُ شَهَـٰدَتُهُمۡ وَیُسۡـَٔلُونَ ۝١٩﴾</span> - نزول الآية، وتفسيرها</h3></p><p><div></p><p><p><span class="item-no">٦٩٣٧٠<span class="dash">-</span></span> قال محمد بن السِّائِب الكلبي: لَمّا قالوا هذا القولَ سألهم النبيُّ ﷺ، فقال: «<b>ما يدريكم أنهم إناث؟</b>». قالوا: سمعنا مِن آبائنا، ونحن نشهد أنهم لم يكذبوا. فقال الله تعالى: <span class="qpc-hafs">﴿سَتُكْتَبُ شَهادَتُهُمْ ويُسْأَلُونَ﴾</span> عنها في الآخرة{13}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٩٣٧١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: يقولُ الله تعالى للنبي ﷺ: <span class="qpc-hafs">﴿أشَهِدُوا خَلْقَهُمْ﴾</span>. فسُئلوا، فقالوا: لا. فقال النبي ﷺ: «<b>ما يدريكم أنهم إناث</b>؟». قالوا: سمعنا من آبائنا، وشهدوا أنهم لم يكذبوا، وأنهم إناث. قال الله تعالى: <span class="qpc-hafs">﴿سَتُكْتَبُ شَهادَتُهُمْ﴾</span> بأنّ الملائكة بنات الله في الدنيا، <span class="qpc-hafs">﴿ويُسْأَلُونَ﴾</span> عنهما في الآخرة، حين شهدوا أنّ الملائكة بنات الله{11}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه أبو عبيد ص١٨٣. وعزاه السيوطي إلى ابن المنذر.</p><p>وهي قراءة شاذة. انظر: المحرر الوجيز ٥/٤٩.|2:كذا في المصدر بالواو ولعلها مدرجة.|3:أخرجه إسحاق البستي ص٣١٤.|4:ذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٤/١٨٠-.</p><p>وهي قراءة متواترة، قرأ بها عاصم، وحمزة، والكسائي، وخلف العاشر، وأبو عمرو، وقرأ بقية العشرة: ‹عِندَ الرَّحْمَنِ›. انظر: النشر ٢/٣٦٨، والإتحاف ص٤٩٤-٤٩٥.|5:أخرجه الحاكم ٢/٤٤٦-٤٤٧. وعزاه السيوطي إلى سعيد بن منصور، وعَبد بن حُمَيد، وابن المنذر، وابن أبي حاتم. وأخرجه إسحاق البستي ص٣١٣ من قراءة سعيد.|6:عزاه السيوطي إلى عبد بن حميد.|7:عزاه السيوطي إلى عبد بن حميد.|8:عزاه السيوطي إلى عبد بن حميد.|9:عزاه السيوطي إلى عَبد بن حُمَيد، وابن المنذر.|10:ذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٤/١٨٠-.|11:تفسير مقاتل بن سليمان ٣/٧٩١.|12:عزاه السيوطي إلى عبد بن حميد.</p><p>وهي قراءة العشرة، ما عدا نافعًا، وأبا جعفر؛ فإنهما قرآ: ‹أأُشْهِدُواْ› بهمزتين. انظر: النشر ٢/٣٦٨، والإتحاف ص٤٩٥.|13:تفسير البغوي ٧/٢٠٩.|14:تفسير مقاتل بن سليمان ٣/٧٩١.
  43,20,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَقَالُوا۟ لَوۡ شَاۤءَ ٱلرَّحۡمَـٰنُ مَا عَبَدۡنَـٰهُمۗ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٩٣٧٢<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿وقالُوا لَوْ شاءَ الرَّحْمَنُ ما عَبَدْناهُمْ﴾</span>، قال: يعنون الأوثان؛ لأنهم عبدوا الأوثان{1}. (١٣/١٩٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٩٣٧٣<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span>، <span class="qpc-hafs">﴿وقالُوا لَوْ شاءَ الرَّحْمَنُ ما عَبَدْناهُمْ﴾</span>، قال: عبدوا الملائكة{2}. (١٣/١٩٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٩٣٧٤<span class="dash">-</span></span> قال <span class="name-3">محمد بن السّائِب الكلبي</span>: <span class="qpc-hafs">﴿وقالُوا لَوْ شاءَ الرَّحْمَنُ ما عَبَدْناهُمْ﴾</span>، يعني: الملائكة{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٩٣٧٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وقالُوا لَوْ شاءَ الرَّحْمَنُ ما عَبَدْناهُمْ﴾</span>، يعني: الملائكة{4}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿مَّا لَهُم بِذَ ٰ⁠لِكَ مِنۡ عِلۡمٍۖ إِنۡ هُمۡ إِلَّا یَخۡرُصُونَ ۝٢٠﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٩٣٧٦<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿ما لَهُمْ بِذَلِكَ مِن عِلْمٍ﴾</span> يعني: الأوثان، أنهم لا يعلمون، <span class="qpc-hafs">﴿إنْ هُمْ إلّا يَخْرُصُونَ﴾</span> قال: ما يعلمون قُدرة الله على ذلك{5}. (١٣/١٩٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٩٣٧٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: يقول الله تعالى: <span class="qpc-hafs">﴿ما لَهُمْ بِذَلِكَ مِن عِلْمٍ﴾</span> يقول: ما يقولون إلا الكذب: إنّ الملائكة إناث، <span class="qpc-hafs">﴿إنْ هُمْ إلّا يَخْرُصُونَ﴾</span> يكذبون{4}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير مجاهد ص٥٩٣، وأخرجه الفريابي -كما في تغليق التعليق ٤/٣٠٦، وفتح الباري ٨/٥٦٧-، وابن جرير ٢٠/٥٦٨، والبيهقي في الأسماء والصفات (٣٧٨). وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.|2:عزاه السيوطي إلى عبد بن حميد.|3:تفسير الثعلبي ٨/٣٣١، وتفسير البغوي ٧/٢٠٩.|4:تفسير مقاتل بن سليمان ٣/٧٩٢.|5:تفسير مجاهد ص٥٩٣، وأخرجه الفريابي -كما في تغليق التعليق ٤/٣٠٦، وفتح الباري ٨/٥٦٧-، وابن جرير ٢٠/٥٦٩، والبيهقي في الأسماء والصفات (٣٧٨). وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.|6:تفسير مقاتل بن سليمان ٣/٧٩٢.
  43,21,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿أَمۡ ءَاتَیۡنَـٰهُمۡ كِتَـٰبࣰا مِّن قَبۡلِهِۦ فَهُم بِهِۦ مُسۡتَمۡسِكُونَ ۝٢١﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٩٣٧٨<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿أمْ آتَيْناهُمْ﴾</span> يقول: أعطيناهم كتابًا <span class="qpc-hafs">﴿مِن قَبْلِهِ﴾</span> مِن قبل هذا القرآن بأن يعبدوا غيره <span class="qpc-hafs">﴿فَهُمْ بِهِ مُسْتَمْسِكُونَ﴾</span> فإنّا لم نُعطِهم{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٩٣٧٩<span class="dash">-</span></span> عن <span class="name-3">عبد الملك ابن جُريْج</span>، في قوله: <span class="qpc-hafs">﴿أمْ آتَيْناهُمْ كِتابًا مِن قَبْلِهِ﴾</span>، قال: قبل هذا الكتاب{2}. (١٣/١٩٧)</p></p><p></div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٣/٧٩٢.|2:عزاه السيوطي إلى ابن المنذر.
  43,22,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿بَلۡ قَالُوۤا۟ إِنَّا وَجَدۡنَاۤ ءَابَاۤءَنَا عَلَىٰۤ أُمَّةࣲ﴾</span> - نزول الآية</h3></p><p><div></p><p><p><span class="item-no">٦٩٣٨٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿بَلْ قالُوا إنّا وجَدْنا آباءَنا عَلى أُمَّةٍ وإنّا عَلى آثارِهِمْ مُهْتَدُونَ﴾</span> نزلت في الوليد بن المغيرة، وصخر بن حرب، وأبي جهل بن هشام، وعُتبة وشيبة ابني ربيعة، كلهم من قريش{1}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿بَلۡ قَالُوۤا۟ إِنَّا وَجَدۡنَاۤ ءَابَاۤءَنَا عَلَىٰۤ أُمَّةࣲ﴾</span> - تفسير الآية</h3></p><p><div></p><p><p><span class="item-no">٦٩٣٨١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطية العَوفيّ- في قوله: <span class="qpc-hafs">﴿بَلْ قالُوا إنّا وجَدْنا آباءَنا عَلى أُمَّةٍ﴾</span>، قال: وجدنا آباءنا على دين{2}. (١٣/١٩٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٩٣٨٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، أنّ نافع بن الأزرق قال له: أخبِرني عن قوله ﷿: <span class="qpc-hafs">﴿إنّا وجَدْنا آباءَنا عَلى أُمَّةٍ﴾</span>. قال: على مِلّة غير المِلّة التي تدعونا إليها. قال: وهل تعرف العرب ذلك؟ قال: نعم، أما سمعت نابغة بني ذُبْيان وهو يعتذر إلى النُّعمان بن المنذر ويقول:</p><p>حلفتُ فلم أتركْ لنفسك ريبةً وهل يأثمنْ ذو أُمّةٍ وهو طائع؟{3}. (١٣/١٩٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٩٣٨٣<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- قوله: <span class="qpc-hafs">﴿بَلْ قالُوا إنّا وجَدْنا آباءَنا عَلى أُمَّةٍ وإنّا عَلى آثارِهِمْ مُهْتَدُونَ﴾</span>، قال: قد قال ذلك مشركو قريش: إنّا وجدنا آباءنا على دين، وإنّا مُتَّبعوهم على ذلك{4}. (١٣/١٩٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٩٣٨٤<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدّيّ</span> -من طريق أسباط- <span class="qpc-hafs">﴿قالُوا إنّا وجَدْنا آباءَنا عَلى أُمَّةٍ﴾</span>، قال: على دين{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٩٣٨٥<span class="dash">-</span></span> عن <span class="name-2">عاصم</span>، قال: الأُمَّة في القرآن على وجوه: <span class="qpc-hafs">﴿وادَّكَرَ بَعْدَ أُمَّةٍ﴾</span> [يوسف:٤٥]، قال: بعد حين. <span class="qpc-hafs">﴿وجَدَ عَلَيْهِ أُمَّةً مِنَ النّاسِ يَسْقُونَ﴾</span> [القصص: ٢٣]، قال: جماعة من الناس. <span class="qpc-hafs">﴿إنّا وجَدْنا آباءَنا عَلى أُمَّةٍ﴾</span> قال: على دين. ورفَع الألف في كلّها{6}<span class=comment-ref>٥٨٥٠</span>. (١٣/١٩٨)</p></p><p></div></p><p><div><span class=comment-ref>٥٨٥٠</span> قال <u>ابنُ عطية</u> (٧/٥٤٠-٥٤١ بتصرف): «<b>قرأ جمهور الناس</b>: <span class="qpc-hafs">﴿على أمّة﴾</span> بضم الهمزة، وهي بمعنى: الملة والديانة، والآية على هذا تعيّب عليهم التقليد. <b>وقرأ مجاهد</b>: (عَلى إمَّةٍ) بكسر الهمزة، وهي بمعنى: النعمة، فالآية على هذا استمرار في احتجاجهم؛ لأنهم يقولون: وجدنا آباءنا في نعمة من الله وهم يعبدون الأصنام، فذلك دليل رضاه عنهم، وكذلك اهتدينا نحن بذلك على آثارهم».</div></p><p><div></p><p><p><span class="item-no">٦٩٣٨٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿بَلْ قالُوا﴾</span> ولكنهم قالوا: <span class="qpc-hafs">﴿إنّا وجَدْنا آباءَنا عَلى أُمَّةٍ وإنّا عَلى آثارِهِمْ مُهْتَدُونَ﴾</span>{1}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَإِنَّا عَلَىٰۤ ءَاثَـٰرِهِم مُّهۡتَدُونَ ۝٢٢﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٩٣٨٧<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطية العَوفيّ- <span class="qpc-hafs">﴿وإنّا عَلى آثارِهِمْ مُهْتَدُونَ﴾</span>، يقول: ونحن على دينهم{8}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٣/٧٩٢.|2:أخرجه ابن جرير ٢٠/٥٧٠.|3:مسائل نافع (٢٥٥). وعزاه السيوطي إلى الطستي.|4:أخرجه ابن جرير ٢٠/٥٧٠، ٥٧٢. وعزاه السيوطي إلى عبد بن حميد.|5:أخرجه ابن جرير ٢٠/٥٧٠.|6:عزاه السيوطي إلى عبد بن حميد.|7:تفسير مقاتل بن سليمان ٣/٧٩٢.|8:أخرجه ابن جرير ٢٠/٥٧٢.