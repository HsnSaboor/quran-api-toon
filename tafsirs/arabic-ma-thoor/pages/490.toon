tafsir[12]{c,v,t}:
43,11," <q>﴿وَٱلَّذِی نَزَّلَ مِنَ ٱلسَّمَاۤءِ مَاۤءَۢ بِقَدَرࣲ﴾</q> - تفسير ٦٩٣٠٤- قال مقاتل بن سليمان: <q>﴿والَّذِي نَزَّلَ مِنَ السَّماءِ ماءً بِقَدَرٍ﴾</q> وهو المطر{1}٥٨٤٣. (ز) ٥٨٤٣ ذكر ابن عطية (٧/٥٣٥) أن المراد بالماء: المطر بإجماع. <q>﴿وَٱلَّذِی نَزَّلَ مِنَ ٱلسَّمَاۤءِ مَاۤءَۢ بِقَدَرࣲ﴾</q> - آثار متعلقة بالآية ٦٩٣٠٥- عن عبد الله بن عباس -من طريق الحسن بن مسلم- قال: ما عامٌ بأكثر مطرًا مِن عام -أو قال: ماء-، ولكنَّ الله يصرّفه حيث يشاء{2}. (ز) <q>﴿فَأَنشَرۡنَا بِهِۦ بَلۡدَةࣰ مَّیۡتࣰاۚ كَذَ ٰ⁠لِكَ تُخۡرَجُونَ ۝١١﴾</q> - تفسير ٦٩٣٠٦- عن قتادة بن دعامة -من طريق سعيد- <q>﴿والَّذِي نَزَّلَ مِنَ السَّماءِ ماءً بِقَدَرٍ﴾</q>: كما أحيا الله هذه الأرض الميتة بهذا الماء، فكذلك تُبعَثون يوم القيامة{3}. (ز) ٦٩٣٠٧- قال مقاتل بن سليمان: <q>﴿فَأَنْشَرْنا بِهِ بَلْدَةً مَيْتًا﴾</q> يقول: فأحيينا به، يعني: بالماء <q>﴿بَلْدَةً مَيْتًا﴾</q> لا نبْت فيها، فلمّا أصابها الماء أنبتَتْ، <q>﴿كَذَلِكَ﴾</q> يقول: هكذا <q>﴿تُخْرَجُونَ﴾</q> من الأرض بالماء كما يخرج النّبْت{1}. (ز) ",footnotes:1:تفسير مقاتل بن سليمان ٣/٧٩٠.أخرجه يحيى بن سلام -كما في تفسير ابن أبي زمنين ٤/١٧٦-١٧٧-، وأخرجه ابن جرير ١٧/٤٦٨، وابن أبي حاتم ٨/٢٧٠٦، والحاكم ٢/٤٠٣، والبيهقي في سننه ٣/٣٦٣ بنحوه من طريق سعيد بن جُبير، عند تفسير قوله تعالى: <q>﴿ولَقَدْ صَرَّفْناهُ بَيْنَهُمْ لِيَذَّكَّرُوا﴾</q> [الفرقان:٥٠].أخرجه ابن جرير ٢٠/٥٥٥.تفسير مقاتل بن سليمان ٣/٧٩٠.
43,12," <q>﴿وَٱلَّذِی خَلَقَ ٱلۡأَزۡوَ ٰ⁠جَ كُلَّهَا وَجَعَلَ لَكُم مِّنَ ٱلۡفُلۡكِ وَٱلۡأَنۡعَـٰمِ مَا تَرۡكَبُونَ ۝١٢﴾</q> - تفسير ٦٩٣٠٨- عن الحسن البصري: <q>﴿والَّذِي خَلَقَ الأَزْواجَ كُلَّها﴾</q> يعني: الشتاء والصيف، والليل والنهار، والسماء والأرض، وكلّ اثنين، فالواحد منهما زوج{1}. (ز) ٦٩٣٠٩- قال مقاتل بن سليمان: ثم قال: <q>﴿والَّذِي خَلَقَ الأَزْواجَ كُلَّها﴾</q> يعني: الأصناف كلّها <q>﴿وجَعَلَ لَكُمْ مِنَ الفُلْكِ﴾</q> يعني: السُّفن <q>﴿والأَنْعام﴾</q> يعني: الإبل والبقر <q>﴿ما تَرْكَبُونَ﴾</q> يعني: الذي تركبون{2}. (ز) ",footnotes:1:ذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٤/١٧٧-.تفسير مقاتل بن سليمان ٣/٧٩٠.
43,13," <q>﴿لِتَسۡتَوُۥا۟ عَلَىٰ ظُهُورِهِۦ ثُمَّ تَذۡكُرُوا۟ نِعۡمَةَ رَبِّكُمۡ إِذَا ٱسۡتَوَیۡتُمۡ عَلَیۡهِ﴾</q> - تفسير ٦٩٣١٠- عن عائشة، أنّها سمعت النبيَّ ﷺ يقرأ هذه الآية: «<q>﴿وجَعَلَ لَكُمْ مِنَ الفُلْكِ والأَنْعامِ ما تَرْكَبُونَ لِتَسْتَوُوا عَلى ظُهُورِهِ ثُمَّ تَذْكُرُوا نِعْمَةَ رَبِّكُمْ إذا اسْتَوَيْتُمْ عَلَيْهِ﴾</q> أن تقولوا: الحمد لله الذي مَنَّ علينا بمحمد عبده ورسوله. ثم تقولوا: <q>﴿سُبْحانَ الَّذِي سَخَّرَ لَنا هَذا وما كُنّا لَهُ مُقْرِنِينَ﴾</q>»{1}. (١٣/١٨٨) ٦٩٣١١- عن شَهْر بن حَوْشَب، <q>﴿ثُمَّ تَذْكُرُوا نِعْمَةَ رَبِّكُمْ إذا اسْتَوَيْتُمْ عَلَيْهِ﴾</q>، قال: نِعمة الإسلام{2}. (١٣/١٩٠) ٦٩٣١٢- قال مقاتل بن سليمان: <q>﴿لِتَسْتَوُوا﴾</q> يعني: لكي تستووا <q>﴿عَلى ظُهُورِهِ﴾</q>يعني: ذكورًا وإناثًا مِن الإبل، <q>﴿ثُمَّ تَذْكُرُوا نِعْمَةَ رَبِّكُمْ إذا اسْتَوَيْتُمْ عَلَيْهِ﴾</q> على ظهورها، يعني: يقولون: الحمد لله{3}. (ز) ",footnotes:1:عزاه السيوطي إلى ابن مردويه.عزاه السيوطي إلى ابن المنذر.تفسير مقاتل بن سليمان ٣/٧٩٠.
43,14," <q>﴿وَتَقُولُوا۟ سُبۡحَـٰنَ ٱلَّذِی سَخَّرَ لَنَا هَـٰذَا وَمَا كُنَّا لَهُۥ مُقۡرِنِینَ ۝١٣ وَإِنَّاۤ إِلَىٰ رَبِّنَا لَمُنقَلِبُونَ ۝١٤﴾</q> - قراءات ٦٩٣١٣- عن علي بن أبي طالب، أنّه كان يقرأ: (سُبْحانَ مَن سَخَّرَ لَنا هَذا){1}. (١٣/١٩١) <q>﴿وَتَقُولُوا۟ سُبۡحَـٰنَ ٱلَّذِی سَخَّرَ لَنَا هَـٰذَا﴾</q> - تفسير ٦٩٣١٤- عن علي بن ربيعة، قال: رأيتُ عليًّا أُتِي بدابَّة، فلما وضع رِجله في الرِّكاب قال: باسم الله. فلمّا استوى على ظهرها قال: الحمد لله -ثلاثًا-، والله أكبر -ثلاثًا-، <q>﴿سُبْحانَ الَّذِي سَخَّرَ لَنا هَذا وما كُنّا لَهُ مُقْرِنِينَ وإنّا إلى رَبِّنا لَمُنْقَلِبُونَ﴾</q>، سبحانك لا إله إلا أنت، قد ظلمتُ نفسي فاغفر لي ذنوبي، إنه لا يغفر الذُّنوب إلا أنت. ثم ضحك، فقلتُ: مِمَّ ضحكتَ، يا أمير المؤمنين؟ قال: رأيتُ رسول الله ﷺ فعل كما فعلتُ، ثم ضحك، فقلتُ: يا رسول الله، مِمَّ ضحكتَ؟ فقال: «يعجب الرّبُّ مِن عبده إذا قال: ربّ اغفر لي. ويقول: علِم عبدي أنّه لا يغفر الذُّنوب غيري»{2}. (١٣/١٨٨) ٦٩٣١٥- عن عبد الله بن عباس: أنّ رسول الله ﷺ أرْدَفَه على دابّته، فلمّا استوى عليها كبّر ثلاثًا، وسبّح ثلاثًا، وهلّل الله وحمده، ثم ضحك، ثم قال: «ما مِن امرئ مسلم يركب دابّته، فيصنع كما صنعتُ؛ إلا أقبل الله فضحك إليه كما ضحكتُ إليك»{3}. (١٣/١٨٩) ٦٩٣١٦- عن ابن عمر: أنّ رسول الله ﷺ كان إذا استوى على بعيره خارجًا إلى سفَرٍ كبّر ثلاثًا، ثم قال: «<q>﴿سُبْحانَ الَّذِي سَخَّرَ لَنا هَذا وما كُنّا لَهُ مُقْرِنِينَ وإنّا إلى رَبِّنا لَمُنْقَلِبُونَ﴾</q>، اللهم، إنّا نسألك في سَفَرنا هذا البِرَّ والتقوى، ومِن العمل ما ترضى، اللهم، هوِّن علينا سَفَرنا هذا، واطْوِ عنا بُعْدَه، اللهم، أنتَ الصاحب في السّفر، والخليفة في الأهل، اللهم، إنِّي أعوذُ بك مِن وعْثاءِ{4} السّفر، وكآبة المنظر، وسوء المُنقلب في المال والأهل». وإذا رجع قالَهُنَّ وزاد فيهن: «آيبون، تائبون، عابدون، لربنا حامدون»{5}. (١٣/١٨٨) ٦٩٣١٧- عن أبي مِجْلَز، قال: رأى الحسنُ بنُ علي رجلًا يركب دابّة، فقال: <q>﴿سُبْحانَ الَّذِي سَخَّرَ لَنا هَذا وما كُنّا لَهُ مُقْرِنِينَ وإنّا إلى رَبِّنا لَمُنْقَلِبُونَ﴾</q>. قال: أوَبذلك أمرتَ؟! قال: فكيف أقول؟ قال: قل: الحمد لله الذي هدانا للإسلام، الحمد لله الذي مَنَّ علينا بمحمد ﷺ، الحمد لله الذي جعلني في خير أُمّة أُخرجت للناس، ثم تقول: <q>﴿سُبْحانَ الَّذِي سَخَّرَ لَنا هَذا وما كُنّا لَهُ مُقْرِنِينَ﴾</q>{6}٥٨٤٤. (١٣/١٩٠) ٥٨٤٤ ذكر ابنُ عطية (٧/٥٣٦) أن السُّنة للراكب إذا ركب أن يقول: الحمد لله على نعمة الإسلام، أو على النعمة بمحمد ﵄، أو على النعمة في كل حال. وساق هذا الأثر، ثم قال (٧/٥٣٧): «وإن قدّرنا أنّ ذكر النعمة هو بالقلب والتذكير بدأ الراكب بـ<q>﴿سبحان الذي سخر﴾</q>، وهو يرى نعمة الله في ذلك وفي سواه». ٦٩٣١٨- عن إبراهيم النَّخْعي، قال: وضع علْقمة بن قيس رِجله في الغرْز، فقال: بسم الله. فلمّا قعد على ظهرها قال: الحمد لله. فلمّا نهض قال: <q>﴿سُبْحانَ الَّذِي سَخَّرَ لَنا هَذا وما كُنّا لَهُ مُقْرِنِينَ وإنّا إلى رَبِّنا لَمُنْقَلِبُونَ﴾</q>{7}. (ز) ٦٩٣١٩- عَن طاووس بن كيسان -من طريق ابنه- أنّه كان إذ ركب دابَّةً قال: بسم الله، اللهم، هذا من منك، وفضلك علينا، فلك الحمد، ربّنا، <q>﴿سُبْحانَ الَّذِي سَخَّرَ لَنا هَذا وما كُنّا لَهُ مُقْرِنِينَ وإنّا إلى رَبِّنا لَمُنْقَلِبُونَ﴾</q>{8}. (١٣/١٩١) ٦٩٣٢٠- عن قتادة بن دعامة -من طريق سعيد- <q>﴿لِتَسْتَوُوا عَلى ظُهُورِهِ ثُمَّ تَذْكُرُوا نِعْمَةَ رَبِّكُمْ إذا اسْتَوَيْتُمْ عَلَيْهِ﴾</q>: يُعَلّمكم كيف تقولون إذا ركبتم؛ في الفلك تقولون: <q>﴿بِسْمِ اللَّهِ مَجْراها ومُرْساها إنَّ رَبِّي لَغَفُورٌ رَحِيمٌ﴾</q> [هود:٤١]، وإذا ركبتم الإبل قلتم: <q>﴿سُبْحانَ الَّذِي سَخَّرَ لَنا هَذا وما كُنّا لَهُ مُقْرِنِينَ وإنّا إلى رَبِّنا لَمُنْقَلِبُونَ﴾</q>. ويعلّمكم ما تقولون إذا نزلتم مِن الفُلك والأنعام جميعًا، تقولون: اللهم، أنزِلنا مُنزلًا مباركًا وأنت خير المنزلين{9}. (ز) ٦٩٣٢١- قال مقاتل بن سليمان: <q>﴿و﴾</q>لكي <q>﴿تَقُولُوا سُبْحانَ الَّذِي سَخَّرَ لَنا هَذا﴾</q>، يعني: ذلَّل لنا هذا المركب{10}. (ز) <q>﴿وَمَا كُنَّا لَهُۥ مُقۡرِنِینَ ۝١٣ وَإِنَّاۤ إِلَىٰ رَبِّنَا لَمُنقَلِبُونَ ۝١٤﴾</q> - تفسير ٦٩٣٢٢- عن عبد الله بن عباس -من طريق علي- في قوله: <q>﴿وما كُنّا لَهُ مُقْرِنِينَ﴾</q>، قال: مُطيقين{11}. (١٣/١٩٢) ٦٩٣٢٣- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿وما كُنّا لَهُ مُقْرِنِينَ﴾</q>، قال: الإبل، والخيل، والبِغال، والحَمير{12}. (١٣/١٩١) ٦٩٣٢٤- عن قتادة بن دعامة -من طريق سعيد- <q>﴿وما كُنّا لَهُ مُقْرِنِينَ﴾</q>، قال: لا في الأيدي، ولا في القوة{13}. (١٣/١٩٢) ٦٩٣٢٥- عن إسماعيل السُّدّيّ -من طريق أسباط- <q>﴿وما كُنّا لَهُ مُقْرِنِينَ﴾</q>، قال: مُطيقين{14}. (ز) ٦٩٣٢٦- قال مقاتل بن سليمان: <q>﴿وما كُنّا لَهُ مُقْرِنِينَ﴾</q> يعني: مُطيقين، ولكي تقولوا: <q>﴿وإنّا إلى رَبِّنا لَمُنْقَلِبُونَ﴾</q> يعني: لراجعون{10}. (ز) ٦٩٣٢٧- قال عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿سُبْحانَ الَّذِي سَخَّرَ لَنا هَذا وما كُنّا لَهُ مُقْرِنِينَ﴾</q>، قال: لسنا له مُطيقين. قال: لا نطيقها إلا بك، لولا أنت ما قوينا عليها، ولا أطقناها{14}. (ز) <q>﴿وَمَا كُنَّا لَهُۥ مُقۡرِنِینَ ۝١٣ وَإِنَّاۤ إِلَىٰ رَبِّنَا لَمُنقَلِبُونَ ۝١٤﴾</q> - آثار متعلقة بالآية ٦٩٣٢٨- عن محمد بن حمزة بن عمرو الأسلمي، عن أبيه، قال: قال رسول الله ﷺ: «فوق ظهر كلِّ بعير شيطانٌ، فإذا ركبتموه فاذكروا اسم الله، ثم لا تُقصِّروا عن حاجاتكم»{17}. (١٣/١٩٠) ٦٩٣٢٩- عن أبي لاس الخزاعي، عن رسول الله ﷺ، قال: «ما مِن بعير إلا في ذُرْوته شيطان، فاذكروا اسمَ الله عليها إذا ركبتموها كما أمركم، ثم امتهنوها لأنفسكم، فإنما يحملُ اللهُ»{18}. (١٣/١٩٠) ٦٩٣٣٠- عن سليمان بن يسار: أنّ قومًا كانوا في سَفر، فكانوا إذا ركبوا قالوا: <q>﴿سُبْحانَ الَّذِي سَخَّرَ لَنا هَذا وما كُنّا لَهُ مُقْرِنِينَ﴾</q>. وكان فيهم رجل له ناقة رازِمٌ{19}، فقال: أمّا أنا فأنا لهذه مُقْرِنٌ. فقَمَصَتْ{20} به، فصرعتْه، فاندقّت عنقه{21}. (١٣/١٩٢) ٦٩٣٣١- عن عبد الملك، عن عطاء [بن أبي رباح] أنه سُئِل: أيبدأ الرجل بالتلبية، أو يقول: <q>﴿سبحان الذي سخّر لنا هذا وما كنا له مقرنين﴾</q>؟ قال: يبدأ بـ<q>﴿سبحان الذي سخّر لنا هذا﴾</q>{22}. (ز) ",footnotes:1:عزاه السيوطي إلى ابن الأنباري في المصاحف. وهي قراءة شاذة. انظر: الجامع لأحكام القرآن ١٩/١٢.أخرجه أحمد ٢/١٤٨ (٧٥٣)، ٢/٢٤٨ (٩٣٠)، ٢/٣١٤ (١٠٥٦)، وأبو داود ٤/٢٤٣-٢٤٤ (٢٦٠٢)، والترمذي ٦/٦٧-٦٨ (٣٧٤٩)، وابن حبان ٦/٤١٥ (٢٦٩٨)، والحاكم ٢/١٠٨-١٠٩ (٢٤٨٢، ٢٤٨٣)، وعبد الرزاق ٣/١٦٥ (٢٧٥٤). قال الترمذي: «هذا حديث حسن صحيح». وقال الحاكم: «هذا حديث صحيح، على شرط مسلم، ولم يخرجاه».أخرجه أحمد ٥/١٧٦ (٣٠٥٧). قال ابن كثير ٧/٢٢١: «تفرد به أحمد». وقال الهيثمي في المجمع ١٠/١٣١ (١٧٠٩٨): «وفيه أبو بكر بن أبي مريم، وهو ضعيف».أي: شدته ومشقته. النهاية (وعث).أخرجه مسلم ٢/٩٧٨ (١٣٤٢).أخرجه ابن جرير ٢٠/٥٥٨. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه آدم ابن أبي إياس -كما في تفسير مجاهد ص٥٩٢-.أخرجه عبد الرزاق ٢/١٩٥، وابن جرير ٢٠/٥٥٩. وعزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ٢٠/٥٥٨-٥٥٩. وذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٤/١٧٨- بنحوه.تفسير مقاتل بن سليمان ٣/٧٩٠.أخرجه ابن جرير ٢٠/٥٥٩، وابن أبي حاتم -كما في تغليق التعليق ٤/٣٠٦-. وعزاه السيوطي إلى ابن المنذر.تفسير مجاهد ص٥٩٢، وأخرجه ابن جرير ٢٠/٥٥٩-٥٦٠، والأثر عند الفريابي -كما في تغليق التعليق٤/٣٠٦، وفتح الباري ٨/٥٦٧-. وعزاه السيوطي إلى عَبد بن حُمَيد.أخرجه عبد الرزاق ٢/١٩٤ من طريق معمر، وابن جرير ٢٠/٥٦٠ بنحوه كذلك من طريق معمر. وعزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ٢٠/٥٦٠.تفسير مقاتل بن سليمان ٣/٧٩٠.أخرجه ابن جرير ٢٠/٥٦٠.أخرجه أحمد ٢٥/٤٢٦ (١٦٠٣٩)، وابن خزيمة ٤/٢٤٣ (٢٥٤٦)، وابن حبان ٤/٦٠٢-٦٠٣ (١٧٠٣)، ٦/٤١١-٤١٢ (٢٦٩٤)، والحاكم ١/٦١٢ (١٦٢٦). قال الحاكم: «هذا حديث صحيح، على شرط مسلم، ولم يخرجاه، وله شاهد على شرطه». وقال المنذري في الترغيب ٤/٣٨ (٤٧٠٧): «رواه أحمد، والطبراني، وإسنادهما جيد». وقال الهيثمي في المجمع ١٠/١٣١ (١٧٠٩٤): «رواه أحمد، والطبراني في الكبير، والأوسط، ورجالهما رجال الصحيح غير محمد بن حمزة، وهو ثقة». وقال المناوي في التيسير ٢/١٣٤: «وإسناده جيد».أخرجه أحمد ٢٩/٤٥٨-٤٥٩ (١٧٩٣٨-١٧٩٣٩)، وابن خزيمة ٤/٢٤١ (٢٥٤٣)، والحاكم ١/٦١٢ (١٦٢٤). قال الحاكم: «هذا حديث صحيح، على شرط مسلم، ولم يخرجاه، وله شاهد صحيح». وقال الهيثمي في المجمع ١٠/١٣١ (١٧٠٩٣): «رواه أحمد والطبراني بأسانيد، ورجال أحدها رجال الصحيح غير محمد بن إسحاق، وقد صرّح بالسماع في إحداهما». وقال البوصيري في إتحاف الخيرة ٣/١٤٧ (٢٤٠٧): «رواه أبو بكر بن أبي شيبة واللفظ له، وأبو يعلى، والبخاري -حدّث به تعليقًا-، والحاكم، وعنه البيهقي بسند ضعيف؛ لتدليس محمد ابن إسحاق». وقال الألباني في الصحيحة ٥/٣٤٢ (٢٢٧١): «وهذا إسناد حسن، رجاله ثقات، وابن إسحاق وإن كان قد عنعنه فقد صرّح بالتحديث في رواية الحربي».أي: لا تتحرك من الهزال. النهاية (رزم).أي: وثبَت ونفرت فألقته. النهاية (قمص).عزاه السيوطي إلى عَبد بن حُمَيد، وابن المنذر.أخرجه سعيد بن منصور في سننه -التفسير ٧/٢٨٨ (١٩٣٥)، وأخرجه ابن أبي شيبة في مصنفه ٨/٥٢ (١٢٨٩٨) بلفظ: إن شئتَ ففي دبر الصلاة، وإن شئتَ فإذا انبعثت بك الناقة تبدأ حين تركب، فتقول: <q>﴿سبحان الذي سخر لنا هذا وما كنا له مقرنين﴾</q>.
43,15," <q>﴿وَجَعَلُوا۟ لَهُۥ مِنۡ عِبَادِهِۦ جُزۡءًاۚ إِنَّ ٱلۡإِنسَـٰنَ لَكَفُورࣱ مُّبِینٌ ۝١٥﴾</q> - تفسير ٦٩٣٣٢- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿وجَعَلُوا لَهُ مِن عِبادِهِ جُزْءًا﴾</q>، قال: ولَدًا، وبنات من الملائكة{1}. (١٣/١٩٢) ٦٩٣٣٣- قال مجاهد بن جبر: <q>﴿مِن عِبادِهِ جُزْءًا﴾</q>، يعني: الملائكة، حيث جعلوهم بنات الله{2}. (ز) ٦٩٣٣٤- عن قتادة بن دعامة -من طريق سعيد- <q>﴿وجَعَلُوا لَهُ مِن عِبادِهِ جُزْءًا﴾</q>، قال: عِدلًا{3}. (١٣/١٩٢) ٦٩٣٣٥- عن إسماعيل السُّدّيّ -من طريق أسباط- <q>﴿وجَعَلُوا لَهُ مِن عِبادِهِ جُزْءًا﴾</q>، قال: البنات{4}. (ز) ٦٩٣٣٦- عن عطاء الخُراساني -من طريق يونس بن يزيد- في قوله ﷿: <q>﴿وجعلوا له من عباده جزءا﴾</q>، قال: جعلوا له نصيبًا وشريكًا مِن عباده{5}. (ز) ٦٩٣٣٧- قال مقاتل بن سليمان: قوله: <q>﴿وجَعَلُوا لَهُ﴾</q> يقول: وصَفوا له <q>﴿مِن عِبادِهِ﴾</q> من الملائكة <q>﴿جُزْءًا﴾</q> يعني: عِدلًا، هو الولد؛ فقالوا: إنّ الملائكة بنات الله تعالى، يقول الله: <q>﴿إنَّ الإنْسانَ﴾</q> في قوله <q>﴿لَكَفُورٌ مُبِينٌ﴾</q> يقول: بيِّن الكفر{6}٥٨٤٥. (ز) ٥٨٤٥ اختُلف في معنى الجزء على قولين: الأول: أنه النصيب والحظّ، وذلك قولهم للملائكة: هم بنات الله. الثاني: أنه عُني به: العِدْل. ورجَّح ابنُ جرير (٢٠/٥٦١-٥٦٢) -مستندًا إلى السياق- القول الأول الذي قاله مجاهد، والسُّدّيّ، ومقاتل، فقال: «لأن الله -جل ثناؤه- أتبع ذلك قوله: <q>﴿أم اتخذ مما يخلق بنات وأصفاكم بالبنين﴾</q> توبيخًا لهم على قولهم ذلك، فكان معلومًا أنّ توبيخه إيّاهم بذلك إنّما هو عما أخبر عنهم من قيلهم ما قالوا في إضافة البنات إلى الله -جل ثناؤه-». وساق ابنُ عطية (٥/٤٣ ط: دار الكتب العلمية) القول الثاني الذي قاله قتادة، ثم علّق بقوله: «فعلى هذا فتعنيف الكفرة في فصلين: في أمر الأصنام، وفي أمر الملائكة، وعلى هذا التأويل الأول فالآية كلها في أمر الملائكة». وساق ابنُ تيمية (٥/٥١٨-٥١٩) القولين، ثم علَّق بقوله: «وكلا القولين صحيح؛ فإنهم يجعلون له ولدًا، والولد يشبه أباه؛ ولهذا قال: <q>﴿وإذا بُشِّرَ أحَدُهُم بِما ضَرَبَ لِلرَّحْمَنِ مَثَلًا ظَلَّ وجْهُهُ مُسْوَدًّا﴾</q> [الزخرف:١٧] أي: البنات، كما قال في الآية الأخرى: <q>﴿وإذا بُشِّرَ أحَدُهُمْ بِالأُنثى﴾</q> [النحل:٥٨]، فقد جعلوها للرحمن مثلًا، وجعلوا له من عباده جزءًا، فإنّ الولد جزء من الوالد كما تقدم، قال ﷺ: «إنما فاطمة بضعة مني». وقوله: <q>﴿وجَعَلُواْ لِلّهِ شُرَكاء الجِنَّ وخَلَقَهُمْ وخَرَقُواْ لَهُ بَنِينَ وبَناتٍ بِغَيْرِ عِلْمٍ﴾</q> [الأنعام:١٠٠]. قال الكلبي: نزلت في الزنادقة، قالوا: إنّ الله وإبليس شريكان؛ فالله خالق النور والناس والدواب والأنعام، وإبليس خالق الظلمة والسّباع والحيّات والعقارب». ",footnotes:1:تفسير مجاهد ص٥٩٢، وأخرجه ابن جرير ٢٠/٥٦١. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.ذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٤/١٧٩-.أخرجه عبد الرزاق ٢/١٩٥ من طريق معمر، وعبد بن حميد -كما في تغليق التعليق ٤/٣٠٩-، وابن جرير ٢٠/٥٦١ بنحوه، ومن طريق معمر أيضًا. وبعده في حاشية١: «وأخرج عبد بن حميد، وابن جرير، وابن المنذر، عن مجاهد في قوله: <q>﴿وجَعَلُوا لَهُ مِن عِبادِهِ جُزْءًا﴾</q> قال: عِدلًا». وعزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ٢٠/٥٦١.أخرجه أبو جعفر الرملي في جزئه (تفسير عطاء) ص٩١.تفسير مقاتل بن سليمان ٣/٧٩٠.
43,16," <q>﴿أَمِ ٱتَّخَذَ مِمَّا یَخۡلُقُ بَنَاتࣲ وَأَصۡفَىٰكُم بِٱلۡبَنِینَ ۝١٦﴾</q> - تفسير ٦٩٣٣٨- قال مقاتل بن سليمان: يقول الله تعالى ردًّا عليهم: <q>﴿أمِ﴾</q> يقول: <q>﴿اتَّخَذَ﴾</q> الرَّبّ لنفسه <q>﴿مِمّا يَخْلُقُ بَناتٍ﴾</q> فيها تقديم واستفهام، اتخذ مما يخلق مِن <q>﴿مَن يُنَشَّأُ فِي الحِلْيَةِ وهُوَ فِي الخِصامِ غَيْرُ مُبِينٍ﴾</q> بنات <q>﴿وأَصْفاكُمْ بِالبَنِينَ﴾</q> يقول: واختصكم بالبنين{1}. (ز) ",footnotes:1:تفسير مقاتل بن سليمان ٣/٧٩٠-٧٩١.
43,17," <q>﴿وَإِذَا بُشِّرَ أَحَدُهُم بِمَا ضَرَبَ لِلرَّحۡمَـٰنِ مَثَلࣰا ظَلَّ وَجۡهُهُۥ مُسۡوَدࣰّا وَهُوَ كَظِیمٌ ۝١٧﴾</q> - قراءات ٦٩٣٣٩- قرأ عاصم: <q>﴿بِما ضَرَبَ لِلرَّحْمَنِ مَثَلًا﴾</q> بنصب الضاد{1}. (١٣/١٩٣) <q>﴿وَإِذَا بُشِّرَ أَحَدُهُم بِمَا ضَرَبَ لِلرَّحۡمَـٰنِ مَثَلࣰا ظَلَّ وَجۡهُهُۥ مُسۡوَدࣰّا وَهُوَ كَظِیمٌ ۝١٧﴾</q> - تفسير الآية ٦٩٣٤٠- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿وإذا بُشِّرَ أحَدُهُمْ بِما ضَرَبَ لِلرَّحْمَنِ مَثَلًا﴾</q>، قال: ولدًا{2}. (١٣/١٩٢) ٦٩٣٤١- عن قتادة بن دعامة -من طريق سعيد- <q>﴿وإذا بُشِّرَ أحَدُهُمْ بِما ضَرَبَ لِلرَّحْمَنِ مَثَلًا﴾</q> قال: بما جعل لله <q>﴿ظَلَّ وجْهُهُ مُسْوَدًّا وهُوَ كَظِيمٌ﴾</q> قال: حزين{3}. (١٣/١٩٣) ٦٩٣٤٢- قال مقاتل بن سليمان: ثم أخبر عنهم في التقديم، فقال: <q>﴿وإذا بُشِّرَ أحَدُهُمْ بِما ضَرَبَ لِلرَّحْمَنِ مَثَلًا﴾</q> يعني: شبهًا، والمثل -زعموا- أنّ الملائكة بنات الله تعالى. <q>﴿وإذا بُشِّرَ أحَدُهُمْ بِالأُنْثى ظَلَّ وجْهُهُ مُسْوَدًّا﴾</q> يعني: متغيّرًا <q>﴿وهُوَ كَظِيمٌ﴾</q> [النحل:٥٨] يعني: مكروب{4}. (ز) ",footnotes:1:عزاه السيوطي إلى عبد بن حميد. وهي قراءة العشرة.تفسير مجاهد ص٥٩٢، وأخرجه ابن جرير ٢٠/٥٦٢. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه ابن جرير ٢٠/٥٦٣. وعزاه السيوطي إلى عبد بن حميد.تفسير مقاتل بن سليمان ٣/٧٩١.
43,18," <q>﴿أَوَمَن یُنَشَّؤُا۟ فِی ٱلۡحِلۡیَةِ وَهُوَ فِی ٱلۡخِصَامِ غَیۡرُ مُبِینࣲ ۝١٨﴾</q> - قراءات ٦٩٣٤٣- عن عبد الله بن عباس، أنّه كان يقرأ: ‹أوَمَن يَنشَؤُاْ فِي الحِلْيَةِ› مُخفّفًا{1}. (١٣/١٩٤) ٦٩٣٤٤- قرأ عاصم: ‹أوَمَن يَنشَؤُاْ› مخفّفة الياء مهموزة{2}٥٨٤٦. (١٣/١٩٤) ٥٨٤٦ اختُلف في قراءة قوله: <q>﴿أومن ينشأ﴾</q>؛ فقرأ قوم: ‹أوَمَن يَنشَؤُاْ› بفتح الياء والتخفيف. وقرأ آخرون: <q>﴿يُنشّأ﴾</q> بضم الياء وتشديد الشين. وذكر ابنُ جرير (٢٠/٥٦٥-٥٦٦) أنّ الأولى من: نشَأ ينشأ، وأن الثانية من: نشَّأته فهو يُنشّأ. ثم رجَّح (٢٠/٥٦٦) صحة كلتا القراءتين مستندًا إلى شهرتهما، وتقارب معناهما، فقال: «والصواب من القول في ذلك عندنا أن يُقال: إنهما قراءتان معروفتان في قرأة الأمصار، متقاربتا المعنى؛ لأن المُنشّأ من الإنشاء ناشئ، والناشئ مُنشأ، فبأيتهما قرأ القارئ فمصيب». <q>﴿أَوَمَن یُنَشَّؤُا۟ فِی ٱلۡحِلۡیَةِ وَهُوَ فِی ٱلۡخِصَامِ غَیۡرُ مُبِینࣲ ۝١٨﴾</q> - تفسير الآية ٦٩٣٤٥- عن عبد الله بن عباس، <q>﴿أوَمَن يُنَشَّأُ فِي الحِلْيَةِ﴾</q>، قال: هُنّ النساء، فرّق بين زيِّهن وزيِّ الرجال، ونقْصهن من الميراث والشهادة، وأمرهن بالقَعْدة، وسمّاهن الخوالف{2}. (١٣/١٩٣) ٦٩٣٤٦- عن عبد الله بن عباس -من طريق عطية العَوفيّ- قوله: <q>﴿أوَمَن يُنَشَّأُ فِي الحِلْيَةِ وهُوَ فِي الخِصامِ غَيْرُ مُبِينٍ﴾</q>، قال: يعني: المرأة{4}. (ز) ٦٩٣٤٧- عن مجاهد بن جبر -من طريق ابن أبي نجيح- <q>﴿أوَمَن يُنَشَّأُ فِي الحِلْيَةِ﴾</q>، قال: الجواري، جعلتموهن للرحمن ولدًا، فكيف تحكمون؟!{5}. (١٣/١٩٣) ٦٩٣٤٨- عن قتادة بن دعامة -من طريق معمر- في قوله: <q>﴿أوَمَن يُنَشَّأُ فِي الحِلْيَةِ﴾</q> قال: جعلوا لله البنات، وإذا بُشِّر أحدهم بهنَّ <q>﴿ظَلَّ وجْهُهُ مُسْوَدًّا وهُوَ كَظِيمٌ﴾</q> حزين، <q>﴿وهُوَ فِي الخِصامِ غَيْرُ مُبِينٍ﴾</q> قال: قلّما تكلّمت امرأةٌ تريد أن تتكلم بحجّتها إلا تكلّمت بالحُجَّة عليها{6}. (١٣/١٩٣) ٦٩٣٤٩- عن قتادة بن دعامة -من طريق سعيد- قوله: <q>﴿أوَمَن يُنَشَّأُ فِي الحِلْيَةِ وهُوَ فِي الخِصامِ غَيْرُ مُبِينٍ﴾</q> قال: الجواري يُسَفِّههن بذلك، <q>﴿وهُوَ فِي الخِصامِ غَيْرُ مُبِينٍ﴾</q> بضعفهنّ{7}. (ز) ٦٩٣٥٠- عن إسماعيل السُّدّيّ –من طريق أسباط- <q>﴿أوَمَن يُنَشَّأُ فِي الحِلْيَةِ وهُوَ فِي الخِصامِ غَيْرُ مُبِينٍ﴾</q>، قال: النساء{7}. (ز) ٦٩٣٥١- قال مقاتل بن سليمان: <q>﴿أوَمَن يُنَشَّأُ فِي الحِلْيَةِ﴾</q> يعني: ينبتُ في الزينة، يعني: الحلي، مع النساء، يعني: البنات <q>﴿وهُوَ فِي الخِصامِ غَيْرُ مُبِينٍ﴾</q> يقول: هذا الولد الأُنثى ضعيفٌ، قليل الحيلة، وهو عند الخصومة والمحاربة غير بيّن، ضعيف عنها{9}. (ز) ٦٩٣٥٢- قال عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿أوَمَن يُنَشَّأُ فِي الحِلْيَةِ وهُوَ فِي الخِصامِ غَيْرُ مُبِينٍ﴾</q> الآية، قال: هذه تماثيلهم التي يضربونها مِن فِضّة وذهب، يعبدونها، هم الذين أنشأوها، ضربوها مِن تلك الحلية، ثم عبدوها، <q>﴿وهُوَ فِي الخِصامِ غَيْرُ مُبِينٍ﴾</q> قال: لا يتكلّم. وقرأ: <q>﴿فَإذا هُوَ خَصِيمٌ مُبِينٌ﴾</q> [يس:٧٧]{10}. (ز) ٦٩٣٥٣- عن سفيان بن عُيَينة -من طريق ابن أبي عمر- في قوله: <q>﴿أومن ينشأ في الحلية وهو في الخصام غير مبين﴾</q>، قال: هو في النساء{11}٥٨٤٧. (ز) ٥٨٤٧ اختُلف في المراد بـ<q>﴿مَن﴾</q> على قولين: الأول: النساء والجواري. الثاني: الأصنام. ورجَّح ابنُ جرير (٢٠/٥٦٥) -مستندًا إلى السياق- القول الأول الذي قاله ابن عباس، ومجاهد، وقتادة، والسُّدّيّ، ومقاتل، فقال: «لأنّ ذلك عقيب خبر الله عن إضافة المشركين إليه ما يكرهونه لأنفسهم من البنات، وقلّة معرفتهم بحقّه، ونُحلتهم إياه مِن الصفات والنِّحَل، وهو خالقهم ومالكهم ورازقهم، والمنعم عليهم النِّعَم التي عدّدها في أول هذه السورة -ما لا يرضونه لأنفسهم-؛ فإتباع ذلك مِن الكلام ما كان نظيرًا له أشبه وأولى مِن إتباعه ما لم يجْر له ذِكر». <q>﴿أَوَمَن یُنَشَّؤُا۟ فِی ٱلۡحِلۡیَةِ وَهُوَ فِی ٱلۡخِصَامِ غَیۡرُ مُبِینࣲ ۝١٨﴾</q> - من أحكام الآية ٦٩٣٥٤- عن أبي موسى الأشعري، قال: قال رسول الله ﷺ: «الذّهب والحرير حرامٌ على ذكور أمتي، وحِلٌّ لإناثهم»{12}. (ز) ٦٩٣٥٥- عن أبي العالية الرِّياحي، أنّه سُئِل: عن الذّهب للنساء. فقال: لا بأس به، يقول الله: <q>﴿أوَمَن يُنَشَّأُ فِي الحِلْيَةِ﴾</q>{2}. (١٣/١٩٤) ٦٩٣٥٦- عن مجاهد بن جبر -من طريق علقمة بن مرثد- قال: رُخِّص للنساء في الحرير والذّهب. وقرأ: <q>﴿أوَمَن يُنَشَّأُ فِي الحِلْيَةِ وهُوَ فِي الخِصامِ غَيْرُ مُبِين﴾</q>{14}. (ز) ",footnotes:1:عزاه السيوطي إلى عبد بن حميد. وهي قراءة متواترة، قرأ بها العشرة، ما عدا حمزة، والكسائي، وخلفًا العاشر، وحفصًا عن عاصم؛ فإنهم قرؤوا: <q>﴿أوَمَن يُنشَّؤُاْ﴾</q> بضمّ الياء وتشديد الشين. انظر: النشر ٢/٣٦٨، والإتحاف ص٤٩٤.عزاه السيوطي إلى عبد بن حميد.عزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ٢٠/٥٦٣.تفسير مجاهد ص٥٩٣، وأخرجه الفريابي -كما في تغليق التعليق ٤/٣٠٦، وفتح الباري ٨/٥٦٧-، وابن جرير ٢٠/٥٦٤ بنحوه. وعزاه السيوطي إلى عبد بن حميد.أخرجه عبد الرزاق ٢/١٩٥، وابن جرير ٢٠/٥٦٤ بنحوه. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه ابن جرير ٢٠/٥٦٤.أخرجه ابن جرير ٢٠/٥٦٤.تفسير مقاتل بن سليمان ٣/٧٩١.أخرجه ابن جرير ٢٠/٥٦٥.أخرجه إسحاق البستي ص٣١٣.أخرجه أحمد ٣٢/٢٧٦ (١٩٥١٥)، والترمذي ٣/٥١٥ (١٨١٧)، والثعلبي ٨/٣٣٠. قال الترمذي: «حديث حسن صحيح». وقال العراقي في تخريج الإحياء ص٤٤٨: «الظاهر انقطاعه بين سعيد بن أبي هند وأبي موسى، فأدخل أحمد بينهما رجلًا لم يُسَمّ». وقال ابن حجر في الفتح ١٠/٢٩٦: «أعلّه ابن حبان وغيره بالانقطاع». وقال الألباني في إرواء الغليل ١/٣٠٥ (٢٧٧): «صحيح».عزاه السيوطي إلى عبد بن حميد.أخرجه عبد الرزاق ٢/١٩٥ مطولًا، وابن جرير ٢٠/٥٦٤.
43,19," <q>﴿وَجَعَلُوا۟ ٱلۡمَلَـٰۤىِٕكَةَ ٱلَّذِینَ هُمۡ عِبَـٰدُ ٱلرَّحۡمَـٰنِ إِنَـٰثًاۚ﴾</q> - قراءات ٦٩٣٥٧- عن هارون، قال: في قراءة أُبَيّ بن كعب: (وجَعَلُواْ المَلَآئِكَةَ عِندَ الرَّحْمَنِ إناثًا) ليس فيه: <q>﴿الَّذِينَ هُمْ﴾</q>{1}. (١٣/١٩٦) ٦٩٣٥٨- عن هارون: في قراءة ابن مسعود: (وعِبادُ الرَّحْمَنِ{2}).= (ز) ٦٩٣٥٩- وفي قراءة أُبي بن كعب: (عِندَ) معجمة مكتوبة، وليس فيها: <q>﴿الَّذِينَ هُمْ﴾</q> وإذا لم يكن فيها <q>﴿الَّذِينَ هُمْ﴾</q> لم يجز أن يكون (عِندَ){3}. (ز) ٦٩٣٦٠- قرأ عبد الله بن عباس: <q>﴿الَّذِينَ هُمْ عِبادُ الرَّحْمَنِ﴾</q>، كقوله سبحانه: <q>﴿بَلْ عِبادٌ مُكْرَمُونَ﴾</q> [الأنبياء:٢٦]{4}. (ز) ٦٩٣٦١- عن سعيد بن جُبير -من طريق أبي بشر- قال: كنت أقرأ هذا الحرف: ‹الَّذِينَ هُمْ عِندَ الرَّحْمَنِ إناثًا›= (ز) ٦٩٣٦٢- فسألتُ ابنَ عباس، فقال: <q>﴿عِبادُ الرَّحْمَنِ﴾</q>. قلت: فإنّها في مصحفي: ‹عِندَ الرَّحْمَنِ›. قال: فامحُها، واكتبها: <q>﴿عِبادُ الرَّحْمَنِ﴾</q>{5}. (١٣/١٩٥) ٦٩٣٦٣- عن علقمة، أنه قرأ: <q>﴿الَّذِينَ هُمْ عِبادُ الرَّحْمَنِ﴾</q> بالألف والباء، وقال: أتاني رجلٌ اليومَ وددتُ أنه لم يأتني. فقال: كيف تقرأ هذا الحرف: <q>﴿وجَعَلُوا المَلَآئِكَةَ الَّذِينَ هُمْ عِبادُ الرَّحْمَنِ إناثًا﴾</q>؟ فقال: إن أناسًا يقرءون: ‹الَّذِينَ هُمْ عِندَ الرَّحْمَنِ›. فسكتُّ عنه، فقلتُ: اذهب إلى أهلك{6}. (١٣/١٩٥) ٦٩٣٦٤- عن الحسن البصري، أنّه قرأها: ‹المَلَآئِكَةَ الَّذِينَ هُمْ عِندَ الرَّحْمَنِ› بالنون{6}. (١٣/١٩٥) ٦٩٣٦٥- عن عاصم، أنّه قرأ: <q>﴿عِبادُ الرَّحْمَنِ﴾</q> بالألف والباء{6}٥٨٤٨. (١٣/١٩٦) ٥٨٤٨ اختُلف في قراءة قوله: <q>﴿الذين هم عباد الرحمن﴾</q>؛ فقرأ قوم: ‹الَّذِينَ هُمْ عِندَ الرَّحْمَنِ›، وقرأ غيرهم: <q>﴿الَّذِينَ هُمْ عِبادُ الرَّحْمَنِ﴾</q>. وذكر ابنُ جرير (٢٠/٥٦٦-٥٦٧) أنّ من قرأوا بالنون كأنهم تأولوا في ذلك قول الله -جل ثناؤه-: <q>﴿إن الذين عند ربك لا يستكبرون﴾</q> [الأعراف:٢٠٦]، وأن تفسير الكلام على هذه القراءة: وجعلوا ملائكة الله الذين هم عنده يسبّحونه إناثًا، فقالوا: هم بنات الله جهلًا منهم بحقِّ الله، وجرأة منهم على قيل الكذب والباطل، وأن القراءة الثانية بمعنى: جمع عبْد، وأنّ معنى الكلام عليها: وجعلوا ملائكة الله الذين هم خلْقه وعباده بنات الله، فأنّثوهم بوصفهم إياهم بأنهم إناث. وذكر ابنُ عطية (٧/٥٣٩) أن القراءة الأولى أدلُّ على رفع المنزلة وقُربها في التكرمة، كما قيل: مَلَك مقرّب. ورجَّح ابنُ جرير (٢٠/٥٦٧) صحة كلتا القراءتين مستندًا إلى شهرتهما، وصحة معناهما، فقال: «والصواب من القول في ذلك عندي أنهما قراءتان معروفتان في قراءة الأمصار صحيحتا المعنى، فبأيتهما قرأ القارئ فمصيب، وذلك أن الملائكة عباد الله، وعنده». وعلَّق ابنُ عطية (٧/٥٣٩) عليهما بقوله: «وقد تصرّف المعنيان في كتاب الله تعالى في وصف الملائكة في غير هذه الآية، فقال تعالى: <q>﴿بل عباد مكرمون﴾</q> [الأنبياء:٢٦]، وقال سبحانه في أخرى: <q>﴿فالذين عند ربك﴾</q> [فصلت:٣٨]». <q>﴿وَجَعَلُوا۟ ٱلۡمَلَـٰۤىِٕكَةَ ٱلَّذِینَ هُمۡ عِبَـٰدُ ٱلرَّحۡمَـٰنِ إِنَـٰثًاۚ﴾</q> - تفسير الآية ٦٩٣٦٦- عن قتادة بن دعامة، <q>﴿وجَعَلُوا المَلائِكَةَ الَّذِينَ هُمْ عِبادُ الرَّحْمَنِ إناثًا﴾</q>، قال: قد قال ذلك أناسٌ مِن الناس، ولا نعلمهم إلا اليهود: إنّ الله ﷿ صاهَرَ الجن، فخرجت مِن بيْنهم الملائكة{9}. (١٣/١٩٤) ٦٩٣٦٧- قال إسماعيل السُّدّيّ: <q>﴿وجَعَلُوا المَلائِكَةَ﴾</q>، يعني: وصَفوا{10}. (ز) ٦٩٣٦٨- قال مقاتل بن سليمان: ثم أخبر عنهم، فقال: <q>﴿وجَعَلُوا﴾</q> يقول: ووصفوا <q>﴿المَلائِكَةَ الَّذِينَ هُمْ عِبادُ الرَّحْمَنِ إناثًا﴾</q> لقولهم: إنّ الملائكة بنات الله{11}. (ز) <q>﴿أَشَهِدُوا۟ خَلۡقَهُمۡۚ سَتُكۡتَبُ شَهَـٰدَتُهُمۡ وَیُسۡـَٔلُونَ ۝١٩﴾</q> - قراءات ٦٩٣٦٩- قرأ عاصم: <q>﴿أشَهِدُواْ خَلْقَهُمْ﴾</q> بنصب الألف والشين، <q>﴿سَتُكْتَبُ شَهادَتُهُمْ﴾</q> بالتاء، ورفع التاء{12}٥٨٤٩. (١٣/١٩٦) ٥٨٤٩ اختُلف في قراءة قوله: <q>﴿أشهدوا خلقهم﴾</q>؛ فقرأ قوم: ‹أُشْهِدُوا› بضم الألف. وقرأ آخرون: <q>﴿أشهدوا﴾</q> بفتح الألف. وذكر ابنُ جرير (٢٠/٥٦٧) أن الأولى على وجه ما لم يُسم فاعله، بمعنى: أأْشْهَد الله هؤلاء المشركين الجاعلين ملائكة الله إناثًا خلق ملائكته الذين هم عنده، فعلموا ما هم، وأنهم إناث، فوصفوهم بذلك؛ لعلمهم بهم، وبرؤيتهم إياهم؟! ثم ردّ ذلك إلى ما لم يُسمّ فاعله، وأن القراءة الثانية بمعنى: أشهدوا هم ذلك فعلموه؟! ثم رجَّح صحة كلتا القراءتين مستندًا إلى شهرتهما، فقال: «والصواب من القول في ذلك عندي أنهما قراءتان معروفتان، فبأيتهما قرأ القارئ فمصيب». <q>﴿أَشَهِدُوا۟ خَلۡقَهُمۡۚ سَتُكۡتَبُ شَهَـٰدَتُهُمۡ وَیُسۡـَٔلُونَ ۝١٩﴾</q> - نزول الآية، وتفسيرها ٦٩٣٧٠- قال محمد بن السِّائِب الكلبي: لَمّا قالوا هذا القولَ سألهم النبيُّ ﷺ، فقال: «ما يدريكم أنهم إناث؟». قالوا: سمعنا مِن آبائنا، ونحن نشهد أنهم لم يكذبوا. فقال الله تعالى: <q>﴿سَتُكْتَبُ شَهادَتُهُمْ ويُسْأَلُونَ﴾</q> عنها في الآخرة{13}. (ز) ٦٩٣٧١- قال مقاتل بن سليمان: يقولُ الله تعالى للنبي ﷺ: <q>﴿أشَهِدُوا خَلْقَهُمْ﴾</q>. فسُئلوا، فقالوا: لا. فقال النبي ﷺ: «ما يدريكم أنهم إناث؟». قالوا: سمعنا من آبائنا، وشهدوا أنهم لم يكذبوا، وأنهم إناث. قال الله تعالى: <q>﴿سَتُكْتَبُ شَهادَتُهُمْ﴾</q> بأنّ الملائكة بنات الله في الدنيا، <q>﴿ويُسْأَلُونَ﴾</q> عنهما في الآخرة، حين شهدوا أنّ الملائكة بنات الله{11}. (ز) ",footnotes:1:أخرجه أبو عبيد ص١٨٣. وعزاه السيوطي إلى ابن المنذر. وهي قراءة شاذة. انظر: المحرر الوجيز ٥/٤٩.كذا في المصدر بالواو ولعلها مدرجة.أخرجه إسحاق البستي ص٣١٤.ذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٤/١٨٠-. وهي قراءة متواترة، قرأ بها عاصم، وحمزة، والكسائي، وخلف العاشر، وأبو عمرو، وقرأ بقية العشرة: ‹عِندَ الرَّحْمَنِ›. انظر: النشر ٢/٣٦٨، والإتحاف ص٤٩٤-٤٩٥.أخرجه الحاكم ٢/٤٤٦-٤٤٧. وعزاه السيوطي إلى سعيد بن منصور، وعَبد بن حُمَيد، وابن المنذر، وابن أبي حاتم. وأخرجه إسحاق البستي ص٣١٣ من قراءة سعيد.عزاه السيوطي إلى عبد بن حميد.عزاه السيوطي إلى عبد بن حميد.عزاه السيوطي إلى عبد بن حميد.عزاه السيوطي إلى عَبد بن حُمَيد، وابن المنذر.ذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٤/١٨٠-.تفسير مقاتل بن سليمان ٣/٧٩١.عزاه السيوطي إلى عبد بن حميد. وهي قراءة العشرة، ما عدا نافعًا، وأبا جعفر؛ فإنهما قرآ: ‹أأُشْهِدُواْ› بهمزتين. انظر: النشر ٢/٣٦٨، والإتحاف ص٤٩٥.تفسير البغوي ٧/٢٠٩.تفسير مقاتل بن سليمان ٣/٧٩١.
43,20," <q>﴿وَقَالُوا۟ لَوۡ شَاۤءَ ٱلرَّحۡمَـٰنُ مَا عَبَدۡنَـٰهُمۗ﴾</q> - تفسير ٦٩٣٧٢- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿وقالُوا لَوْ شاءَ الرَّحْمَنُ ما عَبَدْناهُمْ﴾</q>، قال: يعنون الأوثان؛ لأنهم عبدوا الأوثان{1}. (١٣/١٩٦) ٦٩٣٧٣- عن قتادة بن دعامة، <q>﴿وقالُوا لَوْ شاءَ الرَّحْمَنُ ما عَبَدْناهُمْ﴾</q>، قال: عبدوا الملائكة{2}. (١٣/١٩٦) ٦٩٣٧٤- قال محمد بن السّائِب الكلبي: <q>﴿وقالُوا لَوْ شاءَ الرَّحْمَنُ ما عَبَدْناهُمْ﴾</q>، يعني: الملائكة{3}. (ز) ٦٩٣٧٥- قال مقاتل بن سليمان: <q>﴿وقالُوا لَوْ شاءَ الرَّحْمَنُ ما عَبَدْناهُمْ﴾</q>، يعني: الملائكة{4}. (ز) <q>﴿مَّا لَهُم بِذَ ٰ⁠لِكَ مِنۡ عِلۡمٍۖ إِنۡ هُمۡ إِلَّا یَخۡرُصُونَ ۝٢٠﴾</q> - تفسير ٦٩٣٧٦- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿ما لَهُمْ بِذَلِكَ مِن عِلْمٍ﴾</q> يعني: الأوثان، أنهم لا يعلمون، <q>﴿إنْ هُمْ إلّا يَخْرُصُونَ﴾</q> قال: ما يعلمون قُدرة الله على ذلك{5}. (١٣/١٩٦) ٦٩٣٧٧- قال مقاتل بن سليمان: يقول الله تعالى: <q>﴿ما لَهُمْ بِذَلِكَ مِن عِلْمٍ﴾</q> يقول: ما يقولون إلا الكذب: إنّ الملائكة إناث، <q>﴿إنْ هُمْ إلّا يَخْرُصُونَ﴾</q> يكذبون{4}. (ز) ",footnotes:1:تفسير مجاهد ص٥٩٣، وأخرجه الفريابي -كما في تغليق التعليق ٤/٣٠٦، وفتح الباري ٨/٥٦٧-، وابن جرير ٢٠/٥٦٨، والبيهقي في الأسماء والصفات (٣٧٨). وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.عزاه السيوطي إلى عبد بن حميد.تفسير الثعلبي ٨/٣٣١، وتفسير البغوي ٧/٢٠٩.تفسير مقاتل بن سليمان ٣/٧٩٢.تفسير مجاهد ص٥٩٣، وأخرجه الفريابي -كما في تغليق التعليق ٤/٣٠٦، وفتح الباري ٨/٥٦٧-، وابن جرير ٢٠/٥٦٩، والبيهقي في الأسماء والصفات (٣٧٨). وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.تفسير مقاتل بن سليمان ٣/٧٩٢.
43,21," <q>﴿أَمۡ ءَاتَیۡنَـٰهُمۡ كِتَـٰبࣰا مِّن قَبۡلِهِۦ فَهُم بِهِۦ مُسۡتَمۡسِكُونَ ۝٢١﴾</q> - تفسير ٦٩٣٧٨- قال مقاتل بن سليمان: <q>﴿أمْ آتَيْناهُمْ﴾</q> يقول: أعطيناهم كتابًا <q>﴿مِن قَبْلِهِ﴾</q> مِن قبل هذا القرآن بأن يعبدوا غيره <q>﴿فَهُمْ بِهِ مُسْتَمْسِكُونَ﴾</q> فإنّا لم نُعطِهم{1}. (ز) ٦٩٣٧٩- عن عبد الملك ابن جُريْج، في قوله: <q>﴿أمْ آتَيْناهُمْ كِتابًا مِن قَبْلِهِ﴾</q>، قال: قبل هذا الكتاب{2}. (١٣/١٩٧) ",footnotes:1:تفسير مقاتل بن سليمان ٣/٧٩٢.عزاه السيوطي إلى ابن المنذر.
43,22," <q>﴿بَلۡ قَالُوۤا۟ إِنَّا وَجَدۡنَاۤ ءَابَاۤءَنَا عَلَىٰۤ أُمَّةࣲ﴾</q> - نزول الآية ٦٩٣٨٠- قال مقاتل بن سليمان: <q>﴿بَلْ قالُوا إنّا وجَدْنا آباءَنا عَلى أُمَّةٍ وإنّا عَلى آثارِهِمْ مُهْتَدُونَ﴾</q> نزلت في الوليد بن المغيرة، وصخر بن حرب، وأبي جهل بن هشام، وعُتبة وشيبة ابني ربيعة، كلهم من قريش{1}. (ز) <q>﴿بَلۡ قَالُوۤا۟ إِنَّا وَجَدۡنَاۤ ءَابَاۤءَنَا عَلَىٰۤ أُمَّةࣲ﴾</q> - تفسير الآية ٦٩٣٨١- عن عبد الله بن عباس -من طريق عطية العَوفيّ- في قوله: <q>﴿بَلْ قالُوا إنّا وجَدْنا آباءَنا عَلى أُمَّةٍ﴾</q>، قال: وجدنا آباءنا على دين{2}. (١٣/١٩٧) ٦٩٣٨٢- عن عبد الله بن عباس، أنّ نافع بن الأزرق قال له: أخبِرني عن قوله ﷿: <q>﴿إنّا وجَدْنا آباءَنا عَلى أُمَّةٍ﴾</q>. قال: على مِلّة غير المِلّة التي تدعونا إليها. قال: وهل تعرف العرب ذلك؟ قال: نعم، أما سمعت نابغة بني ذُبْيان وهو يعتذر إلى النُّعمان بن المنذر ويقول: حلفتُ فلم أتركْ لنفسك ريبةً وهل يأثمنْ ذو أُمّةٍ وهو طائع؟{3}. (١٣/١٩٧) ٦٩٣٨٣- عن قتادة بن دعامة -من طريق سعيد- قوله: <q>﴿بَلْ قالُوا إنّا وجَدْنا آباءَنا عَلى أُمَّةٍ وإنّا عَلى آثارِهِمْ مُهْتَدُونَ﴾</q>، قال: قد قال ذلك مشركو قريش: إنّا وجدنا آباءنا على دين، وإنّا مُتَّبعوهم على ذلك{4}. (١٣/١٩٧) ٦٩٣٨٤- عن إسماعيل السُّدّيّ -من طريق أسباط- <q>﴿قالُوا إنّا وجَدْنا آباءَنا عَلى أُمَّةٍ﴾</q>، قال: على دين{2}. (ز) ٦٩٣٨٥- عن عاصم، قال: الأُمَّة في القرآن على وجوه: <q>﴿وادَّكَرَ بَعْدَ أُمَّةٍ﴾</q> [يوسف:٤٥]، قال: بعد حين. <q>﴿وجَدَ عَلَيْهِ أُمَّةً مِنَ النّاسِ يَسْقُونَ﴾</q> [القصص: ٢٣]، قال: جماعة من الناس. <q>﴿إنّا وجَدْنا آباءَنا عَلى أُمَّةٍ﴾</q> قال: على دين. ورفَع الألف في كلّها{6}٥٨٥٠. (١٣/١٩٨) ٥٨٥٠ قال ابنُ عطية (٧/٥٤٠-٥٤١ بتصرف): «قرأ جمهور الناس: <q>﴿على أمّة﴾</q> بضم الهمزة، وهي بمعنى: الملة والديانة، والآية على هذا تعيّب عليهم التقليد. وقرأ مجاهد: (عَلى إمَّةٍ) بكسر الهمزة، وهي بمعنى: النعمة، فالآية على هذا استمرار في احتجاجهم؛ لأنهم يقولون: وجدنا آباءنا في نعمة من الله وهم يعبدون الأصنام، فذلك دليل رضاه عنهم، وكذلك اهتدينا نحن بذلك على آثارهم». ٦٩٣٨٦- قال مقاتل بن سليمان: <q>﴿بَلْ قالُوا﴾</q> ولكنهم قالوا: <q>﴿إنّا وجَدْنا آباءَنا عَلى أُمَّةٍ وإنّا عَلى آثارِهِمْ مُهْتَدُونَ﴾</q>{1}. (ز) <q>﴿وَإِنَّا عَلَىٰۤ ءَاثَـٰرِهِم مُّهۡتَدُونَ ۝٢٢﴾</q> - تفسير ٦٩٣٨٧- عن عبد الله بن عباس -من طريق عطية العَوفيّ- <q>﴿وإنّا عَلى آثارِهِمْ مُهْتَدُونَ﴾</q>، يقول: ونحن على دينهم{8}. (ز) ",footnotes:1:تفسير مقاتل بن سليمان ٣/٧٩٢.أخرجه ابن جرير ٢٠/٥٧٠.مسائل نافع (٢٥٥). وعزاه السيوطي إلى الطستي.أخرجه ابن جرير ٢٠/٥٧٠، ٥٧٢. وعزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ٢٠/٥٧٠.عزاه السيوطي إلى عبد بن حميد.تفسير مقاتل بن سليمان ٣/٧٩٢.أخرجه ابن جرير ٢٠/٥٧٢.
