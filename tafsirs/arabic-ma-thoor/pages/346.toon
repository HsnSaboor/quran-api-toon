quran[15]{c,v,t}:
  23,60,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَٱلَّذِینَ یُؤۡتُونَ مَاۤ ءَاتَوا۟ وَّقُلُوبُهُمۡ وَجِلَةٌ أَنَّهُمۡ إِلَىٰ رَبِّهِمۡ رَ ٰ⁠جِعُونَ ۝٦٠﴾</span> - قراءات</h3></p><p><div></p><p><p><span class="item-no">٥١٧٦٧<span class="dash">-</span></span> عن عائشة، عن النبي ﷺ أنّه قرأ: (<b>والَّذِينَ يَأْتُونَ مَآ أتَوْاْ</b>) مقصور، مِن المجيء{1}. (١٠/٦٠٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥١٧٦٨<span class="dash">-</span></span> عن عبيد بن عمير أنّه سأل عائشة: كيف كان رسول الله ﷺ يقرأ هذه الآية: <span class="qpc-hafs">﴿والَّذِينَ يُؤْتُونَ مَآ آتَوْا﴾</span> أو: (والَّذِينَ يَأْتُونَ مَآ أتَوْاْ)؟ فقالت: أيتهما أحبُّ اليك؟ قلت: والذي نفسي بيده، لإحداهما أحبُّ إلَيَّ مِن الدنيا جميعًا. قالت: أيتهما؟ قلت: (والَّذِينَ يَأْتُونَ مَآ أتَوْاْ). فقالت: أشهد أنّ رسول الله ﷺ كذلك كان يقرأها، وكذلك أُنزِلت، ولكن الهجاء حُرِّفَ{2}. (١٠/٦٠٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥١٧٦٩<span class="dash">-</span></span> عن ابن أبي مليكة، قال: قالت <span class="name-1">عائشة</span>: لَأن تكون هذه الآيةُ كما أقرأ أحَبُّ إلَيَّ مِن حُمُر النَّعَم. فقال لها ابن عباس: ما هي؟ قالت: <span class="qpc-hafs">﴿والَّذِينَ يُؤْتُونَ مَآ آتَوْا﴾</span>{3}. (١٠/٦٠٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥١٧٧٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥١٧٧١<span class="dash">-</span></span> و<span class="name-1">عائشة</span> -من طريق عبد الله بن أبي مليكة- أنهما كانا يقرآن هذا الحرف: (والَّذِينَ يُؤْتُونَ{4} مَآ أتَوْاْ)، خفيفة بغير مد، أي: يعملون ما عملوا مِمّا نُهُوا عنه، <span class="qpc-hafs">﴿وقُلُوبُهُمْ وجِلَةٌ﴾</span> خائفة أن يُؤخَذوا به{5}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَٱلَّذِینَ یُؤۡتُونَ مَاۤ ءَاتَوا۟ وَّقُلُوبُهُمۡ وَجِلَةٌ أَنَّهُمۡ إِلَىٰ رَبِّهِمۡ رَ ٰ⁠جِعُونَ ۝٦٠﴾</span> - تفسير الآية</h3></p><p><div></p><p><p><span class="item-no">٥١٧٧٢<span class="dash">-</span></span> عن عائشة، قالت: قلت: يا رسول الله، قولُ الله: <span class="qpc-hafs">﴿والذين يؤتون ما آتوا وقلوبهم وجلة﴾</span>، أهو الرجل يسرق ويزني ويشرب الخمر، وهو مع ذلك يخاف الله؟ قال: «<b>لا، ولكن الرجل يصوم ويتصدق ويصلي، وهو مع ذلك يخاف الله ألا يُتَقَبَّل منه</b>»{6}. (١٠/٥٩٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥١٧٧٣<span class="dash">-</span></span> عن أبي هريرة، قال: قالت عائشة: يا رسول الله، <span class="qpc-hafs">﴿والذين يؤتون ما آتوا وقلوبهم وجلة﴾</span>، أهم الذين يُخْطِئون ويعملون بالمعاصي؟ -وفي لفظ: هو الذي يُذنِب الذنبَ وهو وجِلٌ منه؟-. قال: «<b>لا، ولكن هم الذين يُصَلُّون، ويصومون، ويتصدقون، وقلوبهم وجلة</b>»{7}. (١٠/٦٠٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥١٧٧٤<span class="dash">-</span></span> عن <span class="name-1">عائشة</span> -من طريق أبي جعفر الأشجعي- <span class="qpc-hafs">﴿والذين يؤتون ما آتوا﴾</span>، قالت: هم الذين يخشون الله ويطيعونه{8}. (١٠/٦٠١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥١٧٧٥<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق مجاهد- في قوله: <span class="qpc-hafs">﴿والذين يؤتون ما آتوا﴾</span>، قال: يُعْطُون ما أعْطَوْا{9}. (١٠/٦٠٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥١٧٧٦<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، في قوله: <span class="qpc-hafs">﴿والذين يؤتون ما آتوا﴾</span>، قال: يتَصَدَّقون، ويُنفِقون{10}. (١٠/٦٠٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥١٧٧٧<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- في قوله: <span class="qpc-hafs">﴿والذين يؤتون ما آتوا وقلوبهم وجلة﴾</span>، قال: يعملون خائفين{11}. (١٠/٦٠٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥١٧٧٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق العوفي- قوله: <span class="qpc-hafs">﴿والذين يؤتون ما آتوا وقلوبهم وجلة﴾</span> يقول: خائفة؛ <span class="qpc-hafs">﴿أنهم إلى ربهم راجعون﴾</span> قال: هو المؤمن يَتَصَدَّق ويُنفِق، ويعلم أنّه راجِعٌ إلى رَبِّه{12}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥١٧٧٩<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عمر</span> -من طريق ابن أبْجر، عن رجل- في قوله: <span class="qpc-hafs">﴿والذين يؤتون ما آتوا﴾</span>، قال: الزكاة{13}. (١٠/٦٠١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥١٧٨٠<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span>، <span class="qpc-hafs">﴿والذين يؤتون ما آتوا﴾</span> قال: يعطون ما أعطوا <span class="qpc-hafs">﴿وقلوبهم وجلة﴾</span> قال: مِمّا يخافون مِمّا بين أيديهم مِن الموقف، وسوء الحساب{14}. (١٠/٦٠١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥١٧٨١<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span> -من طريق سالم الأفطس- في قوله: <span class="qpc-hafs">﴿والذين يؤتون ما آتوا وقلوبهم وجلة﴾</span>، قال: يفعلون ما يفعلون وهم يعلمون أنّهم صائِرون إلى الموت، وهي مِن المُبَشِّرات{15}<span class=comment-ref>٤٥٤٩</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٤٥٤٩</span> خصَّص بعضُ المفسرين الإيتاء بالمال، وأفاد قولُ ابن عباس، وسعيدُ بن جبير عمومَ معنى الإيتاء في المال وغيره.</p><p>و<span class="comment-type-4">علَّق</span> <u>ابنُ عطية</u> (٦/٣٠٣) على قولهما بقوله: «وهذا حسن، كأنه قال: والذين يعطون من أنفسهم في طاعة الله ما بلغه جهدهم». ثم ذكر قراءةً أخرى، وهي: (يَأْتُونَ ما أتَوْا)، من الإتيان، بمعنى: يفعلون ما فعلوا، ونقل <b>عن فرقةٍ</b> بأن معناه: يفعلون ما فعلوا من المعاصي. ونقل <b>عن فرقةٍ أخرى</b>: بأن ذلك في جميع الأعمال طاعتها ومعصيتها. و<span class="comment-type-4">علَّق</span> على هذا القول بقوله: «وهذا أمدح». ثم ذكر حديث عائشة ﵂، <span class="comment-type-3">ورجَّحه</span> <span class="mustanad">مستندًا إليه</span> قائلًا: «ولا نظر مع الحديث».</div></p><p><div></p><p><p><span class="item-no">٥١٧٨٢<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق أبي يحيى- <span class="qpc-hafs">﴿والذين يؤتون ما آتوا﴾</span> قال: يُعْطُون ما أعْطَوا <span class="qpc-hafs">﴿وقلوبهم وجلة﴾</span> قال: المؤمن ينفق مالَه، وقلبُه وجِلٌ{16}<span class=comment-ref>٤٥٥٠</span>. (١٠/٦٠١)</p></p><p></div></p><p><div><span class=comment-ref>٤٥٥٠</span> <span class="comment-type-1">وجَّه</span> <u>ابنُ عطية</u> (٦/٣٠٣) قول ابن عمر، ومجاهد ومَن وافقهما في تخصيص الإيتاء بالمال بقوله: «وإنّما ضَمَّهم إلى هذا التخصيص أنّ العطاء مستعمل في المال على الأغلب».</div></p><p><div></p><p><p><span class="item-no">٥١٧٨٣<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق أبي يحيى- قال: يعملون ما عمِلوا من الخير، وهم يخافون ألّا يُقبَل منهم{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥١٧٨٤<span class="dash">-</span></span> عن <span class="name-2">الضَّحّاك بن مُزاحِم</span> -من طريق عبيد- في قوله: <span class="qpc-hafs">﴿يؤتون ما آتوا﴾</span>، قال: يُنفِقون ما أنفقوا{18}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥١٧٨٥<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span> -من طريق يزيد النحوي- <span class="qpc-hafs">﴿يؤتون ما آتوا﴾</span> قال: يُعْطُون ما أعْطَوا <span class="qpc-hafs">﴿وقلوبهم وجلة﴾</span> يقول: خائفة{19}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥١٧٨٦<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق يونس- قال: إنّ المؤمن جَمَع إحسانًا وشفقة، وإنّ المنافق جمع إساءة وأَمْنًا. ثم تلا: <span class="qpc-hafs">﴿ان الذين هم من خشية ربهم مشفقون﴾</span> إلى قوله: <span class="qpc-hafs">﴿أنهم إلى ربهم راجعون﴾</span>، وقال المنافق: <span class="qpc-hafs">﴿إنما أوتيته على علم عندي﴾</span> [القصص:٧١]{20}. (١٠/٥٩٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥١٧٨٧<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥١٧٨٨<span class="dash">-</span></span> و<span class="name-2">قتادة بن دعامة</span> -من طريق مَعْمَر- أنّهما كانا يقرآن: <span class="qpc-hafs">﴿يؤتون ما آتوا﴾</span>، قال: يعملون ما عمِلوا من الخيرات، ويُعْطُون ما أعْطَوْا على خوفٍ مِن الله ﷿{21}. (١٠/٦٠١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥١٧٨٩<span class="dash">-</span></span> عن الصَّلت السرّاج، قال: سمعتُ <span class="name-2">الحسن البصري</span> يقول: (يَأْتُون ما أتوا)، يصوم، ويصلي، ولا يزيده ذلك إلا خوفًا، والمنافق يعمل السوء ويَتَمَنّى على الله{22}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥١٧٩٠<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق أبي الأشهب- <span class="qpc-hafs">﴿والذين يؤتون ما آتوا وقلوبهم وجلة﴾</span>، قال: كانوا يعملون ما يعملون مِن أعمال البِرِّ، وهم يخافون أن لا ينجيهم ذلك مِن عذاب ربهم{23}<span class=comment-ref>٤٥٥١</span>. (١٠/٦٠١)</p></p><p></div></p><p><div><span class=comment-ref>٤٥٥١</span> <span class="comment-type-4">علَّق</span> <u>ابنُ عطية</u> (٦/٣٠٥) على قول الحسن بقوله: «وهذه عبارة حسنة».</div></p><p><div></p><p><p><span class="item-no">٥١٧٩١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿والذين يؤتون ما آتوا﴾</span> يعني: يعطون ما أعطوا مِن الصدقات والخيرات، <span class="qpc-hafs">﴿وقلوبهم وجلة﴾</span> يعني: خائفة لله مِن عذابه، يعلمون <span class="qpc-hafs">﴿أنهم إلى ربهم راجعون﴾</span> في الآخرة، فيعملون على عِلْم، فيجزيهم بأعمالهم، فكذلك المؤمن ينفق ويتصدق وجِلًا مِن خشية الله ﷿{24}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥١٧٩٢<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- <span class="qpc-hafs">﴿يؤتون ما آتوا وقلوبهم وجلة﴾</span>، قال: يُعْطُون ما أعْطَوا، ويُنفِقون ما أنفقوا، ويَتَصَدَّقون بما تَصَدَّقوا، وقلوبهم وجِلة، اتقاءً لسَخَط الله والنار. وفي لفظ: يعطون ما أعطوا فَرَقًا مِن الله، ووَجَلًا مِن الله{18}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥١٧٩٣<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿وقوبهم وجلة﴾</span>: خائفة{26}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه الثعلبي ٧/٥٠. وعزاه السيوطي إلى سعيد بن منصور، وابن مردويه.</p><p>وهي قراءة شاذة، تروى أيضًا عن عائشة، وابن عباس ﵃، وقتادة، والأعمش. انظر: مختصر ابن خالويه ص١٠٠، والمحتسب ٢/٩٥.أخرجه أحمد ٤١/١٨٥ (٢٤٦٤١)، ٤٢/٥١-٥٢ (٢٥١١٥، ٢٥١١٦)، واللفظ له، والحاكم ٢/٢٥٦ (٢٩٢٣)، ٢/٢٦٩ (٢٩٦٩) من طريقين عن عبيد بن عمير.</p><p>قال الدارقطني في الثاني من الأفراد (٤): «غريب مِن حديث عبد الله بن عبيد بن عمير عن أبيه عن عائشة، وهو غريب من حديث خالد بن مهران الحذاء عنه، تفرَّد به يحيى بن راشد عن خالد عنه». وقال الحاكم: «هذا حديث صحيح الإسناد، ولم يخرجاه». وقال الذهبي في التلخيص: «يحيى بن راشد ضعيف». وقال ابن كثير في تفسيره عقب ذكر طريق أحمد ٥/٤٨١: «فيه إسماعيل بن مسلم المكي، وهو ضعيف». وقال الهيثمي في المجمع ٧/٧٢-٧٣ (١١١٨٩): «رواه أحمد، وفيه إسماعيل بن مسلم المكي، وهو ضعيف».عزاه السيوطي إلى عبد بن حميد.كذا في مطبوعة المصدر، ولعل الأصوب: (يَأْتُون).أخرجه يحيى بن سلام ١/٤٠٦.أخرجه أحمد ٤٢/١٥٦ (٢٥٢٦٣)، ٤٢/٤٦٥ (٢٥٧٠٥)، والترمذي ٥/٣٩٣ (٣٤٤٩)، وابن ماجه ٥/٢٨٧-٢٨٨ (٤١٩٨)، والحاكم ٢/٤٢٧ (٣٤٨٦)، وابن جرير ١٧/٧١، والثعلبي ٧/٥٠.</p><p>قال الحاكم: «هذا حديث صحيح الإسناد، ولم يُخَرِّجاه». وقال العراقي عَقِب كلام الحاكم ص١٥١١: «بل منقطع بين عائشة وبين عبد الرحمن بن سعد بن وهب». وأورده الألباني في الصحيحة ١/٣٠٤-٣٠٥ (١٦٢).أخرجه الطبراني في الأوسط ٤/١٩٨ (٣٩٦٥)، وابن جرير ١٧/٧٠-٧١.</p><p>قال الدارقطني في العلل ١١/١٩٣ (٢٢١٦): «رواه يحيى بن اليمان، عن مالك بن مغول، عن عبد الرحمن بن سعيد بن وهب، عن عائشة، وغيره يرويه عن عبد الرحمن مرسلًا عن عائشة، وهو المحفوظ».أخرجه آدم بن أبي إياس -كما في تفسير مجاهد ص٤٨٦-. وعزاه السيوطي إلى سعيد بن منصور، وعبد بن حميد، وابن المنذر.أخرجه عبد الرزاق ٢/٤٦،.عزاه السيوطي إلى ابن أبي حاتم.أخرجه ابن جرير ١٧/٦٩، وابن أبي حاتم -كما في الإتقان ٢/٣١-. وعزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ١٧/٦٩، وأخرج شطره الثاني ١٧/٦٨ من طريق ابن جريج.أخرجه ابن جرير ١٧/٦٧، وإسحاق البستي في تفسيره ص٣٩٨. وعزاه السيوطي إلى الفريابي.عزاه السيوطي إلى عبد بن حميد، وابن أبي حاتم.أخرجه ابن جرير ١٧/٦٨.أخرج شطره الثاني ابن جرير ١٧/٦٧. وعزاه السيوطي إلى عبد بن حميد.أخرجه يحيى بن سلام ١/٤٠٦.أخرجه ابن جرير ١٧/٦٩.أخرجه ابن جرير ١٧/٦٨. وينظر: الفتح ٨/٤٤٥.أخرجه ابن جرير ١٧/٦٨. وعزاه السيوطي إلى ابن أبي حاتم.أخرجه عبد الرزاق ٢/٤٦ عن قتادة من طريق معمر، وكذلك ابن جرير ١٧/٦٧. ومثله يحيى بن سلام ١/٤٠٥ من طريق سعيد بنحوه. وعزاه السيوطي إلى عبد بن حميد.أخرجه إسحاق البستي في تفسيره ص٣٩٨.أخرجه ابن وهب في الجامع ١/١٣٤-١٣٥ (٣١٠)، وابن المبارك في الزهد (١٥)، ويحيى بن سلام ١/٤٠٦، وابن جرير ١٧/٦٧. وعزاه السيوطي إلى عبد بن حميد.تفسير مقاتل بن سليمان ٣/١٦٠.أخرجه ابن جرير ١٧/٦٩.تفسير يحيى بن سلام ١/٤٠٦.
  23,61,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿أُو۟لَـٰۤىِٕكَ یُسَـٰرِعُونَ فِی ٱلۡخَیۡرَ ٰ⁠تِ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥١٧٩٤<span class="dash">-</span></span> قال <span class="name-2">الحسن البصري</span>: أي: فيما افترض اللهُ عليهم{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥١٧٩٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثم نعتهم، فقال: <span class="qpc-hafs">﴿أولئك يسارعون في الخيرات﴾</span>، يعني: يُسارِعون في الأعمال الصالحة التي ذكرها لهم في هذه الآية{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥١٧٩٦<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿أولئك يسارعون في الخيرات﴾</span>، قال: والخيرات: المخافة والوَجَل، والإيمان والكفُّ عن الشِّرك بالله، فذلك المسابقة إلى هذه الخيرات{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥١٧٩٧<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: قوله: <span class="qpc-hafs">﴿أولئك يسارعون في الخيرات﴾</span> في الأعمال الصالحة{4}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَهُمۡ لَهَا سَـٰبِقُونَ ۝٦١﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥١٧٩٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- في قوله: <span class="qpc-hafs">﴿أولئك يسارعون في الخيرات وهم لها سابقون﴾</span>، قال: سَبَقَتْ لهم السعادةُ مِن الله{5}<span class=comment-ref>٤٥٥٢</span>. (١٠/٦٠٢)</p></p><p></div></p><p><div><span class=comment-ref>٤٥٥٢</span> ذكر <u>ابنُ جرير</u> (١٧/٧٢) قول ابن عباس، ثم ذكر قولَيْن آخرَيْن في معنى الآية، ولم ينسبهما: <b>الأول:</b> وهم إليها سابقون. <b>الثاني:</b> وهم من أجلها سابقون.</p><p>ثم <span class="comment-type-3">رجَّح</span> <span class="mustanad">مستندًا إلى الأغلب من لغة العرب</span> قولَ ابن عباس «مِن أنه: سبقت لهم من الله السعادة قبل مسارعتهم في الخيرات، ولما سبق لهم من ذلك سارعوا فيها». وعلَّل ذلك بقوله: «لأن ذلك أظهر معنَيَيْه، وأنّه لا حاجة بنا إذا وجَّهْنا تأويل الكلام إلى ذلك إلى تحويل معنى اللام التي في قوله: <span class="qpc-hafs">﴿وهُمْ لَها﴾</span> إلى غير معناها الأغلب عليها».</p><p>و<span class="comment-type-1">وجَّه</span> <u>ابنُ عطية</u> (٦/٣٠٥) معنى «السباق» على القول الأول بقوله: «فالسباق -على هذا التأويل- هو إلى رضوان الله»؟ وعلى القول الثاني بقوله: «هو إلى الخيرات».</div></p><p><div></p><p><p><span class="item-no">٥١٧٩٩<span class="dash">-</span></span> عن الصلت السراج، قال: سمعتُ <span class="name-2">الحسن البصري</span> يقول: <span class="qpc-hafs">﴿أؤلئك يسارعون في الخيرات* وهم لها سابقون﴾</span>، قال: سابقون بها{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥١٨٠٠<span class="dash">-</span></span> تفسير <span class="name-2">الحسن البصري</span>: <span class="qpc-hafs">﴿وهم لها﴾</span> للخيرات مُدْرِكون{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥١٨٠١<span class="dash">-</span></span> قال <span class="name-3">محمد بن السائب الكلبي</span>: سبقوا الأمم إلى الخيرات{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥١٨٠٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وهم لها سابقون﴾</span> الخيرات التي يسارعون إليها{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥١٨٠٣<span class="dash">-</span></span> قال <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿وهم لها سابقون﴾</span>: فتلك الخيرات{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥١٨٠٤<span class="dash">-</span></span> قال يحيى بن سلّام: وقال بعضهم: <span class="qpc-hafs">﴿لها سابقون﴾</span> بها سابقون، أي: بالخيرات{1}. (ز)</p></p><p></div></p></div>",footnotes:1:علَّقه يحيى بن سلام ١/٤٠٦.تفسير مقاتل بن سليمان ٣/١٦٠.أخرجه ابن جرير ١٧/٧٢.تفسير يحيى بن سلام ١/٤٠٦.أخرجه ابن جرير ١٧/٧٢، وابن أبي حاتم -كما في فتح الباري ٨/٤٤٥-. وعزاه السيوطي إلى ابن المنذر.أخرجه إسحاق البستي في تفسيره ص٣٩٩.علَّقه يحيى بن سلام ١/٤٠٦.تفسير البغوي ٥/٤٢٢.تفسير مقاتل بن سليمان ٣/١٦٠.أخرجه ابن جرير ١٧/٧٢.علَّقه يحيى بن سلام ١/٤٠٦.
  23,62,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَلَا نُكَلِّفُ نَفۡسًا إِلَّا وُسۡعَهَاۚ وَلَدَیۡنَا كِتَـٰبࣱ یَنطِقُ بِٱلۡحَقِّ وَهُمۡ لَا یُظۡلَمُونَ ۝٦٢﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥١٨٠٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ولا نكلف نفسا إلا وسعها﴾</span> يقول: لا نكلف نفسًا مِن العمل إلا ما أطاقت، <span class="qpc-hafs">﴿ولدينا﴾</span> يعني: وعندنا <span class="qpc-hafs">﴿كتاب﴾</span> يعني: أعمالهم التي يعملون في اللوح المحفوظ <span class="qpc-hafs">﴿ينطق بالحق وهم لا يظلمون﴾</span> في أعمالهم{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥١٨٠٦<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: قوله: <span class="qpc-hafs">﴿ولا نكلف نفسا إلا وسعها﴾</span> إلا طاقتها. قوله: <span class="qpc-hafs">﴿ولدينا﴾</span> أي: وعندنا <span class="qpc-hafs">﴿كتاب ينطق بالحق وهم لا يظلمون﴾</span>، عن ابن عباس، قال: أول ما خلق الله القلم، فقال: اكتب. قال: ربِّ، ما أكتب؟ قال: ما هو كائِنٌ. قال: فجَرى القلم بما هو كائِنٌ إلى يوم القيامة. قال: فأعمال العباد تعرض كل يوم اثنين وخميس، فيجدونه على ما في الكتاب. قال يحيى: وسمعتُ بعضَهم يزيد فيه: تلا ابنُ عباس هذه الآية: <span class="qpc-hafs">﴿هذا كتابنا ينطق عليكم بالحق إنا كنا نستنسخ ما كنتم تعملون﴾</span> [الجاثية:٢٩]، ثم قال: ألستم قومًا عَرَبًا؟ هل تكون النسخة إلا مِن كتاب؟!{2}<span class=comment-ref>٤٥٥٣</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٤٥٥٣</span> ذكر <u>ابنُ عطية</u> (٦/٣٠٦) بأنّ أظهر ما قيل في معنى قوله تعالى: <span class="qpc-hafs">﴿ولَدَيْنا كِتابٌ يَنْطِقُ بِالحَقِّ﴾</span>: «أنه أراد: كتاب إحصاء الأعمال الذي ترفعه الملائكة». <span class="comment-type-4">وعلَّق</span> عليه بقوله: «وفي الآية -على هذا التأويل- تهديدٌ وتأنيس من الحيف والظلم». ثم ذكر <b>قولًا آخر</b> ولم ينسبه: أن المراد بقوله تعالى: <span class="qpc-hafs">﴿كِتابٌ﴾</span> القرآن. و<span class="comment-type-4">علَّق</span> عليه بقوله: «وهذا يحتمل». ثم <span class="comment-type-3">رجَّح</span> القول الأول، فقال: «والأول أظهر». ولم يذكر مستندًا.</div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٣/١٦٠.تفسير يحيى بن سلام ١/٤٠٧.
  23,63,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿بَلۡ قُلُوبُهُمۡ فِی غَمۡرَةࣲ مِّنۡ هَـٰذَا﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥١٨٠٧<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، في قوله: <span class="qpc-hafs">﴿بل قلوبهم في غمرة من هذا﴾</span>، قال: يعني بالغَمْرَة: الكُفْر، والشك{1}. (١٠/٦٠٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥١٨٠٨<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح، وابن جُرَيْج- في قوله: <span class="qpc-hafs">﴿بل قلوبهم في غمرة من هذا﴾</span>، قال: في عَمًى مِن هذا القرآن{2}<span class=comment-ref>٤٥٥٤</span>. (١٠/٦٠٣)</p></p><p></div></p><p><div><span class=comment-ref>٤٥٥٤</span> لم يذكر <u>ابنُ جرير</u> (١٧/٧٤) في معنى قوله تعالى: <span class="qpc-hafs">﴿مِن هَذا﴾</span> سوى قول مجاهد أنّه القرآن.</p><p>وذكر <u>ابنُ عطية</u> (٦/٣٠٦) في اسم الإشارة عدة احتمالات، فقال: «وقوله سبحانه: <span class="qpc-hafs">﴿مِن هَذا﴾</span> <b>يحتمل</b> أن يشير إلى القرآن، <b>ويحتمل</b> أن يشير إلى كتاب الإحصاء، <b>ويحتمل</b> أن يشير إلى الأعمال الصالحة المذكورة قبل، أي: هم في غمرة مِن اطِّراحها وتركها، <b>ويحتمل</b> أن يشير إلى الدِّين بجملته، أو إلى محمد ﷺ. وكل تأويل من هذه قد قالته فرقة».</div></p><p><div></p><p><p><span class="item-no">٥١٨٠٩<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق مَعْمَر- في قوله: <span class="qpc-hafs">﴿بل قلوبهم في غمرة من هذا﴾</span>، قال: في غفلة من أعمال المؤمنين{3}. (١٠/٦٠٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥١٨١٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿بل قلوبهم﴾</span> يعني: الكفار <span class="qpc-hafs">﴿في غمرة من هذا﴾</span> يقول: في غفلة من إيمان بهذا القرآن{4}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَلَهُمۡ أَعۡمَـٰلࣱ مِّن دُونِ ذَ ٰ⁠لِكَ هُمۡ لَهَا عَـٰمِلُونَ ۝٦٣﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥١٨١١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، في قوله: <span class="qpc-hafs">﴿ولهم أعمال من دون ذلك﴾</span> يقول: أعمال سيئة دون الشرك، <span class="qpc-hafs">﴿هم لها عاملون﴾</span> قال: لا بد لهم مِن أن يعملوها{1}. (١٠/٦٠٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥١٨١٢<span class="dash">-</span></span> عن <span class="name-2">أبي العالية الرِّياحِيِّ</span> -من طريق الربيع بن أنس- في قوله: <span class="qpc-hafs">﴿ولهم أعمال من دون ذلك﴾</span> الآية، قال: أعمالٌ دونَ الحَقِّ{6}<span class=comment-ref>٤٥٥٥</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٤٥٥٥</span> اختُلِف في مرجع اسم الإشارة <span class="qpc-hafs">﴿ذلك﴾</span>؛ <b>فقيل:</b> إنها إشارة إلى الغمرة. <b>وقيل:</b> إشارة إلى قوله: <span class="qpc-hafs">﴿مِن هَذا﴾</span>، ونسب <u>ابنُ عطية</u> (٦/٣٠٧) القول الأول إلى أبي العالية، وقتادة، و<span class="comment-type-4">بيَّن</span> أن معنى الآية عليه: «بل هم ضالون معرضون عن الحق، وهم -مع ذلك- لهم سعايات فساد، فوسمهم تعالى بحالتي شرٍّ». ثم <span class="comment-type-1">وجَّهه</span> بقوله: «وعلى هذا التأويل فالإخبار عمّا سلف من أعمالهم وعمّا هم فيه». و<span class="comment-type-4">علَّق</span> على القول الثاني -ولم ينسبه لأحد- بقوله: «فكأنّه قال: لهم أعمال من دون الحق، أو القرآن ونحوه».</div></p><p><div></p><p><p><span class="item-no">٥١٨١٣<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span>، في قوله: <span class="qpc-hafs">﴿ولهم أعمال﴾</span> قال: خطايا <span class="qpc-hafs">﴿من دون ذلك﴾</span> قال: الحق، <span class="qpc-hafs">﴿هم لها عاملون﴾</span> قال: لا بُدَّ لهم مِن أن يعملوها{7}. (١٠/٦٠٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥١٨١٤<span class="dash">-</span></span> عن حميد، قال: سألتُ <span class="name-2">الحسن البصري</span> عن قول الله: <span class="qpc-hafs">﴿ولهم أعمال من دون ذلك هم لها عاملون﴾</span>، قال: أعمال لم يعملوها، سيعملونها{8}<span class=comment-ref>٤٥٥٦</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٤٥٥٦</span> <span class="comment-type-4">علَّق</span> <u>ابنُ عطية</u> (٦/٣٠٧) على قول الحسن ومجاهد بقوله: «أي: أنهم لهم أعمال من الفساد سيعملونها».</div></p><p><div></p><p><p><span class="item-no">٥١٨١٥<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق مَعْمَر- في قوله: <span class="qpc-hafs">﴿ولهم أعمال من دون ذلك﴾</span> قال: هي شر من أعمال المؤمنين، ذكر الله الذين هم مِن خشية ربهم مشفقون، والذين، والذين، ثم قال للكافرين: <span class="qpc-hafs">﴿بل قلوبهم في غمرة من هذا ولهم أعمال من دون﴾</span> الأعمال التي سمى: <span class="qpc-hafs">﴿والذين﴾</span>، <span class="qpc-hafs">﴿والذين﴾</span>{9}. (١٠/٦٠٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥١٨١٦<span class="dash">-</span></span> قال <span class="name-2">قتادة بن دعامة</span>: هذا ينصَرِف إلى المسلمين، وأنّ لهم أعمالًا سِوى ما عملوا مِن الخيرات، هم لها عاملون{10}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥١٨١٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ولهم أعمال من دون ذلك﴾</span> يقول: لهم أعمال خبيثةٌ دون الأعمال الصالحة، يعني: غير الأعمال الصالحة التي ذكرت عن المؤمنين في هذه الآية وفي الآية الأولى، <span class="qpc-hafs">﴿هم لها عاملون﴾</span> يقول: هم لتلك الأعمال الخبيثة عاملون، التي هي في اللوح المحفوظ أنّهم سيعملونها، لا بُدَّ لهم مِن أن يعملوها{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥١٨١٨<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿ولهم أعمال من دون ذلك هم لها عاملون﴾</span>، قال: لم يكن له بُدٌّ مِن أن يستوفي بقية عمله، ويَصْلى به{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥١٨١٩<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿ولهم﴾</span> يعني: المشركين <span class="qpc-hafs">﴿أعمال من دون ذلك﴾</span> دون أعمال المؤمنين هي شَرٌّ مِن أعمال المؤمنين، <span class="qpc-hafs">﴿هم لها عاملون﴾</span> لتلك الأعمال ... وبعضهم يقول: أعمال لم يعملوها، سيعملونها.عن عمر بن الخطاب، قال: يا رسول الله، أنعمل لِما قد فُرِغ منه أو لِما نَأْتَنِف؟ قال: «<b>لا، بل اعمل لِما قد فُرِغ منه</b>». قال: ففيمَ العمل إذًا؟ قال: «<b>اعملوا، فكُلٌّ لا يُنال إلا بعمل</b>». قال: هذا حين نجتهد. وعن عمر بن الخطاب، قال: يا رسول الله، ما العمل اليوم، أشيءٌ مُستأنف، أم شيء قد فُرِغ منه؟ قال: «<b>قد فُرِغ منه</b>». قال: ففِيمَ العمل اليوم؟ فقال: «<b>كلُّ عبدٍ مُؤَتًّى لِما خُلِق له</b>».=</p><p>وعن مطرف بن عبد الله بن الشخير، قال: لم تُكَلوا{13} إلى القدر، وإليه تصيرون{14}. (ز)</p></p><p></div></p></div>",footnotes:1:عزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.أخرجه ابن جرير ١٧/٧٤. وعلَّقه يحيى بن سلام ١/٤٠٧. وعزاه السيوطي إلى ابن أبي شيبة، وعبد بن حميد، وابن المنذر، وابن أبي حاتم.أخرجه عبد الرزاق ٢/٤٧، وابن جرير ١٧/٧٥. وعلَّقه يحيى بن سلام ١/٤٠٧. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.تفسير مقاتل بن سليمان ٣/١٦٠.عزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.أخرجه ابن جرير ١٧/٧٥.أخرج ابن جرير ١٧/٧٥-٧٦ شطره الأول من طريق ابن أبي نجيح وابن جريج، والأخير من طريق العلاء بن عبد الكريم. وعلَّقه يحيى بن سلام ١/٤٠٧ دون آخره. وعزاه السيوطي إلى ابن أبي شيبة، وعبد بن حميد، وابن المنذر، وابن أبي حاتم.أخرجه ابن جرير ١٧/٧٦.أخرجه عبد الرزاق ٢/٤٧، وابن جرير ١٧/٧٦. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.تفسير البغوي ٥/٤٢٢.تفسير مقاتل بن سليمان ٣/١٦٠.أخرجه ابن جرير ١٧/٧٦.في مختصر ابن محكم: لم توكلوا، كما في حاشية تحقيق المصدر.تفسير يحيى بن سلام ١/٤٠٦. والحديث أخرجه ابن أبي عاصم في السنة ١/٧١، والخطيب في موضح أوهام الجمع ٢/٤٠٤، ويحيى بن سلام في تفسيره ١/٤٠٧-٤٠٨، من طريق الزهري، عن سعيد بن المسيب، عن عمر به.</p><p>إسناده صحيح، وفي سماع سعيد من عمر كلام، لكن وإن لم يثبت سماعه منه فإنّ مراسيله كما قال الإمام أحمد: «صحاح، لا ترى أصح منها». وقال ابن معين: «أصح المراسيل مراسيل سعيد بن المسيب». وقال الشافعي: «إرسال ابن المسيب عندنا حجة». كما في جامع التحصيل ١/٤٧.
  23,64,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿حَتَّىٰۤ إِذَاۤ أَخَذۡنَا مُتۡرَفِیهِم بِٱلۡعَذَابِ﴾</span> - نزول الآية، وتفسيرها</h3></p><p><div></p><p><p><span class="item-no">٥١٨٢٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، في قوله: <span class="qpc-hafs">﴿حتى اذا أخذنا مترفيهم بالعذاب﴾</span> الآية، قال: هم أهل بدر{1}. (١٠/٦٠٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥١٨٢١<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span>، <span class="qpc-hafs">﴿حتى إذا أخذنا مترفيهم بالعذاب﴾</span>، قال: بالسيوف يوم بدر{2}. (١٠/٦٠٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥١٨٢٢<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق علقمة بن مرثد- <span class="qpc-hafs">﴿حتى اذا أخذنا مترفيهم بالعذاب﴾</span>، قال: بالسيوف يوم بدر{3}. (١٠/٦٠٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥١٨٢٣<span class="dash">-</span></span> عن <span class="name-2">الضحاك بن مزاحم</span> -من طريق عبيد- في قوله: <span class="qpc-hafs">﴿حتى إذا أخذنا مترفيهم بالعذاب﴾</span>، قال: يعني: أهل بدر، أخذهم الله بالعذاب يوم بدر{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥١٨٢٤<span class="dash">-</span></span> قال <span class="name-2">الضحّاك بن مُزاحِم</span>: يعني: الجوع، وذلك حين دعا عليهم رسول الله ﷺ، فقال: «<b>اللَّهُمَّ، اشْدُدْ وطْأَتَك على مُضَر، واجعلها عليهم سنين كسِنِي يوسف</b>». فابتلاهم الله ﷿ بالقَحْط، حتى أكلوا الكِلاب والجِيَف{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥١٨٢٥<span class="dash">-</span></span> عن مَعْمَر، قال: أخبَرني مَن سمِع <span class="name-2">عكرمة مولى ابن عباس</span> يقول: ... ثم كانت وقعة بدر ...، وفيهم نزلت: <span class="qpc-hafs">﴿حتى إذا أخذنا مترفيهم بالعذاب﴾</span> ...{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥١٨٢٦<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق مَعْمَر- <span class="qpc-hafs">﴿حتى اذا أخذنا مترفيهم بالعذاب﴾</span>، قال: ذُكِر لنا: أنّها نزلت في الذين قتل اللهُ يوم بدر{7}. (١٠/٦٠٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥١٨٢٧<span class="dash">-</span></span> تفسير <span class="name-2">إسماعيل السُّدِّيّ</span>: قوله: <span class="qpc-hafs">﴿حتى إذا﴾</span>، يعني: فلَمّا{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥١٨٢٨<span class="dash">-</span></span> عن <span class="name-2">الربيع بن أنس</span>، في قوله: <span class="qpc-hafs">﴿حتى إذا أخذنا مترفيهم﴾</span>، قال: مُسْتَكْبِرِيهم{9}. (١٠/٦٠٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥١٨٢٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿حتى إذا أخذنا مترفيهم﴾</span> يعني: أغنياءهم وجبابرتهم <span class="qpc-hafs">﴿بالعذاب﴾</span> يعني: القتل ببدر{10}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥١٨٣٠<span class="dash">-</span></span> عن <span class="name-3">عبد الملك ابن جُرَيْج</span> -من طريق حجاج- <span class="qpc-hafs">﴿حتى إذا أخذنا مترفيهم بالعذاب﴾</span>، قال: عذاب يوم بدر{11}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥١٨٣١<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- <span class="qpc-hafs">﴿إذا أخذنا مترفيهم بالعذاب﴾</span>، قال: المُتْرَفون: العظماء{12}<span class=comment-ref>٤٥٥٧</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٤٥٥٧</span> لم يذكر <u>ابنُ جرير</u> (١٧/٧٧) في معنى قوله تعالى: <span class="qpc-hafs">﴿إذا أخَذْنا مُتْرَفِيهِمْ بِالعَذابِ﴾</span> سوى قول ابن زيد.</div></p><p><div></p><p><p><span class="item-no">٥١٨٣٢<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿أخذنا مترفيهم بالعذاب﴾</span>، يعني: أبا جهل وأصحابَه الذين قُتِلوا يوم بدر، نزلت هذه الآيةُ قبل ذلك بمكة{13}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿إِذَا هُمۡ یَجۡـَٔرُونَ ۝٦٤﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥١٨٣٣<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- في قوله: <span class="qpc-hafs">﴿إذا هم يجأرون﴾</span>، قال: يستغيثون{14}. (١٠/٦٠٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥١٨٣٤<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق علقمة بن مرثد- <span class="qpc-hafs">﴿حتى اذا أخذنا مترفيهم بالعذاب﴾</span> قال: بالسيوف يوم بدر؛ <span class="qpc-hafs">﴿اذا هم يجأرون﴾</span> قال: الذين بمكة{15}. (١٠/٦٠٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥١٨٣٥<span class="dash">-</span></span> قال <span class="name-2">الحسن البصري</span>: <span class="qpc-hafs">﴿يجأرون﴾</span> يصرخون إلى الله بالتوبة، فلا يُقْبَل منهم{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥١٨٣٦<span class="dash">-</span></span> قال <span class="name-2">قتادة بن دعامة</span>: <span class="qpc-hafs">﴿إذا هم يجأرون﴾</span>: يجزعون{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥١٨٣٧<span class="dash">-</span></span> عن <span class="name-2">الربيع بن أنس</span> -من طريق أبي جعفر- في قوله: <span class="qpc-hafs">﴿إذا هم يجأرون﴾</span>، قال: يَجْزَعون{11}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥١٨٣٨<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿إذا هم يجأرون﴾</span> [إذا] هم يَضِجُّون إلى الله ﷿ حين نزل بهم العذاب{10}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥١٨٣٩<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- <span class="qpc-hafs">﴿إذا هم يجأرون﴾</span>، قال: يَجْزَعون{12}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه النسائي في الكبرى (١١٣٥٣).عزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ١٧/٧٨، وإسحاق البستي في تفسيره ص٤٠٣. وعزاه السيوطي إلى ابن أبي شيبة، وعبد بن حميد، وابن المنذر، وابن أبي حاتم.أخرجه ابن جرير ١٧/٧٨، وإسحاق البستي في تفسيره ص٤٠٣.تفسير الثعلبي ٧/٥١، وتفسير البغوي ٥/٤٢٢. والحديث أخرجه البخاري ١/١٦٠ (٨٠٤)، ٢/٢٦ (١٠٠٦)، ٤/٤٤ (٢٩٣٢)، ٤/١٥٠ (٣٣٨٦)، ٦/٣٨ (٤٥٦٠)، ٦/٤٨ (٤٥٩٨)، ٨/٤٤ (٦٢٠٠)، ٨/٨٤ (٦٣٩٣)، ٩/١٩-٢٠ (٦٩٤٠)، ومسلم ١/٤٦٦ (٦٧٥) كلاهما من حديث أبي هريرة إلى قوله: «<b>كسني يوسف</b>».أخرجه عبد الرزاق ٥/٣٦١-٣٦٣ (٩٧٣٤).أخرجه عبد الرزاق ٢/٤٧. وعلَّقه يحيى بن سلام ١/٤٠٨. وعزاه السيوطي إلى عبد بن حميد، وابن أبي حاتم.علَّقه يحيى بن سلام ١/٤٠٨.عزاه السيوطي إلى ابن أبي حاتم.تفسير مقاتل بن سليمان ٣/١٦٠.أخرجه ابن جرير ١٧/٧٨.أخرجه ابن جرير ١٧/٧٧-٧٨.تفسير يحيى بن سلام ١/٤٠٨.أخرجه ابن جرير ١٧/٧٧، وابن أبي حاتم -كما في الإتقان ٢/٣١-. وعزاه السيوطي إلى ابن المنذر.عزاه السيوطي إلى ابن أبي شيبة، وعبد بن حميد، وابن المنذر، وابن أبي حاتم.علَّقه يحيى بن سلام ١/٤٠٨.علَّقه يحيى بن سلام ١/٤٠٨.أخرجه ابن جرير ١٧/٧٨.تفسير مقاتل بن سليمان ٣/١٦٠.أخرجه ابن جرير ١٧/٧٧-٧٨.
  23,65,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿لَا تَجۡـَٔرُوا۟ ٱلۡیَوۡمَۖ إِنَّكُم مِّنَّا لَا تُنصَرُونَ ۝٦٥﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥١٨٤٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عكرمة- في قوله: <span class="qpc-hafs">﴿بالعذاب إذا هم يجأرون لا تجأروا اليوم إنكم منا لا تنصرون﴾</span>، قال: هم أهل بدر{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥١٨٤١<span class="dash">-</span></span> عن <span class="name-2">الربيع بن أنس</span> -من طريق أبي جعفر- <span class="qpc-hafs">﴿لا تجأروا اليوم﴾</span>: لا تجزعوا الآن حين نزل بكم العذاب؛ إنّه لا ينفعكم، فلو كان هذا الجَزَع والتَّضَرُّعُ قبلُ نَفَعَكُم{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥١٨٤٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: يقول الله ﷿: <span class="qpc-hafs">﴿لا تجأروا اليوم﴾</span> لا تضجوا اليوم؛ <span class="qpc-hafs">﴿إنكم منا لا تنصرون﴾</span> يقول: لا تُمْنَعون منا، حتى تُعَذَّبوا بعد القتل ببدر{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥١٨٤٣<span class="dash">-</span></span> عن <span class="name-3">عبد الملك ابن جريج</span> -من طريق حجاج- <span class="qpc-hafs">﴿حتى إذا أخذنا مترفيهم بالعذاب﴾</span> قال: عذاب يوم بدر؛ <span class="qpc-hafs">﴿إذا هم يجأرون﴾</span> قال: الذين بمكة{4}<span class=comment-ref>٤٥٥٨</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٤٥٥٨</span> <span class="comment-type-4">ذكر</span> <u>ابنُ عطية</u> (٦/٣٠٨) في معنى قوله تعالى: <span class="qpc-hafs">﴿لا تَجْأَرُوا اليَوْمَ إنَّكُمْ مِنّا لا تُنصَرُونَ﴾</span> أنّ هذا «القول يجوز أن يكون حقيقة، أي: تقول لهم ذلك الملائكة، ويحتمل أن يكون مجازًا، أي: لسان الحال يقول ذلك». و<span class="comment-type-4">علَّق</span> على احتمال كونه مجازًا بقوله: «وهذا على أنّ الذين يجأرون هم المُعَذَّبون، وأمّا على قول ابنِ جريج فلا يُحْتَمل أن تقول ذلك الملائكة».</div></p><p><div></p><p><p><span class="item-no">٥١٨٤٤<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿لا تجأروا اليوم﴾</span> لا تجزعوا اليوم؛ <span class="qpc-hafs">﴿إنكم منا لا تنصرون﴾</span> أي: لا يمنعكم مِنّا أحد{5}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه النسائي في الكبرى (ت: شعيب الأرناؤوط) ١٠/١٩٤ (١١٢٩٠).أخرجه ابن جرير ١٧/٧٩.تفسير مقاتل بن سليمان ٣/١٦٠.أخرجه ابن جرير ١٧/٧٨.تفسير يحيى بن سلام ١/٤٠٨.
  23,66,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿قَدۡ كَانَتۡ ءَایَـٰتِی تُتۡلَىٰ عَلَیۡكُمۡ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥١٨٤٥<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق العوفي- قوله: <span class="qpc-hafs">﴿قد كانت آياتي تتلى عليكم فكنتم على أعقابكم تنكصون﴾</span>، يعني: أهل مكة{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥١٨٤٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿قد كانت آياتي﴾</span> يعني: القرآن <span class="qpc-hafs">﴿تتلى عليكم﴾</span> يعني: على كفار مكة{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥١٨٤٧<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿قد كانت آياتي تتلى عليكم﴾</span>، يعني: القرآن{3}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿فَكُنتُمۡ عَلَىٰۤ أَعۡقَـٰبِكُمۡ تَنكِصُونَ ۝٦٦﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥١٨٤٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- في قوله: <span class="qpc-hafs">﴿فكنتم على أعقابكم تنكصون﴾</span>، قال: تُدبِرون{4}. (١٠/٦٠٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥١٨٤٩<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span> -من طريق حصين- قال: تُدبِرون{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥١٨٥٠<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن جريج، وابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿تنكصون﴾</span>، قال: تَسْتَأخِرُون{6}. (١٠/٦٠٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥١٨٥١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فكنتم على أعقابكم تنكصون﴾</span> يعني: تتأخرون عن [الإيمان] به، تكذيبًا بالقرآن{2}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ١٧/٨٠.تفسير مقاتل بن سليمان ٣/١٦١.تفسير يحيى بن سلام ١/٤٠٨.أخرجه ابن جرير ١٧/٨٠، وابن أبي حاتم -كما في الإتقان ٢/٣١-. وعزاه السيوطي إلى ابن المنذر.أخرجه الثوري في تفسيره ص٢١٧ دون ذكر الآية.أخرجه يحيى بن سلام ١/٤٠٩ من طريق ابن مجاهد بلفظ: تستأخرون عن الإيمان، وابن جرير ١٧/٧٩-٨٠. وعزاه السيوطي إلى عبد بن حميد.تفسير مقاتل بن سليمان ٣/١٦١.
  23,67,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿مُسۡتَكۡبِرِینَ بِهِۦ سَـٰمِرࣰا تَهۡجُرُونَ ۝٦٧﴾</span> - قراءات</h3></p><p><div></p><p><p><span class="item-no">٥١٨٥٢<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span> أنّه قرأ: (سُمَّرًا تُهَجِّرُونَ)، وكانوا إذا سمروا هَجَّرُوا في القول{1}. (١٠/٦٠٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥١٨٥٣<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span> -من طريق أبي نَهيك- أنّه قرأ: ‹سامِرًا تُهْجِرُونَ›، أي: تَسُبُّون{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥١٨٥٤<span class="dash">-</span></span> عن <span class="name-2">عاصم</span> أنّه قرأ: <span class="qpc-hafs">﴿سامِرًا تَهْجُرُونَ﴾</span> بنصب التاء، ورفع الجيم{3}. (١٠/٦٠٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥١٨٥٥<span class="dash">-</span></span> قال يحيى بن سلّام: مقرأ <span class="name-3">الكلبي</span> في هذا الحرف: (سُمَّرًا){4}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿مُسۡتَكۡبِرِینَ بِهِۦ سَـٰمِرࣰا تَهۡجُرُونَ ۝٦٧﴾</span> - نزول الآية</h3></p><p><div></p><p><p><span class="item-no">٥١٨٥٦<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span>، قال: كانت قريش تسمر حول البيت، ولا تطوف به، ويفتخرون به؛ فأنزل الله: <span class="qpc-hafs">﴿مستكبرين به سامرا تهجرون﴾</span>{5}. (١٠/٦٠٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥١٨٥٧<span class="dash">-</span></span> قال مقاتل بن سليمان: نزلت في الملأ مِن قريش الذين مَشَوا إلى أبي طالب{6}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿مُسۡتَكۡبِرِینَ بِهِۦ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥١٨٥٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق العوفي- <span class="qpc-hafs">﴿مستكبرين به﴾</span>، قال: مستكبرين بحَرَم البيت، إنّه لا يظهر علينا فيه أحد{7}. (١٠/٦٠٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥١٨٥٩<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق سعيد- قال: <span class="qpc-hafs">﴿مستكبرين به﴾</span>، قال: مستكبرين بالبيت، تقولون: نحن أهله{8}. (١٠/٦٠٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥١٨٦٠<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span> -من طريق حصين- في قوله: <span class="qpc-hafs">﴿مستكبرين به﴾</span>: بالحرم{9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥١٨٦١<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- <span class="qpc-hafs">﴿مستكبرين به﴾</span>، قال: بمكة؛ بالبلد{10}. (١٠/٦٠٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥١٨٦٢<span class="dash">-</span></span> عن <span class="name-2">الضَّحّاك بن مُزاحِم</span> -من طريق عبيد- يقول في قوله: <span class="qpc-hafs">﴿مستكبرين به﴾</span>، قال: بالحرم{11}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥١٨٦٣<span class="dash">-</span></span> عن <span class="name-2">أبي مالك غزوان الغفاري</span>، <span class="qpc-hafs">﴿مستكبرين به سامرا تهجرون﴾</span>، قال: مستكبرين بحَرَمي{3}. (١٠/٦٠٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥١٨٦٤<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق عوف- <span class="qpc-hafs">﴿مستكبرين به﴾</span>، قال: بحَرَمي{13}. (١٠/٦٠٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥١٨٦٥<span class="dash">-</span></span> عن <span class="name-2">أبي صالح [باذام]</span>، <span class="qpc-hafs">﴿مستكبرين به﴾</span>، قال: بالقرآن{14}<span class=comment-ref>٤٥٥٩</span>. (١٠/٦٠٦)</p></p><p></div></p><p><div><span class=comment-ref>٤٥٥٩</span> اختُلِف في مرجع الضمير في <span class="qpc-hafs">﴿به﴾</span> مِن قوله تعالى: <span class="qpc-hafs">﴿مُسْتَكْبِرِينَ بِهِ﴾</span> على قولين: <b>الأول:</b> أنّ الضمير عائد على الحرم والمسجد، وإن لم يتقدم له ذِكْرٌ؛ لشهرته في الأمر. <b>الثاني:</b> أنّ الضمير عائد على القرآن.</p><p>و<span class="comment-type-1">وجَّه</span> <u>ابنُ عطية</u> (٦/٣٠٨) المعنى على القول الأول، فقال: «والمعنى: إنكم تعتقدون في أنفسكم أنّ لكم بالمسجد والحَرَم أعظم الحقوق على الناس والمنازل عند الله؛ فأنتم تستكبرون لذلك، وليس الاستكبار من الحق». و<span class="comment-type-1">وجَّه</span> المعنى على القول الثاني، فقال: «والمعنى: يُحدث لكم سماع الآيات كُفرًا وطغيانًا». ثم <span class="comment-type-4">علَّق</span> عليه بقوله: «وهذا قولٌ جيد».</div></p><p><div></p><p><p><span class="item-no">٥١٨٦٦<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق مَعْمَر- <span class="qpc-hafs">﴿مستكبرين به﴾</span>، قال: بالبيت، والحرم{15}. (١٠/٦٠٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥١٨٦٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثم نعتهم، فقال سبحانه: <span class="qpc-hafs">﴿مستكبرين به﴾</span>، يعني: آمنين بالحرم بأنّ لهم البيت الحرام{16}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥١٨٦٨<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿مستكبرين به﴾</span> بالحرم{17}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿سَـٰمِرࣰا تَهۡجُرُونَ ۝٦٧﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥١٨٦٩<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>: أن رسول الله ﷺ كان يقرأ: ‹مُسْتَكْبِرِينَ بِهِ سامِرًا تُهْجِرُونَ›. قال: كان المشركون يُهْجِرون رسول الله ﷺ في القول في سَمَرِهم{18}. (١٠/٦٠٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥١٨٧٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق سعيد- قال: إنّما كُرِهَ السمر حين نزلت هذه الآية: <span class="qpc-hafs">﴿مستكبرين به سامرا تهجرون﴾</span>. قال: مستكبرين بالبيت، تقولون: نحن أهله، <span class="qpc-hafs">﴿تهجرون﴾</span> قال: كانوا يهجرونه، ولا يعمرونه{8}. (١٠/٦٠٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥١٨٧١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- في قوله: ‹تُهْجِرون›، قال: تقولون هُجْرًا{20}<span class=comment-ref>٤٥٦٠</span>. (١٠/٦٠٤)</p></p><p></div></p><p><div><span class=comment-ref>٤٥٦٠</span> <span class="comment-type-4">علَّق</span> <u>ابنُ عطية</u> (٦/٣١٠) على قول ابن عباس وما في معناه بقوله: «وهذا إشارة إلى سبِّهم رسول الله ﷺ وأصحابه».</div></p><p><div></p><p><p><span class="item-no">٥١٨٧٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>: أنّ نافع بن الأزرق قال له: أخبِرني عن قوله ﷿: <span class="qpc-hafs">﴿سامرا تهجرون﴾</span>. قال: كانوا يهجرون على اللهو والباطل. قال: وهل تعرف العرب ذلك؟ قال: نعم، أما سمعت الشاعر يقول:</p><p>وباتوا بشِعْبٍ لهم سامرًا إذا خَبَّ نيرانُهم أوقدوا{21}. (١٠/٦٠٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥١٨٧٣<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، في قوله: <span class="qpc-hafs">﴿سامرا تهجرون﴾</span>، قال: كانت قريش يَتَحَلَّقون حِلَقًا يَتَحَدَّثون حول البيت{22}. (١٠/٦٠٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥١٨٧٤<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق العوفي- قوله: <span class="qpc-hafs">﴿تهجرون﴾</span>، قال: يهجرون ذِكْرَ الله، والحقّ{23}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥١٨٧٥<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span> -من طريق حصين- في قوله: <span class="qpc-hafs">﴿سامرا تهجرون﴾</span>: وتقولون غير الحق{24}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥١٨٧٦<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span> -من طريق حصين- في قوله: <span class="qpc-hafs">﴿مستكبرين به سامرا تهجرون﴾</span>، قال: سمروا بالليل يخوضون في الباطل{25}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥١٨٧٧<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- <span class="qpc-hafs">﴿سامرا﴾</span>، يعني: بالليل{26}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥١٨٧٨<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- <span class="qpc-hafs">﴿سامرا﴾</span> قال: مَجالِسًا، <span class="qpc-hafs">﴿تهجرون﴾</span> بالقول السيء في القرآن{27}. (١٠/٦٠٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥١٨٧٩<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق أبي يحيى- قال: هو مُنكَر القول، وهُجْر القول{28}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥١٨٨٠<span class="dash">-</span></span> عن <span class="name-2">الضحاك بن مزاحم</span> -من طريق عبيد- يقول في قوله: <span class="qpc-hafs">﴿سامرا﴾</span> قال: يعني: سمَر الليل، ‹تُهْجِرُون› يقول: يقولون المنكر والخَنا مِن القول، كذلك هُجْر القول{29}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥١٨٨١<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span>، في قوله: <span class="qpc-hafs">﴿سامرا تهجرون﴾</span>، قال: تهجرون الحق{30}. (١٠/٦٠٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥١٨٨٢<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span> -من طريق سعيد بن مسروق- <span class="qpc-hafs">﴿سامرا تهجرون﴾</span>: تُسِيئون القولَ فيه{31}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥١٨٨٣<span class="dash">-</span></span> عن <span class="name-2">أبي مالك غزوان الغفاري</span>، <span class="qpc-hafs">﴿مستكبرين به سامرا تهجرون﴾</span>، قال: مستكبرين بحَرَمي، سامرًا فيه بما لا ينبغي مِن القول{3}. (١٠/٦٠٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥١٨٨٤<span class="dash">-</span></span> عن <span class="name-2">أبي مالك غزوان الغفاري</span> -من طريق حصين- في قوله ﷿: <span class="qpc-hafs">﴿مستكبرين به سامرا تهجرون﴾</span>، قال: كانوا يهجرون ما لا يرضى اللهُ مِن القول{33}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥١٨٨٥<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق عوف-<span class="qpc-hafs">﴿سامِرًا تُهْجِرون﴾</span>، قال: القرآن، وذِكْري، ورسولي{34}. (١٠/٦٠٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥١٨٨٦<span class="dash">-</span></span> تفسير <span class="name-2">الحسن البصري</span> -من طريق عمرو- في قوله: <span class="qpc-hafs">﴿سامرا﴾</span>، يقول: قد بلغ مِن أمانكم أنّ سامِركم يسمر بالبطحاء -يعني: سمر الليل- والعربُ تقتل بعضُها بعضًا، وتسيء بعضُها بعضًا، وأنتم في ذلك تهجرون كتابي ورسولي{35}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥١٨٨٧<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق مَعْمَر- <span class="qpc-hafs">﴿مستكبرين به﴾</span> قال: بالبيت والحرم، <span class="qpc-hafs">﴿سامرا﴾</span> قال: كان سامِرُهم لا يخاف؛ مِمّا أُعْطُوا من الأمن، وكانت العرب يخاف سامرُهم، ويغزو بعضُهم بعضًا، وكان أهلُ مكة لا يخافون ذلك بما أُعْطُوا مِن الأمن، ‹ تُهْجِرُونَ› قال: تَتَكَلَّمون بالشِّرك والبهتان في حرم الله وعند بيته.= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥١٨٨٨<span class="dash">-</span></span> قال: وكان <span class="name-2">الحسن</span> يقول: ‹سامِرًا تُهْجِرُونَ› كتاب الله، ونبي الله{36}. (١٠/٦٠٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥١٨٨٩<span class="dash">-</span></span> عن <span class="name-2">أبي صالح [باذام]</span> -من طريق إسماعيل [بن أبي خالد]- في قوله: <span class="qpc-hafs">﴿سامرا تهجرون﴾</span>، قال: بالبيت، أو بالحرم{37}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥١٨٩٠<span class="dash">-</span></span> عن <span class="name-2">أبي صالح [باذام]</span> -من طريق السُّدِّيّ- في قوله: <span class="qpc-hafs">﴿سامرا تهجرون﴾</span>، قال: السَّبّ{23}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥١٨٩١<span class="dash">-</span></span> عن عقيل بن خالد: أن [محمد] بن شهاب [الزهري] كان يسمر، فكان إذا رآه ينعس قال: ما أنت من سُمّار قريش الذين قال الله تعالى: <span class="qpc-hafs">﴿سامرا تهجرون﴾</span>{39}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥١٨٩٢<span class="dash">-</span></span> قال <span class="name-3">محمد بن السائب الكلبي</span>: وأنتم سُمُرًا حول البيت{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥١٨٩٣<span class="dash">-</span></span> قال <span class="name-3">محمد بن السائب الكلبي</span> -من طريق معمر- <span class="qpc-hafs">﴿تهجرون﴾</span>: أي: يقولون هُجْرًا{41}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥١٨٩٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿سامرا﴾</span> بالليل، إضمار في الباطل، وأنتم آمِنون فيه. ثم قال: <span class="qpc-hafs">﴿تهجرون﴾</span> القرآن، فلا تؤمنون به{16}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥١٨٩٥<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿سامرا﴾</span> قال: كانوا يسمرون ليلتهم ويلعبون؛ يتكلمون بالشِّعر والكهانة وبما لا يدرون، <span class="qpc-hafs">﴿تهجرون﴾</span>: الهذيان؛ الذي يتكلم بما لا يريد ولا يعقل، كالمريض الذي يتكلم بما لا يدري. قال: كان أبي يقرؤها: <span class="qpc-hafs">﴿سامرا تهجرون﴾</span>{43}<span class=comment-ref>٤٥٦١</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٤٥٦١</span> <span class="comment-type-1">وجَّه</span> <u>ابنُ عطية</u> (٦/٣٠٩) قول ابن زيد بقوله: أي: تقولون اللغو من القول، وقاله أبو حاتم.</div></p><p><h3><span class="qpc-hafs">﴿سَـٰمِرࣰا تَهۡجُرُونَ ۝٦٧﴾</span> - أحكام متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٥١٨٩٦<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق سعيد- قال: إنّما كُرِهَ السمر حين نزلت هذه الآية: <span class="qpc-hafs">﴿مستكبرين به سامرا تهجرون﴾</span>{8}. (١٠/٦٠٨)</p></p><p></div></p></div>",footnotes:1:عزاه السيوطي إلى عبد بن حميد.</p><p>و(سُمَّرًا) بتشديد الميم قراءة شاذة، تروى أيضًا عن ابن مسعود، وابن عباس، وغيرهما، وكذلك (تُهَجِّرُونَ) بتشديد الجيم، وتروى أيضا عن ابن عباس، وابن مسعود. انظر: مختصر ابن خالويه ص١٠٠، والمحتسب ٢/٩٥.أخرجه ابن جرير ١٧/٨٦.</p><p>وهي قراءة متواترة، قرأ بها نافع، وقرأ بقية العشرة: <span class="qpc-hafs">﴿تَهْجُرُونَ﴾</span> بفتح التاء، وضم الجيم. انظر: النشر ٢/٣٢٩، والإتحاف ص٤٠٤-٤٠٥.عزاه السيوطي إلى عبد بن حميد.علَّقه يحيى بن سلام ١/٤٠٩.عزاه السيوطي إلى سعيد بن منصور، وابن أبي حاتم مرسلًا.تفسير مقاتل بن سليمان ٣/١٦١، وهو مرسل.أخرجه ابن جرير ١٧/٨٠. وعزاه السيوطي إلى ابن أبي حاتم.أخرجه النسائي في الكبرى (١١٣٥١)، والحاكم ٢/٣٩٤. وعزاه السيوطي إلى ابن أبي حاتم، وابن مردويه.أخرجه ابن جرير ١٧/٨١.أخرجه ابن جرير ١٧/٨١. وعزاه السيوطي إلى عبد بن حميد، وابن أبي حاتم.أخرجه ابن جرير ١٧/٨١، وإسحاق البستي في تفسيره ص٤٠٤.عزاه السيوطي إلى عبد بن حميد.أخرجه يحيى بن سلام ١/٤٠٩ من طريق أبي الأشهب، وابن جرير ١٧/٨١. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.عزاه السيوطي إلى عبد بن حميد، وابن أبي حاتم.أخرجه يحيى بن سلام ١/٤٠٩ من طريق سعيد، وابن جرير ١٧/٨١. وعزاه السيوطي إلى عبد بن حميد، وابن أبي حاتم.تفسير مقاتل بن سليمان ٣/١٦١.تفسير يحيى بن سلام ١/٤٠٩. وينظر: المكتفى لأبي عمرو الداني ص١٤٢ (١٧).أخرجه الحاكم ٢/٢٦٩ (٢٩٧٠).</p><p>قال الحاكم: «هذا حديث صحيح الإسناد، ولم يخرجاه». وقال الهيثمي في المجمع ٧/٧٣ (١١١٩٠): «رواه الطبراني، وفيه يحيى بن سلمة بن كهيل، وهو ضعيف، وقد ذكره ابن حِبّان في الثقات، وقال: في رواية ابنه إبراهيم عنه مناكير. قلت: وهذا منها».أخرجه النسائي في الكبرى (١١٣٥١)، والحاكم ٢/٣٩٤. وعزاه السيوطي إلى ابن أبي حاتم، وابن مردويه.أخرجه ابن جرير ١٧/٨٥، وابن أبي حاتم -كما في الإتقان ٢/٣١-. وعزاه السيوطي إلى ابن المنذر.عزاه السيوطي إلى الطستي. وينظر: مسائل نافع (٢٤٢).عزاه السيوطي إلى عبد بن حميد، وابن أبي حاتم، وابن مردويه.أخرجه ابن جرير ١٧/٨٤.تفسير الثوري ص٢١٧.أخرجه ابن جرير ١٧/٨٥، وإسحاق البستي في تفسيره ص٤٠٣.تفسير مجاهد ص٤٨٧.أخرجه ابن جرير ١٧/٨٣، ٨٥، وأخرج أوله يحيى بن سلام ١/٤٠٩ من طريق عاصم بن حكيم. وعزاه السيوطي إلى عبد بن حميد، وابن أبي حاتم.أخرجه يحيى بن سلام ١/٤٠٩.أخرجه ابن جرير ١٧/٨١، ٨٣، ٨٦، وإسحاق البستي في تفسيره ص٤٠٤.عزاه السيوطي إلى ابن أبي حاتم.أخرجه أبو إسحاق المالكي في أحكام القرآن ص١٤٤.عزاه السيوطي إلى عبد بن حميد.أخرجه سعيد بن منصور في سننه - التفسير ٦/٣٦٨ (١٥١٩).أخرجه يحيى بن سلام ١/٤٠٩ من طريق أبي الأشهب بنحوه، وابن جرير ١٧/٨١، ٨٦ كذلك من طريق معمر. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.أخرجه يحيى بن سلام ١/٤٠٩، وأخرج ابن جرير ١٧/٨٦ آخره. وعزاه السيوطي إلى عبد بن حميد، وابن أبي حاتم.أخرجه ابن جرير ١٧/٨٣، ٨٦. وعزاه السيوطي إلى عبد بن حميد، وابن أبي حاتم.أخرجه إسحاق البستي في تفسيره ص٤٠٤.أخرجه ابن جرير ١٧/٨٤.أخرجه المستغفري في طب النبي ﷺ ص٣٠٨، وابن عساكر في تاريخ دمشق ٥٥/٣٧٥.علَّقه يحيى بن سلام ١/٤٠٩.أخرجه عبد الرزاق ٢/٤٧.تفسير مقاتل بن سليمان ٣/١٦١.أخرجه ابن جرير ١٧/٨٣، ٨٥.أخرجه النسائي في الكبرى (١١٣٥١)، والحاكم ٢/٣٩٤. وعزاه السيوطي إلى ابن أبي حاتم، وابن مردويه.
  23,68,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿أَفَلَمۡ یَدَّبَّرُوا۟ ٱلۡقَوۡلَ أَمۡ جَاۤءَهُم مَّا لَمۡ یَأۡتِ ءَابَاۤءَهُمُ ٱلۡأَوَّلِینَ ۝٦٨﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥١٨٩٧<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عكرمة- في قوله: <span class="qpc-hafs">﴿أفلم يدبروا القول أم جاءهم ما لم يأت آباءهم الأولين﴾</span>، قال: لَعَمْري، لقد جاءهم ما لم يأت آباءهم الأولين، ولكن أوَلَم يأتهم ما لم يأت آباءهم الأولين؟!{1}<span class=comment-ref>٤٥٦٢</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٤٥٦٢</span> ذكر <u>ابنُ جرير</u> (١٧/٨٧) أنه: «قد يحتمل أن تكون <span class="qpc-hafs">﴿أم﴾</span> في هذا الموضع بمعنى: بل؛ فيكون تأويل الكلام: أفلم يدبروا القول؟ بل جاءهم ما لم يأت آباءهم الأولين، فتركوا لذلك التدبر وأعرضوا عنه، إذ لم يكن فيمن سلف من آبائهم ذلك. وقد ذكر عن ابن عباس في ذلك نحو هذا القول». ثم أورد قول ابن عباس المذكور.</div></p><p><div></p><p><p><span class="item-no">٥١٨٩٨<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span>، في قوله: <span class="qpc-hafs">﴿أفلم يدبروا القول﴾</span>، قال: إذن -والله- كانوا يَجِدون في القرآن زاجِرًا عن معصية الله، لو تَدَبَّرَهُ القوم وعقلوه!{2}. (١٠/٦٠٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥١٨٩٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿أفلم يدبروا القول﴾</span> يعني: أفلم يستمعوا القرآن، <span class="qpc-hafs">﴿أم جاءهم ما لم يأت آبآءهم الأولين﴾</span> يقول: قد جاء أهلَ مكة النُّذُر، كما جاء آباءهم وأجدادهم الأولين{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥١٩٠٠<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: قوله: <span class="qpc-hafs">﴿أفلم يدبروا القول﴾</span> يعني: القرآن، <span class="qpc-hafs">﴿أم جاءهم ما لم يأت آباءهم الأولين﴾</span> أي: لم يأتهم إلا ما أتى آباءهم الأولين.= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥١٩٠١<span class="dash">-</span></span> وقال <span class="name-2">السُّدِّيّ</span>: <span class="qpc-hafs">﴿أم جاءهم ما لم يأت﴾</span> يعني: الذي لم يأت آباءهم الأولين. [قال <span class="name-3">يحيى بن سلّام</span>:] وهو واحد{4}<span class=comment-ref>٤٥٦٣</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٤٥٦٣</span> ذكر <u>ابنُ عطية</u> (٦/٣١٠-٣١١) في قوله تعالى: <span class="qpc-hafs">﴿أمْ جاءَهُمْ﴾</span> معنيين: <b>الأول:</b> «أأَبْدَع لهم أمرًا لم يكن في الناس قبلهم؟! بل قد جاء الرسل قبل كنوح وإبراهيم وإسماعيل ﵈». و<span class="comment-type-4">علَّق</span> عليه بقوله: «وفي هذا التأويل مِن التَّجَوُّز أن جعل سالِف الأمم آباء، إذ الناس في الجملة آخرهم من أولهم». <b>والثاني:</b> أن المراد بـ<span class="qpc-hafs">﴿آباءهم الأولين﴾</span> «مَن فَرَط مِن سلفهم في العرب. كأنه قال: أفلم يدَّبَّروا القول أم جاءهم أمر غريب من عند الله لم يأت آباءهم فبهر عقولهم، ونَبَتْ عنه أذهانهم». و<span class="comment-type-4">علَّق</span> عليه بقوله: «فكأن التوبيخ يتَّسِق بأن يُقدَّر الكلام: أفلم يدَّبَّروا أم بُهرت عقولهم ونَبَتْ أذهانهم عن أمر من أمور الله غريب في سلفهم». ثم <span class="comment-type-4">علَّق</span> على القول الأول بقوله: «والمعنى الأول أبْيَن».</div></p></div>",footnotes:1:أخرجه ابن جرير ١٧/٨٧.عزاه السيوطي إلى ابن أبي حاتم.تفسير مقاتل بن سليمان ٣/١٦١.تفسير يحيى بن سلام ١/٤٠٩.
  23,69,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿أَمۡ لَمۡ یَعۡرِفُوا۟ رَسُولَهُمۡ فَهُمۡ لَهُۥ مُنكِرُونَ ۝٦٩﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥١٩٠٢<span class="dash">-</span></span> قال <span class="name-1">عبد الله بن عباس</span>: أليس قد عَرَفوا محمدًا ﷺ صغيرًا وكبيرًا، وعرفوا نسبَه وصدقَه وأمانتَه ووفاءَه بالعهود؟!{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥١٩٠٣<span class="dash">-</span></span> عن <span class="name-2">عبد الرحمن بن أبي ليلى</span> -من طريق سفيان الثوري، عن رجل- في قوله: <span class="qpc-hafs">﴿أم لم يعرفوا رسولهم فهم له منكرون﴾</span>، قال: قد عرفوه، ولكنهم حَسَدُوه{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥١٩٠٤<span class="dash">-</span></span> عن <span class="name-2">أبي صالح [باذام]</span>، في قوله: <span class="qpc-hafs">﴿أم لم يعرفوا رسولهم﴾</span>، قال: عرفوه، ولكن حسدوه{3}. (١٠/٦٠٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥١٩٠٥<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿فهم له منكرون﴾</span>، قال: بل يعرفون وجْهَه، ونَسَبَه{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥١٩٠٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿أم لم يعرفوا رسولهم﴾</span> يعني: محمدًا ﷺ بوجهه ونسبه؛ <span class="qpc-hafs">﴿فهم له منكرون﴾</span> فلا يعرفونه؟! بل يعرفونه{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥١٩٠٧<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: قوله: <span class="qpc-hafs">﴿أم لم يعرفوا رسولهم﴾</span>، أي: الذي [أرسله] إليهم، يعني: محمدًا{6}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير البغوي ٥/٤٢٣.تفسير الثوري ص٢١٧.عزاه السيوطي إلى ابن أبي شيبة، وعبد بن حميد، وابن المنذر، ابن جرير، وابن أبي حاتم.أخرجه يحيى بن سلام ١/٤١٠.تفسير مقاتل بن سليمان ٣/١٦١.تفسير يحيى بن سلام ١/٤١٠.
  23,70,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿أَمۡ یَقُولُونَ بِهِۦ جِنَّةُۢۚ بَلۡ جَاۤءَهُم بِٱلۡحَقِّ وَأَكۡثَرُهُمۡ لِلۡحَقِّ كَـٰرِهُونَ ۝٧٠﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥١٩٠٨<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿أم يقولون به جنة﴾</span> قالوا: إنّ بمحمد جنونًا، يقول الله ﷿: <span class="qpc-hafs">﴿بل جاءهم﴾</span> محمد ﷺ <span class="qpc-hafs">﴿بالحق﴾</span> يعني: بالتوحيد، <span class="qpc-hafs">﴿وأكثرهم للحق﴾</span> يعني: التوحيد <span class="qpc-hafs">﴿كارهون﴾</span>{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥١٩٠٩<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: قوله: <span class="qpc-hafs">﴿أم يقولون به جنة﴾</span> أي: بمحمد جنون. أي: قد قالوا ذلك. قال الله: <span class="qpc-hafs">﴿بل جاءهم بالحق﴾</span> القرآن، <span class="qpc-hafs">﴿وأكثرهم للحق كارهون﴾</span> يعني: جماعة مَن لم يؤمِن منهم{2}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٣/١٦١.تفسير يحيى بن سلام ١/٤١٠.
  23,71,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَلَوِ ٱتَّبَعَ ٱلۡحَقُّ أَهۡوَاۤءَهُمۡ لَفَسَدَتِ ٱلسَّمَـٰوَ ٰ⁠تُ وَٱلۡأَرۡضُ وَمَن فِیهِنَّۚ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥١٩١٠<span class="dash">-</span></span> تفسير <span class="name-2">الحسن البصري</span>: لو كان الحقُّ في أهوائهم لوَقَعَتْ أهواؤهم على هلاك السموات والأرض ومَن فيهنَّ{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥١٩١١<span class="dash">-</span></span> عن <span class="name-2">أبي صالح [باذام]</span> -من طريق إسماعيل بن أبي خالد- في قوله: <span class="qpc-hafs">﴿ولو اتبع الحق أهواءهم﴾</span>، قال: الحقُّ هو الله ﷿{2}. (١٠/٦٠٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥١٩١٢<span class="dash">-</span></span> قال <span class="name-2">إسماعيل السُّدِّيّ</span>: الحق هو الله{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥١٩١٣<span class="dash">-</span></span> قال <span class="name-3">محمد بن السائب الكلبي</span> -من طريق معمر- في قوله تعالى: <span class="qpc-hafs">﴿ولو اتبع الحق أهواءهم﴾</span> قال: يقول: لو اتبع الله أهواءهم <span class="qpc-hafs">﴿لفسدت السموات والأرض﴾</span>{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥١٩١٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: يقول الله ﷿: <span class="qpc-hafs">﴿ولو اتبع الحق أهواءهم﴾</span> يعني: لو اتَّبع اللهُ أهواء كفار مكة، فجعل مع نفسه شريكًا؛ <span class="qpc-hafs">﴿لفسدت﴾</span> يعني: لهلكت <span class="qpc-hafs">﴿السماوات والأرض ومن فيهن﴾</span> مِن الخلق{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥١٩١٥<span class="dash">-</span></span> عن <span class="name-3">عبد الملك ابن جريج</span> -من طريق حجاج- قوله: <span class="qpc-hafs">﴿ولو اتبع الحق أهواءهم﴾</span>، قال: الحقُّ اللهُ{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥١٩١٦<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: قوله: <span class="qpc-hafs">﴿ولو اتبع الحق أهواءهم﴾</span> أهواء المشركين؛ <span class="qpc-hafs">﴿لفسدت﴾</span> يعني: لهلكت <span class="qpc-hafs">﴿السموات والأرض ومن فيهن﴾</span> ... وقال بعضهم: الحق هاهنا: الله، كقوله: <span class="qpc-hafs">﴿وتواصوا بالحق﴾</span> يعني بالحق: الله، <span class="qpc-hafs">﴿وتواصوا بالصبر﴾</span> [العصر:٤] على فرائضه{1}<span class=comment-ref>٤٥٦٤</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٤٥٦٤</span> <span class="comment-type-2">انتقد</span> <u>ابنُ عطية</u> (٦/٣١١) <span class="mustanad">مستندًا إلى الدلالة العقلية</span> قولَ أبي صالح، والسدي، والكلبي، ومقاتل، ويحيى بن سلام، فقال: «وهذا ليس من نمط الآية». ثم قال أيضًا (٦/٣١١-٣١٢): «ومَن قال: إن الحق في الآية: الله تعالى؛ تشعَّبَتْ له لفظة <span class="qpc-hafs">﴿اتَّبَعَ﴾</span>، وصَعُبَ عليه ترتيبُ الفساد المذكور في الآية؛ لأن لفظة الاتِّباع -على كلا الوجهين- إنما هي استعارة بمعنى أن تكون أهواؤهم يصونها الحق ويقررها، فنحن نجد الله تعالى قد قدَّر كُفْرَ أمم وأهواءهم، فليس في ذلك فساد سماوات، وأما الحق نفسه الذي هو الصواب فلو كان طبْق أهوائهم لفسد كلُّ شيءٍ. فتأمَّلْه». وذكر <b>قولًا آخر</b> ولم ينسبه، وهو أنّ الحق هنا: الصواب والمستقيم، و<span class="comment-type-3">رجَّحه</span> (٦/٣١١ بتصرف) بقوله: «وهذا هو الأحرى». ثم <span class="comment-type-4">علَّق</span> بقوله: «على أن يكون الحقّ المذكور في قوله تعالى: <span class="qpc-hafs">﴿بَلْ جاءَهُمْ بِالحَقِّ وأَكْثَرُهُمْ لِلْحَقِّ كارِهُونَ﴾</span> هو: الذي جاء به محمد رسول الله ﷺ». ثم بيَّن <span class="comment-type-1">وجْه</span> فساد السماوات والأرض في الآية بناءً على هذا المعنى، فقال: «ويستقيم -على هذا- فساد السماوات والأرض ومن فيهن لو كان بحكم هوى هؤلاء، وذلك أنهم جعلوا لله شركاء وأولادًا، ولو كان هذا حقًّا لم تكن لله -تبارك وتعالى- الصِّفات العَلِيَّة، ولو لم يَكُن له لم تَكُن له الصنعة ولا القدرة، وكان ذلك فساد السماوات والأرض ومن فيهن».</div></p><p><h3><span class="qpc-hafs">﴿بَلۡ أَتَیۡنَـٰهُم بِذِكۡرِهِمۡ فَهُمۡ عَن ذِكۡرِهِم مُّعۡرِضُونَ ۝٧١﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥١٩١٧<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي بن أبي طلحة- في قوله: <span class="qpc-hafs">﴿بل أتيناهم بذكرهم﴾</span>، قال: بيَّنّا لهم{8}. (١٠/٦٠٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥١٩١٨<span class="dash">-</span></span> قال <span class="name-1">عبد الله بن عباس</span>: أي: بما فيه فخرُهم وشَرَفُهم{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥١٩١٩<span class="dash">-</span></span> قال <span class="name-2">الحسن البصري</span>: يعني: القرآن، أنزلنا عليهم فيه ما يأتون، وما يتَّقون، وما يُحَرِّمون، وما يُحِلُّون{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥١٩٢٠<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق مَعْمَر- في قوله: <span class="qpc-hafs">﴿بل أتيناهم بذكرهم﴾</span>، قال: هذا القرآن{11}. (١٠/٦٠٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥١٩٢١<span class="dash">-</span></span> قال <span class="name-2">إسماعيل السُّدِّيّ</span>: <span class="qpc-hafs">﴿بل أتيناهم بذكرهم﴾</span>: بشرفهم، <span class="qpc-hafs">﴿فهم عن ذكرهم﴾</span> يعني: عن شرفهم <span class="qpc-hafs">﴿معرضون﴾</span>{12}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥١٩٢٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: يقول الله ﷿: <span class="qpc-hafs">﴿بل أتيناهم بذكرهم﴾</span> يعني: بشرفهم، يعني: القرآن، <span class="qpc-hafs">﴿فهم عن ذكرهم معرضون﴾</span> يعني: القرآن مُعْرِضون عنه فلا يُؤْمِنون به{13}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥١٩٢٣<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: قال: <span class="qpc-hafs">﴿بل أتيناهم بذكرهم﴾</span> بشرفهم؛ شرف لِمَن آمن به، <span class="qpc-hafs">﴿فهم عن ذكرهم﴾</span> عما بَيَّنّا لهم <span class="qpc-hafs">﴿معرضون﴾</span>... = (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥١٩٢٤<span class="dash">-</span></span> قال يحيى: سمعت <span class="name-3">سفيان الثوري</span> يذكر في هذه الآية: <span class="qpc-hafs">﴿لقد أنزلنا إليكم كتابا فيه ذكركم﴾</span> [الأنبياء:١٠]: فيه شَرَفُكم{14}<span class=comment-ref>٤٥٦٥</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٤٥٦٥</span> <span class="comment-type-4">علَّق</span> <u>ابن جرير</u> (١٧/٨٩-٩٠) على قول ابن عباس من طريق علي بن أبي طلحة وما في معناه، وقول السدي وما في معناه بقوله: «وهذان القولان متقاربا المعنى؛ وذلك أنّ الله -جلَّ ثناؤه- أنزل هذا القرآن بيانًا بيَّن فيه ما لِخَلْقِه إليه الحاجة من أمر دينهم، وهو مع ذلك ذِكْرٌ لرسول الله ﷺ وقومه، وشرفٌ لهم».</div></p></div>",footnotes:1:علَّقه يحيى بن سلام ١/٤١٠.أخرجه ابن جرير ١٧/٨٩. وعزاه السيوطي إلى ابن أبي شيبة، وعبد بن حميد، وابن المنذر، وابن أبي حاتم. وأخرج نحوه ابن جرير ١٧/٨٩ من طريق السدي.تفسير البغوي ٥/٤٢٤.أخرجه عبد الرزاق ٢/٤٧.تفسير مقاتل بن سليمان ٣/١٦١. وفي تفسير البغوي ٥/٤٢٤ قال مقاتل: الحق هو الله.أخرجه ابن جرير ١٧/٨٩.علَّقه يحيى بن سلام ١/٤١٠.أخرجه ابن جرير ١٧/٨٩. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.تفسير البغوي ٥/٤٢٤.علَّقه يحيى بن سلام ١/٤١٠.أخرجه عبد الرزاق ٢/٤٨. وعلَّقه يحيى بن سلام ١/٤١٠ وزاد: <span class="qpc-hafs">﴿معرضون﴾</span> عن القرآن. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.علَّقه يحيى بن سلام ١/٤١١.تفسير مقاتل بن سليمان ٣/١٦١.تفسير يحيى بن سلام ١/٤١٠-٤١١.
  23,72,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿أَمۡ تَسۡـَٔلُهُمۡ خَرۡجࣰا فَخَرَاجُ رَبِّكَ خَیۡرࣱۖ وَهُوَ خَیۡرُ ٱلرَّ ٰ⁠زِقِینَ ۝٧٢﴾</span> - قراءات</h3></p><p><div></p><p><p><span class="item-no">٥١٩٢٥<span class="dash">-</span></span> عن <span class="name-2">عاصم</span> أنّه قرأ: <span class="qpc-hafs">﴿أمْ تَسْأَلُهُمْ خَرْجًا﴾</span> بغير ألف، <span class="qpc-hafs">﴿فَخَراجُ رَبِّكَ﴾</span> بالألف{1}. (١٠/٦٠٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥١٩٢٦<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> أنه قرأ: ‹أمْ تَسْأَلُهُمْ خَراجًا فَخَراجُ رَبِّكَ خَيْرٌ› {2}. (١٠/٦٠٩)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿أَمۡ تَسۡـَٔلُهُمۡ خَرۡجࣰا﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥١٩٢٧<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span>، قال: الخَرْجُ وما قبلها مِن القصة لكُفّار قريش{3}. (١٠/٦٠٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥١٩٢٨<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق مَعْمَر- في قوله: <span class="qpc-hafs">﴿خرجا﴾</span>، قال: أجرًا{4}. (١٠/٦٠٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥١٩٢٩<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span>، في قوله: <span class="qpc-hafs">﴿أم تسألهم خرجا﴾</span>، يقول: أم تسألهم على ما أتيناهم به جُعْلًا{5}. (١٠/٦٠٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥١٩٣٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿أم تسألهم﴾</span> يا محمد <span class="qpc-hafs">﴿خرجا﴾</span> أجرًا على الإيمان بالقرآن{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥١٩٣١<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: قوله: <span class="qpc-hafs">﴿أم تسألهم خرجا﴾</span>، أي: إنك لا تسألهم عليه أجرًا{7}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿فَخَرَاجُ رَبِّكَ خَیۡرࣱۖ وَهُوَ خَیۡرُ ٱلرَّ ٰ⁠زِقِینَ ۝٧٢﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥١٩٣٢<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: قال: <span class="qpc-hafs">﴿فخراج ربك خير﴾</span> أجرُ ربك، أي: ثوابه في الآخرة خيرٌ من أجرهم لو أعطوك في الدنيا أجرًا. قال: <span class="qpc-hafs">﴿وهو خير الرازقين﴾</span> وقد يجعل الله رزق العباد بعضهم من بعض، يرزق الله إيّاهم، يقسم رزق هذا على يَدَيْ هذا، <span class="qpc-hafs">﴿وهو خير﴾</span> أفضل <span class="qpc-hafs">﴿الرازقين﴾</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥١٩٣٣<span class="dash">-</span></span> وهو تفسير <span class="name-2">السُّدِّيّ</span>{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥١٩٣٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فخراج ربك﴾</span> يعني: فأجر ربك <span class="qpc-hafs">﴿خير﴾</span> يعني: أفضل مِن خراجهم، <span class="qpc-hafs">﴿وهو خير الرازقين﴾</span>{6}<span class=comment-ref>٤٥٦٦</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٤٥٦٦</span> ذكر <u>ابنُ عطية</u> (٦/٣١٣) أن معنى قوله تعالى: <span class="qpc-hafs">﴿فَخَراجُ رَبِّكَ﴾</span>: ثوابه، سمّاه: خراجًا من حيث كان معادلًا للخراج في هذا الكلام«. ثم ذكر <b>احتمالًا</b> آخر، فقال:»ويحتمل أن يريد بخراج ربك: رزق ربك«. <span class="comment-type-4">وعلَّق</span> عليه بقوله:»<span class="mustanad">ويؤيد هذا قوله تعالى</span>: <span class="qpc-hafs">﴿وهُوَ خَيْرُ الرّازِقِينَ﴾</span>".</div></p><p><h3><span class="qpc-hafs">﴿فَخَرَاجُ رَبِّكَ خَیۡرࣱۖ وَهُوَ خَیۡرُ ٱلرَّ ٰ⁠زِقِینَ ۝٧٢﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٥١٩٣٥<span class="dash">-</span></span> عن <span class="name-1">أُمِّ الدَّرداء</span> -من طريق عثمان بن حيّان- قالت: ما بال أحدكم يقول: اللَّهُمَّ، ارزقني. وقد علِم أنّ الله لا يُمْطِر عليه مِن السماء دنانير ولا دراهم، وإنما يرزق بعضكم من بعض، فمَن ساق الله إليه رزقًا فليقبله، وإن لم يكن إليه محتاجًا فلْيُعْطِهِ في أهل الحاجة مِن إخوانه، وإن كان محتاجًا استعان به على حاجته، ولا يرد على الله رزقه الذي رزقه{10}. (ز)</p></p><p></div></p></div>",footnotes:1:عزاه السيوطي إلى عبد بن الحميد.</p><p>و<span class="qpc-hafs">﴿أمْ تَسْأَلُهُمْ خَرْجًا فَخَراجُ رَبِّكَ﴾</span> بغير ألف في الأول، وبالألف في الثاني قراءة العشرة ما عدا ابن عامر، فإنه قرأ: ‹أمْ تَسْأَلُهُمْ خَرْجًا فَخَرْجُ رَبِّكَ› بإسقاط الألف فيهما، وما عدا حمزة والكسائي، فإنهما قرآ: ‹أمْ تَسْأَلُهُمْ خَراجًا فَخَراجُ رَبِّكَ› بالألف فيهما. انظر: الإتحاف ص٤٠٥.عزاه السيوطي إلى ابن أبي شيبة، وابن المنذر.عزاه السيوطي إلى عبد بن حميد.أخرجه عبد الرزاق ٢/٤٨، وابن جرير ١٧/٩٠-٩١. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.علَّقه يحيى بن سلام ١/٤١١. وعزاه السيوطي إلى عبد الرزاق، وعبد بن حميد، وابن المنذر، وابن أبي حاتم.تفسير مقاتل بن سليمان ٣/١٦٢.تفسير يحيى بن سلام ١/٤١١.تفسير يحيى بن سلام ١/٤١١.تفسير مقاتل بن سليمان ٣/١٦٢.أخرجه يحيى بن سلام ١/٤١١.
  23,73,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَإِنَّكَ لَتَدۡعُوهُمۡ إِلَىٰ صِرَ ٰ⁠طࣲ مُّسۡتَقِیمࣲ ۝٧٣﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥١٩٣٦<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span>، في قوله: <span class="qpc-hafs">﴿وانك لتدعوهم إلى صراط مستقيم﴾</span>، قال: ما فيه عِوَج. ذُكِر لنا: أنّ نبيَّ الله ﷺ لَقِي رجلًا، فقال له: «<b>أسلِم</b>». فتَصَعَّد{1} له ذلك، وكَبُر عليه، فقال له النبيُّ ﷺ: «<b>أرأيتَ لو كنتَ في طريق وعر وعث</b>{2}، <b>فلقيت رجلًا تعرف وجهَه وتعرف نسبَه، فدعاك إلى طريق واسع سهل أكنت تتبعه</b>؟». قال: نعم. قال: «<b>فوالذي نفسُ محمد بيده، إنّك لَفي أوعَرَ مِن ذلك الطريق لو كنتَ فيه، إنِّي لأدعوك إلى أسهل من ذلك الطريق لو دُعِيت إليه</b>». وذُكِر لنا: أنّ النبيَّ ﷺ لقي رجلًا، فقال له: «<b>أسلِم</b>». فصَعَّدَه ذلك، فقال له نبي ﷺ: «<b>أرأيت فَتَيَيْك؛ أحدهما: إن حدَّثَك صَدَقَكَ، وإن ائْتَمَنتَهُ أدّى اليك، والآخر: إن حدَّثَك كَذَبَك، وان ائتمنته خانك</b>؟». قال: بلى، فتاي الذي إذا حدثني صَدَقَني، وإن ائتمنته أدّى إلَيَّ. قال نبيُّ الله ﷺ: «<b>كذاكم أنتم عند ربكم</b>»{3}. (١٠/٦١٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥١٩٣٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وإنك لتدعوهم إلى صراط مستقيم﴾</span>، يعني: الإسلام لا عوج فيه{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥١٩٣٨<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: قوله: <span class="qpc-hafs">﴿وإنك لتدعوهم إلى صراط مستقيم﴾</span> إلى دين مستقيم، وهو الطريق إلى الجنة{5}. (ز)</p></p><p></div></p></div>",footnotes:1:تَصعَّده الأمر: شَقَّ عليه وصَعُب. النهاية (صعد) ٣/٣٠.وعث الطريق: تعسر سلوكه. ينظر: اللسان (وعث).عزاه السيوطي إلى عبد بن حميد، وابن أبي حاتم. وأورده ابن كثير في تفسيره ٥/٤٨٤ عن قتادة.تفسير مقاتل بن سليمان ٣/١٦٢.تفسير يحيى بن سلام ١/٤١٢.
  23,74,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَإِنَّ ٱلَّذِینَ لَا یُؤۡمِنُونَ بِٱلۡـَٔاخِرَةِ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥١٩٣٩<span class="dash">-</span></span> تفسير <span class="name-2">إسماعيل السُّدِّيّ</span>: قوله: <span class="qpc-hafs">﴿وإن الذين لا يؤمنون بالآخرة﴾</span>، يعني: بالبعث يوم القيامة{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥١٩٤٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وإن الذين لا يؤمنون بالآخرة﴾</span>، يعني: لا يُصَدِّقون بالبَعْث{2}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿عَنِ ٱلصِّرَ ٰ⁠طِ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥١٩٤١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- قوله: <span class="qpc-hafs">﴿وإن الذين لا يؤمنون بالآخرة عن الصراط لناكبون﴾</span>، يقول: عن الحقِّ{3}<span class=comment-ref>٤٥٦٧</span>. (١٠/٦١٠)</p></p><p></div></p><p><div><span class=comment-ref>٤٥٦٧</span> لم يذكر <u>ابنُ جرير</u> (١٧/٩١-٩٢) في معنى قوله تعالى: <span class="qpc-hafs">﴿عَنِ الصِّراطِ لَناكِبُونَ﴾</span> سوى قول ابن عباس.</div></p><p><div></p><p><p><span class="item-no">٥١٩٤٢<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span>، في قوله: <span class="qpc-hafs">﴿وإن الذين لا يؤمنون بالآخرة عن الصراط لناكبون﴾</span>، قال: عن الحقِّ{4}. (١٠/٦١٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥١٩٤٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿عن الصراط﴾</span>، يعني: عن الدِّين{2}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿لَنَـٰكِبُونَ ۝٧٤﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥١٩٤٤<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- قوله: <span class="qpc-hafs">﴿لناكبون﴾</span>، يقول: عادِلون{6}. (١٠/٦١٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥١٩٤٥<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span>، في قوله: <span class="qpc-hafs">﴿لناكبون﴾</span>، قال: لَحائِدون{4}. (١٠/٦١٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥١٩٤٦<span class="dash">-</span></span> قال <span class="name-2">الحسن البصري</span>: تاركون له= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥١٩٤٧<span class="dash">-</span></span> وقال <span class="name-3">محمد بن السائب الكلبي</span>: مُعْرِضون عنه{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥١٩٤٨<span class="dash">-</span></span> في تفسير <span class="name-2">قتادة بن دعامة</span>: <span class="qpc-hafs">﴿عن الصراط لناكبون﴾</span>: لجائرون{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥١٩٤٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿لناكبون﴾</span> لعادلون{2}. (ز)</p></p><p></div></p></div>",footnotes:1:علَّقه يحيى بن سلام ١/٤١٢.تفسير مقاتل بن سليمان ٣/١٦٢.أخرجه ابن جرير ١٧/٩١-٩٢، ومن طريق عطاء الخراساني مختصرًا، وابن أبي حاتم -كما في الإتقان ٢/٣١-. وعزاه السيوطي إلى ابن المنذر.عزاه السيوطي إلى عبد بن حميد.تفسير مقاتل بن سليمان ٣/١٦٢.أخرجه ابن جرير ١٧/٩١-٩٢ كذلك من طريق عطاء الخراساني، وابن أبي حاتم -كما في الإتقان ٢/٣١-. وعزاه السيوطي إلى ابن المنذر.عزاه السيوطي إلى عبد بن حميد.علَّقه يحيى بن سلام ١/٤١٢، وعقَّب على قوليهما بقوله: وهو واحد.علَّقه يحيى بن سلام ١/٤١٢.تفسير مقاتل بن سليمان ٣/١٦٢.