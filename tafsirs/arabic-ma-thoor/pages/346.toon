tafsir[15]{c,v,t}:
23,60," <q>﴿وَٱلَّذِینَ یُؤۡتُونَ مَاۤ ءَاتَوا۟ وَّقُلُوبُهُمۡ وَجِلَةٌ أَنَّهُمۡ إِلَىٰ رَبِّهِمۡ رَ ٰ⁠جِعُونَ ۝٦٠﴾</q> - قراءات ٥١٧٦٧- عن عائشة، عن النبي ﷺ أنّه قرأ: (والَّذِينَ يَأْتُونَ مَآ أتَوْاْ) مقصور، مِن المجيء{1}. (١٠/٦٠٢) ٥١٧٦٨- عن عبيد بن عمير أنّه سأل عائشة: كيف كان رسول الله ﷺ يقرأ هذه الآية: <q>﴿والَّذِينَ يُؤْتُونَ مَآ آتَوْا﴾</q> أو: (والَّذِينَ يَأْتُونَ مَآ أتَوْاْ)؟ فقالت: أيتهما أحبُّ اليك؟ قلت: والذي نفسي بيده، لإحداهما أحبُّ إلَيَّ مِن الدنيا جميعًا. قالت: أيتهما؟ قلت: (والَّذِينَ يَأْتُونَ مَآ أتَوْاْ). فقالت: أشهد أنّ رسول الله ﷺ كذلك كان يقرأها، وكذلك أُنزِلت، ولكن الهجاء حُرِّفَ{2}. (١٠/٦٠٢) ٥١٧٦٩- عن ابن أبي مليكة، قال: قالت عائشة: لَأن تكون هذه الآيةُ كما أقرأ أحَبُّ إلَيَّ مِن حُمُر النَّعَم. فقال لها ابن عباس: ما هي؟ قالت: <q>﴿والَّذِينَ يُؤْتُونَ مَآ آتَوْا﴾</q>{3}. (١٠/٦٠٢) ٥١٧٧٠- عن عبد الله بن عباس= (ز) ٥١٧٧١- وعائشة -من طريق عبد الله بن أبي مليكة- أنهما كانا يقرآن هذا الحرف: (والَّذِينَ يُؤْتُونَ{4} مَآ أتَوْاْ)، خفيفة بغير مد، أي: يعملون ما عملوا مِمّا نُهُوا عنه، <q>﴿وقُلُوبُهُمْ وجِلَةٌ﴾</q> خائفة أن يُؤخَذوا به{5}. (ز) <q>﴿وَٱلَّذِینَ یُؤۡتُونَ مَاۤ ءَاتَوا۟ وَّقُلُوبُهُمۡ وَجِلَةٌ أَنَّهُمۡ إِلَىٰ رَبِّهِمۡ رَ ٰ⁠جِعُونَ ۝٦٠﴾</q> - تفسير الآية ٥١٧٧٢- عن عائشة، قالت: قلت: يا رسول الله، قولُ الله: <q>﴿والذين يؤتون ما آتوا وقلوبهم وجلة﴾</q>، أهو الرجل يسرق ويزني ويشرب الخمر، وهو مع ذلك يخاف الله؟ قال: «لا، ولكن الرجل يصوم ويتصدق ويصلي، وهو مع ذلك يخاف الله ألا يُتَقَبَّل منه»{6}. (١٠/٥٩٩) ٥١٧٧٣- عن أبي هريرة، قال: قالت عائشة: يا رسول الله، <q>﴿والذين يؤتون ما آتوا وقلوبهم وجلة﴾</q>، أهم الذين يُخْطِئون ويعملون بالمعاصي؟ -وفي لفظ: هو الذي يُذنِب الذنبَ وهو وجِلٌ منه؟-. قال: «لا، ولكن هم الذين يُصَلُّون، ويصومون، ويتصدقون، وقلوبهم وجلة»{7}. (١٠/٦٠٠) ٥١٧٧٤- عن عائشة -من طريق أبي جعفر الأشجعي- <q>﴿والذين يؤتون ما آتوا﴾</q>، قالت: هم الذين يخشون الله ويطيعونه{8}. (١٠/٦٠١) ٥١٧٧٥- عن عبد الله بن عباس -من طريق مجاهد- في قوله: <q>﴿والذين يؤتون ما آتوا﴾</q>، قال: يُعْطُون ما أعْطَوْا{9}. (١٠/٦٠٠) ٥١٧٧٦- عن عبد الله بن عباس، في قوله: <q>﴿والذين يؤتون ما آتوا﴾</q>، قال: يتَصَدَّقون، ويُنفِقون{10}. (١٠/٦٠٠) ٥١٧٧٧- عن عبد الله بن عباس -من طريق علي- في قوله: <q>﴿والذين يؤتون ما آتوا وقلوبهم وجلة﴾</q>، قال: يعملون خائفين{11}. (١٠/٦٠٠) ٥١٧٧٨- عن عبد الله بن عباس -من طريق العوفي- قوله: <q>﴿والذين يؤتون ما آتوا وقلوبهم وجلة﴾</q> يقول: خائفة؛ <q>﴿أنهم إلى ربهم راجعون﴾</q> قال: هو المؤمن يَتَصَدَّق ويُنفِق، ويعلم أنّه راجِعٌ إلى رَبِّه{12}. (ز) ٥١٧٧٩- عن عبد الله بن عمر -من طريق ابن أبْجر، عن رجل- في قوله: <q>﴿والذين يؤتون ما آتوا﴾</q>، قال: الزكاة{13}. (١٠/٦٠١) ٥١٧٨٠- عن سعيد بن جبير، <q>﴿والذين يؤتون ما آتوا﴾</q> قال: يعطون ما أعطوا <q>﴿وقلوبهم وجلة﴾</q> قال: مِمّا يخافون مِمّا بين أيديهم مِن الموقف، وسوء الحساب{14}. (١٠/٦٠١) ٥١٧٨١- عن سعيد بن جبير -من طريق سالم الأفطس- في قوله: <q>﴿والذين يؤتون ما آتوا وقلوبهم وجلة﴾</q>، قال: يفعلون ما يفعلون وهم يعلمون أنّهم صائِرون إلى الموت، وهي مِن المُبَشِّرات{15}٤٥٤٩. (ز) ٤٥٤٩ خصَّص بعضُ المفسرين الإيتاء بالمال، وأفاد قولُ ابن عباس، وسعيدُ بن جبير عمومَ معنى الإيتاء في المال وغيره. وعلَّق ابنُ عطية (٦/٣٠٣) على قولهما بقوله: «وهذا حسن، كأنه قال: والذين يعطون من أنفسهم في طاعة الله ما بلغه جهدهم». ثم ذكر قراءةً أخرى، وهي: (يَأْتُونَ ما أتَوْا)، من الإتيان، بمعنى: يفعلون ما فعلوا، ونقل عن فرقةٍ بأن معناه: يفعلون ما فعلوا من المعاصي. ونقل عن فرقةٍ أخرى: بأن ذلك في جميع الأعمال طاعتها ومعصيتها. وعلَّق على هذا القول بقوله: «وهذا أمدح». ثم ذكر حديث عائشة ﵂، ورجَّحه مستندًا إليه قائلًا: «ولا نظر مع الحديث». ٥١٧٨٢- عن مجاهد بن جبر -من طريق أبي يحيى- <q>﴿والذين يؤتون ما آتوا﴾</q> قال: يُعْطُون ما أعْطَوا <q>﴿وقلوبهم وجلة﴾</q> قال: المؤمن ينفق مالَه، وقلبُه وجِلٌ{16}٤٥٥٠. (١٠/٦٠١) ٤٥٥٠ وجَّه ابنُ عطية (٦/٣٠٣) قول ابن عمر، ومجاهد ومَن وافقهما في تخصيص الإيتاء بالمال بقوله: «وإنّما ضَمَّهم إلى هذا التخصيص أنّ العطاء مستعمل في المال على الأغلب». ٥١٧٨٣- عن مجاهد بن جبر -من طريق أبي يحيى- قال: يعملون ما عمِلوا من الخير، وهم يخافون ألّا يُقبَل منهم{5}. (ز) ٥١٧٨٤- عن الضَّحّاك بن مُزاحِم -من طريق عبيد- في قوله: <q>﴿يؤتون ما آتوا﴾</q>، قال: يُنفِقون ما أنفقوا{18}. (ز) ٥١٧٨٥- عن عكرمة مولى ابن عباس -من طريق يزيد النحوي- <q>﴿يؤتون ما آتوا﴾</q> قال: يُعْطُون ما أعْطَوا <q>﴿وقلوبهم وجلة﴾</q> يقول: خائفة{19}. (ز) ٥١٧٨٦- عن الحسن البصري -من طريق يونس- قال: إنّ المؤمن جَمَع إحسانًا وشفقة، وإنّ المنافق جمع إساءة وأَمْنًا. ثم تلا: <q>﴿ان الذين هم من خشية ربهم مشفقون﴾</q> إلى قوله: <q>﴿أنهم إلى ربهم راجعون﴾</q>، وقال المنافق: <q>﴿إنما أوتيته على علم عندي﴾</q> [القصص:٧١]{20}. (١٠/٥٩٩) ٥١٧٨٧- عن الحسن البصري= (ز) ٥١٧٨٨- وقتادة بن دعامة -من طريق مَعْمَر- أنّهما كانا يقرآن: <q>﴿يؤتون ما آتوا﴾</q>، قال: يعملون ما عمِلوا من الخيرات، ويُعْطُون ما أعْطَوْا على خوفٍ مِن الله ﷿{21}. (١٠/٦٠١) ٥١٧٨٩- عن الصَّلت السرّاج، قال: سمعتُ الحسن البصري يقول: (يَأْتُون ما أتوا)، يصوم، ويصلي، ولا يزيده ذلك إلا خوفًا، والمنافق يعمل السوء ويَتَمَنّى على الله{22}. (ز) ٥١٧٩٠- عن الحسن البصري -من طريق أبي الأشهب- <q>﴿والذين يؤتون ما آتوا وقلوبهم وجلة﴾</q>، قال: كانوا يعملون ما يعملون مِن أعمال البِرِّ، وهم يخافون أن لا ينجيهم ذلك مِن عذاب ربهم{23}٤٥٥١. (١٠/٦٠١) ٤٥٥١ علَّق ابنُ عطية (٦/٣٠٥) على قول الحسن بقوله: «وهذه عبارة حسنة». ٥١٧٩١- قال مقاتل بن سليمان: <q>﴿والذين يؤتون ما آتوا﴾</q> يعني: يعطون ما أعطوا مِن الصدقات والخيرات، <q>﴿وقلوبهم وجلة﴾</q> يعني: خائفة لله مِن عذابه، يعلمون <q>﴿أنهم إلى ربهم راجعون﴾</q> في الآخرة، فيعملون على عِلْم، فيجزيهم بأعمالهم، فكذلك المؤمن ينفق ويتصدق وجِلًا مِن خشية الله ﷿{24}. (ز) ٥١٧٩٢- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- <q>﴿يؤتون ما آتوا وقلوبهم وجلة﴾</q>، قال: يُعْطُون ما أعْطَوا، ويُنفِقون ما أنفقوا، ويَتَصَدَّقون بما تَصَدَّقوا، وقلوبهم وجِلة، اتقاءً لسَخَط الله والنار. وفي لفظ: يعطون ما أعطوا فَرَقًا مِن الله، ووَجَلًا مِن الله{18}. (ز) ٥١٧٩٣- قال يحيى بن سلّام: <q>﴿وقوبهم وجلة﴾</q>: خائفة{26}. (ز) ",footnotes:1:أخرجه الثعلبي ٧/٥٠. وعزاه السيوطي إلى سعيد بن منصور، وابن مردويه. وهي قراءة شاذة، تروى أيضًا عن عائشة، وابن عباس ﵃، وقتادة، والأعمش. انظر: مختصر ابن خالويه ص١٠٠، والمحتسب ٢/٩٥.أخرجه أحمد ٤١/١٨٥ (٢٤٦٤١)، ٤٢/٥١-٥٢ (٢٥١١٥، ٢٥١١٦)، واللفظ له، والحاكم ٢/٢٥٦ (٢٩٢٣)، ٢/٢٦٩ (٢٩٦٩) من طريقين عن عبيد بن عمير. قال الدارقطني في الثاني من الأفراد (٤): «غريب مِن حديث عبد الله بن عبيد بن عمير عن أبيه عن عائشة، وهو غريب من حديث خالد بن مهران الحذاء عنه، تفرَّد به يحيى بن راشد عن خالد عنه». وقال الحاكم: «هذا حديث صحيح الإسناد، ولم يخرجاه». وقال الذهبي في التلخيص: «يحيى بن راشد ضعيف». وقال ابن كثير في تفسيره عقب ذكر طريق أحمد ٥/٤٨١: «فيه إسماعيل بن مسلم المكي، وهو ضعيف». وقال الهيثمي في المجمع ٧/٧٢-٧٣ (١١١٨٩): «رواه أحمد، وفيه إسماعيل بن مسلم المكي، وهو ضعيف».عزاه السيوطي إلى عبد بن حميد.كذا في مطبوعة المصدر، ولعل الأصوب: (يَأْتُون).أخرجه يحيى بن سلام ١/٤٠٦.أخرجه أحمد ٤٢/١٥٦ (٢٥٢٦٣)، ٤٢/٤٦٥ (٢٥٧٠٥)، والترمذي ٥/٣٩٣ (٣٤٤٩)، وابن ماجه ٥/٢٨٧-٢٨٨ (٤١٩٨)، والحاكم ٢/٤٢٧ (٣٤٨٦)، وابن جرير ١٧/٧١، والثعلبي ٧/٥٠. قال الحاكم: «هذا حديث صحيح الإسناد، ولم يُخَرِّجاه». وقال العراقي عَقِب كلام الحاكم ص١٥١١: «بل منقطع بين عائشة وبين عبد الرحمن بن سعد بن وهب». وأورده الألباني في الصحيحة ١/٣٠٤-٣٠٥ (١٦٢).أخرجه الطبراني في الأوسط ٤/١٩٨ (٣٩٦٥)، وابن جرير ١٧/٧٠-٧١. قال الدارقطني في العلل ١١/١٩٣ (٢٢١٦): «رواه يحيى بن اليمان، عن مالك بن مغول، عن عبد الرحمن بن سعيد بن وهب، عن عائشة، وغيره يرويه عن عبد الرحمن مرسلًا عن عائشة، وهو المحفوظ».أخرجه آدم بن أبي إياس -كما في تفسير مجاهد ص٤٨٦-. وعزاه السيوطي إلى سعيد بن منصور، وعبد بن حميد، وابن المنذر.أخرجه عبد الرزاق ٢/٤٦،.عزاه السيوطي إلى ابن أبي حاتم.أخرجه ابن جرير ١٧/٦٩، وابن أبي حاتم -كما في الإتقان ٢/٣١-. وعزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ١٧/٦٩، وأخرج شطره الثاني ١٧/٦٨ من طريق ابن جريج.أخرجه ابن جرير ١٧/٦٧، وإسحاق البستي في تفسيره ص٣٩٨. وعزاه السيوطي إلى الفريابي.عزاه السيوطي إلى عبد بن حميد، وابن أبي حاتم.أخرجه ابن جرير ١٧/٦٨.أخرج شطره الثاني ابن جرير ١٧/٦٧. وعزاه السيوطي إلى عبد بن حميد.أخرجه يحيى بن سلام ١/٤٠٦.أخرجه ابن جرير ١٧/٦٩.أخرجه ابن جرير ١٧/٦٨. وينظر: الفتح ٨/٤٤٥.أخرجه ابن جرير ١٧/٦٨. وعزاه السيوطي إلى ابن أبي حاتم.أخرجه عبد الرزاق ٢/٤٦ عن قتادة من طريق معمر، وكذلك ابن جرير ١٧/٦٧. ومثله يحيى بن سلام ١/٤٠٥ من طريق سعيد بنحوه. وعزاه السيوطي إلى عبد بن حميد.أخرجه إسحاق البستي في تفسيره ص٣٩٨.أخرجه ابن وهب في الجامع ١/١٣٤-١٣٥ (٣١٠)، وابن المبارك في الزهد (١٥)، ويحيى بن سلام ١/٤٠٦، وابن جرير ١٧/٦٧. وعزاه السيوطي إلى عبد بن حميد.تفسير مقاتل بن سليمان ٣/١٦٠.أخرجه ابن جرير ١٧/٦٩.تفسير يحيى بن سلام ١/٤٠٦.
23,61," <q>﴿أُو۟لَـٰۤىِٕكَ یُسَـٰرِعُونَ فِی ٱلۡخَیۡرَ ٰ⁠تِ﴾</q> - تفسير ٥١٧٩٤- قال الحسن البصري: أي: فيما افترض اللهُ عليهم{1}. (ز) ٥١٧٩٥- قال مقاتل بن سليمان: ثم نعتهم، فقال: <q>﴿أولئك يسارعون في الخيرات﴾</q>، يعني: يُسارِعون في الأعمال الصالحة التي ذكرها لهم في هذه الآية{2}. (ز) ٥١٧٩٦- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿أولئك يسارعون في الخيرات﴾</q>، قال: والخيرات: المخافة والوَجَل، والإيمان والكفُّ عن الشِّرك بالله، فذلك المسابقة إلى هذه الخيرات{3}. (ز) ٥١٧٩٧- قال يحيى بن سلّام: قوله: <q>﴿أولئك يسارعون في الخيرات﴾</q> في الأعمال الصالحة{4}. (ز) <q>﴿وَهُمۡ لَهَا سَـٰبِقُونَ ۝٦١﴾</q> - تفسير ٥١٧٩٨- عن عبد الله بن عباس -من طريق علي- في قوله: <q>﴿أولئك يسارعون في الخيرات وهم لها سابقون﴾</q>، قال: سَبَقَتْ لهم السعادةُ مِن الله{5}٤٥٥٢. (١٠/٦٠٢) ٤٥٥٢ ذكر ابنُ جرير (١٧/٧٢) قول ابن عباس، ثم ذكر قولَيْن آخرَيْن في معنى الآية، ولم ينسبهما: الأول: وهم إليها سابقون. الثاني: وهم من أجلها سابقون. ثم رجَّح مستندًا إلى الأغلب من لغة العرب قولَ ابن عباس «مِن أنه: سبقت لهم من الله السعادة قبل مسارعتهم في الخيرات، ولما سبق لهم من ذلك سارعوا فيها». وعلَّل ذلك بقوله: «لأن ذلك أظهر معنَيَيْه، وأنّه لا حاجة بنا إذا وجَّهْنا تأويل الكلام إلى ذلك إلى تحويل معنى اللام التي في قوله: <q>﴿وهُمْ لَها﴾</q> إلى غير معناها الأغلب عليها». ووجَّه ابنُ عطية (٦/٣٠٥) معنى «السباق» على القول الأول بقوله: «فالسباق -على هذا التأويل- هو إلى رضوان الله»؟ وعلى القول الثاني بقوله: «هو إلى الخيرات». ٥١٧٩٩- عن الصلت السراج، قال: سمعتُ الحسن البصري يقول: <q>﴿أؤلئك يسارعون في الخيرات* وهم لها سابقون﴾</q>، قال: سابقون بها{6}. (ز) ٥١٨٠٠- تفسير الحسن البصري: <q>﴿وهم لها﴾</q> للخيرات مُدْرِكون{1}. (ز) ٥١٨٠١- قال محمد بن السائب الكلبي: سبقوا الأمم إلى الخيرات{8}. (ز) ٥١٨٠٢- قال مقاتل بن سليمان: <q>﴿وهم لها سابقون﴾</q> الخيرات التي يسارعون إليها{2}. (ز) ٥١٨٠٣- قال عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿وهم لها سابقون﴾</q>: فتلك الخيرات{3}. (ز) ٥١٨٠٤- قال يحيى بن سلّام: وقال بعضهم: <q>﴿لها سابقون﴾</q> بها سابقون، أي: بالخيرات{1}. (ز) ",footnotes:1:علَّقه يحيى بن سلام ١/٤٠٦.تفسير مقاتل بن سليمان ٣/١٦٠.أخرجه ابن جرير ١٧/٧٢.تفسير يحيى بن سلام ١/٤٠٦.أخرجه ابن جرير ١٧/٧٢، وابن أبي حاتم -كما في فتح الباري ٨/٤٤٥-. وعزاه السيوطي إلى ابن المنذر.أخرجه إسحاق البستي في تفسيره ص٣٩٩.علَّقه يحيى بن سلام ١/٤٠٦.تفسير البغوي ٥/٤٢٢.تفسير مقاتل بن سليمان ٣/١٦٠.أخرجه ابن جرير ١٧/٧٢.علَّقه يحيى بن سلام ١/٤٠٦.
23,62," <q>﴿وَلَا نُكَلِّفُ نَفۡسًا إِلَّا وُسۡعَهَاۚ وَلَدَیۡنَا كِتَـٰبࣱ یَنطِقُ بِٱلۡحَقِّ وَهُمۡ لَا یُظۡلَمُونَ ۝٦٢﴾</q> - تفسير ٥١٨٠٥- قال مقاتل بن سليمان: <q>﴿ولا نكلف نفسا إلا وسعها﴾</q> يقول: لا نكلف نفسًا مِن العمل إلا ما أطاقت، <q>﴿ولدينا﴾</q> يعني: وعندنا <q>﴿كتاب﴾</q> يعني: أعمالهم التي يعملون في اللوح المحفوظ <q>﴿ينطق بالحق وهم لا يظلمون﴾</q> في أعمالهم{1}. (ز) ٥١٨٠٦- قال يحيى بن سلّام: قوله: <q>﴿ولا نكلف نفسا إلا وسعها﴾</q> إلا طاقتها. قوله: <q>﴿ولدينا﴾</q> أي: وعندنا <q>﴿كتاب ينطق بالحق وهم لا يظلمون﴾</q>، عن ابن عباس، قال: أول ما خلق الله القلم، فقال: اكتب. قال: ربِّ، ما أكتب؟ قال: ما هو كائِنٌ. قال: فجَرى القلم بما هو كائِنٌ إلى يوم القيامة. قال: فأعمال العباد تعرض كل يوم اثنين وخميس، فيجدونه على ما في الكتاب. قال يحيى: وسمعتُ بعضَهم يزيد فيه: تلا ابنُ عباس هذه الآية: <q>﴿هذا كتابنا ينطق عليكم بالحق إنا كنا نستنسخ ما كنتم تعملون﴾</q> [الجاثية:٢٩]، ثم قال: ألستم قومًا عَرَبًا؟ هل تكون النسخة إلا مِن كتاب؟!{2}٤٥٥٣. (ز) ٤٥٥٣ ذكر ابنُ عطية (٦/٣٠٦) بأنّ أظهر ما قيل في معنى قوله تعالى: <q>﴿ولَدَيْنا كِتابٌ يَنْطِقُ بِالحَقِّ﴾</q>: «أنه أراد: كتاب إحصاء الأعمال الذي ترفعه الملائكة». وعلَّق عليه بقوله: «وفي الآية -على هذا التأويل- تهديدٌ وتأنيس من الحيف والظلم». ثم ذكر قولًا آخر ولم ينسبه: أن المراد بقوله تعالى: <q>﴿كِتابٌ﴾</q> القرآن. وعلَّق عليه بقوله: «وهذا يحتمل». ثم رجَّح القول الأول، فقال: «والأول أظهر». ولم يذكر مستندًا. ",footnotes:1:تفسير مقاتل بن سليمان ٣/١٦٠.تفسير يحيى بن سلام ١/٤٠٧.
23,63," <q>﴿بَلۡ قُلُوبُهُمۡ فِی غَمۡرَةࣲ مِّنۡ هَـٰذَا﴾</q> - تفسير ٥١٨٠٧- عن عبد الله بن عباس، في قوله: <q>﴿بل قلوبهم في غمرة من هذا﴾</q>، قال: يعني بالغَمْرَة: الكُفْر، والشك{1}. (١٠/٦٠٣) ٥١٨٠٨- عن مجاهد بن جبر -من طريق ابن أبي نجيح، وابن جُرَيْج- في قوله: <q>﴿بل قلوبهم في غمرة من هذا﴾</q>، قال: في عَمًى مِن هذا القرآن{2}٤٥٥٤. (١٠/٦٠٣) ٤٥٥٤ لم يذكر ابنُ جرير (١٧/٧٤) في معنى قوله تعالى: <q>﴿مِن هَذا﴾</q> سوى قول مجاهد أنّه القرآن. وذكر ابنُ عطية (٦/٣٠٦) في اسم الإشارة عدة احتمالات، فقال: «وقوله سبحانه: <q>﴿مِن هَذا﴾</q> يحتمل أن يشير إلى القرآن، ويحتمل أن يشير إلى كتاب الإحصاء، ويحتمل أن يشير إلى الأعمال الصالحة المذكورة قبل، أي: هم في غمرة مِن اطِّراحها وتركها، ويحتمل أن يشير إلى الدِّين بجملته، أو إلى محمد ﷺ. وكل تأويل من هذه قد قالته فرقة». ٥١٨٠٩- عن قتادة بن دعامة -من طريق مَعْمَر- في قوله: <q>﴿بل قلوبهم في غمرة من هذا﴾</q>، قال: في غفلة من أعمال المؤمنين{3}. (١٠/٦٠٣) ٥١٨١٠- قال مقاتل بن سليمان: <q>﴿بل قلوبهم﴾</q> يعني: الكفار <q>﴿في غمرة من هذا﴾</q> يقول: في غفلة من إيمان بهذا القرآن{4}. (ز) <q>﴿وَلَهُمۡ أَعۡمَـٰلࣱ مِّن دُونِ ذَ ٰ⁠لِكَ هُمۡ لَهَا عَـٰمِلُونَ ۝٦٣﴾</q> - تفسير ٥١٨١١- عن عبد الله بن عباس، في قوله: <q>﴿ولهم أعمال من دون ذلك﴾</q> يقول: أعمال سيئة دون الشرك، <q>﴿هم لها عاملون﴾</q> قال: لا بد لهم مِن أن يعملوها{1}. (١٠/٦٠٣) ٥١٨١٢- عن أبي العالية الرِّياحِيِّ -من طريق الربيع بن أنس- في قوله: <q>﴿ولهم أعمال من دون ذلك﴾</q> الآية، قال: أعمالٌ دونَ الحَقِّ{6}٤٥٥٥. (ز) ٤٥٥٥ اختُلِف في مرجع اسم الإشارة <q>﴿ذلك﴾</q>؛ فقيل: إنها إشارة إلى الغمرة. وقيل: إشارة إلى قوله: <q>﴿مِن هَذا﴾</q>، ونسب ابنُ عطية (٦/٣٠٧) القول الأول إلى أبي العالية، وقتادة، وبيَّن أن معنى الآية عليه: «بل هم ضالون معرضون عن الحق، وهم -مع ذلك- لهم سعايات فساد، فوسمهم تعالى بحالتي شرٍّ». ثم وجَّهه بقوله: «وعلى هذا التأويل فالإخبار عمّا سلف من أعمالهم وعمّا هم فيه». وعلَّق على القول الثاني -ولم ينسبه لأحد- بقوله: «فكأنّه قال: لهم أعمال من دون الحق، أو القرآن ونحوه». ٥١٨١٣- عن مجاهد بن جبر، في قوله: <q>﴿ولهم أعمال﴾</q> قال: خطايا <q>﴿من دون ذلك﴾</q> قال: الحق، <q>﴿هم لها عاملون﴾</q> قال: لا بُدَّ لهم مِن أن يعملوها{7}. (١٠/٦٠٣) ٥١٨١٤- عن حميد، قال: سألتُ الحسن البصري عن قول الله: <q>﴿ولهم أعمال من دون ذلك هم لها عاملون﴾</q>، قال: أعمال لم يعملوها، سيعملونها{8}٤٥٥٦. (ز) ٤٥٥٦ علَّق ابنُ عطية (٦/٣٠٧) على قول الحسن ومجاهد بقوله: «أي: أنهم لهم أعمال من الفساد سيعملونها». ٥١٨١٥- عن قتادة بن دعامة -من طريق مَعْمَر- في قوله: <q>﴿ولهم أعمال من دون ذلك﴾</q> قال: هي شر من أعمال المؤمنين، ذكر الله الذين هم مِن خشية ربهم مشفقون، والذين، والذين، ثم قال للكافرين: <q>﴿بل قلوبهم في غمرة من هذا ولهم أعمال من دون﴾</q> الأعمال التي سمى: <q>﴿والذين﴾</q>، <q>﴿والذين﴾</q>{9}. (١٠/٦٠٣) ٥١٨١٦- قال قتادة بن دعامة: هذا ينصَرِف إلى المسلمين، وأنّ لهم أعمالًا سِوى ما عملوا مِن الخيرات، هم لها عاملون{10}. (ز) ٥١٨١٧- قال مقاتل بن سليمان: <q>﴿ولهم أعمال من دون ذلك﴾</q> يقول: لهم أعمال خبيثةٌ دون الأعمال الصالحة، يعني: غير الأعمال الصالحة التي ذكرت عن المؤمنين في هذه الآية وفي الآية الأولى، <q>﴿هم لها عاملون﴾</q> يقول: هم لتلك الأعمال الخبيثة عاملون، التي هي في اللوح المحفوظ أنّهم سيعملونها، لا بُدَّ لهم مِن أن يعملوها{4}. (ز) ٥١٨١٨- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿ولهم أعمال من دون ذلك هم لها عاملون﴾</q>، قال: لم يكن له بُدٌّ مِن أن يستوفي بقية عمله، ويَصْلى به{8}. (ز) ٥١٨١٩- قال يحيى بن سلّام: <q>﴿ولهم﴾</q> يعني: المشركين <q>﴿أعمال من دون ذلك﴾</q> دون أعمال المؤمنين هي شَرٌّ مِن أعمال المؤمنين، <q>﴿هم لها عاملون﴾</q> لتلك الأعمال ... وبعضهم يقول: أعمال لم يعملوها، سيعملونها.عن عمر بن الخطاب، قال: يا رسول الله، أنعمل لِما قد فُرِغ منه أو لِما نَأْتَنِف؟ قال: «لا، بل اعمل لِما قد فُرِغ منه». قال: ففيمَ العمل إذًا؟ قال: «اعملوا، فكُلٌّ لا يُنال إلا بعمل». قال: هذا حين نجتهد. وعن عمر بن الخطاب، قال: يا رسول الله، ما العمل اليوم، أشيءٌ مُستأنف، أم شيء قد فُرِغ منه؟ قال: «قد فُرِغ منه». قال: ففِيمَ العمل اليوم؟ فقال: «كلُّ عبدٍ مُؤَتًّى لِما خُلِق له».= وعن مطرف بن عبد الله بن الشخير، قال: لم تُكَلوا{13} إلى القدر، وإليه تصيرون{14}. (ز) ",footnotes:1:عزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.أخرجه ابن جرير ١٧/٧٤. وعلَّقه يحيى بن سلام ١/٤٠٧. وعزاه السيوطي إلى ابن أبي شيبة، وعبد بن حميد، وابن المنذر، وابن أبي حاتم.أخرجه عبد الرزاق ٢/٤٧، وابن جرير ١٧/٧٥. وعلَّقه يحيى بن سلام ١/٤٠٧. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.تفسير مقاتل بن سليمان ٣/١٦٠.عزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.أخرجه ابن جرير ١٧/٧٥.أخرج ابن جرير ١٧/٧٥-٧٦ شطره الأول من طريق ابن أبي نجيح وابن جريج، والأخير من طريق العلاء بن عبد الكريم. وعلَّقه يحيى بن سلام ١/٤٠٧ دون آخره. وعزاه السيوطي إلى ابن أبي شيبة، وعبد بن حميد، وابن المنذر، وابن أبي حاتم.أخرجه ابن جرير ١٧/٧٦.أخرجه عبد الرزاق ٢/٤٧، وابن جرير ١٧/٧٦. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.تفسير البغوي ٥/٤٢٢.تفسير مقاتل بن سليمان ٣/١٦٠.أخرجه ابن جرير ١٧/٧٦.في مختصر ابن محكم: لم توكلوا، كما في حاشية تحقيق المصدر.تفسير يحيى بن سلام ١/٤٠٦. والحديث أخرجه ابن أبي عاصم في السنة ١/٧١، والخطيب في موضح أوهام الجمع ٢/٤٠٤، ويحيى بن سلام في تفسيره ١/٤٠٧-٤٠٨، من طريق الزهري، عن سعيد بن المسيب، عن عمر به. إسناده صحيح، وفي سماع سعيد من عمر كلام، لكن وإن لم يثبت سماعه منه فإنّ مراسيله كما قال الإمام أحمد: «صحاح، لا ترى أصح منها». وقال ابن معين: «أصح المراسيل مراسيل سعيد بن المسيب». وقال الشافعي: «إرسال ابن المسيب عندنا حجة». كما في جامع التحصيل ١/٤٧.
23,64," <q>﴿حَتَّىٰۤ إِذَاۤ أَخَذۡنَا مُتۡرَفِیهِم بِٱلۡعَذَابِ﴾</q> - نزول الآية، وتفسيرها ٥١٨٢٠- عن عبد الله بن عباس، في قوله: <q>﴿حتى اذا أخذنا مترفيهم بالعذاب﴾</q> الآية، قال: هم أهل بدر{1}. (١٠/٦٠٤) ٥١٨٢١- عن سعيد بن جبير، <q>﴿حتى إذا أخذنا مترفيهم بالعذاب﴾</q>، قال: بالسيوف يوم بدر{2}. (١٠/٦٠٤) ٥١٨٢٢- عن مجاهد بن جبر -من طريق علقمة بن مرثد- <q>﴿حتى اذا أخذنا مترفيهم بالعذاب﴾</q>، قال: بالسيوف يوم بدر{3}. (١٠/٦٠٤) ٥١٨٢٣- عن الضحاك بن مزاحم -من طريق عبيد- في قوله: <q>﴿حتى إذا أخذنا مترفيهم بالعذاب﴾</q>، قال: يعني: أهل بدر، أخذهم الله بالعذاب يوم بدر{4}. (ز) ٥١٨٢٤- قال الضحّاك بن مُزاحِم: يعني: الجوع، وذلك حين دعا عليهم رسول الله ﷺ، فقال: «اللَّهُمَّ، اشْدُدْ وطْأَتَك على مُضَر، واجعلها عليهم سنين كسِنِي يوسف». فابتلاهم الله ﷿ بالقَحْط، حتى أكلوا الكِلاب والجِيَف{5}. (ز) ٥١٨٢٥- عن مَعْمَر، قال: أخبَرني مَن سمِع عكرمة مولى ابن عباس يقول: ... ثم كانت وقعة بدر ...، وفيهم نزلت: <q>﴿حتى إذا أخذنا مترفيهم بالعذاب﴾</q> ...{6}. (ز) ٥١٨٢٦- عن قتادة بن دعامة -من طريق مَعْمَر- <q>﴿حتى اذا أخذنا مترفيهم بالعذاب﴾</q>، قال: ذُكِر لنا: أنّها نزلت في الذين قتل اللهُ يوم بدر{7}. (١٠/٦٠٤) ٥١٨٢٧- تفسير إسماعيل السُّدِّيّ: قوله: <q>﴿حتى إذا﴾</q>، يعني: فلَمّا{8}. (ز) ٥١٨٢٨- عن الربيع بن أنس، في قوله: <q>﴿حتى إذا أخذنا مترفيهم﴾</q>، قال: مُسْتَكْبِرِيهم{9}. (١٠/٦٠٤) ٥١٨٢٩- قال مقاتل بن سليمان: <q>﴿حتى إذا أخذنا مترفيهم﴾</q> يعني: أغنياءهم وجبابرتهم <q>﴿بالعذاب﴾</q> يعني: القتل ببدر{10}. (ز) ٥١٨٣٠- عن عبد الملك ابن جُرَيْج -من طريق حجاج- <q>﴿حتى إذا أخذنا مترفيهم بالعذاب﴾</q>، قال: عذاب يوم بدر{11}. (ز) ٥١٨٣١- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- <q>﴿إذا أخذنا مترفيهم بالعذاب﴾</q>، قال: المُتْرَفون: العظماء{12}٤٥٥٧. (ز) ٤٥٥٧ لم يذكر ابنُ جرير (١٧/٧٧) في معنى قوله تعالى: <q>﴿إذا أخَذْنا مُتْرَفِيهِمْ بِالعَذابِ﴾</q> سوى قول ابن زيد. ٥١٨٣٢- قال يحيى بن سلّام: <q>﴿أخذنا مترفيهم بالعذاب﴾</q>، يعني: أبا جهل وأصحابَه الذين قُتِلوا يوم بدر، نزلت هذه الآيةُ قبل ذلك بمكة{13}. (ز) <q>﴿إِذَا هُمۡ یَجۡـَٔرُونَ ۝٦٤﴾</q> - تفسير ٥١٨٣٣- عن عبد الله بن عباس -من طريق علي- في قوله: <q>﴿إذا هم يجأرون﴾</q>، قال: يستغيثون{14}. (١٠/٦٠٤) ٥١٨٣٤- عن مجاهد بن جبر -من طريق علقمة بن مرثد- <q>﴿حتى اذا أخذنا مترفيهم بالعذاب﴾</q> قال: بالسيوف يوم بدر؛ <q>﴿اذا هم يجأرون﴾</q> قال: الذين بمكة{15}. (١٠/٦٠٤) ٥١٨٣٥- قال الحسن البصري: <q>﴿يجأرون﴾</q> يصرخون إلى الله بالتوبة، فلا يُقْبَل منهم{8}. (ز) ٥١٨٣٦- قال قتادة بن دعامة: <q>﴿إذا هم يجأرون﴾</q>: يجزعون{8}. (ز) ٥١٨٣٧- عن الربيع بن أنس -من طريق أبي جعفر- في قوله: <q>﴿إذا هم يجأرون﴾</q>، قال: يَجْزَعون{11}. (ز) ٥١٨٣٨- قال مقاتل بن سليمان: <q>﴿إذا هم يجأرون﴾</q> [إذا] هم يَضِجُّون إلى الله ﷿ حين نزل بهم العذاب{10}. (ز) ٥١٨٣٩- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- <q>﴿إذا هم يجأرون﴾</q>، قال: يَجْزَعون{12}. (ز) ",footnotes:1:أخرجه النسائي في الكبرى (١١٣٥٣).عزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ١٧/٧٨، وإسحاق البستي في تفسيره ص٤٠٣. وعزاه السيوطي إلى ابن أبي شيبة، وعبد بن حميد، وابن المنذر، وابن أبي حاتم.أخرجه ابن جرير ١٧/٧٨، وإسحاق البستي في تفسيره ص٤٠٣.تفسير الثعلبي ٧/٥١، وتفسير البغوي ٥/٤٢٢. والحديث أخرجه البخاري ١/١٦٠ (٨٠٤)، ٢/٢٦ (١٠٠٦)، ٤/٤٤ (٢٩٣٢)، ٤/١٥٠ (٣٣٨٦)، ٦/٣٨ (٤٥٦٠)، ٦/٤٨ (٤٥٩٨)، ٨/٤٤ (٦٢٠٠)، ٨/٨٤ (٦٣٩٣)، ٩/١٩-٢٠ (٦٩٤٠)، ومسلم ١/٤٦٦ (٦٧٥) كلاهما من حديث أبي هريرة إلى قوله: «كسني يوسف».أخرجه عبد الرزاق ٥/٣٦١-٣٦٣ (٩٧٣٤).أخرجه عبد الرزاق ٢/٤٧. وعلَّقه يحيى بن سلام ١/٤٠٨. وعزاه السيوطي إلى عبد بن حميد، وابن أبي حاتم.علَّقه يحيى بن سلام ١/٤٠٨.عزاه السيوطي إلى ابن أبي حاتم.تفسير مقاتل بن سليمان ٣/١٦٠.أخرجه ابن جرير ١٧/٧٨.أخرجه ابن جرير ١٧/٧٧-٧٨.تفسير يحيى بن سلام ١/٤٠٨.أخرجه ابن جرير ١٧/٧٧، وابن أبي حاتم -كما في الإتقان ٢/٣١-. وعزاه السيوطي إلى ابن المنذر.عزاه السيوطي إلى ابن أبي شيبة، وعبد بن حميد، وابن المنذر، وابن أبي حاتم.علَّقه يحيى بن سلام ١/٤٠٨.علَّقه يحيى بن سلام ١/٤٠٨.أخرجه ابن جرير ١٧/٧٨.تفسير مقاتل بن سليمان ٣/١٦٠.أخرجه ابن جرير ١٧/٧٧-٧٨.
23,65," <q>﴿لَا تَجۡـَٔرُوا۟ ٱلۡیَوۡمَۖ إِنَّكُم مِّنَّا لَا تُنصَرُونَ ۝٦٥﴾</q> - تفسير ٥١٨٤٠- عن عبد الله بن عباس -من طريق عكرمة- في قوله: <q>﴿بالعذاب إذا هم يجأرون لا تجأروا اليوم إنكم منا لا تنصرون﴾</q>، قال: هم أهل بدر{1}. (ز) ٥١٨٤١- عن الربيع بن أنس -من طريق أبي جعفر- <q>﴿لا تجأروا اليوم﴾</q>: لا تجزعوا الآن حين نزل بكم العذاب؛ إنّه لا ينفعكم، فلو كان هذا الجَزَع والتَّضَرُّعُ قبلُ نَفَعَكُم{2}. (ز) ٥١٨٤٢- قال مقاتل بن سليمان: يقول الله ﷿: <q>﴿لا تجأروا اليوم﴾</q> لا تضجوا اليوم؛ <q>﴿إنكم منا لا تنصرون﴾</q> يقول: لا تُمْنَعون منا، حتى تُعَذَّبوا بعد القتل ببدر{3}. (ز) ٥١٨٤٣- عن عبد الملك ابن جريج -من طريق حجاج- <q>﴿حتى إذا أخذنا مترفيهم بالعذاب﴾</q> قال: عذاب يوم بدر؛ <q>﴿إذا هم يجأرون﴾</q> قال: الذين بمكة{4}٤٥٥٨. (ز) ٤٥٥٨ ذكر ابنُ عطية (٦/٣٠٨) في معنى قوله تعالى: <q>﴿لا تَجْأَرُوا اليَوْمَ إنَّكُمْ مِنّا لا تُنصَرُونَ﴾</q> أنّ هذا «القول يجوز أن يكون حقيقة، أي: تقول لهم ذلك الملائكة، ويحتمل أن يكون مجازًا، أي: لسان الحال يقول ذلك». وعلَّق على احتمال كونه مجازًا بقوله: «وهذا على أنّ الذين يجأرون هم المُعَذَّبون، وأمّا على قول ابنِ جريج فلا يُحْتَمل أن تقول ذلك الملائكة». ٥١٨٤٤- قال يحيى بن سلّام: <q>﴿لا تجأروا اليوم﴾</q> لا تجزعوا اليوم؛ <q>﴿إنكم منا لا تنصرون﴾</q> أي: لا يمنعكم مِنّا أحد{5}. (ز) ",footnotes:1:أخرجه النسائي في الكبرى (ت: شعيب الأرناؤوط) ١٠/١٩٤ (١١٢٩٠).أخرجه ابن جرير ١٧/٧٩.تفسير مقاتل بن سليمان ٣/١٦٠.أخرجه ابن جرير ١٧/٧٨.تفسير يحيى بن سلام ١/٤٠٨.
23,66," <q>﴿قَدۡ كَانَتۡ ءَایَـٰتِی تُتۡلَىٰ عَلَیۡكُمۡ﴾</q> - تفسير ٥١٨٤٥- عن عبد الله بن عباس -من طريق العوفي- قوله: <q>﴿قد كانت آياتي تتلى عليكم فكنتم على أعقابكم تنكصون﴾</q>، يعني: أهل مكة{1}. (ز) ٥١٨٤٦- قال مقاتل بن سليمان: <q>﴿قد كانت آياتي﴾</q> يعني: القرآن <q>﴿تتلى عليكم﴾</q> يعني: على كفار مكة{2}. (ز) ٥١٨٤٧- قال يحيى بن سلّام: <q>﴿قد كانت آياتي تتلى عليكم﴾</q>، يعني: القرآن{3}. (ز) <q>﴿فَكُنتُمۡ عَلَىٰۤ أَعۡقَـٰبِكُمۡ تَنكِصُونَ ۝٦٦﴾</q> - تفسير ٥١٨٤٨- عن عبد الله بن عباس -من طريق علي- في قوله: <q>﴿فكنتم على أعقابكم تنكصون﴾</q>، قال: تُدبِرون{4}. (١٠/٦٠٤) ٥١٨٤٩- عن سعيد بن جبير -من طريق حصين- قال: تُدبِرون{5}. (ز) ٥١٨٥٠- عن مجاهد بن جبر -من طريق ابن جريج، وابن أبي نجيح- في قوله: <q>﴿تنكصون﴾</q>، قال: تَسْتَأخِرُون{6}. (١٠/٦٠٥) ٥١٨٥١- قال مقاتل بن سليمان: <q>﴿فكنتم على أعقابكم تنكصون﴾</q> يعني: تتأخرون عن [الإيمان] به، تكذيبًا بالقرآن{2}. (ز) ",footnotes:1:أخرجه ابن جرير ١٧/٨٠.تفسير مقاتل بن سليمان ٣/١٦١.تفسير يحيى بن سلام ١/٤٠٨.أخرجه ابن جرير ١٧/٨٠، وابن أبي حاتم -كما في الإتقان ٢/٣١-. وعزاه السيوطي إلى ابن المنذر.أخرجه الثوري في تفسيره ص٢١٧ دون ذكر الآية.أخرجه يحيى بن سلام ١/٤٠٩ من طريق ابن مجاهد بلفظ: تستأخرون عن الإيمان، وابن جرير ١٧/٧٩-٨٠. وعزاه السيوطي إلى عبد بن حميد.تفسير مقاتل بن سليمان ٣/١٦١.
23,67," <q>﴿مُسۡتَكۡبِرِینَ بِهِۦ سَـٰمِرࣰا تَهۡجُرُونَ ۝٦٧﴾</q> - قراءات ٥١٨٥٢- عن عكرمة مولى ابن عباس أنّه قرأ: (سُمَّرًا تُهَجِّرُونَ)، وكانوا إذا سمروا هَجَّرُوا في القول{1}. (١٠/٦٠٧) ٥١٨٥٣- عن عكرمة مولى ابن عباس -من طريق أبي نَهيك- أنّه قرأ: ‹سامِرًا تُهْجِرُونَ›، أي: تَسُبُّون{2}. (ز) ٥١٨٥٤- عن عاصم أنّه قرأ: <q>﴿سامِرًا تَهْجُرُونَ﴾</q> بنصب التاء، ورفع الجيم{3}. (١٠/٦٠٧) ٥١٨٥٥- قال يحيى بن سلّام: مقرأ الكلبي في هذا الحرف: (سُمَّرًا){4}. (ز) <q>﴿مُسۡتَكۡبِرِینَ بِهِۦ سَـٰمِرࣰا تَهۡجُرُونَ ۝٦٧﴾</q> - نزول الآية ٥١٨٥٦- عن سعيد بن جبير، قال: كانت قريش تسمر حول البيت، ولا تطوف به، ويفتخرون به؛ فأنزل الله: <q>﴿مستكبرين به سامرا تهجرون﴾</q>{5}. (١٠/٦٠٧) ٥١٨٥٧- قال مقاتل بن سليمان: نزلت في الملأ مِن قريش الذين مَشَوا إلى أبي طالب{6}. (ز) <q>﴿مُسۡتَكۡبِرِینَ بِهِۦ﴾</q> - تفسير ٥١٨٥٨- عن عبد الله بن عباس -من طريق العوفي- <q>﴿مستكبرين به﴾</q>، قال: مستكبرين بحَرَم البيت، إنّه لا يظهر علينا فيه أحد{7}. (١٠/٦٠٦) ٥١٨٥٩- عن عبد الله بن عباس -من طريق سعيد- قال: <q>﴿مستكبرين به﴾</q>، قال: مستكبرين بالبيت، تقولون: نحن أهله{8}. (١٠/٦٠٨) ٥١٨٦٠- عن سعيد بن جبير -من طريق حصين- في قوله: <q>﴿مستكبرين به﴾</q>: بالحرم{9}. (ز) ٥١٨٦١- عن مجاهد بن جبر -من طريق ابن أبي نجيح- <q>﴿مستكبرين به﴾</q>، قال: بمكة؛ بالبلد{10}. (١٠/٦٠٦) ٥١٨٦٢- عن الضَّحّاك بن مُزاحِم -من طريق عبيد- يقول في قوله: <q>﴿مستكبرين به﴾</q>، قال: بالحرم{11}. (ز) ٥١٨٦٣- عن أبي مالك غزوان الغفاري، <q>﴿مستكبرين به سامرا تهجرون﴾</q>، قال: مستكبرين بحَرَمي{3}. (١٠/٦٠٦) ٥١٨٦٤- عن الحسن البصري -من طريق عوف- <q>﴿مستكبرين به﴾</q>، قال: بحَرَمي{13}. (١٠/٦٠٦) ٥١٨٦٥- عن أبي صالح [باذام]، <q>﴿مستكبرين به﴾</q>، قال: بالقرآن{14}٤٥٥٩. (١٠/٦٠٦) ٤٥٥٩ اختُلِف في مرجع الضمير في <q>﴿به﴾</q> مِن قوله تعالى: <q>﴿مُسْتَكْبِرِينَ بِهِ﴾</q> على قولين: الأول: أنّ الضمير عائد على الحرم والمسجد، وإن لم يتقدم له ذِكْرٌ؛ لشهرته في الأمر. الثاني: أنّ الضمير عائد على القرآن. ووجَّه ابنُ عطية (٦/٣٠٨) المعنى على القول الأول، فقال: «والمعنى: إنكم تعتقدون في أنفسكم أنّ لكم بالمسجد والحَرَم أعظم الحقوق على الناس والمنازل عند الله؛ فأنتم تستكبرون لذلك، وليس الاستكبار من الحق». ووجَّه المعنى على القول الثاني، فقال: «والمعنى: يُحدث لكم سماع الآيات كُفرًا وطغيانًا». ثم علَّق عليه بقوله: «وهذا قولٌ جيد». ٥١٨٦٦- عن قتادة بن دعامة -من طريق مَعْمَر- <q>﴿مستكبرين به﴾</q>، قال: بالبيت، والحرم{15}. (١٠/٦٠٥) ٥١٨٦٧- قال مقاتل بن سليمان: ثم نعتهم، فقال سبحانه: <q>﴿مستكبرين به﴾</q>، يعني: آمنين بالحرم بأنّ لهم البيت الحرام{16}. (ز) ٥١٨٦٨- قال يحيى بن سلّام: <q>﴿مستكبرين به﴾</q> بالحرم{17}. (ز) <q>﴿سَـٰمِرࣰا تَهۡجُرُونَ ۝٦٧﴾</q> - تفسير ٥١٨٦٩- عن عبد الله بن عباس: أن رسول الله ﷺ كان يقرأ: ‹مُسْتَكْبِرِينَ بِهِ سامِرًا تُهْجِرُونَ›. قال: كان المشركون يُهْجِرون رسول الله ﷺ في القول في سَمَرِهم{18}. (١٠/٦٠٧) ٥١٨٧٠- عن عبد الله بن عباس -من طريق سعيد- قال: إنّما كُرِهَ السمر حين نزلت هذه الآية: <q>﴿مستكبرين به سامرا تهجرون﴾</q>. قال: مستكبرين بالبيت، تقولون: نحن أهله، <q>﴿تهجرون﴾</q> قال: كانوا يهجرونه، ولا يعمرونه{8}. (١٠/٦٠٨) ٥١٨٧١- عن عبد الله بن عباس -من طريق علي- في قوله: ‹تُهْجِرون›، قال: تقولون هُجْرًا{20}٤٥٦٠. (١٠/٦٠٤) ٤٥٦٠ علَّق ابنُ عطية (٦/٣١٠) على قول ابن عباس وما في معناه بقوله: «وهذا إشارة إلى سبِّهم رسول الله ﷺ وأصحابه». ٥١٨٧٢- عن عبد الله بن عباس: أنّ نافع بن الأزرق قال له: أخبِرني عن قوله ﷿: <q>﴿سامرا تهجرون﴾</q>. قال: كانوا يهجرون على اللهو والباطل. قال: وهل تعرف العرب ذلك؟ قال: نعم، أما سمعت الشاعر يقول: وباتوا بشِعْبٍ لهم سامرًا إذا خَبَّ نيرانُهم أوقدوا{21}. (١٠/٦٠٦) ٥١٨٧٣- عن عبد الله بن عباس، في قوله: <q>﴿سامرا تهجرون﴾</q>، قال: كانت قريش يَتَحَلَّقون حِلَقًا يَتَحَدَّثون حول البيت{22}. (١٠/٦٠٧) ٥١٨٧٤- عن عبد الله بن عباس -من طريق العوفي- قوله: <q>﴿تهجرون﴾</q>، قال: يهجرون ذِكْرَ الله، والحقّ{23}. (ز) ٥١٨٧٥- عن سعيد بن جبير -من طريق حصين- في قوله: <q>﴿سامرا تهجرون﴾</q>: وتقولون غير الحق{24}. (ز) ٥١٨٧٦- عن سعيد بن جبير -من طريق حصين- في قوله: <q>﴿مستكبرين به سامرا تهجرون﴾</q>، قال: سمروا بالليل يخوضون في الباطل{25}. (ز) ٥١٨٧٧- عن مجاهد بن جبر -من طريق ابن أبي نجيح- <q>﴿سامرا﴾</q>، يعني: بالليل{26}. (ز) ٥١٨٧٨- عن مجاهد بن جبر -من طريق ابن أبي نجيح- <q>﴿سامرا﴾</q> قال: مَجالِسًا، <q>﴿تهجرون﴾</q> بالقول السيء في القرآن{27}. (١٠/٦٠٦) ٥١٨٧٩- عن مجاهد بن جبر -من طريق أبي يحيى- قال: هو مُنكَر القول، وهُجْر القول{28}. (ز) ٥١٨٨٠- عن الضحاك بن مزاحم -من طريق عبيد- يقول في قوله: <q>﴿سامرا﴾</q> قال: يعني: سمَر الليل، ‹تُهْجِرُون› يقول: يقولون المنكر والخَنا مِن القول، كذلك هُجْر القول{29}. (ز) ٥١٨٨١- عن عكرمة مولى ابن عباس، في قوله: <q>﴿سامرا تهجرون﴾</q>، قال: تهجرون الحق{30}. (١٠/٦٠٧) ٥١٨٨٢- عن عكرمة مولى ابن عباس -من طريق سعيد بن مسروق- <q>﴿سامرا تهجرون﴾</q>: تُسِيئون القولَ فيه{31}. (ز) ٥١٨٨٣- عن أبي مالك غزوان الغفاري، <q>﴿مستكبرين به سامرا تهجرون﴾</q>، قال: مستكبرين بحَرَمي، سامرًا فيه بما لا ينبغي مِن القول{3}. (١٠/٦٠٦) ٥١٨٨٤- عن أبي مالك غزوان الغفاري -من طريق حصين- في قوله ﷿: <q>﴿مستكبرين به سامرا تهجرون﴾</q>، قال: كانوا يهجرون ما لا يرضى اللهُ مِن القول{33}. (ز) ٥١٨٨٥- عن الحسن البصري -من طريق عوف-<q>﴿سامِرًا تُهْجِرون﴾</q>، قال: القرآن، وذِكْري، ورسولي{34}. (١٠/٦٠٦) ٥١٨٨٦- تفسير الحسن البصري -من طريق عمرو- في قوله: <q>﴿سامرا﴾</q>، يقول: قد بلغ مِن أمانكم أنّ سامِركم يسمر بالبطحاء -يعني: سمر الليل- والعربُ تقتل بعضُها بعضًا، وتسيء بعضُها بعضًا، وأنتم في ذلك تهجرون كتابي ورسولي{35}. (ز) ٥١٨٨٧- عن قتادة بن دعامة -من طريق مَعْمَر- <q>﴿مستكبرين به﴾</q> قال: بالبيت والحرم، <q>﴿سامرا﴾</q> قال: كان سامِرُهم لا يخاف؛ مِمّا أُعْطُوا من الأمن، وكانت العرب يخاف سامرُهم، ويغزو بعضُهم بعضًا، وكان أهلُ مكة لا يخافون ذلك بما أُعْطُوا مِن الأمن، ‹ تُهْجِرُونَ› قال: تَتَكَلَّمون بالشِّرك والبهتان في حرم الله وعند بيته.= (ز) ٥١٨٨٨- قال: وكان الحسن يقول: ‹سامِرًا تُهْجِرُونَ› كتاب الله، ونبي الله{36}. (١٠/٦٠٥) ٥١٨٨٩- عن أبي صالح [باذام] -من طريق إسماعيل [بن أبي خالد]- في قوله: <q>﴿سامرا تهجرون﴾</q>، قال: بالبيت، أو بالحرم{37}. (ز) ٥١٨٩٠- عن أبي صالح [باذام] -من طريق السُّدِّيّ- في قوله: <q>﴿سامرا تهجرون﴾</q>، قال: السَّبّ{23}. (ز) ٥١٨٩١- عن عقيل بن خالد: أن [محمد] بن شهاب [الزهري] كان يسمر، فكان إذا رآه ينعس قال: ما أنت من سُمّار قريش الذين قال الله تعالى: <q>﴿سامرا تهجرون﴾</q>{39}. (ز) ٥١٨٩٢- قال محمد بن السائب الكلبي: وأنتم سُمُرًا حول البيت{4}. (ز) ٥١٨٩٣- قال محمد بن السائب الكلبي -من طريق معمر- <q>﴿تهجرون﴾</q>: أي: يقولون هُجْرًا{41}. (ز) ٥١٨٩٤- قال مقاتل بن سليمان: <q>﴿سامرا﴾</q> بالليل، إضمار في الباطل، وأنتم آمِنون فيه. ثم قال: <q>﴿تهجرون﴾</q> القرآن، فلا تؤمنون به{16}. (ز) ٥١٨٩٥- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿سامرا﴾</q> قال: كانوا يسمرون ليلتهم ويلعبون؛ يتكلمون بالشِّعر والكهانة وبما لا يدرون، <q>﴿تهجرون﴾</q>: الهذيان؛ الذي يتكلم بما لا يريد ولا يعقل، كالمريض الذي يتكلم بما لا يدري. قال: كان أبي يقرؤها: <q>﴿سامرا تهجرون﴾</q>{43}٤٥٦١. (ز) ٤٥٦١ وجَّه ابنُ عطية (٦/٣٠٩) قول ابن زيد بقوله: أي: تقولون اللغو من القول، وقاله أبو حاتم. <q>﴿سَـٰمِرࣰا تَهۡجُرُونَ ۝٦٧﴾</q> - أحكام متعلقة بالآية ٥١٨٩٦- عن عبد الله بن عباس -من طريق سعيد- قال: إنّما كُرِهَ السمر حين نزلت هذه الآية: <q>﴿مستكبرين به سامرا تهجرون﴾</q>{8}. (١٠/٦٠٨) ",footnotes:1:عزاه السيوطي إلى عبد بن حميد. و(سُمَّرًا) بتشديد الميم قراءة شاذة، تروى أيضًا عن ابن مسعود، وابن عباس، وغيرهما، وكذلك (تُهَجِّرُونَ) بتشديد الجيم، وتروى أيضا عن ابن عباس، وابن مسعود. انظر: مختصر ابن خالويه ص١٠٠، والمحتسب ٢/٩٥.أخرجه ابن جرير ١٧/٨٦. وهي قراءة متواترة، قرأ بها نافع، وقرأ بقية العشرة: <q>﴿تَهْجُرُونَ﴾</q> بفتح التاء، وضم الجيم. انظر: النشر ٢/٣٢٩، والإتحاف ص٤٠٤-٤٠٥.عزاه السيوطي إلى عبد بن حميد.علَّقه يحيى بن سلام ١/٤٠٩.عزاه السيوطي إلى سعيد بن منصور، وابن أبي حاتم مرسلًا.تفسير مقاتل بن سليمان ٣/١٦١، وهو مرسل.أخرجه ابن جرير ١٧/٨٠. وعزاه السيوطي إلى ابن أبي حاتم.أخرجه النسائي في الكبرى (١١٣٥١)، والحاكم ٢/٣٩٤. وعزاه السيوطي إلى ابن أبي حاتم، وابن مردويه.أخرجه ابن جرير ١٧/٨١.أخرجه ابن جرير ١٧/٨١. وعزاه السيوطي إلى عبد بن حميد، وابن أبي حاتم.أخرجه ابن جرير ١٧/٨١، وإسحاق البستي في تفسيره ص٤٠٤.عزاه السيوطي إلى عبد بن حميد.أخرجه يحيى بن سلام ١/٤٠٩ من طريق أبي الأشهب، وابن جرير ١٧/٨١. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.عزاه السيوطي إلى عبد بن حميد، وابن أبي حاتم.أخرجه يحيى بن سلام ١/٤٠٩ من طريق سعيد، وابن جرير ١٧/٨١. وعزاه السيوطي إلى عبد بن حميد، وابن أبي حاتم.تفسير مقاتل بن سليمان ٣/١٦١.تفسير يحيى بن سلام ١/٤٠٩. وينظر: المكتفى لأبي عمرو الداني ص١٤٢ (١٧).أخرجه الحاكم ٢/٢٦٩ (٢٩٧٠). قال الحاكم: «هذا حديث صحيح الإسناد، ولم يخرجاه». وقال الهيثمي في المجمع ٧/٧٣ (١١١٩٠): «رواه الطبراني، وفيه يحيى بن سلمة بن كهيل، وهو ضعيف، وقد ذكره ابن حِبّان في الثقات، وقال: في رواية ابنه إبراهيم عنه مناكير. قلت: وهذا منها».أخرجه النسائي في الكبرى (١١٣٥١)، والحاكم ٢/٣٩٤. وعزاه السيوطي إلى ابن أبي حاتم، وابن مردويه.أخرجه ابن جرير ١٧/٨٥، وابن أبي حاتم -كما في الإتقان ٢/٣١-. وعزاه السيوطي إلى ابن المنذر.عزاه السيوطي إلى الطستي. وينظر: مسائل نافع (٢٤٢).عزاه السيوطي إلى عبد بن حميد، وابن أبي حاتم، وابن مردويه.أخرجه ابن جرير ١٧/٨٤.تفسير الثوري ص٢١٧.أخرجه ابن جرير ١٧/٨٥، وإسحاق البستي في تفسيره ص٤٠٣.تفسير مجاهد ص٤٨٧.أخرجه ابن جرير ١٧/٨٣، ٨٥، وأخرج أوله يحيى بن سلام ١/٤٠٩ من طريق عاصم بن حكيم. وعزاه السيوطي إلى عبد بن حميد، وابن أبي حاتم.أخرجه يحيى بن سلام ١/٤٠٩.أخرجه ابن جرير ١٧/٨١، ٨٣، ٨٦، وإسحاق البستي في تفسيره ص٤٠٤.عزاه السيوطي إلى ابن أبي حاتم.أخرجه أبو إسحاق المالكي في أحكام القرآن ص١٤٤.عزاه السيوطي إلى عبد بن حميد.أخرجه سعيد بن منصور في سننه - التفسير ٦/٣٦٨ (١٥١٩).أخرجه يحيى بن سلام ١/٤٠٩ من طريق أبي الأشهب بنحوه، وابن جرير ١٧/٨١، ٨٦ كذلك من طريق معمر. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.أخرجه يحيى بن سلام ١/٤٠٩، وأخرج ابن جرير ١٧/٨٦ آخره. وعزاه السيوطي إلى عبد بن حميد، وابن أبي حاتم.أخرجه ابن جرير ١٧/٨٣، ٨٦. وعزاه السيوطي إلى عبد بن حميد، وابن أبي حاتم.أخرجه إسحاق البستي في تفسيره ص٤٠٤.أخرجه ابن جرير ١٧/٨٤.أخرجه المستغفري في طب النبي ﷺ ص٣٠٨، وابن عساكر في تاريخ دمشق ٥٥/٣٧٥.علَّقه يحيى بن سلام ١/٤٠٩.أخرجه عبد الرزاق ٢/٤٧.تفسير مقاتل بن سليمان ٣/١٦١.أخرجه ابن جرير ١٧/٨٣، ٨٥.أخرجه النسائي في الكبرى (١١٣٥١)، والحاكم ٢/٣٩٤. وعزاه السيوطي إلى ابن أبي حاتم، وابن مردويه.
23,68," <q>﴿أَفَلَمۡ یَدَّبَّرُوا۟ ٱلۡقَوۡلَ أَمۡ جَاۤءَهُم مَّا لَمۡ یَأۡتِ ءَابَاۤءَهُمُ ٱلۡأَوَّلِینَ ۝٦٨﴾</q> - تفسير ٥١٨٩٧- عن عبد الله بن عباس -من طريق عكرمة- في قوله: <q>﴿أفلم يدبروا القول أم جاءهم ما لم يأت آباءهم الأولين﴾</q>، قال: لَعَمْري، لقد جاءهم ما لم يأت آباءهم الأولين، ولكن أوَلَم يأتهم ما لم يأت آباءهم الأولين؟!{1}٤٥٦٢. (ز) ٤٥٦٢ ذكر ابنُ جرير (١٧/٨٧) أنه: «قد يحتمل أن تكون <q>﴿أم﴾</q> في هذا الموضع بمعنى: بل؛ فيكون تأويل الكلام: أفلم يدبروا القول؟ بل جاءهم ما لم يأت آباءهم الأولين، فتركوا لذلك التدبر وأعرضوا عنه، إذ لم يكن فيمن سلف من آبائهم ذلك. وقد ذكر عن ابن عباس في ذلك نحو هذا القول». ثم أورد قول ابن عباس المذكور. ٥١٨٩٨- عن قتادة بن دعامة، في قوله: <q>﴿أفلم يدبروا القول﴾</q>، قال: إذن -والله- كانوا يَجِدون في القرآن زاجِرًا عن معصية الله، لو تَدَبَّرَهُ القوم وعقلوه!{2}. (١٠/٦٠٨) ٥١٨٩٩- قال مقاتل بن سليمان: <q>﴿أفلم يدبروا القول﴾</q> يعني: أفلم يستمعوا القرآن، <q>﴿أم جاءهم ما لم يأت آبآءهم الأولين﴾</q> يقول: قد جاء أهلَ مكة النُّذُر، كما جاء آباءهم وأجدادهم الأولين{3}. (ز) ٥١٩٠٠- قال يحيى بن سلّام: قوله: <q>﴿أفلم يدبروا القول﴾</q> يعني: القرآن، <q>﴿أم جاءهم ما لم يأت آباءهم الأولين﴾</q> أي: لم يأتهم إلا ما أتى آباءهم الأولين.= (ز) ٥١٩٠١- وقال السُّدِّيّ: <q>﴿أم جاءهم ما لم يأت﴾</q> يعني: الذي لم يأت آباءهم الأولين. [قال يحيى بن سلّام:] وهو واحد{4}٤٥٦٣. (ز) ٤٥٦٣ ذكر ابنُ عطية (٦/٣١٠-٣١١) في قوله تعالى: <q>﴿أمْ جاءَهُمْ﴾</q> معنيين: الأول: «أأَبْدَع لهم أمرًا لم يكن في الناس قبلهم؟! بل قد جاء الرسل قبل كنوح وإبراهيم وإسماعيل ﵈». وعلَّق عليه بقوله: «وفي هذا التأويل مِن التَّجَوُّز أن جعل سالِف الأمم آباء، إذ الناس في الجملة آخرهم من أولهم». والثاني: أن المراد بـ<q>﴿آباءهم الأولين﴾</q> «مَن فَرَط مِن سلفهم في العرب. كأنه قال: أفلم يدَّبَّروا القول أم جاءهم أمر غريب من عند الله لم يأت آباءهم فبهر عقولهم، ونَبَتْ عنه أذهانهم». وعلَّق عليه بقوله: «فكأن التوبيخ يتَّسِق بأن يُقدَّر الكلام: أفلم يدَّبَّروا أم بُهرت عقولهم ونَبَتْ أذهانهم عن أمر من أمور الله غريب في سلفهم». ثم علَّق على القول الأول بقوله: «والمعنى الأول أبْيَن». ",footnotes:1:أخرجه ابن جرير ١٧/٨٧.عزاه السيوطي إلى ابن أبي حاتم.تفسير مقاتل بن سليمان ٣/١٦١.تفسير يحيى بن سلام ١/٤٠٩.
23,69," <q>﴿أَمۡ لَمۡ یَعۡرِفُوا۟ رَسُولَهُمۡ فَهُمۡ لَهُۥ مُنكِرُونَ ۝٦٩﴾</q> - تفسير ٥١٩٠٢- قال عبد الله بن عباس: أليس قد عَرَفوا محمدًا ﷺ صغيرًا وكبيرًا، وعرفوا نسبَه وصدقَه وأمانتَه ووفاءَه بالعهود؟!{1}. (ز) ٥١٩٠٣- عن عبد الرحمن بن أبي ليلى -من طريق سفيان الثوري، عن رجل- في قوله: <q>﴿أم لم يعرفوا رسولهم فهم له منكرون﴾</q>، قال: قد عرفوه، ولكنهم حَسَدُوه{2}. (ز) ٥١٩٠٤- عن أبي صالح [باذام]، في قوله: <q>﴿أم لم يعرفوا رسولهم﴾</q>، قال: عرفوه، ولكن حسدوه{3}. (١٠/٦٠٨) ٥١٩٠٥- عن قتادة بن دعامة -من طريق سعيد- <q>﴿فهم له منكرون﴾</q>، قال: بل يعرفون وجْهَه، ونَسَبَه{4}. (ز) ٥١٩٠٦- قال مقاتل بن سليمان: <q>﴿أم لم يعرفوا رسولهم﴾</q> يعني: محمدًا ﷺ بوجهه ونسبه؛ <q>﴿فهم له منكرون﴾</q> فلا يعرفونه؟! بل يعرفونه{5}. (ز) ٥١٩٠٧- قال يحيى بن سلّام: قوله: <q>﴿أم لم يعرفوا رسولهم﴾</q>، أي: الذي [أرسله] إليهم، يعني: محمدًا{6}. (ز) ",footnotes:1:تفسير البغوي ٥/٤٢٣.تفسير الثوري ص٢١٧.عزاه السيوطي إلى ابن أبي شيبة، وعبد بن حميد، وابن المنذر، ابن جرير، وابن أبي حاتم.أخرجه يحيى بن سلام ١/٤١٠.تفسير مقاتل بن سليمان ٣/١٦١.تفسير يحيى بن سلام ١/٤١٠.
23,70," <q>﴿أَمۡ یَقُولُونَ بِهِۦ جِنَّةُۢۚ بَلۡ جَاۤءَهُم بِٱلۡحَقِّ وَأَكۡثَرُهُمۡ لِلۡحَقِّ كَـٰرِهُونَ ۝٧٠﴾</q> - تفسير ٥١٩٠٨- قال مقاتل بن سليمان: <q>﴿أم يقولون به جنة﴾</q> قالوا: إنّ بمحمد جنونًا، يقول الله ﷿: <q>﴿بل جاءهم﴾</q> محمد ﷺ <q>﴿بالحق﴾</q> يعني: بالتوحيد، <q>﴿وأكثرهم للحق﴾</q> يعني: التوحيد <q>﴿كارهون﴾</q>{1}. (ز) ٥١٩٠٩- قال يحيى بن سلّام: قوله: <q>﴿أم يقولون به جنة﴾</q> أي: بمحمد جنون. أي: قد قالوا ذلك. قال الله: <q>﴿بل جاءهم بالحق﴾</q> القرآن، <q>﴿وأكثرهم للحق كارهون﴾</q> يعني: جماعة مَن لم يؤمِن منهم{2}. (ز) ",footnotes:1:تفسير مقاتل بن سليمان ٣/١٦١.تفسير يحيى بن سلام ١/٤١٠.
23,71," <q>﴿وَلَوِ ٱتَّبَعَ ٱلۡحَقُّ أَهۡوَاۤءَهُمۡ لَفَسَدَتِ ٱلسَّمَـٰوَ ٰ⁠تُ وَٱلۡأَرۡضُ وَمَن فِیهِنَّۚ﴾</q> - تفسير ٥١٩١٠- تفسير الحسن البصري: لو كان الحقُّ في أهوائهم لوَقَعَتْ أهواؤهم على هلاك السموات والأرض ومَن فيهنَّ{1}. (ز) ٥١٩١١- عن أبي صالح [باذام] -من طريق إسماعيل بن أبي خالد- في قوله: <q>﴿ولو اتبع الحق أهواءهم﴾</q>، قال: الحقُّ هو الله ﷿{2}. (١٠/٦٠٨) ٥١٩١٢- قال إسماعيل السُّدِّيّ: الحق هو الله{3}. (ز) ٥١٩١٣- قال محمد بن السائب الكلبي -من طريق معمر- في قوله تعالى: <q>﴿ولو اتبع الحق أهواءهم﴾</q> قال: يقول: لو اتبع الله أهواءهم <q>﴿لفسدت السموات والأرض﴾</q>{4}. (ز) ٥١٩١٤- قال مقاتل بن سليمان: يقول الله ﷿: <q>﴿ولو اتبع الحق أهواءهم﴾</q> يعني: لو اتَّبع اللهُ أهواء كفار مكة، فجعل مع نفسه شريكًا؛ <q>﴿لفسدت﴾</q> يعني: لهلكت <q>﴿السماوات والأرض ومن فيهن﴾</q> مِن الخلق{5}. (ز) ٥١٩١٥- عن عبد الملك ابن جريج -من طريق حجاج- قوله: <q>﴿ولو اتبع الحق أهواءهم﴾</q>، قال: الحقُّ اللهُ{6}. (ز) ٥١٩١٦- قال يحيى بن سلّام: قوله: <q>﴿ولو اتبع الحق أهواءهم﴾</q> أهواء المشركين؛ <q>﴿لفسدت﴾</q> يعني: لهلكت <q>﴿السموات والأرض ومن فيهن﴾</q> ... وقال بعضهم: الحق هاهنا: الله، كقوله: <q>﴿وتواصوا بالحق﴾</q> يعني بالحق: الله، <q>﴿وتواصوا بالصبر﴾</q> [العصر:٤] على فرائضه{1}٤٥٦٤. (ز) ٤٥٦٤ انتقد ابنُ عطية (٦/٣١١) مستندًا إلى الدلالة العقلية قولَ أبي صالح، والسدي، والكلبي، ومقاتل، ويحيى بن سلام، فقال: «وهذا ليس من نمط الآية». ثم قال أيضًا (٦/٣١١-٣١٢): «ومَن قال: إن الحق في الآية: الله تعالى؛ تشعَّبَتْ له لفظة <q>﴿اتَّبَعَ﴾</q>، وصَعُبَ عليه ترتيبُ الفساد المذكور في الآية؛ لأن لفظة الاتِّباع -على كلا الوجهين- إنما هي استعارة بمعنى أن تكون أهواؤهم يصونها الحق ويقررها، فنحن نجد الله تعالى قد قدَّر كُفْرَ أمم وأهواءهم، فليس في ذلك فساد سماوات، وأما الحق نفسه الذي هو الصواب فلو كان طبْق أهوائهم لفسد كلُّ شيءٍ. فتأمَّلْه». وذكر قولًا آخر ولم ينسبه، وهو أنّ الحق هنا: الصواب والمستقيم، ورجَّحه (٦/٣١١ بتصرف) بقوله: «وهذا هو الأحرى». ثم علَّق بقوله: «على أن يكون الحقّ المذكور في قوله تعالى: <q>﴿بَلْ جاءَهُمْ بِالحَقِّ وأَكْثَرُهُمْ لِلْحَقِّ كارِهُونَ﴾</q> هو: الذي جاء به محمد رسول الله ﷺ». ثم بيَّن وجْه فساد السماوات والأرض في الآية بناءً على هذا المعنى، فقال: «ويستقيم -على هذا- فساد السماوات والأرض ومن فيهن لو كان بحكم هوى هؤلاء، وذلك أنهم جعلوا لله شركاء وأولادًا، ولو كان هذا حقًّا لم تكن لله -تبارك وتعالى- الصِّفات العَلِيَّة، ولو لم يَكُن له لم تَكُن له الصنعة ولا القدرة، وكان ذلك فساد السماوات والأرض ومن فيهن». <q>﴿بَلۡ أَتَیۡنَـٰهُم بِذِكۡرِهِمۡ فَهُمۡ عَن ذِكۡرِهِم مُّعۡرِضُونَ ۝٧١﴾</q> - تفسير ٥١٩١٧- عن عبد الله بن عباس -من طريق علي بن أبي طلحة- في قوله: <q>﴿بل أتيناهم بذكرهم﴾</q>، قال: بيَّنّا لهم{8}. (١٠/٦٠٨) ٥١٩١٨- قال عبد الله بن عباس: أي: بما فيه فخرُهم وشَرَفُهم{3}. (ز) ٥١٩١٩- قال الحسن البصري: يعني: القرآن، أنزلنا عليهم فيه ما يأتون، وما يتَّقون، وما يُحَرِّمون، وما يُحِلُّون{1}. (ز) ٥١٩٢٠- عن قتادة بن دعامة -من طريق مَعْمَر- في قوله: <q>﴿بل أتيناهم بذكرهم﴾</q>، قال: هذا القرآن{11}. (١٠/٦٠٨) ٥١٩٢١- قال إسماعيل السُّدِّيّ: <q>﴿بل أتيناهم بذكرهم﴾</q>: بشرفهم، <q>﴿فهم عن ذكرهم﴾</q> يعني: عن شرفهم <q>﴿معرضون﴾</q>{12}. (ز) ٥١٩٢٢- قال مقاتل بن سليمان: يقول الله ﷿: <q>﴿بل أتيناهم بذكرهم﴾</q> يعني: بشرفهم، يعني: القرآن، <q>﴿فهم عن ذكرهم معرضون﴾</q> يعني: القرآن مُعْرِضون عنه فلا يُؤْمِنون به{13}. (ز) ٥١٩٢٣- قال يحيى بن سلّام: قال: <q>﴿بل أتيناهم بذكرهم﴾</q> بشرفهم؛ شرف لِمَن آمن به، <q>﴿فهم عن ذكرهم﴾</q> عما بَيَّنّا لهم <q>﴿معرضون﴾</q>... = (ز) ٥١٩٢٤- قال يحيى: سمعت سفيان الثوري يذكر في هذه الآية: <q>﴿لقد أنزلنا إليكم كتابا فيه ذكركم﴾</q> [الأنبياء:١٠]: فيه شَرَفُكم{14}٤٥٦٥. (ز) ٤٥٦٥ علَّق ابن جرير (١٧/٨٩-٩٠) على قول ابن عباس من طريق علي بن أبي طلحة وما في معناه، وقول السدي وما في معناه بقوله: «وهذان القولان متقاربا المعنى؛ وذلك أنّ الله -جلَّ ثناؤه- أنزل هذا القرآن بيانًا بيَّن فيه ما لِخَلْقِه إليه الحاجة من أمر دينهم، وهو مع ذلك ذِكْرٌ لرسول الله ﷺ وقومه، وشرفٌ لهم». ",footnotes:1:علَّقه يحيى بن سلام ١/٤١٠.أخرجه ابن جرير ١٧/٨٩. وعزاه السيوطي إلى ابن أبي شيبة، وعبد بن حميد، وابن المنذر، وابن أبي حاتم. وأخرج نحوه ابن جرير ١٧/٨٩ من طريق السدي.تفسير البغوي ٥/٤٢٤.أخرجه عبد الرزاق ٢/٤٧.تفسير مقاتل بن سليمان ٣/١٦١. وفي تفسير البغوي ٥/٤٢٤ قال مقاتل: الحق هو الله.أخرجه ابن جرير ١٧/٨٩.علَّقه يحيى بن سلام ١/٤١٠.أخرجه ابن جرير ١٧/٨٩. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.تفسير البغوي ٥/٤٢٤.علَّقه يحيى بن سلام ١/٤١٠.أخرجه عبد الرزاق ٢/٤٨. وعلَّقه يحيى بن سلام ١/٤١٠ وزاد: <q>﴿معرضون﴾</q> عن القرآن. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.علَّقه يحيى بن سلام ١/٤١١.تفسير مقاتل بن سليمان ٣/١٦١.تفسير يحيى بن سلام ١/٤١٠-٤١١.
23,72," <q>﴿أَمۡ تَسۡـَٔلُهُمۡ خَرۡجࣰا فَخَرَاجُ رَبِّكَ خَیۡرࣱۖ وَهُوَ خَیۡرُ ٱلرَّ ٰ⁠زِقِینَ ۝٧٢﴾</q> - قراءات ٥١٩٢٥- عن عاصم أنّه قرأ: <q>﴿أمْ تَسْأَلُهُمْ خَرْجًا﴾</q> بغير ألف، <q>﴿فَخَراجُ رَبِّكَ﴾</q> بالألف{1}. (١٠/٦٠٩) ٥١٩٢٦- عن الحسن البصري أنه قرأ: ‹أمْ تَسْأَلُهُمْ خَراجًا فَخَراجُ رَبِّكَ خَيْرٌ› {2}. (١٠/٦٠٩) <q>﴿أَمۡ تَسۡـَٔلُهُمۡ خَرۡجࣰا﴾</q> - تفسير ٥١٩٢٧- عن مجاهد بن جبر، قال: الخَرْجُ وما قبلها مِن القصة لكُفّار قريش{3}. (١٠/٦٠٩) ٥١٩٢٨- عن الحسن البصري -من طريق مَعْمَر- في قوله: <q>﴿خرجا﴾</q>، قال: أجرًا{4}. (١٠/٦٠٨) ٥١٩٢٩- عن قتادة بن دعامة، في قوله: <q>﴿أم تسألهم خرجا﴾</q>، يقول: أم تسألهم على ما أتيناهم به جُعْلًا{5}. (١٠/٦٠٨) ٥١٩٣٠- قال مقاتل بن سليمان: <q>﴿أم تسألهم﴾</q> يا محمد <q>﴿خرجا﴾</q> أجرًا على الإيمان بالقرآن{6}. (ز) ٥١٩٣١- قال يحيى بن سلّام: قوله: <q>﴿أم تسألهم خرجا﴾</q>، أي: إنك لا تسألهم عليه أجرًا{7}. (ز) <q>﴿فَخَرَاجُ رَبِّكَ خَیۡرࣱۖ وَهُوَ خَیۡرُ ٱلرَّ ٰ⁠زِقِینَ ۝٧٢﴾</q> - تفسير ٥١٩٣٢- قال يحيى بن سلّام: قال: <q>﴿فخراج ربك خير﴾</q> أجرُ ربك، أي: ثوابه في الآخرة خيرٌ من أجرهم لو أعطوك في الدنيا أجرًا. قال: <q>﴿وهو خير الرازقين﴾</q> وقد يجعل الله رزق العباد بعضهم من بعض، يرزق الله إيّاهم، يقسم رزق هذا على يَدَيْ هذا، <q>﴿وهو خير﴾</q> أفضل <q>﴿الرازقين﴾</q>= (ز) ٥١٩٣٣- وهو تفسير السُّدِّيّ{7}. (ز) ٥١٩٣٤- قال مقاتل بن سليمان: <q>﴿فخراج ربك﴾</q> يعني: فأجر ربك <q>﴿خير﴾</q> يعني: أفضل مِن خراجهم، <q>﴿وهو خير الرازقين﴾</q>{6}٤٥٦٦. (ز) ٤٥٦٦ ذكر ابنُ عطية (٦/٣١٣) أن معنى قوله تعالى: <q>﴿فَخَراجُ رَبِّكَ﴾</q>: ثوابه، سمّاه: خراجًا من حيث كان معادلًا للخراج في هذا الكلام«. ثم ذكر احتمالًا آخر، فقال:»ويحتمل أن يريد بخراج ربك: رزق ربك«. وعلَّق عليه بقوله:»ويؤيد هذا قوله تعالى: <q>﴿وهُوَ خَيْرُ الرّازِقِينَ﴾</q>". <q>﴿فَخَرَاجُ رَبِّكَ خَیۡرࣱۖ وَهُوَ خَیۡرُ ٱلرَّ ٰ⁠زِقِینَ ۝٧٢﴾</q> - آثار متعلقة بالآية ٥١٩٣٥- عن أُمِّ الدَّرداء -من طريق عثمان بن حيّان- قالت: ما بال أحدكم يقول: اللَّهُمَّ، ارزقني. وقد علِم أنّ الله لا يُمْطِر عليه مِن السماء دنانير ولا دراهم، وإنما يرزق بعضكم من بعض، فمَن ساق الله إليه رزقًا فليقبله، وإن لم يكن إليه محتاجًا فلْيُعْطِهِ في أهل الحاجة مِن إخوانه، وإن كان محتاجًا استعان به على حاجته، ولا يرد على الله رزقه الذي رزقه{10}. (ز) ",footnotes:1:عزاه السيوطي إلى عبد بن الحميد. و<q>﴿أمْ تَسْأَلُهُمْ خَرْجًا فَخَراجُ رَبِّكَ﴾</q> بغير ألف في الأول، وبالألف في الثاني قراءة العشرة ما عدا ابن عامر، فإنه قرأ: ‹أمْ تَسْأَلُهُمْ خَرْجًا فَخَرْجُ رَبِّكَ› بإسقاط الألف فيهما، وما عدا حمزة والكسائي، فإنهما قرآ: ‹أمْ تَسْأَلُهُمْ خَراجًا فَخَراجُ رَبِّكَ› بالألف فيهما. انظر: الإتحاف ص٤٠٥.عزاه السيوطي إلى ابن أبي شيبة، وابن المنذر.عزاه السيوطي إلى عبد بن حميد.أخرجه عبد الرزاق ٢/٤٨، وابن جرير ١٧/٩٠-٩١. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.علَّقه يحيى بن سلام ١/٤١١. وعزاه السيوطي إلى عبد الرزاق، وعبد بن حميد، وابن المنذر، وابن أبي حاتم.تفسير مقاتل بن سليمان ٣/١٦٢.تفسير يحيى بن سلام ١/٤١١.تفسير يحيى بن سلام ١/٤١١.تفسير مقاتل بن سليمان ٣/١٦٢.أخرجه يحيى بن سلام ١/٤١١.
23,73," <q>﴿وَإِنَّكَ لَتَدۡعُوهُمۡ إِلَىٰ صِرَ ٰ⁠طࣲ مُّسۡتَقِیمࣲ ۝٧٣﴾</q> - تفسير ٥١٩٣٦- عن قتادة بن دعامة، في قوله: <q>﴿وانك لتدعوهم إلى صراط مستقيم﴾</q>، قال: ما فيه عِوَج. ذُكِر لنا: أنّ نبيَّ الله ﷺ لَقِي رجلًا، فقال له: «أسلِم». فتَصَعَّد{1} له ذلك، وكَبُر عليه، فقال له النبيُّ ﷺ: «أرأيتَ لو كنتَ في طريق وعر وعث{2}، فلقيت رجلًا تعرف وجهَه وتعرف نسبَه، فدعاك إلى طريق واسع سهل أكنت تتبعه؟». قال: نعم. قال: «فوالذي نفسُ محمد بيده، إنّك لَفي أوعَرَ مِن ذلك الطريق لو كنتَ فيه، إنِّي لأدعوك إلى أسهل من ذلك الطريق لو دُعِيت إليه». وذُكِر لنا: أنّ النبيَّ ﷺ لقي رجلًا، فقال له: «أسلِم». فصَعَّدَه ذلك، فقال له نبي ﷺ: «أرأيت فَتَيَيْك؛ أحدهما: إن حدَّثَك صَدَقَكَ، وإن ائْتَمَنتَهُ أدّى اليك، والآخر: إن حدَّثَك كَذَبَك، وان ائتمنته خانك؟». قال: بلى، فتاي الذي إذا حدثني صَدَقَني، وإن ائتمنته أدّى إلَيَّ. قال نبيُّ الله ﷺ: «كذاكم أنتم عند ربكم»{3}. (١٠/٦١٠) ٥١٩٣٧- قال مقاتل بن سليمان: <q>﴿وإنك لتدعوهم إلى صراط مستقيم﴾</q>، يعني: الإسلام لا عوج فيه{4}. (ز) ٥١٩٣٨- قال يحيى بن سلّام: قوله: <q>﴿وإنك لتدعوهم إلى صراط مستقيم﴾</q> إلى دين مستقيم، وهو الطريق إلى الجنة{5}. (ز) ",footnotes:1:تَصعَّده الأمر: شَقَّ عليه وصَعُب. النهاية (صعد) ٣/٣٠.وعث الطريق: تعسر سلوكه. ينظر: اللسان (وعث).عزاه السيوطي إلى عبد بن حميد، وابن أبي حاتم. وأورده ابن كثير في تفسيره ٥/٤٨٤ عن قتادة.تفسير مقاتل بن سليمان ٣/١٦٢.تفسير يحيى بن سلام ١/٤١٢.
23,74," <q>﴿وَإِنَّ ٱلَّذِینَ لَا یُؤۡمِنُونَ بِٱلۡـَٔاخِرَةِ﴾</q> - تفسير ٥١٩٣٩- تفسير إسماعيل السُّدِّيّ: قوله: <q>﴿وإن الذين لا يؤمنون بالآخرة﴾</q>، يعني: بالبعث يوم القيامة{1}. (ز) ٥١٩٤٠- قال مقاتل بن سليمان: <q>﴿وإن الذين لا يؤمنون بالآخرة﴾</q>، يعني: لا يُصَدِّقون بالبَعْث{2}. (ز) <q>﴿عَنِ ٱلصِّرَ ٰ⁠طِ﴾</q> - تفسير ٥١٩٤١- عن عبد الله بن عباس -من طريق علي- قوله: <q>﴿وإن الذين لا يؤمنون بالآخرة عن الصراط لناكبون﴾</q>، يقول: عن الحقِّ{3}٤٥٦٧. (١٠/٦١٠) ٤٥٦٧ لم يذكر ابنُ جرير (١٧/٩١-٩٢) في معنى قوله تعالى: <q>﴿عَنِ الصِّراطِ لَناكِبُونَ﴾</q> سوى قول ابن عباس. ٥١٩٤٢- عن مجاهد بن جبر، في قوله: <q>﴿وإن الذين لا يؤمنون بالآخرة عن الصراط لناكبون﴾</q>، قال: عن الحقِّ{4}. (١٠/٦١٠) ٥١٩٤٣- قال مقاتل بن سليمان: <q>﴿عن الصراط﴾</q>، يعني: عن الدِّين{2}. (ز) <q>﴿لَنَـٰكِبُونَ ۝٧٤﴾</q> - تفسير ٥١٩٤٤- عن عبد الله بن عباس -من طريق علي- قوله: <q>﴿لناكبون﴾</q>، يقول: عادِلون{6}. (١٠/٦١٠) ٥١٩٤٥- عن مجاهد بن جبر، في قوله: <q>﴿لناكبون﴾</q>، قال: لَحائِدون{4}. (١٠/٦١٠) ٥١٩٤٦- قال الحسن البصري: تاركون له= (ز) ٥١٩٤٧- وقال محمد بن السائب الكلبي: مُعْرِضون عنه{8}. (ز) ٥١٩٤٨- في تفسير قتادة بن دعامة: <q>﴿عن الصراط لناكبون﴾</q>: لجائرون{1}. (ز) ٥١٩٤٩- قال مقاتل بن سليمان: <q>﴿لناكبون﴾</q> لعادلون{2}. (ز) ",footnotes:1:علَّقه يحيى بن سلام ١/٤١٢.تفسير مقاتل بن سليمان ٣/١٦٢.أخرجه ابن جرير ١٧/٩١-٩٢، ومن طريق عطاء الخراساني مختصرًا، وابن أبي حاتم -كما في الإتقان ٢/٣١-. وعزاه السيوطي إلى ابن المنذر.عزاه السيوطي إلى عبد بن حميد.تفسير مقاتل بن سليمان ٣/١٦٢.أخرجه ابن جرير ١٧/٩١-٩٢ كذلك من طريق عطاء الخراساني، وابن أبي حاتم -كما في الإتقان ٢/٣١-. وعزاه السيوطي إلى ابن المنذر.عزاه السيوطي إلى عبد بن حميد.علَّقه يحيى بن سلام ١/٤١٢، وعقَّب على قوليهما بقوله: وهو واحد.علَّقه يحيى بن سلام ١/٤١٢.تفسير مقاتل بن سليمان ٣/١٦٢.
