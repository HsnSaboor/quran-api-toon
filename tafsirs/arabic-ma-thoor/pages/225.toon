quran[9]{c,v,t}:
11,29," <q>﴿وَیَـٰقَوۡمِ لَاۤ أَسۡـَٔلُكُمۡ عَلَیۡهِ مَالًاۖ إِنۡ أَجۡرِیَ إِلَّا عَلَى ٱللَّهِۚ﴾</q> - تفسير ٣٥٣٨٣- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿إن أجري﴾</q>، قال: جزائي{1}. (٨/٣٧) ٣٥٣٨٤- قال مقاتل بن سليمان: <q>﴿ويا قَوْمِ لا أسْأَلُكُمْ عَلَيْهِ مالًا﴾</q> يعني: جُعْلًا على الإيمان، <q>﴿إنْ أجْرِيَ﴾</q> يعني: ما جزائي <q>﴿إلا عَلى اللَّهِ﴾</q> في الآخرة{2}. (ز) <q>﴿وَمَاۤ أَنَا۠ بِطَارِدِ ٱلَّذِینَ ءَامَنُوۤا۟ۚ﴾</q> - تفسير ٣٥٣٨٥- قال مقاتل بن سليمان: <q>﴿وما أنا بِطارِدِ الَّذِينَ آمَنُوا﴾</q>، يعني: وما أنا بالذي لا أقبل الإيمانَ مِن السَّفِلَة عندكم{2}. (ز) ٣٥٣٨٦- عن عبد الملك ابن جُرَيْج -من طريق حجّاج- في قوله: <q>﴿وما أنا بطارد الذين ءامنوا﴾</q>، قال: قالوا له: يا نوح، إن أحببت أن نَتَّبِعَك فاطرُدهم، وإلّا فلن نرضى أن نكون نحن وهم في الأمر سواء{4}. (٨/٣٧) <q>﴿إِنَّهُم مُّلَـٰقُوا۟ رَبِّهِمۡ وَلَـٰكِنِّیۤ أَرَىٰكُمۡ قَوۡمࣰا تَجۡهَلُونَ ۝٢٩﴾</q> - تفسير ٣٥٣٨٧- عن سعيد بن جبير -من طريق جعفر- في قوله: <q>﴿إنهم ملاقوا ربهم﴾</q>، قال: الذين شَرَوْا أنفسَهم لله، ووَطَّنُوها{5} على الموت{6}. (ز) ٣٥٣٨٨- عن عبد الملك ابن جريج -من طريق حجاج- في قوله: <q>﴿إنهم ملاقوا ربهم﴾</q>، قال: فيسألهم عن أعمالهم{4}. (٨/٣٧) ٣٥٣٨٩- قال مقاتل بن سليمان: ثم قال: <q>﴿إنهم ملاقوا ربهم﴾</q> فيجزيهم بإيمانهم، كقوله: <q>﴿إنْ حِسابُهُمْ إلّا عَلى رَبِّي لَوْ تَشْعُرُونَ﴾</q> [الشعراء:١١٣] يعني: لو تعلمون إذا لقوه، <q>﴿إنَّهُمْ مُلاقُو رَبِّهِمْ ولَكِنِّي أراكُمْ قَوْمًا تَجْهَلُونَ﴾</q> ما آمرُكُم به، وما جِئْتُ به{2}. (ز) ",footnotes:1:تفسير مجاهد ص٣٨٦، وأخرجه ابن جرير ١٢/٣٨٥.تفسير مقاتل بن سليمان ٢/٢٧٩.تفسير مقاتل بن سليمان ٢/٢٧٩.أخرجه ابن جرير ١٢/٣٨٥. وعزاه السيوطي إلى أبي الشيخ.وطَّنَ نفسه على الشيء: حملها عليه فتحَمَّلَت، وذَلَّت له. لسان العرب (وطن).أخرجه ابن أبي حاتم ٦/٢٠٢٣. وأورده قبل ذلك في تفسير قوله تعالى: <q>﴿الَّذِينَ يَظُنُّونَ أنَّهُمْ مُلاقُو رَبِّهِمْ وأَنَّهُمْ إلَيْهِ راجِعُونَ﴾</q> [البقرة:٤٦]، وهو ألصق بسياقها.أخرجه ابن جرير ١٢/٣٨٥. وعزاه السيوطي إلى أبي الشيخ.تفسير مقاتل بن سليمان ٢/٢٧٩.
11,30," <q>﴿وَیَـٰقَوۡمِ مَن یَنصُرُنِی مِنَ ٱللَّهِ إِن طَرَدتُّهُمۡۚ أَفَلَا تَذَكَّرُونَ ۝٣٠﴾</q> - تفسير ٣٥٣٩٠- قال مقاتل بن سليمان: <q>﴿ويا قَوْمِ مَن يَنْصُرُنِي مِنَ اللَّهِ﴾</q> يَمْنَعُنِي من الله <q>﴿إنْ طَرَدْتُهُمْ﴾</q> يعنى: إن لم أقبل منهم الإيمانَ، أي: مِن السَّفِلَة، <q>﴿أفَلا﴾</q> يعني: أفَهَلّا <q>﴿تَذَكَّرُونَ﴾</q> أنّه لا مانِع لأحدٍ مِن الله{1}. (ز) ",footnotes:1:تفسير مقاتل بن سليمان ٢/٢٧٩.
11,31," <q>﴿وَلَاۤ أَقُولُ لَكُمۡ عِندِی خَزَاۤىِٕنُ ٱللَّهِ وَلَاۤ أَعۡلَمُ ٱلۡغَیۡبَ وَلَاۤ أَقُولُ إِنِّی مَلَكࣱ﴾</q> - تفسير ٣٥٣٩١- قال مقاتل بن سليمان: <q>﴿ولا أقُولُ لَكُمْ عِنْدِي خَزائِنُ اللَّهِ﴾</q> يعني: مفاتيح الله بأنّه يهدي السَّفِلَة دونكم، <q>﴿ولا أعْلَمُ الغَيْبَ﴾</q> يقول: ولا أقول لكم عندي غيبُ ذلك أنّ الله يهديهم، وذلك قول نوح في الشعراء: <q>﴿وما علمي بما كانوا يعملون﴾</q> [الشعراء:١١٢]، ثم قال لهم نوح: <q>﴿ولا أقُولُ إنِّي مَلَكٌ﴾</q> مِن الملائكة، إنّما أنا بشر. لقولهم: <q>﴿ما نَراكَ إلّا بَشَرًا مِثْلَنا﴾</q> [هود:٢٧] إلى آخر الآية{1}. (ز) ٣٥٣٩٢- عن عبد الملك ابن جُرَيْج -من طريق حجّاج- في قوله: <q>﴿ولا أقول لكم عندي خزائن الله﴾</q> التي لا يُفنِيها شيء، فأكون إنّما أدعوكم لتتبعوني عليها؛ لأُعطِيَكم منها بملكه لي عليها، <q>﴿ولا أعلم الغيب﴾</q> لا أقول: اتَّبِعوني على علمي بالغيب، <q>﴿ولا أقول إني ملك﴾</q> نَزَلْتُ مِن السماء برسالة، ما أنا إلا بشر مثلكم{2}٣٢٠٥. (٨/٣٧) ٣٢٠٥ لم يذكر ابنُ جرير (١٢/٣٨٧) غير قول ابن جريج. <q>﴿وَلَاۤ أَقُولُ لِلَّذِینَ تَزۡدَرِیۤ أَعۡیُنُكُمۡ﴾</q> - تفسير ٣٥٣٩٣- قال مقاتل بن سليمان: <q>﴿ولا أقول للذين تزدري أعينكم﴾</q>، يعني: السَّفِلَة{1}. (ز) ٣٥٣٩٤- عن عبد الرحمن بن زيد بن أسلم -من طريق أصبغ بن الفرج- <q>﴿ولا أقول للذين تزدري أعينكم﴾</q>، قال: حَقَّرتُموهم{4}. (٨/٣٧) <q>﴿لَن یُؤۡتِیَهُمُ ٱللَّهُ خَیۡرًاۖ ٱللَّهُ أَعۡلَمُ بِمَا فِیۤ أَنفُسِهِمۡ إِنِّیۤ إِذࣰا لَّمِنَ ٱلظَّـٰلِمِینَ ۝٣١﴾</q> - تفسير ٣٥٣٩٥- عن إسماعيل السُّدِّيّ، في قوله: <q>﴿لن يؤتيَهُمُ الله خيرًا﴾</q>، قال: يعني: إيمانًا{5}. (٨/٣٨) ٣٥٣٩٦- قال مقاتل بن سليمان: <q>﴿لن يؤتيَهُمُ الله خيرًا﴾</q> يعني: إيمانًا، وإن كانوا عندكم سَفِلَة، <q>﴿اللَّهُ أعْلَمُ بِما فِي أنْفُسِهِمْ﴾</q> يعني: بما في قلوبهم، يعني: السَّفِلَة، من الإيمان. قال نوح: <q>﴿إنِّي إذًا لَمِنَ الظّالِمِينَ﴾</q> إن لم أقبل منهم الإيمان{6}٣٢٠٦. (ز) ٣٢٠٦ قال ابنُ عطية (٤/٥٦٧): «وقوله: <q>﴿اللَّهُ أعْلَمُ بِما فِي أنْفُسِهِمْ﴾</q> تسليم لله تعالى، أي: لست أحكم عليهم بشيء من هذا، وإنما يحكم عليهم بذلك ويَخْرُج حكمه إلى حَيِّز الوجود اللهُ تعالى الذي يعلم ما في نفوسهم ويجازيهم بذلك. وقد قال بعض المتأولين: هي ردٌّ على قولهم: اتبعك أراذلنا على ما يظهر منهم. حسبما تقدم في بعض تأويلات تلك الآية آنفًا، فالمعنى: لست أنا أحكم عليهم بأن لا يكون لهم خيرٌ لظنكم بهم أنّ بواطنهم ليست كظواهرهم، الله أعلم بما في نفوسهم». ",footnotes:1:تفسير مقاتل بن سليمان ٢/٢٧٩.أخرجه ابن جرير ١٢/٣٨٧. وعزاه السيوطي إلى أبي الشيخ.تفسير مقاتل بن سليمان ٢/٢٧٩.أخرجه ابن أبي حاتم ٦/٢٠٢٣.عزاه السيوطي إلى أبي الشيخ.تفسير مقاتل بن سليمان ٢/٢٧٩-٢٨٠.
11,32," <q>﴿قَالُوا۟ یَـٰنُوحُ قَدۡ جَـٰدَلۡتَنَا فَأَكۡثَرۡتَ جِدَ ٰ⁠لَنَا﴾</q> - تفسير ٣٥٣٩٧- عن مجاهد بن جبر -من طريق ابن جريج- في قوله: <q>﴿قالوا يا نوح قد جادلتنا﴾</q>، قال: مارَيْتَنا{1}. (٨/٣٨) ٣٥٣٩٨- قال مقاتل بن سليمان: <q>﴿قالوا يا نوح قد جادلتنا﴾</q> يعني: مارَيْتَنا، <q>﴿فأكثرت جدالنا﴾</q> يعني: مِراءَنا{2}. (ز) <q>﴿فَأۡتِنَا بِمَا تَعِدُنَاۤ إِن كُنتَ مِنَ ٱلصَّـٰدِقِینَ ۝٣٢﴾</q> - تفسير ٣٥٣٩٩- قال مقاتل بن سليمان: <q>﴿فأتنا بما تعدنا﴾</q> مِن العذاب، <q>﴿إنْ كُنْتَ مِنَ الصّادِقِينَ﴾</q> بأنّ العذاب نازل بنا؛ لقوله في هذه الآية الأولى: <q>﴿إني أخاف عليكم عذاب يوم أليم﴾</q>، وذلك أنّ الله أمر نوحًا أن يُنذرهم العذاب في سورة نوح، فكذَّبوه، فقالوا: <q>﴿فَأْتِنا بِما تَعِدُنا إنْ كُنْتَ مِنَ الصّادِقِينَ﴾</q> بأنّ العذاب نازِل بنا{2}. (ز) ٣٥٤٠٠- عن عبد الملك ابن جُرَيْج -من طريق حجاج- في قوله: <q>﴿فأتنا بما تعدنا﴾</q>، قال: تكذيبًا بالعذاب، وأنّه باطل{4}. (٨/٣٨) ",footnotes:1:تفسير مجاهد ص٣٨٧، وأخرجه ابن جرير ١٢/٣٨٨، وابن أبي حاتم ٦/٢٠٢٤. وعزاه السيوطي إلى ابن المنذر، وأبي الشيخ.تفسير مقاتل بن سليمان ٢/٢٨٠.تفسير مقاتل بن سليمان ٢/٢٨٠.أخرجه ابن جرير ١٢/٣٨٨. وعزاه السيوطي إلى أبي الشيخ.
11,33," <q>﴿قَالَ إِنَّمَا یَأۡتِیكُم بِهِ ٱللَّهُ إِن شَاۤءَ وَمَاۤ أَنتُم بِمُعۡجِزِینَ ۝٣٣﴾</q> - تفسير ٣٥٤٠١- قال عبد الله بن عباس -من طريق الضحاك- <q>﴿بِمُعْجِزِينَ﴾</q>: بمُسابِقين{1}. (ز) ٣٥٤٠٢- قال مقاتل بن سليمان: فرَدَّ عليهم نوح، قال: <q>﴿إنما يأتيكم به الله إن شاء﴾</q> وليس ذلك بيدي، <q>﴿وما أنتم بمعجزين﴾</q> يعني: بسابقي اللهِ بأعمالكم الخبيثةِ حتى يجزيكم بها{2}. (ز) ",footnotes:1:أخرجه ابن أبي حاتم ٦/٢٠٢٤.تفسير مقاتل بن سليمان ٢/٢٨٠.
11,34," <q>﴿وَلَا یَنفَعُكُمۡ نُصۡحِیۤ إِنۡ أَرَدتُّ أَنۡ أَنصَحَ لَكُمۡ إِن كَانَ ٱللَّهُ یُرِیدُ أَن یُغۡوِیَكُمۡۚ﴾</q> - تفسير ٣٥٤٠٣- قال مقاتل بن سليمان: <q>﴿ولا يَنْفَعُكُمْ نُصْحِي﴾</q> فيما أُحَذِّرُكم مِن العذاب <q>﴿إنْ أرَدْتُ أنْ أنْصَحَ لَكُمْ إنْ كانَ اللَّهُ يُرِيدُ أنْ يُغْوِيَكُمْ﴾</q> يعني: يُضِلَّكم عن الهدى، فـ<q>﴿هو ربكم﴾</q>{1}٣٢٠٧. (ز) ٣٢٠٧ قال ابنُ عطية (٤/٥٦٨-٥٦٩بتصرف): «وقالت فرقة: معنى قوله: <q>﴿يُغْوِيَكُمْ﴾</q>: يضلكم، مِن قولهم: غوى الرجل يغوى ... وإذا كان هذا معنى اللفظة ففي الآية حُجَّة على المعتزلة القائلين: إنّ الضلال إنّما هو من العبد». ثم قال: «وقالت فرقة: معنى قوله: <q>﴿يُغْوِيَكُمْ﴾</q>: يهلككم، والغوى: المرض والهلاك، وفي لغة طيّء: أصبح فلان غاويًا، أي: مريضًا، والغوى: بَشَمُ الفصيل. قاله يعقوب في الإصلاح. وقيل: فقْده اللبن حتى يموت جوعًا. قاله الفرّاء، وحكاه الطبري. يقال: غوى يغوى، وحكى الزَّهراوي: أنه الذي قُطِع عنه اللبن حتى كاد يهلك ولَمّا يهلك بعدُ. فإذا كان هذا معنى اللفظة زال موضع النظر بين أهل السنة والمعتزلة، وبقي الاحتجاج عليهم بما هو أبين من هذه الآية، كقوله تعالى: <q>﴿فَمَن يُرِدِ اللَّهُ أنْ يَهْدِيَهُ يَشْرَحْ صَدْرَهُ لِلْإسْلامِ﴾</q> [الأنعام:١٢٥] ونحوها. وأعتقد مكيٌّ أنّ للمعتزلة تَعَلُّقًا وحُجَّة بالغة بهذا التأويل، فردَّ عليه وأفرط حتى أنكر أن يكون الغوى بمعنى الهلاك موجودًا في لسان العرب». <q>﴿هُوَ رَبُّكُمۡ وَإِلَیۡهِ تُرۡجَعُونَ ۝٣٤﴾</q> - تفسير ٣٥٤٠٤- عن أبي العالية الرياحي -من طريق الربيع- <q>﴿وإليه ترجعون﴾</q>، قال: إليه يرجعون بعد الحياة{2}. (ز) ٣٥٤٠٥- قال مقاتل بن سليمان:<q>﴿هو ربكم﴾</q> ليس له شريك، <q>﴿وإليه ترجعون﴾</q> بعد الموت، فيجزيكم بأعمالكم{1}. (ز) ",footnotes:1:تفسير مقاتل بن سليمان ٢/٢٨٠.أخرجه ابن أبي حاتم ٦/٢٠٢٤.تفسير مقاتل بن سليمان ٢/٢٨٠.
11,35," <q>﴿أَمۡ یَقُولُونَ ٱفۡتَرَىٰهُۖ﴾</q> - تفسير ٣٥٤٠٦- قال عبد الله بن عباس: يعني: نوحًا ﵇{1}. (ز) ٣٥٤٠٧- قال مقاتل بن سليمان: ثم ذكر الله تعالى كُفّار أُمَّةِ محمد ﷺ مِن أهل مكة، فقال: <q>﴿أمْ يَقُولُونَ افْتَراهُ﴾</q>. نظيرها في حم الزخرف: <q>﴿أمْ أنا خَيْرٌ﴾</q> يعني: بل أنا خير <q>﴿مِن هَذا الَّذِي هُوَ مَهِينٌ﴾</q> [الزخرف:٥٢]. <q>﴿افْتَراهُ﴾</q>، قالوا: محمد يقول هذا القرآن مِن تلقاء نفسه، وليس من الله{2}٣٢٠٨. (ز) ٣٢٠٨ قال ابنُ عطية (٤/٥٦٩): «وقوله تعالى: <q>﴿أمْ يَقُولُونَ افْتَراهُ﴾</q> الآية، قال الطبريُّ وغيرُه من المتأولين والمؤلفين في التفسير: إنّ هذه الآية اعترضت في قصة نوح ﵇، وهي شأن محمد ﷺ مع كفار قريش، وذلك أنهم قالوا: افترى القرآن، وافترى هذه القصة على نوح. فنَزلت الآية في ذلك. وهذا لو صَحَّ بسند وجب الوقوف عنده، وإلا فهو يحتمل أن يكون في شأن نوح ﵇، ويبقى اتِّساق الآيةِ مُطَّرِدًا، ويكون الضمير في قوله: <q>﴿افْتَراهُ﴾</q> عائدًا إلى العذاب الذي تَوَعَّدهم به، أو على جميع أخباره، وأوقع الافتراء على العذاب من حيث يقع على الإخبار به. والمعنى: أم يقول هؤلاء الكفرة: افترى نوحٌ هذا التَّوَعُّد بالعذاب، وأراد الإرهاب علينا بذلك. ثُمَّ يَطَّرِدُ باقي الآية على هذا». <q>﴿قُلۡ إِنِ ٱفۡتَرَیۡتُهُۥ فَعَلَیَّ إِجۡرَامِی وَأَنَا۠ بَرِیۤءࣱ مِّمَّا تُجۡرِمُونَ ۝٣٥﴾</q> - تفسير ٣٥٤٠٨- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿فعليَّ إجرامي﴾</q> قال: عملي، <q>﴿وأنا بريء مما تجرمون﴾</q> أي: مِمّا تعملون{3}. (٨/٣٨) ٣٥٤٠٩- قال مقاتل بن سليمان: <q>﴿قُلْ إنِ افْتَرَيْتُهُ﴾</q> يعني: تَقَوَّلْتُه مِن تِلقاء نفسي <q>﴿فعليَّ إجرامي﴾</q> فعَلَيَّ خطيئتي بافترائي على الله، <q>﴿وأَنا بَرِيءٌ مِمّا تُجْرِمُونَ﴾</q> يعني: بريء مِن خطاياكم، يعني: كفركم بالله ﷿{4}. (ز) ",footnotes:1:تفسير الثعلبي ٥/١٦٦، وتفسير البغوي ٤/١٧٣.تفسير مقاتل بن سليمان ٢/٢٨٠-٢٨١.أخرجه ابن أبي حاتم ٦/٢٠٢٤.تفسير مقاتل بن سليمان ٢/٢٨١.
11,36," <q>﴿وَأُوحِیَ إِلَىٰ نُوحٍ أَنَّهُۥ لَن یُؤۡمِنَ مِن قَوۡمِكَ إِلَّا مَن قَدۡ ءَامَنَ فَلَا تَبۡتَىِٕسۡ بِمَا كَانُوا۟ یَفۡعَلُونَ ۝٣٦﴾</q> - تفسير ٣٥٤١٠- عن عبد الله بن عباس -من طريق الضحاك- قال: إنّ نوحًا ﵇ كان يُضرَب، ثم يُلَفُّ في لَبَدٍ{1}، فيُلقى في بيته، يَرَوْن أنّه قد مات، ثم يخرج فيدعوهم، حتى إذا أيِس مِن إيمان قومه جاءه رجلٌ ومعه ابنُه وهو يَتَوَكَّأ على عصا، فقال: يا بني، انظر هذا الشيخَ، لا يَغُرَّنَّك. قال: يا أبتِ، أمْكِنِّي مِن العصا. ثم أخذ العصا، ثم قال: ضَعْنِي في الأرض. فوضعه، فمشى إليه، فضربه، فشجَّه مُوضِحَةً{2} في رأسه، وسالت الدماء. قال نوح ﵇: ربِّ، قد ترى ما يفعل بي عبادُك، فإن يكن لك في عبادك حاجةً فاهدِهم، وإن يكن غير ذلك فصَبِّرني إلى أن تحكم، وأنت خير الحاكمين. فأوحى اللهُ إليه وآيَسَه مِن إيمان قومه، وأخبره أنّه لم يبق في أصلاب الرجال ولا في أرحام النساء مُؤْمِن، قال: يا نوح، إنّه لن يؤمن من قومك إلا من قد آمن، فلا تبتئس بما كانوا يفعلون. يعني: لا تحزن عليهم{3}. (٨/٣٩) ٣٥٤١١- عن الضَّحّاك بن مُزاحِم -من طريق عبيد بن سليمان- يقول في قوله: <q>﴿لن يؤمن من قومك إلا من قد آمن﴾</q>: فحينئذٍ دعا على قومه، لَمّا بَيَّن اللهُ له أنّه لن يؤمن مِن قومه إلا مَن قد آمَن{4}. (ز) ٣٥٤١٢- عن الحسن [البصري] -من طريق صالح المُرِّيّ- قال: إنّ نوحًا لم يَدْعُ على قومه حتى نزلت عليه الآية: <q>﴿وأوحي إلى نوح أنه لن يؤمن من قومك إلا من قد آمن﴾</q>. فانقطع عند ذلك رجاؤُه منهم، فدعا عليهم{5}. (٨/٣٨) ٣٥٤١٣- عن محمد بن كعب القرظي -من طريق أيوب- قال: لَمّا استنقذ الله مِن أصلاب الرجال وأرحام النساء كلَّ مؤمن ومؤمنةٍ قال: يا نوحُ، إنه لن يؤمن من قومك إلا من قد ءامن{6}. (٨/٣٩) ٣٥٤١٤- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿وأوحي إلى نوح أنه لن يؤمن من قومك إلا من قد ءامن﴾</q>: وذلك حين دعا عليهم نوح ﵇، قال: <q>﴿ربِ لا تذر على الأرض من الكافرين ديارا﴾</q> [نوح:٢٦]{7}. (٨/٣٨) ٣٥٤١٥- قال مقاتل بن سليمان: ثُمَّ ذَكَر نوحًا، فقال: <q>﴿وأوحي إلى نوح أنه لن يؤمن من قومك إلا من قد آمن﴾</q>، يعني: إلّا مَن صَدَّق بتوحيد الله{8}. (ز) <q>﴿فَلَا تَبۡتَىِٕسۡ بِمَا كَانُوا۟ یَفۡعَلُونَ ۝٣٦﴾</q> - تفسير ٣٥٤١٦- عن عبد الله بن عباس -من طريق العوفي- في قوله: <q>﴿فلا تبتئس﴾</q>، قال: فلا تَحْزَن{9}. (٨/٤٠) ٣٥٤١٧- عن مجاهد بن جبر -من طريق ابن أبي نجيح- <q>﴿فلا تبتئس﴾</q>، قال: لا تحزن{10}. (ز) ٣٥٤١٨- عن قتادة بن دعامة -من طريق سعيد- قوله: <q>﴿فلا تبتئس﴾</q>، يقول: فلا تَأْسَ، ولا تَحْزَن{11}. (ز) ٣٥٤١٩- قال مقاتل بن سليمان: <q>﴿فلا تبتئس﴾</q> يعني: فلا تحزن <q>﴿بما كانوا يفعلون﴾</q> يعني: بكفرهم بالله ﷿{8}. (ز) ",footnotes:1:كل شَعر أو صوف مُلْتَبدٍ بعضه على بعض فهو لِبْد، واللِّبْدُ من البُسُط: معروف. لسان العرب (لبد).المُوضِحَةُ: هي التي تُبدي وضَحَ العظم، أي: بياضه. النهاية (وضح).أخرجه ابن عساكر ٦٢/٢٤٧-٢٤٨. وعزاه السيوطي إلى إسحاق بن بشر.أخرجه ابن جرير ١٢/٣٩١.أخرجه أحمد في الزهد ص١٥. وعزاه السيوطي إلى ابن المنذر، وأبي الشيخ.أخرجه ابن أبي حاتم ٦/٢٠٢٤. وعزاه السيوطي إلى أبي الشيخ.أخرجه ابن جرير ١٢/٣٩١، وابن أبي حاتم ٦/٢٠٢٤. وذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٢/٢٨٧-. وعزاه السيوطي إلى أبي الشيخ.تفسير مقاتل بن سليمان ٢/٢٨١.أخرجه ابن جرير ١٢/٣٩١، وابن أبي حاتم ٦/٢٠٢٥.تفسير مجاهد ص٣٨٧، وأخرجه ابن جرير ١٢/٣٩٠، وابن أبي حاتم ٦/٢٠٢٥.أخرجه ابن جرير ١٢/٣٩١، كما أخرج عبد الرزاق ١/٣٠٤ نحوه من طريق معمر.تفسير مقاتل بن سليمان ٢/٢٨١.
11,37," <q>﴿وَٱصۡنَعِ ٱلۡفُلۡكَ﴾</q> - تفسير ٣٥٤٢٠- عن عبد الله بن عباس -من طريق الضحّاك- <q>﴿واصنع الفلك﴾</q>، قال: يا ربِّ، وما الفُلْك؟ قال: بيتٌ مِن خشب، يجري على وجه الماء، فأُغرِقُ أهلَ معصيتي، وأُطَهِّر أرضي منهم. قال: يا ربِّ، وأين الماء؟ قال: إنِّي على ما أشاء قدير{1}. (٨/٣٩) ٣٥٤٢١- عن عبد الله بن عباس -من طريق العوفي- قال: لم يعلم نوحٌ ﵇ كيف يَصْنَع الفلك، فأوحى الله إليه أن يصنعها على مثل جُؤْجُؤِ{2} الطائِر{3}٣٢٠٩. (٨/٤٠) ٣٢٠٩ ذكر ابنُ عطية (٤/٥٧٣) في هيئة سفينة نوح قولًا أنّها كانت مربعة الشكل، طويلة في السماء، ضيقة الأعلى، وأنّ الغرض منها إنّما كان الحفظ، لا سرعة الجري، ثم قال: «والحديث الذي تَضَمَّن أنها كجؤجؤ الطائر أصَحُّ، ومعناه أظهر؛ لأنها لو كانت مربعة لم تكن فلكًا، بل كانت وعاء فقط، وقد وصفها الله تعالى بالجري في البحر، وفي الحديث: «كان راز سفينة نوح ﵇ جبريل ﵇». والراز: القيِّم بعمل السفن». ٣٥٤٢٢- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿واصنع الفلك﴾</q>، قال: السفينة{4}. (٨/٤٠) ٣٥٤٢٣- عن أبي صالح باذام -من طريق إسماعيل بن أبي خالد- في قوله: <q>﴿الفلك﴾</q>، قال: سفينة نوح{5}. (ز) ٣٥٤٢٤- قال مقاتل بن سليمان: <q>﴿واصْنَعِ الفُلْكَ﴾</q>، يعني: السفينة{6}. (ز) <q>﴿بِأَعۡیُنِنَا وَوَحۡیِنَا﴾</q> - تفسير ٣٥٤٢٥- عن عبد الله بن عباس -من طريق عطاء الخراساني- في قوله: <q>﴿واصنع الفلك بأعيننا ووحينا﴾</q>، قال: بعين الله، ووحيه{7}. (٨/٤٠) ٣٥٤٢٦- قال عبد الله بن عباس، في قوله: <q>﴿واصنع الفلك بأعيننا﴾</q>: بمَرْأًى مِنّا{8}. (ز) ٣٥٤٢٧- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿بأعيننا ووحينا﴾</q>، قال: كما نأمرك{9}٣٢١٠. (٨/٤٠) ٣٢١٠ انتَقَدَ ابنُ عطية (٤/٥٧٣) مستندًا إلى السياق ما جاء في قول مجاهد وغيره بقوله: «ومَن فسر قوله: <q>﴿ووَحْيِنا﴾</q> أي: بأمرنا لك، فذلك ضعيف؛ لأن قوله: <q>﴿واصْنَعِ الفُلْكَ﴾</q> مُغْنٍ عن ذلك». ٣٥٤٢٨- قال الضحاك بن مزاحم، في قوله: <q>﴿واصنع الفلك بأعيننا﴾</q>: بمنظَرٍ مِنّا{10}. (ز) ٣٥٤٢٩- عن قتادة بن دعامة -من طريق معمر- في قوله: <q>﴿بأعيننا ووحينا﴾</q>، قال: بعين الله، ووحيه{11}٣٢١١. (ز) ٣٢١١ لم يذكر ابنُ جرير (١٢/٣٩٢-٣٩٣) غير قول قتادة، ومجاهد. ٣٥٤٣٠- عن عطاء الخراساني -من طريق عثمان بن عطاء-: وأمّا قوله: <q>﴿بأعيننا ووحينا﴾</q> فيُقال: بعين الله، ورحمته{12}. (ز) ٣٥٤٣١- قال الربيع بن أنس، في قوله: <q>﴿واصنع الفلك بأعيننا﴾</q>: بِحِفْظِنا{10}. (ز) ٣٥٤٣٢- قال مقاتل بن سليمان: <q>﴿بأعيننا﴾</q>، يعني: بعلمنا ووحينا كما نأمرك، فعمِلها نوحٌ في أربعمائة سنة، وكانت السفينة مِن ساجٍ{6}. (ز) ٣٥٤٣٣- عن سفيان بن عُيَيْنة، قال: ما وصف الله تبارك به نفسَه في كتابه فقِراءته تفسيرُه، ليس لأحد أن يُفَسِّره بالعربية ولا بالفارسية{15}٣٢١٢. (٨/٤٠) ٣٢١٢ ذكر ابنُ عطية (٤/٥٧٢) في قوله: <q>﴿بأعيننا﴾</q> احتمالين، فقال: «وقوله: <q>﴿بِأَعْيُنِنا﴾</q> يمكن -فيما يتأول- أن يريد به: بمرأًى منا وتحت إدراك، فتكون عبارة عن الإدراك والرعاية والحفظ، ويكون جمع الأعين للعظمة لا للتكثير، كما قال تعالى:<q>﴿فَنِعْمَ القادِرُونَ﴾</q> [المرسلات:٢٣]، فرجع معنى الأعين في هذه وفي غيرها إلى معنى عين في قوله: <q>﴿لِتُصْنَعَ عَلى عَيْنِي﴾</q> [طه:٣٩]، وذلك كله عبارة عن الإدراك وإحاطته بالمدركات، وهو تعالى مُنَزَّه عن الحواس والتشبيه والتكييف لا رب غيره. ويحتمل قوله: <q>﴿بِأَعْيُنِنا﴾</q> أي: بملائكتنا الذين جعلناهم عيونًا على مواضع حفظك ومعونتك، فيكون الجمع على هذا للتكثير». انتهى كلامه، وما قاله من نفي صفة العينين لله تعالى باطل، والحق إثباتهما له سبحانه على ما يليق بجلاله وكماله وعظمته، وهو إجماع السلف من الصحابة والتابعين وتابعيهم، ينظر: الإبانة الكبرى ٣/١١٣-١٢٧، شرح أصول اعتقاد أهل السنة ٢/٤٥٧-٤٨١. <q>﴿وَلَا تُخَـٰطِبۡنِی فِی ٱلَّذِینَ ظَلَمُوۤا۟ إِنَّهُم مُّغۡرَقُونَ ۝٣٧﴾</q> - تفسير ٣٥٤٣٤- عن عُبَيد بن عُمير الليثي -من طريق محمد بن إسحاق- أنّه كان يُحَدِّث، أنّه بَلَغَه: أنهم كانوا يبطشون به -يعني: قوم نوح-، فيخنقونه حتى يغشى عليه، فإذا أفاق قال: اللَّهُمَّ، اغفِر لقومي؛ فإنّهم لا يعلمون. حتى إذا تَمادَوْا في المعصية، وعَظمت في الأرض منهم الخطيئة، وتطاول عليه وعليهم الشأن، واشتد عليه منهم البلاء، وانتظر النَّجْلَ{16} بعد النَّجْلِ، فلا يأتي قرنٌ إلا كان أخبثَ مِن القرن الذي قبله، حتى إن كان الآخر منهم لَيقول: قد كان هذا مع آبائنا ومع أجدادنا هكذا مجنونًا. لا يَقْبَلون منه شيئًا، حتى شَكا ذلك مِن أمرهم نوحٌ إلى الله تعالى، كما قصَّ الله علينا في كتابه: <q>﴿رب إني دعوت قومي ليلا ونهارا فلم يزدهم دعائي إلا فرارا﴾</q> [نوح:٥-٦] إلى آخر القصة، حتى قال: <q>﴿رب لا تذر على الأرض من الكافرين ديارا إنك إن تذرهم يضلوا عبادك ولا يلدوا إلا فاجرا كفارا﴾</q> إلى آخر القصة، فلَمّا شكا ذلك منهم نوحٌ إلى الله واستنصره عليهم أوحى الله إليه أن: <q>﴿واصنع الفلك بأعيننا ووحينا ولا تخاطبني في الذين ظلموا﴾</q> أي: بعد اليوم؛ <q>﴿إنهم مغرقون﴾</q>. فأقبل نوحٌ على عَمَلِ الفُلَك، ولَهِيَ عن قومه، وجعل يقطع الخشب، ويضرب الحديد، ويُهَيِّءُ عِدَّة الفلك مِن القارِ وغيره مِمّا لا يصلحه إلا هو، وجعل قومُه يَمُرُّون به وهو في ذلك مِن عمله، فيسخرون منه، ويستهزئون به، فيقول: <q>﴿إن تسخروا منا فإنا نسخر منكم كما تسخرون فسوف تعلمون من يأتيه عذاب يخزيه ويحل عليه عذاب مقيم﴾</q>. قال: ويقولون له فيما بلغني: يا نوحُ، قد صِرْتَ نَجّارًا بعد النُّبُوَّة؟! قال: وأَعْقَمَ اللهُ أرحامَ النساء، فلا يولد لهم ولد. قال: ويزعمُ أهل التوراة: أنّ الله أمره أن يصنع الفلك مِن خشب السّاج، وأن يصنعه أزْوَرَ{17}، وأن يَطْلِيه بالقارِ مِن داخله وخارجه، وأن يجعل طوله ثمانين ذراعًا، وأن يجعله ثلاثة أطباق؛ سفلًا ووسطًا وعلوًا، وأن يجعل فيه كِوًى{18}. ففعل نوحٌ كما أمره الله، حتى إذا فرغ منه، وقد عهد الله إليه: إذا جاء أمرنا وفار التنور فاحمل فيها من كل زوجين اثنين، وأهلك إلا من سبق عليه القول، ومَن آمن، وما آمَن معه إلا قليل. وقد جعل التنور آيةً فيما بينه وبينه، فقال: <q>﴿حتى إذا جاء أمرنا وفار التنور قلنا احمل فيها من كل زوجين اثنين﴾</q> [المؤمنون:٢٧]، واركب. فلمّا فار التَّنُّورُ حمل نوح في الفلك مَن أمره الله، وكانوا قليلًا كما قال الله، وحمل فيها مِن كل زوجين اثنين مِمّا فيه الروح والشجر، ذكر وأنثى، فحمل فيه بَنِيه الثلاثةَ -سام، وحام، ويافث- ونساءَهم، وسِتَّةَ أُناسٍ مِمَّن كان آمن به، فكانوا عشرة نفر؛ نوح وبنوه وأزواجهم، ثم أدخل ما أمره به من الدواب، وتخلف عنه ابنُه يام، وكان كافرًا{19}. (ز) ٣٥٤٣٥- عن قتادة بن دعامة -من طريق سعيد- في الآية، قال: نهى الله نوحًا ﵇ أن يُراجِعه بعد ذلك في أحَد{20}. (٨/٤٠) ٣٥٤٣٦- قال مقاتل بن سليمان: <q>﴿ولا تخاطبني﴾</q> يقول: ولا تُراجِعْنِي <q>﴿في الذين ظلموا﴾</q> يعني: الذين أشركوا، وهو ابنُه كنعان بن نوح، فإنّه من الذين ظلموا، <q>﴿إنَّهُمْ مُغْرَقُونَ﴾</q> لقول نوح: <q>﴿رَبِّ إنَّ ابْنِي مِن أهْلِي وإنَّ وعْدَكَ الحَقُّ وأَنْتَ أحْكَمُ الحاكِمِينَ﴾</q> [هود:٤٥]{6}. (ز) ٣٥٤٣٧- عن عبد الملك ابن جُرَيْج -من طريق حجّاج- في قوله: <q>﴿ولا تخاطبني في الذين ظلموا﴾</q>، يقول: لا تُراجِعْنِي. تقدَّم إليه ألّا يَشْفَعَ لهم عندَه{22}. (٨/٤٠) ٣٥٤٣٨- عن محمد بن إسحاق -من طريق سلمة-: فلَمّا شكا ذلك منهم نوحٌ إلى الله ﷿، واسْتَنصَر عليهم؛ أوحى الله إليه: <q>﴿أن اصنع الفلك بأعيننا ووحينا ولا تخاطبني في الذين ظلموا﴾</q> أي: بعد اليوم، <q>﴿إنهم مغرقون﴾</q>{12}. (ز) ",footnotes:1:أخرجه ابن عساكر ٦٢/٢٤٧-٢٤٨. وعزاه السيوطي إلى إسحاق بن بشر.جؤْجؤُ الطير: صدره. وقيل: عِظامه. النهاية (جؤجؤ).أخرجه ابن جرير ١٢/٣٩٢، وابن أبي حاتم ٦/٢٠٢٥.أخرجه ابن جرير ١٢/٣٩٢، وابن أبي حاتم ٦/٢٠٢٦. وعزاه السيوطي إلى أبي الشيخ.أخرجه ابن أبي حاتم ٦/٢٠٢٥.تفسير مقاتل بن سليمان ٢/٢٨١.أخرجه ابن جرير ١٢/٣٩٢، وابن أبي حاتم ٦/٢٠٢٦، والبيهقي في الأسماء والصفات (٦٨٢) نحوه. وعزاه السيوطي إلى أبي الشيخ.تفسير البغوي ٤/١٧٣.تفسير مجاهد ص٣٨٧، وأخرجه ابن جرير ١٢/٣٩٢، وابن أبي حاتم ٦/٢٠٢٦. وعزاه السيوطي إلى أبي الشيخ.تفسير الثعلبي ٥/١٦٦.أخرجه عبد الرزاق ١/٣٠٤، وابن جرير ١٢/٣٦٨.أخرجه ابن أبي حاتم ٦/٢٠٢٦.تفسير الثعلبي ٥/١٦٦.تفسير مقاتل بن سليمان ٢/٢٨١.أخرجه البيهقي (٦٨٣).النَّجْل: النَّسْل. لسان العرب (نجل).الأَزْوَرُ: المائِلُ. تاج العروس (زور).الكِوى: جمع كوَّةُ: وهي الخَرْق في الحائط، والثَّقْب في البيت ونحوه. لسان العرب (كوي).أخرجه ابن جرير ١٢/٣٩٦، وابن أبي حاتم ٦/٢٠٢٢ مختصرًا.أخرجه ابن أبي حاتم ٦/٢٠٢٦. وعزاه السيوطي إلى أبي الشيخ.تفسير مقاتل بن سليمان ٢/٢٨١.أخرجه ابن جرير ٦/٣٩٣. وعزاه السيوطي إلى أبي الشيخ.أخرجه ابن أبي حاتم ٦/٢٠٢٦.
