quran[9]{c,v,t}:
  11,29,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَیَـٰقَوۡمِ لَاۤ أَسۡـَٔلُكُمۡ عَلَیۡهِ مَالًاۖ إِنۡ أَجۡرِیَ إِلَّا عَلَى ٱللَّهِۚ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٥٣٨٣<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿إن أجري﴾</span>، قال: جزائي{1}. (٨/٣٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٣٨٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ويا قَوْمِ لا أسْأَلُكُمْ عَلَيْهِ مالًا﴾</span> يعني: جُعْلًا على الإيمان، <span class="qpc-hafs">﴿إنْ أجْرِيَ﴾</span> يعني: ما جزائي <span class="qpc-hafs">﴿إلا عَلى اللَّهِ﴾</span> في الآخرة{2}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَمَاۤ أَنَا۠ بِطَارِدِ ٱلَّذِینَ ءَامَنُوۤا۟ۚ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٥٣٨٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وما أنا بِطارِدِ الَّذِينَ آمَنُوا﴾</span>، يعني: وما أنا بالذي لا أقبل الإيمانَ مِن السَّفِلَة عندكم{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٣٨٦<span class="dash">-</span></span> عن <span class="name-3">عبد الملك ابن جُرَيْج</span> -من طريق حجّاج- في قوله: <span class="qpc-hafs">﴿وما أنا بطارد الذين ءامنوا﴾</span>، قال: قالوا له: يا نوح، إن أحببت أن نَتَّبِعَك فاطرُدهم، وإلّا فلن نرضى أن نكون نحن وهم في الأمر سواء{4}. (٨/٣٧)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿إِنَّهُم مُّلَـٰقُوا۟ رَبِّهِمۡ وَلَـٰكِنِّیۤ أَرَىٰكُمۡ قَوۡمࣰا تَجۡهَلُونَ ۝٢٩﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٥٣٨٧<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span> -من طريق جعفر- في قوله: <span class="qpc-hafs">﴿إنهم ملاقوا ربهم﴾</span>، قال: الذين شَرَوْا أنفسَهم لله، ووَطَّنُوها{5} على الموت{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٣٨٨<span class="dash">-</span></span> عن <span class="name-3">عبد الملك ابن جريج</span> -من طريق حجاج- في قوله: <span class="qpc-hafs">﴿إنهم ملاقوا ربهم﴾</span>، قال: فيسألهم عن أعمالهم{4}. (٨/٣٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٣٨٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثم قال: <span class="qpc-hafs">﴿إنهم ملاقوا ربهم﴾</span> فيجزيهم بإيمانهم، كقوله: <span class="qpc-hafs">﴿إنْ حِسابُهُمْ إلّا عَلى رَبِّي لَوْ تَشْعُرُونَ﴾</span> [الشعراء:١١٣] يعني: لو تعلمون إذا لقوه، <span class="qpc-hafs">﴿إنَّهُمْ مُلاقُو رَبِّهِمْ ولَكِنِّي أراكُمْ قَوْمًا تَجْهَلُونَ﴾</span> ما آمرُكُم به، وما جِئْتُ به{2}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير مجاهد ص٣٨٦، وأخرجه ابن جرير ١٢/٣٨٥.|2:تفسير مقاتل بن سليمان ٢/٢٧٩.|3:تفسير مقاتل بن سليمان ٢/٢٧٩.|4:أخرجه ابن جرير ١٢/٣٨٥. وعزاه السيوطي إلى أبي الشيخ.|5:وطَّنَ نفسه على الشيء: حملها عليه فتحَمَّلَت، وذَلَّت له. لسان العرب (وطن).|6:أخرجه ابن أبي حاتم ٦/٢٠٢٣. وأورده قبل ذلك في تفسير قوله تعالى: <span class="qpc-hafs">﴿الَّذِينَ يَظُنُّونَ أنَّهُمْ مُلاقُو رَبِّهِمْ وأَنَّهُمْ إلَيْهِ راجِعُونَ﴾</span> [البقرة:٤٦]، وهو ألصق بسياقها.|7:أخرجه ابن جرير ١٢/٣٨٥. وعزاه السيوطي إلى أبي الشيخ.|8:تفسير مقاتل بن سليمان ٢/٢٧٩.
  11,30,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَیَـٰقَوۡمِ مَن یَنصُرُنِی مِنَ ٱللَّهِ إِن طَرَدتُّهُمۡۚ أَفَلَا تَذَكَّرُونَ ۝٣٠﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٥٣٩٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ويا قَوْمِ مَن يَنْصُرُنِي مِنَ اللَّهِ﴾</span> يَمْنَعُنِي من الله <span class="qpc-hafs">﴿إنْ طَرَدْتُهُمْ﴾</span> يعنى: إن لم أقبل منهم الإيمانَ، أي: مِن السَّفِلَة، <span class="qpc-hafs">﴿أفَلا﴾</span> يعني: أفَهَلّا <span class="qpc-hafs">﴿تَذَكَّرُونَ﴾</span> أنّه لا مانِع لأحدٍ مِن الله{1}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٢/٢٧٩.
  11,31,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَلَاۤ أَقُولُ لَكُمۡ عِندِی خَزَاۤىِٕنُ ٱللَّهِ وَلَاۤ أَعۡلَمُ ٱلۡغَیۡبَ وَلَاۤ أَقُولُ إِنِّی مَلَكࣱ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٥٣٩١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ولا أقُولُ لَكُمْ عِنْدِي خَزائِنُ اللَّهِ﴾</span> يعني: مفاتيح الله بأنّه يهدي السَّفِلَة دونكم، <span class="qpc-hafs">﴿ولا أعْلَمُ الغَيْبَ﴾</span> يقول: ولا أقول لكم عندي غيبُ ذلك أنّ الله يهديهم، وذلك قول نوح في الشعراء: <span class="qpc-hafs">﴿وما علمي بما كانوا يعملون﴾</span> [الشعراء:١١٢]، ثم قال لهم نوح: <span class="qpc-hafs">﴿ولا أقُولُ إنِّي مَلَكٌ﴾</span> مِن الملائكة، إنّما أنا بشر. لقولهم: <span class="qpc-hafs">﴿ما نَراكَ إلّا بَشَرًا مِثْلَنا﴾</span> [هود:٢٧] إلى آخر الآية{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٣٩٢<span class="dash">-</span></span> عن <span class="name-3">عبد الملك ابن جُرَيْج</span> -من طريق حجّاج- في قوله: <span class="qpc-hafs">﴿ولا أقول لكم عندي خزائن الله﴾</span> التي لا يُفنِيها شيء، فأكون إنّما أدعوكم لتتبعوني عليها؛ لأُعطِيَكم منها بملكه لي عليها، <span class="qpc-hafs">﴿ولا أعلم الغيب﴾</span> لا أقول: اتَّبِعوني على علمي بالغيب، <span class="qpc-hafs">﴿ولا أقول إني ملك﴾</span> نَزَلْتُ مِن السماء برسالة، ما أنا إلا بشر مثلكم{2}<span class=comment-ref>٣٢٠٥</span>. (٨/٣٧)</p></p><p></div></p><p><div><span class=comment-ref>٣٢٠٥</span> لم يذكر <u>ابنُ جرير</u> (١٢/٣٨٧) غير قول ابن جريج.</div></p><p><h3><span class="qpc-hafs">﴿وَلَاۤ أَقُولُ لِلَّذِینَ تَزۡدَرِیۤ أَعۡیُنُكُمۡ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٥٣٩٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ولا أقول للذين تزدري أعينكم﴾</span>، يعني: السَّفِلَة{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٣٩٤<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق أصبغ بن الفرج- <span class="qpc-hafs">﴿ولا أقول للذين تزدري أعينكم﴾</span>، قال: حَقَّرتُموهم{4}. (٨/٣٧)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿لَن یُؤۡتِیَهُمُ ٱللَّهُ خَیۡرًاۖ ٱللَّهُ أَعۡلَمُ بِمَا فِیۤ أَنفُسِهِمۡ إِنِّیۤ إِذࣰا لَّمِنَ ٱلظَّـٰلِمِینَ ۝٣١﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٥٣٩٥<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span>، في قوله: <span class="qpc-hafs">﴿لن يؤتيَهُمُ الله خيرًا﴾</span>، قال: يعني: إيمانًا{5}. (٨/٣٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٣٩٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿لن يؤتيَهُمُ الله خيرًا﴾</span> يعني: إيمانًا، وإن كانوا عندكم سَفِلَة، <span class="qpc-hafs">﴿اللَّهُ أعْلَمُ بِما فِي أنْفُسِهِمْ﴾</span> يعني: بما في قلوبهم، يعني: السَّفِلَة، من الإيمان. قال نوح: <span class="qpc-hafs">﴿إنِّي إذًا لَمِنَ الظّالِمِينَ﴾</span> إن لم أقبل منهم الإيمان{6}<span class=comment-ref>٣٢٠٦</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٣٢٠٦</span> قال <u>ابنُ عطية</u> (٤/٥٦٧): «وقوله: <span class="qpc-hafs">﴿اللَّهُ أعْلَمُ بِما فِي أنْفُسِهِمْ﴾</span> تسليم لله تعالى، أي: لست أحكم عليهم بشيء من هذا، وإنما يحكم عليهم بذلك ويَخْرُج حكمه إلى حَيِّز الوجود اللهُ تعالى الذي يعلم ما في نفوسهم ويجازيهم بذلك. وقد قال بعض المتأولين: هي ردٌّ على قولهم: اتبعك أراذلنا على ما يظهر منهم. حسبما تقدم في بعض تأويلات تلك الآية آنفًا، فالمعنى: لست أنا أحكم عليهم بأن لا يكون لهم خيرٌ لظنكم بهم أنّ بواطنهم ليست كظواهرهم، الله أعلم بما في نفوسهم».</div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٢/٢٧٩.|2:أخرجه ابن جرير ١٢/٣٨٧. وعزاه السيوطي إلى أبي الشيخ.|3:تفسير مقاتل بن سليمان ٢/٢٧٩.|4:أخرجه ابن أبي حاتم ٦/٢٠٢٣.|5:عزاه السيوطي إلى أبي الشيخ.|6:تفسير مقاتل بن سليمان ٢/٢٧٩-٢٨٠.
  11,32,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿قَالُوا۟ یَـٰنُوحُ قَدۡ جَـٰدَلۡتَنَا فَأَكۡثَرۡتَ جِدَ ٰ⁠لَنَا﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٥٣٩٧<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن جريج- في قوله: <span class="qpc-hafs">﴿قالوا يا نوح قد جادلتنا﴾</span>، قال: مارَيْتَنا{1}. (٨/٣٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٣٩٨<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿قالوا يا نوح قد جادلتنا﴾</span> يعني: مارَيْتَنا، <span class="qpc-hafs">﴿فأكثرت جدالنا﴾</span> يعني: مِراءَنا{2}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿فَأۡتِنَا بِمَا تَعِدُنَاۤ إِن كُنتَ مِنَ ٱلصَّـٰدِقِینَ ۝٣٢﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٥٣٩٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فأتنا بما تعدنا﴾</span> مِن العذاب، <span class="qpc-hafs">﴿إنْ كُنْتَ مِنَ الصّادِقِينَ﴾</span> بأنّ العذاب نازل بنا؛ لقوله في هذه الآية الأولى: <span class="qpc-hafs">﴿إني أخاف عليكم عذاب يوم أليم﴾</span>، وذلك أنّ الله أمر نوحًا أن يُنذرهم العذاب في سورة نوح، فكذَّبوه، فقالوا: <span class="qpc-hafs">﴿فَأْتِنا بِما تَعِدُنا إنْ كُنْتَ مِنَ الصّادِقِينَ﴾</span> بأنّ العذاب نازِل بنا{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٤٠٠<span class="dash">-</span></span> عن <span class="name-3">عبد الملك ابن جُرَيْج</span> -من طريق حجاج- في قوله: <span class="qpc-hafs">﴿فأتنا بما تعدنا﴾</span>، قال: تكذيبًا بالعذاب، وأنّه باطل{4}. (٨/٣٨)</p></p><p></div></p></div>",footnotes:1:تفسير مجاهد ص٣٨٧، وأخرجه ابن جرير ١٢/٣٨٨، وابن أبي حاتم ٦/٢٠٢٤. وعزاه السيوطي إلى ابن المنذر، وأبي الشيخ.|2:تفسير مقاتل بن سليمان ٢/٢٨٠.|3:تفسير مقاتل بن سليمان ٢/٢٨٠.|4:أخرجه ابن جرير ١٢/٣٨٨. وعزاه السيوطي إلى أبي الشيخ.
  11,33,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿قَالَ إِنَّمَا یَأۡتِیكُم بِهِ ٱللَّهُ إِن شَاۤءَ وَمَاۤ أَنتُم بِمُعۡجِزِینَ ۝٣٣﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٥٤٠١<span class="dash">-</span></span> قال <span class="name-1">عبد الله بن عباس</span> -من طريق الضحاك- <span class="qpc-hafs">﴿بِمُعْجِزِينَ﴾</span>: بمُسابِقين{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٤٠٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: فرَدَّ عليهم نوح، قال: <span class="qpc-hafs">﴿إنما يأتيكم به الله إن شاء﴾</span> وليس ذلك بيدي، <span class="qpc-hafs">﴿وما أنتم بمعجزين﴾</span> يعني: بسابقي اللهِ بأعمالكم الخبيثةِ حتى يجزيكم بها{2}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن أبي حاتم ٦/٢٠٢٤.|2:تفسير مقاتل بن سليمان ٢/٢٨٠.
  11,34,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَلَا یَنفَعُكُمۡ نُصۡحِیۤ إِنۡ أَرَدتُّ أَنۡ أَنصَحَ لَكُمۡ إِن كَانَ ٱللَّهُ یُرِیدُ أَن یُغۡوِیَكُمۡۚ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٥٤٠٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ولا يَنْفَعُكُمْ نُصْحِي﴾</span> فيما أُحَذِّرُكم مِن العذاب <span class="qpc-hafs">﴿إنْ أرَدْتُ أنْ أنْصَحَ لَكُمْ إنْ كانَ اللَّهُ يُرِيدُ أنْ يُغْوِيَكُمْ﴾</span> يعني: يُضِلَّكم عن الهدى، فـ<span class="qpc-hafs">﴿هو ربكم﴾</span>{1}<span class=comment-ref>٣٢٠٧</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٣٢٠٧</span> <span class="comment-type-4">قال</span> <u>ابنُ عطية</u> (٤/٥٦٨-٥٦٩بتصرف): «وقالت فرقة: معنى قوله: <span class="qpc-hafs">﴿يُغْوِيَكُمْ﴾</span>: يضلكم، مِن قولهم: غوى الرجل يغوى ... وإذا كان هذا معنى اللفظة ففي الآية حُجَّة على المعتزلة القائلين: إنّ الضلال إنّما هو من العبد». ثم قال: «وقالت فرقة: معنى قوله: <span class="qpc-hafs">﴿يُغْوِيَكُمْ﴾</span>: يهلككم، والغوى: المرض والهلاك، وفي لغة طيّء: أصبح فلان غاويًا، أي: مريضًا، والغوى: بَشَمُ الفصيل. قاله يعقوب في الإصلاح. وقيل: فقْده اللبن حتى يموت جوعًا. قاله الفرّاء، وحكاه الطبري. يقال: غوى يغوى، وحكى الزَّهراوي: أنه الذي قُطِع عنه اللبن حتى كاد يهلك ولَمّا يهلك بعدُ. فإذا كان هذا معنى اللفظة زال موضع النظر بين أهل السنة والمعتزلة، وبقي الاحتجاج عليهم بما هو أبين من هذه الآية، كقوله تعالى: <span class="qpc-hafs">﴿فَمَن يُرِدِ اللَّهُ أنْ يَهْدِيَهُ يَشْرَحْ صَدْرَهُ لِلْإسْلامِ﴾</span> [الأنعام:١٢٥] ونحوها. وأعتقد مكيٌّ أنّ للمعتزلة تَعَلُّقًا وحُجَّة بالغة بهذا التأويل، فردَّ عليه وأفرط حتى أنكر أن يكون الغوى بمعنى الهلاك موجودًا في لسان العرب».</div></p><p><h3><span class="qpc-hafs">﴿هُوَ رَبُّكُمۡ وَإِلَیۡهِ تُرۡجَعُونَ ۝٣٤﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٥٤٠٤<span class="dash">-</span></span> عن <span class="name-2">أبي العالية الرياحي</span> -من طريق الربيع- <span class="qpc-hafs">﴿وإليه ترجعون﴾</span>، قال: إليه يرجعون بعد الحياة{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٤٠٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>:<span class="qpc-hafs">﴿هو ربكم﴾</span> ليس له شريك، <span class="qpc-hafs">﴿وإليه ترجعون﴾</span> بعد الموت، فيجزيكم بأعمالكم{1}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٢/٢٨٠.|2:أخرجه ابن أبي حاتم ٦/٢٠٢٤.|3:تفسير مقاتل بن سليمان ٢/٢٨٠.
  11,35,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿أَمۡ یَقُولُونَ ٱفۡتَرَىٰهُۖ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٥٤٠٦<span class="dash">-</span></span> قال <span class="name-1">عبد الله بن عباس</span>: يعني: نوحًا ﵇{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٤٠٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثم ذكر الله تعالى كُفّار أُمَّةِ محمد ﷺ مِن أهل مكة، فقال: <span class="qpc-hafs">﴿أمْ يَقُولُونَ افْتَراهُ﴾</span>. نظيرها في حم الزخرف: <span class="qpc-hafs">﴿أمْ أنا خَيْرٌ﴾</span> يعني: بل أنا خير <span class="qpc-hafs">﴿مِن هَذا الَّذِي هُوَ مَهِينٌ﴾</span> [الزخرف:٥٢]. <span class="qpc-hafs">﴿افْتَراهُ﴾</span>، قالوا: محمد يقول هذا القرآن مِن تلقاء نفسه، وليس من الله{2}<span class=comment-ref>٣٢٠٨</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٣٢٠٨</span> <span class="comment-type-4">قال</span> <u>ابنُ عطية</u> (٤/٥٦٩): «وقوله تعالى: <span class="qpc-hafs">﴿أمْ يَقُولُونَ افْتَراهُ﴾</span> الآية، قال الطبريُّ وغيرُه من المتأولين والمؤلفين في التفسير: إنّ هذه الآية اعترضت في قصة نوح ﵇، وهي شأن محمد ﷺ مع كفار قريش، وذلك أنهم قالوا: افترى القرآن، وافترى هذه القصة على نوح. فنَزلت الآية في ذلك. وهذا لو صَحَّ بسند وجب الوقوف عنده، وإلا فهو يحتمل أن يكون في شأن نوح ﵇، ويبقى اتِّساق الآيةِ مُطَّرِدًا، ويكون الضمير في قوله: <span class="qpc-hafs">﴿افْتَراهُ﴾</span> عائدًا إلى العذاب الذي تَوَعَّدهم به، أو على جميع أخباره، وأوقع الافتراء على العذاب من حيث يقع على الإخبار به. والمعنى: أم يقول هؤلاء الكفرة: افترى نوحٌ هذا التَّوَعُّد بالعذاب، وأراد الإرهاب علينا بذلك. ثُمَّ يَطَّرِدُ باقي الآية على هذا».</div></p><p><h3><span class="qpc-hafs">﴿قُلۡ إِنِ ٱفۡتَرَیۡتُهُۥ فَعَلَیَّ إِجۡرَامِی وَأَنَا۠ بَرِیۤءࣱ مِّمَّا تُجۡرِمُونَ ۝٣٥﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٥٤٠٨<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿فعليَّ إجرامي﴾</span> قال: عملي، <span class="qpc-hafs">﴿وأنا بريء مما تجرمون﴾</span> أي: مِمّا تعملون{3}. (٨/٣٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٤٠٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿قُلْ إنِ افْتَرَيْتُهُ﴾</span> يعني: تَقَوَّلْتُه مِن تِلقاء نفسي <span class="qpc-hafs">﴿فعليَّ إجرامي﴾</span> فعَلَيَّ خطيئتي بافترائي على الله، <span class="qpc-hafs">﴿وأَنا بَرِيءٌ مِمّا تُجْرِمُونَ﴾</span> يعني: بريء مِن خطاياكم، يعني: كفركم بالله ﷿{4}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير الثعلبي ٥/١٦٦، وتفسير البغوي ٤/١٧٣.|2:تفسير مقاتل بن سليمان ٢/٢٨٠-٢٨١.|3:أخرجه ابن أبي حاتم ٦/٢٠٢٤.|4:تفسير مقاتل بن سليمان ٢/٢٨١.
  11,36,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَأُوحِیَ إِلَىٰ نُوحٍ أَنَّهُۥ لَن یُؤۡمِنَ مِن قَوۡمِكَ إِلَّا مَن قَدۡ ءَامَنَ فَلَا تَبۡتَىِٕسۡ بِمَا كَانُوا۟ یَفۡعَلُونَ ۝٣٦﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٥٤١٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق الضحاك- قال: إنّ نوحًا ﵇ كان يُضرَب، ثم يُلَفُّ في لَبَدٍ{1}، فيُلقى في بيته، يَرَوْن أنّه قد مات، ثم يخرج فيدعوهم، حتى إذا أيِس مِن إيمان قومه جاءه رجلٌ ومعه ابنُه وهو يَتَوَكَّأ على عصا، فقال: يا بني، انظر هذا الشيخَ، لا يَغُرَّنَّك. قال: يا أبتِ، أمْكِنِّي مِن العصا. ثم أخذ العصا، ثم قال: ضَعْنِي في الأرض. فوضعه، فمشى إليه، فضربه، فشجَّه مُوضِحَةً{2} في رأسه، وسالت الدماء. قال نوح ﵇: ربِّ، قد ترى ما يفعل بي عبادُك، فإن يكن لك في عبادك حاجةً فاهدِهم، وإن يكن غير ذلك فصَبِّرني إلى أن تحكم، وأنت خير الحاكمين. فأوحى اللهُ إليه وآيَسَه مِن إيمان قومه، وأخبره أنّه لم يبق في أصلاب الرجال ولا في أرحام النساء مُؤْمِن، قال: يا نوح، إنّه لن يؤمن من قومك إلا من قد آمن، فلا تبتئس بما كانوا يفعلون. يعني: لا تحزن عليهم{3}. (٨/٣٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٤١١<span class="dash">-</span></span> عن <span class="name-2">الضَّحّاك بن مُزاحِم</span> -من طريق عبيد بن سليمان- يقول في قوله: <span class="qpc-hafs">﴿لن يؤمن من قومك إلا من قد آمن﴾</span>: فحينئذٍ دعا على قومه، لَمّا بَيَّن اللهُ له أنّه لن يؤمن مِن قومه إلا مَن قد آمَن{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٤١٢<span class="dash">-</span></span> عن <span class="name-2">الحسن [البصري]</span> -من طريق صالح المُرِّيّ- قال: إنّ نوحًا لم يَدْعُ على قومه حتى نزلت عليه الآية: <span class="qpc-hafs">﴿وأوحي إلى نوح أنه لن يؤمن من قومك إلا من قد آمن﴾</span>. فانقطع عند ذلك رجاؤُه منهم، فدعا عليهم{5}. (٨/٣٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٤١٣<span class="dash">-</span></span> عن <span class="name-2">محمد بن كعب القرظي</span> -من طريق أيوب- قال: لَمّا استنقذ الله مِن أصلاب الرجال وأرحام النساء كلَّ مؤمن ومؤمنةٍ قال: يا نوحُ، إنه لن يؤمن من قومك إلا من قد ءامن{6}. (٨/٣٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٤١٤<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿وأوحي إلى نوح أنه لن يؤمن من قومك إلا من قد ءامن﴾</span>: وذلك حين دعا عليهم نوح ﵇، قال: <span class="qpc-hafs">﴿ربِ لا تذر على الأرض من الكافرين ديارا﴾</span> [نوح:٢٦]{7}. (٨/٣٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٤١٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثُمَّ ذَكَر نوحًا، فقال: <span class="qpc-hafs">﴿وأوحي إلى نوح أنه لن يؤمن من قومك إلا من قد آمن﴾</span>، يعني: إلّا مَن صَدَّق بتوحيد الله{8}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿فَلَا تَبۡتَىِٕسۡ بِمَا كَانُوا۟ یَفۡعَلُونَ ۝٣٦﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٥٤١٦<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق العوفي- في قوله: <span class="qpc-hafs">﴿فلا تبتئس﴾</span>، قال: فلا تَحْزَن{9}. (٨/٤٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٤١٧<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- <span class="qpc-hafs">﴿فلا تبتئس﴾</span>، قال: لا تحزن{10}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٤١٨<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- قوله: <span class="qpc-hafs">﴿فلا تبتئس﴾</span>، يقول: فلا تَأْسَ، ولا تَحْزَن{11}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٤١٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فلا تبتئس﴾</span> يعني: فلا تحزن <span class="qpc-hafs">﴿بما كانوا يفعلون﴾</span> يعني: بكفرهم بالله ﷿{8}. (ز)</p></p><p></div></p></div>",footnotes:1:كل شَعر أو صوف مُلْتَبدٍ بعضه على بعض فهو لِبْد، واللِّبْدُ من البُسُط: معروف. لسان العرب (لبد).|2:المُوضِحَةُ: هي التي تُبدي وضَحَ العظم، أي: بياضه. النهاية (وضح).|3:أخرجه ابن عساكر ٦٢/٢٤٧-٢٤٨. وعزاه السيوطي إلى إسحاق بن بشر.|4:أخرجه ابن جرير ١٢/٣٩١.|5:أخرجه أحمد في الزهد ص١٥. وعزاه السيوطي إلى ابن المنذر، وأبي الشيخ.|6:أخرجه ابن أبي حاتم ٦/٢٠٢٤. وعزاه السيوطي إلى أبي الشيخ.|7:أخرجه ابن جرير ١٢/٣٩١، وابن أبي حاتم ٦/٢٠٢٤. وذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٢/٢٨٧-. وعزاه السيوطي إلى أبي الشيخ.|8:تفسير مقاتل بن سليمان ٢/٢٨١.|9:أخرجه ابن جرير ١٢/٣٩١، وابن أبي حاتم ٦/٢٠٢٥.|10:تفسير مجاهد ص٣٨٧، وأخرجه ابن جرير ١٢/٣٩٠، وابن أبي حاتم ٦/٢٠٢٥.|11:أخرجه ابن جرير ١٢/٣٩١، كما أخرج عبد الرزاق ١/٣٠٤ نحوه من طريق معمر.|12:تفسير مقاتل بن سليمان ٢/٢٨١.
  11,37,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَٱصۡنَعِ ٱلۡفُلۡكَ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٥٤٢٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق الضحّاك- <span class="qpc-hafs">﴿واصنع الفلك﴾</span>، قال: يا ربِّ، وما الفُلْك؟ قال: بيتٌ مِن خشب، يجري على وجه الماء، فأُغرِقُ أهلَ معصيتي، وأُطَهِّر أرضي منهم. قال: يا ربِّ، وأين الماء؟ قال: إنِّي على ما أشاء قدير{1}. (٨/٣٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٤٢١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق العوفي- قال: لم يعلم نوحٌ ﵇ كيف يَصْنَع الفلك، فأوحى الله إليه أن يصنعها على مثل جُؤْجُؤِ{2} الطائِر{3}<span class=comment-ref>٣٢٠٩</span>. (٨/٤٠)</p></p><p></div></p><p><div><span class=comment-ref>٣٢٠٩</span> <span class="comment-type-4">ذكر</span> <u>ابنُ عطية</u> (٤/٥٧٣) في هيئة سفينة نوح قولًا أنّها كانت مربعة الشكل، طويلة في السماء، ضيقة الأعلى، وأنّ الغرض منها إنّما كان الحفظ، لا سرعة الجري، ثم قال: «والحديث الذي تَضَمَّن أنها كجؤجؤ الطائر أصَحُّ، ومعناه أظهر؛ لأنها لو كانت مربعة لم تكن فلكًا، بل كانت وعاء فقط، وقد وصفها الله تعالى بالجري في البحر، وفي الحديث: «كان راز سفينة نوح ﵇ جبريل ﵇». والراز: القيِّم بعمل السفن».</div></p><p><div></p><p><p><span class="item-no">٣٥٤٢٢<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿واصنع الفلك﴾</span>، قال: السفينة{4}. (٨/٤٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٤٢٣<span class="dash">-</span></span> عن <span class="name-2">أبي صالح باذام</span> -من طريق إسماعيل بن أبي خالد- في قوله: <span class="qpc-hafs">﴿الفلك﴾</span>، قال: سفينة نوح{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٤٢٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿واصْنَعِ الفُلْكَ﴾</span>، يعني: السفينة{6}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿بِأَعۡیُنِنَا وَوَحۡیِنَا﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٥٤٢٥<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطاء الخراساني- في قوله: <span class="qpc-hafs">﴿واصنع الفلك بأعيننا ووحينا﴾</span>، قال: بعين الله، ووحيه{7}. (٨/٤٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٤٢٦<span class="dash">-</span></span> قال <span class="name-1">عبد الله بن عباس</span>، في قوله: <span class="qpc-hafs">﴿واصنع الفلك بأعيننا﴾</span>: بمَرْأًى مِنّا{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٤٢٧<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿بأعيننا ووحينا﴾</span>، قال: كما نأمرك{9}<span class=comment-ref>٣٢١٠</span>. (٨/٤٠)</p></p><p></div></p><p><div><span class=comment-ref>٣٢١٠</span> <span class="comment-type-2">انتَقَدَ</span> <u>ابنُ عطية</u> (٤/٥٧٣) <span class="mustanad">مستندًا إلى السياق</span> ما جاء في قول مجاهد وغيره بقوله: «ومَن فسر قوله: <span class="qpc-hafs">﴿ووَحْيِنا﴾</span> أي: بأمرنا لك، فذلك ضعيف؛ لأن قوله: <span class="qpc-hafs">﴿واصْنَعِ الفُلْكَ﴾</span> مُغْنٍ عن ذلك».</div></p><p><div></p><p><p><span class="item-no">٣٥٤٢٨<span class="dash">-</span></span> قال <span class="name-2">الضحاك بن مزاحم</span>، في قوله: <span class="qpc-hafs">﴿واصنع الفلك بأعيننا﴾</span>: بمنظَرٍ مِنّا{10}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٤٢٩<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- في قوله: <span class="qpc-hafs">﴿بأعيننا ووحينا﴾</span>، قال: بعين الله، ووحيه{11}<span class=comment-ref>٣٢١١</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٣٢١١</span> لم يذكر <u>ابنُ جرير</u> (١٢/٣٩٢-٣٩٣) غير قول قتادة، ومجاهد.</div></p><p><div></p><p><p><span class="item-no">٣٥٤٣٠<span class="dash">-</span></span> عن <span class="name-2">عطاء الخراساني</span> -من طريق عثمان بن عطاء-: وأمّا قوله: <span class="qpc-hafs">﴿بأعيننا ووحينا﴾</span> فيُقال: بعين الله، ورحمته{12}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٤٣١<span class="dash">-</span></span> قال <span class="name-2">الربيع بن أنس</span>، في قوله: <span class="qpc-hafs">﴿واصنع الفلك بأعيننا﴾</span>: بِحِفْظِنا{10}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٤٣٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿بأعيننا﴾</span>، يعني: بعلمنا ووحينا كما نأمرك، فعمِلها نوحٌ في أربعمائة سنة، وكانت السفينة مِن ساجٍ{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٤٣٣<span class="dash">-</span></span> عن <span class="name-3">سفيان بن عُيَيْنة</span>، قال: ما وصف الله تبارك به نفسَه في كتابه فقِراءته تفسيرُه، ليس لأحد أن يُفَسِّره بالعربية ولا بالفارسية{15}<span class=comment-ref>٣٢١٢</span>. (٨/٤٠)</p></p><p></div></p><p><div><span class=comment-ref>٣٢١٢</span> <span class="comment-type-4">ذكر</span> <u>ابنُ عطية</u> (٤/٥٧٢) في قوله: <span class="qpc-hafs">﴿بأعيننا﴾</span> احتمالين، فقال: «وقوله: <span class="qpc-hafs">﴿بِأَعْيُنِنا﴾</span> يمكن -فيما يتأول- أن يريد به: بمرأًى منا وتحت إدراك، فتكون عبارة عن الإدراك والرعاية والحفظ، ويكون جمع الأعين للعظمة لا للتكثير، كما قال تعالى:<span class="qpc-hafs">﴿فَنِعْمَ القادِرُونَ﴾</span> [المرسلات:٢٣]، فرجع معنى الأعين في هذه وفي غيرها إلى معنى عين في قوله: <span class="qpc-hafs">﴿لِتُصْنَعَ عَلى عَيْنِي﴾</span> [طه:٣٩]، وذلك كله عبارة عن الإدراك وإحاطته بالمدركات، وهو تعالى مُنَزَّه عن الحواس والتشبيه والتكييف لا رب غيره. ويحتمل قوله: <span class="qpc-hafs">﴿بِأَعْيُنِنا﴾</span> أي: بملائكتنا الذين جعلناهم عيونًا على مواضع حفظك ومعونتك، فيكون الجمع على هذا للتكثير». انتهى كلامه، وما قاله من نفي صفة العينين لله تعالى باطل، والحق إثباتهما له سبحانه على ما يليق بجلاله وكماله وعظمته، وهو إجماع السلف من الصحابة والتابعين وتابعيهم، ينظر: الإبانة الكبرى ٣/١١٣-١٢٧، شرح أصول اعتقاد أهل السنة ٢/٤٥٧-٤٨١.</div></p><p><h3><span class="qpc-hafs">﴿وَلَا تُخَـٰطِبۡنِی فِی ٱلَّذِینَ ظَلَمُوۤا۟ إِنَّهُم مُّغۡرَقُونَ ۝٣٧﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٥٤٣٤<span class="dash">-</span></span> عن <span class="name-2">عُبَيد بن عُمير الليثي</span> -من طريق محمد بن إسحاق- أنّه كان يُحَدِّث، أنّه بَلَغَه: أنهم كانوا يبطشون به -يعني: قوم نوح-، فيخنقونه حتى يغشى عليه، فإذا أفاق قال: اللَّهُمَّ، اغفِر لقومي؛ فإنّهم لا يعلمون. حتى إذا تَمادَوْا في المعصية، وعَظمت في الأرض منهم الخطيئة، وتطاول عليه وعليهم الشأن، واشتد عليه منهم البلاء، وانتظر النَّجْلَ{16} بعد النَّجْلِ، فلا يأتي قرنٌ إلا كان أخبثَ مِن القرن الذي قبله، حتى إن كان الآخر منهم لَيقول: قد كان هذا مع آبائنا ومع أجدادنا هكذا مجنونًا. لا يَقْبَلون منه شيئًا، حتى شَكا ذلك مِن أمرهم نوحٌ إلى الله تعالى، كما قصَّ الله علينا في كتابه: <span class="qpc-hafs">﴿رب إني دعوت قومي ليلا ونهارا فلم يزدهم دعائي إلا فرارا﴾</span> [نوح:٥-٦] إلى آخر القصة، حتى قال: <span class="qpc-hafs">﴿رب لا تذر على الأرض من الكافرين ديارا إنك إن تذرهم يضلوا عبادك ولا يلدوا إلا فاجرا كفارا﴾</span> إلى آخر القصة، فلَمّا شكا ذلك منهم نوحٌ إلى الله واستنصره عليهم أوحى الله إليه أن: <span class="qpc-hafs">﴿واصنع الفلك بأعيننا ووحينا ولا تخاطبني في الذين ظلموا﴾</span> أي: بعد اليوم؛ <span class="qpc-hafs">﴿إنهم مغرقون﴾</span>. فأقبل نوحٌ على عَمَلِ الفُلَك، ولَهِيَ عن قومه، وجعل يقطع الخشب، ويضرب الحديد، ويُهَيِّءُ عِدَّة الفلك مِن القارِ وغيره مِمّا لا يصلحه إلا هو، وجعل قومُه يَمُرُّون به وهو في ذلك مِن عمله، فيسخرون منه، ويستهزئون به، فيقول: <span class="qpc-hafs">﴿إن تسخروا منا فإنا نسخر منكم كما تسخرون فسوف تعلمون من يأتيه عذاب يخزيه ويحل عليه عذاب مقيم﴾</span>. قال: ويقولون له فيما بلغني: يا نوحُ، قد صِرْتَ نَجّارًا بعد النُّبُوَّة؟! قال: وأَعْقَمَ اللهُ أرحامَ النساء، فلا يولد لهم ولد. قال: ويزعمُ أهل التوراة: أنّ الله أمره أن يصنع الفلك مِن خشب السّاج، وأن يصنعه أزْوَرَ{17}، وأن يَطْلِيه بالقارِ مِن داخله وخارجه، وأن يجعل طوله ثمانين ذراعًا، وأن يجعله ثلاثة أطباق؛ سفلًا ووسطًا وعلوًا، وأن يجعل فيه كِوًى{18}. ففعل نوحٌ كما أمره الله، حتى إذا فرغ منه، وقد عهد الله إليه: إذا جاء أمرنا وفار التنور فاحمل فيها من كل زوجين اثنين، وأهلك إلا من سبق عليه القول، ومَن آمن، وما آمَن معه إلا قليل. وقد جعل التنور آيةً فيما بينه وبينه، فقال: <span class="qpc-hafs">﴿حتى إذا جاء أمرنا وفار التنور قلنا احمل فيها من كل زوجين اثنين﴾</span> [المؤمنون:٢٧]، واركب. فلمّا فار التَّنُّورُ حمل نوح في الفلك مَن أمره الله، وكانوا قليلًا كما قال الله، وحمل فيها مِن كل زوجين اثنين مِمّا فيه الروح والشجر، ذكر وأنثى، فحمل فيه بَنِيه الثلاثةَ -سام، وحام، ويافث- ونساءَهم، وسِتَّةَ أُناسٍ مِمَّن كان آمن به، فكانوا عشرة نفر؛ نوح وبنوه وأزواجهم، ثم أدخل ما أمره به من الدواب، وتخلف عنه ابنُه يام، وكان كافرًا{19}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٤٣٥<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في الآية، قال: نهى الله نوحًا ﵇ أن يُراجِعه بعد ذلك في أحَد{20}. (٨/٤٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٤٣٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ولا تخاطبني﴾</span> يقول: ولا تُراجِعْنِي <span class="qpc-hafs">﴿في الذين ظلموا﴾</span> يعني: الذين أشركوا، وهو ابنُه كنعان بن نوح، فإنّه من الذين ظلموا، <span class="qpc-hafs">﴿إنَّهُمْ مُغْرَقُونَ﴾</span> لقول نوح: <span class="qpc-hafs">﴿رَبِّ إنَّ ابْنِي مِن أهْلِي وإنَّ وعْدَكَ الحَقُّ وأَنْتَ أحْكَمُ الحاكِمِينَ﴾</span> [هود:٤٥]{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٤٣٧<span class="dash">-</span></span> عن <span class="name-3">عبد الملك ابن جُرَيْج</span> -من طريق حجّاج- في قوله: <span class="qpc-hafs">﴿ولا تخاطبني في الذين ظلموا﴾</span>، يقول: لا تُراجِعْنِي. تقدَّم إليه ألّا يَشْفَعَ لهم عندَه{22}. (٨/٤٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٤٣٨<span class="dash">-</span></span> عن <span class="name-3">محمد بن إسحاق</span> -من طريق سلمة-: فلَمّا شكا ذلك منهم نوحٌ إلى الله ﷿، واسْتَنصَر عليهم؛ أوحى الله إليه: <span class="qpc-hafs">﴿أن اصنع الفلك بأعيننا ووحينا ولا تخاطبني في الذين ظلموا﴾</span> أي: بعد اليوم، <span class="qpc-hafs">﴿إنهم مغرقون﴾</span>{12}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن عساكر ٦٢/٢٤٧-٢٤٨. وعزاه السيوطي إلى إسحاق بن بشر.|2:جؤْجؤُ الطير: صدره. وقيل: عِظامه. النهاية (جؤجؤ).|3:أخرجه ابن جرير ١٢/٣٩٢، وابن أبي حاتم ٦/٢٠٢٥.|4:أخرجه ابن جرير ١٢/٣٩٢، وابن أبي حاتم ٦/٢٠٢٦. وعزاه السيوطي إلى أبي الشيخ.|5:أخرجه ابن أبي حاتم ٦/٢٠٢٥.|6:تفسير مقاتل بن سليمان ٢/٢٨١.|7:أخرجه ابن جرير ١٢/٣٩٢، وابن أبي حاتم ٦/٢٠٢٦، والبيهقي في الأسماء والصفات (٦٨٢) نحوه. وعزاه السيوطي إلى أبي الشيخ.|8:تفسير البغوي ٤/١٧٣.|9:تفسير مجاهد ص٣٨٧، وأخرجه ابن جرير ١٢/٣٩٢، وابن أبي حاتم ٦/٢٠٢٦. وعزاه السيوطي إلى أبي الشيخ.|10:تفسير الثعلبي ٥/١٦٦.|11:أخرجه عبد الرزاق ١/٣٠٤، وابن جرير ١٢/٣٦٨.|12:أخرجه ابن أبي حاتم ٦/٢٠٢٦.|13:تفسير الثعلبي ٥/١٦٦.|14:تفسير مقاتل بن سليمان ٢/٢٨١.|15:أخرجه البيهقي (٦٨٣).|16:النَّجْل: النَّسْل. لسان العرب (نجل).|17:الأَزْوَرُ: المائِلُ. تاج العروس (زور).|18:الكِوى: جمع كوَّةُ: وهي الخَرْق في الحائط، والثَّقْب في البيت ونحوه. لسان العرب (كوي).|19:أخرجه ابن جرير ١٢/٣٩٦، وابن أبي حاتم ٦/٢٠٢٢ مختصرًا.|20:أخرجه ابن أبي حاتم ٦/٢٠٢٦. وعزاه السيوطي إلى أبي الشيخ.|21:تفسير مقاتل بن سليمان ٢/٢٨١.|22:أخرجه ابن جرير ٦/٣٩٣. وعزاه السيوطي إلى أبي الشيخ.|23:أخرجه ابن أبي حاتم ٦/٢٠٢٦.