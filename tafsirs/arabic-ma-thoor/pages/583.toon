quran[25]{c,v,t}:
78,31," <q>﴿إِنَّ لِلۡمُتَّقِینَ مَفَازًا ۝٣١﴾</q> - تفسير ٨٠٩٩٧- عن عبد الله بن عباس -من طريق علي- في قوله: <q>﴿إنَّ لِلْمُتَّقِينَ مَفازًا﴾</q>، قال: مُتنَزَّهًا{1}. (١٥/٢٠٧) ٨٠٩٩٨- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿إنَّ لِلْمُتَّقِينَ مَفازًا﴾</q>، قال: فازوا بأن نَجَوْا مِن النار{2}٦٩٩٢. (١٥/٢٠٧) ٦٩٩٢ ذكر ابنُ كثير (١٤/٢٣٤) قول مجاهد، وقول ابن عباس قبله، ورجّح قول ابن عباس بالسياق، فقال: «الأظهر هاهنا قول ابن عباس؛ لأنه قال بعده: <q>﴿حدائق﴾</q> وهي البساتين من النخيل وغيرها، <q>﴿وأعنابا وكواعب أترابا﴾</q> أي: وحورًا كواعب». ٨٠٩٩٩- قال الضَّحّاك بن مُزاحِم: <q>﴿إنَّ لِلْمُتَّقِينَ مَفازًا﴾</q> مُتَنَزَّهًا{3}. (ز) ٨١٠٠٠- عن قتادة بن دعامة -من طريق معمر- في قوله: <q>﴿إنَّ لِلْمُتَّقِينَ مَفازًا﴾</q>، قال: مَفازًا مِن النار إلى الجنة{4}. (١٥/٢٠٧) ٨١٠٠١- قال مقاتل بن سليمان: ثم ذكر المؤمنين، فقال: <q>﴿إنَّ لِلْمُتَّقِينَ مَفازًا﴾</q>، يعني: النجاة من ذلك العذاب الذي سَمّاه للطاغين{5}. (ز) ",footnotes:1:أخرجه ابن جرير ٢٤/٣٧، وابن أبي حاتم -كما في تغليق التعليق ٣/٥٠١-، والبيهقي في البعث (٣٥٧، ٣٧٧). وعزاه السيوطي إلى ابن المنذر.تفسير مجاهد ص٦٩٦، وأخرجه ابن جرير ٢٤/٣٧. وعزاه السيوطي إلى عَبد بن حُمَيد، وابن المنذر.تفسير الثعلبي ١٠/١١٨، وتفسير البغوي ٨/٣١٦.أخرجه عبد الرزاق ٢/٣٤٣، وابن جرير ٢٤/٣٧، وبنحوه من طريق سعيد. وعزاه السيوطي إلى عَبد بن حُمَيد، وابن المنذر.تفسير مقاتل بن سليمان ٤/٥٦٤.
78,32," <q>﴿حَدَاۤىِٕقَ وَأَعۡنَـٰبࣰا ۝٣٢﴾</q> - تفسير ٨١٠٠٢- عن عبد الله بن عباس، أنّ نافع بن الأزرق قال له: أخبِرني عن قوله: <q>﴿حَدائِقَ وأَعْنابًا﴾</q>. قال: الحدائق: البساتين. قال: وهل تعرف العرب ذلك؟ قال: نعم، أما سمعتَ الشاعر يقول: بلادٌ سقاها الله أمّا سُهولُها فَقَضْبٌ ودُرٌّ مُغدِقٌ وحدائقُ؟{1}. (١٥/٢٠٧) ٨١٠٠٣- قال مقاتل بن سليمان: قال: <q>﴿حَدائِقَ﴾</q> يعني: البساتين قد حَدّقتْ حواليها الحيطان، <q>﴿وأَعْنابًا﴾</q> يعني: الفواكه{2}. (ز) ",footnotes:1:أخرجه الطستي -كما في الإتقان ٢/٨٥-.تفسير مقاتل بن سليمان ٤/٥٦٤.
78,33," <q>﴿وَكَوَاعِبَ أَتۡرَابࣰا ۝٣٣﴾</q> - تفسير ٨١٠٠٤- عن عبد الله بن عباس -من طريق علي- في قوله: <q>﴿وكَواعِبَ﴾</q> قال: نواهد، <q>﴿أتْرابًا﴾</q> قال: مستويات{1}. (١٥/٢٠٧) ٨١٠٠٥- عن عبد الله بن عباس -من طريق عكرمة- في قوله: <q>﴿كواعب﴾</q>، قال: الذي يُجافي ثدياها قميصها{2}. (ز) ٨١٠٠٦- عن القاسم بن مُخِيمِرَة -من طريق زيد بن واقد- في قول الله: <q>﴿وكَواعِبَ أتْرابًا﴾</q>، قال: الأتْراب: المُسْتويات{3}. (ز) ٨١٠٠٧- عن مجاهد بن جبر -من طريق ابن جُرَيْج- في قوله: <q>﴿وكَواعِبَ﴾</q> قال: نواهد، <q>﴿أتْرابًا﴾</q> لِدات{4}. (١٥/٢٠٨) ٨١٠٠٨- عن الضَّحّاك بن مُزاحِم، في قوله: <q>﴿وكَواعِبَ﴾</q>، قال: العذارى{5}. (١٥/٢٠٨) ٨١٠٠٩- عن قتادة بن دعامة -من طريق معمر- في قوله تعالى: <q>﴿كَواعِبَ﴾</q> قال: نواهد، <q>﴿أتْرابًا﴾</q> يقول: سِنًّا واحدًا{6}. (ز) ٨١٠١٠- قال مقاتل بن سليمان: <q>﴿وكَواعِبَ﴾</q> يعني: النساء الكاعبة، يعني: عذارى يَسكُنَّ في الجنة للرجال، وقُسموا لهنّ، <q>﴿أتْرابًا﴾</q> يعني: مستويات على ميلاد واحد؛ بنات ثلاث وثلاثين سنة، وذلك أنّ أهل الجنة إذا دَخلوا الجنة قام [مَلَك] على قصر مِن ياقوت شُرفه كاللؤلؤ المكنون، فينادي بصوت رفيع يُسمع أهل الجنة؛ أولهم وآخرهم، وأسفلهم وأعلاهم، فيقول: أين الذين كانوا نَزّهوا أسماعهم عن قَيْنات{7} الدنيا ومعازفها. قال: ويأمر الله ﷿ جواري، فيَرفعنَ أصواتهنّ جميعًا{8}. (ز) ٨١٠١١- عن عبد الملك ابن جُرَيْج -من طريق حجّاج- قال: الكواعب: النَّواهد{9}. (ز) ٨١٠١٢- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿وكَواعِبَ أتْرابًا﴾</q>، قال: الكواعب: التي قد نَهَدت، وكعَب ثديها. وقال: <q>﴿أترابًا﴾</q> مستويات، فلانة تِرْبة فلانة. قال: الأتراب: اللِّدات{9}٦٩٩٣. (ز) ٦٩٩٣ لم يذكر ابنُ جرير (٢٤/٣٨-٣٩) غير قول عبد الرحمن بن زيد، وابن جُرَيْج، وقتادة، ومجاهد، وابن عباس. ٨١٠١٣- عن وكيع، قال: سمعنا في <q>﴿كواعب﴾</q>، قال: نَواهد{11}. (ز) ",footnotes:1:أخرجه ابن جرير ٢٤/٣٨، وبنحوه من طريق عطية، وابن أبي حاتم -كما في تغليق التعليق ٣/٥٠١-، والبيهقي في البعث (٣٥٧، ٣٧٧). وعزاه السيوطي إلى ابن المنذر.أخرجه الخرائطي في اعتلال القلوب ص١٦١ (٣٢٩).أخرجه عبد الله بن وهب في الجامع -تفسير القرآن ١/١١٠ (٢٤٩).أخرجه ابن جرير ٢٤/٣٩، وابن أبي شيبة ٢/١٨٢ في شطره الأول.عزاه السيوطي إلى ابن المنذر.أخرجه عبد الرزاق ٢/٣٤٣، وابن جرير ٢٤/٣٨-٣٩، وبنحوه من طريق سعيد.قينات: جمع قَيْنة، وهي الأمة غنَّت أو لم تغن، وكثيرًا ما تطلق على المغنية من الإماء، وهو المراد هنا. النهاية (قين).تفسير مقاتل بن سليمان ٤/٥٦٤-٥٦٥.أخرجه ابن جرير ٢٤/٣٩.أخرجه ابن جرير ٢٤/٣٩.أخرجه هناد في الزهد ١/٦٠.
78,34," <q>﴿وَكَأۡسࣰا دِهَاقࣰا ۝٣٤﴾</q> - تفسير ٨١٠١٤- عن أبي هريرة -من طريق أبي رافع- <q>﴿وكَأْسًا دِهاقًا﴾</q>، قال: دمادُم{1}. (١٥/٢٠٩) ٨١٠١٥- عن عبد الله بن عباس، قال: إذا كان فيها خمر فهي كأس، وإذا لم يكن فيها خمر فليس بكأس{2}. (١٥/٢١٠) ٨١٠١٦- عن عبد الله بن عباس، أنّ نافع بن الأزرق قال له: أخبِرني عن قوله: <q>﴿وكَأْسًا دِهاقًا﴾</q>. قال: الكأس: الخمر. والدِّهاق: المَلآن. قال: وهل تعرف العرب ذلك؟ قال: نعم، أما سمعتَ الشاعر وهو يقول: أتانا عامر يرجو قِرانًا فأتْرَعْنا له كأسًا دهاقا؟{3}. (١٥/٢٠٧) ٨١٠١٧- عن عبد الله بن عباس -من طريق علي- قوله: <q>﴿وكَأْسًا دِهاقًا﴾</q>، يقول: مُمتلئًا{4}. (١٥/٢٠٧) ٨١٠١٨- عن عبد الله بن عباس –من طريق مسلم بن نِسْطاس- في قوله: <q>﴿وكَأْسًا دِهاقًا﴾</q>، قال: هي المُمتلئة المُترَعة المُتتابعة، وربما سمعتُ العباسَ يقول: يا غلام، اسقِنا، وادْهَق لنا{5}. (١٥/٢٠٨) ٨١٠١٩- عن عبد الله بن عباس -من طريق عمرو بن دينار- أنه سُئل عن قوله: <q>﴿وكَأْسًا دِهاقًا﴾</q>. قال: دِراكًا{6}. (١٥/٢٠٨) ٨١٠٢٠- عن عبد الله بن عباس -من طريق أبي صالح- <q>﴿وكَأْسًا دِهاقًا﴾</q>، قال: مَلأى{7}. (١٥/٢٠٨) ٨١٠٢١- عن سعيد بن جُبَير= (ز) ٨١٠٢٢- ومجاهد بن جبر -من طريق منصور-= (ز) ٨١٠٢٣- والضَّحّاك بن مُزاحِم= (ز) ٨١٠٢٤- والحسن البصري -من طريق أبي رجاء-= (ز) ٨١٠٢٥- وقتادة بن دعامة -من طريق معمر-، مثله{8}. (١٥/٢٠٩) ٨١٠٢٦- عن مجاهد بن جبر -من طريق ابن أبي نجيح- <q>﴿وكَأْسًا دِهاقًا﴾</q>، قال: المُتتابعة{9}. (١٥/٢٠٩) ٨١٠٢٧- عن سعيد بن جُبَير -من طريق معمر-= (ز) ٨١٠٢٨- والضَّحّاك بن مُزاحِم، مثله{10}. (١٥/٢٠٩) ٨١٠٢٩- عن مجاهد بن جبر -من طريق جابر- <q>﴿وكَأْسًا﴾</q>، قال: الكأْس: كلّ شيء يُشرب فيه الخمر{11}. (ز) ٨١٠٣٠- عن عكرمة مولى ابن عباس، <q>﴿وكَأْسًا دِهاقًا﴾</q>، قال: يَتبع بعضها بعضًا{2}. (١٥/٢٠٩) ٨١٠٣١- عن عكرمة مولى ابن عباس -من طريق حُصَين- في قوله: <q>﴿وكأسا دهاقا﴾</q>، قال: المملوءة: المُتتابعة{13}. (ز) ٨١٠٣٢- عن عكرمة مولى ابن عباس -من طريق عمر بن عطاء- في قوله: <q>﴿وكَأْسًا دِهاقًا﴾</q>، قال: صافية{14}. (١٥/٢١٠) ٨١٠٣٣- عن عطية العَوفيّ -من طريق مُطَرِّف- في قوله: <q>﴿وكَأْسًا دِهاقًا﴾</q>، قال: مَلأى: مُتتابعة{15}. (١٥/٢٠٩) ٨١٠٣٤- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿وكَأْسًا دِهاقًا﴾</q>، قال: مُترَعة: ملأى{14}. (ز) ٨١٠٣٥- قال مقاتل بن سليمان: ثم قال: <q>﴿وكَأْسًا دِهاقًا﴾</q>، يعني: وشرابًا كثيرًا{17}. (ز) ٨١٠٣٦- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿كَأْسًا دِهاقًا﴾</q>، قال: الدِّهاق: المملوءة{14}٦٩٩٤. (ز) ٦٩٩٤ في قوله: <q>﴿دهاقا﴾</q> ثلاثة أقوال: الأول: ملأى. الثاني: مُتتابعة. الثالث: صافية. وقد جمع ابنُ جرير (٢٤/٣٩-٤٢) -مستندًا إلى اللغة، وأقوال السلف- بين القول الأول والثاني، فقال: «وقوله: <q>﴿وكأسا دهاقا﴾</q> يقول: وكأسًا ملأى مُتتابعة على شاربيها بكثرة وامتلاء، وأصله من الدّهق: وهو مُتابعة الضغط على الإنسان بشدّة وعنف. وكذلك الكأس الدِّهاق: مُتابعتها على شاربيها بكثرة وامتلاء. وبنحو الذي قلنا في ذلك قال أهل التأويل». وذكر آثار السلف على ذلك، ثم ذكر قول مَن قال: إنّ معناه: متتابعة. وقول مَن قال: إنّ معناه: صافية. ولم يعلّق عليهما. ",footnotes:1:أخرجه ابن جرير ٢٤/٤٠، وابن أبي الدنيا في كتاب صفة الجنة -موسوعة الإمام ابن أبي الدنيا ٦/٣٤٧ (١٣٦)-. وعزاه السيوطي إلى عَبد بن حُمَيد، ونقل عنه أنّ دمادُم: فارسي بمعنى متتابعة.عزاه السيوطي إلى عَبد بن حُمَيد.مسائل نافع (٤٥).أخرجه ابن جرير ٢٤/٤٠، وابن أبي حاتم -كما في تغليق التعليق ٣/٥٠١-، والبيهقي في البعث (٣٥٧، ٣٧٧). وعزاه السيوطي إلى ابن المنذر.أخرجه عَبد بن حُمَيد -كما في تغليق التعليق ٣/٥٠١-، وابن جرير ٢٤/٣٩-٤٠، والحاكم ٢/٥١٢، والبيهقي في البعث (٣٥٨). وقول العباس عند البخاري (٣٨٤٠). وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم، وابن مردويه.أخرجه ابن جرير ٢٤/٤٠. وعزاه السيوطي إلى عَبد بن حُمَيد، وابن المنذر.أخرجه ابن جرير ٢٤/٤٠، ٤٢، ومن طريق عكرمة أيضًا بنحوه. وعزاه السيوطي إلى عَبد بن حُمَيد.عزاه السيوطي إلى عَبد بن حُمَيد. وأخرجه عبد الرزاق ٢/٣٤٣ عن قتادة، وابن جرير ٢٤/٤٠-٤١ عن مجاهد، والحسن، وقتادة.تفسير مجاهد ص٦٩٦، وأخرجه ابن جرير ٢٤/٤٢، كذلك من طريق منصور أيضًا. وعزاه السيوطي إلى عَبد بن حُمَيد.عزاه السيوطي إلى عَبد بن حُمَيد. وأخرج قول سعيد عبد الرزاق ٢/٣٤٣، وابن جرير ٢٤/٤٢.تفسير مجاهد ص٤٧٩.عزاه السيوطي إلى عَبد بن حُمَيد.أخرجه سعيد بن منصور في سننه -التفسير ٨/٢٤٩-٢٥٠ (٢٣٨٥).أخرجه ابن جرير ٢٤/٤١.أخرجه هناد (٧١).أخرجه ابن جرير ٢٤/٤١.تفسير مقاتل بن سليمان ٤/٥٦٥.أخرجه ابن جرير ٢٤/٤١.
78,35," <q>﴿لَّا یَسۡمَعُونَ فِیهَا لَغۡوࣰا وَلَا كِذَّ ٰ⁠بࣰا ۝٣٥﴾</q> - تفسير ٨١٠٣٧- عن الحسن البصري: <q>﴿ولا كِذّابًا﴾</q>، يقول: لا يُكذِّب بعضهم بعضًا{1}. (ز) ٨١٠٣٨- عن قتادة بن دعامة -من طريق معمر- قوله: <q>﴿لا يَسْمَعُونَ فِيها لَغْوًا ولا كِذّابًا﴾</q>، قال: باطِلًا، ولا مأثمًا{2}. (١٥/٢١٠) ٨١٠٣٩- قال مقاتل بن سليمان: <q>﴿لا يَسْمَعُونَ فِيها﴾</q> إذا شربوا <q>﴿لَغْوًا﴾</q> يعني: حَلِف الباطل، <q>﴿ولا كِذّابًا﴾</q> يقول: ولا يَكذِبون على شرابهم كما يَكذِب أهل الدنيا إذا شربوا{3}. (ز) ٨١٠٤٠- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿لا يَسْمَعُونَ فِيها لَغْوًا ولا كِذّابًا﴾</q>، قال: وهي كذلك؛ ليس فيها لغو، ولا كِذّاب{4}٦٩٩٥. (ز) ٦٩٩٥ لم يذكر ابنُ جرير (٢٤/٤٣) غير قول عبد الرحمن، وقول قتادة. ",footnotes:1:ذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٥/٨٥-.أخرجه عبد الرزاق ٢/٣٤٣، وابن جرير ٢٤/٤٣. وعزاه السيوطي إلى عَبد بن حُمَيد، وابن المنذر.تفسير مقاتل بن سليمان ٤/٥٦٥.أخرجه ابن جرير ٢٤/٤٣.
78,36," <q>﴿جَزَاۤءࣰ مِّن رَّبِّكَ عَطَاۤءً حِسَابࣰا ۝٣٦﴾</q> - تفسير ٨١٠٤١- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿جَزاءً مِن رَبِّكَ عطاءً﴾</q> قال: عطاء منه، <q>﴿حِسابًا﴾</q> قال: لِما عملوا{1}. (١٥/٢١٠) ٨١٠٤٢- عن قتادة بن دعامة -من طريق معمر- قوله: <q>﴿عَطاءً حِسابًا﴾</q>، قال: كثيرًا{2}. (١٥/٢١٠) ٨١٠٤٣- عن قتادة بن دعامة -من طريق سعيد- <q>﴿جَزاءً مِن رَبِّكَ عَطاءً حِسابًا﴾</q>: أي: عطاء كثيرًا، فجَزاهم بالعمل اليسير الخير الجسيم الذي لا انقطاع له{3}. (ز) ٨١٠٤٤- قال مقاتل بن سليمان: ثم جمع أهلَ النار وأهلَ الجنة، فقال: <q>﴿جَزاءً﴾</q> يعني: ثوابًا <q>﴿مِن رَبِّكَ عَطاءً حِسابًا﴾</q> يعني: يُحاسِب المسيئين فيجازيهم بالنار، ويُحاسِب المؤمنين فيجازيهم بالجنة، فأَعطى هؤلاء وهؤلاء جزاءَهم، ولم يَظلم هؤلاء المُعذَّبين شيئًا، فذلك قوله: <q>﴿عَطاءً حِسابًا﴾</q>. نظيرها في الشعراء [١١٣]: <q>﴿إنْ حِسابُهُمْ إلّا عَلى رَبِّي﴾</q>، يقول: إن جزاؤهم إلا على ربي{4}. (ز) ٨١٠٤٥- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قول الله: <q>﴿جَزاءً مِن رَبِّكَ عَطاءً حِسابًا﴾</q>، فقرأ: <q>﴿إنَّ لِلْمُتَّقِينَ مَفازًا حَدائِقَ وأَعْنابًا وكَواعِبَ أتْرابًا﴾</q> إلى: <q>﴿عَطاءً حِسابًا﴾</q>، قال: فهذه جزاء بأعمالهم عطاء الذي أعطاهم، عَملوا له واحدة فجزاهم عشرًا. وقرأ قول الله: <q>﴿مَن جاءَ بِالحَسَنَةِ فَلَهُ عَشْرُ أمْثالِها﴾</q> [الأنعام:١٦٠]، وقرأ قول الله: <q>﴿مَثَلُ الَّذِينَ يُنْفِقُونَ أمْوالَهُمْ فِي سَبِيلِ اللَّهِ كَمَثَلِ حَبَّةٍ أنْبَتَتْ سَبْعَ سَنابِلَ فِي كُلِّ سُنْبُلَةٍ مِائَةُ حَبَّةٍ واللَّهُ يُضاعِفُ لِمَن يَشاءُ﴾</q> [البقرة:٢٦١]، قال: يزيد مَن يشاء، كان هذا كلّه عطاء، ولم يكن أعمالًا يَحسبه لهم، فجزاهم به حتى كأنهم عَملوا له. قال: ولم يَعملوا، إنما عَملوا عشرًا فأعطاهم مائة، وعَملوا مائة فأعطاهم ألفًا، هذا كلّه عطاء، والعمل الأول، ثم حَسب ذلك حتى كأنهم عَملوا، فجزاهم كما جزاهم بالذي عَملوا{3}٦٩٩٦. (ز) ٦٩٩٦ ذكر ابنُ عطية (٨/٥٢٢) أنّ جمهور المفسرين واللغويين ذكروا أنّ قوله: <q>﴿حسابا﴾</q> معناه: «محسبًا، أي: كافيًا من قولهم: أحسبني هذا الأمر، أي: كفاني، ومنه: حسبي الله». ثم ذكر عن مجاهد أنّ <q>﴿حسابا﴾</q> معناه: «مُقسَّطًا على الأعمال». ثم علّق بقوله: «لأنّ نفس دخول الجنة برحمة الله وتَفضُّله لا بعمل، والدرجات فيها والنِّعم على قدْر الأعمال، فإذا ضاعف الله لقوم حسناتهم بسبعمائة مثلًا، ومنهم المُكثر من الأعمال والمُقلّ؛ أخذ كلّ واحد سبعمائة بحسب عمله، وكذلك في كلّ تضعيف، فالحساب هنا هو بموازنة أعمال القوم». ",footnotes:1:تفسير مجاهد ص٦٩٦، وأخرجه ابن جرير ٢٤/٤٤، ٤٦، والفريابي -كما في تغليق التعليق ٤/٣٥٩-. وذكره يحيى بن سلام بنحوه -كما في تفسير ابن أبي زمنين ٥/٨٥-. وعزاه السيوطي إلى عَبد بن حُمَيد، وابن المنذر.أخرجه عبد الرزاق ٢/٣٤٣، وابن جرير ٢٤/٤٤. وعزاه السيوطي إلى عَبد بن حُمَيد، وابن المنذر.أخرجه ابن جرير ٢٤/٤٤.تفسير مقاتل بن سليمان ٤/٥٦٥.أخرجه ابن جرير ٢٤/٤٤.
78,37," <q>﴿رَّبِّ ٱلسَّمَـٰوَ ٰ⁠تِ وَٱلۡأَرۡضِ وَمَا بَیۡنَهُمَا ٱلرَّحۡمَـٰنِۖ لَا یَمۡلِكُونَ مِنۡهُ خِطَابࣰا ۝٣٧﴾</q> - تفسير ٨١٠٤٦- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿لا يَمْلِكُونَ مِنهُ خِطابًا﴾</q>، قال: كلامًا{1}. (١٥/٢١٠) ٨١٠٤٧- قال الحسن البصري: <q>﴿وما بَيْنَهُما الرَّحْمَنِ لا يَمْلِكُونَ مِنهُ خِطابًا﴾</q> لا يَستطيعون مُخاطبته، كقوله: <q>﴿يَوْمَ يَأْتِ لا تَكَلَّمُ نَفْسٌ إلّا بِإذْنِهِ﴾</q> [هود:١٠٥]{2}. (ز) ٨١٠٤٨- عن قتادة بن دعامة -من طريق سعيد- قوله: <q>﴿لا يَمْلِكُونَ مِنهُ خِطابًا﴾</q>، قال: كلامًا{3}. (١٥/٢١٠) ٨١٠٤٩- قال محمد بن السّائِب الكلبي: <q>﴿لا يَمْلِكُونَ مِنهُ خِطابًا﴾</q> شفاعة إلّا بإذنه{4}. (ز) ٨١٠٥٠- قال مقاتل: <q>﴿لا يَمْلِكُونَ مِنهُ خِطابًا﴾</q> لا يَقدِر الخَلْق على أن يُكلِّموا الرّبَّ إلا بإذنه{5}٦٩٩٧. (ز) ٦٩٩٧ رجّح ابنُ تيمية (٦/٤٥٤) -مستندًا إلى النظائر، والسنة- أنّ قوله: <q>﴿لا يملكون منه خطابا﴾</q> عام في جميع الخَلْق، فقال: «والصحيح: قول الجمهور والسلف أنّ هذا عام، كما قال في آية أخرى: <q>﴿وخَشَعَت الأَصْواتُ لِلرَّحْمَنِ فَلا تَسْمَعُ إلّا هَمْسًا﴾</q> [طه:١٠٨]، وفي حديث التَّجلّي الذي في الصحيح لمّا ذكر مرورهم على الصراط قال ﷺ: «ولا يَتكلّم أحد إلا الرُّسُل، ودعوى الرُّسُل: اللهم، سَلِّمْ سَلِّمْ». فهذا في وقت المرور على الصراط، وهو بعد الحساب والميزان، فكيف بما قبل ذلك؟!». ٨١٠٥١- قال مقاتل بن سليمان: ثم عَظّم الرّبّ تعالى نفسه، ودلّ على صُنعه، فقال: <q>﴿رَبِّ السَّماواتِ والأَرْضِ وما بَيْنَهُما﴾</q> يعني: الشمس، والقمر، والنُّجوم، والسحاب، والرياح، قال: هو ‹الرَّحْمَنُ› الرحيم، وهم <q>﴿لا يَمْلِكُونَ مِنهُ خِطابًا﴾</q> يعني: المناجاة، إذا استوى للحساب{6}. (ز) ٨١٠٥٢- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿لا يَمْلِكُونَ مِنهُ خِطابًا﴾</q>، قال: لا يملكون أن يُخاطِبوا الله، والمُخاطِب: المُخاصِم الذي يُخاصم صاحبه{7}٦٩٩٨. (ز) ٦٩٩٨ لم يذكر ابنُ جرير (٢٤/٤٥-٤٦) غير قول عبد الرحمن بن زيد، وقول قتادة، ومجاهد. ",footnotes:1:تفسير مجاهد ص٦٩٦، وأخرجه ابن جرير ٢٤/٤٦، والفريابي -كما في تغليق التعليق ٤/٣٥٩-. وعزاه السيوطي إلى عَبد بن حُمَيد، وابن المنذر.ذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٥/٨٦-.أخرجه ابن جرير ٢٤/٤٦. وعزاه السيوطي إلى عبد الرزاق، وعَبد بن حُمَيد، وابن المنذر.تفسير الثعلبي ١٠/١١٩، وتفسير البغوي ٨/٣١٧.تفسير البغوي ٨/٣١٧.تفسير مقاتل بن سليمان ٤/٥٦٥.أخرجه ابن جرير ٢٤/٤٦.
78,38," <q>﴿یَوۡمَ یَقُومُ ٱلرُّوحُ وَٱلۡمَلَـٰۤىِٕكَةُ صَفࣰّاۖ﴾</q> - تفسير ٨١٠٥٣- عن ابن عباس، أنّ النبيَّ ﷺ، قال: «الروح جند من جنود الله، ليسوا بملائكة، لهم رؤوس وأيد وأرجل». ثم قرأ: <q>﴿يَوْمَ يَقُومُ الرُّوحُ والمَلائِكَةُ صَفًّا﴾</q>، قال: «هؤلاء جند، وهؤلاء جند»{1}. (١٥/٢١٠) ٨١٠٥٤- عن عبد الله بن مسعود -من طريق عَلقمة- قال: الروح مَلَكٌ في السماء الرابعة، وهو أعظم من السموات والجبال ومن الملائكة، يُسبِّح كلَّ يوم اثني عشر ألف تسبيحة، يَخلُق الله من كلّ تسبيحة مَلَكًا مِن الملائكة، يجيء يوم القيامة صفًّا وحده{2}٦٩٩٩. (١٥/٢١٢) ٦٩٩٩ علّق ابنُ كثير (٨/٢٣٦) على قول ابن مسعود، فقال: «وهذا قول غريب جدًّا». ٨١٠٥٥- عن عبد الله بن عباس -من طريق علي- في قوله: <q>﴿يَوْمَ يَقُومُ الرُّوحُ﴾</q>، قال: هو مَلَكٌ مِن أعظم الملائكة خَلْقًا{3}. (١٥/٢١٢) ٨١٠٥٦- عن عبد الله بن عباس: <q>﴿الرُّوحُ﴾</q> مَلَكٌ مِن الملائكة، ما خَلَق الله مخلوقًا أعظم منه، فإذا كان يوم القيامة قام وحده صفًّا، وقامت الملائكة كلّهم صفًّا واحدًا؛ فيكون عِظمُ خَلْقِه مثلَهم{4}. (ز) ٨١٠٥٧- عن عبد الله بن عباس -من طريق سِماك- قال: إنّ جبريل يوم القيامة القائم بين يدي الجبّار تُرْعَد فَرائصه فَرَقًا مِن عذاب الله، يقول: سبحانك، لا إله إلا أنت، ما عبدناك حقّ عبادتك. إنّ ما بين مَنكِبيه كما بين المشرق والمغرب، أما سمعتَ قول الله: <q>﴿يَوْمَ يَقُومُ الرُّوحُ والمَلائِكَةُ صَفًّا﴾</q>{5}. (١٥/٢١٣) ٨١٠٥٨- عن عبد الله بن عباس -من طريق مجاهد- قال: <q>﴿الرُّوحُ﴾</q> أمْرٌ مِن أمْر الله، خَلْقٌ مِن خَلْق الله، صُوَرهم على صُوَر بني آدم، ما نزل من السماءِ مَلَكٌ إلا معه واحد من الروح{6}. (ز) ٨١٠٥٩- عن عبد الله بن عباس -من طريق عطية- في قوله: <q>﴿يَوْمَ يَقُومُ الرُّوحُ﴾</q>، قال: يعني: حين تقوم أرواح الناس مع الملائكة فيما بين النفختين قبل أن تُردّ الأرواح إلى الأجساد{7}. (١٥/٢١٤) ٨١٠٦٠- عن مجاهد بن جبر -من طريق ابن نجيح- قال: الروح خَلْقٌ على صورة بني آدم{8}. (١٥/٢١١) ٨١٠٦١- عن مجاهد بن جبر -من طريق مسلم- قال: الروح يأكلون، ولهم أيدٍ وأرجل ورؤوس، وليسوا بملائكة{9}. (١٥/٢١١) ٨١٠٦٢- عن الضَّحّاك بن مُزاحِم -من طريق ثابت- في قوله: <q>﴿يَوْمَ يَقُومُ الرُّوحُ﴾</q>، قال: جبريل{10}. (١٥/٢١٣) ٨١٠٦٣- عن الضَّحّاك بن مُزاحِم، قال: الروح حاجب الله، فيقوم بين يدي الله يوم القيامة، وهو أعظم الملائكة، لو فَتح فاهُ لَوَسِع جميعَ الملائكة، والخَلْق إليه ينظرون، فمِن مَخافته لا يَرفعون طَرْفهم إلى مَن فوقه{11}. (١٥/٢١٢) ٨١٠٦٤- عن عكرمة مولى ابن عباس، في قوله: <q>﴿يَوْمَ يَقُومُ الرُّوحُ والمَلائِكَةُ صَفًّا﴾</q>، قال: الروح أعظم خَلْقًا مِن الملائكة، ولا يَنزل مَلَكٌ إلا ومعه روح{12}. (١٥/٢١٢) ٨١٠٦٥- عن عامر الشعبي -من طريق منصور- في قوله: <q>﴿يَوْمَ يَقُومُ الرُّوحُ والمَلائِكَةُ صَفًّا﴾</q>، قال: هما سِماطا{13} ربِّ العالمين يوم القيامة؛ سِماط من الروح، وسِماط من الملائكة{14}. (١٥/٢١١) ٨١٠٦٦- عن عامرالشعبي -من طريق أبي حمزة- <q>﴿يَوْمَ يَقُومُ الرُّوحُ﴾</q>، قال: الروح جبريل ﵇{15}. (ز) ٨١٠٦٧- عن عبد الله بن بُرَيْدة، قال: ما يَبلغ الجنُّ والإنسُ والملائكةُ والشياطينُ عُشر الروح، ولقد قُبِض النبيُّ وما يَعلم الروح{16}. (١٥/٢١١) ٨١٠٦٨- عن الحسن البصري -من طريق خُليد بن دَعلج- أنه قرأ: <q>﴿يَوْمَ يَقُومُ الرُّوحُ والمَلائِكَةُ صَفًّا﴾</q>، قال: الروح ههنا بنو آدم، يقومون يوم القيامة صفًّا{17}. (ز) ٨١٠٦٩- قال الحسن البصري: <q>﴿يَوْمَ يَقُومُ الرُّوحُ﴾</q> يقوم روحُ كلِّ شيء في جسده{18}. (ز) ٨١٠٧٠- عن أبي صالح [باذام] -من طريق إسماعيل بن أبي خالد- في قوله: <q>﴿يَوْمَ يَقُومُ الرُّوحُ والمَلائِكَةُ صَفًّا﴾</q>، قال: الروح خَلْقٌ كالناس، وليسوا بالناس، لهم أيدٍ وأرجل{19}. (١٥/٢١١) ٨١٠٧١- عن وهْب بن مُنَبِّه، قال: الرُّوح مَلَكٌ مِن الملائكة، له عشرة آلاف جناح، ما بين كلّ جناحين منها ما بين المشرق والمغرب، له ألف وجه، لكلّ وجه ألف لسان وشَفتان وعَينان يُسبِّحون الله تعالى{20}. (١٥/٢١٣) ٨١٠٧٢- قال وهْب بن مُنَبِّه: إنّ جبريل ﵇ واقفٌ بين يدي الله سبحانه، تُرْعَد فَرائصه، يَخلُق الله ﷾ من كلّ رعدة مائة ألف ملك، فالملائكة صفوف بين يدي الله، مُنَكِّسو رؤوسهم، فإذا أذِن الله سبحانه لهم في الكلام قالوا: لا إله إلّا أنت. وهو قوله سبحانه: <q>﴿يَوْمَ يَقُومُ الرُّوحُ والمَلائِكَةُ صَفًّا﴾</q>{21}. (ز) ٨١٠٧٣- عن قتادة بن دعامة -من طريق عبد الرزاق، عن معمر- في قوله تعالى: <q>﴿يَوْمَ يَقُومُ الرُّوحُ﴾</q>، قال: الروح هم بنو آدم{22}. (ز) ٨١٠٧٤- عن قتادة بن دعامة -من طريق ابن ثور، عن معمر- في قوله: <q>﴿يَوْمَ يَقُومُ الرُّوحُ﴾</q>: هذا مِمّا كان يكتمه ابن عباس{23}. (ز) ٨١٠٧٥- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- كان أبي [زيد بن أسلم] يقول: الروح: القرآن. وقرأ: <q>﴿وكَذَلِكَ أوْحَيْنا إلَيْكَ رُوحًا مِن أمْرِنا ما كُنْتَ تَدْرِي ما الكِتابُ ولا الإيمان﴾</q> [الشورى:٥٢]{24}. (ز) ٨١٠٧٦- عن سليمان بن مهران الأعمش -من طريق المسعودي- في قوله: <q>﴿يَوْمَ يَقُومُ الرُّوحُ والمَلائِكَةُ صَفًّا﴾</q>، قال: الروح خَلْقٌ مِن خَلْق الله، يَضْعُفون على الملائكة أضعافًا، لهم أيدٍ وأرجل{25}. (ز) ٨١٠٧٧- قال مقاتل بن سليمان: ثم أخبرهم متى يكونُ ذلك؟ فقال: <q>﴿يَوْمَ يَقُومُ الرُّوحُ﴾</q> وهو المَلَك الذي قال الله ﷿ عنه: <q>﴿ويَسْأَلُونَكَ عَنِ الرُّوحِ﴾</q> [الإسراء:٨٥]، وجهه وجه آدم ﵇، ونصفه من نار، ونصفه من ثلج، فيُسبّح بحمد ربه، ويقول: ربِّ، كما ألَّفتَ بين هذه النار وهذا الثلج؛ تُذيب هذه النار هذا الثلج، ولا يُطفئ هذا الثلج هذه النار، فكذلك ألِّف بين عبادك المؤمنين، فاختصّه الله تعالى مِن بين الخَلْق من عِظَمه. فقال: <q>﴿يَوْمَ يَقُومُ الرُّوحُ﴾</q>{26}. (ز) ٨١٠٧٨- عن مقاتل بن حيّان، قال: الروح أشرفُ الملائكة، وأقربهم من الرّبّ، وهو صاحب الوحي{27}. (١٥/٢١٣) ٨١٠٧٩- قال يحيى بن سلّام:<q>﴿يوم يقوم الروح﴾</q> روح كل شيء في جسده{28}٧٠٠٠. (ز) ٧٠٠٠ اختُلف فيما عنى الله بالروح في هذه الآية على أقوال: الأول: مَلَكٌ مِن أعظم الملائكة. الثاني: جبريل. الثالث: خَلْقٌ يُشبه بني آدم. الرابع: بنو آدم. الخامس: أرواح بني آدم. السادس: القرآن. السابع: أنهم حفظة على الملائكة. وعلّق ابنُ كثير (١٤/٢٣٦) على القول الثاني بقوله: «ويُستشهد لهذا القول بقوله: <q>﴿نزل به الروح الأمين على قلبك لتكون من المنذرين﴾</q> [الشعراء:١٩٣-١٩٤]». وعلّق ابنُ عطية (٨/٥٢٣-٥٢٤) على القول الخامس، فقال: «وقال ابن عباس، والحسن، وقتادة: الرُّوحُ هنا اسم جنس، يراد به: أرواح بني آدم، والمعنى: يوم تقوم الأرواح في أجسادها إثر البعث والنشأة الآخرة، ويكون الجمع من الإنس والملائكة صَفًّا، ولا يَتكلّم أحد هيبة وفزعًا، <q>﴿إلّا مَن أذِنَ لَهُ الرَّحْمنُ﴾</q> مِن مَلَك أو نبيٍّ، وكان أهلًا أن يقول صَوابًا في ذلك الموطن». وعلّق على القول السادس، فقال: «وقال ابن زيد: كان أبي يقول: هو القرآن، وقد قال الله تعالى: <q>﴿أوْحَيْنا إلَيْكَ رُوحًا مِن أمْرِنا﴾</q> [الشورى:٥٢] أي: من أمرنا. فالقيام فيه مُستعار يُراد به بيانه وظهوره وشدة آثاره، والأشياء الكائنة عن تصديقه أو تكذيبه». ثم انتقده بقوله: «ومع هذا ففي القول قلق». وجوّز ابنُ جرير (٢٤/٥٠) هذه الأقوال، ولم يقطع بقولٍ منها؛ لصحتها، وعدم الدليل على التعيين، فقال: «والصواب من القول أن يُقال: إنّ الله -تعالى ذِكْره- أخبر أنّ خَلْقه لا يملكون منه خطابًا يوم يقوم الروح، والروح: خَلْقٌ من خَلْقه. وجائز أن يكون بعض هذه الأشياء التي ذكرت، والله أعلم أيَّ ذلك هو؟ ولا خبر بشيء من ذلك أنه المعني به دون غيره يجب التسليم له، ولا حُجّة تدل عليه، وغير ضائر الجهل به». ورجّح ابنُ كثير (٨/٣١٠) القول الرابع، فقال: «والأشبه -والله أعلم- أنهم بنو آدم». ولم يذكر مستندًا. <q>﴿یَوۡمَ یَقُومُ ٱلرُّوحُ وَٱلۡمَلَـٰۤىِٕكَةُ صَفࣰّاۖ﴾</q> - آثار متعلقة بالآية ٨١٠٨٠- عن عائشة، أنّ رسول الله ﷺ كان يقول في ركوعه وسجوده: «سُبُّوح، قُدُّوس، ربّ الملائكة والرُّوح»{29}. (١٥/٢١٣) <q>﴿لَّا یَتَكَلَّمُونَ إِلَّا مَنۡ أَذِنَ لَهُ ٱلرَّحۡمَـٰنُ وَقَالَ صَوَابࣰا ۝٣٨﴾</q> - تفسير ٨١٠٨١- عن عبد الله بن عباس -من طريق علي- في قوله: <q>﴿وقالَ صَوابًا﴾</q>، قال: لا إله إلا الله{30}. (١٥/٢١٤) ٨١٠٨٢- عن عبد الله بن عباس -من طريق سِماك- في قوله: <q>﴿وقالَ صَوابًا﴾</q>، قال: شهادة أن لا إله إلا الله{31}. (١٥/٢١٤) ٨١٠٨٣- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿وقالَ صَوابًا﴾</q>، قال: حقًّا في الدنيا، وعَمِل به{32}٧٠٠١. (١٥/٢١٤) ٧٠٠١ ذكر ابنُ تيمية (٦/٤٥٥) قول مجاهد، وعلّق عليه قائلًا: «فعلى قول مجاهد يكون المستثنى مَن أتى بالكلم الطّيّب والعمل الصالح». ٨١٠٨٤- عن عكرمة مولى ابن عباس -من طريق الحكم بن أبان- في قوله: <q>﴿إلّا مَن أذِنَ لَهُ الرَّحْمَنُ وقالَ صَوابًا﴾</q>، قال: لا إله إلا الله{33}. (١٥/٢١٤) ٨١٠٨٥- عن عكرمة مولى ابن عباس -من طريق أبي عمرو الذي يقُصُّ في طَيِّئ- وقرأ هذه الآية: <q>﴿إلّا مَن أذِنَ لَهُ الرَّحْمَنُ وقالَ صَوابًا﴾</q>، قال: يُمَرُّ بأناسٍ مِن أهل النار على ملائكة، فيقولون: أين تذهبون بهؤلاء؟ فيقال: إلى النار. فيقولون: بما كسبت أيديهم، وما ظلمهم الله. ويُمَرُّ بأناس مِن أهل الجنة على ملائكة، فيقال: أين تذهبون بهؤلاء؟ فيقولون: إلى الجنة. فيقولون: برحمة الله دَخلتم الجنة. قال: فيُؤذن لهم في الكلام، أو نحو ذلك{34}. (ز) ٨١٠٨٦- عن أبي صالح [باذام] -من طريق إسماعيل بن أبي خالد- في قوله: <q>﴿إلّا مَن أذِنَ لَهُ الرَّحْمَنُ وقالَ صَوابًا﴾</q>، قال: لا إله إلا الله{35}. (ز) ٨١٠٨٧- عن قتادة بن دعامة -من طريق خُليد- يقول: وقرأ: <q>﴿لا يَتَكَلَّمُونَ إلّا مَن أذِنَ لَهُ الرَّحْمَنُ وقالَ صَوابًا﴾</q> في الدنيا{36}. (ز) ٨١٠٨٨- قال مقاتل بن سليمان: ثم انقطع الكلام، فقال: <q>﴿والمَلائِكَةُ صَفًّا لا يَتَكَلَّمُونَ﴾</q> مِن الخوف أربعين عامًا، <q>﴿إلّا مَن أذِنَ لَهُ الرَّحْمنُ﴾</q> بالكلام، <q>﴿وقالَ صَوابًا﴾</q> يعني: شهادة ألا إله إلا الله، فذلك الصواب{26}٧٠٠٢. (ز) ٧٠٠٢ اختُلف في الوقت الذي يُؤذن فيه بالكلام القول الصواب على قولين: الأول: أنه في الدنيا، كما ورد في قول مَن قال من السلف: هو قول لا إله إلا الله، والإذن يكون في الدنيا بالتوحيد. الثاني: أنه في الآخرة، والإذن كما أُشير إليه في أثر عكرمة من طريق أبي عمرو. وقد ذكر ابنُ جرير (٢٤/٥٢) القولين، ولم يقطع بأحدهما لعدم وجود دليل على تعيينه، فقال: «والصواب من القول في ذلك: أن يُقال: إنّ الله -تعالى ذِكره- أخبر عن خَلْقه أنهم لا يتكلّمون يوم يقوم الروح والملائكة صفًّا، إلا مَن أذن له منهم في الكلام الرحمن، وقال صوابًا، فالواجب أن يُقال كما أخبر إذ لم يخبرنا في كتابه، ولا على لسان رسوله، أنه عنى بذلك نوعًا من أنواع الصواب، والظاهر محتمل جميعه». ٨١٠٨٩- قال يحيى بن سلّام: <q>﴿لا يتكلمون إلا من أذن له الرحمن وقال صوابا﴾</q> التوحيد{28}. (ز) ",footnotes:1:أخرجه أبو الشيخ في العظمة ٣/٨٧٠ (٤١٠)، والمخلص في المخلصيات ٣/٣٧٧ (٢٧٥٢) مطولًا، والثعلبي ١٠/١١٩، من طريق مسلم الأعور، عن مجاهد، عن ابن عباس به. وسنده شديد الضعف؛ فيه مسلم بن كيسان الأعور، وهو متروك. الميزان ٤/١٠٦.أخرجه ابن جرير ٢٤/٤٦-٤٧، والثعلبي ١٠/١١٩.أخرجه ابن جرير ٢٤/٤٧، وابن أبي حاتم -كما في الإتقان ٢/٥٢-، وأبو الشيخ (٤١٣)، والبيهقي في الأسماء والصفات (٧٨٠). وعزاه السيوطي إلى ابن المنذر.تفسير البغوي ٨/٣١٧.أخرجه أبو الشيخ (٣٦٥).أخرجه آدم بن أبي إياس -كما في تفسير مجاهد ص٦٩٦-.أخرجه ابن جرير ٢٤/٤٩-٥٠، والبيهقي في الأسماء والصفات (٧٨٤).أخرجه عبد الرزاق ٢/٣٤٤، وابن جرير ٢٤/٤٨-٤٩، وأبو الشيخ (٤١٤)، والبيهقي في الأسماء والصفات (٧٨٣). وعزاه السيوطي إلى عَبد بن حُمَيد، وابن المنذر، وابن أبي حاتم.أخرجه عبد الرزاق ٢/٣٤٤، وابن جرير ٢٤/٤٨، وأبو الشيخ (٤١٤). وعزاه السيوطي إلى عَبد بن حُمَيد، وابن المنذر.أخرجه ابن جرير ٢٤/٤٧، ومن طريق سفيان أيضًا، وأبو الشيخ (٤١٦). وعزاه السيوطي إلى عَبد بن حُمَيد.أخرجه أبو الشيخ في العظمة (٤٠٨).عزاه السيوطي إلى عَبد بن حُمَيد، وابن المنذر.السماط: الصف. لسان العرب (سمط).أخرجه ابن جرير ٢٤/٥٠، وأبو الشيخ في العظمة (٤١٧). وعزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ٢٤/٤٧.أخرجه أبو الشيخ (٤٠٩). وعزاه السيوطي إلى ابن أبي حاتم.أخرجه ابن أبي الدنيا في كتاب الأهوال -موسوعة الإمام ابن أبي الدنيا ٦/٢٢١ (٢٠٧)-، وأخرجه ابن جرير ٢٤/٤٩ من طريق معمر.ذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٥/٨٦-.أخرجه عبد الرزاق ٢/٣٤٤، وابن جرير ٢٤/٤٨-٤٩، وأبو الشيخ (٤١٥)، والبيهقي في الأسماء والصفات (٧٨٢). وعزاه السيوطي إلى عَبد بن حُمَيد، وابن المنذر، وابن أبي حاتم.عزاه السيوطي إلى الخطيب في المتفق والمفترق.تفسير الثعلبي ١٠/١١٩.أخرجه عبد الرزاق ٢/٣٤٣، وابن جرير ٢٤/٤٩ من طريق سعيد.أخرجه ابن جرير ٢٤/٤٩.أخرجه ابن جرير ٢٤/٥٠.أخرجه ابن جرير ٢٤/٤٨.تفسير مقاتل بن سليمان ٤/٥٦٥-٥٦٦.أخرجه أبو الشيخ (٤١٨). وعزاه السيوطي إلى ابن المنذر.تفسير يحيى بن سلام ١/٢٨١.أخرجه مسلم (٤٨٧)، وأبو داود (٨٧٢)، والنسائي (١١٣٣)، والبيهقي في الأسماء والصفات (٥٧).أخرجه ابن جرير ٢٤/٥١، والبيهقي في الأسماء والصفات (٢٠٥-٢٠٦). وعزاه السيوطي إلى ابن المنذر.أخرجه أبو الشيخ (٣٦٥). وعزاه السيوطي إلى ابن المنذر.تفسير مجاهد ص٦٩٦، وأخرجه الفريابي -كما في تغليق التعليق ٤/٣٥٩-، وابن جرير ٢٤/٥١. وعلّقه البخاريُّ في صحيحه ٤/١٨٨٠. وعزاه السيوطي إلى عَبد بن حُمَيد.أخرجه ابن جرير ٢٤/٥٢. وعزاه السيوطي إلى عَبد بن حُمَيد.أخرجه ابن جرير ٢٤/٥١.أخرجه ابن جرير ٢٤/٥٢، والطبراني في الدعاء ٣/١٥٢٠ وزاد في آخره: في الدنيا.أخرجه ابن أبي الدنيا في كتاب الأهوال -موسوعة الإمام ابن أبي الدنيا ٦/٢٢١ (٢٠٨)-، وهو مروي بالإسناد السابق للأثر الذي قبله: وقال: عمار بن نصر، دثنا الوليد بن مسلم، دثنا خليد بن دعلج.تفسير مقاتل بن سليمان ٤/٥٦٥-٥٦٦.تفسير يحيى بن سلام ١/٢٨١.
78,39," <q>﴿ذَ ٰ⁠لِكَ ٱلۡیَوۡمُ ٱلۡحَقُّۖ فَمَن شَاۤءَ ٱتَّخَذَ إِلَىٰ رَبِّهِۦ مَـَٔابًا ۝٣٩﴾</q> - تفسير ٨١٠٩٠- عن قتادة بن دعامة -من طريق معمر- في قوله: <q>﴿فَمَن شاءَ اتَّخَذَ إلى رَبِّهِ مَآبًا﴾</q>، قال: سبيلًا{1}. (١٥/٢١٥) ٨١٠٩١- عن قتادة بن دعامة -من طريق سعيد- <q>﴿فَمَن شاءَ اتَّخَذَ إلى رَبِّهِ مَآبًا﴾</q>، قال: اتخذوا إلى الله مآبًا بطاعته، وما يُقرِّبهم إليه{2}. (ز) ٨١٠٩٢- قال مقاتل بن سليمان: <q>﴿ذلِكَ اليَوْمُ الحَقُّ﴾</q> لأنّ العرب قالوا: إنّ القيامة باطل. فذلك قوله: <q>﴿اليَوْمُ الحَقُّ فَمَن شاءَ اتَّخَذَ إلى رَبِّهِ مَآبًا﴾</q> يعني: منزلة، يعني: الأعمال الصالحة{3}. (ز) ٨١٠٩٣- عن سفيان [الثوري] -من طريق مهران- <q>﴿مَآبًا﴾</q>، يقول: مرجعًا، منزلًا{2}. (ز) ",footnotes:1:أخرجه عبد الرزاق ٢/٣٤٤، وابن جرير ٢٤/٥٣. وعزاه السيوطي إلى عَبد بن حُمَيد، وابن المنذر.أخرجه ابن جرير ٢٤/٥٣.تفسير مقاتل بن سليمان ٤/٥٦٦.أخرجه ابن جرير ٢٤/٥٣.
78,40," <q>﴿إِنَّاۤ أَنذَرۡنَـٰكُمۡ عَذَابࣰا قَرِیبࣰا﴾</q> - تفسير ٨١٠٩٤- قال مقاتل بن سليمان: ثم خوّفهم أيضًا العذاب في الدنيا، فقال: <q>﴿إنّا أنْذَرْناكُمْ عَذابًا قَرِيبًا﴾</q>، يعني: في الدنيا القتل ببدر، وهلاك الأمم الخالية، وإنما قال: <q>﴿قريبًا﴾</q> لأنها أقرب من الآخرة{1}. (ز) <q>﴿یَوۡمَ یَنظُرُ ٱلۡمَرۡءُ مَا قَدَّمَتۡ یَدَاهُ﴾</q> - تفسير ٨١٠٩٥- عن الحسن البصري -من طريق محمد بن جحادة- <q>﴿يَوْمَ يَنْظُرُ المَرْءُ﴾</q>، قال: المؤمن{2}٧٠٠٣. (١٥/٢١٥) ٧٠٠٣ لم يذكر ابنُ جرير (٢٤/٥٤) غير قول الحسن. ٨١٠٩٦- عن الحسن البصري أنه قرأ هذه الآية: <q>﴿يَوْمَ يَنْظُرُ المَرْءُ ما قَدَّمَتْ يَداهُ﴾</q>، قال: هو المؤمن العامِل بطاعة الله{3}. (١٥/٢١٥) ٨١٠٩٧- عن الحسن البصري -من طريق المبارك بن فَضالة- <q>﴿يَوْمَ يَنْظُرُ المَرْءُ ما قَدَّمَتْ يَداهُ﴾</q> قال: ذاك المؤمن الكيِّس الحذِر، عَلِم أنّ له معادًا فقدَّم وقدَّم، فلمّا قدِم عليه نظر إلى ما قدَّم واغتبط. ويقول الكافر: <q>﴿يا لَيْتَنِي كُنْتُ تُرابًا﴾</q> لأنّه لا يُقَدِّم خيرًا، فيقول: <q>﴿يا لَيْتَنِي كُنْتُ تُرابًا﴾</q> فلا يكون ترابًا{4}. (ز) ٨١٠٩٨- قال مقاتل بن سليمان: ثم رجع إلى القول الأول حين قال: <q>﴿يَوْمَ يَقُومُ الرُّوحُ والمَلائِكَةُ صَفًّا﴾</q>، فقال: <q>﴿يَوْمَ يَنْظُرُ المَرْءُ ما قَدَّمَتْ يَداهُ﴾</q> يعني: الإنسان الخاطئ يرى عمله أسود مثل الجبل{1}. (ز) <q>﴿وَیَقُولُ ٱلۡكَافِرُ یَـٰلَیۡتَنِی كُنتُ تُرَ ٰ⁠بَۢا ۝٤٠﴾</q> - تفسير ٨١٠٩٩- عن أبي هريرة، أنّ رسول الله ﷺ قال: «يَقضي الله بين خَلْقه الجنّ والإنس والبهائم، وإنّه لَيُقِيد يومئذٍ الجَمّاء مِن القَرْناء، حتى إذا لم يَبق تبعةٌ عند واحدة لأخرى قال الله: كونوا ترابًا. فعند ذلك يقول الكافر: <q>﴿يا لَيْتَنِي كُنْتُ تُرابًا﴾</q>»{6}. (ز) ٨١١٠٠- عن أبي هريرة -من طريق يزيد بن الأصمّ- قال: يُحشَر الخَلْق كلّهم يوم القيامة؛ البهائم، والدواب، والطير، وكل شيء، فيَبلغ مِن عدل الله أن يأخذ للجَمّاء من القرناء، ثم يقول: كونوا ترابًا. فذلك حين يقول الكافر: <q>﴿يا لَيْتَنِي كُنْتُ تُرابًا﴾</q>{7}. (١٥/٢١٥) ٨١١٠١- عن عبد الله بن عمرو -من طريق أبي المُغيرة- قال: إذا كان يوم القيامة مُدَّت الأرض مدّ الأديم، وحُشِر الدواب والبهائم والوحش، ثم يُجعل القصاص بين الدواب، يُقتصّ للشاة الجَمّاء من الشاة القَرْناء نَطحتها، فإذا فُرغ من القصاص بين الدواب قال لها: كوني ترابًا. قال: فعند ذلك يقول الكافر: <q>﴿يا لَيْتَنِي كُنْتُ تُرابًا﴾</q>{8}. (ز) ٨١١٠٢- عن مجاهد بن جبر، قال: يُقاد للمنقورة مِن الناقرة، والمركوضة مِن الراكضة، والجَلحاء مِن ذات القَرْنَيْن، والناس ينظرون، ثم يقول: كوني ترابًا؛ لا جنة، ولا نار. فذلك حين يقول الكافر: <q>﴿يا لَيْتَنِي كُنْتُ تُرابًا﴾</q>{3}. (١٥/٢١٦) ٨١١٠٣- عن عكرمة مولى ابن عباس، قال: لَمّا حُوسِب البهائم، ثم صيّرها الله ترابًا، فعند ذلك قال الكافر: <q>﴿يا لَيْتَنِي كُنْتُ تُرابًا﴾</q>{10}. (١٥/٢١٧) ٨١١٠٤- عن الحسن البصري -من طريق المبارك بن فَضالة-: <q>﴿ويقول الكافر يا لَيْتَنِي كُنْتُ تُرابًا﴾</q> لأنه لا يُقدّم خيرًا، فيقول: <q>﴿يا لَيْتَنِي كُنْتُ تُرابًا﴾</q> فلا يكون ترابًا{11}. (ز) ٨١١٠٥- عن يحيى بن جعدة، قال: إنّ أول خَلْق اللهِ يُحاسب يوم القيامة الدواب والهوام، حتى يُقضى بينهما، حتى لا يَذهب شيء بظُلامته، ثم يجعلها ترابًا، ثم يَبعث الثَّقلين الإنس والجنّ، فيحاسبهم، فيومئذٍ يتمنّى الكافر: يا ليتني كنت ترابًا{12}. (١٥/٢١٦) ٨١١٠٦- عن القاسم بن أبي بَزَّة، في قوله: <q>﴿وما مِن دابَّةٍ فِي الأَرْضِ ولا طائِرٍ يَطِيرُ بِجَناحَيْهِ إلّا أُمَمٌ أمْثالُكُمْ ما فَرَّطْنا فِي الكِتابِ مِن شَيْءٍ ثُمَّ إلى رَبِّهِمْ يُحْشَرُونَ﴾</q> [الأنعام:٣٨]، قال: يؤتى بهم، والناس وقوف، فيُقضى بينهم، حتى إنه ليؤخذ لِلجَمّاء مِن القَرْناء لقهْرها إيّاها، وحتى يُقاد للذّرة من الذّرة، ثم يقال لهم: كونوا ترابًا. قال: ثم يقول الكافر: <q>﴿يا لَيْتَنِي كُنْتُ تُرابًا﴾</q>{13}. (ز) ٨١١٠٧- عن قتادة بن دعامة -من طريق سعيد- قوله: <q>﴿يَوْمَ يَنْظُرُ المَرْءُ ما قَدَّمَتْ يَداهُ ويَقُولُ الكافِرُ يا لَيْتَنِي كُنْتُ تُرابًا﴾</q>: وهو الهالك المُفرِط العاجز، وما يمنعه أن يقول ذلك وقد راج عليه عورات عمله، وقد استَقبل الرحمن وهو عليه غضبان؟! فتمنّى الموت يومئذ، ولم يكن في الدنيا شيء أكره عنده من الموت{14}. (ز) ٨١١٠٨- عن أبي الزّناد عبد الله بن ذكوان -من طريق جعفر- قال: إذا قُضِي بين الناس، وأُمر بأهل الجنة إلى الجنة وأهل النار إلى النار؛ قيل لمؤمني الجن ولسائر الأمم سوى ولد آدم: عُودوا ترابًا. [فيعودون] ترابًا، فعند ذلك يقول الكافر حين يراهم قد عادوا ترابًا: يا ليتني كنت ترابًا{15}. (١٥/٢١٦) ٨١١٠٩- عن ليث بن أبي سليم، قال: مؤمنو الجن يعودون ترابًا{10}. (١٥/٢١٧) ٨١١١٠- عن ليث بن أبي سليم، قال: ثواب الجن أن يُجاروا مِن النار، ثم يُقال لهم: كونوا ترابًا{17}. (١٥/٢١٧) ٨١١١١- قال مقاتل بن سليمان: <q>﴿ويَقُولُ الكافِرُ يا لَيْتَنِي كُنْتُ تُرابًا﴾</q> وذلك أنّ الله ﷿ يَجمع الوحوش والسِّباع يوم القيامة، فيقْتَصّ لبعضهم من بعض حقوقهم، حتى ليأخذ [للجماء] مِن القَرْناء بحقها، ثم يقول لهم: كونوا ترابًا. فيتمنى الكافر لو كان خنزيرًا في الدنيا ثم صار ترابًا، كما كانت الوحوش والسباع ثم صارت ترابًا{18}. (ز) ٨١١١٢- عن سفيان [الثوري] -من طريق مهران- في قوله: <q>﴿ويَقُولُ الكافِرُ يا لَيْتَنِي كُنْتُ تُرابًا﴾</q>، قال: إذا قيل للبهائم: كونوا ترابًا. قال الكافر: يا ليتني كنتُ ترابًا{19}. (ز) ٨١١١٣- عن الليث [بن سعد] -من طريق ابن وهب- قال: يقال إذا فَرغ الله مِن الحكم [...] والطير والبهائم، واقتصّ للشاة الجَمّاء من الشاة القَرْناء، قال لهم: كونوا ترابًا. فعند ذلك <q>﴿يَقُولُ الكافِرُ يا لَيْتَنِي كُنْتُ تُرابًا﴾</q>{20}٧٠٠٤. (ز) ٧٠٠٤ ذكر ابنُ عطية (٨/٥٢٤) في قوله: <q>﴿يا ليتني كنت ترابا﴾</q> ما أفادته آثار السلف مِن أنّ هذا «تَمَنٍّ أن يكون شيئًا حقيرًا، لا يُحاسب، ولا يلتفتُ إليه». وعلّق عليه قائلًا: «وهذا قد تجده في الخائفين من المؤمنين». ثم ذكر في معنى الآية قولًا آخر، ووجّهه، فقال: «قال أبو القاسم بن حبيب: رأيتُ في بعض التفاسير أنّ الكافر هنا: إبليس، إذا رأى ما حصل للمؤمنين من بني آدم من الثواب، قال: يا ليتني كنتُ ترابًا، أي: كآدم الذي خُلق من تراب واحتقره هو أولًا». ",footnotes:1:تفسير مقاتل بن سليمان ٤/٥٦٦.أخرجه ابن جرير ٢٤/٥٤. وعزاه السيوطي إلى عَبد بن حُمَيد، وابن المنذر.عزاه السيوطي إلى ابن المنذر.أخرجه آدم بن أبي إياس -كما في تفسير مجاهد ص٦٩٧-، وابن أبي الدنيا في كتاب الأهوال -موسوعة الإمام ابن أبي الدنيا ٦/٢٢٢ (٢١٠)- بلفظ: المرء المؤمن يحذر الصغيرة، ويخاف الكبيرة. كما أخرجه بنحوه من طريق عمارة.تفسير مقاتل بن سليمان ٤/٥٦٦.أخرجه ابن جرير ٢٤/٥٥، وأخرجه الطبراني مطولًا في الأحاديث الطوال ص٢٦٦-٢٦٨ (٣٦)، والبيهقي في البعث والنشور ص٣٣٦-٣٤٤ (٦٠٩)، وابن جرير ٢٤/٣٨٦-٣٨٩، من طريق محمد بن كعب القُرَظيّ، عن رجل من الأنصار، عن أبي هريرة به. وقال ابن كثير في تفسيره ٣/٢٨٧: «هذا حديث مشهور، وهو غريب جدًّا». وقال الألباني في الصحيحة ٤/٦٠٦-٦٠٧ (١٩٦٦): «إسناد ضعيف».أخرجه ابن جرير ٢٤/٥٥ مختصرًا. وعزاه السيوطي إلى البيهقي في البعث والنشور، وعَبد بن حُمَيد، وابن المنذر، وابن أبي حاتم. وفي تفسير الثعلبي ١٠/١٢١، وتفسير البغوي ٨/٣١٩ تتمة: فيقول التراب للكافر: لا، ولا كرامة لك، مَن جعلك مثلي؟!.أخرجه ابن جرير ٢٤/٥٤-٥٥.عزاه السيوطي إلى ابن المنذر.عزاه السيوطي إلى عَبد بن حُمَيد.أخرجه آدم بن أبي إياس -كما في تفسير مجاهد ص٦٩٧-.عزاه السيوطي إلى الدينوري في المجالسة.أخرجه ابن أبي الدنيا في كتاب الأهوال -موسوعة الإمام ابن أبي الدنيا ٦/٢٣١ (٢٢٤)-.أخرجه ابن جرير ٢٤/٥٥.أخرجه ابن جرير ٢٤/٥٦. وعزاه السيوطي إلى عَبد بن حُمَيد، وابن المنذر، وابن شاهين في كتاب العجائب والغرائب.عزاه السيوطي إلى عَبد بن حُمَيد.عزاه السيوطي إلى ابن أبي الدنيا.تفسير مقاتل بن سليمان ٤/٥٦٦. وفي تفسير البغوي ٨/٣١٨-٣١٩ بنحوه منسوبًا إلى مقاتل دون تعيينه.أخرجه ابن جرير ٢٤/٥٦.أخرجه عبد الله بن وهب في الجامع -تفسير القرآن ٢/١٥٨ (٣٢٧).
79,1," مقدمة السورة ٨١١١٤- عن عبد الله بن عباس -من طريق مجاهد- قال: نزلت سورة النازعات بمكة{1}. (١٥/٢١٨) ٨١١١٥- عن عبد الله بن الزُّبير، مثله{2}. (١٥/٢١٨) ٨١١١٦- عن عبد الله بن عباس -من طريق عطاء الخُراسانيّ-: مكّيّة، ونزلت بعد: <q>﴿عَمَّ يَتَساءَلُونَ﴾</q>{3}. (ز) ٨١١١٧- عن عكرمة= (ز) ٨١١١٨- والحسن البصري -من طريق يزيد النحوي-: مكّيّة{4}. (ز) ٨١١١٩- عن قتادة بن دعامة -من طرق-: مكّيّة{5}. (ز) ٨١١٢٠- عن محمد بن مسلم الزُّهريّ: مكّيّة، ونزلت بعد: <q>﴿عَمَّ يَتَساءَلُونَ﴾</q>{6}. (ز) ٨١١٢١- عن علي بن أبي طلحة: مكّيّة{7}. (ز) ٨١١٢٢- قال مقاتل بن سليمان: سورة النازعات مكّيّة، عددها ست وأربعون آية كوفي{8}. (ز) <q>﴿وَٱلنَّـٰزِعَـٰتِ غَرۡقࣰا ۝١﴾</q> - تفسير ٨١١٢٣- عن عبد الله بن مسعود -من طريق مسروق- في قوله: <q>﴿والنّازِعاتِ غَرْقًا﴾</q>، قال: الملائكة الذين يَلُون أنفسَ الكفار{9}٧٠٠٥. (١٥/٢٢٠) ٧٠٠٥ ذكر ابنُ عطية (٨/٥٢٥) قول ابن مسعود، ومثله عن ابن عباس، ثم علّق بقوله: «و<q>﴿غَرْقًا﴾</q> على هذا القول إما أن يكون مصدرًا بمعنى الإغراق والمبالغة في الفعل، وإما أن يكون كما قال علي، وابن عباس: تغرق نفوس الكفرة في نار جهنم». ٨١١٢٤- عن علي بن أبي طالب، في قوله: <q>﴿والنّازِعاتِ غَرْقًا﴾</q>، قال: هي الملائكة تَنزِعُ أرواحَ الكفار{10}. (١٥/٢١٨) ٨١١٢٥- عن عبد الله بن عباس -من طريق سعيد بن جُبَير- في قوله: <q>﴿والنّازِعاتِ غَرْقًا﴾</q>، قال: هي أنفس الكفار تُنزع، ثم تُنشط، ثم تُغرق في النار{11}. (١٥/٢١٨) ٨١١٢٦- عن عبد الله بن عباس، في قوله: <q>﴿والنّازِعاتِ غَرْقًا﴾</q>، قال: هي أرواح الكفار، لما عاينت مَلَك الموت فيُخبِرها بسخط الله غَرِقتْ، فيَنشِطها انتشاطًا مِن العَصَب واللحم{12}. (١٥/٢١٩) ٨١١٢٧- عن عبد الله بن عباس -من طريق مجاهد- <q>﴿والنّازِعاتِ غَرْقًا﴾</q>، قال: الموت{13}. (١٥/٢١٨) ٨١١٢٨- عن عبد الله بن عباس -من طريق عطية العَوفيّ- قوله: <q>﴿والنّازِعاتِ غَرْقًا﴾</q>، قال: تَنزع الأنفسَ{14}. (ز) ٨١١٢٩- عن عبد الله بن عباس -من طريق السُّدِّيّ، عن أبي صالح- قوله: <q>﴿والنّازِعاتِ غَرْقًا﴾</q>، قال: حين تَنزع نفسَه{15}. (ز) ٨١١٣٠- عن مَسروق بن الأَجْدع الهمداني -من طريق مسلم- أنه كان يقول في النازعات: هي الملائكة{15}. (ز) ٨١١٣١- عن سعيد بن جُبَير -من طريق جعفر- في قوله: <q>﴿والنّازِعاتِ غَرْقًا﴾</q>، قال: نُزعت أرواحهم، ثم غَرِقتْ، ثم قُذِف بها في النار{14}. (ز) ٨١١٣٢- عن مجاهد بن جبر -من طريق ابن أبي نجيح- <q>﴿والنّازِعاتِ غَرْقًا﴾</q>، قال: الموت{18}. (١٥/٢٢٠) ٨١١٣٣- عن مجاهد بن جبر، <q>﴿والنّازِعاتِ غَرْقًا﴾</q>، قال: الملائكة{19}٧٠٠٦. (١٥/٢٢٠) ٧٠٠٦ ذكر ابنُ عطية (٨/٥٢٥) قول مجاهد وابن عباس في معناه، ووجّههما، فقال: «قال ابن عباس ومجاهد: هي الملائكة؛ لأنها تنشِط النفوس عند الموت، أي: تحلّها كحلّ العِقال، وتنشَط بأمر الله إلى حيث كان». ٨١١٣٤- عن عكرمة مولى ابن عباس: <q>﴿والنّازِعاتِ غَرْقًا﴾</q> هي القِسِيُّ{20}. (ز) ٨١١٣٥- عن الحسن البصري -من طرق- في <q>﴿والنّازِعاتِ غَرْقًا﴾</q>، قال: النُّجوم{21}. (ز) ٨١١٣٦- عن عطاء [بن أبي رباح] -من طريق واصل بن السّائِب- <q>﴿والنّازِعاتِ غَرْقًا﴾</q>، قال: هي القِسِيُّ{22}٧٠٠٧. (١٥/٢٢١) ٧٠٠٧ ذكر ابنُ عطية (٨/٥٢٥) قول عطاء، وعلّق عليه، فقال: «وقال عطاء فيما رُوي عنه: النّازِعات: الجماعات النازعات بالقسي، و<q>﴿غَرْقًا﴾</q> بمعنى: الإغراق». ٨١١٣٧- عن أبي صالح [باذام]، <q>﴿والنّازِعاتِ غَرْقًا﴾</q>، قال: الملائكة يَنزعون نفس الإنسان{23}. (١٥/٢٢٠) ٨١١٣٨- عن قتادة بن دعامة، <q>﴿والنّازِعاتِ غَرْقًا﴾</q>، قال: هو الكافِر{24}. (١٥/٢٢٠) ٨١١٣٩- عن قتادة بن دعامة -من طريق أبي ثور، عن معمر- في قوله <q>﴿والنّازِعاتِ غَرْقًا﴾</q>، قال: النُّجوم{25}. (ز) ٨١١٤٠- عن قتادة بن دعامة -من طريق عبد الرزاق، عن معمر- في قوله: <q>﴿والنّازِعاتِ غَرْقًا﴾</q>، قال: هذه النُّفوس{26}. (ز) ٨١١٤١- عن إسماعيل السُّدِّيّ -من طريق سفيان- في قوله: <q>﴿والنّازِعاتِ غَرْقًا﴾</q>، قال: النفس حين تَغرق في الصدور{27}٧٠٠٨. (١٥/٢١٩) ٧٠٠٨ ذكر ابنُ عطية (٨/٥٢٥) قول السُّدِّيّ، وعلّق عليه، فقال: «وقال السُّدِّيّ وجماعة: النّازِعاتِ: النفوس تنزع بالموت إلى ربّها، وغَرْقًا هنا بمعنى الإغراق، أي: تغرق في الصدور». ٨١١٤٢- عن الربيع بن أنس، في قوله: <q>﴿والنّازِعاتِ غَرْقًا والنّاشِطاتِ نَشْطًا﴾</q>، قال: هاتان الآيتان للكفار عند نَزع النفس، تُنشَط نَشْطًا عنيفًا، مثل سَفُّود في صوف، فكان خروجه شديدًا{28}٧٠٠٩. (١٥/٢١٩) ٧٠٠٩ وجّه ابنُ القيم (٣/٢٤٩) هذا القول بقوله: «و<q>﴿غرقًا﴾</q> على هذا معناه: نزعًا شديدًا أبلغ ما يكون وأشدّه». ثم انتقده مستندًا إلى السياق، والدلالة العقلية، فقال: «وفي هذا القول ضعف من وجوه، أحدها: أنّ عطف ما بعده عليه يدل على أنها الملائكة فهي السابحات والمُدبِّرات والنازعات. الثاني: أنّ الإقسام بنفوس الكفار خاصة ليس بالبَيِّن، ولا في اللفظ ما يدل عليه. الثالث: أنّ النَّزع مشتركٌ بين نفوس بني آدم، والإغراق لا يختص بالكافر». ٨١١٤٣- قال مقاتل بن سليمان: <q>﴿والنّازِعاتِ غَرْقًا﴾</q> فهو مَلَك الموت وحده، يَنزع روح الكافر حتى إذا بلَغ ترقوته{29} غرقه في حَلْقه، فيعذّبه في حياته قبل أن يُميته، ثم يَنشطها مِن حَلْقه كما يُنشط السَّفُّود الكثير الشعث من الصوف، فينشط روح الكافر مِن قدمه إلى حَلْقه مثل الصوف المبلول، فذلك قوله: <q>﴿والنّاشِطاتِ نَشْطًا﴾</q>{30}٧٠١٠. (ز) ٧٠١٠ اختُلف في النازعات ما هي؟ وما تَنزع؟ على أقوال: الأول: أنها الملائكة تَنزع نفوسَ بني آدم. الثاني: أنه الموت يَنزع النفوس. الثالث: أنها النُّجوم تَنزع من أفق إلى أفق. الرابع: أنها القسي تُنزع بالسهم. الخامس: أنها النفس حين تُنزع. وقد ذكر ابنُ جرير (٢٤/٥٩) هذه الأقوال، ورجّح العموم فيها، فقال: «والصواب من القول في ذلك عندي أن يُقال: إنّ الله -تعالى ذِكْره- أقسم بالنازعات غرقًا، ولم يخصص نازعة دون نازعة، فكلّ نازعة غرقًا فداخلة في قَسمه؛ مَلَكًا كان، أو موتًا، أو نجمًا، أو قوسًا، أو غير ذلك. والمعنى: والنازعات إغراقًا، كما يغرق النازع في القوس». ورجّح ابنُ القيم (٣/٢٤٩-٢٥٠ بتصرف) -مستندًا إلى الدلالة العقلية- القول الأول، فقال: «قلتُ: النازعات اسم فاعل من نزع، ويقال: نزع كذا إذا اجتذبه بقوة، ونزع عنه إذا خلّاه وتركه بعد ملابسته له، ونزع إليه إذا ذهب إليه ومال إليه. وهذا إنما تُوصف به النفوس التي لها حركة إرادية للميل إلى الشيء أو الميل عنه، وأحقّ ما صدق عليه هذا الوصف الملائكة؛ لأنّ هذه القوة فيها أكمل، وموضع الآية فيها أعظم، فهي التي تُغرق في النزع إذا طلبتْ ما تنزعه، أو تنزع إليه، والنفس الإنسانية أيضًا لها هذه القوة». ووافقه ابنُ كثير (١٤/٢٣٨) بقوله: «والصحيح الأول، وعليه الأكثرون». ثم وجّه ابنُ القيم بقية الأقوال الواردة عن السلف، فقال: «والنُّجوم أيضًا تَنزع من أفق إلى أفق؛ فالنّزع حركة شديدة؛ سواء كانت من مَلَك، أو نفس إنسانية، أو نجم، والنفوس تَنزع إلى أوطانها وإلى مألفها، وعند الموت تَنزع إلى ربها المنايا تنزع النفوس، والقِسِيُّ تُنزع بالسهام، والملائكة تنزِع مِن مكان إلى مكان، وتَنزع ما وُكِلتْ بنَزعه، والخيل تَنزع في أعنّتها نزعًا تغرق فيه الأعنة لطول أعناقها. فالصفة واقعة على كلّ مَن له هذه الحركة التي هي آيةٌ مِن آيات الرّبّ تعالى؛ فإنه هو الذي خَلَقها، وخَلَق محلَّها، وخَلَق القوة والنفس التي بها تتحرك، ومن ذكر صورة من هذه الصور فإنما أراد التمثيل، وإن كانت الملائكة أحقَّ مَن تناوله هذا الوصف ... وهذا أولى الأقوال». ",footnotes:1:أخرجه أبو جعفر النحاس في الناسخ والمنسوخ ص٧٥٧ من طريق أبي عمرو بن العلاء عن مجاهد، والبيهقي في دلائل النبوة ٧/١٤٢-١٤٤ من طريق خُصَيف عن مجاهد. وعزاه السيوطي إلى ابن مردويه.عزاه السيوطي إلى ابن مردويه.أخرجه ابن الضريس في فضائل القرآن ١/٣٣-٣٥.أخرجه البيهقي في دلائل النبوة ٧/١٤٢-١٤٣.أخرجه الحارث المحاسبي في فهم القرآن ص٣٩٥-٣٩٦ من طريق سعيد، وأبو بكر ابن الأنباري -كما في الإتقان ١/٥٧- من طريق همام.تنزيل القرآن ص٣٧-٤٢.أخرجه أبو عبيد في فضائله (ت: الخياطي) ٢/٢٠٠.تفسير مقاتل بن سليمان ٤/٥٧١.أخرجه ابن جرير ٢٤/٥٧. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.عزاه السيوطي إلى سعيد بن منصور، وابن المنذر.أخرجه ابن أبي حاتم -كما في تفسير ابن كثير ٨/٣٣٥-.عزاه السيوطي إلى جويبر في تفسيره.أخرجه الحاكم ٢/٥١٣.أخرجه ابن جرير ٢٤/٥٨.أخرجه ابن جرير ٢٤/٥٧.أخرجه ابن جرير ٢٤/٥٧.أخرجه ابن جرير ٢٤/٥٨.أخرجه ابن جرير ٢٤/٥٨ بطرق متعددة، وأبو الشيخ في العظمة (٤٦٤). وعزاه السيوطي إلى عَبد بن حُمَيد.أخرجه أبو الشيخ (٤٩٤). وعزاه السيوطي إلى عَبد بن حُمَيد، وابن المنذر.تفسير الثعلبي ١٠/١٢٢، وتفسير البغوي ٨/٣٢٤.أخرجه آدم بن أبي إياس -كما في تفسير مجاهد ص٧٠١- من طريق قتادة، وعبد الرزاق ٢/٣٤٥ من طريق معمر، وابن جرير ٢٤/٥٨ من طريق أبي العوام. وذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٥/٨٨-.أخرجه ابن جرير ٢٤/٥٩. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.عزاه السيوطي إلى عبد بن حميد، وابن المنذر.عزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ٢٤/٥٨-٥٩.أخرجه عبد الرزاق ٢/٣٤٥.أخرجه ابن جرير ٢٤/٥٩. وعزاه السيوطي إلى ابن أبي حاتم.عزاه السيوطي إلى ابن أبي حاتم.الترقوة: العظم الذي بين ثغرة النحر والعاتق. النهاية (ترق).تفسير مقاتل بن سليمان ٤/٥٧٣.
79,2," <q>﴿وَٱلنَّـٰشِطَـٰتِ نَشۡطࣰا ۝٢﴾</q> - تفسير ٨١١٤٤- عن معاذ بن جبل، قال: قال لي رسول الله ﷺ: «لا تُمزِّق الناس فيُمزِّقك كلاب النار، قال الله: <q>﴿والنّاشِطاتِ نَشْطًا﴾</q> أتدري ما هو؟». قلت: يا نبي الله، ما هو؟ قال: «كلاب في النار، تَنشِط اللحم والعظم»{1}. (١٥/٢٢١) ٨١١٤٥- عن علي بن أبي طالب، في قوله: <q>﴿والنّاشِطاتِ نَشْطًا﴾</q>: هي الملائكة تَنْشِط أرواح الكفار ما بين الأظفار والجلد حتى تُخرجها{2}. (١٥/٢١٨) ٨١١٤٦- عن عبد الله بن عباس، <q>﴿والنّاشِطاتِ نَشْطًا﴾</q>، قال: الموت{3}. (١٥/٢١٩) ٨١١٤٧- عن عبد الله بن عباس: <q>﴿والنّاشِطاتِ نَشْطًا﴾</q> هي نفس المؤمن تَنشِط للخروج عند الموت؛ لِما يَرى مِن الكرامة{4}. (ز) ٨١١٤٨- عن عبد الله بن عباس -من طريق أبي صالح- <q>﴿والنّاشِطاتِ نَشْطًا﴾</q>، قال: حين تَنشِط نفْسَه{5}. (ز) ٨١١٤٩- عن عبد الله بن عباس -من طريق عطية- <q>﴿والنّاشِطاتِ نَشْطًا﴾</q>، قال: الملائكة{5}. (ز) ٨١١٥٠- عن مجاهد بن جبر -من طريق ابن أبي نجيح- <q>﴿والنّاشِطاتِ نَشْطًا﴾</q>، قال: الموت{7}. (١٥/٢٢٠) ٨١١٥١- عن مجاهد بن جبر، <q>﴿والنّاشِطاتِ نَشْطًا﴾</q>، قال: الملائكة{8}. (١٥/٢٢٠) ٨١١٥٢- قال عكرمة مولى ابن عباس: <q>﴿والنّاشِطاتِ نَشْطًا﴾</q> هي الأوهاق{9}. (ز) ٨١١٥٣- عن الحسن البصري -من طريق قتادة- في <q>﴿والنّاشِطاتِ نَشْطًا﴾</q>، قال: النُّجوم{10}. (ز) ٨١١٥٤- عن عطاء [بن أبي رباح] -من طريق واصل بن السّائِب- <q>﴿والنّاشِطاتِ نَشْطًا﴾</q>، قال: هي الأوهاق{11}٧٠١١. (١٥/٢٢١) ٧٠١١ ذكر ابنُ عطية (٨/٥٢٦) قول عطاء، ووجّهه بقوله: «تقول: نشَطْتُ البعيرَ والإنسانَ: إذا ربطته، وأنشطْتُه: إذا حللته، وحكاه الفراء، وخولف فيه، ومنه الحديث: «كأنما أنشط من عقال»». وذكر ابنُ عطية قولًا آخر عن عطاء، وعلّق عليه، فقال: "وقال عطاء: النّاشِطاتِ في الآية: البقرة الوحشية وما جرى مجراها مِن الحيوان الذي يَنشط من قطر إلى قطر، ومن هذا المعنى قول الشاعر: أمست همومي تَنشط المناشطا الشام بي طوْرًا وطوْرًا واسطا وكأن هذه اللفظة في هذا التأويل مأخوذة من النشاط". ٨١١٥٥- عن أبي صالح [باذام] <q>﴿والنّاشِطاتِ نَشْطًا﴾</q>، قال: الملائكة يَنشِطون نفس الإنسان{12}. (١٥/٢٢٠) ٨١١٥٦- عن قتادة بن دعامة -من طريق سعيد- <q>﴿والنّاشِطاتِ نَشْطًا﴾</q>، قال: هي النُّجوم{13}. (١٥/٢٢٠) ٨١١٥٧- عن قتادة بن دعامة -من طريق معمر- في قوله: <q>﴿والنّاشِطاتِ نَشْطًا﴾</q>، قال: هذه النفوس{14}. (ز) ٨١١٥٨- عن إسماعيل السُّدِّيّ -من طريق سفيان- في قوله: <q>﴿والنّاشِطاتِ نَشْطًا﴾</q>، قال: الملائكة حين تَنشِط الروح مِن الأصابع والقدمين{15}. (١٥/٢١٩) ٨١١٥٩- قال مقاتل بن سليمان: <q>﴿والنّاشِطاتِ نَشْطًا﴾</q> فهو مَلَك الموت، فيُخْرِج نفسَه مِن حَلْقه ومعها العروق؛ كالغريق من الماء{16}٧٠١٢. (ز) ٧٠١٢ اختُلف في قوله: <q>﴿والناشطات نشطا﴾</q> على أقوال: الأول: أنها الملائكة، تَنشِط نفس المؤمن فتَقبضها. الثاني: أنه الموت، يَنشِط النفوس فيَقبضها. الثالث: أنها النُّجوم، تَنشَط من أُفق لأُفق. الرابع: أنها الأوهاق. وقد ذكر ابنُ جرير (٢٤/٦١) هذه الأقوال، ورجّح العموم فيها، فقال: «والصواب من القول في ذلك عندي أن يُقال: إنّ الله -جلّ ثناؤه- أقسم بالناشطات نشطًا، وهي التي تَنشَط مِن موضع إلى موضع، فتَذهب إليه، ولم يخصص الله بذلك شيئًا دون شيء، بل عمّ القَسم بجميع الناشطات، والملائكة تَنشط من موضع إلى موضع، وكذلك الموت، وكذلك النُّجوم والأوهاق وبقر الوحش أيضًا تَنشط، والهموم تَنشِط صاحبها، فكلّ ناشطٍ فداخل فيما أقسم به، إلا أن تقوم حُجّة يجب التسليم لها بأن المعنيّ بالقَسم من ذلك بعضٌ دون بعض». ",footnotes:1:أخرجه ابن الجوزي في الموضوعات ٣/١٥٤-١٥٦، ١٥٧-١٦١ مطولًا. وقال ابن الجوزي: «موضوع». وقال المنذري في الترغيب والترهيب ١/٣٨-٤٠ (٥٩): «وبالجملة فآثار الوضع ظاهرة عليه في جميع طرقه وبجميع ألفاظه». وقال السيوطي في اللآلئ المصنوعة ٢/٢٨٤: «موضوع».عزاه السيوطي إلى سعيد بن منصور، وابن المنذر.عزاه السيوطي إلى ابن أبي حاتم.تفسير الثعلبي ١٠/١٢٣، وتفسير البغوي ٨/٣٢٤ واللفظ له. وقال عقبه: لأنه تُعرض عليه الجنة قبل أن يموت.أخرجه ابن جرير ٢٤/٦٠.أخرجه ابن جرير ٢٤/٦٠.أخرجه ابن جرير ٢٤/٦٠ بطرق متعددة، وأبو الشيخ في العظمة (٤٦٤). وعزاه السيوطي إلى عَبد بن حُمَيد.عزاه السيوطي إلى عَبد بن حُمَيد، وابن المنذر، وأبي الشيخ.تفسير الثعلبي ١٠/١٢٣، وتفسير البغوي ٨/٣٢٤. والأوهاق: جمع وهَق، وهو حبل تُشدّ به الإبل والخيل لئلا تندّ. النهاية (وهق).أخرجه آدم بن أبي إياس -كما في تفسير مجاهد ص٧٠١-. وذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٥/٨٨-.أخرجه ابن جرير ٢٤/٦١. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.عزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه ابن جرير ٢٤/٦١، ومن طريق معمر أيضًا. وعزاه السيوطي إلى عبد بن حميد.أخرجه عبد الرزاق ٢/٣٤٥.أخرجه ابن جرير ٢٤/٦٠-٦١. وعزاه السيوطي إلى ابن أبي حاتم.تفسير مقاتل بن سليمان ٤/٥٧٣.
79,3," <q>﴿وَٱلسَّـٰبِحَـٰتِ سَبۡحࣰا ۝٣﴾</q> - تفسير ٨١١٦٠- عن عبد الله بن مسعود، في قوله:<q>﴿والسّابِحاتِ سَبْحًا﴾</q>، قال: الملائكة{1}. (١٥/٢٢٠) ٨١١٦١- عن علي بن أبي طالب، في قوله: <q>﴿والسّابِحاتِ سَبْحًا﴾</q>: هي الملائكة تَسْبح بأرواح المؤمنين بين السماء والأرض{2}. (١٥/٢١٨) ٨١١٦٢- عن عبد الله بن عباس، في قوله: <q>﴿والسّابِحاتِ سَبْحًا﴾</q>: أرواح المؤمنين لَمّا عاينتْ مَلَك الموت، قال: اخرجي -أيتها النفس الطّيّبة- إلى رَوح وريحان، وربّ غير غضبان. سَبَحتْ سِباحة الغائص في الماء فرحًا وشوقًا إلى الجنة{3}. (١٥/٢١٩) ٨١١٦٣- عن مجاهد بن جبر -من طريق ابن أبي نجيح- <q>﴿والسّابِحاتِ سَبْحًا﴾</q>، قال: الملائكة{4}٧٠١٣. (١٥/٢٢٠) ٧٠١٣ ذكر ابن جرير (٢٤/٦٣) أثر مجاهد من طريق ابن حميد، ثم قال معلّقًا: «فإن يكن ما ذكرنا عن ابن حميد صحيحًا فإنّ مجاهدًا كان يرى أنّ نزول الملائكة من السماء سِباحة، كما يقال للفرس الجواد: إنه لسابح؛ إذا مرّ يُسرع». ٨١١٦٤- عن مجاهد بن جبر -من طريق ابن أبي نجيح- <q>﴿والسّابِحاتِ سَبْحًا﴾</q>، قال: الموت{5}. (ز) ٨١١٦٥- عن الحسن البصري -من طريق قتادة- <q>﴿والسّابِحاتِ سَبْحًا﴾</q>، قال: هذه النُّجوم كلّها{6}. (١٥/٢٢١) ٨١١٦٦- عن عطاء [بن أبي رباح] -من طريق واصل بن السّائِب- <q>﴿والسّابِحاتِ سَبْحًا﴾</q>، قال: السُّفُن{7}. (ز) ٨١١٦٧- عن أبي صالح [باذام]، <q>﴿والسّابِحاتِ سَبْحًا﴾</q>، قال: الملائكة حين يَنزِلون من السماء إلى الأرض{8}. (١٥/٢٢٠) ٨١١٦٨- عن قتادة بن دعامة -من طريق سعيد- <q>﴿والسّابِحاتِ سَبْحًا﴾</q>، قال: هي النُّجوم{9}. (١٥/٢٢٠) ٨١١٦٩- عن إسماعيل السُّدِّيّ، في قوله: <q>﴿والسّابِحاتِ سَبْحًا﴾</q>: حين تَسْبح النفسُ في الجوف تَتردّد عند الموت{10}. (١٥/٢١٩) ٨١١٧٠- عن الربيع بن أنس، في قوله: <q>﴿والسّابِحاتِ سَبْحًا فالسّابِقاتِ سَبْقًا﴾</q>، قال: هاتان للمؤمنين{10}. (١٥/٢١٩) ٨١١٧١- قال محمد بن السّائِب الكلبي: هم الملائكة يَقبضون أرواح المؤمنين، كالذي يَسْبح في الماء؛ فأحيانًا ينغمس، وأحيانًا يرتفع، يسُلُّونه سلًّا رفيقًا، ثم يَدَعُونها حتى يستريح{12}. (ز) ٨١١٧٢- قال مقاتل بن سليمان: وأمّا قوله: <q>﴿والسّابِحاتِ سَبْحًا﴾</q> وهو مَلَك الموت وحده، وهي روح المؤمن، ولكن قال في التقديم: <q>﴿فالسّابِقاتِ سَبْقًا﴾</q> ثم <q>﴿السّابِحاتِ سَبْحًا﴾</q> تَقبض روح المؤمن كالسابح في الماء لا يهوله الماء. يقول: تَستبق الملائكةُ أرواحَهم في حريرة بيضاء من حرير الجنة، يَسبقون بها ملائكة الرحمة، ووجوههم مثل الشمس، عليهم تاج مِن نور ضاحكين مُستبشِرين طيِّبين، فذلك قوله: <q>﴿تَتَوَفّاهُمُ المَلائِكَةُ طَيِّبِينَ﴾</q> [النحل:٣٢]، قال: <q>﴿والسّابِحاتِ سَبْحًا﴾</q> يقول: تَسْبح الملائكة في السموات، لا تحجب روحه في السماء حتى يَبلغ به المَلَك عند سِدْرة المُنتهى، عندها مأوى أرواح المؤمنين{13}٧٠١٤. (ز) ٧٠١٤ اختُلف في قوله: <q>﴿والسابحات سبحا﴾</q> على أقوال: الأول: الملائكة. الثاني: النُّجوم. الثالث: الموت. الرابع: أرواح المؤمنين. الخامس: السُّفن. وقد رجّح ابنُ جرير (٢٤/٦٣) العموم، فقال: «والصواب من القول في ذلك عندي أن يُقال: إنّ الله -جلّ ثناؤه- أقسم بالسّابحات سبحًا من خَلْقه، ولم يخصص من ذلك بعضًا دون بعض، فذلك كلّ سابح؛ لما وصفنا قبل في النازعات». وزاد ابنُ عطية (٨/٥٢٦) في معنى الآية عدة أقوال، فقال: «وقال أبو رَوق: السابحات: الشمس والقمر والليل والنهار. وقال بعض المتأولين: السابحات: السحاب؛ لأنها كالعائمة في الهواء. وقال عطاء وجماعة: السابحات: الخيل، ويقال للفرس: سابح. وقال آخرون: السابحات: الحيتان دواب البحر فما دونها، وذلك من عظيم المخلوقات، فرُوي أنّ الله تعالى بثّ في الدنيا ألف نوع من الحيوان؛ منها أربعمائة في البر، وستمائة في البحر». ",footnotes:1:عزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.عزاه السيوطي إلى سعيد بن منصور، وابن المنذر.عزاه السيوطي إلى جويبر في تفسيره.أخرجه ابن جرير ٢٤/٦٢ من طريق مهران عن سفيان به، وأبو الشيخ (٤٩٤). وعزاه السيوطي إلى عَبد بن حُمَيد، وابن المنذر.أخرجه ابن جرير ٢٤/٦٢ من طريق وكيع، عن سفيان به، وقال عقبه: «هكذا وجدته في كتابي».أخرجه آدم بن أبي إياس -كما في تفسير مجاهد ص٧٠١-. وعزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ٢٤/٦٣.عزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه ابن جرير ٢٤/٦٣، وكذلك من طريق معمر. وعزاه السيوطي إلى عبد بن حميد.عزاه السيوطي إلى ابن أبي حاتم.عزاه السيوطي إلى ابن أبي حاتم.تفسير الثعلبي ١٠/١٢٣.تفسير مقاتل بن سليمان ٤/٥٧٣-٥٧٤.
79,4," <q>﴿فَٱلسَّـٰبِقَـٰتِ سَبۡقࣰا ۝٤﴾</q> - تفسير ٨١١٧٣- قال عبد الله بن مسعود: <q>﴿فالسّابِقاتِ سَبْقًا﴾</q> هي أنفس المؤمنين تَسبق إلى الملائكة الذين يَقبضونها شوقًا إلى لقاء الله ورحمته وكرامته، وقد عاينت السرور{1}. (ز) ٨١١٧٤- عن علي بن أبي طالب، في قوله: <q>﴿فالسّابِقاتِ سَبْقًا﴾</q>: هي الملائكة يَسبق بعضها بعضًا بأرواح المؤمنين إلى الله{2}. (١٥/٢١٨) ٨١١٧٥- عن عبد الله بن عباس، في قوله: <q>﴿فالسّابِقاتِ سَبْقًا﴾</q>: يعني: تمشي إلى كرامة الله{3}. (١٥/٢١٩) ٨١١٧٦- عن مجاهد بن جبر -من طريق ابن أبي نجيح- <q>﴿فالسّابِقاتِ سَبْقًا﴾</q>، قال: الموت{4}. (ز) ٨١١٧٧- عن مجاهد بن جبر -من طريق ابن أبي نجيح- <q>﴿فالسّابِقاتِ سَبْقًا﴾</q>، قال: الملائكة{5}. (١٥/٢٢٠) ٨١١٧٨- قال الحسن البصري: <q>﴿فالسّابِقاتِ سَبْقًا﴾</q> هي الملائكة سبقوا إلى طاعة الله{6}. (ز) ٨١١٧٩- عن عطاء [بن أبي رباح] -من طريق واصل بن السّائِب- <q>﴿فالسّابِقاتِ سَبْقًا﴾</q>، قال: هي الخيل{7}. (١٥/٢٢١) ٨١١٨٠- عن أبي صالح [باذام]، <q>﴿فالسّابِقاتِ سَبْقًا﴾</q>، قال: الملائكة{8}. (١٥/٢٢٠) ٨١١٨١- عن قتادة بن دعامة -من طريق سعيد- <q>﴿فالسّابِقاتِ سَبْقًا﴾</q>، قال: هي النُّجوم{9}. (١٥/٢٢٠) ٨١١٨٢- عن الربيع بن أنس، في قوله: <q>﴿والسّابِحاتِ سَبْحًا فالسّابِقاتِ سَبْقًا﴾</q>، قال: هاتان للمؤمنين{10}. (١٥/٢١٩) ٨١١٨٣- قال أبو رَوق عطية بن الحارث الهَمداني: سبقت ابن آدم بالخير والعمل الصالح{11}. (ز) ٨١١٨٤- قال مقاتل بن سليمان: فأمّا الكافر فإنه أول ما يُنزِل المَلَك الروح من جسده، فتَستبق ملائكة الغضب وجوههم مثل الجَمْر، وأعينهم مثل البْرق، غضاب، حرّهم أشد من حرّ النار، فتُوضع روحه على جمرٍ مثل الكبريت، فيَضعون روحه عليه، وتُقلب روحه عليه، مثل السمك على الطابق، ولا تُفتح له أبواب السماء، فيَهبط به المَلَك حتى يضعه في سِجِّين، وهي الأرض السُّفلى تحت خدّ إبليس. هذا معنى: <q>﴿فالسّابِقاتِ سَبْقًا﴾</q>{12}٧٠١٥. (ز) ٧٠١٥ اختُلف في قوله: <q>﴿فالسابقات سبقا﴾</q> على أقوال: الأول: الملائكة. الثاني: الموت. الثالث: النُّجوم. الرابع: أنفس المؤمنين. الخامس: الخيل. وقد رجّح ابنُ جرير (٢٤/٦٤) صوابَ جميعها مستندًا لأقوال السلف، والعموم. وزاد ابن عطية (٨/٥٢٦) قولا أنها الرِّياح. ",footnotes:1:تفسير الثعلبي ١٠/١٢٤، وتفسير البغوي ٨/٣٢٥.عزاه السيوطي إلى سعيد بن منصور، وابن المنذر.عزاه السيوطي إلى جُويبر في تفسيره.أخرجه ابن جرير ٢٤/٦٤.أخرجه ابن جرير ٢٤/٦٤، وأبو الشيخ (٤٩٤). وعزاه السيوطي إلى عَبد بن حُمَيد، وابن المنذر.ذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٥/٨٨-.أخرجه ابن جرير ٢٤/٦٤. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.عزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه ابن جرير ٢٤/٦٤، ومن طريق معمر أيضًا. وعزاه السيوطي إلى عبد بن حميد.عزاه السيوطي إلى ابن أبي حاتم.تفسير الثعلبي ١٠/١٢٤.تفسير مقاتل بن سليمان ٤/٥٧٣-٥٧٤.
79,5," <q>﴿فَٱلۡمُدَبِّرَ ٰ⁠تِ أَمۡرࣰا ۝٥﴾</q> - تفسير ٨١١٨٥- عن علي بن أبي طالب، في قوله: <q>﴿فالمُدَبِّراتِ أمْرًا﴾</q>، قال: هي الملائكة تُدبِّر أمرَ العباد من السنة إلى السنة{1}. (١٥/٢١٨) ٨١١٨٦- عن علي بن أبي طالب -من طريق عبيد الله- أنّ ابن الكَوّاء سأله عن: <q>﴿فالمُدَبِّراتِ أمْرًا﴾</q>. قال: هي الملائكة يُدبِّرون ذِكر الرحمن وأَمْره{2}. (١٥/٢٢١) ٨١١٨٧- قال عبد الله بن عباس: <q>﴿فالمُدَبِّراتِ أمْرًا﴾</q> هم الملائكة وُكِّلوا بأمور عرّفهم الله ﷿ العمل بها{3}. (ز) ٨١١٨٨- عن عبد الله بن عباس -من طريق أبي المتوكل النّاجي- في قوله: <q>﴿فالمُدَبِّراتِ أمْرًا﴾</q>، قال: ملائكة يكونون مع مَلَك الموت، يَحضُرون الموتى عند قَبْض أرواحهم؛ فمنهم مَن يَعرج بالروح، ومنهم مَن يُؤمِّن على الدعاء، ومنهم مَن يَستغفر للميت حتى يُصَلّى عليه ويُدلى في حُفرته{4}. (١٥/٢٢٢) ٨١١٨٩- عن مجاهد بن جبر-من طريق ابن أبي نجيح-، <q>﴿فالمُدَبِّراتِ أمْرًا﴾</q>، قال: الملائكة{5}. (١٥/٢٢٠) ٨١١٩٠- عن أبي صالح [باذام]، <q>﴿فالمُدَبِّراتِ أمْرًا﴾</q>، قال: الملائكة يُدبِّرون ما أُمِرُوا به{6}. (١٥/٢٢٠) ٨١١٩١- عن قتادة بن دعامة -من طريق معمر- <q>﴿فالمُدَبِّراتِ أمْرًا﴾</q>، قال: هي الملائكة{7}. (١٥/٢٢٠) ٨١١٩٢- قال مقاتل بن سليمان: وأما قوله تعالى: <q>﴿فالمُدَبِّراتِ أمْرًا﴾</q> فهم الملائكة، منهم الخُزّان الذين يكونون مع الرياح، ومع المطر، ومع الكواكب، ومع الشمس والقمر، ومع الإنس والجن، فكذلك هم. ويقال: جبريل، وميكائيل، ومَلَك الموت ﵈ الذين يُدبِّرون أمْر الله تعالى في عباده، وبلاده، وبأمْره{8}٧٠١٦. (ز) ٧٠١٦ قال ابنُ عطية (٨/٥٢٧) مستندًا إلى الإجماع: «وأمّا <q>﴿المدبرات﴾</q> فلا أحفظ خلافًا أنها الملائكة، ومعناها: أنها تُدبِّر الأمور التي يُسخِّرها الله تعالى وصَرّفها فيها كالرياح والسحاب وسائر المخلوقات». وبنحوه قال ابنُ تيمية (٦/٤٥٧). <q>﴿فَٱلۡمُدَبِّرَ ٰ⁠تِ أَمۡرࣰا ۝٥﴾</q> - آثار متعلقة بالآية ٨١١٩٣- عن عبد الرحمن بن عبد الله بن سابط الجُمحي -من طريق عمرو بن مُرّة- قال: يُدبِّر أمْرَ الدنيا أربعة: جبريل، وميكائيل، ومَلَك الموت، وإسرافيل؛ فأمّا جبريل فموكّل بالرياح والجنود، وأما ميكائيل فموكّل بالقَطْر والنبات، وأمّا مَلَك الموت فموكّل بقَبْض الأرواح، وأمّا إسرافيل فهو يَنزل عليهم بالأمر{9}. (١٥/٢٢٢) ",footnotes:1:عزاه السيوطي إلى سعيد بن منصور، وابن المنذر. وزاد ابنُ عطية (٨/٥٢٦) قولًا أنها الرِّياح.أخرجه عبد الله بن وهب في الجامع -تفسير القرآن ١/١٠٧ (٢٤٤). وعزاه السيوطي إلى ابن أبي حاتم.تفسير البغوي ٨/٣٢٥.عزاه السيوطي إلى ابن أبي الدنيا في ذكر الموت.أخرجه أبو الشيخ (٤٩٤). وعزاه السيوطي إلى عَبد بن حُمَيد، وابن المنذر.عزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه عبد الرزاق ٢/٣٤٥، وابن جرير ٢٤/٦٥، ومن طريق سعيد أيضًا. وعزاه السيوطي إلى عبد بن حميد.تفسير مقاتل بن سليمان ٤/٥٧٤.أخرجه البيهقي في شعب الإيمان (١٥٨). وعزاه السيوطي إلى عَبد بن حُمَيد، وابن المنذر، وابن أبي حاتم.
79,6," <q>﴿یَوۡمَ تَرۡجُفُ ٱلرَّاجِفَةُ ۝٦ تَتۡبَعُهَا ٱلرَّادِفَةُ ۝٧﴾</q> - تفسير ٨١١٩٤- عن أُبيّ بن كعب، قال: كان رسول الله ﷺ إذا ذهب رُبع الليل قام، فقال: «يا أيها الناس، اذكروا الله، اذكروا الله، جاءت الرّاجفة تَتْبعها الرادفة، جاء الموت بما فيه»{1}. (١٥/٢٢٣) ٨١١٩٥- عن أبي هريرة، قال: قال رسول الله ﷺ: وذكر الصُّور، فقال أبو هريرة: يا رسول الله، وما الصُّور؟ قال: «قَرْنٌ». قال: فكيف هو؟ قال: «قَرْنٌ عظيم، يُنفخ فيه ثلاث نفخات: الأولى نَفْخة الفَزَع، والثانية نَفْخة الصَّعق، والثالثة نَفْخة القيام، فيَفزع أهل السماوات والأرض إلا مَن شاء الله، ويأمر الله فيُديمها، ويُطوّلها، ولا يَفتُر، وهي التي يقول: <q>﴿ما ينظر هؤلاء إلا صيحة واحدة ما لها من فواق﴾</q> [ص:١٥]، فيُسيّر الله الجبال، فتكون سرابًا، وتُرجّ الأرض بأهلها رجًّا، وهي التي يقول: <q>﴿يوْمَ تَرْجُفُ الرّاجِفَةُ تَتْبَعُها الرّادِفَةُ قُلُوبٌ يَوْمَئِذٍ واجِفَةٌ﴾</q>»{2}. (ز) ٨١١٩٦- عن أبي هريرة، قال: قال رسول الله ﷺ: «تَرجف الأرض رجفًا، وتُزلزل بأهلها، وهي التي يقول الله: <q>﴿يَوْمَ تَرْجُفُ الرّاجِفَةُ تَتْبَعُها الرّادِفَةُ﴾</q>. يقول: مثل السّفينة في البحر تَكَفّأ بأهلها، مثل القنديل المُعلّق بأرجائه»{3}. (١٥/٢٢٣) ٨١١٩٧- عن عبد الله بن عباس -من طريق علي- في قوله: <q>﴿يَوْمَ تَرْجُفُ الرّاجِفَةُ﴾</q> قال: النَّفخة الأولى، <q>﴿تَتْبَعُها الرّادِفَةُ﴾</q> قال: النفخة الثانية{4}. (١٥/٢٢٢) ٨١١٩٨- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿يَوْمَ تَرْجُفُ الرّاجِفَةُ﴾</q> قال: تَرجف الأرض والجبال، وهي الزلزلة، <q>﴿تَتْبَعُها الرّادِفَةُ﴾</q> قال: دُكّتا دكّة واحدة{5}. (١٥/٢٢٢) ٨١١٩٩- عن الضَّحّاك بن مُزاحِم -من طريق عبيد- يقول في قوله: <q>﴿يَوْمَ تَرْجُفُ الرّاجِفَةُ﴾</q> النَّفخة الأولى، <q>﴿تَتْبَعُها الرّادِفَةُ﴾</q> النَّفخة الأخرى{6}. (ز) ٨١٢٠٠- عن الحسن البصري -من طريق أبي رجاء- أنه سُئل عن قول الله: <q>﴿يَوْمَ تَرْجُفُ الرّاجِفَةُ تَتْبَعُها الرّادِفَةُ﴾</q>. قال: هما النَّفختان؛ أمّا الأولى فتُميت الأحياء، وأمّا الثانية فتُحيي الموتى. ثم تلا هذه الآية: <q>﴿ونُفِخَ فِي الصُّورِ فَصَعِقَ مَن فِي السَّماواتِ ومَن فِي الأَرْضِ إلّا مَن شاءَ اللَّهُ ثُمَّ نُفِخَ فِيهِ أُخْرى فَإذا هُمْ قِيامٌ يَنْظُرُونَ﴾</q> [الزمر:٦٨]{7}. (١٥/٢٢٤) ٨١٢٠١- قال عطاء: <q>﴿الرّاجِفَةُ﴾</q> القيامة، و<q>﴿الرّادِفَةُ﴾</q> البعث{8}. (ز) ٨١٢٠٢- عن قتادة بن دعامة -من طريق سعيد- <q>﴿يَوْمَ تَرْجُفُ الرّاجِفَةُ تَتْبَعُها الرّادِفَةُ﴾</q>، قال: هما الصَّيحتان؛ أمّا الأولى فتُميت كلَّ شيء بإذن الله، وأمّا الأخرى فتُحيي كلَّ شيء بإذن الله{9}. (١٥/٢٢٣) ٨١٢٠٣- عن أبي صالح [باذام]، <q>﴿يَوْمَ تَرْجُفُ الرّاجِفَةُ﴾</q> قال: النَّفخة الأولى، <q>﴿تَتْبَعُها الرّادِفَةُ﴾</q> قال: النَّفخة الثانية{10}. (١٥/٢٢٣) ٨١٢٠٤- قال مقاتل بن سليمان: وأما قوله تعالى: <q>﴿يَوْمَ تَرْجُفُ الرّاجِفَةُ﴾</q> وهي النَّفخة الأولى، وإنما سُمِّيت الراجفة لأنها تُميت الخَلْق كلّهم، كقوله: <q>﴿فَأَخَذَتْهُمُ الرَّجْفَةُ﴾</q> [الأعراف:٧٨] يعني: الموت، من فوق سبع سموات مِن عند العرش، فيموت الخَلْق كلّهم، <q>﴿تَتْبَعُها الرّادِفَةُ﴾</q> وهي النَّفخة الثانية، أردَفت النَّفخة الأولى، بينهما أربعون سنة، أسمعت الخلائق، وهي عند صخرة بيت المقدس، وذلك أنه ينزل إسرافيل، وترتفع أرواح الكفار مِن تحت الأرض السُّفلى إلى وادٍ يُقال له: بَرَهُوت، وهو بحضرموت، وهو كأشرّ وادٍ في الأرض، وتَنزل أرواح المؤمنين مِن فوق سبع سموات إلى وادٍ يُقال له: الجابية، وهو بالشام، وهو خير وادٍ في الأرض، فيأخذ هؤلاء وهؤلاء جميعها إسرافيل، فيَجعلهم في القَرْن، وهو الصُّور، فيَنفخ فيه، فيقول: أيّتها العظام البالية، وأيّتها العروق المنقطعة، وأيّتها اللحوم المُتمزِّقة، اخرجوا من قبوركم؛ لتُجازوا بأعمالكم{11}. (ز) ٨١٢٠٥- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿يَوْمَ تَرْجُفُ الرّاجِفَةُ﴾</q>: الأرض، وفي قوله: <q>﴿تَتْبَعُها الرّادِفَةُ﴾</q> قال: الرادفة: الساعة{12}٧٠١٧. (ز) ٧٠١٧ قال ابنُ جرير (٢٤/٦٥): «وقوله: <q>﴿يوم ترجف الراجفة﴾</q> يقول -تعالى ذِكره-: <q>﴿يوم ترجف الأرض والجبال﴾</q> [المزمل:١٤] للنَّفخة الأولى، <q>﴿تتبعها الرادفة﴾</q> تتبعها أخرى بعدها، وهي النَّفخة الثانية التي ردفت الأولى، لبعْث يوم القيامة». وذكر أقوال السلف على هذا، ثم ذكر أثر مجاهد، وقول مَن قال: الراجفة: الأرض، والرادفة: الساعة. ولم يعلّق عليهما. ",footnotes:1:أخرجه أحمد ٣٥/١٦٥-١٦٦ (٢١٢٤١) مختصرًا، والترمذي ٤/٤٤٨-٤٤٩ (٢٦٢٥)، والحاكم ٢/٤٥٧ (٣٥٧٨)، ٢/٥٥٨ (٣٨٩٤)، وابن جرير ٢٤/٦٧، والثعلبي ١٠/١٢٤. قال الترمذي: «هذا حديث حسن». وقال الحاكم: «هذا حديث صحيح الإسناد، ولم يخرجاه». ووافقه الذهبي في التلخيص. وقال الألباني في الصحيحة ٥/٤٤٣: «حسن».أخرجه ابن أبي الدنيا في كتاب الأهوال ص٣٩-٤٥ (٥٥)، والطبراني في الأحاديث الطوال ص٢٦٦-٢٦٨ (٣٦) كلاهما مطولًا، وابن جرير ١٥/٤١٩، ١٦/٤٤٧-٤٤٩، ١٨/١٣٢-١٣٣، ٤٥١-٤٥٣، ٢٠/٣٣-٣٤، ٢٥٦-٢٥٨، ٢٤/٦٦-٦٧ بعضها مختصرًا وبعضها مطولًا، والثعلبي ٧/٢٢٧. وقال ابن كثير في تفسيره ٣/٢٨٧ عن رواية الطبراني: «هذا حديث مشهور، وهو غريب جدًّا». وقال في البداية والنهاية ١٩/٣٢٢-٣٢٣: «هذا حديث مشهور، رواه جماعة من الأئمة في كتبهم ... من طرق متعددة، عن إسماعيل بن رافع قاص أهل المدينة، وقد تكلم فيه بسببه، وفي بعض سياقاته نكارة واختلاف ... وإسماعيل بن رافع المديني ليس من الوضاعين، وكأنه جمع هذا الحديث مِن طرق وأماكن متفرقة، وساقه سياقة واحدة، فكان يقص به على أهل المدينة. وقال الحافظ أبو موسى المديني بعد إيراده له بتمامه: وهذا الحديث وإن كان في إسناده مَن تكلَّم فيه، فعامة ما فيه يروى مفرقًا بأسانيد ثابتة». وقال ابن حجر في الفتح ١١/٣٦٩: «أخرجه الطبري ... مختصرًا، وقد ذكرتُ أنّ سنده ضعيف ومضطرب».أخرجه أبو الشيخ في العظمة ٣/٨٢١-٨٣٩ (٣٨٦، ٣٨٧، ٣٨٨)، والطبراني في الأحاديث الطوال ص٢٦٦-٢٦٨ (٣٦) كلاهما مطولًا، وابن جرير ١٦/٤٤٧-٤٤٩، ١٨/١٣٢-١٣٣، ٢٠/٣١٧-٣١٨، والثعلبي ٧/٢٢٧. قال ابن كثير في تفسيره ٣/٢٨٧ عن رواية الطبراني: «هذا حديث مشهور، وهو غريب جدًّا».أخرجه ابن جرير ٢٤/٦٥، ومن طريق عطية بنحوه، وابن أبي حاتم -كما في تغليق التعليق ٥/١٨٠-. وعزاه السيوطي إلى ابن المنذر.تفسير مجاهد ص٧٠١، وأخرجه عبد بن حميد -كما في فتح الباري ٨/٦٩٠-، وابن جرير ٢٤/٦٧. وعزاه السيوطي إلى البيهقي في البعث.أخرجه ابن جرير ٢٤/٦٧.أخرجه ابن جرير ٢٤/٦٥-٦٦. وعزاه السيوطي إلى عَبد بن حُمَيد.تفسير الثعلبي ١٠/١٢٤، وتفسير البغوي ٨/٣٢٦.أخرجه ابن جرير ٢٤/٦٦. وعزاه السيوطي إلى عَبد بن حُمَيد.عزاه السيوطي إلى عَبد بن حُمَيد.تفسير مقاتل بن سليمان ٤/٥٧٤-٥٧٥.أخرجه ابن جرير ٢٤/٦٨.
  79,7,""
79,8," <q>﴿قُلُوبࣱ یَوۡمَىِٕذࣲ وَاجِفَةٌ ۝٨﴾</q> - تفسير ٨١٢٠٦- عن عبد الله بن عباس، في قوله: <q>﴿قُلُوبٌ يَوْمَئِذٍ واجِفَةٌ﴾</q>، قال: وجِلَة مُتحرّكة{1}. (١٥/٢٢٤) ٨١٢٠٧- عن عبد الله بن عباس -من طريق علي- في قوله: <q>﴿قُلُوبٌ يَوْمَئِذٍ واجِفَةٌ﴾</q>، قال: خائفة{2}. (١٥/٢٢٢) ٨١٢٠٨- عن مجاهد بن جبر، في قوله: <q>﴿قُلُوبٌ يَوْمَئِذٍ واجِفَةٌ﴾</q>، قال: وجِلَة{3}. (١٥/٢٢٤) ٨١٢٠٩- عن قتادة بن دعامة -من طريق معمر- <q>﴿قُلُوبٌ يَوْمَئِذٍ واجِفَةٌ﴾</q>، قال: خائفة{4}. (١٥/٢٢٤) ٨١٢١٠- عن قتادة بن دعامة -من طريق سعيد- <q>﴿قُلُوبٌ يَوْمَئِذٍ واجِفَةٌ﴾</q>، قال: وجَفَتْ مما عاينتْ يومئذ{5}. (١٥/٢٢٤) ٨١٢١١- قال إسماعيل السُّدِّيّ: <q>﴿قُلُوبٌ يَوْمَئِذٍ واجِفَةٌ﴾</q> زائلة عن أماكنها{6}. (ز) ٨١٢١٢- عن عطاء الخُراسانيّ -من طريق يونس بن يزيد- في قوله ﷿: <q>﴿قلوب يومئذ واجفة﴾</q>، يُقال: وجِلَة مُتحرِّكة{7}. (ز) ٨١٢١٣- قال مقاتل بن سليمان: ثم قال: <q>﴿قُلُوبٌ يَوْمَئِذٍ واجِفَةٌ﴾</q> يعني: خائفة{8}. (ز) ٨١٢١٤- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿قُلُوبٌ يَوْمَئِذٍ واجِفَةٌ﴾</q>، قال: الواجفة: الخائفة{9}٧٠١٨. (ز) ٧٠١٨ لم يذكر ابنُ جرير (٢٤/٦٨-٦٩) غير قول عبد الرحمن، وقول قتادة، وابن عباس من طريق علي. ",footnotes:1:عزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ٢٤/٦٨-٦٩، ومن طريق عطية أيضًا، وابن أبي حاتم -كما في تغليق التعليق ٥/١٨٠-. وعزاه السيوطي إلى ابن المنذر.عزاه السيوطي إلى عَبد بن حُمَيد، وابن المنذر.أخرجه عبد الرزاق ٢/٣٤٥، وابن جرير ٢٤/٦٩. وعزاه السيوطي إلى عَبد بن حُمَيد.أخرجه ابن جرير ٢٤/٦٩ بنحوه. وعزاه السيوطي إلى عَبد بن حُمَيد، وابن المنذر.تفسير الثعلبي ١٠/١٢٤.أخرجه أبو جعفر الرملي في جزئه (تفسير عطاء) ص٩٩.تفسير مقاتل بن سليمان ٤/٥٧٥.أخرجه ابن جرير ٢٤/٦٩.
79,9," <q>﴿أَبۡصَـٰرُهَا خَـٰشِعَةࣱ ۝٩﴾</q> - تفسير ٨١٢١٥- عن قتادة بن دعامة -من طريق معمر- في قوله: <q>﴿أبْصارُها خاشِعَةٌ﴾</q>، قال: ذليلة{1}. (١٥/٢٢٤) ٨١٢١٦- قال مقاتل بن سليمان: <q>﴿أبْصارُها خاشِعَةٌ﴾</q> يعني: ذليلة مما رأتْ عند مُعاينة النار، فخَضعتْ، كقوله: <q>﴿خاشِعِينَ مِنَ الذُّلِّ﴾</q> [الشورى:٤٥] مما تَرى من العجائب، ومما تَرى من أمر الآخرة{2}. (ز) ٨١٢١٧- قال عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- <q>﴿أبْصارُها خاشِعَةٌ﴾</q>، قال: خاشعة للذّل الذي قد نَزل بها{3}. (ز) ",footnotes:1:أخرجه عبد الرزاق ٢/٣٤٥، وابن جرير ٢٤/٦٩ من طريق سعيد. وعزاه السيوطي إلى عَبد بن حُمَيد، وابن المنذر.تفسير مقاتل بن سليمان ٤/٥٧٥.أخرجه ابن جرير ٢٤/٦٩.
79,10," <q>﴿یَقُولُونَ أَءِنَّا لَمَرۡدُودُونَ فِی ٱلۡحَافِرَةِ ۝١٠﴾</q> - تفسير ٨١٢١٨- عن عبد الله بن عباس -من طريق علي- في قوله: <q>﴿أإنّا لَمَرْدُودُونَ فِي الحافِرَةِ﴾</q>، قال: الحياة{1}. (١٥/٢٢٢) ٨١٢١٩- عن عبد الله بن عباس، <q>﴿أإنّا لَمَرْدُودُونَ فِي الحافِرَةِ﴾</q>، قال: خَلْقًا جديدًا{2}. (١٥/٢٢٥) ٨١٢٢٠- عن عبد الله بن عباس -من طريق عطية العَوفيّ- قوله: <q>﴿أإنّا لَمَرْدُودُونَ فِي الحافِرَة﴾</q>، يقول: أئِنّا لنَحيا بعد موتنا، ونُبعث مِن مكاننا هذا؟!{3}. (ز) ٨١٢٢١- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿أإنّا لَمَرْدُودُونَ فِي الحافِرَةِ﴾</q>، قال: الأرض، نُبعث خَلْقًا جديدًا{4}. (١٥/٢٢٤) ٨١٢٢٢- عن أبي مالك غَزْوان الغفاري، <q>﴿أإنّا لَمَرْدُودُونَ فِي الحافِرَةِ﴾</q>، قال: الحياة{2}. (١٥/٢٢٥) ٨١٢٢٣- عن الحسن البصري -من طريق عمران القطان- <q>﴿أإنّا لَمَرْدُودُونَ فِي الحافِرَةِ﴾</q>، قال: خلق جديد{6}. (ز) ٨١٢٢٤- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿يَقُولُونَ أإنّا لَمَرْدُودُونَ فِي الحافِرَةِ﴾</q>: أئنا لمبعوثون خَلْقًا جديدًا إذا مِتنا؟! تكذيبًا بالبعْث{7}. (١٥/٢٢٤) ٨١٢٢٥- عن محمد بن كعب القُرَظيّ -من طريق أبي مَعْشر- <q>﴿أإنّا لَمَرْدُودُونَ فِي الحافِرَةِ﴾</q>، قال: الحياة بعد الموت{8}. (١٥/٢٢٥) ٨١٢٢٦- عن محمد بن قيس، أو محمد بن كعب القُرَظيّ -من طريق أبي مَعْشر- <q>﴿أإنّا لَمَرْدُودُونَ فِي الحافِرَة﴾</q>، قال: في الحياة{9}. (ز) ٨١٢٢٧- عن إسماعيل السُّدِّيّ -من طريق سفيان- <q>﴿أإنّا لَمَرْدُودُونَ فِي الحافِرَةِ﴾</q>، قال: في الحياة{9}. (ز) ٨١٢٢٨- عن عطاء الخُراسانيّ -من طريق يونس بن يزيد- في قوله ﷿: <q>﴿لمردودون في الحافرة﴾</q>، قال: الحياة{11}. (ز) ٨١٢٢٩- قال مقاتل بن سليمان: ثم أخبَر الله ﷿ عن كفار مكة، فقال: <q>﴿يَقُولُونَ أإنّا لَمَرْدُودُونَ فِي الحافِرَةِ﴾</q> تَعجُّبًا منها، فيها تقديم. يقولون: أئِنّا لراجعون على أقدامنا إلى الحياة بعد الموت، وهذا قول كفار مكة{12}. (ز) ٨١٢٣٠- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿أإنّا لَمَرْدُودُونَ فِي الحافِرَةِ﴾</q>، قال: الحافرة: النار. وقرأ قول الله: <q>﴿تِلْكَ إذًا كَرَّةٌ خاسِرَةٌ﴾</q>، قال: ما أكثر أسماءها! هي النار، وهي الجحيم، وهي سَقر، وهي جهنم، وهي الهاوية، وهي الحافرة، وهي لَظى، وهي الحُطَمة{13}٧٠١٩. (ز) ٧٠١٩ اختُلف في الحافرة على أقوال: الأول: العودة إلى الحياة. الثاني: الأرض التي فيها قبورهم حُفِرتْ. الثالث: النار. واختار ابنُ جرير (٢٤/٧٠) -مستندًا إلى اللغة، وأقوال السلف- أنها العودة إلى الحياة بعد الموت، فقال: "يقول -تعالى ذِكْره-: يقول هؤلاء المُكذِّبون بالبعْث مِن مشركي قريش إذا قيل لهم: إنكم مبعوثون من بعد الموت: أئنا لمردودون إلى حالنا الأولى قبل الممات، فراجِعون أحياء كما كُنّا قبل هلاكنا، وقبل مماتنا؟ وهو مِن قولهم: رجع فلان على حافرته: إذا رجع من حيث جاء، ومنه قول الشاعر: أحافِرَةً عَلى صَلَعٍ وشَيْبٍ مَعاذَ اللهِ مِن سَفَهٍ وطَيْش وبنحو الذي قلنا في ذلك قال أهل التأويل". وذكر أقوال السلف على هذا، ووجّه (٢٤/٧١) القول الثاني بقوله: «وقال آخرون: الحافرة: الأرض المحفورة التي حُفِرتْ فيها قبورهم، فجعلوا ذلك نظير قوله: <q>﴿من ماء دافق﴾</q> [الطارق:٦] يعني: مدفوق، وقالوا: الحافرة بمعنى المحفورة، ومعنى الكلام عندهم: أئنا لمردودون في قبورنا أمواتًا؟!». ",footnotes:1:أخرجه ابن جرير ٢٤/٧٠، وابن أبي حاتم -كما في تغليق التعليق ٥/١٨٠-. وعزاه السيوطي إلى ابن المنذر.عزاه السيوطي إلى عَبد بن حُمَيد.أخرجه ابن جرير ٢٤/٧٠.تفسير مجاهد ص٧٠٢ بنحوه، وأخرجه ابن جرير ٢٤/٧١. وعزاه السيوطي إلى عَبد بن حُمَيد، وابن المنذر.عزاه السيوطي إلى عَبد بن حُمَيد.أخرجه الثعلبي ١٠/١٢٥.أخرجه عبد الرزاق ٢/٣٤٥ من طريق معمر، وابن جرير ٢٤/٧٠-٧١ من طريق معمر أيضًا. وعزاه السيوطي إلى عَبد بن حُمَيد، وابن المنذر.أخرجه ابن جرير ٢٤/٧١. وعزاه السيوطي إلى عَبد بن حُمَيد.أخرجه ابن جرير ٢٤/٧١.أخرجه ابن جرير ٢٤/٧١.أخرجه أبو جعفر الرملي في جزئه (تفسير عطاء) ص٩٩.تفسير مقاتل بن سليمان ٤/٥٧٥.أخرجه ابن جرير ٢٤/٧١-٧٢.
79,11," <q>﴿أَءِذَا كُنَّا عِظَـٰمࣰا نَّخِرَةࣰ ۝١١﴾</q> - قراءات ٨١٢٣١- عن عمر بن الخطاب أنه كان يقرأ: <q>﴿كُنّا عِظامًا نَّخِرَةً﴾</q>{1}. (١٥/٢٢٥) ٨١٢٣٢- عن عبد الله بن مسعود أنه كان يقرأ: ‹نّاخِرَةً› بالألف{2}. (١٥/٢٢٦) ٨١٢٣٣- عن عبد الله بن عباس -من طريق عمرو بن دينار- أنه كان يقرأ التي في النازعات: ‹نّاخِرَةً› بالألف، وقال: بالية{3}. (١٥/٢٢٦) ٨١٢٣٤- عن مجاهد، قال: سمعتُ ابن الزُّبير يقرؤها: ‹عِظامًا نّاخِرَةً› فذَكرتُ ذلك لابن عباس، فقال: أوَليس كذلك؟{4}. (١٥/٢٢٦) ٨١٢٣٥- عن عبد الله بن الزُّبير -من طريق مجاهد- أنه قال على المنبر: ما بالُ صبيانٍ يقرؤون: <q>﴿نَّخِرَةً﴾</q>، إنما هي: ‹نّاخِرَةً›{5}. (١٥/٢٢٦) ٨١٢٣٦- عن عبد الله بن عمر -من طريق زيد بن معاوية- أنه كان يقرأ هذا الحرف: ‹أئِذا كُنّا عِظامًا نّاخِرَةً›{6}. (١٥/٢٢٦) ٨١٢٣٧- عن محمد بن كعب القُرَظيّ= (ز) ٨١٢٣٨- وعكرمة مولى ابن عباس= (ز) ٨١٢٣٩- وإبراهيم النَّخْعي أنهم كانوا يقرؤون: ‹نّاخِرَةً› بالألف{2}٧٠٢٠. (١٥/٢٢٦) ٧٠٢٠ وجّه ابن جرير (٢٤/٧٢) معنى القراءتين، فقال: «قرأته عامة قراء المدينة والحجاز والبصرة: <q>﴿نخرة﴾</q> بمعنى: بالية. وقرأ ذلك عامة قُراء الكوفة: ‹نّاخِرَةً› بألف، بمعنى: أنها مُجوّفة، تنخر الرياح في جوفها إذا مَرّتْ بها». وبنحوه قال ابنُ عطية (٨/٥٢٩). ثم قال ابنُ جرير معلّقًا: «وأفصح اللغتين عندنا وأشهرهما عندنا: <q>﴿نخرة﴾</q> بغير ألف، بمعنى: بالية، غير أنّ رءوس الآي قبلها وبعدها جاءت بالألف؛ فأَعجبُ إليّ لذلك أن تُلْحَق ‹نّاخِرَةً› بها؛ ليتفق هو وسائر رءوس الآيات، لولا ذلك كان أعجبُ القراءتين إليّ حذف الألف منها». <q>﴿أَءِذَا كُنَّا عِظَـٰمࣰا نَّخِرَةࣰ ۝١١﴾</q> - تفسير الآية ٨١٢٤٠- عن عبد الله بن عباس -من طريق عطية- <q>﴿أإذا كُنّا عِظامًا نَخِرَةً﴾</q>: فالنَّخِرة: الفانية البالية{8}. (ز) ٨١٢٤١- عن إبراهيم النَّخْعي -من طريق مغيرة- قال: النَّخِرة: البالية.= (ز) ٨١٢٤٢- قال: وقال شُريح [القاضي]: النّاخِرة: التي صفَّرتْ فيه الريح{9}. (ز) ٨١٢٤٣- عن مجاهد بن جبر -من طريق ابن أبي نجيح- <q>﴿أإذا كُنّا عِظامًا نَخِرَةً﴾</q>، قال: مَرفوتة{10}. (١٥/٢٢٤) ٨١٢٤٤- عن مجاهد بن جبر، قال: النّاخِرة: العظم يَبلى فتدخل الريح فيه{11}. (١٥/٢٢٧) ٨١٢٤٥- عن الضَّحّاك بن مُزاحِم، ‹عِظامًا نّاخِرَةً›، قال: بالية{2}. (١٥/٢٢٧) ٨١٢٤٦- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿أإذا كُنّا عِظامًا نَخِرَةً﴾</q>، قال: بالية{13}. (١٥/٢٢٤) ٨١٢٤٧- عن عطاء الخُراسانيّ -من طريق يونس بن يزيد- في قول الله ﷿: ‹عِظامًا نّاخِرَةً›، قال: بالية{14}. (ز) ٨١٢٤٨- قال مقاتل بن سليمان: <q>﴿أإذا كُنّا عِظامًا نَخِرَةً﴾</q> يعني: بالية، أي: أنّا لا نُبعث خَلْقًا كما كُنّا{15}. (ز) ",footnotes:1:عزاه السيوطي إلى سعيد بن منصور، وعَبد بن حُمَيد. و<q>﴿نَّخِرَةً﴾</q> بحذف الألف قراءة متواترة، قرأ بها العشرة، ما عدا شعبة، وحمزة، والكسائي، وخلف، ورويسًا؛ فإنهم قرؤوا ‹نّاخِرَةً› بألف بعد النون. انظر: النشر ٢/٣٩٧، والإتحاف ص٥٧٠.عزاه السيوطي إلى عَبد بن حُمَيد.أخرجه عبد الرزاق ٢/٣٤٥. وعزاه السيوطي إلى سعيد بن منصور، وعَبد بن حُمَيد، وابن المنذر.عزاه السيوطي إلى سعيد بن منصور، وعَبد بن حُمَيد.أخرجه الفراء في معاني القرآن ٣/٢٣١.أخرجه الطبراني (١٣٠٧٦). قال الهيثمي في مجمع الزوائد ٧/١٣٣: «رواه الطبراني من طريق زيد بن معاوية، عن ابن عمر، ولم أعرفه وبقية رجاله رجال الصحيح».عزاه السيوطي إلى عَبد بن حُمَيد.أخرجه ابن جرير ٢٤/٧٢.أخرجه سعيد بن منصور في سننه -التفسير ٨/٢٥٤ (٢٣٩٠).تفسير مجاهد ص٧٠٢ بلفظ: عظامًا مرفوتة، وأخرجه ابن جرير ٢٤/٧٢-٧٣. وعزاه السيوطي إلى عَبد بن حُمَيد، وابن المنذر.عزاه السيوطي إلى ابن أبي حاتم.عزاه السيوطي إلى عَبد بن حُمَيد.أخرجه ابن جرير ٢٤/٧٣. وعزاه السيوطي إلى عَبد بن حُمَيد، وابن المنذر.أخرجه أبو جعفر الرملي في جزئه (تفسير عطاء) ص٩٩.تفسير مقاتل بن سليمان ٤/٥٧٥.
79,12," <q>﴿قَالُوا۟ تِلۡكَ إِذࣰا كَرَّةٌ خَاسِرَةࣱ ۝١٢﴾</q> - نزول الآية ٨١٢٤٩- عن محمد بن كعب القُرَظيّ -من طريق أبي مَعْشر- في قوله: <q>﴿أإنّا لَمَرْدُودُونَ فِي الحافِرَةِ أإذا كُنّا عِظامًا نَخِرَةً﴾</q>، قال: لما نزلت هذه الآية قال كفار قريش: لئن حَيِينا بعد الموت لنَخْسَرن. فنزلت: <q>﴿تِلْكَ إذًا كَرَّةٌ خاسِرَةٌ﴾</q>{1}. (١٥/٢٢٥) <q>﴿قَالُوا۟ تِلۡكَ إِذࣰا كَرَّةٌ خَاسِرَةࣱ ۝١٢﴾</q> - تفسير الآية ٨١٢٥٠- عن قتادة بن دعامة -من طريق سعيد- <q>﴿قالُوا تِلْكَ إذًا كَرَّةٌ خاسِرَةٌ﴾</q>، قال: رَجْعة خاسرة{2}. (١٥/٢٢٧) ٨١٢٥١- قال مقاتل بن سليمان: <q>﴿قالُوا تِلْكَ إذًا كَرَّةٌ خاسِرَةٌ﴾</q>، قالوا: إن بُعثنا بعد الموت إنّا إذًا لخاسرون، يعني: هالِكون{3}. (ز) ٨١٢٥٢- عن عبد الملك ابن جُرَيْج، في قوله: <q>﴿قالُوا تِلْكَ إذًا كَرَّةٌ خاسِرَةٌ﴾</q>، قال: لَئِن خُلقنا خَلْقًا جديدًا لنَرْجِعنّ إلى الخُسران{4}. (١٥/٢٢٧) ٨١٢٥٣- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿تِلْكَ إذًا كَرَّةٌ خاسِرَةٌ﴾</q>، قال: وأيُّ كرَّةٍ أخسرُ منها؛ أُحيوا ثم صاروا إلى النار، فكانت كرَّة سوء{5}٧٠٢١. (ز) ٧٠٢١ أفادت آثار السلف أنّ قوله: <q>﴿خاسرة﴾</q> مِن الخسران، أي: رجعة خاسرة؛ لما فيها من سوء المآل. وقد ذكر هذا ابنُ عطية (٨/٥٢٩)، وأضاف عن الحسن أنّ <q>﴿خاسرة﴾</q> بمعنى: كاذبة، ووجّهه بقوله: «أي: ليست كافية». ",footnotes:1:أخرجه سعيد بن منصور ٨/٥٢٥ (٢٣٨٧). وعزاه السيوطي إلى عَبد بن حُمَيد، وابن المنذر.أخرجه ابن جرير ٢٤/٧٣. وعزاه السيوطي إلى عَبد بن حُمَيد.تفسير مقاتل بن سليمان ٤/٥٧٥.عزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ٢٤/٧٣.
79,13," <q>﴿فَإِنَّمَا هِیَ زَجۡرَةࣱ وَ ٰ⁠حِدَةࣱ ۝١٣﴾</q> - تفسير ٨١٢٥٤- عن مجاهد بن جبر -من طريق ابن أبي نجيح- <q>﴿فَإنَّما هِيَ زَجْرَةٌ واحِدَةٌ﴾</q>، قال: صيحة{1}. (١٥/٢٢٧) ٨١٢٥٥- قال مقاتل بن سليمان: ثم قال الله -تبارك وتعالى- لمحمد ﷺ: <q>﴿فَإنَّما هِيَ زَجْرَةٌ واحِدَةٌ﴾</q>، يقول: فإنما هي صيحة واحدة مِن إسرافيل ﵇، فيَسمعونها وهم في بطن الأرض أمواتًا، لا يُثنيها{2}. (ز) ٨١٢٥٦- عن عبد الملك ابن جُرَيْج، في قوله: <q>﴿فَإنَّما هِيَ زَجْرَةٌ واحِدَةٌ﴾</q>، قال: صيحة{3}. (١٥/٢٢٧) ٨١٢٥٧- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿زَجْرَةٌ واحِدَةٌ﴾</q>، قال: الزّجرة: النَّفخة في الصور{4}. (ز) ",footnotes:1:تفسير مجاهد ص٧٠٢ بلفظ: صيحة واحدة، وأخرجه ابن جرير ٢٤/٧٤، وعَبد بن حُمَيد -كما في فتح الباري ٨/٦٩٠-. وعزاه السيوطي إلى ابن المنذر.تفسير مقاتل بن سليمان ٤/٥٧٥-٥٧٦.عزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ٢٤/٧٤.
79,14," <q>﴿فَإِذَا هُم بِٱلسَّاهِرَةِ ۝١٤﴾</q> - تفسير ٨١٢٥٨- عن عبد الله بن عباس -من طريق عكرمة- أنه سُئل عن قوله: <q>﴿فَإذا هُمْ بِالسّاهِرَةِ﴾</q>. قال: السّاهرة: وجه الأرض. وفي لفظ قال: الأرض كلّها. وقال ابن عباس: قال أُمَيّة بن أبي الصّلت: وفيها لحم ساهرةٍ وبحر{1}. (١٥/٢٢٨) ٨١٢٥٩- عن عبد الله بن عمر -من طريق عبد الرحمن بن البيلماني- في قول الله ﷿: <q>﴿إنَّما هِيَ زَجْرَةٌ واحِدَةٌ فَإذا هُمْ بِالسّاهِرَةِ﴾</q>، قال: السّاهرة: تَلٌّ في ثُلث الهواء، يُزجرون من هذه فيَصيرون بذلك التَّل{2}. (ز) ٨١٢٦٠- عن سهل بن سعد السّاعدي، <q>﴿فَإذا هُمْ بِالسّاهِرَةِ﴾</q>، قال: أرض بيضاء عَفْراء، كالخُبْزة من النَّقيّ{3}. (١٥/٢٢٩) ٨١٢٦١- عن سعيد بن جُبَير -من طريق عكرمة- <q>﴿فَإذا هُمْ بِالسّاهِرَةِ﴾</q>، قال: بالأرض{4}. (١٥/٢٢٩) ٨١٢٦٢- عن عكرمة مولى ابن عباس -من طريق حُصَين-، مثله{5}. (ز) ٨١٢٦٣- عن مجاهد بن جبر -من طريق ابن أبي نجيح- <q>﴿فَإذا هُمْ بِالسّاهِرَةِ﴾</q>، قال: المكان المستوي في الأرض{6}. (١٥/٢٢٧) ٨١٢٦٤- عن مجاهد بن جبر، <q>﴿فَإذا هُمْ بِالسّاهِرَةِ﴾</q>، قال: بالأرض؛ كانوا في أسفلها فأُخرجوا إلى أعلاها{7}. (١٥/٢٢٩) ٨١٢٦٥- عن الضَّحّاك بن مُزاحِم -من طريق عبيد- <q>﴿فَإذا هُمْ بِالسّاهِرَةِ﴾</q>، قال: كانوا في بطن الأرض، ثم صاروا على ظهرها{8}. (١٥/٢٢٧) ٨١٢٦٦- عن الحسن البصري -من طريق أبي رجاء-= (ز) ٨١٢٦٧- وعامر الشعبي، مثله{9}. (١٥/٢٢٧) ٨١٢٦٨- عن عكرمة مولى ابن عباس -من طريق عمارة بن أبي حفصة- <q>﴿فَإذا هُمْ بِالسّاهِرَةِ﴾</q>، قال: السّاهرة: وجه الأرض. وفي لفظ قال: الأرض كلّها ساهرة، ألا ترى قول الشاعر: صيدُ بحر وصيدُ ساهرة؟{10}. (١٥/٢٢٨) ٨١٢٦٩- عن عكرمة مولى ابن عباس، في قوله: <q>﴿بِالسّاهِرَةِ﴾</q>، قال: تُسمّى الأرض: ساهرة بني فلان{7}. (١٥/٢٢٩) ٨١٢٧٠- عن عامر الشعبي -من طريق بيان- <q>﴿فَإذا هُمْ بِالسّاهِرَةِ﴾</q>، قال: إذا هم بالأرض. ثم تمثّل ببيت أُمَيّة بن أبي الصّلت: وفيها لحمُ ساهرةٍ وبحر وما فاهوا به لَهُمُ مُقيم{12}. (١٥/٢٢٨) ٨١٢٧١- عن وهْب بن مُنَبِّه -من طريق أبي سنان- قال في قول الله: <q>﴿فَإذا هُمْ بِالسّاهِرَةِ﴾</q>: السّاهرة: جبل إلى جَنب بيت المقدس{13}. (١٥/٢٢٩) ٨١٢٧٢- عن قتادة بن دعامة -من طريق سعيد- <q>﴿فَإذا هُمْ بِالسّاهِرَةِ﴾</q>، قال: جهنم{14}. (١٥/٢٢٩) ٨١٢٧٣- عن قتادة بن دعامة -من طريق معمر- في قوله: <q>﴿فَإنَّما هِيَ زَجْرَةٌ واحِدَةٌ فَإذا هُمْ بِالسّاهِرَةِ﴾</q>، قال: فإذا هم يخرجون مِن قبورهم فوق الأرض، والساهرة: الأرض{15}. (١٥/٢٢٧) ٨١٢٧٤- قال مقاتل بن سليمان: <q>﴿فَإذا هُمْ بِالسّاهِرَةِ﴾</q> يعني: الأرض الجديدة التي تُبسط على هذه الأرض، فيسلّها الله ﷿ من تحتها كما يُسلُّ الثوب الخَلِق البالي، فذلك قوله: <q>﴿فَإذا هُمْ بِالسّاهِرَةِ﴾</q> يقول: بالأرض الأخرى، واسمها: الساهرة{16}. (ز) ٨١٢٧٥- عن عثمان بن أبي العاتكة -من طريق الوليد بن مسلم- قوله: <q>﴿فَإنَّما هِيَ زَجْرَةٌ واحِدَةٌ فَإذا هُمْ بِالسّاهِرَةِ﴾</q>، قال: بالصّقع الذي بين جبل حَسّان وجبل أريحاء، يَمُدَّه الله كيف يشاء{5}. (ز) ٨١٢٧٦- عن سفيان [الثوري] -من طريق مهران- <q>﴿فَإذا هُمْ بِالسّاهِرَةِ﴾</q>، قال: أرض بالشام{18}. (ز) ٨١٢٧٧- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿فَإذا هُمْ بِالسّاهِرَةِ﴾</q>، قال: السّاهرة: ظهر الأرض، فوق ظهرها{19}. (ز) ٨١٢٧٨- قال يحيى بن سلّام: <q>﴿فَإذا هُمْ بِالسّاهِرَةِ﴾</q> السّاهرة عند أهل اللغة: وجه الأرض{20}٧٠٢٢. (ز) ٧٠٢٢ اختُلف فيما عنى الله بالسّاهرة على أقوال: الأول: وجه الأرض. الثاني: اسم مكان مِن الأرض بعينه معروف. الثالث: جبلٌ بعينه. الرابع: جهنم. الخامس: المكان المستوي. السادس: الأرض كلّها. وقد رجّح ابنُ جرير (٢٤/٧٤ بتصرف) -مستندًا إلى اللغة- القول الأول، فقال: «وقوله: <q>﴿فإذا هم بالساهرة﴾</q> يعني: بظهر الأرض. والعرب تُسمّي الفَلاة ووجه الأرض: ساهرة، وأراهم سَمّوا ذلك بها لأن فيه نوم الحيوان وسهرها، فوصف بصفة ما فيه». وبنحوه قال ابنُ كثير (١٤/٢٤١)، وانتقد بقية الأقوال بقوله: «وهذه أقوال كلّها غريبة». ",footnotes:1:أخرجه أبو عبيد في فضائله ص٢٠٦، وابن جرير ٢٤/٧٥، ومن طريق عطية أيضًا بدون بيت الشعر. وعزاه السيوطي إلى ابن الأنباري في الوقف والابتداء، وعَبد بن حُمَيد، وابن المنذر، وابن أبي حاتم.أخرجه عبد الله بن وهب في الجامع -تفسير القرآن ٢/١٠١ (١٩٨)، والعقيلي في كتاب الضعفاء ٥/٣٥١ (١٨٣٩).أخرجه ابن أبي حاتم -كما في تفسير ابن كثير ٨/٣٣٧، وفتح الباري ٦/٢٩٤-. وعزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ٢٤/٧٧، ومن طريق أبي الهيثم أيضًا. وعزاه السيوطي إلى عَبد بن حُمَيد.أخرجه ابن جرير ٢٤/٧٧.تفسير مجاهد ص٧٠٢ بلفظ: المكان المستوي، وأخرجه ابن جرير ٢٤/٧٦، وعَبد بن حُمَيد -كما في فتح الباري ٨/٦٩٠-. وعزاه السيوطي إلى ابن المنذر.عزاه السيوطي إلى عَبد بن حُمَيد.أخرجه ابن جرير ٢٤/٧٧. وعزاه السيوطي إلى عَبد بن حُمَيد.عزاه السيوطي إلى عَبد بن حُمَيد. وأخرجه ابن جرير ٢٤/٧٦ عن الحسن.أخرجه ابن جرير ٢٤/٧٥-٧٦، وكذلك من طريق حُصَين. وعزاه السيوطي إلى عَبد بن حُمَيد، وابن المنذر.عزاه السيوطي إلى عَبد بن حُمَيد.أخرجه ابن أبي شيبة ٨/٥١٦-٥١٧. وعزاه السيوطي إلى عَبد بن حُمَيد.أخرجه آدم بن أبي إياس -كما في تفسير مجاهد ص٧٠٢- من طريق سَلمة، وابن جرير ٢٤/٧٨. وعزاه السيوطي إلى عَبد بن حُمَيد، وابن المنذر.أخرجه ابن جرير ٢٤/٧٨. وعزاه السيوطي إلى ابن المنذر.أخرجه عبد الرزاق ٢/٣٤٦، وابن جرير ٢٤/٧٦. وعزاه السيوطي إلى عَبد بن حُمَيد بلفظ: قال: فإذا هم على ظهر الأرض، بعد أن كانوا في جوفها.تفسير مقاتل بن سليمان ٤/٥٧٦.أخرجه ابن جرير ٢٤/٧٧.أخرجه ابن جرير ٢٤/٧٨.أخرجه ابن جرير ٢٤/٧٤.تفسير ابن أبي زمنين ٥/٨٨.
79,15," <q>﴿هَلۡ أَتَىٰكَ حَدِیثُ مُوسَىٰۤ ۝١٥ إِذۡ نَادَىٰهُ رَبُّهُۥ بِٱلۡوَادِ ٱلۡمُقَدَّسِ طُوًى ۝١٦﴾</q> - تفسير ٨١٢٧٩- عن مجاهد بن جبر -من طريق ابن أبي نجيح- قوله: <q>﴿طُوًى﴾</q> اسم الوادي{1}. (ز) ٨١٢٨٠- عن مجاهد بن جبر -من طريق ابن جُرَيْج- <q>﴿إنَّكَ بِالوادِ المُقَدَّسِ طُوًى﴾</q> [طه:١٢]، قال: طَأِ الأرضَ بقدمك{2}. (ز) ٨١٢٨١- قال الحسن البصري: <q>﴿طُوًى﴾</q> المعنى: طُوِيَ بالبركة{3}. (ز) ٨١٢٨٢- قال الحسن البصري -من طريق قتادة- <q>﴿طُوًى﴾</q>: المُقدّس، قُدِّس مرتين{4}. (ز) ٨١٢٨٣- عن قتادة بن دعامة -من طريق معمر- في قوله تعالى: <q>﴿بِالوادِ المُقَدَّسِ طُوًى﴾</q>، قال: هو اسم الوادي{5}. (ز) ٨١٢٨٤- عن قتادة بن دعامة -من طريق سعيد- <q>﴿إذْ ناداهُ رَبُّهُ بِالوادِ المُقَدَّسِ طُوًى﴾</q>: كُنّا نحدَّث أنه قُدِّس مرتين، واسم الوادي: طُوى{2}. (ز) ٨١٢٨٥- قال مقاتل بن سليمان: قوله: <q>﴿هَلْ أتاكَ حَدِيثُ مُوسى﴾</q> قبل هذا؛ <q>﴿إذْ ناداهُ رَبُّهُ بِالوادِ المُقَدَّسِ﴾</q> يقول: بالوادي المُطَهَّر اسمه: <q>﴿طُوىً﴾</q>؛ لأنّ الله ﷿ طَوى عليه القدس، وكان نداؤه إيّاه أنه قال: يا موسى. فناداه من الشجرة، وهي الشمران{7}، فقال: يا موسى، إني أنا ربك{8}. (ز) ٨١٢٨٦- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿إنَّكَ بِالوادِ المُقَدَّسِ طُوًى﴾</q> [طه:١٢]، قال: اسم المُقَدّس: طوى{2}. (ز) ",footnotes:1:تفسير مجاهد ص٧٠٢، وأخرجه ابن جرير ٢٤/٧٩.أخرجه ابن جرير ٢٤/٧٩.ذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٥/٨٩-.أخرجه عبد الرزاق ٢/٣٤٦.أخرجه عبد الرزاق ٢/٣٤٥-٣٤٦.أخرجه ابن جرير ٢٤/٧٩.كذا أثبتها المحقق من إحدى النسخ، وأورد أنها جاءت في نسخة أخرى: السمران.تفسير مقاتل بن سليمان ٤/٥٧٦.أخرجه ابن جرير ٢٤/٧٩.
