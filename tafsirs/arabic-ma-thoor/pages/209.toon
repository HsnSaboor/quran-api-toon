quran[8]{c,v,t}:
  10,7,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿إِنَّ ٱلَّذِینَ لَا یَرۡجُونَ لِقَاۤءَنَا﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٤٢١٢<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- قوله: <span class="qpc-hafs">﴿إن الذين لا يرجون لقاءنا ورضوا بالحياة الدنيا واطمأنوا بها والذين هم عن آياتنا غافلون﴾</span>، قال: إذا شئت رأيت صاحب دنيا، لها يفرح، ولها يحزن، ولها يرضى، ولها يسخط{1}<span class=comment-ref>٣٠٩٨</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٣٠٩٨</span> <span class="comment-type-4">علَّق</span> <u>ابنُ عطية</u> (٤/٤٥٤بتصرف) على قول قتادة بقوله: «فكأنّ قتادة صوَّرها في العُصاة، ولا يترتب ذلك إلا مع تأول الرجاء على بابه؛ إذ قد يكون العاصي المُجلِّح مستوحشًا من آخرته، فأمّا على تأويل الرجاء بالخوف فالمعنى: فمن لا يخاف لقاء الله فهو كافر».</div></p><p><div></p><p><p><span class="item-no">٣٤٢١٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿إنَّ الَّذِينَ لا يَرْجُونَ لِقاءَنا﴾</span>، يعني: لا يخشون لقاءنا، يعني: البعث، والحساب{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤٢١٤<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿إنّ الَّذِينَ لا يَرجُونَ لِقَآءَنا ورَضُوا بِالحَياةِ الدُّنيا﴾</span> الآية كلَّها، قال: هؤلاء أهلُ الكفرِ{3}<span class=comment-ref>٣٠٩٩</span>. (٧/٦٣٢)</p></p><p></div></p><p><div><span class=comment-ref>٣٠٩٩</span> <span class="comment-type-4">ذكر</span> <u>ابنُ عطية</u> (٤/٤٥٤) أنّ المهدويَّ حكى عن بعض أهل اللغة: أنّ لفظة الرجاء إذا جاءت منفيَّة فإنها تكون بمعنى: الخوف، وحكي عن بعضهم أنّها تكون بمعناها في كل موضع تدل عليه قرائن ما قبله وما بعده، ثم <span class="comment-type-4">علَّق</span> بقوله: «فعلى هذا التأويل معنى الآية: إنّ الذين لا يخافون لقاءنا». ثُمَّ بيَّن أنّ بعض أهل العلم قال: إنّ الرجاء في هذه الآية على بابه، وذلك أنّ الكافر المُكَذِّب بالبعث ليس يرجو رحمةً في الآخرة، ولا يُحْسِن ظنًّا بأنّه يلقى الله، ولا له في الآخرة أمل، فإنّه لو كان له فيها أملٌ لَقارنه لا محالة خوفٌ، وهذه الحال من الخوف المقارن هي القائدة إلى النجاة«. ثم <span class="comment-type-4">قال</span>:»والذي أقول: إنّ الرجاء في كل موضع على بابه".</div></p><p><h3><span class="qpc-hafs">﴿وَرَضُوا۟ بِٱلۡحَیَوٰةِ ٱلدُّنۡیَا وَٱطۡمَأَنُّوا۟ بِهَا﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٤٢١٥<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿ورَضُوا بِالحَياةِ الدُّنيا واطمَأَنُّوا بِها﴾</span>، قال: مثل قوله: <span class="qpc-hafs">﴿مَن كانَ يُرِيدُ الحَياةَ الدُّنْيا وزِينَتَها نُوَفِ إلَيهِم أعمالَهُم فِيها﴾</span> الآية [هود:١٥]{4}. (٧/٦٣٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤٢١٦<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق حَوْشَب- في قوله: <span class="qpc-hafs">﴿إنّ الَّذِينَ لا يَرجُونَ لِقَآءَنا ورَضُوا بِالحَياةِ الدُّنيا واطمَأَنُّوا بِها﴾</span>، قال: واللهِ، ما زَيَّنوها ولا رفعوها حتى رَضُوا بها{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤٢١٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ورَضُوا بِالحَياةِ الدُّنْيا واطْمَأَنُّوا بِها﴾</span> فعمِلوا لها، <span class="qpc-hafs">﴿والَّذِينَ هُمْ عَنْ آياتِنا﴾</span> يعني: ما أخبر في أول هذه السورة <span class="qpc-hafs">﴿غافِلُونَ﴾</span> يعني: ما ذُكِر من صنيعه في هؤلاء الآيات لَمُعْرِضون، فلا يؤمنون{2}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَٱلَّذِینَ هُمۡ عَنۡ ءَایَـٰتِنَا غَـٰفِلُونَ ۝٧﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٤٢١٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>: <span class="qpc-hafs">﴿والَّذِينَ هُمْ عَنْ آياتِنا﴾</span>: محمد، والقرآن{7}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ١٢/١٢٢، وابن أبي حاتم ٦/١٩٢٨.تفسير مقاتل بن سليمان ٢/٢٢٧.أخرجه ابن جرير ١٢/١٢٢-١٢٣. وعزاه السيوطي إلى أبي الشيخ.تفسير مجاهد ص٣٧٩، وأخرجه ابن جرير ١٢/١٢٢، وابن أبي حاتم ٦/١٩٢٨.أخرجه ابن أبي حاتم ٦/١٩٢٨.تفسير مقاتل بن سليمان ٢/٢٢٧.تفسير الثعلبي ٥/١٢٠، وتفسير البغوي ٤/١٢٢.
  10,8,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿أُو۟لَـٰۤىِٕكَ مَأۡوَىٰهُمُ ٱلنَّارُ بِمَا كَانُوا۟ یَكۡسِبُونَ ۝٨﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٤٢١٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿أُولئِكَ مَأْواهُمُ النّارُ﴾</span> يعني: مصيرهم النار؛ <span class="qpc-hafs">﴿بِما كانُوا يَكْسِبُونَ﴾</span> من الكفر، والتَّكذيب{1}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿أُو۟لَـٰۤىِٕكَ مَأۡوَىٰهُمُ ٱلنَّارُ بِمَا كَانُوا۟ یَكۡسِبُونَ ۝٨﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٣٤٢٢٠<span class="dash">-</span></span> عن <span class="name-3">يوسف بن أسباط</span>، قال: الدنيا دارُ نعيمِ الظالمين.= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤٢٢١<span class="dash">-</span></span> قال: وقال <span class="name-1">عليُّ بن أبي طالب</span>: الدنيا جِيفَةٌ، فمَن أرادها فلْيَصْبِرْ على مخالطةِ الكلابِ{2}<span class=comment-ref>٣١٠٠</span>. (٧/٦٣٢)</p></p><p></div></p><p><div><span class=comment-ref>٣١٠٠</span> <span class="comment-type-4">ذكر</span> <u>ابنُ عطية</u> (٤/٤٥٤) أنّ قوله: <span class="qpc-hafs">﴿والذين هم عن آياتنا غافلون﴾</span> يحتمل أن يكون ابتداء إشارة إلى فرقة أخرى من الكفار، ثم <span class="comment-type-4">علَّق</span> بقوله: «وهؤلاء -على هذا التأويل- أهلُ صفقةٍ؛ لأنهم ليسوا أهل دنيا، بل غفلة فقط».</div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٢/٢٢٧.عزاه السيوطي إلى أبي الشيخ.
  10,9,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿إِنَّ ٱلَّذِینَ ءَامَنُوا۟ وَعَمِلُوا۟ ٱلصَّـٰلِحَـٰتِ یَهۡدِیهِمۡ رَبُّهُم بِإِیمَـٰنِهِمۡۖ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٤٢٢٢<span class="dash">-</span></span> عن قتادة، في قوله: <span class="qpc-hafs">﴿يَهدِيهِم رَبُّهُم بِإيِمانِهِم﴾</span>، قال: حدَّثنا الحسن، قال: بلَغَنا: أنّ النبيَّ ﷺ قال: «<b>إنّ المؤمن إذا خرَج من قبرِه صُوِّر له عملُه في صورةٍ حسنة، وريحٍ طيِّبة، فيقول له: ما أنت؟ فواللهِ، إنِّي لأراك عينَ امرئ صدق. فيقول: أنا عَمَلُك. فيكون له نورًا، وقائدًا إلى الجنة، وأمّا الكافرُ فإذا خرَج من قبرِه صُوِّر له عملُه في صورةٍ سيئة، وريح مُنتِنة، فيقول له: ما أنت؟ فواللهِ، إنِّي لَأراك عينَ امرئ سوءٍ. فيقول: أنا عملُك. فيَنطلِقُ به حتى يُدخِلَه النارَ</b>»{1}. (٧/٦٣٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤٢٢٣<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿يَهدِيهِم رَبُّهُم بِإيِمانِهِم﴾</span>، قال: يكونُ لهم نورًا يَمشون به{2}<span class=comment-ref>٣١٠١</span>. (٧/٦٣٣)</p></p><p></div></p><p><div><span class=comment-ref>٣١٠١</span> <span class="comment-type-4">علَّق</span> <u>ابنُ عطية</u> (٤/٤٥٥) على قول مجاهد بقوله: «ويَتَرَكَّب هذا التأويلُ على ما رُوِي عن النبي ﷺ: «إنّ العبد المؤمن إذا قام من قبره للحشر تَمَثَّل له رجلٌ جميل الوجه، طيّب الرائحة، فيقول: مَن أنت؟ فيقول: أنا عملك الصالح. فيقوده إلى الجنة». وبعكس هذا في الكافر».</p><p>و<span class="comment-type-4">ذكر</span> <u>ابنُ كثير</u> (٧/٣٣٧) أنّ الباء على قول مجاهد للاستعانة، وأنّها تحتمل أن تكون سببية، والتقدير: بسبب إيمانهم في الدنيا يهديهم الله يوم القيامة على الصراط، حتى يجوزوه ويخلصوا إلى الجنة.</div></p><p><div></p><p><p><span class="item-no">٣٤٢٢٤<span class="dash">-</span></span> وعن <span class="name-2">قتادة بن دعامة</span>، مثلَه{3}. (٧/٦٣٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤٢٢٥<span class="dash">-</span></span> قال <span class="name-2">عطية بن سعد العوفي</span>: <span class="qpc-hafs">﴿يَهدِيهِم رَبُّهُم بِإيِمانِهِم﴾</span>، يهديهم، ويُثِيبهم، ويجزيهم{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤٢٢٦<span class="dash">-</span></span> عن <span class="name-2">الربيع بن أنس</span>، في قوله: <span class="qpc-hafs">﴿يَهدِيهِم رَبُّهُم بِإيِمانِهِم﴾</span>، قال: حتى يُدخلَهم الجنة، فحدث أصحابُ النبي ﷺ: لَأحدُهم يومَئذٍ أعلمُ بمنزلِه منكم اليومَ بمنزلِنا. ثم ذكر عن العلماء: أنّه أنزَلهم الجنة سبعةَ منازلَ، لكلِّ منزلٍ من تلك المنازلِ أهلُها في سبعِ فضائلَ، فقال النبي ﷺ: «<b>يُسعى عليهم بما سأَلوا، وبما خطَر على أنفسهم، حتى إذا امْتَلَؤوا كان طعامُهم ذلك جُشاءً، وريحَ المسك، ليس فيها حَدَثٌ، ثم أُلهِموا الحمدَ، والتسبيحَ، كما أُلهِموا النفَسَ، ثم يَجتنِي فاكهتَها قائمًا، وقاعدًا، ومتكِئًا، على أيِّ حالٍ كان عليه، ثم لا تَصِلُ إلى فيه حتى تعودَ كما كانت، إنّها بَركةُ الرحمن، وبَركةُ الرحمنِ لا تَفنى، وهي الخزائنُ التي لا تَنقطِعُ أبدًا، ما أُخِذ منها لم يَنقُصْ، وما تُرِك منها لم يفسُدْ</b>»{3}. (٧/٦٣٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤٢٢٧<span class="dash">-</span></span> قال <span class="name-2">أبو رَوْق عطية بن الحارث الهمداني</span>: <span class="qpc-hafs">﴿يهديهم ربهم بإيمانهم﴾</span> إلى الجنة{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤٢٢٨<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿إنَّ الَّذِينَ آمَنُوا﴾</span> يعني: صدَّقوا بالله، <span class="qpc-hafs">﴿وعَمِلُوا الصّالِحاتِ﴾</span>، وأقاموا فرائض الله؛ <span class="qpc-hafs">﴿يَهْدِيهِمْ رَبُّهُمْ بِإيمانِهِمْ﴾</span> يعني: بتصديقهم، وتوحيدهم، كما صدّقوا ووحَّدوا كذلك يهديهم ربهم إلى الفرائض، ويثيبهم الجنَّة{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤٢٢٩<span class="dash">-</span></span> عن <span class="name-3">عبد الملك ابن جُرَيْج</span>، في قوله: <span class="qpc-hafs">﴿يَهدِيهِم رَبُّهُم بِإيِمانِهِم﴾</span>، قال: يُمثَّلُ له عملُه في صورةٍ حسنةٍ، وريحٍ طيبةٍ، يعارِضُ صاحبَه، ويُبَشِّره بكلِّ خير، فيقول: مَن أنت؟ فيقول: أنا عملك الصالح. فيجعلُ له نورًا مِن بين يديه حتى يُدخِلَه الجنةَ، والكافرَ يُمثَّلُ له عملُه في صورة سيئة، وريح مُنتِنة، فيُلازِمُ صاحبَه حتى يَقذِفَه في النار{8}<span class=comment-ref>٣١٠٢</span>. (٧/٦٣٣)</p></p><p></div></p><p><div><span class=comment-ref>٣١٠٢</span> <span class="comment-type-4">ذكر</span> <u>ابنُ عطية</u> (٤/٤٥٥) أنّ قوله: <span class="qpc-hafs">﴿بإيمانهم﴾</span> يحتمل احتمالين: <b>الأول</b>: أن يريد بسبب إيمانهم، ويكون مقابلًا لقوله قبل: <span class="qpc-hafs">﴿مأواهم النار بما كانوا يكسبون﴾</span>. <b>الثاني</b>: أن يكون الإيمان هو نفس الهدى، أي: يهديهم إلى طرق الجنة بنور إيمانهم.</div></p><p><h3><span class="qpc-hafs">﴿تَجۡرِی مِن تَحۡتِهِمُ ٱلۡأَنۡهَـٰرُ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٤٢٣٠<span class="dash">-</span></span> عن <span class="name-2">أبي مالك غزوان الغفاري</span> -من طريق إسماعيل السدي- قوله: <span class="qpc-hafs">﴿تجري من تحتهم الأنهار﴾</span>، يعني: تحت منازلهم، وأرضِهم{9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤٢٣١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿تَجْرِي مِن تَحْتِهِمُ الأَنْهارُ﴾</span> يعني: تحت قصورهم، نور في نور، قصور الدُّرِّ والياقوت، وأنها تجري من غرفهم، <span class="qpc-hafs">﴿فِي جَنّاتِ النَّعِيمِ﴾</span> لا يُكَلَّفون فيها عملًا أبدًا، ولا يُصِيبهم فيها مَشَقَّةٌ أبدًا{7}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ١٢/١٢٣-١٢٤، وابن أبي حاتم ٦/١٩٢٩ (١٠٢٣٧).تفسير مجاهد ص٣٧٩، وأخرجه ابن جرير ١٢/١٢٤، وابن أبي حاتم ٦/١٩٢٩. وعزاه السيوطي إلى ابن أبي شيبة، وابن المنذر.عزاه السيوطي إلى أبي الشيخ.تفسير الثعلبي ٥/١٢٠.عزاه السيوطي إلى أبي الشيخ.تفسير الثعلبي ٥/١٢٠.تفسير مقاتل بن سليمان ٢/٢٢٧.علَّقه ابن جرير ١٢/١٢٤-١٢٥. وعزاه السيوطي إلى ابن المنذر، وأبي الشيخ.أخرجه ابن أبي حاتم ٦/١٩٢٩.تفسير مقاتل بن سليمان ٢/٢٢٧.
  10,10,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿دَعۡوَىٰهُمۡ فِیهَا سُبۡحَـٰنَكَ ٱللَّهُمَّ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٤٢٣٢<span class="dash">-</span></span> عن أُبَيِّ بن كعب، قال: قال رسول الله ﷺ: «<b>إذا قالوا: سبحانَك اللهم. أتاهم ما اشتَهَوا من الجنةِ مِن ربِّهم</b>»{1}. (٧/٦٣٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤٢٣٣<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دِعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿دَعواهُمْ فِيها سُبْحانَكَ اللَّهُمَّ﴾</span>، قال: يكونُ ذلك قولَهم فيها{2}. (٧/٦٣٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤٢٣٤<span class="dash">-</span></span> عن <span class="name-2">الربيع بن أنس</span> -من طريق سليمان بن علي- قال: أهلُ الجنةِ إذا اشتهَوا شيئًا قالوا: سبحانَك اللهمَّ وبحمدِك. فإذا هو عندَهم، فذلك قوله: <span class="qpc-hafs">﴿دَعواهُمْ فِيها سُبْحانَكَ اللَّهُمَّ﴾</span>{3}. (٧/٦٣٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤٢٣٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿دَعْواهُمْ فِيها سُبْحانَكَ اللَّهُمَّ﴾</span> فهذا عَلَمٌ بين أهل الجنة وبين الخدم؛ إذا أرادوا الطعام والشراب دعواهم أن يقولوا في الجنة: <span class="qpc-hafs">﴿سُبْحانَكَ اللَّهُمَّ﴾</span>. فإذا الموائد قد جاءت، فوُضعت مِيلًا في ميل، قوائمها اللؤلؤ، ودخل عليهم الخدم من أربعة آلاف باب، معهم صِحاف الذَّهب، سبعون ألف صَحْفَة، في كل صَحْفَة لَوْنٌ مِن الطعام، ليس في صاحبتها مثله، كُلَّما شَبِع ألقى اللهُ عليه ألفَ بابٍ مِن الشهوة، كُلَّما شَبِع أُتِي بِشَرْبَةٍ تهضم ما قبلها بمقدار أربعين عامًا، ويُؤْتَون بألوان الثمار، وتجيء الطير أمثال البخت، مناقيرها لون، وأجنحتها لون، وظهورها لون، وبطونها لون، وقوائِمها لون، تَتَلَأْلَأُ نورًا، حتى تقف بين يديه، في بيتٍ طوله فَرْسَخ في فَرْسَخ، في غرفة فيها سُرُر مَوْضُونَة، والوَضْن: مشبك{4} وسطه بقُضْبان الياقوت والزُّمُرُّد الرطب، ألين من الحرير، قوائمها اللؤلؤ، حافَتاه ذهب وفضة، عليه مِن الفُرُش مقدارُ سبعين غرفة في دار الدنيا، لو أنّ رجلًا وقَع من تلك الغُرَف لم يبلغ قرار الأرض سبعين عامًا، فيأكلون، ويشربون، وتقوم الطير، وتَصْطَفُّ بين يديه، وتقول: يا ولِيَّ الله، رَعَيْتَ في رَوْضَة كذا وكذا، وشربتَ مِن عين كذا وكذا، فأيَّتهُنَّ أعجبه وصفُها وقَعَتْ على مائدته، نِصْفُها قديد، سبعون ألف لون من الطير الواحد، والنِّصْف شِواء، فيأكل منها ما أحبَّ، ثم يطير، فينطلق إلى الجنة؛ لأنه ليس في الجنة مَن يموت{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤٢٣٦<span class="dash">-</span></span> عن <span class="name-3">مقاتل بن حيان</span> -من طريق شبيب بن عبد الملك- قال: إنّ أهل الجنة إذا دَعَوا بالطعامِ قالوا: سُبحانَك، اللهمَّ. فيقومُ على أحدِهم عشَرةُ آلاف خادم، مع كلِّ خادم صَحْفةٌ مِن ذهبٍ، فيها طعامٌ ليس في الأخرى، فيأكلُ مِنهُنَّ كُلِّهن{6}. (٧/٦٣٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤٢٣٧<span class="dash">-</span></span> عن <span class="name-3">عبد الملك ابن جُرَيْج</span> -من طريق حجاج- قال: أُخبِرتُ أنّ قوله: <span class="qpc-hafs">﴿سُبْحانَكَ اللَّهُمَّ﴾</span> إذا مَرَّ بهم الطائرُ يشتهُونه قالوا: سبحانَك، اللهمَّ. ذلك دعاؤُهم به، فيأتِيهم الملَكُ بما اشْتَهَوا، فإذا جاء الملَكُ بما يشتهون، فيُسَلِّمُ عليهم، فيردُّون عليه، فذلك قولُه: <span class="qpc-hafs">﴿وتَحِيَّتُهُمْ فِيها سَلامٌ﴾</span>. فإذا أكَلوا قَدْرَ حاجتِهم قالوا: الحمدُ لله ربِّ العالمين. فذلك قوله: <span class="qpc-hafs">﴿وءاخِرُ دَعْواهُمْ أنِ الحَمْدُ لِلَّهِ رَبِ العالمَينَ﴾</span>{7}<span class=comment-ref>٣١٠٣</span>. (٧/٦٣٥)</p></p><p></div></p><p><div><span class=comment-ref>٣١٠٣</span> <span class="comment-type-4">ذكر</span> <u>ابنُ عطية</u> (٤/٤٥٦) أنّ بعض العلماء قال: «<span class="qpc-hafs">﴿وتحيتهم﴾</span>، يريد: تسليم الله ﷿ عليهم».</div></p><p><div></p><p><p><span class="item-no">٣٤٢٣٨<span class="dash">-</span></span> قال <span class="name-3">سفيان الثوري</span>، في قوله: <span class="qpc-hafs">﴿دعواهم فيها سبحانك اللهم﴾</span>، قال: إذا اشْتَهَوْا شيئًا قالوا: سُبْحانَك، اللَّهُمَّ. فإذا هو بين أيديهم{8}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَتَحِیَّتُهُمۡ فِیهَا سَلَـٰمࣱۚ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٤٢٣٩<span class="dash">-</span></span> عن <span class="name-3">الفضل الرقاشي</span> -من طريق مروان العقيلي- فقال: <span class="qpc-hafs">﴿وتحيتهم فيها سلام وآخر دعواهم أن الحمد لله رب العالمين﴾</span>، قال: فيتَجَلّى لهم، فيَخِرُّون له سُجَّدًا، ويقولون: سبحانك، اللهم. وتحيتهم بالسلام، فإذا انصرف عنهم قالوا: الحمد لله رب العالمين{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤٢٤٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وتَحِيَّتُهُمْ فِيها سَلامٌ﴾</span>، وذلك أن يأتيه مَلَك مِن عند ربِّ العِزَّة، فلا يَصِل إليه حتى يستأذن له حاجِبٌ، فيقوم بين يديه، فيقول: يا ولِيَّ الله، ربُّك يقرأُ عليك السلام. وذلك قوله تعالى: <span class="qpc-hafs">﴿وتَحِيَّتُهُمْ فِيها سَلامٌ﴾</span> مِن عند الرب تعالى، فإذا فرغوا من الطعام والشراب، قالوا: الحمد لله رب العالمين. وذلك قوله ﷿: <span class="qpc-hafs">﴿وآخِرُ دَعْواهُمْ أنِ الحَمْدُ لِلَّهِ رَبِّ العالَمِينَ﴾</span>{10}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَءَاخِرُ دَعۡوَىٰهُمۡ أَنِ ٱلۡحَمۡدُ لِلَّهِ رَبِّ ٱلۡعَـٰلَمِینَ ۝١٠﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٤٢٤١<span class="dash">-</span></span> عن <span class="name-2">ابن أبي الهُذَيلِ</span> -من طريق سفيان عن أبي سنان- قال: الحمدُ أولَ الكلام، وآخِرُ الكلام. ثم تلا: <span class="qpc-hafs">﴿وآخِرُ دَعْواهُمْ أنِ الحَمْدُ لِلَّهِ رَبِ العالمَينَ﴾</span>{11}. (٧/٦٣٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤٢٤٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وآخِرُ دَعْواهُمْ﴾</span> يعني: قولهم حين فرغوا من الطعام والشراب: <span class="qpc-hafs">﴿أنِ الحَمْدُ لِلَّهِ رَبِّ العالَمِينَ﴾</span>{12}. (ز)</p></p><p></div></p></div>",footnotes:1:عزاه السيوطي إلى ابن مردويه.أخرجه ابن جرير ١٢/١٢٦. وعزاه السيوطي إلى أبي الشيخ.أخرجه ابن أبي حاتم ٦/١٩٢٩-١٩٣٠.ذكر المحقق أن العبارة في نسخة بلفظ:«يُشك».تفسير مقاتل بن سليمان ٢/٢٢٧-٢٢٨.أخرجه ابن أبي حاتم ٦/١٩٣٠.أخرجه ابن جرير ١٢/١٢٦. وعزاه السيوطي إلى ابن المنذر، وأبي الشيخ.تفسير سفيان الثوري ص١٢٨، وأخرجه ابن جرير ١٢/١٢٧ بلفظ: إذا أرادوا الشيء قالوا: اللهم، فيأتيهم ما دعوا به، وابن أبي حاتم ٦/١٩٣٠ بنحوه.أخرجه ابن أبي حاتم ٦/١٩٣٠.تفسير مقاتل بن سليمان ٢/٢٢٨-٢٢٩.أخرجه ابن أبي حاتم ٦/١٩٣١. وعزاه السيوطي إلى أبي الشيخ. وعند ابن أبي حاتم أن سفيان تلا الآية.تفسير مقاتل بن سليمان ٢/٢٢٩.
  10,11,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَلَوۡ یُعَجِّلُ ٱللَّهُ لِلنَّاسِ ٱلشَّرَّ ٱسۡتِعۡجَالَهُم بِٱلۡخَیۡرِ لَقُضِیَ إِلَیۡهِمۡ أَجَلُهُمۡۖ﴾</span> - نزول الآية</h3></p><p><div></p><p><p><span class="item-no">٣٤٢٤٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ولَوْ يُعَجِّلُ اللَّهُ لِلنّاسِ الشَّرَّ اسْتِعْجالَهُمْ بِالخَيْرِ﴾</span>، وذلك حين قال النضر بن الحارث: <span class="qpc-hafs">﴿فَأَمْطِرْ عَلَيْنا حِجارَةً مِنَ السَّماءِ أوِ ائْتِنا بِعَذابٍ ألِيمٍ﴾</span> [الأنفال:٣٢] فيصيبنا. فأنزل الله ﷿: <span class="qpc-hafs">﴿ولَوْ يُعَجِّلُ اللَّهُ لِلنّاسِ الشَّرَّ اسْتِعْجالَهُمْ بِالخَيْرِ﴾</span>{1}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَلَوۡ یُعَجِّلُ ٱللَّهُ لِلنَّاسِ ٱلشَّرَّ ٱسۡتِعۡجَالَهُم بِٱلۡخَیۡرِ لَقُضِیَ إِلَیۡهِمۡ أَجَلُهُمۡۖ﴾</span> - تفسير الآية</h3></p><p><div></p><p><p><span class="item-no">٣٤٢٤٤<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، قال: <span class="qpc-hafs">﴿ولَوْ يُعَجِّلُ اللَّهُ لِلنّاسِ الشَّرَّ اسْتِعْجالَهُمْ بِالخَيْرِ﴾</span>، هذا في قول الرجل عند الغضب لأهله وولده: لعنكم الله، ولا بارك فيكم{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤٢٤٥<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span> -من طريق سالم- <span class="qpc-hafs">﴿ولَو يُعَجِلُ الله لِلناسِ الشَّرَّ اسْتِعْجالَهُم بِالخَيْرِ﴾</span>، قال: قولُ الرجلِ للرجلِ: اللَّهُمْ أخْزِه، اللَّهُمَّ العَنْه. قال: وهو يُحِبُّ أن يُستجابَ له، كما يُحِبُّ: اللَّهُمَّ اغفِرْ له، اللَّهُمَّ ارْحَمْه{3}. (٧/٦٣٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤٢٤٦<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نَجِيح- في قوله: <span class="qpc-hafs">﴿ولَو يُعَجِلُ الله لِلناسِ الشَّرَّ اسْتِعْجالَهُم بِالخَيْرِ﴾</span> قال: هو قولُ الإنسانِ لولدِه ومالِه إذا غضِب عليه: اللَّهُمَّ، لا تُبارِكْ فيه، والعَنْه. <span class="qpc-hafs">﴿لَقُضِيَ إلَيهِم أجَلُهُم﴾</span> قال: لَأهلَك مَن دعا عليه، ولَأَماتَه. وفي رواية: فلو يُعجِّل الله الاستجابة لهم في ذلك كما يُستجاب في الخير لأَهْلَكَهم {4}. (٧/٦٣٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤٢٤٧<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق مَعْمَر- في الآية، قال: هو دعاءُ الرجلِ على نفسِه ومالِه بما يَكْرَهُ أن يُستَجابَ له{5}. (٧/٦٣٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤٢٤٨<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ولَوْ يُعَجِّلُ اللَّهُ لِلنّاسِ الشَّرَّ اسْتِعْجالَهُمْ بِالخَيْرِ﴾</span> إذا أرادوه فأصابوه، يقول الله: ولو استجيب لهم في الشَّرِّ كما يُحِبُّون أن يستجاب لهم في الخير؛ <span class="qpc-hafs">﴿لَقُضِيَ إلَيْهِمْ أجَلُهُمْ﴾</span> في الدنيا بالهلاك إذًا، ... وأيضًا <span class="qpc-hafs">﴿ولو يعجّل الله للناس﴾</span> يقول: ابنُ آدم يدعو لنفسه بالخير، ويُحِبُّ أن يُعَجِّل اللهُ ذلك، ويدعو على نفسه بالشر، يقول: اللَّهُمَّ، إن كنت صادقًا فافعل كذا وكذا. فلو يُعَجِّل اللهُ ذلك <span class="qpc-hafs">﴿لُقضي إليهم أجلهم﴾</span> يعني: العذاب، <span class="qpc-hafs">﴿فَنَذَرُ﴾</span> يعني: فنترك <span class="qpc-hafs">﴿الَّذِينَ لا يَرْجُونَ لِقاءَنا﴾</span> يعني: لا يخشون لقاءنا{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤٢٤٩<span class="dash">-</span></span> قال <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿لقضي إليهم أجلهم﴾</span>، قال: لَأهلَكْناهم. وقرأ: <span class="qpc-hafs">﴿ما ترك على ظهرها من دابة﴾</span> [النحل:٦١]. قال: يُهْلِكُهم كلَّهم{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤٢٥٠<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: المعنى: لو عَجَّل اللهُ للناسِ الشَّرَّ إذا دَعَوْا به على أنفسهم عند الغضب، وعلى أهليهم وأولادهم، واستعجلوا به كما يستعجلونه بالخير إذا سألوه إيّاه{8}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَلَوۡ یُعَجِّلُ ٱللَّهُ لِلنَّاسِ ٱلشَّرَّ ٱسۡتِعۡجَالَهُم بِٱلۡخَیۡرِ لَقُضِیَ إِلَیۡهِمۡ أَجَلُهُمۡۖ﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٣٤٢٥١<span class="dash">-</span></span> عن <span class="name-2">شَهْر بن حَوْشَب</span>، قال: قرأتُ في بعض الكُتُب: أنّ الله تعالى يقول للمَلَكَين الموكلين: لا تكتبا على عبدي في حال ضَجَرِه شيئًا{9}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿فَنَذَرُ ٱلَّذِینَ لَا یَرۡجُونَ لِقَاۤءَنَا﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٤٢٥٢<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق عبد الملك ابن جُرَيْج- قوله: <span class="qpc-hafs">﴿فنذر الذين لا يرجون لقاءنا﴾</span>، قال: يقول: لا نُهْلِك أهلَ الشرك، ولكن نذرهم في طغيانهم يعمهون{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤٢٥٣<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد بن أبي عروبة- <span class="qpc-hafs">﴿الذين لا يرجون لقاءنا﴾</span>: مُشرِكي أهلِ مكَّة{11}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤٢٥٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فَنَذَرُ الَّذِينَ لا يَرْجُونَ لِقاءَنا﴾</span> فنذرهم لا يخرجون أبدًا، فذلك قوله: <span class="qpc-hafs">﴿فِي طُغْيانِهِمْ يَعْمَهُونَ﴾</span>{12}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿فِی طُغۡیَـٰنِهِمۡ یَعۡمَهُونَ ۝١١﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٤٢٥٥<span class="dash">-</span></span> عن <span class="name-2">أبي العالية الرِّياحِيِّ</span> -من طريق الربيع- <span class="qpc-hafs">﴿في طغيانهم﴾</span>، يعني: في ضلالهم{11}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤٢٥٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فِي طُغْيانِهِمْ يَعْمَهُونَ﴾</span>، يعني: في ضلالتهم يَتَرَدَّدون، لا يخرجون منها إلا أن يخرجهم الله ﷿{12}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٢/٢٢٩.تفسير البغوي ٤/١٢٣.أخرجه ابن أبي حاتم ٦/١٩٣٢ بنحوه. وعزاه السيوطي إلى أبي الشيخ.تفسير مجاهد ص٣٧٩، وأخرجه ابن جرير ١٢/١٣٠-١٣١، وابن أبي حاتم ٦/١٩٣٢. وعزاه السيوطي إلى ابن أبي شيبة، وابن المنذر، وأبي الشيخ.أخرجه ابن جرير ١٢/١٣١، وابن أبي حاتم ٦/١٩٣٢.تفسير مقاتل بن سليمان ٢/٢٢٩.أخرجه ابن جرير ١٢/١٣١.تفسير ابن أبي زمنين ٢/٢٤٦.تفسير الثعلبي ٥/١٢٢.أخرجه ابن جرير ١٢/١٣١.أخرجه ابن أبي حاتم ٦/١٩٣٢.تفسير مقاتل بن سليمان ٢/٢٢٩-٢٣٠.أخرجه ابن أبي حاتم ٦/١٩٣٢.تفسير مقاتل بن سليمان ٢/٢٢٩-٢٣٠.
  10,12,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَإِذَا مَسَّ ٱلۡإِنسَـٰنَ ٱلضُّرُّ دَعَانَا لِجَنۢبِهِۦۤ أَوۡ قَاعِدًا أَوۡ قَاۤىِٕمࣰا﴾</span> الآية - نزول الآية</h3></p><p><div></p><p><p><span class="item-no">٣٤٢٥٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وإذا مَسَّ الإنْسانَ الضُّرُّ﴾</span>، نزلت في أبي حذيفة، اسمه: هاشم بن المغيرة بن عبد الله المخزومي{1}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَإِذَا مَسَّ ٱلۡإِنسَـٰنَ ٱلضُّرُّ دَعَانَا لِجَنۢبِهِۦۤ أَوۡ قَاعِدًا أَوۡ قَاۤىِٕمࣰا﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٤٢٥٨<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق مَعْمَر- قال: إذا مسَّهُمُ الضُّرُّ أخْلَصوا لله الدعاءَ{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤٢٥٩<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span>، في قوله: <span class="qpc-hafs">﴿دَعانا لِجَنبِهِ أو قاعِدًا أو قَآئِمًا﴾</span>، قال: على كلِّ حالٍ{3}. (٧/٦٣٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤٢٦٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وإذا مَسَّ الإنْسانَ الضُّرُّ﴾</span> يعني: المرض؛ بلاء أو شدة، <span class="qpc-hafs">﴿دَعانا لِجَنْبِهِ﴾</span> يعني: لمضجعه في مرضه، <span class="qpc-hafs">﴿أوْ﴾</span> دعانا <span class="qpc-hafs">﴿قاعِدًا أوْ قائِمًا﴾</span> كل ذلك لِما كان{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤٢٦١<span class="dash">-</span></span> عن <span class="name-3">عبد الملك ابن جُرَيْج</span> -من طريق حجّاج- في قوله: <span class="qpc-hafs">﴿دَعانا لِجَنبِهِ﴾</span>، قال: مُضطجِعًا{5}. (٧/٦٣٦)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿فَلَمَّا كَشَفۡنَا عَنۡهُ ضُرَّهُۥ مَرَّ كَأَن لَّمۡ یَدۡعُنَاۤ إِلَىٰ ضُرࣲّ مَّسَّهُۥۚ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٤٢٦٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فَلَمّا كَشَفْنا عَنْهُ ضُرَّهُ﴾</span> وعُوفِي مِن مرضه؛ <span class="qpc-hafs">﴿مَرَّ﴾</span> يعني: اسْتَمَرَّ، أي: أعْرَض عن الدعاء، <span class="qpc-hafs">﴿كَأَنْ لَمْ يَدْعُنا إلى ضُرٍّ مَسَّهُ﴾</span> ولا يزال يدعونا ما احتاج إلى ربِّه، فإذا أُعْطِي حاجتَه أمْسَك عن الدعاء، قال الله تعالى عند ذلك: اسْتَغْنى عبدي{1}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿كَذَ ٰ⁠لِكَ زُیِّنَ لِلۡمُسۡرِفِینَ مَا كَانُوا۟ یَعۡمَلُونَ ۝١٢﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٤٢٦٣<span class="dash">-</span></span> عن عباد بن منصور، قال: سألتُ <span class="name-2">الحسن [البصري]</span> عن قوله: <span class="qpc-hafs">﴿زُيِّنَ﴾</span>. قال: زَيَّن لهم الشيطان{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤٢٦٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿كَذلِكَ﴾</span> يعني: هكذا <span class="qpc-hafs">﴿زُيِّنَ لِلْمُسْرِفِينَ﴾</span> يعني: المشركين <span class="qpc-hafs">﴿ما كانُوا يَعْمَلُونَ﴾</span> مِن أعمالهم السيئة، يعني: الدُّعاء في الشِّدَّة{1}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿كَذَ ٰ⁠لِكَ زُیِّنَ لِلۡمُسۡرِفِینَ مَا كَانُوا۟ یَعۡمَلُونَ ۝١٢﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٣٤٢٦٥<span class="dash">-</span></span> عن أبي الدَّرداء، قال: ادعُ اللهَ يومَ سَرّائِك يَستَجِبْ لك يومَ ضرّائِك{3}. (٧/٦٣٧)</p></p><p></div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٢/٢٣٠.أخرجه ابن أبي حاتم ٦/١٩٣٣.عزاه السيوطي إلى أبي الشيخ.تفسير مقاتل بن سليمان ٢/٢٣٠.أخرجه ابن جرير ١٢/١٣٣. وعزاه السيوطي إلى ابن المنذر.تفسير مقاتل بن سليمان ٢/٢٣٠.أخرجه ابن أبي حاتم ٦/١٩٣٣.تفسير مقاتل بن سليمان ٢/٢٣٠.عزاه السيوطي إلى أبي الشيخ.
  10,13,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَلَقَدۡ أَهۡلَكۡنَا ٱلۡقُرُونَ مِن قَبۡلِكُمۡ لَمَّا ظَلَمُوا۟ وَجَاۤءَتۡهُمۡ رُسُلُهُم بِٱلۡبَیِّنَـٰتِ وَمَا كَانُوا۟ لِیُؤۡمِنُوا۟ۚ كَذَ ٰ⁠لِكَ نَجۡزِی ٱلۡقَوۡمَ ٱلۡمُجۡرِمِینَ ۝١٣﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٤٢٦٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ولَقَدْ أهْلَكْنا القُرُونَ﴾</span> بالعذاب في الدُّنيا <span class="qpc-hafs">﴿مِن قَبْلِكُمْ﴾</span> يا أهل مكة <span class="qpc-hafs">﴿لَمّا ظَلَمُوا﴾</span> يعني: حين أشركوا. يُخَوِّفُ كُفّارَ مكة بمثل عذاب الأُمَم الخالية؛ لكي لا يُكَذِّبوا محمدًا ﷺ، <span class="qpc-hafs">﴿وجاءَتْهُمْ رُسُلُهُمْ بِالبَيِّناتِ﴾</span> يقول: أخبرتهم رسلُهم بالعذاب أنّه نازل بهم في الدنيا، ثم قال: <span class="qpc-hafs">﴿وما كانُوا لِيُؤْمِنُوا﴾</span> يقول: ما كان كفار مكة لِيُصَدِّقوا بنزول العذاب بهم في الدنيا، <span class="qpc-hafs">﴿كَذلِكَ﴾</span> يعني: هكذا <span class="qpc-hafs">﴿نَجْزِي﴾</span> بالعذاب <span class="qpc-hafs">﴿القَوْمَ المُجْرِمِينَ﴾</span> يعني: مُشركي الأُمَم الخالية{1}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٢/٢٣٠.
  10,14,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿ثُمَّ جَعَلۡنَـٰكُمۡ خَلَـٰۤىِٕفَ فِی ٱلۡأَرۡضِ مِنۢ بَعۡدِهِمۡ لِنَنظُرَ كَیۡفَ تَعۡمَلُونَ ۝١٤﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٤٢٦٧<span class="dash">-</span></span> عن قتادة بن دعامة، في قوله: <span class="qpc-hafs">﴿ثُمَّ جَعَلْنَكُمْ خَلائِفَ في الأرضِ مِن بَعدِهِم لِنَنظُرَ كَيْفَ تَعْمَلُونَ﴾</span>، قال: ذُكِر لنا: أنّ <span class="name-1">عمر بن الخطاب</span> قرَأ هذه الآية، فقال: صدَق ربُّنا، ما جعَلَنا خلائفَ في الأرضِ إلا لينظرَ إلى أعمالِنا؛ فأرُوا الله خيرَ أعمالِكم بالليلِ والنهارِ، والسِّرِّ والعلانيةِ{1}. (٧/٦٣٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤٢٦٨<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ثُمَّ جَعَلْناكُمْ﴾</span> يا أُمَّة محمد <span class="qpc-hafs">﴿خَلائِفَ فِي الأَرْضِ مِن بَعْدِهِمْ لِنَنْظُرَ كَيْفَ تَعْمَلُونَ﴾</span>{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤٢٦٩<span class="dash">-</span></span> عن <span class="name-3">عبد الملك ابن جُرَيْج</span>، في قوله: <span class="qpc-hafs">﴿ثُمَّ جَعَلْنَكُمْ خَلائِفَ﴾</span> لِأُمَّةِ محمد ﷺ{3}. (٧/٦٣٧)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿ثُمَّ جَعَلۡنَـٰكُمۡ خَلَـٰۤىِٕفَ فِی ٱلۡأَرۡضِ مِنۢ بَعۡدِهِمۡ لِنَنظُرَ كَیۡفَ تَعۡمَلُونَ ۝١٤﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٣٤٢٧٠<span class="dash">-</span></span> عن عبد الرحمن بن أبي ليلى: أنّ <span class="name-1">عوف بن مالك</span> قال لأبي بكر: رأيتُ فيما يرى النائمُ كأنّ سَبَبًا{4} دُلِّيَ مِن السماء، فانتشطَ{5} رسولُ الله ﷺ، ثم دُلِّيَ فانتشطَ أبو بكر، ثم ذَرَعَ{6} الناسُ حول المنبر، فَفَضُلَ عمر بثلاث أذْرُعٍ إلى المنبر. فقال عمر: دَعْنا مِن رؤياك، لا أرَبَ لنا فيها. فلما استُخْلِف عمر، قال: يا عوف، رؤياك. قال: وهل لك في رُؤياي مِن حاجة؟ أوَلَمْ تَنتَهِرْني؟! قال: ويْحَك، إنِّي كرهت أن تنعي لخليفة رسولِ الله ﷺ نفسَه. فقصَّ عليه الرؤيا، حتى إذا بلغ: ذرع الناس إلى المنبر بهذه الثلاث الأذرع. قال: أمّا إحداهُنَّ فإنّه كائن خليفةً، وأمّا الثانية فإنّه لا يخافُ في الله لومة لائم، وأمّا الثالثة فإنّه شهيد. قال: فقال: يقول الله: <span class="qpc-hafs">﴿ثُمَّ جَعَلْناكُمْ خَلائِفَ فِي الأَرْضِ مِن بَعْدِهِمْ لِنَنْظُرَ كَيْفَ تَعْمَلُونَ﴾</span>، فقد اسْتُخْلِفْتَ، يا ابنَ أُمِّ عمر، فانظر كيف تعمل. وأمّا قوله: فإني لا أخاف في الله لومة لائم. فما شاء الله. وأمّا قوله: فإني شهيد. فأنّى لعمر الشهادة والمسلمون مُطيفون به؟! ثم قال: إنّ الله على ما يشاء قدير{7}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ١٢/١٣٤-١٣٥، وابن أبي حاتم ٦/١٩٣٤. وعزاه السيوطي إلى ابن المنذر، وأبي الشيخ.تفسير مقاتل بن سليمان ٢/٢٣٠.عزاه السيوطي إلى ابن المنذر.أي: حبلًا. النهاية (سبب).أي: جُذِب إلى السماء ورُفِعَ إليها. لسان العرب (نشط).الذَّرْعُ: بسط اليد ومدها، وأصله من الذراع وهو الساعد. النهاية (ذرع).أخرجه ابن جرير ١٢/١٣٥، وابن أبي حاتم ٦/١٩٣٤ مقتصرًا على الشاهد.