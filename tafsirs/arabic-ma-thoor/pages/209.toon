tafsir[8]{c,v,t}:
10,7," <q>﴿إِنَّ ٱلَّذِینَ لَا یَرۡجُونَ لِقَاۤءَنَا﴾</q> - تفسير ٣٤٢١٢- عن قتادة بن دعامة -من طريق سعيد- قوله: <q>﴿إن الذين لا يرجون لقاءنا ورضوا بالحياة الدنيا واطمأنوا بها والذين هم عن آياتنا غافلون﴾</q>، قال: إذا شئت رأيت صاحب دنيا، لها يفرح، ولها يحزن، ولها يرضى، ولها يسخط{1}٣٠٩٨. (ز) ٣٠٩٨ علَّق ابنُ عطية (٤/٤٥٤بتصرف) على قول قتادة بقوله: «فكأنّ قتادة صوَّرها في العُصاة، ولا يترتب ذلك إلا مع تأول الرجاء على بابه؛ إذ قد يكون العاصي المُجلِّح مستوحشًا من آخرته، فأمّا على تأويل الرجاء بالخوف فالمعنى: فمن لا يخاف لقاء الله فهو كافر». ٣٤٢١٣- قال مقاتل بن سليمان: <q>﴿إنَّ الَّذِينَ لا يَرْجُونَ لِقاءَنا﴾</q>، يعني: لا يخشون لقاءنا، يعني: البعث، والحساب{2}. (ز) ٣٤٢١٤- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿إنّ الَّذِينَ لا يَرجُونَ لِقَآءَنا ورَضُوا بِالحَياةِ الدُّنيا﴾</q> الآية كلَّها، قال: هؤلاء أهلُ الكفرِ{3}٣٠٩٩. (٧/٦٣٢) ٣٠٩٩ ذكر ابنُ عطية (٤/٤٥٤) أنّ المهدويَّ حكى عن بعض أهل اللغة: أنّ لفظة الرجاء إذا جاءت منفيَّة فإنها تكون بمعنى: الخوف، وحكي عن بعضهم أنّها تكون بمعناها في كل موضع تدل عليه قرائن ما قبله وما بعده، ثم علَّق بقوله: «فعلى هذا التأويل معنى الآية: إنّ الذين لا يخافون لقاءنا». ثُمَّ بيَّن أنّ بعض أهل العلم قال: إنّ الرجاء في هذه الآية على بابه، وذلك أنّ الكافر المُكَذِّب بالبعث ليس يرجو رحمةً في الآخرة، ولا يُحْسِن ظنًّا بأنّه يلقى الله، ولا له في الآخرة أمل، فإنّه لو كان له فيها أملٌ لَقارنه لا محالة خوفٌ، وهذه الحال من الخوف المقارن هي القائدة إلى النجاة«. ثم قال:»والذي أقول: إنّ الرجاء في كل موضع على بابه". <q>﴿وَرَضُوا۟ بِٱلۡحَیَوٰةِ ٱلدُّنۡیَا وَٱطۡمَأَنُّوا۟ بِهَا﴾</q> - تفسير ٣٤٢١٥- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿ورَضُوا بِالحَياةِ الدُّنيا واطمَأَنُّوا بِها﴾</q>، قال: مثل قوله: <q>﴿مَن كانَ يُرِيدُ الحَياةَ الدُّنْيا وزِينَتَها نُوَفِ إلَيهِم أعمالَهُم فِيها﴾</q> الآية [هود:١٥]{4}. (٧/٦٣٢) ٣٤٢١٦- عن الحسن البصري -من طريق حَوْشَب- في قوله: <q>﴿إنّ الَّذِينَ لا يَرجُونَ لِقَآءَنا ورَضُوا بِالحَياةِ الدُّنيا واطمَأَنُّوا بِها﴾</q>، قال: واللهِ، ما زَيَّنوها ولا رفعوها حتى رَضُوا بها{5}. (ز) ٣٤٢١٧- قال مقاتل بن سليمان: <q>﴿ورَضُوا بِالحَياةِ الدُّنْيا واطْمَأَنُّوا بِها﴾</q> فعمِلوا لها، <q>﴿والَّذِينَ هُمْ عَنْ آياتِنا﴾</q> يعني: ما أخبر في أول هذه السورة <q>﴿غافِلُونَ﴾</q> يعني: ما ذُكِر من صنيعه في هؤلاء الآيات لَمُعْرِضون، فلا يؤمنون{2}. (ز) <q>﴿وَٱلَّذِینَ هُمۡ عَنۡ ءَایَـٰتِنَا غَـٰفِلُونَ ۝٧﴾</q> - تفسير ٣٤٢١٨- عن عبد الله بن عباس: <q>﴿والَّذِينَ هُمْ عَنْ آياتِنا﴾</q>: محمد، والقرآن{7}. (ز) ",footnotes:1:أخرجه ابن جرير ١٢/١٢٢، وابن أبي حاتم ٦/١٩٢٨.تفسير مقاتل بن سليمان ٢/٢٢٧.أخرجه ابن جرير ١٢/١٢٢-١٢٣. وعزاه السيوطي إلى أبي الشيخ.تفسير مجاهد ص٣٧٩، وأخرجه ابن جرير ١٢/١٢٢، وابن أبي حاتم ٦/١٩٢٨.أخرجه ابن أبي حاتم ٦/١٩٢٨.تفسير مقاتل بن سليمان ٢/٢٢٧.تفسير الثعلبي ٥/١٢٠، وتفسير البغوي ٤/١٢٢.
10,8," <q>﴿أُو۟لَـٰۤىِٕكَ مَأۡوَىٰهُمُ ٱلنَّارُ بِمَا كَانُوا۟ یَكۡسِبُونَ ۝٨﴾</q> - تفسير ٣٤٢١٩- قال مقاتل بن سليمان: <q>﴿أُولئِكَ مَأْواهُمُ النّارُ﴾</q> يعني: مصيرهم النار؛ <q>﴿بِما كانُوا يَكْسِبُونَ﴾</q> من الكفر، والتَّكذيب{1}. (ز) <q>﴿أُو۟لَـٰۤىِٕكَ مَأۡوَىٰهُمُ ٱلنَّارُ بِمَا كَانُوا۟ یَكۡسِبُونَ ۝٨﴾</q> - آثار متعلقة بالآية ٣٤٢٢٠- عن يوسف بن أسباط، قال: الدنيا دارُ نعيمِ الظالمين.= (ز) ٣٤٢٢١- قال: وقال عليُّ بن أبي طالب: الدنيا جِيفَةٌ، فمَن أرادها فلْيَصْبِرْ على مخالطةِ الكلابِ{2}٣١٠٠. (٧/٦٣٢) ٣١٠٠ ذكر ابنُ عطية (٤/٤٥٤) أنّ قوله: <q>﴿والذين هم عن آياتنا غافلون﴾</q> يحتمل أن يكون ابتداء إشارة إلى فرقة أخرى من الكفار، ثم علَّق بقوله: «وهؤلاء -على هذا التأويل- أهلُ صفقةٍ؛ لأنهم ليسوا أهل دنيا، بل غفلة فقط». ",footnotes:1:تفسير مقاتل بن سليمان ٢/٢٢٧.عزاه السيوطي إلى أبي الشيخ.
10,9," <q>﴿إِنَّ ٱلَّذِینَ ءَامَنُوا۟ وَعَمِلُوا۟ ٱلصَّـٰلِحَـٰتِ یَهۡدِیهِمۡ رَبُّهُم بِإِیمَـٰنِهِمۡۖ﴾</q> - تفسير ٣٤٢٢٢- عن قتادة، في قوله: <q>﴿يَهدِيهِم رَبُّهُم بِإيِمانِهِم﴾</q>، قال: حدَّثنا الحسن، قال: بلَغَنا: أنّ النبيَّ ﷺ قال: «إنّ المؤمن إذا خرَج من قبرِه صُوِّر له عملُه في صورةٍ حسنة، وريحٍ طيِّبة، فيقول له: ما أنت؟ فواللهِ، إنِّي لأراك عينَ امرئ صدق. فيقول: أنا عَمَلُك. فيكون له نورًا، وقائدًا إلى الجنة، وأمّا الكافرُ فإذا خرَج من قبرِه صُوِّر له عملُه في صورةٍ سيئة، وريح مُنتِنة، فيقول له: ما أنت؟ فواللهِ، إنِّي لَأراك عينَ امرئ سوءٍ. فيقول: أنا عملُك. فيَنطلِقُ به حتى يُدخِلَه النارَ»{1}. (٧/٦٣٣) ٣٤٢٢٣- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿يَهدِيهِم رَبُّهُم بِإيِمانِهِم﴾</q>، قال: يكونُ لهم نورًا يَمشون به{2}٣١٠١. (٧/٦٣٣) ٣١٠١ علَّق ابنُ عطية (٤/٤٥٥) على قول مجاهد بقوله: «ويَتَرَكَّب هذا التأويلُ على ما رُوِي عن النبي ﷺ: «إنّ العبد المؤمن إذا قام من قبره للحشر تَمَثَّل له رجلٌ جميل الوجه، طيّب الرائحة، فيقول: مَن أنت؟ فيقول: أنا عملك الصالح. فيقوده إلى الجنة». وبعكس هذا في الكافر». وذكر ابنُ كثير (٧/٣٣٧) أنّ الباء على قول مجاهد للاستعانة، وأنّها تحتمل أن تكون سببية، والتقدير: بسبب إيمانهم في الدنيا يهديهم الله يوم القيامة على الصراط، حتى يجوزوه ويخلصوا إلى الجنة. ٣٤٢٢٤- وعن قتادة بن دعامة، مثلَه{3}. (٧/٦٣٣) ٣٤٢٢٥- قال عطية بن سعد العوفي: <q>﴿يَهدِيهِم رَبُّهُم بِإيِمانِهِم﴾</q>، يهديهم، ويُثِيبهم، ويجزيهم{4}. (ز) ٣٤٢٢٦- عن الربيع بن أنس، في قوله: <q>﴿يَهدِيهِم رَبُّهُم بِإيِمانِهِم﴾</q>، قال: حتى يُدخلَهم الجنة، فحدث أصحابُ النبي ﷺ: لَأحدُهم يومَئذٍ أعلمُ بمنزلِه منكم اليومَ بمنزلِنا. ثم ذكر عن العلماء: أنّه أنزَلهم الجنة سبعةَ منازلَ، لكلِّ منزلٍ من تلك المنازلِ أهلُها في سبعِ فضائلَ، فقال النبي ﷺ: «يُسعى عليهم بما سأَلوا، وبما خطَر على أنفسهم، حتى إذا امْتَلَؤوا كان طعامُهم ذلك جُشاءً، وريحَ المسك، ليس فيها حَدَثٌ، ثم أُلهِموا الحمدَ، والتسبيحَ، كما أُلهِموا النفَسَ، ثم يَجتنِي فاكهتَها قائمًا، وقاعدًا، ومتكِئًا، على أيِّ حالٍ كان عليه، ثم لا تَصِلُ إلى فيه حتى تعودَ كما كانت، إنّها بَركةُ الرحمن، وبَركةُ الرحمنِ لا تَفنى، وهي الخزائنُ التي لا تَنقطِعُ أبدًا، ما أُخِذ منها لم يَنقُصْ، وما تُرِك منها لم يفسُدْ»{3}. (٧/٦٣٤) ٣٤٢٢٧- قال أبو رَوْق عطية بن الحارث الهمداني: <q>﴿يهديهم ربهم بإيمانهم﴾</q> إلى الجنة{4}. (ز) ٣٤٢٢٨- قال مقاتل بن سليمان: <q>﴿إنَّ الَّذِينَ آمَنُوا﴾</q> يعني: صدَّقوا بالله، <q>﴿وعَمِلُوا الصّالِحاتِ﴾</q>، وأقاموا فرائض الله؛ <q>﴿يَهْدِيهِمْ رَبُّهُمْ بِإيمانِهِمْ﴾</q> يعني: بتصديقهم، وتوحيدهم، كما صدّقوا ووحَّدوا كذلك يهديهم ربهم إلى الفرائض، ويثيبهم الجنَّة{7}. (ز) ٣٤٢٢٩- عن عبد الملك ابن جُرَيْج، في قوله: <q>﴿يَهدِيهِم رَبُّهُم بِإيِمانِهِم﴾</q>، قال: يُمثَّلُ له عملُه في صورةٍ حسنةٍ، وريحٍ طيبةٍ، يعارِضُ صاحبَه، ويُبَشِّره بكلِّ خير، فيقول: مَن أنت؟ فيقول: أنا عملك الصالح. فيجعلُ له نورًا مِن بين يديه حتى يُدخِلَه الجنةَ، والكافرَ يُمثَّلُ له عملُه في صورة سيئة، وريح مُنتِنة، فيُلازِمُ صاحبَه حتى يَقذِفَه في النار{8}٣١٠٢. (٧/٦٣٣) ٣١٠٢ ذكر ابنُ عطية (٤/٤٥٥) أنّ قوله: <q>﴿بإيمانهم﴾</q> يحتمل احتمالين: الأول: أن يريد بسبب إيمانهم، ويكون مقابلًا لقوله قبل: <q>﴿مأواهم النار بما كانوا يكسبون﴾</q>. الثاني: أن يكون الإيمان هو نفس الهدى، أي: يهديهم إلى طرق الجنة بنور إيمانهم. <q>﴿تَجۡرِی مِن تَحۡتِهِمُ ٱلۡأَنۡهَـٰرُ﴾</q> - تفسير ٣٤٢٣٠- عن أبي مالك غزوان الغفاري -من طريق إسماعيل السدي- قوله: <q>﴿تجري من تحتهم الأنهار﴾</q>، يعني: تحت منازلهم، وأرضِهم{9}. (ز) ٣٤٢٣١- قال مقاتل بن سليمان: <q>﴿تَجْرِي مِن تَحْتِهِمُ الأَنْهارُ﴾</q> يعني: تحت قصورهم، نور في نور، قصور الدُّرِّ والياقوت، وأنها تجري من غرفهم، <q>﴿فِي جَنّاتِ النَّعِيمِ﴾</q> لا يُكَلَّفون فيها عملًا أبدًا، ولا يُصِيبهم فيها مَشَقَّةٌ أبدًا{7}. (ز) ",footnotes:1:أخرجه ابن جرير ١٢/١٢٣-١٢٤، وابن أبي حاتم ٦/١٩٢٩ (١٠٢٣٧).تفسير مجاهد ص٣٧٩، وأخرجه ابن جرير ١٢/١٢٤، وابن أبي حاتم ٦/١٩٢٩. وعزاه السيوطي إلى ابن أبي شيبة، وابن المنذر.عزاه السيوطي إلى أبي الشيخ.تفسير الثعلبي ٥/١٢٠.عزاه السيوطي إلى أبي الشيخ.تفسير الثعلبي ٥/١٢٠.تفسير مقاتل بن سليمان ٢/٢٢٧.علَّقه ابن جرير ١٢/١٢٤-١٢٥. وعزاه السيوطي إلى ابن المنذر، وأبي الشيخ.أخرجه ابن أبي حاتم ٦/١٩٢٩.تفسير مقاتل بن سليمان ٢/٢٢٧.
10,10," <q>﴿دَعۡوَىٰهُمۡ فِیهَا سُبۡحَـٰنَكَ ٱللَّهُمَّ﴾</q> - تفسير ٣٤٢٣٢- عن أُبَيِّ بن كعب، قال: قال رسول الله ﷺ: «إذا قالوا: سبحانَك اللهم. أتاهم ما اشتَهَوا من الجنةِ مِن ربِّهم»{1}. (٧/٦٣٤) ٣٤٢٣٣- عن قتادة بن دِعامة -من طريق سعيد- في قوله: <q>﴿دَعواهُمْ فِيها سُبْحانَكَ اللَّهُمَّ﴾</q>، قال: يكونُ ذلك قولَهم فيها{2}. (٧/٦٣٥) ٣٤٢٣٤- عن الربيع بن أنس -من طريق سليمان بن علي- قال: أهلُ الجنةِ إذا اشتهَوا شيئًا قالوا: سبحانَك اللهمَّ وبحمدِك. فإذا هو عندَهم، فذلك قوله: <q>﴿دَعواهُمْ فِيها سُبْحانَكَ اللَّهُمَّ﴾</q>{3}. (٧/٦٣٥) ٣٤٢٣٥- قال مقاتل بن سليمان: <q>﴿دَعْواهُمْ فِيها سُبْحانَكَ اللَّهُمَّ﴾</q> فهذا عَلَمٌ بين أهل الجنة وبين الخدم؛ إذا أرادوا الطعام والشراب دعواهم أن يقولوا في الجنة: <q>﴿سُبْحانَكَ اللَّهُمَّ﴾</q>. فإذا الموائد قد جاءت، فوُضعت مِيلًا في ميل، قوائمها اللؤلؤ، ودخل عليهم الخدم من أربعة آلاف باب، معهم صِحاف الذَّهب، سبعون ألف صَحْفَة، في كل صَحْفَة لَوْنٌ مِن الطعام، ليس في صاحبتها مثله، كُلَّما شَبِع ألقى اللهُ عليه ألفَ بابٍ مِن الشهوة، كُلَّما شَبِع أُتِي بِشَرْبَةٍ تهضم ما قبلها بمقدار أربعين عامًا، ويُؤْتَون بألوان الثمار، وتجيء الطير أمثال البخت، مناقيرها لون، وأجنحتها لون، وظهورها لون، وبطونها لون، وقوائِمها لون، تَتَلَأْلَأُ نورًا، حتى تقف بين يديه، في بيتٍ طوله فَرْسَخ في فَرْسَخ، في غرفة فيها سُرُر مَوْضُونَة، والوَضْن: مشبك{4} وسطه بقُضْبان الياقوت والزُّمُرُّد الرطب، ألين من الحرير، قوائمها اللؤلؤ، حافَتاه ذهب وفضة، عليه مِن الفُرُش مقدارُ سبعين غرفة في دار الدنيا، لو أنّ رجلًا وقَع من تلك الغُرَف لم يبلغ قرار الأرض سبعين عامًا، فيأكلون، ويشربون، وتقوم الطير، وتَصْطَفُّ بين يديه، وتقول: يا ولِيَّ الله، رَعَيْتَ في رَوْضَة كذا وكذا، وشربتَ مِن عين كذا وكذا، فأيَّتهُنَّ أعجبه وصفُها وقَعَتْ على مائدته، نِصْفُها قديد، سبعون ألف لون من الطير الواحد، والنِّصْف شِواء، فيأكل منها ما أحبَّ، ثم يطير، فينطلق إلى الجنة؛ لأنه ليس في الجنة مَن يموت{5}. (ز) ٣٤٢٣٦- عن مقاتل بن حيان -من طريق شبيب بن عبد الملك- قال: إنّ أهل الجنة إذا دَعَوا بالطعامِ قالوا: سُبحانَك، اللهمَّ. فيقومُ على أحدِهم عشَرةُ آلاف خادم، مع كلِّ خادم صَحْفةٌ مِن ذهبٍ، فيها طعامٌ ليس في الأخرى، فيأكلُ مِنهُنَّ كُلِّهن{6}. (٧/٦٣٥) ٣٤٢٣٧- عن عبد الملك ابن جُرَيْج -من طريق حجاج- قال: أُخبِرتُ أنّ قوله: <q>﴿سُبْحانَكَ اللَّهُمَّ﴾</q> إذا مَرَّ بهم الطائرُ يشتهُونه قالوا: سبحانَك، اللهمَّ. ذلك دعاؤُهم به، فيأتِيهم الملَكُ بما اشْتَهَوا، فإذا جاء الملَكُ بما يشتهون، فيُسَلِّمُ عليهم، فيردُّون عليه، فذلك قولُه: <q>﴿وتَحِيَّتُهُمْ فِيها سَلامٌ﴾</q>. فإذا أكَلوا قَدْرَ حاجتِهم قالوا: الحمدُ لله ربِّ العالمين. فذلك قوله: <q>﴿وءاخِرُ دَعْواهُمْ أنِ الحَمْدُ لِلَّهِ رَبِ العالمَينَ﴾</q>{7}٣١٠٣. (٧/٦٣٥) ٣١٠٣ ذكر ابنُ عطية (٤/٤٥٦) أنّ بعض العلماء قال: «<q>﴿وتحيتهم﴾</q>، يريد: تسليم الله ﷿ عليهم». ٣٤٢٣٨- قال سفيان الثوري، في قوله: <q>﴿دعواهم فيها سبحانك اللهم﴾</q>، قال: إذا اشْتَهَوْا شيئًا قالوا: سُبْحانَك، اللَّهُمَّ. فإذا هو بين أيديهم{8}. (ز) <q>﴿وَتَحِیَّتُهُمۡ فِیهَا سَلَـٰمࣱۚ﴾</q> - تفسير ٣٤٢٣٩- عن الفضل الرقاشي -من طريق مروان العقيلي- فقال: <q>﴿وتحيتهم فيها سلام وآخر دعواهم أن الحمد لله رب العالمين﴾</q>، قال: فيتَجَلّى لهم، فيَخِرُّون له سُجَّدًا، ويقولون: سبحانك، اللهم. وتحيتهم بالسلام، فإذا انصرف عنهم قالوا: الحمد لله رب العالمين{6}. (ز) ٣٤٢٤٠- قال مقاتل بن سليمان: <q>﴿وتَحِيَّتُهُمْ فِيها سَلامٌ﴾</q>، وذلك أن يأتيه مَلَك مِن عند ربِّ العِزَّة، فلا يَصِل إليه حتى يستأذن له حاجِبٌ، فيقوم بين يديه، فيقول: يا ولِيَّ الله، ربُّك يقرأُ عليك السلام. وذلك قوله تعالى: <q>﴿وتَحِيَّتُهُمْ فِيها سَلامٌ﴾</q> مِن عند الرب تعالى، فإذا فرغوا من الطعام والشراب، قالوا: الحمد لله رب العالمين. وذلك قوله ﷿: <q>﴿وآخِرُ دَعْواهُمْ أنِ الحَمْدُ لِلَّهِ رَبِّ العالَمِينَ﴾</q>{10}. (ز) <q>﴿وَءَاخِرُ دَعۡوَىٰهُمۡ أَنِ ٱلۡحَمۡدُ لِلَّهِ رَبِّ ٱلۡعَـٰلَمِینَ ۝١٠﴾</q> - تفسير ٣٤٢٤١- عن ابن أبي الهُذَيلِ -من طريق سفيان عن أبي سنان- قال: الحمدُ أولَ الكلام، وآخِرُ الكلام. ثم تلا: <q>﴿وآخِرُ دَعْواهُمْ أنِ الحَمْدُ لِلَّهِ رَبِ العالمَينَ﴾</q>{11}. (٧/٦٣٦) ٣٤٢٤٢- قال مقاتل بن سليمان: <q>﴿وآخِرُ دَعْواهُمْ﴾</q> يعني: قولهم حين فرغوا من الطعام والشراب: <q>﴿أنِ الحَمْدُ لِلَّهِ رَبِّ العالَمِينَ﴾</q>{12}. (ز) ",footnotes:1:عزاه السيوطي إلى ابن مردويه.أخرجه ابن جرير ١٢/١٢٦. وعزاه السيوطي إلى أبي الشيخ.أخرجه ابن أبي حاتم ٦/١٩٢٩-١٩٣٠.ذكر المحقق أن العبارة في نسخة بلفظ:«يُشك».تفسير مقاتل بن سليمان ٢/٢٢٧-٢٢٨.أخرجه ابن أبي حاتم ٦/١٩٣٠.أخرجه ابن جرير ١٢/١٢٦. وعزاه السيوطي إلى ابن المنذر، وأبي الشيخ.تفسير سفيان الثوري ص١٢٨، وأخرجه ابن جرير ١٢/١٢٧ بلفظ: إذا أرادوا الشيء قالوا: اللهم، فيأتيهم ما دعوا به، وابن أبي حاتم ٦/١٩٣٠ بنحوه.أخرجه ابن أبي حاتم ٦/١٩٣٠.تفسير مقاتل بن سليمان ٢/٢٢٨-٢٢٩.أخرجه ابن أبي حاتم ٦/١٩٣١. وعزاه السيوطي إلى أبي الشيخ. وعند ابن أبي حاتم أن سفيان تلا الآية.تفسير مقاتل بن سليمان ٢/٢٢٩.
10,11," <q>﴿وَلَوۡ یُعَجِّلُ ٱللَّهُ لِلنَّاسِ ٱلشَّرَّ ٱسۡتِعۡجَالَهُم بِٱلۡخَیۡرِ لَقُضِیَ إِلَیۡهِمۡ أَجَلُهُمۡۖ﴾</q> - نزول الآية ٣٤٢٤٣- قال مقاتل بن سليمان: <q>﴿ولَوْ يُعَجِّلُ اللَّهُ لِلنّاسِ الشَّرَّ اسْتِعْجالَهُمْ بِالخَيْرِ﴾</q>، وذلك حين قال النضر بن الحارث: <q>﴿فَأَمْطِرْ عَلَيْنا حِجارَةً مِنَ السَّماءِ أوِ ائْتِنا بِعَذابٍ ألِيمٍ﴾</q> [الأنفال:٣٢] فيصيبنا. فأنزل الله ﷿: <q>﴿ولَوْ يُعَجِّلُ اللَّهُ لِلنّاسِ الشَّرَّ اسْتِعْجالَهُمْ بِالخَيْرِ﴾</q>{1}. (ز) <q>﴿وَلَوۡ یُعَجِّلُ ٱللَّهُ لِلنَّاسِ ٱلشَّرَّ ٱسۡتِعۡجَالَهُم بِٱلۡخَیۡرِ لَقُضِیَ إِلَیۡهِمۡ أَجَلُهُمۡۖ﴾</q> - تفسير الآية ٣٤٢٤٤- عن عبد الله بن عباس، قال: <q>﴿ولَوْ يُعَجِّلُ اللَّهُ لِلنّاسِ الشَّرَّ اسْتِعْجالَهُمْ بِالخَيْرِ﴾</q>، هذا في قول الرجل عند الغضب لأهله وولده: لعنكم الله، ولا بارك فيكم{2}. (ز) ٣٤٢٤٥- عن سعيد بن جبير -من طريق سالم- <q>﴿ولَو يُعَجِلُ الله لِلناسِ الشَّرَّ اسْتِعْجالَهُم بِالخَيْرِ﴾</q>، قال: قولُ الرجلِ للرجلِ: اللَّهُمْ أخْزِه، اللَّهُمَّ العَنْه. قال: وهو يُحِبُّ أن يُستجابَ له، كما يُحِبُّ: اللَّهُمَّ اغفِرْ له، اللَّهُمَّ ارْحَمْه{3}. (٧/٦٣٦) ٣٤٢٤٦- عن مجاهد بن جبر -من طريق ابن أبي نَجِيح- في قوله: <q>﴿ولَو يُعَجِلُ الله لِلناسِ الشَّرَّ اسْتِعْجالَهُم بِالخَيْرِ﴾</q> قال: هو قولُ الإنسانِ لولدِه ومالِه إذا غضِب عليه: اللَّهُمَّ، لا تُبارِكْ فيه، والعَنْه. <q>﴿لَقُضِيَ إلَيهِم أجَلُهُم﴾</q> قال: لَأهلَك مَن دعا عليه، ولَأَماتَه. وفي رواية: فلو يُعجِّل الله الاستجابة لهم في ذلك كما يُستجاب في الخير لأَهْلَكَهم {4}. (٧/٦٣٦) ٣٤٢٤٧- عن قتادة بن دعامة -من طريق مَعْمَر- في الآية، قال: هو دعاءُ الرجلِ على نفسِه ومالِه بما يَكْرَهُ أن يُستَجابَ له{5}. (٧/٦٣٦) ٣٤٢٤٨- قال مقاتل بن سليمان: <q>﴿ولَوْ يُعَجِّلُ اللَّهُ لِلنّاسِ الشَّرَّ اسْتِعْجالَهُمْ بِالخَيْرِ﴾</q> إذا أرادوه فأصابوه، يقول الله: ولو استجيب لهم في الشَّرِّ كما يُحِبُّون أن يستجاب لهم في الخير؛ <q>﴿لَقُضِيَ إلَيْهِمْ أجَلُهُمْ﴾</q> في الدنيا بالهلاك إذًا، ... وأيضًا <q>﴿ولو يعجّل الله للناس﴾</q> يقول: ابنُ آدم يدعو لنفسه بالخير، ويُحِبُّ أن يُعَجِّل اللهُ ذلك، ويدعو على نفسه بالشر، يقول: اللَّهُمَّ، إن كنت صادقًا فافعل كذا وكذا. فلو يُعَجِّل اللهُ ذلك <q>﴿لُقضي إليهم أجلهم﴾</q> يعني: العذاب، <q>﴿فَنَذَرُ﴾</q> يعني: فنترك <q>﴿الَّذِينَ لا يَرْجُونَ لِقاءَنا﴾</q> يعني: لا يخشون لقاءنا{1}. (ز) ٣٤٢٤٩- قال عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿لقضي إليهم أجلهم﴾</q>، قال: لَأهلَكْناهم. وقرأ: <q>﴿ما ترك على ظهرها من دابة﴾</q> [النحل:٦١]. قال: يُهْلِكُهم كلَّهم{7}. (ز) ٣٤٢٥٠- قال يحيى بن سلّام: المعنى: لو عَجَّل اللهُ للناسِ الشَّرَّ إذا دَعَوْا به على أنفسهم عند الغضب، وعلى أهليهم وأولادهم، واستعجلوا به كما يستعجلونه بالخير إذا سألوه إيّاه{8}. (ز) <q>﴿وَلَوۡ یُعَجِّلُ ٱللَّهُ لِلنَّاسِ ٱلشَّرَّ ٱسۡتِعۡجَالَهُم بِٱلۡخَیۡرِ لَقُضِیَ إِلَیۡهِمۡ أَجَلُهُمۡۖ﴾</q> - آثار متعلقة بالآية ٣٤٢٥١- عن شَهْر بن حَوْشَب، قال: قرأتُ في بعض الكُتُب: أنّ الله تعالى يقول للمَلَكَين الموكلين: لا تكتبا على عبدي في حال ضَجَرِه شيئًا{9}. (ز) <q>﴿فَنَذَرُ ٱلَّذِینَ لَا یَرۡجُونَ لِقَاۤءَنَا﴾</q> - تفسير ٣٤٢٥٢- عن مجاهد بن جبر -من طريق عبد الملك ابن جُرَيْج- قوله: <q>﴿فنذر الذين لا يرجون لقاءنا﴾</q>، قال: يقول: لا نُهْلِك أهلَ الشرك، ولكن نذرهم في طغيانهم يعمهون{7}. (ز) ٣٤٢٥٣- عن قتادة بن دعامة -من طريق سعيد بن أبي عروبة- <q>﴿الذين لا يرجون لقاءنا﴾</q>: مُشرِكي أهلِ مكَّة{11}. (ز) ٣٤٢٥٤- قال مقاتل بن سليمان: <q>﴿فَنَذَرُ الَّذِينَ لا يَرْجُونَ لِقاءَنا﴾</q> فنذرهم لا يخرجون أبدًا، فذلك قوله: <q>﴿فِي طُغْيانِهِمْ يَعْمَهُونَ﴾</q>{12}. (ز) <q>﴿فِی طُغۡیَـٰنِهِمۡ یَعۡمَهُونَ ۝١١﴾</q> - تفسير ٣٤٢٥٥- عن أبي العالية الرِّياحِيِّ -من طريق الربيع- <q>﴿في طغيانهم﴾</q>، يعني: في ضلالهم{11}. (ز) ٣٤٢٥٦- قال مقاتل بن سليمان: <q>﴿فِي طُغْيانِهِمْ يَعْمَهُونَ﴾</q>، يعني: في ضلالتهم يَتَرَدَّدون، لا يخرجون منها إلا أن يخرجهم الله ﷿{12}. (ز) ",footnotes:1:تفسير مقاتل بن سليمان ٢/٢٢٩.تفسير البغوي ٤/١٢٣.أخرجه ابن أبي حاتم ٦/١٩٣٢ بنحوه. وعزاه السيوطي إلى أبي الشيخ.تفسير مجاهد ص٣٧٩، وأخرجه ابن جرير ١٢/١٣٠-١٣١، وابن أبي حاتم ٦/١٩٣٢. وعزاه السيوطي إلى ابن أبي شيبة، وابن المنذر، وأبي الشيخ.أخرجه ابن جرير ١٢/١٣١، وابن أبي حاتم ٦/١٩٣٢.تفسير مقاتل بن سليمان ٢/٢٢٩.أخرجه ابن جرير ١٢/١٣١.تفسير ابن أبي زمنين ٢/٢٤٦.تفسير الثعلبي ٥/١٢٢.أخرجه ابن جرير ١٢/١٣١.أخرجه ابن أبي حاتم ٦/١٩٣٢.تفسير مقاتل بن سليمان ٢/٢٢٩-٢٣٠.أخرجه ابن أبي حاتم ٦/١٩٣٢.تفسير مقاتل بن سليمان ٢/٢٢٩-٢٣٠.
10,12," <q>﴿وَإِذَا مَسَّ ٱلۡإِنسَـٰنَ ٱلضُّرُّ دَعَانَا لِجَنۢبِهِۦۤ أَوۡ قَاعِدًا أَوۡ قَاۤىِٕمࣰا﴾</q> الآية - نزول الآية ٣٤٢٥٧- قال مقاتل بن سليمان: <q>﴿وإذا مَسَّ الإنْسانَ الضُّرُّ﴾</q>، نزلت في أبي حذيفة، اسمه: هاشم بن المغيرة بن عبد الله المخزومي{1}. (ز) <q>﴿وَإِذَا مَسَّ ٱلۡإِنسَـٰنَ ٱلضُّرُّ دَعَانَا لِجَنۢبِهِۦۤ أَوۡ قَاعِدًا أَوۡ قَاۤىِٕمࣰا﴾</q> - تفسير ٣٤٢٥٨- عن قتادة بن دعامة -من طريق مَعْمَر- قال: إذا مسَّهُمُ الضُّرُّ أخْلَصوا لله الدعاءَ{2}. (ز) ٣٤٢٥٩- عن قتادة بن دعامة، في قوله: <q>﴿دَعانا لِجَنبِهِ أو قاعِدًا أو قَآئِمًا﴾</q>، قال: على كلِّ حالٍ{3}. (٧/٦٣٧) ٣٤٢٦٠- قال مقاتل بن سليمان: <q>﴿وإذا مَسَّ الإنْسانَ الضُّرُّ﴾</q> يعني: المرض؛ بلاء أو شدة، <q>﴿دَعانا لِجَنْبِهِ﴾</q> يعني: لمضجعه في مرضه، <q>﴿أوْ﴾</q> دعانا <q>﴿قاعِدًا أوْ قائِمًا﴾</q> كل ذلك لِما كان{1}. (ز) ٣٤٢٦١- عن عبد الملك ابن جُرَيْج -من طريق حجّاج- في قوله: <q>﴿دَعانا لِجَنبِهِ﴾</q>، قال: مُضطجِعًا{5}. (٧/٦٣٦) <q>﴿فَلَمَّا كَشَفۡنَا عَنۡهُ ضُرَّهُۥ مَرَّ كَأَن لَّمۡ یَدۡعُنَاۤ إِلَىٰ ضُرࣲّ مَّسَّهُۥۚ﴾</q> - تفسير ٣٤٢٦٢- قال مقاتل بن سليمان: <q>﴿فَلَمّا كَشَفْنا عَنْهُ ضُرَّهُ﴾</q> وعُوفِي مِن مرضه؛ <q>﴿مَرَّ﴾</q> يعني: اسْتَمَرَّ، أي: أعْرَض عن الدعاء، <q>﴿كَأَنْ لَمْ يَدْعُنا إلى ضُرٍّ مَسَّهُ﴾</q> ولا يزال يدعونا ما احتاج إلى ربِّه، فإذا أُعْطِي حاجتَه أمْسَك عن الدعاء، قال الله تعالى عند ذلك: اسْتَغْنى عبدي{1}. (ز) <q>﴿كَذَ ٰ⁠لِكَ زُیِّنَ لِلۡمُسۡرِفِینَ مَا كَانُوا۟ یَعۡمَلُونَ ۝١٢﴾</q> - تفسير ٣٤٢٦٣- عن عباد بن منصور، قال: سألتُ الحسن [البصري] عن قوله: <q>﴿زُيِّنَ﴾</q>. قال: زَيَّن لهم الشيطان{2}. (ز) ٣٤٢٦٤- قال مقاتل بن سليمان: <q>﴿كَذلِكَ﴾</q> يعني: هكذا <q>﴿زُيِّنَ لِلْمُسْرِفِينَ﴾</q> يعني: المشركين <q>﴿ما كانُوا يَعْمَلُونَ﴾</q> مِن أعمالهم السيئة، يعني: الدُّعاء في الشِّدَّة{1}. (ز) <q>﴿كَذَ ٰ⁠لِكَ زُیِّنَ لِلۡمُسۡرِفِینَ مَا كَانُوا۟ یَعۡمَلُونَ ۝١٢﴾</q> - آثار متعلقة بالآية ٣٤٢٦٥- عن أبي الدَّرداء، قال: ادعُ اللهَ يومَ سَرّائِك يَستَجِبْ لك يومَ ضرّائِك{3}. (٧/٦٣٧) ",footnotes:1:تفسير مقاتل بن سليمان ٢/٢٣٠.أخرجه ابن أبي حاتم ٦/١٩٣٣.عزاه السيوطي إلى أبي الشيخ.تفسير مقاتل بن سليمان ٢/٢٣٠.أخرجه ابن جرير ١٢/١٣٣. وعزاه السيوطي إلى ابن المنذر.تفسير مقاتل بن سليمان ٢/٢٣٠.أخرجه ابن أبي حاتم ٦/١٩٣٣.تفسير مقاتل بن سليمان ٢/٢٣٠.عزاه السيوطي إلى أبي الشيخ.
10,13," <q>﴿وَلَقَدۡ أَهۡلَكۡنَا ٱلۡقُرُونَ مِن قَبۡلِكُمۡ لَمَّا ظَلَمُوا۟ وَجَاۤءَتۡهُمۡ رُسُلُهُم بِٱلۡبَیِّنَـٰتِ وَمَا كَانُوا۟ لِیُؤۡمِنُوا۟ۚ كَذَ ٰ⁠لِكَ نَجۡزِی ٱلۡقَوۡمَ ٱلۡمُجۡرِمِینَ ۝١٣﴾</q> - تفسير ٣٤٢٦٦- قال مقاتل بن سليمان: <q>﴿ولَقَدْ أهْلَكْنا القُرُونَ﴾</q> بالعذاب في الدُّنيا <q>﴿مِن قَبْلِكُمْ﴾</q> يا أهل مكة <q>﴿لَمّا ظَلَمُوا﴾</q> يعني: حين أشركوا. يُخَوِّفُ كُفّارَ مكة بمثل عذاب الأُمَم الخالية؛ لكي لا يُكَذِّبوا محمدًا ﷺ، <q>﴿وجاءَتْهُمْ رُسُلُهُمْ بِالبَيِّناتِ﴾</q> يقول: أخبرتهم رسلُهم بالعذاب أنّه نازل بهم في الدنيا، ثم قال: <q>﴿وما كانُوا لِيُؤْمِنُوا﴾</q> يقول: ما كان كفار مكة لِيُصَدِّقوا بنزول العذاب بهم في الدنيا، <q>﴿كَذلِكَ﴾</q> يعني: هكذا <q>﴿نَجْزِي﴾</q> بالعذاب <q>﴿القَوْمَ المُجْرِمِينَ﴾</q> يعني: مُشركي الأُمَم الخالية{1}. (ز) ",footnotes:1:تفسير مقاتل بن سليمان ٢/٢٣٠.
10,14," <q>﴿ثُمَّ جَعَلۡنَـٰكُمۡ خَلَـٰۤىِٕفَ فِی ٱلۡأَرۡضِ مِنۢ بَعۡدِهِمۡ لِنَنظُرَ كَیۡفَ تَعۡمَلُونَ ۝١٤﴾</q> - تفسير ٣٤٢٦٧- عن قتادة بن دعامة، في قوله: <q>﴿ثُمَّ جَعَلْنَكُمْ خَلائِفَ في الأرضِ مِن بَعدِهِم لِنَنظُرَ كَيْفَ تَعْمَلُونَ﴾</q>، قال: ذُكِر لنا: أنّ عمر بن الخطاب قرَأ هذه الآية، فقال: صدَق ربُّنا، ما جعَلَنا خلائفَ في الأرضِ إلا لينظرَ إلى أعمالِنا؛ فأرُوا الله خيرَ أعمالِكم بالليلِ والنهارِ، والسِّرِّ والعلانيةِ{1}. (٧/٦٣٧) ٣٤٢٦٨- قال مقاتل بن سليمان: <q>﴿ثُمَّ جَعَلْناكُمْ﴾</q> يا أُمَّة محمد <q>﴿خَلائِفَ فِي الأَرْضِ مِن بَعْدِهِمْ لِنَنْظُرَ كَيْفَ تَعْمَلُونَ﴾</q>{2}. (ز) ٣٤٢٦٩- عن عبد الملك ابن جُرَيْج، في قوله: <q>﴿ثُمَّ جَعَلْنَكُمْ خَلائِفَ﴾</q> لِأُمَّةِ محمد ﷺ{3}. (٧/٦٣٧) <q>﴿ثُمَّ جَعَلۡنَـٰكُمۡ خَلَـٰۤىِٕفَ فِی ٱلۡأَرۡضِ مِنۢ بَعۡدِهِمۡ لِنَنظُرَ كَیۡفَ تَعۡمَلُونَ ۝١٤﴾</q> - آثار متعلقة بالآية ٣٤٢٧٠- عن عبد الرحمن بن أبي ليلى: أنّ عوف بن مالك قال لأبي بكر: رأيتُ فيما يرى النائمُ كأنّ سَبَبًا{4} دُلِّيَ مِن السماء، فانتشطَ{5} رسولُ الله ﷺ، ثم دُلِّيَ فانتشطَ أبو بكر، ثم ذَرَعَ{6} الناسُ حول المنبر، فَفَضُلَ عمر بثلاث أذْرُعٍ إلى المنبر. فقال عمر: دَعْنا مِن رؤياك، لا أرَبَ لنا فيها. فلما استُخْلِف عمر، قال: يا عوف، رؤياك. قال: وهل لك في رُؤياي مِن حاجة؟ أوَلَمْ تَنتَهِرْني؟! قال: ويْحَك، إنِّي كرهت أن تنعي لخليفة رسولِ الله ﷺ نفسَه. فقصَّ عليه الرؤيا، حتى إذا بلغ: ذرع الناس إلى المنبر بهذه الثلاث الأذرع. قال: أمّا إحداهُنَّ فإنّه كائن خليفةً، وأمّا الثانية فإنّه لا يخافُ في الله لومة لائم، وأمّا الثالثة فإنّه شهيد. قال: فقال: يقول الله: <q>﴿ثُمَّ جَعَلْناكُمْ خَلائِفَ فِي الأَرْضِ مِن بَعْدِهِمْ لِنَنْظُرَ كَيْفَ تَعْمَلُونَ﴾</q>، فقد اسْتُخْلِفْتَ، يا ابنَ أُمِّ عمر، فانظر كيف تعمل. وأمّا قوله: فإني لا أخاف في الله لومة لائم. فما شاء الله. وأمّا قوله: فإني شهيد. فأنّى لعمر الشهادة والمسلمون مُطيفون به؟! ثم قال: إنّ الله على ما يشاء قدير{7}. (ز) ",footnotes:1:أخرجه ابن جرير ١٢/١٣٤-١٣٥، وابن أبي حاتم ٦/١٩٣٤. وعزاه السيوطي إلى ابن المنذر، وأبي الشيخ.تفسير مقاتل بن سليمان ٢/٢٣٠.عزاه السيوطي إلى ابن المنذر.أي: حبلًا. النهاية (سبب).أي: جُذِب إلى السماء ورُفِعَ إليها. لسان العرب (نشط).الذَّرْعُ: بسط اليد ومدها، وأصله من الذراع وهو الساعد. النهاية (ذرع).أخرجه ابن جرير ١٢/١٣٥، وابن أبي حاتم ٦/١٩٣٤ مقتصرًا على الشاهد.
