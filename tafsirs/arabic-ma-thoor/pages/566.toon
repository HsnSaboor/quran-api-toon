quran[18]{c,v,t}:
68,43," <q>﴿خَـٰشِعَةً أَبۡصَـٰرُهُمۡ تَرۡهَقُهُمۡ ذِلَّةࣱۖ وَقَدۡ كَانُوا۟ یُدۡعَوۡنَ إِلَى ٱلسُّجُودِ وَهُمۡ سَـٰلِمُونَ ۝٤٣﴾</q> - تفسير ٧٨٣١٧- عن عبد الله بن عباس -من طريق علي- في قوله: <q>﴿وقَدْ كانُوا يُدْعَوْنَ إلى السُّجُودِ وهُمْ سالِمُونَ﴾</q>، قال: هم الكفار، يُدعَون في الدنيا وهم آمنون، فاليوم يُدعَون وهم خائفون، ثم أخبر الله سبحانه أنه حال بين أهل الشرك وبين طاعته في الدنيا والآخرة، فأمّا في الدنيا فإنه قال: <q>﴿ما كانُوا يَسْتَطِيعُونَ السَّمْعَ﴾</q> وهي طاعته، <q>﴿وما كانُوا يُبْصِرُونَ﴾</q> [هود:٢٠]. وأمّا الآخرة فإنه قال: <q>﴿لا يَسْتَطِيعُونَ خاشِعَةً أبْصارُهُمْ﴾</q>{1}. (١٤/٦٤٧) ٧٨٣١٨- عن عبد الله بن عباس-من طريق أبي سِنان، عن سعيد بن جُبَير- في قوله: <q>﴿وقَدْ كانُوا يُدْعَوْنَ إلى السُّجُودِ﴾</q>، قال: الرجل يَسمع الأذان فلا يجيب الصلاة{2}. (١٤/٦٤٩) ٧٨٣١٩- عن كعب الأحبار، قال: والذي أنزل التوراة على موسى، والإنجيل على عيسى، والزّبور على داود، والفرقان على محمد؛ لنَزَلَتْ هذه الآية في الصلوات المكتوبات حيث يُنادى بهن: <q>﴿يَوْمَ يُكْشَفُ عَنْ ساقٍ﴾</q> إلى قوله: <q>﴿وقَدْ كانُوا يُدْعَوْنَ إلى السُّجُودِ وهُمْ سالِمُونَ﴾</q> الصلوات الخمس إذا نُودِي بها{3}. (١٤/٦٤٨) ٧٨٣٢٠- عن سعيد بن جُبَير -من طريق أبي سِنان- في قوله: <q>﴿وقَدْ كانُوا يُدْعَوْنَ إلى السُّجُودِ﴾</q>، قال: الصلوات في الجماعات{4}. (١٤/٦٤٨) ٧٨٣٢١- عن إبراهيم التيميّ -من طريق منصور- <q>﴿وقَدْ كانُوا يُدْعَوْنَ إلى السُّجُودِ وهُمْ سالِمُونَ﴾</q>، قال: إلى الصلاة المكتوبة{5}. (ز) ٧٨٣٢٢- قال مقاتل بن سليمان: <q>﴿خاشِعَةً أبْصارُهُمْ﴾</q> عند معاينة النار، <q>﴿تَرْهَقُهُمْ ذِلَّةٌ﴾</q> يعني: تغشاهم مَذَلّة، <q>﴿وقَدْ كانُوا يُدْعَوْنَ إلى السُّجُودِ﴾</q> يعني: يُؤمرون بالصلاة{6} الخمس <q>﴿وهُمْ سالِمُونَ﴾</q> يقول: كانوا مُعافون في الدنيا، فتصير أصلابهم مثل سفافيد الحديد{7}٦٧٥٠. (ز) ٦٧٥٠ علَّق ابنُ عطية (٨/٣٨٠) على الأقوال الواردة في السجود بقوله: «وهذا كلّه قريب بعضه من بعض». ",footnotes:1:أخرجه ابن جرير ٢٣/١٩٧. وعزاه السيوطي إلى ابن المنذر.أخرجه البيهقي في الشعب (٢٩١٥).عزاه السيوطي إلى ابن مردويه.أخرجه البيهقي في شعب الإيمان (٢٩١٤)، وابن جرير ٢٣/١٩٦-١٩٧ بلفظ: يسمع المنادي إلى الصلاة المكتوبة فلا يجيبه.أخرجه ابن جرير ٢٣/١٩٦.كذا في المصدر، ولعلها: الصلوات.تفسير مقاتل بن سليمان ٤/٤٠٨-٤٠٩.
68,44," <q>﴿فَذَرۡنِی وَمَن یُكَذِّبُ بِهَـٰذَا ٱلۡحَدِیثِۖ سَنَسۡتَدۡرِجُهُم مِّنۡ حَیۡثُ لَا یَعۡلَمُونَ ۝٤٤﴾</q> - تفسير ٧٨٣٢٣- قال مقاتل بن سليمان: قوله: <q>﴿فَذَرْنِي﴾</q> هذا تهديد <q>﴿ومَن يُكَذِّبُ بِهَذا الحَدِيثِ﴾</q> يقول: خَلِّ بيني وبين مَن يُكذّب بهذا القرآن، فأنا أنفرد بهلاكهم؛ <q>﴿سَنَسْتَدْرِجُهُمْ مِن حَيْثُ لا يَعْلَمُونَ﴾</q> سَنأخذهم بالعذاب من حيث يَجهلون{1}. (ز) ٧٨٣٢٤- قال سفيان الثوري: يُسبِغ عليهم النِّعم، ويُنسيهم الشكر{2}٦٧٥١. (ز) ٦٧٥١ ذكر ابنُ عطية (٨/٣٨٠) «أنّ الاستدراج هو: الحمْل من رتبة إلى رتبة، حتى يصير المحمول إلى شرّ». ثم علَّق بقوله: «وإنما يُستعمل الاستدراج في الشّرّ، وهو مأخوذ من الدرَج». وساق الأقوال. ",footnotes:1:تفسير مقاتل بن سليمان ٤/٤١٠-٤١١.تفسير الثعلبي ١٠/٢٢.
68,45," <q>﴿وَأُمۡلِی لَهُمۡۚ إِنَّ كَیۡدِی مَتِینٌ ۝٤٥﴾</q> - نزول الآية، وتفسيرها ٧٨٣٢٥- قال مقاتل بن سليمان: <q>﴿وأُمْلِي لَهُمْ﴾</q> يقول: لا أعْجَل عليهم بالعذاب، <q>﴿إنَّ كَيْدِي مَتِينٌ﴾</q> يقول: إنّ أخذي بالعذاب شديد. نَزَلَتْ هذه الآية في المُستهزئين من قريش، قَتلهم الله تعالى في ليلة واحدة{1}. (ز) ",footnotes:1:تفسير مقاتل بن سليمان ٤/٤١١.
68,46," <q>﴿أَمۡ تَسۡـَٔلُهُمۡ أَجۡرࣰا فَهُم مِّن مَّغۡرَمࣲ مُّثۡقَلُونَ ۝٤٦ أَمۡ عِندَهُمُ ٱلۡغَیۡبُ فَهُمۡ یَكۡتُبُونَ ۝٤٧﴾</q> - تفسير ٧٨٣٢٦- قال مقاتل بن سليمان: قوله: <q>﴿أمْ تَسْأَلُهُمْ أجْرًا﴾</q> يعني: خَراجًا على الإيمان؛ <q>﴿فَهُمْ مِن مَغْرَمٍ مُثْقَلُونَ﴾</q> يقول: أثقَلهم الغُرم؛ فلا يستطيعون الإكثار من أجل الغُرم، <q>﴿أمْ عِنْدَهُمُ﴾</q> يقول: أعندهم علم <q>﴿الغَيْبُ﴾</q> بأنّ الله لا يَبعثهم، وأنّ الذي يقول محمد غير كائن، أم عندهم بذلك كتاب <q>﴿فَهُمْ يَكْتُبُونَ﴾</q> ما شاؤوا{1}. (ز) ",footnotes:1:تفسير مقاتل بن سليمان ٤/٤١١-٤١٢.
  68,47,""
68,48," <q>﴿فَٱصۡبِرۡ لِحُكۡمِ رَبِّكَ وَلَا تَكُن كَصَاحِبِ ٱلۡحُوتِ إِذۡ نَادَىٰ وَهُوَ مَكۡظُومࣱ ۝٤٨﴾</q> - تفسير ٧٨٣٢٧- عن عبد الله بن عباس -من طريق علي- في قوله: <q>﴿وهُوَ مَكْظُومٌ﴾</q>، قال: مغموم{1}. (١٤/٦٥٨) ٧٨٣٢٨- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿وهُوَ مَكْظُومٌ﴾</q>، قال: مغموم{2}. (١٤/٦٥٨) ٧٨٣٢٩- عن وهْب بن مُنَبِّه -من طريق عبد المنعم بن إدريس، عن أبيه- قال: كان في خُلُق يونس ضِيق، فلمّا حُمِّلتْ عليه أثقالُ النّبوة تفسخّ منها تفسخ الرَّبَع{3}، فقذفها من يديه، وهرب، قال تعالى لنبيّه: <q>﴿ولا تَكُنْ كَصاحِبِ الحُوتِ إذْ نادى وهُوَ مَكْظُومٌ﴾</q>{4}. (١٤/٦٥٧) ٧٨٣٣٠- عن قتادة بن دعامة -من طريق معمر- <q>﴿ولا تَكُنْ كَصاحِبِ الحُوتِ﴾</q>، قال: لا تَعجَل كما عَجِل، ولا تُغاضِب كما غاضب{5}. (١٤/٦٥٧) ٧٨٣٣١- قال مقاتل بن سليمان: ثم قال للنبي ﷺ: <q>﴿فاصْبِرْ﴾</q> على الأذى <q>﴿لِحُكْمِ رَبِّكَ﴾</q> يعني: لقضاء ربّك والذي هو آتٍ عليك، <q>﴿ولا تَكُنْ كَصاحِبِ الحُوتِ﴾</q> يعني: يونس بن متّى مِن أهل نَيْنَوى ﵇. يقول: لا تَضْجر كما ضجر يونس، فإنه لم يصبر. يقول: لا تَعجَل كما عَجِل يونس، ولا تُغاضِب كما غاضب يونس بن متّى، فتُعاقَب كما عُوقب يونس <q>﴿إذْ نادى﴾</q> ربَّه في بطن الحوت، وكان نداؤه في سورة الأنبياء [٨٧]: <q>﴿لا إلَهَ إلّا أنْتَ سُبْحانَكَ إنِّي كُنْتُ مِنَ الظّالِمِينَ﴾</q>، <q>﴿وهُوَ مَكْظُومٌ﴾</q> يعني: مكروب في بطن الحوت، يعني: السمكة{6}. (ز) ٧٨٣٣٢- عن عبد الملك ابن جُرَيْج، في قوله: <q>﴿ولا تَكُنْ كَصاحِبِ الحُوتِ﴾</q>، قال: لا تُغاضِب كما غاضب يونس{7}. (١٤/٦٥٧) ",footnotes:1:أخرجه ابن أبي حاتم -كما في الإتقان ٢/٤٩-، وابن جرير ٢٣/٢٠٠. وعزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ٢٣/٢٠٠. وعزاه السيوطي إلى عبد بن حميد.تفسخ الربع -وهو الفصيل- تحت الحمل الثقيل: ضعف وعجز، وذلك إذا لم يطقه. تاج العروس (فسخ).أخرجه الحاكم ٢/٥٨٤-٥٨٥، وأخرج ابن جرير ١٦/٣٧٦ نحوه طريق ربيعة.أخرجه عبد الرزاق ٢/٣١٠-٣١١، وابن جرير ٢٣/٢٠٠، ومن طريق سعيد أيضًا. وعزاه السيوطي إلى أحمد في الزهد، وابن المنذر.تفسير مقاتل بن سليمان ٤/٤١٢.عزاه السيوطي إلى ابن المنذر.
68,49," <q>﴿لَّوۡلَاۤ أَن تَدَ ٰ⁠رَكَهُۥ نِعۡمَةࣱ مِّن رَّبِّهِۦ لَنُبِذَ بِٱلۡعَرَاۤءِ وَهُوَ مَذۡمُومࣱ ۝٤٩ فَٱجۡتَبَـٰهُ رَبُّهُۥ فَجَعَلَهُۥ مِنَ ٱلصَّـٰلِحِینَ ۝٥٠﴾</q> - تفسير ٧٨٣٣٣- عن عبد الله بن عباس -من طريق علي- في قوله: <q>﴿وهُوَ مَذْمُومٌ﴾</q>، قال: مُلِيم{1}. (١٤/٦٥٨) ٧٨٣٣٤- عن بكر [بن عبد الله المزني] -من طريق المعتمر، عن أبيه- <q>﴿وهُوَ مَذْمُومٌ﴾</q>، قال: هو مُذنِب{2}. (ز) ٧٨٣٣٥- قال مقاتل بن سليمان: <q>﴿لَوْلا أنْ تَدارَكَهُ نِعْمَةٌ مِن رَبِّهِ لَنُبِذَ بِالعَراءِ وهُوَ مَذْمُومٌ﴾</q> ولكن تَداركه نعمة، يعني: رحمة من ربّه، فنبذناه بالعراء وهو سقيم، والعراء: البَراز، يعني: لأُلقِي بالبَراز وهو مذموم{3}. (ز) <q>﴿لَّوۡلَاۤ أَن تَدَ ٰ⁠رَكَهُۥ نِعۡمَةࣱ مِّن رَّبِّهِۦ لَنُبِذَ بِٱلۡعَرَاۤءِ وَهُوَ مَذۡمُومࣱ ۝٤٩ فَٱجۡتَبَـٰهُ رَبُّهُۥ فَجَعَلَهُۥ مِنَ ٱلصَّـٰلِحِینَ ۝٥٠﴾</q> - آثار متعلقة بالآية ٧٨٣٣٦- عن عبد الله بن عباس، أن النبي ﷺ قال: «لا ينبغي لأحد أن يقول: إني خير من يونس بن متّى -نسبه إلى أمه-. أصاب ذنبًا، ثم اجتباه ربه»{4}. (ز) ",footnotes:1:أخرجه ابن أبي حاتم -كما في الإتقان ٢/٤٩-، وابن جرير ٢٣/٢٠١. وعزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ٢٣/٢٠١.تفسير مقاتل بن سليمان ٤/٤١٢.أخرجه عبد الرزاق ٢/١٥٥-١٥٦، وأحمد في مسنده ٥/ ٣٠٣ (٣٢٥٢)، وعنده: نسبه إلى أمه. وأصله عند البخاري ٤/١٣٢، ومسلم ٧/١٠٣، والترمذي ٥/٥١ دون قوله: أصاب ذنبًا ثم اجتباه ربه. قال محققو المسند: «إسناده صحيح، على شرط الشيخين».
  68,50,""
68,51," <q>﴿وَإِن یَكَادُ ٱلَّذِینَ كَفَرُوا۟ لَیُزۡلِقُونَكَ بِأَبۡصَـٰرِهِمۡ لَمَّا سَمِعُوا۟ ٱلذِّكۡرَ وَیَقُولُونَ إِنَّهُۥ لَمَجۡنُونࣱ ۝٥١﴾</q> - قراءات ٧٨٣٣٧- عن عبد الله بن مسعود -من طريق إبراهيم- أنه قرأ: (لَيُزْهِقُونَكَ بِأَبَصارِهِمْ){1}. (١٤/٦٥٩) <q>﴿وَإِن یَكَادُ ٱلَّذِینَ كَفَرُوا۟ لَیُزۡلِقُونَكَ بِأَبۡصَـٰرِهِمۡ لَمَّا سَمِعُوا۟ ٱلذِّكۡرَ وَیَقُولُونَ إِنَّهُۥ لَمَجۡنُونࣱ ۝٥١﴾</q> - نزول الآية ٧٨٣٣٨- قال محمد بن السّائِب الكلبي: كان رجل من العرب يَمكث لا يأكل يومين أو ثلاثة، ثم يَرفع جانب خِبائه، فتَمُرّ به النّعم، فيقول: ما رعى اليوم إبل ولا غنم أحسن مِن هذه. فما تَذهب إلا قريبًا حتى يَسقط منها طائفة وعِدّة. فسأل الكفارُ هذا الرجل أن يُصيب رسول الله ﷺ بالعين، ويَفعل به مثل ذلك، فعَصم الله تعالى نبيّه، وأَنزَل هذه الآية: <q>﴿وإنْ يَكادُ الَّذِينَ كَفَرُوا لَيُزْلِقُونَكَ بِأَبْصارِهِمْ﴾</q>{2}. (ز) <q>﴿وَإِن یَكَادُ ٱلَّذِینَ كَفَرُوا۟ لَیُزۡلِقُونَكَ بِأَبۡصَـٰرِهِمۡ لَمَّا سَمِعُوا۟ ٱلذِّكۡرَ وَیَقُولُونَ إِنَّهُۥ لَمَجۡنُونࣱ ۝٥١﴾</q> - تفسير الآية ٧٨٣٣٩- عن عبد الله بن عباس -من طريق علي- في قوله: <q>﴿لَيُزْلِقُونَكَ بِأَبْصارِهِمْ﴾</q>، قال: يَنفُذُونك بأبصارهم{3}. (١٤/٦٥٨) ٧٨٣٤٠- عن عبد الله بن عباس -من طريق عطاء- أنه كان يقرأ: <q>﴿وإنْ يَكادُ الَّذِينَ كَفَرُوا لَيُزْلِقُونَكَ بِأَبْصارِهِمْ﴾</q>. قال: يقول: يَنفُذُونك بأبصارهم مِن شِدّة النظر إليك. قال ابن عباس: فكيف يقولون: زَلَق السهم أو زَهَق السهم{4}. (١٤/٦٥٨) ٧٨٣٤١- عن عبد الله بن عباس -من طريق عطية- <q>﴿وإنْ يَكادُ الَّذِينَ كَفَرُوا لَيُزْلِقُونَكَ بِأَبْصارِهِمْ﴾</q>: ليُزْهِقُونك بأبصارهم{5}. (ز) ٧٨٣٤٢- عن مجاهد بن جبر -من طريق ابن أبي نجيح- <q>﴿لَيُزْلِقُونَكَ بِأَبْصارِهِمْ﴾</q>، قال: ليَنفُذُونك بأبصارهم{6}. (١٤/٦٥٨) ٧٨٣٤٣- عن الضَّحّاك بن مُزاحِم -من طريق عبيد- في قوله: <q>﴿وإنْ يَكادُ الَّذِينَ كَفَرُوا لَيُزْلِقُونَكَ بِأَبْصارِهِمْ﴾</q>، يقول: يَنفُذُونك بأبصارهم؛ مِن العداوة والبغضاء{7}. (ز) ٧٨٣٤٤- قال الحسن البصري: <q>﴿لَيُزْلِقُونَكَ بِأَبْصارِهِمْ﴾</q> ليَقْتلونك{8}. (ز) ٧٨٣٤٥- قال عطية العَوفيّ: <q>﴿لَيُزْلِقُونَكَ بِأَبْصارِهِمْ﴾</q> يرمونك{9}. (ز) ٧٨٣٤٦- عن قتادة بن دعامة -من طريق سعيد- <q>﴿لَيُزْلِقُونَكَ بِأَبْصارِهِمْ﴾</q>، قال: ليَنفُذُونك بأبصارهم؛ معاداةً لكتاب الله، ولِذِكْر الله{6}. (١٤/٦٥٨) ٧٨٣٤٧- عن قتادة بن دعامة -من طريق معمر- في قوله تعالى: <q>﴿لَيُزْلِقُونَكَ بِأَبْصارِهِمْ﴾</q>، قال: لَيُزْهِقُونك{11}. (ز) ٧٨٣٤٨- قال إسماعيل السُّدِّيّ: <q>﴿لَيُزْلِقُونَكَ بِأَبْصارِهِمْ﴾</q> يُصيبونك بعيونهم{12}. (ز) ٧٨٣٤٩- عن عطاء الخُراسانيّ -من طريق يونس بن يزيد- في قول الله: <q>﴿ليزلقونك بأبصارهم﴾</q>، قال: لَيُزِيلُونك بأبصارهم{13}. (ز) ٧٨٣٥٠- قال زيد بن أسلم: <q>﴿لَيُزْلِقُونَكَ بِأَبْصارِهِمْ﴾</q> لَيمَسّوك{8}. (ز) ٧٨٣٥١- عن محمد بن السّائِب الكلبي-من طريق معمر- <q>﴿لَيُزْلِقُونَكَ بِأَبْصارِهِمْ﴾</q>: ليَصْرعُونك{15}. (ز) ٧٨٣٥٢- عن محمد بن السّائِب الكلبي -من طريق حيّان- <q>﴿لَيُزْلِقُونَكَ بِأَبْصارِهِمْ﴾</q>: يَصْرفُونك عمّا أنت عليه من تبليغ الرسالة{9}. (ز) ٧٨٣٥٣- قال مقاتل بن سليمان: <q>﴿وإنْ يَكادُ﴾</q> يقول: قد كاد <q>﴿الَّذِينَ كَفَرُوا﴾</q> يعني: المُستهزئين من قريش <q>﴿لَيُزْلِقُونَكَ بِأَبْصارِهِمْ﴾</q> يعني: يُبعِدونك <q>﴿لَمّا سَمِعُوا الذِّكْرَ﴾</q> يقول: حين سمعوا القرآن كراهيةً له، <q>﴿ويَقُولُونَ إنَّهُ﴾</q> إنّ محمدًا <q>﴿لَمَجْنُونٌ﴾</q>{17}. (ز) <q>﴿وَإِن یَكَادُ ٱلَّذِینَ كَفَرُوا۟ لَیُزۡلِقُونَكَ بِأَبۡصَـٰرِهِمۡ لَمَّا سَمِعُوا۟ ٱلذِّكۡرَ وَیَقُولُونَ إِنَّهُۥ لَمَجۡنُونࣱ ۝٥١﴾</q> - آثار متعلقة بالآية ٧٨٣٥٤- عن عبد الله بن عباس، أنّ رسول الله ﷺ قال: «العين حق، ولو كان شيء سابق القدَر سبقته العين، وإذا استُغسلتم فاغسلوا»{18}. (١٤/٦٥٩) ٧٨٣٥٥- عن جابر، أنّ النبي ﷺ قال: «العين تُدخِلُ الرجلَ القبرَ، والجملَ القِدْرَ»{19}. (١٤/٦٥٩) ٧٨٣٥٦- عن جابر، أنّ النبي ﷺ قال: «أكثر مَن يموت مِن أمتي بعد قضاء الله وقدَره بالعين»{20}. (١٤/٦٥٩) ٧٨٣٥٧- عن أسماء بنت عُمَيْس أنها قالتْ: يا رسول الله، إنّ بني جعفر تُصيبهم العين، أفأَسترقي لهم؟ قال: «نعم، فلو كان شيءٌ يَسبق القضاءَ لَسَبَقتْه العين»{21}. (ز) ٧٨٣٥٨- قال الحسن البصري: دواء إصابة العين أن يَقرأ الإنسانُ هذه الآية{22}. (ز) ",footnotes:1:أخرجه أبو عبيد في فضائله (١٧٨)، وابن جرير ٢٣/٢٠٣. وهي قراءة شاذة، تروى أيضًا عن ابن عباس. انظر: مختصر ابن خالويه ص١٦١.تفسير الثعلبي ١٠/٢٣، وأسباب النزول للواحدي ص٦٩٤، وتفسير البغوي ٨/٢٠٢.أخرجه ابن أبي حاتم -كما في الإتقان ٢/٤٩-، وابن جرير ٢٣/٢٠٣. وعزاه السيوطي إلى ابن المنذر، وابن مردويه.عزاه السيوطي إلى سعيد بن منصور، وعبد بن حميد، وابن المنذر، وابن مردويه.أخرجه ابن جرير ٢٣/٢٠٣.أخرجه ابن جرير ٢٣/٢٠٣. وعزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ٢٣/٢٠٣-٢٠٤.تفسير الثعلبي ١٠/٢٤.تفسير الثعلبي ١٠/٢٣.أخرجه ابن جرير ٢٣/٢٠٣. وعزاه السيوطي إلى عبد بن حميد.أخرجه عبد الرزاق ٢/٣١٣، وابن جرير ٢٣/٢٠٣.تفسير الثعلبي ١٠/٢٤، وتفسير البغوي ٨/٢٠٢.أخرجه أبو جعفر الرملي في جزئه (تفسير عطاء) ص١٢٢.تفسير الثعلبي ١٠/٢٤.أخرجه عبد الرزاق ٢/٣١٣، وابن جرير ٢٣/٢٠٣، والثعلبي ١٠/٢٣.تفسير الثعلبي ١٠/٢٣.تفسير مقاتل بن سليمان ٤/٤١٢.أخرجه مسلم ٤/١٧١٩ (٢١٨٨).أخرجه ابن عدي في الكامل ٦/٣١٦، ٨/١٤٨، وأبو نعيم في الحلية ٧/٩٠-٩١، من طريق شعيب بن أيوب، عن معاوية بن هشام، عن سفيان الثوري، عن محمد بن المُنكَدر، عن جابر به. قال أبو نعيم: «غريب من حديث الثوري، تفرد به معاوية». وأورده الألباني في الصحيحة ٣/٢٥٠-٢٥١ (١٢٤٩).أخرجه ابن عدي في الكامل ٥/١٩١، والبزار -كما في كشف الأستار ٣/٤٠٣ (٣٠٥٢)-، من طريق طالب بن حبيب الأنصاري، عن عبد الرحمن بن جابر الأنصاري، عن أبيه به. وقال العراقي في طرح التثريب ٨/١٩٨ عن رواية البزار: «ورجاله ثقات». وقال الهيثمي في المجمع ٥/١٠٦ (٨٤٢٣): «رجاله رجال الصحيح، خلا الطالب بن حبيب بن عمرو، وهو ثقة». وقال ابن حجر في الفتح ١٠/٢٠٠، ٢٠٤: «سنده حسن». وتابعه السخاوي في المقاصد الحسنة ص٤٧٠، والزرقاني في شرحه على الموطأ ٤/٥١١، والعجلوني في كشف الخفاء ٢/٨٩، والشوكاني في نيل الأوطار ٨/٢٤٨، والألباني في الصحيحة ٢/٣٧٢-٣٧٣ (٧٤٧).أخرجه أحمد ٤٥/٤٦٢ (٢٧٤٧٠)، والترمذي ٤/١٤٦-١٤٧ (٢١٨٦، ٢١٨٧)، وابن ماجه ٤/٥٤٣ (٣٥١٠)، والبغوي ٨/٢٠٣ واللفظ له. قال الترمذي: «وهذا حديث حسن صحيح». وقال ابن عدي في الكامل ٥/٤٣١: «وهذه الأحاديث غير محفوظة». وأورده الدارقطني في العلل ١٥/٣٠٤ (٤٠٥١). وقال ابن القيسراني في ذخيرة الحفاظ ٣/١٦٩٣ (٣٨١٠): «رواه عبد الله بن شبيب أبو سعيد، عن يحيى بن إبراهيم، عن أسامة بن حفص، عن عبيد الله بن عمر، عن أيوب البصري رجل من أهل الفضل، عن عمرو بن دينار، عن عروة بن عامر، عن عبيد بن رفاعة، عن أسماء بنت عُمَيْس. وهذا غير محفوظ، وإسناده كما ترى، وعبد الله متروك الحديث». وقال المناوي في التيسير ٢/٣١٠: «إسناد صحيح». وقال في فيض القدير ٥/٣٢٦ (٧٤٧٤): «رمز المصنف-السيوطي- لصحته». وقال الألباني في الصحيحة ٣/٢٥٢ (١٢٥٢): «ورجاله ثقات مشهورون من رجال الشيخين، غير عبيد بن رفاعة، وهو ثقة».تفسير الثعلبي ١٠/٢٤، وتفسير البغوي ٨/٢٠٣.
68,52," <q>﴿وَمَا هُوَ إِلَّا ذِكۡرࣱ لِّلۡعَـٰلَمِینَ ۝٥٢﴾</q> - تفسير ٧٨٣٥٩- قال عبد الله بن عباس: <q>﴿إلا ذِكْرٌ لِلْعالَمِينَ﴾</q> موعظة للمؤمنين{1}. (ز) ٧٨٣٦٠- قال مقاتل بن سليمان: <q>﴿وما هُوَ﴾</q> يعني: إنْ هو <q>﴿إلّا ذِكْرٌ لِلْعالَمِينَ﴾</q> يعني: ما القرآن إلا تَذْكِرة للعالمين{2}. (ز) ",footnotes:1:تفسير البغوي ٨/٢٠٢.تفسير مقاتل بن سليمان ٤/٤١٢.
69,1," مقدمة السورة ٧٨٣٦١- عن عمر بن الخطاب، قال: خَرجتُ أتعرّض لرسول الله ﷺ قبل أنْ أُسلِم، فوجَدتُه قد سبقني إلى المسجد، فقمتُ خَلفه، فاستفتحَ سورة الحاقة، فجَعلتُ أعجب من تأليف القرآن، فقلتُ: هذا -واللهِ- شاعر كما قالتْ قريش. فقرأ: <q>﴿إنَّهُ لَقَوْلُ رَسُولٍ كَرِيمٍ وما هُوَ بِقَوْلِ شاعِرٍ قَلِيلًا ما تُؤْمِنُونَ﴾</q> [الحاقة:٤٠-٤١]. قلتُ: كاهن. قال: <q>﴿ولا بِقَوْلِ كاهِنٍ قَلِيلًا ما تَذَكَّرُونَ تَنْزِيلٌ﴾</q> إلى آخر السورة [الحاقة:٤٢-٥٢]، فوقع الإسلام في قلبي كلّ موقع{1}. (١٤/٦٦٠) ٧٨٣٦٢- عن عبد الله بن عباس -من طريق مجاهد- قال: نَزَلَتْ سورةُ الحاقة بمكة{2}. (١٤/٦٦٠) ٧٨٣٦٣- عن عبد الله بن الزبير، مثله{3}. (١٤/٦٦٠) ٧٨٣٦٤- عن عبد الله بن عباس -من طريق عطاء الخُراسانيّ-: مكّيّة، ونزلت بعد <q>﴿تبارك﴾</q> المُلك{4}. (ز) ٧٨٣٦٥- عن عكرمة مولى ابن عباس= (ز) ٧٨٣٦٦- والحسن البصري -من طريق يزيد النحوي-: مكّيّة{5}. (ز) ٧٨٣٦٧- عن قتادة بن دعامة -من طرق-: مكّيّة{6}. (ز) ٧٨٣٦٨- عن محمد بن مسلم الزُّهريّ: مكّيّة، ونزلت بعد سورة المُلك{7}. (ز) ٧٨٣٦٩- عن علي بن أبي طلحة: مكّيّة{8}. (ز) ٧٨٣٧٠- قال مقاتل بن سليمان: سورة الحاقة مكّيّة، عددها اثنتان وخمسون آية كوفي{9}٦٧٥٢. (ز) ٦٧٥٢ ذكر ابنُ عطية (٨/٣٨٤) أنّ هذه السورة مكية بإجماع. ",footnotes:1:أخرجه أحمد ١/٢٦٢ (١٠٧). وقال محقّقوه: «إسناده ضعيف».أخرجه أبو جعفر النحاس في الناسخ والمنسوخ ص٧٤٩ من طريق أبي عمرو بن العلاء عن مجاهد، والبيهقي في دلائل النبوة ٧/١٤٢-١٤٤ من طريق خُصَيف عن مجاهد. وعزاه السيوطي إلى ابن مردويه.عزاه السيوطي إلى ابن مردويه.أخرجه ابن الضُّريس في فضائل القرآن ١/٣٣-٣٥.أخرجه البيهقي في دلائل النبوة ٧/١٤٢-١٤٣.أخرجه الحارث المحاسبي في فهم القرآن ص٣٩٥-٣٩٦ من طريق سعيد، وأبو بكر بن الأنباري -كما في الإتقان ١/٥٧- من طريق همام.تنزيل القرآن ص٣٧-٤٢.أخرجه أبو عبيد في فضائله (ت: الخياطي) ٢/٢٠٠.تفسير مقاتل بن سليمان ٤/٤١٩.
69,2," <q>﴿ٱلۡحَاۤقَّةُ ۝١ مَا ٱلۡحَاۤقَّةُ ۝٢ وَمَاۤ أَدۡرَىٰكَ مَا ٱلۡحَاۤقَّةُ ۝٣﴾</q> - تفسير ٧٨٣٧١- عن عبد الله بن عباس -من طريق علي- في قوله: <q>﴿الحاقَّةُ﴾</q>، قال: من أسماء يوم القيامة{1}. (١٤/٦٦٠) ٧٨٣٧٢- عن الضَّحّاك بن مُزاحِم -من طريق عبيد- قال في قوله: <q>﴿الحاقَّةُ﴾</q>: يعني: القيامة{2}. (ز) ٧٨٣٧٣- عن عكرمة مولى ابن عباس -من طريق جابر- قال: <q>﴿الحاقَّةُ﴾</q> القيامة{3}. (ز) ٧٨٣٧٤- عن قتادة بن دعامة -من طريق معمر- في قوله: <q>﴿الحاقَّةُ﴾</q> قال: يعني: الساعة، أحقّتْ لكلِّ عاملٍ عمَلَه، <q>﴿وما أدْراكَ ما الحاقَّةُ﴾</q> قال: تعظيمًا ليوم القيامة، كما تَسمعون{4}. (١٤/٦٦١) ٧٨٣٧٥- قال مقاتل بن سليمان: قوله تعالى: <q>﴿الحاقَّةُ ما الحاقَّةُ﴾</q> ثم بيّن ما الحاقة؛ يعني: الساعة التي فيها حقائق الأعمال، يقول: يحقّ للمؤمنين عملهم، ويحقّ للكافرين عملهم. ثم قال للنبي ﷺ: <q>﴿وما أدْراكَ ما الحاقَّةُ﴾</q> تعظيمًا لها لشِدّتها{5}. (ز) ٧٨٣٧٦- عن عبد الملك ابن جُرَيْج، في قوله: <q>﴿الحاقَّةُ﴾</q>، قال: حقَّقتْ لكل عامل عمَله؛ للمؤمن إيمانه، وللمنافق نفاقه{6}. (١٤/٦٦١) ٧٨٣٧٧- عن سفيان -من طريق مهران- قال: ما في القرآن: <q>﴿وما يُدْرِيكَ﴾</q> [الأحزاب:٦٣، الشورى:١٧، عبس:٣] فلم يُخبِره، وما كان: <q>﴿وما أدْراكَ﴾</q> فقد أخبَره{7}. (ز) ٧٨٣٧٨- قال عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿الحاقَّةُ ما الحاقَّةُ﴾</q>، و<q>﴿القارِعَةُ ما القارِعَةُ﴾</q> [القارعة:١-٢]، و<q>﴿الواقِعَةُ﴾</q> [الواقعة:١]، و<q>﴿الطّامَّةُ﴾</q> [النازعات:٣٤]، و<q>﴿الصّاخَّةُ﴾</q> [عبس:٣٣]، قال: هذا كلّه يوم القيامة؛ الساعة. وقرأ قول الله: <q>﴿لَيْسَ لِوَقْعَتِها كاذِبَةٌ خافِضَةٌ رافِعَةٌ﴾</q> [الواقعة:٢-٣]، والخافضة مِن هؤلاء أيضًا خَفَضَتْ أهل النار، ولا نَعلَم أحدًا أخْفَض من أهل النار، ولا أذلّ، ولا أخْزى، ورَفعَتْ أهل الجنة، ولا نَعلَم أحدًا أشرف من أهل الجنة، ولا أكرم{2}. (ز) ٧٨٣٧٩- قال يحيى بن سلّام: وبلغني أنّ كلّ شيء في القرآن <q>﴿وما أدْراكَ﴾</q> فقد أدراه إياه، وكلّ شيء <q>﴿وما يُدْرِيكَ﴾</q> [الأحزاب:٦٣، الشورى:١٧، عبس:٣] فهو ما لم يُعْلِمه إياه بعد{9}٦٧٥٣. (ز) ٦٧٥٣ ذكر ابن عطية (٨/٣٨٤) أنّ بعض المفسرين قال بأن «الحاقة» مصدر كالعافية والعاقبة، وعلَّق عليه بقوله: «كأنه قال: ذات الحق». ",footnotes:1:أخرجه ابن جرير ٢٣/٢٠٥. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.أخرجه ابن جرير ٢٣/٢٠٦.أخرجه آدم بن أبي إياس -كما في تفسير مجاهد ص٦٧١-، وابن جرير ٢٣/٢٠٥.أخرجه عبد الرزاق ٢/٣١٢ بنحوه، وابن جرير ٢٣/٢٠٦-٢٠٧ بنحوه، ومن طريق سعيد أيضًا. وعلقه الحاكم ٢/٥٠٠. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.تفسير مقاتل بن سليمان ٤/٤٢١.عزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ٢٣/٢٠٧.أخرجه ابن جرير ٢٣/٢٠٦.تفسير ابن أبي زمنين ٥/٢٦.
  69,3,""
69,4," <q>﴿كَذَّبَتۡ ثَمُودُ وَعَادُۢ بِٱلۡقَارِعَةِ ۝٤﴾</q> - تفسير ٧٨٣٨٠- عن عبد الله بن عباس -من طريق عطية العَوفيّ- قوله: <q>﴿كَذَّبَتْ ثَمُودُ وعادٌ بِالقارِعَةِ﴾</q>، قال: القارعة: يوم القيامة{1}. (ز) ٧٨٣٨١- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿كَذَّبَتْ ثَمُودُ وعادٌ بِالقارِعَةِ﴾</q>، قال: بالساعة{2}. (١٤/٦٦١) ٧٨٣٨٢- قال محمد بن السّائِب الكلبي: <q>﴿كَذَّبَتْ ثَمُودُ وعادٌ بِالقارِعَةِ﴾</q>، القارعة: اسم من أسماء القيامة{3}. (ز) ٧٨٣٨٣- قال مقاتل بن سليمان: ثم قال: هي القارعة، والساعة التي <q>﴿كَذَّبَتْ﴾</q> بها <q>﴿ثَمُودُ وعادٌ بِالقارِعَةِ﴾</q>، نظيرها في سورة القارعة، وإنما سُمّيت القارعة لأن الله ﷿ يَقرع أعداءه بالعذاب{4}. (ز) ٧٨٣٨٤- عن عبد الملك ابن جُرَيْج، في قوله: <q>﴿بِالقارِعَةِ﴾</q>، قال: يوم القيامة{5}. (١٤/٦٦١) ",footnotes:1:أخرجه ابن جرير ٢٣/٢٠٧.أخرجه ابن جرير ٢٣/٢٠٧. وعلقه الحاكم ٢/٥٠٠. وعزاه السيوطي إلى عبد الرزاق، وعبد بن حميد، وابن المنذر.ذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٥/٢٦-.تفسير مقاتل بن سليمان ٤/٤٢١.عزاه السيوطي إلى ابن المنذر.
69,5," <q>﴿فَأَمَّا ثَمُودُ فَأُهۡلِكُوا۟ بِٱلطَّاغِیَةِ ۝٥﴾</q> - تفسير ٧٨٣٨٥- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿فَأُهْلِكُوا بِالطّاغِيَةِ﴾</q>، قال: بالذّنوب.= (ز) ٧٨٣٨٦- وكان عبد الله بن عباس يقول: الصّيحة{1}. (١٤/٦٦١) ٧٨٣٨٧- عن قتادة بن دعامة -من طريق معمر- في قوله: <q>﴿فَأُهْلِكُوا بِالطّاغِيَةِ﴾</q>، قال: أرسَل الله عليهم صيحة واحدة، فأهمدتهم، فأُهلكوا{2}. (١٤/٦٦١) ٧٨٣٨٨- قال محمد بن السّائِب الكلبي: <q>﴿فَأَمّا ثَمُودُ فَأُهْلِكُوا بِالطّاغِيَةِ﴾</q>، الطّاغية: الصّاعقة التي أُهلِكوا بها{3}. (ز) ٧٨٣٨٩- قال مقاتل بن سليمان: ثم أخبر الله تعالى عن عاد وثمود، فقال: <q>﴿فَأَمّا ثَمُودُ فَأُهْلِكُوا بِالطّاغِيَةِ﴾</q> يقول: عُذِّبوا بطغيانهم، والطّغيان حمَلهم على تكذيب صالح النبي -صلى الله عليه-{4}. (ز) ٧٨٣٩٠- قال عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿فَأَمّا ثَمُودُ فَأُهْلِكُوا بِالطّاغِيَةِ﴾</q>، فقرأ قول الله: <q>﴿كَذَّبَتْ ثَمُودُ بِطَغْواها﴾</q> [الشمس:١١]، وقال: هذه الطّاغية طغيانهم وكفْرهم بآيات الله؛ الطّاغية طغيانهم الذي طَغَوا في معاصي الله وخلاف كتاب الله{5}٦٧٥٤. (ز) ٦٧٥٤ اختُلف في المراد بالطاغية على أقوال: الأول: أنها طغيانهم وكفرهم بالله. الثاني: الصّيحة الطّاغية. الثالث: أنها الفئة الطاغية. ذكره ابن عطية (٨/٣٨٥). ورجَّح ابنُ جرير (٢٣/٢٠٩) -مستندًا إلى السياق، ودلالة العقل- القول الثاني الذي قاله ابن عباس، وقتادة، والكلبي، فقال: «لأنّ الله إنما أخبر عن ثمود بالمعنى الذي أهلكها به، كما أخبر عن عادٍ بالذي أهلكها به، فقال: <q>﴿وأما عاد فأهلكوا بريح صرصر عاتية﴾</q>، ولو كان الخبر عن ثمود بالسبب الذي أهلكها مِن أجله كان الخبر أيضًا عن عاد كذلك؛ إذ كان ذلك في سياق واحد، وفي إتباعه ذلك بخبره عن عاد بأنّ هلاكها كان بالريح- الدليل الواضح على أنّ إخباره عن ثمود إنما هو ما بَيّنتُ». ورجَّحه ابنُ عطية (٨/٣٨٥)، وانتقد ما عداه مستندًا إلى السياق، فقال: «وأولى الأقوال وأصوبها الأول؛ لأنه منتسب لما ذكر في عاد؛ إذ ذكر فيه الوجه الذي وقع به الهلاك، وعلى سائر الأقوال لا يتناسب الأمران؛ لأنّ طغيان ثمود سبب، والريح لا يناسب ذلك؛ لأنها ليست بسبب الإهلاك، بل آلته كما في الصيحة». وذكر ابنُ عطية أنّ الطّاغية على قول ابن زيد مصدر كالعاقبة. وعلَّق عليه بقوله: «فكأنه تعالى قال: بطغيانهم». وذكر أنّ قوله تعالى: <q>﴿كذبت ثمود بطغواها﴾</q> [الشمس:١٠] يقوّي هذا القول. وذكر ابنُ كثير (١٤/١١١) أنّ السُّدِّيّ قال بأن الطاغية: «عاقر الناقة». ",footnotes:1:أخرجه ابن جرير ٢٣/٢٠٨. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه عبد الرزاق ٢/٣١٢، وابن جرير ٢٣/٢٠٩، وبنحوه من طريق سعيد. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.ذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٥/٢٦-٢٧-.تفسير مقاتل بن سليمان ٤/٤٢١.أخرجه ابن جرير ٢٣/٢٠٨.
69,6," <q>﴿وَأَمَّا عَادࣱ فَأُهۡلِكُوا۟ بِرِیحࣲ صَرۡصَرٍ عَاتِیَةࣲ ۝٦﴾</q> - تفسير ٧٨٣٩١- عن عبد الله بن عباس، عن النبي ﷺ، قال: «نُصِرْتُ بالصّبا، وأُهلِكَتْ عادٌ بالدَّبُورِ». قال: «ما أُمِر الخُزّان أن يُرسِلوا على عادٍ إلا مثل موضع الخاتم مِن الريح، فعَتَتْ على الخُزّان، فخَرجتْ من نواحي الأبواب، فذلك قوله: <q>﴿بِرِيحٍ صَرْصَرٍ عاتِيَةٍ﴾</q>». قال: «عُتوّها: عَتَتْ على الخُزّان، فبدأتْ بأهل البادية منهم، فحَملتْهم بمواشيهم وبيوتهم، فأَقبلتْ بهم إلى الحاضرة، فلمّا رَأوها قالوا: هذا عارضٌ مُمطِرنا. فلمّا دنَت الريح وأَظلّتهم استبقَ الناسُ والمواشي فيها، فأَلقَت الباديةَ على أهل الحاضرة، فقَصفتْهم، فهَلكوا جميعًا»{1}. (١٤/٦٦٢) ٧٨٣٩٢- عن عبد الله بن عباس، قال: قال رسول الله ﷺ: «ما أنزل الله من السماء كفًّا من ماء إلا بمكيال، ولا كفًّا من ريح إلا بمكيال، إلا يوم نوح، فإنّ الماء طغى على الخُزّان، فلم يكن لهم عليه سلطان، قال الله: <q>﴿إنّا لَمّا طَغى الماءُ حَمَلْناكُمْ فِي الجارِيَةِ﴾</q>. ويوم عاد، فإنّ الريح عَتَتْ على الخُزّان، قال الله: <q>﴿بِرِيحٍ صَرْصَرٍ عاتِيَةٍ﴾</q>»{2}. (١٤/٦٦٣) ٧٨٣٩٣- عن علي بن أبي طالب -من طريق أبي سنان، عن غير واحد- قال: لم تَنزِل قَطرةٌ مِن ماء إلا بمكيالٍ على يدي مَلك، إلا يوم نوح، فإنه أُذِن للماء دون الخُزّان، فطغى الماء على الخُزّان، فخرج، فذلك قوله: <q>﴿إنّا لَمّا طَغى الماءُ﴾</q>، ولم ينزل شيءٌ من الريح إلا بكيلٍ على يدي مَلك، إلا يوم عاد، فإنه أُذِن لها دون الخُزّان، فخَرجتْ، فذلك قول الله: <q>﴿بِرِيحٍ صَرْصَرٍ عاتِيَةٍ﴾</q> عَتَتْ على الخُزّان{3}. (١٤/٦٦٢) ٧٨٣٩٤- عن عبد الله بن عباس -من طريق شَهْر بن حَوْشَب- قال: ما أرسَل الله شيئًا من ريح إلا بمكيال، ولا قَطرة من مطر إلا بمكيال، إلا يوم نوح ويوم عاد، فأمّا يوم نوح فإنّ الماء طغى على خُزّانه، فلم يكن لهم عليه سبيل. ثم قرأ: <q>﴿إنّا لَمّا طَغى الماءُ﴾</q>. وأمّا يوم عاد فإنّ الريح عَتَتْ على خُزّانها، فلم يكن لهم عليها سبيل. ثم قرأ: <q>﴿بِرِيحٍ صَرْصَرٍ عاتِيَةٍ﴾</q>{4}. (١٤/٦٦١) ٧٨٣٩٥- عن عبد الله بن عباس -من طريق عطية- قوله: <q>﴿وأَمّا عادٌ فَأُهْلِكُوا بِرِيحٍ صَرْصَرٍ عاتِيَةٍ﴾</q>، يقول: بريح مُهلِكة باردة، عَتَتْ عليهم بغير رحمة ولا بركة، دائمة لا تَفْتُر{5}. (ز) ٧٨٣٩٦- عن عبد الله بن عباس، في قوله: <q>﴿بِرِيحٍ صَرْصَرٍ عاتِيَةٍ﴾</q>، قال: الغالبة{6}. (١٤/٦٦٣) ٧٨٣٩٧- عن قَبِيصة بن ذُؤَيْب -من طريق ابن شهاب- قال: ما يَخرج مِن الريح شيءٌ إلا عليها خُزّان يعلمون قَدْرها، وعددها، ووزنها، وكَيْلها، حتى كانت الريحُ التي أُرسِلَتْ على عاد، فاندَفقَ منها شيءٌ لا يعلمون قَدْره ولا وزْنه ولا كَيْله؛ غضبًا لله، ولذلك سُمّيتْ عاتية، والماء كذلك حين كان أمْر نوح؛ فلذلك سُمّي طاغية{7}. (١٤/٦٦٤) ٧٨٣٩٨- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿عاتِيَةٍ﴾</q>، قال: شديدة{8}. (١٤/٦٦٣) ٧٨٣٩٩- عن الضَّحّاك بن مُزاحِم -من طريق عبيد- في قوله: <q>﴿بِرِيحٍ صَرْصَرٍ﴾</q> يعني: باردة، <q>﴿عاتِيَةٍ﴾</q> عَتَتْ عليهم بلا رحمة ولا بركة{9}. (ز) ٧٨٤٠٠- عن عكرمة مولى ابن عباس، قال: الصَّرْصَر: الباردة، <q>﴿عاتِيَةٍ﴾</q> قال: حيثُ عَتَتْ على خُزّانها{10}. (١٤/٦٦٣) ٧٨٤٠١- عن عامر الشعبي -من طريق زكريا- قال: كانت الريح تَمُرّ بالمرأة في هَوْدجها فتَحملها، وبالإبل والغنم لهم فتَحملها، وبالقوم منهم فتَحملهم، فتَطير بهم بين السماء والأرض، فتَضرب بعضهم ببعض. وتَمُرّ بالعادي الواحد بين القوم، فتَحمله من بينهم، والناس يَنظرون، لا تُصيب إلا عاديًّا. يقول الله تعالى: <q>﴿وأَمّا عادٌ فَأُهْلِكُوا بِرِيحٍ صَرْصَرٍ عاتِيَةٍ﴾</q> يعني: باردة. في يوم نحس: يعني: مشؤوم{11}. (ز) ٧٨٤٠٢- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿بِرِيحٍ صَرْصَرٍ عاتِيَةٍ﴾</q>، قال: عَتَتْ عليهم حتى نَقَّبتْ أفئدتَهم{12}. (١٤/٦٦١) ٧٨٤٠٣- عن عطاء الخُراسانيّ -من طريق يونس بن يزيد- في قوله تعالى: <q>﴿بريح صرصر﴾</q>، قال: صَرْصرٌ باردة شديدة{13}. (ز) ٧٨٤٠٤- قال مقاتل بن سليمان: <q>﴿وأَمّا عادٌ فَأُهْلِكُوا﴾</q> يعني: عُذِّبوا <q>﴿بِرِيحٍ صَرْصَرٍ﴾</q> يعني: باردة <q>﴿عاتِيَةٍ﴾</q> شديدة، عَتَتْ على خُزّانها بغير رأفة ولا رحمة{14}. (ز) ٧٨٤٠٥- قال عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿بِرِيحٍ صَرْصَرٍ عاتِيَةٍ﴾</q>، قال: الصَّرْصَر: الشديدة. والعاتية: القاهرة، التي عَتَتْ عليهم فقَهرتْهم{9}. (ز) ٧٨٤٠٦- عن سفيان بن عُيينة: <q>﴿عاتِيَةٍ﴾</q> عَتَتْ عن الخُزّان{16}٦٧٥٥. (ز) ٦٧٥٥ قال ابنُ عطية (٨/٣٨٥): «والصرصر: يحتمل أنْ يكون من الصِّرّ، أي: البرد. وهو قول قتادة. ويحتمل أن يكون مِن: صرّ الشيء؛ إذا صوّت». وذكر أنّ قومًا قالوا: صوت الريح صَرْصَر. وعلَّق عليه بقوله: «كأنه يحكي هذين الحرفين». ",footnotes:1:أخرجه أبو الشيخ في العظمة ٤/١٣٥٠-١٣٥١، وأخرج الجملة الأولى منه البخاري ٢/٣٣ (١٠٣٥)، ٤/١٠٩ (٣٢٠٥)، ٤/١٣٧ (٣٣٤٣)، ٥/١٠٩ (٤١٠٥)، ومسلم ٢/٦١٧ (٩٠٠).أخرجه أبو الشيخ في العظمة ٤/١٢٥٣-١٢٥٤، ٤/١٣٠٦-١٣٠٧، وأبو نعيم في الحلية ٦/٦٥، وابن عساكر في تاريخ دمشق ٦٢/٢٦١، وابن مردويه -كما في تخريج أحاديث الكشاف ٤/٨٣-٨٤-، من طريق المعافى الحراني، عن موسى بن أعين، عن الثوري، عن موسى بن المسيب، عن شهر بن حوشب، عن ابن عباس به. قال أبو نعيم: «رواه الفريابي والناس موقوفًا على سفيان، وتفرَّد به، يرفعه عن موسى بن أعين، عن سفيان».أخرجه ابن جرير ٢٣/٢١٠-٢١١.أخرجه ابن جرير ٢٣/٢١٠. وعزاه السيوطي إلى الفريابي، وعبد بن حميد.أخرجه ابن جرير ٢٣/٢١٠.عزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.عزاه السيوطي إلى ابن عساكر.أخرجه أبو الشيخ في العظمة (٨١٣)، وابن جرير ٢٣/٢١١.أخرجه ابن جرير ٢٣/٢١١.عزاه السيوطي إلى عبد بن حميد.أخرجه ابن أبي الدنيا في كتاب العقوبات -موسوعة الإمام ابن أبي الدنيا ٤/٤٥٨-٤٥٩ (١٣١)-.أخرجه ابن جرير ٢٣/٢١٠. وعزاه السيوطي إلى عبد الرزاق، وعبد بن حميد، وابن المنذر.أخرجه أبو جعفر الرملي في جزئه (تفسير عطاء) ص٩١.تفسير مقاتل بن سليمان ٤/٤٢١.أخرجه ابن جرير ٢٣/٢١١.تفسير ابن عيينة -كما في الفتح ٦/٣٧٧-. وعلقه البخاري في صحيحه ٦/١٠٩.
69,7," <q>﴿سَخَّرَهَا عَلَیۡهِمۡ سَبۡعَ لَیَالࣲ وَثَمَـٰنِیَةَ أَیَّامٍ حُسُومࣰاۖ﴾</q> - تفسير ٧٨٤٠٧- عن عبد الله بن مسعود -من طريق أبي معمر- في قوله: <q>﴿حُسُومًا﴾</q>، قال: مُتتابعات{1}. (١٤/٦٦٤) ٧٨٤٠٨- عن عبد الله بن عباس -من طريق علي- في قوله: <q>﴿حُسُومًا﴾</q>، قال: تِباعًا{2}. (١٤/٦٦٤) ٧٨٤٠٩- عن عبد الله بن عباس، أنّ نافع بن الأزرق قال له: أخبِرني عن قوله: <q>﴿حُسُومًا﴾</q>. قال: دائمة شديدة، يعني: مَحسومة بالبلاء. قال: وهل تعرف العرب ذلك؟ قال: نعم، أما سمعتَ أُميّة بن أبي الصّلت وهو يقول: وكم كُنّا بها من فَرطِ عام وهذا الدّهر مُقتبلٌ حُسُوم{3}. (١٤/٦٦٤) ٧٨٤١٠- عن عبد الله بن عباس -من طريق أبي داود- قال: أول ما عَرفوا أنّه عذاب رَأوا ما كان خارجًا من رِحالهم ومواشيهم، تَطير بين السماء والأرض مِثل الريش، دَخلوا بيوتهم، وأَغلقوا أبوابهم، فجاءت الريح، ففَتحتْ أبوابهم، ومالتْ بالرّمل، فكانوا تحت الرّمل <q>﴿سَبْعَ لَيالٍ وثَمانِيَةَ أيّامٍ حُسُومًا﴾</q> لهم أنين، ثم أمَر الريح فسَكنتْ عنهم الرّمل، وأَمرَها فطَرحتْهم في البحر، فهو قوله تعالى: <q>﴿فَأَصْبَحُوا لا يُرى إلّا مَساكِنُهُمْ﴾</q> [الأحقاف:٢٥]{4}. (ز) ٧٨٤١١- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿حُسُومًا﴾</q>، قال: مُتتابِعة{5}. (١٤/٦٦٥) ٧٨٤١٢- قال الضَّحّاك بن مُزاحِم: كاملة، لم تَفْتُر عنهم حتى أفنَتْهم{6}. (ز) ٧٨٤١٣- عن عكرمة مولى ابن عباس -من طريق سِماك- في قوله: <q>﴿حُسُومًا﴾</q>، قال: مُتتابعة{7}. (١٤/٦٦٥) ٧٨٤١٤- عن عكرمة مولى ابن عباس -من طريق عبد الكريم الجزري- قال: <q>﴿حُسُومًا﴾</q>، قال: مشايِم{8}. (ز) ٧٨٤١٥- قال عطية العَوفيّ: شؤمًا؛ كأنها حَسمت الخير عن أهلها{9}. (ز) ٧٨٤١٦- قال وهْب بن مُنَبِّه: <q>﴿سَبْعَ لَيالٍ وثَمانِيَةَ أيّامٍ﴾</q> هي الأيام التي سَمّاها العرب: أيام العجوز، ذات بردٍ ورياح شديدة، وإنما نُسبتْ هذه الأيام الى العجوز لأنّ عجوزًا دخَلتْ سربًا، فتَبِعتْها الريح، فقتَلتْها اليوم الثامن من نزول العذاب، وانقطع العذاب في اليوم الثامن{10}. (ز) ٧٨٤١٧- عن قتادة بن دعامة -من طريق سعيد- قوله <q>﴿وثَمانِيَةَ أيّامٍ حُسُومًا﴾</q>، قال: مُتتابعة، ليس فيه تَفتير{11}. (ز) ٧٨٤١٨- عن قتادة بن دعامة -من طريق معمر- في قوله: <q>﴿حُسُومًا﴾</q>، قال: دائمات{12}. (١٤/٦٦٥) ٧٨٤١٩- عن الربيع بن أنس، في قوله: <q>﴿سَخَّرَها عَلَيْهِمْ سَبْعَ لَيالٍ وثَمانِيَةَ أيّامٍ﴾</q>، قال: كان أولها الجمعة{13}. (١٤/٦٦٤) ٧٨٤٢٠- قال محمد بن السّائِب الكلبي: <q>﴿حُسُومًا﴾</q> دائمة{14}. (ز) ٧٨٤٢١- قال مقاتل بن سليمان: <q>﴿سَخَّرَها﴾</q> يعني: سَلّطها <q>﴿عَلَيْهِمْ﴾</q> الرّبُّ -تبارك وتعالى- <q>﴿سَبْعَ لَيالٍ وثَمانِيَةَ أيّامٍ حُسُومًا﴾</q> فهي كاملة دائمة، لا تَفْتُر عنهم فيهنَّ، يُعذّبهم بالريح كلَّ يوم حتى أفنتْ أرْواحَهُم يوم الثامن{15}. (ز) ٧٨٤٢٢- عن عبد الملك ابن جُرَيْج، في قوله: <q>﴿سَخَّرَها عَلَيْهِمْ سَبْعَ لَيالٍ وثَمانِيَةَ أيّامٍ حُسُومًا﴾</q>، قال: كانوا سبعَ ليال وثمانيةَ أيام أحياء في عذاب مِن الريح، فلمّا أمسَوا اليومَ الثامن ماتوا، فاحتَملتْهم الريح، فأَلقتْهم في البحر، فذلك قوله: <q>﴿فَهَلْ تَرى لَهُمْ مِن باقِيَةٍ﴾</q>. وقوله: ‹فَأَصْبَحُوا لا تَرى إلّا مَساكِنَهُمْ› [الأحقاف:٢٥]. قال: وأُخْبِرتُ أنّ النبي ﷺ قال: «عذّبهم بُكرةً، وكَشف عنهم في اليوم الثاني حتى كان الليلُ»{16}. (١٤/٦٦٥) ٧٨٤٢٣- عن سفيان [الثوري] -من طريق مهران- <q>﴿أيّامٍ حُسُومًا﴾</q>، قال: مُتتابعة. و<q>﴿أيّامٍ نَحِساتٍ﴾</q> [فصلت:١٦]، قال: مَشائيم{11}. (ز) ٧٨٤٢٤- قال عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿وثَمانِيَةَ أيّامٍ حُسُومًا﴾</q>، قال: حَسَمتْهم؛ لم تُبقِ منهم أحدًا. قال: ذلك الحُسُوم، مثل الذي يقول: احْسِم هذا الأمر. قال: وكان فيهم ثمانية لهم خَلْقٌ يَذهب بهم في كلّ مَذهب. قال: قال موسى بن عُقبة: فلما جاءهم العذاب قالوا: قُوموا بنا نَردّ هذا العذاب عن قومنا. قال: فقاموا، وصَفُّوا في الوادي، فأوحى اللهُ إلى مَلِك الريح أن يَقلع منهم كلَّ يوم واحدًا. وقرأ قول الله: <q>﴿سَخَّرَها عَلَيْهِمْ سَبْعَ لَيالٍ وثَمانِيَةَ أيّامٍ حُسُومًا﴾</q> حتى بلغ: <q>﴿نَخْلٍ خاوِيَةٍ﴾</q>. قال: فإن كانت الريح لَتَمُرّ بالظَّعينة، فتَسْتَدْبرها وحُمولتها، ثم تَذهب بهم في السماء، ثم تَكُبّهم على الرؤوس. وقرأ قول الله: <q>﴿فَلَمّا رَأَوْهُ عارِضًا مُسْتَقْبِلَ أوْدِيَتِهِمْ قالُوا هَذا عارِضٌ مُمْطِرُنا﴾</q> قال: وكان أمسك عنهم المطر. فقرأ حتى بلغ: <q>﴿تُدَمِّرُ كُلَّ شَيْءٍ بِأَمْرِ رَبِّها﴾</q> [الأحقاف:٢٤، ٢٥]. قال: وما كانت الريح تَقلع من أولئك الثمانية كلّ يوم إلا واحدًا. قال: فلمّا عَذّب الله قوم عاد أبقى الله واحدًا يُنذِر الناس. قال: فكانت امرأةُ قد رَأتْ قومها، فقالوا لها: أنتِ أيضًا. قالت: تَنحّيتُ على الجبل. قال: وقيل لها بعدُ: أنتِ قد سَلمتِ وقد رأيتِ، فكيف لا رأيتِ عذاب الله؟ قالت: ما أدري غير أنّ أسْلَم ليلةٍ ليلةَ لا ريح{18}٦٧٥٦. (ز) ٦٧٥٦ اختُلف في معنى قوله: <q>﴿حسوما﴾</q> على أقوال: الأول: أنها المتتابعة. الثاني: أنها الريح التي تَحسم كلّ شيء. الثالث: مشائيم. وعلَّق ابنُ عطية (٨/٣٨٦) على القول الأول الذي قاله ابن مسعود، وابن عباس، وقتادة، وعكرمة، ومجاهد، وسفيان، والكلبي، والضَّحّاك، بقوله: «ومنه كما تقول العرب:ما لقيته حولًا مجرّمًا». وعلَّق (٨/٣٨٧) على القول الثاني الذي قاله ابن زيد، والعَوفيّ، بقوله: «ومعناه: أنّ تلك الأيام قطّعتهم بالإهلاك، ومنه: حسْم العِلل، ومنه: الحُسام». ورجَّح ابنُ جرير (١٤/٢١٤-٢١٥) -مستندًا إلى الإجماع- القول الأول، فقال: «لإجماع الحجة مِن أهل التأويل على ذلك». ثم ذكر أنّ بعض أهل العربية يقول: الحُسوم: التّباع، إذا تتابع الشيء فلم ينقطع أوله عن آخره قيل فيه: حُسوم. وعلَّق عليه بقوله: «وإنما أُخذ -والله أعلم- من: حَسَم الداء؛ إذا كُوى صاحبه؛ لأنه لحم يُكوى بالمكواة، ثم يُتابع عليه». وبيّن (١٤/٢١٣) أنه على القول الثاني فالحُسوم من صفة الريح. <q>﴿فَتَرَى ٱلۡقَوۡمَ فِیهَا صَرۡعَىٰ كَأَنَّهُمۡ أَعۡجَازُ نَخۡلٍ خَاوِیَةࣲ ۝٧﴾</q> - تفسير ٧٨٤٢٥- عن عبد الله بن عباس، في قوله: <q>﴿كَأَنَّهُمْ أعْجازُ نَخْلٍ﴾</q> قال: أصولها. وفي قوله: <q>﴿خاوِيَةٍ﴾</q> قال: خَرِبة{16}. (١٤/٦٦٥) ٧٨٤٢٦- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿كَأَنَّهُمْ أعْجازُ نَخْلٍ خاوِيَةٍ﴾</q>، قال: هي أصول النّخل؛ قد بَقِيتْ أصولُها، وذَهبت أعاليها{20}. (١٤/٦٦٥) ٧٨٤٢٧- قال مقاتل بن سليمان: <q>﴿فَتَرى﴾</q> يا محمد <q>﴿القَوْمَ فِيها﴾</q> يعني: في تلك الأيام <q>﴿صَرْعى﴾</q> يعني: موتى، يعني: أمواتًا، وكان طول كلِّ رجل منهم اثني عشر ذراعًا، ثم شَبّههم بالنّخل، فقال: <q>﴿كَأَنَّهُمْ أعْجازُ نَخْلٍ﴾</q> فذَكر النّخل لطولهم، <q>﴿خاوِيَةٍ﴾</q> يعني: أصول نخلٍ بالية، التي ليست لها رؤوس، وبَقِيتْ أصولها، وذهبت أعناقها{21}٦٧٥٧. (ز) ٦٧٥٧ ذكر ابنُ عطية (٨/٣٨٧) أنّ الضمير في قوله: <q>﴿فِيها صَرْعى﴾</q> يحتمل احتمالين: الأول: أن يعود على دارهم وحِلّتهم؛ لأنّ معنى الكلام يقتضيها، وإن لم يُلفظ بها. الثاني: أن يعود على الريح. وذكر أنّ الثعلبي نَقله. ",footnotes:1:أخرجه عبد الرزاق ٢/٣١٢ بلفظ: مُتتابعة، وابن جرير ٢٣/٢١٢-٢١٣ بلفظ: مُتتابعة، وتِباعًا، والطبراني (٩٠٦١)، والحاكم ٢/٥٠٠. وعزاه السيوطي إلى الفريابي، وسعيد بن منصور، وعبد بن حميد، وابن المنذر.أخرجه ابن جرير ٢٣/٢١٢. وعزاه السيوطي إلى عبد بن حميد، وقال: وفي لفظ: مُتتابعات.عزاه السيوطي إلى الطستي.أخرجه ابن أبي الدنيا في كتاب العقوبات، وفي كتاب المطر والرعد والبرق والريح -موسوعة الإمام ابن أبي الدنيا ٤/٤٥٧ (١٢٧)، ٨/٤٤٤ (١٣٤)-، وأبو الشيخ في العظمة (٨١١).تفسير مجاهد ص٦٧١ من طريق منصور. وأخرجه ابن جرير ٢٣/٢١٢، وأبو الشيخ في العظمة (٨١٣). وعزاه السيوطي إلى عبد بن حميد.تفسير الثعلبي ١٠/٢٧.أخرجه ابن جرير ٢٣/٢١٢. وعزاه السيوطي إلى عبد بن حميد.أخرجه عبد الرزاق ٢/٣١٢. ووردت هكذا في المطبوع! ولعلها تصحَّفت عن: مشائيم.تفسير الثعلبي ١٠/٢٧، وتفسير البغوي ٨/٢٠٨.تفسير الثعلبي ١٠/٢٦، وتفسير البغوي ٨/٢٠٨.أخرجه ابن جرير ٢٣/٢١٣.أخرجه عبد الرزاق ٢/٢١٣، ٣/٣٣٨، وابن جرير ٢٣/٢١٣. وعزاه السيوطي إلى عبد بن حميد.عزاه السيوطي إلى ابن أبي حاتم.تفسير البغوي ٨/٢٠٨، وتفسير الثعلبي ١٠/٢٧.تفسير مقاتل بن سليمان ٤/٤٢١.عزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ٢٣/٢١٣.أخرجه ابن جرير ٢٣/٢١٤.عزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ٢٣/٢١٥. وعزاه السيوطي إلى عبد بن حميد، وعبد الرزاق.تفسير مقاتل بن سليمان ٤/٤٢١-٤٢٢.
69,8," <q>﴿فَهَلۡ تَرَىٰ لَهُم مِّنۢ بَاقِیَةࣲ ۝٨﴾</q> - تفسير ٧٨٤٢٨- قال مقاتل بن سليمان: <q>﴿فَهَلْ تَرى لَهُمْ مِن باقِيَةٍ﴾</q>، يقول: لم تُبقِ منهم أحدًا{1}. (ز) ٧٨٤٢٩- عن عبد الملك ابن جُرَيْج، في قوله: ... فلما أمسَوا اليومَ الثامن ماتوا، فاحتَملتْهم الريح، فأَلقتْهم في البحر، فذلك قوله: <q>﴿فَهَلْ تَرى لَهُمْ مِن باقِيَةٍ﴾</q>{2}. (١٤/٦٦٥) ",footnotes:1:تفسير مقاتل بن سليمان ٤/٤٢١-٤٢٢.عزاه السيوطي إلى ابن المنذر.
