quran[18]{c,v,t}:
  68,43,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿خَـٰشِعَةً أَبۡصَـٰرُهُمۡ تَرۡهَقُهُمۡ ذِلَّةࣱۖ وَقَدۡ كَانُوا۟ یُدۡعَوۡنَ إِلَى ٱلسُّجُودِ وَهُمۡ سَـٰلِمُونَ ۝٤٣﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٨٣١٧<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- في قوله: <span class="qpc-hafs">﴿وقَدْ كانُوا يُدْعَوْنَ إلى السُّجُودِ وهُمْ سالِمُونَ﴾</span>، قال: هم الكفار، يُدعَون في الدنيا وهم آمنون، فاليوم يُدعَون وهم خائفون، ثم أخبر الله سبحانه أنه حال بين أهل الشرك وبين طاعته في الدنيا والآخرة، فأمّا في الدنيا فإنه قال: <span class="qpc-hafs">﴿ما كانُوا يَسْتَطِيعُونَ السَّمْعَ﴾</span> وهي طاعته، <span class="qpc-hafs">﴿وما كانُوا يُبْصِرُونَ﴾</span> [هود:٢٠]. وأمّا الآخرة فإنه قال: <span class="qpc-hafs">﴿لا يَسْتَطِيعُونَ خاشِعَةً أبْصارُهُمْ﴾</span>{1}. (١٤/٦٤٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٣١٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>-من طريق أبي سِنان، عن سعيد بن جُبَير- في قوله: <span class="qpc-hafs">﴿وقَدْ كانُوا يُدْعَوْنَ إلى السُّجُودِ﴾</span>، قال: الرجل يَسمع الأذان فلا يجيب الصلاة{2}. (١٤/٦٤٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٣١٩<span class="dash">-</span></span> عن <span class="name-2">كعب الأحبار</span>، قال: والذي أنزل التوراة على موسى، والإنجيل على عيسى، والزّبور على داود، والفرقان على محمد؛ لنَزَلَتْ هذه الآية في الصلوات المكتوبات حيث يُنادى بهن: <span class="qpc-hafs">﴿يَوْمَ يُكْشَفُ عَنْ ساقٍ﴾</span> إلى قوله: <span class="qpc-hafs">﴿وقَدْ كانُوا يُدْعَوْنَ إلى السُّجُودِ وهُمْ سالِمُونَ﴾</span> الصلوات الخمس إذا نُودِي بها{3}. (١٤/٦٤٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٣٢٠<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جُبَير</span> -من طريق أبي سِنان- في قوله: <span class="qpc-hafs">﴿وقَدْ كانُوا يُدْعَوْنَ إلى السُّجُودِ﴾</span>، قال: الصلوات في الجماعات{4}. (١٤/٦٤٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٣٢١<span class="dash">-</span></span> عن <span class="name-2">إبراهيم التيميّ</span> -من طريق منصور- <span class="qpc-hafs">﴿وقَدْ كانُوا يُدْعَوْنَ إلى السُّجُودِ وهُمْ سالِمُونَ﴾</span>، قال: إلى الصلاة المكتوبة{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٣٢٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿خاشِعَةً أبْصارُهُمْ﴾</span> عند معاينة النار، <span class="qpc-hafs">﴿تَرْهَقُهُمْ ذِلَّةٌ﴾</span> يعني: تغشاهم مَذَلّة، <span class="qpc-hafs">﴿وقَدْ كانُوا يُدْعَوْنَ إلى السُّجُودِ﴾</span> يعني: يُؤمرون بالصلاة{6} الخمس <span class="qpc-hafs">﴿وهُمْ سالِمُونَ﴾</span> يقول: كانوا مُعافون في الدنيا، فتصير أصلابهم مثل سفافيد الحديد{7}<span class=comment-ref>٦٧٥٠</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٧٥٠</span> <span class="comment-type-4">علَّق</span> <u>ابنُ عطية</u> (٨/٣٨٠) على الأقوال الواردة في السجود بقوله: «وهذا كلّه قريب بعضه من بعض».</div></p></div>",footnotes:1:أخرجه ابن جرير ٢٣/١٩٧. وعزاه السيوطي إلى ابن المنذر.|2:أخرجه البيهقي في الشعب (٢٩١٥).|3:عزاه السيوطي إلى ابن مردويه.|4:أخرجه البيهقي في شعب الإيمان (٢٩١٤)، وابن جرير ٢٣/١٩٦-١٩٧ بلفظ: يسمع المنادي إلى الصلاة المكتوبة فلا يجيبه.|5:أخرجه ابن جرير ٢٣/١٩٦.|6:كذا في المصدر، ولعلها: الصلوات.|7:تفسير مقاتل بن سليمان ٤/٤٠٨-٤٠٩.
  68,44,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿فَذَرۡنِی وَمَن یُكَذِّبُ بِهَـٰذَا ٱلۡحَدِیثِۖ سَنَسۡتَدۡرِجُهُم مِّنۡ حَیۡثُ لَا یَعۡلَمُونَ ۝٤٤﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٨٣٢٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: قوله: <span class="qpc-hafs">﴿فَذَرْنِي﴾</span> هذا تهديد <span class="qpc-hafs">﴿ومَن يُكَذِّبُ بِهَذا الحَدِيثِ﴾</span> يقول: خَلِّ بيني وبين مَن يُكذّب بهذا القرآن، فأنا أنفرد بهلاكهم؛ <span class="qpc-hafs">﴿سَنَسْتَدْرِجُهُمْ مِن حَيْثُ لا يَعْلَمُونَ﴾</span> سَنأخذهم بالعذاب من حيث يَجهلون{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٣٢٤<span class="dash">-</span></span> قال <span class="name-3">سفيان الثوري</span>: يُسبِغ عليهم النِّعم، ويُنسيهم الشكر{2}<span class=comment-ref>٦٧٥١</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٧٥١</span> <span class="comment-type-4">ذكر</span> <u>ابنُ عطية</u> (٨/٣٨٠) «أنّ الاستدراج هو: الحمْل من رتبة إلى رتبة، حتى يصير المحمول إلى شرّ». ثم <span class="comment-type-4">علَّق</span> بقوله: «وإنما يُستعمل الاستدراج في الشّرّ، وهو مأخوذ من الدرَج». وساق الأقوال.</div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٤/٤١٠-٤١١.|2:تفسير الثعلبي ١٠/٢٢.
  68,45,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَأُمۡلِی لَهُمۡۚ إِنَّ كَیۡدِی مَتِینٌ ۝٤٥﴾</span> - نزول الآية، وتفسيرها</h3></p><p><div></p><p><p><span class="item-no">٧٨٣٢٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وأُمْلِي لَهُمْ﴾</span> يقول: لا أعْجَل عليهم بالعذاب، <span class="qpc-hafs">﴿إنَّ كَيْدِي مَتِينٌ﴾</span> يقول: إنّ أخذي بالعذاب شديد. نَزَلَتْ هذه الآية في المُستهزئين من قريش، قَتلهم الله تعالى في ليلة واحدة{1}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٤/٤١١.
  68,46,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿أَمۡ تَسۡـَٔلُهُمۡ أَجۡرࣰا فَهُم مِّن مَّغۡرَمࣲ مُّثۡقَلُونَ ۝٤٦ أَمۡ عِندَهُمُ ٱلۡغَیۡبُ فَهُمۡ یَكۡتُبُونَ ۝٤٧﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٨٣٢٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: قوله: <span class="qpc-hafs">﴿أمْ تَسْأَلُهُمْ أجْرًا﴾</span> يعني: خَراجًا على الإيمان؛ <span class="qpc-hafs">﴿فَهُمْ مِن مَغْرَمٍ مُثْقَلُونَ﴾</span> يقول: أثقَلهم الغُرم؛ فلا يستطيعون الإكثار من أجل الغُرم، <span class="qpc-hafs">﴿أمْ عِنْدَهُمُ﴾</span> يقول: أعندهم علم <span class="qpc-hafs">﴿الغَيْبُ﴾</span> بأنّ الله لا يَبعثهم، وأنّ الذي يقول محمد غير كائن، أم عندهم بذلك كتاب <span class="qpc-hafs">﴿فَهُمْ يَكْتُبُونَ﴾</span> ما شاؤوا{1}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٤/٤١١-٤١٢.
  68,47,""
  68,48,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿فَٱصۡبِرۡ لِحُكۡمِ رَبِّكَ وَلَا تَكُن كَصَاحِبِ ٱلۡحُوتِ إِذۡ نَادَىٰ وَهُوَ مَكۡظُومࣱ ۝٤٨﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٨٣٢٧<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- في قوله: <span class="qpc-hafs">﴿وهُوَ مَكْظُومٌ﴾</span>، قال: مغموم{1}. (١٤/٦٥٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٣٢٨<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿وهُوَ مَكْظُومٌ﴾</span>، قال: مغموم{2}. (١٤/٦٥٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٣٢٩<span class="dash">-</span></span> عن <span class="name-2">وهْب بن مُنَبِّه</span> -من طريق عبد المنعم بن إدريس، عن أبيه- قال: كان في خُلُق يونس ضِيق، فلمّا حُمِّلتْ عليه أثقالُ النّبوة تفسخّ منها تفسخ الرَّبَع{3}، فقذفها من يديه، وهرب، قال تعالى لنبيّه: <span class="qpc-hafs">﴿ولا تَكُنْ كَصاحِبِ الحُوتِ إذْ نادى وهُوَ مَكْظُومٌ﴾</span>{4}. (١٤/٦٥٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٣٣٠<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- <span class="qpc-hafs">﴿ولا تَكُنْ كَصاحِبِ الحُوتِ﴾</span>، قال: لا تَعجَل كما عَجِل، ولا تُغاضِب كما غاضب{5}. (١٤/٦٥٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٣٣١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثم قال للنبي ﷺ: <span class="qpc-hafs">﴿فاصْبِرْ﴾</span> على الأذى <span class="qpc-hafs">﴿لِحُكْمِ رَبِّكَ﴾</span> يعني: لقضاء ربّك والذي هو آتٍ عليك، <span class="qpc-hafs">﴿ولا تَكُنْ كَصاحِبِ الحُوتِ﴾</span> يعني: يونس بن متّى مِن أهل نَيْنَوى ﵇. يقول: لا تَضْجر كما ضجر يونس، فإنه لم يصبر. يقول: لا تَعجَل كما عَجِل يونس، ولا تُغاضِب كما غاضب يونس بن متّى، فتُعاقَب كما عُوقب يونس <span class="qpc-hafs">﴿إذْ نادى﴾</span> ربَّه في بطن الحوت، وكان نداؤه في سورة الأنبياء [٨٧]: <span class="qpc-hafs">﴿لا إلَهَ إلّا أنْتَ سُبْحانَكَ إنِّي كُنْتُ مِنَ الظّالِمِينَ﴾</span>، <span class="qpc-hafs">﴿وهُوَ مَكْظُومٌ﴾</span> يعني: مكروب في بطن الحوت، يعني: السمكة{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٣٣٢<span class="dash">-</span></span> عن <span class="name-3">عبد الملك ابن جُرَيْج</span>، في قوله: <span class="qpc-hafs">﴿ولا تَكُنْ كَصاحِبِ الحُوتِ﴾</span>، قال: لا تُغاضِب كما غاضب يونس{7}. (١٤/٦٥٧)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن أبي حاتم -كما في الإتقان ٢/٤٩-، وابن جرير ٢٣/٢٠٠. وعزاه السيوطي إلى ابن المنذر.|2:أخرجه ابن جرير ٢٣/٢٠٠. وعزاه السيوطي إلى عبد بن حميد.|3:تفسخ الربع -وهو الفصيل- تحت الحمل الثقيل: ضعف وعجز، وذلك إذا لم يطقه. تاج العروس (فسخ).|4:أخرجه الحاكم ٢/٥٨٤-٥٨٥، وأخرج ابن جرير ١٦/٣٧٦ نحوه طريق ربيعة.|5:أخرجه عبد الرزاق ٢/٣١٠-٣١١، وابن جرير ٢٣/٢٠٠، ومن طريق سعيد أيضًا. وعزاه السيوطي إلى أحمد في الزهد، وابن المنذر.|6:تفسير مقاتل بن سليمان ٤/٤١٢.|7:عزاه السيوطي إلى ابن المنذر.
  68,49,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿لَّوۡلَاۤ أَن تَدَ ٰ⁠رَكَهُۥ نِعۡمَةࣱ مِّن رَّبِّهِۦ لَنُبِذَ بِٱلۡعَرَاۤءِ وَهُوَ مَذۡمُومࣱ ۝٤٩ فَٱجۡتَبَـٰهُ رَبُّهُۥ فَجَعَلَهُۥ مِنَ ٱلصَّـٰلِحِینَ ۝٥٠﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٨٣٣٣<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- في قوله: <span class="qpc-hafs">﴿وهُوَ مَذْمُومٌ﴾</span>، قال: مُلِيم{1}. (١٤/٦٥٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٣٣٤<span class="dash">-</span></span> عن <span class="name-2">بكر [بن عبد الله المزني]</span> -من طريق المعتمر، عن أبيه- <span class="qpc-hafs">﴿وهُوَ مَذْمُومٌ﴾</span>، قال: هو مُذنِب{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٣٣٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿لَوْلا أنْ تَدارَكَهُ نِعْمَةٌ مِن رَبِّهِ لَنُبِذَ بِالعَراءِ وهُوَ مَذْمُومٌ﴾</span> ولكن تَداركه نعمة، يعني: رحمة من ربّه، فنبذناه بالعراء وهو سقيم، والعراء: البَراز، يعني: لأُلقِي بالبَراز وهو مذموم{3}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿لَّوۡلَاۤ أَن تَدَ ٰ⁠رَكَهُۥ نِعۡمَةࣱ مِّن رَّبِّهِۦ لَنُبِذَ بِٱلۡعَرَاۤءِ وَهُوَ مَذۡمُومࣱ ۝٤٩ فَٱجۡتَبَـٰهُ رَبُّهُۥ فَجَعَلَهُۥ مِنَ ٱلصَّـٰلِحِینَ ۝٥٠﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٧٨٣٣٦<span class="dash">-</span></span> عن عبد الله بن عباس، أن النبي ﷺ قال: «<b>لا ينبغي لأحد أن يقول</b>: <b>إني خير من يونس بن متّى</b> -نسبه إلى أمه-. <b>أصاب ذنبًا، ثم اجتباه ربه</b>»{4}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن أبي حاتم -كما في الإتقان ٢/٤٩-، وابن جرير ٢٣/٢٠١. وعزاه السيوطي إلى ابن المنذر.|2:أخرجه ابن جرير ٢٣/٢٠١.|3:تفسير مقاتل بن سليمان ٤/٤١٢.|4:أخرجه عبد الرزاق ٢/١٥٥-١٥٦، وأحمد في مسنده ٥/ ٣٠٣ (٣٢٥٢)، وعنده: نسبه إلى أمه. وأصله عند البخاري ٤/١٣٢، ومسلم ٧/١٠٣، والترمذي ٥/٥١ دون قوله: أصاب ذنبًا ثم اجتباه ربه.</p><p>قال محققو المسند: «إسناده صحيح، على شرط الشيخين».
  68,50,""
  68,51,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَإِن یَكَادُ ٱلَّذِینَ كَفَرُوا۟ لَیُزۡلِقُونَكَ بِأَبۡصَـٰرِهِمۡ لَمَّا سَمِعُوا۟ ٱلذِّكۡرَ وَیَقُولُونَ إِنَّهُۥ لَمَجۡنُونࣱ ۝٥١﴾</span> - قراءات</h3></p><p><div></p><p><p><span class="item-no">٧٨٣٣٧<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن مسعود</span> -من طريق إبراهيم- أنه قرأ: (لَيُزْهِقُونَكَ بِأَبَصارِهِمْ){1}. (١٤/٦٥٩)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَإِن یَكَادُ ٱلَّذِینَ كَفَرُوا۟ لَیُزۡلِقُونَكَ بِأَبۡصَـٰرِهِمۡ لَمَّا سَمِعُوا۟ ٱلذِّكۡرَ وَیَقُولُونَ إِنَّهُۥ لَمَجۡنُونࣱ ۝٥١﴾</span> - نزول الآية</h3></p><p><div></p><p><p><span class="item-no">٧٨٣٣٨<span class="dash">-</span></span> قال <span class="name-3">محمد بن السّائِب الكلبي</span>: كان رجل من العرب يَمكث لا يأكل يومين أو ثلاثة، ثم يَرفع جانب خِبائه، فتَمُرّ به النّعم، فيقول: ما رعى اليوم إبل ولا غنم أحسن مِن هذه. فما تَذهب إلا قريبًا حتى يَسقط منها طائفة وعِدّة. فسأل الكفارُ هذا الرجل أن يُصيب رسول الله ﷺ بالعين، ويَفعل به مثل ذلك، فعَصم الله تعالى نبيّه، وأَنزَل هذه الآية: <span class="qpc-hafs">﴿وإنْ يَكادُ الَّذِينَ كَفَرُوا لَيُزْلِقُونَكَ بِأَبْصارِهِمْ﴾</span>{2}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَإِن یَكَادُ ٱلَّذِینَ كَفَرُوا۟ لَیُزۡلِقُونَكَ بِأَبۡصَـٰرِهِمۡ لَمَّا سَمِعُوا۟ ٱلذِّكۡرَ وَیَقُولُونَ إِنَّهُۥ لَمَجۡنُونࣱ ۝٥١﴾</span> - تفسير الآية</h3></p><p><div></p><p><p><span class="item-no">٧٨٣٣٩<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- في قوله: <span class="qpc-hafs">﴿لَيُزْلِقُونَكَ بِأَبْصارِهِمْ﴾</span>، قال: يَنفُذُونك بأبصارهم{3}. (١٤/٦٥٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٣٤٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطاء- أنه كان يقرأ: <span class="qpc-hafs">﴿وإنْ يَكادُ الَّذِينَ كَفَرُوا لَيُزْلِقُونَكَ بِأَبْصارِهِمْ﴾</span>. قال: يقول: يَنفُذُونك بأبصارهم مِن شِدّة النظر إليك. قال ابن عباس: فكيف يقولون: زَلَق السهم أو زَهَق السهم{4}. (١٤/٦٥٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٣٤١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطية- <span class="qpc-hafs">﴿وإنْ يَكادُ الَّذِينَ كَفَرُوا لَيُزْلِقُونَكَ بِأَبْصارِهِمْ﴾</span>: ليُزْهِقُونك بأبصارهم{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٣٤٢<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- <span class="qpc-hafs">﴿لَيُزْلِقُونَكَ بِأَبْصارِهِمْ﴾</span>، قال: ليَنفُذُونك بأبصارهم{6}. (١٤/٦٥٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٣٤٣<span class="dash">-</span></span> عن <span class="name-2">الضَّحّاك بن مُزاحِم</span> -من طريق عبيد- في قوله: <span class="qpc-hafs">﴿وإنْ يَكادُ الَّذِينَ كَفَرُوا لَيُزْلِقُونَكَ بِأَبْصارِهِمْ﴾</span>، يقول: يَنفُذُونك بأبصارهم؛ مِن العداوة والبغضاء{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٣٤٤<span class="dash">-</span></span> قال <span class="name-2">الحسن البصري</span>: <span class="qpc-hafs">﴿لَيُزْلِقُونَكَ بِأَبْصارِهِمْ﴾</span> ليَقْتلونك{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٣٤٥<span class="dash">-</span></span> قال <span class="name-2">عطية العَوفيّ</span>: <span class="qpc-hafs">﴿لَيُزْلِقُونَكَ بِأَبْصارِهِمْ﴾</span> يرمونك{9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٣٤٦<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿لَيُزْلِقُونَكَ بِأَبْصارِهِمْ﴾</span>، قال: ليَنفُذُونك بأبصارهم؛ معاداةً لكتاب الله، ولِذِكْر الله{6}. (١٤/٦٥٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٣٤٧<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- في قوله تعالى: <span class="qpc-hafs">﴿لَيُزْلِقُونَكَ بِأَبْصارِهِمْ﴾</span>، قال: لَيُزْهِقُونك{11}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٣٤٨<span class="dash">-</span></span> قال <span class="name-2">إسماعيل السُّدِّيّ</span>: <span class="qpc-hafs">﴿لَيُزْلِقُونَكَ بِأَبْصارِهِمْ﴾</span> يُصيبونك بعيونهم{12}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٣٤٩<span class="dash">-</span></span> عن <span class="name-2">عطاء الخُراسانيّ</span> -من طريق يونس بن يزيد- في قول الله: <span class="qpc-hafs">﴿ليزلقونك بأبصارهم﴾</span>، قال: لَيُزِيلُونك بأبصارهم{13}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٣٥٠<span class="dash">-</span></span> قال <span class="name-2">زيد بن أسلم</span>: <span class="qpc-hafs">﴿لَيُزْلِقُونَكَ بِأَبْصارِهِمْ﴾</span> لَيمَسّوك{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٣٥١<span class="dash">-</span></span> عن <span class="name-3">محمد بن السّائِب الكلبي</span>-من طريق معمر- <span class="qpc-hafs">﴿لَيُزْلِقُونَكَ بِأَبْصارِهِمْ﴾</span>: ليَصْرعُونك{15}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٣٥٢<span class="dash">-</span></span> عن <span class="name-3">محمد بن السّائِب الكلبي</span> -من طريق حيّان- <span class="qpc-hafs">﴿لَيُزْلِقُونَكَ بِأَبْصارِهِمْ﴾</span>: يَصْرفُونك عمّا أنت عليه من تبليغ الرسالة{9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٣٥٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وإنْ يَكادُ﴾</span> يقول: قد كاد <span class="qpc-hafs">﴿الَّذِينَ كَفَرُوا﴾</span> يعني: المُستهزئين من قريش <span class="qpc-hafs">﴿لَيُزْلِقُونَكَ بِأَبْصارِهِمْ﴾</span> يعني: يُبعِدونك <span class="qpc-hafs">﴿لَمّا سَمِعُوا الذِّكْرَ﴾</span> يقول: حين سمعوا القرآن كراهيةً له، <span class="qpc-hafs">﴿ويَقُولُونَ إنَّهُ﴾</span> إنّ محمدًا <span class="qpc-hafs">﴿لَمَجْنُونٌ﴾</span>{17}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَإِن یَكَادُ ٱلَّذِینَ كَفَرُوا۟ لَیُزۡلِقُونَكَ بِأَبۡصَـٰرِهِمۡ لَمَّا سَمِعُوا۟ ٱلذِّكۡرَ وَیَقُولُونَ إِنَّهُۥ لَمَجۡنُونࣱ ۝٥١﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٧٨٣٥٤<span class="dash">-</span></span> عن عبد الله بن عباس، أنّ رسول الله ﷺ قال: «<b>العين حق، ولو كان شيء سابق القدَر سبقته العين، وإذا استُغسلتم فاغسلوا</b>»{18}. (١٤/٦٥٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٣٥٥<span class="dash">-</span></span> عن جابر، أنّ النبي ﷺ قال: «<b>العين تُدخِلُ الرجلَ القبرَ، والجملَ القِدْرَ</b>»{19}. (١٤/٦٥٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٣٥٦<span class="dash">-</span></span> عن جابر، أنّ النبي ﷺ قال: «<b>أكثر مَن يموت مِن أمتي بعد قضاء الله وقدَره بالعين</b>»{20}. (١٤/٦٥٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٣٥٧<span class="dash">-</span></span> عن أسماء بنت عُمَيْس أنها قالتْ: يا رسول الله، إنّ بني جعفر تُصيبهم العين، أفأَسترقي لهم؟ قال: «<b>نعم، فلو كان شيءٌ يَسبق القضاءَ لَسَبَقتْه العين</b>»{21}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٣٥٨<span class="dash">-</span></span> قال <span class="name-2">الحسن البصري</span>: دواء إصابة العين أن يَقرأ الإنسانُ هذه الآية{22}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه أبو عبيد في فضائله (١٧٨)، وابن جرير ٢٣/٢٠٣.</p><p>وهي قراءة شاذة، تروى أيضًا عن ابن عباس. انظر: مختصر ابن خالويه ص١٦١.|2:تفسير الثعلبي ١٠/٢٣، وأسباب النزول للواحدي ص٦٩٤، وتفسير البغوي ٨/٢٠٢.|3:أخرجه ابن أبي حاتم -كما في الإتقان ٢/٤٩-، وابن جرير ٢٣/٢٠٣. وعزاه السيوطي إلى ابن المنذر، وابن مردويه.|4:عزاه السيوطي إلى سعيد بن منصور، وعبد بن حميد، وابن المنذر، وابن مردويه.|5:أخرجه ابن جرير ٢٣/٢٠٣.|6:أخرجه ابن جرير ٢٣/٢٠٣. وعزاه السيوطي إلى عبد بن حميد.|7:أخرجه ابن جرير ٢٣/٢٠٣-٢٠٤.|8:تفسير الثعلبي ١٠/٢٤.|9:تفسير الثعلبي ١٠/٢٣.|10:أخرجه ابن جرير ٢٣/٢٠٣. وعزاه السيوطي إلى عبد بن حميد.|11:أخرجه عبد الرزاق ٢/٣١٣، وابن جرير ٢٣/٢٠٣.|12:تفسير الثعلبي ١٠/٢٤، وتفسير البغوي ٨/٢٠٢.|13:أخرجه أبو جعفر الرملي في جزئه (تفسير عطاء) ص١٢٢.|14:تفسير الثعلبي ١٠/٢٤.|15:أخرجه عبد الرزاق ٢/٣١٣، وابن جرير ٢٣/٢٠٣، والثعلبي ١٠/٢٣.|16:تفسير الثعلبي ١٠/٢٣.|17:تفسير مقاتل بن سليمان ٤/٤١٢.|18:أخرجه مسلم ٤/١٧١٩ (٢١٨٨).|19:أخرجه ابن عدي في الكامل ٦/٣١٦، ٨/١٤٨، وأبو نعيم في الحلية ٧/٩٠-٩١، من طريق شعيب بن أيوب، عن معاوية بن هشام، عن سفيان الثوري، عن محمد بن المُنكَدر، عن جابر به.</p><p>قال أبو نعيم: «غريب من حديث الثوري، تفرد به معاوية». وأورده الألباني في الصحيحة ٣/٢٥٠-٢٥١ (١٢٤٩).|20:أخرجه ابن عدي في الكامل ٥/١٩١، والبزار -كما في كشف الأستار ٣/٤٠٣ (٣٠٥٢)-، من طريق طالب بن حبيب الأنصاري، عن عبد الرحمن بن جابر الأنصاري، عن أبيه به.</p><p>وقال العراقي في طرح التثريب ٨/١٩٨ عن رواية البزار: «ورجاله ثقات». وقال الهيثمي في المجمع ٥/١٠٦ (٨٤٢٣): «رجاله رجال الصحيح، خلا الطالب بن حبيب بن عمرو، وهو ثقة». وقال ابن حجر في الفتح ١٠/٢٠٠، ٢٠٤: «سنده حسن». وتابعه السخاوي في المقاصد الحسنة ص٤٧٠، والزرقاني في شرحه على الموطأ ٤/٥١١، والعجلوني في كشف الخفاء ٢/٨٩، والشوكاني في نيل الأوطار ٨/٢٤٨، والألباني في الصحيحة ٢/٣٧٢-٣٧٣ (٧٤٧).|21:أخرجه أحمد ٤٥/٤٦٢ (٢٧٤٧٠)، والترمذي ٤/١٤٦-١٤٧ (٢١٨٦، ٢١٨٧)، وابن ماجه ٤/٥٤٣ (٣٥١٠)، والبغوي ٨/٢٠٣ واللفظ له.</p><p>قال الترمذي: «وهذا حديث حسن صحيح». وقال ابن عدي في الكامل ٥/٤٣١: «وهذه الأحاديث غير محفوظة». وأورده الدارقطني في العلل ١٥/٣٠٤ (٤٠٥١). وقال ابن القيسراني في ذخيرة الحفاظ ٣/١٦٩٣ (٣٨١٠): «رواه عبد الله بن شبيب أبو سعيد، عن يحيى بن إبراهيم، عن أسامة بن حفص، عن عبيد الله بن عمر، عن أيوب البصري رجل من أهل الفضل، عن عمرو بن دينار، عن عروة بن عامر، عن عبيد بن رفاعة، عن أسماء بنت عُمَيْس. وهذا غير محفوظ، وإسناده كما ترى، وعبد الله متروك الحديث». وقال المناوي في التيسير ٢/٣١٠: «إسناد صحيح». وقال في فيض القدير ٥/٣٢٦ (٧٤٧٤): «رمز المصنف-السيوطي- لصحته». وقال الألباني في الصحيحة ٣/٢٥٢ (١٢٥٢): «ورجاله ثقات مشهورون من رجال الشيخين، غير عبيد بن رفاعة، وهو ثقة».|22:تفسير الثعلبي ١٠/٢٤، وتفسير البغوي ٨/٢٠٣.
  68,52,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَمَا هُوَ إِلَّا ذِكۡرࣱ لِّلۡعَـٰلَمِینَ ۝٥٢﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٨٣٥٩<span class="dash">-</span></span> قال <span class="name-1">عبد الله بن عباس</span>: <span class="qpc-hafs">﴿إلا ذِكْرٌ لِلْعالَمِينَ﴾</span> موعظة للمؤمنين{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٣٦٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وما هُوَ﴾</span> يعني: إنْ هو <span class="qpc-hafs">﴿إلّا ذِكْرٌ لِلْعالَمِينَ﴾</span> يعني: ما القرآن إلا تَذْكِرة للعالمين{2}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير البغوي ٨/٢٠٢.|2:تفسير مقاتل بن سليمان ٤/٤١٢.
  69,1,"<div class=ar lang=ar><p><h3>مقدمة السورة</h3></p><p><div></p><p><p><span class="item-no">٧٨٣٦١<span class="dash">-</span></span> عن عمر بن الخطاب، قال: خَرجتُ أتعرّض لرسول الله ﷺ قبل أنْ أُسلِم، فوجَدتُه قد سبقني إلى المسجد، فقمتُ خَلفه، فاستفتحَ سورة الحاقة، فجَعلتُ أعجب من تأليف القرآن، فقلتُ: هذا -واللهِ- شاعر كما قالتْ قريش. فقرأ: <span class="qpc-hafs">﴿إنَّهُ لَقَوْلُ رَسُولٍ كَرِيمٍ وما هُوَ بِقَوْلِ شاعِرٍ قَلِيلًا ما تُؤْمِنُونَ﴾</span> [الحاقة:٤٠-٤١]. قلتُ: كاهن. قال: <span class="qpc-hafs">﴿ولا بِقَوْلِ كاهِنٍ قَلِيلًا ما تَذَكَّرُونَ تَنْزِيلٌ﴾</span> إلى آخر السورة [الحاقة:٤٢-٥٢]، فوقع الإسلام في قلبي كلّ موقع{1}. (١٤/٦٦٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٣٦٢<span class="dash">-</span></span> عن عبد الله بن عباس -من طريق مجاهد- قال: نَزَلَتْ سورةُ الحاقة بمكة{2}. (١٤/٦٦٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٣٦٣<span class="dash">-</span></span> عن عبد الله بن الزبير، مثله{3}. (١٤/٦٦٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٣٦٤<span class="dash">-</span></span> عن عبد الله بن عباس -من طريق عطاء الخُراسانيّ-: مكّيّة، ونزلت بعد <span class="qpc-hafs">﴿تبارك﴾</span> المُلك{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٣٦٥<span class="dash">-</span></span> عن عكرمة مولى ابن عباس= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٣٦٦<span class="dash">-</span></span> والحسن البصري -من طريق يزيد النحوي-: مكّيّة{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٣٦٧<span class="dash">-</span></span> عن قتادة بن دعامة -من طرق-: مكّيّة{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٣٦٨<span class="dash">-</span></span> عن محمد بن مسلم الزُّهريّ: مكّيّة، ونزلت بعد سورة المُلك{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٣٦٩<span class="dash">-</span></span> عن علي بن أبي طلحة: مكّيّة{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٣٧٠<span class="dash">-</span></span> قال مقاتل بن سليمان: سورة الحاقة مكّيّة، عددها اثنتان وخمسون آية كوفي{9}<span class=comment-ref>٦٧٥٢</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٧٥٢</span> <span class="comment-type-4">ذكر</span> <u>ابنُ عطية</u> (٨/٣٨٤) أنّ هذه السورة مكية <span class="mustanad">بإجماع</span>.</div></p></div>",footnotes:1:أخرجه أحمد ١/٢٦٢ (١٠٧).</p><p>وقال محقّقوه: «إسناده ضعيف».|2:أخرجه أبو جعفر النحاس في الناسخ والمنسوخ ص٧٤٩ من طريق أبي عمرو بن العلاء عن مجاهد، والبيهقي في دلائل النبوة ٧/١٤٢-١٤٤ من طريق خُصَيف عن مجاهد. وعزاه السيوطي إلى ابن مردويه.|3:عزاه السيوطي إلى ابن مردويه.|4:أخرجه ابن الضُّريس في فضائل القرآن ١/٣٣-٣٥.|5:أخرجه البيهقي في دلائل النبوة ٧/١٤٢-١٤٣.|6:أخرجه الحارث المحاسبي في فهم القرآن ص٣٩٥-٣٩٦ من طريق سعيد، وأبو بكر بن الأنباري -كما في الإتقان ١/٥٧- من طريق همام.|7:تنزيل القرآن ص٣٧-٤٢.|8:أخرجه أبو عبيد في فضائله (ت: الخياطي) ٢/٢٠٠.|9:تفسير مقاتل بن سليمان ٤/٤١٩.
  69,2,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿ٱلۡحَاۤقَّةُ ۝١ مَا ٱلۡحَاۤقَّةُ ۝٢ وَمَاۤ أَدۡرَىٰكَ مَا ٱلۡحَاۤقَّةُ ۝٣﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٨٣٧١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- في قوله: <span class="qpc-hafs">﴿الحاقَّةُ﴾</span>، قال: من أسماء يوم القيامة{1}. (١٤/٦٦٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٣٧٢<span class="dash">-</span></span> عن <span class="name-2">الضَّحّاك بن مُزاحِم</span> -من طريق عبيد- قال في قوله: <span class="qpc-hafs">﴿الحاقَّةُ﴾</span>: يعني: القيامة{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٣٧٣<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span> -من طريق جابر- قال: <span class="qpc-hafs">﴿الحاقَّةُ﴾</span> القيامة{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٣٧٤<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- في قوله: <span class="qpc-hafs">﴿الحاقَّةُ﴾</span> قال: يعني: الساعة، أحقّتْ لكلِّ عاملٍ عمَلَه، <span class="qpc-hafs">﴿وما أدْراكَ ما الحاقَّةُ﴾</span> قال: تعظيمًا ليوم القيامة، كما تَسمعون{4}. (١٤/٦٦١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٣٧٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن</span> <span class="name-3">سليمان</span>: قوله تعالى: <span class="qpc-hafs">﴿الحاقَّةُ ما الحاقَّةُ﴾</span> ثم بيّن ما الحاقة؛ يعني: الساعة التي فيها حقائق الأعمال، يقول: يحقّ للمؤمنين عملهم، ويحقّ للكافرين عملهم. ثم قال للنبي ﷺ: <span class="qpc-hafs">﴿وما أدْراكَ ما الحاقَّةُ﴾</span> تعظيمًا لها لشِدّتها{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٣٧٦<span class="dash">-</span></span> عن <span class="name-3">عبد الملك ابن جُرَيْج</span>، في قوله: <span class="qpc-hafs">﴿الحاقَّةُ﴾</span>، قال: حقَّقتْ لكل عامل عمَله؛ للمؤمن إيمانه، وللمنافق نفاقه{6}. (١٤/٦٦١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٣٧٧<span class="dash">-</span></span> عن <span class="name-3">سفيان</span> -من طريق مهران- قال: ما في القرآن: <span class="qpc-hafs">﴿وما يُدْرِيكَ﴾</span> [الأحزاب:٦٣، الشورى:١٧، عبس:٣] فلم يُخبِره، وما كان: <span class="qpc-hafs">﴿وما أدْراكَ﴾</span> فقد أخبَره{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٣٧٨<span class="dash">-</span></span> قال <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿الحاقَّةُ ما الحاقَّةُ﴾</span>، و<span class="qpc-hafs">﴿القارِعَةُ ما القارِعَةُ﴾</span> [القارعة:١-٢]، و<span class="qpc-hafs">﴿الواقِعَةُ﴾</span> [الواقعة:١]، و<span class="qpc-hafs">﴿الطّامَّةُ﴾</span> [النازعات:٣٤]، و<span class="qpc-hafs">﴿الصّاخَّةُ﴾</span> [عبس:٣٣]، قال: هذا كلّه يوم القيامة؛ الساعة. وقرأ قول الله: <span class="qpc-hafs">﴿لَيْسَ لِوَقْعَتِها كاذِبَةٌ خافِضَةٌ رافِعَةٌ﴾</span> [الواقعة:٢-٣]، والخافضة مِن هؤلاء أيضًا خَفَضَتْ أهل النار، ولا نَعلَم أحدًا أخْفَض من أهل النار، ولا أذلّ، ولا أخْزى، ورَفعَتْ أهل الجنة، ولا نَعلَم أحدًا أشرف من أهل الجنة، ولا أكرم{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٣٧٩<span class="dash">-</span></span> قال <span class="name-3">يحيى بن</span> <span class="name-3">سلّام</span>: وبلغني أنّ كلّ شيء في القرآن <span class="qpc-hafs">﴿وما أدْراكَ﴾</span> فقد أدراه إياه، وكلّ شيء <span class="qpc-hafs">﴿وما يُدْرِيكَ﴾</span> [الأحزاب:٦٣، الشورى:١٧، عبس:٣] فهو ما لم يُعْلِمه إياه بعد{9}<span class=comment-ref>٦٧٥٣</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٧٥٣</span> <span class="comment-type-4">ذكر</span> <u>ابن عطية</u> (٨/٣٨٤) أنّ بعض المفسرين قال بأن «الحاقة» مصدر كالعافية والعاقبة، و<span class="comment-type-4">علَّق</span> عليه بقوله: «كأنه قال: ذات الحق».</div></p></div>",footnotes:1:أخرجه ابن جرير ٢٣/٢٠٥. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.|2:أخرجه ابن جرير ٢٣/٢٠٦.|3:أخرجه آدم بن أبي إياس -كما في تفسير مجاهد ص٦٧١-، وابن جرير ٢٣/٢٠٥.|4:أخرجه عبد الرزاق ٢/٣١٢ بنحوه، وابن جرير ٢٣/٢٠٦-٢٠٧ بنحوه، ومن طريق سعيد أيضًا. وعلقه الحاكم ٢/٥٠٠. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.|5:تفسير مقاتل بن سليمان ٤/٤٢١.|6:عزاه السيوطي إلى ابن المنذر.|7:أخرجه ابن جرير ٢٣/٢٠٧.|8:أخرجه ابن جرير ٢٣/٢٠٦.|9:تفسير ابن أبي زمنين ٥/٢٦.
  69,3,""
  69,4,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿كَذَّبَتۡ ثَمُودُ وَعَادُۢ بِٱلۡقَارِعَةِ ۝٤﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٨٣٨٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطية العَوفيّ- قوله: <span class="qpc-hafs">﴿كَذَّبَتْ ثَمُودُ وعادٌ بِالقارِعَةِ﴾</span>، قال: القارعة: يوم القيامة{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٣٨١<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿كَذَّبَتْ ثَمُودُ وعادٌ بِالقارِعَةِ﴾</span>، قال: بالساعة{2}. (١٤/٦٦١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٣٨٢<span class="dash">-</span></span> قال <span class="name-3">محمد بن السّائِب الكلبي</span>: <span class="qpc-hafs">﴿كَذَّبَتْ ثَمُودُ وعادٌ بِالقارِعَةِ﴾</span>، القارعة: اسم من أسماء القيامة{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٣٨٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثم قال: هي القارعة، والساعة التي <span class="qpc-hafs">﴿كَذَّبَتْ﴾</span> بها <span class="qpc-hafs">﴿ثَمُودُ وعادٌ بِالقارِعَةِ﴾</span>، نظيرها في سورة القارعة، وإنما سُمّيت القارعة لأن الله ﷿ يَقرع أعداءه بالعذاب{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٣٨٤<span class="dash">-</span></span> عن <span class="name-3">عبد الملك ابن جُرَيْج</span>، في قوله: <span class="qpc-hafs">﴿بِالقارِعَةِ﴾</span>، قال: يوم القيامة{5}. (١٤/٦٦١)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ٢٣/٢٠٧.|2:أخرجه ابن جرير ٢٣/٢٠٧. وعلقه الحاكم ٢/٥٠٠. وعزاه السيوطي إلى عبد الرزاق، وعبد بن حميد، وابن المنذر.|3:ذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٥/٢٦-.|4:تفسير مقاتل بن سليمان ٤/٤٢١.|5:عزاه السيوطي إلى ابن المنذر.
  69,5,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿فَأَمَّا ثَمُودُ فَأُهۡلِكُوا۟ بِٱلطَّاغِیَةِ ۝٥﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٨٣٨٥<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿فَأُهْلِكُوا بِالطّاغِيَةِ﴾</span>، قال: بالذّنوب.= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٣٨٦<span class="dash">-</span></span> وكان <span class="name-1">عبد الله بن عباس</span> يقول: الصّيحة{1}. (١٤/٦٦١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٣٨٧<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- في قوله: <span class="qpc-hafs">﴿فَأُهْلِكُوا بِالطّاغِيَةِ﴾</span>، قال: أرسَل الله عليهم صيحة واحدة، فأهمدتهم، فأُهلكوا{2}. (١٤/٦٦١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٣٨٨<span class="dash">-</span></span> قال <span class="name-3">محمد بن السّائِب الكلبي</span>: <span class="qpc-hafs">﴿فَأَمّا ثَمُودُ فَأُهْلِكُوا بِالطّاغِيَةِ﴾</span>، الطّاغية: الصّاعقة التي أُهلِكوا بها{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٣٨٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثم أخبر الله تعالى عن عاد وثمود، فقال: <span class="qpc-hafs">﴿فَأَمّا ثَمُودُ فَأُهْلِكُوا بِالطّاغِيَةِ﴾</span> يقول: عُذِّبوا بطغيانهم، والطّغيان حمَلهم على تكذيب صالح النبي -صلى الله عليه-{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٣٩٠<span class="dash">-</span></span> قال <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿فَأَمّا ثَمُودُ فَأُهْلِكُوا بِالطّاغِيَةِ﴾</span>، فقرأ قول الله: <span class="qpc-hafs">﴿كَذَّبَتْ ثَمُودُ بِطَغْواها﴾</span> [الشمس:١١]، وقال: هذه الطّاغية طغيانهم وكفْرهم بآيات الله؛ الطّاغية طغيانهم الذي طَغَوا في معاصي الله وخلاف كتاب الله{5}<span class=comment-ref>٦٧٥٤</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٧٥٤</span> اختُلف في المراد بالطاغية على أقوال: <b>الأول</b>: أنها طغيانهم وكفرهم بالله. <b>الثاني</b>: الصّيحة الطّاغية. <b>الثالث</b>: أنها الفئة الطاغية. <span class="comment-type-4">ذكره</span> <u>ابن عطية</u> (٨/٣٨٥).</p><p>و<span class="comment-type-3">رجَّح</span> <u>ابنُ جرير</u> (٢٣/٢٠٩) -<span class="mustanad">مستندًا إلى السياق، ودلالة العقل</span>- القول الثاني الذي قاله ابن عباس، وقتادة، والكلبي، فقال: «لأنّ الله إنما أخبر عن ثمود بالمعنى الذي أهلكها به، كما أخبر عن عادٍ بالذي أهلكها به، فقال: <span class="qpc-hafs">﴿وأما عاد فأهلكوا بريح صرصر عاتية﴾</span>، ولو كان الخبر عن ثمود بالسبب الذي أهلكها مِن أجله كان الخبر أيضًا عن عاد كذلك؛ إذ كان ذلك في سياق واحد، وفي إتباعه ذلك بخبره عن عاد بأنّ هلاكها كان بالريح- الدليل الواضح على أنّ إخباره عن ثمود إنما هو ما بَيّنتُ».</p><p>و<span class="comment-type-3">رجَّحه</span> <u>ابنُ عطية</u> (٨/٣٨٥)، و<span class="comment-type-2">انتقد</span> ما عداه <span class="mustanad">مستندًا إلى السياق</span>، فقال: «وأولى الأقوال وأصوبها الأول؛ لأنه منتسب لما ذكر في عاد؛ إذ ذكر فيه الوجه الذي وقع به الهلاك، وعلى سائر الأقوال لا يتناسب الأمران؛ لأنّ طغيان ثمود سبب، والريح لا يناسب ذلك؛ لأنها ليست بسبب الإهلاك، بل آلته كما في الصيحة».</p><p>و<span class="comment-type-4">ذكر</span> <u>ابنُ عطية</u> أنّ الطّاغية على قول ابن زيد مصدر كالعاقبة. و<span class="comment-type-4">علَّق</span> عليه بقوله: «فكأنه تعالى قال: بطغيانهم». و<span class="comment-type-4">ذكر</span> أنّ <span class="mustanad">قوله تعالى</span>: <span class="qpc-hafs">﴿كذبت ثمود بطغواها﴾</span> [الشمس:١٠] يقوّي هذا القول.</p><p>و<span class="comment-type-4">ذكر</span> <u>ابنُ كثير</u> (١٤/١١١) أنّ السُّدِّيّ قال بأن الطاغية: «عاقر الناقة».</div></p></div>",footnotes:1:أخرجه ابن جرير ٢٣/٢٠٨. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.|2:أخرجه عبد الرزاق ٢/٣١٢، وابن جرير ٢٣/٢٠٩، وبنحوه من طريق سعيد. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.|3:ذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٥/٢٦-٢٧-.|4:تفسير مقاتل بن سليمان ٤/٤٢١.|5:أخرجه ابن جرير ٢٣/٢٠٨.
  69,6,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَأَمَّا عَادࣱ فَأُهۡلِكُوا۟ بِرِیحࣲ صَرۡصَرٍ عَاتِیَةࣲ ۝٦﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٨٣٩١<span class="dash">-</span></span> عن عبد الله بن عباس، عن النبي ﷺ، قال: «<b>نُصِرْتُ بالصّبا، وأُهلِكَتْ عادٌ بالدَّبُورِ</b>». قال: «<b>ما أُمِر الخُزّان أن يُرسِلوا على عادٍ إلا مثل موضع الخاتم مِن الريح، فعَتَتْ على الخُزّان، فخَرجتْ من نواحي الأبواب، فذلك قوله: <span class="qpc-hafs">﴿بِرِيحٍ صَرْصَرٍ عاتِيَةٍ﴾</span></b>». قال: «<b>عُتوّها: عَتَتْ على الخُزّان، فبدأتْ بأهل البادية منهم، فحَملتْهم بمواشيهم وبيوتهم، فأَقبلتْ بهم إلى الحاضرة، فلمّا رَأوها قالوا: هذا عارضٌ مُمطِرنا. فلمّا دنَت الريح وأَظلّتهم استبقَ الناسُ والمواشي فيها، فأَلقَت الباديةَ على أهل الحاضرة، فقَصفتْهم، فهَلكوا جميعًا</b>»{1}. (١٤/٦٦٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٣٩٢<span class="dash">-</span></span> عن عبد الله بن عباس، قال: قال رسول الله ﷺ: «<b>ما أنزل الله من السماء كفًّا من ماء إلا بمكيال، ولا كفًّا من ريح إلا بمكيال، إلا يوم نوح، فإنّ الماء طغى على الخُزّان، فلم يكن لهم عليه سلطان، قال الله: <span class="qpc-hafs">﴿إنّا لَمّا طَغى الماءُ حَمَلْناكُمْ فِي الجارِيَةِ﴾</span>. ويوم عاد، فإنّ الريح عَتَتْ على الخُزّان، قال الله: <span class="qpc-hafs">﴿بِرِيحٍ صَرْصَرٍ عاتِيَةٍ﴾</span></b>»{2}. (١٤/٦٦٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٣٩٣<span class="dash">-</span></span> عن <span class="name-1">علي بن أبي طالب</span> -من طريق أبي سنان، عن غير واحد- قال: لم تَنزِل قَطرةٌ مِن ماء إلا بمكيالٍ على يدي مَلك، إلا يوم نوح، فإنه أُذِن للماء دون الخُزّان، فطغى الماء على الخُزّان، فخرج، فذلك قوله: <span class="qpc-hafs">﴿إنّا لَمّا طَغى الماءُ﴾</span>، ولم ينزل شيءٌ من الريح إلا بكيلٍ على يدي مَلك، إلا يوم عاد، فإنه أُذِن لها دون الخُزّان، فخَرجتْ، فذلك قول الله: <span class="qpc-hafs">﴿بِرِيحٍ صَرْصَرٍ عاتِيَةٍ﴾</span> عَتَتْ على الخُزّان{3}. (١٤/٦٦٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٣٩٤<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق شَهْر بن حَوْشَب- قال: ما أرسَل الله شيئًا من ريح إلا بمكيال، ولا قَطرة من مطر إلا بمكيال، إلا يوم نوح ويوم عاد، فأمّا يوم نوح فإنّ الماء طغى على خُزّانه، فلم يكن لهم عليه سبيل. ثم قرأ: <span class="qpc-hafs">﴿إنّا لَمّا طَغى الماءُ﴾</span>. وأمّا يوم عاد فإنّ الريح عَتَتْ على خُزّانها، فلم يكن لهم عليها سبيل. ثم قرأ: <span class="qpc-hafs">﴿بِرِيحٍ صَرْصَرٍ عاتِيَةٍ﴾</span>{4}. (١٤/٦٦١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٣٩٥<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطية- قوله: <span class="qpc-hafs">﴿وأَمّا عادٌ فَأُهْلِكُوا بِرِيحٍ صَرْصَرٍ عاتِيَةٍ﴾</span>، يقول: بريح مُهلِكة باردة، عَتَتْ عليهم بغير رحمة ولا بركة، دائمة لا تَفْتُر{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٣٩٦<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، في قوله: <span class="qpc-hafs">﴿بِرِيحٍ صَرْصَرٍ عاتِيَةٍ﴾</span>، قال: الغالبة{6}. (١٤/٦٦٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٣٩٧<span class="dash">-</span></span> عن <span class="name-2">قَبِيصة بن ذُؤَيْب</span> -من طريق ابن شهاب- قال: ما يَخرج مِن الريح شيءٌ إلا عليها خُزّان يعلمون قَدْرها، وعددها، ووزنها، وكَيْلها، حتى كانت الريحُ التي أُرسِلَتْ على عاد، فاندَفقَ منها شيءٌ لا يعلمون قَدْره ولا وزْنه ولا كَيْله؛ غضبًا لله، ولذلك سُمّيتْ عاتية، والماء كذلك حين كان أمْر نوح؛ فلذلك سُمّي طاغية{7}. (١٤/٦٦٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٣٩٨<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿عاتِيَةٍ﴾</span>، قال: شديدة{8}. (١٤/٦٦٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٣٩٩<span class="dash">-</span></span> عن <span class="name-2">الضَّحّاك بن مُزاحِم</span> -من طريق عبيد- في قوله: <span class="qpc-hafs">﴿بِرِيحٍ صَرْصَرٍ﴾</span> يعني: باردة، <span class="qpc-hafs">﴿عاتِيَةٍ﴾</span> عَتَتْ عليهم بلا رحمة ولا بركة{9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٤٠٠<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span>، قال: الصَّرْصَر: الباردة، <span class="qpc-hafs">﴿عاتِيَةٍ﴾</span> قال: حيثُ عَتَتْ على خُزّانها{10}. (١٤/٦٦٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٤٠١<span class="dash">-</span></span> عن <span class="name-2">عامر الشعبي</span> -من طريق زكريا- قال: كانت الريح تَمُرّ بالمرأة في هَوْدجها فتَحملها، وبالإبل والغنم لهم فتَحملها، وبالقوم منهم فتَحملهم، فتَطير بهم بين السماء والأرض، فتَضرب بعضهم ببعض. وتَمُرّ بالعادي الواحد بين القوم، فتَحمله من بينهم، والناس يَنظرون، لا تُصيب إلا عاديًّا. يقول الله تعالى: <span class="qpc-hafs">﴿وأَمّا عادٌ فَأُهْلِكُوا بِرِيحٍ صَرْصَرٍ عاتِيَةٍ﴾</span> يعني: باردة. في يوم نحس: يعني: مشؤوم{11}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٤٠٢<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿بِرِيحٍ صَرْصَرٍ عاتِيَةٍ﴾</span>، قال: عَتَتْ عليهم حتى نَقَّبتْ أفئدتَهم{12}. (١٤/٦٦١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٤٠٣<span class="dash">-</span></span> عن <span class="name-2">عطاء الخُراسانيّ</span> -من طريق يونس بن يزيد- في قوله تعالى: <span class="qpc-hafs">﴿بريح صرصر﴾</span>، قال: صَرْصرٌ باردة شديدة{13}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٤٠٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وأَمّا عادٌ فَأُهْلِكُوا﴾</span> يعني: عُذِّبوا <span class="qpc-hafs">﴿بِرِيحٍ صَرْصَرٍ﴾</span> يعني: باردة <span class="qpc-hafs">﴿عاتِيَةٍ﴾</span> شديدة، عَتَتْ على خُزّانها بغير رأفة ولا رحمة{14}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٤٠٥<span class="dash">-</span></span> قال <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿بِرِيحٍ صَرْصَرٍ عاتِيَةٍ﴾</span>، قال: الصَّرْصَر: الشديدة. والعاتية: القاهرة، التي عَتَتْ عليهم فقَهرتْهم{9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٤٠٦<span class="dash">-</span></span> عن <span class="name-3">سفيان بن عُيينة</span>: <span class="qpc-hafs">﴿عاتِيَةٍ﴾</span> عَتَتْ عن الخُزّان{16}<span class=comment-ref>٦٧٥٥</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٧٥٥</span> <span class="comment-type-4">قال</span> <u>ابنُ عطية</u> (٨/٣٨٥): «والصرصر: <b>يحتمل</b> أنْ يكون من الصِّرّ، أي: البرد. وهو قول قتادة. <b>ويحتمل</b> أن يكون مِن: صرّ الشيء؛ إذا صوّت». وذكر أنّ قومًا قالوا: صوت الريح صَرْصَر. و<span class="comment-type-4">علَّق</span> عليه بقوله: «كأنه يحكي هذين الحرفين».</div></p></div>",footnotes:1:أخرجه أبو الشيخ في العظمة ٤/١٣٥٠-١٣٥١، وأخرج الجملة الأولى منه البخاري ٢/٣٣ (١٠٣٥)، ٤/١٠٩ (٣٢٠٥)، ٤/١٣٧ (٣٣٤٣)، ٥/١٠٩ (٤١٠٥)، ومسلم ٢/٦١٧ (٩٠٠).|2:أخرجه أبو الشيخ في العظمة ٤/١٢٥٣-١٢٥٤، ٤/١٣٠٦-١٣٠٧، وأبو نعيم في الحلية ٦/٦٥، وابن عساكر في تاريخ دمشق ٦٢/٢٦١، وابن مردويه -كما في تخريج أحاديث الكشاف ٤/٨٣-٨٤-، من طريق المعافى الحراني، عن موسى بن أعين، عن الثوري، عن موسى بن المسيب، عن شهر بن حوشب، عن ابن عباس به.</p><p>قال أبو نعيم: «رواه الفريابي والناس موقوفًا على سفيان، وتفرَّد به، يرفعه عن موسى بن أعين، عن سفيان».|3:أخرجه ابن جرير ٢٣/٢١٠-٢١١.|4:أخرجه ابن جرير ٢٣/٢١٠. وعزاه السيوطي إلى الفريابي، وعبد بن حميد.|5:أخرجه ابن جرير ٢٣/٢١٠.|6:عزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.|7:عزاه السيوطي إلى ابن عساكر.|8:أخرجه أبو الشيخ في العظمة (٨١٣)، وابن جرير ٢٣/٢١١.|9:أخرجه ابن جرير ٢٣/٢١١.|10:عزاه السيوطي إلى عبد بن حميد.|11:أخرجه ابن أبي الدنيا في كتاب العقوبات -موسوعة الإمام ابن أبي الدنيا ٤/٤٥٨-٤٥٩ (١٣١)-.|12:أخرجه ابن جرير ٢٣/٢١٠. وعزاه السيوطي إلى عبد الرزاق، وعبد بن حميد، وابن المنذر.|13:أخرجه أبو جعفر الرملي في جزئه (تفسير عطاء) ص٩١.|14:تفسير مقاتل بن سليمان ٤/٤٢١.|15:أخرجه ابن جرير ٢٣/٢١١.|16:تفسير ابن عيينة -كما في الفتح ٦/٣٧٧-. وعلقه البخاري في صحيحه ٦/١٠٩.
  69,7,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿سَخَّرَهَا عَلَیۡهِمۡ سَبۡعَ لَیَالࣲ وَثَمَـٰنِیَةَ أَیَّامٍ حُسُومࣰاۖ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٨٤٠٧<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن مسعود</span> -من طريق أبي معمر- في قوله: <span class="qpc-hafs">﴿حُسُومًا﴾</span>، قال: مُتتابعات{1}. (١٤/٦٦٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٤٠٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- في قوله: <span class="qpc-hafs">﴿حُسُومًا﴾</span>، قال: تِباعًا{2}. (١٤/٦٦٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٤٠٩<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، أنّ نافع بن الأزرق قال له: أخبِرني عن قوله: <span class="qpc-hafs">﴿حُسُومًا﴾</span>. قال: دائمة شديدة، يعني: مَحسومة بالبلاء. قال: وهل تعرف العرب ذلك؟ قال: نعم، أما سمعتَ أُميّة بن أبي الصّلت وهو يقول:</p><p>وكم كُنّا بها من فَرطِ عام وهذا الدّهر مُقتبلٌ حُسُوم{3}. (١٤/٦٦٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٤١٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق أبي داود- قال: أول ما عَرفوا أنّه عذاب رَأوا ما كان خارجًا من رِحالهم ومواشيهم، تَطير بين السماء والأرض مِثل الريش، دَخلوا بيوتهم، وأَغلقوا أبوابهم، فجاءت الريح، ففَتحتْ أبوابهم، ومالتْ بالرّمل، فكانوا تحت الرّمل <span class="qpc-hafs">﴿سَبْعَ لَيالٍ وثَمانِيَةَ أيّامٍ حُسُومًا﴾</span> لهم أنين، ثم أمَر الريح فسَكنتْ عنهم الرّمل، وأَمرَها فطَرحتْهم في البحر، فهو قوله تعالى: <span class="qpc-hafs">﴿فَأَصْبَحُوا لا يُرى إلّا مَساكِنُهُمْ﴾</span> [الأحقاف:٢٥]{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٤١١<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿حُسُومًا﴾</span>، قال: مُتتابِعة{5}. (١٤/٦٦٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٤١٢<span class="dash">-</span></span> قال <span class="name-2">الضَّحّاك بن مُزاحِم</span>: كاملة، لم تَفْتُر عنهم حتى أفنَتْهم{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٤١٣<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span> -من طريق سِماك- في قوله: <span class="qpc-hafs">﴿حُسُومًا﴾</span>، قال: مُتتابعة{7}. (١٤/٦٦٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٤١٤<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span> -من طريق عبد الكريم الجزري- قال: <span class="qpc-hafs">﴿حُسُومًا﴾</span>، قال: مشايِم{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٤١٥<span class="dash">-</span></span> قال <span class="name-2">عطية العَوفيّ</span>: شؤمًا؛ كأنها حَسمت الخير عن أهلها{9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٤١٦<span class="dash">-</span></span> قال <span class="name-2">وهْب بن مُنَبِّه</span>: <span class="qpc-hafs">﴿سَبْعَ لَيالٍ وثَمانِيَةَ أيّامٍ﴾</span> هي الأيام التي سَمّاها العرب: أيام العجوز، ذات بردٍ ورياح شديدة، وإنما نُسبتْ هذه الأيام الى العجوز لأنّ عجوزًا دخَلتْ سربًا، فتَبِعتْها الريح، فقتَلتْها اليوم الثامن من نزول العذاب، وانقطع العذاب في اليوم الثامن{10}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٤١٧<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- قوله <span class="qpc-hafs">﴿وثَمانِيَةَ أيّامٍ حُسُومًا﴾</span>، قال: مُتتابعة، ليس فيه تَفتير{11}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٤١٨<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- في قوله: <span class="qpc-hafs">﴿حُسُومًا﴾</span>، قال: دائمات{12}. (١٤/٦٦٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٤١٩<span class="dash">-</span></span> عن <span class="name-2">الربيع بن أنس</span>، في قوله: <span class="qpc-hafs">﴿سَخَّرَها عَلَيْهِمْ سَبْعَ لَيالٍ وثَمانِيَةَ أيّامٍ﴾</span>، قال: كان أولها الجمعة{13}. (١٤/٦٦٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٤٢٠<span class="dash">-</span></span> قال <span class="name-3">محمد بن السّائِب الكلبي</span>: <span class="qpc-hafs">﴿حُسُومًا﴾</span> دائمة{14}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٤٢١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿سَخَّرَها﴾</span> يعني: سَلّطها <span class="qpc-hafs">﴿عَلَيْهِمْ﴾</span> الرّبُّ -تبارك وتعالى- <span class="qpc-hafs">﴿سَبْعَ لَيالٍ وثَمانِيَةَ أيّامٍ حُسُومًا﴾</span> فهي كاملة دائمة، لا تَفْتُر عنهم فيهنَّ، يُعذّبهم بالريح كلَّ يوم حتى أفنتْ أرْواحَهُم يوم الثامن{15}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٤٢٢<span class="dash">-</span></span> عن <span class="name-3">عبد الملك ابن جُرَيْج</span>، في قوله: <span class="qpc-hafs">﴿سَخَّرَها عَلَيْهِمْ سَبْعَ لَيالٍ وثَمانِيَةَ أيّامٍ حُسُومًا﴾</span>، قال: كانوا سبعَ ليال وثمانيةَ أيام أحياء في عذاب مِن الريح، فلمّا أمسَوا اليومَ الثامن ماتوا، فاحتَملتْهم الريح، فأَلقتْهم في البحر، فذلك قوله: <span class="qpc-hafs">﴿فَهَلْ تَرى لَهُمْ مِن باقِيَةٍ﴾</span>. وقوله: ‹فَأَصْبَحُوا لا تَرى إلّا مَساكِنَهُمْ› [الأحقاف:٢٥]. قال: وأُخْبِرتُ أنّ النبي ﷺ قال: «<b>عذّبهم بُكرةً، وكَشف عنهم في اليوم الثاني حتى كان الليلُ</b>»{16}. (١٤/٦٦٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٤٢٣<span class="dash">-</span></span> عن <span class="name-3">سفيان [الثوري]</span> -من طريق مهران- <span class="qpc-hafs">﴿أيّامٍ حُسُومًا﴾</span>، قال: مُتتابعة. و<span class="qpc-hafs">﴿أيّامٍ نَحِساتٍ﴾</span> [فصلت:١٦]، قال: مَشائيم{11}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٤٢٤<span class="dash">-</span></span> قال <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿وثَمانِيَةَ أيّامٍ حُسُومًا﴾</span>، قال: حَسَمتْهم؛ لم تُبقِ منهم أحدًا. قال: ذلك الحُسُوم، مثل الذي يقول: احْسِم هذا الأمر. قال: وكان فيهم ثمانية لهم خَلْقٌ يَذهب بهم في كلّ مَذهب. قال: قال موسى بن عُقبة: فلما جاءهم العذاب قالوا: قُوموا بنا نَردّ هذا العذاب عن قومنا. قال: فقاموا، وصَفُّوا في الوادي، فأوحى اللهُ إلى مَلِك الريح أن يَقلع منهم كلَّ يوم واحدًا. وقرأ قول الله: <span class="qpc-hafs">﴿سَخَّرَها عَلَيْهِمْ سَبْعَ لَيالٍ وثَمانِيَةَ أيّامٍ حُسُومًا﴾</span> حتى بلغ: <span class="qpc-hafs">﴿نَخْلٍ خاوِيَةٍ﴾</span>. قال: فإن كانت الريح لَتَمُرّ بالظَّعينة، فتَسْتَدْبرها وحُمولتها، ثم تَذهب بهم في السماء، ثم تَكُبّهم على الرؤوس. وقرأ قول الله: <span class="qpc-hafs">﴿فَلَمّا رَأَوْهُ عارِضًا مُسْتَقْبِلَ أوْدِيَتِهِمْ قالُوا هَذا عارِضٌ مُمْطِرُنا﴾</span> قال: وكان أمسك عنهم المطر. فقرأ حتى بلغ: <span class="qpc-hafs">﴿تُدَمِّرُ كُلَّ شَيْءٍ بِأَمْرِ رَبِّها﴾</span> [الأحقاف:٢٤، ٢٥]. قال: وما كانت الريح تَقلع من أولئك الثمانية كلّ يوم إلا واحدًا. قال: فلمّا عَذّب الله قوم عاد أبقى الله واحدًا يُنذِر الناس. قال: فكانت امرأةُ قد رَأتْ قومها، فقالوا لها: أنتِ أيضًا. قالت: تَنحّيتُ على الجبل. قال: وقيل لها بعدُ: أنتِ قد سَلمتِ وقد رأيتِ، فكيف لا رأيتِ عذاب الله؟ قالت: ما أدري غير أنّ أسْلَم ليلةٍ ليلةَ لا ريح{18}<span class=comment-ref>٦٧٥٦</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٧٥٦</span> اختُلف في معنى قوله: <span class="qpc-hafs">﴿حسوما﴾</span> على أقوال: <b>الأول</b>: أنها المتتابعة. <b>الثاني</b>: أنها الريح التي تَحسم كلّ شيء. <b>الثالث</b>: مشائيم.</p><p>و<span class="comment-type-4">علَّق</span> <u>ابنُ عطية</u> (٨/٣٨٦) على القول الأول الذي قاله ابن مسعود، وابن عباس، وقتادة، وعكرمة، ومجاهد، وسفيان، والكلبي، والضَّحّاك، بقوله: «ومنه كما <span class="mustanad">تقول العرب</span>:ما لقيته حولًا مجرّمًا». و<span class="comment-type-4">علَّق</span> (٨/٣٨٧) على القول الثاني الذي قاله ابن زيد، والعَوفيّ، بقوله: «ومعناه: أنّ تلك الأيام قطّعتهم بالإهلاك، ومنه: حسْم العِلل، ومنه: الحُسام».</p><p>و<span class="comment-type-3">رجَّح</span> <u>ابنُ جرير</u> (١٤/٢١٤-٢١٥) -<span class="mustanad">مستندًا إلى الإجماع</span>- القول الأول، فقال: «لإجماع الحجة مِن أهل التأويل على ذلك». ثم <span class="comment-type-4">ذكر</span> أنّ بعض أهل العربية يقول: الحُسوم: التّباع، إذا تتابع الشيء فلم ينقطع أوله عن آخره قيل فيه: حُسوم. و<span class="comment-type-4">علَّق</span> عليه بقوله: «وإنما أُخذ -والله أعلم- من: حَسَم الداء؛ إذا كُوى صاحبه؛ لأنه لحم يُكوى بالمكواة، ثم يُتابع عليه». و<span class="comment-type-4">بيّن</span> (١٤/٢١٣) أنه على القول الثاني فالحُسوم من صفة الريح.</div></p><p><h3><span class="qpc-hafs">﴿فَتَرَى ٱلۡقَوۡمَ فِیهَا صَرۡعَىٰ كَأَنَّهُمۡ أَعۡجَازُ نَخۡلٍ خَاوِیَةࣲ ۝٧﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٨٤٢٥<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، في قوله: <span class="qpc-hafs">﴿كَأَنَّهُمْ أعْجازُ نَخْلٍ﴾</span> قال: أصولها. وفي قوله: <span class="qpc-hafs">﴿خاوِيَةٍ﴾</span> قال: خَرِبة{16}. (١٤/٦٦٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٤٢٦<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿كَأَنَّهُمْ أعْجازُ نَخْلٍ خاوِيَةٍ﴾</span>، قال: هي أصول النّخل؛ قد بَقِيتْ أصولُها، وذَهبت أعاليها{20}. (١٤/٦٦٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٤٢٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فَتَرى﴾</span> يا محمد <span class="qpc-hafs">﴿القَوْمَ فِيها﴾</span> يعني: في تلك الأيام <span class="qpc-hafs">﴿صَرْعى﴾</span> يعني: موتى، يعني: أمواتًا، وكان طول كلِّ رجل منهم اثني عشر ذراعًا، ثم شَبّههم بالنّخل، فقال: <span class="qpc-hafs">﴿كَأَنَّهُمْ أعْجازُ نَخْلٍ﴾</span> فذَكر النّخل لطولهم، <span class="qpc-hafs">﴿خاوِيَةٍ﴾</span> يعني: أصول نخلٍ بالية، التي ليست لها رؤوس، وبَقِيتْ أصولها، وذهبت أعناقها{21}<span class=comment-ref>٦٧٥٧</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٧٥٧</span> <span class="comment-type-4">ذكر</span> <u>ابنُ عطية</u> (٨/٣٨٧) أنّ الضمير في قوله: <span class="qpc-hafs">﴿فِيها صَرْعى﴾</span> يحتمل احتمالين: <b>الأول</b>: أن يعود على دارهم وحِلّتهم؛ لأنّ معنى الكلام يقتضيها، وإن لم يُلفظ بها. <b>الثاني</b>: أن يعود على الريح. و<span class="comment-type-4">ذكر</span> أنّ الثعلبي نَقله.</div></p></div>",footnotes:1:أخرجه عبد الرزاق ٢/٣١٢ بلفظ: مُتتابعة، وابن جرير ٢٣/٢١٢-٢١٣ بلفظ: مُتتابعة، وتِباعًا، والطبراني (٩٠٦١)، والحاكم ٢/٥٠٠. وعزاه السيوطي إلى الفريابي، وسعيد بن منصور، وعبد بن حميد، وابن المنذر.|2:أخرجه ابن جرير ٢٣/٢١٢. وعزاه السيوطي إلى عبد بن حميد، وقال: وفي لفظ: مُتتابعات.|3:عزاه السيوطي إلى الطستي.|4:أخرجه ابن أبي الدنيا في كتاب العقوبات، وفي كتاب المطر والرعد والبرق والريح -موسوعة الإمام ابن أبي الدنيا ٤/٤٥٧ (١٢٧)، ٨/٤٤٤ (١٣٤)-، وأبو الشيخ في العظمة (٨١١).|5:تفسير مجاهد ص٦٧١ من طريق منصور. وأخرجه ابن جرير ٢٣/٢١٢، وأبو الشيخ في العظمة (٨١٣). وعزاه السيوطي إلى عبد بن حميد.|6:تفسير الثعلبي ١٠/٢٧.|7:أخرجه ابن جرير ٢٣/٢١٢. وعزاه السيوطي إلى عبد بن حميد.|8:أخرجه عبد الرزاق ٢/٣١٢. ووردت هكذا في المطبوع! ولعلها تصحَّفت عن: مشائيم.|9:تفسير الثعلبي ١٠/٢٧، وتفسير البغوي ٨/٢٠٨.|10:تفسير الثعلبي ١٠/٢٦، وتفسير البغوي ٨/٢٠٨.|11:أخرجه ابن جرير ٢٣/٢١٣.|12:أخرجه عبد الرزاق ٢/٢١٣، ٣/٣٣٨، وابن جرير ٢٣/٢١٣. وعزاه السيوطي إلى عبد بن حميد.|13:عزاه السيوطي إلى ابن أبي حاتم.|14:تفسير البغوي ٨/٢٠٨، وتفسير الثعلبي ١٠/٢٧.|15:تفسير مقاتل بن سليمان ٤/٤٢١.|16:عزاه السيوطي إلى ابن المنذر.|17:أخرجه ابن جرير ٢٣/٢١٣.|18:أخرجه ابن جرير ٢٣/٢١٤.|19:عزاه السيوطي إلى ابن المنذر.|20:أخرجه ابن جرير ٢٣/٢١٥. وعزاه السيوطي إلى عبد بن حميد، وعبد الرزاق.|21:تفسير مقاتل بن سليمان ٤/٤٢١-٤٢٢.
  69,8,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿فَهَلۡ تَرَىٰ لَهُم مِّنۢ بَاقِیَةࣲ ۝٨﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٨٤٢٨<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فَهَلْ تَرى لَهُمْ مِن باقِيَةٍ﴾</span>، يقول: لم تُبقِ منهم أحدًا{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٨٤٢٩<span class="dash">-</span></span> عن <span class="name-3">عبد الملك ابن جُرَيْج</span>، في قوله: ... فلما أمسَوا اليومَ الثامن ماتوا، فاحتَملتْهم الريح، فأَلقتْهم في البحر، فذلك قوله: <span class="qpc-hafs">﴿فَهَلْ تَرى لَهُمْ مِن باقِيَةٍ﴾</span>{2}. (١٤/٦٦٥)</p></p><p></div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٤/٤٢١-٤٢٢.|2:عزاه السيوطي إلى ابن المنذر.