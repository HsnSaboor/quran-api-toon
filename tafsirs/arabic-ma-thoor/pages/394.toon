quran[7]{c,v,t}:
  28,71,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿قُلۡ أَرَءَیۡتُمۡ إِن جَعَلَ ٱللَّهُ عَلَیۡكُمُ ٱلَّیۡلَ سَرۡمَدًا إِلَىٰ یَوۡمِ ٱلۡقِیَـٰمَةِ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٩١٣٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- في قوله: <span class="qpc-hafs">﴿إن جعل الله عليكم الليل سرمدا﴾</span>، قال: دائِمًا{1}. (١١/٥٠١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٩١٣١<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿سرمدا﴾</span>، قال: دائِمًا لا ينقطع{2}. (١١/٥٠١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٩١٣٢<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿سرمدا إلى يوم القيامة﴾</span>: أي: دائِمًا إلى يوم القيامة{3}. (١١/٥٠١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٩١٣٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿قل﴾</span> يا محمد لكفار مكة: <span class="qpc-hafs">﴿أرأيتم إن جعل الله عليكم الليل سرمدا إلى يوم القيامة﴾</span> فدامتْ ظُلْمَتُه{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٩١٣٤<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿سرمدا﴾</span>، أي: دائمًا لا ينقطع{5}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿مَنۡ إِلَـٰهٌ غَیۡرُ ٱللَّهِ یَأۡتِیكُم بِضِیَاۤءٍۚ أَفَلَا تَسۡمَعُونَ ۝٧١﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٩١٣٥<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿من إله غير الله يأتيكم بضياء﴾</span>، قال: بنهار{3}. (١١/٥٠١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٩١٣٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿من إله غير الله يأتيكم بضياء﴾</span> يعني: بضوء النهار، <span class="qpc-hafs">﴿أفلا﴾</span> يعني: أفهَلّا <span class="qpc-hafs">﴿تسمعون﴾</span> المواعِظَ{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٩١٣٧<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿إلى يوم القيامة من إله غير الله يأتيكم بضياء﴾</span> وهذا على الاستفهام <span class="qpc-hafs">﴿يأتيكم بضياء﴾</span> بنهار، <span class="qpc-hafs">﴿أفلا تسمعون﴾</span>. أمَرَهُ أن يقوله للمشركين{8}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ١٨/٣٠٥، وابن أبي حاتم ٩/٣٠٠٣. وعزاه السيوطي إلى ابن المنذر.|2:أخرجه ابن جرير ١٨/٣٠٤، وإسحاق البستي في تفسيره ص٥٥ من طريق ابن جريج، وابن أبي حاتم ٩/٣٠٠٣. وعلَّقه يحيى بن سلام ٢/٦٠٦. وعزاه السيوطي إلى الفريابي، وعبد بن حميد، وابن جرير، وابن المنذر.|3:أخرجه ابن أبي حاتم ٩/٣٠٠٣. وعزاه السيوطي إلى عبد بن حميد.|4:تفسير مقاتل بن سليمان ٣/٣٥٤.|5:تفسير يحيى بن سلام ٢/٦٠٧.|6:أخرجه ابن أبي حاتم ٩/٣٠٠٣. وعزاه السيوطي إلى عبد بن حميد.|7:تفسير مقاتل بن سليمان ٣/٣٥٤.|8:تفسير يحيى بن سلام ٢/٦٠٦.
  28,72,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿قُلۡ أَرَءَیۡتُمۡ إِن جَعَلَ ٱللَّهُ عَلَیۡكُمُ ٱلنَّهَارَ سَرۡمَدًا إِلَىٰ یَوۡمِ ٱلۡقِیَـٰمَةِ مَنۡ إِلَـٰهٌ غَیۡرُ ٱللَّهِ یَأۡتِیكُم بِلَیۡلࣲ تَسۡكُنُونَ فِیهِۚ أَفَلَا تُبۡصِرُونَ ۝٧٢﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٩١٣٨<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- <span class="qpc-hafs">﴿تسكنون﴾</span>: تقرون{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٩١٣٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: و<span class="qpc-hafs">﴿قل﴾</span> لهم: <span class="qpc-hafs">﴿أرأيتم إن جعل الله عليكم النهار سرمدا إلى يوم القيامة من إله غير الله يأتيكم بليل تسكنون فيه﴾</span> مِن النَّصَب، <span class="qpc-hafs">﴿أفلا﴾</span> يعني: أفهَلّا <span class="qpc-hafs">﴿تبصرون﴾</span>{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٩١٤٠<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿قل أرأيتم إن جعل الله عليكم النهار سرمدا﴾</span> أي: دائِمًا لا ينقطع <span class="qpc-hafs">﴿إلى يوم القيامة من إله غير الله يأتيكم بليل تسكنون فيه﴾</span> كقوله: <span class="qpc-hafs">﴿وجعل الليل سكنا﴾</span> [الأنعام:٩٦] يسكن فيه الخلق، <span class="qpc-hafs">﴿أفلا تبصرون﴾</span>. أمَرَهُ أن يقوله للمشركين{3}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن أبي حاتم ٩/٣٠٠٣.|2:تفسير مقاتل بن سليمان ٣/٣٥٤.|3:تفسير يحيى بن سلام ٢/٦٠٧.
  28,73,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَمِن رَّحۡمَتِهِۦ جَعَلَ لَكُمُ ٱلَّیۡلَ وَٱلنَّهَارَ لِتَسۡكُنُوا۟ فِیهِ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٩١٤١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثم أخبر عن صنعه -تعالى ذِكْرُه-، فقال سبحانه: <span class="qpc-hafs">﴿ومن رحمته جعل لكم الليل والنهار لتسكنوا﴾</span> يعني: لتستقروا <span class="qpc-hafs">﴿فيه﴾</span> بالليل مِن النصَب{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٩١٤٢<span class="dash">-</span></span> عن <span class="name-3">عبد الملك ابن جُرَيْج</span>، <span class="qpc-hafs">﴿ومن رحمته جعل لكم الليل والنهار لتسكنوا فيه﴾</span>، قال: في الليل{2}. (١١/٥٠١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٩١٤٣<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿ومن رحمته جعل لكم الليل والنهار لتسكنوا فيه﴾</span> في الليل{3}<span class=comment-ref>٤٩٨٧</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٤٩٨٧</span> <span class="comment-type-4">ذكر</span> <u>ابنُ جرير</u> (١٨/٣٠٦) في الهاء من قوله: <span class="qpc-hafs">﴿لتسكنوا فيه﴾</span> وجهين، فقال: «وفي الهاء التي في قوله: <span class="qpc-hafs">﴿لتسكنوا فيه﴾</span> وجهان: <b>أحدهما</b>: أن تكون من ذكر الليل خاصة، ويضم للنهار مع الابتغاء هاء أخرى. <b>والثاني</b>: أن تكون من ذكر الليل والنهار، فيكون وجه توحيدها -وهي لهما- وجه توحيد العرب في قولهم: إقبالك وإدبارك يؤذيني. لأن الإقبال والإدبار فعل، والفعل يُوَحَّد كثيره وقليله».</div></p><p><h3><span class="qpc-hafs">﴿وَلِتَبۡتَغُوا۟ مِن فَضۡلِهِۦ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٩١٤٤<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- <span class="qpc-hafs">﴿ولتبتغوا من فضله﴾</span>: يعني: التجارة{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٩١٤٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ولتبتغوا﴾</span> بالنهار <span class="qpc-hafs">﴿من فضله﴾</span> يعني: الرِّزق{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٩١٤٦<span class="dash">-</span></span> عن <span class="name-3">عبد الملك ابن جريج</span>: <span class="qpc-hafs">﴿ولتبتغوا من فضله﴾</span> قال: في النهار{2}. (١١/٥٠١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٩١٤٧<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿ولتبتغوا من فضله﴾</span> بالنهار، وهذا رحمة مِن الله للمؤمن والكافر، فأمّا المؤمن فتَتِمُّ عليه رحمة الله في الآخرة، وأمّا الكافر فهي رحمة له في الدنيا، وليس له في الآخرة نصيب{3}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَلَعَلَّكُمۡ تَشۡكُرُونَ ۝٧٣﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٩١٤٨<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ولعلكم تشكرون﴾</span> ربَّكم في نِعَمِه، فتُوَحِّدوه ﷿{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٩١٤٩<span class="dash">-</span></span> قال <span class="name-3">سفيان بن عيينة</span> -من طريق عمر بن عبد الغفار-: على كل مُسْلِمٍ أن يشكر الله؛ لأنّ الله قال: <span class="qpc-hafs">﴿ولعلكم تشكرون﴾</span>{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٩١٥٠<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: قال: <span class="qpc-hafs">﴿ولعلكم تشكرون﴾</span> ولكي تشكروا{3}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٣/٣٥٤.|2:عزاه السيوطي إلى ابن المنذر.|3:تفسير يحيى بن سلام ٢/٦٠٧.|4:أخرجه ابن أبي حاتم ٩/٣٠٠٣.|5:تفسير مقاتل بن سليمان ٣/٣٥٤.|6:عزاه السيوطي إلى ابن المنذر.|7:تفسير يحيى بن سلام ٢/٦٠٧.|8:تفسير مقاتل بن سليمان ٣/٣٥٤.|9:أخرجه ابن أبي حاتم ٩/٣٠٠٣.|10:تفسير يحيى بن سلام ٢/٦٠٧.
  28,74,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَیَوۡمَ یُنَادِیهِمۡ فَیَقُولُ أَیۡنَ شُرَكَاۤءِیَ ٱلَّذِینَ كُنتُمۡ تَزۡعُمُونَ ۝٧٤﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٩١٥١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ويوم يناديهم﴾</span> يعني: يسألهم <span class="qpc-hafs">﴿فيقول أين شركائي الذين كنتم تزعمون﴾</span> أي: في الدنيا{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٩١٥٢<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿ويوم يناديهم فيقول أين شركائي الذين كنتم تزعمون﴾</span>، وهي مثل الأولى{2}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٣/٣٥٥.|2:تفسير يحيى بن سلام ٢/٦٠٧.
  28,75,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَنَزَعۡنَا مِن كُلِّ أُمَّةࣲ شَهِیدࣰا﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٩١٥٣<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق أبي نجيح- في قوله: <span class="qpc-hafs">﴿ونزعنا من كل أمة شهيدا﴾</span>، قال: رسولًا{1}<span class=comment-ref>٤٩٨٨</span>. (١١/٥٠٢)</p></p><p></div></p><p><div><span class=comment-ref>٤٩٨٨</span> ذكر <u>ابنُ عطية</u> (٦/٦٠٨) قول مجاهد، و<b>قولًا آخر</b> عن الرماني: أنّ الشهيد: هم العدول والأخيار من الأمم. ثم <span class="comment-type-4">علّق</span> بقوله: «وهم حَمَلة الحُجَّة الذين لا يخلو منهم زمان، و»الشهيد«على هذا التأويل، اسم الجنس».</div></p><p><div></p><p><p><span class="item-no">٥٩١٥٤<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿ونزعنا من كل أمة شهيدا﴾</span>، قال: شهيدها: نبيها؛ ليشهد عليها أنّه قد بلَّغ رسالاتِ ربه{2}. (١١/٥٠٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٩١٥٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ونزعنا﴾</span> يقول: وأخرجنا <span class="qpc-hafs">﴿من كل أمة شهيدا﴾</span> يعني: رسولها ونبيَّها، يشهد عليها بالبلاغ والرسالة{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٩١٥٦<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿ونزعنا من كل أمة شهيدا﴾</span> جئنا برسولهم. كقوله: <span class="qpc-hafs">﴿فكيف إذا جئنا من كل أمة بشهيد وجئنا بك على هؤلاء شهيدا﴾</span> [النساء:٤١]، وكقوله: <span class="qpc-hafs">﴿يوم ندعو كل أناس بإمامهم﴾</span> [الإسراء:٧١] بنبيِّهم. وقال بعضُهم: بكتابهم{4}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿فَقُلۡنَا هَاتُوا۟ بُرۡهَـٰنَكُمۡ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٩١٥٧<span class="dash">-</span></span> عن <span class="name-2">أبي العالية الرِّياحِيِّ</span> -من طريق الربيع- قوله: <span class="qpc-hafs">﴿قل هاتوا برهانكم﴾</span>، أي: حُجَّتكم{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٩١٥٨<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٩١٥٩<span class="dash">-</span></span> و<span class="name-2">الربيع بن أنس</span>، مثل ذلك{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٩١٦٠<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق أبي نجيح- في قوله: <span class="qpc-hafs">﴿فقلنا هاتوا برهانكم﴾</span>، قال: هاتوا حُجَّتكم بما كنتم تعبدون وتقولون{7}. (١١/٥٠٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٩١٦١<span class="dash">-</span></span> تفسير <span class="name-2">الحسن البصري</span>: قوله: <span class="qpc-hafs">﴿فقلنا هاتوا برهانكم﴾</span> حجتكم{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٩١٦٢<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿فقلنا هاتوا برهانكم﴾</span>، قال: بَيِّنَتكم{9}. (١١/٥٠٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٩١٦٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فقلنا﴾</span> لهم يعني: للكفار: <span class="qpc-hafs">﴿هاتوا﴾</span> هلموا <span class="qpc-hafs">﴿برهانكم﴾</span> يعني: حجتكم بأنّ معي شريكًا. فلم يكن لهم حجة{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٩١٦٤<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: قوله: <span class="qpc-hafs">﴿فقلنا هاتوا برهانكم﴾</span> بأنّ الله أمركم بما كنتم عليه مِن الشِّرك{4}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿فَعَلِمُوۤا۟ أَنَّ ٱلۡحَقَّ لِلَّهِ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٩١٦٥<span class="dash">-</span></span> تفسير <span class="name-2">إسماعيل السُّدِّيّ</span>: قوله <span class="qpc-hafs">﴿أن الحق لله﴾</span>، يعني: التوحيد{12}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٩١٦٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فعلموا أن الحق لله﴾</span>، يعني: التوحيد لله ﷿{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٩١٦٧<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: قوله: <span class="qpc-hafs">﴿فعلموا﴾</span> يومئذ{14}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَضَلَّ عَنۡهُم مَّا كَانُوا۟ یَفۡتَرُونَ ۝٧٥﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٩١٦٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق الضحاك-: <span class="qpc-hafs">﴿وضل عنهم﴾</span> في القيامة <span class="qpc-hafs">﴿ما كانوا يفترون﴾</span> يكذبون في الدنيا{15}. (١١/٥٠٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٩١٦٩<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق أبي نجيح- في قوله: <span class="qpc-hafs">﴿وضل عنهمما كانوا يفترون﴾</span>: ما كانوا يعبدون ويقولون{16}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٩١٧٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وضل عنهم﴾</span> في الآخرة <span class="qpc-hafs">﴿ماكانوا يفترون﴾</span> في الدنيا بأنّ مع الله سبحانه شريكًا{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٩١٧١<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿وضل عنهم ما كانوا يفترون﴾</span> أوثانهم التي كانوا يعبدونها{14}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ١٨/٣٠٧-٣٠٨، وإسحاق البستي في تفسيره ص٥٥ من طريق ابن جريج، وابن أبي حاتم ٩/٣٠٠٤. وعلَّقه يحيى بن سلام ٢/٦٠٧. وعزاه السيوطي إلى الفريابي، وابن أبي شيبة، وعبد بن حميد، وابن المنذر.|2:أخرجه ابن جرير ١٨/٣٠٧، وابن أبي حاتم ٩/٣٠٠٤. وعزاه السيوطي إلى عبد بن حميد.|3:تفسير مقاتل بن سليمان ٣/٣٥٥.|4:تفسير يحيى بن سلام ٢/٦٠٧.|5:أخرجه ابن أبي حاتم ٩/٣٠٠٤.|6:علقه ابن أبي حاتم ٩/٣٠٠٤.|7:أخرجه ابن جرير ١٨/٣٠٨ بلفظ: حجتكم لما كنتم .... وعلَّقه ابن أبي حاتم ٩/٣٠٠٤. وعزاه السيوطي إلى الفريابي، وابن أبي شيبة، وعبد بن حميد، وابن المنذر.|8:علَّقه يحيى بن سلام ٢/٦٠٧.|9:أخرجه ابن جرير ١٨/٣٠٧-٣٠٨، وابن أبي حاتم ٩/٣٠٠٤. وعلقه يحيى بن سلام ٢/٦٠٨. وعزاه السيوطي إلى عبد بن حميد.|10:تفسير مقاتل بن سليمان ٣/٣٥٥.|11:تفسير يحيى بن سلام ٢/٦٠٧.|12:علَّقه يحيى بن سلام ٢/٦٠٨.|13:تفسير مقاتل بن سليمان ٣/٣٥٥.|14:تفسير يحيى بن سلام ٢/٦٠٨.|15:أخرجه ابن أبي حاتم ٩/٣٠٠٥.|16:تفسير مجاهد ص٥٣١.|17:تفسير مقاتل بن سليمان ٣/٣٥٥.|18:تفسير يحيى بن سلام ٢/٦٠٨.
  28,76,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿إِنَّ قَـٰرُونَ كَانَ مِن قَوۡمِ مُوسَىٰ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٩١٧٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق سعيد بن جبير- <span class="qpc-hafs">﴿إن قارون كان من قوم موسى﴾</span>، قال: كان ابنَ عمِّه{1}. (١١/٥٠٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٩١٧٣<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق مقاتل بن سليمان، وجويبر، عن الضحاك- أنّه قال في هذه الآية: <span class="qpc-hafs">﴿إن قارون كان من قوم موسى فبغى عليهم﴾</span>: يعني: كان ابنَ عمِّ موسى، وكان قارون بن يصهر بن لاوي{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٩١٧٤<span class="dash">-</span></span> عن <span class="name-2">إبراهيم النخعي</span> -من طريق سماك- قال: كان قارونُ ابنَ عمِّ موسى{3}. (١١/٥٠٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٩١٧٥<span class="dash">-</span></span> عن <span class="name-2">عبد الله بن الحارث بن نوفل</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٩١٧٦<span class="dash">-</span></span> و<span class="name-2">سماك بن حرب</span>، مثله{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٩١٧٧<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- قال: كان قارونُ ابنَ عم موسى أخي أبيه، وكان قطع البحر مع بني إسرائيل، وكان يُسَمّى: النورَ؛ مِن حسن صوته بالتوراة، ولكن عدو الله نافق كما نافق السامريُّ، فأهلكه الله لِبَغْيِه{5}. (١١/٥٠٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٩١٧٨<span class="dash">-</span></span> عن <span class="name-2">مالك بن دينار</span> -من طريق جعفر بن سليمان الضبعي- قال: بلغني: أنّ موسى بن عمران كان ابنَ عمِّ قارون{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٩١٧٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿إن قارون كان من قوم موسى﴾</span>، يعني: مِن بني إسرائيل، وكان ابنَ عمِّه؛ قارون بن أصهر بن قوهث بن لاوي بن يعقوب، وموسى بن عمران بن قوهث{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٩١٨٠<span class="dash">-</span></span> عن <span class="name-3">عبد الملك ابن جريج</span> -من طريق حجاج- في قوله: <span class="qpc-hafs">﴿إن قارون كان من قوم موسى﴾</span>، قال: كان ابن عمه أخي أبيه؛ قارون بن يصهر بن قاهث أو قاهب، وموسى بن عرمرم{8} بن قاهث أو قاهب. وعرمرم بالعربية: عِمْران{9}. (١١/٥٠٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٩١٨١<span class="dash">-</span></span> عن <span class="name-3">محمد بن إسحاق</span> -من طريق سلمة-: أن يصهر بن قاهث تزوج سميتَ بنت بتاويت بن بركنا بن يقسان بن إبراهيم، فولدت له عمران بن يصهر، وقارون بن يصهر، فنكح عمران يحيب بنت شمويل بن بركنا بن يقسان بن إبراهيم، فولدت له هارون بن عمران، وموسى بن عمران صفيَّ اللهِ ونبيه{10}<span class=comment-ref>٤٩٨٩</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٤٩٨٩</span> في نسبة قارون لموسى أقوال: <b>الأول</b>: أنه كان ابن عمه. <b>والثاني</b>: أنه كان عمَّ موسى. قاله ابن إسحاق.</p><p>و<span class="comment-type-4">ذكر</span> <u>ابنُ جرير</u> (١٨/٣١٠) أنّ الأول قول <span class="mustanad">أكثر أهل العلم</span>.</p><p>و<span class="comment-type-4">ذكر</span> <u>ابنُ عطية</u> (٦/٦٠٨) أنه <span class="mustanad">الأشهر</span>. و<span class="comment-type-4">ذكر</span> <u>ابنُ عطية</u> <b>قولًا ثالثًا</b> بأنّه كان ابن خالته.</p><p>و<span class="comment-type-4">ساق</span> <u>ابن عطية</u> (٦/٦٠٨-٦٠٩) هذه الأقوال، ثم قال: «فهو <span class="mustanad">بإجماع</span> رجل من بني إسرائيل، كان ممن آمن بموسى، وحفظ التوراة، وكان مِن أقرأ الناس لها، وكان عند موسى ﵇ مِن عُبّاد المؤمنين، ثم إنه لحقه الزهوُ والإعجاب، فبغى على قومه بأنواعٍ مِن البغي».</div></p><p><div></p><p><p><span class="item-no">٥٩١٨٢<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿إن قارون كان من قوم موسى﴾</span> كان ابنَ عمِّه أخي أبيه{11}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿فَبَغَىٰ عَلَیۡهِمۡۖ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٩١٨٣<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق سعيد بن جبير- <span class="qpc-hafs">﴿إن قارون كان من قوم موسى﴾</span>، قال: كان ابنَ عمِّه، وكان يتبع العلم حتى جمع عِلْمًا، فلم يزل في أمره ذلك حتى بغى على موسى وحَسَدَه{1}. (١١/٥٠٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٩١٨٤<span class="dash">-</span></span> عن <span class="name-2">الضَّحّاك بن مُزاحِم</span> -من طريق جويبر- في قوله: <span class="qpc-hafs">﴿فبغى عليهم﴾</span>، قال: الكفر بالله{13}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٩١٨٥<span class="dash">-</span></span> عن <span class="name-2">شَهْر بن حَوْشَب</span> -من طريق ليث- في قوله: <span class="qpc-hafs">﴿إن قارون كان من قوم موسى فبغى عليهم﴾</span>، قال: زاد عليهم في طول ثيابه شِبرًا{14}. (١١/٥٠٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٩١٨٦<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق شيبان- في قوله: <span class="qpc-hafs">﴿فبغى عليهم﴾</span>، قال: فَعَلا عليهم{15}. (١١/٥٠٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٩١٨٧<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- قال: إنّما بَغى لكثرة ماله وولده{16}. (١١/٥٠٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٩١٨٨<span class="dash">-</span></span> عن <span class="name-2">عطاء الخراساني</span>، في قوله: <span class="qpc-hafs">﴿فبغى عليهم﴾</span>، قال: زاد عليهم في الثياب شِبرًا{17}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٩١٨٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فبغى عليهم﴾</span>، يقول: بغى قارونُ على بني إسرائيل مِن أجل كنزِه مالَه{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٩١٩٠<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿فبغى عليهم﴾</span>، وكان عاملًا لِفرعون، فتعدّى عليهم، وظَلَمهم{11}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَءَاتَیۡنَـٰهُ مِنَ ٱلۡكُنُوزِ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٩١٩١<span class="dash">-</span></span> عن سلمان الفارسي، قال: قال رسول الله ﷺ: «<b>كانت أرضُ دارِ قارون مِن فضة، وأساسُها مِن ذهب</b>»{20}. (١١/٥٠٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٩١٩٢<span class="dash">-</span></span> عن <span class="name-2">عبد الله بن الحارث بن نوفل الهاشمي</span> -من طريق علي بن زيد بن جدعان- قال: بلغنا: أنّ قارون أُوتِي مِن الكنوز والمال حتى جعل بابَ دارِه من ذهب، وجعل دارَه كلها مِن صفائح الذهب{21}. (١١/٥١٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٩١٩٣<span class="dash">-</span></span> عن <span class="name-2">عطاء الخراساني</span> -من طريق ابنه عثمان- في قوله: <span class="qpc-hafs">﴿وآتيناه من الكنوز﴾</span>، قال: أصاب كنزًا مِن كنوز يوسف{22}. (١١/٥٠٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٩١٩٤<span class="dash">-</span></span> عن <span class="name-2">الوليد بن زروان</span> -من طريق موسى بن أعين- في قوله: <span class="qpc-hafs">﴿وآتيناه من الكنوز﴾</span>، قال: كان قارون يعلم الكيمياء{22}. (١١/٥٠٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٩١٩٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿واتيناه﴾</span> يعني: وأعطيناه <span class="qpc-hafs">﴿من الكنوز﴾</span> يعني: مِن الأموال{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٩١٩٦<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿وآتيناه﴾</span> يعني: قارون، أي: أعطيناه <span class="qpc-hafs">﴿من الكنوز﴾</span> أي: مِن الأموال{11}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿مَاۤ إِنَّ مَفَاتِحَهُۥ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٩١٩٧<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق حميد- في الآية، قال: كانت المفاتيحُ مِن جلود الإبل{26}. (١١/٥٠٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٩١٩٨<span class="dash">-</span></span> قال <span class="name-2">مجاهد بن جبر</span>: الذي يُفتَح به الباب{27}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٩١٩٩<span class="dash">-</span></span> عن <span class="name-2">الضَّحّاك بن مُزاحِم</span> -من طريق أبي حجير- <span class="qpc-hafs">﴿ما إن مفاتحه﴾</span>، قال: أوْعِيَته{28}<span class=comment-ref>٤٩٩٠</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٤٩٩٠</span> أفادت الآثار أنّ المفاتح إما أن تكون: ما يُفتَح به، وإما الأوعية. و<span class="comment-type-4">ذكر</span> <u>ابنُ عطية</u> (٦/٦٠٩) أنّ الظاهر القول الأول، و<span class="comment-type-1">وجَّه</span> القول الثاني بقوله: «لأنّ المفتح <span class="mustanad">في كلام العرب</span>: الخزانة».</div></p><p><div></p><p><p><span class="item-no">٥٩٢٠٠<span class="dash">-</span></span> عن <span class="name-2">أبي صالح باذام</span> -من طريق إسماعيل بن سالم- في قوله: <span class="qpc-hafs">﴿ما إن مفاتحه لتنوء بالعصبة﴾</span>، قال: كانت خزائنه تُحمَل على أربعين بغلًا{29}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٩٢٠١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٩٢٠٢<span class="dash">-</span></span> و<span class="name-2">قتادة بن دعامة</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٩٢٠٣<span class="dash">-</span></span> و<span class="name-2">الضحاك بن مزاحم</span>، مثل ذلك{30}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٩٢٠٤<span class="dash">-</span></span> عن حصين بن عبد الرحمن، قال: سألتُ <span class="name-2">أبا رزين</span> عن قوله: <span class="qpc-hafs">﴿ما إن مفاتحه﴾</span>. قال: خزائنه. وفي لفظ: إن كان مفتاح واحد لكافي أهل الكوفة، إنما يعني: كنوزه{31}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٩٢٠٥<span class="dash">-</span></span> قال <span class="name-2">قتادة بن دعامة</span>: الذي يفتح به الباب{27}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٩٢٠٦<span class="dash">-</span></span> عن <span class="name-2">خيثمة بن عبد الرحمن بن أبي سبرة</span> -من طريق الأعمش- قال: وجدتُ في الإنجيل: أنّ مفاتيح خزائن قارون كانت وِقْرَ{33} ستين بغلًا غرًّا محجلة، ما يزيد منها مفتاح على إصبع، لكل مفتاح كنز{34}. (١١/٥٠٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٩٢٠٧<span class="dash">-</span></span> عن <span class="name-2">خيثمة بن عبد الرحمن بن أبي سبرة</span>، قال: كانت مفاتيحُ كنوز قارون مِن جلود، كل مفتاح مثل الإصبع، كل مفتاح على خزانة على حِدة، فإذا رَكِب حملت المفاتيح على سبعين بغلًا أغر محجلًا{35}<span class=comment-ref>٤٩٩١</span>. (١١/٥٠٦)</p></p><p></div></p><p><div><span class=comment-ref>٤٩٩١</span> <span class="comment-type-2">انتقد</span> <u>ابنُ عطية</u> (٦/٦٠٩-٦١٠) ما جاء في وصف مفاتيح قارون <span class="mustanad">مستندًا لدلالة العقل، والقراءة المشهورة</span>، <span class="comment-type-4">فقال</span>: «ذلك كله ضعيف، والنظر يشهد بفساد هذا، ومَن كان الذي يميز بعضها من بعض، وما الداعي إلى هذا؟! وفي الممكن أن ترجع كلها إلى ما يُحصى ويقدر على حمله بسهولة، وكان يلزم على هذا المعنى أن تكون (مَفاتِيح) بياء وهي قراءة الأعمش والذي يشبه إنما هو أن تكون»المفاتيح«من الحديد ونحوه، وعلى هذا تنوء بالعُصبة إذا كانت كثيرة لكثرة مخازنه، أو تكون المفاتيح: الخزائن».</div></p><p><div></p><p><p><span class="item-no">٥٩٢٠٨<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span>، <span class="qpc-hafs">﴿ما إن مفاتحه﴾</span>، قال: خزائنه{36}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٩٢٠٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ما ان مفاتحه﴾</span>، يعني: خزائنه{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٩٢١٠<span class="dash">-</span></span> قال يحيى بن سلّام: قوله ﷿: <span class="qpc-hafs">﴿ما إن مفاتحه﴾</span>، قال بعضهم: خزائنه، يعني: أمواله. وقال بعضهم: مفاتح خزائنه{11}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿لَتَنُوۤأُ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٩٢١١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- في قوله: <span class="qpc-hafs">﴿لتنوء بالعصبة﴾</span>، قال: تُثْقِلُ{39}. (١١/٥٠٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٩٢١٢<span class="dash">-</span></span> عن <span class="name-2">أبي صالح</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٩٢١٣<span class="dash">-</span></span> و<span class="name-2">إسماعيل السُّدِّيّ</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٩٢١٤<span class="dash">-</span></span> و<span class="name-3">عبد الرحمن بن زيد بن أسلم</span>، مثل ذلك{30}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٩٢١٥<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، في قوله: <span class="qpc-hafs">﴿لتنوء بالعصبة﴾</span>، يقول: لا يرفعها العُصْبَة من الرجال أُولي القُوَّة{41}. (١١/٥٠٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٩٢١٦<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>: أنّ نافع بن الأزرق سأله عن قوله: <span class="qpc-hafs">﴿لتنوء بالعصبة﴾</span>. قال: لَتُثْقِلُ. قال: وهل تعرفُ العرب ذلك؟ قال: نعم، أما سمعت قول امرئ القيس:</p><p>تمشي فتُثْقِلُها عَجِيزَتُها{42} مشي الضعيف يَنُوءُ بالوَسْقِ{43}{44}.(١١/٥٠٧) (١١/٥٠٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٩٢١٧<span class="dash">-</span></span> عن <span class="name-2">الربيع بن أنس</span> -من طريق أبي جعفر- قوله: <span class="qpc-hafs">﴿لتنوء بالعصبة﴾</span>، قال: لَتَمُرُّ بالعصبة{45}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٩٢١٨<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: يقول: لتعجز العصبة أولي القوة عن حمل الخزائن{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٩٢١٩<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿لتنوء﴾</span> لَتَثْقُل{11}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿بِٱلۡعُصۡبَةِ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٩٢٢٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق العوفي- قال: <span class="qpc-hafs">﴿بالعصبة﴾</span> أربعون رجلًا{48}. (١١/٥٠٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٩٢٢١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق أبي رَوْق، عن الضحاك- <span class="qpc-hafs">﴿لتنوء بالعصبة﴾</span>، قال: العصبة: ما بين ثلاثة إلى العشرة{48}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٩٢٢٢<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span> -من طريق أبي بشر- قال: قلت: كم العصبة؟ قال: ست، أو سبع{50}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٩٢٢٣<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- قال: العصبة: ما بين العشرة إلى الخمسة عشر{51}. (١١/٥٠٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٩٢٢٤<span class="dash">-</span></span> عن <span class="name-2">الضَّحّاك بن مُزاحِم</span> -من طريق عبيد- في قوله: <span class="qpc-hafs">﴿لتنوء بالعصبة أولي القوة﴾</span>، قال: يزعمون أنّ العصبة أربعون رجلًا، ينقلون مفاتحه مِن كثرة عددها{52}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٩٢٢٥<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span> -من طريق الحكم-: العصبة: أربعون{53}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٩٢٢٦<span class="dash">-</span></span> عن <span class="name-2">أبي صالح مولى أم هانئ</span> -من طريق أبي عوانة، عن إسماعيل بن سالم- قال: العصبة: سبعون رجلًا. قال: وكانت خزانته تحمل على أربعين بغلًا{54}. (١١/٥٠٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٩٢٢٧<span class="dash">-</span></span> عن <span class="name-2">أبي صالح مولى أُمِّ هانئ</span> -من طريق هشيم، عن إسماعيل بن سالم- قال: العصبة: أربعون{55}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٩٢٢٨<span class="dash">-</span></span> عن <span class="name-2">الحكم بن عتيبة</span> -من طريق الحجاج بن أرطأة- <span class="qpc-hafs">﴿لتنوء بالعصبة﴾</span>، قال: العصبة: أربعون رجلًا{45}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٩٢٢٩<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- قال: كُنّا نُحَدَّث: أنّ العصبة: ما فوق العشرة إلى الأربعين{57}. (١١/٥٠٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٩٢٣٠<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط-: <span class="qpc-hafs">﴿ما إن مفاتحه لتنوء بالعصبة﴾</span>، والعصبة: ما بين العشرة إلى الأربعين{58}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٩٢٣١<span class="dash">-</span></span> عن <span class="name-3">محمد بن السائب الكلبي</span> -من طريق معمر- قال: بالعصبة: ما بين الخمس عشرة إلى الأربعين{59}. (١١/٥٠٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٩٢٣٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿لتنوء بالعصبة اولي القوة﴾</span>، والعصبة: مِن عشرة نفر إلى أربعين، فإذا كانوا أربعين فهم أولو قوة، يقول: لتعجز العصبة أولي القوة عن حمل الخزائن{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٩٢٣٣<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق أصبغ بن الفرج - في قوله: <span class="qpc-hafs">﴿لتنوء بالعصبة أولي القوة﴾</span>، قال: العصبة: ما بين الثلاثة إلى تسعة، وهم النفر{50}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٩٢٣٤<span class="dash">-</span></span> قال <span class="name-3">سفيان بن عيينة</span>: ويقال: العصبة: أربعون رجلًا{62}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٩٢٣٥<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿بالعصبة﴾</span> الجماعة{11}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿أُو۟لِی ٱلۡقُوَّةِ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٩٢٣٦<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- قال: وأولو القوة: خمسة عشر{64}. (١١/٥٠٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٩٢٣٧<span class="dash">-</span></span> قال <span class="name-2">إسماعيل السُّدِّيّ</span>: <span class="qpc-hafs">﴿أولي القوة﴾</span>، يعني: أولي الشدة ... وهم هاهنا أربعون رجلًا{65}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٩٢٣٨<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: فإذا كانوا أربعين فهم أولو قوة{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٩٢٣٩<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿أولي القوة﴾</span> من الرجال{11}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿إِذۡ قَالَ لَهُۥ قَوۡمُهُۥ لَا تَفۡرَحۡۖ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٩٢٤٠<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق العوام- في قوله: <span class="qpc-hafs">﴿إن الله لا يحب الفرحين﴾</span>، قال: الفرح هنا: البغي{68}. (١١/٥٠٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٩٢٤١<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- قوله: <span class="qpc-hafs">﴿إذ قال له قومه لا تفرح﴾</span>: أي: لا تمرح{69}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٩٢٤٢<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- في قوله: <span class="qpc-hafs">﴿إذ قال له قومه لا تفرح﴾</span>، قال: هؤلاء المؤمنون منهم، قالوا: يا قارون، لا تفرح بما أُولِيت فتبطر{70}. (١١/٥٠٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٩٢٤٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿اذ قال له قومه﴾</span> بنو إسرائيل: <span class="qpc-hafs">﴿لا تفرح﴾</span> يقول: لا تمرح، ولا تبطر، ولا تفخر بما أُوتيت من الأموال{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٩٢٤٤<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿إذ قال له قومه﴾</span> قال له موسى والمؤمنون بنو إسرائيل: <span class="qpc-hafs">﴿لا تفرح﴾</span> لا تبطر{11}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿إِنَّ ٱللَّهَ لَا یُحِبُّ ٱلۡفَرِحِینَ ۝٧٦﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٩٢٤٥<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- في قوله: <span class="qpc-hafs">﴿إن الله لا يحب الفرحين﴾</span>، قال: المَرِحين{73}. (١١/٥٠٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٩٢٤٦<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿إن الله لا يحب الفرحين﴾</span>، قال: المُتَبَذِّخين، الأشِرِين، البطرين، الذين لا يشكرون الله على ما أعطاهم{74}. (١١/٥٠٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٩٢٤٧<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿إن الله لا يحب الفرحين﴾</span>: أي: إنّ الله لا يحب المرحين{75}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٩٢٤٨<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- في قوله: <span class="qpc-hafs">﴿إن الله لا يحب الفرحين﴾</span>، قال: إنّ الله لا يحب الفرِح بطرًا{76}. (١١/٥٠٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٩٢٤٩<span class="dash">-</span></span> قال <span class="name-2">إسماعيل السُّدِّيّ</span>: و<span class="qpc-hafs">﴿لا تفرح إن الله لا يحب الفرحين﴾</span> المرحين البطرين المشركين{77}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٩٢٥٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ان الله لا يحب الفرحين﴾</span>، يعني: المرحين البطرين{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٩٢٥١<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿إن الله لا يحب الفرحين﴾</span>، أي: الذين يفرحون بالدنيا لا يفرحون بالآخرة، لا يؤمنون بها، ولا يرجونها، وقال في آية أخرى: <span class="qpc-hafs">﴿وفرحوا بالحياة الدنيا﴾</span> [الرعد:٢٦]، وهم المشركون{79}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن أبي شيبة في المصنف ١١/٥٣١-٥٣٢، وابن جرير ١٨/٣٣٤، وابن أبي حاتم ٩/٣٠٠٥-٣٠٠٦، والحاكم ٢/٤٠٨-٤٠٩. وعزاه السيوطي إلى ابن المنذر، وابن مردويه.|2:أخرجه ابن عساكر في تاريخ دمشق ٦١/٩٤. وفي الطبري والدر أنه ابن عمه دون ذكر نسبه.|3:أخرجه ابن جرير ١٨/٣١٠-٣١١، وإسحاق البستي في تفسيره ص٥٦. وعلَّقه ابن أبي حاتم ٩/٣٠٠٥. وعزاه السيوطي إلى الفريابي.|4:علَّقه ابن أبي حاتم ٩/٣٠٠٥.|5:أخرجه ابن أبي حاتم ٩/٣٠٠٥. وعزاه السيوطي إلى عبد بن حميد. وأخرجه ابن جرير ١٨/٣١٠ بلفظ: وكان يسمى: المنوَّرَ؛ من حسن صورته في التوراة....|6:أخرجه ابن جرير ١٨/٣١١.|7:تفسير مقاتل بن سليمان ٣/٣٥٥.|8:عند ابن جرير ١٨/٣٠٩ في الموضعين: موسى بن عرمر. وأورد رواية شيخه أنه: قارون بن يصفر. ثم استدرك عليه فقال: هكذا قال القاسم، وإنما هو يصهر.|9:أخرجه ابن جرير ١٨/٣٠٩. وعزاه السيوطي إلى ابن المنذر.|10:أخرجه ابن جرير ١٨/٣٠٩. وجاء في تفسير الثعلبي ٧/٢٦٠ مختصرًا، وتفسير البغوي ٦/٢٢٠ عنه: كان قارون عم موسى، كان أخا عمران، وهما ابنا يصهر، ولم يكن في بني إسرائيل أقرأ للتوراة من قارون، ولكنه نافق كما نافق السامري.|11:تفسير يحيى بن سلّام ٢/٦٠٨.|12:أخرجه ابن أبي شيبة في المصنف ١١/٥٣١-٥٣٢، وابن جرير ١٨/٣٣٤، وابن أبي حاتم ٩/٣٠٠٥-٣٠٠٦، والحاكم ٢/٤٠٨-٤٠٩. وعزاه السيوطي إلى ابن المنذر، وابن مردويه.|13:أخرجه ابن أبي حاتم ٩/٣٠٠٦. وفي تفسير البغوي ٦/٢٢٠: بغى عليهم بالشرك.|14:أخرجه ابن جرير ١٨/٣١١، وابن أبي حاتم /٣٠٠٦. وعزاه السيوطي إلى ابن أبي شيبة، وعبد بن حميد، وابن المنذر.|15:أخرجه ابن أبي حاتم ٩/٣٠٠٦. وعزاه السيوطي إلى عبد بن حميد.|16:أخرجه ابن جرير ١٨/٣١٢ دون قوله: وولده، وابن أبي حاتم ٩/٣٠٠٦. وعزاه السيوطي إلى عبد بن حميد.|17:تفسير الثعلبي ٧/٢٦٠.|18:تفسير مقاتل بن سليمان ٣/٣٥٥.|19:تفسير يحيى بن سلّام ٢/٦٠٨.|20:عزاه السيوطي إلى ابن مردويه.|21:أخرجه عبد الرزاق -كما في تخريج الكشاف ٣/٣٣-، وابن جرير ١٨/٣٣٥، وابن أبي حاتم ٩/٣٠١٩.|22:أخرجه ابن أبي حاتم ٩/٣٠٠٧.|23:أخرجه ابن أبي حاتم ٩/٣٠٠٧.|24:تفسير مقاتل بن سليمان ٣/٣٥٥.|25:تفسير يحيى بن سلّام ٢/٦٠٨.|26:أخرجه عبد الرزاق ٢/٩٣، وابن جرير ١٨/٣١٣، وإسحاق البستي في تفسيره ص٥٦ من طريق ابن أبي نجيح، وابن أبي حاتم ٩/٣٠٠٧، وعند ابن جرير من طريق ابن جريج: مفاتح مِن جلود كمفاتح العيدان. وعزاه السيوطي إلى عبد بن حميد.|27:تفسير البغوي ٦/٢٢٠.|28:أخرجه ابن جرير ١٨/٣١٤، وابن أبي حاتم ٩/٣٠٠٧.|29:أخرجه ابن جرير ١٨/٣١٣، وابن أبي حاتم ٩/٣٠٠٨.|30:علَّقه ابن أبي حاتم ٩/٣٠٠٨.|31:أخرجه سعيد بن منصور في سننه - التفسير ٧/١٩ (١٦٩٧)، وابن أبي حاتم ٩/٣٠٠٧.|32:تفسير البغوي ٦/٢٢٠.|33:الوِقْر: الحِمْل. النهاية (وقر).|34:أخرجه ابن جرير ١٨/٣١٣، والبغوي ٦/٢٢٠ من طريق منصور. وعزاه السيوطي إلى سعيد بن منصور، وابن المنذر.|35:عزاه السيوطي إلى الفريابي، وابن أبي شيبة، وعبد بن حميد، وابن المنذر. وأخرجه ابن أبي حاتم ٩/٣٠٠٧ من طريق الأعمش بلفظ: سبعين بغلًا أغر محجلًا، وفي رواية أخرى عنده: يحملها أربعون بغلًا غرًا محجلًا.|36:علَّقه ابن أبي حاتم ٩/٣٠٠٧.|37:تفسير مقاتل بن سليمان ٣/٣٥٥.|38:تفسير يحيى بن سلّام ٢/٦٠٨.|39:أخرجه ابن جرير ١٨/٣١٣، وابن أبي حاتم ٩/٣٠٠٨. وعزاه السيوطي إلى ابن المنذر.|40:علَّقه ابن أبي حاتم ٩/٣٠٠٨.|41:عزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.|42:العجِيزة: الألية. القاموس (الإلية).|43:الوَسَق -بالفتح-: ستون صاعًا. النهاية (وسق).|44:أخرجه الطستي -كما في الإتقان ٢/١٠١-. وعزاه السيوطي إلى الطستي في مسائله.|45:أخرجه ابن أبي حاتم ٩/٣٠٠٨.|46:تفسير مقاتل بن سليمان ٣/٣٥٥.|47:تفسير يحيى بن سلّام ٢/٦٠٨.|48:أخرجه ابن جرير ١٨/٣١٥.|49:أخرجه ابن جرير ١٨/٣١٥.|50:أخرجه ابن أبي حاتم ٩/٣٠٠٩.|51:أخرجه عبد الرزاق ٢/٩٣، وابن جرير ١٨/٣١٦، وابن أبي حاتم ٩/٣٠٠٨. كما أخرجه عبد الرزاق وابن جرير كلاهما من طريق ابن جريج بلفظ: العصبة: خمسة عشر رجلًا. وعزاه السيوطي إلى الفريابي، وابن أبي شيبة، وعبد بن حميد، وابن المنذر.|52:أخرجه الحربي في غريب الحديث ١/٣٠٥ مختصرًا، وابن جرير ١٨/٣١٦، وإسحاق البستي في تفسيره ص٥٧ بنحوه.|53:أخرجه الحربي في غريب الحديث ١/٣٠٥.|54:أخرجه ابن أبي حاتم ٩/٣٠٠٨. وعزاه السيوطي إلى عبد بن حميد. وشطره الثاني أخرجه ابن أبي حاتم ٩/٣٠٠٨ من طريق هشيم عن إسماعيل بن سالم.|55:أخرجه ابن جرير ١٨/٣١٥، وإسحاق البستي في تفسيره ص٥٧.|56:أخرجه ابن أبي حاتم ٩/٣٠٠٨.|57:أخرجه ابن جرير ١٨/٣١٥. وعزاه السيوطي إلى عبد بن حميد.|58:أخرجه ابن أبي حاتم ٩/٣٠٠٨. وعلَّقه يحيى بن سلّام ٢/٦٠٨ بلفظ: والعصبة: الجماعة، وهم هاهنا أربعون رجلًا.|59:أخرجه عبد الرزاق ٢/٩٢. وعزاه السيوطي إلى ابن المنذر.|60:تفسير مقاتل بن سليمان ٣/٣٥٥.|61:أخرجه ابن أبي حاتم ٩/٣٠٠٩.|62:علَّقه إسحاق البستي في تفسيره ص٥٦.|63:تفسير يحيى بن سلّام ٢/٦٠٨.|64:أخرجه ابن جرير ١٨/٣١٦، وابن أبي حاتم ٩/٣٠٠٩. وعزاه السيوطي إلى الفريابي، وابن أبي شيبة، وعبد بن حميد، وابن المنذر.|65:علَّقه يحيى بن سلّام ٢/٦٠٨.|66:تفسير مقاتل بن سليمان ٣/٣٥٥.|67:تفسير يحيى بن سلّام ٢/٦٠٨.|68:أخرجه ابن جرير ١٨/٣٢٠-٣٢١، وابن أبي حاتم ٩/٣٠٠٩.|69:أخرجه ابن جرير ١٨/٣٢١، وابن أبي حاتم ٩/٣٠٠٩.|70:أخرجه ابن أبي حاتم ٩/٣٠٠٩. وعلقه يحيى بن سلّام ٢/٦٠٩ مختصرًا بلفظ: يعني: لا تبطر.|71:تفسير مقاتل بن سليمان ٣/٣٥٥.|72:تفسير يحيى بن سلّام ٢/٦٠٨.|73:أخرجه ابن جرير ١٨/٣٢٠، وابن أبي حاتم ٩/٣٠١٠. وعزاه السيوطي إلى ابن المنذر.|74:أخرجه ابن جرير ١٨/٣٢٠ من طُرُق، وابن أبي حاتم ٩/٣٠٠٩، وأخرجه يحيى بن سلّام ٢/٦٠٩ من طريق ابن مجاهد، وابن أبي الدنيا في كتاب الهم والحزن -موسوعة الإمام ابن أبي الدنيا ٣/٢٩١ (١٥٨)- من طريق جابر مختصرًا بلفظ: الأشرين، وإسحاق البستي في تفسيره ص٥٧ من طريق ابن جريج، وفيه: «الممتدحين» بدلًا من «المتبذخين». وعزاه السيوطي إلى الفريابي، وابن أبي شيبة، وعبد بن حميد، وابن المنذر.|75:أخرجه ابن جرير ١٨/٣٢١. وعلَّقه ابن أبي حاتم ٩/٣٠١٠.|76:أخرجه ابن أبي حاتم ٩/٣٠١٠.|77:علَّقه يحيى بن سلّام ٢/٦٠٩. وقال عنه وعن قول مجاهد: وهو واحد.|78:تفسير مقاتل بن سليمان ٣/٣٥٥.|79:تفسير يحيى بن سلّام ٢/٦٠٩.
  28,77,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَٱبۡتَغِ فِیمَاۤ ءَاتَىٰكَ ٱللَّهُ ٱلدَّارَ ٱلۡـَٔاخِرَةَۖ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٩٢٥٢<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- في قوله: <span class="qpc-hafs">﴿وابتغ فيما آتاك الله الدار الآخرة﴾</span>، قال: تَصَدِّق، وقَرِّب لله تعالى، وصِلِ الرحم{1}. (١١/٥٠٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٩٢٥٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿و﴾</span>قالوا له: <span class="qpc-hafs">﴿ابتغ فيما اتاك الله﴾</span> يعني: فيما أعطاك الله ﷿ مِن الأموال والخير <span class="qpc-hafs">﴿الدار الاخرة﴾</span> يعني: دار الجنة{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٩٢٥٤<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿وابتغ فيما آتاك الله﴾</span> مِن هذه النِّعَم والخزائن <span class="qpc-hafs">﴿الدار الآخرة﴾</span> الجنة{3}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَلَا تَنسَ نَصِیبَكَ مِنَ ٱلدُّنۡیَاۖ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٩٢٥٥<span class="dash">-</span></span> قال <span class="name-1">علي بن أبي طالب</span>: لا تنس صِحَّتك، وقُوَّتك، وشبابك، وغِناك؛ أن تطلب بها الآخرة{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٩٢٥٦<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- في قوله: <span class="qpc-hafs">﴿وابتغ فيما آتاك الله الدار الآخرة ولا تنس نصيبك من الدنيا﴾</span>، يقول: لا تترك أن تعمل لله في الدنيا{5}. (١١/٥٠٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٩٢٥٧<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق الأعمش- في قوله: <span class="qpc-hafs">﴿ولا تنس نصيبك من الدنيا﴾</span>، قال: أن تعمل فيها لآخرتك{6}<span class=comment-ref>٤٩٩٢</span>. (١١/٥١٠)</p></p><p></div></p><p><div><span class=comment-ref>٤٩٩٢</span> <span class="comment-type-4">ذكر</span> <u>ابنُ عطية</u> (٦/٦١٢) هذا القول، ثم <span class="comment-type-4">علَّق</span> بقوله: «فالكلام كله -على هذا التأويل- شِدَّة في الموعظة».</div></p><p><div></p><p><p><span class="item-no">٥٩٢٥٨<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span>، في قوله: <span class="qpc-hafs">﴿ولا تنس نصيبك من الدنيا﴾</span>، قال: العمل بطاعة الله نصيبه من الدنيا الذي يُثاب عليه في الآخرة{7}. (١١/٥١٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٩٢٥٩<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق أشعث- في قوله: <span class="qpc-hafs">﴿ولا تنس نصيبك من الدنيا﴾</span>، قال: قدِّم الفضل، وأَمْسِك ما يُبَلِّغك{8}. (١١/٥١٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٩٢٦٠<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق إسرائيل أبي عبد الله-: احبِسْ قوت سنة، وتصدَّق بما بقي{9}. (١١/٥١٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٩٢٦١<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق مُحَرَّر- في قوله تعالى: <span class="qpc-hafs">﴿ولا تنس نصيبك من الدنيا﴾</span>، قال: أمره أن يأخذ قدر قوته، ويَدَع ما سوى ذلك{10}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٩٢٦٢<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق قتادة-: ما أحل اللهُ لك منها فإنّ لك فيه غِنًى وكفاية{11}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٩٢٦٣<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span>، <span class="qpc-hafs">﴿ولا تنس نصيبك من الدنيا﴾</span>، قال: أن تأخذ من الدنيا ما أحلَّ اللهُ لك، فإنّ لك فيه غِنًى وكفاية{12}<span class=comment-ref>٤٩٩٣</span>. (١١/٥١٠)</p></p><p></div></p><p><div><span class=comment-ref>٤٩٩٣</span> <span class="comment-type-4">علَّق</span> <u>ابنُ عطية</u> (٦/٦١٣) على هذا القول الذي قاله الحسن، وقتادة، وابن جريج، فقال: «فالكلام -على هذا التأويل- هو في الرفق به، وإصلاح الأمر الذي يشتهيه، وهذا مما يجب استعماله مع الموعظة خشية النَّبْوة مِن الشِّدة».</div></p><p><div></p><p><p><span class="item-no">٥٩٢٦٤<span class="dash">-</span></span> عن <span class="name-2">عون بن عبد الله بن عتبة بن مسعود</span> -من طريق قُرَّة بن خالد- <span class="qpc-hafs">﴿ولا تنس نصيبك من الدنيا﴾</span>، قال: إنّ قومًا يضعونها على غير موضعها؛ <span class="qpc-hafs">﴿ولا تنس نصيبك من الدنيا﴾</span> تعمل فيها بطاعة الله{13}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٩٢٦٥<span class="dash">-</span></span> عن <span class="name-2">منصور</span> -من طريق مبارك بن سعيد- في قوله: <span class="qpc-hafs">﴿ولا تنس نصيبك من الدنيا﴾</span>، قال: ليس هو عَرَضًا مِن عَرَض الدنيا، ولكن نصيبك عمرك أن تُقَدِّم فيه لآخرتك{14}. (١١/٥١١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٩٢٦٦<span class="dash">-</span></span> قال <span class="name-2">منصور بن زاذان</span> -من طريق خلف بن خليفة- في قوله: <span class="qpc-hafs">﴿ولا تنس نصيبك من الدنيا﴾</span>، قال: قُوتك، وقُوت أهلك{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٩٢٦٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ولا تنس نصيبك﴾</span> يعني: ولا تترك حظَّك <span class="qpc-hafs">﴿من الدنيا﴾</span> أن تعمل فيها لآخرتك{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٩٢٦٨<span class="dash">-</span></span> عن <span class="name-3">عبد الملك ابن جريج</span> -من طريق حجاج- قال: الحلال فيها{17}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٩٢٦٩<span class="dash">-</span></span> عن أشهب، قال: سُئِل <span class="name-3">مالك بن أنس</span>: ما هو؟ قال: أن يعيش ويأكل ويشرب غير مضيق عليه في رأي{18}<span class=comment-ref>٤٩٩٤</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٤٩٩٤</span> <span class="comment-type-4">ذكر</span> <u>ابنُ عطية</u> (٦/٦١٣) أن الثعلبي حكى أنه قيل: أرادوا بنصيبه: الكفن. ثم <span class="comment-type-4">علَّق</span> بقوله: «وهذا وعْظٌ مُتَّصِل، كأنهم قالوا: لا تنس أنك تترك جميع مالك إلا نصيبك الذي هو الكفن».</div></p><p><div></p><p><p><span class="item-no">٥٩٢٧٠<span class="dash">-</span></span> قال <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿ولا تنس نصيبك من الدنيا﴾</span>، قال: لا تنس أن تُقَدِّم مِن دنياك لآخرتك، فإنّما تجد في آخرتك ما قدَّمْت في الدنيا فيما رزقك الله{19}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٩٢٧١<span class="dash">-</span></span> قال يحيى بن سلّام: <span class="qpc-hafs">﴿ولا تنس نصيبك من الدنيا﴾</span>، أي: اعمل في دنياك لآخرتك. في تفسير بعضهم{3}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَأَحۡسِن كَمَاۤ أَحۡسَنَ ٱللَّهُ إِلَیۡكَۖ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٩٢٧٢<span class="dash">-</span></span> عن سلّام بن مسكين، قال: سألتُ <span class="name-2">الحسنَ البصري</span> عن هذه الآية: <span class="qpc-hafs">﴿ولا تنس نصيبك من الدنيا وأحسن كما أحسن الله إليك﴾</span>. قال: أمره أن يأخذ مِن ماله قدر عِيشته، وأن يُقَدِّم ما سوى ذلك لآخرته{18}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٩٢٧٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وأحسن﴾</span> العَطِيَّة في الصدقة والخير فيما يرضي الله ﷿ <span class="qpc-hafs">﴿كما أحسن الله إليك﴾</span>{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٩٢٧٤<span class="dash">-</span></span> قال <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿وأحسن كما أحسن الله إليك﴾</span>، قال: أحسن فيما رزقك الله{23}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٩٢٧٥<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿وأحسن﴾</span> فيما افترض الله عليك <span class="qpc-hafs">﴿كما أحسن الله إليك﴾</span>{3}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَلَا تَبۡغِ ٱلۡفَسَادَ فِی ٱلۡأَرۡضِۖ إِنَّ ٱللَّهَ لَا یُحِبُّ ٱلۡمُفۡسِدِینَ ۝٧٧﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٩٢٧٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ولا تبغ﴾</span> بإحسان الله إليك <span class="qpc-hafs">﴿الفساد في الأرض﴾</span> يقول: لا تعمل فيها بالمعاصي؛ <span class="qpc-hafs">﴿إن الله لا يحب المفسدين﴾</span>{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٩٢٧٧<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿ولا تبغ الفساد في الأرض إن الله لا يحب المفسدين﴾</span> المشركين{3}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن أبي حاتم ٩/٣٠١٠.|2:تفسير مقاتل بن سليمان ٣/٣٥٥.|3:تفسير يحيى بن سلّام ٢/٦٠٩.|4:تفسير الثعلبي ٧/٢٦١، وتفسير البغوي ٦/٢٢١.|5:أخرجه ابن جرير ١٨/٣٢٢، وابن أبي حاتم ٩/٣٠١٠. وعزاه السيوطي إلى ابن المنذر.|6:أخرجه ابن جرير ١٨/٣٢٢، وابن أبي حاتم ٩/٣٠١٠ من طريق الأعمش عن رجل. وعزاه السيوطي إلى الفريابي.|7:أخرجه عبد الرزاق ٢/٩٣ من طريق معمر عن ابن أبي نجيح، وابن جرير ١٨/٣٢٢-٣٢٣ من طريق ابن أبي نجيح وابن جريج وعيسى الجُرشي، وإسحاق البستي في تفسيره ص٥٨ من طريق ابن جريج وابن أبي نجيح مختصرًا، وابن أبي حاتم ٩/٣٠١٠ من طريق ابن أبي نجيح ومنصور. وعزاه السيوطي إلى الفريابي، وعبد بن حميد، وابن المنذر.|8:أخرجه ابن أبي شيبة ١٣/٥٣٠، وابن جرير ١٨/٣٢٤، وابن أبي حاتم ٩/٣٠١١، والبيهقي في شعب الإيمان (٣٣٩٤). وعزاه السيوطي إلى الفريابي، وابن المنذر.|9:أخرجه ابن أبي حاتم ٩/٣٠١١. وعزاه السيوطي إلى الفريابي، وابن المنذر.|10:أخرجه عبد الرزاق ٢/٩٣.|11:أخرجه ابن جرير ١٨/٣٢٤، وابن أبي حاتم ٩/٣٠١١.|12:عزاه السيوطي إلى عبد الرزاق، وعبد بن حميد. وأخرجه ابن جرير ١٨/٣٢٤ من طريق معمر بلفظ: طلب الحلال، وابن أبي حاتم ٩/٣٠١١ من طريق سعيد بلفظ: استغن بما أحل الله لك.|13:أخرجه يحيى بن سلّام ٢/٦٠٩ بلفظ: أي: طاعة ربك وعبادته، وابن جرير ١٨/٣٢٢ واللفظ له، وإسحاق البستي في تفسيره ص٥٨.|14:أخرجه عبد الله بن أحمد في زوائد الزهد ص١٦٧.|15:تفسير الثعلبي ٧/٢٦١، وتفسير البغوي ٦/٢٢١.|16:تفسير مقاتل بن سليمان ٣/٣٥٥.|17:أخرجه ابن جرير ١٨/٣٢٤.|18:أخرجه ابن أبي حاتم ٩/٣٠١١.|19:أخرجه ابن جرير ١٨/٣٢٤، وابن أبي حاتم ٩/٣٠١١ من طريق أصبغ.|20:تفسير يحيى بن سلّام ٢/٦٠٩.|21:أخرجه ابن أبي حاتم ٩/٣٠١١.|22:تفسير مقاتل بن سليمان ٣/٣٥٥.|23:أخرجه ابن جرير ١٨/٣٢٥، وابن أبي حاتم ٩/٣٠١٢ من طريق أصبغ بلفظ: فيما زادك الله.|24:تفسير يحيى بن سلّام ٢/٦٠٩.|25:تفسير مقاتل بن سليمان ٣/٣٥٥.|26:تفسير يحيى بن سلّام ٢/٦٠٩.