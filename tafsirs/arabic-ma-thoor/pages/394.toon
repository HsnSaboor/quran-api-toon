quran[7]{c,v,t}:
28,71," <q>﴿قُلۡ أَرَءَیۡتُمۡ إِن جَعَلَ ٱللَّهُ عَلَیۡكُمُ ٱلَّیۡلَ سَرۡمَدًا إِلَىٰ یَوۡمِ ٱلۡقِیَـٰمَةِ﴾</q> - تفسير ٥٩١٣٠- عن عبد الله بن عباس -من طريق علي- في قوله: <q>﴿إن جعل الله عليكم الليل سرمدا﴾</q>، قال: دائِمًا{1}. (١١/٥٠١) ٥٩١٣١- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿سرمدا﴾</q>، قال: دائِمًا لا ينقطع{2}. (١١/٥٠١) ٥٩١٣٢- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿سرمدا إلى يوم القيامة﴾</q>: أي: دائِمًا إلى يوم القيامة{3}. (١١/٥٠١) ٥٩١٣٣- قال مقاتل بن سليمان: <q>﴿قل﴾</q> يا محمد لكفار مكة: <q>﴿أرأيتم إن جعل الله عليكم الليل سرمدا إلى يوم القيامة﴾</q> فدامتْ ظُلْمَتُه{4}. (ز) ٥٩١٣٤- قال يحيى بن سلّام: <q>﴿سرمدا﴾</q>، أي: دائمًا لا ينقطع{5}. (ز) <q>﴿مَنۡ إِلَـٰهٌ غَیۡرُ ٱللَّهِ یَأۡتِیكُم بِضِیَاۤءٍۚ أَفَلَا تَسۡمَعُونَ ۝٧١﴾</q> - تفسير ٥٩١٣٥- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿من إله غير الله يأتيكم بضياء﴾</q>، قال: بنهار{3}. (١١/٥٠١) ٥٩١٣٦- قال مقاتل بن سليمان: <q>﴿من إله غير الله يأتيكم بضياء﴾</q> يعني: بضوء النهار، <q>﴿أفلا﴾</q> يعني: أفهَلّا <q>﴿تسمعون﴾</q> المواعِظَ{4}. (ز) ٥٩١٣٧- قال يحيى بن سلّام: <q>﴿إلى يوم القيامة من إله غير الله يأتيكم بضياء﴾</q> وهذا على الاستفهام <q>﴿يأتيكم بضياء﴾</q> بنهار، <q>﴿أفلا تسمعون﴾</q>. أمَرَهُ أن يقوله للمشركين{8}. (ز) ",footnotes:1:أخرجه ابن جرير ١٨/٣٠٥، وابن أبي حاتم ٩/٣٠٠٣. وعزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ١٨/٣٠٤، وإسحاق البستي في تفسيره ص٥٥ من طريق ابن جريج، وابن أبي حاتم ٩/٣٠٠٣. وعلَّقه يحيى بن سلام ٢/٦٠٦. وعزاه السيوطي إلى الفريابي، وعبد بن حميد، وابن جرير، وابن المنذر.أخرجه ابن أبي حاتم ٩/٣٠٠٣. وعزاه السيوطي إلى عبد بن حميد.تفسير مقاتل بن سليمان ٣/٣٥٤.تفسير يحيى بن سلام ٢/٦٠٧.أخرجه ابن أبي حاتم ٩/٣٠٠٣. وعزاه السيوطي إلى عبد بن حميد.تفسير مقاتل بن سليمان ٣/٣٥٤.تفسير يحيى بن سلام ٢/٦٠٦.
28,72," <q>﴿قُلۡ أَرَءَیۡتُمۡ إِن جَعَلَ ٱللَّهُ عَلَیۡكُمُ ٱلنَّهَارَ سَرۡمَدًا إِلَىٰ یَوۡمِ ٱلۡقِیَـٰمَةِ مَنۡ إِلَـٰهٌ غَیۡرُ ٱللَّهِ یَأۡتِیكُم بِلَیۡلࣲ تَسۡكُنُونَ فِیهِۚ أَفَلَا تُبۡصِرُونَ ۝٧٢﴾</q> - تفسير ٥٩١٣٨- عن إسماعيل السُّدِّيّ -من طريق أسباط- <q>﴿تسكنون﴾</q>: تقرون{1}. (ز) ٥٩١٣٩- قال مقاتل بن سليمان: و<q>﴿قل﴾</q> لهم: <q>﴿أرأيتم إن جعل الله عليكم النهار سرمدا إلى يوم القيامة من إله غير الله يأتيكم بليل تسكنون فيه﴾</q> مِن النَّصَب، <q>﴿أفلا﴾</q> يعني: أفهَلّا <q>﴿تبصرون﴾</q>{2}. (ز) ٥٩١٤٠- قال يحيى بن سلّام: <q>﴿قل أرأيتم إن جعل الله عليكم النهار سرمدا﴾</q> أي: دائِمًا لا ينقطع <q>﴿إلى يوم القيامة من إله غير الله يأتيكم بليل تسكنون فيه﴾</q> كقوله: <q>﴿وجعل الليل سكنا﴾</q> [الأنعام:٩٦] يسكن فيه الخلق، <q>﴿أفلا تبصرون﴾</q>. أمَرَهُ أن يقوله للمشركين{3}. (ز) ",footnotes:1:أخرجه ابن أبي حاتم ٩/٣٠٠٣.تفسير مقاتل بن سليمان ٣/٣٥٤.تفسير يحيى بن سلام ٢/٦٠٧.
28,73," <q>﴿وَمِن رَّحۡمَتِهِۦ جَعَلَ لَكُمُ ٱلَّیۡلَ وَٱلنَّهَارَ لِتَسۡكُنُوا۟ فِیهِ﴾</q> - تفسير ٥٩١٤١- قال مقاتل بن سليمان: ثم أخبر عن صنعه -تعالى ذِكْرُه-، فقال سبحانه: <q>﴿ومن رحمته جعل لكم الليل والنهار لتسكنوا﴾</q> يعني: لتستقروا <q>﴿فيه﴾</q> بالليل مِن النصَب{1}. (ز) ٥٩١٤٢- عن عبد الملك ابن جُرَيْج، <q>﴿ومن رحمته جعل لكم الليل والنهار لتسكنوا فيه﴾</q>، قال: في الليل{2}. (١١/٥٠١) ٥٩١٤٣- قال يحيى بن سلّام: <q>﴿ومن رحمته جعل لكم الليل والنهار لتسكنوا فيه﴾</q> في الليل{3}٤٩٨٧. (ز) ٤٩٨٧ ذكر ابنُ جرير (١٨/٣٠٦) في الهاء من قوله: <q>﴿لتسكنوا فيه﴾</q> وجهين، فقال: «وفي الهاء التي في قوله: <q>﴿لتسكنوا فيه﴾</q> وجهان: أحدهما: أن تكون من ذكر الليل خاصة، ويضم للنهار مع الابتغاء هاء أخرى. والثاني: أن تكون من ذكر الليل والنهار، فيكون وجه توحيدها -وهي لهما- وجه توحيد العرب في قولهم: إقبالك وإدبارك يؤذيني. لأن الإقبال والإدبار فعل، والفعل يُوَحَّد كثيره وقليله». <q>﴿وَلِتَبۡتَغُوا۟ مِن فَضۡلِهِۦ﴾</q> - تفسير ٥٩١٤٤- عن إسماعيل السُّدِّيّ -من طريق أسباط- <q>﴿ولتبتغوا من فضله﴾</q>: يعني: التجارة{4}. (ز) ٥٩١٤٥- قال مقاتل بن سليمان: <q>﴿ولتبتغوا﴾</q> بالنهار <q>﴿من فضله﴾</q> يعني: الرِّزق{1}. (ز) ٥٩١٤٦- عن عبد الملك ابن جريج: <q>﴿ولتبتغوا من فضله﴾</q> قال: في النهار{2}. (١١/٥٠١) ٥٩١٤٧- قال يحيى بن سلّام: <q>﴿ولتبتغوا من فضله﴾</q> بالنهار، وهذا رحمة مِن الله للمؤمن والكافر، فأمّا المؤمن فتَتِمُّ عليه رحمة الله في الآخرة، وأمّا الكافر فهي رحمة له في الدنيا، وليس له في الآخرة نصيب{3}. (ز) <q>﴿وَلَعَلَّكُمۡ تَشۡكُرُونَ ۝٧٣﴾</q> - تفسير ٥٩١٤٨- قال مقاتل بن سليمان: <q>﴿ولعلكم تشكرون﴾</q> ربَّكم في نِعَمِه، فتُوَحِّدوه ﷿{1}. (ز) ٥٩١٤٩- قال سفيان بن عيينة -من طريق عمر بن عبد الغفار-: على كل مُسْلِمٍ أن يشكر الله؛ لأنّ الله قال: <q>﴿ولعلكم تشكرون﴾</q>{4}. (ز) ٥٩١٥٠- قال يحيى بن سلّام: قال: <q>﴿ولعلكم تشكرون﴾</q> ولكي تشكروا{3}. (ز) ",footnotes:1:تفسير مقاتل بن سليمان ٣/٣٥٤.عزاه السيوطي إلى ابن المنذر.تفسير يحيى بن سلام ٢/٦٠٧.أخرجه ابن أبي حاتم ٩/٣٠٠٣.تفسير مقاتل بن سليمان ٣/٣٥٤.عزاه السيوطي إلى ابن المنذر.تفسير يحيى بن سلام ٢/٦٠٧.تفسير مقاتل بن سليمان ٣/٣٥٤.أخرجه ابن أبي حاتم ٩/٣٠٠٣.تفسير يحيى بن سلام ٢/٦٠٧.
28,74," <q>﴿وَیَوۡمَ یُنَادِیهِمۡ فَیَقُولُ أَیۡنَ شُرَكَاۤءِیَ ٱلَّذِینَ كُنتُمۡ تَزۡعُمُونَ ۝٧٤﴾</q> - تفسير ٥٩١٥١- قال مقاتل بن سليمان: <q>﴿ويوم يناديهم﴾</q> يعني: يسألهم <q>﴿فيقول أين شركائي الذين كنتم تزعمون﴾</q> أي: في الدنيا{1}. (ز) ٥٩١٥٢- قال يحيى بن سلّام: <q>﴿ويوم يناديهم فيقول أين شركائي الذين كنتم تزعمون﴾</q>، وهي مثل الأولى{2}. (ز) ",footnotes:1:تفسير مقاتل بن سليمان ٣/٣٥٥.تفسير يحيى بن سلام ٢/٦٠٧.
28,75," <q>﴿وَنَزَعۡنَا مِن كُلِّ أُمَّةࣲ شَهِیدࣰا﴾</q> - تفسير ٥٩١٥٣- عن مجاهد بن جبر -من طريق أبي نجيح- في قوله: <q>﴿ونزعنا من كل أمة شهيدا﴾</q>، قال: رسولًا{1}٤٩٨٨. (١١/٥٠٢) ٤٩٨٨ ذكر ابنُ عطية (٦/٦٠٨) قول مجاهد، وقولًا آخر عن الرماني: أنّ الشهيد: هم العدول والأخيار من الأمم. ثم علّق بقوله: «وهم حَمَلة الحُجَّة الذين لا يخلو منهم زمان، و»الشهيد«على هذا التأويل، اسم الجنس». ٥٩١٥٤- عن قتادة بن دعامة -من طريق سعيد- <q>﴿ونزعنا من كل أمة شهيدا﴾</q>، قال: شهيدها: نبيها؛ ليشهد عليها أنّه قد بلَّغ رسالاتِ ربه{2}. (١١/٥٠٢) ٥٩١٥٥- قال مقاتل بن سليمان: <q>﴿ونزعنا﴾</q> يقول: وأخرجنا <q>﴿من كل أمة شهيدا﴾</q> يعني: رسولها ونبيَّها، يشهد عليها بالبلاغ والرسالة{3}. (ز) ٥٩١٥٦- قال يحيى بن سلّام: <q>﴿ونزعنا من كل أمة شهيدا﴾</q> جئنا برسولهم. كقوله: <q>﴿فكيف إذا جئنا من كل أمة بشهيد وجئنا بك على هؤلاء شهيدا﴾</q> [النساء:٤١]، وكقوله: <q>﴿يوم ندعو كل أناس بإمامهم﴾</q> [الإسراء:٧١] بنبيِّهم. وقال بعضُهم: بكتابهم{4}. (ز) <q>﴿فَقُلۡنَا هَاتُوا۟ بُرۡهَـٰنَكُمۡ﴾</q> - تفسير ٥٩١٥٧- عن أبي العالية الرِّياحِيِّ -من طريق الربيع- قوله: <q>﴿قل هاتوا برهانكم﴾</q>، أي: حُجَّتكم{5}. (ز) ٥٩١٥٨- عن إسماعيل السُّدِّيّ= (ز) ٥٩١٥٩- والربيع بن أنس، مثل ذلك{6}. (ز) ٥٩١٦٠- عن مجاهد بن جبر -من طريق أبي نجيح- في قوله: <q>﴿فقلنا هاتوا برهانكم﴾</q>، قال: هاتوا حُجَّتكم بما كنتم تعبدون وتقولون{7}. (١١/٥٠٢) ٥٩١٦١- تفسير الحسن البصري: قوله: <q>﴿فقلنا هاتوا برهانكم﴾</q> حجتكم{8}. (ز) ٥٩١٦٢- عن قتادة بن دعامة -من طريق سعيد- <q>﴿فقلنا هاتوا برهانكم﴾</q>، قال: بَيِّنَتكم{9}. (١١/٥٠٢) ٥٩١٦٣- قال مقاتل بن سليمان: <q>﴿فقلنا﴾</q> لهم يعني: للكفار: <q>﴿هاتوا﴾</q> هلموا <q>﴿برهانكم﴾</q> يعني: حجتكم بأنّ معي شريكًا. فلم يكن لهم حجة{3}. (ز) ٥٩١٦٤- قال يحيى بن سلّام: قوله: <q>﴿فقلنا هاتوا برهانكم﴾</q> بأنّ الله أمركم بما كنتم عليه مِن الشِّرك{4}. (ز) <q>﴿فَعَلِمُوۤا۟ أَنَّ ٱلۡحَقَّ لِلَّهِ﴾</q> - تفسير ٥٩١٦٥- تفسير إسماعيل السُّدِّيّ: قوله <q>﴿أن الحق لله﴾</q>، يعني: التوحيد{12}. (ز) ٥٩١٦٦- قال مقاتل بن سليمان: <q>﴿فعلموا أن الحق لله﴾</q>، يعني: التوحيد لله ﷿{3}. (ز) ٥٩١٦٧- قال يحيى بن سلّام: قوله: <q>﴿فعلموا﴾</q> يومئذ{14}. (ز) <q>﴿وَضَلَّ عَنۡهُم مَّا كَانُوا۟ یَفۡتَرُونَ ۝٧٥﴾</q> - تفسير ٥٩١٦٨- عن عبد الله بن عباس -من طريق الضحاك-: <q>﴿وضل عنهم﴾</q> في القيامة <q>﴿ما كانوا يفترون﴾</q> يكذبون في الدنيا{15}. (١١/٥٠٢) ٥٩١٦٩- عن مجاهد بن جبر -من طريق أبي نجيح- في قوله: <q>﴿وضل عنهمما كانوا يفترون﴾</q>: ما كانوا يعبدون ويقولون{16}. (ز) ٥٩١٧٠- قال مقاتل بن سليمان: <q>﴿وضل عنهم﴾</q> في الآخرة <q>﴿ماكانوا يفترون﴾</q> في الدنيا بأنّ مع الله سبحانه شريكًا{3}. (ز) ٥٩١٧١- قال يحيى بن سلّام: <q>﴿وضل عنهم ما كانوا يفترون﴾</q> أوثانهم التي كانوا يعبدونها{14}. (ز) ",footnotes:1:أخرجه ابن جرير ١٨/٣٠٧-٣٠٨، وإسحاق البستي في تفسيره ص٥٥ من طريق ابن جريج، وابن أبي حاتم ٩/٣٠٠٤. وعلَّقه يحيى بن سلام ٢/٦٠٧. وعزاه السيوطي إلى الفريابي، وابن أبي شيبة، وعبد بن حميد، وابن المنذر.أخرجه ابن جرير ١٨/٣٠٧، وابن أبي حاتم ٩/٣٠٠٤. وعزاه السيوطي إلى عبد بن حميد.تفسير مقاتل بن سليمان ٣/٣٥٥.تفسير يحيى بن سلام ٢/٦٠٧.أخرجه ابن أبي حاتم ٩/٣٠٠٤.علقه ابن أبي حاتم ٩/٣٠٠٤.أخرجه ابن جرير ١٨/٣٠٨ بلفظ: حجتكم لما كنتم .... وعلَّقه ابن أبي حاتم ٩/٣٠٠٤. وعزاه السيوطي إلى الفريابي، وابن أبي شيبة، وعبد بن حميد، وابن المنذر.علَّقه يحيى بن سلام ٢/٦٠٧.أخرجه ابن جرير ١٨/٣٠٧-٣٠٨، وابن أبي حاتم ٩/٣٠٠٤. وعلقه يحيى بن سلام ٢/٦٠٨. وعزاه السيوطي إلى عبد بن حميد.تفسير مقاتل بن سليمان ٣/٣٥٥.تفسير يحيى بن سلام ٢/٦٠٧.علَّقه يحيى بن سلام ٢/٦٠٨.تفسير مقاتل بن سليمان ٣/٣٥٥.تفسير يحيى بن سلام ٢/٦٠٨.أخرجه ابن أبي حاتم ٩/٣٠٠٥.تفسير مجاهد ص٥٣١.تفسير مقاتل بن سليمان ٣/٣٥٥.تفسير يحيى بن سلام ٢/٦٠٨.
28,76," <q>﴿إِنَّ قَـٰرُونَ كَانَ مِن قَوۡمِ مُوسَىٰ﴾</q> - تفسير ٥٩١٧٢- عن عبد الله بن عباس -من طريق سعيد بن جبير- <q>﴿إن قارون كان من قوم موسى﴾</q>، قال: كان ابنَ عمِّه{1}. (١١/٥٠٢) ٥٩١٧٣- عن عبد الله بن عباس -من طريق مقاتل بن سليمان، وجويبر، عن الضحاك- أنّه قال في هذه الآية: <q>﴿إن قارون كان من قوم موسى فبغى عليهم﴾</q>: يعني: كان ابنَ عمِّ موسى، وكان قارون بن يصهر بن لاوي{2}. (ز) ٥٩١٧٤- عن إبراهيم النخعي -من طريق سماك- قال: كان قارونُ ابنَ عمِّ موسى{3}. (١١/٥٠٤) ٥٩١٧٥- عن عبد الله بن الحارث بن نوفل= (ز) ٥٩١٧٦- وسماك بن حرب، مثله{4}. (ز) ٥٩١٧٧- عن قتادة بن دعامة -من طريق سعيد- قال: كان قارونُ ابنَ عم موسى أخي أبيه، وكان قطع البحر مع بني إسرائيل، وكان يُسَمّى: النورَ؛ مِن حسن صوته بالتوراة، ولكن عدو الله نافق كما نافق السامريُّ، فأهلكه الله لِبَغْيِه{5}. (١١/٥٠٥) ٥٩١٧٨- عن مالك بن دينار -من طريق جعفر بن سليمان الضبعي- قال: بلغني: أنّ موسى بن عمران كان ابنَ عمِّ قارون{6}. (ز) ٥٩١٧٩- قال مقاتل بن سليمان: <q>﴿إن قارون كان من قوم موسى﴾</q>، يعني: مِن بني إسرائيل، وكان ابنَ عمِّه؛ قارون بن أصهر بن قوهث بن لاوي بن يعقوب، وموسى بن عمران بن قوهث{7}. (ز) ٥٩١٨٠- عن عبد الملك ابن جريج -من طريق حجاج- في قوله: <q>﴿إن قارون كان من قوم موسى﴾</q>، قال: كان ابن عمه أخي أبيه؛ قارون بن يصهر بن قاهث أو قاهب، وموسى بن عرمرم{8} بن قاهث أو قاهب. وعرمرم بالعربية: عِمْران{9}. (١١/٥٠٤) ٥٩١٨١- عن محمد بن إسحاق -من طريق سلمة-: أن يصهر بن قاهث تزوج سميتَ بنت بتاويت بن بركنا بن يقسان بن إبراهيم، فولدت له عمران بن يصهر، وقارون بن يصهر، فنكح عمران يحيب بنت شمويل بن بركنا بن يقسان بن إبراهيم، فولدت له هارون بن عمران، وموسى بن عمران صفيَّ اللهِ ونبيه{10}٤٩٨٩. (ز) ٤٩٨٩ في نسبة قارون لموسى أقوال: الأول: أنه كان ابن عمه. والثاني: أنه كان عمَّ موسى. قاله ابن إسحاق. وذكر ابنُ جرير (١٨/٣١٠) أنّ الأول قول أكثر أهل العلم. وذكر ابنُ عطية (٦/٦٠٨) أنه الأشهر. وذكر ابنُ عطية قولًا ثالثًا بأنّه كان ابن خالته. وساق ابن عطية (٦/٦٠٨-٦٠٩) هذه الأقوال، ثم قال: «فهو بإجماع رجل من بني إسرائيل، كان ممن آمن بموسى، وحفظ التوراة، وكان مِن أقرأ الناس لها، وكان عند موسى ﵇ مِن عُبّاد المؤمنين، ثم إنه لحقه الزهوُ والإعجاب، فبغى على قومه بأنواعٍ مِن البغي». ٥٩١٨٢- قال يحيى بن سلّام: <q>﴿إن قارون كان من قوم موسى﴾</q> كان ابنَ عمِّه أخي أبيه{11}. (ز) <q>﴿فَبَغَىٰ عَلَیۡهِمۡۖ﴾</q> - تفسير ٥٩١٨٣- عن عبد الله بن عباس -من طريق سعيد بن جبير- <q>﴿إن قارون كان من قوم موسى﴾</q>، قال: كان ابنَ عمِّه، وكان يتبع العلم حتى جمع عِلْمًا، فلم يزل في أمره ذلك حتى بغى على موسى وحَسَدَه{1}. (١١/٥٠٢) ٥٩١٨٤- عن الضَّحّاك بن مُزاحِم -من طريق جويبر- في قوله: <q>﴿فبغى عليهم﴾</q>، قال: الكفر بالله{13}. (ز) ٥٩١٨٥- عن شَهْر بن حَوْشَب -من طريق ليث- في قوله: <q>﴿إن قارون كان من قوم موسى فبغى عليهم﴾</q>، قال: زاد عليهم في طول ثيابه شِبرًا{14}. (١١/٥٠٥) ٥٩١٨٦- عن قتادة بن دعامة -من طريق شيبان- في قوله: <q>﴿فبغى عليهم﴾</q>، قال: فَعَلا عليهم{15}. (١١/٥٠٥) ٥٩١٨٧- عن قتادة بن دعامة -من طريق سعيد- قال: إنّما بَغى لكثرة ماله وولده{16}. (١١/٥٠٥) ٥٩١٨٨- عن عطاء الخراساني، في قوله: <q>﴿فبغى عليهم﴾</q>، قال: زاد عليهم في الثياب شِبرًا{17}. (ز) ٥٩١٨٩- قال مقاتل بن سليمان: <q>﴿فبغى عليهم﴾</q>، يقول: بغى قارونُ على بني إسرائيل مِن أجل كنزِه مالَه{7}. (ز) ٥٩١٩٠- قال يحيى بن سلّام: <q>﴿فبغى عليهم﴾</q>، وكان عاملًا لِفرعون، فتعدّى عليهم، وظَلَمهم{11}. (ز) <q>﴿وَءَاتَیۡنَـٰهُ مِنَ ٱلۡكُنُوزِ﴾</q> - تفسير ٥٩١٩١- عن سلمان الفارسي، قال: قال رسول الله ﷺ: «كانت أرضُ دارِ قارون مِن فضة، وأساسُها مِن ذهب»{20}. (١١/٥٠٦) ٥٩١٩٢- عن عبد الله بن الحارث بن نوفل الهاشمي -من طريق علي بن زيد بن جدعان- قال: بلغنا: أنّ قارون أُوتِي مِن الكنوز والمال حتى جعل بابَ دارِه من ذهب، وجعل دارَه كلها مِن صفائح الذهب{21}. (١١/٥١٥) ٥٩١٩٣- عن عطاء الخراساني -من طريق ابنه عثمان- في قوله: <q>﴿وآتيناه من الكنوز﴾</q>، قال: أصاب كنزًا مِن كنوز يوسف{22}. (١١/٥٠٥) ٥٩١٩٤- عن الوليد بن زروان -من طريق موسى بن أعين- في قوله: <q>﴿وآتيناه من الكنوز﴾</q>، قال: كان قارون يعلم الكيمياء{22}. (١١/٥٠٦) ٥٩١٩٥- قال مقاتل بن سليمان: <q>﴿واتيناه﴾</q> يعني: وأعطيناه <q>﴿من الكنوز﴾</q> يعني: مِن الأموال{7}. (ز) ٥٩١٩٦- قال يحيى بن سلّام: <q>﴿وآتيناه﴾</q> يعني: قارون، أي: أعطيناه <q>﴿من الكنوز﴾</q> أي: مِن الأموال{11}. (ز) <q>﴿مَاۤ إِنَّ مَفَاتِحَهُۥ﴾</q> - تفسير ٥٩١٩٧- عن مجاهد بن جبر -من طريق حميد- في الآية، قال: كانت المفاتيحُ مِن جلود الإبل{26}. (١١/٥٠٦) ٥٩١٩٨- قال مجاهد بن جبر: الذي يُفتَح به الباب{27}. (ز) ٥٩١٩٩- عن الضَّحّاك بن مُزاحِم -من طريق أبي حجير- <q>﴿ما إن مفاتحه﴾</q>، قال: أوْعِيَته{28}٤٩٩٠. (ز) ٤٩٩٠ أفادت الآثار أنّ المفاتح إما أن تكون: ما يُفتَح به، وإما الأوعية. وذكر ابنُ عطية (٦/٦٠٩) أنّ الظاهر القول الأول، ووجَّه القول الثاني بقوله: «لأنّ المفتح في كلام العرب: الخزانة». ٥٩٢٠٠- عن أبي صالح باذام -من طريق إسماعيل بن سالم- في قوله: <q>﴿ما إن مفاتحه لتنوء بالعصبة﴾</q>، قال: كانت خزائنه تُحمَل على أربعين بغلًا{29}. (ز) ٥٩٢٠١- عن عبد الله بن عباس= (ز) ٥٩٢٠٢- وقتادة بن دعامة= (ز) ٥٩٢٠٣- والضحاك بن مزاحم، مثل ذلك{30}. (ز) ٥٩٢٠٤- عن حصين بن عبد الرحمن، قال: سألتُ أبا رزين عن قوله: <q>﴿ما إن مفاتحه﴾</q>. قال: خزائنه. وفي لفظ: إن كان مفتاح واحد لكافي أهل الكوفة، إنما يعني: كنوزه{31}. (ز) ٥٩٢٠٥- قال قتادة بن دعامة: الذي يفتح به الباب{27}. (ز) ٥٩٢٠٦- عن خيثمة بن عبد الرحمن بن أبي سبرة -من طريق الأعمش- قال: وجدتُ في الإنجيل: أنّ مفاتيح خزائن قارون كانت وِقْرَ{33} ستين بغلًا غرًّا محجلة، ما يزيد منها مفتاح على إصبع، لكل مفتاح كنز{34}. (١١/٥٠٦) ٥٩٢٠٧- عن خيثمة بن عبد الرحمن بن أبي سبرة، قال: كانت مفاتيحُ كنوز قارون مِن جلود، كل مفتاح مثل الإصبع، كل مفتاح على خزانة على حِدة، فإذا رَكِب حملت المفاتيح على سبعين بغلًا أغر محجلًا{35}٤٩٩١. (١١/٥٠٦) ٤٩٩١ انتقد ابنُ عطية (٦/٦٠٩-٦١٠) ما جاء في وصف مفاتيح قارون مستندًا لدلالة العقل، والقراءة المشهورة، فقال: «ذلك كله ضعيف، والنظر يشهد بفساد هذا، ومَن كان الذي يميز بعضها من بعض، وما الداعي إلى هذا؟! وفي الممكن أن ترجع كلها إلى ما يُحصى ويقدر على حمله بسهولة، وكان يلزم على هذا المعنى أن تكون (مَفاتِيح) بياء وهي قراءة الأعمش والذي يشبه إنما هو أن تكون»المفاتيح«من الحديد ونحوه، وعلى هذا تنوء بالعُصبة إذا كانت كثيرة لكثرة مخازنه، أو تكون المفاتيح: الخزائن». ٥٩٢٠٨- عن إسماعيل السُّدِّيّ، <q>﴿ما إن مفاتحه﴾</q>، قال: خزائنه{36}. (ز) ٥٩٢٠٩- قال مقاتل بن سليمان: <q>﴿ما ان مفاتحه﴾</q>، يعني: خزائنه{7}. (ز) ٥٩٢١٠- قال يحيى بن سلّام: قوله ﷿: <q>﴿ما إن مفاتحه﴾</q>، قال بعضهم: خزائنه، يعني: أمواله. وقال بعضهم: مفاتح خزائنه{11}. (ز) <q>﴿لَتَنُوۤأُ﴾</q> - تفسير ٥٩٢١١- عن عبد الله بن عباس -من طريق علي- في قوله: <q>﴿لتنوء بالعصبة﴾</q>، قال: تُثْقِلُ{39}. (١١/٥٠٦) ٥٩٢١٢- عن أبي صالح= (ز) ٥٩٢١٣- وإسماعيل السُّدِّيّ= (ز) ٥٩٢١٤- وعبد الرحمن بن زيد بن أسلم، مثل ذلك{30}. (ز) ٥٩٢١٥- عن عبد الله بن عباس، في قوله: <q>﴿لتنوء بالعصبة﴾</q>، يقول: لا يرفعها العُصْبَة من الرجال أُولي القُوَّة{41}. (١١/٥٠٧) ٥٩٢١٦- عن عبد الله بن عباس: أنّ نافع بن الأزرق سأله عن قوله: <q>﴿لتنوء بالعصبة﴾</q>. قال: لَتُثْقِلُ. قال: وهل تعرفُ العرب ذلك؟ قال: نعم، أما سمعت قول امرئ القيس: تمشي فتُثْقِلُها عَجِيزَتُها{42} مشي الضعيف يَنُوءُ بالوَسْقِ{43}{44}.(١١/٥٠٧) (١١/٥٠٧) ٥٩٢١٧- عن الربيع بن أنس -من طريق أبي جعفر- قوله: <q>﴿لتنوء بالعصبة﴾</q>، قال: لَتَمُرُّ بالعصبة{45}. (ز) ٥٩٢١٨- قال مقاتل بن سليمان: يقول: لتعجز العصبة أولي القوة عن حمل الخزائن{7}. (ز) ٥٩٢١٩- قال يحيى بن سلّام: <q>﴿لتنوء﴾</q> لَتَثْقُل{11}. (ز) <q>﴿بِٱلۡعُصۡبَةِ﴾</q> - تفسير ٥٩٢٢٠- عن عبد الله بن عباس -من طريق العوفي- قال: <q>﴿بالعصبة﴾</q> أربعون رجلًا{48}. (١١/٥٠٨) ٥٩٢٢١- عن عبد الله بن عباس -من طريق أبي رَوْق، عن الضحاك- <q>﴿لتنوء بالعصبة﴾</q>، قال: العصبة: ما بين ثلاثة إلى العشرة{48}. (ز) ٥٩٢٢٢- عن سعيد بن جبير -من طريق أبي بشر- قال: قلت: كم العصبة؟ قال: ست، أو سبع{50}. (ز) ٥٩٢٢٣- عن مجاهد بن جبر -من طريق ابن أبي نجيح- قال: العصبة: ما بين العشرة إلى الخمسة عشر{51}. (١١/٥٠٧) ٥٩٢٢٤- عن الضَّحّاك بن مُزاحِم -من طريق عبيد- في قوله: <q>﴿لتنوء بالعصبة أولي القوة﴾</q>، قال: يزعمون أنّ العصبة أربعون رجلًا، ينقلون مفاتحه مِن كثرة عددها{52}. (ز) ٥٩٢٢٥- عن عكرمة مولى ابن عباس -من طريق الحكم-: العصبة: أربعون{53}. (ز) ٥٩٢٢٦- عن أبي صالح مولى أم هانئ -من طريق أبي عوانة، عن إسماعيل بن سالم- قال: العصبة: سبعون رجلًا. قال: وكانت خزانته تحمل على أربعين بغلًا{54}. (١١/٥٠٨) ٥٩٢٢٧- عن أبي صالح مولى أُمِّ هانئ -من طريق هشيم، عن إسماعيل بن سالم- قال: العصبة: أربعون{55}. (ز) ٥٩٢٢٨- عن الحكم بن عتيبة -من طريق الحجاج بن أرطأة- <q>﴿لتنوء بالعصبة﴾</q>، قال: العصبة: أربعون رجلًا{45}. (ز) ٥٩٢٢٩- عن قتادة بن دعامة -من طريق سعيد- قال: كُنّا نُحَدَّث: أنّ العصبة: ما فوق العشرة إلى الأربعين{57}. (١١/٥٠٨) ٥٩٢٣٠- عن إسماعيل السُّدِّيّ -من طريق أسباط-: <q>﴿ما إن مفاتحه لتنوء بالعصبة﴾</q>، والعصبة: ما بين العشرة إلى الأربعين{58}. (ز) ٥٩٢٣١- عن محمد بن السائب الكلبي -من طريق معمر- قال: بالعصبة: ما بين الخمس عشرة إلى الأربعين{59}. (١١/٥٠٧) ٥٩٢٣٢- قال مقاتل بن سليمان: <q>﴿لتنوء بالعصبة اولي القوة﴾</q>، والعصبة: مِن عشرة نفر إلى أربعين، فإذا كانوا أربعين فهم أولو قوة، يقول: لتعجز العصبة أولي القوة عن حمل الخزائن{7}. (ز) ٥٩٢٣٣- عن عبد الرحمن بن زيد بن أسلم -من طريق أصبغ بن الفرج - في قوله: <q>﴿لتنوء بالعصبة أولي القوة﴾</q>، قال: العصبة: ما بين الثلاثة إلى تسعة، وهم النفر{50}. (ز) ٥٩٢٣٤- قال سفيان بن عيينة: ويقال: العصبة: أربعون رجلًا{62}. (ز) ٥٩٢٣٥- قال يحيى بن سلّام: <q>﴿بالعصبة﴾</q> الجماعة{11}. (ز) <q>﴿أُو۟لِی ٱلۡقُوَّةِ﴾</q> - تفسير ٥٩٢٣٦- عن مجاهد بن جبر -من طريق ابن أبي نجيح- قال: وأولو القوة: خمسة عشر{64}. (١١/٥٠٧) ٥٩٢٣٧- قال إسماعيل السُّدِّيّ: <q>﴿أولي القوة﴾</q>، يعني: أولي الشدة ... وهم هاهنا أربعون رجلًا{65}. (ز) ٥٩٢٣٨- قال مقاتل بن سليمان: فإذا كانوا أربعين فهم أولو قوة{7}. (ز) ٥٩٢٣٩- قال يحيى بن سلّام: <q>﴿أولي القوة﴾</q> من الرجال{11}. (ز) <q>﴿إِذۡ قَالَ لَهُۥ قَوۡمُهُۥ لَا تَفۡرَحۡۖ﴾</q> - تفسير ٥٩٢٤٠- عن مجاهد بن جبر -من طريق العوام- في قوله: <q>﴿إن الله لا يحب الفرحين﴾</q>، قال: الفرح هنا: البغي{68}. (١١/٥٠٩) ٥٩٢٤١- عن قتادة بن دعامة -من طريق سعيد- قوله: <q>﴿إذ قال له قومه لا تفرح﴾</q>: أي: لا تمرح{69}. (ز) ٥٩٢٤٢- عن إسماعيل السُّدِّيّ -من طريق أسباط- في قوله: <q>﴿إذ قال له قومه لا تفرح﴾</q>، قال: هؤلاء المؤمنون منهم، قالوا: يا قارون، لا تفرح بما أُولِيت فتبطر{70}. (١١/٥٠٨) ٥٩٢٤٣- قال مقاتل بن سليمان: <q>﴿اذ قال له قومه﴾</q> بنو إسرائيل: <q>﴿لا تفرح﴾</q> يقول: لا تمرح، ولا تبطر، ولا تفخر بما أُوتيت من الأموال{7}. (ز) ٥٩٢٤٤- قال يحيى بن سلّام: <q>﴿إذ قال له قومه﴾</q> قال له موسى والمؤمنون بنو إسرائيل: <q>﴿لا تفرح﴾</q> لا تبطر{11}. (ز) <q>﴿إِنَّ ٱللَّهَ لَا یُحِبُّ ٱلۡفَرِحِینَ ۝٧٦﴾</q> - تفسير ٥٩٢٤٥- عن عبد الله بن عباس -من طريق علي- في قوله: <q>﴿إن الله لا يحب الفرحين﴾</q>، قال: المَرِحين{73}. (١١/٥٠٩) ٥٩٢٤٦- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿إن الله لا يحب الفرحين﴾</q>، قال: المُتَبَذِّخين، الأشِرِين، البطرين، الذين لا يشكرون الله على ما أعطاهم{74}. (١١/٥٠٨) ٥٩٢٤٧- عن قتادة بن دعامة -من طريق سعيد- <q>﴿إن الله لا يحب الفرحين﴾</q>: أي: إنّ الله لا يحب المرحين{75}. (ز) ٥٩٢٤٨- عن إسماعيل السُّدِّيّ -من طريق أسباط- في قوله: <q>﴿إن الله لا يحب الفرحين﴾</q>، قال: إنّ الله لا يحب الفرِح بطرًا{76}. (١١/٥٠٩) ٥٩٢٤٩- قال إسماعيل السُّدِّيّ: و<q>﴿لا تفرح إن الله لا يحب الفرحين﴾</q> المرحين البطرين المشركين{77}. (ز) ٥٩٢٥٠- قال مقاتل بن سليمان: <q>﴿ان الله لا يحب الفرحين﴾</q>، يعني: المرحين البطرين{7}. (ز) ٥٩٢٥١- قال يحيى بن سلّام: <q>﴿إن الله لا يحب الفرحين﴾</q>، أي: الذين يفرحون بالدنيا لا يفرحون بالآخرة، لا يؤمنون بها، ولا يرجونها، وقال في آية أخرى: <q>﴿وفرحوا بالحياة الدنيا﴾</q> [الرعد:٢٦]، وهم المشركون{79}. (ز) ",footnotes:1:أخرجه ابن أبي شيبة في المصنف ١١/٥٣١-٥٣٢، وابن جرير ١٨/٣٣٤، وابن أبي حاتم ٩/٣٠٠٥-٣٠٠٦، والحاكم ٢/٤٠٨-٤٠٩. وعزاه السيوطي إلى ابن المنذر، وابن مردويه.أخرجه ابن عساكر في تاريخ دمشق ٦١/٩٤. وفي الطبري والدر أنه ابن عمه دون ذكر نسبه.أخرجه ابن جرير ١٨/٣١٠-٣١١، وإسحاق البستي في تفسيره ص٥٦. وعلَّقه ابن أبي حاتم ٩/٣٠٠٥. وعزاه السيوطي إلى الفريابي.علَّقه ابن أبي حاتم ٩/٣٠٠٥.أخرجه ابن أبي حاتم ٩/٣٠٠٥. وعزاه السيوطي إلى عبد بن حميد. وأخرجه ابن جرير ١٨/٣١٠ بلفظ: وكان يسمى: المنوَّرَ؛ من حسن صورته في التوراة....أخرجه ابن جرير ١٨/٣١١.تفسير مقاتل بن سليمان ٣/٣٥٥.عند ابن جرير ١٨/٣٠٩ في الموضعين: موسى بن عرمر. وأورد رواية شيخه أنه: قارون بن يصفر. ثم استدرك عليه فقال: هكذا قال القاسم، وإنما هو يصهر.أخرجه ابن جرير ١٨/٣٠٩. وعزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ١٨/٣٠٩. وجاء في تفسير الثعلبي ٧/٢٦٠ مختصرًا، وتفسير البغوي ٦/٢٢٠ عنه: كان قارون عم موسى، كان أخا عمران، وهما ابنا يصهر، ولم يكن في بني إسرائيل أقرأ للتوراة من قارون، ولكنه نافق كما نافق السامري.تفسير يحيى بن سلّام ٢/٦٠٨.أخرجه ابن أبي شيبة في المصنف ١١/٥٣١-٥٣٢، وابن جرير ١٨/٣٣٤، وابن أبي حاتم ٩/٣٠٠٥-٣٠٠٦، والحاكم ٢/٤٠٨-٤٠٩. وعزاه السيوطي إلى ابن المنذر، وابن مردويه.أخرجه ابن أبي حاتم ٩/٣٠٠٦. وفي تفسير البغوي ٦/٢٢٠: بغى عليهم بالشرك.أخرجه ابن جرير ١٨/٣١١، وابن أبي حاتم /٣٠٠٦. وعزاه السيوطي إلى ابن أبي شيبة، وعبد بن حميد، وابن المنذر.أخرجه ابن أبي حاتم ٩/٣٠٠٦. وعزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ١٨/٣١٢ دون قوله: وولده، وابن أبي حاتم ٩/٣٠٠٦. وعزاه السيوطي إلى عبد بن حميد.تفسير الثعلبي ٧/٢٦٠.تفسير مقاتل بن سليمان ٣/٣٥٥.تفسير يحيى بن سلّام ٢/٦٠٨.عزاه السيوطي إلى ابن مردويه.أخرجه عبد الرزاق -كما في تخريج الكشاف ٣/٣٣-، وابن جرير ١٨/٣٣٥، وابن أبي حاتم ٩/٣٠١٩.أخرجه ابن أبي حاتم ٩/٣٠٠٧.أخرجه ابن أبي حاتم ٩/٣٠٠٧.تفسير مقاتل بن سليمان ٣/٣٥٥.تفسير يحيى بن سلّام ٢/٦٠٨.أخرجه عبد الرزاق ٢/٩٣، وابن جرير ١٨/٣١٣، وإسحاق البستي في تفسيره ص٥٦ من طريق ابن أبي نجيح، وابن أبي حاتم ٩/٣٠٠٧، وعند ابن جرير من طريق ابن جريج: مفاتح مِن جلود كمفاتح العيدان. وعزاه السيوطي إلى عبد بن حميد.تفسير البغوي ٦/٢٢٠.أخرجه ابن جرير ١٨/٣١٤، وابن أبي حاتم ٩/٣٠٠٧.أخرجه ابن جرير ١٨/٣١٣، وابن أبي حاتم ٩/٣٠٠٨.علَّقه ابن أبي حاتم ٩/٣٠٠٨.أخرجه سعيد بن منصور في سننه - التفسير ٧/١٩ (١٦٩٧)، وابن أبي حاتم ٩/٣٠٠٧.تفسير البغوي ٦/٢٢٠.الوِقْر: الحِمْل. النهاية (وقر).أخرجه ابن جرير ١٨/٣١٣، والبغوي ٦/٢٢٠ من طريق منصور. وعزاه السيوطي إلى سعيد بن منصور، وابن المنذر.عزاه السيوطي إلى الفريابي، وابن أبي شيبة، وعبد بن حميد، وابن المنذر. وأخرجه ابن أبي حاتم ٩/٣٠٠٧ من طريق الأعمش بلفظ: سبعين بغلًا أغر محجلًا، وفي رواية أخرى عنده: يحملها أربعون بغلًا غرًا محجلًا.علَّقه ابن أبي حاتم ٩/٣٠٠٧.تفسير مقاتل بن سليمان ٣/٣٥٥.تفسير يحيى بن سلّام ٢/٦٠٨.أخرجه ابن جرير ١٨/٣١٣، وابن أبي حاتم ٩/٣٠٠٨. وعزاه السيوطي إلى ابن المنذر.علَّقه ابن أبي حاتم ٩/٣٠٠٨.عزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.العجِيزة: الألية. القاموس (الإلية).الوَسَق -بالفتح-: ستون صاعًا. النهاية (وسق).أخرجه الطستي -كما في الإتقان ٢/١٠١-. وعزاه السيوطي إلى الطستي في مسائله.أخرجه ابن أبي حاتم ٩/٣٠٠٨.تفسير مقاتل بن سليمان ٣/٣٥٥.تفسير يحيى بن سلّام ٢/٦٠٨.أخرجه ابن جرير ١٨/٣١٥.أخرجه ابن جرير ١٨/٣١٥.أخرجه ابن أبي حاتم ٩/٣٠٠٩.أخرجه عبد الرزاق ٢/٩٣، وابن جرير ١٨/٣١٦، وابن أبي حاتم ٩/٣٠٠٨. كما أخرجه عبد الرزاق وابن جرير كلاهما من طريق ابن جريج بلفظ: العصبة: خمسة عشر رجلًا. وعزاه السيوطي إلى الفريابي، وابن أبي شيبة، وعبد بن حميد، وابن المنذر.أخرجه الحربي في غريب الحديث ١/٣٠٥ مختصرًا، وابن جرير ١٨/٣١٦، وإسحاق البستي في تفسيره ص٥٧ بنحوه.أخرجه الحربي في غريب الحديث ١/٣٠٥.أخرجه ابن أبي حاتم ٩/٣٠٠٨. وعزاه السيوطي إلى عبد بن حميد. وشطره الثاني أخرجه ابن أبي حاتم ٩/٣٠٠٨ من طريق هشيم عن إسماعيل بن سالم.أخرجه ابن جرير ١٨/٣١٥، وإسحاق البستي في تفسيره ص٥٧.أخرجه ابن أبي حاتم ٩/٣٠٠٨.أخرجه ابن جرير ١٨/٣١٥. وعزاه السيوطي إلى عبد بن حميد.أخرجه ابن أبي حاتم ٩/٣٠٠٨. وعلَّقه يحيى بن سلّام ٢/٦٠٨ بلفظ: والعصبة: الجماعة، وهم هاهنا أربعون رجلًا.أخرجه عبد الرزاق ٢/٩٢. وعزاه السيوطي إلى ابن المنذر.تفسير مقاتل بن سليمان ٣/٣٥٥.أخرجه ابن أبي حاتم ٩/٣٠٠٩.علَّقه إسحاق البستي في تفسيره ص٥٦.تفسير يحيى بن سلّام ٢/٦٠٨.أخرجه ابن جرير ١٨/٣١٦، وابن أبي حاتم ٩/٣٠٠٩. وعزاه السيوطي إلى الفريابي، وابن أبي شيبة، وعبد بن حميد، وابن المنذر.علَّقه يحيى بن سلّام ٢/٦٠٨.تفسير مقاتل بن سليمان ٣/٣٥٥.تفسير يحيى بن سلّام ٢/٦٠٨.أخرجه ابن جرير ١٨/٣٢٠-٣٢١، وابن أبي حاتم ٩/٣٠٠٩.أخرجه ابن جرير ١٨/٣٢١، وابن أبي حاتم ٩/٣٠٠٩.أخرجه ابن أبي حاتم ٩/٣٠٠٩. وعلقه يحيى بن سلّام ٢/٦٠٩ مختصرًا بلفظ: يعني: لا تبطر.تفسير مقاتل بن سليمان ٣/٣٥٥.تفسير يحيى بن سلّام ٢/٦٠٨.أخرجه ابن جرير ١٨/٣٢٠، وابن أبي حاتم ٩/٣٠١٠. وعزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ١٨/٣٢٠ من طُرُق، وابن أبي حاتم ٩/٣٠٠٩، وأخرجه يحيى بن سلّام ٢/٦٠٩ من طريق ابن مجاهد، وابن أبي الدنيا في كتاب الهم والحزن -موسوعة الإمام ابن أبي الدنيا ٣/٢٩١ (١٥٨)- من طريق جابر مختصرًا بلفظ: الأشرين، وإسحاق البستي في تفسيره ص٥٧ من طريق ابن جريج، وفيه: «الممتدحين» بدلًا من «المتبذخين». وعزاه السيوطي إلى الفريابي، وابن أبي شيبة، وعبد بن حميد، وابن المنذر.أخرجه ابن جرير ١٨/٣٢١. وعلَّقه ابن أبي حاتم ٩/٣٠١٠.أخرجه ابن أبي حاتم ٩/٣٠١٠.علَّقه يحيى بن سلّام ٢/٦٠٩. وقال عنه وعن قول مجاهد: وهو واحد.تفسير مقاتل بن سليمان ٣/٣٥٥.تفسير يحيى بن سلّام ٢/٦٠٩.
28,77," <q>﴿وَٱبۡتَغِ فِیمَاۤ ءَاتَىٰكَ ٱللَّهُ ٱلدَّارَ ٱلۡـَٔاخِرَةَۖ﴾</q> - تفسير ٥٩٢٥٢- عن إسماعيل السُّدِّيّ -من طريق أسباط- في قوله: <q>﴿وابتغ فيما آتاك الله الدار الآخرة﴾</q>، قال: تَصَدِّق، وقَرِّب لله تعالى، وصِلِ الرحم{1}. (١١/٥٠٩) ٥٩٢٥٣- قال مقاتل بن سليمان: <q>﴿و﴾</q>قالوا له: <q>﴿ابتغ فيما اتاك الله﴾</q> يعني: فيما أعطاك الله ﷿ مِن الأموال والخير <q>﴿الدار الاخرة﴾</q> يعني: دار الجنة{2}. (ز) ٥٩٢٥٤- قال يحيى بن سلّام: <q>﴿وابتغ فيما آتاك الله﴾</q> مِن هذه النِّعَم والخزائن <q>﴿الدار الآخرة﴾</q> الجنة{3}. (ز) <q>﴿وَلَا تَنسَ نَصِیبَكَ مِنَ ٱلدُّنۡیَاۖ﴾</q> - تفسير ٥٩٢٥٥- قال علي بن أبي طالب: لا تنس صِحَّتك، وقُوَّتك، وشبابك، وغِناك؛ أن تطلب بها الآخرة{4}. (ز) ٥٩٢٥٦- عن عبد الله بن عباس -من طريق علي- في قوله: <q>﴿وابتغ فيما آتاك الله الدار الآخرة ولا تنس نصيبك من الدنيا﴾</q>، يقول: لا تترك أن تعمل لله في الدنيا{5}. (١١/٥٠٩) ٥٩٢٥٧- عن عبد الله بن عباس -من طريق الأعمش- في قوله: <q>﴿ولا تنس نصيبك من الدنيا﴾</q>، قال: أن تعمل فيها لآخرتك{6}٤٩٩٢. (١١/٥١٠) ٤٩٩٢ ذكر ابنُ عطية (٦/٦١٢) هذا القول، ثم علَّق بقوله: «فالكلام كله -على هذا التأويل- شِدَّة في الموعظة». ٥٩٢٥٨- عن مجاهد بن جبر، في قوله: <q>﴿ولا تنس نصيبك من الدنيا﴾</q>، قال: العمل بطاعة الله نصيبه من الدنيا الذي يُثاب عليه في الآخرة{7}. (١١/٥١٠) ٥٩٢٥٩- عن الحسن البصري -من طريق أشعث- في قوله: <q>﴿ولا تنس نصيبك من الدنيا﴾</q>، قال: قدِّم الفضل، وأَمْسِك ما يُبَلِّغك{8}. (١١/٥١٠) ٥٩٢٦٠- عن الحسن البصري -من طريق إسرائيل أبي عبد الله-: احبِسْ قوت سنة، وتصدَّق بما بقي{9}. (١١/٥١٠) ٥٩٢٦١- عن الحسن البصري -من طريق مُحَرَّر- في قوله تعالى: <q>﴿ولا تنس نصيبك من الدنيا﴾</q>، قال: أمره أن يأخذ قدر قوته، ويَدَع ما سوى ذلك{10}. (ز) ٥٩٢٦٢- عن الحسن البصري -من طريق قتادة-: ما أحل اللهُ لك منها فإنّ لك فيه غِنًى وكفاية{11}. (ز) ٥٩٢٦٣- عن قتادة بن دعامة، <q>﴿ولا تنس نصيبك من الدنيا﴾</q>، قال: أن تأخذ من الدنيا ما أحلَّ اللهُ لك، فإنّ لك فيه غِنًى وكفاية{12}٤٩٩٣. (١١/٥١٠) ٤٩٩٣ علَّق ابنُ عطية (٦/٦١٣) على هذا القول الذي قاله الحسن، وقتادة، وابن جريج، فقال: «فالكلام -على هذا التأويل- هو في الرفق به، وإصلاح الأمر الذي يشتهيه، وهذا مما يجب استعماله مع الموعظة خشية النَّبْوة مِن الشِّدة». ٥٩٢٦٤- عن عون بن عبد الله بن عتبة بن مسعود -من طريق قُرَّة بن خالد- <q>﴿ولا تنس نصيبك من الدنيا﴾</q>، قال: إنّ قومًا يضعونها على غير موضعها؛ <q>﴿ولا تنس نصيبك من الدنيا﴾</q> تعمل فيها بطاعة الله{13}. (ز) ٥٩٢٦٥- عن منصور -من طريق مبارك بن سعيد- في قوله: <q>﴿ولا تنس نصيبك من الدنيا﴾</q>، قال: ليس هو عَرَضًا مِن عَرَض الدنيا، ولكن نصيبك عمرك أن تُقَدِّم فيه لآخرتك{14}. (١١/٥١١) ٥٩٢٦٦- قال منصور بن زاذان -من طريق خلف بن خليفة- في قوله: <q>﴿ولا تنس نصيبك من الدنيا﴾</q>، قال: قُوتك، وقُوت أهلك{4}. (ز) ٥٩٢٦٧- قال مقاتل بن سليمان: <q>﴿ولا تنس نصيبك﴾</q> يعني: ولا تترك حظَّك <q>﴿من الدنيا﴾</q> أن تعمل فيها لآخرتك{2}. (ز) ٥٩٢٦٨- عن عبد الملك ابن جريج -من طريق حجاج- قال: الحلال فيها{17}. (ز) ٥٩٢٦٩- عن أشهب، قال: سُئِل مالك بن أنس: ما هو؟ قال: أن يعيش ويأكل ويشرب غير مضيق عليه في رأي{18}٤٩٩٤. (ز) ٤٩٩٤ ذكر ابنُ عطية (٦/٦١٣) أن الثعلبي حكى أنه قيل: أرادوا بنصيبه: الكفن. ثم علَّق بقوله: «وهذا وعْظٌ مُتَّصِل، كأنهم قالوا: لا تنس أنك تترك جميع مالك إلا نصيبك الذي هو الكفن». ٥٩٢٧٠- قال عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿ولا تنس نصيبك من الدنيا﴾</q>، قال: لا تنس أن تُقَدِّم مِن دنياك لآخرتك، فإنّما تجد في آخرتك ما قدَّمْت في الدنيا فيما رزقك الله{19}. (ز) ٥٩٢٧١- قال يحيى بن سلّام: <q>﴿ولا تنس نصيبك من الدنيا﴾</q>، أي: اعمل في دنياك لآخرتك. في تفسير بعضهم{3}. (ز) <q>﴿وَأَحۡسِن كَمَاۤ أَحۡسَنَ ٱللَّهُ إِلَیۡكَۖ﴾</q> - تفسير ٥٩٢٧٢- عن سلّام بن مسكين، قال: سألتُ الحسنَ البصري عن هذه الآية: <q>﴿ولا تنس نصيبك من الدنيا وأحسن كما أحسن الله إليك﴾</q>. قال: أمره أن يأخذ مِن ماله قدر عِيشته، وأن يُقَدِّم ما سوى ذلك لآخرته{18}. (ز) ٥٩٢٧٣- قال مقاتل بن سليمان: <q>﴿وأحسن﴾</q> العَطِيَّة في الصدقة والخير فيما يرضي الله ﷿ <q>﴿كما أحسن الله إليك﴾</q>{2}. (ز) ٥٩٢٧٤- قال عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿وأحسن كما أحسن الله إليك﴾</q>، قال: أحسن فيما رزقك الله{23}. (ز) ٥٩٢٧٥- قال يحيى بن سلّام: <q>﴿وأحسن﴾</q> فيما افترض الله عليك <q>﴿كما أحسن الله إليك﴾</q>{3}. (ز) <q>﴿وَلَا تَبۡغِ ٱلۡفَسَادَ فِی ٱلۡأَرۡضِۖ إِنَّ ٱللَّهَ لَا یُحِبُّ ٱلۡمُفۡسِدِینَ ۝٧٧﴾</q> - تفسير ٥٩٢٧٦- قال مقاتل بن سليمان: <q>﴿ولا تبغ﴾</q> بإحسان الله إليك <q>﴿الفساد في الأرض﴾</q> يقول: لا تعمل فيها بالمعاصي؛ <q>﴿إن الله لا يحب المفسدين﴾</q>{2}. (ز) ٥٩٢٧٧- قال يحيى بن سلّام: <q>﴿ولا تبغ الفساد في الأرض إن الله لا يحب المفسدين﴾</q> المشركين{3}. (ز) ",footnotes:1:أخرجه ابن أبي حاتم ٩/٣٠١٠.تفسير مقاتل بن سليمان ٣/٣٥٥.تفسير يحيى بن سلّام ٢/٦٠٩.تفسير الثعلبي ٧/٢٦١، وتفسير البغوي ٦/٢٢١.أخرجه ابن جرير ١٨/٣٢٢، وابن أبي حاتم ٩/٣٠١٠. وعزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ١٨/٣٢٢، وابن أبي حاتم ٩/٣٠١٠ من طريق الأعمش عن رجل. وعزاه السيوطي إلى الفريابي.أخرجه عبد الرزاق ٢/٩٣ من طريق معمر عن ابن أبي نجيح، وابن جرير ١٨/٣٢٢-٣٢٣ من طريق ابن أبي نجيح وابن جريج وعيسى الجُرشي، وإسحاق البستي في تفسيره ص٥٨ من طريق ابن جريج وابن أبي نجيح مختصرًا، وابن أبي حاتم ٩/٣٠١٠ من طريق ابن أبي نجيح ومنصور. وعزاه السيوطي إلى الفريابي، وعبد بن حميد، وابن المنذر.أخرجه ابن أبي شيبة ١٣/٥٣٠، وابن جرير ١٨/٣٢٤، وابن أبي حاتم ٩/٣٠١١، والبيهقي في شعب الإيمان (٣٣٩٤). وعزاه السيوطي إلى الفريابي، وابن المنذر.أخرجه ابن أبي حاتم ٩/٣٠١١. وعزاه السيوطي إلى الفريابي، وابن المنذر.أخرجه عبد الرزاق ٢/٩٣.أخرجه ابن جرير ١٨/٣٢٤، وابن أبي حاتم ٩/٣٠١١.عزاه السيوطي إلى عبد الرزاق، وعبد بن حميد. وأخرجه ابن جرير ١٨/٣٢٤ من طريق معمر بلفظ: طلب الحلال، وابن أبي حاتم ٩/٣٠١١ من طريق سعيد بلفظ: استغن بما أحل الله لك.أخرجه يحيى بن سلّام ٢/٦٠٩ بلفظ: أي: طاعة ربك وعبادته، وابن جرير ١٨/٣٢٢ واللفظ له، وإسحاق البستي في تفسيره ص٥٨.أخرجه عبد الله بن أحمد في زوائد الزهد ص١٦٧.تفسير الثعلبي ٧/٢٦١، وتفسير البغوي ٦/٢٢١.تفسير مقاتل بن سليمان ٣/٣٥٥.أخرجه ابن جرير ١٨/٣٢٤.أخرجه ابن أبي حاتم ٩/٣٠١١.أخرجه ابن جرير ١٨/٣٢٤، وابن أبي حاتم ٩/٣٠١١ من طريق أصبغ.تفسير يحيى بن سلّام ٢/٦٠٩.أخرجه ابن أبي حاتم ٩/٣٠١١.تفسير مقاتل بن سليمان ٣/٣٥٥.أخرجه ابن جرير ١٨/٣٢٥، وابن أبي حاتم ٩/٣٠١٢ من طريق أصبغ بلفظ: فيما زادك الله.تفسير يحيى بن سلّام ٢/٦٠٩.تفسير مقاتل بن سليمان ٣/٣٥٥.تفسير يحيى بن سلّام ٢/٦٠٩.
