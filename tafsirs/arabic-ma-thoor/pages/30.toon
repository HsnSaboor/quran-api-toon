: كان صدوقًا، لكنَّه كان يهم».أخرجه ابن أبي شيبة ٤/١، وابن جرير ٣/٤١٩، وابن أبي حاتم ١/٣٤٢، والبيهقي ٥/٢٥. وعزاه السيوطي إلى عبد الرزاق، وعبد بن حميد.أخرجه مالك ١/٤٢٦، والشافعي في الأم ٢/٢٠٧، وابن أبي حاتم ١/٣٤٢ (١٨٠١).أخرجه مالك ١/٤٢٦.علَّقه ابن أبي حاتم ١/٣٤٢ (عَقِب ١٨٠٢).أخرجه ابن جرير ٣/٤٢٠.أخرجه ابن جرير ٣/٤٢٣.عزاه السيوطي إلى ابن المنذر.أخرجه ابن أبي شيبة ٤/٣، وابن جرير ٣/٤٢٠، كما أخرج يحيى بن سلام -كما في تفسير ابن أبي زمنين ١/٢٠٨- نحوه، وعبد الرزاق ١/٧٧ كلاهما من طريق سالم. وعزاه السيوطي إلى وكيع، وعبد بن حميد، وابن المنذر.أخرجه ابن أبي شيبة ٤/١-٣.أخرجه ابن أبي شيبة ٤/٣، وابن جرير ٣/٤٢٥، وابن أبي حاتم ١/٣٤٢ (١٨٠٣).أخرجه سعيد بن منصور في سننه (تفسير - ٣٢٢)، وابن جرير ٣/٤٢١، كما أخرج ابن أبي شيبة ٤/٢ نحوه من طريق حبيب.أخرجه ابن جرير ٣/٤٢٠. وعلَّقه ابن أبي حاتم ١/٣٤٢ (عَقِب ١٨٠٣).أخرجه ابن جرير ٣/٤٢٥.أخرجه ابن جرير ٣/٤٢٠، ٤٢٣. وعلَّقه ابن أبي حاتم ١/٣٤٢ (عَقِب ١٨٠٠).أخرجه ابن أبي شيبة ٤/٣، وابن جرير ٣/٤٢٣. وكلام مجاهد في تفسيره ص٢٢٧ من طريق ابن أبي نجيح.أخرجه ابن جرير ٣/٤٢١.أخرجه ابن أبي حاتم ١/٣٤٣ (١٨٠٤).أخرجه عبد الرزاق ١/٧٦. وعلَّقه ابن أبي حاتم ١/٣٤٢ (عَقِب ١٨٠٢).أخرجه ابن أبي شيبة في مصنفه (ت: محمد عوامة) ٨/٦٣٥ (١٥٣٨٧)، وابن جرير ٣/٤٢٢، وابن أبي حاتم ١/٣٤٢ (عَقِب ١٨٠٠).علَّقه ابن أبي حاتم ١/٣٤٢ (عَقِب ١٨٠٠)، وهو ساقط من المطبوعة، واستُدرِك من الرسالة المحققة المرقومة بالآلة الكاتبة ص٤٧٢.أخرجه ابن جرير ٣/٤٢٠، وعلَّقه ابن أبي حاتم ١/٣٤٢ (عَقِب ١٨٠٠)، وهو ساقط من المطبوعة، واستدركته من الرسالة المحققة المرقومة بالآلة الكاتبة ص٤٧٢.أخرجه ابن جرير ٣/٤٢٠. وعلَّقه ابن أبي حاتم ١/٣٤٢ (عَقِب ١٨٠٠).أخرجه ابن جرير ٣/٤٢١.أخرجه ابن جرير ٣/٤٢٤. وعلَّقه ابن أبي حاتم ١/٣٤٢ (عَقِب ١٨٠٠).أخرجه ابن جرير ٣/٤٢٢.أخرجه ابن جرير ٣/٤٢٢.أخرجه ابن جرير ٣/٤٢٣، وابن أبي حاتم ١/٣٤٢ (عَقِب ١٨٠٢).أخرجه ابن أبي حاتم ١/٣٤٢ (عَقِب ١٨٠٢).تفسير مقاتل بن سليمان ١/١٧٢.أخرجه ابن أبي شيبة (القسم الأول من الجزء الرابع) ص١٢٣، والبخاري (١٩٩٧، ١٩٩٨)، وابن جرير ٣/٤٢٥، والدارقطني ٢/١٨٦، والبيهقي ٥/٢٥.أخرجه البيهقي ٥/٣٦-٣٧ (٨٩٠٠)، والدارقطني ٣/١٥٧ (٢٢٨٣)، وابن جرير ٣/٤٢٧.</p><p>قال البيهقي: «رواه يحيى بن