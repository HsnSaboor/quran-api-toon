tafsir[11]{c,v,t}:
  12,53,""
12,54," <q>﴿وَقَالَ ٱلۡمَلِكُ ٱئۡتُونِی بِهِۦۤ أَسۡتَخۡلِصۡهُ لِنَفۡسِیۖ﴾</q> - تفسير ٣٧٥٩٨- عن عبد الله بن عباس -من طريق الكلبي، عن أبي صالح- قال: فأتاه الرسول، فقال: ألْقِ عنك ثياب السجن، والبَس ثيابًا جددًا، وقُمْ إلى الملك. فدعا له أهلُ السجن، وهو يومئذ ابنُ ثلاثين سنة، فلمّا أتاه رأى غُلامًا حَدَثًا، فقال: أيَعْلَمُ هذا رؤيايَ ولا يعلمُها السحرةُ والكَهَنَةُ؟! وأَقْعَدَه قُدّامه، وقال له: لا تَخَفْ. وألْبَسَه طَوْقًا مِن ذهب وثياب حرير، وأعطاه دابَّة مُسْرَجَةً مُزَيَّنة كدابَّة المَلِك، وضُرِب بالطَّبْل بمصر: إنّ يوسفَ خليفةُ الملِك{1}. (٨/٢٧٦) ٣٧٥٩٩- عن عبد الله بن عباس -من طريق أبي سنان، عن عبد الله بن أبي الهذيل- قال: قال الملِك ليوسف: إنِّي أُحِبُّ أن تُخالِطَني في كل شيء إلا في أهلي، وأنا آنَفُ أن تأكل معي. فغضِب يوسفُ ﵇، فقال: أنا أحقُّ أن آنَفُ؛ أنا ابنُ إبراهيم خليل الله، وأنا ابنُ إسحاق ذبيح الله، وأنا ابنُ يعقوب نبي الله{2}. (٨/٢٧٧) ٣٧٦٠٠- عن عبد الله بن أبي الهذيل -من طريق أبي سنان- قال: قال العزيزُ ليوسف: ما مِن شيء إلا وأنا أُحِبُّ أن تَشْرَكَني فيه، إلا أنِّي أُحِبُّ أن لا تَشْرَكَني في أهلي، وأن لا يأكل معي عبدي. قال: أتأنفُ أن آكُلَ معك؟! فأنا أحَقُّ أن آنَفَ مِنك، أنا ابن إبراهيم خليل الله، وابن إسحاق الذبيح، وابن يعقوب الذي ابْيَضَّت عيناه مِن الحزن{3}٣٣٨٧. (ز) ٣٣٨٧ انتقد ابنُ عطية (٥/١٠٧) هذا الأثر بقوله: «وفي هذا الحديث بُعْدٌ وضعف». ٣٧٦٠١- عن أبي ميسرة [عمرو بن شرحبيل] -من طريق أبي إسحاق- قال: لَمّا رأى العزيزُ لَبَقَ يوسف وكَيْسَه وظُرفه دعاه، فكان يتغَدّى معه، ويتَعَشّى دون غِلمانه، فلمّا كان بينَه وبين المرأة ما كان قالت: لِمَ تُدْنِي هذا مِن بين غلمانك؟! مُرْهُ فلْيَتَغَدَّ مع الغلمان. فقال له: اذهَبْ، فتَغَدَّ مع الغلمان. فقال له يوسف: أترغب أن تأكل معي؟! أنا –واللهِ- يوسفُ بنُ يعقوبَ نبيِّ الله، ابنِ إسحاقَ ذبيحِ الله، ابنِ إبراهيمَ خليلِ الله{4}٣٣٨٨. (٨/٢٧٧) ٣٣٨٨ ساق ابنُ عطية (٥/١٠٧) قول أبي ميسرة، ثم علّق بقوله: «أما إنّ الظاهر مِن قصته وقت محاورة الملك أنّه كان على عبودية، وإلا كان اللائق به أن ينتحي بنفسه عن عمل الكافر؛ لأنّ القوم كانوا أهل أوثان، ومحاورة يوسف لصاحبي السجن تقضي بذلك». ٣٧٦٠٢- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿أستخلصه لنفسي﴾</q>، قال: أتَّخِذه لنفسي{5}. (٨/٢٧٦) ٣٧٦٠٣- عن إسماعيل السُّدِّيّ -من طريق أسباط- قال: فلمّا وجد المَلِك له عُذْرًا قال: <q>﴿ائتونى به أستخلصه لنفسي﴾</q>{6}. (٨/١٩٣) ٣٧٦٠٤- قال مقاتل بن سليمان: <q>﴿وقالَ المَلِكُ ائْتُونِي بِهِ أسْتَخْلِصْهُ لِنَفْسِي﴾</q>، يعني: أتَّخِذه{7}. (ز) ٣٧٦٠٥- عن محمد بن إسحاق -من طريق سلمة-: قال المَلِكُ الرَّيّان بن الوليد الأكبر: <q>﴿ائتوني به أستخلصه لنفسي﴾</q>{8}. (ز) <q>﴿فَلَمَّا كَلَّمَهُۥ قَالَ إِنَّكَ ٱلۡیَوۡمَ لَدَیۡنَا مَكِینٌ أَمِینࣱ ۝٥٤﴾</q> - تفسير ٣٧٦٠٦- قال مقاتل بن سليمان: <q>﴿فَلَمّا﴾</q> أتاه يوسف، و<q>﴿كَلَّمَهُ﴾</q> أي: كلَّم الملِك؛ <q>﴿قالَ﴾</q> ليوسف: <q>﴿إنَّكَ اليَوْمَ لَدَيْنا مَكِينٌ﴾</q> يقول: عندنا وجِيه <q>﴿أمِينٌ﴾</q> على ما وُكِّلت به. كقوله: <q>﴿عِنْدَ ذِي العَرْشِ مَكِينٍ﴾</q> [التكوير:٢٠]{7}٣٣٨٩. (ز) ٣٣٨٩ ذكر ابنُ عطية (٥/١٠٧) أن فرقة قالت: <q>﴿أمين﴾</q> بمعنى: آمِن. وانتقده مستندًا للسياق، والدلالة العقلية، فقال: «وهذا ضعيف؛ لأنّه يخرج مِن نمط الكلام، ويَنْحَطُّ إكرامُ يوسف كثيرًا». ",footnotes:1:أخرجه ابن عبد الحكم في فتوح مصر ص١٣.أخرجه سعيد بن منصور (١١٢٩ - تفسير)، وابن أبي حاتم ٧/٢١٥٩. وعزاه السيوطي إلى ابن المنذر، وأبي الشيخ.أخرجه ابن جرير ١٣/٢١٧، وفي رواية بلفظ: أنا ابن إبراهيم خليل الله، ابن إسماعيل ذبيح الله.أخرجه ابن جرير ١٣/٢١٧، وابن أبي حاتم ٧/٢١٥٩. وعزاه السيوطي إلى أبي الشيخ.أخرجه ابن جرير ١٣/٢١٦، وابن أبي حاتم ٧/٢١٥٩ من طريق سعيد بن بشير. وعزاه السيوطي إلى أبي الشيخ.أخرجه ابن جرير ١٣/٢١٦، وابن أبي حاتم ٧/٢١٦١.تفسير مقاتل بن سليمان ٢/٣٤٠.أخرجه ابن أبي حاتم ٧/٢١٥٩.تفسير مقاتل بن سليمان ٢/٣٤٠.
12,55," <q>﴿قَالَ ٱجۡعَلۡنِی عَلَىٰ خَزَاۤىِٕنِ ٱلۡأَرۡضِۖ﴾</q> - تفسير ٣٧٦٠٧- عن عبد الله بن عباس، قال: قال رسول الله ﷺ: «رَحِم اللهُ أخي يوسف، لو لم يقل: اجعلني على خزائن الأرض. لاسْتَعْمَلَه مِن ساعتِه، ولكنَّه أخَّره لذلك سَنَةً، فأقام في بيته سَنَةً مع المَلِك»{1}. (ز) ٣٧٦٠٨- قال مقاتل: قال النبي ﷺ: «لو قال: إنِّي حَفِيظ عليم -إن شاء الله-. لَمَلَك مِن يومه ذلك»{2}. (ز) ٣٧٦٠٩- قال عبد الله بن عباس: لَبِث بعد ذلك سنةً ونِصْفًا، ثُمَّ مَلَك أرضَ مِصْرَ{2}. (ز) ٣٧٦١٠- عن عبد الله بن عباس، قال: لَمّا انصَرَمَتِ السنةُ مِن اليوم الذي سأل الإمارة دعاه المَلِك، فتَوَجَّه، [وقلَّده بسيفه]، ووضع له سريرًا مِن ذهب مُكَلَّل بالدُّرِّ والياقوت، وضرب عليه حُلَّةً مِن إستبرق، وطول السرير ثلاثون ذراعًا، وعرضه عشرة أذرع، عليه ثلاثون فراشًا، وستون مِقْرَمَةً{4}، ثم أمره أن يخرج، فخَرَجَ مُتَوَّجًا، ولونه كالثلج، ووجهه كالقمر، يرى الناظرُ وجهَه في صفاء لون وجهه، فانطلق حتى جلس على السرير، ودانَتْ له الملوك، ودخل المَلِك بيتَه، وفوَّض إليه أمرَ مصر، وعَزَل قُطْفِير عمّا كان عليه، وجعل يوسفَ مكانَه. قاله ابن إسحاق{5}. (ز) ٣٧٦١١- قال الربيع بن أنس: على خَراج مِصر، ودَخْلِه{6}. (ز) ٣٧٦١٢- عن شيبة بن نعامة الضَّبِّيِّ -من طريق إبراهيم بن المختار- في قوله: <q>﴿اجعلني على خزائن الأرض﴾</q>، يقول: على جميع الطعام{7}. (٨/٢٧٩) ٣٧٦١٣- قال مقاتل بن سليمان: ثم <q>﴿قالَ﴾</q> يوسف للملك: <q>﴿اجْعَلْنِي عَلى خَزائِنِ الأَرْضِ﴾</q> بمصر{2}. (ز) ٣٧٦١٤- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿اجعلنى على خزائن الأرض﴾</q>، قال: كان لفرعون خزائنُ كثيرةٌ غير الطعام، فأسلم سلطانَه كُلَّه له، وجعل القضاء إليه؛ أمره، وقضاؤه نافِذ{9}. (٨/٢٧٩) <q>﴿إِنِّی حَفِیظٌ عَلِیمࣱ ۝٥٥﴾</q> - تفسير ٣٧٦١٥- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿إنى حفيظ﴾</q> قال: لِما وُلِّيتُ، <q>﴿عليم﴾</q> بأمره{10}. (٨/٢٧٩) ٣٧٦١٦- عن شيبة بن نعامة الضَّبِّيِّ -من طريق إبراهيم بن المختار- في قوله: <q>﴿إنى حفيظ﴾</q> لِما اسْتَوْدَعْتَنِي، <q>﴿عليم﴾</q> بسنين المَجاعَة{11}. (٨/٢٧٩) ٣٧٦١٧- قال محمد بن السائب الكلبي: <q>﴿حفيظ﴾</q> بتقديره في السنين الخصبة [في الأرض الجدبة]، <q>﴿عليم﴾</q> بوقت الجُوع حين يَقَع. فقال له المَلِك: ومَن أحقُّ به منك؟! فوَلّاه ذلك، وقال له: <q>﴿إنّك اليوم لدينا مكين﴾</q> ذو مكانة ومنزِلة، <q>﴿أمين﴾</q> على الخزائن{12}. (ز) ٣٧٦١٨- قال مقاتل بن سليمان: <q>﴿إنِّي حَفِيظٌ﴾</q> لِما وكَّلتني به، <q>﴿عَلِيمٌ﴾</q> يعني: عالِم بلُغَة الناس كلها{2}. (ز) ٣٧٦١٩- عن محمد بن إسحاق -من طريق سلمة- <q>﴿إني حفيظ﴾</q>: إنِّي حافِظ لِما اسْتَوْدَعْتَنِي، <q>﴿عليم﴾</q> بما ولَّيْتَنِي، قال: قد فعلتُ. فوَلّاه -فيما يذكرون- عمل إطفير، وعَزَل إطفير عمّا كان عليه{14}. (ز) ٣٧٦٢٠- عن سفيان -من طريق الأشجعي- في قوله: <q>﴿إني حفيظ﴾</q> قال: حفيظ للحساب، <q>﴿عليم﴾</q> بالألْسُن{15}. (٨/٢٧٩) ٣٧٦٢١- عن الأشجعي -من طريق عمرو-، مثله{16}٣٣٩٠. (٨/٢٧٩) ٣٣٩٠ اختُلِف في المراد بقوله: <q>﴿إني حفيظ عليم﴾</q> على أقوال: الأول: أنّ المعنى: إني حفيظ لما استودعتني، عليم بما وليتني. الثاني: حفيظ بالحساب، عليم بالألسن. الثالث: حفيظ بتقديره في السنين الخصبة، عليم بسني المجاعة. ورجَّح ابنُ جرير (١٣/٢٢٠) مستندًا إلى السياق القولَ الأول الذي قاله قتادة، وشيبة، وابن إسحاق، فقال: «لأنّ ذلك عقيب قوله: <q>﴿اجعلني على خزائن الأرض﴾</q>، ومسألته الملكِ استكفاءَه خزائن الأرض، فكان إعلامُه بأنّ عنده خبرة في ذلك وكفايته إياه أشبه من إعلامه حفظه الحساب، ومعرفته بالألسن». وذكر ابنُ عطية (٥/١٠٨) أنّ <q>﴿حفيظ عليم﴾</q> صفتان تَعُمُّ وجوه التثقيف والحيطة، لا خلل معهما لعامل. وانتقد ما جاء في هذه الأقوال من تخصيص، مستندًا لدلالة العموم، فقال: «وهذا كله تخصيص لا وجه له، وإنّما أراد باتصافه أن يعرف الملك بالوجه الذي به يستحق الكون على خزائن الأرض، فاتَّصف بأنه يحفظ المجْبى مِن كل جهة تحتاج إلى الحفظ، ويعلم التناول أجمع». <q>﴿إِنِّی حَفِیظٌ عَلِیمࣱ ۝٥٥﴾</q> - آثار متعلقة بالآية ٣٧٦٢٢- عن أبي هريرة -من طريق محمد بن سيرين- قال: اسْتَعْمَلَني عمرُ على البحرين، ثم نزعني وغرَّمني اثني عشر ألفًا، ثم دعاني بعدُ إلى العمل، فأَبَيْتُ، فقال: ولِمَ، وقد سأل يوسفُ ﵇ العملَ وكان خيرًا منك؟ فقلت: إنّ يوسف ﵇ نبيٌّ ابنُ نبيٍّ ابنِ نبيٍّ ابنِ نبيٍّ، وأنا ابنُ أُمَيْمَة، وأنا أخاف أن أقول بغير علم، وأن أُفتِي بغير علم، وأن يُضْرَب ظهري، ويُشتَمَ عِرْضِي، ويؤخذ مالي{17}. (٨/٢٧٨) ٣٧٦٢٣- عن جابر بن عبد الله، قال: كان يوسف ﵇ لا يشبع، فقيل له: ما لَك لا تشبعُ وبيدك خزائنُ الأرض؟ قال: إنِّي إذا شَبِعْتُ نَسِيتُ الجائعَ{18}. (٨/٢٧٨) ٣٧٦٢٤- عن الحسن البصري، قال: قيل ليوسف ﵇: تجوع وخزائن الأرض بيدك؟ قال: إنِّي أخاف أن أشبع؛ فأنسى الجِياع{19}. (٨/٢٧٨) ٣٧٦٢٥- عن مجاهد بن جبر -من طريق أبي إسحاق الكوفي- قال: أسلم الملِكُ الذي كان معه يوسفُ ﵇{20}. (٨/٢٧٨) ",footnotes:1:أخرجه الثعلبي في تفسيره٥/٢٣١، والواحدي في التفسير الوسيط ٢/٦١٨ (٤٧٦)، والبغوي في تفسيره ٤/٢٥١. وأورده الديلمي في الفردوس ٢/٢٦٣ (٣٢٢٣). قال الحافظ ابن حجر في الكافي الشاف ص٩٠ (٢١٣): «أخرجه الثعلبي عن ابن عباس من رواية إسحاق بن بشر، عن جويبر، عن الضحاك عنه. وهذا إسناد ساقط». وقال الألباني في الضعيفة ١/٤٩٩ (٣٢٩): «موضوع».تفسير مقاتل بن سليمان ٢/٣٤٠.تفسير مقاتل بن سليمان ٢/٣٤٠.القِرامُ: ثوب من صوف ملون فيه ألوان من العِهن، وهو صفيق يتخذ سترًا. وقيل: هو السِّتر الرقيق، والجمع قُرُم، وهو المِقْرَمَة. وقيل: المِقْرَمَةُ مَحبِس الفِراش. لسان العرب (قرم).تفسير الثعلبي ٥/٢٣٢، وتفسير البغوي ٤/٢٥٢.تفسير البغوي ٤/٢٥١.أخرجه ابن جرير ١٣/٢١٩ بلفظ: على حفظ الطعام، وابن أبي حاتم ٧/٢١٦٠. وعزاه السيوطي إلى أبي الشيخ.تفسير مقاتل بن سليمان ٢/٣٤٠.أخرجه ابن جرير ١٣/٢١٨. وعزاه السيوطي إلى ابن أبي حاتم.أخرجه ابن جرير ١٣/٢١٩. وعزاه السيوطي إلى ابن أبي حاتم.أخرجه ابن جرير ١٣/٢١٩، وابن أبي حاتم ٧/٢١٦٠. وعزاه السيوطي إلى أبي الشيخ.تفسير الثعلبي ٥/٢٣١، وتفسير البغوي ٤/٢٥١.تفسير مقاتل بن سليمان ٢/٣٤٠.أخرجه ابن جرير ١٣/٢١٩، وابن أبي حاتم ٧/٢١٦٠.أخرجه ابن أبي حاتم ٧/٢١٦٠.أخرجه ابن جرير ١٣/٢١٩. وعزاه السيوطي إلى أبي الشيخ.أخرجه ابن أبي حاتم ٧/٢١٦٠ مقتصرًا على أوله، والحاكم ٢/٣٤٧.عزاه السيوطي إلى الخطيب في رواة مالك.أخرجه البيهقي في شعب الإيمان (٥٦٨٣). وعزاه السيوطي إلى وكيع في الغرر، وأبي الشيخ.أخرجه ابن جرير ١٣/٢٢٢.
12,56," <q>﴿وَكَذَ ٰ⁠لِكَ مَكَّنَّا لِیُوسُفَ فِی ٱلۡأَرۡضِ﴾</q> - تفسير ٣٧٦٢٦- عن إسماعيل السُّدِّيّ -من طريق أسباط- <q>﴿وكذلك مكنا ليوسف في الأرض يتبوأ منها حيث يشاء﴾</q>، قال: استعمله الملِك على مصر، وكان صاحبَ أمرها، وكان يلي البيعَ والتجارةَ وأمرَها كُلَّه، فذلك قوله: <q>﴿وكذلك مكنا ليوسف في الأرض يتبوأ منها حيث يشاء﴾</q>{1}. (ز) (٨/١٩٣) ٣٧٦٢٧- قال مقاتل بن سليمان: <q>﴿وكَذلِكَ مَكَّنّا لِيُوسُفَ﴾</q> يعني: وهكذا مَكَّنّا ليوسف المُلْكَ <q>﴿فِي الأَرْضِ﴾</q> في أرض مصر{2}. (ز) ٣٧٦٢٨- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿وكذلك مكنا ليوسف في الأرض﴾</q>، قال: مَلَّكناه فيما يكون فيها{3}. (٨/٢٧٩) <q>﴿یَتَبَوَّأُ مِنۡهَا حَیۡثُ یَشَاۤءُۚ﴾</q> - تفسير ٣٧٦٢٩- عن سعيد بن جبير -من طريق عطاء بن دينار- في قول الله: <q>﴿يتبوأ منها حيث يشاء﴾</q>، يقول: ينزل منها حيث يشاء{4}. (ز) ٣٧٦٣٠- قال مقاتل بن سليمان: <q>﴿يَتَبَوَّأُ﴾</q> يقول: ينزل <q>﴿مِنها حَيْثُ يَشاءُ﴾</q>{2}. (ز) ٣٧٦٣١- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿حيث يشاء﴾</q> مِن تلك الدنيا، يصنع فيها ما يشاء، فُوِّضَت إليه. قال: لو شاء أن يجعل فرعون من تحت يده، ويجعله من فوق لَفَعَل{3}. (٨/٢٧٩) <q>﴿یَتَبَوَّأُ مِنۡهَا حَیۡثُ یَشَاۤءُۚ﴾</q> - آثار متعلقة بالآية ٣٧٦٣٢- عن بكر بن عبد الله، قال: دخلت امرأةُ العزيز على يوسف، فلمّا رَأَتْه عَرَفَتْه، وقالت: الحمدُ لله الذي صيَّر العبيدَ بطاعته مُلوكًا، وجعل الملوك بمعصيته عبيدًا{7}. (٨/٢٤٧) ٣٧٦٣٣- عن عبد الله بن منبه، عن أبيه، قال: تَعَرَّضَتْ امرأةُ العزيز ليوسف ﵇ في الطريق حين مَرَّ بها، فقالت: الحمدُ لله الذى جعل الملوكَ بمعصيته عبيدًا، وجعل العبيد بطاعته ملوكًا، فعرَفها، فتزوَّجها، فوجدها بِكْرًا، وكان صاحبُها مِن قبلُ لا يأتي النساءَ{8}. (٨/٢٨٠) ٣٧٦٣٤- عن وهب بن مُنَبِّه، قال: أصابت امرأةُ العزيزِ حاجَةً لها، فقيل لها: لو أتيتِ يوسفَ بن يعقوب فسَأَلْتِهِ. فاستشارت الناسَ في ذلك، فقالوا: لا تفعلي؛ فإنّا نخاف عليك. قالت: كَلّا، إنِّي لا أخافُ مِمَّن يخاف الله. فدَخَلَتْ عليه، فرَأَتْه في مُلْكِه، فقالت: الحمدُ لله الذي جعل العبيدَ ملوكًا بطاعته. ثُمَّ نظرت إلى نفسها، فقالت: الحمد لله الذي جعل الملوكَ عبيدًا بمعصيته. فقضى لها جميع حوائجها، ثم تزوَّجها، فوجدها بِكْرًا، فقال لها: أليس هذا أجملَ مِمّا أردتِ؟ قالت: يا نبيَّ الله، إنِّي ابتُليتُ فيكَ بأربع: كنتَ أجملَ الناس كلهم، وكنتُ أنا أجمل أهل زماني، وكنتُ بكرًا، وكان زوجي عِنِّينًا{9}. (٨/٢٨١) ٣٧٦٣٥- عن زيد بن أسلم: أنّ يوسف ﵇ تَزَوَّج امرأةَ العزيز، فوجدها بِكْرًا، وكان زوجُها عِنِّينًا{8}. (٨/٢٨١) ٣٧٦٣٦- عن محمد بن إسحاق -من طريق سلمة- قال: ذكروا أنّ إطفير هَلَك في تلك الليالي، وأنّ الملك الرَّيّان زوج يوسف ﵇ امرأته راعيل، فقال لها حين أُدخِلَتْ عليه: أليس هذا خيرًا مما كنتِ تريدين؟ فقالت: أيُّها الصِّديق، لا تَلُمْنِي، فإنِّي كنتُ امرأةً كما ترى حسناء جَمْلاء ناعِمةً في مُلْك ودُنيا، وكان صاحبي لا يأتي النساء، وكنتَ كما جعلك الله في حُسْنِك وهيئتك، فغَلَبَتْنِي نفسي على ما رأيتَ. فيزعمون أنّه وجَدَها عَذْراء، فأصابها، فوَلَدَت له رجلين؛ أفراييم بن يوسف، ومنشا بن يوسف{11}. (٨/٢٨٠) ٣٧٦٣٧- عن فضيل بن عياض -من طريق قادم الديلمي العابد- قال: وقَفَتِ امرأةُ العزيز على ظَهْرِ الطريق حتى مرَّ يوسفُ ﵇، فقالت: الحمد لله الذي جعل العبيدَ ملوكًا بطاعته، وجعل الملوك عبيدًا بمعصيته{12}٣٣٩١. (٨/٢٨٠) ٣٣٩١ ساق ابنُ عطية (٥/١٠٩) هذه الآثار، ثم علّق بقوله: «ورُوِي في نحو هذا مِن القصص ما لا يوقف على صحته، ويطول الكلام بسوقه». <q>﴿نُصِیبُ بِرَحۡمَتِنَا مَن نَّشَاۤءُۖ وَلَا نُضِیعُ أَجۡرَ ٱلۡمُحۡسِنِینَ ۝٥٦﴾</q> - تفسير ٣٧٦٣٨- عن عبد الله بن عباس، في قوله: <q>﴿ولا نضيع أجر المحسنين﴾</q>، قال: يعني: الصابرين{13}. (ز) ٣٧٦٣٩- قال مجاهد بن جبر: فلم يزل يوسفُ ﵇ يدعو المَلِك إلى الإسلام ويَتَلَطَّف له حتى أسْلَم الملِكُ، وكثيرٌ من الناس. فهذا في الدنيا{13}. (ز) ٣٧٦٤٠- عن وهب بن مُنَبِّه، في قوله: <q>﴿ولا نضيع أجر المحسنين﴾</q>، قال: يعني: الصّابرين{13}. (ز) ٣٧٦٤١- قال مقاتل بن سليمان: <q>﴿نُصِيبُ بِرَحْمَتِنا﴾</q> يعني: سَعَتَنا <q>﴿مَن نَشاءُ ولا نُضِيعُ أجْرَ المُحْسِنِينَ﴾</q> يعني: نُوَفِّيه جزاءه، فجزاه الله بالصبر على البلاء، والصبر عن المعصية بأن ملَّكه على مصر{2}. (ز) <q>﴿نُصِیبُ بِرَحۡمَتِنَا مَن نَّشَاۤءُۖ وَلَا نُضِیعُ أَجۡرَ ٱلۡمُحۡسِنِینَ ۝٥٦﴾</q> - آثار متعلقة بالآية ٣٧٦٤٢- عن أنس بن مالك، عن رسول الله ﷺ أنّه قال: «اطلبوا الخيرَ دهرَكم كُلَّه، وتعرَّضوا لِنَفَحات رحمةِ الله، فإنّ لله ﷿ نفحاتٍ مِن رحمته يصيب بها مَن يشاء مِن عباده، واسألوا اللهَ أن يستر عَوْراتِكم، ويُؤَمِّن رَوْعاتكم»{17}. (٨/٢٨١) ",footnotes:1:أخرجه ابن جرير ١٣/٢٢١، وابن أبي حاتم ٧/٢١٦١ مختصرًا.تفسير مقاتل بن سليمان ٢/٣٤١.أخرجه ابن جرير ١٣/٢٢١، وابن أبي حاتم ٧/٢١٦١ من طريق أصبغ بن الفرج.أخرجه ابن أبي حاتم ٧/٢١٦١.تفسير مقاتل بن سليمان ٢/٣٤١.أخرجه ابن جرير ١٣/٢٢١، وابن أبي حاتم ٧/٢١٦١ من طريق أصبغ بن الفرج.عزاه السيوطي إلى ابن المنذر.عزاه السيوطي إلى أبي الشيخ.أخرجه الحكيم الترمذي ٢/١٨١، ٣/٣٥.عزاه السيوطي إلى أبي الشيخ.أخرجه ابن جرير ١٣/٢٢٠-٢٢١، وابن أبي حاتم ٧/٢١٦١.أخرجه ابن أبي حاتم ٧/٢١٦٢.تفسير الثعلبي ٥/٢٣٣، وتفسير البغوي ٤/٢٥٢.تفسير الثعلبي ٥/٢٣٣، وتفسير البغوي ٤/٢٥٢.تفسير الثعلبي ٥/٢٣٣، وتفسير البغوي ٤/٢٥٢.تفسير مقاتل بن سليمان ٢/٣٤١.أخرجه البيهقي في الأسماء والصفات ١/٣٧٨-٣٧٩ (٣٠٦)، والبغوي في شرح السنة ٥/١٧٩ (١٣٧٨). قال البغوي: «هذا حديث غريب». وقال المناوي في التيسير ١/١٦٤: «رمز المؤلف -السيوطي- لضعفه، وقول العامري:»حسن صحيح«باطل». وقال الألباني في الضعيفة ٦/٣١٣ (٢٧٩٨): «ضعيف».
12,57," <q>﴿وَلَأَجۡرُ ٱلۡـَٔاخِرَةِ خَیۡرࣱ لِّلَّذِینَ ءَامَنُوا۟﴾</q> - تفسير ٣٧٦٤٣- عن عبد الله بن عباس -من طريق علي- <q>﴿ولأجر الآخرة خير﴾</q>، يقول: باقِيَة{1}. (ز) ٣٧٦٤٤- قال مقاتل بن سليمان: ثم قال: <q>﴿ولَأَجْرُ الآخِرَةِ خَيْرٌ﴾</q> يعني: أكبر، يعني: جزاء الآخرة أفضلُ مِمّا أُعْطِي في الدنيا مِن الملك <q>﴿لِلَّذِينَ آمَنُوا﴾</q> يعني: صدَّقوا بالتوحيد{2}. (ز) <q>﴿وَكَانُوا۟ یَتَّقُونَ ۝٥٧﴾</q> - تفسير ٣٧٦٤٥- عن مجاهد بن جبر -من طريق ابن أبي نجيح- <q>﴿يتقون﴾</q>: يُطِيعونه{1}. (ز) ٣٧٦٤٦- عن مالك بن دينار، قال: سألتُ الحسن البصري، فقلتُ: يا أبا سعيد، قوله: <q>﴿ولأجر الآخرة خير للذين آمنوا وكانوا يتقون﴾</q>، ما هِيَه؟ قال: يا مالك، اتَّقَوُا المحارمَ، خَمِصَت بطونُهم؛ تركوا المحارم وهم يشتهونها{4}. (٨/٢٨٢) ٣٧٦٤٧- قال مقاتل بن سليمان: <q>﴿وكانُوا يَتَّقُونَ﴾</q> الشِّرْكَ، مِثْل الذي اتَّقى يوسفُ ﵇{2}. (ز) ",footnotes:1:أخرجه ابن أبي حاتم ٧/٢١٦٢.تفسير مقاتل بن سليمان ٢/٣٤١.أخرجه ابن أبي حاتم ٧/٢١٦٢.أخرجه ابن أبي حاتم ٧/٢١٦٢ (١١٧٢٨). وعزاه السيوطي إلى أبي الشيخ.تفسير مقاتل بن سليمان ٢/٣٤١.
12,58," <q>﴿وَجَاۤءَ إِخۡوَةُ یُوسُفَ فَدَخَلُوا۟ عَلَیۡهِ فَعَرَفَهُمۡ وَهُمۡ لَهُۥ مُنكِرُونَ ۝٥٨﴾</q> - تفسير ٣٧٦٤٨- قال عبد الله بن عباس: عرفهم بأوَّل ما نظر إليهم{1}. (ز) ٣٧٦٤٩- عن عبد الله بن عباس -من طريق عُبادَة الأسَدي- قال: إنّ إخوة يوسف لَمّا دخلوا عليه فعرَفهم وهم له منكرون؛ جاء بصُواع الملك الذي كان يشرب فيه، فوَضَعه على يده، فجعل ينقُرُهُ ويَطِنُّ، وينقُرُه ويَطِنُّ، فقال: إنّ هذا الجامَ لَيُخْبِرُني عنكم خَبَرًا، هل كان لكم أخ مِن أبيكم يُقال له: يوسف، وكان أبوه يُحِبُّه دونكم، وإنّكم انطلقتم به فألقيتموه في الجُبِّ، وأخبرتم أباكم أنّ الذئب أكله، وجئتم على قميصه بدم كذب؟ قال: فجعل بعضُهم ينظر إلى بعض، ويعجبون أنّ هذا الجامَ لَيُخْبِرُ خَبرَهم، فمِن أين يعلم هذا؟! قال ابنُ عباس: فلا نرى هذه الآيةَ نزلت إلا فيهم: <q>﴿لتنبئنهم بأمرهم هذا وهم لا يشعرون﴾</q> [يوسف:١٥]{2}. (٨/٢٨٢) ٣٧٦٥٠- قال عبد الله بن عباس: وكان بين أن قذفوه في البئر وبين أن دخلوا عليه أربعون سنة، فلذلك أنكروه{3}. (ز) ٣٧٦٥١- عن أبي الجَلْد -من طريق سفيان- قال: قال يوسف ﵇ لإخوته: إنّ أمرَكم لَيَرِيبُنِي، كأنّكم جواسيس. قالوا: يا أيها العزيز، إنّ أبانا شيخ صِدِّيق، وإنّا قومٌ صِدِّيقون، وإنّ الله يُحْيِي بكلام الأنبياء القلوبَ كما يُحْيِي وابلُ السماءِ الأرضَ. ويقول لهم وفي يده الإناءُ وهو يَقْرَعُه القَرْعَةَ: كأنّ هذا يخبر عنكم بأنّكم جواسيس{4}. (٨/٢٨٣) ٣٧٦٥٢- قال مجاهد بن جبر: عرفهم بأوَّلِ ما نَظَر إليهم{1}. (ز) ٣٧٦٥٣- قال عطاء: إنّما لم يعرفوه لأنّه كان على سرير المَلِك، وعلى رأسه تاج المُلْك{1}. (ز) ٣٧٦٥٤- عن ابن عون، قال: قلتُ للحسن البصري: تُرى يوسف عرَف إخوتَه؟ قال: لا، واللهِ، ما عرَفهم حتى تعرَّفوا إليه{7}. (٨/٢٨٣) ٣٧٦٥٥- عن قتادة بن دعامة -من طريق مَعْمَر- في قوله: <q>﴿فعرفهم وهم له منكرون﴾</q>، قال: لا يعرِفونه{8}. (٨/٢٨٣) ٣٧٦٥٦- عن وهب بن مُنَبِّه، قال: لَمّا جعَل يوسفُ ﵇ ينقُر الصاعَ ويُخْبِرُهم؛ قام إليه بعضُ إخوتُه، فقال: أنشُدُك باللهِ ألّا تَكْشِف لنا عَوْرَةً{9}. (٨/٢٨٣) ٣٧٦٥٧- عن إسماعيل السُّدِّيّ -من طريق أسباط- قال: فأصابَ الأرضَ الجوعُ، وأصاب بلادَ يعقوب التي كان فيها، فبعث بنيه إلى مصر، وأمسك بنيامين أخا يوسف، فلمّا دخلوا على يوسف <q>﴿فَعَرَفَهُم وهم له منكرون﴾</q>، فلمّا نظر إليهم أخذهم، وأدخلهم الدار، وأدخل المَكُّوكَ{10}، وقال لهم: أخْبِرُوني، ما أمرُكم؟ فإنِّي أُنكِرُ شأنَكم. قالوا: نحن مِن أرض الشام. قال: فما جاء بكم؟ قالوا: نَمْتارُ طعامًا. قال: كذبتم، أنتم عُيُون، كم أنتم؟ قالوا: نحن عشرة. قال: أنتم عشرة آلاف؛ كل رجل منكم أميرُ ألف، فأخبِرُوني خبركم. قالوا: إنّا إخْوَةٌ، بنو رجل صِدِّيقٍ، وإنّا كُنّا اثني عشر، فكان يُحِبُّ أخًا لنا، وإنّه ذَهَبَ معنا إلى البَرِّيَّةِ، فهَلَكَ مِنّا فيها، وكانَ أحبَّنا إلى أبينا. قال: فإلى مَن يسكن أبوكُم بعده؟ قالوا: إلى أخٍ له أصغر منه. قال: كيف تُحَدِّثوني أنّ أباكم صِدِّيق، وهو يُحِبُّ الصغير منكم دون الكبير؟! ائْتوني بأخيكم هذا حتى أنظر إليه، <q>﴿فإن لم تأتونى به فلا كيل لكم عندى ولا تقربون﴾</q>. قالوا: <q>﴿سنراود عنه أباه وإنا لفاعلون﴾</q>. قال: فإني أخشى ألا تأتوني به، فضعوا بعضَكم رهينةً حتى ترجعوا. فارْتَهَنَ شَمْعُون عنده{11}٣٣٩٢. (٨/١٩٣) ٣٣٩٢ انتَقَد ابنُ كثير (٨/٥٤) ما قاله السدي مِن أنّ يوسف قد أخذ منهم رهائن حتى يقدموا بأخيهم معهم مستندًا للدلالة العقلية، فقال: «وفي هذا نظر؛ لأنّه أحسن إليهم، ورغَّبهم كثيرًا، وهذا لحرصه على رجوعهم». ٣٧٦٥٨- قال مقاتل بن سليمان: <q>﴿وجاءَ إخْوَةُ يُوسُفَ﴾</q> مِن أرض كَنْعان، <q>﴿فَدَخَلُوا عَلَيْهِ﴾</q> أي: على يوسف بمِصْر، <q>﴿فَعَرَفَهُمْ﴾</q> يوسفُ، <q>﴿وهُمْ لَهُ مُنْكِرُونَ﴾</q> يقول: وهم لا يعرفون يوسف. فقال: مَن أنتم؟ قالوا: نحن بنو يعقوب، نحن من أهل كنعان. قال: كَم أنتم؟ قالوا: نحنُ أحد عشر. قال: ما لي لا أرى الأحدَ عشر؟ قالوا: واحِدٌ مِنّا عند أبينا. قال: ولِم ذلك؟ قالوا: إنّ أخاه لأمه أكله الذئب، فلذلك تركناه عند أبينا، فهو يستريح إليه{12}. (ز) ٣٧٦٥٩- عن محمد بن إسحاق -من طريق سلمة- قال: لَمّا اطمأن يوسفُ في مُلْكِه، وخرج مِن البلاء الذي كان فيه، وخَلَت السنون المُخْصِبة التي كان أمرهم بالإعداد فيها للسِّنين التي أخبرهم بها أنها كائنة؛ جُهِدَ الناسُ{13} في كل وجْهٍ، وضربوا إلى مصر يلتمسون بها المِيرَةَ مِن كل بلدة، وكان يوسفُ حين رأى ما أصاب الناس مِن الجَهْدِ قد آسى بينهم، وكان لا يحمل للرجل إلا بعيرًا واحدًا، ولا يحمل للرجل الواحد بعيرين؛ تقسيطًا بين الناس، وتوسيعًا عليهم، فقَدِم إخوتُه فيمن قَدِم عليه من الناس، يلتمسون الميرَة مِن مصر، فعرفهم وهم له منكرون؛ لِما أراد اللهُ أن يبلغ ليوسف ﵇ ما أراد{14}٣٣٩٣. (ز) ٣٣٩٣ ساق ابنُ عطية (٥/١١١) ما أفادته هذه الآثار، ثم علّق بقوله: «وفي ذلك قصص طويل جاءت الإشارة إليه في القرآن وجيزة». وذكر (٥/١١٢) أنه رُوي عن النبي ﷺ أنه قال: «كان يوسف يلقي حصاة في إناء فضة مخوص بالذهب، فيطِنُّ، فيقول لهم: إنّ هذا الإناء يخبرني أن لكم أبا شيخًا». ثم علّق بقوله: «كأنها حيلة وإيهام لهم». وبيّن أنّ الظاهر أنّ كل ما فعله يوسف معهم أنّه بوحي وأمْر، وإلا فكان بِرُّ يعقوب يقتضي أن يبادر إليه ويستدعيه، لكن الله تعالى أعلمه بما يصنع ليكمل أجر يعقوب ومحنته، وتتفسر الرؤيا الأولى. وذكر ابنُ كثير (٨/٥٤) أنّ ما ذكره بعض المفسرين من أنّه باعهم في السنة الأولى بالأموال، وفي الثانية بالمتاع، وفي الثالثة بكذا، وفي الرابعة بكذا، حتى باعهم بأنفسهم وأولادهم بعدما تملك عليهم جميع ما يملكون، ثم أعتقهم وردَّ عليهم أموالهم كلها؛ أنه من الإسرائيليات التي لا تصدق ولا تكذب. ",footnotes:1:تفسير البغوي ٤/٢٥٤.أخرجه ابن جرير ١٣/٣٣، وابن أبي حاتم ٧/٢١٦٢. وعزاه السيوطي إلى أبي الشيخ دون آخره.تفسير الثعلبي ٥/٢٣٤، وتفسير البغوي ٤/٢٥٤.أخرجه ابن أبي حاتم ٧/٢١٦٣.تفسير البغوي ٤/٢٥٤.تفسير البغوي ٤/٢٥٤.عزاه السيوطي إلى ابن أبي حاتم، وأبي الشيخ.أخرجه عبد الرزاق ١/٣٢٥، وابن جرير ١٣/٢٢٤، وابن أبي حاتم ٧/٢١٦٣. وعزاه السيوطي إلى ابن المنذر.عزاه السيوطي إلى أبي الشيخ.المكوك: اسم للمكيال، ويختلف مقداره باختلاف اصطلاح الناس عليه في البلاد. النهاية (مكك).أخرجه ابن جرير ١٣/٢٢٣-٢٢٤، وابن أبي حاتم ٧/٢١٦٣-٢١٦٤.تفسير مقاتل بن سليمان ٢/٣٤١.جُهِدَ الناس: أجدبوا. النهاية (جهد).أخرجه ابن جرير ١٣/٢٢٢-٢٢٣.
12,59," <q>﴿وَلَمَّا جَهَّزَهُم بِجَهَازِهِمۡ﴾</q> - تفسير ٣٧٦٦٠- قال مقاتل بن سليمان: <q>﴿ولَمّا جَهَّزَهُمْ﴾</q> يوسفُ <q>﴿بِجَهازِهِمْ﴾</q> يعني: في أمر الطعام{1}. (ز) ٣٧٦٦١- عن محمد بن إسحاق -من طريق سلمة- قال: لَمّا جهز يوسفُ فيمَن جَهَّز مِن الناس؛ حَمل لكلِّ رجلٍ منهم بعيرًا بعِدَّتهم{2}. (ز) <q>﴿قَالَ ٱئۡتُونِی بِأَخࣲ لَّكُم مِّنۡ أَبِیكُمۡۚ﴾</q> - تفسير ٣٧٦٦٢- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿ائتونى بأخ لكم من أبيكم﴾</q>، قال: يعني: بنيامين، وهو أخو يوسف لأبيه وأمه{3}. (٨/٢٨٣) ٣٧٦٦٣- قال مقاتل بن سليمان: <q>﴿قالَ ائْتُونِي بِأَخٍ لَكُمْ مِن أبِيكُمْ﴾</q>، يعني: بِنيامين، وكان أخاهم مِن أبيهم، وكان أخا يوسف لأبيه وأُمِّه{1}. (ز) ٣٧٦٦٤- عن محمد بن إسحاق -من طريق سلمة- قال: ثُمَّ قال لهم: <q>﴿ائتوني بأخ لكم من أبيكم﴾</q> أجعل لكم بعيرًا آخر. أو كما قال{5}. (ز) <q>﴿أَلَا تَرَوۡنَ أَنِّیۤ أُوفِی ٱلۡكَیۡلَ﴾</q> - تفسير ٣٧٦٦٥- قال مقاتل بن سليمان: <q>﴿ألا تَرَوْنَ أنِّي أُوفِي﴾</q> يعني: أوفي لكم <q>﴿الكَيْلَ﴾</q>{1}. (ز) ٣٧٦٦٦- عن محمد بن إسحاق -من طريق سلمة- <q>﴿ألا ترون أني أوفي الكيل﴾</q>، أي: لا أبْخَسُ الناسَ شيئًا{5}. (ز) <q>﴿وَأَنَا۠ خَیۡرُ ٱلۡمُنزِلِینَ ۝٥٩﴾</q> - تفسير ٣٧٦٦٧- عن عبد الله بن عباس -من طريق أبي رَوْق، عن الضَّحّاك- في قوله: <q>﴿وأنا خير المنزلين﴾</q>، قال: خير مَن يَضِيُف بمِصر{8}. (٨/٢٨٣) ٣٧٦٦٨- عن مجاهد بن جبر -من طريق ابن أبي نجيح-: <q>﴿وأنا خير المنزلين﴾</q>، قال يوسف ﵇: أنا خيرُ مَن يضيف بمصر{5}. (٨/٢٨٤) ٣٧٦٦٩- عن عبد الملك ابن جُرَيج، في قوله: <q>﴿وأنا خير المنزلين﴾</q>، قال: خير المُضِيفين{10}. (٨/٢٨٤) ٣٧٦٧٠- قال مقاتل بن سليمان: <q>﴿وأَنا خَيْرُ المُنْزِلِينَ﴾</q>: وأنا أفضلُ مَن يضيف بمصر{1}. (ز) ٣٧٦٧١- عن محمد بن إسحاق -من طريق سلمة- <q>﴿وأنا خير المنزلين﴾</q>، أي: خيرٌ لكم مِن غيري، فإنّكم إن أتيتُم به أكرمتُ منزلتكم، وأحسنتُ إليكم، وازددتُم به بعيرًا مَعَ عِدَّتكم، فإنِّي لا أُعطي كلَّ رجل منكم إلا بعيرًا{12}. (ز) ",footnotes:1:تفسير مقاتل بن سليمان ٢/٣٤١.أخرجه ابن جرير ١٣/٢٢٥، وابن أبي حاتم ٧/٢١٦٣.أخرجه ابن جرير ١٣/٢٢٥، وابن أبي حاتم ٧/٢١٦٣ من طريق سعيد بن أبي عروبة.تفسير مقاتل بن سليمان ٢/٣٤١.أخرجه ابن جرير ١٣/٢٢٥.تفسير مقاتل بن سليمان ٢/٣٤١.أخرجه ابن جرير ١٣/٢٢٥.أخرجه ابن أبي حاتم ٧/٢١٦٤. وعزاه السيوطي إلى أبي الشيخ.أخرجه ابن جرير ١٣/٢٢٥.عزاه السيوطي إلى ابن المنذر.تفسير مقاتل بن سليمان ٢/٣٤١.أخرجه ابن جرير ١٣/٢٢٥، وابن أبي حاتم ٧/٢١٦٤.
12,60," <q>﴿فَإِن لَّمۡ تَأۡتُونِی بِهِۦ فَلَا كَیۡلَ لَكُمۡ عِندِی وَلَا تَقۡرَبُونِ ۝٦٠﴾</q> - تفسير ٣٧٦٧٢- قال مقاتل بن سليمان: <q>﴿فَإنْ لَمْ تَأْتُونِي بِهِ فَلا كَيْلَ لَكُمْ﴾</q> يعني: فلا بيع لكم <q>﴿عِنْدِي﴾</q> مِن الطعام <q>﴿ولا تَقْرَبُونِ﴾</q> بلادي{1}. (ز) ٣٧٦٧٣- عن محمد بن إسحاق -من طريق سلمة- <q>﴿فإن لم تأتوني به فلا كيل لكم عندي ولا تقربون﴾</q>، قال: لا تقربوا بلدي{2}. (ز) ",footnotes:1:تفسير مقاتل بن سليمان ٢/٣٤٢.أخرجه ابن جرير ١٣/٢٢٥، وابن أبي حاتم ٧/٢١٦٤.
12,61," <q>﴿قَالُوا۟ سَنُرَ ٰ⁠وِدُ عَنۡهُ أَبَاهُ﴾</q> - تفسير ٣٧٦٧٤- عن عبد الله بن عباس، في قوله: <q>﴿قالُوا سَنُراوِدُ عَنْهُ أباهُ﴾</q>، قال: سنخدعه حتى يُخرجَه معنا{1}. (ز) ٣٧٦٧٥- قال مقاتل بن سليمان: <q>﴿قالُوا سَنُراوِدُ عَنْهُ أباهُ﴾</q> يعقوب{2}. (ز) <q>﴿وَإِنَّا لَفَـٰعِلُونَ ۝٦١﴾</q> - تفسير ٣٧٦٧٦- قال مقاتل بن سليمان: <q>﴿وإنّا لَفاعِلُونَ﴾</q> ذلك بأبيه{2}. (ز) ٣٧٦٧٧- عن محمد بن إسحاق -من طريق سلمة- <q>﴿وإنا لفاعلون﴾</q>: لَنَجْتَهِدَنَّ{4}. (ز) ",footnotes:1:تفسير الثعلبي ٥/٢٣٥.تفسير مقاتل بن سليمان ٢/٣٤٢.تفسير مقاتل بن سليمان ٢/٣٤٢.أخرجه ابن جرير ١٣/٢٢٦، وابن أبي حاتم ٧/٢١٦٤.
12,62," <q>﴿وَقَالَ لِفِتۡیَـٰنِهِ ٱجۡعَلُوا۟ بِضَـٰعَتَهُمۡ فِی رِحَالِهِمۡ لَعَلَّهُمۡ یَعۡرِفُونَهَاۤ إِذَا ٱنقَلَبُوۤا۟ إِلَىٰۤ أَهۡلِهِمۡ لَعَلَّهُمۡ یَرۡجِعُونَ ۝٦٢﴾</q> - قراءات ٣٧٦٧٨- عن إبراهيم النخعي أنّه كان يقرأ: ‹وقالَ لِفِتْيَتِهِ›{1}. (٨/٢٨٤) ٣٧٦٧٩- عن الحسن البصري -من طريق عوف، وعباد بن راشد- أنّه كان يقرأ: <q>﴿لِفِتْيانِهِ﴾</q>{2}٣٣٩٤. (٨/٢٨٤) ٣٣٩٤ اختُلِف في قراءة قوله: <q>﴿لفتيانه﴾</q>؛ فقرأ قوم: <q>﴿لفتيانه﴾</q>. وقرأ آخرون: ‹لِفِتْيَتِهِ›. وذكر ابنُ عطية (٥/١١٢) أنّ فتيان للكثرة -على مراعاة المأمورين-، وفتية للقلّة -على مراعاة المتناولين، وهم الخدمة-، ثم علّق بقوله: «ويكون هذا الوصف للحُرِّ والعبد». <q>﴿وَقَالَ لِفِتۡیَـٰنِهِ﴾</q> - تفسير ٣٧٦٨٠- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿لِفِتْيانِهِ﴾</q>، أي: لغلمانه{3}. (٨/٢٨٤) ٣٧٦٨١- قال مقاتل بن سليمان: <q>﴿وقالَ﴾</q> يوسف: <q>﴿لِفِتْيانِهِ﴾</q> يعني: لِخُدّامه وهم يكيلون لهم الطعام{4}. (ز) <q>﴿ٱجۡعَلُوا۟ بِضَـٰعَتَهُمۡ﴾</q> - تفسير ٣٧٦٨٢- عن عبد الله بن عباس -من طريق الضَّحّاك- في قوله: <q>﴿اجعلوا بضاعتهم﴾</q>: كانت النِّعال، والأُدْمَ{5}. (ز) ٣٧٦٨٣- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿اجعلوا بضاعتهم﴾</q>، أي: أوراقَهم{6}. (٨/٢٨٤) ٣٧٦٨٤- قال محمد بن السائب الكلبي: تَخَوَّف أن لا يكون عند أبيه مِن الوَرِق ما يرجعون به مَرَّة أخرى{7}. (ز) ٣٧٦٨٥- قال مقاتل بن سليمان: <q>﴿اجْعَلُوا بِضاعَتَهُمْ﴾</q>، يعني: دراهمهم{4}. (ز) ٣٧٦٨٦- عن محمد بن إسحاق -من طريق سلمة- قال: ثُمَّ أمر ببضاعتهم التي أعطاهم بها ما أعطاهم مِن الطعام، فجعلت في رحالهم وهم لا يعلمون{9}. (ز) <q>﴿فِی رِحَالِهِمۡ لَعَلَّهُمۡ یَعۡرِفُونَهَاۤ إِذَا ٱنقَلَبُوۤا۟ إِلَىٰۤ أَهۡلِهِمۡ﴾</q> - تفسير ٣٧٦٨٧- قال مقاتل بن سليمان: <q>﴿فِي رِحالِهِمْ﴾</q> يعني: في أوعيتهم <q>﴿لَعَلَّهُمْ﴾</q> يعني: لكي <q>﴿يَعْرِفُونَها إذا انْقَلَبُوا إلى أهْلِهِمْ﴾</q>{4}. (ز) <q>﴿لَعَلَّهُمۡ یَرۡجِعُونَ ۝٦٢﴾</q> - تفسير ٣٧٦٨٨- عن إسماعيل السُّدِّيّ -من طريق أسباط- قال: فقال لفتيته وهو يكيل لهم: <q>﴿اجعلوا بضاعتهم في رحالهم لعلهم يعرفونها إذا انقلبوا إلى أهلهم لعلهم يرجعون﴾</q> إلَيَّ{9}. (٨/١٩٤) ٣٧٦٨٩- قال مقاتل بن سليمان: <q>﴿لَعَلَّهُمْ﴾</q> يعني: لكي <q>﴿يَرْجِعُونَ﴾</q> إلينا، فلا يحبسهم عَنّا حبس الدَّراهم إذا رُدَّت إليهم؛ لأنهم كانوا أهل ماشية{4}. (ز) ٣٧٦٩٠- عن محمد بن إسحاق -من طريق سلمة- في قوله: <q>﴿لعلهم يعرفونها إذا انقلبوا إلى أهلهم لعلهم يرجعون﴾</q>، قال: ثُمَّ خرجوا حتى قدموا على أبيهم، وكان منزل يعقوب وبنيه -فيما ذكر لي بعضُ أهل العلم- بالعَرَبات، من أرض فلسطين بِغَور الشام. وبعضٌ يقول: بالأَوْلاج، من ناحية شعب أسفل من حِسْمى{13}. وكان صاحبَ بادية، له بها شاءٌ وإبِل{14}٣٣٩٥. (٨/٢٨٥) ٣٣٩٥ ذكر ابنُ جرير (١٣/٢٢٨-٢٢٩) أنّ العِلَّة التي من أجلها أمر يوسف فتيانه أن يجعلوا بضاعة إخوته في رحالهم تحتمل ثلاثة احتمالات: الأول: ما ذكره الكلبيُّ مِن خشيته أن لا يكون عند أبيه دراهم، فيضر أخذ ذلك منهم به، وأحب أن يرجع إليه. الثاني: أنّه أراد أن يَتَّسع بها أبوه وإخوته مع حاجتهم إليه، فردَّه عليهم مِن حيث لا يعلمون تكرُّمًا وتفضُّلًا. الثالث: أن يتحرجوا مِن أخذ الطعام بلا ثمن فيكون ذلك أدعى لهم إلى العوْد. ونقل ابنُ عطية (٥/١١٣) احتمالًا رابعًا أنّه قيل: إنّ يوسف ﵇ فعل ذلك ليجعلها توطئة لجعل السقاية في رحل أخيه بعد ذلك، لِيُبَيِّن أنه لم يسرق لِمَن يتأمل القصة. وانتقد الاحتمال الثالث مستندًا للسياق، والدلالة العقلية، فقال: «وهذا ضعيف من وجوه، وسرورهم بالبضاعة وقولهم: <q>﴿هذه بضاعتنا ردت إلينا﴾</q> يكشف أنّ يوسف ﵇ لم يقصد هذا، وإنما قصد أن يستميلهم ويصلهم فيرغبهم في نفسه كالذي كان. وخص البضاعة بعينها دون أن يعطيهم غيرها من الأموال لأنها أوقع في نفوسهم، إذ يعرفون حلها، وماله هو إنما كان عندهم مالًا مجهول الحال، غايته أن يستجاز على نحو استجازتهم قبول الميرة». ثم قال: «ويظهر أنّ ما فعل يوسف من صلتهم، وجبرهم في تلك الشدة كان واجبًا عليه، إذ هو ملك عدل، وهم أهل إيمان ونبوة». ثم رجَّح أنّه أراد استمالتهم وصلتهم، فقال: «والظاهر من القِصَّة أنه إنما أراد الاستئلاف، وصلة الرَّحِم». ",footnotes:1:أخرجه سعيد بن منصور (١١٣٠، ١١٣١- تفسير). وهي قراءة متواترة، قرأ بها العشرة ما عدا حمزة، والكسائي، وخلف العاشر، وحفصًا عن عاصم، وقرأ بقية العشرة: <q>﴿لِفِتْيانِهِ﴾</q> بألف بعد الياء، ونون مكسورة بعدها. انظر: النشر ٢/٢٩٥، والإتحاف ص٣٣٣.أخرجه سعيد بن منصور (ت: سعد آل حميد) ٥/٤٠٠ (١١٣١).أخرجه ابن جرير ١٣/٢٢٧، وابن أبي حاتم ٧/٢١٦٥.تفسير مقاتل بن سليمان ٢/٣٤٢.تفسير الثعلبي ٥/٢٣٥، وتفسير البغوي ٤/٢٥٥.أخرجه ابن جرير ١٣/٢٢٧، وابن أبي حاتم ٧/٢١٦٥ من طريق سعيد بن أبي عروبة.تفسير الثعلبي ٥/٢٣٥، وتفسير البغوي ٤/٢٥٦.تفسير مقاتل بن سليمان ٢/٣٤٢.أخرجه ابن جرير ١٣/٢٢٨، وابن أبي حاتم ٧/٢١٦٥.تفسير مقاتل بن سليمان ٢/٣٤٢.أخرجه ابن جرير ١٣/٢٢٨، وابن أبي حاتم ٧/٢١٦٥.تفسير مقاتل بن سليمان ٢/٣٤٢.حِسْمى: أرض ببادية الشام. معجم البلدان ٢/٣١٧.أخرجه ابن أبي حاتم ٧/٢١٦٥.
12,63," <q>﴿فَلَمَّا رَجَعُوۤا۟ إِلَىٰۤ أَبِیهِمۡ قَالُوا۟ یَـٰۤأَبَانَا مُنِعَ مِنَّا ٱلۡكَیۡلُ فَأَرۡسِلۡ مَعَنَاۤ أَخَانَا نَكۡتَلۡ وَإِنَّا لَهُۥ لَحَـٰفِظُونَ ۝٦٣﴾</q> - قراءات ٣٧٦٩١- قال سفيان الثوري: في قراءة عبد الله بن مسعود (أرْسِلْ مَعَنَآ أخانا يَكْتَلْ مِثْلَ نَصِيبِ أحَدِنا){1}. (ز) ٣٧٦٩٢- عن المغيرة، عن أصحاب عبد الله بن مسعود: ‹فَأَرْسِلْ مَعَنَآ أخانا يَكْتَلْ›{2}. (٨/٢٨٥) ٣٧٦٩٣- عن عبد الملك ابن جُرَيْج: ‹فَأَرْسِلْ مَعَنَآ أخانَآ يَكْتَلْ›...{3}٣٣٩٦. (٨/٢٨٥) ٣٣٩٦ اختُلِف في قراءة قوله: <q>﴿نكتل﴾</q>؛ فقرأ قوم بالنون. وقرأ غيرهم بالياء. وذكر ابنُ جرير (١٣/٢٣١) أنّ قراءة النون بمعنى: نكتل نحن وهو. وأنّ قراءة الياء بمعنى: يكتل هو لنفسه كما نكتال لأنفسنا. وبنحوه قال ابنُ عطية (٥/١١٣). وابنُ كثير (٨/٥٥). وذكر ابنُ عطية أنّ قراءة النون على مراعاة: <q>﴿مُنع منا﴾</q>، ثم علّق بقوله: «ويقويه: <q>﴿ونمير أهلنا﴾</q><q>﴿ونزداد﴾</q>». ورجَّح ابنُ جرير (١٣/٢٣١) صحة كلتا القراءتين مستندًا إلى شهرتهما، وصِحَّة معناهما، فقال: «والصواب من القول في ذلك أنهما قراءتان معروفتان مُتَّفِقتا المعنى، فبأيتهما قرأ القارئُ فمصيبٌ الصواب، وذلك أنّهم إنّما أخبروا أباهم أنّه مُنِع منهم زيادة الكيل على عدد رءوسهم، فقالوا: <q>﴿يا أبانا منع منا الكيل﴾</q>. ثم سألوه أن يرسل معهم أخاهم ليكتال لنفسه، فهو إذا اكتال لنفسه واكتالوا هم لأنفسهم فقد دخل الأخ في عددهم، فسواء كان الخبر بذلك عن خاصة نفسه، أو عن جميعهم بلفظ الجميع، إذ كان مفهومًا معنى الكلام وما أريد به». <q>﴿فَلَمَّا رَجَعُوۤا۟ إِلَىٰۤ أَبِیهِمۡ قَالُوا۟ یَـٰۤأَبَانَا مُنِعَ مِنَّا ٱلۡكَیۡلُ﴾</q> - تفسير ٣٧٦٩٤- قال الحسن البصري، في قوله: <q>﴿منع منا الكيل﴾</q>، قال: معناه: يُمْنَع مِنّا الكيل{4}. (ز) ٣٧٦٩٥- عن إسماعيل السدي -من طريق أسباط- قال: فلمّا رجع القومُ إلى أبيهم كلَّموه، فقالوا: يا أبانا، إنّ ملِك مِصْرَ أكرَمنا كرامةً لو كان رَجُلًا مِنّا مِن بني يعقوب ما أكرَمَنا كرامته، وإنّه ارْتَهَنَ شمعون، وقال: ائْتُويى بأخيكم هذا الذي عَطَفَ عليه أبوكم بعد أخيكم الذي هَلَك حتى أنظر إليه، فإن لم تأتوني به فلا تقربوا بلادي أبدًا. فقال لهم يعقوب: إذا أتيتم ملِك مصر فأقرِئوه مِنِّي السلام، وقولوا: إنّ أبانا يُصَلِّي عليك، ويدعو لك بما أوْلَيْتَنا{5}. (٨/١٩٥) ٣٧٦٩٦- قال مقاتل بن سليمان: <q>﴿فَلَمّا رَجَعُوا إلى أبِيهِمْ قالُوا يا أبانا مُنِعَ مِنّا الكَيْلُ﴾</q>، يعني: مُنِع كيل الطعام. فيه إضمارٌ فِيما يُسْتَأْنَف{6}٣٣٩٧. (ز) ٣٣٩٧ ذكر ابنُ عطية (٥/١١٣) أنّ قولهم: <q>﴿منع منا﴾</q> ظاهره أنهم أشاروا إلى قوله: <q>﴿فلا كيل لكم عندي﴾</q>، فهو خوف في المستأنف. ونقل أنّه قيل: أشاروا إلى بعير بنيامين الذي لم يَمْتَر. ثم رجَّح أنّه خوفٌ في المستانف، وهو ما أفاده قول مقاتل، فقال: «والأول أرجح». ولم يذكر مستندًا. ٣٧٦٩٧- عن محمد بن إسحاق -من طريق سلمة- قال: ... فقالوا: يا أبانا، قدِمنا على خيرِ رجُلٍ؛ أنزَلَنا فأَكْرَم منزِلَنا، وكال لنا فأَوْفانا ولم يَبْخَسْنا، وقد أمَرَنا أن نأتيه بأخٍ لنا مِن أبينا، وقال: إن أنتم لم تفعلوا فلا تَقْرَبُنِّي، ولا تَدْخُلُنَّ بلدي. فقال لهم يعقوب: <q>﴿هل آمنكم عليه إلا كما أمنتكم على أخيه من قبل، فالله خير حافظا وهو أرحم الراحمين﴾</q>{7}. (ز) <q>﴿فَأَرۡسِلۡ مَعَنَاۤ أَخَانَا نَكۡتَلۡ وَإِنَّا لَهُۥ لَحَـٰفِظُونَ ۝٦٣﴾</q> - تفسير ٣٧٦٩٨- قال مقاتل بن سليمان: <q>﴿فَأَرْسِلْ مَعَنا أخانا﴾</q> بنيامين <q>﴿نَكْتَلْ﴾</q> الطعامَ بثَمَن، <q>﴿وإنّا لَهُ لَحافِظُونَ﴾</q> مِن الضَيْعَة{6}. (ز) ٣٧٦٩٩- عن عبد الملك ابن جُرَيْج: ‹فَأَرْسِلْ مَعَنَآ أخانا يَكْتَلْ› له بعيرًا{3}. (٨/٢٨٥) ",footnotes:1:تفسير الثوري ص١٤٤. وهي قراءة شاذة.عزاه السيوطي إلى ابن أبي شيبة، وابن المنذر. وهي قراءة متواترة، قرأ بها حمزة، والكسائي، وخلف العاشر، وقرأ بقية العشرة: <q>﴿نَكْتَلْ﴾</q> بالنون. انظر: النشر ٢/٢٩٥، والإتحاف ص٣٣٣.عزاه السيوطي إلى ابن جرير، وابن المنذر.تفسير البغوي ٤/٢٥٦.أخرجه ابن جرير ١٣/٢٢٩، وابن أبي حاتم ٧/٢١٦٥-٢١٦٦.تفسير مقاتل بن سليمان ٢/٣٤٢.أخرجه ابن جرير ١٣/٢٣٠، وابن أبي حاتم ٧/٢١٦٦.تفسير مقاتل بن سليمان ٢/٣٤٢.عزاه السيوطي إلى ابن جرير، وابن المنذر.
