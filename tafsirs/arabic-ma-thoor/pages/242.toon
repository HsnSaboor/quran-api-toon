quran[11]{c,v,t}:
  12,53,""
  12,54,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَقَالَ ٱلۡمَلِكُ ٱئۡتُونِی بِهِۦۤ أَسۡتَخۡلِصۡهُ لِنَفۡسِیۖ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٧٥٩٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق الكلبي، عن أبي صالح- قال: فأتاه الرسول، فقال: ألْقِ عنك ثياب السجن، والبَس ثيابًا جددًا، وقُمْ إلى الملك. فدعا له أهلُ السجن، وهو يومئذ ابنُ ثلاثين سنة، فلمّا أتاه رأى غُلامًا حَدَثًا، فقال: أيَعْلَمُ هذا رؤيايَ ولا يعلمُها السحرةُ والكَهَنَةُ؟! وأَقْعَدَه قُدّامه، وقال له: لا تَخَفْ. وألْبَسَه طَوْقًا مِن ذهب وثياب حرير، وأعطاه دابَّة مُسْرَجَةً مُزَيَّنة كدابَّة المَلِك، وضُرِب بالطَّبْل بمصر: إنّ يوسفَ خليفةُ الملِك{1}. (٨/٢٧٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٥٩٩<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق أبي سنان، عن عبد الله بن أبي الهذيل- قال: قال الملِك ليوسف: إنِّي أُحِبُّ أن تُخالِطَني في كل شيء إلا في أهلي، وأنا آنَفُ أن تأكل معي. فغضِب يوسفُ ﵇، فقال: أنا أحقُّ أن آنَفُ؛ أنا ابنُ إبراهيم خليل الله، وأنا ابنُ إسحاق ذبيح الله، وأنا ابنُ يعقوب نبي الله{2}. (٨/٢٧٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٦٠٠<span class="dash">-</span></span> عن <span class="name-2">عبد الله بن أبي الهذيل</span> -من طريق أبي سنان- قال: قال العزيزُ ليوسف: ما مِن شيء إلا وأنا أُحِبُّ أن تَشْرَكَني فيه، إلا أنِّي أُحِبُّ أن لا تَشْرَكَني في أهلي، وأن لا يأكل معي عبدي. قال: أتأنفُ أن آكُلَ معك؟! فأنا أحَقُّ أن آنَفَ مِنك، أنا ابن إبراهيم خليل الله، وابن إسحاق الذبيح، وابن يعقوب الذي ابْيَضَّت عيناه مِن الحزن{3}<span class=comment-ref>٣٣٨٧</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٣٣٨٧</span> <span class="comment-type-2">انتقد</span> <u>ابنُ عطية</u> (٥/١٠٧) هذا الأثر بقوله: «وفي هذا الحديث بُعْدٌ وضعف».</div></p><p><div></p><p><p><span class="item-no">٣٧٦٠١<span class="dash">-</span></span> عن <span class="name-2">أبي ميسرة [عمرو بن شرحبيل]</span> -من طريق أبي إسحاق- قال: لَمّا رأى العزيزُ لَبَقَ يوسف وكَيْسَه وظُرفه دعاه، فكان يتغَدّى معه، ويتَعَشّى دون غِلمانه، فلمّا كان بينَه وبين المرأة ما كان قالت: لِمَ تُدْنِي هذا مِن بين غلمانك؟! مُرْهُ فلْيَتَغَدَّ مع الغلمان. فقال له: اذهَبْ، فتَغَدَّ مع الغلمان. فقال له يوسف: أترغب أن تأكل معي؟! أنا –واللهِ- يوسفُ بنُ يعقوبَ نبيِّ الله، ابنِ إسحاقَ ذبيحِ الله، ابنِ إبراهيمَ خليلِ الله{4}<span class=comment-ref>٣٣٨٨</span>. (٨/٢٧٧)</p></p><p></div></p><p><div><span class=comment-ref>٣٣٨٨</span> ساق <u>ابنُ عطية</u> (٥/١٠٧) قول أبي ميسرة، <span class="comment-type-4">ثم علّق</span> بقوله: «أما إنّ الظاهر مِن قصته وقت محاورة الملك أنّه كان على عبودية، وإلا كان اللائق به أن ينتحي بنفسه عن عمل الكافر؛ لأنّ القوم كانوا أهل أوثان، ومحاورة يوسف لصاحبي السجن تقضي بذلك».</div></p><p><div></p><p><p><span class="item-no">٣٧٦٠٢<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿أستخلصه لنفسي﴾</span>، قال: أتَّخِذه لنفسي{5}. (٨/٢٧٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٦٠٣<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- قال: فلمّا وجد المَلِك له عُذْرًا قال: <span class="qpc-hafs">﴿ائتونى به أستخلصه لنفسي﴾</span>{6}. (٨/١٩٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٦٠٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وقالَ المَلِكُ ائْتُونِي بِهِ أسْتَخْلِصْهُ لِنَفْسِي﴾</span>، يعني: أتَّخِذه{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٦٠٥<span class="dash">-</span></span> عن <span class="name-3">محمد بن إسحاق</span> -من طريق سلمة-: قال المَلِكُ الرَّيّان بن الوليد الأكبر: <span class="qpc-hafs">﴿ائتوني به أستخلصه لنفسي﴾</span>{8}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿فَلَمَّا كَلَّمَهُۥ قَالَ إِنَّكَ ٱلۡیَوۡمَ لَدَیۡنَا مَكِینٌ أَمِینࣱ ۝٥٤﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٧٦٠٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فَلَمّا﴾</span> أتاه يوسف، و<span class="qpc-hafs">﴿كَلَّمَهُ﴾</span> أي: كلَّم الملِك؛ <span class="qpc-hafs">﴿قالَ﴾</span> ليوسف: <span class="qpc-hafs">﴿إنَّكَ اليَوْمَ لَدَيْنا مَكِينٌ﴾</span> يقول: عندنا وجِيه <span class="qpc-hafs">﴿أمِينٌ﴾</span> على ما وُكِّلت به. كقوله: <span class="qpc-hafs">﴿عِنْدَ ذِي العَرْشِ مَكِينٍ﴾</span> [التكوير:٢٠]{7}<span class=comment-ref>٣٣٨٩</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٣٣٨٩</span> <span class="comment-type-4">ذكر</span> <u>ابنُ عطية</u> (٥/١٠٧) أن فرقة قالت: <span class="qpc-hafs">﴿أمين﴾</span> بمعنى: آمِن. و<span class="comment-type-2">انتقده</span> <span class="mustanad">مستندًا للسياق، والدلالة العقلية</span>، فقال: «وهذا ضعيف؛ لأنّه يخرج مِن نمط الكلام، ويَنْحَطُّ إكرامُ يوسف كثيرًا».</div></p></div>",footnotes:1:أخرجه ابن عبد الحكم في فتوح مصر ص١٣.|2:أخرجه سعيد بن منصور (١١٢٩ - تفسير)، وابن أبي حاتم ٧/٢١٥٩. وعزاه السيوطي إلى ابن المنذر، وأبي الشيخ.|3:أخرجه ابن جرير ١٣/٢١٧، وفي رواية بلفظ: أنا ابن إبراهيم خليل الله، ابن إسماعيل ذبيح الله.|4:أخرجه ابن جرير ١٣/٢١٧، وابن أبي حاتم ٧/٢١٥٩. وعزاه السيوطي إلى أبي الشيخ.|5:أخرجه ابن جرير ١٣/٢١٦، وابن أبي حاتم ٧/٢١٥٩ من طريق سعيد بن بشير. وعزاه السيوطي إلى أبي الشيخ.|6:أخرجه ابن جرير ١٣/٢١٦، وابن أبي حاتم ٧/٢١٦١.|7:تفسير مقاتل بن سليمان ٢/٣٤٠.|8:أخرجه ابن أبي حاتم ٧/٢١٥٩.|9:تفسير مقاتل بن سليمان ٢/٣٤٠.
  12,55,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿قَالَ ٱجۡعَلۡنِی عَلَىٰ خَزَاۤىِٕنِ ٱلۡأَرۡضِۖ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٧٦٠٧<span class="dash">-</span></span> عن عبد الله بن عباس، قال: قال رسول الله ﷺ: «<b>رَحِم اللهُ أخي يوسف، لو لم يقل: اجعلني على خزائن الأرض. لاسْتَعْمَلَه مِن ساعتِه، ولكنَّه أخَّره لذلك سَنَةً، فأقام في بيته سَنَةً مع المَلِك</b>»{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٦٠٨<span class="dash">-</span></span> قال مقاتل: قال النبي ﷺ: «<b>لو قال: إنِّي حَفِيظ عليم -إن شاء الله-. لَمَلَك مِن يومه ذلك</b>»{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٦٠٩<span class="dash">-</span></span> قال <span class="name-1">عبد الله بن عباس</span>: لَبِث بعد ذلك سنةً ونِصْفًا، ثُمَّ مَلَك أرضَ مِصْرَ{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٦١٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، قال: لَمّا انصَرَمَتِ السنةُ مِن اليوم الذي سأل الإمارة دعاه المَلِك، فتَوَجَّه، [وقلَّده بسيفه]، ووضع له سريرًا مِن ذهب مُكَلَّل بالدُّرِّ والياقوت، وضرب عليه حُلَّةً مِن إستبرق، وطول السرير ثلاثون ذراعًا، وعرضه عشرة أذرع، عليه ثلاثون فراشًا، وستون مِقْرَمَةً{4}، ثم أمره أن يخرج، فخَرَجَ مُتَوَّجًا، ولونه كالثلج، ووجهه كالقمر، يرى الناظرُ وجهَه في صفاء لون وجهه، فانطلق حتى جلس على السرير، ودانَتْ له الملوك، ودخل المَلِك بيتَه، وفوَّض إليه أمرَ مصر، وعَزَل قُطْفِير عمّا كان عليه، وجعل يوسفَ مكانَه. قاله <span class="name-3">ابن إسحاق</span>{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٦١١<span class="dash">-</span></span> قال <span class="name-2">الربيع بن أنس</span>: على خَراج مِصر، ودَخْلِه{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٦١٢<span class="dash">-</span></span> عن <span class="name-2">شيبة بن نعامة الضَّبِّيِّ</span> -من طريق إبراهيم بن المختار- في قوله: <span class="qpc-hafs">﴿اجعلني على خزائن الأرض﴾</span>، يقول: على جميع الطعام{7}. (٨/٢٧٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٦١٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثم <span class="qpc-hafs">﴿قالَ﴾</span> يوسف للملك: <span class="qpc-hafs">﴿اجْعَلْنِي عَلى خَزائِنِ الأَرْضِ﴾</span> بمصر{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٦١٤<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿اجعلنى على خزائن الأرض﴾</span>، قال: كان لفرعون خزائنُ كثيرةٌ غير الطعام، فأسلم سلطانَه كُلَّه له، وجعل القضاء إليه؛ أمره، وقضاؤه نافِذ{9}. (٨/٢٧٩)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿إِنِّی حَفِیظٌ عَلِیمࣱ ۝٥٥﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٧٦١٥<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿إنى حفيظ﴾</span> قال: لِما وُلِّيتُ، <span class="qpc-hafs">﴿عليم﴾</span> بأمره{10}. (٨/٢٧٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٦١٦<span class="dash">-</span></span> عن <span class="name-2">شيبة بن نعامة الضَّبِّيِّ</span> -من طريق إبراهيم بن المختار- في قوله: <span class="qpc-hafs">﴿إنى حفيظ﴾</span> لِما اسْتَوْدَعْتَنِي، <span class="qpc-hafs">﴿عليم﴾</span> بسنين المَجاعَة{11}. (٨/٢٧٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٦١٧<span class="dash">-</span></span> قال <span class="name-3">محمد بن السائب الكلبي</span>: <span class="qpc-hafs">﴿حفيظ﴾</span> بتقديره في السنين الخصبة [في الأرض الجدبة]، <span class="qpc-hafs">﴿عليم﴾</span> بوقت الجُوع حين يَقَع. فقال له المَلِك: ومَن أحقُّ به منك؟! فوَلّاه ذلك، وقال له: <span class="qpc-hafs">﴿إنّك اليوم لدينا مكين﴾</span> ذو مكانة ومنزِلة، <span class="qpc-hafs">﴿أمين﴾</span> على الخزائن{12}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٦١٨<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿إنِّي حَفِيظٌ﴾</span> لِما وكَّلتني به، <span class="qpc-hafs">﴿عَلِيمٌ﴾</span> يعني: عالِم بلُغَة الناس كلها{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٦١٩<span class="dash">-</span></span> عن <span class="name-3">محمد بن إسحاق</span> -من طريق سلمة- <span class="qpc-hafs">﴿إني حفيظ﴾</span>: إنِّي حافِظ لِما اسْتَوْدَعْتَنِي، <span class="qpc-hafs">﴿عليم﴾</span> بما ولَّيْتَنِي، قال: قد فعلتُ. فوَلّاه -فيما يذكرون- عمل إطفير، وعَزَل إطفير عمّا كان عليه{14}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٦٢٠<span class="dash">-</span></span> عن <span class="name-3">سفيان</span> -من طريق الأشجعي- في قوله: <span class="qpc-hafs">﴿إني حفيظ﴾</span> قال: حفيظ للحساب، <span class="qpc-hafs">﴿عليم﴾</span> بالألْسُن{15}. (٨/٢٧٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٦٢١<span class="dash">-</span></span> عن الأشجعي -من طريق عمرو-، مثله{16}<span class=comment-ref>٣٣٩٠</span>. (٨/٢٧٩)</p></p><p></div></p><p><div><span class=comment-ref>٣٣٩٠</span> اختُلِف في المراد بقوله: <span class="qpc-hafs">﴿إني حفيظ عليم﴾</span> على أقوال: <b>الأول</b>: أنّ المعنى: إني حفيظ لما استودعتني، عليم بما وليتني. <b>الثاني</b>: حفيظ بالحساب، عليم بالألسن. <b>الثالث</b>: حفيظ بتقديره في السنين الخصبة، عليم بسني المجاعة.</p><p>و<span class="comment-type-3">رجَّح</span> <u>ابنُ جرير</u> (١٣/٢٢٠) <span class="mustanad">مستندًا إلى السياق</span> القولَ الأول الذي قاله قتادة، وشيبة، وابن إسحاق، فقال: «لأنّ ذلك عقيب قوله: <span class="qpc-hafs">﴿اجعلني على خزائن الأرض﴾</span>، ومسألته الملكِ استكفاءَه خزائن الأرض، فكان إعلامُه بأنّ عنده خبرة في ذلك وكفايته إياه أشبه من إعلامه حفظه الحساب، ومعرفته بالألسن».</p><p>و<span class="comment-type-4">ذكر</span> <u>ابنُ عطية</u> (٥/١٠٨) أنّ <span class="qpc-hafs">﴿حفيظ عليم﴾</span> صفتان تَعُمُّ وجوه التثقيف والحيطة، لا خلل معهما لعامل. و<span class="comment-type-2">انتقد</span> ما جاء في هذه الأقوال من تخصيص، <span class="mustanad">مستندًا لدلالة العموم</span>، فقال: «وهذا كله تخصيص لا وجه له، وإنّما أراد باتصافه أن يعرف الملك بالوجه الذي به يستحق الكون على خزائن الأرض، فاتَّصف بأنه يحفظ المجْبى مِن كل جهة تحتاج إلى الحفظ، ويعلم التناول أجمع».</div></p><p><h3><span class="qpc-hafs">﴿إِنِّی حَفِیظٌ عَلِیمࣱ ۝٥٥﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٣٧٦٢٢<span class="dash">-</span></span> عن <span class="name-1">أبي هريرة</span> -من طريق محمد بن سيرين- قال: اسْتَعْمَلَني عمرُ على البحرين، ثم نزعني وغرَّمني اثني عشر ألفًا، ثم دعاني بعدُ إلى العمل، فأَبَيْتُ، فقال: ولِمَ، وقد سأل يوسفُ ﵇ العملَ وكان خيرًا منك؟ فقلت: إنّ يوسف ﵇ نبيٌّ ابنُ نبيٍّ ابنِ نبيٍّ ابنِ نبيٍّ، وأنا ابنُ أُمَيْمَة، وأنا أخاف أن أقول بغير علم، وأن أُفتِي بغير علم، وأن يُضْرَب ظهري، ويُشتَمَ عِرْضِي، ويؤخذ مالي{17}. (٨/٢٧٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٦٢٣<span class="dash">-</span></span> عن <span class="name-1">جابر بن عبد الله</span>، قال: كان يوسف ﵇ لا يشبع، فقيل له: ما لَك لا تشبعُ وبيدك خزائنُ الأرض؟ قال: إنِّي إذا شَبِعْتُ نَسِيتُ الجائعَ{18}. (٨/٢٧٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٦٢٤<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span>، قال: قيل ليوسف ﵇: تجوع وخزائن الأرض بيدك؟ قال: إنِّي أخاف أن أشبع؛ فأنسى الجِياع{19}. (٨/٢٧٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٦٢٥<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق أبي إسحاق الكوفي- قال: أسلم الملِكُ الذي كان معه يوسفُ ﵇{20}. (٨/٢٧٨)</p></p><p></div></p></div>",footnotes:1:أخرجه الثعلبي في تفسيره٥/٢٣١، والواحدي في التفسير الوسيط ٢/٦١٨ (٤٧٦)، والبغوي في تفسيره ٤/٢٥١. وأورده الديلمي في الفردوس ٢/٢٦٣ (٣٢٢٣).</p><p>قال الحافظ ابن حجر في الكافي الشاف ص٩٠ (٢١٣): «أخرجه الثعلبي عن ابن عباس من رواية إسحاق بن بشر، عن جويبر، عن الضحاك عنه. وهذا إسناد ساقط». وقال الألباني في الضعيفة ١/٤٩٩ (٣٢٩): «موضوع».|2:تفسير مقاتل بن سليمان ٢/٣٤٠.|3:تفسير مقاتل بن سليمان ٢/٣٤٠.|4:القِرامُ: ثوب من صوف ملون فيه ألوان من العِهن، وهو صفيق يتخذ سترًا. وقيل: هو السِّتر الرقيق، والجمع قُرُم، وهو المِقْرَمَة. وقيل: المِقْرَمَةُ مَحبِس الفِراش. لسان العرب (قرم).|5:تفسير الثعلبي ٥/٢٣٢، وتفسير البغوي ٤/٢٥٢.|6:تفسير البغوي ٤/٢٥١.|7:أخرجه ابن جرير ١٣/٢١٩ بلفظ: على حفظ الطعام، وابن أبي حاتم ٧/٢١٦٠. وعزاه السيوطي إلى أبي الشيخ.|8:تفسير مقاتل بن سليمان ٢/٣٤٠.|9:أخرجه ابن جرير ١٣/٢١٨. وعزاه السيوطي إلى ابن أبي حاتم.|10:أخرجه ابن جرير ١٣/٢١٩. وعزاه السيوطي إلى ابن أبي حاتم.|11:أخرجه ابن جرير ١٣/٢١٩، وابن أبي حاتم ٧/٢١٦٠. وعزاه السيوطي إلى أبي الشيخ.|12:تفسير الثعلبي ٥/٢٣١، وتفسير البغوي ٤/٢٥١.|13:تفسير مقاتل بن سليمان ٢/٣٤٠.|14:أخرجه ابن جرير ١٣/٢١٩، وابن أبي حاتم ٧/٢١٦٠.|15:أخرجه ابن أبي حاتم ٧/٢١٦٠.|16:أخرجه ابن جرير ١٣/٢١٩. وعزاه السيوطي إلى أبي الشيخ.|17:أخرجه ابن أبي حاتم ٧/٢١٦٠ مقتصرًا على أوله، والحاكم ٢/٣٤٧.|18:عزاه السيوطي إلى الخطيب في رواة مالك.|19:أخرجه البيهقي في شعب الإيمان (٥٦٨٣). وعزاه السيوطي إلى وكيع في الغرر، وأبي الشيخ.|20:أخرجه ابن جرير ١٣/٢٢٢.
  12,56,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَكَذَ ٰ⁠لِكَ مَكَّنَّا لِیُوسُفَ فِی ٱلۡأَرۡضِ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٧٦٢٦<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- <span class="qpc-hafs">﴿وكذلك مكنا ليوسف في الأرض يتبوأ منها حيث يشاء﴾</span>، قال: استعمله الملِك على مصر، وكان صاحبَ أمرها، وكان يلي البيعَ والتجارةَ وأمرَها كُلَّه، فذلك قوله: <span class="qpc-hafs">﴿وكذلك مكنا ليوسف في الأرض يتبوأ منها حيث يشاء﴾</span>{1}. (ز) (٨/١٩٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٦٢٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وكَذلِكَ مَكَّنّا لِيُوسُفَ﴾</span> يعني: وهكذا مَكَّنّا ليوسف المُلْكَ <span class="qpc-hafs">﴿فِي الأَرْضِ﴾</span> في أرض مصر{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٦٢٨<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿وكذلك مكنا ليوسف في الأرض﴾</span>، قال: مَلَّكناه فيما يكون فيها{3}. (٨/٢٧٩)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿یَتَبَوَّأُ مِنۡهَا حَیۡثُ یَشَاۤءُۚ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٧٦٢٩<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span> -من طريق عطاء بن دينار- في قول الله: <span class="qpc-hafs">﴿يتبوأ منها حيث يشاء﴾</span>، يقول: ينزل منها حيث يشاء{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٦٣٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿يَتَبَوَّأُ﴾</span> يقول: ينزل <span class="qpc-hafs">﴿مِنها حَيْثُ يَشاءُ﴾</span>{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٦٣١<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿حيث يشاء﴾</span> مِن تلك الدنيا، يصنع فيها ما يشاء، فُوِّضَت إليه. قال: لو شاء أن يجعل فرعون من تحت يده، ويجعله من فوق لَفَعَل{3}. (٨/٢٧٩)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿یَتَبَوَّأُ مِنۡهَا حَیۡثُ یَشَاۤءُۚ﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٣٧٦٣٢<span class="dash">-</span></span> عن <span class="name-2">بكر بن عبد الله</span>، قال: دخلت امرأةُ العزيز على يوسف، فلمّا رَأَتْه عَرَفَتْه، وقالت: الحمدُ لله الذي صيَّر العبيدَ بطاعته مُلوكًا، وجعل الملوك بمعصيته عبيدًا{7}. (٨/٢٤٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٦٣٣<span class="dash">-</span></span> عن عبد الله بن منبه، عن أبيه، قال: تَعَرَّضَتْ امرأةُ العزيز ليوسف ﵇ في الطريق حين مَرَّ بها، فقالت: الحمدُ لله الذى جعل الملوكَ بمعصيته عبيدًا، وجعل العبيد بطاعته ملوكًا، فعرَفها، فتزوَّجها، فوجدها بِكْرًا، وكان صاحبُها مِن قبلُ لا يأتي النساءَ{8}. (٨/٢٨٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٦٣٤<span class="dash">-</span></span> عن <span class="name-2">وهب بن مُنَبِّه</span>، قال: أصابت امرأةُ العزيزِ حاجَةً لها، فقيل لها: لو أتيتِ يوسفَ بن يعقوب فسَأَلْتِهِ. فاستشارت الناسَ في ذلك، فقالوا: لا تفعلي؛ فإنّا نخاف عليك. قالت: كَلّا، إنِّي لا أخافُ مِمَّن يخاف الله. فدَخَلَتْ عليه، فرَأَتْه في مُلْكِه، فقالت: الحمدُ لله الذي جعل العبيدَ ملوكًا بطاعته. ثُمَّ نظرت إلى نفسها، فقالت: الحمد لله الذي جعل الملوكَ عبيدًا بمعصيته. فقضى لها جميع حوائجها، ثم تزوَّجها، فوجدها بِكْرًا، فقال لها: أليس هذا أجملَ مِمّا أردتِ؟ قالت: يا نبيَّ الله، إنِّي ابتُليتُ فيكَ بأربع: كنتَ أجملَ الناس كلهم، وكنتُ أنا أجمل أهل زماني، وكنتُ بكرًا، وكان زوجي عِنِّينًا{9}. (٨/٢٨١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٦٣٥<span class="dash">-</span></span> عن <span class="name-2">زيد بن أسلم</span>: أنّ يوسف ﵇ تَزَوَّج امرأةَ العزيز، فوجدها بِكْرًا، وكان زوجُها عِنِّينًا{8}. (٨/٢٨١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٦٣٦<span class="dash">-</span></span> عن <span class="name-3">محمد بن إسحاق</span> -من طريق سلمة- قال: ذكروا أنّ إطفير هَلَك في تلك الليالي، وأنّ الملك الرَّيّان زوج يوسف ﵇ امرأته راعيل، فقال لها حين أُدخِلَتْ عليه: أليس هذا خيرًا مما كنتِ تريدين؟ فقالت: أيُّها الصِّديق، لا تَلُمْنِي، فإنِّي كنتُ امرأةً كما ترى حسناء جَمْلاء ناعِمةً في مُلْك ودُنيا، وكان صاحبي لا يأتي النساء، وكنتَ كما جعلك الله في حُسْنِك وهيئتك، فغَلَبَتْنِي نفسي على ما رأيتَ. فيزعمون أنّه وجَدَها عَذْراء، فأصابها، فوَلَدَت له رجلين؛ أفراييم بن يوسف، ومنشا بن يوسف{11}. (٨/٢٨٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٦٣٧<span class="dash">-</span></span> عن <span class="name-3">فضيل بن عياض</span> -من طريق قادم الديلمي العابد- قال: وقَفَتِ امرأةُ العزيز على ظَهْرِ الطريق حتى مرَّ يوسفُ ﵇، فقالت: الحمد لله الذي جعل العبيدَ ملوكًا بطاعته، وجعل الملوك عبيدًا بمعصيته{12}<span class=comment-ref>٣٣٩١</span>. (٨/٢٨٠)</p></p><p></div></p><p><div><span class=comment-ref>٣٣٩١</span> ساق <u>ابنُ عطية</u> (٥/١٠٩) هذه الآثار، ثم <span class="comment-type-4">علّق</span> بقوله: «ورُوِي في نحو هذا مِن القصص ما لا يوقف على صحته، ويطول الكلام بسوقه».</div></p><p><h3><span class="qpc-hafs">﴿نُصِیبُ بِرَحۡمَتِنَا مَن نَّشَاۤءُۖ وَلَا نُضِیعُ أَجۡرَ ٱلۡمُحۡسِنِینَ ۝٥٦﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٧٦٣٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، في قوله: <span class="qpc-hafs">﴿ولا نضيع أجر المحسنين﴾</span>، قال: يعني: الصابرين{13}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٦٣٩<span class="dash">-</span></span> قال <span class="name-2">مجاهد بن جبر</span>: فلم يزل يوسفُ ﵇ يدعو المَلِك إلى الإسلام ويَتَلَطَّف له حتى أسْلَم الملِكُ، وكثيرٌ من الناس. فهذا في الدنيا{13}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٦٤٠<span class="dash">-</span></span> عن <span class="name-2">وهب بن مُنَبِّه</span>، في قوله: <span class="qpc-hafs">﴿ولا نضيع أجر المحسنين﴾</span>، قال: يعني: الصّابرين{13}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٦٤١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿نُصِيبُ بِرَحْمَتِنا﴾</span> يعني: سَعَتَنا <span class="qpc-hafs">﴿مَن نَشاءُ ولا نُضِيعُ أجْرَ المُحْسِنِينَ﴾</span> يعني: نُوَفِّيه جزاءه، فجزاه الله بالصبر على البلاء، والصبر عن المعصية بأن ملَّكه على مصر{2}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿نُصِیبُ بِرَحۡمَتِنَا مَن نَّشَاۤءُۖ وَلَا نُضِیعُ أَجۡرَ ٱلۡمُحۡسِنِینَ ۝٥٦﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٣٧٦٤٢<span class="dash">-</span></span> عن أنس بن مالك، عن رسول الله ﷺ أنّه قال: «<b>اطلبوا الخيرَ دهرَكم كُلَّه، وتعرَّضوا لِنَفَحات رحمةِ الله، فإنّ لله ﷿ نفحاتٍ مِن رحمته يصيب بها مَن يشاء مِن عباده، واسألوا اللهَ أن يستر عَوْراتِكم، ويُؤَمِّن رَوْعاتكم</b>»{17}. (٨/٢٨١)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ١٣/٢٢١، وابن أبي حاتم ٧/٢١٦١ مختصرًا.|2:تفسير مقاتل بن سليمان ٢/٣٤١.|3:أخرجه ابن جرير ١٣/٢٢١، وابن أبي حاتم ٧/٢١٦١ من طريق أصبغ بن الفرج.|4:أخرجه ابن أبي حاتم ٧/٢١٦١.|5:تفسير مقاتل بن سليمان ٢/٣٤١.|6:أخرجه ابن جرير ١٣/٢٢١، وابن أبي حاتم ٧/٢١٦١ من طريق أصبغ بن الفرج.|7:عزاه السيوطي إلى ابن المنذر.|8:عزاه السيوطي إلى أبي الشيخ.|9:أخرجه الحكيم الترمذي ٢/١٨١، ٣/٣٥.|10:عزاه السيوطي إلى أبي الشيخ.|11:أخرجه ابن جرير ١٣/٢٢٠-٢٢١، وابن أبي حاتم ٧/٢١٦١.|12:أخرجه ابن أبي حاتم ٧/٢١٦٢.|13:تفسير الثعلبي ٥/٢٣٣، وتفسير البغوي ٤/٢٥٢.|14:تفسير الثعلبي ٥/٢٣٣، وتفسير البغوي ٤/٢٥٢.|15:تفسير الثعلبي ٥/٢٣٣، وتفسير البغوي ٤/٢٥٢.|16:تفسير مقاتل بن سليمان ٢/٣٤١.|17:أخرجه البيهقي في الأسماء والصفات ١/٣٧٨-٣٧٩ (٣٠٦)، والبغوي في شرح السنة ٥/١٧٩ (١٣٧٨).</p><p>قال البغوي: «هذا حديث غريب». وقال المناوي في التيسير ١/١٦٤: «رمز المؤلف -السيوطي- لضعفه، وقول العامري:»حسن صحيح«باطل». وقال الألباني في الضعيفة ٦/٣١٣ (٢٧٩٨): «ضعيف».
  12,57,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَلَأَجۡرُ ٱلۡـَٔاخِرَةِ خَیۡرࣱ لِّلَّذِینَ ءَامَنُوا۟﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٧٦٤٣<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- <span class="qpc-hafs">﴿ولأجر الآخرة خير﴾</span>، يقول: باقِيَة{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٦٤٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثم قال: <span class="qpc-hafs">﴿ولَأَجْرُ الآخِرَةِ خَيْرٌ﴾</span> يعني: أكبر، يعني: جزاء الآخرة أفضلُ مِمّا أُعْطِي في الدنيا مِن الملك <span class="qpc-hafs">﴿لِلَّذِينَ آمَنُوا﴾</span> يعني: صدَّقوا بالتوحيد{2}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَكَانُوا۟ یَتَّقُونَ ۝٥٧﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٧٦٤٥<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- <span class="qpc-hafs">﴿يتقون﴾</span>: يُطِيعونه{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٦٤٦<span class="dash">-</span></span> عن مالك بن دينار، قال: سألتُ <span class="name-2">الحسن البصري</span>، فقلتُ: يا أبا سعيد، قوله: <span class="qpc-hafs">﴿ولأجر الآخرة خير للذين آمنوا وكانوا يتقون﴾</span>، ما هِيَه؟ قال: يا مالك، اتَّقَوُا المحارمَ، خَمِصَت بطونُهم؛ تركوا المحارم وهم يشتهونها{4}. (٨/٢٨٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٦٤٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وكانُوا يَتَّقُونَ﴾</span> الشِّرْكَ، مِثْل الذي اتَّقى يوسفُ ﵇{2}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن أبي حاتم ٧/٢١٦٢.|2:تفسير مقاتل بن سليمان ٢/٣٤١.|3:أخرجه ابن أبي حاتم ٧/٢١٦٢.|4:أخرجه ابن أبي حاتم ٧/٢١٦٢ (١١٧٢٨). وعزاه السيوطي إلى أبي الشيخ.|5:تفسير مقاتل بن سليمان ٢/٣٤١.
  12,58,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَجَاۤءَ إِخۡوَةُ یُوسُفَ فَدَخَلُوا۟ عَلَیۡهِ فَعَرَفَهُمۡ وَهُمۡ لَهُۥ مُنكِرُونَ ۝٥٨﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٧٦٤٨<span class="dash">-</span></span> قال <span class="name-1">عبد الله بن عباس</span>: عرفهم بأوَّل ما نظر إليهم{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٦٤٩<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عُبادَة الأسَدي- قال: إنّ إخوة يوسف لَمّا دخلوا عليه فعرَفهم وهم له منكرون؛ جاء بصُواع الملك الذي كان يشرب فيه، فوَضَعه على يده، فجعل ينقُرُهُ ويَطِنُّ، وينقُرُه ويَطِنُّ، فقال: إنّ هذا الجامَ لَيُخْبِرُني عنكم خَبَرًا، هل كان لكم أخ مِن أبيكم يُقال له: يوسف، وكان أبوه يُحِبُّه دونكم، وإنّكم انطلقتم به فألقيتموه في الجُبِّ، وأخبرتم أباكم أنّ الذئب أكله، وجئتم على قميصه بدم كذب؟ قال: فجعل بعضُهم ينظر إلى بعض، ويعجبون أنّ هذا الجامَ لَيُخْبِرُ خَبرَهم، فمِن أين يعلم هذا؟! قال ابنُ عباس: فلا نرى هذه الآيةَ نزلت إلا فيهم: <span class="qpc-hafs">﴿لتنبئنهم بأمرهم هذا وهم لا يشعرون﴾</span> [يوسف:١٥]{2}. (٨/٢٨٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٦٥٠<span class="dash">-</span></span> قال <span class="name-1">عبد الله بن عباس</span>: وكان بين أن قذفوه في البئر وبين أن دخلوا عليه أربعون سنة، فلذلك أنكروه{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٦٥١<span class="dash">-</span></span> عن <span class="name-2">أبي الجَلْد</span> -من طريق سفيان- قال: قال يوسف ﵇ لإخوته: إنّ أمرَكم لَيَرِيبُنِي، كأنّكم جواسيس. قالوا: يا أيها العزيز، إنّ أبانا شيخ صِدِّيق، وإنّا قومٌ صِدِّيقون، وإنّ الله يُحْيِي بكلام الأنبياء القلوبَ كما يُحْيِي وابلُ السماءِ الأرضَ. ويقول لهم وفي يده الإناءُ وهو يَقْرَعُه القَرْعَةَ: كأنّ هذا يخبر عنكم بأنّكم جواسيس{4}. (٨/٢٨٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٦٥٢<span class="dash">-</span></span> قال <span class="name-2">مجاهد بن جبر</span>: عرفهم بأوَّلِ ما نَظَر إليهم{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٦٥٣<span class="dash">-</span></span> قال <span class="name-2">عطاء</span>: إنّما لم يعرفوه لأنّه كان على سرير المَلِك، وعلى رأسه تاج المُلْك{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٦٥٤<span class="dash">-</span></span> عن ابن عون، قال: قلتُ <span class="name-2">للحسن البصري</span>: تُرى يوسف عرَف إخوتَه؟ قال: لا، واللهِ، ما عرَفهم حتى تعرَّفوا إليه{7}. (٨/٢٨٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٦٥٥<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق مَعْمَر- في قوله: <span class="qpc-hafs">﴿فعرفهم وهم له منكرون﴾</span>، قال: لا يعرِفونه{8}. (٨/٢٨٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٦٥٦<span class="dash">-</span></span> عن <span class="name-2">وهب بن مُنَبِّه</span>، قال: لَمّا جعَل يوسفُ ﵇ ينقُر الصاعَ ويُخْبِرُهم؛ قام إليه بعضُ إخوتُه، فقال: أنشُدُك باللهِ ألّا تَكْشِف لنا عَوْرَةً{9}. (٨/٢٨٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٦٥٧<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- قال: فأصابَ الأرضَ الجوعُ، وأصاب بلادَ يعقوب التي كان فيها، فبعث بنيه إلى مصر، وأمسك بنيامين أخا يوسف، فلمّا دخلوا على يوسف <span class="qpc-hafs">﴿فَعَرَفَهُم وهم له منكرون﴾</span>، فلمّا نظر إليهم أخذهم، وأدخلهم الدار، وأدخل المَكُّوكَ{10}، وقال لهم: أخْبِرُوني، ما أمرُكم؟ فإنِّي أُنكِرُ شأنَكم. قالوا: نحن مِن أرض الشام. قال: فما جاء بكم؟ قالوا: نَمْتارُ طعامًا. قال: كذبتم، أنتم عُيُون، كم أنتم؟ قالوا: نحن عشرة. قال: أنتم عشرة آلاف؛ كل رجل منكم أميرُ ألف، فأخبِرُوني خبركم. قالوا: إنّا إخْوَةٌ، بنو رجل صِدِّيقٍ، وإنّا كُنّا اثني عشر، فكان يُحِبُّ أخًا لنا، وإنّه ذَهَبَ معنا إلى البَرِّيَّةِ، فهَلَكَ مِنّا فيها، وكانَ أحبَّنا إلى أبينا. قال: فإلى مَن يسكن أبوكُم بعده؟ قالوا: إلى أخٍ له أصغر منه. قال: كيف تُحَدِّثوني أنّ أباكم صِدِّيق، وهو يُحِبُّ الصغير منكم دون الكبير؟! ائْتوني بأخيكم هذا حتى أنظر إليه، <span class="qpc-hafs">﴿فإن لم تأتونى به فلا كيل لكم عندى ولا تقربون﴾</span>. قالوا: <span class="qpc-hafs">﴿سنراود عنه أباه وإنا لفاعلون﴾</span>. قال: فإني أخشى ألا تأتوني به، فضعوا بعضَكم رهينةً حتى ترجعوا. فارْتَهَنَ شَمْعُون عنده{11}<span class=comment-ref>٣٣٩٢</span>. (٨/١٩٣)</p></p><p></div></p><p><div><span class=comment-ref>٣٣٩٢</span> <span class="comment-type-2">انتَقَد</span> <u>ابنُ كثير</u> (٨/٥٤) ما قاله السدي مِن أنّ يوسف قد أخذ منهم رهائن حتى يقدموا بأخيهم معهم <span class="mustanad">مستندًا للدلالة العقلية</span>، فقال: «وفي هذا نظر؛ لأنّه أحسن إليهم، ورغَّبهم كثيرًا، وهذا لحرصه على رجوعهم».</div></p><p><div></p><p><p><span class="item-no">٣٧٦٥٨<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وجاءَ إخْوَةُ يُوسُفَ﴾</span> مِن أرض كَنْعان، <span class="qpc-hafs">﴿فَدَخَلُوا عَلَيْهِ﴾</span> أي: على يوسف بمِصْر، <span class="qpc-hafs">﴿فَعَرَفَهُمْ﴾</span> يوسفُ، <span class="qpc-hafs">﴿وهُمْ لَهُ مُنْكِرُونَ﴾</span> يقول: وهم لا يعرفون يوسف. فقال: مَن أنتم؟ قالوا: نحن بنو يعقوب، نحن من أهل كنعان. قال: كَم أنتم؟ قالوا: نحنُ أحد عشر. قال: ما لي لا أرى الأحدَ عشر؟ قالوا: واحِدٌ مِنّا عند أبينا. قال: ولِم ذلك؟ قالوا: إنّ أخاه لأمه أكله الذئب، فلذلك تركناه عند أبينا، فهو يستريح إليه{12}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٦٥٩<span class="dash">-</span></span> عن <span class="name-3">محمد بن إسحاق</span> -من طريق سلمة- قال: لَمّا اطمأن يوسفُ في مُلْكِه، وخرج مِن البلاء الذي كان فيه، وخَلَت السنون المُخْصِبة التي كان أمرهم بالإعداد فيها للسِّنين التي أخبرهم بها أنها كائنة؛ جُهِدَ الناسُ{13} في كل وجْهٍ، وضربوا إلى مصر يلتمسون بها المِيرَةَ مِن كل بلدة، وكان يوسفُ حين رأى ما أصاب الناس مِن الجَهْدِ قد آسى بينهم، وكان لا يحمل للرجل إلا بعيرًا واحدًا، ولا يحمل للرجل الواحد بعيرين؛ تقسيطًا بين الناس، وتوسيعًا عليهم، فقَدِم إخوتُه فيمن قَدِم عليه من الناس، يلتمسون الميرَة مِن مصر، فعرفهم وهم له منكرون؛ لِما أراد اللهُ أن يبلغ ليوسف ﵇ ما أراد{14}<span class=comment-ref>٣٣٩٣</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٣٣٩٣</span> ساق <u>ابنُ عطية</u> (٥/١١١) ما أفادته هذه الآثار، ثم <span class="comment-type-4">علّق</span> بقوله: «وفي ذلك قصص طويل جاءت الإشارة إليه في القرآن وجيزة». و<span class="comment-type-4">ذكر</span> (٥/١١٢) أنه رُوي عن النبي ﷺ أنه قال: «كان يوسف يلقي حصاة في إناء فضة مخوص بالذهب، فيطِنُّ، فيقول لهم: إنّ هذا الإناء يخبرني أن لكم أبا شيخًا». ثم <span class="comment-type-4">علّق</span> بقوله: «كأنها حيلة وإيهام لهم». و<span class="comment-type-4">بيّن</span> أنّ الظاهر أنّ كل ما فعله يوسف معهم أنّه بوحي وأمْر، وإلا فكان بِرُّ يعقوب يقتضي أن يبادر إليه ويستدعيه، لكن الله تعالى أعلمه بما يصنع ليكمل أجر يعقوب ومحنته، وتتفسر الرؤيا الأولى.</p><p>و<span class="comment-type-4">ذكر</span> <u>ابنُ كثير</u> (٨/٥٤) أنّ ما ذكره بعض المفسرين من أنّه باعهم في السنة الأولى بالأموال، وفي الثانية بالمتاع، وفي الثالثة بكذا، وفي الرابعة بكذا، حتى باعهم بأنفسهم وأولادهم بعدما تملك عليهم جميع ما يملكون، ثم أعتقهم وردَّ عليهم أموالهم كلها؛ أنه من الإسرائيليات التي لا تصدق ولا تكذب.</div></p></div>",footnotes:1:تفسير البغوي ٤/٢٥٤.|2:أخرجه ابن جرير ١٣/٣٣، وابن أبي حاتم ٧/٢١٦٢. وعزاه السيوطي إلى أبي الشيخ دون آخره.|3:تفسير الثعلبي ٥/٢٣٤، وتفسير البغوي ٤/٢٥٤.|4:أخرجه ابن أبي حاتم ٧/٢١٦٣.|5:تفسير البغوي ٤/٢٥٤.|6:تفسير البغوي ٤/٢٥٤.|7:عزاه السيوطي إلى ابن أبي حاتم، وأبي الشيخ.|8:أخرجه عبد الرزاق ١/٣٢٥، وابن جرير ١٣/٢٢٤، وابن أبي حاتم ٧/٢١٦٣. وعزاه السيوطي إلى ابن المنذر.|9:عزاه السيوطي إلى أبي الشيخ.|10:المكوك: اسم للمكيال، ويختلف مقداره باختلاف اصطلاح الناس عليه في البلاد. النهاية (مكك).|11:أخرجه ابن جرير ١٣/٢٢٣-٢٢٤، وابن أبي حاتم ٧/٢١٦٣-٢١٦٤.|12:تفسير مقاتل بن سليمان ٢/٣٤١.|13:جُهِدَ الناس: أجدبوا. النهاية (جهد).|14:أخرجه ابن جرير ١٣/٢٢٢-٢٢٣.
  12,59,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَلَمَّا جَهَّزَهُم بِجَهَازِهِمۡ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٧٦٦٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ولَمّا جَهَّزَهُمْ﴾</span> يوسفُ <span class="qpc-hafs">﴿بِجَهازِهِمْ﴾</span> يعني: في أمر الطعام{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٦٦١<span class="dash">-</span></span> عن <span class="name-3">محمد بن إسحاق</span> -من طريق سلمة- قال: لَمّا جهز يوسفُ فيمَن جَهَّز مِن الناس؛ حَمل لكلِّ رجلٍ منهم بعيرًا بعِدَّتهم{2}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿قَالَ ٱئۡتُونِی بِأَخࣲ لَّكُم مِّنۡ أَبِیكُمۡۚ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٧٦٦٢<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿ائتونى بأخ لكم من أبيكم﴾</span>، قال: يعني: بنيامين، وهو أخو يوسف لأبيه وأمه{3}. (٨/٢٨٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٦٦٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿قالَ ائْتُونِي بِأَخٍ لَكُمْ مِن أبِيكُمْ﴾</span>، يعني: بِنيامين، وكان أخاهم مِن أبيهم، وكان أخا يوسف لأبيه وأُمِّه{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٦٦٤<span class="dash">-</span></span> عن <span class="name-3">محمد بن إسحاق</span> -من طريق سلمة- قال: ثُمَّ قال لهم: <span class="qpc-hafs">﴿ائتوني بأخ لكم من أبيكم﴾</span> أجعل لكم بعيرًا آخر. أو كما قال{5}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿أَلَا تَرَوۡنَ أَنِّیۤ أُوفِی ٱلۡكَیۡلَ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٧٦٦٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ألا تَرَوْنَ أنِّي أُوفِي﴾</span> يعني: أوفي لكم <span class="qpc-hafs">﴿الكَيْلَ﴾</span>{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٦٦٦<span class="dash">-</span></span> عن <span class="name-3">محمد بن إسحاق</span> -من طريق سلمة- <span class="qpc-hafs">﴿ألا ترون أني أوفي الكيل﴾</span>، أي: لا أبْخَسُ الناسَ شيئًا{5}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَأَنَا۠ خَیۡرُ ٱلۡمُنزِلِینَ ۝٥٩﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٧٦٦٧<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق أبي رَوْق، عن الضَّحّاك- في قوله: <span class="qpc-hafs">﴿وأنا خير المنزلين﴾</span>، قال: خير مَن يَضِيُف بمِصر{8}. (٨/٢٨٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٦٦٨<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح-: <span class="qpc-hafs">﴿وأنا خير المنزلين﴾</span>، قال يوسف ﵇: أنا خيرُ مَن يضيف بمصر{5}. (٨/٢٨٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٦٦٩<span class="dash">-</span></span> عن <span class="name-3">عبد الملك ابن جُرَيج</span>، في قوله: <span class="qpc-hafs">﴿وأنا خير المنزلين﴾</span>، قال: خير المُضِيفين{10}. (٨/٢٨٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٦٧٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وأَنا خَيْرُ المُنْزِلِينَ﴾</span>: وأنا أفضلُ مَن يضيف بمصر{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٦٧١<span class="dash">-</span></span> عن <span class="name-3">محمد بن إسحاق</span> -من طريق سلمة- <span class="qpc-hafs">﴿وأنا خير المنزلين﴾</span>، أي: خيرٌ لكم مِن غيري، فإنّكم إن أتيتُم به أكرمتُ منزلتكم، وأحسنتُ إليكم، وازددتُم به بعيرًا مَعَ عِدَّتكم، فإنِّي لا أُعطي كلَّ رجل منكم إلا بعيرًا{12}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٢/٣٤١.|2:أخرجه ابن جرير ١٣/٢٢٥، وابن أبي حاتم ٧/٢١٦٣.|3:أخرجه ابن جرير ١٣/٢٢٥، وابن أبي حاتم ٧/٢١٦٣ من طريق سعيد بن أبي عروبة.|4:تفسير مقاتل بن سليمان ٢/٣٤١.|5:أخرجه ابن جرير ١٣/٢٢٥.|6:تفسير مقاتل بن سليمان ٢/٣٤١.|7:أخرجه ابن جرير ١٣/٢٢٥.|8:أخرجه ابن أبي حاتم ٧/٢١٦٤. وعزاه السيوطي إلى أبي الشيخ.|9:أخرجه ابن جرير ١٣/٢٢٥.|10:عزاه السيوطي إلى ابن المنذر.|11:تفسير مقاتل بن سليمان ٢/٣٤١.|12:أخرجه ابن جرير ١٣/٢٢٥، وابن أبي حاتم ٧/٢١٦٤.
  12,60,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿فَإِن لَّمۡ تَأۡتُونِی بِهِۦ فَلَا كَیۡلَ لَكُمۡ عِندِی وَلَا تَقۡرَبُونِ ۝٦٠﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٧٦٧٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فَإنْ لَمْ تَأْتُونِي بِهِ فَلا كَيْلَ لَكُمْ﴾</span> يعني: فلا بيع لكم <span class="qpc-hafs">﴿عِنْدِي﴾</span> مِن الطعام <span class="qpc-hafs">﴿ولا تَقْرَبُونِ﴾</span> بلادي{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٦٧٣<span class="dash">-</span></span> عن <span class="name-3">محمد بن إسحاق</span> -من طريق سلمة- <span class="qpc-hafs">﴿فإن لم تأتوني به فلا كيل لكم عندي ولا تقربون﴾</span>، قال: لا تقربوا بلدي{2}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٢/٣٤٢.|2:أخرجه ابن جرير ١٣/٢٢٥، وابن أبي حاتم ٧/٢١٦٤.
  12,61,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿قَالُوا۟ سَنُرَ ٰ⁠وِدُ عَنۡهُ أَبَاهُ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٧٦٧٤<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، في قوله: <span class="qpc-hafs">﴿قالُوا سَنُراوِدُ عَنْهُ أباهُ﴾</span>، قال: سنخدعه حتى يُخرجَه معنا{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٦٧٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿قالُوا سَنُراوِدُ عَنْهُ أباهُ﴾</span> يعقوب{2}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَإِنَّا لَفَـٰعِلُونَ ۝٦١﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٧٦٧٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وإنّا لَفاعِلُونَ﴾</span> ذلك بأبيه{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٦٧٧<span class="dash">-</span></span> عن <span class="name-3">محمد بن إسحاق</span> -من طريق سلمة- <span class="qpc-hafs">﴿وإنا لفاعلون﴾</span>: لَنَجْتَهِدَنَّ{4}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير الثعلبي ٥/٢٣٥.|2:تفسير مقاتل بن سليمان ٢/٣٤٢.|3:تفسير مقاتل بن سليمان ٢/٣٤٢.|4:أخرجه ابن جرير ١٣/٢٢٦، وابن أبي حاتم ٧/٢١٦٤.
  12,62,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَقَالَ لِفِتۡیَـٰنِهِ ٱجۡعَلُوا۟ بِضَـٰعَتَهُمۡ فِی رِحَالِهِمۡ لَعَلَّهُمۡ یَعۡرِفُونَهَاۤ إِذَا ٱنقَلَبُوۤا۟ إِلَىٰۤ أَهۡلِهِمۡ لَعَلَّهُمۡ یَرۡجِعُونَ ۝٦٢﴾</span> - قراءات</h3></p><p><div></p><p><p><span class="item-no">٣٧٦٧٨<span class="dash">-</span></span> عن <span class="name-2">إبراهيم النخعي</span> أنّه كان يقرأ: ‹وقالَ لِفِتْيَتِهِ›{1}. (٨/٢٨٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٦٧٩<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق عوف، وعباد بن راشد- أنّه كان يقرأ: <span class="qpc-hafs">﴿لِفِتْيانِهِ﴾</span>{2}<span class=comment-ref>٣٣٩٤</span>. (٨/٢٨٤)</p></p><p></div></p><p><div><span class=comment-ref>٣٣٩٤</span> اختُلِف في قراءة قوله: <span class="qpc-hafs">﴿لفتيانه﴾</span>؛ <b>فقرأ قوم</b>: <span class="qpc-hafs">﴿لفتيانه﴾</span>. و<b>قرأ آخرون</b>: ‹لِفِتْيَتِهِ›. و<span class="comment-type-4">ذكر</span> <u>ابنُ عطية</u> (٥/١١٢) أنّ فتيان للكثرة -على مراعاة المأمورين-، وفتية للقلّة -على مراعاة المتناولين، وهم الخدمة-، ثم <span class="comment-type-4">علّق</span> بقوله: «ويكون هذا الوصف للحُرِّ والعبد».</div></p><p><h3><span class="qpc-hafs">﴿وَقَالَ لِفِتۡیَـٰنِهِ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٧٦٨٠<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿لِفِتْيانِهِ﴾</span>، أي: لغلمانه{3}. (٨/٢٨٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٦٨١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وقالَ﴾</span> يوسف: <span class="qpc-hafs">﴿لِفِتْيانِهِ﴾</span> يعني: لِخُدّامه وهم يكيلون لهم الطعام{4}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿ٱجۡعَلُوا۟ بِضَـٰعَتَهُمۡ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٧٦٨٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق الضَّحّاك- في قوله: <span class="qpc-hafs">﴿اجعلوا بضاعتهم﴾</span>: كانت النِّعال، والأُدْمَ{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٦٨٣<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿اجعلوا بضاعتهم﴾</span>، أي: أوراقَهم{6}. (٨/٢٨٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٦٨٤<span class="dash">-</span></span> قال <span class="name-3">محمد بن السائب الكلبي</span>: تَخَوَّف أن لا يكون عند أبيه مِن الوَرِق ما يرجعون به مَرَّة أخرى{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٦٨٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿اجْعَلُوا بِضاعَتَهُمْ﴾</span>، يعني: دراهمهم{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٦٨٦<span class="dash">-</span></span> عن <span class="name-3">محمد بن إسحاق</span> -من طريق سلمة- قال: ثُمَّ أمر ببضاعتهم التي أعطاهم بها ما أعطاهم مِن الطعام، فجعلت في رحالهم وهم لا يعلمون{9}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿فِی رِحَالِهِمۡ لَعَلَّهُمۡ یَعۡرِفُونَهَاۤ إِذَا ٱنقَلَبُوۤا۟ إِلَىٰۤ أَهۡلِهِمۡ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٧٦٨٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فِي رِحالِهِمْ﴾</span> يعني: في أوعيتهم <span class="qpc-hafs">﴿لَعَلَّهُمْ﴾</span> يعني: لكي <span class="qpc-hafs">﴿يَعْرِفُونَها إذا انْقَلَبُوا إلى أهْلِهِمْ﴾</span>{4}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿لَعَلَّهُمۡ یَرۡجِعُونَ ۝٦٢﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٧٦٨٨<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- قال: فقال لفتيته وهو يكيل لهم: <span class="qpc-hafs">﴿اجعلوا بضاعتهم في رحالهم لعلهم يعرفونها إذا انقلبوا إلى أهلهم لعلهم يرجعون﴾</span> إلَيَّ{9}. (٨/١٩٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٦٨٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿لَعَلَّهُمْ﴾</span> يعني: لكي <span class="qpc-hafs">﴿يَرْجِعُونَ﴾</span> إلينا، فلا يحبسهم عَنّا حبس الدَّراهم إذا رُدَّت إليهم؛ لأنهم كانوا أهل ماشية{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٦٩٠<span class="dash">-</span></span> عن <span class="name-3">محمد بن إسحاق</span> -من طريق سلمة- في قوله: <span class="qpc-hafs">﴿لعلهم يعرفونها إذا انقلبوا إلى أهلهم لعلهم يرجعون﴾</span>، قال: ثُمَّ خرجوا حتى قدموا على أبيهم، وكان منزل يعقوب وبنيه -فيما ذكر لي بعضُ أهل العلم- بالعَرَبات، من أرض فلسطين بِغَور الشام. وبعضٌ يقول: بالأَوْلاج، من ناحية شعب أسفل من حِسْمى{13}. وكان صاحبَ بادية، له بها شاءٌ وإبِل{14}<span class=comment-ref>٣٣٩٥</span>. (٨/٢٨٥)</p></p><p></div></p><p><div><span class=comment-ref>٣٣٩٥</span> <span class="comment-type-4">ذكر</span> <u>ابنُ جرير</u> (١٣/٢٢٨-٢٢٩) أنّ العِلَّة التي من أجلها أمر يوسف فتيانه أن يجعلوا بضاعة إخوته في رحالهم تحتمل ثلاثة احتمالات: <b>الأول</b>: ما ذكره الكلبيُّ مِن خشيته أن لا يكون عند أبيه دراهم، فيضر أخذ ذلك منهم به، وأحب أن يرجع إليه. <b>الثاني</b>: أنّه أراد أن يَتَّسع بها أبوه وإخوته مع حاجتهم إليه، فردَّه عليهم مِن حيث لا يعلمون تكرُّمًا وتفضُّلًا. <b>الثالث</b>: أن يتحرجوا مِن أخذ الطعام بلا ثمن فيكون ذلك أدعى لهم إلى العوْد.</p><p>و<span class="comment-type-4">نقل</span> <u>ابنُ عطية</u> (٥/١١٣) <b>احتمالًا رابعًا</b> أنّه قيل: إنّ يوسف ﵇ فعل ذلك ليجعلها توطئة لجعل السقاية في رحل أخيه بعد ذلك، لِيُبَيِّن أنه لم يسرق لِمَن يتأمل القصة.</p><p>و<span class="comment-type-2">انتقد</span> الاحتمال الثالث <span class="mustanad">مستندًا للسياق، والدلالة العقلية</span>، فقال: «وهذا ضعيف من وجوه، وسرورهم بالبضاعة وقولهم: <span class="qpc-hafs">﴿هذه بضاعتنا ردت إلينا﴾</span> يكشف أنّ يوسف ﵇ لم يقصد هذا، وإنما قصد أن يستميلهم ويصلهم فيرغبهم في نفسه كالذي كان. وخص البضاعة بعينها دون أن يعطيهم غيرها من الأموال لأنها أوقع في نفوسهم، إذ يعرفون حلها، وماله هو إنما كان عندهم مالًا مجهول الحال، غايته أن يستجاز على نحو استجازتهم قبول الميرة». ثم قال: «ويظهر أنّ ما فعل يوسف من صلتهم، وجبرهم في تلك الشدة كان واجبًا عليه، إذ هو ملك عدل، وهم أهل إيمان ونبوة».</p><p>ثم <span class="comment-type-3">رجَّح</span> أنّه أراد استمالتهم وصلتهم، فقال: «والظاهر من القِصَّة أنه إنما أراد الاستئلاف، وصلة الرَّحِم».</div></p></div>",footnotes:1:أخرجه سعيد بن منصور (١١٣٠، ١١٣١- تفسير).</p><p>وهي قراءة متواترة، قرأ بها العشرة ما عدا حمزة، والكسائي، وخلف العاشر، وحفصًا عن عاصم، وقرأ بقية العشرة: <span class="qpc-hafs">﴿لِفِتْيانِهِ﴾</span> بألف بعد الياء، ونون مكسورة بعدها. انظر: النشر ٢/٢٩٥، والإتحاف ص٣٣٣.|2:أخرجه سعيد بن منصور (ت: سعد آل حميد) ٥/٤٠٠ (١١٣١).|3:أخرجه ابن جرير ١٣/٢٢٧، وابن أبي حاتم ٧/٢١٦٥.|4:تفسير مقاتل بن سليمان ٢/٣٤٢.|5:تفسير الثعلبي ٥/٢٣٥، وتفسير البغوي ٤/٢٥٥.|6:أخرجه ابن جرير ١٣/٢٢٧، وابن أبي حاتم ٧/٢١٦٥ من طريق سعيد بن أبي عروبة.|7:تفسير الثعلبي ٥/٢٣٥، وتفسير البغوي ٤/٢٥٦.|8:تفسير مقاتل بن سليمان ٢/٣٤٢.|9:أخرجه ابن جرير ١٣/٢٢٨، وابن أبي حاتم ٧/٢١٦٥.|10:تفسير مقاتل بن سليمان ٢/٣٤٢.|11:أخرجه ابن جرير ١٣/٢٢٨، وابن أبي حاتم ٧/٢١٦٥.|12:تفسير مقاتل بن سليمان ٢/٣٤٢.|13:حِسْمى: أرض ببادية الشام. معجم البلدان ٢/٣١٧.|14:أخرجه ابن أبي حاتم ٧/٢١٦٥.
  12,63,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿فَلَمَّا رَجَعُوۤا۟ إِلَىٰۤ أَبِیهِمۡ قَالُوا۟ یَـٰۤأَبَانَا مُنِعَ مِنَّا ٱلۡكَیۡلُ فَأَرۡسِلۡ مَعَنَاۤ أَخَانَا نَكۡتَلۡ وَإِنَّا لَهُۥ لَحَـٰفِظُونَ ۝٦٣﴾</span> - قراءات</h3></p><p><div></p><p><p><span class="item-no">٣٧٦٩١<span class="dash">-</span></span> قال سفيان الثوري: في قراءة <span class="name-1">عبد الله بن مسعود</span> (أرْسِلْ مَعَنَآ أخانا يَكْتَلْ مِثْلَ نَصِيبِ أحَدِنا){1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٦٩٢<span class="dash">-</span></span> عن المغيرة، عن <span class="name-2">أصحاب عبد الله بن مسعود</span>: ‹فَأَرْسِلْ مَعَنَآ أخانا يَكْتَلْ›{2}. (٨/٢٨٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٦٩٣<span class="dash">-</span></span> عن <span class="name-3">عبد الملك ابن جُرَيْج</span>: ‹فَأَرْسِلْ مَعَنَآ أخانَآ يَكْتَلْ›...{3}<span class=comment-ref>٣٣٩٦</span>. (٨/٢٨٥)</p></p><p></div></p><p><div><span class=comment-ref>٣٣٩٦</span> اختُلِف في قراءة قوله: <span class="qpc-hafs">﴿نكتل﴾</span>؛ <b>فقرأ قوم</b> بالنون. <b>وقرأ غيرهم</b> بالياء.</p><p>و<span class="comment-type-4">ذكر</span> <u>ابنُ جرير</u> (١٣/٢٣١) أنّ قراءة النون بمعنى: نكتل نحن وهو. وأنّ قراءة الياء بمعنى: يكتل هو لنفسه كما نكتال لأنفسنا.</p><p>و<span class="comment-type-4">بنحوه</span> قال <u>ابنُ عطية</u> (٥/١١٣). و<u>ابنُ كثير</u> (٨/٥٥).</p><p>و<span class="comment-type-4">ذكر</span> <u>ابنُ عطية</u> أنّ قراءة النون على مراعاة: <span class="qpc-hafs">﴿مُنع منا﴾</span>، ثم <span class="comment-type-4">علّق</span> بقوله: <span class="mustanad">«ويقويه</span>: <span class="qpc-hafs">﴿ونمير أهلنا﴾</span><span class="qpc-hafs">﴿ونزداد﴾</span>».</p><p>و<span class="comment-type-3">رجَّح</span> <u>ابنُ جرير</u> (١٣/٢٣١) صحة كلتا القراءتين <span class="mustanad">مستندًا إلى شهرتهما، وصِحَّة معناهما</span>، فقال: «والصواب من القول في ذلك أنهما قراءتان معروفتان مُتَّفِقتا المعنى، فبأيتهما قرأ القارئُ فمصيبٌ الصواب، وذلك أنّهم إنّما أخبروا أباهم أنّه مُنِع منهم زيادة الكيل على عدد رءوسهم، فقالوا: <span class="qpc-hafs">﴿يا أبانا منع منا الكيل﴾</span>. ثم سألوه أن يرسل معهم أخاهم ليكتال لنفسه، فهو إذا اكتال لنفسه واكتالوا هم لأنفسهم فقد دخل الأخ في عددهم، فسواء كان الخبر بذلك عن خاصة نفسه، أو عن جميعهم بلفظ الجميع، إذ كان مفهومًا معنى الكلام وما أريد به».</div></p><p><h3><span class="qpc-hafs">﴿فَلَمَّا رَجَعُوۤا۟ إِلَىٰۤ أَبِیهِمۡ قَالُوا۟ یَـٰۤأَبَانَا مُنِعَ مِنَّا ٱلۡكَیۡلُ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٧٦٩٤<span class="dash">-</span></span> قال <span class="name-2">الحسن البصري</span>، في قوله: <span class="qpc-hafs">﴿منع منا الكيل﴾</span>، قال: معناه: يُمْنَع مِنّا الكيل{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٦٩٥<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السدي</span> -من طريق أسباط- قال: فلمّا رجع القومُ إلى أبيهم كلَّموه، فقالوا: يا أبانا، إنّ ملِك مِصْرَ أكرَمنا كرامةً لو كان رَجُلًا مِنّا مِن بني يعقوب ما أكرَمَنا كرامته، وإنّه ارْتَهَنَ شمعون، وقال: ائْتُويى بأخيكم هذا الذي عَطَفَ عليه أبوكم بعد أخيكم الذي هَلَك حتى أنظر إليه، فإن لم تأتوني به فلا تقربوا بلادي أبدًا. فقال لهم يعقوب: إذا أتيتم ملِك مصر فأقرِئوه مِنِّي السلام، وقولوا: إنّ أبانا يُصَلِّي عليك، ويدعو لك بما أوْلَيْتَنا{5}. (٨/١٩٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٦٩٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فَلَمّا رَجَعُوا إلى أبِيهِمْ قالُوا يا أبانا مُنِعَ مِنّا الكَيْلُ﴾</span>، يعني: مُنِع كيل الطعام. فيه إضمارٌ فِيما يُسْتَأْنَف{6}<span class=comment-ref>٣٣٩٧</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٣٣٩٧</span> <span class="comment-type-4">ذكر</span> <u>ابنُ عطية</u> (٥/١١٣) أنّ قولهم: <span class="qpc-hafs">﴿منع منا﴾</span> ظاهره أنهم أشاروا إلى قوله: <span class="qpc-hafs">﴿فلا كيل لكم عندي﴾</span>، فهو خوف في المستأنف. و<span class="comment-type-4">نقل</span> أنّه قيل: أشاروا إلى بعير بنيامين الذي لم يَمْتَر.</p><p>ثم <span class="comment-type-3">رجَّح</span> أنّه خوفٌ في المستانف، وهو ما أفاده قول مقاتل، فقال: «والأول أرجح». ولم يذكر مستندًا.</div></p><p><div></p><p><p><span class="item-no">٣٧٦٩٧<span class="dash">-</span></span> عن <span class="name-3">محمد بن إسحاق</span> -من طريق سلمة- قال: ... فقالوا: يا أبانا، قدِمنا على خيرِ رجُلٍ؛ أنزَلَنا فأَكْرَم منزِلَنا، وكال لنا فأَوْفانا ولم يَبْخَسْنا، وقد أمَرَنا أن نأتيه بأخٍ لنا مِن أبينا، وقال: إن أنتم لم تفعلوا فلا تَقْرَبُنِّي، ولا تَدْخُلُنَّ بلدي. فقال لهم يعقوب: <span class="qpc-hafs">﴿هل آمنكم عليه إلا كما أمنتكم على أخيه من قبل، فالله خير حافظا وهو أرحم الراحمين﴾</span>{7}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿فَأَرۡسِلۡ مَعَنَاۤ أَخَانَا نَكۡتَلۡ وَإِنَّا لَهُۥ لَحَـٰفِظُونَ ۝٦٣﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٧٦٩٨<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فَأَرْسِلْ مَعَنا أخانا﴾</span> بنيامين <span class="qpc-hafs">﴿نَكْتَلْ﴾</span> الطعامَ بثَمَن، <span class="qpc-hafs">﴿وإنّا لَهُ لَحافِظُونَ﴾</span> مِن الضَيْعَة{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٦٩٩<span class="dash">-</span></span> عن <span class="name-3">عبد الملك ابن جُرَيْج</span>: ‹فَأَرْسِلْ مَعَنَآ أخانا يَكْتَلْ› له بعيرًا{3}. (٨/٢٨٥)</p></p><p></div></p></div>",footnotes:1:تفسير الثوري ص١٤٤.</p><p>وهي قراءة شاذة.|2:عزاه السيوطي إلى ابن أبي شيبة، وابن المنذر.</p><p>وهي قراءة متواترة، قرأ بها حمزة، والكسائي، وخلف العاشر، وقرأ بقية العشرة: <span class="qpc-hafs">﴿نَكْتَلْ﴾</span> بالنون. انظر: النشر ٢/٢٩٥، والإتحاف ص٣٣٣.|3:عزاه السيوطي إلى ابن جرير، وابن المنذر.|4:تفسير البغوي ٤/٢٥٦.|5:أخرجه ابن جرير ١٣/٢٢٩، وابن أبي حاتم ٧/٢١٦٥-٢١٦٦.|6:تفسير مقاتل بن سليمان ٢/٣٤٢.|7:أخرجه ابن جرير ١٣/٢٣٠، وابن أبي حاتم ٧/٢١٦٦.|8:تفسير مقاتل بن سليمان ٢/٣٤٢.|9:عزاه السيوطي إلى ابن جرير، وابن المنذر.