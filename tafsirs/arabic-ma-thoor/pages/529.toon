quran[21]{c,v,t}:
54,7," <q>﴿خُشَّعًا أَبۡصَـٰرُهُمۡ یَخۡرُجُونَ مِنَ ٱلۡأَجۡدَاثِ كَأَنَّهُمۡ جَرَادࣱ مُّنتَشِرࣱ ۝٧﴾</q> - قراءات ٧٣٧٣٢- عن الأعمش: في قراءة عبد الله [بن مسعود]: (خاشِعَةً أبْصارُهُمْ){1}. (ز) ٧٣٧٣٣- عن عبد الله بن عباس أنه كان يقرأ: ‹خاشِعًا أبْصارُهُمْ› بالألف{2}. (١٤/٧٢) ٧٣٧٣٤- عن عاصم أنه قرأ: <q>﴿خُشَّعًا أبْصارُهُمْ﴾</q> برفع الخاء{3}٦٣١٣. (١٤/٧٢) ٦٣١٣ اختُلف في قراءة قوله: <q>﴿خشعًا أبصارهم﴾</q> فقرأ قوم: <q>﴿خُشّعًا﴾</q>. وقرأ غيرهم: ‹خاشِعًا›. وقرأ آخرون: (خاشِعَةً). وذكر ابنُ جرير (٢٢/١١٧-١١٨) أنّ الأولى بمعنى: خاشع. وأنّ الثانية بالألف على التوحيد اعتبارًا بقراءة عبد الله الثالثة، وبين أنهم ألحقوه وهو بلفظ الاسم في التوحيد، إذ كان صفة بحكم «فعَل» و«يفعَل» في التوحيد إذا تقدم الأسماء، كما قال الشاعر: وشبابٍ حَسنٍ أوجههم من إياد بن نِزار بن مَعد فوحّد حسنًا وهو صفة للأوجه، وهي جمع. وبنحوه قال ابن عطية (٨/١٤٠). <q>﴿خُشَّعًا أَبۡصَـٰرُهُمۡ﴾</q> - تفسير ٧٣٧٣٥- عن قتادة بن دعامة -من طريق سعيد- (خاشِعًا أبْصارُهُمْ): أي: ذليلة أبصارهم{4}. (١٤/٧٢) ٧٣٧٣٦- قال مقاتل بن سليمان: <q>﴿خُشَّعًا﴾</q> يعني: ذليلة خافضة <q>﴿أبْصارُهُمْ﴾</q> عند معاينة النار{5}. (ز) <q>﴿یَخۡرُجُونَ مِنَ ٱلۡأَجۡدَاثِ كَأَنَّهُمۡ جَرَادࣱ مُّنتَشِرࣱ ۝٧﴾</q> - تفسير ٧٣٧٣٧- قال الحسن البصري: <q>﴿كَأَنَّهُمْ جَرادٌ مُنْتَشِرٌ﴾</q> شبّههم بالجراد؛ إذا أدركه الليل لزِم الأرض، فإذا أصبح وطلع عليه الشمس انتشر{6}. (ز) ٧٣٧٣٨- عن عطاء الخُراسانيّ -من طريق يونس بن يزيد- <q>﴿يخرجون من الأجداث كأنهم جراد منتشر﴾</q>، قال: الأجداث: القبور{7}. (ز) ٧٣٧٣٩- قال مقاتل بن سليمان: <q>﴿يَخْرُجُونَ مِنَ الأَجْداثِ﴾</q> يعني: القبور <q>﴿كَأَنَّهُمْ جَرادٌ مُنْتَشِرٌ﴾</q> حين انتشر من معدنه، فشبّه الناسَ بالجراد إذا خرجوا من قبورهم{5}. (ز) ",footnotes:1:أخرجه ابن أبي داود في المصاحف ١/٣٣٧. وهي قراءة شاذة، تروى أيضًا عن أُبَيّ. انظر: مختصر ابن خالويه ص١٤٨.أخرجه الحاكم ٢/٤٧٢-٤٧٣. وعزاه السيوطي إلى سعيد بن منصور، وابن المنذر. وهي قراءة متواترة، قرأ بها أبو عمرو، ويعقوب، وحمزة، والكسائي، وخلف، وقرأ بقية العشرة: <q>﴿خُشَّعًا أبْصارُهُمْ﴾</q> بضم الخاء. انظر: النشر ٢/٣٨٠، والإتحاف ص٥٢٤.عزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ٢٢/١١٧.تفسير مقاتل بن سليمان ٤/١٧٨.ذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٤/٣١٧-.أخرجه أبو جعفر الرملي في جزئه (تفسير عطاء) ص١١٠.تفسير مقاتل بن سليمان ٤/١٧٨.
54,8," <q>﴿مُّهۡطِعِینَ إِلَى ٱلدَّاعِۖ یَقُولُ ٱلۡكَـٰفِرُونَ هَـٰذَا یَوۡمٌ عَسِرࣱ ۝٨﴾</q> - تفسير ٧٣٧٤٠- عن عبد الله بن عباس -من طريق علي- في قوله: <q>﴿مُهْطِعِينَ إلى الدّاعِ﴾</q>، قال: ناظرين{1}. (١٤/٧٣) ٧٣٧٤١- عن عبد الله بن عباس: أنّ نافع بن الأزرق سأله عن قوله: <q>﴿مُهْطِعِينَ﴾</q>. قال: مُذْعنين خاضعين. قال: وهل تعرف العرب ذلك؟ قال: نعم أما سمعتَ قول تُبّع: تعبَّدني نِمْر بن سعد وقد دَرى ونِمْر بن سعد لي مَدِينٌ ومُهْطِع{2}. (١٤/٧٣) ٧٣٧٤٢- عن سعيد بن جُبَير -من طريق سالم الأفطس- ‹مُهْطِعِينَ إلى الدّاعِي›، قال: هو النَّسَلان{3}{4}. (١٤/٧٣) ٧٣٧٤٣- عن أبي الضُّحى مسلم بن صبيح -من طريق سفيان، عن أبيه- <q>﴿مُهْطِعِينَ إلى الدّاعِ﴾</q>، قال: التَّحْمِيجُ{5}{6}. (ز) ٧٣٧٤٤- عن عكرمة مولى ابن عباس، ‹مُهْطِعِينَ إلى الدّاعِي›، قال: صائخي آذانهم إلى الصوت{7}. (١٤/٧٤) ٧٣٧٤٥- عن الحسن البصري، في قوله: <q>﴿مُهْطِعِينَ إلى الدّاعِ﴾</q>، قال: مُنطلقين{7}. (١٤/٧٣) ٧٣٧٤٦- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿مُهْطِعِينَ إلى الدّاعِ﴾</q>، قال: عامدين إلى الداعي{9}. (١٤/٧٣) ٧٣٧٤٧- عن تميم بن حَذْلَم -من طريق عثمان بن يسار- في قوله <q>﴿مُهْطِعِينَ إلى الدّاعِ﴾</q>، قال: الإهطاع: التّحميج{10}. (١٤/٧٣) ٧٣٧٤٨- قال مقاتل بن سليمان: <q>﴿مُهْطِعِينَ إلى الدّاعِ﴾</q>، يعني: مُقبلين سِراعًا إذا خرجوا مِن القبور إلى صوت إسرافيل القائم على الصخرة التي ببيت المقدس، فيُهوَّن على المؤمنين الحشر كأدنى صلاتهم، والكفار يُكبّون على وجوههم، فلا يقومون مقامًا ولا يخرجون مخرجًا إلا عسر عليهم، في كلّ موطن شدّة ومشقّة، فذلك قوله: <q>﴿يَقُولُ الكافِرُونَ هَذا يَوْمٌ عَسِرٌ﴾</q>{11}. (ز) ٧٣٧٤٩- عن سفيان [الثوري] -من طريق مهران- <q>﴿مُهْطِعِينَ إلى الدّاعِ﴾</q>، قال: هكذا، أبصارهم شاخصة إلى السماء{12}. (ز) ",footnotes:1:أخرجه ابن جرير ١٣/٧٠٥، ٢٢/١١٩، وابن المنذر -كما في فتح الباري ٨/٦١٦-، وابن أبي حاتم -كما في الإتقان ٢/٢٢-.أخرجه الطستي -كما في الإتقان ٢/١٠١-.النَّسَلان: الإسراع في العدو. لسان العرب (نسل).أخرجه ابن أبي حاتم -كما في تغليق التعليق ٤/٣٢٧-٣٢٨-. وعزاه السيوطي إلى عبد بن حميد.التَّحْمِيج: فتح العين وتحديد النظر، كأنه مبهُوت أو خائف. النهاية ولسان العرب (حمج).أخرجه ابن جرير ٢٢/١١٨.عزاه السيوطي إلى عبد بن حميد.عزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ١٣/٧٠٥، ٢٢/١١٩. وعزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ١٣/٧٠٥، ٢٢/١١٨. وعزاه السيوطي إلى عبد بن حميد.تفسير مقاتل بن سليمان ٤/١٧٨.أخرجه ابن جرير ٢٢/١١٩.
54,9," <q>﴿كَذَّبَتۡ قَبۡلَهُمۡ قَوۡمُ نُوحࣲ فَكَذَّبُوا۟ عَبۡدَنَا وَقَالُوا۟ مَجۡنُونࣱ وَٱزۡدُجِرَ ۝٩﴾</q> - تفسير ٧٣٧٥٠- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿وقالُوا مَجْنُونٌ وازْدُجِرَ﴾</q>، قال: استُطِير جنونًا{1}. (١٤/٧٤) ٧٣٧٥١- عن مجاهد بن جبر -من طريق الحكم- <q>﴿وقالُوا مَجْنُونٌ وازْدُجِرَ﴾</q>، قال: استُعِرَ جنونًا{2}٦٣١٤. (ز) ٦٣١٤ ذكر ابنُ عطية (٨/١٤١-١٤٢) أنه على قول مجاهد فقوله: <q>﴿وازدجر﴾</q> من قول قوم نوح، وانتقده بقوله: «وهذا قول فيه تَعَسُّف وتَحَكُّم». ٧٣٧٥٢- عن الحسن البصري، في قوله: <q>﴿وازْدُجِرَ﴾</q>، قال: تهدّدوه بالقتل{3}. (١٤/٧٤) ٧٣٧٥٣- قال مقاتل بن سليمان: <q>﴿كَذَّبَتْ قَبْلَهُمْ﴾</q> قبل أهل مكة <q>﴿قَوْمُ نُوحٍ فَكَذَّبُوا عَبْدَنا﴾</q> نوحًا، <q>﴿وقالُوا﴾</q> لنوح: <q>﴿مَجْنُونٌ وازْدُجِرَ﴾</q> يعني: استطار القلب منه، وأوعدوه بالقتل، وضربوه{4}. (ز) ٧٣٧٥٤- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿وقالُوا مَجْنُونٌ وازْدُجِرَ﴾</q>، قال: اتّهموه وزجروه وأوعدوه لَئِن لم يفعل ليكوننّ من المرجومين. وقرأ: <q>﴿قالُوا لَئِنْ لَمْ تَنْتَهِ يا نُوحُ لَتَكُونَنَّ مِنَ المَرْجُومِينَ﴾</q> [الشعراء:١١٦]{5}٦٣١٥. (ز) ٦٣١٥ علَّق ابنُ كثير (١٣/٢٩٦) على قول ابن زيد بقوله: «وهو متوجه حسن». ",footnotes:1:تفسير مجاهد ص٦٣٤، وأخرجه الفريابي -كما في التغليق ٤/٣٢٧-، وابن جرير ٢٢/١٢٠، ومن طريق منصور أيضًا. وعزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ٢٢/١٢٠.ذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٤/٣١٧-. وعزاه السيوطي إلى سعيد بن منصور، وعَبد بن حُمَيد، وابن المنذر.تفسير مقاتل بن سليمان ٤/١٧٨.أخرجه ابن جرير ٢٢/١٢١.
54,10," <q>﴿فَدَعَا رَبَّهُۥۤ أَنِّی مَغۡلُوبࣱ فَٱنتَصِرۡ ۝١٠﴾</q> - تفسير ٧٣٧٥٥- قال مقاتل بن سليمان: <q>﴿فَدَعا رَبَّهُ أنِّي مَغْلُوبٌ فانْتَصِرْ﴾</q> بعد ما كان يُضرب في كلّ يوم مرتين حتى يُغشى عليه، فإذا أفاق قال: اللهم، اهدِ قومي؛ فإنهم لا يعلمون{1}. (ز) ",footnotes:1:تفسير مقاتل بن سليمان ٤/١٧٨.
54,11," <q>﴿فَفَتَحۡنَاۤ أَبۡوَ ٰ⁠بَ ٱلسَّمَاۤءِ بِمَاۤءࣲ مُّنۡهَمِرࣲ ۝١١﴾</q> - تفسير ٧٣٧٥٦- عن أبي الطُّفيل: أنّ ابن الكَوّاء سأل عليًّا عن المَجرّة. فقال: هي شَرْج{1} السماء، ومنها فُتحت أبواب السماء بماء مُنهمر. ثم قرأ: <q>﴿فَفَتَحْنا أبْوابَ السَّماءِ﴾</q> الآية{2}. (١٤/٧٤) ٧٣٧٥٧- عن عبد الله بن عباس، في قوله: <q>﴿فَفَتَحْنا أبْوابَ السَّماءِ بِماءٍ مُنْهَمِرٍ﴾</q>، قال: كثير، لم تمطر السماء قبل ذلك اليوم ولا بعده إلا مِن السحاب، وفُتحت أبواب السماء بالماء مِن غير سحابٍ ذلك اليوم، فالتقى الماءان{3}٦٣١٦. (١٤/٧٥) ٦٣١٦ ذكر ابن عطية (٨/١٤٢) هذا القول منسوبًا لأبي حاتم، ثم قال: «وقال قوم من أهل التأويل: الأبواب حقيقة، فُتحت في السماء أبواب جرى منها الماء. وقال جمهور المفسرين: بل هو مجاز وتشبيه؛ لأن المطر كثر كأنه من أبواب». ٧٣٧٥٨- قال مقاتل بن سليمان: <q>﴿فَفَتَحْنا أبْوابَ السَّماءِ﴾</q> أربعين يومًا <q>﴿بِماءٍ مُنْهَمِرٍ﴾</q> يعني: مُنصَبٌّ كثير{4}. (ز) ٧٣٧٥٩- عن سفيان [الثوري] -من طريق مهران- <q>﴿بِماءٍ مُنْهَمِرٍ﴾</q>، قال: ينصبُّ انصِبابًا{5}. (ز) ",footnotes:1:المجرة شَرَج السماء: يقال: هي بابُها. لسان العرب (جرر).أخرجه البخاري في الأدب (٧٦٦)، وابن أبي حاتم -كما في تفسير ابن كثير ٧/٤٥٢-.عزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.تفسير مقاتل بن سليمان ٤/١٧٨.أخرجه ابن جرير ٢٢/١٢٢.
54,12," <q>﴿وَفَجَّرۡنَا ٱلۡأَرۡضَ عُیُونࣰا﴾</q> - تفسير ٧٣٧٦٠- قال عبد الله بن عباس= (ز) ٧٣٧٦١- ومحمد بن كعب القُرَظيّ: <q>﴿وفَجَّرْنا الأَرْضَ﴾</q> مُنفجرٌ من الأرض{1}. (ز) ٧٣٧٦٢- قال مقاتل بن سليمان: <q>﴿وفَجَّرْنا الأَرْضَ﴾</q> أربعين يومًا <q>﴿عُيُونًا﴾</q>{2}. (ز) ٧٣٧٦٣- عن سفيان [الثوري] -من طريق مهران- في قوله: <q>﴿وفَجَّرْنا الأَرْضَ عُيُونًا﴾</q>، قال: فجّرنا الأرض بالماء، وجاء من السماء ماءٌ؛ فالتقى الماء والماء{3}. (ز) <q>﴿فَٱلۡتَقَى ٱلۡمَاۤءُ عَلَىٰۤ أَمۡرࣲ قَدۡ قُدِرَ ۝١٢﴾</q> - تفسير ٧٣٧٦٤- عن محمد بن كعب القُرَظيّ -من طريق موسى بن عبيد- في قوله: <q>﴿فالتَقى الماءُ﴾</q> قال: ماء السماء وماء الأرض، <q>﴿عَلى أمْرٍ قَدْ قُدِرَ﴾</q> قال: كانت الأقواتُ قبل الأجساد، وكان القدرُ قبل البلاء{4}. (١٤/٧٥) ٧٣٧٦٥- قال مقاتل بن سليمان: <q>﴿فالتَقى الماءُ عَلى أمْرٍ قَدْ قُدِرَ﴾</q> وذلك أنّ ماء السماء وماء الأرض قدّر الله تعالى كليهما، فكانا سواء، لم يَزد ماءُ السماء على ماء الأرض، وكان ماءُ السماء باردًا مثل الثّلج، وماء الأرض حارًّا مثل الحميم، فذلك قوله: <q>﴿عَلى أمْرٍ قَدْ قُدِرَ﴾</q> لأنّ الماء ارتفع فوق كلّ جبل ثلاثين يومًا، ويقال: أربعين ذراعًا، فكان الماء الذي على الأرض والذي على رؤوس الجبال سواء، فابتَلعت الأرضُ ماءَها، وبقي ماء السماء أربعين يومًا لم تشربه الأرض، فهذه البحور التي على الأرض منها{5}٦٣١٧. (ز) ٦٣١٧ علَّق ابن عطية (٨/١٤٣) على الاختلاف في ارتفاع الماء بقوله: «ولا خبر يقطع العذر في شيء من هذا التحديد». ٧٣٧٦٦- عن عبد الملك ابن جُرَيْج، في قوله: <q>﴿قَدْ قُدِرَ﴾</q>، قال: صاعٌ بصاع{6}. (١٤/٧٥) ٧٣٧٦٧- عن سفيان [الثوري] -من طريق مهران- في قوله: <q>﴿فالتَقى الماءُ عَلى أمْرٍ قَدْ قُدِرَ﴾</q>، قال: ماء السماء وماء الأرض{3}. (ز) ",footnotes:1:تفسير الثعلبي ٩/١٦٤.تفسير مقاتل بن سليمان ٤/١٧٨.أخرجه ابن جرير ٢٢/١٢٢.أخرجه ابن جرير ٢٢/١٢٣. وعزاه السيوطي إلى عَبد بن حُمَيد، وابن المنذر.تفسير مقاتل بن سليمان ٤/١٧٨-١٧٩.عزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ٢٢/١٢٢.
54,13," <q>﴿وَحَمَلۡنَـٰهُ عَلَىٰ ذَاتِ أَلۡوَ ٰ⁠حࣲ وَدُسُرࣲ ۝١٣﴾</q> - تفسير ٧٣٧٦٨- عن عبد الله بن عباس -من طريق حصين، عن مجاهد- في قوله: <q>﴿وحَمَلْناهُ عَلى ذاتِ ألْواحٍ ودُسُرٍ﴾</q>، قال: الألواح: ألواح السفينة، والدُّسُر: معاريضها التي تُشَدّ بها السفينة{1}. (١٤/٧٥) ٧٣٧٦٩- عن عبد الله بن عباس -من طريق علي- في قوله تعالى: <q>﴿ودُسُرٍ﴾</q>، قال: المسامير{2}. (١٤/٧٦) ٧٣٧٧٠- عن عبد الله بن عباس، أن نافع بن الأزرق قال له: أخبِرني عن قول الله: <q>﴿ودُسُرٍ﴾</q>. قال: الدُّسُر: التي تُحرز به السفينة. قال: وهل تعرفُ العربُ ذلك؟ قال: نعم، أما سمعت الشاعر وهو يقول: سفينة نُوتِيٍّ{3} قدُ احْكِم صُنعُها مُثخَّنة{4} الألواح مَنسوجة الدُّسُر؟{5}. (١٤/٧٦) ٧٣٧٧١- عن عبد الله بن عباس -من طريق عطية العَوفيّ- قال: الدُّسُر: كَلْكَل{6} السفينة{7}. (١٤/٧٦) ٧٣٧٧٢- عن مجاهد بن جبر -من طريق ابن أبي نجيح- قوله: <q>﴿ودُسُرٍ﴾</q>، قال: أضلاع السفينة{8}. (ز) ٧٣٧٧٣- عن مجاهد بن جبر، قال: الألواح: الصفائح، والدُّسُر: العوارض{9}. (١٤/٧٥) ٧٣٧٧٤- عن مجاهد بن جبر -من طريق الحُصين- <q>﴿وحَمَلْناهُ عَلى ذاتِ ألْواحٍ﴾</q> قال: ألواح السفينة، <q>﴿ودُسُرٍ﴾</q>: عوارضها{10}. (ز) ٧٣٧٧٥- عن الضَّحّاك بن مُزاحِم -من طريق عبيد- في قوله: <q>﴿ذاتِ ألْواحٍ ودُسُرٍ﴾</q>: أمّا الألواح: فجانبا السفينة، وأمّا الدُّسُر: فطرفاها وأصلها{11}. (ز) ٧٣٧٧٦- عن عكرمة مولى ابن عباس، قال: الدُّسُر: صدرها الذي تَضرب به الموج{12}. (١٤/٧٧) ٧٣٧٧٧- عن الحسن البصري، نحوه{12}. (١٤/٧٧) ٧٣٧٧٨- عن الحسن البصري -من طريق أبي رجاء- في قوله: <q>﴿وحَمَلْناهُ عَلى ذاتِ ألْواحٍ ودُسُرٍ﴾</q>، قال: تدْسُر الماء بصدرها. أو قال: بِجُؤْجُؤها{14}٦٣١٨. (ز) ٦٣١٨ علَّق ابن عطية (٨/١٤٣) على هذا القول الذي قاله ابن عباس من طريق العَوفيّ، والحسن، بقوله: «لأنها تدْسُر الماء، أي: تدفعه، والدّسر: الدفع». ٧٣٧٧٩- عن محمد بن كعب القُرَظيّ -من طريق أبي صخر- وسئل عن هذه الآية: <q>﴿وحَمَلْناهُ عَلى ذاتِ ألْواحٍ ودُسُرٍ﴾</q>. قال: الدُّسُر: المسامير{15}٦٣١٩. (ز) ٦٣١٩ علَّق ابن عطية (٨/١٤٣) على هذا القول الذي قاله ابن عباس من طريق علي، والقُرَظيّ، وقتادة، وابن زيد، فقال: «وهذا هو قول الجمهور، وهو عندي من الدفع المتتابع؛ لأن المسمار يُدفع أبدًا حتى يستوي». ٧٣٧٨٠- عن قتادة بن دعامة -من طريق معمر- <q>﴿وحَمَلْناهُ عَلى ذاتِ ألْواحٍ﴾</q> قال: معاريض السفينة، <q>﴿ودُسُرٍ﴾</q> قال: دُسرت بمسامير{16}. (١٤/٧٥) ٧٣٧٨١- عن قتادة بن دعامة -من طريق سعيد- قال: حُدِّثنا: أنّ دُسُرها: مساميرها التي شُدّت بها{17}. (١٤/٧٦) ٧٣٧٨٢- قال مقاتل بن سليمان: <q>﴿وحَمَلْناهُ﴾</q> نوحًا <q>﴿عَلى ذاتِ ألْواحٍ﴾</q> يعني: ألواح السفينة، وهي مِن ساج، ثم قال: <q>﴿ودُسُرٍ﴾</q> يعني: مسامير مِن حديد، تُشدّ به السفينة، كان بابها في عرضها{18}. (ز) ٧٣٧٨٣- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿ودُسُرٍ﴾</q>، قال: الدُسُر: المسامير التي دُسِرت بها السفينة؛ ضُربت فيها، شُدّت بها{19}٦٣٢٠. (ز) ٦٣٢٠ ذكر ابن عطية (٨/١٤٣-١٤٤) أن جمهور الناس على أنّ السفينة كانت على هيئة السفن اليوم كجُؤْجُؤ الطائر. ثم بيّن أنه ورد في بعض الكتب أنها كانت مربّعة، طويلة في السماء، واسعة السّفل، ضيّقة العلو، وكان أعلاها مفتوحًا للهواء والتنفس؛ لأن الغرض منها إنما كانت السلامة حتى ينزل الماء، ولم يكن طلب الجري وقصد المواضع المعيّنة، ومع هذه الهيئة فلها مجرى ومرسى، ثم علَّق بقوله: «والله أعلم كيف كانت، والكلّ محتمل». ",footnotes:1:أخرجه إبراهيم الحربي في غريب الحديث -كما في تغليق التعليق ٤/٣٢٧-، وابن المنذر -كما في فتح الباري ٨/٦١٦-. وعزاه السيوطي إلى عَبد بن حُمَيد.أخرجه ابن جرير ٢٢/١٢٤، وابن المنذر -كما في فتح الباري ٨/٦١٦-.النوتى: الملاّح. اللسان (نتا).ثَخُنَ الشيء: كَثُف وغَلُظ وصَلُب. لسان العرب (ثخن).أخرجه الطستي -كما في الإتقان ٢/٩٨-.الكلكل: الصدر من كل شيء. اللسان (كلكل).أخرجه ابن جرير ٢٢/١٢٥. وعزاه السيوطي إلى ابن أبي حاتم.تفسير مجاهد ص٦٣٤، وأخرجه الفريابي -كما في تغليق التعليق ٤/٣٢٧-، وابن جرير ٢٢/١٢٦. وعلقه البخاري في صحيحه ٤/١٨٤٣.عزاه السيوطي إلى عَبد بن حُمَيد.أخرجه ابن جرير ٢٢/١٢٥.أخرجه ابن جرير ٢٢/١٢٥-١٢٦.عزاه السيوطي إلى عبد بن حميد.عزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ٢٢/١٢٤-١٢٥، كما أخرجه من طريق قتادة ومعمر بنحوه، كذلك أخرجه عبد الرزاق ٢/٢٥٨ من طريق معمر بنحوه.أخرجه عبد الله بن وهب في الجامع -تفسير القرآن ٢/١٥١ (٣٠٨)، وابن جرير ٢٢/١٢٣.أخرجه عبد الرزاق ٢/٢٥٨، وابن جرير ٢٢/١٢٤. وعزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ٢٢/١٢٤. وذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٤/٣١٨- بنحوه.تفسير مقاتل بن سليمان ٤/١٧٩.أخرجه ابن جرير ٢٢/١٢٤.
54,14," <q>﴿تَجۡرِی بِأَعۡیُنِنَا﴾</q> - تفسير ٧٣٧٨٤- قال مقاتل بن سليمان: <q>﴿تَجْرِي بِأَعْيُنِنا﴾</q>، يقول: تجري السفينة في الماء بعين الله تعالى، فأغرق الله قوم نوح، فذلك الغرق{1}. (ز) ٧٣٧٨٥- قال مقاتل بن حيّان: <q>﴿تَجْرِي بِأَعْيُنِنا﴾</q> بحِفظنا{2}٦٣٢١. (ز) ٦٣٢١ ذكر ابنُ عطية (٨/١٤٣) أنّ الجمهور على هذا القول، وأنّ قوله: <q>﴿بأعيننا﴾</q> معناه: بحفظنا وكفايتنا وتحت نظرنا منّا لأهلها. وساق قولين آخرين: الأول: أن المراد مَن حفظها مِن الملائكة، سمّاهم: عيونًا. الثاني: أن قوله: <q>﴿بأعيننا﴾</q> يريد به: العيون المفجَّرة من الأرض. ونسبه للرمّاني. وانتقده بقوله: «وهذا ضعيف». ٧٣٧٨٦- عن سفيان [الثوري] -من طريق مهران- في قوله: <q>﴿تَجْرِي بِأَعْيُنِنا﴾</q>، يقول: بأمرنا{3}. (ز) <q>﴿جَزَاۤءࣰ لِّمَن كَانَ كُفِرَ ۝١٤﴾</q> - تفسير ٧٣٧٨٧- عن مجاهد بن جبر، في قوله: (جَزَآءً لِمَن كانَ كَفَرَ){4}، قال: جزاءً، الله هو الذي كُفِر{5}. (١٤/٧٧) ٧٣٧٨٨- عن مجاهد بن جبر -من طريق عيسى، عن ابن أبي نجيح- (لِمَن كانَ كَفَرَ)، قال: كفر بالله{3}. (ز) ٧٣٧٨٩- عن مجاهد بن جبر -من طريق ورقاء، عن ابن أبي نجيح- (جَزَآءً لِمَن كانَ كَفَرَ)، قال: لمن كان كفَر فيه{7}. (ز) ٧٣٧٩٠- قال مقاتل بن سليمان: <q>﴿جَزاءً لِمَن كانَ كُفِرَ﴾</q>، يعني: نوحًا المكفور به{1}. (ز) ٧٣٧٩١- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿جَزاءً لِمَن كانَ كُفِرَ﴾</q>، قال: لمن كان كَفر نِعم الله، وكَفر بآلاء ربّه وكتبه ورسله، فإنّ ذلك جزاء له{9}٦٣٢٢. (ز) ٦٣٢٢ اختُلف في معنى قوله: <q>﴿جزاء لمن كان كفر﴾</q> على قولين: الأول: أن المعنى: فعلنا ذلك جزاء لمن كان كفر فيه، بمعنى: كفر بالله فيه. الثاني: جزاء لما كان كُفر من أيادي الله ونِعمه. وعلى هذا القول وُجّه معنى «مَن» إلى «ما». ورجَّح ابنُ جرير (٢٢/١٢٧-١٢٨) -مستندًا إلى دلالة اللغة، والقرآن- القول الأول الذي قاله مجاهد، فقال: «لأن معنى الكفر: الجحود، وهو الذي جحد ألوهيته ووحدانيته قوم نوح، فقال بعضهم لبعض: <q>﴿لا تذرن آلهتكم ولا تذرن ودا ولا سواعا ولا يغوث ويعوق ونسرا﴾</q> [نوح:٢٣]. ومَن ذهب به إلى هذا التأويل كانت»مَن«: الله، كأنه قيل: غُرّقت لله بكفرهم به. ثم ساق احتمالًا آخر، هو قريب من قول مقاتل، فقال:»ولو وجّه موجّهٌ إلى أنها مرادٌ بها نوح والمؤمنون به كان مذهبًا، فيكون معنى الكلام حينئذ: فعلنا ذلك جزاء لنوح ولمن كان معه في الفُلك، كأنه قيل: غرّقناهم لنوح ولصنيعهم بنوح ما صنعوا من كُفرهم به". وعلَّق ابنُ عطية (٨/١٤٤) على القول الأول، بقوله: «كأنه قال: غضبًا وانتصارًا لله تعالى، أي: انتصَر لنفسه، فأنجى المؤمنين، وأغرق الكافرين». ",footnotes:1:تفسير مقاتل بن سليمان ٤/١٧٩.تفسير الثعلبي ٩/١٦٥، وتفسير البغوي ٧/٤٢٩.أخرجه ابن جرير ٢٢/١٢٦.وهي قراءة شاذة، قرأ بها قتادة ويزيد بن رومان وحميد. ينظر: تفسير القرطبي ١٧/١٣٣.عزاه السيوطي إلى الفريابي، وعبد بن حميد، وابن جرير، وابن المنذر.أخرجه ابن جرير ٢٢/١٢٦.أخرجه الفريابي -كما في تغليق التعليق ٤/٣٢٧-، وابن جرير ٢٢/١٢٧. وفي تفسير مجاهد ص٦٣٤ بلفظ: قال: يقول: كفر، يقول: جزاء من الله.تفسير مقاتل بن سليمان ٤/١٧٩.أخرجه ابن جرير ٢٢/١٢٧.
54,15," <q>﴿وَلَقَد تَّرَكۡنَـٰهَاۤ ءَایَةࣰ فَهَلۡ مِن مُّدَّكِرࣲ ۝١٥﴾</q> - تفسير ٧٣٧٩٢- عن مجاهد بن جبر -من طريق معمر، عن يونس-: أنّ الله حين غَرَّق الأرض جعلت الجبال تشمخ، فتواضع الجُوديّ، فرفعه الله على الجبال، وجعل قرار السفينة عليه{1}. (ز) ٧٣٧٩٣- عن قتادة بن دعامة -من طريق معمر- في قوله: <q>﴿ولَقَدْ تَرَكْناها آيَةً﴾</q>، قال: أبقى الله سفينة نوح على الجُوديّ حتى أدركها أوائل هذه الأمة{2}٦٣٢٣. (١٤/٧٧) ٦٣٢٣ ساق ابن كثير (١٣/٢٩٧) هذا القول، ثم رجَّح أن المراد: جنس السُّفن، مستندًا إلى الظاهر، فقال: «والظاهر أن المراد من ذلك: جنس السُّفن». وذكر ابنُ عطية (٨/١٤٤) أنّ مكيًّا قال بعود الضمير في قوله: <q>﴿تركناها﴾</q> على الفِعلة والقصة. ٧٣٧٩٤- عن قتادة بن دعامة -من طريق سعيد- قال: أبقى اللهُ السفينةَ في أرض الجزيرة عبرةً وآيةً، حتى نظر إليها أوائلُ هذه الأمة نظرًا، وكم مِن سفينة بعدها فصارت رمادًا{3}. (ز) ٧٣٧٩٥- قال مقاتل بن سليمان: <q>﴿ولَقَدْ تَرَكْناها آيَةً﴾</q> يعني: السفينة كانت عِبرة وآية لمن بعدهم من الناس، نظيرها في الحاقة، وفي الصافات، وفى العنكبوت{4}، <q>﴿فَهَلْ مِن مُدَّكِرٍ﴾</q> يقول: هل مَن يتذكر؟ فيعلم أنّ ذلك حقٌّ فيعتبر ويخاف عقوبة الله تعالى{5}. (ز) ",footnotes:1:أخرجه عبد الرزاق ٢/٢٥٨، وابن جرير ٢٢/١٢٩ من طريق معمر.أخرجه عبد الرزاق ٢/٢٥٨، وعبد بن حميد -كما في التغليق ٤/٣٢٨-، وابن جرير ٢٢/١٢٨ من طريق سعيد بنحوه. وعزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ٢٢/١٢٨، وابن أبي حاتم -كما في تغليق التعليق ٤/٣٢٨- واللفظ له.لعله يشير إلى آيات قصة نوح في هذه السور: <q>﴿إنّا لَمّا طَغى الماءُ حَمَلْناكُمْ فِي الجارِيَةِ لِنَجْعَلَها لَكُمْ تَذْكِرَةً وتَعِيَها أُذُنٌ واعِيَةٌ﴾</q> [الحاقة:١١-١٢]، <q>﴿ونَجَّيْناهُ وأَهْلَهُ مِنَ الكَرْبِ العَظِيمِ وجَعَلْنا ذُرِّيَّتَهُ هُمُ الباقِينَ وتَرَكْنا عَلَيْهِ فِي الآخِرِينَ﴾</q> [الصافات:٧٦-٧٨]، <q>﴿فَأَنْجَيْناهُ وأَصْحابَ السَّفِينَةِ وجَعَلْناها آيَةً لِلْعالَمِينَ﴾</q> [العنكبوت:١٥].تفسير مقاتل بن سليمان ٤/١٧٩-١٨٠.
54,16," <q>﴿فَكَیۡفَ كَانَ عَذَابِی وَنُذُرِ ۝١٦ وَلَقَدۡ یَسَّرۡنَا ٱلۡقُرۡءَانَ لِلذِّكۡرِ﴾</q> - تفسير ٧٣٧٩٦- عن عبد الله بن عباس -من طريق الضَّحّاك- في قوله: <q>﴿ولَقَدْ يَسَّرْنا القُرْآنَ لِلذِّكْرِ﴾</q>، قال: لولا أنّ الله يسّره على لسان الآدميين ما استطاع أحدٌ مِن الخلق أن يتكلّم بكلام الله{1}. (١٤/٧٧) ٧٣٧٩٧- عن أنس بن مالك مرفوعًا، مثله{2}. (١٤/٧٨) ٧٣٧٩٨- قال سعيد بن جُبَير: يسَّرنا للحفظ ظاهرًا، وليس مِن كُتُبِ اللهِ كتابًا يُقرأ كلُّه ظاهرًا إلا القرآن{3}٦٣٢٤. (ز) ٦٣٢٤ ساق ابن عطية قول ابن جبير (٨/١٤٥)، ثم علَّق بقوله: «يسّر بما فيه من حُسن النّظم وشرف المعاني، فله لَوْطة بالقلوب، وامتزاج بالعقول السليمة». ٧٣٧٩٩- عن مجاهد بن جبر -من طريق ابن أبي نجيح- <q>﴿ولَقَدْ يَسَّرْنا القُرْآنَ لِلذِّكْرِ﴾</q>، قال: هوَّنّا قراءته{4}. (١٤/٧٧) ٧٣٨٠٠- قال مقاتل بن سليمان: <q>﴿فَكَيْفَ كانَ عَذابِي ونُذُرِ ولَقَدْ يَسَّرْنا﴾</q> يقول: هوَّنّا <q>﴿القُرْآنَ لِلذِّكْرِ﴾</q> يعني: ليتذكّروا فيه{5}. (ز) ٧٣٨٠١- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿ولَقَدْ يَسَّرْنا القُرْآنَ لِلذِّكْرِ﴾</q>، قال: يسّرنا: بيّنّا{6}. (ز) <q>﴿فَهَلۡ مِن مُّدَّكِرࣲ ۝١٥﴾</q> - قراءات ٧٣٨٠٢- عن ابن مسعود، قال: قرأتُ على النبيِّ ﷺ: (فَهَلْ مِن مُّذَّكِرٍ) بالذال، فقال: <q>﴿فَهَلْ مِن مُّدَّكِرٍ﴾</q> بالدال{7}٦٣٢٥. (١٤/٧٨) ٦٣٢٥ علَّق ابن كثير (١٣/٢٩٨) على هذا الحديث بقوله: «أخرج مسلم هذا الحديث وأهل السنن إلا ابن ماجه، من حديث أبي إسحاق». <q>﴿فَهَلۡ مِن مُّدَّكِرࣲ ۝١٥﴾</q> - تفسير الآية ٧٣٨٠٣- عن عبد الله بن عباس، في قوله: <q>﴿فَهَلْ مِن مُدَّكِرٍ﴾</q>، قال: هل من متذكّر{8}. (١٤/٧٨) ٧٣٨٠٤- عن محمد بن كعب القُرَظيّ -من طريق أبي صخر- في قوله: <q>﴿فَهَلْ مِن مُدَّكِرٍ﴾</q>، قال: هل من مُنزَجِر عن المعاصي{9}. (١٤/٧٨) ٧٣٨٠٥- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿فَهَلْ مِن مُدَّكِرٍ﴾</q>، قال: هل مِن طالب خير يُعان عليه؟{10}. (١٤/٧٨) ٧٣٨٠٦- عن مَطر الورّاق -من طريق ابن شَوذب- في قوله: <q>﴿فَهَلْ مِن مُدَّكِرٍ﴾</q>، قال: هل مِن طالب علم فيُعان عليه؟{11}٦٣٢٦٦٣٢٧. (١٤/٧٨) ٦٣٢٦ ساق ابن عطية (٨/١٤٥) هذا القول الذي قاله قتادة، ومطر الوراق، وضمرة، ثم علَّق بقوله: «الآية تعديد نعمة في أنّ الله يسّر الهدى ولا بخل من قبله، فلله درّ مَن قبل واهتدى». ٦٣٢٧ علَّق ابن كثير (١٣/٢٩٨) على هذا الأثر بقوله: «وكذا علقه البخاري بصيغة الجزم عن مطر الوراق». ٧٣٨٠٧- قال مقاتل بن سليمان: <q>﴿فَهَلْ مِن مُدَّكِرٍ﴾</q> يعنى: فيتذكّر فيه، ولولا أنّ الله تعالى يسّر القرآن للذِّكر ما استطاع أحدٌ أن يتكلّم بكلام الله تعالى، ولكنّ الله تعالى يسّره على خلْقه، فيقرؤونه على كلّ حال{5}. (ز) ٧٣٨٠٨- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿فَهَلْ مِن مُدَّكِرٍ﴾</q>، قال: المدّكر: الذي يتذكّر، وفي كلام العرب: المدّكر: المتذكّر{13}. (ز) ٧٣٨٠٩- عن سفيان [الثوري] -من طريق مهران- <q>﴿فَهَلْ مِن مُدَّكِرٍ﴾</q>، قال: فهل من مذّكّر{13}. (ز) ٧٣٨١٠- عن ضمرة -من طريق مروان- قال: <q>﴿ولَقَدْ يَسَّرْنا القُرْآنَ لِلذِّكْرِ فَهَلْ مِن مُدَّكِرٍ﴾</q> طالب علم{15}٦٣٢٨. (ز) ٦٣٢٨ اختُلف في معنى قوله: <q>﴿فهل من مدكر﴾</q> على قولين: الأول: أنه يعني: فهل من معتبرٍ ومتّعظ. الثاني: فهل من طالب خير فيُعان عليه. ورجَّح ابنُ جرير (٢٢/١٣١) القول الأول مستندًا إلى الأغلب في اللغة، فقال: «لأن ذلك هو الأغلب من معانيه على ظاهره». وبيّن أن القول الثاني قريب مما قاله. <q>﴿فَهَلۡ مِن مُّدَّكِرࣲ ۝١٥﴾</q> - آثار متعلقة بالآية ٧٣٨١١- عن محمد بن سيرين -من طريق عاصم- أنه مرَّ برجل يقول: سورة خفيفة. قال لا تقُلْ: سورة خفيفة. ولكن قُلْ: سورة يسيرة. لأن الله يقول: <q>﴿ولَقَدْ يَسَّرْنا القُرْآنَ لِلذِّكْرِ﴾</q>{16}. (١٤/٧٨) ",footnotes:1:أخرجه البيهقي (٥٧٢). وعزاه السيوطي إلى ابن أبي حاتم، وابن مردويه.أورده الديلمي في الفردوس ٥/٢٥٩-٢٦٠ (٨١٢٢) بنحوه. قال ابن عراق الكناني في تنزيه الشريعة ١/٣٠٩ (٨٤): «وفيه عباد بن عبد الصمد». وقال ابن عدي في الكامل في ضعفاء الرجال ٥/٥٥٢ في ترجمة عباد بن عبد الصمد أبي معمر (١١٧١): «وعباد بن عبد الصمد له عن أنس غير حديث منكر، وعامة ما يرويه في فضائل علي، وهو ضعيف منكر الحديث، ومع ذلك غالٍ في التشيع».تفسير الثعلبي ٩/١٦٥.أخرجه آدم ابن أبي إياس -كما في تفسير مجاهد ص٦٣٤-، وابن جرير ٢٢/١٣٠ بلفظ: هوَّنّا، والبيهقي في الأسماء والصفات (٥٧٣). وعلقه البخاري في صحيحه (ت: مصطفى البغا) كتاب التوحيد، باب <q>﴿ولقد يسرنا القرآن للذكر فهل من مدكر﴾</q> ٦/٢٧٤٤. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.تفسير مقاتل بن سليمان ٤/١٨٠.أخرجه ابن جرير ٢٢/١٣١.أخرجه البخاري (٤٨٧٤)، والحاكم ٢/٢٧٣ (٢٩٨٥). و(فَهَلْ مِن مُّذَّكِرٍ) بالذال قراءة شاذة، تروى أيضًا عن عيسى، وقتادة. انظر: مختصر ابن خالويه ص١٤٨-١٤٩.عزاه السيوطي إلى ابن المنذر، وعبد بن حميد.أخرجه عبد الله بن وهب في الجامع -تفسير القرآن ٢/١٤٧ (٢٩٧). وعزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ٢٢/١٣١، ومن طريق الحارث بن عبيد أيضًا. وعزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ٢٢/١٣١-١٣٢، وأبو نعيم في الحلية ٣/٧٦. وعزاه السيوطي إلى ابن أبي الدنيا، وابن المنذر.تفسير مقاتل بن سليمان ٤/١٨٠.أخرجه ابن جرير ٢٢/١٣٠.أخرجه ابن جرير ٢٢/١٣٠.أخرجه الدارمي في سننه ١/٣٦٤ (٣٥٩).أخرجه عبد الله بن وهب في الجامع -تفسير القرآن ٣/١٤ (١٨)، وابن أبي شيبة في مصنفه (ت: محمد عوامة) ١٥/٤٩٧-٤٩٨ (٣٠٧٢٠). وعزاه السيوطي إلى ابن المنذر، وزاد ابن وهب في روايته: فإن الله يقول: <q>﴿إنّا سَنُلْقِي عَلَيْكَ قَوْلًا ثَقِيلًا﴾</q> [المزمل:٥].
  54,17,""
54,18," <q>﴿كَذَّبَتۡ عَادࣱ فَكَیۡفَ كَانَ عَذَابِی وَنُذُرِ ۝١٨ إِنَّاۤ أَرۡسَلۡنَا عَلَیۡهِمۡ رِیحࣰا صَرۡصَرࣰا فِی یَوۡمِ نَحۡسࣲ مُّسۡتَمِرࣲّ ۝١٩﴾</q> - تفسير ٧٣٨١٢- عن عبد الله بن عباس -من طريق عطية العَوفيّ- في قوله: <q>﴿إنّا أرْسَلْنا عَلَيْهِمْ رِيحًا صَرْصَرًا﴾</q>، قال: باردة{1}. (١٤/٧٩) ٧٣٨١٣- عن مجاهد بن جبر، في قوله: <q>﴿صَرْصَرًا﴾</q>، قال: شديدة{2}. (١٤/٧٩) ٧٣٨١٤- عن الضَّحّاك بن مُزاحِم -من طريق عبيد- في قوله: <q>﴿رِيحًا صَرْصَرًا﴾</q>: باردة{1}. (ز) ٧٣٨١٥- عن الحسن البصري -من طريق قتادة- في قوله تعالى: <q>﴿رِيحًا صَرْصَرًا﴾</q>، قال: الصرصر: الباردة{4}. (ز) ٧٣٨١٦- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿رِيحًا صَرْصَرًا﴾</q>، قال: الباردة{5}. (١٤/٧٩) ٧٣٨١٧- قال مقاتل بن سليمان: <q>﴿كَذَّبَتْ عادٌ﴾</q> هودًا بالعذاب <q>﴿فَكَيْفَ كانَ عَذابِي ونُذُرِ﴾</q> يقول: الذي أنذر قومه، ألم يجدوه حقًّا؟! ثم أخبر عن عذابهم، فقال: <q>﴿إنّا أرْسَلْنا عَلَيْهِمْ رِيحًا صَرْصَرًا﴾</q> يعني: باردة شديدة{6}. (ز) ٧٣٨١٨- عن سفيان [الثوري] -من طريق مهران- <q>﴿رِيحًا صَرْصَرًا﴾</q>، قال: شديدة، والصَّرْصر: الباردة{1}. (ز) ٧٣٨١٩- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿رِيحًا صَرْصَرًا﴾</q>، قال: الصَّرْصر: الشديدة{1}٦٣٢٩. (ز) ٦٣٢٩ ذكر ابنُ عطية (٨/١٤٦) أنّ مَن قال: «الصّرصر» معناه: الباردة، فهو: الصرّ. ومَن قال معناه: المصوّتة نحو هذين الحرفين. فهو مأخوذ من صوت الريح إذا هبّت دفعًا، كأنها تنطق بهذين الحرفين؛ الصاد والراء. <q>﴿فِی یَوۡمِ نَحۡسࣲ مُّسۡتَمِرࣲّ ۝١٩﴾</q> - تفسير ٧٣٨٢٠- عن عبد الله بن عباس -من طريق عطية العَوفيّ- في قوله: <q>﴿فِي يَوْمِ نَحْسٍ﴾</q>، قال: أيام شِداد{9}. (١٤/٧٩) ٧٣٨٢١- عن عبد الله بن عباس، أنّ نافع بن الأزرق قال له: أخبِرني عن قوله ﷿: <q>﴿فِي يَوْمِ نَحْسٍ مُسْتَمِرٍّ﴾</q>. قال: النّحس والبلاء والشّدة. قال: وهل تعرف العرب ذلك؟ قال: نعم، أما سمعتَ قول زُهير بن أبي سُلمى وهو يقول: سواءٌ عليه أيّ يوم أتيتَه أساعة نحْسٍ تُتَّقى أم بأَسْعُد؟{10}. (١٤/٧٩) ٧٣٨٢٢- عن زِرّ بن حُبَيش، <q>﴿فِي يَوْمِ نَحْسٍ مُسْتَمِرٍّ﴾</q>، قال: يوم الأربعاء{11}. (١٤/٨٠) ٧٣٨٢٣- عن الضَّحّاك بن مُزاحِم -من طريق عبيد- في قوله: <q>﴿فِي يَوْمِ نَحْسٍ﴾</q>: يوم شديد{12}٦٣٣٠. (ز) ٦٣٣٠ ذكر ابنُ جرير (٢٢/١٣٤) أنّ مَن فسّر النّحس بالشديد -كما قال ابن عباس، والضَّحّاك- فإنه يجعله من صفة اليوم، وينبغي أن تكون قراءته بتنوين اليوم، وكسر الحاء من النّحس، فيكون «في يومٍ نَحِس»، كما قال جل ثناؤه: <q>﴿في أيام نَحِسات﴾</q> [فصلت:١٦]. ثم قال: «ولا أعلم أحدًا قرأ ذلك كذلك في هذا الموضع، غير أنّ الرواية التي ذكرت في تأويل ذلك عمن ذكرت عنه على ما وصفنا تدل على أن ذلك كان قراءة». ٧٣٨٢٤- عن الحسن البصري -من طريق قتادة-: النّحس: المشؤوم{4}. (ز) ٧٣٨٢٥- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿فِي يَوْمِ نَحْسٍ﴾</q> قال: في يوم مشئوم على القوم، <q>﴿مُسْتَمِرٍّ﴾</q> استمرّ عليهم شرّه{14}. (١٤/٧٩) ٧٣٨٢٦- عن إسماعيل السُّدِّيّ -من طريق أسباط بن نصر- قال: ... <q>﴿فِي يَوْمِ نَحْسٍ مُسْتَمِرٍّ﴾</q> النّحس: الشؤم، والمستمرّ: استمرّ عليهم العذاب <q>﴿سَبْعَ لَيالٍ وثَمانِيَةَ أيّامٍ حُسُومًا﴾</q> قال: حَسمتْ كلّ شيء مرّتْ به <q>﴿فَتَرى القَوْمَ فِيها صَرْعى﴾</q> [الحاقة:٧]، <q>﴿كَأَنَّهُمْ أعْجازُ نَخْلٍ مُنْقَعِرٍ﴾</q>{15}. (ز) ٧٣٨٢٧- قال مقاتل بن سليمان: <q>﴿فِي يَوْمِ نَحْسٍ﴾</q> يعني: شديد <q>﴿مُسْتَمِرٍّ﴾</q> يقول: استمرت عليهم الرّيح لا تفتر عنهم سبع ليال، وثمانية أيام حسومًا دائمة{6}. (ز) ٧٣٨٢٨- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿فِي يَوْمِ نَحْسٍ﴾</q> قال النّحس: الشرّ، <q>﴿فِي يَوْمِ نَحْسٍ﴾</q> في يوم شر{9}. (ز) <q>﴿فِی یَوۡمِ نَحۡسࣲ مُّسۡتَمِرࣲّ ۝١٩﴾</q> - آثار متعلقة بالآية ٧٣٨٢٩- عن جابر بن عبد الله، قال: قال رسول الله ﷺ: «يوم الأربعاء يوم نحْسٍ مستمرّ»{18}. (١٤/٨٠) ٧٣٨٣٠- عن أنس، قال: سُئِل رسولُ الله ﷺ عن الأيام، وسُئل عن يوم الأربعاء. قال: «يوم نحْسٍ». قالوا: وكيف ذاك، يا رسول الله؟ قال: «أغرق الله فرعون وقومه، وأهلك عادًا وثمود»{19}. (١٤/٨١) ٧٣٨٣١- عن ابن عباس، قال: قال رسول الله ﷺ: «آخر أربعاء في الشهر يوم نحْسٍ مستمرّ»{20}٦٣٣١. (١٤/٨١) ٦٣٣١ ذكر ابنُ عطية (٨/١٤٦) أن ما جاء في الأحاديث بأنّ النّحس هو يوم الأربعاء جعل بعضَ الناس يتأول أنه مستصحب في الزمن كلّه، وانتقده بقوله: «وهذا عندي ضعيف، وإن كان الدولابي أبو بشر قد ذكر حديثًا رواه أبو جعفر المنصور، عن أبيه محمد، عن أبيه علي، عن أبيه عبد الله بن عباس، قال: قال رسول الله ﷺ: «آخر أربعاء من الشهر يوم نحْسٍ مستمرّ»». ثم قال: «ويوجد نحو هذا في كلام الفُرس والأعاجم، وقد وُجد ذِكر الأربعاء التي لا تدور في شعر لبعض الخُراسانيّين المولدين». وذكر (٥/٢١٦ ط: دار الكتب العلمية) أنّ النَّقاش نسب لجعفر بن محمد القول بأنه كان في أربعاء لا تدور، وأنه قال: كان القمر منحوسًا بزُحل. وانتقده، فقال: «وهذه نزعة سوء عياذًا بالله أن تصحّ عن جعفر بن محمد». ",footnotes:1:أخرجه ابن جرير ٢٢/١٣٣.عزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ٢٢/١٣٣.أخرجه عبد الرزاق ٢/٢٥٨.أخرجه ابن جرير ٢٢/١٣٣، كذلك من طريق معمر بنحوه. وعزاه السيوطي إلى عبد بن حميد.تفسير مقاتل بن سليمان ٤/١٨٠.أخرجه ابن جرير ٢٢/١٣٣.أخرجه ابن جرير ٢٢/١٣٣.أخرجه ابن جرير ٢٢/١٣٤.أخرجه الطستي في مسائل نافع (٢٤٣).عزاه السيوطي إلى ابن أبي حاتم.أخرجه ابن جرير ٢٢/١٣٥.أخرجه عبد الرزاق ٢/٢٥٨.أخرجه ابن جرير ٢٢/١٣٥، وبلفظ: يستمر بهم إلى نار جهنم، ومن طريق معمر بنحوه. وعزاه السيوطي إلى عبد بن حميد.أخرجه ابن أبي الدنيا في العقوبات ٤/٤٥٨ (١٢٩).تفسير مقاتل بن سليمان ٤/١٨٠.أخرجه ابن جرير ٢٢/١٣٤.أخرجه الطبراني في الأوسط ١/٢٤٣ (٧٩٧)، ٦/٢٨٣ (٦٤٢٢)، والبيهقي في الكبرى ١٠/٢٨٦ (٢٠٦٥٥)، من طريق إبراهيم بن أبي حية، عن جعفر بن محمد، عن أبيه، عن جابر بن عبد الله به. قال الطبراني: «لم يروِ هذا الحديثَ عن جعفر بن محمد إلا إبراهيم بن أبي حية». وقال ابن القيسراني في ذخيرة الحفاظ ١/٢١٨ (٦٣): «هذا الأصل فيه مرسل، والزيادة فيه ينفرد بها إبراهيم، وهو لا شيء». وقال ابن الجوزي في الموضوعات ٢/٧٤ بعد أن ذكر أحاديث وهذا من بينها: «هذه الأحاديث لا تصحّ عن رسول الله ﷺ ...، وأما حديث جابر فلم يروه غير إبراهيم، قال الدارقطني: هو متروك». وقال ابن حجر في التلخيص الحبير ٤/٤٩٢ (٢١٣٣): «إبراهيم ضعيف جدًّا». وقال ابن عراق الكناني في تنزيه الشريعة ٢/٥٥ (٢٤): «لا يصحّ، فيه إبراهيم بن أبي حية». وقال الفتني في تذكرة الموضوعات ص١١٦: «موضوع». وقال المناوي في فيض القدير ١/٤٧: «سند ضعيف ...». وقال أبو عبد الرحمن الحوت في أسنى المطالب ص٣٣٥ (١٧٧٨): «موضوع». وقال الشوكاني في الفوائد المجموعة ص٤٣٨ (٢٩): «قال الصنعاني: موضوع. وكذا قال ابن الجوزي. ورواه الخطيب وفي إسناده كذّاب، ورواه ابن مردويه وفي إسناده متروك». وقال الألباني في الضعيفة ٤/٨٣: «أورده ابن الجوزي في الموضوعات أيضًا من طرق، وكلها واهية شديدة الضعف، فما أبعد ابن الجوزي عن الصواب، وما أحسن السيوطي بإيراده إياه في الزيادة على الجامع».أخرجه ابن مردويه -كما في اللآلئ المصنوعة ١/٤٤٢-، من طريق أبي الأخيل خالد بن عمرو الحمصي، عن يزيد بن خالد القرشي، عن عبد الرحمن بن كسرى، عن مسلم بن عبد الله، عن سعيد بن ميمون، عن أنس بن مالك به. قال السيوطي: «أبو الأخيل متهم».أخرجه الخطيب في تاريخه ١٦/٥٨٤ (٤٨٣١)، وابن الجوزي في الموضوعات ٢/٧٣، من طريق مسلمة بن الصلت، عن أبي الوزير صاحب ديوان المهدي، عن المهدي أمير المؤمنين، عن أبيه، عن أبيه، عن ابن عباس به. قال المناوي في التيسير بشرح الجامع الصغير ١/٨: «ضعيف، بل واهٍ؛ لضعف رواية سلمة بن الصلت وغيره». وقال في فيض القدير ١/٤٧ (٨): «فيه سلمة بن الصلت؛ قال أبو حاتم: متروك. وجزم ابن الجوزي بوضعه، وحكاه في الكبير ولم يتعقّبه، وقال ابن رجب: حديث لا يصحّ». وقال السيوطي: «سند ضعيف». وقال في اللآلئ المصنوعة ١/٤٤١: «مسلمة متروك». وقال ابن عراق الكناني في تنزيه الشريعة ٢/٥٥ (٢٣): «ولا يصحّ، فيه مسلمة بن الصلت؛ متروك». وأورده الشوكاني في الفوائد المجموعة ص٤٣٨ (٢٦) وقال: «قال ابن حجر: هذا كذب على ابن عباس لا تحل روايته». وقال الألباني في الضعيفة ٤/٨٣ (١٥٨١): «موضوع».
  54,19,""
54,20," <q>﴿تَنزِعُ ٱلنَّاسَ كَأَنَّهُمۡ أَعۡجَازُ نَخۡلࣲ مُّنقَعِرࣲ ۝٢٠ فَكَیۡفَ كَانَ عَذَابِی وَنُذُرِ ۝٢١ وَلَقَدۡ یَسَّرۡنَا ٱلۡقُرۡءَانَ لِلذِّكۡرِ فَهَلۡ مِن مُّدَّكِرࣲ ۝٢٢﴾</q> - تفسير ٧٣٨٣٢- عن قَرَظَة بن كعب، عن رسول الله ﷺ، قال: «انتزعت الرّيحُ الناس من قبورهم»{1}. (ز) ٧٣٨٣٣- عن أبي هريرة -من طريق شهر- قال: إن كان الرجل مِن عاد لَيَتَّخذ المِصراعين مِن حجارة، لو اجتمع عليه خمسمائة مِن هذه الأمة لم يستطيعوا أن يحملوه، فكان الرجل يغمِز قدمه في الأرض، فتدخل فيه{2}. (١٤/٨١) ٧٣٨٣٤- عن عبد الله بن عباس -من طريق عطية العَوفيّ- قوله: <q>﴿تَنْزِعُ النّاسَ كَأَنَّهُمْ أعْجازُ نَخْلٍ مُنْقَعِرٍ﴾</q>، قال: هم قوم عاد حين صرَعتهم الرّيح، كأنهم فِلق نخلٍ مُنقعر{3}. (ز) ٧٣٨٣٥- عن عبد الله بن عباس، في قوله: <q>﴿كَأَنَّهُمْ أعْجازُ نَخْلٍ﴾</q> قال: أصول نخل <q>﴿مُنْقَعِرٍ﴾</q> قال: مُنقلع{4}. (١٤/٨٢) ٧٣٨٣٦- عن عبد الله بن عباس، في قوله: <q>﴿أعْجازُ نَخْلٍ مُنْقَعِرٍ﴾</q>، قال: أعجاز سواد النخل{5}. (١٤/٨٢) ٧٣٨٣٧- عن مجاهد بن جبر -من طريق هلال بن خباب- في قوله: <q>﴿كَأَنَّهُمْ أعْجازُ نَخْلٍ مُنْقَعِرٍ﴾</q>، قال: وقعت رؤوسهم كأمثال الأخْبِية{6}، وتفرّقت أعناقهم، فشبّهها بأعجاز نخلٍ منقعر{7}٦٣٣٢. (١٤/٨٢) ٦٣٣٢ ساق ابن عطية (٨/١٤٦) هذا القول الذي قاله ابن عباس، ومجاهد، ثم علَّق بقوله: «وذلك أنّ المنقعر: هو الذي ينقلب من قعره. فذلك التشعّب الذي كان لأعجاز النخل كان يشبهها ما تقطع وتشعث من شخص الإنسان». وذكر (٨/١٤٦-١٤٧) أنّ قومًا قالوا: إنما شبّههم بأعجاز النخل لأنهم كانوا يحفرون حفرًا ليمتنعوا فيها من الريح، وعلَّق عليه بقوله: «فكأنه شبّه تلك الحُفر بعد النزع بحفر أعجاز النخل». ٧٣٨٣٨- عن الحسن البصري -من طريق محمد بن سيف- قال: لَمّا أقبلت الرّيح قام إليها قومُ عاد، فأخذ بعضُهم بأيدي بعض، وغمزوا أقدامهم في الأرض، وقالوا: مَن يُزيل أقدامنا عن الأرض إن كان صادقًا؟! فأرسل الله عليهم الرّيح <q>﴿تَنْزِعُ النّاسَ كَأَنَّهُمْ أعْجازُ نَخْلٍ مُنْقَعِرٍ﴾</q>{8}. (١٤/٨١) ٧٣٨٣٩- عن إسماعيل السُّدِّيّ -من طريق أسباط بن نصر- قال: <q>﴿كَأَنَّهُمْ أعْجازُ نَخْلٍ مُنْقَعِرٍ﴾</q> انقعر من أصوله{9}. (ز) ٧٣٨٤٠- قال مقاتل بن سليمان: <q>﴿تَنْزِعُ﴾</q> الريحُ أرواح <q>﴿النّاسَ﴾</q> من أجسادهم، فتصرعهم، ثم شبّههم، فقال: <q>﴿كَأَنَّهُمْ أعْجازُ نَخْلٍ﴾</q> يعني: أصول النخل <q>﴿مُنْقَعِرٍ﴾</q> يقول: انقعرت النّخلة مِن أصلها، فوقعت، وهو المنقطع، فشبّههم حين وقعوا مِن شدّة العذاب بالنخيل الساقطة التي ليست لها رؤوس، وشبّههم بالنخيل لطُولهم، كان طول كلّ رجل منهم اثني عشر ذراعًا{10}. (ز) <q>﴿تَنزِعُ ٱلنَّاسَ كَأَنَّهُمۡ أَعۡجَازُ نَخۡلࣲ مُّنقَعِرࣲ ۝٢٠ فَكَیۡفَ كَانَ عَذَابِی وَنُذُرِ ۝٢١ وَلَقَدۡ یَسَّرۡنَا ٱلۡقُرۡءَانَ لِلذِّكۡرِ فَهَلۡ مِن مُّدَّكِرࣲ ۝٢٢﴾</q> - آثار متعلقة بالآية ٧٣٨٤١- عن محمد بن إسحاق -من طريق سلمة- قال: لَمّا هاجت الرّيح قام نفرٌ مِن عاد سبعة، سُمّي لنا منهم ستة من أيِّد عاد وأجسمها، منهم: عمرو بن الحليّ، والحارث بن شداد، والهِلْقام، وابنا تيقن، وخَلَجان بن أسعد، فأَوْلجوا العيال في شِعبٍ بين جبلين، ثم اصطفُّوا على باب الشِّعب ليردّوا الرّيح عمَّن بالشّعب مِن العيال، فجعلت الريح تَجْعَفُهُم{11} رجلًا رجلًا، فقالت امرأة من عاد: ذهب الدهر بعمرو بـ ـن حليٍّ والهَنِيّات ثم بالحـارث والهِلْـ ـقام طلّاع الثَّنِيّات والذي سدّ مَهبّ الرّ يح أيام البليّات{12}. (ز) ٧٣٨٤٢- عن محمد بن إسحاق -من طريق إسماعيل بن عيّاش- قال: لما هبّت الرّيح قام سبعة من عاد، فقالوا: نردّ الرّيح. فأتَوا فَم الشّعب الذي يأتي منه الرّيح، فوقفوا عليه، فجعلت الرّيح تهبّ، فتدخل تحت واحد منهم، فتقتلعه من الأرض، فترمي به على رأسه، فتندقّ رقبته، ففعلت ذلك بستة منهم، وتركتهم كما قال الله: <q>﴿أعْجازُ نَخْلٍ خاوِيَةٍ﴾</q> [الحاقة:٧]، وبقي الخَلَجان، فأتى هودًا، فقال: يا هود، ما هذا الذي أرى في السحاب كهيئة البَخاتيّ؟ قال: تلك ملائكة ربي. فقال: مالي إنْ أسلمْتُ؟ قال: تَسْلم. قال: أيعيذني ربّك إنْ أسلمْتُ من هؤلاء؟ فقال: ويلك، أرأيتَ مَلِكًا يُعِيذ من جُنده؟ فقال: وعزّته، لو فعل ما رضيتُ. قال: ثم مال إلى جانب الجبل، فأخذ برُكنٍ منه، فهزّه، فاهتزّ في يده، ثم جعل يقول: لم يبق إلا الخَلَجان نفسه يا لك من يومٍ دهاني أمسُه بثابت الوطِء شديدٍ وطْسه لو لم يجئني جئـتُه أجُسُّه قال: ثم هبّت الريح، فألحقَتْه بأصحابه{13}. (ز) ",footnotes:1:علّقه الثعلبي ٩/١٦٦، من طريق أبي حمزة الثُّمالي، عن محمد بن سفيان، عن محمد بن قرظة بن كعب، عن أبيه به. وسنده ضعيف؛ فيه ثابت بن أبي صفية الثُّمالي، قال ابن حجر في التقريب (٨١٨): «ضعيف، رافضي». وفيه محمد بن قرظة بن كعب الأنصاري، قال عنه ابن حجر في التقريب (٦٢٤١): «مجهول».أخرجه ابن جرير ٢٢/١٣٧ بنحوه. وعزاه السيوطي إلى عَبد بن حُمَيد.أخرجه ابن جرير ٢٢/١٣٨-١٣٩.عزاه السيوطي إلى ابن المنذر.عزاه السيوطي إلى ابن أبي حاتم.الأخبية: جمع خباء، والخباء من الأبنية ما كان من وبر أو صوف ولا يكون من شعر، وهو على عمودين أو ثلاثة. اللسان (خبي).أخرجه ابن جرير ٢٢/١٣٨. وعزاه السيوطي إلى سعيد بن منصور، وابن المنذر.أخرجه ابن جرير ٢٢/١٣٧، وابن أبي حاتم ٩/٢٧٩٨. وعزاه السيوطي إلى عَبد بن حُمَيد، وعبد الله بن أحمد في زوائد الزهد، وابن المنذر، وابن أبي حاتم.أخرجه ابن أبي الدنيا في العقوبات ٤/٤٥٨ (١٢٩).تفسير مقاتل بن سليمان ٤/١٨٠-١٨١.تَجْعَفُهُم: تصرعهم. لسان العرب (جعف).أخرجه ابن جرير ٢٢/١٣٥-١٣٦.أخرجه ابن جرير ٢٢/١٣٦-١٣٧.
  54,21,""
  54,22,""
54,23," <q>﴿كَذَّبَتۡ ثَمُودُ بِٱلنُّذُرِ ۝٢٣ فَقَالُوۤا۟ أَبَشَرࣰا مِّنَّا وَ ٰ⁠حِدࣰا نَّتَّبِعُهُۥۤ إِنَّاۤ إِذࣰا لَّفِی ضَلَـٰلࣲ وَسُعُرٍ ۝٢٤﴾</q> - تفسير ٧٣٨٤٣- قال عبد الله بن عباس: <q>﴿وسُعُرٍ﴾</q> يعني: وعذاب{1}. (ز) ٧٣٨٤٤- عن عبد الله بن عباس، في قوله: <q>﴿إنّا إذًا لَفِي ضَلالٍ وسُعُرٍ﴾</q>، قال: شقاء{2}. (١٤/٨٢) ٧٣٨٤٥- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿وسُعُرٍ﴾</q>، قال: ضلال{3}. (١٤/٨٣) ٧٣٨٤٦- قال الحسن البصري: <q>﴿وسُعُرٍ﴾</q> شدّة العذاب{1}. (ز) ٧٣٨٤٧- قال وهْب بن مُنَبِّه: <q>﴿وسُعُرٍ﴾</q> أي: بُعد من الحق{5}. (ز) ٧٣٨٤٨- عن قتادة بن دعامة -من طريق معمر- <q>﴿إنّا إذًا لَفِي ضَلالٍ وسُعُرٍ﴾</q>، قال: في ضلال وعناء{6}. (١٤/٨٢) ٧٣٨٤٩- قال إسماعيل السدي: <q>﴿وسُعُرٍ﴾</q> في احتراق{7}. (ز) ٧٣٨٥٠- قال مقاتل بن سليمان: <q>﴿كَذَّبَتْ ثَمُودُ بِالنُّذُرِ﴾</q> يعني: بالرُّسُل، <q>﴿فَقالُوا أبَشَرًا مِنّا واحِدًا نَتَّبِعُهُ﴾</q> يعنون: صالحًا، <q>﴿إنّا إذًا لَفِي ضَلالٍ وسُعُرٍ﴾</q> يعني: لفي شقاء وعناء إن تبعنا صالحًا{8}. (ز) ٧٣٨٥١- قال سفيان بن عُيينة: <q>﴿إنّا إذًا لَفِي ضَلالٍ وسُعُرٍ﴾</q> هو جمع سعير{1}٦٣٣٣. (ز) ٦٣٣٣ ذكر ابن عطية (٨/١٤٨) قولًا بأنّ السُّعر: هو الجنون. وعلَّق عليه بقوله: «ومنه قولهم: ناقة بمعنى مسعورة، إذا كانت تفرط في سيرها». ",footnotes:1:تفسير الثعلبي ٩/١٦٧، وتفسير البغوي ٤/٣٢٤.عزاه السيوطي إلى ابن المنذر.تفسير مجاهد ص٦٣٤، وأخرجه الفريابي -كما في التغليق ٤/٣٢٧-، وابن جرير ٢٢/١٤٣ بنحوه. وعزاه السيوطي إلى عبد بن حميد.تفسير الثعلبي ٩/١٦٧، وتفسير البغوي ٤/٣٢٤.تفسير الثعلبي ٩/١٦٧، وتفسير البغوي ٧/٤٣٠.أخرجه عبد الرزاق ٢/٢٦٠-٢٦١ بلفظ: في عناء وعذاب، وابن جرير ٢٢/١٤٠ بنحوه، ومن طريق سعيد. وعزاه السيوطي إلى عبد بن حميد.تفسير الثعلبي (ط: دار التفسير) ٢٥/٢٣٤.تفسير مقاتل بن سليمان ٤/١٨١.تفسير الثعلبي ٩/١٦٧، وتفسير البغوي ٤/٣٢٤.
  54,24,""
54,25," <q>﴿أَءُلۡقِیَ ٱلذِّكۡرُ عَلَیۡهِ مِنۢ بَیۡنِنَا بَلۡ هُوَ كَذَّابٌ أَشِرࣱ ۝٢٥﴾</q> - تفسير ٧٣٨٥٢- قال مقاتل بن سليمان: <q>﴿أأُلْقِيَ الذِّكْرُ عَلَيْهِ﴾</q> يعني: أنزل عليه الوحي <q>﴿مِن بَيْنِنا﴾</q> يعنون: صالحًا -صلى الله عليه-، ونحن أفضل منه عند الله منزلة! فقالوا: <q>﴿بَلْ هُوَ كَذّابٌ أشِرٌ﴾</q> يعني: بطِر مَرِح{1}. (ز) ٧٣٨٥٣- عن الحسن بن محمد بن سعيد القُرشي، قال: قلتُ لعبد الرحمن بن أبي حماد: ما الكذّاب الأشر؟ قال: الذي لا يُبالي ما قال{2}. (ز) ",footnotes:1:تفسير مقاتل بن سليمان ٤/١٨١.أخرجه ابن جرير ٢٢/١٤٠.
54,26," <q>﴿سَیَعۡلَمُونَ غَدࣰا مَّنِ ٱلۡكَذَّابُ ٱلۡأَشِرُ ۝٢٦﴾</q> - تفسير ٧٣٨٥٤- قال الفرّاء: وحدّثني سفيان بن عُيينة، عن رجل، عن مجاهد [بن جبر] أنه قرأ: <q>﴿سَيَعْلَمُونَ﴾</q> بالياء -كذا قال سفيان- <q>﴿غَدًا مَّنِ الكَذّابُ الأَشِرُ﴾</q>: وهو بمنزلة قولك في الكلام: رجل حذِر وحذُر، وفطِن وفطُن، وعجِل وعجُل{1}. (ز) ٧٣٨٥٥- قال محمد بن السّائِب الكلبي: <q>﴿سَيَعْلَمُونَ غَدًا﴾</q> يوم القيامة، وذكر الغد للتقريب على عادة الناس{2}. (ز) ٧٣٨٥٦- قال مقاتل بن سليمان: قال صالح: <q>﴿سَيَعْلَمُونَ غَدًا﴾</q> عند نزول العذاب <q>﴿مَنِ الكَذّابُ الأَشِرُ﴾</q> فهذا وعيد، أنا أم أنتم!{3}. (ز) ",footnotes:1:أخرجه الفراء في معاني القرآن ٣/١٠٨. و<q>﴿سَيَعْلَمُونَ﴾</q> بالياء قراءة العشرة.تفسير البغوي ٤/٣٢٥.تفسير مقاتل بن سليمان ٤/١٨١.
54,27," <q>﴿إِنَّا مُرۡسِلُوا۟ ٱلنَّاقَةِ فِتۡنَةࣰ لَّهُمۡ فَٱرۡتَقِبۡهُمۡ وَٱصۡطَبِرۡ ۝٢٧﴾</q> - تفسير ٧٣٨٥٧- قال مقاتل بن سليمان: <q>﴿إنّا مُرْسِلُوا النّاقَةِ فِتْنَةً لَهُمْ﴾</q> لنبتليهم بها، <q>﴿فارْتَقِبْهُمْ﴾</q> يعني: انتظِرهم، فإنّ العذاب نازل بهم، <q>﴿واصْطَبِرْ﴾</q> على الأذى{1}. (ز) ",footnotes:1:تفسير مقاتل بن سليمان ٤/١٨١.
