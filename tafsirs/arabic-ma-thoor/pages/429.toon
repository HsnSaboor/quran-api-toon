quran[7]{c,v,t}:
  34,8,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿أَفۡتَرَىٰ عَلَى ٱللَّهِ كَذِبًا أَم بِهِۦ جِنَّةُۢۗ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٣٠٧٠<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿أفْتَرى عَلى اللَّهِ كَذِبًا أمْ بِهِ جِنَّةٌ﴾</span>، قال: قالوا: إمّا أن يكون يكذب على الله، وإمّا أن يكون مجنونًا{1}. (١٢/١٦٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٣٠٧١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثم قال أبو سفيان: <span class="qpc-hafs">﴿أفْتَرى﴾</span> محمد ﷺ <span class="qpc-hafs">﴿عَلى اللَّهِ كَذِبًا﴾</span> حين يزعم أنّا نُبعث بعد الموت؟ <span class="qpc-hafs">﴿أمْ بِهِ جِنَّةٌ﴾</span> يقول: أم بمحمد جنون؟{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٣٠٧٢<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿أفْتَرى عَلى اللَّهِ كَذِبًا أمْ بِهِ جِنَّةٌ﴾</span> أي: جنون{3}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿بَلِ ٱلَّذِینَ لَا یُؤۡمِنُونَ بِٱلۡـَٔاخِرَةِ فِی ٱلۡعَذَابِ وَٱلضَّلَـٰلِ ٱلۡبَعِیدِ ۝٨﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٣٠٧٣<span class="dash">-</span></span> قال <span class="name-2">إسماعيل السُّدِّيّ</span>: <span class="qpc-hafs">﴿فِي العَذابِ والضَّلالِ البَعِيدِ﴾</span>، يعني: الشقاء الطويل{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٣٠٧٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: فرد الله -جلَّ وعزَّ- عليهم، فقال: <span class="qpc-hafs">﴿بَلِ الَّذِينَ لا يُؤْمِنُونَ بِالآخِرَةِ﴾</span> لا يصدقون بالبعث الذي فيه جزاء الأعمال هم أكذب وأشد فرية من محمد ﷺ حين كذَّبوا بالبعث. ثم قال جل وعز: هم <span class="qpc-hafs">﴿فِي العَذابِ﴾</span> في الآخرة، <span class="qpc-hafs">﴿والضَّلالِ البَعِيدِ﴾</span> الشقاء الطويل. نظيرها في آخر «اقتربت الساعة»{5}{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٣٠٧٥<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب-: ثم قال بعضهم لبعض: <span class="qpc-hafs">﴿أفْتَرى عَلى اللَّهِ كَذِبًا أمْ بِهِ جِنَّةٌ﴾</span> الرجل مجنون فيتكلم بما لا يعقل؟ فقال الله: <span class="qpc-hafs">﴿بَلِ الَّذِينَ لا يُؤْمِنُونَ بِالآخِرَةِ فِي العَذابِ والضَّلالِ البَعِيدِ﴾</span> وأمره أن يحلف لهم ليعتبروا. وقرأ: <span class="qpc-hafs">﴿قُلْ بَلى ورَبِّي لَتُبْعَثُنَّ ثُمَّ لَتُنَبَّؤُنَّ بِما عَمِلْتُمْ﴾</span> [التغابن:٧]{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٣٠٧٦<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿بَلِ الَّذِينَ لا يُؤْمِنُونَ بِالآخِرَةِ فِي العَذابِ﴾</span> في الآخرة، <span class="qpc-hafs">﴿والضَّلالِ البَعِيدِ﴾</span> في الدنيا، الذي لا يصيبون به خيرًا في الدنيا ولا الآخرة. وقال بعضهم: البعيد من الهُدى{3}<span class=comment-ref>٥٢٩١</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٥٢٩١</span> <span class="comment-type-4">أورد</span> <u>ابنُ عطية</u> (٧/١٥٩) في قوله تعالى: <span class="qpc-hafs">﴿في العذاب﴾</span> احتمالين، فقال: «<span class="qpc-hafs">﴿فِي العَذابِ﴾</span> يريد: عذاب الآخرة؛ لأنهم يصيرون إليه. و<b>يحتمل</b> أن يريد: في العذاب في الدنيا بمكابدة الشرع ومكايدته، ومحاولة إطفاء نور الله تعالى، وهو يتم، وهذا كله عذاب».</div></p></div>",footnotes:1:أخرجه ابن جرير ١٩/٢١٦. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.|2:تفسير مقاتل بن سليمان ٣/٥٢٤-٥٢٥.|3:تفسير يحيى بن سلام ٢/٧٤٦.|4:علقه يحيى بن سلام ٢/٧٤٧.|5:يشير إلى الآيات: <span class="qpc-hafs">﴿كَذَّبُوا بِآياتِنا كُلِّها فَأَخَذْناهُمْ أخْذَ عَزِيزٍ مُقْتَدِرٍ أكُفّارُكُمْ خَيْرٌ مِن أُولئِكُمْ أمْ لَكُمْ بَراءَةٌ فِي الزُّبُرِ، أمْ يَقُولُونَ نَحْنُ جَمِيعٌ مُنْتَصِرٌ، سَيُهْزَمُ الجَمْعُ ويُوَلُّونَ الدُّبُرَ، بَلِ السّاعَةُ مَوْعِدُهُمْ والسّاعَةُ أدْهى وأَمَرُّ، إنَّ المُجْرِمِينَ فِي ضَلالٍ وسُعُرٍ يَوْمَ يُسْحَبُونَ فِي النّارِ عَلى وُجُوهِهِمْ ذُوقُوا مَسَّ سَقَرَ﴾</span> [القمر:٤٢-٤٨].|6:تفسير مقاتل بن سليمان ٣/٥٢٤-٥٢٥.|7:أخرجه ابن جرير ١٩/٢١٦-٢١٧.|8:تفسير يحيى بن سلام ٢/٧٤٦.
  34,9,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿أَفَلَمۡ یَرَوۡا۟ إِلَىٰ مَا بَیۡنَ أَیۡدِیهِمۡ وَمَا خَلۡفَهُم مِّنَ ٱلسَّمَاۤءِ وَٱلۡأَرۡضِۚ إِن نَّشَأۡ نَخۡسِفۡ بِهِمُ ٱلۡأَرۡضَ أَوۡ نُسۡقِطۡ عَلَیۡهِمۡ كِسَفࣰا مِّنَ ٱلسَّمَاۤءِۚ إِنَّ فِی ذَ ٰ⁠لِكَ لَـَٔایَةࣰ لِّكُلِّ عَبۡدࣲ مُّنِیبࣲ ۝٩﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٣٠٧٧<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- في قوله: <span class="qpc-hafs">﴿أفَلَمْ يَرَوْا إلى ما بَيْنَ أيْدِيهِمْ وما خَلْفَهُمْ مِنَ السَّماءِ والأَرْضِ﴾</span>، قال: إنّك إن نظرت عن يمينك وعن شمالك ومِن بين يديك ومن خلفك؛ رأيتَ السماءَ والأرضَ{1}. (١٢/١٦٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٣٠٧٨<span class="dash">-</span></span> قال <span class="name-2">إسماعيل السُّدِّيّ</span>: <span class="qpc-hafs">﴿إلى ما بَيْنَ أيْدِيهِمْ﴾</span> يعني: أمامهم، <span class="qpc-hafs">﴿وما خَلْفَهُمْ مِنَ السَّماءِ والأَرْضِ﴾</span> وراءهم{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٣٠٧٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثم خوفهم، فقال -جلَّ وعزَّ-: <span class="qpc-hafs">﴿أفَلَمْ يَرَوْا إلى ما بَيْنَ أيْدِيهِمْ وما خَلْفَهُمْ﴾</span>، ثم بيّن ما هو، فقال جل وعز: <span class="qpc-hafs">﴿مِنَ السَّماءِ والأَرْضِ﴾</span>{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٣٠٨٠<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿أفَلَمْ يَرَوْا﴾</span> ينظروا <span class="qpc-hafs">﴿إلى ما بَيْنَ أيْدِيهِمْ﴾</span> يعني: أمامهم، <span class="qpc-hafs">﴿وما خَلْفَهُمْ مِنَ السَّماءِ والأَرْضِ﴾</span> وراءهم، حيثما قام الإنسان فإنّ بين يديه مِن السماء والأرض مثل ما خلفه منها{4}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿إِن نَّشَأۡ نَخۡسِفۡ بِهِمُ ٱلۡأَرۡضَ أَوۡ نُسۡقِطۡ عَلَیۡهِمۡ كِسَفࣰا مِّنَ ٱلسَّمَاۤءِۚ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٣٠٨١<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿إنْ نَشَأْ نَخْسِفْ بِهِمُ الأَرْضَ﴾</span> كما خسفنا بِمَن كان قبلهم، <span class="qpc-hafs">﴿أوْ نُسْقِطْ عَلَيْهِمْ كِسَفًا مِنَ السَّماءِ﴾</span> أي: قِطَعًا من السماء، إن شاء أن يعذب بسمائه فعل، وان شاء أن يعذب بأرضه فعل، وكل خلقه له جند. قال قتادة: وكان الحسن يقول: إن الزَبَدَ لمن جنودِ الله{5}. (١٢/١٦٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٣٠٨٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿إنْ نَشَأْ نَخْسِفْ بِهِمُ الأَرْضَ﴾</span> فتبتلعهم، <span class="qpc-hafs">﴿أوْ نُسْقِطْ عَلَيْهِمْ كِسَفًا مِنَ السَّماءِ﴾</span> يعني: جانبًا مِن السماء، فنهلكهم بها{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٣٠٨٣<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿إنْ نَشَأْ نَخْسِفْ بِهِمُ الأَرْضَ أوْ نُسْقِطْ عَلَيْهِمْ كِسَفًا مِنَ السَّماءِ﴾</span> والكِسفُ: القطعة، والكسف مذكر، والقطعة مؤنثة، والمعنى على القطعة{4}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿إِنَّ فِی ذَ ٰ⁠لِكَ لَـَٔایَةࣰ لِّكُلِّ عَبۡدࣲ مُّنِیبࣲ ۝٩﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٣٠٨٤<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿إنَّ فِي ذَلِكَ لَآيَةً لِكُلِّ عَبْدٍ مُنِيبٍ﴾</span>: تائب مقبل على الله{8}. (١٢/١٦٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٣٠٨٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿إنَّ فِي ذَلِكَ لَآيَةً﴾</span> يعني: عِبرة <span class="qpc-hafs">﴿لِكُلِّ عَبْدٍ مُنِيبٍ﴾</span> مخلص بالتوحيد{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٣٠٨٦<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿إنَّ فِي ذَلِكَ لَآيَةً﴾</span> لعبرة <span class="qpc-hafs">﴿لِكُلِّ عَبْدٍ مُنِيبٍ﴾</span> وهو المُقبِل إلى الله بالإخلاص له{4}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه عبد الرزاق ٢/١٢٦، وعبد بن حميد من طريقه -كما في تفسير ابن كثير ٦/٤٨٤- وابن جرير ١٩/٢١٨ من طريق سعيد بلفظ: لينظروا عن أيمانهم، وعن شمائلهم، كيف السماء قد أحاطت بهم. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.|2:علقه يحيى بن سلام ٢/٧٤٧.|3:تفسير مقاتل بن سليمان ٣/٥٢٥.|4:تفسير يحيى بن سلام ٢/٧٤٧.|5:أخرجه ابن جرير ١٩/٢١٨ مختصرًا. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.|6:تفسير مقاتل بن سليمان ٣/٥٢٥.|7:تفسير يحيى بن سلام ٢/٧٤٧.|8:أخرجه عبد الرزاق ٢/١٢٦ من طريق معمر بلفظ: تائب، وابن جرير ١٩/٢١٩ بلفظ: المنيب المقبل التائب. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.|9:تفسير مقاتل بن سليمان ٣/٥٢٥.|10:تفسير يحيى بن سلام ٢/٧٤٧.
  34,10,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَلَقَدۡ ءَاتَیۡنَا دَاوُۥدَ مِنَّا فَضۡلࣰاۖ یَـٰجِبَالُ أَوِّبِی مَعَهُۥ وَٱلطَّیۡرَۖ وَأَلَنَّا لَهُ ٱلۡحَدِیدَ ۝١٠﴾</span> - قراءات</h3></p><p><div></p><p><p><span class="item-no">٦٣٠٨٧<span class="dash">-</span></span> عن <span class="name-2">عبد الله بن أبي إسحاق</span> أنّه قرأ: <span class="qpc-hafs">﴿والطَّيْرَ﴾</span> نصَب بجملة. قال: سخَّرنا له الطير{1}<span class=comment-ref>٥٢٩٢</span>. (١٢/١٦٦)</p></p><p></div></p><p><div><span class=comment-ref>٥٢٩٢</span> <span class="comment-type-4">قال</span> <u>ابن جرير</u> (١٩/٢٢١): «وفي نصب الطير وجهان: <b>أحدهما</b>: على ما قاله ابن زيد مِن أن الطير نُودِيت كما نوديت الجبال، فتكون منصوبة مِن أجل أنها معطوفة على مرفوع بما لا يحسن إعادة رافعه عليه، فيكون كالمصدر عن جهته. <b>والآخر</b>: فعل ضمير متروك استغني بدلالة الكلام عليه، فيكون معنى الكلام: فقلنا: يا جبال، أوبي معه، وسخرنا له الطير. وإن رفع ردًّا على ما في قوله:»سبحي" من ذكر الجبال كان جائزًا، وقد يجوز رفع الطير وهو معطوف على الجبال، وإن لم يحسن نداؤها بالذي نوديت به الجبال، فيكون ذلك كما قال الشاعر:</p><p>ألا يا عمرو والضحاك سيرا ... فقد جاوزتما خمر الطريق".</div></p><p><h3><span class="qpc-hafs">﴿وَلَقَدۡ ءَاتَیۡنَا دَاوُۥدَ مِنَّا فَضۡلࣰاۖ یَـٰجِبَالُ أَوِّبِی مَعَهُۥ وَٱلطَّیۡرَۖ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٣٠٨٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق سعيد بن جبير- في قوله: <span class="qpc-hafs">﴿أوِّبِي مَعَهُ﴾</span>، قال: سبِّحي معه{2}<span class=comment-ref>٥٢٩٣</span>. (١٢/١٦٥)</p></p><p></div></p><p><div><span class=comment-ref>٥٢٩٣</span> قال <u>ابنُ عطية</u> (٧/١٦٠-١٦١) <span class="comment-type-4">معلِّقًا</span> على قول ابن عباس: «<span class="qpc-hafs">﴿وأَوِّبِي﴾</span> معناه: رجِّعي معه؛ لأنه مضاعف آب يؤوب، فقال ابن عباس وقتادة وابن زيد وغيرهم معناه: سبحي معه، أي: يسبح هو وترجع هي معه التسبيح، أي: تردُّ بالذكر، ثم ضوعف الفعل للمبالغة».</div></p><p><div></p><p><p><span class="item-no">٦٣٠٨٩<span class="dash">-</span></span> عن <span class="name-2">أبي ميسرة [عمرو بن شرحبيل]</span> -من طريق أبي إسحاق- <span class="qpc-hafs">﴿أوِّبِي مَعَهُ﴾</span>، قال: سبِّحي معه. بلسان الحبشة{3}<span class=comment-ref>٥٢٩٤</span>. (١٢/١٦٥)</p></p><p></div></p><p><div><span class=comment-ref>٥٢٩٤</span> ذكر <u>ابنُ عطية</u> (٧/١٦١) مثل هذا القول عن مؤرج، و<span class="comment-type-4">علَّق</span> عليه قائلًا: «وهذا ضعيف غير معروف».</p><p>و<span class="comment-type-2">انتقده</span> <u>ابنُ كثير</u> (١١/٢٦٢) <span class="mustanad">مستندًا إلى اللغة</span> بقوله: «وفي هذا نظر؛ فإن التأويب في اللغة هو الترجيع، فأمرت الجبال والطير أن تُرَجِّع معه بأصواتها».</div></p><p><div></p><p><p><span class="item-no">٦٣٠٩٠<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- <span class="qpc-hafs">﴿أوِّبِي مَعَهُ﴾</span>، قال: سبِّحي{4}. (١٢/١٦٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٣٠٩١<span class="dash">-</span></span> عن <span class="name-2">أبي عبد الرحمن [السلمي]</span> -من طريق أبي حصين-= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٣٠٩٢<span class="dash">-</span></span> و<span class="name-2">عكرمة</span>، مثله{5}. (١٢/١٦٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٣٠٩٣<span class="dash">-</span></span> عن <span class="name-2">الضحاك بن مزاحم</span> -من طريق عبيد، وجُوَيْبِر- في قوله: <span class="qpc-hafs">﴿يا جِبالُ أوِّبِي مَعَهُ﴾</span>، قال: سبِّحي{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٣٠٩٤<span class="dash">-</span></span> قال <span class="name-2">وهب بن مُنَبِّه</span>: <span class="qpc-hafs">﴿أوِّبِي مَعَهُ﴾</span> نُوحِي معه{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٣٠٩٥<span class="dash">-</span></span> عن <span class="name-2">وهب بن مُنَبِّه</span> -من طريق ابن إسحاق، عن بعض أهل العلم- قال: <span class="qpc-hafs">﴿يا جِبالُ أوِّبِي مَعَهُ والطَّيْرَ وأَلَنّا لَهُ الحَدِيدَ﴾</span>، أمر الله الجبال والطير أن تسبِّح مع داود إذا سبَّح، وعلَّمه صنعة الحديد وألانه، وأنزل عليه الزبور، فكان إذا قرأ الزبور ترنا{8} له الوحوش حتى يؤخذ بأعناقها، وإنها لمُصِيخة{9} تسمع لصوته{10}. (١٢/١٦٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٣٠٩٦<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- <span class="qpc-hafs">﴿يا جِبالُ أوِّبِي مَعَهُ﴾</span>، قال: سبِّحي مع داود إذا سبّح{11}. (١٢/١٦٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٣٠٩٧<span class="dash">-</span></span> عن <span class="name-2">محمد بن شهاب الزهري</span> -من طريق مالك بن أنس- <span class="qpc-hafs">﴿أوبي معه﴾</span>، قال: سبِّحي معه{12}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٣٠٩٨<span class="dash">-</span></span> عن <span class="name-2">عطاء الخراساني</span> -من طريق يونس بن يزيد- في قوله: <span class="qpc-hafs">﴿يا جبال أوبي معه﴾</span>، قال: سبِّحي معه{13}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٣٠٩٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ولَقَدْ آتَيْنا داوُودَ﴾</span> أعطينا داود <span class="qpc-hafs">﴿مِنّا فَضْلًا﴾</span> النبوة، كقوله ﷿ للنبي ﷺ في سورة النساء [١١٣]: <span class="qpc-hafs">﴿وكانَ فَضْلُ اللَّهِ عَلَيْكَ عَظِيمًا﴾</span> يعني: النبوة والكتاب، فذلك قوله ﷿: <span class="qpc-hafs">﴿ولَقَدْ آتَيْنا داوُودَ مِنّا فَضْلًا﴾</span> النبوة، والزبور، وما سخر له من الجبل والطير والحديد، ثم بيّن له ما أعطاه، فقال ﷿: <span class="qpc-hafs">﴿يا جِبالُ أوِّبِي مَعَهُ﴾</span> سبِّحي معه؛ مع داود ﵇. يقول: اذكري الربَّ مع داود، وهو التسبيح، وسخّرنا له الطير{14}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٣١٠٠<span class="dash">-</span></span> عن <span class="name-3">عبد الملك ابن جريج</span> -من طريق حجاج- <span class="qpc-hafs">﴿ياجبال أوبي معه﴾</span>، يقول: سبِّحي{15}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٣١٠١<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿يا جِبالُ أوِّبِي مَعَهُ والطَّيْرَ﴾</span>، قال: سبِّحي معه، والطير أيضًا، يعني: يسبّح معه الطير{16}. (١٢/١٦٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٣١٠٢<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿ولَقَدْ آتَيْنا داوُد مِنّا فَضْلا﴾</span> النبوة، <span class="qpc-hafs">﴿يا جِبالُ﴾</span> قلنا: يا جبال، <span class="qpc-hafs">﴿أوِّبِي مَعَهُ﴾</span> سبِّحي معه، <span class="qpc-hafs">﴿والطَّيْرَ﴾</span> وهو قوله: <span class="qpc-hafs">﴿وسَخَّرْنا مَعَ داوُدَ الجِبالَ يُسَبِّحْنَ والطَّيْرَ﴾</span> [الأنبياء:٧٩]{17}<span class=comment-ref>٥٢٩٥</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٥٢٩٥</span> ذكر <u>ابنُ عطية</u> (٧/١٦١) إضافة إلى ما ورد في آثار السلف في معنى: <span class="qpc-hafs">﴿أوبي﴾</span> قولًا، و<span class="comment-type-1">وجّهه</span>، فقال: "وقيل: معناه: سيري معه؛ لأن التأويب سير النهار، كأن الإنسان يسير بالليل ثم يرجِّع السير بالنهار، أي: يردده، فكأنه يُؤَوِّبه، فقيل له: التأويب، <span class="mustanad">ومنه قول الشاعر</span>:</p><p>يومان يوم مقامات وأندية ... ويوم سير إلى الأعداء تأويب".</div></p><p><h3><span class="qpc-hafs">﴿وَأَلَنَّا لَهُ ٱلۡحَدِیدَ ۝١٠﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٣١٠٣<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، في قوله: <span class="qpc-hafs">﴿وأَلَنّا لَهُ الحَدِيدَ﴾</span>، قال: كالعجين{18}. (١٢/١٦٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٣١٠٤<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span>، في قوله: <span class="qpc-hafs">﴿وأَلَنّا لَهُ الحَدِيدَ﴾</span>، قال: كان يأخذ الحديدَ، فيصير في يده مثلَ العجين، فيصنع منه الدروع{19}. (١٢/١٦٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٣١٠٥<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- في قوله: <span class="qpc-hafs">﴿وأَلَنّا لَهُ الحَدِيدَ﴾</span>، قال: ليّنه الله له؛ يعمله بغير نار{20}. (١٢/١٦٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٣١٠٦<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد بن بشير- في قوله: <span class="qpc-hafs">﴿وأَلَنّا لَهُ الحَدِيدَ﴾</span>، قال: سخَّر الله له الحديد، فكان يسرده حِلَقًا بيده، يعمل به كما يعمل بالطين، مِن غير أن يُدخله النار، ولا يضربه بمطرقة{21}. (١٢/١٦٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٣١٠٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وأَلَنّا لَهُ الحَدِيدَ﴾</span>، فكان داود ﵇ يضفر الحديد ضفر العجين من غير نار، فيتخذها دروعًا طِوالًا{14}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٣١٠٨<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿وأَلَنّا لَهُ الحَدِيدَ﴾</span> ألانه الله له، فكان يعمله بلا نار ولا مطرقة، بأصابعه الثلاث، كهيئة الطين بيده{17}. (ز)</p></p><p></div></p></div>",footnotes:1:عزاه السيوطي إلى ابن أبي حاتم.</p><p>وهي قراءة العشرة.|2:أخرجه ابن أبي شيبة في المصنف ١١/٥٥٩، وابن جرير ١٩/٢٢٠ من طريق سعيد والعوفي. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.|3:أخرجه ابن جرير ١٩/٢٢٠.|4:تفسير مجاهد (٥٥٣)، وأخرجه يحيى بن سلام ٢/٧٤٧ من طريق أبي يحيى، والفريابي -كما في التغليق ٤/٢٩-، وابن جرير ١٩/٢٢٠-٢٢١ من طريق ابن أبي نجيح ومنصور. وعزاه السيوطي إلى عبد بن حميد.|5:أخرجه ابن أبي شيبة في مصنفه (ت: محمد عوامة) ١٦/٥٦٥ (٣٢٥٦٠)، وابن جرير ١٩/٢٢٠ كلاهما عن أبي عبد الرحمن وحده. وعزاه السيوطي إلى عبد بن حميد.|6:أخرجه ابن جرير ١٩/٢٢١. وزاد ابن حجر في الفتح ٦/٤٥٤ عن الضحاك: «هو بلسان الحبشة»، ولم يعزه.|7:تفسير الثعلبي ٨/٧١، وتفسير البغوي ٦/٣٨٧.|8:قال محققو الدر: كذا في النسخ... وفي مصدر التخريج: «تدنو»، ولعل «ترنا»من الرنو، أي: إدامة النظر. اللسان (رنو).|9:مصيخة: مستمعة منصتة. اللسان (صيخ).|10:أخرجه أبو الشيخ في العظمة (١١٦٦).|11:أخرجه عبد الرزاق ٢/١٢٧، وابن جرير ١٩/٢٢١ من طريق سعيد. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم. وذكر ابن حجر في الفتح ٦/٤٥٤ عن قتادة: معنى <span class="qpc-hafs">﴿أوبي﴾</span>: سيري. ولم يعزه.|12:أخرجه ابن عساكر في تاريخ دمشق ١٧/٩٣.|13:أخرجه أبو جعفر الرملي في جزئه ص٨٩ (تفسير عطاء الخراساني).|14:تفسير مقاتل بن سليمان ٣/٥٢٥-٥٢٦.|15:أخرجه إسحاق البستي ص١٤٥.|16:أخرجه ابن جرير ١٩/٢٢١ بدون لفظ: يعني: يسبح معه الطير. وعزاه السيوطي إلى ابن أبي حاتم.|17:تفسير يحيى بن سلام ٢/٧٤٧.|18:عزاه السيوطي إلى ابن المنذر.|19:عزاه السيوطي إلى ابن أبي حاتم.|20:أخرجه عبد الرزاق ٢/١٢٧. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.|21:أخرجه ابن جرير ١٢/٢٢٢-٢٢٣ بنحوه، كما أخرجه مختصرًا من طريق سعيد بن أبي عروبة. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.|22:تفسير مقاتل بن سليمان ٣/٥٢٥-٥٢٦.|23:تفسير يحيى بن سلام ٢/٧٤٧.
  34,11,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿أَنِ ٱعۡمَلۡ سَـٰبِغَـٰتࣲ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٣١٠٩<span class="dash">-</span></span> عن <span class="name-2">الضحاك بن مزاحم</span> -من طريق جويبر- <span class="qpc-hafs">﴿أن اعمل سابغات﴾</span>، قال: الدرع{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٣١١٠<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿أنِ اعْمَلْ سابِغاتٍ﴾</span>: دروع، وكان داود أوَّل مَن صنعها، وإنما كانت قبل ذلك صفائحَ مِن حديد، يجتنُّون{2} بها مِن عدوهم{3}. (١٢/١٦٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٣١١١<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- في قوله: <span class="qpc-hafs">﴿أنِ اعْمَلْ سابِغاتٍ﴾</span>، قال: دروع سابغات{4}. (١٢/١٦٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٣١١٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿أنِ اعْمَلْ سابِغاتٍ﴾</span> الدروع الطوال، وكانت الدُّروع قبل داود إنّما هي صفائح الحديد مضروبة، فكان داود ﵇ يَشُدُّ الدروعَ بمسامير، ما يقرعها بحديد، ولا يدخلها النار، فيقرع مِن الدروع في بعض النهار وبعض الليل بيده ثمنَ ألف درهم{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٣١١٣<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿أنِ اعْمَلْ سابِغاتٍ﴾</span>، قال: السابغات: دروع الحديد{6}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَقَدِّرۡ فِی ٱلسَّرۡدِۖ وَٱعۡمَلُوا۟ صَـٰلِحًاۖ إِنِّی بِمَا تَعۡمَلُونَ بَصِیرࣱ ۝١١﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٣١١٤<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق مجاهد- في قوله: <span class="qpc-hafs">﴿وقَدِّرْ فِي السَّرْدِ﴾</span>، قال: لا تُدِقّ المسامير وتوسِّع الحِلق فتسْلس{7}، ولا تغلِّظ المسامير وتُضيِّق الحِلق فتنقصم، واجعله قدرًا{8}. (١٢/١٦٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٣١١٥<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- في قوله: <span class="qpc-hafs">﴿وقَدِّرْ فِي السَّرْدِ﴾</span>، قال: حِلَق الحديد{9}. (١٢/١٦٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٣١١٦<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطية العوفي-: <span class="qpc-hafs">﴿وقَدِّرْ فِي السَّرْدِ﴾</span> يعني بالسرد: ثقْب الدروع حين يشُدُّ قَتيرَها{10}، وعنى بقوله: <span class="qpc-hafs">﴿وقَدِّرْ فِي السَّرْدِ﴾</span>: قدِّر المسامير{11}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٣١١٧<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- <span class="qpc-hafs">﴿وقَدِّرْ فِي السَّرْدِ﴾</span>، قال: قدِّر المسامير والحِلق؛ لا تُدق المسمار فتسْلَس، ولا تُجلّها فتُقْصَم{12}. (١٢/١٦٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٣١١٨<span class="dash">-</span></span> عن <span class="name-2">الحكم [بن عتيبة]</span> -من طريق عيينة- <span class="qpc-hafs">﴿وقَدِّرْ فِي السَّرْدِ﴾</span>، قال: لا تغلِّظ المسمار فيفصم الحلقة، ولا تدقّه فيقلق{13}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٣١١٩<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- في قوله: <span class="qpc-hafs">﴿وقَدِّرْ فِي السَّرْدِ﴾</span>، قال: السرد: هي المسامير التي في حِلق الدرع{14}. (١٢/١٦٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٣١٢٠<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿وقَدِّرْ فِي السَّرْدِ﴾</span>، قال: كان يجعلها بغير نار، ولا يقرعها بحديد، ثم يسردها. والسرد: المسامير التي في الحِلق{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٣١٢١<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق خالد بن قيس- <span class="qpc-hafs">﴿وقَدِّرْ فِي السَّرْدِ﴾</span>، قال: كانت صفائح، فأمر أن يَسْرُدَها حِلَقًا{16}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٣١٢٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وقَدِّرْ فِي السَّرْدِ﴾</span> يقول: قدِّر المسامير في الحِلَق، ولا تعظم المسامير فتنقصم، ولا تضفر{17} المسامير فتسلس، <span class="qpc-hafs">﴿واعْمَلُوا صالِحًا﴾</span> يعني: قولوا: الحمد لله، <span class="qpc-hafs">﴿إنِّي بِما تَعْمَلُونَ بَصِيرٌ﴾</span>{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٣١٢٣<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿وقَدِّرْ فِي السَّرْدِ﴾</span>، قال: السرد: حلقة، أي: قدِّر تلك الحِلَق. قال: وقال الشاعر:</p><p>أجاد المُسدِّي سَرْدَها وأذالها</p><p>قال: يقول: وسَّعها، وأجاد حلَقها{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٣١٢٤<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿أنِ اعْمَلْ سابِغاتٍ﴾</span> وهي الدروع. وبلغنا: أنّ لقمان حضر داود عند أول درع عملها، فجعل يتفكَّر فيما يريد بها، ولا يدري ما يريد بها، فلم يسأله حتى إذا فرغ منها داود قام فلبسها، فقال لقمان: الصمت حكمة، وقليلٌ فاعِلُه{20}<span class=comment-ref>٥٢٩٦</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٥٢٩٦</span> اختلف السلف في تفسير قوله: <span class="qpc-hafs">﴿وقدر في السرد﴾</span> على أقوال: <b>الأول</b>: أن السرد: هو مسمار حلق الدرع. <b>الثاني</b>: أنه الحلق بعينها.</p><p>وقد <span class="comment-type-3">رجَّح</span> <u>ابنُ جرير</u> (١٩/٢٢٤-٢٢٦) القول الأول <span class="mustanad">مستندًا إلى أقوال السلف</span>، فقال: «وعنى بقوله: <span class="qpc-hafs">﴿وقدر في السرد﴾</span>» وقدر المسامير في حلق الدروع حتى يكون بمقدار؛ لا تغلظ المسمار وتضيق الحلقة فتفصم الحلقة، ولا توسع الحلقة وتصغر المسامير وتدقها فتسلس في الحلقة. وبنحو الذي قلنا في ذلك قال أهل التأويل".</div></p><p><h3><span class="qpc-hafs">﴿وَقَدِّرۡ فِی ٱلسَّرۡدِۖ وَٱعۡمَلُوا۟ صَـٰلِحًاۖ إِنِّی بِمَا تَعۡمَلُونَ بَصِیرࣱ ۝١١﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٦٣١٢٥<span class="dash">-</span></span> عن ابن شوذب، قال: كان داود يرفع في كل يوم دِرْعًا، فيبيعها بستة آلاف درهم، ألفين له ولأهله، وأربعة آلاف يُطعم بها بني إسرائيل الخبز الحُوّاري{21}{22}. (١٢/١٦٨)</p></p><p></div></p></div>",footnotes:1:أخرجه الحربي في غريب الحديث ٢/٤٠٧.|2:يجتنون: يتحصنون. اللسان (جنن).|3:أخرجه ابن جرير ١٢/٢٢٣ بنحوه. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.|4:أخرجه عبد الرزاق ٢/١٢٧. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.|5:تفسير مقاتل بن سليمان ٣/٥٢٦.|6:أخرجه ابن جرير ١٩/٢٢٣.|7:تسلس: كل شيء قلق فهو سلس. اللسان (سلس). والمعنى: فتقلق المسامير وتتحرك.|8:أخرجه عبد الرزاق ٢/١٢٧، والحاكم ٢/٤٢٣.|9:أخرجه ابن جرير ١٩/٢٢٤. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.|10:القَتِير: رؤوس مسامِير حلَق الدروع. اللسان (قتر).|11:أخرجه ابن جرير ١٩/٢٢٥.|12:تفسير مجاهد (٥٥٣)، وأخرجه ابن جرير ١٩/٢٢٥. وعلَّقه يحيى بن سلام ٢/٧٤٨. وعزاه السيوطي إلى الفريابي -ينظر: التغليق ٤/٢٩-، وعبد بن حميد. وذكر ابن جرير روايتين في كلمة (تقصم) بالفاء والقاف. وأخرج عن مجاهد ١٩/٢٢٦ من طريق ابن جريج بلفظ: لا تصغر المسمار، وتعظم الحلقة فتسلس، ولا تعظم المسمار وتصغر الحلقة فيفصم المسمار.|13:أخرجه ابن جرير ١٩/٢٢٦.|14:أخرجه عبد الرزاق ٢/١٢٧. وعزاه السيوطي إلى عبد بن حميد، وابن أبي حاتم.|15:أخرجه ابن جرير ١٩/٢٢٣.|16:أخرجه ابن جرير ١٩/٢٢٤.|17:كذا في مطبوعة المصدر.|18:تفسير مقاتل بن سليمان ٣/٥٢٦.|19:أخرجه ابن جرير ١٩/٢٢٣.|20:تفسير يحيى بن سلام ٢/٧٤٨.|21:الحُوّاري: الدقيق الأبيض، وهو لباب الدقيق وأجوده. اللسان (حور).|22:أخرجه الحكيم الترمذي في نوادر الأصول ١/٣٧٤، وابن أبي حاتم -كما في تفسير ابن كثير ٦/٤٨٥-.
  34,12,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَلِسُلَیۡمَـٰنَ ٱلرِّیحَ غُدُوُّهَا شَهۡرࣱ وَرَوَاحُهَا شَهۡرࣱۖ﴾</span> - قراءات</h3></p><p><div></p><p><p><span class="item-no">٦٣١٢٦<span class="dash">-</span></span> عن <span class="name-2">عاصم</span> أنّه قرأ: ‹ولِسُلَيْمانَ الرِّيحُ› برفع الحاء{1}<span class=comment-ref>٥٢٩٧</span>. (١٢/١٦٩)</p></p><p></div></p><p><div><span class=comment-ref>٥٢٩٧</span> ذكر <u>ابنُ جرير</u> (١٩/٢٢٦) هذه القراءة وقراءة النصب في <span class="qpc-hafs">﴿الريح﴾</span>، و<span class="comment-type-3">رجّحها</span> <span class="mustanad">مستندًا إلى إجماع الحجة من القراء</span>.</p><p>و<span class="comment-type-4">علّق</span> <u>ابنُ عطية</u> (٧/١٦٤) على هذه القراءة، فقال: «وقرأ عاصم في رواية أبي بكر والأعرج <span class="qpc-hafs">﴿الريحُ﴾</span> بالرفع على تقدير: تسخرت الريح، أو على الابتداء، والخبر في المجرور، وذلك على حذف مضاف تقديره: ولسليمان تسخير الريح».</div></p><p><h3><span class="qpc-hafs">﴿وَلِسُلَیۡمَـٰنَ ٱلرِّیحَ غُدُوُّهَا شَهۡرࣱ وَرَوَاحُهَا شَهۡرࣱۖ﴾</span> - تفسير الآية</h3></p><p><div></p><p><p><span class="item-no">٦٣١٢٧<span class="dash">-</span></span> عن <span class="name-2">سعيد بن المسيب</span>، قال: <span class="qpc-hafs">﴿ولِسُلَيْمانَ الرِّيحَ غُدُوُّها شَهْرٌ ورَواحُها شَهْرٌ﴾</span> كان سليمان ﵇ يركب الريح من إصطخر{2}، فيتَغَدّى ببيت المقدس، ثم يعود فيتعشى بإصطخر{3}. (١٢/١٧٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٣١٢٨<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span>، قال: <span class="qpc-hafs">﴿ولِسُلَيْمانَ الرِّيحَ غُدُوُّها شَهْرٌ ورَواحُها شَهْرٌ﴾</span> الريح مسيرها شهران في يوم{4}. (١٢/١٦٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٣١٢٩<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span>، قال: <span class="qpc-hafs">﴿ولِسُلَيْمانَ الرِّيحَ غُدُوُّها شَهْرٌ ورَواحُها شَهْرٌ﴾</span> إنّ سليمان ﵇ لَمّا شغلته الخيل حتى فاتته صلاة العصر؛ غضب لله، فعقر الخيل، فأبدله الله مكانها خيرًا منها وأسرع؛ الريح تجري بأمره كيف شاء، فكان غدوّها شهرًا ورواحها شهرًا، وكان يغدو من إيلياء فيقيل بقُرَير{5}، ويروح من قرير فيبيت بكابل{6}. (١٢/١٦٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٣١٣٠<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span>، في قوله: <span class="qpc-hafs">﴿غُدُوُّها شَهْرٌ ورَواحُها شَهْرٌ﴾</span>، قال: كان سليمان يغدو من بيت المقدس فيقيل بإصطخر، ثم يروح من إصطخر فيبيت بقلعة خراسان{7}. (١٢/١٧٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٣١٣١<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق عمرو بن عبيد- قال: <span class="qpc-hafs">﴿غُدُوُّها شَهْرٌ ورَواحُها شَهْرٌ﴾</span> كان سليمان إذا أراد أن يركب جاءت الريحُ، فوضع سرير مملكته عليها، ووُضعت الكراسي والمجالس على الريح، وجلس على سريره، وجلس وُجُوهُ أصحابِه على منازلهم في الدِّين عنده من الجن والإنس، والجن يومئذ ظاهرة للإنس، رجال أمثال الإنس إلا إنهم أُدْم، يحجُّون جميعًا، ويصلُّون جميعًا، ويعتمرون جميعًا، والطير ترفرف على رأسه ورؤوسهم، والشياطين حرَسه لا يتركون أحدًا يتقدم بين يديه، وهو قوله: <span class="qpc-hafs">﴿وحُشِرَ لِسُلَيْمانَ جُنُودُهُ مِنَ الجِنِّ والإنْسِ والطَّيْرِ فَهُمْ يُوزَعُونَ﴾</span> [النمل:١٧] فهم يدفعون؛ ألّا يتقدمه منهم أحد{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٣١٣٢<span class="dash">-</span></span> عن <span class="name-2">وهب بن منبه</span> -من طريق محمد بن إسحاق، عن بعض أهل العلم- قال: ورِث سليمانُ المُلكَ، وأحدث اللهُ إليه النبوةَ، وسأله أن يهَبَ له ملكًا لا ينبغي لأحد من بعده، ففعل -تبارك وتعالى-، فسخَّر له الإنس والجن والطير والريح، فكان إذا خرج من بيته إلى مجلسه -وكان فيما يزعمون أبيض، وسيمًا، وضيئًا، كثير الشعر، يلبس البياض من الثياب- عكفت عليه الطير، وقام عليه الإنس والجن حتى يجلس على سريره، وكان امرأً غزّاءً قَلَّ ما يقعد عن الغزو، ولا يسمع بملِكٍ في ناحية من الأرض إلا أتاه حتى يُذِلَّه، كان فيما يزعمون إذا أراد الغزوَ أمَر بعسكره فضُرب له من خشب، ثم نصب على الخشب، ثم حمل عليه الناس والدواب وآلة الحرب كلها، حتى إذا حمل معه ما يريد أمر العاصف من الريح، فدخلت تحت ذلك الخشب، فاحتملته حتى إذا [استقلت] به أمرت الرخاء، فقذفت به شهرًا في روحته، وشهرًا في غدوته إلى حيث أراد الله. يقول الله ﷿: <span class="qpc-hafs">﴿فَسَخَّرْنا لَهُ الرِّيحَ تَجْرِي بِأَمْرِهِ رُخاءً حَيْثُ أصابَ﴾</span> [ص:٣٦]، أي: حيث أراد. قال: <span class="qpc-hafs">﴿ولسليمان الريح غدوها شهر ورواحها شهر﴾</span>، قال: ذُكر لي: أنّ منزلًا بناحية دجلة مكتوب فيه كتاب كتبه بعض صحابة سليمان؛ إما من الجن، وإما من الإنس: نحن نزلناه وما بنيناه، ومبنِيًّا وجدناه، غدونا من إصطخر فقلناه، ونحن رائحون منه -إن شاء الله- فبائتون بالشام{9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٣١٣٣<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿ولِسُلَيْمانَ الرِّيحَ غُدُوُّها شَهْرٌ ورَواحُها شَهْرٌ﴾</span>، قال: تغدو مسيرة شهر، وتروح مسيرة شهرين في يوم{10}. (١٢/١٦٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٣١٣٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثم ذكر ابنه سليمان ﵉، وما أعطاه الله ﷿ من الخير والكرامة، فقال ﷿: <span class="qpc-hafs">﴿ولِسُلَيْمانَ الرِّيحَ غُدُوُّها شَهْرٌ﴾</span> يعني: مسيرة شهر، فتحملهم الريح من بيت المقدس إلى إصطخر، وتروح بهم، <span class="qpc-hafs">﴿ورَواحُها شَهْرٌ﴾</span> يعني: مسيرة، فتحملهم إلى بيت المقدس، لا تحوِّل طيرًا مِن فوقهم، ولا ورقة من تحتهم، ولا تثير ترابًا{11}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٣١٣٥<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿ولِسُلَيْمانَ الرِّيحَ غُدُوُّها شَهْرٌ ورَواحُها شَهْرٌ﴾</span>، قال: كان له مَرْكَب مِن خشب، وكان فيه ألف ركن، في كل ركن ألف بيت تركب فيه الجن والإنس، تحت كل ركن ألف شيطان، يرفعون ذلك المركب هم والعِصار؛ فإذا ارتفع أتت الريح رخاءً فسارت به، وساروا معه، يقيل عند قوم بينه وبينهم شهر، ويمسي عند قوم بينه وبينهم شهر، ولا يدري القوم إلا وقد أظلَّهم معه الجيوش والجنود، والعصار: الريح العاصفة{12}<span class=comment-ref>٥٢٩٨</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٥٢٩٨</span> ذكر <u>ابنُ عطية</u> (٧/١٦٥) نحو ما جاء في قول ابن زيد، و<span class="comment-type-4">علّق</span> عليه، فقال: «وكانت الأعصار تُقِلُّ بساطَه وتحمله بعد ذلك الرخاء، وكان هذا البساط يحمل -فيما روي- أربعة آلاف فارس، وما يشبهها من الرجال والعُدد، ويتسع لهم، وروي أكثر من هذا بكثير، ولكن عدم صحته مع بُعد شبهه أوجب اختصاره».</div></p><p><div></p><p><p><span class="item-no">٦٣١٣٦<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿ولِسُلَيْمانَ الرِّيحَ﴾</span>، أي: وسخرنا لسليمان الريح{13}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَأَسَلۡنَا لَهُۥ عَیۡنَ ٱلۡقِطۡرِۖ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٣١٣٧<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق ابن جريج- قال: <span class="qpc-hafs">﴿وأَسَلْنا لَهُ عَيْنَ القِطْرِ﴾</span>، القِطر: النحاس. لم يقدر عليها أحد بعد سليمان، وإنّما يعمل الناس بعدُ فيما كان أُعطي سليمان{14}. (١٢/١٧١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٣١٣٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طُرُق- في قوله: <span class="qpc-hafs">﴿وأَسَلْنا لَهُ عَيْنَ القِطْرِ﴾</span>، قال: النحاس{15}. (١٢/١٧٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٣١٣٩<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>: أنّ نافع بن الأزرق قال له: أخبِرني عن قوله: <span class="qpc-hafs">﴿وأَسَلْنا لَهُ عَيْنَ القِطْرِ﴾</span>. قال: أعطاه الله عينًا مِن صُفر{16}، تسيل كما يسيل الماء. قال: وهل تعرف العرب ذلك؟ قال: نعم، أما سمعت قول الشاعر وهو يقول:</p><p>فألقى في مَراجِلَ{17} من حديدٍ قُدور القِطر ليس من البِرام{18}{19}. (١٢/١٧٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٣١٤٠<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق أبي يحيى- <span class="qpc-hafs">﴿عَيْنَ القِطْرِ﴾</span>، قال: الصُفر، سالت له مثل الماء{20}. (١٢/١٧١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٣١٤١<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span>، في قوله: <span class="qpc-hafs">﴿وأَسَلْنا لَهُ عَيْنَ القِطْرِ﴾</span>، قال: أسال الله له القِطر ثلاثةَ أيام من صنعاء، يسيل كما يسيل الماء. قيل: إلى أين؟ قال: لا أدري{14}. (١٢/١٧١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٣١٤٢<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق أبي سهل- قال: كان الله -تبارك وتعالى- سخَّر لسليمان الريح <span class="qpc-hafs">﴿غدوها شهر ورواحها شهر﴾</span>، وقال الله ﷿: <span class="qpc-hafs">﴿وأسلنا له عين القطر﴾</span> يعني: النحاس، فجرى له{22}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٣١٤٣<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿وأَسَلْنا لَهُ عَيْنَ القِطْرِ﴾</span>، قال: عين النحاس، كانت باليمن، وإنما يصنع الناسُ اليومَ مِمّا أخرج الله لسليمان{23}<span class=comment-ref>٥٢٩٩</span>. (١٢/١٧١)</p></p><p></div></p><p><div><span class=comment-ref>٥٢٩٩</span> ذكر <u>ابنُ عطية</u> (٤/٤٠٩) قول قتادة وقول ابن عباس، ثم <span class="comment-type-4">قال</span>: «و<b>قالت فرقة</b>: القطر: الفلز كله؛ النحاس، والحديد، وما جرى مجراه، كان يسيل له منه عيون. <b>وقالت فرقة</b>: بل معنى <span class="qpc-hafs">﴿وأسلنا له عين القطر﴾</span>: أذبنا له النحاس عن نحوِ ما كان الحديد يلين لداود، قالوا: وكانت الأعمال تتأتى منه لسليمان وهو بارد دون نار. وعين على هذا التأويل بمعنى: المذاب».</div></p><p><div></p><p><p><span class="item-no">٦٣١٤٤<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span>، قال: <span class="qpc-hafs">﴿وأَسَلْنا لَهُ عَيْنَ القِطْرِ﴾</span> سُيِّلَت له عين مِن نحاس ثلاثة أيام{24}. (١٢/١٧١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٣١٤٥<span class="dash">-</span></span> عن <span class="name-2">عطاء الخراساني</span> -من طريق يونس بن يزيد- في قوله: <span class="qpc-hafs">﴿عين القطر﴾</span>، قال: عين الصفر{25}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٣١٤٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وأَسَلْنا لَهُ عَيْنَ القِطْرِ﴾</span>، يعني: أخرجنا لسليمان عين الصُفر ثلاثة أيام، تجري مجرى الماء بأرض اليمن{26}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٣١٤٧<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿وأَسَلْنا لَهُ عَيْنَ القِطْرِ﴾</span>، قال: الصُفر سال كما يسيل الماء، يُعمَل به كما كان يُعمل العجين في اللين{27}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَمِنَ ٱلۡجِنِّ مَن یَعۡمَلُ بَیۡنَ یَدَیۡهِ بِإِذۡنِ رَبِّهِۦۖ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٣١٤٨<span class="dash">-</span></span> قال <span class="name-1">عبد الله بن عباس</span>: <span class="qpc-hafs">﴿ومِنَ الجِنِّ مَن يَعْمَلُ بَيْنَ يَدَيْهِ﴾</span> سخَّر الله الجنَّ لسليمان، وأمرهم بطاعته فيما يأمرهم به{28}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٣١٤٩<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن جريج- قال: <span class="qpc-hafs">﴿ومِنَ الجِنِّ مَن يَعْمَلُ بَيْنَ يَدَيْهِ﴾</span>، أي: له{29}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٣١٥٠<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span>، قال: ليس كل الجن سُخِّر له كما تسمعون: <span class="qpc-hafs">﴿ومِنَ الجِنِّ مَن يَعْمَلُ بَيْنَ يَدَيْهِ﴾</span>{30}. (١٢/١٧١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٣١٥١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ومِنَ الجِنِّ مَن يَعْمَلُ﴾</span> وسخرنا لسليمان مِن الجن من يعمل <span class="qpc-hafs">﴿بين يديه﴾</span> بين يدي سليمان، <span class="qpc-hafs">﴿بِإذْنِ رَبِّهِ﴾</span> يعني: رب سليمان ﷿{26}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٣١٥٢<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿بِإذْنِ رَبِّهِ﴾</span> بالسخرة التي سخَّرها الله له{32}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَمَن یَزِغۡ مِنۡهُمۡ عَنۡ أَمۡرِنَا نُذِقۡهُ مِنۡ عَذَابِ ٱلسَّعِیرِ ۝١٢﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٣١٥٣<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن جريج- <span class="qpc-hafs">﴿ومَن يَزِغْ مِنهُمْ عَنْ أمْرِنا﴾</span>، قال: مِن الجن{33}. (١٢/١٧٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٣١٥٤<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- قال: <span class="qpc-hafs">﴿ومَن يَزِغْ مِنهُمْ عَنْ أمْرِنا﴾</span>، قال: يعدل عن أمرنا، عما أمره به سليمان{34}<span class=comment-ref>٥٣٠٠</span>. (١٢/١٧٢)</p></p><p></div></p><p><div><span class=comment-ref>٥٣٠٠</span> لم يذكر <u>ابنُ جرير</u> (١٩/٢٢٩) غير قول قتادة.</div></p><p><div></p><p><p><span class="item-no">٦٣١٥٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ومَن يَزِغْ مِنهُمْ﴾</span> ومَن يعدل منهم <span class="qpc-hafs">﴿عَنْ أمْرِنا﴾</span> عن أمر سليمان ﵇؛ <span class="qpc-hafs">﴿نُذِقْهُ مِن عَذابِ السَّعِيرِ﴾</span> الوقود في الدنيا. كان ملَكٌ بيده سوط مِن نار، مَن يزِغ عن أمر سليمان ضربه بسوط من نار، فذلك عذاب السعير{26}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٣١٥٦<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿ومَن يَزِغْ مِنهُمْ عَنْ أمْرِنا﴾</span> عن طاعة الله وعن عبادته؛ <span class="qpc-hafs">﴿نُذِقْهُ مِن عَذابِ السَّعِيرِ﴾</span> في الآخرة، ولم يكن يتسخَّر منهم، ويُستعمل في هذه الأشياء، ولا يُصفّد في الأصفاد، أي: ولا يُسلسل في السلاسل منهم، إلا الكافر، فإذا تابوا فآمنوا حلَّهم مِن تلك الأصفاد. وقال بعضهم: <span class="qpc-hafs">﴿نذقه من عذاب السعير﴾</span> جعل معه ملك بيده سوط من عذاب السعير، فإذا خالف سليمانَ أحدٌ منهم ضربه الملَكُ بذلك السوط{32}. (ز)</p></p><p></div></p></div>",footnotes:1:عزاه السيوطي إلى عبد بن حميد.</p><p>وهي قراءة متواترة، قرأ بها شعبة عن عاصم، وقرأ بقية العشرة: <span class="qpc-hafs">﴿الرِّيحَ﴾</span> بالنصب. انظر: النشر ٢/٣٤٩، والإتحاف ص٤٥٨.|2:إصطخر: بلدة بفارس. معجم البلدان ١/٢٩٩.|3:عزاه السيوطي إلى الخطيب في رواة مالك.|4:عزاه السيوطي إلى عبد بن حميد.|5:قُرير: بلدة بين نصيبين والرقة. معجم البلدان ٤/٧٨.|6:عزاه السيوطي إلى ابن أبي شيبة، وعبد بن حميد، وابن المنذر، وابن أبي حاتم. وأخرج آخره يحيى بن سلام ٢/٧٤٨ بنحوه من طريق أبي أمية وقرة بن خالد، وبنحوه ابن جرير ١٩/٢٢٨ من طريق قرة بن خالد. وعبد الرزاق ٢/١٢٧ من طريق معمر، وعندهم: إصطخر، بدل: قرير. وعند عبد الرزاق: دمشق، بدل: إيلياء، وزاد: وما بين إصطخر ودمشق مسيرة شهر للمسرع، ومن إصطخر إلى كابل مسيرة شهر للمسرع. وبنحوه أخرجه بحشل في تاريخ واسط ص١٠١، وابن عساكر في تاريخ دمشق ٢٢/٢٣١.|7:عزاه السيوطي إلى أحمد في الزهد.|8:علَّقه يحيى بن سلام ٢/٧٤٨-٧٤٩.|9:أخرجه ابن أبي حاتم ٩/٢٨٥٦، كما أخرج ابن جرير ١٩/٢٢٧ آخره.|10:أخرجه ابن جرير ١٩/٢٢٧ بنحوه. وعزاه السيوطي إلى عبد بن حميد.|11:تفسير مقاتل بن سليمان ٣/٥٢٦.|12:أخرجه ابن جرير ١٩/٢٢٧.|13:تفسير يحيى بن سلام ٢/٧٤٨.|14:عزاه السيوطي إلى ابن المنذر.|15:أخرجه ابن جرير ١٩/٢٢٩ من طريق علي، ومن طريق العوفي بلفظ: عين النحاس أُسيلت. وعزاه السيوطي إلى ابن أبي شيبة، وعبد بن حميد، وابن المنذر، وابن أبي حاتم -ينظر: التغليق ٤/١١-.|16:صُفر: النحاس الجيد. اللسان (صفر).|17:مراجِل: جمع مِرْجل: وهو الإناءُ الذي يُغْلى فيه الماءُ. النهاية (مرجل).|18:البرام: القِدر من الحجارة. اللسان (برم).|19:عزاه السيوطي إلى الطستي -ينظر: الإتقان ٢/٩٩-.|20:أخرجه يحيى بن سلام ٢/٧٤٩. وعزاه السيوطي إلى عبد بن حميد مختصرًا.|21:عزاه السيوطي إلى ابن المنذر.|22:أخرجه ابن عساكر في تاريخ دمشق ٢٢/٢٣١.|23:أخرجه ابن جرير ١٩/٢٢٨، وأخرجه عبد الرزاق ٢/١٢٧ مختصرًا من طريق معمر. وعزاه السيوطي إلى عبد بن حميد، وابن أبي حاتم.|24:عزاه السيوطي إلى ابن أبي حاتم.|25:أخرجه أبو جعفر الرملي في جزئه ص٨٩ (تفسير عطاء الخراساني).|26:تفسير مقاتل بن سليمان ٣/٥٢٧.|27:أخرجه ابن جرير ١٩/٢٢٩.|28:تفسير البغوي ٦/٣٨٩.|29:أخرجه يحيى بن سلام ٢/٧٤٩ من طريق ابن مجاهد، وإسحاق البستي ص١٤٧.|30:عزاه السيوطي إلى عبد بن حميد، وابن جرير، وابن أبي حاتم.|31:تفسير مقاتل بن سليمان ٣/٥٢٧.|32:تفسير يحيى بن سلام ٢/٧٤٩.|33:أخرجه إسحاق البستي ص١٤٨. وعزاه السيوطي إلى عبد بن حميد، وابن أبي حاتم.|34:أخرجه ابن جرير ١٩/٢٢٩. وعزاه السيوطي إلى عبد بن حميد، وابن أبي حاتم.|35:تفسير مقاتل بن سليمان ٣/٥٢٧.|36:تفسير يحيى بن سلام ٢/٧٤٩.
  34,13,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿یَعۡمَلُونَ لَهُۥ مَا یَشَاۤءُ مِن مَّحَـٰرِیبَ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٣١٥٧<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿مِن مَحارِيبَ﴾</span>، قال: بنيان دون القصور{1}. (١٢/١٧٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٣١٥٨<span class="dash">-</span></span> عن <span class="name-2">الضحاك بن مزاحم</span> -من طريق جويبر- في قوله: <span class="qpc-hafs">﴿مِن مَحارِيبَ﴾</span>، قال: المساجد{2}. (١٢/١٧٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٣١٥٩<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span>: <span class="qpc-hafs">﴿يَعْمَلُونَ لَهُ ما يَشاءُ مِن مَحارِيبَ﴾</span>، المحاريب: المساجد{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٣١٦٠<span class="dash">-</span></span> عن <span class="name-2">عطية بن سعد العوفي</span>، قال: <span class="qpc-hafs">﴿يَعْمَلُونَ لَهُ ما يَشاءُ مِن مَحارِيبَ﴾</span> المحاريب: القصور{4}. (١٢/١٧٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٣١٦١<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿مِن مَحارِيبَ﴾</span>، قال: قصور ومساجد{5}. (١٢/١٧٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٣١٦٢<span class="dash">-</span></span> عن <span class="name-3">محمد بن السائب الكلبي</span>: <span class="qpc-hafs">﴿مِن مَحارِيبَ﴾</span> المساجد والقصور{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٣١٦٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿يَعْمَلُونَ لَهُ ما يَشاءُ﴾</span> يعني: الجن لسليمان <span class="qpc-hafs">﴿مِن مَحارِيبَ﴾</span> المساجد{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٣١٦٤<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿يَعْمَلُونَ لَهُ ما يَشاءُ مِن مَحارِيبَ﴾</span>، قال: المحاريب: المساكن. وقرأ قول الله ﷿: <span class="qpc-hafs">﴿فَنادَتْهُ المَلائِكَةُ وهُوَ قائِمٌ يُصَلِّي فِي المِحْرابِ﴾</span> [آل عمران:٣٩]{8}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَتَمَـٰثِیلَ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٣١٦٥<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> –من طريق السدي عن أبي مالك-، في قوله: <span class="qpc-hafs">﴿وتَماثِيلَ﴾</span> قال: اتخذ سليمانُ تماثيل مِن نحاس، فقال: يا رب، انفخ فيها الروح؛ فإنها أقوى على الخدمة. فنفخ الله فيها الروح، فكانت تخدمه، وكان إسفنديار من بقاياهم، فقيل لداود وسليمان: <span class="qpc-hafs">﴿اعْمَلُوا آلَ داوُودَ شُكْرًا وقَلِيلٌ مِن عِبادِيَ الشَّكُورُ﴾</span>{9}. (١٢/١٧٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٣١٦٦<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿وتَماثِيلَ﴾</span>، قال: من نحاس{10}. (١٢/١٧٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٣١٦٧<span class="dash">-</span></span> عن <span class="name-2">الضحاك بن مزاحم</span> -من طريق جويبر- في قوله: <span class="qpc-hafs">﴿وتَماثِيلَ﴾</span>، قال: الصور{2}. (١٢/١٧٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٣١٦٨<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span>: <span class="qpc-hafs">﴿وتَماثِيلَ﴾</span>: الصور. وقال: ولم تكن يومئذ محرمة{3}<span class=comment-ref>٥٣٠١</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٥٣٠١</span> ذكر <u>ابنُ عطية</u> (٧/١٦٦) نحو قول الحسن والضحاك، و<span class="comment-type-4">علّق</span> عليه بقوله: «وقال الضحاك: كانت تماثيل حيوان، وكان هذا من الجائز في ذلك الشرع، ونسخ بشرع محمد ﷺ. و<b>قال قوم</b>: حرم التصوير؛ لأن الصور كانت تُعبد. وحكى مكي في الهداية: أنّ فرقة تجوِّز التصوير وتحتج بهذه الآية. وذلك خطأ، وما أحفظ من أئمة العلم مَن يُجَوِّزه».</div></p><p><div></p><p><p><span class="item-no">٦٣١٦٩<span class="dash">-</span></span> عن <span class="name-2">عطية بن سعد العوفي</span>، قال: <span class="qpc-hafs">﴿وتَماثِيلَ﴾</span> والتماثيل: الصور{4}. (١٢/١٧٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٣١٧٠<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span>، في قوله: <span class="qpc-hafs">﴿وتَماثِيلَ﴾</span>، قال: من رُخام وشَبَهٍ{14}. (١٢/١٧٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٣١٧١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وتَماثِيلَ﴾</span> مِن نحاس ورخام، من الأرض المقدسة وإصطخر، مِن غير أن يعبدها أحد{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٣١٧٢<span class="dash">-</span></span> عن <span class="name-3">عبد الملك ابن جريج</span>، في قوله: <span class="qpc-hafs">﴿يَعْمَلُونَ لَهُ ما يَشاءُ مِن مَحارِيبَ وتَماثِيلَ﴾</span>، قال: مِن شَبَهٍ ورخام{16}. (١٢/١٧٢)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَجِفَانࣲ كَٱلۡجَوَابِ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٣١٧٣<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- في قوله: ‹وجِفانٍ كالجَوابِي›، قال: كالجوْبة{17} من الأرض منها{18}. (١٢/١٧٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٣١٧٤<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق العوفي- قوله: <span class="qpc-hafs">﴿وجِفانٍ كالجَوابِ﴾</span>: يعني بالجواب: الحياض{19}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٣١٧٥<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، أن نافع بن الأزرق قال له: أخبرني عن قوله: ‹وجِفانٍ كالجَوابِي›. قال: كالحياض الواسعة، تسع الجفنة الجزور. قال: وهل تعرف العربُ ذلك؟ قال: نعم، أما سمعت طرفة بن العبد وهو يقول:</p><p>كالجوابي لا تَني مُتْرَعة لِقِرى الأضياف أو للمُحْتَضر{20}.</p><p>وقال أيضًا:</p><p>يجبر المحروب{21} فينا ماله بقبابٍ وجفانٍ وخَدم{22}. (١٢/١٧٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٣١٧٦<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- قوله: <span class="qpc-hafs">﴿وجِفانٍ كالجَوابِ﴾</span>، قال: حياض الإبل{23}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٣١٧٧<span class="dash">-</span></span> قال <span class="name-2">مجاهد بن جبر</span>: <span class="qpc-hafs">﴿وجِفانٍ﴾</span> وصحاف{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٣١٧٨<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح-: <span class="qpc-hafs">﴿وجِفانٍ﴾</span> صحاف، ‹كالجَوابِي› الجفنة مثل الجوْبة من الأرض{25}<span class=comment-ref>٥٣٠٢</span>. (١٢/١٧٢)</p></p><p></div></p><p><div><span class=comment-ref>٥٣٠٢</span> ذكر <u>ابنُ عطية</u> (٧/١٦٧) ما جاء في قول مجاهد، و<span class="comment-type-2">انتقده</span>، فقال: «وقال مجاهد: هي جمع جوْبة، وهي الحفرة العظيمة من الأرض. وفي هذا نظر». ثم قال: "<span class="mustanad">ومنه قول الأعشى</span>:</p><p>نفى الذم عن آل المحلق جفنة كجابية الشيخ العراقي تفهق".</div></p><p><div></p><p><p><span class="item-no">٦٣١٧٩<span class="dash">-</span></span> عن <span class="name-2">الضحاك بن مزاحم</span> -من طريق عبيد- ‹وجِفانٍ كالجَوابِي›: كحياض الإبل العظام{26}. (١٢/١٧٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٣١٨٠<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق أبي رجاء- <span class="qpc-hafs">﴿كالجَوابِ﴾</span>: كالحياض{27}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٣١٨١<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span>، ‹وجِفانٍ كالجَوابِي›، قال: كالحياض{28}. (١٢/١٧٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٣١٨٢<span class="dash">-</span></span> عن <span class="name-2">عطية بن سعد العوفي</span>، قال: <span class="qpc-hafs">﴿وجِفانٍ كالجَوابِ﴾</span>، قال: كالجوْبة من الأرض{4}. (١٢/١٧٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٣١٨٣<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- ‹وجِفانٍ كالجَوابِي›، قال: كالحياض{30}. (١٢/١٧٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٣١٨٤<span class="dash">-</span></span> عن <span class="name-2">عطاء الخراساني</span> -من طريق يونس بن يزيد- في قوله جل وعلا: <span class="qpc-hafs">﴿جفان كالجواب﴾</span>، قال: الجفان: العظام{31}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٣١٨٥<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- <span class="qpc-hafs">﴿وجِفانٍ كالجَوابِ﴾</span>، قال: جفان كجوبة الأرض من العِظَم. والجوبة من الأرض: يُستنقع فيها الماء{19}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَقُدُورࣲ رَّاسِیَـٰتٍۚ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٣١٨٦<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- في قوله: <span class="qpc-hafs">﴿وقُدُورٍ راسِياتٍ﴾</span>، قال: أثافِيُّها{33} منها{18}. (١٢/١٧٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٣١٨٧<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span>، <span class="qpc-hafs">﴿وقُدُورٍ راسِياتٍ﴾</span>، قال: عظام تُفْرَغ إفراغًا{35}. (١٢/١٧٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٣١٨٨<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- <span class="qpc-hafs">﴿وقُدُورٍ راسِياتٍ﴾</span>، قال: عِظام{36}. (١٢/١٧٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٣١٨٩<span class="dash">-</span></span> عن <span class="name-2">الضحاك بن مزاحم</span> -من طريق عبيد- <span class="qpc-hafs">﴿وقُدُورٍ راسِياتٍ﴾</span>: قدور عِظام، كانوا ينحتونها من الجبال{37}. (١٢/١٧٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٣١٩٠<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span>، <span class="qpc-hafs">﴿وقُدُورٍ راسِياتٍ﴾</span>، قال: القدور العظام التي لا تُحرَّك من مكانها{28}. (١٢/١٧٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٣١٩١<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿وقُدُورٍ راسِياتٍ﴾</span>، قال: ثابِتات لا يزُلن عن مكانهن، كُنَّ يُرَيْنَ بأرض اليمن{30}. (١٢/١٧٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٣١٩٢<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span>: <span class="qpc-hafs">﴿راسِياتٍ﴾</span>، يعني: ثابتات في الأرض، عِظام تنقُر من الجبال بأثافيِّها لا تُحوّل عن أماكنها{40}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٣١٩٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وجِفانٍ كالجَوابِ﴾</span> وقصاع في العِظَم كحياض الإبل بأرض اليمن، من العِظَم يجلس على كل قصعة واحدة ألف رجل، يأكلون منها بين يدي سليمان، <span class="qpc-hafs">﴿وقُدُورٍ﴾</span> عظام لها قوائم لا تتحرك، <span class="qpc-hafs">﴿راسِياتٍ﴾</span> ثابتات تُتخذ من الجبال. والقدور وعين الصُفر بأرض اليمن، وكان مُلكُ سليمان ما بين مصر وكابل{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٣١٩٤<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- <span class="qpc-hafs">﴿وقُدُورٍ راسِياتٍ﴾</span>، قال: مثال الجبال مِن عِظَمِها، يُعمل فيها الطعام مِن الكِبَر والعِظم، لا تُحرّك، ولا تُنقل، كما قال للجبال: راسيات{42}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَقُدُورࣲ رَّاسِیَـٰتٍۚ﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٦٣١٩٥<span class="dash">-</span></span> عن <span class="name-2">عطية العوفي</span> -من طريق قُرَّة بن خالد- قال: أمر سليمانُ ببناء بيت المقدس، فقالوا له: زوبعة الشيطان له عينٌ في جزيرة من البحر يرِدها كل سبعة أيام يومًا. فأَتوها، فنزحوها ثم صبُّوا فيها خمرًا، فجاء لِوِرْده، فلمّا أبصر الخمر قال في كلام له: ما علمتُ أنكِ إذا شربكِ صاحبُك لمَما تُظهرين عليه عدوه -في أساجيع له-، لا أذوقكِ اليوم. فذهب ثم رجع لظمأٍ آخر، فلما رآها قال كما قال أول مرة، ثم ذهب فلم يشرب، حتى جاء لظمئه لإحدى وعشرين ليلة، فقال: ما علمتُ أنكِ لَتُذهبين الهمَّ. في سجع له، فشرب منها، فسكر، فجاءوا إليه، فأروْه خاتم السُّخرة، فانطلق معهم إلى سليمان، فأمرهم بالبناء، فقال زوبعة: دلُّوني على بيض الهدهد. فدُلّ على عُشِّه، فأكبَّ عليه جُمجُمة، يعني: زجاجة، فجاء الهدهد، فجعل لا يصِل إليه، فانطلق، فجاء بالماس الذي يُثقب به الياقوت، فوضعه عليها فقطَّ الزجاجة نصفين، ثم ذهب ليأخذه، فأزعجوه، فجاء بالماس إلى سليمان، فجعلوا يستعرضون الجبال كأنما يخطون، أي: في نواحيها؛ في نواحي الجبل في طين{43}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٣١٩٦<span class="dash">-</span></span> قال معمر، وقال <span class="name-2">قتادة</span>: إنّ سليمان قال للشياطين: إنِّي قد أمرتُ أن أبني مسجدًا -يعني: مسجد بيت المقدس- لا أسمع فيه صوت منقار ولا ميشار{44}. فقالت له الشياطين: إنّ في البحر شيطانًا، فلعلك إن قدرت عليه أن يخبرك بذلك. وكان ذلك الشيطان يرد كل سبعة أيام عينًا يشرب منها، فعمدت الشياطين إلى تلك العين، فنزحتها، ثم ملأتها خمرًا، فجاء ذلك الشيطان، فقال: إنّك لطيبة الريح، ولكنك تُسفِّهين الحليم، وتزيدين السفيه سفهًا. ثم ذهب فلم يشرب، ثم أدركه العطش، فرجع، فقال مثل ذلك ثلاث مرات، ثم إنه كرع فشرب فسكر، فأخذوه، فجاءوا به إلى سليمان، فأراه سليمان خاتمه، فلما رآه ذلَّ له، وكان ملك سليمان في خاتمه، فقال سليمان: إني قد أمرت أن أبني مسجدًا فلا أسمع فيه صوت منقار ولا ميشار. فأمر الشياطين بزجاجة فصنعت له، ثم وضعت على بيض الهدهد، فجاء الهدهد ليربض على بيضه فلم يقدر عليه، فذهب، فقال الشيطان: انظروا ما يأتي به الهدهد فخذوه. فجاء بالماس، فوضعه على الزجاجة، ففلقها، فأخذوا الماس، فجعلوا يقطعون به الحجارة قطعًا حتى بنى بيت المقدس{45}. (١٢/٥٧٤)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿ٱعۡمَلُوۤا۟ ءَالَ دَاوُۥدَ شُكۡرࣰاۚ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٣١٩٧<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، في قوله: <span class="qpc-hafs">﴿اعْمَلُوا آلَ داوُودَ شُكْرًا﴾</span>، قال: اعملوا شكرًا لله على ما أنعم به عليكم{4}. (١٢/١٧٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٣١٩٨<span class="dash">-</span></span> عن <span class="name-2">أبي عبد الرحمن الحُبُلِّي</span> -من طريق زهرة بن معبد- قال: <span class="qpc-hafs">﴿اعْمَلُوا آلَ داوُودَ شُكْرًا﴾</span> الصلاة شكر، والصيام شكر، وكل خير تعمله لله شكر، وأفضل الشكر الحمد{47}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٣١٩٩<span class="dash">-</span></span> عن <span class="name-2">محمد بن كعب القرظي</span> -من طريق موسى بن عبيدة- في قوله: <span class="qpc-hafs">﴿اعْمَلُوا آلَ داوُودَ شُكْرًا﴾</span>، قال: الشكر: تقوى الله، والعمل بطاعته{48}. (١٢/١٧٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٣٢٠٠<span class="dash">-</span></span> عن <span class="name-2">عطاء الخراساني</span> -من طريق ابنه عثمان- قال: كان داود ﵇ يرتفع له كل يوم درع، فيبيعه بستة آلاف، فينفق على بني إسرائيل أربعة آلاف، وعلى عياله ألفين، فأُوتي داود ﵇ ما أُوتي ثم قيل له: <span class="qpc-hafs">﴿اعْمَلُوا آلَ داوُودَ شُكْرًا﴾</span>{49}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٣٢٠١<span class="dash">-</span></span> عن <span class="name-2">محمد بن شهاب الزهري</span> -من طريق عبد الجليل بن حميد- في قوله: <span class="qpc-hafs">﴿اعْمَلُوا آلَ داوُودَ شُكْرًا﴾</span>، قال: قولوا: الحمد لله{50}. (١٢/١٧٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٣٢٠٢<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span>، في قوله: <span class="qpc-hafs">﴿اعْمَلُوا آلَ داوُودَ شُكْرًا﴾</span>، قال:لم ينفكْ منهم مصلٍّ{16}. (١٢/١٧٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٣٢٠٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثم قال ﷿: <span class="qpc-hafs">﴿اعْمَلُوا آلَ داوُودَ شُكْرًا﴾</span> بما أعطيتم من الخير{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٣٢٠٤<span class="dash">-</span></span> عن <span class="name-3">مسعر</span>، قال: لَمّا قيل لهم: <span class="qpc-hafs">﴿اعْمَلُوا آلَ داوُودَ شُكْرًا﴾</span>لم يأتِ على القوم ساعةٌ إلا ومنهم مصلٍّ{53}. (١٢/١٧٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٣٢٠٥<span class="dash">-</span></span> عن <span class="name-3">الفضيل</span>، قال في قوله: <span class="qpc-hafs">﴿اعْمَلُوا آلَ داوُودَ شُكْرًا﴾</span>: قال داود: يا رب، كيف أشكرك، والشكر نعمة منك؟ قال: الآن شكرتني؛ حين علمتَ أنّ النِّعَم مِنِّي{54}. (١٢/١٧٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٣٢٠٦<span class="dash">-</span></span> عن المغيرة بن عتيبة، قال: قال داود: يا رب، هل بات أحدٌ مِن خلقك الليلةَ أطول ذِكرًا لك مِنِّي؟ فأوحى الله إليه: نعم، الضفدع. وأنزل الله على داود: <span class="qpc-hafs">﴿اعْمَلُوا آلَ داوُودَ شُكْرًا﴾</span>، فقال داود: يا رب، كيف أطيق شكرك، وأنت الذي تُنعِمُ عَلَيَّ ثم ترزقني على النعمة الشكر؟ فالنعمة منك، والشكر منك، فكيف أطيق شكرك؟ قال: يا داود، الآن عرفتني حق معرفتي{55}. (١٢/١٧٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٣٢٠٧<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿اعْمَلُوا آلَ داوُودَ شُكْرًا﴾</span>، قال: فيما أعطاكم وعلَّمكم، وسخَّر لكم ما لم يُسَخِّر لغيركم، وعلَّمكم منطق الطير، اشكروا له، يا آل داود. قال: الحمد طرفٌ مِن الشكر{56}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٣٢٠٨<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿اعْمَلُوا آلَ داوُودَ شُكْرًا﴾</span> قال بعضهم: توحيدًا. وقال بعضهم: لما نزلت لم يزل إنسانٌ منهم قائمًا يصلي{57}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَقَلِیلࣱ مِّنۡ عِبَادِیَ ٱلشَّكُورُ ۝١٣﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٣٢٠٩<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- في قوله: <span class="qpc-hafs">﴿وقَلِيلٌ مِن عِبادِيَ الشَّكُورُ﴾</span>، يقول: قليل مِن عبادي الموحدين توحيدهم{58}. (١٢/١٧٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٣٢١٠<span class="dash">-</span></span> عن <span class="name-2">ثابت بن أسلم البناني</span> -من طريق جعفر بن سليمان- قال: بلغنا: أنّ داود ﵇ جَزَّأ الصلاة على بيوته؛ على نسائه وولده، فلم تكن تأتي ساعةٌ مِن الليل والنهار إلا وإنسانٌ قائِمٌ من آل داود يصلي، فعَمَّتهم هذه الآية: <span class="qpc-hafs">﴿اعْمَلُوا آلَ داوُودَ شُكْرًا وقَلِيلٌ مِن عِبادِيَ الشَّكُورُ﴾</span>{59}. (١٢/١٧٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٣٢١١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وقَلِيلٌ مِن عِبادِيَ الشَّكُورُ﴾</span> لربهم{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٣٢١٢<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿وقَلِيلٌ مِن عِبادِيَ الشَّكُورُ﴾</span> أي: أقل الناس المؤمن{57}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَقَلِیلࣱ مِّنۡ عِبَادِیَ ٱلشَّكُورُ ۝١٣﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٦٣٢١٣<span class="dash">-</span></span> عن عطاء بن يسار، قال: قال رسول الله ﷺ وهو يخطب الناسَ على المنبر، وقرأ هذه الآية: <span class="qpc-hafs">﴿اعْمَلُوا آلَ داوُودَ شُكْرًا﴾</span>، قال: «<b>ثلاثٌ مَن أُوتِيهُنَّ فقد أُوتِي ما أُوتِي آلُ داود</b>». قيل: وما هُنَّ، يا رسول الله؟ قال: «<b>العدلُ في الغضب والرضا، والقَصْد في الفقر والغِنى، وذِكرُ الله في السِّرِّ والعلانية</b>»{62}. (١٢/١٧٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٣٢١٤<span class="dash">-</span></span> عن حفصة -من طريق عطاء بن يسار-، مرفوعًا به{63}. (١٢/١٧٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٣٢١٥<span class="dash">-</span></span> عن أبي هريرة -من طريق عطاء بن يسار-، مرفوعًا به{64}. (١٢/١٧٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٣٢١٦<span class="dash">-</span></span> عن أبي ذر -من طريق عطاء بن يسار- مرفوعًا به، وقال: «<b>خشية الله في السر والعلانية</b>»{65}. (١٢/١٧٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٣٢١٧<span class="dash">-</span></span> عن إبراهيم التيمي، قال: قال رجل عند عمر: اللهم، اجعلني مِن القليل. فقال عمر: ما هذا الدعاء الذي تدعو به؟! قال: إني سمعت الله يقول: <span class="qpc-hafs">﴿وقَلِيلٌ مِن عِبادِيَ الشَّكُورُ﴾</span>، فأنا أدعو الله أن يجعلني من ذلك القليل. فقال عمر: كل الناس أعلمُ مِن عمر{66}. (١٢/١٧٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٣٢١٨<span class="dash">-</span></span> عن مسعر، قال: إنّ عمر سمع رجلًا يقول: اللهم، اجعلني من القليل. فقال: يا عبد الله، ما هذا؟! قال: سمعتُ الله يقول: <span class="qpc-hafs">﴿ومَن آمَنَ وما آمَنَ مَعَهُ إلّا قَلِيلٌ﴾</span> [هود:٤٠]، <span class="qpc-hafs">﴿وقَلِيلٌ مِن عِبادِيَ الشَّكُورُ﴾</span>، وذكر آية أخرى. فقال عمر: كل أحد أفقه مِن عمر{67}. (١٢/١٧٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٣٢١٩<span class="dash">-</span></span> عن <span class="name-2">أبي الجلد</span>، قال: قرأتُ في مسألة داود أنّه قال: أي ربِّ، كيف لي أن أشكرك، وأنا لا أصِل إلى شكرك إلا بنعمتك؟ قال: فأتاه الوحي: أن يا داود، أليس تعلم أنّ الذي بِك مِن النِّعَم مِنِّي؟ قال: بلى، يا رب. قال: فإنِّي أرضى بذلك منك شكرًا{68}. (١٢/١٧٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٣٢٢٠<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span>: قال داود لسليمان: قد ذكر الله الشكرَ، فاكفني قيامَ النهار أكفك قيام الليل. قال: لا أستطيع. قال: فاكفني إلى صلاة الظهر. فكفاه{69}. (١٢/١٧٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٣٢٢١<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق معاوية- قال: قال داود: إلهي، لو أنّ لكل شعرة مِنِّي لِسانَيْنِ يُسَبِّحانك الليلَ والنهارَ والدهر كله؛ ما قضيتُ حقَّ نعمة واحدة من نِعَمِك عَلَيَّ{70}. (١٢/١٧٧)</p></p><p></div></p></div>",footnotes:1:أخرجه عبد بن حميد -كما في التغليق ٤/٣١-، وابن جرير ١٩/٢٣٠. وعلَّقه يحيى بن سلام ٢/٧٤٩. وعزاه السيوطي إلى الفريابي، وابن المنذر، وابن أبي حاتم.|2:أخرجه ابن جرير ١٩/٢٣١. وعزاه السيوطي إلى ابن المنذر، وابن أبي شيبة.|3:علقه يحيى بن سلام ٢/٧٤٩.|4:عزاه السيوطي إلى ابن أبي حاتم.|5:أخرجه عبد الرزاق ٢/١٢٧ من طريق معمر، وابن جرير ١٩/٢٣٠. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.|6:علقه يحيى بن سلام ٢/٧٤٩.|7:تفسير مقاتل بن سليمان ٣/٥٢٧.|8:أخرجه ابن جرير ١٩/٢٣١.|9:أخرجه الحكيم الترمذي في نوادر الأصول ١/٣٧٤.|10:أخرجه ابن جرير ١٩/٢٣١. وعلَّقه يحيى بن سلام ٢/٧٤٩. وعزاه السيوطي إلى الفريابي، وعبد بن حميد، وابن المنذر، وابن أبي حاتم.|11:أخرجه ابن جرير ١٩/٢٣١. وعزاه السيوطي إلى ابن المنذر، وابن أبي شيبة.|12:علقه يحيى بن سلام ٢/٧٤٩.|13:عزاه السيوطي إلى ابن أبي حاتم.|14:عزاه السيوطي إلى عبد الرزاق، وعبد بن حميد، وابن أبي حاتم، وابن المنذر. وأخرجه ابن جرير ١٩/٢٣٠ من طريق سعيد بلفظ: زجاج وشَبَهٍ. والشبه: النحاس يُصبغ فيصفر. اللسان (شبه). وعزاه الحافظ ابن حجر في الفتح ١٠/٣٨٢ إلى عبد الرزاق بلفظ: كانت من خشب ومن زجاج.|15:تفسير مقاتل بن سليمان ٣/٥٢٧.|16:عزاه السيوطي إلى ابن المنذر.|17:الجوبة: الحفرة. اللسان (جوب).|18:أخرجه ابن جرير ١٩/٢٣٢، وابن أبي حاتم -كما في التغليق ٤/٣١، وفتح الباري ٨/٥٣٧-. وعزاه السيوطي إلى ابن المنذر.|19:أخرجه ابن جرير ١٩/٢٣٣.|20:لا تني: لا تفتر. والمترعة: المملوءة. والمحتضر: النازل على الماء. شرح ديوان طرفة (٦٧).|21:المحروب: المسلوب ماله. شرح ديوان طرفة (١١٠).|22:أخرجه الطستي -كما في الإتقان ٢/٧٥- دون البيت الثاني.|23:تفسير مجاهد (٥٥٣)، وأخرجه ابن جرير ١٩/٢٣٣، كما أخرجه يحيى بن سلام ٢/٧٥٠ بنحوه من طريق أبي يحيى.|24:علقه يحيى بن سلام ٢/٧٤٩.|25:أخرجه عبد بن حميد -كما في التغليق ٤/٣١-، وابن جرير ١٩/٢٣٣ بنحوه. وعلَّقه يحيى بن سلام ٢/٧٥٠. وعزاه السيوطي إلى الفريابي، وابن المنذر، وابن أبي حاتم.|26:أخرجه ابن جرير ١٩/٢٣٤ من طريق جويبر أيضًا. وعزاه السيوطي إلى ابن المنذر، وابن أبي شيبة.|27:عزاه السيوطي إلى ابن أبي حاتم.</p><p>([٩٨٤]) أخرجه ابن جرير ١٩/٢٣٣. وعلَّقه يحيى بن سلام في تفسيره ٢/٧٤٩-٧٥٠. وأخرجه الثعلبي في تفسيره ٨/٧٩ من طريق سهل السراج بلفظ: مثل حياض الإبل.|28:عزاه السيوطي إلى عبد بن حميد.|29:عزاه السيوطي إلى ابن أبي حاتم.|30:أخرجه عبد الرزاق ٢/١٢٧ من طريق معمر، وأخرجه ابن جرير ١٩/٢٣٤ بنحوه. وعزاه السيوطي إلى عبد بن حميد، وابن أبي حاتم، وابن المنذر.|31:أخرجه أبو جعفر الرملي في جزئه ص٨٩ (تفسير عطاء الخراساني).|32:أخرجه ابن جرير ١٩/٢٣٣.|33:أثافيها: هي الحجارة التي توضع عليها القِدر. اللسان (أثف).|34:أخرجه ابن جرير ١٩/٢٣٢، وابن أبي حاتم -كما في التغليق ٤/٣١، وفتح الباري ٨/٥٣٧-. وعزاه السيوطي إلى ابن المنذر.|35:عزاه السيوطي إلى عبد بن حميد، والفريابي.|36:أخرجه عبد بن حميد -كما في التغليق ٤/٣١-، وابن جرير ١٩/٢٣٤ بنحوه. وعلَّقه يحيى بن سلام ٢/٧٥٠. وعزاه السيوطي إلى الفريابي، وابن المنذر، وابن أبي حاتم.|37:أخرجه ابن جرير ١٩/٢٣٤. وعزاه السيوطي إلى ابن أبي شيبة،وابن المنذر.|38:عزاه السيوطي إلى عبد بن حميد.|39:أخرجه عبد الرزاق ٢/١٢٧ من طريق معمر، وأخرجه ابن جرير ١٩/٢٣٤ بنحوه. وعزاه السيوطي إلى عبد بن حميد، وابن أبي حاتم، وابن المنذر.|40:علقه يحيى بن سلام ٢/٧٥٠.|41:تفسير مقاتل بن سليمان ٣/٥٢٧.|42:أخرجه ابن جرير ١٩/٢٣٣، ٢٣٥.|43:أخرجه يحيى بن سلام ٢/٧٥٠-٧٥١.|44:المئشار، بالهمز: هو المنشار، بالنون. وقد يترك الهمز. لسان العرب (أشر).|45:أخرجه عبد الرزاق في تفسيره ٢/١٦٤-١٦٥، وفي مصنفه (٩٧٥٣)، وابن جرير ٢٠/٨٩-٩١. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر. وسيأتي بنحوه في سورة ص.|46:عزاه السيوطي إلى ابن أبي حاتم.|47:أخرجه عبد الله بن وهب في الجامع في تفسير القرآن ١/١٤٢ (٣٣١)، وابن جرير ١٩/٢٣٦.|48:أخرجه ابن جرير ١٩/٢٣٥-٢٣٦، وابن أبي حاتم -كما في تفسير ابن كثير ٦/٤٨٨-. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.|49:أخرجه الحكيم الترمذي في نوادر الأصول (ت: إسماعيل إبراهيم عوض) ١/٣١٧ (٤٣٩).|50:أخرجه البيهقي في شعب الإيمان (٤٤٧٨).|51:عزاه السيوطي إلى ابن المنذر.|52:تفسير مقاتل بن سليمان ٣/٥٢٧.|53:أخرجه ابن أبي الدنيا (٧٤)، والبيهقي في شعب الإيمان (٤٥٢٤)، وابن عساكر في تاريخ دمشق ١٧/٩٣.|54:أخرجه ابن أبي حاتم -كما في تفسير ابن كثير ٦/٤٨٩-.|55:أخرجه البيهقي في شعب الإيمان (٤٤١٣)، وأحمد في الزهد (٦٩). وعزاه السيوطي إلى ابن المنذر.|56:أخرجه ابن جرير ١٩/٢٣٦.|57:تفسير يحيى بن سلام ٢/٧٥١.|58:أخرجه ابن جرير ١٩/٢٣٦، وابن أبي حاتم -كما في الإتقان ٢/٣٧-. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.|59:أخرجه ابن أبي شيبة في مصنفه (ت: محمد عوامة) ١٦/٥٥٦-٥٥٧ (٣٢٥٥٠)، ١٩/٣٩ (٣٥٤٢٠)، وابن أبي حاتم -كما في تفسير ابن كثير ٦/٤٨٨-، والبيهقي في شعب الإيمان (٣١٨٧). وعزاه السيوطي إلى أحمد في الزهد.|60:تفسير مقاتل بن سليمان ٣/٥٢٧.|61:تفسير يحيى بن سلام ٢/٧٥١.|62:أخرجه القاسم بن سلام في الخطب والمواعظ ص١٤٣ (٥٨).|63:عزاه السيوطي إلى ابن مردويه.|64:أورده الحكيم الترمذي في نوادر الأصول ٢/٧.|65:أخرجه ابن النجار في تاريخه ١٦/١٨٩، من طريق عبد الله بن منيب الحارثي الأنصاري، عن أبيه، عن عطاء بن يسار، عن أبي ذر به.</p><p>إسناده ضعيف؛ فيه عبد الله بن منيب، قال عنه ابن حجر في لسان الميزان ٥/٢٤: «روى عن الزهري أحاديث مكذوبة، وهو ضعيف».</p><p>وأخرج إسحاق البستي ص١٥٠ نحوه من طريق يزيد بن أبي تميم، عن رجل من أصحاب رسول الله ﷺ.|66:أخرجه ابن أبي شيبة ١٠/٣٢٢. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.|67:عزاه السيوطي إلى عبد الله في زوائد الزهد.|68:أخرجه أحمد في الزهد (٧٢)، وابن أبي الدنيا في كتاب الشكر (٥)، والبيهقي في شعب الإيمان (٤٤١٤).|69:عزاه السيوطي إلى الفريابي، وابن أبي حاتم.|70:أخرجه ابن أبي شيبة ١١/٥٥٣، وأحمد (٦٩).
  34,14,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿فَلَمَّا قَضَیۡنَا عَلَیۡهِ ٱلۡمَوۡتَ مَا دَلَّهُمۡ عَلَىٰ مَوۡتِهِۦۤ إِلَّا دَاۤبَّةُ ٱلۡأَرۡضِ تَأۡكُلُ مِنسَأَتَهُۥۖ فَلَمَّا خَرَّ تَبَیَّنَتِ ٱلۡجِنُّ أَن لَّوۡ كَانُوا۟ یَعۡلَمُونَ ٱلۡغَیۡبَ مَا لَبِثُوا۟ فِی ٱلۡعَذَابِ ٱلۡمُهِینِ ۝١٤﴾</span> - قراءات</h3></p><p><div></p><p><p><span class="item-no">٦٣٢٢٢<span class="dash">-</span></span> قال سفيان: وفي قراءة <span class="name-1">ابن مسعود</span>: (وهُمْ يَدْأبُونَ لَهُ حَوْلًا){1}. (١٢/١٨١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٣٢٢٣<span class="dash">-</span></span> عن مُرَّة الهمذاني: أنّ في قراءة <span class="name-1">ابن مسعود</span>: (فَمَكَثُواْ يَدْأَبُونَ لَهُ مِن بَعْدِ مَوْتِهِ حَوْلًا كامِلًا){2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٣٢٢٤<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق قيس بن سعد- أنّه كان يقرأ: (فَلَمّا خَرَّ تَبَيَّنَتِ الإنسُ أن لَّوْ كانَ الجِنُّ يَعْلَمُونَ الغَيْبَ ما لَبِثُواْ فِي العَذابِ المُهِينِ).= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٣٢٢٥<span class="dash">-</span></span> قال قيس بن سعد: وهي في قراءة <span class="name-1">أُبَيِّ بن كعب</span> كذلك{3}. (١٢/١٨٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٣٢٢٦<span class="dash">-</span></span> كان <span class="name-1">عبد الله بن عباس</span> يقرأها: (فَتَبَيَّنَتِ الإنسُ أنَّ الجِنَّ لَوْ كانُواْ يَعْلَمُونَ الغَيْبَ ما لَبِثُواْ حَوْلًا فِي العَذابِ المُهِينِ){4}. (١٢/١٨١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٣٢٢٧<span class="dash">-</span></span> كان <span class="name-1">عبد الله بن عباس</span> يقرأ: (فَلَمّا خَرَّ تَبَيَّنَتِ الإنسُ أن لَّوْ كانَ الجِنُّ يَعْلَمُونَ الغَيْبَ ما لَبِثُواْ فِي العَذابِ المُهِينِ سَنَةً){5}<span class=comment-ref>٥٣٠٣</span>. (١٢/١٨١)</p></p><p></div></p><p><div><span class=comment-ref>٥٣٠٣</span> <span class="comment-type-4">علّق</span> <u>ابن جرير</u> (١٩/٢٤٣) على قراءة ابن عباس، فقال: «و<span class="qpc-hafs">﴿أن﴾</span>في قوله: <span class="qpc-hafs">﴿أن لو كانوا﴾</span> في موضع رفع بـ(تبين)؛ لأن معنى الكلام: فلما خر تبين وانكشف أن لو كان الجن يعلمون الغيب ما لبثوا في العذاب المهين. وأما على التأويل الذي تأوله ابن عباس من أن معناه: تبينت الإنس الجن. فإنه ينبغي أن تكون<span class="qpc-hafs">﴿أن﴾</span> في موضع نصب بتكريرها على <span class="qpc-hafs">﴿الجن﴾</span>، وكذلك يجب على هذه القراءة أن تكون <span class="qpc-hafs">﴿الجن﴾</span> منصوبة، غير أني لا أعلم أحدًا من قرأة الأمصار يقرأ ذلك بنصب <span class="qpc-hafs">﴿الجن﴾</span>، ولو نُصبت كان في قوله: <span class="qpc-hafs">﴿تبينت﴾</span> ضمير من ذكر الإنس».</div></p><p><h3><span class="qpc-hafs">﴿فَلَمَّا قَضَیۡنَا عَلَیۡهِ ٱلۡمَوۡتَ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٣٢٢٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن مسعود</span>، <span class="qpc-hafs">﴿فَلَمّا قَضَيْنا عَلَيْهِ المَوْتَ﴾</span> الآية، قال: مكث سليمانُ بنُ داود حولًا على عصاه مُتَّكِئًا، حتى أكلتها الأرَضَةُ، فخرَّ{6}. (١٢/١٨٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٣٢٢٩<span class="dash">-</span></span> عن <span class="name-2">عطاء</span> -من طريق جرير- قال: كان سليمان بن داود يصلي، فمات وهو قائم يصلي، والجن يعملون لا يعلمون بموته، حتى أكلت الأرَضَة عصاه، فخرَّ{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٣٢٣٠<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span>: <span class="qpc-hafs">﴿فَلَمّا قَضَيْنا عَلَيْهِ المَوْتَ﴾</span>، يعني: فلما أنزلنا عليه الموت{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٣٢٣١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فَلَمّا قَضَيْنا عَلَيْهِ﴾</span> على سليمان <span class="qpc-hafs">﴿المَوْتَ﴾</span> وذلك أنّ سليمان ﵇ كان دخل في السن، وهو في بيت المقدس{9}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿مَا دَلَّهُمۡ عَلَىٰ مَوۡتِهِۦۤ إِلَّا دَاۤبَّةُ ٱلۡأَرۡضِ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٣٢٣٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- <span class="qpc-hafs">﴿دابَّةُ الأَرْضِ﴾</span>: الأرَضَة{10}. (١٢/١٨١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٣٢٣٣<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿إلّا دابَّةُ الأَرْضِ﴾</span>، قال: الأرَضَة{11}. (١٢/١٨٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٣٢٣٤<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span>: قال: الأرَضَة{6}. (١٢/١٨٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٣٢٣٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ما دَلَّهُمْ﴾</span> ما دل الجنَّ <span class="qpc-hafs">﴿عَلى مَوْتِهِ﴾</span> على موت سليمان <span class="qpc-hafs">﴿إلّا دابَّةُ الأَرْضِ﴾</span> يعني: الأرَضَة{13}<span class=comment-ref>٥٣٠٤</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٥٣٠٤</span> قال <u>ابنُ عطية</u> (٧/١٧٠): «وقال كثير من المفسرين: <span class="qpc-hafs">﴿دابَّةُ الأَرْضِ﴾</span> هي سوسة العود، وهي الأرَضَة، <span class="mustanad">وقرأ ابن عباس والعباس بن المفضل</span>: (الأَرَضِ) بفتح الراء، جمع: أرضة، فهذا يقوي ذلك التأويل». ثم ذكر في معنى الآية قولين آخرين، فقال: «<b>وقالت فرقة</b>: <span class="qpc-hafs">﴿دابة الأرض﴾</span> حيوان مِن الأرض شأنه أن يأكل العود، وذلك موجود، وليس السوسة من دواب الأرض. <b>وقالت فرقة</b> منها أبو حاتم اللغوي: <span class="qpc-hafs">﴿الأرض﴾</span> هنا مصدر: أرضت الأثواب والخشبة؛ إذا أكلتها الأرضة، فكأنه قال: دابة الأكل الذي هو بتلك الصورة على جهة التسوس».</div></p><p><h3><span class="qpc-hafs">﴿تَأۡكُلُ مِنسَأَتَهُۥۖ﴾</span> - قراءات</h3></p><p><div></p><p><p><span class="item-no">٦٣٢٣٦<span class="dash">-</span></span> عن <span class="name-3">هارون [بن موسى الأعور]</span> -من طريق النضر-: <span class="qpc-hafs">﴿تَأْكُلُ مِنسَأَتَهُ﴾</span> مهموزة.= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٣٢٣٧<span class="dash">-</span></span> وكان <span class="name-2">أبو عمرو</span> يهمزها ثم ترك الهمز، وكلاهما عربية، والمنسأ: العصا{14}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿تَأۡكُلُ مِنسَأَتَهُۥۖ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٣٢٣٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- <span class="qpc-hafs">﴿مِنسَأَتَهُ﴾</span>: عصاه{10}. (١٢/١٨١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٣٢٣٩<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، قال: لبث سليمانُ على عصاه حولًا بعدما مات، ثم خرّ على رأس الحول، فأخذت الجن عصًا مثل عصاه، ودابةً مثل دابته، فأرسلوها عليها، فأكلتها في سنة، وكان ابن عباس يقرأ: (فَلَمّا خَرَّ تَبَيَّنَتِ الإنسُ أن لَّوْ كانَ الجِنُّ يَعْلَمُونَ الغَيْبَ ما لَبِثُواْ فِي العَذابِ المُهِينِ سَنَةً) قال سفيان: وفي قراءة ابن مسعود: (وهُمْ يَدْأَبُونَ لَهُ حَوْلًا){16}. (١٢/١٨١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٣٢٤٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق قيس بن سعد- قال: كانت الإنس تقول في زمن سليمان: إنّ الجن تعلم الغيب. فلمّا مات سليمان مكث قائمًا على عصاه ميِّتا حولًا، والجن تعمل بقيامه، (فَلَمّا خَرَّ تَبَيَّنَتِ الإنسُ أن لَّوْ كانَ الجِنُّ يَعْلَمُونَ الغَيْبَ ما لَبِثُواْ فِي العَذابِ المُهِينِ سَنَةً) كان ابن عباس يقرؤها كذلك{16}. (١٢/١٨٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٣٢٤١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، قال: <span class="qpc-hafs">﴿تَأْكُلُ مِنسَأَتَهُ﴾</span> بلغت نصف العصا، فتركوها في النصف الباقي، فأكلتها في حَوْل، فقالوا: مات عام أول{18}. (١٢/١٨٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٣٢٤٢<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span>، <span class="qpc-hafs">﴿تَأْكُلُ مِنسَأَتَهُ﴾</span>، قال: العصا{6}. (١٢/١٨٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٣٢٤٣<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿تَأْكُلُ مِنسَأَتَهُ﴾</span>، قال: عصاه{20}. (١٢/١٨٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٣٢٤٤<span class="dash">-</span></span> <span class="name-2">عن عكرمة مولى ابن عباس</span>: <span class="qpc-hafs">﴿تَأْكُلُ مِنسَأَتَهُ﴾</span>، أنّه سُئِل عن المنسأة. قال: هي العصا. وأنشد فيها شعرًا قاله عبد المطلب:</p><p>أمن أجلِ حبْلٍ لا أبا لك صِدْتَه بمنسأة قد جر حبْلك أحبُلا{18}. (١٢/١٨٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٣٢٤٥<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿تَأْكُلُ مِنسَأَتَهُ﴾</span>، قال: الأرَضَة أكلت عصاه حتى خرَّ{22}. (١٢/١٨٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٣٢٤٦<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- قال: كانت الجِنُّ تخبر الإنسَ أنهم يعلمون من الغيب أشياء، وأنهم يعلمون ما في غدٍ، فابتُلوا بموت سليمان، فمات، فلبث سنة على عصاه وهم لا يشعرون بموته، وهم مُسَخَّرون تلك السنة، ويعملون دائبين، <span class="qpc-hafs">﴿فَلَمّا خَرَّ تَبَيَّنَتِ الجِنُّ﴾</span>، وفي بعض القراءة: (تَبَيَّنَتِ الإنسُ أن لَّوْ كانَ الجِنُّ يَعْلَمُونَ الغَيْبَ ما لَبِثُواْ فِي العَذابِ المُهِينِ)، وقد لبثوا يدأبون ويعملون له حولًا بعد موته{23}. (١٢/١٨٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٣٢٤٧<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- قال: المنسأة: العصا. بلسان الحبشة{24}. (١٢/١٨٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٣٢٤٨<span class="dash">-</span></span> عن <span class="name-2">عطاء الخراساني</span> -من طريق يونس بن يزيد- في قوله: <span class="qpc-hafs">﴿منسأته﴾</span>، قال: عصاه{25}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٣٢٤٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: وذلك أنّ الجِنَّ كانوا يُخْبِرُون الإنسَ أنّهم يعلمون الغيب الذي يكون في غدٍ، فابتُلوا بموت سليمان ببيت المقدس، وكان داود أسَّسَ بيتَ المقدس موضع فسطاط موسى ﵇، فمات قبل أن يُبْنى، فبناه سليمان بالصَّخر والقار، فلما حضره الموت قال لأهله: لا تخبروا الجِنَّ بموتي حتى يفرغوا مِن بناء بيت المقدس. وكان قد بقي منه عملَ سنة، فلما حضره الموت وهو مُتَّكِئٌ على عصاه، وقد أوصى أن يُكتم موته، وقال: لا تبكوا عَلَيَّ سنةً؛ لِئَلّا يتفرق الجنُّ عن بناء بيت المقدس. ففعلوا، فلما بنوا سنة وفرغوا مِن بنائه سلَّط الله ﷿ عليه الأَرَضَة عند رأس الحوْل على أسفل عصاه، فأكلته <span class="qpc-hafs">﴿تَأْكُلُ مِنسَأَتَهُ﴾</span> أسفل العصا، فخرَّ عند ذلك سليمان ميتًا، فرأته الجنُّ، فتفرقت، <span class="qpc-hafs">﴿فَلَمّا خَرَّ تَبَيَّنَتِ الجِنُّ﴾</span> يعنى: تبينت الإنس أن لو كانوا الجن <span class="qpc-hafs">﴿يَعْلَمُونَ الغَيْبَ﴾</span> يعني: غيب موت سليمان <span class="qpc-hafs">﴿ما لَبِثُوا﴾</span> حولًا <span class="qpc-hafs">﴿فِي العَذابِ المُهِينِ﴾</span> والشقاء والنصَب في بيت المقدس. وإنما سُمُّوا الجن لأنهم استخفوا مِن الإنس فلم يروهم{13}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٣٢٥٠<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- <span class="qpc-hafs">﴿تَأْكُلُ مِنسَأَتَهُ﴾</span>: المنسأة: العصا{24}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٣٢٥١<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- قال: قال سليمان لملك الموت: إذا أُمِرتَ بي فأعلِمني. فأتاه، فقال: يا سليمان، قد أُمِرتُ بك، قد بقيتْ لك سُوَيْعَةٌ. فدعا الشياطينَ، فبنوا عليه صَرْحًا مِن قوارير ليس له باب، فقام يصلي، فاتَّكأ على عصاه، فدخل عليه ملك الموت، فقبضَ روحه وهو متكئ على عصاه، ولم يصنع ذلك فرارًا مِن ملَك الموت. قال: والجِنُّ تعمل بين يديه وينظرون إليه، يحسبون أنه حي، فبعث الله دابة الأرض؛ دابةٌ تأكل العيدان يُقال لها: القادح. فدخلتْ فيها، فأكلتها، حتى إذا أكلتْ جوف العصا ضعُفتْ، وثقل عليها، فخرّ ميتًا، فلما رأت ذلك الجن انفَضُّوا وذهبوا، فذلك قوله: <span class="qpc-hafs">﴿ما دَلَّهُمْ عَلى مَوْتِهِ إلّا دابَّةُ الأَرْضِ تَأْكُلُ مِنسَأَتَهُ﴾</span>{28}. (١٢/١٨٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٣٢٥٢<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: مكث حولًا وهو مُتَوَكِّئ على عصاه، لا يرى الجِنُّ والإنسُ إلا أنّه حيٌّ على حاله الأول؛ لتعظُم الآية، بمنزلة ما أذهب الله مِن عملهم تلك الأربعين الليلة التي غاب عنها سليمان عن مُلْكِه، حيث خلَفه ذلك الشيطانُ في ملكه، وكان موتُه فجأةً وهو مُتَوَكِّئٌ على عصاه حولًا لا يعلمون أنه مات، وذلك أن الشياطين كانت تزعم للإنس أنهم يعلمون الغيب، فكانوا يعملون له حولًا لا يعلمون أنه مات، قال ﷿: <span class="qpc-hafs">﴿فَلَمّا خَرَّ﴾</span> سقط لَمّا أكلتِ الأَرَضَةُ العَصا خرَّ سليمان، فقال: <span class="qpc-hafs">﴿فَلَمّا خَرَّ تَبَيَّنَتِ الجِنُّ﴾</span> للإنس <span class="qpc-hafs">﴿أنْ لَوْ كانُوا يَعْلَمُونَ الغَيْبَ ما لَبِثُوا فِي العَذابِ المُهِينِ﴾</span> في تلك السُّخرة؛ في تلك الأعمال في السلاسل، تبين للإنس أن الجن لو كانوا يعلمون الغيب ما لبثوا في العذاب المهين{29}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿فَلَمَّا قَضَیۡنَا عَلَیۡهِ ٱلۡمَوۡتَ مَا دَلَّهُمۡ عَلَىٰ مَوۡتِهِۦۤ إِلَّا دَاۤبَّةُ ٱلۡأَرۡضِ تَأۡكُلُ مِنسَأَتَهُۥۖ فَلَمَّا خَرَّ تَبَیَّنَتِ ٱلۡجِنُّ أَن لَّوۡ كَانُوا۟ یَعۡلَمُونَ ٱلۡغَیۡبَ مَا لَبِثُوا۟ فِی ٱلۡعَذَابِ ٱلۡمُهِینِ ۝١٤﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٣٢٥٣<span class="dash">-</span></span> عن عبد الله بن عباس، عن النبي ﷺ، قال: «<b>كان سليمانُ إذا صلّى رأى شجرةً نابتة بين يديه، فيقول لها: ما اسمُكِ؟ فتقول: كذا وكذا. فيقول: لِمَ أنتِ؟ فتقول: لكذا وكذا. فإن كانت لغرْسٍ غُرست، وإن كانت لدواء كُتِبَت، فصلّى ذات يوم، فإذا شجرة نابتة بين يديه، فقال لها: ما اسمك؟ قالت: الخروب. قال: لأي شيء أنتِ؟ قالت: لخراب هذا البيت. فقال سليمان: اللهم، عمِّ عنِ الجن موتي، حتى يعلم الإنسُ أنّ الجن لا يعلمون الغيب. فهيّأ عصًا، فتوكأ عليها، وقبضه الله وهو متكئ، فمكث حولًا ميتًا والجن تعمل، فأكلتها الأرَضَة، فسقطت، فعلموا عند ذلك بموته، (فَتَبَيَّنَتِ الإنسُ أنَّ الجِنَّ لَوْ كانُوا يَعْلَمُونَ الغَيْبَ ما لَبِثُوا حَوْلًا فِي العَذابِ المُهِينِ)</b> -وكان ابن عباس يقرأها كذلك-، <b>فشكرت الجنُّ الأَرَضَة، فأينما كانت يأتونها بالماء</b>»{30}. (١٢/١٨١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٣٢٥٤<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق سعيد بن جبير-، موقوفًا{31}. (١٢/١٨٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٣٢٥٥<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن مسعود</span>، و<span class="name-1">ناس من أصحاب رسول الله ﷺ</span> -من طريق السُّدِّيّ، عن مرة الهمداني-= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٣٢٥٦<span class="dash">-</span></span> و<span class="name-1">عبد الله بن عباس</span> -من طريق السُّدِّيّ، عن أبي مالك وأبي صالح- قالوا: كان سليمان يَتَجَرَّدُ في بيت المقدس السنة والسنتين، والشهر والشهرين، وأقل من ذلك وأكثر، يُدخل طعامه وشرابه، فدخله في المرة التي مات فيها، فكان بدء ذلك أنه لم يكن يوم يصبح فيه إلا تنبت في بيت المقدس شجرة، فيأتيها، فيسألها: ما اسمكِ؟ فتقول الشجرة: اسمي كذا وكذا. فيقول لها: لأيِّ شيء نبتِّ{32}؟ فتقول: نبتُّ لكذا وكذا. فيأمر بها فتُقطع، فإن كانت نبتتْ لغرسٍ غرسها، وإن كانت نبتت لدواء، قالت: نبتُ دواء لكذا وكذا. فيجعلها كذلك، حتى نبتت شجرة يقال لها الخروبة، فسألها: ما اسمكِ؟ فقالت له: أنا الخروبة. فقال: لأي شيء نبتِّ؟ قالت: لخراب هذا المسجد. قال سليمان: ما كان الله لِيُخَرِّبه وأنا حي، أنتِ التي على وجهكِ هلاكي وخراب بيت المقدس. فنزعها، وغرسها في حائط له، ثم دخل المحراب، فقام يصلي مُتَّكئًا على عصاه، فمات ولا تعلم به الشياطين في ذلك، وهم يعملون له يخافون أن يخرج فيعاقبهم، وكانت الشياطين تجتمع حول المحراب، وكان المحراب له كُوًى بين يديه وخلفه، وكان الشيطان الذي يريد أن يَخْلَعَ{33} يقول: ألستُ جليدًا{34} إن دخلتُ فخرجتُ من الجانب الآخر. فيدخل حتى يخرج من الجانب الآخر، فدخل شيطان من أولئك فمرَّ، ولم يكن شيطان ينظر إلى سليمان في المحراب إلا احترق، فمرَّ ولم يسمع صوت سليمان ﵇، ثم رجع فلم يسمع، ثم رجع فوقع في البيت فلم يحترق، ونظر إلى سليمان قد سقط، فخرج فأخبر الناس أن سليمان قد مات، ففتحوا عنه، فأخرجوه، ووجدوا منسأته -وهي العصا بلسان الحبشة- قد أكلتها الأرَضَة، ولم يعلموا منذ كم مات، فوضعوا الأرَضَة على العصا، فأكلت منها يوما وليلة، ثم حسبوا على ذلك النحو، فوجدوه قد مات منذ سنة، وهي في قراءة ابن مسعود: (فَمَكَثُوا يَدْأَبُونَ لَهُ مِن بَعْدِ مَوْتِهِ حَوْلًا كامِلًا). فأيقن الناس عند ذلك أن الجن كانوا يكذِبونهم، ولو أنهم علموا الغيب لعلموا بموت سليمان، ولم يلبثوا في العذاب سنةً يعملون له، وذلك قول الله: <span class="qpc-hafs">﴿ما دَلَّهُمْ عَلى مَوْتِهِ إلّا دابَّةُ الأَرْضِ تَأْكُلُ مِنسَأَتَهُ فَلَمّا خَرَّ تَبَيَّنَتِ الجِنُّ أنْ لَوْ كانُوا يَعْلَمُونَ الغَيْبَ ما لَبِثُوا فِي العَذابِ المُهِينِ﴾</span> يقول: تبيّن أمرهم للناس أنهم كانوا يكذِبونهم، ثم إن الشياطين قالوا للأرضة: لو كنتِ تأكلين الطعام أتيناكِ بأطيب الطعام، ولو كنتِ تشربين الشراب سقيناكِ أطيب الشراب، ولكنا سننقل إليك الماء والطين. فالذي يكون في جوف الخشب فهو ما تأتيها به الشياطينُ شكرًا لها{35}<span class=comment-ref>٥٣٠٥</span>. (١٢/١٧٩)</p></p><p></div></p><p><div><span class=comment-ref>٥٣٠٥</span> <span class="comment-type-4">علّق</span> <u>ابنُ كثير</u> (١١٦/٢٦٩) على هذا الأثر فقال: «وهذا الأثر -والله أعلم-إنّما هو مما تلقي من علماء أهل الكتاب، وهي وقف، لا يصدق منها إلا ما وافق الحق، ولا يكذب منها إلا ما خالف الحق، والباقي لا يصدق ولا يكذب».</div></p><p><div></p><p><p><span class="item-no">٦٣٢٥٧<span class="dash">-</span></span> عن <span class="name-2">عبد الله بن شداد</span> -من طريق خالد بن حصين- قال: قيل لسليمان -صلى الله عليه-: إنّ آية موتك أن ينبت في بيت المقدس شجرةٌ يُقال لها: الخروبة، فإذا نبتَ فهو آيةُ موتِك، فبينا هو كذلك إذ خرجت شجرة، فقال لها: ما اسمكِ؟ قالت: أنا الخروبة. فدخل المحراب، فقام على عصاه، فقُبض وهو على عصاه، فخرجت دابة من الأرض، فأكلت عصاه، فخَرَّ، فـ<span class="qpc-hafs">﴿تبينت الجن أن لو كانوا يعلمون الغيب ما لبثوا في العذاب المهين﴾</span>{36}<span class=comment-ref>٥٣٠٦</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٥٣٠٦</span> نقل <u>ابنُ عطية</u> (٧/١٧١) إضافة إلى ما ورد في آثار السلف في قصة موت سليمان ﵇ <b>قولًا</b> آخر، فقال: «وقال بعض الناس: إن سليمان ﵇ لم يمت إلا في سفر مضطجعًا، ولكنه كان في بيت مبني عليه، وأكلت الأرَضَة عتبة الباب حتى خرَّ البيت؛ فعُلم موته». و<span class="comment-type-2">انتقده</span> بقوله: «وهذا ضعيف». ثمَّ قال <u>ابن عطية</u> عقب هذا: «وأكثرَ المفسرون في قصص هذه الآية بما لا صحة له، ولا تقتضيه ألفاظ القرآن، وفي معانيه بُعْدٌ، فاختصرته لذلك».</div></p><p><div></p><p><p><span class="item-no">٦٣٢٥٨<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span> -من طريق أيوب- قال: لَمّا ردّ الله الخاتم إليه لم يُصَلِّ صلاة الصبح يومًا إلا نظر وراءَه، فإذا هو بشجرة خضراء تهتز، فيقول: يا شجرة، أما يأكلك جِنٌّ ولا إنس ولا طير ولا هوام ولا بهائم؟ فتقول: إنِّي لم أُجعل رزقًا لشيء، ولكن دواء مِن كذا، ودواء من كذا. فقام الجن والإنس يقطعونها، ويجعلونها في الدواء، فصلى الصبح ذات يوم والتفت، فإذا بشجرة وراءه، قال: مَن أنتِ، يا شجرة؟ قالت: أنا الخرنوبة. قال: واللهِ، ما الخرنوبة إلا خراب بيت المقدس، واللهِ ما يُخرّب ما كنت حيًّا، ولكني أموت. فدعا بحنوط، فتحنّط وتكفَّن، ثم جلس على كرسيه، ثم جمع كفيه على طرف عصاه، ثم جعلها تحت ذقنه، ومات، فمكث الجن يعملون سنة يحسبون أنه حي، وكانت لا ترفع أبصارها إليه، وبعث الله الأرَضَة، فأكلت طرف العصا، فخَرَّ مُنكَبًّا على وجهه، فعلمتُ الجنُّ أن قد مات، فذلك قوله: <span class="qpc-hafs">﴿تَبَيَّنَتِ الجِنُّ﴾</span> ولقد كانت الجن تعلم أنها لا تعلم الغيب، ولكن في القراءة الأولى: (تَبَيَّنَتِ الإنسُ أن لَّوْ كانَ الجِنُّ يَعْلَمُونَ الغَيْبَ ما لَبِثُوا فِي العَذابِ المُهِينِ){37}<span class=comment-ref>٥٣٠٧</span>. (١٢/١٨٤)</p></p><p></div></p><p><div><span class=comment-ref>٥٣٠٧</span> <span class="comment-type-4">قال</span> <u>ابنُ عطية</u> (٧/١٧١-١٧٢): «وقرأ الجمهور <span class="qpc-hafs">﴿تَبَيَّنَتِ الجِنُّ﴾</span> بإسناد الفعل إليها، أي: بان أمرُها، كأنه قال: افتضحت الجنُّ، أي: للإنس، هذا تأويل. و<b>يحتمل</b> أن يكون قوله: <span class="qpc-hafs">﴿تَبَيَّنَتِ الجِنُّ﴾</span> بمعنى: علمت الجن وتحققت، ويريد بالجِنّ: جمهورهم والفَعَلة منهم والخَدَمة، ويريد بالضمير في <span class="qpc-hafs">﴿كانُوا﴾</span>: رؤساءهم وكبارهم؛ لأنهم هم الذين يدعون علم الغيب لأتباعهم من الجن والإنس ويوهمونهم ذلك. قاله قتادة، فتبين الأتباع أن الرؤوس لَوْ كانُوا عالمين الغيب ما لَبِثُوا، و<span class="qpc-hafs">﴿أنْ﴾</span> على التأويل الأول بدل من <span class="qpc-hafs">﴿الجِنُّ﴾</span>، وعلى التأويل الثاني مفعولة محضة، وقرأ يعقوب: (تُبُيِّنَتُ الجِنُّ) على بناء الفعل للمفعول، أي: تبينها الناس، و<span class="qpc-hafs">﴿أنْ﴾</span> على هذه القراءة بدل، ويجوز أن تكون في موضع نصب بإسقاط حرف الجر، أي: بأن، على هذه القراءة، وعلى التأويل الأول من القراءة الأولى».</div></p></div>",footnotes:1:عزاه السيوطي إلى سعيد بن منصور، وعبد بن حميد، وابن المنذر، وابن أبي حاتم.</p><p>وهي قراءة شاذة. انظر: فتح القدير ٤/٤٢١.|2:أخرجه ابن جرير ١٩/٢٤١-٢٤٢.</p><p>وهي قراءة شاذة. انظر: الكشف والبيان ٨/٨١.|3:عزاه السيوطي إلى عبد بن حميد.</p><p>وهي قراءة شاذة. انظر: الجامع لأحكام القرآن ١٧/٢٨٥.|4:أخرجه البزار (٢٣٥٥- كشف)، وابن جرير ١٩/٢٤٠ بنحوه، وابن أبي حاتم -كما في تفسير ابن كثير ٦/٤٩٠-، والطبراني (١٢٢٨١). وعزاه السيوطي إلى ابن السني في الطب النبوي، وابن المنذر، وابن مردويه.</p><p>وهي قراءة شاذة.|5:عزاه السيوطي إلى سعيد بن منصور، وعبد بن حميد، وابن المنذر، وابن أبي حاتم.</p><p>وهي قراءة شاذة.|6:عزاه السيوطي إلى عبد بن حميد.|7:أخرجه ابن جرير ١٩/٢٤٣.|8:علقه يحيى بن سلام ٢/٧٥١.|9:تفسير مقاتل بن سليمان ٣/٥٢٧.|10:أخرجه ابن جرير ١٩/٢٣٧، وبنحوه من طريق العوفي، وابن أبي حاتم -كما في التغليق ٤/٣١-. وعزاه السيوطي إلى ابن المنذر.|11:تفسير مجاهد (٥٥٣)، وأخرجه ابن جرير ١٩/٢٣٧. وعلَّقه يحيى بن سلام ٢/٧٥١ من طريق عاصم بن حكيم. وعزاه السيوطي إلى عبد بن حميد، والفريابي.|12:عزاه السيوطي إلى عبد بن حميد.|13:تفسير مقاتل بن سليمان ٣/٥٢٧-٥٢٨.|14:أخرجه إسحاق البستي ص١٥٠.</p><p>وكلاهما قراءة متواترة، فوافقها على ترك الهمز نافع، وأبو جعفر، ووافقه على الهمز بقية العشرة، إلا أنه اختلف فيه عن هشام فله الوجهان. انظر: النشر ٢/٣٤٩-٣٥٠، والإتحاف ص٤٥٨.|15:أخرجه ابن جرير ١٩/٢٣٧، وبنحوه من طريق العوفي، وابن أبي حاتم -كما في التغليق ٤/٣١-. وعزاه السيوطي إلى ابن المنذر.|16:تقدم في قراءات الآية.|17:تقدم في قراءات الآية.|18:عزاه السيوطي إلى عبد بن حميد، وابن المنذر.|19:عزاه السيوطي إلى عبد بن حميد.|20:تفسير مجاهد (٥٥٣)، وأخرجه ابن جرير ١٩/٢٣٧، ومن طريق أبي يحيى ١٩/٢٣٨. وعلَّقه يحيى بن سلام ٢/٧٥١ من طريق عاصم بن حكيم. وعزاه السيوطي إلى عبد بن حميد، والفريابي.|21:عزاه السيوطي إلى عبد بن حميد، وابن المنذر.|22:أخرجه ابن جرير ١٩/٢٣٨، وعبد الرزاق ٢/١٢٨ من طريق معمر مختصرًا. وعزاه السيوطي إلى عبد بن حميد.|23:أخرجه ابن جرير ١٩/٢٤٢، وعبد الرزاق ٢/١٢٨ مختصرًا من طريق معمر. وعزاه السيوطي إلى عبد بن حميد. كما أخرجه ابن أبي حاتم ٩/٢٩١٣ مطولًا وفي آخره: وهي في مصحف ابن مسعود: (تَبَيَّنَتِ الإنسُ والجِنُّ لَوْ كانُوا يَعْلَمُونَ الغَيْبَ ما لَبِثُوا فِي العَذابِ المُهِينِ)، وكانت الجن تقول قبل ذلك أنها تعلم الغيب، وتعلم ما في غد، فابتلاهم الله بذلك، وجعل موت سليمان للجن عِظَةً.|24:أخرجه ابن جرير ١٩/٢٣٨.|25:أخرجه أبو جعفر الرملي في جزئه ص٨٩ (تفسير عطاء الخراساني).|26:تفسير مقاتل بن سليمان ٣/٥٢٧-٥٢٨.|27:أخرجه ابن جرير ١٩/٢٣٨.|28:أخرجه ابن جرير ١٩/٢٤٣. وعزاه السيوطي إلى ابن أبي حاتم.|29:تفسير يحيى بن سلام ٢/٧٥١-٧٥٢.|30:أخرجه الحاكم ٤/٢١٩ (٧٤٢٨)، ٤/٤٤٦ (٨٢٢٢)، وابن جرير ١٩/٢٤٠.</p><p>قال الحاكم: «هذا حديث صحيح الإسناد، ولم يخرجاه». وقال ابن كثير في تفسيره ٦/٥٠٢: «حديث مرفوع غريب، وفي صحّته نظر ... وفي رفعه غرابة ونكارة، والأقرب أن يكون موقوفًا، وعطاء بن أبي مسلم الخراساني له غرابات، وفي بعض حديثه نكارة». وقال الألباني في الضعيفة ١٤/١١٦٧ (٦٥٧٣): «ضعيف».|31:أخرجه البزار (٢٣٥٦- كشف)، والحاكم ٤/١٩٧-١٩٨.|32:هكذا في المصادر.|33:أي يخرجُ عن الطّاعة. النهاية (خلع).|34:الجليد: القوي الصُلب. اللسان (جلد).|35:أخرجه ابن جرير ١٩/٢٤١-٢٤٢. وعزاه السيوطي إلى ابن أبي حاتم موقوفًا على السُّدِّيّ من قوله.|36:أخرجه محمد بن نصر في تعظيم قدر الصلاة ١/٢٢٥.|37:أخرجه عبد الرزاق ٢/١٢٨. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.