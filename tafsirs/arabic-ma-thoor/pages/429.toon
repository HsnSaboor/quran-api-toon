tafsir[7]{c,v,t}:
34,8," <q>﴿أَفۡتَرَىٰ عَلَى ٱللَّهِ كَذِبًا أَم بِهِۦ جِنَّةُۢۗ﴾</q> - تفسير ٦٣٠٧٠- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿أفْتَرى عَلى اللَّهِ كَذِبًا أمْ بِهِ جِنَّةٌ﴾</q>، قال: قالوا: إمّا أن يكون يكذب على الله، وإمّا أن يكون مجنونًا{1}. (١٢/١٦٥) ٦٣٠٧١- قال مقاتل بن سليمان: ثم قال أبو سفيان: <q>﴿أفْتَرى﴾</q> محمد ﷺ <q>﴿عَلى اللَّهِ كَذِبًا﴾</q> حين يزعم أنّا نُبعث بعد الموت؟ <q>﴿أمْ بِهِ جِنَّةٌ﴾</q> يقول: أم بمحمد جنون؟{2}. (ز) ٦٣٠٧٢- قال يحيى بن سلّام: <q>﴿أفْتَرى عَلى اللَّهِ كَذِبًا أمْ بِهِ جِنَّةٌ﴾</q> أي: جنون{3}. (ز) <q>﴿بَلِ ٱلَّذِینَ لَا یُؤۡمِنُونَ بِٱلۡـَٔاخِرَةِ فِی ٱلۡعَذَابِ وَٱلضَّلَـٰلِ ٱلۡبَعِیدِ ۝٨﴾</q> - تفسير ٦٣٠٧٣- قال إسماعيل السُّدِّيّ: <q>﴿فِي العَذابِ والضَّلالِ البَعِيدِ﴾</q>، يعني: الشقاء الطويل{4}. (ز) ٦٣٠٧٤- قال مقاتل بن سليمان: فرد الله -جلَّ وعزَّ- عليهم، فقال: <q>﴿بَلِ الَّذِينَ لا يُؤْمِنُونَ بِالآخِرَةِ﴾</q> لا يصدقون بالبعث الذي فيه جزاء الأعمال هم أكذب وأشد فرية من محمد ﷺ حين كذَّبوا بالبعث. ثم قال جل وعز: هم <q>﴿فِي العَذابِ﴾</q> في الآخرة، <q>﴿والضَّلالِ البَعِيدِ﴾</q> الشقاء الطويل. نظيرها في آخر «اقتربت الساعة»{5}{2}. (ز) ٦٣٠٧٥- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب-: ثم قال بعضهم لبعض: <q>﴿أفْتَرى عَلى اللَّهِ كَذِبًا أمْ بِهِ جِنَّةٌ﴾</q> الرجل مجنون فيتكلم بما لا يعقل؟ فقال الله: <q>﴿بَلِ الَّذِينَ لا يُؤْمِنُونَ بِالآخِرَةِ فِي العَذابِ والضَّلالِ البَعِيدِ﴾</q> وأمره أن يحلف لهم ليعتبروا. وقرأ: <q>﴿قُلْ بَلى ورَبِّي لَتُبْعَثُنَّ ثُمَّ لَتُنَبَّؤُنَّ بِما عَمِلْتُمْ﴾</q> [التغابن:٧]{7}. (ز) ٦٣٠٧٦- قال يحيى بن سلّام: <q>﴿بَلِ الَّذِينَ لا يُؤْمِنُونَ بِالآخِرَةِ فِي العَذابِ﴾</q> في الآخرة، <q>﴿والضَّلالِ البَعِيدِ﴾</q> في الدنيا، الذي لا يصيبون به خيرًا في الدنيا ولا الآخرة. وقال بعضهم: البعيد من الهُدى{3}٥٢٩١. (ز) ٥٢٩١ أورد ابنُ عطية (٧/١٥٩) في قوله تعالى: <q>﴿في العذاب﴾</q> احتمالين، فقال: «<q>﴿فِي العَذابِ﴾</q> يريد: عذاب الآخرة؛ لأنهم يصيرون إليه. ويحتمل أن يريد: في العذاب في الدنيا بمكابدة الشرع ومكايدته، ومحاولة إطفاء نور الله تعالى، وهو يتم، وهذا كله عذاب». ",footnotes:1:أخرجه ابن جرير ١٩/٢١٦. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.تفسير مقاتل بن سليمان ٣/٥٢٤-٥٢٥.تفسير يحيى بن سلام ٢/٧٤٦.علقه يحيى بن سلام ٢/٧٤٧.يشير إلى الآيات: <q>﴿كَذَّبُوا بِآياتِنا كُلِّها فَأَخَذْناهُمْ أخْذَ عَزِيزٍ مُقْتَدِرٍ أكُفّارُكُمْ خَيْرٌ مِن أُولئِكُمْ أمْ لَكُمْ بَراءَةٌ فِي الزُّبُرِ، أمْ يَقُولُونَ نَحْنُ جَمِيعٌ مُنْتَصِرٌ، سَيُهْزَمُ الجَمْعُ ويُوَلُّونَ الدُّبُرَ، بَلِ السّاعَةُ مَوْعِدُهُمْ والسّاعَةُ أدْهى وأَمَرُّ، إنَّ المُجْرِمِينَ فِي ضَلالٍ وسُعُرٍ يَوْمَ يُسْحَبُونَ فِي النّارِ عَلى وُجُوهِهِمْ ذُوقُوا مَسَّ سَقَرَ﴾</q> [القمر:٤٢-٤٨].تفسير مقاتل بن سليمان ٣/٥٢٤-٥٢٥.أخرجه ابن جرير ١٩/٢١٦-٢١٧.تفسير يحيى بن سلام ٢/٧٤٦.
34,9," <q>﴿أَفَلَمۡ یَرَوۡا۟ إِلَىٰ مَا بَیۡنَ أَیۡدِیهِمۡ وَمَا خَلۡفَهُم مِّنَ ٱلسَّمَاۤءِ وَٱلۡأَرۡضِۚ إِن نَّشَأۡ نَخۡسِفۡ بِهِمُ ٱلۡأَرۡضَ أَوۡ نُسۡقِطۡ عَلَیۡهِمۡ كِسَفࣰا مِّنَ ٱلسَّمَاۤءِۚ إِنَّ فِی ذَ ٰ⁠لِكَ لَـَٔایَةࣰ لِّكُلِّ عَبۡدࣲ مُّنِیبࣲ ۝٩﴾</q> - تفسير ٦٣٠٧٧- عن قتادة بن دعامة -من طريق معمر- في قوله: <q>﴿أفَلَمْ يَرَوْا إلى ما بَيْنَ أيْدِيهِمْ وما خَلْفَهُمْ مِنَ السَّماءِ والأَرْضِ﴾</q>، قال: إنّك إن نظرت عن يمينك وعن شمالك ومِن بين يديك ومن خلفك؛ رأيتَ السماءَ والأرضَ{1}. (١٢/١٦٥) ٦٣٠٧٨- قال إسماعيل السُّدِّيّ: <q>﴿إلى ما بَيْنَ أيْدِيهِمْ﴾</q> يعني: أمامهم، <q>﴿وما خَلْفَهُمْ مِنَ السَّماءِ والأَرْضِ﴾</q> وراءهم{2}. (ز) ٦٣٠٧٩- قال مقاتل بن سليمان: ثم خوفهم، فقال -جلَّ وعزَّ-: <q>﴿أفَلَمْ يَرَوْا إلى ما بَيْنَ أيْدِيهِمْ وما خَلْفَهُمْ﴾</q>، ثم بيّن ما هو، فقال جل وعز: <q>﴿مِنَ السَّماءِ والأَرْضِ﴾</q>{3}. (ز) ٦٣٠٨٠- قال يحيى بن سلّام: <q>﴿أفَلَمْ يَرَوْا﴾</q> ينظروا <q>﴿إلى ما بَيْنَ أيْدِيهِمْ﴾</q> يعني: أمامهم، <q>﴿وما خَلْفَهُمْ مِنَ السَّماءِ والأَرْضِ﴾</q> وراءهم، حيثما قام الإنسان فإنّ بين يديه مِن السماء والأرض مثل ما خلفه منها{4}. (ز) <q>﴿إِن نَّشَأۡ نَخۡسِفۡ بِهِمُ ٱلۡأَرۡضَ أَوۡ نُسۡقِطۡ عَلَیۡهِمۡ كِسَفࣰا مِّنَ ٱلسَّمَاۤءِۚ﴾</q> - تفسير ٦٣٠٨١- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿إنْ نَشَأْ نَخْسِفْ بِهِمُ الأَرْضَ﴾</q> كما خسفنا بِمَن كان قبلهم، <q>﴿أوْ نُسْقِطْ عَلَيْهِمْ كِسَفًا مِنَ السَّماءِ﴾</q> أي: قِطَعًا من السماء، إن شاء أن يعذب بسمائه فعل، وان شاء أن يعذب بأرضه فعل، وكل خلقه له جند. قال قتادة: وكان الحسن يقول: إن الزَبَدَ لمن جنودِ الله{5}. (١٢/١٦٥) ٦٣٠٨٢- قال مقاتل بن سليمان: <q>﴿إنْ نَشَأْ نَخْسِفْ بِهِمُ الأَرْضَ﴾</q> فتبتلعهم، <q>﴿أوْ نُسْقِطْ عَلَيْهِمْ كِسَفًا مِنَ السَّماءِ﴾</q> يعني: جانبًا مِن السماء، فنهلكهم بها{3}. (ز) ٦٣٠٨٣- قال يحيى بن سلّام: <q>﴿إنْ نَشَأْ نَخْسِفْ بِهِمُ الأَرْضَ أوْ نُسْقِطْ عَلَيْهِمْ كِسَفًا مِنَ السَّماءِ﴾</q> والكِسفُ: القطعة، والكسف مذكر، والقطعة مؤنثة، والمعنى على القطعة{4}. (ز) <q>﴿إِنَّ فِی ذَ ٰ⁠لِكَ لَـَٔایَةࣰ لِّكُلِّ عَبۡدࣲ مُّنِیبࣲ ۝٩﴾</q> - تفسير ٦٣٠٨٤- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿إنَّ فِي ذَلِكَ لَآيَةً لِكُلِّ عَبْدٍ مُنِيبٍ﴾</q>: تائب مقبل على الله{8}. (١٢/١٦٥) ٦٣٠٨٥- قال مقاتل بن سليمان: <q>﴿إنَّ فِي ذَلِكَ لَآيَةً﴾</q> يعني: عِبرة <q>﴿لِكُلِّ عَبْدٍ مُنِيبٍ﴾</q> مخلص بالتوحيد{3}. (ز) ٦٣٠٨٦- قال يحيى بن سلّام: <q>﴿إنَّ فِي ذَلِكَ لَآيَةً﴾</q> لعبرة <q>﴿لِكُلِّ عَبْدٍ مُنِيبٍ﴾</q> وهو المُقبِل إلى الله بالإخلاص له{4}. (ز) ",footnotes:1:أخرجه عبد الرزاق ٢/١٢٦، وعبد بن حميد من طريقه -كما في تفسير ابن كثير ٦/٤٨٤- وابن جرير ١٩/٢١٨ من طريق سعيد بلفظ: لينظروا عن أيمانهم، وعن شمائلهم، كيف السماء قد أحاطت بهم. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.علقه يحيى بن سلام ٢/٧٤٧.تفسير مقاتل بن سليمان ٣/٥٢٥.تفسير يحيى بن سلام ٢/٧٤٧.أخرجه ابن جرير ١٩/٢١٨ مختصرًا. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.تفسير مقاتل بن سليمان ٣/٥٢٥.تفسير يحيى بن سلام ٢/٧٤٧.أخرجه عبد الرزاق ٢/١٢٦ من طريق معمر بلفظ: تائب، وابن جرير ١٩/٢١٩ بلفظ: المنيب المقبل التائب. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.تفسير مقاتل بن سليمان ٣/٥٢٥.تفسير يحيى بن سلام ٢/٧٤٧.
34,10," <q>﴿وَلَقَدۡ ءَاتَیۡنَا دَاوُۥدَ مِنَّا فَضۡلࣰاۖ یَـٰجِبَالُ أَوِّبِی مَعَهُۥ وَٱلطَّیۡرَۖ وَأَلَنَّا لَهُ ٱلۡحَدِیدَ ۝١٠﴾</q> - قراءات ٦٣٠٨٧- عن عبد الله بن أبي إسحاق أنّه قرأ: <q>﴿والطَّيْرَ﴾</q> نصَب بجملة. قال: سخَّرنا له الطير{1}٥٢٩٢. (١٢/١٦٦) ٥٢٩٢ قال ابن جرير (١٩/٢٢١): «وفي نصب الطير وجهان: أحدهما: على ما قاله ابن زيد مِن أن الطير نُودِيت كما نوديت الجبال، فتكون منصوبة مِن أجل أنها معطوفة على مرفوع بما لا يحسن إعادة رافعه عليه، فيكون كالمصدر عن جهته. والآخر: فعل ضمير متروك استغني بدلالة الكلام عليه، فيكون معنى الكلام: فقلنا: يا جبال، أوبي معه، وسخرنا له الطير. وإن رفع ردًّا على ما في قوله:»سبحي" من ذكر الجبال كان جائزًا، وقد يجوز رفع الطير وهو معطوف على الجبال، وإن لم يحسن نداؤها بالذي نوديت به الجبال، فيكون ذلك كما قال الشاعر: ألا يا عمرو والضحاك سيرا ... فقد جاوزتما خمر الطريق". <q>﴿وَلَقَدۡ ءَاتَیۡنَا دَاوُۥدَ مِنَّا فَضۡلࣰاۖ یَـٰجِبَالُ أَوِّبِی مَعَهُۥ وَٱلطَّیۡرَۖ﴾</q> - تفسير ٦٣٠٨٨- عن عبد الله بن عباس -من طريق سعيد بن جبير- في قوله: <q>﴿أوِّبِي مَعَهُ﴾</q>، قال: سبِّحي معه{2}٥٢٩٣. (١٢/١٦٥) ٥٢٩٣ قال ابنُ عطية (٧/١٦٠-١٦١) معلِّقًا على قول ابن عباس: «<q>﴿وأَوِّبِي﴾</q> معناه: رجِّعي معه؛ لأنه مضاعف آب يؤوب، فقال ابن عباس وقتادة وابن زيد وغيرهم معناه: سبحي معه، أي: يسبح هو وترجع هي معه التسبيح، أي: تردُّ بالذكر، ثم ضوعف الفعل للمبالغة». ٦٣٠٨٩- عن أبي ميسرة [عمرو بن شرحبيل] -من طريق أبي إسحاق- <q>﴿أوِّبِي مَعَهُ﴾</q>، قال: سبِّحي معه. بلسان الحبشة{3}٥٢٩٤. (١٢/١٦٥) ٥٢٩٤ ذكر ابنُ عطية (٧/١٦١) مثل هذا القول عن مؤرج، وعلَّق عليه قائلًا: «وهذا ضعيف غير معروف». وانتقده ابنُ كثير (١١/٢٦٢) مستندًا إلى اللغة بقوله: «وفي هذا نظر؛ فإن التأويب في اللغة هو الترجيع، فأمرت الجبال والطير أن تُرَجِّع معه بأصواتها». ٦٣٠٩٠- عن مجاهد بن جبر -من طريق ابن أبي نجيح- <q>﴿أوِّبِي مَعَهُ﴾</q>، قال: سبِّحي{4}. (١٢/١٦٥) ٦٣٠٩١- عن أبي عبد الرحمن [السلمي] -من طريق أبي حصين-= (ز) ٦٣٠٩٢- وعكرمة، مثله{5}. (١٢/١٦٥) ٦٣٠٩٣- عن الضحاك بن مزاحم -من طريق عبيد، وجُوَيْبِر- في قوله: <q>﴿يا جِبالُ أوِّبِي مَعَهُ﴾</q>، قال: سبِّحي{6}. (ز) ٦٣٠٩٤- قال وهب بن مُنَبِّه: <q>﴿أوِّبِي مَعَهُ﴾</q> نُوحِي معه{7}. (ز) ٦٣٠٩٥- عن وهب بن مُنَبِّه -من طريق ابن إسحاق، عن بعض أهل العلم- قال: <q>﴿يا جِبالُ أوِّبِي مَعَهُ والطَّيْرَ وأَلَنّا لَهُ الحَدِيدَ﴾</q>، أمر الله الجبال والطير أن تسبِّح مع داود إذا سبَّح، وعلَّمه صنعة الحديد وألانه، وأنزل عليه الزبور، فكان إذا قرأ الزبور ترنا{8} له الوحوش حتى يؤخذ بأعناقها، وإنها لمُصِيخة{9} تسمع لصوته{10}. (١٢/١٦٦) ٦٣٠٩٦- عن قتادة بن دعامة -من طريق معمر- <q>﴿يا جِبالُ أوِّبِي مَعَهُ﴾</q>، قال: سبِّحي مع داود إذا سبّح{11}. (١٢/١٦٦) ٦٣٠٩٧- عن محمد بن شهاب الزهري -من طريق مالك بن أنس- <q>﴿أوبي معه﴾</q>، قال: سبِّحي معه{12}. (ز) ٦٣٠٩٨- عن عطاء الخراساني -من طريق يونس بن يزيد- في قوله: <q>﴿يا جبال أوبي معه﴾</q>، قال: سبِّحي معه{13}. (ز) ٦٣٠٩٩- قال مقاتل بن سليمان: <q>﴿ولَقَدْ آتَيْنا داوُودَ﴾</q> أعطينا داود <q>﴿مِنّا فَضْلًا﴾</q> النبوة، كقوله ﷿ للنبي ﷺ في سورة النساء [١١٣]: <q>﴿وكانَ فَضْلُ اللَّهِ عَلَيْكَ عَظِيمًا﴾</q> يعني: النبوة والكتاب، فذلك قوله ﷿: <q>﴿ولَقَدْ آتَيْنا داوُودَ مِنّا فَضْلًا﴾</q> النبوة، والزبور، وما سخر له من الجبل والطير والحديد، ثم بيّن له ما أعطاه، فقال ﷿: <q>﴿يا جِبالُ أوِّبِي مَعَهُ﴾</q> سبِّحي معه؛ مع داود ﵇. يقول: اذكري الربَّ مع داود، وهو التسبيح، وسخّرنا له الطير{14}. (ز) ٦٣١٠٠- عن عبد الملك ابن جريج -من طريق حجاج- <q>﴿ياجبال أوبي معه﴾</q>، يقول: سبِّحي{15}. (ز) ٦٣١٠١- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿يا جِبالُ أوِّبِي مَعَهُ والطَّيْرَ﴾</q>، قال: سبِّحي معه، والطير أيضًا، يعني: يسبّح معه الطير{16}. (١٢/١٦٦) ٦٣١٠٢- قال يحيى بن سلّام: <q>﴿ولَقَدْ آتَيْنا داوُد مِنّا فَضْلا﴾</q> النبوة، <q>﴿يا جِبالُ﴾</q> قلنا: يا جبال، <q>﴿أوِّبِي مَعَهُ﴾</q> سبِّحي معه، <q>﴿والطَّيْرَ﴾</q> وهو قوله: <q>﴿وسَخَّرْنا مَعَ داوُدَ الجِبالَ يُسَبِّحْنَ والطَّيْرَ﴾</q> [الأنبياء:٧٩]{17}٥٢٩٥. (ز) ٥٢٩٥ ذكر ابنُ عطية (٧/١٦١) إضافة إلى ما ورد في آثار السلف في معنى: <q>﴿أوبي﴾</q> قولًا، ووجّهه، فقال: "وقيل: معناه: سيري معه؛ لأن التأويب سير النهار، كأن الإنسان يسير بالليل ثم يرجِّع السير بالنهار، أي: يردده، فكأنه يُؤَوِّبه، فقيل له: التأويب، ومنه قول الشاعر: يومان يوم مقامات وأندية ... ويوم سير إلى الأعداء تأويب". <q>﴿وَأَلَنَّا لَهُ ٱلۡحَدِیدَ ۝١٠﴾</q> - تفسير ٦٣١٠٣- عن عبد الله بن عباس، في قوله: <q>﴿وأَلَنّا لَهُ الحَدِيدَ﴾</q>، قال: كالعجين{18}. (١٢/١٦٧) ٦٣١٠٤- عن الحسن البصري، في قوله: <q>﴿وأَلَنّا لَهُ الحَدِيدَ﴾</q>، قال: كان يأخذ الحديدَ، فيصير في يده مثلَ العجين، فيصنع منه الدروع{19}. (١٢/١٦٧) ٦٣١٠٥- عن قتادة بن دعامة -من طريق معمر- في قوله: <q>﴿وأَلَنّا لَهُ الحَدِيدَ﴾</q>، قال: ليّنه الله له؛ يعمله بغير نار{20}. (١٢/١٦٧) ٦٣١٠٦- عن قتادة بن دعامة -من طريق سعيد بن بشير- في قوله: <q>﴿وأَلَنّا لَهُ الحَدِيدَ﴾</q>، قال: سخَّر الله له الحديد، فكان يسرده حِلَقًا بيده، يعمل به كما يعمل بالطين، مِن غير أن يُدخله النار، ولا يضربه بمطرقة{21}. (١٢/١٦٧) ٦٣١٠٧- قال مقاتل بن سليمان: <q>﴿وأَلَنّا لَهُ الحَدِيدَ﴾</q>، فكان داود ﵇ يضفر الحديد ضفر العجين من غير نار، فيتخذها دروعًا طِوالًا{14}. (ز) ٦٣١٠٨- قال يحيى بن سلّام: <q>﴿وأَلَنّا لَهُ الحَدِيدَ﴾</q> ألانه الله له، فكان يعمله بلا نار ولا مطرقة، بأصابعه الثلاث، كهيئة الطين بيده{17}. (ز) ",footnotes:1:عزاه السيوطي إلى ابن أبي حاتم. وهي قراءة العشرة.أخرجه ابن أبي شيبة في المصنف ١١/٥٥٩، وابن جرير ١٩/٢٢٠ من طريق سعيد والعوفي. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.أخرجه ابن جرير ١٩/٢٢٠.تفسير مجاهد (٥٥٣)، وأخرجه يحيى بن سلام ٢/٧٤٧ من طريق أبي يحيى، والفريابي -كما في التغليق ٤/٢٩-، وابن جرير ١٩/٢٢٠-٢٢١ من طريق ابن أبي نجيح ومنصور. وعزاه السيوطي إلى عبد بن حميد.أخرجه ابن أبي شيبة في مصنفه (ت: محمد عوامة) ١٦/٥٦٥ (٣٢٥٦٠)، وابن جرير ١٩/٢٢٠ كلاهما عن أبي عبد الرحمن وحده. وعزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ١٩/٢٢١. وزاد ابن حجر في الفتح ٦/٤٥٤ عن الضحاك: «هو بلسان الحبشة»، ولم يعزه.تفسير الثعلبي ٨/٧١، وتفسير البغوي ٦/٣٨٧.قال محققو الدر: كذا في النسخ... وفي مصدر التخريج: «تدنو»، ولعل «ترنا»من الرنو، أي: إدامة النظر. اللسان (رنو).مصيخة: مستمعة منصتة. اللسان (صيخ).أخرجه أبو الشيخ في العظمة (١١٦٦).أخرجه عبد الرزاق ٢/١٢٧، وابن جرير ١٩/٢٢١ من طريق سعيد. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم. وذكر ابن حجر في الفتح ٦/٤٥٤ عن قتادة: معنى <q>﴿أوبي﴾</q>: سيري. ولم يعزه.أخرجه ابن عساكر في تاريخ دمشق ١٧/٩٣.أخرجه أبو جعفر الرملي في جزئه ص٨٩ (تفسير عطاء الخراساني).تفسير مقاتل بن سليمان ٣/٥٢٥-٥٢٦.أخرجه إسحاق البستي ص١٤٥.أخرجه ابن جرير ١٩/٢٢١ بدون لفظ: يعني: يسبح معه الطير. وعزاه السيوطي إلى ابن أبي حاتم.تفسير يحيى بن سلام ٢/٧٤٧.عزاه السيوطي إلى ابن المنذر.عزاه السيوطي إلى ابن أبي حاتم.أخرجه عبد الرزاق ٢/١٢٧. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه ابن جرير ١٢/٢٢٢-٢٢٣ بنحوه، كما أخرجه مختصرًا من طريق سعيد بن أبي عروبة. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.تفسير مقاتل بن سليمان ٣/٥٢٥-٥٢٦.تفسير يحيى بن سلام ٢/٧٤٧.
34,11," <q>﴿أَنِ ٱعۡمَلۡ سَـٰبِغَـٰتࣲ﴾</q> - تفسير ٦٣١٠٩- عن الضحاك بن مزاحم -من طريق جويبر- <q>﴿أن اعمل سابغات﴾</q>، قال: الدرع{1}. (ز) ٦٣١١٠- عن قتادة بن دعامة -من طريق سعيد- <q>﴿أنِ اعْمَلْ سابِغاتٍ﴾</q>: دروع، وكان داود أوَّل مَن صنعها، وإنما كانت قبل ذلك صفائحَ مِن حديد، يجتنُّون{2} بها مِن عدوهم{3}. (١٢/١٦٧) ٦٣١١١- عن قتادة بن دعامة -من طريق معمر- في قوله: <q>﴿أنِ اعْمَلْ سابِغاتٍ﴾</q>، قال: دروع سابغات{4}. (١٢/١٦٧) ٦٣١١٢- قال مقاتل بن سليمان: <q>﴿أنِ اعْمَلْ سابِغاتٍ﴾</q> الدروع الطوال، وكانت الدُّروع قبل داود إنّما هي صفائح الحديد مضروبة، فكان داود ﵇ يَشُدُّ الدروعَ بمسامير، ما يقرعها بحديد، ولا يدخلها النار، فيقرع مِن الدروع في بعض النهار وبعض الليل بيده ثمنَ ألف درهم{5}. (ز) ٦٣١١٣- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿أنِ اعْمَلْ سابِغاتٍ﴾</q>، قال: السابغات: دروع الحديد{6}. (ز) <q>﴿وَقَدِّرۡ فِی ٱلسَّرۡدِۖ وَٱعۡمَلُوا۟ صَـٰلِحًاۖ إِنِّی بِمَا تَعۡمَلُونَ بَصِیرࣱ ۝١١﴾</q> - تفسير ٦٣١١٤- عن عبد الله بن عباس -من طريق مجاهد- في قوله: <q>﴿وقَدِّرْ فِي السَّرْدِ﴾</q>، قال: لا تُدِقّ المسامير وتوسِّع الحِلق فتسْلس{7}، ولا تغلِّظ المسامير وتُضيِّق الحِلق فتنقصم، واجعله قدرًا{8}. (١٢/١٦٨) ٦٣١١٥- عن عبد الله بن عباس -من طريق علي- في قوله: <q>﴿وقَدِّرْ فِي السَّرْدِ﴾</q>، قال: حِلَق الحديد{9}. (١٢/١٦٨) ٦٣١١٦- عن عبد الله بن عباس -من طريق عطية العوفي-: <q>﴿وقَدِّرْ فِي السَّرْدِ﴾</q> يعني بالسرد: ثقْب الدروع حين يشُدُّ قَتيرَها{10}، وعنى بقوله: <q>﴿وقَدِّرْ فِي السَّرْدِ﴾</q>: قدِّر المسامير{11}. (ز) ٦٣١١٧- عن مجاهد بن جبر -من طريق ابن أبي نجيح- <q>﴿وقَدِّرْ فِي السَّرْدِ﴾</q>، قال: قدِّر المسامير والحِلق؛ لا تُدق المسمار فتسْلَس، ولا تُجلّها فتُقْصَم{12}. (١٢/١٦٨) ٦٣١١٨- عن الحكم [بن عتيبة] -من طريق عيينة- <q>﴿وقَدِّرْ فِي السَّرْدِ﴾</q>، قال: لا تغلِّظ المسمار فيفصم الحلقة، ولا تدقّه فيقلق{13}. (ز) ٦٣١١٩- عن قتادة بن دعامة -من طريق معمر- في قوله: <q>﴿وقَدِّرْ فِي السَّرْدِ﴾</q>، قال: السرد: هي المسامير التي في حِلق الدرع{14}. (١٢/١٦٨) ٦٣١٢٠- عن قتادة بن دعامة -من طريق سعيد- <q>﴿وقَدِّرْ فِي السَّرْدِ﴾</q>، قال: كان يجعلها بغير نار، ولا يقرعها بحديد، ثم يسردها. والسرد: المسامير التي في الحِلق{6}. (ز) ٦٣١٢١- عن قتادة بن دعامة -من طريق خالد بن قيس- <q>﴿وقَدِّرْ فِي السَّرْدِ﴾</q>، قال: كانت صفائح، فأمر أن يَسْرُدَها حِلَقًا{16}. (ز) ٦٣١٢٢- قال مقاتل بن سليمان: <q>﴿وقَدِّرْ فِي السَّرْدِ﴾</q> يقول: قدِّر المسامير في الحِلَق، ولا تعظم المسامير فتنقصم، ولا تضفر{17} المسامير فتسلس، <q>﴿واعْمَلُوا صالِحًا﴾</q> يعني: قولوا: الحمد لله، <q>﴿إنِّي بِما تَعْمَلُونَ بَصِيرٌ﴾</q>{5}. (ز) ٦٣١٢٣- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿وقَدِّرْ فِي السَّرْدِ﴾</q>، قال: السرد: حلقة، أي: قدِّر تلك الحِلَق. قال: وقال الشاعر: أجاد المُسدِّي سَرْدَها وأذالها قال: يقول: وسَّعها، وأجاد حلَقها{6}. (ز) ٦٣١٢٤- قال يحيى بن سلّام: <q>﴿أنِ اعْمَلْ سابِغاتٍ﴾</q> وهي الدروع. وبلغنا: أنّ لقمان حضر داود عند أول درع عملها، فجعل يتفكَّر فيما يريد بها، ولا يدري ما يريد بها، فلم يسأله حتى إذا فرغ منها داود قام فلبسها، فقال لقمان: الصمت حكمة، وقليلٌ فاعِلُه{20}٥٢٩٦. (ز) ٥٢٩٦ اختلف السلف في تفسير قوله: <q>﴿وقدر في السرد﴾</q> على أقوال: الأول: أن السرد: هو مسمار حلق الدرع. الثاني: أنه الحلق بعينها. وقد رجَّح ابنُ جرير (١٩/٢٢٤-٢٢٦) القول الأول مستندًا إلى أقوال السلف، فقال: «وعنى بقوله: <q>﴿وقدر في السرد﴾</q>» وقدر المسامير في حلق الدروع حتى يكون بمقدار؛ لا تغلظ المسمار وتضيق الحلقة فتفصم الحلقة، ولا توسع الحلقة وتصغر المسامير وتدقها فتسلس في الحلقة. وبنحو الذي قلنا في ذلك قال أهل التأويل". <q>﴿وَقَدِّرۡ فِی ٱلسَّرۡدِۖ وَٱعۡمَلُوا۟ صَـٰلِحًاۖ إِنِّی بِمَا تَعۡمَلُونَ بَصِیرࣱ ۝١١﴾</q> - آثار متعلقة بالآية ٦٣١٢٥- عن ابن شوذب، قال: كان داود يرفع في كل يوم دِرْعًا، فيبيعها بستة آلاف درهم، ألفين له ولأهله، وأربعة آلاف يُطعم بها بني إسرائيل الخبز الحُوّاري{21}{22}. (١٢/١٦٨) ",footnotes:1:أخرجه الحربي في غريب الحديث ٢/٤٠٧.يجتنون: يتحصنون. اللسان (جنن).أخرجه ابن جرير ١٢/٢٢٣ بنحوه. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه عبد الرزاق ٢/١٢٧. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.تفسير مقاتل بن سليمان ٣/٥٢٦.أخرجه ابن جرير ١٩/٢٢٣.تسلس: كل شيء قلق فهو سلس. اللسان (سلس). والمعنى: فتقلق المسامير وتتحرك.أخرجه عبد الرزاق ٢/١٢٧، والحاكم ٢/٤٢٣.أخرجه ابن جرير ١٩/٢٢٤. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.القَتِير: رؤوس مسامِير حلَق الدروع. اللسان (قتر).أخرجه ابن جرير ١٩/٢٢٥.تفسير مجاهد (٥٥٣)، وأخرجه ابن جرير ١٩/٢٢٥. وعلَّقه يحيى بن سلام ٢/٧٤٨. وعزاه السيوطي إلى الفريابي -ينظر: التغليق ٤/٢٩-، وعبد بن حميد. وذكر ابن جرير روايتين في كلمة (تقصم) بالفاء والقاف. وأخرج عن مجاهد ١٩/٢٢٦ من طريق ابن جريج بلفظ: لا تصغر المسمار، وتعظم الحلقة فتسلس، ولا تعظم المسمار وتصغر الحلقة فيفصم المسمار.أخرجه ابن جرير ١٩/٢٢٦.أخرجه عبد الرزاق ٢/١٢٧. وعزاه السيوطي إلى عبد بن حميد، وابن أبي حاتم.أخرجه ابن جرير ١٩/٢٢٣.أخرجه ابن جرير ١٩/٢٢٤.كذا في مطبوعة المصدر.تفسير مقاتل بن سليمان ٣/٥٢٦.أخرجه ابن جرير ١٩/٢٢٣.تفسير يحيى بن سلام ٢/٧٤٨.الحُوّاري: الدقيق الأبيض، وهو لباب الدقيق وأجوده. اللسان (حور).أخرجه الحكيم الترمذي في نوادر الأصول ١/٣٧٤، وابن أبي حاتم -كما في تفسير ابن كثير ٦/٤٨٥-.
34,12," <q>﴿وَلِسُلَیۡمَـٰنَ ٱلرِّیحَ غُدُوُّهَا شَهۡرࣱ وَرَوَاحُهَا شَهۡرࣱۖ﴾</q> - قراءات ٦٣١٢٦- عن عاصم أنّه قرأ: ‹ولِسُلَيْمانَ الرِّيحُ› برفع الحاء{1}٥٢٩٧. (١٢/١٦٩) ٥٢٩٧ ذكر ابنُ جرير (١٩/٢٢٦) هذه القراءة وقراءة النصب في <q>﴿الريح﴾</q>، ورجّحها مستندًا إلى إجماع الحجة من القراء. وعلّق ابنُ عطية (٧/١٦٤) على هذه القراءة، فقال: «وقرأ عاصم في رواية أبي بكر والأعرج <q>﴿الريحُ﴾</q> بالرفع على تقدير: تسخرت الريح، أو على الابتداء، والخبر في المجرور، وذلك على حذف مضاف تقديره: ولسليمان تسخير الريح». <q>﴿وَلِسُلَیۡمَـٰنَ ٱلرِّیحَ غُدُوُّهَا شَهۡرࣱ وَرَوَاحُهَا شَهۡرࣱۖ﴾</q> - تفسير الآية ٦٣١٢٧- عن سعيد بن المسيب، قال: <q>﴿ولِسُلَيْمانَ الرِّيحَ غُدُوُّها شَهْرٌ ورَواحُها شَهْرٌ﴾</q> كان سليمان ﵇ يركب الريح من إصطخر{2}، فيتَغَدّى ببيت المقدس، ثم يعود فيتعشى بإصطخر{3}. (١٢/١٧٠) ٦٣١٢٨- عن مجاهد بن جبر، قال: <q>﴿ولِسُلَيْمانَ الرِّيحَ غُدُوُّها شَهْرٌ ورَواحُها شَهْرٌ﴾</q> الريح مسيرها شهران في يوم{4}. (١٢/١٦٩) ٦٣١٢٩- عن الحسن البصري، قال: <q>﴿ولِسُلَيْمانَ الرِّيحَ غُدُوُّها شَهْرٌ ورَواحُها شَهْرٌ﴾</q> إنّ سليمان ﵇ لَمّا شغلته الخيل حتى فاتته صلاة العصر؛ غضب لله، فعقر الخيل، فأبدله الله مكانها خيرًا منها وأسرع؛ الريح تجري بأمره كيف شاء، فكان غدوّها شهرًا ورواحها شهرًا، وكان يغدو من إيلياء فيقيل بقُرَير{5}، ويروح من قرير فيبيت بكابل{6}. (١٢/١٦٩) ٦٣١٣٠- عن الحسن البصري، في قوله: <q>﴿غُدُوُّها شَهْرٌ ورَواحُها شَهْرٌ﴾</q>، قال: كان سليمان يغدو من بيت المقدس فيقيل بإصطخر، ثم يروح من إصطخر فيبيت بقلعة خراسان{7}. (١٢/١٧٠) ٦٣١٣١- عن الحسن البصري -من طريق عمرو بن عبيد- قال: <q>﴿غُدُوُّها شَهْرٌ ورَواحُها شَهْرٌ﴾</q> كان سليمان إذا أراد أن يركب جاءت الريحُ، فوضع سرير مملكته عليها، ووُضعت الكراسي والمجالس على الريح، وجلس على سريره، وجلس وُجُوهُ أصحابِه على منازلهم في الدِّين عنده من الجن والإنس، والجن يومئذ ظاهرة للإنس، رجال أمثال الإنس إلا إنهم أُدْم، يحجُّون جميعًا، ويصلُّون جميعًا، ويعتمرون جميعًا، والطير ترفرف على رأسه ورؤوسهم، والشياطين حرَسه لا يتركون أحدًا يتقدم بين يديه، وهو قوله: <q>﴿وحُشِرَ لِسُلَيْمانَ جُنُودُهُ مِنَ الجِنِّ والإنْسِ والطَّيْرِ فَهُمْ يُوزَعُونَ﴾</q> [النمل:١٧] فهم يدفعون؛ ألّا يتقدمه منهم أحد{8}. (ز) ٦٣١٣٢- عن وهب بن منبه -من طريق محمد بن إسحاق، عن بعض أهل العلم- قال: ورِث سليمانُ المُلكَ، وأحدث اللهُ إليه النبوةَ، وسأله أن يهَبَ له ملكًا لا ينبغي لأحد من بعده، ففعل -تبارك وتعالى-، فسخَّر له الإنس والجن والطير والريح، فكان إذا خرج من بيته إلى مجلسه -وكان فيما يزعمون أبيض، وسيمًا، وضيئًا، كثير الشعر، يلبس البياض من الثياب- عكفت عليه الطير، وقام عليه الإنس والجن حتى يجلس على سريره، وكان امرأً غزّاءً قَلَّ ما يقعد عن الغزو، ولا يسمع بملِكٍ في ناحية من الأرض إلا أتاه حتى يُذِلَّه، كان فيما يزعمون إذا أراد الغزوَ أمَر بعسكره فضُرب له من خشب، ثم نصب على الخشب، ثم حمل عليه الناس والدواب وآلة الحرب كلها، حتى إذا حمل معه ما يريد أمر العاصف من الريح، فدخلت تحت ذلك الخشب، فاحتملته حتى إذا [استقلت] به أمرت الرخاء، فقذفت به شهرًا في روحته، وشهرًا في غدوته إلى حيث أراد الله. يقول الله ﷿: <q>﴿فَسَخَّرْنا لَهُ الرِّيحَ تَجْرِي بِأَمْرِهِ رُخاءً حَيْثُ أصابَ﴾</q> [ص:٣٦]، أي: حيث أراد. قال: <q>﴿ولسليمان الريح غدوها شهر ورواحها شهر﴾</q>، قال: ذُكر لي: أنّ منزلًا بناحية دجلة مكتوب فيه كتاب كتبه بعض صحابة سليمان؛ إما من الجن، وإما من الإنس: نحن نزلناه وما بنيناه، ومبنِيًّا وجدناه، غدونا من إصطخر فقلناه، ونحن رائحون منه -إن شاء الله- فبائتون بالشام{9}. (ز) ٦٣١٣٣- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿ولِسُلَيْمانَ الرِّيحَ غُدُوُّها شَهْرٌ ورَواحُها شَهْرٌ﴾</q>، قال: تغدو مسيرة شهر، وتروح مسيرة شهرين في يوم{10}. (١٢/١٦٩) ٦٣١٣٤- قال مقاتل بن سليمان: ثم ذكر ابنه سليمان ﵉، وما أعطاه الله ﷿ من الخير والكرامة، فقال ﷿: <q>﴿ولِسُلَيْمانَ الرِّيحَ غُدُوُّها شَهْرٌ﴾</q> يعني: مسيرة شهر، فتحملهم الريح من بيت المقدس إلى إصطخر، وتروح بهم، <q>﴿ورَواحُها شَهْرٌ﴾</q> يعني: مسيرة، فتحملهم إلى بيت المقدس، لا تحوِّل طيرًا مِن فوقهم، ولا ورقة من تحتهم، ولا تثير ترابًا{11}. (ز) ٦٣١٣٥- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿ولِسُلَيْمانَ الرِّيحَ غُدُوُّها شَهْرٌ ورَواحُها شَهْرٌ﴾</q>، قال: كان له مَرْكَب مِن خشب، وكان فيه ألف ركن، في كل ركن ألف بيت تركب فيه الجن والإنس، تحت كل ركن ألف شيطان، يرفعون ذلك المركب هم والعِصار؛ فإذا ارتفع أتت الريح رخاءً فسارت به، وساروا معه، يقيل عند قوم بينه وبينهم شهر، ويمسي عند قوم بينه وبينهم شهر، ولا يدري القوم إلا وقد أظلَّهم معه الجيوش والجنود، والعصار: الريح العاصفة{12}٥٢٩٨. (ز) ٥٢٩٨ ذكر ابنُ عطية (٧/١٦٥) نحو ما جاء في قول ابن زيد، وعلّق عليه، فقال: «وكانت الأعصار تُقِلُّ بساطَه وتحمله بعد ذلك الرخاء، وكان هذا البساط يحمل -فيما روي- أربعة آلاف فارس، وما يشبهها من الرجال والعُدد، ويتسع لهم، وروي أكثر من هذا بكثير، ولكن عدم صحته مع بُعد شبهه أوجب اختصاره». ٦٣١٣٦- قال يحيى بن سلّام: <q>﴿ولِسُلَيْمانَ الرِّيحَ﴾</q>، أي: وسخرنا لسليمان الريح{13}. (ز) <q>﴿وَأَسَلۡنَا لَهُۥ عَیۡنَ ٱلۡقِطۡرِۖ﴾</q> - تفسير ٦٣١٣٧- عن عبد الله بن عباس -من طريق ابن جريج- قال: <q>﴿وأَسَلْنا لَهُ عَيْنَ القِطْرِ﴾</q>، القِطر: النحاس. لم يقدر عليها أحد بعد سليمان، وإنّما يعمل الناس بعدُ فيما كان أُعطي سليمان{14}. (١٢/١٧١) ٦٣١٣٨- عن عبد الله بن عباس -من طُرُق- في قوله: <q>﴿وأَسَلْنا لَهُ عَيْنَ القِطْرِ﴾</q>، قال: النحاس{15}. (١٢/١٧٠) ٦٣١٣٩- عن عبد الله بن عباس: أنّ نافع بن الأزرق قال له: أخبِرني عن قوله: <q>﴿وأَسَلْنا لَهُ عَيْنَ القِطْرِ﴾</q>. قال: أعطاه الله عينًا مِن صُفر{16}، تسيل كما يسيل الماء. قال: وهل تعرف العرب ذلك؟ قال: نعم، أما سمعت قول الشاعر وهو يقول: فألقى في مَراجِلَ{17} من حديدٍ قُدور القِطر ليس من البِرام{18}{19}. (١٢/١٧٠) ٦٣١٤٠- عن مجاهد بن جبر -من طريق أبي يحيى- <q>﴿عَيْنَ القِطْرِ﴾</q>، قال: الصُفر، سالت له مثل الماء{20}. (١٢/١٧١) ٦٣١٤١- عن عكرمة مولى ابن عباس، في قوله: <q>﴿وأَسَلْنا لَهُ عَيْنَ القِطْرِ﴾</q>، قال: أسال الله له القِطر ثلاثةَ أيام من صنعاء، يسيل كما يسيل الماء. قيل: إلى أين؟ قال: لا أدري{14}. (١٢/١٧١) ٦٣١٤٢- عن الحسن البصري -من طريق أبي سهل- قال: كان الله -تبارك وتعالى- سخَّر لسليمان الريح <q>﴿غدوها شهر ورواحها شهر﴾</q>، وقال الله ﷿: <q>﴿وأسلنا له عين القطر﴾</q> يعني: النحاس، فجرى له{22}. (ز) ٦٣١٤٣- عن قتادة بن دعامة -من طريق سعيد- <q>﴿وأَسَلْنا لَهُ عَيْنَ القِطْرِ﴾</q>، قال: عين النحاس، كانت باليمن، وإنما يصنع الناسُ اليومَ مِمّا أخرج الله لسليمان{23}٥٢٩٩. (١٢/١٧١) ٥٢٩٩ ذكر ابنُ عطية (٤/٤٠٩) قول قتادة وقول ابن عباس، ثم قال: «وقالت فرقة: القطر: الفلز كله؛ النحاس، والحديد، وما جرى مجراه، كان يسيل له منه عيون. وقالت فرقة: بل معنى <q>﴿وأسلنا له عين القطر﴾</q>: أذبنا له النحاس عن نحوِ ما كان الحديد يلين لداود، قالوا: وكانت الأعمال تتأتى منه لسليمان وهو بارد دون نار. وعين على هذا التأويل بمعنى: المذاب». ٦٣١٤٤- عن إسماعيل السُّدِّيّ، قال: <q>﴿وأَسَلْنا لَهُ عَيْنَ القِطْرِ﴾</q> سُيِّلَت له عين مِن نحاس ثلاثة أيام{24}. (١٢/١٧١) ٦٣١٤٥- عن عطاء الخراساني -من طريق يونس بن يزيد- في قوله: <q>﴿عين القطر﴾</q>، قال: عين الصفر{25}. (ز) ٦٣١٤٦- قال مقاتل بن سليمان: <q>﴿وأَسَلْنا لَهُ عَيْنَ القِطْرِ﴾</q>، يعني: أخرجنا لسليمان عين الصُفر ثلاثة أيام، تجري مجرى الماء بأرض اليمن{26}. (ز) ٦٣١٤٧- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿وأَسَلْنا لَهُ عَيْنَ القِطْرِ﴾</q>، قال: الصُفر سال كما يسيل الماء، يُعمَل به كما كان يُعمل العجين في اللين{27}. (ز) <q>﴿وَمِنَ ٱلۡجِنِّ مَن یَعۡمَلُ بَیۡنَ یَدَیۡهِ بِإِذۡنِ رَبِّهِۦۖ﴾</q> - تفسير ٦٣١٤٨- قال عبد الله بن عباس: <q>﴿ومِنَ الجِنِّ مَن يَعْمَلُ بَيْنَ يَدَيْهِ﴾</q> سخَّر الله الجنَّ لسليمان، وأمرهم بطاعته فيما يأمرهم به{28}. (ز) ٦٣١٤٩- عن مجاهد بن جبر -من طريق ابن جريج- قال: <q>﴿ومِنَ الجِنِّ مَن يَعْمَلُ بَيْنَ يَدَيْهِ﴾</q>، أي: له{29}. (ز) ٦٣١٥٠- عن قتادة بن دعامة، قال: ليس كل الجن سُخِّر له كما تسمعون: <q>﴿ومِنَ الجِنِّ مَن يَعْمَلُ بَيْنَ يَدَيْهِ﴾</q>{30}. (١٢/١٧١) ٦٣١٥١- قال مقاتل بن سليمان: <q>﴿ومِنَ الجِنِّ مَن يَعْمَلُ﴾</q> وسخرنا لسليمان مِن الجن من يعمل <q>﴿بين يديه﴾</q> بين يدي سليمان، <q>﴿بِإذْنِ رَبِّهِ﴾</q> يعني: رب سليمان ﷿{26}. (ز) ٦٣١٥٢- قال يحيى بن سلّام: <q>﴿بِإذْنِ رَبِّهِ﴾</q> بالسخرة التي سخَّرها الله له{32}. (ز) <q>﴿وَمَن یَزِغۡ مِنۡهُمۡ عَنۡ أَمۡرِنَا نُذِقۡهُ مِنۡ عَذَابِ ٱلسَّعِیرِ ۝١٢﴾</q> - تفسير ٦٣١٥٣- عن مجاهد بن جبر -من طريق ابن جريج- <q>﴿ومَن يَزِغْ مِنهُمْ عَنْ أمْرِنا﴾</q>، قال: مِن الجن{33}. (١٢/١٧٢) ٦٣١٥٤- عن قتادة بن دعامة -من طريق سعيد- قال: <q>﴿ومَن يَزِغْ مِنهُمْ عَنْ أمْرِنا﴾</q>، قال: يعدل عن أمرنا، عما أمره به سليمان{34}٥٣٠٠. (١٢/١٧٢) ٥٣٠٠ لم يذكر ابنُ جرير (١٩/٢٢٩) غير قول قتادة. ٦٣١٥٥- قال مقاتل بن سليمان: <q>﴿ومَن يَزِغْ مِنهُمْ﴾</q> ومَن يعدل منهم <q>﴿عَنْ أمْرِنا﴾</q> عن أمر سليمان ﵇؛ <q>﴿نُذِقْهُ مِن عَذابِ السَّعِيرِ﴾</q> الوقود في الدنيا. كان ملَكٌ بيده سوط مِن نار، مَن يزِغ عن أمر سليمان ضربه بسوط من نار، فذلك عذاب السعير{26}. (ز) ٦٣١٥٦- قال يحيى بن سلّام: <q>﴿ومَن يَزِغْ مِنهُمْ عَنْ أمْرِنا﴾</q> عن طاعة الله وعن عبادته؛ <q>﴿نُذِقْهُ مِن عَذابِ السَّعِيرِ﴾</q> في الآخرة، ولم يكن يتسخَّر منهم، ويُستعمل في هذه الأشياء، ولا يُصفّد في الأصفاد، أي: ولا يُسلسل في السلاسل منهم، إلا الكافر، فإذا تابوا فآمنوا حلَّهم مِن تلك الأصفاد. وقال بعضهم: <q>﴿نذقه من عذاب السعير﴾</q> جعل معه ملك بيده سوط من عذاب السعير، فإذا خالف سليمانَ أحدٌ منهم ضربه الملَكُ بذلك السوط{32}. (ز) ",footnotes:1:عزاه السيوطي إلى عبد بن حميد. وهي قراءة متواترة، قرأ بها شعبة عن عاصم، وقرأ بقية العشرة: <q>﴿الرِّيحَ﴾</q> بالنصب. انظر: النشر ٢/٣٤٩، والإتحاف ص٤٥٨.إصطخر: بلدة بفارس. معجم البلدان ١/٢٩٩.عزاه السيوطي إلى الخطيب في رواة مالك.عزاه السيوطي إلى عبد بن حميد.قُرير: بلدة بين نصيبين والرقة. معجم البلدان ٤/٧٨.عزاه السيوطي إلى ابن أبي شيبة، وعبد بن حميد، وابن المنذر، وابن أبي حاتم. وأخرج آخره يحيى بن سلام ٢/٧٤٨ بنحوه من طريق أبي أمية وقرة بن خالد، وبنحوه ابن جرير ١٩/٢٢٨ من طريق قرة بن خالد. وعبد الرزاق ٢/١٢٧ من طريق معمر، وعندهم: إصطخر، بدل: قرير. وعند عبد الرزاق: دمشق، بدل: إيلياء، وزاد: وما بين إصطخر ودمشق مسيرة شهر للمسرع، ومن إصطخر إلى كابل مسيرة شهر للمسرع. وبنحوه أخرجه بحشل في تاريخ واسط ص١٠١، وابن عساكر في تاريخ دمشق ٢٢/٢٣١.عزاه السيوطي إلى أحمد في الزهد.علَّقه يحيى بن سلام ٢/٧٤٨-٧٤٩.أخرجه ابن أبي حاتم ٩/٢٨٥٦، كما أخرج ابن جرير ١٩/٢٢٧ آخره.أخرجه ابن جرير ١٩/٢٢٧ بنحوه. وعزاه السيوطي إلى عبد بن حميد.تفسير مقاتل بن سليمان ٣/٥٢٦.أخرجه ابن جرير ١٩/٢٢٧.تفسير يحيى بن سلام ٢/٧٤٨.عزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ١٩/٢٢٩ من طريق علي، ومن طريق العوفي بلفظ: عين النحاس أُسيلت. وعزاه السيوطي إلى ابن أبي شيبة، وعبد بن حميد، وابن المنذر، وابن أبي حاتم -ينظر: التغليق ٤/١١-.صُفر: النحاس الجيد. اللسان (صفر).مراجِل: جمع مِرْجل: وهو الإناءُ الذي يُغْلى فيه الماءُ. النهاية (مرجل).البرام: القِدر من الحجارة. اللسان (برم).عزاه السيوطي إلى الطستي -ينظر: الإتقان ٢/٩٩-.أخرجه يحيى بن سلام ٢/٧٤٩. وعزاه السيوطي إلى عبد بن حميد مختصرًا.عزاه السيوطي إلى ابن المنذر.أخرجه ابن عساكر في تاريخ دمشق ٢٢/٢٣١.أخرجه ابن جرير ١٩/٢٢٨، وأخرجه عبد الرزاق ٢/١٢٧ مختصرًا من طريق معمر. وعزاه السيوطي إلى عبد بن حميد، وابن أبي حاتم.عزاه السيوطي إلى ابن أبي حاتم.أخرجه أبو جعفر الرملي في جزئه ص٨٩ (تفسير عطاء الخراساني).تفسير مقاتل بن سليمان ٣/٥٢٧.أخرجه ابن جرير ١٩/٢٢٩.تفسير البغوي ٦/٣٨٩.أخرجه يحيى بن سلام ٢/٧٤٩ من طريق ابن مجاهد، وإسحاق البستي ص١٤٧.عزاه السيوطي إلى عبد بن حميد، وابن جرير، وابن أبي حاتم.تفسير مقاتل بن سليمان ٣/٥٢٧.تفسير يحيى بن سلام ٢/٧٤٩.أخرجه إسحاق البستي ص١٤٨. وعزاه السيوطي إلى عبد بن حميد، وابن أبي حاتم.أخرجه ابن جرير ١٩/٢٢٩. وعزاه السيوطي إلى عبد بن حميد، وابن أبي حاتم.تفسير مقاتل بن سليمان ٣/٥٢٧.تفسير يحيى بن سلام ٢/٧٤٩.
34,13," <q>﴿یَعۡمَلُونَ لَهُۥ مَا یَشَاۤءُ مِن مَّحَـٰرِیبَ﴾</q> - تفسير ٦٣١٥٧- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿مِن مَحارِيبَ﴾</q>، قال: بنيان دون القصور{1}. (١٢/١٧٢) ٦٣١٥٨- عن الضحاك بن مزاحم -من طريق جويبر- في قوله: <q>﴿مِن مَحارِيبَ﴾</q>، قال: المساجد{2}. (١٢/١٧٣) ٦٣١٥٩- عن الحسن البصري: <q>﴿يَعْمَلُونَ لَهُ ما يَشاءُ مِن مَحارِيبَ﴾</q>، المحاريب: المساجد{3}. (ز) ٦٣١٦٠- عن عطية بن سعد العوفي، قال: <q>﴿يَعْمَلُونَ لَهُ ما يَشاءُ مِن مَحارِيبَ﴾</q> المحاريب: القصور{4}. (١٢/١٧٢) ٦٣١٦١- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿مِن مَحارِيبَ﴾</q>، قال: قصور ومساجد{5}. (١٢/١٧٣) ٦٣١٦٢- عن محمد بن السائب الكلبي: <q>﴿مِن مَحارِيبَ﴾</q> المساجد والقصور{3}. (ز) ٦٣١٦٣- قال مقاتل بن سليمان: <q>﴿يَعْمَلُونَ لَهُ ما يَشاءُ﴾</q> يعني: الجن لسليمان <q>﴿مِن مَحارِيبَ﴾</q> المساجد{7}. (ز) ٦٣١٦٤- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿يَعْمَلُونَ لَهُ ما يَشاءُ مِن مَحارِيبَ﴾</q>، قال: المحاريب: المساكن. وقرأ قول الله ﷿: <q>﴿فَنادَتْهُ المَلائِكَةُ وهُوَ قائِمٌ يُصَلِّي فِي المِحْرابِ﴾</q> [آل عمران:٣٩]{8}. (ز) <q>﴿وَتَمَـٰثِیلَ﴾</q> - تفسير ٦٣١٦٥- عن عبد الله بن عباس –من طريق السدي عن أبي مالك-، في قوله: <q>﴿وتَماثِيلَ﴾</q> قال: اتخذ سليمانُ تماثيل مِن نحاس، فقال: يا رب، انفخ فيها الروح؛ فإنها أقوى على الخدمة. فنفخ الله فيها الروح، فكانت تخدمه، وكان إسفنديار من بقاياهم، فقيل لداود وسليمان: <q>﴿اعْمَلُوا آلَ داوُودَ شُكْرًا وقَلِيلٌ مِن عِبادِيَ الشَّكُورُ﴾</q>{9}. (١٢/١٧٣) ٦٣١٦٦- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿وتَماثِيلَ﴾</q>، قال: من نحاس{10}. (١٢/١٧٢) ٦٣١٦٧- عن الضحاك بن مزاحم -من طريق جويبر- في قوله: <q>﴿وتَماثِيلَ﴾</q>، قال: الصور{2}. (١٢/١٧٣) ٦٣١٦٨- عن الحسن البصري: <q>﴿وتَماثِيلَ﴾</q>: الصور. وقال: ولم تكن يومئذ محرمة{3}٥٣٠١. (ز) ٥٣٠١ ذكر ابنُ عطية (٧/١٦٦) نحو قول الحسن والضحاك، وعلّق عليه بقوله: «وقال الضحاك: كانت تماثيل حيوان، وكان هذا من الجائز في ذلك الشرع، ونسخ بشرع محمد ﷺ. وقال قوم: حرم التصوير؛ لأن الصور كانت تُعبد. وحكى مكي في الهداية: أنّ فرقة تجوِّز التصوير وتحتج بهذه الآية. وذلك خطأ، وما أحفظ من أئمة العلم مَن يُجَوِّزه». ٦٣١٦٩- عن عطية بن سعد العوفي، قال: <q>﴿وتَماثِيلَ﴾</q> والتماثيل: الصور{4}. (١٢/١٧٢) ٦٣١٧٠- عن قتادة بن دعامة، في قوله: <q>﴿وتَماثِيلَ﴾</q>، قال: من رُخام وشَبَهٍ{14}. (١٢/١٧٣) ٦٣١٧١- قال مقاتل بن سليمان: <q>﴿وتَماثِيلَ﴾</q> مِن نحاس ورخام، من الأرض المقدسة وإصطخر، مِن غير أن يعبدها أحد{7}. (ز) ٦٣١٧٢- عن عبد الملك ابن جريج، في قوله: <q>﴿يَعْمَلُونَ لَهُ ما يَشاءُ مِن مَحارِيبَ وتَماثِيلَ﴾</q>، قال: مِن شَبَهٍ ورخام{16}. (١٢/١٧٢) <q>﴿وَجِفَانࣲ كَٱلۡجَوَابِ﴾</q> - تفسير ٦٣١٧٣- عن عبد الله بن عباس -من طريق علي- في قوله: ‹وجِفانٍ كالجَوابِي›، قال: كالجوْبة{17} من الأرض منها{18}. (١٢/١٧٤) ٦٣١٧٤- عن عبد الله بن عباس -من طريق العوفي- قوله: <q>﴿وجِفانٍ كالجَوابِ﴾</q>: يعني بالجواب: الحياض{19}. (ز) ٦٣١٧٥- عن عبد الله بن عباس، أن نافع بن الأزرق قال له: أخبرني عن قوله: ‹وجِفانٍ كالجَوابِي›. قال: كالحياض الواسعة، تسع الجفنة الجزور. قال: وهل تعرف العربُ ذلك؟ قال: نعم، أما سمعت طرفة بن العبد وهو يقول: كالجوابي لا تَني مُتْرَعة لِقِرى الأضياف أو للمُحْتَضر{20}. وقال أيضًا: يجبر المحروب{21} فينا ماله بقبابٍ وجفانٍ وخَدم{22}. (١٢/١٧٤) ٦٣١٧٦- عن مجاهد بن جبر -من طريق ابن أبي نجيح- قوله: <q>﴿وجِفانٍ كالجَوابِ﴾</q>، قال: حياض الإبل{23}. (ز) ٦٣١٧٧- قال مجاهد بن جبر: <q>﴿وجِفانٍ﴾</q> وصحاف{3}. (ز) ٦٣١٧٨- عن مجاهد بن جبر -من طريق ابن أبي نجيح-: <q>﴿وجِفانٍ﴾</q> صحاف، ‹كالجَوابِي› الجفنة مثل الجوْبة من الأرض{25}٥٣٠٢. (١٢/١٧٢) ٥٣٠٢ ذكر ابنُ عطية (٧/١٦٧) ما جاء في قول مجاهد، وانتقده، فقال: «وقال مجاهد: هي جمع جوْبة، وهي الحفرة العظيمة من الأرض. وفي هذا نظر». ثم قال: "ومنه قول الأعشى: نفى الذم عن آل المحلق جفنة كجابية الشيخ العراقي تفهق". ٦٣١٧٩- عن الضحاك بن مزاحم -من طريق عبيد- ‹وجِفانٍ كالجَوابِي›: كحياض الإبل العظام{26}. (١٢/١٧٣) ٦٣١٨٠- عن الحسن البصري -من طريق أبي رجاء- <q>﴿كالجَوابِ﴾</q>: كالحياض{27}. (ز) ٦٣١٨١- عن الحسن البصري، ‹وجِفانٍ كالجَوابِي›، قال: كالحياض{28}. (١٢/١٧٤) ٦٣١٨٢- عن عطية بن سعد العوفي، قال: <q>﴿وجِفانٍ كالجَوابِ﴾</q>، قال: كالجوْبة من الأرض{4}. (١٢/١٧٢) ٦٣١٨٣- عن قتادة بن دعامة -من طريق سعيد- ‹وجِفانٍ كالجَوابِي›، قال: كالحياض{30}. (١٢/١٧٣) ٦٣١٨٤- عن عطاء الخراساني -من طريق يونس بن يزيد- في قوله جل وعلا: <q>﴿جفان كالجواب﴾</q>، قال: الجفان: العظام{31}. (ز) ٦٣١٨٥- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- <q>﴿وجِفانٍ كالجَوابِ﴾</q>، قال: جفان كجوبة الأرض من العِظَم. والجوبة من الأرض: يُستنقع فيها الماء{19}. (ز) <q>﴿وَقُدُورࣲ رَّاسِیَـٰتٍۚ﴾</q> - تفسير ٦٣١٨٦- عن عبد الله بن عباس -من طريق علي- في قوله: <q>﴿وقُدُورٍ راسِياتٍ﴾</q>، قال: أثافِيُّها{33} منها{18}. (١٢/١٧٤) ٦٣١٨٧- عن سعيد بن جبير، <q>﴿وقُدُورٍ راسِياتٍ﴾</q>، قال: عظام تُفْرَغ إفراغًا{35}. (١٢/١٧٥) ٦٣١٨٨- عن مجاهد بن جبر -من طريق ابن أبي نجيح- <q>﴿وقُدُورٍ راسِياتٍ﴾</q>، قال: عِظام{36}. (١٢/١٧٢) ٦٣١٨٩- عن الضحاك بن مزاحم -من طريق عبيد- <q>﴿وقُدُورٍ راسِياتٍ﴾</q>: قدور عِظام، كانوا ينحتونها من الجبال{37}. (١٢/١٧٣) ٦٣١٩٠- عن الحسن البصري، <q>﴿وقُدُورٍ راسِياتٍ﴾</q>، قال: القدور العظام التي لا تُحرَّك من مكانها{28}. (١٢/١٧٤) ٦٣١٩١- عن قتادة بن دعامة -من طريق سعيد- <q>﴿وقُدُورٍ راسِياتٍ﴾</q>، قال: ثابِتات لا يزُلن عن مكانهن، كُنَّ يُرَيْنَ بأرض اليمن{30}. (١٢/١٧٣) ٦٣١٩٢- عن إسماعيل السُّدِّيّ: <q>﴿راسِياتٍ﴾</q>، يعني: ثابتات في الأرض، عِظام تنقُر من الجبال بأثافيِّها لا تُحوّل عن أماكنها{40}. (ز) ٦٣١٩٣- قال مقاتل بن سليمان: <q>﴿وجِفانٍ كالجَوابِ﴾</q> وقصاع في العِظَم كحياض الإبل بأرض اليمن، من العِظَم يجلس على كل قصعة واحدة ألف رجل، يأكلون منها بين يدي سليمان، <q>﴿وقُدُورٍ﴾</q> عظام لها قوائم لا تتحرك، <q>﴿راسِياتٍ﴾</q> ثابتات تُتخذ من الجبال. والقدور وعين الصُفر بأرض اليمن، وكان مُلكُ سليمان ما بين مصر وكابل{7}. (ز) ٦٣١٩٤- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- <q>﴿وقُدُورٍ راسِياتٍ﴾</q>، قال: مثال الجبال مِن عِظَمِها، يُعمل فيها الطعام مِن الكِبَر والعِظم، لا تُحرّك، ولا تُنقل، كما قال للجبال: راسيات{42}. (ز) <q>﴿وَقُدُورࣲ رَّاسِیَـٰتٍۚ﴾</q> - آثار متعلقة بالآية ٦٣١٩٥- عن عطية العوفي -من طريق قُرَّة بن خالد- قال: أمر سليمانُ ببناء بيت المقدس، فقالوا له: زوبعة الشيطان له عينٌ في جزيرة من البحر يرِدها كل سبعة أيام يومًا. فأَتوها، فنزحوها ثم صبُّوا فيها خمرًا، فجاء لِوِرْده، فلمّا أبصر الخمر قال في كلام له: ما علمتُ أنكِ إذا شربكِ صاحبُك لمَما تُظهرين عليه عدوه -في أساجيع له-، لا أذوقكِ اليوم. فذهب ثم رجع لظمأٍ آخر، فلما رآها قال كما قال أول مرة، ثم ذهب فلم يشرب، حتى جاء لظمئه لإحدى وعشرين ليلة، فقال: ما علمتُ أنكِ لَتُذهبين الهمَّ. في سجع له، فشرب منها، فسكر، فجاءوا إليه، فأروْه خاتم السُّخرة، فانطلق معهم إلى سليمان، فأمرهم بالبناء، فقال زوبعة: دلُّوني على بيض الهدهد. فدُلّ على عُشِّه، فأكبَّ عليه جُمجُمة، يعني: زجاجة، فجاء الهدهد، فجعل لا يصِل إليه، فانطلق، فجاء بالماس الذي يُثقب به الياقوت، فوضعه عليها فقطَّ الزجاجة نصفين، ثم ذهب ليأخذه، فأزعجوه، فجاء بالماس إلى سليمان، فجعلوا يستعرضون الجبال كأنما يخطون، أي: في نواحيها؛ في نواحي الجبل في طين{43}. (ز) ٦٣١٩٦- قال معمر، وقال قتادة: إنّ سليمان قال للشياطين: إنِّي قد أمرتُ أن أبني مسجدًا -يعني: مسجد بيت المقدس- لا أسمع فيه صوت منقار ولا ميشار{44}. فقالت له الشياطين: إنّ في البحر شيطانًا، فلعلك إن قدرت عليه أن يخبرك بذلك. وكان ذلك الشيطان يرد كل سبعة أيام عينًا يشرب منها، فعمدت الشياطين إلى تلك العين، فنزحتها، ثم ملأتها خمرًا، فجاء ذلك الشيطان، فقال: إنّك لطيبة الريح، ولكنك تُسفِّهين الحليم، وتزيدين السفيه سفهًا. ثم ذهب فلم يشرب، ثم أدركه العطش، فرجع، فقال مثل ذلك ثلاث مرات، ثم إنه كرع فشرب فسكر، فأخذوه، فجاءوا به إلى سليمان، فأراه سليمان خاتمه، فلما رآه ذلَّ له، وكان ملك سليمان في خاتمه، فقال سليمان: إني قد أمرت أن أبني مسجدًا فلا أسمع فيه صوت منقار ولا ميشار. فأمر الشياطين بزجاجة فصنعت له، ثم وضعت على بيض الهدهد، فجاء الهدهد ليربض على بيضه فلم يقدر عليه، فذهب، فقال الشيطان: انظروا ما يأتي به الهدهد فخذوه. فجاء بالماس، فوضعه على الزجاجة، ففلقها، فأخذوا الماس، فجعلوا يقطعون به الحجارة قطعًا حتى بنى بيت المقدس{45}. (١٢/٥٧٤) <q>﴿ٱعۡمَلُوۤا۟ ءَالَ دَاوُۥدَ شُكۡرࣰاۚ﴾</q> - تفسير ٦٣١٩٧- عن عبد الله بن عباس، في قوله: <q>﴿اعْمَلُوا آلَ داوُودَ شُكْرًا﴾</q>، قال: اعملوا شكرًا لله على ما أنعم به عليكم{4}. (١٢/١٧٥) ٦٣١٩٨- عن أبي عبد الرحمن الحُبُلِّي -من طريق زهرة بن معبد- قال: <q>﴿اعْمَلُوا آلَ داوُودَ شُكْرًا﴾</q> الصلاة شكر، والصيام شكر، وكل خير تعمله لله شكر، وأفضل الشكر الحمد{47}. (ز) ٦٣١٩٩- عن محمد بن كعب القرظي -من طريق موسى بن عبيدة- في قوله: <q>﴿اعْمَلُوا آلَ داوُودَ شُكْرًا﴾</q>، قال: الشكر: تقوى الله، والعمل بطاعته{48}. (١٢/١٧٦) ٦٣٢٠٠- عن عطاء الخراساني -من طريق ابنه عثمان- قال: كان داود ﵇ يرتفع له كل يوم درع، فيبيعه بستة آلاف، فينفق على بني إسرائيل أربعة آلاف، وعلى عياله ألفين، فأُوتي داود ﵇ ما أُوتي ثم قيل له: <q>﴿اعْمَلُوا آلَ داوُودَ شُكْرًا﴾</q>{49}. (ز) ٦٣٢٠١- عن محمد بن شهاب الزهري -من طريق عبد الجليل بن حميد- في قوله: <q>﴿اعْمَلُوا آلَ داوُودَ شُكْرًا﴾</q>، قال: قولوا: الحمد لله{50}. (١٢/١٧٥) ٦٣٢٠٢- عن إسماعيل السُّدِّيّ، في قوله: <q>﴿اعْمَلُوا آلَ داوُودَ شُكْرًا﴾</q>، قال:لم ينفكْ منهم مصلٍّ{16}. (١٢/١٧٧) ٦٣٢٠٣- قال مقاتل بن سليمان: ثم قال ﷿: <q>﴿اعْمَلُوا آلَ داوُودَ شُكْرًا﴾</q> بما أعطيتم من الخير{7}. (ز) ٦٣٢٠٤- عن مسعر، قال: لَمّا قيل لهم: <q>﴿اعْمَلُوا آلَ داوُودَ شُكْرًا﴾</q>لم يأتِ على القوم ساعةٌ إلا ومنهم مصلٍّ{53}. (١٢/١٧٧) ٦٣٢٠٥- عن الفضيل، قال في قوله: <q>﴿اعْمَلُوا آلَ داوُودَ شُكْرًا﴾</q>: قال داود: يا رب، كيف أشكرك، والشكر نعمة منك؟ قال: الآن شكرتني؛ حين علمتَ أنّ النِّعَم مِنِّي{54}. (١٢/١٧٦) ٦٣٢٠٦- عن المغيرة بن عتيبة، قال: قال داود: يا رب، هل بات أحدٌ مِن خلقك الليلةَ أطول ذِكرًا لك مِنِّي؟ فأوحى الله إليه: نعم، الضفدع. وأنزل الله على داود: <q>﴿اعْمَلُوا آلَ داوُودَ شُكْرًا﴾</q>، فقال داود: يا رب، كيف أطيق شكرك، وأنت الذي تُنعِمُ عَلَيَّ ثم ترزقني على النعمة الشكر؟ فالنعمة منك، والشكر منك، فكيف أطيق شكرك؟ قال: يا داود، الآن عرفتني حق معرفتي{55}. (١٢/١٧٦) ٦٣٢٠٧- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿اعْمَلُوا آلَ داوُودَ شُكْرًا﴾</q>، قال: فيما أعطاكم وعلَّمكم، وسخَّر لكم ما لم يُسَخِّر لغيركم، وعلَّمكم منطق الطير، اشكروا له، يا آل داود. قال: الحمد طرفٌ مِن الشكر{56}. (ز) ٦٣٢٠٨- قال يحيى بن سلّام: <q>﴿اعْمَلُوا آلَ داوُودَ شُكْرًا﴾</q> قال بعضهم: توحيدًا. وقال بعضهم: لما نزلت لم يزل إنسانٌ منهم قائمًا يصلي{57}. (ز) <q>﴿وَقَلِیلࣱ مِّنۡ عِبَادِیَ ٱلشَّكُورُ ۝١٣﴾</q> - تفسير ٦٣٢٠٩- عن عبد الله بن عباس -من طريق علي- في قوله: <q>﴿وقَلِيلٌ مِن عِبادِيَ الشَّكُورُ﴾</q>، يقول: قليل مِن عبادي الموحدين توحيدهم{58}. (١٢/١٧٨) ٦٣٢١٠- عن ثابت بن أسلم البناني -من طريق جعفر بن سليمان- قال: بلغنا: أنّ داود ﵇ جَزَّأ الصلاة على بيوته؛ على نسائه وولده، فلم تكن تأتي ساعةٌ مِن الليل والنهار إلا وإنسانٌ قائِمٌ من آل داود يصلي، فعَمَّتهم هذه الآية: <q>﴿اعْمَلُوا آلَ داوُودَ شُكْرًا وقَلِيلٌ مِن عِبادِيَ الشَّكُورُ﴾</q>{59}. (١٢/١٧٥) ٦٣٢١١- قال مقاتل بن سليمان: <q>﴿وقَلِيلٌ مِن عِبادِيَ الشَّكُورُ﴾</q> لربهم{7}. (ز) ٦٣٢١٢- قال يحيى بن سلّام: <q>﴿وقَلِيلٌ مِن عِبادِيَ الشَّكُورُ﴾</q> أي: أقل الناس المؤمن{57}. (ز) <q>﴿وَقَلِیلࣱ مِّنۡ عِبَادِیَ ٱلشَّكُورُ ۝١٣﴾</q> - آثار متعلقة بالآية ٦٣٢١٣- عن عطاء بن يسار، قال: قال رسول الله ﷺ وهو يخطب الناسَ على المنبر، وقرأ هذه الآية: <q>﴿اعْمَلُوا آلَ داوُودَ شُكْرًا﴾</q>، قال: «ثلاثٌ مَن أُوتِيهُنَّ فقد أُوتِي ما أُوتِي آلُ داود». قيل: وما هُنَّ، يا رسول الله؟ قال: «العدلُ في الغضب والرضا، والقَصْد في الفقر والغِنى، وذِكرُ الله في السِّرِّ والعلانية»{62}. (١٢/١٧٧) ٦٣٢١٤- عن حفصة -من طريق عطاء بن يسار-، مرفوعًا به{63}. (١٢/١٧٧) ٦٣٢١٥- عن أبي هريرة -من طريق عطاء بن يسار-، مرفوعًا به{64}. (١٢/١٧٧) ٦٣٢١٦- عن أبي ذر -من طريق عطاء بن يسار- مرفوعًا به، وقال: «خشية الله في السر والعلانية»{65}. (١٢/١٧٨) ٦٣٢١٧- عن إبراهيم التيمي، قال: قال رجل عند عمر: اللهم، اجعلني مِن القليل. فقال عمر: ما هذا الدعاء الذي تدعو به؟! قال: إني سمعت الله يقول: <q>﴿وقَلِيلٌ مِن عِبادِيَ الشَّكُورُ﴾</q>، فأنا أدعو الله أن يجعلني من ذلك القليل. فقال عمر: كل الناس أعلمُ مِن عمر{66}. (١٢/١٧٨) ٦٣٢١٨- عن مسعر، قال: إنّ عمر سمع رجلًا يقول: اللهم، اجعلني من القليل. فقال: يا عبد الله، ما هذا؟! قال: سمعتُ الله يقول: <q>﴿ومَن آمَنَ وما آمَنَ مَعَهُ إلّا قَلِيلٌ﴾</q> [هود:٤٠]، <q>﴿وقَلِيلٌ مِن عِبادِيَ الشَّكُورُ﴾</q>، وذكر آية أخرى. فقال عمر: كل أحد أفقه مِن عمر{67}. (١٢/١٧٨) ٦٣٢١٩- عن أبي الجلد، قال: قرأتُ في مسألة داود أنّه قال: أي ربِّ، كيف لي أن أشكرك، وأنا لا أصِل إلى شكرك إلا بنعمتك؟ قال: فأتاه الوحي: أن يا داود، أليس تعلم أنّ الذي بِك مِن النِّعَم مِنِّي؟ قال: بلى، يا رب. قال: فإنِّي أرضى بذلك منك شكرًا{68}. (١٢/١٧٦) ٦٣٢٢٠- عن مجاهد بن جبر: قال داود لسليمان: قد ذكر الله الشكرَ، فاكفني قيامَ النهار أكفك قيام الليل. قال: لا أستطيع. قال: فاكفني إلى صلاة الظهر. فكفاه{69}. (١٢/١٧٥) ٦٣٢٢١- عن الحسن البصري -من طريق معاوية- قال: قال داود: إلهي، لو أنّ لكل شعرة مِنِّي لِسانَيْنِ يُسَبِّحانك الليلَ والنهارَ والدهر كله؛ ما قضيتُ حقَّ نعمة واحدة من نِعَمِك عَلَيَّ{70}. (١٢/١٧٧) ",footnotes:1:أخرجه عبد بن حميد -كما في التغليق ٤/٣١-، وابن جرير ١٩/٢٣٠. وعلَّقه يحيى بن سلام ٢/٧٤٩. وعزاه السيوطي إلى الفريابي، وابن المنذر، وابن أبي حاتم.أخرجه ابن جرير ١٩/٢٣١. وعزاه السيوطي إلى ابن المنذر، وابن أبي شيبة.علقه يحيى بن سلام ٢/٧٤٩.عزاه السيوطي إلى ابن أبي حاتم.أخرجه عبد الرزاق ٢/١٢٧ من طريق معمر، وابن جرير ١٩/٢٣٠. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.علقه يحيى بن سلام ٢/٧٤٩.تفسير مقاتل بن سليمان ٣/٥٢٧.أخرجه ابن جرير ١٩/٢٣١.أخرجه الحكيم الترمذي في نوادر الأصول ١/٣٧٤.أخرجه ابن جرير ١٩/٢٣١. وعلَّقه يحيى بن سلام ٢/٧٤٩. وعزاه السيوطي إلى الفريابي، وعبد بن حميد، وابن المنذر، وابن أبي حاتم.أخرجه ابن جرير ١٩/٢٣١. وعزاه السيوطي إلى ابن المنذر، وابن أبي شيبة.علقه يحيى بن سلام ٢/٧٤٩.عزاه السيوطي إلى ابن أبي حاتم.عزاه السيوطي إلى عبد الرزاق، وعبد بن حميد، وابن أبي حاتم، وابن المنذر. وأخرجه ابن جرير ١٩/٢٣٠ من طريق سعيد بلفظ: زجاج وشَبَهٍ. والشبه: النحاس يُصبغ فيصفر. اللسان (شبه). وعزاه الحافظ ابن حجر في الفتح ١٠/٣٨٢ إلى عبد الرزاق بلفظ: كانت من خشب ومن زجاج.تفسير مقاتل بن سليمان ٣/٥٢٧.عزاه السيوطي إلى ابن المنذر.الجوبة: الحفرة. اللسان (جوب).أخرجه ابن جرير ١٩/٢٣٢، وابن أبي حاتم -كما في التغليق ٤/٣١، وفتح الباري ٨/٥٣٧-. وعزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ١٩/٢٣٣.لا تني: لا تفتر. والمترعة: المملوءة. والمحتضر: النازل على الماء. شرح ديوان طرفة (٦٧).المحروب: المسلوب ماله. شرح ديوان طرفة (١١٠).أخرجه الطستي -كما في الإتقان ٢/٧٥- دون البيت الثاني.تفسير مجاهد (٥٥٣)، وأخرجه ابن جرير ١٩/٢٣٣، كما أخرجه يحيى بن سلام ٢/٧٥٠ بنحوه من طريق أبي يحيى.علقه يحيى بن سلام ٢/٧٤٩.أخرجه عبد بن حميد -كما في التغليق ٤/٣١-، وابن جرير ١٩/٢٣٣ بنحوه. وعلَّقه يحيى بن سلام ٢/٧٥٠. وعزاه السيوطي إلى الفريابي، وابن المنذر، وابن أبي حاتم.أخرجه ابن جرير ١٩/٢٣٤ من طريق جويبر أيضًا. وعزاه السيوطي إلى ابن المنذر، وابن أبي شيبة.عزاه السيوطي إلى ابن أبي حاتم. ([٩٨٤]) أخرجه ابن جرير ١٩/٢٣٣. وعلَّقه يحيى بن سلام في تفسيره ٢/٧٤٩-٧٥٠. وأخرجه الثعلبي في تفسيره ٨/٧٩ من طريق سهل السراج بلفظ: مثل حياض الإبل.عزاه السيوطي إلى عبد بن حميد.عزاه السيوطي إلى ابن أبي حاتم.أخرجه عبد الرزاق ٢/١٢٧ من طريق معمر، وأخرجه ابن جرير ١٩/٢٣٤ بنحوه. وعزاه السيوطي إلى عبد بن حميد، وابن أبي حاتم، وابن المنذر.أخرجه أبو جعفر الرملي في جزئه ص٨٩ (تفسير عطاء الخراساني).أخرجه ابن جرير ١٩/٢٣٣.أثافيها: هي الحجارة التي توضع عليها القِدر. اللسان (أثف).أخرجه ابن جرير ١٩/٢٣٢، وابن أبي حاتم -كما في التغليق ٤/٣١، وفتح الباري ٨/٥٣٧-. وعزاه السيوطي إلى ابن المنذر.عزاه السيوطي إلى عبد بن حميد، والفريابي.أخرجه عبد بن حميد -كما في التغليق ٤/٣١-، وابن جرير ١٩/٢٣٤ بنحوه. وعلَّقه يحيى بن سلام ٢/٧٥٠. وعزاه السيوطي إلى الفريابي، وابن المنذر، وابن أبي حاتم.أخرجه ابن جرير ١٩/٢٣٤. وعزاه السيوطي إلى ابن أبي شيبة،وابن المنذر.عزاه السيوطي إلى عبد بن حميد.أخرجه عبد الرزاق ٢/١٢٧ من طريق معمر، وأخرجه ابن جرير ١٩/٢٣٤ بنحوه. وعزاه السيوطي إلى عبد بن حميد، وابن أبي حاتم، وابن المنذر.علقه يحيى بن سلام ٢/٧٥٠.تفسير مقاتل بن سليمان ٣/٥٢٧.أخرجه ابن جرير ١٩/٢٣٣، ٢٣٥.أخرجه يحيى بن سلام ٢/٧٥٠-٧٥١.المئشار، بالهمز: هو المنشار، بالنون. وقد يترك الهمز. لسان العرب (أشر).أخرجه عبد الرزاق في تفسيره ٢/١٦٤-١٦٥، وفي مصنفه (٩٧٥٣)، وابن جرير ٢٠/٨٩-٩١. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر. وسيأتي بنحوه في سورة ص.عزاه السيوطي إلى ابن أبي حاتم.أخرجه عبد الله بن وهب في الجامع في تفسير القرآن ١/١٤٢ (٣٣١)، وابن جرير ١٩/٢٣٦.أخرجه ابن جرير ١٩/٢٣٥-٢٣٦، وابن أبي حاتم -كما في تفسير ابن كثير ٦/٤٨٨-. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه الحكيم الترمذي في نوادر الأصول (ت: إسماعيل إبراهيم عوض) ١/٣١٧ (٤٣٩).أخرجه البيهقي في شعب الإيمان (٤٤٧٨).عزاه السيوطي إلى ابن المنذر.تفسير مقاتل بن سليمان ٣/٥٢٧.أخرجه ابن أبي الدنيا (٧٤)، والبيهقي في شعب الإيمان (٤٥٢٤)، وابن عساكر في تاريخ دمشق ١٧/٩٣.أخرجه ابن أبي حاتم -كما في تفسير ابن كثير ٦/٤٨٩-.أخرجه البيهقي في شعب الإيمان (٤٤١٣)، وأحمد في الزهد (٦٩). وعزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ١٩/٢٣٦.تفسير يحيى بن سلام ٢/٧٥١.أخرجه ابن جرير ١٩/٢٣٦، وابن أبي حاتم -كما في الإتقان ٢/٣٧-. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.أخرجه ابن أبي شيبة في مصنفه (ت: محمد عوامة) ١٦/٥٥٦-٥٥٧ (٣٢٥٥٠)، ١٩/٣٩ (٣٥٤٢٠)، وابن أبي حاتم -كما في تفسير ابن كثير ٦/٤٨٨-، والبيهقي في شعب الإيمان (٣١٨٧). وعزاه السيوطي إلى أحمد في الزهد.تفسير مقاتل بن سليمان ٣/٥٢٧.تفسير يحيى بن سلام ٢/٧٥١.أخرجه القاسم بن سلام في الخطب والمواعظ ص١٤٣ (٥٨).عزاه السيوطي إلى ابن مردويه.أورده الحكيم الترمذي في نوادر الأصول ٢/٧.أخرجه ابن النجار في تاريخه ١٦/١٨٩، من طريق عبد الله بن منيب الحارثي الأنصاري، عن أبيه، عن عطاء بن يسار، عن أبي ذر به. إسناده ضعيف؛ فيه عبد الله بن منيب، قال عنه ابن حجر في لسان الميزان ٥/٢٤: «روى عن الزهري أحاديث مكذوبة، وهو ضعيف». وأخرج إسحاق البستي ص١٥٠ نحوه من طريق يزيد بن أبي تميم، عن رجل من أصحاب رسول الله ﷺ.أخرجه ابن أبي شيبة ١٠/٣٢٢. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.عزاه السيوطي إلى عبد الله في زوائد الزهد.أخرجه أحمد في الزهد (٧٢)، وابن أبي الدنيا في كتاب الشكر (٥)، والبيهقي في شعب الإيمان (٤٤١٤).عزاه السيوطي إلى الفريابي، وابن أبي حاتم.أخرجه ابن أبي شيبة ١١/٥٥٣، وأحمد (٦٩).
34,14," <q>﴿فَلَمَّا قَضَیۡنَا عَلَیۡهِ ٱلۡمَوۡتَ مَا دَلَّهُمۡ عَلَىٰ مَوۡتِهِۦۤ إِلَّا دَاۤبَّةُ ٱلۡأَرۡضِ تَأۡكُلُ مِنسَأَتَهُۥۖ فَلَمَّا خَرَّ تَبَیَّنَتِ ٱلۡجِنُّ أَن لَّوۡ كَانُوا۟ یَعۡلَمُونَ ٱلۡغَیۡبَ مَا لَبِثُوا۟ فِی ٱلۡعَذَابِ ٱلۡمُهِینِ ۝١٤﴾</q> - قراءات ٦٣٢٢٢- قال سفيان: وفي قراءة ابن مسعود: (وهُمْ يَدْأبُونَ لَهُ حَوْلًا){1}. (١٢/١٨١) ٦٣٢٢٣- عن مُرَّة الهمذاني: أنّ في قراءة ابن مسعود: (فَمَكَثُواْ يَدْأَبُونَ لَهُ مِن بَعْدِ مَوْتِهِ حَوْلًا كامِلًا){2}. (ز) ٦٣٢٢٤- عن عبد الله بن عباس -من طريق قيس بن سعد- أنّه كان يقرأ: (فَلَمّا خَرَّ تَبَيَّنَتِ الإنسُ أن لَّوْ كانَ الجِنُّ يَعْلَمُونَ الغَيْبَ ما لَبِثُواْ فِي العَذابِ المُهِينِ).= (ز) ٦٣٢٢٥- قال قيس بن سعد: وهي في قراءة أُبَيِّ بن كعب كذلك{3}. (١٢/١٨٣) ٦٣٢٢٦- كان عبد الله بن عباس يقرأها: (فَتَبَيَّنَتِ الإنسُ أنَّ الجِنَّ لَوْ كانُواْ يَعْلَمُونَ الغَيْبَ ما لَبِثُواْ حَوْلًا فِي العَذابِ المُهِينِ){4}. (١٢/١٨١) ٦٣٢٢٧- كان عبد الله بن عباس يقرأ: (فَلَمّا خَرَّ تَبَيَّنَتِ الإنسُ أن لَّوْ كانَ الجِنُّ يَعْلَمُونَ الغَيْبَ ما لَبِثُواْ فِي العَذابِ المُهِينِ سَنَةً){5}٥٣٠٣. (١٢/١٨١) ٥٣٠٣ علّق ابن جرير (١٩/٢٤٣) على قراءة ابن عباس، فقال: «و<q>﴿أن﴾</q>في قوله: <q>﴿أن لو كانوا﴾</q> في موضع رفع بـ(تبين)؛ لأن معنى الكلام: فلما خر تبين وانكشف أن لو كان الجن يعلمون الغيب ما لبثوا في العذاب المهين. وأما على التأويل الذي تأوله ابن عباس من أن معناه: تبينت الإنس الجن. فإنه ينبغي أن تكون<q>﴿أن﴾</q> في موضع نصب بتكريرها على <q>﴿الجن﴾</q>، وكذلك يجب على هذه القراءة أن تكون <q>﴿الجن﴾</q> منصوبة، غير أني لا أعلم أحدًا من قرأة الأمصار يقرأ ذلك بنصب <q>﴿الجن﴾</q>، ولو نُصبت كان في قوله: <q>﴿تبينت﴾</q> ضمير من ذكر الإنس». <q>﴿فَلَمَّا قَضَیۡنَا عَلَیۡهِ ٱلۡمَوۡتَ﴾</q> - تفسير ٦٣٢٢٨- عن عبد الله بن مسعود، <q>﴿فَلَمّا قَضَيْنا عَلَيْهِ المَوْتَ﴾</q> الآية، قال: مكث سليمانُ بنُ داود حولًا على عصاه مُتَّكِئًا، حتى أكلتها الأرَضَةُ، فخرَّ{6}. (١٢/١٨٥) ٦٣٢٢٩- عن عطاء -من طريق جرير- قال: كان سليمان بن داود يصلي، فمات وهو قائم يصلي، والجن يعملون لا يعلمون بموته، حتى أكلت الأرَضَة عصاه، فخرَّ{7}. (ز) ٦٣٢٣٠- عن إسماعيل السُّدِّيّ: <q>﴿فَلَمّا قَضَيْنا عَلَيْهِ المَوْتَ﴾</q>، يعني: فلما أنزلنا عليه الموت{8}. (ز) ٦٣٢٣١- قال مقاتل بن سليمان: <q>﴿فَلَمّا قَضَيْنا عَلَيْهِ﴾</q> على سليمان <q>﴿المَوْتَ﴾</q> وذلك أنّ سليمان ﵇ كان دخل في السن، وهو في بيت المقدس{9}. (ز) <q>﴿مَا دَلَّهُمۡ عَلَىٰ مَوۡتِهِۦۤ إِلَّا دَاۤبَّةُ ٱلۡأَرۡضِ﴾</q> - تفسير ٦٣٢٣٢- عن عبد الله بن عباس -من طريق علي- <q>﴿دابَّةُ الأَرْضِ﴾</q>: الأرَضَة{10}. (١٢/١٨١) ٦٣٢٣٣- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿إلّا دابَّةُ الأَرْضِ﴾</q>، قال: الأرَضَة{11}. (١٢/١٨٥) ٦٣٢٣٤- عن قتادة بن دعامة: قال: الأرَضَة{6}. (١٢/١٨٥) ٦٣٢٣٥- قال مقاتل بن سليمان: <q>﴿ما دَلَّهُمْ﴾</q> ما دل الجنَّ <q>﴿عَلى مَوْتِهِ﴾</q> على موت سليمان <q>﴿إلّا دابَّةُ الأَرْضِ﴾</q> يعني: الأرَضَة{13}٥٣٠٤. (ز) ٥٣٠٤ قال ابنُ عطية (٧/١٧٠): «وقال كثير من المفسرين: <q>﴿دابَّةُ الأَرْضِ﴾</q> هي سوسة العود، وهي الأرَضَة، وقرأ ابن عباس والعباس بن المفضل: (الأَرَضِ) بفتح الراء، جمع: أرضة، فهذا يقوي ذلك التأويل». ثم ذكر في معنى الآية قولين آخرين، فقال: «وقالت فرقة: <q>﴿دابة الأرض﴾</q> حيوان مِن الأرض شأنه أن يأكل العود، وذلك موجود، وليس السوسة من دواب الأرض. وقالت فرقة منها أبو حاتم اللغوي: <q>﴿الأرض﴾</q> هنا مصدر: أرضت الأثواب والخشبة؛ إذا أكلتها الأرضة، فكأنه قال: دابة الأكل الذي هو بتلك الصورة على جهة التسوس». <q>﴿تَأۡكُلُ مِنسَأَتَهُۥۖ﴾</q> - قراءات ٦٣٢٣٦- عن هارون [بن موسى الأعور] -من طريق النضر-: <q>﴿تَأْكُلُ مِنسَأَتَهُ﴾</q> مهموزة.= (ز) ٦٣٢٣٧- وكان أبو عمرو يهمزها ثم ترك الهمز، وكلاهما عربية، والمنسأ: العصا{14}. (ز) <q>﴿تَأۡكُلُ مِنسَأَتَهُۥۖ﴾</q> - تفسير ٦٣٢٣٨- عن عبد الله بن عباس -من طريق علي- <q>﴿مِنسَأَتَهُ﴾</q>: عصاه{10}. (١٢/١٨١) ٦٣٢٣٩- عن عبد الله بن عباس، قال: لبث سليمانُ على عصاه حولًا بعدما مات، ثم خرّ على رأس الحول، فأخذت الجن عصًا مثل عصاه، ودابةً مثل دابته، فأرسلوها عليها، فأكلتها في سنة، وكان ابن عباس يقرأ: (فَلَمّا خَرَّ تَبَيَّنَتِ الإنسُ أن لَّوْ كانَ الجِنُّ يَعْلَمُونَ الغَيْبَ ما لَبِثُواْ فِي العَذابِ المُهِينِ سَنَةً) قال سفيان: وفي قراءة ابن مسعود: (وهُمْ يَدْأَبُونَ لَهُ حَوْلًا){16}. (١٢/١٨١) ٦٣٢٤٠- عن عبد الله بن عباس -من طريق قيس بن سعد- قال: كانت الإنس تقول في زمن سليمان: إنّ الجن تعلم الغيب. فلمّا مات سليمان مكث قائمًا على عصاه ميِّتا حولًا، والجن تعمل بقيامه، (فَلَمّا خَرَّ تَبَيَّنَتِ الإنسُ أن لَّوْ كانَ الجِنُّ يَعْلَمُونَ الغَيْبَ ما لَبِثُواْ فِي العَذابِ المُهِينِ سَنَةً) كان ابن عباس يقرؤها كذلك{16}. (١٢/١٨٣) ٦٣٢٤١- عن عبد الله بن عباس، قال: <q>﴿تَأْكُلُ مِنسَأَتَهُ﴾</q> بلغت نصف العصا، فتركوها في النصف الباقي، فأكلتها في حَوْل، فقالوا: مات عام أول{18}. (١٢/١٨٥) ٦٣٢٤٢- عن سعيد بن جبير، <q>﴿تَأْكُلُ مِنسَأَتَهُ﴾</q>، قال: العصا{6}. (١٢/١٨٥) ٦٣٢٤٣- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿تَأْكُلُ مِنسَأَتَهُ﴾</q>، قال: عصاه{20}. (١٢/١٨٥) ٦٣٢٤٤- عن عكرمة مولى ابن عباس: <q>﴿تَأْكُلُ مِنسَأَتَهُ﴾</q>، أنّه سُئِل عن المنسأة. قال: هي العصا. وأنشد فيها شعرًا قاله عبد المطلب: أمن أجلِ حبْلٍ لا أبا لك صِدْتَه بمنسأة قد جر حبْلك أحبُلا{18}. (١٢/١٨٥) ٦٣٢٤٥- عن قتادة بن دعامة -من طريق سعيد- <q>﴿تَأْكُلُ مِنسَأَتَهُ﴾</q>، قال: الأرَضَة أكلت عصاه حتى خرَّ{22}. (١٢/١٨٥) ٦٣٢٤٦- عن قتادة بن دعامة -من طريق سعيد- قال: كانت الجِنُّ تخبر الإنسَ أنهم يعلمون من الغيب أشياء، وأنهم يعلمون ما في غدٍ، فابتُلوا بموت سليمان، فمات، فلبث سنة على عصاه وهم لا يشعرون بموته، وهم مُسَخَّرون تلك السنة، ويعملون دائبين، <q>﴿فَلَمّا خَرَّ تَبَيَّنَتِ الجِنُّ﴾</q>، وفي بعض القراءة: (تَبَيَّنَتِ الإنسُ أن لَّوْ كانَ الجِنُّ يَعْلَمُونَ الغَيْبَ ما لَبِثُواْ فِي العَذابِ المُهِينِ)، وقد لبثوا يدأبون ويعملون له حولًا بعد موته{23}. (١٢/١٨٣) ٦٣٢٤٧- عن إسماعيل السُّدِّيّ -من طريق أسباط- قال: المنسأة: العصا. بلسان الحبشة{24}. (١٢/١٨٥) ٦٣٢٤٨- عن عطاء الخراساني -من طريق يونس بن يزيد- في قوله: <q>﴿منسأته﴾</q>، قال: عصاه{25}. (ز) ٦٣٢٤٩- قال مقاتل بن سليمان: وذلك أنّ الجِنَّ كانوا يُخْبِرُون الإنسَ أنّهم يعلمون الغيب الذي يكون في غدٍ، فابتُلوا بموت سليمان ببيت المقدس، وكان داود أسَّسَ بيتَ المقدس موضع فسطاط موسى ﵇، فمات قبل أن يُبْنى، فبناه سليمان بالصَّخر والقار، فلما حضره الموت قال لأهله: لا تخبروا الجِنَّ بموتي حتى يفرغوا مِن بناء بيت المقدس. وكان قد بقي منه عملَ سنة، فلما حضره الموت وهو مُتَّكِئٌ على عصاه، وقد أوصى أن يُكتم موته، وقال: لا تبكوا عَلَيَّ سنةً؛ لِئَلّا يتفرق الجنُّ عن بناء بيت المقدس. ففعلوا، فلما بنوا سنة وفرغوا مِن بنائه سلَّط الله ﷿ عليه الأَرَضَة عند رأس الحوْل على أسفل عصاه، فأكلته <q>﴿تَأْكُلُ مِنسَأَتَهُ﴾</q> أسفل العصا، فخرَّ عند ذلك سليمان ميتًا، فرأته الجنُّ، فتفرقت، <q>﴿فَلَمّا خَرَّ تَبَيَّنَتِ الجِنُّ﴾</q> يعنى: تبينت الإنس أن لو كانوا الجن <q>﴿يَعْلَمُونَ الغَيْبَ﴾</q> يعني: غيب موت سليمان <q>﴿ما لَبِثُوا﴾</q> حولًا <q>﴿فِي العَذابِ المُهِينِ﴾</q> والشقاء والنصَب في بيت المقدس. وإنما سُمُّوا الجن لأنهم استخفوا مِن الإنس فلم يروهم{13}. (ز) ٦٣٢٥٠- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- <q>﴿تَأْكُلُ مِنسَأَتَهُ﴾</q>: المنسأة: العصا{24}. (ز) ٦٣٢٥١- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- قال: قال سليمان لملك الموت: إذا أُمِرتَ بي فأعلِمني. فأتاه، فقال: يا سليمان، قد أُمِرتُ بك، قد بقيتْ لك سُوَيْعَةٌ. فدعا الشياطينَ، فبنوا عليه صَرْحًا مِن قوارير ليس له باب، فقام يصلي، فاتَّكأ على عصاه، فدخل عليه ملك الموت، فقبضَ روحه وهو متكئ على عصاه، ولم يصنع ذلك فرارًا مِن ملَك الموت. قال: والجِنُّ تعمل بين يديه وينظرون إليه، يحسبون أنه حي، فبعث الله دابة الأرض؛ دابةٌ تأكل العيدان يُقال لها: القادح. فدخلتْ فيها، فأكلتها، حتى إذا أكلتْ جوف العصا ضعُفتْ، وثقل عليها، فخرّ ميتًا، فلما رأت ذلك الجن انفَضُّوا وذهبوا، فذلك قوله: <q>﴿ما دَلَّهُمْ عَلى مَوْتِهِ إلّا دابَّةُ الأَرْضِ تَأْكُلُ مِنسَأَتَهُ﴾</q>{28}. (١٢/١٨٣) ٦٣٢٥٢- قال يحيى بن سلّام: مكث حولًا وهو مُتَوَكِّئ على عصاه، لا يرى الجِنُّ والإنسُ إلا أنّه حيٌّ على حاله الأول؛ لتعظُم الآية، بمنزلة ما أذهب الله مِن عملهم تلك الأربعين الليلة التي غاب عنها سليمان عن مُلْكِه، حيث خلَفه ذلك الشيطانُ في ملكه، وكان موتُه فجأةً وهو مُتَوَكِّئٌ على عصاه حولًا لا يعلمون أنه مات، وذلك أن الشياطين كانت تزعم للإنس أنهم يعلمون الغيب، فكانوا يعملون له حولًا لا يعلمون أنه مات، قال ﷿: <q>﴿فَلَمّا خَرَّ﴾</q> سقط لَمّا أكلتِ الأَرَضَةُ العَصا خرَّ سليمان، فقال: <q>﴿فَلَمّا خَرَّ تَبَيَّنَتِ الجِنُّ﴾</q> للإنس <q>﴿أنْ لَوْ كانُوا يَعْلَمُونَ الغَيْبَ ما لَبِثُوا فِي العَذابِ المُهِينِ﴾</q> في تلك السُّخرة؛ في تلك الأعمال في السلاسل، تبين للإنس أن الجن لو كانوا يعلمون الغيب ما لبثوا في العذاب المهين{29}. (ز) <q>﴿فَلَمَّا قَضَیۡنَا عَلَیۡهِ ٱلۡمَوۡتَ مَا دَلَّهُمۡ عَلَىٰ مَوۡتِهِۦۤ إِلَّا دَاۤبَّةُ ٱلۡأَرۡضِ تَأۡكُلُ مِنسَأَتَهُۥۖ فَلَمَّا خَرَّ تَبَیَّنَتِ ٱلۡجِنُّ أَن لَّوۡ كَانُوا۟ یَعۡلَمُونَ ٱلۡغَیۡبَ مَا لَبِثُوا۟ فِی ٱلۡعَذَابِ ٱلۡمُهِینِ ۝١٤﴾</q> - تفسير ٦٣٢٥٣- عن عبد الله بن عباس، عن النبي ﷺ، قال: «كان سليمانُ إذا صلّى رأى شجرةً نابتة بين يديه، فيقول لها: ما اسمُكِ؟ فتقول: كذا وكذا. فيقول: لِمَ أنتِ؟ فتقول: لكذا وكذا. فإن كانت لغرْسٍ غُرست، وإن كانت لدواء كُتِبَت، فصلّى ذات يوم، فإذا شجرة نابتة بين يديه، فقال لها: ما اسمك؟ قالت: الخروب. قال: لأي شيء أنتِ؟ قالت: لخراب هذا البيت. فقال سليمان: اللهم، عمِّ عنِ الجن موتي، حتى يعلم الإنسُ أنّ الجن لا يعلمون الغيب. فهيّأ عصًا، فتوكأ عليها، وقبضه الله وهو متكئ، فمكث حولًا ميتًا والجن تعمل، فأكلتها الأرَضَة، فسقطت، فعلموا عند ذلك بموته، (فَتَبَيَّنَتِ الإنسُ أنَّ الجِنَّ لَوْ كانُوا يَعْلَمُونَ الغَيْبَ ما لَبِثُوا حَوْلًا فِي العَذابِ المُهِينِ) -وكان ابن عباس يقرأها كذلك-، فشكرت الجنُّ الأَرَضَة، فأينما كانت يأتونها بالماء»{30}. (١٢/١٨١) ٦٣٢٥٤- عن عبد الله بن عباس -من طريق سعيد بن جبير-، موقوفًا{31}. (١٢/١٨٢) ٦٣٢٥٥- عن عبد الله بن مسعود، وناس من أصحاب رسول الله ﷺ -من طريق السُّدِّيّ، عن مرة الهمداني-= (ز) ٦٣٢٥٦- وعبد الله بن عباس -من طريق السُّدِّيّ، عن أبي مالك وأبي صالح- قالوا: كان سليمان يَتَجَرَّدُ في بيت المقدس السنة والسنتين، والشهر والشهرين، وأقل من ذلك وأكثر، يُدخل طعامه وشرابه، فدخله في المرة التي مات فيها، فكان بدء ذلك أنه لم يكن يوم يصبح فيه إلا تنبت في بيت المقدس شجرة، فيأتيها، فيسألها: ما اسمكِ؟ فتقول الشجرة: اسمي كذا وكذا. فيقول لها: لأيِّ شيء نبتِّ{32}؟ فتقول: نبتُّ لكذا وكذا. فيأمر بها فتُقطع، فإن كانت نبتتْ لغرسٍ غرسها، وإن كانت نبتت لدواء، قالت: نبتُ دواء لكذا وكذا. فيجعلها كذلك، حتى نبتت شجرة يقال لها الخروبة، فسألها: ما اسمكِ؟ فقالت له: أنا الخروبة. فقال: لأي شيء نبتِّ؟ قالت: لخراب هذا المسجد. قال سليمان: ما كان الله لِيُخَرِّبه وأنا حي، أنتِ التي على وجهكِ هلاكي وخراب بيت المقدس. فنزعها، وغرسها في حائط له، ثم دخل المحراب، فقام يصلي مُتَّكئًا على عصاه، فمات ولا تعلم به الشياطين في ذلك، وهم يعملون له يخافون أن يخرج فيعاقبهم، وكانت الشياطين تجتمع حول المحراب، وكان المحراب له كُوًى بين يديه وخلفه، وكان الشيطان الذي يريد أن يَخْلَعَ{33} يقول: ألستُ جليدًا{34} إن دخلتُ فخرجتُ من الجانب الآخر. فيدخل حتى يخرج من الجانب الآخر، فدخل شيطان من أولئك فمرَّ، ولم يكن شيطان ينظر إلى سليمان في المحراب إلا احترق، فمرَّ ولم يسمع صوت سليمان ﵇، ثم رجع فلم يسمع، ثم رجع فوقع في البيت فلم يحترق، ونظر إلى سليمان قد سقط، فخرج فأخبر الناس أن سليمان قد مات، ففتحوا عنه، فأخرجوه، ووجدوا منسأته -وهي العصا بلسان الحبشة- قد أكلتها الأرَضَة، ولم يعلموا منذ كم مات، فوضعوا الأرَضَة على العصا، فأكلت منها يوما وليلة، ثم حسبوا على ذلك النحو، فوجدوه قد مات منذ سنة، وهي في قراءة ابن مسعود: (فَمَكَثُوا يَدْأَبُونَ لَهُ مِن بَعْدِ مَوْتِهِ حَوْلًا كامِلًا). فأيقن الناس عند ذلك أن الجن كانوا يكذِبونهم، ولو أنهم علموا الغيب لعلموا بموت سليمان، ولم يلبثوا في العذاب سنةً يعملون له، وذلك قول الله: <q>﴿ما دَلَّهُمْ عَلى مَوْتِهِ إلّا دابَّةُ الأَرْضِ تَأْكُلُ مِنسَأَتَهُ فَلَمّا خَرَّ تَبَيَّنَتِ الجِنُّ أنْ لَوْ كانُوا يَعْلَمُونَ الغَيْبَ ما لَبِثُوا فِي العَذابِ المُهِينِ﴾</q> يقول: تبيّن أمرهم للناس أنهم كانوا يكذِبونهم، ثم إن الشياطين قالوا للأرضة: لو كنتِ تأكلين الطعام أتيناكِ بأطيب الطعام، ولو كنتِ تشربين الشراب سقيناكِ أطيب الشراب، ولكنا سننقل إليك الماء والطين. فالذي يكون في جوف الخشب فهو ما تأتيها به الشياطينُ شكرًا لها{35}٥٣٠٥. (١٢/١٧٩) ٥٣٠٥ علّق ابنُ كثير (١١٦/٢٦٩) على هذا الأثر فقال: «وهذا الأثر -والله أعلم-إنّما هو مما تلقي من علماء أهل الكتاب، وهي وقف، لا يصدق منها إلا ما وافق الحق، ولا يكذب منها إلا ما خالف الحق، والباقي لا يصدق ولا يكذب». ٦٣٢٥٧- عن عبد الله بن شداد -من طريق خالد بن حصين- قال: قيل لسليمان -صلى الله عليه-: إنّ آية موتك أن ينبت في بيت المقدس شجرةٌ يُقال لها: الخروبة، فإذا نبتَ فهو آيةُ موتِك، فبينا هو كذلك إذ خرجت شجرة، فقال لها: ما اسمكِ؟ قالت: أنا الخروبة. فدخل المحراب، فقام على عصاه، فقُبض وهو على عصاه، فخرجت دابة من الأرض، فأكلت عصاه، فخَرَّ، فـ<q>﴿تبينت الجن أن لو كانوا يعلمون الغيب ما لبثوا في العذاب المهين﴾</q>{36}٥٣٠٦. (ز) ٥٣٠٦ نقل ابنُ عطية (٧/١٧١) إضافة إلى ما ورد في آثار السلف في قصة موت سليمان ﵇ قولًا آخر، فقال: «وقال بعض الناس: إن سليمان ﵇ لم يمت إلا في سفر مضطجعًا، ولكنه كان في بيت مبني عليه، وأكلت الأرَضَة عتبة الباب حتى خرَّ البيت؛ فعُلم موته». وانتقده بقوله: «وهذا ضعيف». ثمَّ قال ابن عطية عقب هذا: «وأكثرَ المفسرون في قصص هذه الآية بما لا صحة له، ولا تقتضيه ألفاظ القرآن، وفي معانيه بُعْدٌ، فاختصرته لذلك». ٦٣٢٥٨- عن عكرمة مولى ابن عباس -من طريق أيوب- قال: لَمّا ردّ الله الخاتم إليه لم يُصَلِّ صلاة الصبح يومًا إلا نظر وراءَه، فإذا هو بشجرة خضراء تهتز، فيقول: يا شجرة، أما يأكلك جِنٌّ ولا إنس ولا طير ولا هوام ولا بهائم؟ فتقول: إنِّي لم أُجعل رزقًا لشيء، ولكن دواء مِن كذا، ودواء من كذا. فقام الجن والإنس يقطعونها، ويجعلونها في الدواء، فصلى الصبح ذات يوم والتفت، فإذا بشجرة وراءه، قال: مَن أنتِ، يا شجرة؟ قالت: أنا الخرنوبة. قال: واللهِ، ما الخرنوبة إلا خراب بيت المقدس، واللهِ ما يُخرّب ما كنت حيًّا، ولكني أموت. فدعا بحنوط، فتحنّط وتكفَّن، ثم جلس على كرسيه، ثم جمع كفيه على طرف عصاه، ثم جعلها تحت ذقنه، ومات، فمكث الجن يعملون سنة يحسبون أنه حي، وكانت لا ترفع أبصارها إليه، وبعث الله الأرَضَة، فأكلت طرف العصا، فخَرَّ مُنكَبًّا على وجهه، فعلمتُ الجنُّ أن قد مات، فذلك قوله: <q>﴿تَبَيَّنَتِ الجِنُّ﴾</q> ولقد كانت الجن تعلم أنها لا تعلم الغيب، ولكن في القراءة الأولى: (تَبَيَّنَتِ الإنسُ أن لَّوْ كانَ الجِنُّ يَعْلَمُونَ الغَيْبَ ما لَبِثُوا فِي العَذابِ المُهِينِ){37}٥٣٠٧. (١٢/١٨٤) ٥٣٠٧ قال ابنُ عطية (٧/١٧١-١٧٢): «وقرأ الجمهور <q>﴿تَبَيَّنَتِ الجِنُّ﴾</q> بإسناد الفعل إليها، أي: بان أمرُها، كأنه قال: افتضحت الجنُّ، أي: للإنس، هذا تأويل. ويحتمل أن يكون قوله: <q>﴿تَبَيَّنَتِ الجِنُّ﴾</q> بمعنى: علمت الجن وتحققت، ويريد بالجِنّ: جمهورهم والفَعَلة منهم والخَدَمة، ويريد بالضمير في <q>﴿كانُوا﴾</q>: رؤساءهم وكبارهم؛ لأنهم هم الذين يدعون علم الغيب لأتباعهم من الجن والإنس ويوهمونهم ذلك. قاله قتادة، فتبين الأتباع أن الرؤوس لَوْ كانُوا عالمين الغيب ما لَبِثُوا، و<q>﴿أنْ﴾</q> على التأويل الأول بدل من <q>﴿الجِنُّ﴾</q>، وعلى التأويل الثاني مفعولة محضة، وقرأ يعقوب: (تُبُيِّنَتُ الجِنُّ) على بناء الفعل للمفعول، أي: تبينها الناس، و<q>﴿أنْ﴾</q> على هذه القراءة بدل، ويجوز أن تكون في موضع نصب بإسقاط حرف الجر، أي: بأن، على هذه القراءة، وعلى التأويل الأول من القراءة الأولى». ",footnotes:1:عزاه السيوطي إلى سعيد بن منصور، وعبد بن حميد، وابن المنذر، وابن أبي حاتم. وهي قراءة شاذة. انظر: فتح القدير ٤/٤٢١.أخرجه ابن جرير ١٩/٢٤١-٢٤٢. وهي قراءة شاذة. انظر: الكشف والبيان ٨/٨١.عزاه السيوطي إلى عبد بن حميد. وهي قراءة شاذة. انظر: الجامع لأحكام القرآن ١٧/٢٨٥.أخرجه البزار (٢٣٥٥- كشف)، وابن جرير ١٩/٢٤٠ بنحوه، وابن أبي حاتم -كما في تفسير ابن كثير ٦/٤٩٠-، والطبراني (١٢٢٨١). وعزاه السيوطي إلى ابن السني في الطب النبوي، وابن المنذر، وابن مردويه. وهي قراءة شاذة.عزاه السيوطي إلى سعيد بن منصور، وعبد بن حميد، وابن المنذر، وابن أبي حاتم. وهي قراءة شاذة.عزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ١٩/٢٤٣.علقه يحيى بن سلام ٢/٧٥١.تفسير مقاتل بن سليمان ٣/٥٢٧.أخرجه ابن جرير ١٩/٢٣٧، وبنحوه من طريق العوفي، وابن أبي حاتم -كما في التغليق ٤/٣١-. وعزاه السيوطي إلى ابن المنذر.تفسير مجاهد (٥٥٣)، وأخرجه ابن جرير ١٩/٢٣٧. وعلَّقه يحيى بن سلام ٢/٧٥١ من طريق عاصم بن حكيم. وعزاه السيوطي إلى عبد بن حميد، والفريابي.عزاه السيوطي إلى عبد بن حميد.تفسير مقاتل بن سليمان ٣/٥٢٧-٥٢٨.أخرجه إسحاق البستي ص١٥٠. وكلاهما قراءة متواترة، فوافقها على ترك الهمز نافع، وأبو جعفر، ووافقه على الهمز بقية العشرة، إلا أنه اختلف فيه عن هشام فله الوجهان. انظر: النشر ٢/٣٤٩-٣٥٠، والإتحاف ص٤٥٨.أخرجه ابن جرير ١٩/٢٣٧، وبنحوه من طريق العوفي، وابن أبي حاتم -كما في التغليق ٤/٣١-. وعزاه السيوطي إلى ابن المنذر.تقدم في قراءات الآية.تقدم في قراءات الآية.عزاه السيوطي إلى عبد بن حميد، وابن المنذر.عزاه السيوطي إلى عبد بن حميد.تفسير مجاهد (٥٥٣)، وأخرجه ابن جرير ١٩/٢٣٧، ومن طريق أبي يحيى ١٩/٢٣٨. وعلَّقه يحيى بن سلام ٢/٧٥١ من طريق عاصم بن حكيم. وعزاه السيوطي إلى عبد بن حميد، والفريابي.عزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه ابن جرير ١٩/٢٣٨، وعبد الرزاق ٢/١٢٨ من طريق معمر مختصرًا. وعزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ١٩/٢٤٢، وعبد الرزاق ٢/١٢٨ مختصرًا من طريق معمر. وعزاه السيوطي إلى عبد بن حميد. كما أخرجه ابن أبي حاتم ٩/٢٩١٣ مطولًا وفي آخره: وهي في مصحف ابن مسعود: (تَبَيَّنَتِ الإنسُ والجِنُّ لَوْ كانُوا يَعْلَمُونَ الغَيْبَ ما لَبِثُوا فِي العَذابِ المُهِينِ)، وكانت الجن تقول قبل ذلك أنها تعلم الغيب، وتعلم ما في غد، فابتلاهم الله بذلك، وجعل موت سليمان للجن عِظَةً.أخرجه ابن جرير ١٩/٢٣٨.أخرجه أبو جعفر الرملي في جزئه ص٨٩ (تفسير عطاء الخراساني).تفسير مقاتل بن سليمان ٣/٥٢٧-٥٢٨.أخرجه ابن جرير ١٩/٢٣٨.أخرجه ابن جرير ١٩/٢٤٣. وعزاه السيوطي إلى ابن أبي حاتم.تفسير يحيى بن سلام ٢/٧٥١-٧٥٢.أخرجه الحاكم ٤/٢١٩ (٧٤٢٨)، ٤/٤٤٦ (٨٢٢٢)، وابن جرير ١٩/٢٤٠. قال الحاكم: «هذا حديث صحيح الإسناد، ولم يخرجاه». وقال ابن كثير في تفسيره ٦/٥٠٢: «حديث مرفوع غريب، وفي صحّته نظر ... وفي رفعه غرابة ونكارة، والأقرب أن يكون موقوفًا، وعطاء بن أبي مسلم الخراساني له غرابات، وفي بعض حديثه نكارة». وقال الألباني في الضعيفة ١٤/١١٦٧ (٦٥٧٣): «ضعيف».أخرجه البزار (٢٣٥٦- كشف)، والحاكم ٤/١٩٧-١٩٨.هكذا في المصادر.أي يخرجُ عن الطّاعة. النهاية (خلع).الجليد: القوي الصُلب. اللسان (جلد).أخرجه ابن جرير ١٩/٢٤١-٢٤٢. وعزاه السيوطي إلى ابن أبي حاتم موقوفًا على السُّدِّيّ من قوله.أخرجه محمد بن نصر في تعظيم قدر الصلاة ١/٢٢٥.أخرجه عبد الرزاق ٢/١٢٨. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.
