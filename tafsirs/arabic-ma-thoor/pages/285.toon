tafsir[11]{c,v,t}:
17,28," <q>﴿وَإِمَّا تُعۡرِضَنَّ عَنۡهُمُ ٱبۡتِغَاۤءَ رَحۡمَةࣲ مِّن رَّبِّكَ تَرۡجُوهَا فَقُل لَّهُمۡ قَوۡلࣰا مَّیۡسُورࣰا ۝٢٨﴾</q> - نزول الآية ٤٢٩٠٦- عن عطاء الخراسانيِّ، قال: جاء ناس مِن مُزَينة يَسْتَحمِلون رسولَ الله ﷺ، فقال: <q>﴿لا أجد ما أحمِلُكُم عليه﴾</q>، <q>﴿تَوَلَّوا وأعيُنُهم تفِيض من الدمع حزنًا﴾</q> [التوبة: ٩٢]، ظنوا ذلك من غضب رسول الله ﷺ عليهم؛ فأنزل الله: <q>﴿وإمّا تُعرِضَنَّ عنهم ابتغاء رحمة من ربك﴾</q> الآية. قال: الرحمة: الفيء{1}. (٩/٣٢٣) ٤٢٩٠٧- عن الضحاك بن مزاحم -من طريق عبيد بن سليمان- في قوله: <q>﴿وإما تعرضن عنهم ابتغاء رحمة من ربك﴾</q>: نزلت فيمن كان يسأل النبي ﷺ من المساكين{2}. (٩/٣٢٣) ٤٢٩٠٨- عن إسماعيل السُّدِّيّ، في الآية، قال: كان ناسٌ من بني عبد المطلب يأتون النَّبي ﷺ يسألونه، فإذا صادفوا عنده شيئًا أعطاهم، وإن لم يصادفوا عنده شيئًا سكت، ولم يقُل لهم: نعم. ولا: لا. والقُربى: قُربى بني عبد المطلب{3}. (٩/٣١٧) ٤٢٩٠٩- قال مقاتل بن سليمان: <q>﴿وإما تعرضن عنهم﴾</q>، نزلت في خباب، وبلال، ومهجع، وعمار، ونحوهم من الفقراء، كانوا يسألون النبى ﷺ، فلا يجد ما يعطيهم، فيعرض عنهم، فيسكت{4}. (ز) <q>﴿وَإِمَّا تُعۡرِضَنَّ عَنۡهُمُ﴾</q> - تفسير ٤٢٩١٠- عن عبد الله بن عباس: <q>﴿وإمّا تُعِرَضَّن عنهم﴾</q>، يقول: تُمْسِك عن عطائهم{5}. (٩/٣٢١) ٤٢٩١١- عن مجاهد بن جبر -من طريق ابن جريج-: إن سألوك فلم يكن عندك ما تعطيهم، فأعرضت عنهم <q>﴿ابتغاء رحمة﴾</q> قال: رزق تنتظره؛ <q>﴿فقل لهم قولا ميسورا﴾</q>{6}. (ز) ٤٢٩١٢- عن عكرمة مولى ابن عباس -من طريق ابن جريج- قوله: <q>﴿وإما تعرضن عنهم ابتغاء رحمة من ربك ترجوها﴾</q>، قال: إن سألوك فلم يجدوا عندك ما تعطيهم ابتغاء رحمة، قال: رزق تنتظره؛ ترجوه{6}. (ز) ٤٢٩١٣- قال مقاتل بن سليمان: ثم رجع إلى المسكين وابن السبيل، فقال: <q>﴿وإما تعرضن عنهم﴾</q>{4}. (ز) ٤٢٩١٤- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿وإما تعرضن عنهم﴾</q>: عن هؤلاء الذين أوْصَيْناك بهم{9}. (ز) <q>﴿ٱبۡتِغَاۤءَ رَحۡمَةࣲ مِّن رَّبِّكَ تَرۡجُوهَا﴾</q> - تفسير ٤٢٩١٥- عن عبد الله بن عباس، في قوله: <q>﴿وءات ذا القربى حقه﴾</q>، قال: أمَره بأحقّ الحقوق، وعَلَّمه كيف يصنع إذا كان عنده، وكيف يصنع إذا لم يكن، فقال: <q>﴿وإمّا تُعرِضَنَّ عنهم ابتغاء رحمة من ربك﴾</q> قال: إذا سألوك وليس عندك شيء انتظرت رزقًا مِن الله، <q>﴿فقل لهم قولًا ميسورًا﴾</q>: يكون إن شاء الله. «يكون» شِبْهُ العِدَة. قال سفيان: العِدَةُ مِن النبي ﷺ دَين{10}. (٩/٣١٦) ٤٢٩١٦- عن عبد الله بن عباس -من طريق عطاء الخراساني- <q>﴿ابتغاء رحمة من ربك﴾</q>، قال: رزق، <q>﴿أهم يقسمون رحمة ربك نحن قسمنا بينهم معيشتهم﴾</q> [الزخرف:٣٢]{6}. (٩/٣٢٣) ٤٢٩١٧- عن عَبيدة السلماني -من طريق أبي الضُّحى- في قوله: <q>﴿ابتغاء رحمة من ربك ترجوها﴾</q>، قال: ابتغاء الرِّزق{2}. (ز) ٤٢٩١٨- عن سعيد بن جبير -من طريق عطاء- <q>﴿وإما تعرضن عنهم ابتغاء رحمة من ربك ترجوها﴾</q>، قال: رِزْق تنتظره{2}. (ز) ٤٢٩١٩- عن إبراهيم النخعي -من طريق منصور- <q>﴿وإما تعرضن عنهم ابتغاء رحمة من ربك ترجوها﴾</q>، قال: انتظار الرزق{14}. (ز) ٤٢٩٢٠- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿وإمّا تُعرِضَنَّ عنهم ابتغاء رحمة من ربك ترجوها﴾</q>، قال: انتظار رزقِ الله{15}. (٩/٣٢٣) ٤٢٩٢١- عن الضحاك بن مزاحم -من طريق عبيد بن سليمان- في قوله: <q>﴿وإما تعرضن عنهم﴾</q> يقول: لا تجد شيئًا تعطيهم <q>﴿ابتغاء رحمة من ربك﴾</q> يقول: انتظار الرزق من ربك{2}. (٩/٣٢٣) ٤٢٩٢٢- عن عكرمة مولى ابن عباس -من طريق عمارة- في قوله: <q>﴿وإما تعرضن عنهم ابتغاء رحمة من ربك ترجوها﴾</q>، قال: انتظار رزقٍ مِن الله يأتيك{6}. (ز) ٤٢٩٢٣- قال مقاتل بن سليمان: <q>﴿ابتغآء رحمة من ربك ترجوها﴾</q>، يعني: انتظار رزق مِن ربِّك{4}. (ز) ٤٢٩٢٤- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿وإما تعرضن عنهم﴾</q>: عن هؤلاء الذين أوصيناك بهم <q>﴿ابتغاء رحمة من ربك ترجوها﴾</q> إذا خشيت إن أعطيتهم أن يَتَقَوَّوا بها على معاصي الله، ويستعينوا بها عليها، فرأيت أن تمنعهم خيرًا، فإذا سألوك <q>﴿فقل لهم قولا ميسورا﴾</q>{9}٣٨٣٣. (ز) ٣٨٣٣ انتقد ابنُ جرير (١٤/٥٧٢) قول ابن زيد مستندًا إلى أقوال السلف، ومخالفة ظاهر الآية، فقال: «وهذا القول الذي ذكرناه عن ابن زيدٍ -مع خلافه أقوال أهل التأويل في تأويل هذه الآية- بعيدٌ بالمعنى مما يدل عليه ظاهرُها، وذلك أن الله تعالى قال لنبيه ﷺ: <q>﴿وإمّا تُعْرِضَنَّ عَنْهُمُ ابْتِغاءَ رَحْمَةٍ مِن رَبِّكَ تَرْجُوها﴾</q>، أمَره أن يقول إذا كان إعراضه عن القوم الذين ذكَرهم انتظار رحمةٍ منه يرجوها من ربه <q>﴿قَوْلا مَيْسُورًا﴾</q>، وذلك الإعراضُ ابتغاءَ الرحمة لن يَخْلُوَ من أحد أمرين: إما أن يكون إعراضًا منه ابتغاءَ رحمةٍ من الله يرجوها لنفسه، فيكونَ معنى الكلام كما قلناه، وقاله أهل التأويل الذين ذكرنا قولهم وخلافَ قوله، أو يكون إعراضًا منه ابتغاءَ رحمةٍ من الله يرجوها للسائلين الذين أُمِر نبيُّ الله ﷺ بزعمه أن يمنعهم ما سألوه خشيةً عليهم من أن ينفقوه في معاصي الله، فمعلومٌ أن سخط الله على من كان غير مأمونٍ منه صَرْفُ ما أُعْطِي من نفقةٍ ليتقوّى بها على طاعة الله في معاصيه أخوفُ من رجاء رحمته له، وذلك أن رحمة الله إنما تُرجى لأهل طاعته، لا لأهل معاصيه». غير أنه ذكر له وجْهًا يُمكِن أن يُحمَل عليه، وانتقده لمخالفته أقوال أهل التأويل، فقال: «إلا أن يكون أراد توجيه ذلك إلى أن نبيَّ الله ﷺ أُمِر بمنعهم ما سألوه ليُنِيبوا من معاصي الله، ويتوبوا بِمَنعِه إيّاهم ما سألوه، فيكونَ ذلك وجْهًا يَحْتَمِلُه تأويل الآية، وإن كان لقول أهل التأويل مخالفًا». ٤٢٩٢٥- قال يحيى بن سلّام: وأما قوله: <q>﴿ابتغاء رحمة من ربك ترجوها﴾</q>، يعني: انتظار رزق ربك{20}. (ز) <q>﴿فَقُل لَّهُمۡ قَوۡلࣰا مَّیۡسُورࣰا ۝٢٨﴾</q> - تفسير ٤٢٩٢٦- عن عبد الله بن عباس، في قوله: <q>﴿فقل لهم قولًا ميسورًا﴾</q>، قال: العِدَة. قال سفيان: والعِدَة من رسول الله دَيْن{21}. (٩/٣٢٤) ٤٢٩٢٧- عن عبد الله بن عباس: <q>﴿وإمّا تُعِرَضَّن عنهم﴾</q> يقول: تُمسك عن عطائهم؛ <q>﴿فقل لهم قولًا ميسورًا﴾</q> يعني: قولًا معروفًا: لعله أن يكون، عسى أن يكون{5}. (٩/٣٢١) ٤٢٩٢٨- عن عبد الله بن عباس -من طريق محمد بن أبى موسى- في قوله: <q>﴿وءات ذا القربى حقه﴾</q> الآية، قال: بدأ فأمره بأوجب الحقوق، ودَلَّه على أفضل الأعمال إذا كان عنده شيء، فقال: <q>﴿وءات ذا القربى حقه والمسكين وابن السبيل﴾</q>. وعلَّمه إذا لم يكن عنده شيء كيف يقول، فقال: <q>﴿وإمّا تُعرِضَنَّ عنهم ابتغاء رحمة من ربك ترجوها فقل لهم قولًا ميسورًا﴾</q>: عِدَةً حسنة، كأنه قد كان، ولعله أن يكون إن شاء الله{23}. (٩/٣١٧) ٤٢٩٢٩- عن سعيد بن جبير -من طريق عطاء- <q>﴿فقل لهم قولا ميسورا﴾</q>، قال: معروفًا{2}. (ز) ٤٢٩٣٠- عن إبراهيم النخعي -من طريق منصور- <q>﴿فقل لهم قولا ميسورا﴾</q>، قال: ليِّنًا، تعدهم{25}. (ز) ٤٢٩٣١- عن عكرمة مولى ابن عباس -من طريق عمارة- في قول الله: <q>﴿فقل لهم قولا ميسورا﴾</q>، قال: الرِّفْق{9}. (ز) ٤٢٩٣٢- عن عكرمة مولى ابن عباس -من طريق ابن جريج- قوله: <q>﴿فقل لهم قولا ميسورا﴾</q>، قال: عدهم عدة حسنة: إذا كان ذلك، إذا جاءنا ذلك فعلنا؛ أعطيناكم، فهو القول الميسور{6}. (ز) ٤٢٩٣٣- عن الحسن البصري في قوله: <q>﴿فقل لهم قولًا ميسورًا﴾</q>، قال: لَيِّنًا سهلًا: سيكون -إن شاء الله- فأفعل، سنُصِيبُ -إن شاء الله- فأفعل{28}. (٩/٣٢٤) ٤٢٩٣٤- عن قتادة بن دعامة -من طريق معمر- <q>﴿فقل لهم قولا ميسورا﴾</q>، قال: عِدْهُم خيرًا{29}. (ز) ٤٢٩٣٥- عن إسماعيل السُّدِّيّ، في قوله: <q>﴿فقل لهم قولًا ميسورًا﴾</q>، يقول: قل لهم: نعم وكرامة، وليس عندنا اليوم، فإن يأتِنا شيء نعرف حقَّكم{3}. (٩/٣٢٤) ٤٢٩٣٦- قال مقاتل بن سليمان: <q>﴿فقل لهم قولا ميسورا﴾</q>، يقول: ارْدُد عليهم معروفًا، يعني: العِدَة الحسنة؛ أنّه سيكون فأعطيكم{4}. (ز) ٤٢٩٣٧- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿قولًا ميسورًا﴾</q>، قال: قولًا جميلًا: رزقنا الله وإياك، بارك الله فيك{32}. (٩/٣٢٤) ٤٢٩٣٨- قال يحيى بن سلّام: وبلغني: أنّ قوله: <q>﴿فقل لهم قولا ميسورا﴾</q> أن تقول للسائل: رزقنا الله وإياك{33}. (ز) <q>﴿فَقُل لَّهُمۡ قَوۡلࣰا مَّیۡسُورࣰا ۝٢٨﴾</q> - آثار متعلقة بالآية ٤٢٩٣٩- عن أبي أمية، عن الحسن البصري: أنّ سائلًا قام، فقال: يا رسول الله، فقد بِتنا البارحة بغير عشاء، وما أمسينا الليلة نرجوه. فقال: «يرزقنا الله وإيّاك من فضله، اجلس». فجلس، ثم قام آخر، فقال مثل ذلك، فرد عليه رسول الله ﷺ مثل ذلك، فأُتِي رسولُ الله ﷺ بأربع أواقٍ مِن ذهب، فقال: «أين السائلان؟». فقام الرجلان، فأعطى كل واحد منهما أوقية، ولم يسأله أحد، فرجع بأوقيتين، فجعلهما تحت فراشه، فسهر ليلته بين فراشه ومسجده، فقالت أم المؤمنين: يا رسول الله، ما أسهرك؟ أوجَع أو أمر نزل؟ فقال: «أوتيت بأربع أواق، فأمضيت وقيتين، وبقيت وقيتان، فخشيت أن يحدث بي حدث ولم أوجههما»{34}. (ز) ٤٢٩٤٠- عن عائشة -من طريق عاصم بن حكيم، وأشعث، عن عاصم الأحول، عن قريبه- قالت: لا تقولوا للمسكين -وفي لفظ: للسائل-: بارك الله فيك؛ فإنه يسأل البرَّ والفاجر. -قال يحيى بن سلّام: يعني: الكافر- ولكن قولوا: يرزقك الله. وفي لفظ: يرزقنا الله وإياك{35}. (ز) ",footnotes:1:عزاه السيوطي إلى سعيد بن منصور، وابن المنذر.أخرجه ابن جرير ١٤/٥٧١.عزاه السيوطي إلى ابن أبي حاتم.تفسير مقاتل بن سليمان ٢/٥٢٩.عزاه السيوطي إلى ابن مَرْدويه.أخرجه ابن جرير ١٤/٥٧٠.أخرجه ابن جرير ١٤/٥٧٠.تفسير مقاتل بن سليمان ٢/٥٢٩.أخرجه ابن جرير ١٤/٥٧٢.عزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.أخرجه ابن جرير ١٤/٥٧٠.أخرجه ابن جرير ١٤/٥٧١.أخرجه ابن جرير ١٤/٥٧١.أخرجه ابن جرير ١٤/٥٦٩، وأخرج يحيى بن سلام ١/١٣٠ نحوه من طريق ابن مجاهد.أخرجه ابن جرير ١٤/٥٧٠-٥٧١. وعزاه السيوطي إلى ابن أبي حاتم.أخرجه ابن جرير ١٤/٥٧١.أخرجه ابن جرير ١٤/٥٧٠.تفسير مقاتل بن سليمان ٢/٥٢٩.أخرجه ابن جرير ١٤/٥٧٢.تفسير يحيى بن سلام ١/١٣١.عزاه السيوطي إلى ابن أبي حاتم، وابن مردويه.عزاه السيوطي إلى ابن مَرْدويه.أخرجه البخاري في الأدب المفرد (٥١). وعزاه السيوطي إلى ابن أبي حاتم.أخرجه ابن جرير ١٤/٥٧١.أخرجه ابن جرير ١٤/٥٦٩.أخرجه ابن جرير ١٤/٥٧٢.أخرجه ابن جرير ١٤/٥٧٠.عزاه السيوطي إلى ابن أبي حاتم. وأخرجه عبد الرزاق ٢/٣٧٧ من طريق معمر بلفظ: قل لهم قولًا لينًا وسهلًا، وعلقه ابن جرير ١٤/٥٧١ مختصرًا.أخرجه عبد الرزاق ٢/٣٧٦، وابن جرير ١٤/٥٧١.عزاه السيوطي إلى ابن أبي حاتم.تفسير مقاتل بن سليمان ٢/٥٢٩.أخرجه ابن جرير ١٤/٥٧٢ بلفظ: قولًا جميلًا: رزقك الله، بارك الله فيك. وعزاه السيوطي إلى ابن أبي حاتم.تفسير يحيى بن سلام ١/١٣٠.أخرجه يحيى بن سلام ١/١٣٠ مرسلًا.أخرجه يحيى بن سلام ١/١٣١.
17,29," <q>﴿وَلَا تَجۡعَلۡ یَدَكَ مَغۡلُولَةً إِلَىٰ عُنُقِكَ وَلَا تَبۡسُطۡهَا كُلَّ ٱلۡبَسۡطِ فَتَقۡعُدَ مَلُومࣰا مَّحۡسُورًا ۝٢٩﴾</q> - نزول الآية ٤٢٩٤١- عن عبد الله بن مسعود، قال: جاء غلام إلى النبي ﷺ، فقال: إنّ أمي تسألك كذا وكذا. فقال: «ما عندنا اليوم شيء». قال: فتقول لك: اكسُني قميصَك. فخلع قميصه، فدفع إليه، فجلس في البيت حاسِرًا؛ فأنزل الله: <q>﴿ولا تجعل يدك مغلولة﴾</q> الآية{1}. (٩/٣٢٥) ٤٢٩٤٢- عن المِنهال بن عمرو، قال: بَعثَت امرأةٌ إلى النَّبي ﷺ بابنها، فقالت: قل له: اكسُني ثوبًا. فقال: «ما عندي شيء». فقالت: ارجِع إليه، فقل له: اكسُني قميصك. فرجع إليه، فنزع قميصه، فأعطاه إيّاه؛ فنزلت: <q>﴿ولا تجعل يدك مغلولة﴾</q> الآية{2}. (٩/٣٢٥) ٤٢٩٤٣- عن أبي أُمامة، أنّ النبي ﷺ قال لعائشة وضرب بيده: «أنفقِي ما على ظهْرِ كَفِّي». قالت: إذن لا يبقى شيء. قال ذلك ثلاث مرات، فأنزل الله: <q>﴿ولا تجعل يدك مغلولة﴾</q> الآية{3}. (٩/٣٢٥) ٤٢٩٤٤- عن سيّار أبي الحكم، قال: أتى رسولَ الله ﷺ بَزٌّ من العراق، وكان مِعطاء كريمًا، فقسَمه بين الناس، فبلغ ذلك قومًا مِن العرب، فقالوا: نأتي النَّبيَّ ﷺ، فنسأله. فوجدوه قد فرغ منه؛ فأنزل الله: <q>﴿ولا تجعل يدك مغلولة إلى عنقك﴾</q> قال: محبوسة، <q>﴿ولا تبسطها كل البسط فتقعد ملومًا﴾</q> يلُومُك الناس، <q>﴿محسورًا﴾</q> ليس بيدك شيء{4}. (٩/٣٢٤) <q>﴿وَلَا تَجۡعَلۡ یَدَكَ مَغۡلُولَةً إِلَىٰ عُنُقِكَ﴾</q> - تفسير ٤٢٩٤٥- عن عبد الله بن عباس -من طريق علي- في قوله: <q>﴿ولا تجعل يدك مغلولة﴾</q>، قال: يعني بذلك: البُخل{5}. (٩/٣٢٦) ٤٢٩٤٦- عن عبد الله بن عباس -من طريق العوفي- <q>﴿ولا تجعل يدك مغلولة إلى عنقك﴾</q>، قال: هذا في النفقة. يقول: لا تجعلها مغلولةً؛ لا تَبسُطُها بخير{6}. (٩/٣٢٦) ٤٢٩٤٧- عن عبد الله بن عباس: قال: أمَر رسولَ اللهِ ﷺ مَن يُعطي، وكيف يُعطي، وبمن يبدأ؛ فأنزل الله: <q>﴿وءات ذا القربى حقه والمسكين وابن السبيل﴾</q> فأمره الله أن يبدأ بذي القربى، ثم بالمسكين وابن السبيل مِن بعدهم، وقال: <q>﴿ولا تبذر تبذيرًا﴾</q> يقول الله ﷿: ولا تُعط مالك كلَّه فتقعُد بغير شيء. ثم قال: <q>﴿ولا تجعل يدك مغلولة إلى عنقك﴾</q> فتمنع ما عندك، فلا تُعطِيَ أحدًا، <q>﴿ولا تبسُطها كل البسط﴾</q> فنهاه أن يُعطي إلا ما بَيَّنَ له، وقال له: <q>﴿وإمّا تُعِرَضَّن عنهم﴾</q> يقول: تُمسك عن عطائهم؛ <q>﴿فقل لهم قولًا ميسورًا﴾</q> يعني: قولًا معروفًا: لعله أن يكون، عسى أن يكون{7}. (٩/٣٢١) ٤٢٩٤٨- عن عبد الله بن عباس -من طريق محمد بن أبى موسى- في قوله: <q>﴿ولا تجعل يدك مغلولة إلى عنقك﴾</q>: لا تُعطي شيئًا{8}. (٩/٣١٧) ٤٢٩٤٩- عن مجاهد بن جبر -من طريق سفيان، عن رجل- في قوله: <q>﴿ولا تجعل يدك مغلولة إلى عنقك﴾</q>، قال: لا تنفق شيئًا{9}. (ز) ٤٢٩٥٠- عن الحسن البصري، في قوله: <q>﴿ولا تجعل يدك مغلولة إلى عنقك ولا تبسطها كل البسط﴾</q>، قال: نهاه عن السَّرَفِ والبخل{10}. (٩/٣٢٦) ٤٢٩٥١- عن الحسن البصري -من طريق عوف- في قوله: <q>﴿ولا تجعل يدك مغلولة إلى عنقك﴾</q>، قال: لا تجعلها مغلولة عن النفقة{11}. (ز) ٤٢٩٥٢- قال الحسن البصري: قوله: <q>﴿ولا تجعل يدك مغلولة إلى عنقك﴾</q>، أي: لا تَدَعِ النفقةَ في حقِّ الله، فيكون مَثَلُك مَثَلَ الذي غُلَّتْ يدُه إلى عنقه، فلا يستطيع أن يبسطها{12}. (ز) ٤٢٩٥٣- عن قتادة بن دعامة -من طريق سعيد- قوله: <q>﴿ولا تجعل يدك مغلولة إلى عنقك﴾</q>، أي: لا تُمْسِكها عن طاعة الله، ولا عن حقِّه{13}. (ز) ٤٢٩٥٤- عن قتادة بن دعامة -من طريق معمر- في قوله تعالى: <q>﴿ولا تجعل يدك مغلولة إلى عنقك﴾</q>، قال: في النفقة، يقول: لا تمسك عن النفقة{14}. (ز) ٤٢٩٥٥- قال إسماعيل السُّدِّيّ: هذا مَثَل ضربه الله في أمر النفقة، وذلك قوله للنبي ﷺ: <q>﴿ولا تجعل يدك مغلولة إلى عنقك﴾</q>{15}. (ز) ٤٢٩٥٦- عن محمد ابن شهاب الزهري -من طريق عقيل- أنّه كان يقول في هذه الآية: <q>﴿ولا تجعل يدك مغلولة إلى عنقك ولا تبسطها كل البسط﴾</q>، يقول: لا تمنعه مِن حق، ولا تنفقه في باطل، <q>﴿والذين إذا أنفقوا لم يسرفوا ولم يقتروا﴾</q> [الفرقان:٦٧]، كذلك أيضًا{16}. (ز) ٤٢٩٥٧- قال مقاتل بن سليمان: ثم علَّمهم كيف يعمل في النفقة، فقال سبحانه: <q>﴿ولا تجعل يدك مغلولة إلى عنقك﴾</q>، يقول: ولا تُمْسِك يدك مِن البخل عن النفقة في الحق{17}. (ز) ٤٢٩٥٨- عن عبد الملك ابن جريج -من طريق حجاج- قال: لا تُمْسِك عن النفقة فيما أمرتُك به مِن الحقِّ{18}. (ز) ٤٢٩٥٩- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿ولا تجعل يدك مغلولة إلى عنقك﴾</q>، قال: مغلولة؛ لا تبسطها بخير، ولا بعَطِيَّة{18}. (ز) ٤٢٩٦٠- قال يحيى بن سلّام: يعني: لا تُمْسِك يدك عن النفقة بمنزلة المغلولة، فلا تستطيع بسطها{20}. (ز) <q>﴿وَلَا تَبۡسُطۡهَا كُلَّ ٱلۡبَسۡطِ﴾</q> - تفسير ٤٢٩٦١- عن عبد الله بن عباس -من طريق العوفي- <q>﴿ولا تبسطها كل البسط﴾</q>، يعني: التبذير{5}. (٩/٣٢٦) ٤٢٩٦٢- عن عبد الله بن عباس -من طريق محمد بن أبي موسى- في قوله: <q>﴿ولا تبسُطها كل البسط﴾</q>: تُعطي ما عندك{8}. (٩/٣١٧) ٤٢٩٦٣- عن مجاهد بن جبر -من طريق سفيان، عن رجل- في قوله: <q>﴿ولا تبسطها كل البسط﴾</q>، قال: لا تُسْرِف{9}. (ز) ٤٢٩٦٤- عن الحسن البصري -من طريق عوف- في قوله: <q>﴿ولا تبسطها﴾</q>: تُبَذِّر؛ تُسْرِف{11}. (ز) ٤٢٩٦٥- عن قتادة بن دعامة -من طريق معمر- في قوله تعالى: <q>﴿ولا تبسطها كل البسط﴾</q>، يقول: لا تُبَذِّر تبذيرًا{14}. (ز) ٤٢٩٦٦- عن قتادة بن دعامة -من طريق سعيد- قوله: <q>﴿ولا تبسطها كل البسط﴾</q>، يقول: لا تُنفِقها في معصية الله، ولا فيما لا يصلح ولا ينبغي لك، وهو الإسراف{26}. (ز) ٤٢٩٦٧- قال مقاتل بن سليمان: <q>﴿ولا تبسطها﴾</q> يعني: في العَطِيَّة <q>﴿كل البسط﴾</q>، فلا تبقى عندك، فإن سُئِلْتَ لم تجد ما تعطيهم. كقوله: <q>﴿يد الله مغلولة﴾</q> [المائدة:٦٤]{17}. (ز) ٤٢٩٦٨- عن عبد الملك ابن جريج -من طريق حجاج- قوله: <q>﴿ولا تبسطها كل البسط﴾</q>: فيما نهيتك{18}. (ز) ٤٢٩٦٩- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿ولا تبسطها كل البسط﴾</q>: في الحق والباطل، فينفذ ما في يديك، فيأتيك مَن يريد أن تعطيه كما أعطيت هؤلاء، فلا تجد ما تعطيه، فيحسرك، فيلومك حين أعطيت هؤلاء ولم تُعطِهم{18}. (ز) ٤٢٩٧٠- قال يحيى بن سلّام: <q>﴿ولا تبسطها كل البسط﴾</q>، فتنفق في غير حق الله، أي: لا تنفقها في معصية الله، وفيما لا يصلح، وهو الإسراف{30}. (ز) <q>﴿فَتَقۡعُدَ مَلُومࣰا﴾</q> - تفسير ٤٢٩٧١- عن عبد الله بن عباس -من طريق العوفي- <q>﴿فتقعد ملومًا﴾</q>: يلوم نفسه على ما فاته مِن ماله{5}. (٩/٣٢٦) ٤٢٩٧٢- عن عبد الله بن عباس، في قوله: <q>﴿فتقعد ملومًا﴾</q>، قال: ملومًا عند الناس{32}. (٩/٣٢٦) ٤٢٩٧٣- عن عبد الله بن عباس -من طريق محمد بن أبي موسى- في قوله: <q>﴿فتقعُدَ ملومًا﴾</q>: يلومك مَن يأتيك بعدُ ولا يَجِدُ عندك شيئًا{8}. (٩/٣١٧) ٤٢٩٧٤- عن مجاهد بن جبر -من طريق سفيان، عن رجل- في قوله: <q>﴿فتقعد ملوما﴾</q>، قال: ملومًا فيما بينك وبين ربك{9}. (ز) ٤٢٩٧٥- عن قتادة بن دعامة -من طريق سعيد- قوله: <q>﴿فتقعد ملوما﴾</q>، قال: ملومًا في عباد الله{35}. (ز) ٤٢٩٧٦- قال مقاتل بن سليمان: <q>﴿فتقعد ملوما﴾</q> يلومك الناس{17}. (ز) ٤٢٩٧٧- عن عبد الملك ابن جريج -من طريق حجاج- قوله: <q>﴿فتقعد ملوما﴾</q>، قال: مُذنِبًا{18}. (ز) ٤٢٩٧٨- قال يحيى بن سلّام، في قوله: <q>﴿فتقعد ملوما﴾</q>: في عباد الله، لا تستطيع أن توسع الناس{38}. (ز) <q>﴿مَّحۡسُورًا ۝٢٩﴾</q> - تفسير ٤٢٩٧٩- عن عبد الله بن عباس، أنّ نافع بن الأزرق قال: أخبِرني عن قوله: <q>﴿ملومًا محسورًا﴾</q>. قال: مُستَحِيًا خجلًا. قال: وهل تعرف العرب ذلك؟ قال: نعم، أما سمعت الشاعر وهو يقول: ما قادَ مِن عرب يموت جوادهم إلا تركت جوادهم محسورًا؟{39}. (٩/٣٢٦) ٤٢٩٨٠- عن عبد الله بن عباس -من طريق محمد بن أبي موسى- في قوله: <q>﴿محسورًا﴾</q>، قال: قد حَسَرَك مَن قد أعطيتَه{8}. (٩/٣١٧) ٤٢٩٨١- عن عبد الله بن عباس -من طريق العوفي- <q>﴿محسورًا﴾</q>: ذهب مالُه كلُّه{5}. (٩/٣٢٦) ٤٢٩٨٢- عن عبد الله بن عباس، في قوله: <q>﴿محسورًا﴾</q>، قال: محسورًا من المال{32}. (٩/٣٢٦) ٤٢٩٨٣- عن مجاهد بن جبر -من طريق سفيان، عن رجل- في قوله: <q>﴿محسورا﴾</q>: في مالك{9}. (ز) ٤٢٩٨٤- عن حوشب، قال: كان الحسن [البصري] إذا تلا هذه الآية: <q>﴿ولا تجعل يدك مغلولة إلى عنقك ولا تبسطها كل البسط فتقعد ملوما محسورا﴾</q>، يقول: لا تُطَفِّف برزقي عن غير رضاي، ولا تضعه في سخطي؛ فأسلبك ما في يديك؛ فتكون حسيرًا ليس في يديك منه شيء{11}. (ز) ٤٢٩٨٥- عن قتادة بن دعامة -من طريق سعيد- قوله: <q>﴿محسورا﴾</q>، قال: محسورًا على ما سَلَف مِن دهره وفَرَّط{26}. (ز) ٤٢٩٨٦- عن قتادة بن دعامة -من طريق معمر- في قوله تعالى: <q>﴿محسورا﴾</q>، يقول: نادِمًا على ما فرط منك{14}. (ز) ٤٢٩٨٧- قال مقاتل بن سليمان: <q>﴿محسورا﴾</q>، يعني: مُنقَطِعًا بك، كقوله سبحانه في تبارك الملك [٤]: <q>﴿وهو حسير﴾</q>، يعني: منقطع به{17}. (ز) ٤٢٩٨٨- عن عبد الملك ابن جريج -من طريق حجاج- قوله: <q>﴿محسورا﴾</q>، قال: منقطعًا بك{18}. (ز) ٤٢٩٨٩- قال يحيى بن سلّام: <q>﴿محسورا﴾</q> قد ذهب ما في يديك، يقول: قد خسر{38}. (ز) <q>﴿مَّحۡسُورًا ۝٢٩﴾</q> - آثار متعلقة بالآية ٤٢٩٩٠- عن عبد الله بن مسعود، قال: قال رسول الله عليه وسلم: «ما عالَ مَنِ اقتَصَد»{50}. (٩/٣٢٧) ٤٢٩٩١- عن عبد الله بن عباس، قال: قال رسول الله ﷺ: «ما عال مقتصدٌ قطُّ»{51}. (٩/٣٢٧) ٤٢٩٩٢- عن أبي الدرداء، قال: قال رسول الله ﷺ: «مِن فِقهِك رِفقُك في معيشتك»{52}. (٩/٣٢٧) ٤٢٩٩٣- عن جابر بن عبد الله، قال: قال رسول الله ﷺ: «الرِّفق في المعيشة خيرٌ مِن بعض التجارة»{53}. (٩/٣٢٧) ٤٢٩٩٤- عن مُطَرِّف بن الشِّخِّير -من طريق ثابت- قال: خير الأمور أوساطُها{54}. (٩/٣٢٨) ",footnotes:1:أخرجه الواحدي في أسباب النزول ص٢٨٧، من طريق سليمان بن سفيان الجهني، قال: حدثنا قيس بن الربيع، عن أبي إسحاق، عن أبي الأحوص، عن ابن مسعود به. وعزاه السيوطي إلى ابن أبي حاتم. إسناده ضعيف؛ فيه سليمان بن سفيان، قال عنه الذهبي في المغني في الضعفاء (٢٥٩١): «ضعيف».أخرجه ابن أبي الدنيا في كتاب مكارم الأخلاق -موسوعة الإمام ابن أبي الدنيا ٣/٥٠٧ (٤١٢)-. وعزاه السيوطي إلى ابن أبي حاتم.عزاه السيوطي إلى ابن مردويه.عزاه السيوطي إلى سعيد بن منصور، وابن المنذر.أخرجه ابن جرير ١٤/٥٧٥. وعزاه السيوطي إلى ابن أبي حاتم.أخرجه ابن جرير ١٤/٥٧٥ بنحوه. وعزاه السيوطي إلى ابن أبي حاتم.عزاه السيوطي إلى ابن مَرْدويه.أخرجه البخاري في الأدب المفرد (٥١). وعزاه السيوطي إلى ابن أبي حاتم.تفسير الثوري ص١٧٢.عزاه السيوطي إلى ابن أبي حاتم.أخرجه ابن جرير ١٤/٥٧٤.علقه يحيى بن سلام ١/١٣١.أخرجه يحيى بن سلام ١/١٢٦، وابن جرير ١٤/٥٧٥.أخرجه عبد الرزاق ٢/٣٧٧، وابن جرير ١٤/٥٧٥.علقه يحيى بن سلام ١/١٣٢.أخرجه ابن وهب في الجامع - تفسير القرآن ١/٥٥-٥٦ (١٢٢).تفسير مقاتل بن سليمان ٢/٥٢٩.أخرجه ابن جرير ١٤/٥٧٦.أخرجه ابن جرير ١٤/٥٧٦.تفسير يحيى بن سلام ١/١٣٢.أخرجه ابن جرير ١٤/٥٧٥. وعزاه السيوطي إلى ابن أبي حاتم.أخرجه البخاري في الأدب المفرد (٥١). وعزاه السيوطي إلى ابن أبي حاتم.تفسير الثوري ص١٧٢.أخرجه ابن جرير ١٤/٥٧٤.أخرجه عبد الرزاق ٢/٣٧٧، وابن جرير ١٤/٥٧٥.أخرجه ابن جرير ١٤/٥٧٥.تفسير مقاتل بن سليمان ٢/٥٢٩.أخرجه ابن جرير ١٤/٥٧٦.أخرجه ابن جرير ١٤/٥٧٦.تفسير يحيى بن سلام ١/١٣١-١٣٢.أخرجه ابن جرير ١٤/٥٧٥. وعزاه السيوطي إلى ابن أبي حاتم.عزاه السيوطي إلى ابن المنذر.أخرجه البخاري في الأدب المفرد (٥١). وعزاه السيوطي إلى ابن أبي حاتم.تفسير الثوري ص١٧٢.أخرجه عبد الرزاق ٢/٣٧٧ من طريق معمر، وابن جرير ١٤/٥٧٥.تفسير مقاتل بن سليمان ٢/٥٢٩.أخرجه ابن جرير ١٤/٥٧٦.تفسير يحيى بن سلام ١/١٣١.مسائل نافع (٢٤٨). وعزاه السيوطي إلى الطَّسْتيِّ.أخرجه البخاري في الأدب المفرد (٥١). وعزاه السيوطي إلى ابن أبي حاتم.أخرجه ابن جرير ١٤/٥٧٥. وعزاه السيوطي إلى ابن أبي حاتم.عزاه السيوطي إلى ابن المنذر.تفسير الثوري ص١٧٢.أخرجه ابن جرير ١٤/٥٧٤.أخرجه ابن جرير ١٤/٥٧٥.أخرجه عبد الرزاق ٢/٣٧٧، وابن جرير ١٤/٥٧٥.تفسير مقاتل بن سليمان ٢/٥٢٩.أخرجه ابن جرير ١٤/٥٧٦.تفسير يحيى بن سلام ١/١٣١.أخرجه أحمد ٧/٣٠٢ (٤٢٦٩)، والطبراني في الأوسط ٥/٢٠٦ (٥٠٩٤). قال الطبراني: «لم يرو هذا الحديثَ عن إبراهيم الهجري إلا سكينُ بن عبد العزيز». وأورده ابن عدي في الكامل ٤/٥٤٤ (٨٧٦) في ترجمة سكين بن عبد العزيز بن قيس العبدي. وقال ابن القيسراني في ذخيرة الحفاظ ٤/٢٠٩١ (٤٨٣٥): «سكين ليس بالقوي، والهجري متروك الحديث». وقال ابن القطان في بيان الوهم ٤/٥٩٧: «ضعيف». وقال الهيثمي في المجمع ١٠/٢٥٢ (١٧٨٤٨): «في أسانيدهم إبراهيم بن مسلم الهجري، وهو ضعيف». وقال المناوي في التيسير ٢/٣٥٢: «وقول المؤلف -السيوطي- حسن غير حسن». وقال السفاريني في غذاء الألباب ٢/٥٤٠: «بإسناد حسن». وقال الألباني في الضعيفة ٩/٤٤٨ (٤٤٥٩): «ضعيف».أخرجه الطبراني في الأوسط ٨/١٥٢ (٨٢٤١)، والبيهقي في شعب الإيمان ٨/٥٠٥-٥٠٦ (٦١٥٠، ٦١٥١). قال الطبراني: «لم يروِ هذا الحديثَ عن أبي روق إلا خالد بن يزيد، تفرد به هشام بن خالد». وأورده ابن عدي في الكامل ٣/٤٢٦ (٥٧٧) في ترجمة خالد بن يزيد بن عبد الرحمن بن أبي مالك، وقال الهيثمي في المجمع ١٠/٢٥٢ (١٧٨٤٩): «رواه الطبراني في الكبير، والأوسط، ورجاله وُثِّقوا، وفي بعضهم خلاف». وقال الألباني في الضعيفة ٩/٤٤٨: «ضعيف ... لانقطاعه».أخرجه ابن عدي في الكامل في الضعفاء ٢/٢١١ (٢٧٧) في ترجمة أبي بكر بن عبد الله بن أبي مريم الغساني الحمصي، والبيهقي في شعب الإيمان ٨/٥٠٠-٥٠١ (٦١٤٥). قال الهيثمي في المجمع ٤/٧٤ (٦٣٠٨): «رواه أحمد، وفيه أبو بكر بن أبي مريم، وقد اختلط». وقال المناوي في فيض القدير ٦/١٦ (٨٢٥٦)، وفي التيسير ٢/٣٨٣: «وسنده لا بأس به». وقال الألباني في الضعيفة ٢/٣٣ (٥٥٦): «ضعيف».أخرجه الطبراني في الأوسط ٨/٣١٧-٣١٨ (٨٧٤٦)، والبيهقي في شعب الإيمان ٨/٤٩٥ (٦١٣٦)، ٨/٤٩٨ (٦١٤٢). قال الطبراني: «لم يرو هذا الحديث عن محمد بن المنكدر إلا ابن لهيعة، تفرد به عبد الله بن صالح، ولا يروى عن جابر إلا بهذا الإسناد». وأورده ابن عدي في الكامل ٢/٥٣٧ (٤١٢) في ترجمة حجاج بن سليمان الرعيني. وقال الهيثمي في المجمع ٤/٧٤ (٦٣٠٩): «رواه الطبراني في الأوسط، وفيه عبد الله بن صالح المصري؛ قال عبد الملك بن شعيب: ثقة مأمون. وضعفه جماعة». وقال المناوي في التيسير ٢/٤١: «بإسناد حسن». وقال الألباني في الضعيفة ٨/١٥٤ (٣٦٧٧): «ضعيف».أخرجه البيهقي (٦٦٠١).
17,30," <q>﴿إِنَّ رَبَّكَ یَبۡسُطُ ٱلرِّزۡقَ لِمَن یَشَاۤءُ وَیَقۡدِرُۚ إِنَّهُۥ كَانَ بِعِبَادِهِۦ خَبِیرَۢا بَصِیرࣰا ۝٣٠﴾</q> - تفسير ٤٢٩٩٥- عن الحسن البصري، في قوله: <q>﴿إن ربك يبسط الرزق لمن يشاء ويقدر﴾</q>، قال: ينظر له؛ فإن كان الغِنى خيرًا له أغناه، وإن كان الفقر خيرًا له أفقره{1}. (٩/٣٢٩) ٤٢٩٩٦- عن الحسن البصري، في الآية، قال: يبسط لهذا مكرًا به، ويقدِر لهذا نظرًا له{1}. (٩/٣٢٩) ٤٢٩٩٧- قال مقاتل بن سليمان: <q>﴿إن ربك يبسط الرزق﴾</q> يعني: يُوَسِّع الرزق <q>﴿لمن يشاء ويقدر﴾</q> يعني: ويقتر على من يشاء، <q>﴿إنه كان بعباده خبيرا﴾</q> بأمر الرزق بالسعة والتقتير، <q>﴿بصيرا﴾</q> به{3}. (ز) ٤٢٩٩٨- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- قال: كلُّ شيء في القرآن «يقدر» فمعناه: يُقِلُّ{4}. (٩/٣٢٩) ٤٢٩٩٩- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- قال: ثم أخبَرنا كيف يصنع بنا، فقال: <q>﴿إن ربك يبسط الرزق لمن يشاء ويقدر﴾</q>، ثم أخبر عباده أنه لا يَرزَؤُه ولا يَئُودوه أن لو بسط الرزق عليهم، ولكن نظرًا لهم منه، فقال: <q>﴿ولو بسط الله الرزق لعباده لبغوا في الأرض ولكن يُنزل بقدر ما يشاء إنه بعباده خبير بصير﴾</q> [الشورى:٢٧]. قال: والعرب إذا كان الخِصب وبُسِط عليهم أشِروا{5}، وقتل بعضهم بعضًا، وجاء الفساد، وإذا كان السَّنَةُ شُغِلوا عن ذلك{6}. (٩/٣٢٨) ٤٣٠٠٠- قال يحيى بن سلّام: <q>﴿إن ربك يبسط الرزق لمن يشاء ويقدر﴾</q> أي: ويقتر، وتقتيره على المؤمن نظرًا له، <q>﴿إنه كان بعباده خبيرا بصيرا﴾</q>{7}. (ز) ",footnotes:1:عزاه السيوطي إلى ابن أبي حاتم.عزاه السيوطي إلى ابن أبي حاتم.تفسير مقاتل بن سليمان ٢/٥٢٩.أخرجه ابن جرير ١٤/٥٧٧، وابن أبي حاتم ٩/٣٠٨٠ من طريق أصبغ بن الفرج.أشروا: بطروا وكفروا النعمة. التاج (أشر).أخرجه ابن جرير ١٤/٥٧٧. وعزاه السيوطي إلى ابن أبي حاتم.تفسير يحيى بن سلام ١/١٣٢.
17,31," <q>﴿وَلَا تَقۡتُلُوۤا۟ أَوۡلَـٰدَكُمۡ خَشۡیَةَ إِمۡلَـٰقࣲۖ نَّحۡنُ نَرۡزُقُهُمۡ وَإِیَّاكُمۡۚ إِنَّ قَتۡلَهُمۡ كَانَ خِطۡـࣰٔا كَبِیرࣰا ۝٣١﴾</q> - قراءات ٤٣٠٠١- عن الحسن البصري أنه قرأ: ‹خِطَآءً كَبِيرًا› مهموزة، مِن قِبَلِ الخطأ والصواب{1}٣٨٣٤. (٩/٣٣١) ٣٨٣٤ ذكر ابنُ جرير (١٤/٥٧٩-٥٨٠) اختلاف القرأة في قراءة قوله تعالى: <q>﴿إنَّ قَتْلَهُمْ كانَ خِطْئًا كَبِيرًا﴾</q> على ثلاث قراءات، فقال: الأولى: <q>﴿خِطْئًا﴾</q> بكسر الخاء وسكون الطاء، ولهم فيها معنيان: الأول: أن يكون اسمًا من قول القائل: خَطِئْتُ فأنا أخْطَأُ خِطْأ، بمعنى: أذنبتُ وأَثِمْتُ. ويُحكى عن العرب: خَطِئتَ: إذا أذنبتَ عمدًا، وأخطأتَ: إذا وقع منك الذَّنبُ على غير عمدٍ منك له. والثاني: أن يكون بمعنى «خَطَأ» بفتح الخاء والطاء، ثم كُسِرت الخاء وسُكِّنت الطاء، كما قيل: قِتْبٌ وقَتَبٌ، وحِذْرٌ وحَذَرٌ، ونِجْسٌ ونَجَسٌ. والخِطْء بالكسر اسم، والخَطَأ بفتح الخاء والطاء مصدر من قولهم: خَطِئ الرجل، وقد يكون اسمًا من قولهم: أخْطَأَ. الثانية: ‹خَطَأً› بفتح الخاء والطاء، على أنه اسمٌ، من قولهم: أخْطَأَ فلان خَطَأ. الثالثة: ‹خِطَآءً› [بكسر] الخاء والطاء ومدِّ الخطاء، وهي في المعنى كالقراءة الثانية. ورجَّح ابنُ جرير (١٤/٥٨٠) القراءة الأولى مستندًا إلى إجماع الحجة من القرأة عليها، وعلَّل ذلك بقوله: «لإجماع الحجة من القرأة عليها، وشذوذ ما عداها». ورجَّح (١٤/٥٨٠ بتصرف) مستندًا إلى أقوال السلف أن المعنى: «إن قتلهم كان إثمًا وخطيئةً، لا خطأً من الفعل، لأنهم إنما كانوا يقتلونهم عمدًا لا خطأً، وعلى عمدهم ذلك عاتبهم ربهم، وتقدم إليهم بالنهي عنه». <q>﴿وَلَا تَقۡتُلُوۤا۟ أَوۡلَـٰدَكُمۡ خَشۡیَةَ إِمۡلَـٰقࣲۖ نَّحۡنُ نَرۡزُقُهُمۡ وَإِیَّاكُمۡۚ﴾</q> - تفسير ٤٣٠٠٢- عن عبد الله بن عباس -من طريق علي- في قوله: <q>﴿خشية إملاق﴾</q>، قال: مخافة الفاقَة والفقر{2}. (٩/٣٣٠) ٤٣٠٠٣- عن عبد الله بن عباس، أن نافع بن الأزرق قال: أخبِرني عن قوله: <q>﴿خشية إملاق﴾</q>. قال: مخافة الفقر. قال: وهل تعرف العرب ذلك؟ قال: نعم، أما سمعت الشاعر وهو يقول: وإني على الإملاق يا قوم ماجِد أُعِدُّ لأَضيافي الشِّواء المضهَّبا؟{3}. (٩/٣٣٠) ٤٣٠٠٤- عن مجاهد بن جبر -من طريق ابن جريج- <q>﴿ولا تقتلوا أولادكم خشية إملاق﴾</q>، قال: الفاقة والفقر{4}. (ز) ٤٣٠٠٥- عن قتادة بن دعامة -من طريق معمر- <q>﴿خشية إملاق﴾</q>، قال: كانوا يقتلون البنات{5}. (ز) ٤٣٠٠٦- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿ولا تقتلوا أولادكم خشية إملاق﴾</q> أي: خشية الفاقة، وكان أهل الجاهلية يقتلون أولادهم خشية الفاقة، فوعظهم الله في ذلك، وأخبرهم أنّ رزقهم ورزق أولادِهم على الله، فقال: <q>﴿نحن نرزقهم وإياكم إن قتلهم كان خِطئًا كبيرًا﴾</q>{6}. (٩/٣٢٩) ٤٣٠٠٧- قال يحيى بن سلّام، في قوله: <q>﴿ولا تقتلوا أولادكم﴾</q>: يعني: الموءودة. كان أحدهم يقتل ابنته؛ يدفنها حية حتى تموت مخافة الفاقة، ويغذي كلبه{7}. (ز) <q>﴿إِنَّ قَتۡلَهُمۡ كَانَ خِطۡـࣰٔا كَبِیرࣰا ۝٣١﴾</q> - تفسير ٤٣٠٠٨- عن عبد الله بن عباس -من طريق ابن جريج- في قوله: <q>﴿خِطئًا﴾</q>، قال: خطيئة{8}. (٩/٣٣٠) ٤٣٠٠٩- عن مجاهد بن جبر -من طريق ابن أبي نجيح- <q>﴿خطئا كبيرا﴾</q>، قال: خطيئة{9}. (ز) ٤٣٠١٠- عن الحسن البصري أنّه قرأ: ‹خِطَآءً كَبِيرًا› مهموزة، مِن قِبَلِ الخطأ والصواب{10}. (٩/٣٣١) ٤٣٠١١- قال الحسن البصري: ذنبًا كبيرًا{11}. (ز) ٤٣٠١٢- عن قتادة بن دعامة، في قوله: <q>﴿إن قتلهم كان خِطئًا كبيرًا﴾</q>، أي: إثمًا كبيرًا{12}. (٩/٣٢٩) ٤٣٠١٣- قال مقاتل بن سليمان: <q>﴿ولا تقتلوا أولادكم﴾</q> يعني: دفن البنات وهن أحياء <q>﴿خشية إملاق﴾</q> يعني: مخافة للفقر، <q>﴿نحن نرزقهم وإياكم إن قتلهم كان خطئا﴾</q> يعني: إثمًا <q>﴿كبيرا﴾</q>{13}. (ز) ٤٣٠١٤- قال يحيى بن سلّام: <q>﴿نحن نرزقهم وإياكم إن قتلهم كان خطأ كبيرا﴾</q> ذنبًا كبيرًا، قتلُ النفس التي حرم الله من الكبائر{7}. (ز) ",footnotes:1:عزاه السيوطي إلى ابن أبي حاتم. وهي قراءة متواترة، قرأ بها ابن كثير، وقرأ أبو جعفر وابن عامر بخلف عن هشام: ‹خَطَأً› بفتح الخاء والطاء من غير ألف ولا مدّ، واختلف عن هشام، وقرأ بقية العشرة: <q>﴿خِطْئًا﴾</q> بكسر الخاء وإسكان الطاء، وهو الوجه الثاني لهشام. انظر: النشر ٢/٣٠٧، والإتحاف ص٣٥٧.أخرجه ابن جرير ٩/٦٥٨، ١٤/٥٧٨، وابن أبي حاتم ٥/١٤١٤ (٨٠٥٩). وعزاه السيوطي إلى ابن المنذر.عزاه السيوطي إلى الطستيِّ. وينظر: الإتقان ٢/٨٥.أخرجه ابن جرير ١٤/٥٧٨، وبنحوه في تفسير مجاهد ص٤٣٦ من طريق ابن أبي نجيح.أخرجه ابن جرير ١٤/٥٧٨.أخرجه ابن جرير ٩/٦٥٨، ١٤/٥٧٨، وابن أبي حاتم ٥/١٤١٥ (٨٠٦٠). وعلقه يحيى بن سلام ١/١٣٢ مختصرًا.تفسير يحيى بن سلام ١/١٣٢.أخرجه ابن جرير ١٤/٥٨١. وعزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ١٤/٥٨١.عزاه السيوطي إلى ابن أبي حاتم.علقه يحيى بن سلام ١/١٣٢.أخرجه ابن جرير ٩/٦٥٨، ١٤/٥٧٨، وابن أبي حاتم ٥/١٤١٥ (٨٠٦٠). وعلقه يحيى بن سلام ١/١٣٢ وعقَّب عليه وعلى قول الحسن السابق: وهو واحد.تفسير مقاتل بن سليمان ٢/٥٢٩.تفسير يحيى بن سلام ١/١٣٢.
17,32," <q>﴿وَلَا تَقۡرَبُوا۟ ٱلزِّنَىٰۤۖ إِنَّهُۥ كَانَ فَـٰحِشَةࣰ وَسَاۤءَ سَبِیلࣰا ۝٣٢﴾</q> - قراءات ٤٣٠١٥- عن أُبيّ بن كعب أنه قرأ: (ولا تَقْرَبُوا الزِّنَآ إنَّهُ كانَ فاحِشَةً ومَقْتًا وسَآءَ سَبِيلًا إلّا مَن تابَ فَإنَّ اللهَ كانَ غَفّارًا رَّحِيمًا). فذُكر لعمر، فأتاه، فسأله، فقال: أخذتُها مِن فِي رسول الله ﷺ، وليس لك عملٌ إلا الصَّفْق{1} بالنَّقيع{2}{3}. (٩/٣٣٢) <q>﴿وَلَا تَقۡرَبُوا۟ ٱلزِّنَىٰۤۖ إِنَّهُۥ كَانَ فَـٰحِشَةࣰ وَسَاۤءَ سَبِیلࣰا ۝٣٢﴾</q> - نزول الآية ٤٣٠١٦- عن إسماعيل السُّدِّيّ، في قوله: <q>﴿ولا تقربوا الزنا﴾</q>، قال: يوم نزلت هذه الآية لم تكن حدود، فجاءت بعد ذلك الحدود في سورة النور{4}. (٩/٣٣٢) ٤٣٠١٧- عن زيد بن أسلم -من طريق سعيد بن أبي هلال- قال: كان في الزنا ثلاثة أنحاء؛ أمّا نحوٌ فقال الله: <q>﴿لا تقربوا الزنا إنه كان فاحشة﴾</q>، فلم يَنتَهِ الناسُ. قال: ثم نزل: <q>﴿واللاتي يأتين الفاحشة من نسائكم فاستشهدوا عليهن أربعة منكم فإن شهدوا فأمسكوهن في البيوت حتى يتوفاهن الموت أو يجعل الله لهن سبيلا﴾</q> [النساء:١٥]، كانت المرأة الثيب إذا زنتْ، فشهد عليها أربعةٌ عُطِّلت، فلم يتزوجها أحد، فهي التي قال الله: <q>﴿ولا تعضلوهن إلا أن يأتين بفاحشة مبينة﴾</q> [النساء:١٩]. قال زيد: ثم نزلت: <q>﴿واللذان يأتيانها منكم فآذوهما﴾</q> [النساء:١٦]، فهذان البكران اللذان إن لم يتزوجا وآذاهما أن يعرفا بذنبهما، فيقال: يا زان. حتى تُرى منهما توبة، حتى نزل السبيل، قال: <q>﴿الزانية والزاني فاجلدوا كل واحد منهما مائة جلدة﴾</q> [النور:٢]، فهذا للبِكْرَيْن. قال زيد: وكان للثَّيِّب الرجم {5}. (ز) ٤٣٠١٨- قال مقاتل بن سليمان: قوله سبحانه: <q>﴿ولا تقربوا الزنى إنه كان فاحشة وساء سبيلا﴾</q>، يعني: لم يكن يومئذ في الزنا حدٌّ، حتى نزل الحدُّ بالمدينة في سورة النور{6}. (ز) <q>﴿وَلَا تَقۡرَبُوا۟ ٱلزِّنَىٰۤۖ إِنَّهُۥ كَانَ فَـٰحِشَةࣰ وَسَاۤءَ سَبِیلࣰا ۝٣٢﴾</q> - تفسير الآية ٤٣٠١٩- قال قتادة، عن الحسن البصري في قوله: <q>﴿ولا تقربوا الزنى إنه كان فاحشة﴾</q>، أن رسول الله ﷺ كان يقول: «لا يزني العبد حين يزني وهو مؤمن، ولا يَنتَهِب حين يَنتَهِب وهو مؤمن، ولا يسرق حين يسرق وهو مؤمن، ولا يشرب الخمر حين يشربها وهو مؤمن، ولا يَغُلُّ حين يَغُلُّ وهو مؤمن». قيل: يا رسول الله، والله إن كُنّا لَنرى أنه يأتي ذلك وهو مؤمن. فقال نبي الله ﷺ: «إذا فعل شيئًا مِن ذلك نُزِع الإيمان من قلبه، فإن تاب تاب الله عليه»{4}. (٩/٣٣٢) ٤٣٠٢٠- قال مقاتل بن سليمان: قوله سبحانه: <q>﴿ولا تقربوا الزنى إنه كان فاحشة﴾</q> يعني: معصية، <q>﴿وساء سبيلا﴾</q> يعني: المسلك{6}. (ز) ٤٣٠٢١- قال يحيى بن سلّام: قوله: <q>﴿ولا تقربوا الزنى إنه كان فاحشة وساء سبيلا﴾</q> وبئس الطريق.= (ز) ٤٣٠٢٢- وقال السُّدِّيّ: ويعني: المسلك. وهو نحوه{9}. (ز) <q>﴿وَلَا تَقۡرَبُوا۟ ٱلزِّنَىٰۤۖ إِنَّهُۥ كَانَ فَـٰحِشَةࣰ وَسَاۤءَ سَبِیلࣰا ۝٣٢﴾</q> - آثار متعلقة بالآية ٤٣٠٢٣- عن أبي هريرة، أن رسول الله ﷺ قال: «لا يزني الزاني حين يزني وهو مؤمن، ولا يسرق السارق حين يسرق وهو مؤمن، ولا يشرب الخمر حين يشربها وهو مؤمن، ولا يَنتَهِب نُهبَةً ذات شرف يرفَعُ المؤمنون إليه فيها أبصارهم وهو مؤمن»{10}. (٩/٣٣٣) ٤٣٠٢٤- عن أبي هريرة، قال: قال رسول الله ﷺ: «ثلاثة لا يُكَلِّمُهم الله يوم القيامة، ولا يُزكِّيهم، ولا ينظُرُ إليهم، ولهم عذاب أليم: شيخٌ زانٍ، ومَلِكٌ كَذّابٌ، وعائلٌ مُستكبر»{11}. (٩/٣٣٧) ",footnotes:1:تصافق القوم: تبايعوا. اللسان (صفق).النقيع: موضع تلقاء المدينة، بينها وبين مكة. معجم ما استعجم ٤/١٣٢٣، ومعجم البلدان ٤/٨٠٩.عزاه السيوطي إلى أبي يعلى، وابن مَرْدويه. وهي قراءة شاذة.عزاه السيوطي إلى ابن أبي حاتم.أخرجه ابن وهب في الجامع ١/١٢٥-١٢٧ (٢٩٠).تفسير مقاتل بن سليمان ٢/٥٢٩.عزاه السيوطي إلى ابن أبي حاتم.تفسير مقاتل بن سليمان ٢/٥٢٩.تفسير يحيى بن سلام ١/١٣٢.أخرجه البخاري ٣/١٣٦ (٢٤٧٥)، ٧/١٠٤ (٥٥٧٨)، ٨/١٥٧ (٦٧٧٢)، ٨/١٦٤ (٦٨١٠)، ومسلم ١/٧٦-٧٧ (٥٧).أخرجه مسلم ١/١٠٢ (١٠٧)، وابن أبي حاتم ١/٢٨٦ (١٥٣٦)، ٢/٦٨٨ (٣٧٢٧).
17,33," <q>﴿وَلَا تَقۡتُلُوا۟ ٱلنَّفۡسَ ٱلَّتِی حَرَّمَ ٱللَّهُ إِلَّا بِٱلۡحَقِّۗ وَمَن قُتِلَ مَظۡلُومࣰا فَقَدۡ جَعَلۡنَا لِوَلِیِّهِۦ سُلۡطَـٰنࣰا فَلَا یُسۡرِف فِّی ٱلۡقَتۡلِۖ إِنَّهُۥ كَانَ مَنصُورࣰا ۝٣٣﴾</q> - قراءات ٤٣٠٢٥- عن الكسائيِّ قال: هي قراءة أُبيّ بن كعب: (فَلا تُسْرِفُواْ فِي القَتْلِ إنَّ ولِيَّهُ كانَ مَنصُورًا){1}. (٩/٣٤٢) <q>﴿وَلَا تَقۡتُلُوا۟ ٱلنَّفۡسَ ٱلَّتِی حَرَّمَ ٱللَّهُ إِلَّا بِٱلۡحَقِّۗ وَمَن قُتِلَ مَظۡلُومࣰا فَقَدۡ جَعَلۡنَا لِوَلِیِّهِۦ سُلۡطَـٰنࣰا فَلَا یُسۡرِف فِّی ٱلۡقَتۡلِۖ إِنَّهُۥ كَانَ مَنصُورࣰا ۝٣٣﴾</q> - نزول الآية ٤٣٠٢٦- عن الضَّحّاك بن مُزاحِم -من طريق عبيد- في قوله: <q>﴿ولا تقتلوا النفس﴾</q> الآية، قال: كان هذا بمكة ونبيُّ الله ﷺ بها، وهو أول شيء نزل من القرآن في شأن القتل{2}. (٩/٣٣٨) <q>﴿وَلَا تَقۡتُلُوا۟ ٱلنَّفۡسَ ٱلَّتِی حَرَّمَ ٱللَّهُ إِلَّا بِٱلۡحَقِّۗ﴾</q> - تفسير ٤٣٠٢٧- عن عثمان بن عفان، قال: قال رسول الله ﷺ: «لا يَحِلُّ دمُ مسلمٍ إلا بأحد ثلاث: رجل كفر بعد إسلامه، أو زنى بعد إحصانه، أو قتل نفسا متعمدًا»{3}. (ز) ٤٣٠٢٨- عن أنس بن مالك، قال: قال رسول الله ﷺ: «أُمِرْتُ أن أقاتل الناس حتى يقولوا: لا إله إلا الله. فإذا قالوها عصموا مني دماءَهم وأموالَهم إلا بحقِّها، وحسابُهم على الله». قيل: وما حقُّها؟ قال: «زِنًا بعد إحصان، وكفر بعد إيمان، وقتل نفس فيقتل بها»{4}. (ز) ٤٣٠٢٩- عن عروة أو غيره، قال: قيل لأبي بكر الصديق: أتقتل مَن يرى أن لا يؤدي الزكاة؟ قال: لو منعوني شيئًا مما أقرُّوا به لرسول الله ﷺ لقاتلتهم. فقيل لأبي بكر: أليس قال رسول الله ﷺ: «أمرت أن أقاتل الناس حتى يقولوا: لا إله إلا الله، فإذا قالوها عصموا مني دماءهم وأموالهم إلا بحقها وحسابهم على الله»؟ فقال أبو بكر: هذا من حقِّها{5}. (ز) ٤٣٠٣٠- عن الضحاك بن مزاحم -من طريق عبيد- في قوله: <q>﴿ولا تقتلوا النفس﴾</q> الآية، قال: كان هذا بمكة ونبيُّ الله ﷺ بها، وهو أولُ شيء نزل من القرآن في شأن القتل، كان المشركون من أهل مكة يغتالون أصحاب النبي ﷺ، فقال الله: مَن قتلكم مِن المشركين فلا يَحمِلَنَّكم قَتلهُ إيّاكم على أن تقتُلوا له أبًا، أو أخًا، أو أحدًا من عشيرته، وإن كانوا مشركين فلا تقتلوا إلا قاتلَكم. وهذا قبل أن تنزل براءة، وقبل أن يُؤمَروا بقتال المشركين، فذلك قوله: <q>﴿فلا يُسرف في القتل﴾</q>. يقول: لا تَقتُل غير قاتلك. وهي اليوم على ذلك الموضع من المسلمين، لا يحلُّ لهم أن يقتُلوا إلا قاتِلَهم{2}. (٩/٣٣٨) ٤٣٠٣١- عن قتادة بن دعامة -من طريق سعيد- قوله: <q>﴿ولا تقتلوا النفس التي حرم الله إلا بالحق﴾</q>: وإنّا -واللهِ- ما نعلم بحِلِّ دمِ امرئ مسلم إلا بإحدى ثلاث: إلا رجلًا قتل متعمدًا فعليه القَوَدُ، أو زنى بعد إحصانه فعليه الرجم، أو كفر بعد إسلامه فعليه القتل{5}. (ز) ٤٣٠٣٢- عن زيد بن أسلم -من طريق يزيد بن عياض، وهشام بن سعد-: أنّ الناس في الجاهلية كانوا إذا قتَل الرجل مِن القوم رجلًا لم يرضَوا حتى يقتُلوا به رجلًا شريفًا إذا كان قاتلهم غير شريف، لم يقتلوا قاتلهم وقتلوا غيره، فوُعِظوا في ذلك بقول الله تعالى: <q>﴿ولا تقتلوا النفس﴾</q> إلى قوله: <q>﴿فلا يسرف في القتل﴾</q>{8}. (٩/٣٣٩) ٤٣٠٣٣- قال مقاتل بن سليمان: <q>﴿ولا تقتلوا النفس التي حرم الله﴾</q> قتلها، يعني: باغيًا، <q>﴿إلا بالحق﴾</q> الذي يَقْتُل فيُقْتَل به{9}. (ز) <q>﴿وَلَا تَقۡتُلُوا۟ ٱلنَّفۡسَ ٱلَّتِی حَرَّمَ ٱللَّهُ إِلَّا بِٱلۡحَقِّۗ﴾</q> - أحكام متعلقة بالآية ٤٣٠٣٤- عن عبد الله بن عمرو، قال: قال رسول الله ﷺ: «مَن قُتِل دون ماله فهو شهيد»{10}. (ز) ٤٣٠٣٥- عن عبد الله بن عباس، قال: قال رسول الله ﵇: «مَن قاتل دون ماله فقُتِل فهو شهيد، ومَن قاتل دون نفسه فقُتِل فهو شهيد، ومَن قاتل دون أهله فقُتِل فهو شهيد. وكل قتيل في جَنب الله فهو شهيد»{11}. (ز) ٤٣٠٣٦- عن قابوس بن المخارق، عن أبيه، أنّ رجلًا قال: يا رسول الله، الرجل يعرِض لي، يريد نفسي ومالي، كيف أصنع به؟ قال: «ناشِده الله». قال: نشدته بالله فلم ينتهِ. قال: «اسْتَعْدِ عليه السلطانَ». قال: ليس بحضرتنا سلطان. قال: «اسْتَعِن عليه المسلمين». قال: نحن بفلاة مِن الأرض، ليس قربنا أحد. قال: «فجاهده دون مالك حتى تمنعه، أو تكتب في شهداء الآخرة»{12}. (ز) <q>﴿وَمَن قُتِلَ مَظۡلُومࣰا فَقَدۡ جَعَلۡنَا لِوَلِیِّهِۦ سُلۡطَـٰنࣰا﴾</q> - تفسير ٤٣٠٣٧- عن عبد الله بن عباس -من طريق العوفي- في قوله: <q>﴿ومن قتل مظلومًا فقد جعلنا لوليه سلطانًا﴾</q>، قال: بيِّنَة مِن الله أنزلها، يطلبها ولِيُّ المقتول؛ القَوَدَ أو العقل{13}، وذلك السلطان{14}. (٩/٣٣٩) ٤٣٠٣٨- قال مجاهد بن جبر، في قوله: <q>﴿ومن قتل مظلوما فقد جعلنا لوليه سلطانا﴾</q>، أي: قوة وولاية على القاتل بالقتل{15}. (ز) ٤٣٠٣٩- عن الضحاك بن مزاحم -من طريق جويبر- في قوله: <q>﴿فقد جعلنا لوليه سلطانا﴾</q>، قال: إن شاء عفا، وإن شاء أخذ الدِّيَة{16}. (ز) ٤٣٠٤٠- عن الحسن البصري -من طريق أبي رجاء- في قوله: <q>﴿ومن قتل مظلوما فقد جعلنا لوليه سلطانا﴾</q>، قال: كان الرجل يُقْتَل، فيقول وليُّه: لا أرضى حتى أقتل به فلانًا وفلانًا مِن أشراف قبيلته{17}. (ز) ٤٣٠٤١- عن قتادة بن دعامة -من طريق سعيد- قوله: <q>﴿ومن قتل مظلوما فقد جعلنا لوليه سلطانا﴾</q>: وهو القَوَد الذي جعله الله تعالى{18}. (ز) ٤٣٠٤٢- تفسير [إسماعيل] السُّدِّيّ، قوله: <q>﴿ومن قتل مظلوما﴾</q>: يعني: المقتول ظلمه القاتل حين قتله بغير حقِّه{19}. (ز) ٤٣٠٤٣- قال مقاتل بن سليمان: <q>﴿ومن قتل مظلوما فقد جعلنا لوليه﴾</q> يعني: ولي المقتول <q>﴿سلطانا﴾</q> يعني: مسلطًا على القتلى{20}؛ إن شاء قَبِله، وإن شاء عفا عنه، وإن شاء أخذ الدية{9}٣٨٣٥. (ز) ٣٨٣٥ اختلف في معنى: <q>﴿فَقَدْ جَعَلْنا لِوَلِيِّهِ سُلْطانًا﴾</q> في هذه الآية على قولين: الأول: أنه الخيار بيْن القَوَد أو الدِّيَة أو العَفْو. الثاني: أنه القَوَد. ورجَّح ابن جرير (١٤/٥٨٤) مستندًا إلى السنة القول الأول، وهو قول ابن عباس، وقول الضحاك، وعلَّل ذلك بقوله: «لصحة الخبر عن رسول الله ﷺ أنه قال يوم فتح مكة: «ألا ومَن قُتِل له قتيلٌ فهو بخير النَّظَرَيْن، بيْن أن يَقتُل أو يأخذ الدية»». <q>﴿فَلَا یُسۡرِف فِّی ٱلۡقَتۡلِۖ﴾</q> - تفسير ٤٣٠٤٤- عن عبد الله بن عباس -من طريق مجاهد- في قوله: <q>﴿فلا يسرف في القتل﴾</q>، قال: لا يُكثِر في القتل{22}. (٩/٣٣٩) ٤٣٠٤٥- عن عبد الله بن عباس -من طريق أبي صالح- في قوله: <q>﴿فلا يسرف في القتل﴾</q>، قال: لا يقتل إلا قاتل رَحِمِه{23}. (٩/٣٣٩) ٤٣٠٤٦- عن مجاهد بن جبر، في قوله: <q>﴿فلا يسرف في القتل﴾</q>، قال: لا يقتُل غير قاتله{22}. (٩/٣٤٠) ٤٣٠٤٧- عن سعيد بن جبير -من طريق خُصَيْف- في قوله: <q>﴿فلا يسرف في القتل﴾</q>، قال: لا يقتل اثنين بواحد{25}. (٩/٣٤٠) ٤٣٠٤٨- عن مجاهد بن جبر -من طريق ابن كثير المكي- <q>﴿فلا يسرف في القتل﴾</q>، قال: لا يسرف القاتلُ في القتل{26}. (ز) ٤٣٠٤٩- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله تعالى: <q>﴿فلا يسرف في القتل إنه كان منصورا﴾</q>، قال: القتل سَرَف{27}. (ز) ٤٣٠٥٠- عن الضحاك بن مزاحم -من طريق عبيد- في قوله: <q>﴿فلا يُسرف في القتل﴾</q>، يقول: لا تَقتُل غير قاتلك{28}. (٩/٣٣٨) ٤٣٠٥١- عن طَلْق بن حبيب -من طريق منصور- في قوله: <q>﴿فلا يسرف في القتل﴾</q>، قال: لا تقتل غير قاتله، ولا تُمَثِّل به{29}. (٩/٣٣٩) ٤٣٠٥٢- عن الحسن البصري -من طريق أبي رجاء- قال: لا يقتل غير قاتله{30}. (ز) ٤٣٠٥٣- عن الحسن البصري -من طريق أبي رجاء- في قوله: <q>﴿ومن قتل مظلوما فقد جعلنا لوليه سلطانا﴾</q>، قال: كان الرجل يُقْتَل، فيقول وليُّه: لا أرضى حتى أقتل به فلانًا وفلانًا من أشراف قبيلته{17}. (ز) ٤٣٠٥٤- عن قتادة بن دعامة -من طريق معمر- <q>﴿فلا يُسرف في القتل﴾</q>، قال: لا تقتل غير قاتلك، ولا تُمَثِّل به{17}. (ز) ٤٣٠٥٥- عن قتادة بن دعامة -من طريق سعيد- <q>﴿فلا يسرف في القتل﴾</q>، قال: لا يقتل غير قاتله؛ مَن قَتَل بحديدة قُتِل بحديدة، ومن قَتَل بخشبة قُتِل بخشبة، ومَن قَتَل بحجر قُتِل بحجر. ذُكِر لنا: أنّ نبي الله ﷺ كان يقول: «إنّ مِن أعتى الناس على الله -جل ثناؤه- ثلاثة: رجل قتل غير قاتله، أو قتل بذحْلِ{33} الجاهلية، أو قتل في حرم الله»{34}. (٩/٣٤٠) ٤٣٠٥٦- عن زيد بن أسلم -من طريق يزيد بن عياض، وهشام بن سعد- في قوله: <q>﴿فلا يسرف في القتل﴾</q>، قال: السَّرَف: أن يقتل غير قاتله{8}. (٩/٣٣٩) ٤٣٠٥٧- قال مقاتل بن سليمان: ثم قال لولي المقتول: <q>﴿فلا يسرف في القتل إنه كان منصورا﴾</q>، من أمر الله ﷿ في كتابه جعل الأمر إليه، ولا تقتلن غير القاتل، فإنّ مَن قتل غير القاتل فقد أسرف؛ لقوله سبحانه: <q>﴿إنه كان منصورا﴾</q>{9}. (ز) ٤٣٠٥٨- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- قال في قول الله -جل ثناؤه-: <q>﴿ومن قتل مظلوما فقد جعلنا لوليه سلطانا﴾</q>، قال: إنّ العرب كانت إذا قُتِل منهم قتيل لم يرضوا أن يقتلوا قاتل صاحبهم، حتى يقتلوا أشرف مِن الذي قتله. فقال الله -جل ثناؤه-: <q>﴿فقد جعلنا لوليه سلطانا﴾</q> ينصره، وينتصف من حقه؛ <q>﴿فلا يسرف في القتل﴾</q> يقتل بريئًا{17}. (ز) ٤٣٠٥٩- قال يحيى بن سلّام: قوله: <q>﴿فلا يسرف في القتل﴾</q>: لا يقتل غير قاتله{38}٣٨٣٦. (ز) ٣٨٣٦ اختُلِف في معنى: <q>﴿فَلا يُسْرِفْ فِي القَتْلِ﴾</q> بناءً على اختلاف القرأة في قراءتها؛ فمن قرأها: ›فَلا تُسرِف‹ بالتاء: كانت على معنى الخطاب لرسول الله ﷺ، ولأُمَّته بعده. ووجَّهه ابنُ عطية (٥/٤٧٢) بقوله: «أي: فلا تقتلوا غير القاتل». ثم ذكر احتمالًا آخر أن يكون الخطاب للوليِّ، فقال: «ويصحّ أن يراد به الوليِّ، أي: فلا تسرف -أيُّها الوليُّ- في قتل أحد متحصل في هذا الحكم». ومن قرأها: <q>﴿فلا يُسرِف﴾</q> بالياء كان له فيها معنيان: الأول: فلا يُسرِف وليُّ المقتول فيَقْتُل غير قاتِلِ وليِّه. الثاني: فلا يُسرِف القاتل في القتل. ووجَّهه ابنُ عطية بقوله: «والمعنى: فلا يكن أحد من المسرفين بأن يقتل نفسًا، فإنه يحصل في سياق هذا الحكم». ورجَّح ابنُ جرير (١٤/٥٨٥، ٥٨٨) صوابَ القراءتين وتقارب معنييهما، ثم رجَّح صحة المعاني المبنية عليها القراءات مستندًا إلى دلالة العموم، فقال: «وإن كان كِلا وجْهَي القراءة عندنا صوابًا، فكذلك جميع أوجُهِ تأويله التي ذكرناها غيرُ خارجٍ وجْهٌ منها من الصواب». وعلَّل ذلك بقوله: «لاحتمال الكلام ذلك، وإنّ في نهي الله -جلَّ ثناؤُه- بعضَ خَلْقِه عن الإسراف في القتل نهيًا منه جميعَهم عنه». <q>﴿فَلَا یُسۡرِف فِّی ٱلۡقَتۡلِۖ﴾</q> - أحكام متعلقة بالآية ٤٣٠٦٠- عن عبد الله بن مسعود، قال: قال رسول الله ﷺ: «أعفُّ الناس قِتلةً أهل الإيمان»{39}. (٩/٣٤١) ٤٣٠٦١- عن سمُرة بن جندب، وعمران بن حصين، قالا: نهى رسول الله ﷺ عن المُثلَةِ{40}. (٩/٣٤١) <q>﴿إِنَّهُۥ كَانَ مَنصُورࣰا ۝٣٣﴾</q> - تفسير ٤٣٠٦٢- عن عبد الله بن عباس، في قوله: <q>﴿فلا يسرف في القتل إنه كان منصورًا﴾</q>، يقول: ينصُرُه السلطان حتى يُنصِفَه مِن ظالمه، ومن انتصر لنفسه دون السلطان فهو عاصٍ مُسْرِفٌ قد عمِل بحَمِيَّةِ أهل الجاهلية، ولم يرضَ بحكم الله تعالى{41}. (٩/٣٤١) ٤٣٠٦٣- عن مجاهد بن جبر -من طريق ابن كثير المكي- في قوله: <q>﴿إنه كان منصورًا﴾</q>، قال: إنّ المقتول كان منصورًا{42}. (٩/٣٤١) ٤٣٠٦٤- عن قتادة بن دعامة -من طريق معمر- <q>﴿إنه كان منصورا﴾</q>، قال: هو دفع الإمام إليه -يعني: إلى الولي-؛ فإن شاء قتل، وإن شاء عفا{43}. (ز) ٤٣٠٦٥- قال يحيى بن سلّام: وبعضهم يقول: <q>﴿إنه كان منصورا﴾</q>، يعني: في الآخرة، يعني: الذي يُعدى عليه فَقُتِلَ، وليس هو قاتل الأول ينصر على الذي تعدّى عليه فقتله{38}٣٨٣٧. (ز) ٣٨٣٧ اختُلِف في عود الضمير في قوله تعالى: <q>﴿إنَّهُ كانَ مَنصُورًا﴾</q> على ثلاثة أقوال: الأول: أنه يعود على وليِّ المقتول، وهو المنصور على القاتل، والمعنى: إنه كان منصورًا بتمكينه من القَوَد. الثاني: أنه يعود على المقتول، والمعنى: إنه كان منصورًا بقتل قاتله. الثالث: أنه يعود على دم المقتول، والمعنى: إن دم القتيل كان منصورًا، أي: مطلوبًا به. ورجَّح ابنُ جرير (١٤/٥٨٩) مستندًا إلى دلالة اللغة، والدلالة العقلية القولَ الأول، وهو قول قتادة، وعلَّل ذلك بقوله: «لأنه هو المظلوم، ووَلِيُّه المقتول، وهي إلى ذِكْرِه أقربُ من ذِكْر المقتول، وهو المنصور أيضًا؛ لأن الله -جلَّ ثناؤه- قضى في كتابه المُنَزَّل أن سلَّطه على قاتل وليِّه، وحكَّمه فيه بأن جعل إليه قتْلَه إن شاء، واستبقاءَه على الدِّيَة إن أحبَّ، والعفوَ عنه إن رأى، وكفى بذلك نصرةً له من الله، فلذلك قلنا: هو المعنيُّ بالهاء التي في قوله: <q>﴿إنَّهُ كانَ مَنصُورًا﴾</q>». ورجَّح ابنُ عطية (٥/٤٧٣) مستندًا إلى الدلالة العقلية القول الثاني، وهو قول مجاهد، فقال: «وهو أرجح الأقوال؛ لأنه المظلوم، ولفظة النصر تقارن أبدًا الظلم، كقوله عليه الصلاة والسلام: «ونَصْر المظلوم، وإبْرار القَسم». وكقوله ﷺ: «انصر أخاك ظالمًا أو مظلومًا». إلى كثيرٍ من الأمثلة». ونقل قولًا عن أبي عبدة: أن الضمير يعود «على القاتل؛ لأنه إذا قُتِل في الدنيا وخلص بذلك من عذاب الآخرة فقد نُصِر». ثم انتقده قائلًا: «وهذا ضعيفٌ بعيد المقصد». <q>﴿إِنَّهُۥ كَانَ مَنصُورࣰا ۝٣٣﴾</q> - آثار متعلقة بالآية ٤٣٠٦٦- عن عبد الله بن عباس، قال: إنّه لَمّا كان مِن أمر هذا الرجل ما كان -يعني: عثمان- قلتُ لعليٍّ: اعتزل، فلو كنتَ في جحرٍ طُلِبتَ حتى تُستخرَجَ. فعصاني، وايمُ اللهِ، ليَتَأمَرَنَّ عليكم معاوية، وذلك أنّ الله يقول: <q>﴿ومن قتل مظلومًا فقد جعلنا لوليه سلطانًا فلا يسرف في القتل إنه كان منصورًا﴾</q>{45}. (٩/٣٤٢) ",footnotes:1:عزاه السيوطي إلى أبي عبيد، وابن المنذر. وهي قراءة شاذة. انظر: مختصر ابن خالويه ص٨٠.أخرجه ابن جرير ١٤/٥٨٦. وعزاه السيوطي إلى ابن المنذر.أخرجه أحمد ١/٤٩١ (٤٣٧)، ١/٥١١-٥١٢ (٤٦٨)، ١/٥٣٤ (٥٠٩)، والنسائي ٧/٩١ (٤٠١٩)، والشافعي في اختلاف الحديث ٨/٦٤٣ واللفظ له، ويحيى بن سلام في تفسيره ١/١٣٣. قال الشافعي: «وهذا حديث لا يَشُكُّ أهل العلم بالحديث في ثبوته عن النبي ﷺ».أخرجه ابن جرير ١٤/٥٨٢-٥٨٣. وأورده الثعلبي ٦/٩٧. وأصله في البخاري ١/٨٧ (٣٩٢).أخرجه ابن جرير ١٤/٥٨٢.أخرجه ابن جرير ١٤/٥٨٦. وعزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ١٤/٥٨٢.أخرجه البيهقي في سُنَنِه ٨/٢٥.تفسير مقاتل بن سليمان ٢/٥٣٠.أخرجه البخاري ٣/١٣٦ (٢٤٨٠)، ومسلم ١/١٢٤ (١٤١)، ويحيى بن سلام في تفسيره ١/١٣٣.أخرجه الحارث في مسنده ٢/٦٦٠ (٦٣٦)، وابن البختري في مجموع فيه مصنفاته ص٢٢٤ (٢٠٩)، ويحيى بن سلام في تفسيره ١/١٣٣. قال البوصيري في إتحاف الخيرة ٥/١٥١ (٤٤٢٣): «مدار حديث ابن عباس هذا على جويبر بن سعيد البلخي، وهو ضعيف، ضعَّفه ابن المديني، وأحمد، وابن معين، والنسائي، وعلي بن الجنيد، والدارقطني، وابن عدي، وأبو أحمد الحاكم، والحاكم أبو عبد الله، والذهبي، وغيرهم». وقال الكتاني في نظم المتناثر في الحديث المتواتر ص١٤٦: «أورده في الأزهار في كتاب الأدب من حديث ابن عمرو، وأبي هريرة، والحسين بن علي، وابن عباس، وسعد بن أبي وقاص، وأنس، وابن الزبير، وابن مسعود، وعبد الله بن عامر بن كريز، وشداد بن أوس، وعلي بن أبي طالب، وجابر بن عبد الله، وسويد بن مقرن ثلاثة عشر نفسًا. قلت: ورد أيضًا من حديث بريدة، وابن عمر بن الخطاب، وسعيد بن زيد».أخرجه أحمد ٣٧/١٩١-١٩٢ (٢٢٥١٣، ٢٢٥١٤)، والنسائي ٧/١١٣ (٤٠٨١)، ويحيى بن سلام في تفسيره ١/١٣٣. قال المناوي في فيض القدير ٤/٤٦٧ (٥٩٩٧): «رمز المصنف -السيوطي- لحسنه». وقال الألباني في الصحيحة ٧/٧٥١: «وإسناده حسن».العقل: الدية. اللسان (عقل).أخرجه ابن جرير ١٤/٥٨٣. وعزاه السيوطي إلى ابن أبي حاتم.تفسير البغوي ٥/٩١.أخرجه ابن جرير ١٤/٥٨٣.أخرجه ابن جرير ١٤/٥٨٧.أخرجه ابن جرير ١٤/٥٨٤. وعلقه يحيى بن سلام ١/١٣٤، وزاد: إلا أن يعفو الولي، أو يرضى بالدية إن أُعْطِيها.علقه يحيى بن سلام ١/١٣٣.كذا في المصدر. ولعلها تصحَّفت عن القاتل.تفسير مقاتل بن سليمان ٢/٥٣٠.عزاه السيوطي إلى ابن أبي حاتم.عزاه السيوطي إلى ابن المنذر.عزاه السيوطي إلى ابن أبي حاتم.أخرجه عبد الرزاق ١/٣٧٧، وابن أبي شيبة ٩/٤٢٣-٤٢٤، وابن جرير ١٤/٥٨٦ بلفظ: لا تقتل اثنين بواحد. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.أخرجه ابن جرير ١٤/٥٨٨.أخرجه أبو جعفر الرملي في جزئه ص٥٢ (تفسير مسلم الزنجي).أخرجه ابن جرير ١٤/٥٨٦ مطولًا. وعزاه السيوطي إلى ابن المنذر.أخرجه ابن أبي شيبة ٩/٤٢٣، وابن جرير ١٤/٥٨٥ واللفظ له، والبيهقي في سُنَنِه ٨/٢٥. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.أخرجه يحيى بن سلام ١/١٣٤.أخرجه ابن جرير ١٤/٥٨٧.أخرجه ابن جرير ١٤/٥٨٧.الذحل: الثأر، أو طلب مكافأة بجناية جُنيت عليك، أو عداوة أتيت إليك، أو هو العداوة والحقد. القاموس المحيط (ذحل).أخرجه يحيى بن سلام ١/١٣٤ مختصرًا من طريق سعيد، ومن طريق حماد، وابن جرير ١٤/٥٨٧. وعزاه السيوطي إلى ابن أبي حاتم. والجزء المرفوع أخرجه أحمد (٦٦٨١) من حديث عبد الله بن عمرو بن العاص بنحوه، كما أخرجه في (١٦٣٧٦، ١٦٣٧٨)، والبيهقي ٨/٢٦ من حديث أبي شريح الخزاعي بنحوه.أخرجه البيهقي في سُنَنِه ٨/٢٥.تفسير مقاتل بن سليمان ٢/٥٣٠.أخرجه ابن جرير ١٤/٥٨٧.تفسير يحيى بن سلام ١/١٣٤.أخرجه أحمد ٦/٢٧٤-٢٧٦ (٣٧٢٨، ٣٧٢٩)، وأبو داود ٤/٣٠٠ (٢٦٦٦)، وابن ماجه ٣/٦٨٨، ٦٨٩ (٢٩٨١، ٢٩٨٢)، وابن حبان ١٣/٣٣٥ (٥٩٩٤). قال ابن حزم في المحلى ١٠/٢٦٤: «وإن لم يصح لفظه -فإن فيه هنيء بن نويرة، وهو مجهول-، فمعناه صحيح». وقال المناوي في فيض القدير ٢/٧ (١١٩٠): «رجاله ثقات». وقال الألباني في ضعيف أبي داود ٢/٣٣٤ (٤٥٨): «ضعيف». وقال في الضعيفة ٣/٣٧٦ (١٢٣٢): «ضعيف؛ لاضطرابه وجهالته ... وجملة القول أن الحديث ضعيف مرفوعًا، وقد يصح موقوفًا».أخرجه أحمد ٣٣/٧٨-٧٩ (١٩٨٤٤)، ٣٣/٨٠-٨١ (١٩٨٤٦)، ٣٣/١٤١ (١٩٩٠٩)، وأبو داود ٤/٣٠١ (٢٦٦٧). قال البزار في مسنده ٩/٧٥- ٧٦ (٣٦٠٥): «هذا الحديث قد روي عن عمران بن حصين من غير وجه، ورواه عن الحسن غير واحد عن عمران، ولم يدخل بين عمران والحسن أحدًا غير قتادة». وقال فيه ١٠/٤٤٢ (٤٥٩٨): «قال أبو بكر: وهذا الحديث قد رواه جماعة عن الحسن عن عمران بن حصين، والصواب: عن عمران بن حصين». وقال البيهقي في معرفة السنن والآثار ١٤/٢٠١ (١٩٦٦٣): «هذا أصح ما روي فيه عن عمران». وقال في السنن الكبرى ١٠/١٢٢: «هذا إسناد موصول». وقال ابن القيسراني في ذخيرة الحفاظ ٤/٢٠٩٥ (٤٨٤٢): «رواه أبو بكر الهذلي ... والهذلي متروك الحديث». وقال ابن حجر في الفتح ٧/٤٥٩: «إسناد هذا الحديث قوي». وقال الهيثمي في المجمع ٤/١٨٩ (٦٩٦٩): «رواه أحمد والبزار بنحوه، والطبراني في الكبير، ورجال أحمد رجال الصحيح». وقال الألباني في صحيح أبي داود ٧/٤١٩-٤٢٠ (٢٣٩٣): «صح الحديث يقينًا».عزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.أخرجه ابن جرير ١٤/٥٨٩. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم. وفي تفسير الثعلبي ٦/٩٨: <q>﴿ومن قتل مظلوما﴾</q> يعني: أن المقتول منصور في الدنيا بالقصاص، وفي الآخرة بالتوبة.أخرجه ابن جرير ١٤/٥٨٨. وعلق يحيى بن سلام ١/١٣٤ نحوه بلفظ: ينصره السلطان حتى يُقِيده منه.تفسير يحيى بن سلام ١/١٣٤.أخرجه الطبراني (١٠٦١٣)، وابن عساكر ٣٩/٤٧٧، ٥٩/١٢٥.
17,34," <q>﴿وَلَا تَقۡرَبُوا۟ مَالَ ٱلۡیَتِیمِ إِلَّا بِٱلَّتِی هِیَ أَحۡسَنُ﴾</q> - تفسير ٤٣٠٦٧- قال مجاهد بن جبر: أي: <q>﴿لا تقربوا مال اليتيم﴾</q> فتستقرضوا منه <q>﴿إلا بالتي هي أحسن﴾</q> التجارة لهم{1}. (ز) ٤٣٠٦٨- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿ولا تقربوا مال اليتيم إلا بالتي هي أحسن﴾</q>، قال: كانوا لا يُخالِطونهم في مالٍ، ولا مأكلٍ، ولا مركبٍ، حتى نزلت: <q>﴿وإن تخالطوهم فإخوانكم﴾</q> [البقرة:٢٢٠]{2}. (٩/٣٤٢) ٤٣٠٦٩- قال مقاتل بن سليمان: <q>﴿ولا تقربوا مال اليتيم إلا بالتي هي أحسن﴾</q>، إلا لِتُنَمِّي ماله بالأرباح{3}. (ز) ٤٣٠٧٠- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿ولا تقربوا مال اليتيم إلا بالتي هي أحسن﴾</q>، قال: الأكل بالمعروف؛ أن تأكل معه إذا احتجت إليه. كان أبي{4} يقول ذلك{2}. (ز) ٤٣٠٧١- قال يحيى بن سلّام: قوله: <q>﴿ولا تقربوا مال اليتيم إلا بالتي هي أحسن﴾</q>، والتي هي أحسن: أن يوفر ماله، حتى إذا بلغ أشده دفع إليه ماله إن آنس منه رشدًا{6}. (ز) <q>﴿حَتَّىٰ یَبۡلُغَ أَشُدَّهُۥۚ﴾</q> - تفسير ٤٣٠٧٢- عن سعيد بن جبير -من طريق عطاء بن دينار- قال: <q>﴿ولا تقربوا مال اليتيم إلا بالتي هي أحسن حتى يبلغ أشده﴾</q> [الأنعام:١٥٢]، أي: ثماني عشرة سنة. ومثلها في سورة بني إسرائيل{7}. (ز) ٤٣٠٧٣- قال مقاتل بن سليمان: <q>﴿حتى يبلغ أشده﴾</q>، يعني: ثماني عشرة سنة{3}. (ز) <q>﴿حَتَّىٰ یَبۡلُغَ أَشُدَّهُۥۚ﴾</q> - النسخ في الآية ٤٣٠٧٤- عن قتادة بن دعامة -من طريق سعيد- قال: لَمّا نزلت هذه الآية اشتدَّت عليهم، فكانوا لا يخالطونهم في المال، ولا في المأكل، فجَهَدَهم ذلك، فنسختها هذه الآية: <q>﴿وإن تخالطوهم فإخوانكم والله يعلم المفسد من المصلح﴾</q> [البقرة:٢٢٠]{9}. (ز) ٤٣٠٧٥- قال مقاتل بن سليمان: نسختها: <q>﴿وإن تخالطوهم فإخوانكم﴾</q>{3}. (ز) <q>﴿وَأَوۡفُوا۟ بِٱلۡعَهۡدِۖ إِنَّ ٱلۡعَهۡدَ كَانَ مَسۡـُٔولࣰا ۝٣٤﴾</q> - تفسير ٤٣٠٧٦- عن سعيد بن جبير، في قوله: <q>﴿إن العهد كان مسئولًا﴾</q>، قال: يسأل اللهُ ناقضَ العهد عن نقضه{11}. (٩/٣٤٣) ٤٣٠٧٧- عن ميمون بن مِهران، قال: ثلاث تُؤَدّى إلى البَرِّ والفاجر: العهد يُوفى إلى البرِّ والفاجر. وقرأ: <q>﴿وأوفوا بالعهد إن العهد كان مسئولًا﴾</q>{11}. (٩/٣٤٣) ٤٣٠٧٨- قال إسماعيل السُّدِّيّ، في قوله: <q>﴿إن العهد كان مسئولا﴾</q>: كان مطلوبًا{13}. (ز) ٤٣٠٧٩- عن إسماعيل السُّدِّيّ، في قوله: <q>﴿وأوفوا بالعهد إن العهد كان مسئولًا﴾</q>، قال: يوم أُنزلت هذه كان إنما يُسألُ عنه، ثم يَدْخُلُ الجنةَ، فنزلت: <q>﴿إن الذين يشترون بعهد الله وأيمانهم ثمنًا قليلًا أولئك لا خلاق لهم في الآخرة﴾</q> [آل عمران:٧٧]{14}. (٩/٣٤٢) ٤٣٠٨٠- قال مقاتل بن سليمان: <q>﴿وأوفوا بالعهد﴾</q> فيما بينكم وبين الناس؛ <q>﴿إن العهد﴾</q> إذا نُقِض <q>﴿كان مسؤولا﴾</q> يقول: الله سائلكم عنه في الآخرة{3}. (ز) ٤٣٠٨١- عن عبد الملك ابن جريج، في قوله: <q>﴿إن العهد كان مسئولًا﴾</q>، قال: يسأل عهدَه مَن أعطاه إيّاه{16}. (٩/٣٤٣) ٤٣٠٨٢- قال يحيى بن سلّام: قوله: <q>﴿وأوفوا بالعهد﴾</q> يعني: ما عاهدتم عليه فيما وافق الحق؛ <q>﴿إن العهد كان مسئولا﴾</q> مطلوبًا، يُسْأَل عنه أهلُه الذين أعطوه{17}. (ز) <q>﴿وَأَوۡفُوا۟ بِٱلۡعَهۡدِۖ إِنَّ ٱلۡعَهۡدَ كَانَ مَسۡـُٔولࣰا ۝٣٤﴾</q> - آثار متعلقة بالآية ٤٣٠٨٣- عن كعب الأحبار، قال: مَن نكث بيعة كانت سِترًا بينه وبين الجنة. قال: وإنما تَهلِكُ هذه الأُمَّة بنَكثِها عُهُودَها{11}. (٩/٣٤٣) ",footnotes:1:علقه النحاس في ناسخه ٢/٤٩٥.أخرجه ابن جرير ١٤/٥٩٠.تفسير مقاتل بن سليمان ٢/٥٣٠.ضبطت في طبعة «هجر» ١٤/٥٩٠ بضم الهمزة وفتح الباء وتشديد الياء: أُبَيٌّ!أخرجه ابن جرير ١٤/٥٩٠.تفسير يحيى بن سلام ١/١٣٤.أخرجه الطحاوي في شرح معاني الآثار ٣/٢٢٠.تفسير مقاتل بن سليمان ٢/٥٣٠.أخرجه يحيى بن سلام ١/١٣٤، وابن جرير ١٤/٥٩٠ بنحوه، والنحاس في ناسخه ٢/٤٩٥.تفسير مقاتل بن سليمان ٢/٥٣٠.عزاه السيوطي إلى ابن أبي حاتم.عزاه السيوطي إلى ابن أبي حاتم.تفسير البغوي ٥/٩٢.عزاه السيوطي إلى ابن أبي حاتم. وينظر: تفسير السدي لقوله تعالى: <q>﴿ولا تقف ما ليس لك به علم﴾</q> فيما يأتي.تفسير مقاتل بن سليمان ٢/٥٣٠.عزاه السيوطي إلى ابن المنذر.تفسير يحيى بن سلام ١/١٣٥.عزاه السيوطي إلى ابن أبي حاتم.
17,35," <q>﴿وَأَوۡفُوا۟ ٱلۡكَیۡلَ إِذَا كِلۡتُمۡ﴾</q> - تفسير ٤٣٠٨٤- عن سعيد بن جبير، في قوله: <q>﴿وأوفوا الكيل إذا كِلتم﴾</q>: يعني: لغيركم{1}. (٩/٣٤٣) <q>﴿وَزِنُوا۟ بِٱلۡقِسۡطَاسِ ٱلۡمُسۡتَقِیمِۚ﴾</q> - تفسير ٤٣٠٨٥- عن سعيد بن جبير، في قوله: <q>﴿وزنوا بالقسطاس المستقيم﴾</q>، يعني: الميزان، وبلغة الروم الميزان: القسطاس{1}. (٩/٣٤٣) ٤٣٠٨٦- عن مجاهد بن جبر -من طريق جابر- قال: القسطاس: العدل، بالرُّوميَّة{3}٣٨٣٨. (٩/٣٤٤) ٣٨٣٨ وجَّه ابن عطية (٥/٤٧٧) قول مجاهد بقوله: «فكأن الناس قيل لهم: زِنوا بمعدلةٍ في وزنكم». ٤٣٠٨٧- عن الضحاك بن مزاحم، <q>﴿وزنوا بالقسطاس﴾</q>، قال: القَبّانِ{4}{5}. (٩/٣٤٤) ٤٣٠٨٨- عن الحسن البصري -من طريق الحسن بن ذكوان- <q>﴿وزنوا بالقسطاس﴾</q>، قال: القَبّان{6}. (٩/٣٤٤) ٤٣٠٨٩- عن الحسن البصري -من طريق مبارك- <q>﴿وزنوا بالقسطاس﴾</q>، قال: بالحديد{7}. (٩/٣٤٥) ٤٣٠٩٠- عن قتادة بن دعامة -من طريق سعيد- <q>﴿وزنوا بالقسطاس﴾</q>، قال: العدل{8}. (٩/٣٤٤) ٤٣٠٩١- قال مقاتل بن سليمان: <q>﴿وزنوا بالقسطاس﴾</q>، يعني: بالميزان، بلغة الروم{9}. (ز) ٤٣٠٩٢- قال يحيى بن سلّام: قوله: <q>﴿وزنوا بالقسطاس المستقيم﴾</q>، والقسطاس: العدل، بالرومية{10}. (ز) <q>﴿ذَ ٰ⁠لِكَ خَیۡرࣱ﴾</q> - تفسير ٤٣٠٩٣- عن سعيد بن جبير، في قوله: <q>﴿ذلك خير﴾</q>، يعني: وفاء الكيل والميزان خيرٌ من النقصان{1}. (٩/٣٤٣) ٤٣٠٩٤- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿ذلك خير﴾</q>، أي: خيرٌ ثوابًا{12}. (٩/٣٤٤) ٤٣٠٩٥- قال مقاتل بن سليمان: <q>﴿ذلك﴾</q> الوفاء <q>﴿خير﴾</q> مِن النُّقصان{13}. (ز) ٤٣٠٩٦- قال يحيى بن سلّام: قوله: <q>﴿ذلك خير﴾</q> إذا أوفيتم الكيل، وأقمتم الوزن{10}. (ز) <q>﴿وَأَحۡسَنُ تَأۡوِیلࣰا ۝٣٥﴾</q> - تفسير ٤٣٠٩٧- عن سعيد بن جبير، في قوله: <q>﴿وأحسن تأويلًا﴾</q>: عاقبة{1}. (٩/٣٤٣) ٤٣٠٩٨- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿وأحسن تأويلًا﴾</q>، أي: وعاقبة{16}٣٨٣٩. (٩/٣٤٤) ٣٨٣٩ ذكر ابنُ عطية (٥/٤٧٧) في معنى: «التأويل» احتمالًا آخر، فقال: «ويحتمل أن يكون»التأويل«مصدر تأوَّل، أي: يتأول عليكم الخير في جميع أموركم إذا أحسنتم في الكيل والوزن». ٤٣٠٩٩- تفسير إسماعيل السُّدِّيّ: <q>﴿وأحسن تأويلا﴾</q>، يعني: عاقبة في الآخرة{17}. (ز) ٤٣١٠٠- قال مقاتل بن سليمان: <q>﴿وأحسن تأويلا﴾</q>، يعني: وخير عاقبة في الآخرة{13}. (ز) <q>﴿وَأَحۡسَنُ تَأۡوِیلࣰا ۝٣٥﴾</q> - آثار متعلقة بالآية ٤٣١٠١- قال قتادة: وأُخبِرنا أن عبد الله بن عباس كان يقول: يا معشر الموالي، إنكم ولِيتُم أمرين بهما هلك الناس قبلَكم؛ هذا المكيال، وهذا الميزان. قال: وذُكِر لنا: أنّ نبي الله ﷺ كان يقول: «لا يقدر رجل على حرام ثم يدعه، ليس به إلا مخافة الله؛ إلا أبدله الله في عاجل الدنيا قبل الآخرة ما هو خيرٌ له من ذلك»{19}. (٩/٣٤٤) ",footnotes:1:عزاه السيوطي إلى ابن أبي حاتم.عزاه السيوطي إلى ابن أبي حاتم.أخرجه يحيى بن سلام ٢/٥٢٢، والفريابي -كما في التغليق ٥/٣٨٢-٣٨٣-، وابن أبي شيبة ١٠/٤٧١-٤٧٢، وابن جرير ١٤/٥٩٢ من طريق ابن جريج، وابن أبي حاتم ٩/٢٨١٢. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.القبان: الذي يوزن به. لسان العرب (قبن).عزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ١٤/٥٩١، وابن أبي حاتم ٩/٢٨١٢ من طريق عمرو. وعزاه السيوطي إلى عبد بن حميد.أخرجه ابن أبي حاتم ٩/٢٨١٢.أخرجه ابن أبي حاتم ٩/٢٨١٢. وعلقه يحيى بن سلام ٢/٥٢٢. وعزاه السيوطي إلى عبد بن حميد.تفسير مقاتل بن سليمان ٢/٥٣٠، ٣/٢٧٨.تفسير يحيى بن سلام ١/١٣٥.عزاه السيوطي إلى ابن أبي حاتم.أخرجه يحيى بن سلام ١/١٣٥، وابن جرير ١٤/٥٩٣. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.تفسير مقاتل بن سليمان ٢/٥٣٠.تفسير يحيى بن سلام ١/١٣٥.عزاه السيوطي إلى ابن أبي حاتم.أخرجه يحيى بن سلام ١/١٣٥، وعبد الرزاق في تفسيره ١/٥٩٣ من طريق معمر بلفظ: عاقبة وثوابًا، وابن جرير ١٤/٥٩٣، ومن طريق معمر أيضًا بلفظ: عاقبة وثوابًا. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.علقه يحيى بن سلام ١/١٣٥.تفسير مقاتل بن سليمان ٢/٥٣٠.أخرجه ابن جرير ١٤/٥٩٣. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.
17,36," <q>﴿وَلَا تَقۡفُ مَا لَیۡسَ لَكَ بِهِۦ عِلۡمٌۚ﴾</q> - تفسير ٤٣١٠٢- عن عبد الله بن عباس -من طريق علي- في قوله: <q>﴿ولا تقف﴾</q>، قال: لا تَقُل{1}. (٩/٣٤٥) ٤٣١٠٣- عن عبد الله بن عباس -من طريق العوفي- في قوله: <q>﴿ولا تقف ما ليس لك به علم﴾</q>، يقول: لا تَرمِ أحدًا بما ليس لك به علم{2}. (٩/٣٤٥) ٤٣١٠٤- عن محمد ابن الحنفية -من طريق أبي عمر البزار- في قوله: <q>﴿ولا تقف ما ليس لك به علم﴾</q>، قال: شهادة الزور{3}. (٩/٣٤٥) ٤٣١٠٥- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿ولا تقف﴾</q>، يقول: ولا تَرْم{4}. (ز) ٤٣١٠٦- تفسير الحسن [البصري]: لا تقْف أخاك المسلم من بعده إذا مَرَّ بك، فتقول: إني رأيت هذا يفعل كذا، ورأيته يفعل كذا، وسمعته يقول كذا، لم تسمع ولم تر{5}. (ز) ٤٣١٠٧- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿ولا تقف ما ليس لك به علم﴾</q>، قال: لا تقل: سمعتُ؛ ولم تسمع، ولا تقل: رأيتُ؛ ولم تر، فإنّ الله سائِلُك عن ذلك كلِّه{6}. (٩/٣٤٦) ٤٣١٠٨- عن إسماعيل السُّدِّيّ، في قوله: <q>﴿ولا تقف ما ليس لك به علم﴾</q>، قال: هذا في الفِرْية، يوم نزلت الآية لم يكن فيها حَدٌّ، إنّما كان يُسأل عنه يوم القيامة، ثم يُغفر له، حتى نزلت آية الفِرية؛ جلد ثمانين{7}. (٩/٣٤٥) ٤٣١٠٩- قال مقاتل بن سليمان: <q>﴿ولا تقف ما ليس لك به علم﴾</q>، يقول: ولا ترمِ بالشرك؛ فإنّه ليس لك به علم أنّ لي شريكًا{8}. (ز) ٤٣١١٠- عن محمد بن أبي تميلة، قال: سمعت الفضيل بن عياض يقول: ليس لأحد أن يقول ما لا يعلم، أو يسمع إلى ما شاء، أو يهوى ما شاء؛ لأن الله ﷿ يقول: <q>﴿ولا تقف ما ليس لك به علم إن السمع والبصر والفؤاد كل أولئك كان عنه مسئولا﴾</q>، ولا تفعل، يقول: ولا تقل{9}٣٨٤٠. (ز) ٣٨٤٠ اختُلِف في معنى: <q>﴿ولا تَقْفُ ما لَيْسَ لَكَ بِهِ عِلْمٌ﴾</q> في هذه الآية على قولين: الأول: ولا تَقُلْ ما ليس لك به علم. الثاني: لا تَرْمِ أحدًا بما ليس لك به علم. ورجَّح ابنُ جرير (١٤/٥٩٥) شمول الآية للمعنيين مستندًا إلى دلالة العموم، وعلَّل ذلك بقوله: «لأن القول بما لا يعلمه القائل يدخل فيه شهادة الزور، ورَمْيُ الناس بالباطل، وادعاءُ سماع ما لم يَسْمَعْهُ ورؤية ما لم يَرَهُ». وذكر ابنُ جرير (١٤/٥٩٥) أن أصل القَفْو: «العَضَهُ والبَهْتُ، ومنه قول النبي ﷺ: «نحن بنو النضر بن كنانة لا نَقْفُو أُمَّنا، ولا نَنتَفي من أبِينا»». ثم نقل عن بعض اللغويين أن معنى قوله: <q>﴿ولا تَقْفُ﴾</q>: لا تَتَّبِعْ ما لا تعلم ولا يَعْنِيك، وأن أصله القيافة، وهي اتَّباع الأثر. ثم رجَّح (١٤/٥٩٦) مستندًا إلى الأغلب من لغة العرب ما ذهب إليه من أن معنى: <q>﴿ولا تَقْفُ﴾</q>: «لا تَقُلْ للناس وفيهم ما لا علم لك به، فَتَرْمِيَهم بالباطل، وتَشْهَدَ عليهم بغير الحق، فذلك هو القَفْوُ». وعلَّل ذلك بقوله: «لأن ذلك هو الغالب من استعمال العرب القَفْوَ فيه». <q>﴿إِنَّ ٱلسَّمۡعَ وَٱلۡبَصَرَ وَٱلۡفُؤَادَ كُلُّ أُو۟لَـٰۤىِٕكَ كَانَ عَنۡهُ مَسۡـُٔولࣰا ۝٣٦﴾</q> - تفسير ٤٣١١١- عن عبد الله بن عباس، في قوله: <q>﴿كل أولئك كان عنه مسئولًا﴾</q>، قال: يوم القيامة؛ يقال: أكذلك كان أم لا؟{10}. (٩/٣٤٦) ٤٣١١٢- عن عكرمة مولى ابن عباس، في قوله: <q>﴿إن السمع والبصر والفؤاد كلُّ أولئك كان عنه مسئولًا﴾</q>، يقول: سمعُه وبصرُه يشهَدُ عليه{7}. (٩/٣٤٥) ٤٣١١٣- عن عمرو بن قيس{12}، في قوله: <q>﴿كل أولئك كان عنه مسئولًا﴾</q>، قال: يُقال للأُذُن يوم القيامة: هل سمعتِ؟ ويُقال للعين: هل رأيتِ؟ ويُقال للفؤاد مثل ذلك{7}. (٩/٣٤٦) ٤٣١١٤- قال مقاتل بن سليمان: ثم حذرهم <q>﴿إن السمع والبصر والفؤاد﴾</q> يعني: القلب، <q>﴿كل أولئك كان عنه مسؤولا﴾</q> يعني: عن الشرك مسئولًا في الآخرة{8}. (ز) ٤٣١١٥- قال يحيى بن سلّام: <q>﴿كل أولئك﴾</q> كل ذلك <q>﴿كان عنه مسئولا﴾</q> يُسأل السمع على حدة عما سمع، ويُسأل البصر على حدة عما بصر، ويُسأل القلب عمّا عزم عليه{15}٣٨٤١. (ز) ٣٨٤١ ذكر ابنُ عطية (٥/٤٨٠) احتمالين آخرين لعود الضمير في <q>﴿عَنْهُ﴾</q>، فقال: «والضمير في <q>﴿عنه﴾</q> يعود على ما ليس للإنسان به علم، ويكون المعنى: أن الله تعالى يسأل سمع الإنسان وبصره وفؤاده عما قال مما لا علم له به، فيقع تكذيبه من جوارحه، وتلك غاية الخزي. ويحتمل أن يعود الضمير في <q>﴿عَنْهُ﴾</q> على <q>﴿كُلُّ﴾</q> التي هي للسمع والبصر والفؤاد، والمعنى: أن الله تعالى يسأل الإنسان عما حواه سمعه وبصر وفؤاده». ثم وجَّهه بقوله: «فكأنه قال: كل هذه كان الإنسان عنه مسؤولًا، أي: عما حصل لهؤلاء من الإدراكات، ووقع منها من الخطايا، فالتقدير: عن أعمالها مسؤولًا. فهو على حذف مضاف». ",footnotes:1:أخرجه ابن جرير ١٤/٥٩٣، وابن أبي حاتم -كما في التغليق ٤/٢٤٢-. وفي تفسير الثعلبي ٦/٩٨: لا تقل: رأيتُ؛ ولم تر، وسمعتُ؛ ولم تسمعه، وعلمتُ؛ ولم تعلمه.أخرجه ابن جرير ١٤/٥٩٤.أخرجه ابن أبي شيبة ٧/٢٥٨، وابن جرير ١٤/٥٩٤. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.أخرجه ابن جرير ١٤/٥٩٥.علقه يحيى بن سلام ١/١٣٥.أخرجه يحيى بن سلام ١/١٣٥، وعبد الرزاق ١/٣٧٨ من طريق معمر، وابن جرير ١٤/٥٩٤ من طريق معمر أيضًا بنحوه. وعزاه السيوطي إلى ابن أبي حاتم.عزاه السيوطي إلى ابن أبي حاتم.تفسير مقاتل بن سليمان ٢/٥٣٠.أخرجه البيهقي في الزهد الكبير ص٣٤١ (٩٣٢).عزاه السيوطي إلى الفريابي.عزاه السيوطي إلى ابن أبي حاتم.يحتمل أن يكون عمرو بن قيس السكوني الحمصي (ت١٤٠)، أو عمرو بن قيس الملائي (ت١٤٥).عزاه السيوطي إلى ابن أبي حاتم.تفسير مقاتل بن سليمان ٢/٥٣٠.تفسير يحيى بن سلام ١/١٣٥.
17,37," <q>﴿وَلَا تَمۡشِ فِی ٱلۡأَرۡضِ مَرَحًاۖ إِنَّكَ لَن تَخۡرِقَ ٱلۡأَرۡضَ وَلَن تَبۡلُغَ ٱلۡجِبَالَ طُولࣰا ۝٣٧﴾</q> - تفسير ٤٣١١٦- عن قتادة بن دعامة -من طريق معمر- في قوله: <q>﴿ولا تمش في الأرض مرحًا﴾</q>، قال: لا تمش فخرًا وكبرًا؛ فإن ذلك لا يبلُغُ بك الجبال، ولا أن تخرِقَ الأرض بفخرك وكبرك{1}. (٩/٣٤٧) ٤٣١١٧- قال مقاتل بن سليمان: <q>﴿ولا تمش في الأرض مرحا﴾</q> يعني: بالعظمة، والخيلاء، والكبرياء؛ <q>﴿إنك لن تخرق الأرض﴾</q> إذا مشيت بالخيلاء والكبرياء، <q>﴿ولن تبلغ﴾</q> رأسك <q>﴿الجبال طولا﴾</q> إذا تكبَّرْت{2}. (ز) ٤٣١١٨- عن عبد الملك ابن جريج -من طريق حجاج- <q>﴿ولا تمش في الأرض﴾</q>، قال: لا تفخر{3}. (ز) ٤٣١١٩- قال يحيى بن سلّام: قوله: <q>﴿ولا تمش في الأرض﴾</q> يعني: على الأرض <q>﴿مرحا﴾</q> كما يمشي المشركون، فتمرح في الأرض. وهي مثل قوله: <q>﴿ذلكم بما كنتم تفرحون في الأرض بغير الحق وبما كنتم تمرحون﴾</q> [غافر:٧٥]، وكقوله: <q>﴿وفرحوا بالحياة الدنيا﴾</q> [الرعد:٢٦]، يعني: المشركين لا يفرحون بالآخرة. وقال: <q>﴿إنك لن تخرق الأرض﴾</q> بقدمك إذا مشيت، <q>﴿ولن تبلغ الجبال طولا﴾</q>{4}. (ز) <q>﴿وَلَا تَمۡشِ فِی ٱلۡأَرۡضِ مَرَحًاۖ إِنَّكَ لَن تَخۡرِقَ ٱلۡأَرۡضَ وَلَن تَبۡلُغَ ٱلۡجِبَالَ طُولࣰا ۝٣٧﴾</q> - آثار متعلقة بالآية ٤٣١٢٠- عن يُحنَّسَ، قال: قال رسول الله ﷺ: «إذا مَشَت أمَّتي المُطَيطاءَ{5}، وخَدَمَتهم فارسُ والروم؛ سُلِّط بعضهم على بعض»{6}. (٩/٣٤٨) ٤٣١٢١- عن عبد الله بن عمر -من طريق جميل بن زيد-: أنّه رأى رجلًا يَخطِرُ في مِشيَتِه، فقال: إنّ للشيطان إخوانًا{7}. (٩/٣٤٨) ٤٣١٢٢- عن خالد بن مَعْدان -من طريق ثور- قال: إيّاكم والخَطرَ؛ فإن الرجل قد تُنافقُ يدُه من دون سائر جسده{8}. (٩/٣٤٨) ٤٣١٢٣- عن أبي بكر الهذلي، قال: بينما نحن مع الحسن البصري إذ مرَّ عليه ابن الأهتم يريد المَقْصُورَةَ{9}، وعليه جِبابُ خَزٍّ قد نُضِّدَ بعضها فوق بعض على ساقه، فانفرج عنها قِباؤُه{10}، وهو يمشي يتبختر، إذ نظر إليه الحسن نظرة، فقال: أفٍّ لك، شامخ بأنفه، ثاني عطفه، مصعِّر خده، ينظر في عطفيه، أيْ حُمَيْقٍ، أنت تنظر في عطفيك في نِعَمٍ غير مشكورة ولا مذكورة، غير المأخوذ بأمر الله ﷿ فيها، ولا المؤدي حق الله منها، واللهِ، إن يمشي أحدهم طبيعته أن يَتَخَلَّجَ{11} تَخلُّجَ المجنون، في كل عضو من أعضائه لله نعمة، وللشيطان به لعنة. فسمع ابن الأهتم، فرجع يعتذر، فقال: لا تعتذر إليَّ، وتُبْ إلى ربك، أما سمعت قول الله ﷿: <q>﴿ولا تمش في الأرض مرحا إنك لن تخرق الأرض ولن تبلغ الجبال طولا﴾</q>؟!{12}. (ز) ",footnotes:1:أخرجه عبد الرزاق ١/٣٧٨، وابن جرير ١٤/٥٩٨، كما أخرجه من طريق سعيد مختصرًا. وعزاه السيوطي إلى ابن أبي حاتم.تفسير مقاتل بن سليمان ٢/٥٣١.أخرجه ابن جرير ١٤/٥٩٨.تفسير يحيى بن سلام ١/١٣٥-١٣٦.المطيطاء: التبختر. التاج (مطط).أخرجه ابن أبي الدنيا في كتاب التواضع (٢٤٩). والحديث عند الترمذي (٢٢٦١) من حديث ابن عمر. وصححه الألباني في السلسلة الصحيحة (٩٥٦).أخرجه ابن أبي الدنيا في كتاب التواضع والخمول (٢٤٦)، وفيه: يجر إزاره. بدلًا من: يخطر في مشيته.أخرجه ابن أبي الدنيا في كتاب التواضع والخمول (٢٤٧).المَقْصُورة: الدار الواسعة المُحَصَّنَة. لسان العرب (قصر).القباء –ممدود-: من الثياب. لسان العرب (قبا).الاختلاج: الحركة والاضطراب. النهاية (خلج).أخرجه ابن أبي الدنيا في كتاب التواضع والخمول (٢٣٧).
17,38," <q>﴿كُلُّ ذَ ٰ⁠لِكَ كَانَ سَیِّئُهُۥ عِندَ رَبِّكَ مَكۡرُوهࣰا ۝٣٨﴾</q> - قراءات الآية، وتفسيرها ٤٣١٢٤- عن ابن كثير المكي أنه كان يقرأ: ‹كُلُّ ذَلِكَ كانَ سَيِّئَةً عِندَ رَبِّكَ مَكْرُوهًا› على واحدٍ. يقول: هذه الأشياء التي نُهِيتَ عنها كلُّها سيئة{1}. (٩/٣٤٨) ٤٣١٢٥- قال مقاتل بن سليمان: <q>﴿كُلُّ ذَلِكَ﴾</q> يعني: كل ما أمر الله ﷿ به، ونهى عنه في هؤلاء الآيات، <q>﴿كانَ سَيِّئُهُ﴾</q> يعني: ترك ما أمر الله ﷿ به، ونهى عنه في هؤلاء الآيات، أي: وركوب ما نهى عنه، كان <q>﴿عِندَ رَبِّكَ مَكْرُوهًا﴾</q>{2}. (ز) ٤٣١٢٦- قال يحيى بن سلّام: وقال: <q>﴿كُلُّ ذَلِكَ كانَ سَيِّئُهُ﴾</q> في قراءة مَن قرأها بالرفع <q>﴿عِندَ رَبِّكَ مَكْرُوهًا﴾</q> يقول: سيء ذلك الفعل. ومن قرأها بالنصب يقول: كل ذلك كان سيئةً –مهموزة-؛ يوجب أنها سيئة <q>﴿عِندَ رَبِّكَ مَكْرُوهًا﴾</q> وهي قراءة المكي، ذكره حماد بن سلمة{3}٣٨٤٢. (ز) ٣٨٤٢ اختلفت القرأة في قراءة قوله تعالى: <q>﴿كُلُّ ذَلِكَ كانَ سَيِّئُهُ عِنْدَ رَبِّكَ مَكْرُوهًا﴾</q> على قراءتين، وقد ذكرهما ابن جرير (١٤/٥٩٩) فقال: الأولى: <q>﴿كلُّ ذلك كان سَيِّئُهُ﴾</q> على الإضافة، ووجَّهوا قراءتهم بقولهم: «لأن فيما عدَّدْنا من قوله: <q>﴿وقَضى رَبُّكَ ألا تَعْبُدُوا إلا إيّاهُ﴾</q> أمورًا، هي أمْرٌ بالجميل، كقوله: <q>﴿وبِالوالِدَيْنِ إحْسانًا﴾</q>، وقوله: <q>﴿وآتِ ذا القُرْبى حَقَّهُ﴾</q>، وما أشبه ذلك. قالوا: فليس كل ما فيه نهيًا عن سيئةٍ، بل فيه نهيٌ عن سيئةٍ، وأَمْرٌ بحسنات، فلذلك قرأنا: <q>﴿سَيِّئُهُ﴾</q>». الثانية: ‹كلُّ ذلك كان سَيِّئَةً› بالتنوين، والمعنى عند من قرأها كذلك: «أن الله إنما عَنى بذلك: كلُّ ما عدَّدْنا من قولنا: <q>﴿ولا تَقْتُلُوا أوْلادَكُمْ خَشْيَةَ إمْلاقٍ﴾</q>، ولم يدخل فيه ما قَبْل ذلك، قالوا: وكلُّ ما عدَّدنا من ذلك الموضع إلى هذا الموضع سيِّئَةٌ لا حسنة فيه». ووجَّه ابنُ عطية (٥/٤٨٢) اسم الإشارة <q>﴿ذلك﴾</q> على القراءة الأولى بقوله: «والإشارة إلى جميع ما ذكر في هذه الآيات من بِرٍّ ومعصية، ثم اختَصَّ ذكر السَّيِّء منه بأنه مكروه عند الله تعالى». ووجَّهه على القراءة الثانية بقوله: «والإشارة إلى ما تقدم ذكره مما نهي عنه كقول: أُفٍّ، وقَذْف الناس، والمرح، وغير ذلك». وبمعناه ابنُ كثير (٩/١٣). ورجَّح ابنُ جرير (١٤/٦٠٠) مستندًا إلى دلالة اللغة القراءة الأولى، وعلَّل ذلك بقوله: «لأنّ في ذلك أمورًا منهيًّا عنها، وأمورًا مأمورًا بها، وابتداءُ الوصية والعهد من ذلك الموضع دون قوله: <q>﴿ولا تَقْتُلُوا أوْلادَكُمْ﴾</q> إنما هو عطفٌ على ما تقدم من قوله: <q>﴿وقَضى رَبُّكَ ألا تَعْبُدُوا إلا إيّاهُ﴾</q>، فإذ كان ذلك كذلك فقراءتُه بإضافة السيِّء إلى الهاء أوْلى وأحقُّ من قراءته ‹سَيِّئَةً› بالتنوين، بمعنى السيئةٍ الواحدة». واستدرك ابنُ عطية (٥/٤٨٣) على ابن جرير في قوله: بـ«أن هذه النواهي كلها معطوفة على قوله أولًا: <q>﴿وقَضى رَبُّكَ ألا تَعْبُدُوا إلا إيّاهُ﴾</q>» قائلًا: «وليس ذلك بالبيِّن». ",footnotes:1:عزاه السيوطي إلى ابن المنذر، وابن أبي حاتم. وهي قراءة متواترة، قرأ بها نافع، وابن كثير، وأبو عمرو، وأبو جعفر، ويعقوب، وقرأ بقية العشرة: <q>﴿سَيِّئُهُ﴾</q> بضم الهمزة والهاء وإلحاقها واوًا في اللفظ. انظر: النشر ٢/٣٠٧، والإتحاف ص٣٥٧.تفسير مقاتل بن سليمان ٢/٥٣١.تفسير يحيى بن سلام ١/١٣٦.
