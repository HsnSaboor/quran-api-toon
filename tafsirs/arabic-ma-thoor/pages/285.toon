quran[11]{c,v,t}:
  17,28,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَإِمَّا تُعۡرِضَنَّ عَنۡهُمُ ٱبۡتِغَاۤءَ رَحۡمَةࣲ مِّن رَّبِّكَ تَرۡجُوهَا فَقُل لَّهُمۡ قَوۡلࣰا مَّیۡسُورࣰا ۝٢٨﴾</span> - نزول الآية</h3></p><p><div></p><p><p><span class="item-no">٤٢٩٠٦<span class="dash">-</span></span> عن <span class="name-2">عطاء الخراسانيِّ</span>، قال: جاء ناس مِن مُزَينة يَسْتَحمِلون رسولَ الله ﷺ، فقال: <span class="qpc-hafs">﴿لا أجد ما أحمِلُكُم عليه﴾</span>، <span class="qpc-hafs">﴿تَوَلَّوا وأعيُنُهم تفِيض من الدمع حزنًا﴾</span> [التوبة: ٩٢]، ظنوا ذلك من غضب رسول الله ﷺ عليهم؛ فأنزل الله: <span class="qpc-hafs">﴿وإمّا تُعرِضَنَّ عنهم ابتغاء رحمة من ربك﴾</span> الآية. قال: الرحمة: الفيء{1}. (٩/٣٢٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٢٩٠٧<span class="dash">-</span></span> عن <span class="name-2">الضحاك بن مزاحم</span> -من طريق عبيد بن سليمان- في قوله: <span class="qpc-hafs">﴿وإما تعرضن عنهم ابتغاء رحمة من ربك﴾</span>: نزلت فيمن كان يسأل النبي ﷺ من المساكين{2}. (٩/٣٢٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٢٩٠٨<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span>، في الآية، قال: كان ناسٌ من بني عبد المطلب يأتون النَّبي ﷺ يسألونه، فإذا صادفوا عنده شيئًا أعطاهم، وإن لم يصادفوا عنده شيئًا سكت، ولم يقُل لهم: نعم. ولا: لا. والقُربى: قُربى بني عبد المطلب{3}. (٩/٣١٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٢٩٠٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وإما تعرضن عنهم﴾</span>، نزلت في خباب، وبلال، ومهجع، وعمار، ونحوهم من الفقراء، كانوا يسألون النبى ﷺ، فلا يجد ما يعطيهم، فيعرض عنهم، فيسكت{4}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَإِمَّا تُعۡرِضَنَّ عَنۡهُمُ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٢٩١٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>: <span class="qpc-hafs">﴿وإمّا تُعِرَضَّن عنهم﴾</span>، يقول: تُمْسِك عن عطائهم{5}. (٩/٣٢١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٢٩١١<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن جريج-: إن سألوك فلم يكن عندك ما تعطيهم، فأعرضت عنهم <span class="qpc-hafs">﴿ابتغاء رحمة﴾</span> قال: رزق تنتظره؛ <span class="qpc-hafs">﴿فقل لهم قولا ميسورا﴾</span>{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٢٩١٢<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span> -من طريق ابن جريج- قوله: <span class="qpc-hafs">﴿وإما تعرضن عنهم ابتغاء رحمة من ربك ترجوها﴾</span>، قال: إن سألوك فلم يجدوا عندك ما تعطيهم ابتغاء رحمة، قال: رزق تنتظره؛ ترجوه{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٢٩١٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثم رجع إلى المسكين وابن السبيل، فقال: <span class="qpc-hafs">﴿وإما تعرضن عنهم﴾</span>{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٢٩١٤<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿وإما تعرضن عنهم﴾</span>: عن هؤلاء الذين أوْصَيْناك بهم{9}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿ٱبۡتِغَاۤءَ رَحۡمَةࣲ مِّن رَّبِّكَ تَرۡجُوهَا﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٢٩١٥<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، في قوله: <span class="qpc-hafs">﴿وءات ذا القربى حقه﴾</span>، قال: أمَره بأحقّ الحقوق، وعَلَّمه كيف يصنع إذا كان عنده، وكيف يصنع إذا لم يكن، فقال: <span class="qpc-hafs">﴿وإمّا تُعرِضَنَّ عنهم ابتغاء رحمة من ربك﴾</span> قال: إذا سألوك وليس عندك شيء انتظرت رزقًا مِن الله، <span class="qpc-hafs">﴿فقل لهم قولًا ميسورًا﴾</span>: يكون إن شاء الله. «يكون» شِبْهُ العِدَة. قال سفيان: العِدَةُ مِن النبي ﷺ دَين{10}. (٩/٣١٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٢٩١٦<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطاء الخراساني- <span class="qpc-hafs">﴿ابتغاء رحمة من ربك﴾</span>، قال: رزق، <span class="qpc-hafs">﴿أهم يقسمون رحمة ربك نحن قسمنا بينهم معيشتهم﴾</span> [الزخرف:٣٢]{6}. (٩/٣٢٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٢٩١٧<span class="dash">-</span></span> عن <span class="name-2">عَبيدة السلماني</span> -من طريق أبي الضُّحى- في قوله: <span class="qpc-hafs">﴿ابتغاء رحمة من ربك ترجوها﴾</span>، قال: ابتغاء الرِّزق{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٢٩١٨<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span> -من طريق عطاء- <span class="qpc-hafs">﴿وإما تعرضن عنهم ابتغاء رحمة من ربك ترجوها﴾</span>، قال: رِزْق تنتظره{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٢٩١٩<span class="dash">-</span></span> عن <span class="name-2">إبراهيم النخعي</span> -من طريق منصور- <span class="qpc-hafs">﴿وإما تعرضن عنهم ابتغاء رحمة من ربك ترجوها﴾</span>، قال: انتظار الرزق{14}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٢٩٢٠<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿وإمّا تُعرِضَنَّ عنهم ابتغاء رحمة من ربك ترجوها﴾</span>، قال: انتظار رزقِ الله{15}. (٩/٣٢٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٢٩٢١<span class="dash">-</span></span> عن <span class="name-2">الضحاك بن مزاحم</span> -من طريق عبيد بن سليمان- في قوله: <span class="qpc-hafs">﴿وإما تعرضن عنهم﴾</span> يقول: لا تجد شيئًا تعطيهم <span class="qpc-hafs">﴿ابتغاء رحمة من ربك﴾</span> يقول: انتظار الرزق من ربك{2}. (٩/٣٢٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٢٩٢٢<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span> -من طريق عمارة- في قوله: <span class="qpc-hafs">﴿وإما تعرضن عنهم ابتغاء رحمة من ربك ترجوها﴾</span>، قال: انتظار رزقٍ مِن الله يأتيك{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٢٩٢٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ابتغآء رحمة من ربك ترجوها﴾</span>، يعني: انتظار رزق مِن ربِّك{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٢٩٢٤<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿وإما تعرضن عنهم﴾</span>: عن هؤلاء الذين أوصيناك بهم <span class="qpc-hafs">﴿ابتغاء رحمة من ربك ترجوها﴾</span> إذا خشيت إن أعطيتهم أن يَتَقَوَّوا بها على معاصي الله، ويستعينوا بها عليها، فرأيت أن تمنعهم خيرًا، فإذا سألوك <span class="qpc-hafs">﴿فقل لهم قولا ميسورا﴾</span>{9}<span class=comment-ref>٣٨٣٣</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٣٨٣٣</span> <span class="comment-type-2">انتقد</span> <u>ابنُ جرير</u> (١٤/٥٧٢) قول ابن زيد <span class="mustanad">مستندًا إلى أقوال السلف، ومخالفة ظاهر الآية</span>، فقال: «وهذا القول الذي ذكرناه عن ابن زيدٍ -مع خلافه أقوال أهل التأويل في تأويل هذه الآية- بعيدٌ بالمعنى مما يدل عليه ظاهرُها، وذلك أن الله تعالى قال لنبيه ﷺ: <span class="qpc-hafs">﴿وإمّا تُعْرِضَنَّ عَنْهُمُ ابْتِغاءَ رَحْمَةٍ مِن رَبِّكَ تَرْجُوها﴾</span>، أمَره أن يقول إذا كان إعراضه عن القوم الذين ذكَرهم انتظار رحمةٍ منه يرجوها من ربه <span class="qpc-hafs">﴿قَوْلا مَيْسُورًا﴾</span>، وذلك الإعراضُ ابتغاءَ الرحمة لن يَخْلُوَ من أحد أمرين: إما أن يكون إعراضًا منه ابتغاءَ رحمةٍ من الله يرجوها لنفسه، فيكونَ معنى الكلام كما قلناه، وقاله أهل التأويل الذين ذكرنا قولهم وخلافَ قوله، أو يكون إعراضًا منه ابتغاءَ رحمةٍ من الله يرجوها للسائلين الذين أُمِر نبيُّ الله ﷺ بزعمه أن يمنعهم ما سألوه خشيةً عليهم من أن ينفقوه في معاصي الله، فمعلومٌ أن سخط الله على من كان غير مأمونٍ منه صَرْفُ ما أُعْطِي من نفقةٍ ليتقوّى بها على طاعة الله في معاصيه أخوفُ من رجاء رحمته له، وذلك أن رحمة الله إنما تُرجى لأهل طاعته، لا لأهل معاصيه». غير أنه ذكر له <span class="comment-type-1">وجْهًا</span> يُمكِن أن يُحمَل عليه، و<span class="comment-type-2">انتقده</span> <span class="mustanad">لمخالفته أقوال أهل التأويل</span>، فقال: «إلا أن يكون أراد توجيه ذلك إلى أن نبيَّ الله ﷺ أُمِر بمنعهم ما سألوه ليُنِيبوا من معاصي الله، ويتوبوا بِمَنعِه إيّاهم ما سألوه، فيكونَ ذلك وجْهًا يَحْتَمِلُه تأويل الآية، وإن كان لقول أهل التأويل مخالفًا».</div></p><p><div></p><p><p><span class="item-no">٤٢٩٢٥<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: وأما قوله: <span class="qpc-hafs">﴿ابتغاء رحمة من ربك ترجوها﴾</span>، يعني: انتظار رزق ربك{20}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿فَقُل لَّهُمۡ قَوۡلࣰا مَّیۡسُورࣰا ۝٢٨﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٢٩٢٦<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، في قوله: <span class="qpc-hafs">﴿فقل لهم قولًا ميسورًا﴾</span>، قال: العِدَة. قال سفيان: والعِدَة من رسول الله دَيْن{21}. (٩/٣٢٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٢٩٢٧<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>: <span class="qpc-hafs">﴿وإمّا تُعِرَضَّن عنهم﴾</span> يقول: تُمسك عن عطائهم؛ <span class="qpc-hafs">﴿فقل لهم قولًا ميسورًا﴾</span> يعني: قولًا معروفًا: لعله أن يكون، عسى أن يكون{5}. (٩/٣٢١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٢٩٢٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق محمد بن أبى موسى- في قوله: <span class="qpc-hafs">﴿وءات ذا القربى حقه﴾</span> الآية، قال: بدأ فأمره بأوجب الحقوق، ودَلَّه على أفضل الأعمال إذا كان عنده شيء، فقال: <span class="qpc-hafs">﴿وءات ذا القربى حقه والمسكين وابن السبيل﴾</span>. وعلَّمه إذا لم يكن عنده شيء كيف يقول، فقال: <span class="qpc-hafs">﴿وإمّا تُعرِضَنَّ عنهم ابتغاء رحمة من ربك ترجوها فقل لهم قولًا ميسورًا﴾</span>: عِدَةً حسنة، كأنه قد كان، ولعله أن يكون إن شاء الله{23}. (٩/٣١٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٢٩٢٩<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span> -من طريق عطاء- <span class="qpc-hafs">﴿فقل لهم قولا ميسورا﴾</span>، قال: معروفًا{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٢٩٣٠<span class="dash">-</span></span> عن <span class="name-2">إبراهيم النخعي</span> -من طريق منصور- <span class="qpc-hafs">﴿فقل لهم قولا ميسورا﴾</span>، قال: ليِّنًا، تعدهم{25}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٢٩٣١<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span> -من طريق عمارة- في قول الله: <span class="qpc-hafs">﴿فقل لهم قولا ميسورا﴾</span>، قال: الرِّفْق{9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٢٩٣٢<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span> -من طريق ابن جريج- قوله: <span class="qpc-hafs">﴿فقل لهم قولا ميسورا﴾</span>، قال: عدهم عدة حسنة: إذا كان ذلك، إذا جاءنا ذلك فعلنا؛ أعطيناكم، فهو القول الميسور{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٢٩٣٣<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> في قوله: <span class="qpc-hafs">﴿فقل لهم قولًا ميسورًا﴾</span>، قال: لَيِّنًا سهلًا: سيكون -إن شاء الله- فأفعل، سنُصِيبُ -إن شاء الله- فأفعل{28}. (٩/٣٢٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٢٩٣٤<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- <span class="qpc-hafs">﴿فقل لهم قولا ميسورا﴾</span>، قال: عِدْهُم خيرًا{29}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٢٩٣٥<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span>، في قوله: <span class="qpc-hafs">﴿فقل لهم قولًا ميسورًا﴾</span>، يقول: قل لهم: نعم وكرامة، وليس عندنا اليوم، فإن يأتِنا شيء نعرف حقَّكم{3}. (٩/٣٢٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٢٩٣٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فقل لهم قولا ميسورا﴾</span>، يقول: ارْدُد عليهم معروفًا، يعني: العِدَة الحسنة؛ أنّه سيكون فأعطيكم{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٢٩٣٧<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿قولًا ميسورًا﴾</span>، قال: قولًا جميلًا: رزقنا الله وإياك، بارك الله فيك{32}. (٩/٣٢٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٢٩٣٨<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: وبلغني: أنّ قوله: <span class="qpc-hafs">﴿فقل لهم قولا ميسورا﴾</span> أن تقول للسائل: رزقنا الله وإياك{33}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿فَقُل لَّهُمۡ قَوۡلࣰا مَّیۡسُورࣰا ۝٢٨﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٤٢٩٣٩<span class="dash">-</span></span> عن أبي أمية، عن الحسن البصري: أنّ سائلًا قام، فقال: يا رسول الله، فقد بِتنا البارحة بغير عشاء، وما أمسينا الليلة نرجوه. فقال: «<b>يرزقنا الله وإيّاك من فضله، اجلس</b>». فجلس، ثم قام آخر، فقال مثل ذلك، فرد عليه رسول الله ﷺ مثل ذلك، فأُتِي رسولُ الله ﷺ بأربع أواقٍ مِن ذهب، فقال: «<b>أين السائلان</b>؟». فقام الرجلان، فأعطى كل واحد منهما أوقية، ولم يسأله أحد، فرجع بأوقيتين، فجعلهما تحت فراشه، فسهر ليلته بين فراشه ومسجده، فقالت أم المؤمنين: يا رسول الله، ما أسهرك؟ أوجَع أو أمر نزل؟ فقال: «<b>أوتيت بأربع أواق، فأمضيت وقيتين، وبقيت وقيتان، فخشيت أن يحدث بي حدث ولم أوجههما</b>»{34}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٢٩٤٠<span class="dash">-</span></span> عن <span class="name-1">عائشة</span> -من طريق عاصم بن حكيم، وأشعث، عن عاصم الأحول، عن قريبه- قالت: لا تقولوا للمسكين -وفي لفظ: للسائل-: بارك الله فيك؛ فإنه يسأل البرَّ والفاجر. -قال يحيى بن سلّام: يعني: الكافر- ولكن قولوا: يرزقك الله. وفي لفظ: يرزقنا الله وإياك{35}. (ز)</p></p><p></div></p></div>",footnotes:1:عزاه السيوطي إلى سعيد بن منصور، وابن المنذر.|2:أخرجه ابن جرير ١٤/٥٧١.|3:عزاه السيوطي إلى ابن أبي حاتم.|4:تفسير مقاتل بن سليمان ٢/٥٢٩.|5:عزاه السيوطي إلى ابن مَرْدويه.|6:أخرجه ابن جرير ١٤/٥٧٠.|7:أخرجه ابن جرير ١٤/٥٧٠.|8:تفسير مقاتل بن سليمان ٢/٥٢٩.|9:أخرجه ابن جرير ١٤/٥٧٢.|10:عزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.|11:أخرجه ابن جرير ١٤/٥٧٠.|12:أخرجه ابن جرير ١٤/٥٧١.|13:أخرجه ابن جرير ١٤/٥٧١.|14:أخرجه ابن جرير ١٤/٥٦٩، وأخرج يحيى بن سلام ١/١٣٠ نحوه من طريق ابن مجاهد.|15:أخرجه ابن جرير ١٤/٥٧٠-٥٧١. وعزاه السيوطي إلى ابن أبي حاتم.|16:أخرجه ابن جرير ١٤/٥٧١.|17:أخرجه ابن جرير ١٤/٥٧٠.|18:تفسير مقاتل بن سليمان ٢/٥٢٩.|19:أخرجه ابن جرير ١٤/٥٧٢.|20:تفسير يحيى بن سلام ١/١٣١.|21:عزاه السيوطي إلى ابن أبي حاتم، وابن مردويه.|22:عزاه السيوطي إلى ابن مَرْدويه.|23:أخرجه البخاري في الأدب المفرد (٥١). وعزاه السيوطي إلى ابن أبي حاتم.|24:أخرجه ابن جرير ١٤/٥٧١.|25:أخرجه ابن جرير ١٤/٥٦٩.|26:أخرجه ابن جرير ١٤/٥٧٢.|27:أخرجه ابن جرير ١٤/٥٧٠.|28:عزاه السيوطي إلى ابن أبي حاتم. وأخرجه عبد الرزاق ٢/٣٧٧ من طريق معمر بلفظ: قل لهم قولًا لينًا وسهلًا، وعلقه ابن جرير ١٤/٥٧١ مختصرًا.|29:أخرجه عبد الرزاق ٢/٣٧٦، وابن جرير ١٤/٥٧١.|30:عزاه السيوطي إلى ابن أبي حاتم.|31:تفسير مقاتل بن سليمان ٢/٥٢٩.|32:أخرجه ابن جرير ١٤/٥٧٢ بلفظ: قولًا جميلًا: رزقك الله، بارك الله فيك. وعزاه السيوطي إلى ابن أبي حاتم.|33:تفسير يحيى بن سلام ١/١٣٠.|34:أخرجه يحيى بن سلام ١/١٣٠ مرسلًا.|35:أخرجه يحيى بن سلام ١/١٣١.
  17,29,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَلَا تَجۡعَلۡ یَدَكَ مَغۡلُولَةً إِلَىٰ عُنُقِكَ وَلَا تَبۡسُطۡهَا كُلَّ ٱلۡبَسۡطِ فَتَقۡعُدَ مَلُومࣰا مَّحۡسُورًا ۝٢٩﴾</span> - نزول الآية</h3></p><p><div></p><p><p><span class="item-no">٤٢٩٤١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن مسعود</span>، قال: جاء غلام إلى النبي ﷺ، فقال: إنّ أمي تسألك كذا وكذا. فقال: «<b>ما عندنا اليوم شيء</b>». قال: فتقول لك: اكسُني قميصَك. فخلع قميصه، فدفع إليه، فجلس في البيت حاسِرًا؛ فأنزل الله: <span class="qpc-hafs">﴿ولا تجعل يدك مغلولة﴾</span> الآية{1}. (٩/٣٢٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٢٩٤٢<span class="dash">-</span></span> عن <span class="name-2">المِنهال بن عمرو</span>، قال: بَعثَت امرأةٌ إلى النَّبي ﷺ بابنها، فقالت: قل له: اكسُني ثوبًا. فقال: «<b>ما عندي شيء</b>». فقالت: ارجِع إليه، فقل له: اكسُني قميصك. فرجع إليه، فنزع قميصه، فأعطاه إيّاه؛ فنزلت: <span class="qpc-hafs">﴿ولا تجعل يدك مغلولة﴾</span> الآية{2}. (٩/٣٢٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٢٩٤٣<span class="dash">-</span></span> عن <span class="name-1">أبي أُمامة</span>، أنّ النبي ﷺ قال لعائشة وضرب بيده: «<b>أنفقِي ما على ظهْرِ كَفِّي</b>». قالت: إذن لا يبقى شيء. قال ذلك ثلاث مرات، فأنزل الله: <span class="qpc-hafs">﴿ولا تجعل يدك مغلولة﴾</span> الآية{3}. (٩/٣٢٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٢٩٤٤<span class="dash">-</span></span> عن <span class="name-2">سيّار أبي الحكم</span>، قال: أتى رسولَ الله ﷺ بَزٌّ من العراق، وكان مِعطاء كريمًا، فقسَمه بين الناس، فبلغ ذلك قومًا مِن العرب، فقالوا: نأتي النَّبيَّ ﷺ، فنسأله. فوجدوه قد فرغ منه؛ فأنزل الله: <span class="qpc-hafs">﴿ولا تجعل يدك مغلولة إلى عنقك﴾</span> قال: محبوسة، <span class="qpc-hafs">﴿ولا تبسطها كل البسط فتقعد ملومًا﴾</span> يلُومُك الناس، <span class="qpc-hafs">﴿محسورًا﴾</span> ليس بيدك شيء{4}. (٩/٣٢٤)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَلَا تَجۡعَلۡ یَدَكَ مَغۡلُولَةً إِلَىٰ عُنُقِكَ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٢٩٤٥<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- في قوله: <span class="qpc-hafs">﴿ولا تجعل يدك مغلولة﴾</span>، قال: يعني بذلك: البُخل{5}. (٩/٣٢٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٢٩٤٦<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق العوفي- <span class="qpc-hafs">﴿ولا تجعل يدك مغلولة إلى عنقك﴾</span>،</p><p>قال: هذا في النفقة. يقول: لا تجعلها مغلولةً؛ لا تَبسُطُها بخير{6}. (٩/٣٢٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٢٩٤٧<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>: قال: أمَر رسولَ اللهِ ﷺ مَن يُعطي، وكيف يُعطي، وبمن يبدأ؛ فأنزل الله: <span class="qpc-hafs">﴿وءات ذا القربى حقه والمسكين وابن السبيل﴾</span> فأمره الله أن يبدأ بذي القربى، ثم بالمسكين وابن السبيل مِن بعدهم، وقال: <span class="qpc-hafs">﴿ولا تبذر تبذيرًا﴾</span> يقول الله ﷿: ولا تُعط مالك كلَّه فتقعُد بغير شيء. ثم قال: <span class="qpc-hafs">﴿ولا تجعل يدك مغلولة إلى عنقك﴾</span> فتمنع ما عندك، فلا تُعطِيَ أحدًا، <span class="qpc-hafs">﴿ولا تبسُطها كل البسط﴾</span> فنهاه أن يُعطي إلا ما بَيَّنَ له، وقال له: <span class="qpc-hafs">﴿وإمّا تُعِرَضَّن عنهم﴾</span> يقول: تُمسك عن عطائهم؛ <span class="qpc-hafs">﴿فقل لهم قولًا ميسورًا﴾</span> يعني: قولًا معروفًا: لعله أن يكون، عسى أن يكون{7}. (٩/٣٢١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٢٩٤٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق محمد بن أبى موسى- في قوله: <span class="qpc-hafs">﴿ولا تجعل يدك مغلولة إلى عنقك﴾</span>: لا تُعطي شيئًا{8}. (٩/٣١٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٢٩٤٩<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق سفيان، عن رجل- في قوله: <span class="qpc-hafs">﴿ولا تجعل يدك مغلولة إلى عنقك﴾</span>، قال: لا تنفق شيئًا{9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٢٩٥٠<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span>، في قوله: <span class="qpc-hafs">﴿ولا تجعل يدك مغلولة إلى عنقك ولا تبسطها كل البسط﴾</span>، قال: نهاه عن السَّرَفِ والبخل{10}. (٩/٣٢٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٢٩٥١<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق عوف- في قوله: <span class="qpc-hafs">﴿ولا تجعل يدك مغلولة إلى عنقك﴾</span>، قال: لا تجعلها مغلولة عن النفقة{11}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٢٩٥٢<span class="dash">-</span></span> قال <span class="name-2">الحسن البصري</span>: قوله: <span class="qpc-hafs">﴿ولا تجعل يدك مغلولة إلى عنقك﴾</span>، أي: لا تَدَعِ النفقةَ في حقِّ الله، فيكون مَثَلُك مَثَلَ الذي غُلَّتْ يدُه إلى عنقه، فلا يستطيع أن يبسطها{12}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٢٩٥٣<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- قوله: <span class="qpc-hafs">﴿ولا تجعل يدك مغلولة إلى عنقك﴾</span>، أي: لا تُمْسِكها عن طاعة الله، ولا عن حقِّه{13}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٢٩٥٤<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- في قوله تعالى: <span class="qpc-hafs">﴿ولا تجعل يدك مغلولة إلى عنقك﴾</span>، قال: في النفقة، يقول: لا تمسك عن النفقة{14}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٢٩٥٥<span class="dash">-</span></span> قال <span class="name-2">إسماعيل السُّدِّيّ</span>: هذا مَثَل ضربه الله في أمر النفقة، وذلك قوله للنبي ﷺ: <span class="qpc-hafs">﴿ولا تجعل يدك مغلولة إلى عنقك﴾</span>{15}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٢٩٥٦<span class="dash">-</span></span> عن <span class="name-2">محمد ابن شهاب الزهري</span> -من طريق عقيل- أنّه كان يقول في هذه الآية: <span class="qpc-hafs">﴿ولا تجعل يدك مغلولة إلى عنقك ولا تبسطها كل البسط﴾</span>، يقول: لا تمنعه مِن حق، ولا تنفقه في باطل، <span class="qpc-hafs">﴿والذين إذا أنفقوا لم يسرفوا ولم يقتروا﴾</span> [الفرقان:٦٧]، كذلك أيضًا{16}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٢٩٥٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثم علَّمهم كيف يعمل في النفقة، فقال سبحانه: <span class="qpc-hafs">﴿ولا تجعل يدك مغلولة إلى عنقك﴾</span>، يقول: ولا تُمْسِك يدك مِن البخل عن النفقة في الحق{17}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٢٩٥٨<span class="dash">-</span></span> عن <span class="name-3">عبد الملك ابن جريج</span> -من طريق حجاج- قال: لا تُمْسِك عن النفقة فيما أمرتُك به مِن الحقِّ{18}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٢٩٥٩<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿ولا تجعل يدك مغلولة إلى عنقك﴾</span>، قال: مغلولة؛ لا تبسطها بخير، ولا بعَطِيَّة{18}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٢٩٦٠<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: يعني: لا تُمْسِك يدك عن النفقة بمنزلة المغلولة، فلا تستطيع بسطها{20}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَلَا تَبۡسُطۡهَا كُلَّ ٱلۡبَسۡطِ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٢٩٦١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق العوفي- <span class="qpc-hafs">﴿ولا تبسطها كل البسط﴾</span>، يعني: التبذير{5}. (٩/٣٢٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٢٩٦٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق محمد بن أبي موسى- في قوله: <span class="qpc-hafs">﴿ولا تبسُطها كل البسط﴾</span>: تُعطي ما عندك{8}. (٩/٣١٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٢٩٦٣<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق سفيان، عن رجل- في قوله: <span class="qpc-hafs">﴿ولا تبسطها كل البسط﴾</span>، قال: لا تُسْرِف{9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٢٩٦٤<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق عوف- في قوله: <span class="qpc-hafs">﴿ولا تبسطها﴾</span>: تُبَذِّر؛ تُسْرِف{11}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٢٩٦٥<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- في قوله تعالى: <span class="qpc-hafs">﴿ولا تبسطها كل البسط﴾</span>، يقول: لا تُبَذِّر تبذيرًا{14}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٢٩٦٦<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- قوله: <span class="qpc-hafs">﴿ولا تبسطها كل البسط﴾</span>، يقول: لا تُنفِقها في معصية الله، ولا فيما لا يصلح ولا ينبغي لك، وهو الإسراف{26}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٢٩٦٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ولا تبسطها﴾</span> يعني: في العَطِيَّة <span class="qpc-hafs">﴿كل البسط﴾</span>، فلا تبقى عندك، فإن سُئِلْتَ لم تجد ما تعطيهم. كقوله: <span class="qpc-hafs">﴿يد الله مغلولة﴾</span> [المائدة:٦٤]{17}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٢٩٦٨<span class="dash">-</span></span> عن <span class="name-3">عبد الملك ابن جريج</span> -من طريق حجاج- قوله: <span class="qpc-hafs">﴿ولا تبسطها كل البسط﴾</span>: فيما نهيتك{18}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٢٩٦٩<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿ولا تبسطها كل البسط﴾</span>: في الحق والباطل، فينفذ ما في يديك، فيأتيك مَن يريد أن تعطيه كما أعطيت هؤلاء، فلا تجد ما تعطيه، فيحسرك، فيلومك حين أعطيت هؤلاء ولم تُعطِهم{18}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٢٩٧٠<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿ولا تبسطها كل البسط﴾</span>، فتنفق في غير حق الله، أي: لا تنفقها في معصية الله، وفيما لا يصلح، وهو الإسراف{30}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿فَتَقۡعُدَ مَلُومࣰا﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٢٩٧١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق العوفي- <span class="qpc-hafs">﴿فتقعد ملومًا﴾</span>: يلوم نفسه على ما فاته مِن ماله{5}. (٩/٣٢٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٢٩٧٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، في قوله: <span class="qpc-hafs">﴿فتقعد ملومًا﴾</span>، قال: ملومًا عند الناس{32}. (٩/٣٢٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٢٩٧٣<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق محمد بن أبي موسى- في قوله: <span class="qpc-hafs">﴿فتقعُدَ ملومًا﴾</span>: يلومك مَن يأتيك بعدُ ولا يَجِدُ عندك شيئًا{8}. (٩/٣١٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٢٩٧٤<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق سفيان، عن رجل- في قوله: <span class="qpc-hafs">﴿فتقعد ملوما﴾</span>، قال: ملومًا فيما بينك وبين ربك{9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٢٩٧٥<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- قوله: <span class="qpc-hafs">﴿فتقعد ملوما﴾</span>، قال: ملومًا في عباد الله{35}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٢٩٧٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فتقعد ملوما﴾</span> يلومك الناس{17}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٢٩٧٧<span class="dash">-</span></span> عن <span class="name-3">عبد الملك ابن جريج</span> -من طريق حجاج- قوله: <span class="qpc-hafs">﴿فتقعد ملوما﴾</span>، قال: مُذنِبًا{18}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٢٩٧٨<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>، في قوله: <span class="qpc-hafs">﴿فتقعد ملوما﴾</span>: في عباد الله، لا تستطيع أن توسع الناس{38}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿مَّحۡسُورًا ۝٢٩﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٢٩٧٩<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، أنّ نافع بن الأزرق قال: أخبِرني عن قوله: <span class="qpc-hafs">﴿ملومًا محسورًا﴾</span>. قال: مُستَحِيًا خجلًا. قال: وهل تعرف العرب ذلك؟ قال: نعم، أما سمعت الشاعر وهو يقول:</p><p>ما قادَ مِن عرب يموت جوادهم إلا تركت جوادهم محسورًا؟{39}. (٩/٣٢٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٢٩٨٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق محمد بن أبي موسى- في قوله: <span class="qpc-hafs">﴿محسورًا﴾</span>، قال: قد حَسَرَك مَن قد أعطيتَه{8}. (٩/٣١٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٢٩٨١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق العوفي- <span class="qpc-hafs">﴿محسورًا﴾</span>: ذهب مالُه كلُّه{5}. (٩/٣٢٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٢٩٨٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، في قوله: <span class="qpc-hafs">﴿محسورًا﴾</span>، قال: محسورًا من المال{32}. (٩/٣٢٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٢٩٨٣<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق سفيان، عن رجل- في قوله: <span class="qpc-hafs">﴿محسورا﴾</span>: في مالك{9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٢٩٨٤<span class="dash">-</span></span> عن حوشب، قال: كان <span class="name-2">الحسن [البصري]</span> إذا تلا هذه الآية: <span class="qpc-hafs">﴿ولا تجعل يدك مغلولة إلى عنقك ولا تبسطها كل البسط فتقعد ملوما محسورا﴾</span>، يقول: لا تُطَفِّف برزقي عن غير رضاي، ولا تضعه في سخطي؛ فأسلبك ما في يديك؛ فتكون حسيرًا ليس في يديك منه شيء{11}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٢٩٨٥<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- قوله: <span class="qpc-hafs">﴿محسورا﴾</span>، قال: محسورًا على ما سَلَف مِن دهره وفَرَّط{26}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٢٩٨٦<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- في قوله تعالى: <span class="qpc-hafs">﴿محسورا﴾</span>، يقول: نادِمًا على ما فرط منك{14}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٢٩٨٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿محسورا﴾</span>، يعني: مُنقَطِعًا بك، كقوله سبحانه في تبارك الملك [٤]: <span class="qpc-hafs">﴿وهو حسير﴾</span>، يعني: منقطع به{17}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٢٩٨٨<span class="dash">-</span></span> عن <span class="name-3">عبد الملك ابن جريج</span> -من طريق حجاج- قوله: <span class="qpc-hafs">﴿محسورا﴾</span>، قال: منقطعًا بك{18}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٢٩٨٩<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿محسورا﴾</span> قد ذهب ما في يديك، يقول: قد خسر{38}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿مَّحۡسُورًا ۝٢٩﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٤٢٩٩٠<span class="dash">-</span></span> عن عبد الله بن مسعود، قال: قال رسول الله عليه وسلم: «<b>ما عالَ مَنِ اقتَصَد</b>»{50}. (٩/٣٢٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٢٩٩١<span class="dash">-</span></span> عن عبد الله بن عباس، قال: قال رسول الله ﷺ: «<b>ما عال مقتصدٌ قطُّ</b>»{51}. (٩/٣٢٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٢٩٩٢<span class="dash">-</span></span> عن أبي الدرداء، قال: قال رسول الله ﷺ: «<b>مِن فِقهِك رِفقُك في معيشتك</b>»{52}. (٩/٣٢٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٢٩٩٣<span class="dash">-</span></span> عن جابر بن عبد الله، قال: قال رسول الله ﷺ: «<b>الرِّفق في المعيشة خيرٌ مِن بعض التجارة</b>»{53}. (٩/٣٢٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٢٩٩٤<span class="dash">-</span></span> عن <span class="name-2">مُطَرِّف بن الشِّخِّير</span> -من طريق ثابت- قال: خير الأمور أوساطُها{54}. (٩/٣٢٨)</p></p><p></div></p></div>",footnotes:1:أخرجه الواحدي في أسباب النزول ص٢٨٧، من طريق سليمان بن سفيان الجهني، قال: حدثنا قيس بن الربيع، عن أبي إسحاق، عن أبي الأحوص، عن ابن مسعود به. وعزاه السيوطي إلى ابن أبي حاتم.</p><p>إسناده ضعيف؛ فيه سليمان بن سفيان، قال عنه الذهبي في المغني في الضعفاء (٢٥٩١): «ضعيف».|2:أخرجه ابن أبي الدنيا في كتاب مكارم الأخلاق -موسوعة الإمام ابن أبي الدنيا ٣/٥٠٧ (٤١٢)-. وعزاه السيوطي إلى ابن أبي حاتم.|3:عزاه السيوطي إلى ابن مردويه.|4:عزاه السيوطي إلى سعيد بن منصور، وابن المنذر.|5:أخرجه ابن جرير ١٤/٥٧٥. وعزاه السيوطي إلى ابن أبي حاتم.|6:أخرجه ابن جرير ١٤/٥٧٥ بنحوه. وعزاه السيوطي إلى ابن أبي حاتم.|7:عزاه السيوطي إلى ابن مَرْدويه.|8:أخرجه البخاري في الأدب المفرد (٥١). وعزاه السيوطي إلى ابن أبي حاتم.|9:تفسير الثوري ص١٧٢.|10:عزاه السيوطي إلى ابن أبي حاتم.|11:أخرجه ابن جرير ١٤/٥٧٤.|12:علقه يحيى بن سلام ١/١٣١.|13:أخرجه يحيى بن سلام ١/١٢٦، وابن جرير ١٤/٥٧٥.|14:أخرجه عبد الرزاق ٢/٣٧٧، وابن جرير ١٤/٥٧٥.|15:علقه يحيى بن سلام ١/١٣٢.|16:أخرجه ابن وهب في الجامع - تفسير القرآن ١/٥٥-٥٦ (١٢٢).|17:تفسير مقاتل بن سليمان ٢/٥٢٩.|18:أخرجه ابن جرير ١٤/٥٧٦.|19:أخرجه ابن جرير ١٤/٥٧٦.|20:تفسير يحيى بن سلام ١/١٣٢.|21:أخرجه ابن جرير ١٤/٥٧٥. وعزاه السيوطي إلى ابن أبي حاتم.|22:أخرجه البخاري في الأدب المفرد (٥١). وعزاه السيوطي إلى ابن أبي حاتم.|23:تفسير الثوري ص١٧٢.|24:أخرجه ابن جرير ١٤/٥٧٤.|25:أخرجه عبد الرزاق ٢/٣٧٧، وابن جرير ١٤/٥٧٥.|26:أخرجه ابن جرير ١٤/٥٧٥.|27:تفسير مقاتل بن سليمان ٢/٥٢٩.|28:أخرجه ابن جرير ١٤/٥٧٦.|29:أخرجه ابن جرير ١٤/٥٧٦.|30:تفسير يحيى بن سلام ١/١٣١-١٣٢.|31:أخرجه ابن جرير ١٤/٥٧٥. وعزاه السيوطي إلى ابن أبي حاتم.|32:عزاه السيوطي إلى ابن المنذر.|33:أخرجه البخاري في الأدب المفرد (٥١). وعزاه السيوطي إلى ابن أبي حاتم.|34:تفسير الثوري ص١٧٢.|35:أخرجه عبد الرزاق ٢/٣٧٧ من طريق معمر، وابن جرير ١٤/٥٧٥.|36:تفسير مقاتل بن سليمان ٢/٥٢٩.|37:أخرجه ابن جرير ١٤/٥٧٦.|38:تفسير يحيى بن سلام ١/١٣١.|39:مسائل نافع (٢٤٨). وعزاه السيوطي إلى الطَّسْتيِّ.|40:أخرجه البخاري في الأدب المفرد (٥١). وعزاه السيوطي إلى ابن أبي حاتم.|41:أخرجه ابن جرير ١٤/٥٧٥. وعزاه السيوطي إلى ابن أبي حاتم.|42:عزاه السيوطي إلى ابن المنذر.|43:تفسير الثوري ص١٧٢.|44:أخرجه ابن جرير ١٤/٥٧٤.|45:أخرجه ابن جرير ١٤/٥٧٥.|46:أخرجه عبد الرزاق ٢/٣٧٧، وابن جرير ١٤/٥٧٥.|47:تفسير مقاتل بن سليمان ٢/٥٢٩.|48:أخرجه ابن جرير ١٤/٥٧٦.|49:تفسير يحيى بن سلام ١/١٣١.|50:أخرجه أحمد ٧/٣٠٢ (٤٢٦٩)، والطبراني في الأوسط ٥/٢٠٦ (٥٠٩٤).</p><p>قال الطبراني: «لم يرو هذا الحديثَ عن إبراهيم الهجري إلا سكينُ بن عبد العزيز». وأورده ابن عدي في الكامل ٤/٥٤٤ (٨٧٦) في ترجمة سكين بن عبد العزيز بن قيس العبدي. وقال ابن القيسراني في ذخيرة الحفاظ ٤/٢٠٩١ (٤٨٣٥): «سكين ليس بالقوي، والهجري متروك الحديث». وقال ابن القطان في بيان الوهم ٤/٥٩٧: «ضعيف». وقال الهيثمي في المجمع ١٠/٢٥٢ (١٧٨٤٨): «في أسانيدهم إبراهيم بن مسلم الهجري، وهو ضعيف». وقال المناوي في التيسير ٢/٣٥٢: «وقول المؤلف -السيوطي- حسن غير حسن». وقال السفاريني في غذاء الألباب ٢/٥٤٠: «بإسناد حسن». وقال الألباني في الضعيفة ٩/٤٤٨ (٤٤٥٩): «ضعيف».|51:أخرجه الطبراني في الأوسط ٨/١٥٢ (٨٢٤١)، والبيهقي في شعب الإيمان ٨/٥٠٥-٥٠٦ (٦١٥٠، ٦١٥١).</p><p>قال الطبراني: «لم يروِ هذا الحديثَ عن أبي روق إلا خالد بن يزيد، تفرد به هشام بن خالد». وأورده ابن عدي في الكامل ٣/٤٢٦ (٥٧٧) في ترجمة خالد بن يزيد بن عبد الرحمن بن أبي مالك، وقال الهيثمي في المجمع ١٠/٢٥٢ (١٧٨٤٩): «رواه الطبراني في الكبير، والأوسط، ورجاله وُثِّقوا، وفي بعضهم خلاف». وقال الألباني في الضعيفة ٩/٤٤٨: «ضعيف ... لانقطاعه».|52:أخرجه ابن عدي في الكامل في الضعفاء ٢/٢١١ (٢٧٧) في ترجمة أبي بكر بن عبد الله بن أبي مريم الغساني الحمصي، والبيهقي في شعب الإيمان ٨/٥٠٠-٥٠١ (٦١٤٥).</p><p>قال الهيثمي في المجمع ٤/٧٤ (٦٣٠٨): «رواه أحمد، وفيه أبو بكر بن أبي مريم، وقد اختلط». وقال المناوي في فيض القدير ٦/١٦ (٨٢٥٦)، وفي التيسير ٢/٣٨٣: «وسنده لا بأس به». وقال الألباني في الضعيفة ٢/٣٣ (٥٥٦): «ضعيف».|53:أخرجه الطبراني في الأوسط ٨/٣١٧-٣١٨ (٨٧٤٦)، والبيهقي في شعب الإيمان ٨/٤٩٥ (٦١٣٦)، ٨/٤٩٨ (٦١٤٢).</p><p>قال الطبراني: «لم يرو هذا الحديث عن محمد بن المنكدر إلا ابن لهيعة، تفرد به عبد الله بن صالح، ولا يروى عن جابر إلا بهذا الإسناد». وأورده ابن عدي في الكامل ٢/٥٣٧ (٤١٢) في ترجمة حجاج بن سليمان الرعيني. وقال الهيثمي في المجمع ٤/٧٤ (٦٣٠٩): «رواه الطبراني في الأوسط، وفيه عبد الله بن صالح المصري؛ قال عبد الملك بن شعيب: ثقة مأمون. وضعفه جماعة». وقال المناوي في التيسير ٢/٤١: «بإسناد حسن». وقال الألباني في الضعيفة ٨/١٥٤ (٣٦٧٧): «ضعيف».|54:أخرجه البيهقي (٦٦٠١).
  17,30,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿إِنَّ رَبَّكَ یَبۡسُطُ ٱلرِّزۡقَ لِمَن یَشَاۤءُ وَیَقۡدِرُۚ إِنَّهُۥ كَانَ بِعِبَادِهِۦ خَبِیرَۢا بَصِیرࣰا ۝٣٠﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٢٩٩٥<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span>، في قوله: <span class="qpc-hafs">﴿إن ربك يبسط الرزق لمن يشاء ويقدر﴾</span>، قال: ينظر له؛ فإن كان الغِنى خيرًا له أغناه، وإن كان الفقر خيرًا له أفقره{1}. (٩/٣٢٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٢٩٩٦<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span>، في الآية، قال: يبسط لهذا مكرًا به، ويقدِر لهذا نظرًا له{1}. (٩/٣٢٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٢٩٩٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿إن ربك يبسط الرزق﴾</span> يعني: يُوَسِّع الرزق <span class="qpc-hafs">﴿لمن يشاء ويقدر﴾</span> يعني: ويقتر على من يشاء، <span class="qpc-hafs">﴿إنه كان بعباده خبيرا﴾</span> بأمر الرزق بالسعة والتقتير، <span class="qpc-hafs">﴿بصيرا﴾</span> به{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٢٩٩٨<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- قال: كلُّ شيء في القرآن «يقدر» فمعناه: يُقِلُّ{4}. (٩/٣٢٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٢٩٩٩<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- قال: ثم أخبَرنا كيف يصنع بنا، فقال: <span class="qpc-hafs">﴿إن ربك يبسط الرزق لمن يشاء ويقدر﴾</span>، ثم أخبر عباده أنه لا يَرزَؤُه ولا يَئُودوه أن لو بسط الرزق عليهم، ولكن نظرًا لهم منه، فقال: <span class="qpc-hafs">﴿ولو بسط الله الرزق لعباده لبغوا في الأرض ولكن يُنزل بقدر ما يشاء إنه بعباده خبير بصير﴾</span> [الشورى:٢٧]. قال: والعرب إذا كان الخِصب وبُسِط عليهم أشِروا{5}، وقتل بعضهم بعضًا، وجاء الفساد، وإذا كان السَّنَةُ شُغِلوا عن ذلك{6}. (٩/٣٢٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٣٠٠٠<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿إن ربك يبسط الرزق لمن يشاء ويقدر﴾</span> أي: ويقتر، وتقتيره على المؤمن نظرًا له، <span class="qpc-hafs">﴿إنه كان بعباده خبيرا بصيرا﴾</span>{7}. (ز)</p></p><p></div></p></div>",footnotes:1:عزاه السيوطي إلى ابن أبي حاتم.|2:عزاه السيوطي إلى ابن أبي حاتم.|3:تفسير مقاتل بن سليمان ٢/٥٢٩.|4:أخرجه ابن جرير ١٤/٥٧٧، وابن أبي حاتم ٩/٣٠٨٠ من طريق أصبغ بن الفرج.|5:أشروا: بطروا وكفروا النعمة. التاج (أشر).|6:أخرجه ابن جرير ١٤/٥٧٧. وعزاه السيوطي إلى ابن أبي حاتم.|7:تفسير يحيى بن سلام ١/١٣٢.
  17,31,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَلَا تَقۡتُلُوۤا۟ أَوۡلَـٰدَكُمۡ خَشۡیَةَ إِمۡلَـٰقࣲۖ نَّحۡنُ نَرۡزُقُهُمۡ وَإِیَّاكُمۡۚ إِنَّ قَتۡلَهُمۡ كَانَ خِطۡـࣰٔا كَبِیرࣰا ۝٣١﴾</span> - قراءات</h3></p><p><div></p><p><p><span class="item-no">٤٣٠٠١<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> أنه قرأ: ‹خِطَآءً كَبِيرًا› مهموزة، مِن قِبَلِ الخطأ والصواب{1}<span class=comment-ref>٣٨٣٤</span>. (٩/٣٣١)</p></p><p></div></p><p><div><span class=comment-ref>٣٨٣٤</span> ذكر <u>ابنُ جرير</u> (١٤/٥٧٩-٥٨٠) اختلاف القرأة في قراءة قوله تعالى: <span class="qpc-hafs">﴿إنَّ قَتْلَهُمْ كانَ خِطْئًا كَبِيرًا﴾</span> على ثلاث قراءات، <span class="comment-type-4">فقال</span>: <b>الأولى:</b> <span class="qpc-hafs">﴿خِطْئًا﴾</span> بكسر الخاء وسكون الطاء، ولهم فيها معنيان: <b>الأول:</b> أن يكون اسمًا من قول القائل: خَطِئْتُ فأنا أخْطَأُ خِطْأ، بمعنى: أذنبتُ وأَثِمْتُ. ويُحكى عن العرب: خَطِئتَ: إذا أذنبتَ عمدًا، وأخطأتَ: إذا وقع منك الذَّنبُ على غير عمدٍ منك له. <b>والثاني:</b> أن يكون بمعنى «خَطَأ» بفتح الخاء والطاء، ثم كُسِرت الخاء وسُكِّنت الطاء، كما قيل: قِتْبٌ وقَتَبٌ، وحِذْرٌ وحَذَرٌ، ونِجْسٌ ونَجَسٌ. والخِطْء بالكسر اسم، والخَطَأ بفتح الخاء والطاء مصدر من قولهم: خَطِئ الرجل، وقد يكون اسمًا من قولهم: أخْطَأَ. <b>الثانية:</b> ‹خَطَأً› بفتح الخاء والطاء، على أنه اسمٌ، من قولهم: أخْطَأَ فلان خَطَأ. <b>الثالثة:</b> ‹خِطَآءً› [بكسر] الخاء والطاء ومدِّ الخطاء، وهي في المعنى كالقراءة الثانية.</p><p>و<span class="comment-type-3">رجَّح</span> <u>ابنُ جرير</u> (١٤/٥٨٠) القراءة الأولى <span class="mustanad">مستندًا إلى إجماع الحجة من القرأة عليها،</span> وعلَّل ذلك بقوله: «لإجماع الحجة من القرأة عليها، وشذوذ ما عداها».</p><p>و<span class="comment-type-3">رجَّح</span> (١٤/٥٨٠ بتصرف) <span class="mustanad">مستندًا إلى أقوال السلف</span> أن المعنى: «إن قتلهم كان إثمًا وخطيئةً، لا خطأً من الفعل، لأنهم إنما كانوا يقتلونهم عمدًا لا خطأً، وعلى عمدهم ذلك عاتبهم ربهم، وتقدم إليهم بالنهي عنه».</div></p><p><h3><span class="qpc-hafs">﴿وَلَا تَقۡتُلُوۤا۟ أَوۡلَـٰدَكُمۡ خَشۡیَةَ إِمۡلَـٰقࣲۖ نَّحۡنُ نَرۡزُقُهُمۡ وَإِیَّاكُمۡۚ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٣٠٠٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- في قوله: <span class="qpc-hafs">﴿خشية إملاق﴾</span>، قال: مخافة الفاقَة والفقر{2}. (٩/٣٣٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٣٠٠٣<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، أن نافع بن الأزرق قال: أخبِرني عن قوله: <span class="qpc-hafs">﴿خشية إملاق﴾</span>. قال: مخافة الفقر. قال: وهل تعرف العرب ذلك؟ قال: نعم، أما سمعت الشاعر وهو يقول:</p><p>وإني على الإملاق يا قوم ماجِد أُعِدُّ لأَضيافي الشِّواء المضهَّبا؟{3}. (٩/٣٣٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٣٠٠٤<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن جريج- <span class="qpc-hafs">﴿ولا تقتلوا أولادكم خشية إملاق﴾</span>، قال: الفاقة والفقر{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٣٠٠٥<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- <span class="qpc-hafs">﴿خشية إملاق﴾</span>، قال: كانوا يقتلون البنات{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٣٠٠٦<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿ولا تقتلوا أولادكم خشية إملاق﴾</span> أي: خشية الفاقة، وكان أهل الجاهلية يقتلون أولادهم خشية الفاقة، فوعظهم الله في ذلك، وأخبرهم أنّ رزقهم ورزق أولادِهم على الله، فقال: <span class="qpc-hafs">﴿نحن نرزقهم وإياكم إن قتلهم كان خِطئًا كبيرًا﴾</span>{6}. (٩/٣٢٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٣٠٠٧<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>، في قوله: <span class="qpc-hafs">﴿ولا تقتلوا أولادكم﴾</span>: يعني: الموءودة. كان أحدهم يقتل ابنته؛ يدفنها حية حتى تموت مخافة الفاقة، ويغذي كلبه{7}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿إِنَّ قَتۡلَهُمۡ كَانَ خِطۡـࣰٔا كَبِیرࣰا ۝٣١﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٣٠٠٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق ابن جريج- في قوله: <span class="qpc-hafs">﴿خِطئًا﴾</span>، قال: خطيئة{8}. (٩/٣٣٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٣٠٠٩<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- <span class="qpc-hafs">﴿خطئا كبيرا﴾</span>، قال: خطيئة{9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٣٠١٠<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> أنّه قرأ: ‹خِطَآءً كَبِيرًا› مهموزة، مِن قِبَلِ الخطأ والصواب{10}. (٩/٣٣١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٣٠١١<span class="dash">-</span></span> قال <span class="name-2">الحسن البصري</span>: ذنبًا كبيرًا{11}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٣٠١٢<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span>، في قوله: <span class="qpc-hafs">﴿إن قتلهم كان خِطئًا كبيرًا﴾</span>، أي: إثمًا كبيرًا{12}. (٩/٣٢٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٣٠١٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ولا تقتلوا أولادكم﴾</span> يعني: دفن البنات وهن أحياء <span class="qpc-hafs">﴿خشية إملاق﴾</span> يعني: مخافة للفقر، <span class="qpc-hafs">﴿نحن نرزقهم وإياكم إن قتلهم كان خطئا﴾</span> يعني: إثمًا <span class="qpc-hafs">﴿كبيرا﴾</span>{13}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٣٠١٤<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿نحن نرزقهم وإياكم إن قتلهم كان خطأ كبيرا﴾</span> ذنبًا كبيرًا، قتلُ النفس التي حرم الله من الكبائر{7}. (ز)</p></p><p></div></p></div>",footnotes:1:عزاه السيوطي إلى ابن أبي حاتم.</p><p>وهي قراءة متواترة، قرأ بها ابن كثير، وقرأ أبو جعفر وابن عامر بخلف عن هشام: ‹خَطَأً› بفتح الخاء والطاء من غير ألف ولا مدّ، واختلف عن هشام، وقرأ بقية العشرة: <span class="qpc-hafs">﴿خِطْئًا﴾</span> بكسر الخاء وإسكان الطاء، وهو الوجه الثاني لهشام. انظر: النشر ٢/٣٠٧، والإتحاف ص٣٥٧.|2:أخرجه ابن جرير ٩/٦٥٨، ١٤/٥٧٨، وابن أبي حاتم ٥/١٤١٤ (٨٠٥٩). وعزاه السيوطي إلى ابن المنذر.|3:عزاه السيوطي إلى الطستيِّ. وينظر: الإتقان ٢/٨٥.|4:أخرجه ابن جرير ١٤/٥٧٨، وبنحوه في تفسير مجاهد ص٤٣٦ من طريق ابن أبي نجيح.|5:أخرجه ابن جرير ١٤/٥٧٨.|6:أخرجه ابن جرير ٩/٦٥٨، ١٤/٥٧٨، وابن أبي حاتم ٥/١٤١٥ (٨٠٦٠). وعلقه يحيى بن سلام ١/١٣٢ مختصرًا.|7:تفسير يحيى بن سلام ١/١٣٢.|8:أخرجه ابن جرير ١٤/٥٨١. وعزاه السيوطي إلى ابن المنذر.|9:أخرجه ابن جرير ١٤/٥٨١.|10:عزاه السيوطي إلى ابن أبي حاتم.|11:علقه يحيى بن سلام ١/١٣٢.|12:أخرجه ابن جرير ٩/٦٥٨، ١٤/٥٧٨، وابن أبي حاتم ٥/١٤١٥ (٨٠٦٠). وعلقه يحيى بن سلام ١/١٣٢ وعقَّب عليه وعلى قول الحسن السابق: وهو واحد.|13:تفسير مقاتل بن سليمان ٢/٥٢٩.|14:تفسير يحيى بن سلام ١/١٣٢.
  17,32,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَلَا تَقۡرَبُوا۟ ٱلزِّنَىٰۤۖ إِنَّهُۥ كَانَ فَـٰحِشَةࣰ وَسَاۤءَ سَبِیلࣰا ۝٣٢﴾</span> - قراءات</h3></p><p><div></p><p><p><span class="item-no">٤٣٠١٥<span class="dash">-</span></span> عن <span class="name-1">أُبيّ بن كعب</span> أنه قرأ: (ولا تَقْرَبُوا الزِّنَآ إنَّهُ كانَ فاحِشَةً ومَقْتًا وسَآءَ سَبِيلًا إلّا مَن تابَ فَإنَّ اللهَ كانَ غَفّارًا رَّحِيمًا). فذُكر لعمر، فأتاه، فسأله، فقال: أخذتُها مِن فِي رسول الله ﷺ، وليس لك عملٌ إلا الصَّفْق{1} بالنَّقيع{2}{3}. (٩/٣٣٢)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَلَا تَقۡرَبُوا۟ ٱلزِّنَىٰۤۖ إِنَّهُۥ كَانَ فَـٰحِشَةࣰ وَسَاۤءَ سَبِیلࣰا ۝٣٢﴾</span> - نزول الآية</h3></p><p><div></p><p><p><span class="item-no">٤٣٠١٦<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span>، في قوله: <span class="qpc-hafs">﴿ولا تقربوا الزنا﴾</span>، قال: يوم نزلت هذه الآية لم تكن حدود، فجاءت بعد ذلك الحدود في سورة النور{4}. (٩/٣٣٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٣٠١٧<span class="dash">-</span></span> عن <span class="name-2">زيد بن أسلم</span> -من طريق سعيد بن أبي هلال- قال: كان في الزنا ثلاثة أنحاء؛ أمّا نحوٌ فقال الله: <span class="qpc-hafs">﴿لا تقربوا الزنا إنه كان فاحشة﴾</span>، فلم يَنتَهِ الناسُ. قال: ثم نزل: <span class="qpc-hafs">﴿واللاتي يأتين الفاحشة من نسائكم فاستشهدوا عليهن أربعة منكم فإن شهدوا فأمسكوهن في البيوت حتى يتوفاهن الموت أو يجعل الله لهن سبيلا﴾</span> [النساء:١٥]، كانت المرأة الثيب إذا زنتْ، فشهد عليها أربعةٌ عُطِّلت، فلم يتزوجها أحد، فهي التي قال الله: <span class="qpc-hafs">﴿ولا تعضلوهن إلا أن يأتين بفاحشة مبينة﴾</span> [النساء:١٩]. قال زيد: ثم نزلت: <span class="qpc-hafs">﴿واللذان يأتيانها منكم فآذوهما﴾</span> [النساء:١٦]، فهذان البكران اللذان إن لم يتزوجا وآذاهما أن يعرفا بذنبهما، فيقال: يا زان. حتى تُرى منهما توبة، حتى نزل السبيل، قال: <span class="qpc-hafs">﴿الزانية والزاني فاجلدوا كل واحد منهما مائة جلدة﴾</span> [النور:٢]، فهذا للبِكْرَيْن. قال زيد: وكان للثَّيِّب الرجم {5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٣٠١٨<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: قوله سبحانه: <span class="qpc-hafs">﴿ولا تقربوا الزنى إنه كان فاحشة وساء سبيلا﴾</span>، يعني: لم يكن يومئذ في الزنا حدٌّ، حتى نزل الحدُّ بالمدينة في سورة النور{6}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَلَا تَقۡرَبُوا۟ ٱلزِّنَىٰۤۖ إِنَّهُۥ كَانَ فَـٰحِشَةࣰ وَسَاۤءَ سَبِیلࣰا ۝٣٢﴾</span> - تفسير الآية</h3></p><p><div></p><p><p><span class="item-no">٤٣٠١٩<span class="dash">-</span></span> قال قتادة، عن الحسن البصري في قوله: <span class="qpc-hafs">﴿ولا تقربوا الزنى إنه كان فاحشة﴾</span>، أن رسول الله ﷺ كان يقول: «<b>لا يزني العبد حين يزني وهو مؤمن، ولا يَنتَهِب حين يَنتَهِب وهو مؤمن، ولا يسرق حين يسرق وهو مؤمن، ولا يشرب الخمر حين يشربها وهو مؤمن، ولا يَغُلُّ حين يَغُلُّ وهو مؤمن</b>». قيل: يا رسول الله، والله إن كُنّا لَنرى أنه يأتي ذلك وهو مؤمن. فقال نبي الله ﷺ: «<b>إذا فعل شيئًا مِن ذلك نُزِع الإيمان من قلبه، فإن تاب تاب الله عليه</b>»{4}. (٩/٣٣٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٣٠٢٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: قوله سبحانه: <span class="qpc-hafs">﴿ولا تقربوا الزنى إنه كان فاحشة﴾</span> يعني: معصية، <span class="qpc-hafs">﴿وساء سبيلا﴾</span> يعني: المسلك{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٣٠٢١<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: قوله: <span class="qpc-hafs">﴿ولا تقربوا الزنى إنه كان فاحشة وساء سبيلا﴾</span> وبئس الطريق.= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٣٠٢٢<span class="dash">-</span></span> وقال <span class="name-2">السُّدِّيّ</span>: ويعني: المسلك. وهو نحوه{9}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَلَا تَقۡرَبُوا۟ ٱلزِّنَىٰۤۖ إِنَّهُۥ كَانَ فَـٰحِشَةࣰ وَسَاۤءَ سَبِیلࣰا ۝٣٢﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٤٣٠٢٣<span class="dash">-</span></span> عن أبي هريرة، أن رسول الله ﷺ قال: «<b>لا يزني الزاني حين يزني وهو مؤمن، ولا يسرق السارق حين يسرق وهو مؤمن، ولا يشرب الخمر حين يشربها وهو مؤمن، ولا يَنتَهِب نُهبَةً ذات شرف يرفَعُ المؤمنون إليه فيها أبصارهم وهو مؤمن</b>»{10}. (٩/٣٣٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٣٠٢٤<span class="dash">-</span></span> عن أبي هريرة، قال: قال رسول الله ﷺ: «<b>ثلاثة لا يُكَلِّمُهم الله يوم القيامة، ولا يُزكِّيهم، ولا ينظُرُ إليهم، ولهم عذاب أليم: شيخٌ زانٍ، ومَلِكٌ كَذّابٌ، وعائلٌ مُستكبر</b>»{11}. (٩/٣٣٧)</p></p><p></div></p></div>",footnotes:1:تصافق القوم: تبايعوا. اللسان (صفق).|2:النقيع: موضع تلقاء المدينة، بينها وبين مكة. معجم ما استعجم ٤/١٣٢٣، ومعجم البلدان ٤/٨٠٩.|3:عزاه السيوطي إلى أبي يعلى، وابن مَرْدويه.</p><p>وهي قراءة شاذة.|4:عزاه السيوطي إلى ابن أبي حاتم.|5:أخرجه ابن وهب في الجامع ١/١٢٥-١٢٧ (٢٩٠).|6:تفسير مقاتل بن سليمان ٢/٥٢٩.|7:عزاه السيوطي إلى ابن أبي حاتم.|8:تفسير مقاتل بن سليمان ٢/٥٢٩.|9:تفسير يحيى بن سلام ١/١٣٢.|10:أخرجه البخاري ٣/١٣٦ (٢٤٧٥)، ٧/١٠٤ (٥٥٧٨)، ٨/١٥٧ (٦٧٧٢)، ٨/١٦٤ (٦٨١٠)، ومسلم ١/٧٦-٧٧ (٥٧).|11:أخرجه مسلم ١/١٠٢ (١٠٧)، وابن أبي حاتم ١/٢٨٦ (١٥٣٦)، ٢/٦٨٨ (٣٧٢٧).
  17,33,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَلَا تَقۡتُلُوا۟ ٱلنَّفۡسَ ٱلَّتِی حَرَّمَ ٱللَّهُ إِلَّا بِٱلۡحَقِّۗ وَمَن قُتِلَ مَظۡلُومࣰا فَقَدۡ جَعَلۡنَا لِوَلِیِّهِۦ سُلۡطَـٰنࣰا فَلَا یُسۡرِف فِّی ٱلۡقَتۡلِۖ إِنَّهُۥ كَانَ مَنصُورࣰا ۝٣٣﴾</span> - قراءات</h3></p><p><div></p><p><p><span class="item-no">٤٣٠٢٥<span class="dash">-</span></span> عن الكسائيِّ قال: هي قراءة <span class="name-1">أُبيّ بن كعب</span>: (فَلا تُسْرِفُواْ فِي القَتْلِ إنَّ ولِيَّهُ كانَ مَنصُورًا){1}. (٩/٣٤٢)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَلَا تَقۡتُلُوا۟ ٱلنَّفۡسَ ٱلَّتِی حَرَّمَ ٱللَّهُ إِلَّا بِٱلۡحَقِّۗ وَمَن قُتِلَ مَظۡلُومࣰا فَقَدۡ جَعَلۡنَا لِوَلِیِّهِۦ سُلۡطَـٰنࣰا فَلَا یُسۡرِف فِّی ٱلۡقَتۡلِۖ إِنَّهُۥ كَانَ مَنصُورࣰا ۝٣٣﴾</span> - نزول الآية</h3></p><p><div></p><p><p><span class="item-no">٤٣٠٢٦<span class="dash">-</span></span> عن <span class="name-2">الضَّحّاك بن مُزاحِم</span> -من طريق عبيد- في قوله: <span class="qpc-hafs">﴿ولا تقتلوا النفس﴾</span> الآية، قال: كان هذا بمكة ونبيُّ الله ﷺ بها، وهو أول شيء نزل من القرآن في شأن القتل{2}. (٩/٣٣٨)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَلَا تَقۡتُلُوا۟ ٱلنَّفۡسَ ٱلَّتِی حَرَّمَ ٱللَّهُ إِلَّا بِٱلۡحَقِّۗ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٣٠٢٧<span class="dash">-</span></span> عن عثمان بن عفان، قال: قال رسول الله ﷺ: «<b>لا يَحِلُّ دمُ مسلمٍ إلا بأحد ثلاث: رجل كفر بعد إسلامه، أو زنى بعد إحصانه، أو قتل نفسا متعمدًا</b>»{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٣٠٢٨<span class="dash">-</span></span> عن أنس بن مالك، قال: قال رسول الله ﷺ: «<b>أُمِرْتُ أن أقاتل الناس حتى يقولوا: لا إله إلا الله. فإذا قالوها عصموا مني دماءَهم وأموالَهم إلا بحقِّها، وحسابُهم على الله».</b> قيل: وما حقُّها؟ قال: <b>«زِنًا بعد إحصان، وكفر بعد إيمان، وقتل نفس فيقتل بها</b>»{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٣٠٢٩<span class="dash">-</span></span> عن عروة أو غيره، قال: قيل <span class="name-1">لأبي بكر الصديق</span>: أتقتل مَن يرى أن لا يؤدي الزكاة؟ قال: لو منعوني شيئًا مما أقرُّوا به لرسول الله ﷺ لقاتلتهم. فقيل لأبي بكر: أليس قال رسول الله ﷺ: «<b>أمرت أن أقاتل الناس حتى يقولوا: لا إله إلا الله، فإذا قالوها عصموا مني دماءهم وأموالهم إلا بحقها وحسابهم على الله</b>»؟ فقال أبو بكر: هذا من حقِّها{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٣٠٣٠<span class="dash">-</span></span> عن <span class="name-2">الضحاك بن مزاحم</span> -من طريق عبيد- في قوله: <span class="qpc-hafs">﴿ولا تقتلوا النفس﴾</span> الآية، قال: كان هذا بمكة ونبيُّ الله ﷺ بها، وهو أولُ شيء نزل من القرآن في شأن القتل، كان المشركون من أهل مكة يغتالون أصحاب النبي ﷺ، فقال الله: مَن قتلكم مِن المشركين فلا يَحمِلَنَّكم قَتلهُ إيّاكم على أن تقتُلوا له أبًا، أو أخًا، أو أحدًا من عشيرته، وإن كانوا مشركين فلا تقتلوا إلا قاتلَكم. وهذا قبل أن تنزل براءة، وقبل أن يُؤمَروا بقتال المشركين، فذلك قوله: <span class="qpc-hafs">﴿فلا يُسرف في القتل﴾</span>. يقول: لا تَقتُل غير قاتلك. وهي اليوم على ذلك الموضع من المسلمين، لا يحلُّ لهم أن يقتُلوا إلا قاتِلَهم{2}. (٩/٣٣٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٣٠٣١<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- قوله: <span class="qpc-hafs">﴿ولا تقتلوا النفس التي حرم الله إلا بالحق﴾</span>: وإنّا -واللهِ- ما نعلم بحِلِّ دمِ امرئ مسلم إلا بإحدى ثلاث: إلا رجلًا قتل متعمدًا فعليه القَوَدُ، أو زنى بعد إحصانه فعليه الرجم، أو كفر بعد إسلامه فعليه القتل{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٣٠٣٢<span class="dash">-</span></span> عن <span class="name-2">زيد بن أسلم</span> -من طريق يزيد بن عياض، وهشام بن سعد-: أنّ الناس في الجاهلية كانوا إذا قتَل الرجل مِن القوم رجلًا لم يرضَوا حتى يقتُلوا به رجلًا شريفًا إذا كان قاتلهم غير شريف، لم يقتلوا قاتلهم وقتلوا غيره، فوُعِظوا في ذلك بقول الله تعالى: <span class="qpc-hafs">﴿ولا تقتلوا النفس﴾</span> إلى قوله: <span class="qpc-hafs">﴿فلا يسرف في القتل﴾</span>{8}. (٩/٣٣٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٣٠٣٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ولا تقتلوا النفس التي حرم الله﴾</span> قتلها، يعني: باغيًا، <span class="qpc-hafs">﴿إلا بالحق﴾</span> الذي يَقْتُل فيُقْتَل به{9}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَلَا تَقۡتُلُوا۟ ٱلنَّفۡسَ ٱلَّتِی حَرَّمَ ٱللَّهُ إِلَّا بِٱلۡحَقِّۗ﴾</span> - أحكام متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٤٣٠٣٤<span class="dash">-</span></span> عن عبد الله بن عمرو، قال: قال رسول الله ﷺ: «<b>مَن قُتِل دون ماله فهو شهيد</b>»{10}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٣٠٣٥<span class="dash">-</span></span> عن عبد الله بن عباس، قال: قال رسول الله ﵇: «<b>مَن قاتل دون ماله فقُتِل فهو شهيد، ومَن قاتل دون نفسه فقُتِل فهو شهيد، ومَن قاتل دون أهله فقُتِل فهو شهيد. وكل قتيل في جَنب الله فهو شهيد</b>»{11}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٣٠٣٦<span class="dash">-</span></span> عن قابوس بن المخارق، عن أبيه، أنّ رجلًا قال: يا رسول الله، الرجل يعرِض لي، يريد نفسي ومالي، كيف أصنع به؟ قال: «<b>ناشِده الله</b>». قال: نشدته بالله فلم ينتهِ. قال: «<b>اسْتَعْدِ عليه السلطانَ</b>». قال: ليس بحضرتنا سلطان. قال: «<b>اسْتَعِن عليه المسلمين</b>». قال: نحن بفلاة مِن الأرض، ليس قربنا أحد. قال: «<b>فجاهده دون مالك حتى تمنعه، أو تكتب في شهداء الآخرة</b>»{12}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَمَن قُتِلَ مَظۡلُومࣰا فَقَدۡ جَعَلۡنَا لِوَلِیِّهِۦ سُلۡطَـٰنࣰا﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٣٠٣٧<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق العوفي- في قوله: <span class="qpc-hafs">﴿ومن قتل مظلومًا فقد جعلنا لوليه سلطانًا﴾</span>، قال: بيِّنَة مِن الله أنزلها، يطلبها ولِيُّ المقتول؛ القَوَدَ أو العقل{13}، وذلك السلطان{14}. (٩/٣٣٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٣٠٣٨<span class="dash">-</span></span> قال <span class="name-2">مجاهد بن جبر</span>، في قوله: <span class="qpc-hafs">﴿ومن قتل مظلوما فقد جعلنا لوليه سلطانا﴾</span>، أي: قوة وولاية على القاتل بالقتل{15}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٣٠٣٩<span class="dash">-</span></span> عن <span class="name-2">الضحاك بن مزاحم</span> -من طريق جويبر- في قوله: <span class="qpc-hafs">﴿فقد جعلنا لوليه سلطانا﴾</span>، قال: إن شاء عفا، وإن شاء أخذ الدِّيَة{16}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٣٠٤٠<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق أبي رجاء- في قوله: <span class="qpc-hafs">﴿ومن قتل مظلوما فقد جعلنا لوليه سلطانا﴾</span>، قال: كان الرجل يُقْتَل، فيقول وليُّه: لا أرضى حتى أقتل به فلانًا وفلانًا مِن أشراف قبيلته{17}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٣٠٤١<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- قوله: <span class="qpc-hafs">﴿ومن قتل مظلوما فقد جعلنا لوليه سلطانا﴾</span>: وهو القَوَد الذي جعله الله تعالى{18}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٣٠٤٢<span class="dash">-</span></span> تفسير [<span class="name-2">إسماعيل</span>] <span class="name-2">السُّدِّيّ</span>، قوله: <span class="qpc-hafs">﴿ومن قتل مظلوما﴾</span>: يعني: المقتول ظلمه القاتل حين قتله بغير حقِّه{19}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٣٠٤٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ومن قتل مظلوما فقد جعلنا لوليه﴾</span> يعني: ولي المقتول <span class="qpc-hafs">﴿سلطانا﴾</span> يعني: مسلطًا على القتلى{20}؛ إن شاء قَبِله، وإن شاء عفا عنه، وإن شاء أخذ الدية{9}<span class=comment-ref>٣٨٣٥</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٣٨٣٥</span> اختلف في معنى: <span class="qpc-hafs">﴿فَقَدْ جَعَلْنا لِوَلِيِّهِ سُلْطانًا﴾</span> في هذه الآية على قولين: <b>الأول:</b> أنه الخيار بيْن القَوَد أو الدِّيَة أو العَفْو. <b>الثاني:</b> أنه القَوَد. <span class="comment-type-3">ورجَّح</span> <u>ابن جرير</u> (١٤/٥٨٤) <span class="mustanad">مستندًا إلى السنة</span> القول الأول، وهو قول ابن عباس، وقول الضحاك، وعلَّل ذلك بقوله: «لصحة الخبر عن رسول الله ﷺ أنه قال يوم فتح مكة: «ألا ومَن قُتِل له قتيلٌ فهو بخير النَّظَرَيْن، بيْن أن يَقتُل أو يأخذ الدية»».</div></p><p><h3><span class="qpc-hafs">﴿فَلَا یُسۡرِف فِّی ٱلۡقَتۡلِۖ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٣٠٤٤<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق مجاهد- في قوله: <span class="qpc-hafs">﴿فلا يسرف في القتل﴾</span>، قال: لا يُكثِر في القتل{22}. (٩/٣٣٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٣٠٤٥<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق أبي صالح- في قوله: <span class="qpc-hafs">﴿فلا يسرف في القتل﴾</span>، قال: لا يقتل إلا قاتل رَحِمِه{23}. (٩/٣٣٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٣٠٤٦<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span>، في قوله: <span class="qpc-hafs">﴿فلا يسرف في القتل﴾</span>، قال: لا يقتُل غير قاتله{22}. (٩/٣٤٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٣٠٤٧<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span> -من طريق خُصَيْف- في قوله: <span class="qpc-hafs">﴿فلا يسرف في القتل﴾</span>، قال: لا يقتل اثنين بواحد{25}. (٩/٣٤٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٣٠٤٨<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن كثير المكي- <span class="qpc-hafs">﴿فلا يسرف في القتل﴾</span>، قال: لا يسرف القاتلُ في القتل{26}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٣٠٤٩<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله تعالى: <span class="qpc-hafs">﴿فلا يسرف في القتل إنه كان منصورا﴾</span>، قال: القتل سَرَف{27}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٣٠٥٠<span class="dash">-</span></span> عن <span class="name-2">الضحاك بن مزاحم</span> -من طريق عبيد- في قوله: <span class="qpc-hafs">﴿فلا يُسرف في القتل﴾</span>، يقول: لا تَقتُل غير قاتلك{28}. (٩/٣٣٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٣٠٥١<span class="dash">-</span></span> عن <span class="name-2">طَلْق بن حبيب</span> -من طريق منصور- في قوله: <span class="qpc-hafs">﴿فلا يسرف في القتل﴾</span>، قال: لا تقتل غير قاتله، ولا تُمَثِّل به{29}. (٩/٣٣٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٣٠٥٢<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق أبي رجاء- قال: لا يقتل غير قاتله{30}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٣٠٥٣<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق أبي رجاء- في قوله: <span class="qpc-hafs">﴿ومن قتل مظلوما فقد جعلنا لوليه سلطانا﴾</span>، قال: كان الرجل يُقْتَل، فيقول وليُّه: لا أرضى حتى أقتل به فلانًا وفلانًا من أشراف قبيلته{17}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٣٠٥٤<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- <span class="qpc-hafs">﴿فلا يُسرف في القتل﴾</span>، قال: لا تقتل غير قاتلك، ولا تُمَثِّل به{17}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٣٠٥٥<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿فلا يسرف في القتل﴾</span>، قال: لا يقتل غير قاتله؛ مَن قَتَل بحديدة قُتِل بحديدة، ومن قَتَل بخشبة قُتِل بخشبة، ومَن قَتَل بحجر قُتِل بحجر. ذُكِر لنا: أنّ نبي الله ﷺ كان يقول: «<b>إنّ مِن أعتى الناس على الله -جل ثناؤه- ثلاثة: رجل قتل غير قاتله، أو قتل بذحْلِ</b>{33} <b>الجاهلية، أو قتل في حرم الله</b>»{34}. (٩/٣٤٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٣٠٥٦<span class="dash">-</span></span> عن <span class="name-2">زيد بن أسلم</span> -من طريق يزيد بن عياض، وهشام بن سعد- في قوله: <span class="qpc-hafs">﴿فلا يسرف في القتل﴾</span>، قال: السَّرَف: أن يقتل غير قاتله{8}. (٩/٣٣٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٣٠٥٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثم قال لولي المقتول: <span class="qpc-hafs">﴿فلا يسرف في القتل إنه كان منصورا﴾</span>، من أمر الله ﷿ في كتابه جعل الأمر إليه، ولا تقتلن غير القاتل، فإنّ مَن قتل غير القاتل فقد أسرف؛ لقوله سبحانه: <span class="qpc-hafs">﴿إنه كان منصورا﴾</span>{9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٣٠٥٨<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- قال في قول الله -جل ثناؤه-: <span class="qpc-hafs">﴿ومن قتل مظلوما فقد جعلنا لوليه سلطانا﴾</span>، قال: إنّ العرب كانت إذا قُتِل منهم قتيل لم يرضوا أن يقتلوا قاتل صاحبهم، حتى يقتلوا أشرف مِن الذي قتله. فقال الله -جل ثناؤه-: <span class="qpc-hafs">﴿فقد جعلنا لوليه سلطانا﴾</span> ينصره، وينتصف من حقه؛ <span class="qpc-hafs">﴿فلا يسرف في القتل﴾</span> يقتل بريئًا{17}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٣٠٥٩<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: قوله: <span class="qpc-hafs">﴿فلا يسرف في القتل﴾</span>: لا يقتل غير قاتله{38}<span class=comment-ref>٣٨٣٦</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٣٨٣٦</span> اختُلِف في معنى: <span class="qpc-hafs">﴿فَلا يُسْرِفْ فِي القَتْلِ﴾</span> بناءً على اختلاف القرأة في قراءتها؛ <b>فمن قرأها:</b> ›فَلا تُسرِف‹ بالتاء: كانت على معنى الخطاب لرسول الله ﷺ، ولأُمَّته بعده. و<span class="comment-type-1">وجَّهه</span> <u>ابنُ عطية</u> (٥/٤٧٢) بقوله: «أي: فلا تقتلوا غير القاتل». ثم ذكر احتمالًا آخر أن يكون الخطاب للوليِّ، فقال: «ويصحّ أن يراد به الوليِّ، أي: فلا تسرف -أيُّها الوليُّ- في قتل أحد متحصل في هذا الحكم». <b>ومن قرأها:</b> <span class="qpc-hafs">﴿فلا يُسرِف﴾</span> بالياء كان له فيها معنيان: <b>الأول:</b> فلا يُسرِف وليُّ المقتول فيَقْتُل غير قاتِلِ وليِّه. <b>الثاني:</b> فلا يُسرِف القاتل في القتل. و<span class="comment-type-1">وجَّهه</span> <u>ابنُ عطية</u> بقوله: «والمعنى: فلا يكن أحد من المسرفين بأن يقتل نفسًا، فإنه يحصل في سياق هذا الحكم».</p><p>و<span class="comment-type-3">رجَّح</span> <u>ابنُ جرير</u> (١٤/٥٨٥، ٥٨٨) صوابَ القراءتين وتقارب معنييهما، ثم <span class="comment-type-3">رجَّح</span> صحة المعاني المبنية عليها القراءات <span class="mustanad">مستندًا إلى دلالة العموم</span>، فقال: «وإن كان كِلا وجْهَي القراءة عندنا صوابًا، فكذلك جميع أوجُهِ تأويله التي ذكرناها غيرُ خارجٍ وجْهٌ منها من الصواب». وعلَّل ذلك بقوله: «لاحتمال الكلام ذلك، وإنّ في نهي الله -جلَّ ثناؤُه- بعضَ خَلْقِه عن الإسراف في القتل نهيًا منه جميعَهم عنه».</div></p><p><h3><span class="qpc-hafs">﴿فَلَا یُسۡرِف فِّی ٱلۡقَتۡلِۖ﴾</span> - أحكام متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٤٣٠٦٠<span class="dash">-</span></span> عن عبد الله بن مسعود، قال: قال رسول الله ﷺ: «<b>أعفُّ الناس قِتلةً أهل الإيمان</b>»{39}. (٩/٣٤١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٣٠٦١<span class="dash">-</span></span> عن سمُرة بن جندب، وعمران بن حصين، قالا: نهى رسول الله ﷺ عن المُثلَةِ{40}. (٩/٣٤١)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿إِنَّهُۥ كَانَ مَنصُورࣰا ۝٣٣﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٣٠٦٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، في قوله: <span class="qpc-hafs">﴿فلا يسرف في القتل إنه كان منصورًا﴾</span>، يقول: ينصُرُه السلطان حتى يُنصِفَه مِن ظالمه، ومن انتصر لنفسه دون السلطان فهو عاصٍ مُسْرِفٌ قد عمِل بحَمِيَّةِ أهل الجاهلية، ولم يرضَ بحكم الله تعالى{41}. (٩/٣٤١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٣٠٦٣<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن كثير المكي- في قوله: <span class="qpc-hafs">﴿إنه كان منصورًا﴾</span>، قال: إنّ المقتول كان منصورًا{42}. (٩/٣٤١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٣٠٦٤<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- <span class="qpc-hafs">﴿إنه كان منصورا﴾</span>، قال: هو دفع الإمام إليه -يعني: إلى الولي-؛ فإن شاء قتل، وإن شاء عفا{43}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٣٠٦٥<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: وبعضهم يقول: <span class="qpc-hafs">﴿إنه كان منصورا﴾</span>، يعني: في الآخرة، يعني: الذي يُعدى عليه فَقُتِلَ، وليس هو قاتل الأول ينصر على الذي تعدّى عليه فقتله{38}<span class=comment-ref>٣٨٣٧</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٣٨٣٧</span> اختُلِف في عود الضمير في قوله تعالى: <span class="qpc-hafs">﴿إنَّهُ كانَ مَنصُورًا﴾</span> على ثلاثة أقوال: <b>الأول:</b> أنه يعود على وليِّ المقتول، وهو المنصور على القاتل، والمعنى: إنه كان منصورًا بتمكينه من القَوَد. <b>الثاني:</b> أنه يعود على المقتول، والمعنى: إنه كان منصورًا بقتل قاتله. <b>الثالث:</b> أنه يعود على دم المقتول، والمعنى: إن دم القتيل كان منصورًا، أي: مطلوبًا به.</p><p>و<span class="comment-type-3">رجَّح</span> <u>ابنُ جرير</u> (١٤/٥٨٩) <span class="mustanad">مستندًا إلى دلالة اللغة، والدلالة العقلية</span> القولَ الأول، وهو قول قتادة، وعلَّل ذلك بقوله: «لأنه هو المظلوم، ووَلِيُّه المقتول، وهي إلى ذِكْرِه أقربُ من ذِكْر المقتول، وهو المنصور أيضًا؛ لأن الله -جلَّ ثناؤه- قضى في كتابه المُنَزَّل أن سلَّطه على قاتل وليِّه، وحكَّمه فيه بأن جعل إليه قتْلَه إن شاء، واستبقاءَه على الدِّيَة إن أحبَّ، والعفوَ عنه إن رأى، وكفى بذلك نصرةً له من الله، فلذلك قلنا: هو المعنيُّ بالهاء التي في قوله: <span class="qpc-hafs">﴿إنَّهُ كانَ مَنصُورًا﴾</span>».</p><p>و<span class="comment-type-3">رجَّح</span> <u>ابنُ عطية</u> (٥/٤٧٣) <span class="mustanad">مستندًا إلى الدلالة العقلية</span> القول الثاني، وهو قول مجاهد، فقال: «وهو أرجح الأقوال؛ لأنه المظلوم، ولفظة النصر تقارن أبدًا الظلم، كقوله عليه الصلاة والسلام: «<b>ونَصْر المظلوم، وإبْرار القَسم</b>». وكقوله ﷺ: «<b>انصر أخاك ظالمًا أو مظلومًا</b>». إلى كثيرٍ من الأمثلة». ونقل قولًا عن أبي عبدة: أن الضمير يعود «على القاتل؛ لأنه إذا قُتِل في الدنيا وخلص بذلك من عذاب الآخرة فقد نُصِر». ثم <span class="comment-type-2">انتقده</span> قائلًا: «وهذا ضعيفٌ بعيد المقصد».</div></p><p><h3><span class="qpc-hafs">﴿إِنَّهُۥ كَانَ مَنصُورࣰا ۝٣٣﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٤٣٠٦٦<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، قال: إنّه لَمّا كان مِن أمر هذا الرجل ما كان -يعني: عثمان- قلتُ لعليٍّ: اعتزل، فلو كنتَ في جحرٍ طُلِبتَ حتى تُستخرَجَ. فعصاني، وايمُ اللهِ، ليَتَأمَرَنَّ عليكم معاوية، وذلك أنّ الله يقول: <span class="qpc-hafs">﴿ومن قتل مظلومًا فقد جعلنا لوليه سلطانًا فلا يسرف في القتل إنه كان منصورًا﴾</span>{45}. (٩/٣٤٢)</p></p><p></div></p></div>",footnotes:1:عزاه السيوطي إلى أبي عبيد، وابن المنذر.</p><p>وهي قراءة شاذة. انظر: مختصر ابن خالويه ص٨٠.|2:أخرجه ابن جرير ١٤/٥٨٦. وعزاه السيوطي إلى ابن المنذر.|3:أخرجه أحمد ١/٤٩١ (٤٣٧)، ١/٥١١-٥١٢ (٤٦٨)، ١/٥٣٤ (٥٠٩)، والنسائي ٧/٩١ (٤٠١٩)، والشافعي في اختلاف الحديث ٨/٦٤٣ واللفظ له، ويحيى بن سلام في تفسيره ١/١٣٣.</p><p>قال الشافعي: «وهذا حديث لا يَشُكُّ أهل العلم بالحديث في ثبوته عن النبي ﷺ».|4:أخرجه ابن جرير ١٤/٥٨٢-٥٨٣. وأورده الثعلبي ٦/٩٧. وأصله في البخاري ١/٨٧ (٣٩٢).|5:أخرجه ابن جرير ١٤/٥٨٢.|6:أخرجه ابن جرير ١٤/٥٨٦. وعزاه السيوطي إلى ابن المنذر.|7:أخرجه ابن جرير ١٤/٥٨٢.|8:أخرجه البيهقي في سُنَنِه ٨/٢٥.|9:تفسير مقاتل بن سليمان ٢/٥٣٠.|10:أخرجه البخاري ٣/١٣٦ (٢٤٨٠)، ومسلم ١/١٢٤ (١٤١)، ويحيى بن سلام في تفسيره ١/١٣٣.|11:أخرجه الحارث في مسنده ٢/٦٦٠ (٦٣٦)، وابن البختري في مجموع فيه مصنفاته ص٢٢٤ (٢٠٩)، ويحيى بن سلام في تفسيره ١/١٣٣.</p><p>قال البوصيري في إتحاف الخيرة ٥/١٥١ (٤٤٢٣): «مدار حديث ابن عباس هذا على جويبر بن سعيد البلخي، وهو ضعيف، ضعَّفه ابن المديني، وأحمد، وابن معين، والنسائي، وعلي بن الجنيد، والدارقطني، وابن عدي، وأبو أحمد الحاكم، والحاكم أبو عبد الله، والذهبي، وغيرهم». وقال الكتاني في نظم المتناثر في الحديث المتواتر ص١٤٦: «أورده في الأزهار في كتاب الأدب من حديث ابن عمرو، وأبي هريرة، والحسين بن علي، وابن عباس، وسعد بن أبي وقاص، وأنس، وابن الزبير، وابن مسعود، وعبد الله بن عامر بن كريز، وشداد بن أوس، وعلي بن أبي طالب، وجابر بن عبد الله، وسويد بن مقرن ثلاثة عشر نفسًا. قلت: ورد أيضًا من حديث بريدة، وابن عمر بن الخطاب، وسعيد بن زيد».|12:أخرجه أحمد ٣٧/١٩١-١٩٢ (٢٢٥١٣، ٢٢٥١٤)، والنسائي ٧/١١٣ (٤٠٨١)، ويحيى بن سلام في تفسيره ١/١٣٣.</p><p>قال المناوي في فيض القدير ٤/٤٦٧ (٥٩٩٧): «رمز المصنف -السيوطي- لحسنه». وقال الألباني في الصحيحة ٧/٧٥١: «وإسناده حسن».|13:العقل: الدية. اللسان (عقل).|14:أخرجه ابن جرير ١٤/٥٨٣. وعزاه السيوطي إلى ابن أبي حاتم.|15:تفسير البغوي ٥/٩١.|16:أخرجه ابن جرير ١٤/٥٨٣.|17:أخرجه ابن جرير ١٤/٥٨٧.|18:أخرجه ابن جرير ١٤/٥٨٤. وعلقه يحيى بن سلام ١/١٣٤، وزاد: إلا أن يعفو الولي، أو يرضى بالدية إن أُعْطِيها.|19:علقه يحيى بن سلام ١/١٣٣.|20:كذا في المصدر. ولعلها تصحَّفت عن القاتل.|21:تفسير مقاتل بن سليمان ٢/٥٣٠.|22:عزاه السيوطي إلى ابن أبي حاتم.|23:عزاه السيوطي إلى ابن المنذر.|24:عزاه السيوطي إلى ابن أبي حاتم.|25:أخرجه عبد الرزاق ١/٣٧٧، وابن أبي شيبة ٩/٤٢٣-٤٢٤، وابن جرير ١٤/٥٨٦ بلفظ: لا تقتل اثنين بواحد. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.|26:أخرجه ابن جرير ١٤/٥٨٨.|27:أخرجه أبو جعفر الرملي في جزئه ص٥٢ (تفسير مسلم الزنجي).|28:أخرجه ابن جرير ١٤/٥٨٦ مطولًا. وعزاه السيوطي إلى ابن المنذر.|29:أخرجه ابن أبي شيبة ٩/٤٢٣، وابن جرير ١٤/٥٨٥ واللفظ له، والبيهقي في سُنَنِه ٨/٢٥. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.|30:أخرجه يحيى بن سلام ١/١٣٤.|31:أخرجه ابن جرير ١٤/٥٨٧.|32:أخرجه ابن جرير ١٤/٥٨٧.|33:الذحل: الثأر، أو طلب مكافأة بجناية جُنيت عليك، أو عداوة أتيت إليك، أو هو العداوة والحقد. القاموس المحيط (ذحل).|34:أخرجه يحيى بن سلام ١/١٣٤ مختصرًا من طريق سعيد، ومن طريق حماد، وابن جرير ١٤/٥٨٧. وعزاه السيوطي إلى ابن أبي حاتم.</p><p>والجزء المرفوع أخرجه أحمد (٦٦٨١) من حديث عبد الله بن عمرو بن العاص بنحوه، كما أخرجه في (١٦٣٧٦، ١٦٣٧٨)، والبيهقي ٨/٢٦ من حديث أبي شريح الخزاعي بنحوه.|35:أخرجه البيهقي في سُنَنِه ٨/٢٥.|36:تفسير مقاتل بن سليمان ٢/٥٣٠.|37:أخرجه ابن جرير ١٤/٥٨٧.|38:تفسير يحيى بن سلام ١/١٣٤.|39:أخرجه أحمد ٦/٢٧٤-٢٧٦ (٣٧٢٨، ٣٧٢٩)، وأبو داود ٤/٣٠٠ (٢٦٦٦)، وابن ماجه ٣/٦٨٨، ٦٨٩ (٢٩٨١، ٢٩٨٢)، وابن حبان ١٣/٣٣٥ (٥٩٩٤).</p><p>قال ابن حزم في المحلى ١٠/٢٦٤: «وإن لم يصح لفظه -فإن فيه هنيء بن نويرة، وهو مجهول-، فمعناه صحيح». وقال المناوي في فيض القدير ٢/٧ (١١٩٠): «رجاله ثقات». وقال الألباني في ضعيف أبي داود ٢/٣٣٤ (٤٥٨): «ضعيف». وقال في الضعيفة ٣/٣٧٦ (١٢٣٢): «ضعيف؛ لاضطرابه وجهالته ... وجملة القول أن الحديث ضعيف مرفوعًا، وقد يصح موقوفًا».|40:أخرجه أحمد ٣٣/٧٨-٧٩ (١٩٨٤٤)، ٣٣/٨٠-٨١ (١٩٨٤٦)، ٣٣/١٤١ (١٩٩٠٩)، وأبو داود ٤/٣٠١ (٢٦٦٧).</p><p>قال البزار في مسنده ٩/٧٥- ٧٦ (٣٦٠٥): «هذا الحديث قد روي عن عمران بن حصين من غير وجه، ورواه عن الحسن غير واحد عن عمران، ولم يدخل بين عمران والحسن أحدًا غير قتادة». وقال فيه ١٠/٤٤٢ (٤٥٩٨): «قال أبو بكر: وهذا الحديث قد رواه جماعة عن الحسن عن عمران بن حصين، والصواب: عن عمران بن حصين». وقال البيهقي في معرفة السنن والآثار ١٤/٢٠١ (١٩٦٦٣): «هذا أصح ما روي فيه عن عمران». وقال في السنن الكبرى ١٠/١٢٢: «هذا إسناد موصول». وقال ابن القيسراني في ذخيرة الحفاظ ٤/٢٠٩٥ (٤٨٤٢): «رواه أبو بكر الهذلي ... والهذلي متروك الحديث». وقال ابن حجر في الفتح ٧/٤٥٩: «إسناد هذا الحديث قوي». وقال الهيثمي في المجمع ٤/١٨٩ (٦٩٦٩): «رواه أحمد والبزار بنحوه، والطبراني في الكبير، ورجال أحمد رجال الصحيح». وقال الألباني في صحيح أبي داود ٧/٤١٩-٤٢٠ (٢٣٩٣): «صح الحديث يقينًا».|41:عزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.|42:أخرجه ابن جرير ١٤/٥٨٩. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم. وفي تفسير الثعلبي ٦/٩٨: <span class="qpc-hafs">﴿ومن قتل مظلوما﴾</span> يعني: أن المقتول منصور في الدنيا بالقصاص، وفي الآخرة بالتوبة.|43:أخرجه ابن جرير ١٤/٥٨٨. وعلق يحيى بن سلام ١/١٣٤ نحوه بلفظ: ينصره السلطان حتى يُقِيده منه.|44:تفسير يحيى بن سلام ١/١٣٤.|45:أخرجه الطبراني (١٠٦١٣)، وابن عساكر ٣٩/٤٧٧، ٥٩/١٢٥.
  17,34,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَلَا تَقۡرَبُوا۟ مَالَ ٱلۡیَتِیمِ إِلَّا بِٱلَّتِی هِیَ أَحۡسَنُ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٣٠٦٧<span class="dash">-</span></span> قال <span class="name-2">مجاهد بن جبر</span>: أي: <span class="qpc-hafs">﴿لا تقربوا مال اليتيم﴾</span> فتستقرضوا منه <span class="qpc-hafs">﴿إلا بالتي هي أحسن﴾</span> التجارة لهم{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٣٠٦٨<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿ولا تقربوا مال اليتيم إلا بالتي هي أحسن﴾</span>، قال: كانوا لا يُخالِطونهم في مالٍ، ولا مأكلٍ، ولا مركبٍ، حتى نزلت: <span class="qpc-hafs">﴿وإن تخالطوهم فإخوانكم﴾</span> [البقرة:٢٢٠]{2}. (٩/٣٤٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٣٠٦٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ولا تقربوا مال اليتيم إلا بالتي هي أحسن﴾</span>، إلا لِتُنَمِّي ماله بالأرباح{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٣٠٧٠<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿ولا تقربوا مال اليتيم إلا بالتي هي أحسن﴾</span>، قال: الأكل بالمعروف؛ أن تأكل معه إذا احتجت إليه. كان <b>أبي</b>{4} يقول ذلك{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٣٠٧١<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: قوله: <span class="qpc-hafs">﴿ولا تقربوا مال اليتيم إلا بالتي هي أحسن﴾</span>، والتي هي أحسن: أن يوفر ماله، حتى إذا بلغ أشده دفع إليه ماله إن آنس منه رشدًا{6}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿حَتَّىٰ یَبۡلُغَ أَشُدَّهُۥۚ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٣٠٧٢<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span> -من طريق عطاء بن دينار- قال: <span class="qpc-hafs">﴿ولا تقربوا مال اليتيم إلا بالتي هي أحسن حتى يبلغ أشده﴾</span> [الأنعام:١٥٢]، أي: ثماني عشرة سنة. ومثلها في سورة بني إسرائيل{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٣٠٧٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿حتى يبلغ أشده﴾</span>، يعني: ثماني عشرة سنة{3}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿حَتَّىٰ یَبۡلُغَ أَشُدَّهُۥۚ﴾</span> - النسخ في الآية</h3></p><p><div></p><p><p><span class="item-no">٤٣٠٧٤<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- قال: لَمّا نزلت هذه الآية اشتدَّت عليهم، فكانوا لا يخالطونهم في المال، ولا في المأكل، فجَهَدَهم ذلك، فنسختها هذه الآية: <span class="qpc-hafs">﴿وإن تخالطوهم فإخوانكم والله يعلم المفسد من المصلح﴾</span> [البقرة:٢٢٠]{9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٣٠٧٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: نسختها: <span class="qpc-hafs">﴿وإن تخالطوهم فإخوانكم﴾</span>{3}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَأَوۡفُوا۟ بِٱلۡعَهۡدِۖ إِنَّ ٱلۡعَهۡدَ كَانَ مَسۡـُٔولࣰا ۝٣٤﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٣٠٧٦<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span>، في قوله: <span class="qpc-hafs">﴿إن العهد كان مسئولًا﴾</span>، قال: يسأل اللهُ ناقضَ العهد عن نقضه{11}. (٩/٣٤٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٣٠٧٧<span class="dash">-</span></span> عن <span class="name-2">ميمون بن مِهران</span>، قال: ثلاث تُؤَدّى إلى البَرِّ والفاجر: العهد يُوفى إلى البرِّ والفاجر. وقرأ: <span class="qpc-hafs">﴿وأوفوا بالعهد إن العهد كان مسئولًا﴾</span>{11}. (٩/٣٤٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٣٠٧٨<span class="dash">-</span></span> قال <span class="name-2">إسماعيل السُّدِّيّ</span>، في قوله: <span class="qpc-hafs">﴿إن العهد كان مسئولا﴾</span>: كان مطلوبًا{13}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٣٠٧٩<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span>، في قوله: <span class="qpc-hafs">﴿وأوفوا بالعهد إن العهد كان مسئولًا﴾</span>، قال: يوم أُنزلت هذه كان إنما يُسألُ عنه، ثم يَدْخُلُ الجنةَ، فنزلت: <span class="qpc-hafs">﴿إن الذين يشترون بعهد الله وأيمانهم ثمنًا قليلًا أولئك لا خلاق لهم في الآخرة﴾</span> [آل عمران:٧٧]{14}. (٩/٣٤٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٣٠٨٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وأوفوا بالعهد﴾</span> فيما بينكم وبين الناس؛ <span class="qpc-hafs">﴿إن العهد﴾</span> إذا نُقِض <span class="qpc-hafs">﴿كان مسؤولا﴾</span> يقول: الله سائلكم عنه في الآخرة{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٣٠٨١<span class="dash">-</span></span> عن <span class="name-3">عبد الملك ابن جريج</span>، في قوله: <span class="qpc-hafs">﴿إن العهد كان مسئولًا﴾</span>، قال: يسأل عهدَه مَن أعطاه إيّاه{16}. (٩/٣٤٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٣٠٨٢<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: قوله: <span class="qpc-hafs">﴿وأوفوا بالعهد﴾</span> يعني: ما عاهدتم عليه فيما وافق الحق؛ <span class="qpc-hafs">﴿إن العهد كان مسئولا﴾</span> مطلوبًا، يُسْأَل عنه أهلُه الذين أعطوه{17}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَأَوۡفُوا۟ بِٱلۡعَهۡدِۖ إِنَّ ٱلۡعَهۡدَ كَانَ مَسۡـُٔولࣰا ۝٣٤﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٤٣٠٨٣<span class="dash">-</span></span> عن <span class="name-2">كعب الأحبار</span>، قال: مَن نكث بيعة كانت سِترًا بينه وبين الجنة. قال: وإنما تَهلِكُ هذه الأُمَّة بنَكثِها عُهُودَها{11}. (٩/٣٤٣)</p></p><p></div></p></div>",footnotes:1:علقه النحاس في ناسخه ٢/٤٩٥.|2:أخرجه ابن جرير ١٤/٥٩٠.|3:تفسير مقاتل بن سليمان ٢/٥٣٠.|4:ضبطت في طبعة «هجر» ١٤/٥٩٠ بضم الهمزة وفتح الباء وتشديد الياء: أُبَيٌّ!|5:أخرجه ابن جرير ١٤/٥٩٠.|6:تفسير يحيى بن سلام ١/١٣٤.|7:أخرجه الطحاوي في شرح معاني الآثار ٣/٢٢٠.|8:تفسير مقاتل بن سليمان ٢/٥٣٠.|9:أخرجه يحيى بن سلام ١/١٣٤، وابن جرير ١٤/٥٩٠ بنحوه، والنحاس في ناسخه ٢/٤٩٥.|10:تفسير مقاتل بن سليمان ٢/٥٣٠.|11:عزاه السيوطي إلى ابن أبي حاتم.|12:عزاه السيوطي إلى ابن أبي حاتم.|13:تفسير البغوي ٥/٩٢.|14:عزاه السيوطي إلى ابن أبي حاتم. وينظر: تفسير السدي لقوله تعالى: <span class="qpc-hafs">﴿ولا تقف ما ليس لك به علم﴾</span> فيما يأتي.|15:تفسير مقاتل بن سليمان ٢/٥٣٠.|16:عزاه السيوطي إلى ابن المنذر.|17:تفسير يحيى بن سلام ١/١٣٥.|18:عزاه السيوطي إلى ابن أبي حاتم.
  17,35,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَأَوۡفُوا۟ ٱلۡكَیۡلَ إِذَا كِلۡتُمۡ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٣٠٨٤<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span>، في قوله: <span class="qpc-hafs">﴿وأوفوا الكيل إذا كِلتم﴾</span>: يعني: لغيركم{1}. (٩/٣٤٣)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَزِنُوا۟ بِٱلۡقِسۡطَاسِ ٱلۡمُسۡتَقِیمِۚ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٣٠٨٥<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span>، في قوله: <span class="qpc-hafs">﴿وزنوا بالقسطاس المستقيم﴾</span>، يعني: الميزان، وبلغة الروم الميزان: القسطاس{1}. (٩/٣٤٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٣٠٨٦<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق جابر- قال: القسطاس: العدل، بالرُّوميَّة{3}<span class=comment-ref>٣٨٣٨</span>. (٩/٣٤٤)</p></p><p></div></p><p><div><span class=comment-ref>٣٨٣٨</span> <span class="comment-type-1">وجَّه</span> <u>ابن عطية</u> (٥/٤٧٧) قول مجاهد بقوله: «فكأن الناس قيل لهم: زِنوا بمعدلةٍ في وزنكم».</div></p><p><div></p><p><p><span class="item-no">٤٣٠٨٧<span class="dash">-</span></span> عن <span class="name-2">الضحاك بن مزاحم</span>، <span class="qpc-hafs">﴿وزنوا بالقسطاس﴾</span>، قال: القَبّانِ{4}{5}. (٩/٣٤٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٣٠٨٨<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق الحسن بن ذكوان- <span class="qpc-hafs">﴿وزنوا بالقسطاس﴾</span>، قال: القَبّان{6}. (٩/٣٤٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٣٠٨٩<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق مبارك- <span class="qpc-hafs">﴿وزنوا بالقسطاس﴾</span>، قال: بالحديد{7}. (٩/٣٤٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٣٠٩٠<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿وزنوا بالقسطاس﴾</span>، قال: العدل{8}. (٩/٣٤٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٣٠٩١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وزنوا بالقسطاس﴾</span>، يعني: بالميزان، بلغة الروم{9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٣٠٩٢<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: قوله: <span class="qpc-hafs">﴿وزنوا بالقسطاس المستقيم﴾</span>، والقسطاس: العدل، بالرومية{10}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿ذَ ٰ⁠لِكَ خَیۡرࣱ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٣٠٩٣<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span>، في قوله: <span class="qpc-hafs">﴿ذلك خير﴾</span>، يعني: وفاء الكيل والميزان خيرٌ من النقصان{1}. (٩/٣٤٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٣٠٩٤<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿ذلك خير﴾</span>، أي: خيرٌ ثوابًا{12}. (٩/٣٤٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٣٠٩٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ذلك﴾</span> الوفاء <span class="qpc-hafs">﴿خير﴾</span> مِن النُّقصان{13}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٣٠٩٦<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: قوله: <span class="qpc-hafs">﴿ذلك خير﴾</span> إذا أوفيتم الكيل، وأقمتم الوزن{10}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَأَحۡسَنُ تَأۡوِیلࣰا ۝٣٥﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٣٠٩٧<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span>، في قوله: <span class="qpc-hafs">﴿وأحسن تأويلًا﴾</span>: عاقبة{1}. (٩/٣٤٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٣٠٩٨<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿وأحسن تأويلًا﴾</span>، أي: وعاقبة{16}<span class=comment-ref>٣٨٣٩</span>. (٩/٣٤٤)</p></p><p></div></p><p><div><span class=comment-ref>٣٨٣٩</span> ذكر <u>ابنُ عطية</u> (٥/٤٧٧) في معنى: «التأويل» <b>احتمالًا</b> آخر، فقال: «ويحتمل أن يكون»التأويل«مصدر تأوَّل، أي: يتأول عليكم الخير في جميع أموركم إذا أحسنتم في الكيل والوزن».</div></p><p><div></p><p><p><span class="item-no">٤٣٠٩٩<span class="dash">-</span></span> تفسير <span class="name-2">إسماعيل</span> <span class="name-2">السُّدِّيّ</span>: <span class="qpc-hafs">﴿وأحسن تأويلا﴾</span>، يعني: عاقبة في الآخرة{17}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٣١٠٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وأحسن تأويلا﴾</span>، يعني: وخير عاقبة في الآخرة{13}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَأَحۡسَنُ تَأۡوِیلࣰا ۝٣٥﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٤٣١٠١<span class="dash">-</span></span> قال قتادة: وأُخبِرنا أن <span class="name-1">عبد الله بن عباس</span> كان يقول: يا معشر الموالي، إنكم ولِيتُم أمرين بهما هلك الناس قبلَكم؛ هذا المكيال، وهذا الميزان. قال: وذُكِر لنا: أنّ نبي الله ﷺ كان يقول: «<b>لا يقدر رجل على حرام ثم يدعه، ليس به إلا مخافة الله؛ إلا أبدله الله في عاجل الدنيا قبل الآخرة ما هو خيرٌ له من ذلك</b>»{19}. (٩/٣٤٤)</p></p><p></div></p></div>",footnotes:1:عزاه السيوطي إلى ابن أبي حاتم.|2:عزاه السيوطي إلى ابن أبي حاتم.|3:أخرجه يحيى بن سلام ٢/٥٢٢، والفريابي -كما في التغليق ٥/٣٨٢-٣٨٣-، وابن أبي شيبة ١٠/٤٧١-٤٧٢، وابن جرير ١٤/٥٩٢ من طريق ابن جريج، وابن أبي حاتم ٩/٢٨١٢. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.|4:القبان: الذي يوزن به. لسان العرب (قبن).|5:عزاه السيوطي إلى ابن المنذر.|6:أخرجه ابن جرير ١٤/٥٩١، وابن أبي حاتم ٩/٢٨١٢ من طريق عمرو. وعزاه السيوطي إلى عبد بن حميد.|7:أخرجه ابن أبي حاتم ٩/٢٨١٢.|8:أخرجه ابن أبي حاتم ٩/٢٨١٢. وعلقه يحيى بن سلام ٢/٥٢٢. وعزاه السيوطي إلى عبد بن حميد.|9:تفسير مقاتل بن سليمان ٢/٥٣٠، ٣/٢٧٨.|10:تفسير يحيى بن سلام ١/١٣٥.|11:عزاه السيوطي إلى ابن أبي حاتم.|12:أخرجه يحيى بن سلام ١/١٣٥، وابن جرير ١٤/٥٩٣. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.|13:تفسير مقاتل بن سليمان ٢/٥٣٠.|14:تفسير يحيى بن سلام ١/١٣٥.|15:عزاه السيوطي إلى ابن أبي حاتم.|16:أخرجه يحيى بن سلام ١/١٣٥، وعبد الرزاق في تفسيره ١/٥٩٣ من طريق معمر بلفظ: عاقبة وثوابًا، وابن جرير ١٤/٥٩٣، ومن طريق معمر أيضًا بلفظ: عاقبة وثوابًا. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.|17:علقه يحيى بن سلام ١/١٣٥.|18:تفسير مقاتل بن سليمان ٢/٥٣٠.|19:أخرجه ابن جرير ١٤/٥٩٣. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.
  17,36,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَلَا تَقۡفُ مَا لَیۡسَ لَكَ بِهِۦ عِلۡمٌۚ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٣١٠٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- في قوله: <span class="qpc-hafs">﴿ولا تقف﴾</span>، قال: لا تَقُل{1}. (٩/٣٤٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٣١٠٣<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق العوفي- في قوله: <span class="qpc-hafs">﴿ولا تقف ما ليس لك به علم﴾</span>، يقول: لا تَرمِ أحدًا بما ليس لك به علم{2}. (٩/٣٤٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٣١٠٤<span class="dash">-</span></span> عن <span class="name-2">محمد ابن الحنفية</span> -من طريق أبي عمر البزار- في قوله: <span class="qpc-hafs">﴿ولا تقف ما ليس لك به علم﴾</span>، قال: شهادة الزور{3}. (٩/٣٤٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٣١٠٥<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿ولا تقف﴾</span>، يقول: ولا تَرْم{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٣١٠٦<span class="dash">-</span></span> تفسير <span class="name-2">الحسن [البصري]</span>: لا تقْف أخاك المسلم من بعده إذا مَرَّ بك، فتقول: إني رأيت هذا يفعل كذا، ورأيته يفعل كذا، وسمعته يقول كذا، لم تسمع ولم تر{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٣١٠٧<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿ولا تقف ما ليس لك به علم﴾</span>، قال: لا تقل: سمعتُ؛ ولم تسمع، ولا تقل: رأيتُ؛ ولم تر، فإنّ الله سائِلُك عن ذلك كلِّه{6}. (٩/٣٤٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٣١٠٨<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span>، في قوله: <span class="qpc-hafs">﴿ولا تقف ما ليس لك به علم﴾</span>، قال: هذا في الفِرْية، يوم نزلت الآية لم يكن فيها حَدٌّ، إنّما كان يُسأل عنه يوم القيامة، ثم يُغفر له، حتى نزلت آية الفِرية؛ جلد ثمانين{7}. (٩/٣٤٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٣١٠٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ولا تقف ما ليس لك به علم﴾</span>، يقول: ولا ترمِ بالشرك؛ فإنّه ليس لك به علم أنّ لي شريكًا{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٣١١٠<span class="dash">-</span></span> عن محمد بن أبي تميلة، قال: سمعت <span class="name-3">الفضيل بن عياض</span> يقول: ليس لأحد أن يقول ما لا يعلم، أو يسمع إلى ما شاء، أو يهوى ما شاء؛ لأن الله ﷿ يقول: <span class="qpc-hafs">﴿ولا تقف ما ليس لك به علم إن السمع والبصر والفؤاد كل أولئك كان عنه مسئولا﴾</span>، ولا تفعل، يقول: ولا تقل{9}<span class=comment-ref>٣٨٤٠</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٣٨٤٠</span> اختُلِف في معنى: <span class="qpc-hafs">﴿ولا تَقْفُ ما لَيْسَ لَكَ بِهِ عِلْمٌ﴾</span> في هذه الآية على قولين: <b>الأول:</b> ولا تَقُلْ ما ليس لك به علم. <b>الثاني:</b> لا تَرْمِ أحدًا بما ليس لك به علم.</p><p>و<span class="comment-type-3">رجَّح</span> <u>ابنُ جرير</u> (١٤/٥٩٥) شمول الآية للمعنيين <span class="mustanad">مستندًا إلى دلالة العموم</span>، وعلَّل ذلك بقوله: «لأن القول بما لا يعلمه القائل يدخل فيه شهادة الزور، ورَمْيُ الناس بالباطل، وادعاءُ سماع ما لم يَسْمَعْهُ ورؤية ما لم يَرَهُ».</p><p>و<span class="comment-type-4">ذكر</span> <u>ابنُ جرير</u> (١٤/٥٩٥) أن أصل القَفْو: «العَضَهُ والبَهْتُ، ومنه قول النبي ﷺ: «<b>نحن بنو النضر بن كنانة لا نَقْفُو أُمَّنا، ولا نَنتَفي من أبِينا</b>»». ثم نقل عن بعض اللغويين أن معنى قوله: <span class="qpc-hafs">﴿ولا تَقْفُ﴾</span>: لا تَتَّبِعْ ما لا تعلم ولا يَعْنِيك، وأن أصله القيافة، وهي اتَّباع الأثر.</p><p>ثم <span class="comment-type-3">رجَّح</span> (١٤/٥٩٦) <span class="mustanad">مستندًا إلى الأغلب من لغة العرب</span> ما ذهب إليه من أن معنى: <span class="qpc-hafs">﴿ولا تَقْفُ﴾</span>: «لا تَقُلْ للناس وفيهم ما لا علم لك به، فَتَرْمِيَهم بالباطل، وتَشْهَدَ عليهم بغير الحق، فذلك هو القَفْوُ». وعلَّل ذلك بقوله: «لأن ذلك هو الغالب من استعمال العرب القَفْوَ فيه».</div></p><p><h3><span class="qpc-hafs">﴿إِنَّ ٱلسَّمۡعَ وَٱلۡبَصَرَ وَٱلۡفُؤَادَ كُلُّ أُو۟لَـٰۤىِٕكَ كَانَ عَنۡهُ مَسۡـُٔولࣰا ۝٣٦﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٣١١١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، في قوله: <span class="qpc-hafs">﴿كل أولئك كان عنه مسئولًا﴾</span>، قال: يوم القيامة؛ يقال: أكذلك كان أم لا؟{10}. (٩/٣٤٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٣١١٢<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span>، في قوله: <span class="qpc-hafs">﴿إن السمع والبصر والفؤاد كلُّ أولئك كان عنه مسئولًا﴾</span>، يقول: سمعُه وبصرُه يشهَدُ عليه{7}. (٩/٣٤٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٣١١٣<span class="dash">-</span></span> عن <span class="name-3">عمرو بن قيس</span>{12}، في قوله: <span class="qpc-hafs">﴿كل أولئك كان عنه مسئولًا﴾</span>، قال: يُقال للأُذُن يوم القيامة: هل سمعتِ؟ ويُقال للعين: هل رأيتِ؟ ويُقال للفؤاد مثل ذلك{7}. (٩/٣٤٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٣١١٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثم حذرهم <span class="qpc-hafs">﴿إن السمع والبصر والفؤاد﴾</span> يعني: القلب، <span class="qpc-hafs">﴿كل أولئك كان عنه مسؤولا﴾</span> يعني: عن الشرك مسئولًا في الآخرة{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٣١١٥<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿كل أولئك﴾</span> كل ذلك <span class="qpc-hafs">﴿كان عنه مسئولا﴾</span> يُسأل السمع على حدة عما سمع، ويُسأل البصر على حدة عما بصر، ويُسأل القلب عمّا عزم عليه{15}<span class=comment-ref>٣٨٤١</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٣٨٤١</span> ذكر <u>ابنُ عطية</u> (٥/٤٨٠) احتمالين آخرين لعود الضمير في <span class="qpc-hafs">﴿عَنْهُ﴾</span>، فقال: «والضمير في <span class="qpc-hafs">﴿عنه﴾</span> يعود على ما ليس للإنسان به علم، ويكون المعنى: أن الله تعالى يسأل سمع الإنسان وبصره وفؤاده عما قال مما لا علم له به، فيقع تكذيبه من جوارحه، وتلك غاية الخزي. و<b>يحتمل</b> أن يعود الضمير في <span class="qpc-hafs">﴿عَنْهُ﴾</span> على <span class="qpc-hafs">﴿كُلُّ﴾</span> التي هي للسمع والبصر والفؤاد، والمعنى: أن الله تعالى يسأل الإنسان عما حواه سمعه وبصر وفؤاده». ثم <span class="comment-type-1">وجَّهه</span> بقوله: «فكأنه قال: كل هذه كان الإنسان عنه مسؤولًا، أي: عما حصل لهؤلاء من الإدراكات، ووقع منها من الخطايا، فالتقدير: عن أعمالها مسؤولًا. فهو على حذف مضاف».</div></p></div>",footnotes:1:أخرجه ابن جرير ١٤/٥٩٣، وابن أبي حاتم -كما في التغليق ٤/٢٤٢-. وفي تفسير الثعلبي ٦/٩٨: لا تقل: رأيتُ؛ ولم تر، وسمعتُ؛ ولم تسمعه، وعلمتُ؛ ولم تعلمه.|2:أخرجه ابن جرير ١٤/٥٩٤.|3:أخرجه ابن أبي شيبة ٧/٢٥٨، وابن جرير ١٤/٥٩٤. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.|4:أخرجه ابن جرير ١٤/٥٩٥.|5:علقه يحيى بن سلام ١/١٣٥.|6:أخرجه يحيى بن سلام ١/١٣٥، وعبد الرزاق ١/٣٧٨ من طريق معمر، وابن جرير ١٤/٥٩٤ من طريق معمر أيضًا بنحوه. وعزاه السيوطي إلى ابن أبي حاتم.|7:عزاه السيوطي إلى ابن أبي حاتم.|8:تفسير مقاتل بن سليمان ٢/٥٣٠.|9:أخرجه البيهقي في الزهد الكبير ص٣٤١ (٩٣٢).|10:عزاه السيوطي إلى الفريابي.|11:عزاه السيوطي إلى ابن أبي حاتم.|12:يحتمل أن يكون عمرو بن قيس السكوني الحمصي (ت١٤٠)، أو عمرو بن قيس الملائي (ت١٤٥).|13:عزاه السيوطي إلى ابن أبي حاتم.|14:تفسير مقاتل بن سليمان ٢/٥٣٠.|15:تفسير يحيى بن سلام ١/١٣٥.
  17,37,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَلَا تَمۡشِ فِی ٱلۡأَرۡضِ مَرَحًاۖ إِنَّكَ لَن تَخۡرِقَ ٱلۡأَرۡضَ وَلَن تَبۡلُغَ ٱلۡجِبَالَ طُولࣰا ۝٣٧﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٣١١٦<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- في قوله: <span class="qpc-hafs">﴿ولا تمش في الأرض مرحًا﴾</span>، قال: لا تمش فخرًا وكبرًا؛ فإن ذلك لا يبلُغُ بك الجبال، ولا أن تخرِقَ الأرض بفخرك وكبرك{1}. (٩/٣٤٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٣١١٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ولا تمش في الأرض مرحا﴾</span> يعني: بالعظمة، والخيلاء، والكبرياء؛ <span class="qpc-hafs">﴿إنك لن تخرق الأرض﴾</span> إذا مشيت بالخيلاء والكبرياء، <span class="qpc-hafs">﴿ولن تبلغ﴾</span> رأسك <span class="qpc-hafs">﴿الجبال طولا﴾</span> إذا تكبَّرْت{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٣١١٨<span class="dash">-</span></span> عن <span class="name-3">عبد الملك ابن جريج</span> -من طريق حجاج- <span class="qpc-hafs">﴿ولا تمش في الأرض﴾</span>، قال: لا تفخر{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٣١١٩<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: قوله: <span class="qpc-hafs">﴿ولا تمش في الأرض﴾</span> يعني: على الأرض <span class="qpc-hafs">﴿مرحا﴾</span> كما يمشي المشركون، فتمرح في الأرض. وهي مثل قوله: <span class="qpc-hafs">﴿ذلكم بما كنتم تفرحون في الأرض بغير الحق وبما كنتم تمرحون﴾</span> [غافر:٧٥]، وكقوله: <span class="qpc-hafs">﴿وفرحوا بالحياة الدنيا﴾</span> [الرعد:٢٦]، يعني: المشركين لا يفرحون بالآخرة. وقال: <span class="qpc-hafs">﴿إنك لن تخرق الأرض﴾</span> بقدمك إذا مشيت، <span class="qpc-hafs">﴿ولن تبلغ الجبال طولا﴾</span>{4}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَلَا تَمۡشِ فِی ٱلۡأَرۡضِ مَرَحًاۖ إِنَّكَ لَن تَخۡرِقَ ٱلۡأَرۡضَ وَلَن تَبۡلُغَ ٱلۡجِبَالَ طُولࣰا ۝٣٧﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٤٣١٢٠<span class="dash">-</span></span> عن يُحنَّسَ، قال: قال رسول الله ﷺ: «<b>إذا مَشَت أمَّتي المُطَيطاءَ</b>{5}، <b>وخَدَمَتهم فارسُ والروم؛ سُلِّط بعضهم على بعض</b>»{6}. (٩/٣٤٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٣١٢١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عمر</span> -من طريق جميل بن زيد-: أنّه رأى رجلًا يَخطِرُ في مِشيَتِه، فقال: إنّ للشيطان إخوانًا{7}. (٩/٣٤٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٣١٢٢<span class="dash">-</span></span> عن <span class="name-2">خالد بن مَعْدان</span> -من طريق ثور- قال: إيّاكم والخَطرَ؛ فإن الرجل قد تُنافقُ يدُه من دون سائر جسده{8}. (٩/٣٤٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٣١٢٣<span class="dash">-</span></span> عن أبي بكر الهذلي، قال: بينما نحن مع <span class="name-2">الحسن البصري</span> إذ مرَّ عليه ابن الأهتم يريد المَقْصُورَةَ{9}، وعليه جِبابُ خَزٍّ قد نُضِّدَ بعضها فوق بعض على ساقه، فانفرج عنها قِباؤُه{10}، وهو يمشي يتبختر، إذ نظر إليه الحسن نظرة، فقال: أفٍّ لك، شامخ بأنفه، ثاني عطفه، مصعِّر خده، ينظر في عطفيه، أيْ حُمَيْقٍ، أنت تنظر في عطفيك في نِعَمٍ غير مشكورة ولا مذكورة، غير المأخوذ بأمر الله ﷿ فيها، ولا المؤدي حق الله منها، واللهِ، إن يمشي أحدهم طبيعته أن يَتَخَلَّجَ{11} تَخلُّجَ المجنون، في كل عضو من أعضائه لله نعمة، وللشيطان به لعنة. فسمع ابن الأهتم، فرجع يعتذر، فقال: لا تعتذر إليَّ، وتُبْ إلى ربك، أما سمعت قول الله ﷿: <span class="qpc-hafs">﴿ولا تمش في الأرض مرحا إنك لن تخرق الأرض ولن تبلغ الجبال طولا﴾</span>؟!{12}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه عبد الرزاق ١/٣٧٨، وابن جرير ١٤/٥٩٨، كما أخرجه من طريق سعيد مختصرًا. وعزاه السيوطي إلى ابن أبي حاتم.|2:تفسير مقاتل بن سليمان ٢/٥٣١.|3:أخرجه ابن جرير ١٤/٥٩٨.|4:تفسير يحيى بن سلام ١/١٣٥-١٣٦.|5:المطيطاء: التبختر. التاج (مطط).|6:أخرجه ابن أبي الدنيا في كتاب التواضع (٢٤٩). والحديث عند الترمذي (٢٢٦١) من حديث ابن عمر.</p><p>وصححه الألباني في السلسلة الصحيحة (٩٥٦).|7:أخرجه ابن أبي الدنيا في كتاب التواضع والخمول (٢٤٦)، وفيه: يجر إزاره. بدلًا من: يخطر في مشيته.|8:أخرجه ابن أبي الدنيا في كتاب التواضع والخمول (٢٤٧).|9:المَقْصُورة: الدار الواسعة المُحَصَّنَة. لسان العرب (قصر).|10:القباء –ممدود-: من الثياب. لسان العرب (قبا).|11:الاختلاج: الحركة والاضطراب. النهاية (خلج).|12:أخرجه ابن أبي الدنيا في كتاب التواضع والخمول (٢٣٧).
  17,38,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿كُلُّ ذَ ٰ⁠لِكَ كَانَ سَیِّئُهُۥ عِندَ رَبِّكَ مَكۡرُوهࣰا ۝٣٨﴾</span> - قراءات الآية، وتفسيرها</h3></p><p><div></p><p><p><span class="item-no">٤٣١٢٤<span class="dash">-</span></span> عن <span class="name-2">ابن كثير المكي</span> أنه كان يقرأ: ‹كُلُّ ذَلِكَ كانَ سَيِّئَةً عِندَ رَبِّكَ مَكْرُوهًا› على واحدٍ. يقول: هذه الأشياء التي نُهِيتَ عنها كلُّها سيئة{1}. (٩/٣٤٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٣١٢٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿كُلُّ ذَلِكَ﴾</span> يعني: كل ما أمر الله ﷿ به، ونهى عنه في هؤلاء الآيات، <span class="qpc-hafs">﴿كانَ سَيِّئُهُ﴾</span> يعني: ترك ما أمر الله ﷿ به، ونهى عنه في هؤلاء الآيات، أي: وركوب ما نهى عنه، كان <span class="qpc-hafs">﴿عِندَ رَبِّكَ مَكْرُوهًا﴾</span>{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٣١٢٦<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: وقال: <span class="qpc-hafs">﴿كُلُّ ذَلِكَ كانَ سَيِّئُهُ﴾</span> في قراءة مَن قرأها بالرفع <span class="qpc-hafs">﴿عِندَ رَبِّكَ مَكْرُوهًا﴾</span> يقول: سيء ذلك الفعل. ومن قرأها بالنصب يقول: كل ذلك كان سيئةً –مهموزة-؛ يوجب أنها سيئة <span class="qpc-hafs">﴿عِندَ رَبِّكَ مَكْرُوهًا﴾</span> وهي قراءة المكي، ذكره حماد بن سلمة{3}<span class=comment-ref>٣٨٤٢</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٣٨٤٢</span> اختلفت القرأة في قراءة قوله تعالى: <span class="qpc-hafs">﴿كُلُّ ذَلِكَ كانَ سَيِّئُهُ عِنْدَ رَبِّكَ مَكْرُوهًا﴾</span> على قراءتين، وقد ذكرهما <u>ابن جرير</u> (١٤/٥٩٩) فقال: <b>الأولى:</b> <span class="qpc-hafs">﴿كلُّ ذلك كان سَيِّئُهُ﴾</span> على الإضافة، و<span class="comment-type-1">وجَّهوا</span> قراءتهم بقولهم: «لأن فيما عدَّدْنا من قوله: <span class="qpc-hafs">﴿وقَضى رَبُّكَ ألا تَعْبُدُوا إلا إيّاهُ﴾</span> أمورًا، هي أمْرٌ بالجميل، كقوله: <span class="qpc-hafs">﴿وبِالوالِدَيْنِ إحْسانًا﴾</span>، وقوله: <span class="qpc-hafs">﴿وآتِ ذا القُرْبى حَقَّهُ﴾</span>، وما أشبه ذلك. قالوا: فليس كل ما فيه نهيًا عن سيئةٍ، بل فيه نهيٌ عن سيئةٍ، وأَمْرٌ بحسنات، فلذلك قرأنا: <span class="qpc-hafs">﴿سَيِّئُهُ﴾</span>». <b>الثانية:</b> ‹كلُّ ذلك كان سَيِّئَةً› بالتنوين، والمعنى عند من قرأها كذلك: «أن الله إنما عَنى بذلك: كلُّ ما عدَّدْنا من قولنا: <span class="qpc-hafs">﴿ولا تَقْتُلُوا أوْلادَكُمْ خَشْيَةَ إمْلاقٍ﴾</span>، ولم يدخل فيه ما قَبْل ذلك، قالوا: وكلُّ ما عدَّدنا من ذلك الموضع إلى هذا الموضع سيِّئَةٌ لا حسنة فيه».</p><p>و<span class="comment-type-1">وجَّه</span> <u>ابنُ عطية</u> (٥/٤٨٢) اسم الإشارة <span class="qpc-hafs">﴿ذلك﴾</span> على القراءة الأولى بقوله: «والإشارة إلى جميع ما ذكر في هذه الآيات من بِرٍّ ومعصية، ثم اختَصَّ ذكر السَّيِّء منه بأنه مكروه عند الله تعالى». و<span class="comment-type-1">وجَّهه</span> على القراءة الثانية بقوله: «والإشارة إلى ما تقدم ذكره مما نهي عنه كقول: أُفٍّ، وقَذْف الناس، والمرح، وغير ذلك».</p><p>و<span class="comment-type-4">بمعناه</span> <u>ابنُ كثير</u> (٩/١٣).</p><p>و<span class="comment-type-3">رجَّح</span> <u>ابنُ جرير</u> (١٤/٦٠٠) <span class="mustanad">مستندًا إلى دلالة اللغة</span> القراءة الأولى، وعلَّل ذلك بقوله: «لأنّ في ذلك أمورًا منهيًّا عنها، وأمورًا مأمورًا بها، وابتداءُ الوصية والعهد من ذلك الموضع دون قوله: <span class="qpc-hafs">﴿ولا تَقْتُلُوا أوْلادَكُمْ﴾</span> إنما هو عطفٌ على ما تقدم من قوله: <span class="qpc-hafs">﴿وقَضى رَبُّكَ ألا تَعْبُدُوا إلا إيّاهُ﴾</span>، فإذ كان ذلك كذلك فقراءتُه بإضافة السيِّء إلى الهاء أوْلى وأحقُّ من قراءته ‹سَيِّئَةً› بالتنوين، بمعنى السيئةٍ الواحدة».</p><p>و<span class="comment-type-2">استدرك</span> <u>ابنُ عطية</u> (٥/٤٨٣) على <u>ابن جرير</u> في قوله: بـ«أن هذه النواهي كلها معطوفة على قوله أولًا: <span class="qpc-hafs">﴿وقَضى رَبُّكَ ألا تَعْبُدُوا إلا إيّاهُ﴾</span>» قائلًا: «وليس ذلك بالبيِّن».</div></p></div>",footnotes:1:عزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.</p><p>وهي قراءة متواترة، قرأ بها نافع، وابن كثير، وأبو عمرو، وأبو جعفر، ويعقوب، وقرأ بقية العشرة: <span class="qpc-hafs">﴿سَيِّئُهُ﴾</span> بضم الهمزة والهاء وإلحاقها واوًا في اللفظ. انظر: النشر ٢/٣٠٧، والإتحاف ص٣٥٧.|2:تفسير مقاتل بن سليمان ٢/٥٣١.|3:تفسير يحيى بن سلام ١/١٣٦.