quran[8]{c,v,t}:
  29,31,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَلَمَّا جَاۤءَتۡ رُسُلُنَاۤ إِبۡرَ ٰ⁠هِیمَ بِٱلۡبُشۡرَىٰ قَالُوۤا۟ إِنَّا مُهۡلِكُوۤا۟ أَهۡلِ هَـٰذِهِ ٱلۡقَرۡیَةِۖ إِنَّ أَهۡلَهَا كَانُوا۟ ظَـٰلِمِینَ ۝٣١﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٩٨٥٧<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطية العوفي- قوله: <span class="qpc-hafs">﴿ولما جاءت رسلنا إبراهيم بالبشرى﴾</span> إلى قوله: <span class="qpc-hafs">﴿نحن أعلم بمن فيها﴾</span>، قال: فجادل إبراهيمُ الملائكة في قوم لوط أن يُترَكوا. قال: فقال: أرأيتم إن كان فيها عشرة أبيات مِن المسلمين، أتتركونهم؟ فقالت الملائكة: ليس فيها عشرة أبيات، ولا خمسة، ولا أربعة، ولا ثلاثة، ولا اثنان. قال: فحزن على لوط وأهل بيته، فقال: <span class="qpc-hafs">﴿إن فيها لوطا قالوا نحن أعلم بمن فيها لننجينه وأهله إلا امرأته كانت من الغابرين﴾</span>. فذلك قوله: <span class="qpc-hafs">﴿يجادلنا في قوم لوط، إن إبراهيم لحليم أواه منيب﴾</span> [هود:٧٤-٧٥]. فقالت الملائكة: <span class="qpc-hafs">﴿يا إبراهيم أعرض عن هذا إنه قد جاء أمر ربك وإنهم آتيهم عذاب غير مردود﴾</span> [هود:٧٦]. فبعث الله إليهم جبريل ﷺ، فانتَسَف المدينة وما فيها بأحد جناحيه، فجعل عاليها سافلها، وتتبَّعَتهم الحجارة بكل أرض{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٩٨٥٨<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- قوله: <span class="qpc-hafs">﴿بالبشرى﴾</span>، قال: حين أخبروه أنهم أُرسِلوا إلى قوم لوط{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٩٨٥٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ولما جاءت رسلنا﴾</span> يعني: الملائكة <span class="qpc-hafs">﴿إبراهيم بالبشرى﴾</span> بالولد؛ <span class="qpc-hafs">﴿قالوا﴾</span> لإبراهيم: <span class="qpc-hafs">﴿إنا مهلكوا أهل هذه القرية﴾</span> يعنون: قرية لوط، <span class="qpc-hafs">﴿إن أهلها كانوا ظالمين﴾</span>{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٩٨٦٠<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: قال الله: <span class="qpc-hafs">﴿ولما جاءت رسلنا﴾</span> يعني: الملائكة <span class="qpc-hafs">﴿إبراهيم بالبشرى﴾</span> بإسحاق، وذلك أنّ الملائكة لما بُعِثَت إلى قوم لوط بعذابهم مَرُّوا بإبراهيم، فسألوه الضيافة، فلما أخبروه أنهم أُرسِلوا بعذاب قوم لوط بعد ما بشروه بإسحاق <span class="qpc-hafs">﴿قالوا إنا مهلكو أهل هذه القرية﴾</span> يعني: قوم لوط؛ <span class="qpc-hafs">﴿إن أهلها كانوا ظالمين﴾</span> يعني: مشركين{4}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ١٨/٣٩٣، وابن أبي حاتم ٩/٣٠٥٥ مختصرًا.|2:أخرجه ابن أبي حاتم ٩/٣٠٥٥.|3:تفسير مقاتل بن سليمان ٣/٣٨١.|4:تفسير يحيى بن سلّام ٢/٦٢٧-٦٢٨.
  29,32,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿قَالَ إِنَّ فِیهَا لُوطࣰاۚ قَالُوا۟ نَحۡنُ أَعۡلَمُ بِمَن فِیهَاۖ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٩٨٦١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطية العوفي- قوله: <span class="qpc-hafs">﴿قال إن فيها لوطا قالوا نحن أعلم بمن فيها﴾</span>، قال: فحزن إبراهيم ﷺ على لوط وأهل بيته، فقال: <span class="qpc-hafs">﴿إن فيها لوطا﴾</span>. فقالوا: <span class="qpc-hafs">﴿نحن أعلم بمن فيها﴾</span>{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٩٨٦٢<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- في قوله: <span class="qpc-hafs">﴿قال إن فيها لوطا قالوا نحن أعلم بمن فيها﴾</span>، قال: لا تَلْقى المؤمنَ إلا يرحمُ المؤمنَ ويحوطه حيثما كان{2}. (١١/٥٤٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٩٨٦٣<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿قال﴾</span> إبراهيم لهم: <span class="qpc-hafs">﴿إن فيها لوطا قالوا نحن أعلم بمن فيها﴾</span>{3}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿لَنُنَجِّیَنَّهُۥ وَأَهۡلَهُۥۤ إِلَّا ٱمۡرَأَتَهُۥ كَانَتۡ مِنَ ٱلۡغَـٰبِرِینَ ۝٣٢﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٩٨٦٤<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- وفي قوله: <span class="qpc-hafs">﴿إلا امرأته كانت من الغابرين﴾</span>، قال: مِن الباقين في عذاب الله{4}. (١١/٥٤٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٩٨٦٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿لننجينه وأهله﴾</span> يعني: لوطًا، ثم استثنى، فقال: <span class="qpc-hafs">﴿إلا امرأته كانت من الغابرين﴾</span> يعني: الباقين في العذاب{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٩٨٦٦<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿لننجينه وأهله إلا امرأته كانت من الغابرين﴾</span> الباقين في عذاب الله، وقال في آية أخرى: <span class="qpc-hafs">﴿إلا امرأته قدرنا إنها لمن الغابرين﴾</span> [الحجر:٦٠]{3}<span class=comment-ref>٥٠٤٠</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٥٠٤٠</span> نقل <u>ابنُ عطية</u> (٦/٦٤٢) في معنى قوله تعالى: <span class="qpc-hafs">﴿مِنَ الغابِرِينَ﴾</span> عن <b>فرقة</b> قولهم: «<span class="qpc-hafs">﴿مِنَ الغابِرِينَ﴾</span>، أي: مِمَّن غَبَر وبَقِيَ من الناس وعسى في كفره».</div></p></div>",footnotes:1:أخرجه ابن جرير ١٨/٣٩٣، وابن أبي حاتم ٩/٣٠٥٦.|2:أخرجه عبد الرزاق ٢/٩٧-٩٨، وابن أبي حاتم ٩/٣٠٥٦-٣٠٥٨، وابن عساكر ٥٠/٣١٠. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.|3:تفسير يحيى بن سلّام ٢/٦٢٨.|4:أخرجه ابن أبي حاتم ٩/٣٠٥٦-٣٠٥٨، وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن عساكر.|5:تفسير مقاتل بن سليمان ٣/٣٨١.|6:تفسير يحيى بن سلّام ٢/٦٢٨.
  29,33,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَلَمَّاۤ أَن جَاۤءَتۡ رُسُلُنَا لُوطࣰا﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٩٨٦٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ولما أن جاءت رسلنا﴾</span> الملائكة <span class="qpc-hafs">﴿لوطًا﴾</span>، وحسِب أنّهم مِن الإنس{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٩٨٦٨<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: قال: <span class="qpc-hafs">﴿ولما أن جاءت رسلنا﴾</span> يعني: الملائكة <span class="qpc-hafs">﴿لوطا﴾</span>{2}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿سِیۤءَ بِهِمۡ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٩٨٦٩<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي بن أبي طلحة- قوله: <span class="qpc-hafs">﴿سيء بهم﴾</span>، يقول: ساء ظنًّا بقومه{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٩٨٧٠<span class="dash">-</span></span> عن <span class="name-2">كعب الأحبار</span> -من طريق عبد الله بن رباح- <span class="qpc-hafs">﴿سيء بهم﴾</span>: ساءه مكانهم؛ لِما رأى منهم من الجمال{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٩٨٧١<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- في قوله: <span class="qpc-hafs">﴿ولما جاءت رسلنا لوطا سيء بهم﴾</span>، قال: ساء بقومه ظنًّا؛ يَتَخَوَّفُهم على أضْيافه{5}. (١١/٥٤٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٩٨٧٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿سيء بهم﴾</span>، يعني: كَرِهَهم لوطٌ؛ لِصنيع قومه بالرجال{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٩٨٧٣<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: قال: <span class="qpc-hafs">﴿سيء بهم﴾</span> سيء بقومه الظَّنَّ؛ بما كانوا يأتون الرجال في أدبارهم؛ تخوُّفًا على أضيافه، وهو يظُنُّ أنهم آدَمِيُّون{2}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَضَاقَ بِهِمۡ ذَرۡعࣰاۖ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٩٨٧٤<span class="dash">-</span></span> عن <span class="name-2">كعب الأحبار</span> -من طريق عبد الله بن رباح- <span class="qpc-hafs">﴿وضاق بهم ذرعا﴾</span>، يقول: ضاق ذرعًا بأضيافه{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٩٨٧٥<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- في قوله: <span class="qpc-hafs">﴿وضاق بهم ذرعا﴾</span> وضاق ذرعًا بضيفه؛ مخافة عليهم مما يعلم مِن شرِّ قومه{5}. (١١/٥٤٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٩٨٧٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وضاق بهم ذرعًا﴾</span>، يعني: بضيافة الملائكة ذرعًا، يعني: مخافة عليهم أن يفضحوهم{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٩٨٧٧<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: قال: <span class="qpc-hafs">﴿وضاق بهم ذرعا﴾</span> ضاق بأضيافه الذَّرْع؛ لِما يتخوَّف عليهم منهم{2}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَقَالُوا۟ لَا تَخَفۡ وَلَا تَحۡزَنۡ إِنَّا مُنَجُّوكَ وَأَهۡلَكَ إِلَّا ٱمۡرَأَتَكَ كَانَتۡ مِنَ ٱلۡغَـٰبِرِینَ ۝٣٣﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٩٨٧٨<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وقالوا﴾</span> وقالت الرسل للوط ﵇: <span class="qpc-hafs">﴿لا تخف ولا تحزن﴾</span> لأنّ قومه وعَدُوه، فقالوا: معك رِجال سحروا أبصارنا، فستعلم ما تلقى عذابهم. فقالت الرسل: <span class="qpc-hafs">﴿إنا منجوك وأهلك﴾</span>. ثم استثنى امرأته، فذلك قوله ﷿: <span class="qpc-hafs">﴿إلا امرأتك كانت من الغابرين﴾</span> يعني: مِن الباقين في العذاب، فهلك قوم لوط، ثم أهلكت بعدُ بحجرٍ أصابها فقتلها{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٩٨٧٩<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: قال: <span class="qpc-hafs">﴿وقالوا﴾</span> الملائكة قالته للوط: <span class="qpc-hafs">﴿لا تخف ولا تحزن إنا منجوك وأهلك إلا امرأتك كانت من الغابرين﴾</span>{2}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٣/٣٨١-٣٨٢.|2:تفسير يحيى بن سلّام ٢/٦٢٨.|3:أخرجه ابن أبي حاتم ٩/٣٠٥٧.|4:أخرجه ابن أبي حاتم ٩/٣٠٥٧.|5:أخرجه عبد الرزاق في تفسيره ٢/٩٧-٩٨، وابن جرير ١٨/٣٩٥-٣٩٧ من طريق سعيد، وابن أبي حاتم ٩/٣٠٥٦-٣٠٥٨ من طريق شيبان، وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن عساكر.|6:تفسير مقاتل بن سليمان ٣/٣٨١-٣٨٢.|7:تفسير يحيى بن سلّام ٢/٦٢٨.|8:أخرجه ابن أبي حاتم ٩/٣٠٥٧.|9:أخرجه عبد الرزاق في تفسيره ٢/٩٧-٩٨، وابن جرير ١٨/٣٩٥-٣٩٧ من طريق سعيد، وابن أبي حاتم ٩/٣٠٥٦-٣٠٥٨ من طريق شيبان، وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن عساكر.|10:تفسير مقاتل بن سليمان ٣/٣٨١-٣٨٢.|11:تفسير يحيى بن سلّام ٢/٦٢٨.|12:تفسير مقاتل بن سليمان ٣/٣٨١-٣٨٢.|13:تفسير يحيى بن سلّام ٢/٦٢٨.
  29,34,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿إِنَّا مُنزِلُونَ عَلَىٰۤ أَهۡلِ هَـٰذِهِ ٱلۡقَرۡیَةِ رِجۡزࣰا مِّنَ ٱلسَّمَاۤءِ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٩٨٨٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق الضحاك- في قوله: <span class="qpc-hafs">﴿رجزا﴾</span>، قال: كل شيء في كتاب الله من الرجز يعني به: العذاب{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٩٨٨١<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿إنا منزلون على أهل هذه القرية رجزا من السماء﴾</span>، قال: عذابًا مِن السماء{2}. (١١/٥٤٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٩٨٨٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>، في قوله تعالى: <span class="qpc-hafs">﴿إنا منزلون على أهل هذه القرية رجزًا﴾</span> يعني: عذابًا <span class="qpc-hafs">﴿من السماء﴾</span> على قرى لوط، يعني: الخسف والحصب{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٩٨٨٣<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿إنا منزلون على أهل هذه القرية رجزا من السماء﴾</span> يعنون: قرية قوم لوط، <span class="qpc-hafs">﴿رجزا﴾</span>: عذابًا{4}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿بِمَا كَانُوا۟ یَفۡسُقُونَ ۝٣٤﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٩٨٨٤<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿بما كانوا يفسقون﴾</span>، قال: بما كانوا يعصون{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٩٨٨٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>، في قوله تعالى: <span class="qpc-hafs">﴿بما كانوا يفسقون﴾</span>: يعني: يعصون{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٩٨٨٦<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿بما كانوا يفسقون﴾</span> يشركون{4}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن أبي حاتم ٩/٣٠٥٨.|2:أخرجه عبد الرزاق في تفسيره ٢/٢٦٩ من طريق معمر، وابن جرير ١٨/٣٩٥-٣٩٧، وابن أبي حاتم ٩/٣٠٥٦-٣٠٥٨، وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن عساكر.|3:تفسير مقاتل بن سليمان ٣/٣٨٢.|4:تفسير يحيى بن سلّام ٢/٦٢٨.|5:أخرجه ابن أبي حاتم ٩/٣٠٥٨.|6:تفسير مقاتل بن سليمان ٣/٣٨٢.|7:تفسير يحيى بن سلّام ٢/٦٢٨.
  29,35,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَلَقَد تَّرَكۡنَا مِنۡهَاۤ ءَایَةَۢ بَیِّنَةࣰ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٩٨٨٧<span class="dash">-</span></span> قال <span class="name-1">عبد الله بن عباس</span>: الآية البينة: آثار منازلهم الخَرِبة{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٩٨٨٨<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿ولقد تركنا منها آية بينة﴾</span>، قال: عِبْرَة{2}. (١١/٥٤٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٩٨٨٩<span class="dash">-</span></span> قال <span class="name-2">مجاهد بن جبر</span>: هي ظهور الماء الأسود على وجه الأرض{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٩٨٩٠<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿ولقد تركنا منها آية بينة﴾</span>، قال: هي الحجارة التي أُمْطِرَت عليهم، أبقاها الله{4}<span class=comment-ref>٥٠٤١</span>. (١١/٥٤٧)</p></p><p></div></p><p><div><span class=comment-ref>٥٠٤١</span> <span class="comment-type-3">رجّح</span> <u>ابنُ جرير</u> (١٨/٣٩٧) أن الآية البينة هي: «عُفُوّ آثارهم، ودُرُوس معالمهم». ولم يذكر مستندًا.</div></p><p><div></p><p><p><span class="item-no">٥٩٨٩١<span class="dash">-</span></span> تفسير <span class="name-2">إسماعيل السُّدِّيّ</span>: قال الله: <span class="qpc-hafs">﴿ولقد تركنا منها آية﴾</span>، أي: عبرة لقوم{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٩٨٩٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>، في قوله تعالى: <span class="qpc-hafs">﴿ولقد تركنا منهآ آيةً﴾</span>: يعني: من قرية لوط آية <span class="qpc-hafs">﴿بينةً﴾</span> يعني: علامة واضحة، يعني: هلاكهم{6}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿لِّقَوۡمࣲ یَعۡقِلُونَ ۝٣٥﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٩٨٩٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>، في قوله تعالى: <span class="qpc-hafs">﴿لقومٍ يعقلون﴾</span>: بتوحيد الله ﷿، كانت قرية لوط بين المدينة والشام، ووُلِد للوط بعد هلاك قومه ابنتان، وكان له ابنتان قبل هلاكهم، ثم مات لوط، وكان أولاده مؤمنين مِن بعده{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٩٨٩٤<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق أصبغ بن الفرج- في قول الله: <span class="qpc-hafs">﴿يعقلون﴾</span>، قال: يتفكرون{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٩٨٩٥<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿بينة لقوم يعقلون﴾</span> وهم المؤمنون، عقلوا عن الله ما أنزل عليهم، فأخبرهم أنه جعل عاليها سافلها، خسف بهم وأمطر عليهم الحجارة{9}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير البغوي ٦/٢٤١.|2:أخرجه ابن جرير ١٨/٣٩٧، وابن أبي حاتم ٩/٣٠٥٨. وعلقه يحيى بن سلّام ٢/٦٢٩. وعزاه السيوطي إلى الفريابي، وعبد بن حميد، وابن المنذر.|3:تفسير البغوي ٦/٢٤١.|4:أخرجه عبد الرزاق ٢/٩٧-٩٨ من طريق معمر، وابن جرير ١٨/٣٩٥-٣٩٧ دون آخره، وابن أبي حاتم ٩/٣٠٥٦-٣٠٥٨، وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن عساكر.|5:علقه يحيى بن سلّام ٢/٦٢٩.|6:تفسير مقاتل بن سليمان ٣/٣٨٢.|7:تفسير مقاتل بن سليمان ٣/٣٨٢.|8:أخرجه ابن أبي حاتم ٩/٣٠٥٨.|9:تفسير يحيى بن سلّام ٢/٦٢٩.
  29,36,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَإِلَىٰ مَدۡیَنَ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٩٨٩٦<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- في قوله: <span class="qpc-hafs">﴿وإلى مدين أخاهم شعيبا﴾</span>، قال: بلغنا: أنّ شعيبًا أُرْسِل مرتين؛ إلى مدين، وأصحاب الأيكة{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٩٨٩٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿و﴾</span>أرسلنا <span class="qpc-hafs">﴿إلى مَدْيَنَ﴾</span>{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٩٨٩٨<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>، في قوله: <span class="qpc-hafs">﴿وإلى مدين﴾</span>: أي: وأرسلنا إلى مدين{3}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿أَخَاهُمۡ شُعَیۡبࣰا﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٩٨٩٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿أخاهُمْ شُعَيْبًا﴾</span> بن نويب بن مدين بن إبراهيم خليل الرحمن -جل جلاله-؛ لِصُلْبِه{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٩٩٠٠<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿أخاهم شعيبا﴾</span> أخوهم في النسب، وليس بأخيهم في الدين{3}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿فَقَالَ یَـٰقَوۡمِ ٱعۡبُدُوا۟ ٱللَّهَ وَٱرۡجُوا۟ ٱلۡیَوۡمَ ٱلۡـَٔاخِرَ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٩٩٠١<span class="dash">-</span></span> تفسير <span class="name-2">إسماعيل السُّدِّيّ</span>، في قوله: <span class="qpc-hafs">﴿فقال يا قوم اعبدوا الله﴾</span>: وحِّدوا الله{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٩٩٠٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فَقالَ ياقوم اعبدوا الله﴾</span> يعني: وحِّدوا الله، <span class="qpc-hafs">﴿وارجوا اليوم الآخِرَ﴾</span> يعني: واخَشَوا البعث الذي فيه جزاء الأعمال{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٩٩٠٣<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿وارجوا اليوم﴾</span>، أي: صَدِّقوا باليوم الآخر{3}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَلَا تَعۡثَوۡا۟ فِی ٱلۡأَرۡضِ مُفۡسِدِینَ ۝٣٦﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٩٩٠٤<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق الضحاك- <span class="qpc-hafs">﴿ولا تعثوا في الأرض﴾</span>، يقول: لا تَسْعَوا في الأرض{9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٩٩٠٥<span class="dash">-</span></span> عن <span class="name-2">أبي مالك غزوان الغفاري</span> -من طريق السُّدِّيّ- <span class="qpc-hafs">﴿ولا تعثوا في الأرض﴾</span>: يعني: لا تمشوا بالمعاصي{9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٩٩٠٦<span class="dash">-</span></span> تفسير <span class="name-2">الحسن البصري</span>، في قوله: <span class="qpc-hafs">﴿ولا تعثوا في الأرض﴾</span>: ولا تكونوا في الأرض مفسدين{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٩٩٠٧<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿ولا تعثوا في الأرض مفسدين﴾</span>، يقول: لا تسيروا في الأرض مفسدين{12}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٩٩٠٨<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- قال: إنّ الله ﷿ بعث شعيبًا إلى مدين، فكانوا مع كُفْرِهم يبخسون الكيل والموازين، فدعاهم، فكَذَّبوه، فقال لهم: ذكر الله في القرآن ما رَدُّوا عليهم، فلما عتوا وكذبوا سألوه العذاب{9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٩٩٠٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ولا تَعْثَوْاْ﴾</span> يعني: ولا تسعوا <span class="qpc-hafs">﴿فِي الأرض مُفْسِدِينَ﴾</span> يعني: بالمعاصي؛ في نُقصان الكيل والميزان، وهو الفساد في الأرض{2}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه عبد الرزاق في تفسيره ٢/٩٨، وابن أبي حاتم ٩/٣٠٥٩.|2:تفسير مقاتل بن سليمان ٣/٣٨٢.|3:تفسير يحيى بن سلّام ٢/٦٢٩.|4:تفسير مقاتل بن سليمان ٣/٣٨٢.|5:تفسير يحيى بن سلّام ٢/٦٢٩.|6:علقه يحيى بن سلّام ٢/٦٢٩.|7:تفسير مقاتل بن سليمان ٣/٣٨٢.|8:تفسير يحيى بن سلّام ٢/٦٢٩.|9:أخرجه ابن أبي حاتم ٩/٣٠٥٩.|10:أخرجه ابن أبي حاتم ٩/٣٠٥٩.|11:علقه يحيى بن سلّام ٢/٦٢٩.|12:أخرجه ابن أبي حاتم ٩/٣٠٥٩. وعلقه يحيى بن سلّام ٢/٦٢٩.|13:أخرجه ابن أبي حاتم ٩/٣٠٥٩.|14:تفسير مقاتل بن سليمان ٣/٣٨٢.
  29,37,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿فَكَذَّبُوهُ فَأَخَذَتۡهُمُ ٱلرَّجۡفَةُ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٩٩١٠<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نَجيح- <span class="qpc-hafs">﴿فأخذتهم الرجفة﴾</span>، قال: الصيحة{1}. (١١/٥٤٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٩٩١١<span class="dash">-</span></span> قال يحيى بن سلّام: <span class="qpc-hafs">﴿فأخذتهم الرجفة﴾</span> والرجفة هاهنا عند <span class="name-2">الحسن [البصري]</span> مثل الصيحة، وهما عنده العذاب{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٩٩١٢<span class="dash">-</span></span> تفسير <span class="name-2">إسماعيل السُّدِّيّ</span>، في قوله: <span class="qpc-hafs">﴿فأخذتهم الرجفة﴾</span>: صيحة جبريل{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٩٩١٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فَكَذَّبُوهُ﴾</span> بالعذاب حين أوعدهم أنه نازل بهم في الدنيا؛ <span class="qpc-hafs">﴿فَأَخَذَتْهُمُ الرجفة﴾</span>{4}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿فَأَصۡبَحُوا۟ فِی دَارِهِمۡ جَـٰثِمِینَ ۝٣٧﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٩٩١٤<span class="dash">-</span></span> عن <span class="name-2">أبي مالك غزوان الغفاري</span> -من طريق السُّدِّيّ- قوله: <span class="qpc-hafs">﴿دارهم﴾</span>، يعني: العسكر كله{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٩٩١٥<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿فأصبحوا في دارهم جاثمين﴾</span>، قال: ميتين{6}<span class=comment-ref>٥٠٤٢</span>. (١١/٥٤٨)</p></p><p></div></p><p><div><span class=comment-ref>٥٠٤٢</span> لم يذكر <u>ابنُ جرير</u> (١٨/٣٩٨) غير قول قتادة.</div></p><p><div></p><p><p><span class="item-no">٥٩٩١٦<span class="dash">-</span></span> وعن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span>، مثل ذلك{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٩٩١٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فَأَصْبَحُواْ فِي دارِهِمْ﴾</span> يعني ﷿: في محلتهم وعسكرهم <span class="qpc-hafs">﴿جاثِمِينَ﴾</span> أمواتًا خامدين، مثل النار إذا أُطْفِئت، بينما هي تتَّقد إذا هي أُطْفِئت، فشبه أرواحهم في أجسادهم وهم أحياء مثل النار إذا تتَّقد، ثم شبه هلاكهم بالنار إذا طفئت، بينما هم أحياء [إذ] صاح بهم جبريل ﵇، فصعقوا أمواتًا أجمعين{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٩٩١٨<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿فأصبحوا في دارهم جاثمين﴾</span>: موتى قد هَلَكوا{9}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ١٠/٣٠٢-٣٠٣، وابن أبي حاتم ٥/١٥١٦، ٣٠٥٩-٣٠٦٠. وعزاه السيوطي إلى الفريابي، وابن أبي شيبة، وعبد بن حميد، وابن المنذر.|2:علقه يحيى بن سلّام ٢/٦٢٩.|3:علَّقه يحيى بن سلّام ٢/٦٢٩.|4:تفسير مقاتل بن سليمان ٣/٣٨٢.|5:أخرجه ابن أبي حاتم ٩/٣٠٥٩.|6:أخرجه عبد الرزاق في تفسيره ٢/٩٧، وابن جرير ١٨/٣٩٨، وابن أبي حاتم ٩/٣٠٦٠، ٣٠٦٢. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.|7:علقه ابن أبي حاتم ٩/٣٠٦٠.|8:تفسير مقاتل بن سليمان ٣/٣٨٢.|9:تفسير يحيى بن سلّام ٢/٦٢٩.
  29,38,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَعَادࣰا وَثَمُودَا۟ وَقَد تَّبَیَّنَ لَكُم مِّن مَّسَـٰكِنِهِمۡۖ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٩٩١٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿و﴾</span>أهلكنا <span class="qpc-hafs">﴿وعادًا وثَمُودَ﴾</span> وهما ابنا عم، <span class="qpc-hafs">﴿وقَد تَّبَيَّنَ لَكُم﴾</span> يا أهل مكة <span class="qpc-hafs">﴿مِّن مَّساكِنِهِمْ﴾</span> يعني: منازلهم آية في هلاكهم{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٩٩٢٠<span class="dash">-</span></span> عن <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿وعادا وثمود﴾</span> قال: وأهلكنا عادًا وثمود، <span class="qpc-hafs">﴿وقد تبين لكم من مساكنهم﴾</span> يعني: ما رأوا مِن آثارهم{2}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَزَیَّنَ لَهُمُ ٱلشَّیۡطَـٰنُ أَعۡمَـٰلَهُمۡ فَصَدَّهُمۡ عَنِ ٱلسَّبِیلِ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٩٩٢١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وزَيَّنَ لَهُمُ الشيطان أعْمالَهُمْ﴾</span> السيئة؛ <span class="qpc-hafs">﴿فَصَدَّهُمْ﴾</span> الشيطان <span class="qpc-hafs">﴿عَنِ السبيل﴾</span> أي: طريق الهدى{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٩٩٢٢<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿وزين لهم الشيطان أعمالهم فصدهم عن السبيل﴾</span> عن سبيل الهدى{2}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَكَانُوا۟ مُسۡتَبۡصِرِینَ ۝٣٨﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٩٩٢٣<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطية العوفي- قوله: <span class="qpc-hafs">﴿فصدهم عن السبيل وكانوا مستبصرين﴾</span>، يقول: كانوا مستبصرين في دينهم{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٩٩٢٤<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نَجيح- في قوله: <span class="qpc-hafs">﴿وكانوا مستبصرين﴾</span>، قال: في الضلالة{6}. (١١/٥٤٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٩٩٢٥<span class="dash">-</span></span> عن <span class="name-2">الضحاك بن مُزاحِم</span> -من طريق عبيد- يقول في قوله: <span class="qpc-hafs">﴿وكانوا مستبصرين﴾</span>، يقول: في دينهم{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٩٩٢٦<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿وكانوا مستبصرين﴾</span>: في ضلالتهم، معجبين بها{8}. (١١/٥٤٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٩٩٢٧<span class="dash">-</span></span> عن <span class="name-3">محمد بن السائب الكلبي</span>، قال في قوله: <span class="qpc-hafs">﴿وكانوا مستبصرين﴾</span>: كانوا معجبين في دينهم وضلالتهم، يحسبون أنهم على هدى{9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٩٩٢٨<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وكانُواْ مُسْتَبْصِرِينَ﴾</span> في دينهم، يحسبون أنهم على هدى{1}<span class=comment-ref>٥٠٤٣</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٥٠٤٣</span> نقل <u>ابنُ عطية</u> (٦/٦٤٤) في قوله تعالى: <span class="qpc-hafs">﴿مُسْتَبْصِرِينَ﴾</span> أن المعنى: «لهم بصيرة في أنّ الرسالة والآيات حق، ولكن كانوا -مع ذلك- يكفرون عنادًا، ويردُّهم الضلال إلى مجاهلة ومتالفة». و<span class="comment-type-4">علَّق</span> عليه بقوله: «<span class="mustanad">فيجري هذا مجرى قوله تعالى</span>: <span class="qpc-hafs">﴿وجَحَدُوا بِها واسْتَيْقَنَتْها أنْفُسُهُمْ ظُلْمًا وعُلُوًّا﴾</span> [النمل:١٤]».</div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٣/٣٨٣.|2:تفسير يحيى بن سلّام ٢/٦٢٩.|3:تفسير مقاتل بن سليمان ٣/٣٨٣.|4:تفسير يحيى بن سلّام ٢/٦٢٩.|5:أخرجه ابن جرير ١٨/٣٩٩، وابن أبي حاتم ٩/٣٠٦٠.|6:أخرجه ابن جرير ١٠/٣٠٢-٣٠٣، وابن أبي حاتم ٥/١٥١٦، ٣٠٥٩-٣٠٦٠. وعلقه يحيى بن سلّام ٢/٦٣٠. وعلقه البخاري ٤/١٧٩٠ بلفظ: ضَلَلَةً. وعزاه السيوطي إلى الفريابي، وابن أبي شيبة، وعبد بن حميد، وابن المنذر.|7:أخرجه ابن جرير ١٨/٣٩٩، وإسحاق البستي في تفسيره ص٧١.|8:أخرجه ابن جرير ١٨/٣٩٩، وابن أبي حاتم ٩/٣٠٦٠، ٣٠٦٢، وأخرجه عبد الرزاق في تفسيره ٢/٩٧ من طريق معمر بلفظ: معجبين بضلالتهم. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.|9:تفسير البغوي ٦/٢٤٢.|10:تفسير مقاتل بن سليمان ٣/٣٨٣.