tafsir[8]{c,v,t}:
29,31," <q>﴿وَلَمَّا جَاۤءَتۡ رُسُلُنَاۤ إِبۡرَ ٰ⁠هِیمَ بِٱلۡبُشۡرَىٰ قَالُوۤا۟ إِنَّا مُهۡلِكُوۤا۟ أَهۡلِ هَـٰذِهِ ٱلۡقَرۡیَةِۖ إِنَّ أَهۡلَهَا كَانُوا۟ ظَـٰلِمِینَ ۝٣١﴾</q> - تفسير ٥٩٨٥٧- عن عبد الله بن عباس -من طريق عطية العوفي- قوله: <q>﴿ولما جاءت رسلنا إبراهيم بالبشرى﴾</q> إلى قوله: <q>﴿نحن أعلم بمن فيها﴾</q>، قال: فجادل إبراهيمُ الملائكة في قوم لوط أن يُترَكوا. قال: فقال: أرأيتم إن كان فيها عشرة أبيات مِن المسلمين، أتتركونهم؟ فقالت الملائكة: ليس فيها عشرة أبيات، ولا خمسة، ولا أربعة، ولا ثلاثة، ولا اثنان. قال: فحزن على لوط وأهل بيته، فقال: <q>﴿إن فيها لوطا قالوا نحن أعلم بمن فيها لننجينه وأهله إلا امرأته كانت من الغابرين﴾</q>. فذلك قوله: <q>﴿يجادلنا في قوم لوط، إن إبراهيم لحليم أواه منيب﴾</q> [هود:٧٤-٧٥]. فقالت الملائكة: <q>﴿يا إبراهيم أعرض عن هذا إنه قد جاء أمر ربك وإنهم آتيهم عذاب غير مردود﴾</q> [هود:٧٦]. فبعث الله إليهم جبريل ﷺ، فانتَسَف المدينة وما فيها بأحد جناحيه، فجعل عاليها سافلها، وتتبَّعَتهم الحجارة بكل أرض{1}. (ز) ٥٩٨٥٨- عن قتادة بن دعامة -من طريق معمر- قوله: <q>﴿بالبشرى﴾</q>، قال: حين أخبروه أنهم أُرسِلوا إلى قوم لوط{2}. (ز) ٥٩٨٥٩- قال مقاتل بن سليمان: <q>﴿ولما جاءت رسلنا﴾</q> يعني: الملائكة <q>﴿إبراهيم بالبشرى﴾</q> بالولد؛ <q>﴿قالوا﴾</q> لإبراهيم: <q>﴿إنا مهلكوا أهل هذه القرية﴾</q> يعنون: قرية لوط، <q>﴿إن أهلها كانوا ظالمين﴾</q>{3}. (ز) ٥٩٨٦٠- قال يحيى بن سلّام: قال الله: <q>﴿ولما جاءت رسلنا﴾</q> يعني: الملائكة <q>﴿إبراهيم بالبشرى﴾</q> بإسحاق، وذلك أنّ الملائكة لما بُعِثَت إلى قوم لوط بعذابهم مَرُّوا بإبراهيم، فسألوه الضيافة، فلما أخبروه أنهم أُرسِلوا بعذاب قوم لوط بعد ما بشروه بإسحاق <q>﴿قالوا إنا مهلكو أهل هذه القرية﴾</q> يعني: قوم لوط؛ <q>﴿إن أهلها كانوا ظالمين﴾</q> يعني: مشركين{4}. (ز) ",footnotes:1:أخرجه ابن جرير ١٨/٣٩٣، وابن أبي حاتم ٩/٣٠٥٥ مختصرًا.أخرجه ابن أبي حاتم ٩/٣٠٥٥.تفسير مقاتل بن سليمان ٣/٣٨١.تفسير يحيى بن سلّام ٢/٦٢٧-٦٢٨.
29,32," <q>﴿قَالَ إِنَّ فِیهَا لُوطࣰاۚ قَالُوا۟ نَحۡنُ أَعۡلَمُ بِمَن فِیهَاۖ﴾</q> - تفسير ٥٩٨٦١- عن عبد الله بن عباس -من طريق عطية العوفي- قوله: <q>﴿قال إن فيها لوطا قالوا نحن أعلم بمن فيها﴾</q>، قال: فحزن إبراهيم ﷺ على لوط وأهل بيته، فقال: <q>﴿إن فيها لوطا﴾</q>. فقالوا: <q>﴿نحن أعلم بمن فيها﴾</q>{1}. (ز) ٥٩٨٦٢- عن قتادة بن دعامة -من طريق معمر- في قوله: <q>﴿قال إن فيها لوطا قالوا نحن أعلم بمن فيها﴾</q>، قال: لا تَلْقى المؤمنَ إلا يرحمُ المؤمنَ ويحوطه حيثما كان{2}. (١١/٥٤٧) ٥٩٨٦٣- قال يحيى بن سلّام: <q>﴿قال﴾</q> إبراهيم لهم: <q>﴿إن فيها لوطا قالوا نحن أعلم بمن فيها﴾</q>{3}. (ز) <q>﴿لَنُنَجِّیَنَّهُۥ وَأَهۡلَهُۥۤ إِلَّا ٱمۡرَأَتَهُۥ كَانَتۡ مِنَ ٱلۡغَـٰبِرِینَ ۝٣٢﴾</q> - تفسير ٥٩٨٦٤- عن قتادة بن دعامة -من طريق معمر- وفي قوله: <q>﴿إلا امرأته كانت من الغابرين﴾</q>، قال: مِن الباقين في عذاب الله{4}. (١١/٥٤٧) ٥٩٨٦٥- قال مقاتل بن سليمان: <q>﴿لننجينه وأهله﴾</q> يعني: لوطًا، ثم استثنى، فقال: <q>﴿إلا امرأته كانت من الغابرين﴾</q> يعني: الباقين في العذاب{5}. (ز) ٥٩٨٦٦- قال يحيى بن سلّام: <q>﴿لننجينه وأهله إلا امرأته كانت من الغابرين﴾</q> الباقين في عذاب الله، وقال في آية أخرى: <q>﴿إلا امرأته قدرنا إنها لمن الغابرين﴾</q> [الحجر:٦٠]{3}٥٠٤٠. (ز) ٥٠٤٠ نقل ابنُ عطية (٦/٦٤٢) في معنى قوله تعالى: <q>﴿مِنَ الغابِرِينَ﴾</q> عن فرقة قولهم: «<q>﴿مِنَ الغابِرِينَ﴾</q>، أي: مِمَّن غَبَر وبَقِيَ من الناس وعسى في كفره». ",footnotes:1:أخرجه ابن جرير ١٨/٣٩٣، وابن أبي حاتم ٩/٣٠٥٦.أخرجه عبد الرزاق ٢/٩٧-٩٨، وابن أبي حاتم ٩/٣٠٥٦-٣٠٥٨، وابن عساكر ٥٠/٣١٠. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.تفسير يحيى بن سلّام ٢/٦٢٨.أخرجه ابن أبي حاتم ٩/٣٠٥٦-٣٠٥٨، وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن عساكر.تفسير مقاتل بن سليمان ٣/٣٨١.تفسير يحيى بن سلّام ٢/٦٢٨.
29,33," <q>﴿وَلَمَّاۤ أَن جَاۤءَتۡ رُسُلُنَا لُوطࣰا﴾</q> - تفسير ٥٩٨٦٧- قال مقاتل بن سليمان: <q>﴿ولما أن جاءت رسلنا﴾</q> الملائكة <q>﴿لوطًا﴾</q>، وحسِب أنّهم مِن الإنس{1}. (ز) ٥٩٨٦٨- قال يحيى بن سلّام: قال: <q>﴿ولما أن جاءت رسلنا﴾</q> يعني: الملائكة <q>﴿لوطا﴾</q>{2}. (ز) <q>﴿سِیۤءَ بِهِمۡ﴾</q> - تفسير ٥٩٨٦٩- عن عبد الله بن عباس -من طريق علي بن أبي طلحة- قوله: <q>﴿سيء بهم﴾</q>، يقول: ساء ظنًّا بقومه{3}. (ز) ٥٩٨٧٠- عن كعب الأحبار -من طريق عبد الله بن رباح- <q>﴿سيء بهم﴾</q>: ساءه مكانهم؛ لِما رأى منهم من الجمال{3}. (ز) ٥٩٨٧١- عن قتادة بن دعامة -من طريق معمر- في قوله: <q>﴿ولما جاءت رسلنا لوطا سيء بهم﴾</q>، قال: ساء بقومه ظنًّا؛ يَتَخَوَّفُهم على أضْيافه{5}. (١١/٥٤٧) ٥٩٨٧٢- قال مقاتل بن سليمان: <q>﴿سيء بهم﴾</q>، يعني: كَرِهَهم لوطٌ؛ لِصنيع قومه بالرجال{1}. (ز) ٥٩٨٧٣- قال يحيى بن سلّام: قال: <q>﴿سيء بهم﴾</q> سيء بقومه الظَّنَّ؛ بما كانوا يأتون الرجال في أدبارهم؛ تخوُّفًا على أضيافه، وهو يظُنُّ أنهم آدَمِيُّون{2}. (ز) <q>﴿وَضَاقَ بِهِمۡ ذَرۡعࣰاۖ﴾</q> - تفسير ٥٩٨٧٤- عن كعب الأحبار -من طريق عبد الله بن رباح- <q>﴿وضاق بهم ذرعا﴾</q>، يقول: ضاق ذرعًا بأضيافه{3}. (ز) ٥٩٨٧٥- عن قتادة بن دعامة -من طريق معمر- في قوله: <q>﴿وضاق بهم ذرعا﴾</q> وضاق ذرعًا بضيفه؛ مخافة عليهم مما يعلم مِن شرِّ قومه{5}. (١١/٥٤٧) ٥٩٨٧٦- قال مقاتل بن سليمان: <q>﴿وضاق بهم ذرعًا﴾</q>، يعني: بضيافة الملائكة ذرعًا، يعني: مخافة عليهم أن يفضحوهم{1}. (ز) ٥٩٨٧٧- قال يحيى بن سلّام: قال: <q>﴿وضاق بهم ذرعا﴾</q> ضاق بأضيافه الذَّرْع؛ لِما يتخوَّف عليهم منهم{2}. (ز) <q>﴿وَقَالُوا۟ لَا تَخَفۡ وَلَا تَحۡزَنۡ إِنَّا مُنَجُّوكَ وَأَهۡلَكَ إِلَّا ٱمۡرَأَتَكَ كَانَتۡ مِنَ ٱلۡغَـٰبِرِینَ ۝٣٣﴾</q> - تفسير ٥٩٨٧٨- قال مقاتل بن سليمان: <q>﴿وقالوا﴾</q> وقالت الرسل للوط ﵇: <q>﴿لا تخف ولا تحزن﴾</q> لأنّ قومه وعَدُوه، فقالوا: معك رِجال سحروا أبصارنا، فستعلم ما تلقى عذابهم. فقالت الرسل: <q>﴿إنا منجوك وأهلك﴾</q>. ثم استثنى امرأته، فذلك قوله ﷿: <q>﴿إلا امرأتك كانت من الغابرين﴾</q> يعني: مِن الباقين في العذاب، فهلك قوم لوط، ثم أهلكت بعدُ بحجرٍ أصابها فقتلها{1}. (ز) ٥٩٨٧٩- قال يحيى بن سلّام: قال: <q>﴿وقالوا﴾</q> الملائكة قالته للوط: <q>﴿لا تخف ولا تحزن إنا منجوك وأهلك إلا امرأتك كانت من الغابرين﴾</q>{2}. (ز) ",footnotes:1:تفسير مقاتل بن سليمان ٣/٣٨١-٣٨٢.تفسير يحيى بن سلّام ٢/٦٢٨.أخرجه ابن أبي حاتم ٩/٣٠٥٧.أخرجه ابن أبي حاتم ٩/٣٠٥٧.أخرجه عبد الرزاق في تفسيره ٢/٩٧-٩٨، وابن جرير ١٨/٣٩٥-٣٩٧ من طريق سعيد، وابن أبي حاتم ٩/٣٠٥٦-٣٠٥٨ من طريق شيبان، وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن عساكر.تفسير مقاتل بن سليمان ٣/٣٨١-٣٨٢.تفسير يحيى بن سلّام ٢/٦٢٨.أخرجه ابن أبي حاتم ٩/٣٠٥٧.أخرجه عبد الرزاق في تفسيره ٢/٩٧-٩٨، وابن جرير ١٨/٣٩٥-٣٩٧ من طريق سعيد، وابن أبي حاتم ٩/٣٠٥٦-٣٠٥٨ من طريق شيبان، وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن عساكر.تفسير مقاتل بن سليمان ٣/٣٨١-٣٨٢.تفسير يحيى بن سلّام ٢/٦٢٨.تفسير مقاتل بن سليمان ٣/٣٨١-٣٨٢.تفسير يحيى بن سلّام ٢/٦٢٨.
29,34," <q>﴿إِنَّا مُنزِلُونَ عَلَىٰۤ أَهۡلِ هَـٰذِهِ ٱلۡقَرۡیَةِ رِجۡزࣰا مِّنَ ٱلسَّمَاۤءِ﴾</q> - تفسير ٥٩٨٨٠- عن عبد الله بن عباس -من طريق الضحاك- في قوله: <q>﴿رجزا﴾</q>، قال: كل شيء في كتاب الله من الرجز يعني به: العذاب{1}. (ز) ٥٩٨٨١- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿إنا منزلون على أهل هذه القرية رجزا من السماء﴾</q>، قال: عذابًا مِن السماء{2}. (١١/٥٤٧) ٥٩٨٨٢- قال مقاتل بن سليمان، في قوله تعالى: <q>﴿إنا منزلون على أهل هذه القرية رجزًا﴾</q> يعني: عذابًا <q>﴿من السماء﴾</q> على قرى لوط، يعني: الخسف والحصب{3}. (ز) ٥٩٨٨٣- قال يحيى بن سلّام: <q>﴿إنا منزلون على أهل هذه القرية رجزا من السماء﴾</q> يعنون: قرية قوم لوط، <q>﴿رجزا﴾</q>: عذابًا{4}. (ز) <q>﴿بِمَا كَانُوا۟ یَفۡسُقُونَ ۝٣٤﴾</q> - تفسير ٥٩٨٨٤- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿بما كانوا يفسقون﴾</q>، قال: بما كانوا يعصون{1}. (ز) ٥٩٨٨٥- قال مقاتل بن سليمان، في قوله تعالى: <q>﴿بما كانوا يفسقون﴾</q>: يعني: يعصون{3}. (ز) ٥٩٨٨٦- قال يحيى بن سلّام: <q>﴿بما كانوا يفسقون﴾</q> يشركون{4}. (ز) ",footnotes:1:أخرجه ابن أبي حاتم ٩/٣٠٥٨.أخرجه عبد الرزاق في تفسيره ٢/٢٦٩ من طريق معمر، وابن جرير ١٨/٣٩٥-٣٩٧، وابن أبي حاتم ٩/٣٠٥٦-٣٠٥٨، وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن عساكر.تفسير مقاتل بن سليمان ٣/٣٨٢.تفسير يحيى بن سلّام ٢/٦٢٨.أخرجه ابن أبي حاتم ٩/٣٠٥٨.تفسير مقاتل بن سليمان ٣/٣٨٢.تفسير يحيى بن سلّام ٢/٦٢٨.
29,35," <q>﴿وَلَقَد تَّرَكۡنَا مِنۡهَاۤ ءَایَةَۢ بَیِّنَةࣰ﴾</q> - تفسير ٥٩٨٨٧- قال عبد الله بن عباس: الآية البينة: آثار منازلهم الخَرِبة{1}. (ز) ٥٩٨٨٨- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿ولقد تركنا منها آية بينة﴾</q>، قال: عِبْرَة{2}. (١١/٥٤٧) ٥٩٨٨٩- قال مجاهد بن جبر: هي ظهور الماء الأسود على وجه الأرض{1}. (ز) ٥٩٨٩٠- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿ولقد تركنا منها آية بينة﴾</q>، قال: هي الحجارة التي أُمْطِرَت عليهم، أبقاها الله{4}٥٠٤١. (١١/٥٤٧) ٥٠٤١ رجّح ابنُ جرير (١٨/٣٩٧) أن الآية البينة هي: «عُفُوّ آثارهم، ودُرُوس معالمهم». ولم يذكر مستندًا. ٥٩٨٩١- تفسير إسماعيل السُّدِّيّ: قال الله: <q>﴿ولقد تركنا منها آية﴾</q>، أي: عبرة لقوم{5}. (ز) ٥٩٨٩٢- قال مقاتل بن سليمان، في قوله تعالى: <q>﴿ولقد تركنا منهآ آيةً﴾</q>: يعني: من قرية لوط آية <q>﴿بينةً﴾</q> يعني: علامة واضحة، يعني: هلاكهم{6}. (ز) <q>﴿لِّقَوۡمࣲ یَعۡقِلُونَ ۝٣٥﴾</q> - تفسير ٥٩٨٩٣- قال مقاتل بن سليمان، في قوله تعالى: <q>﴿لقومٍ يعقلون﴾</q>: بتوحيد الله ﷿، كانت قرية لوط بين المدينة والشام، ووُلِد للوط بعد هلاك قومه ابنتان، وكان له ابنتان قبل هلاكهم، ثم مات لوط، وكان أولاده مؤمنين مِن بعده{6}. (ز) ٥٩٨٩٤- عن عبد الرحمن بن زيد بن أسلم -من طريق أصبغ بن الفرج- في قول الله: <q>﴿يعقلون﴾</q>، قال: يتفكرون{8}. (ز) ٥٩٨٩٥- قال يحيى بن سلّام: <q>﴿بينة لقوم يعقلون﴾</q> وهم المؤمنون، عقلوا عن الله ما أنزل عليهم، فأخبرهم أنه جعل عاليها سافلها، خسف بهم وأمطر عليهم الحجارة{9}. (ز) ",footnotes:1:تفسير البغوي ٦/٢٤١.أخرجه ابن جرير ١٨/٣٩٧، وابن أبي حاتم ٩/٣٠٥٨. وعلقه يحيى بن سلّام ٢/٦٢٩. وعزاه السيوطي إلى الفريابي، وعبد بن حميد، وابن المنذر.تفسير البغوي ٦/٢٤١.أخرجه عبد الرزاق ٢/٩٧-٩٨ من طريق معمر، وابن جرير ١٨/٣٩٥-٣٩٧ دون آخره، وابن أبي حاتم ٩/٣٠٥٦-٣٠٥٨، وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن عساكر.علقه يحيى بن سلّام ٢/٦٢٩.تفسير مقاتل بن سليمان ٣/٣٨٢.تفسير مقاتل بن سليمان ٣/٣٨٢.أخرجه ابن أبي حاتم ٩/٣٠٥٨.تفسير يحيى بن سلّام ٢/٦٢٩.
29,36," <q>﴿وَإِلَىٰ مَدۡیَنَ﴾</q> - تفسير ٥٩٨٩٦- عن قتادة بن دعامة -من طريق معمر- في قوله: <q>﴿وإلى مدين أخاهم شعيبا﴾</q>، قال: بلغنا: أنّ شعيبًا أُرْسِل مرتين؛ إلى مدين، وأصحاب الأيكة{1}. (ز) ٥٩٨٩٧- قال مقاتل بن سليمان: <q>﴿و﴾</q>أرسلنا <q>﴿إلى مَدْيَنَ﴾</q>{2}. (ز) ٥٩٨٩٨- قال يحيى بن سلّام، في قوله: <q>﴿وإلى مدين﴾</q>: أي: وأرسلنا إلى مدين{3}. (ز) <q>﴿أَخَاهُمۡ شُعَیۡبࣰا﴾</q> - تفسير ٥٩٨٩٩- قال مقاتل بن سليمان: <q>﴿أخاهُمْ شُعَيْبًا﴾</q> بن نويب بن مدين بن إبراهيم خليل الرحمن -جل جلاله-؛ لِصُلْبِه{2}. (ز) ٥٩٩٠٠- قال يحيى بن سلّام: <q>﴿أخاهم شعيبا﴾</q> أخوهم في النسب، وليس بأخيهم في الدين{3}. (ز) <q>﴿فَقَالَ یَـٰقَوۡمِ ٱعۡبُدُوا۟ ٱللَّهَ وَٱرۡجُوا۟ ٱلۡیَوۡمَ ٱلۡـَٔاخِرَ﴾</q> - تفسير ٥٩٩٠١- تفسير إسماعيل السُّدِّيّ، في قوله: <q>﴿فقال يا قوم اعبدوا الله﴾</q>: وحِّدوا الله{6}. (ز) ٥٩٩٠٢- قال مقاتل بن سليمان: <q>﴿فَقالَ ياقوم اعبدوا الله﴾</q> يعني: وحِّدوا الله، <q>﴿وارجوا اليوم الآخِرَ﴾</q> يعني: واخَشَوا البعث الذي فيه جزاء الأعمال{2}. (ز) ٥٩٩٠٣- قال يحيى بن سلّام: <q>﴿وارجوا اليوم﴾</q>، أي: صَدِّقوا باليوم الآخر{3}. (ز) <q>﴿وَلَا تَعۡثَوۡا۟ فِی ٱلۡأَرۡضِ مُفۡسِدِینَ ۝٣٦﴾</q> - تفسير ٥٩٩٠٤- عن عبد الله بن عباس -من طريق الضحاك- <q>﴿ولا تعثوا في الأرض﴾</q>، يقول: لا تَسْعَوا في الأرض{9}. (ز) ٥٩٩٠٥- عن أبي مالك غزوان الغفاري -من طريق السُّدِّيّ- <q>﴿ولا تعثوا في الأرض﴾</q>: يعني: لا تمشوا بالمعاصي{9}. (ز) ٥٩٩٠٦- تفسير الحسن البصري، في قوله: <q>﴿ولا تعثوا في الأرض﴾</q>: ولا تكونوا في الأرض مفسدين{6}. (ز) ٥٩٩٠٧- عن قتادة بن دعامة -من طريق سعيد- <q>﴿ولا تعثوا في الأرض مفسدين﴾</q>، يقول: لا تسيروا في الأرض مفسدين{12}. (ز) ٥٩٩٠٨- عن إسماعيل السُّدِّيّ -من طريق أسباط- قال: إنّ الله ﷿ بعث شعيبًا إلى مدين، فكانوا مع كُفْرِهم يبخسون الكيل والموازين، فدعاهم، فكَذَّبوه، فقال لهم: ذكر الله في القرآن ما رَدُّوا عليهم، فلما عتوا وكذبوا سألوه العذاب{9}. (ز) ٥٩٩٠٩- قال مقاتل بن سليمان: <q>﴿ولا تَعْثَوْاْ﴾</q> يعني: ولا تسعوا <q>﴿فِي الأرض مُفْسِدِينَ﴾</q> يعني: بالمعاصي؛ في نُقصان الكيل والميزان، وهو الفساد في الأرض{2}. (ز) ",footnotes:1:أخرجه عبد الرزاق في تفسيره ٢/٩٨، وابن أبي حاتم ٩/٣٠٥٩.تفسير مقاتل بن سليمان ٣/٣٨٢.تفسير يحيى بن سلّام ٢/٦٢٩.تفسير مقاتل بن سليمان ٣/٣٨٢.تفسير يحيى بن سلّام ٢/٦٢٩.علقه يحيى بن سلّام ٢/٦٢٩.تفسير مقاتل بن سليمان ٣/٣٨٢.تفسير يحيى بن سلّام ٢/٦٢٩.أخرجه ابن أبي حاتم ٩/٣٠٥٩.أخرجه ابن أبي حاتم ٩/٣٠٥٩.علقه يحيى بن سلّام ٢/٦٢٩.أخرجه ابن أبي حاتم ٩/٣٠٥٩. وعلقه يحيى بن سلّام ٢/٦٢٩.أخرجه ابن أبي حاتم ٩/٣٠٥٩.تفسير مقاتل بن سليمان ٣/٣٨٢.
29,37," <q>﴿فَكَذَّبُوهُ فَأَخَذَتۡهُمُ ٱلرَّجۡفَةُ﴾</q> - تفسير ٥٩٩١٠- عن مجاهد بن جبر -من طريق ابن أبي نَجيح- <q>﴿فأخذتهم الرجفة﴾</q>، قال: الصيحة{1}. (١١/٥٤٧) ٥٩٩١١- قال يحيى بن سلّام: <q>﴿فأخذتهم الرجفة﴾</q> والرجفة هاهنا عند الحسن [البصري] مثل الصيحة، وهما عنده العذاب{2}. (ز) ٥٩٩١٢- تفسير إسماعيل السُّدِّيّ، في قوله: <q>﴿فأخذتهم الرجفة﴾</q>: صيحة جبريل{3}. (ز) ٥٩٩١٣- قال مقاتل بن سليمان: <q>﴿فَكَذَّبُوهُ﴾</q> بالعذاب حين أوعدهم أنه نازل بهم في الدنيا؛ <q>﴿فَأَخَذَتْهُمُ الرجفة﴾</q>{4}. (ز) <q>﴿فَأَصۡبَحُوا۟ فِی دَارِهِمۡ جَـٰثِمِینَ ۝٣٧﴾</q> - تفسير ٥٩٩١٤- عن أبي مالك غزوان الغفاري -من طريق السُّدِّيّ- قوله: <q>﴿دارهم﴾</q>، يعني: العسكر كله{5}. (ز) ٥٩٩١٥- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿فأصبحوا في دارهم جاثمين﴾</q>، قال: ميتين{6}٥٠٤٢. (١١/٥٤٨) ٥٠٤٢ لم يذكر ابنُ جرير (١٨/٣٩٨) غير قول قتادة. ٥٩٩١٦- وعن عبد الرحمن بن زيد بن أسلم، مثل ذلك{7}. (ز) ٥٩٩١٧- قال مقاتل بن سليمان: <q>﴿فَأَصْبَحُواْ فِي دارِهِمْ﴾</q> يعني ﷿: في محلتهم وعسكرهم <q>﴿جاثِمِينَ﴾</q> أمواتًا خامدين، مثل النار إذا أُطْفِئت، بينما هي تتَّقد إذا هي أُطْفِئت، فشبه أرواحهم في أجسادهم وهم أحياء مثل النار إذا تتَّقد، ثم شبه هلاكهم بالنار إذا طفئت، بينما هم أحياء [إذ] صاح بهم جبريل ﵇، فصعقوا أمواتًا أجمعين{4}. (ز) ٥٩٩١٨- قال يحيى بن سلّام: <q>﴿فأصبحوا في دارهم جاثمين﴾</q>: موتى قد هَلَكوا{9}. (ز) ",footnotes:1:أخرجه ابن جرير ١٠/٣٠٢-٣٠٣، وابن أبي حاتم ٥/١٥١٦، ٣٠٥٩-٣٠٦٠. وعزاه السيوطي إلى الفريابي، وابن أبي شيبة، وعبد بن حميد، وابن المنذر.علقه يحيى بن سلّام ٢/٦٢٩.علَّقه يحيى بن سلّام ٢/٦٢٩.تفسير مقاتل بن سليمان ٣/٣٨٢.أخرجه ابن أبي حاتم ٩/٣٠٥٩.أخرجه عبد الرزاق في تفسيره ٢/٩٧، وابن جرير ١٨/٣٩٨، وابن أبي حاتم ٩/٣٠٦٠، ٣٠٦٢. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.علقه ابن أبي حاتم ٩/٣٠٦٠.تفسير مقاتل بن سليمان ٣/٣٨٢.تفسير يحيى بن سلّام ٢/٦٢٩.
29,38," <q>﴿وَعَادࣰا وَثَمُودَا۟ وَقَد تَّبَیَّنَ لَكُم مِّن مَّسَـٰكِنِهِمۡۖ﴾</q> - تفسير ٥٩٩١٩- قال مقاتل بن سليمان: <q>﴿و﴾</q>أهلكنا <q>﴿وعادًا وثَمُودَ﴾</q> وهما ابنا عم، <q>﴿وقَد تَّبَيَّنَ لَكُم﴾</q> يا أهل مكة <q>﴿مِّن مَّساكِنِهِمْ﴾</q> يعني: منازلهم آية في هلاكهم{1}. (ز) ٥٩٩٢٠- عن يحيى بن سلّام: <q>﴿وعادا وثمود﴾</q> قال: وأهلكنا عادًا وثمود، <q>﴿وقد تبين لكم من مساكنهم﴾</q> يعني: ما رأوا مِن آثارهم{2}. (ز) <q>﴿وَزَیَّنَ لَهُمُ ٱلشَّیۡطَـٰنُ أَعۡمَـٰلَهُمۡ فَصَدَّهُمۡ عَنِ ٱلسَّبِیلِ﴾</q> - تفسير ٥٩٩٢١- قال مقاتل بن سليمان: <q>﴿وزَيَّنَ لَهُمُ الشيطان أعْمالَهُمْ﴾</q> السيئة؛ <q>﴿فَصَدَّهُمْ﴾</q> الشيطان <q>﴿عَنِ السبيل﴾</q> أي: طريق الهدى{1}. (ز) ٥٩٩٢٢- قال يحيى بن سلّام: <q>﴿وزين لهم الشيطان أعمالهم فصدهم عن السبيل﴾</q> عن سبيل الهدى{2}. (ز) <q>﴿وَكَانُوا۟ مُسۡتَبۡصِرِینَ ۝٣٨﴾</q> - تفسير ٥٩٩٢٣- عن عبد الله بن عباس -من طريق عطية العوفي- قوله: <q>﴿فصدهم عن السبيل وكانوا مستبصرين﴾</q>، يقول: كانوا مستبصرين في دينهم{5}. (ز) ٥٩٩٢٤- عن مجاهد بن جبر -من طريق ابن أبي نَجيح- في قوله: <q>﴿وكانوا مستبصرين﴾</q>، قال: في الضلالة{6}. (١١/٥٤٧) ٥٩٩٢٥- عن الضحاك بن مُزاحِم -من طريق عبيد- يقول في قوله: <q>﴿وكانوا مستبصرين﴾</q>، يقول: في دينهم{7}. (ز) ٥٩٩٢٦- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿وكانوا مستبصرين﴾</q>: في ضلالتهم، معجبين بها{8}. (١١/٥٤٨) ٥٩٩٢٧- عن محمد بن السائب الكلبي، قال في قوله: <q>﴿وكانوا مستبصرين﴾</q>: كانوا معجبين في دينهم وضلالتهم، يحسبون أنهم على هدى{9}. (ز) ٥٩٩٢٨- قال مقاتل بن سليمان: <q>﴿وكانُواْ مُسْتَبْصِرِينَ﴾</q> في دينهم، يحسبون أنهم على هدى{1}٥٠٤٣. (ز) ٥٠٤٣ نقل ابنُ عطية (٦/٦٤٤) في قوله تعالى: <q>﴿مُسْتَبْصِرِينَ﴾</q> أن المعنى: «لهم بصيرة في أنّ الرسالة والآيات حق، ولكن كانوا -مع ذلك- يكفرون عنادًا، ويردُّهم الضلال إلى مجاهلة ومتالفة». وعلَّق عليه بقوله: «فيجري هذا مجرى قوله تعالى: <q>﴿وجَحَدُوا بِها واسْتَيْقَنَتْها أنْفُسُهُمْ ظُلْمًا وعُلُوًّا﴾</q> [النمل:١٤]». ",footnotes:1:تفسير مقاتل بن سليمان ٣/٣٨٣.تفسير يحيى بن سلّام ٢/٦٢٩.تفسير مقاتل بن سليمان ٣/٣٨٣.تفسير يحيى بن سلّام ٢/٦٢٩.أخرجه ابن جرير ١٨/٣٩٩، وابن أبي حاتم ٩/٣٠٦٠.أخرجه ابن جرير ١٠/٣٠٢-٣٠٣، وابن أبي حاتم ٥/١٥١٦، ٣٠٥٩-٣٠٦٠. وعلقه يحيى بن سلّام ٢/٦٣٠. وعلقه البخاري ٤/١٧٩٠ بلفظ: ضَلَلَةً. وعزاه السيوطي إلى الفريابي، وابن أبي شيبة، وعبد بن حميد، وابن المنذر.أخرجه ابن جرير ١٨/٣٩٩، وإسحاق البستي في تفسيره ص٧١.أخرجه ابن جرير ١٨/٣٩٩، وابن أبي حاتم ٩/٣٠٦٠، ٣٠٦٢، وأخرجه عبد الرزاق في تفسيره ٢/٩٧ من طريق معمر بلفظ: معجبين بضلالتهم. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.تفسير البغوي ٦/٢٤٢.تفسير مقاتل بن سليمان ٣/٣٨٣.
