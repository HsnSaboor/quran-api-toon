quran[11]{c,v,t}:
21,25," <q>﴿وَمَاۤ أَرۡسَلۡنَا مِن قَبۡلِكَ مِن رَّسُولٍ إِلَّا نُوحِیۤ إِلَیۡهِ أَنَّهُۥ لَاۤ إِلَـٰهَ إِلَّاۤ أَنَا۠ فَٱعۡبُدُونِ ۝٢٥﴾</q> - تفسير ٤٨٩٢٠- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿وما أرسلنا من قبلك من رسول إلا نوحي إليه أنه لا إله إلا أنا فاعبدون﴾</q>، قال: أُرْسِلَت الرُّسُلُ بالإخلاص والتوحيد لله، لا يقبل منهم حتى يقولوه ويُقِرُّوا به، والشرائع تختلف؛ في التوراة شريعة، وفي الإنجيل شريعة، وفي القرآن شريعة، حلال وحرام، فهذا كله في الإخلاص لله، وتوحيد الله{1}. (١٠/٢٨٣) ٤٨٩٢١- قال مقاتل بن سليمان: <q>﴿وما أرسلنا من قبلك من رسول إلا نوحي إليه أنه لا إله إلا أنا فاعبدون﴾</q>، يعني: فوحِّدون{2}. (ز) ٤٨٩٢٢- قال يحيى بن سلّام: قوله: <q>﴿وما أرسلنا من قبلك من رسول إلا نوحي إليه أنه لا إله إلا أنا فاعبدون﴾</q>، أي: لا تعبدوا غيري، بذلك أُرسِل الرُّسُلُ جميعًا{3}. (ز) <q>﴿وَمَاۤ أَرۡسَلۡنَا مِن قَبۡلِكَ مِن رَّسُولٍ إِلَّا نُوحِیۤ إِلَیۡهِ أَنَّهُۥ لَاۤ إِلَـٰهَ إِلَّاۤ أَنَا۠ فَٱعۡبُدُونِ ۝٢٥﴾</q> - آثار متعلقة بالآية ٤٨٩٢٣- عن أُبَيِّ بن كعب: أنّهم جمعوا القرآنَ في مصاحف في خلافة أبي بكر، فكان رجال يكتبون، ويُمْلِي عليهم أُبَيُّ بن كعب، فلمّا انتهوا إلى هذه الآية من سورة براءة: <q>﴿ثم انصرفوا صرف الله قلوبهم بأنهم قوم لا يفقهون﴾</q> [التوبة:١٢٧]، فظنوا أنّ هذا آخر ما أنزل من القرآن، فقال لهم أبيُّ بن كعب: إنّ رسول الله ﷺ أقرأني بعدها آيتين: <q>﴿لقد جاءكم رسول من أنفسكم عزيز عليه ما عنتم حريص عليكم بالمؤمنين رءوف رحيم﴾</q> إلى <q>﴿وهو رب العرش العظيم﴾</q> [التوبة:١٢٨-١٢٩]. ثم قال: هذا آخِرُ ما أُنزِلَ من القرآن. قال: فَخُتِمَ بما فُتِحَ به بـ: الله الذي لا إله إلّا هُوَ، وهو قول الله -تبارك وتعالى-: ‹وما أرْسَلْنا مِن قَبْلِكَ مِن رَسُولٍ إلّا يُوحى{4} إلَيْهِ أنَّهُ لا إلَهَ إلّا أنا فاعْبُدُونِ› [الأنبياء:٢٥]{5}. (ز) ٤٨٩٢٤- عن عبد الله بن عمرو -من طريق يزيد بن أبي حبيب- قال: إنّ إدريس كان قبل نوح، بعثه الله إلى قومه، يأمرهم أن يقولوا: لا إله إلا الله. ويعملوا ما شاءوا، فأبوا، فأهلكهم الله{6}. (ز) ",footnotes:1:أخرجه ابن جرير ١٦/٢٤٨-٢٥٠. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.تفسير مقاتل بن سليمان ٣/٧٥.تفسير يحيى بن سلّام ١/٣٠٧.كذا في المسند بالياء على قراءة غير حمزة والكسائي وحفص عن عاصم. ينظر: السبعة في القراءات لابن مجاهد ص٤٢٨.أخرجه عبد الله بن أحمد في زوائد المسند ٣٥/١٤٩-١٥٠ (٢١٢٢٦)، وابن أبي حاتم ٦/١٩١٩ (١٠١٧٢)، من طريق أبي جعفر الرازي، عن الربيع بن أنس، عن أبي العالية، عن أبي بن كعب به. قال ابن كثير في تفسيره ٤/٢٤٤ عن رواية عبد الله بن أحمد: «غريب». وقال الهيثمي في المجمع ٧/٣٥-٣٦ (١١٠٦٣): «رواه عبد الله بن أحمد، وفيه محمد بن جابر الأنصاري، وهو ضعيف».أخرجه يحيى بن سلّام ١/٣٠٧.
21,26," <q>﴿وَقَالُوا۟ ٱتَّخَذَ ٱلرَّحۡمَـٰنُ وَلَدࣰاۗ﴾</q> - تفسير ٤٨٩٢٥- عن قتادة بن دعامة -من طريق سعيد- قال: قالت اليهود: إنّ الله ﷿ صاهَر الجن، فكانت بينهم الملائكة{1}. (١٠/٢٨٣) ٤٨٩٢٦- قال مقاتل بن سليمان: <q>﴿وقالوا﴾</q> أي: كُفّار مكة، منهم النضر بن الحارث: <q>﴿اتخذ الرحمن ولدا﴾</q> قالوا: إنّ الملائكة بنات الله تعالى{2}. (ز) <q>﴿سُبۡحَـٰنَهُۥۚ بَلۡ عِبَادࣱ مُّكۡرَمُونَ ۝٢٦﴾</q> - تفسير ٤٨٩٢٧- عن قتادة بن دعامة -من طريق سعيد- قال: فقال الله تكذيبًا لهم: <q>﴿بل عباد مكرمون﴾</q>، أي: الملائكة ليس كما قالوا، بل هم عباد أكرمهم الله بعبادته{3}. (١٠/٢٨٣) ٤٨٩٢٨- قال مقاتل بن سليمان: فنَزَّه الربُّ جل جلاله نفسه عن قولهم، فقال: <q>﴿سبحانه بل﴾</q> هم يعني: الملائكة <q>﴿عباد مكرمون﴾</q> لعبادة ربهم، وليسوا ببنات الرحمن، ولكن الله أكرمهم بعبادته{2}. (ز) ٤٨٩٢٩- قال يحيى بن سلّام: قال الله: <q>﴿سبحانه﴾</q> يُنَزِّه نفسه عما قالوا، <q>﴿بل عباد مكرمون﴾</q> يعني: الملائكة هم كِرام على الله{5}. (ز) ",footnotes:1:أخرجه يحيى بن سلّام ١/٣٠٧، وابن جرير ١٦/٢٥٠. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.تفسير مقاتل بن سليمان ٣/٧٥.أخرجه ابن جرير ١٦/٢٥٠. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.تفسير مقاتل بن سليمان ٣/٧٥.تفسير يحيى بن سلّام ١/٣٠٧.
21,27," <q>﴿لَا یَسۡبِقُونَهُۥ بِٱلۡقَوۡلِ وَهُم بِأَمۡرِهِۦ یَعۡمَلُونَ ۝٢٧﴾</q> - تفسير ٤٨٩٣٠- عن قتادة بن دعامة -من طريق سعيد- قال: <q>﴿لا يسبقونه بالقول﴾</q>، يُثْنِي عليهم{1}. (١٠/٢٨٣) ٤٨٩٣١- قال مقاتل بن سليمان: ثم أخبر عن الملائكة، فقال: <q>﴿لا يسبقونه بالقول﴾</q> يعني: الملائكة لا يسبقون ربهم بأمر، يقول: الملائكة لم تأمر كفّار مكة بعبادتهم إيّاها، ثم قال: <q>﴿وهم﴾</q> يعني: الملائكة <q>﴿بأمره يعملون﴾</q> يقول: لا تعمل الملائكةُ إلا بأمره، فأخبر الله ﷿ عن الملائكة أنّهم عباد يخافون ربَّهم، ويُقَدِّسونه، ويعبدونه{2}. (ز) ٤٨٩٣٢- قال يحيى بن سلّام: قال الله: <q>﴿لا يسبقونه بالقول﴾</q> فيقولون شيئًا لم يقبلوه عن الله. قال: <q>﴿وهم بأمره يعملون﴾</q>{3}. (ز) ",footnotes:1:أخرجه ابن جرير ١٦/٢٥٠. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.تفسير مقاتل بن سليمان ٣/٧٥.تفسير يحيى بن سلّام ١/٣٠٧.
21,28," <q>﴿یَعۡلَمُ مَا بَیۡنَ أَیۡدِیهِمۡ وَمَا خَلۡفَهُمۡ﴾</q> - تفسير ٤٨٩٣٣- تفسير إسماعيل السُّدِّيّ: <q>﴿يعلم ما بين أيديهم وما خلفهم﴾</q>، يعني: يعلم ما كان مِن قبل خلق الملائكة، وما كان بعد خلقهم{1}. (ز) ٤٨٩٣٤- قال مقاتل بن سليمان: <q>﴿يعلم ما بين أيديهم وما خلفهم﴾</q>، يقول الرب ﷿: يعلم ما كان قبل أن يخلق الملائكة، ويعلم ما كان بعد خلقهم{2}. (ز) ٤٨٩٣٥- قال يحيى بن سلّام: <q>﴿يعلم ما بين أيديهم﴾</q> من أمر الآخرة، <q>﴿وما خلفهم﴾</q> من أمر الدنيا إذا كانت الآخرة{3}. (ز) <q>﴿وَلَا یَشۡفَعُونَ إِلَّا لِمَنِ ٱرۡتَضَىٰ﴾</q> - تفسير ٤٨٩٣٦- عن جابر بن عبد الله، أنّ رسول الله ﷺ تلا قول الله: <q>﴿ولا يشفعون إلا لمن ارتضى﴾</q>، فقال: «إنّ شفاعتي لأهل الكبائر مِن أُمَّتي»{4}. (١٠/٢٨٤) ٤٨٩٣٧- عن عبد الله بن عباس، في قوله: <q>﴿إلا لمن ارتضى﴾</q>، قال: الذين ارتضاهم لشهادة أن لا إله إلا الله{5}. (١٠/٢٨٤) ٤٨٩٣٨- عن مجاهد بن جبر -من طريق ابن أبي نَجِيح- في قوله: <q>﴿إلا لمن ارتضى﴾</q>، قال: لِمَن رضي عنه{6}. (١٠/٢٨٤) ٤٨٩٣٩- عن الحسن البصري، في قوله: <q>﴿إلا لمن ارتضى﴾</q>، قال: قول: لا إله إلا الله{7}. (١٠/٢٨٤) ٤٨٩٤٠- عن قتادة بن دِعامة -من طريق سعيد- قال: <q>﴿ولا يشفعون﴾</q> قال: لا تشفع الملائكة يوم القيامة <q>﴿إلا لمن ارتضى﴾</q> قال: لأهل التوحيد{8}. (١٠/٢٨٤) ٤٨٩٤١- قال مقاتل بن سليمان: <q>﴿ولا يشفعون إلا لمن ارتضى﴾</q> يقول: لا تشفع الملائكة إلا لِمَن رضي اللهُ أن يشفع له، يعني: مِن أهل التوحيد الذين لا يقولون: إنّ الملائكة بنات الله ﷿؛ لأنّ كُفّار مكَّة زعموا أنّ الملائكة تشفع لهم في الآخرة إلى الله ﷿{2}. (ز) <q>﴿وَهُم مِّنۡ خَشۡیَتِهِۦ مُشۡفِقُونَ ۝٢٨﴾</q> - تفسير ٤٨٩٤٢- تفسير مجاهد بن جبر: <q>﴿وهم من خشيته مشفقون﴾</q>، أي: خائفون{1}. (ز) ٤٨٩٤٣- قال مقاتل بن سليمان: ثم قال سبحانه: [<q>﴿وهم﴾</q> يعني: الملائكة] <q>﴿من خشيته مشفقون﴾</q> يعني: خائفين{2}. (ز) <q>﴿وَهُم مِّنۡ خَشۡیَتِهِۦ مُشۡفِقُونَ ۝٢٨﴾</q> - آثار متعلقة بالآية ٤٨٩٤٤- عن جابر بن عبد الله، قال: قال النبي ﷺ: «ليلةَ أسري بي مررتُ بجبريل، وهو بالملأ الأعلى، مُلْقىً كالحِلْسِ{12} البالي مِن خشية الله»{13}. (١٠/٢٨٤) ",footnotes:1:علَّقه يحيى بن سلّام ١/٣٠٨.تفسير مقاتل بن سليمان ٣/٧٦.تفسير يحيى بن سلّام ١/٣٠٧.أخرجه الحاكم ٢/٤١٤ (٣٤٤٢)، وأخرجه الترمذي دون الآية ٤/٤٣٤ (٢٦٠٥)، وابن حبان ١٤/٣٨٦ (٦٤٦٧)، من طريق جعفر بن محمد، عن أبيه، عن جابر بن عبد الله به. قال الترمذي: «هذا حديث حسن غريب من هذا الوجه». وقال الحاكم: «هذا حديث صحيح، على شرط الشيخين، ولم يخرجاه». وقال الذهبي في التلخيص: «على شرط مسلم».أخرجه ابن جرير ١٦/٢٥٢، والبيهقي في البعث (٢). وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.تفسير مجاهد ص٤٧٠، وأخرجه ابن جرير ١٦/٢٥٣. وعلَّقه يحيى بن سلّام ١/٣٠٨، والبخاري (ت: مصطفى البغا) كتاب التفسير - باب تفسير سورة الأنبياء ٤/١٧٦٦، بلفظ: رَضِيَ. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.عزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ١٦/٢٤٩. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.تفسير مقاتل بن سليمان ٣/٧٦.علَّقه يحيى بن سلّام ١/٣٠٨.تفسير مقاتل بن سليمان ٣/٧٦.الحِلْس: كل ما يلي ظهر البعير، ويُطلق على بساط البيت. اللسان (حلس).أخرجه ابن أبي عاصم في كتاب السنة ١/٢٧٦ (٦٢١)، والطبراني في الأوسط ٥/٦٤ (٤٦٧٩)، من طريق عبيد الله بن عمرو، وموسى بن أعين، عن عبد الكريم، عن عطاء، عن جابر به. قال الهيثمي في المجمع ١/٧٨ (٢٤٦): «رجاله رجال الصحيح». وقال السيوطي في الدر ٩/٢٠٧: «سند صحيح». وقال المناوي في التيسير بشرح الجامع الصغير ٢/٣٧٥ عن رواية الطبراني: «إسناده صحيح». وأورده الألباني في الصحيحة ٥/٣٦٢ (٢٢٨٩).
21,29," <q>﴿وَمَن یَقُلۡ مِنۡهُمۡ إِنِّیۤ إِلَـٰهࣱ مِّن دُونِهِۦ فَذَ ٰ⁠لِكَ نَجۡزِیهِ جَهَنَّمَۚ كَذَ ٰ⁠لِكَ نَجۡزِی ٱلظَّـٰلِمِینَ ۝٢٩﴾</q> - تفسير ٤٨٩٤٥- عن الضحاك بن مُزاحم -من طريق عبيد- في قوله: <q>﴿ومن يقل منهم﴾</q> يعني: مِن الملائكة، <q>﴿إني إله من دونه﴾</q> قال: ولم يقل ذلك أحد مِن الملائكة إلا إبليس، دعا إلى عبادة نفسه، وشَرَعَ الكفر{1}. (١٠/٢٨٥) ٤٨٩٤٦- قال الحسن البصري: ومن يقل ذلك منهم -إن قالوه-، ولا يقوله أحدٌ منهم. وكان يقول: إنّ إبليس لم يكن منهم{2}. (ز) ٤٨٩٤٧- عن قتادة بن دِعامة -من طريق معمر- في قوله: <q>﴿ومن يقل منهم أني إله من دونه﴾</q> الآية، قال: إنّما كانت هذه خاصة لإبليس{3}. (١٠/٢٨٥) ٤٨٩٤٨- قال مقاتل بن سليمان: <q>﴿ومن يقل منهم﴾</q> يعني: مِن الملائكة <q>﴿إني إله من دونه﴾</q> يعني: مِن دون الله ﷿ <q>﴿فذلك﴾</q> يعني: فهذا الذي يقول: إني إله من دونه <q>﴿نجزيه جهنم كذلك نجزي الظالمين﴾</q> النارَ حين زعموا أنّ مع الله ﷿ إلهًا. ولم يقل ذلك أحدٌ مِن الملائكة غير إبليس؛ عدو الله؛ رأس الكفر{4}. (ز) ٤٨٩٤٩- قال سفيان الثوري، في قوله: <q>﴿ومن يقل منهم إني إله من دونه﴾</q>: إبليس{5}٤٣٣٩. (ز) ٤٣٣٩ ذكر ابنُ جرير (١٦/٢٥٣-٢٥٤) أنّ قائلي هذا القول قالوه لأنّه لم يقل أحد من الملائكة: إني إله، سوى إبليس. وانتقد ابنُ عطية (٦/١٦٢) هذا القول الذي قاله قتادة، والضحاك، والثوري مستندًا لواقع الحال، فقال: «وهذا ضعيف؛ لأن إبليس لم يُروَ قطُّ أنّه ادَّعى ربوبية». <q>﴿وَمَن یَقُلۡ مِنۡهُمۡ إِنِّیۤ إِلَـٰهࣱ مِّن دُونِهِۦ فَذَ ٰ⁠لِكَ نَجۡزِیهِ جَهَنَّمَۚ كَذَ ٰ⁠لِكَ نَجۡزِی ٱلظَّـٰلِمِینَ ۝٢٩﴾</q> - آثار متعلقة بالآية ٤٨٩٥٠- عن عبد الله بن عباس -من طريق عكرمة- قال: إنّ الله فَضَّل محمدًا ﷺ على الأنبياء ﵈، وعلى أهل السماء. فقالوا: يا ابن عباس، بِمَ فضَّله على أهل السماء؟ قال: إنّ الله قال لأهل السماء: <q>﴿ومن يقل منهم إني إله من دونه فذلك نجزيه جهنم كذلك نجزي الظالمين﴾</q> الآية، وقال الله تعالى لمحمد ﷺ: <q>﴿إنا فتحنا لك فتحا مبينا ليغفر لك الله ما تقدم من ذنبك وما تأخر﴾</q> [الفتح:١-٢]. قالوا: فما فَضْلُهُ على الأنبياء ﵈؟ قال: قال الله ﷿: <q>﴿وما أرسلنا من رسول إلا بلسان قومه ليبين لهم﴾</q> الآية [إبراهيم:٤]، وقال الله ﷿ لمحمد ﷺ: <q>﴿وما أرسلناك إلا كافة للناس﴾</q> [سبأ:٢٨]، فأرسله إلى الجن والإنس{6}. (ز) ",footnotes:1:أخرجه إسحاق البستي في تفسيره ص٢٩٩. وعزاه السيوطي إلى ابن أبي حاتم.علَّقه يحيى بن سلام ١/٣٠٨.أخرجه عبد الرزاق ٢/٢٣. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم. وعلَّقه يحيى بن سلام ١/٣٠٨ وزاد: لَمّا قال ما قال دعا إلى عبادة نفسه.تفسير مقاتل بن سليمان ٣/٧٦.تفسير الثوري ص٢٠٠.أخرجه الدارمي ١/١٩٣-١٩٤ (٤٧).
21,30," <q>﴿أَوَلَمۡ یَرَ ٱلَّذِینَ كَفَرُوۤا۟ أَنَّ ٱلسَّمَـٰوَ ٰ⁠تِ وَٱلۡأَرۡضَ كَانَتَا رَتۡقࣰا فَفَتَقۡنَـٰهُمَاۖ﴾</q> - تفسير ٤٨٩٥١- عن عبد الله بن عباس -من طريق عطاء- في قوله: <q>﴿كانتا رتقا ففتقناهما﴾</q>، قال: فُتِقَتِ السماء بالغيث، وفُتِقَتِ الأرض بالنبات{1}. (١٠/٢٨٥) ٤٨٩٥٢- عن عبد الله بن عباس، في قوله: <q>﴿كانتا رتقا﴾</q> قال: لا يخرج منها شيء، <q>﴿ففتقناهما﴾</q> قال: فُتِقَتِ السماءُ بالمطر، وفُتِقَتِ الأرض بالنبات{2}. (١٠/٢٨٥) ٤٨٩٥٣- عن عبد الله بن عباس -من طريق علي- في قوله: <q>﴿كانتا رتقا﴾</q>، قال: مُلْتَصِقَتَين{3}. (١٠/٢٨٦) ٤٨٩٥٤- عن عكرمة، قال: سُئِل عبد الله بن عباس عن الليل؛ كان قبل أم النهار؟ قال: الليل. ثم قرأ: <q>﴿أن السموات والأرض كانتا رتقا ففتقناهما﴾</q>. فهل تعلمون كان بينهما إلا ظُلْمة!{4}. (١٠/٢٨٦) ٤٨٩٥٥- عن عبد الله بن عمر -من طريق عبد الله بن دينار- أنّ رجلًا أتاه، فسأله عن: <q>﴿السموات والأرض كانتا رتقا ففتقناهما﴾</q>. قال: اذهب إلى ذلك الشيخ، فاسأله، ثم تعال فأخبرني ما قال. فذهب إلى ابن عباس، فسأله، قال: نعم، كانت السماء رَتْقًا لا تُمْطِر، وكانت الأرض رَتْقاء لا تُنبِت، فلمّا خلق اللهُ للأرض أهلًا فَتَقَ هذه بالمطر، وفَتَقَ هذه بالنبات. فرجع الرجلُ إلى ابن عمر، فأخبره، فقال ابن عمر: الآن علمتُ أنّ ابن عباس قد أُوتِي في القرآن عِلْمًا، صدق ابنُ عباس، هكذا كانت{5}. (١٠/٢٨٥) ٤٨٩٥٦- قال كعب الأحبار: خلق الله السموات والأرض بعضها على بعض، ثم خلق رِيحًا بوَسَطِها، ففتحها بها{6}. (ز) ٤٨٩٥٧- عن سعيد بن جبير -من طريق عطاء بن دينار- قال: كانت السموات والأرضون مُلْتَزِقَتَيْنِ، فلمّا رفع الله السماءَ، وأنبذها من الأرض، فكان فَتْقَها الذي ذَكَرَ اللهُ{7}. (١٠/٢٨٧) ٤٨٩٥٨- عن مجاهد بن جبر -من طريق ابن أبي نَجِيح- في قوله: <q>﴿كانتا رتقا ففتقناهما﴾</q>، قال: فَتَقَ مِن الأرضِ ستَّ أرضين معها، فتلك سبع أرضين بعضهن تحت بعض، ومن السماء سبع سموات معها، فتلك سبع سموات بعضهن فوق بعض، ولم تكن الأرض والسماء مُتَماسَّتَيْن{8}. (١٠/٢٨٧) ٤٨٩٥٩- عن مجاهد بن جبر -من طريق أبي يحيى- قال: كُنَّ مُنطَبِقات، ففَتَقَهُنَّ{9}. (ز) ٤٨٩٦٠- عن مجاهد بن جبر -من طريق خُصَيْف- في قول الله: <q>﴿ففتقناهما﴾</q>، قال: فُتِقَتْ هذه بالماء، وهذه بالنبات{10}. (ز) ٤٨٩٦١- قال يحيى بن سلام: وتفسير مجاهد: كُنَّ مُطْبَقات ففَتَقَهُنَّ. أحسبه قال: بالمطر. وقاله غيره. قال مجاهد: ولم تكن السماء والأرض مُتماسَّتَيْن{11}. (ز) ٤٨٩٦٢- عن الضَّحّاك بن مُزاحِم -من طريق سفيان الثوري- في قوله: <q>﴿كانتا رتقا ففتقناهما﴾</q>، قال: كُنَّ سبعًا ملتزقات، ففتق بعضهن مِن بعض{12}. (ز) ٤٨٩٦٣- قال الضحاك بن مزاحم: يعني: كانتا شيئًا واحدًا ملتزقين، فَفَصَل اللهُ بينهما بالهواء{13}. (ز) ٤٨٩٦٤- قال عكرمة مولى ابن عباس= (ز) ٤٨٩٦٥- وعطية العوفي: كانت السماء رتقًا لا تُمْطِر، والأرض رتقًا لا تُنبِت، ففتق السماء بالمطر، والأرض بالنبات{14}٤٣٤٠. (ز) ٤٣٤٠ ذكر ابنُ عطية (٦/١٦٣) أنّ الرؤية على هذا القول رؤية العين، وكذا على قول ابن عباس من طريق عكرمة. ٤٨٩٦٦- قال عطاء: كانتا شيئًا واحدًا ملتزقتين، ففصل الله سبحانه بينهما بالهواء{14}. (ز) ٤٨٩٦٧- تفسير الحسن البصري: <q>﴿أولم ير الذين كفروا﴾</q> هذا على الخبر{16}. (ز) ٤٨٩٦٨- عن الحسن البصري= (ز) ٤٨٩٦٩- وقتادة بن دعامة، في قوله: <q>﴿كانتا رتقا ففتقناهما﴾</q>، قالا: كانتا جمعًا، ففصل الله بينهما بهذا الهواء{17}٤٣٤١. (١٠/٢٨٧) ٤٣٤١ ذكر ابنُ عطية (٦/١٦٣) أنّه على هذا القول الذي قاله ابن عباس -من طريق علي، والعوفي-، والحسن، وقتادة، وكعب؛ فالرؤية المُوقَف عليها رؤية القلب. وكذا على القول الذي قاله مجاهد، وأبو صالح، والسدي، والضحاك، وعطاء، وسعيد بن جبير، ومقاتل، ويحيى بن سلام. ٤٨٩٧٠- عن أبي صالح باذام -من طريق إسماعيل بن أبي خالد- في قوله: <q>﴿كانتا رتقا ففتقناهما﴾</q>، قال: كانت السماء واحدةً، ففتق منها سبع سموات، وكانت الأرض واحدةً، ففتق منها سبع أرضين{18}. (١٠/٢٨٧) ٤٨٩٧١- عن محمد بن قيس -من طريق أبي معشر- في قوله ﷿: <q>﴿أولم ير الذين كفروا أن السماوات والأرض كانتا رتقا ففتقناهما وجعلنا من الماء كل شيء حي أفلا يؤمنون﴾</q>، قال: كانت السماءُ لا تُمْطِر، والأرضُ لا تُنبِت، ففتق الله ﷿ السماءَ بالمطر، والأرضَ بالنبات، وجَعَل مِن الماء كل شيء، أفلا يؤمنون{19}. (ز) ٤٨٩٧٢- قال إسماعيل السُّدِّيّ: <q>﴿أولم ير﴾</q>، يعني: أوَلَم يعلم الذين كفروا{16}. (ز) ٤٨٩٧٣- عن إسماعيل السُّدِّيّ: كانت السموات مُرْتَقَةً طبقة واحدة، ففتقها؛ فجعلها سبع سماوات، وكذلك الأرض كانتا مُرْتَقَةً طبقة واحدة، فجعلها سبع أرضين{14}. (ز) ٤٨٩٧٤- عن محمد بن السائب الكلبي -من طريق مَعْمَر- قوله تعالى: <q>﴿رتقا ففتقناهما﴾</q>، قال: فتق السماء عن الماء، والأرض عن النبات{22}. (ز) ٤٨٩٧٥- قال مقاتل بن سليمان: <q>﴿أولم ير الذين كفروا﴾</q> يقول: أوَلَم يعلم الذين كفروا مِن أهل مكة <q>﴿أن السموات والأرض كانتا رتقا﴾</q> يعني: مُلْتَزِقَيْن، وذلك أنّ الله -تبارك وتعالى- أمر بُخارَ الماء فارتفع، فخلق منه السموات السبع، فأبان إحداهما من الأخرى، فذلك قوله: <q>﴿ففتقناهما﴾</q>{23}. (ز) ٤٨٩٧٦- قال عبد الرحمن بن زيد بن أسلم: كانت السماء رتقًا لا تُمْطِر، والأرضُ رتقًا لا تُنبِت، ففتق السماء بالمطر، والأرض بالنبات{13}. (ز) ٤٨٩٧٧- عن سفيان بن عيينة -من طريق ابن أبي عمر- في قوله: <q>﴿كانتا رتقا ففتقناهما﴾</q>، قال: كانت السماءُ لا تُمْطِر، والأرضُ لا تُنبِت، ففتقت هذه بالمطر، وفتقت هذه بالنبات{25}. (ز) ٤٨٩٧٨- قال سفيان بن عيينة: وقال آخرون: <q>﴿كانتا رتقا﴾</q> إحداهما فوق الأخرى{26}. (ز) ٤٨٩٧٩- قال يحيى بن سلام: <q>﴿ففتقناهما﴾</q> فوضع الأرض، ورفع السماء{27}٤٣٤٢. (ز) ٤٣٤٢ اختُلِف في معنى قوله: <q>﴿كانَتا رَتْقًا فَفَتَقْناهُما﴾</q> على أقوال: الأول: كانت السموات والأرض ملتصقتين، ففتق الله بينهما بالهواء. قاله ابن عباس. والثاني: كانت السماء ملتصقة بعضها ببعض، والأرض كذلك، ففتقهما الله سبعًا سبعًا. قاله مجاهد. والثالث: إنما قيل: <q>﴿ففتقناهما﴾</q> لأن الليل كان قبل النهار، ففتق النهار. والرابع: السماء قبل المطر رتْق، والأرض قبل النبات رتق، ففتقهما تعالى بالمطر والنبات. ورجَّح ابنُ جرير (١٦/٢٥٩) مستندًا إلى السياق القولَ الأخير الذي قاله عكرمة، وعطية، وابن زيد، فقال: «لدلالة قوله: <q>﴿وجعلنا من الماء كل شيء حي﴾</q> على ذلك، وأنه -جلَّ ثناؤه- لم يُعْقِب ذلك بوصف الماء بهذه الصفة إلا والذي تَقَدَّمه من ذكر أسبابه». وعلَّق ابنُ عطية (٦/١٦٣) على هذا القول بقوله: «وهذا قول حسن، يجمع العبرة، وتعديد النعمة، والحجة بمحسوس بيّن، ويناسب قوله: <q>﴿وجَعَلْنا مِنَ الماءِ كُلَّ شَيْءٍ حَيٍّ﴾</q>، أي: مِن الماء الذي أوجده الفتق، فيظهر معنى الآية، ويتوجه الاعتبار». ثم بيّن (٦/١٦٤) أنّ قوله: <q>﴿كانَتا﴾</q> في القولين الأولين بمنزلة قولك: كان زيد حيًّا، أي: لم يكن، وفي القولين الآخرين بمنزلة قولك: كان زيدًا عالمًا، أي: وهو كذلك. <q>﴿وَجَعَلۡنَا مِنَ ٱلۡمَاۤءِ كُلَّ شَیۡءٍ حَیٍّۚ أَفَلَا یُؤۡمِنُونَ ۝٣٠﴾</q> - تفسير ٤٨٩٨٠- عن أبي العالية الرِّياحِيِّ -من طريق الربيع بن أنس- <q>﴿وجعلنا من الماء كل شيء حي﴾</q>، قال: نُطْفَةُ الرَّجُلِ{28}. (١٠/٢٨٨) ٤٨٩٨١- عن الحسن البصري، في قوله: <q>﴿وجعلنا من الماء كل شيء حي﴾</q>، قال: خلق كل شيء من الماء، وهو حياة كل شيء{2}. (١٠/٢٨٨) ٤٨٩٨٢- عن قتادة بن دعامة -من طريق مَعْمَر- في قوله تعالى: <q>﴿من الماء كل شيء حي﴾</q>، قال: كل شيء حي خُلِق مِن الماء{30}. (ز) ٤٨٩٨٣- قال مقاتل بن سليمان: ثم قال سبحانه: <q>﴿وجعلنا من الماء كل شيء حي﴾</q> يقول: وجعلنا الماء حياةَ كل شيء يشربُ الماءَ، <q>﴿أفلا يؤمنون﴾</q> يقول: أفلا يُصَدِّقون بتوحيد الله ﷿ مِمّا يرون مِن صُنْعِهِ!{23}. (ز) ٤٨٩٨٤- قال يحيى بن سلّام: قوله: <q>﴿وجعلنا من الماء كل شيء حي أفلا يؤمنون﴾</q>، يعني: المشركين. وكل شيء حي فإنّما خُلِق مِن الماء{32}. (ز) <q>﴿وَجَعَلۡنَا مِنَ ٱلۡمَاۤءِ كُلَّ شَیۡءٍ حَیٍّۚ أَفَلَا یُؤۡمِنُونَ ۝٣٠﴾</q> - آثار متعلقة بالآية ٤٨٩٨٥- عن أبي هريرة، قال: قلتُ: يا رسول الله، إنِّي إذا رأيتُك طابَتْ نفسي، وقَرَّتْ عيني، فأنبِئْني عن كل شيء. قال: «كلُّ شيء خُلِق مِن الماء»{33}. (١٠/٢٨٨) ",footnotes:1:أخرجه الحاكم ٢/٣٨٢، والبيهقي في الأسماء والصفات (٣٩). وعزاه السيوطي إلى الفريابي، وعبد بن حميد.عزاه السيوطي إلى ابن أبي حاتم.أخرجه ابن جرير ١٦/٢٥٥.أخرجه عبد الرزاق ٢/٢٣. وعزاه السيوطي إلى الفريابي، وعبد حميد، وابن أبي حاتم، وأبي الشيخ.أخرجه ابن أبي حاتم -كما في تفسير ابن كثير ٥/٣٣٢-، وأبو نعيم في الحلية ١/٣٢٠. وعزاه السيوطي إلى ابن المنذر.تفسير الثعلبي ٦/٢٧٤ وفيه: توسطتها، وتفسير البغوي ٥/٣١٦، وفي بعض نسخه: فَوَسَّطَها.أخرجه أبو الشيخ في العظمة (٥٧١).أخرجه أبو الشيخ في العظمة (٥٤٤). وعلَّق يحيى بن سلام ١/٣٠٩ آخره. وعزاه السيوطي إلى ابن أبي شيبة، وعبد بن حميد، وابن المنذر، وابن أبي حاتم.أخرجه يحيى بن سلام ١/٣٠٩.تفسير الثوري ص٢٠٠.علَّقه يحيى بن سلام ١/٣٠٩.أخرجه الثوري ص٢٠٠.تفسير الثعلبي ٦/٢٧٤.تفسير الثعلبي ٦/٢٧٤، وتفسير البغوي ٥/٣١٦.تفسير الثعلبي ٦/٢٧٤، وتفسير البغوي ٥/٣١٦.علَّقه يحيى بن سلام ١/٣٠٨.علَّقه يحيى بن سلام ١/٣٠٨-٣٠٩ بنحوه، وزاد: فجعله بينهن. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.أخرجه أبو الشيخ في العظمة (٥٤٣). وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.أخرجه سعيد بن منصور في سننه - التفسير ٦/٢٩٢ (١٤٤٨).علَّقه يحيى بن سلام ١/٣٠٨.تفسير الثعلبي ٦/٢٧٤، وتفسير البغوي ٥/٣١٦.أخرجه عبد الرزاق ٢/٢٣. وعلَّقه يحيى بن سلام ١/٣٠٨ بلفظ: إنّ السماء كانت رتقًا لا ينزل منها ماء، ففتقها الله بالماء، وفتق الأرض بالنبات.تفسير مقاتل بن سليمان ٣/٧٦.تفسير الثعلبي ٦/٢٧٤.أخرجه إسحاق البستي في تفسيره ص٣٠٠.علَّقه إسحاق البستي في تفسيره ص٣٠١.تفسير يحيى بن سلام ١/٣٠٨.أخرجه البيهقي في الأسماء والصفات (٨٢٦). وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.عزاه السيوطي إلى ابن أبي حاتم.أخرجه عبد الرزاق ٢/٢٣.تفسير مقاتل بن سليمان ٣/٧٦.تفسير يحيى بن سلام ١/٣٠٩.أخرجه أحمد ١٣/٣١٤ (٧٩٣٢)، ١٤/٤٩ (٨٢٩٥، ٨٢٩٦)، ١٦/٢٥٢ (١٠٣٩٩)، وابن حبان ٦/٢٩٩ (٢٥٥٩)، والحاكم ٤/١٧٦ (٧٢٧٨)، ويحيى بن سلام ١/٣٠٩، وابن أبي حاتم -كما في تفسير ابن كثير ٥/٣٤٠-، من طريق قتادة، عن أبي ميمونة، عن أبي هريرة به. قال الحاكم: «هذا حديث صحيح الإسناد، ولم يخرجاه». ووافقه الذهبي. وقال ابن مفلح في الآداب الشرعية ١/٤٢١: «إسناد جيد». وقال الهيثمي في المجمع ٥/١٦ (٧٨٦٥): «رجاله رجال الصحيح، خلا أبي ميمونة، وهو ثقة». وقال البوصيري في إتحاف الخيرة ٥/٤٨١-٤٨٢ (٥٠٥٢): «رواته ثقات». وقال ابن حجر في الفتح ٥/٢٩: «إسناده صحيح». وقال المناوي في التيسير بشرح الجامع الصغير ٢/٢١٤: «إسناده صحيح».
21,31," <q>﴿وَجَعَلۡنَا فِی ٱلۡأَرۡضِ رَوَ ٰ⁠سِیَ أَن تَمِیدَ بِهِمۡ﴾</q> - تفسير ٤٨٩٨٦- قال مقاتل بن سليمان: <q>﴿وجعلنا في الأرض رواسي﴾</q> يعني: الجبال أُرْسِيَت في الأرض، فأُثْبِتَتِ الأرضُ بالجبال؛ <q>﴿أن تميد بهم﴾</q> لِئَلّا تزول الأرضُ بهم{1}. (ز) ٤٨٩٨٧- قال يحيى بن سلّام: قوله: <q>﴿وجعلنا في الأرض رواسي﴾</q> يعني: الجبال؛ <q>﴿أن تميد بهم﴾</q> لأن لا تَحَرَّكَ بهم{2}. (ز) <q>﴿وَجَعَلۡنَا فِیهَا فِجَاجࣰا سُبُلࣰا﴾</q> - تفسير ٤٨٩٨٨- عن عبد الله بن عباس -من طريق ابن جُرَيْج- في قوله: <q>﴿وجعلنا فيها فجاجا سبلا﴾</q>، قال: بين الجبال{3}. (١٠/٢٨٨) ٤٨٩٨٩- عن قتادة بن دعامة، في قوله: <q>﴿فجاجا﴾</q> أي: أعلامًا، <q>﴿سبلا﴾</q> أي: طُرُقًا{4}. (١٠/٢٨٨) ٤٨٩٩٠- قال مقاتل بن سليمان: <q>﴿وجعلنا فيها﴾</q> يعني: في الجبال <q>﴿فجاجا﴾</q> يعني: كل شِعْب في جبل فيه منذ{5} <q>﴿سبلا﴾</q> يعني: طُرُقًا{1}. (ز) ٤٨٩٩١- قال سفيان الثوري، في قوله: <q>﴿وجعلنا فيها فجاجا سبلا﴾</q>، قال: الطرق{7}٤٣٤٣. (ز) ٤٣٤٣ اختُلِف في عود الضمير في قوله تعالى: <q>﴿فِيها﴾</q>؛ فقال قوم بعودته على الرواسي، وقال آخرون بعودته على الأرض. ورجَّح ابنُ جرير (١٦/٢٦٢) القولَ الثاني الذي قاله قتادة مستندًا إلى دلالة العموم، فقال: «لأنها إذا كانت مِن ذكرها دخل في ذلك السهلُ والجبلُ، وذلك أنّ ذلك كله مِن الأرض، وقد جعل الله لخلقه في ذلك كله فجاجًا سبلًا. ولا دلالة تدل على أنه عنى بذلك فجاج بعض الأرض التي جعلها لهم سبلًا دون بعض؛ فالعموم بها أولى». وعلَّق ابنُ عطية (٦/١٦٤) على هذا القول بقوله: «وهو أحسن». <q>﴿لَّعَلَّهُمۡ یَهۡتَدُونَ ۝٣١﴾</q> - تفسير ٤٨٩٩٢- قال إسماعيل السُّدِّيّ: لعلهم يعرفون الطرق{8}. (ز) ٤٨٩٩٣- قال مقاتل بن سليمان: <q>﴿لعلهم يهتدون﴾</q>، يقول: لكي يعرفوا طرقها{1}. (ز) ٤٨٩٩٤- قال يحيى بن سلّام: <q>﴿لعلهم يهتدون﴾</q> لكي يهتدوا الطرق{2}. (ز) ",footnotes:1:تفسير مقاتل بن سليمان ٣/٧٧.تفسير يحيى بن سلام ١/٣٠٩.أخرجه ابن جرير ١٦/٢٦٢. وعزاه السيوطي إلى ابن المنذر.علَّقه يحيى بن سلام ١/٣٠٩. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.كذا في المطبوع، ولعلها: منفذ.تفسير مقاتل بن سليمان ٣/٧٧.تفسير الثوري ص٢٠٠.علَّقه يحيى بن سلام ١/٣١٠.تفسير مقاتل بن سليمان ٣/٧٧.تفسير يحيى بن سلام ١/٣٠٩.
21,32," <q>﴿وَجَعَلۡنَا ٱلسَّمَاۤءَ سَقۡفࣰا مَّحۡفُوظࣰاۖ﴾</q> - تفسير ٤٨٩٩٥- عن مجاهد بن جبر -من طريق ابن أبي نَجِيح- في قوله: <q>﴿وجعلنا السماء سقفا محفوظا﴾</q>، قال: مرفوعًا{1}. (١٠/٢٨٩) ٤٨٩٩٦- عن قتادة بن دعامة -من طريق سعيد- قوله: <q>﴿وجعلنا السماء سقفا محفوظا﴾</q> الآيةَ: سقفًا مرفوعًا، ومَوْجًا مَكْفُوفًا{2}. (ز) ٤٨٩٩٧- قال مقاتل بن سليمان: <q>﴿وجعلنا السماء سقفا﴾</q> يعني: المرفوع <q>﴿محفوظا﴾</q> مِن الشياطين؛ لِئَلّا يسمعوا إلى كلام الملائكة، فيُخْبِروا الناس{3}. (ز) ٤٨٩٩٨- قال يحيى بن سلّام: قوله: <q>﴿وجعلنا السماء سقفا محفوظا﴾</q> على مَن تحتها، محفوظًا مِن كل شيطان رجيم. كقوله: <q>﴿وحفظناها من كل شيطان رجيم﴾</q> [الحجر:١٧]. وإنما كانت هاهنا <q>﴿محفوظًا﴾</q>؛ لأنه قال: <q>﴿سقفا محفوظا﴾</q>، فوقع الحِفْظُ فيها على السقف، وفي الآية الأخرى على السماء{4}. (ز) <q>﴿وَهُمۡ عَنۡ ءَایَـٰتِهَا مُعۡرِضُونَ ۝٣٢﴾</q> - تفسير ٤٨٩٩٩- عن مجاهد بن جبر -من طريق ابن أبي نَجِيح- في قوله: <q>﴿وهم عن آياتها معرضون﴾</q>، قال: الشمس والقمر والنجوم مِن آيات السماء{5}. (١٠/٢٨٩) ٤٩٠٠٠- قال مقاتل بن سليمان: <q>﴿وهم عن آياتها﴾</q> يعني: الشمس والقمر والنجوم وغيرها <q>﴿معرضون﴾</q> فلا يتفكرون فيما يرون مِن صُنعِه ﷿، فيُوَحِّدُونه{3}. (ز) ٤٩٠٠١- قال يحيى بن سلّام: <q>﴿معرضون﴾</q> لا يتفكرون فيما يرون فيها، فيعرفون أنّ لهم معادًا فيؤمنوا. وقال في آية أخرى: <q>﴿قل انظروا ماذا في السموات والأرض وما تغني الآيات والنذر عن قوم لا يؤمنون﴾</q> [يونس:١٠١]{4}. (ز) <q>﴿وَهُمۡ عَنۡ ءَایَـٰتِهَا مُعۡرِضُونَ ۝٣٢﴾</q> - آثار متعلقة بالآية ٤٩٠٠٢- عن عبد الله بن عباس، قال: قال رجل: يا رسول الله، ما هذه السماء؟ قال: «هذا موج مكفوف عنكم»{8}. (١٠/٢٨٩) ",footnotes:1:أخرجه ابن جرير ١٦/٢٦٣-٢٦٤، وأبو الشيخ (٥٥٩). وعزاه السيوطي إلى الفريابي، وابن أبي شيبة، وعبد بن حميد، وابن المنذر، وابن أبي حاتم.أخرجه ابن جرير ١٦/٢٦٣. وأخرجه يحيى بن سلام ١/٣١٠ بلفظ: هي سقف محفوظ، وموج مكفوف. وقوله: «وموجًا مكفوفًا» يوضحه أثر ابن عباس الآتي: «خلَق الله بحرًا دونَ السماء بمقدار ثلاث فراسخ، فهو موجٌ مكفوف، قائمٌ في الهواء بأمر الله، لا يقطُرُ منه قطرة، جارٍ في سرعة السهم ...».تفسير مقاتل بن سليمان ٣/٧٧.تفسير يحيى بن سلام ١/٣١٠.أخرجه يحيى بن سلام ١/٣١٠ من طريق ابن مجاهد، وابن جرير ١٦/٢٦٣-٢٦٤. وعزاه السيوطي إلى الفريابي، وابن أبي شيبة، وعبد بن حميد، وابن المنذر، وابن أبي حاتم، وأبي الشيخ.تفسير مقاتل بن سليمان ٣/٧٧.تفسير يحيى بن سلام ١/٣١٠.أخرجه أبو الشيخ في العظمة ٣/١٠٢٣ (٥٣٩)، والضياء المقدسي في المختارة ١٠/١١٨ (١١٧)، وابن أبي حاتم -كما في تفسير ابن كثير ٥/٣٤٠-٣٤١، من طريق أحمد بن عبد الرحمن بن عبد الله بن سعد، قال: حدثني أبي، عن أبيه، عن الأشعث، عن جعفر بن أبي المغيرة، عن سعيد بن جبير، عن ابن عباس به. قال ابن كثير: «إسناد غريب».
21,33," <q>﴿وَهُوَ ٱلَّذِی خَلَقَ ٱلَّیۡلَ وَٱلنَّهَارَ وَٱلشَّمۡسَ وَٱلۡقَمَرَۖ كُلࣱّ فِی فَلَكࣲ یَسۡبَحُونَ ۝٣٣﴾</q> - قراءات ٤٩٠٠٣- عن الضحاك، قال: كان عبد الله [بن مسعود] يقرأ: (كُلٌّ فِي فَلَكٍ يَعْمَلُونَ){1}. (١٠/٢٩١) <q>﴿وَهُوَ ٱلَّذِی خَلَقَ ٱلَّیۡلَ وَٱلنَّهَارَ وَٱلشَّمۡسَ وَٱلۡقَمَرَۖ كُلࣱّ فِی فَلَكࣲ﴾</q> - تفسير ٤٩٠٠٤- عن عبد الله بن عباس -من طريق علي- في قوله: <q>﴿كل في فلك﴾</q>، قال: دوران{2}. (١٠/٢٨٩) ٤٩٠٠٥- عن عبد الله بن عباس -من طريق سعيد بن جبير- في قوله: <q>﴿كل في فلك﴾</q>، قال: فَلَك كفَلْكَةِ المِغْزَلِ{3}. (١٠/٢٩٠) ٤٩٠٠٦- عن عبد الله بن عباس -من طريق أبي ظبيان- في قوله: <q>﴿كل في فلك﴾</q>، قال: هو فلك السماء{4}. (١٠/٢٩٠) ٤٩٠٠٧- عن عبد الله بن عباس -من طريق عكرمة- قال: خلَق الله بحرًا دونَ السماء بمقدار ثلاث فراسخ، فهو مَوجٌ مكفوف، قائمٌ في الهواء بأمر الله، لا يقطُرُ منه قطرة، جارٍ في سُرْعة السَّهْم، تجرِي فيه الشمس والقمر والنجوم، فذلك قوله: <q>﴿كل في فلك يسبحون﴾</q>. والفلك: دوران العجلة في لُجَّة غَمْرِ ذلك البحر ...{5}. (٦/١٤٦) ٤٩٠٠٨- عن عوف{6} البكالي -من طريق أبي صالح- قال: إنّ السماء خُلِقت مثل القُبَّة، وإنّ الشمس والقمر والنجوم ليس منها شيء لازِق، وإنّها تجري في فَلَك دون السماء، وإنّ أقرب الأرض إلى السماء بيت المقدس باثني عشر ميلًا، وإنّ أبعد الأرض مِن السماء الأُبُلَّة{7}{8}. (ز) ٤٩٠٠٩- عن مجاهد بن جبر -من طريق ابن أبي نَجِيح- في قوله: <q>﴿كل في فلك﴾</q>، قال: الفَلَك: كهيئة حديدة الرَّحى{9}. (١٠/٢٩١) ٤٩٠١٠- عن مجاهد بن جبر -من طريق أبي يحيى- <q>﴿كل في فلك يسبحون﴾</q>، قال: المغزل. قال: كما تدور الفلكة في المغزل{10}. (١٠/٢٩١) ٤٩٠١١- عن مجاهد بن جبر -من طريق عاصم بن حكيم- قال في قوله: <q>﴿الشمس والقمر بحسبان﴾</q> [الرحمن:٥]، قال: حُسْبان كحُسْبان الرَّحى{11}. (ز) ٤٩٠١٢- عن مجاهد بن جبر -من طريق عبد الله بن كثير- في قوله: <q>﴿كل في فلك يسبحون﴾</q>: النجوم والشمس والقمر. قال: كفلكة المغزل. قال: هو مثل حسبان. قال: فلا يدور الغزل إلا بالفلكة، ولا تدور الفلكة إلا بالمغزل، ولا يدور الرحى إلا بالحسبان، ولا يدور الحسبان إلا بالرحى، كذلك النجوم والشمس والقمر لا يَدُمْنَ إلا به، ولا يدوم إلا بِهِنَّ. قال: والحسبان والفلك يصيران إلى شيء واحد، غير أنّ الحسبان في الرحى كالفلكة في المغزل{12}٤٣٤٤. (١٠/٢٩١) ٤٣٤٤ علَّق ابنُ تيمية (٤/٣٧١ بتصرف) على قول مجاهد بقوله: «يعني مجاهدًا: حسبان الرحى، وهو سَفُّودُها القائم الذي يدور عليه ... [و]قوله: لا يدوم إلا به. أي: لا يدور إلا به، ومنه: الدُّوّامة -بالضم والتشديد-، هي فلكة يرميها الصبي بخيط، فتدوم على الأرض، أي: تدور، ومنه: تدويم الطير، وهو تحليقه، وهو دورانه في طيرانه ليرتفع إلى السماء». ٤٩٠١٣- عن الضَّحّاك بن مُزاحِم -من طريق عبيد- في قوله: <q>﴿كل في فلك يسبحون﴾</q>، قال: الفَلَك: الجري والسرعة{13}٤٣٤٥. (ز) ٤٣٤٥ علَّق ابنُ تيمية (٤/٣٧٢) على قول الضحاك بقوله: «يريد أن لفظ»الفلك«يدُلُّ على الاستدارة، وعلى سرعة الحركة، كما في دوران فلكة المغزل، ودوران الرحى». ٤٩٠١٤- عن الحسن البصري -من طريق عمرو بن دينار- في قوله: <q>﴿فِي فَلَكٍ﴾</q>، قال: مثل فَلْكَة المِغْزَل{14}. (ز) ٤٩٠١٥- تفسير الحسن البصري: إنّ الشمس والقمر والنجوم في طاحونة بين السماء والأرض كهيئة فلك المغزل، يدورون فيها، ولو كانت مُلْتَصِقَةً في السماء لم تَجْرِ{15}. (ز) ٤٩٠١٦- عن قتادة بن دعامة -من طريق مَعْمَر- في قوله: <q>﴿كل في فلك يسبحون﴾</q>، قال: يَجْرُون في فلك السماء كما رأيت{16}. (١٠/٢٩١) ٤٩٠١٧- عن حسّان بن عطية -من طريق الأوزاعي- قال: الشمس والقمر والنجوم مُسَخَّرة في فلك بين السماء والأرض تدور{17}. (١٠/٢٩٠) ٤٩٠١٨- عن محمد بن السائب الكلبي -من طريق معمر- قال: كل شيء يدور فهو فَلَك{18}. (١٠/٢٩٠) ٤٩٠١٩- قال محمد بن السائب الكلبي: الفَلَك: استدارة السماء{19}. (ز) ٤٩٠٢٠- قال مقاتل بن سليمان: <q>﴿وهو الذي خلق الليل والنهار والشمس والقمر كل في فلك يسبحون﴾</q>، يقول: يدخلان مِن قِبَل المغرب، فيجريان تحت الأرض، حتى يخرجا مِن قِبَل المشرق، ثم يجريان في السماء إلى المغرب، فذلك قوله سبحانه: <q>﴿كل﴾</q> يعني: الشمس والقمر <q>﴿في فلك﴾</q> يعني: في دَوَران{20}. (ز) ٤٩٠٢١- عن عبد الملك ابن جُرَيْج -من طريق حجاج- <q>﴿كل في فلك﴾</q>، قال: كَنَعْتِ حَدِيدَةِ الرَّحى{13}. (ز) ٤٩٠٢٢- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿كل في فلك يسبحون﴾</q>، قال: الفلك الذي بين السماء والأرض مِن مجاري النجوم والشمس والقمر. وقرأ: <q>﴿تبارك الذي جعل في السماء بروجا وجعل فيها سراجا وقمرا منيرا﴾</q> [الفرقان:٦١]، وقال: تلك البروج بين السماء والأرض، وليست في الأرض. <q>﴿كل في فلك يسبحون﴾</q>، قال: فيما بين السماء والأرض؛ النجوم والشمس والقمر{22}٤٣٤٦. (١٠/٢٩٠) ٤٣٤٦ اختُلِف في الفلك على أقوال: الأول: هو كهيئة حديدة الرحى. والثاني: سرعة جري الشمس والقمر والنجوم وغيرها. والثالث: بل هو القطب الذي تدور به النجوم. والرابع: طاحونة كهيئة فلك المغزل. ورجَّح ابنُ جرير (١٦/٢٦٦-٢٦٧ بتصرف) مستندًا إلى اللغة، وعدم الدليل على التعيين جوازَ تلك الأقوال، فقال: «والصواب من القول في ذلك أن يُقال كما قال الله ﷿: <q>﴿كل في فلك يسبحون﴾</q>، وجائزٌ أن يكون ذلك الفلك كما قال مجاهد: كحديدة الرحى، وكما ذكر عن الحسن: كطاحونة الرحى، وجائز أن يكون موجًا مكفوفًا، وأن يكون قطب السماء. وذلك أنّ الفلك في كلام العرب هو كل شيء دائر، فجمعه: أفلاك ... وإذا كان كل ما دار في كلامها فلكًا، ولم يكن في كتاب الله ولا في خبر عن رسول الله ﷺ ولا عمَّن يقطع قوله العذر دليلٌ يدل على أي ذلك هو من أيٍّ؛ كان الواجب أن نقول فيه ما قال، ونسكت عمّا لا عِلْم لنا به. فإذ كان الصواب في ذلك مِن القول ما ذكرنا فتأويل الكلام: والشمس والقمر كل ذلك في دائر يسبحون». وحكى ابنُ عطية (٦/١٦٥) هذه الأقوال، ثم ذكر أنّ المعنى لا ينبغي التَّسَوُّر عليه، ثم قال: «غير أنّا نعرف أنّ الفلك جسم مستدير». ونقل ابنُ تيمية (٤/٣٧٠) اتفاق أهل التفسير واللغة على أن الفلك: هو المستدير. <q>﴿یَسۡبَحُونَ ۝٣٣﴾</q> - تفسير ٤٩٠٢٣- عن عبد الله بن عباس -من طريق علي- في قوله: <q>﴿يسبحون﴾</q>، قال: يَجْرُون{23}. (١٠/٢٨٩) ٤٩٠٢٤- عن عبد الله بن عباس -من طريق سعيد بن جبير- في قوله: <q>﴿يسبحون﴾</q>، قال: يدورون في أبواب السماء ما تدور الفَلَكَة في المِغْزَل{24}. (١٠/٢٩٠) ٤٩٠٢٥- عن مجاهد بن جبر -من طريق ابن أبي نَجِيح- في قوله: <q>﴿كل في فلك يسبحون﴾</q>، قال: يجرون{25}. (١٠/٢٩٢) ٤٩٠٢٦- عن الضحاك بن مزاحم، <q>﴿كل في فلك يسبحون﴾</q>، قال: يجرون. قال: وكان عبدُ الله يقرأ: (كُلٌّ فِي فَلَكٍ يَعْمَلُونَ){26}. (١٠/٢٩١) ٤٩٠٢٧- عن الضَّحّاك بن مُزاحِم -من طريق عبيد- <q>﴿يسبحون﴾</q>، قال: يعملون{27}. (ز) ٤٩٠٢٨- عن عكرمة مولى ابن عباس، في قوله: <q>﴿كل في فلك يسبحون﴾</q>، قال: هو الدَّوَران{26}. (١٠/٢٩١) ٤٩٠٢٩- عن الحسن البصري -من طريق عمرو- في قوله: <q>﴿يسبحون﴾</q>، قال: يدورون{29}. (ز) ٤٩٠٣٠- عن السري بن يحيى، قال: سأل رجلٌ الحسنَ البصري عن قول الله: <q>﴿كل في فلك يسبحون﴾</q>. قال: يعني: في استدارتهم. وقال بيده{30}. (ز) ٤٩٠٣١- قال محمد بن السائب الكلبي: <q>﴿يسبحون﴾</q> يَجْرُون{31}. (ز) ٤٩٠٣٢- قال مقاتل بن سليمان: <q>﴿يسبحون﴾</q> يعني: يجرون، فذلك دَوَرانهما{20}. (ز) ٤٩٠٣٣- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿يسبحون﴾</q>، قال: يجرون{33}. (١٠/٢٩٢) ",footnotes:1:عزاه السيوطي إلى عبد بن حميد. والقراءة شاذة.أخرجه ابن جرير ١٩/٤٤١، وابن المنذر -كما في الفتح ٨/٤٣٦- بلفظ: يدورون حوله، وابن أبي حاتم -كما في الإتقان ٢/٢٩-.أخرجه ابن جرير ١٩/٤٤٠. وعزاه السيوطي إلى ابن أبي حاتم.أخرجه ابن جرير ١٦/٢٦٥. وعزاه السيوطي إلى ابن أبي شيبة، وابن المنذر، وابن أبي حاتم.أخرجه أبو الشيخ في العظمة (٦٤٧) مطولًا. وأورده السيوطي بطوله ٦/١٤٦.كذا في المطبوع، ولعل الصواب: نوف، فقد ورد هذا السند في المصدر في موضعين آخرين -بعد هذا الموضع - بتسمية هذا الشيخ نوفًا.الأُبُلَّة: بلدة على شاطئ دجلة البصرة. معجم البلدان (الأبلة).أخرجه يحيى بن سلام ١/٣١٠.أخرجه يحيى بن سلام ١/٣١١ من طريق ابن مجاهد، وابن جرير ١٦/٢٦٤-٢٦٥، وابن المنذر -كما في فتح الباري ٨/٤٣٦-. وعزاه السيوطي إلى ابن أبي شيبة، وعبد بن حميد، وابن أبي حاتم.أخرجه يحيى بن سلام ١/٣١١. وعزاه السيوطي إلى عبد بن حميد.أخرجه يحيى بن سلام ١/٣١٢. وحسبان الرحى: هو ما أحاط بها من أطرافها المستديرة. التاج (حسب).أخرجه أبو الشيخ في العظمة (٦٨٥). وعزاه السيوطي إلى ابن أبي حاتم.أخرجه ابن جرير ١٦/٢٦٥.أخرجه ابن عيينة في تفسيره -كما في تغليق التغليق ٤/٢٥٧-. وعلَّقه البخاري ٤/١٧٦٥، وابن جرير ١٦/٢٦٦ بلفظ: الفلك طاحونة كهيئة فلكة المغزل.علَّقه يحيى بن سلام ١/٣١١.أخرجه عبد الرزاق ٢/٢٣-٢٤، وابن جرير ١٦/٢٦٦. وعلَّقه يحيى بن سلام ١/٣١٠. وعزاه السيوطي إلى عبد بن حميد.أخرجه أبو الشيخ في العظمة (٦٣٦). وعزاه السيوطي إلى ابن أبي حاتم.أخرجه عبد الرزاق ٢/٢٣-٢٤. وعزاه السيوطي إلى ابن المنذر.تفسير البغوي ٥/٣١٧.تفسير مقاتل بن سليمان ٣/٧٧.أخرجه ابن جرير ١٦/٢٦٥.أخرجه ابن جرير ١٦/٢٦٦. وعزاه السيوطي إلى ابن أبي حاتم.أخرجه ابن جرير ١٩/٤٤١، وابن المنذر -كما في الفتح ٨/٤٣٦-، وابن أبي حاتم -كما في الإتقان ٢/٢٩-.أخرجه ابن جرير ١٩/٤٤١، وأبو الشيخ في العظمة (٦٥٤). وعزاه السيوطي إلى ابن أبي حاتم.أخرجه ابن جرير ١٦/٢٦٧.عزاه السيوطي إلى عبد بن حميد.أخرجه إسحاق البستي في تفسيره ص٣٠٢.عزاه السيوطي إلى عبد بن حميد.أخرجه ابن عيينة في تفسيره -كما في تغليق التغليق ٤/٢٥٧-. وعلَّقه البخاري (ت: مصطفى البغا) كتاب التفسير - عقِب باب تفسير سورة الأنبياء ٤/١٧٦٥.أخرجه عبد الله بن وهب في الجامع - تفسير القرآن ١/٨٧ (١٩٥).علَّقه يحيى بن سلام ١/٣١٢.تفسير مقاتل بن سليمان ٣/٧٧.أخرجه ابن جرير ١٦/٢٦٧. وعزاه السيوطي إلى ابن أبي حاتم.
21,34," <q>﴿وَمَا جَعَلۡنَا لِبَشَرࣲ مِّن قَبۡلِكَ ٱلۡخُلۡدَۖ أَفَإِی۟ن مِّتَّ فَهُمُ ٱلۡخَـٰلِدُونَ ۝٣٤﴾</q> - نزول الآية ٤٩٠٣٤- قال مقاتل بن سليمان: <q>﴿وما جعلنا لبشر﴾</q>، وذلك أنّ قومًا قالوا: إنّ محمدًا ﷺ لا يموت. فأنزل الله ﷿: <q>﴿وما جعلنا لبشر من قبلك الخلد﴾</q> ... فلمّا نزلت هذه الآيةُ قال النبيُّ صلى الله ﵇: «فمَن يكون في أُمَّتي مِن بعدي؟». فأنزل الله ﷿: <q>﴿أفإن مت فهم الخالدون﴾</q>{1}. (ز) ٤٩٠٣٥- عن عبد الملك ابن جريج قال: لما نعى جبريل ﵇ للنبي ﷺ نفسه، قال: «يا رب، فمن لأمتي؟» فنزلت: <q>﴿وما جعلنا لبشر من قبلك الخلد﴾</q>الآية{2}. (١٠/٢٩٢) <q>﴿وَمَا جَعَلۡنَا لِبَشَرࣲ مِّن قَبۡلِكَ ٱلۡخُلۡدَۖ أَفَإِی۟ن مِّتَّ فَهُمُ ٱلۡخَـٰلِدُونَ ۝٣٤﴾</q> - تفسير الآية ٤٩٠٣٦- قال مقاتل بن سليمان: <q>﴿وما جعلنا لبشر من قبلك الخلد﴾</q> في الدنيا، فلا يموت فيها، بل يموتون ... <q>﴿أفإن مت﴾</q> يعني: محمدًا ﷺ <q>﴿فهم الخالدون﴾</q> فإنهم يموتون أيضًا{3}. (ز) ٤٩٠٣٧- قال يحيى بن سلّام: قوله: <q>﴿وما جعلنا لبشر من قبلك الخلد أفإن مت فهم الخالدون﴾</q> على الاستفهام، أي: لا يُخَلَّدون{4}. (ز) <q>﴿وَمَا جَعَلۡنَا لِبَشَرࣲ مِّن قَبۡلِكَ ٱلۡخُلۡدَۖ أَفَإِی۟ن مِّتَّ فَهُمُ ٱلۡخَـٰلِدُونَ ۝٣٤﴾</q> - آثار متعلقة بالآية ٤٩٠٣٨- عن عائشة، قالت: دخل أبو بكر على النبيِّ ﷺ وقد مات، فقَبَّله، وقال: وانبيّاه! واخليلاه! واصَفِيّاه! ثم تلا: <q>﴿وما جعلنا لبشر من قبلك الخلد﴾</q> الآية، وقوله: <q>﴿إنك ميت وإنهم ميتون﴾</q> [الزمر:٣٠]{5}. (١٠/٢٩٣) ٤٩٠٣٩- عن عبد الله بن عمر، قال: لَمّا قُبِض رسولُ الله ﷺ كان أبو بكر في ناحية المدينة، فجاء، فدخل على رسول الله ﷺ وهو مُسَجًّى، فوضع فاه على جبين رسول الله ﷺ، وجعل يُقَبِّلُه، ويبكي، ويقول: بأبي وأمي، طِبتَ حَيًّا، وطِبْتَ ميِّتًا. فلمّا خرج مرَّ بعمر بن الخطاب، وهو يقول: ما مات رسولُ الله ﷺ، ولا يموت حتى يقتل اللهُ المنافقين، وحتى يُخْزِي اللهُ المنافقين. قال: وكانوا قد استبشروا بموتِ النبي ﷺ، فرفعوا رؤوسهم، فقال: أيها الرجل، اربَع على نفسك، فإنّ رسول الله ﷺ قد مات؛ ألم تسمع الله يقول: <q>﴿إنك ميت وإنهم ميتون﴾</q> [الزمر:٣٠]، وقال: <q>﴿وما جعلنا لبشر من قبلك الخلد أفإن مت فهم الخالدون﴾</q>. قال: ثم أتى المنبر، فصعده، فحمد الله، وأثنى عليه، ثم قال: أيها الناس، إن كان محمدٌ ﷺ إلهكم الذي تعبدون فإنّ محمدًا قد مات، وإن كان إلهكم الذي في السماء فإن إلهكم لم يمت. ثم تلا: <q>﴿وما محمد إلا رسول قد خلت من قبله الرسل أفإن مات أو قُتِل انقلبتم على أعقابكم﴾</q> [آل عمران:١٤٤] حتى ختم الآية، ثم نزل، وقد استبشر المسلمون بذلك، واشْتَدَّ فرحُهم، وأخذت المنافقين الكآبةُ. قال عبد الله بن عمر: فوالَّذي نفسي بيده، لكأنّما كانت على وُجوهنا أغطيةٌ فكُشِفَت{6}. (١٠/٢٩٢) ٤٩٠٤٠- عن عبد الرحمن بن كعب بن مالك: أنّ أبا بكر كتب إلى قبائل العرب المرتدة كتابًا واحدًا، وفيه نحو خطبته في الأثر السابق{7}. (ز) ",footnotes:1:تفسير مقاتل بن سليمان ٣/٧٨ مرسلًا.عزاه السيوطي إلى ابن المنذر مرسلًا.تفسير مقاتل بن سليمان ٣/٧٨.تفسير يحيى بن سلام ١/٣١٢.أخرجه البيهقي في الدلائل ٧/٢١٣-٢١٥، مطولًا. وعزاه السيوطي إلى ابن أبي حاتم، وابن مردويه.أخرجه ابن أبي شيبة ١٤/٥٥٢-٥٥٣، والبزار ١/١٨٢-١٨٣ (١٠٣).أخرجه ابن جرير في تاريخه ٣/٢٥٠ مطولًا.
21,35," <q>﴿كُلُّ نَفۡسࣲ ذَاۤىِٕقَةُ ٱلۡمَوۡتِۗ﴾</q> - تفسير ٤٩٠٤١- قال مقاتل بن سليمان: ثم قال ﷿: <q>﴿كل نفس ذائقة الموت﴾</q>، يعني: النبي ﷺ وغيره{1}. (ز) <q>﴿وَنَبۡلُوكُم بِٱلشَّرِّ وَٱلۡخَیۡرِ فِتۡنَةࣰۖ وَإِلَیۡنَا تُرۡجَعُونَ ۝٣٥﴾</q> - تفسير ٤٩٠٤٢- عن عبد الله بن عباس -من طريق علي- في قوله: <q>﴿ونبلوكم بالشر والخير فتنة﴾</q>، قال: نبتليكم بالشِّدَّة والرخاء، والصحة والسقم، والغِنى والفقر، والحلال والحرام، والطاعة والمعصية، والهدى والضلالة {2}٤٣٤٧. (١٠/٢٩٣) ٤٣٤٧ انتقد ابنُ عطية (٦/١٦٦) ما أفاده قولُ ابن عباس مِن تعميم الخير والشر في كل المذكورات مستندًا إلى الدلالات العقلية، ورجَّح تخصيص الخير والشر بما يصِحُّ أن يكون فتنة وابتلاء، وذلك خيرُ المال وشرُّه، وخير البدَن وشرُّه، فقال: «وأمّا الهدى والضلال فغير داخل في هذا، ولا الطاعة ولا المعصية؛ لأنّ مَن هُدِي فليس نفس هُداه اختبارًا، بل قد تبين خبره، فعلى هذا ففي الخير والشر ما ليس فيه اختبار، كما يوجد أيضًا اختبار بالأوامر والنواهي، وليس بداخل في هذه الآية». ٤٩٠٤٣- عن عبد الله بن عباس -من طريق ابن جُرَيْج- قوله: <q>﴿ونبلوكم بالشر والخير فتنة﴾</q>، قال: بالرخاء والشدة، وكلاهما بلاء{3}. (ز) ٤٩٠٤٤- عن سعيد بن جبير، عن عبد الله بن عباس أنّه قال: ألا تسألني عن آيةٍ فيها مِائةُ آية؟ قال: قلت: ما هي؟ قال: قوله تعالى: <q>﴿وفتناك فتونا﴾</q> [طه:٤٠]. قال: كلُّ شيء أُوتِي مِن خير أو شر كان فتنة. ثم ذكر حين حملت به أمه، وحين وضعته، وحين التقطه آل فرعون، حتى بلغ ما بلغ، ثم قال: ألا ترى قوله: <q>﴿ونبلوكم بالشر والخير فتنة﴾</q>؟!{4}. (ز) ٤٩٠٤٥- قال قتادة بن دعامة: <q>﴿كل نفس ذائقة الموت ونبلوكم بالشر والخير فتنة﴾</q> بالشدة والرخاء{5}. (ز) ٤٩٠٤٦- عن قتادة بن دعامة -من طريق سعيد- قوله: <q>﴿ونبلوكم بالشر والخير فتنة﴾</q> يقول: نبلوكم بالشر بلاء، وبالخير فتنة، <q>﴿وإلينا ترجعون﴾</q>{3}. (ز) ٤٩٠٤٧- قال مقاتل بن سليمان: <q>﴿ونبلوكم﴾</q> يقول: ونختبركم <q>﴿بالشر﴾</q> يعني: بالشِّدَّة لتصبروا <q>﴿و﴾</q>بـ<q>﴿الخير فتنة﴾</q> [يعني]: بالرخاء لتشكروا <q>﴿فتنة﴾</q> يقول: هما بلاء يبتليكم بهما، <q>﴿وإلينا﴾</q> في الآخرة <q>﴿ترجعون﴾</q> بعد الموت فنجزيكم بأعمالكم{1}. (ز) ٤٩٠٤٨- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿ونبلوكم بالشر والخير فتنة وإلينا ترجعون﴾</q>، قال: نبلوهم بما يُحِبُّون وبما يكرهون؛ نختبرهم بذلك لننظر كيف شكرهم فيما يحبون، وكيف صبرهم فيما يكرهون{3}. (ز) ٤٩٠٤٩- قال يحيى بن سلام: <q>﴿فتنة﴾</q> أي: بلاء، أي: اختبار، <q>﴿وإلينا ترجعون﴾</q> يوم القيامة{9}. (ز) ",footnotes:1:تفسير مقاتل بن سليمان ٣/٧٨.أخرجه ابن جرير ١٦/٢٦٩، واللالكائي في السنة (١٠٠٧). وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.أخرجه ابن جرير ١٦/٢٦٩.أخرجه ابن عبد البر في جامع بيان العلم وفضله ١/٤٦٧-٤٦٨.علَّقه يحيى بن سلام ١/٣١٢.أخرجه ابن جرير ١٦/٢٦٩.تفسير مقاتل بن سليمان ٣/٧٨.أخرجه ابن جرير ١٦/٢٦٩.تفسير يحيى بن سلام ١/٣١٢.
