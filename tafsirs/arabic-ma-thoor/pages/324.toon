quran[11]{c,v,t}:
  21,25,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَمَاۤ أَرۡسَلۡنَا مِن قَبۡلِكَ مِن رَّسُولٍ إِلَّا نُوحِیۤ إِلَیۡهِ أَنَّهُۥ لَاۤ إِلَـٰهَ إِلَّاۤ أَنَا۠ فَٱعۡبُدُونِ ۝٢٥﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٨٩٢٠<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿وما أرسلنا من قبلك من رسول إلا نوحي إليه أنه لا إله إلا أنا فاعبدون﴾</span>، قال: أُرْسِلَت الرُّسُلُ بالإخلاص والتوحيد لله، لا يقبل منهم حتى يقولوه ويُقِرُّوا به، والشرائع تختلف؛ في التوراة شريعة، وفي الإنجيل شريعة، وفي القرآن شريعة، حلال وحرام، فهذا كله في الإخلاص لله، وتوحيد الله{1}. (١٠/٢٨٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٩٢١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وما أرسلنا من قبلك من رسول إلا نوحي إليه أنه لا إله إلا أنا فاعبدون﴾</span>، يعني: فوحِّدون{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٩٢٢<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: قوله: <span class="qpc-hafs">﴿وما أرسلنا من قبلك من رسول إلا نوحي إليه أنه لا إله إلا أنا فاعبدون﴾</span>، أي: لا تعبدوا غيري، بذلك أُرسِل الرُّسُلُ جميعًا{3}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَمَاۤ أَرۡسَلۡنَا مِن قَبۡلِكَ مِن رَّسُولٍ إِلَّا نُوحِیۤ إِلَیۡهِ أَنَّهُۥ لَاۤ إِلَـٰهَ إِلَّاۤ أَنَا۠ فَٱعۡبُدُونِ ۝٢٥﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٤٨٩٢٣<span class="dash">-</span></span> عن <span class="name-1">أُبَيِّ بن كعب</span>: أنّهم جمعوا القرآنَ في مصاحف في خلافة أبي بكر، فكان رجال يكتبون، ويُمْلِي عليهم أُبَيُّ بن كعب، فلمّا انتهوا إلى هذه الآية من سورة براءة: <span class="qpc-hafs">﴿ثم انصرفوا صرف الله قلوبهم بأنهم قوم لا يفقهون﴾</span> [التوبة:١٢٧]، فظنوا أنّ هذا آخر ما أنزل من القرآن، فقال لهم أبيُّ بن كعب: إنّ رسول الله ﷺ أقرأني بعدها آيتين: <span class="qpc-hafs">﴿لقد جاءكم رسول من أنفسكم عزيز عليه ما عنتم حريص عليكم بالمؤمنين رءوف رحيم﴾</span> إلى <span class="qpc-hafs">﴿وهو رب العرش العظيم﴾</span> [التوبة:١٢٨-١٢٩]. ثم قال: هذا آخِرُ ما أُنزِلَ من القرآن. قال: فَخُتِمَ بما فُتِحَ به بـ: الله الذي لا إله إلّا هُوَ، وهو قول الله -تبارك وتعالى-: ‹وما أرْسَلْنا مِن قَبْلِكَ مِن رَسُولٍ إلّا يُوحى{4} إلَيْهِ أنَّهُ لا إلَهَ إلّا أنا فاعْبُدُونِ› [الأنبياء:٢٥]{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٩٢٤<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عمرو</span> -من طريق يزيد بن أبي حبيب- قال: إنّ إدريس كان قبل نوح، بعثه الله إلى قومه، يأمرهم أن يقولوا: لا إله إلا الله. ويعملوا ما شاءوا، فأبوا، فأهلكهم الله{6}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ١٦/٢٤٨-٢٥٠. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.تفسير مقاتل بن سليمان ٣/٧٥.تفسير يحيى بن سلّام ١/٣٠٧.كذا في المسند بالياء على قراءة غير حمزة والكسائي وحفص عن عاصم. ينظر: السبعة في القراءات لابن مجاهد ص٤٢٨.أخرجه عبد الله بن أحمد في زوائد المسند ٣٥/١٤٩-١٥٠ (٢١٢٢٦)، وابن أبي حاتم ٦/١٩١٩ (١٠١٧٢)، من طريق أبي جعفر الرازي، عن الربيع بن أنس، عن أبي العالية، عن أبي بن كعب به.</p><p>قال ابن كثير في تفسيره ٤/٢٤٤ عن رواية عبد الله بن أحمد: «غريب». وقال الهيثمي في المجمع ٧/٣٥-٣٦ (١١٠٦٣): «رواه عبد الله بن أحمد، وفيه محمد بن جابر الأنصاري، وهو ضعيف».أخرجه يحيى بن سلّام ١/٣٠٧.
  21,26,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَقَالُوا۟ ٱتَّخَذَ ٱلرَّحۡمَـٰنُ وَلَدࣰاۗ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٨٩٢٥<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- قال: قالت اليهود: إنّ الله ﷿ صاهَر الجن، فكانت بينهم الملائكة{1}. (١٠/٢٨٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٩٢٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وقالوا﴾</span> أي: كُفّار مكة، منهم النضر بن الحارث: <span class="qpc-hafs">﴿اتخذ الرحمن ولدا﴾</span> قالوا: إنّ الملائكة بنات الله تعالى{2}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿سُبۡحَـٰنَهُۥۚ بَلۡ عِبَادࣱ مُّكۡرَمُونَ ۝٢٦﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٨٩٢٧<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- قال: فقال الله تكذيبًا لهم: <span class="qpc-hafs">﴿بل عباد مكرمون﴾</span>، أي: الملائكة ليس كما قالوا، بل هم عباد أكرمهم الله بعبادته{3}. (١٠/٢٨٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٩٢٨<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: فنَزَّه الربُّ جل جلاله نفسه عن قولهم، فقال: <span class="qpc-hafs">﴿سبحانه بل﴾</span> هم يعني: الملائكة <span class="qpc-hafs">﴿عباد مكرمون﴾</span> لعبادة ربهم، وليسوا ببنات الرحمن، ولكن الله أكرمهم بعبادته{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٩٢٩<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: قال الله: <span class="qpc-hafs">﴿سبحانه﴾</span> يُنَزِّه نفسه عما قالوا، <span class="qpc-hafs">﴿بل عباد مكرمون﴾</span> يعني: الملائكة هم كِرام على الله{5}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه يحيى بن سلّام ١/٣٠٧، وابن جرير ١٦/٢٥٠. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.تفسير مقاتل بن سليمان ٣/٧٥.أخرجه ابن جرير ١٦/٢٥٠. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.تفسير مقاتل بن سليمان ٣/٧٥.تفسير يحيى بن سلّام ١/٣٠٧.
  21,27,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿لَا یَسۡبِقُونَهُۥ بِٱلۡقَوۡلِ وَهُم بِأَمۡرِهِۦ یَعۡمَلُونَ ۝٢٧﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٨٩٣٠<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- قال: <span class="qpc-hafs">﴿لا يسبقونه بالقول﴾</span>، يُثْنِي عليهم{1}. (١٠/٢٨٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٩٣١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثم أخبر عن الملائكة، فقال: <span class="qpc-hafs">﴿لا يسبقونه بالقول﴾</span> يعني: الملائكة لا يسبقون ربهم بأمر، يقول: الملائكة لم تأمر كفّار مكة بعبادتهم إيّاها، ثم قال: <span class="qpc-hafs">﴿وهم﴾</span> يعني: الملائكة <span class="qpc-hafs">﴿بأمره يعملون﴾</span> يقول: لا تعمل الملائكةُ إلا بأمره، فأخبر الله ﷿ عن الملائكة أنّهم عباد يخافون ربَّهم، ويُقَدِّسونه، ويعبدونه{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٩٣٢<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: قال الله: <span class="qpc-hafs">﴿لا يسبقونه بالقول﴾</span> فيقولون شيئًا لم يقبلوه عن الله. قال: <span class="qpc-hafs">﴿وهم بأمره يعملون﴾</span>{3}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ١٦/٢٥٠. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.تفسير مقاتل بن سليمان ٣/٧٥.تفسير يحيى بن سلّام ١/٣٠٧.
  21,28,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿یَعۡلَمُ مَا بَیۡنَ أَیۡدِیهِمۡ وَمَا خَلۡفَهُمۡ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٨٩٣٣<span class="dash">-</span></span> تفسير <span class="name-2">إسماعيل السُّدِّيّ</span>: <span class="qpc-hafs">﴿يعلم ما بين أيديهم وما خلفهم﴾</span>، يعني: يعلم ما كان مِن قبل خلق الملائكة، وما كان بعد خلقهم{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٩٣٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿يعلم ما بين أيديهم وما خلفهم﴾</span>، يقول الرب ﷿: يعلم ما كان قبل أن يخلق الملائكة، ويعلم ما كان بعد خلقهم{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٩٣٥<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿يعلم ما بين أيديهم﴾</span> من أمر الآخرة، <span class="qpc-hafs">﴿وما خلفهم﴾</span> من أمر الدنيا إذا كانت الآخرة{3}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَلَا یَشۡفَعُونَ إِلَّا لِمَنِ ٱرۡتَضَىٰ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٨٩٣٦<span class="dash">-</span></span> عن <span class="name-1">جابر بن عبد الله</span>، أنّ رسول الله ﷺ تلا قول الله: <span class="qpc-hafs">﴿ولا يشفعون إلا لمن ارتضى﴾</span>، فقال: «<b>إنّ شفاعتي لأهل الكبائر مِن أُمَّتي</b>»{4}. (١٠/٢٨٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٩٣٧<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، في قوله: <span class="qpc-hafs">﴿إلا لمن ارتضى﴾</span>، قال: الذين ارتضاهم لشهادة أن لا إله إلا الله{5}. (١٠/٢٨٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٩٣٨<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نَجِيح- في قوله: <span class="qpc-hafs">﴿إلا لمن ارتضى﴾</span>، قال: لِمَن رضي عنه{6}. (١٠/٢٨٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٩٣٩<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span>، في قوله: <span class="qpc-hafs">﴿إلا لمن ارتضى﴾</span>، قال: قول: لا إله إلا الله{7}. (١٠/٢٨٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٩٤٠<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دِعامة</span> -من طريق سعيد- قال: <span class="qpc-hafs">﴿ولا يشفعون﴾</span> قال: لا تشفع الملائكة يوم القيامة <span class="qpc-hafs">﴿إلا لمن ارتضى﴾</span> قال: لأهل التوحيد{8}. (١٠/٢٨٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٩٤١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ولا يشفعون إلا لمن ارتضى﴾</span> يقول: لا تشفع الملائكة إلا لِمَن رضي اللهُ أن يشفع له، يعني: مِن أهل التوحيد الذين لا يقولون: إنّ الملائكة بنات الله ﷿؛ لأنّ كُفّار مكَّة زعموا أنّ الملائكة تشفع لهم في الآخرة إلى الله ﷿{2}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَهُم مِّنۡ خَشۡیَتِهِۦ مُشۡفِقُونَ ۝٢٨﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٨٩٤٢<span class="dash">-</span></span> تفسير <span class="name-2">مجاهد بن جبر</span>: <span class="qpc-hafs">﴿وهم من خشيته مشفقون﴾</span>، أي: خائفون{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٩٤٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثم قال سبحانه: [<span class="qpc-hafs">﴿وهم﴾</span> يعني: الملائكة] <span class="qpc-hafs">﴿من خشيته مشفقون﴾</span> يعني: خائفين{2}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَهُم مِّنۡ خَشۡیَتِهِۦ مُشۡفِقُونَ ۝٢٨﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٤٨٩٤٤<span class="dash">-</span></span> عن جابر بن عبد الله، قال: قال النبي ﷺ: «<b>ليلةَ أسري بي مررتُ بجبريل، وهو بالملأ الأعلى، مُلْقىً كالحِلْسِ</b>{12} <b>البالي مِن خشية الله</b>»{13}. (١٠/٢٨٤)</p></p><p></div></p></div>",footnotes:1:علَّقه يحيى بن سلّام ١/٣٠٨.تفسير مقاتل بن سليمان ٣/٧٦.تفسير يحيى بن سلّام ١/٣٠٧.أخرجه الحاكم ٢/٤١٤ (٣٤٤٢)، وأخرجه الترمذي دون الآية ٤/٤٣٤ (٢٦٠٥)، وابن حبان ١٤/٣٨٦ (٦٤٦٧)، من طريق جعفر بن محمد، عن أبيه، عن جابر بن عبد الله به.</p><p>قال الترمذي: «هذا حديث حسن غريب من هذا الوجه». وقال الحاكم: «هذا حديث صحيح، على شرط الشيخين، ولم يخرجاه». وقال الذهبي في التلخيص: «على شرط مسلم».أخرجه ابن جرير ١٦/٢٥٢، والبيهقي في البعث (٢). وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.تفسير مجاهد ص٤٧٠، وأخرجه ابن جرير ١٦/٢٥٣. وعلَّقه يحيى بن سلّام ١/٣٠٨، والبخاري (ت: مصطفى البغا) كتاب التفسير - باب تفسير سورة الأنبياء ٤/١٧٦٦، بلفظ: رَضِيَ. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.عزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ١٦/٢٤٩. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.تفسير مقاتل بن سليمان ٣/٧٦.علَّقه يحيى بن سلّام ١/٣٠٨.تفسير مقاتل بن سليمان ٣/٧٦.الحِلْس: كل ما يلي ظهر البعير، ويُطلق على بساط البيت. اللسان (حلس).أخرجه ابن أبي عاصم في كتاب السنة ١/٢٧٦ (٦٢١)، والطبراني في الأوسط ٥/٦٤ (٤٦٧٩)، من طريق عبيد الله بن عمرو، وموسى بن أعين، عن عبد الكريم، عن عطاء، عن جابر به.</p><p>قال الهيثمي في المجمع ١/٧٨ (٢٤٦): «رجاله رجال الصحيح». وقال السيوطي في الدر ٩/٢٠٧: «سند صحيح». وقال المناوي في التيسير بشرح الجامع الصغير ٢/٣٧٥ عن رواية الطبراني: «إسناده صحيح». وأورده الألباني في الصحيحة ٥/٣٦٢ (٢٢٨٩).
  21,29,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَمَن یَقُلۡ مِنۡهُمۡ إِنِّیۤ إِلَـٰهࣱ مِّن دُونِهِۦ فَذَ ٰ⁠لِكَ نَجۡزِیهِ جَهَنَّمَۚ كَذَ ٰ⁠لِكَ نَجۡزِی ٱلظَّـٰلِمِینَ ۝٢٩﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٨٩٤٥<span class="dash">-</span></span> عن <span class="name-2">الضحاك بن مُزاحم</span> -من طريق عبيد- في قوله: <span class="qpc-hafs">﴿ومن يقل منهم﴾</span> يعني: مِن الملائكة، <span class="qpc-hafs">﴿إني إله من دونه﴾</span> قال: ولم يقل ذلك أحد مِن الملائكة إلا إبليس، دعا إلى عبادة نفسه، وشَرَعَ الكفر{1}. (١٠/٢٨٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٩٤٦<span class="dash">-</span></span> قال <span class="name-2">الحسن البصري</span>: ومن يقل ذلك منهم -إن قالوه-، ولا يقوله أحدٌ منهم. وكان يقول: إنّ إبليس لم يكن منهم{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٩٤٧<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دِعامة</span> -من طريق معمر- في قوله: <span class="qpc-hafs">﴿ومن يقل منهم أني إله من دونه﴾</span> الآية، قال: إنّما كانت هذه خاصة لإبليس{3}. (١٠/٢٨٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٩٤٨<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ومن يقل منهم﴾</span> يعني: مِن الملائكة <span class="qpc-hafs">﴿إني إله من دونه﴾</span> يعني: مِن دون الله ﷿ <span class="qpc-hafs">﴿فذلك﴾</span> يعني: فهذا الذي يقول: إني إله من دونه <span class="qpc-hafs">﴿نجزيه جهنم كذلك نجزي الظالمين﴾</span> النارَ حين زعموا أنّ مع الله ﷿ إلهًا. ولم يقل ذلك أحدٌ مِن الملائكة غير إبليس؛ عدو الله؛ رأس الكفر{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٩٤٩<span class="dash">-</span></span> قال <span class="name-3">سفيان الثوري</span>، في قوله: <span class="qpc-hafs">﴿ومن يقل منهم إني إله من دونه﴾</span>: إبليس{5}<span class=comment-ref>٤٣٣٩</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٤٣٣٩</span> <span class="comment-type-4">ذكر</span> <u>ابنُ جرير</u> (١٦/٢٥٣-٢٥٤) أنّ قائلي هذا القول قالوه لأنّه لم يقل أحد من الملائكة: إني إله، سوى إبليس. و<span class="comment-type-2">انتقد</span> <u>ابنُ عطية</u> (٦/١٦٢) هذا القول الذي قاله قتادة، والضحاك، والثوري <span class="mustanad">مستندًا لواقع الحال</span>، فقال: «وهذا ضعيف؛ لأن إبليس لم يُروَ قطُّ أنّه ادَّعى ربوبية».</div></p><p><h3><span class="qpc-hafs">﴿وَمَن یَقُلۡ مِنۡهُمۡ إِنِّیۤ إِلَـٰهࣱ مِّن دُونِهِۦ فَذَ ٰ⁠لِكَ نَجۡزِیهِ جَهَنَّمَۚ كَذَ ٰ⁠لِكَ نَجۡزِی ٱلظَّـٰلِمِینَ ۝٢٩﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٤٨٩٥٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عكرمة- قال: إنّ الله فَضَّل محمدًا ﷺ على الأنبياء ﵈، وعلى أهل السماء. فقالوا: يا ابن عباس، بِمَ فضَّله على أهل السماء؟ قال: إنّ الله قال لأهل السماء: <span class="qpc-hafs">﴿ومن يقل منهم إني إله من دونه فذلك نجزيه جهنم كذلك نجزي الظالمين﴾</span> الآية، وقال الله تعالى لمحمد ﷺ: <span class="qpc-hafs">﴿إنا فتحنا لك فتحا مبينا ليغفر لك الله ما تقدم من ذنبك وما تأخر﴾</span> [الفتح:١-٢]. قالوا: فما فَضْلُهُ على الأنبياء ﵈؟ قال: قال الله ﷿: <span class="qpc-hafs">﴿وما أرسلنا من رسول إلا بلسان قومه ليبين لهم﴾</span> الآية [إبراهيم:٤]، وقال الله ﷿ لمحمد ﷺ: <span class="qpc-hafs">﴿وما أرسلناك إلا كافة للناس﴾</span> [سبأ:٢٨]، فأرسله إلى الجن والإنس{6}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه إسحاق البستي في تفسيره ص٢٩٩. وعزاه السيوطي إلى ابن أبي حاتم.علَّقه يحيى بن سلام ١/٣٠٨.أخرجه عبد الرزاق ٢/٢٣. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم. وعلَّقه يحيى بن سلام ١/٣٠٨ وزاد: لَمّا قال ما قال دعا إلى عبادة نفسه.تفسير مقاتل بن سليمان ٣/٧٦.تفسير الثوري ص٢٠٠.أخرجه الدارمي ١/١٩٣-١٩٤ (٤٧).
  21,30,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿أَوَلَمۡ یَرَ ٱلَّذِینَ كَفَرُوۤا۟ أَنَّ ٱلسَّمَـٰوَ ٰ⁠تِ وَٱلۡأَرۡضَ كَانَتَا رَتۡقࣰا فَفَتَقۡنَـٰهُمَاۖ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٨٩٥١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطاء- في قوله: <span class="qpc-hafs">﴿كانتا رتقا ففتقناهما﴾</span>، قال: فُتِقَتِ السماء بالغيث، وفُتِقَتِ الأرض بالنبات{1}. (١٠/٢٨٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٩٥٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، في قوله: <span class="qpc-hafs">﴿كانتا رتقا﴾</span> قال: لا يخرج منها شيء، <span class="qpc-hafs">﴿ففتقناهما﴾</span> قال: فُتِقَتِ السماءُ بالمطر، وفُتِقَتِ الأرض بالنبات{2}. (١٠/٢٨٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٩٥٣<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- في قوله: <span class="qpc-hafs">﴿كانتا رتقا﴾</span>، قال: مُلْتَصِقَتَين{3}. (١٠/٢٨٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٩٥٤<span class="dash">-</span></span> عن عكرمة، قال: سُئِل <span class="name-1">عبد الله بن عباس</span> عن الليل؛ كان قبل أم النهار؟ قال: الليل. ثم قرأ: <span class="qpc-hafs">﴿أن السموات والأرض كانتا رتقا ففتقناهما﴾</span>. فهل تعلمون كان بينهما إلا ظُلْمة!{4}. (١٠/٢٨٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٩٥٥<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عمر</span> -من طريق عبد الله بن دينار- أنّ رجلًا أتاه، فسأله عن: <span class="qpc-hafs">﴿السموات والأرض كانتا رتقا ففتقناهما﴾</span>. قال: اذهب إلى ذلك الشيخ، فاسأله، ثم تعال فأخبرني ما قال. فذهب إلى <span class="name-1">ابن عباس</span>، فسأله، قال: نعم، كانت السماء رَتْقًا لا تُمْطِر، وكانت الأرض رَتْقاء لا تُنبِت، فلمّا خلق اللهُ للأرض أهلًا فَتَقَ هذه بالمطر، وفَتَقَ هذه بالنبات. فرجع الرجلُ إلى ابن عمر، فأخبره، فقال ابن عمر: الآن علمتُ أنّ ابن عباس قد أُوتِي في القرآن عِلْمًا، صدق ابنُ عباس، هكذا كانت{5}. (١٠/٢٨٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٩٥٦<span class="dash">-</span></span> قال <span class="name-2">كعب الأحبار</span>: خلق الله السموات والأرض بعضها على بعض، ثم خلق رِيحًا بوَسَطِها، ففتحها بها{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٩٥٧<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span> -من طريق عطاء بن دينار- قال: كانت السموات والأرضون مُلْتَزِقَتَيْنِ، فلمّا رفع الله السماءَ، وأنبذها من الأرض، فكان فَتْقَها الذي ذَكَرَ اللهُ{7}. (١٠/٢٨٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٩٥٨<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نَجِيح- في قوله: <span class="qpc-hafs">﴿كانتا رتقا ففتقناهما﴾</span>، قال: فَتَقَ مِن الأرضِ ستَّ أرضين معها، فتلك سبع أرضين بعضهن تحت بعض، ومن السماء سبع سموات معها، فتلك سبع سموات بعضهن فوق بعض، ولم تكن الأرض والسماء مُتَماسَّتَيْن{8}. (١٠/٢٨٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٩٥٩<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق أبي يحيى- قال: كُنَّ مُنطَبِقات، ففَتَقَهُنَّ{9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٩٦٠<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق خُصَيْف- في قول الله: <span class="qpc-hafs">﴿ففتقناهما﴾</span>، قال: فُتِقَتْ هذه بالماء، وهذه بالنبات{10}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٩٦١<span class="dash">-</span></span> قال يحيى بن سلام: وتفسير <span class="name-2">مجاهد</span>: كُنَّ مُطْبَقات ففَتَقَهُنَّ. أحسبه قال: بالمطر. وقاله غيره. قال <span class="name-2">مجاهد</span>: ولم تكن السماء والأرض مُتماسَّتَيْن{11}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٩٦٢<span class="dash">-</span></span> عن <span class="name-2">الضَّحّاك بن مُزاحِم</span> -من طريق سفيان الثوري- في قوله: <span class="qpc-hafs">﴿كانتا رتقا ففتقناهما﴾</span>، قال: كُنَّ سبعًا ملتزقات، ففتق بعضهن مِن بعض{12}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٩٦٣<span class="dash">-</span></span> قال <span class="name-2">الضحاك بن مزاحم</span>: يعني: كانتا شيئًا واحدًا ملتزقين، فَفَصَل اللهُ بينهما بالهواء{13}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٩٦٤<span class="dash">-</span></span> قال <span class="name-2">عكرمة مولى ابن عباس</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٩٦٥<span class="dash">-</span></span> و<span class="name-2">عطية العوفي</span>: كانت السماء رتقًا لا تُمْطِر، والأرض رتقًا لا تُنبِت، ففتق السماء بالمطر، والأرض بالنبات{14}<span class=comment-ref>٤٣٤٠</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٤٣٤٠</span> <span class="comment-type-4">ذكر</span> <u>ابنُ عطية</u> (٦/١٦٣) أنّ الرؤية على هذا القول رؤية العين، وكذا على قول ابن عباس من طريق عكرمة.</div></p><p><div></p><p><p><span class="item-no">٤٨٩٦٦<span class="dash">-</span></span> قال <span class="name-2">عطاء</span>: كانتا شيئًا واحدًا ملتزقتين، ففصل الله سبحانه بينهما بالهواء{14}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٩٦٧<span class="dash">-</span></span> تفسير <span class="name-2">الحسن البصري:</span> <span class="qpc-hafs">﴿أولم ير الذين كفروا﴾</span> هذا على الخبر{16}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٩٦٨<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٩٦٩<span class="dash">-</span></span> و<span class="name-2">قتادة بن دعامة</span>، في قوله: <span class="qpc-hafs">﴿كانتا رتقا ففتقناهما﴾</span>، قالا: كانتا جمعًا، ففصل الله بينهما بهذا الهواء{17}<span class=comment-ref>٤٣٤١</span>. (١٠/٢٨٧)</p></p><p></div></p><p><div><span class=comment-ref>٤٣٤١</span> <span class="comment-type-4">ذكر</span> <u>ابنُ عطية</u> (٦/١٦٣) أنّه على هذا القول الذي قاله ابن عباس -من طريق علي، والعوفي-، والحسن، وقتادة، وكعب؛ فالرؤية المُوقَف عليها رؤية القلب. وكذا على القول الذي قاله مجاهد، وأبو صالح، والسدي، والضحاك، وعطاء، وسعيد بن جبير، ومقاتل، ويحيى بن سلام.</div></p><p><div></p><p><p><span class="item-no">٤٨٩٧٠<span class="dash">-</span></span> عن <span class="name-2">أبي صالح باذام</span> -من طريق إسماعيل بن أبي خالد- في قوله: <span class="qpc-hafs">﴿كانتا رتقا ففتقناهما﴾</span>، قال: كانت السماء واحدةً، ففتق منها سبع سموات، وكانت الأرض واحدةً، ففتق منها سبع أرضين{18}. (١٠/٢٨٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٩٧١<span class="dash">-</span></span> عن <span class="name-2">محمد بن قيس</span> -من طريق أبي معشر- في قوله ﷿: <span class="qpc-hafs">﴿أولم ير الذين كفروا أن السماوات والأرض كانتا رتقا ففتقناهما وجعلنا من الماء كل شيء حي أفلا يؤمنون﴾</span>، قال: كانت السماءُ لا تُمْطِر، والأرضُ لا تُنبِت، ففتق الله ﷿ السماءَ بالمطر، والأرضَ بالنبات، وجَعَل مِن الماء كل شيء، أفلا يؤمنون{19}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٩٧٢<span class="dash">-</span></span> قال <span class="name-2">إسماعيل السُّدِّيّ</span>: <span class="qpc-hafs">﴿أولم ير﴾</span>، يعني: أوَلَم يعلم الذين كفروا{16}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٩٧٣<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span>: كانت السموات مُرْتَقَةً طبقة واحدة، ففتقها؛ فجعلها سبع سماوات، وكذلك الأرض كانتا مُرْتَقَةً طبقة واحدة، فجعلها سبع أرضين{14}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٩٧٤<span class="dash">-</span></span> عن <span class="name-3">محمد بن السائب الكلبي</span> -من طريق مَعْمَر- قوله تعالى: <span class="qpc-hafs">﴿رتقا ففتقناهما﴾</span>، قال: فتق السماء عن الماء، والأرض عن النبات{22}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٩٧٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿أولم ير الذين كفروا﴾</span> يقول: أوَلَم يعلم الذين كفروا مِن أهل مكة <span class="qpc-hafs">﴿أن السموات والأرض كانتا رتقا﴾</span> يعني: مُلْتَزِقَيْن، وذلك أنّ الله -تبارك وتعالى- أمر بُخارَ الماء فارتفع، فخلق منه السموات السبع، فأبان إحداهما من الأخرى، فذلك قوله: <span class="qpc-hafs">﴿ففتقناهما﴾</span>{23}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٩٧٦<span class="dash">-</span></span> قال <span class="name-3">عبد الرحمن بن زيد بن أسلم</span>: كانت السماء رتقًا لا تُمْطِر، والأرضُ رتقًا لا تُنبِت، ففتق السماء بالمطر، والأرض بالنبات{13}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٩٧٧<span class="dash">-</span></span> عن <span class="name-3">سفيان بن عيينة</span> -من طريق ابن أبي عمر- في قوله: <span class="qpc-hafs">﴿كانتا رتقا ففتقناهما﴾</span>، قال: كانت السماءُ لا تُمْطِر، والأرضُ لا تُنبِت، ففتقت هذه بالمطر، وفتقت هذه بالنبات{25}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٩٧٨<span class="dash">-</span></span> قال سفيان بن عيينة: وقال آخرون: <span class="qpc-hafs">﴿كانتا رتقا﴾</span> إحداهما فوق الأخرى{26}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٩٧٩<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلام</span>: <span class="qpc-hafs">﴿ففتقناهما﴾</span> فوضع الأرض، ورفع السماء{27}<span class=comment-ref>٤٣٤٢</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٤٣٤٢</span> اختُلِف في معنى قوله: <span class="qpc-hafs">﴿كانَتا رَتْقًا فَفَتَقْناهُما﴾</span> على أقوال: <b>الأول</b>: كانت السموات والأرض ملتصقتين، ففتق الله بينهما بالهواء. قاله ابن عباس. <b>والثاني</b>: كانت السماء ملتصقة بعضها ببعض، والأرض كذلك، ففتقهما الله سبعًا سبعًا. قاله مجاهد. <b>والثالث</b>: إنما قيل: <span class="qpc-hafs">﴿ففتقناهما﴾</span> لأن الليل كان قبل النهار، ففتق النهار. <b>والرابع</b>: السماء قبل المطر رتْق، والأرض قبل النبات رتق، ففتقهما تعالى بالمطر والنبات.</p><p>و<span class="comment-type-3">رجَّح</span> <u>ابنُ جرير</u> (١٦/٢٥٩) <span class="mustanad">مستندًا إلى السياق</span> القولَ الأخير الذي قاله عكرمة، وعطية، وابن زيد، فقال: «لدلالة قوله: <span class="qpc-hafs">﴿وجعلنا من الماء كل شيء حي﴾</span> على ذلك، وأنه -جلَّ ثناؤه- لم يُعْقِب ذلك بوصف الماء بهذه الصفة إلا والذي تَقَدَّمه من ذكر أسبابه».</p><p>و<span class="comment-type-4">علَّق</span> <u>ابنُ عطية</u> (٦/١٦٣) على هذا القول بقوله: «وهذا قول حسن، يجمع العبرة، وتعديد النعمة، والحجة بمحسوس بيّن، ويناسب قوله: <span class="qpc-hafs">﴿وجَعَلْنا مِنَ الماءِ كُلَّ شَيْءٍ حَيٍّ﴾</span>، أي: مِن الماء الذي أوجده الفتق، فيظهر معنى الآية، ويتوجه الاعتبار».</p><p>ثم <span class="comment-type-4">بيّن</span> (٦/١٦٤) أنّ قوله: <span class="qpc-hafs">﴿كانَتا﴾</span> في القولين الأولين بمنزلة قولك: كان زيد حيًّا، أي: لم يكن، وفي القولين الآخرين بمنزلة قولك: كان زيدًا عالمًا، أي: وهو كذلك.</div></p><p><h3><span class="qpc-hafs">﴿وَجَعَلۡنَا مِنَ ٱلۡمَاۤءِ كُلَّ شَیۡءٍ حَیٍّۚ أَفَلَا یُؤۡمِنُونَ ۝٣٠﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٨٩٨٠<span class="dash">-</span></span> عن <span class="name-2">أبي العالية الرِّياحِيِّ</span> -من طريق الربيع بن أنس- <span class="qpc-hafs">﴿وجعلنا من الماء كل شيء حي﴾</span>، قال: نُطْفَةُ الرَّجُلِ{28}. (١٠/٢٨٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٩٨١<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span>، في قوله: <span class="qpc-hafs">﴿وجعلنا من الماء كل شيء حي﴾</span>، قال: خلق كل شيء من الماء، وهو حياة كل شيء{2}. (١٠/٢٨٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٩٨٢<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق مَعْمَر- في قوله تعالى: <span class="qpc-hafs">﴿من الماء كل شيء حي﴾</span>، قال: كل شيء حي خُلِق مِن الماء{30}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٩٨٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثم قال سبحانه: <span class="qpc-hafs">﴿وجعلنا من الماء كل شيء حي﴾</span> يقول: وجعلنا الماء حياةَ كل شيء يشربُ الماءَ، <span class="qpc-hafs">﴿أفلا يؤمنون﴾</span> يقول: أفلا يُصَدِّقون بتوحيد الله ﷿ مِمّا يرون مِن صُنْعِهِ!{23}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٩٨٤<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: قوله: <span class="qpc-hafs">﴿وجعلنا من الماء كل شيء حي أفلا يؤمنون﴾</span>، يعني: المشركين. وكل شيء حي فإنّما خُلِق مِن الماء{32}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَجَعَلۡنَا مِنَ ٱلۡمَاۤءِ كُلَّ شَیۡءٍ حَیٍّۚ أَفَلَا یُؤۡمِنُونَ ۝٣٠﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٤٨٩٨٥<span class="dash">-</span></span> عن أبي هريرة، قال: قلتُ: يا رسول الله، إنِّي إذا رأيتُك طابَتْ نفسي، وقَرَّتْ عيني، فأنبِئْني عن كل شيء. قال: «<b>كلُّ شيء خُلِق مِن الماء</b>»{33}. (١٠/٢٨٨)</p></p><p></div></p></div>",footnotes:1:أخرجه الحاكم ٢/٣٨٢، والبيهقي في الأسماء والصفات (٣٩). وعزاه السيوطي إلى الفريابي، وعبد بن حميد.عزاه السيوطي إلى ابن أبي حاتم.أخرجه ابن جرير ١٦/٢٥٥.أخرجه عبد الرزاق ٢/٢٣. وعزاه السيوطي إلى الفريابي، وعبد حميد، وابن أبي حاتم، وأبي الشيخ.أخرجه ابن أبي حاتم -كما في تفسير ابن كثير ٥/٣٣٢-، وأبو نعيم في الحلية ١/٣٢٠. وعزاه السيوطي إلى ابن المنذر.تفسير الثعلبي ٦/٢٧٤ وفيه: توسطتها، وتفسير البغوي ٥/٣١٦، وفي بعض نسخه: فَوَسَّطَها.أخرجه أبو الشيخ في العظمة (٥٧١).أخرجه أبو الشيخ في العظمة (٥٤٤). وعلَّق يحيى بن سلام ١/٣٠٩ آخره. وعزاه السيوطي إلى ابن أبي شيبة، وعبد بن حميد، وابن المنذر، وابن أبي حاتم.أخرجه يحيى بن سلام ١/٣٠٩.تفسير الثوري ص٢٠٠.علَّقه يحيى بن سلام ١/٣٠٩.أخرجه الثوري ص٢٠٠.تفسير الثعلبي ٦/٢٧٤.تفسير الثعلبي ٦/٢٧٤، وتفسير البغوي ٥/٣١٦.تفسير الثعلبي ٦/٢٧٤، وتفسير البغوي ٥/٣١٦.علَّقه يحيى بن سلام ١/٣٠٨.علَّقه يحيى بن سلام ١/٣٠٨-٣٠٩ بنحوه، وزاد: فجعله بينهن. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.أخرجه أبو الشيخ في العظمة (٥٤٣). وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.أخرجه سعيد بن منصور في سننه - التفسير ٦/٢٩٢ (١٤٤٨).علَّقه يحيى بن سلام ١/٣٠٨.تفسير الثعلبي ٦/٢٧٤، وتفسير البغوي ٥/٣١٦.أخرجه عبد الرزاق ٢/٢٣. وعلَّقه يحيى بن سلام ١/٣٠٨ بلفظ: إنّ السماء كانت رتقًا لا ينزل منها ماء، ففتقها الله بالماء، وفتق الأرض بالنبات.تفسير مقاتل بن سليمان ٣/٧٦.تفسير الثعلبي ٦/٢٧٤.أخرجه إسحاق البستي في تفسيره ص٣٠٠.علَّقه إسحاق البستي في تفسيره ص٣٠١.تفسير يحيى بن سلام ١/٣٠٨.أخرجه البيهقي في الأسماء والصفات (٨٢٦). وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.عزاه السيوطي إلى ابن أبي حاتم.أخرجه عبد الرزاق ٢/٢٣.تفسير مقاتل بن سليمان ٣/٧٦.تفسير يحيى بن سلام ١/٣٠٩.أخرجه أحمد ١٣/٣١٤ (٧٩٣٢)، ١٤/٤٩ (٨٢٩٥، ٨٢٩٦)، ١٦/٢٥٢ (١٠٣٩٩)، وابن حبان ٦/٢٩٩ (٢٥٥٩)، والحاكم ٤/١٧٦ (٧٢٧٨)، ويحيى بن سلام ١/٣٠٩، وابن أبي حاتم -كما في تفسير ابن كثير ٥/٣٤٠-، من طريق قتادة، عن أبي ميمونة، عن أبي هريرة به.</p><p>قال الحاكم: «هذا حديث صحيح الإسناد، ولم يخرجاه». ووافقه الذهبي. وقال ابن مفلح في الآداب الشرعية ١/٤٢١: «إسناد جيد». وقال الهيثمي في المجمع ٥/١٦ (٧٨٦٥): «رجاله رجال الصحيح، خلا أبي ميمونة، وهو ثقة». وقال البوصيري في إتحاف الخيرة ٥/٤٨١-٤٨٢ (٥٠٥٢): «رواته ثقات». وقال ابن حجر في الفتح ٥/٢٩: «إسناده صحيح». وقال المناوي في التيسير بشرح الجامع الصغير ٢/٢١٤: «إسناده صحيح».
  21,31,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَجَعَلۡنَا فِی ٱلۡأَرۡضِ رَوَ ٰ⁠سِیَ أَن تَمِیدَ بِهِمۡ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٨٩٨٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وجعلنا في الأرض رواسي﴾</span> يعني: الجبال أُرْسِيَت في الأرض، فأُثْبِتَتِ الأرضُ بالجبال؛ <span class="qpc-hafs">﴿أن تميد بهم﴾</span> لِئَلّا تزول الأرضُ بهم{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٩٨٧<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: قوله: <span class="qpc-hafs">﴿وجعلنا في الأرض رواسي﴾</span> يعني: الجبال؛ <span class="qpc-hafs">﴿أن تميد بهم﴾</span> لأن لا تَحَرَّكَ بهم{2}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَجَعَلۡنَا فِیهَا فِجَاجࣰا سُبُلࣰا﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٨٩٨٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق ابن جُرَيْج- في قوله: <span class="qpc-hafs">﴿وجعلنا فيها فجاجا سبلا﴾</span>، قال: بين الجبال{3}. (١٠/٢٨٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٩٨٩<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span>، في قوله: <span class="qpc-hafs">﴿فجاجا﴾</span> أي: أعلامًا، <span class="qpc-hafs">﴿سبلا﴾</span> أي: طُرُقًا{4}. (١٠/٢٨٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٩٩٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وجعلنا فيها﴾</span> يعني: في الجبال <span class="qpc-hafs">﴿فجاجا﴾</span> يعني: كل شِعْب في جبل فيه منذ{5} <span class="qpc-hafs">﴿سبلا﴾</span> يعني: طُرُقًا{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٩٩١<span class="dash">-</span></span> قال <span class="name-3">سفيان الثوري</span>، في قوله: <span class="qpc-hafs">﴿وجعلنا فيها فجاجا سبلا﴾</span>، قال: الطرق{7}<span class=comment-ref>٤٣٤٣</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٤٣٤٣</span> اختُلِف في عود الضمير في قوله تعالى: <span class="qpc-hafs">﴿فِيها﴾</span>؛ <b>فقال قوم</b> بعودته على الرواسي، <b>وقال آخرون</b> بعودته على الأرض.</p><p>و<span class="comment-type-3">رجَّح</span> <u>ابنُ جرير</u> (١٦/٢٦٢) القولَ الثاني الذي قاله قتادة <span class="mustanad">مستندًا إلى دلالة العموم</span>، فقال: «لأنها إذا كانت مِن ذكرها دخل في ذلك السهلُ والجبلُ، وذلك أنّ ذلك كله مِن الأرض، وقد جعل الله لخلقه في ذلك كله فجاجًا سبلًا. ولا دلالة تدل على أنه عنى بذلك فجاج بعض الأرض التي جعلها لهم سبلًا دون بعض؛ فالعموم بها أولى».</p><p>و<span class="comment-type-4">علَّق</span> <u>ابنُ عطية</u> (٦/١٦٤) على هذا القول بقوله: «وهو أحسن».</div></p><p><h3><span class="qpc-hafs">﴿لَّعَلَّهُمۡ یَهۡتَدُونَ ۝٣١﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٨٩٩٢<span class="dash">-</span></span> قال <span class="name-2">إسماعيل السُّدِّيّ</span>: لعلهم يعرفون الطرق{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٩٩٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿لعلهم يهتدون﴾</span>، يقول: لكي يعرفوا طرقها{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٩٩٤<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿لعلهم يهتدون﴾</span> لكي يهتدوا الطرق{2}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٣/٧٧.تفسير يحيى بن سلام ١/٣٠٩.أخرجه ابن جرير ١٦/٢٦٢. وعزاه السيوطي إلى ابن المنذر.علَّقه يحيى بن سلام ١/٣٠٩. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.كذا في المطبوع، ولعلها: منفذ.تفسير مقاتل بن سليمان ٣/٧٧.تفسير الثوري ص٢٠٠.علَّقه يحيى بن سلام ١/٣١٠.تفسير مقاتل بن سليمان ٣/٧٧.تفسير يحيى بن سلام ١/٣٠٩.
  21,32,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَجَعَلۡنَا ٱلسَّمَاۤءَ سَقۡفࣰا مَّحۡفُوظࣰاۖ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٨٩٩٥<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نَجِيح- في قوله: <span class="qpc-hafs">﴿وجعلنا السماء سقفا محفوظا﴾</span>، قال: مرفوعًا{1}. (١٠/٢٨٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٩٩٦<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- قوله: <span class="qpc-hafs">﴿وجعلنا السماء سقفا محفوظا﴾</span> الآيةَ: سقفًا مرفوعًا، ومَوْجًا مَكْفُوفًا{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٩٩٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وجعلنا السماء سقفا﴾</span> يعني: المرفوع <span class="qpc-hafs">﴿محفوظا﴾</span> مِن الشياطين؛ لِئَلّا يسمعوا إلى كلام الملائكة، فيُخْبِروا الناس{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٩٩٨<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: قوله: <span class="qpc-hafs">﴿وجعلنا السماء سقفا محفوظا﴾</span> على مَن تحتها، محفوظًا مِن كل شيطان رجيم. كقوله: <span class="qpc-hafs">﴿وحفظناها من كل شيطان رجيم﴾</span> [الحجر:١٧]. وإنما كانت هاهنا <span class="qpc-hafs">﴿محفوظًا﴾</span>؛ لأنه قال: <span class="qpc-hafs">﴿سقفا محفوظا﴾</span>، فوقع الحِفْظُ فيها على السقف، وفي الآية الأخرى على السماء{4}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَهُمۡ عَنۡ ءَایَـٰتِهَا مُعۡرِضُونَ ۝٣٢﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٨٩٩٩<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نَجِيح- في قوله: <span class="qpc-hafs">﴿وهم عن آياتها معرضون﴾</span>، قال: الشمس والقمر والنجوم مِن آيات السماء{5}. (١٠/٢٨٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٩٠٠٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وهم عن آياتها﴾</span> يعني: الشمس والقمر والنجوم وغيرها <span class="qpc-hafs">﴿معرضون﴾</span> فلا يتفكرون فيما يرون مِن صُنعِه ﷿، فيُوَحِّدُونه{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٩٠٠١<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿معرضون﴾</span> لا يتفكرون فيما يرون فيها، فيعرفون أنّ لهم معادًا فيؤمنوا. وقال في آية أخرى: <span class="qpc-hafs">﴿قل انظروا ماذا في السموات والأرض وما تغني الآيات والنذر عن قوم لا يؤمنون﴾</span> [يونس:١٠١]{4}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَهُمۡ عَنۡ ءَایَـٰتِهَا مُعۡرِضُونَ ۝٣٢﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٤٩٠٠٢<span class="dash">-</span></span> عن عبد الله بن عباس، قال: قال رجل: يا رسول الله، ما هذه السماء؟ قال: «<b>هذا موج مكفوف عنكم</b>»{8}. (١٠/٢٨٩)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ١٦/٢٦٣-٢٦٤، وأبو الشيخ (٥٥٩). وعزاه السيوطي إلى الفريابي، وابن أبي شيبة، وعبد بن حميد، وابن المنذر، وابن أبي حاتم.أخرجه ابن جرير ١٦/٢٦٣. وأخرجه يحيى بن سلام ١/٣١٠ بلفظ: هي سقف محفوظ، وموج مكفوف.</p><p>وقوله: «وموجًا مكفوفًا» يوضحه أثر ابن عباس الآتي: «خلَق الله بحرًا دونَ السماء بمقدار ثلاث فراسخ، فهو موجٌ مكفوف، قائمٌ في الهواء بأمر الله، لا يقطُرُ منه قطرة، جارٍ في سرعة السهم ...».تفسير مقاتل بن سليمان ٣/٧٧.تفسير يحيى بن سلام ١/٣١٠.أخرجه يحيى بن سلام ١/٣١٠ من طريق ابن مجاهد، وابن جرير ١٦/٢٦٣-٢٦٤. وعزاه السيوطي إلى الفريابي، وابن أبي شيبة، وعبد بن حميد، وابن المنذر، وابن أبي حاتم، وأبي الشيخ.تفسير مقاتل بن سليمان ٣/٧٧.تفسير يحيى بن سلام ١/٣١٠.أخرجه أبو الشيخ في العظمة ٣/١٠٢٣ (٥٣٩)، والضياء المقدسي في المختارة ١٠/١١٨ (١١٧)، وابن أبي حاتم -كما في تفسير ابن كثير ٥/٣٤٠-٣٤١، من طريق أحمد بن عبد الرحمن بن عبد الله بن سعد، قال: حدثني أبي، عن أبيه، عن الأشعث، عن جعفر بن أبي المغيرة، عن سعيد بن جبير، عن ابن عباس به.</p><p>قال ابن كثير: «إسناد غريب».
  21,33,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَهُوَ ٱلَّذِی خَلَقَ ٱلَّیۡلَ وَٱلنَّهَارَ وَٱلشَّمۡسَ وَٱلۡقَمَرَۖ كُلࣱّ فِی فَلَكࣲ یَسۡبَحُونَ ۝٣٣﴾</span> - قراءات</h3></p><p><div></p><p><p><span class="item-no">٤٩٠٠٣<span class="dash">-</span></span> عن الضحاك، قال: كان <span class="name-1">عبد الله [بن مسعود]</span> يقرأ: (كُلٌّ فِي فَلَكٍ يَعْمَلُونَ){1}. (١٠/٢٩١)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَهُوَ ٱلَّذِی خَلَقَ ٱلَّیۡلَ وَٱلنَّهَارَ وَٱلشَّمۡسَ وَٱلۡقَمَرَۖ كُلࣱّ فِی فَلَكࣲ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٩٠٠٤<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- في قوله: <span class="qpc-hafs">﴿كل في فلك﴾</span>، قال: دوران{2}. (١٠/٢٨٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٩٠٠٥<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق سعيد بن جبير- في قوله: <span class="qpc-hafs">﴿كل في فلك﴾</span>، قال: فَلَك كفَلْكَةِ المِغْزَلِ{3}. (١٠/٢٩٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٩٠٠٦<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق أبي ظبيان- في قوله: <span class="qpc-hafs">﴿كل في فلك﴾</span>، قال: هو فلك السماء{4}. (١٠/٢٩٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٩٠٠٧<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عكرمة- قال: خلَق الله بحرًا دونَ السماء بمقدار ثلاث فراسخ، فهو مَوجٌ مكفوف، قائمٌ في الهواء بأمر الله، لا يقطُرُ منه قطرة، جارٍ في سُرْعة السَّهْم، تجرِي فيه الشمس والقمر والنجوم، فذلك قوله: <span class="qpc-hafs">﴿كل في فلك يسبحون﴾</span>. والفلك: دوران العجلة في لُجَّة غَمْرِ ذلك البحر ...{5}. (٦/١٤٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٩٠٠٨<span class="dash">-</span></span> عن <span class="name-2">عوف</span>{6} <span class="name-2">البكالي</span> -من طريق أبي صالح- قال: إنّ السماء خُلِقت مثل القُبَّة، وإنّ الشمس والقمر والنجوم ليس منها شيء لازِق، وإنّها تجري في فَلَك دون السماء، وإنّ أقرب الأرض إلى السماء بيت المقدس باثني عشر ميلًا، وإنّ أبعد الأرض مِن السماء الأُبُلَّة{7}{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٩٠٠٩<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نَجِيح- في قوله: <span class="qpc-hafs">﴿كل في فلك﴾</span>، قال: الفَلَك: كهيئة حديدة الرَّحى{9}. (١٠/٢٩١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٩٠١٠<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق أبي يحيى- <span class="qpc-hafs">﴿كل في فلك يسبحون﴾</span>، قال: المغزل. قال: كما تدور الفلكة في المغزل{10}. (١٠/٢٩١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٩٠١١<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق عاصم بن حكيم- قال في قوله: <span class="qpc-hafs">﴿الشمس والقمر بحسبان﴾</span> [الرحمن:٥]، قال: حُسْبان كحُسْبان الرَّحى{11}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٩٠١٢<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق عبد الله بن كثير- في قوله: <span class="qpc-hafs">﴿كل في فلك يسبحون﴾</span>: النجوم والشمس والقمر. قال: كفلكة المغزل. قال: هو مثل حسبان. قال: فلا يدور الغزل إلا بالفلكة، ولا تدور الفلكة إلا بالمغزل، ولا يدور الرحى إلا بالحسبان، ولا يدور الحسبان إلا بالرحى، كذلك النجوم والشمس والقمر لا يَدُمْنَ إلا به، ولا يدوم إلا بِهِنَّ. قال: والحسبان والفلك يصيران إلى شيء واحد، غير أنّ الحسبان في الرحى كالفلكة في المغزل{12}<span class=comment-ref>٤٣٤٤</span>. (١٠/٢٩١)</p></p><p></div></p><p><div><span class=comment-ref>٤٣٤٤</span> <span class="comment-type-4">علَّق</span> <u>ابنُ تيمية</u> (٤/٣٧١ بتصرف) على قول مجاهد بقوله: «يعني مجاهدًا: حسبان الرحى، وهو سَفُّودُها القائم الذي يدور عليه ... [و]قوله: لا يدوم إلا به. أي: لا يدور إلا به، ومنه: الدُّوّامة -بالضم والتشديد-، هي فلكة يرميها الصبي بخيط، فتدوم على الأرض، أي: تدور، ومنه: تدويم الطير، وهو تحليقه، وهو دورانه في طيرانه ليرتفع إلى السماء».</div></p><p><div></p><p><p><span class="item-no">٤٩٠١٣<span class="dash">-</span></span> عن <span class="name-2">الضَّحّاك بن مُزاحِم</span> -من طريق عبيد- في قوله: <span class="qpc-hafs">﴿كل في فلك يسبحون﴾</span>، قال: الفَلَك: الجري والسرعة{13}<span class=comment-ref>٤٣٤٥</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٤٣٤٥</span> <span class="comment-type-4">علَّق</span> <u>ابنُ تيمية</u> (٤/٣٧٢) على قول الضحاك بقوله: «يريد أن لفظ»الفلك«يدُلُّ على الاستدارة، وعلى سرعة الحركة، كما في دوران فلكة المغزل، ودوران الرحى».</div></p><p><div></p><p><p><span class="item-no">٤٩٠١٤<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق عمرو بن دينار- في قوله: <span class="qpc-hafs">﴿فِي فَلَكٍ﴾</span>، قال: مثل فَلْكَة المِغْزَل{14}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٩٠١٥<span class="dash">-</span></span> تفسير <span class="name-2">الحسن البصري</span>: إنّ الشمس والقمر والنجوم في طاحونة بين السماء والأرض كهيئة فلك المغزل، يدورون فيها، ولو كانت مُلْتَصِقَةً في السماء لم تَجْرِ{15}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٩٠١٦<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق مَعْمَر- في قوله: <span class="qpc-hafs">﴿كل في فلك يسبحون﴾</span>، قال: يَجْرُون في فلك السماء كما رأيت{16}. (١٠/٢٩١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٩٠١٧<span class="dash">-</span></span> عن <span class="name-2">حسّان بن عطية</span> -من طريق الأوزاعي- قال: الشمس والقمر والنجوم مُسَخَّرة في فلك بين السماء والأرض تدور{17}. (١٠/٢٩٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٩٠١٨<span class="dash">-</span></span> عن <span class="name-3">محمد بن السائب الكلبي</span> -من طريق معمر- قال: كل شيء يدور فهو فَلَك{18}. (١٠/٢٩٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٩٠١٩<span class="dash">-</span></span> قال <span class="name-3">محمد بن السائب الكلبي</span>: الفَلَك: استدارة السماء{19}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٩٠٢٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وهو الذي خلق الليل والنهار والشمس والقمر كل في فلك يسبحون﴾</span>، يقول: يدخلان مِن قِبَل المغرب، فيجريان تحت الأرض، حتى يخرجا مِن قِبَل المشرق، ثم يجريان في السماء إلى المغرب، فذلك قوله سبحانه: <span class="qpc-hafs">﴿كل﴾</span> يعني: الشمس والقمر <span class="qpc-hafs">﴿في فلك﴾</span> يعني: في دَوَران{20}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٩٠٢١<span class="dash">-</span></span> عن <span class="name-3">عبد الملك ابن جُرَيْج</span> -من طريق حجاج- <span class="qpc-hafs">﴿كل في فلك﴾</span>، قال: كَنَعْتِ حَدِيدَةِ الرَّحى{13}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٩٠٢٢<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿كل في فلك يسبحون﴾</span>، قال: الفلك الذي بين السماء والأرض مِن مجاري النجوم والشمس والقمر. وقرأ: <span class="qpc-hafs">﴿تبارك الذي جعل في السماء بروجا وجعل فيها سراجا وقمرا منيرا﴾</span> [الفرقان:٦١]، وقال: تلك البروج بين السماء والأرض، وليست في الأرض. <span class="qpc-hafs">﴿كل في فلك يسبحون﴾</span>، قال: فيما بين السماء والأرض؛ النجوم والشمس والقمر{22}<span class=comment-ref>٤٣٤٦</span>. (١٠/٢٩٠)</p></p><p></div></p><p><div><span class=comment-ref>٤٣٤٦</span> اختُلِف في الفلك على أقوال: <b>الأول</b>: هو كهيئة حديدة الرحى. <b>والثاني</b>: سرعة جري الشمس والقمر والنجوم وغيرها. <b>والثالث</b>: بل هو القطب الذي تدور به النجوم. <b>والرابع</b>: طاحونة كهيئة فلك المغزل.</p><p>و<span class="comment-type-3">رجَّح</span> <u>ابنُ جرير</u> (١٦/٢٦٦-٢٦٧ بتصرف) <span class="mustanad">مستندًا إلى اللغة، وعدم الدليل على التعيين</span> جوازَ تلك الأقوال، فقال: «والصواب من القول في ذلك أن يُقال كما قال الله ﷿: <span class="qpc-hafs">﴿كل في فلك يسبحون﴾</span>، وجائزٌ أن يكون ذلك الفلك كما قال مجاهد: كحديدة الرحى، وكما ذكر عن الحسن: كطاحونة الرحى، وجائز أن يكون موجًا مكفوفًا، وأن يكون قطب السماء. وذلك أنّ الفلك في كلام العرب هو كل شيء دائر، فجمعه: أفلاك ... وإذا كان كل ما دار في كلامها فلكًا، ولم يكن في كتاب الله ولا في خبر عن رسول الله ﷺ ولا عمَّن يقطع قوله العذر دليلٌ يدل على أي ذلك هو من أيٍّ؛ كان الواجب أن نقول فيه ما قال، ونسكت عمّا لا عِلْم لنا به. فإذ كان الصواب في ذلك مِن القول ما ذكرنا فتأويل الكلام: والشمس والقمر كل ذلك في دائر يسبحون».</p><p>و<span class="comment-type-4">حكى</span> <u>ابنُ عطية</u> (٦/١٦٥) هذه الأقوال، ثم ذكر أنّ المعنى لا ينبغي التَّسَوُّر عليه، ثم قال: «غير أنّا نعرف أنّ الفلك جسم مستدير».</p><p>و<span class="comment-type-4">نقل</span> <u>ابنُ تيمية</u> (٤/٣٧٠) <span class="mustanad">اتفاق أهل التفسير واللغة</span> على أن الفلك: هو المستدير.</div></p><p><h3><span class="qpc-hafs">﴿یَسۡبَحُونَ ۝٣٣﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٩٠٢٣<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- في قوله: <span class="qpc-hafs">﴿يسبحون﴾</span>، قال: يَجْرُون{23}. (١٠/٢٨٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٩٠٢٤<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق سعيد بن جبير- في قوله: <span class="qpc-hafs">﴿يسبحون﴾</span>، قال: يدورون في أبواب السماء ما تدور الفَلَكَة في المِغْزَل{24}. (١٠/٢٩٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٩٠٢٥<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نَجِيح- في قوله: <span class="qpc-hafs">﴿كل في فلك يسبحون﴾</span>، قال: يجرون{25}. (١٠/٢٩٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٩٠٢٦<span class="dash">-</span></span> عن <span class="name-2">الضحاك بن مزاحم</span>، <span class="qpc-hafs">﴿كل في فلك يسبحون﴾</span>، قال: يجرون. قال: وكان <span class="name-1">عبدُ الله</span> يقرأ: (كُلٌّ فِي فَلَكٍ يَعْمَلُونَ){26}. (١٠/٢٩١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٩٠٢٧<span class="dash">-</span></span> عن <span class="name-2">الضَّحّاك بن مُزاحِم</span> -من طريق عبيد- <span class="qpc-hafs">﴿يسبحون﴾</span>، قال: يعملون{27}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٩٠٢٨<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span>، في قوله: <span class="qpc-hafs">﴿كل في فلك يسبحون﴾</span>، قال: هو الدَّوَران{26}. (١٠/٢٩١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٩٠٢٩<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق عمرو- في قوله: <span class="qpc-hafs">﴿يسبحون﴾</span>، قال: يدورون{29}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٩٠٣٠<span class="dash">-</span></span> عن السري بن يحيى، قال: سأل رجلٌ <span class="name-2">الحسنَ البصري</span> عن قول الله: <span class="qpc-hafs">﴿كل في فلك يسبحون﴾</span>. قال: يعني: في استدارتهم. وقال بيده{30}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٩٠٣١<span class="dash">-</span></span> قال <span class="name-3">محمد بن السائب الكلبي</span>: <span class="qpc-hafs">﴿يسبحون﴾</span> يَجْرُون{31}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٩٠٣٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿يسبحون﴾</span> يعني: يجرون، فذلك دَوَرانهما{20}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٩٠٣٣<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿يسبحون﴾</span>، قال: يجرون{33}. (١٠/٢٩٢)</p></p><p></div></p></div>",footnotes:1:عزاه السيوطي إلى عبد بن حميد.</p><p>والقراءة شاذة.أخرجه ابن جرير ١٩/٤٤١، وابن المنذر -كما في الفتح ٨/٤٣٦- بلفظ: يدورون حوله، وابن أبي حاتم -كما في الإتقان ٢/٢٩-.أخرجه ابن جرير ١٩/٤٤٠. وعزاه السيوطي إلى ابن أبي حاتم.أخرجه ابن جرير ١٦/٢٦٥. وعزاه السيوطي إلى ابن أبي شيبة، وابن المنذر، وابن أبي حاتم.أخرجه أبو الشيخ في العظمة (٦٤٧) مطولًا. وأورده السيوطي بطوله ٦/١٤٦.كذا في المطبوع، ولعل الصواب: نوف، فقد ورد هذا السند في المصدر في موضعين آخرين -بعد هذا الموضع - بتسمية هذا الشيخ نوفًا.الأُبُلَّة: بلدة على شاطئ دجلة البصرة. معجم البلدان (الأبلة).أخرجه يحيى بن سلام ١/٣١٠.أخرجه يحيى بن سلام ١/٣١١ من طريق ابن مجاهد، وابن جرير ١٦/٢٦٤-٢٦٥، وابن المنذر -كما في فتح الباري ٨/٤٣٦-. وعزاه السيوطي إلى ابن أبي شيبة، وعبد بن حميد، وابن أبي حاتم.أخرجه يحيى بن سلام ١/٣١١. وعزاه السيوطي إلى عبد بن حميد.أخرجه يحيى بن سلام ١/٣١٢. وحسبان الرحى: هو ما أحاط بها من أطرافها المستديرة. التاج (حسب).أخرجه أبو الشيخ في العظمة (٦٨٥). وعزاه السيوطي إلى ابن أبي حاتم.أخرجه ابن جرير ١٦/٢٦٥.أخرجه ابن عيينة في تفسيره -كما في تغليق التغليق ٤/٢٥٧-. وعلَّقه البخاري ٤/١٧٦٥، وابن جرير ١٦/٢٦٦ بلفظ: الفلك طاحونة كهيئة فلكة المغزل.علَّقه يحيى بن سلام ١/٣١١.أخرجه عبد الرزاق ٢/٢٣-٢٤، وابن جرير ١٦/٢٦٦. وعلَّقه يحيى بن سلام ١/٣١٠. وعزاه السيوطي إلى عبد بن حميد.أخرجه أبو الشيخ في العظمة (٦٣٦). وعزاه السيوطي إلى ابن أبي حاتم.أخرجه عبد الرزاق ٢/٢٣-٢٤. وعزاه السيوطي إلى ابن المنذر.تفسير البغوي ٥/٣١٧.تفسير مقاتل بن سليمان ٣/٧٧.أخرجه ابن جرير ١٦/٢٦٥.أخرجه ابن جرير ١٦/٢٦٦. وعزاه السيوطي إلى ابن أبي حاتم.أخرجه ابن جرير ١٩/٤٤١، وابن المنذر -كما في الفتح ٨/٤٣٦-، وابن أبي حاتم -كما في الإتقان ٢/٢٩-.أخرجه ابن جرير ١٩/٤٤١، وأبو الشيخ في العظمة (٦٥٤). وعزاه السيوطي إلى ابن أبي حاتم.أخرجه ابن جرير ١٦/٢٦٧.عزاه السيوطي إلى عبد بن حميد.أخرجه إسحاق البستي في تفسيره ص٣٠٢.عزاه السيوطي إلى عبد بن حميد.أخرجه ابن عيينة في تفسيره -كما في تغليق التغليق ٤/٢٥٧-. وعلَّقه البخاري (ت: مصطفى البغا) كتاب التفسير - عقِب باب تفسير سورة الأنبياء ٤/١٧٦٥.أخرجه عبد الله بن وهب في الجامع - تفسير القرآن ١/٨٧ (١٩٥).علَّقه يحيى بن سلام ١/٣١٢.تفسير مقاتل بن سليمان ٣/٧٧.أخرجه ابن جرير ١٦/٢٦٧. وعزاه السيوطي إلى ابن أبي حاتم.
  21,34,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَمَا جَعَلۡنَا لِبَشَرࣲ مِّن قَبۡلِكَ ٱلۡخُلۡدَۖ أَفَإِی۟ن مِّتَّ فَهُمُ ٱلۡخَـٰلِدُونَ ۝٣٤﴾</span> - نزول الآية</h3></p><p><div></p><p><p><span class="item-no">٤٩٠٣٤<span class="dash">-</span></span> قال مقاتل بن سليمان: <span class="qpc-hafs">﴿وما جعلنا لبشر﴾</span>، وذلك أنّ قومًا قالوا: إنّ محمدًا ﷺ لا يموت. فأنزل الله ﷿: <span class="qpc-hafs">﴿وما جعلنا لبشر من قبلك الخلد﴾</span> ... فلمّا نزلت هذه الآيةُ قال النبيُّ صلى الله ﵇: «<b>فمَن يكون في أُمَّتي مِن بعدي؟</b>». فأنزل الله ﷿: <span class="qpc-hafs">﴿أفإن مت فهم الخالدون﴾</span>{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٩٠٣٥<span class="dash">-</span></span> عن عبد الملك ابن جريج قال: لما نعى جبريل ﵇ للنبي ﷺ نفسه، قال: «<b>يا رب، فمن لأمتي</b>؟» فنزلت: <span class="qpc-hafs">﴿وما جعلنا لبشر من قبلك الخلد﴾</span>الآية{2}. (١٠/٢٩٢)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَمَا جَعَلۡنَا لِبَشَرࣲ مِّن قَبۡلِكَ ٱلۡخُلۡدَۖ أَفَإِی۟ن مِّتَّ فَهُمُ ٱلۡخَـٰلِدُونَ ۝٣٤﴾</span> - تفسير الآية</h3></p><p><div></p><p><p><span class="item-no">٤٩٠٣٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وما جعلنا لبشر من قبلك الخلد﴾</span> في الدنيا، فلا يموت فيها، بل يموتون ... <span class="qpc-hafs">﴿أفإن مت﴾</span> يعني: محمدًا ﷺ <span class="qpc-hafs">﴿فهم الخالدون﴾</span> فإنهم يموتون أيضًا{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٩٠٣٧<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: قوله: <span class="qpc-hafs">﴿وما جعلنا لبشر من قبلك الخلد أفإن مت فهم الخالدون﴾</span> على الاستفهام، أي: لا يُخَلَّدون{4}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَمَا جَعَلۡنَا لِبَشَرࣲ مِّن قَبۡلِكَ ٱلۡخُلۡدَۖ أَفَإِی۟ن مِّتَّ فَهُمُ ٱلۡخَـٰلِدُونَ ۝٣٤﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٤٩٠٣٨<span class="dash">-</span></span> عن عائشة، قالت: دخل <span class="name-1">أبو بكر</span> على النبيِّ ﷺ وقد مات، فقَبَّله، وقال: وانبيّاه! واخليلاه! واصَفِيّاه! ثم تلا: <span class="qpc-hafs">﴿وما جعلنا لبشر من قبلك الخلد﴾</span> الآية، وقوله: <span class="qpc-hafs">﴿إنك ميت وإنهم ميتون﴾</span> [الزمر:٣٠]{5}. (١٠/٢٩٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٩٠٣٩<span class="dash">-</span></span> عن عبد الله بن عمر، قال: لَمّا قُبِض رسولُ الله ﷺ كان <span class="name-1">أبو بكر</span> في ناحية المدينة، فجاء، فدخل على رسول الله ﷺ وهو مُسَجًّى، فوضع فاه على جبين رسول الله ﷺ، وجعل يُقَبِّلُه، ويبكي، ويقول: بأبي وأمي، طِبتَ حَيًّا، وطِبْتَ ميِّتًا. فلمّا خرج مرَّ بعمر بن الخطاب، وهو يقول: ما مات رسولُ الله ﷺ، ولا يموت حتى يقتل اللهُ المنافقين، وحتى يُخْزِي اللهُ المنافقين. قال: وكانوا قد استبشروا بموتِ النبي ﷺ، فرفعوا رؤوسهم، فقال: أيها الرجل، اربَع على نفسك، فإنّ رسول الله ﷺ قد مات؛ ألم تسمع الله يقول: <span class="qpc-hafs">﴿إنك ميت وإنهم ميتون﴾</span> [الزمر:٣٠]، وقال: <span class="qpc-hafs">﴿وما جعلنا لبشر من قبلك الخلد أفإن مت فهم الخالدون﴾</span>. قال: ثم أتى المنبر، فصعده، فحمد الله، وأثنى عليه، ثم قال: أيها الناس، إن كان محمدٌ ﷺ إلهكم الذي تعبدون فإنّ محمدًا قد مات، وإن كان إلهكم الذي في السماء فإن إلهكم لم يمت. ثم تلا: <span class="qpc-hafs">﴿وما محمد إلا رسول قد خلت من قبله الرسل أفإن مات أو قُتِل انقلبتم على أعقابكم﴾</span> [آل عمران:١٤٤] حتى ختم الآية، ثم نزل، وقد استبشر المسلمون بذلك، واشْتَدَّ فرحُهم، وأخذت المنافقين الكآبةُ. قال عبد الله بن عمر: فوالَّذي نفسي بيده، لكأنّما كانت على وُجوهنا أغطيةٌ فكُشِفَت{6}. (١٠/٢٩٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٩٠٤٠<span class="dash">-</span></span> عن عبد الرحمن بن كعب بن مالك: أنّ <span class="name-1">أبا بكر</span> كتب إلى قبائل العرب المرتدة كتابًا واحدًا، وفيه نحو خطبته في الأثر السابق{7}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٣/٧٨ مرسلًا.عزاه السيوطي إلى ابن المنذر مرسلًا.تفسير مقاتل بن سليمان ٣/٧٨.تفسير يحيى بن سلام ١/٣١٢.أخرجه البيهقي في الدلائل ٧/٢١٣-٢١٥، مطولًا. وعزاه السيوطي إلى ابن أبي حاتم، وابن مردويه.أخرجه ابن أبي شيبة ١٤/٥٥٢-٥٥٣، والبزار ١/١٨٢-١٨٣ (١٠٣).أخرجه ابن جرير في تاريخه ٣/٢٥٠ مطولًا.
  21,35,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿كُلُّ نَفۡسࣲ ذَاۤىِٕقَةُ ٱلۡمَوۡتِۗ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٩٠٤١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثم قال ﷿: <span class="qpc-hafs">﴿كل نفس ذائقة الموت﴾</span>، يعني: النبي ﷺ وغيره{1}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَنَبۡلُوكُم بِٱلشَّرِّ وَٱلۡخَیۡرِ فِتۡنَةࣰۖ وَإِلَیۡنَا تُرۡجَعُونَ ۝٣٥﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٩٠٤٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- في قوله: <span class="qpc-hafs">﴿ونبلوكم بالشر والخير فتنة﴾</span>، قال: نبتليكم بالشِّدَّة والرخاء، والصحة والسقم، والغِنى والفقر، والحلال والحرام، والطاعة والمعصية، والهدى والضلالة {2}<span class=comment-ref>٤٣٤٧</span>. (١٠/٢٩٣)</p></p><p></div></p><p><div><span class=comment-ref>٤٣٤٧</span> <span class="comment-type-2">انتقد</span> <u>ابنُ عطية</u> (٦/١٦٦) ما أفاده قولُ ابن عباس مِن تعميم الخير والشر في كل المذكورات <span class="mustanad">مستندًا إلى الدلالات العقلية</span>، و<span class="comment-type-3">رجَّح</span> تخصيص الخير والشر بما يصِحُّ أن يكون فتنة وابتلاء، وذلك خيرُ المال وشرُّه، وخير البدَن وشرُّه، فقال: «وأمّا الهدى والضلال فغير داخل في هذا، ولا الطاعة ولا المعصية؛ لأنّ مَن هُدِي فليس نفس هُداه اختبارًا، بل قد تبين خبره، فعلى هذا ففي الخير والشر ما ليس فيه اختبار، كما يوجد أيضًا اختبار بالأوامر والنواهي، وليس بداخل في هذه الآية».</div></p><p><div></p><p><p><span class="item-no">٤٩٠٤٣<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق ابن جُرَيْج- قوله: <span class="qpc-hafs">﴿ونبلوكم بالشر والخير فتنة﴾</span>، قال: بالرخاء والشدة، وكلاهما بلاء{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٩٠٤٤<span class="dash">-</span></span> عن سعيد بن جبير، عن <span class="name-1">عبد الله بن عباس</span> أنّه قال: ألا تسألني عن آيةٍ فيها مِائةُ آية؟ قال: قلت: ما هي؟ قال: قوله تعالى: <span class="qpc-hafs">﴿وفتناك فتونا﴾</span> [طه:٤٠]. قال: كلُّ شيء أُوتِي مِن خير أو شر كان فتنة. ثم ذكر حين حملت به أمه، وحين وضعته، وحين التقطه آل فرعون، حتى بلغ ما بلغ، ثم قال: ألا ترى قوله: <span class="qpc-hafs">﴿ونبلوكم بالشر والخير فتنة﴾</span>؟!{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٩٠٤٥<span class="dash">-</span></span> قال <span class="name-2">قتادة بن دعامة</span>: <span class="qpc-hafs">﴿كل نفس ذائقة الموت ونبلوكم بالشر والخير فتنة﴾</span> بالشدة والرخاء{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٩٠٤٦<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- قوله: <span class="qpc-hafs">﴿ونبلوكم بالشر والخير فتنة﴾</span> يقول: نبلوكم بالشر بلاء، وبالخير فتنة، <span class="qpc-hafs">﴿وإلينا ترجعون﴾</span>{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٩٠٤٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ونبلوكم﴾</span> يقول: ونختبركم <span class="qpc-hafs">﴿بالشر﴾</span> يعني: بالشِّدَّة لتصبروا <span class="qpc-hafs">﴿و﴾</span>بـ<span class="qpc-hafs">﴿الخير فتنة﴾</span> [يعني]: بالرخاء لتشكروا <span class="qpc-hafs">﴿فتنة﴾</span> يقول: هما بلاء يبتليكم بهما، <span class="qpc-hafs">﴿وإلينا﴾</span> في الآخرة <span class="qpc-hafs">﴿ترجعون﴾</span> بعد الموت فنجزيكم بأعمالكم{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٩٠٤٨<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿ونبلوكم بالشر والخير فتنة وإلينا ترجعون﴾</span>، قال: نبلوهم بما يُحِبُّون وبما يكرهون؛ نختبرهم بذلك لننظر كيف شكرهم فيما يحبون، وكيف صبرهم فيما يكرهون{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٩٠٤٩<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلام</span>: <span class="qpc-hafs">﴿فتنة﴾</span> أي: بلاء، أي: اختبار، <span class="qpc-hafs">﴿وإلينا ترجعون﴾</span> يوم القيامة{9}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٣/٧٨.أخرجه ابن جرير ١٦/٢٦٩، واللالكائي في السنة (١٠٠٧). وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.أخرجه ابن جرير ١٦/٢٦٩.أخرجه ابن عبد البر في جامع بيان العلم وفضله ١/٤٦٧-٤٦٨.علَّقه يحيى بن سلام ١/٣١٢.أخرجه ابن جرير ١٦/٢٦٩.تفسير مقاتل بن سليمان ٣/٧٨.أخرجه ابن جرير ١٦/٢٦٩.تفسير يحيى بن سلام ١/٣١٢.