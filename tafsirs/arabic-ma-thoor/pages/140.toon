quran[7]{c,v,t}:
6,95," <q>﴿إِنَّ ٱللَّهَ فَالِقُ ٱلۡحَبِّ وَٱلنَّوَىٰۖ﴾</q> - تفسير ٢٥٦٠٢- عن عبد الله بن عباس -من طريق عطية العوفي- في قوله: <q>﴿فالق الحب والنوى﴾</q>، يقول: خلَق الحبَّ والنَّوى{1}. (٦/١٤٢) ٢٥٦٠٣- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿فالق الحب والنوى﴾</q>، قال: الشَّقّان اللذان فيهما{2}. (٦/١٤٣) ٢٥٦٠٤- عن الضحاك بن مُزاحِم -من طريق جُوَيْبِر- في قوله: <q>﴿إن الله فالق الحب والنوى﴾</q>، قال: خالق الحبِّ والنَّوى{3}. (ز) ٢٥٦٠٥- عن أبي مالك غزوان الغفاري -من طريق حصين- في قوله: <q>﴿فالق الحب والنوى﴾</q>، قال: الشَّقُّ الذي في النواة والحِنطة{4}. (٦/١٤٣) ٢٥٦٠٦- عن الحسن البصري: قوله: <q>﴿إن الله فالق الحب والنوى﴾</q>، يعني: ينفلق عن النبات{5}. (ز) ٢٥٦٠٧- عن الحسن البصري= (ز) ٢٥٦٠٨- وقتادة بن دعامة: معناه: يشق الحبة عن السنبلة، والنواة عن النخلة، فيخرجها منها{6}. (ز) ٢٥٦٠٩- عن قتادة بن دعامة -من طريق معمر- في قوله: <q>﴿فالق الحب والنوى﴾</q>، قال: يفلِقُ الحبَّ والنَّوى عن النبات{7}. (٦/١٤٢) ٢٥٦١٠- عن إسماعيل السُّدِّيّ -من طريق أسباط- في قوله: <q>﴿فالق الحب والنوى﴾</q>، قال: فالقُ الحبة عن السُّنبلة، وفالقُ النواة عن النخلة{8}. (٦/١٤٣) ٢٥٦١١- عن يعقوب، قال: سألتُ زيد بن أسلم عن قول الله: <q>﴿فالق الحب والنوى يخرج الحي من الميت ومخرج الميت من الحي﴾</q>، قال: الحبة قد فلقها، والنواة قد فلقها، فتُزرَع، فيُخرِج منها كما ترى النخل والزرع، والنطفة يُخرِجها ميتة، فيُقِرُّها في رَحِم المرأة، فيُخرِج منها خَلْقًا{9}. (ز) ٢٥٦١٢- قال مقاتل بن سليمان: <q>﴿إن الله فالق الحب﴾</q> يعني: خالق الحب، يعني: البُرَّ، والشعير، والذُّرة، والحبوب كلها. ثم قال: <q>﴿والنوى﴾</q> يعني: كل ثمرة لها نوى؛ الخوخ، والنبق، والمشمش، والعنب، والإجاص، وكل ما كان من الثمار له نوى{10}. (ز) ٢٥٦١٣- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿فالق الحب والنوى﴾</q>، قال: الله فالق ذلك، فلقه فأنبت منه ما أنبت، فلق النواة فأخرج منها نبات نخلة، وفلق الحبة فأخرج نبات الذي خلق{3}٢٣٥٠. (ز) ٢٣٥٠ أفادت الآثار اختلاف المفسرين في معنى: <q>﴿فالِقُ الحَبِّ والنَّوى﴾</q> على ثلاثة أقوال: الأول: شَقَّ الله جميع الحب عن جميع النبات الذي يكون منه، وشق النوى عن جميع الأشجار الكائنة عنه. وهو قول السدي، وقتادة، وابن زيد. الثاني: معنى فالق: خالق. وهو قول ابن عباس من طريق العوفي، والضحاك. الثالث: الشَّقَّ الذي في الحبَّة والنَّواة.وهو قول مجاهد، وأبي مالك. وقد رجَّح ابنُ جرير (٩/٤٢٢) القولَ الأول مستندًا إلى السياق، فقال: «وذلك أنّ الله -جل ثناؤه- أتْبَع ذلك بإخباره عن إخراجه الحي من الميت، والميت من الحي، فكان معلومًا بذلك أنه إنما عنى بإخباره عن نَفْسِه أنّه فالق الحب عن النبات، والنوى عن الغروس والأشجار، كما هو مُخْرِج الحي من الميت، والميت من الحي». ووافقه ابنُ عطية (٣/٤٢٤) مستندًا إلى ظاهر لفظ الآية، فقال: «وهذا هو الظاهر الذي يعطي العبرة التامة». وانتَقَد ابنُ جرير مستندًا إلى مخالفة لغة العرب قول الضحاك، وابن عباس من طريق العوفي، فقال: «وأمّا القول الذي حُكِي عن الضحاك في معنى فالق: أنّه خالق؛ فقولٌ -إن لم يكن أراد به أنّه خالقٌ منه النبات والغروس بِفَلْقِه إياه- لا أعرف له وجْهًا؛ لأنه لا يُعْرَف في كلام العرب: فَلَقَ الله الشيء، بمعنى: خَلَق». وانتقد ابنُ عطية مستندًا لدلالة العقل القولَ الثالث، فقال: «والعبرة على هذا القول مخصوصةً في بعض الحَبِّ وبعض النَّوى، وليس لذلك وجْه». <q>﴿یُخۡرِجُ ٱلۡحَیَّ مِنَ ٱلۡمَیِّتِ وَمُخۡرِجُ ٱلۡمَیِّتِ مِنَ ٱلۡحَیِّۚ﴾</q> - تفسير ٢٥٦١٤- عن عبيد الله بن عبد الله: أنّ خالدة بنت الأسود بن عبد يغوث دخلت على رسول الله ﷺ وهو عند بعض نسائه، فقال: «مَن هذه؟». قيل: إحدى خالاتك، يا رسول الله. قال: «إنّ خالاتي بهذه البلدة لغرائب، فمن هي؟». قيل: خالدة بنت الأسود بن عبد يغوث. فقال: «سبحان الله! <q>﴿يخرج الحي من الميت﴾</q>»{12}. (ز) ٢٥٦١٥- قال عمر بن الخطاب -من طريق سلمان-: خَمَّر الله ﷿ طينة آدم أربعين يومًا، ثم وضع يده فيها، فارتفع على هذه كُلُّ طيب، وعلى هذه كُلُّ خبيث، ثم خلط بعضه ببعض -وقال مؤمل بيده هكذا-، ودمج إحداهما بالأخرى، ثم خلق منها آدم، فمن ثم <q>﴿يخرج الحي من الميت ومخرج الميت من الحي﴾</q>؛ يخرج المؤمن من الكافر، ويخرج الكافر من المؤمن{13}. (ز) ٢٥٦١٦- عن الحسن البصري= (ز) ٢٥٦١٧- وقتادة بن دعامة، نحو ذلك{14}. (ز) ٢٥٦١٨- عن عبد الله بن مسعود -من طريق إبراهيم- قوله: <q>﴿ومخرج الميت من الحي﴾</q>، قال: يخرج النطفة الميتة من الرجل الحي{15}. (ز) ٢٥٦١٩- عن عبد الله بن عباس -من طريق علي بن أبي طلحة- قوله: <q>﴿إن الله فالق الحب والنوى يخرج الحي من الميت ومخرج الميت من الحي﴾</q>، قال: يخرج النطفة الميتة من الحي، ثم يخرج من النطفة بشرًا حيًّا{16}. (ز) ٢٥٦٢٠- عن أبي سعيد الخدري= (ز) ٢٥٦٢١- وسعيد بن جبير= (ز) ٢٥٦٢٢- وإبراهيم النخعي= (ز) ٢٥٦٢٣- والضحاك بن مزاحم= (ز) ٢٥٦٢٤- وقتادة بن دعامة= (ز) ٢٥٦٢٥- وإسماعيل السُّدِّيّ، نحو ذلك{14}. (ز) ٢٥٦٢٦- عن مجاهد بن جبر -من طريق ابن أبي نَجِيح- في قوله: <q>﴿يخرج الحي من الميت ومخرج الميت من الحي﴾</q>، قال: الناسَ الأحياء من النُّطف، والنُّطفةَ ميِّتةً تُخرَجُ من الناس الأحياء، ومن الأنعام والنبات كذلك أيضًا{18}. (٦/١٤٣) ٢٥٦٢٧- عن عكرمة مولى ابن عباس -من طريق أبي المنيب- <q>﴿يخرج الحي من الميت ومخرج الميت من الحي﴾</q>، قال: البيضة تخرج من الحي وهي ميتة، ثم يخرج منها الحي{15}. (ز) ٢٥٦٢٨- عن أبي مالك غزوان الغفاري -من طريق السدي- في قوله: <q>﴿يخرج الحي من الميت﴾</q> قال: النخلةَ من النواة، والسُّنبلةَ من الحبة، <q>﴿ومخرج الميت من الحي﴾</q> قال: النواة من النخلة، والحبة من السُّنبلة{20}. (٦/١٤٣) ٢٥٦٢٩- عن إسماعيل السُّدِّيّ -من طريق أسباط- قال: أما <q>﴿يخرج الحي من الميت﴾</q> فيخرج السنبلة الحيَّة من الحبَّة الميتة، ويخرج الحبَّة الميتة من السنبلة الحيَّة، ويخرج النخلة الحيَّة من النواة الميتة، ويخرج النواة الميتة من النخلة الحية{21}٢٣٥١. (ز) ٢٣٥١ وجَّه ابنُ عطية (٣/٤٢٥) قول السدي وأبي مالك بقوله: «فكأنّه جعل الخضرة والنضارة حياة، واليَبْسَ موتًا». ورجَّح ابنُ جرير (٩/٤٢٤) مستندًا إلى السياق في معنى: <q>﴿يُخْرِجُ الحَيَّ مِنَ المَيِّتِ ومُخْرِجُ المَيِّتِ مِنَ الحَيِّ﴾</q> قولَ السدي، وأبي مالك، وبيَّن علَّة ذلك، فقال: «وإنّما اخترنا التأويل الذي اخترنا في ذلك لأنّه عَقِيب قوله: <q>﴿إنَّ اللَّهَ فالِقُ الحَبِّ والنَّوى﴾</q>». ورأى قولَ ابن عباس من طريق علي بن أبي طلحة داخلًا تحت عموم اللفظ، فقال: «على أنّ قوله: <q>﴿يُخْرِجُ الحَيَّ مِنَ المَيِّتِ ومُخْرِجُ المَيِّتِ مِنَ الحَيِّ﴾</q> وإن كان خبرًا من الله عن إخراجه من الحبّ السنبل، ومن السنبل الحبّ؛ فإنه داخلٌ في عمومه ما رُوِي عن ابن عباس في تأويل ذلك: وكلُّ ميتٍ أخرجه الله من جسمٍ حيٍّ، وكلُّ حيّ أخرجه الله من جسمٍ ميتٍ». ورجَّح ابنُ عطية (٣/٤٢٥) قول ابن عباس، ولم يذكر مستندًا، ثم علَّق بعد إيراد القولين بقوله: «وهما على هذا التأويل الراجح معنيان متباينان، فيهما معتبر». ٢٥٦٣٠- قال مقاتل بن سليمان: <q>﴿يخرج الحي من الميت﴾</q> يقول: أخرج الناس والدواب من النُّطَف وهي ميتة، ويخرج الطير كلها من البيضة وهي ميتة، ثم قال: <q>﴿ومخرج الميت من الحي﴾</q> يعني: النطف والبيض من الحي، يعني: الحيوانات كلها{22}. (ز) <q>﴿یُخۡرِجُ ٱلۡحَیَّ مِنَ ٱلۡمَیِّتِ وَمُخۡرِجُ ٱلۡمَیِّتِ مِنَ ٱلۡحَیِّۚ﴾</q> - آثار متعلقة بالآية ٢٥٦٣١- عن شهر بن حوشب -من طريق شبيل بن غرزة - قال: لما أُري إبراهيم ﵇ ملكوت السماوات والأرض رأى رجلًا يعصي الله، فدعا عليه فهَلَك، ثم آخر، ثم آخر فدعا عليهم فهلكوا، فنُودي: يا صاحب الدعوة، إني قد خلقت ابن آدم لثلاث: أُخرج منه ذُرِّيَّةً تعبدني، وتلا:<q>﴿يُخْرِجُ الحَيَّ مِنَ المَيِّتِ ويُخْرِجُ المَيِّتَ مِنَ الحَيِّ﴾</q> [الروم: ١٩]، ويتوب إلى ما بينه وبين الهرم فأتوب عليه، ولا تأخذني عجلة العباد، أو يتمادى فالنار من ورائه{23}.(ز) (ز) <q>﴿ذَ ٰ⁠لِكُمُ ٱللَّهُۖ فَأَنَّىٰ تُؤۡفَكُونَ ۝٩٥﴾</q> - تفسير ٢٥٦٣٢- عن عبد الله بن عباس -من طريق الضحاك- في قوله: <q>﴿فأنى تؤفكون﴾</q>، قال: كيف تُكَذِّبون؟!{18}. (٦/١٤٤) ٢٥٦٣٣- عن الحسن البصري -من طريق مَعْمَر- في قوله: <q>﴿فأنى تؤفكون﴾</q>، قال: أنّى تُصرَفون؟!{18}. (٦/١٤٤) ٢٥٦٣٤- عن إسماعيل السُّدِّيّ، في قوله: <q>﴿فأنى تؤفكون﴾</q>، قال: كيف تَضِلُّ عقولُكم عن هذا؟!{26}. (٦/١٤٤) ٢٥٦٣٥- قال مقاتل بن سليمان: <q>﴿ذلكم الله﴾</q> الذي ذكر في هذه الآية مِن صنعه وحْدَه، يدُلُّ على توحيده بصنعه، <q>﴿فأنى تؤفكون﴾</q> يقول: أنى يُكَذِّبون بأنّ الله وحده لا شريك له؟!{27}. (ز) ",footnotes:1:أخرجه ابن جرير ٩/٤٢١، وابن أبي حاتم ٤/١٣٥١.تفسير مجاهد ص٣٢٦، وأخرجه ابن جرير ٩/٤٢١، وابن أبي حاتم ٤/١٣٥١. وعزاه السيوطي إلى ابن أبي شيبة، وعَبد بن حُمَيد، وابن المنذر، وأبي الشيخ.أخرجه ابن جرير ٩/٤٢١.أخرجه سعيد بن منصور (٨٩١ - تفسير)، وابن جرير ٩/٤٢٢. وعزاه السيوطي إلى ابن المنذر.ذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٢/٨٦-.تفسير البغوي ٣/١٧٠.أخرجه عبد الرزاق ١/٢١٤، وابن جرير ٩/٤٢٠، وابن أبي حاتم ٤/١٣٥١. وعزاه السيوطي إلى ابن المنذر، وأبي الشيخ.أخرجه ابن جرير ٩/٤٢٠، وابن أبي حاتم ٤/١٣٥١.أخرجه عبد الله بن وهب في الجامع - تفسير القرآن ٢/١٢٤ (٢٤٦).تفسير مقاتل بن سليمان ١/٥٧٩.أخرجه ابن جرير ٩/٤٢١.أخرجه الطبراني في الكبير ٢٥/٩٦ (٢٤٨)، وابن أبي حاتم ٢/٦٢٦ (٣٣٦٠)، ٤/١٣٥١ (٧٦٥٥) واللفظ له مرسلًا. قال الهيثمي في المجمع ٩/٢٦٤ (١٥٤٣٧): «رواه كله الطبراني بإسنادين، وإسناد الثاني حسن».أخرجه ابن أبي حاتم ٤/١٣٥١-١٣٥٢.علَّقه ابن أبي حاتم ٤/١٣٥٢.أخرجه ابن أبي حاتم ٤/١٣٥٢.أخرجه ابن جرير ٩/٤٢٣، وابن أبي حاتم ٤/١٣٥٢.علَّقه ابن أبي حاتم ٤/١٣٥٢.أخرجه ابن أبي حاتم ٤/١٣٥٣.أخرجه ابن أبي حاتم ٤/١٣٥٢.أخرجه ابن جرير ٩/٤٢٣، وابن أبي حاتم ٤/١٣٥٢-١٣٥٣. وعزاه السيوطي إلى عبد بن حميد، وأبي الشيخ.أخرجه ابن جرير ٩/٤٢٣.تفسير مقاتل بن سليمان ١/٥٧٩-٥٨٠.أخرجه ابن أبي الدنيا في كتاب «حسن الظن بالله» -موسوعة الإمام ابن أبي الدنيا (١/٩٦) رقم (٨٨).أخرجه ابن أبي حاتم ٤/١٣٥٣.أخرجه ابن أبي حاتم ٤/١٣٥٣.عزاه السيوطي إلى ابن أبي حاتم.تفسير مقاتل بن سليمان ١/٥٨٠.
6,96," <q>﴿فَالِقُ ٱلۡإِصۡبَاحِ﴾</q> - تفسير ٢٥٦٣٦- عن عبد الله بن عباس -من طريق عطية العوفي- في قوله: <q>﴿فالق الإصباح﴾</q>، قال: خالق الليل والنهار{1}. (٦/١٤٤) ٢٥٦٣٧- عن عبد الله بن عباس -من طريق علي بن أبي طلحة- في قوله: <q>﴿فالق الإصباح﴾</q>، قال: يعني بالإصباح: ضوءَ الشمس بالنهار، وضوءَ القمر بالليل{2}. (٦/١٤٤) ٢٥٦٣٨- عن مجاهد بن جبر -من طريق ابن أبي نَجِيح- في قوله: <q>﴿فالق الإصباح﴾</q>، قال: إضاءة الفجر{3}. (٦/١٤٤) ٢٥٦٣٩- عن الضحاك بن مزاحم -من طريق عبيد بن سليمان- في قوله: <q>﴿فالق الإصباح﴾</q>، قال: خالقُ النور؛ نور النهار{4}. (٦/١٤٥) ٢٥٦٤٠- عن الضحاك بن مزاحم -من طريق جُوَيْبِر- قال: <q>﴿فالق الإصباح﴾</q>، قال: إضاءة الصبح{5}. (ز) ٢٥٦٤١- عن قتادة بن دعامة -من طريق مَعْمَر- في قوله: <q>﴿فالق الإصباح﴾</q>، قال: فالقُ الصبح{6}. (٦/١٤٤) ٢٥٦٤٢- قال مقاتل بن سليمان: ثم ذكر أيضًا في هذه مِن صنعه لِيَدُلَّ على توحيده بصنعه، فقال: <q>﴿فالق الإصباح﴾</q> يعني: خالق النهار من حين يبدو أوَّلُه{7}. (ز) ٢٥٦٤٣- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿فالق الإصباح﴾</q>، قال: فلق الإصباح عن الليل{8}. (ز) <q>﴿وَجَعَلَ ٱلَّیۡلَ سَكَنࣰا﴾</q> - تفسير ٢٥٦٤٤- عن قتادة بن دعامة -من طريق سعيد بن بشير- في قوله: ‹وجاعِلُ اللَّيْلِ سَكَنًا›، قال: يسكُنُ فيه كلُّ طير ودابة{9}. (٦/١٤٥) ٢٥٦٤٥- قال مقاتل بن سليمان: <q>﴿وجعل الليل سكنا﴾</q> لخلقه، يسكنون فيه لراحة أجسادهم{7}. (ز) <q>﴿وَٱلشَّمۡسَ وَٱلۡقَمَرَ حُسۡبَانࣰاۚ ذَ ٰ⁠لِكَ تَقۡدِیرُ ٱلۡعَزِیزِ ٱلۡعَلِیمِ ۝٩٦﴾</q> - تفسير ٢٥٦٤٦- عن عبد الله بن عباس -من طريق علي بن أبي طلحة- في قوله: <q>﴿والشمس والقمر حسبانا﴾</q>، يعني: عدد الأيام، والشهور، والسنين{11}. (٦/١٤٥) ٢٥٦٤٧- عن عبد الله بن عباس -من طريق عطية العوفي- <q>﴿والشمس والقمر حسبانا﴾</q>، قال: يجريان إلى أجل جُعِل لهما{12}. (ز) ٢٥٦٤٨- عن مجاهد بن جبر -من طريق ابن جُرَيْج- <q>﴿والشمس والقمر حسبانا﴾</q>، قال: هو مثل قوله: <q>﴿كل في فلك يسبحون﴾</q> [يس:٤٠]، ومثل قوله: و<q>﴿الشمس والقمر بحسبان﴾</q> [الرحمن:٥]{13}. (ز) ٢٥٦٤٩- عن قتادة بن دعامة -من طريق مَعْمَر- في قوله: <q>﴿والشمس والقمر حسبانا﴾</q>، قال: يدوران في حساب{14}. (٦/١٤٥) ٢٥٦٥٠- عن قتادة بن دعامة -من طريق سعيد بن بشير- <q>﴿حسبانا﴾</q>، قال: ضياءً{15}. (٦/١٤٥) ٢٥٦٥١- عن إسماعيل السُّدِّيّ -من طريق أسباط- <q>﴿والشمس والقمر حسبانا﴾</q>، يقول: بحساب{13}. (ز) ٢٥٦٥٢- عن الربيع بن أنس -من طريق أبي جعفر الرازي- في قوله: <q>﴿والشمس والقمر حسبانا﴾</q>، قال: الشمس والقمر في حساب، فإذا خلَت أيامُها فذلك آخر الدهر، وأولُ الفزَع الأكبر{17}٢٣٥٢. (٦/١٤٥) ٢٣٥٢ رجَّح ابنُ جرير (٩/٤٣٠) مستندًا إلى السياق، ودلالة العقل قولَ ابن عباس، ومجاهد، والسدي، والضحاك، والربيع، وقتادة من طريق معمر، أنّ معنى: <q>﴿والشَّمْسَ والقَمَرَ حُسْبانًا﴾</q>: وجعل الشمس والقمر يجريان في أفلاكهما بحساب. وبيَّن علَّة ذلك، فقال: «لأنّ الله -تعالى ذِكْرُه- ذَكَرَ قَبْلَه أياديه عند خلقه، وعظم سلطانه بِفَلْقِه الإصباح لهم، وإخراج النبات والغِراس من الحبِّ والنَّوى، وعقَّب ذلك بذكره خلق النجوم لهدايتهم في البر والبحر، فكان وصفُه إجراءه الشمس والقمر لمنافعهم أشْبَه بهذا الموضع من ذِكْر إضاءتهما؛ لأنّه قد وصف ذلك قبلُ بقوله: <q>﴿فالِقُ الإصْباحِ﴾</q>، فلا معنى لتكريره مرةً أخرى في آيةٍ واحدةٍ لغير معنى». ثم وجَّه قول قتادة، فقال: «وأَحْسَبُ أنّ قتادة في تأويل ذلك بمعنى: الضياء؛ ذهب إلى شيءٍ يُروى عن ابن عباس في قوله: <q>﴿ويُرْسِلَ عَلَيْها حُسْبانًا مِنَ السَّماءِ﴾</q> [الكهف:٤٠]، قال: نارًا. فوجَّه تأويل قوله: <q>﴿والشَّمْسَ والقَمَرَ حُسْبانًا﴾</q> إلى ذلك التأويل». وانتقده قائلًا: «وليس هذا من ذلك المعنى في شيءٍ». ٢٥٦٥٣- قال محمد بن السائب الكلبي: يعني: حساب منازل الشمس والقمر، كل يوم بمنزل{18}. (ز) ٢٥٦٥٤- قال مقاتل بن سليمان: <q>﴿و﴾</q> جعل <q>﴿الشمس والقمر حسبانا﴾</q> يقول: جعلهما في مسيرهما كالحسبان في الفلك. يقول: <q>﴿لتعلموا عدد السنين والحساب﴾</q> [يونس:٥]، وذلك أنّ الله قدَّر لهما منازلهما في السماء الدنيا، فذلك قوله: <q>﴿ذلك تقدير العزيز﴾</q> في مُلكه يصنع ما أراد، <q>﴿العليم﴾</q> بما قدَّر من خلقه. نظيرُها في يونس{19}. (ز) <q>﴿وَٱلشَّمۡسَ وَٱلۡقَمَرَ حُسۡبَانࣰاۚ ذَ ٰ⁠لِكَ تَقۡدِیرُ ٱلۡعَزِیزِ ٱلۡعَلِیمِ ۝٩٦﴾</q> - آثار متعلقة بالآية ٢٥٦٥٥- عن مسلم بن يسار، قال: كان من دعاء النبي ﷺ: «اللَّهُمَّ، فالقَ الإصباح، وجاعلَ الليل سكنًا، والشمس والقمر حسبانًا، اقْضِ عنِّي الدَّين، وأَغْنِني من الفقر، وأَمْتِعني بسمعي وبصري وقُوَّتي في سبيلك»{20}. (٦/١٤٨) ٢٥٦٥٦- عن سلمان الفارسي -من طريق وهب- قال: الليل موكَّل به مَلَك يقال له: شراهيل، فإذا حان وقتُ الليل أخذ خَرَزةً سوداءَ فدلّاها مِن قِبَل المغرب، فإذا نظَرَتْ إليها الشمسُ وجبَت في أسرعَ من طرْفة العين، وقد أُمِرَت الشمسُ ألا تغرُبَ حتى تَرى الخَرَزة، فإذا غرَبت جاء الليل، فلا تزالُ الخَرَزَةُ مُعَلَّقةً حتى يجيء مَلَكٌ آخر -يُقال له: هراهيل- بخَرَزَة بيضاء، فيُعَلِّقُها مِن قِبَل المطلِع، فإذا رآها شراهيل مدَّ إليه خرزتَه، وترى الشمسُ الخرزةَ البيضاء فتطلُعُ، وقد أُمِرت ألا تطلُعَ حتى تراها، فإذا طلَعت جاء النهار{21}. (٦/١٤٧) ٢٥٦٥٧- عن عبد الله بن عباس -من طريق عكرمة- قال: خلَق الله بحرًا دونَ السماء بمقدار ثلاث فراسخ، فهو موجٌ مكفوف، قائمٌ في الهواء بأمر الله، لا يقطُرُ منه قطرة، جارٍ في سرعة السهم، تجرِي فيه الشمس والقمر والنجوم، فذلك قوله: <q>﴿كل في فلك يسبحون﴾</q> [الأنبياء:٣٣]. والفَلَك: دَوَران العجلة في لُجَّة غَمْرِ ذلك البحر، فإذا أحبَّ الله أن يُحدِثَ الكسوف خرَّت الشمس عن العجلة فتقعُ في غَمْرِ ذلك البحر، فإذا أراد أن يُعظِمَ الآية وقَعت كلُّها فلا يَبقى على العجلة منها شيء، وإذا أراد دونَ ذلك وقَع النصفُ منها أو الثُّلثُ أو الثُّلثان في الماء، ويبقى سائر ذلك على العجلة، وصارت الملائكة الموكَّلون بها فِرقتين؛ فرقة يُقبِلون على الشمس فيجرُّونها نحوَ العجلة، وفرقة يُقبِلون إلى العجلة فيجرُّونها إلى الشمس، فإذا غَرَبت رُفِع بها إلى السماء السابعة في سرعة طيران الملائكة، وتُحبَسُ تحتَ العرش، فتستأذنُ مِن أين تؤمرُ بالطلوع، ثم يُنطلَقُ بها ما بينَ السماء السابعة وبينَ أسفل درجات الجنان في سرعة طيران الملائكة، فتنحدِرُ حِيالَ المشرق من سماء إلى سماء، فإذا وصَلَت إلى هذه السماء فذلك حينَ ينفجرُ الصبح، فإذا وصَلت إلى هذا الوجه من السماء فذلك حينَ تطلُعُ الشمس. قال: وخلَق الله عندَ المشرق حجابًا من الظُّلمة، فوضَعها على البحر السابع، مقدارَ عدَّة الليالي في الدنيا منذُ خلَقها الله إلى يوم القيامة، فإذا كان عندَ غروب الشمس أقبَل مَلَك قد وُكِّل بالليل، فقبَض قبضةً من ظُلمة ذلك الحجاب، ثم يستقبلُ المغرب، فلا يزالُ يُرْسِلُ تلك الظُّلمةَ من خَللِ أصابعه قليلًا قليلًا، وهو يراعي الشَّفَقَ، فإذا غاب الشَّفَقُ أرسَل الظُّلْمة كلَّها، ثم ينشُرُ جناحيه فيبلُغان قُطرَيِ الأرض، وكَنفَيِ السماء، فتُشرقُ ظُلمةُ الليل بجناحيه، فإذا حان الصبحُ ضمَّ جناحَيه، ثم يضمُّ الظلمة كلَّها بعضَها إلى بعض بكفَّيه من المشرق، ويضعُها على البحر السابع بالمغرب{22}. (٦/١٤٦) ",footnotes:1:أخرجه ابن جرير ٩/٤٢٦، وابن أبي حاتم ٤/١٣٥٤.أخرجه ابن جرير ٩/٤٢٥، وابن أبي حاتم ٤/١٣٥٣. وعزاه السيوطي إلى ابن المنذر.تفسير مجاهد ص٣٢٥، وأخرجه ابن جرير ٩/٤٢٥، وابن أبي حاتم ٤/١٣٥٤. وعزاه السيوطي إلى ابن أبي شيبة، وعبد بن حميد، وابن المنذر، وأبي الشيخ.أخرجه ابن جرير ٩/٤٢٦، وابن أبي حاتم ٤/١٣٥٤. وعزاه السيوطي إلى أبي الشيخ.أخرجه ابن جرير ٩/٤٢٥.أخرجه عبد الرزاق ١/٢١٤، وابن جرير ٩/٤٢٥. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.تفسير مقاتل بن سليمان ١/٥٨٠.أخرجه ابن جرير ٩/٤٢٦. وعلَّقه ابن أبي حاتم ٤/١٣٥٣.أخرجه ابن أبي حاتم ٤/١٣٥٤. والقراءة لجمهور القراء، ما عدا عاصمًا، وحمزة، والكسائي، وخلف الذين يقرءون: <q>﴿وجَعَل﴾</q>. ينظر: النشر ٢/١٩٦.تفسير مقاتل بن سليمان ١/٥٨٠.أخرجه ابن جرير ٩/٤٢٨، وابن أبي حاتم ٤/١٣٥٤. وعزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ٩/٤٢٨.أخرجه ابن جرير ٩/٤٢٩.أخرجه عبد الرزاق ١/٢١٤، وابن جرير ٩/٤٢٩، وابن أبي حاتم ٤/١٣٥٤. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه ابن جرير ٩/٤٣٠، وابن أبي حاتم ٤/١٣٥٥. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه ابن جرير ٩/٤٢٩.أخرجه ابن جرير ٩/٤٢٩. وعزاه السيوطي إلى أبي الشيخ.ذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٢/٨٧-.تفسير مقاتل بن سليمان ١/٥٨٠. يشير إلى قوله تعالى: <q>﴿هُوَ الَّذِي جَعَلَ الشَّمْسَ ضِياءً والقَمَرَ نُورًا وقَدَّرَهُ مَنازِلَ لِتَعْلَمُوا عَدَدَ السِّنِينَ والحِسابَ﴾</q> الآية [يونس:٥].أخرجه ابن أبي شيبة ٦/٢٤ (٢٩١٩٣)، والدوري في جزء فيه قراءات النبي ص٩٤ (٤٣). قال الزرقاني في شرح الموطأ ٢/٤٣ (٤٩٦): «وهو مرسل».أخرجه أبو الشيخ في العظمة (٩١١).أخرجه أبو الشيخ في العظمة (٦٤٧). وأورد السيوطي ٦/١٤٦-١٤٨ عقب الآية عدة آثار في فضل مراعاة الشمس والقمر لذكر الله.
6,97," <q>﴿وَهُوَ ٱلَّذِی جَعَلَ لَكُمُ ٱلنُّجُومَ لِتَهۡتَدُوا۟ بِهَا فِی ظُلُمَـٰتِ ٱلۡبَرِّ وَٱلۡبَحۡرِۗ قَدۡ فَصَّلۡنَا ٱلۡـَٔایَـٰتِ لِقَوۡمࣲ یَعۡلَمُونَ ۝٩٧﴾</q> - تفسير ٢٥٦٥٨- عن ابن عمر، قال: قال رسول الله ﷺ: «تعلَّموا من النجوم ما تَهتدون به في ظلمات البرِّ والبحر، ثم انتهُوا»{1}. (٦/١٥٠) ٢٥٦٥٩- عن عمر بن الخطاب -من طريق أبي نضرة- قال: تعلَّموا من النجوم ما تهتدون به في بَرِّكم وبحركم، ثم أمسِكوا، فإنّها -واللهِ- ما خُلِقت إلا زينةً للسماء، ورُجومًا للشياطين، وعلامات يُهتدى بها، وتعلَّموا من النِّسبة ما تَصلِون به أرحامكم، وتعلَّموا ما يحِلُّ لكم من النساء، ويَحرُمُ عليكم، ثم أمْسِكوا{2}. (٦/١٤٩) ٢٥٦٦٠- عن عبد الله بن عباس -من طريق عطية العوفي- في قوله: <q>﴿وهو الذي جعل لكم النجوم لتهتدوا بها في ظلمات البر والبحر﴾</q>، قال: يَضِلُّ الرجلُ وهو في الظُّلمة والجور عن الطريق{3}. (٦/١٤٩) ٢٥٦٦١- عن قتادة بن دعامة -من طريق سعيد- قال: إنّ الله إنّما جعل هذه النجوم لثلاث خصال: جعلها زينةً للسماء، وجعلها يُهتدى بها، وجعَلها رجومًا للشياطين، فمَن تعاطى فيها غيرَ ذلك فقد قال رأيَه، وأخطَأ حظَّه، وأضاع نصيبه، وتكلَّف ما لا علمَ له به، وإنّ ناسًا جهلةً بأمر الله قد أحدَثوا في هذه النجوم كهانة؛ مَن أعرَس بنجم كذا وكذا كان كذا وكذا، ومن سافر بنجم كذا وكذا كان كذا وكذا، ولَعَمري ما من نجم إلا يولَدُ به الأحمر والأسود، والطويل والقصير، والحسن والذَّميم، ولو أنّ أحدًا علِم الغيب لَعلِمه آدم الذي خلقه الله بيده، وأسجَد له ملائكتَه، وعلَّمه أسماء كلِّ شيء{4}. (٦/١٤٩) ٢٥٦٦٢- قال مقاتل بن سليمان: <q>﴿وهو الذي جعل لكم النجوم﴾</q> نورًا لتهتدوا بها؛ بالكواكب ليلًا. يقول: لتعرفوا الطريق إذا سرتم في ظلمات البر والبحر، <q>﴿قد فصلنا الآيات لقوم يعلمون﴾</q> بأنّ الله واحد لا شريك له{5}. (ز) <q>﴿وَهُوَ ٱلَّذِی جَعَلَ لَكُمُ ٱلنُّجُومَ لِتَهۡتَدُوا۟ بِهَا فِی ظُلُمَـٰتِ ٱلۡبَرِّ وَٱلۡبَحۡرِۗ قَدۡ فَصَّلۡنَا ٱلۡـَٔایَـٰتِ لِقَوۡمࣲ یَعۡلَمُونَ ۝٩٧﴾</q> - آثار متعلقة بالآية ٢٥٦٦٣- عن العباس بن عبد المطلب -من طريق الحسن- قال: قال رسول الله ﷺ: «لقد طهَّر اللهُ هذه الجزيرة مِن الشِّرك، ما لم تُضِلَّهمُ النجوم»{6}. (٦/١٥٥) ٢٥٦٦٤- عن عمر بن الخطاب، قال: سمعتُ رسول الله ﷺ يقول: «لا تسألوا عن النجوم، ولا تَعْبُرُوا{7} القرآن برأيكم، ولا تسبُّوا أحدًا من أصحابي، فإنّ ذلك الإيمان المحض»{8}. (٦/١٥١) ٢٥٦٦٥- عن ابن مسعود، قال: قال رسول الله ﷺ: «إذا ذُكِر أصحابي فأَمْسِكوا، وإذا ذُكِر القَدَر فأَمْسِكوا، وإذا ذُكر النجوم فأَمْسِكوا»{9}. (٦/١٥٢) ٢٥٦٦٦- عن علي، قال: نهاني رسول الله ﷺ عن النظر في النجوم، وأمَرني بإسباغ الطُّهور{10}. (٦/١٥١) ٢٥٦٦٧- عن أبي هريرة، قال: نهى رسول الله ﷺ عن النظر في النجوم{11}. (٦/١٥٢) ٢٥٦٦٨- عن عائشة، قالت: نهى رسول الله ﷺ عن النظر في النجوم{12}. (٦/١٥٢) ٢٥٦٦٩- عن سَمُرَة بن جُندُب أنّه خطَب، فذكَرَ حديثًا عن رسول الله ﷺ أنّه قال: «أما بعد، فإنّ ناسًا يزعُمون أنّ كسوف هذه الشمس، وكسوفَ هذا القمر، وزوالَ هذه النجوم عن مواضعِها؛ لموت رجال عظماء من أهل الأرض، وإنّهم قد كذَبوا، ولكنها آياتٌ من آيات الله، يَعْتَبِرُ{13} بها عبادَه؛ لينظرَ مَن يُحدِثُ له منهم توبة»{14}. (٦/١٥١) ٢٥٦٧٠- عن ابن عباس، قال: قال النبي ﷺ: «مَن اقتَبَس عِلْمًا من النجوم اقتَبس شُعبةً من السِّحر، زاد ما زاد»{15}. (٦/١٥٢) ٢٥٦٧١- عن ابن عباس، قال: قال رسول الله ﷺ: «رُبَّ مُتعلِّمِ حروفَ أبي جاد وراء في النجوم ليس له عندَ الله خَلاقٌ يوم القيامة»{16}. (٦/١٥٥) ٢٥٦٧٢- عن أنس، قال: قال رسول الله ﷺ: «أخافُ على أُمَّتي خَصلتين: تكذيبًا بالقدر، وتصديقًا بالنجوم». وفي لفظ: «وحِذْقًا بالنجوم»{17}. (٦/١٥٢) ٢٥٦٧٣- عن ميمون بن مهران، قال: قلتُ لعبد الله بن عباس: أوصِني. قال: أوصيك بتقوى الله، وإيّاك وعلمَ النجوم؛ فإنّه يدعو إلى الكهانة، وإيّاك أن تذكُرَ أحدًا من أصحاب رسول الله ﷺ إلا بخير فيَكبَّك الله على وجهك في جهنم؛ فإنّ الله أظهَر بهم هذا الدين، وإيّاك والكلامَ في القدر؛ فإنّه ما تكلَّم فيه اثنان إلا أثِما، أو أثِم أحدُهما{18}. (٦/١٥٣) ٢٥٦٧٤- عن عبد الله بن عباس -من طريق طاووس- قال: إنّ قومًا ينظرون في النجوم، ويحسُبون أبا جاد، وما أرى للذين يفعَلون ذلك من خَلاق{19}. (٦/١٥٣) ٢٥٦٧٥- عن عبد الله بن عباس -من طريق الحسن بن صالح- قال: ذلك عِلْمٌ ضيَّعه الناس؛ النجوم{20}. (٦/١٥٠) ٢٥٦٧٦- عن عكرمة: أنّه سأَل رجلًا عن حساب النجوم، وجعَل الرجلُ يتحرَّجُ أن يُخبرَه، فقال عكرمة: سمعتُ عبد الله بن عباس يقول: علمٌ عجَز الناسُ عنه، ودِدتُ أنِّي علِمتُه {21}. (٦/١٥٠) ٢٥٦٧٧- عن مجاهد بن جبر، قال: لا بأسَ أن يتعلَّمَ الرجلُ من النجوم ما يَهتدي به في البرِّ والبحر، ويتعلَّم منازل القمر{22}. (٦/١٥٠) ٢٥٦٧٨- عن محمد بن كعب القرظي -من طريق عمر مولى غفرة- قال: واللهِ، ما لِأَحد من أهل الأرض في السماء من نجم، ولكن يتَّبعون الكهنة، ويتَّخذون النجوم عِلَّة{23}. (٦/١٥١) ٢٥٦٧٩- عن عبد الله بن حفص، قال: خُصَّت العرب بخصال: بالكهانة، والقِيافة، والعيافة، والنجوم، والحساب، فهدَم الإسلامُ الكهانة، وثـبَّت الباقي بعد ذلك{24}. (٦/١٥١) ٢٥٦٨٠- عن حميد الشامي، قال: النجوم هي علمُ آدم ﵇{25}. (٦/١٥٠) ",footnotes:1:ذكره الخطيب في القول في علم النجوم ص١٣١-١٣٢. وأورده الديلمي في الفردوس ٢/٤٣ (٢٢٤٨). قال الدارقطني في العلل الواردة في الأحاديث النبوية ١٣/١٠٧ (٢٩٩٠): «وإنما يحفظ من قول عمر موقوفًا». وقال الألباني في الضعيفة ٧/٤١٧ (٣٤٠٨): «ضعيف».أخرجه ابن أبي شيبة ٨/٤١٤ مختصرًا، والخطيب في كتاب النجوم ص٣٢٣. وعزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ٩/٤٣٢، وابن أبي حاتم ٤/١٣٥٥.أخرجه عبد الرزاق ١/٣٥٤ مختصرًا، وعبد بن حميد -كما في التغليق ٣/٤٨٩- من طريق شيبان، وابن جرير ٢٣/١٢٣، وابن أبي حاتم ٩/٢٩١٣، وأبو الشيخ في العظمة (٧٠٦)، والخطيب في كتاب النجوم ص١٨٥. وعزاه السيوطي إلى ابن المنذر.تفسير مقاتل بن سليمان ١/٥٨٠.أخرجه أبو يعلى في مسنده ١٢/٧٧ (٦٧١٤)، وابن عبد البر في جامع بيان العلم ٢/٧٩٣ (١٤٧٩). قال ابن خزيمة كما في إتحاف المهرة لابن حجر ٦/ ٤٧٧: «الحسن لم يسمع من العباس». وقال البوصيري في إتحاف الخيرة ٣/٢٥٢ (٢٦٨٠): «رواه أبو يعلى بسندٍ فيه انقطاع». وقال الألباني في الضعيفة ٩/٣٠٥ (٤٣١٦): «ضعيف».أي لا تفسروه برأيكم. ينظر النهاية (عبر).ذكره الخطيب في القول في علم النجوم ص١٧٥ واللفظ له. وأورده الديلمي في الفردوس ٥/٦٤ (٧٤٧٠).أخرجه الطبراني في الكبير ١٠/١٩٨ (١٠٤٤٨)، وأبو نعيم في الحلية ٤/١٠٨، من طريق سعيد بن سليمان، عن مسهر بن عبد الملك بن سلع الهمداني، عن الأعمش، عن أبي وائل، عن عبد الله به. قال العراقي في تخريج أحاديث الإحياء ص٣٩ (٢): «إسناد حسن». وقال الهيثمي المجمع ٧/٢٠٢ (١١٨٥١): «وفيه مسهر بن عبد الملك، وثَّقه ابن حبان وغيره، وفيه خلاف، وبقية رجاله رجال الصحيح». وقال الألباني في الصحيحة ١/٧٥- ٨٠ (٣٤): «... له شواهد وطرق، ... فيقوى الحديث به».أخرجه الخطيب في المتفق والمفترق ٢/٩١١، والموضح ٢/٧٧، من طريق الربيع بن حبيب، عن نوفل بن عبد الملك، عن أبيه، عن علي به. قال ابن عدي في الكامل ٤/٤٣ بعد ذكره لجملة من مرويات الربيع بن حبيب: «هذه الأحاديث مع غيرها يرويها عن الربيع بن حبيب عبيد الله بن موسى، وليست بالمحفوظة». وقال ابن القيسراني في ذخيرة الحفاظ ٥/٢٥٣٣ (٥٨٨٨): «رواه الربيع بن حبيب، عن نوفل بن عبد الملك، عن أبيه، عن علي، والربيع -وهو أخو عائذ- ثقة».أخرجه الطبراني في الأوسط ٨/١٣١ (٨١٨٢)، والبيهقي في الشعب ٧/١٦٩ (٤٨٣٣)، من طريق عقبة الأصم، عن عطاء، عن أبي هريرة به. قال الطبراني: «لم يروِ هذا الحديثَ عن عطاء إلا عقبة الأصم». وقال العقيلي في الضعفاء الكبير ٣/٣٥٣ (١٣٨٦) بعد أن ذكره بسنده من طريق عقبه الأصم: «ولا يعرف إلا به، ولا يتابعه إلا مَن هو دونه أو مثله». وقال ابن عدي في الكامل ٦/٤٨٩: «وهذا لا يعرف إلا بعقبة عن عطاء». وقال القيسراني في تذكرة الحفاظ ١/٣٦٥- ٣٦٦ (٩٣٣): «رواه عقبة بن عبد الله الأصم البصري، عن عطاء، عن أبي هريرة، وعقبة هذا يروي المناكير عن الثقات». وقال في ذخيرة الحفاظ ٥/٢٥٣٢ (٥٨٨٣): «رواه عقبة بن عبد الله الأصم، عن عطاء بن أبي رباح، عن أبي هريرة، وعقبة ضعيف». وقال الهيثمي في المجمع ٥/١١٦- ١١٧ (٨٤٧٧): «فيه عقبة بن عبد الله الأصم، وهو ضعيف، وذكر عن أحمد أنّه وثقه، وأنكر أبو حاتم عليه هذا الحديث». وقال البوصيري في إتحاف الخيرة ١/٢٤٩-٢٥٠ (٣٧٨): «له شاهد من حديث أنس ...».ذكره الخطيب في القول في علم النجوم ص١٧٧.اعتبر الشيء: اختبره وامتحنه. الوسيط (ع ب ر).أخرجه أحمد ٣٣/٣٤٦-٣٤٩ (٢٠١٧٨) واللفظ له، وابن خزيمة ٢/٥٢٣-٥٢٤ (١٣٩٧)، وابن حبان ٧/١٠١-١٠٣ (٢٨٥٦)، والحاكم ١/٤٧٨ (١٢٣٠)، من طريق الأسود بن قيس، عن ثعلبة بن عباد العبدي، عن سمرة بن جندب به. قال الحاكم: «حديث صحيح، على شرط الشيخين، ولم يخرجاه». وقال الهيثمي في المجمع ٧/٣٤٢ (١٢٥١٩): «ورجال أحمد رجال الصحيح، غير ثعلبة بن عبادة، وثَّقه ابن حبان». وقال الألباني في ضعيف أبي داود ٢/٢٣ (٢١٦): «إسناده ضعيف».أخرجه ابن ماجه ٤/٦٧٠ (٣٧٢٦)، وأبو داود ٦/٥٠-٥١ (٣٩٠٥)، وأحمد ٣/٤٥٤ (٢٠٠٠)، ٥/٤١ (٢٨٤٠)، من طريق يحيى بن سعيد، عن عبيد الله بن الأخنس، عن الوليد بن عبد الله، عن يوسف بن ماهك، عن ابن عباس به. قال النووي في رياض الصالحين ص٣٦٩ (١٦٧١): «... إسناده صحيح». وقال شيخ الإسلام في الفتاوى ٣٥/١٩٣: «... إسناد صحيح». وقال الذهبي في المهذب: «حديث صحيح». وقال في الكبائر ص٣٢٨: «سند صحيح». وقال العراقي في تخريج أحاديث الإحياء ص١٤٦٠: «... سند صحيح». وقال المناوي في فيض القدير ٦/٨٠ (٨٥٠٠)، وفي التيسير بشرح الجامع الصغير ٢/٤٠٣: «إسناد صحيح». وقال الرباعي في فتح الغفار ٣/١٧١٦ (٥٠٦١): «... رجال إسناده ثقات». وقال الألباني في الصحيحة ٢/٤٢٠ (٧٩٣): «إسناد جيد، رجاله كلهم ثقات».أخرجه ابن الأعرابي في معجمه ٢/٨٣٩ (١٦٨٤)، والطبراني في الكبير ١١/ ٤١ (١٠٩٨٠)، من طريق خالد بن يزيد العمري، عن محمد بن مسلم، عن إبراهيم بن ميسرة، عن طاووس، عن ابن عباس به. قال الهيثمي في المجمع ٥/١١٧ (٨٤٧٨): «فيه خالد بن يزيد العمري، وهو كذاب». وقال المناوي في التيسير بشرح الجامع الصغير ٢/٢٩: «إسناد فيه كذاب». وقال الألباني في الضعيفة ١/٦٠٩ (٤١٧): «موضوع».أخرجه أبو يعلى في مسنده ٧/١٦٢ (٤١٣٥)، والخطيب في القول في علم النجوم ص١٦٢ واللفظ له، والبيهقي في القضاء والقدر (٢٨٥)، من طريق شهاب بن خراش، عن يزيد الرقاشي، عن أنس بن مالك به. قال ابن القيسراني في ذخيرة الحفاظ ١/٢٥١ (١٣٥): «رواه شهاب بن خراش، عن يزيد الرقاشي، عن أنس، وشهاب هذا في روايته إنكار، وليس للمتقدمين فيه كلام». وقال الهيثمي في المجمع ٧/٢٠٣ (١١٨٦١): «وفيه يزيد الرقاشي، وهو ضعيف، ووثَّقه ابن عدي».أخرجه الخطيب في كتاب النجوم ص١٩٠.أخرجه عبد الرزاق في المصنف (١٩٨٠٥)، وابن أبي شيبة ٨/٤١٤، والخطيب ص١٨٩.عزاه السيوطي إلى المُرهِبيُّ.أخرجه الخطيب في كتاب النجوم ص١٨٨-١٨٩. وقال:. قال الخطيب: مرادُه الضربُ المباح الذي كانت العرب تختصُّ به.ذكره الخطيب في كتاب النجوم ص١٣٣.أخرجه أبو الشيخ في العظمة (٧١٠). وعزاه السيوطي إلى ابن أبي حاتم.أخرجه الزبير بن بكار في الموفقيات ص٣٦٢-٣٦٣.عزاه السيوطي إلى ابن أبي حاتم، والمُرهِبيُّ في فضل العلم.
6,98," <q>﴿وَهُوَ ٱلَّذِیۤ أَنشَأَكُم مِّن نَّفۡسࣲ وَ ٰ⁠حِدَةࣲ﴾</q> - تفسير ٢٥٦٨١- عن أبي أُمامة، عن رسول الله ﷺ، قال: «نَصَب آدمَ بينَ يديه، ثم ضرَب كَتِفَه اليسرى، فخرَجت ذُرِّيتُه من صُلْبِه حتى ملئوا الأرض»{1}. (٦/١٥٥) ٢٥٦٨٢- عن قتادة بن دِعامة -من طريق سعيد- <q>﴿وهو الذي أنشأكم من نفس واحدة﴾</q>، قال: من آدم ﵇{2}. (ز) ٢٥٦٨٣- عن إسماعيل السُّدِّيّ -من طريق أسباط- قوله: <q>﴿وهو الذي أنشأكم من نفس واحدة﴾</q>، قال: آدم ﵇{3}. (ز) ٢٥٦٨٤- عن مجاهد بن جبر= (ز) ٢٥٦٨٥- وأبي مالك غزوان الغفاري= (ز) ٢٥٦٨٦- ومقاتل بن حيان، مثل ذلك{4}. (ز) ٢٥٦٨٧- قال مقاتل بن سليمان: ثم أخبر عن صنعه، فقال: <q>﴿وهو الذي أنشأكم من نفس واحدة﴾</q>، يعني: خلقكم من نفس واحدة، يعني: آدم وحده{5}. (ز) <q>﴿فَمُسۡتَقَرࣱّ وَمُسۡتَوۡدَعࣱۗ﴾</q> - قراءات ٢٥٦٨٨- عن عاصم ابن أبي النجود: <q>﴿فَمُسْتَقَرٌّ﴾</q> بنصب القاف{6}. (٦/١٥٧) <q>﴿فَمُسۡتَقَرࣱّ وَمُسۡتَوۡدَعࣱۗ﴾</q> - تفسير الآية ٢٥٦٨٩- عن أُبَيّ بن كعب: مستقر في أصلاب الآباء، ومستودع في أرحام الأمهات{7}. (ز) ٢٥٦٩٠- عن عبد الله بن مسعود -من طريق ابن عيينة، عن إسماعيل بن أبي خالد، عن إبراهيم- في قوله: <q>﴿فمستقر ومستودع﴾</q>، قال: مستقرُّها في الدنيا، ومستودَعُها في الآخرة{8}. (٦/١٥٦) ٢٥٦٩١- عن عبد الله بن مسعود -من طريق ابن عيينة، عن إسماعيل بن أبي خالد، عن إبراهيم- في قوله: <q>﴿فمستقر ومستودع﴾</q>، قال: مستودعها في الدنيا، ومستقرها في الرَّحِم{9}. (ز) ٢٥٦٩٢- عن عبد الله بن مسعود -من طريق السدي، عن مُرَّة- قال: المستقَرُّ: الرَّحِم. والمستودَعُ: المكان الذي تموتُ فيه{10}. (٦/١٥٦) ٢٥٦٩٣- عن عبد الله بن مسعود -من طريق قيس بن أبي حازم- قال: إذا كان أجلُ الرجل بأرض أُتِيحَتْ له إليها الحاجة، فإذا بلَغ أقصى أثَرِه قُبِض، فتقول الأرض يوم القيامة: هذا ما استودَعْتَني{11}. (٦/١٥٦) ٢٥٦٩٤- عن عبد الله بن عباس -من طريق سعيد بن جبير-: المستقر: الأرض. والمستودع: عند الرحمن{12}. (ز) ٢٥٦٩٥- عن عبد الله بن عباس -من طريق قتادة- <q>﴿فمستقر ومستودع﴾</q>، قال: مستقر في الرحم، ومستودع في الصلب{13}. (ز) ٢٥٦٩٦- عن عبد الله بن عباس -من طريق العوفي- <q>﴿فَمُسْتَقَرٌّ ومُسْتَوْدَعٌ﴾</q>، قال: المستقر في الأرحام، والمستودع في الصلب، لم يُخْلَق، وهو خالِقه{14}. (ز) ٢٥٦٩٧- عن عبد الله بن عباس -من طريق مقسم- قال: <q>﴿مستقرها﴾</q> حيث تأوي، <q>﴿ومستودعها﴾</q> [هود:٦] حيث تموت{15}. (ز) ٢٥٦٩٨- عن سعيد بن جبير، قال: قال لي عبد الله بن عباس: أتزوَّجتَ؟ قلتُ: لا، وما ذاك في نفسِي اليوم. قال: إن كان في صُلبِك وديعةٌ فسَتخرُجُ{16}. (٦/١٥٧) ٢٥٦٩٩- عن عبد الله بن عباس -من طريق علي بن أبي طلحة وغيره- في قوله: <q>﴿فمستقر ومستودع﴾</q>، قال: المستقَرُّ: ما كان في الرَّحِم. والمُسْتَوْدَعُ: ما استُودِع في أصلاب الرجال والدواب. وفي لفظ: المستقَرُّ: ما في الرَّحم، وعلى ظهر الأرض، وبطنِها مما هو حيٌّ، ومِمّا قد مات. وفي لفظ: المستقَرُّ: ما كان في الأرض. والمستودَعُ: ما كان في الصُّلْب{17}. (٦/١٥٥) ٢٥٧٠٠- عن أبي عبد الرحمن السلمي= (ز) ٢٥٧٠١- وقيس بن أبي حازم= (ز) ٢٥٧٠٢- وعطاء الخراساني، نحو اللفظ الأول{4}. (ز) ٢٥٧٠٣- عن كريب، قال: دعاني ابنُ عباس فقال: اكتب: بسم الله الرحمن الرحيم، من عبد الله بن عباس إلى فلان حبر تيماء، سلامٌ عليك، فإني أحمد إليك الله الذي لا إله إلا هو، أمّا بعد. قال: فقلت: تبدؤه تقول: السلام عليك؟! فقال: إنّ الله هو السلام. ثم قال: اكتب: سلامٌ عليك، أمّا بعد، فحدِّثني عن مستقر ومستودع. قال: ثم بعثني بالكتاب إلى اليهودي، فأعطيته إياه، فلما نظر إليه قال: مرحبًا بكتاب خليلي من المسلمين، فذهب بي إلى بيته، ففتح أسْفاطًا{19} له كبيرة، فجعل يطرح تلك الأشياء لا يلتفت إليها، قال: قلت: ما شأنُك؟ قال: هذه أشياء كتبها اليهود. حتى أخرج سِفْر موسى ﵇، قال: فنظر إليه مرتين، فقال: المستقر: الرحم. قال: ثم قرأ: <q>﴿ونقر في الأرحام ما نشاء﴾</q> [الحج:٥]، وقرأ: <q>﴿ولكم في الأرض مستقر ومتاع﴾</q> [البقرة:٣٦]. قال: مستقره فوق الأرض، ومستقره في الرحم، ومستقره تحت الأرض، حتى يصير إلى الجنة أو إلى النار{14}. (ز) ٢٥٧٠٤- عن محمد ابن الحنفية: مستقر في صلب الأب، ومستودع في رحم الأم{21}. (ز) ٢٥٧٠٥- عن أبي العالية الرياحي: مستقرها أيام حياتها، ومستودعها حيث تموت وحيث يبعث{22}. (ز) ٢٥٧٠٦- عن سعيد بن جبير -من طريق كلثوم بن جبر- في قوله: <q>﴿فمستقر ومستودع﴾</q>، قال: مُسْتَوْدَعون ما كانوا في أصلاب الرجال، فإذا قرُّوا في أرحام النساء، أو على ظهر الأرض، أو في بطنها؛ فقد استقرُّوا{23}. (ز) ٢٥٧٠٧- عن سعيد بن جبير -من طريق أبي بشر- قال: المستودع: في الصلب. والمستقر: في الآخرة، وعلى وجه الأرض{24}. (ز) ٢٥٧٠٨- عن سعيد بن جبير -من طريق عطاء بن السائب-= (ز) ٢٥٧٠٩- وإبراهيم النخعي -من طريق أبي حمزة، وابن عون- قالا: مستقر ومستودع؛ المستقرُّ في الرحم، والمستودع في الصُّلْب{25}. (ز) ٢٥٧١٠- قال مقسم -من طريق ليث-: <q>﴿مستقرها﴾</q> في الصلب حيث تأوي إليه، <q>﴿ومستودعها﴾</q> [هود:٦] حيث تموت{26}. (ز) ٢٥٧١١- عن مجاهد بن جبر -من طريق ابن أبي نجيح- قال: المستقر: الأرض، والمستودع عند ربك{27}. (ز) ٢٥٧١٢- عن مجاهد بن جبر -من طريق ابن أبي نجيح- قال: <q>﴿فمستقر﴾</q>: ما استقر في أرحام النساء، <q>﴿ومستودع﴾</q>: ما كان في أصلاب الرجال{28}. (ز) ٢٥٧١٣- عن مجاهد بن جبر: المستودع: المكان الذي يموت فيه{29}. (ز) ٢٥٧١٤- عن الضحاك بن مُزاحِم -من طريق عبيد بن سليمان- <q>﴿فمستقر ومستودع﴾</q>: أمّا مستقرٌّ: فما استقر في الرحم، وأمّا مُستودَع: فما استودع في الصُّلْب{13}. (ز) ٢٥٧١٥- عن عكرمة مولى ابن عباس -من طريق يحيى الجابر- <q>﴿فمستقر ومستودع﴾</q>، قال: المستقر: الذي قد استقر في الرَّحِم، والمستودع: الذي قد اسْتُودِع في الصُّلْب{24}. (ز) ٢٥٧١٦- عن الحسن البصري -من طريق منصور- في قوله: <q>﴿مستقر﴾</q> قال: المستقر: الذي قد مات فاستقر به عمله، <q>﴿ومستودع﴾</q> قال: إلى أجل{32}. (ز) ٢٥٧١٧- عن الحسن البصري= (ز) ٢٥٧١٨- وقتادة بن دعامة، في قوله: <q>﴿فمستقر ومستودع﴾</q>، قالا: مستقَرٌّ في القبر، ومستودَعٌ في الدنيا، أوشَك أن يلحَقَ بصاحبه{33}. (٦/١٥٦) ٢٥٧١٩- عن عطاء بن أبي رباح -من طريق ابن جريج- <q>﴿فمستقر ومستودع﴾</q>، قال: المستقر: ما اسْتَقَرَّ في أرحام النساء. والمستودع: ما اسْتُودِع في أصلاب الرجال{34}. (ز) ٢٥٧٢٠- عن قتادة بن دعامة -من طريق مَعْمَر- <q>﴿فمستقر ومستودع﴾</q>، قال: مستقر في الرَّحِم، ومُستودَع في الصُّلْب{35}. (ز) ٢٥٧٢١- عن إسماعيل السُّدِّيّ -من طريق أسباط- قال: المستقر في الرحم، والمستودع في الصلب{36}. (ز) ٢٥٧٢٢- عن إسماعيل السُّدِّيّ -من طريق إسماعيل بن أبي خالد- <q>﴿فمستقر ومستودع﴾</q>، قال: المستقر: ما فُرِغ من خلقه{37}. (ز) ٢٥٧٢٣- قال يعقوب الأشعري القُمِّيُّ: سألتُ إبراهيم بن محمد ابن الحنفية، فقلتُ: مستقر ومستودع؟ قال: المستقر في أصلاب الرجال، والمستودع في أرحام النساء{32}. (ز) ٢٥٧٢٤- عن زيد بن علي بن الحسين، نحوه{39}. (ز) ٢٥٧٢٥- قال مقاتل بن سليمان: <q>﴿فمستقر﴾</q> في أرحام النساء، <q>﴿ومستودع﴾</q> في أصلاب الرجال مِمّا لم يخلقه، وهو خالِقه{5}. (ز) ٢٥٧٢٦- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿فمستقر ومستودع﴾</q>، قال: مستقر في الأرحام، ومستودع في الأصلاب{41}٢٣٥٣. (ز) ٢٣٥٣ أفادت الآثار اختلاف المفسرين في معنى «المستقر والمستودع» على خمسة أقوال: الأول: المستقَرُّ في الرحم، والمستودَع في القبر حتى يبعثه الله لنَشْرِ القيامة. الثاني: المستقَرُّ: ما كان في بطون النساء، وبطون الأرض، أو على ظهورها. والمستودَع: ما كان في أصلاب الآباء. الثالث: المستقَرُّ في الأرض على ظهورها، والمستودَع عند الله. الرابع: المستقَرُّ في الرحم، والمستودَع في الصلب، الخامس: المستقَرُّ في القبر، والمستودَع في الدنيا. وقد رجَّح ابنُ جرير (٩/٤٤٢) الجمعَ بين كل تلك الأقوال مستندًا إلى عموم اللفظ، فقال: «ولا شكَّ أنّ مِن بني آدم مستقرًّا في الرحم، ومستودَعًا في الصلب، ومنهم مَن هو مستقرٌّ على ظهر الأرض أو بطنها، ومستودَعٌ في أصلاب الرجال، ومنهم مستقرٌّ في القبر، مستودَعٌ على ظهر الأرض، فكلُّ مستقَرٍّ أو مستودَعٍ بمعنًى من هذه المعاني فداخلٌ في عموم قوله: <q>﴿فَمُسْتَقَرٌّ ومُسْتَوْدَعٌ﴾</q>، ومرادٌ به». وانتقد ابنُ عطية (٣/٤٢٧) الأقوال السابقة، ورجَّح مستندًا إلى دلالة العقل، ودلالة الواقع أن «الذي يقتضيه النظر أنّ ابن آدم هو مستودع في ظهر أبيه، وليس بمستقر فيه استقرارًا مطلقًا لأنه ينتقل لا محالة: ينتقل إلى الرحم، ثم ينتقل إلى الدنيا، ثم ينتقل إلى القبر، ثم ينتقل إلى المحشر، ثم ينتقل إلى الجنة أو النار، فيستقرُّ في إحداهما استقرارًا مطلقًا، وليس فيها مستودع لأنّه لا نقلة له بعد». غير أنه ذكر توجيهًا للأقوال الواردة في معنى «المستقر والمستودع»، فقال: «وهو في كل رتبة متوسطة بين هذين الطرفين مستقرٌّ بالإضافة إلى التي قبلها، ومستودع بالإضافة إلى التي بعدها؛ لأنّ لفظ الوديعة يقتضي فيها نقلة ولا بُدَّ». ورجَّح ابنُ كثير (٦/١١٨) قولَ من قال: إنّ المستقَر في الأرحام، والمستودَع في الأصلاب. ولم يذكر مستندًا. <q>﴿قَدۡ فَصَّلۡنَا ٱلۡـَٔایَـٰتِ لِقَوۡمࣲ یَفۡقَهُونَ ۝٩٨﴾</q> - تفسير ٢٥٧٢٧- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿قد فصلنا الآيات﴾</q> يقول: بيَّنّا الآيات <q>﴿لقوم يفقهون﴾</q>{42}. (٦/١٥٧) ٢٥٧٢٨- قال مقاتل بن سليمان: <q>﴿قد فصلنا الآيات﴾</q> يعني: قد بيَّنّا الآيات <q>﴿لقوم يفقهون﴾</q> عن الله ﷿{5}. (ز) <q>﴿قَدۡ فَصَّلۡنَا ٱلۡـَٔایَـٰتِ لِقَوۡمࣲ یَفۡقَهُونَ ۝٩٨﴾</q> - آثار متعلقة بالآية ٢٥٧٢٩- عن عوف، قال: بلَغَني: أنّ رسول الله ﷺ قال: «أُنبِئتُ بكلِّ مستقَرٍّ ومستودَعٍ من هذه الأُمة إلى يوم القيامة، كما عُلِّم آدم الأسماء كلَّها»{44}. (٦/١٥٧) ٢٥٧٣٠- عن عبد الله بن عباس، قال: مَنِ اشتكى ضِرْسَه فلْيضَعْ يدَه عليه، ولْيقْرَأْ: <q>﴿وهو الذي أنشأكم من نفس واحدة﴾</q> الآية{44}. (٦/١٥٧) ",footnotes:1:عزاه السيوطي إلى ابن مردويه.أخرجه ابن جرير ٩/٤٣٣. وعلَّقه ابن أبي حاتم ٤/١٣٥٥.أخرجه ابن جرير ٩/٤٣٣، وابن أبي حاتم ٤/١٣٥٥.علَّقه ابن أبي حاتم ٤/١٣٥٥.تفسير مقاتل بن سليمان ١/٥٨٠.عزاه السيوطي إلى عبد بن حميد. وهي قراءة متواترة عن العشرة ما عدا ابن كثير، وأبا عمرو، وروح، فإنهم قرؤوا: ‹فَمُسْتَقِرٌّ› بكسر القاف. انظر: النشر ٢/٢٦٠، والإتحاف ص٢٧٠.تفسير البغوي ٣/١٧١.أخرجه عبد الرزاق ١/٢١٥، وابن جرير ٩/٤٣٥، وابن أبي حاتم ٤/١٣٥٥، ١٣٥٧، ٦/٢٠٠٢-٢٠٠٣. وعزاه السيوطي إلى أبي الشيخ.أخرجه سعيد بن منصور في سننه (٨٩٥ - تفسير).أخرجه ابن جرير ٩/٤٣٣، وابن أبي حاتم ٤/١٣٥٦-١٣٥٧، ٦/٢٠٠٢ من طريق إبراهيم في تفسير المستقر ومن طريق مرة في تفسير المستودع، كما أخرجه ابن جرير ٩/٤٣٣ بنحوه من طريق أبي معاوية عن إسماعيل بن أبي خالد عن إبراهيم، والطبراني في المعجم الكبير (٩٠١٦) بنحوه من طريق قيس بن الربيع، عن إسماعيل بن أبي خالد، عن إبراهيم. وعزاه السيوطي إلى الفريابي، وسعيد بن منصور، وعبد بن حميد، وأبي الشيخ.أخرجه عبد الرزاق ١/٢١٥، وسعيد بن منصور (٨٩٤ - تفسير). وعزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ٩/٤٣٥.أخرجه ابن جرير ٩/٤٤١.أخرجه ابن جرير ٩/٤٣٨.أخرجه ابن جرير ١٢/٣٢٥، وابن أبي حاتم ٤/١٣٥٦ في شطره الأول.أخرجه عبد الرزاق في مصنفه (١٢٥٨١)، وابن جرير ٩/٤٣٧.أخرجه سعيد بن منصور (٨٩٢-تفسير)، وابن جرير ٩/٤٣٥-٤٣٨، ٤٤١، وابن أبي حاتم ٤/١٣٥٥، ١٣٥٧، ٦/٢٠٠٢، ٢٠٠٣، والحاكم ٢/٣١٦. وعزاه السيوطي إلى ابن أبي شيبة، وعبد بن حميد، وابن المنذر، وأبي الشيخ.علَّقه ابن أبي حاتم ٤/١٣٥٥.السَّفَطُ: الذي يُعَبّى فيه الطِّيب وما أشبهه من أدوات النساء. لسان العرب (سفط).أخرجه ابن جرير ٩/٤٣٨.عزاه ابن حجر في الفتح ٨/٢٨٩ إلى عبد بن حميد.تفسير الثعلبي ٤/١٧٣.أخرجه ابن جرير ٩/٤٣٤، وابن أبي حاتم ٤/١٣٥٦.أخرجه ابن جرير ٩/٤٣٦.أخرجه ابن جرير ٩/٤٤٠، ٤٤٢، وعبد الله بن وهب في الجامع - تفسير القرآن ١/١٤٨ (٣٤٨) عن إبراهيم من طريق ابن عون.أخرجه ابن جرير ٩/٤٣٤.أخرجه ابن جرير ٩/٤٣٥، كما أخرج ابن أبي حاتم ٤/١٣٥٦ شطره الأول من طريق أبي يحيى.تفسير مجاهد ص٣٢٦، وأخرجه ابن جرير ٩/٤٣٩، كذلك ٩/٤٣٨ من طريق ليث بنحوه. وعلَّقه ابن أبي حاتم ٤/١٣٥٥، ١٣٥٧.علَّقه ابن أبي حاتم ٤/١٣٥٧.أخرجه ابن جرير ٩/٤٤١.أخرجه ابن جرير ٩/٤٣٦.أخرجه ابن أبي حاتم ٤/١٣٥٦-١٣٥٧.عزاه السيوطي إلى أبي الشيخ. وأخرجه ابن جرير ٩/٤٤٢ عن الحسن من طريق قتادة. وفي تفسير الثعلبي ٤/١٧٣، وتفسير البغوي ٣/١٧٢ زيادة عن الحسن: وكان يقول: يا ابن آدم، أنت وديعة في أهلك، يوشك أن تلحق بصاحبك، وأنشد قول لبيد: وما المال والأهلون إلا وديعة ولا بد يومًا أن تُرَدَّ الودائع.أخرجه ابن جرير ٩/٤٣٩. وعلَّقه ابن أبي حاتم ٤/١٣٥٥.أخرجه عبد الرزاق ٢/٢١٤، وابن جرير ٩/٤٤١.أخرجه ابن جرير ٩/٤٤١. وعلَّقه ابن أبي حاتم ٤/١٣٥٥، ١٣٥٧.أخرجه ابن أبي حاتم ٤/١٣٥٦.أخرجه ابن أبي حاتم ٤/١٣٥٦-١٣٥٧.علَّقه ابن أبي حاتم ٤/١٣٥٨.تفسير مقاتل بن سليمان ١/٥٨٠.أخرجه ابن جرير ٩/٤٤٢.أخرجه ابن جرير ٩/٤٤٤، وابن أبي حاتم ٤/١٣٥٨. وعزاه السيوطي إلى ابن المنذر.تفسير مقاتل بن سليمان ١/٥٨٠.عزاه السيوطي إلى أبي الشيخ.عزاه السيوطي إلى أبي الشيخ.
6,99," <q>﴿وَهُوَ ٱلَّذِیۤ أَنزَلَ مِنَ ٱلسَّمَاۤءِ مَاۤءࣰ﴾</q> - تفسير ٢٥٧٣١- قال مقاتل بن سليمان: ثم أخبر عن صُنعِه؛ لِيُعْرَف توحيدُه، فقال: <q>﴿وهو الذي أنزل من السماء ماء﴾</q>، يعني: المطر{1}. (ز) <q>﴿فَأَخۡرَجۡنَا بِهِۦ نَبَاتَ كُلِّ شَیۡءࣲ فَأَخۡرَجۡنَا مِنۡهُ خَضِرࣰا﴾</q> - تفسير ٢٥٧٣٢- قال مقاتل بن سليمان: <q>﴿فأخرجنا به﴾</q> يعني: بالمطر <q>﴿نبات كل شيء﴾</q> يعني: الثمار، والحبوب، وألوان النبات، <q>﴿فأخرجنا منه خضرا﴾</q> يعني: أول النبات{2}. (ز) <q>﴿فَأَخۡرَجۡنَا بِهِۦ نَبَاتَ كُلِّ شَیۡءࣲ فَأَخۡرَجۡنَا مِنۡهُ خَضِرࣰا﴾</q> - آثار متعلقة بالآية ٢٥٧٣٣- عن سيار، قال: كان خالد بن يزيد عند عبد الملك بن مروان، فذكروا الماء، فقال خالد بن يزيد: منه من السماء، ومنه ما يسقيه الغيم من البحر فَيُعْذِبُهُ{3} الرعد والبرق، فأمّا ما كان من البحر فلا يكون له نبات، وأمّا النبات فمِمّا كان من السماء{4}. (ز) <q>﴿نُّخۡرِجُ مِنۡهُ حَبࣰّا مُّتَرَاكِبࣰا﴾</q> - تفسير ٢٥٧٣٤- عن إسماعيل السُّدِّيّ -من طريق أسباط- في قوله: <q>﴿نخرج منه حبا متراكبا﴾</q>، قال: فهذا السُّنبُلُ{5}. (٦/١٥٧) ٢٥٧٣٥- قال مقاتل بن سليمان: <q>﴿نخرج منه﴾</q> يعني: من الماء <q>﴿حبا متراكبا﴾</q> يعني: السُّنبُل، قد رَكِب بعضُه بعضًا{2}. (ز) <q>﴿وَمِنَ ٱلنَّخۡلِ مِن طَلۡعِهَا قِنۡوَانࣱ دَانِیَةࣱ﴾</q> - تفسير ٢٥٧٣٦- عن عبد الله بن عباس -من طريق علي بن أبي طلحة- <q>﴿قنوان دانية﴾</q>، قال: قِصارُ النخل اللّاصقةُ عُذوقُها بالأرض{7}. (٦/١٥٨) ٢٥٧٣٧- عن عبد الله بن عباس -من طريق السدي- <q>﴿قنوان﴾</q>: الكبائسُ{8}، والدّانيةُ: المنصوبة{9}٢٣٥٤. (٦/١٥٨) ٢٣٥٤ لم يذكر ابنُ جرير (٩/٤٤٦-٤٤٧) في معنى: <q>﴿دانية﴾</q> سوى القول بأنها القريبة المتهدِّلة. وزاد ابنُ عطية (٣/٤٢٩) قولًا نقله ولم ينسبه، أنّ المعنى: «قريبة بعضها من بعض». ٢٥٧٣٨- عن عبد الله بن عباس -من طريق عطية- في قوله: <q>﴿قنوان دانية﴾</q>، قال: تَهَدُّلُ العُذُوقِ من الطَّلْع{10}. (٦/١٥٨) ٢٥٧٣٩- عن البراء بن عازب -من طريق أبي إسحاق- <q>﴿قنوان دانية﴾</q>، قال: قريبة{11}. (٦/١٥٧) ٢٥٧٤٠- قال مجاهد بن جبر: <q>﴿دانية﴾</q>: مُتَدَلِّيَة{12}. (ز) ٢٥٧٤١- عن الضحاك بن مزاحم -من طريق عبيد بن سليمان- قال في قوله: <q>﴿ومن النخل من طلعها قنوان دانية﴾</q>: يعني: النخل القصار الملتزقة بالأرض، والقنوان: طَلْعُه{13}. (ز) ٢٥٧٤٢- عن قتادة بن دعامة -من طريق مَعْمَر- في قوله: <q>﴿قنوان﴾</q> قال: عُذُوقُ النخل، <q>﴿دانية﴾</q> قال: مُتَهَدِّلَة، يعني: مُتَدَلِّية{14}. (٦/١٥٨) ٢٥٧٤٣- قال مقاتل بن سليمان: وأخرجنا بالماء من النخل؛ <q>﴿من طلعها﴾</q> يعني: من ثمرها <q>﴿قنوان﴾</q> يعني: قصار النخل <q>﴿دانية﴾</q> يعني: ملتصقة بالأرض تُجْنى باليد{2}. (ز) <q>﴿وَجَنَّـٰتࣲ مِّنۡ أَعۡنَابࣲ وَٱلزَّیۡتُونَ وَٱلرُّمَّانَ﴾</q> - قراءات ٢٥٧٤٤- عن سليمان الأعمش -من طريق حمزة- أنّه قرأ: (وجَنّاتٌ مِّنْ أعْنابٍ) بالرفع{16}. (ز) <q>﴿وَجَنَّـٰتࣲ مِّنۡ أَعۡنَابࣲ وَٱلزَّیۡتُونَ وَٱلرُّمَّانَ﴾</q> - تفسير الآية ٢٥٧٤٥- قال مقاتل بن سليمان: وأخرجنا بالماء جنات، يعني: البساتين. ثُمَّ نعت البساتين، فقال: <q>﴿من أعناب والزيتون والرمان..﴾</q>{2}. (ز) <q>﴿مُشۡتَبِهࣰا وَغَیۡرَ مُتَشَـٰبِهٍۗ﴾</q> - تفسير ٢٥٧٤٦- عن قتادة بن دعامة -من طريق خالد بن قيس- في قوله: <q>﴿مشتبها وغير متشابه﴾</q>، قال: متشابهًا ورَقُه، مختلِفًا ثمرُه{18}. (٦/١٥٨) ٢٥٧٤٧- قال مقاتل بن سليمان: <q>﴿مشتبها﴾</q> ورقها في المنظر، يشبه ورق الزيتون، وورق الرمان، ثم قال: <q>﴿وغير متشابه﴾</q> في اللون، مختلف في الطَّعم{2}. (ز) ٢٥٧٤٨- قال يحيى بن سلّام: يعني: وأخرجنا الزيتون والرمان <q>﴿مشتبها وغير متشابه﴾</q>، أي: مشتبهًا في طعمه ولونه، وغير متشابه{20}. (ز) <q>﴿ٱنظُرُوۤا۟ إِلَىٰ ثَمَرِهِۦۤ إِذَاۤ أَثۡمَرَ وَیَنۡعِهِۦۤۚ﴾</q> - قراءات ٢٥٧٤٩- عن يحيى بن وثّاب -من طريق الأعمش- أنّه كان يقرأ: ‹إلى ثُمُرِهِ›. يقول: هو أصناف المال{21}٢٣٥٥. (ز) ٢٣٥٥ وجَّه ابنُ عطية (٣/٤٣٠) قول يحيى بن وثاب بقوله: «كأن المعنى: انظروا إلى الأموال التي تتحصل منه». ٢٥٧٥٠- عن عاصم ابن أبي النجود أنّه قرأ: <q>﴿انْظُرُوا إلى ثَمَرِهِ﴾</q> بنصب الثاء والميم، <q>﴿ويَنْعِهِ﴾</q> بنصب الياء{22}. (٦/١٥٩) <q>﴿ٱنظُرُوۤا۟ إِلَىٰ ثَمَرِهِۦۤ إِذَاۤ أَثۡمَرَ وَیَنۡعِهِۦۤۚ﴾</q> - تفسير الآية ٢٥٧٥١- عن مجاهد بن جبر -من طريق قيس بن سعد- قال: الثُّمُر: هو المال. والثَّمَر: ثمر النخل{23}. (ز) ٢٥٧٥٢- عن محمد بن كعب القرظي -من طريق موسى بن عبيدة- في قوله: <q>﴿انظروا إلى ثمره إذا أثمر﴾</q>، قال: رُطَبه، وعِنَبه{24}. (٦/١٥٩) ٢٥٧٥٣- قال مقاتل بن سليمان: <q>﴿انظروا إلى ثمره إذا أثمر﴾</q> حين يبدو غضًّا أوَّلُه صِيصًا{25} <q>﴿وينعه﴾</q>{2}. (ز) <q>﴿ٱنظُرُوۤا۟ إِلَىٰ ثَمَرِهِۦۤ إِذَاۤ أَثۡمَرَ وَیَنۡعِهِۦۤۚ﴾</q> - آثار متعلقة بالآية ٢٥٧٥٤- عن محمد بن مِسْعَر، قال: فَرْضًا على الناس إذا أُخرِجت الثمار أن يَخرُجوا وينظُروا إليها، قال الله: <q>﴿انظروا إلى ثمره إذا أثمر﴾</q>{27}. (٦/١٥٩) <q>﴿وَیَنۡعِهِۦۤۚ﴾</q> - تفسير ٢٥٧٥٥- عن عبد الله بن عباس -من طريق علي بن أبي طلحة- <q>﴿وينعه﴾</q>، قال: نُضْجِه{28}. (٦/١٥٩) ٢٥٧٥٦- عن عبد الله بن عباس: أنّ نافع بن الأزرق قال له: أخبِرني عن قوله: <q>﴿وينعه﴾</q>. قال: نُضْجِه، وبلاغِه. قال: وهل تعرف العرب ذلك؟ قال: نعم، أما سمعتَ الشاعر وهو يقول: = إذا ما مَشَتْ وسْطَ النساء تأوَّدَتْ كما اهْتَزَّ غُصْنٌ ناعِمَ النَّبْتِ يانِعُ {29}. (٦/١٦٠) ٢٥٧٥٧- عن البراء بن عازب -من طريق أبي إسحاق- <q>﴿وينعه﴾</q>، قال: نُضْجه{30}. (٦/١٥٩) ٢٥٧٥٨- عن عطاء الخراساني= (ز) ٢٥٧٥٩- وعبد الله بن أبي إسحاق البصري، مثل ذلك{31}. (ز) ٢٥٧٦٠- عن الضحاك بن مُزاحم -من طريق عبيد بن سليمان- قال في قوله: <q>﴿وينعه﴾</q>: يعني: نُضْجه{32}. (ز) ٢٥٧٦١- عن قتادة بن دعامة -من طريق مَعْمَر- في قوله: <q>﴿وينعه﴾</q>، قال: نُضْجه{33}. (ز) ٢٥٧٦٢- عن إسماعيل السُّدِّيّ -من طريق أسباط- <q>﴿وينعه﴾</q>، يقول: ونُضْجه{32}. (ز) <q>﴿إِنَّ فِی ذَ ٰ⁠لِكُمۡ لَـَٔایَـٰتࣲ لِّقَوۡمࣲ یُؤۡمِنُونَ ۝٩٩﴾</q> - تفسير ٢٥٧٦٣- قال الحسن البصري: <q>﴿إن في ذلكم لآيات لقوم يؤمنون﴾</q>، يقول: الذي أخرج من هذا الماء هذا النبات، وهذا الخضر، وهذه الجنات؛ قادرٌ على أن يُحْيِيَ الموتى{20}. (ز) ٢٥٧٦٤- قال مقاتل بن سليمان: <q>﴿إن في ذلكم﴾</q> يعني: إنّ في هذا الذي ذُكِر من صنعه وعجائبه <q>﴿لآيات﴾</q> لَعِبْرَة <q>﴿لقوم يؤمنون﴾</q> يعني: يُصَدِّقون بالتوحيد{2}. (ز) ",footnotes:1:تفسير مقاتل بن سليمان ١/٥٨٠.تفسير مقاتل بن سليمان ١/٥٨١.يُعْذبه: يجعله عَذْبًا. اللسان (عذب).أخرجه ابن أبي حاتم ٤/١٣٥٨.أخرجه ابن جرير ٩/٤٤٥، وابن أبي حاتم ٤/١٣٥٨. وعزاه السيوطي إلى أبي الشيخ.تفسير مقاتل بن سليمان ١/٥٨١.أخرجه ابن جرير ٩/٤٤٦، وابن أبي حاتم ٤/١٣٥٩. وعزاه السيوطي إلى ابن المنذر.الكبائس: جمع كِباسَة، وهو العِذْق التام بشَماريخه ورُطَبه. النهاية (كبس).أخرجه ابن أبي حاتم ٤/١٣٥٩. وعزاه السيوطي إلى أبي الشيخ.أخرجه ابن جرير ٩/٤٤٧، وابن أبي حاتم ٤/١٣٥٩.أخرجه عبد الرزاق ١/٢١٥، وابن جرير ٩/٤٤٧، وابن أبي حاتم ٤/١٣٥٩. وعزاه السيوطي إلى الفريابي، وعبد بن حميد، وابن المنذر، وأبي الشيخ.تفسير الثعلبي ٤/١٧٤، وتفسير البغوي ٣/١٧٢.أخرجه ابن جرير ٩/٤٤٧، وابن أبي حاتم ٤/١٣٥٨.أخرجه عبد الرزاق ١/٢١٥، وابن جرير ٩/٤٤٧، وابن أبي حاتم ٤/١٣٥٩. وعزاه السيوطي إلى عبد بن حُمَيد، وابن المنذر، وأبي الشيخ.تفسير مقاتل بن سليمان ١/٥٨١.أخرجه ابن جرير ٩/٤٤٨. وهي قراءة شاذة. انظر: مختصر ابن خالويه ص٤٥.تفسير مقاتل بن سليمان ١/٥٨١.أخرجه ابن جرير ٩/٤٤٩، وابن أبي حاتم ٤/١٣٥٩. وعزاه السيوطي إلى عبد بن حُمَيد، وابن المنذر، وأبي الشيخ.تفسير مقاتل بن سليمان ١/٥٨١.تفسير ابن أبي زمنين ٢/٨٨.أخرجه ابن جرير ٩/٤٥٠. وهي قراءة متواترة، قرأ بها حمزة، والكسائي، وخلف العاشر، وقرأ بقية العشرة: <q>﴿إلى ثَمَرِهِ﴾</q> بفتح الثاء والميم. انظر: النشر ٢/٢٦٠، والإتحاف ص٢٧٠. أمّا <q>﴿يَنْعِهِ﴾</q> المذكور في الأثر التالي فلا خلاف بين القراء فيه أنه بفتح الياء.عزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ٩/٤٥٠.أخرجه ابن أبي حاتم ٤/١٣٥٩.كذا في مطبوعة المصدر، والصِّيص: لغة فِي الشِّيص وهو الحَشَف مِنَ التَّمْرِ. لسان العرب (صيص، شيص).تفسير مقاتل بن سليمان ١/٥٨١.عزاه السيوطي إلى أبي الشيخ.أخرجه ابن جرير ٩/٤٥١-٤٥٢. وعلَّقه ابن أبي حاتم ٤/١٣٦٠. وعزاه السيوطي إلى ابن المنذر، وأبي الشيخ.أخرجه الطستي -كما في الإتقان ٢/٦٩-.أخرجه ابن أبي حاتم ٤/١٣٦٠. وعزاه السيوطي إلى أبي عبيد، وابن المنذر.علَّقه ابن أبي حاتم ٤/١٣٦٠.أخرجه ابن جرير ٩/٤٥٢.أخرجه عبد الرزاق ٢/٢١٥، وابن جرير ٩/٤٥٢ وله أيضًا من طريق سعيد.أخرجه ابن جرير ٩/٤٥٢.تفسير ابن أبي زمنين ٢/٨٨.تفسير مقاتل بن سليمان ١/٥٨١.
6,100," <q>﴿وَجَعَلُوا۟ لِلَّهِ شُرَكَاۤءَ ٱلۡجِنَّ وَخَلَقَهُمۡۖ وَخَرَقُوا۟ لَهُۥ بَنِینَ وَبَنَـٰتِۭ بِغَیۡرِ عِلۡمࣲۚ سُبۡحَـٰنَهُۥ وَتَعَـٰلَىٰ عَمَّا یَصِفُونَ ۝١٠٠﴾</q> - نزول الآية ٢٥٧٦٥- قال محمد بن السائب الكلبي: نزلت في الزنادقة، أثبتوا الشِّرْكَة لإبليس في الخلق، فقالوا: اللهُ خالقُ النورِ والناس والدواب والأنعام، وإبليسُ خالقُ الظلمةِ والسباع والحيات والعقارب. وهذا كقوله: <q>﴿وجعلوا بينه وبين الجنة نسبا﴾</q> [الصافات:١٥٨]، وإبليس من الجِنَّة{1}. (ز) ٢٥٧٦٦- قال مقاتل بن سليمان: <q>﴿وجعلوا لله شركاء الجن﴾</q> من الملائكة، وذلك أنّ جُهَيْنة وبني سلمة وخزاعة وغيرهم قالوا: إنّ حيًّا من الملائكة يُقال لهم: الجن بنات الرحمن. فقال الله: <q>﴿وخلقهم﴾</q>{2}. (ز) <q>﴿وَجَعَلُوا۟ لِلَّهِ شُرَكَاۤءَ ٱلۡجِنَّ وَخَلَقَهُمۡۖ وَخَرَقُوا۟ لَهُۥ بَنِینَ وَبَنَـٰتِۭ بِغَیۡرِ عِلۡمࣲۚ سُبۡحَـٰنَهُۥ وَتَعَـٰلَىٰ عَمَّا یَصِفُونَ ۝١٠٠﴾</q> - قراءات ٢٥٧٦٧- عن يحيى بن يَعْمَرَ البصري -من طريق يحيى بن عقيل- أنّه كان يقرَؤها: (وجَعَلُواْ للهِ شُرَكَآءَ الجِنَّ وخَلْقَهُمْ) خفيفةً. يقول: جعَلوا لله خلْقَهم{3}٢٣٥٦. (٦/١٦١) ٢٣٥٦ وجَّه ابنُ عطية (٣/٤٣١) قول يحيى بن يعمر بقوله: «أي: جعلوا خلقهم الذي ينحتونه أصنامًا شركاء لله». ٢٥٧٦٨- عن الحسن البصري أنّه قرَأ: (خَلَّقَهُمْ) مُثَقَّلَةً. يقول: هو خلَّقهم{4}. (٦/١٦١) ٢٥٧٦٩- عن الحسن البصري، في الآية، قال: ‹خَرَّقُواْ› ما هو؟! إنّما <q>﴿خَرَقُواْ﴾</q> خفيفة{5}. (٦/١٦١) <q>﴿وَجَعَلُوا۟ لِلَّهِ شُرَكَاۤءَ ٱلۡجِنَّ وَخَلَقَهُمۡۖ﴾</q> - تفسير ٢٥٧٧٠- عن عبد الله بن عباس -من طريق علي بن أبي طلحة- في قوله: <q>﴿وجعلوا لله شركاء الجن وخلقهم﴾</q>، قال: واللهُ خلَقهم{6}. (٦/١٦٠) ٢٥٧٧١- عن الضحاك بن مُزاحِم -من طريق جُوَيْبِر- في قوله: <q>﴿وجعلوا لله شركاء﴾</q>، يقول: هل تشركون عبيدكم في الذي لكم فتكونوا فيه سواء؟ فكيف ترضون لي ما لا ترضون لأنفسكم؟!{7}. (ز) ٢٥٧٧٢- قال مقاتل بن سليمان: <q>﴿وجعلوا﴾</q> يعني: وصفوا <q>﴿لله﴾</q> الذي خلقهم في التقديم <q>﴿شركاء الجن﴾</q> من الملائكة{2}. (ز) ٢٥٧٧٣- عن عبد الملك ابن جُرَيْج -من طريق حجّاج- قوله: <q>﴿وجعلوا لله شركاء الجن﴾</q>، قال: قول الزَّنادِقة{9}. (ز) <q>﴿وَخَرَقُوا۟ لَهُۥ بَنِینَ وَبَنَـٰتِۭ بِغَیۡرِ عِلۡمࣲۚ﴾</q> - تفسير ٢٥٧٧٤- عن عبد الله بن عباس -من طريق علي بن أبي طلحة- في قوله: <q>﴿وخرقوا له بنين وبنات بغير علم﴾</q>، قال: تَخَرَّصوا{6}. (٦/١٦٠) ٢٥٧٧٥- عن عبد الله بن عباس -من طريق عطِيَّة- في قوله: <q>﴿وخرقوا له بنين وبنات﴾</q>، قال: جعَلوا له بنين وبنات{11}. (٦/١٦٠) ٢٥٧٧٦- عن عبد الله بن عباس: أنّ نافع بن الأزرق قال له: أخبِرني عن قوله: <q>﴿وخرقوا له بنين وبنات﴾</q>. قال: وصفوا لله بنين وبنات افتراءً عليه. قال: وهل تعرف العرب ذلك؟ قال: نعم، أما سمعتَ حسان بن ثابت يقول: اخترَقَ القولَ بها لاهيًا مستقبلًا أشعثَ عذبَ الكلامْ{12}. (٦/١٦١) ٢٥٧٧٧- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿وخرقوا﴾</q>، قال: كذَبوا{13}. (٦/١٦٠) ٢٥٧٧٨- عن الضحاك بن مُزاحِم -من طريق جُوَيْبِر- <q>﴿وخرقوا له بنين وبنات﴾</q>، قال: وصَفوا له{14}. (ز) ٢٥٧٧٩- عن الحسن البصري، في الآية، قال: ‹خَرَّقُواْ› ما هو؟! إنّما <q>﴿خَرَقُواْ﴾</q> خفيفة، كان الرجل إذا كذَب الكَذْبَةَ في نادي القوم قيل: خَرَقَها{15}. (٦/١٦١) ٢٥٧٨٠- عن قتادة بن دعامة -من طريق مَعْمَر- <q>﴿وخرقوا له بنين وبنات بغير علم﴾</q>، قال: خرصوا له بنين وبنات{16}. (ز) ٢٥٧٨١- عن قتادة بن دعامة -من طريق خالد بن قيس- في قوله: <q>﴿وخرقوا له بنين وبنات﴾</q>، قال: كذَبوا له؛ أمّا اليهود والنصارى فقالوا: نحنُ أبناء الله وأحباؤُه. وأمّا مشركو العرب فكانوا يعبدون اللات والعزى، فيقولون: العُزّى بنات الله{17}. (٦/١٦١) ٢٥٧٨٢- عن إسماعيل السُّدِّيّ -من طريق أسباط- في قوله: <q>﴿وخرقوا له بنين وبنات﴾</q>، يعني: قطعوا. قال: قالت العرب: الملائكة بنات الله. وقالت اليهود والنصارى: المسيحُ وعزيرٌ ابنا الله{18}. (٦/١٦٠) ٢٥٧٨٣- عن أبي عمرو بن العلاء -من طريق عبد الوارث- <q>﴿وخرقوا له بنين وبنات﴾</q>، قال: تفسيرها: وكذبوا{19}. (ز) ٢٥٧٨٤- قال مقاتل بن سليمان: <q>﴿وخرقوا له﴾</q> يعني: وتخرَّصوا، يعني: يخلقوا لله <q>﴿بنين وبنات بغير علم﴾</q> يعلمونه أنّ له بنين وبنات، وذلك أنّ اليهود قالوا: عزيرٌ ابن الله. وقالت النصارى: المسيح ابن الله. وقالت العرب: الملائكة بنات الله{2}. (ز) ٢٥٧٨٥- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿وخرقوا له بنين وبنات بغير علم﴾</q>، قال: خرقوا: كذبوا، لم يكن لله بنون ولا بنات، قالت النصارى: المسيح ابن الله. وقال المشركون: الملائكة بنات الله. فكل خرقوا الكذب، <q>﴿وخرقوا﴾</q>: اخترقوا{21}. (ز) <q>﴿سُبۡحَـٰنَهُۥ وَتَعَـٰلَىٰ عَمَّا یَصِفُونَ ۝١٠٠﴾</q> - تفسير ٢٥٧٨٦- عن قتادة بن دعامة -من طريق خالد بن قيس- في قوله: <q>﴿سبحانه وتعالى عما يصفون﴾</q>، قال: أي: عما يَكْذِبون{22}٢٣٥٧. (٦/١٦١) ٢٣٥٧ وجَّه ابنُ جرير (٩/٤٥٧) قول قتادة، فقال: «وأَحْسَبُ أنّ قتادة عنى بتأويله ذلك كذلك: أنّهم يكذبون في وصفهم الله بما كانوا يصفونه به، من ادِّعائهم له بنين وبنات، لا أنه وجَّه تأويل الوصف إلى الكذب». ٢٥٧٨٧- قال مقاتل بن سليمان: يقول الله: <q>﴿سبحانه﴾</q> نزَّه نفسه عما قالوا من البهتان، ثم عظَّم نفسه، فقال: <q>﴿وتعالى﴾</q> يعني: وارتفع <q>﴿عما يصفون﴾</q> يعني: يقولون من الكذب{2}. (ز) ",footnotes:1:تفسير الثعلبي ٤/١٧٥، وتفسير البغوي ٣/١٧٣.تفسير مقاتل بن سليمان ١/٥٨١.أخرجه ابن جرير ٩/٤٥٣. وعزاه السيوطي إلى أبي الشيخ. وهي قراءة شاذة. انظر: مختصر ابن خالويه ص٤٥، والمحتسب ١/٢٢٤.عزاه السيوطي إلى أبي الشيخ. وهي قراءة شاذة.عزاه السيوطي إلى أبي الشيخ. ‹خَرَّقُواْ› بتشديد الراء قراءة متواترة، قرأ بها نافع، وأبو جعفر، وقرأ بقية العشرة: <q>﴿خَرَقُواْ﴾</q> مخففة. انظر: النشر ٢/٢٦١.أخرجه ابن جرير ٩/٤٥٤، وابن أبي حاتم ٤/١٣٦٠. وعزاه السيوطي إلى ابن المنذر.أخرجه ابن أبي حاتم ٤/١٣٦٠.تفسير مقاتل بن سليمان ١/٥٨١.أخرجه ابن جرير ٩/٤٥٥.أخرجه ابن جرير ٩/٤٥٤، وابن أبي حاتم ٤/١٣٦٠. وعزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ٩/٤٥٤، وابن أبي حاتم ٤/١٣٦٠.عزاه السيوطي إلى الطستي.تفسير مجاهد ص٣٢٦، وأخرجه ابن جرير ٩/٤٥٤، وابن أبي حاتم ٤/١٣٦٠. وعزاه السيوطي إلى عبد بن حُمَيد، وابن المنذر.أخرجه ابن جرير ٩/٤٥٦، وابن أبي حاتم ٤/١٣٦١.عزاه السيوطي إلى أبي الشيخ. وعلَّق ابن أبي حاتم ٤/١٣٦٠ نحو آخره.أخرجه ابن جرير ٩/٤٥٥. وعلَّقه ابن أبي حاتم ٤/١٣٦٠ بنحوه.أخرجه ابن جرير ٩/٤٥٥، وابن أبي حاتم ٤/١٣٦١. وعزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ٩/٤٥٥ دون أوله، وابن أبي حاتم ٤/١٣٦٠-١٣٦١.أخرجه ابن جرير ٩/٤٥٦.تفسير مقاتل بن سليمان ١/٥٨١.أخرجه ابن جرير ٩/٤٥٥، وابن أبي حاتم ٤/١٣٦١.أخرجه ابن جرير ٩/٤٥٧، وابن أبي حاتم ٤/١٣٦١. وعزاه السيوطي إلى عبد بن حميد.تفسير مقاتل بن سليمان ١/٥٨١.
6,101," <q>﴿بَدِیعُ ٱلسَّمَـٰوَ ٰ⁠تِ وَٱلۡأَرۡضِۖ﴾</q> - تفسير ٢٥٧٨٨- عن أبي العالية الرِّياحي -من طريق الربيع- قوله: <q>﴿بديع السموات والأرض﴾</q>، قال: ابتَدَع خَلْقَهما، ولم يشركه في خلقهما أحد{1}. (ز) ٢٥٧٨٩- عن الربيع بن أنس، نحو ذلك{2}. (ز) ٢٥٧٩٠- عن إسماعيل السُّدِّيّ -من طريق أسباط- <q>﴿بديع السموات والأرض﴾</q>، يقول: ابتدعهما، فخلقهما، ولم يخلق قبلهما شيئًا فيتَمَثَّل عليه{1}. (ز) ٢٥٧٩١- عن مجاهد بن جبر، نحو ذلك{2}. (ز) ٢٥٧٩٢- قال مقاتل بن سليمان: فعظَّم نفسه، وأخبر عن قدرته، فقال: <q>﴿بديع السماوات والأرض﴾</q> لم يكونا، فابتَدَع خلقَهما{5}. (ز) ٢٥٧٩٣- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿بديع السموات والأرض﴾</q>، قال: هو الذي ابتدع خلقهما جل جلاله، فخلقهما، ولم تكونا شيئًا قبله{6}. (ز) <q>﴿أَنَّىٰ یَكُونُ لَهُۥ وَلَدࣱ وَلَمۡ تَكُن لَّهُۥ صَـٰحِبَةࣱۖ وَخَلَقَ كُلَّ شَیۡءࣲۖ وَهُوَ بِكُلِّ شَیۡءٍ عَلِیمࣱ ۝١٠١﴾</q> - تفسير ٢٥٧٩٤- قال مقاتل بن سليمان: <q>﴿أنى﴾</q> يعني: مِن أين <q>﴿يكون له ولد ولم تكن له صاحبة﴾</q> يعني: زوجة، <q>﴿وخلق كل شيء﴾</q> يعني: من الملائكة، وعزير، وعيسى، وغيرهم، فهم خلقُه، وعبادُه، وفي ملكه{5}. (ز) ",footnotes:1:أخرجه ابن أبي حاتم ٤/١٣٦٢.علَّقه ابن أبي حاتم ٤/١٣٦٢.أخرجه ابن أبي حاتم ٤/١٣٦٢.علَّقه ابن أبي حاتم ٤/١٣٦٢.تفسير مقاتل بن سليمان ١/٥٨١-٥٨٢.أخرجه ابن جرير ٩/٤٥٧.تفسير مقاتل بن سليمان ١/٥٨١-٥٨٢.
