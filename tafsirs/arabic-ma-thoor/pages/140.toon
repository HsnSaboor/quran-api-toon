quran[7]{c,v,t}:
  6,95,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿إِنَّ ٱللَّهَ فَالِقُ ٱلۡحَبِّ وَٱلنَّوَىٰۖ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٢٥٦٠٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطية العوفي- في قوله: <span class="qpc-hafs">﴿فالق الحب والنوى﴾</span>، يقول: خلَق الحبَّ والنَّوى{1}. (٦/١٤٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٥٦٠٣<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿فالق الحب والنوى﴾</span>، قال: الشَّقّان اللذان فيهما{2}. (٦/١٤٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٥٦٠٤<span class="dash">-</span></span> عن <span class="name-2">الضحاك بن مُزاحِم</span> -من طريق جُوَيْبِر- في قوله: <span class="qpc-hafs">﴿إن الله فالق الحب والنوى﴾</span>، قال: خالق الحبِّ والنَّوى{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٥٦٠٥<span class="dash">-</span></span> عن <span class="name-2">أبي مالك غزوان الغفاري</span> -من طريق حصين- في قوله: <span class="qpc-hafs">﴿فالق الحب والنوى﴾</span>، قال: الشَّقُّ الذي في النواة والحِنطة{4}. (٦/١٤٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٥٦٠٦<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span>: قوله: <span class="qpc-hafs">﴿إن الله فالق الحب والنوى﴾</span>، يعني: ينفلق عن النبات{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٥٦٠٧<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٥٦٠٨<span class="dash">-</span></span> و<span class="name-2">قتادة بن دعامة</span>: معناه: يشق الحبة عن السنبلة، والنواة عن النخلة، فيخرجها منها{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٥٦٠٩<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- في قوله: <span class="qpc-hafs">﴿فالق الحب والنوى﴾</span>، قال: يفلِقُ الحبَّ والنَّوى عن النبات{7}. (٦/١٤٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٥٦١٠<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- في قوله: <span class="qpc-hafs">﴿فالق الحب والنوى﴾</span>، قال: فالقُ الحبة عن السُّنبلة، وفالقُ النواة عن النخلة{8}. (٦/١٤٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٥٦١١<span class="dash">-</span></span> عن يعقوب، قال: سألتُ <span class="name-2">زيد بن أسلم</span> عن قول الله: <span class="qpc-hafs">﴿فالق الحب والنوى يخرج الحي من الميت ومخرج الميت من الحي﴾</span>، قال: الحبة قد فلقها، والنواة قد فلقها، فتُزرَع، فيُخرِج منها كما ترى النخل والزرع، والنطفة يُخرِجها ميتة، فيُقِرُّها في رَحِم المرأة، فيُخرِج منها خَلْقًا{9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٥٦١٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿إن الله فالق الحب﴾</span> يعني: خالق الحب، يعني: البُرَّ، والشعير، والذُّرة، والحبوب كلها. ثم قال: <span class="qpc-hafs">﴿والنوى﴾</span> يعني: كل ثمرة لها نوى؛ الخوخ، والنبق، والمشمش، والعنب، والإجاص، وكل ما كان من الثمار له نوى{10}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٥٦١٣<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿فالق الحب والنوى﴾</span>، قال: الله فالق ذلك، فلقه فأنبت منه ما أنبت، فلق النواة فأخرج منها نبات نخلة، وفلق الحبة فأخرج نبات الذي خلق{3}<span class=comment-ref>٢٣٥٠</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٢٣٥٠</span> أفادت الآثار اختلاف المفسرين في معنى: <span class="qpc-hafs">﴿فالِقُ الحَبِّ والنَّوى﴾</span> على ثلاثة أقوال: <b>الأول:</b> شَقَّ الله جميع الحب عن جميع النبات الذي يكون منه، وشق النوى عن جميع الأشجار الكائنة عنه. وهو قول السدي، وقتادة، وابن زيد. <b>الثاني:</b> معنى فالق: خالق. وهو قول ابن عباس من طريق العوفي، والضحاك. <b>الثالث:</b> الشَّقَّ الذي في الحبَّة والنَّواة.وهو قول مجاهد، وأبي مالك.</p><p>وقد <span class="comment-type-3">رجَّح</span> <u>ابنُ جرير</u> (٩/٤٢٢) القولَ الأول <span class="mustanad">مستندًا إلى السياق</span>، فقال: «وذلك أنّ الله -جل ثناؤه- أتْبَع ذلك بإخباره عن إخراجه الحي من الميت، والميت من الحي، فكان معلومًا بذلك أنه إنما عنى بإخباره عن نَفْسِه أنّه فالق الحب عن النبات، والنوى عن الغروس والأشجار، كما هو مُخْرِج الحي من الميت، والميت من الحي».</p><p>و<span class="comment-type-4">وافقه</span> <u>ابنُ عطية</u> (٣/٤٢٤) <span class="mustanad">مستندًا إلى ظاهر لفظ الآية</span>، فقال: «وهذا هو الظاهر الذي يعطي العبرة التامة».</p><p>و<span class="comment-type-2">انتَقَد</span> <u>ابنُ جرير</u> <span class="mustanad">مستندًا إلى مخالفة لغة العرب</span> قول الضحاك، وابن عباس من طريق العوفي، فقال: «وأمّا القول الذي حُكِي عن الضحاك في معنى فالق: أنّه خالق؛ فقولٌ -إن لم يكن أراد به أنّه خالقٌ منه النبات والغروس بِفَلْقِه إياه- لا أعرف له وجْهًا؛ لأنه لا يُعْرَف في كلام العرب: فَلَقَ الله الشيء، بمعنى: خَلَق».</p><p><span class="comment-type-2">وانتقد</span> <u>ابنُ عطية</u> <span class="mustanad">مستندًا لدلالة العقل</span> القولَ الثالث، فقال: «والعبرة على هذا القول مخصوصةً في بعض الحَبِّ وبعض النَّوى، وليس لذلك وجْه».</div></p><p><h3><span class="qpc-hafs">﴿یُخۡرِجُ ٱلۡحَیَّ مِنَ ٱلۡمَیِّتِ وَمُخۡرِجُ ٱلۡمَیِّتِ مِنَ ٱلۡحَیِّۚ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٢٥٦١٤<span class="dash">-</span></span> عن عبيد الله بن عبد الله: أنّ خالدة بنت الأسود بن عبد يغوث دخلت على رسول الله ﷺ وهو عند بعض نسائه، فقال: «<b>مَن هذه؟</b>». قيل: إحدى خالاتك، يا رسول الله. قال: «<b>إنّ خالاتي بهذه البلدة لغرائب، فمن هي؟</b>». قيل: خالدة بنت الأسود بن عبد يغوث. فقال: «<b>سبحان الله! <span class="qpc-hafs">﴿يخرج الحي من الميت﴾</span></b>»{12}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٥٦١٥<span class="dash">-</span></span> قال <span class="name-1">عمر بن الخطاب</span> -من طريق سلمان-: خَمَّر الله ﷿ طينة آدم أربعين يومًا، ثم وضع يده فيها، فارتفع على هذه كُلُّ طيب، وعلى هذه كُلُّ خبيث، ثم خلط بعضه ببعض -وقال مؤمل بيده هكذا-، ودمج إحداهما بالأخرى، ثم خلق منها آدم، فمن ثم <span class="qpc-hafs">﴿يخرج الحي من الميت ومخرج الميت من الحي﴾</span>؛ يخرج المؤمن من الكافر، ويخرج الكافر من المؤمن{13}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٥٦١٦<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٥٦١٧<span class="dash">-</span></span> و<span class="name-2">قتادة بن دعامة</span>، نحو ذلك{14}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٥٦١٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن مسعود</span> -من طريق إبراهيم- قوله: <span class="qpc-hafs">﴿ومخرج الميت من الحي﴾</span>، قال: يخرج النطفة الميتة من الرجل الحي{15}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٥٦١٩<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي بن أبي طلحة- قوله: <span class="qpc-hafs">﴿إن الله فالق الحب والنوى يخرج الحي من الميت ومخرج الميت من الحي﴾</span>، قال: يخرج النطفة الميتة من الحي، ثم يخرج من النطفة بشرًا حيًّا{16}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٥٦٢٠<span class="dash">-</span></span> عن <span class="name-1">أبي سعيد الخدري</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٥٦٢١<span class="dash">-</span></span> و<span class="name-2">سعيد بن جبير</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٥٦٢٢<span class="dash">-</span></span> و<span class="name-2">إبراهيم النخعي</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٥٦٢٣<span class="dash">-</span></span> و<span class="name-2">الضحاك بن مزاحم</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٥٦٢٤<span class="dash">-</span></span> و<span class="name-2">قتادة بن دعامة</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٥٦٢٥<span class="dash">-</span></span> و<span class="name-2">إسماعيل السُّدِّيّ</span>، نحو ذلك{14}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٥٦٢٦<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نَجِيح- في قوله: <span class="qpc-hafs">﴿يخرج الحي من الميت ومخرج الميت من الحي﴾</span>، قال: الناسَ الأحياء من النُّطف، والنُّطفةَ ميِّتةً تُخرَجُ من الناس الأحياء، ومن الأنعام والنبات كذلك أيضًا{18}. (٦/١٤٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٥٦٢٧<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span> -من طريق أبي المنيب- <span class="qpc-hafs">﴿يخرج الحي من الميت ومخرج الميت من الحي﴾</span>، قال: البيضة تخرج من الحي وهي ميتة، ثم يخرج منها الحي{15}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٥٦٢٨<span class="dash">-</span></span> عن <span class="name-2">أبي مالك غزوان الغفاري</span> -من طريق السدي- في قوله: <span class="qpc-hafs">﴿يخرج الحي من الميت﴾</span> قال: النخلةَ من النواة، والسُّنبلةَ من الحبة، <span class="qpc-hafs">﴿ومخرج الميت من الحي﴾</span> قال: النواة من النخلة، والحبة من السُّنبلة{20}. (٦/١٤٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٥٦٢٩<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- قال: أما <span class="qpc-hafs">﴿يخرج الحي من الميت﴾</span> فيخرج السنبلة الحيَّة من الحبَّة الميتة، ويخرج الحبَّة الميتة من السنبلة الحيَّة، ويخرج النخلة الحيَّة من النواة الميتة، ويخرج النواة الميتة من النخلة الحية{21}<span class=comment-ref>٢٣٥١</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٢٣٥١</span> <span class="comment-type-1">وجَّه</span> <u>ابنُ عطية</u> (٣/٤٢٥) قول السدي وأبي مالك بقوله: «فكأنّه جعل الخضرة والنضارة حياة، واليَبْسَ موتًا».</p><p>و<span class="comment-type-3">رجَّح</span> <u>ابنُ جرير</u> (٩/٤٢٤) <span class="mustanad">مستندًا إلى السياق</span> في معنى: <span class="qpc-hafs">﴿يُخْرِجُ الحَيَّ مِنَ المَيِّتِ ومُخْرِجُ المَيِّتِ مِنَ الحَيِّ﴾</span> قولَ السدي، وأبي مالك، وبيَّن علَّة ذلك، فقال: «وإنّما اخترنا التأويل الذي اخترنا في ذلك لأنّه عَقِيب قوله: <span class="qpc-hafs">﴿إنَّ اللَّهَ فالِقُ الحَبِّ والنَّوى﴾</span>».</p><p>و<span class="comment-type-4">رأى</span> قولَ ابن عباس من طريق علي بن أبي طلحة داخلًا تحت <span class="mustanad">عموم اللفظ</span>، فقال: «على أنّ قوله: <span class="qpc-hafs">﴿يُخْرِجُ الحَيَّ مِنَ المَيِّتِ ومُخْرِجُ المَيِّتِ مِنَ الحَيِّ﴾</span> وإن كان خبرًا من الله عن إخراجه من الحبّ السنبل، ومن السنبل الحبّ؛ فإنه داخلٌ في عمومه ما رُوِي عن ابن عباس في تأويل ذلك: وكلُّ ميتٍ أخرجه الله من جسمٍ حيٍّ، وكلُّ حيّ أخرجه الله من جسمٍ ميتٍ».</p><p>و<span class="comment-type-3">رجَّح</span> <u>ابنُ عطية</u> (٣/٤٢٥) قول ابن عباس، ولم يذكر مستندًا، ثم <span class="comment-type-4">علَّق</span> بعد إيراد القولين بقوله: «وهما على هذا التأويل الراجح معنيان متباينان، فيهما معتبر».</div></p><p><div></p><p><p><span class="item-no">٢٥٦٣٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿يخرج الحي من الميت﴾</span> يقول: أخرج الناس والدواب من النُّطَف وهي ميتة، ويخرج الطير كلها من البيضة وهي ميتة، ثم قال: <span class="qpc-hafs">﴿ومخرج الميت من الحي﴾</span> يعني: النطف والبيض من الحي، يعني: الحيوانات كلها{22}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿یُخۡرِجُ ٱلۡحَیَّ مِنَ ٱلۡمَیِّتِ وَمُخۡرِجُ ٱلۡمَیِّتِ مِنَ ٱلۡحَیِّۚ﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٢٥٦٣١<span class="dash">-</span></span> عن شهر بن حوشب -من طريق شبيل بن غرزة - قال: لما أُري إبراهيم ﵇ ملكوت السماوات والأرض رأى رجلًا يعصي الله، فدعا عليه فهَلَك، ثم آخر، ثم آخر فدعا عليهم فهلكوا، فنُودي: يا صاحب الدعوة، إني قد خلقت ابن آدم لثلاث: أُخرج منه ذُرِّيَّةً تعبدني، وتلا:<span class="qpc-hafs">﴿يُخْرِجُ الحَيَّ مِنَ المَيِّتِ ويُخْرِجُ المَيِّتَ مِنَ الحَيِّ﴾</span> [الروم: ١٩]، ويتوب إلى ما بينه وبين الهرم فأتوب عليه، ولا تأخذني عجلة العباد، أو يتمادى فالنار من ورائه{23}.(ز) (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿ذَ ٰ⁠لِكُمُ ٱللَّهُۖ فَأَنَّىٰ تُؤۡفَكُونَ ۝٩٥﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٢٥٦٣٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق الضحاك- في قوله: <span class="qpc-hafs">﴿فأنى تؤفكون﴾</span>، قال: كيف تُكَذِّبون؟!{18}. (٦/١٤٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٥٦٣٣<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق مَعْمَر- في قوله: <span class="qpc-hafs">﴿فأنى تؤفكون﴾</span>، قال: أنّى تُصرَفون؟!{18}. (٦/١٤٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٥٦٣٤<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span>، في قوله: <span class="qpc-hafs">﴿فأنى تؤفكون﴾</span>، قال: كيف تَضِلُّ عقولُكم عن هذا؟!{26}. (٦/١٤٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٥٦٣٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ذلكم الله﴾</span> الذي ذكر في هذه الآية مِن صنعه وحْدَه، يدُلُّ على توحيده بصنعه، <span class="qpc-hafs">﴿فأنى تؤفكون﴾</span> يقول: أنى يُكَذِّبون بأنّ الله وحده لا شريك له؟!{27}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ٩/٤٢١، وابن أبي حاتم ٤/١٣٥١.تفسير مجاهد ص٣٢٦، وأخرجه ابن جرير ٩/٤٢١، وابن أبي حاتم ٤/١٣٥١. وعزاه السيوطي إلى ابن أبي شيبة، وعَبد بن حُمَيد، وابن المنذر، وأبي الشيخ.أخرجه ابن جرير ٩/٤٢١.أخرجه سعيد بن منصور (٨٩١ - تفسير)، وابن جرير ٩/٤٢٢. وعزاه السيوطي إلى ابن المنذر.ذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٢/٨٦-.تفسير البغوي ٣/١٧٠.أخرجه عبد الرزاق ١/٢١٤، وابن جرير ٩/٤٢٠، وابن أبي حاتم ٤/١٣٥١. وعزاه السيوطي إلى ابن المنذر، وأبي الشيخ.أخرجه ابن جرير ٩/٤٢٠، وابن أبي حاتم ٤/١٣٥١.أخرجه عبد الله بن وهب في الجامع - تفسير القرآن ٢/١٢٤ (٢٤٦).تفسير مقاتل بن سليمان ١/٥٧٩.أخرجه ابن جرير ٩/٤٢١.أخرجه الطبراني في الكبير ٢٥/٩٦ (٢٤٨)، وابن أبي حاتم ٢/٦٢٦ (٣٣٦٠)، ٤/١٣٥١ (٧٦٥٥) واللفظ له مرسلًا.</p><p>قال الهيثمي في المجمع ٩/٢٦٤ (١٥٤٣٧): «رواه كله الطبراني بإسنادين، وإسناد الثاني حسن».أخرجه ابن أبي حاتم ٤/١٣٥١-١٣٥٢.علَّقه ابن أبي حاتم ٤/١٣٥٢.أخرجه ابن أبي حاتم ٤/١٣٥٢.أخرجه ابن جرير ٩/٤٢٣، وابن أبي حاتم ٤/١٣٥٢.علَّقه ابن أبي حاتم ٤/١٣٥٢.أخرجه ابن أبي حاتم ٤/١٣٥٣.أخرجه ابن أبي حاتم ٤/١٣٥٢.أخرجه ابن جرير ٩/٤٢٣، وابن أبي حاتم ٤/١٣٥٢-١٣٥٣. وعزاه السيوطي إلى عبد بن حميد، وأبي الشيخ.أخرجه ابن جرير ٩/٤٢٣.تفسير مقاتل بن سليمان ١/٥٧٩-٥٨٠.أخرجه ابن أبي الدنيا في كتاب «حسن الظن بالله» -موسوعة الإمام ابن أبي الدنيا (١/٩٦) رقم (٨٨).أخرجه ابن أبي حاتم ٤/١٣٥٣.أخرجه ابن أبي حاتم ٤/١٣٥٣.عزاه السيوطي إلى ابن أبي حاتم.تفسير مقاتل بن سليمان ١/٥٨٠.
  6,96,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿فَالِقُ ٱلۡإِصۡبَاحِ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٢٥٦٣٦<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطية العوفي- في قوله: <span class="qpc-hafs">﴿فالق الإصباح﴾</span>، قال: خالق الليل والنهار{1}. (٦/١٤٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٥٦٣٧<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي بن أبي طلحة- في قوله: <span class="qpc-hafs">﴿فالق الإصباح﴾</span>، قال: يعني بالإصباح: ضوءَ الشمس بالنهار، وضوءَ القمر بالليل{2}. (٦/١٤٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٥٦٣٨<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نَجِيح- في قوله: <span class="qpc-hafs">﴿فالق الإصباح﴾</span>، قال: إضاءة الفجر{3}. (٦/١٤٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٥٦٣٩<span class="dash">-</span></span> عن <span class="name-2">الضحاك بن مزاحم</span> -من طريق عبيد بن سليمان- في قوله: <span class="qpc-hafs">﴿فالق الإصباح﴾</span>، قال: خالقُ النور؛ نور النهار{4}. (٦/١٤٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٥٦٤٠<span class="dash">-</span></span> عن <span class="name-2">الضحاك بن مزاحم</span> -من طريق جُوَيْبِر- قال: <span class="qpc-hafs">﴿فالق الإصباح﴾</span>، قال: إضاءة الصبح{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٥٦٤١<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق مَعْمَر- في قوله: <span class="qpc-hafs">﴿فالق الإصباح﴾</span>، قال: فالقُ الصبح{6}. (٦/١٤٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٥٦٤٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثم ذكر أيضًا في هذه مِن صنعه لِيَدُلَّ على توحيده بصنعه، فقال: <span class="qpc-hafs">﴿فالق الإصباح﴾</span> يعني: خالق النهار من حين يبدو أوَّلُه{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٥٦٤٣<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿فالق الإصباح﴾</span>، قال: فلق الإصباح عن الليل{8}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَجَعَلَ ٱلَّیۡلَ سَكَنࣰا﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٢٥٦٤٤<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد بن بشير- في قوله: ‹وجاعِلُ اللَّيْلِ سَكَنًا›، قال: يسكُنُ فيه كلُّ طير ودابة{9}. (٦/١٤٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٥٦٤٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وجعل الليل سكنا﴾</span> لخلقه، يسكنون فيه لراحة أجسادهم{7}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَٱلشَّمۡسَ وَٱلۡقَمَرَ حُسۡبَانࣰاۚ ذَ ٰ⁠لِكَ تَقۡدِیرُ ٱلۡعَزِیزِ ٱلۡعَلِیمِ ۝٩٦﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٢٥٦٤٦<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي بن أبي طلحة- في قوله: <span class="qpc-hafs">﴿والشمس والقمر حسبانا﴾</span>، يعني: عدد الأيام، والشهور، والسنين{11}. (٦/١٤٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٥٦٤٧<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطية العوفي- <span class="qpc-hafs">﴿والشمس والقمر حسبانا﴾</span>، قال: يجريان إلى أجل جُعِل لهما{12}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٥٦٤٨<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن جُرَيْج- <span class="qpc-hafs">﴿والشمس والقمر حسبانا﴾</span>، قال: هو مثل قوله: <span class="qpc-hafs">﴿كل في فلك يسبحون﴾</span> [يس:٤٠]، ومثل قوله: و<span class="qpc-hafs">﴿الشمس والقمر بحسبان﴾</span> [الرحمن:٥]{13}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٥٦٤٩<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق مَعْمَر- في قوله: <span class="qpc-hafs">﴿والشمس والقمر حسبانا﴾</span>، قال: يدوران في حساب{14}. (٦/١٤٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٥٦٥٠<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد بن بشير- <span class="qpc-hafs">﴿حسبانا﴾</span>، قال: ضياءً{15}. (٦/١٤٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٥٦٥١<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- <span class="qpc-hafs">﴿والشمس والقمر حسبانا﴾</span>، يقول: بحساب{13}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٥٦٥٢<span class="dash">-</span></span> عن <span class="name-2">الربيع بن أنس</span> -من طريق أبي جعفر الرازي- في قوله: <span class="qpc-hafs">﴿والشمس والقمر حسبانا﴾</span>، قال: الشمس والقمر في حساب، فإذا خلَت أيامُها فذلك آخر الدهر، وأولُ الفزَع الأكبر{17}<span class=comment-ref>٢٣٥٢</span>. (٦/١٤٥)</p></p><p></div></p><p><div><span class=comment-ref>٢٣٥٢</span> <span class="comment-type-3">رجَّح</span> <u>ابنُ جرير</u> (٩/٤٣٠) <span class="mustanad">مستندًا إلى السياق، ودلالة العقل</span> قولَ ابن عباس، ومجاهد، والسدي، والضحاك، والربيع، وقتادة من طريق معمر، أنّ معنى: <span class="qpc-hafs">﴿والشَّمْسَ والقَمَرَ حُسْبانًا﴾</span>: وجعل الشمس والقمر يجريان في أفلاكهما بحساب. وبيَّن علَّة ذلك، فقال: «لأنّ الله -تعالى ذِكْرُه- ذَكَرَ قَبْلَه أياديه عند خلقه، وعظم سلطانه بِفَلْقِه الإصباح لهم، وإخراج النبات والغِراس من الحبِّ والنَّوى، وعقَّب ذلك بذكره خلق النجوم لهدايتهم في البر والبحر، فكان وصفُه إجراءه الشمس والقمر لمنافعهم أشْبَه بهذا الموضع من ذِكْر إضاءتهما؛ لأنّه قد وصف ذلك قبلُ بقوله: <span class="qpc-hafs">﴿فالِقُ الإصْباحِ﴾</span>، فلا معنى لتكريره مرةً أخرى في آيةٍ واحدةٍ لغير معنى».</p><p>ثم <span class="comment-type-1">وجَّه</span> قول قتادة، فقال: «وأَحْسَبُ أنّ قتادة في تأويل ذلك بمعنى: الضياء؛ ذهب إلى شيءٍ يُروى عن ابن عباس في قوله: <span class="qpc-hafs">﴿ويُرْسِلَ عَلَيْها حُسْبانًا مِنَ السَّماءِ﴾</span> [الكهف:٤٠]، قال: نارًا. فوجَّه تأويل قوله: <span class="qpc-hafs">﴿والشَّمْسَ والقَمَرَ حُسْبانًا﴾</span> إلى ذلك التأويل». <span class="comment-type-2">وانتقده</span> قائلًا: «وليس هذا من ذلك المعنى في شيءٍ».</div></p><p><div></p><p><p><span class="item-no">٢٥٦٥٣<span class="dash">-</span></span> قال <span class="name-3">محمد بن السائب الكلبي</span>: يعني: حساب منازل الشمس والقمر، كل يوم بمنزل{18}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٥٦٥٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿و﴾</span> جعل <span class="qpc-hafs">﴿الشمس والقمر حسبانا﴾</span> يقول: جعلهما في مسيرهما كالحسبان في الفلك. يقول: <span class="qpc-hafs">﴿لتعلموا عدد السنين والحساب﴾</span> [يونس:٥]، وذلك أنّ الله قدَّر لهما منازلهما في السماء الدنيا، فذلك قوله: <span class="qpc-hafs">﴿ذلك تقدير العزيز﴾</span> في مُلكه يصنع ما أراد، <span class="qpc-hafs">﴿العليم﴾</span> بما قدَّر من خلقه. نظيرُها في يونس{19}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَٱلشَّمۡسَ وَٱلۡقَمَرَ حُسۡبَانࣰاۚ ذَ ٰ⁠لِكَ تَقۡدِیرُ ٱلۡعَزِیزِ ٱلۡعَلِیمِ ۝٩٦﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٢٥٦٥٥<span class="dash">-</span></span> عن مسلم بن يسار، قال: كان من دعاء النبي ﷺ: «<b>اللَّهُمَّ، فالقَ الإصباح، وجاعلَ الليل سكنًا، والشمس والقمر حسبانًا، اقْضِ عنِّي الدَّين، وأَغْنِني من الفقر، وأَمْتِعني بسمعي وبصري وقُوَّتي في سبيلك</b>»{20}. (٦/١٤٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٥٦٥٦<span class="dash">-</span></span> عن <span class="name-1">سلمان الفارسي</span> -من طريق وهب- قال: الليل موكَّل به مَلَك يقال له: شراهيل، فإذا حان وقتُ الليل أخذ خَرَزةً سوداءَ فدلّاها مِن قِبَل المغرب، فإذا نظَرَتْ إليها الشمسُ وجبَت في أسرعَ من طرْفة العين، وقد أُمِرَت الشمسُ ألا تغرُبَ حتى تَرى الخَرَزة، فإذا غرَبت جاء الليل، فلا تزالُ الخَرَزَةُ مُعَلَّقةً حتى يجيء مَلَكٌ آخر -يُقال له: هراهيل- بخَرَزَة بيضاء، فيُعَلِّقُها مِن قِبَل المطلِع، فإذا رآها شراهيل مدَّ إليه خرزتَه، وترى الشمسُ الخرزةَ البيضاء فتطلُعُ، وقد أُمِرت ألا تطلُعَ حتى تراها، فإذا طلَعت جاء النهار{21}. (٦/١٤٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٥٦٥٧<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عكرمة- قال: خلَق الله بحرًا دونَ السماء بمقدار ثلاث فراسخ، فهو موجٌ مكفوف، قائمٌ في الهواء بأمر الله، لا يقطُرُ منه قطرة، جارٍ في سرعة السهم، تجرِي فيه الشمس والقمر والنجوم، فذلك قوله: <span class="qpc-hafs">﴿كل في فلك يسبحون﴾</span> [الأنبياء:٣٣]. والفَلَك: دَوَران العجلة في لُجَّة غَمْرِ ذلك البحر، فإذا أحبَّ الله أن يُحدِثَ الكسوف خرَّت الشمس عن العجلة فتقعُ في غَمْرِ ذلك البحر، فإذا أراد أن يُعظِمَ الآية وقَعت كلُّها فلا يَبقى على العجلة منها شيء، وإذا أراد دونَ ذلك وقَع النصفُ منها أو الثُّلثُ أو الثُّلثان في الماء، ويبقى سائر ذلك على العجلة، وصارت الملائكة الموكَّلون بها فِرقتين؛ فرقة يُقبِلون على الشمس فيجرُّونها نحوَ العجلة، وفرقة يُقبِلون إلى العجلة فيجرُّونها إلى الشمس، فإذا غَرَبت رُفِع بها إلى السماء السابعة في سرعة طيران الملائكة، وتُحبَسُ تحتَ العرش، فتستأذنُ مِن أين تؤمرُ بالطلوع، ثم يُنطلَقُ بها ما بينَ السماء السابعة وبينَ أسفل درجات الجنان في سرعة طيران الملائكة، فتنحدِرُ حِيالَ المشرق من سماء إلى سماء، فإذا وصَلَت إلى هذه السماء فذلك حينَ ينفجرُ الصبح، فإذا وصَلت إلى هذا الوجه من السماء فذلك حينَ تطلُعُ الشمس. قال: وخلَق الله عندَ المشرق حجابًا من الظُّلمة، فوضَعها على البحر السابع، مقدارَ عدَّة الليالي في الدنيا منذُ خلَقها الله إلى يوم القيامة، فإذا كان عندَ غروب الشمس أقبَل مَلَك قد وُكِّل بالليل، فقبَض قبضةً من ظُلمة ذلك الحجاب، ثم يستقبلُ المغرب، فلا يزالُ يُرْسِلُ تلك الظُّلمةَ من خَللِ أصابعه قليلًا قليلًا، وهو يراعي الشَّفَقَ، فإذا غاب الشَّفَقُ أرسَل الظُّلْمة كلَّها، ثم ينشُرُ جناحيه فيبلُغان قُطرَيِ الأرض، وكَنفَيِ السماء، فتُشرقُ ظُلمةُ الليل بجناحيه، فإذا حان الصبحُ ضمَّ جناحَيه، ثم يضمُّ الظلمة كلَّها بعضَها إلى بعض بكفَّيه من المشرق، ويضعُها على البحر السابع بالمغرب{22}. (٦/١٤٦)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ٩/٤٢٦، وابن أبي حاتم ٤/١٣٥٤.أخرجه ابن جرير ٩/٤٢٥، وابن أبي حاتم ٤/١٣٥٣. وعزاه السيوطي إلى ابن المنذر.تفسير مجاهد ص٣٢٥، وأخرجه ابن جرير ٩/٤٢٥، وابن أبي حاتم ٤/١٣٥٤. وعزاه السيوطي إلى ابن أبي شيبة، وعبد بن حميد، وابن المنذر، وأبي الشيخ.أخرجه ابن جرير ٩/٤٢٦، وابن أبي حاتم ٤/١٣٥٤. وعزاه السيوطي إلى أبي الشيخ.أخرجه ابن جرير ٩/٤٢٥.أخرجه عبد الرزاق ١/٢١٤، وابن جرير ٩/٤٢٥. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.تفسير مقاتل بن سليمان ١/٥٨٠.أخرجه ابن جرير ٩/٤٢٦. وعلَّقه ابن أبي حاتم ٤/١٣٥٣.أخرجه ابن أبي حاتم ٤/١٣٥٤.</p><p>والقراءة لجمهور القراء، ما عدا عاصمًا، وحمزة، والكسائي، وخلف الذين يقرءون: <span class="qpc-hafs">﴿وجَعَل﴾</span>. ينظر: النشر ٢/١٩٦.تفسير مقاتل بن سليمان ١/٥٨٠.أخرجه ابن جرير ٩/٤٢٨، وابن أبي حاتم ٤/١٣٥٤. وعزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ٩/٤٢٨.أخرجه ابن جرير ٩/٤٢٩.أخرجه عبد الرزاق ١/٢١٤، وابن جرير ٩/٤٢٩، وابن أبي حاتم ٤/١٣٥٤. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه ابن جرير ٩/٤٣٠، وابن أبي حاتم ٤/١٣٥٥. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه ابن جرير ٩/٤٢٩.أخرجه ابن جرير ٩/٤٢٩. وعزاه السيوطي إلى أبي الشيخ.ذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٢/٨٧-.تفسير مقاتل بن سليمان ١/٥٨٠. يشير إلى قوله تعالى: <span class="qpc-hafs">﴿هُوَ الَّذِي جَعَلَ الشَّمْسَ ضِياءً والقَمَرَ نُورًا وقَدَّرَهُ مَنازِلَ لِتَعْلَمُوا عَدَدَ السِّنِينَ والحِسابَ﴾</span> الآية [يونس:٥].أخرجه ابن أبي شيبة ٦/٢٤ (٢٩١٩٣)، والدوري في جزء فيه قراءات النبي ص٩٤ (٤٣).</p><p>قال الزرقاني في شرح الموطأ ٢/٤٣ (٤٩٦): «وهو مرسل».أخرجه أبو الشيخ في العظمة (٩١١).أخرجه أبو الشيخ في العظمة (٦٤٧).</p><p><b>وأورد السيوطي ٦/١٤٦-١٤٨ عقب الآية عدة آثار في فضل مراعاة الشمس والقمر لذكر الله.</b>
  6,97,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَهُوَ ٱلَّذِی جَعَلَ لَكُمُ ٱلنُّجُومَ لِتَهۡتَدُوا۟ بِهَا فِی ظُلُمَـٰتِ ٱلۡبَرِّ وَٱلۡبَحۡرِۗ قَدۡ فَصَّلۡنَا ٱلۡـَٔایَـٰتِ لِقَوۡمࣲ یَعۡلَمُونَ ۝٩٧﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٢٥٦٥٨<span class="dash">-</span></span> عن ابن عمر، قال: قال رسول الله ﷺ: «<b>تعلَّموا من النجوم ما تَهتدون به في ظلمات البرِّ والبحر، ثم انتهُوا</b>»{1}. (٦/١٥٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٥٦٥٩<span class="dash">-</span></span> عن <span class="name-1">عمر بن الخطاب</span> -من طريق أبي نضرة- قال: تعلَّموا من النجوم ما تهتدون به في بَرِّكم وبحركم، ثم أمسِكوا، فإنّها -واللهِ- ما خُلِقت إلا زينةً للسماء، ورُجومًا للشياطين، وعلامات يُهتدى بها، وتعلَّموا من النِّسبة ما تَصلِون به أرحامكم، وتعلَّموا ما يحِلُّ لكم من النساء، ويَحرُمُ عليكم، ثم أمْسِكوا{2}. (٦/١٤٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٥٦٦٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطية العوفي- في قوله: <span class="qpc-hafs">﴿وهو الذي جعل لكم النجوم لتهتدوا بها في ظلمات البر والبحر﴾</span>، قال: يَضِلُّ الرجلُ وهو في الظُّلمة والجور عن الطريق{3}. (٦/١٤٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٥٦٦١<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- قال: إنّ الله إنّما جعل هذه النجوم لثلاث خصال: جعلها زينةً للسماء، وجعلها يُهتدى بها، وجعَلها رجومًا للشياطين، فمَن تعاطى فيها غيرَ ذلك فقد قال رأيَه، وأخطَأ حظَّه، وأضاع نصيبه، وتكلَّف ما لا علمَ له به، وإنّ ناسًا جهلةً بأمر الله قد أحدَثوا في هذه النجوم كهانة؛ مَن أعرَس بنجم كذا وكذا كان كذا وكذا، ومن سافر بنجم كذا وكذا كان كذا وكذا، ولَعَمري ما من نجم إلا يولَدُ به الأحمر والأسود، والطويل والقصير، والحسن والذَّميم، ولو أنّ أحدًا علِم الغيب لَعلِمه آدم الذي خلقه الله بيده، وأسجَد له ملائكتَه، وعلَّمه أسماء كلِّ شيء{4}. (٦/١٤٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٥٦٦٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وهو الذي جعل لكم النجوم﴾</span> نورًا لتهتدوا بها؛ بالكواكب ليلًا. يقول: لتعرفوا الطريق إذا سرتم في ظلمات البر والبحر، <span class="qpc-hafs">﴿قد فصلنا الآيات لقوم يعلمون﴾</span> بأنّ الله واحد لا شريك له{5}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَهُوَ ٱلَّذِی جَعَلَ لَكُمُ ٱلنُّجُومَ لِتَهۡتَدُوا۟ بِهَا فِی ظُلُمَـٰتِ ٱلۡبَرِّ وَٱلۡبَحۡرِۗ قَدۡ فَصَّلۡنَا ٱلۡـَٔایَـٰتِ لِقَوۡمࣲ یَعۡلَمُونَ ۝٩٧﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٢٥٦٦٣<span class="dash">-</span></span> عن العباس بن عبد المطلب -من طريق الحسن- قال: قال رسول الله ﷺ: «<b>لقد طهَّر اللهُ هذه الجزيرة مِن الشِّرك، ما لم تُضِلَّهمُ النجوم</b>»{6}. (٦/١٥٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٥٦٦٤<span class="dash">-</span></span> عن عمر بن الخطاب، قال: سمعتُ رسول الله ﷺ يقول: «<b>لا تسألوا عن النجوم، ولا تَعْبُرُوا</b>{7} <b>القرآن برأيكم، ولا تسبُّوا أحدًا من أصحابي، فإنّ ذلك الإيمان المحض</b>»{8}. (٦/١٥١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٥٦٦٥<span class="dash">-</span></span> عن ابن مسعود، قال: قال رسول الله ﷺ: «<b>إذا ذُكِر أصحابي فأَمْسِكوا، وإذا ذُكِر القَدَر فأَمْسِكوا، وإذا ذُكر النجوم فأَمْسِكوا</b>»{9}. (٦/١٥٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٥٦٦٦<span class="dash">-</span></span> عن علي، قال: نهاني رسول الله ﷺ عن النظر في النجوم، وأمَرني بإسباغ الطُّهور{10}. (٦/١٥١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٥٦٦٧<span class="dash">-</span></span> عن أبي هريرة، قال: نهى رسول الله ﷺ عن النظر في النجوم{11}. (٦/١٥٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٥٦٦٨<span class="dash">-</span></span> عن عائشة، قالت: نهى رسول الله ﷺ عن النظر في النجوم{12}. (٦/١٥٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٥٦٦٩<span class="dash">-</span></span> عن سَمُرَة بن جُندُب أنّه خطَب، فذكَرَ حديثًا عن رسول الله ﷺ أنّه قال: «<b>أما بعد، فإنّ ناسًا يزعُمون أنّ كسوف هذه الشمس، وكسوفَ هذا القمر، وزوالَ هذه النجوم عن مواضعِها؛ لموت رجال عظماء من أهل الأرض، وإنّهم قد كذَبوا، ولكنها آياتٌ من آيات الله، يَعْتَبِرُ</b>{13} <b>بها عبادَه؛ لينظرَ مَن يُحدِثُ له منهم توبة</b>»{14}. (٦/١٥١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٥٦٧٠<span class="dash">-</span></span> عن ابن عباس، قال: قال النبي ﷺ: «<b>مَن اقتَبَس عِلْمًا من النجوم اقتَبس شُعبةً من السِّحر، زاد ما زاد</b>»{15}. (٦/١٥٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٥٦٧١<span class="dash">-</span></span> عن ابن عباس، قال: قال رسول الله ﷺ: «<b>رُبَّ مُتعلِّمِ حروفَ أبي جاد وراء في النجوم ليس له عندَ الله خَلاقٌ يوم القيامة</b>»{16}. (٦/١٥٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٥٦٧٢<span class="dash">-</span></span> عن أنس، قال: قال رسول الله ﷺ: «<b>أخافُ على أُمَّتي خَصلتين: تكذيبًا بالقدر، وتصديقًا بالنجوم</b>». وفي لفظ: «<b>وحِذْقًا بالنجوم</b>»{17}. (٦/١٥٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٥٦٧٣<span class="dash">-</span></span> عن ميمون بن مهران، قال: قلتُ ل<span class="name-1">عبد الله بن عباس</span>: أوصِني. قال: أوصيك بتقوى الله، وإيّاك وعلمَ النجوم؛ فإنّه يدعو إلى الكهانة، وإيّاك أن تذكُرَ أحدًا من أصحاب رسول الله ﷺ إلا بخير فيَكبَّك الله على وجهك في جهنم؛ فإنّ الله أظهَر بهم هذا الدين، وإيّاك والكلامَ في القدر؛ فإنّه ما تكلَّم فيه اثنان إلا أثِما، أو أثِم أحدُهما{18}. (٦/١٥٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٥٦٧٤<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق طاووس- قال: إنّ قومًا ينظرون في النجوم، ويحسُبون أبا جاد، وما أرى للذين يفعَلون ذلك من خَلاق{19}. (٦/١٥٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٥٦٧٥<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق الحسن بن صالح- قال: ذلك عِلْمٌ ضيَّعه الناس؛ النجوم{20}. (٦/١٥٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٥٦٧٦<span class="dash">-</span></span> عن عكرمة: أنّه سأَل رجلًا عن حساب النجوم، وجعَل الرجلُ يتحرَّجُ أن يُخبرَه، فقال عكرمة: سمعتُ <span class="name-1">عبد الله بن عباس</span> يقول: علمٌ عجَز الناسُ عنه، ودِدتُ أنِّي علِمتُه {21}. (٦/١٥٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٥٦٧٧<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span>، قال: لا بأسَ أن يتعلَّمَ الرجلُ من النجوم ما يَهتدي به في البرِّ والبحر، ويتعلَّم منازل القمر{22}. (٦/١٥٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٥٦٧٨<span class="dash">-</span></span> عن <span class="name-2">محمد بن كعب القرظي</span> -من طريق عمر مولى غفرة- قال: واللهِ، ما لِأَحد من أهل الأرض في السماء من نجم، ولكن يتَّبعون الكهنة، ويتَّخذون النجوم عِلَّة{23}. (٦/١٥١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٥٦٧٩<span class="dash">-</span></span> عن <span class="name-2">عبد الله بن حفص</span>، قال: خُصَّت العرب بخصال: بالكهانة، والقِيافة، والعيافة، والنجوم، والحساب، فهدَم الإسلامُ الكهانة، وثـبَّت الباقي بعد ذلك{24}. (٦/١٥١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٥٦٨٠<span class="dash">-</span></span> عن <span class="name-2">حميد الشامي</span>، قال: النجوم هي علمُ آدم ﵇{25}. (٦/١٥٠)</p></p><p></div></p></div>",footnotes:1:ذكره الخطيب في القول في علم النجوم ص١٣١-١٣٢. وأورده الديلمي في الفردوس ٢/٤٣ (٢٢٤٨).</p><p>قال الدارقطني في العلل الواردة في الأحاديث النبوية ١٣/١٠٧ (٢٩٩٠): «وإنما يحفظ من قول عمر موقوفًا». وقال الألباني في الضعيفة ٧/٤١٧ (٣٤٠٨): «ضعيف».أخرجه ابن أبي شيبة ٨/٤١٤ مختصرًا، والخطيب في كتاب النجوم ص٣٢٣. وعزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ٩/٤٣٢، وابن أبي حاتم ٤/١٣٥٥.أخرجه عبد الرزاق ١/٣٥٤ مختصرًا، وعبد بن حميد -كما في التغليق ٣/٤٨٩- من طريق شيبان، وابن جرير ٢٣/١٢٣، وابن أبي حاتم ٩/٢٩١٣، وأبو الشيخ في العظمة (٧٠٦)، والخطيب في كتاب النجوم ص١٨٥. وعزاه السيوطي إلى ابن المنذر.تفسير مقاتل بن سليمان ١/٥٨٠.أخرجه أبو يعلى في مسنده ١٢/٧٧ (٦٧١٤)، وابن عبد البر في جامع بيان العلم ٢/٧٩٣ (١٤٧٩).</p><p>قال ابن خزيمة كما في إتحاف المهرة لابن حجر ٦/ ٤٧٧: «الحسن لم يسمع من العباس». وقال البوصيري في إتحاف الخيرة ٣/٢٥٢ (٢٦٨٠): «رواه أبو يعلى بسندٍ فيه انقطاع». وقال الألباني في الضعيفة ٩/٣٠٥ (٤٣١٦): «ضعيف».أي لا تفسروه برأيكم. ينظر النهاية (عبر).ذكره الخطيب في القول في علم النجوم ص١٧٥ واللفظ له. وأورده الديلمي في الفردوس ٥/٦٤ (٧٤٧٠).أخرجه الطبراني في الكبير ١٠/١٩٨ (١٠٤٤٨)، وأبو نعيم في الحلية ٤/١٠٨، من طريق سعيد بن سليمان، عن مسهر بن عبد الملك بن سلع الهمداني، عن الأعمش، عن أبي وائل، عن عبد الله به.</p><p>قال العراقي في تخريج أحاديث الإحياء ص٣٩ (٢): «إسناد حسن». وقال الهيثمي المجمع ٧/٢٠٢ (١١٨٥١): «وفيه مسهر بن عبد الملك، وثَّقه ابن حبان وغيره، وفيه خلاف، وبقية رجاله رجال الصحيح». وقال الألباني في الصحيحة ١/٧٥- ٨٠ (٣٤): «... له شواهد وطرق، ... فيقوى الحديث به».أخرجه الخطيب في المتفق والمفترق ٢/٩١١، والموضح ٢/٧٧، من طريق الربيع بن حبيب، عن نوفل بن عبد الملك، عن أبيه، عن علي به.</p><p>قال ابن عدي في الكامل ٤/٤٣ بعد ذكره لجملة من مرويات الربيع بن حبيب: «هذه الأحاديث مع غيرها يرويها عن الربيع بن حبيب عبيد الله بن موسى، وليست بالمحفوظة». وقال ابن القيسراني في ذخيرة الحفاظ ٥/٢٥٣٣ (٥٨٨٨): «رواه الربيع بن حبيب، عن نوفل بن عبد الملك، عن أبيه، عن علي، والربيع -وهو أخو عائذ- ثقة».أخرجه الطبراني في الأوسط ٨/١٣١ (٨١٨٢)، والبيهقي في الشعب ٧/١٦٩ (٤٨٣٣)، من طريق عقبة الأصم، عن عطاء، عن أبي هريرة به.</p><p>قال الطبراني: «لم يروِ هذا الحديثَ عن عطاء إلا عقبة الأصم». وقال العقيلي في الضعفاء الكبير ٣/٣٥٣ (١٣٨٦) بعد أن ذكره بسنده من طريق عقبه الأصم: «ولا يعرف إلا به، ولا يتابعه إلا مَن هو دونه أو مثله». وقال ابن عدي في الكامل ٦/٤٨٩: «وهذا لا يعرف إلا بعقبة عن عطاء». وقال القيسراني في تذكرة الحفاظ ١/٣٦٥- ٣٦٦ (٩٣٣): «رواه عقبة بن عبد الله الأصم البصري، عن عطاء، عن أبي هريرة، وعقبة هذا يروي المناكير عن الثقات». وقال في ذخيرة الحفاظ ٥/٢٥٣٢ (٥٨٨٣): «رواه عقبة بن عبد الله الأصم، عن عطاء بن أبي رباح، عن أبي هريرة، وعقبة ضعيف». وقال الهيثمي في المجمع ٥/١١٦- ١١٧ (٨٤٧٧): «فيه عقبة بن عبد الله الأصم، وهو ضعيف، وذكر عن أحمد أنّه وثقه، وأنكر أبو حاتم عليه هذا الحديث». وقال البوصيري في إتحاف الخيرة ١/٢٤٩-٢٥٠ (٣٧٨): «له شاهد من حديث أنس ...».ذكره الخطيب في القول في علم النجوم ص١٧٧.اعتبر الشيء: اختبره وامتحنه. الوسيط (ع ب ر).أخرجه أحمد ٣٣/٣٤٦-٣٤٩ (٢٠١٧٨) واللفظ له، وابن خزيمة ٢/٥٢٣-٥٢٤ (١٣٩٧)، وابن حبان ٧/١٠١-١٠٣ (٢٨٥٦)، والحاكم ١/٤٧٨ (١٢٣٠)، من طريق الأسود بن قيس، عن ثعلبة بن عباد العبدي، عن سمرة بن جندب به.</p><p>قال الحاكم: «حديث صحيح، على شرط الشيخين، ولم يخرجاه». وقال الهيثمي في المجمع ٧/٣٤٢ (١٢٥١٩): «ورجال أحمد رجال الصحيح، غير ثعلبة بن عبادة، وثَّقه ابن حبان». وقال الألباني في ضعيف أبي داود ٢/٢٣ (٢١٦): «إسناده ضعيف».أخرجه ابن ماجه ٤/٦٧٠ (٣٧٢٦)، وأبو داود ٦/٥٠-٥١ (٣٩٠٥)، وأحمد ٣/٤٥٤ (٢٠٠٠)، ٥/٤١ (٢٨٤٠)، من طريق يحيى بن سعيد، عن عبيد الله بن الأخنس، عن الوليد بن عبد الله، عن يوسف بن ماهك، عن ابن عباس به.</p><p>قال النووي في رياض الصالحين ص٣٦٩ (١٦٧١): «... إسناده صحيح». وقال شيخ الإسلام في الفتاوى ٣٥/١٩٣: «... إسناد صحيح». وقال الذهبي في المهذب: «حديث صحيح». وقال في الكبائر ص٣٢٨: «سند صحيح». وقال العراقي في تخريج أحاديث الإحياء ص١٤٦٠: «... سند صحيح». وقال المناوي في فيض القدير ٦/٨٠ (٨٥٠٠)، وفي التيسير بشرح الجامع الصغير ٢/٤٠٣: «إسناد صحيح». وقال الرباعي في فتح الغفار ٣/١٧١٦ (٥٠٦١): «... رجال إسناده ثقات». وقال الألباني في الصحيحة ٢/٤٢٠ (٧٩٣): «إسناد جيد، رجاله كلهم ثقات».أخرجه ابن الأعرابي في معجمه ٢/٨٣٩ (١٦٨٤)، والطبراني في الكبير ١١/ ٤١ (١٠٩٨٠)، من طريق خالد بن يزيد العمري، عن محمد بن مسلم، عن إبراهيم بن ميسرة، عن طاووس، عن ابن عباس به.</p><p>قال الهيثمي في المجمع ٥/١١٧ (٨٤٧٨): «فيه خالد بن يزيد العمري، وهو كذاب». وقال المناوي في التيسير بشرح الجامع الصغير ٢/٢٩: «إسناد فيه كذاب». وقال الألباني في الضعيفة ١/٦٠٩ (٤١٧): «موضوع».أخرجه أبو يعلى في مسنده ٧/١٦٢ (٤١٣٥)، والخطيب في القول في علم النجوم ص١٦٢ واللفظ له، والبيهقي في القضاء والقدر (٢٨٥)، من طريق شهاب بن خراش، عن يزيد الرقاشي، عن أنس بن مالك به.</p><p>قال ابن القيسراني في ذخيرة الحفاظ ١/٢٥١ (١٣٥): «رواه شهاب بن خراش، عن يزيد الرقاشي، عن أنس، وشهاب هذا في روايته إنكار، وليس للمتقدمين فيه كلام». وقال الهيثمي في المجمع ٧/٢٠٣ (١١٨٦١): «وفيه يزيد الرقاشي، وهو ضعيف، ووثَّقه ابن عدي».أخرجه الخطيب في كتاب النجوم ص١٩٠.أخرجه عبد الرزاق في المصنف (١٩٨٠٥)، وابن أبي شيبة ٨/٤١٤، والخطيب ص١٨٩.عزاه السيوطي إلى المُرهِبيُّ.أخرجه الخطيب في كتاب النجوم ص١٨٨-١٨٩. وقال:. قال الخطيب: مرادُه الضربُ المباح الذي كانت العرب تختصُّ به.ذكره الخطيب في كتاب النجوم ص١٣٣.أخرجه أبو الشيخ في العظمة (٧١٠). وعزاه السيوطي إلى ابن أبي حاتم.أخرجه الزبير بن بكار في الموفقيات ص٣٦٢-٣٦٣.عزاه السيوطي إلى ابن أبي حاتم، والمُرهِبيُّ في فضل العلم.
  6,98,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَهُوَ ٱلَّذِیۤ أَنشَأَكُم مِّن نَّفۡسࣲ وَ ٰ⁠حِدَةࣲ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٢٥٦٨١<span class="dash">-</span></span> عن أبي أُمامة، عن رسول الله ﷺ، قال: «نَصَب آدمَ بينَ يديه، ثم ضرَب كَتِفَه اليسرى، فخرَجت ذُرِّيتُه من صُلْبِه حتى ملئوا الأرض»{1}. (٦/١٥٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٥٦٨٢<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دِعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿وهو الذي أنشأكم من نفس واحدة﴾</span>، قال: من آدم ﵇{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٥٦٨٣<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- قوله: <span class="qpc-hafs">﴿وهو الذي أنشأكم من نفس واحدة﴾</span>، قال: آدم ﵇{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٥٦٨٤<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٥٦٨٥<span class="dash">-</span></span> و<span class="name-2">أبي مالك غزوان الغفاري</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٥٦٨٦<span class="dash">-</span></span> و<span class="name-3">مقاتل بن حيان</span>، مثل ذلك{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٥٦٨٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثم أخبر عن صنعه، فقال: <span class="qpc-hafs">﴿وهو الذي أنشأكم من نفس واحدة﴾</span>، يعني: خلقكم من نفس واحدة، يعني: آدم وحده{5}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿فَمُسۡتَقَرࣱّ وَمُسۡتَوۡدَعࣱۗ﴾</span> - قراءات</h3></p><p><div></p><p><p><span class="item-no">٢٥٦٨٨<span class="dash">-</span></span> عن <span class="name-2">عاصم ابن أبي النجود</span>: <span class="qpc-hafs">﴿فَمُسْتَقَرٌّ﴾</span> بنصب القاف{6}. (٦/١٥٧)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿فَمُسۡتَقَرࣱّ وَمُسۡتَوۡدَعࣱۗ﴾</span> - تفسير الآية</h3></p><p><div></p><p><p><span class="item-no">٢٥٦٨٩<span class="dash">-</span></span> عن <span class="name-1">أُبَيّ بن كعب</span>: مستقر في أصلاب الآباء، ومستودع في أرحام الأمهات{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٥٦٩٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن مسعود</span> -من طريق ابن عيينة، عن إسماعيل بن أبي خالد، عن إبراهيم- في قوله: <span class="qpc-hafs">﴿فمستقر ومستودع﴾</span>، قال: مستقرُّها في الدنيا، ومستودَعُها في الآخرة{8}. (٦/١٥٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٥٦٩١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن مسعود</span> -من طريق ابن عيينة، عن إسماعيل بن أبي خالد، عن إبراهيم- في قوله: <span class="qpc-hafs">﴿فمستقر ومستودع﴾</span>، قال: مستودعها في الدنيا، ومستقرها في الرَّحِم{9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٥٦٩٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن مسعود</span> -من طريق السدي، عن مُرَّة- قال: المستقَرُّ: الرَّحِم. والمستودَعُ: المكان الذي تموتُ فيه{10}. (٦/١٥٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٥٦٩٣<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن مسعود</span> -من طريق قيس بن أبي حازم- قال: إذا كان أجلُ الرجل بأرض أُتِيحَتْ له إليها الحاجة، فإذا بلَغ أقصى أثَرِه قُبِض، فتقول الأرض يوم القيامة: هذا ما استودَعْتَني{11}. (٦/١٥٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٥٦٩٤<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق سعيد بن جبير-: المستقر: الأرض. والمستودع: عند الرحمن{12}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٥٦٩٥<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق قتادة- <span class="qpc-hafs">﴿فمستقر ومستودع﴾</span>، قال: مستقر في الرحم، ومستودع في الصلب{13}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٥٦٩٦<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق العوفي- <span class="qpc-hafs">﴿فَمُسْتَقَرٌّ ومُسْتَوْدَعٌ﴾</span>، قال: المستقر في الأرحام، والمستودع في الصلب، لم يُخْلَق، وهو خالِقه{14}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٥٦٩٧<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق مقسم- قال: <span class="qpc-hafs">﴿مستقرها﴾</span> حيث تأوي، <span class="qpc-hafs">﴿ومستودعها﴾</span> [هود:٦] حيث تموت{15}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٥٦٩٨<span class="dash">-</span></span> عن سعيد بن جبير، قال: قال لي <span class="name-1">عبد الله بن عباس</span>: أتزوَّجتَ؟ قلتُ: لا، وما ذاك في نفسِي اليوم. قال: إن كان في صُلبِك وديعةٌ فسَتخرُجُ{16}. (٦/١٥٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٥٦٩٩<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي بن أبي طلحة وغيره- في قوله: <span class="qpc-hafs">﴿فمستقر ومستودع﴾</span>، قال: المستقَرُّ: ما كان في الرَّحِم. والمُسْتَوْدَعُ: ما استُودِع في أصلاب الرجال والدواب. وفي لفظ: المستقَرُّ: ما في الرَّحم، وعلى ظهر الأرض، وبطنِها مما هو حيٌّ، ومِمّا قد مات. وفي لفظ: المستقَرُّ: ما كان في الأرض. والمستودَعُ: ما كان في الصُّلْب{17}. (٦/١٥٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٥٧٠٠<span class="dash">-</span></span> عن <span class="name-2">أبي عبد الرحمن السلمي</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٥٧٠١<span class="dash">-</span></span> و<span class="name-2">قيس بن أبي حازم</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٥٧٠٢<span class="dash">-</span></span> و<span class="name-2">عطاء الخراساني</span>، نحو اللفظ الأول{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٥٧٠٣<span class="dash">-</span></span> عن كريب، قال: دعاني ابنُ عباس فقال: اكتب: بسم الله الرحمن الرحيم، من عبد الله بن عباس إلى فلان حبر تيماء، سلامٌ عليك، فإني أحمد إليك الله الذي لا إله إلا هو، أمّا بعد. قال: فقلت: تبدؤه تقول: السلام عليك؟! فقال: إنّ الله هو السلام. ثم قال: اكتب: سلامٌ عليك، أمّا بعد، فحدِّثني عن مستقر ومستودع. قال: ثم بعثني بالكتاب إلى اليهودي، فأعطيته إياه، فلما نظر إليه قال: مرحبًا بكتاب خليلي من المسلمين، فذهب بي إلى بيته، ففتح أسْفاطًا{19} له كبيرة، فجعل يطرح تلك الأشياء لا يلتفت إليها، قال: قلت: ما شأنُك؟ قال: هذه أشياء كتبها اليهود. حتى أخرج سِفْر موسى ﵇، قال: فنظر إليه مرتين، فقال: المستقر: الرحم. قال: ثم قرأ: <span class="qpc-hafs">﴿ونقر في الأرحام ما نشاء﴾</span> [الحج:٥]، وقرأ: <span class="qpc-hafs">﴿ولكم في الأرض مستقر ومتاع﴾</span> [البقرة:٣٦]. قال: مستقره فوق الأرض، ومستقره في الرحم، ومستقره تحت الأرض، حتى يصير إلى الجنة أو إلى النار{14}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٥٧٠٤<span class="dash">-</span></span> عن <span class="name-2">محمد ابن الحنفية</span>: مستقر في صلب الأب، ومستودع في رحم الأم{21}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٥٧٠٥<span class="dash">-</span></span> عن <span class="name-2">أبي العالية الرياحي</span>: مستقرها أيام حياتها، ومستودعها حيث تموت وحيث يبعث{22}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٥٧٠٦<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span> -من طريق كلثوم بن جبر- في قوله: <span class="qpc-hafs">﴿فمستقر ومستودع﴾</span>، قال: مُسْتَوْدَعون ما كانوا في أصلاب الرجال، فإذا قرُّوا في أرحام النساء، أو على ظهر الأرض، أو في بطنها؛ فقد استقرُّوا{23}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٥٧٠٧<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span> -من طريق أبي بشر- قال: المستودع: في الصلب. والمستقر: في الآخرة، وعلى وجه الأرض{24}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٥٧٠٨<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span> -من طريق عطاء بن السائب-= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٥٧٠٩<span class="dash">-</span></span> و<span class="name-2">إبراهيم النخعي</span> -من طريق أبي حمزة، وابن عون- قالا: مستقر ومستودع؛ المستقرُّ في الرحم، والمستودع في الصُّلْب{25}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٥٧١٠<span class="dash">-</span></span> قال <span class="name-2">مقسم</span> -من طريق ليث-: <span class="qpc-hafs">﴿مستقرها﴾</span> في الصلب حيث تأوي إليه، <span class="qpc-hafs">﴿ومستودعها﴾</span> [هود:٦] حيث تموت{26}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٥٧١١<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- قال: المستقر: الأرض، والمستودع عند ربك{27}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٥٧١٢<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- قال: <span class="qpc-hafs">﴿فمستقر﴾</span>: ما استقر في أرحام النساء، <span class="qpc-hafs">﴿ومستودع﴾</span>: ما كان في أصلاب الرجال{28}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٥٧١٣<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span>: المستودع: المكان الذي يموت فيه{29}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٥٧١٤<span class="dash">-</span></span> عن <span class="name-2">الضحاك بن مُزاحِم</span> -من طريق عبيد بن سليمان- <span class="qpc-hafs">﴿فمستقر ومستودع﴾</span>: أمّا مستقرٌّ: فما استقر في الرحم، وأمّا مُستودَع: فما استودع في الصُّلْب{13}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٥٧١٥<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span> -من طريق يحيى الجابر- <span class="qpc-hafs">﴿فمستقر ومستودع﴾</span>، قال: المستقر: الذي قد استقر في الرَّحِم، والمستودع: الذي قد اسْتُودِع في الصُّلْب{24}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٥٧١٦<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق منصور- في قوله: <span class="qpc-hafs">﴿مستقر﴾</span> قال: المستقر: الذي قد مات فاستقر به عمله، <span class="qpc-hafs">﴿ومستودع﴾</span> قال: إلى أجل{32}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٥٧١٧<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٥٧١٨<span class="dash">-</span></span> و<span class="name-2">قتادة بن دعامة</span>، في قوله: <span class="qpc-hafs">﴿فمستقر ومستودع﴾</span>، قالا: مستقَرٌّ في القبر، ومستودَعٌ في الدنيا، أوشَك أن يلحَقَ بصاحبه{33}. (٦/١٥٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٥٧١٩<span class="dash">-</span></span> عن <span class="name-2">عطاء بن أبي رباح</span> -من طريق ابن جريج- <span class="qpc-hafs">﴿فمستقر ومستودع﴾</span>، قال: المستقر: ما اسْتَقَرَّ في أرحام النساء. والمستودع: ما اسْتُودِع في أصلاب الرجال{34}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٥٧٢٠<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق مَعْمَر- <span class="qpc-hafs">﴿فمستقر ومستودع﴾</span>، قال: مستقر في الرَّحِم، ومُستودَع في الصُّلْب{35}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٥٧٢١<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- قال: المستقر في الرحم، والمستودع في الصلب{36}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٥٧٢٢<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق إسماعيل بن أبي خالد- <span class="qpc-hafs">﴿فمستقر ومستودع﴾</span>، قال: المستقر: ما فُرِغ من خلقه{37}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٥٧٢٣<span class="dash">-</span></span> قال يعقوب الأشعري القُمِّيُّ: سألتُ <span class="name-2">إبراهيم بن محمد ابن الحنفية</span>، فقلتُ: مستقر ومستودع؟ قال: المستقر في أصلاب الرجال، والمستودع في أرحام النساء{32}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٥٧٢٤<span class="dash">-</span></span> عن <span class="name-2">زيد بن علي بن الحسين</span>، نحوه{39}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٥٧٢٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فمستقر﴾</span> في أرحام النساء، <span class="qpc-hafs">﴿ومستودع﴾</span> في أصلاب الرجال مِمّا لم يخلقه، وهو خالِقه{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٥٧٢٦<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿فمستقر ومستودع﴾</span>، قال: مستقر في الأرحام، ومستودع في الأصلاب{41}<span class=comment-ref>٢٣٥٣</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٢٣٥٣</span> أفادت الآثار اختلاف المفسرين في معنى «المستقر والمستودع» على خمسة أقوال: <b>الأول:</b> المستقَرُّ في الرحم، والمستودَع في القبر حتى يبعثه الله لنَشْرِ القيامة. <b>الثاني:</b> المستقَرُّ: ما كان في بطون النساء، وبطون الأرض، أو على ظهورها. والمستودَع: ما كان في أصلاب الآباء. <b>الثالث:</b> المستقَرُّ في الأرض على ظهورها، والمستودَع عند الله. <b>الرابع:</b> المستقَرُّ في الرحم، والمستودَع في الصلب، <b>الخامس:</b> المستقَرُّ في القبر، والمستودَع في الدنيا.</p><p>وقد <span class="comment-type-3">رجَّح</span> <u>ابنُ جرير</u> (٩/٤٤٢) الجمعَ بين كل تلك الأقوال <span class="mustanad">مستندًا إلى عموم اللفظ</span>، فقال: «ولا شكَّ أنّ مِن بني آدم مستقرًّا في الرحم، ومستودَعًا في الصلب، ومنهم مَن هو مستقرٌّ على ظهر الأرض أو بطنها، ومستودَعٌ في أصلاب الرجال، ومنهم مستقرٌّ في القبر، مستودَعٌ على ظهر الأرض، فكلُّ مستقَرٍّ أو مستودَعٍ بمعنًى من هذه المعاني فداخلٌ في عموم قوله: <span class="qpc-hafs">﴿فَمُسْتَقَرٌّ ومُسْتَوْدَعٌ﴾</span>، ومرادٌ به».</p><p>و<span class="comment-type-2">انتقد</span> <u>ابنُ عطية</u> (٣/٤٢٧) الأقوال السابقة، و<span class="comment-type-3">رجَّح</span> <span class="mustanad">مستندًا إلى دلالة العقل، ودلالة الواقع</span> أن «الذي يقتضيه النظر أنّ ابن آدم هو مستودع في ظهر أبيه، وليس بمستقر فيه استقرارًا مطلقًا لأنه ينتقل لا محالة: ينتقل إلى الرحم، ثم ينتقل إلى الدنيا، ثم ينتقل إلى القبر، ثم ينتقل إلى المحشر، ثم ينتقل إلى الجنة أو النار، فيستقرُّ في إحداهما استقرارًا مطلقًا، وليس فيها مستودع لأنّه لا نقلة له بعد».</p><p>غير أنه ذكر <span class="comment-type-1">توجيهًا</span> للأقوال الواردة في معنى «المستقر والمستودع»، فقال: «وهو في كل رتبة متوسطة بين هذين الطرفين مستقرٌّ بالإضافة إلى التي قبلها، ومستودع بالإضافة إلى التي بعدها؛ لأنّ لفظ الوديعة يقتضي فيها نقلة ولا بُدَّ».</p><p>و<span class="comment-type-3">رجَّح</span> <u>ابنُ كثير</u> (٦/١١٨) قولَ من قال: إنّ المستقَر في الأرحام، والمستودَع في الأصلاب. ولم يذكر مستندًا.</div></p><p><h3><span class="qpc-hafs">﴿قَدۡ فَصَّلۡنَا ٱلۡـَٔایَـٰتِ لِقَوۡمࣲ یَفۡقَهُونَ ۝٩٨﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٢٥٧٢٧<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿قد فصلنا الآيات﴾</span> يقول: بيَّنّا الآيات <span class="qpc-hafs">﴿لقوم يفقهون﴾</span>{42}. (٦/١٥٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٥٧٢٨<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿قد فصلنا الآيات﴾</span> يعني: قد بيَّنّا الآيات <span class="qpc-hafs">﴿لقوم يفقهون﴾</span> عن الله ﷿{5}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿قَدۡ فَصَّلۡنَا ٱلۡـَٔایَـٰتِ لِقَوۡمࣲ یَفۡقَهُونَ ۝٩٨﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٢٥٧٢٩<span class="dash">-</span></span> عن عوف، قال: بلَغَني: أنّ رسول الله ﷺ قال: «<b>أُنبِئتُ بكلِّ مستقَرٍّ ومستودَعٍ من هذه الأُمة إلى يوم القيامة، كما عُلِّم آدم الأسماء كلَّها</b>»{44}. (٦/١٥٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٥٧٣٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، قال: مَنِ اشتكى ضِرْسَه فلْيضَعْ يدَه عليه، ولْيقْرَأْ: <span class="qpc-hafs">﴿وهو الذي أنشأكم من نفس واحدة﴾</span> الآية{44}. (٦/١٥٧)</p></p><p></div></p></div>",footnotes:1:عزاه السيوطي إلى ابن مردويه.أخرجه ابن جرير ٩/٤٣٣. وعلَّقه ابن أبي حاتم ٤/١٣٥٥.أخرجه ابن جرير ٩/٤٣٣، وابن أبي حاتم ٤/١٣٥٥.علَّقه ابن أبي حاتم ٤/١٣٥٥.تفسير مقاتل بن سليمان ١/٥٨٠.عزاه السيوطي إلى عبد بن حميد.</p><p>وهي قراءة متواترة عن العشرة ما عدا ابن كثير، وأبا عمرو، وروح، فإنهم قرؤوا: ‹فَمُسْتَقِرٌّ› بكسر القاف. انظر: النشر ٢/٢٦٠، والإتحاف ص٢٧٠.تفسير البغوي ٣/١٧١.أخرجه عبد الرزاق ١/٢١٥، وابن جرير ٩/٤٣٥، وابن أبي حاتم ٤/١٣٥٥، ١٣٥٧، ٦/٢٠٠٢-٢٠٠٣. وعزاه السيوطي إلى أبي الشيخ.أخرجه سعيد بن منصور في سننه (٨٩٥ - تفسير).أخرجه ابن جرير ٩/٤٣٣، وابن أبي حاتم ٤/١٣٥٦-١٣٥٧، ٦/٢٠٠٢ من طريق إبراهيم في تفسير المستقر ومن طريق مرة في تفسير المستودع، كما أخرجه ابن جرير ٩/٤٣٣ بنحوه من طريق أبي معاوية عن إسماعيل بن أبي خالد عن إبراهيم، والطبراني في المعجم الكبير (٩٠١٦) بنحوه من طريق قيس بن الربيع، عن إسماعيل بن أبي خالد، عن إبراهيم. وعزاه السيوطي إلى الفريابي، وسعيد بن منصور، وعبد بن حميد، وأبي الشيخ.أخرجه عبد الرزاق ١/٢١٥، وسعيد بن منصور (٨٩٤ - تفسير). وعزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ٩/٤٣٥.أخرجه ابن جرير ٩/٤٤١.أخرجه ابن جرير ٩/٤٣٨.أخرجه ابن جرير ١٢/٣٢٥، وابن أبي حاتم ٤/١٣٥٦ في شطره الأول.أخرجه عبد الرزاق في مصنفه (١٢٥٨١)، وابن جرير ٩/٤٣٧.أخرجه سعيد بن منصور (٨٩٢-تفسير)، وابن جرير ٩/٤٣٥-٤٣٨، ٤٤١، وابن أبي حاتم ٤/١٣٥٥، ١٣٥٧، ٦/٢٠٠٢، ٢٠٠٣، والحاكم ٢/٣١٦. وعزاه السيوطي إلى ابن أبي شيبة، وعبد بن حميد، وابن المنذر، وأبي الشيخ.علَّقه ابن أبي حاتم ٤/١٣٥٥.السَّفَطُ: الذي يُعَبّى فيه الطِّيب وما أشبهه من أدوات النساء. لسان العرب (سفط).أخرجه ابن جرير ٩/٤٣٨.عزاه ابن حجر في الفتح ٨/٢٨٩ إلى عبد بن حميد.تفسير الثعلبي ٤/١٧٣.أخرجه ابن جرير ٩/٤٣٤، وابن أبي حاتم ٤/١٣٥٦.أخرجه ابن جرير ٩/٤٣٦.أخرجه ابن جرير ٩/٤٤٠، ٤٤٢، وعبد الله بن وهب في الجامع - تفسير القرآن ١/١٤٨ (٣٤٨) عن إبراهيم من طريق ابن عون.أخرجه ابن جرير ٩/٤٣٤.أخرجه ابن جرير ٩/٤٣٥، كما أخرج ابن أبي حاتم ٤/١٣٥٦ شطره الأول من طريق أبي يحيى.تفسير مجاهد ص٣٢٦، وأخرجه ابن جرير ٩/٤٣٩، كذلك ٩/٤٣٨ من طريق ليث بنحوه. وعلَّقه ابن أبي حاتم ٤/١٣٥٥، ١٣٥٧.علَّقه ابن أبي حاتم ٤/١٣٥٧.أخرجه ابن جرير ٩/٤٤١.أخرجه ابن جرير ٩/٤٣٦.أخرجه ابن أبي حاتم ٤/١٣٥٦-١٣٥٧.عزاه السيوطي إلى أبي الشيخ. وأخرجه ابن جرير ٩/٤٤٢ عن الحسن من طريق قتادة. وفي تفسير الثعلبي ٤/١٧٣، وتفسير البغوي ٣/١٧٢ زيادة عن الحسن: وكان يقول: يا ابن آدم، أنت وديعة في أهلك، يوشك أن تلحق بصاحبك، وأنشد قول لبيد:</p><p>وما المال والأهلون إلا وديعة ولا بد يومًا أن تُرَدَّ الودائع.أخرجه ابن جرير ٩/٤٣٩. وعلَّقه ابن أبي حاتم ٤/١٣٥٥.أخرجه عبد الرزاق ٢/٢١٤، وابن جرير ٩/٤٤١.أخرجه ابن جرير ٩/٤٤١. وعلَّقه ابن أبي حاتم ٤/١٣٥٥، ١٣٥٧.أخرجه ابن أبي حاتم ٤/١٣٥٦.أخرجه ابن أبي حاتم ٤/١٣٥٦-١٣٥٧.علَّقه ابن أبي حاتم ٤/١٣٥٨.تفسير مقاتل بن سليمان ١/٥٨٠.أخرجه ابن جرير ٩/٤٤٢.أخرجه ابن جرير ٩/٤٤٤، وابن أبي حاتم ٤/١٣٥٨. وعزاه السيوطي إلى ابن المنذر.تفسير مقاتل بن سليمان ١/٥٨٠.عزاه السيوطي إلى أبي الشيخ.عزاه السيوطي إلى أبي الشيخ.
  6,99,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَهُوَ ٱلَّذِیۤ أَنزَلَ مِنَ ٱلسَّمَاۤءِ مَاۤءࣰ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٢٥٧٣١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثم أخبر عن صُنعِه؛ لِيُعْرَف توحيدُه، فقال: <span class="qpc-hafs">﴿وهو الذي أنزل من السماء ماء﴾</span>، يعني: المطر{1}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿فَأَخۡرَجۡنَا بِهِۦ نَبَاتَ كُلِّ شَیۡءࣲ فَأَخۡرَجۡنَا مِنۡهُ خَضِرࣰا﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٢٥٧٣٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فأخرجنا به﴾</span> يعني: بالمطر <span class="qpc-hafs">﴿نبات كل شيء﴾</span> يعني: الثمار، والحبوب، وألوان النبات، <span class="qpc-hafs">﴿فأخرجنا منه خضرا﴾</span> يعني: أول النبات{2}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿فَأَخۡرَجۡنَا بِهِۦ نَبَاتَ كُلِّ شَیۡءࣲ فَأَخۡرَجۡنَا مِنۡهُ خَضِرࣰا﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٢٥٧٣٣<span class="dash">-</span></span> عن سيار، قال: كان <span class="name-2">خالد بن يزيد</span> عند عبد الملك بن مروان، فذكروا الماء، فقال خالد بن يزيد: منه من السماء، ومنه ما يسقيه الغيم من البحر فَيُعْذِبُهُ{3} الرعد والبرق، فأمّا ما كان من البحر فلا يكون له نبات، وأمّا النبات فمِمّا كان من السماء{4}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿نُّخۡرِجُ مِنۡهُ حَبࣰّا مُّتَرَاكِبࣰا﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٢٥٧٣٤<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- في قوله: <span class="qpc-hafs">﴿نخرج منه حبا متراكبا﴾</span>، قال: فهذا السُّنبُلُ{5}. (٦/١٥٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٥٧٣٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿نخرج منه﴾</span> يعني: من الماء <span class="qpc-hafs">﴿حبا متراكبا﴾</span> يعني: السُّنبُل، قد رَكِب بعضُه بعضًا{2}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَمِنَ ٱلنَّخۡلِ مِن طَلۡعِهَا قِنۡوَانࣱ دَانِیَةࣱ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٢٥٧٣٦<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي بن أبي طلحة- <span class="qpc-hafs">﴿قنوان دانية﴾</span>، قال: قِصارُ النخل اللّاصقةُ عُذوقُها بالأرض{7}. (٦/١٥٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٥٧٣٧<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق السدي- <span class="qpc-hafs">﴿قنوان﴾</span>: الكبائسُ{8}، والدّانيةُ: المنصوبة{9}<span class=comment-ref>٢٣٥٤</span>. (٦/١٥٨)</p></p><p></div></p><p><div><span class=comment-ref>٢٣٥٤</span> لم يذكر <u>ابنُ جرير</u> (٩/٤٤٦-٤٤٧) في معنى: <span class="qpc-hafs">﴿دانية﴾</span> سوى القول بأنها القريبة المتهدِّلة.</p><p>و<span class="comment-type-4">زاد</span> <u>ابنُ عطية</u> (٣/٤٢٩) قولًا نقله ولم ينسبه، أنّ المعنى: «قريبة بعضها من بعض».</div></p><p><div></p><p><p><span class="item-no">٢٥٧٣٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطية- في قوله: <span class="qpc-hafs">﴿قنوان دانية﴾</span>، قال: تَهَدُّلُ العُذُوقِ من الطَّلْع{10}. (٦/١٥٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٥٧٣٩<span class="dash">-</span></span> عن <span class="name-1">البراء بن عازب</span> -من طريق أبي إسحاق- <span class="qpc-hafs">﴿قنوان دانية﴾</span>، قال: قريبة{11}. (٦/١٥٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٥٧٤٠<span class="dash">-</span></span> قال <span class="name-2">مجاهد بن جبر</span>: <span class="qpc-hafs">﴿دانية﴾</span>: مُتَدَلِّيَة{12}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٥٧٤١<span class="dash">-</span></span> عن <span class="name-2">الضحاك بن مزاحم</span> -من طريق عبيد بن سليمان- قال في قوله: <span class="qpc-hafs">﴿ومن النخل من طلعها قنوان دانية﴾</span>: يعني: النخل القصار الملتزقة بالأرض، والقنوان: طَلْعُه{13}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٥٧٤٢<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق مَعْمَر- في قوله: <span class="qpc-hafs">﴿قنوان﴾</span> قال: عُذُوقُ النخل، <span class="qpc-hafs">﴿دانية﴾</span> قال: مُتَهَدِّلَة، يعني: مُتَدَلِّية{14}. (٦/١٥٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٥٧٤٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: وأخرجنا بالماء من النخل؛ <span class="qpc-hafs">﴿من طلعها﴾</span> يعني: من ثمرها <span class="qpc-hafs">﴿قنوان﴾</span> يعني: قصار النخل <span class="qpc-hafs">﴿دانية﴾</span> يعني: ملتصقة بالأرض تُجْنى باليد{2}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَجَنَّـٰتࣲ مِّنۡ أَعۡنَابࣲ وَٱلزَّیۡتُونَ وَٱلرُّمَّانَ﴾</span> - قراءات</h3></p><p><div></p><p><p><span class="item-no">٢٥٧٤٤<span class="dash">-</span></span> عن <span class="name-2">سليمان الأعمش</span> -من طريق حمزة- أنّه قرأ: (وجَنّاتٌ مِّنْ أعْنابٍ) بالرفع{16}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَجَنَّـٰتࣲ مِّنۡ أَعۡنَابࣲ وَٱلزَّیۡتُونَ وَٱلرُّمَّانَ﴾</span> - تفسير الآية</h3></p><p><div></p><p><p><span class="item-no">٢٥٧٤٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: وأخرجنا بالماء جنات، يعني: البساتين. ثُمَّ نعت البساتين، فقال: <span class="qpc-hafs">﴿من أعناب والزيتون والرمان..﴾</span>{2}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿مُشۡتَبِهࣰا وَغَیۡرَ مُتَشَـٰبِهٍۗ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٢٥٧٤٦<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق خالد بن قيس- في قوله: <span class="qpc-hafs">﴿مشتبها وغير متشابه﴾</span>، قال: متشابهًا ورَقُه، مختلِفًا ثمرُه{18}. (٦/١٥٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٥٧٤٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿مشتبها﴾</span> ورقها في المنظر، يشبه ورق الزيتون، وورق الرمان، ثم قال: <span class="qpc-hafs">﴿وغير متشابه﴾</span> في اللون، مختلف في الطَّعم{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٥٧٤٨<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: يعني: وأخرجنا الزيتون والرمان <span class="qpc-hafs">﴿مشتبها وغير متشابه﴾</span>، أي: مشتبهًا في طعمه ولونه، وغير متشابه{20}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿ٱنظُرُوۤا۟ إِلَىٰ ثَمَرِهِۦۤ إِذَاۤ أَثۡمَرَ وَیَنۡعِهِۦۤۚ﴾</span> - قراءات</h3></p><p><div></p><p><p><span class="item-no">٢٥٧٤٩<span class="dash">-</span></span> عن <span class="name-2">يحيى بن وثّاب</span> -من طريق الأعمش- أنّه كان يقرأ: ‹إلى ثُمُرِهِ›. يقول: هو أصناف المال{21}<span class=comment-ref>٢٣٥٥</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٢٣٥٥</span> <span class="comment-type-1">وجَّه</span> <u>ابنُ عطية</u> (٣/٤٣٠) قول يحيى بن وثاب بقوله: «كأن المعنى: انظروا إلى الأموال التي تتحصل منه».</div></p><p><div></p><p><p><span class="item-no">٢٥٧٥٠<span class="dash">-</span></span> عن <span class="name-2">عاصم ابن أبي النجود</span> أنّه قرأ: <span class="qpc-hafs">﴿انْظُرُوا إلى ثَمَرِهِ﴾</span> بنصب الثاء والميم، <span class="qpc-hafs">﴿ويَنْعِهِ﴾</span> بنصب الياء{22}. (٦/١٥٩)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿ٱنظُرُوۤا۟ إِلَىٰ ثَمَرِهِۦۤ إِذَاۤ أَثۡمَرَ وَیَنۡعِهِۦۤۚ﴾</span> - تفسير الآية</h3></p><p><div></p><p><p><span class="item-no">٢٥٧٥١<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق قيس بن سعد- قال: الثُّمُر: هو المال. والثَّمَر: ثمر النخل{23}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٥٧٥٢<span class="dash">-</span></span> عن <span class="name-2">محمد بن كعب القرظي</span> -من طريق موسى بن عبيدة- في قوله: <span class="qpc-hafs">﴿انظروا إلى ثمره إذا أثمر﴾</span>، قال: رُطَبه، وعِنَبه{24}. (٦/١٥٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٥٧٥٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿انظروا إلى ثمره إذا أثمر﴾</span> حين يبدو غضًّا أوَّلُه صِيصًا{25} <span class="qpc-hafs">﴿وينعه﴾</span>{2}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿ٱنظُرُوۤا۟ إِلَىٰ ثَمَرِهِۦۤ إِذَاۤ أَثۡمَرَ وَیَنۡعِهِۦۤۚ﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٢٥٧٥٤<span class="dash">-</span></span> عن محمد بن مِسْعَر، قال: فَرْضًا على الناس إذا أُخرِجت الثمار أن يَخرُجوا وينظُروا إليها، قال الله: <span class="qpc-hafs">﴿انظروا إلى ثمره إذا أثمر﴾</span>{27}. (٦/١٥٩)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَیَنۡعِهِۦۤۚ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٢٥٧٥٥<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي بن أبي طلحة- <span class="qpc-hafs">﴿وينعه﴾</span>، قال: نُضْجِه{28}. (٦/١٥٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٥٧٥٦<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>: أنّ نافع بن الأزرق قال له: أخبِرني عن قوله: <span class="qpc-hafs">﴿وينعه﴾</span>. قال: نُضْجِه، وبلاغِه. قال: وهل تعرف العرب ذلك؟ قال: نعم، أما سمعتَ الشاعر وهو يقول: =</p><p>إذا ما مَشَتْ وسْطَ النساء تأوَّدَتْ كما اهْتَزَّ غُصْنٌ ناعِمَ النَّبْتِ يانِعُ {29}. (٦/١٦٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٥٧٥٧<span class="dash">-</span></span> عن <span class="name-1">البراء بن عازب</span> -من طريق أبي إسحاق- <span class="qpc-hafs">﴿وينعه﴾</span>، قال: نُضْجه{30}. (٦/١٥٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٥٧٥٨<span class="dash">-</span></span> عن <span class="name-2">عطاء الخراساني</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٥٧٥٩<span class="dash">-</span></span> و<span class="name-2">عبد الله بن أبي إسحاق البصري</span>، مثل ذلك{31}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٥٧٦٠<span class="dash">-</span></span> عن <span class="name-2">الضحاك بن مُزاحم</span> -من طريق عبيد بن سليمان- قال في قوله: <span class="qpc-hafs">﴿وينعه﴾</span>: يعني: نُضْجه{32}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٥٧٦١<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق مَعْمَر- في قوله: <span class="qpc-hafs">﴿وينعه﴾</span>، قال: نُضْجه{33}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٥٧٦٢<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- <span class="qpc-hafs">﴿وينعه﴾</span>، يقول: ونُضْجه{32}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿إِنَّ فِی ذَ ٰ⁠لِكُمۡ لَـَٔایَـٰتࣲ لِّقَوۡمࣲ یُؤۡمِنُونَ ۝٩٩﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٢٥٧٦٣<span class="dash">-</span></span> قال <span class="name-2">الحسن البصري</span>: <span class="qpc-hafs">﴿إن في ذلكم لآيات لقوم يؤمنون﴾</span>، يقول: الذي أخرج من هذا الماء هذا النبات، وهذا الخضر، وهذه الجنات؛ قادرٌ على أن يُحْيِيَ الموتى{20}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٥٧٦٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿إن في ذلكم﴾</span> يعني: إنّ في هذا الذي ذُكِر من صنعه وعجائبه <span class="qpc-hafs">﴿لآيات﴾</span> لَعِبْرَة <span class="qpc-hafs">﴿لقوم يؤمنون﴾</span> يعني: يُصَدِّقون بالتوحيد{2}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ١/٥٨٠.تفسير مقاتل بن سليمان ١/٥٨١.يُعْذبه: يجعله عَذْبًا. اللسان (عذب).أخرجه ابن أبي حاتم ٤/١٣٥٨.أخرجه ابن جرير ٩/٤٤٥، وابن أبي حاتم ٤/١٣٥٨. وعزاه السيوطي إلى أبي الشيخ.تفسير مقاتل بن سليمان ١/٥٨١.أخرجه ابن جرير ٩/٤٤٦، وابن أبي حاتم ٤/١٣٥٩. وعزاه السيوطي إلى ابن المنذر.الكبائس: جمع كِباسَة، وهو العِذْق التام بشَماريخه ورُطَبه. النهاية (كبس).أخرجه ابن أبي حاتم ٤/١٣٥٩. وعزاه السيوطي إلى أبي الشيخ.أخرجه ابن جرير ٩/٤٤٧، وابن أبي حاتم ٤/١٣٥٩.أخرجه عبد الرزاق ١/٢١٥، وابن جرير ٩/٤٤٧، وابن أبي حاتم ٤/١٣٥٩. وعزاه السيوطي إلى الفريابي، وعبد بن حميد، وابن المنذر، وأبي الشيخ.تفسير الثعلبي ٤/١٧٤، وتفسير البغوي ٣/١٧٢.أخرجه ابن جرير ٩/٤٤٧، وابن أبي حاتم ٤/١٣٥٨.أخرجه عبد الرزاق ١/٢١٥، وابن جرير ٩/٤٤٧، وابن أبي حاتم ٤/١٣٥٩. وعزاه السيوطي إلى عبد بن حُمَيد، وابن المنذر، وأبي الشيخ.تفسير مقاتل بن سليمان ١/٥٨١.أخرجه ابن جرير ٩/٤٤٨.</p><p>وهي قراءة شاذة. انظر: مختصر ابن خالويه ص٤٥.تفسير مقاتل بن سليمان ١/٥٨١.أخرجه ابن جرير ٩/٤٤٩، وابن أبي حاتم ٤/١٣٥٩. وعزاه السيوطي إلى عبد بن حُمَيد، وابن المنذر، وأبي الشيخ.تفسير مقاتل بن سليمان ١/٥٨١.تفسير ابن أبي زمنين ٢/٨٨.أخرجه ابن جرير ٩/٤٥٠.</p><p>وهي قراءة متواترة، قرأ بها حمزة، والكسائي، وخلف العاشر، وقرأ بقية العشرة: <span class="qpc-hafs">﴿إلى ثَمَرِهِ﴾</span> بفتح الثاء والميم. انظر: النشر ٢/٢٦٠، والإتحاف ص٢٧٠. أمّا <span class="qpc-hafs">﴿يَنْعِهِ﴾</span> المذكور في الأثر التالي فلا خلاف بين القراء فيه أنه بفتح الياء.عزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ٩/٤٥٠.أخرجه ابن أبي حاتم ٤/١٣٥٩.كذا في مطبوعة المصدر، والصِّيص: لغة فِي الشِّيص وهو الحَشَف مِنَ التَّمْرِ. لسان العرب (صيص، شيص).تفسير مقاتل بن سليمان ١/٥٨١.عزاه السيوطي إلى أبي الشيخ.أخرجه ابن جرير ٩/٤٥١-٤٥٢. وعلَّقه ابن أبي حاتم ٤/١٣٦٠. وعزاه السيوطي إلى ابن المنذر، وأبي الشيخ.أخرجه الطستي -كما في الإتقان ٢/٦٩-.أخرجه ابن أبي حاتم ٤/١٣٦٠. وعزاه السيوطي إلى أبي عبيد، وابن المنذر.علَّقه ابن أبي حاتم ٤/١٣٦٠.أخرجه ابن جرير ٩/٤٥٢.أخرجه عبد الرزاق ٢/٢١٥، وابن جرير ٩/٤٥٢ وله أيضًا من طريق سعيد.أخرجه ابن جرير ٩/٤٥٢.تفسير ابن أبي زمنين ٢/٨٨.تفسير مقاتل بن سليمان ١/٥٨١.
  6,100,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَجَعَلُوا۟ لِلَّهِ شُرَكَاۤءَ ٱلۡجِنَّ وَخَلَقَهُمۡۖ وَخَرَقُوا۟ لَهُۥ بَنِینَ وَبَنَـٰتِۭ بِغَیۡرِ عِلۡمࣲۚ سُبۡحَـٰنَهُۥ وَتَعَـٰلَىٰ عَمَّا یَصِفُونَ ۝١٠٠﴾</span> - نزول الآية</h3></p><p><div></p><p><p><span class="item-no">٢٥٧٦٥<span class="dash">-</span></span> قال <span class="name-3">محمد بن السائب الكلبي</span>: نزلت في الزنادقة، أثبتوا الشِّرْكَة لإبليس في الخلق، فقالوا: اللهُ خالقُ النورِ والناس والدواب والأنعام، وإبليسُ خالقُ الظلمةِ والسباع والحيات والعقارب. وهذا كقوله: <span class="qpc-hafs">﴿وجعلوا بينه وبين الجنة نسبا﴾</span> [الصافات:١٥٨]، وإبليس من الجِنَّة{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٥٧٦٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وجعلوا لله شركاء الجن﴾</span> من الملائكة، وذلك أنّ جُهَيْنة وبني سلمة وخزاعة وغيرهم قالوا: إنّ حيًّا من الملائكة يُقال لهم: الجن بنات الرحمن. فقال الله: <span class="qpc-hafs">﴿وخلقهم﴾</span>{2}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَجَعَلُوا۟ لِلَّهِ شُرَكَاۤءَ ٱلۡجِنَّ وَخَلَقَهُمۡۖ وَخَرَقُوا۟ لَهُۥ بَنِینَ وَبَنَـٰتِۭ بِغَیۡرِ عِلۡمࣲۚ سُبۡحَـٰنَهُۥ وَتَعَـٰلَىٰ عَمَّا یَصِفُونَ ۝١٠٠﴾</span> - قراءات</h3></p><p><div></p><p><p><span class="item-no">٢٥٧٦٧<span class="dash">-</span></span> عن <span class="name-2">يحيى بن يَعْمَرَ البصري</span> -من طريق يحيى بن عقيل- أنّه كان يقرَؤها: (وجَعَلُواْ للهِ شُرَكَآءَ الجِنَّ وخَلْقَهُمْ) خفيفةً. يقول: جعَلوا لله خلْقَهم{3}<span class=comment-ref>٢٣٥٦</span>. (٦/١٦١)</p></p><p></div></p><p><div><span class=comment-ref>٢٣٥٦</span> <span class="comment-type-1">وجَّه</span> <u>ابنُ عطية</u> (٣/٤٣١) قول يحيى بن يعمر بقوله: «أي: جعلوا خلقهم الذي ينحتونه أصنامًا شركاء لله».</div></p><p><div></p><p><p><span class="item-no">٢٥٧٦٨<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> أنّه قرَأ: (خَلَّقَهُمْ) مُثَقَّلَةً. يقول: هو خلَّقهم{4}. (٦/١٦١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٥٧٦٩<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span>، في الآية، قال: ‹خَرَّقُواْ› ما هو؟! إنّما <span class="qpc-hafs">﴿خَرَقُواْ﴾</span> خفيفة{5}. (٦/١٦١)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَجَعَلُوا۟ لِلَّهِ شُرَكَاۤءَ ٱلۡجِنَّ وَخَلَقَهُمۡۖ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٢٥٧٧٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي بن أبي طلحة- في قوله: <span class="qpc-hafs">﴿وجعلوا لله شركاء الجن وخلقهم﴾</span>، قال: واللهُ خلَقهم{6}. (٦/١٦٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٥٧٧١<span class="dash">-</span></span> عن <span class="name-2">الضحاك بن مُزاحِم</span> -من طريق جُوَيْبِر- في قوله: <span class="qpc-hafs">﴿وجعلوا لله شركاء﴾</span>، يقول: هل تشركون عبيدكم في الذي لكم فتكونوا فيه سواء؟ فكيف ترضون لي ما لا ترضون لأنفسكم؟!{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٥٧٧٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وجعلوا﴾</span> يعني: وصفوا <span class="qpc-hafs">﴿لله﴾</span> الذي خلقهم في التقديم <span class="qpc-hafs">﴿شركاء الجن﴾</span> من الملائكة{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٥٧٧٣<span class="dash">-</span></span> عن <span class="name-3">عبد الملك ابن جُرَيْج</span> -من طريق حجّاج- قوله: <span class="qpc-hafs">﴿وجعلوا لله شركاء الجن﴾</span>، قال: قول الزَّنادِقة{9}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَخَرَقُوا۟ لَهُۥ بَنِینَ وَبَنَـٰتِۭ بِغَیۡرِ عِلۡمࣲۚ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٢٥٧٧٤<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي بن أبي طلحة- في قوله: <span class="qpc-hafs">﴿وخرقوا له بنين وبنات بغير علم﴾</span>، قال: تَخَرَّصوا{6}. (٦/١٦٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٥٧٧٥<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطِيَّة- في قوله: <span class="qpc-hafs">﴿وخرقوا له بنين وبنات﴾</span>، قال: جعَلوا له بنين وبنات{11}. (٦/١٦٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٥٧٧٦<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>: أنّ نافع بن الأزرق قال له: أخبِرني عن قوله: <span class="qpc-hafs">﴿وخرقوا له بنين وبنات﴾</span>. قال: وصفوا لله بنين وبنات افتراءً عليه. قال: وهل تعرف العرب ذلك؟ قال: نعم، أما سمعتَ حسان بن ثابت يقول:</p><p>اخترَقَ القولَ بها لاهيًا مستقبلًا أشعثَ عذبَ الكلامْ{12}. (٦/١٦١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٥٧٧٧<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿وخرقوا﴾</span>، قال: كذَبوا{13}. (٦/١٦٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٥٧٧٨<span class="dash">-</span></span> عن <span class="name-2">الضحاك بن مُزاحِم</span> -من طريق جُوَيْبِر- <span class="qpc-hafs">﴿وخرقوا له بنين وبنات﴾</span>، قال: وصَفوا له{14}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٥٧٧٩<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span>، في الآية، قال: ‹خَرَّقُواْ› ما هو؟! إنّما <span class="qpc-hafs">﴿خَرَقُواْ﴾</span> خفيفة، كان الرجل إذا كذَب الكَذْبَةَ في نادي القوم قيل: خَرَقَها{15}. (٦/١٦١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٥٧٨٠<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق مَعْمَر- <span class="qpc-hafs">﴿وخرقوا له بنين وبنات بغير علم﴾</span>، قال: خرصوا له بنين وبنات{16}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٥٧٨١<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق خالد بن قيس- في قوله: <span class="qpc-hafs">﴿وخرقوا له بنين وبنات﴾</span>، قال: كذَبوا له؛ أمّا اليهود والنصارى فقالوا: نحنُ أبناء الله وأحباؤُه. وأمّا مشركو العرب فكانوا يعبدون اللات والعزى، فيقولون: العُزّى بنات الله{17}. (٦/١٦١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٥٧٨٢<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- في قوله: <span class="qpc-hafs">﴿وخرقوا له بنين وبنات﴾</span>، يعني: قطعوا. قال: قالت العرب: الملائكة بنات الله. وقالت اليهود والنصارى: المسيحُ وعزيرٌ ابنا الله{18}. (٦/١٦٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٥٧٨٣<span class="dash">-</span></span> عن <span class="name-2">أبي عمرو بن العلاء</span> -من طريق عبد الوارث- <span class="qpc-hafs">﴿وخرقوا له بنين وبنات﴾</span>، قال: تفسيرها: وكذبوا{19}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٥٧٨٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وخرقوا له﴾</span> يعني: وتخرَّصوا، يعني: يخلقوا لله <span class="qpc-hafs">﴿بنين وبنات بغير علم﴾</span> يعلمونه أنّ له بنين وبنات، وذلك أنّ اليهود قالوا: عزيرٌ ابن الله. وقالت النصارى: المسيح ابن الله. وقالت العرب: الملائكة بنات الله{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٥٧٨٥<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿وخرقوا له بنين وبنات بغير علم﴾</span>، قال: خرقوا: كذبوا، لم يكن لله بنون ولا بنات، قالت النصارى: المسيح ابن الله. وقال المشركون: الملائكة بنات الله. فكل خرقوا الكذب، <span class="qpc-hafs">﴿وخرقوا﴾</span>: اخترقوا{21}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿سُبۡحَـٰنَهُۥ وَتَعَـٰلَىٰ عَمَّا یَصِفُونَ ۝١٠٠﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٢٥٧٨٦<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق خالد بن قيس- في قوله: <span class="qpc-hafs">﴿سبحانه وتعالى عما يصفون﴾</span>، قال: أي: عما يَكْذِبون{22}<span class=comment-ref>٢٣٥٧</span>. (٦/١٦١)</p></p><p></div></p><p><div><span class=comment-ref>٢٣٥٧</span> <span class="comment-type-1">وجَّه</span> <u>ابنُ جرير</u> (٩/٤٥٧) قول قتادة، فقال: «وأَحْسَبُ أنّ قتادة عنى بتأويله ذلك كذلك: أنّهم يكذبون في وصفهم الله بما كانوا يصفونه به، من ادِّعائهم له بنين وبنات، لا أنه وجَّه تأويل الوصف إلى الكذب».</div></p><p><div></p><p><p><span class="item-no">٢٥٧٨٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: يقول الله: <span class="qpc-hafs">﴿سبحانه﴾</span> نزَّه نفسه عما قالوا من البهتان، ثم عظَّم نفسه، فقال: <span class="qpc-hafs">﴿وتعالى﴾</span> يعني: وارتفع <span class="qpc-hafs">﴿عما يصفون﴾</span> يعني: يقولون من الكذب{2}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير الثعلبي ٤/١٧٥، وتفسير البغوي ٣/١٧٣.تفسير مقاتل بن سليمان ١/٥٨١.أخرجه ابن جرير ٩/٤٥٣. وعزاه السيوطي إلى أبي الشيخ.</p><p>وهي قراءة شاذة. انظر: مختصر ابن خالويه ص٤٥، والمحتسب ١/٢٢٤.عزاه السيوطي إلى أبي الشيخ.</p><p>وهي قراءة شاذة.عزاه السيوطي إلى أبي الشيخ.</p><p>‹خَرَّقُواْ› بتشديد الراء قراءة متواترة، قرأ بها نافع، وأبو جعفر، وقرأ بقية العشرة: <span class="qpc-hafs">﴿خَرَقُواْ﴾</span> مخففة. انظر: النشر ٢/٢٦١.أخرجه ابن جرير ٩/٤٥٤، وابن أبي حاتم ٤/١٣٦٠. وعزاه السيوطي إلى ابن المنذر.أخرجه ابن أبي حاتم ٤/١٣٦٠.تفسير مقاتل بن سليمان ١/٥٨١.أخرجه ابن جرير ٩/٤٥٥.أخرجه ابن جرير ٩/٤٥٤، وابن أبي حاتم ٤/١٣٦٠. وعزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ٩/٤٥٤، وابن أبي حاتم ٤/١٣٦٠.عزاه السيوطي إلى الطستي.تفسير مجاهد ص٣٢٦، وأخرجه ابن جرير ٩/٤٥٤، وابن أبي حاتم ٤/١٣٦٠. وعزاه السيوطي إلى عبد بن حُمَيد، وابن المنذر.أخرجه ابن جرير ٩/٤٥٦، وابن أبي حاتم ٤/١٣٦١.عزاه السيوطي إلى أبي الشيخ. وعلَّق ابن أبي حاتم ٤/١٣٦٠ نحو آخره.أخرجه ابن جرير ٩/٤٥٥. وعلَّقه ابن أبي حاتم ٤/١٣٦٠ بنحوه.أخرجه ابن جرير ٩/٤٥٥، وابن أبي حاتم ٤/١٣٦١. وعزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ٩/٤٥٥ دون أوله، وابن أبي حاتم ٤/١٣٦٠-١٣٦١.أخرجه ابن جرير ٩/٤٥٦.تفسير مقاتل بن سليمان ١/٥٨١.أخرجه ابن جرير ٩/٤٥٥، وابن أبي حاتم ٤/١٣٦١.أخرجه ابن جرير ٩/٤٥٧، وابن أبي حاتم ٤/١٣٦١. وعزاه السيوطي إلى عبد بن حميد.تفسير مقاتل بن سليمان ١/٥٨١.
  6,101,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿بَدِیعُ ٱلسَّمَـٰوَ ٰ⁠تِ وَٱلۡأَرۡضِۖ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٢٥٧٨٨<span class="dash">-</span></span> عن <span class="name-2">أبي العالية الرِّياحي</span> -من طريق الربيع- قوله: <span class="qpc-hafs">﴿بديع السموات والأرض﴾</span>، قال: ابتَدَع خَلْقَهما، ولم يشركه في خلقهما أحد{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٥٧٨٩<span class="dash">-</span></span> عن <span class="name-2">الربيع بن أنس</span>، نحو ذلك{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٥٧٩٠<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- <span class="qpc-hafs">﴿بديع السموات والأرض﴾</span>، يقول: ابتدعهما، فخلقهما، ولم يخلق قبلهما شيئًا فيتَمَثَّل عليه{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٥٧٩١<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span>، نحو ذلك{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٥٧٩٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: فعظَّم نفسه، وأخبر عن قدرته، فقال: <span class="qpc-hafs">﴿بديع السماوات والأرض﴾</span> لم يكونا، فابتَدَع خلقَهما{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٥٧٩٣<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿بديع السموات والأرض﴾</span>، قال: هو الذي ابتدع خلقهما جل جلاله، فخلقهما، ولم تكونا شيئًا قبله{6}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿أَنَّىٰ یَكُونُ لَهُۥ وَلَدࣱ وَلَمۡ تَكُن لَّهُۥ صَـٰحِبَةࣱۖ وَخَلَقَ كُلَّ شَیۡءࣲۖ وَهُوَ بِكُلِّ شَیۡءٍ عَلِیمࣱ ۝١٠١﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٢٥٧٩٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿أنى﴾</span> يعني: مِن أين <span class="qpc-hafs">﴿يكون له ولد ولم تكن له صاحبة﴾</span> يعني: زوجة، <span class="qpc-hafs">﴿وخلق كل شيء﴾</span> يعني: من الملائكة، وعزير، وعيسى، وغيرهم، فهم خلقُه، وعبادُه، وفي ملكه{5}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن أبي حاتم ٤/١٣٦٢.علَّقه ابن أبي حاتم ٤/١٣٦٢.أخرجه ابن أبي حاتم ٤/١٣٦٢.علَّقه ابن أبي حاتم ٤/١٣٦٢.تفسير مقاتل بن سليمان ١/٥٨١-٥٨٢.أخرجه ابن جرير ٩/٤٥٧.تفسير مقاتل بن سليمان ١/٥٨١-٥٨٢.