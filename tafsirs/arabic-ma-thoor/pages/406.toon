quran[9]{c,v,t}:
  30,16,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿فَسُبۡحَـٰنَ ٱللَّهِ حِینَ تُمۡسُونَ وَحِینَ تُصۡبِحُونَ ۝١٧ وَلَهُ ٱلۡحَمۡدُ فِی ٱلسَّمَـٰوَ ٰ⁠تِ وَٱلۡأَرۡضِ وَعَشِیࣰّا وَحِینَ تُظۡهِرُونَ ۝١٨﴾</span> - تفسير الآية</h3></p><p><div></p><p><p><span class="item-no">٦٠٤٧٦<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، قال: كل تسبيح في القرآن فهو صلاة{1}. (١١/٥٩١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٠٤٧٧<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، قال: أدنى ما يكون مِن الحين بكرةً وعَشِيًّا. ثم قرأ: <span class="qpc-hafs">﴿فَسُبْحانَ اللَّهِ حِينَ تُمْسُونَ وحِينَ تُصْبِحُونَ﴾</span>{2}. (١١/٥٩١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٠٤٧٨<span class="dash">-</span></span> قال <span class="name-1">عبد الله بن عباس</span>: <span class="qpc-hafs">﴿ولَهُ الحَمْدُ في السَّماواتِ والأَرْضِ وعَشِيًّا وحِينَ تُظْهِرُونَ﴾</span> يحمده أهل السموات والأرض، ويُصَلُّون له{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٠٤٧٩<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق أبي رزين- أنّه سأله نافع بن الأزرق، فقال: هل تجد الصلوات الخمس في القرآن؟ قال: نعم. فقرأ: <span class="qpc-hafs">﴿فَسُبْحانَ اللَّهِ حِينَ تُمْسُونَ﴾</span> صلاة المغرب، <span class="qpc-hafs">﴿وحين تُصبحُونَ﴾</span> صلاة الصبح، <span class="qpc-hafs">﴿وعَشِيًّا﴾</span> صلاة العصر، <span class="qpc-hafs">﴿وحين تظْهرُونَ﴾</span> صلاة الظهر. وقرأ: <span class="qpc-hafs">﴿ومن بعد صَلاة العشاء﴾</span> [النور:٥٨]{4}. (١١/٥٩٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٠٤٨٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق أبي عياض- قال: جمعت هذه الآيةُ مواقيتَ الصلاة؛ <span class="qpc-hafs">﴿فَسُبْحانَ اللَّهِ حِينَ تُمْسُونَ﴾</span> قال: المغرب والعشاء، <span class="qpc-hafs">﴿وحين تُصبحُونَ﴾</span> الفجر، <span class="qpc-hafs">﴿وعَشِيًّا﴾</span> العصر، <span class="qpc-hafs">﴿وحين تظْهرُونَ﴾</span> الظهر{5}. (١١/٥٩٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٠٤٨١<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ليث-، مثله{6}. (١١/٥٩٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٠٤٨٢<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span> -من طريق جعفر- <span class="qpc-hafs">﴿وإبراهيم الذي وفى﴾</span> [النجم:٣٧]، قال: <span class="qpc-hafs">﴿سبحان الله حين تمسون وحين تصبحون﴾</span> الآيةَ؛ ثلاثٌ غدوة، وثلاثٌ عشية{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٠٤٨٣<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري:</span> أن الصلوات الخمس كلها في هذه الآية يقول: <span class="qpc-hafs">﴿فَسُبْحانَ اللَّهِ حِينَ تُمْسُونَ﴾</span> المغرب والعشاء {8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٠٤٨٤<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد-: <span class="qpc-hafs">﴿فَسُبْحانَ اللَّهِ حِينَ تُمْسُونَ﴾</span> لصلاة المغرب، <span class="qpc-hafs">﴿وحين تُصبحُونَ﴾</span> لصلاة الصبح، <span class="qpc-hafs">﴿وعَشِيًّا﴾</span> لصلاة العصر، <span class="qpc-hafs">﴿وحين تظْهرُونَ﴾</span> صلاة الظهر؛ أربع صلوات{9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٠٤٨٥<span class="dash">-</span></span> قال <span class="name-2">إسماعيل السُّدِّيّ</span>: <span class="qpc-hafs">﴿وحِينَ تُظْهِرُونَ﴾</span> تنشرون، وتنبسطون{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٠٤٨٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فَسُبْحانَ اللَّهِ﴾</span> يعني: فصلُّوا لله ﷿ <span class="qpc-hafs">﴿حِينَ تُمْسُونَ﴾</span> يعني: صلاة المغرب، وصلاة العشاء، <span class="qpc-hafs">﴿وحِينَ تُصْبِحُونَ﴾</span> يعني: صلاة الفجر، <span class="qpc-hafs">﴿ولَهُ الحَمْدُ في السَّماواتِ والأَرْضِ﴾</span> يحمده الملائكة في السماوات، ويحمده المؤمنون في الأرض <span class="qpc-hafs">﴿وعَشِيًّا﴾</span> يعني: صلاة العصر، <span class="qpc-hafs">﴿وحِينَ تُظْهِرُونَ﴾</span> يعني: صلاة الأولى {11}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٠٤٨٧<span class="dash">-</span></span> قال <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قول الله: <span class="qpc-hafs">﴿فَسُبْحانَ اللَّهِ حِينَ تُمْسُونَ وحِينَ تُصْبِحُونَ * ولَهُ الحَمْدُ في السَّماواتِ والأَرْضِ وعَشِيًّا وحِينَ تُظْهِرُونَ﴾</span>، قال: <span class="qpc-hafs">﴿حِينَ تُمْسُونَ﴾</span> صلاة المغرب، <span class="qpc-hafs">﴿وحِينَ تُصْبِحُونَ﴾</span> صلاة الصبح، <span class="qpc-hafs">﴿وعَشِيًّا﴾</span> صلاة العصر، <span class="qpc-hafs">﴿وحِينَ تُظْهِرُونَ﴾</span> صلاة الظهر، <span class="qpc-hafs">﴿ولَهُ الحَمْدُ في السَّماواتِ والأَرْضِ﴾</span> يقول: وله الحمد مِن جميع خلقه دون غيره <span class="qpc-hafs">﴿في السماوات﴾</span> مِن سكانها من الملائكة، <span class="qpc-hafs">﴿والأرض﴾</span> من أهلها؛ من جميع أصناف خلقه فيها، <span class="qpc-hafs">﴿وعَشِيًّا﴾</span> يقول: وسبِّحوه أيضًا عشيًّا، وذلك صلاة العصر، <span class="qpc-hafs">﴿وحِينَ تُظْهِرُونَ﴾</span> يقول: وحين تدخلون في وقت الظهر{12}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٠٤٨٨<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: كل صلاة ذُكِرت في المكيِّ مِن القرآن قبل الهجرة بسنة فهي ركعتان غدوة، وركعتان عشية، وذلك قبل أن تفرض الصلوات الخمس، وإنما افترضت الصلوات الخمس قبل أن يهاجر النبيُّ ﵇ بسنة؛ ليلة أُسْرِي به، فما كان مِن ذكر الصلاة بعد ذلك يعني: فهي الصلوات الخمس. وهذه الآية نزلت بعدما أُسْرِي بالنبي ﵇، وفُرضت عليه الصلوات الخمس{13}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿فَسُبۡحَـٰنَ ٱللَّهِ حِینَ تُمۡسُونَ وَحِینَ تُصۡبِحُونَ ۝١٧ وَلَهُ ٱلۡحَمۡدُ فِی ٱلسَّمَـٰوَ ٰ⁠تِ وَٱلۡأَرۡضِ وَعَشِیࣰّا وَحِینَ تُظۡهِرُونَ ۝١٨﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٦٠٤٨٩<span class="dash">-</span></span> عن معاذ بن أنس، عن رسول الله ﷺ، قال: «<b>ألا أخبركم لِمَ سَمّى اللهُ إبراهيمَ: خليلَه الذي وفّى؟ لأنّه كان يقول كُلَّما أصبح وأمسى</b>: <span class="qpc-hafs">﴿فَسُبْحانَ اللَّهِ حِينَ تُمْسُونَ وحِينَ تُصْبِحُونَ * ولَهُ الحَمْدُ في السَّماواتِ والأَرْضِ وعَشِيًّا وحِينَ تُظْهِرُونَ﴾</span>»{14}. (١١/٥٩٢). (ز)</p></p><p></div></p></div>",footnotes:1:عزاه السيوطي إلى ابن مردويه، والفريابي.عزاه السيوطي إلى الفريابي، وابن أبي حاتم.تفسير البغوي ٦/٢٦٤.أخرجه يحيى بن سلام ٢/٦٤٩، وعبد الرزاق (١٧٧٢)، وابن جرير ١٨/٤٧٤، وابن المنذر في الأوسط ٢/٣٢١ (٩٣٢)، والطبراني (١٠٥٩٦)، والحاكم ٢/٤١٠-٤١١. وعزاه السيوطي إلى الفريابي، وابن أبي حاتم.أخرجه ابن جرير ١٨/٤٧٤-٤٧٥، وابن المنذر ٢/٣٢٢ (٩٣٣). وعزاه السيوطي إلى ابن أبي شيبة.أخرجه ابن جرير ١٨/٤٧٥. وعزاه السيوطي إلى ابن أبي شيبة، وابن المنذر.أخرجه إسحاق البستي ص٧٧.علقه يحيى بن سلام ٢/٦٤٩.أخرجه ابن جرير ١/٤٧٥.علقه يحيى بن سلام ٢/٦٤٩.تفسير مقاتل بن سليمان ٣/٤٠٩.أخرجه ابن جرير ١٨/٤٧٥.تفسير يحيى بن سلام ٢/٦٤٩-٦٥٠.أخرجه أحمد ٢٤/٣٨٨ (١٥٦٢٤)، وابن جرير ٢/٥٠٧، ٢٢/٧٧-٧٨، والثعلبي ٩/١٥٢.</p><p>قال الزيلعي في تخريج أحاديث الكشاف ٣/٣٨٤-٣٨٥ (١٢٧٢): «رواه الطبري، وابن مردويه، والثعلبي، وابن أبي حاتم في تفاسيرهم، وهو مشتمل على جماعة من الضعفاء». وقال الهيثمي في المجمع ١٠/١١٧ (١٧٠١٠): «رواه الطبراني، وفيه ضعفاء وُثِّقوا». وقال ابن حجر الفتح ٨/٦٠٥: «بإسناد ضعيف». وقال الشوكاني في فتح القدير ٤/٢٥٦: «وفي إسناده ابن لهيعة».
  30,17,""
  30,18,""
  30,19,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿یُخۡرِجُ ٱلۡحَیَّ مِنَ ٱلۡمَیِّتِ وَیُخۡرِجُ ٱلۡمَیِّتَ مِنَ ٱلۡحَیِّ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٠٤٩٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن مسعود</span> -من طريق إبراهيم- قال: <span class="qpc-hafs">﴿يُخْرِجُ الحَيَّ مِنَ المَيِّتِ ويُخْرِجُ المَيِّتَ مِنَ الحَيِّ﴾</span> النطفة ماء الرجل ميتة، وهو حي، ويخرج الرجل منها حيًّا، وهي ميتة{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٠٤٩١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطية العوفي- في قوله: <span class="qpc-hafs">﴿يُخْرِجُ الحَيَّ مِنَ المَيِّتِ ويُخْرِجُ المَيِّتَ مِنَ الحَيِّ﴾</span>، قال: يخرج مِن الإنسان ماء ميتًا فيخلق منه بشرًا، فذلك الميت من الحي، ويخرج الحي من الميت، فيعني بذلك: أنه يخلق من الماء بشرًا، فذلك الحي من الميت{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٠٤٩٢<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span>: <span class="qpc-hafs">﴿يُخْرِجُ الحَيَّ مِنَ المَيِّتِ ويُخْرِجُ المَيِّتَ مِنَ الحَيِّ﴾</span> هي النطفة الحية تخرج من النطفة الميتة الخلق الحي، ويخرج من الخلق الحي النطفة الميتة، ويخرج من الحبة اليابسة الحي، ويخرج من النبات الحي الحبة اليابسة{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٠٤٩٣<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق قتادة- <span class="qpc-hafs">﴿يُخْرِجُ الحَيَّ مِنَ المَيِّتِ ويُخْرِجُ المَيِّتَ مِنَ الحَيِّ﴾</span>: يُخرج المؤمن من الكافر، ويخرج الكافر من المؤمن{4}<span class=comment-ref>٥٠٩٧</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٥٠٩٧</span> <span class="comment-type-4">علَّق</span> <u>ابنُ عطية</u> (٧/١٦) على قول الحسن بقوله: «وروي هذا المعنى عن النبي ﷺ أنه قرأ هذه الآية عند ما كلَّمَتْه بالإسلام أم كلثوم بنت عقبة بن أبي معيط».</div></p><p><div></p><p><p><span class="item-no">٦٠٤٩٤<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span>: <span class="qpc-hafs">﴿يُخْرِجُ الحَيَّ مِنَ المَيِّتِ ويُخْرِجُ المَيِّتَ مِنَ الحَيِّ﴾</span>، يعني: يخرج النُّطَف وهي ميتة مِن الحي، ويخرج الحي -الناس الأحياء- من الميت مِن النُّطَف{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٠٤٩٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿يُخْرِجُ الحَيَّ مِنَ المَيِّتِ﴾</span> يقول: يخرج الناس والدواب والطير من النطف وهي ميتة، <span class="qpc-hafs">﴿ويُخْرِجُ المَيِّتَ﴾</span> يعني: النطف <span class="qpc-hafs">﴿مِنَ الحَيِّ﴾</span> يعني: مِن الناس والدواب والطير{6}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَیُحۡیِ ٱلۡأَرۡضَ بَعۡدَ مَوۡتِهَاۚ وَكَذَ ٰ⁠لِكَ تُخۡرَجُونَ ۝١٩﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٠٤٩٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ويُحْيِ الأَرْضَ﴾</span> بالماء <span class="qpc-hafs">﴿بَعْدَ مَوْتِها﴾</span> فينبت العشب، فذلك حياتها، <span class="qpc-hafs">﴿وكَذَلِكَ﴾</span> يعني: وهكذا <span class="qpc-hafs">﴿تُخْرَجُونَ﴾</span> يا بني آدم مِن الأرض يوم القيامة بالماء، كما يخرج العشب من الأرض بالماء؛ وذلك أنّ الله ﷿ يُرسِل يوم القيامة ماء الحيوان مِن السماء السابعة مِن البحر المسجور على الأرض بين النفختين، فتنبت عظام الخلق ولحومهم وجلودهم كما ينبت العشب من الأرض{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٠٤٩٧<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿ويُحْيِي الأَرْضَ بَعْدَ مَوْتِها﴾</span> يحييها بالنبات بعد أن كانت ميتة، أي: يابسة لا نبات فيها، <span class="qpc-hafs">﴿وكَذَلِكَ تُخْرَجُونَ﴾</span> يعني: البعث، يُرسِلُ اللهُ -تبارك وتعالى- مطرًا منيًّا كمني الرجال، فتنبت به جسمانهم ولحمانهم، كما تُنبِتُ الأرض الثرى{8}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ١٨/٤٧٧.أخرجه ابن جرير ١٨/٤٧٦.علقه يحيى بن سلام ٢/٦٥٠.أخرجه ابن جرير ١٨/٤٧٧. وعلقه يحيى بن سلام ٢/٦٥٠.علَّقه يحيى بن سلام ٢/٦٥٠.تفسير مقاتل بن سليمان ٣/٤٠٩-٤١٠.تفسير مقاتل بن سليمان ٣/٤٠٩-٤١٠.تفسير يحيى بن سلام ٢/٦٥٠.
  30,20,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَمِنۡ ءَایَـٰتِهِۦۤ أَنۡ خَلَقَكُم مِّن تُرَابࣲ ثُمَّ إِذَاۤ أَنتُم بَشَرࣱ تَنتَشِرُونَ ۝٢٠﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٠٤٩٨<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿ومن آياته أن خَلقكُم من تُراب﴾</span> قال: آدم مِن تراب، <span class="qpc-hafs">﴿ثمَّ إذا أنْتُم بشر تنتشرون﴾</span>{1}. (١١/٥٩٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٠٤٩٩<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span>، قال: <span class="qpc-hafs">﴿ومِن آياتِهِ﴾</span>، يعني: ومِن علامات الرب -تبارك وتعالى- أنّه واحد، <span class="qpc-hafs">﴿تَنْتَشِرُونَ﴾</span>: تنبسطون{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٠٥٠٠<span class="dash">-</span></span> عن <span class="name-3">عبد الملك ابن جريج</span>، في قوله: <span class="qpc-hafs">﴿ومن آياته﴾</span>، قال: كل شيء في القرآن آيات بذلك تعرفون الله، إنّكم لن تروه فتعرفونه على رؤية، ولكن تعرفونه بآياته وخلقه{3}. (١١/٥٩٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٠٥٠١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ومِن آياتِهِ﴾</span> يعني: ومِن علامات ربكم أنّه واحد ﷿، وإن لم تروه، فاعرفوا توحيده بصنعه؛ <span class="qpc-hafs">﴿أنْ خَلَقَكُمْ مِن تُرابٍ﴾</span> يعني: آدم صلى الله عليه خلقه مِن طين، <span class="qpc-hafs">﴿ثُمَّ إذا أنْتُمْ بَشَرٌ﴾</span> يعني: ذرية آدم بشر <span class="qpc-hafs">﴿تَنْتَشِرُونَ﴾</span> في الأرض، يعني: تتبسطون في الأرض، كقوله سبحانه: <span class="qpc-hafs">﴿يَنْشُر﴾</span> يعني: ويبسط <span class="qpc-hafs">﴿رحمته﴾</span> [الكهف:١٦]{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٠٥٠٢<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام:</span> <span class="qpc-hafs">﴿أنْ خَلَقَكُمْ مِن تُرابٍ﴾</span> يعني: الخلق الأول؛ خلق آدم، <span class="qpc-hafs">﴿ثُمَّ إذا أنْتُمْ بَشَرٌ تَنْتَشِرُونَ﴾</span> في الأرض{5}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ١٨/٤٧٨. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.علَّقه يحيى بن سلام ٢/٦٥٠.عزاه السيوطي إلى ابن المنذر.تفسير مقاتل بن سليمان ٣/٤١٠.تفسير يحيى بن سلام ٢/٦٥٠-٦٥١.
  30,21,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَمِنۡ ءَایَـٰتِهِۦۤ أَنۡ خَلَقَ لَكُم مِّنۡ أَنفُسِكُمۡ أَزۡوَ ٰ⁠جࣰا لِّتَسۡكُنُوۤا۟ إِلَیۡهَا﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٠٥٠٣<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿ومن آياته أن خلق لكم من أنفسكُم أزْواجًا﴾</span>، قال: حوّاء خلقها الله مِن ضِلَع مِن أضلاع آدم{1}<span class=comment-ref>٥٠٩٨</span>. (١١/٥٩٥)</p></p><p></div></p><p><div><span class=comment-ref>٥٠٩٨</span> <span class="comment-type-4">علَّق</span> <u>ابن عطية</u> (٧/١٧) على قول قتادة بقوله: «فحمل ذلك على جميع الناس من حيث أُمُّهم مخلوقة من نفس آدم، أي: من ذات شخصه».</div></p><p><div></p><p><p><span class="item-no">٦٠٥٠٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ومِن آياتِهِ﴾</span> يعني: علاماته أن تعرفوا توحيده، وإن لم تروه؛ <span class="qpc-hafs">﴿أنْ خَلَقَ لَكُمْ مِن أنْفُسِكُمْ﴾</span> يعني: بعضكم من بعض، أزواجًا <span class="qpc-hafs">﴿لتسكنوا إليها﴾</span>{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٠٥٠٥<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام:</span> <span class="qpc-hafs">﴿ومِن آياتِهِ﴾</span> يعني: ومِن علامات الرب أنّه واحد، فاعرفوا توحيده في صنعه؛ <span class="qpc-hafs">﴿أنْ خَلَقَ لَكُمْ مِن أنْفُسِكُمْ أزْواجًا﴾</span> يعني: أزواجكم؛ المرأة هي من الرجل{3}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَجَعَلَ بَیۡنَكُم مَّوَدَّةࣰ وَرَحۡمَةًۚ إِنَّ فِی ذَ ٰ⁠لِكَ لَـَٔایَـٰتࣲ لِّقَوۡمࣲ یَتَفَكَّرُونَ ۝٢١﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٠٥٠٦<span class="dash">-</span></span> عن صفوان بن عمرو، قال: حدثني المشيخة، أنّ رجلًا أتى النبيَّ ﷺ، فقال: يا نبيَّ الله، لقد عجبتُ من أمرٍ، وإنه لَعَجب؛ إنّ الرجل ليتزوج المرأةَ وما رآها وما رأته قطُّ، حتى إذا ابتنى بها أصبحا وما شيء أحب إلى أحدهما من الآخر. فقال رسول الله ﷺ: <span class="qpc-hafs">﴿وجَعَلَ بَيْنَكُمْ مَوَدَّةً ورَحْمَةً﴾</span>{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٠٥٠٧<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span>، في قوله: <span class="qpc-hafs">﴿وجعل بَيْنكُم مَوَدَّة﴾</span> قال: الجماع، <span class="qpc-hafs">﴿ورَحْمَة﴾</span> قال: الولد{5}. (١١/٥٩٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٠٥٠٨<span class="dash">-</span></span> قال <span class="name-2">إسماعيل السُّدِّيّ</span>: <span class="qpc-hafs">﴿مَوَدَّةً﴾</span>، يعني: محبة، وهو الحب{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٠٥٠٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وجَعَلَ بَيْنَكُمْ﴾</span> وبين أزواجكم <span class="qpc-hafs">﴿مَوَدَّةً﴾</span> يعني: الحب، <span class="qpc-hafs">﴿ورَحْمَةً﴾</span> ليس بينها وبينه رَحِم، <span class="qpc-hafs">﴿إنَّ في ذَلِكَ لَآياتٍ﴾</span> يعني: إنّ في هذا الذي ذُكِر لعبرة <span class="qpc-hafs">﴿لِقَوْمٍ يَتَفَكَّرُونَ﴾</span> فيعتبرون في توحيد الله ﷿{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٠٥١٠<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام:</span> <span class="qpc-hafs">﴿وجَعَلَ بَيْنَكُمْ مَوَدَّةً ورَحْمَةً﴾</span> يعني بالمودة: الحب، والرحمة: للولد، <span class="qpc-hafs">﴿إنَّ في ذَلِكَ لآياتٍ لِقَوْمٍ يَتَفَكَّرُونَ﴾</span> فيؤمنوا، وإنّما يَتَفَكَّر المؤمنون{3}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ١٨/٤٧٨. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.تفسير مقاتل بن سليمان ٣/٤١٠.تفسير يحيى بن سلام ٢/٦٥١.أخرجه الثعلبي ٧/٢٩٩ من طريق أبي شعيب الحراني، عن يحيى بن عبد الله البابلتي، عن صفوان بن عمرو به.</p><p>وهو سند فيه مجاهيل، والبابلتي ضعيف.عزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.علقه يحيى بن سلام ٢/٦٥١.تفسير مقاتل بن سليمان ٣/٤١٠.تفسير يحيى بن سلام ٢/٦٥١.
  30,22,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَمِنۡ ءَایَـٰتِهِۦ خَلۡقُ ٱلسَّمَـٰوَ ٰ⁠تِ وَٱلۡأَرۡضِ وَٱخۡتِلَـٰفُ أَلۡسِنَتِكُمۡ وَأَلۡوَ ٰ⁠نِكُمۡۚ إِنَّ فِی ذَ ٰ⁠لِكَ لَـَٔایَـٰتࣲ لِّلۡعَـٰلِمِینَ ۝٢٢﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٠٥١١<span class="dash">-</span></span> عن <span class="name-2">الضحاك بن مزاحم</span> -من طريق يحيى- قال: <span class="qpc-hafs">﴿واخْتِلافُ ألْسِنَتِكُمْ وأَلْوانِكُمْ﴾</span> يُشْبِهُ الرجلُ الرجلَ ليس بينهما قرابةٌ إلا مِن قِبَل الأب الأكبر آدم{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٠٥١٢<span class="dash">-</span></span> عن <span class="name-3">محمد بن السائب الكلبي</span>: <span class="qpc-hafs">﴿واخْتِلافُ ألْسِنَتِكُمْ﴾</span> للعرب كلام، ولفارس كلام، وللروم كلام، ولسائرهم مِن الناس كلام{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٠٥١٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ومِن آياتِهِ﴾</span> يعني: ومِن علامة الربِّ أنّه واحد، فتعرفوا توحيده بصنعه <span class="qpc-hafs">﴿خَلْقُ السَّماواتِ والأَرْضِ﴾</span> وأنتم تعلمون ذلك، كقوله سبحانه: <span class="qpc-hafs">﴿ولَئِنْ سَأَلْتَهُمْ مَن خَلَقَ السَّماواتِ والأَرْضَ لَيَقُولُنَّ اللَّهُ﴾</span> [لقمان:٢٥]، <span class="qpc-hafs">﴿واخْتِلافُ ألْسِنَتِكُمْ﴾</span> عربي وعجمي وغيره، <span class="qpc-hafs">﴿وأَلْوانِكُمْ﴾</span> أبيض وأحمر وأسود، <span class="qpc-hafs">﴿إنَّ في ذَلِكَ لَآياتٍ﴾</span> يعني: إنّ في هذا الذي ذُكِر لعبرة للعالمين في توحيد الله{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٠٥١٤<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام:</span> <span class="qpc-hafs">﴿وأَلْوانِكُمْ﴾</span> أبيض، وأحمر، وأسود{4}<span class=comment-ref>٥٠٩٩</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٥٠٩٩</span> ذكر <u>ابنُ عطية</u> (٧/١٧) في معنى: <span class="qpc-hafs">﴿وأَلْوانِكُمْ﴾</span> <b>احتمالًا</b>، فقال: «ويحتمل أن يريد: ضروب بني آدم وأنواعهم». و<span class="comment-type-4">علَّق</span> عليه بقوله: «فتَعُمُّ شخوص البشر الذين يختلفون بالألوان، وتَعُمُّ الألسنة».</div></p></div>",footnotes:1:علقه يحيى بن سلام ٢/٦٥١.علقه يحيى بن سلام ٢/٦٥٢.تفسير مقاتل بن سليمان ٣/٤١٠.تفسير يحيى بن سلام ٢/٦٥٢.
  30,23,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَمِنۡ ءَایَـٰتِهِۦ مَنَامُكُم بِٱلَّیۡلِ وَٱلنَّهَارِ وَٱبۡتِغَاۤؤُكُم مِّن فَضۡلِهِۦۤۚ إِنَّ فِی ذَ ٰ⁠لِكَ لَـَٔایَـٰتࣲ لِّقَوۡمࣲ یَسۡمَعُونَ ۝٢٣﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٠٥١٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ومِن آياتِهِ﴾</span> يعني: ومِن علامات الرب تعالى أن يُعرف توحيده بصنعه <span class="qpc-hafs">﴿مَنامُكُمْ بِاللَّيْلِ﴾</span> يعني: النوم، <span class="qpc-hafs">﴿وابْتِغاؤُكُمْ مِن فَضْلِهِ﴾</span> يعني: الرزق، <span class="qpc-hafs">﴿إنَّ في ذَلِكَ لَآياتٍ﴾</span> يعني: إنّ في هذا الذي ذُكِر لعبرة <span class="qpc-hafs">﴿لِقَوْمٍ يَسْمَعُونَ﴾</span> المواعظ فيُوَحِّدون ربهم{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٠٥١٦<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿مَنامُكُمْ بِاللَّيْلِ والنَّهارِ وابْتِغاؤُكُمْ مِن فَضْلِهِ﴾</span> من رزقه. كقوله: <span class="qpc-hafs">﴿ومِن رَحْمَتِهِ جَعَلَ لَكُمُ اللَّيْلَ والنَّهارَ لِتَسْكُنُوا فِيهِ﴾</span> في الليل، <span class="qpc-hafs">﴿ولِتَبْتَغُوا مِن فَضْلِهِ﴾</span> [القصص:٧٣] بالنهار. <span class="qpc-hafs">﴿إنَّ في ذَلِكَ لآياتٍ لِقَوْمٍ يَسْمَعُونَ﴾</span> وهم المؤمنون؛ سمعوا من الله ﷿ ما أُنِزل عليهم{2}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٣/٤١٠-٤١١.تفسير يحيى بن سلام ٢/٦٥٢.
  30,24,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَمِنۡ ءَایَـٰتِهِۦ یُرِیكُمُ ٱلۡبَرۡقَ خَوۡفࣰا وَطَمَعࣰا﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٠٥١٧<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿يُرِيكُمُ البَرْقَ خَوْفًا وطَمَعًا﴾</span>: <span class="qpc-hafs">﴿خَوْفًا﴾</span> للمسافر، يخاف أذاه ومعَرَّته، <span class="qpc-hafs">﴿وطَمَعًا﴾</span> للمقيم، يطمع في رزق الله{1}<span class=comment-ref>٥١٠٠</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٥١٠٠</span> لم يذكر <u>ابنُ جرير</u> (١٨/٤٨٠) في معنى: <span class="qpc-hafs">﴿يُرِيكُمُ البَرْقَ خَوْفًا وطَمَعًا﴾</span> سوى قول قتادة.</p><p>و<span class="comment-type-2">انتقد</span> <u>ابنُ عطية</u> (٧/١٩) قول قتادة <span class="mustanad">مستندًا إلى العموم</span> قائلًا: «ولا وجْه لهذا التخصيص ونحوه، بل الخوف والطمع لكل البشر».</div></p><p><div></p><p><p><span class="item-no">٦٠٥١٨<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ومِن آياتِهِ﴾</span> يعني: ومِن علاماته أن تعرفوا توحيد الربِّ جل جلاله بصنعه، وإن لم تروه <span class="qpc-hafs">﴿يُرِيكُمُ البَرْقَ خَوْفًا﴾</span> مِن الصواعق لمن كان بأرض، نظيرها في الرعد{2}، <span class="qpc-hafs">﴿وطَمَعًا﴾</span> في رحمته، يعني: المطر{3}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَیُنَزِّلُ مِنَ ٱلسَّمَاۤءِ مَاۤءࣰ فَیُحۡیِۦ بِهِ ٱلۡأَرۡضَ بَعۡدَ مَوۡتِهَاۤۚ إِنَّ فِی ذَ ٰ⁠لِكَ لَـَٔایَـٰتࣲ لِّقَوۡمࣲ یَعۡقِلُونَ ۝٢٤﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٠٥١٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ويُنَزِّلُ مِنَ السَّماءِ ماءً﴾</span> يعني: المطر، <span class="qpc-hafs">﴿فَيُحْيِي بِهِ﴾</span> بالمطر <span class="qpc-hafs">﴿الأَرْضَ﴾</span> بالنبات، <span class="qpc-hafs">﴿بعد موتها إنَّ في ذَلِكَ﴾</span> يعني ﷿: في هذا الذي ذُكِر <span class="qpc-hafs">﴿لَآياتٍ﴾</span> يعني: لعبرة <span class="qpc-hafs">﴿لِقَوْمٍ يَعْقِلُونَ﴾</span> عن الله؛ فيُوَحِّدونه{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٠٥٢٠<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام:</span> <span class="qpc-hafs">﴿ويُنَزِّلُ مِنَ السَّماءِ ماءً فَيُحْيِي بِهِ الأَرْضَ بَعْدَ مَوْتِها﴾</span> يحييها بالنبات بعدُ إذ كانت يابسة ليس فيها نبات <span class="qpc-hafs">﴿لِقَوْمٍ يَعْقِلُونَ﴾</span> وهم المؤمنون؛ عقلوا عن الله ما أنزل عليهم{5}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ١٨/٤٨١. وعلقه يحيى بن سلام ٢/٦٥٢.يشير إلى قوله: <span class="qpc-hafs">﴿هُوَ الَّذِي يُرِيكُمُ البَرْقَ خَوْفًا وطَمَعًا ويُنْشِئُ السَّحابَ الثِّقالَ﴾</span> [الرعد:١٢].تفسير مقاتل بن سليمان ٣/٤١١.تفسير مقاتل بن سليمان ٣/٤١١.تفسير يحيى بن سلام ٢/٦٥٢.