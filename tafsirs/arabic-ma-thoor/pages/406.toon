tafsir[9]{c,v,t}:
30,16," <q>﴿فَسُبۡحَـٰنَ ٱللَّهِ حِینَ تُمۡسُونَ وَحِینَ تُصۡبِحُونَ ۝١٧ وَلَهُ ٱلۡحَمۡدُ فِی ٱلسَّمَـٰوَ ٰ⁠تِ وَٱلۡأَرۡضِ وَعَشِیࣰّا وَحِینَ تُظۡهِرُونَ ۝١٨﴾</q> - تفسير الآية ٦٠٤٧٦- عن عبد الله بن عباس، قال: كل تسبيح في القرآن فهو صلاة{1}. (١١/٥٩١) ٦٠٤٧٧- عن عبد الله بن عباس، قال: أدنى ما يكون مِن الحين بكرةً وعَشِيًّا. ثم قرأ: <q>﴿فَسُبْحانَ اللَّهِ حِينَ تُمْسُونَ وحِينَ تُصْبِحُونَ﴾</q>{2}. (١١/٥٩١) ٦٠٤٧٨- قال عبد الله بن عباس: <q>﴿ولَهُ الحَمْدُ في السَّماواتِ والأَرْضِ وعَشِيًّا وحِينَ تُظْهِرُونَ﴾</q> يحمده أهل السموات والأرض، ويُصَلُّون له{3}. (ز) ٦٠٤٧٩- عن عبد الله بن عباس -من طريق أبي رزين- أنّه سأله نافع بن الأزرق، فقال: هل تجد الصلوات الخمس في القرآن؟ قال: نعم. فقرأ: <q>﴿فَسُبْحانَ اللَّهِ حِينَ تُمْسُونَ﴾</q> صلاة المغرب، <q>﴿وحين تُصبحُونَ﴾</q> صلاة الصبح، <q>﴿وعَشِيًّا﴾</q> صلاة العصر، <q>﴿وحين تظْهرُونَ﴾</q> صلاة الظهر. وقرأ: <q>﴿ومن بعد صَلاة العشاء﴾</q> [النور:٥٨]{4}. (١١/٥٩٢) ٦٠٤٨٠- عن عبد الله بن عباس -من طريق أبي عياض- قال: جمعت هذه الآيةُ مواقيتَ الصلاة؛ <q>﴿فَسُبْحانَ اللَّهِ حِينَ تُمْسُونَ﴾</q> قال: المغرب والعشاء، <q>﴿وحين تُصبحُونَ﴾</q> الفجر، <q>﴿وعَشِيًّا﴾</q> العصر، <q>﴿وحين تظْهرُونَ﴾</q> الظهر{5}. (١١/٥٩٢) ٦٠٤٨١- عن مجاهد بن جبر -من طريق ليث-، مثله{6}. (١١/٥٩٢) ٦٠٤٨٢- عن سعيد بن جبير -من طريق جعفر- <q>﴿وإبراهيم الذي وفى﴾</q> [النجم:٣٧]، قال: <q>﴿سبحان الله حين تمسون وحين تصبحون﴾</q> الآيةَ؛ ثلاثٌ غدوة، وثلاثٌ عشية{7}. (ز) ٦٠٤٨٣- عن الحسن البصري: أن الصلوات الخمس كلها في هذه الآية يقول: <q>﴿فَسُبْحانَ اللَّهِ حِينَ تُمْسُونَ﴾</q> المغرب والعشاء {8}. (ز) ٦٠٤٨٤- عن قتادة بن دعامة -من طريق سعيد-: <q>﴿فَسُبْحانَ اللَّهِ حِينَ تُمْسُونَ﴾</q> لصلاة المغرب، <q>﴿وحين تُصبحُونَ﴾</q> لصلاة الصبح، <q>﴿وعَشِيًّا﴾</q> لصلاة العصر، <q>﴿وحين تظْهرُونَ﴾</q> صلاة الظهر؛ أربع صلوات{9}. (ز) ٦٠٤٨٥- قال إسماعيل السُّدِّيّ: <q>﴿وحِينَ تُظْهِرُونَ﴾</q> تنشرون، وتنبسطون{8}. (ز) ٦٠٤٨٦- قال مقاتل بن سليمان: <q>﴿فَسُبْحانَ اللَّهِ﴾</q> يعني: فصلُّوا لله ﷿ <q>﴿حِينَ تُمْسُونَ﴾</q> يعني: صلاة المغرب، وصلاة العشاء، <q>﴿وحِينَ تُصْبِحُونَ﴾</q> يعني: صلاة الفجر، <q>﴿ولَهُ الحَمْدُ في السَّماواتِ والأَرْضِ﴾</q> يحمده الملائكة في السماوات، ويحمده المؤمنون في الأرض <q>﴿وعَشِيًّا﴾</q> يعني: صلاة العصر، <q>﴿وحِينَ تُظْهِرُونَ﴾</q> يعني: صلاة الأولى {11}. (ز) ٦٠٤٨٧- قال عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قول الله: <q>﴿فَسُبْحانَ اللَّهِ حِينَ تُمْسُونَ وحِينَ تُصْبِحُونَ * ولَهُ الحَمْدُ في السَّماواتِ والأَرْضِ وعَشِيًّا وحِينَ تُظْهِرُونَ﴾</q>، قال: <q>﴿حِينَ تُمْسُونَ﴾</q> صلاة المغرب، <q>﴿وحِينَ تُصْبِحُونَ﴾</q> صلاة الصبح، <q>﴿وعَشِيًّا﴾</q> صلاة العصر، <q>﴿وحِينَ تُظْهِرُونَ﴾</q> صلاة الظهر، <q>﴿ولَهُ الحَمْدُ في السَّماواتِ والأَرْضِ﴾</q> يقول: وله الحمد مِن جميع خلقه دون غيره <q>﴿في السماوات﴾</q> مِن سكانها من الملائكة، <q>﴿والأرض﴾</q> من أهلها؛ من جميع أصناف خلقه فيها، <q>﴿وعَشِيًّا﴾</q> يقول: وسبِّحوه أيضًا عشيًّا، وذلك صلاة العصر، <q>﴿وحِينَ تُظْهِرُونَ﴾</q> يقول: وحين تدخلون في وقت الظهر{12}. (ز) ٦٠٤٨٨- قال يحيى بن سلّام: كل صلاة ذُكِرت في المكيِّ مِن القرآن قبل الهجرة بسنة فهي ركعتان غدوة، وركعتان عشية، وذلك قبل أن تفرض الصلوات الخمس، وإنما افترضت الصلوات الخمس قبل أن يهاجر النبيُّ ﵇ بسنة؛ ليلة أُسْرِي به، فما كان مِن ذكر الصلاة بعد ذلك يعني: فهي الصلوات الخمس. وهذه الآية نزلت بعدما أُسْرِي بالنبي ﵇، وفُرضت عليه الصلوات الخمس{13}. (ز) <q>﴿فَسُبۡحَـٰنَ ٱللَّهِ حِینَ تُمۡسُونَ وَحِینَ تُصۡبِحُونَ ۝١٧ وَلَهُ ٱلۡحَمۡدُ فِی ٱلسَّمَـٰوَ ٰ⁠تِ وَٱلۡأَرۡضِ وَعَشِیࣰّا وَحِینَ تُظۡهِرُونَ ۝١٨﴾</q> - آثار متعلقة بالآية ٦٠٤٨٩- عن معاذ بن أنس، عن رسول الله ﷺ، قال: «ألا أخبركم لِمَ سَمّى اللهُ إبراهيمَ: خليلَه الذي وفّى؟ لأنّه كان يقول كُلَّما أصبح وأمسى: <q>﴿فَسُبْحانَ اللَّهِ حِينَ تُمْسُونَ وحِينَ تُصْبِحُونَ * ولَهُ الحَمْدُ في السَّماواتِ والأَرْضِ وعَشِيًّا وحِينَ تُظْهِرُونَ﴾</q>»{14}. (١١/٥٩٢). (ز) ",footnotes:1:عزاه السيوطي إلى ابن مردويه، والفريابي.عزاه السيوطي إلى الفريابي، وابن أبي حاتم.تفسير البغوي ٦/٢٦٤.أخرجه يحيى بن سلام ٢/٦٤٩، وعبد الرزاق (١٧٧٢)، وابن جرير ١٨/٤٧٤، وابن المنذر في الأوسط ٢/٣٢١ (٩٣٢)، والطبراني (١٠٥٩٦)، والحاكم ٢/٤١٠-٤١١. وعزاه السيوطي إلى الفريابي، وابن أبي حاتم.أخرجه ابن جرير ١٨/٤٧٤-٤٧٥، وابن المنذر ٢/٣٢٢ (٩٣٣). وعزاه السيوطي إلى ابن أبي شيبة.أخرجه ابن جرير ١٨/٤٧٥. وعزاه السيوطي إلى ابن أبي شيبة، وابن المنذر.أخرجه إسحاق البستي ص٧٧.علقه يحيى بن سلام ٢/٦٤٩.أخرجه ابن جرير ١/٤٧٥.علقه يحيى بن سلام ٢/٦٤٩.تفسير مقاتل بن سليمان ٣/٤٠٩.أخرجه ابن جرير ١٨/٤٧٥.تفسير يحيى بن سلام ٢/٦٤٩-٦٥٠.أخرجه أحمد ٢٤/٣٨٨ (١٥٦٢٤)، وابن جرير ٢/٥٠٧، ٢٢/٧٧-٧٨، والثعلبي ٩/١٥٢. قال الزيلعي في تخريج أحاديث الكشاف ٣/٣٨٤-٣٨٥ (١٢٧٢): «رواه الطبري، وابن مردويه، والثعلبي، وابن أبي حاتم في تفاسيرهم، وهو مشتمل على جماعة من الضعفاء». وقال الهيثمي في المجمع ١٠/١١٧ (١٧٠١٠): «رواه الطبراني، وفيه ضعفاء وُثِّقوا». وقال ابن حجر الفتح ٨/٦٠٥: «بإسناد ضعيف». وقال الشوكاني في فتح القدير ٤/٢٥٦: «وفي إسناده ابن لهيعة».
  30,17,""
  30,18,""
30,19," <q>﴿یُخۡرِجُ ٱلۡحَیَّ مِنَ ٱلۡمَیِّتِ وَیُخۡرِجُ ٱلۡمَیِّتَ مِنَ ٱلۡحَیِّ﴾</q> - تفسير ٦٠٤٩٠- عن عبد الله بن مسعود -من طريق إبراهيم- قال: <q>﴿يُخْرِجُ الحَيَّ مِنَ المَيِّتِ ويُخْرِجُ المَيِّتَ مِنَ الحَيِّ﴾</q> النطفة ماء الرجل ميتة، وهو حي، ويخرج الرجل منها حيًّا، وهي ميتة{1}. (ز) ٦٠٤٩١- عن عبد الله بن عباس -من طريق عطية العوفي- في قوله: <q>﴿يُخْرِجُ الحَيَّ مِنَ المَيِّتِ ويُخْرِجُ المَيِّتَ مِنَ الحَيِّ﴾</q>، قال: يخرج مِن الإنسان ماء ميتًا فيخلق منه بشرًا، فذلك الميت من الحي، ويخرج الحي من الميت، فيعني بذلك: أنه يخلق من الماء بشرًا، فذلك الحي من الميت{2}. (ز) ٦٠٤٩٢- عن مجاهد بن جبر: <q>﴿يُخْرِجُ الحَيَّ مِنَ المَيِّتِ ويُخْرِجُ المَيِّتَ مِنَ الحَيِّ﴾</q> هي النطفة الحية تخرج من النطفة الميتة الخلق الحي، ويخرج من الخلق الحي النطفة الميتة، ويخرج من الحبة اليابسة الحي، ويخرج من النبات الحي الحبة اليابسة{3}. (ز) ٦٠٤٩٣- عن الحسن البصري -من طريق قتادة- <q>﴿يُخْرِجُ الحَيَّ مِنَ المَيِّتِ ويُخْرِجُ المَيِّتَ مِنَ الحَيِّ﴾</q>: يُخرج المؤمن من الكافر، ويخرج الكافر من المؤمن{4}٥٠٩٧. (ز) ٥٠٩٧ علَّق ابنُ عطية (٧/١٦) على قول الحسن بقوله: «وروي هذا المعنى عن النبي ﷺ أنه قرأ هذه الآية عند ما كلَّمَتْه بالإسلام أم كلثوم بنت عقبة بن أبي معيط». ٦٠٤٩٤- عن إسماعيل السُّدِّيّ: <q>﴿يُخْرِجُ الحَيَّ مِنَ المَيِّتِ ويُخْرِجُ المَيِّتَ مِنَ الحَيِّ﴾</q>، يعني: يخرج النُّطَف وهي ميتة مِن الحي، ويخرج الحي -الناس الأحياء- من الميت مِن النُّطَف{5}. (ز) ٦٠٤٩٥- قال مقاتل بن سليمان: <q>﴿يُخْرِجُ الحَيَّ مِنَ المَيِّتِ﴾</q> يقول: يخرج الناس والدواب والطير من النطف وهي ميتة، <q>﴿ويُخْرِجُ المَيِّتَ﴾</q> يعني: النطف <q>﴿مِنَ الحَيِّ﴾</q> يعني: مِن الناس والدواب والطير{6}. (ز) <q>﴿وَیُحۡیِ ٱلۡأَرۡضَ بَعۡدَ مَوۡتِهَاۚ وَكَذَ ٰ⁠لِكَ تُخۡرَجُونَ ۝١٩﴾</q> - تفسير ٦٠٤٩٦- قال مقاتل بن سليمان: <q>﴿ويُحْيِ الأَرْضَ﴾</q> بالماء <q>﴿بَعْدَ مَوْتِها﴾</q> فينبت العشب، فذلك حياتها، <q>﴿وكَذَلِكَ﴾</q> يعني: وهكذا <q>﴿تُخْرَجُونَ﴾</q> يا بني آدم مِن الأرض يوم القيامة بالماء، كما يخرج العشب من الأرض بالماء؛ وذلك أنّ الله ﷿ يُرسِل يوم القيامة ماء الحيوان مِن السماء السابعة مِن البحر المسجور على الأرض بين النفختين، فتنبت عظام الخلق ولحومهم وجلودهم كما ينبت العشب من الأرض{6}. (ز) ٦٠٤٩٧- قال يحيى بن سلّام: <q>﴿ويُحْيِي الأَرْضَ بَعْدَ مَوْتِها﴾</q> يحييها بالنبات بعد أن كانت ميتة، أي: يابسة لا نبات فيها، <q>﴿وكَذَلِكَ تُخْرَجُونَ﴾</q> يعني: البعث، يُرسِلُ اللهُ -تبارك وتعالى- مطرًا منيًّا كمني الرجال، فتنبت به جسمانهم ولحمانهم، كما تُنبِتُ الأرض الثرى{8}. (ز) ",footnotes:1:أخرجه ابن جرير ١٨/٤٧٧.أخرجه ابن جرير ١٨/٤٧٦.علقه يحيى بن سلام ٢/٦٥٠.أخرجه ابن جرير ١٨/٤٧٧. وعلقه يحيى بن سلام ٢/٦٥٠.علَّقه يحيى بن سلام ٢/٦٥٠.تفسير مقاتل بن سليمان ٣/٤٠٩-٤١٠.تفسير مقاتل بن سليمان ٣/٤٠٩-٤١٠.تفسير يحيى بن سلام ٢/٦٥٠.
30,20," <q>﴿وَمِنۡ ءَایَـٰتِهِۦۤ أَنۡ خَلَقَكُم مِّن تُرَابࣲ ثُمَّ إِذَاۤ أَنتُم بَشَرࣱ تَنتَشِرُونَ ۝٢٠﴾</q> - تفسير ٦٠٤٩٨- عن قتادة بن دعامة -من طريق سعيد- <q>﴿ومن آياته أن خَلقكُم من تُراب﴾</q> قال: آدم مِن تراب، <q>﴿ثمَّ إذا أنْتُم بشر تنتشرون﴾</q>{1}. (١١/٥٩٥) ٦٠٤٩٩- عن إسماعيل السُّدِّيّ، قال: <q>﴿ومِن آياتِهِ﴾</q>، يعني: ومِن علامات الرب -تبارك وتعالى- أنّه واحد، <q>﴿تَنْتَشِرُونَ﴾</q>: تنبسطون{2}. (ز) ٦٠٥٠٠- عن عبد الملك ابن جريج، في قوله: <q>﴿ومن آياته﴾</q>، قال: كل شيء في القرآن آيات بذلك تعرفون الله، إنّكم لن تروه فتعرفونه على رؤية، ولكن تعرفونه بآياته وخلقه{3}. (١١/٥٩٥) ٦٠٥٠١- قال مقاتل بن سليمان: <q>﴿ومِن آياتِهِ﴾</q> يعني: ومِن علامات ربكم أنّه واحد ﷿، وإن لم تروه، فاعرفوا توحيده بصنعه؛ <q>﴿أنْ خَلَقَكُمْ مِن تُرابٍ﴾</q> يعني: آدم صلى الله عليه خلقه مِن طين، <q>﴿ثُمَّ إذا أنْتُمْ بَشَرٌ﴾</q> يعني: ذرية آدم بشر <q>﴿تَنْتَشِرُونَ﴾</q> في الأرض، يعني: تتبسطون في الأرض، كقوله سبحانه: <q>﴿يَنْشُر﴾</q> يعني: ويبسط <q>﴿رحمته﴾</q> [الكهف:١٦]{4}. (ز) ٦٠٥٠٢- قال يحيى بن سلّام: <q>﴿أنْ خَلَقَكُمْ مِن تُرابٍ﴾</q> يعني: الخلق الأول؛ خلق آدم، <q>﴿ثُمَّ إذا أنْتُمْ بَشَرٌ تَنْتَشِرُونَ﴾</q> في الأرض{5}. (ز) ",footnotes:1:أخرجه ابن جرير ١٨/٤٧٨. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.علَّقه يحيى بن سلام ٢/٦٥٠.عزاه السيوطي إلى ابن المنذر.تفسير مقاتل بن سليمان ٣/٤١٠.تفسير يحيى بن سلام ٢/٦٥٠-٦٥١.
30,21," <q>﴿وَمِنۡ ءَایَـٰتِهِۦۤ أَنۡ خَلَقَ لَكُم مِّنۡ أَنفُسِكُمۡ أَزۡوَ ٰ⁠جࣰا لِّتَسۡكُنُوۤا۟ إِلَیۡهَا﴾</q> - تفسير ٦٠٥٠٣- عن قتادة بن دعامة -من طريق سعيد- <q>﴿ومن آياته أن خلق لكم من أنفسكُم أزْواجًا﴾</q>، قال: حوّاء خلقها الله مِن ضِلَع مِن أضلاع آدم{1}٥٠٩٨. (١١/٥٩٥) ٥٠٩٨ علَّق ابن عطية (٧/١٧) على قول قتادة بقوله: «فحمل ذلك على جميع الناس من حيث أُمُّهم مخلوقة من نفس آدم، أي: من ذات شخصه». ٦٠٥٠٤- قال مقاتل بن سليمان: <q>﴿ومِن آياتِهِ﴾</q> يعني: علاماته أن تعرفوا توحيده، وإن لم تروه؛ <q>﴿أنْ خَلَقَ لَكُمْ مِن أنْفُسِكُمْ﴾</q> يعني: بعضكم من بعض، أزواجًا <q>﴿لتسكنوا إليها﴾</q>{2}. (ز) ٦٠٥٠٥- قال يحيى بن سلّام: <q>﴿ومِن آياتِهِ﴾</q> يعني: ومِن علامات الرب أنّه واحد، فاعرفوا توحيده في صنعه؛ <q>﴿أنْ خَلَقَ لَكُمْ مِن أنْفُسِكُمْ أزْواجًا﴾</q> يعني: أزواجكم؛ المرأة هي من الرجل{3}. (ز) <q>﴿وَجَعَلَ بَیۡنَكُم مَّوَدَّةࣰ وَرَحۡمَةًۚ إِنَّ فِی ذَ ٰ⁠لِكَ لَـَٔایَـٰتࣲ لِّقَوۡمࣲ یَتَفَكَّرُونَ ۝٢١﴾</q> - تفسير ٦٠٥٠٦- عن صفوان بن عمرو، قال: حدثني المشيخة، أنّ رجلًا أتى النبيَّ ﷺ، فقال: يا نبيَّ الله، لقد عجبتُ من أمرٍ، وإنه لَعَجب؛ إنّ الرجل ليتزوج المرأةَ وما رآها وما رأته قطُّ، حتى إذا ابتنى بها أصبحا وما شيء أحب إلى أحدهما من الآخر. فقال رسول الله ﷺ: <q>﴿وجَعَلَ بَيْنَكُمْ مَوَدَّةً ورَحْمَةً﴾</q>{4}. (ز) ٦٠٥٠٧- عن الحسن البصري، في قوله: <q>﴿وجعل بَيْنكُم مَوَدَّة﴾</q> قال: الجماع، <q>﴿ورَحْمَة﴾</q> قال: الولد{5}. (١١/٥٩٥) ٦٠٥٠٨- قال إسماعيل السُّدِّيّ: <q>﴿مَوَدَّةً﴾</q>، يعني: محبة، وهو الحب{6}. (ز) ٦٠٥٠٩- قال مقاتل بن سليمان: <q>﴿وجَعَلَ بَيْنَكُمْ﴾</q> وبين أزواجكم <q>﴿مَوَدَّةً﴾</q> يعني: الحب، <q>﴿ورَحْمَةً﴾</q> ليس بينها وبينه رَحِم، <q>﴿إنَّ في ذَلِكَ لَآياتٍ﴾</q> يعني: إنّ في هذا الذي ذُكِر لعبرة <q>﴿لِقَوْمٍ يَتَفَكَّرُونَ﴾</q> فيعتبرون في توحيد الله ﷿{2}. (ز) ٦٠٥١٠- قال يحيى بن سلّام: <q>﴿وجَعَلَ بَيْنَكُمْ مَوَدَّةً ورَحْمَةً﴾</q> يعني بالمودة: الحب، والرحمة: للولد، <q>﴿إنَّ في ذَلِكَ لآياتٍ لِقَوْمٍ يَتَفَكَّرُونَ﴾</q> فيؤمنوا، وإنّما يَتَفَكَّر المؤمنون{3}. (ز) ",footnotes:1:أخرجه ابن جرير ١٨/٤٧٨. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.تفسير مقاتل بن سليمان ٣/٤١٠.تفسير يحيى بن سلام ٢/٦٥١.أخرجه الثعلبي ٧/٢٩٩ من طريق أبي شعيب الحراني، عن يحيى بن عبد الله البابلتي، عن صفوان بن عمرو به. وهو سند فيه مجاهيل، والبابلتي ضعيف.عزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.علقه يحيى بن سلام ٢/٦٥١.تفسير مقاتل بن سليمان ٣/٤١٠.تفسير يحيى بن سلام ٢/٦٥١.
30,22," <q>﴿وَمِنۡ ءَایَـٰتِهِۦ خَلۡقُ ٱلسَّمَـٰوَ ٰ⁠تِ وَٱلۡأَرۡضِ وَٱخۡتِلَـٰفُ أَلۡسِنَتِكُمۡ وَأَلۡوَ ٰ⁠نِكُمۡۚ إِنَّ فِی ذَ ٰ⁠لِكَ لَـَٔایَـٰتࣲ لِّلۡعَـٰلِمِینَ ۝٢٢﴾</q> - تفسير ٦٠٥١١- عن الضحاك بن مزاحم -من طريق يحيى- قال: <q>﴿واخْتِلافُ ألْسِنَتِكُمْ وأَلْوانِكُمْ﴾</q> يُشْبِهُ الرجلُ الرجلَ ليس بينهما قرابةٌ إلا مِن قِبَل الأب الأكبر آدم{1}. (ز) ٦٠٥١٢- عن محمد بن السائب الكلبي: <q>﴿واخْتِلافُ ألْسِنَتِكُمْ﴾</q> للعرب كلام، ولفارس كلام، وللروم كلام، ولسائرهم مِن الناس كلام{2}. (ز) ٦٠٥١٣- قال مقاتل بن سليمان: <q>﴿ومِن آياتِهِ﴾</q> يعني: ومِن علامة الربِّ أنّه واحد، فتعرفوا توحيده بصنعه <q>﴿خَلْقُ السَّماواتِ والأَرْضِ﴾</q> وأنتم تعلمون ذلك، كقوله سبحانه: <q>﴿ولَئِنْ سَأَلْتَهُمْ مَن خَلَقَ السَّماواتِ والأَرْضَ لَيَقُولُنَّ اللَّهُ﴾</q> [لقمان:٢٥]، <q>﴿واخْتِلافُ ألْسِنَتِكُمْ﴾</q> عربي وعجمي وغيره، <q>﴿وأَلْوانِكُمْ﴾</q> أبيض وأحمر وأسود، <q>﴿إنَّ في ذَلِكَ لَآياتٍ﴾</q> يعني: إنّ في هذا الذي ذُكِر لعبرة للعالمين في توحيد الله{3}. (ز) ٦٠٥١٤- قال يحيى بن سلّام: <q>﴿وأَلْوانِكُمْ﴾</q> أبيض، وأحمر، وأسود{4}٥٠٩٩. (ز) ٥٠٩٩ ذكر ابنُ عطية (٧/١٧) في معنى: <q>﴿وأَلْوانِكُمْ﴾</q> احتمالًا، فقال: «ويحتمل أن يريد: ضروب بني آدم وأنواعهم». وعلَّق عليه بقوله: «فتَعُمُّ شخوص البشر الذين يختلفون بالألوان، وتَعُمُّ الألسنة». ",footnotes:1:علقه يحيى بن سلام ٢/٦٥١.علقه يحيى بن سلام ٢/٦٥٢.تفسير مقاتل بن سليمان ٣/٤١٠.تفسير يحيى بن سلام ٢/٦٥٢.
30,23," <q>﴿وَمِنۡ ءَایَـٰتِهِۦ مَنَامُكُم بِٱلَّیۡلِ وَٱلنَّهَارِ وَٱبۡتِغَاۤؤُكُم مِّن فَضۡلِهِۦۤۚ إِنَّ فِی ذَ ٰ⁠لِكَ لَـَٔایَـٰتࣲ لِّقَوۡمࣲ یَسۡمَعُونَ ۝٢٣﴾</q> - تفسير ٦٠٥١٥- قال مقاتل بن سليمان: <q>﴿ومِن آياتِهِ﴾</q> يعني: ومِن علامات الرب تعالى أن يُعرف توحيده بصنعه <q>﴿مَنامُكُمْ بِاللَّيْلِ﴾</q> يعني: النوم، <q>﴿وابْتِغاؤُكُمْ مِن فَضْلِهِ﴾</q> يعني: الرزق، <q>﴿إنَّ في ذَلِكَ لَآياتٍ﴾</q> يعني: إنّ في هذا الذي ذُكِر لعبرة <q>﴿لِقَوْمٍ يَسْمَعُونَ﴾</q> المواعظ فيُوَحِّدون ربهم{1}. (ز) ٦٠٥١٦- قال يحيى بن سلّام: <q>﴿مَنامُكُمْ بِاللَّيْلِ والنَّهارِ وابْتِغاؤُكُمْ مِن فَضْلِهِ﴾</q> من رزقه. كقوله: <q>﴿ومِن رَحْمَتِهِ جَعَلَ لَكُمُ اللَّيْلَ والنَّهارَ لِتَسْكُنُوا فِيهِ﴾</q> في الليل، <q>﴿ولِتَبْتَغُوا مِن فَضْلِهِ﴾</q> [القصص:٧٣] بالنهار. <q>﴿إنَّ في ذَلِكَ لآياتٍ لِقَوْمٍ يَسْمَعُونَ﴾</q> وهم المؤمنون؛ سمعوا من الله ﷿ ما أُنِزل عليهم{2}. (ز) ",footnotes:1:تفسير مقاتل بن سليمان ٣/٤١٠-٤١١.تفسير يحيى بن سلام ٢/٦٥٢.
30,24," <q>﴿وَمِنۡ ءَایَـٰتِهِۦ یُرِیكُمُ ٱلۡبَرۡقَ خَوۡفࣰا وَطَمَعࣰا﴾</q> - تفسير ٦٠٥١٧- عن قتادة بن دعامة -من طريق سعيد- <q>﴿يُرِيكُمُ البَرْقَ خَوْفًا وطَمَعًا﴾</q>: <q>﴿خَوْفًا﴾</q> للمسافر، يخاف أذاه ومعَرَّته، <q>﴿وطَمَعًا﴾</q> للمقيم، يطمع في رزق الله{1}٥١٠٠. (ز) ٥١٠٠ لم يذكر ابنُ جرير (١٨/٤٨٠) في معنى: <q>﴿يُرِيكُمُ البَرْقَ خَوْفًا وطَمَعًا﴾</q> سوى قول قتادة. وانتقد ابنُ عطية (٧/١٩) قول قتادة مستندًا إلى العموم قائلًا: «ولا وجْه لهذا التخصيص ونحوه، بل الخوف والطمع لكل البشر». ٦٠٥١٨- قال مقاتل بن سليمان: <q>﴿ومِن آياتِهِ﴾</q> يعني: ومِن علاماته أن تعرفوا توحيد الربِّ جل جلاله بصنعه، وإن لم تروه <q>﴿يُرِيكُمُ البَرْقَ خَوْفًا﴾</q> مِن الصواعق لمن كان بأرض، نظيرها في الرعد{2}، <q>﴿وطَمَعًا﴾</q> في رحمته، يعني: المطر{3}. (ز) <q>﴿وَیُنَزِّلُ مِنَ ٱلسَّمَاۤءِ مَاۤءࣰ فَیُحۡیِۦ بِهِ ٱلۡأَرۡضَ بَعۡدَ مَوۡتِهَاۤۚ إِنَّ فِی ذَ ٰ⁠لِكَ لَـَٔایَـٰتࣲ لِّقَوۡمࣲ یَعۡقِلُونَ ۝٢٤﴾</q> - تفسير ٦٠٥١٩- قال مقاتل بن سليمان: <q>﴿ويُنَزِّلُ مِنَ السَّماءِ ماءً﴾</q> يعني: المطر، <q>﴿فَيُحْيِي بِهِ﴾</q> بالمطر <q>﴿الأَرْضَ﴾</q> بالنبات، <q>﴿بعد موتها إنَّ في ذَلِكَ﴾</q> يعني ﷿: في هذا الذي ذُكِر <q>﴿لَآياتٍ﴾</q> يعني: لعبرة <q>﴿لِقَوْمٍ يَعْقِلُونَ﴾</q> عن الله؛ فيُوَحِّدونه{3}. (ز) ٦٠٥٢٠- قال يحيى بن سلّام: <q>﴿ويُنَزِّلُ مِنَ السَّماءِ ماءً فَيُحْيِي بِهِ الأَرْضَ بَعْدَ مَوْتِها﴾</q> يحييها بالنبات بعدُ إذ كانت يابسة ليس فيها نبات <q>﴿لِقَوْمٍ يَعْقِلُونَ﴾</q> وهم المؤمنون؛ عقلوا عن الله ما أنزل عليهم{5}. (ز) ",footnotes:1:أخرجه ابن جرير ١٨/٤٨١. وعلقه يحيى بن سلام ٢/٦٥٢.يشير إلى قوله: <q>﴿هُوَ الَّذِي يُرِيكُمُ البَرْقَ خَوْفًا وطَمَعًا ويُنْشِئُ السَّحابَ الثِّقالَ﴾</q> [الرعد:١٢].تفسير مقاتل بن سليمان ٣/٤١١.تفسير مقاتل بن سليمان ٣/٤١١.تفسير يحيى بن سلام ٢/٦٥٢.
