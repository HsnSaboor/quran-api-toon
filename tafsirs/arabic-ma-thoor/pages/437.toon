35,29," <q>﴿إِنَّ ٱلَّذِینَ یَتۡلُونَ كِتَـٰبَ ٱللَّهِ وَأَقَامُوا۟ ٱلصَّلَوٰةَ وَأَنفَقُوا۟ مِمَّا رَزَقۡنَـٰهُمۡ سِرࣰّا وَعَلَانِیَةࣰ یَرۡجُونَ تِجَـٰرَةࣰ لَّن تَبُورَ ۝٢٩﴾</q> - نزول الآية ٦٤٠٥٧- عن عبد الله بن عباس: أنّ حصين بن الحارث بن عبد المطلب بن عبد مناف القرشي نزلت فيه: <q>﴿إنَّ الَّذِينَ يَتْلُونَ كِتابَ اللَّهِ وأَقامُوا الصَّلاةَ﴾</q> الآية{1}. (١٢/٢٨٣) <q>﴿إِنَّ ٱلَّذِینَ یَتۡلُونَ كِتَـٰبَ ٱللَّهِ وَأَقَامُوا۟ ٱلصَّلَوٰةَ وَأَنفَقُوا۟ مِمَّا رَزَقۡنَـٰهُمۡ سِرࣰّا وَعَلَانِیَةࣰ یَرۡجُونَ تِجَـٰرَةࣰ لَّن تَبُورَ ۝٢٩﴾</q> - تفسير الآية ٦٤٠٥٨- عن قتادة بن دعامة، في قوله: <q>﴿يَرْجُونَ تِجارَةً﴾</q> قال: الجنة <q>﴿لَنْ تَبُورَ﴾</q> لا تبيد{2}. (١٢/٢٨٤) ٦٤٠٥٩- عن إسماعيل السُّدِّيّ، في قوله: <q>﴿يَرْجُونَ تِجارَةً لَنْ تَبُورَ﴾</q>، قال: لن تهلك{3}. (١٢/٢٨٤) ٦٤٠٦٠- قال مقاتل بن سليمان: <q>﴿إنَّ الَّذِينَ يَتْلُونَ كِتابَ اللَّهِ وأَقامُوا الصَّلاةَ﴾</q> في مواقيتها، <q>﴿وأَنْفَقُوا مِمّا رَزَقْناهُمْ﴾</q> من الأموال، <q>﴿سِرًّا وعَلانِيَةً يَرْجُونَ تِجارَةً لَنْ تَبُورَ﴾</q> لن تهلك، هؤلاء قوم مِن المؤمنين أثنى الله -جلَّ وعَزَّ- عليهم{4}. (ز) ٦٤٠٦١- قال يحيى بن سلّام: <q>﴿إنَّ الَّذِينَ يَتْلُونَ كِتابَ اللَّهِ وأَقامُوا الصَّلاةَ﴾</q> المفروضة، <q>﴿وأَنْفَقُوا مِمّا رَزَقْناهُمْ سِرًّا وعَلانِيَةً﴾</q> السر: التطوع. والعلانية: الزكاة المفروضة. يُستحب أن تعطى الزكاة المفروضة علانية والتطوع سِرًّا. ويقال: صدقة السر تطوعًا أفضل من صدقة العلانية. عن ابن مسعود -من طريق مرة الهمداني- قال: إنّ فضل صلاة الليل على صلاة النهار كفضل صدقة السر على العلانية. <q>﴿يَرْجُونَ تِجارَةً لَنْ تَبُورَ﴾</q> لن تفسد، وهي تجارة الجنة، يعملون للجنة{5}. (ز) <q>﴿إِنَّ ٱلَّذِینَ یَتۡلُونَ كِتَـٰبَ ٱللَّهِ وَأَقَامُوا۟ ٱلصَّلَوٰةَ وَأَنفَقُوا۟ مِمَّا رَزَقۡنَـٰهُمۡ سِرࣰّا وَعَلَانِیَةࣰ یَرۡجُونَ تِجَـٰرَةࣰ لَّن تَبُورَ ۝٢٩﴾</q> - آثار متعلقة بالآية ٦٤٠٦٢- كان مُطَرِّف بن عبد الله -من طريق قتادة- يقول في قوله: <q>﴿إنَّ الَّذِينَ يَتْلُونَ كِتابَ اللَّهِ وأَقامُوا الصَّلاةَ﴾</q>: هذه آية القُرّاء{6}. (١٢/٢٨٤) ",footnotes:1:أخرجه عبد الغني بن سعيد الثقفي في تفسيره -كما في الإصابة لابن حجر ٢/٧٣ في ترجمة حصين بن الحارث (١٧٣٦)-.عزاه السيوطي إلى عبد بن حميد، وابن جرير، وابن أبي حاتم.عزاه السيوطي إلى ابن أبي حاتم.تفسير مقاتل بن سليمان ٣/٥٥٧.تفسير يحيى بن سلام ٢/٧٨٦.أخرجه ابن أبي شيبة ١٣/٤٧٦-٤٧٧، ومحمد بن نصر (٧٣)، وابن جرير ١٩/٣٦٦ من طريق قتادة ويزيد. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.
35,30," <q>﴿لِیُوَفِّیَهُمۡ أُجُورَهُمۡ وَیَزِیدَهُم مِّن فَضۡلِهِۦۤۚ﴾</q> - تفسير ٦٤٠٦٣- عن شقيق، عن عبد الله، قال: قال رسول الله ﷺ: <q>﴿ليوفيهم أجورهم ويزيدهم من فضله﴾</q>، قال: «<q>﴿أجورهم﴾</q> يدخلهم الجنة، <q>﴿ويزيدهم من فضله﴾</q> الشفاعة لِمَن وجبت له النار مِمَّن صنع إليهم المعروفَ في الدنيا»{1}. (ز) ٦٤٠٦٤- قال عبد الله بن عباس: <q>﴿ويَزِيدَهُمْ مِن فَضْلِهِ﴾</q>، يعني: سوى الثواب مِمّا لم ترَ عين، ولم تسمع أذن{2}. (ز) ٦٤٠٦٥- قال الحسن البصري: <q>﴿ويَزِيدَهُمْ مِن فَضْلِهِ﴾</q> تضاعف لهم الحسنات، يُثابُون عليها في الجنة{3}٥٣٧٩. (ز) ٥٣٧٩ نقل ابنُ عطية (٧/٢١٨) عن فرقة في معنى قوله تعالى: <q>﴿ويَزِيدَهُمْ مِن فَضْلِهِ﴾</q> أنه: تضعيف الحسنات من العشر إلى السبعمائة، ثم وجَّهه بقوله: «وتوفية الأجور -على هذا- هي المجازاة مقابلة». ٦٤٠٦٦- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿لِيُوَفِّيَهُمْ أُجُورَهُمْ ويَزِيدَهُمْ مِن فَضْلِهِ﴾</q>، قال: هو كقوله: <q>﴿ولَدَيْنا مَزِيدٌ﴾</q> [ق:٣٥]{4}. (١٢/٢٨٤) ٦٤٠٦٧- قال مقاتل بن سليمان: <q>﴿لِيُوَفِّيَهُمْ أُجُورَهُمْ﴾</q> ليوفّر لهم أعمالهم، <q>﴿ويَزِيدَهُمْ﴾</q> على أعمالهم مِن الجنة <q>﴿مِن فَضْلِهِ﴾</q>{5}. (ز) ٦٤٠٦٨- قال يحيى بن سلّام: <q>﴿لِيُوَفِّيَهُمْ أُجُورَهُمْ﴾</q> ثوابهم في الجنة، <q>﴿ويَزِيدَهُمْ مِن فَضْلِهِ﴾</q> يضاعف لهم الثواب{6}. (ز) <q>﴿إِنَّهُۥ غَفُورࣱ شَكُورࣱ ۝٣٠﴾</q> - تفسير ٦٤٠٦٩- قال عبد الله بن عباس: <q>﴿إنَّهُ غَفُورٌ شَكُورٌ﴾</q> يغفر العظيم مِن ذنوبهم، ويشكر اليسير من أعمالهم{2}. (ز) ٦٤٠٧٠- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿إنَّهُ غَفُورٌ﴾</q> قال: لذنوبهم، <q>﴿شَكُورٌ﴾</q> قال: لحسناتهم{8}. (١٢/٢٨٤) ٦٤٠٧١- قال مقاتل بن سليمان: <q>﴿إنَّهُ غَفُورٌ﴾</q> للذنوب العظام، <q>﴿شَكُورٌ﴾</q> لحسناتهم{5}. (ز) ",footnotes:1:أخرجه ابن أبي عاصم في السنة ٢/٤٠٨ (٨٤٦)، والطبراني في الأوسط ٦/٥٣ (٥٧٧٠)، وابن مردويه -كما في تفسير ابن كثير ٢/٤٨٠-٤٨١-، من طريق بقية، عن إسماعيل بن عبد الله الكندي، عن الأعمش، عن شقيق، عن عبد الله به. قال الطبراني: «لم يرو هذا الحديثَ عن الأعمش إلا إسماعيلُ الكندي، تفرَّد به بقية». وقال ابن كثير: «هذا إسناد لا يثبت، وإذا رُوِي عن ابن مسعود موقوفًا فهو جيد». وقال الهيثمي في المجمع ٧/١٣ (١٠٩٦٠): «فيه إسماعيل بن عبد الله الكندي، ضعَّفه الذهبيُّ مِن عند نفسه، فقال: أتى بخبر منكر. وبقية رجاله وثقوا». وقال السيوطي في الإتقان في علوم القرآن ٤/٢٥٢: «سند ضعيف».تفسير البغوي ٦/٤٢٠.علقه يحيى بن سلام ٢/٧٨٧.عزاه السيوطي إلى عبد بن حميد، وابن جرير، وابن أبي حاتم.تفسير مقاتل بن سليمان ٣/٥٥٧.تفسير يحيى بن سلام ٢/٧٨٧.تفسير البغوي ٦/٤٢٠.أخرجه ابن جرير ١٩/٣٦٦. وعزاه السيوطي إلى عبد بن حميد، وابن أبي حاتم.تفسير مقاتل بن سليمان ٣/٥٥٧.
