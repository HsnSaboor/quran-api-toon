quran[8]{c,v,t}:
  10,26,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿لِّلَّذِینَ أَحۡسَنُوا۟ ٱلۡحُسۡنَىٰ وَزِیَادَةࣱۖ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٤٣٩٧<span class="dash">-</span></span> عن صهيب، أنّ رسول الله ﷺ تلا هذه الآية: <span class="qpc-hafs">﴿لِلَّذِينَ أحْسَنُوا الحُسْنى وزِيادَةٌ﴾</span>. قال: «<b>إذا دَخَل أهلُ الجنةِ الجنةَ وأهلُ الناِر النارَ نادى مُنادٍ: يا أهلَ الجنةِ، إنّ لكم عندَ الله موعِدًا يريدُ أن يُنجِزَكُمُوه، فيقولون: وما هو؟ ألَمْ يُثَقِّلْ موازينَنا، ويُبيِّضْ وجوهَنا، ويُدْخِلْنا الجنةَ، ويزحْزِحْنا عن النار؟! قال: فيُكْشَفُ لهم الحجابُ، فينظُرون إليه، فواللهِ، ما أعطاهم اللهُ شيئًا أحبَّ إليهم مِن النَّظَر إليه، ولا أقرَّ لِأَعْيُنِهم</b>»{1}. (٧/٦٥٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤٣٩٨<span class="dash">-</span></span> عن صهيب، في الآية، قال: قال رسول الله ﷺ: «<b>الزيادةُ: النَّظَرُ إلى وجْهِ اللهِ</b>»{2}. (٧/٦٥٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤٣٩٩<span class="dash">-</span></span> عن أبي موسى الأشعريِّ، عن رسول الله ﷺ: «<b>إنّ الله يبعَثُ يومَ القيامةِ مُنادِيًا يُنادِي: يا أهلَ الجنةِ -بصوتٍ يَسمعُه أوَّلُهم وآخرُهم-، إنّ الله وعَدكم الحسنى وزيادةً. فالحسنى: الجنةُ، والزيادةُ: النظرُ إلى وجْهِ الرحمنِ</b>»{3}. (٧/٦٥٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤٤٠٠<span class="dash">-</span></span> عن كَعْب بن عُجْرَةَ، عن النبيِّ ﷺ، في قوله: <span class="qpc-hafs">﴿لِلَّذِينَ أحْسَنُوا الحُسْنى وزِيادَةٌ﴾</span>، قال: «<b>الزِّيادةُ: النظرُ إلى وجْهِ الرحمنِ</b>»{4}. (٧/٦٥٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤٤٠١<span class="dash">-</span></span> عن أُبَيِّ بن كَعْبٍ، أنّه سأل رسول الله ﷺ عن قول الله تعالى: <span class="qpc-hafs">﴿لِلَّذِينَ أحْسَنُوا الحُسْنى وزِيادَةٌ﴾</span>. قال: «<b>الذين أحسَنُوا: أهلُ التوحيدِ. والحُسْنى: الجنَّةُ. والزيادة: النَّظَرُ إلى وجْهِ الله</b>»{5}.  (٧/٦٥٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤٤٠٢<span class="dash">-</span></span> عن ابن عمر، عن رسول الله ﷺ، في قوله: <span class="qpc-hafs">﴿لِلَّذِينَ أحْسَنُوا الحُسْنى وزِيادَةٌ﴾</span>، قال: «<b><span class="qpc-hafs">﴿أحسَنوا﴾</span>: شهادةُ أن لا إله إلا الله. و<span class="qpc-hafs">﴿الحسنى﴾</span>: الجنةُ. و<span class="qpc-hafs">﴿زيادةٌ﴾</span>: النظر إلى الله</b>»{6}. (٧/٦٥٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤٤٠٣<span class="dash">-</span></span> عن أنس، أنّ النبيَّ ﷺ سُئِل عن هذه الآية: <span class="qpc-hafs">﴿لِلَّذِينَ أحْسَنُوا الحُسْنى وزِيادَةٌ﴾</span>. فقال: «<b>للذين أحسنوا العملَ في الدنيا لهم الحسنى، وهي الجنةُ، والزيادةُ: النظرُ إلى وجْهِ الله الكريم</b>»{7}. (٧/٦٥٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤٤٠٤<span class="dash">-</span></span> عن أنس، قال: قال رسول الله ﷺ: <span class="qpc-hafs">﴿لِلَّذِينَ أحْسَنُوا الحُسْنى وزِيادَةٌ﴾</span>، قال: «<b>ينظرون إلى ربهم بلا كَيْفِيَّةٍ، ولا حَدٍّ مَحدودٍ، ولا صِفَةٍ معلومةٍ</b>»{8}. (٧/٦٥٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤٤٠٥<span class="dash">-</span></span> عن أبي هريرة، قال: قال رسول الله ﷺ: «<b>مَن كبَّر على سِيفِ البحرِ</b>{9} <b>تكبيرةً رافِعًا بها صوتَه لا يلْتمِسُ بها رياءً ولا سُمْعَةً؛ كَتَبَ الله له رِضوانَه الأكبرَ، ومَن كتب له رِضوانَه الأكبرَ جمَع بينَه وبين محمدٍ وإبراهيمَ في دارِه، ينظرون إلى ربِّهم في جَنَّةِ عَدْنٍ، كما يَنظرُ أهلُ الدنيا إلى الشمسِ والقمرِ في يومٍ لا غَيمَ فيه ولا سحابَ، وذلك قوله: <span class="qpc-hafs">﴿لِلَّذِينَ أحْسَنُوا الحُسْنى وزِيادَةٌ﴾</span>. فالحُسنى: لا إله إلا الله. والزِّيادةُ: الجنَّةُ، والنَّظَرُ إلى الرَّبِّ</b>»{10}. (٧/٦٥٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤٤٠٦<span class="dash">-</span></span> عن <span class="name-1">أبي بكر الصديق</span> -من طريق عامِر بن سعد- في قوله: <span class="qpc-hafs">﴿لِلَّذِينَ أحْسَنُوا الحُسْنى وزِيادَةٌ﴾</span>، قال: الحُسْنى: الجَنَّةُ. والزِّيادةُ: النَّظَرُ إلى وجهِ اللهِ{11}. (٧/٦٥٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤٤٠٧<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن مسعود</span> -من طريق مُرَّة- في الآية، قال: أمّا الحسنى: فالجنَّةُ. وأما الزِّيادةُ: فالنظرُ إلى وجه الله. وأمّا القَتَرُ: فالسَّوادُ{12}. (٧/٦٥٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤٤٠٨<span class="dash">-</span></span> عن <span class="name-1">حذيفةَ بن اليمان</span> -من طريق مسلم بن نذير- في الآية، قال: والزِّيادةُ: النَّظَرُ إلى وجهِ الله{13}. (٧/٦٥٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤٤٠٩<span class="dash">-</span></span> عن <span class="name-1">علي بن أبي طالب</span> -من طريق الحارث- في قوله: <span class="qpc-hafs">﴿لِلَّذِينَ أحْسَنُوا الحُسْنى﴾</span> قال: يعني: الجنةَ، <span class="qpc-hafs">﴿وزِيادَةٌ﴾</span> يعني: النظرَ إلى الله{8}. (٧/٦٥٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤٤١٠<span class="dash">-</span></span> عن <span class="name-1">علي بن أبي طالب</span> -من طريق الحكم بن عتيبة- في الآيةِ، قال: الزيادةُ: غُرْفةٌ مِن لؤلؤةٍ واحدةٍ، لها أربعةُ أبوابٍ، غُرَفُها وأبْوابُها مِن لؤلؤةٍ واحدةٍ{15}. (٧/٦٥٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤٤١١<span class="dash">-</span></span> عن <span class="name-1">أبي موسى الأشعريِّ</span> -من طريق أبي تميمة- في الآية، قال: الحسنى: الجنةُ. والزِّيادةُ: النظرُ إلى وجهِ ربِّهم{16}<span class=comment-ref>٣١١٠</span>. (٧/٦٥٦)</p></p><p></div></p><p><div><span class=comment-ref>٣١١٠</span> <span class="comment-type-4">علَّق</span> <u>ابنُ عطية</u> (٤/٤٧٣) على هذا القول بقوله: «وروي في ذلك حديث عن النبي ﷺ، رواه صهيب».</div></p><p><div></p><p><p><span class="item-no">٣٤٤١٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عكرمة- <span class="qpc-hafs">﴿لِلَّذِينَ أحْسَنُوا﴾</span>، قال: قول: لا إله إلا الله. والحسنى: الجَنَّةُ. والزِّيادةُ: النظرُ إلى وجهِه الكريم{17}. (٧/٦٥٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤٤١٣<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- <span class="qpc-hafs">﴿لِلَّذِينَ أحْسَنُوا﴾</span>، قال: للذين شهِدوا أن لا إله إلا الله <span class="qpc-hafs">﴿الحُسْنى﴾</span>: الجنَّةُ{18}. (٧/٦٥٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤٤١٤<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطية العوفي- في قوله: <span class="qpc-hafs">﴿لِلَّذِينَ أحْسَنُوا الحُسْنى وزِيادَةٌ﴾</span>، قال: هو مِثْلُ قوله: <span class="qpc-hafs">﴿ولَدَينا مَزِيدٌ﴾</span> [ق:٣٥]. يقول: يَجزِيهم بعملِهم ويزيدُهم من فضِله. وقال: <span class="qpc-hafs">﴿مَن جَآءَ بِالحَسَنَةِ فَلَهُ عَشْرُ أمْثالِها﴾</span> [الأنعام:١٦٠]{19}<span class=comment-ref>٣١١١</span>. (٧/٦٥٨)</p></p><p></div></p><p><div><span class=comment-ref>٣١١١</span> <span class="comment-type-4">علَّق</span> <u>ابنُ عطية</u> (٤/٤٧٣-٤٧٤) على هذا القول الذي قاله عبد الله بن عباس من طريق العوفي، وعلقمة، والحسن من طريق قتادة، فقال: «وهذا قولٌ <span class="mustanad">يعضده النظر</span>، ولولا <span class="mustanad">عظم القائلين بالقول الأول</span> لَتَرَجَّح هذا القول، وطريق ترجيحه أنّ الآيةَ تتضمن اقتِرانًا بين ذِكْرِ عمال الحسنات وعمال السيئات، فوصف المحسنين بأنّ لهم على إحسانهم حُسْنى وزيادة من جنسها، ووصف المسيئين بأن لهم بالسيئة مثلها، فتعادل الكلامان. وعبَّر عن الحسنات بالحسنى مبالغة؛ إذ هي عشرة».</div></p><p><div></p><p><p><span class="item-no">٣٤٤١٥<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق الضَّحّاك- في قوله: <span class="qpc-hafs">﴿للذين أحسنوا الحسنى﴾</span>، قال: الحسنى مثلها{20}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤٤١٦<span class="dash">-</span></span> عن <span class="name-2">يزيد بن شَجَرَةَ</span> -من طريق منصور بن عمّار- قال: الزِّيادة: هي أن تَمُرَّ السَّحابة بأهل الجنة، فتمطرهم مِن كُلِّ النوادر، وتقول لهم: ما تريدون أن أُمْطِرَكم؟ فلا يريدون شيئًا إلا مَطَرَتْهُم{21}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤٤١٧<span class="dash">-</span></span> عن <span class="name-2">علقمة بن قيس النخعي</span> -من طريق قابوس، عن أبيه- في الآيةِ، قال: الزِّيادةُ: العَشْرُ؛ <span class="qpc-hafs">﴿مَن جَآءَ بِالحَسَنَةِ فَلَهُ عَشْرُ أمْثالِها﴾</span>{22}. (٧/٦٥٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤٤١٨<span class="dash">-</span></span> عن <span class="name-2">عبد الرحمن بن أبي ليلى</span> -من طريق ثابت- في قوله: <span class="qpc-hafs">﴿لِلَّذِينَ أحْسَنُوا الحُسْنى وزِيادَةٌ﴾</span>، قال: إذا دخل أهلُ الجنةِ الجنةَ أُعطُوا منها ما شاءوا، ثم يُقالُ لهم: إنّه قد بَقِي مِن حَقِّكم شيءٌ لم تُعطَوْه. فيتجلّى اللهُ لهم، فيَصْغُرُ ما أُعطُوا عند ذلك. ثم تلا: <span class="qpc-hafs">﴿لِلَّذِينَ أحْسَنُوا الحُسْنى﴾</span> قال: الجنة، <span class="qpc-hafs">﴿وزِيادَةٌ﴾</span> قال: نظرُهم إلى ربِّهم ﷿{23}. (٧/٦٥٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤٤١٩<span class="dash">-</span></span> عن <span class="name-2">سعيد بن المسيب</span> -من طريق يحيى بن سعيد- في قول الله تعالى: <span class="qpc-hafs">﴿للذين أحسنوا﴾</span>، قال: أحسنوا عبادةَ ربِّهم{20}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤٤٢٠<span class="dash">-</span></span> عن <span class="name-2">سعيد بن المسيب</span> -من طريق يحيى- في قوله: <span class="qpc-hafs">﴿لِلَّذِينَ أحْسَنُوا الحُسْنى وزِيادَةٌ﴾</span>، قال: <span class="qpc-hafs">﴿أحْسَنُوا﴾</span>: شهادة أن لا إله إلا الله. و<span class="qpc-hafs">﴿الحُسْنى﴾</span>: الجنَّة. والزيادة: النَّظَر إلى وجه الله{25}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤٤٢١<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿لِلَّذِينَ أحْسَنُوا الحُسْنى﴾</span> قال: مثلُها، قال: <span class="qpc-hafs">﴿وزِيادَةٌ﴾</span> قال: مغفِرةٌ، ورِضوانٌ{26}. (٧/٦٥٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤٤٢٢<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤٤٢٣<span class="dash">-</span></span> و<span class="name-2">أبي سنان</span>: أنّ الزِّيادة: النَّظَر إلى وجْه الله ﷿{27}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤٤٢٤<span class="dash">-</span></span> عن <span class="name-2">الضحاك بن مزاحم</span>: أنّ الحسنى: الجنةُ{28}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤٤٢٥<span class="dash">-</span></span> عن <span class="name-2">الضحاك بن مُزاحِم</span>، قال: الزِّيادةُ: النَّظَرُ إلى وجهِ الله{29}. (٧/٦٥٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤٤٢٦<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span> -من طريق الحكم بن أبان- في قوله: <span class="qpc-hafs">﴿لِلَّذِينَ أحْسَنُوا الحُسْنى وزِيادَةٌ﴾</span>، قال: قوله: <span class="qpc-hafs">﴿أحْسَنُوا الحُسْنى﴾</span>: قول لا إله إلا الله. و<span class="qpc-hafs">﴿الحُسْنى﴾</span>: الجنة. والزيادة: النظر إلى وجهه الكريم{30}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤٤٢٧<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق قتادة- في الآية، قال: الزِّيادةُ: الحسنةُ بعشرِ أمثالِها إلى سبعِمائةِ ضِعْفٍ{31}. (٧/٦٥٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤٤٢٨<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق أبي بشر الحلبي- <span class="qpc-hafs">﴿لِلَّذِينَ أحْسَنُوا الحُسْنى وزِيادَةٌ﴾</span>، قال: الحسنى: دخول الجنة. والزيادة: النظر إلى وجه الله{32}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤٤٢٩<span class="dash">-</span></span> عن <span class="name-2">أبي الجوزاء</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤٤٣٠<span class="dash">-</span></span> و<span class="name-2">عطاء</span>، نحو ذلك{33}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤٤٣١<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دِعامة</span>، <span class="qpc-hafs">﴿لِلَّذِينَ أحْسَنُوا﴾</span> قال: شهادةُ أن لا إله إلا الله. <span class="qpc-hafs">﴿الحُسْنى﴾</span> قال: الجنةُ. <span class="qpc-hafs">﴿وزِيادَةٌ﴾</span> قال: النظرُ إلى وجْهِ اللهِ{34}. (٧/٦٥٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤٤٣٢<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- قال: يُنادِي المنُادِي يومَ القيامةِ: إنّ اللهَ وعَدَ الحسنى، وهي الجَنَّةُ، فأما الزِّيادةُ: فهي النَّظرُ إلى وجهِ الرحمنِ. قال: فيتجلّى لهم حتى ينظُروا إليه{35}. (٧/٦٥٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤٤٣٣<span class="dash">-</span></span> عن <span class="name-2">عبد الرحمن بن عبد الله بن سابط الجمحي</span> -من طريق ليث- في قوله: <span class="qpc-hafs">﴿للذين أحسنوا الحسنى﴾</span>، قال: الحسنى: النَّضْرَة. والزِّيادةُ: النظرُ إلى وجهِ الله تعالى{36}. (٧/٦٥٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤٤٣٤<span class="dash">-</span></span> عن <span class="name-2">عامر بن سعد البَجَليِّ</span> -من طريق أبي إسحاق- في قوله: <span class="qpc-hafs">﴿لِلَّذِينَ أحْسَنُوا الحُسْنى وزِيادَةٌ﴾</span>، قال: النَّظَرُ إلى وجهِ الله{37}. (٧/٦٥٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤٤٣٥<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span>، في قوله: <span class="qpc-hafs">﴿لِلَّذِينَ أحْسَنُوا الحُسْنى﴾</span> قال: الجنَّةُ. <span class="qpc-hafs">﴿وزِيادَةٌ﴾</span> قال: النَّظرُ إلى وجهِ الربِّ ﷿{29}. (٧/٦٥٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤٤٣٦<span class="dash">-</span></span> عن <span class="name-2">أبي إسحاقَ السَّبيعيّ</span> -من طريق شريك- في قوله: <span class="qpc-hafs">﴿لِلَّذِينَ أحْسَنُوا الحُسْنى﴾</span> قال: الجَنَّةُ. <span class="qpc-hafs">﴿وزِيادَةٌ﴾</span> قال: النَّظَرُ إلى وجهِ الرحمنِ ﷿{39}. (٧/٦٥٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤٤٣٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿لِلَّذِينَ أحْسَنُواْ﴾</span> يعني: وحَّدوا الله <span class="qpc-hafs">﴿الحُسْنى﴾</span> يعني: الجنَّة، <span class="qpc-hafs">﴿وزِيادَةٌ﴾</span> يعني: فضل على الجنة؛ النَّظرُ إلى وجه الله الكريم{40}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤٤٣٨<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في الآية، قال: الزِّيادةُ: ما أعطاهم في الدنيا، لا يُحاسِبُهم به يومَ القيامةِ{41}. (٧/٦٥٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤٤٣٩<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق أصْبَغ بن الفَرَج- في قول الله: <span class="qpc-hafs">﴿للذين أحسنوا الحسنى﴾</span>، قال: الحسنى: الجَنَّة{20}<span class=comment-ref>٣١١٢</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٣١١٢</span> أفادت الآثارُ الاختلافَ في تفسير قوله: <span class="qpc-hafs">﴿الحُسْنى وزِيادَةٌ﴾</span> على أقوال: <b>أحدها</b>: أنّ الحسنى: الجنة. والزيادة: النَّظَر إلى وجه الله تعالى. <b>والثاني</b>: أنّ الحسنى: واحدة من الحسنات. والزيادة: مضاعفتها إلى عشر أمثالها. <b>الثالث</b>: أنّ الحسنى: حسنة مثل حسنة. والزيادة: مغفرة ورضوان. <b>والرابع</b>: أنّ الحسنى: الجزاء في الآخرة. والزيادة: ما أُعْطُوا في الدنيا.</p><p>و<span class="comment-type-3">رجَّح</span> <u>ابنُ جرير</u> (١٢/١٦٤-١٦٥) جميعَ تلك المعاني <span class="mustanad">استنادًا إلى العموم</span>، فقال: «وأَوْلى الأقوال في ذلك بالصواب أن يُقال: إنّ الله -تبارك وتعالى- وعد المحسنين من عباده على إحسانهم الحسنى أن يجزيهم على طاعتهم إيّاه الجنةَ، وأن تبْيَضَّ وجوهُهم، ووعدهم مع الحسنى الزيادةَ عليها، ومِن الزيادة على إدخالهم الجنة أن يكرمهم بالنظر إليه، وأن يعطيهم غُرَفًا من لآلئ، وأن يزيدهم غفرانًا ورضوانًا؛ كل ذلك مِن زيادات عطاءِ الله إيّاهم على الحسنى التي جعلها الله لأهل جناته. وعمَّ ربُّنا -جلَّ ثناؤه- بقوله: <span class="qpc-hafs">﴿وزيادة﴾</span> الزيادات على الحسنى، فلم يُخَصِّص منها شيئًا دون شيء، وغير مستنكر من فضل الله أن يجمع ذلك لهم، بل ذلك كله مجموع لهم -إن شاء الله-. فأولى الأقوال في ذلك بالصواب أن يُعمّ كما عَمَّه -عزَّ ذِكْرُه-».</p><p>و<span class="comment-type-4">بنحوه</span> قال <u>ابنُ كثير</u> (٧/٣٥٤).</p><p>و<span class="comment-type-4">علَّق</span> <u>ابنُ عطية</u> (٤/٤٧٤) على ترجيح <u>ابن جرير</u> للعموم بقوله: «ويُؤَيِّد ذلك أيضًا قولُه: <span class="qpc-hafs">﴿أُولئِكَ أصْحابُ الجَنَّةِ﴾</span>».</p><p>و<span class="comment-type-3">رجَّح</span> <u>ابنُ عطية</u> (٤/٤٧٣) القول الأول <span class="mustanad">استنادًا إلى أقوال السلف</span>.</p><p>وكذا <span class="comment-type-3">رجَّحه</span> <u>ابنُ القيم</u> (٢/٣٥) <span class="mustanad">استنادًا إلى السُّنَّة، وأقوال السلف</span>، وذكر أنّ مَن فَسَّر الزيادة بالمغفرة والرضوان فهو من لوازم رؤيته -تبارك وتعالى-.</p><p>وأورد <u>ابنُ عطية</u> (٤/٤٧٤) إشكالًا على القول الأول؛ بأنّه لو كان معنى الحسنى: الجُنَّة، لكان في القول تكرير بالمعنى، وأجاب عنه بقوله: «على أنّ هذا ينفصل عنه بأنّه وصف المحسنين بأنّ لهم الجنة، وأنّهم لا يرهق وجوهَهم قترٌ ولا ذِلَّة، ثم قال: <span class="qpc-hafs">﴿أُولئِكَ أصْحابُ الجَنَّةِ﴾</span> على جهة المدح لهم، أي: أولئك مُسْتَحِقُّوها وأصحابها حقًّا وباستيجاب».</div></p><p><h3><span class="qpc-hafs">﴿وَلَا یَرۡهَقُ وُجُوهَهُمۡ قَتَرࣱ وَلَا ذِلَّةٌۚ أُو۟لَـٰۤىِٕكَ أَصۡحَـٰبُ ٱلۡجَنَّةِۖ هُمۡ فِیهَا خَـٰلِدُونَ ۝٢٦﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٤٤٤٠<span class="dash">-</span></span> عن صهيبٍ، عن النبيِّ ﷺ، <span class="qpc-hafs">﴿ولا يَرهَقُ وُجُوهَهُم قَتَرٌ ولا ذِلَّةٌ﴾</span>، قال: «<b>بعدَ نظرِهم إليه ﷿</b>»{43}. (٧/٦٥٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤٤٤١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطاء الخراساني- في قوله: <span class="qpc-hafs">﴿ولا يَرهَقُ وُجُوهَهُم﴾</span> قال: لا يغشاهم <span class="qpc-hafs">﴿قَتَرٌ﴾</span> قال: سَوادُ الوُجُوهِ{44}. (٧/٦٥٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤٤٤٢<span class="dash">-</span></span> عن <span class="name-2">عبد الرحمن بن أبي ليلى</span> -من طريق ثابت- في قوله: <span class="qpc-hafs">﴿ولا يَرهَقُ وُجُوهَهُم قَتَرٌ ولا ذِلَّةٌ﴾</span>، قال: بعدَ نظرِهم إلى ربِّهم{45}. (٧/٦٦٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤٤٤٣<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نَجِيح- في قوله: <span class="qpc-hafs">﴿ولا يَرهَقُ وُجُوهَهُم قتر﴾</span>، قال: خِزْيٌ{46}. (٧/٦٥٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤٤٤٤<span class="dash">-</span></span> عن <span class="name-2">عطاء</span>، في الآية، قال: القَتَرُ: سَوادُ الوَجْهِ{34}. (٧/٦٥٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤٤٤٥<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span>، نحو ذلك{48}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤٤٤٦<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span>: <span class="qpc-hafs">﴿ولا ذِلَّةٌ﴾</span>: كآبَة{49}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤٤٤٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ولا يَرْهَقُ وُجُوهَهُمْ قَتَرٌ﴾</span> يعني: ولا يُصِيب وجوهَهم قَتَرٌ، يعني: سواد، ويُقال: كُسوف، ويقال: هو السواد، <span class="qpc-hafs">﴿ولا ذِلَّةٌ﴾</span> يعني: ولا مَذَلَّة في أبدانهم عند مُعايَنَةِ النار، <span class="qpc-hafs">﴿أُولئِكَ﴾</span> الذين هم بهذه المنزلة <span class="qpc-hafs">﴿أصْحابُ الجَنَّةِ هُمْ فِيها خالِدُونَ﴾</span> لا يموتون{40}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه مسلم ١/١٦٣ (١٨١)، وأحمد ٣١/٢٦٥ (١٨٩٣٥)، ٣١/٢٧٠ (١٨٩٤١)، ٣٩/٣٤٧-٣٤٨ (٢٣٩٢٥) واللفظ له، وابن جرير ١٢/١٦٠-١٦١، وابن أبي حاتم ٦/١٩٤٥ (١٠٣٤٠)، والثعلبي ٥/١٢٩.</p><p>قال ابن كثير في تفسيره ٧/٣٥٥: «وهكذا رواه مسلم وجماعة من الأئمة من حديث حمّاد بن سلمة به».|2:أخرجه الشاشيُّ في مسنده ٢/٣٨٩ (٩٩٠)، والدارقطنيُّ في كتاب رؤية الله ص١٣٢ (١٧٠)، وابن جرير ١٢/١٦٠، من طريق حمّاد، عن ثابت، عن عبد الرحمن بن أبي ليلى، عن صهيب به.</p><p>إسناده صحيح، وأصله في صحيح مسلم، وهو المتقدِّم قبله.|3:أخرجه الدارقطني في كتاب رؤية الله ص٦٧ (٥٣)، وابن النحاس في كتاب رؤية الله ص١٧ (٦)، وابن وهب في تفسيره ١/٧٦ (١٧١)، وابن جرير ١٢/١٥٨، وابن أبي حاتم ٦/١٩٤٥ (١٠٣٤١)، وابن مردويه -كما في تخريج أحاديث الكشاف ٢/١٢٥-، من طريقين: أبان بن أبي عياش، عن أبي تميمة الهجيمي، عن أبي موسى الأشعري، ومن طريق أبي بكر الهذلي، عن أبي تميمة الهجيمي، عن أبي موسى الأشعري.</p><p>وكلا الإسنادين ضعيف جدًّا؛ أبان بن أبي عياش قال عنه ابن حجر في التقريب (١٤٢): «متروك». وأبوبكر الهذلي قال عنه في التقريب (٨٠٠٢): «متروك الحديث».|4:أخرجه عبد الله بن أحمد في كتاب السنة ١/٢٦٢ (٤٨٤)، والطبراني في مسند الشاميين ٣/٣٠٢-٣٠٣ (٢٣٣٠)، وابن جرير ١٢/١٦١.</p><p>قال ابن حجر في الفتح ٨/٣٤٧ عن إسناد ابن جرير: «في إسناده ضعف».|5:أخرجه اللالكائي في شرح أصول اعتقاد أهل السنة ٣/٥٠٥-٥٠٦ (٧٨٠)، وابن جرير ١٢/١٦٢، وابن أبي حاتم ٦/١٩٤٤ (١٠٣٣٦)، وابن مردويه -كما في تخريج أحاديث الكشاف ٢/١٢٥-، من طريق عمرو بن أبي سلمة، سمعتُ زهيرًا عمَّن سمع أبا العالية، حدثنا أبي بن كعب به.</p><p>إسناده ضعيف؛ لجهالة شيخ زهير الراوي عن أبي العالية.</p><p>وأخرجه الدارقطني في الرؤية ص٢١٦ (١٣٥)، من طريق محمد بن زكريا بن دينار، حدثني قحطبة بن غدانة، حدثنا أبو خلدة، عن أبي العالية، عن أبي بن كعب به.</p><p>إسناده ضعيف جِدًّا؛ فيه محمد بن زكريا بن دينار، وهو ضعيف، وقال الدارقطني: «يضع الحديث». كما في لسان الميزان لابن حجر ٧/١٣٩.|6:أخرجه الحارث -كما في المطالب العالية ١٤/٧٢٠ (٣٦٣٠)-، من طريق داود بن المحبّر، عن عباد بن كثير، عن نافع، عن ابن عمر به. وعزاه السيوطي بهذا اللفظ إلى ابن مردويه.</p><p>إسناده ضعيف جِدًّا؛ فيه داود بن المحبّر، قال عنه ابن حجر في التقريب (١٨١١): «متروك». وفيه عباد بن كثير الثقفي، قال ابن حجر في التقريب (٣١٣٩): «متروك».|7:أخرجه الدارقطني في كتاب رؤية الله ص١٧١ (٥٧)، وابن منده في الرد على الجهمية ص٥١-٥٢، والثعلبي ٥/١٢٩. وفيه سلم بن سالم، ونوح بن أبي مريم.</p><p>قال الذهبي في تاريخ الإسلام ٤٤/٣٩٤: «هذا حديث مُنكَر، انفرَد به سلم بن سالم البلخي، وهو ضعيف باتِّفاق، عن نوح الجامع شيخ مرو، وليس بثقة، بل تركوه». وقال ابن كثير في البداية والنهاية ٢٠/٣٦٦: «سلم وشيخه نوح بن أبي مريم مُتَكَلَّم فيهما».|8:عزاه السيوطي إلى ابن مردويه.|9:أي: ساحله. النهاية (سيف).|10:أخرجه ابن أبي عاصم في الجهاد ٢/٧٠٢ (٣١٠).|11:أخرجه يحيى بن سلام -كما في تفسير ابن أبي زمنين ٢/٢٥٢- بنحوه، وابن جرير ٢/١٥٦، وابن خزيمة (٢٦٤)، وابن منده في الرد على الجهمية (٨٤)، واللالكائي (٧٨٤)، والآجري في الشريعة (٥٨٩-٥٩١)، والبيهقي في الأسماء والصفات (٦٦٦)، وفي الاعتقاد ص١٣١، والخطيب ٩/١٣٤. وعلَّقه ابن أبي حاتم ٦/١٩٤٥. وعزاه السيوطي إلى ابن أبي شيبة، وابن المنذر، وأبي الشيخ، والدارقطني، وابن مردويه.|12:أخرجه ابن أبي حاتم -كما في شرح أصول الاعتقاد للالكائي (٧٨٧، ٧٨٨)-.|13:أخرجه ابن أبي شيبة ١٣/٣١٨، وابن جرير ١٢/١٥٧. وعلَّقه ابن أبي حاتم ٦/١٩٤٥، وابن خزيمة (٢٦٤، ٢٦٥)، واللالكائي (٧٨٣، ٧٨٤)، والآجري في الشريعة (٥٩١). وينظر: الاعتقاد للبيهقي ص١٣٢. وعزاه السيوطي إلى ابن المنذر، وأبي الشيخ، والدارقطني، والبيهقي.|14:عزاه السيوطي إلى ابن مردويه.|15:أخرجه سعيد بن منصور (١٠٥٨ - تفسير)، وابن جرير ١٢/١٦٢، وابن أبي حاتم ٦/١٩٤٥. وعزاه السيوطي إلى ابن المنذر، وأبي الشيخ، والبيهقي في الرؤية.|16:أخرجه هناد في الزهد (١٦٩)، وابن جرير ١٢/١٥٧، ١٥٨، وابن أبي الدنيا في كتاب صفة الجنة - موسوعة الإمام ابن أبي الدنيا (٦/٣٤٠) رقم (٩٤)، وابن أبي حاتم ٦/١٩٤٥، واللالكائى (٧٨٥، ٧٨٦). وعزاه السيوطي إلى ابن المنذر، وأبي الشيخ، والدارقطني، والبيهقي.|17:أخرجه البيهقى في الأسماء والصفات (٢٠٥). وعزاه السيوطي إلى ابن مردويه.|18:أخرجه ابن جرير ١٢/١٦٤، وابن أبي حاتم ٦/١٩٤٤، والبيهقي في الأسماء والصفات (٢٠٦). وعزاه السيوطي إلى ابن المنذر.|19:أخرجه ابن جرير ١٢/١٦٣.|20:أخرجه ابن أبي حاتم ٦/١٩٤٤.|21:تفسير الثعلبي ٥/١٢٩.|22:أخرجه ابن جرير ١٢/١٦٣، وابن أبي حاتم ٦/١٩٤٦. وعزاه السيوطي إلى ابن المنذر.|23:أخرجه ابن جرير ١٢/١٥٩. وعزاه السيوطي إلى الدارقطني. كما أخرجه ابن جرير بنحوه وزاد فيه: قال ابن أبي ليلى: فما ظنُّك بهم حين ثَقُلَتْ موازينهم، وحين صارت الصحف في أيمانهم، وحين جاوزوا جسر جهنم ودخلوا الجنة، وأُعْطُوا فيها ما أُعْطُوا مِن الكرامة والنعيم؟! كل ذلك لم يكن شيئًا فيما رَأَوْا.|24:أخرجه ابن أبي حاتم ٦/١٩٤٤.|25:أخرجه اللالكائي في شرح أصول اعتقاد أهل السنة والجماعة ٣/٥٠٩-٥١٠ (٧٨٩). وعلَّقه ابن أبي حاتم ٦/١٩٤٤.|26:تفسير مجاهد ص٣٨٠، وأخرجه ابن جرير ١٢/١٦٣-١٦٤، وابن أبي حاتم ٦/١٩٤٥. وعزاه السيوطي إلى ابن أبي شيبة، وابن المنذر.|27:علَّقه ابن أبي حاتم ٦/١٩٤٥.|28:علَّقه ابن أبي حاتم ٦/١٩٤٤.|29:علَّقه ابن أبي حاتم ٦/١٩٤٥. وعزاه السيوطي إلى الدارقطني.|30:أخرجه اللالكائي في شرح أصول اعتقاد أهل السنة والجماعة ٣/٥١٢ (٧٩٦). وعلَّقه ابن أبي حاتم ٦/١٩٤٤.|31:أخرجه ابن جرير ١٢/١٦٣. وعزاه السيوطي إلى ابن المنذر.|32:أخرجه اللالكائي في شرح أصول اعتقاد أهل السنة والجماعة ٣/٥١٠ (٧٩٠)، وأخرج ابن جرير ١٢/١٦٠ شطره الثاني من طريق عوف. وعلَّقه ابن أبي حاتم ٦/١٩٤٥. وعزاه الحافظ في الفتح ٨/٣٤٧ إلى عبد بن حميد.|33:تفسير الثعلبي ٥/١٢٩، وتفسير البغوي ٤/١٣٠.|34:عزاه السيوطي إلى أبي الشيخ.|35:أخرجه ابن جرير ١٢/١٦١. وعلَّقه ابن أبي حاتم ٦/١٩٤٥ بنحوه. وعزاه السيوطي إلى الدارقطني.|36:أخرجه ابن جرير ١٢/١٦٢، وابن أبي حاتم ٦/١٩٤٥. وعزا السيوطيُّ شطره الثاني إلى الدارقطني.|37:أخرجه ابن جرير ١٢/١٥٦، ١٥٧، ١٦١. وعلَّقه ابن أبي حاتم ٦/١٩٤٥. وعزاه السيوطي إلى الدارقطني.|38:علَّقه ابن أبي حاتم ٦/١٩٤٥. وعزاه السيوطي إلى الدارقطني.|39:أخرجه ابن جرير ١٢/١٥٧. وعلَّقه ابن أبي حاتم ٦/١٩٤٥. وعزاه السيوطي إلى الدارقطني.|40:تفسير مقاتل بن سليمان ٢/٢٣٦.|41:أخرجه ابن جرير ١٢/١٦٤. وعزاه السيوطي إلى أبي الشيخ.|42:أخرجه ابن أبي حاتم ٦/١٩٤٤.|43:أخرجه عبد الله بن أحمد في كتاب السنة ١/٢٤٣ (٤٤٣)، والبزار ٦/١٣-١٤ (٢٠٨٧) بنحوه مطولًا، من طريق حماد، عن ثابت، عن عبد الرحمن بن أبي ليلى، عن صُهَيْب به.</p><p>إسناده صحيح.|44:أخرجه ابن جرير ١٢/١٦٦، وابن أبي حاتم ٦/١٩٤٦. وعزاه السيوطي إلى ابن المنذر.|45:أخرجه ابن أبي شيبة ١٣/٤٢٦، وابن جرير ١٢/٦٥٨، ٦٦١، وابن أبي حاتم ٦/١٩٤٦. وعزاه السيوطي إلى ابن المنذر، وأبي الشيخ، والدارقطني.|46:أخرجه ابن أبي حاتم ٦/١٩٤٦.|47:عزاه السيوطي إلى أبي الشيخ.|48:علَّقه ابن أبي حاتم ٦/١٩٤٦.|49:تفسير البغوي ٤/١٣٠.|50:تفسير مقاتل بن سليمان ٢/٢٣٦.
  10,27,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَٱلَّذِینَ كَسَبُوا۟ ٱلسَّیِّـَٔاتِ جَزَاۤءُ سَیِّئَةِۭ بِمِثۡلِهَا﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٤٤٤٨<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- قوله: <span class="qpc-hafs">﴿سيئة﴾</span>، قال: الشَّرُّ{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤٤٤٩<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span>، في قوله: <span class="qpc-hafs">﴿والَّذِينَ كَسَبُوا السَيِئاتِ﴾</span> قال: الذين عمِلوا الكبائرَ، <span class="qpc-hafs">﴿جَزَآءُ سَيِئَةِ بِمِثْلِها﴾</span> قال: النارُ{2}<span class=comment-ref>٣١١٣</span>. (٧/٦٦٠)</p></p><p></div></p><p><div><span class=comment-ref>٣١١٣</span> <span class="comment-type-4">ذَكَرَ</span> <u>ابنُ عطية</u> (٤/٤٧٤) أنّ السيئاتِ تَعُمُّ الكفرَ والمعاصيَ، وأنّ مثلَ سيئة الكفر التخليدُ في النار، ومثلَ سيئة المعاصي مصروفٌ إلى مشيئة الله -تبارك وتعالى-.</div></p><p><div></p><p><p><span class="item-no">٣٤٤٥٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿والَّذِينَ كَسَبُوا السَّيِّئاتِ﴾</span> يعني: عملوا الشرك <span class="qpc-hafs">﴿جَزاءُ سَيِّئَةٍ بِمِثْلِها﴾</span> يعني: جزاء الشرك جهنم{3}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَتَرۡهَقُهُمۡ ذِلَّةࣱۖ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٤٤٥١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- في قوله: <span class="qpc-hafs">﴿وتَرْهَقُهُم ذِلَّةٌ﴾</span>، قال: تَغْشاهم ذِلَّةٌ، وشِدَّةٌ{4}. (٧/٦٦٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤٤٥٢<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السدي</span>، في قوله: <span class="qpc-hafs">﴿وتَرْهَقُهُم ذِلَّةٌ﴾</span>، قال: الذُّلُّ{2}. (٧/٦٦٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤٤٥٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وتَرْهَقُهُمْ ذِلَّةٌ﴾</span>، يعني: مَذَلَّة في أبدانهم{3}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿مَّا لَهُم مِّنَ ٱللَّهِ مِنۡ عَاصِمࣲۖ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٤٤٥٤<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- <span class="qpc-hafs">﴿مّا لَهُم مِنَ الله مِن عاصِمٍ﴾</span>، يقول: مِن مانعٍ{7}. (٧/٦٦٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤٤٥٥<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق مَعْمَر- <span class="qpc-hafs">﴿مّا لَهُم مِنَ الله مِن عاصِمٍ﴾</span>، قال: مِن نصيرٍ{8}. (٧/٦٦٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤٤٥٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ما لَهُمْ مِنَ اللَّهِ مِن عاصِمٍ﴾</span>، يعني: مانِع يمنعهم مِن العذاب{3}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿كَأَنَّمَاۤ أُغۡشِیَتۡ وُجُوهُهُمۡ قِطَعࣰا مِّنَ ٱلَّیۡلِ مُظۡلِمًاۚ أُو۟لَـٰۤىِٕكَ أَصۡحَـٰبُ ٱلنَّارِۖ هُمۡ فِیهَا خَـٰلِدُونَ ۝٢٧﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٤٤٥٧<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دِعامة</span> -من طريق مَعْمَر- <span class="qpc-hafs">﴿كَأَنَّمَآ أُغْشِيَتْ وجَوهَهَمْ قِطَعًا مِنَ الَّيلِ مظلما﴾</span>، قال: ظُلْمةً مِن الليل{10}. (٧/٦٦٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤٤٥٨<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيِّ</span>، في قوله: <span class="qpc-hafs">﴿كَأَنَّمَآ أُغشِيَتْ وجَوهَهَمْ قِطَعًا مِنَ الَّيلِ مُظلِمًا﴾</span>، قال: والقِطَعُ: السَّوادُ{2}. (٧/٦٦٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤٤٥٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿كَأَنَّما أُغْشِيَتْ وُجُوهُهُمْ قِطَعًا مِنَ اللَّيْلِ مُظْلِمًا﴾</span> يعني: سواد الليل، <span class="qpc-hafs">﴿أُولَئِكَ أصْحابُ النّارِ هُمْ فِيها خالِدُونَ﴾</span> لا يموتون{3}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿كَأَنَّمَاۤ أُغۡشِیَتۡ وُجُوهُهُمۡ قِطَعࣰا مِّنَ ٱلَّیۡلِ مُظۡلِمًاۚ أُو۟لَـٰۤىِٕكَ أَصۡحَـٰبُ ٱلنَّارِۖ هُمۡ فِیهَا خَـٰلِدُونَ ۝٢٧﴾</span> - النَّسْخ في الآية</h3></p><p><div></p><p><p><span class="item-no">٣٤٤٦٠<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span>، قال: نسَخَتْها الآيةُ في البقرة [٨١]: <span class="qpc-hafs">﴿بَلى مَن كَسَبَ سَيِئَةً﴾</span> الآيةَ{2}. (٧/٦٦٠)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن أبي حاتم ٦/١٩٤٧.|2:عزاه السيوطي إلى أبي الشيخ.|3:تفسير مقاتل بن سليمان ٢/٢٣٦.|4:أخرجه ابن جرير ١٢/١٦٧.|5:عزاه السيوطي إلى أبي الشيخ.|6:تفسير مقاتل بن سليمان ٢/٢٣٦.|7:أخرجه ابن أبي حاتم ٦/١٩٤٧ بلفظ: شافع. وعزاه السيوطي إلى أبي الشيخ.|8:أخرجه عبد الرزاق ١/٢٩٦، وابن أبي حاتم ٦/١٩٤٧. وعزاه السيوطي إلى ابن المنذر، وابن جرير، وأبي الشيخ.|9:تفسير مقاتل بن سليمان ٢/٢٣٦.|10:أخرجه عبد الرزاق ١/٢٩٦، وابن جرير ١٢/١٦٨، وابن أبي حاتم ٦/١٩٤٧. وعزاه السيوطي إلى ابن المنذر، وأبي الشيخ.|11:عزاه السيوطي إلى أبي الشيخ.|12:تفسير مقاتل بن سليمان ٢/٢٣٦.|13:عزاه السيوطي إلى أبي الشيخ.
  10,28,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَیَوۡمَ نَحۡشُرُهُمۡ جَمِیعࣰا﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٤٤٦١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق الضَّحّاك- قال: يُحْشَرُ كُلُّ شيء، حتى إنّ الذُّباب يُحْشَر{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤٤٦٢<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق الأعمش، عمَّن سَمِعه- في قوله: <span class="qpc-hafs">﴿ويَومَ نَحْشُرُهُمْ﴾</span>، قال: الحَشْرُ: المَوْتُ{2}<span class=comment-ref>٣١١٤</span>. (٧/٦٦١)</p></p><p></div></p><p><div><span class=comment-ref>٣١١٤</span> <span class="comment-type-4">ذكر</span> <u>ابنُ جرير</u> (١٢/١٧٢) أنّ الحشر: جَمْعُ الخلقِ لموقف الحساب جميعًا. ثم ساق قول مجاهد، و<span class="comment-type-3">رجَّحه</span> <span class="mustanad">مستندًا إلى الدلالات العقلية</span>، فقال: «لأنّ الله -تعالى ذِكْرُه- أخبر أنّه يقول يومئذٍ للذين أشركوا ما ذَكَر أنّه يقول لهم، ومعلوم أنّ ذلك غير كائن في القبر، وأنّه إنما هو خبرٌ عَمّا يُقال لهم ويقولون في الموقف بعد البعث».</div></p><p><div></p><p><p><span class="item-no">٣٤٤٦٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ويَوْمَ نَحْشُرُهُمْ جَمِيعًا﴾</span>، يعني: الكفار، وما عَبَدُوا من دون الله{3}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿ثُمَّ نَقُولُ لِلَّذِینَ أَشۡرَكُوا۟ مَكَانَكُمۡ أَنتُمۡ وَشُرَكَاۤؤُكُمۡۚ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٤٤٦٤<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دِعامة</span> -من طريق سعيد- قال: ما لله مِن شريكٍ في السَّماء، ولا في الأرض{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤٤٦٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ثُمَّ نَقُولُ لِلَّذِينَ أشْرَكُوا مَكانَكُمْ أنْتُمْ وشُرَكاؤُكُمْ﴾</span>، يعني: الآلهة{3}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿فَزَیَّلۡنَا بَیۡنَهُمۡۖ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٤٤٦٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فَزَيَّلْنا بَيْنَهُمْ﴾</span>، يعني: فمَيَّزْنا بين الجزاءين{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤٤٦٧<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿فَزَيَّلْنا بَيْنَهُمْ﴾</span>، قال: فَرَّقْنا بينَهم{7}. (٧/٦٦١)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَقَالَ شُرَكَاۤؤُهُم مَّا كُنتُمۡ إِیَّانَا تَعۡبُدُونَ ۝٢٨﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٤٤٦٨<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وقالَ شُرَكاؤُهُمْ﴾</span> يعني: الآلهة، وهم الأصنام: <span class="qpc-hafs">﴿ما كُنْتُمْ إيّانا تَعْبُدُونَ﴾</span>{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤٤٦٩<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قول الله: <span class="qpc-hafs">﴿وقال شركاؤهم ما كنتم إيانا تعبدون﴾</span>، فقالوا: بلى، قد كُنّا نعبدكم{9}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن أبي حاتم ٤/١٣٢٣، ٦/١٩٤٧، ٨/٢٦٧١.|2:أخرجه ابن جرير ١٢/١٧٢، وابن أبي حاتم ٦/١٩٤٧. وعزاه السيوطي إلى ابن المنذر، وأبي الشيخ.|3:تفسير مقاتل بن سليمان ٢/٢٣٦.|4:أخرجه ابن أبي حاتم ٦/١٩٤٨.|5:تفسير مقاتل بن سليمان ٢/٢٣٦.|6:تفسير مقاتل بن سليمان ٢/٢٣٦.|7:أخرجه ابن جرير ١٢/١٧١، وابن أبي حاتم ٦/١٩٤٨. وعزاه السيوطي إلى أبي الشيخ.|8:تفسير مقاتل بن سليمان ٢/٢٣٦.|9:أخرجه ابن جرير ١٢/١٧١، وابن أبي حاتم ٦/١٩٤٨.
  10,29,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿فَكَفَىٰ بِٱللَّهِ شَهِیدَۢا بَیۡنَنَا وَبَیۡنَكُمۡ إِن كُنَّا عَنۡ عِبَادَتِكُمۡ لَغَـٰفِلِینَ ۝٢٩﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٤٤٧٠<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- قال: يأتي على الناسِ يومَ القيامةِ ساعةٌ فيها لِينٌ، يَرى أهلُ الشركِ أهلَ التوحيدِ يُغْفَرُ لهم، فيقولون: <span class="qpc-hafs">﴿واللهِ رَبِنا ما كُنّا مُشرِكِينَ﴾</span>. قال الله: <span class="qpc-hafs">﴿انُظرْ كَيفَ كَذَبُوا عَلى أنفُسِهِم وضَلَّ عَنْهُم مّا كانُوا يَفْتَرُونَ﴾</span> [الأنعام:٢٣-٢٤]. ثم يكونُ مِن بعدِ ذلك ساعةٌ فيها شِدَّةٌ، تُنصَبُ لهم الآلِهَةُ التي كانوا يعبُدون مِن دونِ اللهِ، فيقول: هؤلاء الذين كنتُم تعبُدون من دون الله؟ فيقولون: نعم، هؤلاء الذين كُنّا نعبُدُ. فتقولُ لهم الآلهةُ: واللهِ، ما كُنّا نسمعُ، ولا نُبْصِرُ، ولا نعقِلُ، ولا نعلمُ أنّكم كنتُم تعبُدوننا. فيقولون: بلى، واللهِ، لَإيّاكم كُنّا نعبُدُ. فتقول لهم الآلهة: <span class="qpc-hafs">﴿فَكَفى بِاللهِ شَهِيدا بَينَنا وبَينَكُم إن كُنّا عَن عِبادَتِكُم لَغافِلِينَ﴾</span>{1}<span class=comment-ref>٣١١٥</span>. (٧/٦٦١)</p></p><p></div></p><p><div><span class=comment-ref>٣١١٥</span> <span class="comment-type-4">قال</span> <u>ابنُ عطية</u> (٤/٤٧٦): «وظاهر هذه الآية: أنّ محاورتهم إنّما هي مع الأصنام، دون الملائكة وعيسى ابن مريم <span class="mustanad">بدليل القول لهم</span>: <span class="qpc-hafs">﴿مكانكم أنتم وشركاؤكم﴾</span>، ودون فرعون ومَن عُبِد مِن الجن <span class="mustanad">بدليل قولهم</span>: <span class="qpc-hafs">﴿إن كنا عن عبادتكم لغافلين﴾</span>، وهؤلاء لم يغفلوا قطُّ عن عبادة مَن عبدهم».</div></p><p><div></p><p><p><span class="item-no">٣٤٤٧١<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- قوله: <span class="qpc-hafs">﴿عن عبادتكم لغافلين﴾</span>، قال: ذلك كُلُّ شيءٍ يُعبَد مِن دون الله{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤٤٧٢<span class="dash">-</span></span> قال <span class="name-2">الحسن البصري</span>: يَحْشُر اللهُ ﷿ الأوثانَ المعبودةَ في الدنيا بأعيانها، فتُخاصِمُ مَن كان عَبَدَها{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤٤٧٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فَكَفى بِاللَّهِ شَهِيدًا بَيْنَنا وبَيْنَكُمْ إنْ كُنّا﴾</span> يعني: لقد كُنّا <span class="qpc-hafs">﴿عَنْ عِبادَتِكُمْ﴾</span> إيّانا <span class="qpc-hafs">﴿لَغافِلِينَ﴾</span>، وقد عَبَدتُمُونا وما نشعر بكم{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤٤٧٤<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهْب-: فقالوا: <span class="qpc-hafs">﴿كفى بالله شهيدا بيننا وبينكم إن كنا عن عبادتكم لغافلين﴾</span> ما كُنّا نسمع، ولا نُبْصِر، ولا نتكلم. فقال الله: <span class="qpc-hafs">﴿هنالك تبلو كل نفس ما أسلفت﴾</span>{5}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ١٢/١٧١، وابن أبي حاتم ٦/١٩٤٨. وعزاه السيوطي إلى ابن أبي شيبة، وابن المنذر، وأبي الشيخ.|2:تفسير مجاهد ص٣٨٠، وأخرجه ابن جرير ١٢/١٧٢، وابن أبي حاتم ٦/١٩٤٩.|3:ذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٢/٢٥٥-.|4:تفسير مقاتل بن سليمان ٢/٢٣٦.|5:أخرجه ابن جرير ١٢/١٧١، وابن أبي حاتم ٦/١٩٤٨ من طريق أصبغ بن الفرج.
  10,30,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿هُنَالِكَ تَبۡلُوا۟ كُلُّ نَفۡسࣲ مَّاۤ أَسۡلَفَتۡۚ وَرُدُّوۤا۟ إِلَى ٱللَّهِ مَوۡلَىٰهُمُ ٱلۡحَقِّۖ وَضَلَّ عَنۡهُم مَّا كَانُوا۟ یَفۡتَرُونَ ۝٣٠﴾</span> - قراءات</h3></p><p><div></p><p><p><span class="item-no">٣٤٤٧٥<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن مسعود</span> أنّه كان يقرأُ: ‹هُنالِكَ تَتْلُواْ› بالتاءِ{1}<span class=comment-ref>٣١١٦</span>. (٧/٦٦٢)</p></p><p></div></p><p><div><span class=comment-ref>٣١١٦</span> اختُلِف في قراءة <span class="qpc-hafs">﴿تبلوا﴾</span>؛ فقرأ قوم: <span class="qpc-hafs">﴿تبلوا﴾</span>. وقرأ آخرون: <span class="qpc-hafs">﴿تتلوا﴾</span>.</p><p>و<span class="comment-type-4">ذكر</span> <u>ابنُ جرير</u> (١٢/١٧٣-١٧٤) أنّ قراءة الباء بمعنى: عند ذلك تُختَبَر كلُّ نفس ما قدمت [كذا أثبتها وصححها الشيخ شاكر ١٥/٨٠، وفي طبعة التركي: بما قدمت] مِن خير أو شر. وبيَّن أن قراءة التاء اختُلِف في تفسيرها؛ <b>فمنهم مَن فسرها</b> بمعنى: تتبع ما قدَّمته من خير وشر. و<b>فسَّرها آخرون</b>: بالقراءة. و<b>فسرها غيرهم</b>: بالمعاينة.</p><p>و<span class="comment-type-4">بنحوه</span> قال <u>ابنُ عطية</u> (٤/٤٧٧). و<span class="comment-type-4">كذا</span> <u>ابنُ كثير</u> (٧/٣٥٩-٣٦٠).</p><p>و<span class="comment-type-3">رجَّح</span> <u>ابنُ جرير</u> (١٢/١٧٤-١٧٥) صِحَّة كِلتا القراءتين <span class="mustanad">مستندًا إلى شهرتهما، واستفاضتهما</span>، فقال: «والصوابُ من القول في ذلك أن يُقال: إنّهما قراءتان مشهورتان، قد قرأ بكلِّ واحدة منهما أئمةٌ مِن القراء، وهما متقاربتا المعنى؛ وذلك أنّ مَن تبع في الآخرة ما أسلف من العمل في الدنيا هُجِم به على مَورده، فيُخبَر هنالك ما أسلف من صالح أو سيِّءٍ في الدنيا، وإنّ مِن خَبَر ما أسلف في الدنيا مِن أعماله في الآخرة فإنما يُخبَر بعد مصيره إلى حيث أحلّه ما قدم في الدنيا من عمله، فهو في كلتا الحالتين مُتَّبِعٌ ما أسلف مِن عمله، مُخْتَبِر له، فبأيتهما قرأ القارِئُ كما وصفنا فمصيبٌ الصوابَ في ذلك».</div></p><p><h3><span class="qpc-hafs">﴿هُنَالِكَ تَبۡلُوا۟ كُلُّ نَفۡسࣲ مَّاۤ أَسۡلَفَتۡۚ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٤٤٧٦<span class="dash">-</span></span> عن عبد الله بن مسعود، قال: قال رسول الله ﷺ: «<b>يُمَثَّلُ لهم يومَ القيامةِ ما كانوا يعبُدون مِن دونِ اللهِ، فيَتَّبِعونهم حتى يُورِدُوهم النارِ</b>». ثم تَلا رسولُ الله ﷺ: ‹هُنالِكَ تَتْلُواْ كُلُّ نَفسٍ مَّآ أسْلَفَت›{2}. (٧/٦٦١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤٤٧٧<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن مسعود</span> أنّه كان يقرأُ: ‹هُنالِكَ تَتْلُواْ› بالتاءِ. قال: هنالك تَتْبَعُ{3}. (٧/٦٦٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤٤٧٨<span class="dash">-</span></span> قال <span class="name-1">عبد الله بن مسعود</span>: هذا في البَعْثِ، ليس أحدٌ كان يعبدُ شيئًا مِن دون الله ﷿ إلا وهو مرفوع{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤٤٧٩<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- <span class="qpc-hafs">﴿هُنالِكَ تَبلُوا﴾</span>، قال: تُخْتَبَرُ{5}. (٧/٦٦٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤٤٨٠<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق الربيع بن عبد الله بن خطاف- <span class="qpc-hafs">﴿هُنالِكَ تَبلُوا كُلُّ نَفسٍ مَّآ أسْلَفَت﴾</span>، قال: ما عمِلَتْ{6}. (٧/٦٦٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤٤٨١<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span>، ‹هُنالِكَ تَتْلُوا›، يقول: تَتْبَعُ{7}. (٧/٦٦٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤٤٨٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿هُنالِكَ﴾</span> يعني: عند ذلك <span class="qpc-hafs">﴿تَبْلُواْ﴾</span> يعني: تختبر <span class="qpc-hafs">﴿كُلُّ نَفْسٍ ما أسْلَفَتْ﴾</span> يعني: ما قَدَّمَتْ، <span class="qpc-hafs">﴿ورُدُّوا إلى اللَّهِ مَوْلاهُمُ الحَقِّ وضَلَّ عَنْهُمْ ما كانُوا يَفْتَرُونَ﴾</span> يعني: يعبدون في الدنيا مِن الآلهة{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤٤٨٣<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- <span class="qpc-hafs">﴿هُنالِكَ تَبلُوا كل نفس مَّآ أسْلَفَت﴾</span>، قال: ما عمِلَت. ›تَتْلُوا‹: تُعايِنُه{9}. (٧/٦٦٢)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَرُدُّوۤا۟ إِلَى ٱللَّهِ مَوۡلَىٰهُمُ ٱلۡحَقِّۖ وَضَلَّ عَنۡهُم مَّا كَانُوا۟ یَفۡتَرُونَ ۝٣٠﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٤٤٨٤<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق الضَّحّاك- قوله: <span class="qpc-hafs">﴿وضل عنهم﴾</span> هذا في القيامة <span class="qpc-hafs">﴿ما كانوا يفترون﴾</span> أي: يُشْرِكون{10}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤٤٨٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ورُدُّوا إلى اللَّهِ مَوْلاهُمُ الحَقِّ وضَلَّ عَنْهُمْ ما كانُوا يَفْتَرُونَ﴾</span>، يعني: يعبدون في الدنيا مِن الآلهة{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤٤٨٦<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- <span class="qpc-hafs">﴿وضَلَّ عَنْهُم مّا كانُوا يَفْتَرُونَ﴾</span>، قال: ما كانوا يدْعُون معه مِن الأندادِ{12}. (٧/٦٦٢)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَرُدُّوۤا۟ إِلَى ٱللَّهِ مَوۡلَىٰهُمُ ٱلۡحَقِّۖ وَضَلَّ عَنۡهُم مَّا كَانُوا۟ یَفۡتَرُونَ ۝٣٠﴾</span> - النسخ في الآية</h3></p><p><div></p><p><p><span class="item-no">٣٤٤٨٧<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span>، في قوله: <span class="qpc-hafs">﴿ورُدُّوا إلى اللهِ مَولاهُمُ الحَقِ﴾</span>، قال: نسَخَها قولُه: <span class="qpc-hafs">﴿ذَلِكَ بِأَنَّ اللَّهَ مَولى الَّذِينَ آمَنُوا وأَنَّ الكافِرِينَ لا مَولى لهم﴾</span> [محمد:١١]{7}. (٧/٦٦٢)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَرُدُّوۤا۟ إِلَى ٱللَّهِ مَوۡلَىٰهُمُ ٱلۡحَقِّۖ وَضَلَّ عَنۡهُم مَّا كَانُوا۟ یَفۡتَرُونَ ۝٣٠﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٣٤٤٨٨<span class="dash">-</span></span> عن قيس، قال: دخل عثمانُ على <span class="name-1">عبد الله بن مسعود</span> ﵄، فقال: كيف تَجِدُك؟ قال: مردودٌ إلى مولاي الحق{6}. (ز)</p></p><p></div></p></div>",footnotes:1:عزاه السيوطي إلى ابن المنذر.</p><p>وهي قراءة متواترة، قرأ بها حمزة، والكسائي، وخلف العاشر، وقرأ بقية العشرة: <span class="qpc-hafs">﴿تَبْلُواْ﴾</span> بالباء. انظر: النشر ٢/٢٨٣.|2:عزاه السيوطي إلى ابن مردويه.</p><p>قال ابن جرير ١٢/١٧٤: «وروي بنحو ذلك خبرٌ عن النبيِّ، مِن وجهٍ وسندٍ غير مُرتَضى ...». وذكره.|3:عزاه السيوطي إلى ابن المنذر.|4:ذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٢/٢٥٥-.|5:تفسير مجاهد ص٣٨١، وأخرجه ابن جرير ١٢/١٧٣، وابن أبي حاتم ٦/١٩٤٩. وذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٢/٢٥٥-. وعزاه السيوطي إلى ابن أبي شيبة، وابن المنذر، وأبي الشيخ.|6:أخرجه ابن أبي حاتم ٦/١٩٤٩.|7:عزاه السيوطي إلى أبي الشيخ.|8:تفسير مقاتل بن سليمان ٢/٢٣٦.|9:أخرجه ابن جرير ١٢/١٧٤. وعلَّقه ابن أبي حاتم ٦/١٩٤٩. وعزاه السيوطي إلى أبي الشيخ.|10:أخرجه ابن أبي حاتم ٦/١٩٥٠.|11:تفسير مقاتل بن سليمان ٢/٢٣٦.|12:أخرجه ابن جرير ١٢/١٧٥. وعزاه السيوطي إلى أبي الشيخ.|13:عزاه السيوطي إلى أبي الشيخ.|14:أخرجه ابن أبي حاتم ٦/١٩٤٩.
  10,31,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿قُلۡ مَن یَرۡزُقُكُم مِّنَ ٱلسَّمَاۤءِ وَٱلۡأَرۡضِ أَمَّن یَمۡلِكُ ٱلسَّمۡعَ وَٱلۡأَبۡصَـٰرَ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٤٤٨٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿قُلْ﴾</span> لكُفّار قريش: <span class="qpc-hafs">﴿مَن يَرْزُقُكُمْ مِنَ السَّماءِ﴾</span> يعني: المطر، <span class="qpc-hafs">﴿و﴾</span>مِن <span class="qpc-hafs">﴿الأَرْضِ﴾</span> يعني: النبات والثمار، <span class="qpc-hafs">﴿أمَّنْ يَمْلِكُ السَّمْعَ﴾</span> فيُسْمِعُها المواعظ، <span class="qpc-hafs">﴿والأَبْصارَ﴾</span> فيُرِيها العَظَمَة{1}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَمَن یُخۡرِجُ ٱلۡحَیَّ مِنَ ٱلۡمَیِّتِ وَیُخۡرِجُ ٱلۡمَیِّتَ مِنَ ٱلۡحَیِّ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٤٤٩٠<span class="dash">-</span></span> قال <span class="name-2">مجاهد بن جبر</span>، في قوله: <span class="qpc-hafs">﴿ومن يخرج الحي من الميت ويخرج الميت من الحي﴾</span>، يعني: يُخْرِج الناسَ الأحياءَ مِن النُّطَف، والنُّطَفَ مِن الناس الأحياء، والأنعام مثل ذلك، والنبات مثل ذلك{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤٤٩١<span class="dash">-</span></span> قال <span class="name-2">الحسن البصري</span>: يعني: يُخرِج المؤمنَ مِن الكافر، والكافرَ مِن المؤمن{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤٤٩٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ومَن يُخْرِجُ الحَيَّ مِنَ المَيِّتِ﴾</span> يعني: النَّسَمة الحيَّة مِن النُّطْفَة، <span class="qpc-hafs">﴿ويُخْرِجُ المَيِّتَ مِنَ الحَيِّ﴾</span>{1}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَمَن یُدَبِّرُ ٱلۡأَمۡرَۚ فَسَیَقُولُونَ ٱللَّهُۚ فَقُلۡ أَفَلَا تَتَّقُونَ ۝٣١﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٤٤٩٣<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- <span class="qpc-hafs">﴿يدبر الأمر﴾</span>، قال: يقضيه وحدَه{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤٤٩٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ومَن يُدَبِّرُ الأَمْرَ﴾</span> يعني: أمر الدنيا، يعني: القضاء، وحدَه، <span class="qpc-hafs">﴿فَسَيَقُولُونَ﴾</span> فسيقول مُشْرِكو قريش: <span class="qpc-hafs">﴿اللَّهُ﴾</span> يفعلُ ذلك. فإذا أقرُّوا بذلك <span class="qpc-hafs">﴿فَقُلْ﴾</span> يا محمد: <span class="qpc-hafs">﴿أفَلا﴾</span> يعني: أفَهَلّا <span class="qpc-hafs">﴿تَتَّقُونَ﴾</span> الشِّرْكَ. يعني: فهَلّا تحذرون العقوبةَ والنِّقمةَ{1}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٢/٢٣٧.|2:ذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٢/٢٥٥-.|3:ذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٢/٢٥٥-.|4:تفسير مقاتل بن سليمان ٢/٢٣٧.|5:أخرجه ابن أبي حاتم ٦/١٩٥٠.|6:تفسير مقاتل بن سليمان ٢/٢٣٧.
  10,32,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿فَذَ ٰ⁠لِكُمُ ٱللَّهُ رَبُّكُمُ ٱلۡحَقُّۖ فَمَاذَا بَعۡدَ ٱلۡحَقِّ إِلَّا ٱلضَّلَـٰلُۖ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٤٤٩٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فَذلِكُمُ اللَّهُ رَبُّكُمُ الحَقُّ فَماذا بَعْدَ الحَقِّ إلّا الضَّلالُ﴾</span>: فماذا بعد عبادةِ الحقِّ والإيمان إلا الباطل، <span class="qpc-hafs">﴿فَأَنّى تُصْرَفُونَ﴾</span>{1}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿فَأَنَّىٰ تُصۡرَفُونَ ۝٣٢﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٤٤٩٦<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق الضحاك- في قوله: <span class="qpc-hafs">﴿فأنى﴾</span>، قال: كيف{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤٤٩٧<span class="dash">-</span></span> قال <span class="name-3">محمد بن السائب الكلبي</span>: <span class="qpc-hafs">﴿فَأَنّى تُصْرَفُونَ﴾</span>: فمِن أين تُصرَفون عن عبادته وأنتم مُقِرُّون؟!{3}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿فَأَنَّىٰ تُصۡرَفُونَ ۝٣٢﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٣٤٤٩٨<span class="dash">-</span></span> عن حَرْملةَ بن عبد العزيز، قال: قلتُ لِ<span class="name-3">مالكِ بنِ أنسٍ</span>: ما ترى في رجل أمرُه يُعَنِّيني؟{4} قال: ليس ذلك من الحقِّ؛ قال الله: <span class="qpc-hafs">﴿فَماذا بَعْدَ الحَقِ إلا الضَّلالُ﴾</span>{2}. (٧/٦٦٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤٤٩٩<span class="dash">-</span></span> عن أشْهَبَ، قال: سُئِل <span class="name-3">مالكٌ</span> عن شهادةِ اللُّعّابِ بالشِّطْرَنجِ، والنَّرْدِ. فقال: أمّا مَن أدْمَنَها فما أرى شهادتَهم طائلةً؛ يقول الله: <span class="qpc-hafs">﴿فَماذا بَعْدَ الحَقِ إلا الضَّلالُ﴾</span>، فهذا كُلُّه مِن الضلال{2}. (٧/٦٦٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤٥٠٠<span class="dash">-</span></span> عن همام بن مسلم، قال: سُئِل <span class="name-3">مالك</span> عن اللعب بالشِّطْرَنجِ. فقال: أمِن الحقِّ هي؟ قيل: لا. فتلا هذه الآية: <span class="qpc-hafs">﴿فَماذا بَعْدَ الحَقِ إلا الضَّلالُ﴾</span>{7}. (٧/٦٦٣)</p></p><p></div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٢/٢٣٧.|2:أخرجه ابن أبي حاتم ٦/١٩٥١.|3:تفسير الثعلبي ٥/١٣١.|4:عنّاه: كلفه ما يشق عليه. الوسيط (عنو)|5:أخرجه ابن أبي حاتم ٦/١٩٥١.|6:أخرجه ابن أبي حاتم ٦/١٩٥١.|7:عزاه السيوطي إلى أبي الشيخ.
  10,33,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿كَذَ ٰ⁠لِكَ حَقَّتۡ كَلِمَتُ رَبِّكَ عَلَى ٱلَّذِینَ فَسَقُوۤا۟﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٤٥٠١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق الضحاك- في قوله: <span class="qpc-hafs">﴿كَذَلِكَ حَقَّتْ كَلِمَتُ رَبِكَ﴾</span>، يقول: سَبَقَتْ كلمةُ ربِّك{1}. (٧/٦٦٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤٥٠٢<span class="dash">-</span></span> عن <span class="name-2">الضحاك بن مزاحم</span>، <span class="qpc-hafs">﴿كَذَلِكَ حَقَّتْ﴾</span>، يقول: صَدَقَتْ{2}. (٧/٦٦٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤٥٠٣<span class="dash">-</span></span> قال <span class="name-3">محمد بن السائب الكلبي</span>: <span class="qpc-hafs">﴿كَذَلِكَ﴾</span>: هكذا{3}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿أَنَّهُمۡ لَا یُؤۡمِنُونَ ۝٣٣﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٤٥٠٤<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن كثير- قوله: <span class="qpc-hafs">﴿لا يؤمنون﴾</span>، قال: إذا جاءت بخبر لا يؤمنون{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤٥٠٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿كَذلِكَ حَقَّتْ كَلِمَةُ رَبِّكَ عَلى الَّذِينَ فَسَقُوا أنَّهُمْ لا يُؤْمِنُونَ﴾</span>، فأخبر بعلمه السابق فيهم أنّهم لا يؤمنون{5}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن أبي حاتم ٦/١٩٥١. وعزاه السيوطي إلى أبي الشيخ.|2:عزاه السيوطي إلى أبي الشيخ.|3:تفسير البغوي ٤/١٣٢.|4:أخرجه ابن أبي حاتم ٦/١٩٥١.|5:تفسير مقاتل بن سليمان ٢/٢٣٧.