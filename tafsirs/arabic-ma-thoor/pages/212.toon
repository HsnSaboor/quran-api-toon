tafsir[8]{c,v,t}:
10,26," <q>﴿لِّلَّذِینَ أَحۡسَنُوا۟ ٱلۡحُسۡنَىٰ وَزِیَادَةࣱۖ﴾</q> - تفسير ٣٤٣٩٧- عن صهيب، أنّ رسول الله ﷺ تلا هذه الآية: <q>﴿لِلَّذِينَ أحْسَنُوا الحُسْنى وزِيادَةٌ﴾</q>. قال: «إذا دَخَل أهلُ الجنةِ الجنةَ وأهلُ الناِر النارَ نادى مُنادٍ: يا أهلَ الجنةِ، إنّ لكم عندَ الله موعِدًا يريدُ أن يُنجِزَكُمُوه، فيقولون: وما هو؟ ألَمْ يُثَقِّلْ موازينَنا، ويُبيِّضْ وجوهَنا، ويُدْخِلْنا الجنةَ، ويزحْزِحْنا عن النار؟! قال: فيُكْشَفُ لهم الحجابُ، فينظُرون إليه، فواللهِ، ما أعطاهم اللهُ شيئًا أحبَّ إليهم مِن النَّظَر إليه، ولا أقرَّ لِأَعْيُنِهم»{1}. (٧/٦٥٢) ٣٤٣٩٨- عن صهيب، في الآية، قال: قال رسول الله ﷺ: «الزيادةُ: النَّظَرُ إلى وجْهِ اللهِ»{2}. (٧/٦٥٣) ٣٤٣٩٩- عن أبي موسى الأشعريِّ، عن رسول الله ﷺ: «إنّ الله يبعَثُ يومَ القيامةِ مُنادِيًا يُنادِي: يا أهلَ الجنةِ -بصوتٍ يَسمعُه أوَّلُهم وآخرُهم-، إنّ الله وعَدكم الحسنى وزيادةً. فالحسنى: الجنةُ، والزيادةُ: النظرُ إلى وجْهِ الرحمنِ»{3}. (٧/٦٥٣) ٣٤٤٠٠- عن كَعْب بن عُجْرَةَ، عن النبيِّ ﷺ، في قوله: <q>﴿لِلَّذِينَ أحْسَنُوا الحُسْنى وزِيادَةٌ﴾</q>، قال: «الزِّيادةُ: النظرُ إلى وجْهِ الرحمنِ»{4}. (٧/٦٥٣) ٣٤٤٠١- عن أُبَيِّ بن كَعْبٍ، أنّه سأل رسول الله ﷺ عن قول الله تعالى: <q>﴿لِلَّذِينَ أحْسَنُوا الحُسْنى وزِيادَةٌ﴾</q>. قال: «الذين أحسَنُوا: أهلُ التوحيدِ. والحُسْنى: الجنَّةُ. والزيادة: النَّظَرُ إلى وجْهِ الله»{5}. (٧/٦٥٣) ٣٤٤٠٢- عن ابن عمر، عن رسول الله ﷺ، في قوله: <q>﴿لِلَّذِينَ أحْسَنُوا الحُسْنى وزِيادَةٌ﴾</q>، قال: «<q>﴿أحسَنوا﴾</q>: شهادةُ أن لا إله إلا الله. و<q>﴿الحسنى﴾</q>: الجنةُ. و<q>﴿زيادةٌ﴾</q>: النظر إلى الله»{6}. (٧/٦٥٤) ٣٤٤٠٣- عن أنس، أنّ النبيَّ ﷺ سُئِل عن هذه الآية: <q>﴿لِلَّذِينَ أحْسَنُوا الحُسْنى وزِيادَةٌ﴾</q>. فقال: «للذين أحسنوا العملَ في الدنيا لهم الحسنى، وهي الجنةُ، والزيادةُ: النظرُ إلى وجْهِ الله الكريم»{7}. (٧/٦٥٤) ٣٤٤٠٤- عن أنس، قال: قال رسول الله ﷺ: <q>﴿لِلَّذِينَ أحْسَنُوا الحُسْنى وزِيادَةٌ﴾</q>، قال: «ينظرون إلى ربهم بلا كَيْفِيَّةٍ، ولا حَدٍّ مَحدودٍ، ولا صِفَةٍ معلومةٍ»{8}. (٧/٦٥٤) ٣٤٤٠٥- عن أبي هريرة، قال: قال رسول الله ﷺ: «مَن كبَّر على سِيفِ البحرِ{9} تكبيرةً رافِعًا بها صوتَه لا يلْتمِسُ بها رياءً ولا سُمْعَةً؛ كَتَبَ الله له رِضوانَه الأكبرَ، ومَن كتب له رِضوانَه الأكبرَ جمَع بينَه وبين محمدٍ وإبراهيمَ في دارِه، ينظرون إلى ربِّهم في جَنَّةِ عَدْنٍ، كما يَنظرُ أهلُ الدنيا إلى الشمسِ والقمرِ في يومٍ لا غَيمَ فيه ولا سحابَ، وذلك قوله: <q>﴿لِلَّذِينَ أحْسَنُوا الحُسْنى وزِيادَةٌ﴾</q>. فالحُسنى: لا إله إلا الله. والزِّيادةُ: الجنَّةُ، والنَّظَرُ إلى الرَّبِّ»{10}. (٧/٦٥٤) ٣٤٤٠٦- عن أبي بكر الصديق -من طريق عامِر بن سعد- في قوله: <q>﴿لِلَّذِينَ أحْسَنُوا الحُسْنى وزِيادَةٌ﴾</q>، قال: الحُسْنى: الجَنَّةُ. والزِّيادةُ: النَّظَرُ إلى وجهِ اللهِ{11}. (٧/٦٥٥) ٣٤٤٠٧- عن عبد الله بن مسعود -من طريق مُرَّة- في الآية، قال: أمّا الحسنى: فالجنَّةُ. وأما الزِّيادةُ: فالنظرُ إلى وجه الله. وأمّا القَتَرُ: فالسَّوادُ{12}. (٧/٦٥٦) ٣٤٤٠٨- عن حذيفةَ بن اليمان -من طريق مسلم بن نذير- في الآية، قال: والزِّيادةُ: النَّظَرُ إلى وجهِ الله{13}. (٧/٦٥٥) ٣٤٤٠٩- عن علي بن أبي طالب -من طريق الحارث- في قوله: <q>﴿لِلَّذِينَ أحْسَنُوا الحُسْنى﴾</q> قال: يعني: الجنةَ، <q>﴿وزِيادَةٌ﴾</q> يعني: النظرَ إلى الله{8}. (٧/٦٥٥) ٣٤٤١٠- عن علي بن أبي طالب -من طريق الحكم بن عتيبة- في الآيةِ، قال: الزيادةُ: غُرْفةٌ مِن لؤلؤةٍ واحدةٍ، لها أربعةُ أبوابٍ، غُرَفُها وأبْوابُها مِن لؤلؤةٍ واحدةٍ{15}. (٧/٦٥٧) ٣٤٤١١- عن أبي موسى الأشعريِّ -من طريق أبي تميمة- في الآية، قال: الحسنى: الجنةُ. والزِّيادةُ: النظرُ إلى وجهِ ربِّهم{16}٣١١٠. (٧/٦٥٦) ٣١١٠ علَّق ابنُ عطية (٤/٤٧٣) على هذا القول بقوله: «وروي في ذلك حديث عن النبي ﷺ، رواه صهيب». ٣٤٤١٢- عن عبد الله بن عباس -من طريق عكرمة- <q>﴿لِلَّذِينَ أحْسَنُوا﴾</q>، قال: قول: لا إله إلا الله. والحسنى: الجَنَّةُ. والزِّيادةُ: النظرُ إلى وجهِه الكريم{17}. (٧/٦٥٦) ٣٤٤١٣- عن عبد الله بن عباس -من طريق علي- <q>﴿لِلَّذِينَ أحْسَنُوا﴾</q>، قال: للذين شهِدوا أن لا إله إلا الله <q>﴿الحُسْنى﴾</q>: الجنَّةُ{18}. (٧/٦٥٦) ٣٤٤١٤- عن عبد الله بن عباس -من طريق عطية العوفي- في قوله: <q>﴿لِلَّذِينَ أحْسَنُوا الحُسْنى وزِيادَةٌ﴾</q>، قال: هو مِثْلُ قوله: <q>﴿ولَدَينا مَزِيدٌ﴾</q> [ق:٣٥]. يقول: يَجزِيهم بعملِهم ويزيدُهم من فضِله. وقال: <q>﴿مَن جَآءَ بِالحَسَنَةِ فَلَهُ عَشْرُ أمْثالِها﴾</q> [الأنعام:١٦٠]{19}٣١١١. (٧/٦٥٨) ٣١١١ علَّق ابنُ عطية (٤/٤٧٣-٤٧٤) على هذا القول الذي قاله عبد الله بن عباس من طريق العوفي، وعلقمة، والحسن من طريق قتادة، فقال: «وهذا قولٌ يعضده النظر، ولولا عظم القائلين بالقول الأول لَتَرَجَّح هذا القول، وطريق ترجيحه أنّ الآيةَ تتضمن اقتِرانًا بين ذِكْرِ عمال الحسنات وعمال السيئات، فوصف المحسنين بأنّ لهم على إحسانهم حُسْنى وزيادة من جنسها، ووصف المسيئين بأن لهم بالسيئة مثلها، فتعادل الكلامان. وعبَّر عن الحسنات بالحسنى مبالغة؛ إذ هي عشرة». ٣٤٤١٥- عن عبد الله بن عباس -من طريق الضَّحّاك- في قوله: <q>﴿للذين أحسنوا الحسنى﴾</q>، قال: الحسنى مثلها{20}. (ز) ٣٤٤١٦- عن يزيد بن شَجَرَةَ -من طريق منصور بن عمّار- قال: الزِّيادة: هي أن تَمُرَّ السَّحابة بأهل الجنة، فتمطرهم مِن كُلِّ النوادر، وتقول لهم: ما تريدون أن أُمْطِرَكم؟ فلا يريدون شيئًا إلا مَطَرَتْهُم{21}. (ز) ٣٤٤١٧- عن علقمة بن قيس النخعي -من طريق قابوس، عن أبيه- في الآيةِ، قال: الزِّيادةُ: العَشْرُ؛ <q>﴿مَن جَآءَ بِالحَسَنَةِ فَلَهُ عَشْرُ أمْثالِها﴾</q>{22}. (٧/٦٥٨) ٣٤٤١٨- عن عبد الرحمن بن أبي ليلى -من طريق ثابت- في قوله: <q>﴿لِلَّذِينَ أحْسَنُوا الحُسْنى وزِيادَةٌ﴾</q>، قال: إذا دخل أهلُ الجنةِ الجنةَ أُعطُوا منها ما شاءوا، ثم يُقالُ لهم: إنّه قد بَقِي مِن حَقِّكم شيءٌ لم تُعطَوْه. فيتجلّى اللهُ لهم، فيَصْغُرُ ما أُعطُوا عند ذلك. ثم تلا: <q>﴿لِلَّذِينَ أحْسَنُوا الحُسْنى﴾</q> قال: الجنة، <q>﴿وزِيادَةٌ﴾</q> قال: نظرُهم إلى ربِّهم ﷿{23}. (٧/٦٥٧) ٣٤٤١٩- عن سعيد بن المسيب -من طريق يحيى بن سعيد- في قول الله تعالى: <q>﴿للذين أحسنوا﴾</q>، قال: أحسنوا عبادةَ ربِّهم{20}. (ز) ٣٤٤٢٠- عن سعيد بن المسيب -من طريق يحيى- في قوله: <q>﴿لِلَّذِينَ أحْسَنُوا الحُسْنى وزِيادَةٌ﴾</q>، قال: <q>﴿أحْسَنُوا﴾</q>: شهادة أن لا إله إلا الله. و<q>﴿الحُسْنى﴾</q>: الجنَّة. والزيادة: النَّظَر إلى وجه الله{25}. (ز) ٣٤٤٢١- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿لِلَّذِينَ أحْسَنُوا الحُسْنى﴾</q> قال: مثلُها، قال: <q>﴿وزِيادَةٌ﴾</q> قال: مغفِرةٌ، ورِضوانٌ{26}. (٧/٦٥٨) ٣٤٤٢٢- عن مجاهد بن جبر= (ز) ٣٤٤٢٣- وأبي سنان: أنّ الزِّيادة: النَّظَر إلى وجْه الله ﷿{27}. (ز) ٣٤٤٢٤- عن الضحاك بن مزاحم: أنّ الحسنى: الجنةُ{28}. (ز) ٣٤٤٢٥- عن الضحاك بن مُزاحِم، قال: الزِّيادةُ: النَّظَرُ إلى وجهِ الله{29}. (٧/٦٥٧) ٣٤٤٢٦- عن عكرمة مولى ابن عباس -من طريق الحكم بن أبان- في قوله: <q>﴿لِلَّذِينَ أحْسَنُوا الحُسْنى وزِيادَةٌ﴾</q>، قال: قوله: <q>﴿أحْسَنُوا الحُسْنى﴾</q>: قول لا إله إلا الله. و<q>﴿الحُسْنى﴾</q>: الجنة. والزيادة: النظر إلى وجهه الكريم{30}. (ز) ٣٤٤٢٧- عن الحسن البصري -من طريق قتادة- في الآية، قال: الزِّيادةُ: الحسنةُ بعشرِ أمثالِها إلى سبعِمائةِ ضِعْفٍ{31}. (٧/٦٥٩) ٣٤٤٢٨- عن الحسن البصري -من طريق أبي بشر الحلبي- <q>﴿لِلَّذِينَ أحْسَنُوا الحُسْنى وزِيادَةٌ﴾</q>، قال: الحسنى: دخول الجنة. والزيادة: النظر إلى وجه الله{32}. (ز) ٣٤٤٢٩- عن أبي الجوزاء= (ز) ٣٤٤٣٠- وعطاء، نحو ذلك{33}. (ز) ٣٤٤٣١- عن قتادة بن دِعامة، <q>﴿لِلَّذِينَ أحْسَنُوا﴾</q> قال: شهادةُ أن لا إله إلا الله. <q>﴿الحُسْنى﴾</q> قال: الجنةُ. <q>﴿وزِيادَةٌ﴾</q> قال: النظرُ إلى وجْهِ اللهِ{34}. (٧/٦٥٧) ٣٤٤٣٢- عن قتادة بن دعامة -من طريق سعيد- قال: يُنادِي المنُادِي يومَ القيامةِ: إنّ اللهَ وعَدَ الحسنى، وهي الجَنَّةُ، فأما الزِّيادةُ: فهي النَّظرُ إلى وجهِ الرحمنِ. قال: فيتجلّى لهم حتى ينظُروا إليه{35}. (٧/٦٥٨) ٣٤٤٣٣- عن عبد الرحمن بن عبد الله بن سابط الجمحي -من طريق ليث- في قوله: <q>﴿للذين أحسنوا الحسنى﴾</q>، قال: الحسنى: النَّضْرَة. والزِّيادةُ: النظرُ إلى وجهِ الله تعالى{36}. (٧/٦٥٨) ٣٤٤٣٤- عن عامر بن سعد البَجَليِّ -من طريق أبي إسحاق- في قوله: <q>﴿لِلَّذِينَ أحْسَنُوا الحُسْنى وزِيادَةٌ﴾</q>، قال: النَّظَرُ إلى وجهِ الله{37}. (٧/٦٥٧) ٣٤٤٣٥- عن إسماعيل السُّدِّيّ، في قوله: <q>﴿لِلَّذِينَ أحْسَنُوا الحُسْنى﴾</q> قال: الجنَّةُ. <q>﴿وزِيادَةٌ﴾</q> قال: النَّظرُ إلى وجهِ الربِّ ﷿{29}. (٧/٦٥٧) ٣٤٤٣٦- عن أبي إسحاقَ السَّبيعيّ -من طريق شريك- في قوله: <q>﴿لِلَّذِينَ أحْسَنُوا الحُسْنى﴾</q> قال: الجَنَّةُ. <q>﴿وزِيادَةٌ﴾</q> قال: النَّظَرُ إلى وجهِ الرحمنِ ﷿{39}. (٧/٦٥٨) ٣٤٤٣٧- قال مقاتل بن سليمان: <q>﴿لِلَّذِينَ أحْسَنُواْ﴾</q> يعني: وحَّدوا الله <q>﴿الحُسْنى﴾</q> يعني: الجنَّة، <q>﴿وزِيادَةٌ﴾</q> يعني: فضل على الجنة؛ النَّظرُ إلى وجه الله الكريم{40}. (ز) ٣٤٤٣٨- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في الآية، قال: الزِّيادةُ: ما أعطاهم في الدنيا، لا يُحاسِبُهم به يومَ القيامةِ{41}. (٧/٦٥٩) ٣٤٤٣٩- عن عبد الرحمن بن زيد بن أسلم -من طريق أصْبَغ بن الفَرَج- في قول الله: <q>﴿للذين أحسنوا الحسنى﴾</q>، قال: الحسنى: الجَنَّة{20}٣١١٢. (ز) ٣١١٢ أفادت الآثارُ الاختلافَ في تفسير قوله: <q>﴿الحُسْنى وزِيادَةٌ﴾</q> على أقوال: أحدها: أنّ الحسنى: الجنة. والزيادة: النَّظَر إلى وجه الله تعالى. والثاني: أنّ الحسنى: واحدة من الحسنات. والزيادة: مضاعفتها إلى عشر أمثالها. الثالث: أنّ الحسنى: حسنة مثل حسنة. والزيادة: مغفرة ورضوان. والرابع: أنّ الحسنى: الجزاء في الآخرة. والزيادة: ما أُعْطُوا في الدنيا. ورجَّح ابنُ جرير (١٢/١٦٤-١٦٥) جميعَ تلك المعاني استنادًا إلى العموم، فقال: «وأَوْلى الأقوال في ذلك بالصواب أن يُقال: إنّ الله -تبارك وتعالى- وعد المحسنين من عباده على إحسانهم الحسنى أن يجزيهم على طاعتهم إيّاه الجنةَ، وأن تبْيَضَّ وجوهُهم، ووعدهم مع الحسنى الزيادةَ عليها، ومِن الزيادة على إدخالهم الجنة أن يكرمهم بالنظر إليه، وأن يعطيهم غُرَفًا من لآلئ، وأن يزيدهم غفرانًا ورضوانًا؛ كل ذلك مِن زيادات عطاءِ الله إيّاهم على الحسنى التي جعلها الله لأهل جناته. وعمَّ ربُّنا -جلَّ ثناؤه- بقوله: <q>﴿وزيادة﴾</q> الزيادات على الحسنى، فلم يُخَصِّص منها شيئًا دون شيء، وغير مستنكر من فضل الله أن يجمع ذلك لهم، بل ذلك كله مجموع لهم -إن شاء الله-. فأولى الأقوال في ذلك بالصواب أن يُعمّ كما عَمَّه -عزَّ ذِكْرُه-». وبنحوه قال ابنُ كثير (٧/٣٥٤). وعلَّق ابنُ عطية (٤/٤٧٤) على ترجيح ابن جرير للعموم بقوله: «ويُؤَيِّد ذلك أيضًا قولُه: <q>﴿أُولئِكَ أصْحابُ الجَنَّةِ﴾</q>». ورجَّح ابنُ عطية (٤/٤٧٣) القول الأول استنادًا إلى أقوال السلف. وكذا رجَّحه ابنُ القيم (٢/٣٥) استنادًا إلى السُّنَّة، وأقوال السلف، وذكر أنّ مَن فَسَّر الزيادة بالمغفرة والرضوان فهو من لوازم رؤيته -تبارك وتعالى-. وأورد ابنُ عطية (٤/٤٧٤) إشكالًا على القول الأول؛ بأنّه لو كان معنى الحسنى: الجُنَّة، لكان في القول تكرير بالمعنى، وأجاب عنه بقوله: «على أنّ هذا ينفصل عنه بأنّه وصف المحسنين بأنّ لهم الجنة، وأنّهم لا يرهق وجوهَهم قترٌ ولا ذِلَّة، ثم قال: <q>﴿أُولئِكَ أصْحابُ الجَنَّةِ﴾</q> على جهة المدح لهم، أي: أولئك مُسْتَحِقُّوها وأصحابها حقًّا وباستيجاب». <q>﴿وَلَا یَرۡهَقُ وُجُوهَهُمۡ قَتَرࣱ وَلَا ذِلَّةٌۚ أُو۟لَـٰۤىِٕكَ أَصۡحَـٰبُ ٱلۡجَنَّةِۖ هُمۡ فِیهَا خَـٰلِدُونَ ۝٢٦﴾</q> - تفسير ٣٤٤٤٠- عن صهيبٍ، عن النبيِّ ﷺ، <q>﴿ولا يَرهَقُ وُجُوهَهُم قَتَرٌ ولا ذِلَّةٌ﴾</q>، قال: «بعدَ نظرِهم إليه ﷿»{43}. (٧/٦٥٩) ٣٤٤٤١- عن عبد الله بن عباس -من طريق عطاء الخراساني- في قوله: <q>﴿ولا يَرهَقُ وُجُوهَهُم﴾</q> قال: لا يغشاهم <q>﴿قَتَرٌ﴾</q> قال: سَوادُ الوُجُوهِ{44}. (٧/٦٥٩) ٣٤٤٤٢- عن عبد الرحمن بن أبي ليلى -من طريق ثابت- في قوله: <q>﴿ولا يَرهَقُ وُجُوهَهُم قَتَرٌ ولا ذِلَّةٌ﴾</q>، قال: بعدَ نظرِهم إلى ربِّهم{45}. (٧/٦٦٠) ٣٤٤٤٣- عن مجاهد بن جبر -من طريق ابن أبي نَجِيح- في قوله: <q>﴿ولا يَرهَقُ وُجُوهَهُم قتر﴾</q>، قال: خِزْيٌ{46}. (٧/٦٥٩) ٣٤٤٤٤- عن عطاء، في الآية، قال: القَتَرُ: سَوادُ الوَجْهِ{34}. (٧/٦٥٩) ٣٤٤٤٥- عن إسماعيل السُّدِّيّ، نحو ذلك{48}. (ز) ٣٤٤٤٦- عن قتادة بن دعامة: <q>﴿ولا ذِلَّةٌ﴾</q>: كآبَة{49}. (ز) ٣٤٤٤٧- قال مقاتل بن سليمان: <q>﴿ولا يَرْهَقُ وُجُوهَهُمْ قَتَرٌ﴾</q> يعني: ولا يُصِيب وجوهَهم قَتَرٌ، يعني: سواد، ويُقال: كُسوف، ويقال: هو السواد، <q>﴿ولا ذِلَّةٌ﴾</q> يعني: ولا مَذَلَّة في أبدانهم عند مُعايَنَةِ النار، <q>﴿أُولئِكَ﴾</q> الذين هم بهذه المنزلة <q>﴿أصْحابُ الجَنَّةِ هُمْ فِيها خالِدُونَ﴾</q> لا يموتون{40}. (ز) ",footnotes:1:أخرجه مسلم ١/١٦٣ (١٨١)، وأحمد ٣١/٢٦٥ (١٨٩٣٥)، ٣١/٢٧٠ (١٨٩٤١)، ٣٩/٣٤٧-٣٤٨ (٢٣٩٢٥) واللفظ له، وابن جرير ١٢/١٦٠-١٦١، وابن أبي حاتم ٦/١٩٤٥ (١٠٣٤٠)، والثعلبي ٥/١٢٩. قال ابن كثير في تفسيره ٧/٣٥٥: «وهكذا رواه مسلم وجماعة من الأئمة من حديث حمّاد بن سلمة به».أخرجه الشاشيُّ في مسنده ٢/٣٨٩ (٩٩٠)، والدارقطنيُّ في كتاب رؤية الله ص١٣٢ (١٧٠)، وابن جرير ١٢/١٦٠، من طريق حمّاد، عن ثابت، عن عبد الرحمن بن أبي ليلى، عن صهيب به. إسناده صحيح، وأصله في صحيح مسلم، وهو المتقدِّم قبله.أخرجه الدارقطني في كتاب رؤية الله ص٦٧ (٥٣)، وابن النحاس في كتاب رؤية الله ص١٧ (٦)، وابن وهب في تفسيره ١/٧٦ (١٧١)، وابن جرير ١٢/١٥٨، وابن أبي حاتم ٦/١٩٤٥ (١٠٣٤١)، وابن مردويه -كما في تخريج أحاديث الكشاف ٢/١٢٥-، من طريقين: أبان بن أبي عياش، عن أبي تميمة الهجيمي، عن أبي موسى الأشعري، ومن طريق أبي بكر الهذلي، عن أبي تميمة الهجيمي، عن أبي موسى الأشعري. وكلا الإسنادين ضعيف جدًّا؛ أبان بن أبي عياش قال عنه ابن حجر في التقريب (١٤٢): «متروك». وأبوبكر الهذلي قال عنه في التقريب (٨٠٠٢): «متروك الحديث».أخرجه عبد الله بن أحمد في كتاب السنة ١/٢٦٢ (٤٨٤)، والطبراني في مسند الشاميين ٣/٣٠٢-٣٠٣ (٢٣٣٠)، وابن جرير ١٢/١٦١. قال ابن حجر في الفتح ٨/٣٤٧ عن إسناد ابن جرير: «في إسناده ضعف».أخرجه اللالكائي في شرح أصول اعتقاد أهل السنة ٣/٥٠٥-٥٠٦ (٧٨٠)، وابن جرير ١٢/١٦٢، وابن أبي حاتم ٦/١٩٤٤ (١٠٣٣٦)، وابن مردويه -كما في تخريج أحاديث الكشاف ٢/١٢٥-، من طريق عمرو بن أبي سلمة، سمعتُ زهيرًا عمَّن سمع أبا العالية، حدثنا أبي بن كعب به. إسناده ضعيف؛ لجهالة شيخ زهير الراوي عن أبي العالية. وأخرجه الدارقطني في الرؤية ص٢١٦ (١٣٥)، من طريق محمد بن زكريا بن دينار، حدثني قحطبة بن غدانة، حدثنا أبو خلدة، عن أبي العالية، عن أبي بن كعب به. إسناده ضعيف جِدًّا؛ فيه محمد بن زكريا بن دينار، وهو ضعيف، وقال الدارقطني: «يضع الحديث». كما في لسان الميزان لابن حجر ٧/١٣٩.أخرجه الحارث -كما في المطالب العالية ١٤/٧٢٠ (٣٦٣٠)-، من طريق داود بن المحبّر، عن عباد بن كثير، عن نافع، عن ابن عمر به. وعزاه السيوطي بهذا اللفظ إلى ابن مردويه. إسناده ضعيف جِدًّا؛ فيه داود بن المحبّر، قال عنه ابن حجر في التقريب (١٨١١): «متروك». وفيه عباد بن كثير الثقفي، قال ابن حجر في التقريب (٣١٣٩): «متروك».أخرجه الدارقطني في كتاب رؤية الله ص١٧١ (٥٧)، وابن منده في الرد على الجهمية ص٥١-٥٢، والثعلبي ٥/١٢٩. وفيه سلم بن سالم، ونوح بن أبي مريم. قال الذهبي في تاريخ الإسلام ٤٤/٣٩٤: «هذا حديث مُنكَر، انفرَد به سلم بن سالم البلخي، وهو ضعيف باتِّفاق، عن نوح الجامع شيخ مرو، وليس بثقة، بل تركوه». وقال ابن كثير في البداية والنهاية ٢٠/٣٦٦: «سلم وشيخه نوح بن أبي مريم مُتَكَلَّم فيهما».عزاه السيوطي إلى ابن مردويه.أي: ساحله. النهاية (سيف).أخرجه ابن أبي عاصم في الجهاد ٢/٧٠٢ (٣١٠).أخرجه يحيى بن سلام -كما في تفسير ابن أبي زمنين ٢/٢٥٢- بنحوه، وابن جرير ٢/١٥٦، وابن خزيمة (٢٦٤)، وابن منده في الرد على الجهمية (٨٤)، واللالكائي (٧٨٤)، والآجري في الشريعة (٥٨٩-٥٩١)، والبيهقي في الأسماء والصفات (٦٦٦)، وفي الاعتقاد ص١٣١، والخطيب ٩/١٣٤. وعلَّقه ابن أبي حاتم ٦/١٩٤٥. وعزاه السيوطي إلى ابن أبي شيبة، وابن المنذر، وأبي الشيخ، والدارقطني، وابن مردويه.أخرجه ابن أبي حاتم -كما في شرح أصول الاعتقاد للالكائي (٧٨٧، ٧٨٨)-.أخرجه ابن أبي شيبة ١٣/٣١٨، وابن جرير ١٢/١٥٧. وعلَّقه ابن أبي حاتم ٦/١٩٤٥، وابن خزيمة (٢٦٤، ٢٦٥)، واللالكائي (٧٨٣، ٧٨٤)، والآجري في الشريعة (٥٩١). وينظر: الاعتقاد للبيهقي ص١٣٢. وعزاه السيوطي إلى ابن المنذر، وأبي الشيخ، والدارقطني، والبيهقي.عزاه السيوطي إلى ابن مردويه.أخرجه سعيد بن منصور (١٠٥٨ - تفسير)، وابن جرير ١٢/١٦٢، وابن أبي حاتم ٦/١٩٤٥. وعزاه السيوطي إلى ابن المنذر، وأبي الشيخ، والبيهقي في الرؤية.أخرجه هناد في الزهد (١٦٩)، وابن جرير ١٢/١٥٧، ١٥٨، وابن أبي الدنيا في كتاب صفة الجنة - موسوعة الإمام ابن أبي الدنيا (٦/٣٤٠) رقم (٩٤)، وابن أبي حاتم ٦/١٩٤٥، واللالكائى (٧٨٥، ٧٨٦). وعزاه السيوطي إلى ابن المنذر، وأبي الشيخ، والدارقطني، والبيهقي.أخرجه البيهقى في الأسماء والصفات (٢٠٥). وعزاه السيوطي إلى ابن مردويه.أخرجه ابن جرير ١٢/١٦٤، وابن أبي حاتم ٦/١٩٤٤، والبيهقي في الأسماء والصفات (٢٠٦). وعزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ١٢/١٦٣.أخرجه ابن أبي حاتم ٦/١٩٤٤.تفسير الثعلبي ٥/١٢٩.أخرجه ابن جرير ١٢/١٦٣، وابن أبي حاتم ٦/١٩٤٦. وعزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ١٢/١٥٩. وعزاه السيوطي إلى الدارقطني. كما أخرجه ابن جرير بنحوه وزاد فيه: قال ابن أبي ليلى: فما ظنُّك بهم حين ثَقُلَتْ موازينهم، وحين صارت الصحف في أيمانهم، وحين جاوزوا جسر جهنم ودخلوا الجنة، وأُعْطُوا فيها ما أُعْطُوا مِن الكرامة والنعيم؟! كل ذلك لم يكن شيئًا فيما رَأَوْا.أخرجه ابن أبي حاتم ٦/١٩٤٤.أخرجه اللالكائي في شرح أصول اعتقاد أهل السنة والجماعة ٣/٥٠٩-٥١٠ (٧٨٩). وعلَّقه ابن أبي حاتم ٦/١٩٤٤.تفسير مجاهد ص٣٨٠، وأخرجه ابن جرير ١٢/١٦٣-١٦٤، وابن أبي حاتم ٦/١٩٤٥. وعزاه السيوطي إلى ابن أبي شيبة، وابن المنذر.علَّقه ابن أبي حاتم ٦/١٩٤٥.علَّقه ابن أبي حاتم ٦/١٩٤٤.علَّقه ابن أبي حاتم ٦/١٩٤٥. وعزاه السيوطي إلى الدارقطني.أخرجه اللالكائي في شرح أصول اعتقاد أهل السنة والجماعة ٣/٥١٢ (٧٩٦). وعلَّقه ابن أبي حاتم ٦/١٩٤٤.أخرجه ابن جرير ١٢/١٦٣. وعزاه السيوطي إلى ابن المنذر.أخرجه اللالكائي في شرح أصول اعتقاد أهل السنة والجماعة ٣/٥١٠ (٧٩٠)، وأخرج ابن جرير ١٢/١٦٠ شطره الثاني من طريق عوف. وعلَّقه ابن أبي حاتم ٦/١٩٤٥. وعزاه الحافظ في الفتح ٨/٣٤٧ إلى عبد بن حميد.تفسير الثعلبي ٥/١٢٩، وتفسير البغوي ٤/١٣٠.عزاه السيوطي إلى أبي الشيخ.أخرجه ابن جرير ١٢/١٦١. وعلَّقه ابن أبي حاتم ٦/١٩٤٥ بنحوه. وعزاه السيوطي إلى الدارقطني.أخرجه ابن جرير ١٢/١٦٢، وابن أبي حاتم ٦/١٩٤٥. وعزا السيوطيُّ شطره الثاني إلى الدارقطني.أخرجه ابن جرير ١٢/١٥٦، ١٥٧، ١٦١. وعلَّقه ابن أبي حاتم ٦/١٩٤٥. وعزاه السيوطي إلى الدارقطني.علَّقه ابن أبي حاتم ٦/١٩٤٥. وعزاه السيوطي إلى الدارقطني.أخرجه ابن جرير ١٢/١٥٧. وعلَّقه ابن أبي حاتم ٦/١٩٤٥. وعزاه السيوطي إلى الدارقطني.تفسير مقاتل بن سليمان ٢/٢٣٦.أخرجه ابن جرير ١٢/١٦٤. وعزاه السيوطي إلى أبي الشيخ.أخرجه ابن أبي حاتم ٦/١٩٤٤.أخرجه عبد الله بن أحمد في كتاب السنة ١/٢٤٣ (٤٤٣)، والبزار ٦/١٣-١٤ (٢٠٨٧) بنحوه مطولًا، من طريق حماد، عن ثابت، عن عبد الرحمن بن أبي ليلى، عن صُهَيْب به. إسناده صحيح.أخرجه ابن جرير ١٢/١٦٦، وابن أبي حاتم ٦/١٩٤٦. وعزاه السيوطي إلى ابن المنذر.أخرجه ابن أبي شيبة ١٣/٤٢٦، وابن جرير ١٢/٦٥٨، ٦٦١، وابن أبي حاتم ٦/١٩٤٦. وعزاه السيوطي إلى ابن المنذر، وأبي الشيخ، والدارقطني.أخرجه ابن أبي حاتم ٦/١٩٤٦.عزاه السيوطي إلى أبي الشيخ.علَّقه ابن أبي حاتم ٦/١٩٤٦.تفسير البغوي ٤/١٣٠.تفسير مقاتل بن سليمان ٢/٢٣٦.
10,27," <q>﴿وَٱلَّذِینَ كَسَبُوا۟ ٱلسَّیِّـَٔاتِ جَزَاۤءُ سَیِّئَةِۭ بِمِثۡلِهَا﴾</q> - تفسير ٣٤٤٤٨- عن مجاهد بن جبر -من طريق ابن أبي نجيح- قوله: <q>﴿سيئة﴾</q>، قال: الشَّرُّ{1}. (ز) ٣٤٤٤٩- عن إسماعيل السُّدِّيّ، في قوله: <q>﴿والَّذِينَ كَسَبُوا السَيِئاتِ﴾</q> قال: الذين عمِلوا الكبائرَ، <q>﴿جَزَآءُ سَيِئَةِ بِمِثْلِها﴾</q> قال: النارُ{2}٣١١٣. (٧/٦٦٠) ٣١١٣ ذَكَرَ ابنُ عطية (٤/٤٧٤) أنّ السيئاتِ تَعُمُّ الكفرَ والمعاصيَ، وأنّ مثلَ سيئة الكفر التخليدُ في النار، ومثلَ سيئة المعاصي مصروفٌ إلى مشيئة الله -تبارك وتعالى-. ٣٤٤٥٠- قال مقاتل بن سليمان: <q>﴿والَّذِينَ كَسَبُوا السَّيِّئاتِ﴾</q> يعني: عملوا الشرك <q>﴿جَزاءُ سَيِّئَةٍ بِمِثْلِها﴾</q> يعني: جزاء الشرك جهنم{3}. (ز) <q>﴿وَتَرۡهَقُهُمۡ ذِلَّةࣱۖ﴾</q> - تفسير ٣٤٤٥١- عن عبد الله بن عباس -من طريق علي- في قوله: <q>﴿وتَرْهَقُهُم ذِلَّةٌ﴾</q>، قال: تَغْشاهم ذِلَّةٌ، وشِدَّةٌ{4}. (٧/٦٦٠) ٣٤٤٥٢- عن إسماعيل السدي، في قوله: <q>﴿وتَرْهَقُهُم ذِلَّةٌ﴾</q>، قال: الذُّلُّ{2}. (٧/٦٦٠) ٣٤٤٥٣- قال مقاتل بن سليمان: <q>﴿وتَرْهَقُهُمْ ذِلَّةٌ﴾</q>، يعني: مَذَلَّة في أبدانهم{3}. (ز) <q>﴿مَّا لَهُم مِّنَ ٱللَّهِ مِنۡ عَاصِمࣲۖ﴾</q> - تفسير ٣٤٤٥٤- عن عبد الله بن عباس -من طريق علي- <q>﴿مّا لَهُم مِنَ الله مِن عاصِمٍ﴾</q>، يقول: مِن مانعٍ{7}. (٧/٦٦٠) ٣٤٤٥٥- عن قتادة بن دعامة -من طريق مَعْمَر- <q>﴿مّا لَهُم مِنَ الله مِن عاصِمٍ﴾</q>، قال: مِن نصيرٍ{8}. (٧/٦٦٠) ٣٤٤٥٦- قال مقاتل بن سليمان: <q>﴿ما لَهُمْ مِنَ اللَّهِ مِن عاصِمٍ﴾</q>، يعني: مانِع يمنعهم مِن العذاب{3}. (ز) <q>﴿كَأَنَّمَاۤ أُغۡشِیَتۡ وُجُوهُهُمۡ قِطَعࣰا مِّنَ ٱلَّیۡلِ مُظۡلِمًاۚ أُو۟لَـٰۤىِٕكَ أَصۡحَـٰبُ ٱلنَّارِۖ هُمۡ فِیهَا خَـٰلِدُونَ ۝٢٧﴾</q> - تفسير ٣٤٤٥٧- عن قتادة بن دِعامة -من طريق مَعْمَر- <q>﴿كَأَنَّمَآ أُغْشِيَتْ وجَوهَهَمْ قِطَعًا مِنَ الَّيلِ مظلما﴾</q>، قال: ظُلْمةً مِن الليل{10}. (٧/٦٦٠) ٣٤٤٥٨- عن إسماعيل السُّدِّيِّ، في قوله: <q>﴿كَأَنَّمَآ أُغشِيَتْ وجَوهَهَمْ قِطَعًا مِنَ الَّيلِ مُظلِمًا﴾</q>، قال: والقِطَعُ: السَّوادُ{2}. (٧/٦٦٠) ٣٤٤٥٩- قال مقاتل بن سليمان: <q>﴿كَأَنَّما أُغْشِيَتْ وُجُوهُهُمْ قِطَعًا مِنَ اللَّيْلِ مُظْلِمًا﴾</q> يعني: سواد الليل، <q>﴿أُولَئِكَ أصْحابُ النّارِ هُمْ فِيها خالِدُونَ﴾</q> لا يموتون{3}. (ز) <q>﴿كَأَنَّمَاۤ أُغۡشِیَتۡ وُجُوهُهُمۡ قِطَعࣰا مِّنَ ٱلَّیۡلِ مُظۡلِمًاۚ أُو۟لَـٰۤىِٕكَ أَصۡحَـٰبُ ٱلنَّارِۖ هُمۡ فِیهَا خَـٰلِدُونَ ۝٢٧﴾</q> - النَّسْخ في الآية ٣٤٤٦٠- عن إسماعيل السُّدِّيّ، قال: نسَخَتْها الآيةُ في البقرة [٨١]: <q>﴿بَلى مَن كَسَبَ سَيِئَةً﴾</q> الآيةَ{2}. (٧/٦٦٠) ",footnotes:1:أخرجه ابن أبي حاتم ٦/١٩٤٧.عزاه السيوطي إلى أبي الشيخ.تفسير مقاتل بن سليمان ٢/٢٣٦.أخرجه ابن جرير ١٢/١٦٧.عزاه السيوطي إلى أبي الشيخ.تفسير مقاتل بن سليمان ٢/٢٣٦.أخرجه ابن أبي حاتم ٦/١٩٤٧ بلفظ: شافع. وعزاه السيوطي إلى أبي الشيخ.أخرجه عبد الرزاق ١/٢٩٦، وابن أبي حاتم ٦/١٩٤٧. وعزاه السيوطي إلى ابن المنذر، وابن جرير، وأبي الشيخ.تفسير مقاتل بن سليمان ٢/٢٣٦.أخرجه عبد الرزاق ١/٢٩٦، وابن جرير ١٢/١٦٨، وابن أبي حاتم ٦/١٩٤٧. وعزاه السيوطي إلى ابن المنذر، وأبي الشيخ.عزاه السيوطي إلى أبي الشيخ.تفسير مقاتل بن سليمان ٢/٢٣٦.عزاه السيوطي إلى أبي الشيخ.
10,28," <q>﴿وَیَوۡمَ نَحۡشُرُهُمۡ جَمِیعࣰا﴾</q> - تفسير ٣٤٤٦١- عن عبد الله بن عباس -من طريق الضَّحّاك- قال: يُحْشَرُ كُلُّ شيء، حتى إنّ الذُّباب يُحْشَر{1}. (ز) ٣٤٤٦٢- عن مجاهد بن جبر -من طريق الأعمش، عمَّن سَمِعه- في قوله: <q>﴿ويَومَ نَحْشُرُهُمْ﴾</q>، قال: الحَشْرُ: المَوْتُ{2}٣١١٤. (٧/٦٦١) ٣١١٤ ذكر ابنُ جرير (١٢/١٧٢) أنّ الحشر: جَمْعُ الخلقِ لموقف الحساب جميعًا. ثم ساق قول مجاهد، ورجَّحه مستندًا إلى الدلالات العقلية، فقال: «لأنّ الله -تعالى ذِكْرُه- أخبر أنّه يقول يومئذٍ للذين أشركوا ما ذَكَر أنّه يقول لهم، ومعلوم أنّ ذلك غير كائن في القبر، وأنّه إنما هو خبرٌ عَمّا يُقال لهم ويقولون في الموقف بعد البعث». ٣٤٤٦٣- قال مقاتل بن سليمان: <q>﴿ويَوْمَ نَحْشُرُهُمْ جَمِيعًا﴾</q>، يعني: الكفار، وما عَبَدُوا من دون الله{3}. (ز) <q>﴿ثُمَّ نَقُولُ لِلَّذِینَ أَشۡرَكُوا۟ مَكَانَكُمۡ أَنتُمۡ وَشُرَكَاۤؤُكُمۡۚ﴾</q> - تفسير ٣٤٤٦٤- عن قتادة بن دِعامة -من طريق سعيد- قال: ما لله مِن شريكٍ في السَّماء، ولا في الأرض{4}. (ز) ٣٤٤٦٥- قال مقاتل بن سليمان: <q>﴿ثُمَّ نَقُولُ لِلَّذِينَ أشْرَكُوا مَكانَكُمْ أنْتُمْ وشُرَكاؤُكُمْ﴾</q>، يعني: الآلهة{3}. (ز) <q>﴿فَزَیَّلۡنَا بَیۡنَهُمۡۖ﴾</q> - تفسير ٣٤٤٦٦- قال مقاتل بن سليمان: <q>﴿فَزَيَّلْنا بَيْنَهُمْ﴾</q>، يعني: فمَيَّزْنا بين الجزاءين{3}. (ز) ٣٤٤٦٧- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿فَزَيَّلْنا بَيْنَهُمْ﴾</q>، قال: فَرَّقْنا بينَهم{7}. (٧/٦٦١) <q>﴿وَقَالَ شُرَكَاۤؤُهُم مَّا كُنتُمۡ إِیَّانَا تَعۡبُدُونَ ۝٢٨﴾</q> - تفسير ٣٤٤٦٨- قال مقاتل بن سليمان: <q>﴿وقالَ شُرَكاؤُهُمْ﴾</q> يعني: الآلهة، وهم الأصنام: <q>﴿ما كُنْتُمْ إيّانا تَعْبُدُونَ﴾</q>{3}. (ز) ٣٤٤٦٩- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قول الله: <q>﴿وقال شركاؤهم ما كنتم إيانا تعبدون﴾</q>، فقالوا: بلى، قد كُنّا نعبدكم{9}. (ز) ",footnotes:1:أخرجه ابن أبي حاتم ٤/١٣٢٣، ٦/١٩٤٧، ٨/٢٦٧١.أخرجه ابن جرير ١٢/١٧٢، وابن أبي حاتم ٦/١٩٤٧. وعزاه السيوطي إلى ابن المنذر، وأبي الشيخ.تفسير مقاتل بن سليمان ٢/٢٣٦.أخرجه ابن أبي حاتم ٦/١٩٤٨.تفسير مقاتل بن سليمان ٢/٢٣٦.تفسير مقاتل بن سليمان ٢/٢٣٦.أخرجه ابن جرير ١٢/١٧١، وابن أبي حاتم ٦/١٩٤٨. وعزاه السيوطي إلى أبي الشيخ.تفسير مقاتل بن سليمان ٢/٢٣٦.أخرجه ابن جرير ١٢/١٧١، وابن أبي حاتم ٦/١٩٤٨.
10,29," <q>﴿فَكَفَىٰ بِٱللَّهِ شَهِیدَۢا بَیۡنَنَا وَبَیۡنَكُمۡ إِن كُنَّا عَنۡ عِبَادَتِكُمۡ لَغَـٰفِلِینَ ۝٢٩﴾</q> - تفسير ٣٤٤٧٠- عن مجاهد بن جبر -من طريق ابن أبي نجيح- قال: يأتي على الناسِ يومَ القيامةِ ساعةٌ فيها لِينٌ، يَرى أهلُ الشركِ أهلَ التوحيدِ يُغْفَرُ لهم، فيقولون: <q>﴿واللهِ رَبِنا ما كُنّا مُشرِكِينَ﴾</q>. قال الله: <q>﴿انُظرْ كَيفَ كَذَبُوا عَلى أنفُسِهِم وضَلَّ عَنْهُم مّا كانُوا يَفْتَرُونَ﴾</q> [الأنعام:٢٣-٢٤]. ثم يكونُ مِن بعدِ ذلك ساعةٌ فيها شِدَّةٌ، تُنصَبُ لهم الآلِهَةُ التي كانوا يعبُدون مِن دونِ اللهِ، فيقول: هؤلاء الذين كنتُم تعبُدون من دون الله؟ فيقولون: نعم، هؤلاء الذين كُنّا نعبُدُ. فتقولُ لهم الآلهةُ: واللهِ، ما كُنّا نسمعُ، ولا نُبْصِرُ، ولا نعقِلُ، ولا نعلمُ أنّكم كنتُم تعبُدوننا. فيقولون: بلى، واللهِ، لَإيّاكم كُنّا نعبُدُ. فتقول لهم الآلهة: <q>﴿فَكَفى بِاللهِ شَهِيدا بَينَنا وبَينَكُم إن كُنّا عَن عِبادَتِكُم لَغافِلِينَ﴾</q>{1}٣١١٥. (٧/٦٦١) ٣١١٥ قال ابنُ عطية (٤/٤٧٦): «وظاهر هذه الآية: أنّ محاورتهم إنّما هي مع الأصنام، دون الملائكة وعيسى ابن مريم بدليل القول لهم: <q>﴿مكانكم أنتم وشركاؤكم﴾</q>، ودون فرعون ومَن عُبِد مِن الجن بدليل قولهم: <q>﴿إن كنا عن عبادتكم لغافلين﴾</q>، وهؤلاء لم يغفلوا قطُّ عن عبادة مَن عبدهم». ٣٤٤٧١- عن مجاهد بن جبر -من طريق ابن أبي نجيح- قوله: <q>﴿عن عبادتكم لغافلين﴾</q>، قال: ذلك كُلُّ شيءٍ يُعبَد مِن دون الله{2}. (ز) ٣٤٤٧٢- قال الحسن البصري: يَحْشُر اللهُ ﷿ الأوثانَ المعبودةَ في الدنيا بأعيانها، فتُخاصِمُ مَن كان عَبَدَها{3}. (ز) ٣٤٤٧٣- قال مقاتل بن سليمان: <q>﴿فَكَفى بِاللَّهِ شَهِيدًا بَيْنَنا وبَيْنَكُمْ إنْ كُنّا﴾</q> يعني: لقد كُنّا <q>﴿عَنْ عِبادَتِكُمْ﴾</q> إيّانا <q>﴿لَغافِلِينَ﴾</q>، وقد عَبَدتُمُونا وما نشعر بكم{4}. (ز) ٣٤٤٧٤- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهْب-: فقالوا: <q>﴿كفى بالله شهيدا بيننا وبينكم إن كنا عن عبادتكم لغافلين﴾</q> ما كُنّا نسمع، ولا نُبْصِر، ولا نتكلم. فقال الله: <q>﴿هنالك تبلو كل نفس ما أسلفت﴾</q>{5}. (ز) ",footnotes:1:أخرجه ابن جرير ١٢/١٧١، وابن أبي حاتم ٦/١٩٤٨. وعزاه السيوطي إلى ابن أبي شيبة، وابن المنذر، وأبي الشيخ.تفسير مجاهد ص٣٨٠، وأخرجه ابن جرير ١٢/١٧٢، وابن أبي حاتم ٦/١٩٤٩.ذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٢/٢٥٥-.تفسير مقاتل بن سليمان ٢/٢٣٦.أخرجه ابن جرير ١٢/١٧١، وابن أبي حاتم ٦/١٩٤٨ من طريق أصبغ بن الفرج.
10,30," <q>﴿هُنَالِكَ تَبۡلُوا۟ كُلُّ نَفۡسࣲ مَّاۤ أَسۡلَفَتۡۚ وَرُدُّوۤا۟ إِلَى ٱللَّهِ مَوۡلَىٰهُمُ ٱلۡحَقِّۖ وَضَلَّ عَنۡهُم مَّا كَانُوا۟ یَفۡتَرُونَ ۝٣٠﴾</q> - قراءات ٣٤٤٧٥- عن عبد الله بن مسعود أنّه كان يقرأُ: ‹هُنالِكَ تَتْلُواْ› بالتاءِ{1}٣١١٦. (٧/٦٦٢) ٣١١٦ اختُلِف في قراءة <q>﴿تبلوا﴾</q>؛ فقرأ قوم: <q>﴿تبلوا﴾</q>. وقرأ آخرون: <q>﴿تتلوا﴾</q>. وذكر ابنُ جرير (١٢/١٧٣-١٧٤) أنّ قراءة الباء بمعنى: عند ذلك تُختَبَر كلُّ نفس ما قدمت [كذا أثبتها وصححها الشيخ شاكر ١٥/٨٠، وفي طبعة التركي: بما قدمت] مِن خير أو شر. وبيَّن أن قراءة التاء اختُلِف في تفسيرها؛ فمنهم مَن فسرها بمعنى: تتبع ما قدَّمته من خير وشر. وفسَّرها آخرون: بالقراءة. وفسرها غيرهم: بالمعاينة. وبنحوه قال ابنُ عطية (٤/٤٧٧). وكذا ابنُ كثير (٧/٣٥٩-٣٦٠). ورجَّح ابنُ جرير (١٢/١٧٤-١٧٥) صِحَّة كِلتا القراءتين مستندًا إلى شهرتهما، واستفاضتهما، فقال: «والصوابُ من القول في ذلك أن يُقال: إنّهما قراءتان مشهورتان، قد قرأ بكلِّ واحدة منهما أئمةٌ مِن القراء، وهما متقاربتا المعنى؛ وذلك أنّ مَن تبع في الآخرة ما أسلف من العمل في الدنيا هُجِم به على مَورده، فيُخبَر هنالك ما أسلف من صالح أو سيِّءٍ في الدنيا، وإنّ مِن خَبَر ما أسلف في الدنيا مِن أعماله في الآخرة فإنما يُخبَر بعد مصيره إلى حيث أحلّه ما قدم في الدنيا من عمله، فهو في كلتا الحالتين مُتَّبِعٌ ما أسلف مِن عمله، مُخْتَبِر له، فبأيتهما قرأ القارِئُ كما وصفنا فمصيبٌ الصوابَ في ذلك». <q>﴿هُنَالِكَ تَبۡلُوا۟ كُلُّ نَفۡسࣲ مَّاۤ أَسۡلَفَتۡۚ﴾</q> - تفسير ٣٤٤٧٦- عن عبد الله بن مسعود، قال: قال رسول الله ﷺ: «يُمَثَّلُ لهم يومَ القيامةِ ما كانوا يعبُدون مِن دونِ اللهِ، فيَتَّبِعونهم حتى يُورِدُوهم النارِ». ثم تَلا رسولُ الله ﷺ: ‹هُنالِكَ تَتْلُواْ كُلُّ نَفسٍ مَّآ أسْلَفَت›{2}. (٧/٦٦١) ٣٤٤٧٧- عن عبد الله بن مسعود أنّه كان يقرأُ: ‹هُنالِكَ تَتْلُواْ› بالتاءِ. قال: هنالك تَتْبَعُ{3}. (٧/٦٦٢) ٣٤٤٧٨- قال عبد الله بن مسعود: هذا في البَعْثِ، ليس أحدٌ كان يعبدُ شيئًا مِن دون الله ﷿ إلا وهو مرفوع{4}. (ز) ٣٤٤٧٩- عن مجاهد بن جبر -من طريق ابن أبي نجيح- <q>﴿هُنالِكَ تَبلُوا﴾</q>، قال: تُخْتَبَرُ{5}. (٧/٦٦٢) ٣٤٤٨٠- عن الحسن البصري -من طريق الربيع بن عبد الله بن خطاف- <q>﴿هُنالِكَ تَبلُوا كُلُّ نَفسٍ مَّآ أسْلَفَت﴾</q>، قال: ما عمِلَتْ{6}. (٧/٦٦٢) ٣٤٤٨١- عن إسماعيل السُّدِّيّ، ‹هُنالِكَ تَتْلُوا›، يقول: تَتْبَعُ{7}. (٧/٦٦٢) ٣٤٤٨٢- قال مقاتل بن سليمان: <q>﴿هُنالِكَ﴾</q> يعني: عند ذلك <q>﴿تَبْلُواْ﴾</q> يعني: تختبر <q>﴿كُلُّ نَفْسٍ ما أسْلَفَتْ﴾</q> يعني: ما قَدَّمَتْ، <q>﴿ورُدُّوا إلى اللَّهِ مَوْلاهُمُ الحَقِّ وضَلَّ عَنْهُمْ ما كانُوا يَفْتَرُونَ﴾</q> يعني: يعبدون في الدنيا مِن الآلهة{8}. (ز) ٣٤٤٨٣- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- <q>﴿هُنالِكَ تَبلُوا كل نفس مَّآ أسْلَفَت﴾</q>، قال: ما عمِلَت. ›تَتْلُوا‹: تُعايِنُه{9}. (٧/٦٦٢) <q>﴿وَرُدُّوۤا۟ إِلَى ٱللَّهِ مَوۡلَىٰهُمُ ٱلۡحَقِّۖ وَضَلَّ عَنۡهُم مَّا كَانُوا۟ یَفۡتَرُونَ ۝٣٠﴾</q> - تفسير ٣٤٤٨٤- عن عبد الله بن عباس -من طريق الضَّحّاك- قوله: <q>﴿وضل عنهم﴾</q> هذا في القيامة <q>﴿ما كانوا يفترون﴾</q> أي: يُشْرِكون{10}. (ز) ٣٤٤٨٥- قال مقاتل بن سليمان: <q>﴿ورُدُّوا إلى اللَّهِ مَوْلاهُمُ الحَقِّ وضَلَّ عَنْهُمْ ما كانُوا يَفْتَرُونَ﴾</q>، يعني: يعبدون في الدنيا مِن الآلهة{8}. (ز) ٣٤٤٨٦- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- <q>﴿وضَلَّ عَنْهُم مّا كانُوا يَفْتَرُونَ﴾</q>، قال: ما كانوا يدْعُون معه مِن الأندادِ{12}. (٧/٦٦٢) <q>﴿وَرُدُّوۤا۟ إِلَى ٱللَّهِ مَوۡلَىٰهُمُ ٱلۡحَقِّۖ وَضَلَّ عَنۡهُم مَّا كَانُوا۟ یَفۡتَرُونَ ۝٣٠﴾</q> - النسخ في الآية ٣٤٤٨٧- عن إسماعيل السُّدِّيّ، في قوله: <q>﴿ورُدُّوا إلى اللهِ مَولاهُمُ الحَقِ﴾</q>، قال: نسَخَها قولُه: <q>﴿ذَلِكَ بِأَنَّ اللَّهَ مَولى الَّذِينَ آمَنُوا وأَنَّ الكافِرِينَ لا مَولى لهم﴾</q> [محمد:١١]{7}. (٧/٦٦٢) <q>﴿وَرُدُّوۤا۟ إِلَى ٱللَّهِ مَوۡلَىٰهُمُ ٱلۡحَقِّۖ وَضَلَّ عَنۡهُم مَّا كَانُوا۟ یَفۡتَرُونَ ۝٣٠﴾</q> - آثار متعلقة بالآية ٣٤٤٨٨- عن قيس، قال: دخل عثمانُ على عبد الله بن مسعود ﵄، فقال: كيف تَجِدُك؟ قال: مردودٌ إلى مولاي الحق{6}. (ز) ",footnotes:1:عزاه السيوطي إلى ابن المنذر. وهي قراءة متواترة، قرأ بها حمزة، والكسائي، وخلف العاشر، وقرأ بقية العشرة: <q>﴿تَبْلُواْ﴾</q> بالباء. انظر: النشر ٢/٢٨٣.عزاه السيوطي إلى ابن مردويه. قال ابن جرير ١٢/١٧٤: «وروي بنحو ذلك خبرٌ عن النبيِّ، مِن وجهٍ وسندٍ غير مُرتَضى ...». وذكره.عزاه السيوطي إلى ابن المنذر.ذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٢/٢٥٥-.تفسير مجاهد ص٣٨١، وأخرجه ابن جرير ١٢/١٧٣، وابن أبي حاتم ٦/١٩٤٩. وذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٢/٢٥٥-. وعزاه السيوطي إلى ابن أبي شيبة، وابن المنذر، وأبي الشيخ.أخرجه ابن أبي حاتم ٦/١٩٤٩.عزاه السيوطي إلى أبي الشيخ.تفسير مقاتل بن سليمان ٢/٢٣٦.أخرجه ابن جرير ١٢/١٧٤. وعلَّقه ابن أبي حاتم ٦/١٩٤٩. وعزاه السيوطي إلى أبي الشيخ.أخرجه ابن أبي حاتم ٦/١٩٥٠.تفسير مقاتل بن سليمان ٢/٢٣٦.أخرجه ابن جرير ١٢/١٧٥. وعزاه السيوطي إلى أبي الشيخ.عزاه السيوطي إلى أبي الشيخ.أخرجه ابن أبي حاتم ٦/١٩٤٩.
10,31," <q>﴿قُلۡ مَن یَرۡزُقُكُم مِّنَ ٱلسَّمَاۤءِ وَٱلۡأَرۡضِ أَمَّن یَمۡلِكُ ٱلسَّمۡعَ وَٱلۡأَبۡصَـٰرَ﴾</q> - تفسير ٣٤٤٨٩- قال مقاتل بن سليمان: <q>﴿قُلْ﴾</q> لكُفّار قريش: <q>﴿مَن يَرْزُقُكُمْ مِنَ السَّماءِ﴾</q> يعني: المطر، <q>﴿و﴾</q>مِن <q>﴿الأَرْضِ﴾</q> يعني: النبات والثمار، <q>﴿أمَّنْ يَمْلِكُ السَّمْعَ﴾</q> فيُسْمِعُها المواعظ، <q>﴿والأَبْصارَ﴾</q> فيُرِيها العَظَمَة{1}. (ز) <q>﴿وَمَن یُخۡرِجُ ٱلۡحَیَّ مِنَ ٱلۡمَیِّتِ وَیُخۡرِجُ ٱلۡمَیِّتَ مِنَ ٱلۡحَیِّ﴾</q> - تفسير ٣٤٤٩٠- قال مجاهد بن جبر، في قوله: <q>﴿ومن يخرج الحي من الميت ويخرج الميت من الحي﴾</q>، يعني: يُخْرِج الناسَ الأحياءَ مِن النُّطَف، والنُّطَفَ مِن الناس الأحياء، والأنعام مثل ذلك، والنبات مثل ذلك{2}. (ز) ٣٤٤٩١- قال الحسن البصري: يعني: يُخرِج المؤمنَ مِن الكافر، والكافرَ مِن المؤمن{2}. (ز) ٣٤٤٩٢- قال مقاتل بن سليمان: <q>﴿ومَن يُخْرِجُ الحَيَّ مِنَ المَيِّتِ﴾</q> يعني: النَّسَمة الحيَّة مِن النُّطْفَة، <q>﴿ويُخْرِجُ المَيِّتَ مِنَ الحَيِّ﴾</q>{1}. (ز) <q>﴿وَمَن یُدَبِّرُ ٱلۡأَمۡرَۚ فَسَیَقُولُونَ ٱللَّهُۚ فَقُلۡ أَفَلَا تَتَّقُونَ ۝٣١﴾</q> - تفسير ٣٤٤٩٣- عن مجاهد بن جبر -من طريق ابن أبي نجيح- <q>﴿يدبر الأمر﴾</q>، قال: يقضيه وحدَه{5}. (ز) ٣٤٤٩٤- قال مقاتل بن سليمان: <q>﴿ومَن يُدَبِّرُ الأَمْرَ﴾</q> يعني: أمر الدنيا، يعني: القضاء، وحدَه، <q>﴿فَسَيَقُولُونَ﴾</q> فسيقول مُشْرِكو قريش: <q>﴿اللَّهُ﴾</q> يفعلُ ذلك. فإذا أقرُّوا بذلك <q>﴿فَقُلْ﴾</q> يا محمد: <q>﴿أفَلا﴾</q> يعني: أفَهَلّا <q>﴿تَتَّقُونَ﴾</q> الشِّرْكَ. يعني: فهَلّا تحذرون العقوبةَ والنِّقمةَ{1}. (ز) ",footnotes:1:تفسير مقاتل بن سليمان ٢/٢٣٧.ذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٢/٢٥٥-.ذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٢/٢٥٥-.تفسير مقاتل بن سليمان ٢/٢٣٧.أخرجه ابن أبي حاتم ٦/١٩٥٠.تفسير مقاتل بن سليمان ٢/٢٣٧.
10,32," <q>﴿فَذَ ٰ⁠لِكُمُ ٱللَّهُ رَبُّكُمُ ٱلۡحَقُّۖ فَمَاذَا بَعۡدَ ٱلۡحَقِّ إِلَّا ٱلضَّلَـٰلُۖ﴾</q> - تفسير ٣٤٤٩٥- قال مقاتل بن سليمان: <q>﴿فَذلِكُمُ اللَّهُ رَبُّكُمُ الحَقُّ فَماذا بَعْدَ الحَقِّ إلّا الضَّلالُ﴾</q>: فماذا بعد عبادةِ الحقِّ والإيمان إلا الباطل، <q>﴿فَأَنّى تُصْرَفُونَ﴾</q>{1}. (ز) <q>﴿فَأَنَّىٰ تُصۡرَفُونَ ۝٣٢﴾</q> - تفسير ٣٤٤٩٦- عن عبد الله بن عباس -من طريق الضحاك- في قوله: <q>﴿فأنى﴾</q>، قال: كيف{2}. (ز) ٣٤٤٩٧- قال محمد بن السائب الكلبي: <q>﴿فَأَنّى تُصْرَفُونَ﴾</q>: فمِن أين تُصرَفون عن عبادته وأنتم مُقِرُّون؟!{3}. (ز) <q>﴿فَأَنَّىٰ تُصۡرَفُونَ ۝٣٢﴾</q> - آثار متعلقة بالآية ٣٤٤٩٨- عن حَرْملةَ بن عبد العزيز، قال: قلتُ لِمالكِ بنِ أنسٍ: ما ترى في رجل أمرُه يُعَنِّيني؟{4} قال: ليس ذلك من الحقِّ؛ قال الله: <q>﴿فَماذا بَعْدَ الحَقِ إلا الضَّلالُ﴾</q>{2}. (٧/٦٦٢) ٣٤٤٩٩- عن أشْهَبَ، قال: سُئِل مالكٌ عن شهادةِ اللُّعّابِ بالشِّطْرَنجِ، والنَّرْدِ. فقال: أمّا مَن أدْمَنَها فما أرى شهادتَهم طائلةً؛ يقول الله: <q>﴿فَماذا بَعْدَ الحَقِ إلا الضَّلالُ﴾</q>، فهذا كُلُّه مِن الضلال{2}. (٧/٦٦٣) ٣٤٥٠٠- عن همام بن مسلم، قال: سُئِل مالك عن اللعب بالشِّطْرَنجِ. فقال: أمِن الحقِّ هي؟ قيل: لا. فتلا هذه الآية: <q>﴿فَماذا بَعْدَ الحَقِ إلا الضَّلالُ﴾</q>{7}. (٧/٦٦٣) ",footnotes:1:تفسير مقاتل بن سليمان ٢/٢٣٧.أخرجه ابن أبي حاتم ٦/١٩٥١.تفسير الثعلبي ٥/١٣١.عنّاه: كلفه ما يشق عليه. الوسيط (عنو)أخرجه ابن أبي حاتم ٦/١٩٥١.أخرجه ابن أبي حاتم ٦/١٩٥١.عزاه السيوطي إلى أبي الشيخ.
10,33," <q>﴿كَذَ ٰ⁠لِكَ حَقَّتۡ كَلِمَتُ رَبِّكَ عَلَى ٱلَّذِینَ فَسَقُوۤا۟﴾</q> - تفسير ٣٤٥٠١- عن عبد الله بن عباس -من طريق الضحاك- في قوله: <q>﴿كَذَلِكَ حَقَّتْ كَلِمَتُ رَبِكَ﴾</q>، يقول: سَبَقَتْ كلمةُ ربِّك{1}. (٧/٦٦٣) ٣٤٥٠٢- عن الضحاك بن مزاحم، <q>﴿كَذَلِكَ حَقَّتْ﴾</q>، يقول: صَدَقَتْ{2}. (٧/٦٦٣) ٣٤٥٠٣- قال محمد بن السائب الكلبي: <q>﴿كَذَلِكَ﴾</q>: هكذا{3}. (ز) <q>﴿أَنَّهُمۡ لَا یُؤۡمِنُونَ ۝٣٣﴾</q> - تفسير ٣٤٥٠٤- عن مجاهد بن جبر -من طريق ابن كثير- قوله: <q>﴿لا يؤمنون﴾</q>، قال: إذا جاءت بخبر لا يؤمنون{4}. (ز) ٣٤٥٠٥- قال مقاتل بن سليمان: <q>﴿كَذلِكَ حَقَّتْ كَلِمَةُ رَبِّكَ عَلى الَّذِينَ فَسَقُوا أنَّهُمْ لا يُؤْمِنُونَ﴾</q>، فأخبر بعلمه السابق فيهم أنّهم لا يؤمنون{5}. (ز) ",footnotes:1:أخرجه ابن أبي حاتم ٦/١٩٥١. وعزاه السيوطي إلى أبي الشيخ.عزاه السيوطي إلى أبي الشيخ.تفسير البغوي ٤/١٣٢.أخرجه ابن أبي حاتم ٦/١٩٥١.تفسير مقاتل بن سليمان ٢/٢٣٧.
