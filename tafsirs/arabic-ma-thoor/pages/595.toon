  92,7,""
92,8," <q>﴿وَأَمَّا مَنۢ بَخِلَ وَٱسۡتَغۡنَىٰ ۝٨﴾</q> - تفسير ٨٣٦٢٠- عن عبد الله بن عباس -من طريق أبي صالح- في قوله: <q>﴿وأَمّا مَن بَخِلَ واسْتَغْنى وكَذَّبَ بِالحُسْنى﴾</q>، قال: أبو سفيان بن حرب{1}. (١٥/٤٧٢) ٨٣٦٢١- عن عبد الله بن عباس -من طريق عطية العَوفيّ- <q>﴿وأَمّا مَن بَخِلَ واسْتَغْنى﴾</q>، يقول: مَن أغناه الله فبخل بالزَّكاة{2}. (١٥/٤٧١) ٨٣٦٢٢- عن عبد الله بن عباس -من طريق عكرمة- في قوله: <q>﴿وأَمّا مَن بَخِلَ واسْتَغْنى﴾</q>، قال: بخل بماله، واستغنى عن ربّه{3}. (١٥/٤٧٠) ٨٣٦٢٣- عن عبد الله بن عباس -من طريق عكرمة- في قوله: <q>﴿وأَمّا مَن بَخِلَ واسْتَغْنى﴾</q>، قال: بخل بما عنده، واستغنى في نفسه{2}. (ز) ٨٣٦٢٤- عن الحسن البصري -من طريق أبي الأشهب- في قوله ﷿: <q>﴿وأما من بخل واستغنى﴾</q>، قال: بخل بما لم يَبقَ، واستغنى بغير غِنًى{5}. (ز) ٨٣٦٢٥- عن قتادة بن دعامة -من طريق سعيد- <q>﴿وأَمّا مَن بَخِلَ﴾</q> قال: بحقّ الله عليه، <q>﴿واسْتَغْنى﴾</q> في نفسه عن ربّه{6}. (١٥/٤٧١) ٨٣٦٢٦- قال مقاتل بن سليمان: <q>﴿وأَمّا مَن بَخِلَ واسْتَغْنى﴾</q> عن الله تعالى في نفسه{7}٧١٩٩. (ز) ٧١٩٩ ذكر ابنُ عطية (٨/٦٣٥) في معنى الآية أنّ مَن «جعل <q>﴿بَخِلَ﴾</q> في المال خاصةً جعل»استغنى«في المال أيضًا لتعظم المذمَّة، ومَن جعل <q>﴿بَخِلَ﴾</q> عامًّا في جميع ما ينبغي أن نبذل من قول وفعل قال:»استغنى«عن الله تعالى ورحمته بزعمه». ",footnotes:1:أخرجه ابن عساكر ٣٠/٦٩-٧٠. وعزاه السيوطي إلى عبد بن حميد، وابن مردويه.أخرجه ابن جرير ٢٤/٤٦٧.أخرجه ابن جرير ٢٤/٤٦٧، وابن أبي حاتم -كما في تفسير ابن كثير ٨/٤٣٩، والتغليق ٤/٣٧٠، وفتح الباري ٨/٧٠٦-، والبيهقي في شعب الإيمان (١٠٨٢٥). وعزاه السيوطي إلى سعيد بن منصور، وعبد بن حميد، وابن المنذر.أخرجه ابن جرير ٢٤/٤٦٧.أخرجه أحمد في الزهد ص٣٤٩.أخرجه ابن جرير ٢٤/٤٦٧. وعزاه السيوطي إلى عبد بن حميد، وابن أبي حاتم.تفسير مقاتل بن سليمان ٤/٧٢٢.
92,9," <q>﴿وَكَذَّبَ بِٱلۡحُسۡنَىٰ ۝٩﴾</q> - تفسير ٨٣٦٢٧- عن عبد الله بن مسعود -من طريق يونس بن أبي إسحاق- <q>﴿وأما من بخل واستغنى وكذب بالحسنى﴾</q>: بلا إله إلا الله؛ أُميّة بن خلف، وأُبيّ بن خلف{1}. (ز) ٨٣٦٢٨- عن عبد الله بن عباس -من طريق عكرمة- في قوله: <q>﴿وكَذَّبَ بِالحُسْنى﴾</q>، قال: بالخَلف من الله{2}. (١٥/٤٧٠) ٨٣٦٢٩- عن عبد الله بن عباس -من طريق عطية العَوفيّ- <q>﴿وكَذَّبَ بِالحُسْنى﴾</q>: وكذّب بلا إله إلا الله{3}. (ز) ٨٣٦٣٠- عن مجاهد بن جبر -من طريق ابن أبي نجيح- <q>﴿وكَذَّبَ بِالحُسْنى﴾</q>، قال: بالجنة{3}. (ز) ٨٣٦٣١- عن الضَّحّاك بن مُزاحِم -من طريق عبيد- في قوله: <q>﴿وكَذَّبَ بِالحُسْنى﴾</q> أي: بلا إله إلا الله{3}. (ز) ٨٣٦٣٢- عن قتادة بن دعامة -من طريق معمر- <q>﴿وكَذَّبَ بِالحُسْنى﴾</q>، قال: بموعود الله الذي وعد{6}. (١٥/٤٧١) ٨٣٦٣٣- قال مقاتل بن سليمان: <q>﴿وكَذَّبَ بِالحُسْنى﴾</q>، يعني: بعِدَة الله بأن يخلفه خيرًا منه{7}٧٢٠٠. (ز) ٧٢٠٠ اختُلف في معنى: <q>﴿وكَذَّبَ بِالحُسْنى﴾</q> على نحو اختلافهم في قوله تعالى: <q>﴿وصَدَّقَ بِالحُسْنى﴾</q>. ورجَّح ابنُ جرير (٢٤/٤٦٧) أنّ المعنى: وكذَّب بالخَلَف. نحو ترجيحه في الآية الأخرى. ",footnotes:1:أخرجه الطبراني في الدعاء ٣/١٥٢٥، وبنحوه ابن عساكر من طريق أبي إسحاق ٣٠/٦٨، ٦٩. وعزا السيوطي نحوه إلى ابن أبي حاتم، وأبي الشيخ.أخرجه ابن جرير ٢٤/٤٦٨، وابن أبي حاتم -كما في تفسير ابن كثير ٨/٤٣٩، والتغليق ٤/٣٧٠، وفتح الباري ٨/٧٠٦-، والبيهقي في شعب الإيمان (١٠٨٢٥). وعزاه السيوطي إلى سعيد بن منصور، وعبد بن حميد، وابن المنذر.أخرجه ابن جرير ٢٤/٤٦٨.أخرجه ابن جرير ٢٤/٤٦٨.أخرجه ابن جرير ٢٤/٤٦٨.أخرجه عبد الرزاق ٢/٣٧٧، وابن جرير ٢٤/٤٦٨، وكذلك من طريق سعيد أيضًا. وعزاه السيوطي إلى عبد بن حميد، وابن أبي حاتم.تفسير مقاتل بن سليمان ٤/٧٢٢.
92,10," <q>﴿فَسَنُیَسِّرُهُۥ لِلۡعُسۡرَىٰ ۝١٠﴾</q> - تفسير ٨٣٦٣٤- عن عبد الله بن مسعود -من طريق أبي إسحاق- <q>﴿فَسَنُيَسِّرُهُ لِلْعُسْرى﴾</q>، قال: النار{1}. (١٥/٤٧٠) ٨٣٦٣٥- عن عبد الله بن عباس -من طريق عكرمة- في قوله: <q>﴿فَسَنُيَسِّرُهُ لِلْعُسْرى﴾</q>، قال: للشّرّ من الله{2}٧٢٠١. (١٥/٤٧٠-٤٧١) ٧٢٠١ لم يذكر ابنُ جرير (٢٤/٤٦٩-٤٧٣) في معنى: <q>﴿فَسَنُيَسِّرُهُ لِلْعُسْرى﴾</q> سوى قول ابن عباس، والآثار المرفوعة الواردة في تفسير الآيات بعد نزول الآيات. ٨٣٦٣٦- عن عبد الله بن عباس -من طريق عكرمة- في قوله تعالى: <q>﴿فَسَنُيَسِّرُهُ لِلْعُسْرى﴾</q>، قال: بالإمساك{3}. (ز) ٨٣٦٣٧- قال مقاتل بن سليمان: <q>﴿فَسَنُيَسِّرُهُ لِلْعُسْرى﴾</q>، يقول: نُعسّر عليه أن يعطي خيرًا{4}. (ز) ",footnotes:1:أخرجه ابن عساكر ٣٠/٦٨-٦٩. وعزاه السيوطي إلى ابن أبي حاتم، وأبي الشيخ.أخرجه ابن جرير ٢٤/٤٧٣، وابن أبي حاتم -كما في تفسير ابن كثير ٨/٤٣٩، والتغليق ٤/٣٧٠، وفتح الباري ٨/٧٠٦-، والبيهقي في شعب الإيمان (١٠٨٢٥). وعزاه السيوطي إلى سعيد بن منصور، وعبد بن حميد، وابن المنذر.أخرجه قوام السنة في الترغيب والترهيب ٢/٢٢٥ (١٤٧٩).تفسير مقاتل بن سليمان ٤/٧٢٢.
92,11," <q>﴿وَمَا یُغۡنِی عَنۡهُ مَالُهُۥۤ إِذَا تَرَدَّىٰۤ ۝١١﴾</q> - نزول الآية ٨٣٦٣٨- عن عبد الله بن عباس، قال: نزلت في أبي جهل{1}. (١٥/٤٧٤) ٨٣٦٣٩- قال محمد بن السّائِب الكلبي: <q>﴿وما يُغْنِي عَنْهُ مالُهُ إذا تَرَدّى﴾</q> نزلت في أبي سفيان بن حرب{2}. (ز) ٨٣٦٤٠- قال مقاتل بن سليمان: <q>﴿وما يُغْنِي عَنْهُ مالُهُ إذا تَرَدّى﴾</q>، يعني: أبا سفيان{3}. (ز) <q>﴿وَمَا یُغۡنِی عَنۡهُ مَالُهُۥۤ إِذَا تَرَدَّىٰۤ ۝١١﴾</q> - تفسير الآية ٨٣٦٤١- عن عبد الله بن عباس -من طريق عكرمة- في قوله تعالى: <q>﴿وما يُغْنِي عَنْهُ مالُهُ﴾</q> الذي أمسك <q>﴿إذا تَرَدّى﴾</q> إذا هلك{4}. (ز) ٨٣٦٤٢- عن عبد الله بن عباس: أنّ نافع بن الأزرق قال له: أخبِرني عن قوله ﷿: <q>﴿إذا تَرَدّى﴾</q>. قال: إذا تردّى ودخل في النار، نزلت في أبي جهل. قال: وهل تعرف العرب ذلك؟ قال: نعم أما سمعتَ قول عدي بن زيد: خَطَفَتْه منيّةٌ فتردّى وهو في الملك يأَمُل التعميرا؟{1}. (١٥/٤٧٤) ٨٣٦٤٣- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿إذا تَرَدّى﴾</q>، قال: إذا مات{6}. (١٥/٤٧٥) ٨٣٦٤٤- عن أبي صالح [باذام] -من طريق إسماعيل- <q>﴿وما يُغْنِي عَنْهُ مالُهُ إذا تَرَدّى﴾</q>، قال: في النار{7}. (١٥/٤٧٥) ٨٣٦٤٥- عن قتادة بن دعامة -من طريق معمر- <q>﴿إذا تَرَدّى﴾</q>، قال: في النار{8}. (١٥/٤٧٤) ٨٣٦٤٦- قال مقاتل بن سليمان: <q>﴿وما يُغْنِي عَنْهُ مالُهُ﴾</q> الذي بخل به في الدنيا <q>﴿إذا تردى﴾</q> يعني: إذا مات، وتريد{9} في النار{3}٧٢٠٢. (ز) ٧٢٠٢ اختُلف في معنى: <q>﴿إذا تَرَدّى﴾</q> في هذه الآية على قولين: الأول: إذا سقط في جهنم فهوى. الثاني: إذا مات. ورجَّح ابنُ جرير (٢٤/٤٧٥) القول الأول مستندًا إلى الأغلب لغة، وهو قول ابن عباس، وأبي صالح، وقتادة، وعلَّل ذلك بقوله: «لأن ذلك هو المعروف من التَّردِّي، فأما إذا أريد معنى الموت فإنه يقال: رَدِي فلانٌ، وقلَّما يُقال: تردّى». وزاد ابنُ عطية (٨/٦٣٥) عن قوم أن المعنى: «تردّى بأكفانه من الرداء». واستشهد ببيتٍ من الشعر. ",footnotes:1:أخرجه الطستي في مسائله -كما في الإتقان ٢/٧٨-.تفسير الثعلبي ١٠/٢١٨.تفسير مقاتل بن سليمان ٤/٧٢٢.أخرجه قوام السنة في الترغيب والترهيب ٢/٢٢٥ (١٤٧٩).أخرجه الطستي في مسائله -كما في الإتقان ٢/٧٨-.تفسير مجاهد ص٥١٠، وأخرجه الفريابي-كما في التغليق ٤/٣٧٠، وفتح الباري ٨/٧٠٦-، وابن جرير ٢٤/٤٧٤-٤٧٦. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.أخرجه ابن أبي شيبة ١٣/١٦٨، وابن جرير ٢٤/٤٧٤ بنحوه.أخرجه عبد الرزاق ٢/٣٧٧، وابن جرير ٢٤/٤٧٤. وعزاه السيوطي إلى عبد بن حميد.كذا في مطبوعة المصدر.تفسير مقاتل بن سليمان ٤/٧٢٢.
92,12," <q>﴿إِنَّ عَلَیۡنَا لَلۡهُدَىٰ ۝١٢﴾</q> - تفسير ٨٣٦٤٧- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿إنَّ عَلَيْنا لَلْهُدى﴾</q>، يقول: على الله البيان؛ بيان حلاله وحرامه، وطاعته ومعصيته{1}٧٢٠٣. (١٥/٤٧٥) ٧٢٠٣ زاد ابنُ جرير (٢٤/٤٧٥) قولًا في معنى الآية نقله عن بعض أهل العربية، فقال: «وكان بعض أهل العربية يتأوَّله بمعنى: أنه مَن سلك الهدى فعلى الله سبيله. ويقول: وهو مثلُ قوله: <q>﴿وعَلى اللهِ قَصْدُ السَّبِيلِ﴾</q> [النحل:٩]. ويقول: معنى ذلك: مَن أراد اللهَ فهو على السبيلِ القاصدِ. وقال: يقال معناه: إنّ علينا للهدى والإضلال، كما قال: <q>﴿سَرابِيلَ تَقِيكُمُ الحَرَّ﴾</q> [النحل:٨١] وهي تقي الحرَّ والبرد». وذكر ابنُ القيم (٣/٣٢٤) قول قتادة، ثم انتقده قائلًا: «وهذا المعنى حقٌّ، ولكن مراد الآية شيء آخر». ثم نسب قول أهل العربية للفراء، ثم انتقده قائلًا: «وهذا أضعف من القول الأول -أي: قول قتادة- وإن كان معناه صحيحًا، فليس هو معنى الآية». ثم ذكر معنًى آخر، وهو: «مَن سلك الهدى فعلى الله سبيله، كقوله: <q>﴿وعَلى اللهِ قَصْدُ السَّبِيلِ﴾</q> [النحل:٩]». ثم رجَّحه قائلًا: «وهذا قول مجاهد، وهو أصح الأقوال في الآية». ٨٣٦٤٨- قال مقاتل بن سليمان: <q>﴿إنَّ عَلَيْنا لَلْهُدى﴾</q>، يعني: بيان الهدى{2}. (ز) ",footnotes:1:أخرجه ابن جرير ٢٤/٤٧٥. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.تفسير مقاتل بن سليمان ٤/٧٢٢.
92,13," <q>﴿وَإِنَّ لَنَا لَلۡـَٔاخِرَةَ وَٱلۡأُولَىٰ ۝١٣﴾</q> - تفسير ٨٣٦٤٩- قال مقاتل بن سليمان: <q>﴿وإنَّ لَنا لَلْآخِرَةَ والأُولى﴾</q>، يعني: الدنيا والآخرة{1}. (ز) ",footnotes:1:تفسير مقاتل بن سليمان ٤/٧٢٢.
92,14," <q>﴿فَأَنذَرۡتُكُمۡ نَارࣰا تَلَظَّىٰ ۝١٤﴾</q> - قراءات ٨٣٦٥٠- عن عُبيد بن عُمير أنه قرأ: (فَأَنذَرْتُكُمْ نارًا تَتَلَظّى) بالتاءين{1}. (١٥/٤٧٥) ٨٣٦٥١- عن سعيد بن أبي أيوب، يقول: صلّى بنا رزيق بن حكيم، قال: حَسِبْتُ المغرب، فقرأ فيها بالليل إذا يغشى، فسمعتُه يقول: (نارًا تَتَلَظّى){2}. (ز) <q>﴿فَأَنذَرۡتُكُمۡ نَارࣰا تَلَظَّىٰ ۝١٤﴾</q> - تفسير الآية ٨٣٦٥٢- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿نارًا تَلَظّى﴾</q>، قال: توهّج{3}. (١٥/٤٧٥) ٨٣٦٥٣- قال مقاتل بن سليمان: <q>﴿فَأَنْذَرْتُكُمْ﴾</q> يا أهل مكة <q>﴿نارًا تَلَظّى﴾</q> يعني: تتوقّد وتشتعل{4}. (ز) ",footnotes:1:أخرجه سعيد بن منصور -كما في التغليق ٤/٣٧٠-، والفراء في معاني القرآن ٣/٢٧١-٢٧٢، والبيهقي في سننه ٢/٢٩٩. وعزاه السيوطي إلى الفريابي. قال السيوطي: «بسند صحيح». وهي قراءة شاذة، تروى أيضًا عن ابن الزيير، ورزيق بن حكيم. انظر: مختصر ابن خالويه ص١٧٥.أخرجه عبد الله بن وهب في الجامع -علوم القرآن ٣/٥٠ (١٠٣).تفسير مجاهد ص٥١٠، وأخرجه الفريابي -كما في التغليق ٤/٣٧٠، وفتح الباري ٨/٧٠٦-، وابن جرير ٢٤/٤٧٤-٤٧٦. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.تفسير مقاتل بن سليمان ٤/٧٢٢-٧٢٣.
