quran[9]{c,v,t}:
  41,30,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿إِنَّ ٱلَّذِینَ قَالُوا۟ رَبُّنَا ٱللَّهُ ثُمَّ ٱسۡتَقَـٰمُوا۟﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٨٥١٥<span class="dash">-</span></span> عن أنس بن مالك، قال: قرأ علينا رسولُ الله ﷺ هذه الآية: <span class="qpc-hafs">﴿إنَّ الَّذِينَ قالُوا رَبُّنا اللَّهُ ثُمَّ اسْتَقامُوا﴾</span>، قال: «<b>قد قالها ناسٌ مِن الناس، ثم كفر أكثرُهم، فمَن قالها حتى يموت فهو مِمَّن استقام عليها</b>»{1}<span class=comment-ref>٥٧٥٤</span>. (١٣/١٠٣)</p></p><p></div></p><p><div><span class=comment-ref>٥٧٥٤</span> <span class="comment-type-4">ساق</span> <u>ابنُ عطية</u> (٧/٤٨١-٤٨٢) هذا الأثر، ثم قال: «المعنى: فهو في أول درجات الاستقامة، أمن الخلود، فهذا <span class="mustanad">كقوله</span> ﷺ: «<b>من كان آخر كلامه لا إله إلا الله دخل الجنة</b>». وهذا هو المعتقد -إن شاء الله-، وذلك أنّ العُصاة مِن أمة محمد ﷺ وغيرها فرقتان: فأمّا من قضى الله بالمغفرة له وترك تعذيبه، فلا محالة أنه ممن تنزل عليه الملائكة بالبشارة، وهو إنما استقام على توحيده فقط، وأما مَن قضى الله بتعذيبه مدة، ثم بإدخاله الجنة، فلا محالة أنه يلقى جميع ذلك عند موته ويعلمه، وليس يصح أن تكون حاله كحالة الكافر اليائس من رحمة الله، وإذا كان هذا فقد حصلت له البشارة بأن لا يخاف الخلود ولا يحزن منه، وبأنه يصير آخرًا إلى الخلود في الجنة، وهل العصاة المؤمنون إلا تحت الوعد بالجنة؟ فهم داخلون فيمن يقال لهم: <span class="qpc-hafs">﴿أبْشِرُوا بِالجَنَّةِ الَّتِي كُنْتُمْ تُوعَدُونَ﴾</span>، ومع هذا كله، فلا يختلف أنّ الموحِّد المستقيم على الطاعة أتم حالًا، وأكمل بشارة، وهو مقصد أمير المؤمنين عمر بن الخطاب ﵁، وعلى نحو ذلك قال سفيان: اسْتَقامُوا، عملوا بنحو ما قالوا. وقال الربيع: أعرضوا عمّا سوى الله. وقال الفضيل: زهدوا في الفانية، ورغبوا في الباقية. وبالجملة فكلما كان المرء أشد استعدادًا كان أسرع فوزًا بفضل الله تعالى».</div></p><p><div></p><p><p><span class="item-no">٦٨٥١٦<span class="dash">-</span></span> عن أنس بن مالك: إنّ النبي ﷺ قال لما نزلت هذه الآية: <span class="qpc-hafs">﴿إنَّ الَّذِينَ قالُوا رَبُّنا اللَّهُ ثُمَّ اسْتَقامُوا﴾</span>: «<b>أمتي، وربِّ الكعبة</b>»{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٨٥١٧<span class="dash">-</span></span> عن <span class="name-1">أبي بكر الصِّدِّيق</span> -من طريق سعيد بن نِمْران - في قوله: <span class="qpc-hafs">﴿إنَّ الَّذِينَ قالُوا رَبُّنا اللَّهُ ثُمَّ اسْتَقامُوا﴾</span>، قال: الاستقامة: أن لا تشركوا بالله شيئًا{3}. (١٣/١٠٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٨٥١٨<span class="dash">-</span></span> عن <span class="name-1">أبي بكر الصِّدِّيق</span> -من طريق الأسود بن هلال- أنه قال: ما تقولون في هاتين الآيتين: <span class="qpc-hafs">﴿إنَّ الَّذِينَ قالُوا رَبُّنا اللَّهُ ثُمَّ اسْتَقامُوا﴾</span>، و<span class="qpc-hafs">﴿الَّذِينَ آمَنُوا ولَمْ يَلْبِسُوا إيمانَهُمْ بِظُلْمٍ﴾</span> [الأنعام:٨٢]؟ قالوا: الذين قالوا ربنا الله، ثم عملوا بها، واستقاموا على أمره، فلم يُذنبوا، <span class="qpc-hafs">﴿ولَمْ يَلْبِسُوا إيمانَهُمْ بِظُلْمٍ﴾</span>: لم يُذنبوا. قال: لقد حملتموها على أمر شديد؛ <span class="qpc-hafs">﴿الَّذِينَ آمَنُوا ولَمْ يَلْبِسُوا إيمانَهُمْ بِظُلْمٍ﴾</span> يقول: بشرك، و<span class="qpc-hafs">﴿الَّذِينَ قالُوا رَبُّنا اللَّهُ ثُمَّ اسْتَقامُوا﴾</span> فلم يرجعوا إلى عبادة الأوثان{4}. (١٣/١٠٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٨٥١٩<span class="dash">-</span></span> عن <span class="name-1">أبي بكر الصِّدّيق</span> -من طريق الأسود بن هلال المحاربي- قال: ما تقولون في هذه الآية: <span class="qpc-hafs">﴿الَّذِينَ قالُوا رَبُّنا اللَّهُ ثُمَّ اسْتَقامُوا﴾</span>؟ قال: فقالوا: ربنا الله، ثم استقاموا مِن ذنب. قال: فقال أبو بكر: لقد حملتم على غير المحمل؛ <span class="qpc-hafs">﴿قالوا: ربنا الله، ثم استقاموا﴾</span> فلم يلتفتوا إلى إلهٍ غيره{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٨٥٢٠<span class="dash">-</span></span> عن أبي اسحاق، عن رجل، قال: قال رجل: يا <span class="name-1">خليفةَ رسول الله ﷺ</span>: ما قوله: <span class="qpc-hafs">﴿الذين قالوا ربنا الله ثم استقاموا﴾</span>؟ قال: على لا إله إلا الله{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٨٥٢١<span class="dash">-</span></span> عن <span class="name-1">عمر بن الخطاب</span> -من طريق الزُّهري- <span class="qpc-hafs">﴿الَّذِينَ قالُوا رَبُّنا اللَّهُ ثُمَّ اسْتَقامُوا﴾</span>، قال: استقاموا بطاعة، ولم يروغوا روَغان الثعلب{7}<span class=comment-ref>٥٧٥٥</span>. (١٣/١٠٤)</p></p><p></div></p><p><div><span class=comment-ref>٥٧٥٥</span> ساق <u>ابنُ عطية</u> (٧/٤٨١) قول عمر، ثم <span class="comment-type-4">علَّق</span> قائلًا: «ذهب ﵁ إلى حمل الناس على الأتم الأفضل، وإلا فيلزم -على هذا التأويل- مِن دليل خطابه ألا تنزل الملائكة عند الموت على غير مستقيم على الطاعة».</div></p><p><div></p><p><p><span class="item-no">٦٨٥٢٢<span class="dash">-</span></span> قال <span class="name-1">عثمان بن عفان</span>: <span class="qpc-hafs">﴿الَّذِينَ قالُوا رَبُّنا اللَّهُ ثُمَّ اسْتَقامُوا﴾</span> أخلصوا العمل لله{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٨٥٢٣<span class="dash">-</span></span> قال <span class="name-1">علي بن أبي طالب</span>: <span class="qpc-hafs">﴿الَّذِينَ قالُوا رَبُّنا اللَّهُ ثُمَّ اسْتَقامُوا﴾</span> أدّوا الفرائض{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٨٥٢٤<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عكرمة- في قوله: <span class="qpc-hafs">﴿الَّذِينَ قالُوا رَبُّنا اللَّهُ ثُمَّ اسْتَقامُوا﴾</span>، قال: على شهادة أن لا إله إلا الله{10}. (١٣/١٠٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٨٥٢٥<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، <span class="qpc-hafs">﴿قالُوا رَبُّنا اللَّهُ﴾</span> يقول: وحَّد اللهَ، <span class="qpc-hafs">﴿ثُمَّ اسْتَقامُوا﴾</span> يقول: على أداء فرائضه{11}. (١٣/١٠٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٨٥٢٦<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> أنه سُئل: أيُّ آية في كتاب الله أرجى؟ قال: قوله: <span class="qpc-hafs">﴿الَّذِينَ قالُوا رَبُّنا اللَّهُ ثُمَّ اسْتَقامُوا﴾</span> على شهادة أن لا إله إلا الله. قيل له: فأين قوله تعالى: <span class="qpc-hafs">﴿قُلْ يا عِبادِيَ الَّذِينَ أسْرَفُوا عَلى أنْفُسِهِمْ﴾</span> [الزمر: ٥٣] زاد، اقرأ: <span class="qpc-hafs">﴿وأَنِيبُوا إلى رَبِّكُمْ﴾</span> [الزمر:٥٤] فيها، علَّقه، أي اعملوا{12}. (١٣/١٠٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٨٥٢٧<span class="dash">-</span></span> عن <span class="name-1">أنس بن مالك</span> -من طريق ثابت البُناني- في قوله ﷿: <span class="qpc-hafs">﴿الذين قالوا ربنا الله ثم استقاموا﴾</span>، قال: استقاموا على لا إله إلا الله{13}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٨٥٢٨<span class="dash">-</span></span> عن <span class="name-2">إبراهيم النَّخْعي</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٨٥٢٩<span class="dash">-</span></span> و<span class="name-2">مجاهد بن جبر</span> -من طريق منصور- في قوله: <span class="qpc-hafs">﴿ثُمَّ اسْتَقامُوا﴾</span>، قالا: قالوا: لا إله إلا الله، لم يشركوا بعدها بالله شيئًا حتى يَلقَوه{14}. (١٣/١٠٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٨٥٣٠<span class="dash">-</span></span> عن <span class="name-2">الأسود بن هلال</span> -من طريق جامع بن شداد-، مثله{15}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٨٥٣١<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ليث- <span class="qpc-hafs">﴿إنَّ الَّذِينَ قالُوا رَبُّنا اللَّهُ ثُمَّ اسْتَقامُوا﴾</span>، قال: أي: على لا إله إلا الله{15}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٨٥٣٢<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span> -من طريق الحكم بن أبان- قوله: <span class="qpc-hafs">﴿إنَّ الَّذِينَ قالُوا رَبُّنا اللَّهُ ثُمَّ اسْتَقامُوا﴾</span>، قال: استقاموا على شهادة أن لا إله إلا الله{15}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٨٥٣٣<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق معمر- أنّه كان إذا تلا هذه الآية: <span class="qpc-hafs">﴿إنَّ الَّذِينَ قالُوا رَبُّنا اللَّهُ ثُمَّ اسْتَقامُوا﴾</span>، يقول: اللهمَّ، أنت ربنا، فارزقنا الاستقامة{18}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٨٥٣٤<span class="dash">-</span></span> قال <span class="name-2">محمد بن سيرين</span>: <span class="qpc-hafs">﴿إنَّ الَّذِينَ قالُوا رَبُّنا اللَّهُ ثُمَّ اسْتَقامُوا﴾</span> لم يعوجُّوا{19}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٨٥٣٥<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- في قوله تعالى: <span class="qpc-hafs">﴿إنَّ الَّذِينَ قالُوا رَبُّنا اللَّهُ ثُمَّ اسْتَقامُوا﴾</span>، قال: استقاموا على طاعة الله{20}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٨٥٣٦<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدّيّ</span> -من طريق أسباط- <span class="qpc-hafs">﴿إنَّ الَّذِينَ قالُوا رَبُّنا اللَّهُ ثُمَّ اسْتَقامُوا﴾</span>، قال: تَمُّوا على ذلك{15}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٨٥٣٧<span class="dash">-</span></span> قال <span class="name-2">الربيع [بن أنس]</span>: <span class="qpc-hafs">﴿إنَّ الَّذِينَ قالُوا رَبُّنا اللَّهُ ثُمَّ اسْتَقامُوا﴾</span> أعرضوا عمّا سوى الله تعالى{19}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٨٥٣٨<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثم أخبر عن المؤمنين، فقال: <span class="qpc-hafs">﴿إنَّ الَّذِينَ قالُوا رَبُّنا اللَّهُ﴾</span> فعرفوه، <span class="qpc-hafs">﴿ثُمَّ اسْتَقامُوا﴾</span> على المعرفة، ولم يرتدّوا عنها{23}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٨٥٣٩<span class="dash">-</span></span> عن <span class="name-3">سفيان الثوري</span>، قال: <span class="qpc-hafs">﴿إنَّ الَّذِينَ قالُوا رَبُّنا اللَّهُ ثُمَّ اسْتَقامُوا﴾</span> عمِلوا على وفاق ما قالوا{19}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٨٥٤٠<span class="dash">-</span></span> قال <span class="name-3">فُضيْل بن عِياض</span>: <span class="qpc-hafs">﴿إنَّ الَّذِينَ قالُوا رَبُّنا اللَّهُ ثُمَّ اسْتَقامُوا﴾</span> زهدوا في الفانية، ورغبوا في الباقية{19}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٨٥٤١<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿إنَّ الَّذِينَ قالُوا رَبُّنا اللَّهُ ثُمَّ اسْتَقامُوا﴾</span>، قال: استقاموا على عبادة الله، وعلى طاعته{26}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿إِنَّ ٱلَّذِینَ قَالُوا۟ رَبُّنَا ٱللَّهُ ثُمَّ ٱسۡتَقَـٰمُوا۟﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٦٨٥٤٢<span class="dash">-</span></span> عن ثوبان مولى النبي ﷺ، أنّ النبي ﷺ قال: «<b>استقيموا ولن تُحصُوا، واعلموا أنّ خير أعمالكم الصلاة، ولن يُحافِظ على الوضوء إلا مؤمن</b>»{27}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٨٥٤٣<span class="dash">-</span></span> عن سفيان الثقفي، أنّ رجلًا قال: يا رسول الله، مُرني بأمرٍ في الإسلام لا أسأل عنه أحدًا بعدك. قال: «<b>قل: آمنتُ بالله، فاستقِم</b>»{28}. (١٣/١٠٦)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿تَتَنَزَّلُ عَلَیۡهِمُ ٱلۡمَلَـٰۤىِٕكَةُ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٨٥٤٤<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- <span class="qpc-hafs">﴿تَتَنَزَّلُ عَلَيْهِمُ المَلائِكَةُ﴾</span>، قال: في الآخرة{29}. (١٣/١٠٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٨٥٤٥<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿تَتَنَزَّلُ عَلَيْهِمُ المَلائِكَةُ﴾</span>، قال: عند الموت{30}. (١٣/١٠٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٨٥٤٦<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span>: <span class="qpc-hafs">﴿تَتَنَزَّلُ عَلَيْهِمُ المَلائِكَةُ ألّا تَخافُواْ ولا تَحْزَنُواْ﴾</span> أنّ قول الملائكة لهم: لا تخافوا ولا تحزنوا. تستقبلهم بهذا إذا خرجوا من قبورهم{31}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٨٥٤٧<span class="dash">-</span></span> قال <span class="name-2">قتادة بن دعامة</span>: <span class="qpc-hafs">﴿تَتَنَزَّلُ عَلَيْهِمُ المَلائِكَةُ ألّا تَخافُوا ولا تَحْزَنُوا﴾</span> إذا قاموا من قبورهم{19}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٨٥٤٨<span class="dash">-</span></span> عن <span class="name-2">ثابت بن أسلم البُناني</span> -من طريق جعفر بن سليمان- أنّه قرأ «حم السجدة» حتى بلغ: <span class="qpc-hafs">﴿تَتَنَزَّلُ عَلَيْهِمُ المَلائِكَةُ﴾</span> فوقف، فقال: بلغنا: أنّ العبد المؤمن حين يبعثه الله مِن قبره يتلقّاه ملكاه اللذان كانا معه في الدنيا، فيقولان له: لا تخف ولا تحزن، وأبْشِر بالجنة التي كنت تُوعد. فيُؤمِّن اللهُ خوفَه، ويُقِرُّ عينَه، فما عظيمةٌ إلا وهي للمؤمن قُرّة عين لِما هداه الله، ولِما كان يعمل في الدنيا{33}. (١٣/١٠٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٨٥٤٩<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدّيّ</span> -من طريق أسباط- <span class="qpc-hafs">﴿تَتَنَزَّلُ عَلَيْهِمُ المَلائِكَةُ﴾</span>، قال: عند الموت{34}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٨٥٥٠<span class="dash">-</span></span> عن <span class="name-2">زيد بن أسلم</span>، <span class="qpc-hafs">﴿تَتَنَزَّلُ عَلَيْهِمُ المَلائِكَةُ﴾</span>، قال: يُبشَّر بها عند موته، وفي قبره، ويوم يُبعث، فإنّه لَفي الجنة وما ذهبتْ فرحةُ البِشارة مِن قلبه{35}<span class=comment-ref>٥٧٥٦</span>. (١٣/١٠٧)</p></p><p></div></p><p><div><span class=comment-ref>٥٧٥٦</span> <span class="comment-type-4">علَّق</span> <u>ابنُ كثير</u> (١٢/٢٣٧) على هذا القول الذي قاله ابن زيد ووكيع بن الجراح بقوله: «هذا القول يجمع الأقوال كلها، وهو حسن جِدًّا، وهو الواقع».</div></p><p><div></p><p><p><span class="item-no">٦٨٥٥١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿تَتَنَزَّلُ عَلَيْهِمُ المَلائِكَةُ﴾</span> في الآخرة مِن السماء، وهم الحفظة{23}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٨٥٥٢<span class="dash">-</span></span> عن ابن المبارك، قال: سمعت <span class="name-3">سفيان [الثوريَّ]</span> يقول في قول الله تعالى: <span class="qpc-hafs">﴿تتنزل عليهم الملائكة﴾</span>: أي: عند الموت ...، <span class="qpc-hafs">﴿وأبشروا بالجنة التي كنتم توعدون﴾</span> قال: يُبشَّرون بثلاث تبشيرات عند الموت، وإذا خرج من القبر، وإذا فزع: <span class="qpc-hafs">﴿نحن أولياؤكم في الحيوة الدنيا وفي الآخرة﴾</span> وكانوا معهم{37}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿أَلَّا تَخَافُوا۟ وَلَا تَحۡزَنُوا۟﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٨٥٥٣<span class="dash">-</span></span> قال <span class="name-2">أبوالعالية الرَّياحي</span>: <span class="qpc-hafs">﴿ألا تَخافُوا﴾</span> على صنيعكم، <span class="qpc-hafs">﴿ولا تَحْزَنُوا﴾</span> على مُخلّفيكم{19}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٨٥٥٤<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- قوله: <span class="qpc-hafs">﴿تَتَنَزَّلُ عَلَيْهِمُ المَلائِكَةُ ألّا تَخافُواْ ولا تَحْزَنُواْ﴾</span>، قال: ألّا تخافوا مِمّا تُقدِمون عليه مِن الموت وأمر الآخرة، ولا تحزنوا على ما خلَّفتم مِن أمر دنياكم؛ مِن ولد أو أهل أو دَيْن، فإنّا سنخلفكم في ذلك كله{39}. (١٣/١٠٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٨٥٥٥<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span>، <span class="qpc-hafs">﴿تَتَنَزَّلُ عَلَيْهِمُ المَلائِكَةُ ألّا تَخافُواْ ولا تَحْزَنُواْ﴾</span>، قال: لا تخافوا ما أمامكم، ولا تحزنوا على ما خلفكم مِن ضَيْعتكم{40}. (١٣/١٠٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٨٥٥٦<span class="dash">-</span></span> قال <span class="name-2">عطاء بن رباح</span>: <span class="qpc-hafs">﴿لا تَخافُوا ولا تَحْزَنُوا﴾</span> على ذنوبكم، فإنّي أغفرها لكم{41}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٨٥٥٧<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدّيّ</span> -من طريق أسباط- <span class="qpc-hafs">﴿ألّا تَخافُوا ولا تَحْزَنُوا﴾</span>، قال: لا تخافوا ما أمامكم، ولا تحزنوا على ما بعدكم{42}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٨٥٥٨<span class="dash">-</span></span> عن <span class="name-2">زيد بن أسلم</span> -من طريق سفيان- في هذه الآية: <span class="qpc-hafs">﴿ألّا تَخافُوا ولا تَحْزَنُوا﴾</span>، قال: لا تخافوا ما أمامكم، ولا تحزنوا على ما خلفتم{43}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٨٥٥٩<span class="dash">-</span></span> عن <span class="name-3">سفيان الثوري</span> -من طريق ابن المبارك- في قول الله: <span class="qpc-hafs">﴿ألا تخافوا﴾</span> قال: ما أمامكم، <span class="qpc-hafs">﴿ولا تحزنوا﴾</span> على ما خلَّفتُم من ضَيعاتكم{37}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَأَبۡشِرُوا۟ بِٱلۡجَنَّةِ ٱلَّتِی كُنتُمۡ تُوعَدُونَ ۝٣٠﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٨٥٦٠<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدّي</span> -من طريق أسباط-: <span class="qpc-hafs">﴿وأَبْشِرُوا بِالجَنَّةِ الَّتِي كُنْتُمْ تُوعَدُونَ﴾</span> في الدنيا{42}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٨٥٦١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ألّا تَخافُوا ولا تَحْزَنُوا وأَبْشِرُوا بِالجَنَّةِ الَّتِي كُنْتُمْ تُوعَدُونَ﴾</span> وذلك أنّ المؤمن إذا خرج من قبره، فينفض رأسه، ومَلَكه قائمٌ على رأسه يُسَلِّم عليه، فيقول الملَك للمؤمن: أتعرفني؟ فيقول: لا. فيقول: أنا الذي كنتُ أكتب عملَك الصالح، فلا تَخفْ ولا تَحزن، وأبشِر بالجنة التي كنت تُوعَد. وذلك أنّ الله وعدهم على ألسنة الرسل في الدنيا الجنة{23}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٨٥٦٢<span class="dash">-</span></span> قال <span class="name-3">وكيع بن الجرّاح</span>: <span class="qpc-hafs">﴿تَتَنَزَّلُ عَلَيْهِمُ المَلائِكَةُ ألّا تَخافُوا ولا تَحْزَنُوا﴾</span>، البشرى تكون في ثلاثة مواطن: عند الموت، وفي القبر، وفي البعث{41}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَأَبۡشِرُوا۟ بِٱلۡجَنَّةِ ٱلَّتِی كُنتُمۡ تُوعَدُونَ ۝٣٠﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٦٨٥٦٣<span class="dash">-</span></span> عن أنس بن مالك، قال: قال رسول الله ﷺ: «<b>مَن أحبَّ لقاء الله أحبَّ اللهُ لقاءَه، ومَن كره لقاء الله كره الله لقاءه</b>» قلنا: يا رسول الله، كلّنا نكره الموت. قال: «<b>ليس ذلك كراهية الموت، ولكن المؤمن إذا حُضر جاءه البشير مِن الله بما هو صائر إليه، فليس شيءٌ أحبّ إليه مِن أن يكون قد لقي الله، فأحبّ الله لقاءه. وإن الفاجر والكافر إذا حُضر جاءه بما هو صائر إليه من الشر، فكره لقاء الله، فكره الله لقاءه</b>»{48}. (١٣/١٠٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٨٥٦٤<span class="dash">-</span></span> عن <span class="name-1">علي بن أبي طالب</span> -من طريق المنهال- قال: حرامٌ على كلِّ نفس أن تَخرج مِن الدنيا حتى تعلم أين مصيرها{49}. (١٣/١٠٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٨٥٦٥<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span>، قال: إنّ المؤمن لَيُبشَّر بصلاح ولده من بعده؛ لِتَقَرّ عينُه{50}. (١٣/١٠٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٨٥٦٦<span class="dash">-</span></span> عن <span class="name-2">زيد بن أسلم</span>، قال: يُؤتى المؤمنُ عند الموت، فيُقال له: لا تخف مِمّا أنت قادم عليه -فيذهب خوفه-، ولا تحزن على الدنيا، ولا على أهلها، وأبْشِر بالجنة. فيموت وقد أقرَّ الله عينه{51}. (١٣/١٠٦)</p></p><p></div></p></div>",footnotes:1:أخرجه الترمذي ٥/٤٥٤ (٣٥٣٢)، وابن جرير ٢٠/٤٢٢. وقال ابن كثير (١٢/٢٣٥): «وكذا رواه النسائي في تفسيره، والبزار، وابن جرير، عن عمرو بن علي الفلاس، عن سلم بن قتيبة، به. وكذا رواه ابن أبي حاتم، عن أبيه، عن الفلاس، به».</p><p>قال الترمذي: «هذا حديث غريب، لا نعرفه إلا من هذا الوجه». وقال ابن القيسراني في ذخيرة الحفاظ ٣/١٦٧٩ (٣٧٧١): «رواه سهيل بن أبي حازم عن ثابت عن أنس، وسهيل ضعيف، ولم يُتابع عليه».|2:أورده الثعلبي ٨/٢٩٤.|3:أخرجه ابن المبارك (٣٢٦)، وسفيان الثوري ص٢٦٦، وعبد الرزاق ٢/١٨٧، ومسدد -كما في المطالب (٤٠٨٦)-، وابن سعد ٦/٨٤، وابن جرير ٢٠/٤٢٢-٤٢٣ بلفظ: هم الذين لم يشركوا بالله شيئًا. وعزاه السيوطي إلى الفريابي، وسعيد بن منصور، وعبد بن حميد، وابن المنذر، وابن أبي حاتم.|4:أخرجه إسحاق ابن راهويه -كما في المطالب العالية (٣٩٧١)-، والحكيم الترمذي في نوادر الأصول ١/٢٣١، ٤/٢٠٦، وابن جرير ٢٠/٤٢٣ بلفظ: <span class="qpc-hafs">﴿إن الَّذِينَ قالُوا رَبُّنا اللَّهُ ثُمَّ اسْتَقامُوا﴾</span> قال: قالوا: ربنا الله، ثم عملوا بها، قال: لقد حملتموها على غير المحمل. <span class="qpc-hafs">﴿إن الَّذِينَ قالُوا رَبُّنا اللَّهُ ثُمَّ اسْتَقامُوا﴾</span> الذين لم يعدلوها بشرك ولا غيره، والحاكم ٢/٤٤٠، وأبو نعيم في الحلية ١/٣٠. وعزاه السيوطي إلى عبد بن حميد، وابن مردويه.|5:أخرجه ابن جرير ٢٠/٤٢٣.|6:أخرجه إسحاق البستي ص٢٩٤.|7:أخرجه ابن المبارك (٣٢٥)، وأحمد في الزهد ص١١٥، والحكيم الترمذي ١/٢٣١، وابن جرير ٢٠/٤٢٥. وعزاه السيوطي إلى سعيد بن منصور، وعبد بن حميد، وابن المنذر.|8:تفسير الثعلبي ٨/٢٩٣، وتفسير البغوي ٧/١٧٢.|9:تفسير الثعلبي ٨/٢٩٣، وتفسير البغوي ٧/١٧٢.|10:أخرجه البيهقي في الأسماء والصفات (٢٠٥).|11:عزاه السيوطي إلى ابن أبي حاتم، وابن المنذر. وأخرج ابن جرير ٢٠/٤٢٥ شطره الأخير من طريق علي.|12:عزاه السيوطي إلى عبد بن حميد.|13:أخرجه الطبراني في الدعاء ٣/١٥٢٥.|14:أخرجه ابن جرير ٢٠/٤٢٤ عن مجاهد. وعزاه السيوطي إلى عبد بن حميد. كما أخرجه ابن جرير ٢٠/٤٢٤ بلفظ: أسلموا ثم لم يشركوا به حتى لحقوا به.|15:أخرجه ابن جرير ٢٠/٤٢٤.|16:أخرجه ابن جرير ٢٠/٤٢٤.|17:أخرجه ابن جرير ٢٠/٤٢٤.|18:أخرجه عبد الرزاق ٢/١٨٦، وابن جرير ٢١/٤٦٥ من طريق قتادة.|19:تفسير الثعلبي ٨/٢٩٤.|20:أخرجه عبد الرزاق ٢/١٨٦، وابن جرير ٢٠/٤٢٥.|21:أخرجه ابن جرير ٢٠/٤٢٤.|22:تفسير الثعلبي ٨/٢٩٤.|23:تفسير مقاتل بن سليمان ٣/٧٤٢.|24:تفسير الثعلبي ٨/٢٩٤.|25:تفسير الثعلبي ٨/٢٩٤.|26:أخرجه ابن جرير ٢٠/٤٢٥.|27:أخرجه أحمد ٣٧/٦٠ (٢٢٣٧٨)، ٣٧/١١٠ (٢٢٤٣٦)، وابن ماجه ١/١٨٤ (٢٧٧)، وابن حبان ٣/٣١١ (١٠٣٧)، والحاكم ١/٢٢٠-٢٢١ (٤٤٧-٤٤٩)، وعبد الرزاق ٣/١٥٤ (٢٧٠٨).</p><p>قال الحاكم: «هذا حديث صحيح، على شرط الشيخين، ولم يخرجاه، ولست أعرف له علة يعلّل بمثلها مثل هذا الحديث، إلا وهم من أبي بلال الأشعري وهم فيه على أبي معاوية». وقال البغوي في شرح السنة ١/٣٢٧ (١٥٥): «هذا منقطع، ويُروى متصلًا عن حسان بن عطية، عن أبي كبشة السلولي، عن ثوبان، وثوبان أبو عبد الله مولى رسول الله ﷺ، وأبو كبشة السلولي لا يُعرف له اسم». وقال المنذري في الترغيب والترهيب ١/٩٧ (٣١١): «بإسناد صحيح». وقال البوصيري في مصباح الزجاجة ١/٤١ (١١٢): «رجاله ثقات أثبات، إلا أنه منقطع بين سالم وثوبان؛ فإنه لم يسمع منه بلا خلاف، لكن له طريق أخرى متصلة». وقال الألباني في الإرواء ٢/١٣٥ (٤١٢): «صحيح».|28:أخرجه مسلم ١/٦٥ (٣٨)، والثعلبي ٨/٢٩٤.|29:أخرجه ابن جرير ٢٠/٤٢٧. وعزاه السيوطي إلى ابن أبي حاتم، وابن المنذر.|30:تفسير مجاهد ص٥٨٦، وأخرجه الفريابي -كما في تغليق التعليق ٤/٣٠٢-، وابن جرير ٢٠/٤٢٦. وعلقه البخاري في صحيحه ٤/١٨١٧، والبيهقي في شعب الإيمان ١/٣٥٤. وعزاه السيوطي إلى عبد بن حميد.|31:أخرجه يحيى بن سلام -كما في تفسير ابن أبي زمنين ٤/١٥٢-.|32:تفسير الثعلبي ٨/٢٩٤.|33:أخرجه ابن أبي حاتم -كما في تفسير ابن كثير ٧/١٧٧-. وعزاه السيوطي إلى ابن المنذر.|34:أخرجه ابن جرير ٢٠/٤٢٦.|35:عزاه السيوطي إلى ابن أبي حاتم.|36:تفسير مقاتل بن سليمان ٣/٧٤٢.|37:أخرجه ابن المبارك في الزهد (٣٢٨)، والبيهقي في إثبات عذاب القبر وسؤال الملكين ص٨١.|38:تفسير الثعلبي ٨/٢٩٤.|39:أخرجه ابن جرير ٢٠/٤٢٧. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.|40:عزاه السيوطي إلى عَبد بن حُمَيد.|41:تفسير الثعلبي ٨/٢٩٤، وتفسير البغوي ٧/١٧٣.|42:أخرجه ابن جرير ٢٠/٤٢٦-٤٢٨.|43:أخرجه ابن أبي شيبة في مصنفه (ت: محمد عوامة) ١٩/٣٨٢ (٣٦٤٠٤).|44:أخرجه ابن المبارك في الزهد (٣٢٨)، والبيهقي في إثبات عذاب القبر وسؤال الملكين ص٨١.|45:أخرجه ابن جرير ٢٠/٤٢٦-٤٢٨.|46:تفسير مقاتل بن سليمان ٣/٧٤٢.|47:تفسير الثعلبي ٨/٢٩٤، وتفسير البغوي ٧/١٧٣.|48:أخرجه أحمد ١٩/١٠٣-١٠٤ (١٢٠٤٧).</p><p>قال المنذري في الترغيب والترهيب ٤/١٧١ (٥٢٩٨): «رواه أحمد، ورواته رواة الصحيح والنسائي بإسناد جيد». وقال ابن كثير في تفسيره ٧/١٧٩: «حديث صحيح، وقد ورد في الصحيح من غير هذا الوجه». وقال الهيثمي في المجمع ٢/٣٢٠ (٣٨٩٩): «رجال أحمد رجال الصحيح». وقال البوصيري في إتحاف الخيرة ٢/٤٢٩ (١٨٣٢): «بسند صحيح ... وهو في الصحيحين وغيرهما من حديث أنس، عن عبادة بن الصامت».|49:أخرجه ابن أبي شيبة ١٤/٥٦. وعزاه السيوطي إلى ابن أبي الدنيا في ذكر الموت.|50:عزاه السيوطي إلى أبي نعيم في الحلية.|51:عزاه السيوطي إلى ابن أبي شيبة، وعبد بن حميد، وابن المنذر، وابن أبي حاتم.
  41,31,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿نَحۡنُ أَوۡلِیَاۤؤُكُمۡ فِی ٱلۡحَیَوٰةِ ٱلدُّنۡیَا وَفِی ٱلۡـَٔاخِرَةِۖ وَلَكُمۡ فِیهَا مَا تَشۡتَهِیۤ أَنفُسُكُمۡ وَلَكُمۡ فِیهَا مَا تَدَّعُونَ ۝٣١﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٨٥٦٧<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span>-من طريق منصور- <span class="qpc-hafs">﴿نَحْنُ أوْلِياؤُكُمْ﴾</span>، قال: رفقاؤكم في الدنيا، لا نُفارقكم حتى ندخل معكم الجنة. وفي لفظ: قرناؤهم الذين معهم في الدنيا، فإذا كان يوم القيامة قالوا: لن نفارقكم حتى نُدخلكم الجنة{1}. (١٣/١٠٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٨٥٦٨<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدّيّ</span> -من طريق أسباط- <span class="qpc-hafs">﴿نَحْنُ أوْلِياؤُكُمْ فِي الحَياةِ الدُّنْيا﴾</span>: نحن الحفظة الذين كنا معكم في الدنيا، ونحن أولياؤكم في الآخرة{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٨٥٦٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: وتقول الحفظة يومئذ للمؤمنين: <span class="qpc-hafs">﴿نَحْنُ أوْلِياؤُكُمْ فِي الحَياةِ الدُّنْيا﴾</span> ونحن أولياؤكم اليوم، <span class="qpc-hafs">﴿وفِي الآخِرَةِ ولَكُمْ فِيها﴾</span> يعني: في الجنة <span class="qpc-hafs">﴿ما تَشْتَهِي أنْفُسُكُمْ ولَكُمْ فِيها ما تَدَّعُونَ﴾</span> يعني: ما تَتَمَّنَوْن، هذا الذي أعطاكم الله كان <span class="qpc-hafs">﴿نُزُلًا مِن غَفُورٍ رَحِيمٍ﴾</span>{3}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن المبارك (٣٢٩). وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم، كذلك عزا اللفظ الثاني إلى عبد بن حميد.|2:أخرجه ابن جرير ٢٠/٤٢٨.|3:تفسير مقاتل بن سليمان ٣/٧٤٢.
  41,32,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿نُزُلࣰا مِّنۡ غَفُورࣲ رَّحِیمࣲ ۝٣٢﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٨٥٧٠<span class="dash">-</span></span> عن جابر بن عبد الله، قال: قال رسولُ الله ﷺ: «<b>بَينا أهل الجنة في مجلس لهم إذ سطع لهم نورٌ على باب الجنة، فرفعوا رؤوسهم، فإذا الربُّ تعالى قد أشرف، فقال: يا أهل الجنة، سَلوني. فقالوا: نسألك الرِّضا عنّا. قال: رِضاي أحلّكم داري، وأنالكم كرامتي، هذ أوانُها، فاسألوني. قالوا: نسألك الزيادة. قال: فيُؤتون بنجائِبَ{1} من ياقوت أحمر، أزِّمَّتها زَبَرْجد أخضر وياقوت أحمر، فجاءوا عليها تضع حوافرها عند منتهى طرفها، فأمر الله بأشجار عليها الثمار، فتجيء حوارٍ مِن الحُور العِين وهُنَّ يقُلن: نحن الناعمات فلا نبأس، ونحن الخالدات فلا نموت، أزواج قوم مؤمنين كرام. ويأمر الله بكُثْبان مِن مسكٍ أبيض أذْفَر</b>{2}، <b>فتثير عليهم ريحًا يقال لها: المُثِيرة. حتى تنتهي بهم إلى جنة عدن، وهي قصبة الجنة، فتقول الملائكة: يا ربنا، قد جاء القوم. فيقول: مرحبًا بالصادقين، مرحبًا بالطائعين. فيكشف لهم الحجاب، فينظرون إلى الله، فيتمتعون بنور الرحمن حتى لا يُبصِر بعضُهم بعضًا، ثم يقول: ارجِعوهم إلى القصور بالتُّحَف. فيرجعون وقد أبصر بعضُهم بعضًا</b>». قال رسول الله ﷺ: «<b>فذلك قوله تعالى: <span class="qpc-hafs">﴿نُزُلًا مِن غَفُورٍ رَحِيمٍ﴾</span></b>»{3}. (١٣/١٠٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٨٥٧١<span class="dash">-</span></span> عن أبي هريرة، مثله سواء{4}. (١٣/١١٠)</p></p><p></div></p></div>",footnotes:1:نجائب: هي الإبل القوية الخفيفة السريعة. النهاية (نجب).|2:أي: طيب الرِّيح. النهاية (ذفر).|3:أخرجه البيهقي في البعث والنشور ص٢٦٢-٢٦٣ (٤٤٨)، والقشيري في الرسالة القشيرية ٢/٣٤١.</p><p>قال السيوطي في اللآلىء المصنوعة في الأحاديث الموضوعة ٢/٣٨٣-٣٨٤: «موضوع».|4:أخرجه ابن النجار في تاريخه -كما في اللآلىء المصنوعة للسيوطي ٢/٣٨٣-. وفيه سليمان بن أبي كريمة.</p><p>قال السيوطي في اللآلىء المصنوعة: «سليمان بن أبي كريمة، قال ابن عدي: عامة أحاديثه مناكير، ولم أر للمتقدمين فيه كلامًا».
  41,33,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَمَنۡ أَحۡسَنُ قَوۡلࣰا مِّمَّن دَعَاۤ إِلَى ٱللَّهِ وَعَمِلَ صَـٰلِحࣰا وَقَالَ إِنَّنِی مِنَ ٱلۡمُسۡلِمِینَ ۝٣٣﴾</span> - نزول الآية، وتفسيرها</h3></p><p><div></p><p><p><span class="item-no">٦٨٥٧٢<span class="dash">-</span></span> عن <span class="name-1">عائشة</span> -من طريق عبيد الله بن عبيد- قالت: ما أرى هذه الآيةَ نزلت إلا في المؤذِّنين: <span class="qpc-hafs">﴿ومَن أحْسَنُ قَوْلًا مِمَّنْ دَعا إلى اللَّهِ﴾</span> الآية{1}. (١٣/١١٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٨٥٧٣<span class="dash">-</span></span> عن <span class="name-1">عائشة</span>: <span class="qpc-hafs">﴿ومَن أحْسَنُ قَوْلًا مِمَّنْ دَعا إلى اللَّهِ﴾</span> قالت: المؤذّن، <span class="qpc-hafs">﴿وعَمِلَ صالِحًا﴾</span> قالت: ركعتان فيما بين الأذان والإقامة{2}. (١٣/١١٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٨٥٧٤<span class="dash">-</span></span> قال <span class="name-1">عبد الله بن عباس</span>: <span class="qpc-hafs">﴿ومَن أحْسَنُ قَوْلًا مِمَّنْ دَعا إلى اللَّهِ وعَمِلَ صالِحًا وقالَ إنَّنِي مِنَ المُسْلِمِينَ﴾</span> هو رسول الله ﷺ؛ دعا إلى شهادة أن لا إله إلا الله{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٨٥٧٥<span class="dash">-</span></span> قال <span class="name-1">أبو أُمامة الباهلي</span>: <span class="qpc-hafs">﴿وعَمِلَ صالِحًا﴾</span> صلّى ركعتين بين الأذان والإقامة{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٨٥٧٦<span class="dash">-</span></span> عن <span class="name-2">قيس بن أبي حازم</span> -من طريق إسماعيل بن أبي خالد- في قوله: <span class="qpc-hafs">﴿ومَن أحْسَنُ قَوْلًا مِمَّنْ دَعا إلى اللَّهِ﴾</span> قال: الأذان، <span class="qpc-hafs">﴿وعَمِلَ صالِحًا﴾</span> قال: الصلاة بين الأذان والإقامة{5}. (١٣/١١١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٨٥٧٧<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span>، <span class="qpc-hafs">﴿ومَن أحْسَنُ قَوْلًا مِمَّنْ دَعا إلى اللَّهِ﴾</span>، قال: قول: لا إله إلا الله. يعني: المؤذّن، <span class="qpc-hafs">﴿وعَمِلَ صالِحًا﴾</span> صام وصلّى{6}<span class=comment-ref>٥٧٥٧</span>. (١٣/١١١)</p></p><p></div></p><p><div><span class=comment-ref>٥٧٥٧</span> <span class="comment-type-1">وجّه</span> <u>ابنُ عطية</u> (٧/٤٨٣) هذا القول الذي قالته عائشة، وأبو أمامة، وعكرمة، وابن أبي حازم، بقوله: «ومعنى القول بأنها في المؤذّنين: أنهم داخلون فيها. وأما نزولها فمكية بلا خلاف، ولم يكن بمكة أذان، وإنما ترتب بالمدينة، وإنّ الأذان لَمِن الدعاء إلى الله تعالى، ولكنه جزء منه. والدعاء إلى الله بقوة، كجهاد الكفار وردع الطغاة وكفّ الظلمة وغيره أعظم عناء من تولي الأذان؛ إذ لا مشقة فيه».</p><p>و<span class="comment-type-2">انتقد</span> <u>ابنُ كثير</u> (١٢/٢٤٢) هذا القول <span class="mustanad">مستندًا لأحوال النُّزول</span>، فقال: «فأما حال نزول هذه الآية فإنه لم يكن الأذان مشروعًا بالكلية؛ لأنها مكية، والأذان إنما شرُع بالمدينة بعد الهجرة، حين أريه عبد الله بن زيد بن عبد ربه الأنصاري في منامه، فقصّه على رسول الله ﷺ، فأمره أن يلقيه على بلال فإنه أندى صوتًا».</div></p><p><div></p><p><p><span class="item-no">٦٨٥٧٨<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span>، في قوله: <span class="qpc-hafs">﴿ومَن أحْسَنُ قَوْلًا مِمَّنْ دَعا إلى اللَّهِ﴾</span>، قال: هو النبيُّ ﷺ{7}. (١٣/١١٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٨٥٧٩<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span>، <span class="qpc-hafs">﴿ومَن أحْسَنُ قَوْلًا مِمَّنْ دَعا إلى اللَّهِ﴾</span>، قال: هو المؤمن عمل صالحًا، ودعا إلى الله تعالى{8}<span class=comment-ref>٥٧٥٨</span>. (١٣/١١٠)</p></p><p></div></p><p><div><span class=comment-ref>٥٧٥٨</span> ذهب الحسنُ وقتادةُ إلى العموم في الآية، وهو ما <span class="comment-type-4">ذكره</span> <u>ابنُ عطية</u> (٧/٤٨٣)، ثم <span class="comment-type-4">علَّق</span> بقوله: «وبيّن أن حالة النبي ﷺ كانت كذلك مبرزة».</div></p><p><div></p><p><p><span class="item-no">٦٨٥٨٠<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق معمر- <span class="qpc-hafs">﴿ومَن أحْسَنُ قَوْلًا مِمَّنْ دَعا إلى اللَّهِ وعَمِلَ صالِحًا﴾</span> فقال: هذا حبيب الله، هذا ولِيُّ الله، هذا صفوة الله، هذا خِيرة الله، هذا أحبّ أهل الأرض إلى الله، أجاب اللهَ في دعوته، ودعا الناسَ إلى ما أجاب الله فيه من دعوته، وعمل صالحًا في إجابته، <span class="qpc-hafs">﴿وقالَ إنَّنِي مِنَ المُسْلِمِينَ﴾</span> هذا خليفة الله{9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٨٥٨١<span class="dash">-</span></span> عن <span class="name-2">محمد بن سيرين</span>، في قوله: <span class="qpc-hafs">﴿ومَن أحْسَنُ قَوْلًا مِمَّنْ دَعا إلى اللَّهِ﴾</span>، قال: ذلك النبي ﷺ{8}. (١٣/١١٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٨٥٨٢<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿ومَن أحْسَنُ قَوْلًا مِمَّنْ دَعا إلى اللَّهِ وعَمِلَ صالِحًا وقالَ إنَّنِي مِنَ المُسْلِمِينَ﴾</span>، قال: هذا عبد صدَّق قولَه عملُه، ومولِجَه ومخرَجُه، وسِرَّه وعلانيتُه، ومشهدَه مغيبُه، وإنّ المنافق عبدٌ خالف قولَه عملُه، ومولجَه مخرجُه، وسرَّه علانيتُه، وشاهدَه مغيبُه{11}. (١٣/١١١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٨٥٨٣<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدّيّ</span> -من طريق أسباط- <span class="qpc-hafs">﴿ومَن أحْسَنُ قَوْلًا مِمَّنْ دَعا إلى اللَّهِ﴾</span>، قال: محمد ﷺ حين دعا إلى الإسلام{12}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٨٥٨٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: قوله: <span class="qpc-hafs">﴿ومَن أحْسَنُ قَوْلًا مِمَّنْ دَعا إلى اللَّهِ﴾</span> يعني: التوحيد، <span class="qpc-hafs">﴿وعَمِلَ صالِحًا وقالَ إنَّنِي مِنَ المُسْلِمِينَ﴾</span> يعني: المخلصين، يعني: النبي ﷺ{13}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٨٥٨٥<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿ومَن أحْسَنُ قَوْلًا مِمَّنْ دَعا إلى اللَّهِ وعَمِلَ صالِحًا وقالَ إنَّنِي مِنَ المُسْلِمِينَ﴾</span>، قال: هذا رسول الله ﷺ{12}<span class=comment-ref>٥٧٥٩</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٥٧٥٩</span> <span class="comment-type-4">ذكر</span> <u>ابنُ كثير</u> (١٢/٢٤٠) أنّ الآية عامَّةٌ في كل مَن دعا إلى خير وهو في نفسه مهتدٍ، ثم قال: «ورسول الله ﷺ أولى الناس بذلك، كما قال محمد بن سيرين، والسُّدّيّ، وعبد الرحمن بن زيد بن أسلم».</div></p><p><div></p><p><p><span class="item-no">٦٨٥٨٦<span class="dash">-</span></span> عن <span class="name-3">سفيان بن عُيينة</span> -من طريق ابن أبي عمر- في قوله -جلّ ذِكْرُه-: <span class="qpc-hafs">﴿ومن أحسن قولا ممن دعا إلى الله وعمل صالحا﴾</span> الآية، قال: نزلت في المؤذّنين، إلى قوله: <span class="qpc-hafs">﴿من المسلمين﴾</span> قال: منهم المؤذِّنون{15}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٨٥٨٧<span class="dash">-</span></span> عن <span class="name-3">عاصم بن هُبَيرة</span>، قال: إذا فرغت مِن أذانِك فقُل: لا إله إلا الله، والله أكبر، وأنا من المسلمين. ثم قرأ: <span class="qpc-hafs">﴿ومَن أحْسَنُ قَوْلًا مِمَّنْ دَعا إلى اللَّهِ وعَمِلَ صالِحًا وقالَ إنَّنِي مِنَ المُسْلِمِينَ﴾</span>{16}<span class=comment-ref>٥٧٦٠</span>. (١٣/١١١)</p></p><p></div></p><p><div><span class=comment-ref>٥٧٦٠</span> اختُلف في المراد بالآية على أقوال: <b>الأول</b>: أنها عامة. <b>الثاني</b>: النبي ﷺ. <b>الثالث</b>: المؤذّنين.</p><p>و<span class="comment-type-3">رجَّح</span> <u>ابنُ عطية</u> (٧/٤٨٣) القول بالعموم الذي قاله قتادة، والحسن، فقال: «والأصوب أن يُعتقد أن الآية نزلت عامة». ولم يذكر مستندًا.</p><p>و<span class="comment-type-4">بنحوه</span> <u>ابنُ كثير</u> (١٢/٢٤٢) <span class="mustanad">مستندًا إلى أحوال النُّزول</span>، فقال: «والصحيح أن الآية عامة في المؤذّنين وفي غيرهم، فأما حال نزول هذه الآية فإنه لم يكن الأذان مشروعًا بالكلية؛ لأنها مكية، والأذان إنما شُرع بالمدينة بعد الهجرة، حين أريه عبد الله بن زيد بن عبد ربه الأنصاري في منامه، فقصّه على رسول الله ﷺ، فأمره أن يلقيه على بلال فإنه أندى صوتًا، كما هو مقرّر في موضعه، فالصحيح إذًا أنها عامة».</div></p></div>",footnotes:1:أخرجه ابن أبي شيبة في المصنف ١/٢٢٥. وعزاه السيوطي إلى ابن المنذر، وابن مردويه.|2:عزاه السيوطي إلى عَبد بن حُمَيد، وابن أبي حاتم، وابن مردويه.|3:تفسير البغوي ٧/١٧٣.|4:تفسير الثعلبي ٨/٢٩٦، وتفسير البغوي ٧/١٧٣.|5:أخرجه الخطيب في تاريخه ٨/٤٧١-٤٧٢، وابن جرير ٢٠/٤٣٠.|6:عزاه السيوطي إلى عَبد بن حُمَيد.|7:عزاه السيوطي إلى عَبد بن حُمَيد، وابن أبي حاتم.|8:عزاه السيوطي إلى عَبد بن حُمَيد، وابن المنذر.|9:أخرجه عبد الرزاق ٢/١٨٧، وابن جرير ٢٠/٤٢٩.|10:عزاه السيوطي إلى عَبد بن حُمَيد، وابن المنذر.|11:أخرجه ابن جرير ٢٠/٤٢٩. وعزاه السيوطي إلى عَبد بن حُمَيد دون آخره.|12:أخرجه ابن جرير ٢٠/٤٣٠.|13:تفسير مقاتل بن سليمان ٣/٧٤٢.|14:أخرجه ابن جرير ٢٠/٤٣٠.|15:أخرجه إسحاق البستي ص٢٩٤.</p><p><b>وقد أورد السيوطي عقب تفسير الآية ١٣/١١١-١١٣ آثارًا كثيرة عن فضل الأذان والمؤذنين.</b>|16:أخرجه سعيد بن منصور في سننه -التفسير ٧/٢٤١ (١٨٩٣)، والثعلبي ٨/٢٩٧.
  41,34,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَلَا تَسۡتَوِی ٱلۡحَسَنَةُ وَلَا ٱلسَّیِّئَةُۚ ٱدۡفَعۡ بِٱلَّتِی هِیَ أَحۡسَنُ﴾</span> - نزول الآية</h3></p><p><div></p><p><p><span class="item-no">٦٨٥٨٨<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ولا تَسْتَوِي الحسنة ولا السَّيِّئَةُ ادْفَعْ بِالَّتِي هِيَ أحْسَنُ﴾</span>، وذلك أنّ أبا جهل كان يُؤذي النبيَّ ﷺ، وكان النبيُّ مُبغِضًا له يكره رؤيته، فأُمر بالعفو والصفح{1}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَلَا تَسۡتَوِی ٱلۡحَسَنَةُ وَلَا ٱلسَّیِّئَةُۚ ٱدۡفَعۡ بِٱلَّتِی هِیَ أَحۡسَنُ﴾</span> - تفسير الآية</h3></p><p><div></p><p><p><span class="item-no">٦٨٥٨٩<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- في قوله: <span class="qpc-hafs">﴿ولا تَسْتَوِي الحسنةُ ولا السَّيِّئَةُ ادْفَعْ بِالَّتِي هِيَ أحْسَنُ﴾</span>، قال: أمر اللهُ المؤمنين بالصّبر عند الغضب، والحِلم عند الجهل، والعفو عند الإساءة، فإذا فعلوا ذلك عصمهم اللهُ مِن الشيطان، وخضع لهم عدوُّهم كأنه ولِيٌّ حميم{2}. (١٣/١١٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٨٥٩٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، في قوله: <span class="qpc-hafs">﴿ولا تَسْتَوِي الحسنةُ ولا السَّيِّئَةُ ادْفَعْ بِالَّتِي هِيَ أحْسَنُ﴾</span> قال: القَه بالسلام <span class="qpc-hafs">﴿فَإذا الَّذِي بَيْنَكَ وبَيْنَهُ عَداوَةٌ كَأَنَّهُ ولِيٌّ حَمِيمٌ﴾</span>{3}. (١٣/١١٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٨٥٩١<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق عبد الكريم الجزري- في قوله: <span class="qpc-hafs">﴿ادْفَعْ بِالَّتِي هِيَ أحْسَنُ﴾</span>، قال: السلام، أن تُسلِّم عليه إذا لقيتَه{4}. (١٣/١١٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٨٥٩٢<span class="dash">-</span></span> عن <span class="name-2">عطاء [بن أبي رباح]</span> -من طريق طلحة بن عمرو- <span class="qpc-hafs">﴿ادْفَعْ بِالَّتِي هِيَ أحْسَنُ﴾</span>، قال: بالسلام{5}<span class=comment-ref>٥٧٦١</span>. (١٣/١١٤)</p></p><p></div></p><p><div><span class=comment-ref>٥٧٦١</span> <span class="comment-type-1">وجَّه</span> <u>ابنُ عطية</u> (٧/٤٨٤) قول مجاهد، وعطاء، بقوله: «لا شكَّ أنّ السلام هو مبدأ الدفع بالتي هي أحسن، وهو جزء منه».</div></p><p><h3><span class="qpc-hafs">﴿فَإِذَا ٱلَّذِی بَیۡنَكَ وَبَیۡنَهُۥ عَدَ ٰ⁠وَةࣱ كَأَنَّهُۥ وَلِیٌّ حَمِیمࣱ ۝٣٤﴾</span> - نزول الآية</h3></p><p><div></p><p><p><span class="item-no">٦٨٥٩٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن حيّان</span>: <span class="qpc-hafs">﴿كَأَنَّهُ ولِيٌّ حَمِيمٌ﴾</span> نزلت في أبي سفيان بن حرب، وذلك أنه لان للمسلمين بعد شِدَّة عداوته بالمصاهرة التي حصلت بينه وبين النبي ﷺ، ثم أسلم فصار وليًّا بالإسلام، حميمًا بالقرابة{6}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿فَإِذَا ٱلَّذِی بَیۡنَكَ وَبَیۡنَهُۥ عَدَ ٰ⁠وَةࣱ كَأَنَّهُۥ وَلِیٌّ حَمِیمࣱ ۝٣٤﴾</span> - تفسير الآية</h3></p><p><div></p><p><p><span class="item-no">٦٨٥٩٤<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span>، قال: الحميم: ذو القرابة. والوَلِيُّ: الصَّديق{7}. (١٣/١١٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٨٥٩٥<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿كَأَنَّهُ ولِيٌّ حَمِيمٌ﴾</span>، قال: وليّ رقيب{8}. (١٣/١١٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٨٥٩٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: يقول: إذا فعلتَ ذلك <span class="qpc-hafs">﴿فَإذا الَّذِي بَيْنَكَ وبَيْنَهُ عَداوَة﴾</span> يعني: أبا جهل <span class="qpc-hafs">﴿كَأَنَّهُ ولِيٌّ﴾</span> لك في الدين، <span class="qpc-hafs">﴿حَمِيمٌ﴾</span> لك في النسب، الشفيق عليك{1}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٣/٧٤٣.|2:أخرجه ابن جرير ٢٠/٤٣٢ بنحوه، وابن أبي حاتم -كما في التغليق ٤/٣٠٣-، والبيهقي في سننه ٧/٤٥. وعزاه السيوطي إلى ابن المنذر.|3:عزاه السيوطي إلى ابن مردويه.|4:أخرجه عبد الرزاق ٢/١٨٧، وابن جرير ٢٠/٤٣٣، والبيهقي في شعب الإيمان (٦٦٢٣). وعزاه السيوطي إلى سعيد بن منصور، وعبد بن حميد، وابن المنذر، وابن أبي حاتم.|5:أخرجه ابن جرير ٢٠/٤٣٣. وعزاه السيوطي إلى عبد بن حميد.|6:تفسير البغوي ٧/١٧٥.|7:عزاه السيوطي إلى عبد بن حميد.|8:أخرجه عبد الرزاق ٢/١٨٧-١٨٨ من طريق معمر، وابن جرير ٢٠/٤٣٣. وعزاه السيوطي إلى عبد بن حميد.|9:تفسير مقاتل بن سليمان ٣/٧٤٣.
  41,35,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَمَا یُلَقَّىٰهَاۤ إِلَّا ٱلَّذِینَ صَبَرُوا۟ وَمَا یُلَقَّىٰهَاۤ إِلَّا ذُو حَظٍّ عَظِیمࣲ ۝٣٥﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٨٥٩٧<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- قوله: <span class="qpc-hafs">﴿وما يُلَقّاها إلّا الَّذِينَ صَبَرُوا وما يُلَقّاها إلّا ذُو حَظٍّ عَظِيمٍ﴾</span>، يقول: الذين أعدَّ الله لهم الجنة{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٨٥٩٨<span class="dash">-</span></span> عن <span class="name-1">أنس بن مالك</span>، في قوله: <span class="qpc-hafs">﴿وما يُلَقّاها إلّا الَّذِينَ صَبَرُوا وما يُلَقّاها إلّا ذُو حَظٍّ عَظِيمٍ﴾</span>، قال: الرجل يشتمه أخوه، فيقول: إن كنتَ صادقًا يغفر الله لي، وإن كنتَ كاذبًا يغفر الله لك{2}. (١٣/١١٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٨٥٩٩<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span>، <span class="qpc-hafs">﴿وما يُلَقّاها إلّا الَّذِينَ صَبَرُوا﴾</span>، قال: واللهِ، لا يصيبها صاحبُها حتى يكظِم غيظًا، ويصفح عن بعض ما يكره{3}. (١٣/١١٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٨٦٠٠<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿وما يُلَقّاها إلّا الَّذِينَ صَبَرُوا﴾</span> الآية، قال: الحظّ العظيم: الجنة{4}<span class=comment-ref>٥٧٦٢</span>. (١٣/١١٤)</p></p><p></div></p><p><div><span class=comment-ref>٥٧٦٢</span> <span class="comment-type-4">ذكر</span> <u>ابنُ عطية</u> (٧/٤٨٤) أن الحظ العظيم: يحتمل احتمالين: <b>أحدهما</b>: أن يريد من العقل والفضل؛ فتكون الآية مدحًا. <b>والآخر</b>: أن يريد: ذُو حَظٍّ عَظِيمٍ من الجنة وثواب الآخرة؛ فتكون الآية وعْدًا.</div></p><p><div></p><p><p><span class="item-no">٦٨٦٠١<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدّيّ</span> -من طريق أسباط- في قوله: <span class="qpc-hafs">﴿وما يُلَقّاها إلّا ذُوحَظٍّ عَظِيمٍ﴾</span>: ذو جَدّ{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٨٦٠٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان:</span> ثم أخبر نبيَّه ﵇: <span class="qpc-hafs">﴿وما يُلَقّاها﴾</span> يعني: لا يؤتاها، يعني: الأعمال الصالحة؛ العفو والصفح <span class="qpc-hafs">﴿إلّا الَّذِينَ صَبَرُوا﴾</span> على كظْم الغيظ، <span class="qpc-hafs">﴿وما يُلَقّاها﴾</span> يعني: لا يؤتاها <span class="qpc-hafs">﴿إلّا ذُو حَظٍّ عَظِيمٍ﴾</span> نصيبًا وافرًا في الجنة، فأمره الله بالصبر والاستعاذة من الشيطان في أمر أبي جهل{6}<span class=comment-ref>٥٧٦٣</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٥٧٦٣</span> <span class="comment-type-4">ذكر</span> <u>ابنُ عطية</u> (٧/٤٨٤) أن فرقة قالت: المراد: وما يُلَقّى لا إله إلا الله. و<span class="comment-type-2">انتقده</span> <span class="mustanad">مستندًا لظاهر لفظ الآية</span>، فقال: «وهذا تفسير لا يقتضيه اللفظ».</div></p></div>",footnotes:1:أخرجه ابن جرير ٢٠/٤٣٥.|2:عزاه السيوطي إلى ابن المنذر.|3:عزاه السيوطي إلى عبد بن حميد.|4:أخرجه عبد الرزاق ٢/١٨٧-١٨٨من طريق معمر، وابن جرير ٢٠/٤٣٤. وعزاه السيوطي إلى عبد بن حميد.|5:أخرجه ابن جرير ٢٠/٤٣٤. وعزاه السيوطي إلى ابن أبي حاتم عند تفسير قوله تعالى: <span class="qpc-hafs">﴿إنَّهُ لَذُو حَظٍّ عَظِيمٍ﴾</span> [القصص:٧٩].|6:تفسير مقاتل بن سليمان ٣/٧٤٣.
  41,36,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَإِمَّا یَنزَغَنَّكَ مِنَ ٱلشَّیۡطَـٰنِ نَزۡغࣱ فَٱسۡتَعِذۡ بِٱللَّهِۖ إِنَّهُۥ هُوَ ٱلسَّمِیعُ ٱلۡعَلِیمُ ۝٣٦﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٨٦٠٣<span class="dash">-</span></span> عن سليمان بن صُرَد، قال: اسْتَبَّ رجلان عند النبيِّ ﷺ، فاشتد غضبُ أحدهما، فقال النبيُّ ﷺ: «<b>إنِّي لَأعلمُ كلمةً لو قالها لذهب عنه الغضب: أعوذ بالله من الشيطان الرجيم</b>». فقال الرجل: أمجنون تراني؟! فتلا رسول الله ﷺ: <span class="qpc-hafs">﴿وإمّا يَنْزَغَنَّكَ مِنَ الشَّيْطانِ نَزْغٌ فاسْتَعِذْ بِاللَّهِ﴾</span>{1}. (١٣/١١٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٨٦٠٤<span class="dash">-</span></span> قال <span class="name-2">قتادة بن دعامة</span>: <span class="qpc-hafs">﴿وإما ينزغنك من الشيطان نزغ﴾</span>، النَّزْغ: الغضب{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٨٦٠٥<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span>، في قوله: <span class="qpc-hafs">﴿وإمّا يَنْزَغَنَّكَ مِنَ الشَّيْطانِ نَزْغٌ فاسْتَعِذْ بِاللَّهِ﴾</span>، قال: ذُكِر لنا: أنّ نبيَّ الله ﷺ بينما هو يصلي إذ جعل يَسْنُد حتى يستلم السارية، ثم يقول: «<b>ألعنك بلعنة الله التامة</b>». فقال له بعض أصحابه: يا نبيَّ الله، ما شيءٌ رأيناك تصنعه؟ قال: «<b>أتاني الشيطانُ بشِهاب مِن نار لِيحرقني به، فلعنتُه بلعنة الله التامة، فانكبّ لِفِيه، وطَفئتْ ناره</b>»{3}. (١٣/١١٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٨٦٠٦<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدّيّ</span> -من طريق أسباط- <span class="qpc-hafs">﴿وإمّا يَنْزَغَنَّكَ مِنَ الشَّيْطانِ نَزْغٌ﴾</span> قال: وسوسة وحديث النفس، <span class="qpc-hafs">﴿فاسْتَعِذْ بِاللَّهِ﴾</span> من الشيطان الرّجيم{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٨٦٠٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وإمّا يَنْزَغَنَّكَ﴾</span> يعني: يفتننّك في أمر أبي جهل والرّد عنه <span class="qpc-hafs">﴿مِنَ الشَّيْطانِ نَزْغٌ﴾</span> يعني: فتنة؛ <span class="qpc-hafs">﴿فاسْتَعِذْ بِاللَّهِ إنَّهُ هُوالسَّمِيعُ﴾</span> بالاستعاذة، <span class="qpc-hafs">﴿العَلِيمُ﴾</span> بها. نظيرها في «حم المؤمن»: <span class="qpc-hafs">﴿إنْ فِي صُدُورِهِمْ إلّا كِبْرٌ ما هُمْ بِبالِغِيهِ فاسْتَعِذْ بِاللَّهِ إنَّهُ هُوالسَّمِيعُ البَصِيرُ﴾</span> [غافر:٥٦]، وفي الأعراف{5}، أمر أبي جهل{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٨٦٠٨<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿وإمّا يَنْزَغَنَّكَ مِنَ الشَّيْطانِ نَزْغٌ﴾</span>، قال: هذا الغضب{4}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَإِمَّا یَنزَغَنَّكَ مِنَ ٱلشَّیۡطَـٰنِ نَزۡغࣱ فَٱسۡتَعِذۡ بِٱللَّهِۖ إِنَّهُۥ هُوَ ٱلسَّمِیعُ ٱلۡعَلِیمُ ۝٣٦﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٦٨٦٠٩<span class="dash">-</span></span> عن <span class="name-2">خَيْثمة [بن عبد الرحمن]</span> -من طريق الأعمش- قال: إنّ الشيطان يقول: كيف يغلبني ابنُ آدم؟! إذا رضي جئتُ حتى أكون في قلبه، وإذا غضب طِرتُ حتى أكون في رأسه{8}. (١٣/١١٦)</p></p><p></div></p></div>",footnotes:1:أخرجه البخاري ٤/١٢٤ (٣٢٨٢)، ٨/١٥-١٦ (٦٠٤٨)، ٨/٢٨ (٦١١٥)، ومسلم ٤/٢٠١٥ (٢٦١٠)، كلاهما دون ذكر الآية، والحاكم ٢/٤٧٨ (٣٦٤٩) واللفظ له.</p><p>قال الحاكم: «هذا حديث صحيح الإسناد».|2:ذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٤/١٥٤-.|3:عزاه السيوطي إلى عبد بن حميد، وابن المنذر.|4:أخرجه ابن جرير ٢٠/٤٣٥.|5:يشير إلى الآية [٢٠٠] وهي قوله تعالى: <span class="qpc-hafs">﴿وإمّا يَنْزَغَنَّكَ مِنَ الشَّيْطانِ نَزْغٌ فاسْتَعِذْ بِاللَّهِ إنَّهُ سَمِيعٌ عَلِيمٌ﴾</span>.|6:تفسير مقاتل بن سليمان ٣/٧٤٣.|7:أخرجه ابن جرير ٢٠/٤٣٥.|8:أخرجه ابن أبي شيبة ١٣/٤٤٦.
  41,37,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَمِنۡ ءَایَـٰتِهِ ٱلَّیۡلُ وَٱلنَّهَارُ وَٱلشَّمۡسُ وَٱلۡقَمَرُۚ لَا تَسۡجُدُوا۟ لِلشَّمۡسِ وَلَا لِلۡقَمَرِ وَٱسۡجُدُوا۟ لِلَّهِ ٱلَّذِی خَلَقَهُنَّ إِن كُنتُمۡ إِیَّاهُ تَعۡبُدُونَ ۝٣٧﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٨٦١٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ومِن آياتِهِ﴾</span> أن يُعرف التوحيد بصُنعه وإن لم تروه <span class="qpc-hafs">﴿اللَّيْلُ والنَّهارُ والشَّمْسُ والقَمَرُ لا تَسْجُدُوا لِلشَّمْسِ ولا لِلْقَمَرِ واسْجُدُوا لِلَّهِ الَّذِي خَلَقَهُنَ﴾</span> يعني: الذي خلق هؤلاء الآيات؛ <span class="qpc-hafs">﴿إنْ كُنْتُمْ إيّاهُ تَعْبُدُونَ﴾</span>. فسجد النبيُّ ﷺ والمؤمنون يومئذ، فقال كفار مكة عند ذلك: بل نسجد للّات والعُزّى ومَناة{1}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٣/٧٤٣.
  41,38,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿فَإِنِ ٱسۡتَكۡبَرُوا۟ فَٱلَّذِینَ عِندَ رَبِّكَ یُسَبِّحُونَ لَهُۥ بِٱلَّیۡلِ وَٱلنَّهَارِ وَهُمۡ لَا یَسۡـَٔمُونَ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٨٦١١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطية- قوله: <span class="qpc-hafs">﴿فَإنِ اسْتَكْبَرُوا فالَّذِينَ عِنْدَ رَبِّكَ يُسَبِّحُونَ لَهُ بِاللَّيْلِ والنَّهارِ﴾</span>، قال: يعني: محمدًا، يقول: عبادي ملائكة صافّون، يسبّحون ولا يستكبرون{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٨٦١٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، أن نافع بن الأزرق سأله عن قوله: <span class="qpc-hafs">﴿لا يَسْأَمُونَ﴾</span>. قال: لا يفتُرون ولا يمَلّون. قال: وهل تعرف العرب ذلك؟ قال: نعم، أما سمعت قول الشاعر:</p><p>من الخوف لا ذو سأمةٍ من عبادةٍ ولا هو من طول التعبد يُجهَد{2}. (١٣/١١٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٨٦١٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: يقول الله تعالى: <span class="qpc-hafs">﴿فَإنِ اسْتَكْبَرُوا﴾</span> عن السجود لله <span class="qpc-hafs">﴿فالَّذِينَ عِنْدَ رَبِّكَ﴾</span> مِن الملائكة <span class="qpc-hafs">﴿يُسَبِّحُونَ لَهُ بِاللَّيْلِ والنَّهارِ وهُمْ لا يَسْأَمُونَ﴾</span> يعني: لا يَمَلُّون مِن الذِّكر له والعبادة، وليست لهم فترة ولا سآمة{3}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿فَإِنِ ٱسۡتَكۡبَرُوا۟ فَٱلَّذِینَ عِندَ رَبِّكَ یُسَبِّحُونَ لَهُۥ بِٱلَّیۡلِ وَٱلنَّهَارِ وَهُمۡ لَا یَسۡـَٔمُونَ﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٦٨٦١٤<span class="dash">-</span></span> عن ليث، عن الحكم، عن رجل من بني سليم: أنّه سمع رسول الله ﷺ يسجد في «حم» بالآية الأولى{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٨٦١٥<span class="dash">-</span></span> عن <span class="name-1">علي بن أبي طالب</span> -من طريق الحارث- قال: عزائم السجود أربع: «آلم تنزيل السجدة»، و«حم السجدة»، والنّجم، و«اقرأ باسم ربك»{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٨٦١٦<span class="dash">-</span></span> عن أبي اسحاق، قال: سمعتُ عبد الرحمن بن يزيد وعبد الرحمن بن الأسود يقولان: كان <span class="name-1">عبد الله [بن مسعود]</span> يسجد بالآية الأولى من <span class="qpc-hafs">﴿حم تنزيل من الرحمن الرحيم﴾</span>{6}. (١٣/١١٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٨٦١٧<span class="dash">-</span></span> عن سعيد بن جُبير: أنّ <span class="name-1">عبد الله بن عباس</span> كان يسجد بآخر الآيتين من «حم السجدة»، وكان <span class="name-1">ابن مسعود</span> يسجد بالأولى منهما{7}. (١٣/١١٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٨٦١٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>: أنّه كان يسجد في الآية الأخيرة من <span class="qpc-hafs">﴿حم تنزيل﴾</span>{8}. (١٣/١١٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٨٦١٩<span class="dash">-</span></span> قال مجاهد بن جبر: سألتُ <span class="name-1">عبد الله بن عباس</span> عن السجدة في <span class="qpc-hafs">﴿حم﴾</span> فقال: اسجدوا بالآخرة من الآيتين{9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٨٦٢٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عمر</span> -من طريق نافع- أنه كان يسجد بالآية الأولى{10}. (١٣/١١٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٨٦٢١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عمر</span>: أنّه كان يسجد في الآية الأخيرة{8}. (١٣/١١٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٨٦٢٢<span class="dash">-</span></span> عن <span class="name-1">عبدة بن حَزْن النَّصرى</span> -وله صحبة-: أنّه سجد في الآية الأولى من <span class="qpc-hafs">﴿حم﴾</span>{12}. (١٣/١١٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٨٦٢٣<span class="dash">-</span></span> عن <span class="name-2">أبي وائل</span> -من طريق مغيرة-: أنّه كان يسجد في الآية الآخرة{13}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٨٦٢٤<span class="dash">-</span></span> عن طلحة، عن <span class="name-2">إبراهيم [النخعي]</span>: أنّه كان يسجد في <span class="qpc-hafs">﴿يَسْأَمُونَ﴾</span>{14}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٨٦٢٥<span class="dash">-</span></span> عن <span class="name-2">محمد بن سيرين</span> -من طريق ابن عون-: أنه كان يسجد في الآية الآخرة{15}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٨٦٢٦<span class="dash">-</span></span> عن الأعمش، قال: أدركت <span class="name-2">إبراهيم</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٨٦٢٧<span class="dash">-</span></span> و<span class="name-2">أبا صالح</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٨٦٢٨<span class="dash">-</span></span> و<span class="name-2">طلحة</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٨٦٢٩<span class="dash">-</span></span> و<span class="name-2">يحيى</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٨٦٣٠<span class="dash">-</span></span> و<span class="name-2">زُبيدًا اليامي</span>: يسجدون بالآية الأولى من <span class="qpc-hafs">﴿حم﴾</span> السجدة{16}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ٢٠/٤٣٧.|2:أخرجه الطستي في مسائله -كما في الإتقان ٢/٨٧-.|3:تفسير مقاتل بن سليمان ٣/٧٤٣.|4:أخرجه ابن أبي شيبة في مصنفه (ت: عوامة) ٢/١١.|5:أخرجه الطبراني في الأوسط ٧/٣١٠ (٧٥٨٨)، كما أخرج الشافعي في كتاب الأم ٨/٤١٥ نحوه من طريق زر.|6:أخرجه إسحاق البستي ص٢٨٨. وعزاه السيوطي إلى سعيد بن منصور.|7:أخرجه ابن أبي شيبة ٢/١٠-١١، والحاكم ٢/٤٤١، والبيهقي في سننه ٢/٣٢٦.|8:عزاه السيوطي إلى سعيد بن منصور.|9:أخرجه يحيى بن سلام -كما في تفسير ابن أبي زمنين ٤/١٥٤-، وإسحاق البستي ص٢٩٥ بنحوه.|10:أخرجه ابن أبي شيبة ٢/١٠-١١. وعزاه السيوطي إلى ابن سعد.|11:عزاه السيوطي إلى سعيد بن منصور.|12:أخرجه البخاري في تاريخه ٦/١١٣.|13:أخرجه سعيد بن منصور في سننه -التفسير ٧/٢٤٥ (١٨٩٩)، وابن أبي شيبة (ت: عوامة) ٢/١٠.|14:أخرجه عبد الله بن وهب في الجامع -تفسير القرآن ٣/١٠٥ (٢٤٤)، وابن أبي شيبة (ت: عوامة) ٢/١٠.|15:أخرجه سعيد بن منصور في سننه -التفسير ٧/٢٤٥ (١٩٠٠)، وابن أبي شيبة (ت: عوامة) ٢/١٠.|16:أخرجه ابن أبي شيبة (ت: عوامة) ٢/١١.