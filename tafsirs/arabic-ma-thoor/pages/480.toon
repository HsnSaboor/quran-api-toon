quran[9]{c,v,t}:
41,30," <q>﴿إِنَّ ٱلَّذِینَ قَالُوا۟ رَبُّنَا ٱللَّهُ ثُمَّ ٱسۡتَقَـٰمُوا۟﴾</q> - تفسير ٦٨٥١٥- عن أنس بن مالك، قال: قرأ علينا رسولُ الله ﷺ هذه الآية: <q>﴿إنَّ الَّذِينَ قالُوا رَبُّنا اللَّهُ ثُمَّ اسْتَقامُوا﴾</q>، قال: «قد قالها ناسٌ مِن الناس، ثم كفر أكثرُهم، فمَن قالها حتى يموت فهو مِمَّن استقام عليها»{1}٥٧٥٤. (١٣/١٠٣) ٥٧٥٤ ساق ابنُ عطية (٧/٤٨١-٤٨٢) هذا الأثر، ثم قال: «المعنى: فهو في أول درجات الاستقامة، أمن الخلود، فهذا كقوله ﷺ: «من كان آخر كلامه لا إله إلا الله دخل الجنة». وهذا هو المعتقد -إن شاء الله-، وذلك أنّ العُصاة مِن أمة محمد ﷺ وغيرها فرقتان: فأمّا من قضى الله بالمغفرة له وترك تعذيبه، فلا محالة أنه ممن تنزل عليه الملائكة بالبشارة، وهو إنما استقام على توحيده فقط، وأما مَن قضى الله بتعذيبه مدة، ثم بإدخاله الجنة، فلا محالة أنه يلقى جميع ذلك عند موته ويعلمه، وليس يصح أن تكون حاله كحالة الكافر اليائس من رحمة الله، وإذا كان هذا فقد حصلت له البشارة بأن لا يخاف الخلود ولا يحزن منه، وبأنه يصير آخرًا إلى الخلود في الجنة، وهل العصاة المؤمنون إلا تحت الوعد بالجنة؟ فهم داخلون فيمن يقال لهم: <q>﴿أبْشِرُوا بِالجَنَّةِ الَّتِي كُنْتُمْ تُوعَدُونَ﴾</q>، ومع هذا كله، فلا يختلف أنّ الموحِّد المستقيم على الطاعة أتم حالًا، وأكمل بشارة، وهو مقصد أمير المؤمنين عمر بن الخطاب ﵁، وعلى نحو ذلك قال سفيان: اسْتَقامُوا، عملوا بنحو ما قالوا. وقال الربيع: أعرضوا عمّا سوى الله. وقال الفضيل: زهدوا في الفانية، ورغبوا في الباقية. وبالجملة فكلما كان المرء أشد استعدادًا كان أسرع فوزًا بفضل الله تعالى». ٦٨٥١٦- عن أنس بن مالك: إنّ النبي ﷺ قال لما نزلت هذه الآية: <q>﴿إنَّ الَّذِينَ قالُوا رَبُّنا اللَّهُ ثُمَّ اسْتَقامُوا﴾</q>: «أمتي، وربِّ الكعبة»{2}. (ز) ٦٨٥١٧- عن أبي بكر الصِّدِّيق -من طريق سعيد بن نِمْران - في قوله: <q>﴿إنَّ الَّذِينَ قالُوا رَبُّنا اللَّهُ ثُمَّ اسْتَقامُوا﴾</q>، قال: الاستقامة: أن لا تشركوا بالله شيئًا{3}. (١٣/١٠٣) ٦٨٥١٨- عن أبي بكر الصِّدِّيق -من طريق الأسود بن هلال- أنه قال: ما تقولون في هاتين الآيتين: <q>﴿إنَّ الَّذِينَ قالُوا رَبُّنا اللَّهُ ثُمَّ اسْتَقامُوا﴾</q>، و<q>﴿الَّذِينَ آمَنُوا ولَمْ يَلْبِسُوا إيمانَهُمْ بِظُلْمٍ﴾</q> [الأنعام:٨٢]؟ قالوا: الذين قالوا ربنا الله، ثم عملوا بها، واستقاموا على أمره، فلم يُذنبوا، <q>﴿ولَمْ يَلْبِسُوا إيمانَهُمْ بِظُلْمٍ﴾</q>: لم يُذنبوا. قال: لقد حملتموها على أمر شديد؛ <q>﴿الَّذِينَ آمَنُوا ولَمْ يَلْبِسُوا إيمانَهُمْ بِظُلْمٍ﴾</q> يقول: بشرك، و<q>﴿الَّذِينَ قالُوا رَبُّنا اللَّهُ ثُمَّ اسْتَقامُوا﴾</q> فلم يرجعوا إلى عبادة الأوثان{4}. (١٣/١٠٤) ٦٨٥١٩- عن أبي بكر الصِّدّيق -من طريق الأسود بن هلال المحاربي- قال: ما تقولون في هذه الآية: <q>﴿الَّذِينَ قالُوا رَبُّنا اللَّهُ ثُمَّ اسْتَقامُوا﴾</q>؟ قال: فقالوا: ربنا الله، ثم استقاموا مِن ذنب. قال: فقال أبو بكر: لقد حملتم على غير المحمل؛ <q>﴿قالوا: ربنا الله، ثم استقاموا﴾</q> فلم يلتفتوا إلى إلهٍ غيره{5}. (ز) ٦٨٥٢٠- عن أبي اسحاق، عن رجل، قال: قال رجل: يا خليفةَ رسول الله ﷺ: ما قوله: <q>﴿الذين قالوا ربنا الله ثم استقاموا﴾</q>؟ قال: على لا إله إلا الله{6}. (ز) ٦٨٥٢١- عن عمر بن الخطاب -من طريق الزُّهري- <q>﴿الَّذِينَ قالُوا رَبُّنا اللَّهُ ثُمَّ اسْتَقامُوا﴾</q>، قال: استقاموا بطاعة، ولم يروغوا روَغان الثعلب{7}٥٧٥٥. (١٣/١٠٤) ٥٧٥٥ ساق ابنُ عطية (٧/٤٨١) قول عمر، ثم علَّق قائلًا: «ذهب ﵁ إلى حمل الناس على الأتم الأفضل، وإلا فيلزم -على هذا التأويل- مِن دليل خطابه ألا تنزل الملائكة عند الموت على غير مستقيم على الطاعة». ٦٨٥٢٢- قال عثمان بن عفان: <q>﴿الَّذِينَ قالُوا رَبُّنا اللَّهُ ثُمَّ اسْتَقامُوا﴾</q> أخلصوا العمل لله{8}. (ز) ٦٨٥٢٣- قال علي بن أبي طالب: <q>﴿الَّذِينَ قالُوا رَبُّنا اللَّهُ ثُمَّ اسْتَقامُوا﴾</q> أدّوا الفرائض{8}. (ز) ٦٨٥٢٤- عن عبد الله بن عباس -من طريق عكرمة- في قوله: <q>﴿الَّذِينَ قالُوا رَبُّنا اللَّهُ ثُمَّ اسْتَقامُوا﴾</q>، قال: على شهادة أن لا إله إلا الله{10}. (١٣/١٠٤) ٦٨٥٢٥- عن عبد الله بن عباس، <q>﴿قالُوا رَبُّنا اللَّهُ﴾</q> يقول: وحَّد اللهَ، <q>﴿ثُمَّ اسْتَقامُوا﴾</q> يقول: على أداء فرائضه{11}. (١٣/١٠٥) ٦٨٥٢٦- عن عبد الله بن عباس أنه سُئل: أيُّ آية في كتاب الله أرجى؟ قال: قوله: <q>﴿الَّذِينَ قالُوا رَبُّنا اللَّهُ ثُمَّ اسْتَقامُوا﴾</q> على شهادة أن لا إله إلا الله. قيل له: فأين قوله تعالى: <q>﴿قُلْ يا عِبادِيَ الَّذِينَ أسْرَفُوا عَلى أنْفُسِهِمْ﴾</q> [الزمر: ٥٣] زاد، اقرأ: <q>﴿وأَنِيبُوا إلى رَبِّكُمْ﴾</q> [الزمر:٥٤] فيها، علَّقه، أي اعملوا{12}. (١٣/١٠٥) ٦٨٥٢٧- عن أنس بن مالك -من طريق ثابت البُناني- في قوله ﷿: <q>﴿الذين قالوا ربنا الله ثم استقاموا﴾</q>، قال: استقاموا على لا إله إلا الله{13}. (ز) ٦٨٥٢٨- عن إبراهيم النَّخْعي= (ز) ٦٨٥٢٩- ومجاهد بن جبر -من طريق منصور- في قوله: <q>﴿ثُمَّ اسْتَقامُوا﴾</q>، قالا: قالوا: لا إله إلا الله، لم يشركوا بعدها بالله شيئًا حتى يَلقَوه{14}. (١٣/١٠٥) ٦٨٥٣٠- عن الأسود بن هلال -من طريق جامع بن شداد-، مثله{15}. (ز) ٦٨٥٣١- عن مجاهد بن جبر -من طريق ليث- <q>﴿إنَّ الَّذِينَ قالُوا رَبُّنا اللَّهُ ثُمَّ اسْتَقامُوا﴾</q>، قال: أي: على لا إله إلا الله{15}. (ز) ٦٨٥٣٢- عن عكرمة مولى ابن عباس -من طريق الحكم بن أبان- قوله: <q>﴿إنَّ الَّذِينَ قالُوا رَبُّنا اللَّهُ ثُمَّ اسْتَقامُوا﴾</q>، قال: استقاموا على شهادة أن لا إله إلا الله{15}. (ز) ٦٨٥٣٣- عن الحسن البصري -من طريق معمر- أنّه كان إذا تلا هذه الآية: <q>﴿إنَّ الَّذِينَ قالُوا رَبُّنا اللَّهُ ثُمَّ اسْتَقامُوا﴾</q>، يقول: اللهمَّ، أنت ربنا، فارزقنا الاستقامة{18}. (ز) ٦٨٥٣٤- قال محمد بن سيرين: <q>﴿إنَّ الَّذِينَ قالُوا رَبُّنا اللَّهُ ثُمَّ اسْتَقامُوا﴾</q> لم يعوجُّوا{19}. (ز) ٦٨٥٣٥- عن قتادة بن دعامة -من طريق معمر- في قوله تعالى: <q>﴿إنَّ الَّذِينَ قالُوا رَبُّنا اللَّهُ ثُمَّ اسْتَقامُوا﴾</q>، قال: استقاموا على طاعة الله{20}. (ز) ٦٨٥٣٦- عن إسماعيل السُّدّيّ -من طريق أسباط- <q>﴿إنَّ الَّذِينَ قالُوا رَبُّنا اللَّهُ ثُمَّ اسْتَقامُوا﴾</q>، قال: تَمُّوا على ذلك{15}. (ز) ٦٨٥٣٧- قال الربيع [بن أنس]: <q>﴿إنَّ الَّذِينَ قالُوا رَبُّنا اللَّهُ ثُمَّ اسْتَقامُوا﴾</q> أعرضوا عمّا سوى الله تعالى{19}. (ز) ٦٨٥٣٨- قال مقاتل بن سليمان: ثم أخبر عن المؤمنين، فقال: <q>﴿إنَّ الَّذِينَ قالُوا رَبُّنا اللَّهُ﴾</q> فعرفوه، <q>﴿ثُمَّ اسْتَقامُوا﴾</q> على المعرفة، ولم يرتدّوا عنها{23}. (ز) ٦٨٥٣٩- عن سفيان الثوري، قال: <q>﴿إنَّ الَّذِينَ قالُوا رَبُّنا اللَّهُ ثُمَّ اسْتَقامُوا﴾</q> عمِلوا على وفاق ما قالوا{19}. (ز) ٦٨٥٤٠- قال فُضيْل بن عِياض: <q>﴿إنَّ الَّذِينَ قالُوا رَبُّنا اللَّهُ ثُمَّ اسْتَقامُوا﴾</q> زهدوا في الفانية، ورغبوا في الباقية{19}. (ز) ٦٨٥٤١- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿إنَّ الَّذِينَ قالُوا رَبُّنا اللَّهُ ثُمَّ اسْتَقامُوا﴾</q>، قال: استقاموا على عبادة الله، وعلى طاعته{26}. (ز) <q>﴿إِنَّ ٱلَّذِینَ قَالُوا۟ رَبُّنَا ٱللَّهُ ثُمَّ ٱسۡتَقَـٰمُوا۟﴾</q> - آثار متعلقة بالآية ٦٨٥٤٢- عن ثوبان مولى النبي ﷺ، أنّ النبي ﷺ قال: «استقيموا ولن تُحصُوا، واعلموا أنّ خير أعمالكم الصلاة، ولن يُحافِظ على الوضوء إلا مؤمن»{27}. (ز) ٦٨٥٤٣- عن سفيان الثقفي، أنّ رجلًا قال: يا رسول الله، مُرني بأمرٍ في الإسلام لا أسأل عنه أحدًا بعدك. قال: «قل: آمنتُ بالله، فاستقِم»{28}. (١٣/١٠٦) <q>﴿تَتَنَزَّلُ عَلَیۡهِمُ ٱلۡمَلَـٰۤىِٕكَةُ﴾</q> - تفسير ٦٨٥٤٤- عن عبد الله بن عباس -من طريق علي- <q>﴿تَتَنَزَّلُ عَلَيْهِمُ المَلائِكَةُ﴾</q>، قال: في الآخرة{29}. (١٣/١٠٥) ٦٨٥٤٥- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿تَتَنَزَّلُ عَلَيْهِمُ المَلائِكَةُ﴾</q>، قال: عند الموت{30}. (١٣/١٠٦) ٦٨٥٤٦- عن الحسن البصري: <q>﴿تَتَنَزَّلُ عَلَيْهِمُ المَلائِكَةُ ألّا تَخافُواْ ولا تَحْزَنُواْ﴾</q> أنّ قول الملائكة لهم: لا تخافوا ولا تحزنوا. تستقبلهم بهذا إذا خرجوا من قبورهم{31}. (ز) ٦٨٥٤٧- قال قتادة بن دعامة: <q>﴿تَتَنَزَّلُ عَلَيْهِمُ المَلائِكَةُ ألّا تَخافُوا ولا تَحْزَنُوا﴾</q> إذا قاموا من قبورهم{19}. (ز) ٦٨٥٤٨- عن ثابت بن أسلم البُناني -من طريق جعفر بن سليمان- أنّه قرأ «حم السجدة» حتى بلغ: <q>﴿تَتَنَزَّلُ عَلَيْهِمُ المَلائِكَةُ﴾</q> فوقف، فقال: بلغنا: أنّ العبد المؤمن حين يبعثه الله مِن قبره يتلقّاه ملكاه اللذان كانا معه في الدنيا، فيقولان له: لا تخف ولا تحزن، وأبْشِر بالجنة التي كنت تُوعد. فيُؤمِّن اللهُ خوفَه، ويُقِرُّ عينَه، فما عظيمةٌ إلا وهي للمؤمن قُرّة عين لِما هداه الله، ولِما كان يعمل في الدنيا{33}. (١٣/١٠٨) ٦٨٥٤٩- عن إسماعيل السُّدّيّ -من طريق أسباط- <q>﴿تَتَنَزَّلُ عَلَيْهِمُ المَلائِكَةُ﴾</q>، قال: عند الموت{34}. (ز) ٦٨٥٥٠- عن زيد بن أسلم، <q>﴿تَتَنَزَّلُ عَلَيْهِمُ المَلائِكَةُ﴾</q>، قال: يُبشَّر بها عند موته، وفي قبره، ويوم يُبعث، فإنّه لَفي الجنة وما ذهبتْ فرحةُ البِشارة مِن قلبه{35}٥٧٥٦. (١٣/١٠٧) ٥٧٥٦ علَّق ابنُ كثير (١٢/٢٣٧) على هذا القول الذي قاله ابن زيد ووكيع بن الجراح بقوله: «هذا القول يجمع الأقوال كلها، وهو حسن جِدًّا، وهو الواقع». ٦٨٥٥١- قال مقاتل بن سليمان: <q>﴿تَتَنَزَّلُ عَلَيْهِمُ المَلائِكَةُ﴾</q> في الآخرة مِن السماء، وهم الحفظة{23}. (ز) ٦٨٥٥٢- عن ابن المبارك، قال: سمعت سفيان [الثوريَّ] يقول في قول الله تعالى: <q>﴿تتنزل عليهم الملائكة﴾</q>: أي: عند الموت ...، <q>﴿وأبشروا بالجنة التي كنتم توعدون﴾</q> قال: يُبشَّرون بثلاث تبشيرات عند الموت، وإذا خرج من القبر، وإذا فزع: <q>﴿نحن أولياؤكم في الحيوة الدنيا وفي الآخرة﴾</q> وكانوا معهم{37}. (ز) <q>﴿أَلَّا تَخَافُوا۟ وَلَا تَحۡزَنُوا۟﴾</q> - تفسير ٦٨٥٥٣- قال أبوالعالية الرَّياحي: <q>﴿ألا تَخافُوا﴾</q> على صنيعكم، <q>﴿ولا تَحْزَنُوا﴾</q> على مُخلّفيكم{19}. (ز) ٦٨٥٥٤- عن مجاهد بن جبر -من طريق ابن أبي نجيح- قوله: <q>﴿تَتَنَزَّلُ عَلَيْهِمُ المَلائِكَةُ ألّا تَخافُواْ ولا تَحْزَنُواْ﴾</q>، قال: ألّا تخافوا مِمّا تُقدِمون عليه مِن الموت وأمر الآخرة، ولا تحزنوا على ما خلَّفتم مِن أمر دنياكم؛ مِن ولد أو أهل أو دَيْن، فإنّا سنخلفكم في ذلك كله{39}. (١٣/١٠٦) ٦٨٥٥٥- عن عكرمة مولى ابن عباس، <q>﴿تَتَنَزَّلُ عَلَيْهِمُ المَلائِكَةُ ألّا تَخافُواْ ولا تَحْزَنُواْ﴾</q>، قال: لا تخافوا ما أمامكم، ولا تحزنوا على ما خلفكم مِن ضَيْعتكم{40}. (١٣/١٠٧) ٦٨٥٥٦- قال عطاء بن رباح: <q>﴿لا تَخافُوا ولا تَحْزَنُوا﴾</q> على ذنوبكم، فإنّي أغفرها لكم{41}. (ز) ٦٨٥٥٧- عن إسماعيل السُّدّيّ -من طريق أسباط- <q>﴿ألّا تَخافُوا ولا تَحْزَنُوا﴾</q>، قال: لا تخافوا ما أمامكم، ولا تحزنوا على ما بعدكم{42}. (ز) ٦٨٥٥٨- عن زيد بن أسلم -من طريق سفيان- في هذه الآية: <q>﴿ألّا تَخافُوا ولا تَحْزَنُوا﴾</q>، قال: لا تخافوا ما أمامكم، ولا تحزنوا على ما خلفتم{43}. (ز) ٦٨٥٥٩- عن سفيان الثوري -من طريق ابن المبارك- في قول الله: <q>﴿ألا تخافوا﴾</q> قال: ما أمامكم، <q>﴿ولا تحزنوا﴾</q> على ما خلَّفتُم من ضَيعاتكم{37}. (ز) <q>﴿وَأَبۡشِرُوا۟ بِٱلۡجَنَّةِ ٱلَّتِی كُنتُمۡ تُوعَدُونَ ۝٣٠﴾</q> - تفسير ٦٨٥٦٠- عن إسماعيل السُّدّي -من طريق أسباط-: <q>﴿وأَبْشِرُوا بِالجَنَّةِ الَّتِي كُنْتُمْ تُوعَدُونَ﴾</q> في الدنيا{42}. (ز) ٦٨٥٦١- قال مقاتل بن سليمان: <q>﴿ألّا تَخافُوا ولا تَحْزَنُوا وأَبْشِرُوا بِالجَنَّةِ الَّتِي كُنْتُمْ تُوعَدُونَ﴾</q> وذلك أنّ المؤمن إذا خرج من قبره، فينفض رأسه، ومَلَكه قائمٌ على رأسه يُسَلِّم عليه، فيقول الملَك للمؤمن: أتعرفني؟ فيقول: لا. فيقول: أنا الذي كنتُ أكتب عملَك الصالح، فلا تَخفْ ولا تَحزن، وأبشِر بالجنة التي كنت تُوعَد. وذلك أنّ الله وعدهم على ألسنة الرسل في الدنيا الجنة{23}. (ز) ٦٨٥٦٢- قال وكيع بن الجرّاح: <q>﴿تَتَنَزَّلُ عَلَيْهِمُ المَلائِكَةُ ألّا تَخافُوا ولا تَحْزَنُوا﴾</q>، البشرى تكون في ثلاثة مواطن: عند الموت، وفي القبر، وفي البعث{41}. (ز) <q>﴿وَأَبۡشِرُوا۟ بِٱلۡجَنَّةِ ٱلَّتِی كُنتُمۡ تُوعَدُونَ ۝٣٠﴾</q> - آثار متعلقة بالآية ٦٨٥٦٣- عن أنس بن مالك، قال: قال رسول الله ﷺ: «مَن أحبَّ لقاء الله أحبَّ اللهُ لقاءَه، ومَن كره لقاء الله كره الله لقاءه» قلنا: يا رسول الله، كلّنا نكره الموت. قال: «ليس ذلك كراهية الموت، ولكن المؤمن إذا حُضر جاءه البشير مِن الله بما هو صائر إليه، فليس شيءٌ أحبّ إليه مِن أن يكون قد لقي الله، فأحبّ الله لقاءه. وإن الفاجر والكافر إذا حُضر جاءه بما هو صائر إليه من الشر، فكره لقاء الله، فكره الله لقاءه»{48}. (١٣/١٠٨) ٦٨٥٦٤- عن علي بن أبي طالب -من طريق المنهال- قال: حرامٌ على كلِّ نفس أن تَخرج مِن الدنيا حتى تعلم أين مصيرها{49}. (١٣/١٠٧) ٦٨٥٦٥- عن مجاهد بن جبر، قال: إنّ المؤمن لَيُبشَّر بصلاح ولده من بعده؛ لِتَقَرّ عينُه{50}. (١٣/١٠٧) ٦٨٥٦٦- عن زيد بن أسلم، قال: يُؤتى المؤمنُ عند الموت، فيُقال له: لا تخف مِمّا أنت قادم عليه -فيذهب خوفه-، ولا تحزن على الدنيا، ولا على أهلها، وأبْشِر بالجنة. فيموت وقد أقرَّ الله عينه{51}. (١٣/١٠٦) ",footnotes:1:أخرجه الترمذي ٥/٤٥٤ (٣٥٣٢)، وابن جرير ٢٠/٤٢٢. وقال ابن كثير (١٢/٢٣٥): «وكذا رواه النسائي في تفسيره، والبزار، وابن جرير، عن عمرو بن علي الفلاس، عن سلم بن قتيبة، به. وكذا رواه ابن أبي حاتم، عن أبيه، عن الفلاس، به». قال الترمذي: «هذا حديث غريب، لا نعرفه إلا من هذا الوجه». وقال ابن القيسراني في ذخيرة الحفاظ ٣/١٦٧٩ (٣٧٧١): «رواه سهيل بن أبي حازم عن ثابت عن أنس، وسهيل ضعيف، ولم يُتابع عليه».أورده الثعلبي ٨/٢٩٤.أخرجه ابن المبارك (٣٢٦)، وسفيان الثوري ص٢٦٦، وعبد الرزاق ٢/١٨٧، ومسدد -كما في المطالب (٤٠٨٦)-، وابن سعد ٦/٨٤، وابن جرير ٢٠/٤٢٢-٤٢٣ بلفظ: هم الذين لم يشركوا بالله شيئًا. وعزاه السيوطي إلى الفريابي، وسعيد بن منصور، وعبد بن حميد، وابن المنذر، وابن أبي حاتم.أخرجه إسحاق ابن راهويه -كما في المطالب العالية (٣٩٧١)-، والحكيم الترمذي في نوادر الأصول ١/٢٣١، ٤/٢٠٦، وابن جرير ٢٠/٤٢٣ بلفظ: <q>﴿إن الَّذِينَ قالُوا رَبُّنا اللَّهُ ثُمَّ اسْتَقامُوا﴾</q> قال: قالوا: ربنا الله، ثم عملوا بها، قال: لقد حملتموها على غير المحمل. <q>﴿إن الَّذِينَ قالُوا رَبُّنا اللَّهُ ثُمَّ اسْتَقامُوا﴾</q> الذين لم يعدلوها بشرك ولا غيره، والحاكم ٢/٤٤٠، وأبو نعيم في الحلية ١/٣٠. وعزاه السيوطي إلى عبد بن حميد، وابن مردويه.أخرجه ابن جرير ٢٠/٤٢٣.أخرجه إسحاق البستي ص٢٩٤.أخرجه ابن المبارك (٣٢٥)، وأحمد في الزهد ص١١٥، والحكيم الترمذي ١/٢٣١، وابن جرير ٢٠/٤٢٥. وعزاه السيوطي إلى سعيد بن منصور، وعبد بن حميد، وابن المنذر.تفسير الثعلبي ٨/٢٩٣، وتفسير البغوي ٧/١٧٢.تفسير الثعلبي ٨/٢٩٣، وتفسير البغوي ٧/١٧٢.أخرجه البيهقي في الأسماء والصفات (٢٠٥).عزاه السيوطي إلى ابن أبي حاتم، وابن المنذر. وأخرج ابن جرير ٢٠/٤٢٥ شطره الأخير من طريق علي.عزاه السيوطي إلى عبد بن حميد.أخرجه الطبراني في الدعاء ٣/١٥٢٥.أخرجه ابن جرير ٢٠/٤٢٤ عن مجاهد. وعزاه السيوطي إلى عبد بن حميد. كما أخرجه ابن جرير ٢٠/٤٢٤ بلفظ: أسلموا ثم لم يشركوا به حتى لحقوا به.أخرجه ابن جرير ٢٠/٤٢٤.أخرجه ابن جرير ٢٠/٤٢٤.أخرجه ابن جرير ٢٠/٤٢٤.أخرجه عبد الرزاق ٢/١٨٦، وابن جرير ٢١/٤٦٥ من طريق قتادة.تفسير الثعلبي ٨/٢٩٤.أخرجه عبد الرزاق ٢/١٨٦، وابن جرير ٢٠/٤٢٥.أخرجه ابن جرير ٢٠/٤٢٤.تفسير الثعلبي ٨/٢٩٤.تفسير مقاتل بن سليمان ٣/٧٤٢.تفسير الثعلبي ٨/٢٩٤.تفسير الثعلبي ٨/٢٩٤.أخرجه ابن جرير ٢٠/٤٢٥.أخرجه أحمد ٣٧/٦٠ (٢٢٣٧٨)، ٣٧/١١٠ (٢٢٤٣٦)، وابن ماجه ١/١٨٤ (٢٧٧)، وابن حبان ٣/٣١١ (١٠٣٧)، والحاكم ١/٢٢٠-٢٢١ (٤٤٧-٤٤٩)، وعبد الرزاق ٣/١٥٤ (٢٧٠٨). قال الحاكم: «هذا حديث صحيح، على شرط الشيخين، ولم يخرجاه، ولست أعرف له علة يعلّل بمثلها مثل هذا الحديث، إلا وهم من أبي بلال الأشعري وهم فيه على أبي معاوية». وقال البغوي في شرح السنة ١/٣٢٧ (١٥٥): «هذا منقطع، ويُروى متصلًا عن حسان بن عطية، عن أبي كبشة السلولي، عن ثوبان، وثوبان أبو عبد الله مولى رسول الله ﷺ، وأبو كبشة السلولي لا يُعرف له اسم». وقال المنذري في الترغيب والترهيب ١/٩٧ (٣١١): «بإسناد صحيح». وقال البوصيري في مصباح الزجاجة ١/٤١ (١١٢): «رجاله ثقات أثبات، إلا أنه منقطع بين سالم وثوبان؛ فإنه لم يسمع منه بلا خلاف، لكن له طريق أخرى متصلة». وقال الألباني في الإرواء ٢/١٣٥ (٤١٢): «صحيح».أخرجه مسلم ١/٦٥ (٣٨)، والثعلبي ٨/٢٩٤.أخرجه ابن جرير ٢٠/٤٢٧. وعزاه السيوطي إلى ابن أبي حاتم، وابن المنذر.تفسير مجاهد ص٥٨٦، وأخرجه الفريابي -كما في تغليق التعليق ٤/٣٠٢-، وابن جرير ٢٠/٤٢٦. وعلقه البخاري في صحيحه ٤/١٨١٧، والبيهقي في شعب الإيمان ١/٣٥٤. وعزاه السيوطي إلى عبد بن حميد.أخرجه يحيى بن سلام -كما في تفسير ابن أبي زمنين ٤/١٥٢-.تفسير الثعلبي ٨/٢٩٤.أخرجه ابن أبي حاتم -كما في تفسير ابن كثير ٧/١٧٧-. وعزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ٢٠/٤٢٦.عزاه السيوطي إلى ابن أبي حاتم.تفسير مقاتل بن سليمان ٣/٧٤٢.أخرجه ابن المبارك في الزهد (٣٢٨)، والبيهقي في إثبات عذاب القبر وسؤال الملكين ص٨١.تفسير الثعلبي ٨/٢٩٤.أخرجه ابن جرير ٢٠/٤٢٧. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.عزاه السيوطي إلى عَبد بن حُمَيد.تفسير الثعلبي ٨/٢٩٤، وتفسير البغوي ٧/١٧٣.أخرجه ابن جرير ٢٠/٤٢٦-٤٢٨.أخرجه ابن أبي شيبة في مصنفه (ت: محمد عوامة) ١٩/٣٨٢ (٣٦٤٠٤).أخرجه ابن المبارك في الزهد (٣٢٨)، والبيهقي في إثبات عذاب القبر وسؤال الملكين ص٨١.أخرجه ابن جرير ٢٠/٤٢٦-٤٢٨.تفسير مقاتل بن سليمان ٣/٧٤٢.تفسير الثعلبي ٨/٢٩٤، وتفسير البغوي ٧/١٧٣.أخرجه أحمد ١٩/١٠٣-١٠٤ (١٢٠٤٧). قال المنذري في الترغيب والترهيب ٤/١٧١ (٥٢٩٨): «رواه أحمد، ورواته رواة الصحيح والنسائي بإسناد جيد». وقال ابن كثير في تفسيره ٧/١٧٩: «حديث صحيح، وقد ورد في الصحيح من غير هذا الوجه». وقال الهيثمي في المجمع ٢/٣٢٠ (٣٨٩٩): «رجال أحمد رجال الصحيح». وقال البوصيري في إتحاف الخيرة ٢/٤٢٩ (١٨٣٢): «بسند صحيح ... وهو في الصحيحين وغيرهما من حديث أنس، عن عبادة بن الصامت».أخرجه ابن أبي شيبة ١٤/٥٦. وعزاه السيوطي إلى ابن أبي الدنيا في ذكر الموت.عزاه السيوطي إلى أبي نعيم في الحلية.عزاه السيوطي إلى ابن أبي شيبة، وعبد بن حميد، وابن المنذر، وابن أبي حاتم.
41,31," <q>﴿نَحۡنُ أَوۡلِیَاۤؤُكُمۡ فِی ٱلۡحَیَوٰةِ ٱلدُّنۡیَا وَفِی ٱلۡـَٔاخِرَةِۖ وَلَكُمۡ فِیهَا مَا تَشۡتَهِیۤ أَنفُسُكُمۡ وَلَكُمۡ فِیهَا مَا تَدَّعُونَ ۝٣١﴾</q> - تفسير ٦٨٥٦٧- عن مجاهد بن جبر-من طريق منصور- <q>﴿نَحْنُ أوْلِياؤُكُمْ﴾</q>، قال: رفقاؤكم في الدنيا، لا نُفارقكم حتى ندخل معكم الجنة. وفي لفظ: قرناؤهم الذين معهم في الدنيا، فإذا كان يوم القيامة قالوا: لن نفارقكم حتى نُدخلكم الجنة{1}. (١٣/١٠٨) ٦٨٥٦٨- عن إسماعيل السُّدّيّ -من طريق أسباط- <q>﴿نَحْنُ أوْلِياؤُكُمْ فِي الحَياةِ الدُّنْيا﴾</q>: نحن الحفظة الذين كنا معكم في الدنيا، ونحن أولياؤكم في الآخرة{2}. (ز) ٦٨٥٦٩- قال مقاتل بن سليمان: وتقول الحفظة يومئذ للمؤمنين: <q>﴿نَحْنُ أوْلِياؤُكُمْ فِي الحَياةِ الدُّنْيا﴾</q> ونحن أولياؤكم اليوم، <q>﴿وفِي الآخِرَةِ ولَكُمْ فِيها﴾</q> يعني: في الجنة <q>﴿ما تَشْتَهِي أنْفُسُكُمْ ولَكُمْ فِيها ما تَدَّعُونَ﴾</q> يعني: ما تَتَمَّنَوْن، هذا الذي أعطاكم الله كان <q>﴿نُزُلًا مِن غَفُورٍ رَحِيمٍ﴾</q>{3}. (ز) ",footnotes:1:أخرجه ابن المبارك (٣٢٩). وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم، كذلك عزا اللفظ الثاني إلى عبد بن حميد.أخرجه ابن جرير ٢٠/٤٢٨.تفسير مقاتل بن سليمان ٣/٧٤٢.
41,32," <q>﴿نُزُلࣰا مِّنۡ غَفُورࣲ رَّحِیمࣲ ۝٣٢﴾</q> - تفسير ٦٨٥٧٠- عن جابر بن عبد الله، قال: قال رسولُ الله ﷺ: «بَينا أهل الجنة في مجلس لهم إذ سطع لهم نورٌ على باب الجنة، فرفعوا رؤوسهم، فإذا الربُّ تعالى قد أشرف، فقال: يا أهل الجنة، سَلوني. فقالوا: نسألك الرِّضا عنّا. قال: رِضاي أحلّكم داري، وأنالكم كرامتي، هذ أوانُها، فاسألوني. قالوا: نسألك الزيادة. قال: فيُؤتون بنجائِبَ{1} من ياقوت أحمر، أزِّمَّتها زَبَرْجد أخضر وياقوت أحمر، فجاءوا عليها تضع حوافرها عند منتهى طرفها، فأمر الله بأشجار عليها الثمار، فتجيء حوارٍ مِن الحُور العِين وهُنَّ يقُلن: نحن الناعمات فلا نبأس، ونحن الخالدات فلا نموت، أزواج قوم مؤمنين كرام. ويأمر الله بكُثْبان مِن مسكٍ أبيض أذْفَر{2}، فتثير عليهم ريحًا يقال لها: المُثِيرة. حتى تنتهي بهم إلى جنة عدن، وهي قصبة الجنة، فتقول الملائكة: يا ربنا، قد جاء القوم. فيقول: مرحبًا بالصادقين، مرحبًا بالطائعين. فيكشف لهم الحجاب، فينظرون إلى الله، فيتمتعون بنور الرحمن حتى لا يُبصِر بعضُهم بعضًا، ثم يقول: ارجِعوهم إلى القصور بالتُّحَف. فيرجعون وقد أبصر بعضُهم بعضًا». قال رسول الله ﷺ: «فذلك قوله تعالى: <q>﴿نُزُلًا مِن غَفُورٍ رَحِيمٍ﴾</q>»{3}. (١٣/١٠٩) ٦٨٥٧١- عن أبي هريرة، مثله سواء{4}. (١٣/١١٠) ",footnotes:1:نجائب: هي الإبل القوية الخفيفة السريعة. النهاية (نجب).أي: طيب الرِّيح. النهاية (ذفر).أخرجه البيهقي في البعث والنشور ص٢٦٢-٢٦٣ (٤٤٨)، والقشيري في الرسالة القشيرية ٢/٣٤١. قال السيوطي في اللآلىء المصنوعة في الأحاديث الموضوعة ٢/٣٨٣-٣٨٤: «موضوع».أخرجه ابن النجار في تاريخه -كما في اللآلىء المصنوعة للسيوطي ٢/٣٨٣-. وفيه سليمان بن أبي كريمة. قال السيوطي في اللآلىء المصنوعة: «سليمان بن أبي كريمة، قال ابن عدي: عامة أحاديثه مناكير، ولم أر للمتقدمين فيه كلامًا».
41,33," <q>﴿وَمَنۡ أَحۡسَنُ قَوۡلࣰا مِّمَّن دَعَاۤ إِلَى ٱللَّهِ وَعَمِلَ صَـٰلِحࣰا وَقَالَ إِنَّنِی مِنَ ٱلۡمُسۡلِمِینَ ۝٣٣﴾</q> - نزول الآية، وتفسيرها ٦٨٥٧٢- عن عائشة -من طريق عبيد الله بن عبيد- قالت: ما أرى هذه الآيةَ نزلت إلا في المؤذِّنين: <q>﴿ومَن أحْسَنُ قَوْلًا مِمَّنْ دَعا إلى اللَّهِ﴾</q> الآية{1}. (١٣/١١٠) ٦٨٥٧٣- عن عائشة: <q>﴿ومَن أحْسَنُ قَوْلًا مِمَّنْ دَعا إلى اللَّهِ﴾</q> قالت: المؤذّن، <q>﴿وعَمِلَ صالِحًا﴾</q> قالت: ركعتان فيما بين الأذان والإقامة{2}. (١٣/١١٠) ٦٨٥٧٤- قال عبد الله بن عباس: <q>﴿ومَن أحْسَنُ قَوْلًا مِمَّنْ دَعا إلى اللَّهِ وعَمِلَ صالِحًا وقالَ إنَّنِي مِنَ المُسْلِمِينَ﴾</q> هو رسول الله ﷺ؛ دعا إلى شهادة أن لا إله إلا الله{3}. (ز) ٦٨٥٧٥- قال أبو أُمامة الباهلي: <q>﴿وعَمِلَ صالِحًا﴾</q> صلّى ركعتين بين الأذان والإقامة{4}. (ز) ٦٨٥٧٦- عن قيس بن أبي حازم -من طريق إسماعيل بن أبي خالد- في قوله: <q>﴿ومَن أحْسَنُ قَوْلًا مِمَّنْ دَعا إلى اللَّهِ﴾</q> قال: الأذان، <q>﴿وعَمِلَ صالِحًا﴾</q> قال: الصلاة بين الأذان والإقامة{5}. (١٣/١١١) ٦٨٥٧٧- عن عكرمة مولى ابن عباس، <q>﴿ومَن أحْسَنُ قَوْلًا مِمَّنْ دَعا إلى اللَّهِ﴾</q>، قال: قول: لا إله إلا الله. يعني: المؤذّن، <q>﴿وعَمِلَ صالِحًا﴾</q> صام وصلّى{6}٥٧٥٧. (١٣/١١١) ٥٧٥٧ وجّه ابنُ عطية (٧/٤٨٣) هذا القول الذي قالته عائشة، وأبو أمامة، وعكرمة، وابن أبي حازم، بقوله: «ومعنى القول بأنها في المؤذّنين: أنهم داخلون فيها. وأما نزولها فمكية بلا خلاف، ولم يكن بمكة أذان، وإنما ترتب بالمدينة، وإنّ الأذان لَمِن الدعاء إلى الله تعالى، ولكنه جزء منه. والدعاء إلى الله بقوة، كجهاد الكفار وردع الطغاة وكفّ الظلمة وغيره أعظم عناء من تولي الأذان؛ إذ لا مشقة فيه». وانتقد ابنُ كثير (١٢/٢٤٢) هذا القول مستندًا لأحوال النُّزول، فقال: «فأما حال نزول هذه الآية فإنه لم يكن الأذان مشروعًا بالكلية؛ لأنها مكية، والأذان إنما شرُع بالمدينة بعد الهجرة، حين أريه عبد الله بن زيد بن عبد ربه الأنصاري في منامه، فقصّه على رسول الله ﷺ، فأمره أن يلقيه على بلال فإنه أندى صوتًا». ٦٨٥٧٨- عن الحسن البصري، في قوله: <q>﴿ومَن أحْسَنُ قَوْلًا مِمَّنْ دَعا إلى اللَّهِ﴾</q>، قال: هو النبيُّ ﷺ{7}. (١٣/١١٠) ٦٨٥٧٩- عن الحسن البصري، <q>﴿ومَن أحْسَنُ قَوْلًا مِمَّنْ دَعا إلى اللَّهِ﴾</q>، قال: هو المؤمن عمل صالحًا، ودعا إلى الله تعالى{8}٥٧٥٨. (١٣/١١٠) ٥٧٥٨ ذهب الحسنُ وقتادةُ إلى العموم في الآية، وهو ما ذكره ابنُ عطية (٧/٤٨٣)، ثم علَّق بقوله: «وبيّن أن حالة النبي ﷺ كانت كذلك مبرزة». ٦٨٥٨٠- عن الحسن البصري -من طريق معمر- <q>﴿ومَن أحْسَنُ قَوْلًا مِمَّنْ دَعا إلى اللَّهِ وعَمِلَ صالِحًا﴾</q> فقال: هذا حبيب الله، هذا ولِيُّ الله، هذا صفوة الله، هذا خِيرة الله، هذا أحبّ أهل الأرض إلى الله، أجاب اللهَ في دعوته، ودعا الناسَ إلى ما أجاب الله فيه من دعوته، وعمل صالحًا في إجابته، <q>﴿وقالَ إنَّنِي مِنَ المُسْلِمِينَ﴾</q> هذا خليفة الله{9}. (ز) ٦٨٥٨١- عن محمد بن سيرين، في قوله: <q>﴿ومَن أحْسَنُ قَوْلًا مِمَّنْ دَعا إلى اللَّهِ﴾</q>، قال: ذلك النبي ﷺ{8}. (١٣/١١٠) ٦٨٥٨٢- عن قتادة بن دعامة -من طريق سعيد- <q>﴿ومَن أحْسَنُ قَوْلًا مِمَّنْ دَعا إلى اللَّهِ وعَمِلَ صالِحًا وقالَ إنَّنِي مِنَ المُسْلِمِينَ﴾</q>، قال: هذا عبد صدَّق قولَه عملُه، ومولِجَه ومخرَجُه، وسِرَّه وعلانيتُه، ومشهدَه مغيبُه، وإنّ المنافق عبدٌ خالف قولَه عملُه، ومولجَه مخرجُه، وسرَّه علانيتُه، وشاهدَه مغيبُه{11}. (١٣/١١١) ٦٨٥٨٣- عن إسماعيل السُّدّيّ -من طريق أسباط- <q>﴿ومَن أحْسَنُ قَوْلًا مِمَّنْ دَعا إلى اللَّهِ﴾</q>، قال: محمد ﷺ حين دعا إلى الإسلام{12}. (ز) ٦٨٥٨٤- قال مقاتل بن سليمان: قوله: <q>﴿ومَن أحْسَنُ قَوْلًا مِمَّنْ دَعا إلى اللَّهِ﴾</q> يعني: التوحيد، <q>﴿وعَمِلَ صالِحًا وقالَ إنَّنِي مِنَ المُسْلِمِينَ﴾</q> يعني: المخلصين، يعني: النبي ﷺ{13}. (ز) ٦٨٥٨٥- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿ومَن أحْسَنُ قَوْلًا مِمَّنْ دَعا إلى اللَّهِ وعَمِلَ صالِحًا وقالَ إنَّنِي مِنَ المُسْلِمِينَ﴾</q>، قال: هذا رسول الله ﷺ{12}٥٧٥٩. (ز) ٥٧٥٩ ذكر ابنُ كثير (١٢/٢٤٠) أنّ الآية عامَّةٌ في كل مَن دعا إلى خير وهو في نفسه مهتدٍ، ثم قال: «ورسول الله ﷺ أولى الناس بذلك، كما قال محمد بن سيرين، والسُّدّيّ، وعبد الرحمن بن زيد بن أسلم». ٦٨٥٨٦- عن سفيان بن عُيينة -من طريق ابن أبي عمر- في قوله -جلّ ذِكْرُه-: <q>﴿ومن أحسن قولا ممن دعا إلى الله وعمل صالحا﴾</q> الآية، قال: نزلت في المؤذّنين، إلى قوله: <q>﴿من المسلمين﴾</q> قال: منهم المؤذِّنون{15}. (ز) ٦٨٥٨٧- عن عاصم بن هُبَيرة، قال: إذا فرغت مِن أذانِك فقُل: لا إله إلا الله، والله أكبر، وأنا من المسلمين. ثم قرأ: <q>﴿ومَن أحْسَنُ قَوْلًا مِمَّنْ دَعا إلى اللَّهِ وعَمِلَ صالِحًا وقالَ إنَّنِي مِنَ المُسْلِمِينَ﴾</q>{16}٥٧٦٠. (١٣/١١١) ٥٧٦٠ اختُلف في المراد بالآية على أقوال: الأول: أنها عامة. الثاني: النبي ﷺ. الثالث: المؤذّنين. ورجَّح ابنُ عطية (٧/٤٨٣) القول بالعموم الذي قاله قتادة، والحسن، فقال: «والأصوب أن يُعتقد أن الآية نزلت عامة». ولم يذكر مستندًا. وبنحوه ابنُ كثير (١٢/٢٤٢) مستندًا إلى أحوال النُّزول، فقال: «والصحيح أن الآية عامة في المؤذّنين وفي غيرهم، فأما حال نزول هذه الآية فإنه لم يكن الأذان مشروعًا بالكلية؛ لأنها مكية، والأذان إنما شُرع بالمدينة بعد الهجرة، حين أريه عبد الله بن زيد بن عبد ربه الأنصاري في منامه، فقصّه على رسول الله ﷺ، فأمره أن يلقيه على بلال فإنه أندى صوتًا، كما هو مقرّر في موضعه، فالصحيح إذًا أنها عامة». ",footnotes:1:أخرجه ابن أبي شيبة في المصنف ١/٢٢٥. وعزاه السيوطي إلى ابن المنذر، وابن مردويه.عزاه السيوطي إلى عَبد بن حُمَيد، وابن أبي حاتم، وابن مردويه.تفسير البغوي ٧/١٧٣.تفسير الثعلبي ٨/٢٩٦، وتفسير البغوي ٧/١٧٣.أخرجه الخطيب في تاريخه ٨/٤٧١-٤٧٢، وابن جرير ٢٠/٤٣٠.عزاه السيوطي إلى عَبد بن حُمَيد.عزاه السيوطي إلى عَبد بن حُمَيد، وابن أبي حاتم.عزاه السيوطي إلى عَبد بن حُمَيد، وابن المنذر.أخرجه عبد الرزاق ٢/١٨٧، وابن جرير ٢٠/٤٢٩.عزاه السيوطي إلى عَبد بن حُمَيد، وابن المنذر.أخرجه ابن جرير ٢٠/٤٢٩. وعزاه السيوطي إلى عَبد بن حُمَيد دون آخره.أخرجه ابن جرير ٢٠/٤٣٠.تفسير مقاتل بن سليمان ٣/٧٤٢.أخرجه ابن جرير ٢٠/٤٣٠.أخرجه إسحاق البستي ص٢٩٤. وقد أورد السيوطي عقب تفسير الآية ١٣/١١١-١١٣ آثارًا كثيرة عن فضل الأذان والمؤذنين.أخرجه سعيد بن منصور في سننه -التفسير ٧/٢٤١ (١٨٩٣)، والثعلبي ٨/٢٩٧.
41,34," <q>﴿وَلَا تَسۡتَوِی ٱلۡحَسَنَةُ وَلَا ٱلسَّیِّئَةُۚ ٱدۡفَعۡ بِٱلَّتِی هِیَ أَحۡسَنُ﴾</q> - نزول الآية ٦٨٥٨٨- قال مقاتل بن سليمان: <q>﴿ولا تَسْتَوِي الحسنة ولا السَّيِّئَةُ ادْفَعْ بِالَّتِي هِيَ أحْسَنُ﴾</q>، وذلك أنّ أبا جهل كان يُؤذي النبيَّ ﷺ، وكان النبيُّ مُبغِضًا له يكره رؤيته، فأُمر بالعفو والصفح{1}. (ز) <q>﴿وَلَا تَسۡتَوِی ٱلۡحَسَنَةُ وَلَا ٱلسَّیِّئَةُۚ ٱدۡفَعۡ بِٱلَّتِی هِیَ أَحۡسَنُ﴾</q> - تفسير الآية ٦٨٥٨٩- عن عبد الله بن عباس -من طريق علي- في قوله: <q>﴿ولا تَسْتَوِي الحسنةُ ولا السَّيِّئَةُ ادْفَعْ بِالَّتِي هِيَ أحْسَنُ﴾</q>، قال: أمر اللهُ المؤمنين بالصّبر عند الغضب، والحِلم عند الجهل، والعفو عند الإساءة، فإذا فعلوا ذلك عصمهم اللهُ مِن الشيطان، وخضع لهم عدوُّهم كأنه ولِيٌّ حميم{2}. (١٣/١١٣) ٦٨٥٩٠- عن عبد الله بن عباس، في قوله: <q>﴿ولا تَسْتَوِي الحسنةُ ولا السَّيِّئَةُ ادْفَعْ بِالَّتِي هِيَ أحْسَنُ﴾</q> قال: القَه بالسلام <q>﴿فَإذا الَّذِي بَيْنَكَ وبَيْنَهُ عَداوَةٌ كَأَنَّهُ ولِيٌّ حَمِيمٌ﴾</q>{3}. (١٣/١١٤) ٦٨٥٩١- عن مجاهد بن جبر -من طريق عبد الكريم الجزري- في قوله: <q>﴿ادْفَعْ بِالَّتِي هِيَ أحْسَنُ﴾</q>، قال: السلام، أن تُسلِّم عليه إذا لقيتَه{4}. (١٣/١١٤) ٦٨٥٩٢- عن عطاء [بن أبي رباح] -من طريق طلحة بن عمرو- <q>﴿ادْفَعْ بِالَّتِي هِيَ أحْسَنُ﴾</q>، قال: بالسلام{5}٥٧٦١. (١٣/١١٤) ٥٧٦١ وجَّه ابنُ عطية (٧/٤٨٤) قول مجاهد، وعطاء، بقوله: «لا شكَّ أنّ السلام هو مبدأ الدفع بالتي هي أحسن، وهو جزء منه». <q>﴿فَإِذَا ٱلَّذِی بَیۡنَكَ وَبَیۡنَهُۥ عَدَ ٰ⁠وَةࣱ كَأَنَّهُۥ وَلِیٌّ حَمِیمࣱ ۝٣٤﴾</q> - نزول الآية ٦٨٥٩٣- قال مقاتل بن حيّان: <q>﴿كَأَنَّهُ ولِيٌّ حَمِيمٌ﴾</q> نزلت في أبي سفيان بن حرب، وذلك أنه لان للمسلمين بعد شِدَّة عداوته بالمصاهرة التي حصلت بينه وبين النبي ﷺ، ثم أسلم فصار وليًّا بالإسلام، حميمًا بالقرابة{6}. (ز) <q>﴿فَإِذَا ٱلَّذِی بَیۡنَكَ وَبَیۡنَهُۥ عَدَ ٰ⁠وَةࣱ كَأَنَّهُۥ وَلِیٌّ حَمِیمࣱ ۝٣٤﴾</q> - تفسير الآية ٦٨٥٩٤- عن عكرمة مولى ابن عباس، قال: الحميم: ذو القرابة. والوَلِيُّ: الصَّديق{7}. (١٣/١١٥) ٦٨٥٩٥- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿كَأَنَّهُ ولِيٌّ حَمِيمٌ﴾</q>، قال: وليّ رقيب{8}. (١٣/١١٤) ٦٨٥٩٦- قال مقاتل بن سليمان: يقول: إذا فعلتَ ذلك <q>﴿فَإذا الَّذِي بَيْنَكَ وبَيْنَهُ عَداوَة﴾</q> يعني: أبا جهل <q>﴿كَأَنَّهُ ولِيٌّ﴾</q> لك في الدين، <q>﴿حَمِيمٌ﴾</q> لك في النسب، الشفيق عليك{1}. (ز) ",footnotes:1:تفسير مقاتل بن سليمان ٣/٧٤٣.أخرجه ابن جرير ٢٠/٤٣٢ بنحوه، وابن أبي حاتم -كما في التغليق ٤/٣٠٣-، والبيهقي في سننه ٧/٤٥. وعزاه السيوطي إلى ابن المنذر.عزاه السيوطي إلى ابن مردويه.أخرجه عبد الرزاق ٢/١٨٧، وابن جرير ٢٠/٤٣٣، والبيهقي في شعب الإيمان (٦٦٢٣). وعزاه السيوطي إلى سعيد بن منصور، وعبد بن حميد، وابن المنذر، وابن أبي حاتم.أخرجه ابن جرير ٢٠/٤٣٣. وعزاه السيوطي إلى عبد بن حميد.تفسير البغوي ٧/١٧٥.عزاه السيوطي إلى عبد بن حميد.أخرجه عبد الرزاق ٢/١٨٧-١٨٨ من طريق معمر، وابن جرير ٢٠/٤٣٣. وعزاه السيوطي إلى عبد بن حميد.تفسير مقاتل بن سليمان ٣/٧٤٣.
41,35," <q>﴿وَمَا یُلَقَّىٰهَاۤ إِلَّا ٱلَّذِینَ صَبَرُوا۟ وَمَا یُلَقَّىٰهَاۤ إِلَّا ذُو حَظٍّ عَظِیمࣲ ۝٣٥﴾</q> - تفسير ٦٨٥٩٧- عن عبد الله بن عباس -من طريق علي- قوله: <q>﴿وما يُلَقّاها إلّا الَّذِينَ صَبَرُوا وما يُلَقّاها إلّا ذُو حَظٍّ عَظِيمٍ﴾</q>، يقول: الذين أعدَّ الله لهم الجنة{1}. (ز) ٦٨٥٩٨- عن أنس بن مالك، في قوله: <q>﴿وما يُلَقّاها إلّا الَّذِينَ صَبَرُوا وما يُلَقّاها إلّا ذُو حَظٍّ عَظِيمٍ﴾</q>، قال: الرجل يشتمه أخوه، فيقول: إن كنتَ صادقًا يغفر الله لي، وإن كنتَ كاذبًا يغفر الله لك{2}. (١٣/١١٥) ٦٨٥٩٩- عن الحسن البصري، <q>﴿وما يُلَقّاها إلّا الَّذِينَ صَبَرُوا﴾</q>، قال: واللهِ، لا يصيبها صاحبُها حتى يكظِم غيظًا، ويصفح عن بعض ما يكره{3}. (١٣/١١٥) ٦٨٦٠٠- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿وما يُلَقّاها إلّا الَّذِينَ صَبَرُوا﴾</q> الآية، قال: الحظّ العظيم: الجنة{4}٥٧٦٢. (١٣/١١٤) ٥٧٦٢ ذكر ابنُ عطية (٧/٤٨٤) أن الحظ العظيم: يحتمل احتمالين: أحدهما: أن يريد من العقل والفضل؛ فتكون الآية مدحًا. والآخر: أن يريد: ذُو حَظٍّ عَظِيمٍ من الجنة وثواب الآخرة؛ فتكون الآية وعْدًا. ٦٨٦٠١- عن إسماعيل السُّدّيّ -من طريق أسباط- في قوله: <q>﴿وما يُلَقّاها إلّا ذُوحَظٍّ عَظِيمٍ﴾</q>: ذو جَدّ{5}. (ز) ٦٨٦٠٢- قال مقاتل بن سليمان: ثم أخبر نبيَّه ﵇: <q>﴿وما يُلَقّاها﴾</q> يعني: لا يؤتاها، يعني: الأعمال الصالحة؛ العفو والصفح <q>﴿إلّا الَّذِينَ صَبَرُوا﴾</q> على كظْم الغيظ، <q>﴿وما يُلَقّاها﴾</q> يعني: لا يؤتاها <q>﴿إلّا ذُو حَظٍّ عَظِيمٍ﴾</q> نصيبًا وافرًا في الجنة، فأمره الله بالصبر والاستعاذة من الشيطان في أمر أبي جهل{6}٥٧٦٣. (ز) ٥٧٦٣ ذكر ابنُ عطية (٧/٤٨٤) أن فرقة قالت: المراد: وما يُلَقّى لا إله إلا الله. وانتقده مستندًا لظاهر لفظ الآية، فقال: «وهذا تفسير لا يقتضيه اللفظ». ",footnotes:1:أخرجه ابن جرير ٢٠/٤٣٥.عزاه السيوطي إلى ابن المنذر.عزاه السيوطي إلى عبد بن حميد.أخرجه عبد الرزاق ٢/١٨٧-١٨٨من طريق معمر، وابن جرير ٢٠/٤٣٤. وعزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ٢٠/٤٣٤. وعزاه السيوطي إلى ابن أبي حاتم عند تفسير قوله تعالى: <q>﴿إنَّهُ لَذُو حَظٍّ عَظِيمٍ﴾</q> [القصص:٧٩].تفسير مقاتل بن سليمان ٣/٧٤٣.
41,36," <q>﴿وَإِمَّا یَنزَغَنَّكَ مِنَ ٱلشَّیۡطَـٰنِ نَزۡغࣱ فَٱسۡتَعِذۡ بِٱللَّهِۖ إِنَّهُۥ هُوَ ٱلسَّمِیعُ ٱلۡعَلِیمُ ۝٣٦﴾</q> - تفسير ٦٨٦٠٣- عن سليمان بن صُرَد، قال: اسْتَبَّ رجلان عند النبيِّ ﷺ، فاشتد غضبُ أحدهما، فقال النبيُّ ﷺ: «إنِّي لَأعلمُ كلمةً لو قالها لذهب عنه الغضب: أعوذ بالله من الشيطان الرجيم». فقال الرجل: أمجنون تراني؟! فتلا رسول الله ﷺ: <q>﴿وإمّا يَنْزَغَنَّكَ مِنَ الشَّيْطانِ نَزْغٌ فاسْتَعِذْ بِاللَّهِ﴾</q>{1}. (١٣/١١٥) ٦٨٦٠٤- قال قتادة بن دعامة: <q>﴿وإما ينزغنك من الشيطان نزغ﴾</q>، النَّزْغ: الغضب{2}. (ز) ٦٨٦٠٥- عن قتادة بن دعامة، في قوله: <q>﴿وإمّا يَنْزَغَنَّكَ مِنَ الشَّيْطانِ نَزْغٌ فاسْتَعِذْ بِاللَّهِ﴾</q>، قال: ذُكِر لنا: أنّ نبيَّ الله ﷺ بينما هو يصلي إذ جعل يَسْنُد حتى يستلم السارية، ثم يقول: «ألعنك بلعنة الله التامة». فقال له بعض أصحابه: يا نبيَّ الله، ما شيءٌ رأيناك تصنعه؟ قال: «أتاني الشيطانُ بشِهاب مِن نار لِيحرقني به، فلعنتُه بلعنة الله التامة، فانكبّ لِفِيه، وطَفئتْ ناره»{3}. (١٣/١١٦) ٦٨٦٠٦- عن إسماعيل السُّدّيّ -من طريق أسباط- <q>﴿وإمّا يَنْزَغَنَّكَ مِنَ الشَّيْطانِ نَزْغٌ﴾</q> قال: وسوسة وحديث النفس، <q>﴿فاسْتَعِذْ بِاللَّهِ﴾</q> من الشيطان الرّجيم{4}. (ز) ٦٨٦٠٧- قال مقاتل بن سليمان: <q>﴿وإمّا يَنْزَغَنَّكَ﴾</q> يعني: يفتننّك في أمر أبي جهل والرّد عنه <q>﴿مِنَ الشَّيْطانِ نَزْغٌ﴾</q> يعني: فتنة؛ <q>﴿فاسْتَعِذْ بِاللَّهِ إنَّهُ هُوالسَّمِيعُ﴾</q> بالاستعاذة، <q>﴿العَلِيمُ﴾</q> بها. نظيرها في «حم المؤمن»: <q>﴿إنْ فِي صُدُورِهِمْ إلّا كِبْرٌ ما هُمْ بِبالِغِيهِ فاسْتَعِذْ بِاللَّهِ إنَّهُ هُوالسَّمِيعُ البَصِيرُ﴾</q> [غافر:٥٦]، وفي الأعراف{5}، أمر أبي جهل{6}. (ز) ٦٨٦٠٨- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿وإمّا يَنْزَغَنَّكَ مِنَ الشَّيْطانِ نَزْغٌ﴾</q>، قال: هذا الغضب{4}. (ز) <q>﴿وَإِمَّا یَنزَغَنَّكَ مِنَ ٱلشَّیۡطَـٰنِ نَزۡغࣱ فَٱسۡتَعِذۡ بِٱللَّهِۖ إِنَّهُۥ هُوَ ٱلسَّمِیعُ ٱلۡعَلِیمُ ۝٣٦﴾</q> - آثار متعلقة بالآية ٦٨٦٠٩- عن خَيْثمة [بن عبد الرحمن] -من طريق الأعمش- قال: إنّ الشيطان يقول: كيف يغلبني ابنُ آدم؟! إذا رضي جئتُ حتى أكون في قلبه، وإذا غضب طِرتُ حتى أكون في رأسه{8}. (١٣/١١٦) ",footnotes:1:أخرجه البخاري ٤/١٢٤ (٣٢٨٢)، ٨/١٥-١٦ (٦٠٤٨)، ٨/٢٨ (٦١١٥)، ومسلم ٤/٢٠١٥ (٢٦١٠)، كلاهما دون ذكر الآية، والحاكم ٢/٤٧٨ (٣٦٤٩) واللفظ له. قال الحاكم: «هذا حديث صحيح الإسناد».ذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٤/١٥٤-.عزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه ابن جرير ٢٠/٤٣٥.يشير إلى الآية [٢٠٠] وهي قوله تعالى: <q>﴿وإمّا يَنْزَغَنَّكَ مِنَ الشَّيْطانِ نَزْغٌ فاسْتَعِذْ بِاللَّهِ إنَّهُ سَمِيعٌ عَلِيمٌ﴾</q>.تفسير مقاتل بن سليمان ٣/٧٤٣.أخرجه ابن جرير ٢٠/٤٣٥.أخرجه ابن أبي شيبة ١٣/٤٤٦.
41,37," <q>﴿وَمِنۡ ءَایَـٰتِهِ ٱلَّیۡلُ وَٱلنَّهَارُ وَٱلشَّمۡسُ وَٱلۡقَمَرُۚ لَا تَسۡجُدُوا۟ لِلشَّمۡسِ وَلَا لِلۡقَمَرِ وَٱسۡجُدُوا۟ لِلَّهِ ٱلَّذِی خَلَقَهُنَّ إِن كُنتُمۡ إِیَّاهُ تَعۡبُدُونَ ۝٣٧﴾</q> - تفسير ٦٨٦١٠- قال مقاتل بن سليمان: <q>﴿ومِن آياتِهِ﴾</q> أن يُعرف التوحيد بصُنعه وإن لم تروه <q>﴿اللَّيْلُ والنَّهارُ والشَّمْسُ والقَمَرُ لا تَسْجُدُوا لِلشَّمْسِ ولا لِلْقَمَرِ واسْجُدُوا لِلَّهِ الَّذِي خَلَقَهُنَ﴾</q> يعني: الذي خلق هؤلاء الآيات؛ <q>﴿إنْ كُنْتُمْ إيّاهُ تَعْبُدُونَ﴾</q>. فسجد النبيُّ ﷺ والمؤمنون يومئذ، فقال كفار مكة عند ذلك: بل نسجد للّات والعُزّى ومَناة{1}. (ز) ",footnotes:1:تفسير مقاتل بن سليمان ٣/٧٤٣.
41,38," <q>﴿فَإِنِ ٱسۡتَكۡبَرُوا۟ فَٱلَّذِینَ عِندَ رَبِّكَ یُسَبِّحُونَ لَهُۥ بِٱلَّیۡلِ وَٱلنَّهَارِ وَهُمۡ لَا یَسۡـَٔمُونَ﴾</q> - تفسير ٦٨٦١١- عن عبد الله بن عباس -من طريق عطية- قوله: <q>﴿فَإنِ اسْتَكْبَرُوا فالَّذِينَ عِنْدَ رَبِّكَ يُسَبِّحُونَ لَهُ بِاللَّيْلِ والنَّهارِ﴾</q>، قال: يعني: محمدًا، يقول: عبادي ملائكة صافّون، يسبّحون ولا يستكبرون{1}. (ز) ٦٨٦١٢- عن عبد الله بن عباس، أن نافع بن الأزرق سأله عن قوله: <q>﴿لا يَسْأَمُونَ﴾</q>. قال: لا يفتُرون ولا يمَلّون. قال: وهل تعرف العرب ذلك؟ قال: نعم، أما سمعت قول الشاعر: من الخوف لا ذو سأمةٍ من عبادةٍ ولا هو من طول التعبد يُجهَد{2}. (١٣/١١٧) ٦٨٦١٣- قال مقاتل بن سليمان: يقول الله تعالى: <q>﴿فَإنِ اسْتَكْبَرُوا﴾</q> عن السجود لله <q>﴿فالَّذِينَ عِنْدَ رَبِّكَ﴾</q> مِن الملائكة <q>﴿يُسَبِّحُونَ لَهُ بِاللَّيْلِ والنَّهارِ وهُمْ لا يَسْأَمُونَ﴾</q> يعني: لا يَمَلُّون مِن الذِّكر له والعبادة، وليست لهم فترة ولا سآمة{3}. (ز) <q>﴿فَإِنِ ٱسۡتَكۡبَرُوا۟ فَٱلَّذِینَ عِندَ رَبِّكَ یُسَبِّحُونَ لَهُۥ بِٱلَّیۡلِ وَٱلنَّهَارِ وَهُمۡ لَا یَسۡـَٔمُونَ﴾</q> - آثار متعلقة بالآية ٦٨٦١٤- عن ليث، عن الحكم، عن رجل من بني سليم: أنّه سمع رسول الله ﷺ يسجد في «حم» بالآية الأولى{4}. (ز) ٦٨٦١٥- عن علي بن أبي طالب -من طريق الحارث- قال: عزائم السجود أربع: «آلم تنزيل السجدة»، و«حم السجدة»، والنّجم، و«اقرأ باسم ربك»{5}. (ز) ٦٨٦١٦- عن أبي اسحاق، قال: سمعتُ عبد الرحمن بن يزيد وعبد الرحمن بن الأسود يقولان: كان عبد الله [بن مسعود] يسجد بالآية الأولى من <q>﴿حم تنزيل من الرحمن الرحيم﴾</q>{6}. (١٣/١١٨) ٦٨٦١٧- عن سعيد بن جُبير: أنّ عبد الله بن عباس كان يسجد بآخر الآيتين من «حم السجدة»، وكان ابن مسعود يسجد بالأولى منهما{7}. (١٣/١١٧) ٦٨٦١٨- عن عبد الله بن عباس: أنّه كان يسجد في الآية الأخيرة من <q>﴿حم تنزيل﴾</q>{8}. (١٣/١١٨) ٦٨٦١٩- قال مجاهد بن جبر: سألتُ عبد الله بن عباس عن السجدة في <q>﴿حم﴾</q> فقال: اسجدوا بالآخرة من الآيتين{9}. (ز) ٦٨٦٢٠- عن عبد الله بن عمر -من طريق نافع- أنه كان يسجد بالآية الأولى{10}. (١٣/١١٨) ٦٨٦٢١- عن عبد الله بن عمر: أنّه كان يسجد في الآية الأخيرة{8}. (١٣/١١٨) ٦٨٦٢٢- عن عبدة بن حَزْن النَّصرى -وله صحبة-: أنّه سجد في الآية الأولى من <q>﴿حم﴾</q>{12}. (١٣/١١٨) ٦٨٦٢٣- عن أبي وائل -من طريق مغيرة-: أنّه كان يسجد في الآية الآخرة{13}. (ز) ٦٨٦٢٤- عن طلحة، عن إبراهيم [النخعي]: أنّه كان يسجد في <q>﴿يَسْأَمُونَ﴾</q>{14}. (ز) ٦٨٦٢٥- عن محمد بن سيرين -من طريق ابن عون-: أنه كان يسجد في الآية الآخرة{15}. (ز) ٦٨٦٢٦- عن الأعمش، قال: أدركت إبراهيم= (ز) ٦٨٦٢٧- وأبا صالح= (ز) ٦٨٦٢٨- وطلحة= (ز) ٦٨٦٢٩- ويحيى= (ز) ٦٨٦٣٠- وزُبيدًا اليامي: يسجدون بالآية الأولى من <q>﴿حم﴾</q> السجدة{16}. (ز) ",footnotes:1:أخرجه ابن جرير ٢٠/٤٣٧.أخرجه الطستي في مسائله -كما في الإتقان ٢/٨٧-.تفسير مقاتل بن سليمان ٣/٧٤٣.أخرجه ابن أبي شيبة في مصنفه (ت: عوامة) ٢/١١.أخرجه الطبراني في الأوسط ٧/٣١٠ (٧٥٨٨)، كما أخرج الشافعي في كتاب الأم ٨/٤١٥ نحوه من طريق زر.أخرجه إسحاق البستي ص٢٨٨. وعزاه السيوطي إلى سعيد بن منصور.أخرجه ابن أبي شيبة ٢/١٠-١١، والحاكم ٢/٤٤١، والبيهقي في سننه ٢/٣٢٦.عزاه السيوطي إلى سعيد بن منصور.أخرجه يحيى بن سلام -كما في تفسير ابن أبي زمنين ٤/١٥٤-، وإسحاق البستي ص٢٩٥ بنحوه.أخرجه ابن أبي شيبة ٢/١٠-١١. وعزاه السيوطي إلى ابن سعد.عزاه السيوطي إلى سعيد بن منصور.أخرجه البخاري في تاريخه ٦/١١٣.أخرجه سعيد بن منصور في سننه -التفسير ٧/٢٤٥ (١٨٩٩)، وابن أبي شيبة (ت: عوامة) ٢/١٠.أخرجه عبد الله بن وهب في الجامع -تفسير القرآن ٣/١٠٥ (٢٤٤)، وابن أبي شيبة (ت: عوامة) ٢/١٠.أخرجه سعيد بن منصور في سننه -التفسير ٧/٢٤٥ (١٩٠٠)، وابن أبي شيبة (ت: عوامة) ٢/١٠.أخرجه ابن أبي شيبة (ت: عوامة) ٢/١١.
