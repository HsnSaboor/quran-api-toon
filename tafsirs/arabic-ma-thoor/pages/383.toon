tafsir[13]{c,v,t}:
27,64," <q>﴿أَمَّن یَبۡدَؤُا۟ ٱلۡخَلۡقَ ثُمَّ یُعِیدُهُۥ﴾</q> - تفسير ٥٧٦٩٦- قال مقاتل بن سليمان: ثم قال تعالى: <q>﴿أمن يبدؤا الخلق ثم يعيده﴾</q>، يقول: مَن بدأ الخلق فخَلَقهم، ولم يكونوا شيئًا، ثم يعيده في الآخرة{1}. (ز) ٥٧٦٩٧- قال يحيى بن سلّام: قوله: <q>﴿أمن يبدأ الخلق ثم يعيده﴾</q>، يعني: البعث{2}٤٨٩٧. (ز) ٤٨٩٧ ذكر ابنُ عطية (٦/٥٥٢) أنّ المراد بـ<q>﴿الخَلْقَ﴾</q> هنا: المخلوق مِن جميع الأشياء، لكن المقصود: بنو آدم؛ من حيث ذكر الإعادة، والبعث من القبور، ثم أورد احتمالًا آخر، فقال: «ويحتمل أن يريد بـ<q>﴿الخَلْقَ﴾</q> مصدر: خلَق يخلق، ويكون <q>﴿يَبْدَأ﴾</q> و»يُعِيدُ «استعارة للإتقان والإحسان: كما تقول: فلان يبدي ويعيد في أمر كذا وكذا؛ أي: يتقنه». <q>﴿وَمَن یَرۡزُقُكُم مِّنَ ٱلسَّمَاۤءِ وَٱلۡأَرۡضِۗ أَءِلَـٰهࣱ مَّعَ ٱللَّهِۚ﴾</q> - تفسير ٥٧٦٩٨- قال مقاتل بن سليمان: <q>﴿ومن يرزقكم من السماء﴾</q> يعني: المطر، <q>﴿والأرض﴾</q> يعني: النبت، <q>﴿أإله مع الله﴾</q> يعينه على صنعه ﷿؟{3}. (ز) ٥٧٦٩٩- قال يحيى بن سلّام: قوله: <q>﴿ومن يرزقكم من السماء والأرض﴾</q> وهو على الاستفهام، يقول: أمَن يفعل هذا خير أو أوثانهم؟ وهذا تبع لقوله: <q>﴿ءالله خير أما يشركون﴾</q>، أي: أنّ الله خير من أوثانهم، <q>﴿أإله مع الله﴾</q> على الاستفهام، أي: ليس معه إله{2}. (ز) <q>﴿وَمَن یَرۡزُقُكُم مِّنَ ٱلسَّمَاۤءِ وَٱلۡأَرۡضِۗ أَءِلَـٰهࣱ مَّعَ ٱللَّهِۚ﴾</q> - آثار متعلقة بالآية ٥٧٧٠٠- عن أبي ثعلبة الخُشني، عن أبي عبيدة بن الجراح، ومعاذ بن جبل، عن النبي ﷺ أنّه قال: «إنّ الله ﷿ بدأ هذا الأمر نبوة ورحمة، وكائنًا خلافة ورحمة، وكائنًا مُلكًا عَضوضًا، وكائنًا عَنوة وجَبريَّة وفسادًا في الأرض؛ يستحلِّون الفروج، والخمور، والحرير، ويُنصَرون على ذلك، ويُرزقون أبدًا حتى يلقوا الله»{5}. (ز) <q>﴿قُلۡ هَاتُوا۟ بُرۡهَـٰنَكُمۡ إِن كُنتُمۡ صَـٰدِقِینَ ۝٦٤﴾</q> - تفسير ٥٧٧٠١- عن أبي العالية الرِّياحِي -من طريق الربيع-: <q>﴿هاتوا برهانكم﴾</q> أي: حُجَّتكم؛ <q>﴿إن كنتم صادقين﴾</q> بما تقولون أنّه كما تقولون{6}. (ز) ٥٧٧٠٢- وعن مجاهد بن جبر= (ز) ٥٧٧٠٣- وإسماعيل السُّدِّيّ، نحو ذلك{7}. (ز) ٥٧٧٠٤- تفسير الحسن البصري: <q>﴿هاتوا برهانكم﴾</q> حُجَّتكم{8}. (ز) ٥٧٧٠٥- عن قتادة بن دعامة -من طريق شيبان- <q>﴿قل هاتوا برهانكم﴾</q>، قال: بينتكم على ذلك <q>﴿إن كنتم صادقين﴾</q>{9}. (ز) ٥٧٧٠٦- قال مقاتل بن سليمان: <q>﴿قل﴾</q> لكفار مكة: <q>﴿هاتوا برهانكم﴾</q> يعني: هلُمُّوا بحجتكم بأنّه صنع شيئًا مِن هذا غير الله ﷿ مِن الآلهة؛ فتكون لكم الحجة على الله تعالى؛ <q>﴿إن كنتم صادقين﴾</q> بأنّ مع الله آلهةً كما زعمتم، يعني: الملائكة{3}. (ز) ٥٧٧٠٧- قال يحيى بن سلّام: <q>﴿قل هاتوا برهانكم﴾</q> يقول للنبي ﷺ، أي: يقول للمشركين: <q>﴿هاتوا برهانكم إن كنتم صادقين﴾</q> أنّ هذه الأوثان خلقت شيئًا، أو صنعت شيئًا مِن هذا{2}. (ز) ",footnotes:1:تفسير مقاتل بن سليمان ٣/٣١٤.تفسير يحيى بن سلام ٢/٥٥٨.تفسير مقاتل بن سليمان ٣/٣١٥.تفسير يحيى بن سلام ٢/٥٥٨.أخرجه الطيالسي ١/١٨٤ (٢٢٥)، والطبراني في الكبير ٢٠/٥٣ (٩١-٩٢)، وابن أبي حاتم ٩/٢٩١٢ (١٦٥٣٠)، ولفظه: «ليكونن في الأرض فساق في الأمة يستحلون الفروج ...» الحديث. قال الهيثمي في المجمع ٥/١٨٩ (٨٩٦٢): «فيه ليث بن أبي سليم، وهو ثقة، ولكنه مُدَلِّس، وبقية رجاله ثقات». وقال الألباني في الضعيفة ٧/٥٦ (٣٠٥٥): «مُنكَر بهذا التمام».أخرجه ابن أبي حاتم ٩/٢٩١٢-٢٩١٣.علَّقه يحيى بن سلام ٢/٥٥٨ عن إسماعيل السدي بلفظ: حجتكم أن معه إلهًا، وعلَّقه ابن أبي حاتم ٩/٢٩١٢.علَّقه يحيى بن سلام ٢/٥٥٨.أخرجه ابن أبي حاتم ٩/٢٩١٢. وعلقه يحيى بن سلام ٢/٥٥٨.تفسير مقاتل بن سليمان ٣/٣١٥.تفسير يحيى بن سلام ٢/٥٥٨.
27,65," <q>﴿قُل لَّا یَعۡلَمُ مَن فِی ٱلسَّمَـٰوَ ٰ⁠تِ وَٱلۡأَرۡضِ ٱلۡغَیۡبَ إِلَّا ٱللَّهُۚ وَمَا یَشۡعُرُونَ أَیَّانَ یُبۡعَثُونَ ۝٦٥﴾</q> - تفسير ٥٧٧٠٨- عن مسروق، قال: كنت مُتَّكِئًا عند عائشة، فقالت: ثلاثٌ مَن تكلَّم بواحدةٍ مِنهُنَّ فقد أعظم على الله الفِرْيَة. قلت: وما هُنَّ؟ قالت: مَن زعم أنّ محمدًا رأى ربَّه فقد أعظم على الله الفرية. قال: وكنت مُتَّكِئًا فجلستُ، فقلتُ: يا أم المؤمنين، أنظريني ولا تعجلي عليَّ، ألم يقل الله: <q>﴿ولقد رآه بالأفق المبين﴾</q> [التكوير:٣٢]، <q>﴿ولقد رآه نزلة أخرى﴾</q> [النجم:١٣]؟. فقالت: أنا أول هذه الأمة سأل عن هذا رسولَ الله ﷺ، فقال: «جبريلُ لم أره على صورته التي خُلق عليها غير هاتين المرتين؛ رأيته منهبطًا مِن السماء، سادًّا عِظَم خَلْقه ما بين السماء إلى الأرض». قالت: أوَلَم تسمع اللهَ ﷿ يقول: <q>﴿لا تدركه الأبصار وهو يدرك الأبصار وهو اللطيف الخبير﴾</q> [الأنعام:١٠٣]؟، أوَلَم تسمع الله يقول: <q>﴿وما كان لبشر أن يكلمه الله إلا وحيا﴾</q> إلى قوله: <q>﴿علي حكيم﴾</q> [الشورى:٥١]؟. قالت: ومَن زعم أنّ محمدًا كتم شيئًا مِن كتاب الله فقد أعظم على الله الفِرْية، والله -جلَّ ذِكْرُه- يقول: <q>﴿يا أيها الرسول بلغ ما أنزل إليك من ربك﴾</q> إلى قوله: <q>﴿والله يعصمك من الناس﴾</q> [المائدة:٦٧]. قالت: ومَن زعم أنّه يخبر الناسَ بما يكون في غدٍ فقد أعظم على الله الفِرْيَة، والله تعالى يقول: <q>﴿قل لا يعلم من في السماوات والأرض الغيب إلا الله﴾</q>{1}. (١١/٣٩٤) ٥٧٧٠٩- قال مقاتل بن سليمان: <q>﴿قل لا يعلم من في السماوات﴾</q> يعني: الملائكة <q>﴿والأرض﴾</q> الناس <q>﴿الغيبَ﴾</q> يعني: البعث، يعني: غيب الساعة إلا الله وحده ﷿. ثم قال ﷿: <q>﴿وما يشعرون أيان يبعثون﴾</q> يقول لكفار مكة: وما يشعرون متى يبعثون بعد الموت؛ لأنهم يكفرون بالبعث{2}. (ز) ٥٧٧١٠- قال يحيى بن سلّام: قوله ﷿: <q>﴿قل لا يعلم من في السموات والأرض الغيب إلا الله﴾</q> الغيب هاهنا: القيامة، لا يعلم مجيئها إلا الله، <q>﴿وما يشعرون﴾</q> وما يشعر جميعُ الخلق <q>﴿أيان يبعثون﴾</q> متى يبعثون{3}. (ز) <q>﴿قُل لَّا یَعۡلَمُ مَن فِی ٱلسَّمَـٰوَ ٰ⁠تِ وَٱلۡأَرۡضِ ٱلۡغَیۡبَ إِلَّا ٱللَّهُۚ وَمَا یَشۡعُرُونَ أَیَّانَ یُبۡعَثُونَ ۝٦٥﴾</q> - آثار متعلقة بالآية ٥٧٧١١- عن قتادة بن دعامة -من طريق سعيد- قال: إنّ الله -تبارك وتعالى- إنّما جعل هذه النجوم لثلاث خصال: جعلها زينة للسماء، وجعلها يُهتدى بها، وجعلها رجومًا للشياطين، فمَن تعاطى فيها غير ذلك فقد قال رأيَه، وأخطأ حظَّه، وأضاع نصيبَه، وتكلَّف ما لا عِلْم له به، وإنّ ناسًا جَهَلَةً بأمر الله قد أحدثوا في هذه النجوم كهانة؛ مَن أعرس بنجم كذا وكذا، ومَن سافر بنجم كذا وكذا وكان كذا وكذا. ولَعَمْرِي ما مِن نجم إلا يُولَد به الأحمر والأسود، والطويل والقصير، والحسن والذميم، وما علم هذا النجم وهذه الدابة وهذا الطائر بشيء من الغيب، وقضى الله أنّه لا يعلم مَن في السموات والأرض الغيبَ إلا الله، وما يشعرون أيان يبعثون، ولَعمري لو أنّ أحدًا علِم الغيب لعلِمه آدم الذي خلقه الله بيده، وأسجد له ملائكته، وعلَّمه أسماء كل شيء، وأسكنه الجنة يأكل فيها رغدًا حيث شاء، ونُهِي عن شجرة واحدة، فلم يزل به البلاء حتى وقع بما نُهي عنه. ولو كان يعلم الغيب لعلمته الجن حين مات نبيُّ الله سليمان ﷺ، فلبثت تعمل له حولًا في أشدِّ الهوان، لا يشعرون بموته، ما دَلهَّم على موته إلا دابةُ الأرض تأكل منسأته، أي: تأكل عصاه، فلما خرَّ تبينت الجن -وهي في مصحف ابن مسعود: (تَبَيَّنَتِ الإنسُ والجِنَّ)- لو كانوا يعلمون الغيب ما لبثوا في العذاب المهين، وكانت الجن تقول قبل ذلك أنها تعلم الغيب، وتعلم ما في غد، فابتلاهم الله بذلك، وجعل موتَ سليمان للجن عِظَة{4}٤٨٩٨. (ز) ٤٨٩٨ علَّقَ ابن كثير (١٠/٤٢٦) على كلام قتادة هذا بقوله: «رواه ابن أبي حاتم عنه بحروفه، وهو كلام جليل متين صحيح». ",footnotes:1:أخرجه البخاري ٦/٥٢ (٤٦١٢)، ٦/١٤٠ (٤٨٥٥)، ٩/١١٦ (٧٣٨٠)، ٩/١٥٥ (٧٥٣١)، ومسلم ١/١٥٩-١٦٠ (١٧٧) واللفظ له، وابن جرير ٨/٥٧١، ٩/٤٦٢، ٢٢/٢٨-٢٩، ٢٢/٣١.تفسير مقاتل بن سليمان ٣/٣١٥.تفسير يحيى بن سلام ٢/٥٥٨.أخرجه ابن أبي حاتم ٩/٢٩١٣.
27,66," <q>﴿بَلِ ٱدَّ ٰ⁠رَكَ عِلۡمُهُمۡ فِی ٱلۡـَٔاخِرَةِۚ﴾</q> - قراءات ٥٧٧١٢- عن عبد الله بن عباس -من طريق ابن جريج، عن عطاء الخراساني- ‹بَلْ أدْرَكَ عِلْمُهُمْ فِي الآخِرَةِ›، قال: حين لم ينفع العلم{1}. (١١/٣٩٤) ٥٧٧١٣- عن عبد الله بن عباس، أنه قرأ: (بَلْ{2} أدّارَكَ عِلْمُهُمْ فِي الآخِرَةِ). قال: لم يدرك علمهم{3}. (١١/٣٩٥) ٥٧٧١٤- عن عبد الله بن عباس -من طريق علي- ‹بَلْ أدْرَكَ عِلْمُهُمْ فِي الآخِرَةِ›، يقول: غاب علمهم{4}. (١١/٣٩٥) ٥٧٧١٥- عن مجاهد بن جبر -من طريق عثمان بن الأسود- أنّه قرأ: (أمْ أدْرَكَ عِلْمُهُمْ){5}. (ز) ٥٧٧١٦- عن مجاهد بن جبر -من طريق حميد- (أأَدْرَكَ عِلْمُهُمْ){6}. (ز) ٥٧٧١٧- عن الحسن البصري -من طريق عمرو بن عبيد- أنّه كان يقرأ: (بَلِ ادَّرَكَ عِلْمُهُمْ فِي الآخِرَةِ). قال: اضْمَحَلَّ علمهُم في الدنيا حين عاينوا الآخرة{7}. (١١/٣٩٦) ٥٧٧١٨- عن قتادة بن دعامة -من طريق الحسين- في قوله: <q>﴿بَلِ ادّارَكَ عِلْمُهُمْ فِي الآخِرَةِ﴾</q>، قال: كان يقرؤها: ‹بَلْ أدْرَكَ عِلْمُهُمْ فِي الآخِرَةِ›، قال: لم يبلغ لهم فيها علمٌ، ولا يصل إليها منهم رغبة{8}. (ز) ٥٧٧١٩- عن عاصم بن أبي النجود أنّه قرأ: <q>﴿بَلِ ادّارَكَ عِلْمُهُمْ﴾</q> مثقلة مكسورة اللام، على معنى: تدارك{9}٤٨٩٩. (١١/٣٩٥) ٤٨٩٩ اختلف القُرّاء في قراءة قوله تعالى: <q>﴿بل ادارك علمهم في الآخرة﴾</q> على أربعة أوجه: أولها: بكسر اللام من <q>﴿بل﴾</q> وتشديد الدال من <q>﴿ادراك﴾</q> هكذا: <q>﴿بَلِ ادّارَكَ﴾</q>، بمعنى: بل تدارك علمهم، أي: تتابع علمهم بالآخرة. وهي قراءة عامة أهل المدينة سوى أبي جعفر، وعامة أهل الكوفة. والثاني: وقرأته عامة قرّاء أهل مكة: بسكون الدال وهمزة مفتوحة، هكذا: ‹بَلْ أدْرَكَ›، بمعنى: هل أدرك علمُهم علمَ الآخرة؟ وكذلك قرأها مجاهد ولكن مع إبدال «أم» بـ<q>﴿بل﴾</q>، هكذا: (أمْ أدْرَكَ). والثالث: بإثبات (ياء) في «بل»، ثم يبتدئ «أدّارَكَ» بهمزة مفتوحة وتشديد الدال، هكذا (بَلى أدّارَكَ)، على وجه الاستفهام. وهي قراءة لابن عباس. والرابع: بسكون الدال ومدّ الألف، هكذا (بَل آدْرَكَ)، بمعنى: لم يدرك علمُهم في الآخرة. وهي قراءة ابن مُحَيصِن. ورجَّحَ ابنُ جرير (١٨/١٠٨) القراءتين الأولى والثانية؛ لأنهما المعروفتان في قَرَأَة الأمصار، وقال: «بأيتهما قرأ القارئ فمصيب عندنا». وعلَّقَ على قراءة ابن عباس هذه بقوله: «كأنّ ابن عباس وجَّهَ ذلك إلى أن مخرجه مخرج الاستهزاء بالمكذّبين بالبعث». ثم انتَقَدَها بقوله: «إنها وإن كانت صحيحة المعنى والإعراب، فخلاف لما عليه مصاحف المسلمين، وذلك أنّ في (بَلى) زيادة ياء في قراءته ليست في المصاحف، وهي مع ذلك قراءة لا نعلمها قرأ بها أحد من قرّاء الأمصار». ونقل إنكار أبي عمرو بن العلاء لقراءة ابن محيصن، فقال (١٨/١٠٦-١٠٧): «كان أبو عمرو بن العلاء يُنكر -فيما ذُكِر عنه- قراءة من قرأ: (بَلْ آدْرَكَ)، ويقول: إنّ»بل«إيجاب، والاستفهام في هذا الموضع إنكار». ثم قال (١٨/١٠٨): «الذي قال فيها أبو عمرو قول صحيح؛ لأن العرب تحقق بـ»بل«ما بعدها، لا تنفيه، والاستفهام في هذا الموضع إنكار لا إثبات، وذلك أن الله قد أخبر عن المشركين أنهم من الساعة في شكّ، فقال: <q>﴿بَلْ هُمْ فِي شَكٍّ مِنها بَلْ هُمْ مِنها عَمُونَ﴾</q>». <q>﴿بَلِ ٱدَّ ٰ⁠رَكَ عِلۡمُهُمۡ فِی ٱلۡـَٔاخِرَةِۚ﴾</q> - تفسير الآية ٥٧٧٢٠- عن عبد الله بن عباس -من طريق ابن جريج، عن عطاء الخراساني- ‹بَلْ أدْرَكَ عِلْمُهُمْ فِي الآخِرَةِ›، قال: حين لم ينفع العلم{10}. (١١/٣٩٤) ٥٧٧٢١- عن عبد الله بن عباس -من طريق علي- ‹بَلْ أدَْرَك عِلْمُهُمْ فِي الآخِرَةِ›، يقول: غاب علمهم{4}. (١١/٣٩٥) ٥٧٧٢٢- عن عبد الله بن عباس -من طريق أبي جمرة- ‹بَلْ أدْرك عِلْمُهُمْ فِي الآخِرَةِ›، يقول: لم يدرك شيئًا{12}. (ز) ٥٧٧٢٣- عن مجاهد بن جبر، في قوله: <q>﴿بل ادارك علمهم﴾</q>، قال: (أمْ أدْرَكَ عِلْمُهُمْ). <q>﴿أم هم قوم طاغون﴾</q> [الطور: ٥٣]، قال: بل هم قوم طاغون{13}. (١١/٣٩٥) ٥٧٧٢٤- عن مجاهد بن جبر -من طريق رجل- في قول الله: <q>﴿بل ادارك علمهم في الآخرة﴾</q>، قال: ما جهِلوه في الدنيا علِموه في الآخرة{14}. (ز) ٥٧٧٢٥- تفسير الحسن البصري: <q>﴿بل ادارك علمهم في الآخرة﴾</q> على الاستفهام، تبعًا للاستفهام الأول، أي: لم يبلغ علمُهم في الآخرة، ولو ادارك علمهم في الآخرة، أي: لو بلغ علمهم أن الآخرة كائنة لآمنوا بها في الدنيا كما آمن بها المؤمنون{15}. (ز) ٥٧٧٢٦- عن قتادة بن دعامة: <q>﴿بل ادارك علمهم في الآخرة﴾</q> قال: تتابع علمهم في الآخرة بسَفَهِهم وجهلهم، <q>﴿بل هم منها عمون﴾</q>{16}. (١١/٣٩٥) ٥٧٧٢٧- عن قتادة بن دعامة -من طريق سعيد بن بشير- قال: <q>﴿بل ادارك علمهم في الآخرة﴾</q> قال: يُجَهِّلهم ربهم، يقول: لم ينفد لهم إلى الآخرة عِلْمٌ، ولم يصل إليه منهم رغبة، <q>﴿بل هم في شك منها﴾</q>{17}. (ز) ٥٧٧٢٨- عن إسماعيل السُّدِّيّ، <q>﴿بل ادارك علمهم في الآخرة﴾</q>، يقول: اجتمع في يوم القيامة{17}. (ز) ٥٧٧٢٩- قال مقاتل بن سليمان: <q>﴿بل ادارك علمهم في الآخرة﴾</q>، يقول: علِموا في الآخرة حين عاينوها ما شكُّوا فيه وعَمَوْا عنه في الدنيا{19}. (ز) ٥٧٧٣٠- قال عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿بل ادارك علمهم في الآخرة﴾</q>، قال: يقول: ضلَّ عِلمُهم في الآخرة، فليس لهم فيها علم، هم منها عمون{20}. (ز) ٥٧٧٣١- قال يحيى بن سلّام: قوله ﷿: <q>﴿بل ادارك علمهم في الآخرة﴾</q> علِموا في الآخرة أنّ الأمر كما قال الله، فآمنوا حين لم ينفعهم علمُهم ولا إيمانُهم{21}٤٩٠٠. (ز) ٤٩٠٠ اختُلِف في تأويل قوله تعالى: <q>﴿بل ادارك علمهم في الآخرة﴾</q> على أربعة أقوال: أولها: أنّ معناها: بل أدرك علمهم في الآخرة فأيقنوها؛ إذ عاينوها، حين لم ينفعهم يقينهم بها؛ إذ كانوا بها في الدنيا مكذّبين. والثاني: أنّ معناها: بل غاب علمُهم في الآخرة. والثالث: أنّ معناها: لم يبلغ لهم فيها علم. والرابع: أنّ معناها: أم أدرك علمهم في الآخرة؟ ورجَّحَ ابنُ جرير (١٨/١١١ بتصرف) على قراءة مَن قرأ: ‹بَلْ أدْرَكَ› القولَ الأولَ –وهو قول ابن عباس، من طريق عطاء الخرساني- استنادًا إلى أنه الأظهر من المعاني، فقال: «إنما قلت: هذا القول أولى الأقوال في تأويل ذلك بالصواب، على القراءة التي ذُكِرَت؛ لأن ذلك أظهر معانيه. فالكلام إذا كان ذلك معناه: وما يشعرون أيان يبعثون، بل أدرك علمهم بذلك في الآخرة، بل هم في الدنيا في شك منها». ورجَّحَ (١٨/١١١ بتصرف) على قراءة من قرأ <q>﴿بَلِ ادّارَكَ﴾</q> القولَ الرابعَ -وهو قول مجاهد- استنادًا إلى لغة العرب، وقال: «العرب تضع»أم«موضع»بل«، وموضع»بل«»أم«إذا كان في أول الكلام استفهام. فيكون تأويل الكلام: وما يشعرون أيان يبعثون، بل تدارك علمهم في الآخرة، يعني: [أم] تتابع علمُهم في الآخرة، أي: بعلم الآخرة، أي: لم يتتابع بذلك ولم يعلموه، بل غاب علمهم عنه، وضل فلم يبلغوه ولم يُدرِكوه». <q>﴿بَلۡ هُمۡ فِی شَكࣲّ مِّنۡهَاۖ بَلۡ هُم مِّنۡهَا عَمُونَ ۝٦٦﴾</q> - تفسير ٥٧٧٣٢- عن مجاهد بن جبر -من طريق عثمان بن الأسود- في قول الله: <q>﴿بَلْ هُمْ فِي شَكٍّ مِنها﴾</q> يعني: الآخرة، <q>﴿بل هم﴾</q> إذ هم <q>﴿منها عمون﴾</q>{17}. (ز) ٥٧٧٣٣- عن قتادة بن دعامة -من طريق شيبان- <q>﴿بل هم منها عمون﴾</q>، قال: عموا عن الآخرة{23}. (١١/٣٩٥) ٥٧٧٣٤- عن إسماعيل السُّدِّيّ: <q>﴿بَلْ هُمْ﴾</q> اليوم <q>﴿فِي شَكٍّ مِنها﴾</q>{17}. (ز) ٥٧٧٣٥- قال محمد بن السائب الكلبي: <q>﴿بل هم منها عمون﴾</q> لا يدرون ما الحسابُ فيها، وما العقاب{25}. (ز) ٥٧٧٣٦- قال مقاتل بن سليمان: <q>﴿بل هم﴾</q> اليوم <q>﴿في شك منها﴾</q> يعني: مِن الساعة، <q>﴿بل هم منها عمون﴾</q> في الدنيا{26}. (ز) ٥٧٧٣٧- قال يحيى بن سلّام: <q>﴿بل هم في شك منها﴾</q> مِن الآخرة{27}. (ز) ",footnotes:1:أخرجه ابن جرير ١٨/١٠٩، وابن أبي حاتم ٩/٢٩١٤. ولفظ ابن جرير: بصرُهم في الآخرة حين لم ينفعهم العلم والبصر، وبهذا اللفظ أخرجه ابن أبي حاتم من طريق عثمان بن عطاء عن أبيه من قوله. وعزاه السيوطي إلى ابن المنذر. و‹بَلْ أدْرَكَ› بقطع الهمزة، وإسكان الدال من غير ألف بعدها قراءة متواترة، قرأ بها ابن كثير، وأبو عمرو، ويعقوب، وأبو جعفر، وقرأ بقية العشرة: <q>﴿بَلِ ادّارَكَ﴾</q> بوصل الهمزة، وتشديد الدال مفتوحة، وألف بعدها. انظر: النشر ٢/٣٣٩، والإتحاف ص٤٣١.كذا أثبته محققو الدر، وهو كذلك في «فضائل القرآن» لأبي عبيد، ونص ابن جرير على أنها «بلى» بإثبات الياء، وكذا نص عليه الفراء في معاني القرآن ٢/٢٩٩، وينظر: تفسير القرطبي ١٣/٢٢٦.أخرجه ابن عبيد في فضائله ص١٨٠، وعقَّب عليه بقوله: يعني: أنه قرأها بالاستفهام، وأثبت تعقيبه السيوطي في الدر عقب الأثر. وعزا السيوطي الأثرَ إلى سعيد بن منصور، وعبد بن حميد، وابن المنذر. وأخرجه ابن جرير ١٨/١٠٧ من طريق أبي حمزة -كذا في المطبوع، ولعله: أبو جمرة- بلفظ: بلى .... وعلى كل فهي شاذة؛ لخروجها عن القراءات العشر المتواترة.أخرجه ابن جرير ١٨/١٠٩، وابن أبي حاتم ٩/٢٩١٤. وعزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ١٨/١٠٧. وهي قراءة شاذة. انظر: مختصر ابن خالويه ص١١١.أخرجه إسحاق البستي في تفسيره ص٥١. وهي قراءة شاذة، تروى أيضًا عن ابن مسعود. انظر: مختصر ابن خالويه ص١١١.أخرجه إسحاق البستي في تفسيره ص٢٦ مختصرًا، وابن أبي حاتم ٩/٢٩١٤. وهي قراءة شاذة، تروى أيضًا عن الأعرج. انظر: مختصر ابن خالويه ص١١١.أخرجه ابن جرير ١٨/١١٠، وابن أبي حاتم ٩/٢٩١٥ من طريق سعيد بن بشير، وزاد: يجهلهم ربهم.عزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ١٨/١٠٩، وابن أبي حاتم ٩/٢٩١٤. وعزاه السيوطي إلى ابن المنذر. ولفظ ابن جرير: بصرهم في الآخرة حين لم ينفعهم العلم والبصر. وبهذا اللفظ أخرجه ابن أبي حاتم من طريق عثمان بن عطاء عن أبيه من قوله.أخرجه ابن جرير ١٨/١٠٩، وابن أبي حاتم ٩/٢٩١٤. وعزاه السيوطي إلى ابن المنذر.أخرجه إسحاق البستي في تفسيره ص٥١.أخرجه ابن جرير ١٨/١١٠من طريق ابن أبي نجيح مختصرًا، ومن طريق عثمان بلفظ: أم أدرك علمهم؟ من أين يدرك علمهم؟، ومن طريق ابن جريج بنحوه، وابن أبي حاتم ٩/٢٩١٤ مختصرًا. وعزاه السيوطي إلى الفريابي، وابن أبي شيبة، وعبد بن حميد، وابن المنذر. وعلَّقه يحيى بن سلام ٢/٥٥٩ قال: تفسير مجاهد: <q>﴿بل ادارك علمهم﴾</q> أم أدرك، أي: لم يدرك، مثل قول قتادة.أخرجه ابن وهب في الجامع ٢/٥٢ (٩٩). وبنحوه في تفسير الثعلبي ٧/٢٢٠، وتفسير البغوي ٦/١٧٤.علقه يحيى بن سلام ٢/٥٥٨. وأخرجه إسحاق البستي في تفسيره ص٢٦ من طريق إسماعيل وعوف بلفظ: (بل أدرك عملهم) [كذا] استفهام.عزاه السيوطي إلى عبد بن حميد، وابن المنذر. وقال يحيى بن سلام ٢/٥٥٩: في تفسير قتادة: <q>﴿بل ادارك علمهم في الآخرة﴾</q> قال: سفههم وجهلهم، أي: ما بلغ علمهم في الآخرة، أي: أن علمهم لم يبلغ ذلك في الدنيا، يسفههم بذلك.أخرجه ابن أبي حاتم ٩/٢٩١٥.أخرجه ابن أبي حاتم ٩/٢٩١٥.تفسير مقاتل بن سليمان ٣/٣١٥. وفي تفسير البغوي ٦/١٧٤ نحوه منسوبًا إلى مقاتل دون تعيينه.أخرجه ابن جرير ١٨/١٠٩.تفسير يحيى بن سلام ٢/٥٥٨.أخرجه ابن أبي حاتم ٩/٢٩١٥.أخرجه ابن أبي حاتم ٩/٢٩١٥. وعلَّقه يحيى بن سلام ٢/٥٥٩. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه ابن أبي حاتم ٩/٢٩١٥.علقه يحيى بن سلام ٢/٥٥٩. وفي تفسير البغوي ٦/١٧٤: يقول: هم جهلة بها.تفسير مقاتل بن سليمان ٣/٣١٥.تفسير يحيى بن سلام ٢/٥٥٩.
27,67," <q>﴿وَقَالَ ٱلَّذِینَ كَفَرُوۤا۟ أَءِذَا كُنَّا تُرَ ٰ⁠بࣰا وَءَابَاۤؤُنَاۤ أَىِٕنَّا لَمُخۡرَجُونَ ۝٦٧﴾</q> - نزول الآية ٥٧٧٣٨- قال مقاتل بن سليمان: نزلت في أبي طلحة، وشيبة، ومشافع، وشرحبيل، والحارث، وأبوه{1}، وأرطاة بن شرحبيل{2}. (ز) <q>﴿وَقَالَ ٱلَّذِینَ كَفَرُوۤا۟ أَءِذَا كُنَّا تُرَ ٰ⁠بࣰا وَءَابَاۤؤُنَاۤ أَىِٕنَّا لَمُخۡرَجُونَ ۝٦٧﴾</q> - تفسير الآية ٥٧٧٣٩- عن قتادة بن دعامة -من طريق سعيد- قوله: <q>﴿أإذا كنا ترابا وآباؤنا أئنا لمخرجون﴾</q>: قال ذلك مشركو قريش والمشركون من الناس: ينبئكم إذا أكلتكم الأرض، وصرتم رفاتًا وعظامًا، وتقطعتكم السباع والطير أنّكم تبعثون!{3}. (ز) ٥٧٧٤٠- قال مقاتل بن سليمان: <q>﴿وقال الذين كفروا أإذا كنا ترابا وآباؤنا أإنا لمخرجون﴾</q> مِن القبور أحياء{2}. (ز) ٥٧٧٤١- قال يحيى بن سلّام: قوله ﷿: <q>﴿وقال الذين كفروا أئذا كنا ترابا وآباؤنا﴾</q> على الاستفهام؛ <q>﴿أئنا لمخرجون﴾</q> لمبعوثون. كقوله: <q>﴿أإذا ما مِتُّ لَسَوْفَ أُخْرَجُ حَيًّا﴾</q> [مريم:٦٦]، أي: لا نُبعَث، وهذا استفهام منهم على إنكار{5}. (ز) ",footnotes:1:كذا وقع في المطبوع.تفسير مقاتل بن سليمان ٣/٣١٥.أخرجه ابن أبي حاتم ٩/٢٩١٥.تفسير مقاتل بن سليمان ٣/٣١٥.تفسير يحيى بن سلام ٢/٥٥٩-٥٦٠.
27,68," <q>﴿لَقَدۡ وُعِدۡنَا هَـٰذَا نَحۡنُ وَءَابَاۤؤُنَا مِن قَبۡلُ﴾</q> - تفسير ٥٧٧٤٢- قال يحيى بن سلّام: قوله ﷿: <q>﴿لقد وعدنا هذا نحن وآباؤنا من قبل﴾</q>، أي: فلم نُبعَث. وهذا قول مشركي العرب، أي: قد وُعدِت آباؤُنا مِن قبلُ بالبعث كما وعدنا محمد، فلم نرها بُعِثَتْ، يعني: مَن كان مِن العرب على عهد موسى، وقد كان موسى يومئذ حجة على العرب، في تفسير الحسن، وهو قوله: <q>﴿قالوا لولا أوتي مثل ما أوتي موسى أولم يكفروا بما أوتي موسى من قبل قالوا سحران تظاهرا وقالوا إنا بكل كافرون﴾</q> [القصص:٤٨]، يعني: موسى ومحمدًا ﷺ، في تفسير الحسن. وقال سعيد بن جبير: يعنون: موسى وهارون{1}. (ز) ٥٧٧٤٣- قال مقاتل بن سليمان: <q>﴿لقد وعدنا هذا﴾</q> الذي يقول محمد ﷺ، يعنون: البعث، <q>﴿نحن وآباؤنا من قبل﴾</q> يعنون: مِن قبلنا{2}. (ز) ٥٧٧٤٤- عن محمد بن إسحاق -من طريق سلمة-: يعني: قوله: <q>﴿لقد وعدنا هذا نحن وآباؤنا من قبل﴾</q> أي: قد جئت تخبرنا أنّا سنُبْعَث بعد موتنا، <q>﴿أئذا كنا عظاما ورفاتا﴾</q> وذلك لا يكون{3}. (ز) <q>﴿إِنۡ هَـٰذَاۤ إِلَّاۤ أَسَـٰطِیرُ ٱلۡأَوَّلِینَ ۝٦٨﴾</q> - تفسير ٥٧٧٤٥- عن قتادة بن دعامة -من طريق سعيد- قوله: <q>﴿أساطير الأولين﴾</q>: أي: كذِب الأولين، وباطلهم{4}. (٦/ ٣٤) ٥٧٧٤٦- عن الضحاك بن مزاحم، نحو ذلك{5}. (ز) ٥٧٧٤٧- عن إسماعيل السُّدِّيّ -من طريق أسباط- قوله: <q>﴿إن هذا إلا أساطير الأولين﴾</q>: أساجيع الأولين{3}. (٦/ ٣٤) ٥٧٧٤٨- قال مقاتل بن سليمان: <q>﴿إن هذا﴾</q> الذي يقول محمد ﷺ <q>﴿إلا أساطير الأولين﴾</q> يعني: أحاديث الأولين، وكذبهم{2}. (ز) ",footnotes:1:تفسير يحيى بن سلام ٢/٥٦٠.تفسير مقاتل بن سليمان ٣/٣١٥.أخرجه ابن أبي حاتم ٩/٢٩١٦.أخرجه يحيى بن سلام ٢/٥٦٠، وابن أبي حاتم ٩/٢٩١٦ بلفظ: أحاديث الأولين وباطلهم. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.علقه ابن أبي حاتم ٩/٢٩١٦.أخرجه ابن أبي حاتم ٩/٢٩١٦.تفسير مقاتل بن سليمان ٣/٣١٥.
27,69," <q>﴿قُلۡ سِیرُوا۟ فِی ٱلۡأَرۡضِ فَٱنظُرُوا۟ كَیۡفَ كَانَ عَـٰقِبَةُ ٱلۡمُجۡرِمِینَ ۝٦٩﴾</q> - تفسير ٥٧٧٤٩- عن الحسن البصري -من طريق عبّاد بن منصور- في قوله: <q>﴿قُلْ سِيرُوا فِي الأَرْضِ﴾</q> قال: لم يسيروا في الأرض، <q>﴿فانْظُرُوا كَيْفَ كانَ عاقِبَةُ المُجْرِمِينَ﴾</q> قال: كيف عذَّب اللهُ قوم نوح، وقوم لوط، وقوم صالح، والأمم التي عذَّب الله{1}. (١١/٣٩٦) ٥٧٧٥٠- عن قتادة بن دعامة -من طريق سعيد- <q>﴿فانْظُرُوا كَيْفَ كانَ عاقِبَةُ المُجْرِمِينَ﴾</q> قال: بئس -واللهِ- كان عاقبة المجرمين، دمَّر الله عليهم، وأهلكهم، ثم صيَّرهم إلى النار{1}. (٦/ ٢١) ٥٧٧٥١- عن قتادة بن دعامة -من طريق شيبان- قوله: <q>﴿فانْظُرُوا كَيْفَ كانَ عاقِبَةُ المُجْرِمِينَ﴾</q>، قال: عاقبة الأولين والأمم قبلكم. قال: كان سوء عاقبة، متَّعهم الله قليلًا، ثم صاروا إلى النار{1}. (ز) ٥٧٧٥٢- قال مقاتل بن سليمان: <q>﴿قل﴾</q> لكفار مكة: <q>﴿سيروا في الأرض فانظروا كيف كان عاقبة المجرمين﴾</q> يعني: كُفّار الأمم الخالية، كيف كان عاقبتهم في الدنيا؛ الهلاك، يُخَوِّف كفار مكة مثل عذاب الأمم الخالية لِئلّا يكذبوا محمدًا ﷺ، وقد رأوا هلاك قوم لوط وعاد وثمود{4}. (ز) ٥٧٧٥٣- قال يحيى بن سلّام: قال الله للنبي ﵇: <q>﴿قل سيروا في الأرض فانظروا كيف كان عاقبة المجرمين﴾</q> المشركين، كان عاقبتهم أن دمَّر الله عليهم ثم صيَّرهم إلى النار، أي: فاحذروا أن ينزل بكم مِن عذاب الله ما نزل بهم، يعني: المشركين{5}. (ز) ",footnotes:1:أخرجه ابن أبي حاتم ٩/٢٩١٦.أخرجه ابن أبي حاتم ٩/٢٩١٦.أخرجه ابن أبي حاتم ٩/٢٩١٦.تفسير مقاتل بن سليمان ٣/٣١٥.تفسير يحيى بن سلام ٢/٥٦٠.
27,70," <q>﴿وَلَا تَحۡزَنۡ عَلَیۡهِمۡ وَلَا تَكُن فِی ضَیۡقࣲ مِّمَّا یَمۡكُرُونَ ۝٧٠﴾</q> - تفسير ٥٧٧٥٤- عن إسماعيل السُّدِّيّ -من طريق أسباط- <q>﴿ولا تك في ضيق مما يمكرون﴾</q>، يقول: في شكٍّ{1}. (ز) ٥٧٧٥٥- قال مقاتل بن سليمان: ثم قال للنبي ﷺ: <q>﴿ولا تحزن عليهم﴾</q> يعني: على كُفّار مكة إن تَوَلَّوْا عنك ولم يُجِيبوك، <q>﴿ولا تكن في ضيق مما يمكرون﴾</q> يقول: لا يضيقُ صدرك بما يقولون، هذا دأبنا ودأبك أيام الموسم، وهم الخرّاصون، وهم المستهزئون{2}. (ز) ٥٧٧٥٦- قال يحيى بن سلّام: قوله ﷿: <q>﴿ولا تحزن عليهم﴾</q> إن لم يؤمنوا، كقوله: <q>﴿فلا تذهب نفسك عليهم حسرات﴾</q> [فاطر:٨]، <q>﴿ولا تكن في ضيق مما يمكرون﴾</q> لا يضيق عليك أمرك مما يمكرون بك وبدينك، فإنّ الله سينصرك عليهم ويُذِلُّهم لك{3}. (ز) ",footnotes:1:أخرجه ابن أبي حاتم ٩/٢٩١٧.تفسير مقاتل بن سليمان ٣/٣١٦.تفسير يحيى بن سلام ٢/٥٦١.
27,71," <q>﴿وَیَقُولُونَ مَتَىٰ هَـٰذَا ٱلۡوَعۡدُ إِن كُنتُمۡ صَـٰدِقِینَ ۝٧١﴾</q> - تفسير ٥٧٧٥٧- قال مقاتل بن سليمان: <q>﴿ويقولون متى هذا الوعد﴾</q> يعنون: العذاب؛ <q>﴿إن كنتم صادقين﴾</q> يعني: النبي ﷺ وحده؛ بأنّ العذاب نازلٌ بِنا{1}. (ز) ٥٧٧٥٨- قال يحيى بن سلّام: قوله ﷿: <q>﴿ويقولون متى هذا الوعد﴾</q> الذي تَعِدُنا به مِن عذاب الله إن كنت مِن الصادقين{2}. (ز) ",footnotes:1:تفسير مقاتل بن سليمان ٣/٣١٦.تفسير يحيى بن سلام ٢/٥٦١.
27,72," <q>﴿قُلۡ عَسَىٰۤ أَن یَكُونَ رَدِفَ لَكُم بَعۡضُ ٱلَّذِی تَسۡتَعۡجِلُونَ ۝٧٢﴾</q> - تفسير ٥٧٧٥٩- عن عبد الله بن عباس -من طريق علي، والعوفي- في قوله: <q>﴿عسى أن يكون ردف لكم﴾</q>، قال: اقترب لكم{1}٤٩٠١. (١١/٣٩٦) ٤٩٠١ علَّقَ ابنُ كثير (١٠/ ٤٢٨) على قول ابن عباس هذا بقوله: «وهكذا قال مجاهد، والضحاك، وعطاء الخراساني، وقتادة، والسدي، وهذا هو المراد، كقوله تعالى: <q>﴿ويقولون متى هو قل عسى أن يكون قريبا﴾</q> [الإسراء:٥١]، وقال تعالى: <q>﴿يستعجلونك بالعذاب وإن جهنم لمحيطة بالكافرين﴾</q> [العنكبوت:٥٤]». ٥٧٧٦٠- عن عبد الله بن عباس، في قوله: <q>﴿عسى أن يكون ردف لكم﴾</q>، قال: حضركم{2}. (ز) ٥٧٧٦١- عن مجاهد بن جبر -من طريق ابن أبي نجيح- <q>﴿عسى أن يكون ردف لكم﴾</q>، قال: عجِل لكم{3}. (١١/٣٩٦) ٥٧٧٦٢- عن مجاهد بن جبر -من طريق ابن جُرَيْج- في قوله: <q>﴿ردف لكم﴾</q>، قال: أزِف لكم{4}. (١١/٣٩٦) ٥٧٧٦٣- تفسير مجاهد بن جبر: قوله <q>﴿قل عسى أن يكون ردف لكم﴾</q>، أي: اقترب لكم{5}. (ز) ٥٧٧٦٤- عن الضحاك بن مُزاحِم -من طريق عبيد- في قوله: <q>﴿ردف لكم﴾</q>، قال: اقترب لكم{6}. (ز) ٥٧٧٦٥- عن قتادة بن دعامة، <q>﴿عسى أن يكون ردف لكم﴾</q>، قال: اقترب منكم{7}. (١١/٣٩٦) ٥٧٧٦٦- عن إسماعيل السُّدِّيّ= (ز) ٥٧٧٦٧- وعطاء الخراساني، نحو ذلك{8}. (ز) ٥٧٧٦٨- قال مقاتل بن سليمان: <q>﴿قل عسى أن يكون ردف لكم﴾</q>، يعني: قريب لكم{9}. (ز) ٥٧٧٦٩- قال يحيى بن سلّام: قال الله للنبي ﷺ: <q>﴿قل عسى أن يكون ردف لكم﴾</q>، أي: دَنا منكم{10}. (ز) <q>﴿بَعۡضُ ٱلَّذِی تَسۡتَعۡجِلُونَ ۝٧٢﴾</q> - تفسير ٥٧٧٧٠- تفسير الحسن البصري: قوله: <q>﴿بعض الذي تستعجلون﴾</q> بعض الذي تستعجلون مِن عذاب الله، يعني: قيام الساعة التي يهلك بها آخرُ كُفّار هذه الأمة الدائنين بدين أبي جهل وأصحابه{11}. (ز) ٥٧٧٧١- قال مقاتل بن سليمان: <q>﴿بعض الذي تستعجلون﴾</q> فكان بعضُ العذاب: القتل ببدر، وسائر العذاب لهم فيما بعد الموت{9}. (ز) ٥٧٧٧٢- عن عبد الملك ابن جريج -من طريق حجاج- <q>﴿ردف لكم بعض الذي تستعجلون﴾</q>، قال: مِن العذاب{13}. (١١/٣٩٦) ",footnotes:1:أخرجه ابن جرير ١٨/١١٣، وابن أبي حاتم -كما في الإتقان ٢/٣٥-. وعزاه السيوطي إلى ابن المنذر.تفسير الثعلبي ٧ /٢٢١.أخرجه ابن جرير ١٨/١١٣، وابن أبي حاتم ٩/٢٩١٧ بمعناه. وعزاه السيوطي إلى الفريابي، وعبد بن حميد.أخرجه ابن جرير ١٨/١١٤، وابن أبي حاتم ٩/٢٩١٧. وعزاه السيوطي إلى ابن المنذر.علَّقه يحيى بن سلام ٢/٥٦١.أخرجه ابن جرير ١٨/١٠٩، وإسحاق البستي في تفسيره ص٥١. وعلقه ابن أبي حاتم ٩/٢٩١٧.علَّقه يحيى بن سلام ٢/٥٦١، وابن أبي حاتم ٩/٢٩١٧. وعزاه السيوطي إلى عبد بن حميد.علقه ابن أبي حاتم ٩/٢٩١٧.تفسير مقاتل بن سليمان ٣/٣١٦.تفسير يحيى بن سلام ٢/٥٦١.علقه يحيى بن سلام ٢/٥٦١.تفسير مقاتل بن سليمان ٣/٣١٦.أخرجه ابن جرير ١٨/١١٥.
27,73," <q>﴿وَإِنَّ رَبَّكَ لَذُو فَضۡلٍ عَلَى ٱلنَّاسِ﴾</q> - تفسير ٥٧٧٧٣- قال مقاتل بن سليمان: ثم قال: <q>﴿وإن ربك لذو فضل على الناس﴾</q>، يعني: على كفار مكة حين لا يعجل عليهم بالعذاب حين أرادوه{1}. (ز) ٥٧٧٧٤- قال يحيى بن سلّام: قوله ﷿: <q>﴿وإن ربك لذو فضل على الناس﴾</q> فبفضل الله خلق الكافر، وبفضله يتقلَّب في الدنيا، ويأكل، ويشرب{2}. (ز) <q>﴿وَلَـٰكِنَّ أَكۡثَرَهُمۡ لَا یَشۡكُرُونَ ۝٧٣﴾</q> - تفسير ٥٧٧٧٥- عن قتادة بن دعامة -من طريق سعيد- قوله: <q>﴿ولكن أكثرهم لا يشكرون﴾</q>، قال: إنّ المؤمن لَيشكر نِعَم الله عليه وعلى خلقِه{3}. (ز) ٥٧٧٧٦- قال مقاتل بن سليمان: ثم قال: <q>﴿ولكن أكثرهم﴾</q> يعني: أكثر أهل مكة <q>﴿لا يشكرون﴾</q> الربَّ ﷿ في تأخير العذاب عنهم{4}. (ز) ٥٧٧٧٧- قال يحيى بن سلّام: قوله ﷿: <q>﴿ولكن أكثرهم﴾</q> أكثر الناس <q>﴿لا يشكرون﴾</q> أكثرهم مَن لا يشكر؛ مَن لا يؤمن، ومنهم مَن يشكر، وهو المؤمن{5}. (ز) ",footnotes:1:تفسير مقاتل بن سليمان ٣/٣١٦. وفي تفسير البغوي ٦/١٧٥ نحوه منسوبًا إلى مقاتل دون تعيينه.تفسير يحيى بن سلام ٢/٥٦١.أخرجه ابن أبي حاتم ٩/٢٩١٨.تفسير مقاتل بن سليمان ٣/٣١٦.تفسير يحيى بن سلام ٢/٥٦٢.
27,74," <q>﴿وَإِنَّ رَبَّكَ لَیَعۡلَمُ مَا تُكِنُّ صُدُورُهُمۡ وَمَا یُعۡلِنُونَ ۝٧٤﴾</q> - تفسير ٥٧٧٧٨- عن عبد الله بن عباس -من طريق العوفي- في قوله: <q>﴿وإن ربك ليعلم ما تكن صدورهم وما يعلنون﴾</q>، قال: يعلم ما عمِلوا بالليل والنهار{1}. (١١/٣٩٧) ٥٧٧٧٩- قال مقاتل بن سليمان: ثم قال: <q>﴿وإن ربك ليعلم ما تكن صدورهم﴾</q> يعني: ما تُسِرُّ قلوبهم، <q>﴿وما يعلنون﴾</q> بألسنتهم{2}. (ز) ٥٧٧٨٠- عن عبد الملك ابن جُرَيج -من طريق حجّاج- في قوله: <q>﴿ليعلم ما تكن صدورهم﴾</q>، قال: السِّرّ{3}. (١١/٣٩٧) ٥٧٧٨١- قال يحيى بن سلّام: قوله ﷿: <q>﴿وإن ربك ليعلم ما تكن صدورهم﴾</q> يعني: المشركين، مِن عداوة رسول الله ﷺ، <q>﴿وما يعلنون﴾</q> مِن الكفر{4}. (ز) ",footnotes:1:أخرجه ابن أبي حاتم ٩/٢٩١٨.تفسير مقاتل بن سليمان ٣/٣١٦.أخرجه ابن جرير ١٨/١١٥-١١٦. وعزاه السيوطي إلى ابن المنذر.تفسير يحيى بن سلام ٢/٥٦٢.
27,75," <q>﴿وَمَا مِنۡ غَاۤىِٕبَةࣲ فِی ٱلسَّمَاۤءِ وَٱلۡأَرۡضِ إِلَّا فِی كِتَـٰبࣲ مُّبِینٍ ۝٧٥﴾</q> - تفسير ٥٧٧٨٢- عن عبد الله بن عباس -من طريق العوفي- <q>﴿وما من غائبة في السماء والأرض إلا في كتاب﴾</q>، يقول: ما مِن شيء في السماء سِرًّا ولا علانية إلا يعلمه{1}٤٩٠٢. (١١/٣٩٧) ٤٩٠٢ علَّقَ ابنُ كثير (١٠/ ٤٢٩) على قول ابن عباس هذا بقوله: «وهذا كقوله تعالى: <q>﴿ألم تعلم أن الله يعلم ما في السماء والأرض إن ذلك في كتاب إن ذلك على الله يسير﴾</q> [الحج:٧٠]». ٥٧٧٨٣- عن مجاهد بن جبر -من طريق إبراهيم بن يزيد- <q>﴿وما من غائبة﴾</q> الآية، يقول: ما مِن قول ولا عمل في السماء والأرض إلا وهو عنده، <q>﴿في كتاب﴾</q> في اللوح المحفوظ قبل أن يخلق اللهُ السموات والأرض{2}. (١١/٣٩٧) ٥٧٧٨٤- تفسير الحسن البصري: قوله ﷿: <q>﴿وما من غائبة في السماء والأرض إلا في كتاب مبين﴾</q>: الغائبة القيامة{3}. (ز) ٥٧٧٨٥- قال مقاتل بن سليمان: ثم قال: <q>﴿وما من غائبة﴾</q> يعني: علم غيب ما يكون مِن العذاب في السماء والأرض، وذلك حين استعجلوه بالعذاب، <q>﴿إلا في كتاب مبين﴾</q> يقول: إلا هو بيِّن في اللوح المحفوظ{4}. (ز) <q>﴿وَمَا مِنۡ غَاۤىِٕبَةࣲ فِی ٱلسَّمَاۤءِ وَٱلۡأَرۡضِ إِلَّا فِی كِتَـٰبࣲ مُّبِینٍ ۝٧٥﴾</q> - آثار متعلقة بالآية ٥٧٧٨٦- عن عبد الله بن عباس -من طريق أبي ظبيان- قال: أول ما خلق الله القلم، فقال: اكتب. قال: ربِّ، ما أكتب؟ قال: ما هو كائن. فجرى القلم بما هو كائن إلى يوم القيامة. قال: فأعمال العباد تُعرَض كل يوم اثنين وخميس، فيجدونه على ما في الكتاب{5}. (ز) ",footnotes:1:أخرجه ابن جرير ١٨/١١٦، وابن أبي حاتم ٩/٢٩١٩.أخرجه ابن أبي حاتم ٩/٢٩١٩.علَّقه يحيى بن سلام ٢/٥٦٢.تفسير مقاتل بن سليمان ٣/٣١٦.أخرجه يحيى بن سلام ٢/٥٦٢.
27,76," <q>﴿إِنَّ هَـٰذَا ٱلۡقُرۡءَانَ یَقُصُّ عَلَىٰ بَنِیۤ إِسۡرَ ٰ⁠ۤءِیلَ أَكۡثَرَ ٱلَّذِی هُمۡ فِیهِ یَخۡتَلِفُونَ ۝٧٦﴾</q> - تفسير ٥٧٧٨٧- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿إن هذا القرآن يقص على بني إسرائيل﴾</q>: يعني: اليهود والنصارى، <q>﴿أكثر الذي هم فيه يختلفون﴾</q> يقول: هذا القرآن يُبَيِّن لهم الذي اختلفوا فيه{1}. (١١/٣٩٧) ٥٧٧٨٨- قال محمد بن السائب الكلبي: إنّ أهل الكتاب اختلفوا فيما بينهم، فصاروا أحزابًا يطعن بعضهم على بعض، فنزل القرآن ببيان ما اختلفوا فيه{2}. (ز) ٥٧٧٨٩- قال مقاتل بن سليمان: <q>﴿إن هذا القرآن يقص على بني إسرائيل أكثر الذي هم فيه﴾</q> يعني: في القرآن <q>﴿يختلفون﴾</q> يقول: هذا القرآن مبين لأهل الكتاب اختلافهم{3}. (ز) ٥٧٧٩٠- قال يحيى بن سلّام: قوله ﷿: <q>﴿إن هذا القرءان يقص على بني إسرائيل﴾</q> قال قتادة: يعني: اليهود والنصارى. يعني: الذين أدركوا النبي ﵇ <q>﴿أكثر الذي هم فيه يختلفون﴾</q> يعني: ما اختلف فيه أوائلُهم، وما حرَّفوا مِن كتاب الله، وما كتبوا بأيديهم ثم قالوا: هذا من عند الله{4}. (ز) ",footnotes:1:أخرجه ابن أبي حاتم ٩/٢٩١٩. وعلَّق يحيى بن سلام ٢/٥٦٢ شطره الأول. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.تفسير البغوي ٦/١٧٥.تفسير مقاتل بن سليمان ٣/٣١٦.تفسير يحيى بن سلام ٢/٥٦٢.
