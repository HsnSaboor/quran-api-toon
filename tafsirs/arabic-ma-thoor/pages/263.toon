tafsir[16]{c,v,t}:
15,16," <q>﴿وَلَقَدۡ جَعَلۡنَا فِی ٱلسَّمَاۤءِ بُرُوجࣰا وَزَیَّنَّـٰهَا لِلنَّـٰظِرِینَ ۝١٦﴾</q> - تفسير ٤٠١٩٨- عن جابر، عن النبي ﷺ أنّه سُئِل: عن <q>﴿السماء ذات البروج﴾</q> [البروج:١]. فقال: «الكواكب». وسُئِل: عن <q>﴿الذي جعل في السماء بروجا﴾</q> [الفرقان:٦١] قال: «الكواكب». مثل البروج مشيدة، قال: «القصور»{1}. (ز) ٤٠١٩٩- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿ولقد جعلنا في السماء بروجا﴾</q>، قال: كواكب{2}٣٥٩٤. (٨/٥٩٦) ٣٥٩٤ لم يذكر ابنُ جرير (١٤/٣١) في معنى: <q>﴿ولَقَدْ جَعَلْنا فِي السَّماءِ بُرُوجًا﴾</q> سوى قول مجاهد، وقتادة. وعلَّق ابنُ كثير (٨/٢٤٨) على قولهما بقوله: «وهذا كقوله تبارك وتعالى: <q>﴿تَبارَكَ الَّذِي جَعَلَ فِي السَّماءِ بُرُوجًا وجَعَلَ فِيها سِراجًا وقَمَرًا مُنِيرًا﴾</q> [الفرقان:٦١]». ٤٠٢٠٠- عن عطية العوفي، <q>﴿ولقد جعلنا في السماء بروجًا﴾</q>، قال: قصورًا في السماء، فيها الحَرَس{3}. (٨/٥٩٦) ٤٠٢٠١- عن أبي صالح باذام، في قوله: <q>﴿ولقد جعلنا في السماء بروجًا﴾</q>، قال: الكواكِب العِظام{3}. (٨/٥٩٦) ٤٠٢٠٢- عن قتادة بن دعامة-من طريق مَعْمَر- <q>﴿ولقد جعلنا في السماء بروجًا﴾</q>، قال: الكواكِب{5}. (٨/٥٩٦) ٤٠٢٠٣- قال مقاتل بن سليمان: <q>﴿ولقد جعلنا في السماء بروجا﴾</q> قال: الكواكب، <q>﴿وزيناها﴾</q> يعني: السماء بالكواكب <q>﴿للناظرين﴾</q> إليها، يعني: أهل الأرض{6}. (ز) ",footnotes:1:أخرجه مقاتل بن سليمان ٢/٤٢٦.أخرجه ابن جرير ١٤/٣٠-٣١. وعزاه السيوطي إلى ابن أبي شيبة، وابن المنذر.عزاه السيوطي إلى ابن أبي حاتم.عزاه السيوطي إلى ابن أبي حاتم.أخرجه ابن جرير ١٤/٣١. وعزاه السيوطي إلى ابن أبي حاتم. كما أخرجه ابن جرير من طريق سعيد بلفظ: بروجها: نجومها.تفسير مقاتل بن سليمان ٢/٤٢٦.
15,17," <q>﴿وَحَفِظۡنَـٰهَا مِن كُلِّ شَیۡطَـٰنࣲ رَّجِیمٍ ۝١٧﴾</q> - تفسير ٤٠٢٠٤- عن قتادة بن دعامة، في قوله: <q>﴿وحفِظناها من كل شيطان رجيم﴾</q>، قال: الرَّجيم: الملعون{1}. (٨/٥٩٦) ٤٠٢٠٥- قال مقاتل بن سليمان: <q>﴿وحفظناها﴾</q> يعني: السماءَ بالكواكب <q>﴿من كل شيطان رجيم﴾</q> يعني: ملعون؛ لِئَلّا يستمعوا إلى كلام الملائكة{2}. (ز) ٤٠٢٠٦- عن عبد الملك ابن جُرَيْج -من طريق حجاج- <q>﴿من كل شيطان رجيم﴾</q>، قال: الرجيم: الملعون{3}. (ز) ٤٠٢٠٧- عن الكسائي -من طريق القاسم- أنّه قال: الرجم في جميع القرآن: الشَّتْم{3}. (ز) ",footnotes:1:عزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.تفسير مقاتل بن سليمان ٢/٤٢٦.أخرجه ابن جرير ١٤/٣٣.أخرجه ابن جرير ١٤/٣٣.
15,18," <q>﴿إِلَّا مَنِ ٱسۡتَرَقَ ٱلسَّمۡعَ فَأَتۡبَعَهُۥ شِهَابࣱ مُّبِینࣱ ۝١٨﴾</q> - تفسير ٤٠٢٠٨- عن عبد الله بن عباس -من طريق العوفي- في قوله: <q>﴿إلّا من استرق السمع﴾</q>: فأراد أن يَخطِفَ السمع، كقوله: <q>﴿إلّا من خَطِفَ الخَطفَة﴾</q> [الصافات:١٠]{1}. (٨/٥٩٧) ٤٠٢٠٩- عن عبد الله بن عباس -من طريق سعيد بن جبير- قال: تصعد الشياطين أفواجًا تَسْتَرِقُ السمع. قال: فينفرد المارد منها، فيعلو، فيُرْمى بالشهاب، فيصيب جبهته أو جنبه، أو حيث شاء الله منه، فيلتهب، فيأتي أصحابُه وهو يلتهب، فيقول: إنّه كان مِن الأمر كذا وكذا. قال: فيذهب أولئك إلى إخوانهم مِن الكَهَنَة، فيزيدون عليه أضعافَه مِن الكذب، فيخبرونهم به، فإذا رأوا شيئًا مِمّا قالوا قد كان صدَّقوهم بما جاءوهم به مِن الكذب{2}. (ز) ٤٠٢١٠- عن الضحاك بن مزاحم -من طريق عبيد بن سليمان- في قوله: <q>﴿إلّا من استرق السمع﴾</q>، قال: هو كقوله: <q>﴿إلا من خطف الخطفة فأتبعه شهاب ثاقب﴾</q> [الصافات:١٠]. قال: كان [عبد الله] بن عباس يقول: إنّ الشُّهُبَ لا تقتل، ولكن تُحرِقُ وتخبِّلُ وتَجرَحُ، مِن غير أن تقتل{3}٣٥٩٥. (٨/٥٩٧) ٣٥٩٥ نقل ابنُ عطية (٥/٢٧٩) عن الحسن: أن الشُّهُب تقتل. ٤٠٢١١- عن قتادة بن دعامة-من طريق سعيد-: قوله: <q>﴿إلا من استرق السمع﴾</q> وهو نحو قوله: <q>﴿إلا من خطف الخطفة فأتبعه شهاب ثاقب﴾</q>{4}. (ز) ٤٠٢١٢- عن عبد الملك ابن جُرَيج -من طريق حجاج- قوله: <q>﴿إلا من استرق السمع﴾</q>، قال: خطِف الخَطْفَة{4}. (ز) ٤٠٢١٣- قال مقاتل بن سليمان: ثم استثنى مِن الشياطين، فقال سبحانه: <q>﴿إلا من استرق السمع﴾</q> يعني: مَنِ اختطف السمع مِن كلام الملائكة <q>﴿فأتبعه شهاب مبين﴾</q> يعني: الكوكب المضيء، وهو الثاقب، ونظيرها في الصافات [١٠]: <q>﴿فأتبعه شهاب ثاقب﴾</q> يعني: مُضِيء{6}. (ز) <q>﴿إِلَّا مَنِ ٱسۡتَرَقَ ٱلسَّمۡعَ فَأَتۡبَعَهُۥ شِهَابࣱ مُّبِینࣱ ۝١٨﴾</q> - آثار متعلقة بالآية ٤٠٢١٤- عن ابن مسعود، قال: قال جرير بن عبد الله: حَدِّثني -يا رسول الله- عن السماء الدنيا، والأرض السُّفلى. قال رسول الله ﷺ: «أمّا السماء الدنيا فإنّ الله خلقها مِن دخان، فأتمَّ رَتْقَها، وجعل فيها سراجًا وقمرًا منيرًا، وزيَّنها بمصابيح النجوم، وجعلها رُجُومًا للشياطين، وحفِظها من كل شيطان رجيم»{7}. (٨/٥٩٧) ٤٠٢١٥- قال عبد الله بن عباس: كانت الشياطين لا يُحْجَبُون عن السموات، وكانوا يدخلونها، ويأتون بأخبارها، فيلقون على الكهنة، فلما وُلِد عيسى ﵇ مُنِعوا من ثلاث سموات، فلمّا وُلِد محمد ﷺ مُنِعُوا مِن السموات أجمع، فما منهم مِن أحد يريد استراق السمع إلا رُمِي بشهاب، فلمّا مُنِعوا مِن تلك المقاعد ذكروا ذلك لإبليس، فقال: لقد حَدَث في الأرض حَدَثٌ. قال: فبعثهم، فوجدوا رسول الله ﷺ يتلو القرآنَ، فقالوا: هذا -واللهِ- ما حَدَثَ{8}. (ز) ",footnotes:1:أخرجه ابن جرير ١٤/٣٢. وعزاه السيوطي إلى ابن أبي حاتم.أخرجه ابن جرير ١٤/٣٢.أخرجه ابن جرير ١٤/٣٣. وعزاه السيوطي إلى ابن أبي حاتم.أخرجه ابن جرير ١٤/٣٣.أخرجه ابن جرير ١٤/٣٣.تفسير مقاتل بن سليمان ٢/٤٢٦.أورده ابن عساكر في تاريخه ٧٢/٧٨. وعزاه السيوطي إلى ابن مردويه.تفسير الثعلبي ٥/٣٣٣، وتفسير البغوي ٤/٣٧٢.
15,19," <q>﴿وَٱلۡأَرۡضَ مَدَدۡنَـٰهَا وَأَلۡقَیۡنَا فِیهَا رَوَ ٰ⁠سِیَ﴾</q> - تفسير ٤٠٢١٦- عن قتادة بن دعامة-من طريق سعيد- في قوله: <q>﴿والأرض مددناها﴾</q>، قال: قال ﷿ في آية أخرى: <q>﴿والأرض بعد ذلك دحاها﴾</q> [النازعات:٣٠]. قال: ذُكر لنا: أنّ أمَّ القُرى مكة، ومنها دُحِيت الأرض.= (ز) ٤٠٢١٧- قال قتادة: وكان الحسن [البصري] يقول: أخَذ طِينةً، فقال لها: انبَسِطي. وفي قوله: <q>﴿وألقينا فيها رواسي﴾</q>، قال: رواسيها: جِبالُها{1}. (٨/٥٩٧) ٤٠٢١٨- قال مقاتل بن سليمان: <q>﴿والأرض مددناها﴾</q> يعني: بسطناها، يعني: مسيرة خمسمائة عام طولها، وعرضها وغلظها مثله، فبسطها مِن تحت الكعبة، ثم قال ﷿: <q>﴿وألقينا فيها رواسي﴾</q> يعني: الجبال الراسيات في الأرض الطِّوال <q>﴿أنْ تَمِيدَ بِكُمْ﴾</q> [النحل:١٥، ولقمان:١٠] يقول: لِئَلّا تزول بكم الأرض وتمور بِمَن عليها{2}. (ز) <q>﴿وَأَنۢبَتۡنَا فِیهَا مِن كُلِّ شَیۡءࣲ مَّوۡزُونࣲ ۝١٩﴾</q> - تفسير ٤٠٢١٩- عن عبد الله بن عباس -من طريق علي، والعوفي- في قوله: <q>﴿وأنبتنا فيها من كل شيء موزون﴾</q>، قال: مَعْلوم{3}. (٨/٥٩٧) ٤٠٢٢٠- عن عبد الله بن عباس، في قوله: <q>﴿من كل شيء موزون﴾</q>، قال: مُقَدَّرٍ{4}. (٨/٥٩٨) ٤٠٢٢١- عن سعيد بن جبير -من طريق حصين- <q>﴿من كل شيء موزون﴾</q>، قال: معلوم{5}. (ز) ٤٠٢٢٢- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿من كل شيء موزون﴾</q>، قال: مُقَدَّرٍ بقَدَر{6}. (٨/٥٩٨) ٤٠٢٢٣- عن الضحاك بن مزاحم -من طريق عبيد بن سليمان- في قوله: <q>﴿من كل شيء موزون﴾</q>، قال: معلوم{7}. (ز) ٤٠٢٢٤- عن عكرمة مولى ابن عباس -من طريق خُصَيْف- <q>﴿من كل شيء موزون﴾</q>، قال: بِقَدَر{8}. (ز) ٤٠٢٢٥- عن عكرمة مولى ابن عباس، في قوله: <q>﴿من كل شيء موزون﴾</q>، قال: ما أنبتت الجبال مثل الكُحْلِ وشبهِه{9}. (٨/٥٩٨) ٤٠٢٢٦- عن أبي صالح باذام، أو عن أبي مالك غزوان الغفاري -من طريق هشيم، عن إسماعيل بن أبي خالد- في قوله: <q>﴿من كل شيء موزون﴾</q>، قال: بقَدَر{10}. (ز) ٤٠٢٢٧- عن الحكم بن عتيبة -من طريق عبد الله بن يونس- أنّه سُئِل عن قوله: <q>﴿من كل شيء موزون﴾</q>. قال: مِن كل شيء مقدور{11}. (ز) ٤٠٢٢٨- عن قتادة بن دعامة-من طريق سعيد- في قوله: <q>﴿وأنبتنا فيها من كل شيء موزون﴾</q>، يقول: معلوم مَقْسُوم{12}. (٨/٥٩٧) ٤٠٢٢٩- قال مقاتل بن سليمان: <q>﴿وأنبتنا فيها من كل شيء موزون﴾</q>، يقول: وأخرجنا مِن الأرض كُلَّ شيء موزون، يعني: مِن كل ألوان النبات معلوم{2}. (ز) ٤٠٢٣٠- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿من كل شيء موزون﴾</q>، قال: الأشياء التي تُوزَن{14}٣٥٩٦. (٨/٥٩٨) ٣٥٩٦ اختُلِف في معنى: <q>﴿وأَنْبَتْنا فِيها مِن كُلِّ شَيْءٍ مَوْزُونٍ﴾</q> في هذه الآية على قولين: الأول: مِن كل شيء بِقَدَر مقدَّر، وبحدٍّ معلوم. الثاني: عنى به الشيء الذي يوزن كالذهب، والفضة. ورجَّح ابنُ جرير (١٤/٣٧) مستندًا إلى الإجماع القول الأول، وهو قول ابن عباس وما في معناه، وعلَّل ذلك بقوله: «لإجماع الحُجَّة مِن أهل التأويل عليه». ووجَّه ابنُ عطية (٥/٢٨٠) القول الأول بقوله: «فالوزن على هذا مستعار». ثم رجَّحه قائلًا: «والأول أعَمُّ وأحسن». ولم يذكر مستندًا. ",footnotes:1:أخرجه ابن جرير ١٤/٣٣-٣٤ دون قول الحسن. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.تفسير مقاتل بن سليمان ٢/٤٢٦.أخرجه ابن جرير ١٤/٣٤. وعزاه السيوطي إلى ابن المنذر.عزاه السيوطي إلى ابن أبي حاتم.أخرجه ابن جرير ١٤/٣٥.أخرجه ابن جرير ١٤/٣٥-٣٦. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.أخرجه ابن جرير ١٤/٣٦.أخرجه الثوري في تفسيره ص١٥٩، وابن جرير ١٤/٣٤.عزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.أخرجه ابن جرير ١٤/٣٤. كما أخرجه ١٤/٣٦ من طريق يحيى بن زكريا، عن إسماعيل، عن أبي صالح دون شك.أخرجه ابن جرير ١٤/٣٤.أخرجه ابن جرير ١٤/٣٦. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.تفسير مقاتل بن سليمان ٢/٤٢٦.أخرجه ابن جرير ١٤/٣٦-٣٧. وعزاه السيوطي إلى ابن أبي حاتم.
15,20," <q>﴿وَجَعَلۡنَا لَكُمۡ فِیهَا مَعَـٰیِشَ وَمَن لَّسۡتُمۡ لَهُۥ بِرَ ٰ⁠زِقِینَ ۝٢٠﴾</q> - تفسير ٤٠٢٣١- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿ومن لستم له برازقين﴾</q>، قال: الدوابّ والأنعام{1}. (٨/٥٩٩) ٤٠٢٣٢- عن منصور [بن المعتمر] -من طريق شعبة- في قوله: <q>﴿ومن لستم له برازقين﴾</q>، قال: الوَحْش{2}. (٨/٥٩٩) ٤٠٢٣٣- قال مقاتل بن سليمان: <q>﴿وجعلنا لكم فيها﴾</q> يعني: في الأرض <q>﴿معايش﴾</q> مِمّا عليها مِن النبات. ثُمَّ قال سبحانه: <q>﴿ومن لستم له برازقين﴾</q> يقول: لستم أنتم ترزقونهم، ولكن أنا أرزقهم -يعني: الدواب، والطير- معايشهم مِمّا في الأرض مِن رِزْقِي{3}٣٥٩٧. (ز) ٣٥٩٧ اختُلِف في معنى: <q>﴿ومَن لَسْتُمْ لَهُ بِرازِقِينَ﴾</q> في هذه الآية على قولين: الأول: أنّه الدوابُّ والأنعام. الثاني: أنه الوحْش. ووجَّه ابنُ جرير (١٤/٣٨) القول الثاني بقوله: «فتأويل <q>﴿ومَن﴾</q> في: <q>﴿ومَن لَسْتُمْ لَهُ بِرازِقِينَ﴾</q> على هذا التأويل بمعنى: ما، وذلك قليلٌ في كلام العرب». ورجَّح مستندًا إلى الأكثر لغة «أن يقال: عنى بقوله: <q>﴿ومَن لَسْتُمْ لَهُ بِرازِقِينَ﴾</q> من العبيد والإماء والدواب والأنعام، فمعنى ذلك: وجعلنا لكم فيها معايش والعبيد والإماء والدواب والأنعام». ثم ذكر (١٤/٣٨-٣٩) احتمالين لموضع <q>﴿ومَن﴾</q>: الأول: أنّها في موضع نصبٍ عطفًا به على <q>﴿مَعايِشَ﴾</q> بمعنى: جعلنا لكم فيها معايش، وجعلنا لكم فيها مَن لستم له برازقين، وعليه بنى المعنى الذي رجَّحه. ووجَّه ابنُ عطية (٥/٢٨١) هذا الاحتمال بقوله: «كأنّ الله تعالى عدَّد النِّعم في المعايش، وهي ما يُؤكَل ويُلبَس، ثم عدَّد النعم في الحيوان والعبيد والضِّياع وغير ذلك مما ينتفع به الناس وليس عليهم رزقهم». ثم زاد وجهَيْن آخرَيْن لموضع النصب: أحدهما: «أن تكون»مَن«معطوفة على موضع الضمير في <q>﴿لَكُمْ﴾</q>، وذلك أن التقدير: وأَعَشْناكم وأَعَشْنا أُمَمًا غيركم من الحيوان». ثم وجَّهه بقوله: «وكأنّ الآية -على هذا- فيها اعتبار وعرض آية». والآخر: «أن تكون»مَن«منصوبة بإضمار فعل يقتضيه الظاهر، وتقديره: وأَعَشْنا مَن لَسْتُم له برازقين». الثاني: أنها في موضع خفض عطفًا به على الكاف والميم في قوله: <q>﴿وجَعَلْنا لَكُمْ﴾</q>، بمعنى: وجعلنا لكم فيها معايش ولمن لستم له برازقين. وبنى ابنُ جرير (١٤/٣٩) عليه توجيهه للقول الثاني بقوله: «وأحسب أنّ منصورًا في قوله: هو الوحش. قصد هذا المعنى، وإيّاه أراد». ثم انتقده مستندًا إلى الأغلب في لغة العرب قائلًا: «وذلك وإن كان له وجْهٌ في كلام العرب، فبعيدٌ قليلٌ؛ لأنها لا تكاد تظاهر على معنًى في حال الخفض، وربما جاء في شعر بعضهم في حال الضرورة». وكذا ابنُ عطية، فقال: «وهذا قلق في النحو؛ لأنّه عطف على الضمير المجرور، وفيه قُبْح، فكأنه قال: ومَن لَسْتُم له برازقين وأنتم تنتفعون به». ",footnotes:1:أخرجه ابن جرير ١٤/٣٧. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.أخرجه ابن جرير ١٤/٣٨. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.تفسير مقاتل بن سليمان ٢/٤٢٦-٤٢٧.
15,21," <q>﴿وَإِن مِّن شَیۡءٍ إِلَّا عِندَنَا خَزَاۤىِٕنُهُۥ وَمَا نُنَزِّلُهُۥۤ إِلَّا بِقَدَرࣲ مَّعۡلُومࣲ ۝٢١﴾</q> - تفسير ٤٠٢٣٤- عن أبي هريرة، قال: قال رسول الله ﷺ: «خزائِنُ الله الكلام، فإذا أراد شيئًا قال له: كن. فكان»{1}. (٨/٥٩٩) ٤٠٢٣٥- عن عبد الله بن مسعود، قال: قال رسول الله ﷺ: «ما مِن عامٍ بأمْطَرَ مِن عام، ولكنَّ الله يُصَرِّفه حيث يشاء مِن البلدان، وما نزلت قطرة مِن السماء ولا خرجت مِن ريح إلا بمكيال أو بميزان»{2}. (٨/٦٠٠) ٤٠٢٣٦- عن عبد الله بن مسعود، عن النبي ﷺ، قال: «ليس أحدٌ بأَكْسَبَ مِن أحد، ولا عامٌ بأَمْطَر مِن عام، ولكنَّ الله يصرِفُه حيث يشاء»{3}. (٨/٦٠٠) ٤٠٢٣٧- عن عبد الله بن مسعود -من طريق جرير، عن يزيد بن أبي زياد، عن أبي جحيفة- قال: ما من عام بأمْطَرَ مِن عام، ولكن الله يصرِفُه حيث يشاء. ثم قرأ: <q>﴿وإن من شيء إلا عندنا خزائنه وما ننزله إلا بقدر معلوم﴾</q>{4}. (٨/٦٠٠) ٤٠٢٣٨- عن أبي هريرة، قال: ما نزل قَطْرٌ إلا بميزان{5}. (٨/٦٠١) ٤٠٢٣٩- عن عبد الله بن عباس، قال: ما نَقَصَ المطرُ منذ أنزله اللهُ، ولكن تُمْطِرُ أرضٌ أكثرَ مِمّا تُمْطِرُ الأخرى. ثم قرأ: <q>﴿وما ننزله إلا بقدر معلوم﴾</q>{6}. (٨/٦٠٠) ٤٠٢٤٠- عن مجاهد بن جبر، في قوله: <q>﴿وما نُنَزِّلُهُ إلّا بقدر معلوم﴾</q>، قال: المَطَر{7}. (٨/٥٩٩) ٤٠٢٤١- عن الحكم بن عُتَيْبَة -من طريق إسماعيل بن سالم- في قوله: <q>﴿وإن من شيء إلا عندنا خزائنه وما ننزله إلا بقدر معلوم﴾</q>، قال: ما مِن عام بأكثرَ مطرًا مِن عام ولا أقل، ولكنه يُمْطَرُ قومٌ ويُحرَمُ آخرون، وربما كان في البحر. قال: وبلغنا: أنّه ينزل مع المطر مِن الملائكة أكثرُ مِن عدد ولد إبليس وولد آدم، يُحْصُون كلَّ قطرة حيث تقع، وما تُنبِت، ومن يُرزَق ذلك النبات{8}. (٨/٥٩٩) ٤٠٢٤٢- عن [علي بن الحسين بن علي] -من طريق جعفر بن محمد بن علي، عن أبيه- قال: في العرش مثالُ جميع ما خلق الله في البرِّ والبحر، وهو تأويل قوله تعالى: <q>﴿وإن من شيء إلا عندنا خزائنه﴾</q>{9}. (ز) ٤٠٢٤٣- قال مقاتل بن سليمان: <q>﴿وإن من شيء إلا عندنا خزائنه﴾</q> يقول: ما مِن شيء مِن الرزق إلا عندنا مفاتيحه، وهو بأيدينا ليس بأيديكم، <q>﴿وما ننزله﴾</q> يعني: الرزق، وهو المطر وحده <q>﴿إلا بقدر معلوم﴾</q> يعني: مَوْقُوت{10}. (ز) ٤٠٢٤٤- عن عبد الملك ابن جُرَيْج -من طريق حجّاج- في قوله: <q>﴿وإن من شيء إلّا عندنا خزائنه﴾</q>، قال: المطر خاصَّة{11}٣٥٩٨. (٨/٥٩٩) ٣٥٩٨ استدرك ابنُ عطية (٥/٢٨١) على قول ابن جريج بقوله: «وينبغي أن يكون أعمَّ مِن هذا في كثيرٍ من المخلوقات». <q>﴿وَإِن مِّن شَیۡءٍ إِلَّا عِندَنَا خَزَاۤىِٕنُهُۥ وَمَا نُنَزِّلُهُۥۤ إِلَّا بِقَدَرࣲ مَّعۡلُومࣲ ۝٢١﴾</q> - آثار متعلقة بالآية ٤٠٢٤٥- عن معاوية، قال: ألستم تعلمون أنّ كتاب الله حقٌّ؟ قالوا: بلى. قال: فاقرءوا هذه الآية: <q>﴿وإن من شيء إلا عندنا خزائنه وما ننزله إلا بقدر معلوم﴾</q>، ألستم تؤمنون بهذا وتعلمون أنّه حق؟ قالوا: بلى. قال: فكيف تلومونني بعد هذا؟! فقام الأحنف فقال: يا معاوية، واللهِ، ما نَلُومُك على ما في خزائن الله، ولكن إنّما نلومك على ما أنزل الله مِن خزائنه، فجعلته أنت في خزائنك، وأغلقت عليه بابك. فسكت معاوية{5}. (٨/٦٠١) ",footnotes:1:أخرجه البزار ١٧/٣١٤ (١٠٠٨١)، وأبو الشيخ في العظمة ٢/٤٨٨. قال البزار بعد ذكره هذا الحديث وحديثًا آخر: «ولا نعلم روى هذين الحديثين عن هشام إلا أغلب، ولا نعلم رواهما عن أغلب إلا ابنه، والأغلب لم يكن بالقوي، وقد حدث عنه غير واحد من المتقدمين». وقال ابن رجب في جامع العلوم ٢/٥١: «إسناد فيه نظر». وقال الألباني في الضعيفة ٨/٢٦٨ (٣٧٩٦): «ضعيف جدًّا».عزاه السيوطي إلى ابن مردويه.أخرجه ابن حبان في الثقات ٨/٤٦٢، وأبو نعيم في الحلية ٧/٢٠٨. قال العقيلي في الضعفاء الكبير ٣/٢٢٨-٢٢٩ (١٢٢٩) في ترجمة علي بن حميد السلولي عن شعبة: «ولا يتابع على رفع حديثه .. -ثم أخرجه موقوفًا- عن عمرو بن مرزوق، حدثنا شعبة به، وهو أولى». وقال أبو نعيم: «تفرد به علي بن حميد». وقال ابن حجر في لسان الميزان ٤/٢٢٧ (٥٩٩): «الحديث غريب جدًّا ... وهو معروف من كلام عبد الله موقوف». وقال الألباني في الضعيفة ١٢/٥٩٥ (٥٧٧٢): «منكر».أخرجه ابن جرير ١٤/٤٠. وعزاه السيوطي إلى ابن المنذر، وابن مردويه. وأخرجه ابن أبي الدنيا في كتاب المطر والرعد والبرق والريح -موسوعة الإمام ابن أبي الدنيا ٨/٤٣٢ (٧٦)-، وفيه بلفظ: ولكن الله يصرفه عمن يشاء. كما أخرجه ابن جرير ١٤/٣٩-٤٠ من طريق علي بن مسهر عن يزيد بن أبي زياد عن أبي جحيفة بلفظ: ولكن الله يقسمه حيث شاء، عامًا ههنا، وعامًا ههنا.عزاه السيوطي إلى ابن أبي حاتم.عزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.عزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ١٤/٤٠-٤١، وأبو الشيخ في العظمة (٤٩٥). وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم. وأخرج آخره ابن أبي الدنيا في كتاب المطر والرعد والبرق والريح -موسوعة الإمام ابن أبي الدنيا ٨/٤١٧ (١٠)-.تفسير الثعلبي ٥/٣٣٦، وتفسير البغوي ٤/٣٧٥.تفسير مقاتل بن سليمان ٢/٤٢٧.أخرجه ابن جرير ١٤/٤٠.عزاه السيوطي إلى ابن أبي حاتم.
15,22," <q>﴿وَأَرۡسَلۡنَا ٱلرِّیَـٰحَ لَوَ ٰ⁠قِحَ فَأَنزَلۡنَا مِنَ ٱلسَّمَاۤءِ مَاۤءࣰ فَأَسۡقَیۡنَـٰكُمُوهُ وَمَاۤ أَنتُمۡ لَهُۥ بِخَـٰزِنِینَ ۝٢٢﴾</q> - تفسير ٤٠٢٤٦- عن أبي هريرة، قال: سمعتُ رسول الله ﷺ يقول: «رِيح الجنوبِ مِن الجنة، وهي الرِّيح اللَّواقِح التي ذكر الله في كتابه، وفيها منافع للناس، والشمال مِن النار، تخرُجُ فتَمُرُّ بالجنة فيُصِيبُها نَفْحَةٌ منها، فبَردُها هذا من ذلك»{1}. (٨/٦٠١) ٤٠٢٤٧- عن قتادة، قال: قال رسول الله ﷺ: «نُصِرتُ بالصَّبا، وأُهلِكَت عادٌ بالدَّبُور، والجنوب مِن الجنة، وهي الريح اللَّواقِح»{2}. (٨/٦٠٢) ٤٠٢٤٨- عن عبد الله بن مسعود -من طريق قيس بن سكَن- في قوله: <q>﴿وأرسلنا الرياح لواقح﴾</q>، قال: يُرْسِلُ الله الريحَ، فتحمِل الماءَ، فتُلقِحُ به السحاب، فيُدِرُّ كما تُدِرُّ اللَّقحَةُ{3}، ثم تُمْطِر{4}. (٨/٦٠٢) ٤٠٢٤٩- عن عبد الله بن عباس -من طريق عكرمة- قال: ما هبَّتْ ريحٌ قطُّ إلا جثا النبيُّ ﷺ على ركبتيه، وقال: «اللَّهُمَّ، اجعلها رحمةً، ولا تجعلها عذابًا، اللهم، اجعلها رياحًا، ولا تجعلها ريحًا». قال ابن عباس: في كتاب الله ﷿: <q>﴿إنا أرسلنا عليهم ريحا صرصرا﴾</q> [القمر:١٩]، <q>﴿إذ أرسلنا عليهم الريح العقيم﴾</q> [الذاريات:٤١]، وقال: <q>﴿وأرسلنا الرياح لواقح﴾</q> [الحجر:٢٢]، وقال: <q>﴿أن يرسل الرياح مبشرات﴾</q> [الروم:٤١]{5}. (ز) ٤٠٢٥٠- عن عبد الله بن عباس -من طريق سعيد بن جبير- قال: يُرْسِلُ الله الريحَ، فتحمل الماءَ مِن السحاب، فتَمرِيه{6} السحابُ، فيُدِرُّ كما تُدِرُّ اللَّقحَةُ{7}. (٨/٦٠٢) ٤٠٢٥١- عن عبد الله بن عباس -من طريق ابن جريج- في قوله: <q>﴿وأرسلنا الرياح لواقح﴾</q>، قال: تُلقِحُ الشجر، وتَمرِي السَّحاب{8}. (٨/٦٠٢) ٤٠٢٥٢- عن عبيد بن عمير-من طريق حبيب بن أبي ثابت- قال: يبعث اللهُ المُبَشِّرَةَ، فتَقُمُّ الأرض قمًّا، ثم يبعث المُثيرَة، فتثير السحاب فتجعله كِسَفًا، ثم يبعث المُؤَلِّفَة، فتُؤلف بينه فتجعله ركامًا، ثم يبعث اللَّواقح، فتُلقِحُه فتُمطر. ثم تلا عبيد: <q>﴿وأرسلنا الرياح لواقح﴾</q>{9}. (٨/٦٠٣) ٤٠٢٥٣- عن إبراهيم النخعي -من طريق الأعمش- في قوله: <q>﴿لواقح﴾</q>، قال: تُلقِح السحابَ، فتجمعه{10}. (٨/٦٠٤) ٤٠٢٥٤- عن الضَّحّاك بن مُزاحِم -من طريق عبيد بن سليمان- في قوله: <q>﴿وأرسلنا الرياح لواقح﴾</q>، قال: الرِّياح يبعثُها اللهُ على السحاب، فتُلقِحُه، فيَمْتَلِئُ ماءً{11}. (٨/٦٠٣) ٤٠٢٥٥- عن أبي رجاء، قال: قلتُ للحسن [البصري]: <q>﴿وأرسلنا الرياح لواقح﴾</q>. قال: لواقح للشجر. قلت: أو للسحاب؟ قال: وللسحاب، تمرِيه حتى يُمطِر{12}. (٨/٦٠٢) ٤٠٢٥٦- عن قتادة بن دعامة-من طريق سعيد- قوله: <q>﴿وأرسلنا الرياح لواقح﴾</q>، يقول: لواقح للسَّحاب، وإنّ مِن الريح عذابًا، وإنّ منها رحمة{13}. (ز) ٤٠٢٥٧- عن قتادة بن دعامة-من طريق مَعْمَر- في قوله: <q>﴿وأرسلنا الرياح لواقح﴾</q>، قال: تُلقِحُ الماء في السحاب{14}. (٨/٦٠٢) ٤٠٢٥٨- قال مَعْمَر: وقاله محمد بن السائب الكلبي أيضًا{15}. (ز) ٤٠٢٥٩- عن عطاء الخراساني، قال: الرياح اللواقح تخرج مِن تحت صخرة بيت المقدس{16}. (٨/٦٠٣) ٤٠٢٦٠- قال مقاتل بن سليمان: <q>﴿وأرسلنا الرياح لواقح﴾</q> وذلك أنّ الله يرسل الريح، فتأخذ الماء بكيلٍ معلوم مِن سماء الدنيا، ثم تثير الرياح والسحاب، فتلقي الريحُ السحابَ بالماء الذي فيها مِن ماء النبت، ثم تسوق تلك الرياحُ السحابَ إلى الأرض التي أُمِر الرعد أن يمطرها، فذلك قوله سبحانه: <q>﴿فأنزلنا من السماء ماء﴾</q> يعني: المطر <q>﴿فأسقيناكموه﴾</q>{17}٣٥٩٩. (ز) ٣٥٩٩ اختلف في وجْه وصف الرياح بأنها <q>﴿لواقح﴾</q> في هذه الآية على قولين: الأول: أنها لواقح بمعنى: لاقِحة مُلْقِحَة. الثاني: أنها لواقح بمعنى: مُلْقِحة. ورجَّح ابنُ جرير (١٤/٤٣) مستندًا إلى أقوال السلف القول الأول، وهو قول ابن مسعود وما في معناه، فقال: «والصوابُ مِن القول في ذلك عندي: أنّ الرياح لواقح كما وصفها به -جلَّ ثناؤه- مِن صفتها، وإن كانت قد تُلْقِحُ السحاب والأشجار، فهي لاقِحَةٌ مُلْقِحَةٌ، ولَقْحُها حَمْلُها الماء، وإلقاحُها السحابَ والشجرَ عملُها فيه، وذلك كما قال عبد الله بن مسعود». ونقل ابنُ عطية (٥/٢٨٢) في معنى الآية أنه «يُقال: لقحت الناقة والشجرة فهي لاقحة إذا حملت، والرياح تلقح الشجر والسحاب، فالوجْه في الريح أنها مُلَقِّحَة لا لاقحة». ثم ذكر أن صفة الريح بـ<q>﴿لواقح﴾</q> تتَّجه على أربعة أوجه: الأول ورجَّحه مستندًا إلى الدلالة العقلية، فقال: «أوَّلها وأَوْلاها: أن جعلها لاقحة حقيقة، وذلك أنّ الريح منها ما فيها عذاب أو ضر أو نار، ومنها ما فيه رحمة أو مطر أو نصر أو غير ذلك، فإذًا هي تحمل ما حمَّلَتها القدرة، أو ما علقته من الهواء أو التراب أو الماء الذي مرت عليه، فهي لاقحة بهذا الوجه، وإن كانت أيضًا تلقح غيرها وتصير إليه نفعها، والعرب تسمي الجنوب الحامل واللاقحة، وتسمي الشمال الحايل والعقيم ومَحْوة؛ لأنها تمحو السحاب». الثاني: «أن يكون وصفها بـ<q>﴿لَواقِحَ﴾</q> من باب قولهم: ليل نائم. أي: فيه نوم ومعه. ويوم عاصف. ونحوه». وعلَّق عليه بقوله: «فهذا على طريق المجاز». الثالث: «أن تُوصَف الرياح بـ<q>﴿لَواقِحَ﴾</q> على جهة النسب، أي: ذات لقح». واستشهد ببيت من الشعر. الرابع: «أن يكون <q>﴿لَواقِحَ﴾</q> جمع: ملقحة. على حذف زوائده، فكأنه»لَقِحَة«، فجمعها كما تجمع لاقحة»، واستشهد ببيت من الشعر. ٤٠٢٦١- قال أبو بكر بن عياش: لا تقطر قطرةٌ مِن السحاب إلا بعد أن تعمل الرياحُ الأربعُ فيه، فالصبا تهيجه، والشمال تجمعه، والجنوب تَذَرُه، والدَّبُور تُفَرِّقه{18}. (ز) <q>﴿وَأَرۡسَلۡنَا ٱلرِّیَـٰحَ لَوَ ٰ⁠قِحَ فَأَنزَلۡنَا مِنَ ٱلسَّمَاۤءِ مَاۤءࣰ فَأَسۡقَیۡنَـٰكُمُوهُ وَمَاۤ أَنتُمۡ لَهُۥ بِخَـٰزِنِینَ ۝٢٢﴾</q> - آثار متعلقة بالآية ٤٠٢٦٢- عن سلمة بن الأكوع، قال: كان رسول الله ﷺ إذا اشتدَّت الريح يقول: «اللهم، لَقحًا، لا عقيمًا»{19}. (٨/٦٠٣) ٤٠٢٦٣- عن عبيد بن عمير، قال: الأوراح{20} أربعة: ريح تَقُمُّ، وريح تُثِير تجعلُه كِسَفًا، وريح تجعلُه رُكامًا، وريحٌ تُمْطِر{16}. (٨/٦٠٤) <q>﴿وَمَاۤ أَنتُمۡ لَهُۥ بِخَـٰزِنِینَ ۝٢٢﴾</q> - تفسير ٤٠٢٦٤- قال مقاتل بن سليمان: <q>﴿وما أنتم﴾</q> يعني: يا بني آدم <q>﴿له بخازنين﴾</q> يقول: لستم أنتم بخازنيها، فتكون مفاتيحها بأيديكم، ولكنَّها بيدي{17}. (ز) ٤٠٢٦٥- عن سفيان الثوري، في قوله: <q>﴿وما أنتم له بخازنين﴾</q>، قال: بمانِعين{23}. (٨/٦٠٤) ",footnotes:1:أخرجه ابن أبي الدنيا في كتاب المطر والرعد ص١٤٠ (١٣٧)، وأبو الشيخ في كتاب العظمة ٤/١٣٠٥-١٣٠٦، وابن جرير ١٤/٤٦. وأورده الثعلبي ٥/٣٣٧. قال ابن عدي في الكامل ٩/١٥٠ (٢١٦٤) في ترجمة يزيد بن سفيان أبي المهزم البهزي: «ولأبي المهزم عن أبي هريرة من الحديث غير ما ذكرت، وعامة ما يرويه ليس بمحفوظ». وقال ابن كثير في تفسيره ٤/٥٣١: «وهذا إسناد ضعيف». وقال السيوطي، والشوكاني في فتح القدير ٣/١٥٤: «بسند ضعيف». وقال الألباني في الضعيفة ٨/١٣٧ (٣٦٥٢): «ضعيف جدًّا».أخرجه ابن أبي الدنيا (١٣٦).اللّقْحَة -بكسر اللام وفتحها-: الناقة الحلوب الغزيرة اللبن. اللسان (لقح).أخرجه ابن جرير ١٤/٤٣، والطبراني (٩٠٨٠). وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم، والخرائطي في مكارم الأخلاق.أخرجه الطبراني في الدعوات الكبير ١/٤٨٠ (٣٦٩)، وأبو الشيخ في العظمة ٤/١٣٥١-١٣٥٢. وأثر ابن عباس أورده البغوي في تفسيره ٤/٣٧٦.مَرَت الرياحُ السحابَ: إذا أنزلت منه المطر. اللسان (مرا).أخرجه أبو الشيخ في العظمة (٧١٣). وعزاه السيوطي إلى ابن أبي حاتم.أخرجه ابن جرير ١٤/٤٥-٤٦. وعزاه السيوطي إلى أبي عبيد، وابن المنذر.أخرجه ابن جرير ١٤/٤٥، وأبو الشيخ في العظمة (٧١٩، ٨٣٠). وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.أخرجه أبو الشيخ (٨٥٥)، وابن جرير ١٤/٤٥ بنحوه.أخرجه ابن جرير ١٤/٤٦. وعزاه السيوطي إلى ابن أبي حاتم.أخرجه ابن جرير ١٤/٤٥، وأبو الشيخ (٨٥٦). وعزاه السيوطي إلى أبي عبيد، وابن المنذر، وابن أبي حاتم.أخرجه ابن جرير ١٤/٤٤.أخرجه عبد الرزاق في تفسيره ٢/٣٤٦، وابن جرير ١٤/٤٥.أخرجه عبد الرزاق في تفسيره ٢/٣٤٦.عزاه السيوطي إلى ابن المنذر.تفسير مقاتل بن سليمان ٢/٤٢٧.تفسير الثعلبي ٥/٣٣٧، وتفسير البغوي٤/٣٧٥ واللفظ له.أخرجه ابن حبان ٣/٢٨٨ (١٠٠٨)، والحاكم ٤/٣١٨ (٧٧٧٠). قال الحاكم: «هذا إسناد صحيح، على شرط الشيخين، ولم يخرجاه». ووافقه الذهبي في التلخيص. وقال النووي في المجموع ٥/٩٨: «رواه ابن السني بإسناد صحيح». وقال الهيثمي في المجمع ١٠/١٣٥ (١٧١٢٤):«رواه الطبراني في الكبير والأوسط، ورجاله رجال الصحيح غير المغيرة بن عبد الرحمن، وهو ثقة». وقال السيوطي في الشمائل الشريفة ص٨٣ (١٠٣): «صح». وأورده الألباني في الصحيحة ٥/٩٠-٩١ (٢٠٥٨) وقال: «قلت: فحسب حديث مثله أن يكون حسنًا، وأما الصحة فلا».الأرواح والرياح، جمع الريح، وجمعت بالواو لأن أصلها الواو، وإنما جاءت بالياء لانكسار ما قبلها، وإذا رجعوا إلى الفتح عادت إلى الواو، كقولك: أروح الماء. النهاية والتاج (روح).عزاه السيوطي إلى ابن المنذر.تفسير مقاتل بن سليمان ٢/٤٢٧.تفسير الثوري ص١٥٩، وأخرجه ابن جرير ١٤/٤٧ من طريق أبي أحمد. وعزاه السيوطي إلى ابن أبي حاتم.
15,23," <q>﴿وَإِنَّا لَنَحۡنُ نُحۡیِۦ وَنُمِیتُ وَنَحۡنُ ٱلۡوَ ٰ⁠رِثُونَ ۝٢٣﴾</q> - تفسير ٤٠٢٦٦- قال مقاتل بن سليمان: <q>﴿وإنا لنحن نحيي ونميت﴾</q> يقول الله تعالى: أنا أحيي الموتى، وأميت الأحياء، <q>﴿ونحن الوارثون﴾</q> يعني: ونُمِيت الخلق، ويبقى الربُّ تعالى، ويَرِثُهم{1}. (ز) ٤٠٢٦٧- عن سفيان [الثوري] في قوله: <q>﴿ونحن الوارثون﴾</q>، قال: الوارِثُ: الباقي{2}. (٨/٦٠٤) ",footnotes:1:تفسير مقاتل بن سليمان ٢/٤٢٧.عزاه السيوطي إلى ابن جرير، وابن أبي حاتم.
15,24," <q>﴿وَلَقَدۡ عَلِمۡنَا ٱلۡمُسۡتَقۡدِمِینَ مِنكُمۡ وَلَقَدۡ عَلِمۡنَا ٱلۡمُسۡتَـٔۡخِرِینَ ۝٢٤﴾</q> - نزول الآية ٤٠٢٦٨- عن سهل بن حُنيف الأنصاري -من طريق داود بن صالح- قال: أتدري فيمَ أُنزِلَت: <q>﴿ولقد علمنا المستقدمين منكم ولقد علمنا المستأخرين﴾</q>؟ قلت: في سبيل الله. قال: لا، ولكنَّها في صفوف الصلاة{1}. (٨/٦٠٦) ٤٠٢٦٩- عن عبد الله بن عباس -من طريق أبي الجوزاء- قال: كانت امرأة تُصَلِّي خلف رسول الله ﷺ، حسناء مِن أحسن الناس، فكان بعضُ القوم يتقدَّم حتى يكون في الصف الأول لِئَلّا يراها، ويستأخر بعضُهم حتى يكون في الصفِّ المُؤَخَّر، فإذا ركع نظر مِن تحت إبطيه؛ فأنزل الله: <q>﴿ولقد علمنا المستقدمين منكم ولقد علمنا المستأخرين﴾</q>{2}. (٨/٦٠٤) ٤٠٢٧٠- عن أبي الجوزاء أوْس بن عبد الله الرَّبَعِي -من طريق عمرو بن مالك- في قوله: <q>﴿ولقد علمنا المستقدمين منكم﴾</q>، قال: في الصُّفوف في الصلاة{3}. (٨/٦٠٥) ٤٠٢٧١- عن مروان بن الحكم -من طريق المعتمر بن سليمان، عن أبيه، عن رجل- أنّه قال: كان أناس يستأخرون في الصفوف مِن أجل النساء. قال: فأنزل الله: <q>﴿ولقد علمنا المستقدمين منكم، ولقد علمنا المستأخرين﴾</q>{4}. (٨/٦٠٦) ٤٠٢٧٢- قال الربيع بن أنس: حرَّض رسولُ الله ﷺ على الصفِّ الأول في الصلاة، فازدحم الناس عليه، وكان بنو عُذْرة دُورُهُم قاصِيَةٌ عن المسجد، فقالوا: نبيع دُورَنا، ونشتري دُورًا قريبة مِن المسجد. فأنزل الله تعالى هذه الآية{5}. (ز) <q>﴿وَلَقَدۡ عَلِمۡنَا ٱلۡمُسۡتَقۡدِمِینَ مِنكُمۡ وَلَقَدۡ عَلِمۡنَا ٱلۡمُسۡتَـٔۡخِرِینَ ۝٢٤﴾</q> - تفسير الآية ٤٠٢٧٣- عن عبد الله بن عباس -من طريق أبي الجوزاء- في الآية، قال: <q>﴿المستقدمين﴾</q>: الصفوف المُقَدَّمَة. و<q>﴿المستأخرين﴾</q>: الصفوف المُؤَخَّرة{6}. (٨/٦٠٥) ٤٠٢٧٤- عن عبد الله بن عباس -من طريق العوفي- في قوله: <q>﴿ولقد علمنا المستقدمين منكم ولقد علمنا المستئخرين﴾</q>، قال: يعني بالمستقدمين: مَن مات. وبالمستأخرين: مَن هو حَيٌّ لم يَمُتْ{7}. (٨/٦٠٩) ٤٠٢٧٥- عن عبد الله بن عباس -من طريق قتادة- في الآية، قال: <q>﴿المستقدمين﴾</q>: آدم ﵇، ومَن مضى مِن ذُرِّيَّتِه. و<q>﴿المستئخرين﴾</q>: مَن في أصلاب الرجال{8}. (٨/٦٠٩) ٤٠٢٧٦- عن عبد الله بن عباس، في الآية، قال: قَدَّم خَلْقًا وأخَّر خَلْقًا، فعلِم ما قدَّم وعلِم ما أخَّر{1}. (٨/٦١٠) ٤٠٢٧٧- عن مجاهد بن جبر -من طريق خُصَيْف- في قوله: <q>﴿ولقد علمنا المستقدمين منكم ولقد علمنا المستأخرين﴾</q>، قال: مَن مات، ومَن بَقِي{10}. (٨/٦١٠) ٤٠٢٧٨- عن مجاهد بن جبر -من طريق قيس- في الآية، قال: المستقدِمون: ما مضى مِن الأمم. والمستأخِرون: أُمَّة محمد ﷺ{11}. (٨/٦١٠) ٤٠٢٧٩- عن عبيد، قال: سمعتُ الضُّحّاك بن مُزاحِم يقول في قوله: <q>﴿ولقد علمنا المستقدمين منكم﴾</q> يعني: الأموات منكم، <q>﴿ولقد علمنا المستأخرين﴾</q>: بقِيَّتَهم، وهم الأحياء. يقول: علِمْنا مَن مات ومَن بَقِي{12}. (ز) ٤٠٢٨٠- عن عكرمة مولى ابن عباس -من طريق أبي الأحوص، عن سعيد بن مسروق- في قوله: <q>﴿ولقد علمنا المستقدمين منكم ولقد علمنا المستأخرين﴾</q>، قال: مَن مات، ومَن بَقِي{10}. (٨/٦١٠) ٤٠٢٨١- عن عكرمة مولى ابن عباس -من طريق سفيان بن سعيد بن مسروق الثوري، عن أبيه- في قوله: <q>﴿ولقد علمنا المستقدمين منكم﴾</q> قال: مَن خرج مِن الخلق، <q>﴿ولقد علمنا المستأخرين﴾</q> قال: مَن في أصلاب الرجال{14}. (ز) ٤٠٢٨٢- عن عامر الشعبي -من طريق داود بن أبي هند- في قول الله: <q>﴿ولقد علمنا المستقدمين منكم ولقد علمنا المستأخرين﴾</q>، قال: ما استقدم في أول الخلق، وما استأخر في آخر الخلق{15}. (ز) ٤٠٢٨٣- عن عامر الشعبي -من طريق داود بن أبي هند- في قوله: <q>﴿ولقد علمنا المستقدمين منكم﴾</q>، قال: في العصر، والمستأخرين منكم في أصلاب الرجال، وأرحام النساء{15}. (ز) ٤٠٢٨٤- عن الحسن البصري -من طريق قتادة- في قوله: <q>﴿ولقد علمنا المستقدمين منكم ولقد علمنا المستأخرين﴾</q>، قال: المستَقْدِمين في طاعة الله، والمستأخرين في معصية الله{17}. (٨/٦٠٨) ٤٠٢٨٥- عن الحسن البصري -من طريق عبّاد بن راشد- في الآية، قال: <q>﴿المستقدمين﴾</q> في الخير مِن الأُمَم، و<q>﴿المستئخرين﴾</q> المُبَطِّئِين عنه{18}. (٨/٦٠٩) ٤٠٢٨٦- عن قتادة بن دعامة -من طريق عبد الرزاق- في الآية، قال: <q>﴿المستقدمين﴾</q> آدم ومَن بعده حين نزلت هذه الآية، و<q>﴿المستئخرين﴾</q> مَن كان ذُرِّيَّة لم يُخْلَق بعد، وهو مخلوق، كلُّ أولئك قد علِمهم ﷿{19}. (٨/٦٠٩) ٤٠٢٨٧- عن عطاء [بن أبي رباح]، في قوله: <q>﴿ولقد علمنا المستقدمين منكم﴾</q> الآية، قال: في صفوف الصَّلاة، والقتال{20}. (٨/٦٠٨) ٤٠٢٨٨- عن أبي معشر، قال: سمعت عون بن عبد الله بن عتبة بن مسعود يُذاكِر محمدَ بن كعب في قول الله: <q>﴿ولقد علمنا المستقدمين منكم ولقد علمنا المستأخرين﴾</q>، فقال عون بن عبد الله بن عتبة بن مسعود: خير صفوف الرجال المُقَدَّم، وشرُّ صفوف الرجال المؤخر، وخير صفوف النساء المؤخر، وشر صفوف النساء المُقَدَّم= (ز) ٤٠٢٨٩- فقال محمد بن كعب [القرظي]: ليس هكذا، <q>﴿ولقد علمنا المستقدمين منكم﴾</q>: الميت والمقتول، والمستأخرين: مَن يلحق بهم من بعد، <q>﴿وإن ربك هو يحشرهم إنه حكيم عليم﴾</q>. فقال عون بن عبد الله: وفَّقك الله، وجزاك خيرًا{21}. (٨/٦١٠) ٤٠٢٩٠- عن مُقاتِل بن حيّان -من طريق مُعتَمِرِ بن سليمان [التَّيمِي]، عن شبيب بن عبد الملك- في قوله: <q>﴿ولقد علمنا المستقدمين منكم﴾</q> الآية، قال: بلغنا: أنّه في القتال. قال معتمر: فحَدَّثتُ أبي، فقال: لقد نزلت هذه الآية قبل أن يُفرَض القتال{22}. (٨/٦٠٨) ٤٠٢٩١- قال مقاتل بن سليمان: <q>﴿ولقد علمنا المستقدمين منكم﴾</q> يعني: مِن بني آدم مَن مات منكم، <q>﴿ولقد علمنا المستأخرين﴾</q> يقول: مَن بَقِي منكم فلم يَمُت. ونظيرها في «ق والقرآن» [٤]: <q>﴿قد علمنا ما تنقص الأرض منهم﴾</q>{23}. (ز) ٤٠٢٩٢- قال الأوزاعي: أراد المُصَلِّين في أول الوقت، والمُؤَخِّرين إلى آخره{24}. (ز) ٤٠٢٩٣- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿ولقد علمنا المستقدمين منكم، ولقد علمنا المستأخرين﴾</q>، قال: المستقدمون منكم: الذين مَضَوْا في أول الأُمَم. والمستأخرون: الباقون{12}٣٦٠٠. (ز) ٣٦٠٠ اختُلِف في معنى قوله تعالى: <q>﴿ولَقَدْ عَلِمْنا المُسْتَقْدِمِينَ مِنكُمْ ولَقَدْ عَلِمْنا المُسْتَأْخِرِينَ﴾</q> على أقوال: الأول: أن المستقدمين مَن تقدَّم موتُهم، والمستأخرين مَن قد خُلِق وهو حَيٌّ، ومَن لم يُخْلَق بَعْدُ ممن سيُخْلَق. الثاني: المستقدمين الذين ماتوا، والمستأخرين الذين هم أحياء لم يموتوا. الثالث: المستقدمين أول الخلق، والمستأخرين آخر الخلق. الرابع: أنّ المستقدمين مَن مضى مِن الأمم، والمستأخرين أمة محمد. الخامس: المستقدمين منكم في الخير، والمستأخرين في الشر. السادس: المستقدمين في صفوف الصلاة، والمستأخرين فيها. ورجَّح ابنُ جرير (١٤/٥٤-٥٥) مستندًا إلى دلالة السياق القول الأول، وهو قول ابن عباس من طريق قتادة، وقول عكرمة، وقتادة، وعلَّل ذلك بقوله: «لدلالة ما قبله من الكلام، وهو قوله: <q>﴿وإنّا لَنَحْنُ نُحْيِي ونُمِيتُ ونَحْنُ الوارِثُونَ﴾</q>، وما بعده، وهو قوله: <q>﴿وإنَّ رَبَّكَ هُوَ يَحْشُرُهُمْ﴾</q> على أنّ ذلك كذلك، إذ كان بيْن هذين الخبرين، ولم يَجْرِ قبل ذلك مِن الكلام ما يدل على خلافه، ولا جاء بعده». ثم بيَّن جواز دخول القول السادس في معنى الآية، فقال: «وجائزٌ أن تكون نزلت في شأن المستقدمين في الصفِّ لشأن النساء والمستأخرين فيه لذلك، ثم يكون اللهُ ﷿ عمَّ بالمعنى المراد منه جميع الخلق، فقال -جلَّ ثناؤه- لهم: قد علمنا ما مضى من الخَلْق وأحصيناهم وما كانوا يعملون، ومَن هو حيٌّ منكم، ومَن هو حادثٌ بعدكم أيُّها الناس، وأعمالَ جميعكم، خيرَها وشرَّها، وأحصينا جميع ذلك، ونحن نَحْشُرُ جميعَهم، فنجازي كُلًّا بأعماله، إن خيرًا فخيرًا، وإن شرًّا فشرًّا، فيكونُ ذلك تهديدًا ووعيدًا للمستأخرين في الصفوف لشأن النساء، ولكلِّ مَن تعدّى حدَّ الله وعَمِل بغير ما أذِن له به، ووعدًا لِمَن تقدَّم في الصفوف لسبب النساء، وسارع إلى محبة الله ورضوانه في أفعاله كلِّها». وذكر ابنُ عطية (٥/٢٨٥) أنّ معنى الآية: إخباره تعالى «بإحاطة علمه بمن تقدَّم مِن الأمم وبِمَن تأخَّر في الزمن، مِن لدن أُهبط آدم إلى الأرض إلى يوم القيامة، وأعلم أنه هو الحاشر لهم الجامع لعرض يوم القيامة على تباعدهم في الأقطار والأزمان، وأن حِكْمَته وعِلْمه يأتيان بهذا كلِّه على أتَمِّ غاياته التي قدرها وأرادها». ثم علَّق (٥/٢٨٦) بقوله: «فهذا سياق معنى الآية، وهو قول جمهور المفسرين». ثم ذكر القول الخامس، وهو قول الحسن من طريق قتادة، وانتقده مستندًا إلى السياق بقوله: «وإن كان اللفظ يتناول كلُّ مَن تقدَّم وتأخَّر على جميع وجوهه، فليس يطرد سياق معنى الآية إلا كما قدمناه». ثم انتقد القول السادس بدلالة السياق، وهو قول ابن عباس من طريق أبي الجوزاء، وقول مروان بن الحكم وما في معناه، فقال: «وما تقدَّم الآية مِن قوله: <q>﴿ونَحْنُ الوارِثُونَ﴾</q> وما تأخَّر من قوله: <q>﴿وإنَّ رَبَّكَ هُوَ يَحْشُرُهُمْ﴾</q> يُضْعِف هذه التأويلات؛ لأنها تُذهِب إيصال المعنى». ٤٠٢٩٤- قال سفيان بن عيينة: أراد: مَن يسلم، ومَن لا يسلم{24}. (ز) <q>﴿وَلَقَدۡ عَلِمۡنَا ٱلۡمُسۡتَقۡدِمِینَ مِنكُمۡ وَلَقَدۡ عَلِمۡنَا ٱلۡمُسۡتَـٔۡخِرِینَ ۝٢٤﴾</q> - آثار متعلقة بالآية ٤٠٢٩٥- عن أبي هريرة، قال: قال رسول الله ﷺ: «خيرُ صفوف الرجال أوَّلُها، وشَرُّها آخِرُها، وخيرُ صفوف النساء آخِرُها، وشرُّها أوَّلُها»{27}. (٨/٦٠٦) ",footnotes:1:عزاه السيوطي إلى ابن مردويه.أخرجه أحمد ٥/٥ (٢٧٨٣)، والترمذي ٥/٣٥٢-٣٥٣ (٣٣٨٧)، والنسائي ٢/١١٨ (٨٧٠)، وابن ماجه ٢/١٦١-١٦٢ (١٠٤٦)، وابن خزيمة ٣/١٨٢ (١٦٩٦)، وابن حبان ٢/١٢٦ (٤٠١)، والحاكم ٢/٣٨٤ (٣٣٤٦)، وابن جرير ١٤/٥٣-٥٤. قال الترمذي: «وروى جعفر بن سليمان هذا الحديث عن عمرو بن مالك عن أبي الجوزاء نحوه، ولم يذكر فيه: عن ابن عباس، وهذا أشبه أن يكون أصحّ مِن حديث نوح». وقال الحاكم: «هذا حديث صحيح الإسناد، ولم يخرجاه». ووافقه الذهبي في التلخيص. وقال القرطبي في تفسيره ١٠/١٩: «ورُوي عن أبي الجوزاء، ولم يذكر ابن عباس، وهو أصح». وقال ابن كثير في تفسيره ٤/٥٣٢: «حديث غريب جدًّا،.. من طرق عن نوح بن قيس الحداني، وقد وثقه أحمد وأبو داود وغيرهما، وحكي عن ابن معين تضعيفه، وأخرج له مسلم، وأهل السنن. وهذا الحديث فيه نكارة شديدة». وأورده الألباني في الصحيحة ٥/٦٠٨ (٢٤٧٢) وقال: «وهذا إسناد صحيح، رجاله ثقات رجال مسلم، غير عمرو بن مالك النُّكْري، وهو ثقة».أخرجه عبد الرزاق ١/٣٤٨ واللفظ له، والترمذي بنحوه الحديث السابق (٣١٢٢). وعزاه السيوطي إلى ابن المنذر. قال الترمذي عقِبَه: «هذا أشبه أن يكون أصح». وكذا رجح ابن كثير في تفسيره ٤/٤٥٠.أخرجه ابن جرير ١٤/٥٣.أسباب النزول للواحدي (ت: الفحل) ص٤٥٨.أخرجه الحاكم ٢/٣٥٣. وعزاه السيوطي إلى ابن مردويه.أخرجه ابن جرير ١٤/٥٠. وعزاه السيوطي إلى ابن أبي حاتم.أخرجه ابن جرير ١٤/٤٩. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم، وابن مردويه.عزاه السيوطي إلى ابن مردويه.أخرجه ابن جرير ١٤/٤٩. وعزاه السيوطي إلى سعيد بن منصور، وابن المنذر.أخرجه عبد الرزاق ١/٣٤٨ من طريق عبد الملك بن أبي سليمان، وابن جرير ١٤/٥٢. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.أخرجه ابن جرير ١٤/٥٠.أخرجه ابن جرير ١٤/٤٩. وعزاه السيوطي إلى سعيد بن منصور، وابن المنذر.أخرجه الثوري في تفسيره ص١٥٩، وعبد الرزاق في تفسيره ١/ ٣٤٨ بنحوه من طريق ابن التيمي عن أبيه، وابن جرير ١٤/٤٨ من طريقه.أخرجه ابن جرير ١٤/٥١.أخرجه ابن جرير ١٤/٥١.أخرجه ابن جرير ١٤/٥٢-٥٣. وعزاه السيوطي إلى ابن أبي حاتم.أخرجه ابن جرير ١٤/٥٣. وعزاه السيوطي إلى ابن المنذر.أخرجه عبد الرزاق ١/٣٤٨، وابن جرير ١٤/٤٩ من طريق معمر. وعزاه السيوطي إلى ابن المنذر.عزاه السيوطي إلى ابن أبي حاتم.أخرجه ابن وهب في الجامع - تفسير القرآن ١/١١٦ (٢٦٥) بنحوه، وابن جرير ١٤/٤٨-٤٩. وعزاه السيوطي إلى ابن أبي حاتم.عزاه السيوطي إلى ابن أبي حاتم. وذكر قول مقاتل الثعلبي في تفسيره ٥/٣٣٨ ونصَّ أنه ابن حيان، ولم يعينه البغوي ٤/٣٧٧.تفسير مقاتل بن سليمان ٢/٤٢٧.تفسير الثعلبي ٥/٣٣٨، وتفسير البغوي ٤/٣٧٧.أخرجه ابن جرير ١٤/٥٠.تفسير الثعلبي ٥/٣٣٨، وتفسير البغوي ٤/٣٧٧.أخرجه مسلم ١/٣٢٦ (٤٤٠). وقد أورد السيوطي ٨/ ٦٠٦-٦٠٨ أحاديث أخرى في ذلك.
15,25," <q>﴿وَإِنَّ رَبَّكَ هُوَ یَحۡشُرُهُمۡۚ إِنَّهُۥ حَكِیمٌ عَلِیمࣱ ۝٢٥﴾</q> - تفسير ٤٠٢٩٦- عن عبد الله بن عباس -من طريق عطاء الخراساني- <q>﴿وإن ربك هو يحشرهم﴾</q>، قال: وكلهم ميِّت، ثم يحشرهم ربُّهم{1}. (ز) ٤٠٢٩٧- عن عكرمة مولى ابن عباس، في قوله: <q>﴿وإن ربك هو يحشرهم﴾</q>، قال: يحشر هؤلاء وهؤلاء{2}. (٨/٦١٠) ٤٠٢٩٨- عن عكرمة مولى ابن عباس -من طريق سفيان، عن أبيه- في قوله: <q>﴿وإن ربك هو يحشرهم﴾</q>، قال: هذا مِن ههنا، وهذا مِن ههنا{1}. (ز) ٤٠٢٩٩- عن عامر الشعبي -من طريق داود بن أبي هند- في قوله: <q>﴿وإن ربك هو يحشرهم﴾</q>، قال: يجمعُهم يوم القيامة جميعًا{1}. (٨/٦١١) ٤٠٣٠٠- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿وإن ربك هو يحشرهم﴾</q>، قال: الأوَّلَ والآخِر{5}. (٨/٦١٠) ٤٠٣٠١- عن إسماعيل السُّدِّيّ، في قوله: <q>﴿وإن ربك هو يحشرهم﴾</q>، قال: يحشر المستقدمين والمستأخرين{2}. (٨/٦١١) ٤٠٣٠٢- قال مقاتل بن سليمان: <q>﴿وإن ربك﴾</q> يا محمد ﷺ <q>﴿هو يحشرهم﴾</q> يعني: مَن تقدَّم منهم ومَن تأخر. يقول: وهو يجمعهم في الآخرة، <q>﴿إنه حكيم﴾</q> حَكَمَ البعث، ثم قال: <q>﴿عليم﴾</q> ببعثهم{7}. (ز) ",footnotes:1:أخرجه ابن جرير ١٤/٥٦.عزاه السيوطي إلى ابن أبي حاتم.أخرجه ابن جرير ١٤/٥٦.أخرجه ابن جرير ١٤/٥٦.أخرجه ابن جرير ١٤/٥٥. وعزاه السيوطي إلى ابن أبي حاتم.عزاه السيوطي إلى ابن أبي حاتم.تفسير مقاتل بن سليمان ٢/٤٢٧.
15,26," <q>﴿وَلَقَدۡ خَلَقۡنَا ٱلۡإِنسَـٰنَ مِن صَلۡصَـٰلࣲ﴾</q> - تفسير ٤٠٣٠٣- عن عبد الله بن عباس -من طريق مجاهد- في قوله: <q>﴿من صلصال﴾</q>، قال: الصلصال: الماء يقع على الأرض الطيِّبة، ثم يحسُرُ عنها، فتَشَقَّقُ، ثم تصير مثل الخَزَف الرِّقاق{1}. (٨/٦١١) ٤٠٣٠٤- عن عبد الله بن عباس -من طريق العوفي- قال: الصلصال: هو التراب اليابس الذي يُبَلُّ بعد يُبسِه{2}. (٨/٦١١) ٤٠٣٠٥- عن عبد الله بن عباس، قال: الصَّلصال: طين خُلِط برَمْلٍ{3}. (٨/٦١٢) ٤٠٣٠٦- عن عبد الله بن عباس، قال: الصَّلصال: الذي إذا ضربته صَلْصَلَ{3}. (٨/٦١٢) ٤٠٣٠٧- عن عبد الله بن عباس، قال: الصَّلصال: الطين تعصِرُه بيدك، فيخرج الماءُ مِن بين أصابعك{3}. (٨/٦١٢) ٤٠٣٠٨- عن عبد الله بن عباس -من طريق الضَّحّاك-: الصلصال: الطِّين الجيِّد -يعني: الحُرّ{6}- إذا ذهب عنه الماءُ تَشَقَّق، فإذا حَرَّك تَقَعْقَع{7} {8}. (ز) ٤٠٣٠٩- عن عبد الله بن عباس -من طريق سعيد بن جبير- قال: خُلِق الإنسان من ثلاث: مِن طين لازِب، وصَلْصال، وحَمَأٍ مَسْنُون؛ فالطين اللازب: اللازم الجيد. والصلصال: المدَقَّقُ الذي يُصنَع منه الفخّار. والحمأ المسنون: الطين فيه الحَمأَةُ{9}٣٦٠١. (٨/٦١١) ٣٦٠١ علَّق ابنُ عطية (٥/٢٨٧) على قول ابن عباس بقوله: «وكان الوجْه -على هذا المعنى- أن يُقال: صلال. لكن ضُوعِف الفعل مِن فائه، وأُبدِلت إحدى اللامين مِن صلال صادًا». ٤٠٣١٠- عن مجاهد بن جبر -من طريق مسلم الأَعْوَر- قال: الصلصال: الماء الطيِّب مِن المطر وغيره، يستنقع في الأرض فيصير طينًا مثل الخزف، فيَتَصَلْصَل{10}. (ز) ٤٠٣١١- عن مجاهد بن جبر -من طريق شبل، عن ابن أبي نجيح- <q>﴿من صلصال﴾</q>، قال: التُّراب اليابس{11}. (ز) ٤٠٣١٢- عن مجاهد بن جبر -من طريق ورْقاء، عن ابن أبي نجيح- <q>﴿من صلصال﴾</q>: الصَّلصال: المُنتِن{12}. (ز) ٤٠٣١٣- عن قتادة بن دعامة -من طريق سعيد- قال: الصلصال: التُّراب اليابِس الذي يُسمَع له صلصلة{13}٣٦٠٢. (٨/٦١٢) ٣٦٠٢ اختُلِف في معنى: «الصلصال» في هذه الآية على أقوال: الأول: أنّه الطين اليابس الذي لم تُصِبْه نار، فإذا نقرته صلَّ، فسَمِعتَ له صلصلة. الثاني: أنّه الطين المُنتِن. ووجَّه ابنُ جرير (١٤/٥٨-٥٩) القول الثاني بقوله: «وكأنهم وجَّهوا ذلك إلى أنّه مِن قولهم: صَلَّ اللحم وأصَلَّ: إذا أنتن، يقال ذلك باللغتين كليهما: بـ(فَعَلَ) و(أفْعَلَ)». ورجَّح القول الأول مستندًا إلى النظائر، والدلالة العقلية، وهو قول ابن عباس من طريق العوفي وما في معناه، وعلَّل ذلك بـ«أنّ الله تعالى وصفه في موضعٍ آخر، فقال: <q>﴿خَلَقَ الإنْسانَ مِن صَلْصالٍ كالفَخّارِ﴾</q> [الرحمن:١٤]، فشبَّهه -تعالى ذِكْرُه- بأنّه كان كالفخّار في يُبْسِه، ولو كان معناه في ذلك: المنْتِن؛ لم يُشَبِّهْه بالفخّار، لأنّ الفخّار ليس بمنتنٍ فيُشَبَّه به في النَّتْنِ غيرُه». وبنحوه ابنُ كثير (٨/٢٥٥). ٤٠٣١٤- قال مقاتل بن سليمان: <q>﴿ولقد خلقنا الإنسان﴾</q> يعني: آدم <q>﴿من صلصال﴾</q>{14}. (ز) <q>﴿مِّنۡ حَمَإࣲ مَّسۡنُونࣲ ۝٢٦﴾</q> - تفسير ٤٠٣١٥- عن عبد الله بن عباس -من طريق سعيد بن جُبَير- في قوله: <q>﴿من حمإ مسنون﴾</q>، قال: مِن طين مُنتِن{15}. (٨/٦١٢) ٤٠٣١٦- عن عبد الله بن عباس -من طريق علي بن أبي طلحة- في قوله: <q>﴿من حمإ مسنون﴾</q>، قال: مِن طين رطب{16}٣٦٠٣. (٨/٦١٢) ٣٦٠٣ نَقَل ابنُ عطية (٥/٢٨٧) قول ابن عباس من طريق ابن أبي طلحة: أنّ المسنون: الرطب. ثم علَّق عليه بقوله: «وهذا تفسير لا يخص اللفظة». ووجَّه القول الثاني، ثم انتقده، فقال: «وهو مِن: أسِن الماءُ، إذا تغيّر، والتصريف يرُدُّ هذا القول». ثم ذكر (٥/٢٨٧-٢٨٨) احتمالين لمعنى <q>﴿مسنون﴾</q>، فقال: «والذي يترتب في <q>﴿مَسنون﴾</q> إما أن يكون بمعنى: محكوك مُحْكَم العمل أملس السطح، فيكون مِن معنى: المسنّ والسنان، وقولهم: سننت السكين، وسننت الحجر: إذا أحكمت مَلْسه،... وإما أن يكون بمعنى: المصبوب، تقول: سنَنتُ التراب والماء، إذا صبَبْتَه شيئًا بعد شيءٍ،... ومِن هذا: سنُّ الغارة، وقال الزجاج: هو مأخوذ من كونه على سُنَّة الطريق؛ لأنّه إنّما يتغير إذا فارق الماء». ثم وجَّه هذا المعنى بقوله: «فمعنى الآية على هذا: مِن حمأٍ مصبوب يوضع بعضه فوق بعض على مثال وصورة». ٤٠٣١٧- عن عبد الله بن عباس: أنّ نافع بن الأزرق قال له: أخبِرني عن قول الله: <q>﴿من حمإ مسنون﴾</q>. قال: الحمأَة: السوداء، وهي الثَّأطُ{17} أيضًا. والمسنون: المُصَوَّر. قال: وهل تعرف العرب ذلك؟ قال: نعم، أما سمعتَ قول حمزة بن عبد المطلب وهو يمدح رسول الله ﷺ، ويقول: أغَرُّ كأنّ البدر سُنَّة وجهه جَلا الغيم عنه ضَوءه فتَبَدَّدا{18}. (٨/٦١٢) ٤٠٣١٨- عن عبد الله بن عباس -من طريق السدي، عمَّن حدَّثه- قال: خُلِق آدم مِن أدِيم الأرض، فأُلْقِي على الأرض حتى صار طينًا لازِبًا؛ وهو الطين المُلْتَزِق، ثم تُرِك حتى صار حَمَأً مسنونًا؛ وهو المُنتِن، ثُمَّ خلقه الله بيده، فكان أربعين يومًا مُصَوَّرًا، حتى يَبِس فصار صلصالًا كالفخّار، إذا ضُرب عليه صَلْصَلَ؛ فذلك الصلصال، والفخّار مثل ذلك{19}. (٨/٦١٣) ٤٠٣١٩- عن مجاهد بن جبر -من طريق ابن أبي نجيح- <q>﴿من حمإ مسنون﴾</q>، قال: مُنتِن{20}. (ز) ٤٠٣٢٠- عن الضحاك بن مُزاحِم -من طريق جُوَيْبِر- في قوله: <q>﴿من حمإ مسنون﴾</q>، قال: مِن طين لازب، وهو اللازِق مِن الكَثِيب، وهو الرَّمل{21}. (ز) ٤٠٣٢١- عن الضَّحّاك بن مُزاحِم -من طريق عبيد بن سليمان- في قوله: <q>﴿من حمإ مسنون﴾</q>، قال: هو الحَمَأ المُنتِن{21}. (ز) ٤٠٣٢٢- عن قتادة بن دعامة -من طريق سعيد-: <q>﴿من حمإ مسنون﴾</q>، والحمأ المسنون: الذي قد تَغَيَّر وأَنتَنَ{20}. (ز) ٤٠٣٢٣- قال مقاتل بن سليمان: <q>﴿ولقد خلقنا الإنسان﴾</q> يعني: آدم <q>﴿من صلصال من حمإ﴾</q> يعني: الأسود <q>﴿مسنون﴾</q> يعني: المُنتِن، فكان الترابُ مُبْتَلًّا، فصار أسود مُنتِنًا{14}. (ز) ",footnotes:1:أخرجه ابن جرير ١٤/٥٧-٥٨. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم، وابن مردويه.أخرجه ابن جرير ١٤/٥٨. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.عزاه السيوطي إلى ابن أبي حاتم.عزاه السيوطي إلى ابن أبي حاتم.عزاه السيوطي إلى ابن أبي حاتم.الطين الحرّ: هو الطيِّب والوسط والخير منه. اللسان (حرر).القَعْقَعَة: حكاية حركة الشيء يُسمع له صوت. النهاية (قعقع).أخرجه مقاتل بن سليمان في تفسيره ٢/٤٢٨. وبنحوه في تفسير الثعلبي ٥/٣٣٩ من طريق أبي صالح، وتفسير البغوي ٤/٣٧٨.أخرجه ابن جرير ١٤/٥٨، وأبو الشيخ في العظمة (١٠١٦). وعزاه السيوطي إلى ابن المنذر. وزاد ابن جرير ١٤/٥٧ في رواية: وإنما سمي إنسانًا لأنّه عُهِد إليه فنسي.تفسير مجاهد ص٤١٦، وأخرجه ابن جرير ١٤/٥٨ بلفظ: الصلصال: الذي يصلصل مثل الخزف من الطين الطيب.أخرجه ابن جرير ١٤/٥٨.أخرجه ابن جرير ١٤/٥٩.أخرجه ابن جرير ١٤/٥٧، كذلك ومن طريق معمر بلفظ: الطين اليابس. وعزاه السيوطي إلى ابن أبي حاتم.تفسير مقاتل بن سليمان ٢/٤٢٧-٤٢٨.أخرجه ابن جرير ١٤/٦١ ومن طريق مجاهد والضحاك والعوفي بنحوه. وعزاه السيوطي إلى الفريابي، وابن المنذر، وابن أبي حاتم.أخرجه ابن جرير ١٤/٦٢، وابن أبي حاتم -كما في الإتقان ٢/٢٢-. وعزاه السيوطي إلى ابن المنذر.الثَأْط: الحَمْأة والطّين. النهاية والقاموس (ثأط).عزاه السيوطي إلى الطستي. وينظر: الإتقان ٢/٧٦.أخرجه ابن عساكر ٧/٣٨٣.أخرجه ابن جرير ١٤/٦١.أخرجه ابن جرير ١٤/٦٢.أخرجه ابن جرير ١٤/٦٢.أخرجه ابن جرير ١٤/٦١.تفسير مقاتل بن سليمان ٢/٤٢٧-٤٢٨.
15,27," <q>﴿وَٱلۡجَاۤنَّ خَلَقۡنَـٰهُ مِن قَبۡلُ﴾</q> - تفسير ٤٠٣٢٤- عن عبد الله بن عباس، قال: الجانُّ: مَسِيخُ الجِن، كما القردة والخنازير مسيخُ الإنس{1}. (٨/٦١٣) ٤٠٣٢٥- عن عبد الله بن عباس -من طريق الضحاك- قال: كان إبليسُ مِن حَيٍّ مِن أحياء الملائكة، يُقال لهم: الجِنُّ، خُلِقوا مِن نار السَّمُوم مِن بين الملائكة. قال: وخُلِقت الجنُّ الذين ذُكِروا في القرآن مِن مارج من نار{2}. (٨/٦١٤) ٤٠٣٢٦- قال عبد الله بن عباس، في قوله: <q>﴿والجان خلقناه من قبل﴾</q>: هو أبو الجِنِّ، كما أنّ آدم أبو البَشَر{3}. (ز) ٤٠٣٢٧- عن قتادة بن دعامة -من طريق سعيد- <q>﴿والجان خلقناه من قبل﴾</q>: وهو إبليس، خُلِق قبل آدم، وإنّما خُلِق آدم آخر الخلق، فحسده عدوُّ الله إبليس على ما أعطاه الله مِن الكرامة، فقال: أنا ناريٌّ، وهذا طينيٌّ، فكانت السجدةُ لآدم، والطاعةُ لله -تعالى ذِكْرُه-، فقال: <q>﴿فاخرج منها فإنك رجيم﴾</q>{4}. (٨/٦١٣) ٤٠٣٢٨- قال مقاتل بن سليمان: <q>﴿والجان﴾</q> يعني: إبليس <q>﴿خلقناه من قبل﴾</q> آدم،... وإنما سمي إبليس: الجان؛ لأنّه مِن حيٍّ مِن الملائكة يُقال لهم: الجن، والجن جماعة، والجانُّ واحد{5}. (ز) <q>﴿مِن نَّارِ ٱلسَّمُومِ ۝٢٧﴾</q> - تفسير ٤٠٣٢٩- عن عبد الله بن مسعود، عن النبيِّ ﷺ، قال: «رُؤيا المؤمن ِجزءٌ مِن سبعين جزءًا مِن النبوة، وهذه النار جزءٌ مِن سبعين جزءًا مِن نار السَّموم التي خُلِق منها الجانُّ». وتلا هذه الآية: <q>﴿والجآنَّ خلقناه من قبل من نار السموم﴾</q>{6}. (٨/٦١٥) ٤٠٣٣٠- عن عبد الله بن مسعود -من طريق عمرو بن عبد الله الأصم- قال: السموم التي خُلق منها الجانُّ جزءٌ مِن سبعين جزءًا مِن نار جهنم. ثم قرأ: <q>﴿والجآنَّ خلقناه من قبل من نار السموم﴾</q>{7}. (٨/٦١٤) ٤٠٣٣١- عن عبد الله بن عباس، في قوله: <q>﴿والجآنَّ خلقناه من قبل من نار السَّمُوم﴾</q>، قال: مِن أحسنِ النارِ{1}. (٨/٦١٤) ٤٠٣٣٢- عن عبد الله بن عباس -من طريق التميمي- <q>﴿والجان خلقناه من قبل من نار السموم﴾</q>، قال: هي السَّمُوم التي تقتل. <q>﴿فأصابها إعصار فيه نار فاحترقت﴾</q> [البقرة:٢٦٦]، قال: هي السموم التي تقتل{9}. (٨/٦١٤) ٤٠٣٣٣- عن عبد الله بن عباس -من طريق أبي صالح الكلبي-: السموم: نارٌ لا دُخان لها، والصَّواعِق تكون منها، وهي نار بين السماء وبين الحجاب، فإذا أحدث الله أمرًا خرقت الحجاب، فهوت إلى ما أُمِرَت، فالهدَّةُ التي تسمعون في خرق ذلك الحجاب{10}. (ز) ٤٠٣٣٤- عن الضحاك بن مُزاحِم -من طريق جُوَيْبِر- في قوله: <q>﴿والجان خلقناه من قبل من نار السموم﴾</q>، قال: مِن لَهَب مِن نار السموم{11}. (ز) ٤٠٣٣٥- عن عمرو بن دينار، قال: خُلِق الجانُّ والشياطين مِن نار الشمس{1}. (٨/٦١٥) ٤٠٣٣٦- قال مقاتل بن سليمان: <q>﴿من نار السموم﴾</q>، يعني: صافي، ليس فيه دُخان، وهو المارِج مِن نار، يعني: الجان{13}. (ز) <q>﴿مِن نَّارِ ٱلسَّمُومِ ۝٢٧﴾</q> - آثار متعلقة بالآية ٤٠٣٣٧- عن وهب بن مُنَبِّه -من طريق عبد الصمد بن معقل- أنّه سُئِل عن الجنِّ: ما هم؟ وهل يأكلون أو يشربون، أو يموتون، أو يتناكحون؟ قال: هم أجناس، فأمّا خالِص الجِنِّ فهم ريح لا يأكلون، ولا يشربون، ولا يموتون، ولا يتوالدون، ومنهم أجناس يأكلون، ويشربون، ويتناكحون، ويموتون، وهي هذه التي منها السَّعالي{14}، والغُول، وأشباه ذلك{15}. (ز) ",footnotes:1:عزاه السيوطي إلى ابن أبي حاتم.أخرجه ابن جرير ١/٤٨٢-٤٨٥ مطولًا، وفي ١٤/٦٤. وقد أحال ابن جرير في معنى الجان وسبب تسميته بذلك إلى ما نقله من آثار في تفسير قوله تعالى: <q>﴿وإذ قلنا للملائكة اسجدوا لآدم فسجدوا إلا إبليس أبى واستكبر وكان من الكافرين﴾</q> [البقرة:٣٤]، ابن جرير ١/٥٣٥ وما بعدها.تفسير الثعلبي ٥/٣٣٩، وتفسير البغوي ٤/٣٧٩.أخرجه ابن جرير ١٤/٦٣. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.تفسير مقاتل بن سليمان ٢/٤٢٨. وأوله في تفسير الثعلبي ٥/٣٤٠ بنحوه منسوبًا إلى مقاتل دون تعيينه.عزاه السيوطي إلى ابن مردويه.أخرجه ابن جرير ١٤/٦٤، والطيالسي -كما في تفسير ابن كثير ٤/٤٥١-، والطبراني (٩٠٥٧) من طريق عمرو بن ميمون، والحاكم ٢/٤٧٤ من طريق عمرو بن عبد الله الأصم، والبيهقي في شعب الإيمان (١٤٥) من طريق عمرو بن عبد الله الأصم. وعزاه السيوطي إلى الفريابي، وابن أبي حاتم.عزاه السيوطي إلى ابن أبي حاتم.أخرجه ابن جرير ١٤/٦٣. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم بلفظ: السموم: الحارة التي تقتل.تفسير الثعلبي ٥/٣٤٠، وفي تفسير البغوي ٤/٣٧٩ عن أبي صالح من قوله.أخرجه ابن جرير ١٤/٦٤.عزاه السيوطي إلى ابن أبي حاتم.تفسير مقاتل بن سليمان ٢/٤٢٨.السَّعالي: جمع سِعْلاة، وهم سَحَرة الجن. النهاية (سعل).أخرجه ابن جرير ١٤/٦٥.
15,28," <q>﴿وَإِذۡ قَالَ رَبُّكَ لِلۡمَلَـٰۤىِٕكَةِ إِنِّی خَـٰلِقُۢ بَشَرࣰا مِّن صَلۡصَـٰلࣲ مِّنۡ حَمَإࣲ مَّسۡنُونࣲ ۝٢٨ فَإِذَا سَوَّیۡتُهُۥ وَنَفَخۡتُ فِیهِ مِن رُّوحِی فَقَعُوا۟ لَهُۥ سَـٰجِدِینَ ۝٢٩﴾</q> - تفسير ٤٠٣٣٨- قال مقاتل بن سليمان: <q>﴿وإذ قال﴾</q> يعني: وقد قال <q>﴿ربك للملائكة﴾</q> الذين في الأرض، منهم إبليس، قال لهم قبل أن يخلق آدم ﵇: <q>﴿إني خالق بشرا﴾</q> يعني: آدم <q>﴿من صلصال من حمإ﴾</q> يعني: أسود <q>﴿مسنون﴾</q> يعني: مُنتِن، <q>﴿فإذا سويته﴾</q> يعني: سَوَّيْت خلقه، <q>﴿ونفخت فيه﴾</q> يعني: آدم <q>﴿من روحي فقعوا له ساجدين﴾</q> يقول: فاسجدوا لآدم{1}. (ز) ",footnotes:1:تفسير مقاتل بن سليمان ٢/٤٢٨.
  15,29,""
15,30," <q>﴿فَسَجَدَ ٱلۡمَلَـٰۤىِٕكَةُ كُلُّهُمۡ أَجۡمَعُونَ ۝٣٠ إِلَّاۤ إِبۡلِیسَ أَبَىٰۤ أَن یَكُونَ مَعَ ٱلسَّـٰجِدِینَ ۝٣١﴾</q> - تفسير ٤٠٣٣٩- عن عبد الله بن عباس -من طريق عكرمة- قال: لَمّا خلق اللهُ الملائكةَ قال: إنِّي خالقٌ بشرًا من طين، فإذا أنا خلقته فاسجدوا له. فقالوا: لا نفعل. فأرسل عليهم نارًا فأحرقتهم، وخلق ملائكة أخرى، فقال: إني خالق بشرًا مِن طين، فإذا أنا خلقته فاسجدوا له. فأَبَوْا. قال: فأرسل عليهم نارًا، فأحرقتهم، ثم خلق ملائكة أخرى، فقال: إنِّي خالقٌ بشرًا مِن طين، فإذا أنا خلقته فاسجدوا له. فأَبَوْا، فأرسل عليهم نارًا، فأحرقتهم، ثم خلق ملائكة، فقال: إني خالق بشرًا من طين، فإذا أنا خلقته فاسجدوا له. فقالوا: سمِعنا وأطعنا. إلا إبليس كان مِن الكافرين الأوَّلين{1}٣٦٠٤. (ز) ٣٦٠٤ وجَّه ابنُ عطية (٥/٢٩٠) قول ابن عباس بقوله: «وقوله:»من الأولين«يحتمل أن يريد: مِن الأولين في حالهم وكفرهم، ويحتمل أن يريد: أنه بقيَ منهم». وانتقده ابنُ كثير (٨/٢٥٧) مستندًا إلى عدم ثبوته قائلًا: «وفي ثبوت هذا عنه بُعد، والظاهر أنه إسرائيلي». ووصفه (٨/٢٥٦) بأنّه أثر غريب عجيب. ٤٠٣٤٠- قال مقاتل بن سليمان: <q>﴿فسجد الملائكة﴾</q> الذين هم في الأرض <q>﴿كلهم أجمعون﴾</q>، ثُمَّ استثنى مِن الملائكة إبليس، فقال سبحانه: <q>﴿إلا إبليس أبى أن يكون مع الساجدين﴾</q> لآدم ﵇{2}٣٦٠٥. (ز) ٣٦٠٥ ذكر ابنُ عطية (٥/٢٩١) الخلاف في إبليس هل هو مِن الملائكة أم لا؟ ثم رجَّح مستندًا إلى السنة، وظاهر الآية أنّه مِن الملائكة قائلًا: «والظاهر مِن كثير من الأحاديث ومِن هذه الآية: أنّه مِن الملائكة، وذلك أنّ الله تعالى أمر الملائكة بالسجود، ولو لم يكن إبليس مِن الملائكة لم يُذنِب في ترك السجود». ",footnotes:1:أخرجه ابن جرير ١٤/٦٥.تفسير مقاتل بن سليمان ٢/٤٢٨.
  15,31,""
