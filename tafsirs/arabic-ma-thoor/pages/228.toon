quran[9]{c,v,t}:
  11,54,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿إِن نَّقُولُ إِلَّا ٱعۡتَرَىٰكَ بَعۡضُ ءَالِهَتِنَا بِسُوۤءࣲۗ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٥٧٥٥<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطية العوفي- في قوله: <span class="qpc-hafs">﴿إن نقول إلا اعتراك بعض آلهتنا بسوء﴾</span>، قال: أصابَتْك بالجنون{1}. (٨/٨٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٧٥٦<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نَجِيح- <span class="qpc-hafs">﴿اعتراك بعض آلهتنا بسوء﴾</span>، قال: أصابَتْكَ الأوثانُ بجنون{2}. (٨/٨٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٧٥٧<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق عيسى- <span class="qpc-hafs">﴿إلا اعتراك بعض آلهتنا بسوء﴾</span>، قال: سَبَبْتَ آلهتَنا وعِبْتَها فأَجَنَّتْكَ{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٧٥٨<span class="dash">-</span></span> عن <span class="name-2">الضحاك بن مزاحم</span> -من طريق عبيد- <span class="qpc-hafs">﴿إنْ نَقُولُ إلّا اعْتَراكَ بَعْضُ آلِهَتِنا بِسُوءٍ﴾</span>، يقولون: نخشى أن يُصِيبك مِن آلهتنا سوء، ولا نُحِبُّ أن تعتريك، يقولون: يصيبك منها سوء{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٧٥٩<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق مَعْمَر- في الآية، قال: ما يحملك على ذمِّ آلهتنا إلا أنّه قد أصابك منها سوء{5}. (٨/٨٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٧٦٠<span class="dash">-</span></span> عن <span class="name-2">عبد الله بن كثير</span> -من طريق ابن جريج-: أصابَتْك آلهتُنا بِشَرٍّ{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٧٦١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿إنْ﴾</span> يعني: ما <span class="qpc-hafs">﴿نَقُولُ إلّا اعْتَراكَ﴾</span> يعنون: جنونًا أصابك به <span class="qpc-hafs">﴿بَعْضُ آلِهَتِنا بِسُوءٍ﴾</span> يعنون: أنّه يعتريك مِن آلهتنا الأوثانُ بجنون أو بِخَبَل، ولا نُحِبُّ أن يصيبك أو يعتريك ذلك، فاجتنبها سالِمًا{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٧٦٢<span class="dash">-</span></span> قال <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿إنْ نَقُولُ إلّا اعْتَراكَ بَعْضُ آلِهَتِنا بِسُوءٍ﴾</span>، يقولون: اختلَط عقلُك، فأصابك هذا مِمّا صَنَعَتْ بِكَ آلِهَتُنا{4}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ١٢/٤٤٧.|2:تفسير مجاهد ص٣٨٩، وأخرجه ابن جرير ١٢/٤٤٧، وابن أبي حاتم ٦/٢٠٤٦. وعزاه السيوطي إلى ابن المنذر، وأبي الشيخ.|3:أخرجه ابن جرير ١٢/٤٤٧.|4:أخرجه ابن جرير ١٢/٤٤٨.|5:أخرجه عبد الرزاق ١/٣٠٤، وابن جرير ١٢/٤٤٨، وابن أبي حاتم ٦/٢٠٤٦. وعزاه السيوطي إلى أبي الشيخ.|6:أخرجه ابن جرير ١٢/٤٤٨.|7:تفسير مقاتل بن سليمان ٢/٢٨٦.|8:أخرجه ابن جرير ١٢/٤٤٨.
  11,55,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿قَالَ إِنِّیۤ أُشۡهِدُ ٱللَّهَ وَٱشۡهَدُوۤا۟ أَنِّی بَرِیۤءࣱ مِّمَّا تُشۡرِكُونَ ۝٥٤ مِن دُونِهِۦۖ فَكِیدُونِی جَمِیعࣰا ثُمَّ لَا تُنظِرُونِ ۝٥٥﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٥٧٦٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: فرَدَّ عليهم هود: <span class="qpc-hafs">﴿قالَ إنِّي أُشْهِدُ اللَّهَ واشْهَدُوا أنِّي بَرِيءٌ مِمّا تُشْرِكُونَ مِن دُونِهِ﴾</span> مِن الآلهة، <span class="qpc-hafs">﴿فَكِيدُونِي جَمِيعًا﴾</span> أنتم والآلهة، <span class="qpc-hafs">﴿ثُمَّ لا تُنْظِرُونِ﴾</span> يعني: ثُمَّ لا تُناظِرون، يعني: لا تُمْهِلون{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٧٦٤<span class="dash">-</span></span> عن <span class="name-3">محمد بن إسحاق</span> -من طريق سلمة– قال: <span class="qpc-hafs">﴿إني أشهد الله واشهدوا أني بريء مما تشركون من دونه﴾</span> أي: إنِّي قد كفرتُ بآلهتكم التي تزعمون أنّها أصابَتْنِي بالجنون، فلْتُصِبْنِي بما هو أعظمَ مِن ذلك، إنِّي قد كفرتُ بها، <span class="qpc-hafs">﴿فكيدوني جميعا﴾</span> أي: فكيدوني أنتم ومَن معكم جميعًا{2}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿قَالَ إِنِّیۤ أُشۡهِدُ ٱللَّهَ وَٱشۡهَدُوۤا۟ أَنِّی بَرِیۤءࣱ مِّمَّا تُشۡرِكُونَ ۝٥٤ مِن دُونِهِۦۖ فَكِیدُونِی جَمِیعࣰا ثُمَّ لَا تُنظِرُونِ ۝٥٥﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٣٥٧٦٥<span class="dash">-</span></span> عن محمد بن مهاجر، قال: كان <span class="name-1">عمر</span> جالِسًا وهو يَشُقُّ عليه الجلوس، فكان مُتَّكِئًا وعنده يومئذٍ سعيد بن خالد، وعنبسة بن سعيد، وأناسٌ مِن بني عمِّه، فقال: يا بني عمِّ، أسألكم صنع أما لكم كذا{3}! قالوا: بلى. قال سعيد بن خالد -وكانت فيه أعْرابِيَّةٌ-: واللهِ، إنّك لَتُرِيد أمرًا لا تناله حتى تنالَ السماء. قال: فاستوى قاعِدًا، ثم قال: <span class="qpc-hafs">﴿فَكِيدُونِي جَمِيعًا ثُمَّ لا تُنْظِرُونِ﴾</span>. قال: فقال عنبسة بن سعيد: يا أمير المؤمنين، أما لنا قرابة؟ أما لنا حقٌّ؟ قال: بلى، ولكِنِّي -واللهِ- ما لكم فيه إلا كالرجل في حضرموت راعي غنم. قال: فلمّا سَمِعوها افترقوا، ولحقوا بمنازلهم{2}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٢/٢٨٦.|2:أخرجه ابن أبي حاتم ٦/٢٠٤٦.|3:كذا جاءت العبارة في المطبوع.|4:أخرجه ابن أبي حاتم ٦/٢٠٤٦.
  11,56,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿إِنِّی تَوَكَّلۡتُ عَلَى ٱللَّهِ رَبِّی وَرَبِّكُمۚ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٥٧٦٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿إنِّي تَوَكَّلْتُ عَلى اللَّهِ﴾</span> يعني: وثِقْتُ بالله <span class="qpc-hafs">﴿رَبِّي ورَبِّكُمْ﴾</span> حين خوَّفُوه آلهتَهم أنّها تُصِيبُه{1}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿مَّا مِن دَاۤبَّةٍ إِلَّا هُوَ ءَاخِذُۢ بِنَاصِیَتِهَاۤۚ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٥٧٦٧<span class="dash">-</span></span> قال <span class="name-2">الضحاك بن مُزاحِم</span>: يُحْيِيها، ويُميتها{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٧٦٨<span class="dash">-</span></span> عن <span class="name-2">أيفع بن عبد الكلاعي</span> -من طريق صفوان بن عمرو- قال في قوله: <span class="qpc-hafs">﴿ما من دابة إلا هو آخذ بناصيتها إن ربي على صراط مستقيم﴾</span>، قال: فيأخذ بنواصي عبادِه، فيلِين للمؤمن حتى يكون لهم ألْيَنَ مِن الوالد بولده، ويُقال للكافر: <span class="qpc-hafs">﴿ما غرك بربك الكريم﴾</span> [الانفطار:٦]{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٧٦٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ما مِن دابَّةٍ﴾</span> يعني: ما مِن شيء <span class="qpc-hafs">﴿إلّا هُوَ آخِذٌ بِناصِيَتِها﴾</span> يقول: إلا اللهُ يُمِيتُها{1}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿إِنَّ رَبِّی عَلَىٰ صِرَ ٰ⁠طࣲ مُّسۡتَقِیمࣲ ۝٥٦﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٥٧٧٠<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- <span class="qpc-hafs">﴿إن ربي على صراط مستقيم﴾</span>، قال: الحق{5}. (٨/٨٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٧٧١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿إنَّ رَبِّي عَلى صِراطٍ مُسْتَقِيمٍ﴾</span>، يعني: على الحق المستقيم{1}<span class=comment-ref>٣٢٣٦</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٣٢٣٦</span> نقل <u>ابنُ القيم</u> (٢/٥٦-٥٧) عن ابن الأنباري في قوله: <span class="qpc-hafs">﴿إن ربي على صراط مستقيم﴾</span> قولين، فقال: «وقال ابن الأنباري: لَمّا قال: <span class="qpc-hafs">﴿هُوَ آخِذٌ بِناصِيَتِها﴾</span> كان في معنى: لا يخرج مِن قبضته، وأنّه قاهِرٌ بعظيم سلطانه لكل دابة، فأتبع قوله: <span class="qpc-hafs">﴿إنَّ رَبِّي عَلى صِراطٍ مُسْتَقِيمٍ﴾</span>. قال: وهذا <span class="mustanad">نحو كلام العرب</span> إذا وصَفُوا بحسن السيرة والعدل والإنصاف قالوا: فلان على طريقة حسنة، وليس ثمَّ طريق. ثم ذكر وجهًا آخر، فقال:»لَمّا ذكر أنّ سلطانه قد قهر كل دابة <span class="mustanad">أتبع هذا قوله</span>: <span class="qpc-hafs">﴿إنَّ رَبِّي عَلى صِراطٍ مُسْتَقِيمٍ﴾</span>، أي: لا تخفى عليه مشيئتُه، ولا يعدل عنه هارِبٌ، فذكر الصراط المستقيم وهو يعني به: الطريق الذي لا يكون لأحد مسلك إلا عليه، كما قال: <span class="qpc-hafs">﴿إنَّ رَبَّكَ لَبِالمِرْصادِ﴾</span> [الفجر:١٤]«. ثم <span class="comment-type-1">وجّه</span> <u>ابنُ القيم</u> معنى الآية على القولين، فقال:»فعلى هذا القول الأول يكون المراد: أنّه في تصرُّفه في ملكه يتصرَّف بالعدل، ومجازاة المحسن بإحسانه والمسيء بإساءته، ولا يظلم مثقال ذرة، ولا يُعاقِب أحدًا بما لم يَجْنِه، ولا يهضمه ثوابَ ما عمله، ولا يحمل عليه ذنبَ غيره، ولا يأخذ أحدًا بجريرة أحد، ولا يُكَلِّف نفسًا ما لا تطيقه، فيكون من باب: له الملك وله الحمد، ومن باب: ماضٍ فِيَّ حُكْمُك عدلٌ فِيَّ قضاؤك، ومن باب: الحمد لله رب العالمين، أي: كما أنّه رب العالمين المتصرف فيهم بقدرته ومشيئته فهو المحمود على هذا التصرف، وله الحمد على جميعه. وعلى القول الثاني المراد به: التهديد والوعيد، وأنّ مصير العباد إليه، وطريقهم عليه، لا يفوته منهم أحد، <span class="mustanad">كما قال تعالى</span>: <span class="qpc-hafs">﴿قالَ هَذا صِراطٌ عَلَيَّ مُسْتَقِيمٌ﴾</span> [الحجر:٤١]".</div></p><p><h3><span class="qpc-hafs">﴿إِنَّ رَبِّی عَلَىٰ صِرَ ٰ⁠طࣲ مُّسۡتَقِیمࣲ ۝٥٦﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٣٥٧٧٢<span class="dash">-</span></span> عن <span class="name-3">يحيى بن سعيد</span>، قال: ما مِن أحد يخاف لِصًّا عادِيًا، أو سَبُعًا ضارِيًا، أو شيطانًا مارِدًا، فيتلو هذه الآية: <span class="qpc-hafs">﴿إني توكلت على الله ربي وربكم ما من دابة إلا هو آخذ بناصيتها إن ربي على صراط مستقيم﴾</span>؛ إلّا صَرَفَه اللهُ عنه{7}. (٨/٨٥)</p></p><p></div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٢/٢٨٦.|2:تفسير الثعلبي ٥/١٧٤، وتفسير البغوي ٤/١٨٣.|3:أخرجه ابن أبي حاتم ٦/٢٠٤٧. وفي تفسير ابن كثير بلفظ: فيلقى المؤمن، بدل: فيلين للمؤمن.|4:تفسير مقاتل بن سليمان ٢/٢٨٦.|5:تفسير مجاهد ص٣٨٩، وأخرجه ابن جرير ١٢/٤٥٠. وعزاه السيوطي إلى أبي الشيخ.|6:تفسير مقاتل بن سليمان ٢/٢٨٦.|7:عزاه السيوطي إلى ابن أبي حاتم.
  11,57,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿فَإِن تَوَلَّوۡا۟ فَقَدۡ أَبۡلَغۡتُكُم مَّاۤ أُرۡسِلۡتُ بِهِۦۤ إِلَیۡكُمۡۚ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٥٧٧٣<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي بن أبي طلحة- <span class="qpc-hafs">﴿فإن تولوا﴾</span>، يعني: الكُفّار{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٧٧٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فَإنْ تَوَلَّوْا﴾</span> يعني: فإن تُعْرِضُوا عن الإيمان، <span class="qpc-hafs">﴿فَقَدْ أبْلَغْتُكُمْ ما أُرْسِلْتُ بِهِ إلَيْكُمْ﴾</span> مِن نزول العذاب بكم في الدنيا{2}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَیَسۡتَخۡلِفُ رَبِّی قَوۡمًا غَیۡرَكُمۡ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٥٧٧٥<span class="dash">-</span></span> عن <span class="name-1">أبي سعيد الخدري</span> -من طريق الوليد بن قيس- قال: الخَلَف مِن بعد ستين سنة{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٧٧٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ويَسْتَخْلِفُ رَبِّي﴾</span> بعد هلاككم <span class="qpc-hafs">﴿قَوْمًا غَيْرَكُمْ﴾</span> أمثلَ وأطوعَ لله منكم{4}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَلَا تَضُرُّونَهُۥ شَیۡـًٔاۚ إِنَّ رَبِّی عَلَىٰ كُلِّ شَیۡءٍ حَفِیظࣱ ۝٥٧﴾</span> - قراءات</h3></p><p><div></p><p><p><span class="item-no">٣٥٧٧٧<span class="dash">-</span></span> عن الأعمش، في قراءة <span class="name-1">عبد الله [بن مسعود]</span>: (ولا تَنقُصُوهُ شَيْئًا) مكان <span class="qpc-hafs">﴿ولا تضرونه شيئا﴾</span>{5}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَلَا تَضُرُّونَهُۥ شَیۡـًٔاۚ إِنَّ رَبِّی عَلَىٰ كُلِّ شَیۡءٍ حَفِیظࣱ ۝٥٧﴾</span> - تفسير الآية</h3></p><p><div></p><p><p><span class="item-no">٣٥٧٧٨<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ولا تَضُرُّونَهُ شَيْئًا﴾</span> يقول: ولا تنقصونه مِن مُلكه شيئًا، إنّما تنقصون أنفسكم، <span class="qpc-hafs">﴿إنَّ رَبِّي عَلى كُلِّ شَيْءٍ﴾</span> مِن أعمالكم <span class="qpc-hafs">﴿حَفِيظٌ﴾</span>{4}<span class=comment-ref>٣٢٣٧</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٣٢٣٧</span> <span class="comment-type-4">ذكر</span> <u>ابنُ عطية</u> (٤/٥٩٧) في الآية قولين، فقال: «وقوله:<span class="qpc-hafs">﴿ولا تَضُرُّونَهُ شَيْئًا﴾</span> يحتمل من المعنى وجهين: <b>أحدهما</b>: ولا تضرونه بذهابكم وهلاككم شيئًا، أي: لا ينتقص ملكه، ولا يختل أمرُه، وعلى هذا المعنى قرأ ابن مسعود: (ولا تَنقُصُونَهُ شَيْئًا». <b>والمعنى الآخر</b>: <span class="qpc-hafs">﴿ولا تَضُرُّونَهُ﴾</span> أي ولا تقدرون إذا أهلككم على إضراره بشيء، ولا على الانتصار منه، ولا تقابلون فعله بكم بشيء يضره".</div></p></div>",footnotes:1:أخرجه ابن أبي حاتم ٦/٢٠٤٧.|2:تفسير مقاتل بن سليمان ٢/٢٨٦-٢٨٧.|3:أخرجه ابن أبي حاتم ٦/٢٠٤٧. وأورده قبل ذلك ٥/١٦٠٦ في تفسير قوله تعالى: <span class="qpc-hafs">﴿فَخَلَفَ مِن بَعْدِهِمْ خَلْفٌ﴾</span> [الأعراف:١٦٩].|4:تفسير مقاتل بن سليمان ٢/٢٨٧.|5:أخرجه ابن أبي داود في المصاحف ١/٣١٩.</p><p>وهي قراءة شاذة. انظر: البحر المحيط ٥/٢٣٤.|6:تفسير مقاتل بن سليمان ٢/٢٨٧.
  11,58,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَلَمَّا جَاۤءَ أَمۡرُنَا نَجَّیۡنَا هُودࣰا وَٱلَّذِینَ ءَامَنُوا۟ مَعَهُۥ بِرَحۡمَةࣲ مِّنَّا﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٥٧٧٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ولَمّا جاءَ أمْرُنا﴾</span> يعني: قولنا في نزول العذاب <span class="qpc-hafs">﴿نَجَّيْنا هُودًا والَّذِينَ آمَنُوا مَعَهُ﴾</span> مِن العذاب <span class="qpc-hafs">﴿بِرَحْمَةٍ مِنّا﴾</span> يعني: بنِعمةٍ مِنّا عليهم{1}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَنَجَّیۡنَـٰهُم مِّنۡ عَذَابٍ غَلِیظࣲ ۝٥٨﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٥٧٨٠<span class="dash">-</span></span> عن <span class="name-2">أبي مالك غَزْوان الغفاري</span> -من طريق السدي- في قوله: <span class="qpc-hafs">﴿عذاب غليظ﴾</span>، قال: شديد{2}. (٨/٨٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٧٨١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ونَجَّيْناهُمْ مِن عَذابٍ غَلِيظٍ﴾</span>، يعني: شديد، وهي الريح الباردة لم تفتر عنهم حتى أهلكتهم{1}<span class=comment-ref>٣٢٣٨</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٣٢٣٨</span> <span class="comment-type-4">ذكر</span> <u>ابنُ عطية</u> (٤/٥٩٧) في قوله: <span class="qpc-hafs">﴿ونجيناهم من عذاب غليظ﴾</span> احتمالين، فقال: «وقوله: <span class="qpc-hafs">﴿ونَجَّيْناهُمْ مِن عَذابٍ غَلِيظٍ﴾</span> يحتمل أن يريد: عذاب الآخرة. ويحتمل أن يريد: وكانت النجاة المتقدمة مِن عذاب غليظ، يريد: الريح؛ فيكون المقصود على هذا تعديد النعمة».</div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٢/٢٨٧.|2:أخرجه ابن أبي حاتم ٦/٢٠٤٧.|3:تفسير مقاتل بن سليمان ٢/٢٨٧.
  11,59,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَتِلۡكَ عَادࣱۖ جَحَدُوا۟ بِـَٔایَـٰتِ رَبِّهِمۡ وَعَصَوۡا۟ رُسُلَهُۥ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٥٧٨٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وتِلْكَ عادٌ جَحَدُوا بِآياتِ رَبِّهِمْ﴾</span> يعني: كفروا بعذاب الله بأنّه غير نازِل بهم في الدنيا، <span class="qpc-hafs">﴿وعَصَوْا رُسُلَهُ﴾</span> يعني: هودًا وحده{1}<span class=comment-ref>٣٢٣٩</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٣٢٣٩</span> <span class="comment-type-4">ذكر</span> <u>ابنُ عطية</u> (٤/٥٩٨) ما أفاده قولُ مقاتل في تفسير قوله: <span class="qpc-hafs">﴿وعصوا رسله﴾</span> مِن أنه هود وحده، وذكر احتمالًا آخر أن يكون ذلك: «شنعة عليهم؛ وذلك أنّ في تكذيب رسولٍ واحدٍ تكذيبُ سائر الرسل وعصيانهم؛ إذ النبوات كلها مُجْمِعَةٌ على الإيمان بالله، والإقرار بربوبيته».</div></p><p><h3><span class="qpc-hafs">﴿وَٱتَّبَعُوۤا۟ أَمۡرَ كُلِّ جَبَّارٍ عَنِیدࣲ ۝٥٩﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٥٧٨٣<span class="dash">-</span></span> عن <span class="name-2">إبراهيم النخعي</span>: <span class="qpc-hafs">﴿عنيد﴾</span>، قال: مُناكِب{2} عن الحقِّ{3}. (٨/٨٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٧٨٤<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿كل جبار عنيد﴾</span>: المُشْرِك{4}<span class=comment-ref>٣٢٤٠</span>. (٨/٨٦)</p></p><p></div></p><p><div><span class=comment-ref>٣٢٤٠</span> لم يذكر <u>ابنُ جرير</u> (١٢/٤٥٢) غير قول قتادة.</div></p><p><div></p><p><p><span class="item-no">٣٥٧٨٥<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- قال: <span class="qpc-hafs">﴿كل جبار عنيد﴾</span>، قال: المُشاقّ{5}. (٨/٨٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٧٨٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿واتَّبَعُوا أمْرَ كُلِّ جَبّارٍ عَنِيدٍ﴾</span> يعني: مُتَعَظِّمًا عن التوحيد، فهم الأتباع، اتَّبَعُوا قولَ الكُبَراء في تكذيب هود، <span class="qpc-hafs">﴿عَنِيدٍ﴾</span> يعني: مُعْرِضًا عن الحق، وكان هذا القولُ مِن الكبراء للسفلة فى سورة المؤمنين [٣٣-٣٤]: <span class="qpc-hafs">﴿ما هَذا﴾</span> يعني: هودًا <span class="qpc-hafs">﴿إلّا بَشَرٌ مِثْلُكُمْ يَأْكُلُ مِمّا تَأْكُلُونَ مِنهُ ويَشْرَبُ مِمّا تَشْرَبُونَ﴾</span> من الشراب. وقال للأتباع: <span class="qpc-hafs">﴿ولَئِنْ أطَعْتُمْ بَشَرًا مِثْلَكُمْ إنَّكُمْ إذًا لَخاسِرُونَ﴾</span> يعني: لَعَجَزَة، فهذا قولُ الكبراء للسَّفِلة. فاتَّبعوهم على قولهم{1}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٢/٢٨٧.|2:نكب فلان عن الصواب: إذا عدل عنه. لسان العرب (نكب).|3:عزاه السيوطي إلى ابن المنذر.|4:أخرجه ابن جرير ١٢/٤٥٢، وابن أبي حاتم ٦/٢٤٠٧. وعزاه السيوطي إلى أبي الشيخ.|5:أخرجه ابن أبي حاتم ٦/٢٠٤٨. وعزاه السيوطي إلى أبي الشيخ.|6:تفسير مقاتل بن سليمان ٢/٢٨٧.
  11,60,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَأُتۡبِعُوا۟ فِی هَـٰذِهِ ٱلدُّنۡیَا لَعۡنَةࣰ وَیَوۡمَ ٱلۡقِیَـٰمَةِۗ أَلَاۤ إِنَّ عَادࣰا كَفَرُوا۟ رَبَّهُمۡۗ أَلَا بُعۡدࣰا لِّعَادࣲ قَوۡمِ هُودࣲ ۝٦٠﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٥٧٨٧<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span>، في قوله: <span class="qpc-hafs">﴿وأتبعوا في هذه الدنيا لعنة ويوم القيامة﴾</span>، قال: لعنة أخرى{1}. (٨/٨٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٧٨٨<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span>، في الآية، قال: تَتابَعَتْ عليهم لعنتان مِن الله؛ لعنة في الدنيا، ولعنة في الآخرة{2}. (٨/٨٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٧٨٩<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- في قوله: <span class="qpc-hafs">﴿وأتبعوا في هذه الدنيا لعنة﴾</span>، قال: لم يُبعث نبيٌّ بعد عادٍ إلا لُعِنت عادٌ على لسانه{3}. (٨/٨٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٧٩٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وأُتْبِعُوا فِي هَذِهِ الدُّنْيا لَعْنَةً﴾</span> يعني: العذاب، وهي الرِّيح التي أهلكتهم، <span class="qpc-hafs">﴿ويَوْمَ القِيامَةِ﴾</span> يعني: عذاب النار، <span class="qpc-hafs">﴿ألا إنَّ عادًا كَفَرُوا رَبَّهُمْ﴾</span> يعني: بتوحيد ربهم، <span class="qpc-hafs">﴿ألا بعدا لعاد قوم هود﴾</span>{4}<span class=comment-ref>٣٢٤١</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٣٢٤١</span> قال <u>ابنُ جرير</u> (١٢/٤٥٢): «وقيل: إنّ معنى <span class="qpc-hafs">﴿كفروا ربهم﴾</span>: كفروا نعمة ربهم».</div></p></div>",footnotes:1:عزاه السيوطي إلى أبي الشيخ.|2:عزاه السيوطي إلى ابن المنذر، وأبي الشيخ.|3:أخرجه ابن أبي حاتم ٦/٢٠٤٨. وعزاه السيوطي إلى أبي الشيخ.|4:تفسير مقاتل بن سليمان ٢/٢٨٧-٢٨٨.
  11,61,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَإِلَىٰ ثَمُودَ أَخَاهُمۡ صَـٰلِحࣰاۚ قَالَ یَـٰقَوۡمِ ٱعۡبُدُوا۟ ٱللَّهَ مَا لَكُم مِّنۡ إِلَـٰهٍ غَیۡرُهُۥۖ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٥٧٩١<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد بن بشير-: أنّ صالحًا بُعِث مِن الحِجْرِ{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٧٩٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وإلى ثَمُودَ﴾</span> أرْسَلْنا <span class="qpc-hafs">﴿أخاهُمْ صالِحًا﴾</span> ليس بأخيهم في الدِّين، ولَكِنَّه أخوهم في النَّسَب، وهو صالح بن آسف، <span class="qpc-hafs">﴿قالَ يا قَوْمِ اعْبُدُوا اللَّهَ﴾</span> يعني: وحِّدوا اللهَ، <span class="qpc-hafs">﴿ما لَكُمْ مِن إلَهٍ غَيْرُهُ﴾</span>{2}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿هُوَ أَنشَأَكُم مِّنَ ٱلۡأَرۡضِ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٥٧٩٣<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span>، <span class="qpc-hafs">﴿هو أنشأكم من الأرض﴾</span>، قال: خَلَقَكم مِن الأرض{3}. (٨/٨٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٧٩٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿هُوَ أنْشَأَكُمْ مِنَ الأَرْضِ﴾</span>، يعني: هو خَلَقَكم مِن الأرض{2}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَٱسۡتَعۡمَرَكُمۡ فِیهَا﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٥٧٩٥<span class="dash">-</span></span> قال <span class="name-1">عبد الله بن عباس</span>: أعاشَكُم فيها{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٧٩٦<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نَجِيح- <span class="qpc-hafs">﴿واستعمركم فيها﴾</span>، قال: أعْمَرَكم فيها{6}<span class=comment-ref>٣٢٤٢</span>. (٨/٨٧)</p></p><p></div></p><p><div><span class=comment-ref>٣٢٤٢</span> لم يذكر <u>ابنُ جرير</u> (١٢/٤٥٣) في معنى: <span class="qpc-hafs">﴿واسْتَعْمَرَكُمْ فِيها﴾</span> سوى قول مجاهد مِن طريق ابن أبي نجيح.</div></p><p><div></p><p><p><span class="item-no">٣٥٧٩٧<span class="dash">-</span></span> قال <span class="name-2">الضحاك بن مُزاحِم</span>: أطال عُمْرَكم فيها، حتّى كان الواحدُ مِنهم يعيشُ ثلاثمائة سنة إلى ألف سنة، وكذلك قوم عاد{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٧٩٨<span class="dash">-</span></span> قال <span class="name-2">قتادة بن دعامة</span>: أسْكَنَكُم فيها{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٧٩٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿واسْتَعْمَرَكُمْ فِيها﴾</span>، يعني: وعمركم في الأرض{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٨٠٠<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق أصبغ- <span class="qpc-hafs">﴿واستعمركم فيها﴾</span>، قال: اسْتَخْلَفَكم فيها{1}. (٨/٨٧)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿فَٱسۡتَغۡفِرُوهُ ثُمَّ تُوبُوۤا۟ إِلَیۡهِۚ إِنَّ رَبِّی قَرِیبࣱ مُّجِیبࣱ ۝٦١﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٥٨٠١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فاسْتَغْفِرُوهُ﴾</span> مِن الشِّرْك، <span class="qpc-hafs">﴿ثُمَّ تُوبُوا إلَيْهِ﴾</span> مِنه، <span class="qpc-hafs">﴿إنَّ رَبِّي قَرِيبٌ﴾</span> مِنكم في الاستجابة، <span class="qpc-hafs">﴿مُجِيبٌ﴾</span> للدُّعاء، كقوله: <span class="qpc-hafs">﴿فَإنِّي قَرِيبٌ أُجِيبُ دَعْوَةَ الدّاعِ إذا دَعانِ﴾</span> [البقرة:١٨٦]{2}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن أبي حاتم ٦/٢٠٤٨.|2:تفسير مقاتل بن سليمان ٢/٢٨٨.|3:عزاه السيوطي إلى أبي الشيخ.|4:تفسير مقاتل بن سليمان ٢/٢٨٨.|5:تفسير الثعلبي ٥/١٧٦.|6:تفسير مجاهد ص٣٨٩، وأخرجه ابن جرير ١٢/٤٥٣، وابن أبي حاتم ٦/٢٠٤٨. وعزاه السيوطي إلى أبي الشيخ.|7:تفسير البغوي ٤/١٨٥، وفي تفسير الثعلبي ٥/١٧٦ مختصرًا.|8:تفسير الثعلبي ٥/١٧٦، وتفسير البغوي ٤/١٨٥.|9:تفسير مقاتل بن سليمان ٢/٢٨٨.|10:أخرجه ابن أبي حاتم ٦/٢٠٤٨.|11:تفسير مقاتل بن سليمان ٢/٢٨٨.
  11,62,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿قَالُوا۟ یَـٰصَـٰلِحُ قَدۡ كُنتَ فِینَا مَرۡجُوࣰّا قَبۡلَ هَـٰذَاۤۖ أَتَنۡهَىٰنَاۤ أَن نَّعۡبُدَ مَا یَعۡبُدُ ءَابَاۤؤُنَا وَإِنَّنَا لَفِی شَكࣲّ مِّمَّا تَدۡعُونَاۤ إِلَیۡهِ مُرِیبࣲ ۝٦٢﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٥٨٠٢<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- قوله: <span class="qpc-hafs">﴿وإننا لفي شك مما تدعونا إليه مريب﴾</span>: وكَذَبُوا، واللهِ، ما في الله شكٌّ، أفي مَن فَطَر السماء والأرض؟ وأنزل مِن السماء ماءً فأخرج به من الثمرات رزقًا لكم، وأَظْهَرَ لكم مِن الآلاء والنِّعَم المُتَظاهِرَة ما لا يَشُكُّ في الله؟{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٨٠٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿قالُوا يا صالِحُ قَدْ كُنْتَ فِينا مَرْجُوًّا قَبْلَ هَذا﴾</span> يعني: مأمولًا قبل هذا كُنّا نرجو أن ترجع إلى ديننا، فما هذا الذي تدعونا إليه؟ <span class="qpc-hafs">﴿أتَنْهانا أنْ نَعْبُدَ ما يَعْبُدُ آباؤُنا﴾</span> مِن الآلهة، <span class="qpc-hafs">﴿وإنَّنا لَفِي شَكٍّ مِمّا تَدْعُونا إلَيْهِ﴾</span> مِن التوحيد <span class="qpc-hafs">﴿مُرِيبٍ﴾</span> يعني بالمريب: أنّهم لا يعرفون شكَّهم{2}<span class=comment-ref>٣٢٤٣</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٣٢٤٣</span> ذكر <u>ابنُ عطية</u> (٤/٦٠٠) أنّ النقاش حكى عن بعضِهم في: <span class="qpc-hafs">﴿مَرْجُوًّا﴾</span> أنّ معناه: حقيرًا، ثم <span class="comment-type-2">انتَقَدَه</span> <span class="mustanad">مِن جهةِ اللغة</span>، و<span class="comment-type-1">وجَّهه</span> بقوله: «فأمّا أن يكون لفظ <span class="qpc-hafs">﴿مَرْجُوًّا﴾</span> بمعنى: حقير؛ فليس ذلك في كلام العرب، وإنما يتَّجه ذلك على جهة التفسير للمعنى، وذلك أنّ القصد بقولهم: <span class="qpc-hafs">﴿مَرْجُوًّا﴾</span> يكون: لقد كنت فينا سهلًا مرامُك، قريبًا ردُّ أمرك، مِمَّن لا يُظَنُّ أن يَسْتَفْحِلَ مِن أمره مثل هذا، فمعنى مرجوّ: أي مرجوّ اطِّراحه وغلبته ونحو هذا، فيكون ذلك على جهة الاحتقار، فلذلك فُسِّر بحقير، ويشبه هذا المعنى قول أبي سفيان بن حرب: لقد أمِرَ أمْرُ ابن أبي كَبْشَة».</div></p></div>",footnotes:1:أخرجه ابن أبي حاتم ٦/٢٠٤٨. كذلك أورده في تفسير قوله تعلى: <span class="qpc-hafs">﴿قالَتْ رُسُلُهُمْ أفِي اللَّهِ شَكٌّ فاطِرِ السَّماواتِ والأَرْضِ﴾</span> [إبراهيم:١٠]، وهو ألصق بسياقها.|2:تفسير مقاتل بن سليمان ٢/٢٨٨.