tafsir[9]{c,v,t}:
11,54," <q>﴿إِن نَّقُولُ إِلَّا ٱعۡتَرَىٰكَ بَعۡضُ ءَالِهَتِنَا بِسُوۤءࣲۗ﴾</q> - تفسير ٣٥٧٥٥- عن عبد الله بن عباس -من طريق عطية العوفي- في قوله: <q>﴿إن نقول إلا اعتراك بعض آلهتنا بسوء﴾</q>، قال: أصابَتْك بالجنون{1}. (٨/٨٥) ٣٥٧٥٦- عن مجاهد بن جبر -من طريق ابن أبي نَجِيح- <q>﴿اعتراك بعض آلهتنا بسوء﴾</q>، قال: أصابَتْكَ الأوثانُ بجنون{2}. (٨/٨٥) ٣٥٧٥٧- عن مجاهد بن جبر -من طريق عيسى- <q>﴿إلا اعتراك بعض آلهتنا بسوء﴾</q>، قال: سَبَبْتَ آلهتَنا وعِبْتَها فأَجَنَّتْكَ{1}. (ز) ٣٥٧٥٨- عن الضحاك بن مزاحم -من طريق عبيد- <q>﴿إنْ نَقُولُ إلّا اعْتَراكَ بَعْضُ آلِهَتِنا بِسُوءٍ﴾</q>، يقولون: نخشى أن يُصِيبك مِن آلهتنا سوء، ولا نُحِبُّ أن تعتريك، يقولون: يصيبك منها سوء{4}. (ز) ٣٥٧٥٩- عن قتادة بن دعامة -من طريق مَعْمَر- في الآية، قال: ما يحملك على ذمِّ آلهتنا إلا أنّه قد أصابك منها سوء{5}. (٨/٨٥) ٣٥٧٦٠- عن عبد الله بن كثير -من طريق ابن جريج-: أصابَتْك آلهتُنا بِشَرٍّ{4}. (ز) ٣٥٧٦١- قال مقاتل بن سليمان: <q>﴿إنْ﴾</q> يعني: ما <q>﴿نَقُولُ إلّا اعْتَراكَ﴾</q> يعنون: جنونًا أصابك به <q>﴿بَعْضُ آلِهَتِنا بِسُوءٍ﴾</q> يعنون: أنّه يعتريك مِن آلهتنا الأوثانُ بجنون أو بِخَبَل، ولا نُحِبُّ أن يصيبك أو يعتريك ذلك، فاجتنبها سالِمًا{7}. (ز) ٣٥٧٦٢- قال عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿إنْ نَقُولُ إلّا اعْتَراكَ بَعْضُ آلِهَتِنا بِسُوءٍ﴾</q>، يقولون: اختلَط عقلُك، فأصابك هذا مِمّا صَنَعَتْ بِكَ آلِهَتُنا{4}. (ز) ",footnotes:1:أخرجه ابن جرير ١٢/٤٤٧.تفسير مجاهد ص٣٨٩، وأخرجه ابن جرير ١٢/٤٤٧، وابن أبي حاتم ٦/٢٠٤٦. وعزاه السيوطي إلى ابن المنذر، وأبي الشيخ.أخرجه ابن جرير ١٢/٤٤٧.أخرجه ابن جرير ١٢/٤٤٨.أخرجه عبد الرزاق ١/٣٠٤، وابن جرير ١٢/٤٤٨، وابن أبي حاتم ٦/٢٠٤٦. وعزاه السيوطي إلى أبي الشيخ.أخرجه ابن جرير ١٢/٤٤٨.تفسير مقاتل بن سليمان ٢/٢٨٦.أخرجه ابن جرير ١٢/٤٤٨.
11,55," <q>﴿قَالَ إِنِّیۤ أُشۡهِدُ ٱللَّهَ وَٱشۡهَدُوۤا۟ أَنِّی بَرِیۤءࣱ مِّمَّا تُشۡرِكُونَ ۝٥٤ مِن دُونِهِۦۖ فَكِیدُونِی جَمِیعࣰا ثُمَّ لَا تُنظِرُونِ ۝٥٥﴾</q> - تفسير ٣٥٧٦٣- قال مقاتل بن سليمان: فرَدَّ عليهم هود: <q>﴿قالَ إنِّي أُشْهِدُ اللَّهَ واشْهَدُوا أنِّي بَرِيءٌ مِمّا تُشْرِكُونَ مِن دُونِهِ﴾</q> مِن الآلهة، <q>﴿فَكِيدُونِي جَمِيعًا﴾</q> أنتم والآلهة، <q>﴿ثُمَّ لا تُنْظِرُونِ﴾</q> يعني: ثُمَّ لا تُناظِرون، يعني: لا تُمْهِلون{1}. (ز) ٣٥٧٦٤- عن محمد بن إسحاق -من طريق سلمة– قال: <q>﴿إني أشهد الله واشهدوا أني بريء مما تشركون من دونه﴾</q> أي: إنِّي قد كفرتُ بآلهتكم التي تزعمون أنّها أصابَتْنِي بالجنون، فلْتُصِبْنِي بما هو أعظمَ مِن ذلك، إنِّي قد كفرتُ بها، <q>﴿فكيدوني جميعا﴾</q> أي: فكيدوني أنتم ومَن معكم جميعًا{2}. (ز) <q>﴿قَالَ إِنِّیۤ أُشۡهِدُ ٱللَّهَ وَٱشۡهَدُوۤا۟ أَنِّی بَرِیۤءࣱ مِّمَّا تُشۡرِكُونَ ۝٥٤ مِن دُونِهِۦۖ فَكِیدُونِی جَمِیعࣰا ثُمَّ لَا تُنظِرُونِ ۝٥٥﴾</q> - آثار متعلقة بالآية ٣٥٧٦٥- عن محمد بن مهاجر، قال: كان عمر جالِسًا وهو يَشُقُّ عليه الجلوس، فكان مُتَّكِئًا وعنده يومئذٍ سعيد بن خالد، وعنبسة بن سعيد، وأناسٌ مِن بني عمِّه، فقال: يا بني عمِّ، أسألكم صنع أما لكم كذا{3}! قالوا: بلى. قال سعيد بن خالد -وكانت فيه أعْرابِيَّةٌ-: واللهِ، إنّك لَتُرِيد أمرًا لا تناله حتى تنالَ السماء. قال: فاستوى قاعِدًا، ثم قال: <q>﴿فَكِيدُونِي جَمِيعًا ثُمَّ لا تُنْظِرُونِ﴾</q>. قال: فقال عنبسة بن سعيد: يا أمير المؤمنين، أما لنا قرابة؟ أما لنا حقٌّ؟ قال: بلى، ولكِنِّي -واللهِ- ما لكم فيه إلا كالرجل في حضرموت راعي غنم. قال: فلمّا سَمِعوها افترقوا، ولحقوا بمنازلهم{2}. (ز) ",footnotes:1:تفسير مقاتل بن سليمان ٢/٢٨٦.أخرجه ابن أبي حاتم ٦/٢٠٤٦.كذا جاءت العبارة في المطبوع.أخرجه ابن أبي حاتم ٦/٢٠٤٦.
11,56," <q>﴿إِنِّی تَوَكَّلۡتُ عَلَى ٱللَّهِ رَبِّی وَرَبِّكُمۚ﴾</q> - تفسير ٣٥٧٦٦- قال مقاتل بن سليمان: <q>﴿إنِّي تَوَكَّلْتُ عَلى اللَّهِ﴾</q> يعني: وثِقْتُ بالله <q>﴿رَبِّي ورَبِّكُمْ﴾</q> حين خوَّفُوه آلهتَهم أنّها تُصِيبُه{1}. (ز) <q>﴿مَّا مِن دَاۤبَّةٍ إِلَّا هُوَ ءَاخِذُۢ بِنَاصِیَتِهَاۤۚ﴾</q> - تفسير ٣٥٧٦٧- قال الضحاك بن مُزاحِم: يُحْيِيها، ويُميتها{2}. (ز) ٣٥٧٦٨- عن أيفع بن عبد الكلاعي -من طريق صفوان بن عمرو- قال في قوله: <q>﴿ما من دابة إلا هو آخذ بناصيتها إن ربي على صراط مستقيم﴾</q>، قال: فيأخذ بنواصي عبادِه، فيلِين للمؤمن حتى يكون لهم ألْيَنَ مِن الوالد بولده، ويُقال للكافر: <q>﴿ما غرك بربك الكريم﴾</q> [الانفطار:٦]{3}. (ز) ٣٥٧٦٩- قال مقاتل بن سليمان: <q>﴿ما مِن دابَّةٍ﴾</q> يعني: ما مِن شيء <q>﴿إلّا هُوَ آخِذٌ بِناصِيَتِها﴾</q> يقول: إلا اللهُ يُمِيتُها{1}. (ز) <q>﴿إِنَّ رَبِّی عَلَىٰ صِرَ ٰ⁠طࣲ مُّسۡتَقِیمࣲ ۝٥٦﴾</q> - تفسير ٣٥٧٧٠- عن مجاهد بن جبر -من طريق ابن أبي نجيح- <q>﴿إن ربي على صراط مستقيم﴾</q>، قال: الحق{5}. (٨/٨٦) ٣٥٧٧١- قال مقاتل بن سليمان: <q>﴿إنَّ رَبِّي عَلى صِراطٍ مُسْتَقِيمٍ﴾</q>، يعني: على الحق المستقيم{1}٣٢٣٦. (ز) ٣٢٣٦ نقل ابنُ القيم (٢/٥٦-٥٧) عن ابن الأنباري في قوله: <q>﴿إن ربي على صراط مستقيم﴾</q> قولين، فقال: «وقال ابن الأنباري: لَمّا قال: <q>﴿هُوَ آخِذٌ بِناصِيَتِها﴾</q> كان في معنى: لا يخرج مِن قبضته، وأنّه قاهِرٌ بعظيم سلطانه لكل دابة، فأتبع قوله: <q>﴿إنَّ رَبِّي عَلى صِراطٍ مُسْتَقِيمٍ﴾</q>. قال: وهذا نحو كلام العرب إذا وصَفُوا بحسن السيرة والعدل والإنصاف قالوا: فلان على طريقة حسنة، وليس ثمَّ طريق. ثم ذكر وجهًا آخر، فقال:»لَمّا ذكر أنّ سلطانه قد قهر كل دابة أتبع هذا قوله: <q>﴿إنَّ رَبِّي عَلى صِراطٍ مُسْتَقِيمٍ﴾</q>، أي: لا تخفى عليه مشيئتُه، ولا يعدل عنه هارِبٌ، فذكر الصراط المستقيم وهو يعني به: الطريق الذي لا يكون لأحد مسلك إلا عليه، كما قال: <q>﴿إنَّ رَبَّكَ لَبِالمِرْصادِ﴾</q> [الفجر:١٤]«. ثم وجّه ابنُ القيم معنى الآية على القولين، فقال:»فعلى هذا القول الأول يكون المراد: أنّه في تصرُّفه في ملكه يتصرَّف بالعدل، ومجازاة المحسن بإحسانه والمسيء بإساءته، ولا يظلم مثقال ذرة، ولا يُعاقِب أحدًا بما لم يَجْنِه، ولا يهضمه ثوابَ ما عمله، ولا يحمل عليه ذنبَ غيره، ولا يأخذ أحدًا بجريرة أحد، ولا يُكَلِّف نفسًا ما لا تطيقه، فيكون من باب: له الملك وله الحمد، ومن باب: ماضٍ فِيَّ حُكْمُك عدلٌ فِيَّ قضاؤك، ومن باب: الحمد لله رب العالمين، أي: كما أنّه رب العالمين المتصرف فيهم بقدرته ومشيئته فهو المحمود على هذا التصرف، وله الحمد على جميعه. وعلى القول الثاني المراد به: التهديد والوعيد، وأنّ مصير العباد إليه، وطريقهم عليه، لا يفوته منهم أحد، كما قال تعالى: <q>﴿قالَ هَذا صِراطٌ عَلَيَّ مُسْتَقِيمٌ﴾</q> [الحجر:٤١]". <q>﴿إِنَّ رَبِّی عَلَىٰ صِرَ ٰ⁠طࣲ مُّسۡتَقِیمࣲ ۝٥٦﴾</q> - آثار متعلقة بالآية ٣٥٧٧٢- عن يحيى بن سعيد، قال: ما مِن أحد يخاف لِصًّا عادِيًا، أو سَبُعًا ضارِيًا، أو شيطانًا مارِدًا، فيتلو هذه الآية: <q>﴿إني توكلت على الله ربي وربكم ما من دابة إلا هو آخذ بناصيتها إن ربي على صراط مستقيم﴾</q>؛ إلّا صَرَفَه اللهُ عنه{7}. (٨/٨٥) ",footnotes:1:تفسير مقاتل بن سليمان ٢/٢٨٦.تفسير الثعلبي ٥/١٧٤، وتفسير البغوي ٤/١٨٣.أخرجه ابن أبي حاتم ٦/٢٠٤٧. وفي تفسير ابن كثير بلفظ: فيلقى المؤمن، بدل: فيلين للمؤمن.تفسير مقاتل بن سليمان ٢/٢٨٦.تفسير مجاهد ص٣٨٩، وأخرجه ابن جرير ١٢/٤٥٠. وعزاه السيوطي إلى أبي الشيخ.تفسير مقاتل بن سليمان ٢/٢٨٦.عزاه السيوطي إلى ابن أبي حاتم.
11,57," <q>﴿فَإِن تَوَلَّوۡا۟ فَقَدۡ أَبۡلَغۡتُكُم مَّاۤ أُرۡسِلۡتُ بِهِۦۤ إِلَیۡكُمۡۚ﴾</q> - تفسير ٣٥٧٧٣- عن عبد الله بن عباس -من طريق علي بن أبي طلحة- <q>﴿فإن تولوا﴾</q>، يعني: الكُفّار{1}. (ز) ٣٥٧٧٤- قال مقاتل بن سليمان: <q>﴿فَإنْ تَوَلَّوْا﴾</q> يعني: فإن تُعْرِضُوا عن الإيمان، <q>﴿فَقَدْ أبْلَغْتُكُمْ ما أُرْسِلْتُ بِهِ إلَيْكُمْ﴾</q> مِن نزول العذاب بكم في الدنيا{2}. (ز) <q>﴿وَیَسۡتَخۡلِفُ رَبِّی قَوۡمًا غَیۡرَكُمۡ﴾</q> - تفسير ٣٥٧٧٥- عن أبي سعيد الخدري -من طريق الوليد بن قيس- قال: الخَلَف مِن بعد ستين سنة{3}. (ز) ٣٥٧٧٦- قال مقاتل بن سليمان: <q>﴿ويَسْتَخْلِفُ رَبِّي﴾</q> بعد هلاككم <q>﴿قَوْمًا غَيْرَكُمْ﴾</q> أمثلَ وأطوعَ لله منكم{4}. (ز) <q>﴿وَلَا تَضُرُّونَهُۥ شَیۡـًٔاۚ إِنَّ رَبِّی عَلَىٰ كُلِّ شَیۡءٍ حَفِیظࣱ ۝٥٧﴾</q> - قراءات ٣٥٧٧٧- عن الأعمش، في قراءة عبد الله [بن مسعود]: (ولا تَنقُصُوهُ شَيْئًا) مكان <q>﴿ولا تضرونه شيئا﴾</q>{5}. (ز) <q>﴿وَلَا تَضُرُّونَهُۥ شَیۡـًٔاۚ إِنَّ رَبِّی عَلَىٰ كُلِّ شَیۡءٍ حَفِیظࣱ ۝٥٧﴾</q> - تفسير الآية ٣٥٧٧٨- قال مقاتل بن سليمان: <q>﴿ولا تَضُرُّونَهُ شَيْئًا﴾</q> يقول: ولا تنقصونه مِن مُلكه شيئًا، إنّما تنقصون أنفسكم، <q>﴿إنَّ رَبِّي عَلى كُلِّ شَيْءٍ﴾</q> مِن أعمالكم <q>﴿حَفِيظٌ﴾</q>{4}٣٢٣٧. (ز) ٣٢٣٧ ذكر ابنُ عطية (٤/٥٩٧) في الآية قولين، فقال: «وقوله:<q>﴿ولا تَضُرُّونَهُ شَيْئًا﴾</q> يحتمل من المعنى وجهين: أحدهما: ولا تضرونه بذهابكم وهلاككم شيئًا، أي: لا ينتقص ملكه، ولا يختل أمرُه، وعلى هذا المعنى قرأ ابن مسعود: (ولا تَنقُصُونَهُ شَيْئًا». والمعنى الآخر: <q>﴿ولا تَضُرُّونَهُ﴾</q> أي ولا تقدرون إذا أهلككم على إضراره بشيء، ولا على الانتصار منه، ولا تقابلون فعله بكم بشيء يضره". ",footnotes:1:أخرجه ابن أبي حاتم ٦/٢٠٤٧.تفسير مقاتل بن سليمان ٢/٢٨٦-٢٨٧.أخرجه ابن أبي حاتم ٦/٢٠٤٧. وأورده قبل ذلك ٥/١٦٠٦ في تفسير قوله تعالى: <q>﴿فَخَلَفَ مِن بَعْدِهِمْ خَلْفٌ﴾</q> [الأعراف:١٦٩].تفسير مقاتل بن سليمان ٢/٢٨٧.أخرجه ابن أبي داود في المصاحف ١/٣١٩. وهي قراءة شاذة. انظر: البحر المحيط ٥/٢٣٤.تفسير مقاتل بن سليمان ٢/٢٨٧.
11,58," <q>﴿وَلَمَّا جَاۤءَ أَمۡرُنَا نَجَّیۡنَا هُودࣰا وَٱلَّذِینَ ءَامَنُوا۟ مَعَهُۥ بِرَحۡمَةࣲ مِّنَّا﴾</q> - تفسير ٣٥٧٧٩- قال مقاتل بن سليمان: <q>﴿ولَمّا جاءَ أمْرُنا﴾</q> يعني: قولنا في نزول العذاب <q>﴿نَجَّيْنا هُودًا والَّذِينَ آمَنُوا مَعَهُ﴾</q> مِن العذاب <q>﴿بِرَحْمَةٍ مِنّا﴾</q> يعني: بنِعمةٍ مِنّا عليهم{1}. (ز) <q>﴿وَنَجَّیۡنَـٰهُم مِّنۡ عَذَابٍ غَلِیظࣲ ۝٥٨﴾</q> - تفسير ٣٥٧٨٠- عن أبي مالك غَزْوان الغفاري -من طريق السدي- في قوله: <q>﴿عذاب غليظ﴾</q>، قال: شديد{2}. (٨/٨٦) ٣٥٧٨١- قال مقاتل بن سليمان: <q>﴿ونَجَّيْناهُمْ مِن عَذابٍ غَلِيظٍ﴾</q>، يعني: شديد، وهي الريح الباردة لم تفتر عنهم حتى أهلكتهم{1}٣٢٣٨. (ز) ٣٢٣٨ ذكر ابنُ عطية (٤/٥٩٧) في قوله: <q>﴿ونجيناهم من عذاب غليظ﴾</q> احتمالين، فقال: «وقوله: <q>﴿ونَجَّيْناهُمْ مِن عَذابٍ غَلِيظٍ﴾</q> يحتمل أن يريد: عذاب الآخرة. ويحتمل أن يريد: وكانت النجاة المتقدمة مِن عذاب غليظ، يريد: الريح؛ فيكون المقصود على هذا تعديد النعمة». ",footnotes:1:تفسير مقاتل بن سليمان ٢/٢٨٧.أخرجه ابن أبي حاتم ٦/٢٠٤٧.تفسير مقاتل بن سليمان ٢/٢٨٧.
11,59," <q>﴿وَتِلۡكَ عَادࣱۖ جَحَدُوا۟ بِـَٔایَـٰتِ رَبِّهِمۡ وَعَصَوۡا۟ رُسُلَهُۥ﴾</q> - تفسير ٣٥٧٨٢- قال مقاتل بن سليمان: <q>﴿وتِلْكَ عادٌ جَحَدُوا بِآياتِ رَبِّهِمْ﴾</q> يعني: كفروا بعذاب الله بأنّه غير نازِل بهم في الدنيا، <q>﴿وعَصَوْا رُسُلَهُ﴾</q> يعني: هودًا وحده{1}٣٢٣٩. (ز) ٣٢٣٩ ذكر ابنُ عطية (٤/٥٩٨) ما أفاده قولُ مقاتل في تفسير قوله: <q>﴿وعصوا رسله﴾</q> مِن أنه هود وحده، وذكر احتمالًا آخر أن يكون ذلك: «شنعة عليهم؛ وذلك أنّ في تكذيب رسولٍ واحدٍ تكذيبُ سائر الرسل وعصيانهم؛ إذ النبوات كلها مُجْمِعَةٌ على الإيمان بالله، والإقرار بربوبيته». <q>﴿وَٱتَّبَعُوۤا۟ أَمۡرَ كُلِّ جَبَّارٍ عَنِیدࣲ ۝٥٩﴾</q> - تفسير ٣٥٧٨٣- عن إبراهيم النخعي: <q>﴿عنيد﴾</q>، قال: مُناكِب{2} عن الحقِّ{3}. (٨/٨٦) ٣٥٧٨٤- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿كل جبار عنيد﴾</q>: المُشْرِك{4}٣٢٤٠. (٨/٨٦) ٣٢٤٠ لم يذكر ابنُ جرير (١٢/٤٥٢) غير قول قتادة. ٣٥٧٨٥- عن إسماعيل السُّدِّيّ -من طريق أسباط- قال: <q>﴿كل جبار عنيد﴾</q>، قال: المُشاقّ{5}. (٨/٨٦) ٣٥٧٨٦- قال مقاتل بن سليمان: <q>﴿واتَّبَعُوا أمْرَ كُلِّ جَبّارٍ عَنِيدٍ﴾</q> يعني: مُتَعَظِّمًا عن التوحيد، فهم الأتباع، اتَّبَعُوا قولَ الكُبَراء في تكذيب هود، <q>﴿عَنِيدٍ﴾</q> يعني: مُعْرِضًا عن الحق، وكان هذا القولُ مِن الكبراء للسفلة فى سورة المؤمنين [٣٣-٣٤]: <q>﴿ما هَذا﴾</q> يعني: هودًا <q>﴿إلّا بَشَرٌ مِثْلُكُمْ يَأْكُلُ مِمّا تَأْكُلُونَ مِنهُ ويَشْرَبُ مِمّا تَشْرَبُونَ﴾</q> من الشراب. وقال للأتباع: <q>﴿ولَئِنْ أطَعْتُمْ بَشَرًا مِثْلَكُمْ إنَّكُمْ إذًا لَخاسِرُونَ﴾</q> يعني: لَعَجَزَة، فهذا قولُ الكبراء للسَّفِلة. فاتَّبعوهم على قولهم{1}. (ز) ",footnotes:1:تفسير مقاتل بن سليمان ٢/٢٨٧.نكب فلان عن الصواب: إذا عدل عنه. لسان العرب (نكب).عزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ١٢/٤٥٢، وابن أبي حاتم ٦/٢٤٠٧. وعزاه السيوطي إلى أبي الشيخ.أخرجه ابن أبي حاتم ٦/٢٠٤٨. وعزاه السيوطي إلى أبي الشيخ.تفسير مقاتل بن سليمان ٢/٢٨٧.
11,60," <q>﴿وَأُتۡبِعُوا۟ فِی هَـٰذِهِ ٱلدُّنۡیَا لَعۡنَةࣰ وَیَوۡمَ ٱلۡقِیَـٰمَةِۗ أَلَاۤ إِنَّ عَادࣰا كَفَرُوا۟ رَبَّهُمۡۗ أَلَا بُعۡدࣰا لِّعَادࣲ قَوۡمِ هُودࣲ ۝٦٠﴾</q> - تفسير ٣٥٧٨٧- عن مجاهد بن جبر، في قوله: <q>﴿وأتبعوا في هذه الدنيا لعنة ويوم القيامة﴾</q>، قال: لعنة أخرى{1}. (٨/٨٧) ٣٥٧٨٨- عن قتادة بن دعامة، في الآية، قال: تَتابَعَتْ عليهم لعنتان مِن الله؛ لعنة في الدنيا، ولعنة في الآخرة{2}. (٨/٨٧) ٣٥٧٨٩- عن إسماعيل السُّدِّيّ -من طريق أسباط- في قوله: <q>﴿وأتبعوا في هذه الدنيا لعنة﴾</q>، قال: لم يُبعث نبيٌّ بعد عادٍ إلا لُعِنت عادٌ على لسانه{3}. (٨/٨٧) ٣٥٧٩٠- قال مقاتل بن سليمان: <q>﴿وأُتْبِعُوا فِي هَذِهِ الدُّنْيا لَعْنَةً﴾</q> يعني: العذاب، وهي الرِّيح التي أهلكتهم، <q>﴿ويَوْمَ القِيامَةِ﴾</q> يعني: عذاب النار، <q>﴿ألا إنَّ عادًا كَفَرُوا رَبَّهُمْ﴾</q> يعني: بتوحيد ربهم، <q>﴿ألا بعدا لعاد قوم هود﴾</q>{4}٣٢٤١. (ز) ٣٢٤١ قال ابنُ جرير (١٢/٤٥٢): «وقيل: إنّ معنى <q>﴿كفروا ربهم﴾</q>: كفروا نعمة ربهم». ",footnotes:1:عزاه السيوطي إلى أبي الشيخ.عزاه السيوطي إلى ابن المنذر، وأبي الشيخ.أخرجه ابن أبي حاتم ٦/٢٠٤٨. وعزاه السيوطي إلى أبي الشيخ.تفسير مقاتل بن سليمان ٢/٢٨٧-٢٨٨.
11,61," <q>﴿وَإِلَىٰ ثَمُودَ أَخَاهُمۡ صَـٰلِحࣰاۚ قَالَ یَـٰقَوۡمِ ٱعۡبُدُوا۟ ٱللَّهَ مَا لَكُم مِّنۡ إِلَـٰهٍ غَیۡرُهُۥۖ﴾</q> - تفسير ٣٥٧٩١- عن قتادة بن دعامة -من طريق سعيد بن بشير-: أنّ صالحًا بُعِث مِن الحِجْرِ{1}. (ز) ٣٥٧٩٢- قال مقاتل بن سليمان: <q>﴿وإلى ثَمُودَ﴾</q> أرْسَلْنا <q>﴿أخاهُمْ صالِحًا﴾</q> ليس بأخيهم في الدِّين، ولَكِنَّه أخوهم في النَّسَب، وهو صالح بن آسف، <q>﴿قالَ يا قَوْمِ اعْبُدُوا اللَّهَ﴾</q> يعني: وحِّدوا اللهَ، <q>﴿ما لَكُمْ مِن إلَهٍ غَيْرُهُ﴾</q>{2}. (ز) <q>﴿هُوَ أَنشَأَكُم مِّنَ ٱلۡأَرۡضِ﴾</q> - تفسير ٣٥٧٩٣- عن إسماعيل السُّدِّيّ، <q>﴿هو أنشأكم من الأرض﴾</q>، قال: خَلَقَكم مِن الأرض{3}. (٨/٨٧) ٣٥٧٩٤- قال مقاتل بن سليمان: <q>﴿هُوَ أنْشَأَكُمْ مِنَ الأَرْضِ﴾</q>، يعني: هو خَلَقَكم مِن الأرض{2}. (ز) <q>﴿وَٱسۡتَعۡمَرَكُمۡ فِیهَا﴾</q> - تفسير ٣٥٧٩٥- قال عبد الله بن عباس: أعاشَكُم فيها{5}. (ز) ٣٥٧٩٦- عن مجاهد بن جبر -من طريق ابن أبي نَجِيح- <q>﴿واستعمركم فيها﴾</q>، قال: أعْمَرَكم فيها{6}٣٢٤٢. (٨/٨٧) ٣٢٤٢ لم يذكر ابنُ جرير (١٢/٤٥٣) في معنى: <q>﴿واسْتَعْمَرَكُمْ فِيها﴾</q> سوى قول مجاهد مِن طريق ابن أبي نجيح. ٣٥٧٩٧- قال الضحاك بن مُزاحِم: أطال عُمْرَكم فيها، حتّى كان الواحدُ مِنهم يعيشُ ثلاثمائة سنة إلى ألف سنة، وكذلك قوم عاد{7}. (ز) ٣٥٧٩٨- قال قتادة بن دعامة: أسْكَنَكُم فيها{8}. (ز) ٣٥٧٩٩- قال مقاتل بن سليمان: <q>﴿واسْتَعْمَرَكُمْ فِيها﴾</q>، يعني: وعمركم في الأرض{2}. (ز) ٣٥٨٠٠- عن عبد الرحمن بن زيد بن أسلم -من طريق أصبغ- <q>﴿واستعمركم فيها﴾</q>، قال: اسْتَخْلَفَكم فيها{1}. (٨/٨٧) <q>﴿فَٱسۡتَغۡفِرُوهُ ثُمَّ تُوبُوۤا۟ إِلَیۡهِۚ إِنَّ رَبِّی قَرِیبࣱ مُّجِیبࣱ ۝٦١﴾</q> - تفسير ٣٥٨٠١- قال مقاتل بن سليمان: <q>﴿فاسْتَغْفِرُوهُ﴾</q> مِن الشِّرْك، <q>﴿ثُمَّ تُوبُوا إلَيْهِ﴾</q> مِنه، <q>﴿إنَّ رَبِّي قَرِيبٌ﴾</q> مِنكم في الاستجابة، <q>﴿مُجِيبٌ﴾</q> للدُّعاء، كقوله: <q>﴿فَإنِّي قَرِيبٌ أُجِيبُ دَعْوَةَ الدّاعِ إذا دَعانِ﴾</q> [البقرة:١٨٦]{2}. (ز) ",footnotes:1:أخرجه ابن أبي حاتم ٦/٢٠٤٨.تفسير مقاتل بن سليمان ٢/٢٨٨.عزاه السيوطي إلى أبي الشيخ.تفسير مقاتل بن سليمان ٢/٢٨٨.تفسير الثعلبي ٥/١٧٦.تفسير مجاهد ص٣٨٩، وأخرجه ابن جرير ١٢/٤٥٣، وابن أبي حاتم ٦/٢٠٤٨. وعزاه السيوطي إلى أبي الشيخ.تفسير البغوي ٤/١٨٥، وفي تفسير الثعلبي ٥/١٧٦ مختصرًا.تفسير الثعلبي ٥/١٧٦، وتفسير البغوي ٤/١٨٥.تفسير مقاتل بن سليمان ٢/٢٨٨.أخرجه ابن أبي حاتم ٦/٢٠٤٨.تفسير مقاتل بن سليمان ٢/٢٨٨.
11,62," <q>﴿قَالُوا۟ یَـٰصَـٰلِحُ قَدۡ كُنتَ فِینَا مَرۡجُوࣰّا قَبۡلَ هَـٰذَاۤۖ أَتَنۡهَىٰنَاۤ أَن نَّعۡبُدَ مَا یَعۡبُدُ ءَابَاۤؤُنَا وَإِنَّنَا لَفِی شَكࣲّ مِّمَّا تَدۡعُونَاۤ إِلَیۡهِ مُرِیبࣲ ۝٦٢﴾</q> - تفسير ٣٥٨٠٢- عن قتادة بن دعامة -من طريق سعيد- قوله: <q>﴿وإننا لفي شك مما تدعونا إليه مريب﴾</q>: وكَذَبُوا، واللهِ، ما في الله شكٌّ، أفي مَن فَطَر السماء والأرض؟ وأنزل مِن السماء ماءً فأخرج به من الثمرات رزقًا لكم، وأَظْهَرَ لكم مِن الآلاء والنِّعَم المُتَظاهِرَة ما لا يَشُكُّ في الله؟{1}. (ز) ٣٥٨٠٣- قال مقاتل بن سليمان: <q>﴿قالُوا يا صالِحُ قَدْ كُنْتَ فِينا مَرْجُوًّا قَبْلَ هَذا﴾</q> يعني: مأمولًا قبل هذا كُنّا نرجو أن ترجع إلى ديننا، فما هذا الذي تدعونا إليه؟ <q>﴿أتَنْهانا أنْ نَعْبُدَ ما يَعْبُدُ آباؤُنا﴾</q> مِن الآلهة، <q>﴿وإنَّنا لَفِي شَكٍّ مِمّا تَدْعُونا إلَيْهِ﴾</q> مِن التوحيد <q>﴿مُرِيبٍ﴾</q> يعني بالمريب: أنّهم لا يعرفون شكَّهم{2}٣٢٤٣. (ز) ٣٢٤٣ ذكر ابنُ عطية (٤/٦٠٠) أنّ النقاش حكى عن بعضِهم في: <q>﴿مَرْجُوًّا﴾</q> أنّ معناه: حقيرًا، ثم انتَقَدَه مِن جهةِ اللغة، ووجَّهه بقوله: «فأمّا أن يكون لفظ <q>﴿مَرْجُوًّا﴾</q> بمعنى: حقير؛ فليس ذلك في كلام العرب، وإنما يتَّجه ذلك على جهة التفسير للمعنى، وذلك أنّ القصد بقولهم: <q>﴿مَرْجُوًّا﴾</q> يكون: لقد كنت فينا سهلًا مرامُك، قريبًا ردُّ أمرك، مِمَّن لا يُظَنُّ أن يَسْتَفْحِلَ مِن أمره مثل هذا، فمعنى مرجوّ: أي مرجوّ اطِّراحه وغلبته ونحو هذا، فيكون ذلك على جهة الاحتقار، فلذلك فُسِّر بحقير، ويشبه هذا المعنى قول أبي سفيان بن حرب: لقد أمِرَ أمْرُ ابن أبي كَبْشَة». ",footnotes:1:أخرجه ابن أبي حاتم ٦/٢٠٤٨. كذلك أورده في تفسير قوله تعلى: <q>﴿قالَتْ رُسُلُهُمْ أفِي اللَّهِ شَكٌّ فاطِرِ السَّماواتِ والأَرْضِ﴾</q> [إبراهيم:١٠]، وهو ألصق بسياقها.تفسير مقاتل بن سليمان ٢/٢٨٨.
