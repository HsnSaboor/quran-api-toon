tafsir[8]{c,v,t}:
22,31," <q>﴿حُنَفَاۤءَ لِلَّهِ غَیۡرَ مُشۡرِكِینَ بِهِۦۚ﴾</q> - نزول الآية ٥٠٥٩٤- عن أبي بكر الصديق، قال: كان الناس يَحُجُّون، وهم مشركون، فكانوا يسمونهم: حنفاء الحجاج، فنزلت: <q>﴿حنفاء لله غير مشركين به﴾</q>{1}. (١٠/٤٨٩) <q>﴿حُنَفَاۤءَ لِلَّهِ غَیۡرَ مُشۡرِكِینَ بِهِۦۚ﴾</q> - تفسير الآية ٥٠٥٩٥- عن عبد الله بن عباس، في قوله: <q>﴿حنفاء لله غير مشركين به﴾</q>، قال: حُجّاجًا لله غير مشركين به؛ وذلك أنّ الجاهلية كانوا يَحُجُّون مشركين، فلمّا أظهر الله الإسلام قال الله للمسلمين: حُجُّوا الآن غير مشركين بالله{2}. (١٠/٤٨٩) ٥٠٥٩٦- عن عبد الله بن القاسم مولى أبي بكر الصديق، قال: كان ناسٌ مِن مُضَر وغيرِهم يَحُجُّون البيت، وهم مشركون، وكان مَن لا يَحُجُّ البيتَ مِن المشركين يقولون: قولوا: حنفاء. فقال الله: <q>﴿حنفاء لله غير مشركين به﴾</q>. يقول: حُجّاجًا غير مشركين به{1}. (١٠/٤٨٩) ٥٠٥٩٧- عن مجاهد بن جبر، <q>﴿حنفاء﴾</q>، قال: حُجّاجًا{4}. (١٠/٤٨٩) ٥٠٥٩٨- عن الضحاك بن مزاحم، مثله{4}. (١٠/٤٨٩) ٥٠٥٩٩- عن مجاهد بن جبر، <q>﴿حنفاء﴾</q>، قال: مُتَّبِعين{6}. (١٠/٤٩٠) ٥٠٦٠٠- عن إسماعيل السُّدِّيّ -من طريق سفيان- قال: الحُجّاج{7}. (ز) ٥٠٦٠١- عن إسماعيل السُّدِّيّ، قال: ما كان في القرآن مِن حنفاء، قال: مسلمين، وما كان حنفاء مسلمين فهم حُجّاج{8}. (١٠/٤٨٩) ٥٠٦٠٢- قال مقاتل بن سليمان: <q>﴿حنفاء لله﴾</q> يعني: مخلصين لله بالتوحيد، <q>﴿غير مشركين به﴾</q>{9}. (ز) ٥٠٦٠٣- قال يحيى بن سلّام: قوله: <q>﴿حنفاء لله﴾</q> مخلصين لله، وقال بعضهم: حُجّاجًا، أي: لله مخلصين، <q>﴿غير مشركين به﴾</q>{10}٤٤٦٦. (ز) ٤٤٦٦ انتقد ابنُ عطية (٦/٢٤٤) قول ابن عباس وما في معناه، فقال: «وهذا تخصيصٌ لا حُجَّة معه». <q>﴿وَمَن یُشۡرِكۡ بِٱللَّهِ فَكَأَنَّمَا خَرَّ مِنَ ٱلسَّمَاۤءِ فَتَخۡطَفُهُ ٱلطَّیۡرُ﴾</q> - تفسير ٥٠٦٠٤- عن قتادة بن دعامة -من طريق مَعْمَر- في قوله: <q>﴿ومن يشرك بالله فكأنما خر من السماء﴾</q> الآية، قال: هذا مَثَلٌ ضربه الله لِمَن أشرك بالله في بُعْدِه مِن الهُدى وهلاكه{11}. (١٠/٤٩٠) ٥٠٦٠٥- قال مقاتل بن سليمان: ثم عَظَّم الشِّرْك، فقال: <q>﴿ومن يشرك بالله فكأنما خر من السماء فتخطفه الطير﴾</q>، يعني: فتذهب به الطير النسور{9}. (ز) ٥٠٦٠٦- قال يحيى بن سلّام: قوله: <q>﴿ومن يشرك بالله فكأنما خر من السماء﴾</q> في البُعْد مِن الله{10}. (ز) <q>﴿أَوۡ تَهۡوِی بِهِ ٱلرِّیحُ فِی مَكَانࣲ سَحِیقࣲ ۝٣١﴾</q> - تفسير ٥٠٦٠٧- عن مجاهد بن جبر -من طريق ابن أبي نجيح، وابن جريج- في قوله: <q>﴿في مكان سحيق﴾</q>، قال: بعيد{14}. (١٠/٤٩٠) ٥٠٦٠٨- قال الحسن البصري: شَبَّه الله أعمال المشركين بالشيء يَخِرُّ مِن السماء فتخطفه الطير، فلا يصل إلى الأرض، أو تهوي به الريح في مكان سحيق، يعني: بعيد؛ فيذهب فلا يوجد له أصل، ولا يُرى له أثر{15}. (ز) ٥٠٦٠٩- تفسير إسماعيل السُّدِّيّ: <q>﴿في مكان﴾</q>، يعني: تذهب به الريح{16}. (ز) ٥٠٦١٠- قال مقاتل بن سليمان: <q>﴿أو تهوي به الريح في مكان سحيق﴾</q>، يعني: بعيدًا، فهذا مَثَل الشِّرك في البُعْد مِن الله ﷿{9}. (ز) ٥٠٦١١- قال يحيى بن سلّام: قوله: <q>﴿أو تهوي به الريح﴾</q> يعني: تذهب به الريح <q>﴿في مكان سحيق﴾</q> يعني: أنّه ليس لأعمال المشركين عند الله قرارٌ لهم به عنده خير في الآخرة{18}. (ز) ",footnotes:1:عزاه السيوطي إلى ابن أبي حاتم.عزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.عزاه السيوطي إلى ابن أبي حاتم.عزاه السيوطي إلى عبد بن حميد.عزاه السيوطي إلى عبد بن حميد.عزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.أخرجه الثوري في تفسيره ص٢١٢.عزاه السيوطي إلى ابن المنذر.تفسير مقاتل بن سليمان ٣/١٢٦.تفسير يحيى بن سلام ١/٣٧٠.أخرجه عبد الرزاق ٢/٣٨، وابن جرير ١٦/٥٣٨-٥٣٩. وعزاه السيوطي إلى ابن أبي حاتم.تفسير مقاتل بن سليمان ٣/١٢٦.تفسير يحيى بن سلام ١/٣٧٠.أخرجه ابن جرير ١٦/٥٣٩. وعلَّقه يحيى بن سلام ١/٣٧٠. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.علَّقه يحيى بن سلام ١/٣٧١.علَّقه يحيى بن سلام ١/٣٧٠.تفسير مقاتل بن سليمان ٣/١٢٦.تفسير يحيى بن سلام ١/٣٧٠-٣٧١.
22,32," <q>﴿ذَ ٰ⁠لِكَۖ وَمَن یُعَظِّمۡ شَعَـٰۤىِٕرَ ٱللَّهِ﴾</q> - تفسير ٥٠٦١٢- عن عبد الله بن عباس، في قوله: <q>﴿ومن يعظم شعائر الله﴾</q>، قال: البُدْن{1}. (١٠/٤٩٠) ٥٠٦١٣- عن عبد الله بن عباس -من طريق مقسم- في قوله: <q>﴿ذلك ومن يعظم شعائر الله﴾</q>، قال: الاسْتِسْمان، والاسْتِحْسان، والاسْتِعْظام{2}. (١٠/٤٩٠) ٥٠٦١٤- عن طارق بن أحمد، قال: كنت عند ابن عمر إذ جاءه رجلٌ، فقال: يا أبا عبد الرحمن، أيُّ الشعائر أعظم؟ قال: أوَفي شكٍّ أنت منه؟! هذا أعظم الشعائر. يعني: البيت{3}. (ز) ٥٠٦١٥- عن مجاهد بن جبر -من طريق القاسم بن أبي بزة- <q>﴿ذلك ومن يعظم شعائر الله﴾</q>، قال: استعظام البدن، واستسمانها، واستحسانها{4}. (١٠/٤٩٠) ٥٠٦١٦- عن عطاء [بن أبي رباح] -من طريق حبيب المعلم- أنّه سُئِل عن شعائر الله. قال: حرمات الله: اجتناب سخط الله، واتباع طاعته؛ فذلك شعائر الله{5}. (١٠/٤٩٢) ٥٠٦١٧- عن محمد بن أبي موسى -من طريق داود بن أبي هند- في قوله: <q>﴿ذلك ومن يعظم شعائر الله﴾</q>، قال: الوقوف بعرفة مِن شعائر الله، وبجَمْع مِن شعائر الله، والبُدْن من شعائر الله، ورمي الجمار من شعائر الله، والحَلْق مِن شعائر الله، فمَن يعظمها <q>﴿فإنها من تقوى القلوب﴾</q>{6}. (١٠/٤٩١) ٥٠٦١٨- تفسير الحسن البصري: شعائر الله: دين الله كله{7}. (ز) ٥٠٦١٩- قال مقاتل بن سليمان: <q>﴿ذلك﴾</q> يقول: هذا الذي أمر؛ اجتناب الأوثان، <q>﴿ومن يعظم شعائر الله﴾</q> يعني: البدن مَن أعْظَمَها وأَسْمَنَها{8}. (ز) ٥٠٦٢٠- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿ومن يعظم شعائر الله﴾</q>، قال: الشعائر: الجِمار، والصفا والمروة من شعائر الله، والمشعر الحرام، والمزدلفة. قال: والشعائر تدخل في الحرمِ، هي شعائر، وهي حرمٌ{9}٤٤٦٧. (ز) ٤٤٦٧ أفادت الآثار اختلاف المفسرين في معنى: «شعائر الله» في الآية؛ فقيل: إنها البدن، وتعظيمها: استحسانها، واستسمانها. وقيل: إنها مناسك الحج، وتعظيمها: إشعارها. ورجَّح ابنُ جرير (١٦/٥٤١) مستندًا إلى دلالة العموم شمول الآية لكلا المعنيين، فقال: «إن الله -تعالى ذِكْره- أخبر أنّ تعظيم شعائره، وهي ما جعله أعلامًا لخلقه فيما تعبَّدهم به من مناسك حجِّهم من الأماكن التي أمرهم بأداء ما افترض عليهم منها عندها، والأعمال التي ألزمهم عملها في حجهم: من تقوى قلوبهم، لم يَخْصُص من ذلك شيئًا، فتعظيم كل ذلك من تقوى القلوب كما قال -جلَّ ثناؤه-، وحقٌّ على عباده المؤمنين به تعظيم جميع ذلك». <q>﴿فَإِنَّهَا مِن تَقۡوَى ٱلۡقُلُوبِ ۝٣٢﴾</q> - تفسير ٥٠٦٢١- تفسير إسماعيل السُّدِّيّ: قوله: <q>﴿فإنها من تقوى القلوب﴾</q>، يعني: مِن إخلاص القلوب{7}. (ز) ٥٠٦٢٢- قال مقاتل بن سليمان: <q>﴿فإنها من تقوى القلوب﴾</q>، يعني: مِن إخلاص القلوب{8}. (ز) ",footnotes:1:عزاه السيوطي إلى ابن أبي حاتم.أخرجه ابن جرير ١٦/٥٤٠، وابن أبي حاتم -كما في تفسير ابن كثير ٥/٤١٦-، كما أخرجه ابن أبي شيبة (القسم الرابع من الجزء الرابع) ص٢٩٤ من طريق مجاهد بنحوه. وعزاه السيوطي إلى ابن المنذر.أخرجه يحيى بن سلام ١/٣٧١.أخرجه ابن أبي شيبة (القسم الرابع من الجزء الرابع) ص٢٩٥، وابن جرير ١٦/٥٤٠، ٥٤٢، ٥٤٨. وعلَّقه يحيى بن سلام ١/٣٧١. وعزاه السيوطي إلى عبد بن حميد، وابن أبي حاتم.أخرجه ابن أبي شيبة (القسم الأول من الجزء الرابع) ص٢٩٥.أخرجه ابن أبي شيبة (القسم الرابع من الجزء الرابع) ص٢٩٤-٢٩٥، وابن جرير ١٦/٥٤١، ٥٤٦. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.علَّقه يحيى بن سلام ١/٣٧١.تفسير مقاتل بن سليمان ٣/١٢٦.أخرجه ابن جرير ١٦/٥٤١.علَّقه يحيى بن سلام ١/٣٧١.تفسير مقاتل بن سليمان ٣/١٢٦.
22,33," <q>﴿لَكُمۡ فِیهَا مَنَـٰفِعُ إِلَىٰۤ أَجَلࣲ مُّسَمࣰّى﴾</q> - تفسير ٥٠٦٢٣- عن عبد الله بن عباس -من طريق أبي رزين- في قوله: <q>﴿لكم فيها منافع﴾</q>، قال: أسواقهم، فإنه لم يذكر منافع إلا للدنيا{1}. (ز) ٥٠٦٢٤- عن عبد الله بن عباس -من طريق عطاء- قال: الأجل المُسَمّى إلى أن تُقَلَّد{2} وتُشْعَر{3}، هي البدن ينتفع بظهورها، ويُستعان بها{4}. (ز) ٥٠٦٢٥- عن مجاهد بن جبر -من طريق ابن أبي نجيح- <q>﴿لكم فيها منافع إلى أجل مسمى﴾</q>، قال: في ظهورها، وألبانها، وأوبارها، وأشعارها، وأصوافها إلى أن تُسمّى: هَدْيًا، فإذا سُمِّيَت: هديًا ذهبت المنافع{5}. (١٠/٤٩٠) ٥٠٦٢٦- عن الضحاك بن مزاحم= (ز) ٥٠٦٢٧- وعطاء [بن أبي رباح]، قالا: المنافع فيها: الركوب إذا احتاج، وفي أوبارها، وألبانها. والأجل المُسَمّى: إلى أن تقلَّد فتصير بُدنًا{6}. (١٠/٤٩١) ٥٠٦٢٨- عن ابن جُرَيْج، قال: قال عطاء بن أبي رباح في قوله: <q>﴿لكم فيها منافع إلى أجل مسمى﴾</q>، قال: إلى أن تُنحَر. قال: له أن يحمل عليها المُعْي{7}، والمنقطع به، من الضرورة؛ كان النبي ﷺ يأمر بالبدنة إذا احتاج إليها سيِّدُها أن يحمل عليها، ويركب غير منهوكة. قلت لعطاء: ما؟ قال: الرجلُ الراجلُ، والمنقطع به، والمتبعُ، وإن نُتِجت أن يحمل عليها ولدها، ولا يشربَ من لبنها إلا فضلًا عن ولدها، فإن كان في لبنها فضل فليشرب مَن أهداها ومَن لم يُهدِها{8}. (ز) ٥٠٦٢٩- عن قتادة بن دعامة -من طريق ابن أبي نجيح- <q>﴿لكم فيها منافع إلى أجل مسمى﴾</q>، يقول: في ظهورها، وألبانها، فإذا قُلِّدَت فمحلها إلى البيت العتيق{9}. (ز) ٥٠٦٣٠- قال قتادة بن دعامة: <q>﴿إلى أجل مسمى﴾</q>، وهو أن يسميها، ويُوجِبَها هَدْيًا، فإذا فعل ذلك لم يكن له شيء مِن منافعها{10}. (ز) ٥٠٦٣١- عن ابن أبي نجيح -من طريق ابن علية- في قوله: <q>﴿لكم فيها منافع إلى أجل مسمى﴾</q>، قال: إلى أن توجبها بدنةً{9}. (ز) ٥٠٦٣٢- عن محمد بن أبي موسى، في قوله: <q>﴿لكم فيها منافع إلى أجل مسمى﴾</q>، قال: لكم في كل مشعر منها منافع حتى تخرجوا منه إلى غيره{12}. (١٠/٤٩٢) ٥٠٦٣٣- قال إسماعيل السُّدِّيّ: <q>﴿لكم فيها منافع إلى أجل مسمى﴾</q>، يقول: إلى أن تُقَلَّد، فإذا قُلِّدَت لم تُركَب لها ظهور، ولم يُشرَب لها لبن{13}. (ز) ٥٠٦٣٤- عن عطاء الخراساني -من طريق يونس- في قول الله: <q>﴿فيها منافع إلى أجل مسمى﴾</q>، قال: الأجل المسمى: إذا قُلِّدت البدن{14}. (ز) ٥٠٦٣٥- قال مقاتل بن سليمان: <q>﴿لكم فيها﴾</q> في البدن <q>﴿منافع﴾</q> في ظهورها وألبانها <q>﴿إلى أجل مسمى﴾</q> يقول: إلى أن تُقَلَّد، أو تُشْعَر، أو تُسَمّى: هدايا؛ فهذا الأجل المسمى، فإذا فعل ذلك بها لا يحمل عليها إلا مضطرًا، ويركبها بالمعروف، ويشرب فضل ولدها مِن اللبن، ولا يجهد الحلب حتى لا ينهك أجسامها{15}. (ز) ٥٠٦٣٦- قال سفيان الثوري، في قوله: <q>﴿إلى أجل مسمى﴾</q>، قال: إذا دُعِيَت، وسُمِّيَت: البُدُن{16}. (ز) ٥٠٦٣٧- قال عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿لكم فيها منافع إلى أجل مسمى ثم محلها إلى البيت العتيق﴾</q>، فقرأ قول الله: <q>﴿ومن يعظم شعائر الله فإنها من تقوى القلوب﴾</q>: لكم في تلك الشعائر منافع إلى أجل مسمى؛ إذا ذهبت تلك الأيام لم ترَ أحدًا يأتي عرفة يقف فيها يبتغي الأجر، ولا المزدلفة، ولا رمي الجمار، وقد ضربوا مِن البلدان لهذه الأيام التي فيها المنافع، وإنّما منافعُها إلى تلك الأيام، وهي الأجل المسمى، ثم محلها حين تنقضي تلك الأيام إلى البيت العتيق{1}٤٤٦٨. (ز) ٤٤٦٨ أفادت الآثارُ اختلافَ المفسرين في معنى: «المنافع» بناءً على اختلافهم في معنى: «الشعائر» كالتالي: مَن قال بأنّ الشعائر: هي البُدْن: ذهب إلى أنّ معنى: «المنافع» أي: لكم في البدن منافع. ثم اختلف هؤلاء في «الحال» التي لهم فيها منافع، وفي «الأجل» في قوله تعالى: <q>﴿إلى أجَلٍ مُسَمًّى﴾</q>؛ فقيل: الحال: هي الحال التي لم يوجِبْها صاحبها ولم يسمها بدنة. والمنافع في هذه الحال: شرب ألبانها، وركوب ظهروها، وما يرزقهم الله من نتاجها وأولادها. والأجل المسمى: عند إيجابها وتسميتها بدنة، إذ بمجرد إيجابها يبطل الانتفاع بها. وقيل: الحال: بعد إيجاب البدنة. والمنافع بعد إيجابها: ركوب ظهورها إن احتيج إلى ذلك، وشرب ألبانها إن اضطر إليه. والأجل المسمى: هو النحر. ومن قال بأن «الشعائر» هي مناسك الحج: اختلفوا أيضًا في معنى: «المنافع»، فقيل: المنافع: التجارة. والأجل المسمى: الخروج من الشعائر إلى غيرها. وقيل: المنافع: الأجر والثواب في قضاء المناسك. والأجل المسمى: انقضاء أيام الحج. ورجَّح ابنُ جرير (١٦/٥٤٧) مستندًا إلى دلالة العموم شمول الآية لكل هذه المعاني، بناءً على ترجيحه لعموم معنى «الشعائر»، فبيَّن أن معنى: <q>﴿لَكُمْ فِيها مَنافِعُ إلى أجَلٍ مُسَمًّى﴾</q>: «لكم في هذه الشعائر منافع إلى أجلٍ مسمًّى، فما كان مِن هذه الشعائر بُدْنًا وهَدْيًا فمنافعها لكم، من حين تملِكون إلى أن أوجبتموها هدايا وبُدْنًا، وما كان منها أماكن ينسك لله عندها فمنافعها التجارة لله عندها، والعمل لله بما أمر به إلى الشخوص عنها، وما كان منها أوقاتًا فأن يُطاع الله فيها بعملِ أعمال الحج، وبطلب المعاش فيها بالتجارة، إلى أن يُطاف بالبيت في بعضٍ، أو يُوافى الحرم في بعضٍ، ويُخرَج من الحرم في بعضٍ». <q>﴿ثُمَّ مَحِلُّهَاۤ إِلَى ٱلۡبَیۡتِ ٱلۡعَتِیقِ ۝٣٣﴾</q> - تفسير ٥٠٦٣٨- عن ابن جريج، قال: أخبرني عطاء [بن أبي رباح]، قال: كان ابنُ عباس يقول: لا يطوف بالبيت حاجٌّ ولا غير حاجٍّ إلا حلَّ. فقلت لعطاء: مِن أين تقول ذلك؟ قال: مِن قول الله تعالى: <q>﴿ثم محلها إلى البيت العتيق﴾</q>. قلت: فإنّ ذلك بعد المُعَرَّفِ{18}. قال: كان ابنُ عباس يقول: هو بعد المعرَّف وقبله{19}. (ز) ٥٠٦٣٩- عن مجاهد بن جبر -من طريق ابن أبي نجيح- <q>﴿ثم محلها﴾</q> يقول: مَحِلُّ البدن حين تُسَمّى <q>﴿إلى البيت العتيق﴾</q>{20}. (١٠/٤٩٠) ٥٠٦٤٠- عن عكرمة مولى ابن عباس، في قوله: <q>﴿ثم محلها إلى البيت العتيق﴾</q>، قال: إذا دخلت الحرم فقد بلغت محلها{21}. (١٠/٤٩١) ٥٠٦٤١- عن الضحاك بن مزاحم= (ز) ٥٠٦٤٢- وعطاء، في قوله: <q>﴿ثم محلها إلى البيت العتيق﴾</q>، قالا: إلى يوم النحر تُنحَر بمنى{6}. (١٠/٤٩١) ٥٠٦٤٣- عن عطاء [بن أبي رباح] -من طريق حجاج- <q>﴿ثم محلها إلى البيت العتيق﴾</q>: إلى مكة{23}٤٤٦٩. (ز) ٤٤٦٩ وجَّه ابنُ جرير (١٦/٥٤٨) قول مجاهد، وعطاء بقوله: «فوجَّه هؤلاء تأويل ذلك إلى: ثم منحر البُدن والهدايا التي أوجبتموها إلى أرض الحرم. وقالوا: عنى بالبيت العتيق: أرض الحرم كلها. وقالوا: وذلك نظير قوله: <q>﴿فَلا يَقْرَبُوا المَسْجِدَ الحَرامَ﴾</q> [التوبة:٢٨]، والمراد: الحرم كله». ٥٠٦٤٤- عن محمد بن أبي موسى، في قوله: <q>﴿ثم محلها إلى البيت العتيق﴾</q>، قال: محل هذه الشعائر كلها الطواف بالبيت العتيق{24}. (١٠/٤٩٢) ٥٠٦٤٥- قال مقاتل بن سليمان: <q>﴿ثم محلها إلى البيت العتيق﴾</q>، يعني: منحرها إلى أرض الحرم كله، كقوله سبحانه: <q>﴿فلا يقربوا المسجد الحرام﴾</q> [التوبة:٢٨]، يعني: أرض الحرم كله، ثم ينحر ويأكل ويُطْعِم، إن شاء نحر الإبل، وإن شاء ذبح الغنم أو البقر، ثم تَصَدَّق به كله، وإن شاء أكل وأمسك منه، وذلك أنّ أهل الجاهلية كانوا لا يأكلون شيئًا مِن البُدْن؛ فأنزل الله ﷿: <q>﴿فكلوا منها وأطعموا﴾</q>، فليس الأكل بواجب، ولكنه رخصة، كقوله سبحانه: <q>﴿وإذا حللتم فاصطادوا﴾</q> [المائدة:٢]، وليس الصيد بواجب، ولكنه رخصة{15}. (ز) ٥٠٦٤٦- قال عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿ثم محلها إلى البيت العتيق﴾</q>: حين تنقضي تلك الأيام؛ أيام الحج، إلى البيت العتيق{26}. (ز) ٥٠٦٤٧- قال يحيى بن سلّام: <q>﴿ثم محلها﴾</q> إذا قُلِّدَت وأُشْعِرَت <q>﴿إلى البيت العتيق﴾</q>{4}٤٤٧٠. (ز) ٤٤٧٠ أفادت الآثار اختلاف المفسرين في معنى قوله تعالى: <q>﴿ثُمَّ مَحِلُّها إلى البَيْتِ العَتِيقِ﴾</q> بناءً -أيضًا- على اختلافهم في معنى: «الشعائر»؛ فمن قال بأن الشعائر: هي البُدْن: قال بأن المعنى: ثم محل البدن إلى أن تبلغ مكة، وهي التي بها البيت العتيق. ومن قال بأن «الشعائر»: هي مناسك الحج، قال بأن المعنى: ثم مَحِل الناس من إحرامهم إلى البيت العتيق، وهو أن يطوفوا به يوم النحر بعد قضاء المناسك. وقيل: إن محل منافع أيام الحج إلى البيت العتيق بانقضائها. ورجَّح ابنُ جرير (١٦/٥٤٩) مستندًا إلى دلالة العموم أنّ المعنى: «ثم محل الشعائر التي لكم فيها منافع إلى أجل مسمًّى إلى البيت العتيق، فما كان مِن ذلك هديًا أو بُدْنًا فبموافاته الحرمَ في الحرمِ، وما كان مِن نُسُك فبالطواف بالبيت». ",footnotes:1:أخرجه ابن جرير ١٦/٥٤٦.تقليد البدن: أن يجعل في عنقها شعار يعلم به أنها هدي. لسان العرب (قلد).إشعار البدن: أن يشق أحد جنبي سنام البدنة حتى يسيل دمها، ويجعل ذلك لها علامة تعرف بها أنها هدى. النهاية (شعر).تفسير يحيى بن سلام ١/٣٧١.أخرجه ابن أبي شيبة (القسم الرابع من الجزء الرابع) ص٢٩٥، وابن جرير ١٦/٥٤٣، ٥٤٨. وعزاه السيوطي إلى عبد بن حميد، وابن أبي حاتم. ونحوه في تفسير مجاهد ص٤٨١ إلّا أنّ لفظ آخره: إلى أن تُسمّى: بدنًا. ونحوه عند الثوري في تفسيره ص٢١٢. وأخرجه يحيى بن سلام ١/٣٧١ بلفظ: هي البدن ينتفع بها حتى تُقلَّد.عزاه السيوطي إلى سعيد بن منصور، وعبد بن حميد، وابن المنذر، وابن أبي حاتم.المعي: من الإعياء وهو الكلال، وأعيا الرجل في المشي فهو مُعْيٍ. اللسان (عيا).أخرجه ابن جرير ١٦/٥٤٥.أخرجه ابن جرير ١٦/٥٤٤.تفسير الثعلبي ٧/٢٢، وتفسير البغوي ٥/٣٨٤.أخرجه ابن جرير ١٦/٥٤٤.أخرجه ابن أبي شيبة (القسم الرابع من الجزء الرابع) ص٢٩٤-٢٩٥، وابن جرير ١٦/٥٤٦. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.علَّقه يحيى بن سلام ١/٣٧١.أخرجه أبو جعفر الرملي في جزئه ص١١٧ (تفسير عطاء الخراساني).تفسير مقاتل بن سليمان ٣/١٢٦.أخرجه الثوري ص٢١٢.أخرجه ابن جرير ١٦/٥٤٦.المُعَرَّف: الوقوف بعرفة. لسان العرب (عرف).أخرجه ابن حزم في المحلى ٧/١٠١، والطحاوي في شرح معاني الآثار ٢/١٨٩، وزاد: وكان ابن عباس ﵄ يأخذها من أمر النبي ﷺ أصحابه أن يحلوا في حجة الوداع، قالها في غير مرة.أخرجه ابن أبي شيبة (القسم الرابع من الجزء الرابع) ص٢٩٥، وابن جرير ١٦/٥٤٨. وعزاه السيوطي إلى عبد بن حميد، وابن أبي حاتم.عزاه السيوطي إلى عبد بن حميد، وابن المنذر.عزاه السيوطي إلى سعيد بن منصور، وعبد بن حميد، وابن المنذر، وابن أبي حاتم.أخرجه ابن جرير ١٦/٥٤٧.أخرجه ابن جرير ١٦/٥٤٨. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.تفسير مقاتل بن سليمان ٣/١٢٦.أخرجه ابن جرير ١٦/٥٤٩.تفسير يحيى بن سلام ١/٣٧١.
22,34," <q>﴿وَلِكُلِّ أُمَّةࣲ﴾</q> - تفسير ٥٠٦٤٨- تفسير إسماعيل السُّدِّيّ: قوله: <q>﴿ولكل أمة﴾</q>، يعني: ولكل قوم{1}. (ز) ٥٠٦٤٩- قال مقاتل بن سليمان: <q>﴿ولكل أمة﴾</q>، يعني: لكل قوم مِن المؤمنين فيما خلا. كقوله سبحانه: <q>﴿أنْ تَكُونَ أُمَّةٌ هِيَ أرْبى مِن أُمَّةٍ﴾</q> [النحل:٩٢]، أن يكون قوم أكثر من قوم{2}. (ز) <q>﴿جَعَلۡنَا مَنسَكࣰا﴾</q> - تفسير ٥٠٦٥٠- عن عبد الله بن عباس -من طريق علي- في قوله: <q>﴿ولكل أمة جعلنا منسكا﴾</q>، قال: عِيدًا{3}. (١٠/٤٩٢) ٥٠٦٥١- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿ولكل أمة جعلنا منسكا﴾</q>، قال: إهراقة الدماء{4}٤٤٧١. (١٠/٤٩٢) ٤٤٧١ لم يذكر ابنُ جرير (١٦/٥٥٠) في معنى: <q>﴿ولِكُلِّ أُمَّةٍ جَعَلْنا مَنسَكًا﴾</q> سوى قول مجاهد. ٥٠٦٥٢- عن عكرمة مولى ابن عباس <q>﴿ولكل أمة جعلنا منسكا﴾</q>، قال: ذَبْحًا{5}. (١٠/٤٩٢) ٥٠٦٥٣- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿جعلنا منسكا﴾</q>، قال: أي حَجًّا، وذبحًا{6}. (ز) ٥٠٦٥٤- قال مقاتل بن سليمان: ثم قال: <q>﴿جعلنا منسكا﴾</q>، يعني: ذبحًا. يعني: هِراقة{7} الدماء{2}. (ز) ٥٠٦٥٥- عن عبد الرحمن بن زيد بن أسلم أنّه قال في هذه الآية: <q>﴿ولكل أمة جعلنا منسكا﴾</q>: أنها مكة، لم يجعل الله لأمة قط منسكًا غيرها{9}. (١٠/٤٩٣) <q>﴿جَعَلۡنَا مَنسَكࣰا﴾</q> - أثار متعلقة بالآية ٥٠٦٥٦- عن أبي هريرة، قال: نزل جبريلُ فقال النبيُّ ﷺ له: «كيف رأيت عيدنا؟». فقال: لقد تَباهى به أهلُ السماء، اعلم -يا محمد- أنّ الجذَع مِن الضأن خيرٌ مِن السيد من المعز، وأن الجذع مِن الضأن خير من السيد من البقر، وأنّ الجذع من الضأن خير من السيد من الإبل، ولو علم الله خيرًا منه فدى به إبراهيمُ{10}. (١٠/٤٩٣) ٥٠٦٥٧- عن عبد الله بن عمر: أنّ رجلًا أتى رسول الله ﷺ، فقال له رسول الله ﷺ: «أمرت بعيد الأضحى؛ جعله الله لهذه الأمة». قال الرجل: فإن لم نجد إلا ذبيحة أنثى أو شاة أهلي، أذبحها؟ قال: «لا، ولكن قلِّم أظفارك، وقُصَّ شاربك، واحلُق عانتَك، فذلك تمام أضحيتك عند الله»{11}. (١٠/٤٩٣) <q>﴿لِّیَذۡكُرُوا۟ ٱسۡمَ ٱللَّهِ عَلَىٰ مَا رَزَقَهُم مِّنۢ بَهِیمَةِ ٱلۡأَنۡعَـٰمِۗ﴾</q> - تفسير ٥٠٦٥٨- قال يحيى بن سلّام: <q>﴿ليذكروا اسم الله على ما رزقهم من بهيمة الأنعام﴾</q> إذا ذبحوا، فالسُّنَّة إذا ذبح أو نحر أن يقول: بسم الله، والله أكبر ... عن أنس بن مالك: أنّ رسول الله ﷺ كان يُضَحِّي بكبشين أملحين، أقرنين، يذبحهما بيده، ويَطَأ على صَفْحَتَيهما، ويُسَمِّي، ويُكَبِّر{12}. (ز) <q>﴿لِّیَذۡكُرُوا۟ ٱسۡمَ ٱللَّهِ عَلَىٰ مَا رَزَقَهُم مِّنۢ بَهِیمَةِ ٱلۡأَنۡعَـٰمِۗ﴾</q> - آثار متعلقة بالآية ٥٠٦٥٩- عن جابر بن عبد الله: أنّ رسول الله ﷺ صَلّى للناس يوم النحر، فلمّا فرغ مِن خطبته وصلاته دعا بكبش، فذبحه هو بنفسه، وقال: «بسم الله، والله أكبر، اللهُمَّ، هذا عَنِّي وعمَّن لم يُضَحِّ مِن أُمَّتي»{13}. (١٠/٤٩٤) ٥٠٦٦٠- عن جابر بن عبد الله، قال: ضَحّى رسولُ الله ﷺ بكبشين في يوم عيد، فقال حين وجَّههما: «وجَّهتُ وجهي للذي فطر السموات والارض حنيفًا مسلمًا، وما أنا من المشركين، إنّ صلاتي ونسكي ومحياي ومماتي لله رب العالمين، لا شريك له، وبذلك أمرت وأنا أول المسلمين، اللهم منك ولك، وعن محمد وأُمَّتِه». ثم سمّى اللهَ، وكَبَّر، وذبح{14}. (١٠/٤٩٤) ٥٠٦٦١- عن أنس: أنّ رسول الله ﷺ ضَحّى بكبشين أملحين، أقرنين، فسَمّى، وكَبَّر{15}. (١٠/٤٩٥) ٥٠٦٦٢- عن علي، أنّه قال حين ذبح: وجهتُ وجهي للذي فطر السموات والأرض حنيفًا مسلمًا، وما أنا مِن المشركين، إنّ صلاتي ونسكي ومحياي ومماتي لله رب العالمين، لا شريك له، وبذلك أُمِرت، وأنا من المسلمين{16}. (١٠/٤٩٥) ٥٠٦٦٣- عن عبد الله بن عمر، أنّه كان إذا ذبح قال: باسم الله، والله أكبر، اللهم منك ولك، اللَّهُمَّ، تَقَبَّل مِنِّي{17}. (١٠/٤٩٥) ٥٠٦٦٤- عن قتادة: أنّ الحسن البصري كان إذا ذبح الأضحية قال: بسم الله، والله أكبر، اللَّهُمَّ، منك ولك{18}. (ز) <q>﴿مِّنۢ بَهِیمَةِ ٱلۡأَنۡعَـٰمِۗ﴾</q> - تفسير ٥٠٦٦٥- قال مقاتل بن سليمان: <q>﴿ليذكروا اسم الله على ما رزقهم من بهيمة الأنعام﴾</q>، وإنما خَصَّ الأنعام من البهائم؛ لأنّ مِن البهائم ما ليس مِن الأنعام، وإنّما سُمِّيَت: البهائم؛ لأنها لا تتكلم{2}. (ز) <q>﴿فَإِلَـٰهُكُمۡ إِلَـٰهࣱ وَ ٰ⁠حِدࣱ فَلَهُۥۤ أَسۡلِمُوا۟ۗ﴾</q> - تفسير ٥٠٦٦٦- قال مقاتل بن سليمان: <q>﴿فإلهكم إله واحد﴾</q> ليس له شريك، يقول: فربُّكم ربٌّ واحد، <q>﴿فله أسلموا﴾</q>{2}. (ز) ٥٠٦٦٧- عن مقاتل [بن حيان]، <q>﴿فله أسلموا﴾</q>، يقول: فله أخلِصُوا{9}. (١٠/٤٩٥) ٥٠٦٦٨- قال يحيى بن سلّام: قوله: <q>﴿فإلهكم إله واحد فله أسلموا﴾</q>، يقوله للمشركين{22}. (ز) <q>﴿وَبَشِّرِ ٱلۡمُخۡبِتِینَ ۝٣٤﴾</q> - تفسير ٥٠٦٦٩- قال عبد الله بن عباس: المتواضعين{23}٤٤٧٢. (ز) ٤٤٧٢ ذكر ابنُ عطية (٦/٢٤٨) رواية بـ«أنّ هذه الآية -قوله تعالى: <q>﴿وبَشِّرِ المُخْبِتِينَ﴾</q>- نزلت في أبي بكر، وعمر، وعثمان، وعلي ﵃». ٥٠٦٧٠- عن عمرو بن أوس -من طريق عثمان بن عبد الله بن أوس- <q>﴿وبشر المخبتين﴾</q>، قال: المُخْبِتون: الذين لا يظلمون الناس، وإذا ظُلِموا لم ينتصروا{24}٤٤٧٣. (١٠/٤٩٥) ٤٤٧٣ علَّق ابنُ عطية (٦/٢٤٧) على قول عمرو بن أوس قائلًا: «وهذا مِثال شريف مِن خُلُق المؤمن الهيِّن اللَّيِّن». ٥٠٦٧١- قال إبراهيم النخعي: المخلصين{25}. (ز) ٥٠٦٧٢- عن مجاهد بن جبر -من طريق ابن أبي نجيح، وابن جُرَيْج- في قوله: <q>﴿وبشر المخبتين﴾</q>، قال: المُطْمَئِنِّين{26}. (١٠/٤٩٥) ٥٠٦٧٣- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿وبشر المخبتين﴾</q>، قال: المتواضعون{27}. (ز) ٥٠٦٧٤- عن مجاهد بن جبر، قال: المصلين{28}. (ز) ٥٠٦٧٥- عن الضَّحّاك بن مُزاحِم -من طريق جويبر- <q>﴿وبشر المخبتين﴾</q>، قال: المتواضعين{29}. (١٠/٤٩٦) ٥٠٦٧٦- تفسير الحسن البصري: أنّ المخبتين: الخاشعين الخائفين. والخشوع: المخافة الثابتة في القلب{1}. (ز) ٥٠٦٧٧- عن قتادة بن دعامة -من طريق مَعْمَر- في قوله: <q>﴿وبشر المخبتين﴾</q>، قال: هم المتواضعون{27}. (ز) ٥٠٦٧٨- عن إسماعيل السُّدِّيّ، <q>﴿وبشر المخبتين﴾</q>، قال: الوَجِلين{9}٤٤٧٤. (١٠/٤٩٦) ٤٤٧٤ ذهب ابنُ كثير (١٠/٦١) في معنى: <q>﴿المخبتين﴾</q> إلى أنّ «أحسن ما يُفَسَّر بما بعده، وهو قوله: <q>﴿الَّذِينَ إذا ذُكِرَ اللَّهُ وجِلَتْ قُلُوبُهُمْ﴾</q> أي: خافت منه قلوبهم، <q>﴿والصّابِرِينَ عَلى ما أصابَهُمْ﴾</q> أي: من المصائب». ٥٠٦٧٩- قال محمد بن السائب الكلبي: هم الرقيقة قلوبهم{25}. (ز) ٥٠٦٨٠- قال مقاتل بن سليمان: <q>﴿وبشر المخبتين﴾</q>، يعني: المخلصين، بالجنة{2}. (ز) ٥٠٦٨١- قال سفيان بن عيينة -من طريق ابن أبي عمر- في قوله: <q>﴿وبشر المخبتين﴾</q>، قال: المطمئنين{35}. (ز) ٥٠٦٨٢- عن يحيى بن سلّام: قوله: <q>﴿وبشر المخبتين﴾</q> يعني: بالجنة، وبعضهم يقول: <q>﴿وبشر المخبتين﴾</q> يعني: المطمئنين بالإيمان. قال: <q>﴿فتخبت له قلوبهم﴾</q> [الحج:٥٤]، فتطمئن إليه قلوبهم. وقال: <q>﴿الذين آمنوا وتطمئن قلوبهم بذكر الله﴾</q> [الرعد:٢٨]{22}. (ز) <q>﴿وَبَشِّرِ ٱلۡمُخۡبِتِینَ ۝٣٤﴾</q> - آثار متعلقة بالآية ٥٠٦٨٣- عن عبد الله بن مسعود -من طريق ابنه أبي عبيدة- أنّه كان اذا رأى الربيع بن خثيم قال: <q>﴿وبشر المخبتين﴾</q>. وقال له: ما رأيتُكَ إلا ذكرت المخبتين{37}. (١٠/٤٩٦) ",footnotes:1:علَّقه يحيى بن سلام ١/٣٧٤.تفسير مقاتل بن سليمان ٣/١٢٦.أخرجه ابن أبي حاتم -كما في الإتقان ٢/٣٠-.أخرجه ابن جرير ١٦/٥٥٠. وعزاه السيوطي إلى ابن أبي شيبة، وعبد بن حميد، وابن المنذر، وابن أبي حاتم.عزاه السيوطي إلى ابن أبي حاتم. وأخرجه الثوري في تفسيره ص٢١٣ من طريق سعيد بن مسروق بلفظ: ذبائح هم ذابحوها.أخرجه يحيى بن سلام ١/٣٧٤.هِراقة وإراقة الدماء: صبّها وإسالتها. النهاية واللسان (هرق).تفسير مقاتل بن سليمان ٣/١٢٦.عزاه السيوطي إلى ابن أبي حاتم.أخرجه الحاكم ٤/٢٤٧ (٧٥٢٦)، وفيه إسحاق بن إبراهيم الحنيني. قال ابن عدي في الكامل ١/٥٥٤-٥٥٥ (١٧١) في ترجمة إسحاق بن إبراهيم الحنيني: «قال البخاري: إسحاق بن إبراهيم الحنيني ... في حديثه نظر ... وهذا الحديث لا يرويه عن هشام بن سعد إلا الحنيني، والحنيني مع ضعفه يكتب حديثه». وقال الحاكم: «هذا حديث صحيح الإسناد، ولم يخرجاه». وقال الذهبي في التلخيص: «إسحاق هالك».أخرجه أحمد ١١/١٣٩ (٦٥٧٥)، وأبو داود ٤/٤١٦-٤١٧ (٢٧٨٩)، والنسائي ٧/٢١٢ (٤٣٦٥)، وابن حبان ١٣/٢٣٥-٢٣٦ (٥٩١٤)، والحاكم ٤/٢٤٨ (٧٥٢٩)، وابن وهب في الجامع من تفسيره ٣/١٥-١٦ (١٩). قال الحاكم: «هذا حديث صحيح الإسناد، ولم يخرجاه». وقال الألباني في ضعيف أبي داود ٢/٣٧٠ (٤٨٢): «إسناده ليس بذاك -كما قال الذهبي-، والصدفي هذا ليس بالمشهور».تفسير يحيى بن سلام ١/٣٧٩-٣٨٠.أخرجه أحمد ٢٣/١٣٣-١٣٤ (١٤٨٣٧)، ٢٣/١٧٠-١٧٢ (١٤٨٩٣، ١٤٨٩٥)، وأبو داود ٤/٤٣٣ (٢٨١٠)، والترمذي ٣/٣٤٤-٣٤٥ (١٥٩٩)، والحاكم ٤/٢٥٤ (٧٥٥٣). قال الترمذي: «هذا حديث غريب من هذا الوجه .. والمطلب بن عبد الله بن حنطب يُقال: إنه لم يسمع من جابر». وقال الألباني في الإرواء ٤/٣٤٩ (١١٣٨): «صحيح».أخرجه أحمد ٢٣/٢٦٧ (١٥٠٢٢)، وأبو داود ٤/٤٢١ (٢٧٩٥)، وابن ماجه ٤/٣٠٠ (٣١٢١)، وابن خزيمة ٤/٤٨٧ (٢٨٩٩)، والحاكم ١/٦٣٩ (١٧١٦). قال الحاكم: «هذا حديث صحيح، على شرط مسلم، ولم يخرجاه». وقال ابن الملقن في البدر المنير ٩/٣٠٠: «فيه مع أبي عياش هذا عنعنة ابن إسحاق، وأبو عياش هذا روى عنه خالد بن أبي عمران، ويزيد بن أبي حبيب، وهو مستور لم يتحقق حاله. قال عبد الحق: لم أسمع فيه بتجريح ولا بتعديل». وقال الألباني في الإرواء ٤/٣٥٠: «ورجاله ثقات غير أبي عياش هذا، وهو المعافري المصري، وهو مستور، روى عنه ثلاثة من الثقات».أخرجه البخاري ٧/١٠١ (٥٥٥٨)، ٧/١٠٢ (٥٥٦٥)، ٩/١٢٠ (٧٣٩٩)، ومسلم ٣/١٥٥٦ (١٩٦٦)، ويحيى بن سلام ١/٣٧٩.أخرجه البيهقي في الشعب (٧٣٣٩). وعزاه السيوطي إلى ابن أبي حاتم، وابن أبي الدنيا في الأضاحي.عزاه السيوطي إلى ابن أبي الدنيا.أخرجه يحيى بن سلام ١/٣٧٩.تفسير مقاتل بن سليمان ٣/١٢٦.تفسير مقاتل بن سليمان ٣/١٢٦.عزاه السيوطي إلى ابن أبي حاتم.تفسير يحيى بن سلام ١/٣٧٤.تفسير الثعلبي ٧/٢٢، وتفسير البغوي ٥/٣٨٦.أخرجه ابن أبي شيبة ١٣/٥٧٨، والبيهقي في الشعب (٨٠٨٨). وعزاه السيوطي إلى سعيد بن منصور، وعبد بن حميد، وابن أبي الدنيا في ذم الغضب، وابن المنذر، وابن أبي حاتم.تفسير البغوي ٥/٣٨٦.أخرجه ابن جرير ١٦/٥٥١، وابن المنذر -كما في فتح الباري ٨/٤٣٨-. وعزاه السيوطي إلى عبد بن حميد، وابن أبي حاتم.أخرجه عبد الرزاق ٢/٣٨.أخرجه ابن المنذر -كما في فتح الباري ٨/٤٣٨-.أخرجه ابن أبي شيبة ١٣/٥٨٠، وابن المنذر -كما في فتح الباري ٨/٤٣٨-. وعزاه السيوطي إلى ابن أبي حاتم.علَّقه يحيى بن سلام ١/٣٧٤.أخرجه عبد الرزاق ٢/٣٨.عزاه السيوطي إلى ابن أبي حاتم.تفسير البغوي ٥/٣٨٦.تفسير مقاتل بن سليمان ٣/١٢٦.أخرجه إسحاق البستي في تفسيره ص٣٦٥. وعلّقه البخاري في صحيحه ٦/٩٧.تفسير يحيى بن سلام ١/٣٧٤.أخرجه ابن سعد ٦/١٨٣، وابن أبي شيبة ١٣/٥٨٤ مطولًا.
22,35," <q>﴿ٱلَّذِینَ إِذَا ذُكِرَ ٱللَّهُ وَجِلَتۡ قُلُوبُهُمۡ وَٱلصَّـٰبِرِینَ عَلَىٰ مَاۤ أَصَابَهُمۡ وَٱلۡمُقِیمِی ٱلصَّلَوٰةِ وَمِمَّا رَزَقۡنَـٰهُمۡ یُنفِقُونَ ۝٣٥﴾</q> - تفسير ٥٠٦٨٤- قال مقاتل بن سليمان: ثم نعتهم، فقال: <q>﴿الذين إذا ذكر الله وجلت﴾</q> يعني: خافَتْ <q>﴿قلوبهم والصابرين على مآ أصابهم﴾</q> مِن أمر الله، <q>﴿والمقيمي الصلاة ومما رزقناهم ينفقون﴾</q> من الأموال{1}. (ز) ٥٠٦٨٥- عن مقاتل [بن حيان]: <q>﴿الذين اذا ذكر الله وجلت قلوبهم﴾</q> عند ما يُخَوَّفون، <q>﴿والصابرين على ما أصابهم﴾</q> مِن البلاء والمصائب، <q>﴿والمقيمي الصلاة﴾</q> يعني: إقامتها؛ أداء ما استحفظهم اللهُ فيها{2}. (١٠/٤٩٦) ٥٠٦٨٦- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿الذين إذا ذكر الله وجلت قلوبهم﴾</q> قال: لا تقسو قلوبُهم، <q>﴿والصابرين على ما أصابهم﴾</q> مِن شِدَّة في أمر الله، ونالهم مِن مكروهٍ في جنبه، <q>﴿والمقيمي الصلاة﴾</q> المفروضة، <q>﴿ومما رزقناهم﴾</q> مِن الأموال <q>﴿ينفقون﴾</q> في الواجب عليهم إنفاقها فيه؛ في زكاة، ونفقة عيال، ومَن وجَبَتْ عليه نفقتُه، وفي سبيل الله{3}. (ز) ٥٠٦٨٧- قال يحيى بن سلّام: قوله: <q>﴿الذين إذا ذكر الله وجلت قلوبهم﴾</q> يعني: خافت قلوبهم، <q>﴿والصابرين على ما أصابهم والمقيمي الصلاة﴾</q> المفروضة، الصلوات الخمس يحافظون على وضوئها، ومواقيتها، وركوعها، وسجودها، <q>﴿ومما رزقناهم ينفقون﴾</q> يعني: الزكاة المفروضة{4}. (ز) ",footnotes:1:تفسير مقاتل بن سليمان ٣/١٢٧.عزاه السيوطي إلى ابن أبي حاتم.أخرجه ابن جرير ١٦/٥٥٢.تفسير يحيى بن سلام ١/٣٧٥.
22,36," <q>﴿وَٱلۡبُدۡنَ جَعَلۡنَـٰهَا لَكُم مِّن شَعَـٰۤىِٕرِ ٱللَّهِ﴾</q> - قراءات ٥٠٦٨٨- عن عاصم أنّه قرأ: <q>﴿والبُدْنَ﴾</q> خفيفة{1}. (١٠/٤٩٦) <q>﴿وَٱلۡبُدۡنَ﴾</q> - تفسير ٥٠٦٨٩- عن سليمان بن يعقوب الرِّياحي، عن أبيه، قال: أوصى إلَيَّ رجلٌ، وأوصى ببدنة، فأتيت ابنَ عباس، فقلت له: إنّ رجلًا أوصى إلَيَّ ببدنة، فهل تُجْزِئ عنِّي بقرة؟ قال: نعم. ثم قال: مِمَّن صاحبكم؟ فقلت: مِن بني رياح. قال: ومتى اقتنى بنو رياح البقر إلى الإبل؟! وهِمَ صاحبُكم، إنّما البقر للأزدِ، وعبد القيس{2}. (١٠/٤٩٧) ٥٠٦٩٠- عن عبد الله بن عمر، قال: لا نعلم البدن إلا مِن الإبل والبقر{3}. (١٠/٤٩٧) ٥٠٦٩١- عن عبد الله بن عمر، قال: البدن: ذات الجوف{4}. (١٠/٤٩٧) ٥٠٦٩٢- عن سعيد بن المسيب -من طريق ابن جريج، عمَّن سَمِعه- قال: البدن: البعير، والبقرة{5}. (١٠/٤٩٧) ٥٠٦٩٣- عن مجاهد بن جبر -من طريق ابن أبي نجيح- قال: ليس البدن إلا من الإبل{6}. (١٠/٤٩٧) ٥٠٦٩٤- عن مجاهد بن جبر -من طريق ابن أبي نجيح- قال: إنّما سميت: البدن؛ مِن قبل السَّمانَةِ{7}{8}. (١٠/٤٩٨) ٥٠٦٩٥- عن القاسم بن محمد بن أبي بكر -من طريق ابن عون-: إنّ الشاة لن تعدو أن تكون نسيكة، وإنّ البقرة مِن البدن{9}. (ز) ٥٠٦٩٦- عن الحسن البصري، قال: البُدْن مِن البقر{4}. (١٠/٤٩٧) ٥٠٦٩٧- عن عطاء [بن أبي رباح] -من طريق ابن جُرَيْج- <q>﴿والبُدْنَ جَعَلْناها لَكُمْ مِن شَعائِرِ اللَّهِ﴾</q>، قال: البقرة، والبعير{11}٤٤٧٥. (ز) ٤٤٧٥ لم يذكر ابنُ جرير (١٦/٥٥٣) في معنى: <q>﴿والبُدْنَ جَعَلْناها لَكُمْ مِن شَعائِرِ اللَّهِ﴾</q> سوى قول عطاء. وعلَّق ابنُ عطية (٦/٢٤٨) على قول عطاء بقوله: «وسُمِّيَت بذلك لأنها تَبْدُن، أي: تَسْمُن». وعلَّق ابنُ كثير (١٠/٦٢) على هذه الأقوال، فقال: «أمّا إطلاق البدنة على البعير فمُتَّفق عليه، واختلفوا في صحة إطلاق البدنة على البقرة على قولين، أصحهما: أنه يطلق عليها ذلك شرعًا كما صحَّ في الحديث». ٥٠٦٩٨- عن عبد الكريم، قال: اختلف عطاء والحكم؛ فقال عطاء [بن أبي رباح]: البُدن من الإبل والبقر.= (ز) ٥٠٦٩٩- وقال الحكم [بن عتيبة]: مِن الإبل{12}. (١٠/٤٩٧) ٥٠٧٠٠- قال إسماعيل السُّدِّيّ: البدن: الإبل والبقر، أمّا الغنم فلا تُسَمّى بدنة{13}. (ز) ٥٠٧٠١- قال مقاتل بن سليمان: وإنما سميت: البدن؛ لأنّها تُقَلَّد وتُشْعَر وتُساق إلى مكة. والهدي: الذي يُنحَر بمكة ولم يُقَلَّد ولم يُشْعَر. والجزور: البعير الذي ليس ببدنة، ولا بهدي{14}. (ز) <q>﴿جَعَلۡنَـٰهَا لَكُم مِّن شَعَـٰۤىِٕرِ ٱللَّهِ﴾</q> - تفسير ٥٠٧٠٢- قال مقاتل بن سليمان: قوله ﷿: <q>﴿والبدن جعلناها لكم من شعائر الله﴾</q>، يعني: مِن أمر المناسك{14}. (ز) <q>﴿لَكُمۡ فِیهَا خَیۡرࣱۖ﴾</q> - تفسير ٥٠٧٠٣- عن إبراهيم النخعي -من طريق منصور- في قوله: <q>﴿لكم فيها خير﴾</q>، قال: هي البُدْنَة؛ إن احتاج إلى ظهرٍ رَكب، أو إلى لبن شرب{16}. (١٠/٤٩٨) ٥٠٧٠٤- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿لكم فيها خير﴾</q>، قال: لكم أجر ومنافع في البدن{17}. (١٠/٤٩٨) ٥٠٧٠٥- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿لكم فيها خير﴾</q>، قال: إن احتاج إلى اللبن شرِب، وإن احتاج إلى الركوب ركِب، وإن احتاج إلى الصوف أخذ{18}. (١٠/٥٠٠) ٥٠٧٠٦- تفسير إسماعيل السُّدِّيّ: <q>﴿لكم فيها﴾</q>، يعني: في البدن أجر{19}. (ز) ٥٠٧٠٧- قال مقاتل بن سليمان: <q>﴿لكم فيها خير﴾</q>، يقول: لكم في نحرها أجرٌ في الآخرة، ومنفعة في الدنيا{14}. (ز) ٥٠٧٠٨- قال يحيى بن سلّام: قوله: <q>﴿والبدن جعلناها لكم من شعائر الله لكم فيها خير﴾</q>، يعني: أجر في نحرها، والصدقة منها، تَتَقَرَّبون بها إلى الله{21}٤٤٧٦. (ز) ٤٤٧٦ رجَّح ابنُ عطية (٦/٢٤٨) عموم معنى: «الخير» ليشمل خير الدنيا والآخرة، ولم يذكر مستندًا. <q>﴿لَكُمۡ فِیهَا خَیۡرࣱۖ﴾</q> - آثار متعلقة بالآية ٥٠٧٠٩- عن زيد بن أرقم، قال: قلنا: يا رسول الله، ما هذه الأضاحي؟ قال: «سُنَّة أبيكم إبراهيم». قال: فما لنا فيها، يا رسول الله؟ قال: «بكل شعرة حسنة». قالوا: فالصوف؟ قال: «بكل شعرة من الصوف حسنة»{22}. (١٠/٤٩٨) ٥٠٧١٠- عن عائشة، أنّ رسول الله ﷺ قال: «ما عمِل ابنُ آدم يوم النحر عَمَلًا أحبَّ إلى الله مِن هراقة دم، وإنّها لتأتي يوم القيامة بقرونها وأظلافها وأشعارها، وإنّ الدَّمَ لَيَقَعُ من الله بمكان قبل أن يقع على الأرض، فطِيبوا بها نفسًا»{23}. (١٠/٤٩٩) ٥٠٧١١- عن جابر بن عبد الله، قال: قال رسول الله ﷺ: «اركبوا الهَدْيَ بالمعروف حتى تجدوا ظَهْرًا»{24}. (١٠/٥٠١) ٥٠٧١٢- عن أبي هريرة، أنّ رسول الله ﷺ رأى رجلًا يسوق بدنة، فقال: «اركبها». قال: يا رسول الله، إنها بدنة. قال: «اركبها، ويلك» في الثانية أو في الثالثة{25}. (١٠/٥٠٢) ٥٠٧١٣- عن أنس بن مالك، قال: مُرَّ على النبي ﷺ ببدنة أو هدية، فقال: «اركبها». قال: إنها بدنة أو هدية. فقال: «وإن»{26}. (١٠/٥٠٢) ٥٠٧١٤- عن عكرمة، قال: قال رجلٌ لابن عباس: أيركب الرجل البُدْنَة؟ قال: غير مثقل. قال: فيحلبها؟ قال: غير مُجْهِد{27}. (١٠/٥٠١) ٥٠٧١٥- عن هشام بن عروة، عن أبيه قال: البدنة، إن احتاج سائقُها فإنّه يركبها غير فادح، ويشرب من فضل ري فصيلها{28}. (ز) ٥٠٧١٦- عن مالك بن أنس، قال: حجَّ سعيدُ بن المسيب، وحجَّ معه ابنُ حرملة، فاشترى سعيدٌ كَبْشًا، فضَحّى به، واشترى ابنُ حرملة بدنة بستة دنانير، فنحرها، فقال له سعيد: أما كان لك فينا أسوة؟ فقال: إنِّي سمعت الله يقول: <q>﴿والبدن جعلناها لكم من شعائر الله لكم فيها خير﴾</q>، فأحببتُ أن آخذ الخير مِن حيث دَلَّني اللهُ عليه. فأعجب ذلك ابنَ المسيب منه، وجعل يُحَدِّث بها عنه{4}. (١٠/٥٠٠) ٥٠٧١٧- عن ابن عيينة، قال: حجَّ صفوان بن سليم ومعه سبعة دنانير، فاشترى بها بُدنة، فقيل له: ليس معك إلا سبعة دنانير تشتري بها بدنة! فقال: إنِّي سمعتُ الله يقول: <q>﴿لكم فيها خير﴾</q>{30}. (١٠/٥٠٠) <q>﴿فَٱذۡكُرُوا۟ ٱسۡمَ ٱللَّهِ عَلَیۡهَا صَوَاۤفَّۖ﴾</q> - قراءات الآية، وتفسيرها ٥٠٧١٨- عن قتادة، قال: كان عبد الله بن مسعود يقرأ: (فاذْكُرُوا اسْمَ اللهِ عَلَيْها صَوافِنَ). أي: معقولة قِيامًا{31}. (١٠/٥٠٤) ٥٠٧١٩- عن جرير بن حازم، قال: قرأتُ في مصحف عبد الله بن مسعود: (فاذْكُرُوا اسْمَ اللهِ عَلَيْها صَوافِنَ){32}. (ز) ٥٠٧٢٠- عن ميمون بن مهران، قال: في قراءة ابن مسعود: (صَوافِنَ)، يعني: قيامًا{33}. (١٠/٥٠٥) ٥٠٧٢١- عن عبد الله بن عباس -من طريق أبي ظبيان- أنّه كان يقرأ: (فاذْكُرُوا اسْمَ اللهِ عَلَيْها صَوافِنَ){34}. (١٠/٥٠٤) ٥٠٧٢٢- عن سعيد بن جبير أنّه كان يقرؤها: (صَوافِنَ). قال: رأيتُ ابنَ عمر ينحر بدنته، وهي على ثلاثة قوائم، قيامًا معقولة{35}. (١٠/٥٠٥) ٥٠٧٢٣- عن مجاهد بن جبر، في قوله: (صَوافِنَ)، قال: معقولة على ثلاث{36}. (١٠/٥٠٤) ٥٠٧٢٤- عن مجاهد بن جبر، قال: مَن قرأها: (صَوافِنَ) قال: معقولة. ومن قرأها: <q>﴿صَوافَّ﴾</q> قال: يَصُفُّ بين يديها. ولفظ عبد بن حميد: مَن قرأها: <q>﴿صَوافَّ﴾</q> فهي: قائمة مضمومة يديها. ومن قرأها: (صَوافِنَ): قيامًا معقولة. ولفظ ابن أبي شيبة: الصواف على أربع، والصوافن على ثلاث{37}. (١٠/٥٠٥) ٥٠٧٢٥- عن الحسن البصري -من طريق جرير بن حازم- أنّه كان يقرأها: (صَوافِيَ). قال: خالصة لله تعالى. قال: كانوا يذبحونها لأصنامهم{38}. (١٠/٥٠٥) ٥٠٧٢٦- عن ابن لهيعة: أنّه سمع ربيعة [بن أبي عبد الرحمن] يقول: (صَوافِيَ). قال: خالصة لله{39}. (ز) ٥٠٧٢٧- عن عبد الرحمن بن زيد بن أسلم، أنّه قرأ: (فاذْكُرُوا اسْمَ اللهِ عَلَيْها صَوافِيَ) بالياء منتصبة، وقال: خالصة لله مِن الشِّرْك؛ لأنهم كانوا يشركون في الجاهلية إذا نحروها{40}. (١٠/٥٠٥) ٥٠٧٢٨- عن شقيق الضبي- من طريق قيس بن مسلم-: (فاذْكُرُوا اسْمَ اللَّهِ عَلَيْها صَوافِيَ). قال: خالصة{41}. (ز) <q>﴿فَٱذۡكُرُوا۟ ٱسۡمَ ٱللَّهِ عَلَیۡهَا صَوَاۤفَّۖ﴾</q> - نزول الآية ٥٠٧٢٩- عن ابن لهيعة، قال: سمعتُ ربيعة بن أبي عبد الرحمن يقول: كان أهلُ الجاهلية إذا نحروا بدنهم أشركوا فيها؛ فأنزل الله: <q>﴿فاذكروا اسم الله عليها صواف﴾</q>. فقال ربيعة: خالِصةٌ مِن الشِّرك{42}. (ز) <q>﴿فَٱذۡكُرُوا۟ ٱسۡمَ ٱللَّهِ عَلَیۡهَا صَوَاۤفَّۖ﴾</q> - تفسير الآية ٥٠٧٣٠- عن عبد الله بن مسعود -من طريق نافع-: أنّه كان ينحر البُدْن وهي قائمة، مستقبلة البيت، تُصَفُّ أيديها بالقيود. قال: هي التي ذكر الله: <q>﴿فاذكروا اسم الله عليها صواف﴾</q>{41}. (ز) ٥٠٧٣١- عن أبي ظبيان، قال: سألتُ ابنَ عباس عن قوله: <q>﴿فاذكروا اسم الله عليها صواف﴾</q>. قال: إذا أردت أن تنحر البُدْنة، فأقِمْها على ثلاث قوائم معقولة، ثم قل: باسم الله، والله أكبر، اللَّهُمَّ مِنك ولك{44}. (١٠/٥٠٢) ٥٠٧٣٢- عن عبد الله بن عباس -من طرق- في قوله: <q>﴿صواف﴾</q>، قال: قيامًا معقولة{45}. (١٠/٥٠٣) ٥٠٧٣٣- عن عبد الله بن عمر -من طريق بجير بن سالم-: أنّه نحر بدنة وهي قائمة معقولة إحدى يديها، وقال: صواف كما قال الله ﷿{46}. (١٠/٥٠٣) ٥٠٧٣٤- عن عبد الله بن عمر -من طريق نافع- أنه كان ينحرها وهي قائمة يصف بين أيديها بالقيود. وكان يتلو هذه الآية: <q>﴿فاذكروا اسم الله عليها صواف﴾</q>. قال يحيى بن سلام: مقرؤها على هذا التفسير غير مثقلة <q>﴿صوافٍ﴾</q> {47}. (ز) ٥٠٧٣٥- عن سعيد بن جبير قال: رأيت عبد الله بن عمر ينحر بدنته، وقد ثنى يدها، وهي على ثلاث. وقال سعيد بن جبير هو قول الله: <q>﴿فاذكروا اسم الله عليها صواف﴾</q>{48}. (ز) ٥٠٧٣٦- عن مجاهد بن جبر -من طريق ليث-، في قوله: <q>﴿فاذكروا اسم الله عليها صواف﴾</q>. قال: صوافَّ بين أوظافِها{49} {50}. (ز) ٥٠٧٣٧- عن مجاهد بن جبر -من طريق عبد الكريم-، قال: مُعَقَّلَة قيامًا{47}. (ز) ٥٠٧٣٨- عن مجاهد بن جبر -من طريق أبي يحيى-، قال: معقلة خالصة لله{47}. (ز) ٥٠٧٣٩- عن مجاهد بن جبر -من طريق ابن أبي نجيح-: <q>﴿صواف﴾</q> قال: قيام صواف على ثلاث قوائم{50}. (ز) ٥٠٧٤٠- عن الضحاك بن مزاحم -من طريق عبيد-، في قوله: <q>﴿فاذكروا اسم الله عليها صواف﴾</q> يعني: صوافن. والبدنة إذا نحرت عقلت يد واحدة، فكانت على ثلاث، وكذلك تنحر{54}. (ز) ٥٠٧٤١- عن أيمن بن نابل، قال: سألت طاووسًا عن قوله: <q>﴿فاذكروا اسم الله عليها صواف﴾</q> قال: خالصًا{54}. (ز) ٥٠٧٤٢- عن الحسن البصري -من طريق قتادة-، قوله: <q>﴿فاذكروا اسم الله عليها صواف﴾</q> قال: مخلصين لله{56}٤٤٧٧. (ز) ٤٤٧٧ أفادت الآثار اختلاف المفسرين في معنى: «صواف» بناءً على اختلافهم في قراءتها، فمن قرأها: «صوافَّ» بتشديد الفاء ونصبها، قال بأن المعنى: مُصْطَفَّة. ومن قرأها: «صوافي» بالياء، قال بأن المعنى: خالصة لله لا شريك له فيها. ومن قرأها: «صَوافِن» قال بأن المعنى: مُعَقَّلة. ورجَّح ابن جرير (١٦/٥٥٥، ٥٦٠) قراءة من قرأها: صوافَّ، والمعنى المترتب على هذه القراءة، وهو أنها مُصطَفَّة بين أيديها، معقولة إحدى قوائمها، وهو قول ابن عباس، وابن عمر، ومجاهد من طريق ليث. ولم يذكر مستندًا. ٥٠٧٤٣- عن قتادة بن دعامة -من طريق سعيد- قال: مصفوفة بالحبال، معقولة يدها اليمنى وهي قائمة على ثلاث. كذلك ينحرها من نحرها في دار المنحر بمنى{48}. (ز) ٥٠٧٤٤- عن عطاء الخراساني -من طريق يونس- في قول الله تعالى: <q>﴿فاذكروا اسم الله عليها صواف﴾</q>، قال: البُدْن تُصَفُّ وتُشعَر وهي قيام{58}. (ز) ٥٠٧٤٥- قال مقاتل بن سليمان: <q>﴿فاذكروا اسم الله عليها﴾</q> إذا نحرت <q>﴿صواف﴾</q> يعني: معقولة يدها اليسرى قائمة على ثلاثة قوائم مستقبلات القبلة{59}. (ز) <q>﴿فَٱذۡكُرُوا۟ ٱسۡمَ ٱللَّهِ عَلَیۡهَا صَوَاۤفَّۖ﴾</q> - أحكام متعلقة بالآية ٥٠٧٤٦- عن ابن عمر: أنّه رأى رجلًا أناخ بدنته وهو ينحرها، فقال: ابعثها قيامًا مُقَيَّدة؛ سُنَّة محمد ﷺ{60}. (١٠/٥٠٣) ٥٠٧٤٧- عن ابن سابط: أنّ النبيَّ ﷺ وأصحابه كانوا يعقِلون يد البدنة اليسرى، [وينحرونها] قائمة على ما بقي مِن قوائمها{61}. (١٠/٥٠٣) ٥٠٧٤٨- عن عائشة ابنة سعد بن مالك -من طريق عثمان-: أنّ أباها كان ينحر البدن وهي مباركة{48}. (ز) ٥٠٧٤٩- عن عبد الله بن عمر: أنّه كان ينحرها وهي معقولة يدها اليمنى{63}. (١٠/٥٠٣) ٥٠٧٥٠- عن عمرو بن دينار، قال: رأيتُ عبد الله بن عمر ينحر البُدن وهي باركة، ورجل يعينه{48}. (ز) ٥٠٧٥١- عن عمرو بن دينار، قال: رأيتُ عبد الله بن الزبير على برذون أشعر أوْجَرَها{65} الحربة، وهي قائمة{48}. (ز) ٥٠٧٥٢- عن مجاهد بن جبر -من طريق عبد الكريم-: أنّه كان يَعْقِل يدَها اليسرى إذا أراد أن ينحرها{67}. (١٠/٥٠٤) ٥٠٧٥٣- عن القاسم بن محمد -من طريق أفلح بن حميد-: أنّه كان إذا أراد أن ينحرها يَصُفُّ بين يديها وهي قائمة، ويُمْسِك رَجُلٌ بخِطامها، ورَجُلٌ بذَنَبها، ثم يطعنها بالحربة، ثم يجبذانها حتى يصرعاها. وكان يكره أن تُعَرْقَب{68}{69}. (ز) ٥٠٧٥٤- عن الحسن البصري -من طريق أشعث- في البدنة كيف تنحر؟ قال: تُعْقَل يدها اليسرى، وتنحرها مِن قبل يدها اليمنى{70}. (١٠/٥٠٤) ٥٠٧٥٥- عن عطاء [بن أبي رباح] -من طريق حجّاج- قال: اعْقِل أيَّ اليدين شئت{63}. (١٠/٥٠٤) <q>﴿فَإِذَا وَجَبَتۡ جُنُوبُهَا﴾</q> - تفسير ٥٠٧٥٦- عن عبد الله بن عباس، <q>﴿فاذا وجبت﴾</q>، قال: سَقَطَتْ على جنبها{72}. (١٠/٥٠٦) ٥٠٧٥٧- عن عبد الله بن عباس -من طريق العوفي- <q>﴿فاذا وجبت﴾</q>، قال: نُحِرَتْ{73}. (١٠/٥٠٦) ٥٠٧٥٨- عن مجاهد بن جبر -من طريق ابن أبي نجيح، وابن جُرَيْج- <q>﴿فإذا وجبت جنوبها﴾</q>، قال: سقطت إلى الأرض{74}. (١٠/٥٠٦) ٥٠٧٥٩- عن مجاهد بن جبر -من طريق أبي يحيى- <q>﴿فإذا وجبت﴾</q>: نُحِرَت، فسقطت جنوبها على الأرض مِن قيام أو بروك{75}. (ز) ٥٠٧٦٠- عن عطاء الخراساني -من طريق يونس- في قول الله -تبارك وتعالى-: <q>﴿فإذا وجبت جنوبها﴾</q>، قال: إذا جرت وسقطت جنوبها إلى الأرض{76}. (ز) ٥٠٧٦١- قال مقاتل بن سليمان: <q>﴿فإذا وجبت جنوبها﴾</q>، يعني: فإذا خرَّت لجنبها على الأرض بعد نحرها{59}. (ز) ٥٠٧٦٢- عن محمد بن إسحاق -من طريق سلمة- في قوله: <q>﴿فإذا وجبت﴾</q>، قال: إذا فرغت ونحرت{78}. (ز) ٥٠٧٦٣- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿فإذا وجبت جنوبها﴾</q>، قال: فإذا ماتَتْ{78}٤٤٧٨. (ز) ٤٤٧٨ ذكر ابنُ كثير (١٠/٦٦) قول مجاهد من طريق ابن أبي نجيح وابن جريج، وابن عباس من طريق العوفي، وابن زيد، ثم علَّق على قول ابن زيد قائلًا: «وهذا القول هو مراد ابن عباس ومجاهد، فإنه لا يجوز الأكل من البدنة إذا نحرت حتى تموت وتبرد حركتها، وقد جاء في حديث مرفوع: «ولا تُعجِلوا النفوس أن تَزْهَق»». <q>﴿فَإِذَا وَجَبَتۡ جُنُوبُهَا﴾</q> - آثار متعلقة بالآية ٥٠٧٦٤- عن عبد الله بن قُرْط، قال: قُدِّمَ إلى النبي ﷺ بدنات خمس أو ست، فطَفِقْن يزدلفن إليه بأيتهن يبدأ، فلمّا وجبت جنوبها قال: «مَن شاء اقْتَطَعَ»{80}. (١٠/٥٠٦) <q>﴿فَكُلُوا۟ مِنۡهَا﴾</q> - تفسير ٥٠٧٦٥- عن عبد الله بن عباس -من طريق العوفي- <q>﴿فكلوا منها وأطعموا القانع والمعتر﴾</q>، يقول: يأكل منها، ويُطْعِم{81}. (ز) ٥٠٧٦٦- عن عبد الله بن عمر: أنّه كان يُطْعِم مِن بدنته قبل أن يأكل منها، ويقول: <q>﴿فكلوا منها وأطعموا﴾</q>، هما سواء{4}. (١٠/٥٠٦) ٥٠٧٦٧- عن إبراهيم النخعي -من طريق منصور- قال: كانوا لا يأكلون مِن شيء جعلوه لله، ثم رخص لهم أن يأكلوا من الهدي والأضاحي وأشباهه{83}. (١٠/٥٠٦) ٥٠٧٦٨- عن إبراهيم النخعي -من طريق مغيرة-= (ز) ٥٠٧٦٩- ومجاهد بن جبر -من طريق حصين-= (ز) ٥٠٧٧٠- والحسن البصري -من طريق يونس-= (ز) ٥٠٧٧١- وعطاء [بن أبي رباح] -من طريق حجاج- في قوله: <q>﴿فكلوا منها﴾</q>، قال: إن شاء أكل، وإن شاء لم يأكل.= (ز) ٥٠٧٧٢- قال مجاهد: هي رخصة، هي كقوله: <q>﴿فإذا قضيت الصلاة فانتشروا في الأرض﴾</q> [الجمعة:١٠]، ومثل قوله: <q>﴿وإذا حللتم فاصطادوا﴾</q> [المائدة:٢]{84}. (ز) <q>﴿فَكُلُوا۟ مِنۡهَا﴾</q> - أحكام متعلقة بالآية ٥٠٧٧٣- عن علي [بن أبي طالب] -من طريق الحكم- قال: لا يُؤْكَل مِن النَّذر، ولا مِن جزاء الصيد، ولا مِمّا جعل للمساكين{83}. (١٠/٥٠٧) ٥٠٧٧٤- عن سعيد بن جبير -من طريق سالم- قال: لا يُؤكَل مِن النذر، ولا مِن الكَفّارة، ولا مِمّا جعل للمساكين{83}. (١٠/٥٠٧) <q>﴿وَأَطۡعِمُوا۟ ٱلۡقَانِعَ وَٱلۡمُعۡتَرَّۚ﴾</q> - تفسير ٥٠٧٧٥- عن معاذ، قال: أمَرَنا رسولُ الله ﷺ أن نُطْعِم مِن الضحايا الجارَ، والسائلَ، والمتعففَ{87}. (١٠/٥٠٧) ٥٠٧٧٦- عن عبد الله بن عمر -من طريق عاصم، عمَّن سمع ابن عمر- أنّه كان بمنى، فتلا هذه الآية: <q>﴿فكلوا منها وأطعموا القانع والمعتر﴾</q>. وقال لغلام معه: هذا القانع الذي يقنع بما آتيته{88}. (١٠/٥٠٧) ٥٠٧٧٧- عن عبد الله بن عباس -من طريق علي- قال: القانع: المُتَعَفِّف. والمعتر: السائل{89}. (١٠/٥٠٧) ٥٠٧٧٨- عن عبد الله بن عباس، قال: القانع: الذي يقنع بما أُوتِي. والمُعْتَر: الذي يعترض{4}. (١٠/٥٠٧) ٥٠٧٧٩- عن عبد الله بن عباس، قال: القانع: الذي يجلس في بيته{4}. (١٠/٥٠٧) ٥٠٧٨٠- عن عبد الله بن عباس: أنّ نافع بن الأزرق قال له: أخبِرني عن قوله: <q>﴿القانع والمعتر﴾</q>. قال: القانع: الذي يقنع بما أُعْطِي. والمعتر: الذي يَعْتَرُّ الأبواب. قال: وهل تعرفُ العربُ ذلك؟ قال: نعم، أما سمعت قول الشاعر: على مكثريهم حقُّ من يَعْتَرِيهمُ وعند المقِلِّين السماحةُ والبذلُ؟{92}. (١٠/٥٠٨) ٥٠٧٨١- عن عبد الله بن عباس قال: القانع: الذي يسأل، والمعتر: الذي يتعرض ولا يسأل{93}. (١٠/٥٠٨) ٥٠٧٨٢- عن عبد الله بن عباس -من طريق العوفي-: القانع: المستغني بما أعطيته وهو في بيته. والمعتر: الذي يتعرض لك، ويُلِمُّ بك أن تطعمه من اللحم، ولا يسأل. وهؤلاء الذين أمر أن يطعموا من البدن{94}. (ز) ٥٠٧٨٣- عن عبد الله بن عباس -من طريق أبي ظبيان- أنّه سُئِل عن هذه الآية. قال: أمّا القانع: فالقانع بما أرسلت إليه في بيته. والمعتر: الذي يعتريك{95}. (١٠/٥٠٨) ٥٠٧٨٤- عن إبراهيم النخعي -من طريق منصور-، نحوه{96}. (ز) ٥٠٧٨٥- عن مجاهد بن جبر -من طريق منصور-، مثله{97}. (١٠/٥٠٨) ٥٠٧٨٦- عن سعيد بن جبير -من طريق فرات القزّاز- قال: القانع: السائل الذي يسأل. ثم أنشد قول الشاعر: لمال المرء يصلحه فيُغنى مفاقره أعفُّ مِن القُنُوع{98}. (١٠/٥٠٨) ٥٠٧٨٧- عن سعيد بن جبير -من طريق فرات القزاز- قال: القانع: الذي يسأل فيعطى في يديه، والمعتر: الذي يعتر فيطوف{99}. (١٠/٥٠٩) ٥٠٧٨٨- عن سعيد بن جبير -من طريق فرات القزّاز- في قوله: <q>﴿القانع والمعتر﴾</q>، قال: القانع: الذي يسألك. والمعتر: الذي يزورك، ولا يسألك{100}. (ز) ٥٠٧٨٩- عن سعيد بن جبير، قال: القانع: أهل مكة. والمعتر: سائر الناس{4}. (١٠/٥٠٩) ٥٠٧٩٠- عن إبراهيم النخعي -من طريق مغيرة- في قوله: <q>﴿وأطعموا القانع والمعتر﴾</q>، أنّه قال: أحدهما السائل، والآخر الجار{102}. (ز) ٥٠٧٩١- عن إبراهيم النخعي -من طريق منصور- في قوله: <q>﴿القانع والمعتر﴾</q>، قال: القانع: المتعفف الذي لايسأل شيئًا. والمعتر: الذي يتعرض الأحيان{100}. (ز) ٥٠٧٩٢- عن مجاهد بن جبر، قال: <q>﴿القانع﴾</q>: الطامع بما قبلك، ولا يسألك. <q>﴿والمعتر﴾</q>: الذي يعتريك، ويسألك{104}. (١٠/٥٠٩) ٥٠٧٩٣- عن خُصيف، قال: سمعت مجاهدًا، يقول: القانع: أهل مكة. والمعتر: الذي يعتريك فيسألك{105}. (١٠/٥٠٩) ٥٠٧٩٤- عن مجاهد بن جبر -من طريق ابن أبي نجيح- قال: القانع: السائل. والمعتر: معتر البدن{88}. (١٠/٥٠٩) ٥٠٧٩٥- عن مجاهد بن جبر -من طريق منصور- قال: البائس: الذي يسأل بيده إذا سأل. والقانع: الطّامع الذي يطمع في ذبيحتك من جيرانك. والمعتر: الذي يعتريك بنفسه، ولا يسألك؛ يتعرض لك{107}. (١٠/٥١٠) ٥٠٧٩٦- عن مجاهد بن جبر -من طريق ليث- قال: القانع: جارك الذي يقنع بما أعطيتَه. والمعتر: الذي يتعرض لك، ولا يسألك{94}. (ز) ٥٠٧٩٧- عن مجاهد بن جبر -من طريق أبي يحيى- قال: القانع: السائل الذي يقنع بما أُعْطِي. والمعتر: القاعد في بيته؛ لم يُشْعر بما اعتراه{109}. (ز) ٥٠٧٩٨- عن مجاهد بن جبر -من طربق ابن جريج- قال: المعتر: الذي يعتر بالبدن من غني أو فقير، يقول: يتعرض لك، ويسألك{110}. (ز) ٥٠٧٩٩- عن عكرمة مولى ابن عباس -من طريق قتادة- في قوله: <q>﴿القانع والمعتر﴾</q>، قال: القانع: الذي يقعد في بيته. والمعتر: الذي يسأل{111}. (ز) ٥٠٨٠٠- عن عكرمة مولى ابن عباس -من طريق عمر بن عطاء- قال: القانع: الطامِع{112}. (ز) ٥٠٨٠١- عن بكر بن عبد الله المزني -من طريق حميد الطويل- قال: القانع: السائل. والمعتر: الذي يتعرض لك، ولا يسألك{69}. (ز) ٥٠٨٠٢- قال الحسن البصري -من طريق الحسن بن دينار- القانع: السائل. والمعتر: الذي يتعرض، ويقبل إن أُعْطِي شيئًا{114}. (ز) ٥٠٨٠٣- عن الحسن البصري -من طريق يونس، ومنصور بن زاذان- قال: القانع: الذي يقنع إليك فيما في يديك. والمعتر: الذي يَتَصَدّى لك لتطعمه. ولفظ ابن أبي شيبة: والمعتر: الذي يعتريك؛ يريك نفسه، ولا يسألك{115}. (١٠/٥٠٩) ٥٠٨٠٤- عن القاسم بن أبي بَزَّة أنه سُئِل عن هذه الآية: ما الذي آكل، وما الذي أُعْطِي القانع والمعتر؟ قال: اقسمها ثلاثة أجزاء. قيل: ما القانع؟ قال: مَن كان حولك. قيل: وإن ذُبِح؟ قال: وإن ذُبِح. والمعتر: الذي يأتيك ويسألُك{35}. (١٠/٥١٠) ٥٠٨٠٥- عن محمد بن كعب القرظي أنّه كان يقول في هذه الآية: <q>﴿وأطعموا القانع والمعتر﴾</q>: القانع: الذي يقنع بالشيء اليسير؛ يرضى به. والمعتر: الذي يمر بجانبك، لا يسأل شيئًا، فذلك المعتر{117}. (ز) ٥٠٨٠٦- عن قتادة بن دعامة -من طريق سعيد- قال: القانع: المتعفف الجالس في بيته. والمعتر: الذي يعتريك فيسألك{118}. (ز) ٥٠٨٠٧- قال زيد بن أسلم -من طريق عبد الله بن عياش-: القانع: الذي يسأل الناس{119}. (ز) ٥٠٨٠٨- قال زيد بن أسلم -من طريق ابن أبي هلال- في قول الله تعالى: <q>﴿القانع والمعتر﴾</q>: فالقانع: المسكين الذي يطوف. والمعتر: الصديق والضعيف الذي يزور{102}. (ز) ٥٠٨٠٩- عن عطاء الخراساني -من طريق يونس- في قول الله ﷿: <q>﴿القانع﴾</q> قال: القانع: مَن يقنع برزق الله، ويقعد في بيته. وفي قول الله: <q>﴿المعتر﴾</q> قال: يعتر بِرَّكَ، يرجو فضل ما عندك{76}. (ز) ٥٠٨١٠- عن محمد بن السائب الكلبي -من طريق شعبة- قال: القانع: الذي يسأل. والمعتر: الذي يعتريك؛ يتعرض، ولا يسألك{122}. (ز) ٥٠٨١١- قال مقاتل بن سليمان: <q>﴿فكلوا منها وأطعموا القانع﴾</q> يعني: الراضي الذي يقنع بما يُعْطى، وهو السائل. <q>﴿والمعتر﴾</q> الذي يتعرض للمسألة، ولا يتكلم. فهذا تعليم من الله ﷿، فمن شاء أكل، ومَن لم يسأل لم يأكل، ومَن شاء أطعم{59}. (ز) ٥٠٨١٢- عن مالك بن أنس -من طريق يحيى-: أنّ البائس: هو الفقير. وأن المعتر: هو الزائر ... والقانع: هو الفقير أيضًا{124}. (ز) ٥٠٨١٣- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿وأطعموا القانع والمعتر﴾</q>، قال: القانع: المسكين. والمعتر: الذي يعتر للقوم للحمهم، وليس بمسكين، ولا يكون له ذبيحة، يجيء إلى القوم مِن أجل لحمهم. والبائس الفقير: هو القانع{112}٤٤٧٩. (ز) ٤٤٧٩ أفادت الآثار اختلاف المفسرين في معنى: <q>﴿القانع والمعترّ﴾</q> على أقوال: الأول: القانع: المستغني بما أعطيته ولا يسأل. والمعترّ: الذي يتعرض لك ولا يسأل. الثاني: القانع: الذي يقنع بما عنده ولا يسأل. والمعترّ: الذي يعتريك فيسألك. الثالث: القانع: السائل. والمعترّ: الذي يعتريك ولا يسأل. الرابع: القانع: الجار. والمعترّ: الذي يعتريك من الناس. الخامس: القانع: الطوّاف. والمعترّ: الصديق الزائر. السادس: القانع: الطامع. والمعترّ: الذي يعترُّ بالبدن. السابع: القانع: المسكين. والمعترّ: الذي يتعرض للَّحم. ورجَّح ابنُ جرير (١٦/٥٦٩) مستندًا إلى دلالة لفظ الآية، والعقل، واللغة القولَ الثالث، وهو قول الحسن، وسعيد بن جبير، وزيد بن أسلم من طريق عبدالله بن عياش، وانتقد مَن قال بأن القانع: المكتفي بما عنده، والمستغني به، فقال: «وأولى هذه الأقوال بالصواب قولُ من قال: عُنِي بالقانع: السائل؛ لأنه لو كان المعنيّ بالقانع في هذا الموضع المُكتَفي بما عنده والمستغني به لقيل: وأطعموا القانع والسائل، ولم يقل: <q>﴿وأَطْعِمُوا القانِعَ والمُعْتَرَّ﴾</q>. وفي إتباع ذلك قوله: <q>﴿والمُعْتَرَّ﴾</q> الدليل الواضح على أن القانع معنيٌّ به: السائل، مِن قولهم: قنع فلان إلى فلان، بمعنى: سأله وخضع إليه، فهو يقنَع قُنُوعًا؛... وأما»القانع«الذي هو بمعنى المُكتَفي، فإنه من: قَنِعتُ به -بكسر النون- أقنع قناعةً وقَنَعًا وقنعانًا. وأما»المعتر«: فإنه الذي يأتيك معترًّا بك لتعطيه وتطعمه». <q>﴿كَذَ ٰ⁠لِكَ سَخَّرۡنَـٰهَا لَكُمۡ لَعَلَّكُمۡ تَشۡكُرُونَ ۝٣٦﴾</q> - تفسير ٥٠٨١٤- قال مقاتل بن سليمان: قال سبحانه: <q>﴿كذلك سخرناها﴾</q> يعني: هكذا ذَلَّلْناها <q>﴿لكم﴾</q> يعني: البدن؛ <q>﴿لعلكم تشكرون﴾</q> ربكم ﷿ في نِعَمِه{59}. (ز) ٥٠٨١٥- قال يحيى بن سلّام، في قوله: <q>﴿كذلك سخرناها لكم﴾</q>: الأنعام؛ <q>﴿لعلكم تشكرون﴾</q> لكي تشكروا{127}. (ز) ",footnotes:1:عزاه السيوطي إلى عبد بن حميد. وهي قراءة العشرة.أخرجه ابن أبي شيبة (القسم الأول من الجزء الرابع) ص٣٦٧. وعزاه السيوطي إلى عبد بن حميد.عزاه السيوطي إلى عبد بن حميد، وابن المنذر.عزاه السيوطي إلى ابن أبي حاتم.أخرجه ابن أبي شيبة (القسم الأول من الجزء الرابع) ص٣٦٧.أخرجه ابن أبي شيبة (القسم الأول من الجزء الرابع) ص٣٦٧. وعزاه السيوطي إلى عبد بن حميد، وابن أبي حاتم.السَّمانَة: كثرة اللحم، وهو خلاف الهُزال. مشارق الأنوار للقاضي عياض ٢/٢٢٠، واللسان (سمن).أخرجه ابن أبي شيبة ٤/١١٢. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.أخرجه ابن أبي شيبة (ت: محمد عوامة) ٨/٥٠٦ (١٤٨٧٥).عزاه السيوطي إلى ابن أبي حاتم.أخرجه ابن جرير ١٦/٥٥٣، وأخرج إسحاق البستي في تفسيره ص٣٦٦ نحوه من طريق ابن أبي نجيح، وزاد: وكان الإناث أحب إليهم من الذكور.أخرجه ابن أبي شيبة (ت: محمد عوامة) ٨/٥٠٦ (١٤٨٧٦). وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.تفسير الثعلبي ٧/٢٢، وتفسير البغوي ٥/٣٨٦، واللفظ له.تفسير مقاتل بن سليمان ٣/١٢٧.تفسير مقاتل بن سليمان ٣/١٢٧.أخرجه الثوري في تفسيره بنحوه ص٢١٣، ويحيى بن سلام ١/٣٧٥، وابن جرير ١٦/٥٥٤. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.أخرجه ابن جرير ١٦/٥٥٤. وعزاه السيوطي إلى ابن أبي شيبة، وعبد بن حميد، وابن المنذر، وابن أبي حاتم.أخرجه ابن أبي شيبة (القسم الأول من الجزء الرابع) ص٤١٢.علَّقه يحيى بن سلام ١/٣٧٥.تفسير مقاتل بن سليمان ٣/١٢٧.تفسير يحيى بن سلام ١/٣٧٥.أخرجه أحمد ٣٢/٣٤ (١٩٢٨٣)، وابن ماجه ٤/٣٠٥ (٣١٢٧)، والحاكم ٢/٤٢٢ (٣٤٦٧). وفيه عائذ الله، وأبو داود نفيع بن الحارث. قال الحاكم: «هذا حديث صحيح الإسناد، ولم يخرجاه». وقال الذهبي في التلخيص: «عائذ الله، قال أبوحاتم: منكر الحديث». وقال البيهقي في الكبرى ٩/٤٣٩ (١٩٠١٧، ١٩٠١٨): «قال البخاري: عائذ الله المجاشعي عن أبي داود، روى عنه سلام بن مسكين، لا يصح حديثه. قال أبو أحمد: هذا الحديث يعرف بعائذ الله، وليس يرويه عنه غير سلام بن مسكين، وأبو داود لم يُسَمّ هو نفيع بن الحارث». وقال المنذري في الترغيب ٢/٩٩ (١٦٦٠) معقبًا على كلام الحاكم: «بل واهية، عائذ الله هو المجاشعي، وأبو داود هو نفيع بن الحارث الأعمى، وكلاهما ساقط». وقال البوصيري في مصباح الزجاجة ٣/٢٢٣ (٦٨٠١): «هذا إسناد فيه أبو داود، واسمه: نفيع بن الحارث، وهو متروك». وقال الهيتمي في الزواجر ١/٣٤٦: «صححه الحاكم، واعتُرِض بأن في سنده ساقطَين». وقال الألباني في الضعيفة ٢/١٤ (٥٢٧): «موضوع».أخرجه الترمذي ٣/٣١٥-٣١٦ (١٥٦٧)، وابن ماجه ٤/٣٠٤-٣٠٥ (٣١٢٦)، والحاكم ٤/٢٤٦ (٧٥٢٣). وفيه سليمان بن يزيد، وعبد الله بن نافع. قال الترمذي: «هذا حديث حسن غريب». وقال الحاكم: «هذا حديث صحيح الإسناد، ولم يخرجاه». وقال الذهبي في التلخيص: «سليمان واهٍ». وقال البيهقي في السنن الكبرى ٩/٤٣٨ (١٩٠١٥): «قال البخاري فيما حكى أبو عيسى عنه: هو حديث مرسل، لم يسمع أبو المثنى من هشام بن عروة». وقال ابن الجوزي في العلل المتناهية ٢/٧٩: «وهذا حديث لا يصح، قال يحيى: عبد الله بن نافع ليس بشيء. وقال النسائي: متروك. وقال البخاري: منكر الحديث. وقال ابن حبان: لا يحتج بأخباره». وقال المنذري في الترغيب ٢/٩٩ (١٦٦٠): «سليمان واهٍ، وقد وُثِّق». وقال ابن الملقن في البدر المنير ٩/٢٧٤ معلقًا على تصحيح الحاكم: «وفيه نظر؛ فإن في إسناده سليمان بن يزيد أبو المثنى الكعبي الخزاعي، تركه بعضهم، وقال الرازي: منكر الحديث. وقال ابن حبان: لا يجوز الاحتجاج به. وخالف في ثقاته فذكره فيها». وقال الألباني في الضعيفة ٢/١٤ (٥٢٦): «ضعيف».أخرجه مسلم ٢/٩٦١ (١٣٢٤).أخرجه البخاري ٢/١٦٧ (١٦٨٩)، ٢/١٧٠ (١٧٠٦)، ٤/٧ (٢٧٥٥)، ٨/٣٧-٣٨ (٦١٦٠)، ومسلم ٢/٩٦٠ (١٣٢٢).أخرجه البخاري ٢/١٦٧ (١٦٩٠)، ٤/٧ (٢٧٥٤)، ٨/٣٧ (٦١٥٩)، ومسلم ٢/٩٦١ (١٣٢٣) واللفظ له.أخرجه ابن أبي شيبة (القسم الأول من الجزء الرابع) ص٤١٠.أخرجه يحيى بن سلام ١/٣٧٢.عزاه السيوطي إلى ابن أبي حاتم.أخرجه أبو نعيم في الحلية ٣/١٦٠.أخرجه عبد الرزاق ٢/٣٨. وعزاه السيوطي إلى عبد بن حميد، وابن الأنباري. وعلَّقه يحيى بن سلام ١/٣٧٧ ثم عقَّب عليه بقوله: هي مثل قوله: <q>﴿الصافنات الجياد﴾</q> [ص:٣١] الفرس إذا صفن رفع إحدى رجليه، فقام على طرف الحافر. و(صَوافِنَ) قراءة شاذة، تروى أيضًا عن ابن عباس، وابن مسعود، وابن عمر ﵃، وغيرهم، وقراءة العشرة <q>﴿صَوافَّ﴾</q>. انظر: مختصر ابن خالويه ص٩٦-٩٧.أخرجه عبد الله بن وهب في الجامع ٣/٥٣ (١١٤).أخرجه أبو عبيد ص١٧٨. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه الضياء في المختارة (٧). وعزاه السيوطي إلى ابن الأنباري في المصاحف. والقراءة شاذة. انظر: مختصر الشواذ لابن خالويه ص٩٧-٩٨.عزاه السيوطي إلى عبد بن حميد.عزاه السيوطي إلى ابن الأنباري.أخرجه ابن أبي شيبة ٤/٨٢، والبيهقي في سننه ٥/٢٣٧. وعزاه السيوطي إلى عبد الرزاق، وعبد بن حميد، وابن المنذر، وابن أبي حاتم.أخرجه عبد الله بن وهب في الجامع ٣/٥٣ (١١٤) دون قوله: كانوا يذبحونها لأصنامهم. وعزاه السيوطي إلى عبد الرزاق، وأبي عبيد، وعبد بن حميد، وابن المنذر، وابن الأنباري في المصاحف، وابن أبي حاتم. و(صَوافِى) قراءة شاذة، تروى أيضًا عن أبي موسى الأشعري، وعبد الرحمن بن زيد بن أسلم، وغيرهم. انظر: مختصر ابن خالويه ص٩٧، والمحتسب ٢/٨١.أخرجه عبد الله بن وهب في الجامع ٣/٥٣ (١١٥).عزاه السيوطي إلى أبي عبيد، وابن المنذر، وابن أبي حاتم.أخرجه ابن جرير ١٦/٥٥٨.أخرجه عبد الله بن وهب في الجامع - تفسير القرآن ٢/٥٨ (١١٥) مرسلًا.أخرجه ابن جرير ١٦/٥٥٨.أخرجه ابن جرير ١٦/٥٥٥، ٥٥٨، والحاكم ٢/٣٨٩، ٤/٢٣٣، والبيهقي في سننه ٥/٢٣٧، ٩/٢٨٧. وعزاه السيوطي إلى عبد بن حميد، وابن أبي الدنيا في الأضاحي، وابن المنذر، وابن أبي حاتم.أخرجه يحيى بن سلام ١/٣٧٦، وسعيد بن منصور -كما في تغليق التعليق ٣/٩٢-، وابن أبي شيبة ٤/٨٣، وعبد بن حميد -كما في تغليق التعليق ٣/٩٢-، وابن جرير ١٦/٥٥٦. وعزاه السيوطي إلى الفريابي، وأبي عبيد، وابن المنذر، وابن أبي حاتم.أخرجه ابن جرير ١٦/٥٥٧. وعزاه السيوطي إلى سعيد بن منصور، وابن المنذر، وابن أبي حاتم.أخرجه يحيى بن سلام ١/٣٧٦.أخرجه يحيى بن سلام ١/٣٧٧.أوظافها: جمع وظِيف: والوَظِيف لكل ذِي أربع: ما فوق الرُّسْغ إلى مَفْصِل السّاق. اللسان (وظف).أخرجه ابن جرير ١٦/٥٥٧.أخرجه يحيى بن سلام ١/٣٧٦.أخرجه يحيى بن سلام ١/٣٧٦.أخرجه ابن جرير ١٦/٥٥٧.أخرجه ابن جرير ١٦/٥٥٩.أخرجه ابن جرير ١٦/٥٥٩.أخرجه يحيى بن سلام ١/٣٧٦. ثم عقَّب عليه بقوله: مقراها على هذا التفسير غير مثقلة (صوافٍ).أخرجه يحيى بن سلام ١/٣٧٧.أخرجه أبو جعفر الرملي في جزئه ص١١٧ (تفسير الخراساني).تفسير مقاتل بن سليمان ٣/١٢٨.أخرجه البخاري ٢/١٧١ (١٧١٣)، ومسلم ٢/٩٥٦ (١٣٢٠).أخرجه أبو داود ٣/١٨١ (١٧٦٧)، وابن أبي شيبة ٣/٢١٤ (١٣٥٥٨) واللفظ له. قال الزيلعي في نصب الراية ٣/١٦٤: «وجهل من قال: هذا حديث مرسل. فإن المخبر عن عبد الرحمن بن سابط هو ابن جريج، فالحديث من مسند جابر». وقال الشوكاني في نيل الأوطار ٥/١٤٥: «حديث عبد الرحمن بن سابط هو في سنن أبي داود من حديث جابر بن عبد الله؛ فلا إرسال، وهكذا ذكره الحافظ في الفتح من حديث جابر، وعزاه إلى أبي داود. وقد سكت عنه هو والمنذري، ورجاله رجال الصحيح».أخرجه يحيى بن سلام ١/٣٧٧.أخرجه ابن أبي شيبة (القسم الأول من الجزء الرابع) ص٢٠٦.أخرجه يحيى بن سلام ١/٣٧٧.أوجرها: طَعَنَها بِهِ في فِيها. اللسان (وجر).أخرجه يحيى بن سلام ١/٣٧٧.أخرجه ابن أبي شيبة (القسم الأول من الجزء الرابع) ص٢٠٦-٢٠٧.عرقب الدابة: قطع عُرْقُوبها، وهو الوتر الذي خَلْفَ الكَعْبَين بين مَفْصِل القَدَم والسّاق من ذوات الأْربع. النهاية (عرقب).أخرجه يحيى بن سلام ١/٣٧٨.أخرجه ابن أبي شيبة (القسم الأول من الجزء الرابع) ص٢٠٧.أخرجه ابن أبي شيبة (القسم الأول من الجزء الرابع) ص٢٠٦.أخرجه ابن أبي حاتم -كما في فتح الباري ٣/٥٣٧-. وعزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ١٦/٥٦١. وعزاه السيوطي إلى ابن أبي حاتم.أخرجه يحيى بن سلام ١/٣٧٨، وابن جرير ١٦/٥٦٠-٥٦١. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه يحيى بن سلام ١/٣٧٨، وابن جرير ١٦/٥٦١ بلفظ: نحرت.أخرجه أبو جعفر الرملي في جزئه ص١١٨ (تفسير عطاء الخراساني).تفسير مقاتل بن سليمان ٣/١٢٨.أخرجه ابن جرير ١٦/٥٦١.أخرجه ابن جرير ١٦/٥٦١.أخرجه أحمد ٣١/٤٢٧ (١٩٠٧٥)، وأبو داود ٣/١٧٩-١٨٠ (١٧٦٥)، والحاكم ٤/٢٤٦ (٧٥٢٢)، وابن خزيمة ٤/٥٠٠ (٢٩١٧). قال الحاكم: «حديث صحيح الإسناد، ولم يخرجاه». وقال الذهبي في سير أعلام النبلاء ٢/٢٩٣: «حديث حسن». وقال الألباني في صحيح أبي داود ٦/١٤ (١٥٤٩) «إسناده صحيح، وقد صحّحه ابن حبان، والحاكم».أخرجه ابن جرير ١٦/٥٦٢.عزاه السيوطي إلى ابن أبي حاتم.أخرجه ابن أبي شيبة (القسم الأول من الجزء الرابع) ص١٥٣.أخرجه ابن جرير ١٦/٥٦٢، وأخرج قول مجاهد إسحاق البستي في تفسيره ص٣٦٩.أخرجه ابن أبي شيبة (القسم الأول من الجزء الرابع) ص١٥٣.أخرجه ابن أبي شيبة (القسم الأول من الجزء الرابع) ص١٥٣.أخرجه الخطيب في تاريخه ١٣/٣٦٦-٣٦٧ (٣٩٢٨)، والأصبهاني في الترغيب والترهيب ١/٢٥٧ (٣٩٣) واللفظ له، من طريق ابن لهيعة، عن ابن أنعم، عن عتبة بن حميد، عن عبادة بن نسي، عن ابن غنم، عن معاذ به. إسناده ضعيف جِدًّا، فيه ابن لهيعة، وعبد الرحمن بن زياد بن أنعم، وعتبة بن حميد، وكلهم ضعفاء الحفظ أو في حفظهم شيء، كما في التقريب لابن حجر (٣٥٦٣، ٣٨٦٢، ٤٤٢٩). وفي إسناد الخطيب علي بن حماد بن السكن، والواقدي، وهما متروكان، كما في التقريب لابن حجر (٦١٧٥).أخرجه ابن أبي شيبة ٤/٧٢.أخرجه ابن جرير ١٦/٥٦٢، وابن أبي حاتم -كما في الإتقان ٢/٣٠-.عزاه السيوطي إلى ابن أبي حاتم.عزاه السيوطي إلى ابن أبي حاتم.أخرجه الطستي -كما في الإتقان ٢/٧٢-.عزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ١٦/٥٦٣.أخرجه البيهقي في سننه ٩/٢٩٤. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه ابن جرير ١٦/٥٦٩.أخرجه ابن أبي شيبة ٤/٧٢، وابن جرير ١٦/٥٦٩.أخرجه ابن أبي شيبة ٨/٥١٦، ١٠/٤٧٥، وابن جرير ١٦/٥٦٦. وعزاه السيوطي إلى عبد بن حميد.أخرجه عبد الرزاق ٢/٣٨. وعزاه السيوطي إلى عبد بن حميدأخرجه الثوري ص٢١٤.عزاه السيوطي إلى ابن أبي حاتم.أخرجه ابن جرير ١٦/٥٦٧.أخرجه الثوري ص٢١٤.أخرجه عبد الرزاق ٢/٣٨ من قول ابن أبي نجيح، وعبد بن حميد -كما في فتح الباري ٣/٥٣٦-، والبيهقي في سننه ٩/٢٩٤.أخرجه ابن أبي شيبة (ت: محمد عوامة) ٨/٧٣٠-٧٣١ (١٥٨٣٢)، وابن جرير ١٦/٥٦٣.أخرجه ابن أبي شيبة ٤/٧٢.أخرجه البيهقي في سننه ٩/٢٩٤.أخرجه ابن جرير ١٦/٥٦٣.أخرجه يحيى بن سلام ١/٣٧٩.أخرجه إسحاق البستي في تفسيره ص٣٧٠.أخرجه ابن جرير ١٦/٥٦٤.أخرجه ابن جرير ١٦/٥٦٨.أخرجه يحيى بن سلام ١/٣٧٨.تفسير ابن أبي زمنين ٣/١٨٢، وهو ساقط من المطبوع مِن تفسير يحيى بن سلام ١/٣٧٩ كما ذكرت محققته.أخرجه ابن أبي شيبة ٤/٧٢ من طريق يونس، وابن جرير ١٦/٥٦٥ بنحوه من طريق منصور بن زادان. وعزاه السيوطي إلى عبد بن حميد.عزاه السيوطي إلى عبد بن حميد.أخرجه عبد الله بن وهب في الجامع - تفسير القرآن ٢/٧٤-٧٥ (١٤٤) من طريق أبي صخر، وابن جرير ١٦/٥٦٣.أخرجه ابن جرير ١٦/٥٦٤. وعند يحيى بن سلام ١/٣٧٨ بلفظ: القانع: الفقير المتعفف القاعد في بيته لا يسأل. والمعتر: الذي يعتريك يسألك في كفه. ولكلٍّ عليك حق.أخرجه عبد الله بن وهب في الجامع - تفسير القرآن ١/٦١-٦٢ (١٣٦)، وابن جرير ١٦/٥٦٦.أخرجه ابن جرير ١٦/٥٦٧.أخرجه أبو جعفر الرملي في جزئه ص١١٨ (تفسير عطاء الخراساني).أخرجه ابن جرير ١٦/٥٦٥.تفسير مقاتل بن سليمان ٣/١٢٨.الموطأ (ت: د. بشار عواد) ١/٦٤١-٦٤٢ (١٤٣٥).أخرجه ابن جرير ١٦/٥٦٨.تفسير مقاتل بن سليمان ٣/١٢٨.تفسير يحيى بن سلام ١/٣٧٩.
22,37," <q>﴿لَن یَنَالَ ٱللَّهَ لُحُومُهَا وَلَا دِمَاۤؤُهَا وَلَـٰكِن یَنَالُهُ ٱلتَّقۡوَىٰ مِنكُمۡۚ﴾</q> - قراءات ٥٠٨١٦- عن محمد ابن شهاب الزهري -من طريق عقيل بن خالد- أنّه كان يقول: ‹لَن تَنالَ اللهَ لُحُومُها ولا دِمَآؤُها ولَكِن تَنالُهُ التَّقْوى مِنكُمْ›{1}. (ز) <q>﴿لَن یَنَالَ ٱللَّهَ لُحُومُهَا وَلَا دِمَاۤؤُهَا وَلَـٰكِن یَنَالُهُ ٱلتَّقۡوَىٰ مِنكُمۡۚ﴾</q> - نزول الآية ٥٠٨١٧- عن عبد الله بن عباس، قال: كان المشركون إذا ذبحوا استقبلوا الكعبة بالدماء، فينضحون بها نحو الكعبة، فأراد المسلمون أن يفعلوا ذلك؛ فأنزل الله: <q>﴿لن ينال الله لحومها ولا دماؤها﴾</q> الآية{2}. (١٠/٥١٠) ٥٠٨١٨- قال مقاتل بن سليمان: <q>﴿لن ينال الله لحومها ولا دماؤها﴾</q>، وذلك أنّ كُفّار العرب كانوا في الجاهلية، إذا نحروا البدن عند زمزم، أخذوا دماءها فنضحوها قِبَل الكعبة، وقالوا: اللَّهُمَّ، تَقَبَّل مِنّا. فأراد المسلمون أن يفعلوا ذلك؛ فأنزل الله ﷿: <q>﴿لن ينال الله لحومها ولا دماؤها﴾</q>{3}. (ز) ٥٠٨١٩- عن عبد الملك ابن جُرَيْج، قال: كان أهلُ الجاهلية ينضحون البيت بلحوم الإبل ودمائها، فقال أصحاب النبي ﷺ: فنحن أحقُّ أن ننضح. فأنزل الله: <q>﴿لن ينال الله لحومها﴾</q>{4}. (١٠/٥١٠) ٥٠٨٢٠- عن عبد الملك ابن جريج -من طريق حجاج- قال: النُّصُب ليست بأصنام، الصنم يُصَوَّر وينقش، وهذه حجارة تُنصَب، ثلاثمائة وستون حَجَرًا، فكانوا إذا ذبحوا نضحوا الدم على ما أقبل من البيت، وشَرَّحُوا اللحم، وجعلوه على الحجارة، فقال المسلمون: يا رسول الله، كان أهل الجاهلية يُعَظِّمون البيتَ بالدم، فنحن أحقُّ أن نُعَظِّمه. فكأنّ النبي ﷺ لم يكره ما قالوا؛ فأنزل الله: <q>﴿لن ينال الله لحومها ولا دماؤها﴾</q>{5}. (١٠/٥١٠) <q>﴿لَن یَنَالَ ٱللَّهَ لُحُومُهَا وَلَا دِمَاۤؤُهَا وَلَـٰكِن یَنَالُهُ ٱلتَّقۡوَىٰ مِنكُمۡۚ﴾</q> - تفسير الآية ٥٠٨٢١- عن إبراهيم النخعي -من طريق منصور- <q>﴿ولكن يناله التقوى منكم﴾</q>، قال: ما التُمِس به وجهُ الله{6}. (١٠/٥١١) ٥٠٨٢٢- عن الضحاك بن مزاحم، <q>﴿ولكن يناله التقوى منكم﴾</q>، يقول: إن كانت مِن طيب، وكنتم طيبين؛ وصَل إلَيَّ أعمالكم وتَقَبَّلْتُها{7}. (١٠/٥١١) ٥٠٨٢٣- قال مقاتل بن سليمان: <q>﴿ولكن يناله التقوى منكم﴾</q>، يقول: النحر هو تقوى منكم، فالتقوى هو الذي ينال الله ويرفعه إليه، فأما اللحوم والدماء فلا يرفعه إليه{3}. (ز) ٥٠٨٢٤- عن مقاتل بن حيان، <q>﴿لن ينال الله﴾</q>، قال: لن يُرفع إلى الله لحومها ولا دماؤها، ولكن نحر البدن مِن تقوى الله وطاعته. يقول: يُرفَع إلى الله منكم الأعمال الصالحة، والتقوى{9}. (١٠/٥١١) ٥٠٨٢٥- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿لن ينال الله لحومها ولا دماؤها ولكن يناله التقوى منكم﴾</q>، قال: إن اتَّقَيْتَ اللهَ في هذه البدن، وعملت فيها لله، وطلبت ما قال الله تعظيمًا لشعائر الله، ولحرمات الله؛ فإنّه قال: <q>﴿ومن يعظم شعائر الله فإنها من تقوى القلوب﴾</q>. قال: <q>﴿ومن يعظم حرمات الله فهو خير له عند ربه﴾</q>. قال: وجعلته طيِّبًا، فذلك الذي يتقبل الله، فأما اللحوم والدماء فمن أين تنال الله؟!{10}. (ز) ٥٠٨٢٦- قال يحيى بن سلّام: قوله: <q>﴿لن ينال الله لحومها ولا دماؤها﴾</q>، يقول: لا يصعد إلى الله لحومها ولا دماؤها. وقد كان المشركون يذبحون لآلهتهم، ثم ينضحون دماءها حول البيت، <q>﴿ولكن يناله التقوى منكم﴾</q> يصعد إليه التقوى منكم. يعني: من آمن{11}. (ز) <q>﴿كَذَ ٰ⁠لِكَ سَخَّرَهَا لَكُمۡ لِتُكَبِّرُوا۟ ٱللَّهَ عَلَىٰ مَا هَدَىٰكُمۡۗ﴾</q> - تفسير ٥٠٨٢٧- قال مقاتل بن سليمان: <q>﴿كذلك سخرها لكم﴾</q> يعني: البدن؛ <q>﴿لتكبروا﴾</q> لِتُعَظِّموا <q>﴿الله على ما هداكم﴾</q> لدينه{3}. (ز) ٥٠٨٢٨- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿لتكبروا الله على ما هداكم﴾</q>، قال: على ذبحها في تلك الأيام{13}. (١٠/٥١١) ٥٠٨٢٩- قال يحيى بن سلّام: قوله: <q>﴿كذلك سخرها لكم﴾</q> الأنعام <q>﴿لتكبروا الله على ما هداكم﴾</q>، وقال في الآية الأولى: <q>﴿ليذكروا اسم الله على ما رزقهم من بهيمة الأنعام﴾</q> إذا ذبحوا. فالسُّنَّة إذا ذبح أو نحر أن يقول: بسم الله، والله أكبر{11}. (ز) <q>﴿وَبَشِّرِ ٱلۡمُحۡسِنِینَ ۝٣٧﴾</q> - تفسير ٥٠٨٣٠- قال مقاتل بن سليمان: <q>﴿وبشر المحسنين﴾</q> بالجنَّة، فمَن فعل ما ذكر اللهَ في هذه الآيات فقد أحسن{3}. (ز) ٥٠٨٣١- قال يحيى بن سلّام: قوله: <q>﴿وبشر المحسنين﴾</q> بالجنة{16}٤٤٨٠. (ز) ٤٤٨٠ ذكر ابنُ عطية (٦/٢٥١) بأنّه رُوِي «أنّ قوله تعالى: <q>﴿وبَشِّرِ المُحْسِنِينَ﴾</q> نزلت في الخلفاء الأربعة». ثم استدرك على ذلك قائلًا: «فأما ظاهر اللفظة فيقتضي العموم في كل محسن». <q>﴿وَبَشِّرِ ٱلۡمُحۡسِنِینَ ۝٣٧﴾</q> - آثار متعلقة بالآية ٥٠٨٣٢- عن الحسن بن علي، قال: أمرنا رسولُ الله ﷺ أن نلبس أجودَ ما نَجِد، وأن نَتَطَيَّب بأجودَ ما نَجِد، وأن نُضَحِّي بأسمن ما نَجِد، والبقرة عن سبعة، والجزور عن سبعة، وأن نُظْهِر التكبير، وعلينا السَّكِينة والوَقار{17}. (١٠/٥١١) ",footnotes:1:أخرجه عبد الله بن وهب في الجامع - تفسير القرآن ٣/٤٩-٥٠ (١٠٢). والقراءة متواترة، قرأ بها يعقوب، وقرأ بقية العشرة: <q>﴿لَن يَنالَ اللَّهَ لُحُومُها ولا دِماؤُها ولَكِن يَنالُهُ التَّقْوى مِنكُمْ﴾</q> بالياء فيهما. انظر: النشر ٢/٣٢٦، والإتحاف ص٣٩٨.عزاه السيوطي إلى ابن المنذر، وابن مردويه.تفسير مقاتل بن سليمان ٣/١٢٨.عزاه السيوطي إلى ابن أبي حاتم مرسلًا.أخرجه ابن جرير ٨/٧٠ مرسلًا. وعزاه السيوطي إلى ابن المنذر.أخرجه إسحاق البستي في تفسيره ص٣٧٢. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.عزاه السيوطي إلى ابن المنذر.تفسير مقاتل بن سليمان ٣/١٢٨.عزاه السيوطي إلى ابن أبي حاتم.أخرجه ابن جرير ١٦/٥٧٠.تفسير يحيى بن سلام ١/٣٧٩.تفسير مقاتل بن سليمان ٣/١٢٨.أخرجه ابن جرير ١٦/٥٧١. وعزاه السيوطي إلى ابن أبي حاتم.تفسير يحيى بن سلام ١/٣٧٩.تفسير مقاتل بن سليمان ٣/١٢٨.تفسير يحيى بن سلام ١/٣٨٠.أخرجه البيهقي في شعب الإيمان ٥/٢٨٩ (٣٤٤٢)، والحاكم ٤/٢٥٦ (٧٥٦٠) بلفظ: والجزور عن عشرة. وفيه إسحاق بن بزرج. قال الحاكم: «لولا جهالة إسحاق بن بزرج لَحكمتُ للحديث بالصحة». وقال ابن الملقن في تحفة المحتاج ١/٥٤٤ (٦٩٤) مُعَلِّقًا على الحاكم: «ليس بمجهول، فقد ضعّفه الأزدي، ووَثَّقه ابن حِبّان». وقال الهيثمي في المجمع ٤/٢٠-٢١ (٥٩٦١): «رواه الطبراني في الكبير، وفيه عبد الله بن صالح، قال عبد الملك بن شعيب بن الليث بن سعد: ثقة مأمون. وضعّفه أحمد، وجماعة».
22,38," <q>﴿إِنَّ ٱللَّهَ یُدَ ٰ⁠فِعُ عَنِ ٱلَّذِینَ ءَامَنُوۤا۟ۗ﴾</q> - قراءات ٥٠٨٣٣- عن عاصم [بن أبي النجود] أنّه قرأ: <q>﴿إنَّ اللَّهَ يُدافِعُ﴾</q> بالألف، ورفع الياء{1}. (١٠/٥١٢) <q>﴿إِنَّ ٱللَّهَ یُدَ ٰ⁠فِعُ عَنِ ٱلَّذِینَ ءَامَنُوۤا۟ۗ﴾</q> - تفسير الآية ٥٠٨٣٤- تفسير الحسن البصري: قوله: <q>﴿إنَّ اللَّهَ يُدافِعُ عَنِ الَّذِينَ آمَنُواْ﴾</q>: يدافع عنهم، فيعصمهم من الشيطان في دينهم{2}. (ز) ٥٠٨٣٥- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿إنَّ اللَّهَ يُدافِعُ عَنِ الَّذِينَ آمَنُواْ﴾</q>، قال: واللهِ، ما يُضَيِّع اللهُ رجلًا قطُّ حفِظ له دينَه{3}. (١٠/٥١٢) ٥٠٨٣٦- قال مقاتل بن سليمان: قوله ﷿: <q>﴿إنَّ اللَّهَ يُدافِعُ﴾</q> كفار مكة <q>﴿عَنِ الَّذِينَ آمَنُواْ﴾</q> بمكة، هذا حين أمر المؤمنين بالكفِّ عن كُفّار مكة قبل الهجرة حين آذوهم، فاستشاروا النبيَّ ﷺ في قتالهم في السر، فنهاهم الله ﷿{4}. (ز) <q>﴿إِنَّ ٱللَّهَ لَا یُحِبُّ﴾</q> - تفسير ٥٠٨٣٧- عن سفيان، في قوله: <q>﴿ان الله لا يحب﴾</q>، قال: لا يُقَرِّبُ{5}. (١٠/٥١٢) <q>﴿كُلَّ خَوَّانࣲ كَفُورٍ ۝٣٨﴾</q> - تفسير ٥٠٨٣٨- قال عبد الله بن عباس: خانوا اللهَ، فجعلوا معه شريكًا، وكفروا نِعَمَه{6}. (ز) ٥٠٨٣٩- قال مجاهد بن جبر: كل شيء في القرآن: <q>﴿كفور﴾</q> يعني: به: الكُفّار{5}. (١٠/٥١٢) ٥٠٨٤٠- عن الحسن البصري -من طريق أبي الأشهب- قوله: <q>﴿إن الله لا يحب كل خوان كفور﴾</q>، في قوله: <q>﴿إنا عرضنا الأمانة على السموات والأرض والجبال فأبين أن يحملنها وأشفقن منها وحملها الإنسان إنه كان ظلوما جهولا (٧٢) ليعذب الله المنافقين والمنافقات والمشركين والمشركات﴾</q> [الأحزاب:٧٢-٧٣]، قال: هما اللذان ظلماها، هما اللذان خاناها: المنافق، والمشرك{2}. (ز) ٥٠٨٤١- قال مقاتل بن سليمان: <q>﴿إن الله لا يحب كل خوان﴾</q> يعني: كل عاص، <q>﴿كفور﴾</q> بتوحيد الله ﷿، يعني: كفار مكة{4}. (ز) ",footnotes:1:عزاه السيوطي إلى عبد بن حميد. وهي قراءة العشرة ما عدا ابن كثير، وأبا عمرو، ويعقوب؛ فإنهم قرؤوا: <q>﴿إنَّ اللَّهَ يَدْفَعُ﴾</q> بفتح الياء وإسكان الدال من دون ألف. انظر: النشر ٢/٣٢٦، والإتحاف ص٣٩٩.أخرجه يحيى بن سلام ١/٣٨٠.أخرجه يحيى بن سلام ١/٣٨٠. وعزاه السيوطي إلى ابن أبي حاتم.تفسير مقاتل بن سليمان ٣/١٢٩.عزاه السيوطي إلى ابن أبي حاتم.تفسير البغوي ٥/٣٨٨.عزاه السيوطي إلى ابن أبي حاتم.أخرجه يحيى بن سلام ١/٣٨٠.تفسير مقاتل بن سليمان ٣/١٢٩.
