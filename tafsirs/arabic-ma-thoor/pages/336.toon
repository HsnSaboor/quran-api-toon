quran[8]{c,v,t}:
  22,31,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿حُنَفَاۤءَ لِلَّهِ غَیۡرَ مُشۡرِكِینَ بِهِۦۚ﴾</span> - نزول الآية</h3></p><p><div></p><p><p><span class="item-no">٥٠٥٩٤<span class="dash">-</span></span> عن <span class="name-1">أبي بكر الصديق</span>، قال: كان الناس يَحُجُّون، وهم مشركون، فكانوا يسمونهم: حنفاء الحجاج، فنزلت: <span class="qpc-hafs">﴿حنفاء لله غير مشركين به﴾</span>{1}. (١٠/٤٨٩)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿حُنَفَاۤءَ لِلَّهِ غَیۡرَ مُشۡرِكِینَ بِهِۦۚ﴾</span> - تفسير الآية</h3></p><p><div></p><p><p><span class="item-no">٥٠٥٩٥<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، في قوله: <span class="qpc-hafs">﴿حنفاء لله غير مشركين به﴾</span>، قال: حُجّاجًا لله غير مشركين به؛ وذلك أنّ الجاهلية كانوا يَحُجُّون مشركين، فلمّا أظهر الله الإسلام قال الله للمسلمين: حُجُّوا الآن غير مشركين بالله{2}. (١٠/٤٨٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٥٩٦<span class="dash">-</span></span> عن <span class="name-2">عبد الله بن القاسم</span> مولى أبي بكر الصديق، قال: كان ناسٌ مِن مُضَر وغيرِهم يَحُجُّون البيت، وهم مشركون، وكان مَن لا يَحُجُّ البيتَ مِن المشركين يقولون: قولوا: حنفاء. فقال الله: <span class="qpc-hafs">﴿حنفاء لله غير مشركين به﴾</span>. يقول: حُجّاجًا غير مشركين به{1}. (١٠/٤٨٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٥٩٧<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span>، <span class="qpc-hafs">﴿حنفاء﴾</span>، قال: حُجّاجًا{4}. (١٠/٤٨٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٥٩٨<span class="dash">-</span></span> عن <span class="name-2">الضحاك بن مزاحم</span>، مثله{4}. (١٠/٤٨٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٥٩٩<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span>، <span class="qpc-hafs">﴿حنفاء﴾</span>، قال: مُتَّبِعين{6}. (١٠/٤٩٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٦٠٠<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق سفيان- قال: الحُجّاج{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٦٠١<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span>، قال: ما كان في القرآن مِن حنفاء، قال: مسلمين، وما كان حنفاء مسلمين فهم حُجّاج{8}. (١٠/٤٨٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٦٠٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿حنفاء لله﴾</span> يعني: مخلصين لله بالتوحيد، <span class="qpc-hafs">﴿غير مشركين به﴾</span>{9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٦٠٣<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: قوله: <span class="qpc-hafs">﴿حنفاء لله﴾</span> مخلصين لله، وقال بعضهم: حُجّاجًا، أي: لله مخلصين، <span class="qpc-hafs">﴿غير مشركين به﴾</span>{10}<span class=comment-ref>٤٤٦٦</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٤٤٦٦</span> <span class="comment-type-2">انتقد</span> <u>ابنُ عطية</u> (٦/٢٤٤) قول ابن عباس وما في معناه، فقال: «وهذا تخصيصٌ لا حُجَّة معه».</div></p><p><h3><span class="qpc-hafs">﴿وَمَن یُشۡرِكۡ بِٱللَّهِ فَكَأَنَّمَا خَرَّ مِنَ ٱلسَّمَاۤءِ فَتَخۡطَفُهُ ٱلطَّیۡرُ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٠٦٠٤<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق مَعْمَر- في قوله: <span class="qpc-hafs">﴿ومن يشرك بالله فكأنما خر من السماء﴾</span> الآية، قال: هذا مَثَلٌ ضربه الله لِمَن أشرك بالله في بُعْدِه مِن الهُدى وهلاكه{11}. (١٠/٤٩٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٦٠٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثم عَظَّم الشِّرْك، فقال: <span class="qpc-hafs">﴿ومن يشرك بالله فكأنما خر من السماء فتخطفه الطير﴾</span>، يعني: فتذهب به الطير النسور{9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٦٠٦<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: قوله: <span class="qpc-hafs">﴿ومن يشرك بالله فكأنما خر من السماء﴾</span> في البُعْد مِن الله{10}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿أَوۡ تَهۡوِی بِهِ ٱلرِّیحُ فِی مَكَانࣲ سَحِیقࣲ ۝٣١﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٠٦٠٧<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح، وابن جريج- في قوله: <span class="qpc-hafs">﴿في مكان سحيق﴾</span>، قال: بعيد{14}. (١٠/٤٩٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٦٠٨<span class="dash">-</span></span> قال <span class="name-2">الحسن البصري</span>: شَبَّه الله أعمال المشركين بالشيء يَخِرُّ مِن السماء فتخطفه الطير، فلا يصل إلى الأرض، أو تهوي به الريح في مكان سحيق، يعني: بعيد؛ فيذهب فلا يوجد له أصل، ولا يُرى له أثر{15}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٦٠٩<span class="dash">-</span></span> تفسير <span class="name-2">إسماعيل السُّدِّيّ</span>: <span class="qpc-hafs">﴿في مكان﴾</span>، يعني: تذهب به الريح{16}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٦١٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿أو تهوي به الريح في مكان سحيق﴾</span>، يعني: بعيدًا، فهذا مَثَل الشِّرك في البُعْد مِن الله ﷿{9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٦١١<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: قوله: <span class="qpc-hafs">﴿أو تهوي به الريح﴾</span> يعني: تذهب به الريح <span class="qpc-hafs">﴿في مكان سحيق﴾</span> يعني: أنّه ليس لأعمال المشركين عند الله قرارٌ لهم به عنده خير في الآخرة{18}. (ز)</p></p><p></div></p></div>",footnotes:1:عزاه السيوطي إلى ابن أبي حاتم.عزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.عزاه السيوطي إلى ابن أبي حاتم.عزاه السيوطي إلى عبد بن حميد.عزاه السيوطي إلى عبد بن حميد.عزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.أخرجه الثوري في تفسيره ص٢١٢.عزاه السيوطي إلى ابن المنذر.تفسير مقاتل بن سليمان ٣/١٢٦.تفسير يحيى بن سلام ١/٣٧٠.أخرجه عبد الرزاق ٢/٣٨، وابن جرير ١٦/٥٣٨-٥٣٩. وعزاه السيوطي إلى ابن أبي حاتم.تفسير مقاتل بن سليمان ٣/١٢٦.تفسير يحيى بن سلام ١/٣٧٠.أخرجه ابن جرير ١٦/٥٣٩. وعلَّقه يحيى بن سلام ١/٣٧٠. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.علَّقه يحيى بن سلام ١/٣٧١.علَّقه يحيى بن سلام ١/٣٧٠.تفسير مقاتل بن سليمان ٣/١٢٦.تفسير يحيى بن سلام ١/٣٧٠-٣٧١.
  22,32,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿ذَ ٰ⁠لِكَۖ وَمَن یُعَظِّمۡ شَعَـٰۤىِٕرَ ٱللَّهِ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٠٦١٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، في قوله: <span class="qpc-hafs">﴿ومن يعظم شعائر الله﴾</span>، قال: البُدْن{1}. (١٠/٤٩٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٦١٣<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق مقسم- في قوله: <span class="qpc-hafs">﴿ذلك ومن يعظم شعائر الله﴾</span>، قال: الاسْتِسْمان، والاسْتِحْسان، والاسْتِعْظام{2}. (١٠/٤٩٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٦١٤<span class="dash">-</span></span> عن طارق بن أحمد، قال: كنت عند <span class="name-1">ابن عمر</span> إذ جاءه رجلٌ، فقال: يا أبا عبد الرحمن، أيُّ الشعائر أعظم؟ قال: أوَفي شكٍّ أنت منه؟! هذا أعظم الشعائر. يعني: البيت{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٦١٥<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق القاسم بن أبي بزة- <span class="qpc-hafs">﴿ذلك ومن يعظم شعائر الله﴾</span>، قال: استعظام البدن، واستسمانها، واستحسانها{4}. (١٠/٤٩٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٦١٦<span class="dash">-</span></span> عن <span class="name-2">عطاء [بن أبي رباح]</span> -من طريق حبيب المعلم- أنّه سُئِل عن شعائر الله. قال: حرمات الله: اجتناب سخط الله، واتباع طاعته؛ فذلك شعائر الله{5}. (١٠/٤٩٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٦١٧<span class="dash">-</span></span> عن <span class="name-2">محمد بن أبي موسى</span> -من طريق داود بن أبي هند- في قوله: <span class="qpc-hafs">﴿ذلك ومن يعظم شعائر الله﴾</span>، قال: الوقوف بعرفة مِن شعائر الله، وبجَمْع مِن شعائر الله، والبُدْن من شعائر الله، ورمي الجمار من شعائر الله، والحَلْق مِن شعائر الله، فمَن يعظمها <span class="qpc-hafs">﴿فإنها من تقوى القلوب﴾</span>{6}. (١٠/٤٩١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٦١٨<span class="dash">-</span></span> تفسير <span class="name-2">الحسن البصري</span>: شعائر الله: دين الله كله{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٦١٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ذلك﴾</span> يقول: هذا الذي أمر؛ اجتناب الأوثان، <span class="qpc-hafs">﴿ومن يعظم شعائر الله﴾</span> يعني: البدن مَن أعْظَمَها وأَسْمَنَها{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٦٢٠<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿ومن يعظم شعائر الله﴾</span>، قال: الشعائر: الجِمار، والصفا والمروة من شعائر الله، والمشعر الحرام، والمزدلفة. قال: والشعائر تدخل في الحرمِ، هي شعائر، وهي حرمٌ{9}<span class=comment-ref>٤٤٦٧</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٤٤٦٧</span> أفادت الآثار اختلاف المفسرين في معنى: «شعائر الله» في الآية؛ <b>فقيل</b>: إنها البدن، وتعظيمها: استحسانها، واستسمانها. <b>وقيل</b>: إنها مناسك الحج، وتعظيمها: إشعارها.</p><p>و<span class="comment-type-3">رجَّح</span> <u>ابنُ جرير</u> (١٦/٥٤١) <span class="mustanad">مستندًا إلى دلالة العموم</span> شمول الآية لكلا المعنيين، فقال: «إن الله -تعالى ذِكْره- أخبر أنّ تعظيم شعائره، وهي ما جعله أعلامًا لخلقه فيما تعبَّدهم به من مناسك حجِّهم من الأماكن التي أمرهم بأداء ما افترض عليهم منها عندها، والأعمال التي ألزمهم عملها في حجهم: من تقوى قلوبهم، لم يَخْصُص من ذلك شيئًا، فتعظيم كل ذلك من تقوى القلوب كما قال -جلَّ ثناؤه-، وحقٌّ على عباده المؤمنين به تعظيم جميع ذلك».</div></p><p><h3><span class="qpc-hafs">﴿فَإِنَّهَا مِن تَقۡوَى ٱلۡقُلُوبِ ۝٣٢﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٠٦٢١<span class="dash">-</span></span> تفسير <span class="name-2">إسماعيل السُّدِّيّ</span>: قوله: <span class="qpc-hafs">﴿فإنها من تقوى القلوب﴾</span>، يعني: مِن إخلاص القلوب{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٦٢٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فإنها من تقوى القلوب﴾</span>، يعني: مِن إخلاص القلوب{8}. (ز)</p></p><p></div></p></div>",footnotes:1:عزاه السيوطي إلى ابن أبي حاتم.أخرجه ابن جرير ١٦/٥٤٠، وابن أبي حاتم -كما في تفسير ابن كثير ٥/٤١٦-، كما أخرجه ابن أبي شيبة (القسم الرابع من الجزء الرابع) ص٢٩٤ من طريق مجاهد بنحوه. وعزاه السيوطي إلى ابن المنذر.أخرجه يحيى بن سلام ١/٣٧١.أخرجه ابن أبي شيبة (القسم الرابع من الجزء الرابع) ص٢٩٥، وابن جرير ١٦/٥٤٠، ٥٤٢، ٥٤٨. وعلَّقه يحيى بن سلام ١/٣٧١. وعزاه السيوطي إلى عبد بن حميد، وابن أبي حاتم.أخرجه ابن أبي شيبة (القسم الأول من الجزء الرابع) ص٢٩٥.أخرجه ابن أبي شيبة (القسم الرابع من الجزء الرابع) ص٢٩٤-٢٩٥، وابن جرير ١٦/٥٤١، ٥٤٦. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.علَّقه يحيى بن سلام ١/٣٧١.تفسير مقاتل بن سليمان ٣/١٢٦.أخرجه ابن جرير ١٦/٥٤١.علَّقه يحيى بن سلام ١/٣٧١.تفسير مقاتل بن سليمان ٣/١٢٦.
  22,33,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿لَكُمۡ فِیهَا مَنَـٰفِعُ إِلَىٰۤ أَجَلࣲ مُّسَمࣰّى﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٠٦٢٣<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق أبي رزين- في قوله: <span class="qpc-hafs">﴿لكم فيها منافع﴾</span>، قال: أسواقهم، فإنه لم يذكر منافع إلا للدنيا{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٦٢٤<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطاء- قال: الأجل المُسَمّى إلى أن تُقَلَّد{2} وتُشْعَر{3}، هي البدن ينتفع بظهورها، ويُستعان بها{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٦٢٥<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- <span class="qpc-hafs">﴿لكم فيها منافع إلى أجل مسمى﴾</span>، قال: في ظهورها، وألبانها، وأوبارها، وأشعارها، وأصوافها إلى أن تُسمّى: هَدْيًا، فإذا سُمِّيَت: هديًا ذهبت المنافع{5}. (١٠/٤٩٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٦٢٦<span class="dash">-</span></span> عن <span class="name-2">الضحاك بن مزاحم</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٦٢٧<span class="dash">-</span></span> و<span class="name-2">عطاء [بن أبي رباح]</span>، قالا: المنافع فيها: الركوب إذا احتاج، وفي أوبارها، وألبانها. والأجل المُسَمّى: إلى أن تقلَّد فتصير بُدنًا{6}. (١٠/٤٩١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٦٢٨<span class="dash">-</span></span> عن ابن جُرَيْج، قال: قال <span class="name-2">عطاء بن أبي رباح</span> في قوله: <span class="qpc-hafs">﴿لكم فيها منافع إلى أجل مسمى﴾</span>، قال: إلى أن تُنحَر. قال: له أن يحمل عليها المُعْي{7}، والمنقطع به، من الضرورة؛ كان النبي ﷺ يأمر بالبدنة إذا احتاج إليها سيِّدُها أن يحمل عليها، ويركب غير منهوكة. قلت لعطاء: ما؟ قال: الرجلُ الراجلُ، والمنقطع به، والمتبعُ، وإن نُتِجت أن يحمل عليها ولدها، ولا يشربَ من لبنها إلا فضلًا عن ولدها، فإن كان في لبنها فضل فليشرب مَن أهداها ومَن لم يُهدِها{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٦٢٩<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق ابن أبي نجيح- <span class="qpc-hafs">﴿لكم فيها منافع إلى أجل مسمى﴾</span>، يقول: في ظهورها، وألبانها، فإذا قُلِّدَت فمحلها إلى البيت العتيق{9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٦٣٠<span class="dash">-</span></span> قال <span class="name-2">قتادة بن دعامة</span>: <span class="qpc-hafs">﴿إلى أجل مسمى﴾</span>، وهو أن يسميها، ويُوجِبَها هَدْيًا، فإذا فعل ذلك لم يكن له شيء مِن منافعها{10}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٦٣١<span class="dash">-</span></span> عن <span class="name-2">ابن أبي نجيح</span> -من طريق ابن علية- في قوله: <span class="qpc-hafs">﴿لكم فيها منافع إلى أجل مسمى﴾</span>، قال: إلى أن توجبها بدنةً{9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٦٣٢<span class="dash">-</span></span> عن <span class="name-2">محمد بن أبي موسى</span>، في قوله: <span class="qpc-hafs">﴿لكم فيها منافع إلى أجل مسمى﴾</span>، قال: لكم في كل مشعر منها منافع حتى تخرجوا منه إلى غيره{12}. (١٠/٤٩٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٦٣٣<span class="dash">-</span></span> قال <span class="name-2">إسماعيل السُّدِّيّ</span>: <span class="qpc-hafs">﴿لكم فيها منافع إلى أجل مسمى﴾</span>، يقول: إلى أن تُقَلَّد، فإذا قُلِّدَت لم تُركَب لها ظهور، ولم يُشرَب لها لبن{13}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٦٣٤<span class="dash">-</span></span> عن <span class="name-2">عطاء الخراساني</span> -من طريق يونس- في قول الله: <span class="qpc-hafs">﴿فيها منافع إلى أجل مسمى﴾</span>، قال: الأجل المسمى: إذا قُلِّدت البدن{14}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٦٣٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿لكم فيها﴾</span> في البدن <span class="qpc-hafs">﴿منافع﴾</span> في ظهورها وألبانها <span class="qpc-hafs">﴿إلى أجل مسمى﴾</span> يقول: إلى أن تُقَلَّد، أو تُشْعَر، أو تُسَمّى: هدايا؛ فهذا الأجل المسمى، فإذا فعل ذلك بها لا يحمل عليها إلا مضطرًا، ويركبها بالمعروف، ويشرب فضل ولدها مِن اللبن، ولا يجهد الحلب حتى لا ينهك أجسامها{15}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٦٣٦<span class="dash">-</span></span> قال <span class="name-3">سفيان الثوري</span>، في قوله: <span class="qpc-hafs">﴿إلى أجل مسمى﴾</span>، قال: إذا دُعِيَت، وسُمِّيَت: البُدُن{16}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٦٣٧<span class="dash">-</span></span> قال <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿لكم فيها منافع إلى أجل مسمى ثم محلها إلى البيت العتيق﴾</span>، فقرأ قول الله: <span class="qpc-hafs">﴿ومن يعظم شعائر الله فإنها من تقوى القلوب﴾</span>: لكم في تلك الشعائر منافع إلى أجل مسمى؛ إذا ذهبت تلك الأيام لم ترَ أحدًا يأتي عرفة يقف فيها يبتغي الأجر، ولا المزدلفة، ولا رمي الجمار، وقد ضربوا مِن البلدان لهذه الأيام التي فيها المنافع، وإنّما منافعُها إلى تلك الأيام، وهي الأجل المسمى، ثم محلها حين تنقضي تلك الأيام إلى البيت العتيق{1}<span class=comment-ref>٤٤٦٨</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٤٤٦٨</span> أفادت الآثارُ اختلافَ المفسرين في معنى: «المنافع» بناءً على اختلافهم في معنى: «الشعائر» كالتالي: <b>مَن قال بأنّ الشعائر: هي البُدْن:</b> ذهب إلى أنّ معنى: «المنافع» أي: لكم في البدن منافع. ثم اختلف هؤلاء في «الحال» التي لهم فيها منافع، وفي «الأجل» في قوله تعالى: <span class="qpc-hafs">﴿إلى أجَلٍ مُسَمًّى﴾</span>؛ <b>فقيل:</b> الحال: هي الحال التي لم يوجِبْها صاحبها ولم يسمها بدنة. والمنافع في هذه الحال: شرب ألبانها، وركوب ظهروها، وما يرزقهم الله من نتاجها وأولادها. والأجل المسمى: عند إيجابها وتسميتها بدنة، إذ بمجرد إيجابها يبطل الانتفاع بها. <b>وقيل:</b> الحال: بعد إيجاب البدنة. والمنافع بعد إيجابها: ركوب ظهورها إن احتيج إلى ذلك، وشرب ألبانها إن اضطر إليه. والأجل المسمى: هو النحر. ومن قال بأن «الشعائر» هي مناسك الحج: اختلفوا أيضًا في معنى: «المنافع»، <b>فقيل:</b> المنافع: التجارة. والأجل المسمى: الخروج من الشعائر إلى غيرها. <b>وقيل:</b> المنافع: الأجر والثواب في قضاء المناسك. والأجل المسمى: انقضاء أيام الحج.</p><p>و<span class="comment-type-3">رجَّح</span> <u>ابنُ جرير</u> (١٦/٥٤٧) <span class="mustanad">مستندًا إلى دلالة العموم</span> شمول الآية لكل هذه المعاني، بناءً على ترجيحه لعموم معنى «الشعائر»، فبيَّن أن معنى: <span class="qpc-hafs">﴿لَكُمْ فِيها مَنافِعُ إلى أجَلٍ مُسَمًّى﴾</span>: «لكم في هذه الشعائر منافع إلى أجلٍ مسمًّى، فما كان مِن هذه الشعائر بُدْنًا وهَدْيًا فمنافعها لكم، من حين تملِكون إلى أن أوجبتموها هدايا وبُدْنًا، وما كان منها أماكن ينسك لله عندها فمنافعها التجارة لله عندها، والعمل لله بما أمر به إلى الشخوص عنها، وما كان منها أوقاتًا فأن يُطاع الله فيها بعملِ أعمال الحج، وبطلب المعاش فيها بالتجارة، إلى أن يُطاف بالبيت في بعضٍ، أو يُوافى الحرم في بعضٍ، ويُخرَج من الحرم في بعضٍ».</div></p><p><h3><span class="qpc-hafs">﴿ثُمَّ مَحِلُّهَاۤ إِلَى ٱلۡبَیۡتِ ٱلۡعَتِیقِ ۝٣٣﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٠٦٣٨<span class="dash">-</span></span> عن ابن جريج، قال: أخبرني عطاء [بن أبي رباح]، قال: كان <span class="name-1">ابنُ عباس</span> يقول: لا يطوف بالبيت حاجٌّ ولا غير حاجٍّ إلا حلَّ. فقلت ل<span class="name-2">عطاء</span>: مِن أين تقول ذلك؟ قال: مِن قول الله تعالى: <span class="qpc-hafs">﴿ثم محلها إلى البيت العتيق﴾</span>. قلت: فإنّ ذلك بعد المُعَرَّفِ{18}. قال: كان <span class="name-1">ابنُ عباس</span> يقول: هو بعد المعرَّف وقبله{19}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٦٣٩<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- <span class="qpc-hafs">﴿ثم محلها﴾</span> يقول: مَحِلُّ البدن حين تُسَمّى <span class="qpc-hafs">﴿إلى البيت العتيق﴾</span>{20}. (١٠/٤٩٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٦٤٠<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span>، في قوله: <span class="qpc-hafs">﴿ثم محلها إلى البيت العتيق﴾</span>، قال: إذا دخلت الحرم فقد بلغت محلها{21}. (١٠/٤٩١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٦٤١<span class="dash">-</span></span> عن <span class="name-2">الضحاك بن مزاحم</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٦٤٢<span class="dash">-</span></span> و<span class="name-2">عطاء</span>، في قوله: <span class="qpc-hafs">﴿ثم محلها إلى البيت العتيق﴾</span>، قالا: إلى يوم النحر تُنحَر بمنى{6}. (١٠/٤٩١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٦٤٣<span class="dash">-</span></span> عن <span class="name-2">عطاء [بن أبي رباح]</span> -من طريق حجاج- <span class="qpc-hafs">﴿ثم محلها إلى البيت العتيق﴾</span>: إلى مكة{23}<span class=comment-ref>٤٤٦٩</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٤٤٦٩</span> <span class="comment-type-1">وجَّه</span> <u>ابنُ جرير</u> (١٦/٥٤٨) قول مجاهد، وعطاء بقوله: «فوجَّه هؤلاء تأويل ذلك إلى: ثم منحر البُدن والهدايا التي أوجبتموها إلى أرض الحرم. وقالوا: عنى بالبيت العتيق: أرض الحرم كلها. وقالوا: وذلك نظير قوله: <span class="qpc-hafs">﴿فَلا يَقْرَبُوا المَسْجِدَ الحَرامَ﴾</span> [التوبة:٢٨]، والمراد: الحرم كله».</div></p><p><div></p><p><p><span class="item-no">٥٠٦٤٤<span class="dash">-</span></span> عن <span class="name-2">محمد بن أبي موسى</span>، في قوله: <span class="qpc-hafs">﴿ثم محلها إلى البيت العتيق﴾</span>، قال: محل هذه الشعائر كلها الطواف بالبيت العتيق{24}. (١٠/٤٩٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٦٤٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ثم محلها إلى البيت العتيق﴾</span>، يعني: منحرها إلى أرض الحرم كله، كقوله سبحانه: <span class="qpc-hafs">﴿فلا يقربوا المسجد الحرام﴾</span> [التوبة:٢٨]، يعني: أرض الحرم كله، ثم ينحر ويأكل ويُطْعِم، إن شاء نحر الإبل، وإن شاء ذبح الغنم أو البقر، ثم تَصَدَّق به كله، وإن شاء أكل وأمسك منه، وذلك أنّ أهل الجاهلية كانوا لا يأكلون شيئًا مِن البُدْن؛ فأنزل الله ﷿: <span class="qpc-hafs">﴿فكلوا منها وأطعموا﴾</span>، فليس الأكل بواجب، ولكنه رخصة، كقوله سبحانه: <span class="qpc-hafs">﴿وإذا حللتم فاصطادوا﴾</span> [المائدة:٢]، وليس الصيد بواجب، ولكنه رخصة{15}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٦٤٦<span class="dash">-</span></span> قال <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿ثم محلها إلى البيت العتيق﴾</span>: حين تنقضي تلك الأيام؛ أيام الحج، إلى البيت العتيق{26}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٦٤٧<span class="dash">-</span></span> قال <span class="name-3">يحيى بن</span> <span class="name-3">سلّام</span>: <span class="qpc-hafs">﴿ثم محلها﴾</span> إذا قُلِّدَت وأُشْعِرَت <span class="qpc-hafs">﴿إلى البيت العتيق﴾</span>{4}<span class=comment-ref>٤٤٧٠</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٤٤٧٠</span> أفادت الآثار اختلاف المفسرين في معنى قوله تعالى: <span class="qpc-hafs">﴿ثُمَّ مَحِلُّها إلى البَيْتِ العَتِيقِ﴾</span> بناءً -أيضًا- على اختلافهم في معنى: «الشعائر»؛ <b>فمن قال بأن الشعائر: هي البُدْن:</b> قال بأن المعنى: ثم محل البدن إلى أن تبلغ مكة، وهي التي بها البيت العتيق. <b>ومن قال بأن «الشعائر»: هي مناسك الحج</b>، قال بأن المعنى: ثم مَحِل الناس من إحرامهم إلى البيت العتيق، وهو أن يطوفوا به يوم النحر بعد قضاء المناسك. <b>وقيل:</b> إن محل منافع أيام الحج إلى البيت العتيق بانقضائها.</p><p>و<span class="comment-type-3">رجَّح</span> <u>ابنُ جرير</u> (١٦/٥٤٩) <span class="mustanad">مستندًا إلى دلالة العموم</span> أنّ المعنى: «ثم محل الشعائر التي لكم فيها منافع إلى أجل مسمًّى إلى البيت العتيق، فما كان مِن ذلك هديًا أو بُدْنًا فبموافاته الحرمَ في الحرمِ، وما كان مِن نُسُك فبالطواف بالبيت».</div></p></div>",footnotes:1:أخرجه ابن جرير ١٦/٥٤٦.تقليد البدن: أن يجعل في عنقها شعار يعلم به أنها هدي. لسان العرب (قلد).إشعار البدن: أن يشق أحد جنبي سنام البدنة حتى يسيل دمها، ويجعل ذلك لها علامة تعرف بها أنها هدى. النهاية (شعر).تفسير يحيى بن سلام ١/٣٧١.أخرجه ابن أبي شيبة (القسم الرابع من الجزء الرابع) ص٢٩٥، وابن جرير ١٦/٥٤٣، ٥٤٨. وعزاه السيوطي إلى عبد بن حميد، وابن أبي حاتم. ونحوه في تفسير مجاهد ص٤٨١ إلّا أنّ لفظ آخره: إلى أن تُسمّى: بدنًا. ونحوه عند الثوري في تفسيره ص٢١٢. وأخرجه يحيى بن سلام ١/٣٧١ بلفظ: هي البدن ينتفع بها حتى تُقلَّد.عزاه السيوطي إلى سعيد بن منصور، وعبد بن حميد، وابن المنذر، وابن أبي حاتم.المعي: من الإعياء وهو الكلال، وأعيا الرجل في المشي فهو مُعْيٍ. اللسان (عيا).أخرجه ابن جرير ١٦/٥٤٥.أخرجه ابن جرير ١٦/٥٤٤.تفسير الثعلبي ٧/٢٢، وتفسير البغوي ٥/٣٨٤.أخرجه ابن جرير ١٦/٥٤٤.أخرجه ابن أبي شيبة (القسم الرابع من الجزء الرابع) ص٢٩٤-٢٩٥، وابن جرير ١٦/٥٤٦. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.علَّقه يحيى بن سلام ١/٣٧١.أخرجه أبو جعفر الرملي في جزئه ص١١٧ (تفسير عطاء الخراساني).تفسير مقاتل بن سليمان ٣/١٢٦.أخرجه الثوري ص٢١٢.أخرجه ابن جرير ١٦/٥٤٦.المُعَرَّف: الوقوف بعرفة. لسان العرب (عرف).أخرجه ابن حزم في المحلى ٧/١٠١، والطحاوي في شرح معاني الآثار ٢/١٨٩، وزاد: وكان ابن عباس ﵄ يأخذها من أمر النبي ﷺ أصحابه أن يحلوا في حجة الوداع، قالها في غير مرة.أخرجه ابن أبي شيبة (القسم الرابع من الجزء الرابع) ص٢٩٥، وابن جرير ١٦/٥٤٨. وعزاه السيوطي إلى عبد بن حميد، وابن أبي حاتم.عزاه السيوطي إلى عبد بن حميد، وابن المنذر.عزاه السيوطي إلى سعيد بن منصور، وعبد بن حميد، وابن المنذر، وابن أبي حاتم.أخرجه ابن جرير ١٦/٥٤٧.أخرجه ابن جرير ١٦/٥٤٨. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.تفسير مقاتل بن سليمان ٣/١٢٦.أخرجه ابن جرير ١٦/٥٤٩.تفسير يحيى بن سلام ١/٣٧١.
  22,34,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَلِكُلِّ أُمَّةࣲ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٠٦٤٨<span class="dash">-</span></span> تفسير <span class="name-2">إسماعيل السُّدِّيّ</span>: قوله: <span class="qpc-hafs">﴿ولكل أمة﴾</span>، يعني: ولكل قوم{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٦٤٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ولكل أمة﴾</span>، يعني: لكل قوم مِن المؤمنين فيما خلا. كقوله سبحانه: <span class="qpc-hafs">﴿أنْ تَكُونَ أُمَّةٌ هِيَ أرْبى مِن أُمَّةٍ﴾</span> [النحل:٩٢]، أن يكون قوم أكثر من قوم{2}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿جَعَلۡنَا مَنسَكࣰا﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٠٦٥٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- في قوله: <span class="qpc-hafs">﴿ولكل أمة جعلنا منسكا﴾</span>، قال: عِيدًا{3}. (١٠/٤٩٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٦٥١<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿ولكل أمة جعلنا منسكا﴾</span>، قال: إهراقة الدماء{4}<span class=comment-ref>٤٤٧١</span>. (١٠/٤٩٢)</p></p><p></div></p><p><div><span class=comment-ref>٤٤٧١</span> لم يذكر <u>ابنُ جرير</u> (١٦/٥٥٠) في معنى: <span class="qpc-hafs">﴿ولِكُلِّ أُمَّةٍ جَعَلْنا مَنسَكًا﴾</span> سوى قول مجاهد.</div></p><p><div></p><p><p><span class="item-no">٥٠٦٥٢<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span> <span class="qpc-hafs">﴿ولكل أمة جعلنا منسكا﴾</span>، قال: ذَبْحًا{5}. (١٠/٤٩٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٦٥٣<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿جعلنا منسكا﴾</span>، قال: أي حَجًّا، وذبحًا{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٦٥٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثم قال: <span class="qpc-hafs">﴿جعلنا منسكا﴾</span>، يعني: ذبحًا. يعني: هِراقة{7} الدماء{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٦٥٥<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> أنّه قال في هذه الآية: <span class="qpc-hafs">﴿ولكل أمة جعلنا منسكا﴾</span>: أنها مكة، لم يجعل الله لأمة قط منسكًا غيرها{9}. (١٠/٤٩٣)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿جَعَلۡنَا مَنسَكࣰا﴾</span> - أثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٥٠٦٥٦<span class="dash">-</span></span> عن أبي هريرة، قال: نزل جبريلُ فقال النبيُّ ﷺ له: «<b>كيف رأيت عيدنا</b>؟». فقال: لقد تَباهى به أهلُ السماء، اعلم -يا محمد- أنّ الجذَع مِن الضأن خيرٌ مِن السيد من المعز، وأن الجذع مِن الضأن خير من السيد من البقر، وأنّ الجذع من الضأن خير من السيد من الإبل، ولو علم الله خيرًا منه فدى به إبراهيمُ{10}. (١٠/٤٩٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٦٥٧<span class="dash">-</span></span> عن عبد الله بن عمر: أنّ رجلًا أتى رسول الله ﷺ، فقال له رسول الله ﷺ: «<b>أمرت بعيد الأضحى؛ جعله الله لهذه الأمة</b>». قال الرجل: فإن لم نجد إلا ذبيحة أنثى أو شاة أهلي، أذبحها؟ قال: «<b>لا، ولكن قلِّم أظفارك، وقُصَّ شاربك، واحلُق عانتَك، فذلك تمام أضحيتك عند الله</b>»{11}. (١٠/٤٩٣)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿لِّیَذۡكُرُوا۟ ٱسۡمَ ٱللَّهِ عَلَىٰ مَا رَزَقَهُم مِّنۢ بَهِیمَةِ ٱلۡأَنۡعَـٰمِۗ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٠٦٥٨<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿ليذكروا اسم الله على ما رزقهم من بهيمة الأنعام﴾</span> إذا ذبحوا، فالسُّنَّة إذا ذبح أو نحر أن يقول: بسم الله، والله أكبر ... عن أنس بن مالك: أنّ رسول الله ﷺ كان يُضَحِّي بكبشين أملحين، أقرنين، يذبحهما بيده، ويَطَأ على صَفْحَتَيهما، ويُسَمِّي، ويُكَبِّر{12}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿لِّیَذۡكُرُوا۟ ٱسۡمَ ٱللَّهِ عَلَىٰ مَا رَزَقَهُم مِّنۢ بَهِیمَةِ ٱلۡأَنۡعَـٰمِۗ﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٥٠٦٥٩<span class="dash">-</span></span> عن جابر بن عبد الله: أنّ رسول الله ﷺ صَلّى للناس يوم النحر، فلمّا فرغ مِن خطبته وصلاته دعا بكبش، فذبحه هو بنفسه، وقال: «<b>بسم الله، والله أكبر، اللهُمَّ، هذا عَنِّي وعمَّن لم يُضَحِّ مِن أُمَّتي</b>»{13}. (١٠/٤٩٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٦٦٠<span class="dash">-</span></span> عن جابر بن عبد الله، قال: ضَحّى رسولُ الله ﷺ بكبشين في يوم عيد، فقال حين وجَّههما: «<b>وجَّهتُ وجهي للذي فطر السموات والارض حنيفًا مسلمًا، وما أنا من المشركين، إنّ صلاتي ونسكي ومحياي ومماتي لله رب العالمين، لا شريك له، وبذلك أمرت وأنا أول المسلمين، اللهم منك ولك، وعن محمد وأُمَّتِه</b>». ثم سمّى اللهَ، وكَبَّر، وذبح{14}. (١٠/٤٩٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٦٦١<span class="dash">-</span></span> عن أنس: أنّ رسول الله ﷺ ضَحّى بكبشين أملحين، أقرنين، فسَمّى، وكَبَّر{15}. (١٠/٤٩٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٦٦٢<span class="dash">-</span></span> عن <span class="name-1">علي</span>، أنّه قال حين ذبح: وجهتُ وجهي للذي فطر السموات والأرض حنيفًا مسلمًا، وما أنا مِن المشركين، إنّ صلاتي ونسكي ومحياي ومماتي لله رب العالمين، لا شريك له، وبذلك أُمِرت، وأنا من المسلمين{16}. (١٠/٤٩٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٦٦٣<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عمر</span>، أنّه كان إذا ذبح قال: باسم الله، والله أكبر، اللهم منك ولك، اللَّهُمَّ، تَقَبَّل مِنِّي{17}. (١٠/٤٩٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٦٦٤<span class="dash">-</span></span> عن قتادة: أنّ <span class="name-2">الحسن البصري</span> كان إذا ذبح الأضحية قال: بسم الله، والله أكبر، اللَّهُمَّ، منك ولك{18}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿مِّنۢ بَهِیمَةِ ٱلۡأَنۡعَـٰمِۗ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٠٦٦٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ليذكروا اسم الله على ما رزقهم من بهيمة الأنعام﴾</span>، وإنما خَصَّ الأنعام من البهائم؛ لأنّ مِن البهائم ما ليس مِن الأنعام، وإنّما سُمِّيَت: البهائم؛ لأنها لا تتكلم{2}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿فَإِلَـٰهُكُمۡ إِلَـٰهࣱ وَ ٰ⁠حِدࣱ فَلَهُۥۤ أَسۡلِمُوا۟ۗ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٠٦٦٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فإلهكم إله واحد﴾</span> ليس له شريك، يقول: فربُّكم ربٌّ واحد، <span class="qpc-hafs">﴿فله أسلموا﴾</span>{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٦٦٧<span class="dash">-</span></span> عن <span class="name-3">مقاتل [بن حيان]</span>، <span class="qpc-hafs">﴿فله أسلموا﴾</span>، يقول: فله أخلِصُوا{9}. (١٠/٤٩٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٦٦٨<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: قوله: <span class="qpc-hafs">﴿فإلهكم إله واحد فله أسلموا﴾</span>، يقوله للمشركين{22}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَبَشِّرِ ٱلۡمُخۡبِتِینَ ۝٣٤﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٠٦٦٩<span class="dash">-</span></span> قال <span class="name-1">عبد الله بن عباس</span>: المتواضعين{23}<span class=comment-ref>٤٤٧٢</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٤٤٧٢</span> ذكر <u>ابنُ عطية</u> (٦/٢٤٨) رواية بـ«أنّ هذه الآية -قوله تعالى: <span class="qpc-hafs">﴿وبَشِّرِ المُخْبِتِينَ﴾</span>- نزلت في أبي بكر، وعمر، وعثمان، وعلي ﵃».</div></p><p><div></p><p><p><span class="item-no">٥٠٦٧٠<span class="dash">-</span></span> عن <span class="name-2">عمرو بن أوس</span> -من طريق عثمان بن عبد الله بن أوس- <span class="qpc-hafs">﴿وبشر المخبتين﴾</span>، قال: المُخْبِتون: الذين لا يظلمون الناس، وإذا ظُلِموا لم ينتصروا{24}<span class=comment-ref>٤٤٧٣</span>. (١٠/٤٩٥)</p></p><p></div></p><p><div><span class=comment-ref>٤٤٧٣</span> <span class="comment-type-4">علَّق</span> <u>ابنُ عطية</u> (٦/٢٤٧) على قول عمرو بن أوس قائلًا: «وهذا مِثال شريف مِن خُلُق المؤمن الهيِّن اللَّيِّن».</div></p><p><div></p><p><p><span class="item-no">٥٠٦٧١<span class="dash">-</span></span> قال <span class="name-2">إبراهيم النخعي</span>: المخلصين{25}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٦٧٢<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح، وابن جُرَيْج- في قوله: <span class="qpc-hafs">﴿وبشر المخبتين﴾</span>، قال: المُطْمَئِنِّين{26}. (١٠/٤٩٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٦٧٣<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿وبشر المخبتين﴾</span>، قال: المتواضعون{27}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٦٧٤<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span>، قال: المصلين{28}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٦٧٥<span class="dash">-</span></span> عن <span class="name-2">الضَّحّاك بن مُزاحِم</span> -من طريق جويبر- <span class="qpc-hafs">﴿وبشر المخبتين﴾</span>، قال: المتواضعين{29}. (١٠/٤٩٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٦٧٦<span class="dash">-</span></span> تفسير <span class="name-2">الحسن البصري</span>: أنّ المخبتين: الخاشعين الخائفين. والخشوع: المخافة الثابتة في القلب{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٦٧٧<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق مَعْمَر- في قوله: <span class="qpc-hafs">﴿وبشر المخبتين﴾</span>، قال: هم المتواضعون{27}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٦٧٨<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span>، <span class="qpc-hafs">﴿وبشر المخبتين﴾</span>، قال: الوَجِلين{9}<span class=comment-ref>٤٤٧٤</span>. (١٠/٤٩٦)</p></p><p></div></p><p><div><span class=comment-ref>٤٤٧٤</span> <span class="comment-type-4">ذهب</span> <u>ابنُ كثير</u> (١٠/٦١) في معنى: <span class="qpc-hafs">﴿المخبتين﴾</span> إلى أنّ «أحسن ما <span class="mustanad">يُفَسَّر بما بعده</span>، وهو قوله: <span class="qpc-hafs">﴿الَّذِينَ إذا ذُكِرَ اللَّهُ وجِلَتْ قُلُوبُهُمْ﴾</span> أي: خافت منه قلوبهم، <span class="qpc-hafs">﴿والصّابِرِينَ عَلى ما أصابَهُمْ﴾</span> أي: من المصائب».</div></p><p><div></p><p><p><span class="item-no">٥٠٦٧٩<span class="dash">-</span></span> قال <span class="name-3">محمد بن السائب الكلبي</span>: هم الرقيقة قلوبهم{25}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٦٨٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وبشر المخبتين﴾</span>، يعني: المخلصين، بالجنة{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٦٨١<span class="dash">-</span></span> قال <span class="name-3">سفيان بن عيينة</span> -من طريق ابن أبي عمر- في قوله: <span class="qpc-hafs">﴿وبشر المخبتين﴾</span>، قال: المطمئنين{35}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٦٨٢<span class="dash">-</span></span> عن <span class="name-3">يحيى بن</span> <span class="name-3">سلّام</span>: قوله: <span class="qpc-hafs">﴿وبشر المخبتين﴾</span> يعني: بالجنة، وبعضهم يقول: <span class="qpc-hafs">﴿وبشر المخبتين﴾</span> يعني: المطمئنين بالإيمان. قال: <span class="qpc-hafs">﴿فتخبت له قلوبهم﴾</span> [الحج:٥٤]، فتطمئن إليه قلوبهم. وقال: <span class="qpc-hafs">﴿الذين آمنوا وتطمئن قلوبهم بذكر الله﴾</span> [الرعد:٢٨]{22}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَبَشِّرِ ٱلۡمُخۡبِتِینَ ۝٣٤﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٥٠٦٨٣<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن مسعود</span> -من طريق ابنه أبي عبيدة- أنّه كان اذا رأى الربيع بن خثيم قال: <span class="qpc-hafs">﴿وبشر المخبتين﴾</span>. وقال له: ما رأيتُكَ إلا ذكرت المخبتين{37}. (١٠/٤٩٦)</p></p><p></div></p></div>",footnotes:1:علَّقه يحيى بن سلام ١/٣٧٤.تفسير مقاتل بن سليمان ٣/١٢٦.أخرجه ابن أبي حاتم -كما في الإتقان ٢/٣٠-.أخرجه ابن جرير ١٦/٥٥٠. وعزاه السيوطي إلى ابن أبي شيبة، وعبد بن حميد، وابن المنذر، وابن أبي حاتم.عزاه السيوطي إلى ابن أبي حاتم. وأخرجه الثوري في تفسيره ص٢١٣ من طريق سعيد بن مسروق بلفظ: ذبائح هم ذابحوها.أخرجه يحيى بن سلام ١/٣٧٤.هِراقة وإراقة الدماء: صبّها وإسالتها. النهاية واللسان (هرق).تفسير مقاتل بن سليمان ٣/١٢٦.عزاه السيوطي إلى ابن أبي حاتم.أخرجه الحاكم ٤/٢٤٧ (٧٥٢٦)، وفيه إسحاق بن إبراهيم الحنيني.</p><p>قال ابن عدي في الكامل ١/٥٥٤-٥٥٥ (١٧١) في ترجمة إسحاق بن إبراهيم الحنيني: «قال البخاري: إسحاق بن إبراهيم الحنيني ... في حديثه نظر ... وهذا الحديث لا يرويه عن هشام بن سعد إلا الحنيني، والحنيني مع ضعفه يكتب حديثه». وقال الحاكم: «هذا حديث صحيح الإسناد، ولم يخرجاه». وقال الذهبي في التلخيص: «إسحاق هالك».أخرجه أحمد ١١/١٣٩ (٦٥٧٥)، وأبو داود ٤/٤١٦-٤١٧ (٢٧٨٩)، والنسائي ٧/٢١٢ (٤٣٦٥)، وابن حبان ١٣/٢٣٥-٢٣٦ (٥٩١٤)، والحاكم ٤/٢٤٨ (٧٥٢٩)، وابن وهب في الجامع من تفسيره ٣/١٥-١٦ (١٩).</p><p>قال الحاكم: «هذا حديث صحيح الإسناد، ولم يخرجاه». وقال الألباني في ضعيف أبي داود ٢/٣٧٠ (٤٨٢): «إسناده ليس بذاك -كما قال الذهبي-، والصدفي هذا ليس بالمشهور».تفسير يحيى بن سلام ١/٣٧٩-٣٨٠.أخرجه أحمد ٢٣/١٣٣-١٣٤ (١٤٨٣٧)، ٢٣/١٧٠-١٧٢ (١٤٨٩٣، ١٤٨٩٥)، وأبو داود ٤/٤٣٣ (٢٨١٠)، والترمذي ٣/٣٤٤-٣٤٥ (١٥٩٩)، والحاكم ٤/٢٥٤ (٧٥٥٣).</p><p>قال الترمذي: «هذا حديث غريب من هذا الوجه .. والمطلب بن عبد الله بن حنطب يُقال: إنه لم يسمع من جابر». وقال الألباني في الإرواء ٤/٣٤٩ (١١٣٨): «صحيح».أخرجه أحمد ٢٣/٢٦٧ (١٥٠٢٢)، وأبو داود ٤/٤٢١ (٢٧٩٥)، وابن ماجه ٤/٣٠٠ (٣١٢١)، وابن خزيمة ٤/٤٨٧ (٢٨٩٩)، والحاكم ١/٦٣٩ (١٧١٦).</p><p>قال الحاكم: «هذا حديث صحيح، على شرط مسلم، ولم يخرجاه». وقال ابن الملقن في البدر المنير ٩/٣٠٠: «فيه مع أبي عياش هذا عنعنة ابن إسحاق، وأبو عياش هذا روى عنه خالد بن أبي عمران، ويزيد بن أبي حبيب، وهو مستور لم يتحقق حاله. قال عبد الحق: لم أسمع فيه بتجريح ولا بتعديل». وقال الألباني في الإرواء ٤/٣٥٠: «ورجاله ثقات غير أبي عياش هذا، وهو المعافري المصري، وهو مستور، روى عنه ثلاثة من الثقات».أخرجه البخاري ٧/١٠١ (٥٥٥٨)، ٧/١٠٢ (٥٥٦٥)، ٩/١٢٠ (٧٣٩٩)، ومسلم ٣/١٥٥٦ (١٩٦٦)، ويحيى بن سلام ١/٣٧٩.أخرجه البيهقي في الشعب (٧٣٣٩). وعزاه السيوطي إلى ابن أبي حاتم، وابن أبي الدنيا في الأضاحي.عزاه السيوطي إلى ابن أبي الدنيا.أخرجه يحيى بن سلام ١/٣٧٩.تفسير مقاتل بن سليمان ٣/١٢٦.تفسير مقاتل بن سليمان ٣/١٢٦.عزاه السيوطي إلى ابن أبي حاتم.تفسير يحيى بن سلام ١/٣٧٤.تفسير الثعلبي ٧/٢٢، وتفسير البغوي ٥/٣٨٦.أخرجه ابن أبي شيبة ١٣/٥٧٨، والبيهقي في الشعب (٨٠٨٨). وعزاه السيوطي إلى سعيد بن منصور، وعبد بن حميد، وابن أبي الدنيا في ذم الغضب، وابن المنذر، وابن أبي حاتم.تفسير البغوي ٥/٣٨٦.أخرجه ابن جرير ١٦/٥٥١، وابن المنذر -كما في فتح الباري ٨/٤٣٨-. وعزاه السيوطي إلى عبد بن حميد، وابن أبي حاتم.أخرجه عبد الرزاق ٢/٣٨.أخرجه ابن المنذر -كما في فتح الباري ٨/٤٣٨-.أخرجه ابن أبي شيبة ١٣/٥٨٠، وابن المنذر -كما في فتح الباري ٨/٤٣٨-. وعزاه السيوطي إلى ابن أبي حاتم.علَّقه يحيى بن سلام ١/٣٧٤.أخرجه عبد الرزاق ٢/٣٨.عزاه السيوطي إلى ابن أبي حاتم.تفسير البغوي ٥/٣٨٦.تفسير مقاتل بن سليمان ٣/١٢٦.أخرجه إسحاق البستي في تفسيره ص٣٦٥. وعلّقه البخاري في صحيحه ٦/٩٧.تفسير يحيى بن سلام ١/٣٧٤.أخرجه ابن سعد ٦/١٨٣، وابن أبي شيبة ١٣/٥٨٤ مطولًا.
  22,35,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿ٱلَّذِینَ إِذَا ذُكِرَ ٱللَّهُ وَجِلَتۡ قُلُوبُهُمۡ وَٱلصَّـٰبِرِینَ عَلَىٰ مَاۤ أَصَابَهُمۡ وَٱلۡمُقِیمِی ٱلصَّلَوٰةِ وَمِمَّا رَزَقۡنَـٰهُمۡ یُنفِقُونَ ۝٣٥﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٠٦٨٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثم نعتهم، فقال: <span class="qpc-hafs">﴿الذين إذا ذكر الله وجلت﴾</span> يعني: خافَتْ <span class="qpc-hafs">﴿قلوبهم والصابرين على مآ أصابهم﴾</span> مِن أمر الله، <span class="qpc-hafs">﴿والمقيمي الصلاة ومما رزقناهم ينفقون﴾</span> من الأموال{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٦٨٥<span class="dash">-</span></span> عن <span class="name-3">مقاتل [بن حيان]</span>: <span class="qpc-hafs">﴿الذين اذا ذكر الله وجلت قلوبهم﴾</span> عند ما يُخَوَّفون، <span class="qpc-hafs">﴿والصابرين على ما أصابهم﴾</span> مِن البلاء والمصائب، <span class="qpc-hafs">﴿والمقيمي الصلاة﴾</span> يعني: إقامتها؛ أداء ما استحفظهم اللهُ فيها{2}. (١٠/٤٩٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٦٨٦<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿الذين إذا ذكر الله وجلت قلوبهم﴾</span> قال: لا تقسو قلوبُهم، <span class="qpc-hafs">﴿والصابرين على ما أصابهم﴾</span> مِن شِدَّة في أمر الله، ونالهم مِن مكروهٍ في جنبه، <span class="qpc-hafs">﴿والمقيمي الصلاة﴾</span> المفروضة، <span class="qpc-hafs">﴿ومما رزقناهم﴾</span> مِن الأموال <span class="qpc-hafs">﴿ينفقون﴾</span> في الواجب عليهم إنفاقها فيه؛ في زكاة، ونفقة عيال، ومَن وجَبَتْ عليه نفقتُه، وفي سبيل الله{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٦٨٧<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: قوله: <span class="qpc-hafs">﴿الذين إذا ذكر الله وجلت قلوبهم﴾</span> يعني: خافت قلوبهم، <span class="qpc-hafs">﴿والصابرين على ما أصابهم والمقيمي الصلاة﴾</span> المفروضة، الصلوات الخمس يحافظون على وضوئها، ومواقيتها، وركوعها، وسجودها، <span class="qpc-hafs">﴿ومما رزقناهم ينفقون﴾</span> يعني: الزكاة المفروضة{4}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٣/١٢٧.عزاه السيوطي إلى ابن أبي حاتم.أخرجه ابن جرير ١٦/٥٥٢.تفسير يحيى بن سلام ١/٣٧٥.
  22,36,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَٱلۡبُدۡنَ جَعَلۡنَـٰهَا لَكُم مِّن شَعَـٰۤىِٕرِ ٱللَّهِ﴾</span> - قراءات</h3></p><p><div></p><p><p><span class="item-no">٥٠٦٨٨<span class="dash">-</span></span> عن <span class="name-2">عاصم</span> أنّه قرأ: <span class="qpc-hafs">﴿والبُدْنَ﴾</span> خفيفة{1}. (١٠/٤٩٦)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَٱلۡبُدۡنَ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٠٦٨٩<span class="dash">-</span></span> عن سليمان بن يعقوب الرِّياحي، عن أبيه، قال: أوصى إلَيَّ رجلٌ، وأوصى ببدنة، فأتيت <span class="name-1">ابنَ عباس</span>، فقلت له: إنّ رجلًا أوصى إلَيَّ ببدنة، فهل تُجْزِئ عنِّي بقرة؟ قال: نعم. ثم قال: مِمَّن صاحبكم؟ فقلت: مِن بني رياح. قال: ومتى اقتنى بنو رياح البقر إلى الإبل؟! وهِمَ صاحبُكم، إنّما البقر للأزدِ، وعبد القيس{2}. (١٠/٤٩٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٦٩٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عمر</span>، قال: لا نعلم البدن إلا مِن الإبل والبقر{3}. (١٠/٤٩٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٦٩١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عمر</span>، قال: البدن: ذات الجوف{4}. (١٠/٤٩٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٦٩٢<span class="dash">-</span></span> عن <span class="name-2">سعيد بن المسيب</span> -من طريق ابن جريج، عمَّن سَمِعه- قال: البدن: البعير، والبقرة{5}. (١٠/٤٩٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٦٩٣<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- قال: ليس البدن إلا من الإبل{6}. (١٠/٤٩٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٦٩٤<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- قال: إنّما سميت: البدن؛ مِن قبل السَّمانَةِ{7}{8}. (١٠/٤٩٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٦٩٥<span class="dash">-</span></span> عن <span class="name-2">القاسم بن محمد بن أبي بكر</span> -من طريق ابن عون-: إنّ الشاة لن تعدو أن تكون نسيكة، وإنّ البقرة مِن البدن{9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٦٩٦<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span>، قال: البُدْن مِن البقر{4}. (١٠/٤٩٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٦٩٧<span class="dash">-</span></span> عن <span class="name-2">عطاء [بن أبي رباح]</span> -من طريق ابن جُرَيْج- <span class="qpc-hafs">﴿والبُدْنَ جَعَلْناها لَكُمْ مِن شَعائِرِ اللَّهِ﴾</span>، قال: البقرة، والبعير{11}<span class=comment-ref>٤٤٧٥</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٤٤٧٥</span> لم يذكر <u>ابنُ جرير</u> (١٦/٥٥٣) في معنى: <span class="qpc-hafs">﴿والبُدْنَ جَعَلْناها لَكُمْ مِن شَعائِرِ اللَّهِ﴾</span> سوى قول عطاء.</p><p>و<span class="comment-type-4">علَّق</span> <u>ابنُ عطية</u> (٦/٢٤٨) على قول عطاء بقوله: «وسُمِّيَت بذلك لأنها تَبْدُن، أي: تَسْمُن».</p><p>و<span class="comment-type-4">علَّق</span> <u>ابنُ كثير</u> (١٠/٦٢) على هذه الأقوال، فقال: «أمّا إطلاق البدنة على البعير فمُتَّفق عليه، واختلفوا في صحة إطلاق البدنة على البقرة على قولين، أصحهما: أنه يطلق عليها ذلك شرعًا كما صحَّ في الحديث».</div></p><p><div></p><p><p><span class="item-no">٥٠٦٩٨<span class="dash">-</span></span> عن عبد الكريم، قال: اختلف عطاء والحكم؛ فقال <span class="name-2">عطاء [بن أبي رباح]</span>: البُدن من الإبل والبقر.= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٦٩٩<span class="dash">-</span></span> وقال <span class="name-2">الحكم [بن عتيبة]</span>: مِن الإبل{12}. (١٠/٤٩٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٧٠٠<span class="dash">-</span></span> قال <span class="name-2">إسماعيل السُّدِّيّ</span>: البدن: الإبل والبقر، أمّا الغنم فلا تُسَمّى بدنة{13}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٧٠١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: وإنما سميت: البدن؛ لأنّها تُقَلَّد وتُشْعَر وتُساق إلى مكة. والهدي: الذي يُنحَر بمكة ولم يُقَلَّد ولم يُشْعَر. والجزور: البعير الذي ليس ببدنة، ولا بهدي{14}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿جَعَلۡنَـٰهَا لَكُم مِّن شَعَـٰۤىِٕرِ ٱللَّهِ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٠٧٠٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: قوله ﷿: <span class="qpc-hafs">﴿والبدن جعلناها لكم من شعائر الله﴾</span>، يعني: مِن أمر المناسك{14}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿لَكُمۡ فِیهَا خَیۡرࣱۖ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٠٧٠٣<span class="dash">-</span></span> عن إ<span class="name-2">براهيم النخعي</span> -من طريق منصور- في قوله: <span class="qpc-hafs">﴿لكم فيها خير﴾</span>، قال: هي البُدْنَة؛ إن احتاج إلى ظهرٍ رَكب، أو إلى لبن شرب{16}. (١٠/٤٩٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٧٠٤<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿لكم فيها خير﴾</span>، قال: لكم أجر ومنافع في البدن{17}. (١٠/٤٩٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٧٠٥<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿لكم فيها خير﴾</span>، قال: إن احتاج إلى اللبن شرِب، وإن احتاج إلى الركوب ركِب، وإن احتاج إلى الصوف أخذ{18}. (١٠/٥٠٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٧٠٦<span class="dash">-</span></span> تفسير <span class="name-2">إسماعيل السُّدِّيّ</span>: <span class="qpc-hafs">﴿لكم فيها﴾</span>، يعني: في البدن أجر{19}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٧٠٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿لكم فيها خير﴾</span>، يقول: لكم في نحرها أجرٌ في الآخرة، ومنفعة في الدنيا{14}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٧٠٨<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: قوله: <span class="qpc-hafs">﴿والبدن جعلناها لكم من شعائر الله لكم فيها خير﴾</span>، يعني: أجر في نحرها، والصدقة منها، تَتَقَرَّبون بها إلى الله{21}<span class=comment-ref>٤٤٧٦</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٤٤٧٦</span> <span class="comment-type-3">رجَّح</span> <u>ابنُ عطية</u> (٦/٢٤٨) عموم معنى: «الخير» ليشمل خير الدنيا والآخرة، ولم يذكر مستندًا.</div></p><p><h3><span class="qpc-hafs">﴿لَكُمۡ فِیهَا خَیۡرࣱۖ﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٥٠٧٠٩<span class="dash">-</span></span> عن زيد بن أرقم، قال: قلنا: يا رسول الله، ما هذه الأضاحي؟ قال: «<b>سُنَّة أبيكم إبراهيم</b>». قال: فما لنا فيها، يا رسول الله؟ قال: «<b>بكل شعرة حسنة</b>». قالوا: فالصوف؟ قال: «<b>بكل شعرة من الصوف حسنة</b>»{22}. (١٠/٤٩٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٧١٠<span class="dash">-</span></span> عن عائشة، أنّ رسول الله ﷺ قال: «<b>ما عمِل ابنُ آدم يوم النحر عَمَلًا أحبَّ إلى الله مِن هراقة دم، وإنّها لتأتي يوم القيامة بقرونها وأظلافها وأشعارها، وإنّ الدَّمَ لَيَقَعُ من الله بمكان قبل أن يقع على الأرض، فطِيبوا بها نفسًا</b>»{23}. (١٠/٤٩٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٧١١<span class="dash">-</span></span> عن جابر بن عبد الله، قال: قال رسول الله ﷺ: «<b>اركبوا الهَدْيَ بالمعروف حتى تجدوا ظَهْرًا</b>»{24}. (١٠/٥٠١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٧١٢<span class="dash">-</span></span> عن أبي هريرة، أنّ رسول الله ﷺ رأى رجلًا يسوق بدنة، فقال: «<b>اركبها</b>». قال: يا رسول الله، إنها بدنة. قال: «<b>اركبها، ويلك</b>» في الثانية أو في الثالثة{25}. (١٠/٥٠٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٧١٣<span class="dash">-</span></span> عن أنس بن مالك، قال: مُرَّ على النبي ﷺ ببدنة أو هدية، فقال: «<b>اركبها</b>». قال: إنها بدنة أو هدية. فقال: «<b>وإن</b>»{26}. (١٠/٥٠٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٧١٤<span class="dash">-</span></span> عن عكرمة، قال: قال رجلٌ <span class="name-1">لابن عباس</span>: أيركب الرجل البُدْنَة؟ قال: غير مثقل. قال: فيحلبها؟ قال: غير مُجْهِد{27}. (١٠/٥٠١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٧١٥<span class="dash">-</span></span> عن هشام بن <span class="name-2">عروة</span>، عن أبيه قال: البدنة، إن احتاج سائقُها فإنّه يركبها غير فادح، ويشرب من فضل ري فصيلها{28}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٧١٦<span class="dash">-</span></span> عن مالك بن أنس، قال: حجَّ سعيدُ بن المسيب، وحجَّ معه <span class="name-2">ابنُ حرملة</span>، فاشترى سعيدٌ كَبْشًا، فضَحّى به، واشترى ابنُ حرملة بدنة بستة دنانير، فنحرها، فقال له سعيد: أما كان لك فينا أسوة؟ فقال: إنِّي سمعت الله يقول: <span class="qpc-hafs">﴿والبدن جعلناها لكم من شعائر الله لكم فيها خير﴾</span>، فأحببتُ أن آخذ الخير مِن حيث دَلَّني اللهُ عليه. فأعجب ذلك ابنَ المسيب منه، وجعل يُحَدِّث بها عنه{4}. (١٠/٥٠٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٧١٧<span class="dash">-</span></span> عن ابن عيينة، قال: حجَّ <span class="name-2">صفوان بن سليم</span> ومعه سبعة دنانير، فاشترى بها بُدنة، فقيل له: ليس معك إلا سبعة دنانير تشتري بها بدنة! فقال: إنِّي سمعتُ الله يقول: <span class="qpc-hafs">﴿لكم فيها خير﴾</span>{30}. (١٠/٥٠٠)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿فَٱذۡكُرُوا۟ ٱسۡمَ ٱللَّهِ عَلَیۡهَا صَوَاۤفَّۖ﴾</span> - قراءات الآية، وتفسيرها</h3></p><p><div></p><p><p><span class="item-no">٥٠٧١٨<span class="dash">-</span></span> عن قتادة، قال: كان <span class="name-1">عبد الله بن مسعود</span> يقرأ: (فاذْكُرُوا اسْمَ اللهِ عَلَيْها صَوافِنَ). أي: معقولة قِيامًا{31}. (١٠/٥٠٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٧١٩<span class="dash">-</span></span> عن جرير بن حازم، قال: قرأتُ في مصحف <span class="name-1">عبد الله بن مسعود</span>: (فاذْكُرُوا اسْمَ اللهِ عَلَيْها صَوافِنَ){32}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٧٢٠<span class="dash">-</span></span> عن ميمون بن مهران، قال: في قراءة <span class="name-1">ابن مسعود</span>: (صَوافِنَ)، يعني: قيامًا{33}. (١٠/٥٠٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٧٢١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق أبي ظبيان- أنّه كان يقرأ: (فاذْكُرُوا اسْمَ اللهِ عَلَيْها صَوافِنَ){34}. (١٠/٥٠٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٧٢٢<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span> أنّه كان يقرؤها: (صَوافِنَ). قال: رأيتُ <span class="name-1">ابنَ عمر</span> ينحر بدنته، وهي على ثلاثة قوائم، قيامًا معقولة{35}. (١٠/٥٠٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٧٢٣<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span>، في قوله: (صَوافِنَ)، قال: معقولة على ثلاث{36}. (١٠/٥٠٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٧٢٤<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span>، قال: مَن قرأها: (صَوافِنَ) قال: معقولة. ومن قرأها: <span class="qpc-hafs">﴿صَوافَّ﴾</span> قال: يَصُفُّ بين يديها. ولفظ عبد بن حميد: مَن قرأها: <span class="qpc-hafs">﴿صَوافَّ﴾</span> فهي: قائمة مضمومة يديها. ومن قرأها: (صَوافِنَ): قيامًا معقولة. ولفظ ابن أبي شيبة: الصواف على أربع، والصوافن على ثلاث{37}. (١٠/٥٠٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٧٢٥<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق جرير بن حازم- أنّه كان يقرأها: (صَوافِيَ). قال: خالصة لله تعالى. قال: كانوا يذبحونها لأصنامهم{38}. (١٠/٥٠٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٧٢٦<span class="dash">-</span></span> عن ابن لهيعة: أنّه سمع <span class="name-2">ربيعة [بن أبي عبد الرحمن]</span> يقول: (صَوافِيَ). قال: خالصة لله{39}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٧٢٧<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span>، أنّه قرأ: (فاذْكُرُوا اسْمَ اللهِ عَلَيْها صَوافِيَ) بالياء منتصبة، وقال: خالصة لله مِن الشِّرْك؛ لأنهم كانوا يشركون في الجاهلية إذا نحروها{40}. (١٠/٥٠٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٧٢٨<span class="dash">-</span></span> عن شقيق الضبي- من طريق قيس بن مسلم-: (فاذْكُرُوا اسْمَ اللَّهِ عَلَيْها صَوافِيَ). قال: خالصة{41}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿فَٱذۡكُرُوا۟ ٱسۡمَ ٱللَّهِ عَلَیۡهَا صَوَاۤفَّۖ﴾</span> - نزول الآية</h3></p><p><div></p><p><p><span class="item-no">٥٠٧٢٩<span class="dash">-</span></span> عن ابن لهيعة، قال: سمعتُ <span class="name-2">ربيعة بن أبي عبد الرحمن</span> يقول: كان أهلُ الجاهلية إذا نحروا بدنهم أشركوا فيها؛ فأنزل الله: <span class="qpc-hafs">﴿فاذكروا اسم الله عليها صواف﴾</span>. فقال ربيعة: خالِصةٌ مِن الشِّرك{42}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿فَٱذۡكُرُوا۟ ٱسۡمَ ٱللَّهِ عَلَیۡهَا صَوَاۤفَّۖ﴾</span> - تفسير الآية</h3></p><p><div></p><p><p><span class="item-no">٥٠٧٣٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن مسعود</span> -من طريق نافع-: أنّه كان ينحر البُدْن وهي قائمة، مستقبلة البيت، تُصَفُّ أيديها بالقيود. قال: هي التي ذكر الله: <span class="qpc-hafs">﴿فاذكروا اسم الله عليها صواف﴾</span>{41}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٧٣١<span class="dash">-</span></span> عن أبي ظبيان، قال: سألتُ <span class="name-1">ابنَ عباس</span> عن قوله: <span class="qpc-hafs">﴿فاذكروا اسم الله عليها صواف﴾</span>. قال: إذا أردت أن تنحر البُدْنة، فأقِمْها على ثلاث قوائم معقولة، ثم قل: باسم الله، والله أكبر، اللَّهُمَّ مِنك ولك{44}. (١٠/٥٠٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٧٣٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طرق- في قوله: <span class="qpc-hafs">﴿صواف﴾</span>، قال: قيامًا معقولة{45}. (١٠/٥٠٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٧٣٣<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عمر</span> -من طريق بجير بن سالم-: أنّه نحر بدنة وهي قائمة معقولة إحدى يديها، وقال: صواف كما قال الله ﷿{46}. (١٠/٥٠٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٧٣٤<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عمر</span> -من طريق نافع- أنه كان ينحرها وهي قائمة يصف بين أيديها بالقيود. وكان يتلو هذه الآية: <span class="qpc-hafs">﴿فاذكروا اسم الله عليها صواف﴾</span>. قال يحيى بن سلام: مقرؤها على هذا التفسير غير مثقلة <span class="qpc-hafs">﴿صوافٍ﴾</span> {47}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٧٣٥<span class="dash">-</span></span> عن سعيد بن جبير قال: رأيت عبد الله بن عمر ينحر بدنته، وقد ثنى يدها، وهي على ثلاث. وقال <span class="name-2">سعيد بن جبير</span> هو قول الله: <span class="qpc-hafs">﴿فاذكروا اسم الله عليها صواف﴾</span>{48}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٧٣٦<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ليث-، في قوله: <span class="qpc-hafs">﴿فاذكروا اسم الله عليها صواف﴾</span>. قال: صوافَّ بين أوظافِها{49} {50}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٧٣٧<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق عبد الكريم-، قال: مُعَقَّلَة قيامًا{47}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٧٣٨<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق أبي يحيى-، قال: معقلة خالصة لله{47}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٧٣٩<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح-: <span class="qpc-hafs">﴿صواف﴾</span> قال: قيام صواف على ثلاث قوائم{50}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٧٤٠<span class="dash">-</span></span> عن <span class="name-2">الضحاك بن مزاحم</span> -من طريق عبيد-، في قوله: <span class="qpc-hafs">﴿فاذكروا اسم الله عليها صواف﴾</span> يعني: صوافن. والبدنة إذا نحرت عقلت يد واحدة، فكانت على ثلاث، وكذلك تنحر{54}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٧٤١<span class="dash">-</span></span> عن أيمن بن نابل، قال: سألت <span class="name-2">طاووسًا</span> عن قوله: <span class="qpc-hafs">﴿فاذكروا اسم الله عليها صواف﴾</span> قال: خالصًا{54}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٧٤٢<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق قتادة-، قوله: <span class="qpc-hafs">﴿فاذكروا اسم الله عليها صواف﴾</span> قال: مخلصين لله{56}<span class=comment-ref>٤٤٧٧</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٤٤٧٧</span> أفادت الآثار اختلاف المفسرين في معنى: «صواف» بناءً على اختلافهم في قراءتها، <b>فمن قرأها:</b> «صوافَّ» بتشديد الفاء ونصبها، قال بأن المعنى: مُصْطَفَّة. <b>ومن قرأها:</b> «صوافي» بالياء، قال بأن المعنى: خالصة لله لا شريك له فيها. <b>ومن قرأها:</b> «صَوافِن» قال بأن المعنى: مُعَقَّلة. <span class="comment-type-3">ورجَّح</span> <u>ابن جرير</u> (١٦/٥٥٥، ٥٦٠) قراءة من قرأها: صوافَّ، والمعنى المترتب على هذه القراءة، وهو أنها مُصطَفَّة بين أيديها، معقولة إحدى قوائمها، وهو قول ابن عباس، وابن عمر، ومجاهد من طريق ليث. ولم يذكر مستندًا.</div></p><p><div></p><p><p><span class="item-no">٥٠٧٤٣<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- قال: مصفوفة بالحبال، معقولة يدها اليمنى وهي قائمة على ثلاث. كذلك ينحرها من نحرها في دار المنحر بمنى{48}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٧٤٤<span class="dash">-</span></span> عن <span class="name-2">عطاء الخراساني</span> -من طريق يونس- في قول الله تعالى: <span class="qpc-hafs">﴿فاذكروا اسم الله عليها صواف﴾</span>، قال: البُدْن تُصَفُّ وتُشعَر وهي قيام{58}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٧٤٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فاذكروا اسم الله عليها﴾</span> إذا نحرت <span class="qpc-hafs">﴿صواف﴾</span> يعني: معقولة يدها اليسرى قائمة على ثلاثة قوائم مستقبلات القبلة{59}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿فَٱذۡكُرُوا۟ ٱسۡمَ ٱللَّهِ عَلَیۡهَا صَوَاۤفَّۖ﴾</span> - أحكام متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٥٠٧٤٦<span class="dash">-</span></span> عن ابن عمر: أنّه رأى رجلًا أناخ بدنته وهو ينحرها، فقال: ابعثها قيامًا مُقَيَّدة؛ سُنَّة محمد ﷺ{60}. (١٠/٥٠٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٧٤٧<span class="dash">-</span></span> عن ابن سابط: أنّ النبيَّ ﷺ وأصحابه كانوا يعقِلون يد البدنة اليسرى، [وينحرونها] قائمة على ما بقي مِن قوائمها{61}. (١٠/٥٠٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٧٤٨<span class="dash">-</span></span> عن عائشة ابنة <span class="name-1">سعد بن مالك</span> -من طريق عثمان-: أنّ أباها كان ينحر البدن وهي مباركة{48}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٧٤٩<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عمر</span>: أنّه كان ينحرها وهي معقولة يدها اليمنى{63}. (١٠/٥٠٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٧٥٠<span class="dash">-</span></span> عن عمرو بن دينار، قال: رأيتُ <span class="name-1">عبد الله بن عمر</span> ينحر البُدن وهي باركة، ورجل يعينه{48}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٧٥١<span class="dash">-</span></span> عن عمرو بن دينار، قال: رأيتُ <span class="name-1">عبد الله بن الزبير</span> على برذون أشعر أوْجَرَها{65} الحربة، وهي قائمة{48}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٧٥٢<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق عبد الكريم-: أنّه كان يَعْقِل يدَها اليسرى إذا أراد أن ينحرها{67}. (١٠/٥٠٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٧٥٣<span class="dash">-</span></span> عن <span class="name-2">القاسم بن محمد</span> -من طريق أفلح بن حميد-: أنّه كان إذا أراد أن ينحرها يَصُفُّ بين يديها وهي قائمة، ويُمْسِك رَجُلٌ بخِطامها، ورَجُلٌ بذَنَبها، ثم يطعنها بالحربة، ثم يجبذانها حتى يصرعاها. وكان يكره أن تُعَرْقَب{68}{69}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٧٥٤<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق أشعث- في البدنة كيف تنحر؟ قال: تُعْقَل يدها اليسرى، وتنحرها مِن قبل يدها اليمنى{70}. (١٠/٥٠٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٧٥٥<span class="dash">-</span></span> عن <span class="name-2">عطاء [بن أبي رباح]</span> -من طريق حجّاج- قال: اعْقِل أيَّ اليدين شئت{63}. (١٠/٥٠٤)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿فَإِذَا وَجَبَتۡ جُنُوبُهَا﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٠٧٥٦<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، <span class="qpc-hafs">﴿فاذا وجبت﴾</span>، قال: سَقَطَتْ على جنبها{72}. (١٠/٥٠٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٧٥٧<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق العوفي- <span class="qpc-hafs">﴿فاذا وجبت﴾</span>، قال: نُحِرَتْ{73}. (١٠/٥٠٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٧٥٨<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح، وابن جُرَيْج- <span class="qpc-hafs">﴿فإذا وجبت جنوبها﴾</span>، قال: سقطت إلى الأرض{74}. (١٠/٥٠٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٧٥٩<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق أبي يحيى- <span class="qpc-hafs">﴿فإذا وجبت﴾</span>: نُحِرَت، فسقطت جنوبها على الأرض مِن قيام أو بروك{75}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٧٦٠<span class="dash">-</span></span> عن <span class="name-2">عطاء الخراساني</span> -من طريق يونس- في قول الله -تبارك وتعالى-: <span class="qpc-hafs">﴿فإذا وجبت جنوبها﴾</span>، قال: إذا جرت وسقطت جنوبها إلى الأرض{76}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٧٦١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فإذا وجبت جنوبها﴾</span>، يعني: فإذا خرَّت لجنبها على الأرض بعد نحرها{59}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٧٦٢<span class="dash">-</span></span> عن <span class="name-3">محمد بن إسحاق</span> -من طريق سلمة- في قوله: <span class="qpc-hafs">﴿فإذا وجبت﴾</span>، قال: إذا فرغت ونحرت{78}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٧٦٣<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿فإذا وجبت جنوبها﴾</span>، قال: فإذا ماتَتْ{78}<span class=comment-ref>٤٤٧٨</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٤٤٧٨</span> ذكر <u>ابنُ كثير</u> (١٠/٦٦) قول مجاهد من طريق ابن أبي نجيح وابن جريج، وابن عباس من طريق العوفي، وابن زيد، ثم <span class="comment-type-4">علَّق</span> على قول ابن زيد قائلًا: «وهذا القول هو مراد ابن عباس ومجاهد، فإنه لا يجوز الأكل من البدنة إذا نحرت حتى تموت وتبرد حركتها، وقد جاء في حديث مرفوع: «<b>ولا تُعجِلوا النفوس أن تَزْهَق</b>»».</div></p><p><h3><span class="qpc-hafs">﴿فَإِذَا وَجَبَتۡ جُنُوبُهَا﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٥٠٧٦٤<span class="dash">-</span></span> عن عبد الله بن قُرْط، قال: قُدِّمَ إلى النبي ﷺ بدنات خمس أو ست، فطَفِقْن يزدلفن إليه بأيتهن يبدأ، فلمّا وجبت جنوبها قال: «<b>مَن شاء اقْتَطَعَ</b>»{80}. (١٠/٥٠٦)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿فَكُلُوا۟ مِنۡهَا﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٠٧٦٥<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق العوفي- <span class="qpc-hafs">﴿فكلوا منها وأطعموا القانع والمعتر﴾</span>، يقول: يأكل منها، ويُطْعِم{81}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٧٦٦<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عمر</span>: أنّه كان يُطْعِم مِن بدنته قبل أن يأكل منها، ويقول: <span class="qpc-hafs">﴿فكلوا منها وأطعموا﴾</span>، هما سواء{4}. (١٠/٥٠٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٧٦٧<span class="dash">-</span></span> عن <span class="name-2">إبراهيم النخعي</span> -من طريق منصور- قال: كانوا لا يأكلون مِن شيء جعلوه لله، ثم رخص لهم أن يأكلوا من الهدي والأضاحي وأشباهه{83}. (١٠/٥٠٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٧٦٨<span class="dash">-</span></span> عن <span class="name-2">إبراهيم النخعي</span> -من طريق مغيرة-= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٧٦٩<span class="dash">-</span></span> و<span class="name-2">مجاهد بن جبر</span> -من طريق حصين-= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٧٧٠<span class="dash">-</span></span> و<span class="name-2">الحسن البصري</span> -من طريق يونس-= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٧٧١<span class="dash">-</span></span> و<span class="name-2">عطاء [بن أبي رباح]</span> -من طريق حجاج- في قوله: <span class="qpc-hafs">﴿فكلوا منها﴾</span>، قال: إن شاء أكل، وإن شاء لم يأكل.= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٧٧٢<span class="dash">-</span></span> قال <span class="name-2">مجاهد</span>: هي رخصة، هي كقوله: <span class="qpc-hafs">﴿فإذا قضيت الصلاة فانتشروا في الأرض﴾</span> [الجمعة:١٠]، ومثل قوله: <span class="qpc-hafs">﴿وإذا حللتم فاصطادوا﴾</span> [المائدة:٢]{84}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿فَكُلُوا۟ مِنۡهَا﴾</span> - أحكام متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٥٠٧٧٣<span class="dash">-</span></span> عن <span class="name-1">علي [بن أبي طالب]</span> -من طريق الحكم- قال: لا يُؤْكَل مِن النَّذر، ولا مِن جزاء الصيد، ولا مِمّا جعل للمساكين{83}. (١٠/٥٠٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٧٧٤<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span> -من طريق سالم- قال: لا يُؤكَل مِن النذر، ولا مِن الكَفّارة، ولا مِمّا جعل للمساكين{83}. (١٠/٥٠٧)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَأَطۡعِمُوا۟ ٱلۡقَانِعَ وَٱلۡمُعۡتَرَّۚ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٠٧٧٥<span class="dash">-</span></span> عن معاذ، قال: أمَرَنا رسولُ الله ﷺ أن نُطْعِم مِن الضحايا الجارَ، والسائلَ، والمتعففَ{87}. (١٠/٥٠٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٧٧٦<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عمر</span> -من طريق عاصم، عمَّن سمع ابن عمر- أنّه كان بمنى، فتلا هذه الآية: <span class="qpc-hafs">﴿فكلوا منها وأطعموا القانع والمعتر﴾</span>. وقال لغلام معه: هذا القانع الذي يقنع بما آتيته{88}. (١٠/٥٠٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٧٧٧<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- قال: القانع: المُتَعَفِّف. والمعتر: السائل{89}. (١٠/٥٠٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٧٧٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، قال: القانع: الذي يقنع بما أُوتِي. والمُعْتَر: الذي يعترض{4}. (١٠/٥٠٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٧٧٩<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، قال: القانع: الذي يجلس في بيته{4}. (١٠/٥٠٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٧٨٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>: أنّ نافع بن الأزرق قال له: أخبِرني عن قوله: <span class="qpc-hafs">﴿القانع والمعتر﴾</span>. قال: القانع: الذي يقنع بما أُعْطِي. والمعتر: الذي يَعْتَرُّ الأبواب. قال: وهل تعرفُ العربُ ذلك؟ قال: نعم، أما سمعت قول الشاعر:</p><p>على مكثريهم حقُّ من يَعْتَرِيهمُ وعند المقِلِّين السماحةُ والبذلُ؟{92}. (١٠/٥٠٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٧٨١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> قال: القانع: الذي يسأل، والمعتر: الذي يتعرض ولا يسأل{93}. (١٠/٥٠٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٧٨٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق العوفي-: القانع: المستغني بما أعطيته وهو في بيته. والمعتر: الذي يتعرض لك، ويُلِمُّ بك أن تطعمه من اللحم، ولا يسأل. وهؤلاء الذين أمر أن يطعموا من البدن{94}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٧٨٣<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق أبي ظبيان- أنّه سُئِل عن هذه الآية. قال: أمّا القانع: فالقانع بما أرسلت إليه في بيته. والمعتر: الذي يعتريك{95}. (١٠/٥٠٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٧٨٤<span class="dash">-</span></span> عن <span class="name-2">إبراهيم النخعي</span> -من طريق منصور-، نحوه{96}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٧٨٥<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق منصور-، مثله{97}. (١٠/٥٠٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٧٨٦<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span> -من طريق فرات القزّاز- قال: القانع: السائل الذي يسأل. ثم أنشد قول الشاعر:</p><p>لمال المرء يصلحه فيُغنى مفاقره أعفُّ مِن القُنُوع{98}. (١٠/٥٠٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٧٨٧<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span> -من طريق فرات القزاز- قال: القانع: الذي يسأل فيعطى في يديه، والمعتر: الذي يعتر فيطوف{99}. (١٠/٥٠٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٧٨٨<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span> -من طريق فرات القزّاز- في قوله: <span class="qpc-hafs">﴿القانع والمعتر﴾</span>، قال: القانع: الذي يسألك. والمعتر: الذي يزورك، ولا يسألك{100}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٧٨٩<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span>، قال: القانع: أهل مكة. والمعتر: سائر الناس{4}. (١٠/٥٠٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٧٩٠<span class="dash">-</span></span> عن <span class="name-2">إبراهيم النخعي</span> -من طريق مغيرة- في قوله: <span class="qpc-hafs">﴿وأطعموا القانع والمعتر﴾</span>، أنّه قال: أحدهما السائل، والآخر الجار{102}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٧٩١<span class="dash">-</span></span> عن <span class="name-2">إبراهيم النخعي</span> -من طريق منصور- في قوله: <span class="qpc-hafs">﴿القانع والمعتر﴾</span>، قال: القانع: المتعفف الذي لايسأل شيئًا. والمعتر: الذي يتعرض الأحيان{100}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٧٩٢<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span>، قال: <span class="qpc-hafs">﴿القانع﴾</span>: الطامع بما قبلك، ولا يسألك. <span class="qpc-hafs">﴿والمعتر﴾</span>: الذي يعتريك، ويسألك{104}. (١٠/٥٠٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٧٩٣<span class="dash">-</span></span> عن خُصيف، قال: سمعت <span class="name-2">مجاهدًا</span>، يقول: القانع: أهل مكة. والمعتر: الذي يعتريك فيسألك{105}. (١٠/٥٠٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٧٩٤<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- قال: القانع: السائل. والمعتر: معتر البدن{88}. (١٠/٥٠٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٧٩٥<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق منصور- قال: البائس: الذي يسأل بيده إذا سأل. والقانع: الطّامع الذي يطمع في ذبيحتك من جيرانك. والمعتر: الذي يعتريك بنفسه، ولا يسألك؛ يتعرض لك{107}. (١٠/٥١٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٧٩٦<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ليث- قال: القانع: جارك الذي يقنع بما أعطيتَه. والمعتر: الذي يتعرض لك، ولا يسألك{94}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٧٩٧<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق أبي يحيى- قال: القانع: السائل الذي يقنع بما أُعْطِي. والمعتر: القاعد في بيته؛ لم يُشْعر بما اعتراه{109}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٧٩٨<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طربق ابن جريج- قال: المعتر: الذي يعتر بالبدن من غني أو فقير، يقول: يتعرض لك، ويسألك{110}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٧٩٩<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span> -من طريق قتادة- في قوله: <span class="qpc-hafs">﴿القانع والمعتر﴾</span>، قال: القانع: الذي يقعد في بيته. والمعتر: الذي يسأل{111}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٨٠٠<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span> -من طريق عمر بن عطاء- قال: القانع: الطامِع{112}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٨٠١<span class="dash">-</span></span> عن <span class="name-2">بكر بن عبد الله المزني</span> -من طريق حميد الطويل- قال: القانع: السائل. والمعتر: الذي يتعرض لك، ولا يسألك{69}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٨٠٢<span class="dash">-</span></span> قال <span class="name-2">الحسن البصري</span> -من طريق الحسن بن دينار- القانع: السائل. والمعتر: الذي يتعرض، ويقبل إن أُعْطِي شيئًا{114}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٨٠٣<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق يونس، ومنصور بن زاذان- قال: القانع: الذي يقنع إليك فيما في يديك. والمعتر: الذي يَتَصَدّى لك لتطعمه. ولفظ ابن أبي شيبة: والمعتر: الذي يعتريك؛ يريك نفسه، ولا يسألك{115}. (١٠/٥٠٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٨٠٤<span class="dash">-</span></span> عن <span class="name-2">القاسم بن أبي بَزَّة</span> أنه سُئِل عن هذه الآية: ما الذي آكل، وما الذي أُعْطِي القانع والمعتر؟ قال: اقسمها ثلاثة أجزاء. قيل: ما القانع؟ قال: مَن كان حولك. قيل: وإن ذُبِح؟ قال: وإن ذُبِح. والمعتر: الذي يأتيك ويسألُك{35}. (١٠/٥١٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٨٠٥<span class="dash">-</span></span> عن <span class="name-2">محمد بن كعب القرظي</span> أنّه كان يقول في هذه الآية: <span class="qpc-hafs">﴿وأطعموا القانع والمعتر﴾</span>: القانع: الذي يقنع بالشيء اليسير؛ يرضى به. والمعتر: الذي يمر بجانبك، لا يسأل شيئًا، فذلك المعتر{117}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٨٠٦<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- قال: القانع: المتعفف الجالس في بيته. والمعتر: الذي يعتريك فيسألك{118}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٨٠٧<span class="dash">-</span></span> قال <span class="name-2">زيد بن أسلم</span> -من طريق عبد الله بن عياش-: القانع: الذي يسأل الناس{119}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٨٠٨<span class="dash">-</span></span> قال <span class="name-2">زيد بن أسلم</span> -من طريق ابن أبي هلال- في قول الله تعالى: <span class="qpc-hafs">﴿القانع والمعتر﴾</span>: فالقانع: المسكين الذي يطوف. والمعتر: الصديق والضعيف الذي يزور{102}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٨٠٩<span class="dash">-</span></span> عن <span class="name-2">عطاء الخراساني</span> -من طريق يونس- في قول الله ﷿: <span class="qpc-hafs">﴿القانع﴾</span> قال: القانع: مَن يقنع برزق الله، ويقعد في بيته. وفي قول الله: <span class="qpc-hafs">﴿المعتر﴾</span> قال: يعتر بِرَّكَ، يرجو فضل ما عندك{76}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٨١٠<span class="dash">-</span></span> عن <span class="name-3">محمد بن السائب الكلبي</span> -من طريق شعبة- قال: القانع: الذي يسأل. والمعتر: الذي يعتريك؛ يتعرض، ولا يسألك{122}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٨١١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فكلوا منها وأطعموا القانع﴾</span> يعني: الراضي الذي يقنع بما يُعْطى، وهو السائل. <span class="qpc-hafs">﴿والمعتر﴾</span> الذي يتعرض للمسألة، ولا يتكلم. فهذا تعليم من الله ﷿، فمن شاء أكل، ومَن لم يسأل لم يأكل، ومَن شاء أطعم{59}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٨١٢<span class="dash">-</span></span> عن <span class="name-3">مالك بن أنس</span> -من طريق يحيى-: أنّ البائس: هو الفقير. وأن المعتر: هو الزائر ... والقانع: هو الفقير أيضًا{124}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٨١٣<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿وأطعموا القانع والمعتر﴾</span>، قال: القانع: المسكين. والمعتر: الذي يعتر للقوم للحمهم، وليس بمسكين، ولا يكون له ذبيحة، يجيء إلى القوم مِن أجل لحمهم. والبائس الفقير: هو القانع{112}<span class=comment-ref>٤٤٧٩</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٤٤٧٩</span> أفادت الآثار اختلاف المفسرين في معنى: <span class="qpc-hafs">﴿القانع والمعترّ﴾</span> على أقوال: <b>الأول:</b> القانع: المستغني بما أعطيته ولا يسأل. والمعترّ: الذي يتعرض لك ولا يسأل. <b>الثاني:</b> القانع: الذي يقنع بما عنده ولا يسأل. والمعترّ: الذي يعتريك فيسألك. <b>الثالث:</b> القانع: السائل. والمعترّ: الذي يعتريك ولا يسأل. <b>الرابع:</b> القانع: الجار. والمعترّ: الذي يعتريك من الناس. <b>الخامس:</b> القانع: الطوّاف. والمعترّ: الصديق الزائر. <b>السادس:</b> القانع: الطامع. والمعترّ: الذي يعترُّ بالبدن. <b>السابع:</b> القانع: المسكين. والمعترّ: الذي يتعرض للَّحم.</p><p>و<span class="comment-type-3">رجَّح</span> <u>ابنُ جرير</u> (١٦/٥٦٩) <span class="mustanad">مستندًا إلى دلالة لفظ الآية</span>، <span class="mustanad">والعقل، واللغة</span> القولَ الثالث، وهو قول الحسن، وسعيد بن جبير، وزيد بن أسلم من طريق عبدالله بن عياش، و<span class="comment-type-2">انتقد</span> مَن قال بأن القانع: المكتفي بما عنده، والمستغني به، فقال: «وأولى هذه الأقوال بالصواب قولُ من قال: عُنِي بالقانع: السائل؛ لأنه لو كان المعنيّ بالقانع في هذا الموضع المُكتَفي بما عنده والمستغني به لقيل: وأطعموا القانع والسائل، ولم يقل: <span class="qpc-hafs">﴿وأَطْعِمُوا القانِعَ والمُعْتَرَّ﴾</span>. وفي إتباع ذلك قوله: <span class="qpc-hafs">﴿والمُعْتَرَّ﴾</span> الدليل الواضح على أن القانع معنيٌّ به: السائل، مِن قولهم: قنع فلان إلى فلان، بمعنى: سأله وخضع إليه، فهو يقنَع قُنُوعًا؛... وأما»القانع«الذي هو بمعنى المُكتَفي، فإنه من: قَنِعتُ به -بكسر النون- أقنع قناعةً وقَنَعًا وقنعانًا. وأما»المعتر«: فإنه الذي يأتيك معترًّا بك لتعطيه وتطعمه».</div></p><p><h3><span class="qpc-hafs">﴿كَذَ ٰ⁠لِكَ سَخَّرۡنَـٰهَا لَكُمۡ لَعَلَّكُمۡ تَشۡكُرُونَ ۝٣٦﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٠٨١٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: قال سبحانه: <span class="qpc-hafs">﴿كذلك سخرناها﴾</span> يعني: هكذا ذَلَّلْناها <span class="qpc-hafs">﴿لكم﴾</span> يعني: البدن؛ <span class="qpc-hafs">﴿لعلكم تشكرون﴾</span> ربكم ﷿ في نِعَمِه{59}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٨١٥<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>، في قوله: <span class="qpc-hafs">﴿كذلك سخرناها لكم﴾</span>: الأنعام؛ <span class="qpc-hafs">﴿لعلكم تشكرون﴾</span> لكي تشكروا{127}. (ز)</p></p><p></div></p></div>",footnotes:1:عزاه السيوطي إلى عبد بن حميد.</p><p>وهي قراءة العشرة.أخرجه ابن أبي شيبة (القسم الأول من الجزء الرابع) ص٣٦٧. وعزاه السيوطي إلى عبد بن حميد.عزاه السيوطي إلى عبد بن حميد، وابن المنذر.عزاه السيوطي إلى ابن أبي حاتم.أخرجه ابن أبي شيبة (القسم الأول من الجزء الرابع) ص٣٦٧.أخرجه ابن أبي شيبة (القسم الأول من الجزء الرابع) ص٣٦٧. وعزاه السيوطي إلى عبد بن حميد، وابن أبي حاتم.السَّمانَة: كثرة اللحم، وهو خلاف الهُزال. مشارق الأنوار للقاضي عياض ٢/٢٢٠، واللسان (سمن).أخرجه ابن أبي شيبة ٤/١١٢. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.أخرجه ابن أبي شيبة (ت: محمد عوامة) ٨/٥٠٦ (١٤٨٧٥).عزاه السيوطي إلى ابن أبي حاتم.أخرجه ابن جرير ١٦/٥٥٣، وأخرج إسحاق البستي في تفسيره ص٣٦٦ نحوه من طريق ابن أبي نجيح، وزاد: وكان الإناث أحب إليهم من الذكور.أخرجه ابن أبي شيبة (ت: محمد عوامة) ٨/٥٠٦ (١٤٨٧٦). وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.تفسير الثعلبي ٧/٢٢، وتفسير البغوي ٥/٣٨٦، واللفظ له.تفسير مقاتل بن سليمان ٣/١٢٧.تفسير مقاتل بن سليمان ٣/١٢٧.أخرجه الثوري في تفسيره بنحوه ص٢١٣، ويحيى بن سلام ١/٣٧٥، وابن جرير ١٦/٥٥٤. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.أخرجه ابن جرير ١٦/٥٥٤. وعزاه السيوطي إلى ابن أبي شيبة، وعبد بن حميد، وابن المنذر، وابن أبي حاتم.أخرجه ابن أبي شيبة (القسم الأول من الجزء الرابع) ص٤١٢.علَّقه يحيى بن سلام ١/٣٧٥.تفسير مقاتل بن سليمان ٣/١٢٧.تفسير يحيى بن سلام ١/٣٧٥.أخرجه أحمد ٣٢/٣٤ (١٩٢٨٣)، وابن ماجه ٤/٣٠٥ (٣١٢٧)، والحاكم ٢/٤٢٢ (٣٤٦٧). وفيه عائذ الله، وأبو داود نفيع بن الحارث.</p><p>قال الحاكم: «هذا حديث صحيح الإسناد، ولم يخرجاه». وقال الذهبي في التلخيص: «عائذ الله، قال أبوحاتم: منكر الحديث». وقال البيهقي في الكبرى ٩/٤٣٩ (١٩٠١٧، ١٩٠١٨): «قال البخاري: عائذ الله المجاشعي عن أبي داود، روى عنه سلام بن مسكين، لا يصح حديثه. قال أبو أحمد: هذا الحديث يعرف بعائذ الله، وليس يرويه عنه غير سلام بن مسكين، وأبو داود لم يُسَمّ هو نفيع بن الحارث». وقال المنذري في الترغيب ٢/٩٩ (١٦٦٠) معقبًا على كلام الحاكم: «بل واهية، عائذ الله هو المجاشعي، وأبو داود هو نفيع بن الحارث الأعمى، وكلاهما ساقط». وقال البوصيري في مصباح الزجاجة ٣/٢٢٣ (٦٨٠١): «هذا إسناد فيه أبو داود، واسمه: نفيع بن الحارث، وهو متروك». وقال الهيتمي في الزواجر ١/٣٤٦: «صححه الحاكم، واعتُرِض بأن في سنده ساقطَين». وقال الألباني في الضعيفة ٢/١٤ (٥٢٧): «موضوع».أخرجه الترمذي ٣/٣١٥-٣١٦ (١٥٦٧)، وابن ماجه ٤/٣٠٤-٣٠٥ (٣١٢٦)، والحاكم ٤/٢٤٦ (٧٥٢٣). وفيه سليمان بن يزيد، وعبد الله بن نافع.</p><p>قال الترمذي: «هذا حديث حسن غريب». وقال الحاكم: «هذا حديث صحيح الإسناد، ولم يخرجاه». وقال الذهبي في التلخيص: «سليمان واهٍ». وقال البيهقي في السنن الكبرى ٩/٤٣٨ (١٩٠١٥): «قال البخاري فيما حكى أبو عيسى عنه: هو حديث مرسل، لم يسمع أبو المثنى من هشام بن عروة». وقال ابن الجوزي في العلل المتناهية ٢/٧٩: «وهذا حديث لا يصح، قال يحيى: عبد الله بن نافع ليس بشيء. وقال النسائي: متروك. وقال البخاري: منكر الحديث. وقال ابن حبان: لا يحتج بأخباره». وقال المنذري في الترغيب ٢/٩٩ (١٦٦٠): «سليمان واهٍ، وقد وُثِّق». وقال ابن الملقن في البدر المنير ٩/٢٧٤ معلقًا على تصحيح الحاكم: «وفيه نظر؛ فإن في إسناده سليمان بن يزيد أبو المثنى الكعبي الخزاعي، تركه بعضهم، وقال الرازي: منكر الحديث. وقال ابن حبان: لا يجوز الاحتجاج به. وخالف في ثقاته فذكره فيها». وقال الألباني في الضعيفة ٢/١٤ (٥٢٦): «ضعيف».أخرجه مسلم ٢/٩٦١ (١٣٢٤).أخرجه البخاري ٢/١٦٧ (١٦٨٩)، ٢/١٧٠ (١٧٠٦)، ٤/٧ (٢٧٥٥)، ٨/٣٧-٣٨ (٦١٦٠)، ومسلم ٢/٩٦٠ (١٣٢٢).أخرجه البخاري ٢/١٦٧ (١٦٩٠)، ٤/٧ (٢٧٥٤)، ٨/٣٧ (٦١٥٩)، ومسلم ٢/٩٦١ (١٣٢٣) واللفظ له.أخرجه ابن أبي شيبة (القسم الأول من الجزء الرابع) ص٤١٠.أخرجه يحيى بن سلام ١/٣٧٢.عزاه السيوطي إلى ابن أبي حاتم.أخرجه أبو نعيم في الحلية ٣/١٦٠.أخرجه عبد الرزاق ٢/٣٨. وعزاه السيوطي إلى عبد بن حميد، وابن الأنباري. وعلَّقه يحيى بن سلام ١/٣٧٧ ثم عقَّب عليه بقوله: هي مثل قوله: <span class="qpc-hafs">﴿الصافنات الجياد﴾</span> [ص:٣١] الفرس إذا صفن رفع إحدى رجليه، فقام على طرف الحافر.</p><p>و(صَوافِنَ) قراءة شاذة، تروى أيضًا عن ابن عباس، وابن مسعود، وابن عمر ﵃، وغيرهم، وقراءة العشرة <span class="qpc-hafs">﴿صَوافَّ﴾</span>. انظر: مختصر ابن خالويه ص٩٦-٩٧.أخرجه عبد الله بن وهب في الجامع ٣/٥٣ (١١٤).أخرجه أبو عبيد ص١٧٨. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه الضياء في المختارة (٧). وعزاه السيوطي إلى ابن الأنباري في المصاحف.</p><p>والقراءة شاذة. انظر: مختصر الشواذ لابن خالويه ص٩٧-٩٨.عزاه السيوطي إلى عبد بن حميد.عزاه السيوطي إلى ابن الأنباري.أخرجه ابن أبي شيبة ٤/٨٢، والبيهقي في سننه ٥/٢٣٧. وعزاه السيوطي إلى عبد الرزاق، وعبد بن حميد، وابن المنذر، وابن أبي حاتم.أخرجه عبد الله بن وهب في الجامع ٣/٥٣ (١١٤) دون قوله: كانوا يذبحونها لأصنامهم. وعزاه السيوطي إلى عبد الرزاق، وأبي عبيد، وعبد بن حميد، وابن المنذر، وابن الأنباري في المصاحف، وابن أبي حاتم.</p><p>و(صَوافِى) قراءة شاذة، تروى أيضًا عن أبي موسى الأشعري، وعبد الرحمن بن زيد بن أسلم، وغيرهم. انظر: مختصر ابن خالويه ص٩٧، والمحتسب ٢/٨١.أخرجه عبد الله بن وهب في الجامع ٣/٥٣ (١١٥).عزاه السيوطي إلى أبي عبيد، وابن المنذر، وابن أبي حاتم.أخرجه ابن جرير ١٦/٥٥٨.أخرجه عبد الله بن وهب في الجامع - تفسير القرآن ٢/٥٨ (١١٥) مرسلًا.أخرجه ابن جرير ١٦/٥٥٨.أخرجه ابن جرير ١٦/٥٥٥، ٥٥٨، والحاكم ٢/٣٨٩، ٤/٢٣٣، والبيهقي في سننه ٥/٢٣٧، ٩/٢٨٧. وعزاه السيوطي إلى عبد بن حميد، وابن أبي الدنيا في الأضاحي، وابن المنذر، وابن أبي حاتم.أخرجه يحيى بن سلام ١/٣٧٦، وسعيد بن منصور -كما في تغليق التعليق ٣/٩٢-، وابن أبي شيبة ٤/٨٣، وعبد بن حميد -كما في تغليق التعليق ٣/٩٢-، وابن جرير ١٦/٥٥٦. وعزاه السيوطي إلى الفريابي، وأبي عبيد، وابن المنذر، وابن أبي حاتم.أخرجه ابن جرير ١٦/٥٥٧. وعزاه السيوطي إلى سعيد بن منصور، وابن المنذر، وابن أبي حاتم.أخرجه يحيى بن سلام ١/٣٧٦.أخرجه يحيى بن سلام ١/٣٧٧.أوظافها: جمع وظِيف: والوَظِيف لكل ذِي أربع: ما فوق الرُّسْغ إلى مَفْصِل السّاق. اللسان (وظف).أخرجه ابن جرير ١٦/٥٥٧.أخرجه يحيى بن سلام ١/٣٧٦.أخرجه يحيى بن سلام ١/٣٧٦.أخرجه ابن جرير ١٦/٥٥٧.أخرجه ابن جرير ١٦/٥٥٩.أخرجه ابن جرير ١٦/٥٥٩.أخرجه يحيى بن سلام ١/٣٧٦. ثم عقَّب عليه بقوله: مقراها على هذا التفسير غير مثقلة (صوافٍ).أخرجه يحيى بن سلام ١/٣٧٧.أخرجه أبو جعفر الرملي في جزئه ص١١٧ (تفسير الخراساني).تفسير مقاتل بن سليمان ٣/١٢٨.أخرجه البخاري ٢/١٧١ (١٧١٣)، ومسلم ٢/٩٥٦ (١٣٢٠).أخرجه أبو داود ٣/١٨١ (١٧٦٧)، وابن أبي شيبة ٣/٢١٤ (١٣٥٥٨) واللفظ له.</p><p>قال الزيلعي في نصب الراية ٣/١٦٤: «وجهل من قال: هذا حديث مرسل. فإن المخبر عن عبد الرحمن بن سابط هو ابن جريج، فالحديث من مسند جابر». وقال الشوكاني في نيل الأوطار ٥/١٤٥: «حديث عبد الرحمن بن سابط هو في سنن أبي داود من حديث جابر بن عبد الله؛ فلا إرسال، وهكذا ذكره الحافظ في الفتح من حديث جابر، وعزاه إلى أبي داود. وقد سكت عنه هو والمنذري، ورجاله رجال الصحيح».أخرجه يحيى بن سلام ١/٣٧٧.أخرجه ابن أبي شيبة (القسم الأول من الجزء الرابع) ص٢٠٦.أخرجه يحيى بن سلام ١/٣٧٧.أوجرها: طَعَنَها بِهِ في فِيها. اللسان (وجر).أخرجه يحيى بن سلام ١/٣٧٧.أخرجه ابن أبي شيبة (القسم الأول من الجزء الرابع) ص٢٠٦-٢٠٧.عرقب الدابة: قطع عُرْقُوبها، وهو الوتر الذي خَلْفَ الكَعْبَين بين مَفْصِل القَدَم والسّاق من ذوات الأْربع. النهاية (عرقب).أخرجه يحيى بن سلام ١/٣٧٨.أخرجه ابن أبي شيبة (القسم الأول من الجزء الرابع) ص٢٠٧.أخرجه ابن أبي شيبة (القسم الأول من الجزء الرابع) ص٢٠٦.أخرجه ابن أبي حاتم -كما في فتح الباري ٣/٥٣٧-. وعزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ١٦/٥٦١. وعزاه السيوطي إلى ابن أبي حاتم.أخرجه يحيى بن سلام ١/٣٧٨، وابن جرير ١٦/٥٦٠-٥٦١. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه يحيى بن سلام ١/٣٧٨، وابن جرير ١٦/٥٦١ بلفظ: نحرت.أخرجه أبو جعفر الرملي في جزئه ص١١٨ (تفسير عطاء الخراساني).تفسير مقاتل بن سليمان ٣/١٢٨.أخرجه ابن جرير ١٦/٥٦١.أخرجه ابن جرير ١٦/٥٦١.أخرجه أحمد ٣١/٤٢٧ (١٩٠٧٥)، وأبو داود ٣/١٧٩-١٨٠ (١٧٦٥)، والحاكم ٤/٢٤٦ (٧٥٢٢)، وابن خزيمة ٤/٥٠٠ (٢٩١٧).</p><p>قال الحاكم: «حديث صحيح الإسناد، ولم يخرجاه». وقال الذهبي في سير أعلام النبلاء ٢/٢٩٣: «حديث حسن». وقال الألباني في صحيح أبي داود ٦/١٤ (١٥٤٩) «إسناده صحيح، وقد صحّحه ابن حبان، والحاكم».أخرجه ابن جرير ١٦/٥٦٢.عزاه السيوطي إلى ابن أبي حاتم.أخرجه ابن أبي شيبة (القسم الأول من الجزء الرابع) ص١٥٣.أخرجه ابن جرير ١٦/٥٦٢، وأخرج قول مجاهد إسحاق البستي في تفسيره ص٣٦٩.أخرجه ابن أبي شيبة (القسم الأول من الجزء الرابع) ص١٥٣.أخرجه ابن أبي شيبة (القسم الأول من الجزء الرابع) ص١٥٣.أخرجه الخطيب في تاريخه ١٣/٣٦٦-٣٦٧ (٣٩٢٨)، والأصبهاني في الترغيب والترهيب ١/٢٥٧ (٣٩٣) واللفظ له، من طريق ابن لهيعة، عن ابن أنعم، عن عتبة بن حميد، عن عبادة بن نسي، عن ابن غنم، عن معاذ به.</p><p>إسناده ضعيف جِدًّا، فيه ابن لهيعة، وعبد الرحمن بن زياد بن أنعم، وعتبة بن حميد، وكلهم ضعفاء الحفظ أو في حفظهم شيء، كما في التقريب لابن حجر (٣٥٦٣، ٣٨٦٢، ٤٤٢٩).</p><p>وفي إسناد الخطيب علي بن حماد بن السكن، والواقدي، وهما متروكان، كما في التقريب لابن حجر (٦١٧٥).أخرجه ابن أبي شيبة ٤/٧٢.أخرجه ابن جرير ١٦/٥٦٢، وابن أبي حاتم -كما في الإتقان ٢/٣٠-.عزاه السيوطي إلى ابن أبي حاتم.عزاه السيوطي إلى ابن أبي حاتم.أخرجه الطستي -كما في الإتقان ٢/٧٢-.عزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ١٦/٥٦٣.أخرجه البيهقي في سننه ٩/٢٩٤. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه ابن جرير ١٦/٥٦٩.أخرجه ابن أبي شيبة ٤/٧٢، وابن جرير ١٦/٥٦٩.أخرجه ابن أبي شيبة ٨/٥١٦، ١٠/٤٧٥، وابن جرير ١٦/٥٦٦. وعزاه السيوطي إلى عبد بن حميد.أخرجه عبد الرزاق ٢/٣٨. وعزاه السيوطي إلى عبد بن حميدأخرجه الثوري ص٢١٤.عزاه السيوطي إلى ابن أبي حاتم.أخرجه ابن جرير ١٦/٥٦٧.أخرجه الثوري ص٢١٤.أخرجه عبد الرزاق ٢/٣٨ من قول ابن أبي نجيح، وعبد بن حميد -كما في فتح الباري ٣/٥٣٦-، والبيهقي في سننه ٩/٢٩٤.أخرجه ابن أبي شيبة (ت: محمد عوامة) ٨/٧٣٠-٧٣١ (١٥٨٣٢)، وابن جرير ١٦/٥٦٣.أخرجه ابن أبي شيبة ٤/٧٢.أخرجه البيهقي في سننه ٩/٢٩٤.أخرجه ابن جرير ١٦/٥٦٣.أخرجه يحيى بن سلام ١/٣٧٩.أخرجه إسحاق البستي في تفسيره ص٣٧٠.أخرجه ابن جرير ١٦/٥٦٤.أخرجه ابن جرير ١٦/٥٦٨.أخرجه يحيى بن سلام ١/٣٧٨.تفسير ابن أبي زمنين ٣/١٨٢، وهو ساقط من المطبوع مِن تفسير يحيى بن سلام ١/٣٧٩ كما ذكرت محققته.أخرجه ابن أبي شيبة ٤/٧٢ من طريق يونس، وابن جرير ١٦/٥٦٥ بنحوه من طريق منصور بن زادان. وعزاه السيوطي إلى عبد بن حميد.عزاه السيوطي إلى عبد بن حميد.أخرجه عبد الله بن وهب في الجامع - تفسير القرآن ٢/٧٤-٧٥ (١٤٤) من طريق أبي صخر، وابن جرير ١٦/٥٦٣.أخرجه ابن جرير ١٦/٥٦٤. وعند يحيى بن سلام ١/٣٧٨ بلفظ: القانع: الفقير المتعفف القاعد في بيته لا يسأل. والمعتر: الذي يعتريك يسألك في كفه. ولكلٍّ عليك حق.أخرجه عبد الله بن وهب في الجامع - تفسير القرآن ١/٦١-٦٢ (١٣٦)، وابن جرير ١٦/٥٦٦.أخرجه ابن جرير ١٦/٥٦٧.أخرجه أبو جعفر الرملي في جزئه ص١١٨ (تفسير عطاء الخراساني).أخرجه ابن جرير ١٦/٥٦٥.تفسير مقاتل بن سليمان ٣/١٢٨.الموطأ (ت: د. بشار عواد) ١/٦٤١-٦٤٢ (١٤٣٥).أخرجه ابن جرير ١٦/٥٦٨.تفسير مقاتل بن سليمان ٣/١٢٨.تفسير يحيى بن سلام ١/٣٧٩.
  22,37,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿لَن یَنَالَ ٱللَّهَ لُحُومُهَا وَلَا دِمَاۤؤُهَا وَلَـٰكِن یَنَالُهُ ٱلتَّقۡوَىٰ مِنكُمۡۚ﴾</span> - قراءات</h3></p><p><div></p><p><p><span class="item-no">٥٠٨١٦<span class="dash">-</span></span> عن <span class="name-2">محمد ابن شهاب الزهري</span> -من طريق عقيل بن خالد- أنّه كان يقول: ‹لَن تَنالَ اللهَ لُحُومُها ولا دِمَآؤُها ولَكِن تَنالُهُ التَّقْوى مِنكُمْ›{1}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿لَن یَنَالَ ٱللَّهَ لُحُومُهَا وَلَا دِمَاۤؤُهَا وَلَـٰكِن یَنَالُهُ ٱلتَّقۡوَىٰ مِنكُمۡۚ﴾</span> - نزول الآية</h3></p><p><div></p><p><p><span class="item-no">٥٠٨١٧<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، قال: كان المشركون إذا ذبحوا استقبلوا الكعبة بالدماء، فينضحون بها نحو الكعبة، فأراد المسلمون أن يفعلوا ذلك؛ فأنزل الله: <span class="qpc-hafs">﴿لن ينال الله لحومها ولا دماؤها﴾</span> الآية{2}. (١٠/٥١٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٨١٨<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿لن ينال الله لحومها ولا دماؤها﴾</span>، وذلك أنّ كُفّار العرب كانوا في الجاهلية، إذا نحروا البدن عند زمزم، أخذوا دماءها فنضحوها قِبَل الكعبة، وقالوا: اللَّهُمَّ، تَقَبَّل مِنّا. فأراد المسلمون أن يفعلوا ذلك؛ فأنزل الله ﷿: <span class="qpc-hafs">﴿لن ينال الله لحومها ولا دماؤها﴾</span>{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٨١٩<span class="dash">-</span></span> عن <span class="name-3">عبد الملك ابن جُرَيْج</span>، قال: كان أهلُ الجاهلية ينضحون البيت بلحوم الإبل ودمائها، فقال أصحاب النبي ﷺ: فنحن أحقُّ أن ننضح. فأنزل الله: <span class="qpc-hafs">﴿لن ينال الله لحومها﴾</span>{4}. (١٠/٥١٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٨٢٠<span class="dash">-</span></span> عن <span class="name-3">عبد الملك ابن جريج</span> -من طريق حجاج- قال: النُّصُب ليست بأصنام، الصنم يُصَوَّر وينقش، وهذه حجارة تُنصَب، ثلاثمائة وستون حَجَرًا، فكانوا إذا ذبحوا نضحوا الدم على ما أقبل من البيت، وشَرَّحُوا اللحم، وجعلوه على الحجارة، فقال المسلمون: يا رسول الله، كان أهل الجاهلية يُعَظِّمون البيتَ بالدم، فنحن أحقُّ أن نُعَظِّمه. فكأنّ النبي ﷺ لم يكره ما قالوا؛ فأنزل الله: <span class="qpc-hafs">﴿لن ينال الله لحومها ولا دماؤها﴾</span>{5}. (١٠/٥١٠)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿لَن یَنَالَ ٱللَّهَ لُحُومُهَا وَلَا دِمَاۤؤُهَا وَلَـٰكِن یَنَالُهُ ٱلتَّقۡوَىٰ مِنكُمۡۚ﴾</span> - تفسير الآية</h3></p><p><div></p><p><p><span class="item-no">٥٠٨٢١<span class="dash">-</span></span> عن <span class="name-2">إبراهيم النخعي</span> -من طريق منصور- <span class="qpc-hafs">﴿ولكن يناله التقوى منكم﴾</span>، قال: ما التُمِس به وجهُ الله{6}. (١٠/٥١١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٨٢٢<span class="dash">-</span></span> عن <span class="name-2">الضحاك بن مزاحم</span>، <span class="qpc-hafs">﴿ولكن يناله التقوى منكم﴾</span>، يقول: إن كانت مِن طيب، وكنتم طيبين؛ وصَل إلَيَّ أعمالكم وتَقَبَّلْتُها{7}. (١٠/٥١١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٨٢٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ولكن يناله التقوى منكم﴾</span>، يقول: النحر هو تقوى منكم، فالتقوى هو الذي ينال الله ويرفعه إليه، فأما اللحوم والدماء فلا يرفعه إليه{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٨٢٤<span class="dash">-</span></span> عن <span class="name-3">مقاتل بن حيان</span>، <span class="qpc-hafs">﴿لن ينال الله﴾</span>، قال: لن يُرفع إلى الله لحومها ولا دماؤها، ولكن نحر البدن مِن تقوى الله وطاعته. يقول: يُرفَع إلى الله منكم الأعمال الصالحة، والتقوى{9}. (١٠/٥١١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٨٢٥<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿لن ينال الله لحومها ولا دماؤها ولكن يناله التقوى منكم﴾</span>، قال: إن اتَّقَيْتَ اللهَ في هذه البدن، وعملت فيها لله، وطلبت ما قال الله تعظيمًا لشعائر الله، ولحرمات الله؛ فإنّه قال: <span class="qpc-hafs">﴿ومن يعظم شعائر الله فإنها من تقوى القلوب﴾</span>. قال: <span class="qpc-hafs">﴿ومن يعظم حرمات الله فهو خير له عند ربه﴾</span>. قال: وجعلته طيِّبًا، فذلك الذي يتقبل الله، فأما اللحوم والدماء فمن أين تنال الله؟!{10}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٨٢٦<span class="dash">-</span></span> قال <span class="name-3">يحيى بن</span> <span class="name-3">سلّام</span>: قوله: <span class="qpc-hafs">﴿لن ينال الله لحومها ولا دماؤها﴾</span>، يقول: لا يصعد إلى الله لحومها ولا دماؤها. وقد كان المشركون يذبحون لآلهتهم، ثم ينضحون دماءها حول البيت، <span class="qpc-hafs">﴿ولكن يناله التقوى منكم﴾</span> يصعد إليه التقوى منكم. يعني: من آمن{11}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿كَذَ ٰ⁠لِكَ سَخَّرَهَا لَكُمۡ لِتُكَبِّرُوا۟ ٱللَّهَ عَلَىٰ مَا هَدَىٰكُمۡۗ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٠٨٢٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿كذلك سخرها لكم﴾</span> يعني: البدن؛ <span class="qpc-hafs">﴿لتكبروا﴾</span> لِتُعَظِّموا <span class="qpc-hafs">﴿الله على ما هداكم﴾</span> لدينه{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٨٢٨<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿لتكبروا الله على ما هداكم﴾</span>، قال: على ذبحها في تلك الأيام{13}. (١٠/٥١١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٨٢٩<span class="dash">-</span></span> قال <span class="name-3">يحيى بن</span> <span class="name-3">سلّام</span>: قوله: <span class="qpc-hafs">﴿كذلك سخرها لكم﴾</span> الأنعام <span class="qpc-hafs">﴿لتكبروا الله على ما هداكم﴾</span>، وقال في الآية الأولى: <span class="qpc-hafs">﴿ليذكروا اسم الله على ما رزقهم من بهيمة الأنعام﴾</span> إذا ذبحوا. فالسُّنَّة إذا ذبح أو نحر أن يقول: بسم الله، والله أكبر{11}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَبَشِّرِ ٱلۡمُحۡسِنِینَ ۝٣٧﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٠٨٣٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وبشر المحسنين﴾</span> بالجنَّة، فمَن فعل ما ذكر اللهَ في هذه الآيات فقد أحسن{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٨٣١<span class="dash">-</span></span> قال <span class="name-3">يحيى بن</span> <span class="name-3">سلّام</span>: قوله: <span class="qpc-hafs">﴿وبشر المحسنين﴾</span> بالجنة{16}<span class=comment-ref>٤٤٨٠</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٤٤٨٠</span> ذكر <u>ابنُ عطية</u> (٦/٢٥١) بأنّه رُوِي «أنّ قوله تعالى: <span class="qpc-hafs">﴿وبَشِّرِ المُحْسِنِينَ﴾</span> نزلت في الخلفاء الأربعة». ثم <span class="comment-type-2">استدرك</span> على ذلك قائلًا: «فأما ظاهر اللفظة فيقتضي العموم في كل محسن».</div></p><p><h3><span class="qpc-hafs">﴿وَبَشِّرِ ٱلۡمُحۡسِنِینَ ۝٣٧﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٥٠٨٣٢<span class="dash">-</span></span> عن الحسن بن علي، قال: أمرنا رسولُ الله ﷺ أن نلبس أجودَ ما نَجِد، وأن نَتَطَيَّب بأجودَ ما نَجِد، وأن نُضَحِّي بأسمن ما نَجِد، والبقرة عن سبعة، والجزور عن سبعة، وأن نُظْهِر التكبير، وعلينا السَّكِينة والوَقار{17}. (١٠/٥١١)</p></p><p></div></p></div>",footnotes:1:أخرجه عبد الله بن وهب في الجامع - تفسير القرآن ٣/٤٩-٥٠ (١٠٢).</p><p>والقراءة متواترة، قرأ بها يعقوب، وقرأ بقية العشرة: <span class="qpc-hafs">﴿لَن يَنالَ اللَّهَ لُحُومُها ولا دِماؤُها ولَكِن يَنالُهُ التَّقْوى مِنكُمْ﴾</span> بالياء فيهما. انظر: النشر ٢/٣٢٦، والإتحاف ص٣٩٨.عزاه السيوطي إلى ابن المنذر، وابن مردويه.تفسير مقاتل بن سليمان ٣/١٢٨.عزاه السيوطي إلى ابن أبي حاتم مرسلًا.أخرجه ابن جرير ٨/٧٠ مرسلًا. وعزاه السيوطي إلى ابن المنذر.أخرجه إسحاق البستي في تفسيره ص٣٧٢. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.عزاه السيوطي إلى ابن المنذر.تفسير مقاتل بن سليمان ٣/١٢٨.عزاه السيوطي إلى ابن أبي حاتم.أخرجه ابن جرير ١٦/٥٧٠.تفسير يحيى بن سلام ١/٣٧٩.تفسير مقاتل بن سليمان ٣/١٢٨.أخرجه ابن جرير ١٦/٥٧١. وعزاه السيوطي إلى ابن أبي حاتم.تفسير يحيى بن سلام ١/٣٧٩.تفسير مقاتل بن سليمان ٣/١٢٨.تفسير يحيى بن سلام ١/٣٨٠.أخرجه البيهقي في شعب الإيمان ٥/٢٨٩ (٣٤٤٢)، والحاكم ٤/٢٥٦ (٧٥٦٠) بلفظ: والجزور عن عشرة. وفيه إسحاق بن بزرج.</p><p>قال الحاكم: «لولا جهالة إسحاق بن بزرج لَحكمتُ للحديث بالصحة». وقال ابن الملقن في تحفة المحتاج ١/٥٤٤ (٦٩٤) مُعَلِّقًا على الحاكم: «ليس بمجهول، فقد ضعّفه الأزدي، ووَثَّقه ابن حِبّان». وقال الهيثمي في المجمع ٤/٢٠-٢١ (٥٩٦١): «رواه الطبراني في الكبير، وفيه عبد الله بن صالح، قال عبد الملك بن شعيب بن الليث بن سعد: ثقة مأمون. وضعّفه أحمد، وجماعة».
  22,38,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿إِنَّ ٱللَّهَ یُدَ ٰ⁠فِعُ عَنِ ٱلَّذِینَ ءَامَنُوۤا۟ۗ﴾</span> - قراءات</h3></p><p><div></p><p><p><span class="item-no">٥٠٨٣٣<span class="dash">-</span></span> عن <span class="name-2">عاصم [بن أبي النجود]</span> أنّه قرأ: <span class="qpc-hafs">﴿إنَّ اللَّهَ يُدافِعُ﴾</span> بالألف، ورفع الياء{1}. (١٠/٥١٢)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿إِنَّ ٱللَّهَ یُدَ ٰ⁠فِعُ عَنِ ٱلَّذِینَ ءَامَنُوۤا۟ۗ﴾</span> - تفسير الآية</h3></p><p><div></p><p><p><span class="item-no">٥٠٨٣٤<span class="dash">-</span></span> تفسير <span class="name-2">الحسن البصري</span>: قوله: <span class="qpc-hafs">﴿إنَّ اللَّهَ يُدافِعُ عَنِ الَّذِينَ آمَنُواْ﴾</span>: يدافع عنهم، فيعصمهم من الشيطان في دينهم{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٨٣٥<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿إنَّ اللَّهَ يُدافِعُ عَنِ الَّذِينَ آمَنُواْ﴾</span>، قال: واللهِ، ما يُضَيِّع اللهُ رجلًا قطُّ حفِظ له دينَه{3}. (١٠/٥١٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٨٣٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: قوله ﷿: <span class="qpc-hafs">﴿إنَّ اللَّهَ يُدافِعُ﴾</span> كفار مكة <span class="qpc-hafs">﴿عَنِ الَّذِينَ آمَنُواْ﴾</span> بمكة، هذا حين أمر المؤمنين بالكفِّ عن كُفّار مكة قبل الهجرة حين آذوهم، فاستشاروا النبيَّ ﷺ في قتالهم في السر، فنهاهم الله ﷿{4}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿إِنَّ ٱللَّهَ لَا یُحِبُّ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٠٨٣٧<span class="dash">-</span></span> عن <span class="name-3">سفيان</span>، في قوله: <span class="qpc-hafs">﴿ان الله لا يحب﴾</span>، قال: لا يُقَرِّبُ{5}. (١٠/٥١٢)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿كُلَّ خَوَّانࣲ كَفُورٍ ۝٣٨﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٠٨٣٨<span class="dash">-</span></span> قال <span class="name-1">عبد الله بن عباس</span>: خانوا اللهَ، فجعلوا معه شريكًا، وكفروا نِعَمَه{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٨٣٩<span class="dash">-</span></span> قال <span class="name-2">مجاهد بن جبر</span>: كل شيء في القرآن: <span class="qpc-hafs">﴿كفور﴾</span> يعني: به: الكُفّار{5}. (١٠/٥١٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٨٤٠<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق أبي الأشهب- قوله: <span class="qpc-hafs">﴿إن الله لا يحب كل خوان كفور﴾</span>، في قوله: <span class="qpc-hafs">﴿إنا عرضنا الأمانة على السموات والأرض والجبال فأبين أن يحملنها وأشفقن منها وحملها الإنسان إنه كان ظلوما جهولا (٧٢) ليعذب الله المنافقين والمنافقات والمشركين والمشركات﴾</span> [الأحزاب:٧٢-٧٣]، قال: هما اللذان ظلماها، هما اللذان خاناها: المنافق، والمشرك{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٨٤١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿إن الله لا يحب كل خوان﴾</span> يعني: كل عاص، <span class="qpc-hafs">﴿كفور﴾</span> بتوحيد الله ﷿، يعني: كفار مكة{4}. (ز)</p></p><p></div></p></div>",footnotes:1:عزاه السيوطي إلى عبد بن حميد.</p><p>وهي قراءة العشرة ما عدا ابن كثير، وأبا عمرو، ويعقوب؛ فإنهم قرؤوا: <span class="qpc-hafs">﴿إنَّ اللَّهَ يَدْفَعُ﴾</span> بفتح الياء وإسكان الدال من دون ألف. انظر: النشر ٢/٣٢٦، والإتحاف ص٣٩٩.أخرجه يحيى بن سلام ١/٣٨٠.أخرجه يحيى بن سلام ١/٣٨٠. وعزاه السيوطي إلى ابن أبي حاتم.تفسير مقاتل بن سليمان ٣/١٢٩.عزاه السيوطي إلى ابن أبي حاتم.تفسير البغوي ٥/٣٨٨.عزاه السيوطي إلى ابن أبي حاتم.أخرجه يحيى بن سلام ١/٣٨٠.تفسير مقاتل بن سليمان ٣/١٢٩.