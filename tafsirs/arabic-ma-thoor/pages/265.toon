quran[19]{c,v,t}:
  15,52,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿إِذۡ دَخَلُوا۟ عَلَیۡهِ فَقَالُوا۟ سَلَـٰمࣰا قَالَ إِنَّا مِنكُمۡ وَجِلُونَ ۝٥٢ قَالُوا۟ لَا تَوۡجَلۡ إِنَّا نُبَشِّرُكَ بِغُلَـٰمٍ عَلِیمࣲ ۝٥٣﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٠٤٣٨<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span>، <span class="qpc-hafs">﴿قالوا لا توجل﴾</span>، قال: لا تَخَفْ{1}. (٨/٦٣٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٠٤٣٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿إذ دخلوا عليه﴾</span> على إبراهيم، <span class="qpc-hafs">﴿فقالوا سلاما﴾</span> فسَلَّموا عليه، وسَلَّم عليهما، <span class="qpc-hafs">﴿قال إنا منكم وجلون﴾</span> يعني: خائفين، وذلك أنّ إبراهيم ﵇ قرَّب إليهم العِجْل، فلم يأكلوا منه، فخاف إبراهيم ﵇، وكان في زمان إبراهيم ﵇ إذا أكل الرجلُ عند الرجل طعامًا أمِنَ مِن شَرِّه، فلمّا رأى إبراهيم ﵇ أيديَهم لا تصل إلى العِجْل خاف شرَّهم، <span class="qpc-hafs">﴿قالوا﴾</span> قال له جبريل ﵇: <span class="qpc-hafs">﴿لا توجل﴾</span> يقول: لا تَخَفْ، <span class="qpc-hafs">﴿إنا نبشرك بغلام عليم﴾</span> وهو إسحاق ﵇{2}. (ز)</p></p><p></div></p></div>",footnotes:1:عزاه السيوطي إلى ابن أبي حاتم.|2:تفسير مقاتل بن سليمان ٢/٤٣١.
  15,53,""
  15,54,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿قَالَ أَبَشَّرۡتُمُونِی عَلَىٰۤ أَن مَّسَّنِیَ ٱلۡكِبَرُ فَبِمَ تُبَشِّرُونَ ۝٥٤﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٠٤٤٠<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- <span class="qpc-hafs">﴿فبِم تبشرون﴾</span>، قال: عَجِب مِن كِبَرِه، وكِبَرِ امرأتِه{1}. (٨/٦٣٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٠٤٤١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿قال﴾</span> لهم إبراهيم ﵇: <span class="qpc-hafs">﴿أبشرتموني﴾</span> بالولد <span class="qpc-hafs">﴿على أن مسني الكبر﴾</span> على كِبَر سِنِّي، <span class="qpc-hafs">﴿فبم تبشرون﴾</span> قال ذلك إبراهيم ﵇ تَعَجُّبًا لِكِبَرِه، وكِبَر امرأتِه{2}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ١٤/٨٣-٨٤. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.|2:تفسير مقاتل بن سليمان ٢/٤٣١.
  15,55,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿قَالُوا۟ بَشَّرۡنَـٰكَ بِٱلۡحَقِّ فَلَا تَكُن مِّنَ ٱلۡقَـٰنِطِینَ ۝٥٥﴾</span> - قراءات</h3></p><p><div></p><p><p><span class="item-no">٤٠٤٤٢<span class="dash">-</span></span> عن <span class="name-2">يحيى</span> -من طريق الأعمش- أنّه قرأها: (فَلا تَكُن مِّنَ القَنِطِينَ) بغير ألف. قال: وقرأ: <span class="qpc-hafs">﴿ومَن يَقْنَطُ مِن رَّحْمَةِ رَبِّهِ﴾</span> مفتوحة النون{1}<span class=comment-ref>٣٦١٦</span>. (٨/٦٣٣)</p></p><p></div></p><p><div><span class=comment-ref>٣٦١٦</span> اختلفت القرأة في قراءة قوله تعالى: <span class="qpc-hafs">﴿فَلا تَكُنْ مِنَ القانِطِينَ﴾</span> على قراءتين: <b>الأولى:</b> <span class="qpc-hafs">﴿القانِطِين﴾</span> بالألف. <b>الثانية:</b> (القَنِطِين) بدون ألف.</p><p>و<span class="comment-type-3">رجَّح</span> <u>ابنُ جرير</u> (١٤/٨٤-٨٥) القراءة الأولى <span class="mustanad">مستندًا إلى إجماع الحجة مِن القرأة عليها، وشذوذ ما خالفه</span>.</div></p><p><h3><span class="qpc-hafs">﴿قَالُوا۟ بَشَّرۡنَـٰكَ بِٱلۡحَقِّ فَلَا تَكُن مِّنَ ٱلۡقَـٰنِطِینَ ۝٥٥﴾</span> - تفسير الآية</h3></p><p><div></p><p><p><span class="item-no">٤٠٤٤٣<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span>، <span class="qpc-hafs">﴿من القانطين﴾</span>، قال: الآيِسِين{2}. (٨/٦٣٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٠٤٤٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿قالوا﴾</span> قال جبريل ﵇: <span class="qpc-hafs">﴿بشرناك﴾</span> يعني: نُبَشِّرك <span class="qpc-hafs">﴿بالحق﴾</span> يعني: بالصِّدق أنّ الولد لَكائن، <span class="qpc-hafs">﴿فلا تكن﴾</span> يا إبراهيم <span class="qpc-hafs">﴿من القانطين﴾</span> يعني: لا تَيْأَس{3}. (ز)</p></p><p></div></p></div>",footnotes:1:عزاه السيوطي إلى أبي عبيد، وابن المنذر.</p><p>(فَلا تَكُن مِّنَ القَنِطِينَ) بغير ألف قراءة شاذة، تروى أيضًا عن الأعمش، وطلحة بن مصرّف، وغيرهما. انظر: مختصر ابن خالويه ص٧٥، والمحتسب ٢/٤.</p><p>وأما <span class="qpc-hafs">﴿ومَن يَقْنَطُ﴾</span> بفتح النون، فهي قراءة متواترة، قرأ بها ابن كثير، ونافع، وعاصم، وابن عامر، وحمزة، وأبو جعفر، وقرأ بقية العشرة: ‹ومَن يَقْنِطُ› بكسر النون. انظر: النشر ٢/٣٠٢، والإتحاف ص٣٤٧.|2:عزاه السيوطي إلى ابن أبي حاتم.|3:تفسير مقاتل بن سليمان ٢/٤٣٢.
  15,56,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿قَالَ وَمَن یَقۡنَطُ مِن رَّحۡمَةِ رَبِّهِۦۤ إِلَّا ٱلضَّاۤلُّونَ ۝٥٦﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٠٤٤٥<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span>، <span class="qpc-hafs">﴿ومن يقنَط من رحمة ربه﴾</span>، قال: مَن ييأس مِن رحمة ربِّه{1}. (٨/٦٣٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٠٤٤٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿قال﴾</span> إبراهيم ﵇: <span class="qpc-hafs">﴿ومن يقنط﴾</span> يعني: ومَن يَيْئَس <span class="qpc-hafs">﴿من رحمة ربه إلا الضالون﴾</span> يعني: المشركين{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٠٤٤٧<span class="dash">-</span></span> عن <span class="name-3">سفيان بن عيينة</span>، قال: مَن ذهب يُقَنِّطُ الناسَ مِن رحمة الله، أو يُقَنِّطُ نفسَه؛ فقد أخطأ. ثم نَزَعَ{3} بهذه الآية: <span class="qpc-hafs">﴿ومن يقنَط من رحمة ربه إلا الضآلون﴾</span>{1}. (٨/٦٣٣)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿قَالَ وَمَن یَقۡنَطُ مِن رَّحۡمَةِ رَبِّهِۦۤ إِلَّا ٱلضَّاۤلُّونَ ۝٥٦﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٤٠٤٤٨<span class="dash">-</span></span> عن عبد الله بن مسعود، قال: قال رسول الله ﷺ: «<b>الفاجر الرّاجي لِرَحمة اللهِ أقربُ مِن العابد المُقَنِّطِ</b>»{5}. (٨/٦٣٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٠٤٤٩<span class="dash">-</span></span> عن موسى بن علي، عن أبيه، قال: بَلَغَني: أنّ نوحًا ﵇ قال لابنه سام: يا بُنَيَّ، لا تَدْخُلَنَّ القبرَ وفي قلبك مثقال ذَرَّةٍ مِن الشرك بالله؛ فإنه مَن يأت اللهَ ﷿ مُشْرِكًا فلا حُجَّةَ له، ويا بُنَيَّ، لا تَدْخُلَنَّ القبر وفي قلبك مِثقال ذرَّةٍ مِن الكبر؛ فإنّ الكبرياء رِداءُ الله، فمَن يُنازِع اللهَ رداءَه يغضب الله عليه، ويا بُنَيَّ، لا تَدْخُلَنَّ القبر وفي قلبك مثقال ذرة مِن القنَط؛ فإنّه لا يقنَط مِن رحمة الله إلا ضالٌّ{6}. (٨/٦٣٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٠٤٥٠<span class="dash">-</span></span> عن أبي توبة الربيع بن نافع، قال: سُئِل <span class="name-3">سفيان بن عيينة</span> عن قول <span class="name-1">عليٍّ</span>: الفقيهُ كُلَّ الفقيه مَن لم يُقَنِّط الناس من رحمة الله، ولم يُرَخِّص لهم في معاصي الله. فقال: صدق، لا يكون الترخيص إلا في المستقبل، ولا التَّقنيط إلا فيما مضى.=</p><p>قال سفيان: وقال <span class="name-1">عبد الله</span>: اثنتان مُنجِيَتان، واثنتان مُهْلِكتان؛ فالمُنجِيَتان: النِّيَّة، والنهي؛ فالنِّيَّة أن تنوي أن تطيع الله فيما يستقبل، والنهي أن تنهى نفسك عمّا حرم الله ﷿. والمهلكتان: العجب، والقنوط.= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٠٤٥١<span class="dash">-</span></span> قال <span class="name-3">سفيان</span>: وأكبر الكبائر: الشرك بالله، والقنوط من رحمة الله، واليأس من روح الله، والأمن من مكر الله. ثم تلا: <span class="qpc-hafs">﴿فلا يأمن مكر الله إلا القوم الخاسرون﴾</span> [الأعراف:٩٩]، <span class="qpc-hafs">﴿أنه من يشرك بالله فقد حرم الله عليه الجنة﴾</span> [المائدة:٧٢]، <span class="qpc-hafs">﴿لا ييأس من روح الله إلا القوم الكافرون﴾</span> [يوسف:٨٧]، <span class="qpc-hafs">﴿ومن يقنط من رحمة ربه إلا الضالون﴾</span> [الحجر:٥٦]{7}. (ز)</p></p><p></div></p></div>",footnotes:1:عزاه السيوطي إلى ابن أبي حاتم.|2:تفسير مقاتل بن سليمان ٢/٤٣٢.|3:نَزَع بالآية والشِّعر وانتَزَع: تمثّل، ويقال للرجل إذا استنبط معنى آية من كتاب الله ﷿: قد انتزع معنى جيدًا. اللسان (نزع).|4:عزاه السيوطي إلى ابن أبي حاتم.|5:أورده الحكيم الترمذي في نوادر الأصول ١/٩٣، والديلمي في مسند الفردوس ٣/١٥٩ (٤٤٢٧) بلفظ: من العبد المجتهد الآيس منها الذي لا يرجو أن ينالها وهو مطيع لله.</p><p>قال المناوي في التيسير ٢/١٧٩ عن رواية الحكيم الترمذي والشيرازي في الألقاب: «بإسناد ضعيف». وقال في فيض القدير ٤/٤٦٠-٤٦١ (٥٩٧١): «وفيه عبد الله بن يحيى الثقفي، أورده الذهبي في ذيل الضعفاء وقال: صُوَيْلح ضعَّفه ابن معين، وسلام بن مسلم قال في الضعفاء: تركوه باتفاق، وزيد العمي ضعيف متماسك». وقال الألباني في الضعيفة ٩/٢٨ (٤٠٢٥) عن رواية الديلمي: «موضوع».|6:أخرجه أحمد في الزهد ص٥١.|7:أخرجه أبو نعيم في حلية الأولياء ٧/٢٩٧-٢٩٨.
  15,57,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿قَالَ فَمَا خَطۡبُكُمۡ أَیُّهَا ٱلۡمُرۡسَلُونَ ۝٥٧﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٠٤٥٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿قال﴾</span> إبراهيم: <span class="qpc-hafs">﴿فما خطبكم﴾</span> يعني: فما أمَرَكُم <span class="qpc-hafs">﴿أيها المرسلون﴾</span>{1}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٢/٤٣٢.
  15,58,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿قَالُوۤا۟ إِنَّاۤ أُرۡسِلۡنَاۤ إِلَىٰ قَوۡمࣲ مُّجۡرِمِینَ ۝٥٨ إِلَّاۤ ءَالَ لُوطٍ إِنَّا لَمُنَجُّوهُمۡ أَجۡمَعِینَ ۝٥٩ إِلَّا ٱمۡرَأَتَهُۥ قَدَّرۡنَاۤ إِنَّهَا لَمِنَ ٱلۡغَـٰبِرِینَ ۝٦٠﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٠٤٥٣<span class="dash">-</span></span> عن <span class="name-2">إبراهيم النخعي</span>، قال: بيني وبين القَدَرِيَّة هذه الآية: <span class="qpc-hafs">﴿إلا امرأته قدَّرنا إنها لمن الغابرين﴾</span>{1}. (٨/٦٣٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٠٤٥٤<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span>، في قوله: <span class="qpc-hafs">﴿إنها لمن الغابرين﴾</span>، يعني: الباقين في عذاب الله{1}. (٨/٦٣٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٠٤٥٥<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق مَعْمَر- في قوله تعالى: <span class="qpc-hafs">﴿إنها لمن الغابرين﴾</span>، قال: مِمَّن غَبَر فهَلك{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٠٤٥٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿قالوا﴾</span> أي: قال جبريل ﵇: <span class="qpc-hafs">﴿إنا أرسلنا﴾</span> بالعذاب <span class="qpc-hafs">﴿إلى قوم مجرمين* إلا آل لوط إنا لمنجوهم أجمعين﴾</span> ثم استثنى جبريل ﵇ امرأةَ لوط، فقال: <span class="qpc-hafs">﴿إلا امرأته قدرنا إنها لمن الغابرين﴾</span> يعني: الباقين في العذاب{4}. (ز)</p></p><p></div></p></div>",footnotes:1:عزاه السيوطي إلى ابن أبي حاتم.|2:عزاه السيوطي إلى ابن أبي حاتم.|3:أخرجه عبد الرزاق في تفسيره ٢/٣٤٩.|4:تفسير مقاتل بن سليمان ٢/٤٣٢.
  15,59,""
  15,60,""
  15,61,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿فَلَمَّا جَاۤءَ ءَالَ لُوطٍ ٱلۡمُرۡسَلُونَ ۝٦١ قَالَ إِنَّكُمۡ قَوۡمࣱ مُّنكَرُونَ ۝٦٢﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٠٤٥٧<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>- من طريق علي بن أبي طلحة-: <span class="qpc-hafs">﴿قوم منكرون﴾</span> أنكرهم لوط{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٠٤٥٨<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نَجِيح- في قوله: <span class="qpc-hafs">﴿إنكم قوم منكرون﴾</span>، قال: أنكَرَهُم لوط{2}. (٨/٦٣٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٠٤٥٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: فخرجوا مِن عند إبراهيم ﵇ بالأرض المُقَدَّسة، فأَتَوْا لوطًا بأرض سدوم مِن ساعتهم، فلم يعرِفهم لوط ﵇، وظنَّ أنهم رجال، <span class="qpc-hafs">﴿فلما جاء آل لوط المرسلون﴾</span> فيها تقديم، يقول: جاء المرسلون إلى لوط، <span class="qpc-hafs">﴿قال﴾</span> لهم لوط: <span class="qpc-hafs">﴿إنكم قوم منكرون﴾</span> أنكرهم، ولم يعلم أنّهم ملائكة؛ لأنّهم كانوا في صورة الرِّجال{3}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن أبي حاتم -كما في الفتح ٨/٣٧٩. وعلَّقه البخاري ٤/١٧٣٦.|2:أخرجه ابن جرير ١٤/٨٧. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.|3:تفسير مقاتل بن سليمان ٢/٤٣٢.
  15,62,""
  15,63,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿قَالُوا۟ بَلۡ جِئۡنَـٰكَ بِمَا كَانُوا۟ فِیهِ یَمۡتَرُونَ ۝٦٣ وَأَتَیۡنَـٰكَ بِٱلۡحَقِّ وَإِنَّا لَصَـٰدِقُونَ ۝٦٤﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٠٤٦٠<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- وفي قوله: <span class="qpc-hafs">﴿بما كانوا فيه يمترون﴾</span>، قال: بعذاب قوم لوط{1}. (٨/٦٣٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٠٤٦١<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span>، <span class="qpc-hafs">﴿بما كانوا فيه يمترون﴾</span>، قال: يَشُكُّون{2}. (٨/٦٣٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٠٤٦٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿قالوا بل﴾</span> قال جبريل ﵇: قد <span class="qpc-hafs">﴿جئناك﴾</span> يا لوط <span class="qpc-hafs">﴿بما كانوا فيه يمترون﴾</span> يعني: بما كان قومُك بالعذاب يمترون، يعني: يَشُكُّون في العذاب أنّه ليس بنازل بهم في الدنيا، <span class="qpc-hafs">﴿وأتيناك بالحق﴾</span> جِئناك بالصدق، <span class="qpc-hafs">﴿وإنا لصادقون﴾</span> بما تقول: إنّا جئناهم بالعذاب{3}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ١٤/٨٧. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.|2:عزاه السيوطي إلى عبد بن حميد، وابن المنذر.|3:تفسير مقاتل بن سليمان ٢/٤٣٣.
  15,64,""
  15,65,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿فَأَسۡرِ بِأَهۡلِكَ بِقِطۡعࣲ مِّنَ ٱلَّیۡلِ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٠٤٦٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: فقالوا للوط: <span class="qpc-hafs">﴿فأسر بأهلك﴾</span> يعني: امرأته، وابنته ريثا، وزعوثا، <span class="qpc-hafs">﴿بقطع﴾</span> يعني: ببَعْض، وهو السَّحَر <span class="qpc-hafs">﴿من الليل﴾</span>{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٠٤٦٤<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿فأسر بأهلك بقطع من الليل﴾</span>، قال: بعض الليل{2}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَٱتَّبِعۡ أَدۡبَـٰرَهُمۡ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٠٤٦٥<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق مَعْمَر- في قوله: <span class="qpc-hafs">﴿واتبع أدبارهم﴾</span>، قال: أُمِر أن يكون خَلْفَ أهلِه، يَتَّبِعْ أدبارهم في آخرهم إذا مَشَوْا{3}. (٨/٦٣٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٠٤٦٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿واتبع أدبارهم﴾</span>، يعني: سِرْ مِن وراء أهلك، تَسُوقُهم{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٠٤٦٧<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿واتبع أدبارهم﴾</span>: أدبار أهلِه{2}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَلَا یَلۡتَفِتۡ مِنكُمۡ أَحَدࣱ﴾</span> - قراءات</h3></p><p><div></p><p><p><span class="item-no">٤٠٤٦٨<span class="dash">-</span></span> عن الأعمش: في قراءة <span class="name-1">عبد الله [بن مسعود]</span>: (ولا يَلْتَفِتَنَّ مِنكُمْ أحَدٌ){6}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَلَا یَلۡتَفِتۡ مِنكُمۡ أَحَدࣱ﴾</span> - تفسير الآية</h3></p><p><div></p><p><p><span class="item-no">٤٠٤٦٩<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نَجِيح- <span class="qpc-hafs">﴿ولا يلتفت منكم أحد﴾</span>: لا يلتفت وراءَه أحدٌ، ولا يُعَرِّج{2}<span class=comment-ref>٣٦١٧</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٣٦١٧</span> ذكر <u>ابنُ عطية</u> (٥/٣٠٦) قول مجاهد، ثم <span class="comment-type-4">نقل</span> معنًى آخر في معنى الالتفات، فقال: «وقيل: <span class="qpc-hafs">﴿يَلْتَفِتْ﴾</span> معناه: يلوي، مِن قولك: لَفَتُّ الأمر: إذا لويته، ومنه قولهم للقصيدة: لفيتة؛ لأنها مَلْوِيٌّ بعضها على بعض». وذكر في سبب النهي عن الالتفات أنهم «نهوا عن النظر مخافة الغفلة، وتعلق النفس بمن خلف، وقيل: بل لِئَلّا تتفطر قلوبهم مِن معاينة ما جرى على القرية في رفعها وطرحها».</div></p><p><div></p><p><p><span class="item-no">٤٠٤٧٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ولا يلتفت منكم أحد﴾</span> البَتَّة، يقول: ولا ينظر أحدٌ منكم وراءَه{1}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَٱمۡضُوا۟ حَیۡثُ تُؤۡمَرُونَ ۝٦٥﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٠٤٧١<span class="dash">-</span></span> قال <span class="name-1">عبد الله بن عباس</span>، في قوله: <span class="qpc-hafs">﴿وامضوا حيث تؤمرون﴾</span>، يعني: الشام{9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٠٤٧٢<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span>، في قوله: <span class="qpc-hafs">﴿وامضوا حيث تؤمرون﴾</span>، قال: أخرَجهم اللهُ إلى الشام{10}. (٨/٦٣٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٠٤٧٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل</span>، في قوله: <span class="qpc-hafs">﴿وامضوا حيث تؤمرون﴾</span>، يعني: زُغَر{11}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٠٤٧٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وامضوا حيث تؤمرون﴾</span> إلى الشام{1}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٢/٤٣٣.|2:أخرجه ابن جرير ١٤/٨٨.|3:أخرجه عبد الرزاق ١/٣٤٩، وابن جرير ١٤/٨٨. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.|4:تفسير مقاتل بن سليمان ٢/٤٣٣.|5:أخرجه ابن جرير ١٤/٨٨.|6:أخرجه ابن أبي داود في المصاحف ١/٣٢٠.</p><p>وهي قراءة شاذة.|7:أخرجه ابن جرير ١٤/٨٨.|8:تفسير مقاتل بن سليمان ٢/٤٣٣.|9:تفسير الثعلبي ٥/٣٤٥، وتفسير البغوي ٤/٣٨٦.|10:عزاه السيوطي إلى ابن أبي حاتم.|11:تفسير البغوي ٤/٣٨٦.</p><p>وزُغَر: قرية بمشارف الشام. معجم البلدان ٣/١٤٢-١٤٣.|12:تفسير مقاتل بن سليمان ٢/٤٣٣.
  15,66,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَقَضَیۡنَاۤ إِلَیۡهِ ذَ ٰ⁠لِكَ ٱلۡأَمۡرَ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٠٤٧٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وقضينا إليه﴾</span> يقول: وعَهِدنا إلى لوط <span class="qpc-hafs">﴿ذلك الأمر﴾</span> يعني: أمر العذاب{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٠٤٧٦<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- <span class="qpc-hafs">﴿وقضينا إليه ذلك الأمر﴾</span>، قال: أوْحَيْنا إليه{2}. (٨/٦٣٥)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿أَنَّ دَابِرَ هَـٰۤؤُلَاۤءِ مَقۡطُوعࣱ مُّصۡبِحِینَ ۝٦٦﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٠٤٧٧<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق ابن جُرَيْج- في قوله: <span class="qpc-hafs">﴿أنّ دابرَ هؤلاء مقطوع﴾</span> يعني: استِئصال هلاكِهم <span class="qpc-hafs">﴿مصبحين﴾</span>{3}. (٨/٦٣٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٠٤٧٨<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿أن دابر﴾</span> يعني: أصل هؤلاء القوم <span class="qpc-hafs">﴿مقطوع مصبحين﴾</span> يقول: إذا أصبحوا نَزَل بهم العذاب{1}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٢/٤٣٣.|2:أخرجه ابن جرير ١٤/٨٩-٩٠. وعزاه السيوطي إلى ابن أبي حاتم.|3:أخرجه ابن جرير ١٤/٨٩.|4:تفسير مقاتل بن سليمان ٢/٤٣٣.
  15,67,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَجَاۤءَ أَهۡلُ ٱلۡمَدِینَةِ یَسۡتَبۡشِرُونَ ۝٦٧﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٠٤٧٩<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿وجاء أهل المدينة يستبشرون﴾</span>، قال: اسْتَبْشَروا بأضياف نبيِّ الله لوط -صلى الله عليه- حين نزلوا به، لِما أرادوا أن يأتُوا إليهم مِن المنكر{1}. (٨/٦٣٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٠٤٨٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وجاء أهل المدينة يستبشرون﴾</span> بدخول الرِّجال منزلَ لوط{2}<span class=comment-ref>٣٦١٨</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٣٦١٨</span> ذكر <u>ابنُ عطية</u> (٥/٣٠٦-٣٠٧) في معنى: <span class="qpc-hafs">﴿وجاءَ أهْلُ المَدِينَةِ يَسْتَبْشِرُونَ﴾</span> احتمالين: <b>الأول:</b> «أن يرجع إلى وصْفِ أمرٍ جرى قبل إعلام لوط بهلاك أُمَّته، ويدُلُّ على هذا أنّ محاجَّة لوط لقومه في الأضياف تقتضي ضعف مَن لم يعلم إهلاكهم، وأنّ الأضياف ملائكة». <b>الثاني:</b> «أن يكون قوله: <span class="qpc-hafs">﴿وجاءَ أهْلُ المَدِينَةِ﴾</span> بعد علمه بهلاكهم، وكان قولهم ما يأتي مِن المحاورة على جهة التَّهَكُّم عنهم، والإملاء لهم، والتربُّص بهم». ثم <span class="comment-type-3">رجَّح</span> الاحتمال الأول <span class="mustanad">مستندًا إلى النظائر</span> قائلًا: «والاحتمال الأول عندي أرجح، وهو الظاهر من آيات غير هذه السورة».</div></p></div>",footnotes:1:أخرجه ابن جرير ١٤/٩٠. وعزاه السيوطي إلى ابن أبي حاتم.|2:تفسير مقاتل بن سليمان ٢/٤٣٣.
  15,68,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿قَالَ إِنَّ هَـٰۤؤُلَاۤءِ ضَیۡفِی فَلَا تَفۡضَحُونِ ۝٦٨ وَٱتَّقُوا۟ ٱللَّهَ وَلَا تُخۡزُونِ ۝٦٩﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٠٤٨١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثُمَّ <span class="qpc-hafs">﴿قال﴾</span> لهم لوط: <span class="qpc-hafs">﴿إن هؤلاء ضيفي فلا تفضحون﴾</span> فيهم، ولوط ﵇ يرى أنّهم رجال، <span class="qpc-hafs">﴿واتقوا الله ولا تخزون﴾</span> فيهم{1}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٢/٤٣٣.
  15,69,""
  15,70,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿قَالُوۤا۟ أَوَلَمۡ نَنۡهَكَ عَنِ ٱلۡعَـٰلَمِینَ ۝٧٠﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٠٤٨٢<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿أوَلم ننهك عن العالمين﴾</span>، قال: يقولون: أوَلَمْ ننهك أن تُضِيفَ أحدًا، أو تُؤْوِيه؟!{1}. (٨/٦٣٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٠٤٨٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿قالوا أولم ننهك عن العالمين﴾</span> أن تُضِيف منهم أحدًا؛ لأنّ لوطًا كان يُحَذِّرهم؛ لِئَلّا يُؤْتَون في أدبارهم{2}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ١٢/٥٠٣، ١٤/٩٠-٩١. وعزاه السيوطي إلى عَبد بن حُمَيد، وابن المنذر، وابن أبي حاتم.|2:تفسير مقاتل بن سليمان ٢/٤٣٣.