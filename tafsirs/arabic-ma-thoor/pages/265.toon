tafsir[19]{c,v,t}:
15,52," <q>﴿إِذۡ دَخَلُوا۟ عَلَیۡهِ فَقَالُوا۟ سَلَـٰمࣰا قَالَ إِنَّا مِنكُمۡ وَجِلُونَ ۝٥٢ قَالُوا۟ لَا تَوۡجَلۡ إِنَّا نُبَشِّرُكَ بِغُلَـٰمٍ عَلِیمࣲ ۝٥٣﴾</q> - تفسير ٤٠٤٣٨- عن عكرمة مولى ابن عباس، <q>﴿قالوا لا توجل﴾</q>، قال: لا تَخَفْ{1}. (٨/٦٣٣) ٤٠٤٣٩- قال مقاتل بن سليمان: <q>﴿إذ دخلوا عليه﴾</q> على إبراهيم، <q>﴿فقالوا سلاما﴾</q> فسَلَّموا عليه، وسَلَّم عليهما، <q>﴿قال إنا منكم وجلون﴾</q> يعني: خائفين، وذلك أنّ إبراهيم ﵇ قرَّب إليهم العِجْل، فلم يأكلوا منه، فخاف إبراهيم ﵇، وكان في زمان إبراهيم ﵇ إذا أكل الرجلُ عند الرجل طعامًا أمِنَ مِن شَرِّه، فلمّا رأى إبراهيم ﵇ أيديَهم لا تصل إلى العِجْل خاف شرَّهم، <q>﴿قالوا﴾</q> قال له جبريل ﵇: <q>﴿لا توجل﴾</q> يقول: لا تَخَفْ، <q>﴿إنا نبشرك بغلام عليم﴾</q> وهو إسحاق ﵇{2}. (ز) ",footnotes:1:عزاه السيوطي إلى ابن أبي حاتم.تفسير مقاتل بن سليمان ٢/٤٣١.
  15,53,""
15,54," <q>﴿قَالَ أَبَشَّرۡتُمُونِی عَلَىٰۤ أَن مَّسَّنِیَ ٱلۡكِبَرُ فَبِمَ تُبَشِّرُونَ ۝٥٤﴾</q> - تفسير ٤٠٤٤٠- عن مجاهد بن جبر -من طريق ابن أبي نجيح- <q>﴿فبِم تبشرون﴾</q>، قال: عَجِب مِن كِبَرِه، وكِبَرِ امرأتِه{1}. (٨/٦٣٣) ٤٠٤٤١- قال مقاتل بن سليمان: <q>﴿قال﴾</q> لهم إبراهيم ﵇: <q>﴿أبشرتموني﴾</q> بالولد <q>﴿على أن مسني الكبر﴾</q> على كِبَر سِنِّي، <q>﴿فبم تبشرون﴾</q> قال ذلك إبراهيم ﵇ تَعَجُّبًا لِكِبَرِه، وكِبَر امرأتِه{2}. (ز) ",footnotes:1:أخرجه ابن جرير ١٤/٨٣-٨٤. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.تفسير مقاتل بن سليمان ٢/٤٣١.
15,55," <q>﴿قَالُوا۟ بَشَّرۡنَـٰكَ بِٱلۡحَقِّ فَلَا تَكُن مِّنَ ٱلۡقَـٰنِطِینَ ۝٥٥﴾</q> - قراءات ٤٠٤٤٢- عن يحيى -من طريق الأعمش- أنّه قرأها: (فَلا تَكُن مِّنَ القَنِطِينَ) بغير ألف. قال: وقرأ: <q>﴿ومَن يَقْنَطُ مِن رَّحْمَةِ رَبِّهِ﴾</q> مفتوحة النون{1}٣٦١٦. (٨/٦٣٣) ٣٦١٦ اختلفت القرأة في قراءة قوله تعالى: <q>﴿فَلا تَكُنْ مِنَ القانِطِينَ﴾</q> على قراءتين: الأولى: <q>﴿القانِطِين﴾</q> بالألف. الثانية: (القَنِطِين) بدون ألف. ورجَّح ابنُ جرير (١٤/٨٤-٨٥) القراءة الأولى مستندًا إلى إجماع الحجة مِن القرأة عليها، وشذوذ ما خالفه. <q>﴿قَالُوا۟ بَشَّرۡنَـٰكَ بِٱلۡحَقِّ فَلَا تَكُن مِّنَ ٱلۡقَـٰنِطِینَ ۝٥٥﴾</q> - تفسير الآية ٤٠٤٤٣- عن إسماعيل السُّدِّيّ، <q>﴿من القانطين﴾</q>، قال: الآيِسِين{2}. (٨/٦٣٣) ٤٠٤٤٤- قال مقاتل بن سليمان: <q>﴿قالوا﴾</q> قال جبريل ﵇: <q>﴿بشرناك﴾</q> يعني: نُبَشِّرك <q>﴿بالحق﴾</q> يعني: بالصِّدق أنّ الولد لَكائن، <q>﴿فلا تكن﴾</q> يا إبراهيم <q>﴿من القانطين﴾</q> يعني: لا تَيْأَس{3}. (ز) ",footnotes:1:عزاه السيوطي إلى أبي عبيد، وابن المنذر. (فَلا تَكُن مِّنَ القَنِطِينَ) بغير ألف قراءة شاذة، تروى أيضًا عن الأعمش، وطلحة بن مصرّف، وغيرهما. انظر: مختصر ابن خالويه ص٧٥، والمحتسب ٢/٤. وأما <q>﴿ومَن يَقْنَطُ﴾</q> بفتح النون، فهي قراءة متواترة، قرأ بها ابن كثير، ونافع، وعاصم، وابن عامر، وحمزة، وأبو جعفر، وقرأ بقية العشرة: ‹ومَن يَقْنِطُ› بكسر النون. انظر: النشر ٢/٣٠٢، والإتحاف ص٣٤٧.عزاه السيوطي إلى ابن أبي حاتم.تفسير مقاتل بن سليمان ٢/٤٣٢.
15,56," <q>﴿قَالَ وَمَن یَقۡنَطُ مِن رَّحۡمَةِ رَبِّهِۦۤ إِلَّا ٱلضَّاۤلُّونَ ۝٥٦﴾</q> - تفسير ٤٠٤٤٥- عن إسماعيل السُّدِّيّ، <q>﴿ومن يقنَط من رحمة ربه﴾</q>، قال: مَن ييأس مِن رحمة ربِّه{1}. (٨/٦٣٤) ٤٠٤٤٦- قال مقاتل بن سليمان: <q>﴿قال﴾</q> إبراهيم ﵇: <q>﴿ومن يقنط﴾</q> يعني: ومَن يَيْئَس <q>﴿من رحمة ربه إلا الضالون﴾</q> يعني: المشركين{2}. (ز) ٤٠٤٤٧- عن سفيان بن عيينة، قال: مَن ذهب يُقَنِّطُ الناسَ مِن رحمة الله، أو يُقَنِّطُ نفسَه؛ فقد أخطأ. ثم نَزَعَ{3} بهذه الآية: <q>﴿ومن يقنَط من رحمة ربه إلا الضآلون﴾</q>{1}. (٨/٦٣٣) <q>﴿قَالَ وَمَن یَقۡنَطُ مِن رَّحۡمَةِ رَبِّهِۦۤ إِلَّا ٱلضَّاۤلُّونَ ۝٥٦﴾</q> - آثار متعلقة بالآية ٤٠٤٤٨- عن عبد الله بن مسعود، قال: قال رسول الله ﷺ: «الفاجر الرّاجي لِرَحمة اللهِ أقربُ مِن العابد المُقَنِّطِ»{5}. (٨/٦٣٤) ٤٠٤٤٩- عن موسى بن علي، عن أبيه، قال: بَلَغَني: أنّ نوحًا ﵇ قال لابنه سام: يا بُنَيَّ، لا تَدْخُلَنَّ القبرَ وفي قلبك مثقال ذَرَّةٍ مِن الشرك بالله؛ فإنه مَن يأت اللهَ ﷿ مُشْرِكًا فلا حُجَّةَ له، ويا بُنَيَّ، لا تَدْخُلَنَّ القبر وفي قلبك مِثقال ذرَّةٍ مِن الكبر؛ فإنّ الكبرياء رِداءُ الله، فمَن يُنازِع اللهَ رداءَه يغضب الله عليه، ويا بُنَيَّ، لا تَدْخُلَنَّ القبر وفي قلبك مثقال ذرة مِن القنَط؛ فإنّه لا يقنَط مِن رحمة الله إلا ضالٌّ{6}. (٨/٦٣٤) ٤٠٤٥٠- عن أبي توبة الربيع بن نافع، قال: سُئِل سفيان بن عيينة عن قول عليٍّ: الفقيهُ كُلَّ الفقيه مَن لم يُقَنِّط الناس من رحمة الله، ولم يُرَخِّص لهم في معاصي الله. فقال: صدق، لا يكون الترخيص إلا في المستقبل، ولا التَّقنيط إلا فيما مضى.= قال سفيان: وقال عبد الله: اثنتان مُنجِيَتان، واثنتان مُهْلِكتان؛ فالمُنجِيَتان: النِّيَّة، والنهي؛ فالنِّيَّة أن تنوي أن تطيع الله فيما يستقبل، والنهي أن تنهى نفسك عمّا حرم الله ﷿. والمهلكتان: العجب، والقنوط.= (ز) ٤٠٤٥١- قال سفيان: وأكبر الكبائر: الشرك بالله، والقنوط من رحمة الله، واليأس من روح الله، والأمن من مكر الله. ثم تلا: <q>﴿فلا يأمن مكر الله إلا القوم الخاسرون﴾</q> [الأعراف:٩٩]، <q>﴿أنه من يشرك بالله فقد حرم الله عليه الجنة﴾</q> [المائدة:٧٢]، <q>﴿لا ييأس من روح الله إلا القوم الكافرون﴾</q> [يوسف:٨٧]، <q>﴿ومن يقنط من رحمة ربه إلا الضالون﴾</q> [الحجر:٥٦]{7}. (ز) ",footnotes:1:عزاه السيوطي إلى ابن أبي حاتم.تفسير مقاتل بن سليمان ٢/٤٣٢.نَزَع بالآية والشِّعر وانتَزَع: تمثّل، ويقال للرجل إذا استنبط معنى آية من كتاب الله ﷿: قد انتزع معنى جيدًا. اللسان (نزع).عزاه السيوطي إلى ابن أبي حاتم.أورده الحكيم الترمذي في نوادر الأصول ١/٩٣، والديلمي في مسند الفردوس ٣/١٥٩ (٤٤٢٧) بلفظ: من العبد المجتهد الآيس منها الذي لا يرجو أن ينالها وهو مطيع لله. قال المناوي في التيسير ٢/١٧٩ عن رواية الحكيم الترمذي والشيرازي في الألقاب: «بإسناد ضعيف». وقال في فيض القدير ٤/٤٦٠-٤٦١ (٥٩٧١): «وفيه عبد الله بن يحيى الثقفي، أورده الذهبي في ذيل الضعفاء وقال: صُوَيْلح ضعَّفه ابن معين، وسلام بن مسلم قال في الضعفاء: تركوه باتفاق، وزيد العمي ضعيف متماسك». وقال الألباني في الضعيفة ٩/٢٨ (٤٠٢٥) عن رواية الديلمي: «موضوع».أخرجه أحمد في الزهد ص٥١.أخرجه أبو نعيم في حلية الأولياء ٧/٢٩٧-٢٩٨.
15,57," <q>﴿قَالَ فَمَا خَطۡبُكُمۡ أَیُّهَا ٱلۡمُرۡسَلُونَ ۝٥٧﴾</q> - تفسير ٤٠٤٥٢- قال مقاتل بن سليمان: <q>﴿قال﴾</q> إبراهيم: <q>﴿فما خطبكم﴾</q> يعني: فما أمَرَكُم <q>﴿أيها المرسلون﴾</q>{1}. (ز) ",footnotes:1:تفسير مقاتل بن سليمان ٢/٤٣٢.
15,58," <q>﴿قَالُوۤا۟ إِنَّاۤ أُرۡسِلۡنَاۤ إِلَىٰ قَوۡمࣲ مُّجۡرِمِینَ ۝٥٨ إِلَّاۤ ءَالَ لُوطٍ إِنَّا لَمُنَجُّوهُمۡ أَجۡمَعِینَ ۝٥٩ إِلَّا ٱمۡرَأَتَهُۥ قَدَّرۡنَاۤ إِنَّهَا لَمِنَ ٱلۡغَـٰبِرِینَ ۝٦٠﴾</q> - تفسير ٤٠٤٥٣- عن إبراهيم النخعي، قال: بيني وبين القَدَرِيَّة هذه الآية: <q>﴿إلا امرأته قدَّرنا إنها لمن الغابرين﴾</q>{1}. (٨/٦٣٥) ٤٠٤٥٤- عن قتادة بن دعامة، في قوله: <q>﴿إنها لمن الغابرين﴾</q>، يعني: الباقين في عذاب الله{1}. (٨/٦٣٥) ٤٠٤٥٥- عن قتادة بن دعامة -من طريق مَعْمَر- في قوله تعالى: <q>﴿إنها لمن الغابرين﴾</q>، قال: مِمَّن غَبَر فهَلك{3}. (ز) ٤٠٤٥٦- قال مقاتل بن سليمان: <q>﴿قالوا﴾</q> أي: قال جبريل ﵇: <q>﴿إنا أرسلنا﴾</q> بالعذاب <q>﴿إلى قوم مجرمين* إلا آل لوط إنا لمنجوهم أجمعين﴾</q> ثم استثنى جبريل ﵇ امرأةَ لوط، فقال: <q>﴿إلا امرأته قدرنا إنها لمن الغابرين﴾</q> يعني: الباقين في العذاب{4}. (ز) ",footnotes:1:عزاه السيوطي إلى ابن أبي حاتم.عزاه السيوطي إلى ابن أبي حاتم.أخرجه عبد الرزاق في تفسيره ٢/٣٤٩.تفسير مقاتل بن سليمان ٢/٤٣٢.
  15,59,""
  15,60,""
15,61," <q>﴿فَلَمَّا جَاۤءَ ءَالَ لُوطٍ ٱلۡمُرۡسَلُونَ ۝٦١ قَالَ إِنَّكُمۡ قَوۡمࣱ مُّنكَرُونَ ۝٦٢﴾</q> - تفسير ٤٠٤٥٧- عن عبد الله بن عباس- من طريق علي بن أبي طلحة-: <q>﴿قوم منكرون﴾</q> أنكرهم لوط{1}. (ز) ٤٠٤٥٨- عن مجاهد بن جبر -من طريق ابن أبي نَجِيح- في قوله: <q>﴿إنكم قوم منكرون﴾</q>، قال: أنكَرَهُم لوط{2}. (٨/٦٣٥) ٤٠٤٥٩- قال مقاتل بن سليمان: فخرجوا مِن عند إبراهيم ﵇ بالأرض المُقَدَّسة، فأَتَوْا لوطًا بأرض سدوم مِن ساعتهم، فلم يعرِفهم لوط ﵇، وظنَّ أنهم رجال، <q>﴿فلما جاء آل لوط المرسلون﴾</q> فيها تقديم، يقول: جاء المرسلون إلى لوط، <q>﴿قال﴾</q> لهم لوط: <q>﴿إنكم قوم منكرون﴾</q> أنكرهم، ولم يعلم أنّهم ملائكة؛ لأنّهم كانوا في صورة الرِّجال{3}. (ز) ",footnotes:1:أخرجه ابن أبي حاتم -كما في الفتح ٨/٣٧٩. وعلَّقه البخاري ٤/١٧٣٦.أخرجه ابن جرير ١٤/٨٧. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.تفسير مقاتل بن سليمان ٢/٤٣٢.
  15,62,""
15,63," <q>﴿قَالُوا۟ بَلۡ جِئۡنَـٰكَ بِمَا كَانُوا۟ فِیهِ یَمۡتَرُونَ ۝٦٣ وَأَتَیۡنَـٰكَ بِٱلۡحَقِّ وَإِنَّا لَصَـٰدِقُونَ ۝٦٤﴾</q> - تفسير ٤٠٤٦٠- عن مجاهد بن جبر -من طريق ابن أبي نجيح- وفي قوله: <q>﴿بما كانوا فيه يمترون﴾</q>، قال: بعذاب قوم لوط{1}. (٨/٦٣٥) ٤٠٤٦١- عن قتادة بن دعامة، <q>﴿بما كانوا فيه يمترون﴾</q>، قال: يَشُكُّون{2}. (٨/٦٣٥) ٤٠٤٦٢- قال مقاتل بن سليمان: <q>﴿قالوا بل﴾</q> قال جبريل ﵇: قد <q>﴿جئناك﴾</q> يا لوط <q>﴿بما كانوا فيه يمترون﴾</q> يعني: بما كان قومُك بالعذاب يمترون، يعني: يَشُكُّون في العذاب أنّه ليس بنازل بهم في الدنيا، <q>﴿وأتيناك بالحق﴾</q> جِئناك بالصدق، <q>﴿وإنا لصادقون﴾</q> بما تقول: إنّا جئناهم بالعذاب{3}. (ز) ",footnotes:1:أخرجه ابن جرير ١٤/٨٧. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.عزاه السيوطي إلى عبد بن حميد، وابن المنذر.تفسير مقاتل بن سليمان ٢/٤٣٣.
  15,64,""
15,65," <q>﴿فَأَسۡرِ بِأَهۡلِكَ بِقِطۡعࣲ مِّنَ ٱلَّیۡلِ﴾</q> - تفسير ٤٠٤٦٣- قال مقاتل بن سليمان: فقالوا للوط: <q>﴿فأسر بأهلك﴾</q> يعني: امرأته، وابنته ريثا، وزعوثا، <q>﴿بقطع﴾</q> يعني: ببَعْض، وهو السَّحَر <q>﴿من الليل﴾</q>{1}. (ز) ٤٠٤٦٤- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿فأسر بأهلك بقطع من الليل﴾</q>، قال: بعض الليل{2}. (ز) <q>﴿وَٱتَّبِعۡ أَدۡبَـٰرَهُمۡ﴾</q> - تفسير ٤٠٤٦٥- عن قتادة بن دعامة -من طريق مَعْمَر- في قوله: <q>﴿واتبع أدبارهم﴾</q>، قال: أُمِر أن يكون خَلْفَ أهلِه، يَتَّبِعْ أدبارهم في آخرهم إذا مَشَوْا{3}. (٨/٦٣٥) ٤٠٤٦٦- قال مقاتل بن سليمان: <q>﴿واتبع أدبارهم﴾</q>، يعني: سِرْ مِن وراء أهلك، تَسُوقُهم{1}. (ز) ٤٠٤٦٧- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿واتبع أدبارهم﴾</q>: أدبار أهلِه{2}. (ز) <q>﴿وَلَا یَلۡتَفِتۡ مِنكُمۡ أَحَدࣱ﴾</q> - قراءات ٤٠٤٦٨- عن الأعمش: في قراءة عبد الله [بن مسعود]: (ولا يَلْتَفِتَنَّ مِنكُمْ أحَدٌ){6}. (ز) <q>﴿وَلَا یَلۡتَفِتۡ مِنكُمۡ أَحَدࣱ﴾</q> - تفسير الآية ٤٠٤٦٩- عن مجاهد بن جبر -من طريق ابن أبي نَجِيح- <q>﴿ولا يلتفت منكم أحد﴾</q>: لا يلتفت وراءَه أحدٌ، ولا يُعَرِّج{2}٣٦١٧. (ز) ٣٦١٧ ذكر ابنُ عطية (٥/٣٠٦) قول مجاهد، ثم نقل معنًى آخر في معنى الالتفات، فقال: «وقيل: <q>﴿يَلْتَفِتْ﴾</q> معناه: يلوي، مِن قولك: لَفَتُّ الأمر: إذا لويته، ومنه قولهم للقصيدة: لفيتة؛ لأنها مَلْوِيٌّ بعضها على بعض». وذكر في سبب النهي عن الالتفات أنهم «نهوا عن النظر مخافة الغفلة، وتعلق النفس بمن خلف، وقيل: بل لِئَلّا تتفطر قلوبهم مِن معاينة ما جرى على القرية في رفعها وطرحها». ٤٠٤٧٠- قال مقاتل بن سليمان: <q>﴿ولا يلتفت منكم أحد﴾</q> البَتَّة، يقول: ولا ينظر أحدٌ منكم وراءَه{1}. (ز) <q>﴿وَٱمۡضُوا۟ حَیۡثُ تُؤۡمَرُونَ ۝٦٥﴾</q> - تفسير ٤٠٤٧١- قال عبد الله بن عباس، في قوله: <q>﴿وامضوا حيث تؤمرون﴾</q>، يعني: الشام{9}. (ز) ٤٠٤٧٢- عن إسماعيل السُّدِّيّ، في قوله: <q>﴿وامضوا حيث تؤمرون﴾</q>، قال: أخرَجهم اللهُ إلى الشام{10}. (٨/٦٣٥) ٤٠٤٧٣- قال مقاتل، في قوله: <q>﴿وامضوا حيث تؤمرون﴾</q>، يعني: زُغَر{11}. (ز) ٤٠٤٧٤- قال مقاتل بن سليمان: <q>﴿وامضوا حيث تؤمرون﴾</q> إلى الشام{1}. (ز) ",footnotes:1:تفسير مقاتل بن سليمان ٢/٤٣٣.أخرجه ابن جرير ١٤/٨٨.أخرجه عبد الرزاق ١/٣٤٩، وابن جرير ١٤/٨٨. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.تفسير مقاتل بن سليمان ٢/٤٣٣.أخرجه ابن جرير ١٤/٨٨.أخرجه ابن أبي داود في المصاحف ١/٣٢٠. وهي قراءة شاذة.أخرجه ابن جرير ١٤/٨٨.تفسير مقاتل بن سليمان ٢/٤٣٣.تفسير الثعلبي ٥/٣٤٥، وتفسير البغوي ٤/٣٨٦.عزاه السيوطي إلى ابن أبي حاتم.تفسير البغوي ٤/٣٨٦. وزُغَر: قرية بمشارف الشام. معجم البلدان ٣/١٤٢-١٤٣.تفسير مقاتل بن سليمان ٢/٤٣٣.
15,66," <q>﴿وَقَضَیۡنَاۤ إِلَیۡهِ ذَ ٰ⁠لِكَ ٱلۡأَمۡرَ﴾</q> - تفسير ٤٠٤٧٥- قال مقاتل بن سليمان: <q>﴿وقضينا إليه﴾</q> يقول: وعَهِدنا إلى لوط <q>﴿ذلك الأمر﴾</q> يعني: أمر العذاب{1}. (ز) ٤٠٤٧٦- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- <q>﴿وقضينا إليه ذلك الأمر﴾</q>، قال: أوْحَيْنا إليه{2}. (٨/٦٣٥) <q>﴿أَنَّ دَابِرَ هَـٰۤؤُلَاۤءِ مَقۡطُوعࣱ مُّصۡبِحِینَ ۝٦٦﴾</q> - تفسير ٤٠٤٧٧- عن عبد الله بن عباس -من طريق ابن جُرَيْج- في قوله: <q>﴿أنّ دابرَ هؤلاء مقطوع﴾</q> يعني: استِئصال هلاكِهم <q>﴿مصبحين﴾</q>{3}. (٨/٦٣٦) ٤٠٤٧٨- قال مقاتل بن سليمان: <q>﴿أن دابر﴾</q> يعني: أصل هؤلاء القوم <q>﴿مقطوع مصبحين﴾</q> يقول: إذا أصبحوا نَزَل بهم العذاب{1}. (ز) ",footnotes:1:تفسير مقاتل بن سليمان ٢/٤٣٣.أخرجه ابن جرير ١٤/٨٩-٩٠. وعزاه السيوطي إلى ابن أبي حاتم.أخرجه ابن جرير ١٤/٨٩.تفسير مقاتل بن سليمان ٢/٤٣٣.
15,67," <q>﴿وَجَاۤءَ أَهۡلُ ٱلۡمَدِینَةِ یَسۡتَبۡشِرُونَ ۝٦٧﴾</q> - تفسير ٤٠٤٧٩- عن قتادة بن دعامة -من طريق سعيد- <q>﴿وجاء أهل المدينة يستبشرون﴾</q>، قال: اسْتَبْشَروا بأضياف نبيِّ الله لوط -صلى الله عليه- حين نزلوا به، لِما أرادوا أن يأتُوا إليهم مِن المنكر{1}. (٨/٦٣٦) ٤٠٤٨٠- قال مقاتل بن سليمان: <q>﴿وجاء أهل المدينة يستبشرون﴾</q> بدخول الرِّجال منزلَ لوط{2}٣٦١٨. (ز) ٣٦١٨ ذكر ابنُ عطية (٥/٣٠٦-٣٠٧) في معنى: <q>﴿وجاءَ أهْلُ المَدِينَةِ يَسْتَبْشِرُونَ﴾</q> احتمالين: الأول: «أن يرجع إلى وصْفِ أمرٍ جرى قبل إعلام لوط بهلاك أُمَّته، ويدُلُّ على هذا أنّ محاجَّة لوط لقومه في الأضياف تقتضي ضعف مَن لم يعلم إهلاكهم، وأنّ الأضياف ملائكة». الثاني: «أن يكون قوله: <q>﴿وجاءَ أهْلُ المَدِينَةِ﴾</q> بعد علمه بهلاكهم، وكان قولهم ما يأتي مِن المحاورة على جهة التَّهَكُّم عنهم، والإملاء لهم، والتربُّص بهم». ثم رجَّح الاحتمال الأول مستندًا إلى النظائر قائلًا: «والاحتمال الأول عندي أرجح، وهو الظاهر من آيات غير هذه السورة». ",footnotes:1:أخرجه ابن جرير ١٤/٩٠. وعزاه السيوطي إلى ابن أبي حاتم.تفسير مقاتل بن سليمان ٢/٤٣٣.
15,68," <q>﴿قَالَ إِنَّ هَـٰۤؤُلَاۤءِ ضَیۡفِی فَلَا تَفۡضَحُونِ ۝٦٨ وَٱتَّقُوا۟ ٱللَّهَ وَلَا تُخۡزُونِ ۝٦٩﴾</q> - تفسير ٤٠٤٨١- قال مقاتل بن سليمان: ثُمَّ <q>﴿قال﴾</q> لهم لوط: <q>﴿إن هؤلاء ضيفي فلا تفضحون﴾</q> فيهم، ولوط ﵇ يرى أنّهم رجال، <q>﴿واتقوا الله ولا تخزون﴾</q> فيهم{1}. (ز) ",footnotes:1:تفسير مقاتل بن سليمان ٢/٤٣٣.
  15,69,""
15,70," <q>﴿قَالُوۤا۟ أَوَلَمۡ نَنۡهَكَ عَنِ ٱلۡعَـٰلَمِینَ ۝٧٠﴾</q> - تفسير ٤٠٤٨٢- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿أوَلم ننهك عن العالمين﴾</q>، قال: يقولون: أوَلَمْ ننهك أن تُضِيفَ أحدًا، أو تُؤْوِيه؟!{1}. (٨/٦٣٦) ٤٠٤٨٣- قال مقاتل بن سليمان: <q>﴿قالوا أولم ننهك عن العالمين﴾</q> أن تُضِيف منهم أحدًا؛ لأنّ لوطًا كان يُحَذِّرهم؛ لِئَلّا يُؤْتَون في أدبارهم{2}. (ز) ",footnotes:1:أخرجه ابن جرير ١٢/٥٠٣، ١٤/٩٠-٩١. وعزاه السيوطي إلى عَبد بن حُمَيد، وابن المنذر، وابن أبي حاتم.تفسير مقاتل بن سليمان ٢/٤٣٣.
