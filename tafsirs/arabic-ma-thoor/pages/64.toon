quran[7]{c,v,t}:
  3,109,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَلِلَّهِ مَا فِی ٱلسَّمَـٰوَ ٰ⁠تِ وَمَا فِی ٱلۡأَرۡضِۚ وَإِلَى ٱللَّهِ تُرۡجَعُ ٱلۡأُمُورُ ۝١٠٩﴾</span> - قراءات</h3></p><p><div></p><p><p><span class="item-no">١٤١٥١<span class="dash">-</span></span> عن <span class="name-2">يحيى بن وثّاب</span> أنّه قرأ كل شيء في القرآن: ‹وإلى اللهِ تَرْجِعُ الأُمُورُ› بنصب التاء، وكسر الجيم{1}. (٣/٧٢٤)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَلِلَّهِ مَا فِی ٱلسَّمَـٰوَ ٰ⁠تِ وَمَا فِی ٱلۡأَرۡضِۚ وَإِلَى ٱللَّهِ تُرۡجَعُ ٱلۡأُمُورُ ۝١٠٩﴾</span> - تفسير الآية</h3></p><p><div></p><p><p><span class="item-no">١٤١٥٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق الضحاك- قال: ثم قال: يا محمد، لله الخلق كله، السموات كلهن، ومَن فيهن، والأرضون كلهن، ومن فيهن، وما بينهن، مما يعلم ومما لا يعلم{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٤١٥٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ولله ما في السماوات وما في الأرض وإلى الله ترجع الأمور﴾</span>، يعني: تصير أمور العباد إليه في الآخرة{3}. (ز)</p></p><p></div></p></div>",footnotes:1:عزاه السيوطي إلى عَبد بن حُمَيد.</p><p>قرأ ابن عامر وحمزة والكسائي ويعقوب وخلف العاشر بفتح التاء وكسر الجيم حيث وقع في القرآن، وقرأ الباقون بضم التاء وفتح الجيم. انظر: التيسير ص٨٠، والنشر ٢/٢٠٩.|2:أخرجه ابن أبي حاتم ٣/٧٣١.|3:تفسير مقاتل بن سليمان ١/٢٩٤.
  3,110,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿كُنتُمۡ خَیۡرَ أُمَّةٍ أُخۡرِجَتۡ لِلنَّاسِ تَأۡمُرُونَ بِٱلۡمَعۡرُوفِ وَتَنۡهَوۡنَ عَنِ ٱلۡمُنكَرِ وَتُؤۡمِنُونَ بِٱللَّهِۗ وَلَوۡ ءَامَنَ أَهۡلُ ٱلۡكِتَـٰبِ لَكَانَ خَیۡرࣰا لَّهُمۚ﴾</span> - نزول الآية</h3></p><p><div></p><p><p><span class="item-no">١٤١٥٤<span class="dash">-</span></span> عن <span class="name-2">عكرمة</span> مولى ابن عباس -من طريق ابن جُرَيْج- في الآية، قال: نزلت في ابن مسعود، وعمار بن ياسر، وسالم مولى أبي حذيفة، وأبي بن كعب، ومعاذ بن جبل{1}<span class=comment-ref>١٣٤٥</span>. (٣/٧٢٥)</p></p><p></div></p><p><div><span class=comment-ref>١٣٤٥</span> <span class="comment-type-4">علَّق</span> <u>ابن عطية</u> (٢/٣١٦) على هذا الأثر بقوله: «يريد: ومَن شاكلهم».</div></p><p><div></p><p><p><span class="item-no">١٤١٥٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: قوله سبحانه: <span class="qpc-hafs">﴿كنتم خير أمة أخرجت للناس﴾</span>، يعني: خير الناس للناس، وذلك أنّ مالك بن الضَّيف، ووهب بن يهوذا قالا لعبد الله بن مسعود، ومعاذ بن جبل، وسالم مولى أبى حذيفة: إنّ ديننا خير مما تدعونا إليه. فأنزل الله ﷿ فيهم: <span class="qpc-hafs">﴿كنتم خير أمة أخرجت للناس﴾</span>{2}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿كُنتُمۡ خَیۡرَ أُمَّةٍ أُخۡرِجَتۡ لِلنَّاسِ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">١٤١٥٦<span class="dash">-</span></span> عن معاوية بن حَيْدَة، أنه سمع النبي ﷺ، في قوله: <span class="qpc-hafs">﴿كنتم خير أمة أخرجت للناس﴾</span> قال: «<b>إنكم تُتِمُّون سبعين أمة، أنتم خيرها وأكرمها على الله</b>»{3}. (٣/٧٢٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٤١٥٧<span class="dash">-</span></span> عن قتادة بن دِعامة، قال: ذُكِر لنا: أن <span class="name-1">عمر بن الخطاب</span> قرأ هذه الآية: <span class="qpc-hafs">﴿كنتم خير أمة أخرجت للناس﴾</span> الآية، ثم قال: يا أيها الناس، مَن سَرَّه أن يكون مِن تلكم الأمة فلْيُؤَدِّ شرط الله منها{4}. (٣/٧٢٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٤١٥٨<span class="dash">-</span></span> عن إسماعيل السدي، في الآية، قال: قال <span class="name-1">عمر بن الخطاب</span>: لو شاء الله لقال: أنتم؛ فكنا كلنا، ولكن قال: <span class="qpc-hafs">﴿كنتم﴾</span> في خاصة أصحاب محمد، ومن صنع مثل صنيعهم كانوا <span class="qpc-hafs">﴿خير أمة أخرجت للناس﴾</span>{5}. (٣/٧٢٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٤١٥٩<span class="dash">-</span></span> عن <span class="name-1">عمر بن الخطاب</span> -من طريق السدي، عمَّن حَدَّثه- في قوله: <span class="qpc-hafs">﴿كنتم خير أمة﴾</span>، قال: تكون لأولنا، ولا تكون لآخرنا{6}<span class=comment-ref>١٣٤٦</span>. (٣/٧٢٥)</p></p><p></div></p><p><div><span class=comment-ref>١٣٤٦</span> <span class="comment-type-1">وجَّه</span> <u>ابن عطية</u> (٢/٣١٦) قول عكرمة، وعمر بن الخطاب من طريق السدي، وابن عباس من طريق سعيد بن جبير، بقوله: «فهذا كلّه قولٌ واحد، مقتضاه أنّ الآية نزلت في الصحابة، قيل لهم: كنتم خير أمة، فالإشارة بقوله: <span class="qpc-hafs">﴿أُمَّةً﴾</span> إلى أمة محمد معينة، فإن هؤلاء هم خيرها».</div></p><p><div></p><p><p><span class="item-no">١٤١٦٠<span class="dash">-</span></span> عن <span class="name-1">أبي بن كعب</span> -من طريق أبي العالية- قال: لم تكن أمةٌ أكثرَ استجابة في الإسلام مِن هذه الأمة، فمِن ثَمَّ قال: <span class="qpc-hafs">﴿كنتم خير أمة أخرجت للناس﴾</span>{7}. (٣/٧٢٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٤١٦١<span class="dash">-</span></span> عن <span class="name-1">أبي هريرة</span> -من طريق أبي حازم- في قوله: <span class="qpc-hafs">﴿كنتم خير أمة أخرجت للناس﴾</span>، قال: خير الناس للناس، تأتون بهم في السلاسل في أعناقهم حتى يدخلوا في الإسلام{8}. (٣/٧٢٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٤١٦٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>-من طريق عكرمة- <span class="qpc-hafs">﴿كنتم خير أمة أخرجت للناس﴾</span>، قال: خير الناس للناس{9}. (٣/٧٢٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٤١٦٣<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق سعيد بن جبير- في قوله: <span class="qpc-hafs">﴿كنتم خير أمة أخرجت للناس﴾</span>، قال: هم الذين هاجروا مع رسول الله ﷺ إلى المدينة{10}. (٣/٧٢٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٤١٦٤<span class="dash">-</span></span> وعن <span class="name-2">سعيد بن جبير</span>، نحو ذلك{11}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٤١٦٥<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span> -من طريق ثابت- في قوله ﷿: <span class="qpc-hafs">﴿كنتم خير أمة أخرجت للناس﴾</span>، قال: خيرُ الناس للناس{12}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٤١٦٦<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نَجيح- قال: خير الناس للناس{13}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٤١٦٧<span class="dash">-</span></span> عن <span class="name-2">الضحاك بن مزاحم</span> -من طريق جويبر- في قوله: <span class="qpc-hafs">﴿كنتم خير أمة أخرجت للناس﴾</span>، قال: هم أصحاب رسول الله ﷺ خاصة، يعني: وكانوا هم الرواة الدُّعاة الذين أمر الله المسلمين بطاعتهم{14}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٤١٦٨<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span> -من طريق خُصَيْف- في الآية، قال: لم تكن أمةٌ دخل فيها مِن أصناف الناس غير هذه الأمة{7}. (٣/٧٢٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٤١٦٩<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span> -من طريق يزيد النحوي- <span class="qpc-hafs">﴿كنتم خير أمة أخرجت للناس﴾</span>، قال: خير الناس للناس،كان قبلكم لا يأمن هذا في بلاد هذا، ولا هذا في بلاد هذا، فكلما كنتم أمِنَ فيكم الأحمر والأسود، وأنتم خير الناس للناس{16}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٤١٧٠<span class="dash">-</span></span> قال <span class="name-2">الحسن البصري</span>، في قول الله: <span class="qpc-hafs">﴿كنتم خير أمة أخرجت للناس﴾</span>، قال: كنتم خير الناس للناس{17}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٤١٧١<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق عباد- في قوله: <span class="qpc-hafs">﴿كنتم خير أمة أخرجت للناس تأمرون بالمعروف وتنهون عن المنكر﴾</span>، قال: قد كان ما تسمع مِن الخير في هذه الأمة{18}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٤١٧٢<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق قتادة- أنّه كان يقول: نحن آخرها، وأكرمها على الله{18}<span class=comment-ref>١٣٤٧</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>١٣٤٧</span> <span class="comment-type-3">رجَّح</span> <u>ابن جرير</u> (٥/٦٧٥) <span class="mustanad">مستندًا إلى السنة،</span> و<u>ابن عطية</u> (٢/٣١٧) <span class="mustanad">مستندًا إلى القرآن، والسنة،</span> قول الحسن من طريق عباد، ومن طريق قتادة، بأن <span class="qpc-hafs">﴿كُنْتُمْ خَيْرَ أُمَّةٍ أُخْرِجَتْ لِلنّاسِ﴾</span>: خطاب للأمة بأنهم خير أمة أخرجت للناس، فذكر <u>ابن جرير</u> بسنده: عن بَهْز بن حكيم، عن أبيه، عن جده، قال: سمعت رسول الله ﷺ يقول: «ألا إنكم وفَّيتم سبعين أمة، أنتم خيرها وأكرمها على الله». وزاد عليه ابن عطية استدلاله بقوله تعالى: <span class="qpc-hafs">﴿وكَذَلِكَ جَعَلْناكُمْ أُمَّةً وسَطًا لِتَكُونُوا شُهَداءَ عَلى النّاسِ﴾</span> [البقرة:١٤٣]، وبقوله ﷺ: «نحن الآخرون السابقون» الحديث.</p><p>وكذا <span class="comment-type-3">رجَّح</span> <u>ابن كثير</u> (٣/١٤٢) <span class="mustanad">مستندًا إلى دلالة العموم، والنظائر،</span> بأن الآية عامة في جميع الأمة، فقال: "والصحيح أن هذه الآية عامة في جميع الأمة، كل قرن بحسبه، وخير قرونهم الذين بعث فيهم رسول الله ﷺ، ثم الذين يلونهم، ثم الذين يلونهم، كما قال في الآية الأخرى: <span class="qpc-hafs">﴿وكَذَلِكَ جَعَلْناكُمْ أُمَّةً وسَطًا﴾</span>، أي: خيارًا، <span class="qpc-hafs">﴿لِتَكُونُوا شُهَداءَ عَلى النّاسِ ويَكُونَ الرَّسُولُ عَلَيْكُمْ شَهِيدًا﴾</span> [البقرة:١٤٣]».</p><p><span class="comment-type-1">ووجَّه</span> <u>ابن عطية</u> (٢/٣١٦) قول الحسن من طريق عباد، فقال: «فلفظ <span class="qpc-hafs">﴿أمة﴾</span> على هذا التأويل اسم جنس، كأنه قيل لهم: كنتم خير الأمم».</div></p><p><div></p><p><p><span class="item-no">١٤١٧٣<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق سفيان بن حسين- أنّه قرأ: <span class="qpc-hafs">﴿كنتم خير أمة أخرجت للناس﴾</span>، فقال: هم الذين مَضَوْا من صدر هذه الأمة، يعني: أصحاب النبي ﷺ، قد كان الرجل منهم يلقى أخاه، فيقول: أبشر، أليس أنت كُنتِيًّا{20}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٤١٧٤<span class="dash">-</span></span> عن <span class="name-2">أبي جعفر [محمد بن علي بن الحسين]</span> -من طريق جابر- <span class="qpc-hafs">﴿كنتم خير أمة أخرجت للناس﴾</span>، قال: خير أهل بيت النبي ﷺ{7}. (٣/٧٢٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٤١٧٥<span class="dash">-</span></span> عن <span class="name-2">عطية العوفي</span> -من طريق عيسى بن موسى- في الآية، قال: خير الناس للناس، شهدتم للنبيين الذين كَفَر بهم قومُهم بالبلاغ{22}. (٣/٧٢٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٤١٧٦<span class="dash">-</span></span> عن <span class="name-2">عطاء</span>: خير الناس للناس{13}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٤١٧٧<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span>: هم أُمة محمد ﷺ، لم يؤمر نبي قبله بالقتال، فهم يقاتلون الكفار فيدخلونهم في دينهم، فهم خير أُمة للناس{24}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٤١٧٨<span class="dash">-</span></span> عن <span class="name-2">الربيع بن أنس</span> -من طريق أبي جعفر- قوله: <span class="qpc-hafs">﴿كنتم خير أمة أخرجت للناس تأمرون بالمعروف وتنهون عن المنكر﴾</span>، قال: لم تكن أمة أكثر استجابة في الإسلام من هذه الأمة، فمِن ثَمَّ قال: <span class="qpc-hafs">﴿كنتم خير أمة أخرجت للناس﴾</span>{25}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٤١٧٩<span class="dash">-</span></span> قال <span class="name-2">الربيع بن أنس</span>: خير الناس للناس{13}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٤١٨٠<span class="dash">-</span></span> قال <span class="name-3">محمد بن السائب الكلبي</span> -من طريق مَعْمَر- في قوله: <span class="qpc-hafs">﴿كنتم خير أمة﴾</span>، قال: أنتم خير الناس للناس{27}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٤١٨١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: يعنى: خير الناس للناس، ... <span class="qpc-hafs">﴿كنتم خير أمة أخرجت للناس﴾</span> في زمانكم، كما فَضَّل بني إسرائيل في زمانهم{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٤١٨٢<span class="dash">-</span></span> عن <span class="name-3">مقاتل بن حيان</span>: ليس خلق مِن أهل الأديان إلا قالوا: ليس علينا جناح فيما نصيب من غيرنا من أهل الأديان، ولا يأمرون مَن سواهم بالخير، وهذه الأمة يأمرون كل أهل دين وأنفسهم، لا يظلم بعضهم بعضًا، بل يأمرونهم بالمعروف، وينهونهم عن المنكر؛ فأُمة محمد ﷺ خير الأُمم للناس{29}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿تَأۡمُرُونَ بِٱلۡمَعۡرُوفِ وَتَنۡهَوۡنَ عَنِ ٱلۡمُنكَرِ وَتُؤۡمِنُونَ بِٱللَّهِۗ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">١٤١٨٣<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي بن أبي طلحة- في قوله: <span class="qpc-hafs">﴿كنتم خير أمة أخرجت للناس تأمرون بالمعروف﴾</span>، يقول: تأمرونهم أن يشهدوا أن لا إله إلا الله، والإقرار بما أنزل الله، وتقاتلونهم عليه، ولا إله إلا الله هو أعظم المعروف، وتنهونهم عن المنكر، والمنكر هو التكذيب، وهو أنكر المنكر{30}. (٣/٧٢٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٤١٨٤<span class="dash">-</span></span> عن <span class="name-2">أبي العالية الرِّياحِيّ</span> -من طريق الربيع بن أنس- في قوله: <span class="qpc-hafs">﴿تأمرون بالمعروف﴾</span> قال: بالتوحيد، <span class="qpc-hafs">﴿وتنهون عن المنكر﴾</span> قال: عن الشرك{31}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٤١٨٥<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span> -من طريق عطاء- قوله: <span class="qpc-hafs">﴿وتؤمنون بالله﴾</span>، يعني: تصدقون توحيد الله{32}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٤١٨٦<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نَجِيح- في قوله: <span class="qpc-hafs">﴿كنتم خير أمة أخرجت للناس﴾</span>، يقول: على هذا الشرط، أن تأمروا بالمعروف، وتنهوا عن المنكر، وتؤمنوا بالله، يقول: لمن أنتم بين ظهرانيه، كقوله: <span class="qpc-hafs">﴿ولقد اخترناهم على علم على العالمين﴾</span> [الدخان:٣٢]{33}. (٣/٧٢٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٤١٨٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: قوله: <span class="qpc-hafs">﴿تأمرون﴾</span> الناس <span class="qpc-hafs">﴿بالمعروف﴾</span> يعني: بالإيمان، <span class="qpc-hafs">﴿وتنهون عن المنكر وتؤمنون﴾</span> بتوحيد الله، وتنهونهم عن الظلم، وأنتم خير الناس للناس، وغيركم من أهل الأديان لا يأمرون أنفسهم ولا غيرهم بالمعروف، ولا ينهونهم عن المنكر{2}<span class=comment-ref>١٣٤٨</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>١٣٤٨</span> <span class="comment-type-4">ذكر</span> <u>ابنُ عطية</u> (٢/٣١٨) أن قوله تعالى: <span class="qpc-hafs">﴿كُنْتُم﴾</span> «على صيغة الماضي، فإنها التي بمعنى الدوام، <span class="mustanad">كما قال</span>: <span class="qpc-hafs">﴿وكانَ اللهُ غَفُورًا رَحِيمًا﴾</span>، إلى غير هذا من الأمثلة». ثم نقل ثلاثة أقوال أخرى: <b>الأول:</b> «كنتم في علم الله». <b>الثاني:</b> «في اللوح المحفوظ». <b>الثالث:</b> «فيما أخبر به الأمم قديمًا عنكم».</div></p><p><h3><span class="qpc-hafs">﴿وَلَوۡ ءَامَنَ أَهۡلُ ٱلۡكِتَـٰبِ لَكَانَ خَیۡرࣰا لَّهُمۚ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">١٤١٨٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق أبي رَوْق، عن الضحاك- قوله: <span class="qpc-hafs">﴿آمن﴾</span>، قال: صدق{32}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٤١٨٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ولو آمن﴾</span> يعني: ولو صدق <span class="qpc-hafs">﴿أهل الكتاب﴾</span> يعني: اليهود بمحمد ﷺ، وما جاء به من الحق، <span class="qpc-hafs">﴿لكان خيرا لهم﴾</span> مِن الكفر{2}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿مِّنۡهُمُ ٱلۡمُؤۡمِنُونَ وَأَكۡثَرُهُمُ ٱلۡفَـٰسِقُونَ ۝١١٠﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">١٤١٩٠<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span> -من طريق عطاء- في قول الله تعالى: <span class="qpc-hafs">﴿الفاسقون﴾</span>، يعني: هم العاصون{32}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٤١٩١<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دِعامة</span> -من طريق شَيْبان- في قوله: <span class="qpc-hafs">﴿منهم المؤمنون﴾</span>، قال: استثنى الله منهم ثلاثة كانوا على الهدى والحق{32}. (٣/٧٢٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٤١٩٢<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دِعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿وأكثرهم الفاسقون﴾</span>، قال: ذَمَّ الله أكثرَ الناس{39}. (٣/٧٢٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٤١٩٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿منهم المؤمنون﴾</span> يعني: عبد الله بن سلام وأصحابه، <span class="qpc-hafs">﴿وأكثرهم الفاسقون﴾</span> يعني: العاصين، يعني: اليهود{2}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿مِّنۡهُمُ ٱلۡمُؤۡمِنُونَ وَأَكۡثَرُهُمُ ٱلۡفَـٰسِقُونَ ۝١١٠﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">١٤١٩٤<span class="dash">-</span></span> عن علي بن أبي طالب، قال: قال رسول الله ﷺ: «<b>أُعْطِيت ما لم يُعْطَ أحد من الأنبياء: نُصِرت بالرعب، وأُعْطِيت مفاتيح الأرض، وسُمِّيت أحمد، وجُعِل التراب لي طهورًا، وجُعِلَت أمتي خير الأمم»</b>{41}. (٣/٧٢٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٤١٩٥<span class="dash">-</span></span> عن قتادة بن دِعامة، قال: ذُكِرَ لنا: أن نبي الله ﷺ قال ذات يوم وهو مسند ظهره إلى الكعبة: «<b>نحن نكمل يوم القيامة سبعين أمة، نحن آخرها وخيرها</b>»{42}. (٣/٧٢٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٤١٩٦<span class="dash">-</span></span> عن الحسن البصري -من طريق أبي الأشهب- قال رسول الله ﷺ: «<b>أنتم توفون سبعين أمة، أنتم خيرها وأكرمها على الله</b>»{43}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٤١٩٧<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق مبارك- قال: قال رجل: أعوذ بالله أن أكون كُنتِيًّا. قيل له: ما الكنتي؟ قال: تقول: لقد كنت مرة وكنت. وقرأ الحسن: <span class="qpc-hafs">﴿كنتم خير أمة أخرجت للناس﴾</span>{44}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ٥/٦٧٢، وابن المنذر (٨٠٢).|2:تفسير مقاتل بن سليمان ١/٢٩٥.|3:أخرجه عبد الرزاق ١/١٣٠، وعَبد بن حُمَيد (٤٠٩ - منتخب)، وأحمد ٣٣/٢٢٨، والترمذي (٣٠٠١)، وابن ماجه(٤٢٨٧)، وابن جَرِير ٥/٦٧٦،٦٧٥، وابن المنذر ٧٩٧، وابن أبي حاتم ٣/٧٣١، والطبراني ١٩/٤٢٢، والحاكم ٤/٨٤. وعزاه السيوطي إلى ابن مردويه.</p><p>حَسَّنه الترمذي، وصححه الحاكم، وقال الألباني في صحيح سنن ابن ماجه (٣٤٦٠): «حسن».|4:أخرجه ابن جرير ٥/٦٧٢-٦٧٣.|5:أخرجه ابن جرير ٥/٦٧١-٦٧٢، وابن أبي حاتم ٣/٧٣٢.|6:أخرجه ابن جرير ٥/٦٧٢، وابن أبي حاتم ٣/٧٣٢.|7:أخرجه ابن أبي حاتم ٣/٧٣٣.|8:أخرجه البخاري (٤٥٥٧)، والنسائي في الكبرى (١١٠٧١)، وابن جرير ٥/٦٧٤، وابن المنذر (٨٠٣)، وابن أبي حاتم ٣/٧٣٢، والحاكم ٤/٨٤. وعزاه السيوطي إلى الفريابي، وعبد بن حميد.|9:أخرجه ابن المنذر (٧٩٩).|10:أخرجه عبد الرزاق ١/١٣٠، وابن أبي شيبة ١٢/١٥٥، وأحمد ٤/٢٧٢، والنسائي في الكبرى (١١٠٧٢)، وابن جرير ٥/٦٧١، ٦٧٢، وابن المنذر (٨٠١)، وابن أبي حاتم ٣/٧٣٢، والحاكم ٢/٢٩٤. وعزاه السيوطي إلى عبد بن حميد، والفريابي.|11:علَّقه ابن أبي حاتم ٣/٧٣٢.|12:أخرجه ابن عدي في الكامل ٦/٢١٤. وعلَّقه ابن المنذر ١/٣٣١.|13:علَّقه ابن أبي حاتم ٣/٧٣٢-٧٣٣.|14:أخرجه ابن جرير ٥/٦٧٣.|15:أخرجه ابن أبي حاتم ٣/٧٣٣.|16:أخرجه ابن أبي حاتم ٣/٧٣٢-٧٣٣.|17:علَّقه ابن وهْب في الجامع ٢/٤٩ (٨٧).|18:أخرجه ابن جرير ٥/٦٧٥.|19:أخرجه ابن جرير ٥/٦٧٥.|20:أخرجه ابن المنذر ١/٣٣٣.|21:أخرجه ابن أبي حاتم ٣/٧٣٣.|22:أخرجه ابن أبي حاتم ٣/٧٣٣، وابن جرير ٥/٦٧٤ مختصرًا من طريق فضيل بن مرزوق. وعزاه السيوطي إلى عبد بن حميد.|23:علَّقه ابن أبي حاتم ٣/٧٣٢-٧٣٣.|24:تفسير البغوي ٤/٩٠، وتفسير الثعلبي ٣/١٢٧.|25:أخرجه ابن جرير ٥/٦٧٤.|26:علَّقه ابن أبي حاتم ٣/٧٣٢-٧٣٣.|27:أخرجه عبد الرزاق في تفسيره ١/١٣٠، وابن المنذر ١/٣٣٠.|28:تفسير مقاتل بن سليمان ١/٢٩٥.|29:تفسير الثعلبي ٣/١٢٧.|30:أخرجه ابن جرير ٥/٦٧٦، وابن المنذر (٨٠٧)، وابن أبي حاتم ٣/٧٣٣-٧٣٤، والبيهقي في الأسماء والصفات (٢٠٦).|31:أخرجه آدم ابن أبي إياس -كما في تفسير مجاهد ص٢٥٧-. وعلَّق ابن أبي حاتم ٣/٧٣٣ أولَه.|32:أخرجه ابن أبي حاتم ٣/٧٣٤.|33:أخرجه ابن جرير ٥/٦٧٣، وابن المنذر (٨٠٨) مختصرًا. وعزاه السيوطي إلى عبد بن حميد.|34:تفسير مقاتل بن سليمان ١/٢٩٥.|35:أخرجه ابن أبي حاتم ٣/٧٣٤.|36:تفسير مقاتل بن سليمان ١/٢٩٥.|37:أخرجه ابن أبي حاتم ٣/٧٣٤.|38:أخرجه ابن أبي حاتم ٣/٧٣٤.|39:أخرجه ابن أبي حاتم ٣/٧٣٤. وعزاه السيوطي إلى عبد بن حميد.|40:تفسير مقاتل بن سليمان ١/٢٩٥.|41:أخرجه أحمد ٢/١٥٦.</p><p>قال محققو المسند: «بسند حسن».|42:أخرجه ابن جرير ٥/٦٧٦.|43:تفسير ابن أبي زمنين ١/٣١٢.|44:أخرجه ابن المنذر ١/٣٣٠.
  3,111,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿لَن یَضُرُّوكُمۡ إِلَّاۤ أَذࣰىۖ وَإِن یُقَـٰتِلُوكُمۡ یُوَلُّوكُمُ ٱلۡأَدۡبَارَ ثُمَّ لَا یُنصَرُونَ ۝١١١ ضُرِبَتۡ عَلَیۡهِمُ ٱلذِّلَّةُ أَیۡنَ مَا ثُقِفُوۤا۟ إِلَّا بِحَبۡلࣲ مِّنَ ٱللَّهِ وَحَبۡلࣲ مِّنَ ٱلنَّاسِ وَبَاۤءُو بِغَضَبࣲ مِّنَ ٱللَّهِ وَضُرِبَتۡ عَلَیۡهِمُ ٱلۡمَسۡكَنَةُۚ ذَ ٰ⁠لِكَ بِأَنَّهُمۡ كَانُوا۟ یَكۡفُرُونَ بِـَٔایَـٰتِ ٱللَّهِ وَیَقۡتُلُونَ ٱلۡأَنۢبِیَاۤءَ بِغَیۡرِ حَقࣲّۚ ذَ ٰ⁠لِكَ بِمَا عَصَوا۟ وَّكَانُوا۟ یَعۡتَدُونَ ۝١١٢﴾</span> - نزول الآية</h3></p><p><div></p><p><p><span class="item-no">١٤١٩٨<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿لن يضروكم إلا أذى﴾</span>، وذلك أن رؤساء اليهود: كعب بن مالك، وشعبة، وبَحْرِيّ، ونعمان، وأبا ياسر، وأبا نافع، وكنانة بن أبى الحُقَيْق، وابن صُورِيا، عمدوا إلى مؤمنيهم فآذوهم لإسلامهم، وهم عبدالله بن سلام وأصحابه، فأنزل الله ﷿: <span class="qpc-hafs">﴿لن يضروكم إلا أذى وإن يقاتلوكم يولوكم الأدبار ثم لا ينصرون﴾</span>{1}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿لَن یَضُرُّوكُمۡ إِلَّاۤ أَذࣰىۖ وَإِن یُقَـٰتِلُوكُمۡ یُوَلُّوكُمُ ٱلۡأَدۡبَارَ ثُمَّ لَا یُنصَرُونَ ۝١١١﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">١٤١٩٩<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق عباد بن منصور- <span class="qpc-hafs">﴿لن يضروكم إلا أذى﴾</span>، قال: تسمعون منهم كَذِبًا على الله، يدعونكم إلى الضلالة{2}. (٣/٧٢٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٤٢٠٠<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دِعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿لن يضروكم إلا أذى﴾</span>، قال: تسمعونه منهم{3}. (٣/٧٢٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٤٢٠١<span class="dash">-</span></span> عن <span class="name-2">الربيع بن أنس</span> -من طريق أبي جعفر- قوله: <span class="qpc-hafs">﴿لن يضروكم إلا أذى﴾</span>، قال: أذًى تسمعونه منهم{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٤٢٠٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿لن يضروكم﴾</span> اليهود <span class="qpc-hafs">﴿إلا أذى﴾</span> باللسان{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٤٢٠٣<span class="dash">-</span></span> عن <span class="name-3">عبد الملك ابن جريج</span> -من طريق حَجّاج- <span class="qpc-hafs">﴿لن يضروكم إلا أذى﴾</span>، قال: إشراكهم في عُزَيْر، وعيسى، والصليب{6}. (٣/٧٢٩)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿ضُرِبَتۡ عَلَیۡهِمُ ٱلذِّلَّةُ أَیۡنَ مَا ثُقِفُوۤا۟﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">١٤٢٠٤<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق الضحاك- في قوله: <span class="qpc-hafs">﴿ضربت عليهم الذلة﴾</span>، قال: هم أصحاب القَبالات{7}. (٣/٧٢٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٤٢٠٥<span class="dash">-</span></span> عن <span class="name-2">الضحاك بن مزاحم</span> -من طريق جويبر- <span class="qpc-hafs">﴿ضربت عليهم الذلة﴾</span>، قال: الجزية{8}. (٣/٧٣٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٤٢٠٦<span class="dash">-</span></span> عن عباد بن منصور، قال: سألت <span class="name-2">الحسن البصري</span> عن قوله: <span class="qpc-hafs">﴿ضربت عليهم الذلة﴾</span>. قال: أذلهم الله فلا مَنَعَة لهم، وجعلهم الله تحت أقدام المسلمين{9}. (٣/٧٢٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٤٢٠٧<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق عوف- قال: أدركتهم هذه الأمة وإنّ المجوس لتجبيهم الجزية{10}. (٣/٧٢٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٤٢٠٨<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٤٢٠٩<span class="dash">-</span></span> و<span class="name-2">قتادة بن دِعامة</span> -من طريق مَعْمَر- في قوله: <span class="qpc-hafs">﴿ضربت عليهم الذلة﴾</span>، قال: يُعْطُون الجِزْيَة عن يد وهم صاغرون{11}. (٣/٧٢٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٤٢١٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثم أخبر عن اليهود، فقال سبحانه: <span class="qpc-hafs">﴿ضربت عليهم الذلة﴾</span> يعني: المَذَلَّة، <span class="qpc-hafs">﴿أين ما ثقفوا﴾</span> يعني: وُجِدوا{12}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿إِلَّا بِحَبۡلࣲ مِّنَ ٱللَّهِ وَحَبۡلࣲ مِّنَ ٱلنَّاسِ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">١٤٢١١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق هارون بن عنترة، عن أبيه- <span class="qpc-hafs">﴿إلا بحبل من الله وحبل من الناس﴾</span>، قال: بعهد من الله، وعهد من الناس{13}. (٣/٧٣٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٤٢١٢<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نَجِيح- في قوله -جلَّ وعزَّ-: <span class="qpc-hafs">﴿إلا بحبل من الله﴾</span> قال: بعهد، <span class="qpc-hafs">﴿وحبل من الناس﴾</span> قال: بعهدهم{14}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٤٢١٣<span class="dash">-</span></span> عن <span class="name-2">الضحاك بن مزاحم</span> -من طريق عبيد بن سليمان- في قوله: <span class="qpc-hafs">﴿إلا بحبل من الله وحبل من الناس﴾</span>، يقول: بعهد من الله، وعهد من الناس{15}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٤٢١٤<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span> -من طريق عثمان بن غياث- يقول: <span class="qpc-hafs">﴿إلا بحبل من الله وحبل من الناس﴾</span>، قال: بعهد من الله، وعهد من الناس{16}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٤٢١٥<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span>، قال: عهد مِن الله، وعهد مِن الناس{17}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٤٢١٦<span class="dash">-</span></span> عن <span class="name-2">عطاء [بن أبي رباح]</span> -من طريق ابن جريج-: العهد: حبل الله{18}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٤٢١٧<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿إلا بحبل من الله وحبل من الناس﴾</span>، يقول: إلا بعهد من الله، وعهد من الناس{19}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٤٢١٨<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- <span class="qpc-hafs">﴿إلا بحبل من الله وحبل من الناس﴾</span>، يقول: إلا بعهد من الله، وعهد من الناس{20}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٤٢١٩<span class="dash">-</span></span> عن <span class="name-2">عطاء الخراساني</span> -من طريق يونس بن يزيد- في قول الله ﷿: <span class="qpc-hafs">﴿بحبل من الله وحبل من الناس﴾</span>، قال: عهد من الله، وعهد من الناس{21}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٤٢٢٠<span class="dash">-</span></span> عن <span class="name-2">الربيع بن أنس</span> -من طريق أبي جعفر- قوله: <span class="qpc-hafs">﴿إلا بحبل من الله وحبل من الناس﴾</span>، يقول: إلا بعهد من الله، وعهد من الناس{18}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٤٢٢١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿إلا بحبل من الله وحبل من الناس﴾</span>، يقول: لا يأمنوا حيث ما تَوَجَّهُوا إلا بعهد من الله، وعهد من الناس، يعني: النبي ﷺ وحده{12}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٤٢٢٢<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿أينما ثقفوا إلا بحبل من الله وحبل من الناس﴾</span>، قال: إلا بعهد، وهم يهود. قال: والحبل: العهد. قال: وذلك قول أبي الهيثم بن التَيِّهان لرسول الله ﷺ حين أتته الأنصار في العقبة: أيها الرجل، إنا قاطعون فيك حبالًا بيننا وبين الناس. يقول: عهودًا. قال: واليهود لا يأمنون في أرض من أرض الله إلا بهذا الحبل الذي لله قال ﷿، وقرأ: <span class="qpc-hafs">﴿وجاعل الذين اتبعوك فوق الذين كفروا إلى يوم القيامة﴾</span> [آل عمران: ٥٥]، قال: فليس بلد فيه أحد من النصارى إلا وهم فوق يهود في شرق ولا غرب، هم في البلدان كلها مستذلون، قال الله: <span class="qpc-hafs">﴿وقطعناهم في الأرض أمما﴾</span> [الأعراف: ١٦٨] قال: يهود{24}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٤٢٢٣<span class="dash">-</span></span> عن علي بن خلف قال: سمعت <span class="name-3">سفيان بن عيينة</span> يفسر حبل الله، قال: عهد الله. وقرأ: <span class="qpc-hafs">﴿إلا بحبل من الله وحبل من الناس﴾</span>، قال: إلا بعهد من الله، وعهد من الناس{25}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَبَاۤءُو بِغَضَبࣲ مِّنَ ٱللَّهِ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">١٤٢٢٤<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span> -من طريق عطاء بن دينار- في قول الله تعالى: <span class="qpc-hafs">﴿وباءوا بغضب من الله﴾</span>، يقول: استوجبوا سخطه{26}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٤٢٢٥<span class="dash">-</span></span> عن <span class="name-2">الضحاك بن مُزاحِم</span> -من طريق جويبر- <span class="qpc-hafs">﴿وباءوا بغضب من الله﴾</span>، قال: اسْتَحَقُّوا الغضب مِن الله{27}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٤٢٢٦<span class="dash">-</span></span> عن <span class="name-2">الربيع بن أنس</span> -من طريق أبي جعفر- <span class="qpc-hafs">﴿وباؤوا بغضب من الله﴾</span>: فحَدَثَ عليهم من الله غضب{26}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٤٢٢٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وباءوا بغضب من الله﴾</span>، يعني: استوجبوا الغضب من الله{12}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَضُرِبَتۡ عَلَیۡهِمُ ٱلۡمَسۡكَنَةُۚ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">١٤٢٢٨<span class="dash">-</span></span> عن <span class="name-2">أبي العالية الرِّياحِيّ</span> -من طريق الربيع- قوله: <span class="qpc-hafs">﴿وضربت عليهم المسكنة﴾</span>، قال: المسكنة: الفاقة{26}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٤٢٢٩<span class="dash">-</span></span> وعن <span class="name-2">إسماعيل السُّدِّيّ</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٤٢٣٠<span class="dash">-</span></span> و<span class="name-2">الربيع بن أنس</span>، نحو ذلك{31}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٤٢٣١<span class="dash">-</span></span> عن <span class="name-2">الضحاك بن مزاحم</span> -من طريق جويبر- <span class="qpc-hafs">﴿المسكنة﴾</span>، قال: الجزية{26}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٤٢٣٢<span class="dash">-</span></span> عن <span class="name-2">عطية العوفي</span> -من طريق عبيد بن الطفيل- قوله: <span class="qpc-hafs">﴿وضربت عليهم المسكنة﴾</span>، قال: الخَراج{26}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٤٢٣٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وضربت عليهم﴾</span> الذلة و<span class="qpc-hafs">﴿المسكنة﴾</span>، يعني: الذل والفقر{34}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿ذَ ٰ⁠لِكَ بِأَنَّهُمۡ كَانُوا۟ یَكۡفُرُونَ بِـَٔایَـٰتِ ٱللَّهِ وَیَقۡتُلُونَ ٱلۡأَنۢبِیَاۤءَ بِغَیۡرِ حَقࣲّۚ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">١٤٢٣٤<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن مسعود</span> –من طريق أبي مَعْمَر الأزْدِي- قال: كانت بنو إسرائيل تقتل في اليوم ثلاثمائة نبي، ثم يقوم سوق بَقْلِهم من آخر النهار{26}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٤٢٣٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ذلك﴾</span> الذي نزل بهم <span class="qpc-hafs">﴿بأنهم كانوا يكفرون بآيات الله ويقتلون الأنبياء بغير حق﴾</span>{36} <span class=comment-ref>١٣٤٩</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>١٣٤٩</span> ذكر <u>ابنُ عطية</u> (٢/٣٢١-٣٢٢) أن قوله تعالى: <span class="qpc-hafs">﴿بآيات الله﴾</span> يحتمل معنيين: <b>الأول:</b> «أن يراد بها: المتلوّة». <b>والثاني:</b> «أن يريد: العِبَر التي عرضت عليهم».</div></p><p><h3><span class="qpc-hafs">﴿ذَ ٰ⁠لِكَ بِمَا عَصَوا۟ وَّكَانُوا۟ یَعۡتَدُونَ ۝١١٢﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">١٤٢٣٦<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دِعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿ذلك بما عصوا وكانوا يعتدون﴾</span>، قال: اجتَنِبوا المعصية والعدوان، فإن بهما أُهْلِك من أُهْلِك من قبلكم من الناس{37}<span class=comment-ref>١٣٥٠</span>. (٣/٧٣٠)</p></p><p></div></p><p><div><span class=comment-ref>١٣٥٠</span> يرى <u>ابنُ جرير</u> (٥/٦٨٨-٦٨٩) بأن اسم الإشارة <span class="qpc-hafs">﴿ذلك﴾</span> في قوله تعالى: <span class="qpc-hafs">﴿ذَلِكَ بِما عَصَوْا وكانُوا يَعْتَدُونَ﴾</span> راجع إلى الشيء الذي أشير إليه بـ<span class="qpc-hafs">﴿ذلك﴾</span> في قوله تعالى: <span class="qpc-hafs">﴿ذَلِكَ بِأَنَّهُمْ كانُوا يَكْفُرُونَ بِآياتِ اللَّهِ ويَقْتُلُونَ الأَنْبِياءَ بِغَيْرِ حَقٍّ﴾</span>، أي: أنّ ما تحملوه من غضب الله وضرب الذلة والمسكنة عليهم، بسبب كفرهم، وقتلهم الأنبياء، ومعصيتهم ربهم، واعتدائهم في شرع ربهم، فاسم الإشارة الثاني عنده تأكيد للأول، وهو معنى قول قتادة.</p><p>و<span class="comment-type-2">استدرك</span> <u>ابنُ عطية</u> (٢/٣٢٢) على <u>ابن جرير</u>، فقال بعدما ذكر قولَه: «والذي أقول: إن الإشارة بـ<span class="qpc-hafs">﴿ذلِكَ﴾</span> الأخير إنما هي إلى كفرهم وقتلهم، وذلك أنّ الله تعالى استدرجهم، فعاقبهم على العصيان والاعتداء بالمصير إلى الكفر وقتل الأنبياء، وهو الذي يقول أهل العلم: إن الله تعالى يعاقب على المعصية بالإيقاع في معصية، ويجازي على الطاعة بالتوفيق إلى طاعة».</div></p><p><div></p><p><p><span class="item-no">١٤٢٣٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ذلك﴾</span> الذي أصابهم <span class="qpc-hafs">﴿بما عصوا وكانوا يعتدون﴾</span> في دينهم{34}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ١/٢٩٥.|2:أخرجه ابن جرير ٥/٦٧٩-٦٨٠، وابن أبي حاتم ٣/٧٣٤.|3:أخرجه ابن جرير ٥/٦٧٩. وعلَّقه ابن أبي حاتم ٣/٧٣٤. وعزاه السيوطي إلى عبد بن حميد.|4:أخرجه ابن جرير ٥/٦٧٩.|5:تفسير مقاتل بن سليمان ١/٢٩٥.|6:أخرجه ابن جرير ٥/٦٧٩-٦٨٠، وابن أبي حاتم ٣/٧٣٥ من طريق ابن ثور.|7:أخرجه ابن أبي حاتم ٣/٧٣٥، ولفظه: هم أصحاب القبالات، كفروا بالله العظيم.|8:أخرجه ابن المنذر ١/٣٣٥. وفي لفظ آخر ١/٣٣٧: <span class="qpc-hafs">﴿الذلة والمسكنة﴾</span>: الجزية.|9:أخرجه ابن جرير ٥/٦٨١، وابن أبي حاتم ٣/٧٣٥.|10:أخرجه ابن جرير ٥/٦٨١، وابن المنذر (٨١١)، وابن أبي حاتم ٣/٧٣٥. وعزاه السيوطي إلى عبد بن حميد.|11:أخرجه ابن أبي حاتم ٣/٧٣٥.|12:تفسير مقاتل بن سليمان ١/٢٩٥-٢٩٦.|13:أخرجه ابن المنذر (٨١٣)، وابن جرير ٥/٦٨٣، وابن أبي حاتم ٣/٧٣٥.|14:أخرجه ابن جرير ٥/٦٨٢-٦٨٣ من طريق ابن جريج، وعبد الرزاق ١/١٣٠ من طريق معمر، وعبد بن حميد ص٥١ بلفظ: بعهد من الله. وعلَّقه ابن أبي حاتم ٣/٣٣٥.|15:أخرجه ابن جرير ٥/٦٨٤. وعلَّقه ابن المنذر ١/٣٣٦، وابن أبي حاتم ٣/٣٣٥.|16:أخرجه ابن جرير ٥/٦٨٢. وعلَّقه ابن أبي حاتم ٣/٣٣٥.|17:علَّقه ابن أبي حاتم ٣/٣٣٥.|18:أخرجه ابن جرير ٥/٦٨٣. وعلَّقه ابن أبي حاتم ٣/٣٣٥.|19:أخرجه ابن جرير ٥/٦٨٢، وعبد بن حميد ص٥١ بلفظ: بعهد من الله. وعلَّقه ابن المنذر ١/٣٣٦، وابن أبي حاتم ٣/٣٣٥.|20:أخرجه ابن جرير ٥/٦٨٣. وعلَّقه ابن أبي حاتم ٣/٣٣٥. وذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ١/٣١٢-.|21:أخرجه أبو جعفر الرملي في جزئه ص١٠٢ (تفسير عطاء الخراساني). وعلَّقه ابن أبي حاتم ٣/٣٣٥.|22:أخرجه ابن جرير ٥/٦٨٣. وعلَّقه ابن أبي حاتم ٣/٣٣٥.|23:تفسير مقاتل بن سليمان ١/٢٩٥-٢٩٦.|24:أخرجه ابن جرير ٥/٦٨٣.|25:أخرجه أبو نعيم في أخبار أصبهان ٢/٧.|26:أخرجه ابن أبي حاتم ٣/٣٣٦.|27:أخرجه ابن المنذر ١/٣٣٦. وعلَّقه ابن أبي حاتم ٣/٣٣٦ بلفظ: استوجبوا.|28:أخرجه ابن أبي حاتم ٣/٣٣٦.|29:تفسير مقاتل بن سليمان ١/٢٩٥-٢٩٦.|30:أخرجه ابن أبي حاتم ٣/٣٣٦.|31:علَّقه ابن أبي حاتم ٣/٣٣٦.|32:أخرجه ابن أبي حاتم ٣/٣٣٦.|33:أخرجه ابن أبي حاتم ٣/٣٣٦.|34:تفسير مقاتل بن سليمان ١/٢٩٦.|35:أخرجه ابن أبي حاتم ٣/٣٣٦.|36:تفسير مقاتل بن سليمان ١/٢٩٦.</p><p>وقد تقدمت الآثار بتفصيل أكثر عند تفسير نظير هذه الآية في سورة البقرة: <span class="qpc-hafs">﴿وضُرِبَتْ عَلَيْهِمُ الذِّلَّةُ والمَسْكَنَةُ وباءُوا بِغَضَبٍ مِنَ اللَّهِ ذَلِكَ بِأَنَّهُمْ كانُوا يَكْفُرُونَ بِآياتِ اللَّهِ ويَقْتُلُونَ النَّبِيِّينَ بِغَيْرِ الحَقِّ ذَلِكَ بِما عَصَوْا وكانُوا يَعْتَدُونَ﴾</span> [البقرة:٦١]، وقد أحال إليها ابن جرير ٥/٦٨٨، بينما كررها ابن أبي حاتم كعادته.|37:أخرجه ابن المنذر (٨٢١)، وابن جرير ٥/٦٨٩، وابن أبي حاتم ٣/٣٣٧.|38:تفسير مقاتل بن سليمان ١/٢٩٦.
  3,112,""
  3,113,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿لَیۡسُوا۟ سَوَاۤءࣰۗ مِّنۡ أَهۡلِ ٱلۡكِتَـٰبِ أُمَّةࣱ قَاۤىِٕمَةࣱ یَتۡلُونَ ءَایَـٰتِ ٱللَّهِ ءَانَاۤءَ ٱلَّیۡلِ وَهُمۡ یَسۡجُدُونَ ۝١١٣﴾</span> - نزول الآية</h3></p><p><div></p><p><p><span class="item-no">١٤٢٣٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق ابن إسحاق بسنده- قال: لَمّا أسلم عبدُ الله بنُ سلام، وثعلبة بن سَعْيَةَ، وأسد بن سَعْيَةَ، وأسد بن عبيد، ومَن أسلم مِن يهود معهم، فآمنوا وصدَّقوا ورغِبوا في الإسلام؛ قالت أحبارُ يهود وأهلُ الكفر منهم: ما آمن بمحمد وتبِعه إلا أشرارُنا، ولو كانوا خيارنا ما تركوا دين آبائهم وذهبوا إلى غيره. فأنزل الله في ذلك: <span class="qpc-hafs">﴿ليسوا سواء﴾</span> إلى قوله: <span class="qpc-hafs">﴿وأولئك من الصالحين﴾</span>{1}<span class=comment-ref>١٣٥١</span>. (٣/٧٣٠)</p></p><p></div></p><p><div><span class=comment-ref>١٣٥١</span> <span class="comment-type-3">رجَّح</span> <u>ابنُ جرير</u> (٥/٦٨٩-٦٩٣) <span class="mustanad">مستندًا إلى لغة العرب، وأقوال السلف</span> أنّ <span class="qpc-hafs">﴿لَيْسُوا سَواءً﴾</span>: إخبارٌ عن مؤمني أهل الكتاب وأهل الكفر منهم، وأنّ المقصودين بقوله تعالى: <span class="qpc-hafs">﴿مِن أهْلِ الكِتابِ أُمَّةٌ قائِمَةٌ﴾</span> هم مَن أسلم مِن اليهود فَحَسُن إسلامهم، كعبد الله بن سلام وأصحابه، وهو قول ابن عباس، وقتادة، وابن جريج.</p><p>ونحوه قال <u>ابنُ عطية</u> (٢/٣٢٤)، حيث قال: «وهو أصحُّ التَّأويلات». غير أنّ <u>ابن عطية</u> بعد أن ذكر قول ابن مسعود، والسدي من طريق أسباط، أنّ المعنى: ليس اليهود وأمة محمد سواء. <span class="comment-type-1">وجَّه</span> قولهما قائلًا: «فمِن حيث تَقَدُّم ذِكْر هذه الأمة في قوله: <span class="qpc-hafs">﴿كُنْتُمْ خَيْرَ أُمَّةٍ﴾</span>، وذِكْر أيضًا اليهود، قال الله لنبيه: <span class="qpc-hafs">﴿لَيْسُوا سَواءً﴾</span>، والكتاب على هذا جنس كُتُبِ الله، وليس بالمعهود مِن التوراة والإنجيل فقط. والمعنى: مِن أهل الكتاب -وهم أهل القرآن- أمة قائمة».</div></p><p><div></p><p><p><span class="item-no">١٤٢٣٩<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطاء- قال: بَلَغَنِي: أنّ هذه الآية <span class="qpc-hafs">﴿ليسوا سواء من أهل الكتاب أمة قائمة يتلون آيات الله آناء الليل﴾</span> نزلت ما بين المغرب والعشاء{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٤٢٤٠<span class="dash">-</span></span> عن <span class="name-2">منصور [بن المعتمر]</span> -من طريق سفيان الثوري- قال: بَلَغَنِي: أنّها نزلت <span class="qpc-hafs">﴿يتلون آيات الله آناء الليل وهم يسجدون﴾</span> فيما بين المغرب والعشاء{3}. (٣/٧٣٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٤٢٤١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ليسوا سواء من أهل الكتاب﴾</span>، وذلك أنّ اليهود قالوا لابن سلام وأصحابه: لقد خسِرتُم حين استبدلتُم بدينكم دينًا غيرَه، وقد عاهدتم الله بعهد ألا تدينوا إلا بدينكم. فقال الله ﷿: <span class="qpc-hafs">﴿ليسوا سواء﴾</span>{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٤٢٤٢<span class="dash">-</span></span> عن <span class="name-3">عبد الملك ابن جُرَيْج</span> -من طريق حجاج- في قوله: <span class="qpc-hafs">﴿أمة قائمة﴾</span>، قال: عبد الله بن سلام، وثعلبة بن سلام أخوه، وسَعْيَةَ، ومبشر، وأسيد وأسد ابنا كعب{5}. (٣/٧٣١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٤٢٤٣<span class="dash">-</span></span> عن أبي الحسن -من طريق حفص بن ميسرة- أنّه قال في قول الله: <span class="qpc-hafs">﴿ليسوا سواء من أهل الكتاب أمة قائمة يتلون آيات الله أناء الليل وهم يسجدون يؤمنون بالله واليوم الآخر ويأمرون بالمعروف﴾</span> الآية كلها، قال: [نزلت] ما بين المغرب والعشاء{6}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿لَیۡسُوا۟ سَوَاۤءࣰۗ مِّنۡ أَهۡلِ ٱلۡكِتَـٰبِ أُمَّةࣱ قَاۤىِٕمَةࣱ یَتۡلُونَ ءَایَـٰتِ ٱللَّهِ ءَانَاۤءَ ٱلَّیۡلِ وَهُمۡ یَسۡجُدُونَ ۝١١٣﴾</span> - تفسير الآية</h3></p><p><div></p><p><p><span class="item-no">١٤٢٤٤<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن مسعود</span> -من طريق الحسن بن يزيد العِجْلِيِّ- في قوله: <span class="qpc-hafs">﴿ليسوا سواء من أهل الكتاب أمة قائمة﴾</span>، قال: لا يستوي أهلُ الكتاب وأُمَّةُ محمد{7}. (٣/٧٣٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٤٢٤٥<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق أبي الأَشْهَب- <span class="qpc-hafs">﴿ليسوا سواء من أهل الكتاب أمة قائمة﴾</span>، قال: هؤلاء أهل الهدى، ليس كُلُّ القوم هَلَك. فقرأ حتى بلغ: <span class="qpc-hafs">﴿وما يفعلوا من خير فلن يكفروه﴾</span>. قال: فزعوا إلى أنفسهم حين تفرَّقتْ أُمَّتُهم{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٤٢٤٦<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دِعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿ليسوا سواء﴾</span> الآية، يقول: ليس كُلُّ القوم هلَك، قد كان لله فيهم بَقِيَّةٌ{9}. (٣/٧٣١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٤٢٤٧<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيِّ</span> -من طريق أسباط- في الآية، يقول: هؤلاء اليهود ليسوا كمثل هذه الأُمَّةِ التي هي قانِتةٌ لله{10}. (٣/٧٣١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٤٢٤٨<span class="dash">-</span></span> عن <span class="name-3">أبي الأشهب [جعفر بن حيّان العُطارِدِيّ]</span> -من طريق سعيد بن سليمان النَّشِيطِيِّ- قال: ليس كُلُّ القوم هلك{11}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٤٢٤٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثُمَّ أخبر عنهم، فقال سبحانه: <span class="qpc-hafs">﴿ليسوا سواء﴾</span>. يقول: ليس كفار اليهود والذين في الضلالة بمنزلة ابن سلام وأصحابه؛ الذين هم على دين الله{4}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿مِّنۡ أَهۡلِ ٱلۡكِتَـٰبِ أُمَّةࣱ قَاۤىِٕمَةࣱ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">١٤٢٥٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق العوفي- <span class="qpc-hafs">﴿أمة قائمة﴾</span>، يقول: مُهْتَدِيَةٌ قائِمَةٌ على أمر الله، لم تنزِع عنه وتتركْه كما تركه الآخرون وضيَّعوه{13}. (٣/٧٣١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٤٢٥١<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نَجيح- <span class="qpc-hafs">﴿أمة قائمة﴾</span>، قال: عادِلة{14}. (٣/٧٣٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٤٢٥٢<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دِعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿قائمة﴾</span>، قال: على كتاب الله، وحدود الله، وفرائض الله، وطاعة الله، يؤمنون بالله{15}<span class=comment-ref>١٣٥٢</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>١٣٥٢</span> اختلف في معنى: <span class="qpc-hafs">﴿قائمة﴾</span> في هذه الآية على أقوال: <b>الأول:</b> عادلة. <b>الثاني:</b> قائمة على كتاب الله وما أمر به فيه. <b>الثالث:</b> مطيعة.</p><p>و<span class="comment-type-3">رجَّح</span> <u>ابنُ جرير</u> (٥/٦٩٤-٦٩٥) <span class="mustanad">مستندًا إلى نظيره من السنة</span> القول الثاني، وهو قول ابن عباس، وقتادة من طريق سعيد، والربيع، ثم استدل قائلًا: «ونظير ذلك الخبرُ الذي رواه النعمان بن بشير عن النبي ﷺ أنّه قال: «مَثَلُ القائم على حدود الله والواقع فيها كمَثَلِ قوم ركبوا سفينةً». ثم ضرب لهم مثلًا، فالقائم على حدود الله هو الثابت على التمسك بما أمر الله به واجتناب ما نهاه الله عنه».</p><p>و<span class="comment-type-1">وجَّه</span> الأقوال الأخرى بأنها متقاربة المعنى، «وذلك أنّ معنى قوله: <span class="qpc-hafs">﴿قائِمَةٌ﴾</span>: مستقيمة على الهدى وكتاب الله وفرائضه وشرائع دينه، بالعدل والطاعة، وغير ذلك مِن أسباب الخير مِن صفة أهل الاستقامة على كتاب الله وسنة رسول الله ﷺ».</p><p>و<span class="comment-type-1">وجَّه</span> <u>ابن عطية</u> (٢/٣٢٤) الأقوال الثلاثة بقوله: «وهذا كلُّه يرجع إلى معنًى واحد من الاعتدال على أمر الله». ثُمَّ ذكر احتمالَيْن في معنى الآية بناءً على هذا التوجيه، فقال: «وهذه الآيةُ تحتملُ هذا المعنى، وألّا تنظرَ اللفظةَ إلى هيئة الأشخاص وقت تلاوة آيات الله، ويحتمل أنْ يُراد بـ<span class="qpc-hafs">﴿قائِمَةٌ﴾</span> وصف حال التالين في آناءَ اللَّيْلِ، ومَن كانت هذه حالُه فلا محالة أنّه مُعْتَدِلٌ على أمْر الله. وهذه الآية في هذين الاحتمالين مثل ما تقدم في قوله: <span class="qpc-hafs">﴿إلا ما دُمْتَ عَلَيْهِ قائِمًا﴾</span> [آل عمران:٧٥]».</div></p><p><div></p><p><p><span class="item-no">١٤٢٥٣<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- <span class="qpc-hafs">﴿أمة قائمة﴾</span> الآية، يقول: ليس هؤلاء اليهود كمثل هذه الأمة التي هي قائمة لله. والقائمةُ: المطيعةُ{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٤٢٥٤<span class="dash">-</span></span> عن <span class="name-2">الربيع بن أنس</span> -من طريق أبي جعفر- <span class="qpc-hafs">﴿أمة قائمة﴾</span>، يقول: قائمة على كتابِ الله، وحدودِه، وفرائضِه{13}. (٣/٧٣٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٤٢٥٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ليسوا سواء﴾</span>، يقول: ليس كفارُ اليهود والذين في الضلالة بمنزلة ابنِ سلام وأصحابه الذين هم على دين الله، منهم <span class="qpc-hafs">﴿أمة﴾</span> عصابة <span class="qpc-hafs">﴿قائمة﴾</span> بالحق على دين الله، عادِلةٌ{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٤٢٥٦<span class="dash">-</span></span> قال ابن وهب: وسمعتُ <span class="name-3">مالك [بن أنس]</span> يقول في قول الله: <span class="qpc-hafs">﴿ليسوا سواء من أهل الكتاب أمة قائمة﴾</span>، قال: قائمة بالحقِّ{19}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿یَتۡلُونَ ءَایَـٰتِ ٱللَّهِ ءَانَاۤءَ ٱلَّیۡلِ وَهُمۡ یَسۡجُدُونَ ۝١١٣﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">١٤٢٥٧<span class="dash">-</span></span> عن عبد الله بن مسعود، قال: أخَّر رسول الله ﷺ ليلةً صلاة العشاء، ثُمَّ خرج إلى المسجد، فإذا الناسُ ينتظرون الصلاة، فقال: «<b>أما إنّه ليس من أهل هذه الأديان أحد يذكرُ اللهَ هذه الساعة غيركم</b>». -وفي لفظ: «<b>إنه لا يصلي هذه الصلاةَ أحدٌ من أهل الكتاب</b>»-. قال: وأنزلت هذه الآية: <span class="qpc-hafs">﴿ليسوا سواء من أهل الكتاب أمة قائمة﴾</span> حتى بلغ <span class="qpc-hafs">﴿والله عليم بالمتقين﴾</span>{20}. (٣/٧٣٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٤٢٥٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن مسعود</span> -من طريق الحسن بن يزيد العِجْلِيِّ- في قوله: <span class="qpc-hafs">﴿يتلون آيات الله آناء الليل﴾</span>، قال: صلاة العَتَمة، هُم يُصَلُّونها، ومَن سواهم مِن أهل الكتاب لا يصلونها{21}. (٣/٧٣٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٤٢٥٩<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن مسعود</span> -من طريق الأسود- في قوله: <span class="qpc-hafs">﴿يتلون آيات الله آناء الليل﴾</span>، قال: هي صلاة الغفلة{22}. (٣/٧٣٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٤٢٦٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق قابوس، عن أبيه- في قوله: <span class="qpc-hafs">﴿آناء الليل﴾</span>، قال: جَوْف الليل{23}. (٣/٧٣٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٤٢٦١<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق عباد بن منصور- قوله: <span class="qpc-hafs">﴿آناء الليل﴾</span>، قال: ساعات مِن أوَّلِه وآخرِه{24}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٤٢٦٢<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دِعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿يتلون آيات الله آناء الليل﴾</span>، أي: ساعات الليل{25}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٤٢٦٣<span class="dash">-</span></span> عن <span class="name-2">ابن كثير المكِّيِّ</span> -من طريق ابن جُرَيْج- سمعنا العربَ تقول: آناء الليل: ساعات الليل{26}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٤٢٦٤<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- <span class="qpc-hafs">﴿يتلون آيات الله آناء الليل﴾</span>، قال: أمّا آناء الليل: فجَوْفُ الليل{27}<span class=comment-ref>١٣٥٣</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>١٣٥٣</span> <span class="comment-type-2">انتَقَدَ</span> <u>ابنُ عطية</u> (٢/٣٢٥) قول السدي، فقال: «وهذا قلِق». غير أنه ذَكَر له <span class="comment-type-1">وجْهًا</span> يمكن أنْ يُحمَل عليه، بأن يكون فسَّر الآناء بجزءٍ مِن معناه، فقال: «أما إنّ جوف الليل جُزءٌ مِن الآناء».</div></p><p><div></p><p><p><span class="item-no">١٤٢٦٥<span class="dash">-</span></span> عن الربيع بن أنس -من طريق أبي جعفر- في قوله: <span class="qpc-hafs">﴿يتلون آيات الله آناء الليل﴾</span>، قال: قال بعضهم: صلاة العَتَمَةِ يصليها أُمَّةُ محمد ﷺ، ولا يُصَلِّيها غيرُهم مِن أهل الكتاب{28}<span class=comment-ref>١٣٥٤</span>. (٣/٧٣٣)</p></p><p></div></p><p><div><span class=comment-ref>١٣٥٤</span> <span class="comment-type-1">وجَّه</span> <u>ابنُ جرير</u> (٥/٦٩٨) الآثار الواردة في معنى: <span class="qpc-hafs">﴿آناءَ اللَّيْلِ﴾</span> بأنها على اختلافها متقاربة المعنى، وجمع بينها، فقال: «وذلك أنّ الله -تعالى ذِكْرُه- وصف هؤلاء القوم بأنهم يتلون آيات الله في ساعات الليل، وهي: آناؤه، وقد يكون تاليها في صلاة العشاء تاليًا لها آناء الليل، وكذلك مَن تلاها فيما بَيْن المغرب والعشاء، ومَن تلاها جوفَ الليل، فكلٌّ تالٍ لها ساعات الليل».</p><p>غير أنه <span class="comment-type-3">رَجَّح</span> <span class="mustanad">مستندًا إلى السنة</span> قولَ مَن قال: إنّها تلاوة القرآن في صلاة العشاء. مستدلاًّ بأنّها صلاةٌ لا يصليها أحدٌ مِن أهل الكتاب، كما جاء في حديث ابن مسعود، ثُمَّ قال: «فوصف الله -جلَّ ثناؤه- أُمَّةَ محمد ﷺ بأنهم يُصَلُّونها دون أهل الكتاب الذين كفروا بالله ورسوله».</div></p><p><div></p><p><p><span class="item-no">١٤٢٦٦<span class="dash">-</span></span> عن <span class="name-2">الربيع بن أنس</span> -من طريق أبي جعفر- <span class="qpc-hafs">﴿آناء الليل﴾</span>، قال: ساعات الليل{29}. (٣/٧٣٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٤٢٦٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿يتلون آيات الله﴾</span> يعني: يقرؤون كلام الله <span class="qpc-hafs">﴿آناء الليل﴾</span> يعني: ساعات الليل، <span class="qpc-hafs">﴿وهم يسجدون﴾</span> يعني: يُصَلُّون بالليل{4}<span class=comment-ref>١٣٥٥</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>١٣٥٥</span> فسَّر مقاتل <span class="qpc-hafs">﴿وهم يسجدون﴾</span>، أي: يصلون بالليل. وذكر <u>ابنُ جرير</u> (٥/٦٩٨-٦٩٩) هذا المعنى عن بعض أهل العربية، ولم يُسنِده عن مقاتل، ثم <span class="comment-type-2">انتقده</span> <span class="mustanad">مستندًا إلى المعنى الأشهر للسجود</span>، وبيَّن أنّ المعنى: مِن أهل الكتاب أمة قائمة يتلون آيات الله آناء الليل في صلاتهم، وهم مع ذلك يسجدون فيها. فالسجود هو السجود المعروف في الصلاة.</p><p>و<span class="comment-type-3">حَسَّن</span> <u>ابن عطية</u> (٢/٣٢٦) المعنى الذي ذهب إليه <u>ابنُ جرير</u> مِن <span class="mustanad">جهةِ العقلِ</span>، فقال: «مِن جهة أنّ التلاوة آناء الليل قد يعتقد السامعُ أنّ ذلك في غير الصلاة».</div></p><p><h3><span class="qpc-hafs">﴿یَتۡلُونَ ءَایَـٰتِ ٱللَّهِ ءَانَاۤءَ ٱلَّیۡلِ وَهُمۡ یَسۡجُدُونَ ۝١١٣﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">١٤٢٦٨<span class="dash">-</span></span> عن معاذ بن جبل، قال: أخَّر رسولُ الله ﷺ صلاة العَتَمَةِ ليلةً، حتى ظنَّ الظانُّ أن قد صلّى، ثُمَّ خرج، فقال: «<b>أعْتِمُواْ</b>{31} <b>بهذه الصلاة؛ فإنّكم فُضِّلْتُم بها على سائر الأُمَم، ولم تُصَلِّها أُمَّةٌ قبلكم</b>»{32}. (٣/٧٣٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٤٢٦٩<span class="dash">-</span></span> عن عبد الله بن عباس: أنّ النبي ﷺ أخَّر صلاة العشاء، ثُمَّ خرج، فقال: «<b>ما يحبِسُكم هذه الساعة</b>؟». قالوا: يا نبي الله، انتظرناك لنشهد الصلاة معك. فقال لهم: «<b>ما صَلّى صلاتُكم هذه أُمَّةٌ قَطُّ قبلكم، وما زلتم في صلاة بعدُ</b>»{33}. (٣/٧٣٤)</p></p><p></div></p></div>",footnotes:1:أخرجه الطبراني في الكبير ٢/٨٧ (١٣٨٨)، وابن جرير ٥/٦٩١، وابن أبي حاتم ٣/٧٣٧ (٤٠٠٣)، من طريق محمد بن إسحاق، عن محمد ابن أبي محمد مولى زيد بن ثابت، عن سعيد بن جبير أو عكرمة، عن ابن عباس به.</p><p>قال الهيثمي في المجمع ٦/٣٢٧ (١٠٨٩٩): «رجاله ثقات».|2:أخرجه سفيان الثوري في التفسير ص٧٩ من طريق ابن جريج، عن عطاء بن أبي رباح، عن ابن عباس به.</p><p>وسنده صحيح.|3:أخرجه عبد الرزاق ١/١٣١، وابن جرير ٥/٦٩٨، وابن المنذر ١/٣٣٩، وابن أبي حاتم ٣/٧٣٩ بلفظ: بلغني أنهم كانوا يصلون بين المغرب والعشاء. وعزاه السيوطي إلى عبد بن حميد.|4:تفسير مقاتل بن سليمان ١/٢٩٦.|5:أخرجه ابن جرير ٥/٦٩٤.|6:أخرجه ابن وهب في الجامع - تفسير القرآن ١/٣٥ (٧١).|7:أخرجه البخاري في تاريخه ٢/٣٠٨، وابن جرير ٥/٦٩٢، ٦٩٧، وابن المنذر (٨٢٣)، وابن أبي حاتم ٣/٧٣٧، ٧٣٩. وعزاه السيوطي إلى عَبد بن حُمَيد، والفريابي.|8:أخرجه عبد بن حميد ص٥١، وابن المنذر ١/٣٤١-٣٤٢، وعلَّق أوله ابن أبي حاتم ٣/٧٣٧، وأخرج آخره ٣/٧٣٩.|9:أخرجه ابن جرير ٥/٦٩٢. وعزاه السيوطي إلى عبد بن حميد.|10:أخرجه ابن جرير ٥/٦٩٣-٦٩٤، وابن أبي حاتم ٣/٧٣٧ واللفظ له.|11:أخرجه ابن أبي حاتم ٣/٧٣٧.|12:تفسير مقاتل بن سليمان ١/٢٩٦.|13:أخرجه ابن جرير ٥/٦٩٤، وابن أبي حاتم ٣/٧٣٨.|14:أخرجه ابن جرير ٥/٦٩٣، وابن أبي حاتم (ت: حكمت بشير) ٢/٤٨٦. وعزاه السيوطي إلى عبد بن حميد.|15:أخرجه ابن جرير ٥/٦٩٤، وابن المنذر ١/٣٤٠ واللفظ له.|16:أخرجه ابن جرير ٥/٦٩٤.|17:أخرجه ابن جرير ٥/٦٩٤، وابن أبي حاتم ٣/٧٣٨.|18:تفسير مقاتل بن سليمان ١/٢٩٦.|19:أخرجه ابن وهب في الجامع ٢/١٣٣-١٣٤ (٢٦٤).|20:أخرجه أحمد ٦/٣٠٤ (٣٧٦٠)، وابن المنذر ١/٣٣٨ (٨٢٢)، وابن جرير ٥/٦٩٧-٦٩٨ من طريق عاصم بن أبي النجود، عن زر بن حبيش، عن ابن مسعود به.</p><p>قال البزار في مسنده ٥/٢١٦-٢١٧ (١٨١٩): «الحديث لا نعلم رواه عن عاصم بهذا الإسناد إلا شيبان». وصححه ابن حبان ٤/٣٩٧ (١٥٣٠). وقال ابن رجب في فتح الباري ٤/٣٧٤: «خرجه يعقوب بن شيبة في مسنده، وقال: صالح الإسناد». وقال السيوطي: «سند حسن».|21:أخرجه البخاري في تاريخه ٢/٣٠٨، وابن جرير ٥/٦٩٢، ٦٩٧، وابن المنذر (٨٢٣)، وابن أبي حاتم ٣/٧٣٧، ٧٣٩ مختصرًا من طريق الحسن ابن أبي يزيد العجلي. وعزاه السيوطي إلى عبد بن حميد، والفريابي.|22:أخرجه الثوري في تفسيره ص٨٠، وابن أبي حاتم ٣/٧٣٨-٧٣٩.|23:أخرجه ابن أبي شيبة ١٣/٣٧٠، وأحمد ٣/٤١٦، وابن المنذر (٨٣٠)، وابن أبي حاتم ٣/٧٣٨. وعزاه السيوطي إلى ابن نصر.|24:أخرجه ابن أبي حاتم ٣/٧٣٩.|25:أخرجه ابن جرير ٥/٦٩٦، وابن المنذر ١/٣٤١. وعلَّقه ابن أبي حاتم ٣/٧٣٩.|26:أخرجه ابن جرير ٥/٦٩٦.|27:أخرجه ابن جرير ٥/٦٩٦. وعلَّقه ابن أبي حاتم ٣/٧٣٨.|28:أخرجه ابن أبي حاتم ٣/٧٣٨.|29:أخرجه ابن جرير ٥/٦٩٦. وعلَّقه ابن أبي حاتم ٣/٧٣٩.|30:تفسير مقاتل بن سليمان ١/٢٩٦.|31:أي: أخّروها إلى وقت العتمة، وهي ثلث الليل الأوّل بعد غيبوبة الشفق. اللسان (عتم).|32:أخرجه أحمد ٣٦/٣٨٥-٣٨٦ (٢٢٠٦، ٢٢٠٦٧)، وأبو داود ١/٣١٤ (٤٢١).</p><p>قال مغلطاي في شرح سنن ابن ماجه ٣/١٠٣٦: «سكت عنه الإشبيلي مُصَحِّحًا له، وعاب ذلك عليه ابنُ القَطّان، وزعم أنّ عاصمًا لا يعرف أنه ثقة». وقال المناوي في التيسير ١/١٦٨: «إسناده حسن». وقال الألباني في صحيح أبي داود ٢/٢٩٥-٢٩٦ (٤٤٨): «إسناده صحيح».|33:أخرجه الطبراني في الكبير ١١/٥٣ (١١٠٢٣)، وفي مسند الشاميين ٣/١١٢ (١٨٩٥)، والضياء المقدسي في المختارة ١١/٦١ (٥٣).</p><p>قال الهيثمي في المجمع ١/٣١٣ (١٧٥٠): «رجاله مُوَثَّقون». وقال السيوطي: «سند حسن».
  3,114,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿یُؤۡمِنُونَ بِٱللَّهِ وَٱلۡیَوۡمِ ٱلۡـَٔاخِرِ وَیَأۡمُرُونَ بِٱلۡمَعۡرُوفِ وَیَنۡهَوۡنَ عَنِ ٱلۡمُنكَرِ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">١٤٢٧٠<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span> -من طريق عطاء- في قوله: <span class="qpc-hafs">﴿يؤمنون بالله﴾</span> قال: يصدقون بتوحيد الله، <span class="qpc-hafs">﴿واليوم الآخر﴾</span> ويُصَدِّقون بالغيب الذي فيه جزاءُ الأعمال{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٤٢٧١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿يؤمنون بالله﴾</span> يعني: يُصَدِّقون بتوحيد الله، <span class="qpc-hafs">﴿واليوم الآخر﴾</span> يعني: والبعث الذي فيه جزاءُ الأعمال، <span class="qpc-hafs">﴿ويأمرون بالمعروف﴾</span> يعني: إيمانًا بمحمد ﷺ، <span class="qpc-hafs">﴿وينهون عن المنكر﴾</span> يعني: عن تكذيبٍ بمحمد ﷺ{2}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَیُسَـٰرِعُونَ فِی ٱلۡخَیۡرَ ٰ⁠تِۖ وَأُو۟لَـٰۤىِٕكَ مِنَ ٱلصَّـٰلِحِینَ ۝١١٤﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">١٤٢٧٢<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق أبي الأَشْهَب- <span class="qpc-hafs">﴿ويسارعون في الخيرات وأولئك من الصالحين﴾</span>، قال: فزعوا إلى [أنفسهم] حين تفرَّقَتْ أُمَّتُهم{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٤٢٧٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ويسارعون في الخيرات﴾</span> يعني: شرائع الإسلام، <span class="qpc-hafs">﴿وأولئك من الصالحين﴾</span>{2}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن أبي حاتم ٣/٧٣٩.|2:تفسير مقاتل بن سليمان ١/٢٩٦.|3:أخرجه عبد بن حميد ص٥١، وابن المنذر ١/٣٤١-٣٤٢، وابن أبي حاتم ٣/٧٣٩. وما بين المعقوفين ما رآه محقق تفسير ابن المنذر، وفي تفسير ابن أبي حاتم (ت: أسعد الطيب): بعضهم. ورأى د. حكمت بشير ص٤٩٠ أنها مصحَّفة من «دينهم». أما محقق قطعة من تفسير عبد بن حميد فأداه اجتهاده إلى أنها: فزعوا. أو: نزعوا إلى بقيتهم.|4:تفسير مقاتل بن سليمان ١/٢٩٦.
  3,115,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَمَا یَفۡعَلُوا۟ مِنۡ خَیۡرࣲ فَلَن یُكۡفَرُوهُۗ وَٱللَّهُ عَلِیمُۢ بِٱلۡمُتَّقِینَ ۝١١٥﴾</span> - قراءات</h3></p><p><div></p><p><p><span class="item-no">١٤٢٧٤<span class="dash">-</span></span> عن أبي عمرو بن العلاء، أنّه بلغه في قوله: <span class="qpc-hafs">﴿وما يَفْعَلُواْ مِن خَيْرٍ فَلَن يُكْفَرُوهُ﴾</span> أنّ <span class="name-1">ابن عباس</span> كان يقرؤهما جميعًا بالياء{1}. (٣/٧٣٥)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَمَا یَفۡعَلُوا۟ مِنۡ خَیۡرࣲ فَلَن یُكۡفَرُوهُۗ وَٱللَّهُ عَلِیمُۢ بِٱلۡمُتَّقِینَ ۝١١٥﴾</span> - تفسير الآية</h3></p><p><div></p><p><p><span class="item-no">١٤٢٧٥<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق عباد بن منصور- ‹فلن تُكْفَرُوه›، قال: لن تُظْلَمُوه{2}. (٣/٧٣٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٤٢٧٦<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دِعامة</span> -من طريق سعيد- ‹وما تَفْعَلُوا مِن خَيْرٍ فَلَن تُكْفَرُوهُ›، قال: لن يُضَلَّ عنكم{3}. (٣/٧٣٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٤٢٧٧<span class="dash">-</span></span> عن <span class="name-2">الربيع بن أنس</span> -من طريق أبي جعفر- قوله: <span class="qpc-hafs">﴿وما يفعلوا من خير فلن يكفروه﴾</span>، يقول: لن يضل عنكم{4}<span class=comment-ref>١٣٥٦</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>١٣٥٦</span> لم يذكر <u>ابنُ جرير</u> (٥/٧٠١-٧٠٢) في معنى: <span class="qpc-hafs">﴿فَلَنْ يُكْفَرُوهُ﴾</span> سوى قول قتادة، والربيع من طريق أبي جعفر.</div></p><p><div></p><p><p><span class="item-no">١٤٢٧٨<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وما يفعلوا من خير فلن يكفروه﴾</span>: فلن يضل عنهم، بل يُشكَر ذلك لهم، <span class="qpc-hafs">﴿والله عليم بالمتقين﴾</span> يعني: ابن سلام وأصحابه{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٤٢٧٩<span class="dash">-</span></span> عن محمد بن مِسْعَر، قال: سألتُ <span class="name-3">سفيانَ بن عيينة</span> عن قول الله: <span class="qpc-hafs">﴿وما يفعلوا من خير فلن يكفروه﴾</span>. قال: فوسَّع الله عليهم في التَّطَوُّعِ، في اليهود والأعراب{2}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ٥/٧٠١.</p><p>وهي قراءة حمزة والكسائي وخلف العاشر وحفص، وقرأ بقية العشرة: ‹وما تَفْعَلُوا مِن خَيْرٍ فَلَن تُكْفَرُوهُ› بالتاء فيهما. ينظر: النشر ٢/٢٤١، والإتحاف ص٢٢٧.|2:أخرجه ابن أبي حاتم ٣/٧٤٠.|3:أخرجه ابن جرير ٥/٧٠١. وعزاه السيوطي إلى عبد بن حميد.|4:أخرجه ابن جرير ٥/٧٠٢، وابن أبي حاتم ٣/٧٤٠.|5:تفسير مقاتل بن سليمان ١/٢٩٦.|6:أخرجه ابن أبي حاتم ٣/٧٤٠.