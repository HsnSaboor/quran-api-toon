quran[7]{c,v,t}:
3,109," <q>﴿وَلِلَّهِ مَا فِی ٱلسَّمَـٰوَ ٰ⁠تِ وَمَا فِی ٱلۡأَرۡضِۚ وَإِلَى ٱللَّهِ تُرۡجَعُ ٱلۡأُمُورُ ۝١٠٩﴾</q> - قراءات ١٤١٥١- عن يحيى بن وثّاب أنّه قرأ كل شيء في القرآن: ‹وإلى اللهِ تَرْجِعُ الأُمُورُ› بنصب التاء، وكسر الجيم{1}. (٣/٧٢٤) <q>﴿وَلِلَّهِ مَا فِی ٱلسَّمَـٰوَ ٰ⁠تِ وَمَا فِی ٱلۡأَرۡضِۚ وَإِلَى ٱللَّهِ تُرۡجَعُ ٱلۡأُمُورُ ۝١٠٩﴾</q> - تفسير الآية ١٤١٥٢- عن عبد الله بن عباس -من طريق الضحاك- قال: ثم قال: يا محمد، لله الخلق كله، السموات كلهن، ومَن فيهن، والأرضون كلهن، ومن فيهن، وما بينهن، مما يعلم ومما لا يعلم{2}. (ز) ١٤١٥٣- قال مقاتل بن سليمان: <q>﴿ولله ما في السماوات وما في الأرض وإلى الله ترجع الأمور﴾</q>، يعني: تصير أمور العباد إليه في الآخرة{3}. (ز) ",footnotes:1:عزاه السيوطي إلى عَبد بن حُمَيد. قرأ ابن عامر وحمزة والكسائي ويعقوب وخلف العاشر بفتح التاء وكسر الجيم حيث وقع في القرآن، وقرأ الباقون بضم التاء وفتح الجيم. انظر: التيسير ص٨٠، والنشر ٢/٢٠٩.أخرجه ابن أبي حاتم ٣/٧٣١.تفسير مقاتل بن سليمان ١/٢٩٤.
3,110," <q>﴿كُنتُمۡ خَیۡرَ أُمَّةٍ أُخۡرِجَتۡ لِلنَّاسِ تَأۡمُرُونَ بِٱلۡمَعۡرُوفِ وَتَنۡهَوۡنَ عَنِ ٱلۡمُنكَرِ وَتُؤۡمِنُونَ بِٱللَّهِۗ وَلَوۡ ءَامَنَ أَهۡلُ ٱلۡكِتَـٰبِ لَكَانَ خَیۡرࣰا لَّهُمۚ﴾</q> - نزول الآية ١٤١٥٤- عن عكرمة مولى ابن عباس -من طريق ابن جُرَيْج- في الآية، قال: نزلت في ابن مسعود، وعمار بن ياسر، وسالم مولى أبي حذيفة، وأبي بن كعب، ومعاذ بن جبل{1}١٣٤٥. (٣/٧٢٥) ١٣٤٥ علَّق ابن عطية (٢/٣١٦) على هذا الأثر بقوله: «يريد: ومَن شاكلهم». ١٤١٥٥- قال مقاتل بن سليمان: قوله سبحانه: <q>﴿كنتم خير أمة أخرجت للناس﴾</q>، يعني: خير الناس للناس، وذلك أنّ مالك بن الضَّيف، ووهب بن يهوذا قالا لعبد الله بن مسعود، ومعاذ بن جبل، وسالم مولى أبى حذيفة: إنّ ديننا خير مما تدعونا إليه. فأنزل الله ﷿ فيهم: <q>﴿كنتم خير أمة أخرجت للناس﴾</q>{2}. (ز) <q>﴿كُنتُمۡ خَیۡرَ أُمَّةٍ أُخۡرِجَتۡ لِلنَّاسِ﴾</q> - تفسير ١٤١٥٦- عن معاوية بن حَيْدَة، أنه سمع النبي ﷺ، في قوله: <q>﴿كنتم خير أمة أخرجت للناس﴾</q> قال: «إنكم تُتِمُّون سبعين أمة، أنتم خيرها وأكرمها على الله»{3}. (٣/٧٢٦) ١٤١٥٧- عن قتادة بن دِعامة، قال: ذُكِر لنا: أن عمر بن الخطاب قرأ هذه الآية: <q>﴿كنتم خير أمة أخرجت للناس﴾</q> الآية، ثم قال: يا أيها الناس، مَن سَرَّه أن يكون مِن تلكم الأمة فلْيُؤَدِّ شرط الله منها{4}. (٣/٧٢٥) ١٤١٥٨- عن إسماعيل السدي، في الآية، قال: قال عمر بن الخطاب: لو شاء الله لقال: أنتم؛ فكنا كلنا، ولكن قال: <q>﴿كنتم﴾</q> في خاصة أصحاب محمد، ومن صنع مثل صنيعهم كانوا <q>﴿خير أمة أخرجت للناس﴾</q>{5}. (٣/٧٢٥) ١٤١٥٩- عن عمر بن الخطاب -من طريق السدي، عمَّن حَدَّثه- في قوله: <q>﴿كنتم خير أمة﴾</q>، قال: تكون لأولنا، ولا تكون لآخرنا{6}١٣٤٦. (٣/٧٢٥) ١٣٤٦ وجَّه ابن عطية (٢/٣١٦) قول عكرمة، وعمر بن الخطاب من طريق السدي، وابن عباس من طريق سعيد بن جبير، بقوله: «فهذا كلّه قولٌ واحد، مقتضاه أنّ الآية نزلت في الصحابة، قيل لهم: كنتم خير أمة، فالإشارة بقوله: <q>﴿أُمَّةً﴾</q> إلى أمة محمد معينة، فإن هؤلاء هم خيرها». ١٤١٦٠- عن أبي بن كعب -من طريق أبي العالية- قال: لم تكن أمةٌ أكثرَ استجابة في الإسلام مِن هذه الأمة، فمِن ثَمَّ قال: <q>﴿كنتم خير أمة أخرجت للناس﴾</q>{7}. (٣/٧٢٦) ١٤١٦١- عن أبي هريرة -من طريق أبي حازم- في قوله: <q>﴿كنتم خير أمة أخرجت للناس﴾</q>، قال: خير الناس للناس، تأتون بهم في السلاسل في أعناقهم حتى يدخلوا في الإسلام{8}. (٣/٧٢٦) ١٤١٦٢- عن عبد الله بن عباس-من طريق عكرمة- <q>﴿كنتم خير أمة أخرجت للناس﴾</q>، قال: خير الناس للناس{9}. (٣/٧٢٦) ١٤١٦٣- عن عبد الله بن عباس -من طريق سعيد بن جبير- في قوله: <q>﴿كنتم خير أمة أخرجت للناس﴾</q>، قال: هم الذين هاجروا مع رسول الله ﷺ إلى المدينة{10}. (٣/٧٢٤) ١٤١٦٤- وعن سعيد بن جبير، نحو ذلك{11}. (ز) ١٤١٦٥- عن سعيد بن جبير -من طريق ثابت- في قوله ﷿: <q>﴿كنتم خير أمة أخرجت للناس﴾</q>، قال: خيرُ الناس للناس{12}. (ز) ١٤١٦٦- عن مجاهد بن جبر -من طريق ابن أبي نَجيح- قال: خير الناس للناس{13}. (ز) ١٤١٦٧- عن الضحاك بن مزاحم -من طريق جويبر- في قوله: <q>﴿كنتم خير أمة أخرجت للناس﴾</q>، قال: هم أصحاب رسول الله ﷺ خاصة، يعني: وكانوا هم الرواة الدُّعاة الذين أمر الله المسلمين بطاعتهم{14}. (ز) ١٤١٦٨- عن عكرمة مولى ابن عباس -من طريق خُصَيْف- في الآية، قال: لم تكن أمةٌ دخل فيها مِن أصناف الناس غير هذه الأمة{7}. (٣/٧٢٨) ١٤١٦٩- عن عكرمة مولى ابن عباس -من طريق يزيد النحوي- <q>﴿كنتم خير أمة أخرجت للناس﴾</q>، قال: خير الناس للناس،كان قبلكم لا يأمن هذا في بلاد هذا، ولا هذا في بلاد هذا، فكلما كنتم أمِنَ فيكم الأحمر والأسود، وأنتم خير الناس للناس{16}. (ز) ١٤١٧٠- قال الحسن البصري، في قول الله: <q>﴿كنتم خير أمة أخرجت للناس﴾</q>، قال: كنتم خير الناس للناس{17}. (ز) ١٤١٧١- عن الحسن البصري -من طريق عباد- في قوله: <q>﴿كنتم خير أمة أخرجت للناس تأمرون بالمعروف وتنهون عن المنكر﴾</q>، قال: قد كان ما تسمع مِن الخير في هذه الأمة{18}. (ز) ١٤١٧٢- عن الحسن البصري -من طريق قتادة- أنّه كان يقول: نحن آخرها، وأكرمها على الله{18}١٣٤٧. (ز) ١٣٤٧ رجَّح ابن جرير (٥/٦٧٥) مستندًا إلى السنة، وابن عطية (٢/٣١٧) مستندًا إلى القرآن، والسنة، قول الحسن من طريق عباد، ومن طريق قتادة، بأن <q>﴿كُنْتُمْ خَيْرَ أُمَّةٍ أُخْرِجَتْ لِلنّاسِ﴾</q>: خطاب للأمة بأنهم خير أمة أخرجت للناس، فذكر ابن جرير بسنده: عن بَهْز بن حكيم، عن أبيه، عن جده، قال: سمعت رسول الله ﷺ يقول: «ألا إنكم وفَّيتم سبعين أمة، أنتم خيرها وأكرمها على الله». وزاد عليه ابن عطية استدلاله بقوله تعالى: <q>﴿وكَذَلِكَ جَعَلْناكُمْ أُمَّةً وسَطًا لِتَكُونُوا شُهَداءَ عَلى النّاسِ﴾</q> [البقرة:١٤٣]، وبقوله ﷺ: «نحن الآخرون السابقون» الحديث. وكذا رجَّح ابن كثير (٣/١٤٢) مستندًا إلى دلالة العموم، والنظائر، بأن الآية عامة في جميع الأمة، فقال: "والصحيح أن هذه الآية عامة في جميع الأمة، كل قرن بحسبه، وخير قرونهم الذين بعث فيهم رسول الله ﷺ، ثم الذين يلونهم، ثم الذين يلونهم، كما قال في الآية الأخرى: <q>﴿وكَذَلِكَ جَعَلْناكُمْ أُمَّةً وسَطًا﴾</q>، أي: خيارًا، <q>﴿لِتَكُونُوا شُهَداءَ عَلى النّاسِ ويَكُونَ الرَّسُولُ عَلَيْكُمْ شَهِيدًا﴾</q> [البقرة:١٤٣]». ووجَّه ابن عطية (٢/٣١٦) قول الحسن من طريق عباد، فقال: «فلفظ <q>﴿أمة﴾</q> على هذا التأويل اسم جنس، كأنه قيل لهم: كنتم خير الأمم». ١٤١٧٣- عن الحسن البصري -من طريق سفيان بن حسين- أنّه قرأ: <q>﴿كنتم خير أمة أخرجت للناس﴾</q>، فقال: هم الذين مَضَوْا من صدر هذه الأمة، يعني: أصحاب النبي ﷺ، قد كان الرجل منهم يلقى أخاه، فيقول: أبشر، أليس أنت كُنتِيًّا{20}. (ز) ١٤١٧٤- عن أبي جعفر [محمد بن علي بن الحسين] -من طريق جابر- <q>﴿كنتم خير أمة أخرجت للناس﴾</q>، قال: خير أهل بيت النبي ﷺ{7}. (٣/٧٢٧) ١٤١٧٥- عن عطية العوفي -من طريق عيسى بن موسى- في الآية، قال: خير الناس للناس، شهدتم للنبيين الذين كَفَر بهم قومُهم بالبلاغ{22}. (٣/٧٢٧) ١٤١٧٦- عن عطاء: خير الناس للناس{13}. (ز) ١٤١٧٧- عن قتادة بن دعامة: هم أُمة محمد ﷺ، لم يؤمر نبي قبله بالقتال، فهم يقاتلون الكفار فيدخلونهم في دينهم، فهم خير أُمة للناس{24}. (ز) ١٤١٧٨- عن الربيع بن أنس -من طريق أبي جعفر- قوله: <q>﴿كنتم خير أمة أخرجت للناس تأمرون بالمعروف وتنهون عن المنكر﴾</q>، قال: لم تكن أمة أكثر استجابة في الإسلام من هذه الأمة، فمِن ثَمَّ قال: <q>﴿كنتم خير أمة أخرجت للناس﴾</q>{25}. (ز) ١٤١٧٩- قال الربيع بن أنس: خير الناس للناس{13}. (ز) ١٤١٨٠- قال محمد بن السائب الكلبي -من طريق مَعْمَر- في قوله: <q>﴿كنتم خير أمة﴾</q>، قال: أنتم خير الناس للناس{27}. (ز) ١٤١٨١- قال مقاتل بن سليمان: يعنى: خير الناس للناس، ... <q>﴿كنتم خير أمة أخرجت للناس﴾</q> في زمانكم، كما فَضَّل بني إسرائيل في زمانهم{2}. (ز) ١٤١٨٢- عن مقاتل بن حيان: ليس خلق مِن أهل الأديان إلا قالوا: ليس علينا جناح فيما نصيب من غيرنا من أهل الأديان، ولا يأمرون مَن سواهم بالخير، وهذه الأمة يأمرون كل أهل دين وأنفسهم، لا يظلم بعضهم بعضًا، بل يأمرونهم بالمعروف، وينهونهم عن المنكر؛ فأُمة محمد ﷺ خير الأُمم للناس{29}. (ز) <q>﴿تَأۡمُرُونَ بِٱلۡمَعۡرُوفِ وَتَنۡهَوۡنَ عَنِ ٱلۡمُنكَرِ وَتُؤۡمِنُونَ بِٱللَّهِۗ﴾</q> - تفسير ١٤١٨٣- عن عبد الله بن عباس -من طريق علي بن أبي طلحة- في قوله: <q>﴿كنتم خير أمة أخرجت للناس تأمرون بالمعروف﴾</q>، يقول: تأمرونهم أن يشهدوا أن لا إله إلا الله، والإقرار بما أنزل الله، وتقاتلونهم عليه، ولا إله إلا الله هو أعظم المعروف، وتنهونهم عن المنكر، والمنكر هو التكذيب، وهو أنكر المنكر{30}. (٣/٧٢٨) ١٤١٨٤- عن أبي العالية الرِّياحِيّ -من طريق الربيع بن أنس- في قوله: <q>﴿تأمرون بالمعروف﴾</q> قال: بالتوحيد، <q>﴿وتنهون عن المنكر﴾</q> قال: عن الشرك{31}. (ز) ١٤١٨٥- عن سعيد بن جبير -من طريق عطاء- قوله: <q>﴿وتؤمنون بالله﴾</q>، يعني: تصدقون توحيد الله{32}. (ز) ١٤١٨٦- عن مجاهد بن جبر -من طريق ابن أبي نَجِيح- في قوله: <q>﴿كنتم خير أمة أخرجت للناس﴾</q>، يقول: على هذا الشرط، أن تأمروا بالمعروف، وتنهوا عن المنكر، وتؤمنوا بالله، يقول: لمن أنتم بين ظهرانيه، كقوله: <q>﴿ولقد اخترناهم على علم على العالمين﴾</q> [الدخان:٣٢]{33}. (٣/٧٢٦) ١٤١٨٧- قال مقاتل بن سليمان: قوله: <q>﴿تأمرون﴾</q> الناس <q>﴿بالمعروف﴾</q> يعني: بالإيمان، <q>﴿وتنهون عن المنكر وتؤمنون﴾</q> بتوحيد الله، وتنهونهم عن الظلم، وأنتم خير الناس للناس، وغيركم من أهل الأديان لا يأمرون أنفسهم ولا غيرهم بالمعروف، ولا ينهونهم عن المنكر{2}١٣٤٨. (ز) ١٣٤٨ ذكر ابنُ عطية (٢/٣١٨) أن قوله تعالى: <q>﴿كُنْتُم﴾</q> «على صيغة الماضي، فإنها التي بمعنى الدوام، كما قال: <q>﴿وكانَ اللهُ غَفُورًا رَحِيمًا﴾</q>، إلى غير هذا من الأمثلة». ثم نقل ثلاثة أقوال أخرى: الأول: «كنتم في علم الله». الثاني: «في اللوح المحفوظ». الثالث: «فيما أخبر به الأمم قديمًا عنكم». <q>﴿وَلَوۡ ءَامَنَ أَهۡلُ ٱلۡكِتَـٰبِ لَكَانَ خَیۡرࣰا لَّهُمۚ﴾</q> - تفسير ١٤١٨٨- عن عبد الله بن عباس -من طريق أبي رَوْق، عن الضحاك- قوله: <q>﴿آمن﴾</q>، قال: صدق{32}. (ز) ١٤١٨٩- قال مقاتل بن سليمان: <q>﴿ولو آمن﴾</q> يعني: ولو صدق <q>﴿أهل الكتاب﴾</q> يعني: اليهود بمحمد ﷺ، وما جاء به من الحق، <q>﴿لكان خيرا لهم﴾</q> مِن الكفر{2}. (ز) <q>﴿مِّنۡهُمُ ٱلۡمُؤۡمِنُونَ وَأَكۡثَرُهُمُ ٱلۡفَـٰسِقُونَ ۝١١٠﴾</q> - تفسير ١٤١٩٠- عن سعيد بن جبير -من طريق عطاء- في قول الله تعالى: <q>﴿الفاسقون﴾</q>، يعني: هم العاصون{32}. (ز) ١٤١٩١- عن قتادة بن دِعامة -من طريق شَيْبان- في قوله: <q>﴿منهم المؤمنون﴾</q>، قال: استثنى الله منهم ثلاثة كانوا على الهدى والحق{32}. (٣/٧٢٨) ١٤١٩٢- عن قتادة بن دِعامة -من طريق سعيد- في قوله: <q>﴿وأكثرهم الفاسقون﴾</q>، قال: ذَمَّ الله أكثرَ الناس{39}. (٣/٧٢٨) ١٤١٩٣- قال مقاتل بن سليمان: <q>﴿منهم المؤمنون﴾</q> يعني: عبد الله بن سلام وأصحابه، <q>﴿وأكثرهم الفاسقون﴾</q> يعني: العاصين، يعني: اليهود{2}. (ز) <q>﴿مِّنۡهُمُ ٱلۡمُؤۡمِنُونَ وَأَكۡثَرُهُمُ ٱلۡفَـٰسِقُونَ ۝١١٠﴾</q> - آثار متعلقة بالآية ١٤١٩٤- عن علي بن أبي طالب، قال: قال رسول الله ﷺ: «أُعْطِيت ما لم يُعْطَ أحد من الأنبياء: نُصِرت بالرعب، وأُعْطِيت مفاتيح الأرض، وسُمِّيت أحمد، وجُعِل التراب لي طهورًا، وجُعِلَت أمتي خير الأمم»{41}. (٣/٧٢٧) ١٤١٩٥- عن قتادة بن دِعامة، قال: ذُكِرَ لنا: أن نبي الله ﷺ قال ذات يوم وهو مسند ظهره إلى الكعبة: «نحن نكمل يوم القيامة سبعين أمة، نحن آخرها وخيرها»{42}. (٣/٧٢٧) ١٤١٩٦- عن الحسن البصري -من طريق أبي الأشهب- قال رسول الله ﷺ: «أنتم توفون سبعين أمة، أنتم خيرها وأكرمها على الله»{43}. (ز) ١٤١٩٧- عن الحسن البصري -من طريق مبارك- قال: قال رجل: أعوذ بالله أن أكون كُنتِيًّا. قيل له: ما الكنتي؟ قال: تقول: لقد كنت مرة وكنت. وقرأ الحسن: <q>﴿كنتم خير أمة أخرجت للناس﴾</q>{44}. (ز) ",footnotes:1:أخرجه ابن جرير ٥/٦٧٢، وابن المنذر (٨٠٢).تفسير مقاتل بن سليمان ١/٢٩٥.أخرجه عبد الرزاق ١/١٣٠، وعَبد بن حُمَيد (٤٠٩ - منتخب)، وأحمد ٣٣/٢٢٨، والترمذي (٣٠٠١)، وابن ماجه(٤٢٨٧)، وابن جَرِير ٥/٦٧٦،٦٧٥، وابن المنذر ٧٩٧، وابن أبي حاتم ٣/٧٣١، والطبراني ١٩/٤٢٢، والحاكم ٤/٨٤. وعزاه السيوطي إلى ابن مردويه. حَسَّنه الترمذي، وصححه الحاكم، وقال الألباني في صحيح سنن ابن ماجه (٣٤٦٠): «حسن».أخرجه ابن جرير ٥/٦٧٢-٦٧٣.أخرجه ابن جرير ٥/٦٧١-٦٧٢، وابن أبي حاتم ٣/٧٣٢.أخرجه ابن جرير ٥/٦٧٢، وابن أبي حاتم ٣/٧٣٢.أخرجه ابن أبي حاتم ٣/٧٣٣.أخرجه البخاري (٤٥٥٧)، والنسائي في الكبرى (١١٠٧١)، وابن جرير ٥/٦٧٤، وابن المنذر (٨٠٣)، وابن أبي حاتم ٣/٧٣٢، والحاكم ٤/٨٤. وعزاه السيوطي إلى الفريابي، وعبد بن حميد.أخرجه ابن المنذر (٧٩٩).أخرجه عبد الرزاق ١/١٣٠، وابن أبي شيبة ١٢/١٥٥، وأحمد ٤/٢٧٢، والنسائي في الكبرى (١١٠٧٢)، وابن جرير ٥/٦٧١، ٦٧٢، وابن المنذر (٨٠١)، وابن أبي حاتم ٣/٧٣٢، والحاكم ٢/٢٩٤. وعزاه السيوطي إلى عبد بن حميد، والفريابي.علَّقه ابن أبي حاتم ٣/٧٣٢.أخرجه ابن عدي في الكامل ٦/٢١٤. وعلَّقه ابن المنذر ١/٣٣١.علَّقه ابن أبي حاتم ٣/٧٣٢-٧٣٣.أخرجه ابن جرير ٥/٦٧٣.أخرجه ابن أبي حاتم ٣/٧٣٣.أخرجه ابن أبي حاتم ٣/٧٣٢-٧٣٣.علَّقه ابن وهْب في الجامع ٢/٤٩ (٨٧).أخرجه ابن جرير ٥/٦٧٥.أخرجه ابن جرير ٥/٦٧٥.أخرجه ابن المنذر ١/٣٣٣.أخرجه ابن أبي حاتم ٣/٧٣٣.أخرجه ابن أبي حاتم ٣/٧٣٣، وابن جرير ٥/٦٧٤ مختصرًا من طريق فضيل بن مرزوق. وعزاه السيوطي إلى عبد بن حميد.علَّقه ابن أبي حاتم ٣/٧٣٢-٧٣٣.تفسير البغوي ٤/٩٠، وتفسير الثعلبي ٣/١٢٧.أخرجه ابن جرير ٥/٦٧٤.علَّقه ابن أبي حاتم ٣/٧٣٢-٧٣٣.أخرجه عبد الرزاق في تفسيره ١/١٣٠، وابن المنذر ١/٣٣٠.تفسير مقاتل بن سليمان ١/٢٩٥.تفسير الثعلبي ٣/١٢٧.أخرجه ابن جرير ٥/٦٧٦، وابن المنذر (٨٠٧)، وابن أبي حاتم ٣/٧٣٣-٧٣٤، والبيهقي في الأسماء والصفات (٢٠٦).أخرجه آدم ابن أبي إياس -كما في تفسير مجاهد ص٢٥٧-. وعلَّق ابن أبي حاتم ٣/٧٣٣ أولَه.أخرجه ابن أبي حاتم ٣/٧٣٤.أخرجه ابن جرير ٥/٦٧٣، وابن المنذر (٨٠٨) مختصرًا. وعزاه السيوطي إلى عبد بن حميد.تفسير مقاتل بن سليمان ١/٢٩٥.أخرجه ابن أبي حاتم ٣/٧٣٤.تفسير مقاتل بن سليمان ١/٢٩٥.أخرجه ابن أبي حاتم ٣/٧٣٤.أخرجه ابن أبي حاتم ٣/٧٣٤.أخرجه ابن أبي حاتم ٣/٧٣٤. وعزاه السيوطي إلى عبد بن حميد.تفسير مقاتل بن سليمان ١/٢٩٥.أخرجه أحمد ٢/١٥٦. قال محققو المسند: «بسند حسن».أخرجه ابن جرير ٥/٦٧٦.تفسير ابن أبي زمنين ١/٣١٢.أخرجه ابن المنذر ١/٣٣٠.
3,111," <q>﴿لَن یَضُرُّوكُمۡ إِلَّاۤ أَذࣰىۖ وَإِن یُقَـٰتِلُوكُمۡ یُوَلُّوكُمُ ٱلۡأَدۡبَارَ ثُمَّ لَا یُنصَرُونَ ۝١١١ ضُرِبَتۡ عَلَیۡهِمُ ٱلذِّلَّةُ أَیۡنَ مَا ثُقِفُوۤا۟ إِلَّا بِحَبۡلࣲ مِّنَ ٱللَّهِ وَحَبۡلࣲ مِّنَ ٱلنَّاسِ وَبَاۤءُو بِغَضَبࣲ مِّنَ ٱللَّهِ وَضُرِبَتۡ عَلَیۡهِمُ ٱلۡمَسۡكَنَةُۚ ذَ ٰ⁠لِكَ بِأَنَّهُمۡ كَانُوا۟ یَكۡفُرُونَ بِـَٔایَـٰتِ ٱللَّهِ وَیَقۡتُلُونَ ٱلۡأَنۢبِیَاۤءَ بِغَیۡرِ حَقࣲّۚ ذَ ٰ⁠لِكَ بِمَا عَصَوا۟ وَّكَانُوا۟ یَعۡتَدُونَ ۝١١٢﴾</q> - نزول الآية ١٤١٩٨- قال مقاتل بن سليمان: <q>﴿لن يضروكم إلا أذى﴾</q>، وذلك أن رؤساء اليهود: كعب بن مالك، وشعبة، وبَحْرِيّ، ونعمان، وأبا ياسر، وأبا نافع، وكنانة بن أبى الحُقَيْق، وابن صُورِيا، عمدوا إلى مؤمنيهم فآذوهم لإسلامهم، وهم عبدالله بن سلام وأصحابه، فأنزل الله ﷿: <q>﴿لن يضروكم إلا أذى وإن يقاتلوكم يولوكم الأدبار ثم لا ينصرون﴾</q>{1}. (ز) <q>﴿لَن یَضُرُّوكُمۡ إِلَّاۤ أَذࣰىۖ وَإِن یُقَـٰتِلُوكُمۡ یُوَلُّوكُمُ ٱلۡأَدۡبَارَ ثُمَّ لَا یُنصَرُونَ ۝١١١﴾</q> - تفسير ١٤١٩٩- عن الحسن البصري -من طريق عباد بن منصور- <q>﴿لن يضروكم إلا أذى﴾</q>، قال: تسمعون منهم كَذِبًا على الله، يدعونكم إلى الضلالة{2}. (٣/٧٢٩) ١٤٢٠٠- عن قتادة بن دِعامة -من طريق سعيد- في قوله: <q>﴿لن يضروكم إلا أذى﴾</q>، قال: تسمعونه منهم{3}. (٣/٧٢٨) ١٤٢٠١- عن الربيع بن أنس -من طريق أبي جعفر- قوله: <q>﴿لن يضروكم إلا أذى﴾</q>، قال: أذًى تسمعونه منهم{4}. (ز) ١٤٢٠٢- قال مقاتل بن سليمان: <q>﴿لن يضروكم﴾</q> اليهود <q>﴿إلا أذى﴾</q> باللسان{1}. (ز) ١٤٢٠٣- عن عبد الملك ابن جريج -من طريق حَجّاج- <q>﴿لن يضروكم إلا أذى﴾</q>، قال: إشراكهم في عُزَيْر، وعيسى، والصليب{6}. (٣/٧٢٩) <q>﴿ضُرِبَتۡ عَلَیۡهِمُ ٱلذِّلَّةُ أَیۡنَ مَا ثُقِفُوۤا۟﴾</q> - تفسير ١٤٢٠٤- عن عبد الله بن عباس -من طريق الضحاك- في قوله: <q>﴿ضربت عليهم الذلة﴾</q>، قال: هم أصحاب القَبالات{7}. (٣/٧٢٩) ١٤٢٠٥- عن الضحاك بن مزاحم -من طريق جويبر- <q>﴿ضربت عليهم الذلة﴾</q>، قال: الجزية{8}. (٣/٧٣٠) ١٤٢٠٦- عن عباد بن منصور، قال: سألت الحسن البصري عن قوله: <q>﴿ضربت عليهم الذلة﴾</q>. قال: أذلهم الله فلا مَنَعَة لهم، وجعلهم الله تحت أقدام المسلمين{9}. (٣/٧٢٩) ١٤٢٠٧- عن الحسن البصري -من طريق عوف- قال: أدركتهم هذه الأمة وإنّ المجوس لتجبيهم الجزية{10}. (٣/٧٢٩) ١٤٢٠٨- عن الحسن البصري= (ز) ١٤٢٠٩- وقتادة بن دِعامة -من طريق مَعْمَر- في قوله: <q>﴿ضربت عليهم الذلة﴾</q>، قال: يُعْطُون الجِزْيَة عن يد وهم صاغرون{11}. (٣/٧٢٩) ١٤٢١٠- قال مقاتل بن سليمان: ثم أخبر عن اليهود، فقال سبحانه: <q>﴿ضربت عليهم الذلة﴾</q> يعني: المَذَلَّة، <q>﴿أين ما ثقفوا﴾</q> يعني: وُجِدوا{12}. (ز) <q>﴿إِلَّا بِحَبۡلࣲ مِّنَ ٱللَّهِ وَحَبۡلࣲ مِّنَ ٱلنَّاسِ﴾</q> - تفسير ١٤٢١١- عن عبد الله بن عباس -من طريق هارون بن عنترة، عن أبيه- <q>﴿إلا بحبل من الله وحبل من الناس﴾</q>، قال: بعهد من الله، وعهد من الناس{13}. (٣/٧٣٠) ١٤٢١٢- عن مجاهد بن جبر -من طريق ابن أبي نَجِيح- في قوله -جلَّ وعزَّ-: <q>﴿إلا بحبل من الله﴾</q> قال: بعهد، <q>﴿وحبل من الناس﴾</q> قال: بعهدهم{14}. (ز) ١٤٢١٣- عن الضحاك بن مزاحم -من طريق عبيد بن سليمان- في قوله: <q>﴿إلا بحبل من الله وحبل من الناس﴾</q>، يقول: بعهد من الله، وعهد من الناس{15}. (ز) ١٤٢١٤- عن عكرمة مولى ابن عباس -من طريق عثمان بن غياث- يقول: <q>﴿إلا بحبل من الله وحبل من الناس﴾</q>، قال: بعهد من الله، وعهد من الناس{16}. (ز) ١٤٢١٥- عن الحسن البصري، قال: عهد مِن الله، وعهد مِن الناس{17}. (ز) ١٤٢١٦- عن عطاء [بن أبي رباح] -من طريق ابن جريج-: العهد: حبل الله{18}. (ز) ١٤٢١٧- عن قتادة بن دعامة -من طريق سعيد- <q>﴿إلا بحبل من الله وحبل من الناس﴾</q>، يقول: إلا بعهد من الله، وعهد من الناس{19}. (ز) ١٤٢١٨- عن إسماعيل السُّدِّيّ -من طريق أسباط- <q>﴿إلا بحبل من الله وحبل من الناس﴾</q>، يقول: إلا بعهد من الله، وعهد من الناس{20}. (ز) ١٤٢١٩- عن عطاء الخراساني -من طريق يونس بن يزيد- في قول الله ﷿: <q>﴿بحبل من الله وحبل من الناس﴾</q>، قال: عهد من الله، وعهد من الناس{21}. (ز) ١٤٢٢٠- عن الربيع بن أنس -من طريق أبي جعفر- قوله: <q>﴿إلا بحبل من الله وحبل من الناس﴾</q>، يقول: إلا بعهد من الله، وعهد من الناس{18}. (ز) ١٤٢٢١- قال مقاتل بن سليمان: <q>﴿إلا بحبل من الله وحبل من الناس﴾</q>، يقول: لا يأمنوا حيث ما تَوَجَّهُوا إلا بعهد من الله، وعهد من الناس، يعني: النبي ﷺ وحده{12}. (ز) ١٤٢٢٢- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿أينما ثقفوا إلا بحبل من الله وحبل من الناس﴾</q>، قال: إلا بعهد، وهم يهود. قال: والحبل: العهد. قال: وذلك قول أبي الهيثم بن التَيِّهان لرسول الله ﷺ حين أتته الأنصار في العقبة: أيها الرجل، إنا قاطعون فيك حبالًا بيننا وبين الناس. يقول: عهودًا. قال: واليهود لا يأمنون في أرض من أرض الله إلا بهذا الحبل الذي لله قال ﷿، وقرأ: <q>﴿وجاعل الذين اتبعوك فوق الذين كفروا إلى يوم القيامة﴾</q> [آل عمران: ٥٥]، قال: فليس بلد فيه أحد من النصارى إلا وهم فوق يهود في شرق ولا غرب، هم في البلدان كلها مستذلون، قال الله: <q>﴿وقطعناهم في الأرض أمما﴾</q> [الأعراف: ١٦٨] قال: يهود{24}. (ز) ١٤٢٢٣- عن علي بن خلف قال: سمعت سفيان بن عيينة يفسر حبل الله، قال: عهد الله. وقرأ: <q>﴿إلا بحبل من الله وحبل من الناس﴾</q>، قال: إلا بعهد من الله، وعهد من الناس{25}. (ز) <q>﴿وَبَاۤءُو بِغَضَبࣲ مِّنَ ٱللَّهِ﴾</q> - تفسير ١٤٢٢٤- عن سعيد بن جبير -من طريق عطاء بن دينار- في قول الله تعالى: <q>﴿وباءوا بغضب من الله﴾</q>، يقول: استوجبوا سخطه{26}. (ز) ١٤٢٢٥- عن الضحاك بن مُزاحِم -من طريق جويبر- <q>﴿وباءوا بغضب من الله﴾</q>، قال: اسْتَحَقُّوا الغضب مِن الله{27}. (ز) ١٤٢٢٦- عن الربيع بن أنس -من طريق أبي جعفر- <q>﴿وباؤوا بغضب من الله﴾</q>: فحَدَثَ عليهم من الله غضب{26}. (ز) ١٤٢٢٧- قال مقاتل بن سليمان: <q>﴿وباءوا بغضب من الله﴾</q>، يعني: استوجبوا الغضب من الله{12}. (ز) <q>﴿وَضُرِبَتۡ عَلَیۡهِمُ ٱلۡمَسۡكَنَةُۚ﴾</q> - تفسير ١٤٢٢٨- عن أبي العالية الرِّياحِيّ -من طريق الربيع- قوله: <q>﴿وضربت عليهم المسكنة﴾</q>، قال: المسكنة: الفاقة{26}. (ز) ١٤٢٢٩- وعن إسماعيل السُّدِّيّ= (ز) ١٤٢٣٠- والربيع بن أنس، نحو ذلك{31}. (ز) ١٤٢٣١- عن الضحاك بن مزاحم -من طريق جويبر- <q>﴿المسكنة﴾</q>، قال: الجزية{26}. (ز) ١٤٢٣٢- عن عطية العوفي -من طريق عبيد بن الطفيل- قوله: <q>﴿وضربت عليهم المسكنة﴾</q>، قال: الخَراج{26}. (ز) ١٤٢٣٣- قال مقاتل بن سليمان: <q>﴿وضربت عليهم﴾</q> الذلة و<q>﴿المسكنة﴾</q>، يعني: الذل والفقر{34}. (ز) <q>﴿ذَ ٰ⁠لِكَ بِأَنَّهُمۡ كَانُوا۟ یَكۡفُرُونَ بِـَٔایَـٰتِ ٱللَّهِ وَیَقۡتُلُونَ ٱلۡأَنۢبِیَاۤءَ بِغَیۡرِ حَقࣲّۚ﴾</q> - تفسير ١٤٢٣٤- عن عبد الله بن مسعود –من طريق أبي مَعْمَر الأزْدِي- قال: كانت بنو إسرائيل تقتل في اليوم ثلاثمائة نبي، ثم يقوم سوق بَقْلِهم من آخر النهار{26}. (ز) ١٤٢٣٥- قال مقاتل بن سليمان: <q>﴿ذلك﴾</q> الذي نزل بهم <q>﴿بأنهم كانوا يكفرون بآيات الله ويقتلون الأنبياء بغير حق﴾</q>{36} ١٣٤٩. (ز) ١٣٤٩ ذكر ابنُ عطية (٢/٣٢١-٣٢٢) أن قوله تعالى: <q>﴿بآيات الله﴾</q> يحتمل معنيين: الأول: «أن يراد بها: المتلوّة». والثاني: «أن يريد: العِبَر التي عرضت عليهم». <q>﴿ذَ ٰ⁠لِكَ بِمَا عَصَوا۟ وَّكَانُوا۟ یَعۡتَدُونَ ۝١١٢﴾</q> - تفسير ١٤٢٣٦- عن قتادة بن دِعامة -من طريق سعيد- في قوله: <q>﴿ذلك بما عصوا وكانوا يعتدون﴾</q>، قال: اجتَنِبوا المعصية والعدوان، فإن بهما أُهْلِك من أُهْلِك من قبلكم من الناس{37}١٣٥٠. (٣/٧٣٠) ١٣٥٠ يرى ابنُ جرير (٥/٦٨٨-٦٨٩) بأن اسم الإشارة <q>﴿ذلك﴾</q> في قوله تعالى: <q>﴿ذَلِكَ بِما عَصَوْا وكانُوا يَعْتَدُونَ﴾</q> راجع إلى الشيء الذي أشير إليه بـ<q>﴿ذلك﴾</q> في قوله تعالى: <q>﴿ذَلِكَ بِأَنَّهُمْ كانُوا يَكْفُرُونَ بِآياتِ اللَّهِ ويَقْتُلُونَ الأَنْبِياءَ بِغَيْرِ حَقٍّ﴾</q>، أي: أنّ ما تحملوه من غضب الله وضرب الذلة والمسكنة عليهم، بسبب كفرهم، وقتلهم الأنبياء، ومعصيتهم ربهم، واعتدائهم في شرع ربهم، فاسم الإشارة الثاني عنده تأكيد للأول، وهو معنى قول قتادة. واستدرك ابنُ عطية (٢/٣٢٢) على ابن جرير، فقال بعدما ذكر قولَه: «والذي أقول: إن الإشارة بـ<q>﴿ذلِكَ﴾</q> الأخير إنما هي إلى كفرهم وقتلهم، وذلك أنّ الله تعالى استدرجهم، فعاقبهم على العصيان والاعتداء بالمصير إلى الكفر وقتل الأنبياء، وهو الذي يقول أهل العلم: إن الله تعالى يعاقب على المعصية بالإيقاع في معصية، ويجازي على الطاعة بالتوفيق إلى طاعة». ١٤٢٣٧- قال مقاتل بن سليمان: <q>﴿ذلك﴾</q> الذي أصابهم <q>﴿بما عصوا وكانوا يعتدون﴾</q> في دينهم{34}. (ز) ",footnotes:1:تفسير مقاتل بن سليمان ١/٢٩٥.أخرجه ابن جرير ٥/٦٧٩-٦٨٠، وابن أبي حاتم ٣/٧٣٤.أخرجه ابن جرير ٥/٦٧٩. وعلَّقه ابن أبي حاتم ٣/٧٣٤. وعزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ٥/٦٧٩.تفسير مقاتل بن سليمان ١/٢٩٥.أخرجه ابن جرير ٥/٦٧٩-٦٨٠، وابن أبي حاتم ٣/٧٣٥ من طريق ابن ثور.أخرجه ابن أبي حاتم ٣/٧٣٥، ولفظه: هم أصحاب القبالات، كفروا بالله العظيم.أخرجه ابن المنذر ١/٣٣٥. وفي لفظ آخر ١/٣٣٧: <q>﴿الذلة والمسكنة﴾</q>: الجزية.أخرجه ابن جرير ٥/٦٨١، وابن أبي حاتم ٣/٧٣٥.أخرجه ابن جرير ٥/٦٨١، وابن المنذر (٨١١)، وابن أبي حاتم ٣/٧٣٥. وعزاه السيوطي إلى عبد بن حميد.أخرجه ابن أبي حاتم ٣/٧٣٥.تفسير مقاتل بن سليمان ١/٢٩٥-٢٩٦.أخرجه ابن المنذر (٨١٣)، وابن جرير ٥/٦٨٣، وابن أبي حاتم ٣/٧٣٥.أخرجه ابن جرير ٥/٦٨٢-٦٨٣ من طريق ابن جريج، وعبد الرزاق ١/١٣٠ من طريق معمر، وعبد بن حميد ص٥١ بلفظ: بعهد من الله. وعلَّقه ابن أبي حاتم ٣/٣٣٥.أخرجه ابن جرير ٥/٦٨٤. وعلَّقه ابن المنذر ١/٣٣٦، وابن أبي حاتم ٣/٣٣٥.أخرجه ابن جرير ٥/٦٨٢. وعلَّقه ابن أبي حاتم ٣/٣٣٥.علَّقه ابن أبي حاتم ٣/٣٣٥.أخرجه ابن جرير ٥/٦٨٣. وعلَّقه ابن أبي حاتم ٣/٣٣٥.أخرجه ابن جرير ٥/٦٨٢، وعبد بن حميد ص٥١ بلفظ: بعهد من الله. وعلَّقه ابن المنذر ١/٣٣٦، وابن أبي حاتم ٣/٣٣٥.أخرجه ابن جرير ٥/٦٨٣. وعلَّقه ابن أبي حاتم ٣/٣٣٥. وذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ١/٣١٢-.أخرجه أبو جعفر الرملي في جزئه ص١٠٢ (تفسير عطاء الخراساني). وعلَّقه ابن أبي حاتم ٣/٣٣٥.أخرجه ابن جرير ٥/٦٨٣. وعلَّقه ابن أبي حاتم ٣/٣٣٥.تفسير مقاتل بن سليمان ١/٢٩٥-٢٩٦.أخرجه ابن جرير ٥/٦٨٣.أخرجه أبو نعيم في أخبار أصبهان ٢/٧.أخرجه ابن أبي حاتم ٣/٣٣٦.أخرجه ابن المنذر ١/٣٣٦. وعلَّقه ابن أبي حاتم ٣/٣٣٦ بلفظ: استوجبوا.أخرجه ابن أبي حاتم ٣/٣٣٦.تفسير مقاتل بن سليمان ١/٢٩٥-٢٩٦.أخرجه ابن أبي حاتم ٣/٣٣٦.علَّقه ابن أبي حاتم ٣/٣٣٦.أخرجه ابن أبي حاتم ٣/٣٣٦.أخرجه ابن أبي حاتم ٣/٣٣٦.تفسير مقاتل بن سليمان ١/٢٩٦.أخرجه ابن أبي حاتم ٣/٣٣٦.تفسير مقاتل بن سليمان ١/٢٩٦. وقد تقدمت الآثار بتفصيل أكثر عند تفسير نظير هذه الآية في سورة البقرة: <q>﴿وضُرِبَتْ عَلَيْهِمُ الذِّلَّةُ والمَسْكَنَةُ وباءُوا بِغَضَبٍ مِنَ اللَّهِ ذَلِكَ بِأَنَّهُمْ كانُوا يَكْفُرُونَ بِآياتِ اللَّهِ ويَقْتُلُونَ النَّبِيِّينَ بِغَيْرِ الحَقِّ ذَلِكَ بِما عَصَوْا وكانُوا يَعْتَدُونَ﴾</q> [البقرة:٦١]، وقد أحال إليها ابن جرير ٥/٦٨٨، بينما كررها ابن أبي حاتم كعادته.أخرجه ابن المنذر (٨٢١)، وابن جرير ٥/٦٨٩، وابن أبي حاتم ٣/٣٣٧.تفسير مقاتل بن سليمان ١/٢٩٦.
  3,112,""
3,113," <q>﴿لَیۡسُوا۟ سَوَاۤءࣰۗ مِّنۡ أَهۡلِ ٱلۡكِتَـٰبِ أُمَّةࣱ قَاۤىِٕمَةࣱ یَتۡلُونَ ءَایَـٰتِ ٱللَّهِ ءَانَاۤءَ ٱلَّیۡلِ وَهُمۡ یَسۡجُدُونَ ۝١١٣﴾</q> - نزول الآية ١٤٢٣٨- عن عبد الله بن عباس -من طريق ابن إسحاق بسنده- قال: لَمّا أسلم عبدُ الله بنُ سلام، وثعلبة بن سَعْيَةَ، وأسد بن سَعْيَةَ، وأسد بن عبيد، ومَن أسلم مِن يهود معهم، فآمنوا وصدَّقوا ورغِبوا في الإسلام؛ قالت أحبارُ يهود وأهلُ الكفر منهم: ما آمن بمحمد وتبِعه إلا أشرارُنا، ولو كانوا خيارنا ما تركوا دين آبائهم وذهبوا إلى غيره. فأنزل الله في ذلك: <q>﴿ليسوا سواء﴾</q> إلى قوله: <q>﴿وأولئك من الصالحين﴾</q>{1}١٣٥١. (٣/٧٣٠) ١٣٥١ رجَّح ابنُ جرير (٥/٦٨٩-٦٩٣) مستندًا إلى لغة العرب، وأقوال السلف أنّ <q>﴿لَيْسُوا سَواءً﴾</q>: إخبارٌ عن مؤمني أهل الكتاب وأهل الكفر منهم، وأنّ المقصودين بقوله تعالى: <q>﴿مِن أهْلِ الكِتابِ أُمَّةٌ قائِمَةٌ﴾</q> هم مَن أسلم مِن اليهود فَحَسُن إسلامهم، كعبد الله بن سلام وأصحابه، وهو قول ابن عباس، وقتادة، وابن جريج. ونحوه قال ابنُ عطية (٢/٣٢٤)، حيث قال: «وهو أصحُّ التَّأويلات». غير أنّ ابن عطية بعد أن ذكر قول ابن مسعود، والسدي من طريق أسباط، أنّ المعنى: ليس اليهود وأمة محمد سواء. وجَّه قولهما قائلًا: «فمِن حيث تَقَدُّم ذِكْر هذه الأمة في قوله: <q>﴿كُنْتُمْ خَيْرَ أُمَّةٍ﴾</q>، وذِكْر أيضًا اليهود، قال الله لنبيه: <q>﴿لَيْسُوا سَواءً﴾</q>، والكتاب على هذا جنس كُتُبِ الله، وليس بالمعهود مِن التوراة والإنجيل فقط. والمعنى: مِن أهل الكتاب -وهم أهل القرآن- أمة قائمة». ١٤٢٣٩- عن عبد الله بن عباس -من طريق عطاء- قال: بَلَغَنِي: أنّ هذه الآية <q>﴿ليسوا سواء من أهل الكتاب أمة قائمة يتلون آيات الله آناء الليل﴾</q> نزلت ما بين المغرب والعشاء{2}. (ز) ١٤٢٤٠- عن منصور [بن المعتمر] -من طريق سفيان الثوري- قال: بَلَغَنِي: أنّها نزلت <q>﴿يتلون آيات الله آناء الليل وهم يسجدون﴾</q> فيما بين المغرب والعشاء{3}. (٣/٧٣٤) ١٤٢٤١- قال مقاتل بن سليمان: <q>﴿ليسوا سواء من أهل الكتاب﴾</q>، وذلك أنّ اليهود قالوا لابن سلام وأصحابه: لقد خسِرتُم حين استبدلتُم بدينكم دينًا غيرَه، وقد عاهدتم الله بعهد ألا تدينوا إلا بدينكم. فقال الله ﷿: <q>﴿ليسوا سواء﴾</q>{4}. (ز) ١٤٢٤٢- عن عبد الملك ابن جُرَيْج -من طريق حجاج- في قوله: <q>﴿أمة قائمة﴾</q>، قال: عبد الله بن سلام، وثعلبة بن سلام أخوه، وسَعْيَةَ، ومبشر، وأسيد وأسد ابنا كعب{5}. (٣/٧٣١) ١٤٢٤٣- عن أبي الحسن -من طريق حفص بن ميسرة- أنّه قال في قول الله: <q>﴿ليسوا سواء من أهل الكتاب أمة قائمة يتلون آيات الله أناء الليل وهم يسجدون يؤمنون بالله واليوم الآخر ويأمرون بالمعروف﴾</q> الآية كلها، قال: [نزلت] ما بين المغرب والعشاء{6}. (ز) <q>﴿لَیۡسُوا۟ سَوَاۤءࣰۗ مِّنۡ أَهۡلِ ٱلۡكِتَـٰبِ أُمَّةࣱ قَاۤىِٕمَةࣱ یَتۡلُونَ ءَایَـٰتِ ٱللَّهِ ءَانَاۤءَ ٱلَّیۡلِ وَهُمۡ یَسۡجُدُونَ ۝١١٣﴾</q> - تفسير الآية ١٤٢٤٤- عن عبد الله بن مسعود -من طريق الحسن بن يزيد العِجْلِيِّ- في قوله: <q>﴿ليسوا سواء من أهل الكتاب أمة قائمة﴾</q>، قال: لا يستوي أهلُ الكتاب وأُمَّةُ محمد{7}. (٣/٧٣٢) ١٤٢٤٥- عن الحسن البصري -من طريق أبي الأَشْهَب- <q>﴿ليسوا سواء من أهل الكتاب أمة قائمة﴾</q>، قال: هؤلاء أهل الهدى، ليس كُلُّ القوم هَلَك. فقرأ حتى بلغ: <q>﴿وما يفعلوا من خير فلن يكفروه﴾</q>. قال: فزعوا إلى أنفسهم حين تفرَّقتْ أُمَّتُهم{8}. (ز) ١٤٢٤٦- عن قتادة بن دِعامة -من طريق سعيد- في قوله: <q>﴿ليسوا سواء﴾</q> الآية، يقول: ليس كُلُّ القوم هلَك، قد كان لله فيهم بَقِيَّةٌ{9}. (٣/٧٣١) ١٤٢٤٧- عن إسماعيل السُّدِّيِّ -من طريق أسباط- في الآية، يقول: هؤلاء اليهود ليسوا كمثل هذه الأُمَّةِ التي هي قانِتةٌ لله{10}. (٣/٧٣١) ١٤٢٤٨- عن أبي الأشهب [جعفر بن حيّان العُطارِدِيّ] -من طريق سعيد بن سليمان النَّشِيطِيِّ- قال: ليس كُلُّ القوم هلك{11}. (ز) ١٤٢٤٩- قال مقاتل بن سليمان: ثُمَّ أخبر عنهم، فقال سبحانه: <q>﴿ليسوا سواء﴾</q>. يقول: ليس كفار اليهود والذين في الضلالة بمنزلة ابن سلام وأصحابه؛ الذين هم على دين الله{4}. (ز) <q>﴿مِّنۡ أَهۡلِ ٱلۡكِتَـٰبِ أُمَّةࣱ قَاۤىِٕمَةࣱ﴾</q> - تفسير ١٤٢٥٠- عن عبد الله بن عباس -من طريق العوفي- <q>﴿أمة قائمة﴾</q>، يقول: مُهْتَدِيَةٌ قائِمَةٌ على أمر الله، لم تنزِع عنه وتتركْه كما تركه الآخرون وضيَّعوه{13}. (٣/٧٣١) ١٤٢٥١- عن مجاهد بن جبر -من طريق ابن أبي نَجيح- <q>﴿أمة قائمة﴾</q>، قال: عادِلة{14}. (٣/٧٣٢) ١٤٢٥٢- عن قتادة بن دِعامة -من طريق سعيد- في قوله: <q>﴿قائمة﴾</q>، قال: على كتاب الله، وحدود الله، وفرائض الله، وطاعة الله، يؤمنون بالله{15}١٣٥٢. (ز) ١٣٥٢ اختلف في معنى: <q>﴿قائمة﴾</q> في هذه الآية على أقوال: الأول: عادلة. الثاني: قائمة على كتاب الله وما أمر به فيه. الثالث: مطيعة. ورجَّح ابنُ جرير (٥/٦٩٤-٦٩٥) مستندًا إلى نظيره من السنة القول الثاني، وهو قول ابن عباس، وقتادة من طريق سعيد، والربيع، ثم استدل قائلًا: «ونظير ذلك الخبرُ الذي رواه النعمان بن بشير عن النبي ﷺ أنّه قال: «مَثَلُ القائم على حدود الله والواقع فيها كمَثَلِ قوم ركبوا سفينةً». ثم ضرب لهم مثلًا، فالقائم على حدود الله هو الثابت على التمسك بما أمر الله به واجتناب ما نهاه الله عنه». ووجَّه الأقوال الأخرى بأنها متقاربة المعنى، «وذلك أنّ معنى قوله: <q>﴿قائِمَةٌ﴾</q>: مستقيمة على الهدى وكتاب الله وفرائضه وشرائع دينه، بالعدل والطاعة، وغير ذلك مِن أسباب الخير مِن صفة أهل الاستقامة على كتاب الله وسنة رسول الله ﷺ». ووجَّه ابن عطية (٢/٣٢٤) الأقوال الثلاثة بقوله: «وهذا كلُّه يرجع إلى معنًى واحد من الاعتدال على أمر الله». ثُمَّ ذكر احتمالَيْن في معنى الآية بناءً على هذا التوجيه، فقال: «وهذه الآيةُ تحتملُ هذا المعنى، وألّا تنظرَ اللفظةَ إلى هيئة الأشخاص وقت تلاوة آيات الله، ويحتمل أنْ يُراد بـ<q>﴿قائِمَةٌ﴾</q> وصف حال التالين في آناءَ اللَّيْلِ، ومَن كانت هذه حالُه فلا محالة أنّه مُعْتَدِلٌ على أمْر الله. وهذه الآية في هذين الاحتمالين مثل ما تقدم في قوله: <q>﴿إلا ما دُمْتَ عَلَيْهِ قائِمًا﴾</q> [آل عمران:٧٥]». ١٤٢٥٣- عن إسماعيل السُّدِّيّ -من طريق أسباط- <q>﴿أمة قائمة﴾</q> الآية، يقول: ليس هؤلاء اليهود كمثل هذه الأمة التي هي قائمة لله. والقائمةُ: المطيعةُ{5}. (ز) ١٤٢٥٤- عن الربيع بن أنس -من طريق أبي جعفر- <q>﴿أمة قائمة﴾</q>، يقول: قائمة على كتابِ الله، وحدودِه، وفرائضِه{13}. (٣/٧٣٢) ١٤٢٥٥- قال مقاتل بن سليمان: <q>﴿ليسوا سواء﴾</q>، يقول: ليس كفارُ اليهود والذين في الضلالة بمنزلة ابنِ سلام وأصحابه الذين هم على دين الله، منهم <q>﴿أمة﴾</q> عصابة <q>﴿قائمة﴾</q> بالحق على دين الله، عادِلةٌ{4}. (ز) ١٤٢٥٦- قال ابن وهب: وسمعتُ مالك [بن أنس] يقول في قول الله: <q>﴿ليسوا سواء من أهل الكتاب أمة قائمة﴾</q>، قال: قائمة بالحقِّ{19}. (ز) <q>﴿یَتۡلُونَ ءَایَـٰتِ ٱللَّهِ ءَانَاۤءَ ٱلَّیۡلِ وَهُمۡ یَسۡجُدُونَ ۝١١٣﴾</q> - تفسير ١٤٢٥٧- عن عبد الله بن مسعود، قال: أخَّر رسول الله ﷺ ليلةً صلاة العشاء، ثُمَّ خرج إلى المسجد، فإذا الناسُ ينتظرون الصلاة، فقال: «أما إنّه ليس من أهل هذه الأديان أحد يذكرُ اللهَ هذه الساعة غيركم». -وفي لفظ: «إنه لا يصلي هذه الصلاةَ أحدٌ من أهل الكتاب»-. قال: وأنزلت هذه الآية: <q>﴿ليسوا سواء من أهل الكتاب أمة قائمة﴾</q> حتى بلغ <q>﴿والله عليم بالمتقين﴾</q>{20}. (٣/٧٣٣) ١٤٢٥٨- عن عبد الله بن مسعود -من طريق الحسن بن يزيد العِجْلِيِّ- في قوله: <q>﴿يتلون آيات الله آناء الليل﴾</q>، قال: صلاة العَتَمة، هُم يُصَلُّونها، ومَن سواهم مِن أهل الكتاب لا يصلونها{21}. (٣/٧٣٢) ١٤٢٥٩- عن عبد الله بن مسعود -من طريق الأسود- في قوله: <q>﴿يتلون آيات الله آناء الليل﴾</q>، قال: هي صلاة الغفلة{22}. (٣/٧٣٥) ١٤٢٦٠- عن عبد الله بن عباس -من طريق قابوس، عن أبيه- في قوله: <q>﴿آناء الليل﴾</q>، قال: جَوْف الليل{23}. (٣/٧٣٢) ١٤٢٦١- عن الحسن البصري -من طريق عباد بن منصور- قوله: <q>﴿آناء الليل﴾</q>، قال: ساعات مِن أوَّلِه وآخرِه{24}. (ز) ١٤٢٦٢- عن قتادة بن دِعامة -من طريق سعيد- <q>﴿يتلون آيات الله آناء الليل﴾</q>، أي: ساعات الليل{25}. (ز) ١٤٢٦٣- عن ابن كثير المكِّيِّ -من طريق ابن جُرَيْج- سمعنا العربَ تقول: آناء الليل: ساعات الليل{26}. (ز) ١٤٢٦٤- عن إسماعيل السُّدِّيّ -من طريق أسباط- <q>﴿يتلون آيات الله آناء الليل﴾</q>، قال: أمّا آناء الليل: فجَوْفُ الليل{27}١٣٥٣. (ز) ١٣٥٣ انتَقَدَ ابنُ عطية (٢/٣٢٥) قول السدي، فقال: «وهذا قلِق». غير أنه ذَكَر له وجْهًا يمكن أنْ يُحمَل عليه، بأن يكون فسَّر الآناء بجزءٍ مِن معناه، فقال: «أما إنّ جوف الليل جُزءٌ مِن الآناء». ١٤٢٦٥- عن الربيع بن أنس -من طريق أبي جعفر- في قوله: <q>﴿يتلون آيات الله آناء الليل﴾</q>، قال: قال بعضهم: صلاة العَتَمَةِ يصليها أُمَّةُ محمد ﷺ، ولا يُصَلِّيها غيرُهم مِن أهل الكتاب{28}١٣٥٤. (٣/٧٣٣) ١٣٥٤ وجَّه ابنُ جرير (٥/٦٩٨) الآثار الواردة في معنى: <q>﴿آناءَ اللَّيْلِ﴾</q> بأنها على اختلافها متقاربة المعنى، وجمع بينها، فقال: «وذلك أنّ الله -تعالى ذِكْرُه- وصف هؤلاء القوم بأنهم يتلون آيات الله في ساعات الليل، وهي: آناؤه، وقد يكون تاليها في صلاة العشاء تاليًا لها آناء الليل، وكذلك مَن تلاها فيما بَيْن المغرب والعشاء، ومَن تلاها جوفَ الليل، فكلٌّ تالٍ لها ساعات الليل». غير أنه رَجَّح مستندًا إلى السنة قولَ مَن قال: إنّها تلاوة القرآن في صلاة العشاء. مستدلاًّ بأنّها صلاةٌ لا يصليها أحدٌ مِن أهل الكتاب، كما جاء في حديث ابن مسعود، ثُمَّ قال: «فوصف الله -جلَّ ثناؤه- أُمَّةَ محمد ﷺ بأنهم يُصَلُّونها دون أهل الكتاب الذين كفروا بالله ورسوله». ١٤٢٦٦- عن الربيع بن أنس -من طريق أبي جعفر- <q>﴿آناء الليل﴾</q>، قال: ساعات الليل{29}. (٣/٧٣٢) ١٤٢٦٧- قال مقاتل بن سليمان: <q>﴿يتلون آيات الله﴾</q> يعني: يقرؤون كلام الله <q>﴿آناء الليل﴾</q> يعني: ساعات الليل، <q>﴿وهم يسجدون﴾</q> يعني: يُصَلُّون بالليل{4}١٣٥٥. (ز) ١٣٥٥ فسَّر مقاتل <q>﴿وهم يسجدون﴾</q>، أي: يصلون بالليل. وذكر ابنُ جرير (٥/٦٩٨-٦٩٩) هذا المعنى عن بعض أهل العربية، ولم يُسنِده عن مقاتل، ثم انتقده مستندًا إلى المعنى الأشهر للسجود، وبيَّن أنّ المعنى: مِن أهل الكتاب أمة قائمة يتلون آيات الله آناء الليل في صلاتهم، وهم مع ذلك يسجدون فيها. فالسجود هو السجود المعروف في الصلاة. وحَسَّن ابن عطية (٢/٣٢٦) المعنى الذي ذهب إليه ابنُ جرير مِن جهةِ العقلِ، فقال: «مِن جهة أنّ التلاوة آناء الليل قد يعتقد السامعُ أنّ ذلك في غير الصلاة». <q>﴿یَتۡلُونَ ءَایَـٰتِ ٱللَّهِ ءَانَاۤءَ ٱلَّیۡلِ وَهُمۡ یَسۡجُدُونَ ۝١١٣﴾</q> - آثار متعلقة بالآية ١٤٢٦٨- عن معاذ بن جبل، قال: أخَّر رسولُ الله ﷺ صلاة العَتَمَةِ ليلةً، حتى ظنَّ الظانُّ أن قد صلّى، ثُمَّ خرج، فقال: «أعْتِمُواْ{31} بهذه الصلاة؛ فإنّكم فُضِّلْتُم بها على سائر الأُمَم، ولم تُصَلِّها أُمَّةٌ قبلكم»{32}. (٣/٧٣٣) ١٤٢٦٩- عن عبد الله بن عباس: أنّ النبي ﷺ أخَّر صلاة العشاء، ثُمَّ خرج، فقال: «ما يحبِسُكم هذه الساعة؟». قالوا: يا نبي الله، انتظرناك لنشهد الصلاة معك. فقال لهم: «ما صَلّى صلاتُكم هذه أُمَّةٌ قَطُّ قبلكم، وما زلتم في صلاة بعدُ»{33}. (٣/٧٣٤) ",footnotes:1:أخرجه الطبراني في الكبير ٢/٨٧ (١٣٨٨)، وابن جرير ٥/٦٩١، وابن أبي حاتم ٣/٧٣٧ (٤٠٠٣)، من طريق محمد بن إسحاق، عن محمد ابن أبي محمد مولى زيد بن ثابت، عن سعيد بن جبير أو عكرمة، عن ابن عباس به. قال الهيثمي في المجمع ٦/٣٢٧ (١٠٨٩٩): «رجاله ثقات».أخرجه سفيان الثوري في التفسير ص٧٩ من طريق ابن جريج، عن عطاء بن أبي رباح، عن ابن عباس به. وسنده صحيح.أخرجه عبد الرزاق ١/١٣١، وابن جرير ٥/٦٩٨، وابن المنذر ١/٣٣٩، وابن أبي حاتم ٣/٧٣٩ بلفظ: بلغني أنهم كانوا يصلون بين المغرب والعشاء. وعزاه السيوطي إلى عبد بن حميد.تفسير مقاتل بن سليمان ١/٢٩٦.أخرجه ابن جرير ٥/٦٩٤.أخرجه ابن وهب في الجامع - تفسير القرآن ١/٣٥ (٧١).أخرجه البخاري في تاريخه ٢/٣٠٨، وابن جرير ٥/٦٩٢، ٦٩٧، وابن المنذر (٨٢٣)، وابن أبي حاتم ٣/٧٣٧، ٧٣٩. وعزاه السيوطي إلى عَبد بن حُمَيد، والفريابي.أخرجه عبد بن حميد ص٥١، وابن المنذر ١/٣٤١-٣٤٢، وعلَّق أوله ابن أبي حاتم ٣/٧٣٧، وأخرج آخره ٣/٧٣٩.أخرجه ابن جرير ٥/٦٩٢. وعزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ٥/٦٩٣-٦٩٤، وابن أبي حاتم ٣/٧٣٧ واللفظ له.أخرجه ابن أبي حاتم ٣/٧٣٧.تفسير مقاتل بن سليمان ١/٢٩٦.أخرجه ابن جرير ٥/٦٩٤، وابن أبي حاتم ٣/٧٣٨.أخرجه ابن جرير ٥/٦٩٣، وابن أبي حاتم (ت: حكمت بشير) ٢/٤٨٦. وعزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ٥/٦٩٤، وابن المنذر ١/٣٤٠ واللفظ له.أخرجه ابن جرير ٥/٦٩٤.أخرجه ابن جرير ٥/٦٩٤، وابن أبي حاتم ٣/٧٣٨.تفسير مقاتل بن سليمان ١/٢٩٦.أخرجه ابن وهب في الجامع ٢/١٣٣-١٣٤ (٢٦٤).أخرجه أحمد ٦/٣٠٤ (٣٧٦٠)، وابن المنذر ١/٣٣٨ (٨٢٢)، وابن جرير ٥/٦٩٧-٦٩٨ من طريق عاصم بن أبي النجود، عن زر بن حبيش، عن ابن مسعود به. قال البزار في مسنده ٥/٢١٦-٢١٧ (١٨١٩): «الحديث لا نعلم رواه عن عاصم بهذا الإسناد إلا شيبان». وصححه ابن حبان ٤/٣٩٧ (١٥٣٠). وقال ابن رجب في فتح الباري ٤/٣٧٤: «خرجه يعقوب بن شيبة في مسنده، وقال: صالح الإسناد». وقال السيوطي: «سند حسن».أخرجه البخاري في تاريخه ٢/٣٠٨، وابن جرير ٥/٦٩٢، ٦٩٧، وابن المنذر (٨٢٣)، وابن أبي حاتم ٣/٧٣٧، ٧٣٩ مختصرًا من طريق الحسن ابن أبي يزيد العجلي. وعزاه السيوطي إلى عبد بن حميد، والفريابي.أخرجه الثوري في تفسيره ص٨٠، وابن أبي حاتم ٣/٧٣٨-٧٣٩.أخرجه ابن أبي شيبة ١٣/٣٧٠، وأحمد ٣/٤١٦، وابن المنذر (٨٣٠)، وابن أبي حاتم ٣/٧٣٨. وعزاه السيوطي إلى ابن نصر.أخرجه ابن أبي حاتم ٣/٧٣٩.أخرجه ابن جرير ٥/٦٩٦، وابن المنذر ١/٣٤١. وعلَّقه ابن أبي حاتم ٣/٧٣٩.أخرجه ابن جرير ٥/٦٩٦.أخرجه ابن جرير ٥/٦٩٦. وعلَّقه ابن أبي حاتم ٣/٧٣٨.أخرجه ابن أبي حاتم ٣/٧٣٨.أخرجه ابن جرير ٥/٦٩٦. وعلَّقه ابن أبي حاتم ٣/٧٣٩.تفسير مقاتل بن سليمان ١/٢٩٦.أي: أخّروها إلى وقت العتمة، وهي ثلث الليل الأوّل بعد غيبوبة الشفق. اللسان (عتم).أخرجه أحمد ٣٦/٣٨٥-٣٨٦ (٢٢٠٦، ٢٢٠٦٧)، وأبو داود ١/٣١٤ (٤٢١). قال مغلطاي في شرح سنن ابن ماجه ٣/١٠٣٦: «سكت عنه الإشبيلي مُصَحِّحًا له، وعاب ذلك عليه ابنُ القَطّان، وزعم أنّ عاصمًا لا يعرف أنه ثقة». وقال المناوي في التيسير ١/١٦٨: «إسناده حسن». وقال الألباني في صحيح أبي داود ٢/٢٩٥-٢٩٦ (٤٤٨): «إسناده صحيح».أخرجه الطبراني في الكبير ١١/٥٣ (١١٠٢٣)، وفي مسند الشاميين ٣/١١٢ (١٨٩٥)، والضياء المقدسي في المختارة ١١/٦١ (٥٣). قال الهيثمي في المجمع ١/٣١٣ (١٧٥٠): «رجاله مُوَثَّقون». وقال السيوطي: «سند حسن».
3,114," <q>﴿یُؤۡمِنُونَ بِٱللَّهِ وَٱلۡیَوۡمِ ٱلۡـَٔاخِرِ وَیَأۡمُرُونَ بِٱلۡمَعۡرُوفِ وَیَنۡهَوۡنَ عَنِ ٱلۡمُنكَرِ﴾</q> - تفسير ١٤٢٧٠- عن سعيد بن جبير -من طريق عطاء- في قوله: <q>﴿يؤمنون بالله﴾</q> قال: يصدقون بتوحيد الله، <q>﴿واليوم الآخر﴾</q> ويُصَدِّقون بالغيب الذي فيه جزاءُ الأعمال{1}. (ز) ١٤٢٧١- قال مقاتل بن سليمان: <q>﴿يؤمنون بالله﴾</q> يعني: يُصَدِّقون بتوحيد الله، <q>﴿واليوم الآخر﴾</q> يعني: والبعث الذي فيه جزاءُ الأعمال، <q>﴿ويأمرون بالمعروف﴾</q> يعني: إيمانًا بمحمد ﷺ، <q>﴿وينهون عن المنكر﴾</q> يعني: عن تكذيبٍ بمحمد ﷺ{2}. (ز) <q>﴿وَیُسَـٰرِعُونَ فِی ٱلۡخَیۡرَ ٰ⁠تِۖ وَأُو۟لَـٰۤىِٕكَ مِنَ ٱلصَّـٰلِحِینَ ۝١١٤﴾</q> - تفسير ١٤٢٧٢- عن الحسن البصري -من طريق أبي الأَشْهَب- <q>﴿ويسارعون في الخيرات وأولئك من الصالحين﴾</q>، قال: فزعوا إلى [أنفسهم] حين تفرَّقَتْ أُمَّتُهم{3}. (ز) ١٤٢٧٣- قال مقاتل بن سليمان: <q>﴿ويسارعون في الخيرات﴾</q> يعني: شرائع الإسلام، <q>﴿وأولئك من الصالحين﴾</q>{2}. (ز) ",footnotes:1:أخرجه ابن أبي حاتم ٣/٧٣٩.تفسير مقاتل بن سليمان ١/٢٩٦.أخرجه عبد بن حميد ص٥١، وابن المنذر ١/٣٤١-٣٤٢، وابن أبي حاتم ٣/٧٣٩. وما بين المعقوفين ما رآه محقق تفسير ابن المنذر، وفي تفسير ابن أبي حاتم (ت: أسعد الطيب): بعضهم. ورأى د. حكمت بشير ص٤٩٠ أنها مصحَّفة من «دينهم». أما محقق قطعة من تفسير عبد بن حميد فأداه اجتهاده إلى أنها: فزعوا. أو: نزعوا إلى بقيتهم.تفسير مقاتل بن سليمان ١/٢٩٦.
3,115," <q>﴿وَمَا یَفۡعَلُوا۟ مِنۡ خَیۡرࣲ فَلَن یُكۡفَرُوهُۗ وَٱللَّهُ عَلِیمُۢ بِٱلۡمُتَّقِینَ ۝١١٥﴾</q> - قراءات ١٤٢٧٤- عن أبي عمرو بن العلاء، أنّه بلغه في قوله: <q>﴿وما يَفْعَلُواْ مِن خَيْرٍ فَلَن يُكْفَرُوهُ﴾</q> أنّ ابن عباس كان يقرؤهما جميعًا بالياء{1}. (٣/٧٣٥) <q>﴿وَمَا یَفۡعَلُوا۟ مِنۡ خَیۡرࣲ فَلَن یُكۡفَرُوهُۗ وَٱللَّهُ عَلِیمُۢ بِٱلۡمُتَّقِینَ ۝١١٥﴾</q> - تفسير الآية ١٤٢٧٥- عن الحسن البصري -من طريق عباد بن منصور- ‹فلن تُكْفَرُوه›، قال: لن تُظْلَمُوه{2}. (٣/٧٣٥) ١٤٢٧٦- عن قتادة بن دِعامة -من طريق سعيد- ‹وما تَفْعَلُوا مِن خَيْرٍ فَلَن تُكْفَرُوهُ›، قال: لن يُضَلَّ عنكم{3}. (٣/٧٣٥) ١٤٢٧٧- عن الربيع بن أنس -من طريق أبي جعفر- قوله: <q>﴿وما يفعلوا من خير فلن يكفروه﴾</q>، يقول: لن يضل عنكم{4}١٣٥٦. (ز) ١٣٥٦ لم يذكر ابنُ جرير (٥/٧٠١-٧٠٢) في معنى: <q>﴿فَلَنْ يُكْفَرُوهُ﴾</q> سوى قول قتادة، والربيع من طريق أبي جعفر. ١٤٢٧٨- قال مقاتل بن سليمان: <q>﴿وما يفعلوا من خير فلن يكفروه﴾</q>: فلن يضل عنهم، بل يُشكَر ذلك لهم، <q>﴿والله عليم بالمتقين﴾</q> يعني: ابن سلام وأصحابه{5}. (ز) ١٤٢٧٩- عن محمد بن مِسْعَر، قال: سألتُ سفيانَ بن عيينة عن قول الله: <q>﴿وما يفعلوا من خير فلن يكفروه﴾</q>. قال: فوسَّع الله عليهم في التَّطَوُّعِ، في اليهود والأعراب{2}. (ز) ",footnotes:1:أخرجه ابن جرير ٥/٧٠١. وهي قراءة حمزة والكسائي وخلف العاشر وحفص، وقرأ بقية العشرة: ‹وما تَفْعَلُوا مِن خَيْرٍ فَلَن تُكْفَرُوهُ› بالتاء فيهما. ينظر: النشر ٢/٢٤١، والإتحاف ص٢٢٧.أخرجه ابن أبي حاتم ٣/٧٤٠.أخرجه ابن جرير ٥/٧٠١. وعزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ٥/٧٠٢، وابن أبي حاتم ٣/٧٤٠.تفسير مقاتل بن سليمان ١/٢٩٦.أخرجه ابن أبي حاتم ٣/٧٤٠.
