quran[7]{c,v,t}:
  9,41,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿ٱنفِرُوا۟ خِفَافࣰا وَثِقَالࣰا﴾</span> - نزول الآية</h3></p><p><div></p><p><p><span class="item-no">٣٢٤٣٩<span class="dash">-</span></span> عن <span class="name-2">أبي الضُّحى مسلم بن صبيح</span> -من طريق سعيد بن مسروق- قال: أولُ ما أُنزل مِن براءة: <span class="qpc-hafs">﴿انفروا خفافا وثقالا﴾</span>، ثم نزل أوَّلُها وآخرُها{1}. (٧/٣٨٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٢٤٤٠<span class="dash">-</span></span> عن <span class="name-2">أبي مالك غزوان الغفاري</span> -من طريق حصين- قال: أوَّلُ شيءٍ نزل مِن براءة: <span class="qpc-hafs">﴿انفروا خفافا وثقالا﴾</span>{2}. (٧/٣٨٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٢٤٤١<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- قال: قالوا: إنّ فينا الثَّقيلَ، وذا الحاجةِ، والضَّيعةِ، والشغلِ، والمنتشرَ به أمرُه في ذلك. فأنزل الله: <span class="qpc-hafs">﴿انفروا خفافا وثقالا﴾</span>{3}. (٧/٣٨٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٢٤٤٢<span class="dash">-</span></span> عن <span class="name-2">حضرميٍّ</span> -من طريق المعتمر، عن أبيه- قال: ذُكِر لنا: أنّ أُناسًا كانوا عسى أن يكون أحدُهم عليلًا أو كبيرًا، فيقول: إنِّي لا آثم. فأنزل الله: <span class="qpc-hafs">﴿انفروا خفافا وثقالا﴾</span>{4}. (٧/٣٨٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٢٤٤٣<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- قال: جاء رجلٌ زَعَمُوا أنّه المِقداد، وكان عظيمًا سمينًا، فشكا إليه، وسأله أن يأذنَ له، فأبى؛ فنزلت يومئذٍ فيه: <span class="qpc-hafs">﴿انفروا خفافًا وثقالًا﴾</span>{5}. (٧/٣٨٨)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿ٱنفِرُوا۟ خِفَافࣰا وَثِقَالࣰا﴾</span> - تفسير الآية</h3></p><p><div></p><p><p><span class="item-no">٣٢٤٤٤<span class="dash">-</span></span> عن أبي راشدٍ الحُبْرانيِّ، قال: رأيتُ <span class="name-1">المِقداد</span> فارسَ رسول الله ﷺ بحمص يُريدُ الغَزْوَ، فقلت: لقد أعذر اللهُ إليك. قال: أبَتْ علينا سورةُ البُحُوث: <span class="qpc-hafs">﴿انفروا خفافًا وثقالًا﴾</span>. يعني: سورة التوبة{6}. (٧/٣٨٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٢٤٤٥<span class="dash">-</span></span> عن أبي يزيد المدينيِّ، قال: كان <span class="name-1">أبو أيوب الأنصاريّ</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٢٤٤٦<span class="dash">-</span></span> و<span class="name-1">المقدادُ بن الأسود</span> يقولان: أُمِرنا أن نَنفِرَ على كلِّ حالٍ. ويتأوَّلان: <span class="qpc-hafs">﴿انفروا خفافا وثقالا﴾</span>{7}. (٧/٣٨٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٢٤٤٧<span class="dash">-</span></span> عن <span class="name-1">أبي أيوب</span> -من طريق أبي العوّام-: أنّه أقام عن الجهاد عامًا واحِدًا، فقرأ هذه الآية: <span class="qpc-hafs">﴿انفروا خفافا وثقالا﴾</span>، فغزا مِن عامه، وقال: ما رأيتُ في هذه الآية مِن رُخصَة{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٢٤٤٨<span class="dash">-</span></span> عن محمد بن سيرين، قال: شَهِد <span class="name-1">أبو أيوبَ</span> بدرًا، ثم لم يَتَخَلَّفْ عن غزوةٍ للمسلمين إلا عامًا واحدًا، وكان يقول: قال الله: <span class="qpc-hafs">﴿انفروا خفافًا وثقالًا﴾</span>. فلا أجدُني إلا خفيفًا وثقيلًا{9}. (٧/٣٨٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٢٤٤٩<span class="dash">-</span></span> عن أنس بن مالك: أنّ <span class="name-1">أبا طلحة</span> قرأ سورة براءة، فأتى على هذه الآية: <span class="qpc-hafs">﴿انفروا خفافًا وثقالًا﴾</span>، قال: أرى ربَّنا يَستنفِرُنا شُيوخًا وشُبّانًا. وفي لفظٍ: فقال: ما أسمعُ اللهَ عَذَرَ أحدًا؛ جَهِّزوني بَنِيَّ. قال بنُوه: يرحمُك الله، قد غزوتَ مع رسول الله ﷺ حتى مات، وغزوتَ مع أبي بكر حتى مات، وغزوتَ مع عمر حتى مات، فنحن نغزو عنك. فأبى، فركِب البحر فمات، فلم يجِدوا له جزيرةً يدفنونه فيها إلا بعد تسعةِ أيام، فلم يتغيَّر، فدفنوه فيها{10}. (٧/٣٨٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٢٤٥٠<span class="dash">-</span></span> عن علي بن زيد بن جُدْعان، قال: قال <span class="name-1">أبو طلحة</span>: <span class="qpc-hafs">﴿انفروا خفافا وثقالا﴾</span>، قال: كهولًا وشبابًا. قال: ما أرى اللهُ عَذَر أحدًا. فخرج إلى الشام، فجاهد{11}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٢٤٥١<span class="dash">-</span></span> عن المغيرة بن النعمان، قال: كان رجلٌ مِن النَّخَع، وكان شيخًا بادِنًا، فأراد الغزوَ، فمنعه سعد بن أبي وقاص، فقال: إنّ الله يقول: <span class="qpc-hafs">﴿انفروا خفافا وثقالا﴾</span>. فأذِن له سعد، فقُتِل الشيخ، فسأل عنه بعدُ عمر، فقال: ما فعل الشيخ الذي كان من بني هاشم؟ فقالوا: قُتِل، يا أمير المؤمنين{12}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٢٤٥٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق العوفي- في قوله: <span class="qpc-hafs">﴿انفروا خفافا وثقالا﴾</span>، قال: نِشاطًا، وغير نِشاطٍ{13}. (٧/٣٨٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٢٤٥٣<span class="dash">-</span></span> وعن <span class="name-2">قتادة بن دعامة</span> -من طريق مَعْمَر-، نحو ذلك{14}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٢٤٥٤<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٢٤٥٥<span class="dash">-</span></span> و<span class="name-2">عامر الشعبي</span>، قالا: شُبّانًا، وكهولًا{15}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٢٤٥٦<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- قال: قالوا: إنّ فينا الثَّقيلَ، وذا الحاجةِ، والضَّيعةِ، والشغلِ، والمنتشرَ به أمرُه في ذلك. فأنزل الله: <span class="qpc-hafs">﴿انفروا خفافا وثقالا﴾</span>، وأبى أن يَعْذرَهم دون أن يَنفِروا خِفافًا وثِقالًا، وعلى ما كان منهم{3}. (٧/٣٨٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٢٤٥٧<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- <span class="qpc-hafs">﴿انفروا خفافا وثقالا﴾</span>، قال: شبابًا وشيوخًا، وأغنياء ومساكين{17}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٢٤٥٨<span class="dash">-</span></span> عن <span class="name-2">الضحاك بن مُزاحِم</span> -من طريق جُوَيْبِر-: كُهولًا، وشُبّانًا{18}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٢٤٥٩<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span> -من طريق إسماعيل- في قوله: <span class="qpc-hafs">﴿خفافًا وثقالًا﴾</span>، قال: شبابًا، وشيوخًا{19}. (٧/٣٨٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٢٤٦٠<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق منصور بن زاذان- في قوله: <span class="qpc-hafs">﴿انفروا خفافا وثقالا﴾</span>، قال: في العُسْر، واليُسْر{3}. (٧/٣٨٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٢٤٦١<span class="dash">-</span></span> قال <span class="name-2">الحسن البصري</span> -من طريق قتادة-: شيوخًا، وشُبّانًا{21}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٢٤٦٢<span class="dash">-</span></span> عن <span class="name-2">أبي صالح باذام</span> -من طريق إسماعيل بن أبي خالد- قال: الشابُّ، والشيخ{22}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٢٤٦٣<span class="dash">-</span></span> عن <span class="name-2">أبي صالح باذام</span> -من طريق إسماعيل- <span class="qpc-hafs">﴿انفروا خفافا وثقالا﴾</span>، قال: كل شيخ، وشابٍّ{21}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٢٤٦٤<span class="dash">-</span></span> عن <span class="name-2">أبي صالح باذام</span> -من طريق عنبسة، عمَّن ذَكَرَه- <span class="qpc-hafs">﴿انفروا خفافا وثقالا﴾</span>، قال: أغنياء، وفقراء{24}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٢٤٦٥<span class="dash">-</span></span> عن <span class="name-2">الحَكَم [بن عتيبة]</span> -من طريق منصور- في قوله: <span class="qpc-hafs">﴿انفروا خفافا وثقالا﴾</span>، قال: مشاغيلَ، وغيرَ مشاغيل{25}. (٧/٣٨٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٢٤٦٦<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق مَعْمَر- <span class="qpc-hafs">﴿خفافا وثقالا﴾</span>، قال: نِشاطًا، وغير نِشاطٍ{24}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٢٤٦٧<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- قوله تعالى: <span class="qpc-hafs">﴿انفروا خفافا وثقالا﴾</span>، يقول: غنيًّا وفقيرًا، وقويًّا وضعيفًا{27}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٢٤٦٨<span class="dash">-</span></span> عن <span class="name-2">زيد بن أسلم</span>، في قوله: <span class="qpc-hafs">﴿انفروا خفافا وثقالا﴾</span>، قال: فتيانًا، وكُهولًا{28}. (٧/٣٨٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٢٤٦٩<span class="dash">-</span></span> عن <span class="name-3">شمر بن عطية</span> -من طريق حفص بن حميد-: كهولًا، وشُبّانًا{29}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٢٤٧٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل ين سليمان</span>: <span class="qpc-hafs">﴿انفروا﴾</span> إلى غزاة تبوك <span class="qpc-hafs">﴿خفافا وثقالا﴾</span> يعني: نِشاطًا، وغير نِشاط{30}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٢٤٧١<span class="dash">-</span></span> عن <span class="name-3">مقاتل بن حيان</span> -من طريق بُكَير بن معروف- في قوله: <span class="qpc-hafs">﴿انفروا خفافا وثقالا﴾</span>، قال: شُبّانًا، وكهولًا{29}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٢٤٧٢<span class="dash">-</span></span> قال <span class="name-3">أبو عمرو الأوزاعيّ</span> -من طريق الوليد-: إذا كان النفر إلى دروب الشام نفر الناس إليها خفافا ركبانا، وإذا كان النفر إلى هذه السواحل نفروا إليها خفافًا وثقالًا؛ ركبانًا ومُشاةً{4}<span class=comment-ref>٢٩٥٩</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٢٩٥٩</span> <span class="comment-type-4">علَّقَ</span> <u>ابنُ كثير</u> (٧/٢٠٨) على قول الأوزاعيّ هذا بقوله: «هذا تفصيل في المسألة».</p><p>و<span class="comment-type-4">علَّقَ</span> <u>ابنُ عطية</u> (٤/٣١٩-٣٢٠) على قول الأوزاعيِّ، وقول آخر مفاده: أنّ الخفيف هو الشجاع، والثقيل هو الجبان. فقال: «هذان الوجهان الآخران ينعكسان، وقد قيل ذلك، ولكنه بحسب وطأتهم على العدو، فالشجاع هو الثقيل، وكذلك الفارس، والجبان هو الخفيف، وكذلك الراجل، وكذلك ينعكس الفقير والغني، فيكون الغني هو الثقيل، بمعنى: صاحب الشغل، ومعنى هذا: أنّ الناس أُمِروا جملة».</div></p><p><div></p><p><p><span class="item-no">٣٢٤٧٣<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿انفروا خفافا وثقالا﴾</span>، قال: الثقيلُ الذي له الضَّيْعة، فهو ثقيل يكره أن يضيع ضيعته، ويخرج، والخفيفُ الذي لا ضَيْعَة له، فقال الله: <span class="qpc-hafs">﴿انفروا خفافا وثقالا﴾</span>{4}<span class=comment-ref>٢٩٦٠</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٢٩٦٠</span> اختُلِف في معنى الخِفَّة والثّقَل اللَّذَيْن أمر الله بهما في الآية على ستّة أقوال: <b>أولها</b>: أنّ المعنى: شبابًا، وشيوخًا. <b>وثانيها</b>: أنّ المعنى: مشاغيل، وغير مشاغيل. <b>وثالثها</b>: أنّ المعنى: نِشاطًا، وغيرَ نِشاط. <b>ورابعها</b>: أنّ المعنى: في اليسر والعسر، فقراء وأغنياء. <b>وخامسها</b>: أنّ المعنى: رُكبانًا، ومُشاةً. <b>وسادسها</b>: أنّ المعنى: ذا ضيعةٍ، وغيرَ ذي ضيعةٍ.</p><p>و<span class="comment-type-4">ذهب</span> <u>ابنُ جرير</u> (١١/٤٧٤) إلى أنّ كلَّ تلك الأقوال تدخل تحت الآية، <span class="mustanad">مستندًا إلى عموم لفظها</span>، فقال: «أولى الأقوال في ذلك عندنا بالصواب أن يُقال: إنّ الله -تعالى ذِكْرُه- أمَرَ المؤمنين بالنَّفر لجهاد أعدائه في سبيله، خفافًا وثقالًا. وقد يدخل في الخِفاف كلُّ مَن كان سهلًا عليه النفر لقوة بدنه على ذلك، وصحة جسمه، وشبابه، ومَن كان ذا يُسْرٍ بمالٍ، وفراغ من الاشتغال، وقادرًا على الظهر والركاب. ويدخل في الثِّقال كلُّ مَن كان بخلاف ذلك، مِن ضعيف الجسم وعليله وسقيمه، ومِن مُعسِرٍ من المال، ومشتغلٍ بضَيْعَة ومعاش، ومَن كان لا ظهرَ له ولا ركاب، والشيخ، وذو السِّن، والعِيال. فإذ كان قد يدخل في الخفاف والثقال مَن وصفنا مِن أهل الصفات التي ذكرنا، ولم يكن الله -جل ثناؤُه- خصَّ مِن ذلك صنفًا دون صنف في الكتاب، ولا على لسان الرسول ﷺ، ولا نَصَب على خصوصه دليلًا؛ وجب أن يُقال: إنّ الله -جل ثناؤه- أمر المؤمنين من أصحاب رسوله بالنفر للجهاد في سبيله خفافًا وثقالًا مع رسوله ﷺ، على كل حالٍ مِن أحوال الخفّة والثقل».</p><p>وهو <span class="comment-type-3">ظاهر</span> قول <u>ابن كثير</u> (٧/٢٠٨).</p><p><span class="comment-type-4">وقال</span> <u>ابنُ عطية</u> (٤/٣٢٠): «هذه الأقوال إنّما هي على معنى المثال في الثِّقل، والخِفَّة».</div></p><p><div></p><p><p><span class="item-no">٣٢٤٧٤<span class="dash">-</span></span> عن حِبّانِ بن زيدٍ الشَّرْعَبِيُّ، قال: نفرنا مع صفوان بن عمرو -وكان واليًا على حمص قِبَل الأُفْسُوسِ{34}- إلى الجَراجِمَةِ{35}، فلقيت شيخًا كبيرا هِمًّا{36} قد سقط حاجباه على عينيه، من أهل دمشق، على راحلته فيمن أغار، فأقبلت عليه، فقلتُ: يا عمِّ، لقد أعذر اللهُ إليك. قال: فرفع حاجبيه، فقال: يا ابن أخي، استنفرنا الله خِفافًا وثِقالًا، مَن يُحِبُّه الله يبتليه، ثم يُعيدُه فيُبقِيه، وإنما يبتلي اللهُ مِن عباده مَن شكر وصبر وذكر ولم يعبد إلا الله{17}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿ٱنفِرُوا۟ خِفَافࣰا وَثِقَالࣰا﴾</span> - النسخ في الآية</h3></p><p><div></p><p><p><span class="item-no">٣٢٤٧٥<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطاء الخراساني- في قوله: <span class="qpc-hafs">﴿انفروا خفافا وثقالا﴾</span>: فنسخ هذه الآيةَ <span class="qpc-hafs">﴿وما كان المؤمنون لينفروا كافة﴾</span> إلى قوله: <span class="qpc-hafs">﴿لعلهم يحذرون﴾</span> [التوبة:١٢٢]، يقول: لتنفِرْ طائفةٌ، ولتَمْكُثْ طائفةٌ مع رسول الله ﷺ، فالماكثون مع رسول الله ﷺ هم الذين يتفقهون في الدين{27}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٢٤٧٦<span class="dash">-</span></span> وعن <span class="name-2">محمد بن كعب القرظي</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٢٤٧٧<span class="dash">-</span></span> و<span class="name-2">عطاء الخراساني</span>، مثل ذلك{39}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٢٤٧٨<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- قال: جاء رجلٌ زعموا: أنّه المِقداد، وكان عظيمًا سمينًا، فشكا إليه، وسأله أن يأذنَ له، فأبى؛ فنزلت يومئذٍ فيه: <span class="qpc-hafs">﴿انفروا خفافًا وثقالًا﴾</span>. فلما نزلت هذه الآيةُ اشتدَّ على الناس شأنُها؛ فنسخها اللهُ، فقال: <span class="qpc-hafs">﴿ليس على الضعفاء ولا على المرضى﴾</span> الآية [التوبة:٩١]{40}. (٧/٣٨٨)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَجَـٰهِدُوا۟ بِأَمۡوَ ٰ⁠لِكُمۡ وَأَنفُسِكُمۡ فِی سَبِیلِ ٱللَّهِۚ ذَ ٰ⁠لِكُمۡ خَیۡرࣱ لَّكُمۡ إِن كُنتُمۡ تَعۡلَمُونَ ۝٤١﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٢٤٧٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل ين سليمان</span>: <span class="qpc-hafs">﴿وجاهدوا﴾</span> العدوَّ <span class="qpc-hafs">﴿بأموالكم وأنفسكم في سبيل الله﴾</span> يعني: الجهاد، <span class="qpc-hafs">﴿ذلكم خير لكم﴾</span> مِن القعود، <span class="qpc-hafs">﴿إن كنتم تعلمون﴾</span>{30}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَجَـٰهِدُوا۟ بِأَمۡوَ ٰ⁠لِكُمۡ وَأَنفُسِكُمۡ فِی سَبِیلِ ٱللَّهِۚ ذَ ٰ⁠لِكُمۡ خَیۡرࣱ لَّكُمۡ إِن كُنتُمۡ تَعۡلَمُونَ ۝٤١﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٣٢٤٨٠<span class="dash">-</span></span> عن الحارث -يعني: أبا مالك الأشعري-، قال: قال رسول الله ﷺ: «<b>أنا آمركم بخمسٍ أمَرَني اللهُ بِهِنَّ: الجهاد في سبيل الله، والجماعة، والسمع، والطاعة، والهجرة</b>»{42}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن أبي شيبة ١٠/٢٦٧ (١٩٧٠٧)، وابن جرير ١١/٤٧٤. وعزاه السيوطي إلى الفريابيّ، وأبي الشيخ.أخرجه ابن أبي شيبة ١٩/٥٧٠-٥٧١ (٣٧٠٧٧). وعزاه السيوطي إلى ابن المنذر.أخرجه ابن أبي حاتم ٦/١٨٠٣. وعزاه السيوطي إلى أبي الشيخ.أخرجه ابن جرير ١١/٤٧٢.أخرجه ابن أبي حاتم ٦/١٨٠٣-١٨٠٤. وعزاه السيوطي إلى أبي الشيخ.أخرجه ابن جرير ١١/٤٧٣-٤٧٤، وابن أبي حاتم ٦/١٨٠٢، والطبراني (٥٥٦)، والحاكم ٣/٣٤٩.أخرجه ابن أبي حاتم ٦/١٨٠٢. وعزاه السيوطي إلى أبي الشيخ، وابن مَرْدُويَه.أخرجه ابن أبي شيبة ١٠/٢٧١ (١٩٧١٣).أخرجه ابن سعد ٣/٤٨٥، وابن جرير ١١/٤٧٣، والحاكم ٣/٤٥٨.أخرجه ابن سعد ٣/٥٠٧، وابن أبي عمر -كما في المطالب (٤٠٠٧)-، وعبد الله بن أحمد في زوائد المسند ص٢٥٠، وأبو يعلى (٣٤١٣)، وابن جرير ١١/٤٦٨ مختصرًا، وابن أبي حاتم ٦/١٨٠٢، وابن حبان (٧١٨٤)، والحاكم ٣/٣٥٣. وعزاه السيوطي إلى ابن أبي عمر العدنيّ في مسنده، وابن المنذر، وأبي الشيخ، وابن مَرْدُويَه.أخرجه ابن أبي شيبة ١٠/٣٤٣ (١٩٨٥٩).أخرجه ابن جرير ١١/٤٦٨.أخرجه ابن جرير ١١/٤٧١، وابن أبي حاتم ٦/١٨٠٢-١٨٠٣.أخرجه عبد الرزاق ٢/٢٧٦، وابن جرير ١١/٤٧١. وعلَّقه ابن أبي حاتم ٦/١٨٠٣.علَّقه ابن أبي حاتم ٦/١٨٠٢.أخرجه ابن أبي حاتم ٦/١٨٠٣. وعزاه السيوطي إلى أبي الشيخ.أخرجه ابن جرير ١١/٤٧٠.أخرجه ابن جرير ١١/٤٦٩.أخرجه ابن أبي شيبة ١٠/٢٧١ (١٩٧١٨)، ١١/٤٩٦. وعلَّقه ابن أبي حاتم ٦/١٨٠٢. وعزاه السيوطي إلى ابن المنذر.أخرجه ابن أبي حاتم ٦/١٨٠٣. وعزاه السيوطي إلى أبي الشيخ.أخرجه ابن جرير ١١/٤٧٠. وعلَّقه ابن أبي حاتم ٦/١٨٠٢.أخرجه ابن أبي شيبة ١٠/٢٧١ (١٩٧١٥)، وابن جرير ١١/٤٦٩. وعلَّقه ابن أبي حاتم ٦/١٨٠٢.أخرجه ابن جرير ١١/٤٧٠. وعلَّقه ابن أبي حاتم ٦/١٨٠٢.أخرجه ابن جرير ١١/٤٧١.أخرجه ابن أبي شيبة ١٠/٢٧١ (١٩٧١٧)، وابن جرير ١١/٤٧١، وابن أبي حاتم ٦/١٨٠٣. وعزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ١١/٤٧١.أخرجه ابن أبي حاتم ٦/١٨٠٤.علَّقه ابن أبي حاتم ٦/١٨٠٢. وعزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ١١/٤٦٩. وعلَّقه ابن أبي حاتم ٦/١٨٠٢.تفسير مقاتل بن سليمان ٢/١٧٢.أخرجه ابن جرير ١١/٤٦٩. وعلَّقه ابن أبي حاتم ٦/١٨٠٢.أخرجه ابن جرير ١١/٤٧٢.أخرجه ابن جرير ١١/٤٧٢.الأُفْسُوسِ: بلد بثغور طرسوس، وطرسوس مدينة بالشام بين أنطاكية وحلب. معجم البلدان ١/٣٣٠، ٣/٥٣٦.الجَراجِمَةُ: قوم من العجم بالجزيرة أو نَبَط الشام. لسان العرب (جرجم).الهِمُّ: الشيخ الكبير البالي. لسان العرب (همم).أخرجه ابن جرير ١١/٤٧٠.أخرجه ابن أبي حاتم ٦/١٨٠٤.علَّقه ابن أبي حاتم ٦/١٨٠٤.أخرجه ابن أبي حاتم ٦/١٨٠٣-١٨٠٤. وعزاه السيوطي إلى أبي الشيخ. وقد تقدم الحديث عن النسخ في هذه المسألة عند قوله تعالى: <span class="qpc-hafs">﴿إلّا تَنْفِرُوا يُعَذِّبْكُمْ عَذابًا ألِيمًا﴾</span> [التوبة: ٣٩].تفسير مقاتل بن سليمان ٢/١٧٢.أخرجه الترمذي ٥/١٣٦-١٣٩ (٣٠٧٩)، وابن خزيمة ٣/٣٤٧-٣٤٨ (١٨٩٥)، وابن حبان ١٤/١٢٤-١٢٦ (٦٢٣٣)، والحاكم ١/٢٠٤ (٤٠٤-٤٠٦)، ١/٥٨١-٥٨٢ (١٥٣٤) جميعهم مُطَوَّلًا، وابن أبي حاتم ٦/١٨٠٤ (١٠٠٦٤) واللفظ له، من طريق أبان بن يزيد العطار، عن يحيى بن أبي كثير، عن زيد بن أبي سلام، عن أبي سلام، عن الحارث الأشعري به.</p><p>قال الترمذي: «هذا حديث حسن صحيح غريب». وقال الحاكم في الموضع الأخير: «هذا حديث صحيح، على شرط الشيخين، ولم يخرجاه». وقال الذهبي: «لم يخرجاه؛ لأن الحارث تفرَّد عنه أبو سلام».
  9,42,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿لَوۡ كَانَ عَرَضࣰا قَرِیبࣰا وَسَفَرࣰا قَاصِدࣰا لَّٱتَّبَعُوكَ وَلَـٰكِنۢ بَعُدَتۡ عَلَیۡهِمُ ٱلشُّقَّةُۚ وَسَیَحۡلِفُونَ بِٱللَّهِ لَوِ ٱسۡتَطَعۡنَا لَخَرَجۡنَا مَعَكُمۡ یُهۡلِكُونَ أَنفُسَهُمۡ وَٱللَّهُ یَعۡلَمُ إِنَّهُمۡ لَكَـٰذِبُونَ ۝٤٢﴾</span> - نزول الآية</h3></p><p><div></p><p><p><span class="item-no">٣٢٤٨١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق العوفي- قال: إنّ رسولَ الله ﷺ قيل له: ألا تَغزُو بني الأصفر، لعلك أن تُصيبَ ابنةَ عظيم الروم؟ فقال رجلان: قد عَلمِتَ -يا رسولَ الله- أنّ النساءَ فِتنةٌ، فلا تَفْتِنّا بِهِنَّ، فائْذَن لنا. فأذِن لهما، فلما انطلقا قال أحدُهما: إن هو إلا شَحْمةٌ لأَوَّلِ آكلٍ. فسار رسولُ الله ﷺ، ولم ينَزِلْ عليه في ذلك شيءٌ، فلمّا كان ببعض الطريق نزل عليه وهو على بعض المياه: <span class="qpc-hafs">﴿لو كان عرضا قريبا وسفرا قاصدا لاتبعوك﴾</span>. ونزل عليه: <span class="qpc-hafs">﴿عفا الله عنك لم أذنت لهم﴾</span>. ونزل عليه: <span class="qpc-hafs">﴿لا يستأذنك الذين يؤمنون بالله واليوم الآخر﴾</span>. ونزل عليه: <span class="qpc-hafs">﴿إنهم رجس ومأواهم جهنم جزاء بما كانوا يكسبون﴾</span> [التوبة:٩٥]{1}. (٧/٣٩٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٢٤٨٢<span class="dash">-</span></span> قال <span class="name-3">محمد بن السائب الكلبي</span>: وذلك حين استنفر رسولُ الله ﷺ الناسَ إلى تبوك في حرٍّ شديد، وعسرة من الناس، فكره بعضُ الناس الخروج، وجعلوا يستأذنون في المقام مِن بين [...]{2} ومَن ليست به علة، فيأذن لِمن شاء أن يأذن، وتخلَّف كثيرٌ منهم بغير إذن؛ فأنزل الله ﷿: <span class="qpc-hafs">﴿لو كان عرضا قريبا﴾</span>{3}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿لَوۡ كَانَ عَرَضࣰا قَرِیبࣰا وَسَفَرࣰا قَاصِدࣰا لَّٱتَّبَعُوكَ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٢٤٨٣<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق الضحاك- <span class="qpc-hafs">﴿لو كان عرضًا قريبًا﴾</span>، قال: غنيمةً قريبةً{4}. (٧/٣٩٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٢٤٨٤<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق مَعْمَر- <span class="qpc-hafs">﴿لو كان عرضا قريبا﴾</span>، قال: هي غزوة تبوك{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٢٤٨٥<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- في قوله: <span class="qpc-hafs">﴿لو كان عرضًا قريبًا﴾</span> يقول: دنيا يطلُبونها، <span class="qpc-hafs">﴿وسفرا قاصدا﴾</span> يقول: قريبًا{6}. (٧/٣٩٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٢٤٨٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل ين سليمان</span>: <span class="qpc-hafs">﴿لو كان عرضا قريبا﴾</span> يعني: غنيمةً قريبةً، <span class="qpc-hafs">﴿وسفرا قاصدا﴾</span> يعني: هَيِّنًا <span class="qpc-hafs">﴿لاتبعوك﴾</span> في غزاتك، <span class="qpc-hafs">﴿ولكن بعدت عليهم الشقة﴾</span>{7}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَلَـٰكِنۢ بَعُدَتۡ عَلَیۡهِمُ ٱلشُّقَّةُۚ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٢٤٨٧<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق أبي رَوْق، عن الضَّحّاك- <span class="qpc-hafs">﴿ولكن بعدت عليهم الشقة﴾</span>، قال: المَسِير{4}. (٧/٣٩٠)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَسَیَحۡلِفُونَ بِٱللَّهِ لَوِ ٱسۡتَطَعۡنَا لَخَرَجۡنَا مَعَكُمۡ یُهۡلِكُونَ أَنفُسَهُمۡ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٢٤٨٨<span class="dash">-</span></span> عن <span class="name-2">الضحاك بن مزاحم</span> -من طريق جويبر- <span class="qpc-hafs">﴿وسيحلفون بالله لو استطعنا لخرجنا معكم﴾</span>، قال: لِحَلِفِهم باللهِ وهم كاذبون{9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٢٤٨٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل ين سليمان</span>: <span class="qpc-hafs">﴿وسيحلفون بالله لو استطعنا﴾</span> يعني: لو وجدنا سَعَةً في المال؛ <span class="qpc-hafs">﴿لخرجنا معكم﴾</span> في غزاتكم{7}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَٱللَّهُ یَعۡلَمُ إِنَّهُمۡ لَكَـٰذِبُونَ ۝٤٢﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٢٤٩٠<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿والله يعلم إنهم لكاذبون﴾</span>، قال: لقد كانوا يستطيعون الخروج، ولكن كان تَبْطِئةً مِن عند أنفسِهم والشيطان، وزهادةً في الخير{11}. (٧/٣٩٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٢٤٩١<span class="dash">-</span></span> قال <span class="name-3">مقاتل ين سليمان</span>: <span class="qpc-hafs">﴿يهلكون أنفسهم والله يعلم إنهم لكاذبون﴾</span> بأنّ لهم سَعَة في الخروج، ولكنهم لم يريدوا الخروج، منهم: جَدُّ بن قيس، ومُعَتِّب بن قُشَيْر، وهما من الأنصار{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٢٤٩٢<span class="dash">-</span></span> عن <span class="name-3">محمد بن إسحاق</span> -من طريق سلمة- <span class="qpc-hafs">﴿والله يعلم إنهم لكاذبون﴾</span>، أي: إنهم يستطيعون{13}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ١١/٦٢٩.كذا في المطبوع.ذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٢/٢٠٧-.أخرجه ابن أبي حاتم ٦/١٨٠٤. وعزاه السيوطي إلى أبي الشيخ.أخرجه عبد الرزاق ٢/٢٧٦، وابن جرير ١١/٤٧٧، وابن أبي حاتم ٦/١٨٠٤.أخرجه ابن أبي حاتم ٦/١٨٠٤.تفسير مقاتل بن سليمان ٢/١٧٢.أخرجه ابن أبي حاتم ٦/١٨٠٤. وعزاه السيوطي إلى أبي الشيخ.أخرجه ابن أبي حاتم ٦/١٨٠٥.تفسير مقاتل بن سليمان ٢/١٧٢.أخرجه ابن جرير ١١/٤٧٧. وعزاه السيوطي إلى عَبد بن حُمَيد، وابن المنذر بلفظ: وزهادةً في الجهاد.تفسير مقاتل بن سليمان ٢/١٧٢.أخرجه ابن جرير ١١/٤٧٧، وابن أبي حاتم ٦/١٨٠٥.
  9,43,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿عَفَا ٱللَّهُ عَنكَ لِمَ أَذِنتَ لَهُمۡ﴾</span> - نزول الآية</h3></p><p><div></p><p><p><span class="item-no">٣٢٤٩٣<span class="dash">-</span></span> عن <span class="name-2">عمرو بن ميمونٍ الأوديِّ</span> -من طريق عمرو بن دينار- قال: اثنتان فعلهما رسولُ الله ﷺ لم يُؤمرْ فيهما بشيءٍ: إذنُه للمنافقين، وأخذُه من الأسارى؛ فأنزل الله: <span class="qpc-hafs">﴿عفا الله عنك لم أذنت لهم﴾</span> الآية{1}. (٧/٣٩١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٢٤٩٤<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- قوله: <span class="qpc-hafs">﴿عفا الله عنك لم أذنت لهم حتى يتبين لك الذين صدقوا﴾</span>، استأذنه يومئذ ناسٌ، فأَذِن لهم؛ فقال الله: <span class="qpc-hafs">﴿لم أذنت لهم حتى يتبين لك الذين صدقوا﴾</span>{2}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿عَفَا ٱللَّهُ عَنكَ لِمَ أَذِنتَ لَهُمۡ﴾</span> - تفسير الآية</h3></p><p><div></p><p><p><span class="item-no">٣٢٤٩٥<span class="dash">-</span></span> عن <span class="name-2">مُورِّقٍ العجليِّ</span> -من طريق موسى بن سَرْوانَ- في قوله: <span class="qpc-hafs">﴿عفا الله عنك لم أذنت لهم﴾</span>، قال: عاتَبَه ربُّه ﷿{3}. (٧/٣٩١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٢٤٩٦<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿عفا الله عنك لم أذنت لهم﴾</span>، قال: ناسٌ قالوا: استأذِنوا رسولَ الله ﷺ؛ فإن أذِن لكم فاقعُدوا، وإن لم يأذن لكم فاقعُدوا{4}. (٧/٣٩١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٢٤٩٧<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿عفا الله عنك لم أذنت لهم حتى يتبين لك الذين صدقوا﴾</span> الآية: عاتَبه كما تسمعون{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٢٤٩٨<span class="dash">-</span></span> عن <span class="name-2">عون بن عبد الله</span> -من طريق مسعر- قال: سمعتم بمعاتبةٍ أحسنَ من هذا، بدأ بالعفوِ قبلَ المعاتبة، فقال: <span class="qpc-hafs">﴿عفا الله عنك لم أذنت لهم﴾</span>{6}. (٧/٣٩١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٢٤٩٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل ين سليمان</span>: ثم قال للنبي ﷺ: <span class="qpc-hafs">﴿عفا الله عنك لم أذنت لهم﴾</span> في القعود، يعني: في التَّخَلُّف{7}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿حَتَّىٰ یَتَبَیَّنَ لَكَ ٱلَّذِینَ صَدَقُوا۟﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٢٥٠٠<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- قوله: <span class="qpc-hafs">﴿لم أذنت لهم حتى يتبين لك الذين صدقوا﴾</span>: معرفة الذين صدقوا بالخروج{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٢٥٠١<span class="dash">-</span></span> قال <span class="name-3">مقاتل ين سليمان</span>: <span class="qpc-hafs">﴿حتى يتبين لك الذين صدقوا﴾</span> في قولهم، يعني: أهل العذر، منهم: المقداد بن الأسود الكندي، وكان سمينًا{7}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَتَعۡلَمَ ٱلۡكَـٰذِبِینَ ۝٤٣﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٢٥٠٢<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- قوله: <span class="qpc-hafs">﴿وتعلم الكاذبين﴾</span>، قال: معرفة الذين كذبوا بالقعود{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٢٥٠٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل ين سليمان</span>: <span class="qpc-hafs">﴿وتعلم الكاذبين﴾</span> في قولهم، يعني: مَن لا قَدْر لهم{7}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه عبد الرزاق في المصنف (٩٤٠٣)، وابن جرير ١١/٤٧٩.أخرجه ابن أبي حاتم ٦/١٨٠٦.أخرجه ابن جرير ١١/٤٧٩، وابن أبي حاتم ٦/١٨٠٥. وعزاه السيوطي إلى أبي الشيخ.تفسير مجاهد ص٣٦٩، وأخرجه ابن جرير ١١/٤٧٨، وابن أبي حاتم ٦/١٨٠٥. وعزاه السيوطي إلى ابن أبي شيبة، وابن المنذر.أخرجه ابن جرير ١١/٤٧٨.أخرجه ابن أبي شيبة ١٨/٥٤٢-٥٤٣ (٣٥٣٦٣)، وابن أبي حاتم ٦/١٨٠٥. وعزاه السيوطي إلى ابن المنذر، وأبي الشيخ. وفي رواية عند ابن أبي حاتم: أخبره بالعفو قبل أن يخبره بالذنب، فقال: <span class="qpc-hafs">﴿عفا الله عنك لم أذنت لهم﴾</span>.تفسير مقاتل بن سليمان ٢/١٧٢.أخرجه ابن أبي حاتم ٦/١٨٠٦.تفسير مقاتل بن سليمان ٢/١٧٢.أخرجه ابن أبي حاتم ٦/١٨٠٦.تفسير مقاتل بن سليمان ٢/١٧٢.
  9,44,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿لَا یَسۡتَـٔۡذِنُكَ ٱلَّذِینَ یُؤۡمِنُونَ بِٱللَّهِ وَٱلۡیَوۡمِ ٱلۡـَٔاخِرِ أَن یُجَـٰهِدُوا۟ بِأَمۡوَ ٰ⁠لِهِمۡ وَأَنفُسِهِمۡۗ وَٱللَّهُ عَلِیمُۢ بِٱلۡمُتَّقِینَ ۝٤٤﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٢٥٠٤<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- في قوله: <span class="qpc-hafs">﴿لا يستأذنك الذين يؤمنون بالله واليوم الآخرة﴾</span>، قال: هذا تَعْييرٌ للمنافقين حين استأذَنوا في القعود عن الجهاد بغيرِ عذرٍ، وعذَرَ اللهُ المؤمنين فقال: <span class="qpc-hafs">﴿فإذا استأذنوك لبعض شأنهم فأذن لمن شئت منهم﴾</span> [النور:٦٢]{1}. (٧/٣٩٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٢٥٠٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿لا يستأذنك﴾</span> في القعود <span class="qpc-hafs">﴿الذين يؤمنون بالله واليوم الآخر﴾</span> يعني: الذين يُصَدِّقون بتوحيد الله، وبالبعث الذي فيه جزاء الأعمال؛ أنّه كائن، <span class="qpc-hafs">﴿أن يجاهدوا﴾</span> العدوَّ مِن غير عذر <span class="qpc-hafs">﴿بأموالهم وأنفسهم﴾</span> كراهية الجهاد{2}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿لَا یَسۡتَـٔۡذِنُكَ ٱلَّذِینَ یُؤۡمِنُونَ بِٱللَّهِ وَٱلۡیَوۡمِ ٱلۡـَٔاخِرِ أَن یُجَـٰهِدُوا۟ بِأَمۡوَ ٰ⁠لِهِمۡ وَأَنفُسِهِمۡۗ وَٱللَّهُ عَلِیمُۢ بِٱلۡمُتَّقِینَ ۝٤٤﴾</span> - النسخ في الآيات</h3></p><p><div></p><p><p><span class="item-no">٣٢٥٠٦<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق الضحاك- في قوله: <span class="qpc-hafs">﴿عفا الله عنك لم أذنت لهم﴾</span> الآياتِ الثلاثَ، قال: نسَخَها: <span class="qpc-hafs">﴿فإذا استأذنوك لبعض شأنهم فأذن لمن شئت منهم﴾</span> [النور:٦٢]{3}. (٧/٣٩١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٢٥٠٧<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريقِ عطاءٍ الخُراساني- في قوله: <span class="qpc-hafs">﴿لا يستأذنك الذين يؤمنون بالله﴾</span> الآيتين، قال: نسَختها الآيةُ التي في سورة النور: <span class="qpc-hafs">﴿إنما المؤمنون الذي آمنوا بالله ورسوله﴾</span> إلى <span class="qpc-hafs">﴿إن الله غفور رحيم﴾</span> [النور:٦٢] فجعل اللهُ النبيَّ ﷺ بأعلى النَّظرَين{4} في ذلك؛ مَن غزا غزا في فضيلةٍ، ومَن قعَد قعَد في غير حَرَجٍ إن شاء{5}. (٧/٣٩٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٢٥٠٨<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٢٥٠٩<span class="dash">-</span></span> و<span class="name-2">الحسن البصري</span> -من طريق يزيد- قالا: قوله: <span class="qpc-hafs">﴿لا يَسْتَأْذِنُكَ الَّذِينَ يُؤْمِنُونَ بِاللَّهِ﴾</span> إلى قوله: <span class="qpc-hafs">﴿فَهُمْ فِي رَيْبِهِمْ يَتَرَدَّدُونَ﴾</span> نسختهما الآية التي في النور: <span class="qpc-hafs">﴿إنَّما المُؤْمِنُونَ الَّذِينَ آمَنُوا بِاللَّهِ﴾</span> إلى <span class="qpc-hafs">﴿إنَّ اللَّهَ غَفُورٌ رَحِيمٌ﴾</span> [النور:٦٢]{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٢٥١٠<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿عفا الله عنك لم أذنت لهم﴾</span> الآية، قال: ثُمَّ أنزل الله التي في سورة النور، فرَخَّص له في أن يأذن لهم إن شاء، فقال: <span class="qpc-hafs">﴿فإذا استأذنوك لبعض شأنهم فأذن لمن شئت منهم﴾</span> [النور:٦٢]، فجعله اللهُ رخصةً في ذلك مِن ذلك{7}<span class=comment-ref>٢٩٦١</span>. (٧/٣٩٢)</p></p><p></div></p><p><div><span class=comment-ref>٢٩٦١</span> <span class="comment-type-2">انتَقَدَ</span> <u>ابنُ عطية</u> (٤/٣٢٣) قول قتادة هذا <span class="mustanad">مستندًا إلى دلالة زمن النزول</span>، فقال: «هذا غلطٌ؛ لأنّ آية النور نزلت سنة أربع من الهجرة في غزوة الخندق في استئذان بعض المؤمنين رسول الله ﷺ في بعض شأنهم في بيوتهم في بعض الأوقات، فأباح الله له أن يأذن، فتباينت الآيتان في الوقت والمعنى».</div></p><p><div></p><p><p><span class="item-no">٣٢٥١١<span class="dash">-</span></span> عن <span class="name-2">عطاء الخراساني</span> -من طريق ابنه عثمان- قال: <span class="qpc-hafs">﴿لا يستأذنك الذين يؤمنون بالله واليوم الآخر﴾</span> الآيتين إلى قوله: <span class="qpc-hafs">﴿يترددون﴾</span>: فنُسِخَت في سورة النور: <span class="qpc-hafs">﴿إنما المؤمنون الذين آمنوا بالله ورسوله﴾</span> إلى <span class="qpc-hafs">﴿إن الله غفور رحيم﴾</span> [النور:٦٢]، فجُعِل رسول الله ﷺ بأعلى النَّظَرَيْن؛ مَن غزا غزا في فضيلةٍ، ومَن قعَد قعَد في غير حَرَجٍ{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٢٥١٢<span class="dash">-</span></span> عن <span class="name-2">زيد بن أسلم</span> -من طريق القاسم بن عبد الله- أنّه قال: <span class="qpc-hafs">﴿لا يستأذنك الذين يؤمنون بالله واليوم الآخر أن يجاهدوا بأموالهم وأنفسهم والله عليم بالمتقين إنما يستأذنك الذين لا يؤمنون بالله واليوم الآخر وارتابت قلوبهم فهم في ريبهم يترددون﴾</span>، نَسَخَتْها الآيةُ التي في النور [٦٢]: <span class="qpc-hafs">﴿فإذا استأذنوك لبعض شأنهم فأذن لمن شئت منهم واستغفر لهم الله إن الله غفور رحيم﴾</span>{9}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ١١/٤٨٠، وابن أبي حاتم ٦/١٨٠٦، والنحاس في ناسخه ص٥٠٦. وعزاه السيوطي إلى ابن المنذر.تفسير مقاتل بن سليمان ٢/١٧٢.أخرجه النحاس في ناسخه ص٥٠٥.النظرين: الأمرين. النهاية ٥/٧٧.أخرجه أبو عبيد في ناسخه ص٢٧٤، وابن أبي حاتم ٦/١٨٠٦، وعنده عن عطاء الخراساني من قوله كما سيأتي. وعزاه السيوطي إلى ابن المنذر، وابن مَرْدُويَه، والبيهقيّ في سُنَنِه.أخرجه ابن جرير ١١/٤٨١.أخرجه ابن جرير ١١/٤٧٨، وابن أبي حاتم ٦/١٨٠٥ بنحوه من طريق همام، والنحاس ص٥٠٥. وذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٢/٢٠٨-. وعزاه السيوطي إلى ابن المنذر، وأبي الشيخ.أخرجه ابن أبي حاتم ٦/١٨٠٦.أخرجه ابن وهب في الجامع - تفسير القرآن ٣/٧٥ (١٦٤).
  9,45,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿إِنَّمَا یَسۡتَـٔۡذِنُكَ ٱلَّذِینَ لَا یُؤۡمِنُونَ بِٱللَّهِ وَٱلۡیَوۡمِ ٱلۡـَٔاخِرِ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٢٥١٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثم ذكر المنافقين، فقال: <span class="qpc-hafs">﴿إنما يستأذنك﴾</span> في الجهاد وبُعْد الشُّقّة، <span class="qpc-hafs">﴿الذين لا يؤمنون بالله واليوم الآخر﴾</span> لا يصدِّقون بالله، ولا باليوم الآخر، يعني: لا يصدِّقون بالله، ولا بتوحيده، ولا بالبعث الذي فيه جزاء الأعمال{1}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَٱرۡتَابَتۡ قُلُوبُهُمۡ فَهُمۡ فِی رَیۡبِهِمۡ یَتَرَدَّدُونَ ۝٤٥﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٢٥١٤<span class="dash">-</span></span> عن <span class="name-1">أبي الدرداء</span> -من طريق عبد الرحمن بن مسعود- قال: الرَّيْب: الشكُّ، والكُفْر{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٢٥١٥<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- قوله: <span class="qpc-hafs">﴿وارتابت قلوبهم﴾</span>، يقول: شَكَّت قلوبهم{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٢٥١٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وارتابت﴾</span> يعني: شَكَّت <span class="qpc-hafs">﴿قلوبهم﴾</span> في الدِّين، <span class="qpc-hafs">﴿فهم في ريبهم﴾</span> يعني: في شكِّهم <span class="qpc-hafs">﴿يترددون﴾</span>، وهم تسعة وثلاثون رجلًا{1}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٢/١٧٢.أخرجه ابن أبي حاتم ٦/١٨٠٧.أخرجه ابن أبي حاتم ٦/١٨٠٧.تفسير مقاتل بن سليمان ٢/١٧٢.
  9,46,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَلَوۡ أَرَادُوا۟ ٱلۡخُرُوجَ لَأَعَدُّوا۟ لَهُۥ عُدَّةࣰ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٢٥١٧<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- قوله: <span class="qpc-hafs">﴿ولو أرادوا الخروج لأعدوا له عدة﴾</span>، فأمّا العُدَّة فالقُوَّة{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٢٥١٨<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ولَوْ أرادُوا الخُرُوجَ﴾</span> إلى العدو؛ <span class="qpc-hafs">﴿لَأَعَدُّوا لَهُ عُدَّةً﴾</span> يعني به: النِّيَّة{2}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَلَـٰكِن كَرِهَ ٱللَّهُ ٱنۢبِعَاثَهُمۡ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٢٥١٩<span class="dash">-</span></span> عن <span class="name-2">الضحاك بن مزاحم</span> -من طريق جويبر- في قوله: <span class="qpc-hafs">﴿ولكن كرهَ اللهُ انبعاثهُم﴾</span>، قال: خروجَهم{3}. (٧/٣٩٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٢٥٢٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ولكِنْ كَرِهَ اللَّهُ انْبِعاثَهُمْ﴾</span>، يعني: خروجهم{2}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿فَثَبَّطَهُمۡ وَقِیلَ ٱقۡعُدُوا۟ مَعَ ٱلۡقَـٰعِدِینَ ۝٤٦﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٢٥٢١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق الضحاك- في قوله: <span class="qpc-hafs">﴿فثبَّطهم﴾</span>، قال: حبَسهم{1}. (٧/٣٩٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٢٥٢٢<span class="dash">-</span></span> عن <span class="name-2">الضحاك بن مزاحم</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٢٥٢٣<span class="dash">-</span></span> و<span class="name-2">إسماعيل السُّدِّيّ</span>، مثل ذلك{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٢٥٢٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فَثَبَّطَهُمْ﴾</span> عن غزاة تبوك، <span class="qpc-hafs">﴿وقِيلَ اقْعُدُوا﴾</span> وحيًا إلى قلوبهم <span class="qpc-hafs">﴿مَعَ القاعِدِينَ﴾</span> أُلْهِموا ذلك، يعني: مع المتخلفين{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٢٥٢٥<span class="dash">-</span></span> عن <span class="name-3">محمد بن إسحاق</span> -من طريق سلمة- قال: كان الذين استأذنوه -فيما بلغني- مِن ذَوِي الشَّرَف منهم: عبد الله بن أُبَيِّ ابن سلول، والجدُّ بن قيس، وكانوا أشرافًا في قومهم، فثبَّطهم الله؛ لعلمه بهم أن يخرجوا معهم فيفسدوا عليه جنده{8}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن أبي حاتم ٦/١٨٠٧.تفسير مقاتل بن سليمان ٢/١٧٣.أخرجه ابن أبي حاتم ٦/١٨٠٧. وعزاه السيوطي إلى أبي الشيخ.تفسير مقاتل بن سليمان ٢/١٧٣.أخرجه ابن أبي حاتم ٦/١٨٠٧.علَّقه ابن أبي حاتم ٦/١٨٠٧.تفسير مقاتل بن سليمان ٢/١٧٣.أخرجه ابن جرير ١١/٤٨٢.
  9,47,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿لَوۡ خَرَجُوا۟ فِیكُم مَّا زَادُوكُمۡ إِلَّا خَبَالࣰا﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٢٥٢٦<span class="dash">-</span></span> قال <span class="name-2">الضحاك بن مزاحم</span>: غدرًا ومكرًا {1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٢٥٢٧<span class="dash">-</span></span> قال <span class="name-3">محمد بن السائب الكلبي</span>: شرًّا{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٢٥٢٨<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿لَوْ خَرَجُوا فِيكُمْ﴾</span> يعني: معكم إلى العدو؛ <span class="qpc-hafs">﴿ما زادُوكُمْ إلّا خَبالًا﴾</span> يعني: عِيًّا{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٢٥٢٩<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿لوْ خرجُوا فيكم مّا زادوكُمْ إلا خبالًا﴾</span>، قال: هؤلاء المنافقون في غزوة تبوك، يُسلِّي الله عنها نبيَّه والمؤمنين، فقال: وما يُحزِنُكم؟ <span class="qpc-hafs">﴿لوْ خَرجُوا فيكُم مّا زادوكُمْ إلّا خبالًا﴾</span> يقولُون: قد جُمِع لكم، وفُعِل وفُعل. يُخذِّلونكم{4}. (٧/٣٩٣)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَلَأَوۡضَعُوا۟ خِلَـٰلَكُمۡ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٢٥٣٠<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿ولأوضعُوا خلالكُمْ﴾</span>، قال: لارْفَضُّوا{5}{6}. (٧/٣٩٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٢٥٣١<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن جريج- في قوله: <span class="qpc-hafs">﴿ولأوضعُوا خلالكُمْ﴾</span>: لَأسْرَعوا الأزِقَّةَ خلالكم{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٢٥٣٢<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- في قوله: <span class="qpc-hafs">﴿ولأوضعُوا خلالكُم﴾</span>، قال: لأسرعُوا بينكم{8}. (٧/٣٩٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٢٥٣٣<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- قوله: <span class="qpc-hafs">﴿ولأوضعوا خلالكم﴾</span>، يقول: ولأوضعوا أسلحتهم خلالكم بالفتنة{9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٢٥٣٤<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- قوله: <span class="qpc-hafs">﴿ولأوضعوا خلالكم﴾</span>، يقول: أوضعوا رِحالهم حتى يدخلوا بينكم{10}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٢٥٣٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ولَأَوْضَعُوا خِلالَكُمْ﴾</span>، يَتَخَلَّل الراكبُ الرجلين، حتى يدخل بينهما فيقول ما لا ينبغي{3}<span class=comment-ref>٢٩٦٢</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٢٩٦٢</span> <span class="comment-type-4">ذكر</span> <u>ابنُ عطية</u> (٤/٣٢٦) أنّ الزجّاج قال: <span class="qpc-hafs">﴿خِلالَكُمْ﴾</span> معناه: فيما يُخِلُّ بكم. و<span class="comment-type-2">انتَقَده</span> <span class="mustanad">مستندًا إلى النظائر</span>، فقال: «وهذا ضعيف، وماذا يقول في قوله: <span class="qpc-hafs">﴿فَجاسُوا خِلالَ الدِّيارِ﴾</span> [الإسراء:٥]؟».</div></p><p><h3><span class="qpc-hafs">﴿یَبۡغُونَكُمُ ٱلۡفِتۡنَةَ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٢٥٣٦<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿يَبغُونكُمُ الفتنَةَ﴾</span>، قال: يُبَطِّئونكم؛ عبد الله بن نَبْتَلٍ، وعبد الله بن أُبَيِّ بنُ سلولَ، ورِفاعةُ بنُ تابوتٍ، وأوس بن قيظيِّ{12}. (٧/٣٩٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٢٥٣٧<span class="dash">-</span></span> قال <span class="name-2">الضحاك بن مزاحم</span>: <span class="qpc-hafs">﴿الفتنة﴾</span>: الشرك{13}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٢٥٣٨<span class="dash">-</span></span> قال <span class="name-2">الضحاك بن مزاحم</span>: يعني: الكفر{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٢٥٣٩<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- <span class="qpc-hafs">﴿ولأوضعُوا خلالكُم﴾</span>: بينكم، <span class="qpc-hafs">﴿يَبغُونكُمُ الفتنَةَ﴾</span> بذلك{9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٢٥٤٠<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- <span class="qpc-hafs">﴿يبغونكم الفتنة﴾</span>، يقول: الكفر{10}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٢٥٤١<span class="dash">-</span></span> قال <span class="name-3">محمد بن السائب الكلبي</span>: <span class="qpc-hafs">﴿يبغونكم الفتنة﴾</span>، يعني: العيب، والشَّرَّ{17}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٢٥٤٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿يَبْغُونَكُمُ الفِتْنَةَ﴾</span>، يعني: الكفر{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٢٥٤٣<span class="dash">-</span></span> قال <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿ولأوضعوا خلالكم يبغونكم الفتنة﴾</span>: الكفر{19}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَفِیكُمۡ سَمَّـٰعُونَ لَهُمۡۗ وَٱللَّهُ عَلِیمُۢ بِٱلظَّـٰلِمِینَ ۝٤٧﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٢٥٤٤<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿وفيكُم سمّاعون لهُم﴾</span>، قال: مُحَدِّثون بأحاديثهم، غير منافقين، هم عيون للمنافقين{20}. (٧/٣٩٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٢٥٤٥<span class="dash">-</span></span> قال <span class="name-2">مجاهد بن جبر</span>: <span class="qpc-hafs">﴿وفيكم سماعون لهم﴾</span>، معناه: وفيكم مُحِبُّون لهم، يُؤَدُّون إليهم ما يسمعون منكم، وهم الجواسيس{21}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٢٥٤٦<span class="dash">-</span></span> قال <span class="name-2">الحسن البصري</span>: <span class="qpc-hafs">﴿وفيكم سماعون لهم﴾</span>، يعني: المنافقين؛ أنّهم عيون للمشركين عليكم، يسمعون أخباركم، فيرسلون بها إلى المشركين{22}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٢٥٤٧<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- قال: <span class="qpc-hafs">﴿وفيكم سماعون لهم﴾</span>: وفيكم مَن يسمع كلامَهم{23}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٢٥٤٨<span class="dash">-</span></span> عن <span class="name-2">زيد بن أسلم</span> -من طريق محمد بن أبان- في قوله: <span class="qpc-hafs">﴿وفيكُم سمّاعون لهُم﴾</span>، قال: مُبَلِّغون{24}. (٧/٣٩٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٢٥٤٩<span class="dash">-</span></span> عن <span class="name-3">محمد بن إسحاق</span> -من طريق سلمة- قال: كان الذين استأذنوا -فيما بلغني- مِن ذَوِي الشرف منهم: عبد الله بن أُبَيِّ بن سلول، والجَدُّ بن قيس، وكانوا أشرافًا في قومهم، فثَبَّطهم الله؛ لعلمه بهم أن يخرجوا معهم فيفسدوا عليه جنده، وكان في جنده قومٌ أهلُ محبةٍ لهم، وطاعة فيما يدعونهم إليه؛ لشرفهم فيهم، فقال: <span class="qpc-hafs">﴿وفيكم سماعون لهم﴾</span>{23}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٢٥٥٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وفِيكُمْ﴾</span> معشر المؤمنين <span class="qpc-hafs">﴿سَمّاعُونَ لَهُمْ﴾</span> من غير المنافقين، اتَّخذهم المنافقون عيونًا لهم يُحَدِّثونهم، <span class="qpc-hafs">﴿واللَّهُ عَلِيمٌ بِالظّالِمِينَ﴾</span> منهم عبد الله بن أُبَيِّ، وعبد الله بن نَبْتَلٍ، وجَدُّ بن قيس، ورِفاعة بن التابوت، وأوس بن قيظيِّ{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٢٥٥١<span class="dash">-</span></span> قال <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿وفيكم سماعون لهم﴾</span>: يسمعون ما يُؤَدُّونه لعدوكم{27}<span class=comment-ref>٢٩٦٣</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٢٩٦٣</span> أفادت الآثارُ اختلاف المفسرين في معنى قوله تعالى: <span class="qpc-hafs">﴿وفِيكُمْ سَمّاعُونَ لَهُمْ﴾</span> على قولين: <b>الأول:</b> وفيكم عيون ينقلون إليهم أخباركم. وهو قول مجاهد، والحسن، وابن زيد. <b>والثاني:</b> وفيكم من يسمع كلامهم ويطيعهم. وهو قول قتادة، وابن إسحاق.</p><p>و<span class="comment-type-4">علَّق</span> <u>ابنُ جرير</u> (١١/٤٨٧) على القول الأول بأنّ المعنى: «<span class="qpc-hafs">﴿وفيكم﴾</span> منهم <span class="qpc-hafs">﴿سمّاعون﴾</span> يسمعون حديثكم لهم، فيبلِّغونهم ويؤدونه إليهم، عيونٌ لهم عليكم».</p><p>و<span class="comment-type-1">وجَّه</span> المعنى على القول الثاني قائلًا: «فعلى هذا التأويل: وفيكم أهل سمع وطاعة منكم، لو صحبوكم أفسدوهم عليكم بتثبيطهم إياهم عن السَّيْر معكم».</p><p>و<span class="comment-type-1">وجَّه</span> <u>ابنُ القيم</u> (٢/١١) المعنى على القول الثاني قائلًا: «وفيكم أهل سَمْع وطاعة لهم، لو صحبهم هؤلاء المنافقون أفسدوهم عليكم».</p><p>و<span class="comment-type-3">رجَّح</span> <u>ابنُ جرير</u> القول الأول <span class="mustanad">مستندًا إلى الأغلب في لغة العرب</span> بقوله: «لأنّ الأغلب من كلام العرب في قولهم: سمّاعٌ، وصْفُ مَن وُصِفَ به أنّه سمّاعٌ للكلام، كما قال الله -جلَّ ثناؤه- في غير موضعٍ من كتابه: <span class="qpc-hafs">﴿سَمّاعُونَ لِلْكَذِبِ﴾</span> [المائدة:٤١، ٤٢]، واصفًا بذلك قومًا بسماع الكذب من الحديث. وأما إذا وصَفوا الرَّجُلَ بسماعِ كلام الرجل وأمْرِه ونهْيِه وقَبوله منه وانتهائه إليه فإنّما يَصِفُه له بأنه له سامعٌ ومطيع، ولا يكاد يقول: هو له سمّاعٌ مطيعٌ».</p><p>و<span class="comment-type-2">انتَقَد</span> <u>ابنُ تيمية</u> القول الأول <span class="mustanad">مستندًا إلى دلالة العقل</span> بقوله: «وأمّا مَن ظَنَّ أنّ المراد بقوله: <span class="qpc-hafs">﴿سَمّاعُونَ لَهُمْ﴾</span>: أنهم جواسيس لمن غاب، وأخذ حكم الجاسوس من هذه الآية؛ فقد غَلِط، فإنّ ما كان يظهره النبي ﷺ حتى يسمعه المنافقون واليهود لم يكن مما يكتمه حتى يكون نقله جسًّا عليه».</p><p>وكذا <span class="comment-type-2">انتَقَدَه</span> <u>ابنُ القيم</u> <span class="mustanad">مستندًا إلى دلالة العقل</span> بقوله: «ولم يكن في المؤمنين جواسيس للمنافقين؛ فإنّ المنافقين كانوا مختلطين بالمؤمنين، ينزلون معهم، ويرحلون، ويُصَلُّون معهم، ويجالسونهم، ولم يكونوا متحيِّزين عنهم، قد أرسلوا فيهم العيون ينقلون إليهم أخبارهم، فإنّ هذا إنّما يفعله مَن انحاز عن طائفة ولم يُخالِطها، وأرصد بينهم عيونًا له، فالقول قول قتادة وابن إسحاق».</p><p>و<span class="comment-type-2">انتقده</span> <u>ابنُ كثير</u> أيضًا <span class="mustanad">مستندًا إلى دلالة العقل</span> بقوله: «وهذا لا يبقى له اختصاص بخروجهم معهم، بل هذا عامٌّ في جميع الأحوال».</p><p>و<span class="comment-type-3">رجَّح</span> <u>ابنُ كثير</u> (٧/٢١٢) <span class="mustanad">مستندًا إلى السياق</span>، و<span class="comment-type-4">كذا</span> <u>ابنُ القيم</u> (٢/١٢)، و<span class="comment-type-4">قبلهما</span> <u>ابنُ تيمية</u> (٣/٣٧٤-٣٧٥) القول الثاني.</div></p></div>",footnotes:1:تفسير الثعلبي (طبعة دار التفسير) ١٣/٣٩٣.تفسير الثعلبي ٥/٥١.تفسير مقاتل بن سليمان ٢/١٧٣.أخرجه ابن جرير ١١/٤٨٥، وابن أبي حاتم ٦/١٨٠٧ من طريق أصبغ بن الفرج بلفظ: سأل الله عنهم نبيّه .... وبه عزاه السيوطي إلى أبي الشيخ.أي: تفرَّقُوا. النهاية (رفض).تفسير مجاهد ص٣٦٧، وأخرجه ابن أبي حاتم ٦/١٨٠٨. وعزاه السيوطي إلى ابن أبي شيبة، وابن المنذر، وأبي الشيخ.أخرجه ابن جرير ١١/٤٨٥.أخرجه عبد الرزاق ١/٢٧٦، وابن جرير ١١/٤٨٥، وابن أبي حاتم ٦/١٨٠٨. وعزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ١١/٤٨٤.أخرجه ابن أبي حاتم ٦/١٨٠٨.تفسير مقاتل بن سليمان ٢/١٧٣.تفسير مجاهد ص٣٦٩، وأخرجه ابن جرير ١١/٤٨٤، وابن أبي حاتم ٦/١٨٠٨. وعزاه السيوطي إلى ابن أبي شيبة، وابن المنذر، وأبي الشيخ.تفسير البغوي ٤/٥٦.تفسير الثعلبي ٥/٥١.أخرجه ابن جرير ١١/٤٨٤.أخرجه ابن أبي حاتم ٦/١٨٠٨.تفسير الثعلبي ٥/٥١، وتفسير البغوي ٤/٥٦.تفسير مقاتل بن سليمان ٢/١٧٣.أخرجه ابن جرير ١١/٤٨٥. وعلَّقه ابن أبي حاتم ٦/١٨٠٨.تفسير مجاهد ص٣٧٠، وأخرجه ابن جرير ١١/٤٨٦، وابن أبي حاتم ٦/١٨٠٨. وعزاه السيوطي إلى ابن أبي شيبة، وابن المنذر، وأبي الشيخ.تفسير الثعلبي ٥/٥١ بنحوه، وتفسير البغوي ٤/٥٦.ذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٢/٢٠٩-.أخرجه ابن جرير ١١/٤٨٦.أخرجه ابن أبي حاتم ٦/١٨٠٩.أخرجه ابن جرير ١١/٤٨٦.تفسير مقاتل بن سليمان ٢/١٧٣.أخرجه ابن جرير ١١/٤٨٦، وابن أبي حاتم ٦/١٨٠٩ من طريق أصبغ بن الفرج بلفظ: يسمعون ما تأتون به لعدوكم.