quran[7]{c,v,t}:
9,41," <q>﴿ٱنفِرُوا۟ خِفَافࣰا وَثِقَالࣰا﴾</q> - نزول الآية ٣٢٤٣٩- عن أبي الضُّحى مسلم بن صبيح -من طريق سعيد بن مسروق- قال: أولُ ما أُنزل مِن براءة: <q>﴿انفروا خفافا وثقالا﴾</q>، ثم نزل أوَّلُها وآخرُها{1}. (٧/٣٨٧) ٣٢٤٤٠- عن أبي مالك غزوان الغفاري -من طريق حصين- قال: أوَّلُ شيءٍ نزل مِن براءة: <q>﴿انفروا خفافا وثقالا﴾</q>{2}. (٧/٣٨٧) ٣٢٤٤١- عن مجاهد بن جبر -من طريق ابن أبي نجيح- قال: قالوا: إنّ فينا الثَّقيلَ، وذا الحاجةِ، والضَّيعةِ، والشغلِ، والمنتشرَ به أمرُه في ذلك. فأنزل الله: <q>﴿انفروا خفافا وثقالا﴾</q>{3}. (٧/٣٨٧) ٣٢٤٤٢- عن حضرميٍّ -من طريق المعتمر، عن أبيه- قال: ذُكِر لنا: أنّ أُناسًا كانوا عسى أن يكون أحدُهم عليلًا أو كبيرًا، فيقول: إنِّي لا آثم. فأنزل الله: <q>﴿انفروا خفافا وثقالا﴾</q>{4}. (٧/٣٨٨) ٣٢٤٤٣- عن إسماعيل السُّدِّيّ -من طريق أسباط- قال: جاء رجلٌ زَعَمُوا أنّه المِقداد، وكان عظيمًا سمينًا، فشكا إليه، وسأله أن يأذنَ له، فأبى؛ فنزلت يومئذٍ فيه: <q>﴿انفروا خفافًا وثقالًا﴾</q>{5}. (٧/٣٨٨) <q>﴿ٱنفِرُوا۟ خِفَافࣰا وَثِقَالࣰا﴾</q> - تفسير الآية ٣٢٤٤٤- عن أبي راشدٍ الحُبْرانيِّ، قال: رأيتُ المِقداد فارسَ رسول الله ﷺ بحمص يُريدُ الغَزْوَ، فقلت: لقد أعذر اللهُ إليك. قال: أبَتْ علينا سورةُ البُحُوث: <q>﴿انفروا خفافًا وثقالًا﴾</q>. يعني: سورة التوبة{6}. (٧/٣٨٩) ٣٢٤٤٥- عن أبي يزيد المدينيِّ، قال: كان أبو أيوب الأنصاريّ= (ز) ٣٢٤٤٦- والمقدادُ بن الأسود يقولان: أُمِرنا أن نَنفِرَ على كلِّ حالٍ. ويتأوَّلان: <q>﴿انفروا خفافا وثقالا﴾</q>{7}. (٧/٣٨٩) ٣٢٤٤٧- عن أبي أيوب -من طريق أبي العوّام-: أنّه أقام عن الجهاد عامًا واحِدًا، فقرأ هذه الآية: <q>﴿انفروا خفافا وثقالا﴾</q>، فغزا مِن عامه، وقال: ما رأيتُ في هذه الآية مِن رُخصَة{8}. (ز) ٣٢٤٤٨- عن محمد بن سيرين، قال: شَهِد أبو أيوبَ بدرًا، ثم لم يَتَخَلَّفْ عن غزوةٍ للمسلمين إلا عامًا واحدًا، وكان يقول: قال الله: <q>﴿انفروا خفافًا وثقالًا﴾</q>. فلا أجدُني إلا خفيفًا وثقيلًا{9}. (٧/٣٨٩) ٣٢٤٤٩- عن أنس بن مالك: أنّ أبا طلحة قرأ سورة براءة، فأتى على هذه الآية: <q>﴿انفروا خفافًا وثقالًا﴾</q>، قال: أرى ربَّنا يَستنفِرُنا شُيوخًا وشُبّانًا. وفي لفظٍ: فقال: ما أسمعُ اللهَ عَذَرَ أحدًا؛ جَهِّزوني بَنِيَّ. قال بنُوه: يرحمُك الله، قد غزوتَ مع رسول الله ﷺ حتى مات، وغزوتَ مع أبي بكر حتى مات، وغزوتَ مع عمر حتى مات، فنحن نغزو عنك. فأبى، فركِب البحر فمات، فلم يجِدوا له جزيرةً يدفنونه فيها إلا بعد تسعةِ أيام، فلم يتغيَّر، فدفنوه فيها{10}. (٧/٣٨٨) ٣٢٤٥٠- عن علي بن زيد بن جُدْعان، قال: قال أبو طلحة: <q>﴿انفروا خفافا وثقالا﴾</q>، قال: كهولًا وشبابًا. قال: ما أرى اللهُ عَذَر أحدًا. فخرج إلى الشام، فجاهد{11}. (ز) ٣٢٤٥١- عن المغيرة بن النعمان، قال: كان رجلٌ مِن النَّخَع، وكان شيخًا بادِنًا، فأراد الغزوَ، فمنعه سعد بن أبي وقاص، فقال: إنّ الله يقول: <q>﴿انفروا خفافا وثقالا﴾</q>. فأذِن له سعد، فقُتِل الشيخ، فسأل عنه بعدُ عمر، فقال: ما فعل الشيخ الذي كان من بني هاشم؟ فقالوا: قُتِل، يا أمير المؤمنين{12}. (ز) ٣٢٤٥٢- عن عبد الله بن عباس -من طريق العوفي- في قوله: <q>﴿انفروا خفافا وثقالا﴾</q>، قال: نِشاطًا، وغير نِشاطٍ{13}. (٧/٣٨٧) ٣٢٤٥٣- وعن قتادة بن دعامة -من طريق مَعْمَر-، نحو ذلك{14}. (ز) ٣٢٤٥٤- عن عبد الله بن عباس= (ز) ٣٢٤٥٥- وعامر الشعبي، قالا: شُبّانًا، وكهولًا{15}. (ز) ٣٢٤٥٦- عن مجاهد بن جبر -من طريق ابن أبي نجيح- قال: قالوا: إنّ فينا الثَّقيلَ، وذا الحاجةِ، والضَّيعةِ، والشغلِ، والمنتشرَ به أمرُه في ذلك. فأنزل الله: <q>﴿انفروا خفافا وثقالا﴾</q>، وأبى أن يَعْذرَهم دون أن يَنفِروا خِفافًا وثِقالًا، وعلى ما كان منهم{3}. (٧/٣٨٧) ٣٢٤٥٧- عن مجاهد بن جبر -من طريق ابن أبي نجيح- <q>﴿انفروا خفافا وثقالا﴾</q>، قال: شبابًا وشيوخًا، وأغنياء ومساكين{17}. (ز) ٣٢٤٥٨- عن الضحاك بن مُزاحِم -من طريق جُوَيْبِر-: كُهولًا، وشُبّانًا{18}. (ز) ٣٢٤٥٩- عن عكرمة مولى ابن عباس -من طريق إسماعيل- في قوله: <q>﴿خفافًا وثقالًا﴾</q>، قال: شبابًا، وشيوخًا{19}. (٧/٣٨٧) ٣٢٤٦٠- عن الحسن البصري -من طريق منصور بن زاذان- في قوله: <q>﴿انفروا خفافا وثقالا﴾</q>، قال: في العُسْر، واليُسْر{3}. (٧/٣٨٧) ٣٢٤٦١- قال الحسن البصري -من طريق قتادة-: شيوخًا، وشُبّانًا{21}. (ز) ٣٢٤٦٢- عن أبي صالح باذام -من طريق إسماعيل بن أبي خالد- قال: الشابُّ، والشيخ{22}. (ز) ٣٢٤٦٣- عن أبي صالح باذام -من طريق إسماعيل- <q>﴿انفروا خفافا وثقالا﴾</q>، قال: كل شيخ، وشابٍّ{21}. (ز) ٣٢٤٦٤- عن أبي صالح باذام -من طريق عنبسة، عمَّن ذَكَرَه- <q>﴿انفروا خفافا وثقالا﴾</q>، قال: أغنياء، وفقراء{24}. (ز) ٣٢٤٦٥- عن الحَكَم [بن عتيبة] -من طريق منصور- في قوله: <q>﴿انفروا خفافا وثقالا﴾</q>، قال: مشاغيلَ، وغيرَ مشاغيل{25}. (٧/٣٨٧) ٣٢٤٦٦- عن قتادة بن دعامة -من طريق مَعْمَر- <q>﴿خفافا وثقالا﴾</q>، قال: نِشاطًا، وغير نِشاطٍ{24}. (ز) ٣٢٤٦٧- عن إسماعيل السُّدِّيّ -من طريق أسباط- قوله تعالى: <q>﴿انفروا خفافا وثقالا﴾</q>، يقول: غنيًّا وفقيرًا، وقويًّا وضعيفًا{27}. (ز) ٣٢٤٦٨- عن زيد بن أسلم، في قوله: <q>﴿انفروا خفافا وثقالا﴾</q>، قال: فتيانًا، وكُهولًا{28}. (٧/٣٨٧) ٣٢٤٦٩- عن شمر بن عطية -من طريق حفص بن حميد-: كهولًا، وشُبّانًا{29}. (ز) ٣٢٤٧٠- قال مقاتل ين سليمان: <q>﴿انفروا﴾</q> إلى غزاة تبوك <q>﴿خفافا وثقالا﴾</q> يعني: نِشاطًا، وغير نِشاط{30}. (ز) ٣٢٤٧١- عن مقاتل بن حيان -من طريق بُكَير بن معروف- في قوله: <q>﴿انفروا خفافا وثقالا﴾</q>، قال: شُبّانًا، وكهولًا{29}. (ز) ٣٢٤٧٢- قال أبو عمرو الأوزاعيّ -من طريق الوليد-: إذا كان النفر إلى دروب الشام نفر الناس إليها خفافا ركبانا، وإذا كان النفر إلى هذه السواحل نفروا إليها خفافًا وثقالًا؛ ركبانًا ومُشاةً{4}٢٩٥٩. (ز) ٢٩٥٩ علَّقَ ابنُ كثير (٧/٢٠٨) على قول الأوزاعيّ هذا بقوله: «هذا تفصيل في المسألة». وعلَّقَ ابنُ عطية (٤/٣١٩-٣٢٠) على قول الأوزاعيِّ، وقول آخر مفاده: أنّ الخفيف هو الشجاع، والثقيل هو الجبان. فقال: «هذان الوجهان الآخران ينعكسان، وقد قيل ذلك، ولكنه بحسب وطأتهم على العدو، فالشجاع هو الثقيل، وكذلك الفارس، والجبان هو الخفيف، وكذلك الراجل، وكذلك ينعكس الفقير والغني، فيكون الغني هو الثقيل، بمعنى: صاحب الشغل، ومعنى هذا: أنّ الناس أُمِروا جملة». ٣٢٤٧٣- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿انفروا خفافا وثقالا﴾</q>، قال: الثقيلُ الذي له الضَّيْعة، فهو ثقيل يكره أن يضيع ضيعته، ويخرج، والخفيفُ الذي لا ضَيْعَة له، فقال الله: <q>﴿انفروا خفافا وثقالا﴾</q>{4}٢٩٦٠. (ز) ٢٩٦٠ اختُلِف في معنى الخِفَّة والثّقَل اللَّذَيْن أمر الله بهما في الآية على ستّة أقوال: أولها: أنّ المعنى: شبابًا، وشيوخًا. وثانيها: أنّ المعنى: مشاغيل، وغير مشاغيل. وثالثها: أنّ المعنى: نِشاطًا، وغيرَ نِشاط. ورابعها: أنّ المعنى: في اليسر والعسر، فقراء وأغنياء. وخامسها: أنّ المعنى: رُكبانًا، ومُشاةً. وسادسها: أنّ المعنى: ذا ضيعةٍ، وغيرَ ذي ضيعةٍ. وذهب ابنُ جرير (١١/٤٧٤) إلى أنّ كلَّ تلك الأقوال تدخل تحت الآية، مستندًا إلى عموم لفظها، فقال: «أولى الأقوال في ذلك عندنا بالصواب أن يُقال: إنّ الله -تعالى ذِكْرُه- أمَرَ المؤمنين بالنَّفر لجهاد أعدائه في سبيله، خفافًا وثقالًا. وقد يدخل في الخِفاف كلُّ مَن كان سهلًا عليه النفر لقوة بدنه على ذلك، وصحة جسمه، وشبابه، ومَن كان ذا يُسْرٍ بمالٍ، وفراغ من الاشتغال، وقادرًا على الظهر والركاب. ويدخل في الثِّقال كلُّ مَن كان بخلاف ذلك، مِن ضعيف الجسم وعليله وسقيمه، ومِن مُعسِرٍ من المال، ومشتغلٍ بضَيْعَة ومعاش، ومَن كان لا ظهرَ له ولا ركاب، والشيخ، وذو السِّن، والعِيال. فإذ كان قد يدخل في الخفاف والثقال مَن وصفنا مِن أهل الصفات التي ذكرنا، ولم يكن الله -جل ثناؤُه- خصَّ مِن ذلك صنفًا دون صنف في الكتاب، ولا على لسان الرسول ﷺ، ولا نَصَب على خصوصه دليلًا؛ وجب أن يُقال: إنّ الله -جل ثناؤه- أمر المؤمنين من أصحاب رسوله بالنفر للجهاد في سبيله خفافًا وثقالًا مع رسوله ﷺ، على كل حالٍ مِن أحوال الخفّة والثقل». وهو ظاهر قول ابن كثير (٧/٢٠٨). وقال ابنُ عطية (٤/٣٢٠): «هذه الأقوال إنّما هي على معنى المثال في الثِّقل، والخِفَّة». ٣٢٤٧٤- عن حِبّانِ بن زيدٍ الشَّرْعَبِيُّ، قال: نفرنا مع صفوان بن عمرو -وكان واليًا على حمص قِبَل الأُفْسُوسِ{34}- إلى الجَراجِمَةِ{35}، فلقيت شيخًا كبيرا هِمًّا{36} قد سقط حاجباه على عينيه، من أهل دمشق، على راحلته فيمن أغار، فأقبلت عليه، فقلتُ: يا عمِّ، لقد أعذر اللهُ إليك. قال: فرفع حاجبيه، فقال: يا ابن أخي، استنفرنا الله خِفافًا وثِقالًا، مَن يُحِبُّه الله يبتليه، ثم يُعيدُه فيُبقِيه، وإنما يبتلي اللهُ مِن عباده مَن شكر وصبر وذكر ولم يعبد إلا الله{17}. (ز) <q>﴿ٱنفِرُوا۟ خِفَافࣰا وَثِقَالࣰا﴾</q> - النسخ في الآية ٣٢٤٧٥- عن عبد الله بن عباس -من طريق عطاء الخراساني- في قوله: <q>﴿انفروا خفافا وثقالا﴾</q>: فنسخ هذه الآيةَ <q>﴿وما كان المؤمنون لينفروا كافة﴾</q> إلى قوله: <q>﴿لعلهم يحذرون﴾</q> [التوبة:١٢٢]، يقول: لتنفِرْ طائفةٌ، ولتَمْكُثْ طائفةٌ مع رسول الله ﷺ، فالماكثون مع رسول الله ﷺ هم الذين يتفقهون في الدين{27}. (ز) ٣٢٤٧٦- وعن محمد بن كعب القرظي= (ز) ٣٢٤٧٧- وعطاء الخراساني، مثل ذلك{39}. (ز) ٣٢٤٧٨- عن إسماعيل السُّدِّيّ -من طريق أسباط- قال: جاء رجلٌ زعموا: أنّه المِقداد، وكان عظيمًا سمينًا، فشكا إليه، وسأله أن يأذنَ له، فأبى؛ فنزلت يومئذٍ فيه: <q>﴿انفروا خفافًا وثقالًا﴾</q>. فلما نزلت هذه الآيةُ اشتدَّ على الناس شأنُها؛ فنسخها اللهُ، فقال: <q>﴿ليس على الضعفاء ولا على المرضى﴾</q> الآية [التوبة:٩١]{40}. (٧/٣٨٨) <q>﴿وَجَـٰهِدُوا۟ بِأَمۡوَ ٰ⁠لِكُمۡ وَأَنفُسِكُمۡ فِی سَبِیلِ ٱللَّهِۚ ذَ ٰ⁠لِكُمۡ خَیۡرࣱ لَّكُمۡ إِن كُنتُمۡ تَعۡلَمُونَ ۝٤١﴾</q> - تفسير ٣٢٤٧٩- قال مقاتل ين سليمان: <q>﴿وجاهدوا﴾</q> العدوَّ <q>﴿بأموالكم وأنفسكم في سبيل الله﴾</q> يعني: الجهاد، <q>﴿ذلكم خير لكم﴾</q> مِن القعود، <q>﴿إن كنتم تعلمون﴾</q>{30}. (ز) <q>﴿وَجَـٰهِدُوا۟ بِأَمۡوَ ٰ⁠لِكُمۡ وَأَنفُسِكُمۡ فِی سَبِیلِ ٱللَّهِۚ ذَ ٰ⁠لِكُمۡ خَیۡرࣱ لَّكُمۡ إِن كُنتُمۡ تَعۡلَمُونَ ۝٤١﴾</q> - آثار متعلقة بالآية ٣٢٤٨٠- عن الحارث -يعني: أبا مالك الأشعري-، قال: قال رسول الله ﷺ: «أنا آمركم بخمسٍ أمَرَني اللهُ بِهِنَّ: الجهاد في سبيل الله، والجماعة، والسمع، والطاعة، والهجرة»{42}. (ز) ",footnotes:1:أخرجه ابن أبي شيبة ١٠/٢٦٧ (١٩٧٠٧)، وابن جرير ١١/٤٧٤. وعزاه السيوطي إلى الفريابيّ، وأبي الشيخ.أخرجه ابن أبي شيبة ١٩/٥٧٠-٥٧١ (٣٧٠٧٧). وعزاه السيوطي إلى ابن المنذر.أخرجه ابن أبي حاتم ٦/١٨٠٣. وعزاه السيوطي إلى أبي الشيخ.أخرجه ابن جرير ١١/٤٧٢.أخرجه ابن أبي حاتم ٦/١٨٠٣-١٨٠٤. وعزاه السيوطي إلى أبي الشيخ.أخرجه ابن جرير ١١/٤٧٣-٤٧٤، وابن أبي حاتم ٦/١٨٠٢، والطبراني (٥٥٦)، والحاكم ٣/٣٤٩.أخرجه ابن أبي حاتم ٦/١٨٠٢. وعزاه السيوطي إلى أبي الشيخ، وابن مَرْدُويَه.أخرجه ابن أبي شيبة ١٠/٢٧١ (١٩٧١٣).أخرجه ابن سعد ٣/٤٨٥، وابن جرير ١١/٤٧٣، والحاكم ٣/٤٥٨.أخرجه ابن سعد ٣/٥٠٧، وابن أبي عمر -كما في المطالب (٤٠٠٧)-، وعبد الله بن أحمد في زوائد المسند ص٢٥٠، وأبو يعلى (٣٤١٣)، وابن جرير ١١/٤٦٨ مختصرًا، وابن أبي حاتم ٦/١٨٠٢، وابن حبان (٧١٨٤)، والحاكم ٣/٣٥٣. وعزاه السيوطي إلى ابن أبي عمر العدنيّ في مسنده، وابن المنذر، وأبي الشيخ، وابن مَرْدُويَه.أخرجه ابن أبي شيبة ١٠/٣٤٣ (١٩٨٥٩).أخرجه ابن جرير ١١/٤٦٨.أخرجه ابن جرير ١١/٤٧١، وابن أبي حاتم ٦/١٨٠٢-١٨٠٣.أخرجه عبد الرزاق ٢/٢٧٦، وابن جرير ١١/٤٧١. وعلَّقه ابن أبي حاتم ٦/١٨٠٣.علَّقه ابن أبي حاتم ٦/١٨٠٢.أخرجه ابن أبي حاتم ٦/١٨٠٣. وعزاه السيوطي إلى أبي الشيخ.أخرجه ابن جرير ١١/٤٧٠.أخرجه ابن جرير ١١/٤٦٩.أخرجه ابن أبي شيبة ١٠/٢٧١ (١٩٧١٨)، ١١/٤٩٦. وعلَّقه ابن أبي حاتم ٦/١٨٠٢. وعزاه السيوطي إلى ابن المنذر.أخرجه ابن أبي حاتم ٦/١٨٠٣. وعزاه السيوطي إلى أبي الشيخ.أخرجه ابن جرير ١١/٤٧٠. وعلَّقه ابن أبي حاتم ٦/١٨٠٢.أخرجه ابن أبي شيبة ١٠/٢٧١ (١٩٧١٥)، وابن جرير ١١/٤٦٩. وعلَّقه ابن أبي حاتم ٦/١٨٠٢.أخرجه ابن جرير ١١/٤٧٠. وعلَّقه ابن أبي حاتم ٦/١٨٠٢.أخرجه ابن جرير ١١/٤٧١.أخرجه ابن أبي شيبة ١٠/٢٧١ (١٩٧١٧)، وابن جرير ١١/٤٧١، وابن أبي حاتم ٦/١٨٠٣. وعزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ١١/٤٧١.أخرجه ابن أبي حاتم ٦/١٨٠٤.علَّقه ابن أبي حاتم ٦/١٨٠٢. وعزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ١١/٤٦٩. وعلَّقه ابن أبي حاتم ٦/١٨٠٢.تفسير مقاتل بن سليمان ٢/١٧٢.أخرجه ابن جرير ١١/٤٦٩. وعلَّقه ابن أبي حاتم ٦/١٨٠٢.أخرجه ابن جرير ١١/٤٧٢.أخرجه ابن جرير ١١/٤٧٢.الأُفْسُوسِ: بلد بثغور طرسوس، وطرسوس مدينة بالشام بين أنطاكية وحلب. معجم البلدان ١/٣٣٠، ٣/٥٣٦.الجَراجِمَةُ: قوم من العجم بالجزيرة أو نَبَط الشام. لسان العرب (جرجم).الهِمُّ: الشيخ الكبير البالي. لسان العرب (همم).أخرجه ابن جرير ١١/٤٧٠.أخرجه ابن أبي حاتم ٦/١٨٠٤.علَّقه ابن أبي حاتم ٦/١٨٠٤.أخرجه ابن أبي حاتم ٦/١٨٠٣-١٨٠٤. وعزاه السيوطي إلى أبي الشيخ. وقد تقدم الحديث عن النسخ في هذه المسألة عند قوله تعالى: <q>﴿إلّا تَنْفِرُوا يُعَذِّبْكُمْ عَذابًا ألِيمًا﴾</q> [التوبة: ٣٩].تفسير مقاتل بن سليمان ٢/١٧٢.أخرجه الترمذي ٥/١٣٦-١٣٩ (٣٠٧٩)، وابن خزيمة ٣/٣٤٧-٣٤٨ (١٨٩٥)، وابن حبان ١٤/١٢٤-١٢٦ (٦٢٣٣)، والحاكم ١/٢٠٤ (٤٠٤-٤٠٦)، ١/٥٨١-٥٨٢ (١٥٣٤) جميعهم مُطَوَّلًا، وابن أبي حاتم ٦/١٨٠٤ (١٠٠٦٤) واللفظ له، من طريق أبان بن يزيد العطار، عن يحيى بن أبي كثير، عن زيد بن أبي سلام، عن أبي سلام، عن الحارث الأشعري به. قال الترمذي: «هذا حديث حسن صحيح غريب». وقال الحاكم في الموضع الأخير: «هذا حديث صحيح، على شرط الشيخين، ولم يخرجاه». وقال الذهبي: «لم يخرجاه؛ لأن الحارث تفرَّد عنه أبو سلام».
9,42," <q>﴿لَوۡ كَانَ عَرَضࣰا قَرِیبࣰا وَسَفَرࣰا قَاصِدࣰا لَّٱتَّبَعُوكَ وَلَـٰكِنۢ بَعُدَتۡ عَلَیۡهِمُ ٱلشُّقَّةُۚ وَسَیَحۡلِفُونَ بِٱللَّهِ لَوِ ٱسۡتَطَعۡنَا لَخَرَجۡنَا مَعَكُمۡ یُهۡلِكُونَ أَنفُسَهُمۡ وَٱللَّهُ یَعۡلَمُ إِنَّهُمۡ لَكَـٰذِبُونَ ۝٤٢﴾</q> - نزول الآية ٣٢٤٨١- عن عبد الله بن عباس -من طريق العوفي- قال: إنّ رسولَ الله ﷺ قيل له: ألا تَغزُو بني الأصفر، لعلك أن تُصيبَ ابنةَ عظيم الروم؟ فقال رجلان: قد عَلمِتَ -يا رسولَ الله- أنّ النساءَ فِتنةٌ، فلا تَفْتِنّا بِهِنَّ، فائْذَن لنا. فأذِن لهما، فلما انطلقا قال أحدُهما: إن هو إلا شَحْمةٌ لأَوَّلِ آكلٍ. فسار رسولُ الله ﷺ، ولم ينَزِلْ عليه في ذلك شيءٌ، فلمّا كان ببعض الطريق نزل عليه وهو على بعض المياه: <q>﴿لو كان عرضا قريبا وسفرا قاصدا لاتبعوك﴾</q>. ونزل عليه: <q>﴿عفا الله عنك لم أذنت لهم﴾</q>. ونزل عليه: <q>﴿لا يستأذنك الذين يؤمنون بالله واليوم الآخر﴾</q>. ونزل عليه: <q>﴿إنهم رجس ومأواهم جهنم جزاء بما كانوا يكسبون﴾</q> [التوبة:٩٥]{1}. (٧/٣٩٠) ٣٢٤٨٢- قال محمد بن السائب الكلبي: وذلك حين استنفر رسولُ الله ﷺ الناسَ إلى تبوك في حرٍّ شديد، وعسرة من الناس، فكره بعضُ الناس الخروج، وجعلوا يستأذنون في المقام مِن بين [...]{2} ومَن ليست به علة، فيأذن لِمن شاء أن يأذن، وتخلَّف كثيرٌ منهم بغير إذن؛ فأنزل الله ﷿: <q>﴿لو كان عرضا قريبا﴾</q>{3}. (ز) <q>﴿لَوۡ كَانَ عَرَضࣰا قَرِیبࣰا وَسَفَرࣰا قَاصِدࣰا لَّٱتَّبَعُوكَ﴾</q> - تفسير ٣٢٤٨٣- عن عبد الله بن عباس -من طريق الضحاك- <q>﴿لو كان عرضًا قريبًا﴾</q>، قال: غنيمةً قريبةً{4}. (٧/٣٩٠) ٣٢٤٨٤- عن قتادة بن دعامة -من طريق مَعْمَر- <q>﴿لو كان عرضا قريبا﴾</q>، قال: هي غزوة تبوك{5}. (ز) ٣٢٤٨٥- عن إسماعيل السُّدِّيّ -من طريق أسباط- في قوله: <q>﴿لو كان عرضًا قريبًا﴾</q> يقول: دنيا يطلُبونها، <q>﴿وسفرا قاصدا﴾</q> يقول: قريبًا{6}. (٧/٣٩٠) ٣٢٤٨٦- قال مقاتل ين سليمان: <q>﴿لو كان عرضا قريبا﴾</q> يعني: غنيمةً قريبةً، <q>﴿وسفرا قاصدا﴾</q> يعني: هَيِّنًا <q>﴿لاتبعوك﴾</q> في غزاتك، <q>﴿ولكن بعدت عليهم الشقة﴾</q>{7}. (ز) <q>﴿وَلَـٰكِنۢ بَعُدَتۡ عَلَیۡهِمُ ٱلشُّقَّةُۚ﴾</q> - تفسير ٣٢٤٨٧- عن عبد الله بن عباس -من طريق أبي رَوْق، عن الضَّحّاك- <q>﴿ولكن بعدت عليهم الشقة﴾</q>، قال: المَسِير{4}. (٧/٣٩٠) <q>﴿وَسَیَحۡلِفُونَ بِٱللَّهِ لَوِ ٱسۡتَطَعۡنَا لَخَرَجۡنَا مَعَكُمۡ یُهۡلِكُونَ أَنفُسَهُمۡ﴾</q> - تفسير ٣٢٤٨٨- عن الضحاك بن مزاحم -من طريق جويبر- <q>﴿وسيحلفون بالله لو استطعنا لخرجنا معكم﴾</q>، قال: لِحَلِفِهم باللهِ وهم كاذبون{9}. (ز) ٣٢٤٨٩- قال مقاتل ين سليمان: <q>﴿وسيحلفون بالله لو استطعنا﴾</q> يعني: لو وجدنا سَعَةً في المال؛ <q>﴿لخرجنا معكم﴾</q> في غزاتكم{7}. (ز) <q>﴿وَٱللَّهُ یَعۡلَمُ إِنَّهُمۡ لَكَـٰذِبُونَ ۝٤٢﴾</q> - تفسير ٣٢٤٩٠- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿والله يعلم إنهم لكاذبون﴾</q>، قال: لقد كانوا يستطيعون الخروج، ولكن كان تَبْطِئةً مِن عند أنفسِهم والشيطان، وزهادةً في الخير{11}. (٧/٣٩٠) ٣٢٤٩١- قال مقاتل ين سليمان: <q>﴿يهلكون أنفسهم والله يعلم إنهم لكاذبون﴾</q> بأنّ لهم سَعَة في الخروج، ولكنهم لم يريدوا الخروج، منهم: جَدُّ بن قيس، ومُعَتِّب بن قُشَيْر، وهما من الأنصار{7}. (ز) ٣٢٤٩٢- عن محمد بن إسحاق -من طريق سلمة- <q>﴿والله يعلم إنهم لكاذبون﴾</q>، أي: إنهم يستطيعون{13}. (ز) ",footnotes:1:أخرجه ابن جرير ١١/٦٢٩.كذا في المطبوع.ذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٢/٢٠٧-.أخرجه ابن أبي حاتم ٦/١٨٠٤. وعزاه السيوطي إلى أبي الشيخ.أخرجه عبد الرزاق ٢/٢٧٦، وابن جرير ١١/٤٧٧، وابن أبي حاتم ٦/١٨٠٤.أخرجه ابن أبي حاتم ٦/١٨٠٤.تفسير مقاتل بن سليمان ٢/١٧٢.أخرجه ابن أبي حاتم ٦/١٨٠٤. وعزاه السيوطي إلى أبي الشيخ.أخرجه ابن أبي حاتم ٦/١٨٠٥.تفسير مقاتل بن سليمان ٢/١٧٢.أخرجه ابن جرير ١١/٤٧٧. وعزاه السيوطي إلى عَبد بن حُمَيد، وابن المنذر بلفظ: وزهادةً في الجهاد.تفسير مقاتل بن سليمان ٢/١٧٢.أخرجه ابن جرير ١١/٤٧٧، وابن أبي حاتم ٦/١٨٠٥.
9,43," <q>﴿عَفَا ٱللَّهُ عَنكَ لِمَ أَذِنتَ لَهُمۡ﴾</q> - نزول الآية ٣٢٤٩٣- عن عمرو بن ميمونٍ الأوديِّ -من طريق عمرو بن دينار- قال: اثنتان فعلهما رسولُ الله ﷺ لم يُؤمرْ فيهما بشيءٍ: إذنُه للمنافقين، وأخذُه من الأسارى؛ فأنزل الله: <q>﴿عفا الله عنك لم أذنت لهم﴾</q> الآية{1}. (٧/٣٩١) ٣٢٤٩٤- عن إسماعيل السُّدِّيّ -من طريق أسباط- قوله: <q>﴿عفا الله عنك لم أذنت لهم حتى يتبين لك الذين صدقوا﴾</q>، استأذنه يومئذ ناسٌ، فأَذِن لهم؛ فقال الله: <q>﴿لم أذنت لهم حتى يتبين لك الذين صدقوا﴾</q>{2}. (ز) <q>﴿عَفَا ٱللَّهُ عَنكَ لِمَ أَذِنتَ لَهُمۡ﴾</q> - تفسير الآية ٣٢٤٩٥- عن مُورِّقٍ العجليِّ -من طريق موسى بن سَرْوانَ- في قوله: <q>﴿عفا الله عنك لم أذنت لهم﴾</q>، قال: عاتَبَه ربُّه ﷿{3}. (٧/٣٩١) ٣٢٤٩٦- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿عفا الله عنك لم أذنت لهم﴾</q>، قال: ناسٌ قالوا: استأذِنوا رسولَ الله ﷺ؛ فإن أذِن لكم فاقعُدوا، وإن لم يأذن لكم فاقعُدوا{4}. (٧/٣٩١) ٣٢٤٩٧- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿عفا الله عنك لم أذنت لهم حتى يتبين لك الذين صدقوا﴾</q> الآية: عاتَبه كما تسمعون{5}. (ز) ٣٢٤٩٨- عن عون بن عبد الله -من طريق مسعر- قال: سمعتم بمعاتبةٍ أحسنَ من هذا، بدأ بالعفوِ قبلَ المعاتبة، فقال: <q>﴿عفا الله عنك لم أذنت لهم﴾</q>{6}. (٧/٣٩١) ٣٢٤٩٩- قال مقاتل ين سليمان: ثم قال للنبي ﷺ: <q>﴿عفا الله عنك لم أذنت لهم﴾</q> في القعود، يعني: في التَّخَلُّف{7}. (ز) <q>﴿حَتَّىٰ یَتَبَیَّنَ لَكَ ٱلَّذِینَ صَدَقُوا۟﴾</q> - تفسير ٣٢٥٠٠- عن إسماعيل السُّدِّيّ -من طريق أسباط- قوله: <q>﴿لم أذنت لهم حتى يتبين لك الذين صدقوا﴾</q>: معرفة الذين صدقوا بالخروج{2}. (ز) ٣٢٥٠١- قال مقاتل ين سليمان: <q>﴿حتى يتبين لك الذين صدقوا﴾</q> في قولهم، يعني: أهل العذر، منهم: المقداد بن الأسود الكندي، وكان سمينًا{7}. (ز) <q>﴿وَتَعۡلَمَ ٱلۡكَـٰذِبِینَ ۝٤٣﴾</q> - تفسير ٣٢٥٠٢- عن إسماعيل السُّدِّيّ -من طريق أسباط- قوله: <q>﴿وتعلم الكاذبين﴾</q>، قال: معرفة الذين كذبوا بالقعود{2}. (ز) ٣٢٥٠٣- قال مقاتل ين سليمان: <q>﴿وتعلم الكاذبين﴾</q> في قولهم، يعني: مَن لا قَدْر لهم{7}. (ز) ",footnotes:1:أخرجه عبد الرزاق في المصنف (٩٤٠٣)، وابن جرير ١١/٤٧٩.أخرجه ابن أبي حاتم ٦/١٨٠٦.أخرجه ابن جرير ١١/٤٧٩، وابن أبي حاتم ٦/١٨٠٥. وعزاه السيوطي إلى أبي الشيخ.تفسير مجاهد ص٣٦٩، وأخرجه ابن جرير ١١/٤٧٨، وابن أبي حاتم ٦/١٨٠٥. وعزاه السيوطي إلى ابن أبي شيبة، وابن المنذر.أخرجه ابن جرير ١١/٤٧٨.أخرجه ابن أبي شيبة ١٨/٥٤٢-٥٤٣ (٣٥٣٦٣)، وابن أبي حاتم ٦/١٨٠٥. وعزاه السيوطي إلى ابن المنذر، وأبي الشيخ. وفي رواية عند ابن أبي حاتم: أخبره بالعفو قبل أن يخبره بالذنب، فقال: <q>﴿عفا الله عنك لم أذنت لهم﴾</q>.تفسير مقاتل بن سليمان ٢/١٧٢.أخرجه ابن أبي حاتم ٦/١٨٠٦.تفسير مقاتل بن سليمان ٢/١٧٢.أخرجه ابن أبي حاتم ٦/١٨٠٦.تفسير مقاتل بن سليمان ٢/١٧٢.
9,44," <q>﴿لَا یَسۡتَـٔۡذِنُكَ ٱلَّذِینَ یُؤۡمِنُونَ بِٱللَّهِ وَٱلۡیَوۡمِ ٱلۡـَٔاخِرِ أَن یُجَـٰهِدُوا۟ بِأَمۡوَ ٰ⁠لِهِمۡ وَأَنفُسِهِمۡۗ وَٱللَّهُ عَلِیمُۢ بِٱلۡمُتَّقِینَ ۝٤٤﴾</q> - تفسير ٣٢٥٠٤- عن عبد الله بن عباس -من طريق علي- في قوله: <q>﴿لا يستأذنك الذين يؤمنون بالله واليوم الآخرة﴾</q>، قال: هذا تَعْييرٌ للمنافقين حين استأذَنوا في القعود عن الجهاد بغيرِ عذرٍ، وعذَرَ اللهُ المؤمنين فقال: <q>﴿فإذا استأذنوك لبعض شأنهم فأذن لمن شئت منهم﴾</q> [النور:٦٢]{1}. (٧/٣٩٢) ٣٢٥٠٥- قال مقاتل بن سليمان: <q>﴿لا يستأذنك﴾</q> في القعود <q>﴿الذين يؤمنون بالله واليوم الآخر﴾</q> يعني: الذين يُصَدِّقون بتوحيد الله، وبالبعث الذي فيه جزاء الأعمال؛ أنّه كائن، <q>﴿أن يجاهدوا﴾</q> العدوَّ مِن غير عذر <q>﴿بأموالهم وأنفسهم﴾</q> كراهية الجهاد{2}. (ز) <q>﴿لَا یَسۡتَـٔۡذِنُكَ ٱلَّذِینَ یُؤۡمِنُونَ بِٱللَّهِ وَٱلۡیَوۡمِ ٱلۡـَٔاخِرِ أَن یُجَـٰهِدُوا۟ بِأَمۡوَ ٰ⁠لِهِمۡ وَأَنفُسِهِمۡۗ وَٱللَّهُ عَلِیمُۢ بِٱلۡمُتَّقِینَ ۝٤٤﴾</q> - النسخ في الآيات ٣٢٥٠٦- عن عبد الله بن عباس -من طريق الضحاك- في قوله: <q>﴿عفا الله عنك لم أذنت لهم﴾</q> الآياتِ الثلاثَ، قال: نسَخَها: <q>﴿فإذا استأذنوك لبعض شأنهم فأذن لمن شئت منهم﴾</q> [النور:٦٢]{3}. (٧/٣٩١) ٣٢٥٠٧- عن عبد الله بن عباس -من طريقِ عطاءٍ الخُراساني- في قوله: <q>﴿لا يستأذنك الذين يؤمنون بالله﴾</q> الآيتين، قال: نسَختها الآيةُ التي في سورة النور: <q>﴿إنما المؤمنون الذي آمنوا بالله ورسوله﴾</q> إلى <q>﴿إن الله غفور رحيم﴾</q> [النور:٦٢] فجعل اللهُ النبيَّ ﷺ بأعلى النَّظرَين{4} في ذلك؛ مَن غزا غزا في فضيلةٍ، ومَن قعَد قعَد في غير حَرَجٍ إن شاء{5}. (٧/٣٩٢) ٣٢٥٠٨- عن عكرمة مولى ابن عباس= (ز) ٣٢٥٠٩- والحسن البصري -من طريق يزيد- قالا: قوله: <q>﴿لا يَسْتَأْذِنُكَ الَّذِينَ يُؤْمِنُونَ بِاللَّهِ﴾</q> إلى قوله: <q>﴿فَهُمْ فِي رَيْبِهِمْ يَتَرَدَّدُونَ﴾</q> نسختهما الآية التي في النور: <q>﴿إنَّما المُؤْمِنُونَ الَّذِينَ آمَنُوا بِاللَّهِ﴾</q> إلى <q>﴿إنَّ اللَّهَ غَفُورٌ رَحِيمٌ﴾</q> [النور:٦٢]{6}. (ز) ٣٢٥١٠- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿عفا الله عنك لم أذنت لهم﴾</q> الآية، قال: ثُمَّ أنزل الله التي في سورة النور، فرَخَّص له في أن يأذن لهم إن شاء، فقال: <q>﴿فإذا استأذنوك لبعض شأنهم فأذن لمن شئت منهم﴾</q> [النور:٦٢]، فجعله اللهُ رخصةً في ذلك مِن ذلك{7}٢٩٦١. (٧/٣٩٢) ٢٩٦١ انتَقَدَ ابنُ عطية (٤/٣٢٣) قول قتادة هذا مستندًا إلى دلالة زمن النزول، فقال: «هذا غلطٌ؛ لأنّ آية النور نزلت سنة أربع من الهجرة في غزوة الخندق في استئذان بعض المؤمنين رسول الله ﷺ في بعض شأنهم في بيوتهم في بعض الأوقات، فأباح الله له أن يأذن، فتباينت الآيتان في الوقت والمعنى». ٣٢٥١١- عن عطاء الخراساني -من طريق ابنه عثمان- قال: <q>﴿لا يستأذنك الذين يؤمنون بالله واليوم الآخر﴾</q> الآيتين إلى قوله: <q>﴿يترددون﴾</q>: فنُسِخَت في سورة النور: <q>﴿إنما المؤمنون الذين آمنوا بالله ورسوله﴾</q> إلى <q>﴿إن الله غفور رحيم﴾</q> [النور:٦٢]، فجُعِل رسول الله ﷺ بأعلى النَّظَرَيْن؛ مَن غزا غزا في فضيلةٍ، ومَن قعَد قعَد في غير حَرَجٍ{8}. (ز) ٣٢٥١٢- عن زيد بن أسلم -من طريق القاسم بن عبد الله- أنّه قال: <q>﴿لا يستأذنك الذين يؤمنون بالله واليوم الآخر أن يجاهدوا بأموالهم وأنفسهم والله عليم بالمتقين إنما يستأذنك الذين لا يؤمنون بالله واليوم الآخر وارتابت قلوبهم فهم في ريبهم يترددون﴾</q>، نَسَخَتْها الآيةُ التي في النور [٦٢]: <q>﴿فإذا استأذنوك لبعض شأنهم فأذن لمن شئت منهم واستغفر لهم الله إن الله غفور رحيم﴾</q>{9}. (ز) ",footnotes:1:أخرجه ابن جرير ١١/٤٨٠، وابن أبي حاتم ٦/١٨٠٦، والنحاس في ناسخه ص٥٠٦. وعزاه السيوطي إلى ابن المنذر.تفسير مقاتل بن سليمان ٢/١٧٢.أخرجه النحاس في ناسخه ص٥٠٥.النظرين: الأمرين. النهاية ٥/٧٧.أخرجه أبو عبيد في ناسخه ص٢٧٤، وابن أبي حاتم ٦/١٨٠٦، وعنده عن عطاء الخراساني من قوله كما سيأتي. وعزاه السيوطي إلى ابن المنذر، وابن مَرْدُويَه، والبيهقيّ في سُنَنِه.أخرجه ابن جرير ١١/٤٨١.أخرجه ابن جرير ١١/٤٧٨، وابن أبي حاتم ٦/١٨٠٥ بنحوه من طريق همام، والنحاس ص٥٠٥. وذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٢/٢٠٨-. وعزاه السيوطي إلى ابن المنذر، وأبي الشيخ.أخرجه ابن أبي حاتم ٦/١٨٠٦.أخرجه ابن وهب في الجامع - تفسير القرآن ٣/٧٥ (١٦٤).
9,45," <q>﴿إِنَّمَا یَسۡتَـٔۡذِنُكَ ٱلَّذِینَ لَا یُؤۡمِنُونَ بِٱللَّهِ وَٱلۡیَوۡمِ ٱلۡـَٔاخِرِ﴾</q> - تفسير ٣٢٥١٣- قال مقاتل بن سليمان: ثم ذكر المنافقين، فقال: <q>﴿إنما يستأذنك﴾</q> في الجهاد وبُعْد الشُّقّة، <q>﴿الذين لا يؤمنون بالله واليوم الآخر﴾</q> لا يصدِّقون بالله، ولا باليوم الآخر، يعني: لا يصدِّقون بالله، ولا بتوحيده، ولا بالبعث الذي فيه جزاء الأعمال{1}. (ز) <q>﴿وَٱرۡتَابَتۡ قُلُوبُهُمۡ فَهُمۡ فِی رَیۡبِهِمۡ یَتَرَدَّدُونَ ۝٤٥﴾</q> - تفسير ٣٢٥١٤- عن أبي الدرداء -من طريق عبد الرحمن بن مسعود- قال: الرَّيْب: الشكُّ، والكُفْر{2}. (ز) ٣٢٥١٥- عن إسماعيل السُّدِّيّ -من طريق أسباط- قوله: <q>﴿وارتابت قلوبهم﴾</q>، يقول: شَكَّت قلوبهم{2}. (ز) ٣٢٥١٦- قال مقاتل بن سليمان: <q>﴿وارتابت﴾</q> يعني: شَكَّت <q>﴿قلوبهم﴾</q> في الدِّين، <q>﴿فهم في ريبهم﴾</q> يعني: في شكِّهم <q>﴿يترددون﴾</q>، وهم تسعة وثلاثون رجلًا{1}. (ز) ",footnotes:1:تفسير مقاتل بن سليمان ٢/١٧٢.أخرجه ابن أبي حاتم ٦/١٨٠٧.أخرجه ابن أبي حاتم ٦/١٨٠٧.تفسير مقاتل بن سليمان ٢/١٧٢.
9,46," <q>﴿وَلَوۡ أَرَادُوا۟ ٱلۡخُرُوجَ لَأَعَدُّوا۟ لَهُۥ عُدَّةࣰ﴾</q> - تفسير ٣٢٥١٧- عن إسماعيل السُّدِّيّ -من طريق أسباط- قوله: <q>﴿ولو أرادوا الخروج لأعدوا له عدة﴾</q>، فأمّا العُدَّة فالقُوَّة{1}. (ز) ٣٢٥١٨- قال مقاتل بن سليمان: <q>﴿ولَوْ أرادُوا الخُرُوجَ﴾</q> إلى العدو؛ <q>﴿لَأَعَدُّوا لَهُ عُدَّةً﴾</q> يعني به: النِّيَّة{2}. (ز) <q>﴿وَلَـٰكِن كَرِهَ ٱللَّهُ ٱنۢبِعَاثَهُمۡ﴾</q> - تفسير ٣٢٥١٩- عن الضحاك بن مزاحم -من طريق جويبر- في قوله: <q>﴿ولكن كرهَ اللهُ انبعاثهُم﴾</q>، قال: خروجَهم{3}. (٧/٣٩٣) ٣٢٥٢٠- قال مقاتل بن سليمان: <q>﴿ولكِنْ كَرِهَ اللَّهُ انْبِعاثَهُمْ﴾</q>، يعني: خروجهم{2}. (ز) <q>﴿فَثَبَّطَهُمۡ وَقِیلَ ٱقۡعُدُوا۟ مَعَ ٱلۡقَـٰعِدِینَ ۝٤٦﴾</q> - تفسير ٣٢٥٢١- عن عبد الله بن عباس -من طريق الضحاك- في قوله: <q>﴿فثبَّطهم﴾</q>، قال: حبَسهم{1}. (٧/٣٩٣) ٣٢٥٢٢- عن الضحاك بن مزاحم= (ز) ٣٢٥٢٣- وإسماعيل السُّدِّيّ، مثل ذلك{6}. (ز) ٣٢٥٢٤- قال مقاتل بن سليمان: <q>﴿فَثَبَّطَهُمْ﴾</q> عن غزاة تبوك، <q>﴿وقِيلَ اقْعُدُوا﴾</q> وحيًا إلى قلوبهم <q>﴿مَعَ القاعِدِينَ﴾</q> أُلْهِموا ذلك، يعني: مع المتخلفين{2}. (ز) ٣٢٥٢٥- عن محمد بن إسحاق -من طريق سلمة- قال: كان الذين استأذنوه -فيما بلغني- مِن ذَوِي الشَّرَف منهم: عبد الله بن أُبَيِّ ابن سلول، والجدُّ بن قيس، وكانوا أشرافًا في قومهم، فثبَّطهم الله؛ لعلمه بهم أن يخرجوا معهم فيفسدوا عليه جنده{8}. (ز) ",footnotes:1:أخرجه ابن أبي حاتم ٦/١٨٠٧.تفسير مقاتل بن سليمان ٢/١٧٣.أخرجه ابن أبي حاتم ٦/١٨٠٧. وعزاه السيوطي إلى أبي الشيخ.تفسير مقاتل بن سليمان ٢/١٧٣.أخرجه ابن أبي حاتم ٦/١٨٠٧.علَّقه ابن أبي حاتم ٦/١٨٠٧.تفسير مقاتل بن سليمان ٢/١٧٣.أخرجه ابن جرير ١١/٤٨٢.
9,47," <q>﴿لَوۡ خَرَجُوا۟ فِیكُم مَّا زَادُوكُمۡ إِلَّا خَبَالࣰا﴾</q> - تفسير ٣٢٥٢٦- قال الضحاك بن مزاحم: غدرًا ومكرًا {1}. (ز) ٣٢٥٢٧- قال محمد بن السائب الكلبي: شرًّا{2}. (ز) ٣٢٥٢٨- قال مقاتل بن سليمان: <q>﴿لَوْ خَرَجُوا فِيكُمْ﴾</q> يعني: معكم إلى العدو؛ <q>﴿ما زادُوكُمْ إلّا خَبالًا﴾</q> يعني: عِيًّا{3}. (ز) ٣٢٥٢٩- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿لوْ خرجُوا فيكم مّا زادوكُمْ إلا خبالًا﴾</q>، قال: هؤلاء المنافقون في غزوة تبوك، يُسلِّي الله عنها نبيَّه والمؤمنين، فقال: وما يُحزِنُكم؟ <q>﴿لوْ خَرجُوا فيكُم مّا زادوكُمْ إلّا خبالًا﴾</q> يقولُون: قد جُمِع لكم، وفُعِل وفُعل. يُخذِّلونكم{4}. (٧/٣٩٣) <q>﴿وَلَأَوۡضَعُوا۟ خِلَـٰلَكُمۡ﴾</q> - تفسير ٣٢٥٣٠- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿ولأوضعُوا خلالكُمْ﴾</q>، قال: لارْفَضُّوا{5}{6}. (٧/٣٩٣) ٣٢٥٣١- عن مجاهد بن جبر -من طريق ابن جريج- في قوله: <q>﴿ولأوضعُوا خلالكُمْ﴾</q>: لَأسْرَعوا الأزِقَّةَ خلالكم{7}. (ز) ٣٢٥٣٢- عن قتادة بن دعامة -من طريق معمر- في قوله: <q>﴿ولأوضعُوا خلالكُم﴾</q>، قال: لأسرعُوا بينكم{8}. (٧/٣٩٣) ٣٢٥٣٣- عن قتادة بن دعامة -من طريق سعيد- قوله: <q>﴿ولأوضعوا خلالكم﴾</q>، يقول: ولأوضعوا أسلحتهم خلالكم بالفتنة{9}. (ز) ٣٢٥٣٤- عن إسماعيل السُّدِّيّ -من طريق أسباط- قوله: <q>﴿ولأوضعوا خلالكم﴾</q>، يقول: أوضعوا رِحالهم حتى يدخلوا بينكم{10}. (ز) ٣٢٥٣٥- قال مقاتل بن سليمان: <q>﴿ولَأَوْضَعُوا خِلالَكُمْ﴾</q>، يَتَخَلَّل الراكبُ الرجلين، حتى يدخل بينهما فيقول ما لا ينبغي{3}٢٩٦٢. (ز) ٢٩٦٢ ذكر ابنُ عطية (٤/٣٢٦) أنّ الزجّاج قال: <q>﴿خِلالَكُمْ﴾</q> معناه: فيما يُخِلُّ بكم. وانتَقَده مستندًا إلى النظائر، فقال: «وهذا ضعيف، وماذا يقول في قوله: <q>﴿فَجاسُوا خِلالَ الدِّيارِ﴾</q> [الإسراء:٥]؟». <q>﴿یَبۡغُونَكُمُ ٱلۡفِتۡنَةَ﴾</q> - تفسير ٣٢٥٣٦- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿يَبغُونكُمُ الفتنَةَ﴾</q>، قال: يُبَطِّئونكم؛ عبد الله بن نَبْتَلٍ، وعبد الله بن أُبَيِّ بنُ سلولَ، ورِفاعةُ بنُ تابوتٍ، وأوس بن قيظيِّ{12}. (٧/٣٩٣) ٣٢٥٣٧- قال الضحاك بن مزاحم: <q>﴿الفتنة﴾</q>: الشرك{13}. (ز) ٣٢٥٣٨- قال الضحاك بن مزاحم: يعني: الكفر{2}. (ز) ٣٢٥٣٩- عن قتادة بن دعامة -من طريق معمر- <q>﴿ولأوضعُوا خلالكُم﴾</q>: بينكم، <q>﴿يَبغُونكُمُ الفتنَةَ﴾</q> بذلك{9}. (ز) ٣٢٥٤٠- عن إسماعيل السُّدِّيّ -من طريق أسباط- <q>﴿يبغونكم الفتنة﴾</q>، يقول: الكفر{10}. (ز) ٣٢٥٤١- قال محمد بن السائب الكلبي: <q>﴿يبغونكم الفتنة﴾</q>، يعني: العيب، والشَّرَّ{17}. (ز) ٣٢٥٤٢- قال مقاتل بن سليمان: <q>﴿يَبْغُونَكُمُ الفِتْنَةَ﴾</q>، يعني: الكفر{3}. (ز) ٣٢٥٤٣- قال عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿ولأوضعوا خلالكم يبغونكم الفتنة﴾</q>: الكفر{19}. (ز) <q>﴿وَفِیكُمۡ سَمَّـٰعُونَ لَهُمۡۗ وَٱللَّهُ عَلِیمُۢ بِٱلظَّـٰلِمِینَ ۝٤٧﴾</q> - تفسير ٣٢٥٤٤- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿وفيكُم سمّاعون لهُم﴾</q>، قال: مُحَدِّثون بأحاديثهم، غير منافقين، هم عيون للمنافقين{20}. (٧/٣٩٣) ٣٢٥٤٥- قال مجاهد بن جبر: <q>﴿وفيكم سماعون لهم﴾</q>، معناه: وفيكم مُحِبُّون لهم، يُؤَدُّون إليهم ما يسمعون منكم، وهم الجواسيس{21}. (ز) ٣٢٥٤٦- قال الحسن البصري: <q>﴿وفيكم سماعون لهم﴾</q>، يعني: المنافقين؛ أنّهم عيون للمشركين عليكم، يسمعون أخباركم، فيرسلون بها إلى المشركين{22}. (ز) ٣٢٥٤٧- عن قتادة بن دعامة -من طريق سعيد- قال: <q>﴿وفيكم سماعون لهم﴾</q>: وفيكم مَن يسمع كلامَهم{23}. (ز) ٣٢٥٤٨- عن زيد بن أسلم -من طريق محمد بن أبان- في قوله: <q>﴿وفيكُم سمّاعون لهُم﴾</q>، قال: مُبَلِّغون{24}. (٧/٣٩٤) ٣٢٥٤٩- عن محمد بن إسحاق -من طريق سلمة- قال: كان الذين استأذنوا -فيما بلغني- مِن ذَوِي الشرف منهم: عبد الله بن أُبَيِّ بن سلول، والجَدُّ بن قيس، وكانوا أشرافًا في قومهم، فثَبَّطهم الله؛ لعلمه بهم أن يخرجوا معهم فيفسدوا عليه جنده، وكان في جنده قومٌ أهلُ محبةٍ لهم، وطاعة فيما يدعونهم إليه؛ لشرفهم فيهم، فقال: <q>﴿وفيكم سماعون لهم﴾</q>{23}. (ز) ٣٢٥٥٠- قال مقاتل بن سليمان: <q>﴿وفِيكُمْ﴾</q> معشر المؤمنين <q>﴿سَمّاعُونَ لَهُمْ﴾</q> من غير المنافقين، اتَّخذهم المنافقون عيونًا لهم يُحَدِّثونهم، <q>﴿واللَّهُ عَلِيمٌ بِالظّالِمِينَ﴾</q> منهم عبد الله بن أُبَيِّ، وعبد الله بن نَبْتَلٍ، وجَدُّ بن قيس، ورِفاعة بن التابوت، وأوس بن قيظيِّ{3}. (ز) ٣٢٥٥١- قال عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿وفيكم سماعون لهم﴾</q>: يسمعون ما يُؤَدُّونه لعدوكم{27}٢٩٦٣. (ز) ٢٩٦٣ أفادت الآثارُ اختلاف المفسرين في معنى قوله تعالى: <q>﴿وفِيكُمْ سَمّاعُونَ لَهُمْ﴾</q> على قولين: الأول: وفيكم عيون ينقلون إليهم أخباركم. وهو قول مجاهد، والحسن، وابن زيد. والثاني: وفيكم من يسمع كلامهم ويطيعهم. وهو قول قتادة، وابن إسحاق. وعلَّق ابنُ جرير (١١/٤٨٧) على القول الأول بأنّ المعنى: «<q>﴿وفيكم﴾</q> منهم <q>﴿سمّاعون﴾</q> يسمعون حديثكم لهم، فيبلِّغونهم ويؤدونه إليهم، عيونٌ لهم عليكم». ووجَّه المعنى على القول الثاني قائلًا: «فعلى هذا التأويل: وفيكم أهل سمع وطاعة منكم، لو صحبوكم أفسدوهم عليكم بتثبيطهم إياهم عن السَّيْر معكم». ووجَّه ابنُ القيم (٢/١١) المعنى على القول الثاني قائلًا: «وفيكم أهل سَمْع وطاعة لهم، لو صحبهم هؤلاء المنافقون أفسدوهم عليكم». ورجَّح ابنُ جرير القول الأول مستندًا إلى الأغلب في لغة العرب بقوله: «لأنّ الأغلب من كلام العرب في قولهم: سمّاعٌ، وصْفُ مَن وُصِفَ به أنّه سمّاعٌ للكلام، كما قال الله -جلَّ ثناؤه- في غير موضعٍ من كتابه: <q>﴿سَمّاعُونَ لِلْكَذِبِ﴾</q> [المائدة:٤١، ٤٢]، واصفًا بذلك قومًا بسماع الكذب من الحديث. وأما إذا وصَفوا الرَّجُلَ بسماعِ كلام الرجل وأمْرِه ونهْيِه وقَبوله منه وانتهائه إليه فإنّما يَصِفُه له بأنه له سامعٌ ومطيع، ولا يكاد يقول: هو له سمّاعٌ مطيعٌ». وانتَقَد ابنُ تيمية القول الأول مستندًا إلى دلالة العقل بقوله: «وأمّا مَن ظَنَّ أنّ المراد بقوله: <q>﴿سَمّاعُونَ لَهُمْ﴾</q>: أنهم جواسيس لمن غاب، وأخذ حكم الجاسوس من هذه الآية؛ فقد غَلِط، فإنّ ما كان يظهره النبي ﷺ حتى يسمعه المنافقون واليهود لم يكن مما يكتمه حتى يكون نقله جسًّا عليه». وكذا انتَقَدَه ابنُ القيم مستندًا إلى دلالة العقل بقوله: «ولم يكن في المؤمنين جواسيس للمنافقين؛ فإنّ المنافقين كانوا مختلطين بالمؤمنين، ينزلون معهم، ويرحلون، ويُصَلُّون معهم، ويجالسونهم، ولم يكونوا متحيِّزين عنهم، قد أرسلوا فيهم العيون ينقلون إليهم أخبارهم، فإنّ هذا إنّما يفعله مَن انحاز عن طائفة ولم يُخالِطها، وأرصد بينهم عيونًا له، فالقول قول قتادة وابن إسحاق». وانتقده ابنُ كثير أيضًا مستندًا إلى دلالة العقل بقوله: «وهذا لا يبقى له اختصاص بخروجهم معهم، بل هذا عامٌّ في جميع الأحوال». ورجَّح ابنُ كثير (٧/٢١٢) مستندًا إلى السياق، وكذا ابنُ القيم (٢/١٢)، وقبلهما ابنُ تيمية (٣/٣٧٤-٣٧٥) القول الثاني. ",footnotes:1:تفسير الثعلبي (طبعة دار التفسير) ١٣/٣٩٣.تفسير الثعلبي ٥/٥١.تفسير مقاتل بن سليمان ٢/١٧٣.أخرجه ابن جرير ١١/٤٨٥، وابن أبي حاتم ٦/١٨٠٧ من طريق أصبغ بن الفرج بلفظ: سأل الله عنهم نبيّه .... وبه عزاه السيوطي إلى أبي الشيخ.أي: تفرَّقُوا. النهاية (رفض).تفسير مجاهد ص٣٦٧، وأخرجه ابن أبي حاتم ٦/١٨٠٨. وعزاه السيوطي إلى ابن أبي شيبة، وابن المنذر، وأبي الشيخ.أخرجه ابن جرير ١١/٤٨٥.أخرجه عبد الرزاق ١/٢٧٦، وابن جرير ١١/٤٨٥، وابن أبي حاتم ٦/١٨٠٨. وعزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ١١/٤٨٤.أخرجه ابن أبي حاتم ٦/١٨٠٨.تفسير مقاتل بن سليمان ٢/١٧٣.تفسير مجاهد ص٣٦٩، وأخرجه ابن جرير ١١/٤٨٤، وابن أبي حاتم ٦/١٨٠٨. وعزاه السيوطي إلى ابن أبي شيبة، وابن المنذر، وأبي الشيخ.تفسير البغوي ٤/٥٦.تفسير الثعلبي ٥/٥١.أخرجه ابن جرير ١١/٤٨٤.أخرجه ابن أبي حاتم ٦/١٨٠٨.تفسير الثعلبي ٥/٥١، وتفسير البغوي ٤/٥٦.تفسير مقاتل بن سليمان ٢/١٧٣.أخرجه ابن جرير ١١/٤٨٥. وعلَّقه ابن أبي حاتم ٦/١٨٠٨.تفسير مجاهد ص٣٧٠، وأخرجه ابن جرير ١١/٤٨٦، وابن أبي حاتم ٦/١٨٠٨. وعزاه السيوطي إلى ابن أبي شيبة، وابن المنذر، وأبي الشيخ.تفسير الثعلبي ٥/٥١ بنحوه، وتفسير البغوي ٤/٥٦.ذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٢/٢٠٩-.أخرجه ابن جرير ١١/٤٨٦.أخرجه ابن أبي حاتم ٦/١٨٠٩.أخرجه ابن جرير ١١/٤٨٦.تفسير مقاتل بن سليمان ٢/١٧٣.أخرجه ابن جرير ١١/٤٨٦، وابن أبي حاتم ٦/١٨٠٩ من طريق أصبغ بن الفرج بلفظ: يسمعون ما تأتون به لعدوكم.
