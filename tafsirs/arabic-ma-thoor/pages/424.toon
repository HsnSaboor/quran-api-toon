quran[7]{c,v,t}:
  33,44,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿تَحِیَّتُهُمۡ یَوۡمَ یَلۡقَوۡنَهُۥ سَلَـٰمࣱۚ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٢٤٠٦<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن مسعود</span>، قال: <span class="qpc-hafs">﴿تَحِيَّتُهُمْ يَوْمَ يَلْقَوْنَهُ سَلامٌ﴾</span> إذا جاء ملك الموت ليقبض روح المؤمن قال: ربك يقرئك السلام{1}<span class=comment-ref>٥٢٤٥</span>. (١٢/٧٥)</p></p><p></div></p><p><div><span class=comment-ref>٥٢٤٥</span> <span class="comment-type-4">قال</span> <u>ابنُ كثير</u> (١١/١٨٤) <span class="mustanad">مستندًا إلى النظائر</span>: «الظاهر أن المراد -والله أعلم- <span class="qpc-hafs">﴿تحيتهم﴾</span> أي: مِن الله تعالى <span class="qpc-hafs">﴿يوم يلقونه سلام﴾</span> أي: يوم يسلم عليهم، كما قال تعالى: <span class="qpc-hafs">﴿سَلامٌ قَوْلًا مِن رَبٍّ رَحِيمٍ﴾</span> [يس:٥٨]».</div></p><p><div></p><p><p><span class="item-no">٦٢٤٠٧<span class="dash">-</span></span> عن <span class="name-1">البراء بن عازب</span> -من طريق محمد بن مالك- في قوله: <span class="qpc-hafs">﴿تَحِيَّتُهُمْ يَوْمَ يَلْقَوْنَهُ سَلامٌ﴾</span>، قال: يوم يلقون مَلَك الموت، ليس مِن مؤمن يقبض روحه إلا سلَّم عليه{2}. (١٢/٧٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٢٤٠٨<span class="dash">-</span></span> قال <span class="name-2">الحسن البصري</span>: <span class="qpc-hafs">﴿تَحِيَّتُهُمْ يَوْمَ يَلْقَوْنَهُ سَلامٌ﴾</span> تُحييهم الملائكةُ عن الله بالسلام{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٢٤٠٩<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- في قوله: <span class="qpc-hafs">﴿تَحِيَّتُهُمْ يَوْمَ يَلْقَوْنَهُ سَلامٌ﴾</span>، قال: تحية أهل الجنة السلام{4}<span class=comment-ref>٥٢٤٦</span>. (١٢/٧٤)</p></p><p></div></p><p><div><span class=comment-ref>٥٢٤٦</span> <span class="comment-type-4">ذَهَبَ</span> <u>ابنُ جرير</u> (١٩/١٢٥) إلى <span class="mustanad">ما ذهب إليه قتادة</span>، مِن أنّ المراد: يُحَيِّي أهلُ الجنة بعضهم بعضًا.</p><p>و<span class="comment-type-4">علَّقَ</span> <u>ابنُ كثير</u> (١١/١٨٤) على هذا القول بقوله: «قد يستدل له بقوله تعالى: <span class="qpc-hafs">﴿دَعْواهُمْ فِيها سُبْحانَكَ اللَّهُمَّ وتَحِيَّتُهُمْ فِيها سَلامٌ وآخِرُ دَعْواهُمْ أنِ الحَمْدُ لِلَّهِ رَبِّ العالَمِينَ﴾</span> [يونس:١٠]».</div></p><p><div></p><p><p><span class="item-no">٦٢٤١٠<span class="dash">-</span></span> عن <span class="name-2">أبي حمزة الثمالي</span> -من طريق علي بن علي- في قوله: <span class="qpc-hafs">﴿تَحِيَّتُهُمْ يَوْمَ يَلْقَوْنَهُ سَلامٌ﴾</span>، قال: تسلِّم عليهم الملائكة يوم القيامة، وتُبَشِّرهم حين يخرجون من قبورهم{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٢٤١١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿تَحِيَّتُهُمْ يَوْمَ يَلْقَوْنَهُ﴾</span> يعني: يوم يلقون الرب ﷿ في الآخرة، <span class="qpc-hafs">﴿سلام﴾</span> يعني: تسليم الملائكة عليهم{6}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَأَعَدَّ لَهُمۡ أَجۡرࣰا كَرِیمࣰا ۝٤٤﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٢٤١٢<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿وأَعَدَّ لَهُمْ أجْرًا كَرِيمًا﴾</span>، قال: الجنة{7}. (١٢/٧٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٢٤١٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وأَعَدَّ لَهُمْ أجْرًا كَرِيمًا﴾</span>، يعني: أجرًا حسنًا في الجنة{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٢٤١٤<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿وأَعَدَّ لَهُمْ أجْرًا﴾</span> ثوابًا <span class="qpc-hafs">﴿كَرِيمًا﴾</span> الجنة{9}. (ز)</p></p><p></div></p></div>",footnotes:1:عزاه السيوطي إلى المروزي في الجنائز، وابن أبي الدنيا، وأبي الشيخ.أخرجه ابن أبي شيبة في مصنفه (ت: محمد عوامة) ١٩/٢٣٩ (٣٥٩١٢)، وأبو يعلى -كما في المطالب العالية (٤٠٦٥)-، وابن جرير ١٤/٢١٤، والحاكم ٢/٣٥١، والبيهقي في شعب الإيمان (٤٠٣). وعزاه السيوطي إلى ابن أبي الدنيا في ذكر الموت، وعبد بن حميد، وابن المنذر، وابن أبي حاتم، وابن مردويه.علقه يحيى بن سلّام ٢/٧٢٥.أخرجه عبد الرزاق ٢/١١٩، وابن جرير ١٩/١٢٥ من طريق سعيد. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.أخرجه الثعلبي ٨/٥٢.تفسير مقاتل بن سليمان ٣/٤٩٩.أخرجه ابن جرير ١٩/١٢٥. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.تفسير مقاتل بن سليمان ٣/٤٩٩.تفسير يحيى بن سلّام ٢/٧٢٥.
  33,45,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿یَـٰۤأَیُّهَا ٱلنَّبِیُّ إِنَّاۤ أَرۡسَلۡنَـٰكَ شَـٰهِدࣰا وَمُبَشِّرࣰا وَنَذِیرࣰا ۝٤٥﴾</span> - نزول الآية</h3></p><p><div></p><p><p><span class="item-no">٦٢٤١٥<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، قال: لما نزلت: <span class="qpc-hafs">﴿يا أيُّها النبي إنّا أرْسَلْناكَ شاهِدًا ومُبَشِّرًا ونَذِيرًا﴾</span> وقد كان أمَر عليًّا ومعاذًا أن يسيرا إلى اليمن، فقال: «<b>انطلِقا، فبشِّرا ولا تنفِّرا، ويسِّرا ولا تعسِّرا، فإنه قد أنزلت عَلَيَّ</b>: <span class="qpc-hafs">﴿يا أيُّها النبي إنّا أرْسَلْناكَ شاهِدًا ومُبَشِّرًا ونَذِيرًا﴾</span>»{1}. (١٢/٧٥)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿یَـٰۤأَیُّهَا ٱلنَّبِیُّ إِنَّاۤ أَرۡسَلۡنَـٰكَ شَـٰهِدࣰا وَمُبَشِّرࣰا وَنَذِیرࣰا ۝٤٥﴾</span> - تفسير الآية</h3></p><p><div></p><p><p><span class="item-no">٦٢٤١٦<span class="dash">-</span></span> عن العرباض بن سارية: سمعتُ رسول الله ﷺ يقول: «<b>إنِّي عبدُ الله وخاتمُ النبيين وأبي مُنجَدِلٌ</b>{2} <b>في طِينَتِه، وسأخبركم عن ذلك، أنا دعوة أبي إبراهيم، وبشارة عيسى، ورؤيا أمي التي رأت، وكذلك أمهات النبيين يَرَيْن».</b> وإنّ أم رسول الله ﷺ رأت حين وضعته نورًا أضاءت لها قصور الشام. ثم تلا: <span class="qpc-hafs">﴿يا أيُّها النبي إنّا أرْسَلْناكَ شاهِدًا ومُبَشِّرًا ونَذِيرًا﴾</span> إلى قوله: <span class="qpc-hafs">﴿مُنِيرًا﴾</span>{3}. (١٢/٧٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٢٤١٧<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عكرمة- <span class="qpc-hafs">﴿يا أيُّها النبي إنّا أرْسَلْناكَ شاهِدًا ومُبَشِّرًا ونَذِيرًا﴾</span>، قال: شاهدًا على أمتك، ومُبَشِّرًا بالجنة، ونذيرًا مِن النار{4}. (١٢/٧٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٢٤١٨<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span>: <span class="qpc-hafs">﴿ونَذِيرًا﴾</span> مِن عذاب الدنيا وعذاب الآخرة{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٢٤١٩<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿يا أيُّها النبي إنّا أرْسَلْناكَ شاهِدًا﴾</span> قال: على أمتك بالبلاغ، <span class="qpc-hafs">﴿ومُبَشِّرًا﴾</span> بالجنة، <span class="qpc-hafs">﴿ونَذِيرًا﴾</span> مِن النار{6}. (١٢/٧٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٢٤٢٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿يا أيُّها النبي إنّا أرْسَلْناكَ شاهِدًا﴾</span> على هذه الأمة بتبليغ الرسالة، <span class="qpc-hafs">﴿ومُبَشِّرًا ونَذِيرًا﴾</span> ومبشِّرًا بالجنة والنصر في الدنيا على من خالفهم، ونذيرًا مِن النار{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٢٤٢١<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿يا أيُّها النبي إنّا أرْسَلْناكَ شاهِدًا﴾</span> على أمتك، تشهد عليهم في الآخرة أنّك قد بلَّغْتَهم، <span class="qpc-hafs">﴿ومُبَشِّرًا﴾</span> في الدنيا بالجنة، <span class="qpc-hafs">﴿ونَذِيرًا﴾</span> مِن النار{8}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿یَـٰۤأَیُّهَا ٱلنَّبِیُّ إِنَّاۤ أَرۡسَلۡنَـٰكَ شَـٰهِدࣰا وَمُبَشِّرࣰا وَنَذِیرࣰا ۝٤٥﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٦٢٤٢٢<span class="dash">-</span></span> عن عبد الله بن عباس، قال: اجتمع عُتبةُ وشَيبةُ وأبو جهل وغيرهم، فقالوا: أسقِط السماء علينا كسفًا، أو ائتنا بعذاب أليم، أو أمطِر علينا حجارةً مِن السماء. فقال رسول الله ﷺ:«<b>ما ذاك إلَيَّ، إنّما بُعِثْتُ إليكم داعيًا ومُبَشِّرًا ونذيرًا</b>»{9}. (١٢/٧٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٢٤٢٣<span class="dash">-</span></span> عن عطاء بن يسار، قال: لقيت <span class="name-1">عبد الله بن عمرو بن العاص</span>، فقلت: أخبِرني عن صفة رسول الله ﷺ في التوراة. قال: أجل، واللهِ، إنّه لموصوف في التوراة ببعض صفته في القرآن: <span class="qpc-hafs">﴿يا أيها النبي إنا أرسلناك شاهدا ومبشرا ونذيرا﴾</span> وحرزًا للأميين، أنت عبدي ورسولي، سميَّتك المتوكل، ليس بفظٍّ ولا غليظ، ولا سخّاب{10} في الأسواق، ولا يجزى بالسيئة السيئة، ولكن يعفو ويصفح{11}. (١٢/٧٥)</p></p><p></div></p></div>",footnotes:1:أخرجه الطبراني في الكبير ١١/٣١٢ (١١٨٤١)، والخطيب في تاريخه ٤/٥١٣ (١١٢٢) في ترجمة محمد بن نصر بن حميد بن الوازع البزاز (١٦٨٥)، وابن أبي حاتم -كما في تفسير ابن كثير ٦/٤٣٨-٤٣٩-.</p><p>قال الهيثمي في المجمع ٧/٩٢ (١١٢٧٧): «رواه الطبراني، وفيه عبدالرحمن بن محمد بن عبدالله العرزمي، وهو ضعيف».منجدل: ملقى على الجدالة، وهي الأرض. النهاية (جدل).أخرجه الحاكم ٢/٤١٨، والبيهقي ٢/١٣٠. والحديث دون ذكر الآية عند أحمد ٢٨/٣٧٩، ٣٨٢، ٣٦٥ (١٧١٥٠، ١٧١٥١، ١٧١٦٣).</p><p>قال محققو المسند: «صحيح لغيره».أخرجه ابن أبي حاتم -كما في تفسير ابن كثير ٦/٤٣٠-، والطبراني (١١٨٤١)، والخطيب ٣/٣١٩. وعزاه السيوطي إلى ابن مردويه، وابن عساكر.علقه يحيى بن سلّام ٢/٧٢٦.أخرجه ابن جرير ١٩/١٢٦-١٢٧. وعزاه السيوطي إلى عبد بن حميد، وابن أبي حاتم.تفسير مقاتل بن سليمان ٣/٤٩٩.تفسير يحيى بن سلّام ٢/٧٢٥-٧٢٦.عزاه السيوطي إلى أبي الشيخ.سخّاب: بالسين والصاد، هو شدة الصياح. النهاية (سخب).أخرجه أحمد ١١/١٩٣ (٦٦٢٢)، والبخاري (٢١٢٥، ٤٨٣٨)، والبيهقي في الدلائل ١/٣٧٣-٣٧٥. وعزاه السيوطي إلى ابن أبي حاتم. وفي رواية عند البخاري بلفظ: أن هذه الآية التي في القرآن: <span class="qpc-hafs">﴿يا أيُّها النبي إنّا أرْسَلْناكَ شاهِدًا ومُبَشِّرًا ونَذِيرًا﴾</span> قال في التوراة: يا أيها النبي إنا أرسلناك شاهدًا ومبشرًا ... إلخ.
  33,46,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَدَاعِیًا إِلَى ٱللَّهِ بِإِذۡنِهِۦ وَسِرَاجࣰا مُّنِیرࣰا ۝٤٦﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٢٤٢٤<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عكرمة- قال: <span class="qpc-hafs">﴿وداعِيًا﴾</span> إلى شهادة لا إله إلا الله <span class="qpc-hafs">﴿بِإذْنِهِ وسِراجًا مُنِيرًا﴾</span> بالقرآن{1}. (١٢/٧٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٢٤٢٥<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿وداعِيًا إلى اللَّهِ﴾</span> إلى شهادة أن لا إله إلا الله <span class="qpc-hafs">﴿بإذْنِهِ﴾</span> قال: بأمره<span class=comment-ref>٥٢٤٧</span>، <span class="qpc-hafs">﴿وسِراجًا مُنِيرًا﴾</span> قال: كتاب الله يدعوهم إليه{2}. (١٢/٧٧)</p></p><p></div></p><p><div><span class=comment-ref>٥٢٤٧</span> قال <u>ابنُ عطية</u> (٧/١٢٨): «معناه هنا: بأمره إيّاك، وتقديره ذلك في وقته وأوانه».</p><p>وبنحوه قال <u>ابنُ جرير</u> (١٩/١٢٦)، و<u>ابنُ تيمية</u> (٥/٢٤٨)، و<u>ابنُ كثير</u> (١١/١٨٧).</div></p><p><div></p><p><p><span class="item-no">٦٢٤٢٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وداعِيًا إلى اللَّهِ﴾</span> يعني: إلى معرفة الله ﷿ بالتوحيد <span class="qpc-hafs">﴿بِإذْنِهِ﴾</span> يعني: بأمره، <span class="qpc-hafs">﴿وسِراجًا مُنِيرًا﴾</span> يعني: هُدًى مضيئًا للناس{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٢٤٢٧<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿وداعِيًا إلى اللَّهِ بِإذْنِهِ﴾</span> بالقرآن؛ الوحي الذي جاء من عنده، <span class="qpc-hafs">﴿وسِراجًا مُنِيرًا﴾</span> مُضيئًا{4}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن أبي حاتم -كما في تفسير ابن كثير ٦/٤٣٠-، والطبراني (١١٨٤١)، والخطيب ٣/٣١٩. وعزاه السيوطي إلى ابن مردويه، وابن عساكر.أخرجه ابن جرير ١٩/١٢٦-١٢٧. وعزاه السيوطي إلى عبد بن حميد، وابن أبي حاتم.تفسير مقاتل بن سليمان ٣/٥٠٠.تفسير يحيى بن سلّام ٢/٧٢٦.
  33,47,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَبَشِّرِ ٱلۡمُؤۡمِنِینَ بِأَنَّ لَهُم مِّنَ ٱللَّهِ فَضۡلࣰا كَبِیرࣰا ۝٤٧﴾</span> - نزول الآية</h3></p><p><div></p><p><p><span class="item-no">٦٢٤٢٨<span class="dash">-</span></span> قال <span class="name-1">جابر بن عبد الله</span>: لَمّا نزلت <span class="qpc-hafs">﴿إنّا فَتَحْنا﴾</span> الآيات، قال الصحابة: هنيئًا لك -يا رسول الله- هذه الفاتحة، فما لنا؟ فأنزل الله تعالى: <span class="qpc-hafs">﴿وبَشِّرِ المُؤْمِنِينَ بِأَنَّ لَهُمْ مِنَ اللَّهِ فَضْلًا كَبِيرًا﴾</span>{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٢٤٢٩<span class="dash">-</span></span> عن <span class="name-1">أنس بن مالك</span> -من طريق الربيع- قال: لما نزلت: <span class="qpc-hafs">﴿وما أدْرِي ما يُفْعَلُ بِي ولا بِكُمْ﴾</span> [الأحقاف:٩] نزل بعدها: <span class="qpc-hafs">﴿لِيَغْفِرَ لَكَ اللَّهُ ما تَقَدَّمَ مِن ذَنْبِكَ وما تَأَخَّرَ﴾</span> [الفتح:٢]. فقالوا: يا رسول الله، قد علمنا ما يُفعل بك، فماذا يُفعَل بنا؟ فأنزل الله: <span class="qpc-hafs">﴿وبَشِّرِ المُؤْمِنِينَ بِأَنَّ لَهُمْ مِنَ اللَّهِ فَضْلًا كَبِيرًا﴾</span>. قال: الفضل الكبير: الجنة{2}. (١٢/٧٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٢٤٣٠<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٢٤٣١<span class="dash">-</span></span> و<span class="name-2">الحسن البصري</span> -من طريق يزيد- قالا: لما نزلت: <span class="qpc-hafs">﴿لِيَغْفِرَ لَكَ اللَّهُ ما تَقَدَّمَ مِن ذَنْبِكَ وما تَأَخَّرَ﴾</span> [الفتح:٢] قال رجال من المؤمنين: هنيئًا لك، يا رسول الله، قد علمنا ما يُفعل بك، فماذا يُفعل بنا؟ فأنزل الله: <span class="qpc-hafs">﴿وبَشِّرِ المُؤْمِنِينَ بِأَنَّ لَهُمْ مِنَ اللَّهِ فَضْلًا كَبِيرًا﴾</span>{3}. (١٢/٧٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٢٤٣٢<span class="dash">-</span></span> قال <span class="name-2">محمد بن شهاب الزهري</span>، في قوله تعالى: <span class="qpc-hafs">﴿إنا فتحنا لك فتحا مبينا. ليغفر لك الله ما تقدم من ذنبك وما تأخر﴾</span> إلى قوله: <span class="qpc-hafs">﴿ويهديك صراطا مستقيما﴾</span> [الفتح:١-٢]: ... قال رجل من الأنصار: قد حدَّثك ربُّك ما يُفعَل بِك مِن الكرامة، فهنيئًا لك، يا رسول الله، فما يُفْعَل بنا نحن؟ فقال سبحانه: <span class="qpc-hafs">﴿وبشر المؤمنين بأن لهم من الله فضلا كبيرا﴾</span>. وقال تعالى: <span class="qpc-hafs">﴿ليدخل المؤمنين والمؤمنات جنات تجري من تحتها الأنهار﴾</span> [الفتح:٥]. فبيَّن تعالى في هذه الآية كيف يفعل به وبهم{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٢٤٣٣<span class="dash">-</span></span> عن <span class="name-3">ابن جريج</span>، في قوله: <span class="qpc-hafs">﴿إن الله وملائكته﴾</span> الآية [الأحزاب:٥٦]، قال: لما نزلت جعل الناس يهنئونه بهذه الآية. وقال أُبَي بن كعب: ما أنزل فيك خيرًا إلا خلطنا به معك، إلا هذه الآية. فنزلت: <span class="qpc-hafs">﴿وبَشَّرِ المُؤْمِنِينَ﴾</span>{5}. (١٢/١١٦)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَبَشِّرِ ٱلۡمُؤۡمِنِینَ بِأَنَّ لَهُم مِّنَ ٱللَّهِ فَضۡلࣰا كَبِیرࣰا ۝٤٧﴾</span> - تفسير الآية</h3></p><p><div></p><p><p><span class="item-no">٦٢٤٣٤<span class="dash">-</span></span> عن <span class="name-1">أنس بن مالك</span> -من طريق الربيع- قال: <span class="qpc-hafs">﴿وبَشِّرِ المُؤْمِنِينَ بِأَنَّ لَهُمْ مِنَ اللَّهِ فَضْلًا كَبِيرًا﴾</span>، الفضل الكبير: الجنة{6}. (١٢/٧٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٢٤٣٥<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿وبَشِّرِ المُؤْمِنِينَ بِأَنَّ لَهُمْ مِنَ اللَّهِ فَضْلًا كَبِيرًا﴾</span>: وهي الجنة{7}. (١٢/٧٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٢٤٣٦<span class="dash">-</span></span> قال <span class="name-2">إسماعيل السُّدِّيّ</span>: <span class="qpc-hafs">﴿وبَشِّرِ المُؤْمِنِينَ بِأَنَّ لَهُمْ مِنَ اللَّهِ فَضْلًا كَبِيرًا﴾</span>، يعني: الجنة{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٢٤٣٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وبَشِّرِ المُؤْمِنِينَ بِأَنَّ لَهُمْ مِنَ اللَّهِ فَضْلًا كَبِيرًا﴾</span>، يعني: الجنة{9}<span class=comment-ref>٥٢٤٨</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٥٢٤٨</span> <span class="comment-type-4">قال</span> <u>ابنُ عطية</u> (٧/١٢٨): «قال لنا أبي ﵁: هذه مِن أرجى آية عندي في كتاب الله تعالى؛ لأن الله تعالى أمر نبيه أن يبشر المؤمنين بأن لهم عنده فضلًا كبيرًا، وقد بَيَّنَ الله تعالى الفضل الكبير ما هو في قوله تعالى: <span class="qpc-hafs">﴿والذين آمنوا وعملوا الصالحات في روضات الجنات لهم ما يشاءون عند ربهم ذلك هو الفضل الكبير﴾</span> [الشورى:٢٢]، فالآية التي في هذه السورة خبر، والتي في (حم عسق) تفسير لها».</div></p></div>",footnotes:1:أورده الثعلبي ٨/٥٢.أخرجه البيهقي في دلائل النبوة ٤/١٥٩، من طريق أحمد بن عبد الجبار، قال: حدثنا يونس بن بكير، عن عيسى بن [عبيد الله]، عن الربيع بن أنس، عن أنس به.</p><p>إسناده ضعيف؛ فيه أحمد بن عبد الجبار، وهو العطاردي، قال عنه ابن حجر في التقريب (٦٤): «ضعيف».أخرجه ابن جرير ٢١/١٢١ بنحوه.الناسخ والمنسوخ للزهري ص٣٣.عزاه السيوطي إلى ابن المنذر.أخرجه البيهقي في الدلائل ٤/١٥٩.عزاه السيوطي إلى عبد بن حميد، وابن جرير، وابن أبي حاتم.علقه يحيى بن سلّام ٢/٧٢٦.تفسير مقاتل بن سليمان ٣/٥٠٠.
  33,48,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَلَا تُطِعِ ٱلۡكَـٰفِرِینَ وَٱلۡمُنَـٰفِقِینَ وَدَعۡ أَذَىٰهُمۡ وَتَوَكَّلۡ عَلَى ٱللَّهِۚ وَكَفَىٰ بِٱللَّهِ وَكِیلࣰا ۝٤٨﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٢٤٣٨<span class="dash">-</span></span> قال <span class="name-1">عبد الله بن عباس</span>: <span class="qpc-hafs">﴿ودَعْ أذاهُمْ﴾</span> اصبر على أذاهم{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٢٤٣٩<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿ودَعْ أذاهُمْ﴾</span>، قال: أعْرِضْ عنهم{2}. (١٢/٧٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٢٤٤٠<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿ولا تُطِعِ الكافِرِينَ والمُنافِقِينَ﴾</span> قال: أمر اللهُ نبيَّه ألاَّ يطيع كافرًا ولا منافقًا، <span class="qpc-hafs">﴿ودَعْ أذاهُمْ﴾</span> قال: اصبِر على أذاهم{3}<span class=comment-ref>٥٢٤٩</span>. (١٢/٧٧)</p></p><p></div></p><p><div><span class=comment-ref>٥٢٤٩</span> <span class="comment-type-4">قال</span> <u>ابنُ عطية</u> (٧/١٢٨) بتصرف: «قوله تعالى: <span class="qpc-hafs">﴿ودع آذاهم﴾</span> يحتمل معنيين: <b>أحدهما</b>: أن يأمره بترك أن يؤذيهم هو ويعاقبهم، فكأن المعنى: واصفح عن زللهم ولا تؤذهم، فالمصدر -على هذا- مضاف إلى المفعول، ونُسِخ من الآية -على هذا التأويل- ما يخص الكافرين، وناسخه: آية السيف. <b>والمعنى الثاني</b>: أن يكون قوله: <span class="qpc-hafs">﴿ودع آذاهم﴾</span> بمعنى: أعرض عن أقوالهم، وما يؤذونك به، فالمصدر -على هذا التأويل- مضاف إلى الفاعل».</p><p>وإلى المعنى الأول <span class="comment-type-4">ذَهَبَ</span> <u>ابنُ تيمية</u> (٥/٢٥٠-٢٥١) <span class="mustanad">مستندًا إلى أحوال النزول</span>.</p><p>وإلى المعنى الثاني <span class="comment-type-4">ذَهَبَ</span> <u>ابنُ جرير</u> (١٩/١٢٧) <span class="mustanad">مستندًا إلى أقوال السلف</span>.</div></p><p><div></p><p><p><span class="item-no">٦٢٤٤١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ولا تُطِعِ الكافِرِينَ والمُنافِقِينَ﴾</span> ولا تطع الكافرين مِن أهل مكة؛ أبا سفيان بن حرب، وعكرمة بن أبي جهل، وأبا الأعور السلمي، والمنافقين؛ عبد الله بن أُبَيّ، وعبد الله بن سعد، وطعمة بن أُبَيْرِق، حين قال أبو سفيان ومَن معه من هؤلاء النفر: يا محمد، ارفض ذكر آلهتنا، وقل: إنّ لها شفاعة ومنفعة لمن عبدها، <span class="qpc-hafs">﴿ودَعْ أذاهُمْ﴾</span> ودع أذاهم إياك، يعني: الذين قالوا للنبي ﷺ: قل إن لآلهتنا شفاعة، <span class="qpc-hafs">﴿وتَوَكَّلْ عَلى اللَّهِ﴾</span> يعنى: وثِقْ بالله، <span class="qpc-hafs">﴿وكَفى بِاللَّهِ وكِيلًا﴾</span> يعني: مانِعًا{4}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير البغوي ٦/٣٦١.تفسير مجاهد (٥٥٠)، وأخرجه ابن جرير ١٩/١٢٧. وعلَّقه يحيى بن سلّام ٢/٧٢٦ وقال عَقِبَه: أي: اصبر عليه. وعزاه السيوطي إلى الفريابي، وابن أبي شيبة، وعبد بن حميد، وابن المنذر، وابن أبي حاتم.أخرجه ابن جرير ١٩/١٢٧ مقتصرًا على شطره الثاني. وعزاه السيوطي إلى عبد بن حميد، وابن أبي حاتم.تفسير مقاتل بن سليمان ٣/٥٠٠.
  33,49,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿یَـٰۤأَیُّهَا ٱلَّذِینَ ءَامَنُوۤا۟ إِذَا نَكَحۡتُمُ ٱلۡمُؤۡمِنَـٰتِ ثُمَّ طَلَّقۡتُمُوهُنَّ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٢٤٤٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق طاووس- أنه تلا: <span class="qpc-hafs">﴿يا أيُّها الَّذِينَ آمَنُوا إذا نَكَحْتُمُ المُؤْمِناتِ ثُمَّ طَلَّقْتُمُوهُنَّ مِن قَبْلِ أنْ تَمَسُّوهُن﴾</span>، قال: فلا يكون طلاقٌ حتى يكونَ نِكاحٌ{1}. (١٢/٨٠)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿یَـٰۤأَیُّهَا ٱلَّذِینَ ءَامَنُوۤا۟ إِذَا نَكَحۡتُمُ ٱلۡمُؤۡمِنَـٰتِ ثُمَّ طَلَّقۡتُمُوهُنَّ﴾</span> - من أحكام الآية</h3></p><p><div></p><p><p><span class="item-no">٦٢٤٤٣<span class="dash">-</span></span> عن سعيد بن جبير، قال: سُئِل <span class="name-1">ابنُ عباس</span> عن الرجل يقول: إن تزوجتُ فلانةً فهي طالق. قال: ليس بشيءٍ، إنما الطلاق لمن يملك.= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٢٤٤٤<span class="dash">-</span></span> قال: فإنّ <span class="name-1">ابن مسعود</span> كان يقول: إذا وقَّتَ وقتًا فهو كما قال؟ فقال: رحم الله أبا عبد الرحمن، لو كان كما قال لقال الله: يا أيها الذين آمنوا اذا طلقتم النساء ثم نكحتموهن. ولكن إنما قال: <span class="qpc-hafs">﴿إذا نَكَحْتُمُ المُؤْمِناتِ ثُمَّ طَلَّقْتُمُوهُنَّ﴾</span>{2}. (١٢/٨٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٢٤٤٥<span class="dash">-</span></span> عن عبد الملك ابن جريج قال: بلغ <span class="name-1">ابنَ عباس</span> أنّ <span class="name-1">ابن مسعود</span> يقول: إن طلّق ما لم ينكح فهو جائز. فقال <span class="name-1">ابنُ عباس</span>: أخطأ في هذا، إنّ الله تعالى يقول: <span class="qpc-hafs">﴿إذا نَكَحْتُمُ المُؤْمِناتِ ثُمَّ طَلَّقْتُمُوهُنَّ مِن قَبْلِ أنْ تَمَسُّوهُنَّ﴾</span>، ولم يقل: إذا طلقتم المؤمنات ثم نكحتموهن{3}. (١٢/٨٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٢٤٤٦<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عكرمة- قال: ما قالها <span class="name-1">ابن مسعود</span>، وإن يكن قالها فزلَّة من عالم -في الرجل يقول: إن تزوجتُ فلانة فهي طالق-، قال الله تعالى <span class="qpc-hafs">﴿يا أيُّها الَّذِينَ آمَنُوا إذا نَكَحْتُمُ المُؤْمِناتِ ثُمَّ طَلَّقْتُمُوهُنَّ﴾</span>، ولم يقل: إذا طلَّقتم المؤمنات ثم نكحتموهن{4}. (١٢/٨١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٢٤٤٧<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق سعيد بن جبير- قال: إذا قال: كل امرأة أتزوّجها فهي طالق. أو: إن تزوَّجتُ فلانة فهي طالق. فليس بشيء، إنما الطلاق لمن يملك، من أجل أن الله يقول: <span class="qpc-hafs">﴿إذا نَكَحْتُمُ المُؤْمِناتِ ثُمَّ طَلَّقْتُمُوهُنَّ﴾</span>{5}. (١٢/٨٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٢٤٤٨<span class="dash">-</span></span> عن حسين بن ثابت، قال: جاء رجل إلى <span class="name-2">علي بن الحسين</span>، فسأله عن رجل قال: إن تزوجتُ فلانة فهي طالق. قال: ليس بشيء، بدأ الله بالنكاح قبل الطلاق، فقال: <span class="qpc-hafs">﴿يا أيُّها الَّذِينَ آمَنُوا إذا نَكَحْتُمُ المُؤْمِناتِ ثُمَّ طَلَّقْتُمُوهُنَّ﴾</span>{2}. (١٢/٧٩)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿یَـٰۤأَیُّهَا ٱلَّذِینَ ءَامَنُوۤا۟ إِذَا نَكَحۡتُمُ ٱلۡمُؤۡمِنَـٰتِ ثُمَّ طَلَّقۡتُمُوهُنَّ مِن قَبۡلِ أَن تَمَسُّوهُنَّ فَمَا لَكُمۡ عَلَیۡهِنَّ مِنۡ عِدَّةࣲ تَعۡتَدُّونَهَاۖ﴾</span> - تفسير الآية، وأحكامها</h3></p><p><div></p><p><p><span class="item-no">٦٢٤٤٩<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- في قوله: <span class="qpc-hafs">﴿إذا نَكَحْتُمُ المُؤْمِناتِ﴾</span> الآية، قال: هذا في الرجل يتزوج المرأةَ ثُمَّ يُطَلِّقُها من قبل أن يمسها، فإذا طلقها واحدةً بانت منه، ولا عدة عليها، تتزوج مَن شاءت{7}. (١٢/٧٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٢٤٥٠<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- <span class="qpc-hafs">﴿يا أيُّها الَّذِينَ آمَنُوا إذا نَكَحْتُمُ المُؤْمِناتِ ثُمَّ طَلَّقْتُمُوهُنَّ مِن قَبْلِ أنْ تَمَسُّوهُن﴾</span> الآية، قال: التي نُكِحت ولم يُبْنَ بها، ولم يُفرض لها؛ فليس لها صداق، وليس عليها عِدَّة{8}. (١٢/٧٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٢٤٥١<span class="dash">-</span></span> تفسير <span class="name-2">السُّدِّيّ</span>: <span class="qpc-hafs">﴿من قبل أن تمسوهن﴾</span>، يعني: تُجامِعُوهُنَّ{9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٢٤٥٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿يا أيُّها الَّذِينَ آمَنُوا إذا نَكَحْتُمُ المُؤْمِناتِ﴾</span> يعني: إذا تزوجتم المصدِّقات بتوحيد الله، <span class="qpc-hafs">﴿ثُمَّ طَلَّقْتُمُوهُنّ مِن قَبْلِ أنْ تَمَسُّوهُنَّ﴾</span> يعني: مِن قبل أن تجامعوهن؛ <span class="qpc-hafs">﴿فَما لَكُمْ عَلَيْهِنَّ مِن عِدَّةٍ تَعْتَدُّونَها﴾</span> إن شاءت تزوَّجَْت مِن يومها{10}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٢٤٥٣<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿يا أيُّها الَّذِينَ آمَنُوا إذا نَكَحْتُمُ المُؤْمِناتِ ثُمَّ طَلَّقْتُمُوهُنّ مِن قَبْلِ أنْ تَمَسُّوهُنَّ فَما لَكُمْ عَلَيْهِنَّ مِن عِدَّةٍ تَعْتَدُّونَها﴾</span> إذا طلّق الرجلُ المرأةَ -قبل أن يدخل بها- واحدةً فقد بانتْ منه بتلك الواحدة، وهي أملك بنفسها، يخطبها مع الخُطّاب، وليس عليها عدة منه، ولا من غيره، حتى تُزوج إن شاءت مِن يومها الذي طلقها فيه؛ لأنه لم يطأها فتعتد مِن مائه مخافة أن تكون حُبْلى، ولها نصف الصداق، فإن أغلق عليها بابًا أو أرخى عليها سِترًا فقد وجب عليه الصداق كاملًا، ووجبت عليها العِدَّة، وإن طلَّقها ثلاثًا قبل أن يدخل بها لم يتزوجها حتى تنكح زوجًا غيره إلا أن يُفرِّق الطلاق، فيقول: أنت طالق، أنت طالق، أنت طالق. فإنها تبين بالأولى، وليس ما طلَّق بعدها بشيء، وهو خاطب من الخُطّاب، فإن تزوجها كانت عنده على تطليقتين{11}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿فَمَتِّعُوهُنَّ وَسَرِّحُوهُنَّ سَرَاحࣰا جَمِیلࣰا ۝٤٩﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٢٤٥٤<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- في قوله: <span class="qpc-hafs">﴿فَمَتِّعُوهُنَّ وسَرِّحُوهُنَّ سَراحًا جَمِيلًا﴾</span>، يقول: إن كان سمّى لها صداقًا فليس لها إلا النصف، وإن لم يكن سمّى لها صداقًا متَّعها على قدْر عُسْره ويُسْره، وهو السراح الجميل{7}<span class=comment-ref>٥٢٥٠</span>. (١٢/٧٨)</p></p><p></div></p><p><div><span class=comment-ref>٥٢٥٠</span> <span class="comment-type-4">قال</span> <u>ابنُ كثير</u> (١١/١٨٩): «المتعة ههنا أعم مِن أن تكون نصف الصداق المسمى، أو المتعة الخاصة إن لم يكن قد سمي لها، قال الله تعالى: <span class="qpc-hafs">﴿وإنْ طَلَّقْتُمُوهُنَّ مِن قَبْلِ أنْ تَمَسُّوهُنَّ وقَدْ فَرَضْتُمْ لَهُنَّ فَرِيضَةً فَنِصْفُ ما فَرَضْتُمْ﴾</span>، وقال ﷿: <span class="qpc-hafs">﴿لا جُناحَ عَلَيْكُمْ إنْ طَلَّقْتُمُ النِّساءَ ما لَمْ تَمَسُّوهُنَّ أوْ تَفْرِضُوا لَهُنَّ فَرِيضَةً ومَتِّعُوهُنَّ عَلى المُوسِعِ قَدَرُهُ وعَلى المُقْتِرِ قَدَرُهُ مَتاعًا بِالمَعْرُوفِ حَقًّا عَلى المُحْسِنِينَ﴾</span>، وفي صحيح البخاري عن سهل بن سعد، وأبي أسيد ﵄ قالا: إن رسول الله ﷺ تزوج أميمة بنت شراحيل، فلمّا أن دخلت عليه بسط يده إليها، فكأنها كرهت ذلك، فأمر أبا أسيد أن يجهزها ويكسوها ثوبين رازقيَّين».</div></p><p><div></p><p><p><span class="item-no">٦٢٤٥٥<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span>، قال: <span class="qpc-hafs">﴿فَمَتِّعُوهُنَّ﴾</span> لكل مطلَّقة متاع، دُخل أو لم يُدخل بها، فُرض لها أو لم يُفرض لها{2}. (١٢/٧٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٢٤٥٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فَمَتِّعُوهُنَّ وسَرِّحُوهُنَّ سَراحًا جَمِيلًا﴾</span>، يعني: حَسنًا في غير ضِرار{10}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٢٤٥٧<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: قوله: <span class="qpc-hafs">﴿فَمَتِّعُوهُنَّ﴾</span> فهو منسوخ إذا كان قد سَمّى لها صداقًا، إلا أن يكون لم يُسمّ لها صداقًا فيكون لها المتعة ولا صداق لها، فإن كان سَمّى لها صداقًا ثم طلّقها قبل أن يدخل بها فإن لها نصف الصداق ولا متعة لها ...، <span class="qpc-hafs">﴿وسَرِّحُوهُنَّ سَراحًا جَمِيلًا﴾</span> إلى أهلهن، لا تكون المرأة والرجل في بيت وليس بينهما حُرمَة، وإذا مات الرجل قبل أن يدخل بامرأته توارثا ولها الصداق كاملًا، وإنما يكون لها النصف إذا طلقها{15}<span class=comment-ref>٥٢٥١</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٥٢٥١</span> <span class="comment-type-4">قال</span> <u>ابنُ عطية</u> (٧/١٣٠): «هذه الآية خصصت آيتين: <b>إحداهما</b>: <span class="qpc-hafs">﴿والمطلقات يتربصن بأنفسهن ثلاثة قروء﴾</span> فخصصت هذه الآية من لم يدخل بها، وكذلك خصصت من ذوات الثلاثة الأشهر، وهُنَّ مَن قَعَدْن عن المحيض، ومَن لم يحضن مِن صغير المطلقات قبل البناء».</div></p><p><h3><span class="qpc-hafs">﴿فَمَتِّعُوهُنَّ وَسَرِّحُوهُنَّ سَرَاحࣰا جَمِیلࣰا ۝٤٩﴾</span> - النسخ في الآية</h3></p><p><div></p><p><p><span class="item-no">٦٢٤٥٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عمر</span>، في قوله: <span class="qpc-hafs">﴿فَمَتِّعُوهُنَّ﴾</span>، قال: هي منسوخة، نسختها الآية التي في البقرة [٢٣٧]: <span class="qpc-hafs">﴿فَنِصْفُ ما فَرَضْتُمْ﴾</span>{16}. (١٢/٧٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٢٤٥٩<span class="dash">-</span></span> عن <span class="name-2">سعيد بن المسيب</span> -من طريق قتادة- <span class="qpc-hafs">﴿يا أيُّها الَّذِينَ آمَنُوا إذا نَكَحْتُمُ المُؤْمِناتِ﴾</span> إلى قوله: <span class="qpc-hafs">﴿فَمَتِّعُوهُنَّ﴾</span>، قال: هي منسوخة، نسختها الآية التي في البقرة [٢٣٧]: <span class="qpc-hafs">﴿وإنْ طَلَّقْتُمُوهُنَّ مِن قَبْلِ أنْ تَمَسُّوهُنَّ وقَدْ فَرَضْتُمْ لَهُنَّ فَرِيضَةً فَنِصْفُ ما فَرَضْتُمْ﴾</span>، فصار لها نصف الصداق، ولا متاع لها{17}. (١٢/٧٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٢٤٦٠<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٢٤٦١<span class="dash">-</span></span> و<span class="name-2">أبي العالية الرياحي</span>، قالا: <span class="qpc-hafs">﴿فَمَتِّعُوهُنَّ﴾</span> ليست بمنسوخة، لها نصف الصداق، ولها المتاع{2}. (١٢/٧٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٢٤٦٢<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق قرة بن خالد- أنه كان يقول: <span class="qpc-hafs">﴿فَمَتِّعُوهُنَّ﴾</span> لها المتاع، وليست بمنسوخة{19}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٢٤٦٣<span class="dash">-</span></span> قال <span class="name-2">قتادة بن دعامة</span>: <span class="qpc-hafs">﴿فَمَتِّعُوهُنَّ﴾</span> هذه الآية منسوخة بقوله: <span class="qpc-hafs">﴿فَنِصْفُ ما فَرَضْتُمْ﴾</span> [البقرة:٢٣٧]{20}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٢٤٦٤<span class="dash">-</span></span> عن <span class="name-2">زيد بن أسلم</span> -من طريق القاسم بن عبد الله- أنه قال: <span class="qpc-hafs">﴿والمُطَلَّقاتُ يَتَرَبَّصْنَ بِأَنْفُسِهِنَّ ثَلاثَةَ قُرُوءٍ﴾</span> [البقرة:٢٢٨]، وقال: <span class="qpc-hafs">﴿فَعِدَّتُهُنَّ ثَلاثَةُ أشْهُرٍ﴾</span> [الطلاق:٤]، فنسخ واستثنى منها، فقال: <span class="qpc-hafs">﴿يا أيُّها الَّذِينَ آمَنُوا إذا نَكَحْتُمُ المُؤْمِناتِ ثُمَّ طَلَّقْتُمُوهُنَّ مِن قَبْلِ أنْ تَمَسُّوهُنَّ فَما لَكُمْ عَلَيْهِنَّ مِن عِدَّةٍ تَعْتَدُّونَها فَمَتِّعُوهُنَّ وسَرِّحُوهُنَّ سَراحًا جَمِيلًا﴾</span>، وقال: <span class="qpc-hafs">﴿لا يُكَلِّفُ اللَّهُ نَفْسًا إلّا وُسْعَها لَها ما كَسَبَتْ وعَلَيْها ما اكْتَسَبَتْ﴾</span> [البقرة:٢٨٦]{21}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٢٤٦٥<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلام</span>: قوله: <span class="qpc-hafs">﴿فَمَتِّعُوهُنَّ﴾</span> فهو منسوخ إذا كان قد سمى لها صداقًا، إلا أن يكون لم يسم لها صداقًا فيكون لها المتعة ولا صداق لها، فإن كان سمى لها صداقًا ثم طلقها قبل أن يدخل بها فإن لها نصف الصداق، ولا متعة لها، نسختها الآية التي في البقرة [٢٣٦-٢٣٧]: <span class="qpc-hafs">﴿لا جُناحَ عَلَيْكُمْ إنْ طَلَّقْتُمُ النِّساءَ ما لَمْ تَمَسُّوهُنَّ أوْ تَفْرِضُوا لَهُنَّ فَرِيضَةً ومَتِّعُوهُنَّ عَلى المُوسِعِ قَدَرُهُ وعَلى المُقْتِرِ قَدَرُهُ مَتاعًا بِالمَعْرُوفِ حَقًّا عَلى المُحْسِنِينَ * وإنْ طَلَّقْتُمُوهُنَّ مِن قَبْلِ أنْ تَمَسُّوهُنَّ وقَدْ فَرَضْتُمْ لَهُنَّ فَرِيضَةً فَنِصْفُ ما فَرَضْتُمْ﴾</span> ولا متاع لها إلى آخر الآية ... والعامة على أنها منسوخة{15}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿فَمَتِّعُوهُنَّ وَسَرِّحُوهُنَّ سَرَاحࣰا جَمِیلࣰا ۝٤٩﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٦٢٤٦٦<span class="dash">-</span></span> عن عائشة: أنّ رسول الله ﷺ قال: «<b>لا طلاق إلا بعد نكاح، ولا عتق إلا بعد ملك</b>»{23}. (١٢/٨١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٢٤٦٧<span class="dash">-</span></span> عن جابر بن عبد الله، أنّه سمع رسول الله ﷺ يقول: «<b>لا طلاق فيما لا تملك، ولا عتق فيما لا تملك</b>»{24}. (١٢/٨٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٢٤٦٨<span class="dash">-</span></span> عن المسور بن مخرمة، عن النبي ﷺ قال: «<b>لا طلاق قبل نكاح، ولا عتق قبل مِلك</b>»{25}. (١٢/٨٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٢٤٦٩<span class="dash">-</span></span> عن عمرو بن شعيب، عن أبيه، عن جده، قال: قال رسول الله ﷺ:«<b>لا طلاق فيما لا تملك، ولا بيع فيما لا تملك، ولا عِتق فيما لا تملك، ولا وفاء نذر فيما لا تملك، ولا نذر إلا فيما ابتُغي وجه الله تعالى، ومَن حلف على معصية فلا يمين له، ومَن حلف على قطيعة رحم فلا يمين له</b>»{26}. (١٢/٨٢)</p></p><p></div></p></div>",footnotes:1:أخرجه الحاكم ٢/٤١٩. وعزاه السيوطي إلى ابن أبي حاتم.عزاه السيوطي إلى عبد بن حميد.أخرجه عبد الرزاق (١١٤٦٨).أخرجه البيهقي في سننه ٧/٣٢٠-٣٢١.أخرجه ابن أبي حاتم -كما في تفسير ابن كثير ٦/٤٣٢-. وعزاه السيوطي إلى ابن المنذر.عزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ١٩/١٢٨. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.أخرجه عبد الرزاق ٢/١١٩. وعزاه السيوطي إلى ابن المنذر.تفسير يحيى بن سلّام ٢/٧١٣-٧١٤.تفسير مقاتل بن سليمان ٣/٥٠٠.تفسير يحيى بن سلّام ٢/٧٢٨.أخرجه ابن جرير ١٩/١٢٨. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.عزاه السيوطي إلى عبد بن حميد.تفسير مقاتل بن سليمان ٣/٥٠٠.تفسير يحيى بن سلّام ٢/٧٢٧-٧٢٨.عزاه السيوطي إلى ابن مردويه.عزاه السيوطي إلى عبد بن حميد. وأخرجه ابن جرير ١٩/١٢٩ بنحوه، وأخرجه يحيى بن سلّام ٢/٧٢٧ بلفظ: جُعلتْ لها المتعة في هذه الآية، فلما نزلت الآية التي في البقرة: <span class="qpc-hafs">﴿وإنْ طَلَّقْتُمُوهُنَّ مِن قَبْلِ أنْ تَمَسُّوهُنَّ وقَدْ فَرَضْتُمْ لَهُنَّ فَرِيضَةً فَنِصْفُ ما فَرَضْتُمْ﴾</span> جعل لها النصف، ولا متاع لها.عزاه السيوطي إلى عبد بن حميد.أخرجه يحيى بن سلّام ٢/٧٢٨.تفسير الثعلبي ٨/٥٢، وتفسير البغوي ٦/٣٦٢. وعلقه يحيى بن سلّام ٢/٧٢٧.أخرجه عبد الله بن وهب في الجامع -تفسير القرآن ٣/٦٧-٦٨ (١٥٢)-.تفسير يحيى بن سلّام ٢/٧٢٧-٧٢٨.أخرجه الحاكم ٢/٤٥٤ (٣٥٦٩).</p><p>قال ابن أبي حاتم في علل الحديث ٤/٨٠ (١٢٧١): «قال أبي: هذا حديث منكر». وقال ابن الجوزي في العلل المتناهية ٢/١٥٣ (١٠٦٢): «وهذا لا يصح».أخرجه الحاكم ٢/٢٢٢ (٢٨١٩)، ٢/٤٥٥ (٣٥٧٢، ٣٥٧٣).</p><p>قال الحاكم: «هذا حديث صحيح، على شرط الشيخين، ولم يخرجاه». وقال ابن حجر في بلوغ المرام ٢/٩٩ (١٠٨٢): «وهو معلول».أخرجه ابن ماجه ٣/٢٠٢ (٢٠٤٨).</p><p>قال البوصيري في مصباح الزجاجة ٢/١٢٦ (٧٢٩): «هذا إسناد حسن». وقال ابن حجر في بلوغ المرام ٢/٩٩ (١٠٨٣): «إسناده حسن، لكنه معلول». وقال المناوي في التيسير ٢/٥٠١: «إسناده حسن». وقال الألباني في الإرواء ٧/١٥٢ (٢٠٧٠): «صحيح».أخرجه أحمد ١١/٣٨١-٣٨٢ (٦٧٦٩)، ١١/٣٩٢-٣٩٣ (٦٧٨٠، ٦٧٨١)، ١١/٥٢٥ (٦٩٣٢)، وأبو داود ٣/٥١٣-٥١٤ (٢١٩٠، ٢١٩١، ٢١٩٢) واللفظ له، والترمذي ٣/٤١ (١٢١٧)، والنسائي ٧/١٢ (٣٧٩٢)، وابن ماجه ٣/٢٠٢ (٢٠٤٧)، والحاكم ٢/٢٢٢ (٢٨٢٠)، ٤/٣٣٣ (٧٨٢٢).</p><p>قال الترمذي: «حديث حسن صحيح، وهو أحسن شيء روي في هذا الباب». وقال في العلل الكبير ص١٧٣ (٣٠٢): «سألت محمدًا عن هذا الحديث، فقلت: أيُّ حديث في هذا الباب أصح في الطلاق قبل النكاح؟ فقال: حديث عمرو بن شعيب عن أبيه عن جده». وقال الحاكم في الموضع الثاني: «هذا حديث صحيح الإسناد، ولم يخرجاه». وقال ابن الملقن في تحفة المحتاج ٢/٢٠٦ (١١٨٤): «بإسناد صحيح». وقال العيني في عمدة القاري ٢٣/١٩٧: «بإسناد صحيح». وقال الألباني في صحيح أبي داود ٦/٣٩٣-٣٩٤ (١٩٠٠): «إسناده حسن».
  33,50,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿یَـٰۤأَیُّهَا ٱلنَّبِیُّ إِنَّاۤ أَحۡلَلۡنَا لَكَ أَزۡوَ ٰ⁠جَكَ ٱلَّـٰتِیۤ ءَاتَیۡتَ أُجُورَهُنَّ وَمَا مَلَكَتۡ یَمِینُكَ مِمَّاۤ أَفَاۤءَ ٱللَّهُ عَلَیۡكَ وَبَنَاتِ عَمِّكَ وَبَنَاتِ عَمَّـٰتِكَ وَبَنَاتِ خَالِكَ وَبَنَاتِ خَـٰلَـٰتِكَ ٱلَّـٰتِی هَاجَرۡنَ مَعَكَ وَٱمۡرَأَةࣰ مُّؤۡمِنَةً إِن وَهَبَتۡ نَفۡسَهَا لِلنَّبِیِّ إِنۡ أَرَادَ ٱلنَّبِیُّ أَن یَسۡتَنكِحَهَا خَالِصَةࣰ لَّكَ مِن دُونِ ٱلۡمُؤۡمِنِینَۗ قَدۡ عَلِمۡنَا مَا فَرَضۡنَا عَلَیۡهِمۡ فِیۤ أَزۡوَ ٰ⁠جِهِمۡ وَمَا مَلَكَتۡ أَیۡمَـٰنُهُمۡ لِكَیۡلَا یَكُونَ عَلَیۡكَ حَرَجࣱۗ وَكَانَ ٱللَّهُ غَفُورࣰا رَّحِیمࣰا ۝٥٠﴾</span> - قراءات</h3></p><p><div></p><p><p><span class="item-no">٦٢٤٧٠<span class="dash">-</span></span> عن عبيد، قال: سمعت الضحاك يقول في حرف <span class="name-1">ابن مسعود</span>: (واللّاتِي هاجَرْنَ مَعَكَ): يعني بذلك: كل شيء هاجر معه ليس من بنات العم والعمة، ولا من بنات الخال والخالة{1}<span class=comment-ref>٥٢٥٢</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٥٢٥٢</span> <span class="comment-type-4">علَّقَ</span> <u>ابنُ جرير</u> (١٩/١٣١) على هذه القراءة بقوله: "ذلك -وإن كان كذلك في قراءته- محتمل أن يكون بمعنى قراءتنا بغير الواو، وذلك أن العرب تدخل الواو في نعت مَن تقدَّم ذِكْرُه أحيانا،كما قال الشاعر:</p><p>فإنّ رُشَيدًا وابن مَرَوانَ لَم يَكُنْ ... لِيَفْعَلَ حَتّى يَصْدُرَ الأمْرُ مُصْدَرا</p><p>ورشيد هو ابن مروان. وكان الضحاك بن مزاحم يتأوَّل قراءة عبد الله هذه أنهن نوعٌ غيرُ بنات خالاته، وأنهن كل مهاجرة هاجرت مع النبي ﷺ".</div></p><p><h3><span class="qpc-hafs">﴿یَـٰۤأَیُّهَا ٱلنَّبِیُّ إِنَّاۤ أَحۡلَلۡنَا لَكَ أَزۡوَ ٰ⁠جَكَ ٱلَّـٰتِیۤ ءَاتَیۡتَ أُجُورَهُنَّ وَمَا مَلَكَتۡ یَمِینُكَ مِمَّاۤ أَفَاۤءَ ٱللَّهُ عَلَیۡكَ وَبَنَاتِ عَمِّكَ وَبَنَاتِ عَمَّـٰتِكَ وَبَنَاتِ خَالِكَ وَبَنَاتِ خَـٰلَـٰتِكَ ٱلَّـٰتِی هَاجَرۡنَ مَعَكَ وَٱمۡرَأَةࣰ مُّؤۡمِنَةً إِن وَهَبَتۡ نَفۡسَهَا لِلنَّبِیِّ إِنۡ أَرَادَ ٱلنَّبِیُّ أَن یَسۡتَنكِحَهَا خَالِصَةࣰ لَّكَ مِن دُونِ ٱلۡمُؤۡمِنِینَۗ قَدۡ عَلِمۡنَا مَا فَرَضۡنَا عَلَیۡهِمۡ فِیۤ أَزۡوَ ٰ⁠جِهِمۡ وَمَا مَلَكَتۡ أَیۡمَـٰنُهُمۡ لِكَیۡلَا یَكُونَ عَلَیۡكَ حَرَجࣱۗ وَكَانَ ٱللَّهُ غَفُورࣰا رَّحِیمࣰا ۝٥٠﴾</span> - نزول الآية</h3></p><p><div></p><p><p><span class="item-no">٦٢٤٧١<span class="dash">-</span></span> عن <span class="name-1">أم هانئ</span> قالت: نزلت فِيّ هذه الآية: <span class="qpc-hafs">﴿وبَناتِ عَمِّكَ﴾</span> <span class="qpc-hafs">﴿اللّاتِي هاجَرْنَ مَعَكَ﴾</span>، أراد النبي ﷺ أن يتزوَّجني، فنُهي عني؛ إذ لم أهاجر{2}. (١٢/٨٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٢٤٧٢<span class="dash">-</span></span> عن <span class="name-1">أم هانئ بنت أبي طالب</span>، قالت: خطبني رسولُ الله ﷺ، فاعتذرتُ إليه، فعذرني؛ فأنزل الله: <span class="qpc-hafs">﴿يا أيُّها النبي إنّا أحْلَلْنا لَكَ أزْواجَكَ﴾</span> إلى قوله: <span class="qpc-hafs">﴿هاجَرْنَ مَعَكَ﴾</span>، قالت: فلم أكن أحلُّ له؛ لأني لم أهاجر معه، كنت مِن الطلقاء{3}. (١٢/٨٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٢٤٧٣<span class="dash">-</span></span> عن <span class="name-2">أبي صالح مولى أم هانئ</span>، قال: خطب رسولُ الله ﷺ أمَّ هانئ بنت أبي طالب، فقالت: يا رسول الله، إني مُوتِـمــــَةٌ{4}، وبنيَّ صغار. فلمّا أدرك بنوها عرضتْ نفسها عليه، فقال: «<b>أمّا الآن فلا، إنّ الله تعالى أنزل عليّ: <span class="qpc-hafs">﴿يا أيُّها النبي إنّا أحْلَلْنا لَكَ أزْواجَكَ﴾</span> إلى <span class="qpc-hafs">﴿هاجَرْنَ مَعَكَ﴾</span>»</b> ولم تكن من المهاجرات{5}. (١٢/٨٣)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿یَـٰۤأَیُّهَا ٱلنَّبِیُّ إِنَّاۤ أَحۡلَلۡنَا لَكَ أَزۡوَ ٰ⁠جَكَ ٱلَّـٰتِیۤ ءَاتَیۡتَ أُجُورَهُنَّ وَمَا مَلَكَتۡ یَمِینُكَ مِمَّاۤ أَفَاۤءَ ٱللَّهُ عَلَیۡكَ وَبَنَاتِ عَمِّكَ وَبَنَاتِ عَمَّـٰتِكَ وَبَنَاتِ خَالِكَ وَبَنَاتِ خَـٰلَـٰتِكَ ٱلَّـٰتِی هَاجَرۡنَ مَعَكَ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٢٤٧٤<span class="dash">-</span></span> عن <span class="name-1">أُبَيّ بن كعب</span> -من طريق موسى بن عبد الله- قال: <span class="qpc-hafs">﴿إنّا أحْلَلْنا لَكَ أزْواجَكَ اللّاتِي آتَيْتَ أُجُورَهُنَّ﴾</span> صداقهن، <span class="qpc-hafs">﴿وما مَلَكَتْ يَمِينُكَ مِمّا أفاءَ اللَّهُ عَلَيْكَ وبَناتِ عَمِّكَ وبَناتِ عَمّاتِكَ﴾</span> حتى انتهى إلى قوله: <span class="qpc-hafs">﴿لا يَحِلُّ لَكَ النِّساءُ مِن بَعْدُ﴾</span> هؤلاء: العمة، والخالة، ونحوهن. وكان يقول: يتزوج من بنات عماته وبنات خالاته اللاتي هاجرن معه{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٢٤٧٥<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطية العوفي- في قوله: <span class="qpc-hafs">﴿يا أيُّها النبي إنّا أحْلَلْنا لَكَ أزْواجَكَ﴾</span> إلى قوله: <span class="qpc-hafs">﴿خالِصَةً لَكَ مِن دُونِ المُؤْمِنِينَ﴾</span>، قال: فحرَّم الله عليه سوى ذلك من النساء، وكان قبل ذلك ينكح في أيِّ النساء شاء، لم يُحرِّم ذلك عليه، وكان نساؤُه يَجِدْن مِن ذلك وجْدًا شديدًا أن ينكح في أيِّ النساء أحب، فلمّا أنزل الله عليه: إني قد حرَّمت عليك من النساء سوى ما قصصتُ عليك. أعجب ذلكَ نساءَه{7}. (١٢/٨٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٢٤٧٦<span class="dash">-</span></span> عن <span class="name-2">أبي رَزِين [مسعود بن مالك الأسدي]</span> -من طريق مغيرة- في قول الله: <span class="qpc-hafs">﴿وبنات عمك وبنات عماتك وبنات خالك وبنات خالاتك﴾</span>، قال: لا تحل لك النساء بعد هذه الصفة{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٢٤٧٧<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿إنّا أحْلَلْنا لَكَ أزْواجَكَ﴾</span> قال: هُنَّ أزواجه الأُوَل اللاتي كُنَّ قبل أن تنزل هذه الآية. وفي قوله: <span class="qpc-hafs">﴿اللّاتِي آتَيْتَ أُجُورَهُنَّ﴾</span> قال: صدُقاتهن، <span class="qpc-hafs">﴿وما مَلَكَتْ يَمِينُكَ﴾</span> قال: هي الإماء التي أفاء الله عليه{9}. (١٢/٨٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٢٤٧٨<span class="dash">-</span></span> عن <span class="name-2">الضحاك بن مزاحم</span> -من طريق عبيد- يقول في قوله: <span class="qpc-hafs">﴿يا أيُّها النبي إنّا أحْلَلْنا لَكَ أزْواجَكَ اللّاتِي آتَيْتَ أُجُورَهُنَّ﴾</span> إلى قوله: <span class="qpc-hafs">﴿خالِصَةً لَكَ مِن دُونِ المُؤْمِنِين﴾</span>: فما كان مِن هذه التسمية ما شاء كثيرًا أو قليلًا{10}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٢٤٧٩<span class="dash">-</span></span> عن <span class="name-2">الضحاك بن مزاحم</span> -من طريق عبيد- في قوله: <span class="qpc-hafs">﴿يا أيها النبي إنا أحللنا لك أزواجك﴾</span> إلى قوله: <span class="qpc-hafs">﴿خالصة لك من دون المؤمنين﴾</span>، قال: فما كان مِن هذه التسمية، وهي خمس من النساء، فكان للنبي أن ينكح مِن هذه التسمية ما شاء كثيرًا كان أو قليلًا{11}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٢٤٨٠<span class="dash">-</span></span> عن <span class="name-2">عامر الشعبي</span>، في قوله: <span class="qpc-hafs">﴿إنّا أحْلَلْنا لَكَ أزْواجَكَ﴾</span> الآية، قال: رخَّص له في بنات عمه، وبنات عماته، وبنات خاله، وبنات خالاته، اللاتي هاجرن معه؛ أن يتزوج منهن، ولا يتزوج من غيرهن، ورخّص له في امرأة مؤمنة إن وهبت نفسها للنبي ﷺ{12}. (١٢/٨٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٢٤٨١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿يا أيُّها النبي إنّا أحْلَلْنا لَكَ أزْواجَكَ﴾</span> يعني: النساء التسع<span class=comment-ref>٥٢٥٣</span> <span class="qpc-hafs">﴿اللّاتِي آتَيْتَ أُجُورَهُنَّ وما مَلَكَتْ يَمِينُكَ﴾</span> أحللنا لك ما ملكت يمينك -يعني: بالولاية- مارية القبطية أم إبراهيم، وريحانة بنت عمرو اليهودي، وكانت سُبِيَت من اليهود، <span class="qpc-hafs">﴿مِمّا أفاءَ اللَّهُ عَلَيْكَ و﴾</span> أحللنا لك <span class="qpc-hafs">﴿بَناتِ عَمِّكَ وبَناتِ عَمّاتِكَ وبَناتِ خالِكَ وبَناتِ خالاتِكَ اللّاتِي هاجَرْنَ مَعَكَ﴾</span> إلى المدينة؛ إضمارُ: فإن كانت لم تهاجر إلى المدينة؛ فلا يحل تزويجها{13}. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٥٢٥٣</span> <span class="comment-type-4">قال</span> <u>ابنُ عطية</u> (٧/١٣٠) بتصرف: «تأول غير ابن زيد قوله:(أحللنا لك أزواجك اللاتي آتيت أجورهن) أن الإشارة إلى عائشة وحفصة ومن في عصمته ممن تزوجها بمهر، وأن ملك اليمين بعدُ حلال له، وأن الله تعالى أباح له مع المذكورات بنات عمه وعماته وخاله وخالاته ممن هاجرن معه، والواهبات خاصة له، فيجيء الأمر -على هذا التأويل- أضيق على النبي ﷺ، و<span class="comment-type-3">يؤيد</span> هذا التأويل <span class="mustanad">ما قاله ابن عباس</span> ﵄:»كان رسول الله ﷺ يتزوج في أيّ الناس شاء، وكان ذلك يشق على نسائه، فلما نزلت هذه الآية، وحرّم عليه الناس إلا مَن سمّى سُرَّ نساؤه بذلك«؛ لأن ملك اليمين إنما تعلّقه في النادر من الأمر، وبنات العم والعمات والخال والخالات يسير، ومن يمكن أن يتزوج منهن محصور عند نسائه، لا سيما وقد قيد ذلك بشرط الهجرة، وكذا الواهبة من النساء قليل، فلذلك سُرَّ أزواج النبي ﷺ بانحصار الأمر».</div></p><p><div></p><p><p><span class="item-no">٦٢٤٨٢<span class="dash">-</span></span> قال <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿يا أيُّها النبي إنّا أحْلَلْنا لَكَ أزْواجَكَ اللّاتِي آتَيْتَ أُجُورَهُنَّ﴾</span>، قال: كان كل امرأة آتاها مهرًا فقد أحلَّها الله له{14}<span class=comment-ref>٥٢٥٤</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٥٢٥٤</span> <span class="comment-type-4">قال</span> <u>ابنُ عطية</u> (٧/١٣٠-١٣١): «ذهب ابن زيد والضحاك في تفسير قوله: <span class="qpc-hafs">﴿إنا أحللنا لك أزواجك اللاتي آتيت أجورهن﴾</span> إلى أن المعنى: أنّ الله تعالى أحل له أن يتزوج كل امرأة يؤتيها مهرها، وأباح له كلَّ النساء بهذا الوجه، وأباح له ملك اليمين، وبنات العم والعمة والخال والخالة ممن هاجر معه، وخصص هؤلاء بالذكر تشريفًا وتنبيهًا؛ إذ قد تناولهن -على تأويل ابن زيد- قوله تعالى: <span class="qpc-hafs">﴿يا أيها النبيّ إنا أحللنا﴾</span>، وأباح له الواهبات خاصة له، فهذا -على تأويل ابن زيد- إباحة مطلقة في جميع النساء حاشا ذوات المحارم، لا سيما -على ما ذكره الضحاك- أن <span class="mustanad">في مصحف ابن مسعود</span>: (وبَناتِ خالاتِكَ واللاَّتِي هاجَرْنَ مَعَكَ)».</div></p><p><div></p><p><p><span class="item-no">٦٢٤٨٣<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: قوله ﷿: <span class="qpc-hafs">﴿يَأَيُّها النبي إنّا أحْلَلْنا لَكَ أزْواجَكَ اللّاتِي آتَيْتَ أُجُورَهُنَّ﴾</span> صداقهن، <span class="qpc-hafs">﴿وما مَلَكَتْ يَمِينُكَ مِمّا أفاءَ اللَّهُ عَلَيْكَ وبَناتِ عَمِّكَ﴾</span> أي: وأحللنا لك أيضًا بنات عمك، <span class="qpc-hafs">﴿وبَناتِ عَمّاتِكَ وبَناتِ خالِكَ وبَناتِ خالاتِكَ اللّاتِي هاجَرْنَ مَعَكَ﴾</span> إلى قوله: <span class="qpc-hafs">﴿لا يَحِلُّ لَكَ النِّساءُ مِن بَعْدُ﴾</span> هؤلاء اللاتي ذَكر مِن أزواجه، ومن بنات عمه، ومن بنات عماته، وبنات خاله، وبنات خالاته{15}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿یَـٰۤأَیُّهَا ٱلنَّبِیُّ إِنَّاۤ أَحۡلَلۡنَا لَكَ أَزۡوَ ٰ⁠جَكَ ٱلَّـٰتِیۤ ءَاتَیۡتَ أُجُورَهُنَّ وَمَا مَلَكَتۡ یَمِینُكَ مِمَّاۤ أَفَاۤءَ ٱللَّهُ عَلَیۡكَ وَبَنَاتِ عَمِّكَ وَبَنَاتِ عَمَّـٰتِكَ وَبَنَاتِ خَالِكَ وَبَنَاتِ خَـٰلَـٰتِكَ ٱلَّـٰتِی هَاجَرۡنَ مَعَكَ﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٦٢٤٨٤<span class="dash">-</span></span> عن <span class="name-2">محمد بن كعب القرظي</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٢٤٨٥<span class="dash">-</span></span> و<span class="name-2">عمر بن الحكم</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٢٤٨٦<span class="dash">-</span></span> و<span class="name-2">عبد الله بن عبيدة</span> -من طريق موسى بن عبيدة- قالوا: تزوج رسول الله ﷺ ثلاث عشرة امرأة؛ ست من قريش: خديجة، وعائشة، وحفصة، وأم حبيبة، وسودة، وأم سلمة، وثلاث من بني عامر بن صعصعة؛ امرأتان من بني هلال، ميمونة بنت الحارث وهي التي وهبت نفسها للنبي ﷺ، وزينب أم المساكين، وامرأة من بني بكر بن كلاب من القُرطاء، وهي التي اختارت الدنيا، وامرأة من بني الجون، وهي التي استعاذت منه، وزينب بنت جحش الأسدية، والسبيَّتان صفية بنت حيي، وجويرية بنت الحارث الخزاعية{16}. (١٢/٨٦)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَٱمۡرَأَةࣰ مُّؤۡمِنَةً إِن وَهَبَتۡ نَفۡسَهَا لِلنَّبِیِّ﴾</span> - قراءات</h3></p><p><div></p><p><p><span class="item-no">٦٢٤٨٧<span class="dash">-</span></span> عن هارون، عن <span class="name-2">أبي عمرو [البصري]</span>، <span class="qpc-hafs">﴿إن وهبت﴾</span>، قال هارون: في قراءة <span class="name-1">ابن مسعود</span>: (وامْرَأَةً مُّؤْمِنَةً وهَبَتْ نَفْسَها لِلنَّبِيِّ){17}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَٱمۡرَأَةࣰ مُّؤۡمِنَةً إِن وَهَبَتۡ نَفۡسَهَا لِلنَّبِیِّ﴾</span> - نزول الآية، وتفسيرها</h3></p><p><div></p><p><p><span class="item-no">٦٢٤٨٨<span class="dash">-</span></span> عن <span class="name-1">عائشة</span> -من طريق عروة- قالت: <span class="qpc-hafs">﴿وامْرَأَةً مُؤْمِنَةً إنَّ وهَبَتْ نَفْسَها لِلنَّبِيِّ﴾</span> التي وهبت نفسها للنبي ﷺ: خولة بنت حكيم{18}. (١٢/٨٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٢٤٨٩<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عكرمة- قال: <span class="qpc-hafs">﴿وامْرَأَةً مُؤْمِنَةً إنَّ وهَبَتْ نَفْسَها لِلنَّبِيِّ﴾</span> لم يكن عند رسول الله ﷺ امرأة وهبت نفسها{19}. (١٢/٨٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٢٤٩٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق قتادة- <span class="qpc-hafs">﴿وامْرَأَةً مُؤْمِنَةً إنَّ وهَبَتْ نَفْسَها لِلنَّبِيِّ﴾</span>، قال: هي ميمونة بنت الحارث{20}. (١٢/٨٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٢٤٩١<span class="dash">-</span></span> عن <span class="name-1">سهل بن سعد الساعدي</span>: أنّ امرأة جاءت إلى النبي ﷺ، فوهبتْ نفسها له، فصمتْ، فقال رجل: يا رسول الله، زوِّجنيها إن لم يكن لك بها حاجة. قال: «<b>ما عندك تعطيها؟</b>». قال: ما عندي إلا إزاري. قال: «<b>إن أعطيتَها إزارك جلستْ لا إزار لك، فالتمس شيئًا</b>». قال: ما أجدُ شيئًا. فقال: «<b>التمس ولو خاتمًا مِن حديد</b>». فلم يجد، فقال: «<b>هل معك مِن القرآن شيء</b>؟». قال: نعم، سورة كذا وسورة كذا. لسورٍ سماها، فقال: «<b>قد زوّجناكها بما معك من القرآن</b>»{21}. (١٢/٨٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٢٤٩٢<span class="dash">-</span></span> عن <span class="name-1">أنس بن مالك</span> -من طريق ثابت- قال: <span class="qpc-hafs">﴿وامْرَأَةً مُؤْمِنَةً إنَّ وهَبَتْ نَفْسَها لِلنَّبِيِّ﴾</span> جاءت امرأة إلى النبي ﷺ، فقالت: يا نبيَّ الله هل لك فِيَّ حاجة؟ فقالت ابنةُ أنس: ما كان أقلَّ حياءها! فقال: هي خير منكِ، رغبتْ في النبي ﷺ؛ فعرضتْ نفسها عليه{22}. (١٢/٨٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٢٤٩٣<span class="dash">-</span></span> عن <span class="name-2">علي بن الحسين بن علي بن أبي طالب</span> -من طريق الحكم- في قوله: <span class="qpc-hafs">﴿وامْرَأَةً مُؤْمِنَةً إنَّ وهَبَتْ نَفْسَها لِلنَّبِيِّ﴾</span>: هي أم شَرِيك الأزدية التي وهبت نفسها للنبي ﷺ{23}. (١٢/٨٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٢٤٩٤<span class="dash">-</span></span> عن <span class="name-2">عروة بن الزبير</span> -من طريق هشام- <span class="qpc-hafs">﴿وامْرَأَةً مُؤْمِنَةً إنَّ وهَبَتْ نَفْسَها لِلنَّبِيِّ﴾</span>: أنّ خولة بنت حكيم بن الأوقص كانت من اللاتي وهَبْنَ أنفُسَهُنَّ لرسول الله ﷺ{24}. (١٢/٨٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٢٤٩٥<span class="dash">-</span></span> عن <span class="name-2">عروة بن الزبير</span> -من طريق هشام بن عروة- قال: <span class="qpc-hafs">﴿وامْرَأَةً مُؤْمِنَةً إنَّ وهَبَتْ نَفْسَها لِلنَّبِيِّ﴾</span> كُنّا نتحدث: أنّ أم شَرِيك كانت فيمن وهبت نفسها للنبي ﷺ، وكانت امرأة صالحة{25}. (١٢/٨٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٢٤٩٦<span class="dash">-</span></span> قال <span class="name-2">مجاهد بن جبر</span>: <span class="qpc-hafs">﴿وامْرَأَةً مُؤْمِنَةً إنَّ وهَبَتْ نَفْسَها لِلنَّبِيِّ﴾</span> لم يكن عند النبي ﷺ امرأة وهبت نفسها منه، ولم يكن عنده امرأة إلا بعقد نكاح أو مِلك يمين، وإنما قال الله تعالى: <span class="qpc-hafs">﴿إنَّ وهَبَتْ﴾</span> على طريق الشرط والجزاء{26}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٢٤٩٧<span class="dash">-</span></span> قال <span class="name-2">الضحاك بن مزاحم</span>: <span class="qpc-hafs">﴿وامْرَأَةً مُؤْمِنَةً إنْ وهَبَتْ نَفْسَها لِلنَّبِيّ﴾</span> هي أم شَرِيك بنت جابر من بني أسْد{26}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٢٤٩٨<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span> -من طريق ابن جريج، عن أبي الزبير- في قوله: <span class="qpc-hafs">﴿وامْرَأَةً مُؤْمِنَةً﴾</span>، قال: نزلت في أم شَرِيك الدوسية{28}. (١٢/٨٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٢٤٩٩<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span> -من طريق ابن جريج، عن أبي الزبير- قال: <span class="qpc-hafs">﴿وامْرَأَةً مُؤْمِنَةً إنْ وهَبَتْ نَفْسَها لِلنَّبِيّ﴾</span> وهبت ميمونة بنت الحارث نفسها للنبي ﷺ{29}. (١٢/٨٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٢٥٠٠<span class="dash">-</span></span> عن <span class="name-2">عامر الشعبي</span> -من طريق عبد الله بن أبي السفر- <span class="qpc-hafs">﴿وامْرَأَةً مُؤْمِنَةً إنْ وهَبَتْ نَفْسَها لِلنَّبِيّ﴾</span>: أنها امرأة من الأنصار وهبت نفسها للنبي ﷺ، وهي مما أرْجى{30}. (١٢/٨٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٢٥٠١<span class="dash">-</span></span> عن <span class="name-2">عامر الشعبي</span> -من طريق فراس- قال: المرأة التي عزل رسولُ الله ﷺ أمَّ شَرِيك الأنصارية{31}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٢٥٠٢<span class="dash">-</span></span> قال <span class="name-2">عامر الشعبي</span>: <span class="qpc-hafs">﴿وامْرَأَةً مُؤْمِنَةً إنْ وهَبَتْ نَفْسَها لِلنَّبِيّ﴾</span> هي زينب بنت خزيمة الهلالية، يقال لها: أم المساكين{26}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٢٥٠٣<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span>: <span class="qpc-hafs">﴿وامْرَأَةً مُؤْمِنَةً إنْ وهَبَتْ نَفْسَها لِلنَّبِيّ﴾</span> أنّ النبي ﷺ قد تطوع على تلك المرأة التي وهبت نفسها له، فأعطاها الصداق{33}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٢٥٠٤<span class="dash">-</span></span> في تفسير <span class="name-2">الحسن البصري</span>: نزل أمرُ المرأة التي وهبت نفسها للنبي ﵇ قبل أن ينزل: <span class="qpc-hafs">﴿ما كانَ عَلى النبي مِن حَرَجٍ فِيما فَرَضَ اللَّهُ لَهُ﴾</span> [الأحزاب:٣٨]، وهي بعدها في التأليف{34}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٢٥٠٥<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- قال: يزعمون: أنها نزلت في ميمونة بنت الحارث، أنها هي التي وهبت نفسها للنبي ﷺ{35}. (١٢/٩٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٢٥٠٦<span class="dash">-</span></span> عن <span class="name-2">محمد بن كعب القرظي</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٢٥٠٧<span class="dash">-</span></span> و<span class="name-2">عمر بن الحكم</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٢٥٠٨<span class="dash">-</span></span> و<span class="name-2">عبد الله بن عبيدة</span> -من طريق موسى بن عُبيدة- قالوا: <span class="qpc-hafs">﴿وامْرَأَةً مُؤْمِنَةً إنْ وهَبَتْ نَفْسَها لِلنَّبِيّ﴾</span> التي وهبت نفسها للنبي ﷺ: ميمونة{36}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٢٥٠٩<span class="dash">-</span></span> عن <span class="name-2">منير بن عبد الله الدوسي</span>: أن أم شَرِيك غزية بنت جابر بن حكيم الدوسية عرضت نفسها على النبي ﷺ، وكانت جميلة، فقَبِلها، فقالت عائشة: ما في امرأة حين وهبت نفسها لرجل خير. قالت أم شَرِيك: فأنا تلك. فسماها الله تعالى: <span class="qpc-hafs">﴿مُؤْمِنَةً﴾</span>، فقال: <span class="qpc-hafs">﴿وامْرَأَةً مُؤْمِنَةً إنْ وهَبَتْ نَفْسَها لِلنَّبِيّ﴾</span>، فلما نزلت هذه الآية قالت عائشة: إنّ الله لَيُسرِع لكَ في هواك{37}. (١٢/٨٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٢٥١٠<span class="dash">-</span></span> عن [<span class="name-3">عبد الواحد</span>] <span class="name-3">بن أبي عون</span> -من طريق عبد الله بن جعفر- <span class="qpc-hafs">﴿وامْرَأَةً مُؤْمِنَةً إنْ وهَبَتْ نَفْسَها لِلنَّبِيّ﴾</span>: أن ليلى بنت الخطيم وهبت نفسها للنبي ﷺ، ووهبن نساءٌ أنفسَهن، فلم نسمع أنّ النبي ﷺ قَبِلَ منهنَّ أحدًا{38}. (١٢/٨٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٢٥١١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثم قال تعالى: <span class="qpc-hafs">﴿وامْرَأَةً مُؤْمِنَةً إنْ وهَبَتْ نَفْسَها لِلنَّبِيِّ إنْ أرادَ النبي أنْ يَسْتَنْكِحَها﴾</span>، وهي أم شَرِيك بنت جابر بن ضباب بن حجر من بني عامر بن لؤي، وكانت تحت أبي الفكر{39} الأزدي، وولدت له غلامين؛ شَريكًا ومُسلمًا، ويذكرون أنه نزل عليها دَلْوٌ مِن السماء، فشربت منه، ثم تُوفي عنها زوجها أبو الفكر، فوهبت نفسها للنبي ﷺ، فلم يقبلها{40}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿إِن وَهَبَتۡ نَفۡسَهَا لِلنَّبِیِّ﴾</span> - قراءات</h3></p><p><div></p><p><p><span class="item-no">٦٢٥١٢<span class="dash">-</span></span> في قراءة <span class="name-1">عبد الله [بن مسعود]</span>: (وامْرَأَةً مُّؤْمِنَةً وهَبَتْ نَفْسَها لِلنَّبِيِّ) بغير <span class="qpc-hafs">﴿إن﴾</span>{41}<span class=comment-ref>٥٢٥٥</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٥٢٥٥</span> <span class="comment-type-4">علَّقَ</span> <u>ابنُ جرير</u> (١٩/١٣٢) على هذه القراءة بقوله: «معنى ذلك ومعنى قراءتنا -وفيها <span class="qpc-hafs">﴿إن﴾</span>- واحد، وذلك <span class="mustanad">كقول القائل في الكلام</span>: لا بأس أن يطأ جاريةً مملوكةً إن ملكها، وجاريةً مملوكةً ملكها».</div></p><p><div></p><p><p><span class="item-no">٦٢٥١٣<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> أنه قرأ: (أن وهَبَتْ) بفتح الألف{42}<span class=comment-ref>٥٢٥٦</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٥٢٥٦</span> اخْتُلِف في قراءة قوله تعالى: <span class="qpc-hafs">﴿إن وهبت﴾</span> على وجهين: <b>الأول</b>: بكسرالهمزة، بمعنى: إن تَهَب، أي: إن وقَعَ فهو حلال له. و<b>الثاني</b>: بفتح الهمزة، هكذا (أن وهَبَتْ)، بمعنى: وأحللنا له امرأة مؤمنة أن ينكحها لهبتها له نفسها، فهي إشارة إلى ما وقَعَ مِن الواهبات قبل نزول الآية.</p><p>و<span class="comment-type-4">علَّقَ</span> <u>ابنُ عطية</u> (٧/١٣٢) على القراءتين بقوله: «كسر الألف يجري مع تأويل ابن زيد الذي قدمناه، وفتح الألف يجري مع التأويل الآخر».</p><p>و<span class="comment-type-3">رجَّحَ</span> <u>ابنُ جرير</u> (١٩/١٣٣) قراءة الكسر، فقال: «القراءة التي لا أستجيز خلافها في ذلك كسر الألف؛ <span class="mustanad">لإجماع الحجة من القراء عليه</span>».</div></p><p><h3><span class="qpc-hafs">﴿إِن وَهَبَتۡ نَفۡسَهَا لِلنَّبِیِّ﴾</span> - تفسير الآية</h3></p><p><div></p><p><p><span class="item-no">٦٢٥١٤<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿إنْ وهَبَتْ نَفْسَها لِلنَّبِيِّ﴾</span>، قال: فَعَلَتْ ولم يفعل{43}. (١٢/٩٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٢٥١٥<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿إنْ وهَبَتْ نَفْسَها لِلنَّبِيّ﴾</span>، قال: بغير صداق، أُحِلّ له ذلك، ولم يكن ذلك أُحِلَّ إلا له{44}. (١٢/٨٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٢٥١٦<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق الحكم- أنّه قال في هذه الآية: <span class="qpc-hafs">﴿وامْرَأَةً مُؤْمِنَةً إنْ وهَبَتْ نَفْسَها لِلنَّبِيّ﴾</span>، قال: أن تهب{20}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٢٥١٧<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق الحكم- <span class="qpc-hafs">﴿وامْرَأَةً مُؤْمِنَةً إنْ وهَبَتْ نَفْسَها لِلنَّبِيِّ﴾</span>، قال: لَم تهب نفسها{46}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٢٥١٨<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن جريح-: إن وهبت نفسها بغير صداق مِمّا يَحِلُّ له ذلك خاصَّة دون كل أحد من المؤمنين{47}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٢٥١٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثم قال تعالى: <span class="qpc-hafs">﴿وامْرَأَةً مُؤْمِنَةً إنْ وهَبَتْ نَفْسَها لِلنَّبِيِّ﴾</span>، يعني: أن يتزوجها بغير مهر، وهي أم شَرِيك بنت جاب ر... وهبت نفسها للنبي ﷺ، فلم يقبلها، ولو فعله لكان له خاصة دون المؤمنين، فإن وهبت امرأةٌ يهوديةٌ أو نصرانيةٌ أو أعرابيةٌ نفسها فإنه لا يحلُّ للنبي ﷺ أن يتزوجها{48}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٢٥٢٠<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: قوله ﷿: <span class="qpc-hafs">﴿وامْرَأَةً مُؤْمِنَةً إنْ وهَبَتْ نَفْسَها لِلنَّبِيِّ إنْ أرادَ النبي أنْ يَسْتَنْكِحَها خالِصَةً لَكَ﴾</span> يقول: للنبي ﷺ <span class="qpc-hafs">﴿مِن دُونِ المُؤْمِنِينَ﴾</span> مقرأ العامة على (أنْ وهَبَتْ نَفْسَها لِلنَّبِيِّ) يقولون: كانت امرأة واحدة، و(أن) مفتوحة لما قد كان، وبعضهم يقرأها: <span class="qpc-hafs">﴿إنْ وهَبَتْ نَفْسَها﴾</span> يقولون: في المستقبل؛ على تلك الوجوه من قول أُبي، وقول الحسن، وقول مجاهد{49}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿خَالِصَةࣰ لَّكَ مِن دُونِ ٱلۡمُؤۡمِنِینَۗ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٢٥٢١<span class="dash">-</span></span> عن <span class="name-1">أنس بن مالك</span> -من طريق أبان- قال: <span class="qpc-hafs">﴿خالِصَةً لَكَ مِن دُونِ المُؤْمِنِينَ﴾</span> لم تَحِلَّ الهِبَةُ لأحد بعد رسول الله ﷺ{50}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٢٥٢٢<span class="dash">-</span></span> عن <span class="name-2">سعيد بن</span> <span class="name-2">المسيب</span> -من طريق يزيد بن عبد الله بن قسيط- قال: <span class="qpc-hafs">﴿خالِصَةً لَكَ مِن دُونِ المُؤْمِنِينَ﴾</span>، لا تحل الهبة لأحد بعد رسول الله ﷺ، ولو أصدقها سوطًا لحلَّت له{51}. (١٢/٨٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٢٥٢٣<span class="dash">-</span></span> عن <span class="name-2">إبراهيم النخعي</span> -من طريق عبد الكريم-= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٢٥٢٤<span class="dash">-</span></span> و<span class="name-2">محمد بن شهاب الزهري</span> -من طريق معمر- في قوله: <span class="qpc-hafs">﴿خالِصَةً لَكَ مِن دُونِ المُؤْمِنِينَ﴾</span>، قالا: لا تحل الهبة لأحد بعد رسول الله ﷺ{52}. (١٢/٨٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٢٥٢٥<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿خالِصَةً لَكَ مِن دُونِ المُؤْمِنِينَ﴾</span>، قال: أحل له ذلك خاصة دون المؤمنين{53}. (١٢/٨٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٢٥٢٦<span class="dash">-</span></span> عن صالح بن مسلم، قال: سألتُ <span class="name-2">الشعبيَّ</span> عن امرأة وهبت نفسها لرجل. قال: لا يكون، لا تَحِلُّ له، إنما كانت للنبي ﷺ{54}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٢٥٢٧<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span>، في قوله: <span class="qpc-hafs">﴿خالِصَةً لَكَ مِن دُونِ المُؤْمِنِينَ﴾</span>، قال: لا تحل الموهوبة لغيرك، ولو أنّ امرأة وهبت نفسها لرجل لم تَحِلَّ له حتى يعطيها شيئًا{55}. (١٢/٩٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٢٥٢٨<span class="dash">-</span></span> عن <span class="name-2">طاووس بن كيسان</span> -من طريق ابن طاووس- قال: <span class="qpc-hafs">﴿خالِصَةً لَكَ مِن دُونِ المُؤْمِنِينَ﴾</span>، لا يحل لأحد أن يهب ابنته بغير مهر إلا للنبي ﷺ{56}. (١٢/٨٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٢٥٢٩<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق سليمان بن أرقم- <span class="qpc-hafs">﴿خالِصَةً لَكَ مِن دُونِ المُؤْمِنِينَ﴾</span>: لا تكون الهبة بغير صداق إلا للنبي ﷺ{50}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٢٥٣٠<span class="dash">-</span></span> عن <span class="name-2">عطاء [بن أبي رباح]</span> -من طريق عبد الملك- <span class="qpc-hafs">﴿خالِصَةً لَكَ مِن دُونِ المُؤْمِنِينَ﴾</span>، قال في امرأة وهبت نفسها لرجل، قال: لا يصلح إلا بصداق، لم يكن ذلك إلا للنبي ﷺ{58}. (١٢/٨٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٢٥٣١<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿خالِصَةً لَكَ مِن دُونِ المُؤْمِنِينَ﴾</span>، يقول: ليس لامرأة أن تهب نفسها لرجل بغير أمر ولِيٍّ ولا مهر، إلا للنبي ﷺ؛ كانت خاصة له من دون الناس{59}. (١٢/٩٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٢٥٣٢<span class="dash">-</span></span> عن <span class="name-2">مكحول</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٢٥٣٣<span class="dash">-</span></span> و<span class="name-2">محمد بن شهاب الزهري</span> -من طريق عبد الله بن عبيد- قالا: <span class="qpc-hafs">﴿خالِصَةً لَكَ مِن دُونِ المُؤْمِنِينَ﴾</span> لم تحل الموهوبة لأحد بعد رسول الله ﷺ{60}. (١٢/٨٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٢٥٣٤<span class="dash">-</span></span> عن <span class="name-2">محمد ابن شهاب الزهري</span> -من طريق معمر- قال: <span class="qpc-hafs">﴿خالِصَةً لَكَ مِن دُونِ المُؤْمِنِينَ﴾</span> لا يحل لرجل أن يهب ابنته بغير صداق، قد جعل الله ذلك للنبي ﷺ خاصة دون المؤمنين{61}. (١٢/٨٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٢٥٣٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿خالِصَةً لَكَ﴾</span> الهبة، يعني: خاصة لك، يا محمد، <span class="qpc-hafs">﴿مِن دُونِ المُؤْمِنِينَ﴾</span> لا تحل هبة المرأة نفسَها بغير مهرٍ لغيرك مِن المؤمنين، وكانت أم شَرِيك قبل أن تهب نفسها للنبي ﷺ امرأة أبي الفكر الأزدي ثم الدوسي، مِن رهط أبي هريرة{48}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٢٥٣٦<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: قوله ﷿: <span class="qpc-hafs">﴿خالِصَةً لَكَ مِن دُونِ المُؤْمِنِينَ﴾</span> لا تكون الهبة بغير صداق إلا للنبي ﷺ{63}<span class=comment-ref>٥٢٥٧</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٥٢٥٧</span> <span class="comment-type-4">قال</span> <u>ابنُ عطية</u> (٧/١٣٣ بتصرف): «<span class="mustanad">أجمع الناسُ</span> على أن ذلك لا يجوز، إلا ما روي عن أبي حنيفة ومحمد بن الحسن وأبي يوسف أنهم قالوا: إذا وهبت فأشهد هو على نفسه بمهر فذلك جائز. فليس في قولهم إلا تجويز العبارة بلفظة الهبة، وإلا فالأفعال التي اشترطوها هي أفعال النكاح بعينه».</p><p>و<span class="comment-type-4">قال</span> <u>ابنُ تيمية</u> (٥/٢٥٣): «ليس هذا لغيره <span class="mustanad">باتفاق المسلمين</span>».</div></p><p><h3><span class="qpc-hafs">﴿خَالِصَةࣰ لَّكَ مِن دُونِ ٱلۡمُؤۡمِنِینَۗ﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٦٢٥٣٧<span class="dash">-</span></span> عن الحسن البصري: أنّ النبيَّ ﷺ قد تطوع على تلك المرأة التي وهبت نفسها له، فأعطاها الصداق{64}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿قَدۡ عَلِمۡنَا مَا فَرَضۡنَا عَلَیۡهِمۡ فِیۤ أَزۡوَ ٰ⁠جِهِمۡ وَمَا مَلَكَتۡ أَیۡمَـٰنُهُمۡ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٢٥٣٨<span class="dash">-</span></span> عن <span class="name-1">أُبَي بن كعب</span> -من طريق زياد؛ رجل مِن الأنصار-: أنّ التي أحل الله للنبي من النساء هؤلاء اللاتي ذَكر الله: <span class="qpc-hafs">﴿يا أيُّها النبي إنّا أحْلَلْنا لَكَ أزْواجَكَ اللّاتِي آتَيْتَ أُجُورَهُن﴾</span> إلى قوله: <span class="qpc-hafs">﴿فِي أزْواجِهِمْ﴾</span>، وإنما أحل الله للمؤمنين مثنى وثلاث ورباع{65}<span class=comment-ref>٥٢٥٨</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٥٢٥٨</span> <span class="comment-type-4">قال</span> <u>ابنُ عطية</u> (٧/١٣٣): «يظهر من لفظ أبي بن كعب أن معنى قوله: <span class="qpc-hafs">﴿خالصة لك﴾</span> يراد به جميع الإباحة؛ لأن المؤمنين قُصِروا على مثنى وثلاث ورباع».</div></p><p><div></p><p><p><span class="item-no">٦٢٥٣٩<span class="dash">-</span></span> عن <span class="name-1">أُبَي بن كعب</span> -من طريق موسى بن عبد الله-: <span class="qpc-hafs">﴿قَدْ عَلِمْنا ما فَرَضْنا عَلَيْهِمْ فِي أزْواجِهِمْ﴾</span> يعني: الأربع، يقول: يتزوَّج أربعًا إن شاء، <span class="qpc-hafs">﴿وما مَلَكَتْ أيْمانُهُمْ﴾</span> ويطأ بملك يمينه كم شاء{66}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٢٥٤٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، في قوله: <span class="qpc-hafs">﴿قَدْ عَلِمْنا ما فَرَضْنا عَلَيْهِمْ فِي أزْواجِهِمْ﴾</span>، قال: فرض عليهم ألّا نكاح إلا بوَلِيٍّ، وشاهدين، ومهر{67}. (١٢/٩١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٢٥٤١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عمر</span> -من طريق نافع- في قوله: <span class="qpc-hafs">﴿قَدْ عَلِمْنا ما فَرَضْنا عَلَيْهِمْ فِي أزْواجِهِمْ﴾</span>، قال: فَرَض عليهم ألاَّ نكاح إلا بوَلِيٍّ وشاهدين{68}. (١٢/٩١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٢٥٤٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عمر</span>، في قوله: <span class="qpc-hafs">﴿قَدْ عَلِمْنا ما فَرَضْنا عَلَيْهِمْ فِي أزْواجِهِمْ﴾</span>، قال: لا يجاوز الرجلُ أربعَ نسوة{69}. (١٢/٩١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٢٥٤٣<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ليث- في قوله: <span class="qpc-hafs">﴿قَدْ عَلِمْنا ما فَرَضْنا عَلَيْهِمْ فِي أزْواجِهِمْ﴾</span>، قال: لا يُجاوِز الرجلُ أربعَ نسوة{70}. (١٢/٩١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٢٥٤٤<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿قَدْ عَلِمْنا ما فَرَضْنا عَلَيْهِمْ﴾</span>، قال: فرض اللهُ أن لا تُنكَح امرأةٌ إلا بولي وصداق وشهداء، ولا ينكِح الرجلُ إلا أربعًا{71}. (١٢/٩٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٢٥٤٥<span class="dash">-</span></span> قال <span class="name-2">إسماعيل السُّدِّيّ</span>: <span class="qpc-hafs">﴿قَدْ عَلِمْنا ما فَرَضْنا عَلَيْهِمْ فِي أزْواجِهِم﴾</span>، يعني: ما أوجبنا عليهم{33}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٢٥٤٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثم أخبر الله عن المؤمنين، فقال: <span class="qpc-hafs">﴿قَدْ عَلِمْنا ما فَرَضْنا عَلَيْهِمْ﴾</span> يعني: ما أوجبنا على المؤمنين <span class="qpc-hafs">﴿فِي أزْواجِهِمْ﴾</span> ألّا يتزوجوا إلّا أربع نسوة بمهر وبيِّنة، <span class="qpc-hafs">﴿وما مَلَكَتْ أيْمانُهُمْ﴾</span> وأحللنا لهم ما ملكت أيمانهم، يعني: جِماع الولاية{73}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٢٥٤٧<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿قَدْ عَلِمْنا ما فَرَضْنا عَلَيْهِمْ فِي أزْواجِهِمْ﴾</span> فإن تزوج الرجلُ امرأةً ولم يُسمِّ لها صداقًا أو وهبها له الولي فرضيتْ، أو كانت بِكْرًا فزوَّجها أبوها، فإن ذلك جائز عليها، فلها ما اتفقوا عليه من الصداق، فإن اختلفوا فلها صداق مثلها، والنكاح ثابت{74}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿لِكَیۡلَا یَكُونَ عَلَیۡكَ حَرَجࣱۗ وَكَانَ ٱللَّهُ غَفُورࣰا رَّحِیمࣰا ۝٥٠﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٢٥٤٨<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span>، في قوله: <span class="qpc-hafs">﴿لِكَيْلا يَكُونَ عَلَيْكَ حَرَجٌ﴾</span>، قال: جعله الله في حِلٍّ مِن ذلك، وكان نبيُّ الله ﷺ يَقْسِم{12}. (١٢/٩١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٢٥٤٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿لِكَيْلا يَكُونَ عَلَيْكَ﴾</span> يا محمد <span class="qpc-hafs">﴿حَرَجٌ﴾</span> في الهبة بغير مهر، فيها تقديم، <span class="qpc-hafs">﴿وكانَ اللَّهُ غَفُورًا﴾</span> في التزويج بغير مهر للنبي ﷺ، <span class="qpc-hafs">﴿رحيمًا﴾</span> في تحليل ذلك له{73}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٢٥٥٠<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: قوله ﷿: <span class="qpc-hafs">﴿لِكَيْلا يَكُونَ عَلَيْكَ حَرَجٌ﴾</span> رجع إلى قصة النبي ﷺ{77}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ١٩/١٣٠، وإسحاق البستي ص١٣٤.</p><p>وهي قراءة شاذة. انظر: معاني القرآن للفراء ٢/٣٤٥، والمحرر الوجيز ٤/٣٩١.أخرجه ابن عدي في الكامل ٢/٧٠، من طريق أحمد بن أبي طيبة، عن عنبسة بن الأزهر، عن إسماعيل بن أبي خالد، عن أبي صالح، عن أم هانئ به. وعزاه السيوطي إلى ابن أبي حاتم، وابن مردويه.</p><p>إسناده ضعيف؛ فيه باذام، ويقال: باذان، أبو صالح مولى أم هانئ، قال عنه ابن حجر في التقريب (٦٣٤): «ضعيف مدلّس».أخرجه الترمذي ٥/٤٢٧ (٣٤٩٣)، والحاكم ٢/٢٠٢ (٢٧٥٤)، ٢/٤٥٦ (٣٥٧٤)، ٤/٥٨ (٦٨٧٢)، وابن جرير ١٩/١٣٠-١٣١، وابن أبي حاتم -كما في تفسير ابن كثير ٦/٤٤٢-.</p><p>قال الترمذي: «هذا حديث حسن، لا نعرفه إلا من هذا الوجه من حديث السدي». وقال الحاكم: «هذا حديث صحيح الإسناد، ولم يخرجاه».مُوتِـمــــَة: رُزئت بمصيبة فقْد زوجها. اللسان (أتم).أخرجه ابن سعد ٨/١٥٣.أخرجه يحيى بن سلّام ٢/٧٢٨.أخرجه ابن جرير ١٩/١٣٤. وعزاه السيوطي إلى ابن مردويه.أخرجه ابن سعد في الطبقات ١٠/١٨٧.تفسير مجاهد (٥٥٠) مقتصرًا على الشطر الأول، وأخرجه ابن جرير ١٩/١٢٩-١٣٠. وعزاه السيوطي إلى الفريابي، وعبد بن حميد، وابن المنذر، وابن أبي حاتم.أخرجه ابن جرير ١٩/١٣٠، وإسحاق البستي ص١٣٠.أخرجه إسحاق البستي ص١٣٠، وابن جرير ١٩/١٣٠ مختصرًا.عزاه السيوطي إلى ابن المنذر.تفسير مقاتل بن سليمان ٣/٥٠٠.أخرجه ابن جرير ١٩/١٣٠.تفسير يحيى بن سلّام ٢/٧٢٨.أخرجه ابن أبي حاتم -كما في تفسير ابن كثير ٦/٤٤٤ (ت: سامي السلامة)-. وعزاه السيوطي إلى ابن أبي شيبة.أخرجه إسحاق البستي ص١٣١.</p><p>وهي قراءة شاذة. انظر: مختصر ابن خالويه ص١٢١.أخرجه ابن أبي حاتم -كما في تفسير ابن كثير ٦/٤٣٥-، وابن مردويه -كما في التغليق ٤/٤١١-، والبيهقي في سننه ٧/٥٥.أخرجه ابن جرير ١٩/١٣٤، وابن أبي حاتم -كما في تفسير ابن كثير ٦/٤٣٦-، والطبراني (١١٧٨٧)، والبيهقي في سننه ٧/٥٥. وعزاه السيوطي إلى ابن مردويه.أخرجه ابن جرير ١٩/١٣٥.أخرجه البخاري ٣/١٠٠-١٠١ (٢٣١٠)، ٦/١٩٢-١٩٣ (٥٠٢٩، ٥٠٣٠)، ٧/٦-٧ (٥٠٨٧)، ٧/١٣ (٥١٢١)، ٧/١٤-١٥ (٥١٢٦)، ٧/١٧ (٥١٣٢، ٥١٣٥)، ٧/١٨-١٩ (٥١٤١)، ٧/٢٠ (٥١٤٩، ٥١٥٠)، ٧/١٥٦-١٥٧ (٥٨٧١)، ٩/١٢٤ (٧٤١٧)، ومسلم ٢/١٠٤٠ (١٤٢٥).أخرجه البخاري (٥١٢٠، ٦١٢٣). وعزاه السيوطي إلى ابن مردويه.أخرجه ابن سعد ٨/١٥٥، وابن أبي شيبة ٤/٣١٥، وابن جرير ١٩/١٣٥، والطبراني ٢٤/٣٥١ (٨٧٠) واللفظ له. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه عبد الرزاق (١٢٢٦٨، ١٢٢٦٩)، وابن سعد ٨/١٥٨، وابن أبي شيبة ٤/٣١٥، والبخاري (٥١١٣)، وابن جرير ١٩/١٣٦ بنحوه. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم، وابن مردويه.أخرجه ابن أبي شيبة ٤/٣١٥، وابن جرير ١٩/١٣٦. وعزاه السيوطي إلى عبد بن حميد، وابن أبي حاتم، وابن مردويه.تفسير الثعلبي ٨/٥٤، وتفسير البغوي ٦/٣٦٤.تفسير الثعلبي ٨/٥٤، وتفسير البغوي ٦/٣٦٤.أخرجه ابن سعد ٨/١٥٥.أخرجه عبد الرزاق (١٢٢٦٦)، وابن سعد ٨/١٣٧. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه ابن أبي شيبة ٤/٣١٦، وابن جرير ١٩/١٣٦.أخرجه ابن سعد ٨/١٥٥، وأخرجه ابن أبي حاتم -كما في الفتح ٨/٥٢٥- بلفظ: من الواهبات أم شَرِيك.تفسير الثعلبي ٨/٥٤، وتفسير البغوي ٦/٣٦٤.علقه يحيى بن سلّام ٢/٧٣٠.علّقه يحيى بن سلّام ٢/٧٣٠.أخرجه ابن جرير ١٩/١٣٢. وعزاه السيوطي إلى عبد بن حميد، وابن أبي حاتم. وفي تفسير الثعلبي ٨/٥٤، وتفسير البغوي ٦/٣٦٤ بلفظ: هي ميمونة بنت الحارث.أخرجه ابن أبي شيبة في مصنفه (ت: محمد عوامة) ٩/٣٤٤-٣٤٥ (١٧٤٦١).أخرجه ابن سعد ٨/١٥٥-١٥٦ مطولًا.أخرجه ابن سعد ٨/١٥١.كذا بالفاء، وعند ابن سعد بالعين ٨/١٥٥-١٥٦، وينظر: الإصابة ٣/٣٤٨. وقد ذكر ابن سعد قصتها مطولة من رواية منير بن عبد الله الدوسي، وتقدم مختصرها في الأثر السابق، وفيه أنها أزدية.تفسير مقاتل بن سليمان ٣/٥٠١. وفي تفسير الثعلبي ٨/٥٤، وتفسير البغوي ٦/٣٦٤ عن مقاتل -دون تعيينه- قال: هي أم شَرِيك بنت جابر من بني أسد.تفسير ابن جرير ١٩/١٣٢.تفسير ابن جرير ١٩/١٣٣.أخرجه ابن أبي شيبة ٤/٣١٦ واللفظ له. وعزاه السيوطي إلى ابن جرير، وابن المنذر.تفسير مجاهد (٥٥٠)، وأخرجه ابن جرير ١٩/١٣٢. وعزاه السيوطي إلى الفريابي، وعبد بن حميد، وابن أبي حاتم.أخرجه ابن جرير ١٩/١٣٥.أخرجه ابن أبي شيبة في مصنفه (ت: محمد عوامة) ١٩/٣٤٢-٣٤٣ (١٧٤٥٧)، وإسحاق البستي ص١٣٠.أخرجه إسحاق البستي ص١٣٠.تفسير مقاتل بن سليمان ٣/٥٠١.تفسير يحيى بن سلّام ٢/٧٢٩.أخرجه يحيى بن سلّام ٢/٧٣٠.أخرجه يحيى بن سلّام ٢/٧٢٠، وعبد الرزاق (١٢٢٧٢)، والبيهقي ٧/٥٥. وعزاه السيوطي إلى سعيد بن منصور، وابن أبي شيبة، وعبد بن حميد، وابن المنذر.أخرجه عبد الرزاق في مصنفه ٧/٧٦ (١٢٢٧٠) عن الزهري وحده، وابن سعد ٨/٢٠١ عن الزهري وإبراهيم. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.تفسير مجاهد (٥٥٠)، وأخرجه ابن جرير ١٩/١٣٢. وعزا السيوطيُّ نحوه إلى الفريابي، وعبد بن حميد، وابن أبي حاتم.أخرجه ابن جرير ١٩/١٣٣.عزاه السيوطي إلى عبد بن حميد، وابن أبي حاتم.أخرجه ابن أبي شيبة ٤/٣٤٢-٣٤٣.أخرجه يحيى بن سلّام ٢/٧٣٠.أخرجه عبد الرزاق (١٢٢٦٥) بنحوه، وابن أبي شيبة ٤/٣٤٣. وعزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ١٩/١٣٢. وعزاه السيوطي إلى عبد بن حميد، وابن أبي حاتم.أخرجه ابن أبي شيبة ٤/٣٤٣.أخرجه عبد الرزاق ٢/١١٩ بنحوه. وعزاه السيوطي إلى عبد بن حميد.تفسير مقاتل بن سليمان ٣/٥٠١.تفسير يحيى بن سلّام ٢/٧٢٩-٧٣٠.علَّقه يحيى بن سلّام ٢/٧٢٣، ٧٣٠.أخرجه ابن جرير ١٩/١٣٤.أخرجه يحيى بن سلّام ٢/٧٣١.أخرجه ابن مردويه -كما في فتح الباري ٨/٥٢٦-.أخرجه ابن مردويه -كما في فتح الباري ٨/٥٢٦-، وابن عدي في الكامل ٩/١٥ بزيادة قوله: وصدقة.عزاه السيوطي إلى ابن مردويه.أخرجه ابن جرير ١٩/١٣٧ بنحوه. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.أخرجه يحيى بن سلّام ٢/٧٣١ بنحوه، وعبد الرزاق ٢/١١٩-١٢٠ من طريق معمر، وابن جرير ١٩/١٣٧. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم. وأخرج ابن جرير عنه ١٩/١٣٧ من طريق مطر بلفظ: إن مما فرض الله عليهم أن لا نكاح إلا بولي وشاهدين.علقه يحيى بن سلّام ٢/٧٣٠.تفسير مقاتل بن سليمان ٣/٥٠٢.تفسير يحيى بن سلّام ٢/٧٣١.</p><p><b>وقد أورد السيوطي عقب تفسير هذه الآية ١٢/٩١-٩٣ آثارًا عديدة عن حرمة وطء الحبالى مِن السبايا حتى يضعن.</b>عزاه السيوطي إلى ابن المنذر.تفسير مقاتل بن سليمان ٣/٥٠٢.تفسير يحيى بن سلّام ٢/٧٣١.