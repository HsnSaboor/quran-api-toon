quran[7]{c,v,t}:
33,44," <q>﴿تَحِیَّتُهُمۡ یَوۡمَ یَلۡقَوۡنَهُۥ سَلَـٰمࣱۚ﴾</q> - تفسير ٦٢٤٠٦- عن عبد الله بن مسعود، قال: <q>﴿تَحِيَّتُهُمْ يَوْمَ يَلْقَوْنَهُ سَلامٌ﴾</q> إذا جاء ملك الموت ليقبض روح المؤمن قال: ربك يقرئك السلام{1}٥٢٤٥. (١٢/٧٥) ٥٢٤٥ قال ابنُ كثير (١١/١٨٤) مستندًا إلى النظائر: «الظاهر أن المراد -والله أعلم- <q>﴿تحيتهم﴾</q> أي: مِن الله تعالى <q>﴿يوم يلقونه سلام﴾</q> أي: يوم يسلم عليهم، كما قال تعالى: <q>﴿سَلامٌ قَوْلًا مِن رَبٍّ رَحِيمٍ﴾</q> [يس:٥٨]». ٦٢٤٠٧- عن البراء بن عازب -من طريق محمد بن مالك- في قوله: <q>﴿تَحِيَّتُهُمْ يَوْمَ يَلْقَوْنَهُ سَلامٌ﴾</q>، قال: يوم يلقون مَلَك الموت، ليس مِن مؤمن يقبض روحه إلا سلَّم عليه{2}. (١٢/٧٤) ٦٢٤٠٨- قال الحسن البصري: <q>﴿تَحِيَّتُهُمْ يَوْمَ يَلْقَوْنَهُ سَلامٌ﴾</q> تُحييهم الملائكةُ عن الله بالسلام{3}. (ز) ٦٢٤٠٩- عن قتادة بن دعامة -من طريق معمر- في قوله: <q>﴿تَحِيَّتُهُمْ يَوْمَ يَلْقَوْنَهُ سَلامٌ﴾</q>، قال: تحية أهل الجنة السلام{4}٥٢٤٦. (١٢/٧٤) ٥٢٤٦ ذَهَبَ ابنُ جرير (١٩/١٢٥) إلى ما ذهب إليه قتادة، مِن أنّ المراد: يُحَيِّي أهلُ الجنة بعضهم بعضًا. وعلَّقَ ابنُ كثير (١١/١٨٤) على هذا القول بقوله: «قد يستدل له بقوله تعالى: <q>﴿دَعْواهُمْ فِيها سُبْحانَكَ اللَّهُمَّ وتَحِيَّتُهُمْ فِيها سَلامٌ وآخِرُ دَعْواهُمْ أنِ الحَمْدُ لِلَّهِ رَبِّ العالَمِينَ﴾</q> [يونس:١٠]». ٦٢٤١٠- عن أبي حمزة الثمالي -من طريق علي بن علي- في قوله: <q>﴿تَحِيَّتُهُمْ يَوْمَ يَلْقَوْنَهُ سَلامٌ﴾</q>، قال: تسلِّم عليهم الملائكة يوم القيامة، وتُبَشِّرهم حين يخرجون من قبورهم{5}. (ز) ٦٢٤١١- قال مقاتل بن سليمان: <q>﴿تَحِيَّتُهُمْ يَوْمَ يَلْقَوْنَهُ﴾</q> يعني: يوم يلقون الرب ﷿ في الآخرة، <q>﴿سلام﴾</q> يعني: تسليم الملائكة عليهم{6}. (ز) <q>﴿وَأَعَدَّ لَهُمۡ أَجۡرࣰا كَرِیمࣰا ۝٤٤﴾</q> - تفسير ٦٢٤١٢- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿وأَعَدَّ لَهُمْ أجْرًا كَرِيمًا﴾</q>، قال: الجنة{7}. (١٢/٧٤) ٦٢٤١٣- قال مقاتل بن سليمان: <q>﴿وأَعَدَّ لَهُمْ أجْرًا كَرِيمًا﴾</q>، يعني: أجرًا حسنًا في الجنة{6}. (ز) ٦٢٤١٤- قال يحيى بن سلّام: <q>﴿وأَعَدَّ لَهُمْ أجْرًا﴾</q> ثوابًا <q>﴿كَرِيمًا﴾</q> الجنة{9}. (ز) ",footnotes:1:عزاه السيوطي إلى المروزي في الجنائز، وابن أبي الدنيا، وأبي الشيخ.أخرجه ابن أبي شيبة في مصنفه (ت: محمد عوامة) ١٩/٢٣٩ (٣٥٩١٢)، وأبو يعلى -كما في المطالب العالية (٤٠٦٥)-، وابن جرير ١٤/٢١٤، والحاكم ٢/٣٥١، والبيهقي في شعب الإيمان (٤٠٣). وعزاه السيوطي إلى ابن أبي الدنيا في ذكر الموت، وعبد بن حميد، وابن المنذر، وابن أبي حاتم، وابن مردويه.علقه يحيى بن سلّام ٢/٧٢٥.أخرجه عبد الرزاق ٢/١١٩، وابن جرير ١٩/١٢٥ من طريق سعيد. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.أخرجه الثعلبي ٨/٥٢.تفسير مقاتل بن سليمان ٣/٤٩٩.أخرجه ابن جرير ١٩/١٢٥. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.تفسير مقاتل بن سليمان ٣/٤٩٩.تفسير يحيى بن سلّام ٢/٧٢٥.
33,45," <q>﴿یَـٰۤأَیُّهَا ٱلنَّبِیُّ إِنَّاۤ أَرۡسَلۡنَـٰكَ شَـٰهِدࣰا وَمُبَشِّرࣰا وَنَذِیرࣰا ۝٤٥﴾</q> - نزول الآية ٦٢٤١٥- عن عبد الله بن عباس، قال: لما نزلت: <q>﴿يا أيُّها النبي إنّا أرْسَلْناكَ شاهِدًا ومُبَشِّرًا ونَذِيرًا﴾</q> وقد كان أمَر عليًّا ومعاذًا أن يسيرا إلى اليمن، فقال: «انطلِقا، فبشِّرا ولا تنفِّرا، ويسِّرا ولا تعسِّرا، فإنه قد أنزلت عَلَيَّ: <q>﴿يا أيُّها النبي إنّا أرْسَلْناكَ شاهِدًا ومُبَشِّرًا ونَذِيرًا﴾</q>»{1}. (١٢/٧٥) <q>﴿یَـٰۤأَیُّهَا ٱلنَّبِیُّ إِنَّاۤ أَرۡسَلۡنَـٰكَ شَـٰهِدࣰا وَمُبَشِّرࣰا وَنَذِیرࣰا ۝٤٥﴾</q> - تفسير الآية ٦٢٤١٦- عن العرباض بن سارية: سمعتُ رسول الله ﷺ يقول: «إنِّي عبدُ الله وخاتمُ النبيين وأبي مُنجَدِلٌ{2} في طِينَتِه، وسأخبركم عن ذلك، أنا دعوة أبي إبراهيم، وبشارة عيسى، ورؤيا أمي التي رأت، وكذلك أمهات النبيين يَرَيْن». وإنّ أم رسول الله ﷺ رأت حين وضعته نورًا أضاءت لها قصور الشام. ثم تلا: <q>﴿يا أيُّها النبي إنّا أرْسَلْناكَ شاهِدًا ومُبَشِّرًا ونَذِيرًا﴾</q> إلى قوله: <q>﴿مُنِيرًا﴾</q>{3}. (١٢/٧٦) ٦٢٤١٧- عن عبد الله بن عباس -من طريق عكرمة- <q>﴿يا أيُّها النبي إنّا أرْسَلْناكَ شاهِدًا ومُبَشِّرًا ونَذِيرًا﴾</q>، قال: شاهدًا على أمتك، ومُبَشِّرًا بالجنة، ونذيرًا مِن النار{4}. (١٢/٧٥) ٦٢٤١٨- عن الحسن البصري: <q>﴿ونَذِيرًا﴾</q> مِن عذاب الدنيا وعذاب الآخرة{5}. (ز) ٦٢٤١٩- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿يا أيُّها النبي إنّا أرْسَلْناكَ شاهِدًا﴾</q> قال: على أمتك بالبلاغ، <q>﴿ومُبَشِّرًا﴾</q> بالجنة، <q>﴿ونَذِيرًا﴾</q> مِن النار{6}. (١٢/٧٧) ٦٢٤٢٠- قال مقاتل بن سليمان: <q>﴿يا أيُّها النبي إنّا أرْسَلْناكَ شاهِدًا﴾</q> على هذه الأمة بتبليغ الرسالة، <q>﴿ومُبَشِّرًا ونَذِيرًا﴾</q> ومبشِّرًا بالجنة والنصر في الدنيا على من خالفهم، ونذيرًا مِن النار{7}. (ز) ٦٢٤٢١- قال يحيى بن سلّام: <q>﴿يا أيُّها النبي إنّا أرْسَلْناكَ شاهِدًا﴾</q> على أمتك، تشهد عليهم في الآخرة أنّك قد بلَّغْتَهم، <q>﴿ومُبَشِّرًا﴾</q> في الدنيا بالجنة، <q>﴿ونَذِيرًا﴾</q> مِن النار{8}. (ز) <q>﴿یَـٰۤأَیُّهَا ٱلنَّبِیُّ إِنَّاۤ أَرۡسَلۡنَـٰكَ شَـٰهِدࣰا وَمُبَشِّرࣰا وَنَذِیرࣰا ۝٤٥﴾</q> - آثار متعلقة بالآية ٦٢٤٢٢- عن عبد الله بن عباس، قال: اجتمع عُتبةُ وشَيبةُ وأبو جهل وغيرهم، فقالوا: أسقِط السماء علينا كسفًا، أو ائتنا بعذاب أليم، أو أمطِر علينا حجارةً مِن السماء. فقال رسول الله ﷺ:«ما ذاك إلَيَّ، إنّما بُعِثْتُ إليكم داعيًا ومُبَشِّرًا ونذيرًا»{9}. (١٢/٧٧) ٦٢٤٢٣- عن عطاء بن يسار، قال: لقيت عبد الله بن عمرو بن العاص، فقلت: أخبِرني عن صفة رسول الله ﷺ في التوراة. قال: أجل، واللهِ، إنّه لموصوف في التوراة ببعض صفته في القرآن: <q>﴿يا أيها النبي إنا أرسلناك شاهدا ومبشرا ونذيرا﴾</q> وحرزًا للأميين، أنت عبدي ورسولي، سميَّتك المتوكل، ليس بفظٍّ ولا غليظ، ولا سخّاب{10} في الأسواق، ولا يجزى بالسيئة السيئة، ولكن يعفو ويصفح{11}. (١٢/٧٥) ",footnotes:1:أخرجه الطبراني في الكبير ١١/٣١٢ (١١٨٤١)، والخطيب في تاريخه ٤/٥١٣ (١١٢٢) في ترجمة محمد بن نصر بن حميد بن الوازع البزاز (١٦٨٥)، وابن أبي حاتم -كما في تفسير ابن كثير ٦/٤٣٨-٤٣٩-. قال الهيثمي في المجمع ٧/٩٢ (١١٢٧٧): «رواه الطبراني، وفيه عبدالرحمن بن محمد بن عبدالله العرزمي، وهو ضعيف».منجدل: ملقى على الجدالة، وهي الأرض. النهاية (جدل).أخرجه الحاكم ٢/٤١٨، والبيهقي ٢/١٣٠. والحديث دون ذكر الآية عند أحمد ٢٨/٣٧٩، ٣٨٢، ٣٦٥ (١٧١٥٠، ١٧١٥١، ١٧١٦٣). قال محققو المسند: «صحيح لغيره».أخرجه ابن أبي حاتم -كما في تفسير ابن كثير ٦/٤٣٠-، والطبراني (١١٨٤١)، والخطيب ٣/٣١٩. وعزاه السيوطي إلى ابن مردويه، وابن عساكر.علقه يحيى بن سلّام ٢/٧٢٦.أخرجه ابن جرير ١٩/١٢٦-١٢٧. وعزاه السيوطي إلى عبد بن حميد، وابن أبي حاتم.تفسير مقاتل بن سليمان ٣/٤٩٩.تفسير يحيى بن سلّام ٢/٧٢٥-٧٢٦.عزاه السيوطي إلى أبي الشيخ.سخّاب: بالسين والصاد، هو شدة الصياح. النهاية (سخب).أخرجه أحمد ١١/١٩٣ (٦٦٢٢)، والبخاري (٢١٢٥، ٤٨٣٨)، والبيهقي في الدلائل ١/٣٧٣-٣٧٥. وعزاه السيوطي إلى ابن أبي حاتم. وفي رواية عند البخاري بلفظ: أن هذه الآية التي في القرآن: <q>﴿يا أيُّها النبي إنّا أرْسَلْناكَ شاهِدًا ومُبَشِّرًا ونَذِيرًا﴾</q> قال في التوراة: يا أيها النبي إنا أرسلناك شاهدًا ومبشرًا ... إلخ.
33,46," <q>﴿وَدَاعِیًا إِلَى ٱللَّهِ بِإِذۡنِهِۦ وَسِرَاجࣰا مُّنِیرࣰا ۝٤٦﴾</q> - تفسير ٦٢٤٢٤- عن عبد الله بن عباس -من طريق عكرمة- قال: <q>﴿وداعِيًا﴾</q> إلى شهادة لا إله إلا الله <q>﴿بِإذْنِهِ وسِراجًا مُنِيرًا﴾</q> بالقرآن{1}. (١٢/٧٥) ٦٢٤٢٥- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿وداعِيًا إلى اللَّهِ﴾</q> إلى شهادة أن لا إله إلا الله <q>﴿بإذْنِهِ﴾</q> قال: بأمره٥٢٤٧، <q>﴿وسِراجًا مُنِيرًا﴾</q> قال: كتاب الله يدعوهم إليه{2}. (١٢/٧٧) ٥٢٤٧ قال ابنُ عطية (٧/١٢٨): «معناه هنا: بأمره إيّاك، وتقديره ذلك في وقته وأوانه». وبنحوه قال ابنُ جرير (١٩/١٢٦)، وابنُ تيمية (٥/٢٤٨)، وابنُ كثير (١١/١٨٧). ٦٢٤٢٦- قال مقاتل بن سليمان: <q>﴿وداعِيًا إلى اللَّهِ﴾</q> يعني: إلى معرفة الله ﷿ بالتوحيد <q>﴿بِإذْنِهِ﴾</q> يعني: بأمره، <q>﴿وسِراجًا مُنِيرًا﴾</q> يعني: هُدًى مضيئًا للناس{3}. (ز) ٦٢٤٢٧- قال يحيى بن سلّام: <q>﴿وداعِيًا إلى اللَّهِ بِإذْنِهِ﴾</q> بالقرآن؛ الوحي الذي جاء من عنده، <q>﴿وسِراجًا مُنِيرًا﴾</q> مُضيئًا{4}. (ز) ",footnotes:1:أخرجه ابن أبي حاتم -كما في تفسير ابن كثير ٦/٤٣٠-، والطبراني (١١٨٤١)، والخطيب ٣/٣١٩. وعزاه السيوطي إلى ابن مردويه، وابن عساكر.أخرجه ابن جرير ١٩/١٢٦-١٢٧. وعزاه السيوطي إلى عبد بن حميد، وابن أبي حاتم.تفسير مقاتل بن سليمان ٣/٥٠٠.تفسير يحيى بن سلّام ٢/٧٢٦.
33,47," <q>﴿وَبَشِّرِ ٱلۡمُؤۡمِنِینَ بِأَنَّ لَهُم مِّنَ ٱللَّهِ فَضۡلࣰا كَبِیرࣰا ۝٤٧﴾</q> - نزول الآية ٦٢٤٢٨- قال جابر بن عبد الله: لَمّا نزلت <q>﴿إنّا فَتَحْنا﴾</q> الآيات، قال الصحابة: هنيئًا لك -يا رسول الله- هذه الفاتحة، فما لنا؟ فأنزل الله تعالى: <q>﴿وبَشِّرِ المُؤْمِنِينَ بِأَنَّ لَهُمْ مِنَ اللَّهِ فَضْلًا كَبِيرًا﴾</q>{1}. (ز) ٦٢٤٢٩- عن أنس بن مالك -من طريق الربيع- قال: لما نزلت: <q>﴿وما أدْرِي ما يُفْعَلُ بِي ولا بِكُمْ﴾</q> [الأحقاف:٩] نزل بعدها: <q>﴿لِيَغْفِرَ لَكَ اللَّهُ ما تَقَدَّمَ مِن ذَنْبِكَ وما تَأَخَّرَ﴾</q> [الفتح:٢]. فقالوا: يا رسول الله، قد علمنا ما يُفعل بك، فماذا يُفعَل بنا؟ فأنزل الله: <q>﴿وبَشِّرِ المُؤْمِنِينَ بِأَنَّ لَهُمْ مِنَ اللَّهِ فَضْلًا كَبِيرًا﴾</q>. قال: الفضل الكبير: الجنة{2}. (١٢/٧٧) ٦٢٤٣٠- عن عكرمة مولى ابن عباس= (ز) ٦٢٤٣١- والحسن البصري -من طريق يزيد- قالا: لما نزلت: <q>﴿لِيَغْفِرَ لَكَ اللَّهُ ما تَقَدَّمَ مِن ذَنْبِكَ وما تَأَخَّرَ﴾</q> [الفتح:٢] قال رجال من المؤمنين: هنيئًا لك، يا رسول الله، قد علمنا ما يُفعل بك، فماذا يُفعل بنا؟ فأنزل الله: <q>﴿وبَشِّرِ المُؤْمِنِينَ بِأَنَّ لَهُمْ مِنَ اللَّهِ فَضْلًا كَبِيرًا﴾</q>{3}. (١٢/٧٦) ٦٢٤٣٢- قال محمد بن شهاب الزهري، في قوله تعالى: <q>﴿إنا فتحنا لك فتحا مبينا. ليغفر لك الله ما تقدم من ذنبك وما تأخر﴾</q> إلى قوله: <q>﴿ويهديك صراطا مستقيما﴾</q> [الفتح:١-٢]: ... قال رجل من الأنصار: قد حدَّثك ربُّك ما يُفعَل بِك مِن الكرامة، فهنيئًا لك، يا رسول الله، فما يُفْعَل بنا نحن؟ فقال سبحانه: <q>﴿وبشر المؤمنين بأن لهم من الله فضلا كبيرا﴾</q>. وقال تعالى: <q>﴿ليدخل المؤمنين والمؤمنات جنات تجري من تحتها الأنهار﴾</q> [الفتح:٥]. فبيَّن تعالى في هذه الآية كيف يفعل به وبهم{4}. (ز) ٦٢٤٣٣- عن ابن جريج، في قوله: <q>﴿إن الله وملائكته﴾</q> الآية [الأحزاب:٥٦]، قال: لما نزلت جعل الناس يهنئونه بهذه الآية. وقال أُبَي بن كعب: ما أنزل فيك خيرًا إلا خلطنا به معك، إلا هذه الآية. فنزلت: <q>﴿وبَشَّرِ المُؤْمِنِينَ﴾</q>{5}. (١٢/١١٦) <q>﴿وَبَشِّرِ ٱلۡمُؤۡمِنِینَ بِأَنَّ لَهُم مِّنَ ٱللَّهِ فَضۡلࣰا كَبِیرࣰا ۝٤٧﴾</q> - تفسير الآية ٦٢٤٣٤- عن أنس بن مالك -من طريق الربيع- قال: <q>﴿وبَشِّرِ المُؤْمِنِينَ بِأَنَّ لَهُمْ مِنَ اللَّهِ فَضْلًا كَبِيرًا﴾</q>، الفضل الكبير: الجنة{6}. (١٢/٧٧) ٦٢٤٣٥- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿وبَشِّرِ المُؤْمِنِينَ بِأَنَّ لَهُمْ مِنَ اللَّهِ فَضْلًا كَبِيرًا﴾</q>: وهي الجنة{7}. (١٢/٧٧) ٦٢٤٣٦- قال إسماعيل السُّدِّيّ: <q>﴿وبَشِّرِ المُؤْمِنِينَ بِأَنَّ لَهُمْ مِنَ اللَّهِ فَضْلًا كَبِيرًا﴾</q>، يعني: الجنة{8}. (ز) ٦٢٤٣٧- قال مقاتل بن سليمان: <q>﴿وبَشِّرِ المُؤْمِنِينَ بِأَنَّ لَهُمْ مِنَ اللَّهِ فَضْلًا كَبِيرًا﴾</q>، يعني: الجنة{9}٥٢٤٨. (ز) ٥٢٤٨ قال ابنُ عطية (٧/١٢٨): «قال لنا أبي ﵁: هذه مِن أرجى آية عندي في كتاب الله تعالى؛ لأن الله تعالى أمر نبيه أن يبشر المؤمنين بأن لهم عنده فضلًا كبيرًا، وقد بَيَّنَ الله تعالى الفضل الكبير ما هو في قوله تعالى: <q>﴿والذين آمنوا وعملوا الصالحات في روضات الجنات لهم ما يشاءون عند ربهم ذلك هو الفضل الكبير﴾</q> [الشورى:٢٢]، فالآية التي في هذه السورة خبر، والتي في (حم عسق) تفسير لها». ",footnotes:1:أورده الثعلبي ٨/٥٢.أخرجه البيهقي في دلائل النبوة ٤/١٥٩، من طريق أحمد بن عبد الجبار، قال: حدثنا يونس بن بكير، عن عيسى بن [عبيد الله]، عن الربيع بن أنس، عن أنس به. إسناده ضعيف؛ فيه أحمد بن عبد الجبار، وهو العطاردي، قال عنه ابن حجر في التقريب (٦٤): «ضعيف».أخرجه ابن جرير ٢١/١٢١ بنحوه.الناسخ والمنسوخ للزهري ص٣٣.عزاه السيوطي إلى ابن المنذر.أخرجه البيهقي في الدلائل ٤/١٥٩.عزاه السيوطي إلى عبد بن حميد، وابن جرير، وابن أبي حاتم.علقه يحيى بن سلّام ٢/٧٢٦.تفسير مقاتل بن سليمان ٣/٥٠٠.
33,48," <q>﴿وَلَا تُطِعِ ٱلۡكَـٰفِرِینَ وَٱلۡمُنَـٰفِقِینَ وَدَعۡ أَذَىٰهُمۡ وَتَوَكَّلۡ عَلَى ٱللَّهِۚ وَكَفَىٰ بِٱللَّهِ وَكِیلࣰا ۝٤٨﴾</q> - تفسير ٦٢٤٣٨- قال عبد الله بن عباس: <q>﴿ودَعْ أذاهُمْ﴾</q> اصبر على أذاهم{1}. (ز) ٦٢٤٣٩- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿ودَعْ أذاهُمْ﴾</q>، قال: أعْرِضْ عنهم{2}. (١٢/٧٨) ٦٢٤٤٠- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿ولا تُطِعِ الكافِرِينَ والمُنافِقِينَ﴾</q> قال: أمر اللهُ نبيَّه ألاَّ يطيع كافرًا ولا منافقًا، <q>﴿ودَعْ أذاهُمْ﴾</q> قال: اصبِر على أذاهم{3}٥٢٤٩. (١٢/٧٧) ٥٢٤٩ قال ابنُ عطية (٧/١٢٨) بتصرف: «قوله تعالى: <q>﴿ودع آذاهم﴾</q> يحتمل معنيين: أحدهما: أن يأمره بترك أن يؤذيهم هو ويعاقبهم، فكأن المعنى: واصفح عن زللهم ولا تؤذهم، فالمصدر -على هذا- مضاف إلى المفعول، ونُسِخ من الآية -على هذا التأويل- ما يخص الكافرين، وناسخه: آية السيف. والمعنى الثاني: أن يكون قوله: <q>﴿ودع آذاهم﴾</q> بمعنى: أعرض عن أقوالهم، وما يؤذونك به، فالمصدر -على هذا التأويل- مضاف إلى الفاعل». وإلى المعنى الأول ذَهَبَ ابنُ تيمية (٥/٢٥٠-٢٥١) مستندًا إلى أحوال النزول. وإلى المعنى الثاني ذَهَبَ ابنُ جرير (١٩/١٢٧) مستندًا إلى أقوال السلف. ٦٢٤٤١- قال مقاتل بن سليمان: <q>﴿ولا تُطِعِ الكافِرِينَ والمُنافِقِينَ﴾</q> ولا تطع الكافرين مِن أهل مكة؛ أبا سفيان بن حرب، وعكرمة بن أبي جهل، وأبا الأعور السلمي، والمنافقين؛ عبد الله بن أُبَيّ، وعبد الله بن سعد، وطعمة بن أُبَيْرِق، حين قال أبو سفيان ومَن معه من هؤلاء النفر: يا محمد، ارفض ذكر آلهتنا، وقل: إنّ لها شفاعة ومنفعة لمن عبدها، <q>﴿ودَعْ أذاهُمْ﴾</q> ودع أذاهم إياك، يعني: الذين قالوا للنبي ﷺ: قل إن لآلهتنا شفاعة، <q>﴿وتَوَكَّلْ عَلى اللَّهِ﴾</q> يعنى: وثِقْ بالله، <q>﴿وكَفى بِاللَّهِ وكِيلًا﴾</q> يعني: مانِعًا{4}. (ز) ",footnotes:1:تفسير البغوي ٦/٣٦١.تفسير مجاهد (٥٥٠)، وأخرجه ابن جرير ١٩/١٢٧. وعلَّقه يحيى بن سلّام ٢/٧٢٦ وقال عَقِبَه: أي: اصبر عليه. وعزاه السيوطي إلى الفريابي، وابن أبي شيبة، وعبد بن حميد، وابن المنذر، وابن أبي حاتم.أخرجه ابن جرير ١٩/١٢٧ مقتصرًا على شطره الثاني. وعزاه السيوطي إلى عبد بن حميد، وابن أبي حاتم.تفسير مقاتل بن سليمان ٣/٥٠٠.
33,49," <q>﴿یَـٰۤأَیُّهَا ٱلَّذِینَ ءَامَنُوۤا۟ إِذَا نَكَحۡتُمُ ٱلۡمُؤۡمِنَـٰتِ ثُمَّ طَلَّقۡتُمُوهُنَّ﴾</q> - تفسير ٦٢٤٤٢- عن عبد الله بن عباس -من طريق طاووس- أنه تلا: <q>﴿يا أيُّها الَّذِينَ آمَنُوا إذا نَكَحْتُمُ المُؤْمِناتِ ثُمَّ طَلَّقْتُمُوهُنَّ مِن قَبْلِ أنْ تَمَسُّوهُن﴾</q>، قال: فلا يكون طلاقٌ حتى يكونَ نِكاحٌ{1}. (١٢/٨٠) <q>﴿یَـٰۤأَیُّهَا ٱلَّذِینَ ءَامَنُوۤا۟ إِذَا نَكَحۡتُمُ ٱلۡمُؤۡمِنَـٰتِ ثُمَّ طَلَّقۡتُمُوهُنَّ﴾</q> - من أحكام الآية ٦٢٤٤٣- عن سعيد بن جبير، قال: سُئِل ابنُ عباس عن الرجل يقول: إن تزوجتُ فلانةً فهي طالق. قال: ليس بشيءٍ، إنما الطلاق لمن يملك.= (ز) ٦٢٤٤٤- قال: فإنّ ابن مسعود كان يقول: إذا وقَّتَ وقتًا فهو كما قال؟ فقال: رحم الله أبا عبد الرحمن، لو كان كما قال لقال الله: يا أيها الذين آمنوا اذا طلقتم النساء ثم نكحتموهن. ولكن إنما قال: <q>﴿إذا نَكَحْتُمُ المُؤْمِناتِ ثُمَّ طَلَّقْتُمُوهُنَّ﴾</q>{2}. (١٢/٨٠) ٦٢٤٤٥- عن عبد الملك ابن جريج قال: بلغ ابنَ عباس أنّ ابن مسعود يقول: إن طلّق ما لم ينكح فهو جائز. فقال ابنُ عباس: أخطأ في هذا، إنّ الله تعالى يقول: <q>﴿إذا نَكَحْتُمُ المُؤْمِناتِ ثُمَّ طَلَّقْتُمُوهُنَّ مِن قَبْلِ أنْ تَمَسُّوهُنَّ﴾</q>، ولم يقل: إذا طلقتم المؤمنات ثم نكحتموهن{3}. (١٢/٨٠) ٦٢٤٤٦- عن عبد الله بن عباس -من طريق عكرمة- قال: ما قالها ابن مسعود، وإن يكن قالها فزلَّة من عالم -في الرجل يقول: إن تزوجتُ فلانة فهي طالق-، قال الله تعالى <q>﴿يا أيُّها الَّذِينَ آمَنُوا إذا نَكَحْتُمُ المُؤْمِناتِ ثُمَّ طَلَّقْتُمُوهُنَّ﴾</q>، ولم يقل: إذا طلَّقتم المؤمنات ثم نكحتموهن{4}. (١٢/٨١) ٦٢٤٤٧- عن عبد الله بن عباس -من طريق سعيد بن جبير- قال: إذا قال: كل امرأة أتزوّجها فهي طالق. أو: إن تزوَّجتُ فلانة فهي طالق. فليس بشيء، إنما الطلاق لمن يملك، من أجل أن الله يقول: <q>﴿إذا نَكَحْتُمُ المُؤْمِناتِ ثُمَّ طَلَّقْتُمُوهُنَّ﴾</q>{5}. (١٢/٨٠) ٦٢٤٤٨- عن حسين بن ثابت، قال: جاء رجل إلى علي بن الحسين، فسأله عن رجل قال: إن تزوجتُ فلانة فهي طالق. قال: ليس بشيء، بدأ الله بالنكاح قبل الطلاق، فقال: <q>﴿يا أيُّها الَّذِينَ آمَنُوا إذا نَكَحْتُمُ المُؤْمِناتِ ثُمَّ طَلَّقْتُمُوهُنَّ﴾</q>{2}. (١٢/٧٩) <q>﴿یَـٰۤأَیُّهَا ٱلَّذِینَ ءَامَنُوۤا۟ إِذَا نَكَحۡتُمُ ٱلۡمُؤۡمِنَـٰتِ ثُمَّ طَلَّقۡتُمُوهُنَّ مِن قَبۡلِ أَن تَمَسُّوهُنَّ فَمَا لَكُمۡ عَلَیۡهِنَّ مِنۡ عِدَّةࣲ تَعۡتَدُّونَهَاۖ﴾</q> - تفسير الآية، وأحكامها ٦٢٤٤٩- عن عبد الله بن عباس -من طريق علي- في قوله: <q>﴿إذا نَكَحْتُمُ المُؤْمِناتِ﴾</q> الآية، قال: هذا في الرجل يتزوج المرأةَ ثُمَّ يُطَلِّقُها من قبل أن يمسها، فإذا طلقها واحدةً بانت منه، ولا عدة عليها، تتزوج مَن شاءت{7}. (١٢/٧٨) ٦٢٤٥٠- عن قتادة بن دعامة -من طريق معمر- <q>﴿يا أيُّها الَّذِينَ آمَنُوا إذا نَكَحْتُمُ المُؤْمِناتِ ثُمَّ طَلَّقْتُمُوهُنَّ مِن قَبْلِ أنْ تَمَسُّوهُن﴾</q> الآية، قال: التي نُكِحت ولم يُبْنَ بها، ولم يُفرض لها؛ فليس لها صداق، وليس عليها عِدَّة{8}. (١٢/٧٨) ٦٢٤٥١- تفسير السُّدِّيّ: <q>﴿من قبل أن تمسوهن﴾</q>، يعني: تُجامِعُوهُنَّ{9}. (ز) ٦٢٤٥٢- قال مقاتل بن سليمان: <q>﴿يا أيُّها الَّذِينَ آمَنُوا إذا نَكَحْتُمُ المُؤْمِناتِ﴾</q> يعني: إذا تزوجتم المصدِّقات بتوحيد الله، <q>﴿ثُمَّ طَلَّقْتُمُوهُنّ مِن قَبْلِ أنْ تَمَسُّوهُنَّ﴾</q> يعني: مِن قبل أن تجامعوهن؛ <q>﴿فَما لَكُمْ عَلَيْهِنَّ مِن عِدَّةٍ تَعْتَدُّونَها﴾</q> إن شاءت تزوَّجَْت مِن يومها{10}. (ز) ٦٢٤٥٣- قال يحيى بن سلّام: <q>﴿يا أيُّها الَّذِينَ آمَنُوا إذا نَكَحْتُمُ المُؤْمِناتِ ثُمَّ طَلَّقْتُمُوهُنّ مِن قَبْلِ أنْ تَمَسُّوهُنَّ فَما لَكُمْ عَلَيْهِنَّ مِن عِدَّةٍ تَعْتَدُّونَها﴾</q> إذا طلّق الرجلُ المرأةَ -قبل أن يدخل بها- واحدةً فقد بانتْ منه بتلك الواحدة، وهي أملك بنفسها، يخطبها مع الخُطّاب، وليس عليها عدة منه، ولا من غيره، حتى تُزوج إن شاءت مِن يومها الذي طلقها فيه؛ لأنه لم يطأها فتعتد مِن مائه مخافة أن تكون حُبْلى، ولها نصف الصداق، فإن أغلق عليها بابًا أو أرخى عليها سِترًا فقد وجب عليه الصداق كاملًا، ووجبت عليها العِدَّة، وإن طلَّقها ثلاثًا قبل أن يدخل بها لم يتزوجها حتى تنكح زوجًا غيره إلا أن يُفرِّق الطلاق، فيقول: أنت طالق، أنت طالق، أنت طالق. فإنها تبين بالأولى، وليس ما طلَّق بعدها بشيء، وهو خاطب من الخُطّاب، فإن تزوجها كانت عنده على تطليقتين{11}. (ز) <q>﴿فَمَتِّعُوهُنَّ وَسَرِّحُوهُنَّ سَرَاحࣰا جَمِیلࣰا ۝٤٩﴾</q> - تفسير ٦٢٤٥٤- عن عبد الله بن عباس -من طريق علي- في قوله: <q>﴿فَمَتِّعُوهُنَّ وسَرِّحُوهُنَّ سَراحًا جَمِيلًا﴾</q>، يقول: إن كان سمّى لها صداقًا فليس لها إلا النصف، وإن لم يكن سمّى لها صداقًا متَّعها على قدْر عُسْره ويُسْره، وهو السراح الجميل{7}٥٢٥٠. (١٢/٧٨) ٥٢٥٠ قال ابنُ كثير (١١/١٨٩): «المتعة ههنا أعم مِن أن تكون نصف الصداق المسمى، أو المتعة الخاصة إن لم يكن قد سمي لها، قال الله تعالى: <q>﴿وإنْ طَلَّقْتُمُوهُنَّ مِن قَبْلِ أنْ تَمَسُّوهُنَّ وقَدْ فَرَضْتُمْ لَهُنَّ فَرِيضَةً فَنِصْفُ ما فَرَضْتُمْ﴾</q>، وقال ﷿: <q>﴿لا جُناحَ عَلَيْكُمْ إنْ طَلَّقْتُمُ النِّساءَ ما لَمْ تَمَسُّوهُنَّ أوْ تَفْرِضُوا لَهُنَّ فَرِيضَةً ومَتِّعُوهُنَّ عَلى المُوسِعِ قَدَرُهُ وعَلى المُقْتِرِ قَدَرُهُ مَتاعًا بِالمَعْرُوفِ حَقًّا عَلى المُحْسِنِينَ﴾</q>، وفي صحيح البخاري عن سهل بن سعد، وأبي أسيد ﵄ قالا: إن رسول الله ﷺ تزوج أميمة بنت شراحيل، فلمّا أن دخلت عليه بسط يده إليها، فكأنها كرهت ذلك، فأمر أبا أسيد أن يجهزها ويكسوها ثوبين رازقيَّين». ٦٢٤٥٥- عن الحسن البصري، قال: <q>﴿فَمَتِّعُوهُنَّ﴾</q> لكل مطلَّقة متاع، دُخل أو لم يُدخل بها، فُرض لها أو لم يُفرض لها{2}. (١٢/٧٩) ٦٢٤٥٦- قال مقاتل بن سليمان: <q>﴿فَمَتِّعُوهُنَّ وسَرِّحُوهُنَّ سَراحًا جَمِيلًا﴾</q>، يعني: حَسنًا في غير ضِرار{10}. (ز) ٦٢٤٥٧- قال يحيى بن سلّام: قوله: <q>﴿فَمَتِّعُوهُنَّ﴾</q> فهو منسوخ إذا كان قد سَمّى لها صداقًا، إلا أن يكون لم يُسمّ لها صداقًا فيكون لها المتعة ولا صداق لها، فإن كان سَمّى لها صداقًا ثم طلّقها قبل أن يدخل بها فإن لها نصف الصداق ولا متعة لها ...، <q>﴿وسَرِّحُوهُنَّ سَراحًا جَمِيلًا﴾</q> إلى أهلهن، لا تكون المرأة والرجل في بيت وليس بينهما حُرمَة، وإذا مات الرجل قبل أن يدخل بامرأته توارثا ولها الصداق كاملًا، وإنما يكون لها النصف إذا طلقها{15}٥٢٥١. (ز) ٥٢٥١ قال ابنُ عطية (٧/١٣٠): «هذه الآية خصصت آيتين: إحداهما: <q>﴿والمطلقات يتربصن بأنفسهن ثلاثة قروء﴾</q> فخصصت هذه الآية من لم يدخل بها، وكذلك خصصت من ذوات الثلاثة الأشهر، وهُنَّ مَن قَعَدْن عن المحيض، ومَن لم يحضن مِن صغير المطلقات قبل البناء». <q>﴿فَمَتِّعُوهُنَّ وَسَرِّحُوهُنَّ سَرَاحࣰا جَمِیلࣰا ۝٤٩﴾</q> - النسخ في الآية ٦٢٤٥٨- عن عبد الله بن عمر، في قوله: <q>﴿فَمَتِّعُوهُنَّ﴾</q>، قال: هي منسوخة، نسختها الآية التي في البقرة [٢٣٧]: <q>﴿فَنِصْفُ ما فَرَضْتُمْ﴾</q>{16}. (١٢/٧٨) ٦٢٤٥٩- عن سعيد بن المسيب -من طريق قتادة- <q>﴿يا أيُّها الَّذِينَ آمَنُوا إذا نَكَحْتُمُ المُؤْمِناتِ﴾</q> إلى قوله: <q>﴿فَمَتِّعُوهُنَّ﴾</q>، قال: هي منسوخة، نسختها الآية التي في البقرة [٢٣٧]: <q>﴿وإنْ طَلَّقْتُمُوهُنَّ مِن قَبْلِ أنْ تَمَسُّوهُنَّ وقَدْ فَرَضْتُمْ لَهُنَّ فَرِيضَةً فَنِصْفُ ما فَرَضْتُمْ﴾</q>، فصار لها نصف الصداق، ولا متاع لها{17}. (١٢/٧٩) ٦٢٤٦٠- عن الحسن البصري= (ز) ٦٢٤٦١- وأبي العالية الرياحي، قالا: <q>﴿فَمَتِّعُوهُنَّ﴾</q> ليست بمنسوخة، لها نصف الصداق، ولها المتاع{2}. (١٢/٧٩) ٦٢٤٦٢- عن الحسن البصري -من طريق قرة بن خالد- أنه كان يقول: <q>﴿فَمَتِّعُوهُنَّ﴾</q> لها المتاع، وليست بمنسوخة{19}. (ز) ٦٢٤٦٣- قال قتادة بن دعامة: <q>﴿فَمَتِّعُوهُنَّ﴾</q> هذه الآية منسوخة بقوله: <q>﴿فَنِصْفُ ما فَرَضْتُمْ﴾</q> [البقرة:٢٣٧]{20}. (ز) ٦٢٤٦٤- عن زيد بن أسلم -من طريق القاسم بن عبد الله- أنه قال: <q>﴿والمُطَلَّقاتُ يَتَرَبَّصْنَ بِأَنْفُسِهِنَّ ثَلاثَةَ قُرُوءٍ﴾</q> [البقرة:٢٢٨]، وقال: <q>﴿فَعِدَّتُهُنَّ ثَلاثَةُ أشْهُرٍ﴾</q> [الطلاق:٤]، فنسخ واستثنى منها، فقال: <q>﴿يا أيُّها الَّذِينَ آمَنُوا إذا نَكَحْتُمُ المُؤْمِناتِ ثُمَّ طَلَّقْتُمُوهُنَّ مِن قَبْلِ أنْ تَمَسُّوهُنَّ فَما لَكُمْ عَلَيْهِنَّ مِن عِدَّةٍ تَعْتَدُّونَها فَمَتِّعُوهُنَّ وسَرِّحُوهُنَّ سَراحًا جَمِيلًا﴾</q>، وقال: <q>﴿لا يُكَلِّفُ اللَّهُ نَفْسًا إلّا وُسْعَها لَها ما كَسَبَتْ وعَلَيْها ما اكْتَسَبَتْ﴾</q> [البقرة:٢٨٦]{21}. (ز) ٦٢٤٦٥- قال يحيى بن سلام: قوله: <q>﴿فَمَتِّعُوهُنَّ﴾</q> فهو منسوخ إذا كان قد سمى لها صداقًا، إلا أن يكون لم يسم لها صداقًا فيكون لها المتعة ولا صداق لها، فإن كان سمى لها صداقًا ثم طلقها قبل أن يدخل بها فإن لها نصف الصداق، ولا متعة لها، نسختها الآية التي في البقرة [٢٣٦-٢٣٧]: <q>﴿لا جُناحَ عَلَيْكُمْ إنْ طَلَّقْتُمُ النِّساءَ ما لَمْ تَمَسُّوهُنَّ أوْ تَفْرِضُوا لَهُنَّ فَرِيضَةً ومَتِّعُوهُنَّ عَلى المُوسِعِ قَدَرُهُ وعَلى المُقْتِرِ قَدَرُهُ مَتاعًا بِالمَعْرُوفِ حَقًّا عَلى المُحْسِنِينَ * وإنْ طَلَّقْتُمُوهُنَّ مِن قَبْلِ أنْ تَمَسُّوهُنَّ وقَدْ فَرَضْتُمْ لَهُنَّ فَرِيضَةً فَنِصْفُ ما فَرَضْتُمْ﴾</q> ولا متاع لها إلى آخر الآية ... والعامة على أنها منسوخة{15}. (ز) <q>﴿فَمَتِّعُوهُنَّ وَسَرِّحُوهُنَّ سَرَاحࣰا جَمِیلࣰا ۝٤٩﴾</q> - آثار متعلقة بالآية ٦٢٤٦٦- عن عائشة: أنّ رسول الله ﷺ قال: «لا طلاق إلا بعد نكاح، ولا عتق إلا بعد ملك»{23}. (١٢/٨١) ٦٢٤٦٧- عن جابر بن عبد الله، أنّه سمع رسول الله ﷺ يقول: «لا طلاق فيما لا تملك، ولا عتق فيما لا تملك»{24}. (١٢/٨٢) ٦٢٤٦٨- عن المسور بن مخرمة، عن النبي ﷺ قال: «لا طلاق قبل نكاح، ولا عتق قبل مِلك»{25}. (١٢/٨٢) ٦٢٤٦٩- عن عمرو بن شعيب، عن أبيه، عن جده، قال: قال رسول الله ﷺ:«لا طلاق فيما لا تملك، ولا بيع فيما لا تملك، ولا عِتق فيما لا تملك، ولا وفاء نذر فيما لا تملك، ولا نذر إلا فيما ابتُغي وجه الله تعالى، ومَن حلف على معصية فلا يمين له، ومَن حلف على قطيعة رحم فلا يمين له»{26}. (١٢/٨٢) ",footnotes:1:أخرجه الحاكم ٢/٤١٩. وعزاه السيوطي إلى ابن أبي حاتم.عزاه السيوطي إلى عبد بن حميد.أخرجه عبد الرزاق (١١٤٦٨).أخرجه البيهقي في سننه ٧/٣٢٠-٣٢١.أخرجه ابن أبي حاتم -كما في تفسير ابن كثير ٦/٤٣٢-. وعزاه السيوطي إلى ابن المنذر.عزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ١٩/١٢٨. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.أخرجه عبد الرزاق ٢/١١٩. وعزاه السيوطي إلى ابن المنذر.تفسير يحيى بن سلّام ٢/٧١٣-٧١٤.تفسير مقاتل بن سليمان ٣/٥٠٠.تفسير يحيى بن سلّام ٢/٧٢٨.أخرجه ابن جرير ١٩/١٢٨. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.عزاه السيوطي إلى عبد بن حميد.تفسير مقاتل بن سليمان ٣/٥٠٠.تفسير يحيى بن سلّام ٢/٧٢٧-٧٢٨.عزاه السيوطي إلى ابن مردويه.عزاه السيوطي إلى عبد بن حميد. وأخرجه ابن جرير ١٩/١٢٩ بنحوه، وأخرجه يحيى بن سلّام ٢/٧٢٧ بلفظ: جُعلتْ لها المتعة في هذه الآية، فلما نزلت الآية التي في البقرة: <q>﴿وإنْ طَلَّقْتُمُوهُنَّ مِن قَبْلِ أنْ تَمَسُّوهُنَّ وقَدْ فَرَضْتُمْ لَهُنَّ فَرِيضَةً فَنِصْفُ ما فَرَضْتُمْ﴾</q> جعل لها النصف، ولا متاع لها.عزاه السيوطي إلى عبد بن حميد.أخرجه يحيى بن سلّام ٢/٧٢٨.تفسير الثعلبي ٨/٥٢، وتفسير البغوي ٦/٣٦٢. وعلقه يحيى بن سلّام ٢/٧٢٧.أخرجه عبد الله بن وهب في الجامع -تفسير القرآن ٣/٦٧-٦٨ (١٥٢)-.تفسير يحيى بن سلّام ٢/٧٢٧-٧٢٨.أخرجه الحاكم ٢/٤٥٤ (٣٥٦٩). قال ابن أبي حاتم في علل الحديث ٤/٨٠ (١٢٧١): «قال أبي: هذا حديث منكر». وقال ابن الجوزي في العلل المتناهية ٢/١٥٣ (١٠٦٢): «وهذا لا يصح».أخرجه الحاكم ٢/٢٢٢ (٢٨١٩)، ٢/٤٥٥ (٣٥٧٢، ٣٥٧٣). قال الحاكم: «هذا حديث صحيح، على شرط الشيخين، ولم يخرجاه». وقال ابن حجر في بلوغ المرام ٢/٩٩ (١٠٨٢): «وهو معلول».أخرجه ابن ماجه ٣/٢٠٢ (٢٠٤٨). قال البوصيري في مصباح الزجاجة ٢/١٢٦ (٧٢٩): «هذا إسناد حسن». وقال ابن حجر في بلوغ المرام ٢/٩٩ (١٠٨٣): «إسناده حسن، لكنه معلول». وقال المناوي في التيسير ٢/٥٠١: «إسناده حسن». وقال الألباني في الإرواء ٧/١٥٢ (٢٠٧٠): «صحيح».أخرجه أحمد ١١/٣٨١-٣٨٢ (٦٧٦٩)، ١١/٣٩٢-٣٩٣ (٦٧٨٠، ٦٧٨١)، ١١/٥٢٥ (٦٩٣٢)، وأبو داود ٣/٥١٣-٥١٤ (٢١٩٠، ٢١٩١، ٢١٩٢) واللفظ له، والترمذي ٣/٤١ (١٢١٧)، والنسائي ٧/١٢ (٣٧٩٢)، وابن ماجه ٣/٢٠٢ (٢٠٤٧)، والحاكم ٢/٢٢٢ (٢٨٢٠)، ٤/٣٣٣ (٧٨٢٢). قال الترمذي: «حديث حسن صحيح، وهو أحسن شيء روي في هذا الباب». وقال في العلل الكبير ص١٧٣ (٣٠٢): «سألت محمدًا عن هذا الحديث، فقلت: أيُّ حديث في هذا الباب أصح في الطلاق قبل النكاح؟ فقال: حديث عمرو بن شعيب عن أبيه عن جده». وقال الحاكم في الموضع الثاني: «هذا حديث صحيح الإسناد، ولم يخرجاه». وقال ابن الملقن في تحفة المحتاج ٢/٢٠٦ (١١٨٤): «بإسناد صحيح». وقال العيني في عمدة القاري ٢٣/١٩٧: «بإسناد صحيح». وقال الألباني في صحيح أبي داود ٦/٣٩٣-٣٩٤ (١٩٠٠): «إسناده حسن».
33,50," <q>﴿یَـٰۤأَیُّهَا ٱلنَّبِیُّ إِنَّاۤ أَحۡلَلۡنَا لَكَ أَزۡوَ ٰ⁠جَكَ ٱلَّـٰتِیۤ ءَاتَیۡتَ أُجُورَهُنَّ وَمَا مَلَكَتۡ یَمِینُكَ مِمَّاۤ أَفَاۤءَ ٱللَّهُ عَلَیۡكَ وَبَنَاتِ عَمِّكَ وَبَنَاتِ عَمَّـٰتِكَ وَبَنَاتِ خَالِكَ وَبَنَاتِ خَـٰلَـٰتِكَ ٱلَّـٰتِی هَاجَرۡنَ مَعَكَ وَٱمۡرَأَةࣰ مُّؤۡمِنَةً إِن وَهَبَتۡ نَفۡسَهَا لِلنَّبِیِّ إِنۡ أَرَادَ ٱلنَّبِیُّ أَن یَسۡتَنكِحَهَا خَالِصَةࣰ لَّكَ مِن دُونِ ٱلۡمُؤۡمِنِینَۗ قَدۡ عَلِمۡنَا مَا فَرَضۡنَا عَلَیۡهِمۡ فِیۤ أَزۡوَ ٰ⁠جِهِمۡ وَمَا مَلَكَتۡ أَیۡمَـٰنُهُمۡ لِكَیۡلَا یَكُونَ عَلَیۡكَ حَرَجࣱۗ وَكَانَ ٱللَّهُ غَفُورࣰا رَّحِیمࣰا ۝٥٠﴾</q> - قراءات ٦٢٤٧٠- عن عبيد، قال: سمعت الضحاك يقول في حرف ابن مسعود: (واللّاتِي هاجَرْنَ مَعَكَ): يعني بذلك: كل شيء هاجر معه ليس من بنات العم والعمة، ولا من بنات الخال والخالة{1}٥٢٥٢. (ز) ٥٢٥٢ علَّقَ ابنُ جرير (١٩/١٣١) على هذه القراءة بقوله: "ذلك -وإن كان كذلك في قراءته- محتمل أن يكون بمعنى قراءتنا بغير الواو، وذلك أن العرب تدخل الواو في نعت مَن تقدَّم ذِكْرُه أحيانا،كما قال الشاعر: فإنّ رُشَيدًا وابن مَرَوانَ لَم يَكُنْ ... لِيَفْعَلَ حَتّى يَصْدُرَ الأمْرُ مُصْدَرا ورشيد هو ابن مروان. وكان الضحاك بن مزاحم يتأوَّل قراءة عبد الله هذه أنهن نوعٌ غيرُ بنات خالاته، وأنهن كل مهاجرة هاجرت مع النبي ﷺ". <q>﴿یَـٰۤأَیُّهَا ٱلنَّبِیُّ إِنَّاۤ أَحۡلَلۡنَا لَكَ أَزۡوَ ٰ⁠جَكَ ٱلَّـٰتِیۤ ءَاتَیۡتَ أُجُورَهُنَّ وَمَا مَلَكَتۡ یَمِینُكَ مِمَّاۤ أَفَاۤءَ ٱللَّهُ عَلَیۡكَ وَبَنَاتِ عَمِّكَ وَبَنَاتِ عَمَّـٰتِكَ وَبَنَاتِ خَالِكَ وَبَنَاتِ خَـٰلَـٰتِكَ ٱلَّـٰتِی هَاجَرۡنَ مَعَكَ وَٱمۡرَأَةࣰ مُّؤۡمِنَةً إِن وَهَبَتۡ نَفۡسَهَا لِلنَّبِیِّ إِنۡ أَرَادَ ٱلنَّبِیُّ أَن یَسۡتَنكِحَهَا خَالِصَةࣰ لَّكَ مِن دُونِ ٱلۡمُؤۡمِنِینَۗ قَدۡ عَلِمۡنَا مَا فَرَضۡنَا عَلَیۡهِمۡ فِیۤ أَزۡوَ ٰ⁠جِهِمۡ وَمَا مَلَكَتۡ أَیۡمَـٰنُهُمۡ لِكَیۡلَا یَكُونَ عَلَیۡكَ حَرَجࣱۗ وَكَانَ ٱللَّهُ غَفُورࣰا رَّحِیمࣰا ۝٥٠﴾</q> - نزول الآية ٦٢٤٧١- عن أم هانئ قالت: نزلت فِيّ هذه الآية: <q>﴿وبَناتِ عَمِّكَ﴾</q> <q>﴿اللّاتِي هاجَرْنَ مَعَكَ﴾</q>، أراد النبي ﷺ أن يتزوَّجني، فنُهي عني؛ إذ لم أهاجر{2}. (١٢/٨٣) ٦٢٤٧٢- عن أم هانئ بنت أبي طالب، قالت: خطبني رسولُ الله ﷺ، فاعتذرتُ إليه، فعذرني؛ فأنزل الله: <q>﴿يا أيُّها النبي إنّا أحْلَلْنا لَكَ أزْواجَكَ﴾</q> إلى قوله: <q>﴿هاجَرْنَ مَعَكَ﴾</q>، قالت: فلم أكن أحلُّ له؛ لأني لم أهاجر معه، كنت مِن الطلقاء{3}. (١٢/٨٢) ٦٢٤٧٣- عن أبي صالح مولى أم هانئ، قال: خطب رسولُ الله ﷺ أمَّ هانئ بنت أبي طالب، فقالت: يا رسول الله، إني مُوتِـمــــَةٌ{4}، وبنيَّ صغار. فلمّا أدرك بنوها عرضتْ نفسها عليه، فقال: «أمّا الآن فلا، إنّ الله تعالى أنزل عليّ: <q>﴿يا أيُّها النبي إنّا أحْلَلْنا لَكَ أزْواجَكَ﴾</q> إلى <q>﴿هاجَرْنَ مَعَكَ﴾</q>» ولم تكن من المهاجرات{5}. (١٢/٨٣) <q>﴿یَـٰۤأَیُّهَا ٱلنَّبِیُّ إِنَّاۤ أَحۡلَلۡنَا لَكَ أَزۡوَ ٰ⁠جَكَ ٱلَّـٰتِیۤ ءَاتَیۡتَ أُجُورَهُنَّ وَمَا مَلَكَتۡ یَمِینُكَ مِمَّاۤ أَفَاۤءَ ٱللَّهُ عَلَیۡكَ وَبَنَاتِ عَمِّكَ وَبَنَاتِ عَمَّـٰتِكَ وَبَنَاتِ خَالِكَ وَبَنَاتِ خَـٰلَـٰتِكَ ٱلَّـٰتِی هَاجَرۡنَ مَعَكَ﴾</q> - تفسير ٦٢٤٧٤- عن أُبَيّ بن كعب -من طريق موسى بن عبد الله- قال: <q>﴿إنّا أحْلَلْنا لَكَ أزْواجَكَ اللّاتِي آتَيْتَ أُجُورَهُنَّ﴾</q> صداقهن، <q>﴿وما مَلَكَتْ يَمِينُكَ مِمّا أفاءَ اللَّهُ عَلَيْكَ وبَناتِ عَمِّكَ وبَناتِ عَمّاتِكَ﴾</q> حتى انتهى إلى قوله: <q>﴿لا يَحِلُّ لَكَ النِّساءُ مِن بَعْدُ﴾</q> هؤلاء: العمة، والخالة، ونحوهن. وكان يقول: يتزوج من بنات عماته وبنات خالاته اللاتي هاجرن معه{6}. (ز) ٦٢٤٧٥- عن عبد الله بن عباس -من طريق عطية العوفي- في قوله: <q>﴿يا أيُّها النبي إنّا أحْلَلْنا لَكَ أزْواجَكَ﴾</q> إلى قوله: <q>﴿خالِصَةً لَكَ مِن دُونِ المُؤْمِنِينَ﴾</q>، قال: فحرَّم الله عليه سوى ذلك من النساء، وكان قبل ذلك ينكح في أيِّ النساء شاء، لم يُحرِّم ذلك عليه، وكان نساؤُه يَجِدْن مِن ذلك وجْدًا شديدًا أن ينكح في أيِّ النساء أحب، فلمّا أنزل الله عليه: إني قد حرَّمت عليك من النساء سوى ما قصصتُ عليك. أعجب ذلكَ نساءَه{7}. (١٢/٨٣) ٦٢٤٧٦- عن أبي رَزِين [مسعود بن مالك الأسدي] -من طريق مغيرة- في قول الله: <q>﴿وبنات عمك وبنات عماتك وبنات خالك وبنات خالاتك﴾</q>، قال: لا تحل لك النساء بعد هذه الصفة{8}. (ز) ٦٢٤٧٧- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿إنّا أحْلَلْنا لَكَ أزْواجَكَ﴾</q> قال: هُنَّ أزواجه الأُوَل اللاتي كُنَّ قبل أن تنزل هذه الآية. وفي قوله: <q>﴿اللّاتِي آتَيْتَ أُجُورَهُنَّ﴾</q> قال: صدُقاتهن، <q>﴿وما مَلَكَتْ يَمِينُكَ﴾</q> قال: هي الإماء التي أفاء الله عليه{9}. (١٢/٨٤) ٦٢٤٧٨- عن الضحاك بن مزاحم -من طريق عبيد- يقول في قوله: <q>﴿يا أيُّها النبي إنّا أحْلَلْنا لَكَ أزْواجَكَ اللّاتِي آتَيْتَ أُجُورَهُنَّ﴾</q> إلى قوله: <q>﴿خالِصَةً لَكَ مِن دُونِ المُؤْمِنِين﴾</q>: فما كان مِن هذه التسمية ما شاء كثيرًا أو قليلًا{10}. (ز) ٦٢٤٧٩- عن الضحاك بن مزاحم -من طريق عبيد- في قوله: <q>﴿يا أيها النبي إنا أحللنا لك أزواجك﴾</q> إلى قوله: <q>﴿خالصة لك من دون المؤمنين﴾</q>، قال: فما كان مِن هذه التسمية، وهي خمس من النساء، فكان للنبي أن ينكح مِن هذه التسمية ما شاء كثيرًا كان أو قليلًا{11}. (ز) ٦٢٤٨٠- عن عامر الشعبي، في قوله: <q>﴿إنّا أحْلَلْنا لَكَ أزْواجَكَ﴾</q> الآية، قال: رخَّص له في بنات عمه، وبنات عماته، وبنات خاله، وبنات خالاته، اللاتي هاجرن معه؛ أن يتزوج منهن، ولا يتزوج من غيرهن، ورخّص له في امرأة مؤمنة إن وهبت نفسها للنبي ﷺ{12}. (١٢/٨٤) ٦٢٤٨١- قال مقاتل بن سليمان: <q>﴿يا أيُّها النبي إنّا أحْلَلْنا لَكَ أزْواجَكَ﴾</q> يعني: النساء التسع٥٢٥٣ <q>﴿اللّاتِي آتَيْتَ أُجُورَهُنَّ وما مَلَكَتْ يَمِينُكَ﴾</q> أحللنا لك ما ملكت يمينك -يعني: بالولاية- مارية القبطية أم إبراهيم، وريحانة بنت عمرو اليهودي، وكانت سُبِيَت من اليهود، <q>﴿مِمّا أفاءَ اللَّهُ عَلَيْكَ و﴾</q> أحللنا لك <q>﴿بَناتِ عَمِّكَ وبَناتِ عَمّاتِكَ وبَناتِ خالِكَ وبَناتِ خالاتِكَ اللّاتِي هاجَرْنَ مَعَكَ﴾</q> إلى المدينة؛ إضمارُ: فإن كانت لم تهاجر إلى المدينة؛ فلا يحل تزويجها{13}. (ز) ٥٢٥٣ قال ابنُ عطية (٧/١٣٠) بتصرف: «تأول غير ابن زيد قوله:(أحللنا لك أزواجك اللاتي آتيت أجورهن) أن الإشارة إلى عائشة وحفصة ومن في عصمته ممن تزوجها بمهر، وأن ملك اليمين بعدُ حلال له، وأن الله تعالى أباح له مع المذكورات بنات عمه وعماته وخاله وخالاته ممن هاجرن معه، والواهبات خاصة له، فيجيء الأمر -على هذا التأويل- أضيق على النبي ﷺ، ويؤيد هذا التأويل ما قاله ابن عباس ﵄:»كان رسول الله ﷺ يتزوج في أيّ الناس شاء، وكان ذلك يشق على نسائه، فلما نزلت هذه الآية، وحرّم عليه الناس إلا مَن سمّى سُرَّ نساؤه بذلك«؛ لأن ملك اليمين إنما تعلّقه في النادر من الأمر، وبنات العم والعمات والخال والخالات يسير، ومن يمكن أن يتزوج منهن محصور عند نسائه، لا سيما وقد قيد ذلك بشرط الهجرة، وكذا الواهبة من النساء قليل، فلذلك سُرَّ أزواج النبي ﷺ بانحصار الأمر». ٦٢٤٨٢- قال عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿يا أيُّها النبي إنّا أحْلَلْنا لَكَ أزْواجَكَ اللّاتِي آتَيْتَ أُجُورَهُنَّ﴾</q>، قال: كان كل امرأة آتاها مهرًا فقد أحلَّها الله له{14}٥٢٥٤. (ز) ٥٢٥٤ قال ابنُ عطية (٧/١٣٠-١٣١): «ذهب ابن زيد والضحاك في تفسير قوله: <q>﴿إنا أحللنا لك أزواجك اللاتي آتيت أجورهن﴾</q> إلى أن المعنى: أنّ الله تعالى أحل له أن يتزوج كل امرأة يؤتيها مهرها، وأباح له كلَّ النساء بهذا الوجه، وأباح له ملك اليمين، وبنات العم والعمة والخال والخالة ممن هاجر معه، وخصص هؤلاء بالذكر تشريفًا وتنبيهًا؛ إذ قد تناولهن -على تأويل ابن زيد- قوله تعالى: <q>﴿يا أيها النبيّ إنا أحللنا﴾</q>، وأباح له الواهبات خاصة له، فهذا -على تأويل ابن زيد- إباحة مطلقة في جميع النساء حاشا ذوات المحارم، لا سيما -على ما ذكره الضحاك- أن في مصحف ابن مسعود: (وبَناتِ خالاتِكَ واللاَّتِي هاجَرْنَ مَعَكَ)». ٦٢٤٨٣- قال يحيى بن سلّام: قوله ﷿: <q>﴿يَأَيُّها النبي إنّا أحْلَلْنا لَكَ أزْواجَكَ اللّاتِي آتَيْتَ أُجُورَهُنَّ﴾</q> صداقهن، <q>﴿وما مَلَكَتْ يَمِينُكَ مِمّا أفاءَ اللَّهُ عَلَيْكَ وبَناتِ عَمِّكَ﴾</q> أي: وأحللنا لك أيضًا بنات عمك، <q>﴿وبَناتِ عَمّاتِكَ وبَناتِ خالِكَ وبَناتِ خالاتِكَ اللّاتِي هاجَرْنَ مَعَكَ﴾</q> إلى قوله: <q>﴿لا يَحِلُّ لَكَ النِّساءُ مِن بَعْدُ﴾</q> هؤلاء اللاتي ذَكر مِن أزواجه، ومن بنات عمه، ومن بنات عماته، وبنات خاله، وبنات خالاته{15}. (ز) <q>﴿یَـٰۤأَیُّهَا ٱلنَّبِیُّ إِنَّاۤ أَحۡلَلۡنَا لَكَ أَزۡوَ ٰ⁠جَكَ ٱلَّـٰتِیۤ ءَاتَیۡتَ أُجُورَهُنَّ وَمَا مَلَكَتۡ یَمِینُكَ مِمَّاۤ أَفَاۤءَ ٱللَّهُ عَلَیۡكَ وَبَنَاتِ عَمِّكَ وَبَنَاتِ عَمَّـٰتِكَ وَبَنَاتِ خَالِكَ وَبَنَاتِ خَـٰلَـٰتِكَ ٱلَّـٰتِی هَاجَرۡنَ مَعَكَ﴾</q> - آثار متعلقة بالآية ٦٢٤٨٤- عن محمد بن كعب القرظي= (ز) ٦٢٤٨٥- وعمر بن الحكم= (ز) ٦٢٤٨٦- وعبد الله بن عبيدة -من طريق موسى بن عبيدة- قالوا: تزوج رسول الله ﷺ ثلاث عشرة امرأة؛ ست من قريش: خديجة، وعائشة، وحفصة، وأم حبيبة، وسودة، وأم سلمة، وثلاث من بني عامر بن صعصعة؛ امرأتان من بني هلال، ميمونة بنت الحارث وهي التي وهبت نفسها للنبي ﷺ، وزينب أم المساكين، وامرأة من بني بكر بن كلاب من القُرطاء، وهي التي اختارت الدنيا، وامرأة من بني الجون، وهي التي استعاذت منه، وزينب بنت جحش الأسدية، والسبيَّتان صفية بنت حيي، وجويرية بنت الحارث الخزاعية{16}. (١٢/٨٦) <q>﴿وَٱمۡرَأَةࣰ مُّؤۡمِنَةً إِن وَهَبَتۡ نَفۡسَهَا لِلنَّبِیِّ﴾</q> - قراءات ٦٢٤٨٧- عن هارون، عن أبي عمرو [البصري]، <q>﴿إن وهبت﴾</q>، قال هارون: في قراءة ابن مسعود: (وامْرَأَةً مُّؤْمِنَةً وهَبَتْ نَفْسَها لِلنَّبِيِّ){17}. (ز) <q>﴿وَٱمۡرَأَةࣰ مُّؤۡمِنَةً إِن وَهَبَتۡ نَفۡسَهَا لِلنَّبِیِّ﴾</q> - نزول الآية، وتفسيرها ٦٢٤٨٨- عن عائشة -من طريق عروة- قالت: <q>﴿وامْرَأَةً مُؤْمِنَةً إنَّ وهَبَتْ نَفْسَها لِلنَّبِيِّ﴾</q> التي وهبت نفسها للنبي ﷺ: خولة بنت حكيم{18}. (١٢/٨٥) ٦٢٤٨٩- عن عبد الله بن عباس -من طريق عكرمة- قال: <q>﴿وامْرَأَةً مُؤْمِنَةً إنَّ وهَبَتْ نَفْسَها لِلنَّبِيِّ﴾</q> لم يكن عند رسول الله ﷺ امرأة وهبت نفسها{19}. (١٢/٨٧) ٦٢٤٩٠- عن عبد الله بن عباس -من طريق قتادة- <q>﴿وامْرَأَةً مُؤْمِنَةً إنَّ وهَبَتْ نَفْسَها لِلنَّبِيِّ﴾</q>، قال: هي ميمونة بنت الحارث{20}. (١٢/٨٩) ٦٢٤٩١- عن سهل بن سعد الساعدي: أنّ امرأة جاءت إلى النبي ﷺ، فوهبتْ نفسها له، فصمتْ، فقال رجل: يا رسول الله، زوِّجنيها إن لم يكن لك بها حاجة. قال: «ما عندك تعطيها؟». قال: ما عندي إلا إزاري. قال: «إن أعطيتَها إزارك جلستْ لا إزار لك، فالتمس شيئًا». قال: ما أجدُ شيئًا. فقال: «التمس ولو خاتمًا مِن حديد». فلم يجد، فقال: «هل معك مِن القرآن شيء؟». قال: نعم، سورة كذا وسورة كذا. لسورٍ سماها، فقال: «قد زوّجناكها بما معك من القرآن»{21}. (١٢/٨٩) ٦٢٤٩٢- عن أنس بن مالك -من طريق ثابت- قال: <q>﴿وامْرَأَةً مُؤْمِنَةً إنَّ وهَبَتْ نَفْسَها لِلنَّبِيِّ﴾</q> جاءت امرأة إلى النبي ﷺ، فقالت: يا نبيَّ الله هل لك فِيَّ حاجة؟ فقالت ابنةُ أنس: ما كان أقلَّ حياءها! فقال: هي خير منكِ، رغبتْ في النبي ﷺ؛ فعرضتْ نفسها عليه{22}. (١٢/٨٩) ٦٢٤٩٣- عن علي بن الحسين بن علي بن أبي طالب -من طريق الحكم- في قوله: <q>﴿وامْرَأَةً مُؤْمِنَةً إنَّ وهَبَتْ نَفْسَها لِلنَّبِيِّ﴾</q>: هي أم شَرِيك الأزدية التي وهبت نفسها للنبي ﷺ{23}. (١٢/٨٦) ٦٢٤٩٤- عن عروة بن الزبير -من طريق هشام- <q>﴿وامْرَأَةً مُؤْمِنَةً إنَّ وهَبَتْ نَفْسَها لِلنَّبِيِّ﴾</q>: أنّ خولة بنت حكيم بن الأوقص كانت من اللاتي وهَبْنَ أنفُسَهُنَّ لرسول الله ﷺ{24}. (١٢/٨٥) ٦٢٤٩٥- عن عروة بن الزبير -من طريق هشام بن عروة- قال: <q>﴿وامْرَأَةً مُؤْمِنَةً إنَّ وهَبَتْ نَفْسَها لِلنَّبِيِّ﴾</q> كُنّا نتحدث: أنّ أم شَرِيك كانت فيمن وهبت نفسها للنبي ﷺ، وكانت امرأة صالحة{25}. (١٢/٨٩) ٦٢٤٩٦- قال مجاهد بن جبر: <q>﴿وامْرَأَةً مُؤْمِنَةً إنَّ وهَبَتْ نَفْسَها لِلنَّبِيِّ﴾</q> لم يكن عند النبي ﷺ امرأة وهبت نفسها منه، ولم يكن عنده امرأة إلا بعقد نكاح أو مِلك يمين، وإنما قال الله تعالى: <q>﴿إنَّ وهَبَتْ﴾</q> على طريق الشرط والجزاء{26}. (ز) ٦٢٤٩٧- قال الضحاك بن مزاحم: <q>﴿وامْرَأَةً مُؤْمِنَةً إنْ وهَبَتْ نَفْسَها لِلنَّبِيّ﴾</q> هي أم شَرِيك بنت جابر من بني أسْد{26}. (ز) ٦٢٤٩٨- عن عكرمة مولى ابن عباس -من طريق ابن جريج، عن أبي الزبير- في قوله: <q>﴿وامْرَأَةً مُؤْمِنَةً﴾</q>، قال: نزلت في أم شَرِيك الدوسية{28}. (١٢/٨٥) ٦٢٤٩٩- عن عكرمة مولى ابن عباس -من طريق ابن جريج، عن أبي الزبير- قال: <q>﴿وامْرَأَةً مُؤْمِنَةً إنْ وهَبَتْ نَفْسَها لِلنَّبِيّ﴾</q> وهبت ميمونة بنت الحارث نفسها للنبي ﷺ{29}. (١٢/٨٩) ٦٢٥٠٠- عن عامر الشعبي -من طريق عبد الله بن أبي السفر- <q>﴿وامْرَأَةً مُؤْمِنَةً إنْ وهَبَتْ نَفْسَها لِلنَّبِيّ﴾</q>: أنها امرأة من الأنصار وهبت نفسها للنبي ﷺ، وهي مما أرْجى{30}. (١٢/٨٧) ٦٢٥٠١- عن عامر الشعبي -من طريق فراس- قال: المرأة التي عزل رسولُ الله ﷺ أمَّ شَرِيك الأنصارية{31}. (ز) ٦٢٥٠٢- قال عامر الشعبي: <q>﴿وامْرَأَةً مُؤْمِنَةً إنْ وهَبَتْ نَفْسَها لِلنَّبِيّ﴾</q> هي زينب بنت خزيمة الهلالية، يقال لها: أم المساكين{26}. (ز) ٦٢٥٠٣- عن الحسن البصري: <q>﴿وامْرَأَةً مُؤْمِنَةً إنْ وهَبَتْ نَفْسَها لِلنَّبِيّ﴾</q> أنّ النبي ﷺ قد تطوع على تلك المرأة التي وهبت نفسها له، فأعطاها الصداق{33}. (ز) ٦٢٥٠٤- في تفسير الحسن البصري: نزل أمرُ المرأة التي وهبت نفسها للنبي ﵇ قبل أن ينزل: <q>﴿ما كانَ عَلى النبي مِن حَرَجٍ فِيما فَرَضَ اللَّهُ لَهُ﴾</q> [الأحزاب:٣٨]، وهي بعدها في التأليف{34}. (ز) ٦٢٥٠٥- عن قتادة بن دعامة -من طريق سعيد- قال: يزعمون: أنها نزلت في ميمونة بنت الحارث، أنها هي التي وهبت نفسها للنبي ﷺ{35}. (١٢/٩٠) ٦٢٥٠٦- عن محمد بن كعب القرظي= (ز) ٦٢٥٠٧- وعمر بن الحكم= (ز) ٦٢٥٠٨- وعبد الله بن عبيدة -من طريق موسى بن عُبيدة- قالوا: <q>﴿وامْرَأَةً مُؤْمِنَةً إنْ وهَبَتْ نَفْسَها لِلنَّبِيّ﴾</q> التي وهبت نفسها للنبي ﷺ: ميمونة{36}. (ز) ٦٢٥٠٩- عن منير بن عبد الله الدوسي: أن أم شَرِيك غزية بنت جابر بن حكيم الدوسية عرضت نفسها على النبي ﷺ، وكانت جميلة، فقَبِلها، فقالت عائشة: ما في امرأة حين وهبت نفسها لرجل خير. قالت أم شَرِيك: فأنا تلك. فسماها الله تعالى: <q>﴿مُؤْمِنَةً﴾</q>، فقال: <q>﴿وامْرَأَةً مُؤْمِنَةً إنْ وهَبَتْ نَفْسَها لِلنَّبِيّ﴾</q>، فلما نزلت هذه الآية قالت عائشة: إنّ الله لَيُسرِع لكَ في هواك{37}. (١٢/٨٦) ٦٢٥١٠- عن [عبد الواحد] بن أبي عون -من طريق عبد الله بن جعفر- <q>﴿وامْرَأَةً مُؤْمِنَةً إنْ وهَبَتْ نَفْسَها لِلنَّبِيّ﴾</q>: أن ليلى بنت الخطيم وهبت نفسها للنبي ﷺ، ووهبن نساءٌ أنفسَهن، فلم نسمع أنّ النبي ﷺ قَبِلَ منهنَّ أحدًا{38}. (١٢/٨٧) ٦٢٥١١- قال مقاتل بن سليمان: ثم قال تعالى: <q>﴿وامْرَأَةً مُؤْمِنَةً إنْ وهَبَتْ نَفْسَها لِلنَّبِيِّ إنْ أرادَ النبي أنْ يَسْتَنْكِحَها﴾</q>، وهي أم شَرِيك بنت جابر بن ضباب بن حجر من بني عامر بن لؤي، وكانت تحت أبي الفكر{39} الأزدي، وولدت له غلامين؛ شَريكًا ومُسلمًا، ويذكرون أنه نزل عليها دَلْوٌ مِن السماء، فشربت منه، ثم تُوفي عنها زوجها أبو الفكر، فوهبت نفسها للنبي ﷺ، فلم يقبلها{40}. (ز) <q>﴿إِن وَهَبَتۡ نَفۡسَهَا لِلنَّبِیِّ﴾</q> - قراءات ٦٢٥١٢- في قراءة عبد الله [بن مسعود]: (وامْرَأَةً مُّؤْمِنَةً وهَبَتْ نَفْسَها لِلنَّبِيِّ) بغير <q>﴿إن﴾</q>{41}٥٢٥٥. (ز) ٥٢٥٥ علَّقَ ابنُ جرير (١٩/١٣٢) على هذه القراءة بقوله: «معنى ذلك ومعنى قراءتنا -وفيها <q>﴿إن﴾</q>- واحد، وذلك كقول القائل في الكلام: لا بأس أن يطأ جاريةً مملوكةً إن ملكها، وجاريةً مملوكةً ملكها». ٦٢٥١٣- عن الحسن البصري أنه قرأ: (أن وهَبَتْ) بفتح الألف{42}٥٢٥٦. (ز) ٥٢٥٦ اخْتُلِف في قراءة قوله تعالى: <q>﴿إن وهبت﴾</q> على وجهين: الأول: بكسرالهمزة، بمعنى: إن تَهَب، أي: إن وقَعَ فهو حلال له. والثاني: بفتح الهمزة، هكذا (أن وهَبَتْ)، بمعنى: وأحللنا له امرأة مؤمنة أن ينكحها لهبتها له نفسها، فهي إشارة إلى ما وقَعَ مِن الواهبات قبل نزول الآية. وعلَّقَ ابنُ عطية (٧/١٣٢) على القراءتين بقوله: «كسر الألف يجري مع تأويل ابن زيد الذي قدمناه، وفتح الألف يجري مع التأويل الآخر». ورجَّحَ ابنُ جرير (١٩/١٣٣) قراءة الكسر، فقال: «القراءة التي لا أستجيز خلافها في ذلك كسر الألف؛ لإجماع الحجة من القراء عليه». <q>﴿إِن وَهَبَتۡ نَفۡسَهَا لِلنَّبِیِّ﴾</q> - تفسير الآية ٦٢٥١٤- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿إنْ وهَبَتْ نَفْسَها لِلنَّبِيِّ﴾</q>، قال: فَعَلَتْ ولم يفعل{43}. (١٢/٩٠) ٦٢٥١٥- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿إنْ وهَبَتْ نَفْسَها لِلنَّبِيّ﴾</q>، قال: بغير صداق، أُحِلّ له ذلك، ولم يكن ذلك أُحِلَّ إلا له{44}. (١٢/٨٤) ٦٢٥١٦- عن مجاهد بن جبر -من طريق الحكم- أنّه قال في هذه الآية: <q>﴿وامْرَأَةً مُؤْمِنَةً إنْ وهَبَتْ نَفْسَها لِلنَّبِيّ﴾</q>، قال: أن تهب{20}. (ز) ٦٢٥١٧- عن مجاهد بن جبر -من طريق الحكم- <q>﴿وامْرَأَةً مُؤْمِنَةً إنْ وهَبَتْ نَفْسَها لِلنَّبِيِّ﴾</q>، قال: لَم تهب نفسها{46}. (ز) ٦٢٥١٨- عن مجاهد بن جبر -من طريق ابن جريح-: إن وهبت نفسها بغير صداق مِمّا يَحِلُّ له ذلك خاصَّة دون كل أحد من المؤمنين{47}. (ز) ٦٢٥١٩- قال مقاتل بن سليمان: ثم قال تعالى: <q>﴿وامْرَأَةً مُؤْمِنَةً إنْ وهَبَتْ نَفْسَها لِلنَّبِيِّ﴾</q>، يعني: أن يتزوجها بغير مهر، وهي أم شَرِيك بنت جاب ر... وهبت نفسها للنبي ﷺ، فلم يقبلها، ولو فعله لكان له خاصة دون المؤمنين، فإن وهبت امرأةٌ يهوديةٌ أو نصرانيةٌ أو أعرابيةٌ نفسها فإنه لا يحلُّ للنبي ﷺ أن يتزوجها{48}. (ز) ٦٢٥٢٠- قال يحيى بن سلّام: قوله ﷿: <q>﴿وامْرَأَةً مُؤْمِنَةً إنْ وهَبَتْ نَفْسَها لِلنَّبِيِّ إنْ أرادَ النبي أنْ يَسْتَنْكِحَها خالِصَةً لَكَ﴾</q> يقول: للنبي ﷺ <q>﴿مِن دُونِ المُؤْمِنِينَ﴾</q> مقرأ العامة على (أنْ وهَبَتْ نَفْسَها لِلنَّبِيِّ) يقولون: كانت امرأة واحدة، و(أن) مفتوحة لما قد كان، وبعضهم يقرأها: <q>﴿إنْ وهَبَتْ نَفْسَها﴾</q> يقولون: في المستقبل؛ على تلك الوجوه من قول أُبي، وقول الحسن، وقول مجاهد{49}. (ز) <q>﴿خَالِصَةࣰ لَّكَ مِن دُونِ ٱلۡمُؤۡمِنِینَۗ﴾</q> - تفسير ٦٢٥٢١- عن أنس بن مالك -من طريق أبان- قال: <q>﴿خالِصَةً لَكَ مِن دُونِ المُؤْمِنِينَ﴾</q> لم تَحِلَّ الهِبَةُ لأحد بعد رسول الله ﷺ{50}. (ز) ٦٢٥٢٢- عن سعيد بن المسيب -من طريق يزيد بن عبد الله بن قسيط- قال: <q>﴿خالِصَةً لَكَ مِن دُونِ المُؤْمِنِينَ﴾</q>، لا تحل الهبة لأحد بعد رسول الله ﷺ، ولو أصدقها سوطًا لحلَّت له{51}. (١٢/٨٧) ٦٢٥٢٣- عن إبراهيم النخعي -من طريق عبد الكريم-= (ز) ٦٢٥٢٤- ومحمد بن شهاب الزهري -من طريق معمر- في قوله: <q>﴿خالِصَةً لَكَ مِن دُونِ المُؤْمِنِينَ﴾</q>، قالا: لا تحل الهبة لأحد بعد رسول الله ﷺ{52}. (١٢/٨٨) ٦٢٥٢٥- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿خالِصَةً لَكَ مِن دُونِ المُؤْمِنِينَ﴾</q>، قال: أحل له ذلك خاصة دون المؤمنين{53}. (١٢/٨٤) ٦٢٥٢٦- عن صالح بن مسلم، قال: سألتُ الشعبيَّ عن امرأة وهبت نفسها لرجل. قال: لا يكون، لا تَحِلُّ له، إنما كانت للنبي ﷺ{54}. (ز) ٦٢٥٢٧- عن عكرمة مولى ابن عباس، في قوله: <q>﴿خالِصَةً لَكَ مِن دُونِ المُؤْمِنِينَ﴾</q>، قال: لا تحل الموهوبة لغيرك، ولو أنّ امرأة وهبت نفسها لرجل لم تَحِلَّ له حتى يعطيها شيئًا{55}. (١٢/٩٠) ٦٢٥٢٨- عن طاووس بن كيسان -من طريق ابن طاووس- قال: <q>﴿خالِصَةً لَكَ مِن دُونِ المُؤْمِنِينَ﴾</q>، لا يحل لأحد أن يهب ابنته بغير مهر إلا للنبي ﷺ{56}. (١٢/٨٨) ٦٢٥٢٩- عن الحسن البصري -من طريق سليمان بن أرقم- <q>﴿خالِصَةً لَكَ مِن دُونِ المُؤْمِنِينَ﴾</q>: لا تكون الهبة بغير صداق إلا للنبي ﷺ{50}. (ز) ٦٢٥٣٠- عن عطاء [بن أبي رباح] -من طريق عبد الملك- <q>﴿خالِصَةً لَكَ مِن دُونِ المُؤْمِنِينَ﴾</q>، قال في امرأة وهبت نفسها لرجل، قال: لا يصلح إلا بصداق، لم يكن ذلك إلا للنبي ﷺ{58}. (١٢/٨٨) ٦٢٥٣١- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿خالِصَةً لَكَ مِن دُونِ المُؤْمِنِينَ﴾</q>، يقول: ليس لامرأة أن تهب نفسها لرجل بغير أمر ولِيٍّ ولا مهر، إلا للنبي ﷺ؛ كانت خاصة له من دون الناس{59}. (١٢/٩٠) ٦٢٥٣٢- عن مكحول= (ز) ٦٢٥٣٣- ومحمد بن شهاب الزهري -من طريق عبد الله بن عبيد- قالا: <q>﴿خالِصَةً لَكَ مِن دُونِ المُؤْمِنِينَ﴾</q> لم تحل الموهوبة لأحد بعد رسول الله ﷺ{60}. (١٢/٨٨) ٦٢٥٣٤- عن محمد ابن شهاب الزهري -من طريق معمر- قال: <q>﴿خالِصَةً لَكَ مِن دُونِ المُؤْمِنِينَ﴾</q> لا يحل لرجل أن يهب ابنته بغير صداق، قد جعل الله ذلك للنبي ﷺ خاصة دون المؤمنين{61}. (١٢/٨٨) ٦٢٥٣٥- قال مقاتل بن سليمان: <q>﴿خالِصَةً لَكَ﴾</q> الهبة، يعني: خاصة لك، يا محمد، <q>﴿مِن دُونِ المُؤْمِنِينَ﴾</q> لا تحل هبة المرأة نفسَها بغير مهرٍ لغيرك مِن المؤمنين، وكانت أم شَرِيك قبل أن تهب نفسها للنبي ﷺ امرأة أبي الفكر الأزدي ثم الدوسي، مِن رهط أبي هريرة{48}. (ز) ٦٢٥٣٦- قال يحيى بن سلّام: قوله ﷿: <q>﴿خالِصَةً لَكَ مِن دُونِ المُؤْمِنِينَ﴾</q> لا تكون الهبة بغير صداق إلا للنبي ﷺ{63}٥٢٥٧. (ز) ٥٢٥٧ قال ابنُ عطية (٧/١٣٣ بتصرف): «أجمع الناسُ على أن ذلك لا يجوز، إلا ما روي عن أبي حنيفة ومحمد بن الحسن وأبي يوسف أنهم قالوا: إذا وهبت فأشهد هو على نفسه بمهر فذلك جائز. فليس في قولهم إلا تجويز العبارة بلفظة الهبة، وإلا فالأفعال التي اشترطوها هي أفعال النكاح بعينه». وقال ابنُ تيمية (٥/٢٥٣): «ليس هذا لغيره باتفاق المسلمين». <q>﴿خَالِصَةࣰ لَّكَ مِن دُونِ ٱلۡمُؤۡمِنِینَۗ﴾</q> - آثار متعلقة بالآية ٦٢٥٣٧- عن الحسن البصري: أنّ النبيَّ ﷺ قد تطوع على تلك المرأة التي وهبت نفسها له، فأعطاها الصداق{64}. (ز) <q>﴿قَدۡ عَلِمۡنَا مَا فَرَضۡنَا عَلَیۡهِمۡ فِیۤ أَزۡوَ ٰ⁠جِهِمۡ وَمَا مَلَكَتۡ أَیۡمَـٰنُهُمۡ﴾</q> - تفسير ٦٢٥٣٨- عن أُبَي بن كعب -من طريق زياد؛ رجل مِن الأنصار-: أنّ التي أحل الله للنبي من النساء هؤلاء اللاتي ذَكر الله: <q>﴿يا أيُّها النبي إنّا أحْلَلْنا لَكَ أزْواجَكَ اللّاتِي آتَيْتَ أُجُورَهُن﴾</q> إلى قوله: <q>﴿فِي أزْواجِهِمْ﴾</q>، وإنما أحل الله للمؤمنين مثنى وثلاث ورباع{65}٥٢٥٨. (ز) ٥٢٥٨ قال ابنُ عطية (٧/١٣٣): «يظهر من لفظ أبي بن كعب أن معنى قوله: <q>﴿خالصة لك﴾</q> يراد به جميع الإباحة؛ لأن المؤمنين قُصِروا على مثنى وثلاث ورباع». ٦٢٥٣٩- عن أُبَي بن كعب -من طريق موسى بن عبد الله-: <q>﴿قَدْ عَلِمْنا ما فَرَضْنا عَلَيْهِمْ فِي أزْواجِهِمْ﴾</q> يعني: الأربع، يقول: يتزوَّج أربعًا إن شاء، <q>﴿وما مَلَكَتْ أيْمانُهُمْ﴾</q> ويطأ بملك يمينه كم شاء{66}. (ز) ٦٢٥٤٠- عن عبد الله بن عباس، في قوله: <q>﴿قَدْ عَلِمْنا ما فَرَضْنا عَلَيْهِمْ فِي أزْواجِهِمْ﴾</q>، قال: فرض عليهم ألّا نكاح إلا بوَلِيٍّ، وشاهدين، ومهر{67}. (١٢/٩١) ٦٢٥٤١- عن عبد الله بن عمر -من طريق نافع- في قوله: <q>﴿قَدْ عَلِمْنا ما فَرَضْنا عَلَيْهِمْ فِي أزْواجِهِمْ﴾</q>، قال: فَرَض عليهم ألاَّ نكاح إلا بوَلِيٍّ وشاهدين{68}. (١٢/٩١) ٦٢٥٤٢- عن عبد الله بن عمر، في قوله: <q>﴿قَدْ عَلِمْنا ما فَرَضْنا عَلَيْهِمْ فِي أزْواجِهِمْ﴾</q>، قال: لا يجاوز الرجلُ أربعَ نسوة{69}. (١٢/٩١) ٦٢٥٤٣- عن مجاهد بن جبر -من طريق ليث- في قوله: <q>﴿قَدْ عَلِمْنا ما فَرَضْنا عَلَيْهِمْ فِي أزْواجِهِمْ﴾</q>، قال: لا يُجاوِز الرجلُ أربعَ نسوة{70}. (١٢/٩١) ٦٢٥٤٤- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿قَدْ عَلِمْنا ما فَرَضْنا عَلَيْهِمْ﴾</q>، قال: فرض اللهُ أن لا تُنكَح امرأةٌ إلا بولي وصداق وشهداء، ولا ينكِح الرجلُ إلا أربعًا{71}. (١٢/٩٠) ٦٢٥٤٥- قال إسماعيل السُّدِّيّ: <q>﴿قَدْ عَلِمْنا ما فَرَضْنا عَلَيْهِمْ فِي أزْواجِهِم﴾</q>، يعني: ما أوجبنا عليهم{33}. (ز) ٦٢٥٤٦- قال مقاتل بن سليمان: ثم أخبر الله عن المؤمنين، فقال: <q>﴿قَدْ عَلِمْنا ما فَرَضْنا عَلَيْهِمْ﴾</q> يعني: ما أوجبنا على المؤمنين <q>﴿فِي أزْواجِهِمْ﴾</q> ألّا يتزوجوا إلّا أربع نسوة بمهر وبيِّنة، <q>﴿وما مَلَكَتْ أيْمانُهُمْ﴾</q> وأحللنا لهم ما ملكت أيمانهم، يعني: جِماع الولاية{73}. (ز) ٦٢٥٤٧- قال يحيى بن سلّام: <q>﴿قَدْ عَلِمْنا ما فَرَضْنا عَلَيْهِمْ فِي أزْواجِهِمْ﴾</q> فإن تزوج الرجلُ امرأةً ولم يُسمِّ لها صداقًا أو وهبها له الولي فرضيتْ، أو كانت بِكْرًا فزوَّجها أبوها، فإن ذلك جائز عليها، فلها ما اتفقوا عليه من الصداق، فإن اختلفوا فلها صداق مثلها، والنكاح ثابت{74}. (ز) <q>﴿لِكَیۡلَا یَكُونَ عَلَیۡكَ حَرَجࣱۗ وَكَانَ ٱللَّهُ غَفُورࣰا رَّحِیمࣰا ۝٥٠﴾</q> - تفسير ٦٢٥٤٨- عن قتادة بن دعامة، في قوله: <q>﴿لِكَيْلا يَكُونَ عَلَيْكَ حَرَجٌ﴾</q>، قال: جعله الله في حِلٍّ مِن ذلك، وكان نبيُّ الله ﷺ يَقْسِم{12}. (١٢/٩١) ٦٢٥٤٩- قال مقاتل بن سليمان: <q>﴿لِكَيْلا يَكُونَ عَلَيْكَ﴾</q> يا محمد <q>﴿حَرَجٌ﴾</q> في الهبة بغير مهر، فيها تقديم، <q>﴿وكانَ اللَّهُ غَفُورًا﴾</q> في التزويج بغير مهر للنبي ﷺ، <q>﴿رحيمًا﴾</q> في تحليل ذلك له{73}. (ز) ٦٢٥٥٠- قال يحيى بن سلّام: قوله ﷿: <q>﴿لِكَيْلا يَكُونَ عَلَيْكَ حَرَجٌ﴾</q> رجع إلى قصة النبي ﷺ{77}. (ز) ",footnotes:1:أخرجه ابن جرير ١٩/١٣٠، وإسحاق البستي ص١٣٤. وهي قراءة شاذة. انظر: معاني القرآن للفراء ٢/٣٤٥، والمحرر الوجيز ٤/٣٩١.أخرجه ابن عدي في الكامل ٢/٧٠، من طريق أحمد بن أبي طيبة، عن عنبسة بن الأزهر، عن إسماعيل بن أبي خالد، عن أبي صالح، عن أم هانئ به. وعزاه السيوطي إلى ابن أبي حاتم، وابن مردويه. إسناده ضعيف؛ فيه باذام، ويقال: باذان، أبو صالح مولى أم هانئ، قال عنه ابن حجر في التقريب (٦٣٤): «ضعيف مدلّس».أخرجه الترمذي ٥/٤٢٧ (٣٤٩٣)، والحاكم ٢/٢٠٢ (٢٧٥٤)، ٢/٤٥٦ (٣٥٧٤)، ٤/٥٨ (٦٨٧٢)، وابن جرير ١٩/١٣٠-١٣١، وابن أبي حاتم -كما في تفسير ابن كثير ٦/٤٤٢-. قال الترمذي: «هذا حديث حسن، لا نعرفه إلا من هذا الوجه من حديث السدي». وقال الحاكم: «هذا حديث صحيح الإسناد، ولم يخرجاه».مُوتِـمــــَة: رُزئت بمصيبة فقْد زوجها. اللسان (أتم).أخرجه ابن سعد ٨/١٥٣.أخرجه يحيى بن سلّام ٢/٧٢٨.أخرجه ابن جرير ١٩/١٣٤. وعزاه السيوطي إلى ابن مردويه.أخرجه ابن سعد في الطبقات ١٠/١٨٧.تفسير مجاهد (٥٥٠) مقتصرًا على الشطر الأول، وأخرجه ابن جرير ١٩/١٢٩-١٣٠. وعزاه السيوطي إلى الفريابي، وعبد بن حميد، وابن المنذر، وابن أبي حاتم.أخرجه ابن جرير ١٩/١٣٠، وإسحاق البستي ص١٣٠.أخرجه إسحاق البستي ص١٣٠، وابن جرير ١٩/١٣٠ مختصرًا.عزاه السيوطي إلى ابن المنذر.تفسير مقاتل بن سليمان ٣/٥٠٠.أخرجه ابن جرير ١٩/١٣٠.تفسير يحيى بن سلّام ٢/٧٢٨.أخرجه ابن أبي حاتم -كما في تفسير ابن كثير ٦/٤٤٤ (ت: سامي السلامة)-. وعزاه السيوطي إلى ابن أبي شيبة.أخرجه إسحاق البستي ص١٣١. وهي قراءة شاذة. انظر: مختصر ابن خالويه ص١٢١.أخرجه ابن أبي حاتم -كما في تفسير ابن كثير ٦/٤٣٥-، وابن مردويه -كما في التغليق ٤/٤١١-، والبيهقي في سننه ٧/٥٥.أخرجه ابن جرير ١٩/١٣٤، وابن أبي حاتم -كما في تفسير ابن كثير ٦/٤٣٦-، والطبراني (١١٧٨٧)، والبيهقي في سننه ٧/٥٥. وعزاه السيوطي إلى ابن مردويه.أخرجه ابن جرير ١٩/١٣٥.أخرجه البخاري ٣/١٠٠-١٠١ (٢٣١٠)، ٦/١٩٢-١٩٣ (٥٠٢٩، ٥٠٣٠)، ٧/٦-٧ (٥٠٨٧)، ٧/١٣ (٥١٢١)، ٧/١٤-١٥ (٥١٢٦)، ٧/١٧ (٥١٣٢، ٥١٣٥)، ٧/١٨-١٩ (٥١٤١)، ٧/٢٠ (٥١٤٩، ٥١٥٠)، ٧/١٥٦-١٥٧ (٥٨٧١)، ٩/١٢٤ (٧٤١٧)، ومسلم ٢/١٠٤٠ (١٤٢٥).أخرجه البخاري (٥١٢٠، ٦١٢٣). وعزاه السيوطي إلى ابن مردويه.أخرجه ابن سعد ٨/١٥٥، وابن أبي شيبة ٤/٣١٥، وابن جرير ١٩/١٣٥، والطبراني ٢٤/٣٥١ (٨٧٠) واللفظ له. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه عبد الرزاق (١٢٢٦٨، ١٢٢٦٩)، وابن سعد ٨/١٥٨، وابن أبي شيبة ٤/٣١٥، والبخاري (٥١١٣)، وابن جرير ١٩/١٣٦ بنحوه. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم، وابن مردويه.أخرجه ابن أبي شيبة ٤/٣١٥، وابن جرير ١٩/١٣٦. وعزاه السيوطي إلى عبد بن حميد، وابن أبي حاتم، وابن مردويه.تفسير الثعلبي ٨/٥٤، وتفسير البغوي ٦/٣٦٤.تفسير الثعلبي ٨/٥٤، وتفسير البغوي ٦/٣٦٤.أخرجه ابن سعد ٨/١٥٥.أخرجه عبد الرزاق (١٢٢٦٦)، وابن سعد ٨/١٣٧. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه ابن أبي شيبة ٤/٣١٦، وابن جرير ١٩/١٣٦.أخرجه ابن سعد ٨/١٥٥، وأخرجه ابن أبي حاتم -كما في الفتح ٨/٥٢٥- بلفظ: من الواهبات أم شَرِيك.تفسير الثعلبي ٨/٥٤، وتفسير البغوي ٦/٣٦٤.علقه يحيى بن سلّام ٢/٧٣٠.علّقه يحيى بن سلّام ٢/٧٣٠.أخرجه ابن جرير ١٩/١٣٢. وعزاه السيوطي إلى عبد بن حميد، وابن أبي حاتم. وفي تفسير الثعلبي ٨/٥٤، وتفسير البغوي ٦/٣٦٤ بلفظ: هي ميمونة بنت الحارث.أخرجه ابن أبي شيبة في مصنفه (ت: محمد عوامة) ٩/٣٤٤-٣٤٥ (١٧٤٦١).أخرجه ابن سعد ٨/١٥٥-١٥٦ مطولًا.أخرجه ابن سعد ٨/١٥١.كذا بالفاء، وعند ابن سعد بالعين ٨/١٥٥-١٥٦، وينظر: الإصابة ٣/٣٤٨. وقد ذكر ابن سعد قصتها مطولة من رواية منير بن عبد الله الدوسي، وتقدم مختصرها في الأثر السابق، وفيه أنها أزدية.تفسير مقاتل بن سليمان ٣/٥٠١. وفي تفسير الثعلبي ٨/٥٤، وتفسير البغوي ٦/٣٦٤ عن مقاتل -دون تعيينه- قال: هي أم شَرِيك بنت جابر من بني أسد.تفسير ابن جرير ١٩/١٣٢.تفسير ابن جرير ١٩/١٣٣.أخرجه ابن أبي شيبة ٤/٣١٦ واللفظ له. وعزاه السيوطي إلى ابن جرير، وابن المنذر.تفسير مجاهد (٥٥٠)، وأخرجه ابن جرير ١٩/١٣٢. وعزاه السيوطي إلى الفريابي، وعبد بن حميد، وابن أبي حاتم.أخرجه ابن جرير ١٩/١٣٥.أخرجه ابن أبي شيبة في مصنفه (ت: محمد عوامة) ١٩/٣٤٢-٣٤٣ (١٧٤٥٧)، وإسحاق البستي ص١٣٠.أخرجه إسحاق البستي ص١٣٠.تفسير مقاتل بن سليمان ٣/٥٠١.تفسير يحيى بن سلّام ٢/٧٢٩.أخرجه يحيى بن سلّام ٢/٧٣٠.أخرجه يحيى بن سلّام ٢/٧٢٠، وعبد الرزاق (١٢٢٧٢)، والبيهقي ٧/٥٥. وعزاه السيوطي إلى سعيد بن منصور، وابن أبي شيبة، وعبد بن حميد، وابن المنذر.أخرجه عبد الرزاق في مصنفه ٧/٧٦ (١٢٢٧٠) عن الزهري وحده، وابن سعد ٨/٢٠١ عن الزهري وإبراهيم. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.تفسير مجاهد (٥٥٠)، وأخرجه ابن جرير ١٩/١٣٢. وعزا السيوطيُّ نحوه إلى الفريابي، وعبد بن حميد، وابن أبي حاتم.أخرجه ابن جرير ١٩/١٣٣.عزاه السيوطي إلى عبد بن حميد، وابن أبي حاتم.أخرجه ابن أبي شيبة ٤/٣٤٢-٣٤٣.أخرجه يحيى بن سلّام ٢/٧٣٠.أخرجه عبد الرزاق (١٢٢٦٥) بنحوه، وابن أبي شيبة ٤/٣٤٣. وعزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ١٩/١٣٢. وعزاه السيوطي إلى عبد بن حميد، وابن أبي حاتم.أخرجه ابن أبي شيبة ٤/٣٤٣.أخرجه عبد الرزاق ٢/١١٩ بنحوه. وعزاه السيوطي إلى عبد بن حميد.تفسير مقاتل بن سليمان ٣/٥٠١.تفسير يحيى بن سلّام ٢/٧٢٩-٧٣٠.علَّقه يحيى بن سلّام ٢/٧٢٣، ٧٣٠.أخرجه ابن جرير ١٩/١٣٤.أخرجه يحيى بن سلّام ٢/٧٣١.أخرجه ابن مردويه -كما في فتح الباري ٨/٥٢٦-.أخرجه ابن مردويه -كما في فتح الباري ٨/٥٢٦-، وابن عدي في الكامل ٩/١٥ بزيادة قوله: وصدقة.عزاه السيوطي إلى ابن مردويه.أخرجه ابن جرير ١٩/١٣٧ بنحوه. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.أخرجه يحيى بن سلّام ٢/٧٣١ بنحوه، وعبد الرزاق ٢/١١٩-١٢٠ من طريق معمر، وابن جرير ١٩/١٣٧. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم. وأخرج ابن جرير عنه ١٩/١٣٧ من طريق مطر بلفظ: إن مما فرض الله عليهم أن لا نكاح إلا بولي وشاهدين.علقه يحيى بن سلّام ٢/٧٣٠.تفسير مقاتل بن سليمان ٣/٥٠٢.تفسير يحيى بن سلّام ٢/٧٣١. وقد أورد السيوطي عقب تفسير هذه الآية ١٢/٩١-٩٣ آثارًا عديدة عن حرمة وطء الحبالى مِن السبايا حتى يضعن.عزاه السيوطي إلى ابن المنذر.تفسير مقاتل بن سليمان ٣/٥٠٢.تفسير يحيى بن سلّام ٢/٧٣١.
