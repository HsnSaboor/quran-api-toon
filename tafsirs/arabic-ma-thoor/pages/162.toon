quran[8]{c,v,t}:
  7,88,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿قَالَ ٱلۡمَلَأُ ٱلَّذِینَ ٱسۡتَكۡبَرُوا۟ مِن قَوۡمِهِۦ لَنُخۡرِجَنَّكَ یَـٰشُعَیۡبُ وَٱلَّذِینَ ءَامَنُوا۟ مَعَكَ مِن قَرۡیَتِنَاۤ أَوۡ لَتَعُودُنَّ فِی مِلَّتِنَاۚ قَالَ أَوَلَوۡ كُنَّا كَـٰرِهِینَ ۝٨٨﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٢٨٢٥٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿قال الملأ الذين استكبروا من قومه﴾</span> يعني: الذين تكبَّروا عن الإيمان، وهم الكبراء: <span class="qpc-hafs">﴿لنخرجنك يا شعيب والذين آمنوا معك من قريتنا أو لتعودن في ملتنا﴾</span> يعنون: الشرك؛ أو لتدخلن في ملتنا، <span class="qpc-hafs">﴿قال أولو كنا كارهين﴾</span>{1}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٢/٤٩.
  7,89,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿قَدِ ٱفۡتَرَیۡنَا عَلَى ٱللَّهِ كَذِبًا إِنۡ عُدۡنَا فِی مِلَّتِكُم بَعۡدَ إِذۡ نَجَّىٰنَا ٱللَّهُ مِنۡهَاۚ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٢٨٢٥٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثُمَّ قال لهم شعيب: <span class="qpc-hafs">﴿قد افترينا على الله كذبا إن عدنا في ملتكم﴾</span> الشرك، يعني: إن دخلنا في دينكم <span class="qpc-hafs">﴿بعد إذ نجانا الله منها﴾</span> يقول: بعد إذ لم يجعلنا الله من أهل ملتكم الشرك{1}<span class=comment-ref>٢٥٨٧</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٢٥٨٧</span> بيّن <u>ابنُ عطية</u> (٣/٦١٣-٦١٤) أن لـ<span class="qpc-hafs">﴿عدنا﴾</span> معنيين في كلام العرب، <b>الأول</b>: أن تكون بمعنى عَوْد الشيء إلى حال كان عليها قبل ذلك. <b>الثاني</b>: أن تكون بمعنى: صار، ولا تتضمن أن الحال كانت متقدمة. ثم قال <span class="comment-type-4">معلِّقًا</span>: «وشعيب ﵇ لم يكن قط كافرًا، يقتضي أنها بمعنى: صار، وأمّا في جهة المؤمنين بعد كفرهم فيترتب المعنى الآخر، ويخرج عنه شعيب، إلا أن يريدوا عَوْدته إلى حال سكوته قبل أن يبعث».</p><p>والظاهر مِن كلام <u>ابن تيمية</u> (٣/١٧٤- ١٧٨) أنه فسَّر <span class="qpc-hafs">﴿إن عدنا في ملتكم﴾</span> بأنّ العَوْد هنا هو الرجوع إلى حال قومه من الكفر.</div></p><p><h3><span class="qpc-hafs">﴿وَمَا یَكُونُ لَنَاۤ أَن نَّعُودَ فِیهَاۤ إِلَّاۤ أَن یَشَاۤءَ ٱللَّهُ رَبُّنَاۚ وَسِعَ رَبُّنَا كُلَّ شَیۡءٍ عِلۡمًاۚ عَلَى ٱللَّهِ تَوَكَّلۡنَاۚ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٢٨٢٥٨<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- في قوله: <span class="qpc-hafs">﴿وما يكون لنا أن نعود فيها﴾</span> قال: ما ينْبغِي لنا أن نعودَ في شِرْكِكم بعدَ إذْ نجّانا الله، <span class="qpc-hafs">﴿إلا أن يشاء الله ربنا﴾</span> واللهُ لا يشاءُ الشرك، ولكن يقول: إلا أن يكونَ اللهُ قد عَلِم شيئًا؛ فإنّه قد وسِع كلَّ شيءٍ علمًا{2}<span class=comment-ref>٢٥٨٨</span>. (٦/٤٨٠)</p></p><p></div></p><p><div><span class=comment-ref>٢٥٨٨</span> لم يذكر <u>ابنُ جرير</u> (١٠/٣١٩) في تفسير قوله تعالى: <span class="qpc-hafs">﴿وما يكون لنا أن نعود فيها إلا أن يشاء الله ربنا﴾</span> غير قول السدي.</p><p>وذكر <u>ابنُ عطية</u> (٣/٦١٥ بتصرف) عدة احتمالات في الاستثناء الوارد في الآية: <b>أولها</b>: أن يريد: إلا أن يسبق علينا من الله في ذلك سابقٌ وسوء وينفذ منه قضاء لا يرد. وهو موافق لقول السدي، وقد <span class="comment-type-1">وجَّهه</span> بقوله: «والمؤمنون هم المُجَوِّزون لذلك، وشعيب قد عَصَمَتْه النبوة». و<span class="comment-type-3">رجّحه</span> مستندًا إلى <span class="mustanad">ظاهر الآية</span> بقوله: «وهذا أظهر ما يحتمل القول ... وقوله: <span class="qpc-hafs">﴿عَلى اللَّهِ تَوَكَّلْنا﴾</span> استسلام لله، وتمسك بلفظه، وذلك يؤيد التأويل الأول في قوله: <span class="qpc-hafs">﴿إلا أن يشاء الله﴾</span>». <b>ثانيها</b>: ويحتمل أن يريد استثناء ما يمكن أن يَتعبد اللهُ به المؤمنين مما يفعله الكفار من القربات. <b>ثالثها</b>: ويحتمل أن يريد بذلك معنى الاستبعاد، كما تقول: لا أفعل كذا حتى يشيب الغراب. وهذا تأويل <span class="comment-type-2">إنما هو للمعتزلة</span> الذين من مذهبهم أنّ الكفر والإيمان ليسا بمشيئة من الله تعالى، فلا يترتب هذا التأويل إلا عندهم، وهذا تأويل حكاه المفسرون ولم يشعروا بما فيه. <b>رابعها</b>: إنّ هذا الاستثناء إنما هو تستر وتأدب. <span class="comment-type-2">ويقلق</span> هذا التأويل من جهة استقبال الاستثناء، ولو كان في الكلام «إن شاء الله» قوي هذا التأويل.</div></p><p><div></p><p><p><span class="item-no">٢٨٢٥٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وما يكون لنا أن نعود فيها﴾</span> وما ينبغي لنا أن ندخل في ملتكم الشرك، <span class="qpc-hafs">﴿إلا أن يشاء الله ربنا﴾</span> فيدخلنا في ملتكم، <span class="qpc-hafs">﴿وسع﴾</span> يعني: مَلَأَ <span class="qpc-hafs">﴿ربنا كل شيء علما﴾</span> فعلمه، <span class="qpc-hafs">﴿على الله توكلنا﴾</span> لقولهم لشعيب: <span class="qpc-hafs">﴿لنخرجنك يا شعيب والذين آمنوا معك من قريتنا﴾</span>{1}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿رَبَّنَا ٱفۡتَحۡ بَیۡنَنَا وَبَیۡنَ قَوۡمِنَا بِٱلۡحَقِّ وَأَنتَ خَیۡرُ ٱلۡفَـٰتِحِینَ ۝٨٩﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٢٨٢٦٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق قتادة- قال: ما كنتُ أدري ما قولُه: <span class="qpc-hafs">﴿ربنا افتح بيننا وبين قومنا بالحق﴾</span> حتّى سمعتُ ابنةَ ذي يَزَنَ تقولُ: تعال أُفاتِحُك. يعني: أُقاضِيك{4}. (٦/٤٨١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٨٢٦١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- في قوله: <span class="qpc-hafs">﴿ربنا افتح﴾</span>، يقول: اقْضِ{5}. (٦/٤٨١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٨٢٦٢<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق ابن جريج-: <span class="qpc-hafs">﴿افتح﴾</span> الحكم؛ احكم بيننا وبين قومنا، و<span class="qpc-hafs">﴿إنا فتحنا لك فتحا مبينا﴾</span> [الفتح:١]: حكمنا لك حكمًا مبينًا{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٨٢٦٣<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق مَعْمَر- في قوله: <span class="qpc-hafs">﴿ربنا افتح بيننا وبين قومنا بالحق﴾</span>، قال: ربنا اقضِ بيننا وبين قومنا بالحق{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٨٢٦٤<span class="dash">-</span></span> قال <span class="name-2">قتادة بن دعامة</span>: وإذا دعا النبيُّ ربَّه أن يحكم بينه وبين قومه جاءهم العذاب{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٨٢٦٥<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- <span class="qpc-hafs">﴿رَبَّنا افْتَحْ بَيْنَنا﴾</span>، فيقول: احكم بيننا{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٨٢٦٦<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span>، قال: الفتحُ: القضاء، لغةٌ يَمانِية، إذا قال أحدُهم: تعالَ أُقاضِيك القضاء، قال: تعالَ أُفاتِحك{10}. (٦/٤٨١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٨٢٦٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: قال شعيب: <span class="qpc-hafs">﴿ربنا افتح﴾</span> يعني: اقضِ <span class="qpc-hafs">﴿بيننا وبين قومنا بالحق﴾</span> يعني: بالعدل في نزول العذاب بهم، <span class="qpc-hafs">﴿وأنت خير الفاتحين﴾</span> يعني: القاضين{1}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿رَبَّنَا ٱفۡتَحۡ بَیۡنَنَا وَبَیۡنَ قَوۡمِنَا بِٱلۡحَقِّ وَأَنتَ خَیۡرُ ٱلۡفَـٰتِحِینَ ۝٨٩﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٢٨٢٦٨<span class="dash">-</span></span> عن عون، قال: كان عبد الله بن مسعود إذا خرج من بيته قال: بسم الله، توكلت على الله، لا حول ولا قوة إلا بالله. فقال <span class="name-2">محمد بن كعب القرظي</span>: هذا في القرآن: <span class="qpc-hafs">﴿اركبوا فيها بسم الله﴾</span> [هود:٤١]، وقال: <span class="qpc-hafs">﴿على الله توكلنا﴾</span>{12}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٨٢٦٩<span class="dash">-</span></span> عن <span class="name-2">زيد بن أسلم</span> أنّه قال في القَدَرِيَّة: واللهِ، ما قالوا كما قال الله، ولا كما قال النَّبِيُّون، ولا كما قال أصحابُ الجنة، ولا كما قال أصحابُ النار، ولا كما قال أخوهم إبليس، قال الله: <span class="qpc-hafs">﴿وما تشاؤون إلا أن يشاء الله﴾</span> [الإنسان:٣٠]. وقال شعيبٌ: <span class="qpc-hafs">﴿وما يكون لنا أن نعود فيها إلا أن يشاء الله﴾</span>. وقال أصحاب الجنة: <span class="qpc-hafs">﴿الحمد لله الذي هدانا لهذا وما كنا لنهتدي لولا أن هدانا الله﴾</span> [الأعراف:٤٣]. وقال أصحاب النار: <span class="qpc-hafs">﴿ولكن حقت كلمة العذاب على الكافرين﴾</span> [الزمر:٧١]. وقال إبليسُ: <span class="qpc-hafs">﴿رب بما أغويتني﴾</span> [الحجر:٣٩]{13}. (٦/٤٨٠)</p></p><p></div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٢/٤٩.|2:أخرجه ابن جرير ١٠/٣١٩، وابن أبي حاتم ٥/١٥٢٣. وعزاه السيوطي إلى أبي الشيخ.|3:تفسير مقاتل بن سليمان ٢/٤٩.|4:أخرجه ابن أبي شيبة ٨/٥٢٩، وابن جرير ١٠/٣٢٠، وابن أبي حاتم ٥/١٥٢٣، والبيهقي في الأسماء والصفات (١٠٧). وعزاه السيوطي إلى عبد بن حميد، وابن الأنباري في الوقف والابتداء.|5:أخرجه ابن جرير ١٠/٣٢١، وابن أبي حاتم ٥/١٥٢٣. وعزاه السيوطي إلى ابن المنذر.|6:أخرجه ابن جرير ١٠/٣٢١.|7:أخرجه عبد الرزاق ٢/٢٣٣، وابن جرير ١٠/٣٢١.|8:ذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٢/١٣٣-.|9:أخرجه ابن جرير ١٠/٣٢١.|10:عزاه السيوطي إلى ابن أبي حاتم.|11:تفسير مقاتل بن سليمان ٢/٤٩.|12:أخرجه الطبراني في المعجم الكبير ٩/١٨٠ (٨٨٨٩).|13:عزاه السيوطي إلى الزبير بن بكّار في الموفَّقِيات.
  7,90,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَقَالَ ٱلۡمَلَأُ ٱلَّذِینَ كَفَرُوا۟ مِن قَوۡمِهِۦ لَىِٕنِ ٱتَّبَعۡتُمۡ شُعَیۡبًا إِنَّكُمۡ إِذࣰا لَّخَـٰسِرُونَ ۝٩٠﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٢٨٢٧٠<span class="dash">-</span></span> قال <span class="name-1">عبد الله بن عباس</span>: <span class="qpc-hafs">﴿إنكم إذا لخاسرون﴾</span>: مَغْبُونُون{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٨٢٧١<span class="dash">-</span></span> قال <span class="name-2">الضحاك بن مزاحم</span>: <span class="qpc-hafs">﴿إنكم إذا لخاسرون﴾</span>: عجَزَة{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٨٢٧٢<span class="dash">-</span></span> قال <span class="name-2">عطاء:</span> <span class="qpc-hafs">﴿إنكم إذا لخاسرون﴾</span>: جاهلون{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٨٢٧٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وقال الملأ الذين كفروا بالله من قومه﴾</span> وهم الكبراء للضعفاء: <span class="qpc-hafs">﴿لئن اتبعتم شعيبا﴾</span> على دينه <span class="qpc-hafs">﴿إنكم إذا لخاسرون﴾</span> يعني: لَعَجَزة. نظيرها في يوسف: <span class="qpc-hafs">﴿لئن أكله الذئب ونحن عصبة إنا إذا لخاسرون (١٤)﴾</span> يعني: لَعَجَزَة ظالمون{4}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير الثعلبي ٤/٢٦٢.|2:تفسير الثعلبي ٤/٢٦٢.|3:تفسير الثعلبي ٤/٢٦٢.|4:تفسير مقاتل بن سليمان ٢/٥٠.
  7,91,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿فَأَخَذَتۡهُمُ ٱلرَّجۡفَةُ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٢٨٢٧٤<span class="dash">-</span></span> قال <span class="name-1">عبد الله بن عباس</span>، وغيره: فتح الله عليهم بابًا من جهنم، فأرسل عليهم حرًّا شديدًّا، فأخذ بأنفاسهم، ولم ينفعهم ظِلٌّ ولا ماء، فكانوا يدخلون الأسراب لِيَتَبَرَّدوا فيها، فإذا دخلوها وجدوها أشد حرًّا مِن الظاهر، فخرجوا هَرَبًا إلى البَرِّيَّة، فبعث الله سحابة فيها ريحٌ طَيِّبة، فأظلَّتْهُم، أو هي الظُّلَّة، فوجدوا لها بردًا ونسيمًا، فنادى بعضهم بعضًا، حتى اجتمعوا تحت السحابة -رجالهم ونساؤهم وصبيانهم- ألهبها الله عليهم نارًا، ورجفت بهم الأرض، فاحترقوا كما يحترق الجراد المقلي، وصاروا رمادًا{1}<span class=comment-ref>٢٥٨٩</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٢٥٨٩</span> قال <u>ابنُ عطية</u> (٣/٦١٧): «ويحتمل أنّ فرقة من قوم شعيب أُهْلِكَت بالرجفة، وفرقة بالظلة، ويحتمل أن الظلة والرجفة كانتا في حينٍ واحد».</div></p><p><div></p><p><p><span class="item-no">٢٨٢٧٥<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- قوله: <span class="qpc-hafs">﴿الرجفة﴾</span>، قال: الصَّيْحَة{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٨٢٧٦<span class="dash">-</span></span> قال <span class="name-3">محمد بن السائب الكلبي</span>: الزَّلْزَلة{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٨٢٧٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فأخذتهم الرجفة﴾</span>، يعني: العذاب{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٨٢٧٨<span class="dash">-</span></span> عن <span class="name-3">محمد بن إسحاق</span> -من طريق سلمة- قال: بلغني -والله أعلم-: أنّ الله سلَّط عليهم الحر، حتى إذا أنضجهم أنشأ لهم الظُّلَّة كالسحابة السوداء، فلمّا رأوها ابتدروها يستغيثون ببردها مِمّا هم فيه، حتى إذا دخلوا تحتها أطبقت، فهلكوا جميعًا، ونجّى الله ﷿ شعيبًا والذين آمنوا معه برحمته{5}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿فَأَصۡبَحُوا۟ فِی دَارِهِمۡ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٢٨٢٧٩<span class="dash">-</span></span> قال <span class="name-2">أبو العالية الرِّياحِيُّ</span>: ديارهم: منازلهم{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٨٢٨٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فأصبحوا﴾</span> من صيحة جبريل ﵇ <span class="qpc-hafs">﴿في دارهم﴾</span> يعني: قريتهم{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٨٢٨١<span class="dash">-</span></span> قال محمد بن مروان: كل شيء في القرآن <span class="qpc-hafs">﴿دارهم﴾</span> فهو: مدينتهم، وكل شيء <span class="qpc-hafs">﴿ديارهم﴾</span> فهو: عساكرهم{6}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿جَـٰثِمِینَ ۝٩١﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٢٨٢٨٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿جاثمين﴾</span>، يعني: أمواتًا خامدين{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٨٢٨٣<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق أصبغ بن الفرج- في قوله: <span class="qpc-hafs">﴿جاثِمِينَ﴾</span>، قال: مَيِّتين{10}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير الثعلبي ٤/٢٦٤، وتفسير البغوي ٣/٢٥٨.|2:أخرجه ابن أبي حاتم ٥/١٥٢٣.|3:تفسير الثعلبي ٤/٢٦٢، وتفسير البغوي ٣/٢٥٨.|4:تفسير مقاتل بن سليمان ٢/٥٠.|5:أخرجه ابن جرير ١٠/٣٢٤، وابن أبي حاتم ٥/١٥٢٤.|6:تفسير الثعلبي ٤/٢٦٣.|7:تفسير مقاتل بن سليمان ٢/٥٠.|8:تفسير الثعلبي ٤/٢٦٣.|9:تفسير مقاتل بن سليمان ٢/٥٠.|10:أخرجه ابن أبي حاتم ٥/١٥٢٤.
  7,92,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿ٱلَّذِینَ كَذَّبُوا۟ شُعَیۡبࣰا كَأَن لَّمۡ یَغۡنَوۡا۟ فِیهَاۚ ٱلَّذِینَ كَذَّبُوا۟ شُعَیۡبࣰا كَانُوا۟ هُمُ ٱلۡخَـٰسِرِینَ ۝٩٢﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٢٨٢٨٤<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق الضحاك- في قوله: <span class="qpc-hafs">﴿كأن لم يغنوا فيها﴾</span>، قال: كأن لم يَعْمُروا فيها{1}. (٦/٤٨١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٨٢٨٥<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- في قوله: <span class="qpc-hafs">﴿كأن لم يغنوا فيها﴾</span>، قال: كأن لم يَعِيشوا فيها{2}. (٦/٤٨١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٨٢٨٦<span class="dash">-</span></span> عن <span class="name-2">أبي مالك غزوان الغفاري</span>، قال: <span class="qpc-hafs">﴿كأن لم يغنوا فيها﴾</span>: كأن لم يكونوا فيها{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٨٢٨٧<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- <span class="qpc-hafs">﴿كأن لم يغنوا فيها﴾</span>، يقول: كأن لم يَعِيشوا فيها، كأن لم ينعموا فيها{4}. (٦/٤٨١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٨٢٨٨<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿الذين كذبوا شعيبا كأن لم يغنوا فيها﴾</span> يعني: كأن لم يكونوا فيها قط، <span class="qpc-hafs">﴿الذين كذبوا شعيبا كانوا هم الخاسرين﴾</span>{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٨٢٨٩<span class="dash">-</span></span> قال <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿كأن لم يغنوا فيها﴾</span>: كأن لم يكونوا فيها قطُّ{6}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن أبي حاتم ٦/٢٠٥٢. وعزاه السيوطي إلى أبي الشيخ.|2:أخرجه ابن جرير ١٠/٣٢٦، وابن أبي حاتم ٦/٢٠٥٢.|3:علَّقه ابن أبي حاتم ٥/١٥٢٤.|4:أخرجه عبد الرزاق ٢/٢٣٣، وابن جرير ١٠/٣٢٦، وابن أبي حاتم ٥/١٥٢٤. وعزاه السيوطي إلى عبد بن حميد.|5:تفسير مقاتل بن سليمان ٢/٥٠.|6:أخرجه ابن جرير ١٠/٣٢٦.
  7,93,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿فَتَوَلَّىٰ عَنۡهُمۡ وَقَالَ یَـٰقَوۡمِ لَقَدۡ أَبۡلَغۡتُكُمۡ رِسَـٰلَـٰتِ رَبِّی وَنَصَحۡتُ لَكُمۡۖ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٢٨٢٩٠<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿فتولى عنهم وقال يا قوم لقد أبلغتكم رسالات ربي ونصحت لكم﴾</span>، قال: ذُكِر لنا: أنّ نبيَّ الله شعيبًا أسمَعَ قومه، وأنّ نبي الله صالحًا أسمَعَ قومه، كما أسمَعَ -واللهِ- نبيُّكم محمدٌ ﷺ قومَه{1}. (٦/٤٨١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٨٢٩١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فتولى عنهم﴾</span> يعني: فأعرض عنهم حين كذَّبوا بالعذاب، نظيرُها في هود{2}، <span class="qpc-hafs">﴿وقال يا قوم لقد أبلغتكم رسالات ربي﴾</span> في نزول العذاب بكم في الدنيا، <span class="qpc-hafs">﴿ونصحت لكم﴾</span> فيما حذَّرتكم من عذابه{3}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿فَكَیۡفَ ءَاسَىٰ عَلَىٰ قَوۡمࣲ كَـٰفِرِینَ ۝٩٣﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٢٨٢٩٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- في قوله: <span class="qpc-hafs">﴿فكيف آسى﴾</span>، قال: أحْزَن{4}. (٦/٤٨٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٨٢٩٣<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- <span class="qpc-hafs">﴿فكيف آسى﴾</span>، يقول: فكيف أحزن{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٨٢٩٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فكيف آسى﴾</span> يقول: فكيف أحزن بعد الصيحة <span class="qpc-hafs">﴿على قوم كافرين﴾</span> إذا عُذِّبوا{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٨٢٩٥<span class="dash">-</span></span> عن <span class="name-3">محمد بن إسحاق</span> -من طريق سلمة- قال: أصاب شعيبًا على قومه حُزْنٌ لِما نزل بهم من نقمة الله، ثم قال يُعَزِّي نفسَه -فيما ذَكَرَ اللهُ عنه-: <span class="qpc-hafs">﴿يا قوم لقد أبلغتكم رسالات ربي ونصحت لكم فكيف آسى على قوم كافرين﴾</span>{7}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿فَكَیۡفَ ءَاسَىٰ عَلَىٰ قَوۡمࣲ كَـٰفِرِینَ ۝٩٣﴾</span> - آثار متعلقة بالقصة</h3></p><p><div></p><p><p><span class="item-no">٢٨٢٩٦<span class="dash">-</span></span> عن ابن إسحاق، قال: ذكَر لي يعقوب بن أبي سلمة: أنّ رسول الله ﷺ كان إذا ذكَر شعيبًا قال: «<b>ذاك خطيبُ الأنبياء</b>». لحُسْنِ مراجعتِه قومَه فيما يُرادُّهم{8} به، فلمّا كذَّبوه، وتوعَّدُوه بالرجم والنفي من بلاده، وعَتَوْا على الله؛ أخَذهم عذاب يوم الظُّلَّة. فبلغني: أنّ رجلًا مِن أهل مدين يُقال له: عمرو بن جَلْهاءَ، لَمّا رآها قال:</p><p>يا قومِ إنّ شعيبًا مُرْسَلٌ فَذَرُوا عنكم سُمَيْرًا وعِمْرانَ بن شداد</p><p>إنِّي أرى غَبْيَةً{9}يا قومِ قد طلَعت تَدْعُو بصوتٍ على صَمّانةِ{10} الوادي</p><p>وإنه لن تَرْوا فيه ضَحاءَ غدٍ إلا الرَّقيمُ يُمَشِّي بين أنجادِ{11}</p><p>وسُمَيرٌ وعِمرانُ كاهِناهم، والرَّقيمُ كَلْبُهم{12}. (٦/٤٨٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٨٢٩٧<span class="dash">-</span></span> عن <span class="name-3">مالك بن أنسٍ</span> - من طريق ابن وهب - قال: كان شعيبٌ خطيب الأنبياء{13}. (٦/٤٨٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٨٢٩٨<span class="dash">-</span></span> عن أبي عبد الله البجلي -من طريق سلمة- قال: أبو جاد، وهوز، وحطي، وكلمن، وسعفص، وقرشت: أسماء ملوك مدين، وكان مَلِكُهم يومَ الظلة في زمان شعيب: كَلَمُن، فقالت أخت كَلَمُن تبكيه:</p><p>كلمون هدَّ ركني هُلْكُهُ وسْطَ المَحِلَّهْ</p><p>سيِّد القوم أتاه الـ ـحتف نارًا وسْطَ ظُلَّهْ</p><p>جُعلت نارًا عليهم دارهم كالمُضْمَحِلَّه{14}<span class=comment-ref>٢٥٩٠</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٢٥٩٠</span> <span class="comment-type-4">علّق</span> <u>ابن عطية</u> (٣/٦١٨) على هذه الحكاية قائلًا: «وهذه حكاية مظنون بها».</div></p><p><div></p><p><p><span class="item-no">٢٨٢٩٩<span class="dash">-</span></span> عن جبلة بن عبد الله، قال: بعَث الله جبريلَ إلى أهل مدين شَطْرَ الليل، ليأفِكَ بهم{15} مَغانِيَهم{16}، فألَفى رجلًا قائمًا يتلُو كتاب الله، فهاله أن يُهلِكَه فيمَن يُهْلِك، فرجَع إلى المعراج، فقال: اللَّهُمَّ، أنت سُبُّوحٌ قدوسٌ، بَعثتني إلى مَدْينَ لأَفْكِ مَغانِيهم، فأَصبتُ رجلًا قائمًا يتلُو كتاب الله. فأوحى الله: ما أعرَفَني به، هو فلان بن فلان؛ فابدَأْ به، فإنّه لم يَدْفَعْ عن مَحارمي إلا مُوادِعًا{17}. (٦/٤٨٢)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن أبي حاتم ٥/١٥٢٤. وعزاه السيوطي إلى عبد بن حميد، وأبي الشيخ.|2:يشير إلى قوله تعالى: <span class="qpc-hafs">﴿ويا قَوْمِ اعْمَلُوا عَلى مَكانَتِكُمْ إنِّي عامِلٌ سَوْفَ تَعْلَمُونَ مَن يَأْتِيهِ عَذابٌ يُخْزِيهِ ومَن هُوَ كاذِبٌ وارْتَقِبُوا إنِّي مَعَكُمْ رَقِيبٌ (٩٣) ولَمّا جاءَ أمْرُنا نَجَّيْنا شُعَيْبًا والَّذِينَ آمَنُوا مَعَهُ بِرَحْمَةٍ مِنّا وأَخَذَتِ الَّذِينَ ظَلَمُوا الصَّيْحَةُ فَأَصْبَحُوا فِي دِيارِهِمْ جاثِمِينَ (٩٤) كَأَنْ لَمْ يَغْنَوْا فِيها ألا بُعْدًا لِمَدْيَنَ كَما بَعِدَتْ ثَمُودُ (٩٥)﴾</span>.|3:تفسير مقاتل بن سليمان ٢/٥٠.|4:أخرجه ابن جرير ١٠/٣٢٧، وابن أبي حاتم ٥/١٥٢٤. وعزاه السيوطي إلى ابن المنذر.|5:أخرجه ابن جرير ١٠/٣٢٧.|6:تفسير مقاتل بن سليمان ٢/٥٠.|7:أخرجه ابن جرير ١٠/٣٢٧، وابن أبي حاتم ٥/١٥٢٤.|8:رادَّه القول: راجعه. التاج (ردد).|9:الغبية: الدفعة من المطر. اللسان (غبا).|10:الصَّمّان والصَّمّانة: أرض صُلْبة ذات حجارة إلى جنب رَمْل. لسان العرب (صمم).|11:الأنجاد: جمع نَجْد، وهو ما غلظ من الأرض وأشرف وارتفع واستوى. اللسان (نجد).|12:أخرجه الحاكم ٢/٦٢٠ (٤٠٧١) مختصرًا، وابن جرير١٠/٣٢٣-٣٢٤، وابن أبي حاتم ٩/١٨١٣-٢٨١٤ (١٥٩٢١) من مرسل يعقوب بن أبي سلمة.|13:أخرجه ابن أبي حاتم ٥/١٥٢٢.|14:أخرجه ابن جرير ١٠/٣٢٤.|15:يأفك بهم: يقلبهم. ينظر لسان العرب (أفك).|16:المغاني: المنازل التي كان بها أهلوها، واحدها مَغْنًى. لسان العرب (غنى).|17:أخرجه ابن عساكر ٢٣/٧٤.
  7,94,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَمَاۤ أَرۡسَلۡنَا فِی قَرۡیَةࣲ مِّن نَّبِیٍّ إِلَّاۤ أَخَذۡنَاۤ أَهۡلَهَا بِٱلۡبَأۡسَاۤءِ وَٱلضَّرَّاۤءِ لَعَلَّهُمۡ یَضَّرَّعُونَ ۝٩٤﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٢٨٣٠٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن مسعود</span> -من طريق السدي، عن مرة الهمداني- في الآية، قال: البأساء: الفقر. والضراء: السقم{1}. (٢/١٥١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٨٣٠١<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق عباد بن منصور- <span class="qpc-hafs">﴿بالبأساء﴾</span> قال: البلاء، <span class="qpc-hafs">﴿والضراء﴾</span> هذه الأمراض، والجوع، ونحو ذلك{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٨٣٠٢<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- <span class="qpc-hafs">﴿أخذنا أهلها بالبأساء والضراء﴾</span>، يقول: بالفقر، والجوع{3}<span class=comment-ref>٢٥٩١</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٢٥٩١</span> لم يذكر <u>ابنُ جرير</u> (١٠/٣٢٨) في تفسير قوله: <span class="qpc-hafs">﴿بالبأساء والضراء﴾</span> غير قول السدي. ثم قال: «وقد ذكرنا فيما مضى الشواهد على صحة القول بما قلنا في معنى البأساء والضراء بما أغنى عن إعادته في هذا الموضع».</div></p><p><div></p><p><p><span class="item-no">٢٨٣٠٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وما أرسلنا في قرية من نبي﴾</span> فكذَّبوه <span class="qpc-hafs">﴿إلا أخذنا أهلها بالبأساء﴾</span> يعني: قحط المطر، فأصابهم البؤس، وهو الشِّدَّة، <span class="qpc-hafs">﴿والضراء﴾</span> يعني: البلاء؛ <span class="qpc-hafs">﴿لعلهم﴾</span> يعني: لكي <span class="qpc-hafs">﴿يضرعون﴾</span> إلى ربهم، فيُوَحِّدونه، فيرحمهم{4}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ٣/٨٦، وابن أبي حاتم ١/٢٩١، والحاكم ٢/٢٧٣. وعزاه السيوطي إلى وكيع، وابن أبي شيبة، وعبد بن حميد، وابن المنذر، وأبي الشيخ.|2:أخرجه ابن أبي حاتم ١/٢٩١، ٥/١٥٢٥.|3:أخرجه ابن جرير ١٠/٣٢٨.|4:تفسير مقاتل بن سليمان ٢/٥٠. وقد تقدم تفصيلٌ أكثر عند قوله تعالى: <span class="qpc-hafs">﴿والصّابِرِينَ فِي البَأْساءِ والضَّرّاءِ وحِينَ البَأْسِ﴾</span> [البقرة:١٧٧].
  7,95,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿ثُمَّ بَدَّلۡنَا مَكَانَ ٱلسَّیِّئَةِ ٱلۡحَسَنَةَ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٢٨٣٠٤<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- في قوله: <span class="qpc-hafs">﴿ثم بدلنا مكان السيئة الحسنة﴾</span>، قال: مكان الشِدَّةِ الرَّخاءَ{1}. (٦/٤٨٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٨٣٠٥<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿ثم بدلنا مكان السيئة﴾</span> قال: الشر، <span class="qpc-hafs">﴿الحسنة﴾</span> قال: الرخاء، والعدل، والولد{2}. (٦/٤٨٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٨٣٠٦<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق مَعْمَر- <span class="qpc-hafs">﴿مكان السيئة الحسنة﴾</span> قال: مكان الشدة رخاءً <span class="qpc-hafs">﴿حتى عفوا﴾</span>{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٨٣٠٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ثم بدلنا مكان السيئة الحسنة﴾</span>، يقول: حوَّلنا مكان الشدةِ الرخاءَ{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٨٣٠٨<span class="dash">-</span></span> قال <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿ثم بدلنا مكان السيئة الحسنة حتى عفوا﴾</span> قال: بدَّلنا مكان ما كرهوا ما أحَبُّوا في الدنيا، حتى عفوا من ذلك العذاب، <span class="qpc-hafs">﴿وقالوا قد مس آباءنا الضراء والسراء﴾</span>{5}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿حَتَّىٰ عَفَوا۟﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٢٨٣٠٩<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- في قوله: <span class="qpc-hafs">﴿حتى عفوا﴾</span>، قال: كَثُروا، وكثُرت أموالُهم{1}. (٦/٤٨٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٨٣١٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق ابن جُرَيْج- في قوله: <span class="qpc-hafs">﴿حتى عفوا﴾</span>، قال: جَمُّوا{7}. (٦/٤٨٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٨٣١١<span class="dash">-</span></span> عن <span class="name-2">إبراهيم النخعي</span> -من طريق مغيرة- <span class="qpc-hafs">﴿حتى عفوا﴾</span>، قال: حتى جمُّوا وكثروا{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٨٣١٢<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿حتى عفوا﴾</span>، يقول: حتى كثُرت أموالُهم وأولادُهم{9}. (٦/٤٨٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٨٣١٣<span class="dash">-</span></span> عن <span class="name-2">الضحاك بن مزاحم</span> -من طريق جويبر- <span class="qpc-hafs">﴿حتى عفوا﴾</span>، يعني: جمُّوا؛ كثروا{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٨٣١٤<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span> -من طريق يزيد بن أبي سعيد- <span class="qpc-hafs">﴿حتى عفوا﴾</span>، قال: أشِرُوا، وبَطِروا{11}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٨٣١٥<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق أبي حمزة العطّار- في قوله: <span class="qpc-hafs">﴿حتى عفوا﴾</span>، قال: حتّى سمنوا{11}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٨٣١٦<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق مَعْمَر- <span class="qpc-hafs">﴿حتى عفوا﴾</span>، يقول: حتى سُرُّوا بذلك{13}<span class=comment-ref>٢٥٩٢</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٢٥٩٢</span> <span class="comment-type-2">انتَقَد</span> <u>ابنُ جرير</u> (١٠/٣٣٢) قول قتادة <span class="mustanad">لمخالفته للغة العرب</span>، قال: «وهذا الذي قاله قتادة في معنى <span class="qpc-hafs">﴿عفوا﴾</span> تأويل لا وجه له في كلام العرب؛ لأنه لا يعرف العفو بمعنى السرور في شيء من كلامها، إلا أن يكون أراد حتى سُرُّوا بكثرتهم وكثرة أموالهم، فيكون ذلك وجهًا، وإن بَعُد».</div></p><p><div></p><p><p><span class="item-no">٢٨٣١٧<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- <span class="qpc-hafs">﴿حتى عفوا﴾</span>: حتى كَثُروا{14}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٨٣١٨<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن حيان</span>:<span class="qpc-hafs">﴿عفوا﴾</span>حتى أشروا وبطروا ولم يشكروا ربهم، وأصله من الكثرة{15}.(ز) (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٨٣١٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿حتى عفوا﴾</span> يقول: حموا، وسمتوا{16}، فلم يشكروا ربهم{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٨٣٢٠<span class="dash">-</span></span> قال <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿حتى عفوا﴾</span>: كثروا كما يكثر النبات والريش، ثم أخذهم عند ذلك بغتة وهم لا يشعرون{8}<span class=comment-ref>٢٥٩٣</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٢٥٩٣</span> ذكر <u>ابنُ جرير</u> (١٠/٣٢٩) قولين للسلف في تفسير قوله تعالى: <span class="qpc-hafs">﴿حتى عفو﴾</span>: <b>أحدهما</b>: أنّ معناه: حتى كثروا. وهو قول جمهور السلف. <b>وثانيها</b>: أن معناه: حتى سروا وفرحوا، وهو قول قتادة.</p><p>وقد <span class="comment-type-3">رجّح</span> <u>ابنُ جرير</u> القول الأول <span class="mustanad">مستندًا إلى لغة العرب</span>، قال: "قوله: <span class="qpc-hafs">﴿حتى عفوا﴾</span> يقول: حتى كثروا، وكذلك كل شيء كثر فإنه يقال فيه: قد عفا، كما قال الشاعر:</p><p>ولكنا نعض السيف منها بأسوق عافيات الشحم كوم".</div></p><p><h3><span class="qpc-hafs">﴿وَّقَالُوا۟ قَدۡ مَسَّ ءَابَاۤءَنَا ٱلضَّرَّاۤءُ وَٱلسَّرَّاۤءُ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٢٨٣٢١<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق شيبان- في قوله: <span class="qpc-hafs">﴿وقالوا قد مس آباءنا الضراء والسراء﴾</span>، قال: قالوا: قد أتى على آبائِنا مثلُ هذا فلم يَكُن شيئًا{19}. (٦/٤٨٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٨٣٢٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ... فلم يشكروا ربَّهم، فقالوا مِن غِيرتهم وجهلهم: <span class="qpc-hafs">﴿وقالوا قد مس آباءنا﴾</span> يعني: أصاب آباءَنا <span class="qpc-hafs">﴿الضراء والسراء﴾</span> يعني: الشدة والرخاء، مثل ما أصابنا، فلم يك شيئًا{20}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿فَأَخَذۡنَـٰهُم بَغۡتَةࣰ وَهُمۡ لَا یَشۡعُرُونَ ۝٩٥﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٢٨٣٢٣<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق شيبان- في قوله: <span class="qpc-hafs">﴿فأخذناهم بغتة وهم لا يشعرون﴾</span>، قال: بغَت القومَ أمرُ الله، وما أخَذ الله قومًا قطُّ إلا عند سُلْوَتِهم وغِرَّتِهم ونعمتِهم، فلا تَغْتَرُّوا بالله؛ إنّه لا يَغْتَرُّ بالله إلا القوم الفاسقون{19}. (٦/٤٨٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٨٣٢٤<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- قوله: <span class="qpc-hafs">﴿فأخذناهم بغتة﴾</span>، يقول: أخذهم العذابُ بغتة{11}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٨٣٢٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: يقول: <span class="qpc-hafs">﴿فأخذناهم﴾</span> بالعذاب <span class="qpc-hafs">﴿بغتة﴾</span>: فجأة، <span class="qpc-hafs">﴿وهم لا يشعرون﴾</span> أعَزُّ ما كانوا حتى نزل بهم، وقد أنذَرَتْهم رسلُهم العذابَ من قبل أن ينزل بهم، فذلك قوله: <span class="qpc-hafs">﴿ذلك أن لم يكن ربك مهلك القرى بظلم﴾</span> بالشرك <span class="qpc-hafs">﴿وأهلها غافلون﴾</span> [الأنعام:١٣١]{20}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٨٣٢٦<span class="dash">-</span></span> عن <span class="name-3">سفيان [الثوري]</span> -من طريق مهران- قوله: <span class="qpc-hafs">﴿فأخذناهم بغتة﴾</span>، قال: بعد سِتِّين سنة{24}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٨٣٢٧<span class="dash">-</span></span> عن <span class="name-3">محمد بن النضر الحارثي</span> -من طريق ابن المبارك- في قوله: <span class="qpc-hafs">﴿فأخذناهم بغتة﴾</span>، قال: أُمْهِلُوا عشرين سنة{24}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ١٠/٣٣٠، وابن أبي حاتم ٥/١٥٢٦. وعزاه السيوطي إلى ابن المنذر.|2:تفسير مجاهد ص٣٣٩، وأخرجه ابن جرير ١٠/٣٢٩، وابن أبي حاتم ٥/١٥٢٦. وعزاه السيوطي إلى ابن أبي شيبة، وعبد بن حميد، وابن المنذر، وأبي الشيخ.|3:أخرجه عبد الرزاق ٢/٢٣٣، وابن جرير ١٠/٣٢٩.|4:تفسير مقاتل بن سليمان ٢/٥٠.|5:أخرجه ابن جرير ١٠/٣٢٩، وابن أبي حاتم ٥/١٥٢٦ من طريق أصبغ بن الفرج.|6:أخرجه ابن جرير ١٠/٣٣٠، وابن أبي حاتم ٥/١٥٢٦. وعزاه السيوطي إلى ابن المنذر.|7:أخرجه ابن جرير ١٠/٣٣١، وابن أبي حاتم ٥/١٥٢٦. وعزاه السيوطي إلى أبي الشيخ. وجاء في مطبوعة تفسير الثعلبي ٤/٢٦٤: جهدوا. ولعلها تصحَّفت.|8:أخرجه ابن جرير ١٠/٣٣١.|9:تفسير مجاهد ص٣٣٩، وأخرجه ابن جرير ١٠/٣٢٩-٣٣٠، وابن أبي حاتم ٥/١٥٢٦. وعزاه السيوطي إلى ابن أبي شيبة، وعبد بن حميد، وابن المنذر، وأبي الشيخ.|10:أخرجه ابن جرير ١٠/٣٣١.|11:أخرجه ابن أبي حاتم ٥/١٥٢٧.|12:أخرجه ابن أبي حاتم ٥/١٥٢٧.|13:أخرجه عبد الرزاق ٢/٢٣٣، وابن جرير ١٠/٣٣١.|14:أخرجه ابن جرير ١٠/٣٣٠.|15:تفسير الثعلبي ٤/٢٦٤.|16:كذا في المطبوع، ولعلها: جمُّوا وسَمنوا. تصحَّفت.|17:تفسير مقاتل بن سليمان ٢/٥٠.|18:أخرجه ابن جرير ١٠/٣٣١.|19:أخرجه ابن أبي حاتم ٥/١٥٢٧. وعزاه السيوطي إلى عبد بن حميد.|20:تفسير مقاتل بن سليمان ٢/٥٠-٥١.|21:أخرجه ابن أبي حاتم ٥/١٥٢٧. وعزاه السيوطي إلى عبد بن حميد.|22:أخرجه ابن أبي حاتم ٥/١٥٢٧.|23:تفسير مقاتل بن سليمان ٢/٥٠-٥١.|24:أخرجه ابن أبي حاتم ٥/١٥٢٨.|25:أخرجه ابن أبي حاتم ٥/١٥٢٨.