quran[8]{c,v,t}:
7,88," <q>﴿قَالَ ٱلۡمَلَأُ ٱلَّذِینَ ٱسۡتَكۡبَرُوا۟ مِن قَوۡمِهِۦ لَنُخۡرِجَنَّكَ یَـٰشُعَیۡبُ وَٱلَّذِینَ ءَامَنُوا۟ مَعَكَ مِن قَرۡیَتِنَاۤ أَوۡ لَتَعُودُنَّ فِی مِلَّتِنَاۚ قَالَ أَوَلَوۡ كُنَّا كَـٰرِهِینَ ۝٨٨﴾</q> - تفسير ٢٨٢٥٦- قال مقاتل بن سليمان: <q>﴿قال الملأ الذين استكبروا من قومه﴾</q> يعني: الذين تكبَّروا عن الإيمان، وهم الكبراء: <q>﴿لنخرجنك يا شعيب والذين آمنوا معك من قريتنا أو لتعودن في ملتنا﴾</q> يعنون: الشرك؛ أو لتدخلن في ملتنا، <q>﴿قال أولو كنا كارهين﴾</q>{1}. (ز) ",footnotes:1:تفسير مقاتل بن سليمان ٢/٤٩.
7,89," <q>﴿قَدِ ٱفۡتَرَیۡنَا عَلَى ٱللَّهِ كَذِبًا إِنۡ عُدۡنَا فِی مِلَّتِكُم بَعۡدَ إِذۡ نَجَّىٰنَا ٱللَّهُ مِنۡهَاۚ﴾</q> - تفسير ٢٨٢٥٧- قال مقاتل بن سليمان: ثُمَّ قال لهم شعيب: <q>﴿قد افترينا على الله كذبا إن عدنا في ملتكم﴾</q> الشرك، يعني: إن دخلنا في دينكم <q>﴿بعد إذ نجانا الله منها﴾</q> يقول: بعد إذ لم يجعلنا الله من أهل ملتكم الشرك{1}٢٥٨٧. (ز) ٢٥٨٧ بيّن ابنُ عطية (٣/٦١٣-٦١٤) أن لـ<q>﴿عدنا﴾</q> معنيين في كلام العرب، الأول: أن تكون بمعنى عَوْد الشيء إلى حال كان عليها قبل ذلك. الثاني: أن تكون بمعنى: صار، ولا تتضمن أن الحال كانت متقدمة. ثم قال معلِّقًا: «وشعيب ﵇ لم يكن قط كافرًا، يقتضي أنها بمعنى: صار، وأمّا في جهة المؤمنين بعد كفرهم فيترتب المعنى الآخر، ويخرج عنه شعيب، إلا أن يريدوا عَوْدته إلى حال سكوته قبل أن يبعث». والظاهر مِن كلام ابن تيمية (٣/١٧٤- ١٧٨) أنه فسَّر <q>﴿إن عدنا في ملتكم﴾</q> بأنّ العَوْد هنا هو الرجوع إلى حال قومه من الكفر. <q>﴿وَمَا یَكُونُ لَنَاۤ أَن نَّعُودَ فِیهَاۤ إِلَّاۤ أَن یَشَاۤءَ ٱللَّهُ رَبُّنَاۚ وَسِعَ رَبُّنَا كُلَّ شَیۡءٍ عِلۡمًاۚ عَلَى ٱللَّهِ تَوَكَّلۡنَاۚ﴾</q> - تفسير ٢٨٢٥٨- عن إسماعيل السُّدِّيّ -من طريق أسباط- في قوله: <q>﴿وما يكون لنا أن نعود فيها﴾</q> قال: ما ينْبغِي لنا أن نعودَ في شِرْكِكم بعدَ إذْ نجّانا الله، <q>﴿إلا أن يشاء الله ربنا﴾</q> واللهُ لا يشاءُ الشرك، ولكن يقول: إلا أن يكونَ اللهُ قد عَلِم شيئًا؛ فإنّه قد وسِع كلَّ شيءٍ علمًا{2}٢٥٨٨. (٦/٤٨٠) ٢٥٨٨ لم يذكر ابنُ جرير (١٠/٣١٩) في تفسير قوله تعالى: <q>﴿وما يكون لنا أن نعود فيها إلا أن يشاء الله ربنا﴾</q> غير قول السدي. وذكر ابنُ عطية (٣/٦١٥ بتصرف) عدة احتمالات في الاستثناء الوارد في الآية: أولها: أن يريد: إلا أن يسبق علينا من الله في ذلك سابقٌ وسوء وينفذ منه قضاء لا يرد. وهو موافق لقول السدي، وقد وجَّهه بقوله: «والمؤمنون هم المُجَوِّزون لذلك، وشعيب قد عَصَمَتْه النبوة». ورجّحه مستندًا إلى ظاهر الآية بقوله: «وهذا أظهر ما يحتمل القول ... وقوله: <q>﴿عَلى اللَّهِ تَوَكَّلْنا﴾</q> استسلام لله، وتمسك بلفظه، وذلك يؤيد التأويل الأول في قوله: <q>﴿إلا أن يشاء الله﴾</q>». ثانيها: ويحتمل أن يريد استثناء ما يمكن أن يَتعبد اللهُ به المؤمنين مما يفعله الكفار من القربات. ثالثها: ويحتمل أن يريد بذلك معنى الاستبعاد، كما تقول: لا أفعل كذا حتى يشيب الغراب. وهذا تأويل إنما هو للمعتزلة الذين من مذهبهم أنّ الكفر والإيمان ليسا بمشيئة من الله تعالى، فلا يترتب هذا التأويل إلا عندهم، وهذا تأويل حكاه المفسرون ولم يشعروا بما فيه. رابعها: إنّ هذا الاستثناء إنما هو تستر وتأدب. ويقلق هذا التأويل من جهة استقبال الاستثناء، ولو كان في الكلام «إن شاء الله» قوي هذا التأويل. ٢٨٢٥٩- قال مقاتل بن سليمان: <q>﴿وما يكون لنا أن نعود فيها﴾</q> وما ينبغي لنا أن ندخل في ملتكم الشرك، <q>﴿إلا أن يشاء الله ربنا﴾</q> فيدخلنا في ملتكم، <q>﴿وسع﴾</q> يعني: مَلَأَ <q>﴿ربنا كل شيء علما﴾</q> فعلمه، <q>﴿على الله توكلنا﴾</q> لقولهم لشعيب: <q>﴿لنخرجنك يا شعيب والذين آمنوا معك من قريتنا﴾</q>{1}. (ز) <q>﴿رَبَّنَا ٱفۡتَحۡ بَیۡنَنَا وَبَیۡنَ قَوۡمِنَا بِٱلۡحَقِّ وَأَنتَ خَیۡرُ ٱلۡفَـٰتِحِینَ ۝٨٩﴾</q> - تفسير ٢٨٢٦٠- عن عبد الله بن عباس -من طريق قتادة- قال: ما كنتُ أدري ما قولُه: <q>﴿ربنا افتح بيننا وبين قومنا بالحق﴾</q> حتّى سمعتُ ابنةَ ذي يَزَنَ تقولُ: تعال أُفاتِحُك. يعني: أُقاضِيك{4}. (٦/٤٨١) ٢٨٢٦١- عن عبد الله بن عباس -من طريق علي- في قوله: <q>﴿ربنا افتح﴾</q>، يقول: اقْضِ{5}. (٦/٤٨١) ٢٨٢٦٢- عن الحسن البصري -من طريق ابن جريج-: <q>﴿افتح﴾</q> الحكم؛ احكم بيننا وبين قومنا، و<q>﴿إنا فتحنا لك فتحا مبينا﴾</q> [الفتح:١]: حكمنا لك حكمًا مبينًا{6}. (ز) ٢٨٢٦٣- عن قتادة بن دعامة -من طريق مَعْمَر- في قوله: <q>﴿ربنا افتح بيننا وبين قومنا بالحق﴾</q>، قال: ربنا اقضِ بيننا وبين قومنا بالحق{7}. (ز) ٢٨٢٦٤- قال قتادة بن دعامة: وإذا دعا النبيُّ ربَّه أن يحكم بينه وبين قومه جاءهم العذاب{8}. (ز) ٢٨٢٦٥- عن إسماعيل السُّدِّيّ -من طريق أسباط- <q>﴿رَبَّنا افْتَحْ بَيْنَنا﴾</q>، فيقول: احكم بيننا{6}. (ز) ٢٨٢٦٦- عن إسماعيل السُّدِّيّ، قال: الفتحُ: القضاء، لغةٌ يَمانِية، إذا قال أحدُهم: تعالَ أُقاضِيك القضاء، قال: تعالَ أُفاتِحك{10}. (٦/٤٨١) ٢٨٢٦٧- قال مقاتل بن سليمان: قال شعيب: <q>﴿ربنا افتح﴾</q> يعني: اقضِ <q>﴿بيننا وبين قومنا بالحق﴾</q> يعني: بالعدل في نزول العذاب بهم، <q>﴿وأنت خير الفاتحين﴾</q> يعني: القاضين{1}. (ز) <q>﴿رَبَّنَا ٱفۡتَحۡ بَیۡنَنَا وَبَیۡنَ قَوۡمِنَا بِٱلۡحَقِّ وَأَنتَ خَیۡرُ ٱلۡفَـٰتِحِینَ ۝٨٩﴾</q> - آثار متعلقة بالآية ٢٨٢٦٨- عن عون، قال: كان عبد الله بن مسعود إذا خرج من بيته قال: بسم الله، توكلت على الله، لا حول ولا قوة إلا بالله. فقال محمد بن كعب القرظي: هذا في القرآن: <q>﴿اركبوا فيها بسم الله﴾</q> [هود:٤١]، وقال: <q>﴿على الله توكلنا﴾</q>{12}. (ز) ٢٨٢٦٩- عن زيد بن أسلم أنّه قال في القَدَرِيَّة: واللهِ، ما قالوا كما قال الله، ولا كما قال النَّبِيُّون، ولا كما قال أصحابُ الجنة، ولا كما قال أصحابُ النار، ولا كما قال أخوهم إبليس، قال الله: <q>﴿وما تشاؤون إلا أن يشاء الله﴾</q> [الإنسان:٣٠]. وقال شعيبٌ: <q>﴿وما يكون لنا أن نعود فيها إلا أن يشاء الله﴾</q>. وقال أصحاب الجنة: <q>﴿الحمد لله الذي هدانا لهذا وما كنا لنهتدي لولا أن هدانا الله﴾</q> [الأعراف:٤٣]. وقال أصحاب النار: <q>﴿ولكن حقت كلمة العذاب على الكافرين﴾</q> [الزمر:٧١]. وقال إبليسُ: <q>﴿رب بما أغويتني﴾</q> [الحجر:٣٩]{13}. (٦/٤٨٠) ",footnotes:1:تفسير مقاتل بن سليمان ٢/٤٩.أخرجه ابن جرير ١٠/٣١٩، وابن أبي حاتم ٥/١٥٢٣. وعزاه السيوطي إلى أبي الشيخ.تفسير مقاتل بن سليمان ٢/٤٩.أخرجه ابن أبي شيبة ٨/٥٢٩، وابن جرير ١٠/٣٢٠، وابن أبي حاتم ٥/١٥٢٣، والبيهقي في الأسماء والصفات (١٠٧). وعزاه السيوطي إلى عبد بن حميد، وابن الأنباري في الوقف والابتداء.أخرجه ابن جرير ١٠/٣٢١، وابن أبي حاتم ٥/١٥٢٣. وعزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ١٠/٣٢١.أخرجه عبد الرزاق ٢/٢٣٣، وابن جرير ١٠/٣٢١.ذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٢/١٣٣-.أخرجه ابن جرير ١٠/٣٢١.عزاه السيوطي إلى ابن أبي حاتم.تفسير مقاتل بن سليمان ٢/٤٩.أخرجه الطبراني في المعجم الكبير ٩/١٨٠ (٨٨٨٩).عزاه السيوطي إلى الزبير بن بكّار في الموفَّقِيات.
7,90," <q>﴿وَقَالَ ٱلۡمَلَأُ ٱلَّذِینَ كَفَرُوا۟ مِن قَوۡمِهِۦ لَىِٕنِ ٱتَّبَعۡتُمۡ شُعَیۡبًا إِنَّكُمۡ إِذࣰا لَّخَـٰسِرُونَ ۝٩٠﴾</q> - تفسير ٢٨٢٧٠- قال عبد الله بن عباس: <q>﴿إنكم إذا لخاسرون﴾</q>: مَغْبُونُون{1}. (ز) ٢٨٢٧١- قال الضحاك بن مزاحم: <q>﴿إنكم إذا لخاسرون﴾</q>: عجَزَة{1}. (ز) ٢٨٢٧٢- قال عطاء: <q>﴿إنكم إذا لخاسرون﴾</q>: جاهلون{1}. (ز) ٢٨٢٧٣- قال مقاتل بن سليمان: <q>﴿وقال الملأ الذين كفروا بالله من قومه﴾</q> وهم الكبراء للضعفاء: <q>﴿لئن اتبعتم شعيبا﴾</q> على دينه <q>﴿إنكم إذا لخاسرون﴾</q> يعني: لَعَجَزة. نظيرها في يوسف: <q>﴿لئن أكله الذئب ونحن عصبة إنا إذا لخاسرون (١٤)﴾</q> يعني: لَعَجَزَة ظالمون{4}. (ز) ",footnotes:1:تفسير الثعلبي ٤/٢٦٢.تفسير الثعلبي ٤/٢٦٢.تفسير الثعلبي ٤/٢٦٢.تفسير مقاتل بن سليمان ٢/٥٠.
7,91," <q>﴿فَأَخَذَتۡهُمُ ٱلرَّجۡفَةُ﴾</q> - تفسير ٢٨٢٧٤- قال عبد الله بن عباس، وغيره: فتح الله عليهم بابًا من جهنم، فأرسل عليهم حرًّا شديدًّا، فأخذ بأنفاسهم، ولم ينفعهم ظِلٌّ ولا ماء، فكانوا يدخلون الأسراب لِيَتَبَرَّدوا فيها، فإذا دخلوها وجدوها أشد حرًّا مِن الظاهر، فخرجوا هَرَبًا إلى البَرِّيَّة، فبعث الله سحابة فيها ريحٌ طَيِّبة، فأظلَّتْهُم، أو هي الظُّلَّة، فوجدوا لها بردًا ونسيمًا، فنادى بعضهم بعضًا، حتى اجتمعوا تحت السحابة -رجالهم ونساؤهم وصبيانهم- ألهبها الله عليهم نارًا، ورجفت بهم الأرض، فاحترقوا كما يحترق الجراد المقلي، وصاروا رمادًا{1}٢٥٨٩. (ز) ٢٥٨٩ قال ابنُ عطية (٣/٦١٧): «ويحتمل أنّ فرقة من قوم شعيب أُهْلِكَت بالرجفة، وفرقة بالظلة، ويحتمل أن الظلة والرجفة كانتا في حينٍ واحد». ٢٨٢٧٥- عن مجاهد بن جبر -من طريق ابن أبي نجيح- قوله: <q>﴿الرجفة﴾</q>، قال: الصَّيْحَة{2}. (ز) ٢٨٢٧٦- قال محمد بن السائب الكلبي: الزَّلْزَلة{3}. (ز) ٢٨٢٧٧- قال مقاتل بن سليمان: <q>﴿فأخذتهم الرجفة﴾</q>، يعني: العذاب{4}. (ز) ٢٨٢٧٨- عن محمد بن إسحاق -من طريق سلمة- قال: بلغني -والله أعلم-: أنّ الله سلَّط عليهم الحر، حتى إذا أنضجهم أنشأ لهم الظُّلَّة كالسحابة السوداء، فلمّا رأوها ابتدروها يستغيثون ببردها مِمّا هم فيه، حتى إذا دخلوا تحتها أطبقت، فهلكوا جميعًا، ونجّى الله ﷿ شعيبًا والذين آمنوا معه برحمته{5}. (ز) <q>﴿فَأَصۡبَحُوا۟ فِی دَارِهِمۡ﴾</q> - تفسير ٢٨٢٧٩- قال أبو العالية الرِّياحِيُّ: ديارهم: منازلهم{6}. (ز) ٢٨٢٨٠- قال مقاتل بن سليمان: <q>﴿فأصبحوا﴾</q> من صيحة جبريل ﵇ <q>﴿في دارهم﴾</q> يعني: قريتهم{4}. (ز) ٢٨٢٨١- قال محمد بن مروان: كل شيء في القرآن <q>﴿دارهم﴾</q> فهو: مدينتهم، وكل شيء <q>﴿ديارهم﴾</q> فهو: عساكرهم{6}. (ز) <q>﴿جَـٰثِمِینَ ۝٩١﴾</q> - تفسير ٢٨٢٨٢- قال مقاتل بن سليمان: <q>﴿جاثمين﴾</q>، يعني: أمواتًا خامدين{4}. (ز) ٢٨٢٨٣- عن عبد الرحمن بن زيد بن أسلم -من طريق أصبغ بن الفرج- في قوله: <q>﴿جاثِمِينَ﴾</q>، قال: مَيِّتين{10}. (ز) ",footnotes:1:تفسير الثعلبي ٤/٢٦٤، وتفسير البغوي ٣/٢٥٨.أخرجه ابن أبي حاتم ٥/١٥٢٣.تفسير الثعلبي ٤/٢٦٢، وتفسير البغوي ٣/٢٥٨.تفسير مقاتل بن سليمان ٢/٥٠.أخرجه ابن جرير ١٠/٣٢٤، وابن أبي حاتم ٥/١٥٢٤.تفسير الثعلبي ٤/٢٦٣.تفسير مقاتل بن سليمان ٢/٥٠.تفسير الثعلبي ٤/٢٦٣.تفسير مقاتل بن سليمان ٢/٥٠.أخرجه ابن أبي حاتم ٥/١٥٢٤.
7,92," <q>﴿ٱلَّذِینَ كَذَّبُوا۟ شُعَیۡبࣰا كَأَن لَّمۡ یَغۡنَوۡا۟ فِیهَاۚ ٱلَّذِینَ كَذَّبُوا۟ شُعَیۡبࣰا كَانُوا۟ هُمُ ٱلۡخَـٰسِرِینَ ۝٩٢﴾</q> - تفسير ٢٨٢٨٤- عن عبد الله بن عباس -من طريق الضحاك- في قوله: <q>﴿كأن لم يغنوا فيها﴾</q>، قال: كأن لم يَعْمُروا فيها{1}. (٦/٤٨١) ٢٨٢٨٥- عن عبد الله بن عباس -من طريق علي- في قوله: <q>﴿كأن لم يغنوا فيها﴾</q>، قال: كأن لم يَعِيشوا فيها{2}. (٦/٤٨١) ٢٨٢٨٦- عن أبي مالك غزوان الغفاري، قال: <q>﴿كأن لم يغنوا فيها﴾</q>: كأن لم يكونوا فيها{3}. (ز) ٢٨٢٨٧- عن قتادة بن دعامة -من طريق معمر- <q>﴿كأن لم يغنوا فيها﴾</q>، يقول: كأن لم يَعِيشوا فيها، كأن لم ينعموا فيها{4}. (٦/٤٨١) ٢٨٢٨٨- قال مقاتل بن سليمان: <q>﴿الذين كذبوا شعيبا كأن لم يغنوا فيها﴾</q> يعني: كأن لم يكونوا فيها قط، <q>﴿الذين كذبوا شعيبا كانوا هم الخاسرين﴾</q>{5}. (ز) ٢٨٢٨٩- قال عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿كأن لم يغنوا فيها﴾</q>: كأن لم يكونوا فيها قطُّ{6}. (ز) ",footnotes:1:أخرجه ابن أبي حاتم ٦/٢٠٥٢. وعزاه السيوطي إلى أبي الشيخ.أخرجه ابن جرير ١٠/٣٢٦، وابن أبي حاتم ٦/٢٠٥٢.علَّقه ابن أبي حاتم ٥/١٥٢٤.أخرجه عبد الرزاق ٢/٢٣٣، وابن جرير ١٠/٣٢٦، وابن أبي حاتم ٥/١٥٢٤. وعزاه السيوطي إلى عبد بن حميد.تفسير مقاتل بن سليمان ٢/٥٠.أخرجه ابن جرير ١٠/٣٢٦.
7,93," <q>﴿فَتَوَلَّىٰ عَنۡهُمۡ وَقَالَ یَـٰقَوۡمِ لَقَدۡ أَبۡلَغۡتُكُمۡ رِسَـٰلَـٰتِ رَبِّی وَنَصَحۡتُ لَكُمۡۖ﴾</q> - تفسير ٢٨٢٩٠- عن قتادة بن دعامة -من طريق سعيد- <q>﴿فتولى عنهم وقال يا قوم لقد أبلغتكم رسالات ربي ونصحت لكم﴾</q>، قال: ذُكِر لنا: أنّ نبيَّ الله شعيبًا أسمَعَ قومه، وأنّ نبي الله صالحًا أسمَعَ قومه، كما أسمَعَ -واللهِ- نبيُّكم محمدٌ ﷺ قومَه{1}. (٦/٤٨١) ٢٨٢٩١- قال مقاتل بن سليمان: <q>﴿فتولى عنهم﴾</q> يعني: فأعرض عنهم حين كذَّبوا بالعذاب، نظيرُها في هود{2}، <q>﴿وقال يا قوم لقد أبلغتكم رسالات ربي﴾</q> في نزول العذاب بكم في الدنيا، <q>﴿ونصحت لكم﴾</q> فيما حذَّرتكم من عذابه{3}. (ز) <q>﴿فَكَیۡفَ ءَاسَىٰ عَلَىٰ قَوۡمࣲ كَـٰفِرِینَ ۝٩٣﴾</q> - تفسير ٢٨٢٩٢- عن عبد الله بن عباس -من طريق علي- في قوله: <q>﴿فكيف آسى﴾</q>، قال: أحْزَن{4}. (٦/٤٨٢) ٢٨٢٩٣- عن إسماعيل السُّدِّيّ -من طريق أسباط- <q>﴿فكيف آسى﴾</q>، يقول: فكيف أحزن{5}. (ز) ٢٨٢٩٤- قال مقاتل بن سليمان: <q>﴿فكيف آسى﴾</q> يقول: فكيف أحزن بعد الصيحة <q>﴿على قوم كافرين﴾</q> إذا عُذِّبوا{3}. (ز) ٢٨٢٩٥- عن محمد بن إسحاق -من طريق سلمة- قال: أصاب شعيبًا على قومه حُزْنٌ لِما نزل بهم من نقمة الله، ثم قال يُعَزِّي نفسَه -فيما ذَكَرَ اللهُ عنه-: <q>﴿يا قوم لقد أبلغتكم رسالات ربي ونصحت لكم فكيف آسى على قوم كافرين﴾</q>{7}. (ز) <q>﴿فَكَیۡفَ ءَاسَىٰ عَلَىٰ قَوۡمࣲ كَـٰفِرِینَ ۝٩٣﴾</q> - آثار متعلقة بالقصة ٢٨٢٩٦- عن ابن إسحاق، قال: ذكَر لي يعقوب بن أبي سلمة: أنّ رسول الله ﷺ كان إذا ذكَر شعيبًا قال: «ذاك خطيبُ الأنبياء». لحُسْنِ مراجعتِه قومَه فيما يُرادُّهم{8} به، فلمّا كذَّبوه، وتوعَّدُوه بالرجم والنفي من بلاده، وعَتَوْا على الله؛ أخَذهم عذاب يوم الظُّلَّة. فبلغني: أنّ رجلًا مِن أهل مدين يُقال له: عمرو بن جَلْهاءَ، لَمّا رآها قال: يا قومِ إنّ شعيبًا مُرْسَلٌ فَذَرُوا عنكم سُمَيْرًا وعِمْرانَ بن شداد إنِّي أرى غَبْيَةً{9}يا قومِ قد طلَعت تَدْعُو بصوتٍ على صَمّانةِ{10} الوادي وإنه لن تَرْوا فيه ضَحاءَ غدٍ إلا الرَّقيمُ يُمَشِّي بين أنجادِ{11} وسُمَيرٌ وعِمرانُ كاهِناهم، والرَّقيمُ كَلْبُهم{12}. (٦/٤٨٣) ٢٨٢٩٧- عن مالك بن أنسٍ - من طريق ابن وهب - قال: كان شعيبٌ خطيب الأنبياء{13}. (٦/٤٨٣) ٢٨٢٩٨- عن أبي عبد الله البجلي -من طريق سلمة- قال: أبو جاد، وهوز، وحطي، وكلمن، وسعفص، وقرشت: أسماء ملوك مدين، وكان مَلِكُهم يومَ الظلة في زمان شعيب: كَلَمُن، فقالت أخت كَلَمُن تبكيه: كلمون هدَّ ركني هُلْكُهُ وسْطَ المَحِلَّهْ سيِّد القوم أتاه الـ ـحتف نارًا وسْطَ ظُلَّهْ جُعلت نارًا عليهم دارهم كالمُضْمَحِلَّه{14}٢٥٩٠. (ز) ٢٥٩٠ علّق ابن عطية (٣/٦١٨) على هذه الحكاية قائلًا: «وهذه حكاية مظنون بها». ٢٨٢٩٩- عن جبلة بن عبد الله، قال: بعَث الله جبريلَ إلى أهل مدين شَطْرَ الليل، ليأفِكَ بهم{15} مَغانِيَهم{16}، فألَفى رجلًا قائمًا يتلُو كتاب الله، فهاله أن يُهلِكَه فيمَن يُهْلِك، فرجَع إلى المعراج، فقال: اللَّهُمَّ، أنت سُبُّوحٌ قدوسٌ، بَعثتني إلى مَدْينَ لأَفْكِ مَغانِيهم، فأَصبتُ رجلًا قائمًا يتلُو كتاب الله. فأوحى الله: ما أعرَفَني به، هو فلان بن فلان؛ فابدَأْ به، فإنّه لم يَدْفَعْ عن مَحارمي إلا مُوادِعًا{17}. (٦/٤٨٢) ",footnotes:1:أخرجه ابن أبي حاتم ٥/١٥٢٤. وعزاه السيوطي إلى عبد بن حميد، وأبي الشيخ.يشير إلى قوله تعالى: <q>﴿ويا قَوْمِ اعْمَلُوا عَلى مَكانَتِكُمْ إنِّي عامِلٌ سَوْفَ تَعْلَمُونَ مَن يَأْتِيهِ عَذابٌ يُخْزِيهِ ومَن هُوَ كاذِبٌ وارْتَقِبُوا إنِّي مَعَكُمْ رَقِيبٌ (٩٣) ولَمّا جاءَ أمْرُنا نَجَّيْنا شُعَيْبًا والَّذِينَ آمَنُوا مَعَهُ بِرَحْمَةٍ مِنّا وأَخَذَتِ الَّذِينَ ظَلَمُوا الصَّيْحَةُ فَأَصْبَحُوا فِي دِيارِهِمْ جاثِمِينَ (٩٤) كَأَنْ لَمْ يَغْنَوْا فِيها ألا بُعْدًا لِمَدْيَنَ كَما بَعِدَتْ ثَمُودُ (٩٥)﴾</q>.تفسير مقاتل بن سليمان ٢/٥٠.أخرجه ابن جرير ١٠/٣٢٧، وابن أبي حاتم ٥/١٥٢٤. وعزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ١٠/٣٢٧.تفسير مقاتل بن سليمان ٢/٥٠.أخرجه ابن جرير ١٠/٣٢٧، وابن أبي حاتم ٥/١٥٢٤.رادَّه القول: راجعه. التاج (ردد).الغبية: الدفعة من المطر. اللسان (غبا).الصَّمّان والصَّمّانة: أرض صُلْبة ذات حجارة إلى جنب رَمْل. لسان العرب (صمم).الأنجاد: جمع نَجْد، وهو ما غلظ من الأرض وأشرف وارتفع واستوى. اللسان (نجد).أخرجه الحاكم ٢/٦٢٠ (٤٠٧١) مختصرًا، وابن جرير١٠/٣٢٣-٣٢٤، وابن أبي حاتم ٩/١٨١٣-٢٨١٤ (١٥٩٢١) من مرسل يعقوب بن أبي سلمة.أخرجه ابن أبي حاتم ٥/١٥٢٢.أخرجه ابن جرير ١٠/٣٢٤.يأفك بهم: يقلبهم. ينظر لسان العرب (أفك).المغاني: المنازل التي كان بها أهلوها، واحدها مَغْنًى. لسان العرب (غنى).أخرجه ابن عساكر ٢٣/٧٤.
7,94," <q>﴿وَمَاۤ أَرۡسَلۡنَا فِی قَرۡیَةࣲ مِّن نَّبِیٍّ إِلَّاۤ أَخَذۡنَاۤ أَهۡلَهَا بِٱلۡبَأۡسَاۤءِ وَٱلضَّرَّاۤءِ لَعَلَّهُمۡ یَضَّرَّعُونَ ۝٩٤﴾</q> - تفسير ٢٨٣٠٠- عن عبد الله بن مسعود -من طريق السدي، عن مرة الهمداني- في الآية، قال: البأساء: الفقر. والضراء: السقم{1}. (٢/١٥١) ٢٨٣٠١- عن الحسن البصري -من طريق عباد بن منصور- <q>﴿بالبأساء﴾</q> قال: البلاء، <q>﴿والضراء﴾</q> هذه الأمراض، والجوع، ونحو ذلك{2}. (ز) ٢٨٣٠٢- عن إسماعيل السُّدِّيّ -من طريق أسباط- <q>﴿أخذنا أهلها بالبأساء والضراء﴾</q>، يقول: بالفقر، والجوع{3}٢٥٩١. (ز) ٢٥٩١ لم يذكر ابنُ جرير (١٠/٣٢٨) في تفسير قوله: <q>﴿بالبأساء والضراء﴾</q> غير قول السدي. ثم قال: «وقد ذكرنا فيما مضى الشواهد على صحة القول بما قلنا في معنى البأساء والضراء بما أغنى عن إعادته في هذا الموضع». ٢٨٣٠٣- قال مقاتل بن سليمان: <q>﴿وما أرسلنا في قرية من نبي﴾</q> فكذَّبوه <q>﴿إلا أخذنا أهلها بالبأساء﴾</q> يعني: قحط المطر، فأصابهم البؤس، وهو الشِّدَّة، <q>﴿والضراء﴾</q> يعني: البلاء؛ <q>﴿لعلهم﴾</q> يعني: لكي <q>﴿يضرعون﴾</q> إلى ربهم، فيُوَحِّدونه، فيرحمهم{4}. (ز) ",footnotes:1:أخرجه ابن جرير ٣/٨٦، وابن أبي حاتم ١/٢٩١، والحاكم ٢/٢٧٣. وعزاه السيوطي إلى وكيع، وابن أبي شيبة، وعبد بن حميد، وابن المنذر، وأبي الشيخ.أخرجه ابن أبي حاتم ١/٢٩١، ٥/١٥٢٥.أخرجه ابن جرير ١٠/٣٢٨.تفسير مقاتل بن سليمان ٢/٥٠. وقد تقدم تفصيلٌ أكثر عند قوله تعالى: <q>﴿والصّابِرِينَ فِي البَأْساءِ والضَّرّاءِ وحِينَ البَأْسِ﴾</q> [البقرة:١٧٧].
7,95," <q>﴿ثُمَّ بَدَّلۡنَا مَكَانَ ٱلسَّیِّئَةِ ٱلۡحَسَنَةَ﴾</q> - تفسير ٢٨٣٠٤- عن عبد الله بن عباس -من طريق علي- في قوله: <q>﴿ثم بدلنا مكان السيئة الحسنة﴾</q>، قال: مكان الشِدَّةِ الرَّخاءَ{1}. (٦/٤٨٤) ٢٨٣٠٥- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿ثم بدلنا مكان السيئة﴾</q> قال: الشر، <q>﴿الحسنة﴾</q> قال: الرخاء، والعدل، والولد{2}. (٦/٤٨٤) ٢٨٣٠٦- عن قتادة بن دعامة -من طريق مَعْمَر- <q>﴿مكان السيئة الحسنة﴾</q> قال: مكان الشدة رخاءً <q>﴿حتى عفوا﴾</q>{3}. (ز) ٢٨٣٠٧- قال مقاتل بن سليمان: <q>﴿ثم بدلنا مكان السيئة الحسنة﴾</q>، يقول: حوَّلنا مكان الشدةِ الرخاءَ{4}. (ز) ٢٨٣٠٨- قال عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿ثم بدلنا مكان السيئة الحسنة حتى عفوا﴾</q> قال: بدَّلنا مكان ما كرهوا ما أحَبُّوا في الدنيا، حتى عفوا من ذلك العذاب، <q>﴿وقالوا قد مس آباءنا الضراء والسراء﴾</q>{5}. (ز) <q>﴿حَتَّىٰ عَفَوا۟﴾</q> - تفسير ٢٨٣٠٩- عن عبد الله بن عباس -من طريق علي- في قوله: <q>﴿حتى عفوا﴾</q>، قال: كَثُروا، وكثُرت أموالُهم{1}. (٦/٤٨٤) ٢٨٣١٠- عن عبد الله بن عباس -من طريق ابن جُرَيْج- في قوله: <q>﴿حتى عفوا﴾</q>، قال: جَمُّوا{7}. (٦/٤٨٤) ٢٨٣١١- عن إبراهيم النخعي -من طريق مغيرة- <q>﴿حتى عفوا﴾</q>، قال: حتى جمُّوا وكثروا{8}. (ز) ٢٨٣١٢- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿حتى عفوا﴾</q>، يقول: حتى كثُرت أموالُهم وأولادُهم{9}. (٦/٤٨٤) ٢٨٣١٣- عن الضحاك بن مزاحم -من طريق جويبر- <q>﴿حتى عفوا﴾</q>، يعني: جمُّوا؛ كثروا{8}. (ز) ٢٨٣١٤- عن عكرمة مولى ابن عباس -من طريق يزيد بن أبي سعيد- <q>﴿حتى عفوا﴾</q>، قال: أشِرُوا، وبَطِروا{11}. (ز) ٢٨٣١٥- عن الحسن البصري -من طريق أبي حمزة العطّار- في قوله: <q>﴿حتى عفوا﴾</q>، قال: حتّى سمنوا{11}. (ز) ٢٨٣١٦- عن قتادة بن دعامة -من طريق مَعْمَر- <q>﴿حتى عفوا﴾</q>، يقول: حتى سُرُّوا بذلك{13}٢٥٩٢. (ز) ٢٥٩٢ انتَقَد ابنُ جرير (١٠/٣٣٢) قول قتادة لمخالفته للغة العرب، قال: «وهذا الذي قاله قتادة في معنى <q>﴿عفوا﴾</q> تأويل لا وجه له في كلام العرب؛ لأنه لا يعرف العفو بمعنى السرور في شيء من كلامها، إلا أن يكون أراد حتى سُرُّوا بكثرتهم وكثرة أموالهم، فيكون ذلك وجهًا، وإن بَعُد». ٢٨٣١٧- عن إسماعيل السُّدِّيّ -من طريق أسباط- <q>﴿حتى عفوا﴾</q>: حتى كَثُروا{14}. (ز) ٢٨٣١٨- قال مقاتل بن حيان:<q>﴿عفوا﴾</q>حتى أشروا وبطروا ولم يشكروا ربهم، وأصله من الكثرة{15}.(ز) (ز) ٢٨٣١٩- قال مقاتل بن سليمان: <q>﴿حتى عفوا﴾</q> يقول: حموا، وسمتوا{16}، فلم يشكروا ربهم{4}. (ز) ٢٨٣٢٠- قال عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿حتى عفوا﴾</q>: كثروا كما يكثر النبات والريش، ثم أخذهم عند ذلك بغتة وهم لا يشعرون{8}٢٥٩٣. (ز) ٢٥٩٣ ذكر ابنُ جرير (١٠/٣٢٩) قولين للسلف في تفسير قوله تعالى: <q>﴿حتى عفو﴾</q>: أحدهما: أنّ معناه: حتى كثروا. وهو قول جمهور السلف. وثانيها: أن معناه: حتى سروا وفرحوا، وهو قول قتادة. وقد رجّح ابنُ جرير القول الأول مستندًا إلى لغة العرب، قال: "قوله: <q>﴿حتى عفوا﴾</q> يقول: حتى كثروا، وكذلك كل شيء كثر فإنه يقال فيه: قد عفا، كما قال الشاعر: ولكنا نعض السيف منها بأسوق عافيات الشحم كوم". <q>﴿وَّقَالُوا۟ قَدۡ مَسَّ ءَابَاۤءَنَا ٱلضَّرَّاۤءُ وَٱلسَّرَّاۤءُ﴾</q> - تفسير ٢٨٣٢١- عن قتادة بن دعامة -من طريق شيبان- في قوله: <q>﴿وقالوا قد مس آباءنا الضراء والسراء﴾</q>، قال: قالوا: قد أتى على آبائِنا مثلُ هذا فلم يَكُن شيئًا{19}. (٦/٤٨٤) ٢٨٣٢٢- قال مقاتل بن سليمان: ... فلم يشكروا ربَّهم، فقالوا مِن غِيرتهم وجهلهم: <q>﴿وقالوا قد مس آباءنا﴾</q> يعني: أصاب آباءَنا <q>﴿الضراء والسراء﴾</q> يعني: الشدة والرخاء، مثل ما أصابنا، فلم يك شيئًا{20}. (ز) <q>﴿فَأَخَذۡنَـٰهُم بَغۡتَةࣰ وَهُمۡ لَا یَشۡعُرُونَ ۝٩٥﴾</q> - تفسير ٢٨٣٢٣- عن قتادة بن دعامة -من طريق شيبان- في قوله: <q>﴿فأخذناهم بغتة وهم لا يشعرون﴾</q>، قال: بغَت القومَ أمرُ الله، وما أخَذ الله قومًا قطُّ إلا عند سُلْوَتِهم وغِرَّتِهم ونعمتِهم، فلا تَغْتَرُّوا بالله؛ إنّه لا يَغْتَرُّ بالله إلا القوم الفاسقون{19}. (٦/٤٨٤) ٢٨٣٢٤- عن إسماعيل السُّدِّيّ -من طريق أسباط- قوله: <q>﴿فأخذناهم بغتة﴾</q>، يقول: أخذهم العذابُ بغتة{11}. (ز) ٢٨٣٢٥- قال مقاتل بن سليمان: يقول: <q>﴿فأخذناهم﴾</q> بالعذاب <q>﴿بغتة﴾</q>: فجأة، <q>﴿وهم لا يشعرون﴾</q> أعَزُّ ما كانوا حتى نزل بهم، وقد أنذَرَتْهم رسلُهم العذابَ من قبل أن ينزل بهم، فذلك قوله: <q>﴿ذلك أن لم يكن ربك مهلك القرى بظلم﴾</q> بالشرك <q>﴿وأهلها غافلون﴾</q> [الأنعام:١٣١]{20}. (ز) ٢٨٣٢٦- عن سفيان [الثوري] -من طريق مهران- قوله: <q>﴿فأخذناهم بغتة﴾</q>، قال: بعد سِتِّين سنة{24}. (ز) ٢٨٣٢٧- عن محمد بن النضر الحارثي -من طريق ابن المبارك- في قوله: <q>﴿فأخذناهم بغتة﴾</q>، قال: أُمْهِلُوا عشرين سنة{24}. (ز) ",footnotes:1:أخرجه ابن جرير ١٠/٣٣٠، وابن أبي حاتم ٥/١٥٢٦. وعزاه السيوطي إلى ابن المنذر.تفسير مجاهد ص٣٣٩، وأخرجه ابن جرير ١٠/٣٢٩، وابن أبي حاتم ٥/١٥٢٦. وعزاه السيوطي إلى ابن أبي شيبة، وعبد بن حميد، وابن المنذر، وأبي الشيخ.أخرجه عبد الرزاق ٢/٢٣٣، وابن جرير ١٠/٣٢٩.تفسير مقاتل بن سليمان ٢/٥٠.أخرجه ابن جرير ١٠/٣٢٩، وابن أبي حاتم ٥/١٥٢٦ من طريق أصبغ بن الفرج.أخرجه ابن جرير ١٠/٣٣٠، وابن أبي حاتم ٥/١٥٢٦. وعزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ١٠/٣٣١، وابن أبي حاتم ٥/١٥٢٦. وعزاه السيوطي إلى أبي الشيخ. وجاء في مطبوعة تفسير الثعلبي ٤/٢٦٤: جهدوا. ولعلها تصحَّفت.أخرجه ابن جرير ١٠/٣٣١.تفسير مجاهد ص٣٣٩، وأخرجه ابن جرير ١٠/٣٢٩-٣٣٠، وابن أبي حاتم ٥/١٥٢٦. وعزاه السيوطي إلى ابن أبي شيبة، وعبد بن حميد، وابن المنذر، وأبي الشيخ.أخرجه ابن جرير ١٠/٣٣١.أخرجه ابن أبي حاتم ٥/١٥٢٧.أخرجه ابن أبي حاتم ٥/١٥٢٧.أخرجه عبد الرزاق ٢/٢٣٣، وابن جرير ١٠/٣٣١.أخرجه ابن جرير ١٠/٣٣٠.تفسير الثعلبي ٤/٢٦٤.كذا في المطبوع، ولعلها: جمُّوا وسَمنوا. تصحَّفت.تفسير مقاتل بن سليمان ٢/٥٠.أخرجه ابن جرير ١٠/٣٣١.أخرجه ابن أبي حاتم ٥/١٥٢٧. وعزاه السيوطي إلى عبد بن حميد.تفسير مقاتل بن سليمان ٢/٥٠-٥١.أخرجه ابن أبي حاتم ٥/١٥٢٧. وعزاه السيوطي إلى عبد بن حميد.أخرجه ابن أبي حاتم ٥/١٥٢٧.تفسير مقاتل بن سليمان ٢/٥٠-٥١.أخرجه ابن أبي حاتم ٥/١٥٢٨.أخرجه ابن أبي حاتم ٥/١٥٢٨.
