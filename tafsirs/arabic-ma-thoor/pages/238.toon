quran[8]{c,v,t}:
  12,23,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَرَ ٰ⁠وَدَتۡهُ ٱلَّتِی هُوَ فِی بَیۡتِهَا عَن نَّفۡسِهِۦ وَغَلَّقَتِ ٱلۡأَبۡوَ ٰ⁠بَ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٧٠٠١<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد بن أبي عروبة- في قوله: <span class="qpc-hafs">﴿وراودته التى هو في بيتها﴾</span>، قال: هي امرأة العزيز{1}. (٨/٢١٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٠٠٢<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- قال: فأَحَبَّته امرأتُه، فقالت له: يا يوسف، ما أحْسَنَ شَعَرَك! قال: هو أولُ ما يتناثر مِن جسدي. قالت: يا يوسفُ، ما أحْسَنَ عينيك! قال: هما أولُ ما يسيلان إلى الأرض مِن جسدي. قالت: يا يوسفُ، ما أحْسَنَ وجهَك! قال: هو لِلتُّراب يأكلُه{2}. (٨/١٨٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٠٠٣<span class="dash">-</span></span> عن <span class="name-3">محمد بن إسحاق</span>، نحوه{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٠٠٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وراودته التي هو في بيتها عن نفسه وغلقت الأبواب﴾</span> على نفسها وعلى يوسفَ في أمر الجِماع{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٠٠٥<span class="dash">-</span></span> عن <span class="name-3">محمد بن إسحاق</span> -من طريق سلمة-: ولَمّا بلغ أشُدَّه راودته التي هو في بيتها عن نفسه؛ امرأةُ العزيز{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٠٠٦<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿وراودته التى هو في بيتها عن نفسه﴾</span>، قال: حين بَلَغ مَبْلَغَ الرِّجال{6}. (٨/٢١٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٠٠٧<span class="dash">-</span></span> قال أبو عبد الله الشامي: أوَّلَ ما قالت له: يا يوسفُ، ما أحسنَ شَعْرَك! قال: أما إنَّه أولُ شيءٍ يَبْلى مِنِّي{7}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَقَالَتۡ هَیۡتَ لَكَۚ﴾</span> - قراءات، وتفسير</h3></p><p><div></p><p><p><span class="item-no">٣٧٠٠٨<span class="dash">-</span></span> عن ابن عباس، قال: أقرَأني رسولُ الله ﷺ: <span class="qpc-hafs">﴿هَيْتَ لَكَ﴾</span>، يعني: هَلُمَّ لك{8}. (٨/٢٢٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٠٠٩<span class="dash">-</span></span> عن أبي وائل، قال: قرأها <span class="name-1">عبد الله [بن مسعود]</span>: <span class="qpc-hafs">﴿هَيْتَ لَكَ﴾</span> بفتح الهاء والتاء، فقلنا له: إنّ ناسًا يقرءونها: ‹هِيتُ لَكَ›. فقال: دعوني، فإني أقرأ كما أُقرِئْتُ، أحبُّ إلَيَّ{9}. (٨/٢١٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٠١٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن مسعود</span> -من طريق شقيق- أنّه قرأ: <span class="qpc-hafs">﴿هَيْتَ لَكَ﴾</span> بنصب الهاء والتاء، ولا يَهْمِزُ{10}. (٨/٢١٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٠١١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق سعيد- أنّه كان يقرأ كما يقرأ عبدُ الله: <span class="qpc-hafs">﴿هَيْتَ لَكَ﴾</span>. وقال: هَلُمَّ لك، تدعوه إلى نفسها{11}<span class=comment-ref>٣٣٣٩</span>. (٨/٢٢٠)</p></p><p></div></p><p><div><span class=comment-ref>٣٣٣٩</span> <span class="comment-type-1">وجّه</span> <u>ابنُ جرير</u> (١٣/٧٠) هذه القراءة، فقال: "قَرَأْتُه عامَّةُ قُرّاءِ الكوفة والبصرة: <span class="qpc-hafs">﴿هيت لك﴾</span> بفتح الهاء والتاء، بمعنى: هلُمَّ لك، وادْنُ، وتَقَرَّب، <span class="mustanad">كما قال الشاعر</span> لعلي بن أبي طالب ﵁:</p><p>أبلغ أمير المؤمنين ... أخا العراق إذا أتيتا</p><p>أن العراق وأهله ... عنق إليك فهيت هيتا</p><p>يعني: تعال واقرب. وبنحو الذي قلنا في ذلك <span class="mustanad">تأوَّله مَن قرأه كذلك</span>".</div></p><p><div></p><p><p><span class="item-no">٣٧٠١٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق قتادة- أنّه قرأ: ‹هِئْتُ لَكَ› مكسورة الهاء، مضمومة التاء، مهموزة. قال: تهيَّأتُ لك{12}. (٨/٢٢١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٠١٣<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطية العوفي- في قوله: <span class="qpc-hafs">﴿هَيْتَ لَكَ﴾</span>، قال: هلُمَّ لك، وهي بالقِبْطِيَّة{13}. (٨/٢٢٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٠١٤<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق الضحاك-: ‹هِئْتُ لَكَ›، قال: تَهَيَّأْتُ لك. وكان يقرأها مهموزة: ‹هِئْتُ لَكَ›{14}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٠١٥<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>: أنّ نافع بن الأزرق قال له: أخبِرني عن قوله ﷿: <span class="qpc-hafs">﴿هَيْتَ لَكَ﴾</span>. قال: تَهَيَّأتُ لك، قُمْ، فاقضِ حاجتك. قال: وهل تعرف العرب ذلك؟ قال: نعم، أما سمِعتَ أُحَيْحةَ الأنصاري وهو يقول:</p><p>به أحمِي المصابَ إذا دعاني إذا ما قيل للأبطال هَيتا{15}. (٨/٢٢١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٠١٦<span class="dash">-</span></span> عن حماد، عن عاصم بن بهدلة، قال: كان <span class="name-2">أبو وائل</span> يقول: ‹هِئْتُ لَكَ›، أي: تَهَيَّأْتُ لك. وكان <span class="name-2">أبو عمرو بن العلاء</span>، و<span class="name-3">الكسائي</span> يُنكِران هذه القراءة{16}<span class=comment-ref>٣٣٤٠</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٣٣٤٠</span> <span class="comment-type-1">وجّه</span> <u>ابنُ جرير</u> (١٣/٧٤) هذه القراءة، فقال: «وقرأ ذلك جماعة من المتقدمين: ‹وقالَتْ هِئْتُ لَكَ› بكسر الهاء وضم التاء والهمز، بمعنى: تهيأت لك، من قول القائل: هِئْتُ للأمر أهِيءُ هيئة».</p><p>و<span class="comment-type-4">بنحوه</span> قال <u>ابنُ كثير</u> (٨/٢٨).</p><p>ثم <span class="comment-type-3">رجّح</span> <u>ابنُ جرير</u> (١٣/٧٦) <span class="mustanad">مستندًا إلى الأعرف لغة، والسنة</span> قراءة:<span class="qpc-hafs">﴿هيت لك﴾</span> بفتح الهاء والتاء، فقال: «وأولى القراءة في ذلك قراءة من قرأه: <span class="qpc-hafs">﴿هيت لك﴾</span> بفتح الهاء والتاء، وتسكين الياء؛ لأنها اللغة المعروفة في العرب دون غيرها، وأنها فيما ذكر قراءة رسول الله ﷺ». وذكر الآثار على ذلك.</div></p><p><div></p><p><p><span class="item-no">٣٧٠١٧<span class="dash">-</span></span> عن <span class="name-2">أبي وائل [شقيق بن سلمة]</span> -من طريق عاصم بن بهدلة- أنّه كان يقرأ: ‹هِئْتُ لَكَ› رفع، أي: تهيَّأتُ لك{17}. (٨/٢٢٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٠١٨<span class="dash">-</span></span> عن <span class="name-2">أبي عبد الرحمن السُّلَمِيِّ</span> -من طريق عاصم-= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٠١٩<span class="dash">-</span></span> و<span class="name-2">عكرمة مولى ابن عباس</span> -من طريق قتادة-، مثله{18}. (٨/٢٢٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٠٢٠<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span>: (هُيِّئَتْ لَكَ){19}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٠٢١<span class="dash">-</span></span> عن <span class="name-2">زِرِّ بن حُبَيْش</span> -من طريق عاصم- أنّه كان يقرأ: <span class="qpc-hafs">﴿هَيْتَ لَكَ﴾</span> نصبًا، أي: هَلُمَّ لك.= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٠٢٢<span class="dash">-</span></span> وقال أبو عبيد: كذلك كان <span class="name-3">الكسائي</span> يحكيها، قال: هي لغةٌ لأهل نجد وقَعَتْ إلى الحجاز، معناها: تعالَهْ{20}. (٨/٢٢٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٠٢٣<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span> -من طريق أبي حصين- في قوله: <span class="qpc-hafs">﴿هَيْتَ لَكَ﴾</span>، قال: تعال{21}. (٨/٢٢١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٠٢٤<span class="dash">-</span></span> عن <span class="name-2">يحيى بن وثّاب</span> أنّه قرأها:‹هِيتُ لَكَ›، يعني: بكسر الهاء، وضم التاء، بمعنى: تهيَّأتُ لك{22}. (٨/٢٢١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٠٢٥<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن جُرَيْج- في قوله: <span class="qpc-hafs">﴿هَيْتَ لَكَ﴾</span>، قال: ألْقَتْ نفسَها، واسْتَلْقَتْ له، ودَعَتْه إلى نفسِها. وهي لُغَةٌ{23}. (٨/٢٢١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٠٢٦<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- <span class="qpc-hafs">﴿وقالَتْ هَيْتَ لَكَ﴾</span>، قال: هي كلمة عَرَبِيَّةٌ يدعون بها، أي: هَلُمَّ لك، فدَعَتْهُ به{24}. (٨/٢٢١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٠٢٧<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span> -من طريق النَّضْر بن عربي- في قوله: <span class="qpc-hafs">﴿هَيْتَ لَكَ﴾</span>، قال: هَلُمَّ لك. وهي بالحورانية{25}. (٨/٢٢٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٠٢٨<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق عمرو- في قوله: <span class="qpc-hafs">﴿هَيْتَ لَكَ﴾</span>، قال: كلمة بالسُّريانية، أي: عليك{26}. (٨/٢٢١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٠٢٩<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق قتادة- <span class="qpc-hafs">﴿هَيْتَ لَكَ﴾</span>، يقول بعضُهم: هَلُمَّ لك{26}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٠٣٠<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق مَعْمَر- في قوله تعالى: <span class="qpc-hafs">﴿وقالَتْ هَيْتَ لَكَ﴾</span>، قال: يقول بعضهم: هلُمَّ لك{28}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٠٣١<span class="dash">-</span></span> عن <span class="name-2">عبد الله بن عامر اليحصبي</span> أنّه قرأ: ‹هِيتَ لَكَ›، بكسر الهاء، وفتح التاء{29}. (٨/٢٢٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٠٣٢<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- قال: قالت: <span class="qpc-hafs">﴿هَيْتَ لَكَ﴾</span>: هلُمَّ لك. وهي بالقِبْطِيَّة{30}. (٨/١٨٩، ٢٢٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٠٣٣<span class="dash">-</span></span> قال أبو عبيدة معمر بن المثنى: شهدتَ <span class="name-2">أبا عمرو [بن العلاء]</span> -وسأله أبو أحمد، أو أحمد، وكان عالمًا بالقرآن- عن قول مَن قال: ‹هِئْتُ لَكَ› بكسر الهاء، وهمز الياء. فقال أبو عمرو: نبْسِيٌّ -أي: باطل-، جعلها (فِلْتُ) مِن: (تَهَيَّأْتُ)، فهذا الخندق، فاستعرِضِ العربَ حتى تنتهي إلى اليمن؛ هل تعرفُ أحدًا يقول: هِئْتُ لك؟{16}<span class=comment-ref>٣٣٤١</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٣٣٤١</span> ذكر <u>ابنُ عطية</u> (٥/٦٤-٦٦) قراءة من قرأ ذلك: ›هَيتُ‹، ومَن قرأها: (هَيتِ)، ومن قرأها: <span class="qpc-hafs">﴿هَيتَ﴾</span> ومن قرأها: ›هِيتَ‹، ثم <span class="comment-type-4">علّق</span> قائلًا: «وهذه الأربع بمعنًى واحد، واختلفت باختلاف اللغات فيها، ومعناه الدعاء، أي: تعال وأقبل على هذا الأمر ... والتاء على هذه اللغات كلها مبنية، فهي في حال الرفع كقبلُ وبعدُ، وفي الكسرِ على الباب لالتقاء الساكنين، وفي حال النصب ككيف ونحوها». و<span class="comment-type-4">علق</span> على قراءة: ›هِئْتُ‹، فقال: «وهذا يحتمل أن يكون مِن هاء الرجل يهيء إذا أحسن هيئته، على مثال: جاء يجيء. ويحتمل أن يكون بمعنى: تهيأت، كما يقال: فئتُ وتفيأتُ بمعنًى واحد، <span class="mustanad">قال الله ﷿</span>: <span class="qpc-hafs">﴿يتفيأ ظلاله﴾</span> [النحل:٤٨]، <span class="comment-type-4">وقال</span>: <span class="qpc-hafs">﴿حتى تفيء إلى أمر الله﴾</span> [الحجرات:٩]». و<span class="comment-type-4">ذكر</span> <u>ابنُ عطية</u> قراءة عن الحلواني عن هشام أنه قرأ: ‹هِئِْتَ›، ونقل تعليق أبي عليٍّ عليها، فقال: «وقرأ الحلواني عن هشام ‹هِئِْتَ› بكسر الهاء والهمز، وفتح التاء، قال أبو علي: ظاهرٌ أنّ هذه القراءة وهمٌ، لأنّه كان ينبغي أن تقول: هئت لي، <span class="mustanad">وسياق الآيات</span> يخالف هذا».</p><p>و<span class="comment-type-2">انتقد</span> <u>ابنُ كثير</u> (٨/٢٨) قراءة مَن قرأ ذلك: (هَيْتِ لك) بقوله: «وهي غريبة».</div></p><p><div></p><p><p><span class="item-no">٣٧٠٣٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وقالَتْ هَيْتَ لَكَ﴾</span>، يعني: هَلُمَّ لك نفسي، تريد المرأة: الجماع، فغلبته بالكلام، ... وأُلْقِي عليها شهوةُ أربعين إنسانًا{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٠٣٥<span class="dash">-</span></span> عن <span class="name-3">محمد بن إسحاق</span> -من طريق سلمة- <span class="qpc-hafs">﴿وقالَتْ هَيْتَ لَكَ﴾</span>، أي: تعال، فأنا لك{33}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٠٣٦<span class="dash">-</span></span> قال <span class="name-3">سفيان الثوري</span> -من طريق عبد العزيز- قال: بلغني في قوله: <span class="qpc-hafs">﴿هَيْتَ لَكَ﴾</span>، قال: هَلُمَّ لك{34}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٠٣٧<span class="dash">-</span></span> قال <span class="name-3">سفيان الثوري</span>، في قوله: <span class="qpc-hafs">﴿هَيْتَ لَكَ﴾</span>: تَهَيَّأْتُ لك، و‹هِيتَ لَكَ›: هَلُمَّ لك{35}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٠٣٨<span class="dash">-</span></span> قال <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿وقالَتْ هَيْتَ لَكَ﴾</span>، قال: هَلُمَّ لك إلَيَّ{36}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿قَالَ مَعَاذَ ٱللَّهِۖ إِنَّهُۥ رَبِّیۤ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٧٠٣٩<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن جريج- في قوله: <span class="qpc-hafs">﴿إنه ربي﴾</span>، قال: سيِّدي، يعني: زوج المرأة{37}. (٨/٢٢٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٠٤٠<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نَجِيح- في قوله: <span class="qpc-hafs">﴿إنه ربي﴾</span>، قال: سيِّدي{24}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٠٤١<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- قال: <span class="qpc-hafs">﴿قال معاذ الله إنه ربى﴾</span>، قال: سيِّدي{39}. (٨/١٨٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٠٤٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿قال معاذ الله﴾</span> يعني: أعوذ بالله، <span class="qpc-hafs">﴿إنه ربي﴾</span> يقول: إنّه سيِّدي، يعني: زوجها{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٠٤٣<span class="dash">-</span></span> عن <span class="name-3">محمد بن إسحاق</span> -من طريق سلمة- <span class="qpc-hafs">﴿قال معاذ الله إنه ربي﴾</span>: يعني: أطفير. يقول: إنّه سيِّدي{41}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٠٤٤<span class="dash">-</span></span> عن <span class="name-3">أبي بكر بن عياش</span>، في قوله: <span class="qpc-hafs">﴿إنه ربي﴾</span>، قال: يعني: زوجها{42}<span class=comment-ref>٣٣٤٢</span>. (٨/٢٢٣)</p></p><p></div></p><p><div><span class=comment-ref>٣٣٤٢</span> <span class="comment-type-4">ذكر</span> <u>ابنُ عطية</u> (٥/٦٦-٦٧) في عود الضمير في قوله: <span class="qpc-hafs">﴿إنه ربي﴾</span> عدة احتمالات، فقال: «يحتمل أن يعود الضمير في <span class="qpc-hafs">﴿إنه﴾</span> على الله ﷿، ويحتمل أن يريد العزيز سيده، أي: فلا يصلح لي أن أخونه وقد أكرم مثواي وائتمنني، ويحتمل أن يكون الضمير للأمر والشأن، ثم يبتدئ: <span class="qpc-hafs">﴿ربي أحسن مثواي﴾</span>».</p><p>و<span class="comment-type-3">رجّح</span> <u>ابنُ تيمية</u> (٤/٢٣) أنّ المراد بالرب هنا: سيِّده، <span class="mustanad">مستندًا إلى الدلالة العقلية</span>، فقال: «المراد بربِّه في أصح القولين هنا: سيِّده، وهو زوجها الذي اشتراه مِن مصر الذي قال لامرأته: <span class="qpc-hafs">﴿أكرمي مثواه عسى أن ينفعنا أو نتخذه ولدا﴾</span>. قال الله تعالى: <span class="qpc-hafs">﴿وكذلك مكنا ليوسف في الأرض ولنعلمه من تأويل الأحاديث والله غالب على أمره ولكن أكثر الناس لا يعلمون﴾</span>. فلمّا وصّى به امرأته فقال لها: <span class="qpc-hafs">﴿أكرمي مثواه﴾</span> قال يوسف: <span class="qpc-hafs">﴿إنه ربي أحسن مثواي﴾</span>. ولهذا قال: <span class="qpc-hafs">﴿إنه لا يفلح الظالمون﴾</span>، والضمير في <span class="qpc-hafs">﴿إنه﴾</span> معلوم بينهما، وهو سيدها».</div></p><p><h3><span class="qpc-hafs">﴿أَحۡسَنَ مَثۡوَایَۖ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٧٠٤٥<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- قال: <span class="qpc-hafs">﴿أحسن مثواى﴾</span>؛ فلا أخُونُه في أهلِه{43}. (٨/١٨٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٠٤٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿أحسن مثواي﴾</span>: أكْرَم مثواي، يعني: منزِلَتي{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٠٤٧<span class="dash">-</span></span> عن <span class="name-3">محمد بن إسحاق</span> -من طريق سلمة- قال: <span class="qpc-hafs">﴿أحسن مثواي﴾</span>: أمِنَني على بيته وأهله{41}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿إِنَّهُۥ لَا یُفۡلِحُ ٱلظَّـٰلِمُونَ ۝٢٣﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٧٠٤٨<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿إنه لا يفلح﴾</span> يعني: لا يفوز <span class="qpc-hafs">﴿الظالمون﴾</span> إن ظلمتُه في أهله{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٠٤٩<span class="dash">-</span></span> عن <span class="name-3">محمد بن إسحاق</span> -من طريق سلمة- <span class="qpc-hafs">﴿إنه لا يفلح الظالمون﴾</span>، قال: هذا الذي تدعوني إليه ظُلْمٌ، ولا يُفْلِح مَن عَمِل به {47}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن أبي حاتم ٧/٢١٢٠. وعزاه السيوطي إلى أبي الشيخ.|2:أخرجه ابن جرير ١٣/٧٠ مختصرًا بلفظ: أحبته، وابن أبي حاتم ٧/٢١٢٠.|3:تفسير الثعلبي ٥/٢١٠، وتفسير البغوي ٤/٢٢٨-٢٢٩.|4:تفسير مقاتل بن سليمان ٢/٣٢٧.|5:أخرجه ابن جرير ١٣/٦٩.|6:أخرجه ابن أبي حاتم ٧/٢١٢٠.|7:تفسير ابن أبي زمنين ٢/٣٢١.|8:عزاه السيوطي إلى ابن مردويه.</p><p>وهي قراءة متواترة، قرأ بها العشرة، ما عدا نافعًا، وأبا جعفر، وابن ذكوان، فإنهم قرؤوا: ‹هِيتَ لَكَ› بكسر الهاء، وياء ساكنة، وفتح التاء، وقرأ هشام كذلك إلا أنّه همز الياء، وعنه رواية أخرى: ‹هِئْتُ لَكَ› بكسر الهاء، وهمزة ساكنة، وضم التاء، وقرأ ابن كثير: ‹هَيْتُ لَكَ› بفتح الهاء، وياء ساكنة، وضم التاء. انظر: النشر ٢/٢٩٤-٢٩٥، والإتحاف ص٣٣٠.|9:أخرجه عبد الرزاق ١/٣٢٠، والبخاري (٤٦٩٢)، وابن جرير ١٣/٧٧-٧٨، وابن أبي حاتم ٧/٢١٢١، والطبراني (٨٦٨٠، ٨٦٨١)، وابن مردويه -كما في فتح الباري ٨/٣٦٤-. وعزاه السيوطي إلى ابن المنذر، وأبي الشيخ.|10:أخرجه ابن جرير ١٣/٧٨، والحاكم ٢/٣٤٦.|11:أخرجه ابن جرير ١٣/٧١، ٧٣ من طريق عكرمة، وابن أبي حاتم ٧/٢١٢١. وعزاه السيوطي إلى أبي عبيد، وابن المنذر.|12:أخرجه ابن جرير ١٣/٧٤-٧٥، وابن أبي حاتم ٧/٢١٢١. وعزاه السيوطي إلى أبي عبيد.|13:أخرجه ابن أبى شيبة ١٠/٤٧٢-٤٧٣، وفيه: بالنبطية، وابن جرير ١٣/٧١ من طريق سعيد بن جبير، وابن أبي حاتم ٧/٢١٢١. وعزاه السيوطي إلى ابن المنذر.|14:أخرجه ابن أبي حاتم ٧/٢١٢١.|15:أخرجه الطستي -كما في الإتقان ٢/٨٧-.|16:أخرجه ابن جرير ١٣/٧٥.|17:أخرجه ابن جرير ١٣/٧٥. وعزاه السيوطي إلى ابن المنذر.|18:أخرجه ابن جرير ١٣/٧٥، كما أخرجه عبد الرزاق ١/٣٢٠ عن عكرمة. وكذلك علَّقه ابن أبي حاتم ٧/٢١٢١. وفي تفسير الثعلبي ٥/٢٠٨ عن عكرمة: أي: زيّنت لك، وحسنت.|19:عزاه الحافظ ابن حجر في الفتح ٨/٣٦٤ إلى عبد بن حميد.|20:أخرجه ابن جرير ١٣/٧٢، ٧٤. وعزاه السيوطي إلى ابن المنذر.|21:أخرجه ابن جرير ١٣/٧٠، وأبو الشيخ -كما في فتح الباري ٨/٣٦٤-.|22:عزاه السيوطي إلى أبي عبيد، وابن المنذر، وأبي الشيخ.|23:أخرجه ابن أبي حاتم ٧/٢١٢١. وعزاه السيوطي إلى أبي الشيخ.|24:تفسير مجاهد ص٣٩٤.|25:أخرجه عبد بن حميد –كما في التغليق ٤/٢٢٩، وابن جرير ١٣/٧١، ٧٢. وعلَّقه البخاري في صحيحه ٤/١٧٣٠. وعزاه السيوطي إلى أبي الشيخ.|26:أخرجه ابن جرير ١٣/٧٢.|27:أخرجه ابن جرير ١٣/٧٢.|28:أخرجه عبد الرزاق ١/٣٢٠.|29:عزاه السيوطي إلى أبي عبيد، وابن المنذر.|30:أخرجه ابن جرير ١٣/٧٢، وابن أبي حاتم ٧/٢١٢١.|31:أخرجه ابن جرير ١٣/٧٥.|32:تفسير مقاتل بن سليمان ٢/٣٢٧.|33:أخرجه ابن جرير ١٣/٧٤، وابن أبي حاتم ٧/٢١٢٢.|34:أخرجه ابن جرير ١٣/٧٣.|35:تفسير سفيان الثوري ص١٣٩-١٤٠.|36:أخرجه ابن جرير ١٣/٧٤.|37:أخرجه ابن جرير ١٣/٧٩، وابن أبي حاتم ٧/٢١٢٢. وعزاه السيوطي إلى ابن أبي شيبة، وابن المنذر، وأبي الشيخ.|38:تفسير مجاهد ص٣٩٤.|39:أخرجه ابن جرير ١٣/٧٨. وعزاه السيوطي إلى ابن أبي حاتم.|40:تفسير مقاتل بن سليمان ٢/٣٢٧.|41:أخرجه ابن جرير ١٣/٧٩.|42:عزاه السيوطي إلى ابن المنذر.|43:أخرجه ابن جرير ١٣/٧٩. وعزاه السيوطي إلى ابن أبي حاتم.|44:تفسير مقاتل بن سليمان ٢/٣٢٧.|45:أخرجه ابن جرير ١٣/٧٩.|46:تفسير مقاتل بن سليمان ٢/٣٢٧.|47:أخرجه ابن جرير ١٣/٨٠.
  12,24,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَلَقَدۡ هَمَّتۡ بِهِۦۖ وَهَمَّ بِهَا﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٧٠٥٠<span class="dash">-</span></span> عن <span class="name-1">علي بن أبى طالب</span> -من طريق عمر بن علي بن أبي طالب- في قوله: <span class="qpc-hafs">﴿ولقد همت به وهم بها﴾</span>، قال: طمِعت فيه، وطمِع فيها، وكان مِنَ الطَّمَع أن هَمَّ أن يَحُلَّ التِّكَّة{1}، فقامت إلى صنمٍ مُكَلَّلٍ بالدُّرِّ والياقوت في ناحية البيت، فسَتَرَتْهُ بثوب أبيضٍ بينها وبينه، فقال: أيَّ شيء تصنعين؟ فقالتْ: أستحي مِن إلهي أن يراني على هذه الصورة. فقال يوسف ﵇: تستحين مِن صنمٍ لا يأكل ولا يشرب، ولا أستحي أنا مِن إلهي الذي هو قائم على كل نفس بما كسبت؟! ثم قال: لا تنالينها مِنِّي أبدًا. وهو البُرْهان الذي رَأى{2}. (٨/٢٢٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٠٥١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق ابن أبي مليكة- أنّه سُئِل عن هَمِّ يوسف ﵇: ما بلغ؟ قال: حَلَّ الهِمْيان{3} -يعنى: السراويل-، وجلس منها مَجْلِسَ الخاتِن، فصيح به: يا يوسف، لا تكن كالطَّيْرِ له رِيشٌ، فإذا زَنى قَعَد ليس له رِيش{4}. (٨/٢٢٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٠٥٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق ابن أبي مُلَيْكة- قال: لَمّا همَّت به تَزَيَّنَتْ، ثُمَّ اسْتَلْقَتْ على فراشها، وهَمَّ بها، وجلس بين رِجْلَيها يَحُلُّ ثيابه، فنُودِيَ مِن السماء: يا ابن يعقوب، لا تكُن كطائِرٍ نُتِف ريشَه، فبَقِيَ لا ريش له. فلم يَتَّعِظْ على النِّداء شيئًا، حتى رأى برهان ربه؛ جبريل ﵇ في صورة يعقوب، عاضًّا على إصبعَيه، ففَزِع، فخرَجت شهوتُه مِن أنامله، فوثَب إلى الباب، فوَجَدَه مُغْلَقًا، فرفع يوسفُ رجلَه، فضرب بها البابَ الأَدْنى، فانفَرَج له، واتَّبَعَته، فأَدْرَكَتْه، فوَضَعَتْ يديها في قميصه، فشقَّته حتى بلغت عَضَلَة ساقِه، فألفيا سيدها لدى الباب{5}. (٨/٢٢٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٠٥٣<span class="dash">-</span></span> عن عبيد الله بن أبي يزيد، قال: سمعتُ <span class="name-1">عبد الله بن عباس</span> سُئِل: ما بلغ مِن هَمِّ يوسف؟ قال: حَلَّ الهِمْيان، وجلس منها مجلس المُجامِع{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٠٥٤<span class="dash">-</span></span> عن ابن أبي عطية، قال: سألتُ <span class="name-1">عبد الله بن عباس</span>: ما بلغ مِن هَمِّ يوسف؟ قال: اسْتَلْقَتْ له على قفاها، وقعد بين رجليها؛ لِينزِع ثيابه{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٠٥٥<span class="dash">-</span></span> قال <span class="name-2">سعيد بن جبير</span>: أطلق تِكَّة سراويلِه{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٠٥٦<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق الأعمش، وابن أبي نَجِيح- في قوله: <span class="qpc-hafs">﴿وهم بها﴾</span>، قال: حلَّ سراويلَه حتى بلغ ثُنَّتَه{9}، وجلس منها مجلس الرجل مِن امرأته، فمُثِّل له يعقوبُ ﵇، فضرب بيدِه على صدره، فخرَجت شهوتُه مِن أنامله{10}. (٨/٢٢٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٠٥٧<span class="dash">-</span></span> قال <span class="name-2">الضحاك بن مزاحم</span>: جرى الشيطانُ فيما بينهما، فضرب بإحدى يديه إلى جِيدِ يوسف، وباليد الأخرى إلى جِيد المرأة، حتّى جَمَعَ بينهما{11}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٠٥٨<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span>: حَلَّ سراويلَه، وجعل يُعالِج ثيابَه{12}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٠٥٩<span class="dash">-</span></span> قال <span class="name-2">القاسم بن أبي بَزَّة</span> -من طريق شبل- <span class="qpc-hafs">﴿ولقد همت به وهم بها﴾</span>، قال: أمّا هَمُّها به فاسْتَلْقَتْ له، وأما هَمُّه بها فإنّه قعد بين رجليها، ونزع ثيابه{13}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٠٦٠<span class="dash">-</span></span> عن <span class="name-2">عبد الله بن أبي مليكة</span> -من طريق ابن جريج- <span class="qpc-hafs">﴿ولقد همت به وهم بها﴾</span>، قال: اسْتَلْقَتْ له، وحَلَّ ثيابَه{14}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٠٦١<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- قال: فلم تزلْ به حتى أطْمَعَها، فهمَّت به وهمَّ بها، فدخلا البيتَ، <span class="qpc-hafs">﴿وغلقت الأبواب﴾</span>، فذهب لِيَحُلَّ سراويلَه...{15}. (٨/١٨٩-١٩٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٠٦٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ولقد همت به﴾</span> يقول: هَمَّت المرأةُ بيوسف، حتّى اسْتَلْقَتْ لِلجماع، <span class="qpc-hafs">﴿وهم بها﴾</span> يوسفُ حين حَلَّ سراويلَه، وجلس بين رِجليها{16}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٠٦٣<span class="dash">-</span></span> عن <span class="name-3">محمد بن إسحاق</span> -من طريق سلمة- قوله: <span class="qpc-hafs">﴿ولقد همت به وهم بها﴾</span>، فأَكَبَّت عليه تُطِيعه مَرَّة، وتُخِيفُه مَرَّة أخرى، وتدعوه إلى لَذَّةٍ، وهي مِن حاجة الرجال في جمالها وحُسْنِها ومُلْكِها، وهو شابٌّ مُقْتَبِلٌ يَجِدُ مِن شَبَقِ الرِّجال ما يجد الرجال، حتّى رَقَّ لها مِمّا يرى مِن كَلَفِها{17} به، ولم يَتَخَوَّف منها حتى هَمَّ بها وهَمَّت به، حتى دخلوا في بعض بيوته، فلمّا هَمَّ وتَهَيَّأ لذلك رأى برهانَ ربه، فانكشف عنها هارِبًا{18}<span class=comment-ref>٣٣٤٣</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٣٣٤٣</span> أفادت آثارُ السلف أنّ يوسف حصل منه هَمُّ بمواقعة امرأة العزيز. وهذا ما <span class="comment-type-3">رجّحه</span> <u>ابنُ جرير</u> (١٣/٨٢) <span class="mustanad">مستندًا إلى آثار السلف</span> بقوله: «فأمّا ما كان مِن هَمِّ يوسف بالمرأة وهمها به فإنّ أهل العلم قالوا في ذلك ما أنا ذاكره» وذكر أقوال السلف على هذا المعنى الذي ذكرناه.</p><p>وذكر <u>ابنُ عطية</u> (٥/٦٨) أنّه لم يَصِحَّ كونُ يوسف نبيًّا في ذلك الوقت، وبناءً عليه <span class="comment-type-3">رَجَّح</span> أنّ يوسف ﵇ هَمَّ بمواقعة امرأة العزيز، فقال: «والذي أقول في هذه الآية: إنّ كون يوسف نبيًّا في وقت هذه النازلة لم يَصِحَّ، ولا تظاهرت به رواية، وإذا كان ذلك فهو مؤمن قد أُوتِي حكمًا وعلمًا، ويجوز عليه الهَمُّ الذي هو إرادة الشيء دون مواقعته، وأن يستصحب الخاطرَ الرديءَ على ما في ذلك مِن الخطيئة». ثم <span class="comment-type-4">بيّن</span> <span class="mustanad">مستندًا إلى دلالة العقل</span> أنّ يوسف لو كان نبيًّا حينئذ فلا يجوز عليه إلا الهمُّ الذي هو الخاطر الغير مستصحب للعزم ولا للفعل، فقال: «وإن فرضناه نبيًّا في ذلك الوقت فلا يجوز عليه عندي إلا الهمُّ الذي هو الخاطر، ولا يصح عليه شيء مما ذكر مِن حل تكة ونحو ذلك؛ لأنّ العصمة مع النبوة، وما روي من أنّه قيل له: تكون في ديوان الأنبياء وتفعل فعل السفهاء. فإنّما معناه: العِدَة بالنبوة فيما بعد. والهمُّ بالشيء مرتبتان: فالواحدة الأولى تجوز عليه مع النبوة، والثانية الكبرى لا تقع إلا مِن غير نبي؛ لأن استصحاب خاطر المعصية والتلذذ به معصية تكتب، وقول النبي ﷺ: «إنّ الله تجاوز لِأُمَّتي ما حدَّثت به نفوسَها ما لم تنطِق به أو تعمل». معناه: من الخواطر، وأما استصحاب الخاطر فمحال أن يكون مباحًا».</p><p>و<span class="comment-type-3">رجّح</span> <u>ابنُ تيمية</u> (٤/٣٤-٣٥) أنّ همَّ يوسف إنّما كان همَّ خَطَرات لا هم إصرار، وهو غير مؤاخذ به، <span class="mustanad">واستدل على ذلك بالسياق في مواضع</span>: الأول: «دلالة الآية، حيث قال تعالى: <span class="qpc-hafs">﴿لولا أن رءا برهان ربه﴾</span> فصرف الله به ما كان هَمَّ به وكتب له حسنة كاملة، ولم يكتب عليه خطيئة، إذ فعل خيرًا ولم يفعل سيئة. الثاني: أنّ الله لم يذكر عن يوسف توبة في قصة امرأة العزيز، وفي هذا دليلٌ على أنّ يوسف لم يُذنِب أصلًا في تلك القصة. الثالث: أنّه تعالى قال عن نبيه يوسف: <span class="qpc-hafs">﴿كذلك لنصرف عنه السوء والفحشاء إنه من عبادنا المخلصين﴾</span>، فأخبر أنّه صرف عنه السوء والفحشاء، وهذا يدل على أنه لم يصدر منه سوء ولا فحشاء».</p><p>و<span class="comment-type-4">بنحوه</span> قال <u>ابنُ القيم</u> (٢/٦٣).</p><p>و<span class="comment-type-2">انتقد</span> <u>ابنُ تيمية</u> <span class="mustanad">مستندًا إلى عدم وروده في السنة</span> ما ورد في آثار السلف أنّ يوسف ﵇ همَّ بامرأة العزيز همَّ مواقعةٍ وعزم، فقال: «وأما ما يُنقَل مِن أنّه حلَّ سراويله، وجلس مجلس الرجل من المرأة، وأنّه رأى صورة يعقوب عاضًّا على يده، وأمثال ذلك، فكلُّه مما لم يخبر الله به ولا رسوله، وما لم يكن كذلك فإنما هو مأخوذ عن اليهود الذين هم من أعظم الناس كذبًا على الأنبياء وقدحًا فيهم، وكل مَن نقله من المسلمين فعنهم نقله، لم ينقل من ذلك أحد عن نبينا ﷺ حرفًا واحدًا».</p><p>وزاد <u>ابنُ جرير</u> و<u>ابنُ عطية</u> في معنى همِّ يوسف <b>عدة أقوال</b>، <b>أحدها</b>: أنّ يوسف همَّ بضربها. <b>الثاني</b>: أنّ المعنى: همَّ بها لولا أن رأى برهان ربه، أي: فلم يهم بها. <b>الثالث</b>: أن همَّ يوسف كان بالخطرات التي لا يقدر على التحفظ منها بشر.</p><p>وقد <span class="comment-type-2">انتقد</span> <u>ابنُ جرير</u> (١٣/٨٦) <span class="mustanad">مستندًا إلى اللغةِ، وإجماعِ أهل التأويل</span> القولين الأولين، فقال: «ويفسد هذين القولين أنّ العرب لا تُقَدِّم جواب «لولا» قبلها، لا تقول: لقد قمت لولا زيد، وهي تريد: لولا زيد لقد قمت، هذا مع خلافهما جميع أهل العلم بتأويل القرآن الذين عنهم يؤخذ تأويله».</p><p>و<span class="comment-type-4">بنحوه</span> قال <u>ابنُ كثير</u> (٨/٣٠).</div></p><p><h3><span class="qpc-hafs">﴿وَلَقَدۡ هَمَّتۡ بِهِۦۖ وَهَمَّ بِهَا﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٣٧٠٦٤<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، قال: عَثَر يوسف ﵇ ثلاثَ عَثَراتٍ: حين همَّ بها فسُجِن، وحين قال: <span class="qpc-hafs">﴿اذكُرنى عند ربك﴾</span>، فلبث في السجن بضع سنين، فأنساه الشيطان ذكر ربه، وحين قال: <span class="qpc-hafs">﴿إنكم لسارقون﴾</span>، قالوا: <span class="qpc-hafs">﴿إن يسرق فقد سرق أخ له من قبل﴾</span>{19}. (٨/٢٣١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٠٦٥<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق ابن أبي مليكة- قال: كان يُولَد لإخوته اثنا عشر ذَكَرًا، ويولد له أحد عشر ولدًا مِن أجل الشهوة التي خرجت{20}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٠٦٦<span class="dash">-</span></span> قال <span class="name-2">الحسن البصري</span>: إنّ الله تعالى لم يذكر ذنوبَ الأنبياء ﵈ في القرآن لِيُعَيِّرَهم، ولكن ذكرها لِيُبَيِّن موضع النعمة عليهم، ولِئَلّا يَيْئَس أحدٌ مِن رحمته{21}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٠٦٧<span class="dash">-</span></span> عن <span class="name-3">علي بن بذيمة</span> -من طريق سفيان- قال: كان يُولَد لِكُلِّ رجل منهم اثنا عشر اثنا عشر، إلا يوسف ﵇ وُلِد له أحد عشر؛ مِن أجل ما خرج من شهوته{22}. (٨/٢٢٧)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿لَوۡلَاۤ أَن رَّءَا بُرۡهَـٰنَ رَبِّهِۦۚ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٧٠٦٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق سعيد بن جبير- في قوله: <span class="qpc-hafs">﴿لولا أن رَّءا برهان ربه﴾</span>، قال: مُثِّل له يعقوب، فضَرَب بيده على صدره، فخَرَجَتْ شهوتُه مِن أنامله{23}<span class=comment-ref>٣٣٤٤</span>. (٨/٢٢٤)</p></p><p></div></p><p><div><span class=comment-ref>٣٣٤٤</span> ذكر <u>ابنُ عطية</u> (٥/٦٩) نحو قول ابن عباس، و<span class="comment-type-2">انتقده</span>، فقال: «وقيل: إنّ جبريل ركضه، فخرجت شهوته على أنامله. وهذا ضعيف».</div></p><p><div></p><p><p><span class="item-no">٣٧٠٦٩<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق أبي رَوْق، عن الضَّحّاك- في قوله: <span class="qpc-hafs">﴿لولا أن رءا برهان ربه﴾</span>، قال: رأى صورةَ أبيه يعقوب في وسط البيت، عاضًّا على إبهامه، فأَدْبَر هاربًا، قال: وحقِّك، يا أبه، لا أعودُ أبدًا{24}. (٨/٢٢٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٠٧٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق ابن أبي مليكة- قال: نُودِي: يا يوسف، أتَزْنِي فتكون كالطير وقَع رِيشُه فذهب يطيرُ فلا ريش له؟!{25}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٠٧١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق مجاهد- في قوله ﷿: <span class="qpc-hafs">﴿لولا أن رأى برهان ربه﴾</span>، قال: قعد منها مقعد الرجل مِن امرأته، إذا بِكَفٍّ قد بدت بينهما، ليس فيها عَضُدٌ ولا مِعْصَم، مكتوب فيها: <span class="qpc-hafs">﴿وإن عليكم لحافظين * كراما كاتبين * يعلمون ما تفعلون﴾</span> [الانفطار:١٠-١٢]، فقام هاربًا، وقامت، فلمّا ذهب عنهما الرُّعبُ عادَتْ وعاد، فلمّا قعد منها مقعد الرجل مِن امرأته إذا بكَفٍّ قد بدت فيما بينهما ليس فيها عَضُدٌ ولا مِعْصَم، مكتوب فيها: <span class="qpc-hafs">﴿ولا تقربوا الزنى إنه كان فاحشة وساء سبيلا﴾</span> [الإسراء:٣٢]، فقام هارِبًا، وقامت، فلمّا ذَهَب عنهما الرُّعب عادَت وعاد، فلمّا قعد منها مقعد الرجل مِن امرأته إذا بِكَفٍّ قد بَدَتْ فيما بينهما، ليس فيها عَضُدٌ ولا مِعْصَم، مكتوب فيها: <span class="qpc-hafs">﴿واتقوا يوما ترجعون فيه إلى الله﴾</span> [البقرة:٢٨١] الآية، فقام هارِبًا، وقامت، فلمّا ذهب عنهما الروع عاد وعادت، فلما قعد منها مقعد الرجل من امرأته قال الله تعالى لجبريل: أدْرِكْ عبدي قبل أن يُصِيب الخطيئةَ. فانحطَّ جبريلُ عاضًّا على إصبعيه، وهو يقول: يا يوسف، أتعمل عمل السفهاء وأنت مكتوبٌ عند الله تعالى في الأنبياء؟!{26}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٠٧٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطية العوفي- في قوله: <span class="qpc-hafs">﴿لولا أن رءا برهان ربه﴾</span>، قال: آيات ربه؛ رأى تِمْثال المَلِك{27}. (٨/٢٢٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٠٧٣<span class="dash">-</span></span> عن الأوزاعيِّ، قال: كان <span class="name-1">عبد الله بن عباس</span> يقول في قوله: <span class="qpc-hafs">﴿لولا أن رءا برهان ربه﴾</span>، قال: رأى آيةً مِن كتاب الله نَهَتْه، مُثِّلَتْ له في جدار الحائط{24}. (٨/٢٢٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٠٧٤<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٠٧٥<span class="dash">-</span></span> و<span class="name-2">عكرمة مولى ابن عباس</span> -من طريق علي بن بَذِيمة- في قوله: <span class="qpc-hafs">﴿لولا أن رءا برهان ربه﴾</span>، قالا: حَلَّ السَّراويل، وجَلَسَ منها مجلس الخاتِن، فرأى صورةً فيها وجهُ يعقوبَ عاضًّا على أصابعه، فدَفَع صدرَه، فخرجت الشهوة مِن أنامله، فكلُّ ولد يعقوب قد وُلِد له اثنا عشر، إلا يوسف؛ فإنّه نُقِص بتلك الشهوة ولدًا، ولم يُولَد له غير أحد عشر{29}. (٨/٢٢٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٠٧٦<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span> -من طريق أبي حصين- <span class="qpc-hafs">﴿لولا أن رأى برهان ربه﴾</span>، قال: رأى جبريلَ في صورة أبيه يعقوب، فخرجت شهوتُه مِن أنامله{30}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٠٧٧<span class="dash">-</span></span> عن <span class="name-2">علي بن الحسين</span>، قال: كان في البيت صنمٌ، فقامت المرأةُ وسَتَرَتْه بثوب، فقال لها يوسف: لِمَ فعلتِ هذا؟ فقالت: اسْتَحْيَيْتُ منه أن يراني على المعصية. فقال يوسف: أتَسْتَحِينَ مِمّا لا يسمع ولا يُبْصِر ولا يَفْقَه؟ فأنا أحَقُّ أن أستحي مِن ربِّي، وهرب{31}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٠٧٨<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نَجِيح- قال: رأى صورةَ يعقوب في الجدار{32}. (٨/٢٢٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٠٧٩<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طُرُقٍ- في قوله: <span class="qpc-hafs">﴿لولا أن رءا برهان ربه﴾</span>، قال: تَمَثَّل له يعقوب، فضرب في صدر يوسف، فطارت شهوتُه مِن أطراف أنامله، فوُلِد لكل ولدِ يعقوب اثنا عشر ذكرًا، غير يوسف لم يولَد له إلا غلامان{33}. (٨/٢٢٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٠٨٠<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق الأعمش- قال: لَمّا جلس منها يوسفُ ذلك المجلس، وحَلَّ السراويلَ حتى بلغت الثَّفَن{34}؛ تَمَثَّل له يعقوبُ، فضرب صدرَه بيده، فقال: يا يوسف! فخرجت شهوتُه مِن أنامله{35}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٠٨١<span class="dash">-</span></span> عن <span class="name-2">الضحاك بن مُزاحِم</span> -من طريق عبيد بن سليمان- قال: يزعمون: أنّه مُثِّل له يعقوب ﵇، فاسْتَحْيا منه{36}. (٨/٢٢٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٠٨٢<span class="dash">-</span></span> عن <span class="name-2">حميد بن عبد الرحمن</span> -من طريق الزُّهْرِي- أنّه أخبره: أنّ البرهان الذي رأى يوسفُ: يعقوب{37}. (٨/٢٢٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٠٨٣<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق يونس- في قوله: <span class="qpc-hafs">﴿لولا أن رءا برهان ربه﴾</span>، قال: رأى يعقوبُ عاضًّا على إصبعِه، يقول: يوسف، يوسف{38}. (٨/٢٢٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٠٨٤<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق قُرَّة بن خالد السَّدُوسِيِّ- قال: زعَموا: أنّ سَقْفَ البيتِ انفَرَجَ، فرأى يعقوبَ عاضًّا على إصبعيه{39}. (٨/٢٢٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٠٨٥<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span>، في قوله: <span class="qpc-hafs">﴿ولقد همت به وهم بها لولا أن رءا برهان ربه﴾</span>، قال: لَمّا همَّ قيل له: يوسفُ، ارفع رأسَك. فرفع رأسَه، فإذا هو بصورة في سقف البيت تقول: يا يوسف، أنت مكتوب في الأنبياء. فعصمه الله ﷿{40}. (٨/٢٢٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٠٨٦<span class="dash">-</span></span> عن <span class="name-2">محمد بن سيرين</span> -من طريق محمد الخراساني- في قوله: <span class="qpc-hafs">﴿لولا أن رءا برهان ربه﴾</span>، قال: مُثِّل له يعقوبُ ﵇ عاضًّا على إصبعيه، يقول: يوسف بن يعقوب بن إسحاق بن إبراهيم خليل الرحمن، اسمك في الأنبياء وتعمل عمل السفهاء؟!{41}. (٨/٢٢٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٠٨٧<span class="dash">-</span></span> عن <span class="name-2">أبي صالح باذام</span> -من طريق إسماعيل بن أبي سالم- قال: رأى صورةَ يعقوب في سقف البيت يقول: يوسف! يوسف!{42}. (٨/٢٢٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٠٨٨<span class="dash">-</span></span> عن <span class="name-2">وهب بن مُنَبِّه</span>، قال: لَمّا خلا يوسفُ وامرأةُ العزيز خرجت كَفٌّ بلا جَسَدٍ بينهما، مكتوب عليه بالعِبْرانِيَّة: <span class="qpc-hafs">﴿أفمن هو قائم على كل نفس بما كسبت﴾</span> [الرعد:٣٣]. ثم انصَرَفَت الكَفُّ، وقاما مقامهما، ثم رجعت الكَفُّ بينهما، مكتوب عليها بالعبرانية: <span class="qpc-hafs">﴿وإن عليكم لحافظين*كرامًا كاتبين*يعلمون ما تفعلون﴾</span> [الانفطار:١٠-١٢]. ثم انصرفت الكَفُّ، وقاما مقامهما، فعادت الكَفُّ الثالثة، مكتوب عليها: <span class="qpc-hafs">﴿ولا تقربوا الزنى إنه كان فاحشة وساء سبيلا﴾</span> [الإسراء:٣٢]. وانصرفت الكفُّ، وقاما مقامهما، فعادت الكفُّ الرابعةَ، مكتوبٌ عليها بالعِبْرانِيَّة: <span class="qpc-hafs">﴿واتقوا يومًا ترجعون فيه إلى الله ثم توفي كل نفس ما كسبت وهم لا يظلمون﴾</span> [البقرة:٢٨١]. فولّى يوسفُ ﵇ هارِبًا{43}. (٨/٢٢٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٠٨٩<span class="dash">-</span></span> عن <span class="name-2">القاسم بن أبي بَزَّةَ</span> -من طريق شِبْل- قال: نُودِي: يا ابن يعقوب، لا تَكُونَنَّ كالطير له ريش فإذا زَنى قَعَد ليس له رِيش. فلم يعرِضْ للنداء، وقعد، فرفع رأسَه، فرأى وجه يعقوب عاضًّا على إصبعه، فقام مرعوبًا استحياءً مِن أبيه{22}. (٨/٢٢٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٠٩٠<span class="dash">-</span></span> عن <span class="name-2">عبد الله بن أبي مليكة</span> -من طريق عمرو الحضرمي- قال: بلغني: أنّ يوسف لَمّا جلس بين رِجْلَيِ المرأة فهو يَحُلَّ هِمْيانه؛ نُودِي: يا يوسف بن يعقوب، لا تزنِ، فإنّ الطير إذا زنى تناثر ريشُه. فأَعْرَض، ثُمَّ نُودِي، فأعرض، فتَمَثَّل له يعقوبُ عاضًّا على أصبعه، فقام{45}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٠٩١<span class="dash">-</span></span> عن <span class="name-2">محمد بن كعب القرظي</span> -من طريق أبي مودود- قال: رأى في البيتِ في ناحية الحائط مكتوبًا: <span class="qpc-hafs">﴿ولا تقربوا الزنى إنه كان فاحشةً وساء سبيلًا﴾</span> [الإسراء:٣٢]{46}. (٨/٢٢٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٠٩٢<span class="dash">-</span></span> عن <span class="name-2">محمد بن كعب القرظيِّ</span> -من طريق أبي صخر- قال: البُرْهان الذي رأى يوسفُ ﵇ ثلاثُ آيات مِن كتاب الله: <span class="qpc-hafs">﴿وإن عليكم لحافظون*كراما كاتبين*يعلمون ما تفعلون﴾</span> [الانفطار:١٠-١٢]، وقول الله: <span class="qpc-hafs">﴿وما تكون في شأن وما تتلوا منه من قرآن ولا تعملون من عمل إلا كنا عليكم شهودا إذ تفيضون فيه﴾</span> [يونس:٦١]، وقول الله: <span class="qpc-hafs">﴿أفمن هو قائم على كل نفس بما كسبت﴾</span> [الرعد:٣٣]{47}. (٨/٢٢٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٠٩٣<span class="dash">-</span></span> قال نافع: سمعتُ <span class="name-2">أبا هلال</span> يقول مِثْلَ قولِ القُرَظِيِّ، وزاد آيةً رابعة: <span class="qpc-hafs">﴿ولا تقربوا الزنا﴾</span>{27}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٠٩٤<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق هَمّام بن يحيى- في الآية، قال: رأى آيةً مِن آيات ربه، حَجَزَه اللهُ بها عن معصيته. ذُكِر لنا: أنّه مُثِّل له يعقوبُ عاضًّا على إصبعيه وهو يقول له: يا يوسف، أتَهُمُّ بعمل السفهاءِ وأنت مكتوبٌ في الأنبياء؟! فذلك البرهان، فانتزع اللهُ كُلَّ شهوةٍ كانت في مفاصِلِه{49}. (٨/٢٢٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٠٩٥<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- قال: فلم تَزَلْ به حتى أطْمَعَها، فهمَّت به وهمَّ بها، فدَخَلا البيتَ، <span class="qpc-hafs">﴿وغلقت الأبواب﴾</span>، فذهب لِيَحُلَّ سراويلَه، فإذا هو بصورة يعقوب قائمًا في البيت قد عضَّ على أصبُعه، يقول: يا يوسف، لا تُواقِعها، فإنّما مَثَلُك مَثَلُ الطيرِ في جَوِّ السماء لا يُطاق، ومَثَلُك إذا وقعت عليها مَثَلُه إذا مات فوقع على الأرض؛ لا يستطيع أن يدفع عن نفسه، ومثلك ما لم تُواقِعها مثلُ الثَّوْر الصَّعْب الذي لم يُعمَل عليه، ومَثَلُك إذا واقعتها مَثَلُه إذا مات فدخل النَّمْلُ في أصل قَرْنَيْه، لا يستطيع أن يدفع عن نفسه. فربط سراويلَه، وذهب ليخرج، فأَدْرَكَتْه، فأخذت بمُؤَخَّرِ قميصه مِن خلفه، فخرقته حتى أخرجته منه، وسقط، وطرحه يوسف، واشْتَدَّ نحوَ الباب{50}. (٨/١٨٩-١٩٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٠٩٦<span class="dash">-</span></span> عن <span class="name-3">شِمْرِ بن عطية</span> -من طريق حفص بن حميد- قال: نَظَرَ يوسفُ إلى صورة يعقوب عاضًّا على إصبعه يقول: يا يوسف. فذاك حيثُ كفَّ وقام{51}. (٨/٢٢٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٠٩٧<span class="dash">-</span></span> عن <span class="name-3">جعفر بن محمد [الصادق]</span> -من طريق شيخ يكنى: أبا عبد الله- قال: لَمّا دخل يوسف ﵇ معها البيت، وفي البيت صنمٌ مِن ذهب؛ قالت: كما أنت حتّى أُغَطِّي الصَّنَم؛ فإنِّي أسْتَحِي منه. فقال يوسف: هذه تستحي مِن الصنم! أنا أحَقُّ أن أستحي مِن الله. فكفَّ عنها، وتركها{52}. (٨/٢٢٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٠٩٨<span class="dash">-</span></span> قال <span class="name-3">جعفر بن محمد الصادق</span>: البرهان: النُّبُوَّة التي أوْدَعَها اللهُ في صدره حالَتْ بينه وبين ما يُسْخِطُ اللهَ ﷿{31}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٠٩٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿لولا أن رأى برهان ربه﴾</span>، يعني: آية ربه؛ لَواقَعَها، والبرهان: مُثِّل له يعقوب عاضٌّ على إصبعه، فلمّا رأى ذلك ولّى دُبُرًا، واتَّبَعَتْه المرأةُ{54}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧١٠٠<span class="dash">-</span></span> عن <span class="name-3">محمد بن إسحاق</span> -من طريق سلمة- قال: كان بعضُ أهل العلم -فيما بلغني- يقول: البُرهان الذي رأى يوسفُ فصرف عنه السوء والفحشاء: يعقوبُ عاضًّا على أصبعه، فلمّا رآه انكشف هارِبًا{27}<span class=comment-ref>٣٣٤٥</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٣٣٤٥</span> اختُلِف في قوله: <span class="qpc-hafs">﴿لولا أن رأى برهان ربه﴾</span> على أقوال: <b>الأول</b>: نُودِي بالنَّهْيِ عن مُواقَعَةِ الخطيئة. <b>الثاني</b>: أنّه صورة يعقوب ﵉ يَتَوَعَّده. <b>الثالث</b>: أنّه رأى ما أوعد الله ﷿ على الزِّنا أهلَه. <b>الرابع</b>: رأى تمثال الملِك.</p><p>وقد رجّح <u>ابنُ جرير</u> (١٣/٩٩) جوازَ هذه الأقوال وعدم القطع بأحدها <span class="mustanad">لعدم دليل التعيين الذي يشهد لها</span>، فقال: «وأولى الأقوال في ذلك بالصواب أن يُقال: إن الله -جل ثناؤُه- أخبر عن هَمِّ يوسفَ وامرأةِ العزيز كلّ واحد منهما بصاحبه، لولا أن رأى يوسف برهان ربه، وذلك آيةٌ مِن آيات الله زَجَرَتْه عن ركوب ما هَمَّ به يوسف مِن الفاحشة، وجائز أن تكون تلك الآية صورةَ يعقوب، وجائزٌ أن تكون صورةَ الملك، وجائز أن يكون الوعيد في الآيات التي ذكرها الله في القرآن على الزنا، ولا حجة للعُذْر قاطعةً بأيِّ ذلك مِن أيٍّ. والصوابُ أن يقال في ذلك ما قاله الله -تبارك وتعالى-، والإيمان به، وترك ما عدا ذلك إلى عالمه».</p><p>وذكر <u>ابنُ عطية</u> (٥/٦٩) الخلاف، ثم قال <span class="comment-type-4">مُعَلِّقًا</span>: «والبرهان <span class="mustanad">في كلام العرب</span>: الشيءُ الذي يُعْطِي القطعَ واليقين، كان مِمّا يعلم ضرورة أم بخبر قطعيٍّ أو بقياس نظري. فهذه التي رُوِيَت فيما رآه يوسف براهين».</div></p><p><h3><span class="qpc-hafs">﴿كَذَ ٰ⁠لِكَ لِنَصۡرِفَ عَنۡهُ ٱلسُّوۤءَ وَٱلۡفَحۡشَاۤءَۚ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٧١٠١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿كذلك﴾</span> يعني: هكذا <span class="qpc-hafs">﴿لنصرف عنه السوء﴾</span> يعني: الإثم، <span class="qpc-hafs">﴿والفحشاء﴾</span> يعني: المعاصي{54}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧١٠٢<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن يزيد بن جابر</span> -من طريق عبد الملك بن بَزِيع- في قوله: <span class="qpc-hafs">﴿كذلك لنصرف عنه السوء والفحشاء﴾</span>، قال: الزِّنا، والثَّناء القبيح{57}. (٨/٢٣٠)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿إِنَّهُۥ مِنۡ عِبَادِنَا ٱلۡمُخۡلَصِینَ ۝٢٤﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٧١٠٣<span class="dash">-</span></span> عن <span class="name-2">الضَّحّاك بن مُزاحم</span>، <span class="qpc-hafs">﴿إنه من عبادنا المخلصين﴾</span>، قال: الذين لا يعبدون مع الله شيئًا{19}. (٨/٢٣٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧١٠٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿إنه من عبادنا المخلصين﴾</span> بالنُّبُوَّة والرِّسالة. نظيرها: <span class="qpc-hafs">﴿إنا أخلصناهم بخالصة ذكرى الدار﴾</span> [ص:٤٦]، يعني: بالنُّبُوَّة{54}. (ز)</p></p><p></div></p></div>",footnotes:1:التِّكَّة: رِباط السراويل. اللسان (تكك).|2:أخرجه أبو نعيم في الحلية ٣/١٨١.|3:الهِمْيان: موضع شدِّ الإزار. اللسان (همن).|4:أخرجه ابن جرير ١٣/٨٣، ٨٥، ٨٧، وأبو نعيم في الحلية ١/٣٢٣، ٣٢٤. وعزاه السيوطي إلى أبي الشيخ.|5:أخرجه عبد الرزاق ١/٣٢١، وسعيد بن منصور (١١١٦- تفسير)، وابن جرير ١٣/٨٧-٨٩، وابن أبي حاتم ٧/٣١٢٣، ٣١٢٦، ٣١٢٧، والحاكم ٢/٣٤٦. وعزاه السيوطي إلى الفريابي، وابن المنذر، وأبي الشيخ.|6:تفسير الثعلبي ٥/٢٠٩.|7:تفسير الثعلبي ٥/٢٠٩.|8:تفسير الثعلبي ٥/٢١٠.|9:الثنة: ما بين السُّرة والعانة من أسفل البطن. النهاية (ثنن).|10:أخرجه عبد الرزاق ١/٣٢١، وابن جرير ١٣/٨٣-٨٥، ٩٣، وابن أبي حاتم ٧/٢١٢٣. وعزاه السيوطي إلى ابن المنذر، وأبي الشيخ.|11:تفسير الثعلبي ٥/٢١٠، وتفسير البغوي ٤/٢٢٨.|12:تفسير البغوي ٤/٢٢٨.|13:أخرجه ابن جرير ١٣/٨٤.|14:أخرجه ابن جرير ١٣/٨٣.|15:أخرجه ابن جرير ١٣/٨٠-٨١، وابن أبي حاتم ٧/٢١٢٣.|16:تفسير مقاتل بن سليمان ٢/٣٢٧-٣٢٩.|17:كَلِفَ بالشيء: لهِج به، وكَلِف به أشد الكَلَف: أحَبَّه. اللسان (كلف).|18:أخرجه ابن جرير ١٣/٨١، وابن أبي حاتم ٧/٢١٢٣ واللفظ له.|19:عزاه السيوطي إلى أبي الشيخ.|20:تفسير سفيان الثوري ص١٤٠.|21:تفسير البغوي ٤/٢٣١.|22:أخرجه ابن جرير ١٣/٩٤.|23:أخرجه ابن جرير ١٣/٩٠-٩١، وابن أبي حاتم ٧/٣١٢٣، والحاكم ٢/٣٤٦. وعزاه السيوطي إلى أبي الشيخ.|24:أخرجه ابن أبي حاتم ٧/٢١٢٤.|25:تفسير الثعلبي ٥/٢١٢.|26:أخرجه الواحدي في الوسيط ١/٦٠٨-٦٠٩. وينظر: تفسير الثعلبي ٥/٢١٢.|27:أخرجه ابن جرير ١٣/٩٩.|28:أخرجه ابن أبي حاتم ٧/٢١٢٤.|29:أخرجه ابن جرير ١٣/٨٥-٩٢، وابن أبي حاتم ٧/٢١٢٥. وعزاه السيوطي إلى أبي الشيخ.|30:أخرجه البيهقي في الزهد الكبير ص١٦١ (٣٦٣)، وهو في ابن جرير ١٣/٨٥-٩٢ دون ذكر جبريل ﵇.|31:تفسير الثعلبي ٥/٢١٣، وتفسير البغوي ٤/٢٣٣.|32:أخرجه عبد الرزاق ١/٣٢١، وابن جرير ١٣/٩٣. وعزاه السيوطي إلى ابن المنذر.|33:أخرجه ابن جرير ١٣/٩٢-٩٤، وابن أبي حاتم ٧/٢١٢٥.|34:الثَّفَينة: هو مَوْصِل الفَخِذ بالسّاق من باطنٍ. اللسان (ثفن).|35:أخرجه سعيد بن منصور في سننه (ت: سعد آل حميد) ٥/٣٩٠ (١١٢١). وذكر يحيى بن سلام -كما في تفسير ابن أبي زمنين ٢/٣٢١- نحوه.|36:أخرجه ابن جرير ١٣/٩٧.|37:أخرجه ابن جرير ١٣/٩٢.|38:أخرجه ابن جرير ١٣/٩١-٩٢، وابن أبي حاتم ٧/٢١٢٤. وعزاه السيوطي إلى أبي الشيخ.|39:أخرجه ابن جرير ١٣/٩١. وعزاه السيوطي إلى ابن أبي شيبة، وابن المنذر، وأبي الشيخ.|40:عزاه السيوطي إلى عبد الله بن أحمد في زوائد الزهد.|41:أخرجه ابن جرير ١٣/٩٥، وابن أبي حاتم ٧/٢١٢٤. وعزاه السيوطي إلى أبي الشيخ.|42:أخرجه ابن جرير ١٣/٩٦. وعزاه السيوطي إلى أبي عبيد، وابن المنذر.|43:عزاه السيوطي إلى ابن المنذر، وأبي الشيخ.|44:أخرجه ابن جرير ١٣/٩٤.|45:أخرجه ابن جرير ١٣/٨٨.|46:أخرجه ابن جرير ١٣/٩٨. وعزاه السيوطي إلى ابن أبي شيبة، وابن المنذر، وأبي الشيخ.|47:أخرجه ابن وهب في الجامع - تفسير القرآن ٢/١٤٥ (٢٩٥)، وابن جرير ١٣/٩٨، وابن أبي حاتم ٧/٢١٢٥-٢١٢٦.|48:أخرجه ابن جرير ١٣/٩٩.|49:أخرجه ابن جرير ١٣/٨٩، ٩٠، ٩٥، وابن أبي حاتم ٧/٢١٢٤. وعزاه السيوطي إلى أبي الشيخ.|50:أخرجه ابن جرير ١٣/٨٠-٨١، وابن أبي حاتم ٧/٢١٢٤.|51:أخرجه ابن جرير ١٣/٩٦.|52:أخرجه أبو نعيم في الحلية ٣/١٩٨. وعزاه السيوطي إلى أبي الشيخ.|53:تفسير الثعلبي ٥/٢١٣، وتفسير البغوي ٤/٢٣٣.|54:تفسير مقاتل بن سليمان ٢/٣٢٩-٣٣٠.|55:أخرجه ابن جرير ١٣/٩٩.|56:تفسير مقاتل بن سليمان ٢/٣٢٩-٣٣٠.|57:أخرجه ابن أبي حاتم ٧/٢١٢٦. وعزاه السيوطي إلى أبي الشيخ.|58:عزاه السيوطي إلى أبي الشيخ.|59:تفسير مقاتل بن سليمان ٢/٣٢٩-٣٣٠.
  12,25,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَٱسۡتَبَقَا ٱلۡبَابَ وَقَدَّتۡ قَمِیصَهُۥ مِن دُبُرࣲ وَأَلۡفَیَا سَیِّدَهَا لَدَا ٱلۡبَابِۚ قَالَتۡ مَا جَزَاۤءُ مَنۡ أَرَادَ بِأَهۡلِكَ سُوۤءًا إِلَّاۤ أَن یُسۡجَنَ أَوۡ عَذَابٌ أَلِیمࣱ ۝٢٥﴾</span> - قراءات</h3></p><p><div></p><p><p><span class="item-no">٣٧١٠٥<span class="dash">-</span></span> عن يحيى بن زكريا بن أبي زائدة، قال: في قراءة <span class="name-1">عبد الله [بن مسعود]</span>: (ووَجَدا سَيِّدَها){1}. (٨/٢٣٠)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَٱسۡتَبَقَا ٱلۡبَابَ وَقَدَّتۡ قَمِیصَهُۥ مِن دُبُرࣲ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٧١٠٦<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق مَعْمَر- في قوله: <span class="qpc-hafs">﴿واستبقا الباب﴾</span>، قال: اسْتَبَقَ هو والمرأةُ البابَ{2}. (٨/٢٣٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧١٠٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿واستبقا الباب﴾</span>، ويوسفُ أمامَها هارِبٌ منها، وهي وراءَه تَتْبَعُه لِتَحْبِسَه على نفسها، فأدْرَكَتْه قبل أن ينتهي إلى الباب، <span class="qpc-hafs">﴿وقدت قميصه من دبر﴾</span> يقول: فمَزَّقت قميصَه مِن ورائه حتى سقط القميصُ عن يوسف{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧١٠٨<span class="dash">-</span></span> عن <span class="name-3">محمد بن إسحاق</span> -من طريق سلمة- قال: لَمّا رأى برهان ربِّه انكشف عنها هارِبًا، واتبعته، فأخذت قميصَه مِن دُبُرٍ، فشَقَّته عليه{4}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَأَلۡفَیَا سَیِّدَهَا﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٧١٠٩<span class="dash">-</span></span> عن <span class="name-1">زيد بن ثابت</span> -من طريق الحسن- قال: السَّيِّد: الزَّوْج{4}. (٨/٢٣٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧١١٠<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق الثوري، عن رجل- في قوله: <span class="qpc-hafs">﴿وألفيا سيدها﴾</span>، قال: زوجها{6}. (٨/٢٣٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧١١١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وألفيا﴾</span> يقول: وجدا، كقوله: <span class="qpc-hafs">﴿ألفينا عليه آباءنا﴾</span> [البقرة:١٧٠]، يعني: وجَدا سيِّدها، يعني: زوجها{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧١١٢<span class="dash">-</span></span> عن <span class="name-3">محمد بن إسحاق</span> -من طريق سلمة- <span class="qpc-hafs">﴿وألفيا سيدها﴾</span>: إطفير{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧١١٣<span class="dash">-</span></span> قال <span class="name-3">سفيان الثوري</span>، في قوله: <span class="qpc-hafs">﴿وألفيا سيدها لدى الباب﴾</span>: وجد سيِّدها لدى الباب{9}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿لَدَا ٱلۡبَابِۚ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٧١١٤<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق عيسى- قوله: <span class="qpc-hafs">﴿لدى الباب﴾</span>، قال: عند الباب{10}. (٨/٢٣٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧١١٥<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span>، مثل ذلك{11}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧١١٦<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- قوله: <span class="qpc-hafs">﴿وألفيا سيدها لدا الباب﴾</span>، أي: عِند الباب{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧١١٧<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- قوله: <span class="qpc-hafs">﴿وألفيا سيدها لدا الباب﴾</span> قال: جالِسًا عند الباب، هو وابنُ عَمِّ المرأة، فلَمّا رَأَتْه قالت: <span class="qpc-hafs">﴿ما جزاء من أراد بأهلك سوءًا إلا أن يسجن أو عذاب أليم﴾</span>{13}. (٨/١٩٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧١١٨<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿لدى الباب﴾</span>، يعني: عند الباب، ومعه ابنُ عمِّها يمليخا بن زليخا{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧١١٩<span class="dash">-</span></span> عن <span class="name-3">محمد بن إسحاق</span> -من طريق سلمة- <span class="qpc-hafs">﴿وألفيا سيدها لدى الباب﴾</span>: إطفير قائمًا على باب البيت{8}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿قَالَتۡ مَا جَزَاۤءُ مَنۡ أَرَادَ بِأَهۡلِكَ سُوۤءًا إِلَّاۤ أَن یُسۡجَنَ أَوۡ عَذَابٌ أَلِیمࣱ ۝٢٥﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٧١٢٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، في قوله: <span class="qpc-hafs">﴿إلا أن يُسجن أو عذاب أليم﴾</span>، قال: القَيْد{16}. (٨/٢٣١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧١٢١<span class="dash">-</span></span> قال <span class="name-1">عبد الله بن عباس</span>، في قوله: <span class="qpc-hafs">﴿إلا أن يسجن﴾</span>: يُحْبَس، <span class="qpc-hafs">﴿أو عذاب أليم﴾</span> يعني: الضَّرب بالسِّياط{17}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧١٢٢<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السدي</span> -من طريق أسباط- قال: فلمّا رَأَتْه قالت: <span class="qpc-hafs">﴿ما جزاء من أراد بأهلك سوءًا إلا أن يسجن أو عذاب أليم﴾</span>، إنّه راودني عن نفسي، فدفعتُه عَنِّي، فشَقَقْتُ قميصَه{13}. (٨/١٩٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧١٢٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿قالت ما جزاء من أراد بأهلك سوءا﴾</span> يعني: الزِّنا <span class="qpc-hafs">﴿إلا أن يسجن﴾</span> حَبْسًا في نَصَب، <span class="qpc-hafs">﴿أو عذاب أليم﴾</span> يعني: ضَرْبًا وجِيعًا{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧١٢٤<span class="dash">-</span></span> عن <span class="name-3">محمد بن إسحاق</span> -من طريق سلمة-: فقالتْ وهابَتْهُ: <span class="qpc-hafs">﴿ما جزاء من أراد بأهلك سوءا إلا أن يسجن أو عذاب أليم﴾</span>. ولطخته مكانَها بالسَّيِّئَة فَرَقًا مِن أن يَتَّهِمَها صاحبُها على القبيح، فقال هو وصَدَقَه الحديثَ: <span class="qpc-hafs">﴿هي راودتني عن نفسي﴾</span>{8}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه عبد الرزاق ١/٣٢٢، وابن جرير ١٣/١٠١-١٠٢، وابن أبي حاتم ٧/٢١٢٦.</p><p>وهي قراءة شاذة. انظر: روح المعاني ١٢/٢١٨.|2:أخرجه عبد الرزاق ١/٣٢٢، وابن جرير ١٣/١٠١، وابن أبي حاتم ٧/٢١٢٦. وعزاه السيوطي إلى ابن المنذر، وأبي الشيخ.|3:تفسير مقاتل بن سليمان ٢/٣٣٠.|4:أخرجه ابن جرير ١٣/١٠٢.|5:أخرجه ابن جرير ١٣/١٠٢.|6:أخرجه ابن جرير ١٣/١٠٢. وعزاه السيوطي إلى ابن أبي حاتم، وأبي الشيخ.|7:تفسير مقاتل بن سليمان ٢/٣٣٠.|8:أخرجه ابن جرير ١٣/١٠٣.|9:تفسير سفيان الثوري ص١٤١.|10:أخرجه ابن أبي حاتم ٧/٢١٢٧، كما أخرجه ابن جرير ١٣/١٠٢ من طريق الثوري عن رجل.|11:علَّقه ابن أبي حاتم ٧/٢١٢٧.|12:أخرجه ابن جرير ١٣/١٠٢.|13:أخرجه ابن جرير ١٣/١٠٢-١٠٣، وابن أبي حاتم ٧/٢١٢٨.|14:تفسير مقاتل بن سليمان ٢/٣٣٠.|15:أخرجه ابن جرير ١٣/١٠٣.|16:عزاه السيوطي إلى أبي الشيخ.|17:تفسير الثعلبي ٥/٢١٤.|18:أخرجه ابن جرير ١٣/١٠٢-١٠٣، وابن أبي حاتم ٧/٢١٢٨.|19:تفسير مقاتل بن سليمان ٢/٣٣٠.|20:أخرجه ابن جرير ١٣/١٠٣.
  12,26,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿قَالَ هِیَ رَ ٰ⁠وَدَتۡنِی عَن نَّفۡسِیۚ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٧١٢٥<span class="dash">-</span></span> عن <span class="name-2">نوف الشامِيِّ</span> -من طريق أبي إسحاق- قال: ما كان يوسفُ ﵇ يريد أن يذكرَه، حتى قالت: <span class="qpc-hafs">﴿ما جزاء من أراد بأهلك سوءًا﴾</span>؟ فغَضِب يوسف ﵇، وقال: <span class="qpc-hafs">﴿هى راودتنى عن نفسى﴾</span>{1}. (٨/٢٣٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧١٢٦<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- قال: فلمّا رأته قالتْ: <span class="qpc-hafs">﴿ما جزاء من أراد بأهلك سوءًا إلا أن يسجن أو عذاب أليم﴾</span>؟ إنّه راودني عن نفسي، فدفعته عَنِّي، فشققتُ قميصَه. فقال يوسف: لا، بل هى راودتني عن نفسي، فأَبَيْتُ، وفررت منها، فأَدْرَكَتْنِي، فأَخَذَتْ بقميصي، فشَقَّتْهُ عَلَيَّ. فقال ابنُ عمها: في القميص تبيان الأمر؛ انظروا إن كان القميصُ قُدَّ مِن قبُل فصدقت وهو من الكاذبين، وإن كان قُدَّ مِن دُبُرٍ فكذبت وهو مِن الصادقين. فلما أُتِي بالقميص وجَده قد قُدَّ مِن دبر، فقال: <span class="qpc-hafs">﴿إنه من كيدكن إن كيدكن عظيم﴾</span>{2}. (٨/١٩٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧١٢٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿قال﴾</span> يوسف للزوج: <span class="qpc-hafs">﴿هي راودتني عن نفسي﴾</span>{3}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَشَهِدَ شَاهِدࣱ مِّنۡ أَهۡلِهَاۤ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٧١٢٨<span class="dash">-</span></span> عن ابن عباس، عن النبيِّ ﷺ، قال: «<b>تَكَلَّم أربعةٌ وهُم صغار: ابنُ ماشِطَة ابنةِ فرعون، وشاهِدُ يوسف، وصاحبُ جُرَيْج، وعيسى ابن مريم</b>»{4}. (٨/٢٣١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧١٢٩<span class="dash">-</span></span> عن <span class="name-1">أبي هريرة</span> -من طريق شهر بن حوشب- قال: عيسى، وصاحب يوسف، وصاحب جريج تَكَلَّموا في المَهْد{5}. (٨/٢٣٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧١٣٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق سعيد بن جبير- قال: تَكَلَّم أربعةٌ في المهد وهم صغار: ابن ماشطة بنت فرعون، وشاهد يوسف، وصاحب جريج، وعيسى ابن مريم ﵇{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧١٣١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطية العوفي- في قوله: <span class="qpc-hafs">﴿وشهد شاهد من أهلها﴾</span>، قال: صَبِيٌّ في المَهْد{7}. (٨/٢٣١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧١٣٢<span class="dash">-</span></span> وعن <span class="name-2">الحسن البصري</span>، نحو ذلك{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧١٣٣<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عكرمة- في قوله: <span class="qpc-hafs">﴿وشهد شاهد من أهلها﴾</span>، قال: كان رجلًا ذا لِحْيَةٍ{9}. (٨/٢٣٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧١٣٤<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق ابن أبي مُلَيْكة- في قوله: <span class="qpc-hafs">﴿وشهد شاهد من أهلها﴾</span>، قال: كان مِن خاصَّة الملك{10}. (٨/٢٣٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧١٣٥<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span> -من طريق أبي حصين- <span class="qpc-hafs">﴿وشهد شاهد من أهلها﴾</span>، قال: رجل{11}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧١٣٦<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span> -من طريق سالم- في قوله: <span class="qpc-hafs">﴿وشهد شاهد من أهلها﴾</span>، قال: كان صَبِيًّا في مَهْدِه{12}. (٨/٢٣٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧١٣٧<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span>، قال: تَكَلَّم في المهد أربعة: عيسى، وصاحب يوسف، وصاحب جريج، وابن ماشِطَة ابنة فرعون{13}. (١٠/٦٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧١٣٨<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق أبي يحيى- <span class="qpc-hafs">﴿وشهد شاهد﴾</span>، قال: حَكَم حاكِم{14}. (٨/٢٣١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧١٣٩<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق منصور- <span class="qpc-hafs">﴿وشهد شاهد من أهلها﴾</span>، قال: كان رجلًا{15}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧١٤٠<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ليث- في قوله: <span class="qpc-hafs">﴿وشهد شاهد من أهلها﴾</span>، قال: ليس بإنسِيٍّ ولا جانٍّ، هو خَلْقٌ مِن خَلْقِ الله. وفي لفظ قال: قميصُه مشقوق مِن دُبُر، فتلك الشهادة{16}<span class=comment-ref>٣٣٤٦</span>. (٨/٢٣٣)</p></p><p></div></p><p><div><span class=comment-ref>٣٣٤٦</span> <span class="comment-type-4">علّق</span> <u>ابنُ كثير</u> (٨/٣٤) على قول مجاهد، فقال: «وقال ليث بن أبي سليم، عن مجاهد: كان مِن أمر الله، ولم يكن إنسيًّا. وهذا قول غريب».</div></p><p><div></p><p><p><span class="item-no">٣٧١٤١<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نَجِيح- في قوله: <span class="qpc-hafs">﴿وشهد شاهد من أهلها﴾</span>، قال: يعني: قميصه، أي: القميص هو الشاهد، والشاهد إن كان مشقوقًا مِن دُبُرِه فتلك الشهادة{17}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧١٤٢<span class="dash">-</span></span> عن <span class="name-2">الضَّحّاك بن مُزاحِم</span> -من طريق جُوَيْبِر- <span class="qpc-hafs">﴿وشهد شاهد من أهلها﴾</span>، قال: صبيٌّ أنطَقَهُ اللهُ، كان في الدار{18}. (٨/٢٣١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧١٤٣<span class="dash">-</span></span> قال <span class="name-2">الضحاك بن مزاحم</span>: ما كان بصبيٍّ، ولكنَّه كان رجلًا حكيمًا ذا لحية، له رأيٌ ومقالٌ وآية{19}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧١٤٤<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span> -من طريق عمران بن حدير-: ما كان بصبي، ولكن كان رجلًا حكيمًا{20}. (٨/٢٣٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧١٤٥<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق هشيم، عن بعض أصحابه- في قوله: <span class="qpc-hafs">﴿وشهد شاهد من أهلها﴾</span>، قال: رجل له فَهْم وعِلْم{21}. (٨/٢٣٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧١٤٦<span class="dash">-</span></span> عن <span class="name-2">ابن أبي مليكة</span> -من طريق جابر- <span class="qpc-hafs">﴿وشهد شاهد من أهلها﴾</span>، قال: كان مِن خاصَّة المَلِك{22}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧١٤٧<span class="dash">-</span></span> عن <span class="name-2">هلال بن يساف</span> -من طريق حصين- <span class="qpc-hafs">﴿وشهد شاهد من أهلها﴾</span>، قال: صبِيٌّ في المَهْد{23}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧١٤٨<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿وشهد شاهد من أهلها﴾</span>، قال: ذُكِر لنا: أنّه رجل حكيم مِن أهلها، قال: القميصُ يَقْضِي بينهما؛ <span class="qpc-hafs">﴿إن كان قميصه قُدَّ﴾</span> إلى آخره{24}. (٨/٢٣٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧١٤٩<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- قال: ابنُ عمِّها كان الشاهدَ مِن أهلها{22}. (٨/١٩٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧١٥٠<span class="dash">-</span></span> عن <span class="name-2">زيد بن أسلم</span>- من طريق محمد بن أبان- في قوله: <span class="qpc-hafs">﴿وشهد شاهد من أهلها﴾</span>، قال: ابن عمٍّ لها كان حكيمًا{26}. (٨/٢٣٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧١٥١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وشهد شاهد من أهلها﴾</span> وهو يمليخا ابنُ عَمِّ المرأة، فتَكَلَّم بعقلٍ ولُبٍّ، قال: <span class="qpc-hafs">﴿إن كان قميصه قد من قبل فصدقت وهو من الكاذبين﴾</span> أي: إن كان يوسف هو الذي راودها فقَدَّت -يعني: فمَزَّقت- قميصه مِن قُبُلٍ -يعني: مِن قُدّامِه- فصَدَقَتْ على يوسف، ويوسف من الكاذبين في قوله{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧١٥٢<span class="dash">-</span></span> عن <span class="name-3">محمد بن إسحاق</span> -من طريق سلمة- <span class="qpc-hafs">﴿وشهد شاهد من أهلها﴾</span>، قال: يُقال: إنّما كان الشاهِدُ مُشيرًا، رجلًا مِن أهل إطفير، وكان يستعين برأيه، إلا أنه قال: أشهد إن كان قميصه قُدَّ مِن قُبُلٍ لقد صدقت وهو من الكاذبين{14}<span class=comment-ref>٣٣٤٧</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٣٣٤٧</span> اختُلِف في قوله: <span class="qpc-hafs">﴿وشهد شاهد﴾</span> على أقوال: <b>الأول</b>: كان صبيًّا في المهد. <b>الثاني</b>: كان رجلًا حكيمًا ذا لحية. <b>الثالث</b>: أنّ الشاهد هو قميص يوسف. <b>الرابع</b>: كان خَلْقًا مِن خلق الله، ولم يكن إنسيًّا ولا جنيًّا. <b>الخامس</b>: أنّ المعنى: وحكم حاكم.</p><p>وقد <span class="comment-type-3">رجّح</span> <u>ابنُ جرير</u> (١٣/١١١) <span class="mustanad">مستندًا إلى السنة</span> القول الأول، فقال: «والصواب من القول في ذلك قولُ مَن قال: كان صبيًّا في المهد؛ للخبر الذي ذكرناه عن رسول الله ﷺ أنّه ذكر مَن تكلم في المهد، فذكر أنّ أحدهم صاحب يوسف». ثم <span class="comment-type-2">انتقد</span> <span class="mustanad">مستندًا إلى اللغة</span> القول الثالث، فقال: «فأمّا ما قاله مجاهد مِن أنّه القميص المقدود، فمِمّا لا معنى له؛ لأنّ الله -تعالى ذِكْرُه- أخبر عن الشاهد الذي شهد بذلك أنّه من أهل المرأة، فقال: <span class="qpc-hafs">﴿وشهد شاهد من أهلها﴾</span>، ولا يقال للقميص: هو من أهل الرجل ولا المرأة».</p><p>و<span class="comment-type-2">انتقد</span> <u>ابنُ عطية</u> (٥/٧٢-٧٣) <span class="mustanad">مستندًا إلى السنة، والدلالة العقلية</span> القول الأول، فقال: «ومِمّا يضعف هذا أنّ في صحيح البخاري ومسلم: «لم يتكلم في المهد إلا ثلاثة: عيسى ابن مريم، وصاحب جريج، وابن السوداء الذي تمنت له أن يكون كالفاجر الجبار». فقال: لم يتكلم، وأسقط صاحب يوسف منها. ومنها: أنّ الصبي لو تكلم لكان الدليل نفس كلامه دون أن يحتاج إلى الاستدلال بالقميص».</p><p>و<span class="comment-type-2">انتقد</span> <span class="mustanad">مستندًا إلى اللغة</span> القول الثالث بقوله: «وهذا ضعيف؛ لأنّه لا يُوصَف بأنه من الأهل».</div></p></div>",footnotes:1:أخرجه ابن جرير ١٣/١٠٤، وابن أبي حاتم ٧/٢١٢٧. وعزاه السيوطي إلى أبي الشيخ.|2:أخرجه ابن جرير ١٣/١٠٢-١٠٣، وابن أبي حاتم ٧/٢١٢٨.|3:تفسير مقاتل بن سليمان ٢/٣٣٠-٣٣١.|4:أخرجه أحمد ٥/٣٠-٣٣ (٢٨٢١، ٢٨٢٢، ٢٨٢٣، ٢٨٢٤) مطولًا، والحاكم ٢/٥٣٨ (٣٨٣٥) مطولًا، وابن جرير ١٣/١٠٦. وأورده الثعلبي ٥/٢١٥.</p><p>قال الحاكم: «هذا حديث صحيح الإسناد، ولم يخرجاه». ووافقه الذهبي في التلخيص. وقال ابن كثير في تفسيره ٥/٢٩ عن رواية البيهقي: «إسناد لا بأس به، ولم يخرجوه». وقال السيوطي في الخصائص الكبرى ١/٢٦٥: «سند صحيح».|5:أخرجه ابن جرير ١٣/١٠٥.|6:أخرجه ابن جرير ١٣/١٠٥.|7:أخرجه ابن جرير ١٣/١٠٧، وابن أبي حاتم ٧/٢١٢٨ من طريق عكرمة. وعزاه السيوطي إلى أبي الشيخ.|8:علَّقه ابن أبي حاتم ٧/٢١٢٨.|9:أخرجه عبد الرزاق ١/٣٢٢، وابن جرير ١٣/١٠٧-١٠٩، وابن أبي حاتم ٧/٢١٢٨. وعزاه السيوطي إلى الفريابي، وابن المنذر، وأبي الشيخ، وابن مردويه.|10:أخرجه ابن جرير ١٣/١٠٧. وعزاه السيوطي إلى الفريابي، وأبي الشيخ.|11:أخرجه ابن جرير ١٣/١٠٨.|12:أخرجه ابن جرير ١٣/١٠٦. وعلَّقه ابن أبي حاتم ٧/٢١٢٨. وعزاه السيوطي إلى ابن أبي شيبة، وابن المنذر، وأبي الشيخ.|13:عزاه السيوطي إلى عبد بن حميد.|14:أخرجه ابن جرير ١٣/١١٠.|15:أخرجه سفيان الثوري في تفسيره ص١٤١، وابن جرير ١٣/١٠٨٣. وعلَّقه ابن أبي حاتم ٧/٢١٢٨.|16:أخرجه ابن جرير ١٣/١١٠-١١١، وابن أبي حاتم ٧/٢١٢٨-٢١٢٩. وعزاه السيوطي إلى أبي الشيخ.|17:تفسير مجاهد ص٣٩٥.|18:أخرجه ابن جرير ١٣/١٠٦. وعلَّقه ابن أبي حاتم ٧/٢١٢٨. وعزاه السيوطي إلى أبي الشيخ.|19:تفسير الثعلبي ٥/٢١٥.|20:أخرجه ابن جرير ١٣/١٠٨. وعزاه السيوطي إلى أبي الشيخ.|21:أخرجه ابن جرير ١٣/١١٠، وابن أبي حاتم ٧/٢١٢٩.|22:أخرجه ابن جرير ١٣/١٠٩.|23:أخرجه ابن جرير ١٣/١٠٦.|24:أخرجه ابن جرير ١٣/١٠٩، ١١٢، وابن أبي حاتم ٧/٢١٢٩، وابن أبي زمنين في تفسيره ٢/٣٢٢. وعزاه السيوطي إلى أبي الشيخ.|25:أخرجه ابن جرير ١٣/١٠٩.|26:أخرجه ابن أبي حاتم ٧/٢١٢٩. وعزاه السيوطي إلى أبي الشيخ.|27:تفسير مقاتل بن سليمان ٢/٣٣٠-٣٣١.|28:أخرجه ابن جرير ١٣/١١٠.
  12,27,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿إِن كَانَ قَمِیصُهُۥ قُدَّ مِن قُبُلࣲ فَصَدَقَتۡ وَهُوَ مِنَ ٱلۡكَـٰذِبِینَ ۝٢٦ وَإِن كَانَ قَمِیصُهُۥ قُدَّ مِن دُبُرࣲ فَكَذَبَتۡ وَهُوَ مِنَ ٱلصَّـٰدِقِینَ ۝٢٧﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٧١٥٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿إن كان قميصه قد من قبل فصدقت وهو من الكاذبين﴾</span> أي: إن كان يوسف هو الذي راودها فَقَدَّت -يعني: فمَزَّقت- قميصَه مِن قُبُلٍ -يعني: مِن قُدّامِه- فصدقت على يوسف، ويوسف من الكاذبين في قوله، <span class="qpc-hafs">﴿وإن كان قميصه قد من دبر فكذبت وهو من الصادقين﴾</span> أي: وإن كان يوسف هو الهارِب منها، فأدركته، فقَدَّت قميصه مِن دبر؛ فكذبت على يوسف، ويوسف من الصادقين في قوله. وقد سَمِعا جَلَبَتَهما، وتمزيقَ القميص مِن وراء الباب{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧١٥٤<span class="dash">-</span></span> عن <span class="name-3">محمد بن إسحاق</span> -من طريق سلمة- قال: أشهدُ إن كان قميصُه قُدَّ مِن قُبُلٍ لقد صدقت وهو من الكاذبين؛ وذلك أنّ الرجل إنما يريد المرأة مُقْبِلًا، وإن كان قميصه قد مِن دُبُرٍ فكذبت وهو مِن الصادقين؛ وذلك أنّ الرجل لا يأتي المرأة مِن دُبُر. وقال: إنّه لا ينبغي أن يكون في الحقِّ إلا ذاك. فلما رأى إطفير قميصه قُدَّ مِن دبر عرف أنّه مِن كيدها، فقال: <span class="qpc-hafs">﴿إنه من كيدكن إن كيدكن عظيم﴾</span>{2}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٢/٣٣٠-٣٣١.|2:أخرجه ابن جرير ١٣/١١٢.
  12,28,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿فَلَمَّا رَءَا قَمِیصَهُۥ قُدَّ مِن دُبُرࣲ قَالَ إِنَّهُۥ مِن كَیۡدِكُنَّۖ إِنَّ كَیۡدَكُنَّ عَظِیمࣱ ۝٢٨﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٧١٥٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فلما رأى﴾</span> الزوجُ <span class="qpc-hafs">﴿قميصه قد من دبر﴾</span> يقول: مُزِّق مِن ورائه؛ قال لها: <span class="qpc-hafs">﴿إنه من كيدكن﴾</span> يقول: تمزيق القميص مِن فِعْلِكُنَّ، يعني: امرأته. ثم قال: <span class="qpc-hafs">﴿إن كيدكن﴾</span> يعني: فِعْلَكُنَّ <span class="qpc-hafs">﴿عظيم﴾</span>؛ لأنّ المرأة لا تزال بالرجل حتى يقع في الخطيئة العظيمة{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧١٥٦<span class="dash">-</span></span> عن <span class="name-3">محمد بن إسحاق</span> -من طريق سلمة بن الفضل- قال: فلمّا رأى أطيفير قميصَه قُدَّ من دُبُرٍ عرف أنّه مِن كيدها، قال: <span class="qpc-hafs">﴿إنه من كيدكن إن كيدكن عظيم﴾</span>{2}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٢/٣٣٠-٣٣١.|2:أخرجه ابن أبي حاتم ٧/٢١٣٠.
  12,29,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿یُوسُفُ أَعۡرِضۡ عَنۡ هَـٰذَاۚ وَٱسۡتَغۡفِرِی لِذَنۢبِكِۖ إِنَّكِ كُنتِ مِنَ ٱلۡخَاطِـِٔینَ ۝٢٩﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٧١٥٧<span class="dash">-</span></span> قال <span class="name-1">عبد الله بن عباس</span>: هو مِن الشاهد ليوسف وراحيل، وأراد بقوله: <span class="qpc-hafs">﴿واستغفري لذنبك﴾</span> يقول: سَلِي زوجَكِ ألّا يُعاقِبَك على ذنبك، ويصفح عنك{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧١٥٨<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق قُرَّة- في قوله: <span class="qpc-hafs">﴿واستغفري لذنبك إنك كنت من الخاطئين﴾</span>، قال: حِلْمًا{2}. (٨/٢٣٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧١٥٩<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد بن بشير- في قوله: <span class="qpc-hafs">﴿يوسف أعرض عن هذا﴾</span> قال: عن هذا الأمر والحديث، <span class="qpc-hafs">﴿واستغفرى لذنبك﴾</span> أيَّتُها المرأة{3}. (٨/٢٣٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧١٦٠<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- قال: <span class="qpc-hafs">﴿يوسف أعرض عن هذا واستغفرى لذنبك﴾</span>، يقول: لا تَعُودِي لذنبك{4}. (٨/١٩٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧١٦١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثم قال الشاهد ليوسف: <span class="qpc-hafs">﴿يوسف أعرض عن هذا﴾</span> الأمرِ الذي فَعَلَتْ بِكَ، ولا تذكره لأحد. ثم أقبل الشاهد على المرأة، فقال: <span class="qpc-hafs">﴿واستغفري لذنبك﴾</span> يعني: واعتذري إلى زوجك، واسْتَعْفِيه ألّا يعاقبك، <span class="qpc-hafs">﴿إنك كنت من الخاطئين﴾</span>{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧١٦٢<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿يوسف أعرض عن هذا﴾</span>، قال: لا تَذْكُرْه{6}. (٨/٢٣٤)</p></p><p></div></p></div>",footnotes:1:تفسير الثعلبي ٥/٢١٥.|2:أخرجه ابن أبي حاتم ٧/٢١٣٠. وعزاه السيوطي إلى أبي الشيخ.|3:أخرجه ابن أبي حاتم ٧/٢١٣٠-٢١٣١. وعزاه السيوطي إلى أبي الشيخ.|4:أخرجه ابن أبي حاتم ٧/٢١٣١. وعزاه السيوطي إلى ابن جرير.|5:تفسير مقاتل بن سليمان ٢/٣٣١.|6:أخرجه ابن جرير ١٣/١١٣، وابن أبي حاتم ٧/٢١٣٠.
  12,30,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَقَالَ نِسۡوَةࣱ فِی ٱلۡمَدِینَةِ ٱمۡرَأَتُ ٱلۡعَزِیزِ تُرَ ٰ⁠وِدُ فَتَىٰهَا عَن نَّفۡسِهِۦۖ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٧١٦٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وقال نسوة في المدينة﴾</span> وهُنَّ خمس نسوة: امرأة الخَبّاز، وامرأة الساقي، وامرأة صاحب السجن، وامرأة صاحب الدوابّ، وامرأة صاحب الإذن، قُلْنَ: <span class="qpc-hafs">﴿امرأت العزيز تراود فتاها﴾</span> العبراني، يعني: عبدها الكنعاني <span class="qpc-hafs">﴿عن نفسه﴾</span>{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧١٦٤<span class="dash">-</span></span> عن <span class="name-3">محمد بن إسحاق</span> -من طريق سلمة- قال: وشاع الحديثُ في القِرية، وتحدَّث النساءُ بأمره وأمرِها، وقلن: <span class="qpc-hafs">﴿امرأة العزيز تراود فتاها عن نفسه﴾</span>، أي: عبدها{2}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿قَدۡ شَغَفَهَا حُبًّاۖ﴾</span> - قراءات</h3></p><p><div></p><p><p><span class="item-no">٣٧١٦٥<span class="dash">-</span></span> عن <span class="name-2">أبي رجاء [العُطارِدِيِّ]</span> -من طريق أبي الأشهب- أنّه قرأ: (قَدْ شَعَفَها حُبًّا) بالعين المهملة{3}. (٨/٢٣٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧١٦٦<span class="dash">-</span></span> عن <span class="name-2">إبراهيم النَّخَعِيِّ</span> أنّه كان يقرؤها: <span class="qpc-hafs">﴿قَدْ شَغَفَها حُبًّا﴾</span>. ويقول: الشَّغَفُ: شَغَفُ الحُبِّ. والشَّعَف: شَعَف الدابَّةِ حين تُذْعَرُ{4}. (٨/٢٣٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧١٦٧<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> أنّه كان يقرؤها: <span class="qpc-hafs">﴿قَدْ شَغَفَها حُبًّا﴾</span>. قال: بَطَنَها حُبًّا. قال: وأهلُ المدينة يقولون: بطَنَها حُبًّا{5}. (٨/٢٣٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧١٦٨<span class="dash">-</span></span> عن محبوب قال: قرأه <span class="name-2">عوفٌ</span>: (قَدْ شَعَفَها){6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧١٦٩<span class="dash">-</span></span> عن <span class="name-3">[حميد بن قيس] الأعرج</span> -من طريق أسيد- أنّه قرأ: (قَدْ شَعَفَها حُبًّا) بالعين المهملة. وقال: <span class="qpc-hafs">﴿شَغَفَها﴾</span> -يعني: بالمعجمة-: إذا كان هو يُحِبُّها{6}<span class=comment-ref>٣٣٤٨</span>. (٨/٢٣٧)</p></p><p></div></p><p><div><span class=comment-ref>٣٣٤٨</span> اختُلِف في قراءة قوله: <span class="qpc-hafs">﴿قد شغفها﴾</span>؛ <b>فقرأ قومٌ</b> بالغين، <b>وقرأ آخرون</b> بالعين.</p><p>و<span class="comment-type-4">ذكر</span> <u>ابنُ جرير</u> (١٣/١١٩-١٢٠) أنّ مَن قرأ بالغين، فذلك على معنى: أنّ حُبَّ يوسف وصل إلى شغاف قلبها، فدخل تحته حتى غلب على قلبها. وأنّ مَن قرأوا بالعين فإنهم وجَّهوا معنى الكلام إلى أنّ الحُبَّ قد عمها.</p><p>و<span class="comment-type-4">ذكر</span> <u>ابنُ عطية</u> (٥/٧٥-٧٦) أنّ قراءة العين لها وجهان: <b>الأول</b>: أنّه علا بها كُلَّ مرتبة مِن الحُبِّ، وذهب بها كُلَّ مذهب، فهو مأخوذ على هذا مِن شَعَف الجبال، وهي رؤوسها وأعاليها، <span class="mustanad">ومنه قول النبي</span> ﷺ: «يُوشِك أن يكون خيرُ مال المسلم غنمًا يتبع بها شَعَف الجبال، ومواقع القطر يفِرُّ بدينه مِن الفِتَن». <b>الثاني</b>: أن يكون الشَّعَف لَذَّة بحُرْقَةٍ يوجد مِن الجراحات والجرب ونحوها.</p><p>و<span class="comment-type-3">رجَّح</span> <u>ابنُ جرير</u> (١٣/١٢١) قراءة الغين <span class="mustanad">مستندًا إلى إجماع القراء</span>، فقال: «والصواب في ذلك عندنا مِن القراءة: <span class="qpc-hafs">﴿قد شغفها﴾</span> بالغين؛ لإجماع الحُجَّة مِن القراء عليه».</div></p><p><div></p><p><p><span class="item-no">٣٧١٧٠<span class="dash">-</span></span> عن محمد بن الحسن الشيباني: أنّ <span class="name-3">أبا حنيفة</span> قرأ: (قَدْ شَعَفَها حُبًّا) بالعين{8}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿قَدۡ شَغَفَهَا حُبًّاۖ﴾</span> - تفسير الآية</h3></p><p><div></p><p><p><span class="item-no">٣٧١٧١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- في قوله: <span class="qpc-hafs">﴿قد شغفها حبًّا﴾</span>، قال: غَلَبَها{9}. (٨/٢٣٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧١٧٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق أبي رَوْق، عن الضَّحّاك- في قوله: <span class="qpc-hafs">﴿شغفها﴾</span>، قال: قتلها حبُّ يوسف. الشَّغَف: الحب القاتل. والشَّعَف: حُبٌّ دون ذلك. والشَّغافُ: حِجاب القَلْب{10}. (٨/٢٣٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧١٧٣<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>: أنّ نافع بن الأزرق قال له: أخبِرني عن قوله: <span class="qpc-hafs">﴿قد شغفها حبا﴾</span>. قال: الشّغاف في القلب في النياط؛ قد امتلأ قلبُها مِن حُبِّ يوسف. قال: وهل تعرف العرب ذلك؟ قال: نعم، أما سَمِعْتَ نابغة بني ذبيان وهو يقول:</p><p>وفي الصدر حبٌّ دون ذلك داخل دخول الشَّغافِ غيَّبَته الأضالِعُ{11}. (٨/٢٣٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧١٧٤<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق العوفي- في قوله: <span class="qpc-hafs">﴿قد شغفها حبا﴾</span>، قال: قد عَلِقها{12}. (٨/٢٣٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧١٧٥<span class="dash">-</span></span> قال <span class="name-2">إبراهيم النخعي</span>: فَتَنَها، وذَهَبَ بها{13}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧١٧٦<span class="dash">-</span></span> عن أبي الأشهب، عن <span class="name-2">أبي رجاء [العطاردي]</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧١٧٧<span class="dash">-</span></span> و<span class="name-2">الحسن [البصري]</span>، <span class="qpc-hafs">﴿قد شغفها حبا﴾</span>، قال أحدهما: قد بَطَنها حُبًّا. وقال الآخًر: قد صدَقها حُبًّا{14}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧١٧٨<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نَجِيح- <span class="qpc-hafs">﴿قد شغفها حبًّا﴾</span>، قال: دخل حُبُّه في شَغافِها{15}. (٨/٢٣٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧١٧٩<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق أبي يحيى- <span class="qpc-hafs">﴿قد شغفها حبًّا﴾</span>، قال: قد عَلِقها حُبًّا{16}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧١٨٠<span class="dash">-</span></span> عن <span class="name-2">الضحاك بن مُزاحِم</span> -من طريق جُوَيْبِر- في قوله: <span class="qpc-hafs">﴿قد شغفها حبا﴾</span>، قال: هو الحُبُّ اللّازِق بالقلب{17}. (٨/٢٣٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧١٨١<span class="dash">-</span></span> عن <span class="name-2">الضحاك بن مُزاحِم</span> -من طريق عبيد- <span class="qpc-hafs">﴿قد شغفها حبًّا﴾</span>، يقول: هَلَكَتْ عليه حُبًّا{18}. (٨/٢٣٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧١٨٢<span class="dash">-</span></span> قال <span class="name-2">الضحاك بن مزاحم</span>: فَتَنها، وذهب بها{13}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧١٨٣<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span> -من طريق عمرو بن دينار- في قوله: <span class="qpc-hafs">﴿قد شغفها حبًّا﴾</span>، قال: دخل حبُّه تحتَ الشَّغاف{20}. (٨/٢٣٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧١٨٤<span class="dash">-</span></span> عن <span class="name-2">عامر الشعبي</span> -من طريق أيوب بن عائِذ الطائيِّ- في قوله: <span class="qpc-hafs">﴿قد شغفها حبا﴾</span>، قال: المشغوف: المُحِبُّ. والمشعوف: المجنون{21}. (٨/٢٣٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧١٨٥<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق أبي رجاء- في قوله: <span class="qpc-hafs">﴿قد شغفها حبا﴾</span>، قال: قد بَطَنَها حُبًّا. قال يعقوب: قال أبو بشر: أهل المدينة يقولون: قد بَطَنَها حُبًّا{14}. (٨/٢٣٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧١٨٦<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق قُرَّة بن خالد- في هذه الآية: <span class="qpc-hafs">﴿قد شغفها حبا﴾</span>، أي: قد بطن لها حبه، والشغف: أن يكون مَشْغُوفًا بها{23}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧١٨٧<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق يحيى بن المختار- في قوله: <span class="qpc-hafs">﴿قد شغفها حبا﴾</span>، قال: رَأَتِ العِلْجَةُ خليقةً لم تَرَ مثلَها، حيثُ غُلِبَتْ على عقلها، أبى قلبُها أن يَدَعَها، فأنطق اللهُ خَلِيقَةً مِن خلقه فقال: إن كان قميصه{24}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧١٨٨<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- قوله: <span class="qpc-hafs">﴿قد شغفها حبا﴾</span>، أي: قد عَلِقَها{25}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧١٨٩<span class="dash">-</span></span> قال <span class="name-2">قتادة بن دعامة</span> -من طريق مَعْمَر-: استبطنها حُبُّها إيّاه{16}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧١٩٠<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- قال: <span class="qpc-hafs">﴿قد شغفها حبًا﴾</span>، والشغاف: جِلْدةٌ على القلب، يُقال لها: لسان القلب. يقول: دخل الحبُّ الجلدَ حتى أصاب القلبَ{27}. (٨/١٩١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧١٩١<span class="dash">-</span></span> قال <span class="name-3">محمد بن السائب الكلبي</span>: الشغاف: حِجاب القلب{28}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧١٩٢<span class="dash">-</span></span> قال <span class="name-3">محمد بن السائب الكلبي</span>: حَجَب حبُّه قلبَها، حتى لا تَعْقِلَ سِواهُ{29}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧١٩٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿قد شغفها حبا﴾</span>، يعني: غلبها حُبًّا شديدًا هَلَكَتْ عليه{30}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧١٩٤<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- قال: إنّ الشَّغَف والشَّعَف مُختلِفان؛ فالشَّعَف في البُغْض، والشَّغَف في الحُبِّ{31}<span class=comment-ref>٣٣٤٩</span>. (٨/٢٣٦)</p></p><p></div></p><p><div><span class=comment-ref>٣٣٤٩</span> <span class="comment-type-2">انتَقَد</span> <u>ابنُ جرير</u> (١٣/١٢١) قول ابن زيد <span class="mustanad">مستندًا لِلُّغة</span>، فقال: «وهذا الذي قاله ابن زيد لا معنى له؛ لأنّ الشعف في كلام العرب بمعنى عموم الحب أشهرُ مِن أن يجهله ذو علم بكلامهم».</p><p>و<span class="comment-type-2">انتقد</span> <u>ابنُ عطية</u> (٥/٧٦) هذا القول، وكذا قول الشعبي، بقوله: «هذان القولان ضعيفان».</div></p><p><div></p><p><p><span class="item-no">٣٧١٩٥<span class="dash">-</span></span> عن <span class="name-3">سفيان [بن عيينة]</span>-من طريق أحمد بن صالح- قال: الشَّغافُ: جِلدةٌ رقيقةٌ تكون على القلب بيضاء؛ حبُّه خَرَق ذلك الجلدَ حتى وصل إلى القلب{32}. (٨/٢٣٦)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿إِنَّا لَنَرَىٰهَا فِی ضَلَـٰلࣲ مُّبِینࣲ ۝٣٠﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٧١٩٦<span class="dash">-</span></span> قال <span class="name-2">إسماعيل السُّدِّيّ</span>، في قوله: <span class="qpc-hafs">﴿إنا لنراها في ضلال مبين﴾</span>، يعني: في خسرانٍ بَيِّنٍ مِن حُبِّ يوسف{28}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧١٩٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿إنا لنراها في ضلال مبين﴾</span>، يعني: في خسرانٍ بَيِّنٍ، يعني: شَقاء مِن حُبِّ يوسف ﵇، حتى فشا عليها{30}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٢/٣٣١. وفي تفسير الثعلبي ٥/٢١٦ وتفسير البغوي ٤/٢٣٦ بنحوه منسوبًا إلى مقاتل دون تعيينه.|2:أخرجه ابن جرير ١٣/١١٤، وابن أبي حاتم ٧/٢١٣١.|3:أخرجه ابن جرير ١٣/١١٩.</p><p>وهي قراءة شاذة، تُروى أيضًا علي بن أبي طالب ﵄، والنخعي، والحسن البصري، وغيرهم. انظر: المحتسب ١/٣٣٨.|4:عزاه السيوطي إلى ابن أبي شيبة، وابن المنذر، وأبي الشيخ.|5:أخرجه ابن جرير ١٣/١١٧، وابن أبي حاتم ٧/٢١٣١. وعزاه السيوطي إلى ابن أبي شيبة، وابن المنذر، وأبي الشيخ.|6:أخرجه ابن جرير ١٣/١١٩.|7:أخرجه ابن جرير ١٣/١١٩.|8:أخرجه ابن عساكر في تاريخ دمشق ٥٢/٢٣٠.|9:أخرجه ابن جرير ١٣/١١٦. وعزاه السيوطي إلى ابن المنذر.|10:أخرجه ابن أبي حاتم ٧/٢١٣١. وعزاه السيوطي إلى أبي الشيخ.|11:أخرجه الطستي -كما في مسائل نافع (٢٤٦)-.|12:أخرجه ابن جرير ١٣/١١٦ بلفظ: علِقها حُبًّا، وابن أبي حاتم ٧/٢١٣١.|13:تفسير الثعلبي ٥/٢١٦.|14:أخرجه ابن جرير ١٣/١١٧.|15:ذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٢/٣٢٣-، وأخرجه ابن جرير ١٣/١١٦. وعزاه السيوطي إلى أبي الشيخ.|16:أخرجه ابن جرير ١٣/١١٨.|17:أخرجه ابن جرير ١٣/١١٨. وعزاه السيوطي إلى ابن أبي شيبة، وابن المنذر، وأبي الشيخ.|18:أخرجه ابن جرير ١٣/١١٨ وزاد: والشغاف: شغاف القلب.|19:تفسير الثعلبي ٥/٢١٦.|20:أخرجه ابن جرير ١٣/١١٥. وعزاه السيوطي إلى أبي الشيخ.|21:أخرجه ابن جرير ١٣/١١٦-١١٧، وابن أبي حاتم ٧/٢١٣١. وعزاه السيوطي إلى ابن المنذر، وأبي الشيخ.|22:أخرجه ابن جرير ١٣/١١٧.|23:أخرجه ابن وهب في الجامع ١/١٣٧ (٣١٧) واللفظ له، وابن جرير ١٣/١١٧ بلفظ: قد بطن لها حُبًّا.|24:أخرجه ابن أبي حاتم ٧/١٢٣٢.|25:أخرجه عبد الرزاق في تفسيره ١/٣٢٢ من طريق مَعْمَر، وابن جرير ١٣/١١٨. وعلَّقه ابن أبي حاتم ٧/٢١٣١.|26:أخرجه ابن جرير ١٣/١١٨.|27:أخرجه ابن جرير ١٣/١١٩، وابن أبي حاتم ٧/٢١٣١.|28:ذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٢/٣٢٣-.|29:تفسير الثعلبي ٥/٢١٦، وتفسير البغوي ٤/٢٣٦.|30:تفسير مقاتل بن سليمان ٢/٣٣١.|31:أخرجه ابن جرير ١٣/١٢١، وابن أبي حاتم ٧/٢١٣٢ من طريق أصبغ بن الفرج. وعزاه السيوطي إلى أبي الشيخ.|32:أخرجه ابن أبي حاتم ٧/٢١٣١-٢١٣٢.|33:ذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٢/٣٢٣-.|34:تفسير مقاتل بن سليمان ٢/٣٣١.