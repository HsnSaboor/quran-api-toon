tafsir[29]{c,v,t}:
70,11," <q>﴿یُبَصَّرُونَهُمۡۚ﴾</q> - تفسير ٧٨٧٤٦- عن عبد الله بن عباس -من طريق عطية العَوفيّ- في قوله: <q>﴿يُبَصَّرُونَهُمْ﴾</q>، قال: يَعْرِف بعضهم بعضًا ويَتعارفون، ثم يَفرّ بعضهم من بعض. يقول: <q>﴿لكل امرئ منهم يومئذ شأن يغنيه﴾</q> [عبس:٣٧]{1}. (١٤/٦٩٤) ٧٨٧٤٧- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿يُبَصَّرُونَهُمْ﴾</q>، قال: المؤمنون يُبصرون الكافرين{2}. (١٤/٦٩٣) ٧٨٧٤٨- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿يُبَصَّرُونَهُمْ﴾</q> قال: يُعَرَّفونهم؛ يُعلَّمون، واللهِ، ليَعرفنّ يوم القيامة قومٌ قومًا، وأناسٌ أناسًا، <q>﴿يَوَدُّ المُجْرِمُ لَوْ يَفْتَدِي﴾</q> الآيةَ قال: يتمنّى يوم القيامة لو يَفتدي بالأَحبّ فالأَحبّ، والأقرب فالأقرب، من أهله وعشيرته؛ لشدّة ذلك اليوم{2}. (١٤/٦٩٣) ٧٨٧٤٩- قال إسماعيل السُّدِّيّ: <q>﴿يُبَصَّرُونَهُمْ﴾</q> يعرفونهم؛ أما المؤمن فببياض وجهه، وأما الكافر فبسواد وجهه{4}. (ز) ٧٨٧٥٠- قال مقاتل بن سليمان: <q>﴿يُبَصَّرُونَهُمْ﴾</q> يقول: يعرفونهم، ولا يُكلّمونهم، وذلك قوله: <q>﴿فهم لا يتساءلون﴾</q> [القصص:٦٦]، <q>﴿خاشِعَةً أبْصارُهُمْ﴾</q> [القلم:٤٣] خافضة أبصارهم ذليلة عند مُعاينة النار{5}. (ز) ٧٨٧٥١- قال عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿يُبَصَّرُونَهُمْ﴾</q>، قال: يُبصرون الذين أضلُّوهم في الدنيا في النار{6}٦٧٩٦. (ز) ٦٧٩٦ اختُلف في الذين عُنوا بالهاء والميم في قوله: <q>﴿يبصرونهم﴾</q> على أقوال: الأول: أنه عُني بذلك: الأقرباء؛ أنهم يَعرفون أقرباءهم، ويَعرف كلّ إنسان قريبه، فذلك تبصير الله إياهم. الثاني: أنّ المؤمنين يُبصرون الكافرين. الثالث: أنّ الكفار الذين كانوا أتباعًا لآخرين في الدنيا على الكفر يُعرّفون المتبوعين في النار. ورجَّح ابنُ جرير (٢٣/٢٥٩) -مستندًا إلى السياق- القول الأول الذي قاله ابن عباس، وقتادة، فقال: «لأنّ ذلك أشبهها بما دلّ عليه ظاهر التنزيل، وذلك أنّ قوله: <q>﴿يبصرونهم﴾</q> تلا قوله: <q>﴿ولا يسأل حميم حميما﴾</q>؛ فلأن تكون الهاء والميم من ذكرهم أشبه منها بأن تكون مِن ذِكْر غيرهم». <q>﴿یَوَدُّ ٱلۡمُجۡرِمُ لَوۡ یَفۡتَدِی مِنۡ عَذَابِ یَوۡمِىِٕذِۭ بِبَنِیهِ ۝١١﴾</q> - تفسير ٧٨٧٥٢- قال مقاتل بن سليمان: <q>﴿يَوَدُّ المُجْرِمُ﴾</q> يعني: الكافر <q>﴿لَوْ يَفْتَدِي مِن عَذابِ يَوْمِئِذٍ﴾</q> يوم القيامة <q>﴿بِبَنِيهِ﴾</q>{5}. (ز) ",footnotes:1:أخرجه ابن جرير ٢٣/٢٥٧-٢٥٨.أخرجه ابن جرير ٢٣/٢٥٨. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه ابن جرير ٢٣/٢٥٨. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.تفسير الثعلبي ١٠/٣٧، وتفسير البغوي ٨/٢٢٢.تفسير مقاتل بن سليمان ٤/٤٣٧.أخرجه ابن جرير ٢٣/٢٥٨.تفسير مقاتل بن سليمان ٤/٤٣٧.
70,12," <q>﴿وَصَـٰحِبَتِهِۦ وَأَخِیهِ ۝١٢﴾</q> - تفسير ٧٨٧٥٣- قال مقاتل بن سليمان: <q>﴿وصاحِبَتِهِ﴾</q> يعني: امرأته{1}. (ز) ٧٨٧٥٤- قال عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿وصاحِبَتِهِ﴾</q>، قال: الصاحبة الزوجة{2}. (ز) ",footnotes:1:تفسير مقاتل بن سليمان ٤/٤٣٧.أخرجه ابن جرير ٢٣/٢٦٠.
70,13," <q>﴿وَفَصِیلَتِهِ ٱلَّتِی تُـٔۡوِیهِ ۝١٣ وَمَن فِی ٱلۡأَرۡضِ جَمِیعࣰا ثُمَّ یُنجِیهِ ۝١٤﴾</q> - تفسير ٧٨٧٥٥- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿وفَصِيلَتِهِ﴾</q>، قال: قبيلته{1}. (١٤/٦٩٤) ٧٨٧٥٦- عن الضَّحّاك بن مُزاحِم، <q>﴿وفَصِيلَتِهِ﴾</q>، قال: عشيرته{2}. (١٤/٦٩٤) ٧٨٧٥٧- عن محمد بن كعب القُرَظيّ، <q>﴿وفَصِيلَتِهِ الَّتِي تُؤْوِيهِ﴾</q>، قال: قبيلته التي يَنتسب إليها{2}. (١٤/٦٩٤) ٧٨٧٥٨- قال مقاتل بن سليمان: <q>﴿وفَصِيلَتِهِ الَّتِي تُؤْوِيهِ﴾</q> يعني: رهطه وفَخذه الأدنى الذي يساوى إليهم، <q>﴿ومَن فِي الأَرْضِ جَمِيعًا﴾</q> مِن شيء، <q>﴿ثُمَّ يُنْجِيهِ﴾</q>{4}. (ز) ٧٨٧٥٩- قال عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿وفَصِيلَتِهِ الَّتِي تُؤْوِيهِ﴾</q>، قال: فصيلته: عشيرته{5}٦٧٩٧. (ز) ٦٧٩٧ ذكر ابنُ عطية (٨/٤٠٥) أنّ الفصيلة -في هذه الآية-: قرابة الرجل الأدنون. مثال ذلك: بنو هاشم مع النبي ﷺ. وأنها أيضًا في كلام العرب: الزوجة. ثم قال: «ولكن ذكْر الصاحبة في هذه الآية لم يُبْق في معنى الفصيلة إلا الوجه الذي ذكرناه». ",footnotes:1:أخرجه ابن جرير ٢٣/٢٦٠. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.عزاه السيوطي إلى ابن المنذر.عزاه السيوطي إلى ابن المنذر.تفسير مقاتل بن سليمان ٤/٤٣٧.أخرجه ابن جرير ٢٣/٢٦٠.
  70,14,""
70,15," <q>﴿كَلَّاۤۖ إِنَّهَا لَظَىٰ ۝١٥﴾</q> - تفسير ٧٨٧٦٠- قال مقاتل بن سليمان: يقول الله تعالى: <q>﴿كَلّا﴾</q> لا يُنجيه ذلك لو افتَدى بهذا كلّه، ثم استأنف فقال: <q>﴿إنَّها لَظى﴾</q> يعني بلَظى: استطالتها وقُدرتها عليهم، يعني: النار{1}. (ز) ",footnotes:1:تفسير مقاتل بن سليمان ٤/٤٣٧.
70,16," <q>﴿نَزَّاعَةࣰ لِّلشَّوَىٰ ۝١٦﴾</q> - تفسير ٧٨٧٦١- عن عبد الله بن عباس -من طريق قابوس، عن أبيه- في قوله: <q>﴿نَزّاعَةً لِلشَّوى﴾</q>، قال: تَنزع أُمّ الراس{1}. (١٤/٦٩٤) ٧٨٧٦٢- عن عبد الله بن عباس -من طريق عطية العَوفيّ- قوله: <q>﴿نَزّاعَةً لِلشَّوى﴾</q> يعني: الجلود والهام{1}. (ز) ٧٨٧٦٣- عن عبد الله بن عباس -من طريق سعيد بن جُبَير- <q>﴿نَزّاعَةً لِلشَّوى﴾</q>: للعَصب والعَقب{3}. (ز) ٧٨٧٦٤- قال أبو العالية الرِّياحيّ: <q>﴿نَزّاعَةً لِّلشَّوى﴾</q> لمحاسن وجهه{4}. (ز) ٧٨٧٦٥- قال مُرّة: <q>﴿نَزّاعَةً لِلشَّوى﴾</q> للأعضاء{3}. (ز) ٧٨٧٦٦- عن سعيد بن جُبَير، <q>﴿نَزّاعَةً لِلشَّوى﴾</q>، قال: فَروة الرأس{6}. (١٤/٦٩٥) ٧٨٧٦٧- عن إبراهيم بن المُهاجر، قال: سألتُ سعيد بن جُبَير عن قوله: <q>﴿نَزّاعَةً لِلشَّوى﴾</q>. فلم يُخبر، فسألتُ عنها مجاهد بن جبر، فقلتُ: اللحم دون العظم؟ فقال: نعم{1}. (ز) ٧٨٧٦٨- عن مجاهد بن جبر -من طريق الأعمش- <q>﴿نَزّاعَةً لِلشَّوى﴾</q>، قال: الشّوى: الأطراف{8}. (١٤/٦٩٥) ٧٨٧٦٩- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿نَزّاعَةً لِلشَّوى﴾</q>، قال: لجلود الرأس{9}. (١٤/٦٩٤) ٧٨٧٧٠- عن الضَّحّاك بن مُزاحِم -من طريق عبيد- في قوله: <q>﴿نَزّاعَةً لِلشَّوى﴾</q>: تَبري اللحم والجلد عن العظم، حتى لا تَترك منه شيئًا{10}. (ز) ٧٨٧٧١- عن الحسن البصري -من طريق قُرّة بن خالد- <q>﴿نَزّاعَةً لِلشَّوى﴾</q>، قال: للهام، تَحرق كلّ شيء منه، ويَبقى فؤاده يصيح{11}. (ز) ٧٨٧٧٢- عن أبي صالح باذام -من طريق إسماعيل- <q>﴿نَزّاعَةً لِلشَّوى﴾</q>، قال: للحم السّاقين{12}. (١٤/٦٩٥) ٧٨٧٧٣- عن أبي صالح باذام، <q>﴿نَزّاعَةً لِلشَّوى﴾</q>، قال: الأطراف{6}. (١٤/٦٩٥) ٧٨٧٧٤- عن قتادة بن دعامة -من طريق سعيد- <q>﴿نَزّاعَةً لِلشَّوى﴾</q>، قال: لِهامته، ومَكارم وجهه{14}. (١٤/٦٩٤) ٧٨٧٧٥- عن ثابت البُناني -من طريق جعفر- <q>﴿نَزّاعَةً لِلشَّوى﴾</q>، قال: لِمَكارِم وجه ابن آدم{15}. (١٤/٦٩٥) ٧٨٧٧٦- قال محمد بن السّائِب الكلبي: <q>﴿نَزّاعَةً لِّلشَّوى﴾</q> لأُمّ الرأس، تأكل الدِّماغ كلّه، ثم يعود كما كان، ثم تعود لأَكْله، فذلك دَأْبها{4}. (ز) ٧٨٧٧٧- قال مقاتل بن سليمان: <q>﴿نَزّاعَةً لِلشَّوى﴾</q>، يقول: تَنزع النارُ الهامةَ، والأطرافَ؛ فلا تَبْقى{17}. (ز) ٧٨٧٧٨- عن قُرّة بن خالد، <q>﴿نَزّاعَةً لِلشَّوى﴾</q>، قال: نزّاعة للهام، تحرق كلّ شيء منه، ويبقى فؤاده نضيجًا{18}. (١٤/٦٩٥) ٧٨٧٧٩- قال عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿نَزّاعَةً لِلشَّوى﴾</q>، قال: الشوى: الآراب العظام، ذاك الشوى{19}٦٧٩٨. (ز) ٦٧٩٨ ذكر ابنُ جرير (٢٣/٢٦١) أنّ «الشوى»: جمع شواة، وهي من جوارح الإنسان ما لم يكن مَقتلًا، يقال: رمى فأشوى: إذا لم يُصب مقتلًا، ثم علَّق بقوله: "فربما وصف الواصف بذلك جِلدة الرأس، كما قال الأعشى: قالَتْ قُتَيْلَةُ ما لَهُ قَدْ جُلِّلَتْ شَيْبًا شَواتُهْ؟ وربما وصف بذلك الساق كقولهم في صفة الفرس: عبْل الشوى نهد الجزاره يعني بذلك: قوائمه، وأصل ذلك كله ما وصفت". وبنحوه قال ابنُ عطية (٨/٤٠٥-٤٠٦)، وكذا قال ابنُ القيم (٣/١٩٦). ",footnotes:1:أخرجه ابن جرير ٢٣/٢٦٢.أخرجه ابن جرير ٢٣/٢٦٢.تفسير الثعلبي ١٠/٣٨.تفسير الثعلبي ١٠/٣٨، وتفسير البغوي ٨/٢٢٣.تفسير الثعلبي ١٠/٣٨.عزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ٢٣/٢٦٢.أخرجه ابن أبي شيبة ١٣/١٦٨.أخرجه ابن جرير ٢٣/٢٦٢. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه ابن جرير ٢٣/٢٦٣، وابن أبي الدنيا في كتاب صفة النار -موسوعة الإمام ابن أبي الدنيا ٦/٤٢٨ (١٣٥)-.أخرجه عبد الرزاق ٢/٣١٧، وابن جرير ٢٣/٢٦٣. وذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٥/٣٥-.أخرجه ابن أبي شيبة ١٣/١٦٨، وابن جرير ٢٣/٢٦٣. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.عزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ٢٣/٢٦٣. وعزاه السيوطي إلى عبد الرزاق، وعبد بن حميد، وابن المنذر.أخرجه ابن أبي الدنيا في كتاب صفة النار -موسوعة الإمام ابن أبي الدنيا ٦/٤٢٩ (١٣٦)-. وعزاه السيوطي إلى ابن المنذر.تفسير الثعلبي ١٠/٣٨، وتفسير البغوي ٨/٢٢٣.تفسير مقاتل بن سليمان ٤/٤٣٧.عزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ٢٣/٢٦٤.
70,17," <q>﴿تَدۡعُوا۟ مَنۡ أَدۡبَرَ وَتَوَلَّىٰ ۝١٧﴾</q> - تفسير ٧٨٧٨٠- قال عبد الله بن عباس: <q>﴿تَدْعُو مَن أدْبَرَ وتَوَلّى﴾</q> تدعو الكافرين والمنافقين بأسمائهم بلسان فصيح، ثم تَلتَقطهم كما يَلتَقط الطيرُ الحَبَّ{1}٦٧٩٩. (ز) ٦٧٩٩ ذكر ابنُ عطية (٨/٤٠٦) أنه على هذا القول فدعاء النار حقيقة، ثم نَقل عن الخليل بن أحمد القول بأنّ نداءها عبارة عن حِرْصها عليهم، واستدنائها لهم، وما تُوقعه من عذابها. ونَقل عن ثعلب القول بأنّ: <q>﴿تَدْعُو﴾</q> معناه: تُهلك، ثم علَّق بقوله: «تقول العرب: دعاك الله، أي: أهلكك، وحكاه الخليل عن العرب». ٧٨٧٨١- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿تَدْعُو مَن أدْبَرَ وتَوَلّى﴾</q>، قال: عن الحق{2}. (١٤/٦٩٤) ٧٨٧٨٢- عن قتادة بن دعامة -من طريق سعيد- <q>﴿تَدْعُو مَن أدْبَرَ﴾</q> قال: عن طاعة الله، <q>﴿وتَوَلّى﴾</q> قال: عن كتاب الله، وعن حقّه{3}. (١٤/٦٩٤) ٧٨٧٨٣- قال مقاتل بن سليمان: <q>﴿تَدْعُوا مَن أدْبَرَ﴾</q> يعني: تدعو النار يوم القيامة، تقول: إلَيَّ أهلي. فهذا دعاؤها لـــ<q>﴿مَن أدْبَرَ﴾</q> عن الإيمان، <q>﴿وتَوَلّى﴾</q> يقول: وأَعرَض عنه إلى الكفر{4}. (ز) ٧٨٧٨٤- قال عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿تَدْعُو مَن أدْبَرَ وتَوَلّى﴾</q>، قال: ليس لها سلطان إلا على هوان مَن كَفر وتَولّى وأَدبَر عن الله، فأمّا مَن آمن بالله ورسوله فليس لها عليه سلطان{5}. (ز) ",footnotes:1:تفسير الثعلبي ١٠/٣٨، وتفسير البغوي ٨/٢٢٣.أخرجه ابن جرير ٢٣/٢٦٤. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه ابن جرير ٢٣/٢٦٤. وعزاه السيوطي إلى عبد الرزاق، وعبد بن حميد، وابن المنذر.تفسير مقاتل بن سليمان ٤/٤٣٧.أخرجه ابن جرير ٢٣/٢٦٤.
70,18," <q>﴿وَجَمَعَ فَأَوۡعَىٰۤ ۝١٨﴾</q> - تفسير ٧٨٧٨٥- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿وجَمَعَ فَأَوْعى﴾</q>، قال: جمع المال{1}. (١٤/٦٩٤) ٧٨٧٨٦- عن قتادة بن دعامة -من طريق سعيد- <q>﴿وجَمَعَ فَأَوْعى﴾</q>، قال: كان جَموعًا للخبيث{2}. (١٤/٦٩٤) ٧٨٧٨٧- قال مقاتل بن سليمان: قوله: <q>﴿وجَمَعَ فَأَوْعى﴾</q>، يعني: فأَكثر مِن المال، وأَمسَك، فلم يُؤدّ حقّ الله فيه{3}. (ز) <q>﴿وَجَمَعَ فَأَوۡعَىٰۤ ۝١٨﴾</q> - آثار متعلقة بالآية ٧٨٧٨٨- عن الحكم، قال: كان عبد الله بن عُكَيم لا يَربط كِيسه، قال: سمعتُ الله يقول: <q>﴿وجَمَعَ فَأَوْعى﴾</q>{4}. (١٤/٦٩٥) ",footnotes:1:أخرجه ابن جرير ٢٣/٢٦٥. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه ابن جرير ٢٣/٢٦٥. وعزاه السيوطي إلى عبد الرزاق، وعبد بن حميد، وابن المنذر.تفسير مقاتل بن سليمان ٤/٤٣٧.أخرجه ابن سعد ٦/١١٤، وابن جرير ٢٣/٢٦٥.
70,19," <q>﴿إِنَّ ٱلۡإِنسَـٰنَ خُلِقَ هَلُوعًا ۝١٩ إِذَا مَسَّهُ ٱلشَّرُّ جَزُوعࣰا ۝٢٠ وَإِذَا مَسَّهُ ٱلۡخَیۡرُ مَنُوعًا ۝٢١﴾</q> - نزول الآية ٧٨٧٨٩- عن عبد الله بن عباس، قال: نَزَلَتْ في أبي جهل بن هشام{1}. (١٤/٦٩٦) ٧٨٧٩٠- قال مقاتل بن سليمان: <q>﴿إنَّ الإنْسانَ خُلِقَ هَلُوعًا﴾</q>، يعني: ضَجرًا، فهو أُمَيّة بن خلف الجُمَحي{2}. (ز) <q>﴿إِنَّ ٱلۡإِنسَـٰنَ خُلِقَ هَلُوعًا ۝١٩ إِذَا مَسَّهُ ٱلشَّرُّ جَزُوعࣰا ۝٢٠ وَإِذَا مَسَّهُ ٱلۡخَیۡرُ مَنُوعًا ۝٢١﴾</q> - تفسير الآية ٧٨٧٩١- عن عبد الله بن عباس، <q>﴿هَلُوعًا﴾</q>، قال: الشَّرِه{3}. (١٤/٦٩٦) ٧٨٧٩٢- عن عكرمة، قال: سُئل ابن عباس عن الهَلُوع، فقال: هو كما قال الله؛ إذا مسه الشر كان جَزُوعًا، وإذا مَسَّهُ الخَيْر كان مَنُوعًا، فهو الهَلُوع{4}. (١٤/٦٩٥) ٧٨٧٩٣- عن عبد الله بن عباس -من طريق عطية العَوفيّ- في قوله: <q>﴿إنَّ الإنْسانَ خُلِقَ هَلُوعًا﴾</q>، قال: هو الذي قال الله: <q>﴿إذا مَسَّهُ الشَّرُّ جَزُوعًا وإذا مَسَّهُ الخَيْر مَنُوعًا﴾</q>. ويقال: الهَلُوع: هو الجَزُوع الحريص، وهذا في أهل الشّرك{5}. (ز) ٧٨٧٩٤- عن عبد الله بن عباس -من طريق السدي، عن أبي صالح- في قوله: <q>﴿هَلُوعًا﴾</q>، قال: الحريص على ما لا يحل له{6}. (ز) ٧٨٧٩٥- عن عبد الله بن عباس، أنّ نافع بن الأزرق سأله عن قوله: <q>﴿إنَّ الإنْسانَ خُلِقَ هَلُوعًا﴾</q>. قال: ضَجورًا جَزوعًا، نَزَلَتْ في أبي جهل بن هشام. قال: وهل تعرف العرب ذلك؟ قال: نعم، أما سمعتَ بِشر بن أبي خازم وهو يقول: لا مانعًا لليتيم نِحْلته ولا مُكِبًا بخلْقه هلِعًا؟{7}. (١٤/٦٩٦) ٧٨٧٩٦- عن سعيد بن جُبَير -من طريق جعفر بن أبي المُغيرة- في قوله: <q>﴿هَلُوعًا﴾</q>، قال: شَحيحًا جَزُوعًا{8}. (١٤/٦٩٦) ٧٨٧٩٧- قال مجاهد بن جبر: <q>﴿منوعا﴾</q> شرِهًا{6}. (ز) ٧٨٧٩٨- عن الضَّحّاك بن مُزاحِم، <q>﴿هَلُوعًا﴾</q>، قال: الذي لا يَشبع مِن جَمْع المال{3}. (١٤/٦٩٦) ٧٨٧٩٩- عن الضَّحّاك بن مُزاحِم -من طريق عبيد- في قوله: <q>﴿إنَّ الإنْسانَ﴾</q> يعني: الكافر <q>﴿خُلِقَ هَلُوعًا﴾</q> يقول: هو بخيلٌ، مَنوعٌ للخير، جَزوعٌ إذا نَزل به البلاء، فهذا الهَلُوع{5}. (ز) ٧٨٨٠٠- عن عكرمة مولى ابن عباس -من طريق إسماعيل بن أبي خالد- <q>﴿هَلُوعًا﴾</q>، قال: الضَّجِر{8}. (١٤/٦٩٦) ٧٨٨٠١- عن الحسن البصري -من طريق حُميد- أنه سُئِل عن قوله: <q>﴿إنَّ الإنْسانَ خُلِقَ هَلُوعًا﴾</q>. قال: اقرأ ما بعدها. فقرأ: <q>﴿إذا مَسَّهُ الشَّرُّ جَزُوعًا وإذا مَسَّهُ الخَيْر مَنُوعًا﴾</q>. قال: هو هكذا، خُلِق هكذا{13}. (١٤/٦٩٦) ٧٨٨٠٢- قال الحسن البصري -من طريق معمر-: <q>﴿هَلُوعًا﴾</q> هو الشَّرِه{14}. (ز) ٧٨٨٠٣- عن منصور بن زاذان، عن الحسن [البصري]، في قوله: <q>﴿إن الإنسان خلق هلوعا﴾</q>، قال: بخيلًا بالخير{15}. (ز) ٧٨٨٠٤- قال عطاء: <q>﴿منوعا﴾</q> عَجُولًا{6}. (ز) ٧٨٨٠٥- عن قتادة بن دعامة -من طريق معمر- <q>﴿هَلُوعًا﴾</q>، قال: جَزُوعًا{17}. (١٤/٦٩٦) ٧٨٨٠٦- عن حُصَيْن بن عبد الرحمن -من طريق شعبة- <q>﴿هَلُوعًا﴾</q>، قال: الحريص{18}. (١٤/٦٩٦) ٧٨٨٠٧- قال مقاتل بن سليمان: <q>﴿إنَّ الإنْسانَ خُلِقَ هَلُوعًا﴾</q> يعني: ضَجِرًا، فهو أُمَيّة بن خلف الجُمحي، ثم نَعتَه، فقال: <q>﴿إذا مَسَّهُ الشَّرُّ﴾</q> يقول: إذا أصابه <q>﴿جَزُوعًا﴾</q>، <q>﴿وإذا مَسَّهُ الخَيْر﴾</q> يعني: المال <q>﴿مَنُوعًا﴾</q> فمَنع وبَخِل بحقّ الله تعالى{2}. (ز) ٧٨٨٠٨- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿إنَّ الإنْسانَ خُلِقَ هَلُوعًا﴾</q>، قال: الهَلُوع: الجَزُوع{20}٦٨٠٠. (ز) ٦٨٠٠ نَقل ابنُ تيمية (٦/٣٩٤) عن الجوهري القول بأنّ الهَلَع: أفحَش الجَزع. وعن غيره أنه في اللغة: أشدّ الحِرص وأسوأ الجَزع. وساق قول النبي ﷺ: «شرُّ ما في المرء شُحٌّ هالِع، وجُبْنٌ خالع». ثم علَّق بقوله: «ولهذا كان كلام السلف في تفسيره يتضمن هذه المعاني». وساق الآثار. <q>﴿إِنَّ ٱلۡإِنسَـٰنَ خُلِقَ هَلُوعًا ۝١٩ إِذَا مَسَّهُ ٱلشَّرُّ جَزُوعࣰا ۝٢٠ وَإِذَا مَسَّهُ ٱلۡخَیۡرُ مَنُوعًا ۝٢١﴾</q> - آثار متعلقة بالآية ٧٨٨٠٩- عن عليٍّ مرفوعًا: «يُكتب أنين المريض؛ فإن كان صابرًا كان أنينه حسنات، وإن كان جَزوعًا كُتب هَلُوعًا لا أجْر له»{21}. (١٤/٦٩٧) ",footnotes:1:أخرجه ابن الطستي في مسائل نافع بن الأزرق ص٢٠٥ (١٧٤)، من طريق عيسى بن دأب، عن حميد الأعرج، وعبد الله بن أبي بكر بن محمد، عن أبيه، عن ابن عباس به. وسنده شديد الضعف؛ فيه عيسى بن دأب، متروك. كما في الميزان ٣/٣٢٧. وفيه أيضًا حميد الأعرج القاص، قال عنه ابن حجر في التقريب (١٥٦٦): «ضعيف»تفسير مقاتل بن سليمان ٤/٤٣٧.عزاه السيوطي إلى ابن المنذر.عزاه السيوطي إلى ابن جرير، وعبد بن حميد، وابن المنذر، وابن أبي حاتم.أخرجه ابن جرير ٢٣/٢٦٦.تفسير الثعلبي ١٠/٣٩.أخرجه الطستي -كما في الإتقان ٢/٩٧-٩٨-.أخرجه ابن جرير ٢٣/٢٦٦. وعزاه السيوطي إلى ابن المنذر.تفسير الثعلبي ١٠/٣٩.عزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ٢٣/٢٦٦.أخرجه ابن جرير ٢٣/٢٦٦. وعزاه السيوطي إلى ابن المنذر.أخرجه آدم بن أبي إياس -كما في تفسير مجاهد ص٦٧٤-. وعزاه السيوطي إلى ابن المنذر.أخرجه عبد الرزاق ٢/٣١٧.أخرجه سعيد بن منصور في سننه -التفسير ٨/١٦٥ (٢٢٩٤).تفسير الثعلبي ١٠/٣٩.أخرجه عبد الرزاق ٢/٣١٧، وابن جرير ٢٣/٢٦٧. وعزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ٢٣/٢٦٧. وعزاه السيوطي إلى ابن المنذر.تفسير مقاتل بن سليمان ٤/٤٣٧.أخرجه ابن جرير ٢٣/٢٦٧.أخرجه أبو نعيم في أخبار أصبهان ١/٣٣٠، من طريق القاسم بن+ بهرام، عن أبي إسحاق، عن الحارث، عن علي به. وأورده الديلمي في الفردوس ٥/٥٣٧ (٩٠١٤). وسنده ضعيف؛ فيه القاسم بن بهرام، قال عنه الذهبي في الميزان ٣/٣٦٩: «له عجائب، وهّاه ابن حبان وغيره».
