70,29," <q>﴿وَٱلَّذِینَ هُمۡ لِفُرُوجِهِمۡ حَـٰفِظُونَ ۝٢٩ إِلَّا عَلَىٰۤ أَزۡوَ ٰ⁠جِهِمۡ أَوۡ مَا مَلَكَتۡ أَیۡمَـٰنُهُمۡ فَإِنَّهُمۡ غَیۡرُ مَلُومِینَ ۝٣٠ فَمَنِ ٱبۡتَغَىٰ وَرَاۤءَ ذَ ٰ⁠لِكَ فَأُو۟لَـٰۤىِٕكَ هُمُ ٱلۡعَادُونَ ۝٣١﴾</q> - تفسير ٧٨٨٥٦- قال مقاتل بن سليمان: <q>﴿والَّذِينَ هُمْ لِفُرُوجِهِمْ حافِظُونَ﴾</q> عن الفواحش، ثم استثنى فقال: <q>﴿إلّا عَلى أزْواجِهِمْ أوْ ما مَلَكَتْ أيْمانُهُمْ﴾</q> يعني به: الولائد <q>﴿فإنهم غير ملومين﴾</q> يعني: لا يُلامون على الحلال، <q>﴿فَمَنِ ابْتَغى وراءَ ذَلِكَ﴾</q> بعد أزواجه وولائده ما لا يَحلّ له وهو الزنا، <q>﴿فَأُولَئِكَ هُمُ العادُونَ﴾</q> يعني: المُعتدين في دينهم{1}٦٨٠٦. (ز) ٦٨٠٦ ذكر ابنُ عطية (٨/٤٠٩) أن «الفروج» في هذه الآية: هي الفروج المعروفة، والمعنى: يحفظونها مِن الزنا. ثم نقل عن الحسن بن أبي الحسن القول بأنه أراد فروج الثياب، وعلَّق عليه بقوله: «وإلى معنى الوطء يعود». ",footnotes:1:تفسير مقاتل بن سليمان ٤/٤٣٨.
  70,30,""
  70,31,""
70,32," <q>﴿وَٱلَّذِینَ هُمۡ لِأَمَـٰنَـٰتِهِمۡ وَعَهۡدِهِمۡ رَ ٰ⁠عُونَ ۝٣٢ وَٱلَّذِینَ هُم بِشَهَـٰدَ ٰ⁠تِهِمۡ قَاۤىِٕمُونَ ۝٣٣﴾</q> - تفسير ٧٨٨٥٧- قال مقاتل بن سليمان: <q>﴿والَّذِينَ هُمْ لِأَماناتِهِمْ وعَهْدِهِمْ راعُونَ﴾</q> يعني: يؤدون الأمانة، ويوفون بالعهد، ثم قال: <q>﴿راعُونَ﴾</q> يرعونه ويتعاهدونه كما يرعى الراعي الشفيق غنمه عن مواقع الهلكة، <q>﴿والَّذِينَ هُمْ بِشَهاداتِهِمْ قائِمُونَ﴾</q> يعني: يقومون بها بالحق، لا يمنعونها ولا يكتمونها إذا دعوا إليها{1}٦٨٠٧. (ز) ٦٨٠٧ ذكر ابنُ عطية (٨/٤١٠-٤١١) أنّ قوله: <q>﴿والذين هم بشهاداتهم قائمون﴾</q> له معنيان: الأول: أنهم يَحفظون ما يَشهدون فيه، ويَتيقّنونه ويَقومون بمعانيه حتى لا يكون لهم فيه تقصير. وعلَّق عليه بقوله: «وهذا هو وصف من تمثيل قول النبي ﷺ: «على مثل الشمس فاشهد»». الثاني: أنّ المعنى: الذين إذا كانت عندهم شهادة ورأوا حقًّا يدرَس أو حُرمة لله تُنتهك قاموا بشهادتهم. ونَقل عن ابن عباس القول بأنّ شهادتهم في هذه الآية: لا إله إلا الله وحده لا شريك له. وساق حديث النبي ﷺ: «خير الشهداء الذي يأتي بشهادته قبل أن يُسألها». ثم قال: «واختلف الناس في معنى هذا الحديث بحسب المَعْنَيَيْن اللذَيْن ذكرنا في الآية، إحداهما: أنْ يكون يحفظها مُتقنة فيأتي بها ولا يَحتاج أن يُسْتَفْهَم عن شيء منها ولا أن يُعارَض. والثاني: إذا رأى حقًّا يعمل بخلافه وعنده في إحياء الحق شهادة». ثم ساق حديث النبي ﷺ: «سيأتي قوم يخونون ولا يُؤتمنون، ويشهدون ولا يُستشهدون، ويظهر فيهم السّمَن». وبيّن أنه اختُلف في معنى هذا الحديث على قولين: الأول: أنهم قوم مُؤمنون يَتعرّضون ويحرصون على وضْع أسمائهم في وثائق الناس، وينصبون لذلك الحبائل من زي وهيئة وهم غير عُدول في أنفسهم فيغرّون بذلك ويَضرّون. وعلَّق عليه بقوله: «فهذا في ابتداء الشهادة لا في أدائها، ويجيء قوله ﷺ: «ولا يُستشهدون»، أي: وهم غير أهل لذلك». الثاني: أنهم هم شهود الزُّور، يؤدونها، والمشهود عليهم لم يشهدهم، ولا الآخر". ",footnotes:1:تفسير مقاتل بن سليمان ٤/٤٣٨.
  70,33,""
70,34," <q>﴿وَٱلَّذِینَ هُمۡ عَلَىٰ صَلَاتِهِمۡ یُحَافِظُونَ ۝٣٤ أُو۟لَـٰۤىِٕكَ فِی جَنَّـٰتࣲ مُّكۡرَمُونَ ۝٣٥﴾</q> - تفسير ٧٨٨٥٨- عن الحسن البصري -من طريق خُليد- <q>﴿والذين هم على صلاتهم يحافظون﴾</q>، قال: على المواقيت{1}. (ز) ٧٨٨٥٩- قال مقاتل بن سليمان: <q>﴿والَّذِينَ هُمْ عَلى صَلاتِهِمْ﴾</q> الخمس <q>﴿يُحافِظُونَ﴾</q> عليها في مواقيتها، <q>﴿أُولَئِكَ﴾</q> الذين هذه أعمالهم <q>﴿فِي جَنّاتٍ مُكْرَمُونَ﴾</q> يعني: يُكرمون فيها{2}٦٨٠٨. (ز) ٦٨٠٨ ذكر ابنُ تيمية (٦/٣٩٦) أنّ ابن جُرَيْج قال في قوله: <q>﴿والذين هم على صلواتهم يحافظون﴾</q> المكتوبة، والتي في سأل سائل: التطوع. وانتقده بقوله: «وهذا قول ضعيف». ",footnotes:1:أخرجه محمد بن نصر في تعظيم قدر الصلاة ١/١٣٧.تفسير مقاتل بن سليمان ٤/٤٣٨.
  70,35,""
70,36," <q>﴿فَمَالِ ٱلَّذِینَ كَفَرُوا۟ قِبَلَكَ مُهۡطِعِینَ ۝٣٦﴾</q> - نزول الآية ٧٨٨٦٠- قال مقاتل بن سليمان: <q>﴿فَمالِ الَّذِينَ كَفَرُوا قِبَلَكَ مُهْطِعِينَ﴾</q> نزلت هذه الآيةُ في المُستهزئين من قريش، والمُطعمين في غزوة بدر{1}. (ز) <q>﴿فَمَالِ ٱلَّذِینَ كَفَرُوا۟ قِبَلَكَ مُهۡطِعِینَ ۝٣٦﴾</q> - تفسير الآية ٧٨٨٦١- عن عبد الله بن عباس -من طريق عطية- في قوله: <q>﴿فَمالِ الَّذِينَ كَفَرُوا قِبَلَكَ مُهْطِعِينَ﴾</q>، قال: يَنظرون{2}. (١٤/٦٩٨) ٧٨٨٦٢- عن الحسن البصري -من طريق قُرّة- <q>﴿فَمالِ الَّذِينَ كَفَرُوا قِبَلَكَ مُهْطِعِينَ﴾</q>، قال: مُنطَلِقين{3}. (١٤/٦٩٩) ٧٨٨٦٣- عن قتادة بن دعامة -من طريق سعيد- <q>﴿فَمالِ الَّذِينَ كَفَرُوا قِبَلَكَ مُهْطِعِينَ﴾</q>، قال: عامِدين{3}. (١٤/٦٩٩) ٧٨٨٦٤- قال مقاتل بن سليمان: <q>﴿فَمالِ الَّذِينَ كَفَرُوا قِبَلَكَ مُهْطِعِينَ﴾</q> يعني: مُقْبِلين، نزلت هذه الآيةُ في المُستهزئين من قريش، والمُطعمين في غزوة بدر، مُقْبِلين يَنظرون عن يمين النبي ﷺ{1}. (ز) ٧٨٨٦٥- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿فَمالِ الَّذِينَ كَفَرُوا قِبَلَكَ مُهْطِعِينَ﴾</q>، قال: المُهطِع: الذي لا يَطرِف{6}. (ز) ",footnotes:1:تفسير مقاتل بن سليمان ٤/٤٣٨.أخرجه ابن جرير ٢٣/٢٧٨-٢٧٩.أخرجه ابن جرير ٢٣/٢٧٨. وعزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ٢٣/٢٧٨. وعزاه السيوطي إلى عبد بن حميد.تفسير مقاتل بن سليمان ٤/٤٣٨.أخرجه ابن جرير ٢٣/٢٧٨.
70,37," <q>﴿عَنِ ٱلۡیَمِینِ وَعَنِ ٱلشِّمَالِ عِزِینَ ۝٣٧﴾</q> - تفسير ٧٨٨٦٦- عن عبد الله بن عباس -من طريق عطية- في قوله: <q>﴿عَنِ اليَمِينِ وعَنِ الشِّمالِ عِزِينَ﴾</q>، قال: العُصَبُ{1} من الناس عن يمين وشمال، مُعرضين يستهزئون به{2}. (١٤/٦٩٨) ٧٨٨٦٧- عن عبد الله بن عباس، أنّ نافع بن الأزرق سأله عن قوله: <q>﴿عَنِ اليَمِينِ وعَنِ الشِّمالِ عِزِينَ﴾</q>. قال: الحِلَق الرّقاق. قال: وهل تعرف العرب ذلك؟ قال: نعم، أما سمعتَ عَبِيد بن الأَبْرص وهو يقول: فجاؤا يُهرعون إليه حتى يكونوا حول مِنبره عِزينا؟{3}. (١٤/٦٩٩) ٧٨٨٦٨- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿عَنِ اليَمِينِ وعَنِ الشِّمالِ﴾</q> قال: عن يمين النبيِّ ﷺ وعن شماله <q>﴿عِزِينَ﴾</q> قال: مجالس مُحتَبين، نَفرٌ قليل قليل{4}. (١٤/٦٩٩) ٧٨٨٦٩- عن الضَّحّاك بن مُزاحِم -من طريق عبيد- في قوله: <q>﴿عِزِينَ﴾</q>، قال: حِلَقًا، ورفقاء{5}. (ز) ٧٨٨٧٠- عن الحسن البصري -من طريق قُرّة- <q>﴿عَنِ اليَمِينِ وعَنِ الشِّمالِ عِزِينَ﴾</q>، قال: مُتَفرِّقين، يأخذون يمينًا وشمالًا، يقولون: ما يقول هذا الرجل؟!{6}. (١٤/٦٩٩) ٧٨٨٧١- عن قتادة بن دعامة -من طريق معمر- في قوله: <q>﴿عِزِينَ﴾</q>، قال: الحِلَق، المجالس{7}. (١٤/٧٠٠) ٧٨٨٧٢- عن قتادة بن دعامة -من طريق سعيد- <q>﴿عَنِ اليَمِينِ وعَنِ الشِّمالِ عِزِينَ﴾</q>، قال: فِرقًا حول نبي الله، لا يَرغبون في كتاب الله ولا ذِكره{8}. (١٤/٦٩٩) ٧٨٨٧٣- قال مقاتل بن سليمان: <q>﴿عَنِ اليَمِينِ وعَنِ الشِّمالِ عِزِينَ﴾</q> يعني: حِلقًا حِلقًا جُلوسًا، لا يَدنون من النبي ﷺ فيَنتفعون بمجلسه{9}. (ز) ٧٨٨٧٤- عن ابن لَهِيعة -من طريق ابن وهب- في قول الله: <q>﴿عَنِ اليَمِينِ وعَنِ الشِّمالِ عِزِينَ﴾</q>، قال: يقال: العِزين: المُتَفَرِّقين، وقال الشاعر: بمعزاة أضحت صداها ترى ركبانها عُصبًا عزينا{10}. (ز) ٧٨٨٧٥- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في في قوله: <q>﴿عَنِ اليَمِينِ وعَنِ الشِّمالِ عِزِينَ﴾</q>، قال: العِزين: المجلس الذي فيه الثلاثة والأربعة، والمجالس الثلاثة والأربعة أولئك العُزون{5}. (ز) <q>﴿عَنِ ٱلۡیَمِینِ وَعَنِ ٱلشِّمَالِ عِزِینَ ۝٣٧﴾</q> - آثار متعلقة بالآية ٧٨٨٧٦- عن أبي هريرة، قال: خرج رسول الله ﷺ وأصحابه جلوس حِلقٌ حِلقٌ، فقال: «مالي أراكم عِزين؟»{12}. (١٤/٧٠٠) ٧٨٨٧٧- عن جابر بن سَمُرَة، قال: دخل علينا رسول الله ﷺ المسجد ونحن حِلقٌ مُتَفَرِّقون، فقال: «مالي أراكم عِزين؟»{13}. (١٤/٧٠٠) ٧٨٨٧٨- عن عُبادة بن نُسَيٍّ، قال: دخل رسول الله ﷺ المسجد، فقال: «مالي أراكم عِزين، حِلقًا حِلَق الجاهلية؟». قعد الرجل خلف أخيه{14}. (١٤/٧٠٠) ",footnotes:1:العصب: جمع عُصْبَة، وهي الجماعة ما بين العشرة إلى الأربعين. اللسان (عصب).أخرجه ابن جرير ٢٣/٢٧٨-٢٧٩.أخرجه الطستي -كما في الإتقان ٢/٦٨-.أخرجه ابن جرير ٢٣/٢٧٩. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه ابن جرير ٢٣/٢٧٩.أخرجه ابن جرير ٢٣/٢٨١. وذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٥/٣٧-. وعزاه السيوطي إلى عبد بن حميد.أخرجه عبد الرزاق ٢/٣١٧، وابن جرير ٢٣/٢٧٩. وعزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ٢٣/٢٧٩. وعزاه السيوطي إلى عبد بن حميد.تفسير مقاتل بن سليمان ٤/٤٣٨.أخرجه عبد الله بن وهب في الجامع -تفسير القرآن ٢/١٤٨ (٢٩٩).أخرجه ابن جرير ٢٣/٢٧٩.أخرجه ابن حبان ٤/٥٣٤-٥٣٥ (١٦٥٤)، وابن جرير ٢٣/٢٧٩-٢٨٠، والثعلبي ١٠/٤١. وقال ابن كثير في تفسيره ٨/٢٢٩ عن رواية ابن جرير: «هذا إسناد جيد، ولم أره في شيء من الكتب الستة من هذا الوجه».أخرجه مسلم ١/٣٢٢ (٤٣٠) مطولًا، وابن جرير ٢٣/٢٨٠-٢٨١.عزاه السيوطي إلى عبد بن حميد.
70,38," <q>﴿أَیَطۡمَعُ كُلُّ ٱمۡرِئࣲ مِّنۡهُمۡ أَن یُدۡخَلَ جَنَّةَ نَعِیمࣲ ۝٣٨ كَلَّاۤۖ﴾</q> - قراءات ٧٨٨٧٩- عن عاصم أنه قرأ: <q>﴿أن يُدْخَلَ﴾</q> برفع الياء{1}. (١٤/٧٠١) ٧٨٨٨٠- عن أبي معمر أنه قرأ: (أن يَدْخُلَ) بنصب الياء ورفع الخاء{2}٦٨٠٩. (١٤/٧٠١) ٦٨٠٩ اختُلف في قراءة قوله: <q>﴿أن يدخل﴾</q>؛ فقرأ قوم بضم الياء على وجه ما لم يُسمّ فاعله. وقرأ آخرون بفتحها على بناء الفعل للفاعل. ورجَّح ابنُ جرير (٢٣/٢٨٢) قراءة الضم مستندًا إلى إجماع القراء، فقال: «والصواب من القراءة في ذلك ما عليه قراء الأمصار، وهي ضم الياء؛ لإجماع الحُجّة من القُراء عليه». <q>﴿أَیَطۡمَعُ كُلُّ ٱمۡرِئࣲ مِّنۡهُمۡ أَن یُدۡخَلَ جَنَّةَ نَعِیمࣲ ۝٣٨ كَلَّاۤۖ﴾</q> - تفسير الآية ٧٨٨٨١- قال عبد الله بن عباس: <q>﴿أيَطْمَعُ كُلُّ امْرِئٍ مِنهُمْ أنْ يُدْخَلَ جَنَّةَ نَعِيمٍ﴾</q> معناه: أيطمع كلّ رجل منهم أن يَدخل جنتي كما يَدخلها المسلمون ويَتنعّم فيها وقد كذّب نبِيِّي؟ <q>﴿كَلا﴾</q> لا يَدخلونها{3}. (ز) ٧٨٨٨٢- عن الضَّحّاك بن مُزاحِم، في قوله: <q>﴿أيَطْمَعُ كُلُّ امْرِئٍ مِنهُمْ أنْ يُدْخَلَ جَنَّةَ نَعِيمٍ كلا﴾</q> قال: كلا لستُ فاعلًا. ثم ذكر خَلْقهم، فقال: <q>﴿إنّا خَلَقْناهُمْ مِمّا يَعْلَمُونَ﴾</q>{4}. (١٤/٧٠١) ٧٨٨٨٣- قال مقاتل بن سليمان: <q>﴿أيَطْمَعُ كُلُّ امْرِئٍ مِنهُمْ﴾</q> يعني: قريشًا <q>﴿أنْ يُدْخَلَ جَنَّةَ نَعِيمٍ﴾</q> كلّ واحد منهم يقول: إنّ لي في الجنة حقًّا. يقول ذلك استهزاء، يقول: أُعطى منها ما يُعطى المؤمنون. يقول الله تعالى: <q>﴿كَلا﴾</q> لا يَدخلها{5}. (ز) <q>﴿كَلَّاۤۖ إِنَّا خَلَقۡنَـٰهُم مِّمَّا یَعۡلَمُونَ ۝٣٩﴾</q> - تفسير ٧٨٨٨٤- عن بُسْر بن جِحاش، قال: قرأ رسول الله ﷺ هذه الآية: <q>﴿فَمالِ الَّذِينَ كَفَرُوا قِبَلَكَ مُهْطِعِينَ﴾</q> إلى قوله: <q>﴿كَلّا إنّا خَلَقْناهُمْ مِمّا يَعْلَمُونَ﴾</q>، ثم بَزَق رسول الله ﷺ على كَفّه، ووضع عليها إصبعه، وقال: «يقول الله: ابن آدم، أنّى تُعجِزُني وقد خَلَقتُك مِن مثل هذه، حتى إذا سوّيتُك وعدَّلتُك مَشيْتَ بين بُرْدَيْن وللأرض منك وئيد{6}، فجَمَعْتَ ومَنَعْتَ، حتى إذا بلَغت التَّراقيَ قلتُ: أتصدّق. وأنّى أوان الصدقة؟!»{7}. (١٤/٧٠١) ٧٨٨٨٥- عن الضَّحّاك بن مُزاحِم، في قوله: <q>﴿إنّا خَلَقْناهُمْ مِمّا يَعْلَمُونَ﴾</q>، يعني: النُّطفة التي خُلق منها البشر{4}. (١٤/٧٠١) ٧٨٨٨٦- عن قتادة بن دعامة -من طريق سعيد- <q>﴿إنّا خَلَقْناهُمْ مِمّا يَعْلَمُونَ﴾</q>، قال: إنما خُلِقْتَ مِن قَذرٍ، يا ابن آدم، فاتّق الله{9}. (١٤/٧٠١) ٧٨٨٨٧- قال مقاتل بن سليمان: يقول الله تعالى: <q>﴿كَلا﴾</q> لا يَدخلها، ثم استأنف فقال لما كذّبوا بالغيب: <q>﴿إنّا خَلَقْناهُمْ مِمّا يَعْلَمُونَ﴾</q> خُلقوا من نُطفة، ثم من عَلقة، ثم من مُضغة{5}. (ز) <q>﴿كَلَّاۤۖ إِنَّا خَلَقۡنَـٰهُم مِّمَّا یَعۡلَمُونَ ۝٣٩﴾</q> - آثار متعلقة بالآية ٧٨٨٨٨- عن أنس بن مالك، قال: كان أبو بكر الصِّدِّيق إذا خَطبنا ذَكر مَناتِن ابنِ آدم، فذَكر بدء خَلْقه أنه يَخرج مِن مَخرج البول مرتين، ثم يقع في الرَّحِم نُطفة، ثم عَلقة، ثم مُضغة، ثم يَخرج مِن بطن أُمّه فيَتلوّث في بوله وخَراه؛ حتى يَقذر أحدُنا نفسَه{11}. (ز) ",footnotes:1:عزاه السيوطي إلى عبد بن حميد. وهي قراءة العشرة.عزاه السيوطي إلى عبد بن حميد. وهي قراءة شاذة، تروى أيضًا عن ابن يعمر، والحسن، وأبي رجاء، وغيرهم. انظر: البحر المحيط ٨/٣٣٠.تفسير البغوي ٨/٢٢٥.عزاه السيوطي إلى ابن المنذر.تفسير مقاتل بن سليمان ٤/٤٣٨-٤٣٩.الوئيد: صوت شدة الوطء على الأرض يُسمَعُ كالدوِيِّ من بُعدٍ. النهاية (وأد).أخرجه أحمد ٢٩/٣٨٥-٣٨٧ (١٧٨٤٢-١٧٨٤٥)، وابن ماجه ٤/١٢-١٣ (٢٧٠٧)، والحاكم ٢/٥٤٥ (٣٨٥٥)، ٤/٣٥٩ (٧٩١٤)، والثعلبي ١٠/٤١. قال الحاكم: «هذا حديث صحيح الإسناد، ولم يخرجاه». ووافقه الذهبي في التلخيص. وأورده الدارقطني في العلل ١٠/٣٢٤ (٢٠٣٤). وقال البوصيري في مصباح الزجاجة ٣/١٤٣ (١٦٩): «ليس لبُسر عند ابن ماجه سوى هذا الحديث، وليس له رواية في شيء من الكتب الخمسة، وإسناد حديثه صحيح؛ رجال ثقات». وقال الألباني في الصحيحة ٣/١٣٥ (١١٤٣) بعد نقله لقول الحاكم والذهبي والبوصيري: «وهو كما قالوا».عزاه السيوطي إلى ابن المنذر.أخرجه عبد الرزاق ٢/٣١٨ من طريق معمر، وابن جرير ٢٣/٢٨٢. وعزاه السيوطي إلى عبد بن حميد.تفسير مقاتل بن سليمان ٤/٤٣٨-٤٣٩.أخرجه الثعلبي ١٠/٤١.
  70,39,""
