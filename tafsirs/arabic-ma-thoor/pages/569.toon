  70,21,""
70,22," <q>﴿إِلَّا ٱلۡمُصَلِّینَ ۝٢٢ ٱلَّذِینَ هُمۡ عَلَىٰ صَلَاتِهِمۡ دَاۤىِٕمُونَ ۝٢٣﴾</q> - تفسير ٧٨٨١٠- عن عبد الله بن مسعود -من طريق عبد الرحمن- <q>﴿الَّذِينَ هُمْ عَلى صَلاتِهِمْ دائِمُونَ﴾</q>، قال: على مواقيتها{1}. (١٤/٦٩٧) ٧٨٨١١- عن مَسروق بن الأَجْدع الهَمداني، مثله{2}. (١٤/٦٩٧) ٧٨٨١٢- عن عِمران بن حُصَيْن -من طريق أبي الأسود- <q>﴿الَّذِينَ هُمْ عَلى صَلاتِهِمْ دائِمُونَ﴾</q>، قال: الذي لا يَلتفتُ في صلاته{3}. (١٤/٦٩٧) ٧٨٨١٣- عن عُقبة بن عامر -من طريق أبي الخير- في قوله: <q>﴿الَّذِينَ هُمْ عَلى صَلاتِهِمْ دائِمُونَ﴾</q>، قال: هم الذين إذا صَلَّوْا لم يَلتفِتوا{4}. (١٤/٦٩٨) ٧٨٨١٤- عن أبي الخير، أنّ عُقبة بن عامر قال لهم: مَن <q>﴿الَّذِينَ هُمْ عَلى صَلاتِهِمْ دائِمُونَ﴾</q>؟ قلنا: الذين لا يَزالون يُصلُّون. فقال: لا، ولكن الذين إذا صَلَّوا لم يَلتفِتوا عن يمين وشمال{5}٦٨٠١. (١٤/٦٩٨) ٦٨٠١ علَّق ابنُ كثير (١٤/١٣٣ بتصرف) على هذا القول بقوله: «كقوله: <q>﴿قد أفلح المؤمنون الذين هم في صلاتهم خاشعون﴾</q> [المؤمنون:١-٢]، ومنه: الماء الدائم، أي: الساكن الراكد». وبنحوه قال ابنُ عطية (٨/٤٠٧). وساق ابنُ القيم (٣/١٩٧) قول عُقبة، ثم علَّق بقوله: «قلتُ: هما أمران: الدوام عليها، والمداومة عليها، فهذا الدوام والمداومة في قوله تعالى: <q>﴿والذين هم على صلاتهم يحافظون﴾</q>». ثم قال: «وفُسِّر الدوام: بسكون الأطراف والطمأنينة». ٧٨٨١٥- عن سعيد بن المسيّب، سُئل عن قول الله: <q>﴿الَّذِينَ هُمْ عَلى صَلاتِهِمْ دائِمُونَ﴾</q>. قال: يُداوم عليها، ولا يَدَعها، ويُداوم على مواقيتها وحدودها{6}. (ز) ٧٨٨١٦- عن أبي سَلمة بن عبد الرحمن، عن عائشة، قالت: قال رسول الله ﷺ: «خذوا من العمل ما تُطيقون؛ فإنّ الله لا يَملّ حتى تَملّوا». قالت: وكان أحب الأعمال إلى رسول الله ﷺ ما دام عليه وإن قلّ، وكان إذا صلّى صلاة دام عليها. قال أبو سَلمة: قال الله: <q>﴿الَّذِينَ هُمْ عَلى صَلاتِهِمْ دائِمُونَ﴾</q>{7}. (١٤/٦٩٨) ٧٨٨١٧- عن إبراهيم التيميّ، في قوله: <q>﴿الَّذِينَ هُمْ عَلى صَلاتِهِمْ دائِمُونَ﴾</q>، قال: المكتوبة{2}. (١٤/٦٩٧) ٧٨٨١٨- عن إبراهيم [النخعي] -من طريق منصور- في قوله: <q>﴿الَّذِينَ هُمْ عَلى صَلاتِهِمْ دائِمُونَ﴾</q>، قال: الصلوات الخمس{9}. (ز) ٧٨٨١٩- عن عكرمة مولى ابن عباس -من طريق يزيد بن عبد الرحمن بن جَسّاسٍ- <q>﴿على صلاتهم دائمون﴾</q>، قال: على مواقيتها{10}. (ز) ٧٨٨٢٠- قال الحسن البصري: <q>﴿الَّذِينَ هُمْ عَلى صَلاتِهِمْ دائِمُونَ﴾</q> يَدُومون عليها{11}. (ز) ٧٨٨٢١- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿إلّا المُصَلِّينَ الَّذِينَ هُمْ عَلى صَلاتِهِمْ دائِمُونَ﴾</q>، قال: ذُكر لنا: أنّ دانيال نَعتَ أُمّة محمد ﷺ، فقال: يُصَلُّون صلاة لو صَلّاها قوم نوح ما أُغرقوا، أو عاد ما أُرسلتْ عليهم الريح العقيم، أو ثمود ما أخذتْهم الصّيحة. قال قتادة: فعليكم بالصلاة؛ فإنها خُلُقٌ من أخلاق المؤمنين حسن{12}. (١٤/٦٩٧) ٧٨٨٢٢- قال مقاتل بن سليمان: ثم استأنف فقال: <q>﴿إلّا المُصَلِّينَ﴾</q> فليسوا كذلك، ثم نَعتَهم الله تعالى فقال: <q>﴿الَّذِينَ هُمْ عَلى صَلاتِهِمْ﴾</q> يعني: الصلوات الخمس <q>﴿دائِمُونَ﴾</q> بالليل والنهار، لا يَدَعونها{13}. (ز) ٧٨٨٢٣- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿الَّذِينَ هُمْ عَلى صَلاتِهِمْ دائِمُونَ﴾</q>، قال: هؤلاء المؤمنون الذين مع النبي ﷺ على صلاتهم دائمون{14}٦٨٠٢. (ز) ٦٨٠٢ ذكر ابنُ عطية (٨/٤٠٧) أنّ الجمهور على أنّ المعنى: مواظبون قائمون لا يَملُّون في وقت من الأوقات فيتركونها. ثم علَّق بقوله: «وهذا في المكتوب، وأما النافلة فالدوام عليها الإكثار منها بحسب الطاقة، وقد قال ﷺ: «أحبّ العمل إلى الله ما داوم عليه صاحبه»». وذكر ابنُ تيمية (٦/٣٩٥) أنّ السلف فسَّروا الدائم على الصلاة بالمُحافِظ على أوقاتها، وبالدائم على أفعالها بالإقبال عليها. ثم علَّق بقوله: «والآية تعمّ هذا وهذا، فإنه قال: <q>﴿على صلاتهم دائمون﴾</q>، والدائم على الفعل هو المُديم له الذي يفعله دائمًا، فإذا كان هذا فيما يفعل في الأوقات المتفرقة، هو أن يَفعله كلّ يوم بحيث لا يَفعله تارة ويتركه أخرى، وسُمّي ذلك دوامًا عليه، فالدوام على الفعل الواحد المتصل أولى أن يكون دوامًا وأن تتناول الآية ذلك، وذلك يدل على وجوب إدامة أفعالها؛ لأن الله ﷿ ذمّ عموم الإنسان، واستثنى المُداوِم على هذه الصفة، فتاركُ إدامة أفعالها يكون مذمومًا من الشارع، والشارع لا يذمّ إلا على ترْك واجب أو فِعْل محرم». ",footnotes:1:أخرجه ابن أبي شيبة ١/٣١٦.عزاه السيوطي إلى عبد بن حميد.أخرجه ابن أبي شيبة ٢/٤٢. وعزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ٢٣/٢٦٨. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم، وابن مردويه.عزاه السيوطي إلى ابن المنذر.أخرجه عبد الله بن وهب في الجامع -تفسير القرآن ٢/١٥٥ (٣١٨).أخرجه ابن خزيمة ٢/٤٣٧-٤٣٨ (١٢٨٣)، وابن حبان ٢/٦٧-٦٨ (٣٥٣)، ٤/٤٤٦-٤٤٧ (١٥٧٨) واللفظ له، وابن جرير ٢٣/٢٦٩. وأصل الحديث في البخاري ٧/١٥٥ (٥٨٦١)، ٨/٩٨ (٦٤٦٥)، ومسلم ١/٥٤٠ (٧٨٢).عزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ٢٣/٢٦٨، وعنه في رواية بلفظ: المكتوبة.أخرجه محمد بن نصر في تعظيم قدر الصلاة ١/١٣٨.ذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٥/٣٦-.أخرجه ابن جرير ٢٣/٢٦٨. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.تفسير مقاتل بن سليمان ٤/٤٣٧.أخرجه ابن جرير ٢٣/٢٦٨.
  70,23,""
70,24," <q>﴿وَٱلَّذِینَ فِیۤ أَمۡوَ ٰ⁠لِهِمۡ حَقࣱّ مَّعۡلُومࣱ ۝٢٤ لِّلسَّاۤىِٕلِ وَٱلۡمَحۡرُومِ ۝٢٥﴾</q> - نزول الآية ٧٨٨٢٤- عن الحسن بن محمد: أنّ النبي ﷺ بَعثَ سَرِيّة، فغنموا، وفُتح عليهم، فجاء قوم لم يشهدوا، فنَزلت: <q>﴿والَّذِينَ فِي أمْوالِهِمْ حَقٌّ مَعْلُومٌ لِلسّائِلِ والمَحْرُومِ﴾</q>{1}. (ز) <q>﴿وَٱلَّذِینَ فِیۤ أَمۡوَ ٰ⁠لِهِمۡ حَقࣱّ مَّعۡلُومࣱ ۝٢٤﴾</q> - تفسير ٧٨٨٢٥- عن أنس بن مالك، قال: قال رسول الله ﷺ: «يا أنس، ويل للأغنياء مِن الفقراء يوم القيامة، يقولون: ربّنا، ظلمونا حقوقنا التي فَرضتَ لنا عليهم. فيقول: وعزّتي وجلالي، لأقرِّبنكم ولأُبعّدنهم». قال: وتلا رسول الله ﷺ: <q>﴿والذين فِي أمْوالِهِمْ حَقٌّ معلوم لِلسّائِلِ والمَحْرُومِ﴾</q>{2}. (١٣/٦٧٧) ٧٨٨٢٦- عن عبد الله بن عباس -من طريق عليّ- في قوله: <q>﴿والَّذِينَ فِي أمْوالِهِمْ حَقٌّ مَعْلُومٌ لِلسّائِلِ والمَحْرُومِ﴾</q>، يقول: هو سوى الصّدقة يَصل بها رَحِمه، أو يَقري بها ضيفًا، أو يَحمل بها كَلًّا، أو يُعين بها محرومًا{3}. (ز) ٧٨٨٢٧- عن قزعة: أن ابن عمر سُئِل عن قوله: <q>﴿والَّذِينَ فِي أمْوالِهِمْ حَقٌّ مَعْلُومٌ لِلسّائِلِ والمَحْرُومِ﴾</q> أهي الزَّكاة؟ فقال: إنّ عليك حقوقًا سوى ذلك{3}. (ز) ٧٨٨٢٨- عن إبراهيم النَّخَعي، في قوله: <q>﴿والَّذِينَ فِي أمْوالِهِمْ حَقٌّ مَعْلُومٌ﴾</q>، قال: كانوا إذا خَرجَت الأُعطية أُعطوا منها{5}. (١٤/٦٩٨) ٧٨٨٢٩- عن مجاهد بن جبر -من طريق سفيان- في قوله: <q>﴿فِي أمْوالِهِمْ حَقٌّ مَعْلُومٌ﴾</q>، قال: سوى الزَّكاة{6}. (ز) ٧٨٨٣٠- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿والَّذِينَ فِي أمْوالِهِمْ حَقٌّ مَعْلُومٌ لِلسّائِلِ والمَحْرُومِ﴾</q>، قال: الزَّكاة المفروضة{3}. (ز) ٧٨٨٣١- عن زياد بن أبي مريم -من طريق خُصَيف- في قوله: <q>﴿حق معلوم﴾</q>، قال: الزَّكاة{8}٦٨٠٣. (ز) ٦٨٠٣ اختُلف في المراد بالحق المعلوم على قولين: الأول: أنه الزَّكاة المفروضة. الثاني: أنه حقٌّ سوى الزَّكاة. ورجَّح ابنُ عطية (٨/٤٠٨) -مستندًا إلى أحوال النزول- القول الثاني الذي قاله ابن عمر، ومجاهد، والنَّخَعي، فقال: «هو الأصحُّ في هذه الآية؛ لأنّ السورة مكّيّة، وفرْض الزَّكاة وبيانها إنما كان بالمدينة». <q>﴿وَٱلَّذِینَ فِیۤ أَمۡوَ ٰ⁠لِهِمۡ حَقࣱّ مَّعۡلُومࣱ ۝٢٤﴾</q> - النسخ في الآية ٧٨٨٣٢- عن خالد بن أبي عمران، قال: سألتُ القاسم [بن محمد]= (ز) ٧٨٨٣٣- وسالم [بن عبد الله بن عمر] عن قول الله: <q>﴿والَّذِينَ فِي أمْوالِهِمْ حَقٌّ مَعْلُومٌ لِلسّائِلِ والمَحْرُومِ﴾</q>. فقالا: المعلوم منسوخة، وكلّ صَدقة في القرآن منسوخة، نَسَخَتْها هذه الآية: <q>﴿إنَّما الصَّدَقاُت لِلْفُقَراءِ والـمَساكِينِ﴾</q> إلى آخر الآية [التوبة:٦٠]. قالا: والمحروم مُحارَف في الرزق والتجارة{9}. (ز) <q>﴿وَٱلَّذِینَ فِیۤ أَمۡوَ ٰ⁠لِهِمۡ حَقࣱّ مَّعۡلُومࣱ ۝٢٤﴾</q> - آثار متعلقة بالآية ٧٨٨٣٤- عن إبراهيم النَّخَعي -من طريق الأعمش- قال: في المال حقٌّ سوى الزَّكاة{3}. (ز) ٧٨٨٣٥- عن عامر الشعبي -من طريق بيان- قال: إنّ في المال حقًّا سوى الزَّكاة{3}. (ز) <q>﴿لِّلسَّاۤىِٕلِ وَٱلۡمَحۡرُومِ﴾</q>{12} - تفسير ٧٨٨٣٦- عن إبراهيم النَّخَعي: أنّ ناسًا قدموا على علي [بن أبي طالب] ﵁ الكوفة بعد وقْعة الجمل، فقال: اقسِموا لهم. وقال: هذا المحروم{13}. (ز) ٧٨٨٣٧- عن أبي قِلابة عبد الله بن زيد الجرمي، قال: جاء سَيلٌ باليمامة، فذَهب بمال رجل، فقال رجل من أصحاب النبي ﷺ: هذا المحروم{14}. (ز) ٧٨٨٣٨- عن عبد الله بن عباس -من طريق قيس بن كُركُم- في قوله: <q>﴿لِلسّائِلِ والمَحْرُومِ﴾</q>، قال: السائل: الذي يسأل. والمحروم: المُحارَف الذي ليس له في الإسلام سهم{15}. (ز) ٧٨٨٣٩- عن أبي بشر، قال: سألتُ سعيد بن جُبَير عن المحروم، فلم يَقُلْ فيه شيئًا. قال: وقال عطاء: هو المحدود{16} المُحارَف{17}. (١٣/٦٧٧) ٧٨٨٤٠- عن إبراهيم النَّخَعي -من طريق منصور- قال: المحروم: الذي لا فَيء له في الإسلام، وهو مُحارَف في الناس{13}. (ز) ٧٨٨٤١- عن سعيد بن المسيّب -من طريق قتادة بن دعامة-: المحروم: المُحارَف{17}. (ز) ٧٨٨٤٢- عن الحسن بن محمد: أنّ النبي ﷺ بَعثَ سَرِيّة، فغنموا، وفُتح عليهم، فجاء قومٌ لم يشهدوا، فنَزلت: <q>﴿والَّذِينَ فِي أمْوالِهِمْ حَقٌّ مَعْلُومٌ لِلسّائِلِ والمَحْرُومِ﴾</q> يعني: هؤلاء{1}. (ز) ٧٨٨٤٣- عن مجاهد بن جبر -من طريق ابن أبى نجيح- قال: المحروم: الذي لا يُهدى له شيء، وهو مُحارَف{17}. (ز) ٧٨٨٤٤- عن عكرمة مولى ابن عباس -من طريق حُصَيْن- قال: قال: السائل: الذي يسألك. والمَحْرُوم: الذي لا يَنمِي له مال{1}. (ز) ٧٨٨٤٥- عن عكرمة مولى ابن عباس -من طريق حُسين بن قيس- قال: المحروم: الرجل كانت له مَعيشة، فأُصيب بها{23}. (ز) ٧٨٨٤٦- عن عامر الشعبي -من طريق ابن عَوْن- قال: أعياني أنْ أعلم ما المحروم{14}٦٨٠٤. (ز) ٦٨٠٤ علَّق ابنُ عطية (٨/٤٠٨) على قول الشعبي بقوله: «يرحم الله الشعبي فإنه في هذه المسألة محروم، ولو أخذه اسم جنس فيمن عسُرت مطالبه بان له، وإنما كان يطلبه نوعًا مخصوصًا كالسائل». ٧٨٨٤٧- عن خالد بن أبي عمران، عن القاسم [بن محمد]= (ز) ٧٨٨٤٨- وسالم [بن عبد الله بن عمر] في قول الله: قالا: المحروم مُحارَف في الرزق والتجارة{25}. (ز) ٧٨٨٤٩- قال الحسن البصري: <q>﴿لِلسّائِلِ والمَحْرُومِ﴾</q>، السائل: المسكين الذي يسأل عند الحاجة. والمَحْرُوم: الفقير الذي لا يَسأل على حال، فحُرم أن يُعطى عن المسألة كما يُعطى السائل، وإنْ أُعطي شيئًا قَبل{26}. (ز) ٧٨٨٥٠- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿لِلسّائِلِ والمَحْرُومِ﴾</q>، قال: السائل: الذي يسأل بكَفّه. والمَحْرُوم: المُتعفِّف، ولكليهما عليك حقٌّ، يا ابن آدم{14}. (ز) ٧٨٨٥١- عن نافع -من طريق أيوب- قال: المحروم: هو المُحارَف{13}. (ز) ٧٨٨٥٢- عن زياد بن أبي مريم -من طريق خُصَيف- في قوله: <q>﴿والمحروم﴾</q>: الذي لم يُبسَط له في المَعيشة، ولم يُعط باب المسألة{8}. (ز) ٧٨٨٥٣- قال مقاتل بن سليمان: <q>﴿والَّذِينَ فِي أمْوالِهِمْ حَقٌّ مَعْلُومٌ﴾</q> يعني: مفروض <q>﴿لِلسّائِلِ﴾</q> يعني: المسكين <q>﴿والمَحْرُومِ﴾</q> يعني: الفقير الذي لا سهم له في الخُمس ولا الفَيء{30}. (ز) ٧٨٨٥٤- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿والمَحْرُومِ﴾</q>، قال: المحروم: المُصاب ثمره وزَرْعه. وقرأ: <q>﴿أفَرَأَيْتُمْ ما تَحْرُثُونَ أأَنْتُمْ تَزْرَعُونَهُ﴾</q> حتى بَلغ: <q>﴿مَحْرُومُونَ﴾</q> [الواقعة:٦٣-٦٧]. وقال أصحاب الجنة: <q>﴿إنّا لَضالُّونَ بَلْ نَحْنُ مَحْرُومُونَ﴾</q> [القلم:٢٦-٢٧]{14}٦٨٠٥. (ز) ٦٨٠٥ ذكر ابنُ عطية (٨/٤٠٨) في المحروم أقوالًا: الأول: مَن احترق زَرْعه. الثاني: مَن ماتتْ ماشيته. وعلَّق عليهما بقوله: «وهذه أنواع الحرمان، لا أنّ الاسم يلزم هذا خاصّة». الثالث: أنه الكلب. ونسبه لعمر بن عبد العزيز. ووجّهه بقوله: «أراد -والله أعلم- أن يُعطي مثالًا من الحيوان ذي الكبد الرّطبة لما فيه من الأجر حسب الحديث المأثور». ",footnotes:1:أخرجه ابن جرير ٢٣/٢٧٤.أخرجه الطبراني في الأوسط ٥/١٠٧-١٠٨ (٤٨١٣)، والثعلبي ٩/١١٣. وعزاه السيوطي إلى ابن مردويه. والآية وردت في المصدر دون واو في أولها. قال الطبراني: «لم يرو هذا الحديث عن أنس إلا الحارث بن النعمان». وقال المنذري في الترغيب والترهيب ١/٣٠٦-٣٠٧ (١١٣٣): «من رواية الحارث بن النعمان؛ قال أبو حاتم: ليس بقوي. وقال البخاري: منكر الحديث». وقال الهيثمي في المجمع ٣/٦٢ (٤٣٢٥): «رواه الطبراني في الصغير والأوسط، فيه الحارث بن النعمان، وهو ضعيف». وقال المناوي في التيسير ٢/٤٨٤: «إسناد ضعيف».أخرجه ابن جرير ٢٣/٢٧٠.أخرجه ابن جرير ٢٣/٢٧٠.عزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ٢٣/٢٧١.أخرجه ابن جرير ٢٣/٢٧٠.أخرجه سعيد بن منصور في سننه -التفسير ٨/١٦٨ (٢٢٩٨).أخرجه عبد الله بن وهب في الجامع - تفسير القرآن ٣/٨٦ (١٨٦).أخرجه ابن جرير ٢٣/٢٧٠.أخرجه ابن جرير ٢٣/٢٧٠.تقدمت الآثار في تفسير الآية عند نظيرها قوله تعالى: <q>﴿وفِي أمْوالِهِمْ حَقٌّ لِلسّائِلِ والمَحْرُومِ﴾</q> [الذاريات:١٩]، قال ابن جرير ٢٣/٢٧١: «واختلفوا أيضًا في معنى المحروم في هذا الموضع نحو اختلافهم فيه في الذاريات، وقد ذكرنا ما قالوا فيه هنالك، ودلّلنا على الصحيح منه عندنا، غير أنّا نذكر بعض ما لم نذكر من الأخبار هنالك». ثم ذكر بعض ما ذكر أعلاه.أخرجه ابن جرير ٢٣/٢٧٣.أخرجه ابن جرير ٢٣/٢٧٥.أخرجه ابن جرير ٢٣/٢٧١، ٢٧٢، ٢٧٣، ومن طريق مجاهد، وعلي، وسعيد بنحوه.يقال: فلان مَجْدُود، وفلان مَحْدُود، والمجدود الذي يوافقه الجد، والمحدود المحروم. تفسير العلامة السمعاني ٦/٤٨.أخرجه ابن جرير ٢٣/٢٧٢.أخرجه ابن جرير ٢٣/٢٧٣.أخرجه ابن جرير ٢٣/٢٧٢.أخرجه ابن جرير ٢٣/٢٧٤.أخرجه ابن جرير ٢٣/٢٧٢.أخرجه ابن جرير ٢٣/٢٧٤.أخرجه سعيد بن منصور في سننه -التفسير ٨/١٦٩ (٢٣٠٠).أخرجه ابن جرير ٢٣/٢٧٥.أخرجه عبد الله بن وهب في الجامع - تفسير القرآن ٣/٨٦ (١٨٦). وتقدم بتمامه في النسخ في الآية السابقة.ذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٥/٣٦.أخرجه ابن جرير ٢٣/٢٧٥.أخرجه ابن جرير ٢٣/٢٧٣.أخرجه سعيد بن منصور في سننه -التفسير ٨/١٦٨ (٢٢٩٨).تفسير مقاتل بن سليمان ٤/٤٣٧.أخرجه ابن جرير ٢٣/٢٧٥.
  70,25,""
70,26," <q>﴿وَٱلَّذِینَ یُصَدِّقُونَ بِیَوۡمِ ٱلدِّینِ ۝٢٦ وَٱلَّذِینَ هُم مِّنۡ عَذَابِ رَبِّهِم مُّشۡفِقُونَ ۝٢٧ إِنَّ عَذَابَ رَبِّهِمۡ غَیۡرُ مَأۡمُونࣲ ۝٢٨﴾</q> - تفسير ٧٨٨٥٥- قال مقاتل بن سليمان: <q>﴿والَّذِينَ يُصَدِّقُونَ بِيَوْمِ الدِّينِ﴾</q> يعني به: الحساب؛ بأنه كائن، <q>﴿والَّذِينَ هُمْ مِن عَذابِ رَبِّهِمْ مُشْفِقُونَ﴾</q> يعني: وجِلين أن يُصيبهم، <q>﴿إنَّ عَذابَ رَبِّهِمْ غَيْرُ مَأْمُونٍ﴾</q> يقول: لا يأمنون العذاب من الشَّفقة والخوف{1}. (ز) ",footnotes:1:تفسير مقاتل بن سليمان ٤/٤٣٧-٤٣٨.
