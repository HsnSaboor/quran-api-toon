quran[9]{c,v,t}:
  11,63,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿قَالَ یَـٰقَوۡمِ أَرَءَیۡتُمۡ إِن كُنتُ عَلَىٰ بَیِّنَةࣲ مِّن رَّبِّی وَءَاتَىٰنِی مِنۡهُ رَحۡمَةࣰ فَمَن یَنصُرُنِی مِنَ ٱللَّهِ إِنۡ عَصَیۡتُهُۥۖ فَمَا تَزِیدُونَنِی غَیۡرَ تَخۡسِیرࣲ ۝٦٣﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٥٨٠٤<span class="dash">-</span></span> قال <span class="name-1">عبد الله بن عباس</span>: غير خسارة في خسارتكم{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٨٠٥<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- <span class="qpc-hafs">﴿فما تزيدونني غير تخسير﴾</span>، يقول: ما تزدادون أنتم إلا خسارًا{2}. (٨/٨٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٨٠٦<span class="dash">-</span></span> عن <span class="name-2">عطاء الخراساني</span> -من طريق عثمان بن عطاء- <span class="qpc-hafs">﴿فما تزيدونني غير تخسير﴾</span>، قال: ما تزيدونني إلا شَرًّا وخُسرانًا لكم تخسرونه{3}. (٨/٨٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٨٠٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿قالَ﴾</span> صالح: <span class="qpc-hafs">﴿يا قَوْمِ أرَأَيْتُمْ إنْ كُنْتُ عَلى بَيِّنَةٍ مِن رَبِّي﴾</span> يعني: على بَيان مِن ربي، <span class="qpc-hafs">﴿وآتانِي مِنهُ رَحْمَةً﴾</span> يقول: أعطاني نِعمةً مِن عنده، وهو الهُدى، <span class="qpc-hafs">﴿فَمَن يَنْصُرُنِي﴾</span> يعني: فمَن يمنعني <span class="qpc-hafs">﴿مِنَ اللَّهِ إنْ عَصَيْتُهُ﴾</span> يعني: إن رجعتُ إلى دينكم، لقولهم: صالح قد كنت فينا مرجو قبل هذا الذي تدعونا إليه. <span class="qpc-hafs">﴿فَما تَزِيدُونَنِي غَيْرَ تَخْسِيرٍ﴾</span> يقول: فما تزيدونني إلا خسارًا{4}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير الثعلبي ٥/١٧٦، وتفسير البغوي ٤/١٨٦.أخرجه ابن جرير ١٢/٤٥٥. وعزاه السيوطي إلى أبي الشيخ.أخرجه ابن أبي حاتم ٦/٢٠٤٩. وعزاه السيوطي إلى أبي الشيخ.تفسير مقاتل بن سليمان ٢/٢٨٨-٢٨٩.
  11,64,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَیَـٰقَوۡمِ هَـٰذِهِۦ نَاقَةُ ٱللَّهِ لَكُمۡ ءَایَةࣰۖ فَذَرُوهَا تَأۡكُلۡ فِیۤ أَرۡضِ ٱللَّهِۖ وَلَا تَمَسُّوهَا بِسُوۤءࣲ فَیَأۡخُذَكُمۡ عَذَابࣱ قَرِیبࣱ ۝٦٤﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٥٨٠٨<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ويا قَوْمِ هَذِهِ ناقَةُ اللَّهِ لَكُمْ آيَةً﴾</span> يعني: عِبْرَة، <span class="qpc-hafs">﴿فَذَرُوها تَأْكُلْ فِي أرْضِ اللَّهِ﴾</span> لا تُكَلِّفكم مُؤْنَةً ولا عَلَفًا، <span class="qpc-hafs">﴿ولا تَمَسُّوها بِسُوءٍ﴾</span> يقول: ولا تصيبوها بعَقْرٍ؛ <span class="qpc-hafs">﴿فَيَأْخُذَكُمْ﴾</span> في الدنيا <span class="qpc-hafs">﴿عَذابٌ قَرِيبٌ﴾</span> منكم، لا تُمْهَلون حتى تُعَذَّبوا{1}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٢/٢٨٩. وقد تقدمت آثار قصة ثمود مطولة في سورة الأعراف، وأورد ابن جرير وابن أبي حاتم كثيرًا منها في هذه السورة، واكتفينا هنا بإيراد ما لم يرد في سورة الأعراف.
  11,65,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿فَعَقَرُوهَا فَقَالَ تَمَتَّعُوا۟ فِی دَارِكُمۡ ثَلَـٰثَةَ أَیَّامࣲۖ ذَ ٰ⁠لِكَ وَعۡدٌ غَیۡرُ مَكۡذُوبࣲ ۝٦٥﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٥٨٠٩<span class="dash">-</span></span> عن أبي الطُّفَيْل، قال: لَمّا غزا رسولُ الله ﷺ غزوة تبوك نزل الحِجْر، فقال: «<b>يا أيها الناس، لا تسألوا نبيَّكم الآياتِ، هؤلاء قومُ صالح سألوا نبيَّهم أن يبعث لهم آيةً، فبعث الله لهم الناقة آيةً، فكانت تَلِجُ عليهم يوم وُرُودِهم الذي كانوا يَتَرَوَّوْنَ منه، ثم يحلبونها مثل ما كانوا يَتَرَوَّوْن مِن مائهم قبل ذلك لَبَنًا، ثم تخرج مِن ذلك الفَجِّ، فعَتَوْا عن أمر ربِّهم وعقروها، فوعدهم اللهُ العذابَ بعد ثلاثة أيام، وكان وعدًا مِن الله غير مكذوب، فأهلك اللهُ مَن كان منهم في مشارق الأرض ومغاربها إلا رجلًا واحدًا كان في حرم الله، فمنعه حرمُ الله مِن عذاب الله</b>». قالوا: ومن ذلك الرجل، يا رسول الله؟ قال: «<b>أبو رغال</b>»{1}<span class=comment-ref>٣٢٤٤</span>. (٦/٤٦١) (ز)</p></p><p></div></p><p><div><span class=comment-ref>٣٢٤٤</span> <span class="comment-type-4">ذكر</span> <u>ابنُ عطية</u> (٤/٦٠٤) نحو هذا الأثر، ثم <span class="comment-type-2">انتقده</span> <span class="mustanad">بدلالة التاريخ</span> قائلًا: «وفي هذا نظر، وخلافه في السِّيَر».</div></p><p><div></p><p><p><span class="item-no">٣٥٨١٠<span class="dash">-</span></span> قال <span class="name-1">عبد الله بن عباس</span> -من طريق قتادة-: لو صعدتم القارَةَ لَرَأَيْتُم عِظام الفَصِيل. وكانت منازلُ ثمودٍ بحِجْرٍ، بين الشام والمدينة{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٨١١<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق مَعْمَر- <span class="qpc-hafs">﴿تمتعوا في داركم ثلاثة أيام﴾</span>، قال: بقيَّة آجالهم{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٨١٢<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد بن بشير- قوله: <span class="qpc-hafs">﴿تمتعوا في داركم ثلاثة أيام ذلك وعد غير مكذوب﴾</span>، قال: القومُ إلى آجالهم، وهو عليهم غضبان، فواللهِ، ما عجَّل إليهم أن وفّاهم بَقِيَّة آجالهم{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٨١٣<span class="dash">-</span></span>  عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- قال: ذُكِر لنا: أنّ نبي الله ﷺ لَمّا مَرَّ بوادي ثمود وهو عامِد إلى تبوك قال: فأمر أصحابه أن يُسْرِعوا السيرَ، وأن لا ينزِلوا به، ولا يشربوا مِن مائه، وأخبرهم أنّه وادٍ ملعون. قال: وذُكِر لنا: أنّ الرَّجُل المُوسِر مِن قوم صالح كان يُعطي المُعْسِر منهم ما يَتَكَفَّنون به، وكان الرجل منهم يلحد لنفسه، ولأهل بيته؛ لميعاد نبيِّ الله صالح الذي وعدهم، وحدَّث مَن رآهم بالطُّرُق والأَفْنِيَة والبيوت فيهم شبان وشيوخ، أبقاهم اللهُ عِبْرَةً وآية{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٨١٤<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- قوله: <span class="qpc-hafs">﴿فعقروها فقال تمتعوا في داركم ثلاثة أيام ذلك وعد غير مكذوب﴾</span>، وذُكِر لنا: أنّ صالحًا حين أخبرهم أنّ العذاب أتاهم لَبِسُوا الأنطاع والأكْسِيَة، وقيل لهم: إنّ آيةَ ذلك أن تَصْفَرَّ ألوانُكم أوَّلَ يوم، ثم تَحْمَرَّ في اليوم الثاني، ثم تَسْوَدَّ في اليوم الثالث. وذُكِر لنا: أنّهم لَمّا عَقَروا الناقة نَدِموا، وقالوا: عليكم الفصيلَ. فصَعِد الفَصِيلُ القارَةَ –والقارة: الجبل-، حتى إذا كان اليوم الثالث استقبل القبلة، وقال: يا ربِّ، أُمِّي، يا رَبِّ، أُمِّي، يا رَبِّ، أُمِّي. ثلاثًا. قال: فأُرْسِلَتِ الصيحةُ عند ذلك{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٨١٥<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد بن بشير-: أنّ صالحا قال لقومه: إنّ آية ذلك أن تُصْبِح وجوهُكم أولَ يوم مُصْفَرَّة، واليوم الثاني مُحْمَرَّة، واليوم الثالث مُسْوَدَّة. قال: فخَدُّوا لهم أُخْدُودًا، وكَفَرَ{7} غنيُّهم فقيرَهم، فأرسل الله عليهم صيحةً، فأهْمَدَتْهم، قال الله: <span class="qpc-hafs">﴿كأن لم يغنوا فيها﴾</span>{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٨١٦<span class="dash">-</span></span> عن <span class="name-3">عبد الملك ابن جريج</span>، في قوله: <span class="qpc-hafs">﴿ثلاثة أيام﴾</span>، قال: كان بَقِيَ مِن أجل قومِ صالح عند عَقْرِ الناقة ثلاثةُ أيام، فلم يُعَذَّبوا حتى أكملوها{9}. (٨/٨٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٨١٧<span class="dash">-</span></span> عن <span class="name-3">عبد الملك ابن جُرَيْج</span> -من طريق حجّاج- قال: حُدِّثْتُ: أنّه لَمّا أخذتهم الصيحةُ أهْلَكَ اللهُ مِن بين المشارق والمغارب منهم إلا رجلًا واحدًا كان في حَرَمِ الله، مَنَعَهُ حرمُ الله مِن عذاب الله. قيل: ومَن هُو، يا رسول الله؟ قال: «<b>أبو رغال</b>». وقال رسول الله ﷺ حين أتى على قرية ثمود لأصحابه: «<b>لا يَدْخُلَنَّ أحدٌ منكم القريةَ، ولا تشربوا مِن مائهم</b>». وأراهم مُرْتَقى الفصيلِ حين ارتقى في القارَة{10}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٨١٨<span class="dash">-</span></span> عن <span class="name-3">محمد بن إسحاق</span> -من طريق سلمة- قال: رصدوا الناقة حين صَدَرَت عن الماء، وقد كَمَنَ{11} لها قُدارٌ في أصل الصَّخْرَةِ على طريقها، وكَمَنَ لها مِصْدَعٌ في أصْلِ أُخرى، فمَرَّت على مِصْدَع، فرماها بسَهْمٍ، فانتَظَمَ بِه عَضَلَة ساقِها. قال: فشَدَّ -يعني: قدار- على الناَّقة بالسيف، فكشف عرقوبها، فخرَّتْ، ورَغَتْ رُغاةً واحِدة، فَحُتِرَتْ ساقَيْها، ثم طَعَن في لَبَّتِها{12} فنحرها. وانطلق سَقْبُها{13} حتى أتى جبلًا، ثم أتى صخرة في رأس الجبل، فرَغا، ثم لاذ بها، فأتاهم صالحٌ، فلمّا رأى الناقةَ عُقِرَت بكى، ثم قال: انتَهَكْتُم حُرْمَةَ اللهِ! فأبشِرُوا بعذاب اللهِ ونقمته. وأتبع السَّقْبَ أربعةُ نفرٍ مِن التِّسعة الذين عقروا الناقة، ولما قال لهم صالح: أبِشروا بعذاب الله ونقمته. قالوا وهم يهزَؤون به: ومن ذلك، يا صالح؟ وما آيةُ ذلك؟ وكانوا يُسَمُّون الأيام فيهم: الأحدَ أوَّلَ، والاثنين أهونَ، والثلاثاء دُبار، والأربعاء جُبار، والخميس مُؤْنِس، والجمعة العَروبة، والسبتَ شِيارَ، وكانوا عقروا الناقة يوم الأربعاء، فقال لهم صالِحٌ حين قالوا له ذلك: تُصْبِحون غدًا يوم مؤنس -يعني: الخميس- وجوهُكم مُصْفَرَّة، وتُصْبِحُون يومَ العروبة -يعني: الجمعة- ووجوهُكم مُحْمَرَّة، ثم تُصْبِحُون يوم شيار -يعني: السبت- ووجوهكم مُسْوَدَّة، ثم يُصَبِّحُكُم العذابُ يوم الأول -يعني: يوم الأحد-{14}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٨١٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فَعَقَرُوها﴾</span> ليلة الأربعاء بالسَّيْف، فماتت، فقال لهم صالح: <span class="qpc-hafs">﴿تَمَتَّعُوا فِي دارِكُمْ﴾</span> يعني: محلتكم في الدنيا <span class="qpc-hafs">﴿ثَلاثَةَ أيّامٍ ذَلِكَ﴾</span> العذابُ <span class="qpc-hafs">﴿وعْدٌ﴾</span> مِن الله <span class="qpc-hafs">﴿غَيْرُ مَكْذُوبٍ﴾</span> ليس فيه كذب بأنّ العذاب نازِل بهم بعد ثلاثة الأيام{15}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ١٢/٤٦٣-٤٦٤، من طريق إسماعيل بن المتوكل الأشجعي، عن محمد بن كثير، عن عبد الله بن واقد، عن عبد الله بن عثمان بن خثيم، عن أبي الطفيل به.</p><p>قال الشيخ أحمد شاكر في تعليقه على تفسير الطبري ١٥/٣٨٠: «محمد بن كثير، كأنّه محمد بن كثير بن أبي عطاء الثقفي المصيصي الصنعاني، وهو ضعيف جدًّا».أخرجه عبد الرزاق ١/٣٠٥ بلفظ: «لو صعدتم على القارة لرأيتم عظام الفصيل»، وابن جرير ١٢/٤٥٧.أخرجه عبد الرزاق ١/٣٠٥، وابن جرير ١٢/٤٥٧.أخرجه ابن أبي حاتم ٦/٢٠٥٠.أخرجه ابن جرير ١٢/٤٦٣.أخرجه ابن جرير ١٢/٤٥٦.أي: جحد. لسان العرب (كفر).أخرجه ابن أبي حاتم ٦/٢٠٥١.عزاه السيوطي إلى أبي الشيخ.أخرجه ابن جرير في تاريخه ١/٢٣١، وفي تفسيره ١٢/٤٦٢-٤٦٣.أي: استتر واستخفى. النهاية (كمن).اللَبَّة: هي الهَزْمة التي فوق الصدر، وفيها تُنحر الإبل. النهاية (لبب).السَّقْبُ: ولد الناقة. تاج العروس (سقب).أخرجه ابن أبي حاتم ٦/٢٠٥١. وتقدم بتمامه مطولًا جدًّا من قول يعقوب بن عتبة بن المغيرة بن الأخنس من طريق ابن إسحاق، وذلك في سورة الأعراف.تفسير مقاتل بن سليمان ٢/٢٨٩.
  11,66,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿فَلَمَّا جَاۤءَ أَمۡرُنَا نَجَّیۡنَا صَـٰلِحࣰا وَٱلَّذِینَ ءَامَنُوا۟ مَعَهُۥ بِرَحۡمَةࣲ مِّنَّا وَمِنۡ خِزۡیِ یَوۡمِىِٕذٍۚ إِنَّ رَبَّكَ هُوَ ٱلۡقَوِیُّ ٱلۡعَزِیزُ ۝٦٦﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٥٨٢٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق الكلبي، عن أبي صالح- قال: <span class="qpc-hafs">﴿فلما جاء أمرنا نجينا صالحا والذين آمنوا معه برحمة منا﴾</span>، يقول: بنِعْمَةٍ مِنّا{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٨٢١<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق مَعْمَر- في قوله: <span class="qpc-hafs">﴿نجينا صالحًا والذين آمنوا﴾</span> الآية، قال: نجّاه الله برحمة منه، ونجّاه مِن خزي يومئذ{2}. (٨/٨٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٨٢٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: فأهلكهم الله صبيحةَ يوم الرابع يومَ السبت، فذلك قوله: <span class="qpc-hafs">﴿فَلَمّا جاءَ أمْرُنا﴾</span> يعني: قولنا في العذاب <span class="qpc-hafs">﴿نَجَّيْنا صالِحًا والَّذِينَ آمَنُوا مَعَهُ بِرَحْمَةٍ مِنّا﴾</span> يعني: بنعمة عليهم مِنّا، <span class="qpc-hafs">﴿ومِن خِزْيِ يَوْمِئِذٍ﴾</span> يعني: ونجَّيناهم مِن عذاب يومئذ، <span class="qpc-hafs">﴿إنَّ رَبَّكَ هُوَ القَوِيُّ﴾</span> في نَصْرِ أوليائه، <span class="qpc-hafs">﴿العَزِيزُ﴾</span> يعني: المنيع في مُلْكِه وسُلْطانِه حين أهلكهم{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٨٢٣<span class="dash">-</span></span> عن <span class="name-3">محمد بن إسحاق</span> -من طريق سلمة بن الفضل- قال: حتى إذا كان ليلة الأحد خرجَ صالحٌ ومَن معه مِن بين أظهرُهم ومَن أسلم معه إلى الشام، فنَزَل رَمْلَةَ{4} فلسطين{5}<span class=comment-ref>٣٢٤٥</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٣٢٤٥</span> <span class="comment-type-4">ذكر</span> <u>ابنُ عطية</u> (٤/٦٠٣) أنّ قوله: <span class="qpc-hafs">﴿بِرَحْمَةٍ مِنّا﴾</span> يحتمل احتمالين: <b>الأول</b>: أن يقصد: أنّ التنجية إنما كانت بمجرد الرحمة. <b>الثاني</b>: أن يكون وصف حال فقط، أخبر أنه رحمهم في حال التنجية. ثم قال: «وقوله: <span class="qpc-hafs">﴿مِنّا﴾</span> الظاهرُ أنه متعلق برحمة، ويحتمل أن يتعلق بقوله: <span class="qpc-hafs">﴿نَجَّيْنا﴾</span>».</div></p></div>",footnotes:1:أخرجه ابن أبي الدنيا في كتاب العقوبات -موسوعة الإمام ابن أبي الدنيا ٤/٤٦١ (١٤٠)-.أخرجه عبد الرزاق ١/٣٠٥، وابن جرير ١٢/٤٥٨.تفسير مقاتل بن سليمان ٢/٢٨٩.رملة فلسطين: بينها وبين البيت المقدس ثمانية عشر يومًا. معجم البلدان ٣/٦٩.أخرجه ابن أبي حاتم ٦/٢٠٥١.
  11,67,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَأَخَذَ ٱلَّذِینَ ظَلَمُوا۟ ٱلصَّیۡحَةُ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٥٨٢٤<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق الكلبي، عن أبي صالح- قال: أخذتهم الصيحة، والصيحة: صاعِقَةٌ، وكلُّ عذاب الله فهو صاعقة، فاحترقوا جميعًا{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٨٢٥<span class="dash">-</span></span> قال <span class="name-2">إسماعيل السُّدِّيّ</span>: <span class="qpc-hafs">﴿وأخذ الذين ظلموا الصيحة﴾</span>، يعني: صيحة جبريل ﵇{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٨٢٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وأَخَذَ الَّذِينَ ظَلَمُوا﴾</span> يعني: الذين أشركوا <span class="qpc-hafs">﴿الصَّيْحَةُ﴾</span> صيحة جبريل ﵇{3}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿فَأَصۡبَحُوا۟ فِی دِیَـٰرِهِمۡ جَـٰثِمِینَ ۝٦٧﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٥٨٢٧<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق الكلبي، عن أبي صالح- <span class="qpc-hafs">﴿فَأَصْبَحُوا فِي دِيارِهِمْ جاثِمِينَ﴾</span>: قد صاروا رَمادًا، فَهَمَدُوا جُثُومًا لا يَتَحَرَّكون، فشَبَّههم بالرَّماد، حتى صاروا رمادًا{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٨٢٨<span class="dash">-</span></span> عن <span class="name-2">أبي مالك غَزْوان الغِفاري</span> -من طريق إسماعيل السدي- قال: <span class="qpc-hafs">﴿في ديارهم﴾</span>، يعني: بيوتهم{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٨٢٩<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿فأصبحوا في ديارهم جاثمين﴾</span>، يقول: أصبحوا قد هلكوا{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٨٣٠<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق مَعْمَر- في قوله تعالى: <span class="qpc-hafs">﴿فأصبحوا في ديارهم جاثمين﴾</span>، قال: مَيِّتين{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٨٣١<span class="dash">-</span></span> قال <span class="name-2">إسماعيل السُّدِّيّ</span>: <span class="qpc-hafs">﴿فأصبحوا في ديارهم جاثمين﴾</span>، أي: قد هلكوا{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٨٣٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فَأَصْبَحُوا فِي دِيارِهِمْ جاثِمِينَ﴾</span>، يعني: في منازلهم خامِدين{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٨٣٣<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق أصبغ- في قوله: <span class="qpc-hafs">﴿فأصبحوا في ديارهم جاثمين﴾</span>، قال: مَيِّتين{10}. (٨/٨٨)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن أبي الدنيا في كتاب العقوبات -موسوعة الإمام ابن أبي الدنيا ٤/٤٦١ (١٤٠)-.ذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٢/٢٩٨-.تفسير مقاتل بن سليمان ٢/٢٨٩.أخرجه ابن أبي الدنيا في كتاب العقوبات -موسوعة الإمام ابن أبي الدنيا ٤/٤٦١ (١٤٠)-.أخرجه ابن أبي حاتم ٦/٢٠٥٢.أخرجه ابن جرير ١٢/٤٦٤، وابن أبي حاتم ٦/٢٠٥٢.أخرجه عبد الرزاق ١/٣٠٥.ذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٢/٢٩٨-.تفسير مقاتل بن سليمان ٢/٢٨٩.أخرجه ابن أبي حاتم ٥/١٥١٦ (٨٦٨٩).
  11,68,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿كَأَن لَّمۡ یَغۡنَوۡا۟ فِیهَاۤۗ أَلَاۤ إِنَّ ثَمُودَا۟ كَفَرُوا۟ رَبَّهُمۡۗ أَلَا بُعۡدࣰا لِّثَمُودَ ۝٦٨﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٥٨٣٤<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق الضحاك- <span class="qpc-hafs">﴿كأن لم يغنوا فيها﴾</span>، قال: كأن لم يُعَمَّروا فيها{1}. (٨/٨٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٨٣٥<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- في قوله: <span class="qpc-hafs">﴿كأن لم يغنوا فيها﴾</span>، قال: كأن لم يعيشوا فيها{2}. (٨/٨٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٨٣٦<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد-، بمثله{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٨٣٧<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>: أنّ نافع بن الأزرق قال له: أخبِرني عن قوله ﷿: <span class="qpc-hafs">﴿كأن لم يغنوا فيها﴾</span>. قال: كأن لم يكونوا فيها -يعني: في الدنيا- حين عُذِّبوا، ولم يَعمُروا فيها. قال: وهل تعرف العرب ذلك؟ قال: نعم، أما سمعتَ لَبيد بن ربيعة وهو يقول:</p><p>وغَنِيتُ سَبْتًا{4} قبل مَجرى داحِسٍ{5} لو كان للنفس اللَّجُوج خلودُ{6}. (٨/٨٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٨٣٨<span class="dash">-</span></span> عن <span class="name-2">أبي مالك غزوان الغفاري</span>، قال: كأن لم يكونوا فيها{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٨٣٩<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- في قوله: <span class="qpc-hafs">﴿كأن لم يغنوا فيها﴾</span>، قال: كأن لم ينعموا فيها{8}. (٨/٨٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٨٤٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿كَأَنْ لَمْ يَغْنَوْا فِيها﴾</span> يقول: كأنّهم لم يكونوا في الدنيا قطُّ، <span class="qpc-hafs">﴿ألا إنَّ ثَمُودَ كَفَرُوا﴾</span> بتوحيد <span class="qpc-hafs">﴿رَبَّهُمْ ألا بُعْدًا لِثَمُودَ﴾</span> في الهلاك{9}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن أبي الدنيا في كتاب العقوبات -موسوعة الإمام ابن أبي الدنيا ٤/٤٦١ (١٤٠)-، وابن أبي حاتم ٦/٢٠٥٢. وعزاه السيوطي إلى أبي الشيخ.أخرجه ابن جرير ١٠/٣٢٦، ١٢/٤٦٥، وابن أبي حاتم ٦/٢٠٥٢.أخرجه ابن جرير ١٢/٤٦٥.السَّبْت: بُرْهة من الدهر. لسان العرب (سبت).داحِسٌ: اسم فرس معروف مشهور. لسان العرب (دحس).أخرجه الطستي -كما في الإتقان ٢/٩٢-. وعزاه السيوطي إلى ابن الأنباري في الوقف والابتداء.علَّقه ابن أبي حاتم ٦/٢٠٥٣.أخرجه ابن أبي حاتم ٦/٢٠٥٣.تفسير مقاتل بن سليمان ٢/٢٨٩.
  11,69,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَلَقَدۡ جَاۤءَتۡ رُسُلُنَاۤ إِبۡرَ ٰ⁠هِیمَ بِٱلۡبُشۡرَىٰ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٥٨٤١<span class="dash">-</span></span> قال <span class="name-1">عبد الله بن عباس</span>: كانوا ثلاثةً: جبرائيل، وميكائيل، وإسرافيل{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٨٤٢<span class="dash">-</span></span> عن <span class="name-2">عطاء</span>: مثله{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٨٤٣<span class="dash">-</span></span> قال <span class="name-2">الضحاك بن مزاحم</span>: تسعة{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٨٤٤<span class="dash">-</span></span> قال <span class="name-2">محمد بن كعب القرظي</span>: كان جبريل، ومعه سبعة{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٨٤٥<span class="dash">-</span></span> قال <span class="name-2">إسماعيل السُّدِّيّ</span>: أحد عشر مَلَكًا، على صورة الغِلمان الوُضّاءِ وُجوهُهُم{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٨٤٦<span class="dash">-</span></span> عن عثمان بن محصن -من طريق نوح بن قيس- في ضيف إبراهيم، قال: كانوا أربعة: جبريل، وميكائيل، وإسرافيل، ورافائيل{6}. (٨/٨٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٨٤٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل</span>: كانوا اثني عشر مَلَكًا{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٨٤٨<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ولَقَدْ جاءَتْ رُسُلُنا﴾</span>، وهو جبريل، ومعه مَلَكان، وهما: مَلَك الموت، وميكائيل{8}<span class=comment-ref>٣٢٤٦</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٣٢٤٦</span> ذكر <u>ابنُ عطية</u> (٤/٦٠٦ بتصرف) روايةً تَنُصُّ على «أنّ جبريل ﵇ كان مختصًّا بإهلاك قرية لوط، وميكائيل ﵇ مختصًّا بتبشير إبراهيم ﵇ بإسحاق ﵇، وإسرافيل ﵇ مختصًّا بإنجاء لوط ﵇ ومَن معه». ثم <span class="comment-type-2">استدرك</span> عليها بقوله: «وهذه الآية تقضي باشتراكهم في البشارة بإسحاق ﵇».</div></p><p><h3><span class="qpc-hafs">﴿بِٱلۡبُشۡرَىٰ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٥٨٤٩<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span> -من طريق داود- يعني قوله: <span class="qpc-hafs">﴿جاءت رسلنا إبراهيم بالبشرى﴾</span>، قال: ... بنُبُوَّته{9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٨٥٠<span class="dash">-</span></span> قال <span class="name-2">قتادة بن دعامة</span>: <span class="qpc-hafs">﴿ولقد جاءت رسلنا إبراهيم بالبشرى﴾</span>: بإسحاق{10}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٨٥١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ولَقَدْ جاءَتْ رُسُلُنا إبْراهِيمَ بِالبُشْرى﴾</span> في الدُّنيا الولد: بإسحاق، ويعقوب{11}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿قَالُوا۟ سَلَـٰمࣰاۖ قَالَ سَلَـٰمࣱۖ﴾</span> - قراءات</h3></p><p><div></p><p><p><span class="item-no">٣٥٨٥٢<span class="dash">-</span></span> عن عبد الرحمن الأعرج، قال: سمعتُ <span class="name-2">مروان</span> يقرأ: ‹قالُواْ سَلامًا قالَ سِلْمٌ›{12}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٨٥٣<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span> أنّه قرأ: ‹قالُواْ سَلامًا قالَ سِلْمٌ›: وكل شيءٍ سلَّمَت عليه الملائكة فقالوا: سلامًا. قال: سِلم{13}. (٨/٨٩)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿قَالُوا۟ سَلَـٰمࣰاۖ قَالَ سَلَـٰمࣱۖ﴾</span> - تفسير الآية</h3></p><p><div></p><p><p><span class="item-no">٣٥٨٥٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿قالُوا سَلامًا﴾</span> قالوا تحيَّةً لإبراهيم، فسلَّموا على إبراهيم، فرَدَّ إبراهيم عليهم، فـ<span class="qpc-hafs">﴿قالَ سَلامٌ﴾</span>. يقول: ردَّ إبراهيمُ خيرًا، وهو يرى أنّهم مِن البَشَر{11}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿فَمَا لَبِثَ أَن جَاۤءَ بِعِجۡلٍ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٥٨٥٥<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- <span class="qpc-hafs">﴿بعجل حنيذ﴾</span>، قال: العِجل: حَسِيل البَقَر{15}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٨٥٦<span class="dash">-</span></span> قال <span class="name-2">قتادة بن دعامة</span>: كان عامَّةُ مالِ إبراهيم البقرَ{16}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٨٥٧<span class="dash">-</span></span> قال <span class="name-2">عون بن أبي شداد</span> -من طريق نوح بن قيس-: إنّه لَمّا دخل على إبراهيم، فقرَّب إليهم العِجْل؛ مسحه جبريلُ بجناحيه، فقام يدرج حتى لحق بأُمِّه، وأُمِّ العِجْل في الدّار{17}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٨٥٨<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فَما لَبِثَ أنْ جاءَ﴾</span> إبراهيمُ <span class="qpc-hafs">﴿بِعِجْلٍ حَنِيذٍ﴾</span> يعني: الحنيذ النضيج، لأنّه كان البَقَرُ أكثرَ أموالهم{11}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿حَنِیذࣲ ۝٦٩﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٥٨٥٩<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- في قوله: <span class="qpc-hafs">﴿بعجل حنيذ﴾</span>، قال: نَضِيج{19}. (٨/٨٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٨٦٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق الضحاك- في قوله: <span class="qpc-hafs">﴿حنيذ﴾</span>، قال: مَشْوِي{9}. (٨/٩٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٨٦١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق مجاهد- في قوله: <span class="qpc-hafs">﴿بعجل حنيذ﴾</span>، قال: سَمِيط{21}. (٨/٩٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٨٦٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>: أنّ نافع بن الأزرق قال له: أخبِرني عن قوله ﷿: <span class="qpc-hafs">﴿بعجل حنيذ﴾</span>. قال: الحنيذُ: النَّضِيج، ما يُشْوى بالحِجارة. قال: وهل تعرف العربُ ذلك؟ قال: نعم، أما سمعت قولَ الشاعر وهو يقول:</p><p>لهم راحٌ وفارُ المسكِ فيهم وشاويهم إذا شاءوا حنيذُ{22}. (٨/٩٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٨٦٣<span class="dash">-</span></span> قال <span class="name-1">عبد الله بن عباس</span>: مَشْوِيٌّ بالحجارة الحارَّة في خَدٍّ{23} مِن الأرض{24}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٨٦٤<span class="dash">-</span></span> عن <span class="name-2">كعب الأحبار</span> -من طريق عبد الله بن رباح- قال: <span class="qpc-hafs">﴿فما لبث أن جاء بعجل حنيذ﴾</span>: نضيج، وهو يَحْسَبُهم أضْيافًا{25}. (٨/٩٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٨٦٥<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نَجِيح- <span class="qpc-hafs">﴿بعجل حنيذ﴾</span>، قال: ... الحنيذ: المشويُّ النَّضِيج{15}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٨٦٦<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن جُرَيْج- قوله: <span class="qpc-hafs">﴿ولقد جاءت رسلنا إبراهيم بالبشرى﴾</span> إلى: <span class="qpc-hafs">﴿بعجل حنيذ﴾</span>، قال: نَضِيجٍ سخنٍ، أُنضِج بالحِجارة{15}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٨٦٧<span class="dash">-</span></span> عن <span class="name-2">الضَّحّاك بن مُزاحِم</span> -من طريق عبيد- في قوله: <span class="qpc-hafs">﴿بعجل حنيذ﴾</span>، قال: الحنيذ: الذي أُنضِج بالحجارة{28}. (٨/٩٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٨٦٨<span class="dash">-</span></span> عن <span class="name-2">وهب بن مُنَبِّه</span> -من طريق عبد الصمد- قال: <span class="qpc-hafs">﴿حنيذ﴾</span>، يعني: شوي{29}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٨٦٩<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد-: <span class="qpc-hafs">﴿فما لبث أن جاء بعجل حنيذ﴾</span>، والحنيذ: النَّضيج{30}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٨٧٠<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- قال: ذبحه، ثُمَّ شواه في الرَّضْفِ{31}، فهو الحنيذ حين شواه{30}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٨٧١<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- قال: الحنيذ: السمين. قال أسباط: وقال غيره: المشويّ الذي خُدَّ له في الأرض خدًا، فشُوي فيه{33}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٨٧٢<span class="dash">-</span></span> عن <span class="name-2">عطاء الخراساني</span> -من طريق عثمان بن عطاء-: وأمّا عِجْلٌ حنيذٌ فيُقال: النَّضِيج السَّخن{9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٨٧٣<span class="dash">-</span></span> عن <span class="name-3">شمر بن عطية</span>، قال: الحنيذ: الذي شُوِي وهو يسيل مِنه الماء{35}. (٨/٩٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٨٧٤<span class="dash">-</span></span> قال <span class="name-3">محمد بن السائب الكلبي</span> -من طريق مَعْمَر-: والحنيذ: الذي يُحنَذُ{36} في الأرض{37}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٨٧٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿بِعِجْلٍ حَنِيذٍ﴾</span> يعني: الحنيذ النَّضِيج؛ لأنّه كان البقر أكثر أموالهم، والحنيذ: الشِّواء الذي أُنضِج بِحَرِّ النار، مِن غير أن تَمَسه النارُ، بالحجارة تُحْمى وتُجْعَل في سِرْبٍ، فتُشْوى{11}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٨٧٦<span class="dash">-</span></span> عن <span class="name-3">محمد بن إسحاق</span> -من طريق سلمة- قال: الحِناذُ: الإنضاج{29}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٨٧٧<span class="dash">-</span></span> عن <span class="name-3">سفيان الثوري</span> -من طريق عبد العزيز- <span class="qpc-hafs">﴿فما لبث أن جاء بعجل حنيذ﴾</span>، قال: مَشْوِيّ{29}<span class=comment-ref>٣٢٤٧</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٣٢٤٧</span> ذكر <u>ابنُ جرير</u> (١٢/٤٦٧-٤٧٠) قولين عن أهل العربية في معنى <span class="qpc-hafs">﴿حنيذ﴾</span>: <b>الأول:</b> المشوي. <b>والثاني:</b> أنّ «كل شيء شوي في الأرض إذا خَدَدتَ له فيها فَدَفَنتَه وغَمَمتَه فهو الحنيذ والمحنوذ». وهذان القولان وردا في الآثار عن الكلبي ومقاتل، ثم ذكر قول ابن عباس من طريق علي بن أبي طلحة، وقول مجاهد، وقتادة، والضحاك، وشِمْر، والسدي، ووهب بن منبه، وابن إسحاق، وسفيان، في معنى هذه الكلمة، ثم <span class="comment-type-4">علَّق</span> على ما سبق بقوله: «وهذه الأقوال التي ذكرناها عن أهل العربية وأهل التفسير متقاربة المعاني، بعضها من بعض».</div></p><p><h3><span class="qpc-hafs">﴿حَنِیذࣲ ۝٦٩﴾</span> - بسط القصة</h3></p><p><div></p><p><p><span class="item-no">٣٥٨٧٨<span class="dash">-</span></span> عن <span class="name-2">وهب بن مُنَبِّه</span> -من طريق عبد الصمد بن معقل-: أنّ إبراهيم ﵇ حين أخرجه قومُه بعدما ألقوه في النار خرج بامرأته سارَة ومعه أخوها لوط، وهما ابنا أخيه، فتوَجَّها إلى أرضِ الشام، ثم بلغوا مصر، وكانت سارةُ مِن أجمل الناس، فلمّا دخلت مصرَ تحدَّث الناسُ بجمالها، وعَجِبوا له، حتى بلغ ذلك المَلِك، فدعا بها، وسأله: ما هو مِنها؟ فخاف إن قال له: زوجها. أن يقتله، فقال: أنا أخوها. فقال: زَوِّجْنِيها. فكان على ذلك حتى بات ليلة، فجاءه حلم فخنقه وخوَّفه، فكان هو وأهلُه في خوف وهولٍ حتى عَلِم أنه قد أُتِي مِن قِبَلِها، فدعا إبراهيمَ، فقال: ما حملك على أن تَغُرَّني؛ زعمتَ أنها أختُك؟ فقال: إنِّي خِفْتُ إن ذكرتُ أنّها زوجتي أن يصيبني منك ما أكره. فوهب لها هاجر أمَّ إسماعيل، وحمَلهم، وجهَّزهم حتى استقر قرارهم على جبل إيليا، فكانوا بها حتى كثرت أموالهم ومواشيهم، فكان بين رِعاءِ إبراهيم ورِعاءِ لوط حوار وقتال، فقال لوط لإبراهيم: إنّ هؤلاء الرِّعاءَ قد فَسَدَ ما بينهم، وكادت تضيق فيهم المراعي، ونخاف ألا تحملنا هذه الأرض، فإن أحببت أن أخِفَّ عنك خففت. قال إبراهيم: ما شئتَ؛ إن شئتَ فانتَقِلْ منها، وإن شئتَ انتقلتُ عنك. قال لوط: لا، بل أنا أحقُّ أن أخِفَّ عنك. ففرَّ بأهله وماله إلى سهل الأردن، فكان بها حتى أغار عليه أهلُ فلسطين، فسَبَوْا أهله وماله، فبلغ ذلك إبراهيم، فأغار عليهم بما كان عنده مِن أهله ورقيقه، وكان عددُهم زيادةً على ثلاثمائة، مَن كان مع إبراهيم، فاستنقذ مِن أهل فلسطين مَن كان معهم من أهل لوط وماله، حتى ردَّهم إلى قرارهم، ثم انصرف إبراهيم إلى مكانه. وكان أهل سدوم الذين فيهم لوط قومٌ قد اسْتَغْنَوْا عن النِّساء بالرجال، فلمّا رأى الله ما كان عند ذلك بعث الملائكةُ ليعذبوهم، فأتوا إبراهيم، فلمّا رآهم راعَه هيئتُهم وجمالهم، فسلَّموا عليه، وجلسوا إليه، فقام لِيُقَرِّب إليهم قِرًى، فقالوا: مكانك. قال: بل دعوني آتيكم بما ينبغي لكم، فإنّ لكم حقًّا، لم يأتِنا أحدٌ أحقُّ بالكرامة منكم. فأمر بعجلٍ سمين، فحُنِذ له -يعني: شُوي لهم-، فقرَّب إليهم الطعام، <span class="qpc-hafs">﴿فلمّا رأى أيديهم لا تصل إليه نكرهم وأوجس منهم خيفة﴾</span>، وسارة وراء الباب تسمع، قالوا: لا تخفْ، إنّا نُبَشِّرُك بغلام عليم مبارك. فبَشَّر به امرأتَه سارة، فضحكت وعَجِبَت: كيف يكون له مِنِّي ولدٌ وأنا عجوزٌ وهو شيخ كبير؟! قالوا: أتعجبين مِن أمر الله! فإنّه قادِرٌ على ما يشاء، وقد وهبه الله لكم، فأبشِروا به. فقاموا وقام معهم إبراهيم، فمشَوا معًا وسألهم، قال: أخبِرُوني لِمَ بُعِثْتُم؟ وما خطبكم؟ قالوا: إنّا أُرسِلنا إلى أهل سدوم لِنُدَمِّرها؛ فإنّهم قومُ سوء، وقد اسْتَغْنَوْا بالرجال عن النساء. قال إبراهيم: إنّ فيها قومًا صالحين، فكيف يصيبهم مِن العذاب ما يصيب أهل عمل السوء؟ قالوا: وكم فيها؟ قال: أرأيتم إن كان فيها خمسون رجلًا صالحًا؟ قالوا: إذن لا نعذبهم. قال: إن كان فيهم أربعون؟ قالوا: إذن لا نعذبهم. فلم يزل ينقص حتى بلغ إلى عشرة، ثم قال: فأهل بيت؟ قالوا: فإن كان فيها بيت صالح. قال: فلوط وأهل بيته؟ قالوا: إنّ امرأته هواها معهم، فكيف يُصرف عن أهل قرية لم يَتِمَّ فيها أهلُ بيت صالحين؟ فلمّا يئِس منهم إبراهيم انصرف ...{41}. (٨/٩٣)</p></p><p></div></p></div>",footnotes:1:تفسير الثعلبي ٥/١٧٧، وتفسير البغوي ٤/١٨٧.تفسير البغوي ٤/١٨٧.تفسير الثعلبي ٥/١٧٧، وتفسير البغوي ٤/١٨٧.تفسير البغوي ٤/١٨٧.تفسير الثعلبي ٥/١٧٧، وتفسير البغوي ٤/١٨٧.أخرجه ابن أبي حاتم ٦/٢٠٥٤.تفسير البغوي ٤/١٨٧.تفسير مقاتل بن سليمان ٢/٢٨٩-٢٩٠.أخرجه ابن أبي حاتم ٦/٢٠٥٣.ذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٢/٢٩٨-.تفسير مقاتل بن سليمان ٢/٢٩٠.أخرجه عبد الله بن وهب في الجامع - تفسير القرآن ٣/٥١ (١٠٧).</p><p>وهي قراءة متواترة، قرأ بها حمزة، والكسائي، وقرأ بقية العشرة: <span class="qpc-hafs">﴿سَلامٌ﴾</span> بفتح السين واللام وألف بعدها. انظر: النشر ٢/٢٩٠، والإتحاف ص٣٢٣.عزاه السيوطي إلى أبي الشيخ.تفسير مقاتل بن سليمان ٢/٢٩٠.أخرجه ابن جرير ١٢/٤٦٨.تفسير البغوي ٤/١٨٨.أخرجه ابن أبي حاتم ٦/٢٠٥٤. وينظر: تفسير ابن كثير ٤/٣٣٣.تفسير مقاتل بن سليمان ٢/٢٩٠.أخرجه ابن جرير ١٢/٤٦٨. عزاه السيوطي إلى ابن المنذر.أخرجه ابن أبي حاتم ٦/٢٠٥٣.أخرجه ابن أبي حاتم ٦/٢٠٥٣.</p><p>وسميط: مشوي. النهاية (سمط).أخرجه الطستي -كما في الإتقان ٢/٩٧-.الخَدُّ والخُدَّة والأُخدود: الحُفرة تحفرُها في الأرض مستطيلة. لسان العرب (خدد).تفسير الثعلبي ٥/١٧٨.أخرجه ابن أبي الدنيا في كتاب العقوبات -موسوعة الإمام ابن أبي الدنيا ٤/٤٦٤ (١٤٩)-. وعزاه السيوطي إلى عبد الله بن أحمد في زوائد الزهد.أخرجه ابن جرير ١٢/٤٦٨.أخرجه ابن جرير ١٢/٤٦٨.أخرجه ابن جرير ١٢/٤٧٠، وابن أبي حاتم ٦/٢٠٥٣. وعزاه السيوطي إلى ابن المنذر، وأبي الشيخ.أخرجه ابن جرير ١٢/٤٧٠.أخرجه ابن جرير ١٢/٤٦٩.الرَّضْف: الحجارة المحماة على النار. النهاية (رضف).أخرجه ابن جرير ١٢/٤٦٩.أخرجه إسحاق البستي ص ٤٢٩.أخرجه ابن أبي حاتم ٦/٢٠٥٣.أخرجه ابن جرير ١٢/٤٦٩، وابن أبي حاتم ٦/٢٠٥٣. وعزاه السيوطي إلى أبي الشيخ.أي: يُشوى على الحجارة المُحماة. لسان العرب (حنذ).أخرجه عبد الرزاق ١/٣٠٥، وابن جرير ١٢/٤٦٩.تفسير مقاتل بن سليمان ٢/٢٩٠.أخرجه ابن جرير ١٢/٤٧٠.أخرجه ابن جرير ١٢/٤٧٠.أخرجه ابن جرير في تاريخه ١/٣٠٤. وعزاه السيوطي إلى ابن المنذر.
  11,70,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿فَلَمَّا رَءَاۤ أَیۡدِیَهُمۡ لَا تَصِلُ إِلَیۡهِ نَكِرَهُمۡ وَأَوۡجَسَ مِنۡهُمۡ خِیفَةࣰۚ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٥٨٧٩<span class="dash">-</span></span> عن <span class="name-1">جندب بن سفيان</span> -من طريق الأسود- قال: لَمّا دخل ضيفُ إبراهيم ﵇ قَرَّب إليهم العِجْل، فجعلوا يَنكُتون{1} بقِداحٍ في أيديهم مِن نَبْلٍ، ولا تصل أيديهم إليه، نكرهم عند ذلك{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٨٨٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق الضحاك- قال: لَمّا رأى إبراهيمُ أنّه لا تصل إلى العِجْل أيديهم نكِرَهم، فخافهم، وإنّما كان خوفُ إبراهيم أنّهم كانوا في ذلك الزمان إذا همَّ أحدهم بامرئٍ سوءًا لم يأكل عنده، يقول: إذا تحرَّمتُ بطعامه حَرُم عَلَيَّ أذاه. فخاف إبراهيمُ أن يريدوا به سوءًا، فاضطربت مفاصِلُه، وامرأتُه سارةُ قائِمَةٌ تخدمهم، وكان إذا أراد أن يُكرِم أضيافه أقام سارة لتخدمهم، فضحِكت سارة، وإنّما ضحكت أنّها قالت: يا إبراهيم، وما تخاف؟ إنما هم ثلاثة نفر وأنت وأهلُك وغلمانُك. قال لها جبريل: أيَّتُها الضاحكة، أما إنّك سَتَلِدين غلامًا يُقال له: إسحاق، ومِن ورائه غلامٌ يُقال له: يعقوب. فأقبلت في صَرَّةٍ فصَكَّت وجهها، فأقبلت والِهَةً تقول: يا ويلتاه. ووضعت يدها على وجهها استحياءً، فذلك قوله: <span class="qpc-hafs">﴿فصكت وجهها﴾</span> [الذاريات:٢٩]. وقالت: <span class="qpc-hafs">﴿ءألد وأنا عجوز وهذا بعلي شيخًا﴾</span>{3}. (٨/٩٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٨٨١<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق مَعْمَر- في قوله: <span class="qpc-hafs">﴿نكرهم﴾</span> الآية، قال: كانوا إذا نزل بهم ضيفٌ فلم يأكل مِن طعامهم ظنُّوا أنّه لم يأت بخير، وأنّه يُحَدِّث نفسَه بِشَرٍّ، ثُمَّ حدَّثوه عند ذلك بما جاءوا فيه، فضحِكت امرأتُه{4}. (٨/٩٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٨٨٢<span class="dash">-</span></span> عن <span class="name-2">عمرو بن دينار</span>، قال: لَمّا تضيَّفت الملائكةُ إبراهيمَ قَدَّم لهم العِجْل، فقالوا: لا نأكلُه إلا بثَمَن. قال: فكُلوا، وأدُّوا ثمنه. قالوا: وما ثمنه؟ قال: تسمُّون اللهَ إذا أكلتم، وتحمدونه إذا فرغتم. قال: فنظر بعضهم إلى بعض، فقالوا: لهذا اتَّخذك اللهُ خليلًا{5}. (٨/٩٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٨٨٣<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السدي</span> -من طريق أسباط- قال: لَمّا بعث اللهُ الملائكةَ لِتُهلِك قومَ لوط أقبلتْ تمشي في صورة رجال شباب، حتى نزلوا على إبراهيم، فتضيَّفوه، فلمّا رآهم أجلَّهم، فراغ إلى أهله، فجاء بعجل سمين، فذبحه، ثم شواه في الرَّضْفِ، فهو الحنيذ حين شُوِي، وأتاهم، فقعد معهم، وقامت سارةُ تخدمهم، فذلك حين يقول: (وامْرَأَتُه قَآئِمَةٌ وهُوَ جالِسٌ) في قراءة ابن مسعود. فلمّا قرَّبه إليهم قال: ألا تأكلون؟ قالوا: يا إبراهيم، إنّا لا نأكل طعامًا إلا بثَمَن. قال: فإنّ لِهذا ثَمَنًا. قالوا: وما ثَمَنُه؟ قال: تذكرون اسمَ الله على أوَّلِه، وتحمدونه على آخره. فنظر جبريل إلى ميكائيل، فقال: حُقَّ لهذا أن يَتَّخِذَه ربُّه خليلًا. <span class="qpc-hafs">﴿فلما رأى أيديهم لا تصل إليه﴾</span> يقول: لا يأكلون؛ فزِع منهم <span class="qpc-hafs">﴿وأوجس منهم خيفة﴾</span>، فلمّا نظرت إليهم سارةُ أنّه قد أكرمهم وقامت هي تخدمهم ضحِكت، وقالتْ: عجبًا لأضيافِنا هؤلاء، إنّا نخدمُهم بأنفسنا تَكرمة لهم وهم لا يأكلون طعامنا!{6}. (٨/٩٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٨٨٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فَلَمّا رَأى أيْدِيَهُمْ لا تَصِلُ إلَيْهِ﴾</span> أي: إلى العِجْل <span class="qpc-hafs">﴿نَكِرَهُمْ﴾</span> يعني: أنكرهم، وخاف شرَّهم، <span class="qpc-hafs">﴿وأَوْجَسَ مِنهُمْ خِيفَةً﴾</span> يقول: فوَقَع عليه الخوفُ منهم، فَرَعَدَ{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٨٨٥<span class="dash">-</span></span> عن أبي يزيد البصري في قوله: <span class="qpc-hafs">﴿فلمّا رأى أيديهم لا تصل إليه﴾</span>، قال: لم ير لهم أيدٍ، فنكِرَهم{8}. (٨/٩٧)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿قَالُوا۟ لَا تَخَفۡ إِنَّاۤ أُرۡسِلۡنَاۤ إِلَىٰ قَوۡمِ لُوطࣲ ۝٧٠﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٥٨٨٦<span class="dash">-</span></span> قال <span class="name-3">[علي بن أبي طلحة] الوالبي</span>: لَمّا عرف إبراهيمُ أنّهم ملائكةٌ خاف أنّه وقومَه المقصودون بالعذاب؛ لأنّ الملائكة كانت تنزل إذ ذاك بالعذاب. [نظير ما في الحجر: <span class="qpc-hafs">﴿ما نُنَزِّلُ المَلائِكَةَ إلّا بِالحَقِّ﴾</span> [الحجر:٨] أي: بالعذاب]. قالت الملائكة: <span class="qpc-hafs">﴿لا تخف إنا أرسلنا إلى قوم لوط﴾</span> لا إلى قومك{9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٨٨٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿قالُوا﴾</span> أي: قالت الملائكة: <span class="qpc-hafs">﴿لا تَخَفْ إنّا أُرْسِلْنا إلى قَوْمِ لُوطٍ﴾</span> بهلاكهم. ولوط ابن حازان، [وامرأتُه] سارة بنت حازان أخت لوط، وإبراهيم عم لوط وخَتَنُه على أخته{7}<span class=comment-ref>٣٢٤٨</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٣٢٤٨</span> ذكر <u>ابنُ عطية</u> (٤/٦١٠) أن امرأة إبراهيم ﵇ سارة هي ابنة عمِّه، ونقل قولًا ولم ينسبه: أنها أخت لوط ﵇، <span class="comment-type-2">واستدرك</span> عليه <span class="mustanad">بدلالة التاريخ</span> بقوله: «وما أظنُّ ذلك إلا أخوة القرابة؛ لأن إبراهيم ﵇ هو عمّ لوط ﵇ فيما روي».</div></p></div>",footnotes:1:أصله من النَّكْتِ بالحصى، ونَكْت الأرض بالقضيب. النهاية (نكت).أخرجه ابن جرير ١٢/٤٧١، وابن أبي حاتم ٦/٢٠٥٤.أخرجه ابن عساكر ٥٠/٣١٠، ٣١٥. وعزاه السيوطي إلى إسحاق بن بشر.أخرجه عبد الرزاق ١/٣٠٥-٣٠٦، وابن أبي حاتم ٦/٢٠٥٤. وعزاه السيوطي إلى ابن المنذر، وأبي الشيخ.عزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ١٢/٤٧٣-٤٧٤، وفي تاريخه ١/٢٤٩-٢٥٠.تفسير مقاتل بن سليمان ٢/٢٩٠.أخرجه ابن أبي حاتم ٦/٢٠٥٤.تفسير الثعلبي ٥/١٧٨. وكأن ما بين الحاصرتين من تعقيبه.تفسير مقاتل بن سليمان ٢/٢٩٠.
  11,71,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَٱمۡرَأَتُهُۥ قَاۤىِٕمَةࣱ فَضَحِكَتۡ فَبَشَّرۡنَـٰهَا بِإِسۡحَـٰقَ وَمِن وَرَاۤءِ إِسۡحَـٰقَ یَعۡقُوبَ ۝٧١﴾</span> - قراءات</h3></p><p><div></p><p><p><span class="item-no">٣٥٨٨٨<span class="dash">-</span></span> عن المغيرة، قال: في مصحف <span class="name-1">ابن مسعود</span>: (وامْرَأَتُهُ قَآئِمَةٌ وهُوَ جالِسٌ){1}. (٨/٩٩)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَٱمۡرَأَتُهُۥ قَاۤىِٕمَةࣱ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٥٨٨٩<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن جريج- <span class="qpc-hafs">﴿وامرأته قائمة﴾</span>، قال: في خِدمة أضياف إبراهيم{2}<span class=comment-ref>٣٢٤٩</span>. (٨/٩٩)</p></p><p></div></p><p><div><span class=comment-ref>٣٢٤٩</span> <span class="comment-type-4">ذكر</span> <u>ابنُ عطية</u> (٤/٦٠٩) هذا القول، ثم <span class="comment-type-4">ذكر</span> في معنى <span class="qpc-hafs">﴿قائمة﴾</span> قولين آخرين: <b>الأول</b>: أنّ: معناه: قائمة خلف ستر تسمع محاورة إبراهيم مع أضيافه. <b>الثاني</b>: أنّ معناه: قائمة في صلاة.</div></p><p><div></p><p><p><span class="item-no">٣٥٨٩٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وامْرَأَتُهُ﴾</span> وهي سارة <span class="qpc-hafs">﴿قائِمَةٌ﴾</span> وإبراهيم جالس{3}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿فَضَحِكَتۡ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٥٨٩١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق ابنه علي- <span class="qpc-hafs">﴿فضحكت﴾</span>، قال: فحاضَتْ، وهي بنت ثمانٍ وتسعين سنة{4}. (٨/٩٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٨٩٢<span class="dash">-</span></span> قال <span class="name-1">عبد الله بن عباس</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٨٩٣<span class="dash">-</span></span> و<span class="name-2">وهب بن مُنَبِّه</span>: ضَحِكَتْ عجبًا مِن أن يكون لها ولدٌ على كِبَر سِنِّها وسِنِّ زوجها{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٨٩٤<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عمر</span>، في قوله: قال: <span class="qpc-hafs">﴿فضحكت﴾</span>: حاضت{6}. (٨/١٠٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٨٩٥<span class="dash">-</span></span> عن <span class="name-2">كعب الأحبار</span> -من طريق عبد الله بن رباح-: <span class="qpc-hafs">﴿إنا أرسلنا إلى قوم لوط* وامرأته قائمة فضحكت﴾</span> بخزي الله إيّاهم{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٨٩٦<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ليث- في قوله: <span class="qpc-hafs">﴿فضحكت﴾</span>، قال: حاضَتْ، وكانت ابنةَ بِضعٍ وتسعين سنة، وكان إبراهيمُ ابنَ مائة سنة{8}. (٨/٩٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٨٩٧<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span>، في قوله: <span class="qpc-hafs">﴿فضحكت﴾</span>، قال: حاضَتْ{9}. (٨/١٠٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٨٩٨<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- قال: لَمّا أوجس إبراهيمُ خِيفَةً في نفسه حدَّثوه عند ذلك بما جاءوا فيه، فضحِكت امرأته تَعَجُّبًا مِمّا فيه قوم لوط مِن الغفلة، ومِمّا أتاهم مِن العذاب{10}. (٨/٩٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٨٩٩<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- قال: لَمّا ضَحِكَتْ سارةُ وقالت: عَجَبًا لأضيافِنا هؤلاء، إنّا نخدمُهم بأنفسنا تَكرِمَةً لهم، وهم لا يأكلون طعامنا! قال لها جبريل: أبشِري بولد اسمه: إسحاق، ومن وراء إسحاق يعقوب. فضربت جبهتها عَجَبًا، فذلك قوله: <span class="qpc-hafs">﴿فصكت وجهها﴾</span> [الذاريات:٢٩]، وقالت: <span class="qpc-hafs">﴿ءألد وأنا عجوز وهذا بعلي شيخًا إن هذا لشيء عجيب* قالوا أتعجبين من أمر الله رحمت الله وبركاته عليكم أهل البيت إنه حميد مجيد﴾</span>. قالت سارة: ما آيةُ ذلك؟ فأخذ بيده عُودًا يابِسًا، فلواه بين أصابعه، فاهْتَزَّ أخضر، فقال إبراهيم: هو لله إذن ذبيحًا{11}. (٨/٩٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٩٠٠<span class="dash">-</span></span> عن <span class="name-2">محمد بن قيس</span> -من طريق أبي معشر- في قوله: <span class="qpc-hafs">﴿وامرأته قائمة فضحكت﴾</span>، قال: لَمّا جاءت الملائكة ظَنَّت أنهم يريدون أن يعملوا كما يعمل قومُ لوط{12}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٩٠١<span class="dash">-</span></span> عن <span class="name-3">محمد بن السائب الكلبي</span> -من طريق معمر- <span class="qpc-hafs">﴿فضحكت﴾</span>، قال: ضَحِكَت حين راعَوْا إبراهيم مِمّا رَأَتْ مِن الرَّوْع بإبراهيم{13}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٩٠٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فَضَحِكَتْ﴾</span> مِن خوف إبراهيم ورِعْدَتِه مِن ثلاثة نفر، وإبراهيمُ في حشمه وخدمه{14}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٩٠٣<span class="dash">-</span></span> عن <span class="name-3">محمد بن إسحاق</span> -من طريق سلمة- قال: <span class="qpc-hafs">﴿فضحكت﴾</span>، يعني: سارة؛ لِما عَرَفَتْ مِن أمر الله -جلَّ ثناؤه-، ولِما تعلمُ مِن قوم لوط{15}<span class=comment-ref>٣٢٥٠</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٣٢٥٠</span> اختُلِف في معنى الضَّحِك على قولين: <b>الأول:</b> أنّه الضحك المعروف. <b>الثاني:</b> الحيض.</p><p>و<span class="comment-type-2">انتقد</span> <u>ابنُ عطية</u> (٤/٦٠٩) القول الثاني، وهو قول ابن عباس من طريق ابنه علي، وقول ابن عمر، ومجاهد، وعكرمة، فقال: «وهذا قولٌ ضعيفٌ قليل التمكن».</p><p>ثُمَّ اختلف القائلون أنّه الضحك المعروف في السبب الذي من أجله ضَحِكَت على أقوال: <b>الأول:</b> تَعَجُّبًا مِن أنها وزوجها يخدمان الأضياف تكرمةً لهم، وهم لا يأكلون. <b>الثاني:</b> ضحكت من أنّ قوم لوط في غفلة وقد جاءت رسل الله بإهلاكهم. <b>الثالث:</b> ضحكت ظنًّا بالرسل أنهم يريدون عَمَل قوم لوط. <b>الرابع:</b> ضحكت لَمّا رأت ما بزوجها من الرَّوْع. <b>الخامس:</b> ضحكت حين بُشِّرَت بإسحاق تَعَجُّبًا مِن أن يكون لها ولد على كِبَر سنِّها وسنِّ زوجها. <b>السادس:</b> ضحكت سرورًا بالأمن منهم، لمّا قالوا لإبراهيم ﵇: <b><span class="qpc-hafs">﴿لا تَخَفْ﴾</span>.</b></p><p>و<span class="comment-type-3">رجَّح</span> <u>ابنُ جرير</u> (١٢/٤٧٨) <span class="mustanad">مستندًا إلى دلالة السياق، والعقل</span> القول الثاني، وهو قول قتادة، وعلَّل ذلك بقوله: «لأنه ذُكِر عقيب قولهم لإبراهيم: <span class="qpc-hafs">﴿لا تَخَفْ إنّا أُرْسِلْنا إلى قَوْمِ لُوطٍ﴾</span>، فإذا كان ذلك كذلك، وكان لا وجْه للضحك والتعجب من قولهم لإبراهيم ﵇: <span class="qpc-hafs">﴿لا تَخَفْ﴾</span>؛ كان الضحك والتعجب إنما هو مِن أمْرِ قوم لوط ﵇».</p><p>و<span class="comment-type-2">انتقد</span> <u>ابنُ عطية</u> (٤/٦١٠) القول الثالث، وهو قول محمد بن قيس، فقال: «وهذا قولٌ خطأٌ، لا ينبغي أن يلتفت إليه، وقد حكاه الطبري، وإنما ذكرته لمعنى التنبيه على فساده».</p><p>و<span class="comment-type-2">انتقد</span> <u>ابنُ كثير</u> (٧/٤٥٢) القول الثالث، والقول الرابع وهو قول الكلبي من طريق معمر بأنهما: «ضعيفان جدًّا، وإن كان ابنُ جرير قد رواهما بسنده إليهما، فلا يلتفت إلى ذلك». و<span class="comment-type-2">انتقد</span> القول الخامس، وهو قول وهب بن منبه <span class="mustanad">مستندًا إلى مخالفة السياق</span>، فقال عنه: «وهذا مخالف لهذا السياق؛ فإنّ البشارة صريحة مُرَتَّبة على ضحكها».</div></p><p><h3><span class="qpc-hafs">﴿فَبَشَّرۡنَـٰهَا بِإِسۡحَـٰقَ وَمِن وَرَاۤءِ إِسۡحَـٰقَ یَعۡقُوبَ ۝٧١﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٥٩٠٤<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق حبيب بن أبي ثابت- في قوله: <span class="qpc-hafs">﴿فبشرناها بإسحاق ومن ورآء إسحاق يعقوب﴾</span>، قال: هو ولَدُ الوَلَد{16}. (٨/١٠١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٩٠٥<span class="dash">-</span></span> عن حسان بن الحُرِّ، قال: كنتُ عند <span class="name-1">ابن عباس</span>، فجاءه رجل مِن هُذَيْل، فقال له ابن عباس: ما فعل فلان؟ قال: مات وترك أربعةً من الولد، وثلاثة مِن الوراء. فقال ابن عباس: <span class="qpc-hafs">﴿فبشرناها بإسحاق ومن ورآء إسحاق يعقوب﴾</span>، قال: ولد الولد{17}. (٨/١٠١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٩٠٦<span class="dash">-</span></span> عن <span class="name-2">كعب الأحبار</span> -من طريق عبد الله بن رباح- قال: بَلَغَنا: أنّ إبراهيم ﵇ كان يُشْرِف على سدوم، فيقول: ويلكِ، سدوم، يومٌ ما لَكِ! ثم قال: <span class="qpc-hafs">﴿ولقد جاءت رسلنا إبراهيم بالبشرى قالوا سلامًا قال سلام فما لبث أن جاء بعجل حنيذ﴾</span>: نضيج، وهو يحسبهم أضيافًا، <span class="qpc-hafs">﴿فبشرناها بإسحاق ومن وراء إسحاق يعقوب﴾</span> قال: ولدًا لولد، <span class="qpc-hafs">﴿قالت يا ويلتى ءألد وأنا عجوز وهذا بعلي شيخًا إن هذا لشيء عجيب﴾</span>. فقال لها جبريل: <span class="qpc-hafs">﴿أتعجبين من أمر الله رحمت الله وبركاته عليكم أهل البيت إنه حميد مجيد﴾</span>{18}. (٨/٩٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٩٠٧<span class="dash">-</span></span> عن <span class="name-2">عامر الشعبي</span> -من طريق داود- في قوله: <span class="qpc-hafs">﴿ومن وراء إسحاق يعقوب﴾</span>، قال: ولد الولد{19}. (٨/١٠١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٩٠٨<span class="dash">-</span></span> عن أبي اليسع إسماعيل بن حماد بن أبي المغيرة مولى الأشعري، قال: كنتُ إلى جنب جدِّي أبي المغيرة بن مهران في مسجد علي بن زيد، فمَرَّ بنا <span class="name-2">الحسن بن أبي الحسن</span>، فقال: يا أبا المغيرة، مَن هذا الفتى؟ قال: ابني مِن ورائي. فقال الحسن: <span class="qpc-hafs">﴿فبشرناها بإسحاق ومن وراء إسحاق يعقوب﴾</span>{20}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٩٠٩<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد بن بشير- في قوله: <span class="qpc-hafs">﴿فبشرناها بإسحاق﴾</span> بابنها{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٩١٠<span class="dash">-</span></span> قال <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط-: لَمّا ضحِكت سارة وقالت: عجبًا لأضيافنا هؤلاء، إنّا نخدمهم بأنفسنا تكرِمةً لهم، وهم لا يأكلون طعامنا! قال لها جبريل: أبشِري بولدٍ اسمه: إسحاق، ومن وراء إسحاق يعقوب. فضربت وجهها عجبًا، فذلك قوله: <span class="qpc-hafs">﴿فَصَكَّتْ وجْهَها﴾</span> [الذاريات:٢٩]{22}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٩١١<span class="dash">-</span></span> قال <span class="name-3">محمد بن السائب الكلبي</span>: <span class="qpc-hafs">﴿فضحكت﴾</span>، لَمّا رأت سارةُ فَرَق إبراهيم عَجِبَتْ مِن فَرَقِه، فضَحِكَت وهي لا تدري مَنِ القوم، فبشروها بإسحاق، وقالوا: نرجع إليك عامًا قابِلًا وقد ولدت لإبراهيم غلامًا اسمه: إسحاق، ويكون مِن وراء إسحاق يعقوب. أي: من بعد إسحاق{23}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٩١٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ... فقال جبريل ﵇ لسارة: إنّكِ سَتَلِدِين غلامًا، فذلك قوله: <span class="qpc-hafs">﴿فَبَشَّرْناها بِإسْحاقَ ومِن وراءِ إسْحاقَ يَعْقُوبَ﴾</span>{14}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٩١٣<span class="dash">-</span></span> عن <span class="name-3">محمد بن إسحاق</span> -من طريق سلمة- قال: ... فبشروها بإسحاق، ومِن وراء إسحاق يعقوب؛ بابنٍ، وبابن ابن، فقالت وصكَّت وجهها -يُقال: ضربت على جبينها-: <span class="qpc-hafs">﴿يا ويلتى أألد وأنا عجوز﴾</span> إلى قوله: <span class="qpc-hafs">﴿إنه حميد مجيد﴾</span>{25}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿فَبَشَّرۡنَـٰهَا بِإِسۡحَـٰقَ وَمِن وَرَاۤءِ إِسۡحَـٰقَ یَعۡقُوبَ ۝٧١﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٣٥٩١٤<span class="dash">-</span></span> عن <span class="name-1">علي بن أبي طالب</span>: أنّ سارة بنت ملك مِن الملوك، وكانت قد أُوتِيَت حُسْنًا{26}. (٨/١٠١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٩١٥<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق الكلبي، عن أبي صالح- قال: كان حُسْنُ سارةَ حُسْنَ حواءَ ﵍{27}. (٨/١٠٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٩١٦<span class="dash">-</span></span> عن <span class="name-2">الضحاك بن مزاحم</span> -من طريق مقاتل- قال: كان اسمُ سارة: يسارة، فلمّا قال لها جبريل ﵇: يا سارة. قالت: إنّ اسمي يسارة، فكيف تُسمِّيني سارة؟! قال الضحاك بن مزاحم: يسارة: العاقِرُ التي لا تلد، وسارة: الطالق الرَّحِم التي تلد. فقال لها جبريل ﵇: كنتِ يسارةً لا تحملين، فصِرتِ سارةً تحمِلين الولد وتُرضعينه. فقالت سارة: يا جبريل، نقصت اسمي. قال جبريل: إنّ الله قد وعدكِ بأن يجعل هذا الحرفَ في اسمِ ولدٍ مِن ولدك في آخر الزمان، وذلك أن اسمه عند الله حيي، فسمّاه: يحيى{28}. (٨/١٠٠)</p></p><p></div></p></div>",footnotes:1:عزاه السيوطي إلى ابن المنذر.</p><p>وهي قراءة شاذة. انظر: البحر المحيط ٥/٢٤٣.أخرجه ابن أبي حاتم ٦/٢٠٥٥.تفسير مقاتل بن سليمان ٢/٢٩٠.أخرجه ابن أبي حاتم ٦/٢٠٥٥. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وأبي الشيخ. وعزاه الحافظ ابن حجر في الفتح ١/٤٠٠ إلى ابن جرير مختصرًا.تفسير الثعلبي ٥/١٧٩، وتفسير البغوي ٤/١٨٩.عزاه السيوطي إلى أبي الشيخ. وجاء عقبه: "قال الشاعر:</p><p>إني لآتي العُرسَ عند طُهورِها وأهجرُها يومًا إذا تَكُ ضاحك"</p><p>ولا يظهر أن هذا من قول ابن عمر، وكأنّ في النص سقطًا، أو أنه تابع لأثر عكرمة الآتي كما في طبعات الدر السابقة.أخرجه ابن أبي حاتم ٦/٢٠٥٤.أخرجه ابن جرير ١٢/٤٧٦.عزاه السيوطي إلى أبي الشيخ.أخرجه عبد الرزاق ١/٣٠٦، وابن جرير ١٢/٤٧٤، وابن أبي حاتم ٦/٢٠٥٤. وعزاه السيوطي إلى ابن المنذر، وأبي الشيخ.أخرجه ابن جرير ١٢/٤٨٠-٤٨١، وفي تاريخه ١/٢٧٢-٢٧٣.أخرجه ابن جرير ١٢/٤٧٥.أخرجه عبد الرزاق ١/٣٠٦، وابن جرير ١٢/٤٧٥. وذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٢/٢٩٩-.تفسير مقاتل بن سليمان ٢/٢٩٠-٢٩١.أخرجه ابن جرير ١٢/٤٨١، وابن أبي حاتم ٦/٢٠٥٥.أخرجه ابن جرير ١٢/٤٨٠، وابن أبي حاتم ٦/٢٠٥٦. وعزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ١٢/٤٨٠. وعزاه السيوطي إلى ابن الأنباري في كتاب الوقف والابتداء.أخرجه ابن أبي الدنيا في كتاب العقوبات -موسوعة الإمام ابن أبي الدنيا ٤/٤٦٤ (١٤٩)-. وعزاه السيوطي إلى عبد الله بن أحمد في زوائد الزهد.أخرجه ابن أبي الدنيا في كتاب الأشراف -موسوعة الإمام ابن أبي الدنيا ٨/٣١٣ (٤٥٣)-، وابن جرير ١٢/٤٨٠، وابن أبي حاتم ٦/٢٠٥٦. وعزاه السيوطي إلى ابن الأنباري.أخرجه ابن جرير ١٢/٤٧٩.أخرجه ابن أبي حاتم ٦/٢٠٥٥.أخرجه ابن جرير ١٢/٤٨٠.ذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٢/٢٩٩-.تفسير مقاتل بن سليمان ٢/٢٩٠-٢٩١.أخرجه ابن جرير ١٢/٤٨١.أخرجه ابن عبد الحكم في فتوح مصر ص١١.أخرجه ابن عبد الحكم في فتوح مصر ص١٠.أخرجه ابن عساكر ٦٩/١٨١.