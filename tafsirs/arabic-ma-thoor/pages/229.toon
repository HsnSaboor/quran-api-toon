quran[9]{c,v,t}:
11,63," <q>﴿قَالَ یَـٰقَوۡمِ أَرَءَیۡتُمۡ إِن كُنتُ عَلَىٰ بَیِّنَةࣲ مِّن رَّبِّی وَءَاتَىٰنِی مِنۡهُ رَحۡمَةࣰ فَمَن یَنصُرُنِی مِنَ ٱللَّهِ إِنۡ عَصَیۡتُهُۥۖ فَمَا تَزِیدُونَنِی غَیۡرَ تَخۡسِیرࣲ ۝٦٣﴾</q> - تفسير ٣٥٨٠٤- قال عبد الله بن عباس: غير خسارة في خسارتكم{1}. (ز) ٣٥٨٠٥- عن مجاهد بن جبر -من طريق ابن أبي نجيح- <q>﴿فما تزيدونني غير تخسير﴾</q>، يقول: ما تزدادون أنتم إلا خسارًا{2}. (٨/٨٧) ٣٥٨٠٦- عن عطاء الخراساني -من طريق عثمان بن عطاء- <q>﴿فما تزيدونني غير تخسير﴾</q>، قال: ما تزيدونني إلا شَرًّا وخُسرانًا لكم تخسرونه{3}. (٨/٨٧) ٣٥٨٠٧- قال مقاتل بن سليمان: <q>﴿قالَ﴾</q> صالح: <q>﴿يا قَوْمِ أرَأَيْتُمْ إنْ كُنْتُ عَلى بَيِّنَةٍ مِن رَبِّي﴾</q> يعني: على بَيان مِن ربي، <q>﴿وآتانِي مِنهُ رَحْمَةً﴾</q> يقول: أعطاني نِعمةً مِن عنده، وهو الهُدى، <q>﴿فَمَن يَنْصُرُنِي﴾</q> يعني: فمَن يمنعني <q>﴿مِنَ اللَّهِ إنْ عَصَيْتُهُ﴾</q> يعني: إن رجعتُ إلى دينكم، لقولهم: صالح قد كنت فينا مرجو قبل هذا الذي تدعونا إليه. <q>﴿فَما تَزِيدُونَنِي غَيْرَ تَخْسِيرٍ﴾</q> يقول: فما تزيدونني إلا خسارًا{4}. (ز) ",footnotes:1:تفسير الثعلبي ٥/١٧٦، وتفسير البغوي ٤/١٨٦.أخرجه ابن جرير ١٢/٤٥٥. وعزاه السيوطي إلى أبي الشيخ.أخرجه ابن أبي حاتم ٦/٢٠٤٩. وعزاه السيوطي إلى أبي الشيخ.تفسير مقاتل بن سليمان ٢/٢٨٨-٢٨٩.
11,64," <q>﴿وَیَـٰقَوۡمِ هَـٰذِهِۦ نَاقَةُ ٱللَّهِ لَكُمۡ ءَایَةࣰۖ فَذَرُوهَا تَأۡكُلۡ فِیۤ أَرۡضِ ٱللَّهِۖ وَلَا تَمَسُّوهَا بِسُوۤءࣲ فَیَأۡخُذَكُمۡ عَذَابࣱ قَرِیبࣱ ۝٦٤﴾</q> - تفسير ٣٥٨٠٨- قال مقاتل بن سليمان: <q>﴿ويا قَوْمِ هَذِهِ ناقَةُ اللَّهِ لَكُمْ آيَةً﴾</q> يعني: عِبْرَة، <q>﴿فَذَرُوها تَأْكُلْ فِي أرْضِ اللَّهِ﴾</q> لا تُكَلِّفكم مُؤْنَةً ولا عَلَفًا، <q>﴿ولا تَمَسُّوها بِسُوءٍ﴾</q> يقول: ولا تصيبوها بعَقْرٍ؛ <q>﴿فَيَأْخُذَكُمْ﴾</q> في الدنيا <q>﴿عَذابٌ قَرِيبٌ﴾</q> منكم، لا تُمْهَلون حتى تُعَذَّبوا{1}. (ز) ",footnotes:1:تفسير مقاتل بن سليمان ٢/٢٨٩. وقد تقدمت آثار قصة ثمود مطولة في سورة الأعراف، وأورد ابن جرير وابن أبي حاتم كثيرًا منها في هذه السورة، واكتفينا هنا بإيراد ما لم يرد في سورة الأعراف.
11,65," <q>﴿فَعَقَرُوهَا فَقَالَ تَمَتَّعُوا۟ فِی دَارِكُمۡ ثَلَـٰثَةَ أَیَّامࣲۖ ذَ ٰ⁠لِكَ وَعۡدٌ غَیۡرُ مَكۡذُوبࣲ ۝٦٥﴾</q> - تفسير ٣٥٨٠٩- عن أبي الطُّفَيْل، قال: لَمّا غزا رسولُ الله ﷺ غزوة تبوك نزل الحِجْر، فقال: «يا أيها الناس، لا تسألوا نبيَّكم الآياتِ، هؤلاء قومُ صالح سألوا نبيَّهم أن يبعث لهم آيةً، فبعث الله لهم الناقة آيةً، فكانت تَلِجُ عليهم يوم وُرُودِهم الذي كانوا يَتَرَوَّوْنَ منه، ثم يحلبونها مثل ما كانوا يَتَرَوَّوْن مِن مائهم قبل ذلك لَبَنًا، ثم تخرج مِن ذلك الفَجِّ، فعَتَوْا عن أمر ربِّهم وعقروها، فوعدهم اللهُ العذابَ بعد ثلاثة أيام، وكان وعدًا مِن الله غير مكذوب، فأهلك اللهُ مَن كان منهم في مشارق الأرض ومغاربها إلا رجلًا واحدًا كان في حرم الله، فمنعه حرمُ الله مِن عذاب الله». قالوا: ومن ذلك الرجل، يا رسول الله؟ قال: «أبو رغال»{1}٣٢٤٤. (٦/٤٦١) (ز) ٣٢٤٤ ذكر ابنُ عطية (٤/٦٠٤) نحو هذا الأثر، ثم انتقده بدلالة التاريخ قائلًا: «وفي هذا نظر، وخلافه في السِّيَر». ٣٥٨١٠- قال عبد الله بن عباس -من طريق قتادة-: لو صعدتم القارَةَ لَرَأَيْتُم عِظام الفَصِيل. وكانت منازلُ ثمودٍ بحِجْرٍ، بين الشام والمدينة{2}. (ز) ٣٥٨١١- عن قتادة بن دعامة -من طريق مَعْمَر- <q>﴿تمتعوا في داركم ثلاثة أيام﴾</q>، قال: بقيَّة آجالهم{3}. (ز) ٣٥٨١٢- عن قتادة بن دعامة -من طريق سعيد بن بشير- قوله: <q>﴿تمتعوا في داركم ثلاثة أيام ذلك وعد غير مكذوب﴾</q>، قال: القومُ إلى آجالهم، وهو عليهم غضبان، فواللهِ، ما عجَّل إليهم أن وفّاهم بَقِيَّة آجالهم{4}. (ز) ٣٥٨١٣- عن قتادة بن دعامة -من طريق سعيد- قال: ذُكِر لنا: أنّ نبي الله ﷺ لَمّا مَرَّ بوادي ثمود وهو عامِد إلى تبوك قال: فأمر أصحابه أن يُسْرِعوا السيرَ، وأن لا ينزِلوا به، ولا يشربوا مِن مائه، وأخبرهم أنّه وادٍ ملعون. قال: وذُكِر لنا: أنّ الرَّجُل المُوسِر مِن قوم صالح كان يُعطي المُعْسِر منهم ما يَتَكَفَّنون به، وكان الرجل منهم يلحد لنفسه، ولأهل بيته؛ لميعاد نبيِّ الله صالح الذي وعدهم، وحدَّث مَن رآهم بالطُّرُق والأَفْنِيَة والبيوت فيهم شبان وشيوخ، أبقاهم اللهُ عِبْرَةً وآية{5}. (ز) ٣٥٨١٤- عن قتادة بن دعامة -من طريق سعيد- قوله: <q>﴿فعقروها فقال تمتعوا في داركم ثلاثة أيام ذلك وعد غير مكذوب﴾</q>، وذُكِر لنا: أنّ صالحًا حين أخبرهم أنّ العذاب أتاهم لَبِسُوا الأنطاع والأكْسِيَة، وقيل لهم: إنّ آيةَ ذلك أن تَصْفَرَّ ألوانُكم أوَّلَ يوم، ثم تَحْمَرَّ في اليوم الثاني، ثم تَسْوَدَّ في اليوم الثالث. وذُكِر لنا: أنّهم لَمّا عَقَروا الناقة نَدِموا، وقالوا: عليكم الفصيلَ. فصَعِد الفَصِيلُ القارَةَ –والقارة: الجبل-، حتى إذا كان اليوم الثالث استقبل القبلة، وقال: يا ربِّ، أُمِّي، يا رَبِّ، أُمِّي، يا رَبِّ، أُمِّي. ثلاثًا. قال: فأُرْسِلَتِ الصيحةُ عند ذلك{6}. (ز) ٣٥٨١٥- عن قتادة بن دعامة -من طريق سعيد بن بشير-: أنّ صالحا قال لقومه: إنّ آية ذلك أن تُصْبِح وجوهُكم أولَ يوم مُصْفَرَّة، واليوم الثاني مُحْمَرَّة، واليوم الثالث مُسْوَدَّة. قال: فخَدُّوا لهم أُخْدُودًا، وكَفَرَ{7} غنيُّهم فقيرَهم، فأرسل الله عليهم صيحةً، فأهْمَدَتْهم، قال الله: <q>﴿كأن لم يغنوا فيها﴾</q>{8}. (ز) ٣٥٨١٦- عن عبد الملك ابن جريج، في قوله: <q>﴿ثلاثة أيام﴾</q>، قال: كان بَقِيَ مِن أجل قومِ صالح عند عَقْرِ الناقة ثلاثةُ أيام، فلم يُعَذَّبوا حتى أكملوها{9}. (٨/٨٨) ٣٥٨١٧- عن عبد الملك ابن جُرَيْج -من طريق حجّاج- قال: حُدِّثْتُ: أنّه لَمّا أخذتهم الصيحةُ أهْلَكَ اللهُ مِن بين المشارق والمغارب منهم إلا رجلًا واحدًا كان في حَرَمِ الله، مَنَعَهُ حرمُ الله مِن عذاب الله. قيل: ومَن هُو، يا رسول الله؟ قال: «أبو رغال». وقال رسول الله ﷺ حين أتى على قرية ثمود لأصحابه: «لا يَدْخُلَنَّ أحدٌ منكم القريةَ، ولا تشربوا مِن مائهم». وأراهم مُرْتَقى الفصيلِ حين ارتقى في القارَة{10}. (ز) ٣٥٨١٨- عن محمد بن إسحاق -من طريق سلمة- قال: رصدوا الناقة حين صَدَرَت عن الماء، وقد كَمَنَ{11} لها قُدارٌ في أصل الصَّخْرَةِ على طريقها، وكَمَنَ لها مِصْدَعٌ في أصْلِ أُخرى، فمَرَّت على مِصْدَع، فرماها بسَهْمٍ، فانتَظَمَ بِه عَضَلَة ساقِها. قال: فشَدَّ -يعني: قدار- على الناَّقة بالسيف، فكشف عرقوبها، فخرَّتْ، ورَغَتْ رُغاةً واحِدة، فَحُتِرَتْ ساقَيْها، ثم طَعَن في لَبَّتِها{12} فنحرها. وانطلق سَقْبُها{13} حتى أتى جبلًا، ثم أتى صخرة في رأس الجبل، فرَغا، ثم لاذ بها، فأتاهم صالحٌ، فلمّا رأى الناقةَ عُقِرَت بكى، ثم قال: انتَهَكْتُم حُرْمَةَ اللهِ! فأبشِرُوا بعذاب اللهِ ونقمته. وأتبع السَّقْبَ أربعةُ نفرٍ مِن التِّسعة الذين عقروا الناقة، ولما قال لهم صالح: أبِشروا بعذاب الله ونقمته. قالوا وهم يهزَؤون به: ومن ذلك، يا صالح؟ وما آيةُ ذلك؟ وكانوا يُسَمُّون الأيام فيهم: الأحدَ أوَّلَ، والاثنين أهونَ، والثلاثاء دُبار، والأربعاء جُبار، والخميس مُؤْنِس، والجمعة العَروبة، والسبتَ شِيارَ، وكانوا عقروا الناقة يوم الأربعاء، فقال لهم صالِحٌ حين قالوا له ذلك: تُصْبِحون غدًا يوم مؤنس -يعني: الخميس- وجوهُكم مُصْفَرَّة، وتُصْبِحُون يومَ العروبة -يعني: الجمعة- ووجوهُكم مُحْمَرَّة، ثم تُصْبِحُون يوم شيار -يعني: السبت- ووجوهكم مُسْوَدَّة، ثم يُصَبِّحُكُم العذابُ يوم الأول -يعني: يوم الأحد-{14}. (ز) ٣٥٨١٩- قال مقاتل بن سليمان: <q>﴿فَعَقَرُوها﴾</q> ليلة الأربعاء بالسَّيْف، فماتت، فقال لهم صالح: <q>﴿تَمَتَّعُوا فِي دارِكُمْ﴾</q> يعني: محلتكم في الدنيا <q>﴿ثَلاثَةَ أيّامٍ ذَلِكَ﴾</q> العذابُ <q>﴿وعْدٌ﴾</q> مِن الله <q>﴿غَيْرُ مَكْذُوبٍ﴾</q> ليس فيه كذب بأنّ العذاب نازِل بهم بعد ثلاثة الأيام{15}. (ز) ",footnotes:1:أخرجه ابن جرير ١٢/٤٦٣-٤٦٤، من طريق إسماعيل بن المتوكل الأشجعي، عن محمد بن كثير، عن عبد الله بن واقد، عن عبد الله بن عثمان بن خثيم، عن أبي الطفيل به. قال الشيخ أحمد شاكر في تعليقه على تفسير الطبري ١٥/٣٨٠: «محمد بن كثير، كأنّه محمد بن كثير بن أبي عطاء الثقفي المصيصي الصنعاني، وهو ضعيف جدًّا».أخرجه عبد الرزاق ١/٣٠٥ بلفظ: «لو صعدتم على القارة لرأيتم عظام الفصيل»، وابن جرير ١٢/٤٥٧.أخرجه عبد الرزاق ١/٣٠٥، وابن جرير ١٢/٤٥٧.أخرجه ابن أبي حاتم ٦/٢٠٥٠.أخرجه ابن جرير ١٢/٤٦٣.أخرجه ابن جرير ١٢/٤٥٦.أي: جحد. لسان العرب (كفر).أخرجه ابن أبي حاتم ٦/٢٠٥١.عزاه السيوطي إلى أبي الشيخ.أخرجه ابن جرير في تاريخه ١/٢٣١، وفي تفسيره ١٢/٤٦٢-٤٦٣.أي: استتر واستخفى. النهاية (كمن).اللَبَّة: هي الهَزْمة التي فوق الصدر، وفيها تُنحر الإبل. النهاية (لبب).السَّقْبُ: ولد الناقة. تاج العروس (سقب).أخرجه ابن أبي حاتم ٦/٢٠٥١. وتقدم بتمامه مطولًا جدًّا من قول يعقوب بن عتبة بن المغيرة بن الأخنس من طريق ابن إسحاق، وذلك في سورة الأعراف.تفسير مقاتل بن سليمان ٢/٢٨٩.
11,66," <q>﴿فَلَمَّا جَاۤءَ أَمۡرُنَا نَجَّیۡنَا صَـٰلِحࣰا وَٱلَّذِینَ ءَامَنُوا۟ مَعَهُۥ بِرَحۡمَةࣲ مِّنَّا وَمِنۡ خِزۡیِ یَوۡمِىِٕذٍۚ إِنَّ رَبَّكَ هُوَ ٱلۡقَوِیُّ ٱلۡعَزِیزُ ۝٦٦﴾</q> - تفسير ٣٥٨٢٠- عن عبد الله بن عباس -من طريق الكلبي، عن أبي صالح- قال: <q>﴿فلما جاء أمرنا نجينا صالحا والذين آمنوا معه برحمة منا﴾</q>، يقول: بنِعْمَةٍ مِنّا{1}. (ز) ٣٥٨٢١- عن قتادة بن دعامة -من طريق مَعْمَر- في قوله: <q>﴿نجينا صالحًا والذين آمنوا﴾</q> الآية، قال: نجّاه الله برحمة منه، ونجّاه مِن خزي يومئذ{2}. (٨/٨٨) ٣٥٨٢٢- قال مقاتل بن سليمان: فأهلكهم الله صبيحةَ يوم الرابع يومَ السبت، فذلك قوله: <q>﴿فَلَمّا جاءَ أمْرُنا﴾</q> يعني: قولنا في العذاب <q>﴿نَجَّيْنا صالِحًا والَّذِينَ آمَنُوا مَعَهُ بِرَحْمَةٍ مِنّا﴾</q> يعني: بنعمة عليهم مِنّا، <q>﴿ومِن خِزْيِ يَوْمِئِذٍ﴾</q> يعني: ونجَّيناهم مِن عذاب يومئذ، <q>﴿إنَّ رَبَّكَ هُوَ القَوِيُّ﴾</q> في نَصْرِ أوليائه، <q>﴿العَزِيزُ﴾</q> يعني: المنيع في مُلْكِه وسُلْطانِه حين أهلكهم{3}. (ز) ٣٥٨٢٣- عن محمد بن إسحاق -من طريق سلمة بن الفضل- قال: حتى إذا كان ليلة الأحد خرجَ صالحٌ ومَن معه مِن بين أظهرُهم ومَن أسلم معه إلى الشام، فنَزَل رَمْلَةَ{4} فلسطين{5}٣٢٤٥. (ز) ٣٢٤٥ ذكر ابنُ عطية (٤/٦٠٣) أنّ قوله: <q>﴿بِرَحْمَةٍ مِنّا﴾</q> يحتمل احتمالين: الأول: أن يقصد: أنّ التنجية إنما كانت بمجرد الرحمة. الثاني: أن يكون وصف حال فقط، أخبر أنه رحمهم في حال التنجية. ثم قال: «وقوله: <q>﴿مِنّا﴾</q> الظاهرُ أنه متعلق برحمة، ويحتمل أن يتعلق بقوله: <q>﴿نَجَّيْنا﴾</q>». ",footnotes:1:أخرجه ابن أبي الدنيا في كتاب العقوبات -موسوعة الإمام ابن أبي الدنيا ٤/٤٦١ (١٤٠)-.أخرجه عبد الرزاق ١/٣٠٥، وابن جرير ١٢/٤٥٨.تفسير مقاتل بن سليمان ٢/٢٨٩.رملة فلسطين: بينها وبين البيت المقدس ثمانية عشر يومًا. معجم البلدان ٣/٦٩.أخرجه ابن أبي حاتم ٦/٢٠٥١.
11,67," <q>﴿وَأَخَذَ ٱلَّذِینَ ظَلَمُوا۟ ٱلصَّیۡحَةُ﴾</q> - تفسير ٣٥٨٢٤- عن عبد الله بن عباس -من طريق الكلبي، عن أبي صالح- قال: أخذتهم الصيحة، والصيحة: صاعِقَةٌ، وكلُّ عذاب الله فهو صاعقة، فاحترقوا جميعًا{1}. (ز) ٣٥٨٢٥- قال إسماعيل السُّدِّيّ: <q>﴿وأخذ الذين ظلموا الصيحة﴾</q>، يعني: صيحة جبريل ﵇{2}. (ز) ٣٥٨٢٦- قال مقاتل بن سليمان: <q>﴿وأَخَذَ الَّذِينَ ظَلَمُوا﴾</q> يعني: الذين أشركوا <q>﴿الصَّيْحَةُ﴾</q> صيحة جبريل ﵇{3}. (ز) <q>﴿فَأَصۡبَحُوا۟ فِی دِیَـٰرِهِمۡ جَـٰثِمِینَ ۝٦٧﴾</q> - تفسير ٣٥٨٢٧- عن عبد الله بن عباس -من طريق الكلبي، عن أبي صالح- <q>﴿فَأَصْبَحُوا فِي دِيارِهِمْ جاثِمِينَ﴾</q>: قد صاروا رَمادًا، فَهَمَدُوا جُثُومًا لا يَتَحَرَّكون، فشَبَّههم بالرَّماد، حتى صاروا رمادًا{1}. (ز) ٣٥٨٢٨- عن أبي مالك غَزْوان الغِفاري -من طريق إسماعيل السدي- قال: <q>﴿في ديارهم﴾</q>، يعني: بيوتهم{5}. (ز) ٣٥٨٢٩- عن قتادة بن دعامة -من طريق سعيد- <q>﴿فأصبحوا في ديارهم جاثمين﴾</q>، يقول: أصبحوا قد هلكوا{6}. (ز) ٣٥٨٣٠- عن قتادة بن دعامة -من طريق مَعْمَر- في قوله تعالى: <q>﴿فأصبحوا في ديارهم جاثمين﴾</q>، قال: مَيِّتين{7}. (ز) ٣٥٨٣١- قال إسماعيل السُّدِّيّ: <q>﴿فأصبحوا في ديارهم جاثمين﴾</q>، أي: قد هلكوا{2}. (ز) ٣٥٨٣٢- قال مقاتل بن سليمان: <q>﴿فَأَصْبَحُوا فِي دِيارِهِمْ جاثِمِينَ﴾</q>، يعني: في منازلهم خامِدين{3}. (ز) ٣٥٨٣٣- عن عبد الرحمن بن زيد بن أسلم -من طريق أصبغ- في قوله: <q>﴿فأصبحوا في ديارهم جاثمين﴾</q>، قال: مَيِّتين{10}. (٨/٨٨) ",footnotes:1:أخرجه ابن أبي الدنيا في كتاب العقوبات -موسوعة الإمام ابن أبي الدنيا ٤/٤٦١ (١٤٠)-.ذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٢/٢٩٨-.تفسير مقاتل بن سليمان ٢/٢٨٩.أخرجه ابن أبي الدنيا في كتاب العقوبات -موسوعة الإمام ابن أبي الدنيا ٤/٤٦١ (١٤٠)-.أخرجه ابن أبي حاتم ٦/٢٠٥٢.أخرجه ابن جرير ١٢/٤٦٤، وابن أبي حاتم ٦/٢٠٥٢.أخرجه عبد الرزاق ١/٣٠٥.ذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٢/٢٩٨-.تفسير مقاتل بن سليمان ٢/٢٨٩.أخرجه ابن أبي حاتم ٥/١٥١٦ (٨٦٨٩).
11,68," <q>﴿كَأَن لَّمۡ یَغۡنَوۡا۟ فِیهَاۤۗ أَلَاۤ إِنَّ ثَمُودَا۟ كَفَرُوا۟ رَبَّهُمۡۗ أَلَا بُعۡدࣰا لِّثَمُودَ ۝٦٨﴾</q> - تفسير ٣٥٨٣٤- عن عبد الله بن عباس -من طريق الضحاك- <q>﴿كأن لم يغنوا فيها﴾</q>، قال: كأن لم يُعَمَّروا فيها{1}. (٨/٨٨) ٣٥٨٣٥- عن عبد الله بن عباس -من طريق علي- في قوله: <q>﴿كأن لم يغنوا فيها﴾</q>، قال: كأن لم يعيشوا فيها{2}. (٨/٨٨) ٣٥٨٣٦- عن قتادة بن دعامة -من طريق سعيد-، بمثله{3}. (ز) ٣٥٨٣٧- عن عبد الله بن عباس: أنّ نافع بن الأزرق قال له: أخبِرني عن قوله ﷿: <q>﴿كأن لم يغنوا فيها﴾</q>. قال: كأن لم يكونوا فيها -يعني: في الدنيا- حين عُذِّبوا، ولم يَعمُروا فيها. قال: وهل تعرف العرب ذلك؟ قال: نعم، أما سمعتَ لَبيد بن ربيعة وهو يقول: وغَنِيتُ سَبْتًا{4} قبل مَجرى داحِسٍ{5} لو كان للنفس اللَّجُوج خلودُ{6}. (٨/٨٨) ٣٥٨٣٨- عن أبي مالك غزوان الغفاري، قال: كأن لم يكونوا فيها{7}. (ز) ٣٥٨٣٩- عن قتادة بن دعامة -من طريق معمر- في قوله: <q>﴿كأن لم يغنوا فيها﴾</q>، قال: كأن لم ينعموا فيها{8}. (٨/٨٩) ٣٥٨٤٠- قال مقاتل بن سليمان: <q>﴿كَأَنْ لَمْ يَغْنَوْا فِيها﴾</q> يقول: كأنّهم لم يكونوا في الدنيا قطُّ، <q>﴿ألا إنَّ ثَمُودَ كَفَرُوا﴾</q> بتوحيد <q>﴿رَبَّهُمْ ألا بُعْدًا لِثَمُودَ﴾</q> في الهلاك{9}. (ز) ",footnotes:1:أخرجه ابن أبي الدنيا في كتاب العقوبات -موسوعة الإمام ابن أبي الدنيا ٤/٤٦١ (١٤٠)-، وابن أبي حاتم ٦/٢٠٥٢. وعزاه السيوطي إلى أبي الشيخ.أخرجه ابن جرير ١٠/٣٢٦، ١٢/٤٦٥، وابن أبي حاتم ٦/٢٠٥٢.أخرجه ابن جرير ١٢/٤٦٥.السَّبْت: بُرْهة من الدهر. لسان العرب (سبت).داحِسٌ: اسم فرس معروف مشهور. لسان العرب (دحس).أخرجه الطستي -كما في الإتقان ٢/٩٢-. وعزاه السيوطي إلى ابن الأنباري في الوقف والابتداء.علَّقه ابن أبي حاتم ٦/٢٠٥٣.أخرجه ابن أبي حاتم ٦/٢٠٥٣.تفسير مقاتل بن سليمان ٢/٢٨٩.
11,69," <q>﴿وَلَقَدۡ جَاۤءَتۡ رُسُلُنَاۤ إِبۡرَ ٰ⁠هِیمَ بِٱلۡبُشۡرَىٰ﴾</q> - تفسير ٣٥٨٤١- قال عبد الله بن عباس: كانوا ثلاثةً: جبرائيل، وميكائيل، وإسرافيل{1}. (ز) ٣٥٨٤٢- عن عطاء: مثله{2}. (ز) ٣٥٨٤٣- قال الضحاك بن مزاحم: تسعة{1}. (ز) ٣٥٨٤٤- قال محمد بن كعب القرظي: كان جبريل، ومعه سبعة{2}. (ز) ٣٥٨٤٥- قال إسماعيل السُّدِّيّ: أحد عشر مَلَكًا، على صورة الغِلمان الوُضّاءِ وُجوهُهُم{1}. (ز) ٣٥٨٤٦- عن عثمان بن محصن -من طريق نوح بن قيس- في ضيف إبراهيم، قال: كانوا أربعة: جبريل، وميكائيل، وإسرافيل، ورافائيل{6}. (٨/٨٩) ٣٥٨٤٧- قال مقاتل: كانوا اثني عشر مَلَكًا{2}. (ز) ٣٥٨٤٨- قال مقاتل بن سليمان: <q>﴿ولَقَدْ جاءَتْ رُسُلُنا﴾</q>، وهو جبريل، ومعه مَلَكان، وهما: مَلَك الموت، وميكائيل{8}٣٢٤٦. (ز) ٣٢٤٦ ذكر ابنُ عطية (٤/٦٠٦ بتصرف) روايةً تَنُصُّ على «أنّ جبريل ﵇ كان مختصًّا بإهلاك قرية لوط، وميكائيل ﵇ مختصًّا بتبشير إبراهيم ﵇ بإسحاق ﵇، وإسرافيل ﵇ مختصًّا بإنجاء لوط ﵇ ومَن معه». ثم استدرك عليها بقوله: «وهذه الآية تقضي باشتراكهم في البشارة بإسحاق ﵇». <q>﴿بِٱلۡبُشۡرَىٰ﴾</q> - تفسير ٣٥٨٤٩- عن عكرمة مولى ابن عباس -من طريق داود- يعني قوله: <q>﴿جاءت رسلنا إبراهيم بالبشرى﴾</q>، قال: ... بنُبُوَّته{9}. (ز) ٣٥٨٥٠- قال قتادة بن دعامة: <q>﴿ولقد جاءت رسلنا إبراهيم بالبشرى﴾</q>: بإسحاق{10}. (ز) ٣٥٨٥١- قال مقاتل بن سليمان: <q>﴿ولَقَدْ جاءَتْ رُسُلُنا إبْراهِيمَ بِالبُشْرى﴾</q> في الدُّنيا الولد: بإسحاق، ويعقوب{11}. (ز) <q>﴿قَالُوا۟ سَلَـٰمࣰاۖ قَالَ سَلَـٰمࣱۖ﴾</q> - قراءات ٣٥٨٥٢- عن عبد الرحمن الأعرج، قال: سمعتُ مروان يقرأ: ‹قالُواْ سَلامًا قالَ سِلْمٌ›{12}. (ز) ٣٥٨٥٣- عن سعيد بن جبير أنّه قرأ: ‹قالُواْ سَلامًا قالَ سِلْمٌ›: وكل شيءٍ سلَّمَت عليه الملائكة فقالوا: سلامًا. قال: سِلم{13}. (٨/٨٩) <q>﴿قَالُوا۟ سَلَـٰمࣰاۖ قَالَ سَلَـٰمࣱۖ﴾</q> - تفسير الآية ٣٥٨٥٤- قال مقاتل بن سليمان: <q>﴿قالُوا سَلامًا﴾</q> قالوا تحيَّةً لإبراهيم، فسلَّموا على إبراهيم، فرَدَّ إبراهيم عليهم، فـ<q>﴿قالَ سَلامٌ﴾</q>. يقول: ردَّ إبراهيمُ خيرًا، وهو يرى أنّهم مِن البَشَر{11}. (ز) <q>﴿فَمَا لَبِثَ أَن جَاۤءَ بِعِجۡلٍ﴾</q> - تفسير ٣٥٨٥٥- عن مجاهد بن جبر -من طريق ابن أبي نجيح- <q>﴿بعجل حنيذ﴾</q>، قال: العِجل: حَسِيل البَقَر{15}. (ز) ٣٥٨٥٦- قال قتادة بن دعامة: كان عامَّةُ مالِ إبراهيم البقرَ{16}. (ز) ٣٥٨٥٧- قال عون بن أبي شداد -من طريق نوح بن قيس-: إنّه لَمّا دخل على إبراهيم، فقرَّب إليهم العِجْل؛ مسحه جبريلُ بجناحيه، فقام يدرج حتى لحق بأُمِّه، وأُمِّ العِجْل في الدّار{17}. (ز) ٣٥٨٥٨- قال مقاتل بن سليمان: <q>﴿فَما لَبِثَ أنْ جاءَ﴾</q> إبراهيمُ <q>﴿بِعِجْلٍ حَنِيذٍ﴾</q> يعني: الحنيذ النضيج، لأنّه كان البَقَرُ أكثرَ أموالهم{11}. (ز) <q>﴿حَنِیذࣲ ۝٦٩﴾</q> - تفسير ٣٥٨٥٩- عن عبد الله بن عباس -من طريق علي- في قوله: <q>﴿بعجل حنيذ﴾</q>، قال: نَضِيج{19}. (٨/٨٩) ٣٥٨٦٠- عن عبد الله بن عباس -من طريق الضحاك- في قوله: <q>﴿حنيذ﴾</q>، قال: مَشْوِي{9}. (٨/٩٠) ٣٥٨٦١- عن عبد الله بن عباس -من طريق مجاهد- في قوله: <q>﴿بعجل حنيذ﴾</q>، قال: سَمِيط{21}. (٨/٩٠) ٣٥٨٦٢- عن عبد الله بن عباس: أنّ نافع بن الأزرق قال له: أخبِرني عن قوله ﷿: <q>﴿بعجل حنيذ﴾</q>. قال: الحنيذُ: النَّضِيج، ما يُشْوى بالحِجارة. قال: وهل تعرف العربُ ذلك؟ قال: نعم، أما سمعت قولَ الشاعر وهو يقول: لهم راحٌ وفارُ المسكِ فيهم وشاويهم إذا شاءوا حنيذُ{22}. (٨/٩٠) ٣٥٨٦٣- قال عبد الله بن عباس: مَشْوِيٌّ بالحجارة الحارَّة في خَدٍّ{23} مِن الأرض{24}. (ز) ٣٥٨٦٤- عن كعب الأحبار -من طريق عبد الله بن رباح- قال: <q>﴿فما لبث أن جاء بعجل حنيذ﴾</q>: نضيج، وهو يَحْسَبُهم أضْيافًا{25}. (٨/٩٠) ٣٥٨٦٥- عن مجاهد بن جبر -من طريق ابن أبي نَجِيح- <q>﴿بعجل حنيذ﴾</q>، قال: ... الحنيذ: المشويُّ النَّضِيج{15}. (ز) ٣٥٨٦٦- عن مجاهد بن جبر -من طريق ابن جُرَيْج- قوله: <q>﴿ولقد جاءت رسلنا إبراهيم بالبشرى﴾</q> إلى: <q>﴿بعجل حنيذ﴾</q>، قال: نَضِيجٍ سخنٍ، أُنضِج بالحِجارة{15}. (ز) ٣٥٨٦٧- عن الضَّحّاك بن مُزاحِم -من طريق عبيد- في قوله: <q>﴿بعجل حنيذ﴾</q>، قال: الحنيذ: الذي أُنضِج بالحجارة{28}. (٨/٩٠) ٣٥٨٦٨- عن وهب بن مُنَبِّه -من طريق عبد الصمد- قال: <q>﴿حنيذ﴾</q>، يعني: شوي{29}. (ز) ٣٥٨٦٩- عن قتادة بن دعامة -من طريق سعيد-: <q>﴿فما لبث أن جاء بعجل حنيذ﴾</q>، والحنيذ: النَّضيج{30}. (ز) ٣٥٨٧٠- عن إسماعيل السُّدِّيّ -من طريق أسباط- قال: ذبحه، ثُمَّ شواه في الرَّضْفِ{31}، فهو الحنيذ حين شواه{30}. (ز) ٣٥٨٧١- عن إسماعيل السُّدِّيّ -من طريق أسباط- قال: الحنيذ: السمين. قال أسباط: وقال غيره: المشويّ الذي خُدَّ له في الأرض خدًا، فشُوي فيه{33}. (ز) ٣٥٨٧٢- عن عطاء الخراساني -من طريق عثمان بن عطاء-: وأمّا عِجْلٌ حنيذٌ فيُقال: النَّضِيج السَّخن{9}. (ز) ٣٥٨٧٣- عن شمر بن عطية، قال: الحنيذ: الذي شُوِي وهو يسيل مِنه الماء{35}. (٨/٩٠) ٣٥٨٧٤- قال محمد بن السائب الكلبي -من طريق مَعْمَر-: والحنيذ: الذي يُحنَذُ{36} في الأرض{37}. (ز) ٣٥٨٧٥- قال مقاتل بن سليمان: <q>﴿بِعِجْلٍ حَنِيذٍ﴾</q> يعني: الحنيذ النَّضِيج؛ لأنّه كان البقر أكثر أموالهم، والحنيذ: الشِّواء الذي أُنضِج بِحَرِّ النار، مِن غير أن تَمَسه النارُ، بالحجارة تُحْمى وتُجْعَل في سِرْبٍ، فتُشْوى{11}. (ز) ٣٥٨٧٦- عن محمد بن إسحاق -من طريق سلمة- قال: الحِناذُ: الإنضاج{29}. (ز) ٣٥٨٧٧- عن سفيان الثوري -من طريق عبد العزيز- <q>﴿فما لبث أن جاء بعجل حنيذ﴾</q>، قال: مَشْوِيّ{29}٣٢٤٧. (ز) ٣٢٤٧ ذكر ابنُ جرير (١٢/٤٦٧-٤٧٠) قولين عن أهل العربية في معنى <q>﴿حنيذ﴾</q>: الأول: المشوي. والثاني: أنّ «كل شيء شوي في الأرض إذا خَدَدتَ له فيها فَدَفَنتَه وغَمَمتَه فهو الحنيذ والمحنوذ». وهذان القولان وردا في الآثار عن الكلبي ومقاتل، ثم ذكر قول ابن عباس من طريق علي بن أبي طلحة، وقول مجاهد، وقتادة، والضحاك، وشِمْر، والسدي، ووهب بن منبه، وابن إسحاق، وسفيان، في معنى هذه الكلمة، ثم علَّق على ما سبق بقوله: «وهذه الأقوال التي ذكرناها عن أهل العربية وأهل التفسير متقاربة المعاني، بعضها من بعض». <q>﴿حَنِیذࣲ ۝٦٩﴾</q> - بسط القصة ٣٥٨٧٨- عن وهب بن مُنَبِّه -من طريق عبد الصمد بن معقل-: أنّ إبراهيم ﵇ حين أخرجه قومُه بعدما ألقوه في النار خرج بامرأته سارَة ومعه أخوها لوط، وهما ابنا أخيه، فتوَجَّها إلى أرضِ الشام، ثم بلغوا مصر، وكانت سارةُ مِن أجمل الناس، فلمّا دخلت مصرَ تحدَّث الناسُ بجمالها، وعَجِبوا له، حتى بلغ ذلك المَلِك، فدعا بها، وسأله: ما هو مِنها؟ فخاف إن قال له: زوجها. أن يقتله، فقال: أنا أخوها. فقال: زَوِّجْنِيها. فكان على ذلك حتى بات ليلة، فجاءه حلم فخنقه وخوَّفه، فكان هو وأهلُه في خوف وهولٍ حتى عَلِم أنه قد أُتِي مِن قِبَلِها، فدعا إبراهيمَ، فقال: ما حملك على أن تَغُرَّني؛ زعمتَ أنها أختُك؟ فقال: إنِّي خِفْتُ إن ذكرتُ أنّها زوجتي أن يصيبني منك ما أكره. فوهب لها هاجر أمَّ إسماعيل، وحمَلهم، وجهَّزهم حتى استقر قرارهم على جبل إيليا، فكانوا بها حتى كثرت أموالهم ومواشيهم، فكان بين رِعاءِ إبراهيم ورِعاءِ لوط حوار وقتال، فقال لوط لإبراهيم: إنّ هؤلاء الرِّعاءَ قد فَسَدَ ما بينهم، وكادت تضيق فيهم المراعي، ونخاف ألا تحملنا هذه الأرض، فإن أحببت أن أخِفَّ عنك خففت. قال إبراهيم: ما شئتَ؛ إن شئتَ فانتَقِلْ منها، وإن شئتَ انتقلتُ عنك. قال لوط: لا، بل أنا أحقُّ أن أخِفَّ عنك. ففرَّ بأهله وماله إلى سهل الأردن، فكان بها حتى أغار عليه أهلُ فلسطين، فسَبَوْا أهله وماله، فبلغ ذلك إبراهيم، فأغار عليهم بما كان عنده مِن أهله ورقيقه، وكان عددُهم زيادةً على ثلاثمائة، مَن كان مع إبراهيم، فاستنقذ مِن أهل فلسطين مَن كان معهم من أهل لوط وماله، حتى ردَّهم إلى قرارهم، ثم انصرف إبراهيم إلى مكانه. وكان أهل سدوم الذين فيهم لوط قومٌ قد اسْتَغْنَوْا عن النِّساء بالرجال، فلمّا رأى الله ما كان عند ذلك بعث الملائكةُ ليعذبوهم، فأتوا إبراهيم، فلمّا رآهم راعَه هيئتُهم وجمالهم، فسلَّموا عليه، وجلسوا إليه، فقام لِيُقَرِّب إليهم قِرًى، فقالوا: مكانك. قال: بل دعوني آتيكم بما ينبغي لكم، فإنّ لكم حقًّا، لم يأتِنا أحدٌ أحقُّ بالكرامة منكم. فأمر بعجلٍ سمين، فحُنِذ له -يعني: شُوي لهم-، فقرَّب إليهم الطعام، <q>﴿فلمّا رأى أيديهم لا تصل إليه نكرهم وأوجس منهم خيفة﴾</q>، وسارة وراء الباب تسمع، قالوا: لا تخفْ، إنّا نُبَشِّرُك بغلام عليم مبارك. فبَشَّر به امرأتَه سارة، فضحكت وعَجِبَت: كيف يكون له مِنِّي ولدٌ وأنا عجوزٌ وهو شيخ كبير؟! قالوا: أتعجبين مِن أمر الله! فإنّه قادِرٌ على ما يشاء، وقد وهبه الله لكم، فأبشِروا به. فقاموا وقام معهم إبراهيم، فمشَوا معًا وسألهم، قال: أخبِرُوني لِمَ بُعِثْتُم؟ وما خطبكم؟ قالوا: إنّا أُرسِلنا إلى أهل سدوم لِنُدَمِّرها؛ فإنّهم قومُ سوء، وقد اسْتَغْنَوْا بالرجال عن النساء. قال إبراهيم: إنّ فيها قومًا صالحين، فكيف يصيبهم مِن العذاب ما يصيب أهل عمل السوء؟ قالوا: وكم فيها؟ قال: أرأيتم إن كان فيها خمسون رجلًا صالحًا؟ قالوا: إذن لا نعذبهم. قال: إن كان فيهم أربعون؟ قالوا: إذن لا نعذبهم. فلم يزل ينقص حتى بلغ إلى عشرة، ثم قال: فأهل بيت؟ قالوا: فإن كان فيها بيت صالح. قال: فلوط وأهل بيته؟ قالوا: إنّ امرأته هواها معهم، فكيف يُصرف عن أهل قرية لم يَتِمَّ فيها أهلُ بيت صالحين؟ فلمّا يئِس منهم إبراهيم انصرف ...{41}. (٨/٩٣) ",footnotes:1:تفسير الثعلبي ٥/١٧٧، وتفسير البغوي ٤/١٨٧.تفسير البغوي ٤/١٨٧.تفسير الثعلبي ٥/١٧٧، وتفسير البغوي ٤/١٨٧.تفسير البغوي ٤/١٨٧.تفسير الثعلبي ٥/١٧٧، وتفسير البغوي ٤/١٨٧.أخرجه ابن أبي حاتم ٦/٢٠٥٤.تفسير البغوي ٤/١٨٧.تفسير مقاتل بن سليمان ٢/٢٨٩-٢٩٠.أخرجه ابن أبي حاتم ٦/٢٠٥٣.ذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٢/٢٩٨-.تفسير مقاتل بن سليمان ٢/٢٩٠.أخرجه عبد الله بن وهب في الجامع - تفسير القرآن ٣/٥١ (١٠٧). وهي قراءة متواترة، قرأ بها حمزة، والكسائي، وقرأ بقية العشرة: <q>﴿سَلامٌ﴾</q> بفتح السين واللام وألف بعدها. انظر: النشر ٢/٢٩٠، والإتحاف ص٣٢٣.عزاه السيوطي إلى أبي الشيخ.تفسير مقاتل بن سليمان ٢/٢٩٠.أخرجه ابن جرير ١٢/٤٦٨.تفسير البغوي ٤/١٨٨.أخرجه ابن أبي حاتم ٦/٢٠٥٤. وينظر: تفسير ابن كثير ٤/٣٣٣.تفسير مقاتل بن سليمان ٢/٢٩٠.أخرجه ابن جرير ١٢/٤٦٨. عزاه السيوطي إلى ابن المنذر.أخرجه ابن أبي حاتم ٦/٢٠٥٣.أخرجه ابن أبي حاتم ٦/٢٠٥٣. وسميط: مشوي. النهاية (سمط).أخرجه الطستي -كما في الإتقان ٢/٩٧-.الخَدُّ والخُدَّة والأُخدود: الحُفرة تحفرُها في الأرض مستطيلة. لسان العرب (خدد).تفسير الثعلبي ٥/١٧٨.أخرجه ابن أبي الدنيا في كتاب العقوبات -موسوعة الإمام ابن أبي الدنيا ٤/٤٦٤ (١٤٩)-. وعزاه السيوطي إلى عبد الله بن أحمد في زوائد الزهد.أخرجه ابن جرير ١٢/٤٦٨.أخرجه ابن جرير ١٢/٤٦٨.أخرجه ابن جرير ١٢/٤٧٠، وابن أبي حاتم ٦/٢٠٥٣. وعزاه السيوطي إلى ابن المنذر، وأبي الشيخ.أخرجه ابن جرير ١٢/٤٧٠.أخرجه ابن جرير ١٢/٤٦٩.الرَّضْف: الحجارة المحماة على النار. النهاية (رضف).أخرجه ابن جرير ١٢/٤٦٩.أخرجه إسحاق البستي ص ٤٢٩.أخرجه ابن أبي حاتم ٦/٢٠٥٣.أخرجه ابن جرير ١٢/٤٦٩، وابن أبي حاتم ٦/٢٠٥٣. وعزاه السيوطي إلى أبي الشيخ.أي: يُشوى على الحجارة المُحماة. لسان العرب (حنذ).أخرجه عبد الرزاق ١/٣٠٥، وابن جرير ١٢/٤٦٩.تفسير مقاتل بن سليمان ٢/٢٩٠.أخرجه ابن جرير ١٢/٤٧٠.أخرجه ابن جرير ١٢/٤٧٠.أخرجه ابن جرير في تاريخه ١/٣٠٤. وعزاه السيوطي إلى ابن المنذر.
11,70," <q>﴿فَلَمَّا رَءَاۤ أَیۡدِیَهُمۡ لَا تَصِلُ إِلَیۡهِ نَكِرَهُمۡ وَأَوۡجَسَ مِنۡهُمۡ خِیفَةࣰۚ﴾</q> - تفسير ٣٥٨٧٩- عن جندب بن سفيان -من طريق الأسود- قال: لَمّا دخل ضيفُ إبراهيم ﵇ قَرَّب إليهم العِجْل، فجعلوا يَنكُتون{1} بقِداحٍ في أيديهم مِن نَبْلٍ، ولا تصل أيديهم إليه، نكرهم عند ذلك{2}. (ز) ٣٥٨٨٠- عن عبد الله بن عباس -من طريق الضحاك- قال: لَمّا رأى إبراهيمُ أنّه لا تصل إلى العِجْل أيديهم نكِرَهم، فخافهم، وإنّما كان خوفُ إبراهيم أنّهم كانوا في ذلك الزمان إذا همَّ أحدهم بامرئٍ سوءًا لم يأكل عنده، يقول: إذا تحرَّمتُ بطعامه حَرُم عَلَيَّ أذاه. فخاف إبراهيمُ أن يريدوا به سوءًا، فاضطربت مفاصِلُه، وامرأتُه سارةُ قائِمَةٌ تخدمهم، وكان إذا أراد أن يُكرِم أضيافه أقام سارة لتخدمهم، فضحِكت سارة، وإنّما ضحكت أنّها قالت: يا إبراهيم، وما تخاف؟ إنما هم ثلاثة نفر وأنت وأهلُك وغلمانُك. قال لها جبريل: أيَّتُها الضاحكة، أما إنّك سَتَلِدين غلامًا يُقال له: إسحاق، ومِن ورائه غلامٌ يُقال له: يعقوب. فأقبلت في صَرَّةٍ فصَكَّت وجهها، فأقبلت والِهَةً تقول: يا ويلتاه. ووضعت يدها على وجهها استحياءً، فذلك قوله: <q>﴿فصكت وجهها﴾</q> [الذاريات:٢٩]. وقالت: <q>﴿ءألد وأنا عجوز وهذا بعلي شيخًا﴾</q>{3}. (٨/٩٢) ٣٥٨٨١- عن قتادة بن دعامة -من طريق مَعْمَر- في قوله: <q>﴿نكرهم﴾</q> الآية، قال: كانوا إذا نزل بهم ضيفٌ فلم يأكل مِن طعامهم ظنُّوا أنّه لم يأت بخير، وأنّه يُحَدِّث نفسَه بِشَرٍّ، ثُمَّ حدَّثوه عند ذلك بما جاءوا فيه، فضحِكت امرأتُه{4}. (٨/٩٧) ٣٥٨٨٢- عن عمرو بن دينار، قال: لَمّا تضيَّفت الملائكةُ إبراهيمَ قَدَّم لهم العِجْل، فقالوا: لا نأكلُه إلا بثَمَن. قال: فكُلوا، وأدُّوا ثمنه. قالوا: وما ثمنه؟ قال: تسمُّون اللهَ إذا أكلتم، وتحمدونه إذا فرغتم. قال: فنظر بعضهم إلى بعض، فقالوا: لهذا اتَّخذك اللهُ خليلًا{5}. (٨/٩٧) ٣٥٨٨٣- عن إسماعيل السدي -من طريق أسباط- قال: لَمّا بعث اللهُ الملائكةَ لِتُهلِك قومَ لوط أقبلتْ تمشي في صورة رجال شباب، حتى نزلوا على إبراهيم، فتضيَّفوه، فلمّا رآهم أجلَّهم، فراغ إلى أهله، فجاء بعجل سمين، فذبحه، ثم شواه في الرَّضْفِ، فهو الحنيذ حين شُوِي، وأتاهم، فقعد معهم، وقامت سارةُ تخدمهم، فذلك حين يقول: (وامْرَأَتُه قَآئِمَةٌ وهُوَ جالِسٌ) في قراءة ابن مسعود. فلمّا قرَّبه إليهم قال: ألا تأكلون؟ قالوا: يا إبراهيم، إنّا لا نأكل طعامًا إلا بثَمَن. قال: فإنّ لِهذا ثَمَنًا. قالوا: وما ثَمَنُه؟ قال: تذكرون اسمَ الله على أوَّلِه، وتحمدونه على آخره. فنظر جبريل إلى ميكائيل، فقال: حُقَّ لهذا أن يَتَّخِذَه ربُّه خليلًا. <q>﴿فلما رأى أيديهم لا تصل إليه﴾</q> يقول: لا يأكلون؛ فزِع منهم <q>﴿وأوجس منهم خيفة﴾</q>، فلمّا نظرت إليهم سارةُ أنّه قد أكرمهم وقامت هي تخدمهم ضحِكت، وقالتْ: عجبًا لأضيافِنا هؤلاء، إنّا نخدمُهم بأنفسنا تَكرمة لهم وهم لا يأكلون طعامنا!{6}. (٨/٩٧) ٣٥٨٨٤- قال مقاتل بن سليمان: <q>﴿فَلَمّا رَأى أيْدِيَهُمْ لا تَصِلُ إلَيْهِ﴾</q> أي: إلى العِجْل <q>﴿نَكِرَهُمْ﴾</q> يعني: أنكرهم، وخاف شرَّهم، <q>﴿وأَوْجَسَ مِنهُمْ خِيفَةً﴾</q> يقول: فوَقَع عليه الخوفُ منهم، فَرَعَدَ{7}. (ز) ٣٥٨٨٥- عن أبي يزيد البصري في قوله: <q>﴿فلمّا رأى أيديهم لا تصل إليه﴾</q>، قال: لم ير لهم أيدٍ، فنكِرَهم{8}. (٨/٩٧) <q>﴿قَالُوا۟ لَا تَخَفۡ إِنَّاۤ أُرۡسِلۡنَاۤ إِلَىٰ قَوۡمِ لُوطࣲ ۝٧٠﴾</q> - تفسير ٣٥٨٨٦- قال [علي بن أبي طلحة] الوالبي: لَمّا عرف إبراهيمُ أنّهم ملائكةٌ خاف أنّه وقومَه المقصودون بالعذاب؛ لأنّ الملائكة كانت تنزل إذ ذاك بالعذاب. [نظير ما في الحجر: <q>﴿ما نُنَزِّلُ المَلائِكَةَ إلّا بِالحَقِّ﴾</q> [الحجر:٨] أي: بالعذاب]. قالت الملائكة: <q>﴿لا تخف إنا أرسلنا إلى قوم لوط﴾</q> لا إلى قومك{9}. (ز) ٣٥٨٨٧- قال مقاتل بن سليمان: <q>﴿قالُوا﴾</q> أي: قالت الملائكة: <q>﴿لا تَخَفْ إنّا أُرْسِلْنا إلى قَوْمِ لُوطٍ﴾</q> بهلاكهم. ولوط ابن حازان، [وامرأتُه] سارة بنت حازان أخت لوط، وإبراهيم عم لوط وخَتَنُه على أخته{7}٣٢٤٨. (ز) ٣٢٤٨ ذكر ابنُ عطية (٤/٦١٠) أن امرأة إبراهيم ﵇ سارة هي ابنة عمِّه، ونقل قولًا ولم ينسبه: أنها أخت لوط ﵇، واستدرك عليه بدلالة التاريخ بقوله: «وما أظنُّ ذلك إلا أخوة القرابة؛ لأن إبراهيم ﵇ هو عمّ لوط ﵇ فيما روي». ",footnotes:1:أصله من النَّكْتِ بالحصى، ونَكْت الأرض بالقضيب. النهاية (نكت).أخرجه ابن جرير ١٢/٤٧١، وابن أبي حاتم ٦/٢٠٥٤.أخرجه ابن عساكر ٥٠/٣١٠، ٣١٥. وعزاه السيوطي إلى إسحاق بن بشر.أخرجه عبد الرزاق ١/٣٠٥-٣٠٦، وابن أبي حاتم ٦/٢٠٥٤. وعزاه السيوطي إلى ابن المنذر، وأبي الشيخ.عزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ١٢/٤٧٣-٤٧٤، وفي تاريخه ١/٢٤٩-٢٥٠.تفسير مقاتل بن سليمان ٢/٢٩٠.أخرجه ابن أبي حاتم ٦/٢٠٥٤.تفسير الثعلبي ٥/١٧٨. وكأن ما بين الحاصرتين من تعقيبه.تفسير مقاتل بن سليمان ٢/٢٩٠.
11,71," <q>﴿وَٱمۡرَأَتُهُۥ قَاۤىِٕمَةࣱ فَضَحِكَتۡ فَبَشَّرۡنَـٰهَا بِإِسۡحَـٰقَ وَمِن وَرَاۤءِ إِسۡحَـٰقَ یَعۡقُوبَ ۝٧١﴾</q> - قراءات ٣٥٨٨٨- عن المغيرة، قال: في مصحف ابن مسعود: (وامْرَأَتُهُ قَآئِمَةٌ وهُوَ جالِسٌ){1}. (٨/٩٩) <q>﴿وَٱمۡرَأَتُهُۥ قَاۤىِٕمَةࣱ﴾</q> - تفسير ٣٥٨٨٩- عن مجاهد بن جبر -من طريق ابن جريج- <q>﴿وامرأته قائمة﴾</q>، قال: في خِدمة أضياف إبراهيم{2}٣٢٤٩. (٨/٩٩) ٣٢٤٩ ذكر ابنُ عطية (٤/٦٠٩) هذا القول، ثم ذكر في معنى <q>﴿قائمة﴾</q> قولين آخرين: الأول: أنّ: معناه: قائمة خلف ستر تسمع محاورة إبراهيم مع أضيافه. الثاني: أنّ معناه: قائمة في صلاة. ٣٥٨٩٠- قال مقاتل بن سليمان: <q>﴿وامْرَأَتُهُ﴾</q> وهي سارة <q>﴿قائِمَةٌ﴾</q> وإبراهيم جالس{3}. (ز) <q>﴿فَضَحِكَتۡ﴾</q> - تفسير ٣٥٨٩١- عن عبد الله بن عباس -من طريق ابنه علي- <q>﴿فضحكت﴾</q>، قال: فحاضَتْ، وهي بنت ثمانٍ وتسعين سنة{4}. (٨/٩٩) ٣٥٨٩٢- قال عبد الله بن عباس= (ز) ٣٥٨٩٣- ووهب بن مُنَبِّه: ضَحِكَتْ عجبًا مِن أن يكون لها ولدٌ على كِبَر سِنِّها وسِنِّ زوجها{5}. (ز) ٣٥٨٩٤- عن عبد الله بن عمر، في قوله: قال: <q>﴿فضحكت﴾</q>: حاضت{6}. (٨/١٠٠) ٣٥٨٩٥- عن كعب الأحبار -من طريق عبد الله بن رباح-: <q>﴿إنا أرسلنا إلى قوم لوط* وامرأته قائمة فضحكت﴾</q> بخزي الله إيّاهم{7}. (ز) ٣٥٨٩٦- عن مجاهد بن جبر -من طريق ليث- في قوله: <q>﴿فضحكت﴾</q>، قال: حاضَتْ، وكانت ابنةَ بِضعٍ وتسعين سنة، وكان إبراهيمُ ابنَ مائة سنة{8}. (٨/٩٩) ٣٥٨٩٧- عن عكرمة مولى ابن عباس، في قوله: <q>﴿فضحكت﴾</q>، قال: حاضَتْ{9}. (٨/١٠٠) ٣٥٨٩٨- عن قتادة بن دعامة -من طريق معمر- قال: لَمّا أوجس إبراهيمُ خِيفَةً في نفسه حدَّثوه عند ذلك بما جاءوا فيه، فضحِكت امرأته تَعَجُّبًا مِمّا فيه قوم لوط مِن الغفلة، ومِمّا أتاهم مِن العذاب{10}. (٨/٩٩) ٣٥٨٩٩- عن إسماعيل السُّدِّيّ -من طريق أسباط- قال: لَمّا ضَحِكَتْ سارةُ وقالت: عَجَبًا لأضيافِنا هؤلاء، إنّا نخدمُهم بأنفسنا تَكرِمَةً لهم، وهم لا يأكلون طعامنا! قال لها جبريل: أبشِري بولد اسمه: إسحاق، ومن وراء إسحاق يعقوب. فضربت جبهتها عَجَبًا، فذلك قوله: <q>﴿فصكت وجهها﴾</q> [الذاريات:٢٩]، وقالت: <q>﴿ءألد وأنا عجوز وهذا بعلي شيخًا إن هذا لشيء عجيب* قالوا أتعجبين من أمر الله رحمت الله وبركاته عليكم أهل البيت إنه حميد مجيد﴾</q>. قالت سارة: ما آيةُ ذلك؟ فأخذ بيده عُودًا يابِسًا، فلواه بين أصابعه، فاهْتَزَّ أخضر، فقال إبراهيم: هو لله إذن ذبيحًا{11}. (٨/٩٧) ٣٥٩٠٠- عن محمد بن قيس -من طريق أبي معشر- في قوله: <q>﴿وامرأته قائمة فضحكت﴾</q>، قال: لَمّا جاءت الملائكة ظَنَّت أنهم يريدون أن يعملوا كما يعمل قومُ لوط{12}. (ز) ٣٥٩٠١- عن محمد بن السائب الكلبي -من طريق معمر- <q>﴿فضحكت﴾</q>، قال: ضَحِكَت حين راعَوْا إبراهيم مِمّا رَأَتْ مِن الرَّوْع بإبراهيم{13}. (ز) ٣٥٩٠٢- قال مقاتل بن سليمان: <q>﴿فَضَحِكَتْ﴾</q> مِن خوف إبراهيم ورِعْدَتِه مِن ثلاثة نفر، وإبراهيمُ في حشمه وخدمه{14}. (ز) ٣٥٩٠٣- عن محمد بن إسحاق -من طريق سلمة- قال: <q>﴿فضحكت﴾</q>، يعني: سارة؛ لِما عَرَفَتْ مِن أمر الله -جلَّ ثناؤه-، ولِما تعلمُ مِن قوم لوط{15}٣٢٥٠. (ز) ٣٢٥٠ اختُلِف في معنى الضَّحِك على قولين: الأول: أنّه الضحك المعروف. الثاني: الحيض. وانتقد ابنُ عطية (٤/٦٠٩) القول الثاني، وهو قول ابن عباس من طريق ابنه علي، وقول ابن عمر، ومجاهد، وعكرمة، فقال: «وهذا قولٌ ضعيفٌ قليل التمكن». ثُمَّ اختلف القائلون أنّه الضحك المعروف في السبب الذي من أجله ضَحِكَت على أقوال: الأول: تَعَجُّبًا مِن أنها وزوجها يخدمان الأضياف تكرمةً لهم، وهم لا يأكلون. الثاني: ضحكت من أنّ قوم لوط في غفلة وقد جاءت رسل الله بإهلاكهم. الثالث: ضحكت ظنًّا بالرسل أنهم يريدون عَمَل قوم لوط. الرابع: ضحكت لَمّا رأت ما بزوجها من الرَّوْع. الخامس: ضحكت حين بُشِّرَت بإسحاق تَعَجُّبًا مِن أن يكون لها ولد على كِبَر سنِّها وسنِّ زوجها. السادس: ضحكت سرورًا بالأمن منهم، لمّا قالوا لإبراهيم ﵇: <q>﴿لا تَخَفْ﴾</q>. ورجَّح ابنُ جرير (١٢/٤٧٨) مستندًا إلى دلالة السياق، والعقل القول الثاني، وهو قول قتادة، وعلَّل ذلك بقوله: «لأنه ذُكِر عقيب قولهم لإبراهيم: <q>﴿لا تَخَفْ إنّا أُرْسِلْنا إلى قَوْمِ لُوطٍ﴾</q>، فإذا كان ذلك كذلك، وكان لا وجْه للضحك والتعجب من قولهم لإبراهيم ﵇: <q>﴿لا تَخَفْ﴾</q>؛ كان الضحك والتعجب إنما هو مِن أمْرِ قوم لوط ﵇». وانتقد ابنُ عطية (٤/٦١٠) القول الثالث، وهو قول محمد بن قيس، فقال: «وهذا قولٌ خطأٌ، لا ينبغي أن يلتفت إليه، وقد حكاه الطبري، وإنما ذكرته لمعنى التنبيه على فساده». وانتقد ابنُ كثير (٧/٤٥٢) القول الثالث، والقول الرابع وهو قول الكلبي من طريق معمر بأنهما: «ضعيفان جدًّا، وإن كان ابنُ جرير قد رواهما بسنده إليهما، فلا يلتفت إلى ذلك». وانتقد القول الخامس، وهو قول وهب بن منبه مستندًا إلى مخالفة السياق، فقال عنه: «وهذا مخالف لهذا السياق؛ فإنّ البشارة صريحة مُرَتَّبة على ضحكها». <q>﴿فَبَشَّرۡنَـٰهَا بِإِسۡحَـٰقَ وَمِن وَرَاۤءِ إِسۡحَـٰقَ یَعۡقُوبَ ۝٧١﴾</q> - تفسير ٣٥٩٠٤- عن عبد الله بن عباس -من طريق حبيب بن أبي ثابت- في قوله: <q>﴿فبشرناها بإسحاق ومن ورآء إسحاق يعقوب﴾</q>، قال: هو ولَدُ الوَلَد{16}. (٨/١٠١) ٣٥٩٠٥- عن حسان بن الحُرِّ، قال: كنتُ عند ابن عباس، فجاءه رجل مِن هُذَيْل، فقال له ابن عباس: ما فعل فلان؟ قال: مات وترك أربعةً من الولد، وثلاثة مِن الوراء. فقال ابن عباس: <q>﴿فبشرناها بإسحاق ومن ورآء إسحاق يعقوب﴾</q>، قال: ولد الولد{17}. (٨/١٠١) ٣٥٩٠٦- عن كعب الأحبار -من طريق عبد الله بن رباح- قال: بَلَغَنا: أنّ إبراهيم ﵇ كان يُشْرِف على سدوم، فيقول: ويلكِ، سدوم، يومٌ ما لَكِ! ثم قال: <q>﴿ولقد جاءت رسلنا إبراهيم بالبشرى قالوا سلامًا قال سلام فما لبث أن جاء بعجل حنيذ﴾</q>: نضيج، وهو يحسبهم أضيافًا، <q>﴿فبشرناها بإسحاق ومن وراء إسحاق يعقوب﴾</q> قال: ولدًا لولد، <q>﴿قالت يا ويلتى ءألد وأنا عجوز وهذا بعلي شيخًا إن هذا لشيء عجيب﴾</q>. فقال لها جبريل: <q>﴿أتعجبين من أمر الله رحمت الله وبركاته عليكم أهل البيت إنه حميد مجيد﴾</q>{18}. (٨/٩٠) ٣٥٩٠٧- عن عامر الشعبي -من طريق داود- في قوله: <q>﴿ومن وراء إسحاق يعقوب﴾</q>، قال: ولد الولد{19}. (٨/١٠١) ٣٥٩٠٨- عن أبي اليسع إسماعيل بن حماد بن أبي المغيرة مولى الأشعري، قال: كنتُ إلى جنب جدِّي أبي المغيرة بن مهران في مسجد علي بن زيد، فمَرَّ بنا الحسن بن أبي الحسن، فقال: يا أبا المغيرة، مَن هذا الفتى؟ قال: ابني مِن ورائي. فقال الحسن: <q>﴿فبشرناها بإسحاق ومن وراء إسحاق يعقوب﴾</q>{20}. (ز) ٣٥٩٠٩- عن قتادة بن دعامة -من طريق سعيد بن بشير- في قوله: <q>﴿فبشرناها بإسحاق﴾</q> بابنها{2}. (ز) ٣٥٩١٠- قال إسماعيل السُّدِّيّ -من طريق أسباط-: لَمّا ضحِكت سارة وقالت: عجبًا لأضيافنا هؤلاء، إنّا نخدمهم بأنفسنا تكرِمةً لهم، وهم لا يأكلون طعامنا! قال لها جبريل: أبشِري بولدٍ اسمه: إسحاق، ومن وراء إسحاق يعقوب. فضربت وجهها عجبًا، فذلك قوله: <q>﴿فَصَكَّتْ وجْهَها﴾</q> [الذاريات:٢٩]{22}. (ز) ٣٥٩١١- قال محمد بن السائب الكلبي: <q>﴿فضحكت﴾</q>، لَمّا رأت سارةُ فَرَق إبراهيم عَجِبَتْ مِن فَرَقِه، فضَحِكَت وهي لا تدري مَنِ القوم، فبشروها بإسحاق، وقالوا: نرجع إليك عامًا قابِلًا وقد ولدت لإبراهيم غلامًا اسمه: إسحاق، ويكون مِن وراء إسحاق يعقوب. أي: من بعد إسحاق{23}. (ز) ٣٥٩١٢- قال مقاتل بن سليمان: ... فقال جبريل ﵇ لسارة: إنّكِ سَتَلِدِين غلامًا، فذلك قوله: <q>﴿فَبَشَّرْناها بِإسْحاقَ ومِن وراءِ إسْحاقَ يَعْقُوبَ﴾</q>{14}. (ز) ٣٥٩١٣- عن محمد بن إسحاق -من طريق سلمة- قال: ... فبشروها بإسحاق، ومِن وراء إسحاق يعقوب؛ بابنٍ، وبابن ابن، فقالت وصكَّت وجهها -يُقال: ضربت على جبينها-: <q>﴿يا ويلتى أألد وأنا عجوز﴾</q> إلى قوله: <q>﴿إنه حميد مجيد﴾</q>{25}. (ز) <q>﴿فَبَشَّرۡنَـٰهَا بِإِسۡحَـٰقَ وَمِن وَرَاۤءِ إِسۡحَـٰقَ یَعۡقُوبَ ۝٧١﴾</q> - آثار متعلقة بالآية ٣٥٩١٤- عن علي بن أبي طالب: أنّ سارة بنت ملك مِن الملوك، وكانت قد أُوتِيَت حُسْنًا{26}. (٨/١٠١) ٣٥٩١٥- عن عبد الله بن عباس -من طريق الكلبي، عن أبي صالح- قال: كان حُسْنُ سارةَ حُسْنَ حواءَ ﵍{27}. (٨/١٠٠) ٣٥٩١٦- عن الضحاك بن مزاحم -من طريق مقاتل- قال: كان اسمُ سارة: يسارة، فلمّا قال لها جبريل ﵇: يا سارة. قالت: إنّ اسمي يسارة، فكيف تُسمِّيني سارة؟! قال الضحاك بن مزاحم: يسارة: العاقِرُ التي لا تلد، وسارة: الطالق الرَّحِم التي تلد. فقال لها جبريل ﵇: كنتِ يسارةً لا تحملين، فصِرتِ سارةً تحمِلين الولد وتُرضعينه. فقالت سارة: يا جبريل، نقصت اسمي. قال جبريل: إنّ الله قد وعدكِ بأن يجعل هذا الحرفَ في اسمِ ولدٍ مِن ولدك في آخر الزمان، وذلك أن اسمه عند الله حيي، فسمّاه: يحيى{28}. (٨/١٠٠) ",footnotes:1:عزاه السيوطي إلى ابن المنذر. وهي قراءة شاذة. انظر: البحر المحيط ٥/٢٤٣.أخرجه ابن أبي حاتم ٦/٢٠٥٥.تفسير مقاتل بن سليمان ٢/٢٩٠.أخرجه ابن أبي حاتم ٦/٢٠٥٥. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وأبي الشيخ. وعزاه الحافظ ابن حجر في الفتح ١/٤٠٠ إلى ابن جرير مختصرًا.تفسير الثعلبي ٥/١٧٩، وتفسير البغوي ٤/١٨٩.عزاه السيوطي إلى أبي الشيخ. وجاء عقبه: "قال الشاعر: إني لآتي العُرسَ عند طُهورِها وأهجرُها يومًا إذا تَكُ ضاحك" ولا يظهر أن هذا من قول ابن عمر، وكأنّ في النص سقطًا، أو أنه تابع لأثر عكرمة الآتي كما في طبعات الدر السابقة.أخرجه ابن أبي حاتم ٦/٢٠٥٤.أخرجه ابن جرير ١٢/٤٧٦.عزاه السيوطي إلى أبي الشيخ.أخرجه عبد الرزاق ١/٣٠٦، وابن جرير ١٢/٤٧٤، وابن أبي حاتم ٦/٢٠٥٤. وعزاه السيوطي إلى ابن المنذر، وأبي الشيخ.أخرجه ابن جرير ١٢/٤٨٠-٤٨١، وفي تاريخه ١/٢٧٢-٢٧٣.أخرجه ابن جرير ١٢/٤٧٥.أخرجه عبد الرزاق ١/٣٠٦، وابن جرير ١٢/٤٧٥. وذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٢/٢٩٩-.تفسير مقاتل بن سليمان ٢/٢٩٠-٢٩١.أخرجه ابن جرير ١٢/٤٨١، وابن أبي حاتم ٦/٢٠٥٥.أخرجه ابن جرير ١٢/٤٨٠، وابن أبي حاتم ٦/٢٠٥٦. وعزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ١٢/٤٨٠. وعزاه السيوطي إلى ابن الأنباري في كتاب الوقف والابتداء.أخرجه ابن أبي الدنيا في كتاب العقوبات -موسوعة الإمام ابن أبي الدنيا ٤/٤٦٤ (١٤٩)-. وعزاه السيوطي إلى عبد الله بن أحمد في زوائد الزهد.أخرجه ابن أبي الدنيا في كتاب الأشراف -موسوعة الإمام ابن أبي الدنيا ٨/٣١٣ (٤٥٣)-، وابن جرير ١٢/٤٨٠، وابن أبي حاتم ٦/٢٠٥٦. وعزاه السيوطي إلى ابن الأنباري.أخرجه ابن جرير ١٢/٤٧٩.أخرجه ابن أبي حاتم ٦/٢٠٥٥.أخرجه ابن جرير ١٢/٤٨٠.ذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٢/٢٩٩-.تفسير مقاتل بن سليمان ٢/٢٩٠-٢٩١.أخرجه ابن جرير ١٢/٤٨١.أخرجه ابن عبد الحكم في فتوح مصر ص١١.أخرجه ابن عبد الحكم في فتوح مصر ص١٠.أخرجه ابن عساكر ٦٩/١٨١.
