tafsir[11]{c,v,t}:
20,77," <q>﴿وَلَقَدۡ أَوۡحَیۡنَاۤ إِلَىٰ مُوسَىٰۤ أَنۡ أَسۡرِ بِعِبَادِی﴾</q> - تفسير ٤٨٠١١- قال مقاتل بن سليمان: <q>﴿ولقد أوحينا إلى موسى أن أسر بعبادي﴾</q> ليلًا بأرض مصر{1}. (ز) ٤٨٠١٢- قال يحيى بن سلّام: قوله: <q>﴿ولقد أوحينا إلى موسى أن أسر بعبادي﴾</q>، أي: ليلًا{2}. (ز) <q>﴿فَٱضۡرِبۡ لَهُمۡ طَرِیقࣰا فِی ٱلۡبَحۡرِ یَبَسࣰا﴾</q> - تفسير ٤٨٠١٣- عن مجاهد بن جبر -من طريق ابن أبي نَجِيح- في قوله: <q>﴿طريقا في البحر يبسا﴾</q>، قال: يابسًا{3}. (١٠/٢٢٣) ٤٨٠١٤- قال الحسن البصري، في قوله: <q>﴿فاضرب لهم طريقا في البحر يبسا﴾</q>: أتاه جبريلُ على فرس، فأمره أن يضرب البحر بعصاه، فصار طريقًا يبسًا{4}٤٢٩٢. (ز) ٤٢٩٢ ذكر ابنُ عطية (٦/١١٤) اختلافًا في تحديد الوقت الذي أوحى الله فيه لموسى أن يضرب البحر بعصاه، فذكر قولًا أن ذلك كان ساعة مباشرته البحر، وذكر قولًا آخر أن ذلك الوحي كان متقدمًا على ذلك. وقد رجّح مستندًا إلى ظاهر الآية القول الثاني، فقال: «... ويروى أنّ الوحي إليه بذلك كان متقدمًا بمصر، وهو ظاهر الآية». ٤٨٠١٥- عن محمد بن كعب القرظي، في قوله: <q>﴿فاضرب لهم طريقا في البحر يبسا﴾</q>، قال: يابِسًا، ليس فيه ماء ولا طين{5}. (١٠/٢٢٣) ٤٨٠١٦- عن محمد بن إسحاق -من طريق عبيد الله بن سعد القرشي، عن عمِّه، عن أبيه- في قوله: <q>﴿فانفلق فكان كل فرق كالطود العظيم﴾</q> [الشعراء:٦٣]، قال: عن يَبَس مِن الأرض. يقول الله ﷿ لموسى: <q>﴿فاضرب لهم طريقا في البحر يبسا لا تخاف دركا ولا تخشى﴾</q>، فلما شقَّ له البحر عن طريق قاعه يَبِسَ تَلا موسى ببني إسرائيل، فاتبعه فرعون وجنوده{6}. (ز) ٤٨٠١٧- قال يحيى بن سلّام: <q>﴿فاضرب لهم طريقا في البحر يبسا﴾</q>... بلغني: أنّه صار اثني عشر طريقًا، لكل سِبْطٍ طريق{2}. (ز) <q>﴿لَّا تَخَـٰفُ دَرَكࣰا وَلَا تَخۡشَىٰ ۝٧٧﴾</q> - تفسير ٤٨٠١٨- عن عبد الله بن عباس -من طريق علي- في قوله: <q>﴿لا تخاف دركا﴾</q> قال: مِن آل فرعون، <q>﴿ولا تخشى﴾</q> مِن البحر غرقًا{8}. (١٠/٢٢٣) ٤٨٠١٩- عن قتادة بن دعامة -من طريق سعيد- <q>﴿لا تخاف دركا ولا تخشى﴾</q>، يقول: لا تخاف أن يدركك فرعون مِن بعدِك، ولا تخشى الغرق أمامك{9}. (ز) ٤٨٠٢٠- قال مقاتل بن سليمان: <q>﴿لا تخاف دركا﴾</q> مِن آل فرعون مِن ورائك، <q>﴿ولا تخشى﴾</q> الغرق في البحر أمامك؛ لأنّ بني إسرائيل قالوا لموسى: هذا فرعون قد لحقنا بالجنود، وهذا في البحر قد غشينا، فليس لنا منفذ. فنزلت: <q>﴿لا تخاف دركا ولا تخشى﴾</q> أوْجَبَ ذلك على نفسه تعالى{1}. (ز) ٤٨٠٢١- عن عبد الملك ابن جريج -من طريق حجّاج- قال: قال أصحاب موسى: هذا فرعون قد أدركنا، وهذا البحر قد عَمَّنا. فأنزل الله: <q>﴿ولا تخاف دركا﴾</q> مِن آل فرعون، <q>﴿ولا تخشى﴾</q> مِن البحر غرقًا ولا وحَلًا{11}{12}. (١٠/٢٢٣) ",footnotes:1:تفسير مقاتل بن سليمان ٣/٣٤.تفسير يحيى بن سلّام ١/٢٦٨.أخرجه ابن جرير ١٦/١٢١. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.علَّقه يحيى بن سلّام ١/٢٦٨.عزاه السيوطي إلى سعيد بن منصور، وابن المنذر، وابن أبي حاتم.أخرجه ابن أبي الدنيا في كتاب العقوبات -موسوعة ابن أبي الدنيا ٤/٤٩٥-٤٩٦ (٢٤٦)-.تفسير يحيى بن سلّام ١/٢٦٨.أخرجه ابن جرير ١٦/١٢١. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.أخرجه يحيى بن سلّام ١/٢٦٩، وابن جرير ١٦/١٢١.تفسير مقاتل بن سليمان ٣/٣٤.أي: وقوعًا في الوَحَل؛ أي: الطين. النهاية (وحل).أخرجه ابن جرير ١٦/١٢٢. وعزاه السيوطي إلى ابن المنذر.
20,78," <q>﴿فَأَتۡبَعَهُمۡ فِرۡعَوۡنُ بِجُنُودِهِۦ﴾</q> - تفسير ٤٨٠٢٢- قال وهب بن مُنَبِّه: استعار بنو إسرائيل حليًّا كثيرًا مِن القبط، ثم خرج بهم موسى في أول الليل، وكانوا سبعين ألفًا، فأُخْبِر فرعونُ بذلك، فركب في ستمائة ألف مِن القِبْط، يقصُّ أثرَ موسى{1}. (ز) ٤٨٠٢٣- قال يحيى بن سلّام: قوله: <q>﴿فأتبعهم فرعون بجنوده﴾</q>، وكان جميعُ جنوده أربعين ألف ألف{2}٤٢٩٣. (ز) ٤٢٩٣ قال ابنُ عطية (٦/١١٤): «واختلف الناس في عدد جند فرعون؛ فقيل: كان في خيله سبعون ألف أدهم، ونسبة ذلك من سائر الألوان. وقيل أكثر من هذا مِمّا اختصرته؛ لقِلَّة صِحَّته». <q>﴿فَغَشِیَهُم مِّنَ ٱلۡیَمِّ مَا غَشِیَهُمۡ ۝٧٨﴾</q> - تفسير ٤٨٠٢٤- عن إسماعيل السُّدِّيّ، في قوله: <q>﴿فغشيهم من اليم﴾</q>، قال: البحر{3}. (١٠/٢٢٣) ٤٨٠٢٥- قال مقاتل بن سليمان: <q>﴿فأتبعهم فرعون بجنوده فغشيهم من اليم ما غشيهم﴾</q>، يعني: الغرق{4}. (ز) ٤٨٠٢٦- قال يحيى بن سلّام: <q>﴿فغشيهم من اليم ما غشيهم﴾</q>، واليم: البحر، فغرقوا{2}. (ز) ",footnotes:1:تفسير الثعلبي ٦/٢٥٥.تفسير يحيى بن سلّام ١/٢٦٩.أخرجه ابن أبي حاتم -كما في فتح الباري ٨/٤٣٤-.تفسير مقاتل بن سليمان ٣/٣٤.تفسير يحيى بن سلّام ١/٢٦٩.
20,79," <q>﴿وَأَضَلَّ فِرۡعَوۡنُ قَوۡمَهُۥ وَمَا هَدَىٰ ۝٧٩﴾</q> - تفسير ٤٨٠٢٧- قال مقاتل بن سليمان: <q>﴿وأضل فرعون قومه﴾</q> القبط، <q>﴿وما هدى﴾</q> يقول: وما هداهم، وذلك أنّ فرعون قال لقومه في «حم المؤمن»: <q>﴿ما أريكم إلا ما أرى وما أهديكم إلا سبيل الرشاد﴾</q> [غافر:٢٩]، فأضَّلَّهم ولم يَهْدِهم، فذلك قوله ﷿: <q>﴿وما هدى﴾</q>{1}. (ز) ٤٨٠٢٨- قال يحيى بن سلّام: <q>﴿وأضل فرعون قومه وما هدى﴾</q> ما هداهم{2}. (ز) ",footnotes:1:تفسير مقاتل بن سليمان ٣/٣٤.تفسير يحيى بن سلّام ١/٢٦٩.
20,80," <q>﴿یَـٰبَنِیۤ إِسۡرَ ٰ⁠ۤءِیلَ قَدۡ أَنجَیۡنَـٰكُم مِّنۡ عَدُوِّكُمۡ وَوَ ٰ⁠عَدۡنَـٰكُمۡ جَانِبَ ٱلطُّورِ ٱلۡأَیۡمَنَ وَنَزَّلۡنَا عَلَیۡكُمُ ٱلۡمَنَّ وَٱلسَّلۡوَىٰ ۝٨٠﴾</q> - قراءات ٤٨٠٢٩- عن الأعمش: في قراءة عبد الله [بن مسعود]: (قَدْ نَجَّيْتُكُم مِّنْ عَدُوِّكُمْ){1}. (ز) <q>﴿یَـٰبَنِیۤ إِسۡرَ ٰ⁠ۤءِیلَ قَدۡ أَنجَیۡنَـٰكُم مِّنۡ عَدُوِّكُمۡ وَوَ ٰ⁠عَدۡنَـٰكُمۡ جَانِبَ ٱلطُّورِ ٱلۡأَیۡمَنَ﴾</q> - تفسير ٤٨٠٣٠- قال مقاتل بن سليمان: <q>﴿يابني إسرائيل قد أنجيناكم من عدوكم﴾</q> فرعون وقومه، <q>﴿وواعدناكم جانب الطور الأيمن﴾</q> يعني: حين سار موسى مع السبعين عن يمين الجبل، فأُعْطي التوراة{2}٤٢٩٤. (ز) ٤٢٩٤ ذكر ابنُ عطية (٦/١١٦) اختلافا في المخاطب بقوله: <q>﴿يا بني إسرائيل قد أنجيناكم﴾</q> على قولين: الأول: أن الخطاب به وُجِّه لبني إسرائيل أيام موسى. الثاني: أن الخطاب به مُوَجَّه لمعاصري رسول الله ﷺ مِن بني إسرائيل. ورجّح ابنُ عطية مستندًا إلى ظاهر الآية القولَ الأول بقوله: «والمعنى الأول أظهر وأبين». وبيّن أن الآية على القول الثاني «تكون اعتراضًا في أثناء قصة موسى، القَصْدُ به: توبيخ هؤلاء الحضور؛ إذ لم يصبر سلفهم على أداء شكر نعم الله تعالى». ٤٨٠٣١- قال يحيى بن سلّام: قوله: <q>﴿يا بني إسرائيل قد أنجيناكم من عدوكم﴾</q> مِن فرعون وقومه، <q>﴿وواعدناكم جانب الطور الأيمن﴾</q> أيمن الجبل، والطور هو الجبل، يعني: مواعدته لموسى{3}. (ز) <q>﴿وَنَزَّلۡنَا عَلَیۡكُمُ ٱلۡمَنَّ وَٱلسَّلۡوَىٰ ۝٨٠﴾</q> - تفسير ٤٨٠٣٢- عن الضحاك بن مزاحم -من طريق قرة بن خالد- قال: السلوى: السُّمانى{4}. (ز) ٤٨٠٣٣- عن الحسن البصري -من طريق الحسن بن دينار- قال: السلوى: السُّمانى{4}. (ز) ٤٨٠٣٤- عن قتادة بن دعامة -من طريق سعيد- قوله: <q>﴿ونزلنا عليكم المن والسلوى﴾</q>، قال: المَنُّ كان ينزل عليهم في محلتهم مثل العسل، من طلوع الفجر إلى طلوع الشمس، والسلوى هو الطير الذي يُقال له: السُّمانى{4}. (ز) ٤٨٠٣٥- قال مقاتل بن سليمان: <q>﴿ونزلنا عليكم المن والسلوى﴾</q> في التِّيه، أما المَنُّ: فالتَّرَنجَبِينُ، كان بين أعينهم بالليل على شجرهم أبيض كأنه الثلج، حلو مثل العسل، فيغدون عليه، فيأخذون منه ما يكفيهم يومَهم ذلك، ولا يرفعون منه لغد، ويأخذون يوم الجمعة ليومين؛ لأنّ السبت كان عندهم لا يسيحون فيه، ولا يعملون فيه، هذا لهم وهم في التِّيه مع موسى ﵇. وأما السلوى وهو الطير، وذلك أنّ بني إسرائيل سألوا موسى اللحم وهم في التِّيه، فسأل موسى ﵇ ربه ﷿ ذلك، فقال الله: لأطعمنهم أقلَّ الطير لحمًا. فبعث الله سبحانه سحابًا، فأمطرت سُمانًا، وجمعتهم الريحُ الجنوب، وهي طير حمر تكون في طريق مصر، فمَطَرَتْ قدر ميل في عرض الأرض، وقدر طول رُمْح في السماء{7}. (ز) ",footnotes:1:أخرجه ابن أبي داود في المصاحف ١/٣٢٣. و(قَدْ نَجَّيْتُكُم) قراءة شاذة.تفسير مقاتل بن سليمان ٣/٣٥.تفسير يحيى بن سلّام ١/٢٦٩.أخرجه يحيى بن سلّام ١/٢٦٩.أخرجه يحيى بن سلّام ١/٢٦٩.أخرجه يحيى بن سلّام ١/٢٦٩.تفسير مقاتل بن سليمان ٣/٣٥. وقد تقدمت الآثار مفصلة في معنى المن والسلوى في تفسير قوله تعالى: <q>﴿وظَلَّلْنا عَلَيْكُمُ الغَمامَ وأَنْزَلْنا عَلَيْكُمُ المَنَّ والسَّلْوى﴾</q> [البقرة:٥٧].
20,81," <q>﴿كُلُوا۟ مِن طَیِّبَـٰتِ مَا رَزَقۡنَـٰكُمۡ﴾</q> - تفسير ٤٨٠٣٦- قال إسماعيل السدي: <q>﴿من طيبات ما رزقناكم﴾</q>، يعني: مِن الحلال؛ المن والسلوى{1}. (ز) ٤٨٠٣٧- قال مقاتل بن سليمان: يقول الله -تعالى ذِكْرُه-: <q>﴿كلوا من طيبات ما رزقناكم﴾</q>، يعني: بالطيبات الحلال مِن الرزق{2}. (ز) ٤٨٠٣٨- قال يحيى بن سلّام: قوله: <q>﴿كلوا من طيبات ما رزقناكم﴾</q> المن والسلوى{3}. (ز) <q>﴿وَلَا تَطۡغَوۡا۟ فِیهِ﴾</q> - تفسير ٤٨٠٣٩- عن عبد الله بن عباس -من طريق علي- في قوله: <q>﴿ولا تطغوا فيه﴾</q>، يقول: لا تظلِموا{4}٤٢٩٥. (١٠/٢٢٣) ٤٢٩٥ لم يذكر ابنُ جرير (١٩/١٢٥) غير قول ابن عباس. ٤٨٠٤٠- تفسير إسماعيل السُّدِّيّ: <q>﴿ولا تطغوا فيه﴾</q>، يعني: لا تعصوا الله في رفع المنِّ والسلوى{5}. (ز) ٤٨٠٤١- قال محمد بن السائب الكلبي: لا تكفروا النعمة؛ فتكونوا طاغين{6}. (ز) ٤٨٠٤٢- قال مقاتل بن سليمان: <q>﴿ولا تطغوا فيه﴾</q>، يقول: ولا تعصوا في الرزق، يعني: فيما رزقناكم من المن والسلوى فترفعوا منه لغد، وكان الله سبحانه قد نهاهم أن يرفعوا منه لِغَد، فعصوا الله ﷿، ورفعوا منه، وقدَّدُوا، فَتَدَوَّدَ ونَتَنَ، ولولا صنيع بني إسرائيل لم يتغير الطعام أبدًا، ولولا حواء زوج آدم ﵉ لم تخن أنثى زوجُها الدهرَ، فذلك قوله: <q>﴿ولا تطغوا فيه﴾</q>، كقوله تعالى لفرعون: <q>﴿إنه طغى﴾</q> [طه:٢٤]، يعني: عصى{2}. (ز) ٤٨٠٤٣- عن عبد الرحمن بن زيد بن أسلم، في قوله: <q>﴿ولا تطغوا فيه﴾</q>، قال: الطغيان فيه أن يأخذه بغير حِلِّهِ{8}. (١٠/٢٢٤) <q>﴿فَیَحِلَّ عَلَیۡكُمۡ غَضَبِیۖ﴾</q> - قراءات ٤٨٠٤٤- قال يحيى بن سلّام: وهي تُقْرَأ على وجه آخر: ‹فَيَحُلَّ عَلَيْكُمْ غَضَبِي›{9}. (ز) <q>﴿فَیَحِلَّ عَلَیۡكُمۡ غَضَبِیۖ﴾</q> - تفسير الآية ٤٨٠٤٥- عن قتادة بن دعامة -من طريق مَعْمَر- في قوله: <q>﴿فيحل عليكم غضبي﴾</q>، قال: فينزل عليكم غضبي{10}٤٢٩٦. (١٠/٢٢٤) ٤٢٩٦ لم يذكر ابنُ جرير (١٦/١٢٥) غير قول قتادة. ٤٨٠٤٦- عن قتادة بن دعامة -من طريق سعيد- <q>﴿فيحل عليكم غضبي﴾</q>، قال: يعني: فيجب عليكم غضبي {11}. (ز) ٤٨٠٤٧- قال يحيى بن سلّام: وهي تقرأ على وجه آخر: ‹فيَحُلَّ عليكم غضبي›، أي: فينزل عليكم غضبي{12}. (ز) ٤٨٠٤٨- قال مقاتل بن سليمان: <q>﴿فيحل عليكم غضبي﴾</q>، يعني: فيجب عليكم عذابي{2}. (ز) <q>﴿وَمَن یَحۡلِلۡ عَلَیۡهِ غَضَبِی﴾</q> - قراءات ٤٨٠٤٩- عن سليمان بن مهران الأعمش أنه قرأ: <q>﴿مَن يَحْلِلْ عَلَيْهِ غَضَبِي﴾</q> بكسر اللام، على تفسير: من يجب عليه غضبي{14}. (١٠/٢٢٤) <q>﴿وَمَن یَحۡلِلۡ عَلَیۡهِ غَضَبِی﴾</q> - تفسير الآية ٤٨٠٥٠- عن أبي مِجْلِزٍ لاحق بن حميد، في قوله: <q>﴿ومَن يَحْلِلْ عَلَيْهِ غَضَبِي﴾</q>، قال: إن غَضَبَهُ خَلْقٌ مِن خَلْقِهِ، يدعوه فيُكَلِّمه{8}. (١٠/٢٢٤) ٤٨٠٥١- قال يحيى بن سلّام: <q>﴿ومَن يَحْلِلْ عَلَيْهِ غَضَبِي﴾</q>، هو مثل الحرف الأول= (ز) ٤٨٠٥٢- إلا أنّ قتادة قال: ومَن ينزل عليه غضبي{12}. (ز) ٤٨٠٥٣- قال مقاتل بن سليمان: <q>﴿فَيَحِلَّ عَلَيْكُمْ غَضَبِي﴾</q> يعني: فيجب عليكم عذابي، <q>﴿ومَن يَحْلِلْ عَلَيْهِ غَضَبِي﴾</q> عذابي{2}. (ز) <q>﴿فَقَدۡ هَوَىٰ ۝٨١﴾</q> - تفسير ٤٨٠٥٤- عن عبد الله بن عباس -من طريق علي- في قوله: <q>﴿فقد هوى﴾</q>، قال: شَقِيَ{18}٤٢٩٧. (١٠/٢٢٤) ٤٢٩٧ لم يذكر ابنُ جرير (١٦/١٢٦) غير قول ابن عباس. ٤٨٠٥٥- عن شُفَيِّ بن ماتع الأصبحي -من طريق أيوب بن بشير- قال: وإنّ في جهنم قصرًا يُقال له: هوى، يُرْمى الكافر مِن أعلاه، فيهوي في جهنم أربعين خريفًا قبل أن يبلغ أصله. قال الله جل وعز: <q>﴿ومن يحلل عليه غضبي فقد هوى﴾</q>{19}. (١٠/٢٢٤) ٤٨٠٥٦- قال إسماعيل السُّدِّيّ: يعني: فقد هلك{20}. (ز) ٤٨٠٥٧- قال مقاتل بن سليمان: <q>﴿فقد هوى﴾</q>، يقول: ومَن وجَب عليه عذابي فقد هلك{2}. (ز) ٤٨٠٥٨- قال يحيى بن سلّام: قوله: <q>﴿فقد هوى﴾</q> في النار{12}. (ز) ",footnotes:1:علَّقه يحيى بن سلّام ١/٢٦٩.تفسير مقاتل بن سليمان ٣/٣٥.تفسير يحيى بن سلّام ١/٢٦٩.أخرجه ابن جرير ١٦/١٢٥. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.علَّقه يحيى بن سلّام ١/٢٦٩، وذكر عقِبَه قول قتادة من طريق سعيد، قال: كانوا لا يأخذون منه لغد؛ لأنه كان يفسد عندهم، ولا يبقى إلا يوم الجمعة، فإنهم كانوا يأخذون ليوم الجمعة والسبت؛ لأنهم كانوا يتفرغون في السبت للعبادة، ولا يعملون شيئًا.تفسير الثعلبي ٦/٢٥٦، وتفسير البغوي ٥/٢٨٧.تفسير مقاتل بن سليمان ٣/٣٥.عزاه السيوطي إلى ابن أبي حاتم.تفسير يحيى بن سلّام ١/٢٧٠. و‹فَيَحُلَّ› بضم الحاء قراءة متواترة، قرأ بها الكسائي، وقرأ بقية العشرة: <q>﴿فَيَحِلَّ﴾</q> بكسر الحاء. انظر: النشر ٢/٣٢١، والإتحاف ص٣٨٧.أخرجه عبد الرزاق ٢/١٨، وابن جرير ١٦/١٢٥ من طريق سعيد. وعزاه السيوطي إلى عبد بن حميد، وابن أبي حاتم.أخرجه يحيى بن سلّام ١/٢٧١.تفسير يحيى بن سلّام ١/٢٧٠.تفسير مقاتل بن سليمان ٣/٣٥.عزاه السيوطي إلى ابن أبي حاتم. <q>﴿ومَن يَحْلِلْ﴾</q> بكسر اللام الأولى قراءة العشرة ما عدا الكسائي؛ فإنه قرأ: <q>﴿ومَن يَحْلُلْ﴾</q> بضمها. انظر: النشر ٢/٣٢١، والإتحاف ص٣٨٧.عزاه السيوطي إلى ابن أبي حاتم.تفسير يحيى بن سلّام ١/٢٧٠.تفسير مقاتل بن سليمان ٣/٣٥.أخرجه ابن جرير ١٦/١٢٦، وابن أبي حاتم -كما في تغليق التعليق ٤/٢٥٦، والإتقان ٢/٢٨-. وعزاه السيوطي إلى ابن المنذر.أخرجه ابن أبي الدنيا مطولًا في كتاب صفة النار -موسوعة ابن أبي الدنيا ٦/٤٠٧ (٣٧)-، وابن أبي حاتم -كما في تفسير ابن كثير ٥/٣٠١-.علقه يحيى بن سلّام ١/٢٧٠.تفسير مقاتل بن سليمان ٣/٣٥.تفسير يحيى بن سلّام ١/٢٧٠.
20,82," <q>﴿وَإِنِّی لَغَفَّارࣱ لِّمَن تَابَ وَءَامَنَ وَعَمِلَ صَـٰلِحࣰا﴾</q> - تفسير ٤٨٠٥٩- عن عبد الله بن عباس -من طريق علي- <q>﴿وإني لغفار لمن تاب﴾</q> قال: مِن الشرك، <q>﴿وآمن﴾</q> قال: وحَّد الله، <q>﴿وعمل صالحا﴾</q> قال: أدّى الفرائض{1}. (١٠/٢٢٤) ٤٨٠٦٠- عن عبد الله بن عباس، في قوله: <q>﴿وإني لغفار﴾</q> الآية، قال: لِمَن تاب من الذنب، وآمَن مِن الشرك، و[عمل] عملًا صالحًا فيما بينه وبين ربه{2}. (١٠/٢٢٥) ٤٨٠٦١- تفسير الحسن البصري -من طريق الحسن بن دينار- قوله: <q>﴿وإني لغفار لمن تاب﴾</q> مِن الشرك، <q>﴿وآمن﴾</q> أي: أخلص الإيمان لله، <q>﴿وعمل صالحا﴾</q> في إيمانه{3}. (ز) ٤٨٠٦٢- عن قتادة بن دعامة -من طريق سعيد- قوله: <q>﴿وإني لغفار لمن تاب﴾</q> مِن ذنبه، <q>﴿وآمن﴾</q> بربه، <q>﴿وعمل صالحا﴾</q> فيما بينه وبين الله{4}. (ز) ٤٨٠٦٣- عن الربيع بن أنس -من طريق أبي جعفر الرازي-: <q>﴿وإني لغفار لمن تاب﴾</q> مِن الشرك، <q>﴿وآمن﴾</q> يقول: وأخلص لله، وعمل في إخلاصه{4}. (ز) ٤٨٠٦٤- عن زيد بن أسلم -من طريق هشام بن سعد- قال: لا بُدَّ لأهل هذا الدِّين مِن أربع: دخول في دعوة الإسلام، ولا بُدَّ مِن الإيمان وتصديق بالله وبالمرسلين أولهم وآخرهم، وبالجنة والنار، والبعث بعد الموت، ولا بد مِن أن تعمل عملًا تَصدُق به، ولا بد مِن أن تَعْلَم عِلْمًا يحسُن به عَمَلُك. ثم قرأ: <q>﴿وإني لغفار لمن تاب وآمن وعمل صالحا ثم اهتدى﴾</q>{6}. (ز) ٤٨٠٦٥- عن محمد بن السائب الكلبي -من طريق عنبسة-: <q>﴿وإني لغفار لمن تاب﴾</q> من الذنب، <q>﴿وآمن﴾</q> مِن الشرك، <q>﴿وعمل صالحا﴾</q> أدّى ما افترضت عليه{7}. (ز) ٤٨٠٦٦- قال مقاتل بن سليمان: <q>﴿وإني لغفار لمن تاب﴾</q> مِن الشرك عن عبادة العجل، <q>﴿وآمن﴾</q> يعني: وصدَّق بتوحيد الله ﷿{8}. (ز) ٤٨٠٦٧- عن سفيان الثوري، في قوله: <q>﴿لمن تاب وآمن وعمل صالحا ثم اهتدى﴾</q>، قال: <q>﴿تاب﴾</q> مِن الذنوب، <q>﴿وآمن﴾</q> مِن الشرك، <q>﴿وعمل صالحا ثم اهتدى﴾</q> صام وصلّى، وعرف أنّ لها ثوابًا{9}. (ز) <q>﴿ثُمَّ ٱهۡتَدَىٰ ۝٨٢﴾</q> - تفسير ٤٨٠٦٨- عن عبد الله بن عباس -من طريق علي- <q>﴿ثم اهتدى﴾</q>، قال: لم يَشْكُك{1}. (١٠/٢٢٤) ٤٨٠٦٩- عن عبد الله بن عباس، في قوله: <q>﴿ثم اهتدى﴾</q>: علِم أنّ لِعَمَلِه ثوابًا يُجْزى عليه{2}. (١٠/٢٢٥) ٤٨٠٧٠- عن عبد الله بن عباس -من طريق عطاء- <q>﴿ثم اهتدى﴾</q>، قال: علِم أنّ ذلك توفيق مِن الله{12}. (ز) ٤٨٠٧١- عن سعيد بن جبير، في قوله: <q>﴿ثم اهتدى﴾</q>، قال: ثم استقام؛ لَزِم السنة والجماعة{13}. (١٠/٢٢٥) ٤٨٠٧٢- قال عامر الشعبي: عَلِم أن لذلك ثوابًا{14}. (ز) ٤٨٠٧٣- عن الضحاك بن مزاحم -من طريق جُوَيْبِر- في قوله: <q>﴿ثم اهتدى﴾</q>، قال: استقام{15}. (ز) ٤٨٠٧٤- تفسير الحسن البصري -من طريق الحسن بن دينار- قوله: <q>﴿ثم اهتدى﴾</q>: ثُمَّ مضى على العمل الصالح حتى يموت{16}. (ز) ٤٨٠٧٥- عن قتادة بن دعامة -من طريق سعيد- قوله: <q>﴿ثم اهتدى﴾</q>، يقول: ثم لَزِم الإسلامَ حتى يموت عليه{17}. (ز) ٤٨٠٧٦- عن الربيع بن أنس -من طريق أبي جعفر الرازي- <q>﴿ثم اهتدى﴾</q>، قال: أخذ بسُنَّة نبيه ﵇{17}. (ز) ٤٨٠٧٧- عن ثابت البناني -من طريق عمر بن شاكر- في قوله: <q>﴿وإني لغفار لمن تاب وآمن وعمل صالحا ثم اهتدى﴾</q>، قال: إلى ولاية أهل بيت النبي ﵇{7}. (ز) ٤٨٠٧٨- عن محمد بن السائب الكلبي -من طريق عنبسة- <q>﴿ثم اهتدى﴾</q>: عرف مُثِيبَه إن خيرًا فخيرًا، وإن شرًا فشرًا{7}. (ز) ٤٨٠٧٩- قال مقاتل بن سليمان: <q>﴿وعمل صالحا ثم اهتدى﴾</q>، يعني: عرف أنّ لِعَمَلِه ثوابًا يُجازى به. كقوله سبحانه: <q>﴿وبالنجم هم يهتدون﴾</q> [النحل:١٦]، يعني: يعرفون الطريق{21}. (ز) ٤٨٠٨٠- عن سفيان الثوري، في قوله: <q>﴿وعمل صالحا ثم اهتدى﴾</q>: صام وصلى، وعرف أن لها ثوابًا {22}. (ز) ٤٨٠٨١- عن سفيان الثوري، في قوله: <q>﴿ثم اهتدى﴾</q>، قال: لزم الإسلام حتى مات عليه{23}. (ز) ٤٨٠٨٢- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿وعمل صالحا ثم اهتدى﴾</q>، قال: أصاب العمل{24}. (ز) ٤٨٠٨٣- قال يحيى بن سلّام: وقال بعضهم: <q>﴿ثم اهتدى﴾</q>: ثم عرف الثواب{25}٤٢٩٨. (ز) ٤٢٩٨ اختلف السلف في تفسير قوله: <q>﴿ثم اهتدى﴾</q> على سبعة أقوال: الأول: لم يشك في إيمانه. الثاني: لزم الإيمان والعمل الصالح حتى يموت. الثالث: أخذ بسنة النبي ﷺ. الرابع: أصاب العمل. الخامس: عرف جزاء عمله من خير بثواب، أو شر بعقاب. السادس: ثم اهتدى إلى ولاية أهل بيت النبي ﷺ. السابع: أنه استقام. وقد رجّح ابنُ جرير (١٦/١٢٧) مستندًا إلى الدلالة العقلية أن معناه: «ثم لزم ذلك، فاستقام ولم يضيع شيئًا منه». وعلل (١٦/١٢٩) ذلك بقوله: «وإنما اخترنا القول الذي اخترنا في ذلك من أجل أن الاهتداء: هو الاستقامة على هدى. ولا معنى للاستقامة عليه إلا وقد جمعه الإيمان والعمل الصالح والتوبة، فمن فعل ذلك وثَبَتَ عليه فلا شك في اهتدائه». وذكر ابنُ عطية (٦/١١٩) الأقوال المختلفة في الآية، ثم علّق فقال: «وهذه كلها تخصيص واحد منها دون ما هو من نوعه بعيد ليس بالقوي، والذي يقوى في معنى <q>﴿ثُمَّ اهْتَدى﴾</q> أن يكون: ثم حفط معتقداته مِن أن يخالف الحق في شيء من الأشياء، فإنّ الاهتداء على هذا الوجه غير الإيمان وغير العمل، ورب مؤمن عمل صالحًا قد أوبقه عدم الاهتداء، كالقدرية والمرجئة وسائر أهل البدع والخوارج. فمعنى <q>﴿ثُمَّ اهْتَدى﴾</q>: ثم مشى في عقائد الشرع على طريق قويم». <q>﴿ثُمَّ ٱهۡتَدَىٰ ۝٨٢﴾</q> - آثار متعلقة بالآية ٤٨٠٨٤- عن علي بن زمعة{26}: مكتوب حول العرش قبل أن تخلق الدنيا بأربعة آلاف عام: <q>﴿وإنِّي لَغَفّارٌ لِمَن تابَ وآمَنَ وعَمِلَ صالِحًا ثُمَّ اهْتَدى﴾</q>{27}. (١٠/٢٢٥) ",footnotes:1:أخرجه ابن جرير ١٦/١٢٧. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.عزاه السيوطي إلى سعيد بن منصور، والفريابي.أخرجه يحيى بن سلّام ١/٢٧٠، ٤٩٢.أخرجه ابن جرير ١٦/١٢٧، ١٢٨.أخرجه ابن جرير ١٦/١٢٧، ١٢٨.أخرجه ابن أبي شيبة في مصنفه (ت: محمد عوامة) ١٥/٦٣٢ (٣١٠٨٥).أخرجه ابن جرير ١٦/١٢٩.تفسير مقاتل بن سليمان ٣/٣٦.أخرجه الثوري في تفسيره ص١٩٥.أخرجه ابن جرير ١٦/١٢٧. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.عزاه السيوطي إلى سعيد بن منصور، والفريابي.تفسير البغوي ٥/٢٨٨.عزاه السيوطي إلى ابن أبي حاتم.تفسير الثعلبي ٦/٢٥٦، وتفسير البغوي ٥/٢٨٨.أخرجه الهروي في ذم الكلام وأهله ٢/٤٠٣.أخرجه يحيى بن سلّام ١/٢٧٠.أخرجه ابن جرير ١٦/١٢٧-١٢٨.أخرجه ابن جرير ١٦/١٢٧-١٢٨.أخرجه ابن جرير ١٦/١٢٩.أخرجه ابن جرير ١٦/١٢٩.تفسير مقاتل بن سليمان ٣/٣٦. وأوله في تفسير الثعلبي ٦/٢٥٦، وتفسير البغوي ٥/٢٨٨ منسوبًا إلى مقاتل مهملًا.تفسير سفيان الثوري ص١٩٥.تفسير الثعلبي ٦/٢٥٦.أخرجه ابن جرير ١٦/١٢٨.تفسير يحيى بن سلّام ١/٢٧١.قال محققو الدر: كذا في الأصل، ولعله علي بن ربيعة، فله رواية عن علي بن أبي طالب.عزاه السيوطي إلى الديلمي. وعند الديلمي (٦٣٧٨) عن علي بن أبي طالب.
20,83," <q>﴿وَمَاۤ أَعۡجَلَكَ عَن قَوۡمِكَ یَـٰمُوسَىٰ ۝٨٣ قَالَ هُمۡ أُو۟لَاۤءِ عَلَىٰۤ أَثَرِی وَعَجِلۡتُ إِلَیۡكَ رَبِّ لِتَرۡضَىٰ ۝٨٤﴾</q> - تفسير ٤٨٠٨٥- عن عمرو بن ميمون، عن رجل من أصحاب النبي ﷺ، قال: تَعَجَّل موسى إلى ربه، فقال الله: <q>﴿وما أعجلك عن قومك يا موسى قال هم أولاء على أثري وعجلت إليك رب لترضى﴾</q>. قال: فرأى في ظِلِّ العرش رجلًا، فعجب له، فقال: مَن هذا، يا رب؟ قال: لا أُحَدِّثك مَن هو، لكن سأخبرك بثلاث فيه: كان لا يحسد الناس على ما آتاهم الله مِن فضله، ولا يَعُقُّ والديه، ولا يمشي بالنميمة{1}. (١٠/٢٢٥) ٤٨٠٨٦- قال مقاتل بن سليمان: <q>﴿وما أعجلك عن قومك يا موسى﴾</q> يعني: السبعين الذين اختارهم موسى حين ذهبوا معه إلى الطور ليأخذوا التوراة مِن ربِّه ﷿، فلمّا ساروا عجل موسى ﵇ شوقًا إلى ربه -تبارك وتعالى-، وخلف السبعين، وأمرهم أن يتبعوه إلى الجبل، فقال الله ﷿ له: <q>﴿وما أعجلك عن قومك يا موسى﴾</q>؟ السبعين. <q>﴿قال﴾</q> لربه -جلَّ وعَزَّ-: <q>﴿هم أولاء على أثري﴾</q> يجيئون مِن بعدي، <q>﴿وعجلت﴾</q> يعني: أسرعتُ <q>﴿إليك رب لترضى﴾</q> يقول: حتى ترضى عَنِّي{2}. (ز) ٤٨٠٨٧- عن محمد بن إسحاق -من طريق سلمة- قال: وعد الله موسى حين أهلك فرعون وقومه ونجّاه وقومَه ثلاثين ليلة، ثم أتَمَّها بعشر، فتمَّ ميقاتُ ربه أربعين ليلة، تلقّاه فيها بما شاء، فاستخلف موسى هارون في بني إسرائيل، ومعه السامري، يسير بهم على أثر موسى ليلحقهم به، فلما كلَّم اللهُ موسى قال له: <q>﴿وما أعجلك عن قومك يا موسى هم أولاء على أثري وعجلت إليك رب لترضى﴾</q>{3}. (ز) ٤٨٠٨٨- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿وعجلت إليك رب لترضى﴾</q>، قال: لأرضيك{3}. (ز) ٤٨٠٨٩- قال يحيى بن سلّام، قوله: <q>﴿وما أعجلك عن قومك يا موسى (٨٣) قال هم أولاء على أثري وعجلت إليك رب لترضى (٨٤)﴾</q>، قال: هم أولاء ينتظرونني مِن بعدي بالذي آتيهم به، وليس يعني: أنهم يتبعونه. وقال بعضهم: يعني: السبعين الذي اختاروا، فذهبوا معه للميعاد{5}. (ز) ",footnotes:1:أخرجه ابن أبي شيبة ٩/٩١، ٩٣، والبيهقي في الشعب (٦٦٢٥، ١١١١٨). وعزاه السيوطي إلى سعيد بن منصور.تفسير مقاتل بن سليمان ٣/٣٦.أخرجه ابن جرير ١٦/١٣٠.أخرجه ابن جرير ١٦/١٣٠.تفسير يحيى بن سلّام ١/٢٧١.
  20,84,""
20,85," <q>﴿قَالَ فَإِنَّا قَدۡ فَتَنَّا قَوۡمَكَ مِنۢ بَعۡدِكَ وَأَضَلَّهُمُ ٱلسَّامِرِیُّ ۝٨٥﴾</q> - تفسير ٤٨٠٩٠- عن كعب بن مالك، عن النبي ﷺ، قال: «إنّ الله لَمّا وعد موسى أن يُكَلِّمه خرج للوقت الذي وعده، فبينما هو يناجي ربَّه إذ سمع خلفه صوتًا، فقال: إلهي، إنِّي أسمعُ خلفي صوتًا. قال: لعلَّ قومَك ضلُّوا. قال: إلهي، مَن أضلَّهم؟ قال: أضلَّهم السامريُّ. قال: فبِمَ أضلَّهم؟ قال: صاغ لهم عِجلًا جسدًا له خُوار. قال: إلهي، هذا السامريُّ صاغ لهم العجل، فمَن نفخ فيه الروح حتى صار له خُوار؟ قال: أنا، يا موسى. قال: فوَعِزَّتِك، ما أضلَّ قومي أحدٌ غيرك. قال: صدقتَ. قال: يا حكيم الحكماء، لا ينبغي حكيمٌ أن يكون أحكمَ منك»{1}. (١٠/٢٢٦) ٤٨٠٩١- عن راشد بن سعد، قال: إنّ موسى لَمّا قدِم على ربِّه واعد قومَه أربعين ليلة، قال: يا موسى، إنّ قومك قد افْتَتَنوا مِن بعدك. قال: يا رب، كيف يفتنون، وقد نجيتهم مِن فرعون، ونجيتهم مِن البحر، وأنعمت عليهم، وفعلت بهم؟! قال: يا موسى، إنّهم اتخذوا مِن بعدك عِجلًا جسدًا له خُوار. قال: يا ربِّ، فمَن جعل فيه الرُّوح؟ قال: أنا. قال: فأنت -يا ربِّ- أضللتَهم. قال: يا موسى، يا رأس النبيين، ويا أبا الحكام، إنِّي رأيت ذلك في قلوبهم؛ فيَسَّرْتُه لهم{2}. (١٠/٢٢٦) ٤٨٠٩٢- قال مقاتل بن سليمان: <q>﴿قال﴾</q> الله جل جلاله: <q>﴿فإنا قد فتنا قومك﴾</q> يعني: الذين خَلَّفهم مع هارون على ساحل البحر سوى السبعين، <q>﴿من بعدك﴾</q> بالعجل، <q>﴿وأضلهم السامري﴾</q> حين أمرهم بعبادة العجل، وكانوا اثني عشر ألفًا{3}. (ز) ٤٨٠٩٣- قال يحيى بن سلّام: <q>﴿فإنا قد فتنا قومك من بعدك وأضلهم السامري﴾</q>، يقول: إنّ السامريَّ قد أضلَّهم{4}. (ز) <q>﴿وَأَضَلَّهُمُ ٱلسَّامِرِیُّ ۝٨٥﴾</q> - تفسير ٤٨٠٩٤- عن عبد الله بن عباس، قال: كان السامريُّ مِن أهل كَرمان{5}. (١٠/٢٣١) ٤٨٠٩٥- عن عبد الله بن عباس -من طريق سعيد بن جبير- قال: كان السامريُّ رجلًا مِن أهل باجَرْما{6}، وكان مِن قوم يعبدون البقر، فكان حُبُّ عبادة البقر في نفسه، وكان قد أظهر الإسلامَ في بني إسرائيل ... وكان اسمُ السامري: موسى بن ظفر، وقع في أرض مصر، فدخل في بني إسرائيل{7}. (١٠/٢٢٨) ٤٨٠٩٦- عن سعيد بن جبير، قال: كان السامري من أهل كَرمان{8}. (ز) ٤٨٠٩٧- قال قتادة بن دعامة: كان السامريُّ مِن عُظماء بني إسرائيل، مِن قبيلة يُقال لها: سامرة، ولكن نافق بعدما قطع البحر مع موسى{9}٤٢٩٩. (ز) ٤٢٩٩ ذكر ابن عطية (٦/١٢٠) قولين في أصل السامريّ: الأول: أنه من بني إسرائيل، ويقال: إنه كان ابن خال موسى ﵇. الثاني:كان أصله مِن العجم مِن أهل كرمان، ولم يكن من بني إسرائيل. ورجَّح القول الأول قائلًا: «والأول أصح». ولم يذكر مستندًا. ",footnotes:1:عزاه السيوطي إلى ابن مردويه.عزاه السيوطي إلى ابن جرير في تهذيبه.تفسير مقاتل بن سليمان ٣/٣٦.تفسير يحيى بن سلّام ١/٢٧١.عزاه السيوطي إلى ابن أبي حاتم. وكرمان -بفتح الكاف، وربما كسرت والفتح أشهر-: ولاية مشهورة وناحية كبيرة معمورة ذات بلاد وقرى ومدن واسعة بين فارس ومكران وسجستان وخراسان. معجم البلدان ٤/ ٤٥٤.باجَرْما -بفتح الجيم، وسكون الراء، وميم، وألف مقصورة-: قريةٌ قرب الرَّقَّة الواقعة شرق مدينة حلب. معجم البلدان ١/٣١٣.أخرجه ابن جرير ١/٦٧٢-٦٧٣، وسيأتي بتمامه في قصة الآيات.تفسير الثعلبي ٦/٢٥٧.علقه يحيى بن سلّام ١/٢٧٣.
20,86," <q>﴿فَرَجَعَ مُوسَىٰۤ إِلَىٰ قَوۡمِهِۦ غَضۡبَـٰنَ أَسِفࣰاۚ﴾</q> - تفسير ٤٨٠٩٨- عن عبد الله بن عباس -من طريق علي- <q>﴿غضبان أسفا﴾</q>، قال: يعني: حزينًا{1}. (٦/٥٣٩) ٤٨٠٩٩- عن عبد الله بن عباس -من طريق العوفي- قوله: <q>﴿غضبان أسفا﴾</q>، يقول: <q>﴿أسِفًا﴾</q>: حزينًا. وفي الزخرف [٥٥]: <q>﴿فَلَمّا آسَفُونا﴾</q>، يقول: أغضبونا. والأسف على وجهين: الغضب، والحُزْن{2}. (ز) ٤٨١٠٠- عن مجاهد بن جبر -من طريق ابن أبي نَجِيح- قوله: <q>﴿أسفا﴾</q>، قال: جَزِعًا. والأَسَف: الجَزَع{3}. (ز) ٤٨١٠١- قال الحسن البصري: شديد الغضب{4}. (ز) ٤٨١٠٢- عن الحسن البصري -من طريق مالك بن دينار- في قوله: <q>﴿فرجع موسى إلى قومه غضبان أسفا﴾</q>، قال: غضبان حزينًا{5}. (ز) ٤٨١٠٣- عن قتادة بن دعامة -من طريق سعيد- قوله: <q>﴿ولما رجع موسى إلى قومه غضبان أسفا﴾</q> [الأعراف:١٥٠]: أي: حزينًا على ما صَنَع قومُه مِن بعده{6}. (ز) ٤٨١٠٤- عن إسماعيل السُّدِّيّ -من طريق أسباط- <q>﴿غضبان أسفا﴾</q>، قال: حزينًا{7}. (١٠/٢٣١) ٤٨١٠٥- قال مقاتل بن سليمان: <q>﴿فرجع موسى﴾</q> مِن الجبل <q>﴿إلى قومه غضبان﴾</q> عليهم، <q>﴿أسفا﴾</q> حزينًا لعبادتهم العجل{8}. (ز) <q>﴿قَالَ یَـٰقَوۡمِ أَلَمۡ یَعِدۡكُمۡ رَبُّكُمۡ وَعۡدًا حَسَنًاۚ﴾</q> - تفسير ٤٨١٠٦- قال إسماعيل السُّدِّيّ: <q>﴿حسنا﴾</q>، يعني: حقًّا{4}. (ز) ٤٨١٠٧- قال مقاتل بن سليمان: <q>﴿قال﴾</q> لهم: <q>﴿يا قوم ألم يعدكم ربكم وعدا حسنا﴾</q> يعني: حقًّا. كقوله سبحانه في البقرة [٨٠]: <q>﴿وقولوا للناس حسنا﴾</q>، يعني: حقًّا في محمد ﷺ، أن يعطيكم التوراة فيها بيانُ كلِّ شيء. والوعد حين قال ﷿: <q>﴿وواعدناكم جانب الطور الأيمن﴾</q>{8}. (ز) ٤٨١٠٨- قال يحيى بن سلّام: <q>﴿قال يا قوم ألم يعدكم ربكم وعدا حسنا﴾</q> في الآخرة على التَّمَسُّك بدِينه{11}. (ز) <q>﴿أَفَطَالَ عَلَیۡكُمُ ٱلۡعَهۡدُ﴾</q> - تفسير ٤٨١٠٩- عن مجاهد بن جبر -من طريق ابن أبي نَجِيح- في قوله: <q>﴿أفطال عليكم العهد﴾</q>، يقول: الوَعْد{12}. (١٠/٢٣٣) ٤٨١١٠- قال مقاتل بن سليمان: والوَعْد حين قال ﷿: <q>﴿وواعدناكم جانب الطور الأيمن﴾</q> حين سار موسى مع السبعين ليأخذوا التوراة، فطال عليهم العهد، يعني: ميعاده إيّاهم أربعين يومًا، فذلك قوله تعالى: <q>﴿أفطال عليكم﴾</q>{8}. (ز) <q>﴿أَمۡ أَرَدتُّمۡ أَن یَحِلَّ عَلَیۡكُمۡ غَضَبࣱ مِّن رَّبِّكُمۡ﴾</q> - تفسير ٤٨١١١- قال قتادة بن دعامة: <q>﴿أم أردتم أن يحل عليكم غضب من ربكم﴾</q> أن ينزِل عليكم غضبٌ من ربكم{14}. (ز) ٤٨١١٢- قال مقاتل بن سليمان: <q>﴿أم أردتم أن يحل عليكم غضب﴾</q> يعني: أن يجب عليكم عذاب. كقوله تعالى: <q>﴿قد وقع عليكم من ربكم رجس وغضب﴾</q> [الأعراف:٧١]، يعني: عذاب. <q>﴿من ربكم﴾</q>{8}. (ز) <q>﴿فَأَخۡلَفۡتُم مَّوۡعِدِی ۝٨٦﴾</q> - تفسير ٤٨١١٣- عن مجاهد بن جبر -من طريق ابن أبي نَجِيح- وفي قوله: <q>﴿فأخلفتم موعدي﴾</q>، يقول: عهدي{16}. (١٠/٢٣٣) ٤٨١١٤- قال مقاتل بن سليمان: <q>﴿فأخلفتم موعدي﴾</q>، يعني: الأربعين يومًا، وذلك أنهم عدوا الأيام والليالي، فعدوا عشرين يومًا، وعشرين ليلة، ثم قالوا لهارون: قد تَمَّ الأجلُ الذى كان بيننا وبين موسى. فعند ذلك أضلَّهم السامريُّ{8}. (ز) ",footnotes:1:أخرجه ابن أبي حاتم ٥/١٥٦٨-١٥٦٩. وعزاه السيوطي إلى ابن المنذر.أخرجه ابن أبي حاتم ٥/ ١٥٦٩.تفسير مجاهد ص٤٦٤، وأخرجه ابن جرير ١٦/١٣١.علقه يحيى بن سلّام ١/٢٧١.أخرجه إسحاق البستي في تفسيره ص٢٦٦.أخرجه يحيى بن سلّام ١/٢٧١، وابن جرير ١٦/١٣١.عزاه السيوطي إلى ابن أبي حاتم.تفسير مقاتل بن سليمان ٣/٣٧.علقه يحيى بن سلّام ١/٢٧١.تفسير مقاتل بن سليمان ٣/٣٧.تفسير يحيى بن سلّام ١/٢٧١.علقه يحيى بن سلّام ١/٢٧١. وعزاه السيوطي إلى عبد بن حميد، وابن جرير، وابن المنذر، وابن أبي حاتم.تفسير مقاتل بن سليمان ٣/٣٧.علقه يحيى بن سلّام ١/٢٧١، وقال عَقِبه: وهو مثل الحرف الأول. يشير بذلك إلى قوله تعالى: <q>﴿فَيَحِلَّ عَلَيْكُمْ غَضَبِي﴾</q> [طه:٨١].تفسير مقاتل بن سليمان ٣/٣٧.أخرجه ابن جرير ١٦/١٣٢. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم. وفي تفسير مجاهد ص٤٦٤: <q>﴿ما أخلفنا موعدك﴾</q> أي: عهدك.تفسير مقاتل بن سليمان ٣/٣٧.
20,87," <q>﴿قَالُوا۟ مَاۤ أَخۡلَفۡنَا مَوۡعِدَكَ بِمَلۡكِنَا﴾</q> - قراءات ٤٨١١٥- عن يحيى{1} أنه قرأ: <q>﴿بِمَلْكِنا﴾</q> و‹مُلْكِنا› واحد{2}. (١٠/٢٣٤) <q>﴿قَالُوا۟ مَاۤ أَخۡلَفۡنَا مَوۡعِدَكَ بِمَلۡكِنَا﴾</q> - تفسير الآية ٤٨١١٦- عن عبد الله بن عباس -من طريق علي- في قوله: <q>﴿بملكنا﴾</q>، قال: بأمرنا{3}. (١٠/٢٣٣) ٤٨١١٧- عن مجاهد بن جبر -من طريق ابن أبي نَجِيح- في قوله: <q>﴿ما أخلفنا موعدك بملكنا﴾</q>، يقول: بأمرٍ مَلَكْناه{4}{5}. (١٠/٢٣٣) ٤٨١١٨- عن الحسن البصري، في قوله: ‹بِمُلْكِنا›، قال: بسلطاننا{6}. (١٠/٢٣٣) ٤٨١١٩- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿ما أخلفنا موعدك بملكنا﴾</q>، قال: بِطاقَتِنا{7}. (١٠/٢٣٣) ٤٨١٢٠- عن إسماعيل السُّدِّيّ -من طريق أسباط-، مثله{8}. (١٠/٢٣٣) ٤٨١٢١- قال مقاتل بن سليمان: <q>﴿قالوا ما أخلفنا موعدك بملكنا﴾</q>: ونحن نملك أمرنا{9}. (ز) ٤٨١٢٢- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿ما أخلفنا موعدك بملكنا﴾</q>، قال: يقول: بهوانا. قال: ولكنه جاءت ثلاثة. قال: ومعهم حُليٌّ استعاروه مِن آل فرعون وثياب{10}٤٣٠٠. (ز) ٤٣٠٠ أفادت الآثارُ اختلاف المفسرين في معنى: <q>﴿بِمَلْكِنا﴾</q> على أقوال: الأول: بأمْرِنا. الثاني: بطاقتنا. الثالث: بهوانا، ولكنا لم نملك أنفُسَنا. وعلَّق ابنُ جرير (١٦/١٣٥) على هذه الأقوال قائلًا: «وكل هذه الأقوال الثلاثة في ذلك متقارِبات المعنى». ثم بيَّن وجْهتها بقوله: «لأنّ مَن لم يملك نَفْسَه لغلَبَة هواه على أمرٍ فإنه لا تمتنع اللغة أن تقول: فعَل فلان هذا الأمر وهو لا يملك نفْسَه، وفَعَلَه وهو لا يَضْبِطُها، وفعَلَه وهو لا يُطيق تَرْكَه». <q>﴿وَلَـٰكِنَّا حُمِّلۡنَاۤ أَوۡزَارࣰا﴾</q> - قراءات ٤٨١٢٣- قال يحيى بن سلّام: <q>﴿ولَكِنّا حُمِّلْنا﴾</q>، وهي تُقْرَأ أيضًا: <q>﴿حَمَلْنا﴾</q> خفيفة{11}. (ز) <q>﴿وَلَـٰكِنَّا حُمِّلۡنَاۤ أَوۡزَارࣰا﴾</q> - تفسير الآية ٤٨١٢٤- عن مجاهد بن جبر -من طريق ابن أبي نَجِيح- في قوله: <q>﴿ولكنا حملنا أوزارا﴾</q>، قال: أثقالًا{12}. (١٠/٢٣٣) ٤٨١٢٥- قال الحسن البصري: <q>﴿أوزارا﴾</q>: آثامًا{13}. (ز) ٤٨١٢٦- قال مقاتل بن سليمان: <q>﴿ولكنا حملنا أوزارا﴾</q>، يعني: خطايا؛ لأن ذلك حملهم على صُنْعِ العِجْل وعبادته{9}. (ز) <q>﴿مِّن زِینَةِ ٱلۡقَوۡمِ﴾</q> - تفسير ٤٨١٢٧- عن مجاهد بن جبر -من طريق ابن أبي نَجِيح- في قوله: <q>﴿من زينة القوم﴾</q>: وهي الحُلِيُّ الذي استعاروه مِن آل فرعون{15}. (١٠/٢٣٣) ٤٨١٢٨- عن إسماعيل السُّدِّيِّ -من طريق أسباط- <q>﴿ولكنا حملنا أوزارا من زينة القوم﴾</q>، يقول: مِن حُلِيِّ القِبْط{16}. (١٠/٢٣١) ٤٨١٢٩- قال مقاتل بن سليمان: <q>﴿من زينة القوم﴾</q>، يقول: مِن حُلِيِّ آل فرعون؛ الذهب والفضة{9}. (ز) ٤٨١٣٠- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿ولكنا حملنا أوزارا من زينة القوم﴾</q>، قال: الحلي الذي استعاروه والثياب، ليست مِن الذنوب في شيء، لو كانت الذنوب كانت: حُمِّلْناها نتحملها، فليست من الذنوب في شيء{18}٤٣٠١. (ز) ٤٣٠١ لم يذكر ابنُ جرير (١٦/١٣٦-١٣٧) في معنى: <q>﴿ولَكِنّا حُمِّلْنا أوْزارًا مِن زِينَةِ القَوْمِ﴾</q> سوى قول ابن عباس، ومجاهد، والسدي، وابن زيد. ٤٨١٣١- قال يحيى بن سلّام: <q>﴿من زينة القوم﴾</q>، يعني: قوم فرعون{19}. (ز) <q>﴿فَقَذَفۡنَـٰهَا فَكَذَ ٰ⁠لِكَ أَلۡقَى ٱلسَّامِرِیُّ ۝٨٧﴾</q> - تفسير ٤٨١٣٢- عن عبد الله بن عباس -من طريق العوفي- <q>﴿فقذفناها﴾</q>: يعني: زينة القوم، حين أمَرَنا السامِرِيُّ لَمّا قبض قبضة مِن أثر جبرائيل، فألقى القبضة على حُلِيِّهم، فصار عِجلًا جسدًا له خوار{20}. (ز) ٤٨١٣٣- عن مجاهد بن جبر -من طريق ابن أبي نَجِيح- في قوله: <q>﴿فقذفناها﴾</q> قال: فألقيناها، <q>﴿فكذلك ألقى السامري﴾</q> قال: كذلك صنع{21}. (١٠/٢٣٣). (ز) ٤٨١٣٤- عن قتادة بن دعامة -من طريق سعيد- <q>﴿فقذفناها﴾</q>: أي: فنَبَذْناها{22}. (ز) ٤٨١٣٥- قال مقاتل بن سليمان: <q>﴿فقذفناها فكذلك﴾</q> يعني: هكذا <q>﴿ألقى السامري﴾</q> الحُلِيَّ في النار{9}. (ز) ٤٨١٣٦- قال يحيى بن سلّام: وألقى ما معه مِن الحلي، وألقى القومُ ما معهم، وهو قوله: <q>﴿فقذفناها فكذلك ألقى السامري﴾</q> ما معه كما ألقينا ما معنا. فصاغه عِجْلًا، ثم ألقى في فِيهِ الترابَ الذي كان أخذه مِن تحت حافر فرس جبريل{19}. (ز) ",footnotes:1:لعله: يحيى بن وثاب.عزاه السيوطي إلى ابن أبي شيبة، وابن المنذر. <q>﴿بِمَلْكِنا﴾</q> بفتح الميم قراءة متواترة، قرأ نافع، وأبو جعفر، وعاصم، وقرأ حمزة، و الكسائي، وخلف العاشر: ‹بِمُلْكِنا› بضم الميم، وقرأ بقية العشرة: ‹بِمِلْكِنا› بكسر الميم. انظر: النشر ٢/٣٢١-٣٢٢، والإتحاف ص٣٨٧.أخرجه ابن جرير ١٦/١٣٣، وابن أبي حاتم -كما في التغليق ٤/٢٥٦-.في تفسير مجاهد: بأمر نملكه، وفي ابن جرير ضبطه محققوه: بأمرٍ مِلْكِنا.تفسير مجاهد ص٤٦٤، وأخرجه ابن جرير ١٦/١٣٤، وإسحاق البستي في تفسيره ص٢٦٦ من طريق ابن جريج، وابن أبي حاتم ١/١٠٩. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.عزاه السيوطي إلى ابن أبي حاتم.أخرجه يحيى بن سلّام ١/٢٧٢، وعبد الرزاق ٢/١٨ من طريق معمر، وابن جرير ١٦/١٣٤. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه ابن جرير ١٦/١٣٤. وعزاه السيوطي إلى ابن أبي حاتم.تفسير مقاتل بن سليمان ٣/٣٧.أخرجه ابن جرير ١٦/١٣٤.تفسير يحيى بن سلّام ١/٢٧٢. و<q>﴿حُمِّلْنا﴾</q> بضم الحاء، وكسر الميم مشددة قراءة متواترة، قرأ بها نافع، وابن كثير، وابن عامر، وحفص، وأبو جعفر، ورويس، وقرأ بقيّة العشرة: ›حَمَلْنا› بفتح الحاء والميم مخففة. انظر: النشر ٢/٣٢٢، والإتحاف ص٣٨٧.أخرجه ابن جرير ١٦/١٣٦، ١٣٨، وابن أبي حاتم ١/١٠٩. وعلَّقه يحيى بن سلّام ١/٢٧٢، والبخاري ٤/١٧٦٣. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.علقه يحيى بن سلّام ١/٢٧٢. وعقّب عليه وعلى قول مجاهد بقوله: وهو واحد؛ ذلك الثقل: الإثم.تفسير مقاتل بن سليمان ٣/٣٧.أخرجه ابن جرير ١٦/١٣٦، ١٣٨، وابن أبي حاتم ١/١٠٩. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه ابن جرير ١٦/١٣٧. وعزاه السيوطي إلى ابن أبي حاتم.تفسير مقاتل بن سليمان ٣/٣٧.أخرجه ابن جرير ١٦/١٣٧.تفسير يحيى بن سلّام ١/٢٧٢.أخرجه ابن جرير ١٦/١٤١.أخرجه ابن جرير ١٦/١٣٦، ١٣٨. وعلَّقه البخاري ٤/١٧٦٣. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.أخرجه يحيى بن سلّام ١/٢٧٢، وابن جرير ١٦/١٣٨-١٣٩.تفسير مقاتل بن سليمان ٣/٣٧.تفسير يحيى بن سلّام ١/٢٧٢.
