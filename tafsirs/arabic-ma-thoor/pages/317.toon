quran[11]{c,v,t}:
  20,77,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَلَقَدۡ أَوۡحَیۡنَاۤ إِلَىٰ مُوسَىٰۤ أَنۡ أَسۡرِ بِعِبَادِی﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٨٠١١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ولقد أوحينا إلى موسى أن أسر بعبادي﴾</span> ليلًا بأرض مصر{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٠١٢<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: قوله: <span class="qpc-hafs">﴿ولقد أوحينا إلى موسى أن أسر بعبادي﴾</span>، أي: ليلًا{2}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿فَٱضۡرِبۡ لَهُمۡ طَرِیقࣰا فِی ٱلۡبَحۡرِ یَبَسࣰا﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٨٠١٣<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نَجِيح- في قوله: <span class="qpc-hafs">﴿طريقا في البحر يبسا﴾</span>، قال: يابسًا{3}. (١٠/٢٢٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٠١٤<span class="dash">-</span></span> قال <span class="name-2">الحسن البصري</span>، في قوله: <span class="qpc-hafs">﴿فاضرب لهم طريقا في البحر يبسا﴾</span>: أتاه جبريلُ على فرس، فأمره أن يضرب البحر بعصاه، فصار طريقًا يبسًا{4}<span class=comment-ref>٤٢٩٢</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٤٢٩٢</span> ذكر <u>ابنُ عطية</u> (٦/١١٤) اختلافًا في تحديد الوقت الذي أوحى الله فيه لموسى أن يضرب البحر بعصاه، فذكر <b>قولًا</b> أن ذلك كان ساعة مباشرته البحر، وذكر <b>قولًا آخر</b> أن ذلك الوحي كان متقدمًا على ذلك. وقد <span class="comment-type-3">رجّح</span> <span class="mustanad">مستندًا إلى ظاهر الآية</span> القول الثاني، فقال: «... ويروى أنّ الوحي إليه بذلك كان متقدمًا بمصر، وهو ظاهر الآية».</div></p><p><div></p><p><p><span class="item-no">٤٨٠١٥<span class="dash">-</span></span> عن <span class="name-2">محمد بن كعب القرظي</span>، في قوله: <span class="qpc-hafs">﴿فاضرب لهم طريقا في البحر يبسا﴾</span>، قال: يابِسًا، ليس فيه ماء ولا طين{5}. (١٠/٢٢٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٠١٦<span class="dash">-</span></span> عن <span class="name-3">محمد بن إسحاق</span> -من طريق عبيد الله بن سعد القرشي، عن عمِّه، عن أبيه- في قوله: <span class="qpc-hafs">﴿فانفلق فكان كل فرق كالطود العظيم﴾</span> [الشعراء:٦٣]، قال: عن يَبَس مِن الأرض. يقول الله ﷿ لموسى: <span class="qpc-hafs">﴿فاضرب لهم طريقا في البحر يبسا لا تخاف دركا ولا تخشى﴾</span>، فلما شقَّ له البحر عن طريق قاعه يَبِسَ تَلا موسى ببني إسرائيل، فاتبعه فرعون وجنوده{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٠١٧<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿فاضرب لهم طريقا في البحر يبسا﴾</span>... بلغني: أنّه صار اثني عشر طريقًا، لكل سِبْطٍ طريق{2}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿لَّا تَخَـٰفُ دَرَكࣰا وَلَا تَخۡشَىٰ ۝٧٧﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٨٠١٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- في قوله: <span class="qpc-hafs">﴿لا تخاف دركا﴾</span> قال: مِن آل فرعون، <span class="qpc-hafs">﴿ولا تخشى﴾</span> مِن البحر غرقًا{8}. (١٠/٢٢٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٠١٩<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿لا تخاف دركا ولا تخشى﴾</span>، يقول: لا تخاف أن يدركك فرعون مِن بعدِك، ولا تخشى الغرق أمامك{9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٠٢٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿لا تخاف دركا﴾</span> مِن آل فرعون مِن ورائك، <span class="qpc-hafs">﴿ولا تخشى﴾</span> الغرق في البحر أمامك؛ لأنّ بني إسرائيل قالوا لموسى: هذا فرعون قد لحقنا بالجنود، وهذا في البحر قد غشينا، فليس لنا منفذ. فنزلت: <span class="qpc-hafs">﴿لا تخاف دركا ولا تخشى﴾</span> أوْجَبَ ذلك على نفسه تعالى{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٠٢١<span class="dash">-</span></span> عن <span class="name-3">عبد الملك ابن جريج</span> -من طريق حجّاج- قال: قال أصحاب موسى: هذا فرعون قد أدركنا، وهذا البحر قد عَمَّنا. فأنزل الله: <span class="qpc-hafs">﴿ولا تخاف دركا﴾</span> مِن آل فرعون، <span class="qpc-hafs">﴿ولا تخشى﴾</span> مِن البحر غرقًا ولا وحَلًا{11}{12}. (١٠/٢٢٣)</p></p><p></div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٣/٣٤.تفسير يحيى بن سلّام ١/٢٦٨.أخرجه ابن جرير ١٦/١٢١. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.علَّقه يحيى بن سلّام ١/٢٦٨.عزاه السيوطي إلى سعيد بن منصور، وابن المنذر، وابن أبي حاتم.أخرجه ابن أبي الدنيا في كتاب العقوبات -موسوعة ابن أبي الدنيا ٤/٤٩٥-٤٩٦ (٢٤٦)-.تفسير يحيى بن سلّام ١/٢٦٨.أخرجه ابن جرير ١٦/١٢١. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.أخرجه يحيى بن سلّام ١/٢٦٩، وابن جرير ١٦/١٢١.تفسير مقاتل بن سليمان ٣/٣٤.أي: وقوعًا في الوَحَل؛ أي: الطين. النهاية (وحل).أخرجه ابن جرير ١٦/١٢٢. وعزاه السيوطي إلى ابن المنذر.
  20,78,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿فَأَتۡبَعَهُمۡ فِرۡعَوۡنُ بِجُنُودِهِۦ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٨٠٢٢<span class="dash">-</span></span> قال <span class="name-2">وهب بن مُنَبِّه</span>: استعار بنو إسرائيل حليًّا كثيرًا مِن القبط، ثم خرج بهم موسى في أول الليل، وكانوا سبعين ألفًا، فأُخْبِر فرعونُ بذلك، فركب في ستمائة ألف مِن القِبْط، يقصُّ أثرَ موسى{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٠٢٣<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: قوله: <span class="qpc-hafs">﴿فأتبعهم فرعون بجنوده﴾</span>، وكان جميعُ جنوده أربعين ألف ألف{2}<span class=comment-ref>٤٢٩٣</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٤٢٩٣</span> قال <u>ابنُ عطية</u> (٦/١١٤): «واختلف الناس في عدد جند فرعون؛ فقيل: كان في خيله سبعون ألف أدهم، ونسبة ذلك من سائر الألوان. وقيل أكثر من هذا مِمّا اختصرته؛ لقِلَّة صِحَّته».</div></p><p><h3><span class="qpc-hafs">﴿فَغَشِیَهُم مِّنَ ٱلۡیَمِّ مَا غَشِیَهُمۡ ۝٧٨﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٨٠٢٤<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span>، في قوله: <span class="qpc-hafs">﴿فغشيهم من اليم﴾</span>، قال: البحر{3}. (١٠/٢٢٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٠٢٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فأتبعهم فرعون بجنوده فغشيهم من اليم ما غشيهم﴾</span>، يعني: الغرق{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٠٢٦<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿فغشيهم من اليم ما غشيهم﴾</span>، واليم: البحر، فغرقوا{2}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير الثعلبي ٦/٢٥٥.تفسير يحيى بن سلّام ١/٢٦٩.أخرجه ابن أبي حاتم -كما في فتح الباري ٨/٤٣٤-.تفسير مقاتل بن سليمان ٣/٣٤.تفسير يحيى بن سلّام ١/٢٦٩.
  20,79,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَأَضَلَّ فِرۡعَوۡنُ قَوۡمَهُۥ وَمَا هَدَىٰ ۝٧٩﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٨٠٢٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وأضل فرعون قومه﴾</span> القبط، <span class="qpc-hafs">﴿وما هدى﴾</span> يقول: وما هداهم، وذلك أنّ فرعون قال لقومه في «حم المؤمن»: <span class="qpc-hafs">﴿ما أريكم إلا ما أرى وما أهديكم إلا سبيل الرشاد﴾</span> [غافر:٢٩]، فأضَّلَّهم ولم يَهْدِهم، فذلك قوله ﷿: <span class="qpc-hafs">﴿وما هدى﴾</span>{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٠٢٨<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿وأضل فرعون قومه وما هدى﴾</span> ما هداهم{2}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٣/٣٤.تفسير يحيى بن سلّام ١/٢٦٩.
  20,80,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿یَـٰبَنِیۤ إِسۡرَ ٰ⁠ۤءِیلَ قَدۡ أَنجَیۡنَـٰكُم مِّنۡ عَدُوِّكُمۡ وَوَ ٰ⁠عَدۡنَـٰكُمۡ جَانِبَ ٱلطُّورِ ٱلۡأَیۡمَنَ وَنَزَّلۡنَا عَلَیۡكُمُ ٱلۡمَنَّ وَٱلسَّلۡوَىٰ ۝٨٠﴾</span> - قراءات</h3></p><p><div></p><p><p><span class="item-no">٤٨٠٢٩<span class="dash">-</span></span> عن الأعمش: في قراءة <span class="name-1">عبد الله [بن مسعود]</span>: (قَدْ نَجَّيْتُكُم مِّنْ عَدُوِّكُمْ){1}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿یَـٰبَنِیۤ إِسۡرَ ٰ⁠ۤءِیلَ قَدۡ أَنجَیۡنَـٰكُم مِّنۡ عَدُوِّكُمۡ وَوَ ٰ⁠عَدۡنَـٰكُمۡ جَانِبَ ٱلطُّورِ ٱلۡأَیۡمَنَ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٨٠٣٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿يابني إسرائيل قد أنجيناكم من عدوكم﴾</span> فرعون وقومه، <span class="qpc-hafs">﴿وواعدناكم جانب الطور الأيمن﴾</span> يعني: حين سار موسى مع السبعين عن يمين الجبل، فأُعْطي التوراة{2}<span class=comment-ref>٤٢٩٤</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٤٢٩٤</span> ذكر <u>ابنُ عطية</u> (٦/١١٦) اختلافا في المخاطب بقوله: <span class="qpc-hafs">﴿يا بني إسرائيل قد أنجيناكم﴾</span> على قولين: <b>الأول</b>: أن الخطاب به وُجِّه لبني إسرائيل أيام موسى. <b>الثاني</b>: أن الخطاب به مُوَجَّه لمعاصري رسول الله ﷺ مِن بني إسرائيل.</p><p>و<span class="comment-type-3">رجّح</span> <u>ابنُ عطية</u> <span class="mustanad">مستندًا إلى ظاهر الآية</span> القولَ الأول بقوله: «والمعنى الأول أظهر وأبين». و<span class="comment-type-4">بيّن</span> أن الآية على القول الثاني «تكون اعتراضًا في أثناء قصة موسى، القَصْدُ به: توبيخ هؤلاء الحضور؛ إذ لم يصبر سلفهم على أداء شكر نعم الله تعالى».</div></p><p><div></p><p><p><span class="item-no">٤٨٠٣١<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: قوله: <span class="qpc-hafs">﴿يا بني إسرائيل قد أنجيناكم من عدوكم﴾</span> مِن فرعون وقومه، <span class="qpc-hafs">﴿وواعدناكم جانب الطور الأيمن﴾</span> أيمن الجبل، والطور هو الجبل، يعني: مواعدته لموسى{3}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَنَزَّلۡنَا عَلَیۡكُمُ ٱلۡمَنَّ وَٱلسَّلۡوَىٰ ۝٨٠﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٨٠٣٢<span class="dash">-</span></span> عن <span class="name-2">الضحاك بن مزاحم</span> -من طريق قرة بن خالد- قال: السلوى: السُّمانى{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٠٣٣<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق الحسن بن دينار- قال: السلوى: السُّمانى{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٠٣٤<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- قوله: <span class="qpc-hafs">﴿ونزلنا عليكم المن والسلوى﴾</span>، قال: المَنُّ كان ينزل عليهم في محلتهم مثل العسل، من طلوع الفجر إلى طلوع الشمس، والسلوى هو الطير الذي يُقال له: السُّمانى{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٠٣٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ونزلنا عليكم المن والسلوى﴾</span> في التِّيه، أما المَنُّ: فالتَّرَنجَبِينُ، كان بين أعينهم بالليل على شجرهم أبيض كأنه الثلج، حلو مثل العسل، فيغدون عليه، فيأخذون منه ما يكفيهم يومَهم ذلك، ولا يرفعون منه لغد، ويأخذون يوم الجمعة ليومين؛ لأنّ السبت كان عندهم لا يسيحون فيه، ولا يعملون فيه، هذا لهم وهم في التِّيه مع موسى ﵇. وأما السلوى وهو الطير، وذلك أنّ بني إسرائيل سألوا موسى اللحم وهم في التِّيه، فسأل موسى ﵇ ربه ﷿ ذلك، فقال الله: لأطعمنهم أقلَّ الطير لحمًا. فبعث الله سبحانه سحابًا، فأمطرت سُمانًا، وجمعتهم الريحُ الجنوب، وهي طير حمر تكون في طريق مصر، فمَطَرَتْ قدر ميل في عرض الأرض، وقدر طول رُمْح في السماء{7}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن أبي داود في المصاحف ١/٣٢٣.</p><p>و(قَدْ نَجَّيْتُكُم) قراءة شاذة.تفسير مقاتل بن سليمان ٣/٣٥.تفسير يحيى بن سلّام ١/٢٦٩.أخرجه يحيى بن سلّام ١/٢٦٩.أخرجه يحيى بن سلّام ١/٢٦٩.أخرجه يحيى بن سلّام ١/٢٦٩.تفسير مقاتل بن سليمان ٣/٣٥. وقد تقدمت الآثار مفصلة في معنى المن والسلوى في تفسير قوله تعالى: <span class="qpc-hafs">﴿وظَلَّلْنا عَلَيْكُمُ الغَمامَ وأَنْزَلْنا عَلَيْكُمُ المَنَّ والسَّلْوى﴾</span> [البقرة:٥٧].
  20,81,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿كُلُوا۟ مِن طَیِّبَـٰتِ مَا رَزَقۡنَـٰكُمۡ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٨٠٣٦<span class="dash">-</span></span> قال <span class="name-2">إسماعيل السدي</span>: <span class="qpc-hafs">﴿من طيبات ما رزقناكم﴾</span>، يعني: مِن الحلال؛ المن والسلوى{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٠٣٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: يقول الله -تعالى ذِكْرُه-: <span class="qpc-hafs">﴿كلوا من طيبات ما رزقناكم﴾</span>، يعني: بالطيبات الحلال مِن الرزق{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٠٣٨<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: قوله: <span class="qpc-hafs">﴿كلوا من طيبات ما رزقناكم﴾</span> المن والسلوى{3}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَلَا تَطۡغَوۡا۟ فِیهِ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٨٠٣٩<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- في قوله: <span class="qpc-hafs">﴿ولا تطغوا فيه﴾</span>، يقول: لا تظلِموا{4}<span class=comment-ref>٤٢٩٥</span>. (١٠/٢٢٣)</p></p><p></div></p><p><div><span class=comment-ref>٤٢٩٥</span> لم يذكر <u>ابنُ جرير</u> (١٩/١٢٥) غير قول ابن عباس.</div></p><p><div></p><p><p><span class="item-no">٤٨٠٤٠<span class="dash">-</span></span> تفسير <span class="name-2">إسماعيل السُّدِّيّ</span>: <span class="qpc-hafs">﴿ولا تطغوا فيه﴾</span>، يعني: لا تعصوا الله في رفع المنِّ والسلوى{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٠٤١<span class="dash">-</span></span> قال <span class="name-3">محمد بن السائب الكلبي</span>: لا تكفروا النعمة؛ فتكونوا طاغين{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٠٤٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ولا تطغوا فيه﴾</span>، يقول: ولا تعصوا في الرزق، يعني: فيما رزقناكم من المن والسلوى فترفعوا منه لغد، وكان الله سبحانه قد نهاهم أن يرفعوا منه لِغَد، فعصوا الله ﷿، ورفعوا منه، وقدَّدُوا، فَتَدَوَّدَ ونَتَنَ، ولولا صنيع بني إسرائيل لم يتغير الطعام أبدًا، ولولا حواء زوج آدم ﵉ لم تخن أنثى زوجُها الدهرَ، فذلك قوله: <span class="qpc-hafs">﴿ولا تطغوا فيه﴾</span>، كقوله تعالى لفرعون: <span class="qpc-hafs">﴿إنه طغى﴾</span> [طه:٢٤]، يعني: عصى{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٠٤٣<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span>، في قوله: <span class="qpc-hafs">﴿ولا تطغوا فيه﴾</span>، قال: الطغيان فيه أن يأخذه بغير حِلِّهِ{8}. (١٠/٢٢٤)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿فَیَحِلَّ عَلَیۡكُمۡ غَضَبِیۖ﴾</span> - قراءات</h3></p><p><div></p><p><p><span class="item-no">٤٨٠٤٤<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: وهي تُقْرَأ على وجه آخر: ‹فَيَحُلَّ عَلَيْكُمْ غَضَبِي›{9}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿فَیَحِلَّ عَلَیۡكُمۡ غَضَبِیۖ﴾</span> - تفسير الآية</h3></p><p><div></p><p><p><span class="item-no">٤٨٠٤٥<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق مَعْمَر- في قوله: <span class="qpc-hafs">﴿فيحل عليكم غضبي﴾</span>، قال: فينزل عليكم غضبي{10}<span class=comment-ref>٤٢٩٦</span>. (١٠/٢٢٤)</p></p><p></div></p><p><div><span class=comment-ref>٤٢٩٦</span> لم يذكر <u>ابنُ جرير</u> (١٦/١٢٥) غير قول قتادة.</div></p><p><div></p><p><p><span class="item-no">٤٨٠٤٦<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿فيحل عليكم غضبي﴾</span>، قال: يعني: فيجب عليكم غضبي {11}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٠٤٧<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: وهي تقرأ على وجه آخر: ‹فيَحُلَّ عليكم غضبي›، أي: فينزل عليكم غضبي{12}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٠٤٨<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فيحل عليكم غضبي﴾</span>، يعني: فيجب عليكم عذابي{2}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَمَن یَحۡلِلۡ عَلَیۡهِ غَضَبِی﴾</span> - قراءات</h3></p><p><div></p><p><p><span class="item-no">٤٨٠٤٩<span class="dash">-</span></span> عن <span class="name-2">سليمان بن مهران الأعمش</span> أنه قرأ: <span class="qpc-hafs">﴿مَن يَحْلِلْ عَلَيْهِ غَضَبِي﴾</span> بكسر اللام، على تفسير: من يجب عليه غضبي{14}. (١٠/٢٢٤)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَمَن یَحۡلِلۡ عَلَیۡهِ غَضَبِی﴾</span> - تفسير الآية</h3></p><p><div></p><p><p><span class="item-no">٤٨٠٥٠<span class="dash">-</span></span> عن <span class="name-2">أبي مِجْلِزٍ لاحق بن حميد</span>، في قوله: <span class="qpc-hafs">﴿ومَن يَحْلِلْ عَلَيْهِ غَضَبِي﴾</span>، قال: إن غَضَبَهُ خَلْقٌ مِن خَلْقِهِ، يدعوه فيُكَلِّمه{8}. (١٠/٢٢٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٠٥١<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿ومَن يَحْلِلْ عَلَيْهِ غَضَبِي﴾</span>، هو مثل الحرف الأول= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٠٥٢<span class="dash">-</span></span> إلا أنّ <span class="name-2">قتادة</span> قال: ومَن ينزل عليه غضبي{12}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٠٥٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فَيَحِلَّ عَلَيْكُمْ غَضَبِي﴾</span> يعني: فيجب عليكم عذابي، <span class="qpc-hafs">﴿ومَن يَحْلِلْ عَلَيْهِ غَضَبِي﴾</span> عذابي{2}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿فَقَدۡ هَوَىٰ ۝٨١﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٨٠٥٤<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- في قوله: <span class="qpc-hafs">﴿فقد هوى﴾</span>، قال: شَقِيَ{18}<span class=comment-ref>٤٢٩٧</span>. (١٠/٢٢٤)</p></p><p></div></p><p><div><span class=comment-ref>٤٢٩٧</span> لم يذكر <u>ابنُ جرير</u> (١٦/١٢٦) غير قول ابن عباس.</div></p><p><div></p><p><p><span class="item-no">٤٨٠٥٥<span class="dash">-</span></span> عن <span class="name-2">شُفَيِّ بن ماتع الأصبحي</span> -من طريق أيوب بن بشير- قال: وإنّ في جهنم قصرًا يُقال له: هوى، يُرْمى الكافر مِن أعلاه، فيهوي في جهنم أربعين خريفًا قبل أن يبلغ أصله. قال الله جل وعز: <span class="qpc-hafs">﴿ومن يحلل عليه غضبي فقد هوى﴾</span>{19}. (١٠/٢٢٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٠٥٦<span class="dash">-</span></span> قال <span class="name-2">إسماعيل السُّدِّيّ</span>: يعني: فقد هلك{20}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٠٥٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فقد هوى﴾</span>، يقول: ومَن وجَب عليه عذابي فقد هلك{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٠٥٨<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: قوله: <span class="qpc-hafs">﴿فقد هوى﴾</span> في النار{12}. (ز)</p></p><p></div></p></div>",footnotes:1:علَّقه يحيى بن سلّام ١/٢٦٩.تفسير مقاتل بن سليمان ٣/٣٥.تفسير يحيى بن سلّام ١/٢٦٩.أخرجه ابن جرير ١٦/١٢٥. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.علَّقه يحيى بن سلّام ١/٢٦٩، وذكر عقِبَه قول قتادة من طريق سعيد، قال: كانوا لا يأخذون منه لغد؛ لأنه كان يفسد عندهم، ولا يبقى إلا يوم الجمعة، فإنهم كانوا يأخذون ليوم الجمعة والسبت؛ لأنهم كانوا يتفرغون في السبت للعبادة، ولا يعملون شيئًا.تفسير الثعلبي ٦/٢٥٦، وتفسير البغوي ٥/٢٨٧.تفسير مقاتل بن سليمان ٣/٣٥.عزاه السيوطي إلى ابن أبي حاتم.تفسير يحيى بن سلّام ١/٢٧٠.</p><p>و‹فَيَحُلَّ› بضم الحاء قراءة متواترة، قرأ بها الكسائي، وقرأ بقية العشرة: <span class="qpc-hafs">﴿فَيَحِلَّ﴾</span> بكسر الحاء. انظر: النشر ٢/٣٢١، والإتحاف ص٣٨٧.أخرجه عبد الرزاق ٢/١٨، وابن جرير ١٦/١٢٥ من طريق سعيد. وعزاه السيوطي إلى عبد بن حميد، وابن أبي حاتم.أخرجه يحيى بن سلّام ١/٢٧١.تفسير يحيى بن سلّام ١/٢٧٠.تفسير مقاتل بن سليمان ٣/٣٥.عزاه السيوطي إلى ابن أبي حاتم.</p><p><span class="qpc-hafs">﴿ومَن يَحْلِلْ﴾</span> بكسر اللام الأولى قراءة العشرة ما عدا الكسائي؛ فإنه قرأ: <span class="qpc-hafs">﴿ومَن يَحْلُلْ﴾</span> بضمها. انظر: النشر ٢/٣٢١، والإتحاف ص٣٨٧.عزاه السيوطي إلى ابن أبي حاتم.تفسير يحيى بن سلّام ١/٢٧٠.تفسير مقاتل بن سليمان ٣/٣٥.أخرجه ابن جرير ١٦/١٢٦، وابن أبي حاتم -كما في تغليق التعليق ٤/٢٥٦، والإتقان ٢/٢٨-. وعزاه السيوطي إلى ابن المنذر.أخرجه ابن أبي الدنيا مطولًا في كتاب صفة النار -موسوعة ابن أبي الدنيا ٦/٤٠٧ (٣٧)-، وابن أبي حاتم -كما في تفسير ابن كثير ٥/٣٠١-.علقه يحيى بن سلّام ١/٢٧٠.تفسير مقاتل بن سليمان ٣/٣٥.تفسير يحيى بن سلّام ١/٢٧٠.
  20,82,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَإِنِّی لَغَفَّارࣱ لِّمَن تَابَ وَءَامَنَ وَعَمِلَ صَـٰلِحࣰا﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٨٠٥٩<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- <span class="qpc-hafs">﴿وإني لغفار لمن تاب﴾</span> قال: مِن الشرك، <span class="qpc-hafs">﴿وآمن﴾</span> قال: وحَّد الله، <span class="qpc-hafs">﴿وعمل صالحا﴾</span> قال: أدّى الفرائض{1}. (١٠/٢٢٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٠٦٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، في قوله: <span class="qpc-hafs">﴿وإني لغفار﴾</span> الآية، قال: لِمَن تاب من الذنب، وآمَن مِن الشرك، و[عمل] عملًا صالحًا فيما بينه وبين ربه{2}. (١٠/٢٢٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٠٦١<span class="dash">-</span></span> تفسير <span class="name-2">الحسن البصري</span> -من طريق الحسن بن دينار- قوله: <span class="qpc-hafs">﴿وإني لغفار لمن تاب﴾</span> مِن الشرك، <span class="qpc-hafs">﴿وآمن﴾</span> أي: أخلص الإيمان لله، <span class="qpc-hafs">﴿وعمل صالحا﴾</span> في إيمانه{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٠٦٢<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- قوله: <span class="qpc-hafs">﴿وإني لغفار لمن تاب﴾</span> مِن ذنبه، <span class="qpc-hafs">﴿وآمن﴾</span> بربه، <span class="qpc-hafs">﴿وعمل صالحا﴾</span> فيما بينه وبين الله{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٠٦٣<span class="dash">-</span></span> عن <span class="name-2">الربيع بن أنس</span> -من طريق أبي جعفر الرازي-: <span class="qpc-hafs">﴿وإني لغفار لمن تاب﴾</span> مِن الشرك، <span class="qpc-hafs">﴿وآمن﴾</span> يقول: وأخلص لله، وعمل في إخلاصه{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٠٦٤<span class="dash">-</span></span> عن <span class="name-2">زيد بن أسلم</span> -من طريق هشام بن سعد- قال: لا بُدَّ لأهل هذا الدِّين مِن أربع: دخول في دعوة الإسلام، ولا بُدَّ مِن الإيمان وتصديق بالله وبالمرسلين أولهم وآخرهم، وبالجنة والنار، والبعث بعد الموت، ولا بد مِن أن تعمل عملًا تَصدُق به، ولا بد مِن أن تَعْلَم عِلْمًا يحسُن به عَمَلُك. ثم قرأ: <span class="qpc-hafs">﴿وإني لغفار لمن تاب وآمن وعمل صالحا ثم اهتدى﴾</span>{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٠٦٥<span class="dash">-</span></span> عن <span class="name-3">محمد بن السائب الكلبي</span> -من طريق عنبسة-: <span class="qpc-hafs">﴿وإني لغفار لمن تاب﴾</span> من الذنب، <span class="qpc-hafs">﴿وآمن﴾</span> مِن الشرك، <span class="qpc-hafs">﴿وعمل صالحا﴾</span> أدّى ما افترضت عليه{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٠٦٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وإني لغفار لمن تاب﴾</span> مِن الشرك عن عبادة العجل، <span class="qpc-hafs">﴿وآمن﴾</span> يعني: وصدَّق بتوحيد الله ﷿{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٠٦٧<span class="dash">-</span></span> عن <span class="name-3">سفيان الثوري</span>، في قوله: <span class="qpc-hafs">﴿لمن تاب وآمن وعمل صالحا ثم اهتدى﴾</span>، قال: <span class="qpc-hafs">﴿تاب﴾</span> مِن الذنوب، <span class="qpc-hafs">﴿وآمن﴾</span> مِن الشرك، <span class="qpc-hafs">﴿وعمل صالحا ثم اهتدى﴾</span> صام وصلّى، وعرف أنّ لها ثوابًا{9}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿ثُمَّ ٱهۡتَدَىٰ ۝٨٢﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٨٠٦٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- <span class="qpc-hafs">﴿ثم اهتدى﴾</span>، قال: لم يَشْكُك{1}. (١٠/٢٢٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٠٦٩<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، في قوله: <span class="qpc-hafs">﴿ثم اهتدى﴾</span>: علِم أنّ لِعَمَلِه ثوابًا يُجْزى عليه{2}. (١٠/٢٢٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٠٧٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطاء- <span class="qpc-hafs">﴿ثم اهتدى﴾</span>، قال: علِم أنّ ذلك توفيق مِن الله{12}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٠٧١<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span>، في قوله: <span class="qpc-hafs">﴿ثم اهتدى﴾</span>، قال: ثم استقام؛ لَزِم السنة والجماعة{13}. (١٠/٢٢٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٠٧٢<span class="dash">-</span></span> قال <span class="name-2">عامر الشعبي</span>: عَلِم أن لذلك ثوابًا{14}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٠٧٣<span class="dash">-</span></span> عن <span class="name-2">الضحاك بن مزاحم</span> -من طريق جُوَيْبِر- في قوله: <span class="qpc-hafs">﴿ثم اهتدى﴾</span>، قال: استقام{15}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٠٧٤<span class="dash">-</span></span> تفسير <span class="name-2">الحسن البصري</span> -من طريق الحسن بن دينار- قوله: <span class="qpc-hafs">﴿ثم اهتدى﴾</span>: ثُمَّ مضى على العمل الصالح حتى يموت{16}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٠٧٥<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- قوله: <span class="qpc-hafs">﴿ثم اهتدى﴾</span>، يقول: ثم لَزِم الإسلامَ حتى يموت عليه{17}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٠٧٦<span class="dash">-</span></span> عن <span class="name-2">الربيع بن أنس</span> -من طريق أبي جعفر الرازي- <span class="qpc-hafs">﴿ثم اهتدى﴾</span>، قال: أخذ بسُنَّة نبيه ﵇{17}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٠٧٧<span class="dash">-</span></span> عن <span class="name-2">ثابت البناني</span> -من طريق عمر بن شاكر- في قوله: <span class="qpc-hafs">﴿وإني لغفار لمن تاب وآمن وعمل صالحا ثم اهتدى﴾</span>، قال: إلى ولاية أهل بيت النبي ﵇{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٠٧٨<span class="dash">-</span></span> عن <span class="name-3">محمد بن السائب الكلبي</span> -من طريق عنبسة- <span class="qpc-hafs">﴿ثم اهتدى﴾</span>: عرف مُثِيبَه إن خيرًا فخيرًا، وإن شرًا فشرًا{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٠٧٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وعمل صالحا ثم اهتدى﴾</span>، يعني: عرف أنّ لِعَمَلِه ثوابًا يُجازى به. كقوله سبحانه: <span class="qpc-hafs">﴿وبالنجم هم يهتدون﴾</span> [النحل:١٦]، يعني: يعرفون الطريق{21}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٠٨٠<span class="dash">-</span></span> عن <span class="name-3">سفيان الثوري</span>، في قوله: <span class="qpc-hafs">﴿وعمل صالحا ثم اهتدى﴾</span>: صام وصلى، وعرف أن لها ثوابًا {22}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٠٨١<span class="dash">-</span></span> عن <span class="name-3">سفيان الثوري</span>، في قوله: <span class="qpc-hafs">﴿ثم اهتدى﴾</span>، قال: لزم الإسلام حتى مات عليه{23}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٠٨٢<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿وعمل صالحا ثم اهتدى﴾</span>، قال: أصاب العمل{24}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٠٨٣<span class="dash">-</span></span> قال يحيى بن سلّام: وقال بعضهم: <span class="qpc-hafs">﴿ثم اهتدى﴾</span>: ثم عرف الثواب{25}<span class=comment-ref>٤٢٩٨</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٤٢٩٨</span> اختلف السلف في تفسير قوله: <span class="qpc-hafs">﴿ثم اهتدى﴾</span> على سبعة أقوال: <b>الأول</b>: لم يشك في إيمانه. <b>الثاني</b>: لزم الإيمان والعمل الصالح حتى يموت. <b>الثالث</b>: أخذ بسنة النبي ﷺ. <b>الرابع</b>: أصاب العمل. <b>الخامس</b>: عرف جزاء عمله من خير بثواب، أو شر بعقاب. <b>السادس</b>: ثم اهتدى إلى ولاية أهل بيت النبي ﷺ. <b>السابع</b>: أنه استقام.</p><p>وقد <span class="comment-type-3">رجّح</span> <u>ابنُ جرير</u> (١٦/١٢٧) <span class="mustanad">مستندًا إلى الدلالة العقلية</span> أن معناه: «ثم لزم ذلك، فاستقام ولم يضيع شيئًا منه». وعلل (١٦/١٢٩) ذلك بقوله: «وإنما اخترنا القول الذي اخترنا في ذلك من أجل أن الاهتداء: هو الاستقامة على هدى. ولا معنى للاستقامة عليه إلا وقد جمعه الإيمان والعمل الصالح والتوبة، فمن فعل ذلك وثَبَتَ عليه فلا شك في اهتدائه».</p><p>وذكر <u>ابنُ عطية</u> (٦/١١٩) الأقوال المختلفة في الآية، ثم <span class="comment-type-4">علّق</span> فقال: «وهذه كلها تخصيص واحد منها دون ما هو من نوعه بعيد ليس بالقوي، والذي يقوى في معنى <span class="qpc-hafs">﴿ثُمَّ اهْتَدى﴾</span> أن يكون: ثم حفط معتقداته مِن أن يخالف الحق في شيء من الأشياء، فإنّ الاهتداء على هذا الوجه غير الإيمان وغير العمل، ورب مؤمن عمل صالحًا قد أوبقه عدم الاهتداء، كالقدرية والمرجئة وسائر أهل البدع والخوارج. فمعنى <span class="qpc-hafs">﴿ثُمَّ اهْتَدى﴾</span>: ثم مشى في عقائد الشرع على طريق قويم».</div></p><p><h3><span class="qpc-hafs">﴿ثُمَّ ٱهۡتَدَىٰ ۝٨٢﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٤٨٠٨٤<span class="dash">-</span></span> عن علي بن زمعة{26}: مكتوب حول العرش قبل أن تخلق الدنيا بأربعة آلاف عام: <span class="qpc-hafs">﴿وإنِّي لَغَفّارٌ لِمَن تابَ وآمَنَ وعَمِلَ صالِحًا ثُمَّ اهْتَدى﴾</span>{27}. (١٠/٢٢٥)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ١٦/١٢٧. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.عزاه السيوطي إلى سعيد بن منصور، والفريابي.أخرجه يحيى بن سلّام ١/٢٧٠، ٤٩٢.أخرجه ابن جرير ١٦/١٢٧، ١٢٨.أخرجه ابن جرير ١٦/١٢٧، ١٢٨.أخرجه ابن أبي شيبة في مصنفه (ت: محمد عوامة) ١٥/٦٣٢ (٣١٠٨٥).أخرجه ابن جرير ١٦/١٢٩.تفسير مقاتل بن سليمان ٣/٣٦.أخرجه الثوري في تفسيره ص١٩٥.أخرجه ابن جرير ١٦/١٢٧. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.عزاه السيوطي إلى سعيد بن منصور، والفريابي.تفسير البغوي ٥/٢٨٨.عزاه السيوطي إلى ابن أبي حاتم.تفسير الثعلبي ٦/٢٥٦، وتفسير البغوي ٥/٢٨٨.أخرجه الهروي في ذم الكلام وأهله ٢/٤٠٣.أخرجه يحيى بن سلّام ١/٢٧٠.أخرجه ابن جرير ١٦/١٢٧-١٢٨.أخرجه ابن جرير ١٦/١٢٧-١٢٨.أخرجه ابن جرير ١٦/١٢٩.أخرجه ابن جرير ١٦/١٢٩.تفسير مقاتل بن سليمان ٣/٣٦. وأوله في تفسير الثعلبي ٦/٢٥٦، وتفسير البغوي ٥/٢٨٨ منسوبًا إلى مقاتل مهملًا.تفسير سفيان الثوري ص١٩٥.تفسير الثعلبي ٦/٢٥٦.أخرجه ابن جرير ١٦/١٢٨.تفسير يحيى بن سلّام ١/٢٧١.قال محققو الدر: كذا في الأصل، ولعله علي بن ربيعة، فله رواية عن علي بن أبي طالب.عزاه السيوطي إلى الديلمي. وعند الديلمي (٦٣٧٨) عن علي بن أبي طالب.
  20,83,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَمَاۤ أَعۡجَلَكَ عَن قَوۡمِكَ یَـٰمُوسَىٰ ۝٨٣ قَالَ هُمۡ أُو۟لَاۤءِ عَلَىٰۤ أَثَرِی وَعَجِلۡتُ إِلَیۡكَ رَبِّ لِتَرۡضَىٰ ۝٨٤﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٨٠٨٥<span class="dash">-</span></span> عن عمرو بن ميمون، عن <span class="name-1">رجل من أصحاب النبي ﷺ</span>، قال: تَعَجَّل موسى إلى ربه، فقال الله: <span class="qpc-hafs">﴿وما أعجلك عن قومك يا موسى قال هم أولاء على أثري وعجلت إليك رب لترضى﴾</span>. قال: فرأى في ظِلِّ العرش رجلًا، فعجب له، فقال: مَن هذا، يا رب؟ قال: لا أُحَدِّثك مَن هو، لكن سأخبرك بثلاث فيه: كان لا يحسد الناس على ما آتاهم الله مِن فضله، ولا يَعُقُّ والديه، ولا يمشي بالنميمة{1}. (١٠/٢٢٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٠٨٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وما أعجلك عن قومك يا موسى﴾</span> يعني: السبعين الذين اختارهم موسى حين ذهبوا معه إلى الطور ليأخذوا التوراة مِن ربِّه ﷿، فلمّا ساروا عجل موسى ﵇ شوقًا إلى ربه -تبارك وتعالى-، وخلف السبعين، وأمرهم أن يتبعوه إلى الجبل، فقال الله ﷿ له: <span class="qpc-hafs">﴿وما أعجلك عن قومك يا موسى﴾</span>؟ السبعين. <span class="qpc-hafs">﴿قال﴾</span> لربه -جلَّ وعَزَّ-: <span class="qpc-hafs">﴿هم أولاء على أثري﴾</span> يجيئون مِن بعدي، <span class="qpc-hafs">﴿وعجلت﴾</span> يعني: أسرعتُ <span class="qpc-hafs">﴿إليك رب لترضى﴾</span> يقول: حتى ترضى عَنِّي{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٠٨٧<span class="dash">-</span></span> عن <span class="name-3">محمد بن إسحاق</span> -من طريق سلمة- قال: وعد الله موسى حين أهلك فرعون وقومه ونجّاه وقومَه ثلاثين ليلة، ثم أتَمَّها بعشر، فتمَّ ميقاتُ ربه أربعين ليلة، تلقّاه فيها بما شاء، فاستخلف موسى هارون في بني إسرائيل، ومعه السامري، يسير بهم على أثر موسى ليلحقهم به، فلما كلَّم اللهُ موسى قال له: <span class="qpc-hafs">﴿وما أعجلك عن قومك يا موسى هم أولاء على أثري وعجلت إليك رب لترضى﴾</span>{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٠٨٨<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿وعجلت إليك رب لترضى﴾</span>، قال: لأرضيك{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٠٨٩<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>، قوله: <span class="qpc-hafs">﴿وما أعجلك عن قومك يا موسى (٨٣) قال هم أولاء على أثري وعجلت إليك رب لترضى (٨٤)﴾</span>، قال: هم أولاء ينتظرونني مِن بعدي بالذي آتيهم به، وليس يعني: أنهم يتبعونه. وقال بعضهم: يعني: السبعين الذي اختاروا، فذهبوا معه للميعاد{5}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن أبي شيبة ٩/٩١، ٩٣، والبيهقي في الشعب (٦٦٢٥، ١١١١٨). وعزاه السيوطي إلى سعيد بن منصور.تفسير مقاتل بن سليمان ٣/٣٦.أخرجه ابن جرير ١٦/١٣٠.أخرجه ابن جرير ١٦/١٣٠.تفسير يحيى بن سلّام ١/٢٧١.
  20,84,""
  20,85,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿قَالَ فَإِنَّا قَدۡ فَتَنَّا قَوۡمَكَ مِنۢ بَعۡدِكَ وَأَضَلَّهُمُ ٱلسَّامِرِیُّ ۝٨٥﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٨٠٩٠<span class="dash">-</span></span> عن كعب بن مالك، عن النبي ﷺ، قال: «<b>إنّ الله لَمّا وعد موسى أن يُكَلِّمه خرج للوقت الذي وعده، فبينما هو يناجي ربَّه إذ سمع خلفه صوتًا، فقال: إلهي، إنِّي أسمعُ خلفي صوتًا. قال: لعلَّ قومَك ضلُّوا. قال: إلهي، مَن أضلَّهم؟ قال: أضلَّهم السامريُّ. قال: فبِمَ أضلَّهم؟ قال: صاغ لهم عِجلًا جسدًا له خُوار. قال: إلهي، هذا السامريُّ صاغ لهم العجل، فمَن نفخ فيه الروح حتى صار له خُوار؟ قال: أنا، يا موسى. قال: فوَعِزَّتِك، ما أضلَّ قومي أحدٌ غيرك. قال: صدقتَ. قال: يا حكيم الحكماء، لا ينبغي حكيمٌ أن يكون أحكمَ منك</b>»{1}. (١٠/٢٢٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٠٩١<span class="dash">-</span></span> عن <span class="name-2">راشد بن سعد</span>، قال: إنّ موسى لَمّا قدِم على ربِّه واعد قومَه أربعين ليلة، قال: يا موسى، إنّ قومك قد افْتَتَنوا مِن بعدك. قال: يا رب، كيف يفتنون، وقد نجيتهم مِن فرعون، ونجيتهم مِن البحر، وأنعمت عليهم، وفعلت بهم؟! قال: يا موسى، إنّهم اتخذوا مِن بعدك عِجلًا جسدًا له خُوار. قال: يا ربِّ، فمَن جعل فيه الرُّوح؟ قال: أنا. قال: فأنت -يا ربِّ- أضللتَهم. قال: يا موسى، يا رأس النبيين، ويا أبا الحكام، إنِّي رأيت ذلك في قلوبهم؛ فيَسَّرْتُه لهم{2}. (١٠/٢٢٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٠٩٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿قال﴾</span> الله جل جلاله: <span class="qpc-hafs">﴿فإنا قد فتنا قومك﴾</span> يعني: الذين خَلَّفهم مع هارون على ساحل البحر سوى السبعين، <span class="qpc-hafs">﴿من بعدك﴾</span> بالعجل، <span class="qpc-hafs">﴿وأضلهم السامري﴾</span> حين أمرهم بعبادة العجل، وكانوا اثني عشر ألفًا{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٠٩٣<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿فإنا قد فتنا قومك من بعدك وأضلهم السامري﴾</span>، يقول: إنّ السامريَّ قد أضلَّهم{4}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَأَضَلَّهُمُ ٱلسَّامِرِیُّ ۝٨٥﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٨٠٩٤<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، قال: كان السامريُّ مِن أهل كَرمان{5}. (١٠/٢٣١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٠٩٥<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق سعيد بن جبير- قال: كان السامريُّ رجلًا مِن أهل باجَرْما{6}، وكان مِن قوم يعبدون البقر، فكان حُبُّ عبادة البقر في نفسه، وكان قد أظهر الإسلامَ في بني إسرائيل ... وكان اسمُ السامري: موسى بن ظفر، وقع في أرض مصر، فدخل في بني إسرائيل{7}. (١٠/٢٢٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٠٩٦<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span>، قال: كان السامري من أهل كَرمان{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٠٩٧<span class="dash">-</span></span> قال <span class="name-2">قتادة بن دعامة</span>: كان السامريُّ مِن عُظماء بني إسرائيل، مِن قبيلة يُقال لها: سامرة، ولكن نافق بعدما قطع البحر مع موسى{9}<span class=comment-ref>٤٢٩٩</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٤٢٩٩</span> ذكر <u>ابن عطية</u> (٦/١٢٠) قولين في أصل السامريّ: <b>الأول:</b> أنه من بني إسرائيل، ويقال: إنه كان ابن خال موسى ﵇. <b>الثاني:</b>كان أصله مِن العجم مِن أهل كرمان، ولم يكن من بني إسرائيل.</p><p>و<span class="comment-type-3">رجَّح</span> القول الأول قائلًا: «والأول أصح». ولم يذكر مستندًا.</div></p></div>",footnotes:1:عزاه السيوطي إلى ابن مردويه.عزاه السيوطي إلى ابن جرير في تهذيبه.تفسير مقاتل بن سليمان ٣/٣٦.تفسير يحيى بن سلّام ١/٢٧١.عزاه السيوطي إلى ابن أبي حاتم. وكرمان -بفتح الكاف، وربما كسرت والفتح أشهر-: ولاية مشهورة وناحية كبيرة معمورة ذات بلاد وقرى ومدن واسعة بين فارس ومكران وسجستان وخراسان. معجم البلدان ٤/ ٤٥٤.باجَرْما -بفتح الجيم، وسكون الراء، وميم، وألف مقصورة-: قريةٌ قرب الرَّقَّة الواقعة شرق مدينة حلب. معجم البلدان ١/٣١٣.أخرجه ابن جرير ١/٦٧٢-٦٧٣، وسيأتي بتمامه في قصة الآيات.تفسير الثعلبي ٦/٢٥٧.علقه يحيى بن سلّام ١/٢٧٣.
  20,86,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿فَرَجَعَ مُوسَىٰۤ إِلَىٰ قَوۡمِهِۦ غَضۡبَـٰنَ أَسِفࣰاۚ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٨٠٩٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- <span class="qpc-hafs">﴿غضبان أسفا﴾</span>، قال: يعني: حزينًا{1}. (٦/٥٣٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨٠٩٩<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق العوفي- قوله: <span class="qpc-hafs">﴿غضبان أسفا﴾</span>، يقول: <span class="qpc-hafs">﴿أسِفًا﴾</span>: حزينًا. وفي الزخرف [٥٥]: <span class="qpc-hafs">﴿فَلَمّا آسَفُونا﴾</span>، يقول: أغضبونا. والأسف على وجهين: الغضب، والحُزْن{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨١٠٠<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نَجِيح- قوله: <span class="qpc-hafs">﴿أسفا﴾</span>، قال: جَزِعًا. والأَسَف: الجَزَع{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨١٠١<span class="dash">-</span></span> قال <span class="name-2">الحسن البصري</span>: شديد الغضب{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨١٠٢<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق مالك بن دينار- في قوله: <span class="qpc-hafs">﴿فرجع موسى إلى قومه غضبان أسفا﴾</span>، قال: غضبان حزينًا{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨١٠٣<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- قوله: <span class="qpc-hafs">﴿ولما رجع موسى إلى قومه غضبان أسفا﴾</span> [الأعراف:١٥٠]: أي: حزينًا على ما صَنَع قومُه مِن بعده{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨١٠٤<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- <span class="qpc-hafs">﴿غضبان أسفا﴾</span>، قال: حزينًا{7}. (١٠/٢٣١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨١٠٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فرجع موسى﴾</span> مِن الجبل <span class="qpc-hafs">﴿إلى قومه غضبان﴾</span> عليهم، <span class="qpc-hafs">﴿أسفا﴾</span> حزينًا لعبادتهم العجل{8}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿قَالَ یَـٰقَوۡمِ أَلَمۡ یَعِدۡكُمۡ رَبُّكُمۡ وَعۡدًا حَسَنًاۚ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٨١٠٦<span class="dash">-</span></span> قال <span class="name-2">إسماعيل السُّدِّيّ</span>: <span class="qpc-hafs">﴿حسنا﴾</span>، يعني: حقًّا{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨١٠٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿قال﴾</span> لهم: <span class="qpc-hafs">﴿يا قوم ألم يعدكم ربكم وعدا حسنا﴾</span> يعني: حقًّا. كقوله سبحانه في البقرة [٨٠]: <span class="qpc-hafs">﴿وقولوا للناس حسنا﴾</span>، يعني: حقًّا في محمد ﷺ، أن يعطيكم التوراة فيها بيانُ كلِّ شيء. والوعد حين قال ﷿: <span class="qpc-hafs">﴿وواعدناكم جانب الطور الأيمن﴾</span>{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨١٠٨<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿قال يا قوم ألم يعدكم ربكم وعدا حسنا﴾</span> في الآخرة على التَّمَسُّك بدِينه{11}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿أَفَطَالَ عَلَیۡكُمُ ٱلۡعَهۡدُ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٨١٠٩<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نَجِيح- في قوله: <span class="qpc-hafs">﴿أفطال عليكم العهد﴾</span>، يقول: الوَعْد{12}. (١٠/٢٣٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨١١٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: والوَعْد حين قال ﷿: <span class="qpc-hafs">﴿وواعدناكم جانب الطور الأيمن﴾</span> حين سار موسى مع السبعين ليأخذوا التوراة، فطال عليهم العهد، يعني: ميعاده إيّاهم أربعين يومًا، فذلك قوله تعالى: <span class="qpc-hafs">﴿أفطال عليكم﴾</span>{8}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿أَمۡ أَرَدتُّمۡ أَن یَحِلَّ عَلَیۡكُمۡ غَضَبࣱ مِّن رَّبِّكُمۡ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٨١١١<span class="dash">-</span></span> قال <span class="name-2">قتادة بن دعامة</span>: <span class="qpc-hafs">﴿أم أردتم أن يحل عليكم غضب من ربكم﴾</span> أن ينزِل عليكم غضبٌ من ربكم{14}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨١١٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿أم أردتم أن يحل عليكم غضب﴾</span> يعني: أن يجب عليكم عذاب. كقوله تعالى: <span class="qpc-hafs">﴿قد وقع عليكم من ربكم رجس وغضب﴾</span> [الأعراف:٧١]، يعني: عذاب. <span class="qpc-hafs">﴿من ربكم﴾</span>{8}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿فَأَخۡلَفۡتُم مَّوۡعِدِی ۝٨٦﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٨١١٣<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نَجِيح- وفي قوله: <span class="qpc-hafs">﴿فأخلفتم موعدي﴾</span>، يقول: عهدي{16}. (١٠/٢٣٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨١١٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فأخلفتم موعدي﴾</span>، يعني: الأربعين يومًا، وذلك أنهم عدوا الأيام والليالي، فعدوا عشرين يومًا، وعشرين ليلة، ثم قالوا لهارون: قد تَمَّ الأجلُ الذى كان بيننا وبين موسى. فعند ذلك أضلَّهم السامريُّ{8}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن أبي حاتم ٥/١٥٦٨-١٥٦٩. وعزاه السيوطي إلى ابن المنذر.أخرجه ابن أبي حاتم ٥/ ١٥٦٩.تفسير مجاهد ص٤٦٤، وأخرجه ابن جرير ١٦/١٣١.علقه يحيى بن سلّام ١/٢٧١.أخرجه إسحاق البستي في تفسيره ص٢٦٦.أخرجه يحيى بن سلّام ١/٢٧١، وابن جرير ١٦/١٣١.عزاه السيوطي إلى ابن أبي حاتم.تفسير مقاتل بن سليمان ٣/٣٧.علقه يحيى بن سلّام ١/٢٧١.تفسير مقاتل بن سليمان ٣/٣٧.تفسير يحيى بن سلّام ١/٢٧١.علقه يحيى بن سلّام ١/٢٧١. وعزاه السيوطي إلى عبد بن حميد، وابن جرير، وابن المنذر، وابن أبي حاتم.تفسير مقاتل بن سليمان ٣/٣٧.علقه يحيى بن سلّام ١/٢٧١، وقال عَقِبه: وهو مثل الحرف الأول. يشير بذلك إلى قوله تعالى: <span class="qpc-hafs">﴿فَيَحِلَّ عَلَيْكُمْ غَضَبِي﴾</span> [طه:٨١].تفسير مقاتل بن سليمان ٣/٣٧.أخرجه ابن جرير ١٦/١٣٢. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم. وفي تفسير مجاهد ص٤٦٤: <span class="qpc-hafs">﴿ما أخلفنا موعدك﴾</span> أي: عهدك.تفسير مقاتل بن سليمان ٣/٣٧.
  20,87,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿قَالُوا۟ مَاۤ أَخۡلَفۡنَا مَوۡعِدَكَ بِمَلۡكِنَا﴾</span> - قراءات</h3></p><p><div></p><p><p><span class="item-no">٤٨١١٥<span class="dash">-</span></span> عن <span class="name-2">يحيى</span>{1} أنه قرأ: <span class="qpc-hafs">﴿بِمَلْكِنا﴾</span> و‹مُلْكِنا› واحد{2}. (١٠/٢٣٤)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿قَالُوا۟ مَاۤ أَخۡلَفۡنَا مَوۡعِدَكَ بِمَلۡكِنَا﴾</span> - تفسير الآية</h3></p><p><div></p><p><p><span class="item-no">٤٨١١٦<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- في قوله: <span class="qpc-hafs">﴿بملكنا﴾</span>، قال: بأمرنا{3}. (١٠/٢٣٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨١١٧<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نَجِيح- في قوله: <span class="qpc-hafs">﴿ما أخلفنا موعدك بملكنا﴾</span>، يقول: بأمرٍ مَلَكْناه{4}{5}. (١٠/٢٣٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨١١٨<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span>، في قوله: ‹بِمُلْكِنا›، قال: بسلطاننا{6}. (١٠/٢٣٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨١١٩<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿ما أخلفنا موعدك بملكنا﴾</span>، قال: بِطاقَتِنا{7}. (١٠/٢٣٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨١٢٠<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط-، مثله{8}. (١٠/٢٣٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨١٢١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿قالوا ما أخلفنا موعدك بملكنا﴾</span>: ونحن نملك أمرنا{9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨١٢٢<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿ما أخلفنا موعدك بملكنا﴾</span>، قال: يقول: بهوانا. قال: ولكنه جاءت ثلاثة. قال: ومعهم حُليٌّ استعاروه مِن آل فرعون وثياب{10}<span class=comment-ref>٤٣٠٠</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٤٣٠٠</span> أفادت الآثارُ اختلاف المفسرين في معنى: <span class="qpc-hafs">﴿بِمَلْكِنا﴾</span> على أقوال: <b>الأول:</b> بأمْرِنا. <b>الثاني:</b> بطاقتنا. <b>الثالث:</b> بهوانا، ولكنا لم نملك أنفُسَنا.</p><p>و<span class="comment-type-4">علَّق</span> <u>ابنُ جرير</u> (١٦/١٣٥) على هذه الأقوال قائلًا: «وكل هذه الأقوال الثلاثة في ذلك متقارِبات المعنى». ثم بيَّن <span class="comment-type-1">وجْهتها</span> بقوله: «لأنّ مَن لم يملك نَفْسَه لغلَبَة هواه على أمرٍ فإنه لا تمتنع اللغة أن تقول: فعَل فلان هذا الأمر وهو لا يملك نفْسَه، وفَعَلَه وهو لا يَضْبِطُها، وفعَلَه وهو لا يُطيق تَرْكَه».</div></p><p><h3><span class="qpc-hafs">﴿وَلَـٰكِنَّا حُمِّلۡنَاۤ أَوۡزَارࣰا﴾</span> - قراءات</h3></p><p><div></p><p><p><span class="item-no">٤٨١٢٣<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿ولَكِنّا حُمِّلْنا﴾</span>، وهي تُقْرَأ أيضًا: <span class="qpc-hafs">﴿حَمَلْنا﴾</span> خفيفة{11}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَلَـٰكِنَّا حُمِّلۡنَاۤ أَوۡزَارࣰا﴾</span> - تفسير الآية</h3></p><p><div></p><p><p><span class="item-no">٤٨١٢٤<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نَجِيح- في قوله: <span class="qpc-hafs">﴿ولكنا حملنا أوزارا﴾</span>، قال: أثقالًا{12}. (١٠/٢٣٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨١٢٥<span class="dash">-</span></span> قال <span class="name-2">الحسن البصري</span>: <span class="qpc-hafs">﴿أوزارا﴾</span>: آثامًا{13}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨١٢٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ولكنا حملنا أوزارا﴾</span>، يعني: خطايا؛ لأن ذلك حملهم على صُنْعِ العِجْل وعبادته{9}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿مِّن زِینَةِ ٱلۡقَوۡمِ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٨١٢٧<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نَجِيح- في قوله: <span class="qpc-hafs">﴿من زينة القوم﴾</span>: وهي الحُلِيُّ الذي استعاروه مِن آل فرعون{15}. (١٠/٢٣٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨١٢٨<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيِّ</span> -من طريق أسباط- <span class="qpc-hafs">﴿ولكنا حملنا أوزارا من زينة القوم﴾</span>، يقول: مِن حُلِيِّ القِبْط{16}. (١٠/٢٣١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨١٢٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿من زينة القوم﴾</span>، يقول: مِن حُلِيِّ آل فرعون؛ الذهب والفضة{9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨١٣٠<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿ولكنا حملنا أوزارا من زينة القوم﴾</span>، قال: الحلي الذي استعاروه والثياب، ليست مِن الذنوب في شيء، لو كانت الذنوب كانت: حُمِّلْناها نتحملها، فليست من الذنوب في شيء{18}<span class=comment-ref>٤٣٠١</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٤٣٠١</span> لم يذكر <u>ابنُ جرير</u> (١٦/١٣٦-١٣٧) في معنى: <span class="qpc-hafs">﴿ولَكِنّا حُمِّلْنا أوْزارًا مِن زِينَةِ القَوْمِ﴾</span> سوى قول ابن عباس، ومجاهد، والسدي، وابن زيد.</div></p><p><div></p><p><p><span class="item-no">٤٨١٣١<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿من زينة القوم﴾</span>، يعني: قوم فرعون{19}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿فَقَذَفۡنَـٰهَا فَكَذَ ٰ⁠لِكَ أَلۡقَى ٱلسَّامِرِیُّ ۝٨٧﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٨١٣٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق العوفي- <span class="qpc-hafs">﴿فقذفناها﴾</span>: يعني: زينة القوم، حين أمَرَنا السامِرِيُّ لَمّا قبض قبضة مِن أثر جبرائيل، فألقى القبضة على حُلِيِّهم، فصار عِجلًا جسدًا له خوار{20}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨١٣٣<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نَجِيح- في قوله: <span class="qpc-hafs">﴿فقذفناها﴾</span> قال: فألقيناها، <span class="qpc-hafs">﴿فكذلك ألقى السامري﴾</span> قال: كذلك صنع{21}. (١٠/٢٣٣). (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨١٣٤<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿فقذفناها﴾</span>: أي: فنَبَذْناها{22}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨١٣٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فقذفناها فكذلك﴾</span> يعني: هكذا <span class="qpc-hafs">﴿ألقى السامري﴾</span> الحُلِيَّ في النار{9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٨١٣٦<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: وألقى ما معه مِن الحلي، وألقى القومُ ما معهم، وهو قوله: <span class="qpc-hafs">﴿فقذفناها فكذلك ألقى السامري﴾</span> ما معه كما ألقينا ما معنا. فصاغه عِجْلًا، ثم ألقى في فِيهِ الترابَ الذي كان أخذه مِن تحت حافر فرس جبريل{19}. (ز)</p></p><p></div></p></div>",footnotes:1:لعله: يحيى بن وثاب.عزاه السيوطي إلى ابن أبي شيبة، وابن المنذر.</p><p><span class="qpc-hafs">﴿بِمَلْكِنا﴾</span> بفتح الميم قراءة متواترة، قرأ نافع، وأبو جعفر، وعاصم، وقرأ حمزة، و الكسائي، وخلف العاشر: ‹بِمُلْكِنا› بضم الميم، وقرأ بقية العشرة: ‹بِمِلْكِنا› بكسر الميم. انظر: النشر ٢/٣٢١-٣٢٢، والإتحاف ص٣٨٧.أخرجه ابن جرير ١٦/١٣٣، وابن أبي حاتم -كما في التغليق ٤/٢٥٦-.في تفسير مجاهد: بأمر نملكه، وفي ابن جرير ضبطه محققوه: بأمرٍ مِلْكِنا.تفسير مجاهد ص٤٦٤، وأخرجه ابن جرير ١٦/١٣٤، وإسحاق البستي في تفسيره ص٢٦٦ من طريق ابن جريج، وابن أبي حاتم ١/١٠٩. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.عزاه السيوطي إلى ابن أبي حاتم.أخرجه يحيى بن سلّام ١/٢٧٢، وعبد الرزاق ٢/١٨ من طريق معمر، وابن جرير ١٦/١٣٤. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه ابن جرير ١٦/١٣٤. وعزاه السيوطي إلى ابن أبي حاتم.تفسير مقاتل بن سليمان ٣/٣٧.أخرجه ابن جرير ١٦/١٣٤.تفسير يحيى بن سلّام ١/٢٧٢.</p><p>و<span class="qpc-hafs">﴿حُمِّلْنا﴾</span> بضم الحاء، وكسر الميم مشددة قراءة متواترة، قرأ بها نافع، وابن كثير، وابن عامر، وحفص، وأبو جعفر، ورويس، وقرأ بقيّة العشرة: ›حَمَلْنا› بفتح الحاء والميم مخففة. انظر: النشر ٢/٣٢٢، والإتحاف ص٣٨٧.أخرجه ابن جرير ١٦/١٣٦، ١٣٨، وابن أبي حاتم ١/١٠٩. وعلَّقه يحيى بن سلّام ١/٢٧٢، والبخاري ٤/١٧٦٣. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.علقه يحيى بن سلّام ١/٢٧٢. وعقّب عليه وعلى قول مجاهد بقوله: وهو واحد؛ ذلك الثقل: الإثم.تفسير مقاتل بن سليمان ٣/٣٧.أخرجه ابن جرير ١٦/١٣٦، ١٣٨، وابن أبي حاتم ١/١٠٩. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه ابن جرير ١٦/١٣٧. وعزاه السيوطي إلى ابن أبي حاتم.تفسير مقاتل بن سليمان ٣/٣٧.أخرجه ابن جرير ١٦/١٣٧.تفسير يحيى بن سلّام ١/٢٧٢.أخرجه ابن جرير ١٦/١٤١.أخرجه ابن جرير ١٦/١٣٦، ١٣٨. وعلَّقه البخاري ٤/١٧٦٣. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.أخرجه يحيى بن سلّام ١/٢٧٢، وابن جرير ١٦/١٣٨-١٣٩.تفسير مقاتل بن سليمان ٣/٣٧.تفسير يحيى بن سلّام ١/٢٧٢.