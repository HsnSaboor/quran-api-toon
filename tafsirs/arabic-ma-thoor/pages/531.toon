tafsir[22]{c,v,t}:
54,50," <q>﴿وَمَاۤ أَمۡرُنَاۤ إِلَّا وَ ٰ⁠حِدَةࣱ كَلَمۡحِۭ بِٱلۡبَصَرِ ۝٥٠﴾</q> - تفسير ٧٣٩٨٧- عن ابن عباس، عن النبي ﷺ، قال: «ما طَنَّ ذُباب إلا بقَدَر». ثم قرأ: <q>﴿وما أمْرُنا إلّا واحِدَةٌ كَلَمْحٍ بِالبَصَرِ﴾</q>{1}. (١٤/٩٣) ٧٣٩٨٨- عن عبد الله بن عباس -من طريق عطاء- <q>﴿وما أمْرُنا إلّا واحِدَةٌ كَلَمْحٍ بِالبَصَرِ﴾</q>: يريد: أنّ قضائي في خلْقي أسرع مِن لَمْح البصر{2}. (ز) ٧٣٩٨٩- عن عبد الله بن عباس -من طريق الكلبي-: وما أمرنا بمجيء الساعة في السُّرعة إلا كطرْف البصر{2}. (ز) ٧٣٩٩٠- عن الحسن البصري: <q>﴿إلّا واحِدَةٌ كَلَمْحٍ بِالبَصَرِ﴾</q>، يعني: إذا جاء عذاب كُفّار آخر هذه الأُمّة بالنفخة الأولى{4}. (ز) ٧٣٩٩١- قال مقاتل بن سليمان: <q>﴿وما أمْرُنا﴾</q> في الساعة <q>﴿إلّا واحِدَةٌ﴾</q> يعني: إلا مرّة واحدة لا مثنوية لها <q>﴿كَلَمْحٍ بِالبَصَرِ﴾</q> يعني: كجنوح الطّرْف{5}. (ز) ",footnotes:1:عزاه السيوطي إلى ابن مردويه.تفسير البغوي ٧/٤٢٦.تفسير البغوي ٧/٤٢٦.ذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٤/٣٢٤-.تفسير مقاتل بن سليمان ٤/١٨٤.
54,51," <q>﴿وَلَقَدۡ أَهۡلَكۡنَاۤ أَشۡیَاعَكُمۡ فَهَلۡ مِن مُّدَّكِرࣲ ۝٥١﴾</q> - تفسير ٧٣٩٩٢- عن عبد الله بن عباس -من طريق مقسم- قال: <q>﴿ولَقَدْ أهْلَكْنا أشْياعَكُمْ﴾</q> الذين كفروا وكذّبوا بالقَدَر قبلكم{1}. (١٤/٩٣) ٧٣٩٩٣- قال مقاتل بن سليمان: <q>﴿ولَقَدْ أهْلَكْنا﴾</q> بالعذاب <q>﴿أشْياعَكُمْ﴾</q> يعني: عذّبنا إخوانكم أهل مِلّتكم، يا أهل مكة، يعني: الأمم الخالية حين كذّبوا رسلهم، <q>﴿فَهَلْ مِن مُدَّكِرٍ﴾</q> يقول: فهل من مُتَذَكِّر فيعلم أنّ ذلك حقٌّ فيعتبر ويخاف، فلا يكذّب محمدًا ﷺ{2}. (ز) ٧٣٩٩٤- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- <q>﴿ولَقَدْ أهْلَكْنا أشْياعَكُمْ﴾</q> قال: أشياعهم من أهل الكفر من الأمم السالفة، <q>﴿فَهَلْ مِن مُدَّكِرٍ﴾</q> يقول: هل من أحد يتذكّر؟!{3}. (١٤/٩٢) ",footnotes:1:أخرجه اللالكائي في شرح أصول اعتقاد أهل السنة والجماعة ٣/٦٣١-٦٣٢ (١٠١٧). وعزاه السيوطي إلى ابن مردويه.تفسير مقاتل بن سليمان ٤/١٨٤.أخرجه ابن جرير ٢٢/١٦٤ بنحوه.
54,52," <q>﴿وَكُلُّ شَیۡءࣲ فَعَلُوهُ فِی ٱلزُّبُرِ ۝٥٢﴾</q> - تفسير ٧٣٩٩٥- عن عبد الله بن عباس -من طريق مقسم- قال: <q>﴿وكُلُّ شَيْءٍ فَعَلُوهُ فِي الزُّبُرِ﴾</q> الأول، في أُمّ الكتاب، <q>﴿وكُلُّ صَغِيرٍ وكَبِيرٍ مُسْتَطَرٌ﴾</q> يعني: مكتوب{1}. (١٤/٩٣) ٧٣٩٩٦- عن الضَّحّاك بن مُزاحِم -من طريق عبيد- يقول في قوله: <q>﴿فِي الزُّبُرِ﴾</q>، يقول: الكتب{2}. (ز) ٧٣٩٩٧- قال مقاتل بن سليمان: ثم قال: <q>﴿وكُلُّ شَيْءٍ فَعَلُوهُ فِي الزُّبُرِ﴾</q> يعني الأمم الخالية، قال: كلّ شيء عملوه مكتوب في اللوح المحفوظ{3}٦٣٥٠. (ز) ٦٣٥٠ ذكر ابن القيم (٣/٨٩) هذا القول، وساق قولًا آخر بأن المعنى: يُحصى عليهم في كتب أعمالهم. ونقل أنّ أبا إسحاق جمع بين القولين فقال: «مكتوب عليهم قبل أن يفعلوه، ومكتوب عليهم إذا فعلوه للجزاء»، ورجَّحه بقوله: «وهذا أصح» ولم يذكر مستندًا. ٧٣٩٩٨- عن عبد الملك ابن جُرَيْج: <q>﴿وكُلُّ شَيْءٍ فَعَلُوهُ فِي الزُّبُرِ﴾</q> قال: في الكتاب{4}. (١٤/٩٢) ٧٣٩٩٩- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿فِي الزُّبُرِ﴾</q> قال: في الكتاب{2}. (ز) ",footnotes:1:أخرجه اللالكائي في شرح أصول اعتقاد أهل السنة والجماعة ٣/٦٣١-٦٣٢ (١٠١٧). وعزاه السيوطي إلى ابن مردويه.أخرجه ابن جرير ٢٢/١٦٥.تفسير مقاتل بن سليمان ٤/١٨٥.عزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ٢٢/١٦٥.
54,53," <q>﴿وَكُلُّ صَغِیرࣲ وَكَبِیرࣲ مُّسۡتَطَرٌ ۝٥٣﴾</q> - تفسير ٧٤٠٠٠- عن عبد الله بن عباس في قوله: <q>﴿وكُلُّ صَغِيرٍ وكَبِيرٍ مُسْتَطَرٌ﴾</q> قال: مسطور في الكتاب{1}. (١٤/٩٢) ٧٤٠٠١- عن عبد الله بن عباس -من طريق عطية العَوفيّ- قوله: <q>﴿وكُلُّ صَغِيرٍ وكَبِيرٍ مُسْتَطَرٌ﴾</q> يقول: مكتوب، فإذا أراد الله أن يُنزل كتابًا نَسخَتْه السّفرة{2}. (١٤/٩٣) ٧٤٠٠٢- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿وكُلُّ صَغِيرٍ وكَبِيرٍ مُسْتَطَرٌ﴾</q> قال: مكتوب{2}. (١٤/٩٢) ٧٤٠٠٣- عن الضَّحّاك بن مُزاحِم -من طريق عبيد- يقول: <q>﴿مُسْتَطَرٌ﴾</q> قال: مكتوب{4}. (ز) ٧٤٠٠٤- عن عكرمة مولى ابن عباس -من طريق عِمران بن حُدَير- <q>﴿مُسْتَطَرٌ﴾</q>: مكتوب في كلّ سطر{4}. (١٤/٩٣) ٧٤٠٠٥- عن محمد بن كعب القُرَظيّ، قال: طلبتُ هذا القَدَر فيما أنزل اللهُ على محمد ﷺ، فوجدتُه في اقتربت الساعة: <q>﴿وكُلُّ شَيْءٍ فَعَلُوهُ فِي الزُّبُرِ* وكُلُّ صَغِيرٍ وكَبِيرٍ مُسْتَطَرٌ﴾</q>{6}. (١٤/٩٢) ٧٤٠٠٦- عن قتادة بن دعامة -من طريق معمر- <q>﴿وكُلُّ صَغِيرٍ وكَبِيرٍ مُسْتَطَرٌ﴾</q>، قال: محفوظ مكتوب{7}. (١٤/٩٢) ٧٤٠٠٧- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿وكُلُّ صَغِيرٍ وكَبِيرٍ مُسْتَطَرٌ﴾</q>، قال: مكتوب. وقرأ: <q>﴿وما مِن دابَّةٍ فِي الأَرْضِ إلّا عَلى اللَّهِ رِزْقُها ويَعْلَمُ مُسْتَقَرَّها ومُسْتَوْدَعَها كُلٌّ فِي كِتابٍ مُبِينٍ﴾</q> [هود:٦]. وقرأ: <q>﴿وما مِن دابَّةٍ فِي الأَرْضِ ولا طائِرٍ يَطِيرُ بِجَناحَيْهِ إلّا أُمَمٌ أمْثالُكُمْ ما فَرَّطْنا فِي الكِتابِ مِن شَيْءٍ﴾</q> [الأنعام:٣٨]. إنما هو«مفتعل» من: سَطرت إذا كتبت سطرًا{4}. (ز) ",footnotes:1:عزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ٢٢/١٦٥.أخرجه ابن جرير ٢٢/١٦٥.أخرجه ابن جرير ٢٢/١٦٦.أخرجه ابن جرير ٢٢/١٦٦.عزاه السيوطي إلى ابن شاهين في السنة.أخرجه عبد الرزاق ٢/٢٦١، وابن جرير ٢٢/١٦٦، وبنحوه من طريق سعيد. وعزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ٢٢/١٦٦.
54,54," <q>﴿إِنَّ ٱلۡمُتَّقِینَ فِی جَنَّـٰتࣲ وَنَهَرࣲ ۝٥٤﴾</q> - قراءات ٧٤٠٠٨- عن أبي بكر بن عيّاش، أنّ عاصمًا قرأ: <q>﴿فِي جَنّاتٍ ونَهَرٍ﴾</q> مثلّثة منتصبة النون.= (ز) ٧٤٠٠٩- قال أبو بكر: وكان زهير الفرقبي{1} يقرأ: (ونُهُرٍ) يريد: جماعة النهر{2}٦٣٥١. (١٤/٩٨) ٦٣٥١ اختُلف في قراءة قوله: <q>﴿ونهر﴾</q>؛ فقرأ قوم: <q>﴿ونَهَر﴾</q>، وقرأ غيرهم: (ونُهُرٍ). و ذكر ابنُ عطية (٨/١٥٦-١٥٧) أن القراءة الأولى على أن النهر اسم الجنس، يراد به: الأنهار، أو على أنه بمعنى: سعة في الرزق والمنازل. وأن النهر على القراءة الثانية يحتمل احتمالين: الأول: أن يكون جمع نهار؛ إذ لا ليل في الجنة. الثاني: أن يكون جمع نهر. وانتقد الاحتمال الأول، فقال: «وهذا سائغ في اللفظ، قلِق في المعنى». <q>﴿إِنَّ ٱلۡمُتَّقِینَ فِی جَنَّـٰتࣲ وَنَهَرࣲ ۝٥٤﴾</q> - تفسير الآية ٧٤٠١٠- عن ابن عباس، قال: قال رسول الله ﷺ: «النّهر: الضياء والسعة، ليس بنهرٍ جاري»{3}. (١٤/٩٧) ٧٤٠١١- عن عبد الله بن عباس، أنّ نافع بن الأزرق قال له: أخبِرني عن قوله: <q>﴿فِي جَنّاتٍ ونَهَرٍ﴾</q>. قال: النّهر: السَّعَة. قال: وهل تعرف العرب ذلك؟ قال: نعم، أما سمعت لَبيد بن ربيعة وهو يقول: ملكتُ بها كفّي فأنهرتُ فتْقها يرى قائمٌ مِن دونها ما وراءها؟{4}. (١٤/٩٧) ٧٤٠١٢- قال الضَّحّاك بن مُزاحِم: <q>﴿إنَّ المُتَّقِينَ فِي جَنّاتٍ ونَهَرٍ﴾</q> يعني: في ضياء وسعة{5}. (ز) ٧٤٠١٣- عن محمد بن كعب القُرَظيّ، في قوله: <q>﴿إنَّ المُتَّقِينَ فِي جَنّاتٍ ونَهَرٍ﴾</q>، قال: في نور وضياء{6}٦٣٥٢. (١٤/٩٨) ٦٣٥٢ ذكر ابنُ جرير (٢٢/١٦٧) أنه على هذا القول الذي قاله ابن عباس، والضَّحّاك، والقُرَظيّ، فإن قوله: <q>﴿نهر﴾</q> وُجّه إلى معنى: النهار. ٧٤٠١٤- قال مقاتل بن سليمان: <q>﴿إنَّ المُتَّقِينَ فِي جَنّاتٍ﴾</q> يعني: البساتين، <q>﴿ونَهَرٍ﴾</q> يعني: الأنهار الجارية. ويُقال: السعة، مثل قوله في الكهف: <q>﴿وفَجَّرْنا خِلالَهُما نَهَرًا﴾</q> [الكهف:٣٣]{7}. (ز) ٧٤٠١٥- عن شريك، في قوله: <q>﴿فِي جَنّاتٍ ونَهَرٍ﴾</q>، قال: جنات وعيون{8}. (١٤/٩٧) ",footnotes:1:زهير الفرقبي: نحويّ قارئ من علماء الكوفة، قال أبو بكر بن عياش: قلت لزهير الفرقبىّ بمكة: أنّى لك النحو؟ قال: سمعناه من أصحاب أبى الأسود فأخذناه. قال: ومات زهير سنة خمس وخمسين ومائة. وقيل: سنة ست وخمسين ومائة. ينظر: إنباه الرواة ٢/ ١٨.عزاه السيوطي إلى عبد بن حميد. و<q>﴿فِي جَنّاتٍ ونَهَرٍ﴾</q> قراءة العشرة، وأما (ونُهُرٍ) فهي قراءة شاذة. انظر: المحتسب ٢/٣٠٠.عزاه السيوطي إلى ابن مردويه. قال السيوطي: «سند واه».أخرجه الطستي -كما في الإتقان ٢/٧٨-.تفسير الثعلبي ٩/١٧٣، وتفسير البغوي ٤/٢٣٠.عزاه السيوطي إلى الحكيم الترمذي في نوادر الأصول.تفسير مقاتل بن سليمان ٤/١٨٥.عزاه السيوطي إلى عبد بن حميد.
54,55," <q>﴿فِی مَقۡعَدِ صِدۡقٍ عِندَ مَلِیكࣲ مُّقۡتَدِرِۭ ۝٥٥﴾</q> - تفسير ٧٤٠١٦- عن جابر، قال: بينما رسول الله ﷺ يومًا في مسجد المدينة، فذكر بعض أصحابه الجنة، فقال النبيُّ ﷺ: «يا أبا دُجانة، أما علمتَ أنّ مَن أحبّنا وامتُحن بمحبّتنا أسكنه الله تعالى معنا». ثم تلا هذه الآية: <q>﴿فِي مَقْعَدِ صِدْقٍ عِنْدَ مَلِيكٍ مُقْتَدِرٍ﴾</q>{1}. (١٤/٩٩) ٧٤٠١٧- عن بُريْدة، عن رسول الله ﷺ، في قوله: <q>﴿فِي جَنّاتٍ ونَهَرٍ فِي مَقْعَدِ صِدْقٍ عِنْدَ مَلِيكٍ مُقْتَدِرٍ﴾</q>، قال: «إنّ أهل الجنة يدخلون على الجبّار كلّ يوم مرتين، فيقرأ عليهم القرآن، وقد جلس كلُّ امرئ منهم مجلسه الذي هو مجلسه، على منابر الدُّرِّ والياقوت والزُّمُرُّد والذّهب والفِضّة، بالأعمال، فلا تقرُّ أعينهم قطّ كما تقرُّ بذلك، ولم يسمعوا شيئًا أعظم منه، ولا أحسن منه، ثم ينصرفون إلى رحالهم قريرة أعينهم ناعمين، إلى مثلها من الغد»{2}. (١٤/٩٨) ٧٤٠١٨- عن عبد الله بن بُريدة -من طريق صالح بن حيّان- أنه قال في قوله ﷾: <q>﴿فِي مَقْعَدِ صِدْقٍ عِنْدَ مَلِيكٍ مُقْتَدِرٍ﴾</q>: إنّ أهل الجنة يدخلون كلّ يوم على الجبّار ﷿، فيقرؤون عليه القرآن، وقد جلس كلُّ امرئ منهم مجلسه الذي هو يجلسه على منابر الدُّرِّ والياقوت والزُّمُرّد والذّهب والفِضّة بقدر أعمالهم، فلم تقرَّ أعينهم بشيء قطّ كما تقرُّ بذلك، ولم يسمعوا شيئًا أعظم ولا أحسن منه، ثم ينصرفون الى رحالهم ناعمين، قريرة أعينهم إلى مثلها من الغد{3}. (ز) ٧٤٠١٩- قال [جعفر] الصادق: مدح الله المكان بالصّدق، فلا يَقعد فيه إلا أهلُ الصِّدق{4}٦٣٥٣. (ز) ٦٣٥٣ ذكر ابنُ عطية (٨/١٥٧) أنّ قوله تعالى: <q>﴿مَقْعَدِ صِدْقٍ﴾</q> يحتمل احتمالين: الأول: أن يريد به: الصّدق الذي هو ضد الكذب، أي: في المقعد الذي صدقوا في الخبر به. الثاني: أن يكون من قولك: «عُود صدْق» أي: جيد، «ورجل صدق» أي: خيّر، وذو خِلال حسان. ٧٤٠٢٠- قال مقاتل بن سليمان: <q>﴿فِي مَقْعَدِ صِدْقٍ عِنْدَ مَلِيكٍ مُقْتَدِرٍ﴾</q> على ما يشاء، وذلك أنّ أهل الجنة يدخلون على ربهم تعالى على مقدار كلّ يوم جمعة، فيجلسون إليه على قَدْر أعمالهم في الدنيا، وبقَدْر ثوابهم في الآخرة، فيُعطَون في ذلك المجلس ما يحبّون مِن شيء، ثم يعطيهم الرّبُّ تعالى ما لم يسألوه مِن الخير من جنة عَدن ما لم تره عين، ولم تسمعه أذن، ولم يخطُر على قلب بشر{5}. (ز) ٧٤٠٢١- عن ثَور بن يزيد، قال: بلغنا: أنّ الملائكة يأتون المؤمنين يوم القيامة، فيقولون: يا أولياء الله، انطلِقوا. فيقولون: إلى أين؟ فيقولون: إلى الجنة. فيقولون: إنّكم لتذهبون بنا إلى غير بُغيتنا. فيقال لهم: وما بُغيتكم؟ فيقولون: المقعد مع الحبيب. وهو قوله: <q>﴿إنَّ المُتَّقِينَ فِي جَنّاتٍ ونَهَرٍ فِي مَقْعَدِ صِدْقٍ عِنْدَ مَلِيكٍ مُقْتَدِرٍ﴾</q>{6}. (١٤/٩٨) <q>﴿فِی مَقۡعَدِ صِدۡقٍ عِندَ مَلِیكࣲ مُّقۡتَدِرِۭ ۝٥٥﴾</q> - آثار متعلقة بالآية ٧٤٠٢٢- عن سعيد بن المسيّب، قال: دخلتُ المسجدَ وأنا أرى أنّي قد أصبحتُ، فإذا عَلَيَّ ليلٌ طويل، وإذا ليس فيه أحد غيري، فقمتُ، فسمعتُ حركةً خلفي، ففزعتُ، فقال: أيها الممتلئ قلبه فَرقًا، لا تَفْرق -أو لا تفزع- وقل: اللهم، إنك مليك مقتدر، ما تشاء من أمرٍ يكون. ثم سَلْ ما بدا لك. قال سعيد: فما سألتُ الله شيئًا إلا استجاب لي{7}. (١٤/٩٩) ",footnotes:1:أخرجه أبو نعيم في معرفة الصحابة ٥/٢٨٨٣ (٦٧٧٤). وأورده الديلمي في الفردوس ٥/٣٧٧-٣٧٨ (٨٤٨٤).أخرجه الحكيم الترمذي في نوادر الأصول ص٦١٧ (٧٠٢)، من طريق صالح بن حيان، عن ابن بريدة، عن أبيه به. وسنده ضعيف؛ فيه صالح بن حيان، قال عنه ابن حجر في تقريب التهذيب (٢٨٥١): «ضعيف».أخرجه الثعلبي ٩/١٧٤.تفسير الثعلبي ٩/١٧٤، وتفسير البغوي ٧/٤٣٧.تفسير مقاتل بن سليمان ٤/١٨٥.أخرجه الحكيم الترمذي ٢/٩٠، ولم ينسبه إلى قائله.أخرجه ابن أبي شيبة ١٠/٢٥٤.
55,1," مقدمة السورة ٧٤٠٢٣- عن أسماء بنت أبي بكر، قالت: سمعتُ رسول الله ﷺ يقرأ وهو يُصلّي نحو الرُّكن قبل أن يَصْدَع بما يؤمر والمشركون يسمعون: <q>﴿فَبِأَيِّ آلاءِ رَبِّكُما تُكَذِّبانِ﴾</q>{1}. (١٤/١٠٠) ٧٤٠٢٤- عن عائشة، قالت: نَزَلَتْ سورة الرحمن بمكة{2}. (١٤/١٠٠) ٧٤٠٢٥- عن عبد الله بن عباس -من طريق أبي عمرو بن العلاء، عن مجاهد- قال: نَزَلَتْ سورةُ الرحمن بمكة{3}. (١٤/١٠٠) ٧٤٠٢٦- عن عبد الله بن عباس -من طريق خُصَيف، عن مجاهد- قال: نَزَلَتْ سورة الرحمن بالمدينة{4}. (١٤/١٠٠) ٧٤٠٢٧- عبد الله بن عباس -من طريق عطاء الخُراسانيّ-: مدنيّة، ونَزَلَتْ بعد سورة الرّعد{5}. (ز) ٧٤٠٢٨- عن عبد الله بن الزبير، قال: أُنزِل بمكة سورة الرحمن{2}. (١٤/١٠٠) ٧٤٠٢٩- عن عكرمة مولى ابن عباس= (ز) ٧٤٠٣٠- والحسن البصري -من طريق يزيد النحوي-: مدنيّة{7}. (ز) ٧٤٠٣١- عن قتادة بن دعامة -من طريق سعيد-: مدنيّة{8}. (ز) ٧٤٠٣٢- عن قتادة بن دعامة -من طريق همام-: مكّيّة{9}. (ز) ٧٤٠٣٣- عن محمد بن مسلم الزُّهريّ: مدنيّة، ونَزَلَتْ بعد سورة الرّعد{10}. (ز) ٧٤٠٣٤- عن علي بن أبي طلحة: مكّيّة{11}. (ز) ٧٤٠٣٥- قال مقاتل بن سليمان: سورة الرحمن مكّيّة، عددها ثمان وسبعون آية كوفي{12}٦٣٥٤. (ز) ٦٣٥٤ رجّح ابنُ عطية (٣/١٥٨) مستندًا إلى دلالة التاريخ أنّ السورة مكية، ثم قال: «وإنما نَزَلَتْ حين قالت قريش بمكة: وما الرحمن؟ أنسجد لما تأمرنا؟ وفي السيرة أنّ ابن مسعود جهر بقراءتها في المسجد، حتى قامت إليه أندية قريش، فضربوه، وذلك قبل الهجرة». ٧٤٠٣٦- عن علي بن أبي طالب، سمعتُ النبي ﷺ يقول: «لكلّ شيء عَروس، وعَروس القرآن الرحمن»{13}. (١٤/١٠١) ٧٤٠٣٧- عن عبد الله بن مسعود -من طريق عَلْقمة- أنّ رجلًا قال له: إنّي أقرأ المُفصّل في ركعة. فقال: أهذًّا كهَذِّ الشِّعر؟! لكنّ النبيَّ ﷺ كان يقرأ النظائر سورتين في ركعة: الرحمن والنّجم في ركعة، و<q>﴿اقتربت﴾</q> والحاقة في ركعة، والطور والذّاريات في ركعة، و<q>﴿إذا وقَعتْ﴾</q> و<q>﴿ن﴾</q> في ركعة، و<q>﴿عمّ﴾</q> والمُرسلات في ركعة، والدُّخان و<q>﴿إذا الشمس كُوِّرت﴾</q> في ركعة، و<q>﴿سأل سائل﴾</q> والنّازعات في ركعة، و<q>﴿ويلٌ للمطففين﴾</q> و<q>﴿عبس﴾</q> في ركعة{14}. (١٤/١٠٢) ٧٤٠٣٨- عن زِرِّ بن حُبَيْش، قال: كان أول مُفصّل ابن مسعود: الرحمن{15}. (١٤/١٠٢) ",footnotes:1:أخرجه أحمد ٤٤/٥١٧ (٢٦٩٥٥)، والطبراني في الكبير ٢٤/٨٦ (٢٣١)، من طريق ابن لَهيعة، عن أبي الأسود، عن عروة، عن أسماء بنت أبي بكر به. قال الهيثمي في المجمع ٧/١١٧ (١١٣٨٦): «فيه ابن لَهيعة، وفيه ضعف، وحديثه حسن، وبقية رجاله رجال الصحيح». وقال السيوطي: «سند حسن». وقال في الإتقان ١/٥٠: «سند جيد». وقال ابن عاشور في التحرير والتنوير ٢٧/٢٢٨: «سند جيد».عزاه السيوطي إلى ابن مردويه.أخرجه النحاس (٦٧٩).أخرجه البيهقي في الدلائل ٧/١٤٢-١٤٤. وعزاه السيوطي إلى ابن مردويه.أخرجه ابن الضريس في فضائل القرآن ١/٣٣-٣٥.عزاه السيوطي إلى ابن مردويه.أخرجه البيهقي في دلائل النبوة ٧/١٤٢-١٤٣.أخرجه الحارث المحاسبي في فهم القرآن ص٣٩٥-٣٩٦.أخرجه أبو بكر ابن الأنباري -كما في الإتقان في علوم القرآن ١/٥٧-.تنزيل القرآن ص٣٧-٤٢.أخرجه أبو عبيد في فضائله (ت: الخياطي) ٢/٢٠٠.تفسير مقاتل بن سليمان ٤/١٩٣.أخرجه البيهقي في شعب الإيمان ٤/١١٦-١١٧ (٢٢٦٥)، والثعلبي ٩/١٧٦، من طريق هشام البربري، عن علي بن حمزة الكسائي، عن موسى بن جعفر، عن أبيه جعفر، عن أبيه، عن علي بن الحسين، عن أبيه، عن علي به. قال المناوي في التيسير بشرح الجامع الصغير ٢/٢٩٧: «إسناده حسن». وقال في فيض القدير ٥/٢٨٦ (٧٣١٩): «فيه علي بن الحسن دبيس، عدّه الذهبي في الضعفاء والمتروكين. وقال الدارقطني: ليس بثقة». وقال الألباني في الضعيفة ٣/٥٢٦ (١٣٥٠): «منكر».أخرجه أبو داود (١٣٩٦)، والبيهقي في سننه ٢/٦٠. وصححه الألباني في صحيح سنن أبي داود (١٢٤٤).أخرجه أحمد ٧/٢٥.
55,2," <q>﴿ٱلرَّحۡمَـٰنُ ۝١ عَلَّمَ ٱلۡقُرۡءَانَ ۝٢﴾</q> - تفسير الآية، ونزولها ٧٤٠٣٩- عن قتادة بن دعامة -من طريق أبي العوام- <q>﴿الرَّحْمَنُ عَلَّمَ القُرْآنَ﴾</q>، قال: نعمة -والله- عظيمة{1}. (١٤/١٠٣) ٧٤٠٤٠- قال محمد بن السّائِب الكلبي: <q>﴿عَلَّمَ القُرْآنَ﴾</q> علّم القرآنَ محمدًا{2}. (ز) ٧٤٠٤١- قال مقاتل بن سليمان: <q>﴿الرَّحْمنُ﴾</q> وذلك أنه لما نزل: <q>﴿اسْجُدُوا لِلرَّحْمَنِ﴾</q> قال كفار مكة: <q>﴿وما الرَّحْمنُ أنَسْجُدُ لِما تَأْمُرُنا﴾</q> [الفرقان:٦٠] فأنكروا الرحمن، وقالوا: لا نعرف الرحمن. فأخبر الله تعالى عن نفسه، وذكر صُنعه ليُعرَف، فيُوحّد، فقال: <q>﴿الرَّحْمَنُ﴾</q> الذي أنكروه هو الذي <q>﴿عَلَّمَ القُرْآنَ﴾</q>{3}. (ز) ",footnotes:1:أخرجه ابن جرير ٢٢/١٦٨. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.تفسير البغوي ٧/٤٣٨.تفسير مقاتل بن سليمان ٤/١٩٥.
55,3," <q>﴿خَلَقَ ٱلۡإِنسَـٰنَ ۝٣﴾</q> - تفسير ٧٤٠٤٢- قال عبد الله بن عباس: <q>﴿خَلَقَ الإنْسانَ﴾</q> يعني: آدم ﵇{1}. (ز) ٧٤٠٤٣- قال أبو العالية الرِّياحيّ= (ز) ٧٤٠٤٤- والحسن البصري= (ز) ٧٤٠٤٥- وعبد الرحمن بن زيد بن أسلم: <q>﴿خَلَقَ الإنْسانَ﴾</q> اسم جنس، وأراد به: جميع الناس{2}. (ز) ٧٤٠٤٦- عن قتادة بن دعامة -من طريق سعيد- <q>﴿خَلَقَ الإنْسانَ﴾</q>، قال: الإنسان: آدم{3}. (١٤/١٠٣) ٧٤٠٤٧- قال مقاتل بن سليمان: <q>﴿خَلَقَ الإنْسانَ﴾</q>، يعني: آدم ﵇{4}. (ز) ٧٤٠٤٨- عن عبد الملك ابن جُرَيْج، <q>﴿خَلَقَ الإنْسانَ﴾</q>، قال: آدم{5}٦٣٥٥. (١٤/١٠٣) ٦٣٥٥ في المراد بالإنسان ثلاثة أقوال: الأول: أنّ المراد به: جميع الناس. الثاني: أنّ المراد به: آدم. الثالث: أنّ المراد به: محمد ﷺ. ولم يذكر ابنُ جرير (٢٢/١٦٩) سوى القولين الأولين، ثم بيّن احتمال الكلام لهما جميعًا، فقال: «والقولان كلاهما غير بعيدين من الصواب؛ لاحتمال ظاهر الكلام إياهما». وانتقد ابنُ عطية (٨/١٥٩) -مستندًا لعدم الدليل- القول الثاني والثالث بقوله: «وهذا التخصيص لا دليل عليه». ",footnotes:1:تفسير الثعلبي ٩/١٧٧، وتفسير البغوي ٧/٤٣٨.تفسير البغوي ٧/٤٣٨.أخرجه ابن جرير ٢٢/١٦٩. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.تفسير مقاتل بن سليمان ٤/١٩٥.عزاه السيوطي إلى ابن المنذر.
55,4," <q>﴿عَلَّمَهُ ٱلۡبَیَانَ ۝٤﴾</q> - تفسير ٧٤٠٤٩- قال أبو العالية الرِّياحيّ= (ز) ٧٤٠٥٠- والحسن البصري: <q>﴿عَلَّمَهُ البَيانَ﴾</q> النُّطق والكتابة والفهْم والإفهام، حتى عرف ما يقول وما يُقال له{1}. (ز) ٧٤٠٥١- عن قتادة بن دعامة -من طريق سعيد- <q>﴿عَلَّمَهُ البَيانَ﴾</q>، قال: علّمه الله بيان الدنيا والآخرة، بيّن حلاله وحرامه ليَحْتَجّ بذلك عليه، ولله الحُجّة على عباده{2}. (١٤/١٠٣) ٧٤٠٥٢- قال محمد بن كعب القُرَظيّ: <q>﴿عَلَّمَهُ البَيانَ﴾</q> ما يقول وما يُقال له{3}. (ز) ٧٤٠٥٣- قال إسماعيل السُّدِّيّ: <q>﴿عَلَّمَهُ البَيانَ﴾</q> علّم كلَّ قوم لسانهم الذي يتكلّمون به{4}. (ز) ٧٤٠٥٤- قال مقاتل بن سليمان: <q>﴿عَلَّمَهُ البَيانَ﴾</q> يعني: بيان كلّ شيء{5}. (ز) ٧٤٠٥٥- عن عبد الملك ابن جُرَيْج، <q>﴿عَلَّمَهُ البَيانَ﴾</q>، قال: بيّن له سبيل الهُدى، وسبيل الضَّلالة{6}. (١٤/١٠٣) ٧٤٠٥٦- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- قال: <q>﴿عَلَّمَهُ البَيانَ﴾</q> البيان: الكلام{7}٦٣٥٦. (ز) ٦٣٥٦ في قوله: <q>﴿علمه البيان﴾</q> قولان: الأول: أنه بيان الحرام والحلال. الثاني: أنه الكلام والمنطق. وقد ذكر ابنُ جرير (٢٢/١٧٠) القولين، ثم رجّح العموم، فقال: «والصواب من القول في ذلك أن يقال: معنى ذلك: أنّ الله علّم الإنسان ما به الحاجة إليه مِن أمر دينه ودنياه مِن الحلال والحرام، والمعايش والمنطق، وغير ذلك مما به الحاجة إليه؛ لأن الله -جلّ ثناؤه- لم يخصص بخبره ذلك أنه علّمه مِن البيان بعضًا دون بعض، بل عمّ فقال: <q>﴿علمه البيان﴾</q>، فهو كما عمّ -جلّ ثناؤه-». وذكر ابنُ عطية (٨/١٥٩) القول الأول، ووجّهه عليه بقوله: «وهذا جزء من البيان العام». وعلّق على القول الثاني بقوله: «وذلك هو الذي فُضِّل به الإنسانُ من بين سائر الحيوان». ثم ذكر أنّ: «كلّ المعلومات داخلة في البيان الذي علّمه الإنسان، فكأنه قال من ذلك البيان، وفيه معتبر». ورجّح ابنُ كثير (١٣/٣١٣-٣١٤) مستندًا إلى السياق القول الثاني، وعلّل ذلك بقوله: «لأنّ السياق في تعليمه تعالى القرآن، وهو أداء تلاوته، وإنما يكون ذلك بتيسير النطق على الخلْق، وتسهيل خروج الحروف من مواضعها من الحلْق واللسان والشّفتين، على اختلاف مخارجها وأنواعها». ",footnotes:1:تفسير البغوي ٧/٤٣٨. وفي تفسير الثعلبي ٩/١٧٧: أبو العالية، ومرّة الهمذاني، وابن زيد: يعني الكلام الحسن: النطق والتمييز.أخرجه ابن جرير ٢٢/١٦٩، ١٧١، وبنحوه من طريق أبي العوام. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.تفسير الثعلبي ٩/١٧٧.تفسير الثعلبي ٩/١٧٧، وتفسير البغوي ٧/٤٣٨.تفسير مقاتل بن سليمان ٤/١٩٥.عزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ٢٢/١٧٠.
55,5," <q>﴿ٱلشَّمۡسُ وَٱلۡقَمَرُ بِحُسۡبَانࣲ ۝٥﴾</q> - تفسير ٧٤٠٥٧- عن عبد الله بن عباس -من طريق عكرمة- <q>﴿الشَّمْسُ والقَمَرُ بِحُسْبانٍ﴾</q>، قال: بحساب ومنازل يُرسلان{1}. (١٤/١٠٤) ٧٤٠٥٨- عن عبد الله بن عباس -من طريق العَوفيّ- <q>﴿الشَّمْسُ والقَمَرُ بِحُسْبانٍ﴾</q>، قال: يَجْريان بعددٍ وحساب{2}. (ز) ٧٤٠٥٩- عن مجاهد بن جبر -من طريق أبي يحيى- قال: <q>﴿الشَّمْسُ والقَمَرُ بِحُسْبانٍ﴾</q> يَدُوران في مثل قُطب الرَّحى{3}٦٣٥٧. (١٤/١٠٤) ٦٣٥٧ نقل ابنُ عطية (٨/١٥٩) عن مجاهد قوله: «الحُسبان: الفلك المستدير». وعلَّق عليه بقوله: «شبّهه بحُسبان الرّحا، وهو العُود المستدير الذي باستدارته تدور المطحنة». ٧٤٠٦٠- عن الضَّحّاك بن مُزاحِم -من طريق عبيد- قال: <q>﴿الشَّمْسُ والقَمَرُ بِحُسْبانٍ﴾</q> بقَدَرٍ يَجْريان{4}. (١٤/١٠٤) ٧٤٠٦١- عن أبي مالك [الغفاري] -من طريق إسماعيل بن أبي خالد- قال: <q>﴿الشَّمْسُ والقَمَرُ بِحُسْبانٍ﴾</q> بحساب ومنازل لا يَعْدُوانها{5}. (ز) ٧٤٠٦٢- عن أبي مالك [الغفاري]، قال: <q>﴿الشَّمْسُ والقَمَرُ بِحُسْبانٍ﴾</q> عليهما حساب وأجَل كأجَل الناس، فإذا جاء أجَلهما هلَكا{6}. (١٤/١٠٤) ٧٤٠٦٣- عن قتادة بن دعامة -من طريق سعيد- <q>﴿الشَّمْسُ والقَمَرُ بِحُسْبانٍ﴾</q>: إلى أجَل بحساب{7}. (١٤/١٠٣) ٧٤٠٦٤- قال إسماعيل السُّدِّيّ: <q>﴿الشَّمْسُ والقَمَرُ بِحُسْبانٍ﴾</q> بأجَل كآجال الناس، فإذا جاء أجَلهما هلكا{8}. (ز) ٧٤٠٦٥- عن الربيع بن أنس، قال: <q>﴿الشَّمْسُ والقَمَرُ بِحُسْبانٍ﴾</q> يَجْريان بحساب{9}. (١٤/١٠٤) ٧٤٠٦٦- قال محمد بن السّائِب الكلبي: <q>﴿الشَّمْسُ والقَمَرُ بِحُسْبانٍ﴾</q> بحساب ومنازل معدودة، كلّ يوم منزل{10}. (ز) ٧٤٠٦٧- قال مقاتل بن سليمان: <q>﴿الشَّمْسُ والقَمَرُ بِحُسْبانٍ﴾</q> مطالعهما ومغاربهما ثمانين ومائة مطلع، وثمانين ومائة مغرب؛ لتعلموا بها عدد السّنين والحساب{11}٦٣٥٨. (ز) ٦٣٥٨ في قوله: <q>﴿الشمس والقمر بحسبان﴾</q> أقوال: الأول: أنهما بحُسْبان، ومنازل لهما يجريان ولا يعدوانها. الثاني: أنهما يجريان بقدر. الثالث: أنهما يدوران في مثل قُطب الرّحى. وقد رجّح ابنُ جرير (٢٢/١٧٣) -مستندًا إلى اللغة- القول الأول، فقال: «وأولى الأقوال في ذلك بالصواب قول مَن قال: معناه: الشمس والقمر يجريان بحساب ومنازل؛ لأنّ الحُسْبان مصدر من قول القائل: حسبته حسابًا وحسبانًا، مثل قولهم: كفرته كفرانًا، وغفرته غفرانًا، وقد قيل: إنه جمع حساب، كما الشهبان: جمع شهاب». وعلّق ابنُ تيمية (٦/١٦٥) على القول الثالث، فقال: «فهذا مما لا خلاف فيه، بل قد دلّ الكتاب والسنة وأجمع علماء الأُمّة على مثل ما عليه أهل المعرفة مِن أهل الحساب من أنّ الأفلاك مستديرة لا مُسطحة». ٧٤٠٦٨- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿الشَّمْسُ والقَمَرُ بِحُسْبانٍ﴾</q>، قال: يُحْسَب بهما الدّهر والزمان؛ لولا الليل والنهار والشمس والقمر، لم يدرِ أحدٌ كيف يَحسُب شيئًا؛ لو كان الدّهر ليلًا كلّه كيف يُحسَب، أو نهارًا كلّه كيف يُحسَب{2}. (ز) ",footnotes:1:أخرجه إبراهيم الحربي في غريبه كما في تغليق التعليق ٣/٤٩٢، وابن جرير ٢٢/١٧٠، والحاكم ٢/٤٧٤. وعزاه السيوطي إلى الفريابي، وعبد بن حميد، وابن المنذر، وابن أبي حاتم.أخرجه ابن جرير ٢٢/١٧١.أخرجه ابن جرير ٢٢/١٧٢، وهو في تفسير مجاهد ص٦٣٦ من طريق ابن أبي نجيح بلفظ: كحسبان الرحا. وكذا أخرجه الفريابي -كما في تغليق التعليق ٣/٤٩٢- من طريق ابن أبي نجيح، و ابن جرير ٢٢/١٧٢ أيضًا. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه ابن جرير ٢٢/١٧٢. وعزاه السيوطي إلى عبد بن حميد.أخرجه عبد بن حميد -كما في التغليق ٣/٤٩٢-، وابن جرير ٢٢/١٧١ دون آخره.عزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه عبد الرزاق ٣/٢٦٥ من طريق معمر بنحوه، وابن جرير ٢٢/١٧١-١٧٢، وبنحوه من طريق معمر وأبي العوام. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.تفسير الثعلبي ٩/١٧٧.عزاه السيوطي إلى عبد بن حميد.ذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٤/٣٢٥-.تفسير مقاتل بن سليمان ٤/١٩٥.أخرجه ابن جرير ٢٢/١٧١.
55,6," <q>﴿وَٱلنَّجۡمُ وَٱلشَّجَرُ﴾</q> - تفسير ٧٤٠٦٩- عن عبد الله بن عباس -من طريق علي- <q>﴿والنَّجْمُ والشَّجَرُ يَسْجُدانِ﴾</q>، قال: النّجم: ما انبسَط على الأرض. والشّجر: ما كان على ساق{1}. (١٤/١٠٤). (ز) ٧٤٠٧٠- عن سعيد بن جُبَير -من طريق جعفر-، مثله{2}. (١٤/١٠٥) ٧٤٠٧١- عن عبد الله بن عباس أنّ نافع بن الأزرق قال له: أخبِرني عن قوله: <q>﴿والنَّجْمُ والشَّجَرُ يَسْجُدانِ﴾</q>، ما النّجم؟ قال: ما أنَجمَت الأرض مما لا يقوم على ساق، فإذا قام على ساق فهي شجرة، قال صفوان بن أسد التميميّ: لقد أنجم القاع الكبير عِضاهُه{3} وتمّ به حيّا تميم ووائل وقال زُهير بن أبي سُلمى: مُكلّل بأصول النجم تنسِجُه ريح الجنوب لضاحي مائِهِ حُبُكُ{4}{5}. (١٤/١٠٥) ٧٤٠٧٢- عن أبي رَزِين [مسعود بن مالك الأسدي] -من طريق زِبْرقان- قال: النّجم: ما ذهب فرشًا على الأرض؛ ليس له ساق. والشّجر: ما كان له ساق{6}. (١٤/١٠٥) ٧٤٠٧٣- عن مجاهد بن جبر -من طريق ابن أبي نجيح- <q>﴿والنَّجْمُ والشَّجَرُ يَسْجُدانِ﴾</q>، قال: النّجم نَجم السماء، والشجر الشجرة{7}. (١٤/١٠٦) ٧٤٠٧٤- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿والنَّجْمُ﴾</q> يعني: نجم السماء، <q>﴿والشَّجَرُ﴾</q> قال: الشجر: شجر الأرض{8}. (ز) ٧٤٠٧٥- عن إسماعيل السُّدِّيّ -من طريق شريك- <q>﴿والنَّجْمُ والشَّجَرُ يَسْجُدانِ﴾</q>، قال: النّجم: نبات الأرض{9}. (ز) ٧٤٠٧٦- عن محمد بن السّائِب الكلبي -من طريق معمر- قال: النّجم: كلّ شيء ليس له ساق من الشّجر. قال: والشّجر: كلّ شيء له ساق من الشّجر{10}. (ز) ٧٤٠٧٧- قال مقاتل بن سليمان: <q>﴿والنَّجْمُ﴾</q> يعني: كلّ نَبتٍ ليس له ساق، <q>﴿والشَّجَرُ﴾</q> كلّ نَبتٍ له ساق{11}. (ز) ٧٤٠٧٨- عن سفيان الثوري -من طريق مهران- <q>﴿والنَّجْمُ﴾</q> قال: النّجم الذي ليس له ساق، <q>﴿والشَّجَرُ يَسْجُدانِ﴾</q> قال: الشّجر: الذي له سُوق{12}٦٣٥٩. (ز) ٦٣٥٩ أجمع السلف على أنّ الشجر: ما قام على ساق. واختلفوا في معنى النّجم على قولين: الأول: النبات الذي لا ساق له مثل البقْل ونحوه. الثاني: نجم السماء. ووجّه ابنُ عطية (٥/٢٢٤ ط: دار الكتب العلمية) القول الأول، فقال: «وسُمّي نجمًا لأنه نَجَم، أي: ظهر وطلع، وهو مناسب للشّجر نسبة بيّنة». وعلّق على القول الثاني، فقال: «وقال مجاهد، وقتادة، والحسن: النّجم: اسم الجنس من نجوم السماء، والنسبة التي لها من السماء هي التي للشجر من الأرض؛ لأنهما في ظاهرهما». وقد رجّح ابنُ جرير (٢٢/١٧٥) -مستندًا إلى دلالة السياق- القول الأول، فقال: «وأولى القولين في ذلك بالصواب قول مَن قال: عنى بالنجم: ما نجم من الأرض مِن نَبتٍ. لعطف الشّجر عليه، فكان بأن يكون معناه لذلك: ما قام على ساق وما لا يقوم على ساق يسجدان لله، بمعنى: أنه تسجد له الأشياء كلّها المختلفة الهيئات من خَلقِه؛ أشبه وأولى بمعنى الكلام من غيره». ورجّح ابنُ كثير (١٣/٣١٤) -مستندًا إلى النظائر- القول الثاني، فقال: «وهذا القول هو الأظهر -والله أعلم-؛ لقوله تعالى: <q>﴿ألم تر أن الله يسجد له من في السموات ومن في الأرض والشمس والقمر والنجوم والجبال والشجر والدواب وكثير من الناس﴾</q> الآية [الحج: ١٨]». <q>﴿یَسۡجُدَانِ ۝٦﴾</q> - تفسير ٧٤٠٧٩- عن أبي رَزِين [مسعود بن مالك الأسدي] -من طريق زِبْرقان- <q>﴿يَسْجُدانِ﴾</q>، قال: ظِلّهما سجودهما{13}. (١٤/١٠٥) ٧٤٠٨٠- عن سعيد بن جُبَير -من طريق زِبْرقان- قال: <q>﴿والنَّجْمُ والشَّجَرُ يَسْجُدانِ﴾</q> ظِلّهما سجودهما{14}. (ز) ٧٤٠٨١- عن مجاهد بن جبر -من طريق ابن أبي نجيح- <q>﴿والنَّجْمُ والشَّجَرُ يَسْجُدانِ﴾</q>، قال: النّجم نَجم السماء، والشجر الشجرة، يسجد بُكْرةً وعَشيّة{15}٦٣٦٠. (١٤/١٠٦) ٦٣٦٠ نقل ابنُ عطية (٨/١٦٠) عن مجاهد «ما معناه: أنّ السجود في هذا كله تجوُّز، وهو عبارة عن الخضوع والتذلل ونحوه». واستشهد له ابن عطية ببيت من الشعر: ترى الأكم فيها سُجّدًا للحوافر. ٧٤٠٨٢- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿والنَّجْمُ والشَّجَرُ يَسْجُدانِ﴾</q>، قال: لم يَدَعِ اللهُ شيئًا إلا عَبَّدَهُ له{14}. (ز) ٧٤٠٨٣- قال مقاتل بن سليمان: <q>﴿يَسْجُدانِ﴾</q> يعني: سجودهما ظِلّهما طرفي النهار حين تزول الشمس، وعند طلوعها إذا تحوَّل ظِلُّ الشجرة فهو سجودها{11}. (ز) ",footnotes:1:أخرجه ابن جرير ٢٢/١٧٤-١٧٥، وابن أبي حاتم -كما في الإتقان ٢/٤٦-، وأبو الشيخ في العظمة (١٢٢٢)، والحاكم ٢/٤٧٤. وعزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ٢٢/١٧٤-١٧٥، وأبو الشيخ (١٢٠٧) طبعة: دار العصمة.العِضاه: كل شجر له شوك. لسان العرب (عضه).الحُبُك: تَكَسُّر كل شيء، كالرَّملة إذا مرّت عليها الريح الساكنة، والماء القائم إذا مرّت به الريح. التاج (حبك).عزاه السيوطي إلى ابن الأنباري في الوقف والابتداء.أخرجه أبو الشيخ في العظمة (١٢٢٣). وعزاه السيوطي إلى ابن جرير.تفسير مجاهد ص٦٣٦، وأخرجه ابن جرير ٢٢/١٧٤ بنحوه. وعزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ٢٢/١٧٥-١٧٦، وعبد الرزاق ٣/٢٦٥ في بيان معنى النجم من طريق معمر.أخرجه ابن جرير ٢٢/١٧٤.أخرجه عبد الرزاق ٣/٢٦٥.تفسير مقاتل بن سليمان ٤/١٩٥.أخرجه ابن جرير ٢٢/١٧٤، ١٧٦.أخرجه ابن جرير ٢٢/١٧٦، وأبو الشيخ (١٢٢٣).أخرجه ابن جرير ٢٢/١٧٦.تفسير مجاهد ص٦٣٦، وأخرجه ابن جرير ٢٢/١٧٤، ١٧٧ بنحوه. وعزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ٢٢/١٧٦.تفسير مقاتل بن سليمان ٤/١٩٥.
55,7," <q>﴿وَٱلسَّمَاۤءَ رَفَعَهَا وَوَضَعَ ٱلۡمِیزَانَ ۝٧﴾</q> - تفسير ٧٤٠٨٤- عن مجاهد بن جبر -من طريق ابن أبي نجيح- <q>﴿ووَضَعَ المِيزانَ﴾</q>، قال: العدل{1}٦٣٦١. (١٤/١٠٦) ٦٣٦١ لم يذكر ابنُ جرير (٢٢/١٧٧) غيرَ قول مجاهد. ٧٤٠٨٥- قال الحسن البصري= (ز) ٧٤٠٨٦- والضَّحّاك بن مُزاحِم= (ز) ٧٤٠٨٧- وقتادة بن دعامة: <q>﴿ووَضَعَ المِيزانَ﴾</q> هو الذي يُوزَن به لينتصف به الناسُ بعضهم من بعض{2}. (ز) ٧٤٠٨٨- قال مقاتل بن سليمان: <q>﴿والسَّماءَ رَفَعَها﴾</q> مِن الأرض مسيرة خمسمائة عام، <q>﴿ووَضَعَ المِيزانَ﴾</q> الذي يَزِن به الناسُ، وضعه اللهُ عدلًا بين الناس{3}٦٣٦٢. (ز) ٦٣٦٢ للسلف في المراد بالميزان قولان: الأول: أنه العدل. الثاني: أنه الميزان المعروف بين الناس. وقد وجّه ابنُ عطية (٨/١٦١) القول الثاني بقوله: «والميزان المعروف جزء من الميزان الذي يُعبّر به عن العدل». ثم رجّح أنّ قوله: <q>﴿وضع الميزان﴾</q> مراد به: العدل، وأن قوله: <q>﴿ألا تطغوا في الميزان﴾</q> وقوله: <q>﴿ولا تخسروا الميزان﴾</q> وقوله: <q>﴿وأقيموا الوزن بالقسط﴾</q> مراد به: الميزان المعروف، فقال: «ويظهر عندي أن قوله: <q>﴿وضع الميزان﴾</q> يريد به: العدل. وقوله: <q>﴿ألا تطغوا في الميزان﴾</q> وقوله: <q>﴿وأقيموا الوزن﴾</q> وقوله: <q>﴿ولا تخسروا الميزان﴾</q> يريد به: الميزان المعروف». ولم يذكر مستندًا، ثم علّق بقوله: «وكلّ ما قيل محتمل سائغ». ",footnotes:1:تفسير مجاهد ص٦٣٦، وأخرجه ابن جرير ٢٢/١٧٧-١٧٨. وعزاه السيوطي إلى ابن المنذر.تفسير الثعلبي ٩/١٧٨، وتفسير البغوي ٧/٤٤٢.تفسير مقاتل بن سليمان ٤/١٩٥.
55,8," <q>﴿أَلَّا تَطۡغَوۡا۟ فِی ٱلۡمِیزَانِ ۝٨﴾</q> - تفسير ٧٤٠٨٩- عن قتادة بن دعامة -من طريق سعيد- <q>﴿ألّا تَطْغَوْا فِي المِيزانِ﴾</q>، قال: اعدل -يا ابن آدم- كما تُحبّ أن يُعدل عليك، وأَوْفِ كما تُحبُّ أن يُوفى لك؛ فإنّ العدل يُصلح الناس{1}. (١٤/١٠٦) ٧٤٠٩٠- قال مقاتل بن سليمان: <q>﴿ألّا تَطْغَوْا فِي المِيزانِ﴾</q>، يعني: ألّا تظلِموا في الميزان{2}. (ز) ",footnotes:1:أخرجه ابن جرير ٢٢/١٧٨ بنحوه. وعزاه السيوطي إلى ابن المنذر.تفسير مقاتل بن سليمان ٤/١٩٦.
55,9," <q>﴿وَأَقِیمُوا۟ ٱلۡوَزۡنَ بِٱلۡقِسۡطِ وَلَا تُخۡسِرُوا۟ ٱلۡمِیزَانَ ۝٩﴾</q> - تفسير ٧٤٠٩١- قال أبو الدّرداء: <q>﴿وأَقِيمُوا الوَزْنَ بِالقِسْطِ﴾</q> أقيموا لسان الميزان بالعدل{1}. (ز) ٧٤٠٩٢- عن عبد الله بن عباس -من طريق مُغيرة بن مسلم- أنّه رأى رجلًا يَزِن قد أرجح، فقال: أقِم اللسانَ كما قال الله: <q>﴿وأَقِيمُوا الوَزْنَ بِالقِسْطِ﴾</q>{2}. (١٤/١٠٦) ٧٤٠٩٣- عن عبد الله بن عباس -من طريق مُغيرة بن مسلم، عن أبي المُغيرة- أنه كان يقول في سُوق المدينة: يا معشر الموالي، إنّكم قد بُليتم بأمرين أُهلك فيهما أُمّتان مِن الأُمَم: المكيال، والميزان{3}. (ز) ٧٤٠٩٤- عن قتادة، <q>﴿والسماء رفعها ووضع الميزان ألا تطغوا في الميزان وأقيموا الوزن بالقسط ولا تخسروا الميزان﴾</q>، قال: قال ابن عباس: يا معشر الموالي، إنكم وُلِّيتم أمرَين بهما هلك من كان قبلكم، اتقى الله رجلٌ عند ميزانه، اتقى الله رجلٌ عند مكياله، فإنما يعدله شيء يسير، ولا ينقصه ذلك، بل يزيده الله -إن شاء الله-{4}. (ز) ٧٤٠٩٥- عن مجاهد بن جبر -من طريق ابن أبي نجيح- <q>﴿وأَقِيمُوا الوَزْنَ بِالقِسْطِ﴾</q>، قال: اللسان{5}. (١٤/١٠٧) ٧٤٠٩٦- قال عطاء: <q>﴿وأَقِيمُوا الوَزْنَ بِالقِسْطِ﴾</q> أقيموا لسان الميزان بالعدل{6}. (ز) ٧٤٠٩٧- قال مقاتل بن سليمان: <q>﴿وأَقِيمُوا الوَزْنَ بِالقِسْطِ﴾</q> يعني: اللسان بالعدل، <q>﴿ولا تُخْسِرُوا﴾</q> يعني: ولا تَنقصوا <q>﴿المِيزانَ﴾</q>{7}. (ز) ٧٤٠٩٨- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- <q>﴿ولا تُخْسِرُوا﴾</q>، قال: نَقْصه، إذا نَقَصه فقد خَسَره؛ تَخسُّره: نَقْصه{4}. (ز) ٧٤٠٩٩- قال سفيان بن عُيينة: <q>﴿وأَقِيمُوا الوَزْنَ بِالقِسْطِ﴾</q> الإقامة باليد، والقِسط بالقلب{1}. (ز) ",footnotes:1:تفسير الثعلبي ٩/١٧٨، وتفسير البغوي ٧/٤٤٢.أخرجه ابن جرير ٢٢/١٧٨ بنحوه، وابن أبي حاتم -كما في فتح الباري ٨/٦٢١- من طريق أبي المغيرة.أخرجه ابن جرير ٢٢/١٧٨-١٧٩.أخرجه ابن جرير ٢٢/١٧٩.أخرجه ابن المنذر -كما في فتح الباري ٨/٦٢١-.تفسير البغوي ٧/٤٤٢.تفسير مقاتل بن سليمان ٤/١٩٦.أخرجه ابن جرير ٢٢/١٧٩.تفسير الثعلبي ٩/١٧٨، وتفسير البغوي ٧/٤٤٢.
55,10," <q>﴿وَٱلۡأَرۡضَ وَضَعَهَا لِلۡأَنَامِ ۝١٠﴾</q> - تفسير ٧٤١٠٠- عن عبد الله بن عباس -من طريق علي- في قوله: <q>﴿والأَرْضَ وضَعَها لِلْأَنامِ﴾</q>، قال: للخلْق{1}. (١٤/١٠٧) ٧٤١٠١- عن عبد الله بن عباس، <q>﴿والأَرْضَ وضَعَها لِلْأَنامِ﴾</q>، قال: للناس{2}. (١٤/١٠٧) ٧٤١٠٢- عن عبد الله بن عباس -من طريق الضَّحّاك- أنّ نافع بن الأزرق قال له: أخبِرني عن قوله: <q>﴿والأَرْضَ وضَعَها لِلْأَنامِ﴾</q>. قال: الأنام: الخلْق، وهم ألف أُمّة: ستمائة في البحر، وأربعمائة في البَر. قال: وهل تعرف العرب ذلك؟ قال: نعم؛ أما سمعتَ لَبيدًا وهو يقول: فإن تَسْألينا مِمَّ نحنُ فإنّنا عصافير من هذا الأنام المُسَحَّر؟{3}. (١٤/١٠٧) ٧٤١٠٣- عن عبد الله بن عباس -من طريق العَوفيّ- قال: كلّ شيء فيه رُوح{4}. (١٤/١٠٧) ٧٤١٠٤- عن مجاهد بن جبر -من طريق ابن أبي نجيح- <q>﴿والأَرْضَ وضَعَها لِلْأَنامِ﴾</q>، قال: للخلائق{5}. (ز) ٧٤١٠٥- عن الضَّحّاك بن مُزاحِم، <q>﴿والأَرْضَ وضَعَها لِلْأَنامِ﴾</q>، قال: كلّ شيء يَدِبّ على الأرض{6}. (١٤/١٠٧) ٧٤١٠٦- قال عامر الشعبي: <q>﴿والأَرْضَ وضَعَها لِلْأَنامِ﴾</q> لكلّ ذي رُوح{7}. (ز) ٧٤١٠٧- عن الحسن البصري -من طريق أبي رجاء- قال: <q>﴿والأَرْضَ وضَعَها لِلْأَنامِ﴾</q> للخلْق؛ الجنّ والإنس{8}. (١٤/١٠٨) ٧٤١٠٨- عن قتادة بن دعامة -من طريق معمر- <q>﴿والأَرْضَ وضَعَها لِلْأَنامِ﴾</q>، قال: للخلْق{9}. (ز) ٧٤١٠٩- قال مقاتل بن سليمان: <q>﴿والأَرْضَ وضَعَها لِلْأَنامِ﴾</q>، يعني: للخليقة مِن أهل الأرض{10}. (ز) ٧٤١١٠- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- <q>﴿والأَرْضَ وضَعَها لِلْأَنامِ﴾</q>، قال: الأنام: الخلْق{4}. (ز) ",footnotes:1:أخرجه ابن جرير ٢٢/١٨٠ بنحوه، وابن أبي حاتم -كما في فتح الباري ٦/٢٩٦-.أخرجه ابن أبي حاتم -كما في فتح الباري ٦/٢٩٦-، والأثر في مسائل نافع (١١، ٢٢٨). وعزاه السيوطي إلى الفريابي.أخرجه الطبراني (١٠٥٩٧). وعزاه السيوطي إلى الطستي.أخرجه ابن جرير ٢٢/١٨٠.تفسير مجاهد ص٦٣٦، وأخرجه ابن جرير ٢٢/١٨٠.عزاه السيوطي إلى ابن المنذر.تفسير الثعلبي ٩/١٧٨.أخرجه ابن جرير ٢٢/١٨٠. وعزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ٢٢/١٨٠، ومن طريق أبي العوام.تفسير مقاتل بن سليمان ٤/١٩٦.أخرجه ابن جرير ٢٢/١٨٠.
55,11," <q>﴿فِیهَا فَـٰكِهَةࣱ وَٱلنَّخۡلُ ذَاتُ ٱلۡأَكۡمَامِ ۝١١﴾</q> - تفسير ٧٤١١١- عن عبد الله بن عباس، <q>﴿والنَّخْلُ ذاتُ الأَكْمامِ﴾</q>، قال: أوعية الطّلْع{1}. (١٤/١٠٨) ٧٤١١٢- قال الضَّحّاك بن مُزاحِم: <q>﴿ذاتُ الأَكْمامِ﴾</q> أي: ذات الغُلف{2}. (ز) ٧٤١١٣- عن الضَّحّاك بن مُزاحِم -من طريق جويبر-= (ز) ٧٤١١٤- والحسن البصري -من طريق محدث- في قوله ﷿: <q>﴿والنخل ذات الأكمام﴾</q>، قال: اللّيف؛ كُمَّ به النّخل{3}. (ز) ٧٤١١٥- عن الحسن البصري -من طريق أبى رجاء- في قوله: <q>﴿والنَّخْلُ ذاتُ الأَكْمامِ﴾</q>، قال: الأكمام: سَبِيبَة{4} من ليف عُصِبَتْ بها{5}. (ز) ٧٤١١٦- عن الحسن البصري -من طريق معمر-= (ز) ٧٤١١٧- وقتادة بن دعامة -من طريق معمر- في قوله: <q>﴿والنَّخْلُ ذاتُ الأَكْمامِ﴾</q>، قال: أكمامها: لِيفها{6}. (ز) ٧٤١١٨- عن قتادة بن دعامة -من طريق أبي العوام- في قوله: <q>﴿والنَّخْلُ ذاتُ الأَكْمامِ﴾</q>، قال: أكمامها: رُفاتُها{7}٦٣٦٣. (ز) ٦٣٦٣ نقل ابنُ عطية (٨/١٦١) عن قتادة قوله: «أكمام النخل: رقابها». ثم علَّق بقوله: «والكُمّ من النبات: كل ما التفَّ على شيءٍ وستره، ومنه كمائم الزهر، وبه شبه كُمُّ الثوب». ٧٤١١٩- قال مقاتل بن سليمان: <q>﴿فِيها﴾</q> يعني: في الأرض <q>﴿فاكِهَةٌ والنَّخْلُ ذاتُ الأَكْمامِ﴾</q> يعني: ذات الأجواف، مثل قوله: <q>﴿وما تَخْرُجُ مِن ثَمَراتٍ مِن أكْمامِها﴾</q> [فصلت:٤٧]، يعني: الكُفُرّى{8} مُوقَر طَلْعها{9}. (ز) ٧٤١٢٠- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿والنَّخْلُ ذاتُ الأَكْمامِ﴾</q>، قيل له: هو الطّلْع؟ قال: نعم، وهو في كُمٍّ منه حتى يَنفَتق عنه. قال: والحَبّ أيضًا في أكمام. وقرأ: <q>﴿وما تَخْرُجُ مِن ثَمَراتٍ مِن أكْمامِها﴾</q> [فصلت:٤٧]{10}٦٣٦٤. (ز) ٦٣٦٤ اختُلف في معنى قوله: <q>﴿والنخل ذات الأكمام﴾</q> على أقوال: الأول: أنه عنى بذلك: تكمّم النخل في اللّيف. الثاني: أنه عنى بالأكمام: الرفات. الثالث: أنّ معناه: والنخل ذات الطلع المتكمّم في كمامه. وقد رجّح ابنُ جرير (٢٢/١٨٢) العموم، فقال: «وأولى الأقوال في ذلك بالصواب أن يُقال: إنّ الله وصف النخل بأنها ذات أكمام، وهي متكمّمة في لِيفها، وطَلْعها متكمّم في جُفِّه، ولم يخصّص الله الخبر عنها بتكمّمها في لِيفها ولا تكمّم طلْعها في جُفِّه، بل عمّ الخبر عنها بأنها ذات أكمام، والصواب أن يقال: عنى بذلك ذات لِيف، وهي به مُتكمّمة وذات طَلْع هو في جُفّه متكمم؛ فيعمّم، كما عم -جلّ ثناؤه-». ",footnotes:1:عزاه السيوطي إلى ابن المنذر.تفسير الثعلبي ٩/١٧٩، وتفسير البغوي ٧/٤٤٢.أخرجه سعيد بن منصور في سننه -التفسير ٧/٥٠٥ (٢١٢٧).السَّبيبَة: الثوب الرقيق. لسان العرب (سبب).أخرجه ابن جرير ٢٢/١٨١.أخرجه عبد الرزاق ٢/٢٦٢، وابن جرير ٢٢/١٨١-١٨٢، وبنحوه من طريق سعيد. وذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٤/٣٢٦- عن الحسن.أخرجه ابن جرير ٢٢/١٨٢، وذكر محققوه أن في بعض النسخ: رقابها.الكُفُرّى -بالضم وتشديد الراء وفتح الفاء وضمها مقصور-: هو وعاء الطلع وقشره الأعلى، وكذلك كافوره. النهاية (كفر).تفسير مقاتل بن سليمان ٤/١٩٦.أخرجه ابن جرير ٢٢/.١٨٢.
55,12," <q>﴿وَٱلۡحَبُّ ذُو ٱلۡعَصۡفِ﴾</q> - تفسير ٧٤١٢١- عن عبد الله بن عباس -من طريق علي- <q>﴿والحَبُّ ذُو العَصْفِ﴾</q>، قال: التِّبن{1}. (١٤/١٠٨) ٧٤١٢٢- عن عبد الله بن عباس -من طريق العَوفيّ- قال: <q>﴿العَصْفِ﴾</q>: ورق الزرع الأخضر الذي قطع رؤوسه، فهو يُسمّى العصف إذا يبس{2}. (١٤/١٠٨) ٧٤١٢٣- عن عبد الله بن عباس -من طريق سعيد- في الآية، قال: العصف: الزرع أول ما يخرج بقلًا{3}. (١٤/١٠٩) ٧٤١٢٤- عن سعيد بن جُبَير -من طريق جعفر- <q>﴿والحَبُّ ذُو العَصْفِ﴾</q>، قال: العصف: البقْل من الزرع{4}. (ز) ٧٤١٢٥- عن مجاهد بن جبر -من طريق ابن أبي نجيح- <q>﴿والحَبُّ ذُو العَصْفِ﴾</q>، قال: ورق الحنطة{5}. (١٤/١٠٨) ٧٤١٢٦- عن الضَّحّاك بن مُزاحِم -من طريق سفيان- في الآية، قال: الحَبّ: الحنطة والشعير. والعصف: القِشر الذي يكون على الحَبّ{6}. (١٤/١٠٨) ٧٤١٢٧- عن الضَّحّاك بن مُزاحِم -من طريق عطية بن الحارث- قال: <q>﴿والحَبُّ ذُو العَصْفِ﴾</q>، العصف: التِّبن{7}. (ز) ٧٤١٢٨- عن أبي مالك غَزْوان الغفاري -من طريق إسماعيل بن أبي خالد- قال: <q>﴿والحَبُّ﴾</q> الحَبّ: أول ما يَنبُت{8}. (ز) ٧٤١٢٩- عن أبي صالح باذام -من طريق إسماعيل- قال: <q>﴿العَصْفِ﴾</q> أول ما يَنبُت{9}. (١٤/١٠٩) ٧٤١٣٠- عن قتادة بن دعامة -من طريق معمر- قال: <q>﴿ذُو العَصْفِ﴾</q> العصف: التِّبن{10}. (ز) ٧٤١٣١- عن عطاء الخُراسانيّ -من طريق يونس بن يزيد- في قول الله ﷿: <q>﴿العصف والريحان﴾</q>، قال: التِّبن{11}. (ز) ٧٤١٣٢- قال مقاتل بن سليمان: <q>﴿والحَبُّ﴾</q> فيها، يعني: في الأرض أيضًا، الحَبّ: يعني البُرّ والشعير، <q>﴿ذُو العَصْفِ﴾</q> يعني: ورق الزرع الذي يكون فيه الحَبّ{12}. (ز) ٧٤١٣٣- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- قال: <q>﴿ذُو العَصْفِ﴾</q> العَصْف: الورق من كلّ شيء. قال: يُقال للزّرع إذا قُطع: عُصافة، وكلّ ورق فهو عُصافة{13}٦٣٦٥. (ز) ٦٣٦٥ ذهب ابن جرير (٢٢/١٨٣) إلى أن معنى: العَصْف هو: الورق الحادث من حَبّ الشعير والبُرّ، والتّبن إذا يبس. ثم قال: «وبنحو الذي قلنا في ذلك قال أهل التأويل». وذكر أقوال السلف على ذلك. ثم ذكر قول الضَّحّاك: «أنّ معنى العصف هو الحَبّ من البُرّ والشعير بعينه». ولم يعلق عليه. <q>﴿وَٱلرَّیۡحَانُ ۝١٢﴾</q> - تفسير ٧٤١٣٤- عن عبد الله بن عباس -من طريق علي- <q>﴿والرَّيْحانُ﴾</q>، قال: خُضرة الزّرع{14}. (١٤/١٠٨) ٧٤١٣٥- عن عبد الله بن عباس -من طريق العَوفيّ- قال: <q>﴿والرَّيْحانُ﴾</q> ما أنبتَت الأرض من الرّيحان الذي يُشم{15}. (١٤/١٠٨) ٧٤١٣٦- عن عبد الله بن عباس، في الآية، قال: <q>﴿والرّيحان﴾</q> حين يستوي على سُوقه ولم يُسَنبل{16}. (١٤/١٠٩) ٧٤١٣٧- عن عبد الله بن عباس -من طريق عكرمة- قال: كل ريحان في القرآن فهو الرزق{17}. (١٤/١٠٩) ٧٤١٣٨- عن عبد الله بن عباس -من طريق سعيد بن جُبَير- <q>﴿والرَّيْحانُ﴾</q>، قال: الرِّيع{17}. (ز) ٧٤١٣٩- عن مجاهد بن جبر -من طريق ابن أبي نجيح- <q>﴿والرَّيْحانُ﴾</q>، قال: الرِّزق{19}. (١٤/١٠٩) ٧٤١٤٠- عن الضَّحّاك بن مُزاحِم -من طريق عبيد- <q>﴿والرَّيْحانُ﴾</q>، قال: الرّيحان: ما أنبَتت الأرض من ريحان{20}. (ز) ٧٤١٤١- عن الضَّحّاك بن مُزاحِم -من طريق عطية بن الحارث- قال: <q>﴿والرَّيْحانُ﴾</q> الرِّزق والطعام{17}. (١٤/١٠٩) ٧٤١٤٢- عن الحسن البصري -من طريق قتادة- <q>﴿والرَّيْحانُ﴾</q>، قال: ريحانكم هذا{22}. (١٤/١٠٩) ٧٤١٤٣- قال محمد بن السّائِب الكلبي: <q>﴿والرَّيْحانُ﴾</q> الرّيحان: الرِّزق{23}. (ز) ٧٤١٤٤- قال مقاتل بن سليمان: <q>﴿والرَّيْحانُ﴾</q> يعني: الرِّزق. نظيرها: <q>﴿فَرَوْحٌ ورَيْحانٌ﴾</q> [الواقعة:٨٩] يعني: الرِّزق، بلسان حِمْيَر، الذي يَخرج من الحَبّ من دقيق أو سويق أو غيره{12}. (ز) ٧٤١٤٥- قال مقاتل بن حيان: <q>﴿والرَّيْحانُ﴾</q> الرِّزق، بلُغة حِمْيَر{25}. (ز) ٧٤١٤٦- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- <q>﴿والرَّيْحانُ﴾</q>، قال: الرّياحيّن التي تُوجد ريحها{20}٦٣٦٦. (١٤/١٠٩) ٦٣٦٦ في المراد بالريحان أقوال: الأول: أنه الرِّزق. الثاني: أنه الرّيحان الذي يُشم. الثالث: أنه ما قام على ساق. الرابع: أنه خُضرة الزرع. وعلّق ابنُ عطية (٨/١٦٢) على القول الثاني بقوله: «وفي هذا النوع نعمة عظيمة؛ ففيه الأزهار، والمندل، والعقاقير، وغير ذلك». وقد رجّح ابنُ جرير (٢٢/١٨٨) -مستندًا إلى الدلالة العقلية، واللغة- القول الأول، فقال: "وأولى الأقوال في ذلك بالصواب قول مَن قال: عني به: الرِّزق، وهو الحَبّ الذي يؤكل منه، وإنما قلنا ذلك أولى الأقوال في ذلك بالصواب لأن الله -جلّ ثناؤه- أخبر عن الحَبّ أنه ذو العَصْف، وذلك ما وصفنا من الورق الحادث منه، والتِّبن إذا يبس، فالذي هو أولى بالرّيحان أن يكون حَبّه الحادث منه، إذ كان من جنس الشيء الذي منه العَصْف، ومسموع من العرب تقول: خرجنا نطلب ريحان الله ورِزقه، ويقال: سبحانك وريحانك، أي: ورِزقك، ومنه قول النّمر بن تولب: سلامُ الإله ورَيحانه وجنّته وسماءٌ دِرر". ثم قال: «وذُكر عن بعضهم أنه كان يقول: العَصْف: المأكول من الحَبّ. والرّيحان: الصحيح الذي لم يؤكل». وقال ابنُ كثير (١٣/٣١٦) عقب ذكره الخلاف في هذا: «ومعنى هذا -والله أعلم- أنّ الحَبّ كالقمح والشعير ونحوهما له في حال نباته عَصْف، وهو: ما على السُّنبلة، وريحان، وهو: الورق الملتفّ على ساقها». ",footnotes:1:أخرجه ابن جرير ٢٢/١٨٣، وابن أبي حاتم -كما في الفتح ٨/٦٢١-. وعزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ٢٢/١٨٣.أخرجه ابن جرير ٢٢/١٨٥ بنحوه، وابن أبي حاتم -كما في الفتح ٨/٦٢١-. وعزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ٢٢/١٨٣-١٨٤.تفسير مجاهد ص٦٣٦، وأخرجه الفريابي -كما في تغليق التعليق ٤/٣٢٩-، وابن جرير ٢٢/١٨٤-١٨٥ بلفظ: العصف: الورق من كل شيء، قال: يقال للزرع إذا قطع: عصافة، وكل ورق فهو عصافة. وعزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ٢٢/١٨٤ بنحوه، وأخرجه ابن أبي حاتم -كما في الفتح ٨/٦٢١- بلفظ: العصف: البر والشعير. وعزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ٢٢/١٨٥. وعلقه البخاري في صحيحه ٤/١٨٤٦.أخرجه ابن جرير ٢٢/١٨٤، وأخرجه عبد بن حميد -كما في تغليق التعليق ٤/٣٢٩- وزاد: تسميه النبط: هبورا.أخرجه أبو الشيخ في العظمة (٧٥٦).أخرجه عبد الرزاق ٢/٢٦٢، وابن جرير ٢٢/١٨٤، وبنحوه من طريق سعيد.أخرجه أبو جعفر الرملي في جزئه (تفسير عطاء) ص١١٢.تفسير مقاتل بن سليمان ٤/١٩٦.أخرجه ابن جرير ٢٢/١٨٤-١٨٥.أخرجه ابن جرير ٢٢/١٨٧. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.عزاه السيوطي إلى ابن جرير ٢٢/١٨٧، وأخرجه ابن جرير ٢٢/١٨٧ كذلك دون قوله: الذي يُشم.عزاه السيوطي إلى ابن جرير، وابن المنذر، وابن أبي حاتم.أخرجه ابن جرير ٢٢/١٨٦.أخرجه ابن جرير ٢٢/١٨٦.تفسير مجاهد ص٦٣٦، وأخرجه الفريابي -كما في تغليق التعليق ٤/٣٢٩-، وابن جرير ٢٢/١٨٦.أخرجه ابن جرير ٢٢/١٨٧.أخرجه ابن جرير ٢٢/١٨٦.أخرجه ابن جرير ٢٢/١٨٧. وذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٤/٣٢٦- بنحوه.ذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٤/٣٢٦-.تفسير مقاتل بن سليمان ٤/١٩٦.تفسير الثعلبي ٩/١٧٩.أخرجه ابن جرير ٢٢/١٨٧.
55,13," <q>﴿فَبِأَیِّ ءَالَاۤءِ رَبِّكُمَا تُكَذِّبَانِ ۝١٣﴾</q> - تفسير ٧٤١٤٧- عن عبد الله بن عمر: أنّ رسول الله ﷺ قرأ سورة الرحمن على أصحابه فسكتوا، فقال: «ما لي أسمعُ الجنَّ أحسن جوابًا لربها منكم؟! ما أتيتُ على قول الله: <q>﴿فَبِأَيِّ آلاءِ رَبِّكُما تُكَذِّبانِ﴾</q> إلا قالوا: لا شيء من نِعمك ربّنا نُكذّب؛ فلك الحمد»{1}. (١٤/١٠١) ٧٤١٤٨- عن جابر بن عبد الله، قال: خرج رسول الله ﷺ على أصحابه، فقرأ عليهم سورة الرحمن مِن أولها إلى آخرها، فسكتوا، فقال: «ما لي أراكم سُكوتًا؟! لقد قرأتُها على الجنّ ليلة الجنّ فكانوا أحسن مردودًا منكم، كنتُ كلّما أتيتُ على قوله: <q>﴿فَبِأَيِّ آلاءِ رَبِّكُما تُكَذِّبانِ﴾</q> قالوا: ولا بشيء من نِعمك ربّنا نُكذّب؛ فلك الحمد»{2}. (١٤/١٠٠) ٧٤١٤٩- عن عبد الله بن عباس -من طريق علي- <q>﴿فَبِأَيِّ آلاءِ رَبِّكُما تُكَذِّبانِ﴾</q>، قال: بأي نعمة الله{3}. (١٤/١٠٩) ٧٤١٥٠- عن عبد الله بن عباس -من طريق مجاهد- أنه كان إذا قرأ: <q>﴿فَبِأَيِّ آلاءِ رَبِّكُما تُكَذِّبانِ﴾</q> قال: لا بأيتها ربنا{4}. (ز) ٧٤١٥١- عن الحسن البصري -من طريق سهل السراج- قال: <q>﴿فَبِأَيِّ آلاءِ رَبِّكُما تُكَذِّبانِ﴾</q> فبأي نعمة ربكما تكذبان{5}. (ز) ٧٤١٥٢- عن قتادة بن دعامة -من طريق سعيد- قوله: <q>﴿فَبِأَيِّ آلاءِ رَبِّكُما تُكَذِّبانِ﴾</q>، يقول للجن والإنس: فبأيِّ نِعَم الله تُكذِّبان؟!{6}. (١٤/١١٠) ٧٤١٥٣- قال مقاتل بن سليمان: لَمّا ذكر ما خَلَق من النِّعَم؛ قال: <q>﴿فَبِأَيِّ آلاءِ رَبِّكُما تُكَذِّبانِ﴾</q> يعني: الجن والإنس، يعني: فبأي نعماء ربكما تكذبان بأنها ليست من الله؟!{7}. (ز) ٧٤١٥٤- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- <q>﴿فَبِأَيِّ آلاءِ رَبِّكُما تُكَذِّبانِ﴾</q>، قال: الآلاء: القدرة، فبأي آلائه تكذب، خلقكم كذا وكذا، فبأي قدرة الله تكذبان أيها الثقلان؛ الجن والإنس{8}. (ز) ",footnotes:1:أخرجه البزار ١٢/١٩٠ (٥٨٥٣)، والمستغفري في فضائل القرآن ٢/٦٢٦ (٩٣٥)، وابن جرير ٢٢/١٩٠، من طريق يحيى بن سليمان الطائفي، عن إسماعيل بن أُميّة، عن نافع، عن ابن عمر به. وأخرجه ابن أبي الدنيا في كتاب الشكر ص٢٦ (٦٨)، من طريق يحيى بن سليم الطائفي، عن إسماعيل بن أُميّة، عن عمرو بن سعد بن العاصي، عن نافع، عن ابن عمر به. قال البزار: «هذا الحديث لا نعلمه يُروى عن النبي ﷺ إلا من هذا الوجه، بهذا الإسناد». وقال السيوطي: «سند صحيح». وأورده الألباني في الصحيحة ٥/١٨٣ (٢١٥٠).أخرجه الترمذي ٥/٤٨٥ (٣٥٧٥)، والحاكم ٢/٥١٥ (٣٧٦٦)، والثعلبي ٩/١٧٩، والواحدي ٤/٢١٩ (١١٥٢)، من طريق الوليد بن مسلم، عن زهير بن محمد، عن محمد بن المنكدر، عن جابر بن عبد الله به. قال الترمذي: «هذا حديث غريب، لا نعرفه إلا من حديث الوليد بن مسلم عن زهير بن محمد». وقال الحاكم: «صحيح، على شرط الشيخين، ولم يخرجاه». ووافقه الذهبي. وقال الألباني في الصحيحة ٥/١٨٤ (٢١٥٠): «الحديث بمجموع الطريقين لا ينزل عن رتبة الحسن».أخرجه ابن جرير ٢٢/١٩٠ بنحوه. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.أخرجه ابن جرير ٢٢/١٩٠-١٩١.أخرجه ابن جرير ٢٢/١٨٩.أخرجه ابن جرير ٢٢/١٩٠، وابن أبي حاتم -كما في تغليق التعليق ٤/٣٣١-.تفسير مقاتل بن سليمان ٤/١٩٦أخرجه ابن جرير ٢٢/١٩١.
55,14," <q>﴿خَلَقَ ٱلۡإِنسَـٰنَ مِن صَلۡصَـٰلࣲ كَٱلۡفَخَّارِ ۝١٤﴾</q> - تفسير ٧٤١٥٥- عن عبد الله بن عباس -من طريق مجاهد- في قوله: <q>﴿مِن صَلْصالٍ كالفَخّارِ﴾</q>، قال: هو مِن الطّين الذي إذا مَطَرت السماء فيَبِست الأرض كأنه خَزف الرّقاق{1}. (ز) ٧٤١٥٦- عن عبد الله بن عباس -من طريق الضَّحّاك- قال: خلَق الله آدم من طين لازِب، واللازِب: اللّزِج الطيب مِن بعد حَمأً مَسْنون مُنتِن. قال: وإنما كان حَمأً مسنونًا بعد التراب. قال: فخَلَق منه آدم بيده. قال: فمكث أربعين ليلة جسدًا مُلْقًى، فكان إبليس يأتيه، فيضربه بِرِجله، فيُصَلْصِل؛ فيُصوِّت. قال: فهو قول الله تعالى: <q>﴿كالفَخّارِ﴾</q>، يقول: كالشيء المُنفَرج الذي ليس بمُصْمَت{1}. (ز) ٧٤١٥٧- عن عبد الله بن عباس -من طريق سعيد بن جُبَير- قال: الصّلصال: التّراب المُدقَّق{1}. (ز) ٧٤١٥٨- عن عبد الله بن عباس -من طريق علي- <q>﴿خَلَقَ الإنْسانَ مِن صَلْصالٍ كالفَخّارِ﴾</q>، قال: الصّلصال: الطين اليابس{4}. (ز) ٧٤١٥٩- عن عبد الله بن عباس -من طريق عكرمة- <q>﴿خَلَقَ الإنْسانَ مِن صَلْصالٍ كالفَخّارِ﴾</q>، قال: ما عُصِر، فخَرج من بين الأصابع{5}. (ز) ٧٤١٦٠- قال عبد الله بن عباس: الصّلصال: الطين الجيّد إذا ذَهب عنه الماء فتشقّق، فإذا تَحرّك تقَعْقع{6}. (ز) ٧٤١٦١- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿مِن صَلْصالٍ كالفَخّارِ﴾</q>، قال: كما يُصنع الفخّار{7}. (ز) ٧٤١٦٢- عن عكرمة مولى ابن عباس -من طريق سماك- في قوله: <q>﴿مِن صَلْصالٍ كالفَخّارِ﴾</q>، قال: الصّلصال: طين قد خُلِط برمل، فكان الفخّار{4}. (ز) ٧٤١٦٣- عن قتادة بن دعامة -من طريق معمر- في قوله: <q>﴿مِن صَلْصالٍ كالفَخّارِ﴾</q>، قال: من طين له صَلْصَلَة{9} كان يابسًا، ثم خَلَق الإنسان منه{10}. (ز) ٧٤١٦٤- عن قتادة بن دعامة -من طريق عثمان- <q>﴿مِن صَلْصالٍ كالفَخّارِ﴾</q>: وهو التراب اليابس الذي يُسمع له صَلْصَلَة{11}. (ز) ٧٤١٦٥- قال مقاتل بن سليمان: <q>﴿خَلَقَ الإنْسانَ﴾</q> يعني: آدم ﵇ <q>﴿مِن صَلْصالٍ﴾</q> يعني: من تُراب الرّمل، ومعه مِن الطين الحر. وأما قوله: <q>﴿كالفَخّارِ﴾</q> يعني: هو بمنزلة الفخّار مِن قبل أن يُطبخ، يقول: كان ابن آدم مِن قبل أن يُنفخ فيه الرّوح بمنزلة الفخّار أجوف{6}٦٣٦٧. (ز) ٦٣٦٧ نقل ابنُ عطية (٨/١٦٤) في معنى: <q>﴿الإنسان﴾</q> عن آخرين قولهم: «أراد: اسم الجنس». وعلَّق عليه بقوله: «وساغ ذلك مِن حيث إنّ أباهم مخلوق من الصلصال». ٧٤١٦٦- عن عبد الرحمن بن زيد بن أسلم، <q>﴿مِن صَلْصالٍ كالفَخّارِ﴾</q>، قال: يَبِس آدمُ في الطين في الجنة، حتى صار كالصّلصال، وهو الفخّار، والحَمأ المسْنون: المُنتن الرّيح{13}. (ز) ",footnotes:1:أخرجه ابن جرير ٢٢/١٩٢.أخرجه ابن جرير ٢٢/١٩٢.أخرجه ابن جرير ٢٢/١٩٢.أخرجه ابن جرير ٢٢/١٩٣.أخرجه ابن جرير ٢٢/١٩٤.تفسير مقاتل بن سليمان ٤/١٩٦.تفسير مجاهد ص٦٣٦، وأخرجه الفريابي -كما في تغليق التعليق ٤/٣٣٠-، وابن جرير ٢٢/١٩٣.أخرجه ابن جرير ٢٢/١٩٣.الصَّلْصَلَة: صوت الحديد إذا حُرِّك. النهاية (صلصل).أخرجه عبد الرزاق ٢/٢٦٢، وابن جرير ٢٢/١٩٣-١٩٤، كذلك أخرج بنحوه من طريق أبي العوام، وسعيد.أخرجه يحيى بن سلّام ٢/٨٢٦.تفسير مقاتل بن سليمان ٤/١٩٦.أخرجه ابن جرير ٢٢/١٩٣-١٩٤.
55,15," <q>﴿وَخَلَقَ ٱلۡجَاۤنَّ﴾</q> - تفسير ٧٤١٦٧- قال الضَّحّاك بن مُزاحِم: <q>﴿وخَلَقَ الجانَّ﴾</q> هو إبليس{1}. (ز) ٧٤١٦٨- قال مقاتل بن سليمان: <q>﴿وخَلَقَ الجانَ﴾</q>، يعني: إبليس{2}. (ز) ",footnotes:1:تفسير الثعلبي ٩/١٨١، وتفسير البغوي ٧/٤٤٤.تفسير مقاتل بن سليمان ٤/١٩٧.
55,16," <q>﴿مِن مَّارِجࣲ مِّن نَّارࣲ ۝١٥ فَبِأَیِّ ءَالَاۤءِ رَبِّكُمَا تُكَذِّبَانِ ۝١٦﴾</q> - تفسير ٧٤١٦٩- عن عبد الله بن عباس -من طريق عطية العَوفيّ- في قوله: <q>﴿وخَلَقَ الجانَّ مِن مارِجٍ مِن نارٍ﴾</q>، قال: مِن لهب النار{1}. (١٤/١١٠) ٧٤١٧٠- عن عبد الله بن عباس -من طريق مجاهد- <q>﴿مِن مارِجٍ مِن نارٍ﴾</q>، قال: مِن لَهَبِها؛ من وسَطها{2}. (١٤/١١٠) ٧٤١٧١- عن عبد الله بن عباس -من طريق علي- <q>﴿مِن مارِجٍ مِن نارٍ﴾</q>، قال: خالص النار{3}. (١٤/١١٠) ٧٤١٧٢- عن عبد الله بن عباس، قال: <q>﴿مِن مارِجٍ مِن نارٍ﴾</q> مِن شُعَب النار{4}. (١٤/١١٠) ٧٤١٧٣- عن عبد الله بن عباس -من طريق الضحاك- قال: خلقت الجن الذين ذُكروا في القرآن من مارج من نار، وهو لسان النار الذي يكون في طرفها إذا أُلهبَت{5}. (ز) ٧٤١٧٤- عن سعيد بن جُبَير، قال: <q>﴿مِن مارِجٍ مِن نارٍ﴾</q> الخضْرة التي تُقطع من النار؛ السّواد الذي يكون بين النار وبين الدُّخان{6}. (١٤/١١١) ٧٤١٧٥- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿مِن مارِجٍ مِن نارٍ﴾</q>، قال: اللّهب الأصفر والأخضر الذي يعلو النار إذا أُوقدت{7}. (١٤/١١٠) ٧٤١٧٦- عن الضَّحّاك بن مُزاحِم -من طريق سفيان- <q>﴿وخَلَقَ الجانَّ مِن مارِجٍ مِن نارٍ﴾</q>، قال: من أحسن النار{8}. (ز) ٧٤١٧٧- عن الضَّحّاك بن مُزاحِم -من طريق عبيد- <q>﴿مِن مارِجٍ مِن نارٍ﴾</q>: مِن لهب النار{9}. (ز) ٧٤١٧٨- عن عكرمة مولى ابن عباس -من طريق يعقوب بن قيس المكيّ- <q>﴿مِن مارِجٍ مِن نارٍ﴾</q>، قال: مِن أحسن النار{8}. (ز) ٧٤١٧٩- عن عكرمة مولى ابن عباس -من طريق سِماك- <q>﴿مِن مارِجٍ مِن نارٍ﴾</q>، قال: مِن حيث تلتهب النار{8}. (ز) ٧٤١٨٠- عن قتادة بن دعامة -من طريق سعيد- قال: مِن لهب النار{12}. (١٤/١١٠) ٧٤١٨١- عن الحسن البصري -من طريق معمر- <q>﴿مِن مارِجٍ مِن نارٍ﴾</q>، قال: مِن لهب النار{13}. (ز) ٧٤١٨٢- قال مقاتل بن سليمان: <q>﴿مِن مارِجٍ مِن نارٍ﴾</q> يعني: مِن لهب النار، صافٍ ليس له دُخان، وإنما سُمّي: الجان؛ لأنه مِن حيٍّ مِن الملائكة يقال لهم: الجنّ، فالجنّ الجماعة، والجانّ الواحد، وكان حُسن خَلقهما من النّعم، فمِن ثَمّ قال: <q>﴿فَبِأَيِّ آلاءِ﴾</q> يعني: نعماء <q>﴿رَبِّكُما تُكَذِّبانِ﴾</q>{14}. (ز) ٧٤١٨٣- عن عبد الرحمن بن زيد بن أسلم: <q>﴿مِن مارِجٍ مِن نارٍ﴾</q>، قال: المارج: اللهب{9}. (ز) <q>﴿مِن مَّارِجࣲ مِّن نَّارࣲ ۝١٥ فَبِأَیِّ ءَالَاۤءِ رَبِّكُمَا تُكَذِّبَانِ ۝١٦﴾</q> - آثار متعلقة بالآية ٧٤١٨٤- عن عائشة، قالت: قال رسول الله ﷺ: «خُلِقَت الملائكةُ مِن نور، وخُلق الجنّ من مارجٍ من نار، وخُلق آدم كما وُصف لكم»{16}. (١٤/١١١) ٧٤١٨٥- قال الحسن البصري: الإنس كلّهم مِن عند آخرهم ولد آدم، والجنّ كلّهم من عند آخرهم ولد إبليس{17}. (ز) ",footnotes:1:أخرجه ابن جرير ٢٢/١٩٥ بنحوه. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه ابن جرير ٢٢/١٩٥ بنحوه. وعزاه السيوطي إلى الفريابي، وابن المنذر، وابن أبي حاتم.أخرجه ابن جرير ٢٢/١٩٥. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.عزاه السيوطي إلى ابن أبي حاتم.أخرجه ابن جرير ٢٢/١٩٥.عزاه السيوطي إلى عبد بن حميد.تفسير مجاهد ص٦٣٧، وأخرجه عبد الله بن وهب في الجامع -تفسير القرآن ١/١٩ (٣٧) بنحوه، والفريابي -كما في تغليق التعليق ٤/٣٢٩-، وابن جرير ٢٢/١٩٦، وبنحوه من طريق منصور. وعزاه السيوطي إلى الفريابي، وعبد بن حميد.أخرجه ابن جرير ٢٢/١٩٦.أخرجه ابن جرير ٢٢/١٩٧.أخرجه ابن جرير ٢٢/١٩٦.أخرجه ابن جرير ٢٢/١٩٦.أخرجه ابن جرير ٢٢/١٩٧. وعزاه السيوطي إلى عبد بن حميد.أخرجه عبد الرزاق ٢/٢٦٢، وابن جرير ٢٢/١٩٧.تفسير مقاتل بن سليمان ٤/١٩٧.أخرجه ابن جرير ٢٢/١٩٧.أخرجه مسلم ٤/٢٢٩٤ (٢٩٩٦)، وعبد الرزاق ٢/٣٣٢ (١٦٧٨).ذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٤/٣٢٧-.
