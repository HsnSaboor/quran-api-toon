quran[22]{c,v,t}:
  54,50,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَمَاۤ أَمۡرُنَاۤ إِلَّا وَ ٰ⁠حِدَةࣱ كَلَمۡحِۭ بِٱلۡبَصَرِ ۝٥٠﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٣٩٨٧<span class="dash">-</span></span> عن ابن عباس، عن النبي ﷺ، قال: «<b>ما طَنَّ ذُباب إلا بقَدَر</b>». ثم قرأ: <span class="qpc-hafs">﴿وما أمْرُنا إلّا واحِدَةٌ كَلَمْحٍ بِالبَصَرِ﴾</span>{1}. (١٤/٩٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٩٨٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطاء- <span class="qpc-hafs">﴿وما أمْرُنا إلّا واحِدَةٌ كَلَمْحٍ بِالبَصَرِ﴾</span>: يريد: أنّ قضائي في خلْقي أسرع مِن لَمْح البصر{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٩٨٩<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق الكلبي-: وما أمرنا بمجيء الساعة في السُّرعة إلا كطرْف البصر{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٩٩٠<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span>: <span class="qpc-hafs">﴿إلّا واحِدَةٌ كَلَمْحٍ بِالبَصَرِ﴾</span>، يعني: إذا جاء عذاب كُفّار آخر هذه الأُمّة بالنفخة الأولى{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٩٩١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وما أمْرُنا﴾</span> في الساعة <span class="qpc-hafs">﴿إلّا واحِدَةٌ﴾</span> يعني: إلا مرّة واحدة لا مثنوية لها <span class="qpc-hafs">﴿كَلَمْحٍ بِالبَصَرِ﴾</span> يعني: كجنوح الطّرْف{5}. (ز)</p></p><p></div></p></div>",footnotes:1:عزاه السيوطي إلى ابن مردويه.|2:تفسير البغوي ٧/٤٢٦.|3:تفسير البغوي ٧/٤٢٦.|4:ذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٤/٣٢٤-.|5:تفسير مقاتل بن سليمان ٤/١٨٤.
  54,51,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَلَقَدۡ أَهۡلَكۡنَاۤ أَشۡیَاعَكُمۡ فَهَلۡ مِن مُّدَّكِرࣲ ۝٥١﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٣٩٩٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق مقسم- قال: <span class="qpc-hafs">﴿ولَقَدْ أهْلَكْنا أشْياعَكُمْ﴾</span> الذين كفروا وكذّبوا بالقَدَر قبلكم{1}. (١٤/٩٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٩٩٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ولَقَدْ أهْلَكْنا﴾</span> بالعذاب <span class="qpc-hafs">﴿أشْياعَكُمْ﴾</span> يعني: عذّبنا إخوانكم أهل مِلّتكم، يا أهل مكة، يعني: الأمم الخالية حين كذّبوا رسلهم، <span class="qpc-hafs">﴿فَهَلْ مِن مُدَّكِرٍ﴾</span> يقول: فهل من مُتَذَكِّر فيعلم أنّ ذلك حقٌّ فيعتبر ويخاف، فلا يكذّب محمدًا ﷺ{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٩٩٤<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- <span class="qpc-hafs">﴿ولَقَدْ أهْلَكْنا أشْياعَكُمْ﴾</span> قال: أشياعهم من أهل الكفر من الأمم السالفة، <span class="qpc-hafs">﴿فَهَلْ مِن مُدَّكِرٍ﴾</span> يقول: هل من أحد يتذكّر؟!{3}. (١٤/٩٢)</p></p><p></div></p></div>",footnotes:1:أخرجه اللالكائي في شرح أصول اعتقاد أهل السنة والجماعة ٣/٦٣١-٦٣٢ (١٠١٧). وعزاه السيوطي إلى ابن مردويه.|2:تفسير مقاتل بن سليمان ٤/١٨٤.|3:أخرجه ابن جرير ٢٢/١٦٤ بنحوه.
  54,52,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَكُلُّ شَیۡءࣲ فَعَلُوهُ فِی ٱلزُّبُرِ ۝٥٢﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٣٩٩٥<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق مقسم- قال: <span class="qpc-hafs">﴿وكُلُّ شَيْءٍ فَعَلُوهُ فِي الزُّبُرِ﴾</span> الأول، في أُمّ الكتاب، <span class="qpc-hafs">﴿وكُلُّ صَغِيرٍ وكَبِيرٍ مُسْتَطَرٌ﴾</span> يعني: مكتوب{1}. (١٤/٩٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٩٩٦<span class="dash">-</span></span> عن <span class="name-2">الضَّحّاك بن مُزاحِم</span> -من طريق عبيد- يقول في قوله: <span class="qpc-hafs">﴿فِي الزُّبُرِ﴾</span>، يقول: الكتب{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٩٩٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثم قال: <span class="qpc-hafs">﴿وكُلُّ شَيْءٍ فَعَلُوهُ فِي الزُّبُرِ﴾</span> يعني الأمم الخالية، قال: كلّ شيء عملوه مكتوب في اللوح المحفوظ{3}<span class=comment-ref>٦٣٥٠</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٣٥٠</span> <span class="comment-type-4">ذكر</span> <u>ابن القيم</u> (٣/٨٩) هذا القول، وساق <b>قولًا آخر</b> بأن المعنى: يُحصى عليهم في كتب أعمالهم. <span class="comment-type-4">ونقل</span> أنّ أبا إسحاق <span class="comment-type-4">جمع</span> بين القولين فقال: «مكتوب عليهم قبل أن يفعلوه، ومكتوب عليهم إذا فعلوه للجزاء»، <span class="comment-type-3">ورجَّحه</span> بقوله: «وهذا أصح» ولم يذكر مستندًا.</div></p><p><div></p><p><p><span class="item-no">٧٣٩٩٨<span class="dash">-</span></span> عن <span class="name-3">عبد الملك ابن جُرَيْج</span>: <span class="qpc-hafs">﴿وكُلُّ شَيْءٍ فَعَلُوهُ فِي الزُّبُرِ﴾</span> قال: في الكتاب{4}. (١٤/٩٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٩٩٩<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿فِي الزُّبُرِ﴾</span> قال: في الكتاب{2}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه اللالكائي في شرح أصول اعتقاد أهل السنة والجماعة ٣/٦٣١-٦٣٢ (١٠١٧). وعزاه السيوطي إلى ابن مردويه.|2:أخرجه ابن جرير ٢٢/١٦٥.|3:تفسير مقاتل بن سليمان ٤/١٨٥.|4:عزاه السيوطي إلى ابن المنذر.|5:أخرجه ابن جرير ٢٢/١٦٥.
  54,53,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَكُلُّ صَغِیرࣲ وَكَبِیرࣲ مُّسۡتَطَرٌ ۝٥٣﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٤٠٠٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> في قوله: <span class="qpc-hafs">﴿وكُلُّ صَغِيرٍ وكَبِيرٍ مُسْتَطَرٌ﴾</span> قال: مسطور في الكتاب{1}. (١٤/٩٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٠٠١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطية العَوفيّ- قوله: <span class="qpc-hafs">﴿وكُلُّ صَغِيرٍ وكَبِيرٍ مُسْتَطَرٌ﴾</span> يقول: مكتوب، فإذا أراد الله أن يُنزل كتابًا نَسخَتْه السّفرة{2}. (١٤/٩٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٠٠٢<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿وكُلُّ صَغِيرٍ وكَبِيرٍ مُسْتَطَرٌ﴾</span> قال: مكتوب{2}. (١٤/٩٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٠٠٣<span class="dash">-</span></span> عن <span class="name-2">الضَّحّاك بن مُزاحِم</span> -من طريق عبيد- يقول: <span class="qpc-hafs">﴿مُسْتَطَرٌ﴾</span> قال: مكتوب{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٠٠٤<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span> -من طريق عِمران بن حُدَير- <span class="qpc-hafs">﴿مُسْتَطَرٌ﴾</span>: مكتوب في كلّ سطر{4}. (١٤/٩٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٠٠٥<span class="dash">-</span></span> عن <span class="name-2">محمد بن كعب القُرَظيّ</span>، قال: طلبتُ هذا القَدَر فيما أنزل اللهُ على محمد ﷺ، فوجدتُه في اقتربت الساعة: <span class="qpc-hafs">﴿وكُلُّ شَيْءٍ فَعَلُوهُ فِي الزُّبُرِ* وكُلُّ صَغِيرٍ وكَبِيرٍ مُسْتَطَرٌ﴾</span>{6}. (١٤/٩٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٠٠٦<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- <span class="qpc-hafs">﴿وكُلُّ صَغِيرٍ وكَبِيرٍ مُسْتَطَرٌ﴾</span>، قال: محفوظ مكتوب{7}. (١٤/٩٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٠٠٧<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿وكُلُّ صَغِيرٍ وكَبِيرٍ مُسْتَطَرٌ﴾</span>، قال: مكتوب. وقرأ: <span class="qpc-hafs">﴿وما مِن دابَّةٍ فِي الأَرْضِ إلّا عَلى اللَّهِ رِزْقُها ويَعْلَمُ مُسْتَقَرَّها ومُسْتَوْدَعَها كُلٌّ فِي كِتابٍ مُبِينٍ﴾</span> [هود:٦]. وقرأ: <span class="qpc-hafs">﴿وما مِن دابَّةٍ فِي الأَرْضِ ولا طائِرٍ يَطِيرُ بِجَناحَيْهِ إلّا أُمَمٌ أمْثالُكُمْ ما فَرَّطْنا فِي الكِتابِ مِن شَيْءٍ﴾</span> [الأنعام:٣٨]. إنما هو«مفتعل» من: سَطرت إذا كتبت سطرًا{4}. (ز)</p></p><p></div></p></div>",footnotes:1:عزاه السيوطي إلى ابن المنذر.|2:أخرجه ابن جرير ٢٢/١٦٥.|3:أخرجه ابن جرير ٢٢/١٦٥.|4:أخرجه ابن جرير ٢٢/١٦٦.|5:أخرجه ابن جرير ٢٢/١٦٦.|6:عزاه السيوطي إلى ابن شاهين في السنة.|7:أخرجه عبد الرزاق ٢/٢٦١، وابن جرير ٢٢/١٦٦، وبنحوه من طريق سعيد. وعزاه السيوطي إلى عبد بن حميد.|8:أخرجه ابن جرير ٢٢/١٦٦.
  54,54,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿إِنَّ ٱلۡمُتَّقِینَ فِی جَنَّـٰتࣲ وَنَهَرࣲ ۝٥٤﴾</span> - قراءات</h3></p><p><div></p><p><p><span class="item-no">٧٤٠٠٨<span class="dash">-</span></span> عن أبي بكر بن عيّاش، أنّ <span class="name-2">عاصمًا</span> قرأ: <span class="qpc-hafs">﴿فِي جَنّاتٍ ونَهَرٍ﴾</span> مثلّثة منتصبة النون.= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٠٠٩<span class="dash">-</span></span> قال أبو بكر: وكان <span class="name-3">زهير الفرقبي</span>{1} يقرأ: (ونُهُرٍ) يريد: جماعة النهر{2}<span class=comment-ref>٦٣٥١</span>. (١٤/٩٨)</p></p><p></div></p><p><div><span class=comment-ref>٦٣٥١</span> اختُلف في قراءة قوله: <span class="qpc-hafs">﴿ونهر﴾</span>؛ <b>فقرأ قوم</b>: <span class="qpc-hafs">﴿ونَهَر﴾</span>، <b>وقرأ غيرهم</b>: (ونُهُرٍ).</p><p>و <span class="comment-type-4">ذكر</span> <u>ابنُ عطية</u> (٨/١٥٦-١٥٧) أن القراءة الأولى على أن النهر اسم الجنس، يراد به: الأنهار، أو على أنه بمعنى: سعة في الرزق والمنازل. وأن النهر على القراءة الثانية يحتمل احتمالين: <b>الأول</b>: أن يكون جمع نهار؛ إذ لا ليل في الجنة. <b>الثاني</b>: أن يكون جمع نهر. و<span class="comment-type-2">انتقد</span> الاحتمال الأول، فقال: «وهذا سائغ في اللفظ، قلِق في المعنى».</div></p><p><h3><span class="qpc-hafs">﴿إِنَّ ٱلۡمُتَّقِینَ فِی جَنَّـٰتࣲ وَنَهَرࣲ ۝٥٤﴾</span> - تفسير الآية</h3></p><p><div></p><p><p><span class="item-no">٧٤٠١٠<span class="dash">-</span></span> عن ابن عباس، قال: قال رسول الله ﷺ: «<b>النّهر</b>: <b>الضياء والسعة، ليس بنهرٍ جاري</b>»{3}. (١٤/٩٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٠١١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، أنّ نافع بن الأزرق قال له: أخبِرني عن قوله: <span class="qpc-hafs">﴿فِي جَنّاتٍ ونَهَرٍ﴾</span>. قال: النّهر: السَّعَة. قال: وهل تعرف العرب ذلك؟ قال: نعم، أما سمعت لَبيد بن ربيعة وهو يقول:</p><p>ملكتُ بها كفّي فأنهرتُ فتْقها يرى قائمٌ مِن دونها ما وراءها؟{4}. (١٤/٩٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٠١٢<span class="dash">-</span></span> قال <span class="name-2">الضَّحّاك بن مُزاحِم</span>: <span class="qpc-hafs">﴿إنَّ المُتَّقِينَ فِي جَنّاتٍ ونَهَرٍ﴾</span> يعني: في ضياء وسعة{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٠١٣<span class="dash">-</span></span> عن <span class="name-2">محمد بن كعب القُرَظيّ</span>، في قوله: <span class="qpc-hafs">﴿إنَّ المُتَّقِينَ فِي جَنّاتٍ ونَهَرٍ﴾</span>، قال: في نور وضياء{6}<span class=comment-ref>٦٣٥٢</span>. (١٤/٩٨)</p></p><p></div></p><p><div><span class=comment-ref>٦٣٥٢</span> <span class="comment-type-4">ذكر</span> <u>ابنُ جرير</u> (٢٢/١٦٧) أنه على هذا القول الذي قاله ابن عباس، والضَّحّاك، والقُرَظيّ، فإن قوله: <span class="qpc-hafs">﴿نهر﴾</span> وُجّه إلى معنى: النهار.</div></p><p><div></p><p><p><span class="item-no">٧٤٠١٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿إنَّ المُتَّقِينَ فِي جَنّاتٍ﴾</span> يعني: البساتين، <span class="qpc-hafs">﴿ونَهَرٍ﴾</span> يعني: الأنهار الجارية. ويُقال: السعة، مثل قوله في الكهف: <span class="qpc-hafs">﴿وفَجَّرْنا خِلالَهُما نَهَرًا﴾</span> [الكهف:٣٣]{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٠١٥<span class="dash">-</span></span> عن <span class="name-3">شريك</span>، في قوله: <span class="qpc-hafs">﴿فِي جَنّاتٍ ونَهَرٍ﴾</span>، قال: جنات وعيون{8}. (١٤/٩٧)</p></p><p></div></p></div>",footnotes:1:زهير الفرقبي: نحويّ قارئ من علماء الكوفة، قال أبو بكر بن عياش: قلت لزهير الفرقبىّ بمكة: أنّى لك النحو؟ قال: سمعناه من أصحاب أبى الأسود فأخذناه. قال: ومات زهير سنة خمس وخمسين ومائة. وقيل: سنة ست وخمسين ومائة. ينظر: إنباه الرواة ٢/ ١٨.|2:عزاه السيوطي إلى عبد بن حميد.</p><p>و<span class="qpc-hafs">﴿فِي جَنّاتٍ ونَهَرٍ﴾</span> قراءة العشرة، وأما (ونُهُرٍ) فهي قراءة شاذة. انظر: المحتسب ٢/٣٠٠.|3:عزاه السيوطي إلى ابن مردويه.</p><p>قال السيوطي: «سند واه».|4:أخرجه الطستي -كما في الإتقان ٢/٧٨-.|5:تفسير الثعلبي ٩/١٧٣، وتفسير البغوي ٤/٢٣٠.|6:عزاه السيوطي إلى الحكيم الترمذي في نوادر الأصول.|7:تفسير مقاتل بن سليمان ٤/١٨٥.|8:عزاه السيوطي إلى عبد بن حميد.
  54,55,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿فِی مَقۡعَدِ صِدۡقٍ عِندَ مَلِیكࣲ مُّقۡتَدِرِۭ ۝٥٥﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٤٠١٦<span class="dash">-</span></span> عن جابر، قال: بينما رسول الله ﷺ يومًا في مسجد المدينة، فذكر بعض أصحابه الجنة، فقال النبيُّ ﷺ: «<b>يا أبا دُجانة، أما علمتَ أنّ مَن أحبّنا وامتُحن بمحبّتنا أسكنه الله تعالى معنا</b>». ثم تلا هذه الآية: <b><span class="qpc-hafs">﴿فِي مَقْعَدِ صِدْقٍ عِنْدَ مَلِيكٍ مُقْتَدِرٍ﴾</span></b>{1}. (١٤/٩٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٠١٧<span class="dash">-</span></span> عن بُريْدة، عن رسول الله ﷺ، في قوله: <span class="qpc-hafs">﴿فِي جَنّاتٍ ونَهَرٍ فِي مَقْعَدِ صِدْقٍ عِنْدَ مَلِيكٍ مُقْتَدِرٍ﴾</span>، قال: «<b>إنّ أهل الجنة يدخلون على الجبّار كلّ يوم مرتين، فيقرأ عليهم القرآن، وقد جلس كلُّ امرئ منهم مجلسه الذي هو مجلسه، على منابر الدُّرِّ والياقوت والزُّمُرُّد والذّهب والفِضّة، بالأعمال، فلا تقرُّ أعينهم قطّ كما تقرُّ بذلك، ولم يسمعوا شيئًا أعظم منه، ولا أحسن منه، ثم ينصرفون إلى رحالهم قريرة أعينهم ناعمين، إلى مثلها من الغد</b>»{2}. (١٤/٩٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٠١٨<span class="dash">-</span></span> عن <span class="name-2">عبد الله بن بُريدة</span> -من طريق صالح بن حيّان- أنه قال في قوله ﷾: <span class="qpc-hafs">﴿فِي مَقْعَدِ صِدْقٍ عِنْدَ مَلِيكٍ مُقْتَدِرٍ﴾</span>: إنّ أهل الجنة يدخلون كلّ يوم على الجبّار ﷿، فيقرؤون عليه القرآن، وقد جلس كلُّ امرئ منهم مجلسه الذي هو يجلسه على منابر الدُّرِّ والياقوت والزُّمُرّد والذّهب والفِضّة بقدر أعمالهم، فلم تقرَّ أعينهم بشيء قطّ كما تقرُّ بذلك، ولم يسمعوا شيئًا أعظم ولا أحسن منه، ثم ينصرفون الى رحالهم ناعمين، قريرة أعينهم إلى مثلها من الغد{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٠١٩<span class="dash">-</span></span> قال [<span class="name-3">جعفر</span>] <span class="name-3">الصادق</span>: مدح الله المكان بالصّدق، فلا يَقعد فيه إلا أهلُ الصِّدق{4}<span class=comment-ref>٦٣٥٣</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٣٥٣</span> <span class="comment-type-4">ذكر</span> <u>ابنُ عطية</u> (٨/١٥٧) أنّ قوله تعالى: <span class="qpc-hafs">﴿مَقْعَدِ صِدْقٍ﴾</span> يحتمل احتمالين: <b>الأول</b>: أن يريد به: الصّدق الذي هو ضد الكذب، أي: في المقعد الذي صدقوا في الخبر به. <b>الثاني</b>: أن يكون من قولك: «عُود صدْق» أي: جيد، «ورجل صدق» أي: خيّر، وذو خِلال حسان.</div></p><p><div></p><p><p><span class="item-no">٧٤٠٢٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فِي مَقْعَدِ صِدْقٍ عِنْدَ مَلِيكٍ مُقْتَدِرٍ﴾</span> على ما يشاء، وذلك أنّ أهل الجنة يدخلون على ربهم تعالى على مقدار كلّ يوم جمعة، فيجلسون إليه على قَدْر أعمالهم في الدنيا، وبقَدْر ثوابهم في الآخرة، فيُعطَون في ذلك المجلس ما يحبّون مِن شيء، ثم يعطيهم الرّبُّ تعالى ما لم يسألوه مِن الخير من جنة عَدن ما لم تره عين، ولم تسمعه أذن، ولم يخطُر على قلب بشر{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٠٢١<span class="dash">-</span></span> عن <span class="name-3">ثَور بن يزيد</span>، قال: بلغنا: أنّ الملائكة يأتون المؤمنين يوم القيامة، فيقولون: يا أولياء الله، انطلِقوا. فيقولون: إلى أين؟ فيقولون: إلى الجنة. فيقولون: إنّكم لتذهبون بنا إلى غير بُغيتنا. فيقال لهم: وما بُغيتكم؟ فيقولون: المقعد مع الحبيب. وهو قوله: <span class="qpc-hafs">﴿إنَّ المُتَّقِينَ فِي جَنّاتٍ ونَهَرٍ فِي مَقْعَدِ صِدْقٍ عِنْدَ مَلِيكٍ مُقْتَدِرٍ﴾</span>{6}. (١٤/٩٨)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿فِی مَقۡعَدِ صِدۡقٍ عِندَ مَلِیكࣲ مُّقۡتَدِرِۭ ۝٥٥﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٧٤٠٢٢<span class="dash">-</span></span> عن سعيد بن المسيّب، قال: دخلتُ المسجدَ وأنا أرى أنّي قد أصبحتُ، فإذا عَلَيَّ ليلٌ طويل، وإذا ليس فيه أحد غيري، فقمتُ، فسمعتُ حركةً خلفي، ففزعتُ، فقال: أيها الممتلئ قلبه فَرقًا، لا تَفْرق -أو لا تفزع- وقل: اللهم، إنك مليك مقتدر، ما تشاء من أمرٍ يكون. ثم سَلْ ما بدا لك. قال سعيد: فما سألتُ الله شيئًا إلا استجاب لي{7}. (١٤/٩٩)</p></p><p></div></p></div>",footnotes:1:أخرجه أبو نعيم في معرفة الصحابة ٥/٢٨٨٣ (٦٧٧٤). وأورده الديلمي في الفردوس ٥/٣٧٧-٣٧٨ (٨٤٨٤).|2:أخرجه الحكيم الترمذي في نوادر الأصول ص٦١٧ (٧٠٢)، من طريق صالح بن حيان، عن ابن بريدة، عن أبيه به.</p><p>وسنده ضعيف؛ فيه صالح بن حيان، قال عنه ابن حجر في تقريب التهذيب (٢٨٥١): «ضعيف».|3:أخرجه الثعلبي ٩/١٧٤.|4:تفسير الثعلبي ٩/١٧٤، وتفسير البغوي ٧/٤٣٧.|5:تفسير مقاتل بن سليمان ٤/١٨٥.|6:أخرجه الحكيم الترمذي ٢/٩٠، ولم ينسبه إلى قائله.|7:أخرجه ابن أبي شيبة ١٠/٢٥٤.
  55,1,"<div class=ar lang=ar><p><h3>مقدمة السورة</h3></p><p><div></p><p><p><span class="item-no">٧٤٠٢٣<span class="dash">-</span></span> عن أسماء بنت أبي بكر، قالت: سمعتُ رسول الله ﷺ يقرأ وهو يُصلّي نحو الرُّكن قبل أن يَصْدَع بما يؤمر والمشركون يسمعون: <span class="qpc-hafs">﴿فَبِأَيِّ آلاءِ رَبِّكُما تُكَذِّبانِ﴾</span>{1}. (١٤/١٠٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٠٢٤<span class="dash">-</span></span> عن عائشة، قالت: نَزَلَتْ سورة الرحمن بمكة{2}. (١٤/١٠٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٠٢٥<span class="dash">-</span></span> عن عبد الله بن عباس -من طريق أبي عمرو بن العلاء، عن مجاهد- قال: نَزَلَتْ سورةُ الرحمن بمكة{3}. (١٤/١٠٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٠٢٦<span class="dash">-</span></span> عن عبد الله بن عباس -من طريق خُصَيف، عن مجاهد- قال: نَزَلَتْ سورة الرحمن بالمدينة{4}. (١٤/١٠٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٠٢٧<span class="dash">-</span></span> عبد الله بن عباس -من طريق عطاء الخُراسانيّ-: مدنيّة، ونَزَلَتْ بعد سورة الرّعد{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٠٢٨<span class="dash">-</span></span> عن عبد الله بن الزبير، قال: أُنزِل بمكة سورة الرحمن{2}. (١٤/١٠٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٠٢٩<span class="dash">-</span></span> عن عكرمة مولى ابن عباس= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٠٣٠<span class="dash">-</span></span> والحسن البصري -من طريق يزيد النحوي-: مدنيّة{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٠٣١<span class="dash">-</span></span> عن قتادة بن دعامة -من طريق سعيد-: مدنيّة{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٠٣٢<span class="dash">-</span></span> عن قتادة بن دعامة -من طريق همام-: مكّيّة{9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٠٣٣<span class="dash">-</span></span> عن محمد بن مسلم الزُّهريّ: مدنيّة، ونَزَلَتْ بعد سورة الرّعد{10}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٠٣٤<span class="dash">-</span></span> عن علي بن أبي طلحة: مكّيّة{11}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٠٣٥<span class="dash">-</span></span> قال مقاتل بن سليمان: سورة الرحمن مكّيّة، عددها ثمان وسبعون آية كوفي{12}<span class=comment-ref>٦٣٥٤</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٣٥٤</span> <span class="comment-type-3">رجّح</span> <u>ابنُ عطية</u> (٣/١٥٨) <span class="mustanad">مستندًا إلى دلالة التاريخ</span> أنّ السورة مكية، ثم قال: «وإنما نَزَلَتْ حين قالت قريش بمكة: وما الرحمن؟ أنسجد لما تأمرنا؟ وفي السيرة أنّ ابن مسعود جهر بقراءتها في المسجد، حتى قامت إليه أندية قريش، فضربوه، وذلك قبل الهجرة».</div></p><p><div></p><p><p><span class="item-no">٧٤٠٣٦<span class="dash">-</span></span> عن علي بن أبي طالب، سمعتُ النبي ﷺ يقول: «<b>لكلّ شيء عَروس، وعَروس القرآن الرحمن</b>»{13}. (١٤/١٠١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٠٣٧<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن مسعود</span> -من طريق عَلْقمة- أنّ رجلًا قال له: إنّي أقرأ المُفصّل في ركعة. فقال: أهذًّا كهَذِّ الشِّعر؟! لكنّ النبيَّ ﷺ كان يقرأ النظائر سورتين في ركعة: الرحمن والنّجم في ركعة، و<span class="qpc-hafs">﴿اقتربت﴾</span> والحاقة في ركعة، والطور والذّاريات في ركعة، و<span class="qpc-hafs">﴿إذا وقَعتْ﴾</span> و<span class="qpc-hafs">﴿ن﴾</span> في ركعة، و<span class="qpc-hafs">﴿عمّ﴾</span> والمُرسلات في ركعة، والدُّخان و<span class="qpc-hafs">﴿إذا الشمس كُوِّرت﴾</span> في ركعة، و<span class="qpc-hafs">﴿سأل سائل﴾</span> والنّازعات في ركعة، و<span class="qpc-hafs">﴿ويلٌ للمطففين﴾</span> و<span class="qpc-hafs">﴿عبس﴾</span> في ركعة{14}. (١٤/١٠٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٠٣٨<span class="dash">-</span></span> عن زِرِّ بن حُبَيْش، قال: كان أول مُفصّل <span class="name-1">ابن مسعود</span>: الرحمن{15}. (١٤/١٠٢)</p></p><p></div></p></div>",footnotes:1:أخرجه أحمد ٤٤/٥١٧ (٢٦٩٥٥)، والطبراني في الكبير ٢٤/٨٦ (٢٣١)، من طريق ابن لَهيعة، عن أبي الأسود، عن عروة، عن أسماء بنت أبي بكر به.</p><p>قال الهيثمي في المجمع ٧/١١٧ (١١٣٨٦): «فيه ابن لَهيعة، وفيه ضعف، وحديثه حسن، وبقية رجاله رجال الصحيح». وقال السيوطي: «سند حسن». وقال في الإتقان ١/٥٠: «سند جيد». وقال ابن عاشور في التحرير والتنوير ٢٧/٢٢٨: «سند جيد».|2:عزاه السيوطي إلى ابن مردويه.|3:أخرجه النحاس (٦٧٩).|4:أخرجه البيهقي في الدلائل ٧/١٤٢-١٤٤. وعزاه السيوطي إلى ابن مردويه.|5:أخرجه ابن الضريس في فضائل القرآن ١/٣٣-٣٥.|6:عزاه السيوطي إلى ابن مردويه.|7:أخرجه البيهقي في دلائل النبوة ٧/١٤٢-١٤٣.|8:أخرجه الحارث المحاسبي في فهم القرآن ص٣٩٥-٣٩٦.|9:أخرجه أبو بكر ابن الأنباري -كما في الإتقان في علوم القرآن ١/٥٧-.|10:تنزيل القرآن ص٣٧-٤٢.|11:أخرجه أبو عبيد في فضائله (ت: الخياطي) ٢/٢٠٠.|12:تفسير مقاتل بن سليمان ٤/١٩٣.|13:أخرجه البيهقي في شعب الإيمان ٤/١١٦-١١٧ (٢٢٦٥)، والثعلبي ٩/١٧٦، من طريق هشام البربري، عن علي بن حمزة الكسائي، عن موسى بن جعفر، عن أبيه جعفر، عن أبيه، عن علي بن الحسين، عن أبيه، عن علي به.</p><p>قال المناوي في التيسير بشرح الجامع الصغير ٢/٢٩٧: «إسناده حسن». وقال في فيض القدير ٥/٢٨٦ (٧٣١٩): «فيه علي بن الحسن دبيس، عدّه الذهبي في الضعفاء والمتروكين. وقال الدارقطني: ليس بثقة». وقال الألباني في الضعيفة ٣/٥٢٦ (١٣٥٠): «منكر».|14:أخرجه أبو داود (١٣٩٦)، والبيهقي في سننه ٢/٦٠.</p><p>وصححه الألباني في صحيح سنن أبي داود (١٢٤٤).|15:أخرجه أحمد ٧/٢٥.
  55,2,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿ٱلرَّحۡمَـٰنُ ۝١ عَلَّمَ ٱلۡقُرۡءَانَ ۝٢﴾</span> - تفسير الآية، ونزولها</h3></p><p><div></p><p><p><span class="item-no">٧٤٠٣٩<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق أبي العوام- <span class="qpc-hafs">﴿الرَّحْمَنُ عَلَّمَ القُرْآنَ﴾</span>، قال: نعمة -والله- عظيمة{1}. (١٤/١٠٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٠٤٠<span class="dash">-</span></span> قال <span class="name-3">محمد بن السّائِب الكلبي</span>: <span class="qpc-hafs">﴿عَلَّمَ القُرْآنَ﴾</span> علّم القرآنَ محمدًا{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٠٤١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿الرَّحْمنُ﴾</span> وذلك أنه لما نزل: <span class="qpc-hafs">﴿اسْجُدُوا لِلرَّحْمَنِ﴾</span> قال كفار مكة: <span class="qpc-hafs">﴿وما الرَّحْمنُ أنَسْجُدُ لِما تَأْمُرُنا﴾</span> [الفرقان:٦٠] فأنكروا الرحمن، وقالوا: لا نعرف الرحمن. فأخبر الله تعالى عن نفسه، وذكر صُنعه ليُعرَف، فيُوحّد، فقال: <span class="qpc-hafs">﴿الرَّحْمَنُ﴾</span> الذي أنكروه هو الذي <span class="qpc-hafs">﴿عَلَّمَ القُرْآنَ﴾</span>{3}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ٢٢/١٦٨. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.|2:تفسير البغوي ٧/٤٣٨.|3:تفسير مقاتل بن سليمان ٤/١٩٥.
  55,3,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿خَلَقَ ٱلۡإِنسَـٰنَ ۝٣﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٤٠٤٢<span class="dash">-</span></span> قال <span class="name-1">عبد الله بن عباس</span>: <span class="qpc-hafs">﴿خَلَقَ الإنْسانَ﴾</span> يعني: آدم ﵇{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٠٤٣<span class="dash">-</span></span> قال <span class="name-2">أبو العالية الرِّياحيّ</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٠٤٤<span class="dash">-</span></span> و<span class="name-2">الحسن البصري</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٠٤٥<span class="dash">-</span></span> و<span class="name-3">عبد الرحمن بن زيد بن أسلم</span>: <span class="qpc-hafs">﴿خَلَقَ الإنْسانَ﴾</span> اسم جنس، وأراد به: جميع الناس{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٠٤٦<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿خَلَقَ الإنْسانَ﴾</span>، قال: الإنسان: آدم{3}. (١٤/١٠٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٠٤٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿خَلَقَ الإنْسانَ﴾</span>، يعني: آدم ﵇{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٠٤٨<span class="dash">-</span></span> عن <span class="name-3">عبد الملك ابن جُرَيْج</span>، <span class="qpc-hafs">﴿خَلَقَ الإنْسانَ﴾</span>، قال: آدم{5}<span class=comment-ref>٦٣٥٥</span>. (١٤/١٠٣)</p></p><p></div></p><p><div><span class=comment-ref>٦٣٥٥</span> في المراد بالإنسان ثلاثة أقوال: <b>الأول</b>: أنّ المراد به: جميع الناس. <b>الثاني</b>: أنّ المراد به: آدم. <b>الثالث</b>: أنّ المراد به: محمد ﷺ.</p><p>ولم يذكر <u>ابنُ جرير</u> (٢٢/١٦٩) سوى القولين الأولين، ثم <span class="comment-type-4">بيّن</span> احتمال الكلام لهما جميعًا، فقال: «والقولان كلاهما غير بعيدين من الصواب؛ <span class="mustanad">لاحتمال ظاهر الكلام إياهما</span>».</p><p>و<span class="comment-type-2">انتقد</span> <u>ابنُ عطية</u> (٨/١٥٩) -<span class="mustanad">مستندًا لعدم الدليل</span>- القول الثاني والثالث بقوله: «وهذا التخصيص لا دليل عليه».</div></p></div>",footnotes:1:تفسير الثعلبي ٩/١٧٧، وتفسير البغوي ٧/٤٣٨.|2:تفسير البغوي ٧/٤٣٨.|3:أخرجه ابن جرير ٢٢/١٦٩. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.|4:تفسير مقاتل بن سليمان ٤/١٩٥.|5:عزاه السيوطي إلى ابن المنذر.
  55,4,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿عَلَّمَهُ ٱلۡبَیَانَ ۝٤﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٤٠٤٩<span class="dash">-</span></span> قال <span class="name-2">أبو العالية الرِّياحيّ</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٠٥٠<span class="dash">-</span></span> و<span class="name-2">الحسن البصري</span>: <span class="qpc-hafs">﴿عَلَّمَهُ البَيانَ﴾</span> النُّطق والكتابة والفهْم والإفهام، حتى عرف ما يقول وما يُقال له{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٠٥١<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿عَلَّمَهُ البَيانَ﴾</span>، قال: علّمه الله بيان الدنيا والآخرة، بيّن حلاله وحرامه ليَحْتَجّ بذلك عليه، ولله الحُجّة على عباده{2}. (١٤/١٠٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٠٥٢<span class="dash">-</span></span> قال <span class="name-2">محمد بن كعب القُرَظيّ</span>: <span class="qpc-hafs">﴿عَلَّمَهُ البَيانَ﴾</span> ما يقول وما يُقال له{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٠٥٣<span class="dash">-</span></span> قال <span class="name-2">إسماعيل السُّدِّيّ</span>: <span class="qpc-hafs">﴿عَلَّمَهُ البَيانَ﴾</span> علّم كلَّ قوم لسانهم الذي يتكلّمون به{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٠٥٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿عَلَّمَهُ البَيانَ﴾</span> يعني: بيان كلّ شيء{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٠٥٥<span class="dash">-</span></span> عن <span class="name-3">عبد الملك ابن جُرَيْج</span>، <span class="qpc-hafs">﴿عَلَّمَهُ البَيانَ﴾</span>، قال: بيّن له سبيل الهُدى، وسبيل الضَّلالة{6}. (١٤/١٠٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٠٥٦<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- قال: <span class="qpc-hafs">﴿عَلَّمَهُ البَيانَ﴾</span> البيان: الكلام{7}<span class=comment-ref>٦٣٥٦</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٣٥٦</span> في قوله: <span class="qpc-hafs">﴿علمه البيان﴾</span> قولان: <b>الأول</b>: أنه بيان الحرام والحلال. <b>الثاني</b>: أنه الكلام والمنطق.</p><p>وقد ذكر <u>ابنُ جرير</u> (٢٢/١٧٠) القولين، ثم <span class="comment-type-3">رجّح</span> <span class="mustanad">العموم</span>، فقال: «والصواب من القول في ذلك أن يقال: معنى ذلك: أنّ الله علّم الإنسان ما به الحاجة إليه مِن أمر دينه ودنياه مِن الحلال والحرام، والمعايش والمنطق، وغير ذلك مما به الحاجة إليه؛ لأن الله -جلّ ثناؤه- لم يخصص بخبره ذلك أنه علّمه مِن البيان بعضًا دون بعض، بل عمّ فقال: <span class="qpc-hafs">﴿علمه البيان﴾</span>، فهو كما عمّ -جلّ ثناؤه-».</p><p>وذكر <u>ابنُ عطية</u> (٨/١٥٩) القول الأول، و<span class="comment-type-1">وجّهه</span> عليه بقوله: «وهذا جزء من البيان العام». و<span class="comment-type-4">علّق</span> على القول الثاني بقوله: «وذلك هو الذي فُضِّل به الإنسانُ من بين سائر الحيوان». ثم ذكر أنّ: «كلّ المعلومات داخلة في البيان الذي علّمه الإنسان، فكأنه قال من ذلك البيان، وفيه معتبر».</p><p>و<span class="comment-type-3">رجّح</span> <u>ابنُ كثير</u> (١٣/٣١٣-٣١٤) <span class="mustanad">مستندًا إلى السياق</span> القول الثاني، وعلّل ذلك بقوله: «لأنّ السياق في تعليمه تعالى القرآن، وهو أداء تلاوته، وإنما يكون ذلك بتيسير النطق على الخلْق، وتسهيل خروج الحروف من مواضعها من الحلْق واللسان والشّفتين، على اختلاف مخارجها وأنواعها».</div></p></div>",footnotes:1:تفسير البغوي ٧/٤٣٨. وفي تفسير الثعلبي ٩/١٧٧: أبو العالية، ومرّة الهمذاني، وابن زيد: يعني الكلام الحسن: النطق والتمييز.|2:أخرجه ابن جرير ٢٢/١٦٩، ١٧١، وبنحوه من طريق أبي العوام. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.|3:تفسير الثعلبي ٩/١٧٧.|4:تفسير الثعلبي ٩/١٧٧، وتفسير البغوي ٧/٤٣٨.|5:تفسير مقاتل بن سليمان ٤/١٩٥.|6:عزاه السيوطي إلى ابن المنذر.|7:أخرجه ابن جرير ٢٢/١٧٠.
  55,5,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿ٱلشَّمۡسُ وَٱلۡقَمَرُ بِحُسۡبَانࣲ ۝٥﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٤٠٥٧<span class="dash">-</span></span> <span class="name-1">عن عبد الله بن عباس</span> -من طريق عكرمة- <span class="qpc-hafs">﴿الشَّمْسُ والقَمَرُ بِحُسْبانٍ﴾</span>، قال: بحساب ومنازل يُرسلان{1}. (١٤/١٠٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٠٥٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق العَوفيّ- <span class="qpc-hafs">﴿الشَّمْسُ والقَمَرُ بِحُسْبانٍ﴾</span>، قال: يَجْريان بعددٍ وحساب{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٠٥٩<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق أبي يحيى- قال: <span class="qpc-hafs">﴿الشَّمْسُ والقَمَرُ بِحُسْبانٍ﴾</span> يَدُوران في مثل قُطب الرَّحى{3}<span class=comment-ref>٦٣٥٧</span>. (١٤/١٠٤)</p></p><p></div></p><p><div><span class=comment-ref>٦٣٥٧</span> نقل <u>ابنُ عطية</u> (٨/١٥٩) عن مجاهد قوله: «الحُسبان: الفلك المستدير». و<span class="comment-type-4">علَّق</span> عليه بقوله: «شبّهه بحُسبان الرّحا، وهو العُود المستدير الذي باستدارته تدور المطحنة».</div></p><p><div></p><p><p><span class="item-no">٧٤٠٦٠<span class="dash">-</span></span> عن <span class="name-2">الضَّحّاك بن مُزاحِم</span> -من طريق عبيد- قال: <span class="qpc-hafs">﴿الشَّمْسُ والقَمَرُ بِحُسْبانٍ﴾</span> بقَدَرٍ يَجْريان{4}. (١٤/١٠٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٠٦١<span class="dash">-</span></span> عن <span class="name-2">أبي مالك [الغفاري]</span> -من طريق إسماعيل بن أبي خالد- قال: <span class="qpc-hafs">﴿الشَّمْسُ والقَمَرُ بِحُسْبانٍ﴾</span> بحساب ومنازل لا يَعْدُوانها{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٠٦٢<span class="dash">-</span></span> عن <span class="name-2">أبي مالك [الغفاري]</span>، قال: <span class="qpc-hafs">﴿الشَّمْسُ والقَمَرُ بِحُسْبانٍ﴾</span> عليهما حساب وأجَل كأجَل الناس، فإذا جاء أجَلهما هلَكا{6}. (١٤/١٠٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٠٦٣<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿الشَّمْسُ والقَمَرُ بِحُسْبانٍ﴾</span>: إلى أجَل بحساب{7}. (١٤/١٠٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٠٦٤<span class="dash">-</span></span> قال <span class="name-2">إسماعيل السُّدِّيّ</span>: <span class="qpc-hafs">﴿الشَّمْسُ والقَمَرُ بِحُسْبانٍ﴾</span> بأجَل كآجال الناس، فإذا جاء أجَلهما هلكا{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٠٦٥<span class="dash">-</span></span> عن <span class="name-2">الربيع بن أنس</span>، قال: <span class="qpc-hafs">﴿الشَّمْسُ والقَمَرُ بِحُسْبانٍ﴾</span> يَجْريان بحساب{9}. (١٤/١٠٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٠٦٦<span class="dash">-</span></span> قال <span class="name-3">محمد بن السّائِب الكلبي</span>: <span class="qpc-hafs">﴿الشَّمْسُ والقَمَرُ بِحُسْبانٍ﴾</span> بحساب ومنازل معدودة، كلّ يوم منزل{10}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٠٦٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿الشَّمْسُ والقَمَرُ بِحُسْبانٍ﴾</span> مطالعهما ومغاربهما ثمانين ومائة مطلع، وثمانين ومائة مغرب؛ لتعلموا بها عدد السّنين والحساب{11}<span class=comment-ref>٦٣٥٨</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٣٥٨</span> في قوله: <span class="qpc-hafs">﴿الشمس والقمر بحسبان﴾</span> أقوال: <b>الأول</b>: أنهما بحُسْبان، ومنازل لهما يجريان ولا يعدوانها. <b>الثاني</b>: أنهما يجريان بقدر. <b>الثالث</b>: أنهما يدوران في مثل قُطب الرّحى.</p><p>وقد <span class="comment-type-3">رجّح</span> <u>ابنُ جرير</u> (٢٢/١٧٣) -<span class="mustanad">مستندًا إلى اللغة</span>- القول الأول، فقال: «وأولى الأقوال في ذلك بالصواب قول مَن قال: معناه: الشمس والقمر يجريان بحساب ومنازل؛ لأنّ الحُسْبان مصدر من قول القائل: حسبته حسابًا وحسبانًا، مثل قولهم: كفرته كفرانًا، وغفرته غفرانًا، وقد قيل: إنه جمع حساب، كما الشهبان: جمع شهاب».</p><p>و<span class="comment-type-4">علّق</span> <u>ابنُ تيمية</u> (٦/١٦٥) على القول الثالث، فقال: «فهذا مما لا خلاف فيه، بل قد <span class="mustanad">دلّ الكتاب والسنة وأجمع علماء الأُمّة</span> على مثل ما عليه أهل المعرفة مِن أهل الحساب من أنّ الأفلاك مستديرة لا مُسطحة».</div></p><p><div></p><p><p><span class="item-no">٧٤٠٦٨<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿الشَّمْسُ والقَمَرُ بِحُسْبانٍ﴾</span>، قال: يُحْسَب بهما الدّهر والزمان؛ لولا الليل والنهار والشمس والقمر، لم يدرِ أحدٌ كيف يَحسُب شيئًا؛ لو كان الدّهر ليلًا كلّه كيف يُحسَب، أو نهارًا كلّه كيف يُحسَب{2}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه إبراهيم الحربي في غريبه كما في تغليق التعليق ٣/٤٩٢، وابن جرير ٢٢/١٧٠، والحاكم ٢/٤٧٤. وعزاه السيوطي إلى الفريابي، وعبد بن حميد، وابن المنذر، وابن أبي حاتم.|2:أخرجه ابن جرير ٢٢/١٧١.|3:أخرجه ابن جرير ٢٢/١٧٢، وهو في تفسير مجاهد ص٦٣٦ من طريق ابن أبي نجيح بلفظ: كحسبان الرحا. وكذا أخرجه الفريابي -كما في تغليق التعليق ٣/٤٩٢- من طريق ابن أبي نجيح، و ابن جرير ٢٢/١٧٢ أيضًا. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.|4:أخرجه ابن جرير ٢٢/١٧٢. وعزاه السيوطي إلى عبد بن حميد.|5:أخرجه عبد بن حميد -كما في التغليق ٣/٤٩٢-، وابن جرير ٢٢/١٧١ دون آخره.|6:عزاه السيوطي إلى عبد بن حميد، وابن المنذر.|7:أخرجه عبد الرزاق ٣/٢٦٥ من طريق معمر بنحوه، وابن جرير ٢٢/١٧١-١٧٢، وبنحوه من طريق معمر وأبي العوام. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.|8:تفسير الثعلبي ٩/١٧٧.|9:عزاه السيوطي إلى عبد بن حميد.|10:ذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٤/٣٢٥-.|11:تفسير مقاتل بن سليمان ٤/١٩٥.|12:أخرجه ابن جرير ٢٢/١٧١.
  55,6,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَٱلنَّجۡمُ وَٱلشَّجَرُ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٤٠٦٩<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- <span class="qpc-hafs">﴿والنَّجْمُ والشَّجَرُ يَسْجُدانِ﴾</span>، قال: النّجم: ما انبسَط على الأرض. والشّجر: ما كان على ساق{1}. (١٤/١٠٤). (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٠٧٠<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جُبَير</span> -من طريق جعفر-، مثله{2}. (١٤/١٠٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٠٧١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> أنّ نافع بن الأزرق قال له: أخبِرني عن قوله: <span class="qpc-hafs">﴿والنَّجْمُ والشَّجَرُ يَسْجُدانِ﴾</span>، ما النّجم؟ قال: ما أنَجمَت الأرض مما لا يقوم على ساق، فإذا قام على ساق فهي شجرة، قال صفوان بن أسد التميميّ:</p><p>لقد أنجم القاع الكبير عِضاهُه{3} وتمّ به حيّا تميم ووائل</p><p>وقال زُهير بن أبي سُلمى:</p><p>مُكلّل بأصول النجم تنسِجُه ريح الجنوب لضاحي مائِهِ حُبُكُ{4}{5}. (١٤/١٠٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٠٧٢<span class="dash">-</span></span> عن <span class="name-2">أبي رَزِين [مسعود بن مالك الأسدي]</span> -من طريق زِبْرقان- قال: النّجم: ما ذهب فرشًا على الأرض؛ ليس له ساق. والشّجر: ما كان له ساق{6}. (١٤/١٠٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٠٧٣<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- <span class="qpc-hafs">﴿والنَّجْمُ والشَّجَرُ يَسْجُدانِ﴾</span>، قال: النّجم نَجم السماء، والشجر الشجرة{7}. (١٤/١٠٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٠٧٤<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿والنَّجْمُ﴾</span> يعني: نجم السماء، <span class="qpc-hafs">﴿والشَّجَرُ﴾</span> قال: الشجر: شجر الأرض{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٠٧٥<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق شريك- <span class="qpc-hafs">﴿والنَّجْمُ والشَّجَرُ يَسْجُدانِ﴾</span>، قال: النّجم: نبات الأرض{9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٠٧٦<span class="dash">-</span></span> عن <span class="name-3">محمد بن السّائِب الكلبي</span> -من طريق معمر- قال: النّجم: كلّ شيء ليس له ساق من الشّجر. قال: والشّجر: كلّ شيء له ساق من الشّجر{10}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٠٧٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿والنَّجْمُ﴾</span> يعني: كلّ نَبتٍ ليس له ساق، <span class="qpc-hafs">﴿والشَّجَرُ﴾</span> كلّ نَبتٍ له ساق{11}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٠٧٨<span class="dash">-</span></span> عن <span class="name-3">سفيان الثوري</span> -من طريق مهران- <span class="qpc-hafs">﴿والنَّجْمُ﴾</span> قال: النّجم الذي ليس له ساق، <span class="qpc-hafs">﴿والشَّجَرُ يَسْجُدانِ﴾</span> قال: الشّجر: الذي له سُوق{12}<span class=comment-ref>٦٣٥٩</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٣٥٩</span> <span class="mustanad">أجمع</span> السلف على أنّ الشجر: ما قام على ساق. واختلفوا في معنى النّجم على قولين: <b>الأول</b>: النبات الذي لا ساق له مثل البقْل ونحوه. <b>الثاني</b>: نجم السماء.</p><p>و<span class="comment-type-1">وجّه</span> <u>ابنُ عطية</u> (٥/٢٢٤ ط: دار الكتب العلمية) القول الأول، فقال: «وسُمّي نجمًا لأنه نَجَم، أي: ظهر وطلع، وهو مناسب للشّجر نسبة بيّنة». و<span class="comment-type-4">علّق</span> على القول الثاني، فقال: «وقال مجاهد، وقتادة، والحسن: النّجم: اسم الجنس من نجوم السماء، والنسبة التي لها من السماء هي التي للشجر من الأرض؛ لأنهما في ظاهرهما».</p><p>وقد <span class="comment-type-3">رجّح</span> <u>ابنُ جرير</u> (٢٢/١٧٥) <span class="mustanad">-مستندًا إلى دلالة السياق</span>- القول الأول، فقال: «وأولى القولين في ذلك بالصواب قول مَن قال: عنى بالنجم: ما نجم من الأرض مِن نَبتٍ. لعطف الشّجر عليه، فكان بأن يكون معناه لذلك: ما قام على ساق وما لا يقوم على ساق يسجدان لله، بمعنى: أنه تسجد له الأشياء كلّها المختلفة الهيئات من خَلقِه؛ أشبه وأولى بمعنى الكلام من غيره».</p><p>و<span class="comment-type-3">رجّح</span> <u>ابنُ كثير</u> (١٣/٣١٤) -<span class="mustanad">مستندًا إلى النظائر</span>- القول الثاني، فقال: «وهذا القول هو الأظهر -والله أعلم-؛ لقوله تعالى: <span class="qpc-hafs">﴿ألم تر أن الله يسجد له من في السموات ومن في الأرض والشمس والقمر والنجوم والجبال والشجر والدواب وكثير من الناس﴾</span> الآية [الحج: ١٨]».</div></p><p><h3><span class="qpc-hafs">﴿یَسۡجُدَانِ ۝٦﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٤٠٧٩<span class="dash">-</span></span> عن <span class="name-2">أبي رَزِين [مسعود بن مالك الأسدي]</span> -من طريق زِبْرقان- <span class="qpc-hafs">﴿يَسْجُدانِ﴾</span>، قال: ظِلّهما سجودهما{13}. (١٤/١٠٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٠٨٠<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جُبَير</span> -من طريق زِبْرقان- قال: <span class="qpc-hafs">﴿والنَّجْمُ والشَّجَرُ يَسْجُدانِ﴾</span> ظِلّهما سجودهما{14}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٠٨١<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- <span class="qpc-hafs">﴿والنَّجْمُ والشَّجَرُ يَسْجُدانِ﴾</span>، قال: النّجم نَجم السماء، والشجر الشجرة، يسجد بُكْرةً وعَشيّة{15}<span class=comment-ref>٦٣٦٠</span>. (١٤/١٠٦)</p></p><p></div></p><p><div><span class=comment-ref>٦٣٦٠</span> نقل <u>ابنُ عطية</u> (٨/١٦٠) عن مجاهد «ما معناه: أنّ السجود في هذا كله تجوُّز، وهو عبارة عن الخضوع والتذلل ونحوه». واستشهد له <u>ابن عطية</u> <span class="mustanad">ببيت من الشعر</span>:</p><p>ترى الأكم فيها سُجّدًا للحوافر.</div></p><p><div></p><p><p><span class="item-no">٧٤٠٨٢<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿والنَّجْمُ والشَّجَرُ يَسْجُدانِ﴾</span>، قال: لم يَدَعِ اللهُ شيئًا إلا عَبَّدَهُ له{14}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٠٨٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿يَسْجُدانِ﴾</span> يعني: سجودهما ظِلّهما طرفي النهار حين تزول الشمس، وعند طلوعها إذا تحوَّل ظِلُّ الشجرة فهو سجودها{11}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ٢٢/١٧٤-١٧٥، وابن أبي حاتم -كما في الإتقان ٢/٤٦-، وأبو الشيخ في العظمة (١٢٢٢)، والحاكم ٢/٤٧٤. وعزاه السيوطي إلى ابن المنذر.|2:أخرجه ابن جرير ٢٢/١٧٤-١٧٥، وأبو الشيخ (١٢٠٧) طبعة: دار العصمة.|3:العِضاه: كل شجر له شوك. لسان العرب (عضه).|4:الحُبُك: تَكَسُّر كل شيء، كالرَّملة إذا مرّت عليها الريح الساكنة، والماء القائم إذا مرّت به الريح. التاج (حبك).|5:عزاه السيوطي إلى ابن الأنباري في الوقف والابتداء.|6:أخرجه أبو الشيخ في العظمة (١٢٢٣). وعزاه السيوطي إلى ابن جرير.|7:تفسير مجاهد ص٦٣٦، وأخرجه ابن جرير ٢٢/١٧٤ بنحوه. وعزاه السيوطي إلى ابن المنذر.|8:أخرجه ابن جرير ٢٢/١٧٥-١٧٦، وعبد الرزاق ٣/٢٦٥ في بيان معنى النجم من طريق معمر.|9:أخرجه ابن جرير ٢٢/١٧٤.|10:أخرجه عبد الرزاق ٣/٢٦٥.|11:تفسير مقاتل بن سليمان ٤/١٩٥.|12:أخرجه ابن جرير ٢٢/١٧٤، ١٧٦.|13:أخرجه ابن جرير ٢٢/١٧٦، وأبو الشيخ (١٢٢٣).|14:أخرجه ابن جرير ٢٢/١٧٦.|15:تفسير مجاهد ص٦٣٦، وأخرجه ابن جرير ٢٢/١٧٤، ١٧٧ بنحوه. وعزاه السيوطي إلى ابن المنذر.|16:أخرجه ابن جرير ٢٢/١٧٦.|17:تفسير مقاتل بن سليمان ٤/١٩٥.
  55,7,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَٱلسَّمَاۤءَ رَفَعَهَا وَوَضَعَ ٱلۡمِیزَانَ ۝٧﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٤٠٨٤<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- <span class="qpc-hafs">﴿ووَضَعَ المِيزانَ﴾</span>، قال: العدل{1}<span class=comment-ref>٦٣٦١</span>. (١٤/١٠٦)</p></p><p></div></p><p><div><span class=comment-ref>٦٣٦١</span> لم يذكر <u>ابنُ جرير</u> (٢٢/١٧٧) غيرَ قول مجاهد.</div></p><p><div></p><p><p><span class="item-no">٧٤٠٨٥<span class="dash">-</span></span> قال <span class="name-2">الحسن البصري</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٠٨٦<span class="dash">-</span></span> و<span class="name-2">الضَّحّاك بن مُزاحِم</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٠٨٧<span class="dash">-</span></span> و<span class="name-2">قتادة بن دعامة</span>: <span class="qpc-hafs">﴿ووَضَعَ المِيزانَ﴾</span> هو الذي يُوزَن به لينتصف به الناسُ بعضهم من بعض{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٠٨٨<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿والسَّماءَ رَفَعَها﴾</span> مِن الأرض مسيرة خمسمائة عام، <span class="qpc-hafs">﴿ووَضَعَ المِيزانَ﴾</span> الذي يَزِن به الناسُ، وضعه اللهُ عدلًا بين الناس{3}<span class=comment-ref>٦٣٦٢</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٣٦٢</span> للسلف في المراد بالميزان قولان: <b>الأول</b>: أنه العدل. <b>الثاني</b>: أنه الميزان المعروف بين الناس.</p><p>وقد <span class="comment-type-1">وجّه</span> <u>ابنُ عطية</u> (٨/١٦١) القول الثاني بقوله: «والميزان المعروف جزء من الميزان الذي يُعبّر به عن العدل». ثم <span class="comment-type-3">رجّح</span> أنّ قوله: <span class="qpc-hafs">﴿وضع الميزان﴾</span> مراد به: العدل، وأن قوله: <span class="qpc-hafs">﴿ألا تطغوا في الميزان﴾</span> وقوله: <span class="qpc-hafs">﴿ولا تخسروا الميزان﴾</span> وقوله: <span class="qpc-hafs">﴿وأقيموا الوزن بالقسط﴾</span> مراد به: الميزان المعروف، فقال: «ويظهر عندي أن قوله: <span class="qpc-hafs">﴿وضع الميزان﴾</span> يريد به: العدل. وقوله: <span class="qpc-hafs">﴿ألا تطغوا في الميزان﴾</span> وقوله: <span class="qpc-hafs">﴿وأقيموا الوزن﴾</span> وقوله: <span class="qpc-hafs">﴿ولا تخسروا الميزان﴾</span> يريد به: الميزان المعروف». ولم يذكر مستندًا، ثم <span class="comment-type-4">علّق</span> بقوله: «وكلّ ما قيل محتمل سائغ».</div></p></div>",footnotes:1:تفسير مجاهد ص٦٣٦، وأخرجه ابن جرير ٢٢/١٧٧-١٧٨. وعزاه السيوطي إلى ابن المنذر.|2:تفسير الثعلبي ٩/١٧٨، وتفسير البغوي ٧/٤٤٢.|3:تفسير مقاتل بن سليمان ٤/١٩٥.
  55,8,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿أَلَّا تَطۡغَوۡا۟ فِی ٱلۡمِیزَانِ ۝٨﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٤٠٨٩<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿ألّا تَطْغَوْا فِي المِيزانِ﴾</span>، قال: اعدل -يا ابن آدم- كما تُحبّ أن يُعدل عليك، وأَوْفِ كما تُحبُّ أن يُوفى لك؛ فإنّ العدل يُصلح الناس{1}. (١٤/١٠٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٠٩٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ألّا تَطْغَوْا فِي المِيزانِ﴾</span>، يعني: ألّا تظلِموا في الميزان{2}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ٢٢/١٧٨ بنحوه. وعزاه السيوطي إلى ابن المنذر.|2:تفسير مقاتل بن سليمان ٤/١٩٦.
  55,9,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَأَقِیمُوا۟ ٱلۡوَزۡنَ بِٱلۡقِسۡطِ وَلَا تُخۡسِرُوا۟ ٱلۡمِیزَانَ ۝٩﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٤٠٩١<span class="dash">-</span></span> قال <span class="name-1">أبو الدّرداء</span>: <span class="qpc-hafs">﴿وأَقِيمُوا الوَزْنَ بِالقِسْطِ﴾</span> أقيموا لسان الميزان بالعدل{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٠٩٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق مُغيرة بن مسلم- أنّه رأى رجلًا يَزِن قد أرجح، فقال: أقِم اللسانَ كما قال الله: <span class="qpc-hafs">﴿وأَقِيمُوا الوَزْنَ بِالقِسْطِ﴾</span>{2}. (١٤/١٠٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٠٩٣<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق مُغيرة بن مسلم، عن أبي المُغيرة- أنه كان يقول في سُوق المدينة: يا معشر الموالي، إنّكم قد بُليتم بأمرين أُهلك فيهما أُمّتان مِن الأُمَم: المكيال، والميزان{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٠٩٤<span class="dash">-</span></span> عن قتادة، <span class="qpc-hafs">﴿والسماء رفعها ووضع الميزان ألا تطغوا في الميزان وأقيموا الوزن بالقسط ولا تخسروا الميزان﴾</span>، قال: قال <span class="name-1">ابن عباس</span>: يا معشر الموالي، إنكم وُلِّيتم أمرَين بهما هلك من كان قبلكم، اتقى الله رجلٌ عند ميزانه، اتقى الله رجلٌ عند مكياله، فإنما يعدله شيء يسير، ولا ينقصه ذلك، بل يزيده الله -إن شاء الله-{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٠٩٥<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- <span class="qpc-hafs">﴿وأَقِيمُوا الوَزْنَ بِالقِسْطِ﴾</span>، قال: اللسان{5}. (١٤/١٠٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٠٩٦<span class="dash">-</span></span> قال <span class="name-2">عطاء</span>: <span class="qpc-hafs">﴿وأَقِيمُوا الوَزْنَ بِالقِسْطِ﴾</span> أقيموا لسان الميزان بالعدل{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٠٩٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وأَقِيمُوا الوَزْنَ بِالقِسْطِ﴾</span> يعني: اللسان بالعدل، <span class="qpc-hafs">﴿ولا تُخْسِرُوا﴾</span> يعني: ولا تَنقصوا <span class="qpc-hafs">﴿المِيزانَ﴾</span>{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٠٩٨<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- <span class="qpc-hafs">﴿ولا تُخْسِرُوا﴾</span>، قال: نَقْصه، إذا نَقَصه فقد خَسَره؛ تَخسُّره: نَقْصه{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤٠٩٩<span class="dash">-</span></span> قال <span class="name-3">سفيان بن عُيينة</span>: <span class="qpc-hafs">﴿وأَقِيمُوا الوَزْنَ بِالقِسْطِ﴾</span> الإقامة باليد، والقِسط بالقلب{1}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير الثعلبي ٩/١٧٨، وتفسير البغوي ٧/٤٤٢.|2:أخرجه ابن جرير ٢٢/١٧٨ بنحوه، وابن أبي حاتم -كما في فتح الباري ٨/٦٢١- من طريق أبي المغيرة.|3:أخرجه ابن جرير ٢٢/١٧٨-١٧٩.|4:أخرجه ابن جرير ٢٢/١٧٩.|5:أخرجه ابن المنذر -كما في فتح الباري ٨/٦٢١-.|6:تفسير البغوي ٧/٤٤٢.|7:تفسير مقاتل بن سليمان ٤/١٩٦.|8:أخرجه ابن جرير ٢٢/١٧٩.|9:تفسير الثعلبي ٩/١٧٨، وتفسير البغوي ٧/٤٤٢.
  55,10,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَٱلۡأَرۡضَ وَضَعَهَا لِلۡأَنَامِ ۝١٠﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٤١٠٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- في قوله: <span class="qpc-hafs">﴿والأَرْضَ وضَعَها لِلْأَنامِ﴾</span>، قال: للخلْق{1}. (١٤/١٠٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤١٠١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، <span class="qpc-hafs">﴿والأَرْضَ وضَعَها لِلْأَنامِ﴾</span>، قال: للناس{2}. (١٤/١٠٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤١٠٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق الضَّحّاك- أنّ نافع بن الأزرق قال له: أخبِرني عن قوله: <span class="qpc-hafs">﴿والأَرْضَ وضَعَها لِلْأَنامِ﴾</span>. قال: الأنام: الخلْق، وهم ألف أُمّة: ستمائة في البحر، وأربعمائة في البَر. قال: وهل تعرف العرب ذلك؟ قال: نعم؛ أما سمعتَ لَبيدًا وهو يقول:</p><p>فإن تَسْألينا مِمَّ نحنُ فإنّنا عصافير من هذا الأنام المُسَحَّر؟{3}. (١٤/١٠٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤١٠٣<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق العَوفيّ- قال: كلّ شيء فيه رُوح{4}. (١٤/١٠٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤١٠٤<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- <span class="qpc-hafs">﴿والأَرْضَ وضَعَها لِلْأَنامِ﴾</span>، قال: للخلائق{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤١٠٥<span class="dash">-</span></span> عن <span class="name-2">الضَّحّاك بن مُزاحِم</span>، <span class="qpc-hafs">﴿والأَرْضَ وضَعَها لِلْأَنامِ﴾</span>، قال: كلّ شيء يَدِبّ على الأرض{6}. (١٤/١٠٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤١٠٦<span class="dash">-</span></span> قال <span class="name-2">عامر الشعبي</span>: <span class="qpc-hafs">﴿والأَرْضَ وضَعَها لِلْأَنامِ﴾</span> لكلّ ذي رُوح{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤١٠٧<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق أبي رجاء- قال: <span class="qpc-hafs">﴿والأَرْضَ وضَعَها لِلْأَنامِ﴾</span> للخلْق؛ الجنّ والإنس{8}. (١٤/١٠٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤١٠٨<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- <span class="qpc-hafs">﴿والأَرْضَ وضَعَها لِلْأَنامِ﴾</span>، قال: للخلْق{9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤١٠٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿والأَرْضَ وضَعَها لِلْأَنامِ﴾</span>، يعني: للخليقة مِن أهل الأرض{10}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤١١٠<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- <span class="qpc-hafs">﴿والأَرْضَ وضَعَها لِلْأَنامِ﴾</span>، قال: الأنام: الخلْق{4}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ٢٢/١٨٠ بنحوه، وابن أبي حاتم -كما في فتح الباري ٦/٢٩٦-.|2:أخرجه ابن أبي حاتم -كما في فتح الباري ٦/٢٩٦-، والأثر في مسائل نافع (١١، ٢٢٨). وعزاه السيوطي إلى الفريابي.|3:أخرجه الطبراني (١٠٥٩٧). وعزاه السيوطي إلى الطستي.|4:أخرجه ابن جرير ٢٢/١٨٠.|5:تفسير مجاهد ص٦٣٦، وأخرجه ابن جرير ٢٢/١٨٠.|6:عزاه السيوطي إلى ابن المنذر.|7:تفسير الثعلبي ٩/١٧٨.|8:أخرجه ابن جرير ٢٢/١٨٠. وعزاه السيوطي إلى ابن المنذر.|9:أخرجه ابن جرير ٢٢/١٨٠، ومن طريق أبي العوام.|10:تفسير مقاتل بن سليمان ٤/١٩٦.|11:أخرجه ابن جرير ٢٢/١٨٠.
  55,11,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿فِیهَا فَـٰكِهَةࣱ وَٱلنَّخۡلُ ذَاتُ ٱلۡأَكۡمَامِ ۝١١﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٤١١١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، <span class="qpc-hafs">﴿والنَّخْلُ ذاتُ الأَكْمامِ﴾</span>، قال: أوعية الطّلْع{1}. (١٤/١٠٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤١١٢<span class="dash">-</span></span> قال <span class="name-2">الضَّحّاك بن مُزاحِم</span>: <span class="qpc-hafs">﴿ذاتُ الأَكْمامِ﴾</span> أي: ذات الغُلف{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤١١٣<span class="dash">-</span></span> عن <span class="name-2">الضَّحّاك بن مُزاحِم</span> -من طريق جويبر-= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤١١٤<span class="dash">-</span></span> و<span class="name-2">الحسن البصري</span> -من طريق محدث- في قوله ﷿: <span class="qpc-hafs">﴿والنخل ذات الأكمام﴾</span>، قال: اللّيف؛ كُمَّ به النّخل{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤١١٥<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق أبى رجاء- في قوله: <span class="qpc-hafs">﴿والنَّخْلُ ذاتُ الأَكْمامِ﴾</span>، قال: الأكمام: سَبِيبَة{4} من ليف عُصِبَتْ بها{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤١١٦<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق معمر-= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤١١٧<span class="dash">-</span></span> و<span class="name-2">قتادة بن دعامة</span> -من طريق معمر- في قوله: <span class="qpc-hafs">﴿والنَّخْلُ ذاتُ الأَكْمامِ﴾</span>، قال: أكمامها: لِيفها{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤١١٨<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق أبي العوام- في قوله: <span class="qpc-hafs">﴿والنَّخْلُ ذاتُ الأَكْمامِ﴾</span>، قال: أكمامها: رُفاتُها{7}<span class=comment-ref>٦٣٦٣</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٣٦٣</span> نقل <u>ابنُ عطية</u> (٨/١٦١) عن قتادة قوله: «أكمام النخل: رقابها». ثم <span class="comment-type-4">علَّق</span> بقوله: «والكُمّ من النبات: كل ما التفَّ على شيءٍ وستره، ومنه كمائم الزهر، وبه شبه كُمُّ الثوب».</div></p><p><div></p><p><p><span class="item-no">٧٤١١٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فِيها﴾</span> يعني: في الأرض <span class="qpc-hafs">﴿فاكِهَةٌ والنَّخْلُ ذاتُ الأَكْمامِ﴾</span> يعني: ذات الأجواف، مثل قوله: <span class="qpc-hafs">﴿وما تَخْرُجُ مِن ثَمَراتٍ مِن أكْمامِها﴾</span> [فصلت:٤٧]، يعني: الكُفُرّى{8} مُوقَر طَلْعها{9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤١٢٠<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿والنَّخْلُ ذاتُ الأَكْمامِ﴾</span>، قيل له: هو الطّلْع؟ قال: نعم، وهو في كُمٍّ منه حتى يَنفَتق عنه. قال: والحَبّ أيضًا في أكمام. وقرأ: <span class="qpc-hafs">﴿وما تَخْرُجُ مِن ثَمَراتٍ مِن أكْمامِها﴾</span> [فصلت:٤٧]{10}<span class=comment-ref>٦٣٦٤</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٣٦٤</span> اختُلف في معنى قوله: <span class="qpc-hafs">﴿والنخل ذات الأكمام﴾</span> على أقوال: <b>الأول</b>: أنه عنى بذلك: تكمّم النخل في اللّيف. <b>الثاني</b>: أنه عنى بالأكمام: الرفات. <b>الثالث</b>: أنّ معناه: والنخل ذات الطلع المتكمّم في كمامه.</p><p>وقد <span class="comment-type-3">رجّح</span> <u>ابنُ جرير</u> (٢٢/١٨٢) <span class="mustanad">العموم</span>، فقال: «وأولى الأقوال في ذلك بالصواب أن يُقال: إنّ الله وصف النخل بأنها ذات أكمام، وهي متكمّمة في لِيفها، وطَلْعها متكمّم في جُفِّه، ولم يخصّص الله الخبر عنها بتكمّمها في لِيفها ولا تكمّم طلْعها في جُفِّه، بل عمّ الخبر عنها بأنها ذات أكمام، والصواب أن يقال: عنى بذلك ذات لِيف، وهي به مُتكمّمة وذات طَلْع هو في جُفّه متكمم؛ فيعمّم، كما عم -جلّ ثناؤه-».</div></p></div>",footnotes:1:عزاه السيوطي إلى ابن المنذر.|2:تفسير الثعلبي ٩/١٧٩، وتفسير البغوي ٧/٤٤٢.|3:أخرجه سعيد بن منصور في سننه -التفسير ٧/٥٠٥ (٢١٢٧).|4:السَّبيبَة: الثوب الرقيق. لسان العرب (سبب).|5:أخرجه ابن جرير ٢٢/١٨١.|6:أخرجه عبد الرزاق ٢/٢٦٢، وابن جرير ٢٢/١٨١-١٨٢، وبنحوه من طريق سعيد. وذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٤/٣٢٦- عن الحسن.|7:أخرجه ابن جرير ٢٢/١٨٢، وذكر محققوه أن في بعض النسخ: رقابها.|8:الكُفُرّى -بالضم وتشديد الراء وفتح الفاء وضمها مقصور-: هو وعاء الطلع وقشره الأعلى، وكذلك كافوره. النهاية (كفر).|9:تفسير مقاتل بن سليمان ٤/١٩٦.|10:أخرجه ابن جرير ٢٢/.١٨٢.
  55,12,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَٱلۡحَبُّ ذُو ٱلۡعَصۡفِ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٤١٢١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- <span class="qpc-hafs">﴿والحَبُّ ذُو العَصْفِ﴾</span>، قال: التِّبن{1}. (١٤/١٠٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤١٢٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق العَوفيّ- قال: <span class="qpc-hafs">﴿العَصْفِ﴾</span>: ورق الزرع الأخضر الذي قطع رؤوسه، فهو يُسمّى العصف إذا يبس{2}. (١٤/١٠٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤١٢٣<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق سعيد- في الآية، قال: العصف: الزرع أول ما يخرج بقلًا{3}. (١٤/١٠٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤١٢٤<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جُبَير</span> -من طريق جعفر- <span class="qpc-hafs">﴿والحَبُّ ذُو العَصْفِ﴾</span>، قال: العصف: البقْل من الزرع{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤١٢٥<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- <span class="qpc-hafs">﴿والحَبُّ ذُو العَصْفِ﴾</span>، قال: ورق الحنطة{5}. (١٤/١٠٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤١٢٦<span class="dash">-</span></span> عن <span class="name-2">الضَّحّاك بن مُزاحِم</span> -من طريق سفيان- في الآية، قال: الحَبّ: الحنطة والشعير. والعصف: القِشر الذي يكون على الحَبّ{6}. (١٤/١٠٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤١٢٧<span class="dash">-</span></span> عن <span class="name-2">الضَّحّاك بن مُزاحِم</span> -من طريق عطية بن الحارث- قال: <span class="qpc-hafs">﴿والحَبُّ ذُو العَصْفِ﴾</span>، العصف: التِّبن{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤١٢٨<span class="dash">-</span></span> عن <span class="name-2">أبي مالك غَزْوان الغفاري</span> -من طريق إسماعيل بن أبي خالد- قال: <span class="qpc-hafs">﴿والحَبُّ﴾</span> الحَبّ: أول ما يَنبُت{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤١٢٩<span class="dash">-</span></span> عن <span class="name-2">أبي صالح باذام</span> -من طريق إسماعيل- قال: <span class="qpc-hafs">﴿العَصْفِ﴾</span> أول ما يَنبُت{9}. (١٤/١٠٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤١٣٠<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- قال: <span class="qpc-hafs">﴿ذُو العَصْفِ﴾</span> العصف: التِّبن{10}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤١٣١<span class="dash">-</span></span> عن <span class="name-2">عطاء الخُراسانيّ</span> -من طريق يونس بن يزيد- في قول الله ﷿: <span class="qpc-hafs">﴿العصف والريحان﴾</span>، قال: التِّبن{11}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤١٣٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿والحَبُّ﴾</span> فيها، يعني: في الأرض أيضًا، الحَبّ: يعني البُرّ والشعير، <span class="qpc-hafs">﴿ذُو العَصْفِ﴾</span> يعني: ورق الزرع الذي يكون فيه الحَبّ{12}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤١٣٣<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- قال: <span class="qpc-hafs">﴿ذُو العَصْفِ﴾</span> العَصْف: الورق من كلّ شيء. قال: يُقال للزّرع إذا قُطع: عُصافة، وكلّ ورق فهو عُصافة{13}<span class=comment-ref>٦٣٦٥</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٣٦٥</span> <span class="comment-type-4">ذهب</span> <u>ابن جرير</u> (٢٢/١٨٣) إلى أن معنى: العَصْف هو: الورق الحادث من حَبّ الشعير والبُرّ، والتّبن إذا يبس. ثم قال: «<span class="mustanad">وبنحو الذي قلنا في ذلك قال أهل التأويل</span>». وذكر أقوال السلف على ذلك. ثم ذكر قول الضَّحّاك: «أنّ معنى العصف هو الحَبّ من البُرّ والشعير بعينه». ولم يعلق عليه.</div></p><p><h3><span class="qpc-hafs">﴿وَٱلرَّیۡحَانُ ۝١٢﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٤١٣٤<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- <span class="qpc-hafs">﴿والرَّيْحانُ﴾</span>، قال: خُضرة الزّرع{14}. (١٤/١٠٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤١٣٥<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق العَوفيّ- قال: <span class="qpc-hafs">﴿والرَّيْحانُ﴾</span> ما أنبتَت الأرض من الرّيحان الذي يُشم{15}. (١٤/١٠٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤١٣٦<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، في الآية، قال: <span class="qpc-hafs">﴿والرّيحان﴾</span> حين يستوي على سُوقه ولم يُسَنبل{16}. (١٤/١٠٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤١٣٧<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عكرمة- قال: كل ريحان في القرآن فهو الرزق{17}. (١٤/١٠٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤١٣٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق سعيد بن جُبَير- <span class="qpc-hafs">﴿والرَّيْحانُ﴾</span>، قال: الرِّيع{17}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤١٣٩<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- <span class="qpc-hafs">﴿والرَّيْحانُ﴾</span>، قال: الرِّزق{19}. (١٤/١٠٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤١٤٠<span class="dash">-</span></span> عن <span class="name-2">الضَّحّاك بن مُزاحِم</span> -من طريق عبيد- <span class="qpc-hafs">﴿والرَّيْحانُ﴾</span>، قال: الرّيحان: ما أنبَتت الأرض من ريحان{20}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤١٤١<span class="dash">-</span></span> عن <span class="name-2">الضَّحّاك بن مُزاحِم</span> -من طريق عطية بن الحارث- قال: <span class="qpc-hafs">﴿والرَّيْحانُ﴾</span> الرِّزق والطعام{17}. (١٤/١٠٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤١٤٢<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق قتادة- <span class="qpc-hafs">﴿والرَّيْحانُ﴾</span>، قال: ريحانكم هذا{22}. (١٤/١٠٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤١٤٣<span class="dash">-</span></span> قال <span class="name-3">محمد بن السّائِب الكلبي</span>: <span class="qpc-hafs">﴿والرَّيْحانُ﴾</span> الرّيحان: الرِّزق{23}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤١٤٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿والرَّيْحانُ﴾</span> يعني: الرِّزق. نظيرها: <span class="qpc-hafs">﴿فَرَوْحٌ ورَيْحانٌ﴾</span> [الواقعة:٨٩] يعني: الرِّزق، بلسان حِمْيَر، الذي يَخرج من الحَبّ من دقيق أو سويق أو غيره{12}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤١٤٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن حيان</span>: <span class="qpc-hafs">﴿والرَّيْحانُ﴾</span> الرِّزق، بلُغة حِمْيَر{25}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤١٤٦<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- <span class="qpc-hafs">﴿والرَّيْحانُ﴾</span>، قال: الرّياحيّن التي تُوجد ريحها{20}<span class=comment-ref>٦٣٦٦</span>. (١٤/١٠٩)</p></p><p></div></p><p><div><span class=comment-ref>٦٣٦٦</span> في المراد بالريحان أقوال: <b>الأول</b>: أنه الرِّزق. <b>الثاني</b>: أنه الرّيحان الذي يُشم. <b>الثالث</b>: أنه ما قام على ساق. <b>الرابع</b>: أنه خُضرة الزرع.</p><p>و<span class="comment-type-4">علّق</span> <u>ابنُ عطية</u> (٨/١٦٢) على القول الثاني بقوله: «وفي هذا النوع نعمة عظيمة؛ ففيه الأزهار، والمندل، والعقاقير، وغير ذلك».</p><p>وقد <span class="comment-type-3">رجّح</span> <u>ابنُ جرير</u> (٢٢/١٨٨) -<span class="mustanad">مستندًا إلى الدلالة العقلية، واللغة</span>- القول الأول، فقال: "وأولى الأقوال في ذلك بالصواب قول مَن قال: عني به: الرِّزق، وهو الحَبّ الذي يؤكل منه، وإنما قلنا ذلك أولى الأقوال في ذلك بالصواب لأن الله -جلّ ثناؤه- أخبر عن الحَبّ أنه ذو العَصْف، وذلك ما وصفنا من الورق الحادث منه، والتِّبن إذا يبس، فالذي هو أولى بالرّيحان أن يكون حَبّه الحادث منه، إذ كان من جنس الشيء الذي منه العَصْف، ومسموع من العرب تقول: خرجنا نطلب ريحان الله ورِزقه، ويقال: سبحانك وريحانك، أي: ورِزقك، ومنه قول النّمر بن تولب:</p><p>سلامُ الإله ورَيحانه وجنّته وسماءٌ دِرر".</p><p>ثم قال: «وذُكر عن بعضهم أنه كان يقول: العَصْف: المأكول من الحَبّ. والرّيحان: الصحيح الذي لم يؤكل».</p><p>و<span class="comment-type-4">قال</span> <u>ابنُ كثير</u> (١٣/٣١٦) عقب ذكره الخلاف في هذا: «ومعنى هذا -والله أعلم- أنّ الحَبّ كالقمح والشعير ونحوهما له في حال نباته عَصْف، وهو: ما على السُّنبلة، وريحان، وهو: الورق الملتفّ على ساقها».</div></p></div>",footnotes:1:أخرجه ابن جرير ٢٢/١٨٣، وابن أبي حاتم -كما في الفتح ٨/٦٢١-. وعزاه السيوطي إلى ابن المنذر.|2:أخرجه ابن جرير ٢٢/١٨٣.|3:أخرجه ابن جرير ٢٢/١٨٥ بنحوه، وابن أبي حاتم -كما في الفتح ٨/٦٢١-. وعزاه السيوطي إلى ابن المنذر.|4:أخرجه ابن جرير ٢٢/١٨٣-١٨٤.|5:تفسير مجاهد ص٦٣٦، وأخرجه الفريابي -كما في تغليق التعليق ٤/٣٢٩-، وابن جرير ٢٢/١٨٤-١٨٥ بلفظ: العصف: الورق من كل شيء، قال: يقال للزرع إذا قطع: عصافة، وكل ورق فهو عصافة. وعزاه السيوطي إلى ابن المنذر.|6:أخرجه ابن جرير ٢٢/١٨٤ بنحوه، وأخرجه ابن أبي حاتم -كما في الفتح ٨/٦٢١- بلفظ: العصف: البر والشعير. وعزاه السيوطي إلى ابن المنذر.|7:أخرجه ابن جرير ٢٢/١٨٥. وعلقه البخاري في صحيحه ٤/١٨٤٦.|8:أخرجه ابن جرير ٢٢/١٨٤، وأخرجه عبد بن حميد -كما في تغليق التعليق ٤/٣٢٩- وزاد: تسميه النبط: هبورا.|9:أخرجه أبو الشيخ في العظمة (٧٥٦).|10:أخرجه عبد الرزاق ٢/٢٦٢، وابن جرير ٢٢/١٨٤، وبنحوه من طريق سعيد.|11:أخرجه أبو جعفر الرملي في جزئه (تفسير عطاء) ص١١٢.|12:تفسير مقاتل بن سليمان ٤/١٩٦.|13:أخرجه ابن جرير ٢٢/١٨٤-١٨٥.|14:أخرجه ابن جرير ٢٢/١٨٧. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.|15:عزاه السيوطي إلى ابن جرير ٢٢/١٨٧، وأخرجه ابن جرير ٢٢/١٨٧ كذلك دون قوله: الذي يُشم.|16:عزاه السيوطي إلى ابن جرير، وابن المنذر، وابن أبي حاتم.|17:أخرجه ابن جرير ٢٢/١٨٦.|18:أخرجه ابن جرير ٢٢/١٨٦.|19:تفسير مجاهد ص٦٣٦، وأخرجه الفريابي -كما في تغليق التعليق ٤/٣٢٩-، وابن جرير ٢٢/١٨٦.|20:أخرجه ابن جرير ٢٢/١٨٧.|21:أخرجه ابن جرير ٢٢/١٨٦.|22:أخرجه ابن جرير ٢٢/١٨٧. وذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٤/٣٢٦- بنحوه.|23:ذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٤/٣٢٦-.|24:تفسير مقاتل بن سليمان ٤/١٩٦.|25:تفسير الثعلبي ٩/١٧٩.|26:أخرجه ابن جرير ٢٢/١٨٧.
  55,13,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿فَبِأَیِّ ءَالَاۤءِ رَبِّكُمَا تُكَذِّبَانِ ۝١٣﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٤١٤٧<span class="dash">-</span></span> عن عبد الله بن عمر: أنّ رسول الله ﷺ قرأ سورة الرحمن على أصحابه فسكتوا، فقال: «<b>ما لي أسمعُ الجنَّ أحسن جوابًا لربها منكم؟! ما أتيتُ على قول الله: <span class="qpc-hafs">﴿فَبِأَيِّ آلاءِ رَبِّكُما تُكَذِّبانِ﴾</span> إلا قالوا: لا شيء من نِعمك ربّنا نُكذّب؛ فلك الحمد</b>»{1}. (١٤/١٠١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤١٤٨<span class="dash">-</span></span> عن جابر بن عبد الله، قال: خرج رسول الله ﷺ على أصحابه، فقرأ عليهم سورة الرحمن مِن أولها إلى آخرها، فسكتوا، فقال: «<b>ما لي أراكم سُكوتًا؟! لقد قرأتُها على الجنّ ليلة الجنّ فكانوا أحسن مردودًا منكم، كنتُ كلّما أتيتُ على قوله: <span class="qpc-hafs">﴿فَبِأَيِّ آلاءِ رَبِّكُما تُكَذِّبانِ﴾</span> قالوا: ولا بشيء من نِعمك ربّنا نُكذّب؛ فلك الحمد</b>»{2}. (١٤/١٠٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤١٤٩<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- <span class="qpc-hafs">﴿فَبِأَيِّ آلاءِ رَبِّكُما تُكَذِّبانِ﴾</span>، قال: بأي نعمة الله{3}. (١٤/١٠٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤١٥٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق مجاهد- أنه كان إذا قرأ: <span class="qpc-hafs">﴿فَبِأَيِّ آلاءِ رَبِّكُما تُكَذِّبانِ﴾</span> قال: لا بأيتها ربنا{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤١٥١<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق سهل السراج- قال: <span class="qpc-hafs">﴿فَبِأَيِّ آلاءِ رَبِّكُما تُكَذِّبانِ﴾</span> فبأي نعمة ربكما تكذبان{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤١٥٢<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- قوله: <span class="qpc-hafs">﴿فَبِأَيِّ آلاءِ رَبِّكُما تُكَذِّبانِ﴾</span>، يقول للجن والإنس: فبأيِّ نِعَم الله تُكذِّبان؟!{6}. (١٤/١١٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤١٥٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: لَمّا ذكر ما خَلَق من النِّعَم؛ قال: <span class="qpc-hafs">﴿فَبِأَيِّ آلاءِ رَبِّكُما تُكَذِّبانِ﴾</span> يعني: الجن والإنس، يعني: فبأي نعماء ربكما تكذبان بأنها ليست من الله؟!{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤١٥٤<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- <span class="qpc-hafs">﴿فَبِأَيِّ آلاءِ رَبِّكُما تُكَذِّبانِ﴾</span>، قال: الآلاء: القدرة، فبأي آلائه تكذب، خلقكم كذا وكذا، فبأي قدرة الله تكذبان أيها الثقلان؛ الجن والإنس{8}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه البزار ١٢/١٩٠ (٥٨٥٣)، والمستغفري في فضائل القرآن ٢/٦٢٦ (٩٣٥)، وابن جرير ٢٢/١٩٠، من طريق يحيى بن سليمان الطائفي، عن إسماعيل بن أُميّة، عن نافع، عن ابن عمر به.</p><p>وأخرجه ابن أبي الدنيا في كتاب الشكر ص٢٦ (٦٨)، من طريق يحيى بن سليم الطائفي، عن إسماعيل بن أُميّة، عن عمرو بن سعد بن العاصي، عن نافع، عن ابن عمر به.</p><p>قال البزار: «هذا الحديث لا نعلمه يُروى عن النبي ﷺ إلا من هذا الوجه، بهذا الإسناد». وقال السيوطي: «سند صحيح». وأورده الألباني في الصحيحة ٥/١٨٣ (٢١٥٠).|2:أخرجه الترمذي ٥/٤٨٥ (٣٥٧٥)، والحاكم ٢/٥١٥ (٣٧٦٦)، والثعلبي ٩/١٧٩، والواحدي ٤/٢١٩ (١١٥٢)، من طريق الوليد بن مسلم، عن زهير بن محمد، عن محمد بن المنكدر، عن جابر بن عبد الله به.</p><p>قال الترمذي: «هذا حديث غريب، لا نعرفه إلا من حديث الوليد بن مسلم عن زهير بن محمد». وقال الحاكم: «صحيح، على شرط الشيخين، ولم يخرجاه». ووافقه الذهبي. وقال الألباني في الصحيحة ٥/١٨٤ (٢١٥٠): «الحديث بمجموع الطريقين لا ينزل عن رتبة الحسن».|3:أخرجه ابن جرير ٢٢/١٩٠ بنحوه. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.|4:أخرجه ابن جرير ٢٢/١٩٠-١٩١.|5:أخرجه ابن جرير ٢٢/١٨٩.|6:أخرجه ابن جرير ٢٢/١٩٠، وابن أبي حاتم -كما في تغليق التعليق ٤/٣٣١-.|7:تفسير مقاتل بن سليمان ٤/١٩٦|8:أخرجه ابن جرير ٢٢/١٩١.
  55,14,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿خَلَقَ ٱلۡإِنسَـٰنَ مِن صَلۡصَـٰلࣲ كَٱلۡفَخَّارِ ۝١٤﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٤١٥٥<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق مجاهد- في قوله: <span class="qpc-hafs">﴿مِن صَلْصالٍ كالفَخّارِ﴾</span>، قال: هو مِن الطّين الذي إذا مَطَرت السماء فيَبِست الأرض كأنه خَزف الرّقاق{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤١٥٦<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق الضَّحّاك- قال: خلَق الله آدم من طين لازِب، واللازِب: اللّزِج الطيب مِن بعد حَمأً مَسْنون مُنتِن. قال: وإنما كان حَمأً مسنونًا بعد التراب. قال: فخَلَق منه آدم بيده. قال: فمكث أربعين ليلة جسدًا مُلْقًى، فكان إبليس يأتيه، فيضربه بِرِجله، فيُصَلْصِل؛ فيُصوِّت. قال: فهو قول الله تعالى: <span class="qpc-hafs">﴿كالفَخّارِ﴾</span>، يقول: كالشيء المُنفَرج الذي ليس بمُصْمَت{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤١٥٧<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق سعيد بن جُبَير- قال: الصّلصال: التّراب المُدقَّق{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤١٥٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- <span class="qpc-hafs">﴿خَلَقَ الإنْسانَ مِن صَلْصالٍ كالفَخّارِ﴾</span>، قال: الصّلصال: الطين اليابس{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤١٥٩<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عكرمة- <span class="qpc-hafs">﴿خَلَقَ الإنْسانَ مِن صَلْصالٍ كالفَخّارِ﴾</span>، قال: ما عُصِر، فخَرج من بين الأصابع{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤١٦٠<span class="dash">-</span></span> قال <span class="name-1">عبد الله بن عباس</span>: الصّلصال: الطين الجيّد إذا ذَهب عنه الماء فتشقّق، فإذا تَحرّك تقَعْقع{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤١٦١<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿مِن صَلْصالٍ كالفَخّارِ﴾</span>، قال: كما يُصنع الفخّار{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤١٦٢<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span> -من طريق سماك- في قوله: <span class="qpc-hafs">﴿مِن صَلْصالٍ كالفَخّارِ﴾</span>، قال: الصّلصال: طين قد خُلِط برمل، فكان الفخّار{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤١٦٣<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- في قوله: <span class="qpc-hafs">﴿مِن صَلْصالٍ كالفَخّارِ﴾</span>، قال: من طين له صَلْصَلَة{9} كان يابسًا، ثم خَلَق الإنسان منه{10}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤١٦٤<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق عثمان- <span class="qpc-hafs">﴿مِن صَلْصالٍ كالفَخّارِ﴾</span>: وهو التراب اليابس الذي يُسمع له صَلْصَلَة{11}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤١٦٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿خَلَقَ الإنْسانَ﴾</span> يعني: آدم ﵇ <span class="qpc-hafs">﴿مِن صَلْصالٍ﴾</span> يعني: من تُراب الرّمل، ومعه مِن الطين الحر. وأما قوله: <span class="qpc-hafs">﴿كالفَخّارِ﴾</span> يعني: هو بمنزلة الفخّار مِن قبل أن يُطبخ، يقول: كان ابن آدم مِن قبل أن يُنفخ فيه الرّوح بمنزلة الفخّار أجوف{6}<span class=comment-ref>٦٣٦٧</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٣٦٧</span> نقل <u>ابنُ عطية</u> (٨/١٦٤) في معنى: <span class="qpc-hafs">﴿الإنسان﴾</span> عن آخرين قولهم: «أراد: اسم الجنس». و<span class="comment-type-4">علَّق</span> عليه بقوله: «وساغ ذلك مِن حيث إنّ أباهم مخلوق من الصلصال».</div></p><p><div></p><p><p><span class="item-no">٧٤١٦٦<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span>، <span class="qpc-hafs">﴿مِن صَلْصالٍ كالفَخّارِ﴾</span>، قال: يَبِس آدمُ في الطين في الجنة، حتى صار كالصّلصال، وهو الفخّار، والحَمأ المسْنون: المُنتن الرّيح{13}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ٢٢/١٩٢.|2:أخرجه ابن جرير ٢٢/١٩٢.|3:أخرجه ابن جرير ٢٢/١٩٢.|4:أخرجه ابن جرير ٢٢/١٩٣.|5:أخرجه ابن جرير ٢٢/١٩٤.|6:تفسير مقاتل بن سليمان ٤/١٩٦.|7:تفسير مجاهد ص٦٣٦، وأخرجه الفريابي -كما في تغليق التعليق ٤/٣٣٠-، وابن جرير ٢٢/١٩٣.|8:أخرجه ابن جرير ٢٢/١٩٣.|9:الصَّلْصَلَة: صوت الحديد إذا حُرِّك. النهاية (صلصل).|10:أخرجه عبد الرزاق ٢/٢٦٢، وابن جرير ٢٢/١٩٣-١٩٤، كذلك أخرج بنحوه من طريق أبي العوام، وسعيد.|11:أخرجه يحيى بن سلّام ٢/٨٢٦.|12:تفسير مقاتل بن سليمان ٤/١٩٦.|13:أخرجه ابن جرير ٢٢/١٩٣-١٩٤.
  55,15,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَخَلَقَ ٱلۡجَاۤنَّ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٤١٦٧<span class="dash">-</span></span> قال <span class="name-2">الضَّحّاك بن مُزاحِم</span>: <span class="qpc-hafs">﴿وخَلَقَ الجانَّ﴾</span> هو إبليس{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤١٦٨<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وخَلَقَ الجانَ﴾</span>، يعني: إبليس{2}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير الثعلبي ٩/١٨١، وتفسير البغوي ٧/٤٤٤.|2:تفسير مقاتل بن سليمان ٤/١٩٧.
  55,16,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿مِن مَّارِجࣲ مِّن نَّارࣲ ۝١٥ فَبِأَیِّ ءَالَاۤءِ رَبِّكُمَا تُكَذِّبَانِ ۝١٦﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٤١٦٩<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطية العَوفيّ- في قوله: <span class="qpc-hafs">﴿وخَلَقَ الجانَّ مِن مارِجٍ مِن نارٍ﴾</span>، قال: مِن لهب النار{1}. (١٤/١١٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤١٧٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق مجاهد- <span class="qpc-hafs">﴿مِن مارِجٍ مِن نارٍ﴾</span>، قال: مِن لَهَبِها؛ من وسَطها{2}. (١٤/١١٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤١٧١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- <span class="qpc-hafs">﴿مِن مارِجٍ مِن نارٍ﴾</span>، قال: خالص النار{3}. (١٤/١١٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤١٧٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، قال: <span class="qpc-hafs">﴿مِن مارِجٍ مِن نارٍ﴾</span> مِن شُعَب النار{4}. (١٤/١١٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤١٧٣<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق الضحاك- قال: خلقت الجن الذين ذُكروا في القرآن من مارج من نار، وهو لسان النار الذي يكون في طرفها إذا أُلهبَت{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤١٧٤<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جُبَير</span>، قال: <span class="qpc-hafs">﴿مِن مارِجٍ مِن نارٍ﴾</span> الخضْرة التي تُقطع من النار؛ السّواد الذي يكون بين النار وبين الدُّخان{6}. (١٤/١١١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤١٧٥<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿مِن مارِجٍ مِن نارٍ﴾</span>، قال: اللّهب الأصفر والأخضر الذي يعلو النار إذا أُوقدت{7}. (١٤/١١٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤١٧٦<span class="dash">-</span></span> عن <span class="name-2">الضَّحّاك بن مُزاحِم</span> -من طريق سفيان- <span class="qpc-hafs">﴿وخَلَقَ الجانَّ مِن مارِجٍ مِن نارٍ﴾</span>، قال: من أحسن النار{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤١٧٧<span class="dash">-</span></span> عن <span class="name-2">الضَّحّاك بن مُزاحِم</span> -من طريق عبيد- <span class="qpc-hafs">﴿مِن مارِجٍ مِن نارٍ﴾</span>: مِن لهب النار{9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤١٧٨<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span> -من طريق يعقوب بن قيس المكيّ- <span class="qpc-hafs">﴿مِن مارِجٍ مِن نارٍ﴾</span>، قال: مِن أحسن النار{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤١٧٩<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span> -من طريق سِماك- <span class="qpc-hafs">﴿مِن مارِجٍ مِن نارٍ﴾</span>، قال: مِن حيث تلتهب النار{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤١٨٠<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- قال: مِن لهب النار{12}. (١٤/١١٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤١٨١<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق معمر- <span class="qpc-hafs">﴿مِن مارِجٍ مِن نارٍ﴾</span>، قال: مِن لهب النار{13}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤١٨٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿مِن مارِجٍ مِن نارٍ﴾</span> يعني: مِن لهب النار، صافٍ ليس له دُخان، وإنما سُمّي: الجان؛ لأنه مِن حيٍّ مِن الملائكة يقال لهم: الجنّ، فالجنّ الجماعة، والجانّ الواحد، وكان حُسن خَلقهما من النّعم، فمِن ثَمّ قال: <span class="qpc-hafs">﴿فَبِأَيِّ آلاءِ﴾</span> يعني: نعماء <span class="qpc-hafs">﴿رَبِّكُما تُكَذِّبانِ﴾</span>{14}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤١٨٣<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span>: <span class="qpc-hafs">﴿مِن مارِجٍ مِن نارٍ﴾</span>، قال: المارج: اللهب{9}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿مِن مَّارِجࣲ مِّن نَّارࣲ ۝١٥ فَبِأَیِّ ءَالَاۤءِ رَبِّكُمَا تُكَذِّبَانِ ۝١٦﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٧٤١٨٤<span class="dash">-</span></span> عن عائشة، قالت: قال رسول الله ﷺ: «<b>خُلِقَت الملائكةُ مِن نور، وخُلق الجنّ من مارجٍ من نار، وخُلق آدم كما وُصف لكم</b>»{16}. (١٤/١١١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٤١٨٥<span class="dash">-</span></span> قال <span class="name-2">الحسن البصري</span>: الإنس كلّهم مِن عند آخرهم ولد آدم، والجنّ كلّهم من عند آخرهم ولد إبليس{17}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ٢٢/١٩٥ بنحوه. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.|2:أخرجه ابن جرير ٢٢/١٩٥ بنحوه. وعزاه السيوطي إلى الفريابي، وابن المنذر، وابن أبي حاتم.|3:أخرجه ابن جرير ٢٢/١٩٥. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.|4:عزاه السيوطي إلى ابن أبي حاتم.|5:أخرجه ابن جرير ٢٢/١٩٥.|6:عزاه السيوطي إلى عبد بن حميد.|7:تفسير مجاهد ص٦٣٧، وأخرجه عبد الله بن وهب في الجامع -تفسير القرآن ١/١٩ (٣٧) بنحوه، والفريابي -كما في تغليق التعليق ٤/٣٢٩-، وابن جرير ٢٢/١٩٦، وبنحوه من طريق منصور. وعزاه السيوطي إلى الفريابي، وعبد بن حميد.|8:أخرجه ابن جرير ٢٢/١٩٦.|9:أخرجه ابن جرير ٢٢/١٩٧.|10:أخرجه ابن جرير ٢٢/١٩٦.|11:أخرجه ابن جرير ٢٢/١٩٦.|12:أخرجه ابن جرير ٢٢/١٩٧. وعزاه السيوطي إلى عبد بن حميد.|13:أخرجه عبد الرزاق ٢/٢٦٢، وابن جرير ٢٢/١٩٧.|14:تفسير مقاتل بن سليمان ٤/١٩٧.|15:أخرجه ابن جرير ٢٢/١٩٧.|16:أخرجه مسلم ٤/٢٢٩٤ (٢٩٩٦)، وعبد الرزاق ٢/٣٣٢ (١٦٧٨).|17:ذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٤/٣٢٧-.