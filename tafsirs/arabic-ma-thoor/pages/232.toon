tafsir[9]{c,v,t}:
11,89," <q>﴿وَیَـٰقَوۡمِ لَا یَجۡرِمَنَّكُمۡ شِقَاقِیۤ﴾</q> - تفسير ٣٦٢٥٦- عن مجاهد بن جبر، قال: <q>﴿شقاقي﴾</q>، قال: عَداوَتي{1}. (٨/١٣٠) ٣٦٢٥٧- عن الحسن البصري -من طريق عمران بن القطان- في قوله: <q>﴿ويا قوم لا يجرمنكم شقاقي﴾</q>، قال: ضِراري{2}. (ز) ٣٦٢٥٨- عن قتادة بن دعامة -من طريق مَعْمَر- <q>﴿لا يجرمنكم شقاقي﴾</q>: لا يَحْمِلَنَّكم فِراقي{3}. (٨/١٣٠) ٣٦٢٥٩- عن إسماعيل السُّدِّيّ -من طريق أسباط- في قوله: <q>﴿ويا قوم لا يجرِمَنَّكم شِقاقي﴾</q> الآية، يقول: لا يَحْمِلَنَّكم عَداوَتِي{4}. (٨/١٣١) ٣٦٢٦٠- قال مقاتل بن سليمان: <q>﴿ويا قَوْمِ لا يَجْرِمَنَّكُمْ شِقاقِي﴾</q>، يقول: لا تَحْمِلَنَّكم عَداوَتِي{5}. (ز) ٣٦٢٦١- عن عبد الملك ابن جُرَيْج -من طريق حجّاج- قوله: <q>﴿لا يجرمنكم شقاقي﴾</q>، قال: عَداوَتي وبَغْضائي وفِراقي{6}٣٢٧٧. (ز) ٣٢٧٧ لم يذكر ابنُ جرير (١٢/٥٥١) في معنى: <q>﴿لا يَجْرِمَنَّكُمْ شِقاقِي﴾</q> سوى قول قتادة، وابن جريج. ٣٦٢٦٢- قال سفيان الثوري، في قوله: <q>﴿لا يجرمنكم شقاقي﴾</q>: لا تَحْمِلَنَّكم عَداوَتي{7}. (ز) <q>﴿أَن یُصِیبَكُم مِّثۡلُ مَاۤ أَصَابَ قَوۡمَ نُوحٍ أَوۡ قَوۡمَ هُودٍ أَوۡ قَوۡمَ صَـٰلِحࣲۚ وَمَا قَوۡمُ لُوطࣲ مِّنكُم بِبَعِیدࣲ ۝٨٩﴾</q> - تفسير ٣٦٢٦٣- عن عبد الله بن عباس -من طريق جويبر، عن الضحاك- قال: إنّ شعيبًا قال لقومه: يا قومِ، اذكروا قومَ نوح وعاد وثمود، وما قومُ لوط منكم ببعيد. وكان قومُ لوط أقربَهم إلى شعيب، وكانوا أقربَهم عهدًا بالهلاك{8}. (٨/١٣٠) ٣٦٢٦٤- عن قتادة بن دعامة -من طريق مَعْمَر- في قوله: <q>﴿وما قوم لوط منكم ببعيد﴾</q>، قال: إنّما كانوا حديثي عهدٍ قريبٍ بعد نوح وثمود{9}. (٨/١٣١) ٣٦٢٦٥- عن إسماعيل السُّدِّيّ -من طريق أسباط- في قوله: <q>﴿ويا قوم لا يجرِمَنَّكم شِقاقي﴾</q> الآية، يقول: لا يَحْمِلنَّكم عداوتي على أن تَتَمادَوا في الضلال والكفر؛ فيصيبكم مِن العذاب ما أصابهم{4}. (٨/١٣١) ٣٦٢٦٦- قال مقاتل بن سليمان: <q>﴿أنْ يُصِيبَكُمْ﴾</q> مِن العذاب في الدنيا <q>﴿مِثْلُ ما أصابَ قَوْمَ نُوحٍ﴾</q> مِن الغَرَق، <q>﴿أوْ قَوْمَ هُودٍ﴾</q> مِن الرِّيح، <q>﴿أوْ قَوْمَ صالِحٍ﴾</q> مِن الصَّيْحَة، <q>﴿وما قَوْمُ لُوطٍ﴾</q> أي: ما أصابهم مِن الخَسْف والحَصْب <q>﴿مِنكُمْ بِبَعِيدٍ﴾</q> كان عذابُ قوم لوط أقربَ العذاب إلى قوم شعيب مِن غيرهم{5}٣٢٧٨. (ز) ٣٢٧٨ ذكر ابنُ عطية (٥/٨) أنّ قصة قوم لوط كانت أقربَ القصص عهدًا بقصة قوم شعيب، ثم أورد احتمالًا آخر، فقال: «وقد يحتمل أن يريد: وما منازل قوم لوط منكم ببعيد. فكأنه قال: وما قوم لوط منكم ببعيد بالمسافة. ويتضمن هذا القول ضرب المثل لهم بقوم لوط». <q>﴿أَن یُصِیبَكُم مِّثۡلُ مَاۤ أَصَابَ قَوۡمَ نُوحٍ أَوۡ قَوۡمَ هُودٍ أَوۡ قَوۡمَ صَـٰلِحࣲۚ وَمَا قَوۡمُ لُوطࣲ مِّنكُم بِبَعِیدࣲ ۝٨٩﴾</q> - آثار متعلقة بالآية ٣٦٢٦٧- عن أبي ليلى الكندي، قال: أشرف عثمانُ على الناس مِن دارِه وقد أحاطوا به، فقال: <q>﴿ويا قوم لا يجرمنكم شقاقي أن يصيبكم مثل ما أصاب قوم نوح أو قوم هود أو قوم صالح وما قوم لوط منكم ببعيد﴾</q>، يا قومِ، لا تقتُلوني؛ إنّكم إن قتلتموني كنتم هكذا. وشبَّك بين أصابعه{12}. (٨/١٣١) ",footnotes:1:عزاه السيوطي إلى ابن المنذر.أخرجه ابن أبي حاتم ٦/٢٠٧٥.أخرجه ابن جرير ١٢/٥٥١، وابن أبي حاتم ٦/٢٠٧٤-٢٠٧٥. وعزاه السيوطي إلى أبي الشيخ.أخرجه ابن أبي حاتم ٦/٢٠٧٥. وعزاه السيوطي إلى أبي الشيخ.تفسير مقاتل بن سليمان ٢/٢٩٥.أخرجه ابن جرير ١٢/٥٥١.تفسير سفيان الثوري ص١٣٣.أخرجه ابن عساكر ٢٣/٧٠-٧١، وقد سقط أول الأثر من المخطوط والمطبوع. وينظر: مختصر ابن منظور ١٠/٣١٠-٣١١. وعزاه السيوطي إلى إسحاق بن بشر.أخرجه عبد الرزاق ١/٣١٠-٣١١، وابن جرير ١٢/٥٥١، وابن أبي حاتم ٦/٢٠٧٥.أخرجه ابن أبي حاتم ٦/٢٠٧٥. وعزاه السيوطي إلى أبي الشيخ.تفسير مقاتل بن سليمان ٢/٢٩٥.أخرجه ابن أبي شيبة ١٤/٥٩٠-٥٩١، وابن أبي حاتم ٦/٢٠٧٥.
11,90," <q>﴿وَٱسۡتَغۡفِرُوا۟ رَبَّكُمۡ ثُمَّ تُوبُوۤا۟ إِلَیۡهِۚ إِنَّ رَبِّی رَحِیمࣱ وَدُودࣱ ۝٩٠﴾</q> - تفسير ٣٦٢٦٨- عن عبد الله بن عباس -من طريق جُوَيْبِر، عن الضَّحّاك- قال: <q>﴿واستغفروا ربكم ثم توبوا إليه إن ربي رحيم﴾</q> لِمَن تاب إليه مِن الذنب، <q>﴿ودود﴾</q> يعني: يُحِبُّه ثُمَّ يقذف له المَحَبَّة في قلوب عباده. فردُّوا عليه، فقالوا: <q>﴿يا شعيب ما نفقه كثيرًا مما تقول وإنا لنراك فينا ضعيفًا﴾</q>{1}. (٨/١٣٠) ٣٦٢٦٩- قال مقاتل بن سليمان: <q>﴿واسْتَغْفِرُوا رَبَّكُمْ﴾</q> مِن الشِّرْك، <q>﴿ثُمَّ تُوبُوا إلَيْهِ﴾</q> منها{2}، <q>﴿إنَّ رَبِّي رَحِيمٌ﴾</q> لِمَن تاب وأطاعه، <q>﴿ودُودٌ﴾</q> يعني: مُجِيب{3}. (ز) ٣٦٢٧٠- عن سفيان الثوري، في قوله: <q>﴿ربي رحيم ودود﴾</q>، قال: المُحِبّ{4}. (ز) ٣٦٢٧١- عن سفيان الثوري -من طريق عيسى بن جعفر قاضي الرَّيِّ- في قوله: <q>﴿إن ربي رحيم ودود﴾</q>: مُجِيب{5}. (ز) ",footnotes:1:أخرجه ابن عساكر ٢٣/٧٠-٧١، وقد سقط أول الأثر من المخطوط والمطبوع. وينظر: مختصر ابن منظور ١٠/٣١٠-٣١١. وعزاه السيوطي إلى إسحاق بن بشر.كذا في هذا الموضع من مطبوعة المصدر، وتقدم في مواضع سابقة بلفظ: منه، وهو أشبه. وذكر محققه أنّه جاء في حاشية بعض النسخ أن تقدير «منها» أي: من معصية الشرك.تفسير مقاتل بن سليمان ٢/٢٩٥.تفسير سفيان الثوري ص١٣٣.أخرجه ابن أبي حاتم ٦/٢٠٧٦.
11,91," <q>﴿قَالُوا۟ یَـٰشُعَیۡبُ مَا نَفۡقَهُ كَثِیرࣰا مِّمَّا تَقُولُ﴾</q> - تفسير ٣٦٢٧٢- عن سفيان الثوري -من طريق مهران- <q>﴿ما نفقه كثيرا مما تقول﴾</q>: ما نعرِف{1}. (ز) ٣٦٢٧٣- قال مقاتل بن سليمان: <q>﴿قالُوا يا شُعَيْبُ ما نَفْقَهُ﴾</q> يعني: ما نَعْقِل <q>﴿كَثِيرًا مِمّا تَقُولُ﴾</q> لنا مِن التوحيد، ومِن وفاء الكَيْل والميزان{2}. (ز) <q>﴿وَإِنَّا لَنَرَىٰكَ فِینَا ضَعِیفࣰاۖ﴾</q> - تفسير ٣٦٢٧٤- عن علي بن أبي طالب أنّه خَطَب، فتلا هذه الآية في شعيب: <q>﴿وإنا لنراك فينا ضعيفًا﴾</q>، قال: كان مَكْفُوفًا، فنَسَبُوه إلى الضَّعْف{3}. (٨/١٣٣) ٣٦٢٧٥- عن عبد الله بن عباس -من طريق سعيد بن جبير- في قوله: <q>﴿وإنا لنراك فينا ضعيفًا﴾</q>، قال: كان ضَرِيرَ البَّصَر{4}. (٨/١٣٢) ٣٦٢٧٦- عن عبد الله بن عباس -من طريق جُوَيْبِر، عن الضحاك- قال: <q>﴿وإنا لنراك فينا ضعيفًا﴾</q>، كان أعمى{5}. (٨/١٣٠) ٣٦٢٧٧- عن سعيد بن جبير -من طريق سالم- في قوله: <q>﴿وإنا لنراك فينا ضعيفًا﴾</q>، قال: كان أعمى، وإنّما عَمِي مِن بُكائه مِن حُبِّ الله ﷿{6}. (٨/١٣١) ٣٦٢٧٨- عن أبي صالح باذام، في قوله: <q>﴿وإنا لنراك فينا ضعيفًا﴾</q>، قال: كان ضَرِير البَصَر{3}. (٨/١٣٢) ٣٦٢٧٩- عن إسماعيل السُّدِّيّ -من طريق رجل- في قوله: <q>﴿وإنا لنراك فينا ضعيفًا﴾</q>، قال: إنّما أنت واحد{8}. (٨/١٣٢) ٣٦٢٨٠- عن أبي رَوْق عطية بن الحارث الهمداني -من طريق بشر- في قوله: <q>﴿إنا لنراك فينا ضعيفا﴾</q>، قال: ذليلًا. قال: قالوا له: إنّ عشيرتك ليسوا على دينك؛ فأنت ذليلٌ ضعيف{1}. (ز) ٣٦٢٨١- قال مقاتل بن سليمان: <q>﴿وإنّا لَنَراكَ فِينا ضَعِيفًا﴾</q>، يعني: ذليلًا، لا قُوَّة لك ولا حِيلَة{2}. (ز) ٣٦٢٨٢- قال سفيان الثوري، في قوله: <q>﴿وإنا لنراك فينا ضعيفا﴾</q>، قال: في بصره ضَعْفٌ{11}. (ز) ٣٦٢٨٣- عن سفيان الثوري -من طريق أبي نعيم- في قوله: <q>﴿وإنا لنراك فينا ضعيفًا﴾</q>، قال: كان أعمى، وكان يُقال له: خطيب الأنبياء{12}. (٨/١٣٢) ٣٦٢٨٤- عن شريك [بن عبد الله القاضي] -من طريق عمرو بن عون، ومحمد بن الصباح- في قوله: <q>﴿وإنا لنراك فينا ضعيفا﴾</q>، قال: أعمى{13}٣٢٧٩. (ز) ٣٢٧٩ نقل ابنُ عطية (٥/٩) عن سعيد بن جبير، وشريك القاضي «في قولهم: <q>﴿ضَعِيفًا﴾</q>: أنّه كان ضرير البصر أعمى ... وقيل: كان ناحل البدن». ثم انتقده مستندًا إلى الدلالة العقلية قائلًا: «وهذا كله ضعيف ولا تقوم عليه حجة بضعف بصره أو بدنه». واختار في «قولهم: <q>﴿ضَعِيفًا﴾</q> أنّه: ضعيف الانتصار والقدرة، وأنّ رهطه الكفرة كانوا يراعون فيه». <q>﴿وَلَوۡلَا رَهۡطُكَ﴾</q> - تفسير ٣٦٢٨٥- عن علي بن أبي طالب، <q>﴿ولولا رهطك لرجمناك﴾</q>، قال: فواللهِ الذي لا إله غيره، ما هابوا جلالَ ربهم، ما هابوا إلّا العشيرة{3}. (٨/١٣٣) ٣٦٢٨٦- عن زيد بن ثابت -من طريق أبي الأحوص- قال: لو كان لِلُوطٍ مثلُ أصحابِ شُعَيْبٍ لَجاهَد بهم قومَه{15}. (٨/١٣٣) ٣٦٢٨٧- عن عبد الله بن عباس -من طريق جويبر، عن الضحاك- قال: <q>﴿ولولا رهطك﴾</q>، يعني: عشيرتك التي أنت منهم{16}. (٨/١٣٠) ٣٦٢٨٨- عن أبي رَوْق عطية بن الحارث الهمداني -من طريق بشر- قوله: <q>﴿ولولا رهطك لرجمناك﴾</q>، قال: أي: ولولا عشيرتُك نَحْفَظُك فيهم لَرجمناك{1}. (ز) ٣٦٢٨٩- قال مقاتل بن سليمان: <q>﴿ولَوْلا رَهْطُكَ لَرَجَمْناكَ﴾</q>، يعني: عشيرتك، وأقرباءك{18}. (ز) ٣٦٢٩٠- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿ولولا رهطك لرجمناك﴾</q>، قال: لولا أن نتَّقِي قومَك ورهطك لرجمناك{19}. (٨/١٣٣) <q>﴿لَرَجَمۡنَـٰكَۖ﴾</q> - تفسير ٣٦٢٩١- عن عبد الله بن عباس -من طريق جُوَيْبِر، عن الضحاك- قال: <q>﴿لرجمناك﴾</q> يعني: لَقتلناك، <q>﴿وما أنت علينا بعزيز﴾</q>{16}. (٨/١٣٠) ٣٦٢٩٢- عن أبي رَوْق عطية بن الحارث الهمداني -من طريق بشر- قوله: <q>﴿لرجمناك﴾</q>، أي: لَشَتَمْناك، وآذَيناك، ولَفَعَلْنا بك{21}. (ز) ٣٦٢٩٣- قال مقاتل بن سليمان: <q>﴿لَرَجَمْناكَ﴾</q>: لقتلناك{18}٣٢٨٠. (ز) ٣٢٨٠ اختُلِف في معنى: <q>﴿لَرَجَمْناكَ﴾</q> في هذه الآية على أقوال: الأول: لرجمناك بالحجارة. الثاني: لرجمناك بالسَّبِّ. ورجَّح ابنُ عطية (٥/٩) مستندًا إلى ظاهر اللفظ القول الأول، وعلَّق على القول الثاني بقوله: «وهذا أيضًا تستعمله العرب، ومنه قوله تعالى: <q>﴿لأَرْجُمَنَّكَ واهْجُرْنِي مَلِيًّا﴾</q> [مريم:٤٦]». <q>﴿وَمَاۤ أَنتَ عَلَیۡنَا بِعَزِیزࣲ ۝٩١﴾</q> - تفسير ٣٦٢٩٤- قال مقاتل بن سليمان: <q>﴿وما أنْتَ عَلَيْنا﴾</q> يعني: عندنا <q>﴿بِعَزِيزٍ﴾</q> يعني: بعظيم -مثل قول السَّحَرة <q>﴿بِعِزَّةِ فِرْعَوْنَ﴾</q> [الشعراء:٤٤]، يعنون: بعظمة فرعون-، يقولون: أنت علينا هَيِّن{18}. (ز) ",footnotes:1:أخرجه ابن أبي حاتم ٦/٢٠٧٦.تفسير مقاتل بن سليمان ٢/٢٩٥.عزاه السيوطي إلى أبي الشيخ.أخرجه ابن أبي حاتم ٦/٢٠٧٦، والحاكم ٢/٥٦٨، والخطيب ١٠/٤٢٣، وابن عساكر ٢٣/٧١.أخرجه ابن عساكر ٢٣/٧٠-٧١، وقد سقط أول الأثر من المخطوط والمطبوع. وينظر: مختصر ابن منظور ١٠/٣١٠-٣١١. وعزاه السيوطي إلى إسحاق بن بشر.أخرجه ابن عساكر ٢٣/٧٢. وعزاه السيوطي إلى أبي الشيخ.عزاه السيوطي إلى أبي الشيخ.أخرجه ابن أبي حاتم ٦/٢٠٧٦. وعزاه السيوطي إلى أبي الشيخ.أخرجه ابن أبي حاتم ٦/٢٠٧٦.تفسير مقاتل بن سليمان ٢/٢٩٥.تفسير سفيان الثوري ص١٣٣.أخرجه ابن جرير ١٢/٥٥٣. وذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٢/٣٠٦-. وعزاه السيوطي إلى أبي الشيخ.أخرجه ابن جرير ١٢/٥٥٣.عزاه السيوطي إلى أبي الشيخ.أخرجه سعيد بن منصور (١١٠٠ - تفسير).أخرجه ابن عساكر ٢٣/٧٠-٧١. وينظر: مختصر ابن منظور ١٠/٣١٠-٣١١. وعزاه السيوطي إلى إسحاق بن بشر.أخرجه ابن أبي حاتم ٦/٢٠٧٦.تفسير مقاتل بن سليمان ٢/٢٩٥-٢٩٦.أخرجه ابن جرير ١٢/٥٥٤، وابن أبي حاتم ٦/٢٠٧٧. وعزاه السيوطي إلى أبي الشيخ.أخرجه ابن عساكر ٢٣/٧٠-٧١. وينظر: مختصر ابن منظور ١٠/٣١٠-٣١١. وعزاه السيوطي إلى إسحاق بن بشر.أخرجه ابن أبي حاتم ٦/٢٠٧٧.تفسير مقاتل بن سليمان ٢/٢٩٥-٢٩٦.تفسير مقاتل بن سليمان ٢/٢٩٥-٢٩٦.
11,92," <q>﴿قَالَ یَـٰقَوۡمِ أَرَهۡطِیۤ أَعَزُّ عَلَیۡكُم مِّنَ ٱللَّهِ﴾</q> - تفسير ٣٦٢٩٥- عن عبد الله بن عباس -من طريق عطية العوفي- قوله: <q>﴿قال يا قوم أرهطي أعز عليكم من الله واتخذتموه وراءكم ظهريا﴾</q>: وذلك أنّ قومَ شعيب ورهطَه كانوا أعزَّ عليهم مِن الله، وصَغُرَ شأنُ اللهِ عندَهم، عزَّ ربُّنا وجَلَّ{1}. (ز) ٣٦٢٩٦- عن قتادة بن دعامة -من طريق سعيد- قوله: <q>﴿قال يا قوم أرهطي أعز عليكم من الله واتخذتموه وراءكم ظهريا﴾</q>، يقول: عزَّزْتم قومَكم، وأظهَرْتُم بربكم؟!{2}. (ز) ٣٦٢٩٧- عن قتادة بن دعامة -من طريق مَعْمَر- في قوله: <q>﴿أرهطي أعز عليكم من الله﴾</q>، قال: أعززتم قومَكم، واغْتَرَرْتُم بربِّكم؟!{3}. (ز) ٣٦٢٩٨- عن أبي روق عطية بن الحارث الهمداني -من طريق بشر- قال: <q>﴿يا قوم أرهطي أعز عليكم من الله﴾</q>، يقول: عشيرتي أعزُّ عليكم مِن الله؟!{4}. (ز) ٣٦٢٩٩- قال مقاتل بن سليمان: <q>﴿قالَ يا قَوْمِ أرَهْطِي أعَزُّ عَلَيْكُمْ مِنَ اللَّهِ﴾</q>، يعني: أعظم عندكم مِن الله ﷿{5}. (ز) <q>﴿وَٱتَّخَذۡتُمُوهُ وَرَاۤءَكُمۡ ظِهۡرِیًّاۖ﴾</q> - تفسير ٣٦٣٠٠- عن عبد الله بن عباس -من طريق جُوَيْبِر، عن الضَّحّاك- قال: <q>﴿يا قوم أرهطي أعز عليكم من الله﴾</q>؟ قالوا: بل الله. قال: فاتَّخَذتم اللهَ وراءَكم ظِهريًا؟ يعني: تركتم أمرَه وكذَّبتم نبيَّه{6}. (٨/١٣٠) ٣٦٣٠١- عن عبد الله بن عباس -من طريق علي- في قوله: <q>﴿واتخذتموه ورآءكم ظهريًا﴾</q>، يقول: فَضاءً قَصًى{7}{8}. (٨/١٣٣) ٣٦٣٠٢- عن مجاهد بن جبر -من طريق جابر- في قوله: <q>﴿واتخذتموه ورآءكم ظهريًا﴾</q>، قال: نَبَذْتُم أمرَه{9}. (٨/١٣٣) ٣٦٣٠٣- عن مجاهد بن جبر -من طريق ابن أبي نَجِيح- <q>﴿واتخذتموه وراءكم ظهريا﴾</q>، قال: استثناؤهم رهطَ شعيب، وتركهم ما جاء به شعيبٌ وراءَ ظهورهم ظهريًّا{10}. (ز) ٣٦٣٠٤- عن الضحاك بن مزاحم، <q>﴿واتخذتموه ورآءكم ظهريًا﴾</q>، قال: تَهاوَنتُم به{11}. (٨/١٣٤) ٣٦٣٠٥- عن قتادة بن دعامة -من طريق مَعْمَر- في قوله: <q>﴿واتخذتموه ورآءكم ظهريًا﴾</q>، يقول: لا تخافونه{4}. (٨/١٣٣) ٣٦٣٠٦- عن قتادة بن دعامة -من طريق مَعْمَر- <q>﴿واتخذتموه وراءكم ظهريا﴾</q>، قال: لم تُراقِبوه في شيء، إنّما تراقبون قومي. <q>﴿واتخذتموه وراءكم ظهريا﴾</q>، يقول: لا تخافونه{2}. (ز) ٣٦٣٠٧- عن إسماعيل السُّدِّيّ -من طريق أسباط- <q>﴿أرَهْطِي أعَزُّ عَلَيْكُمْ مِنَ اللَّهِ واتَّخَذْتُمُوهُ وراءَكُمْ ظِهْرِيًّا﴾</q>: فجعلتموه خلف ظهوركم؛ فلم تُطِيعوه، ولم تخافوه{14}. (ز) ٣٦٣٠٨- قال مقاتل بن سليمان: <q>﴿واتَّخَذْتُمُوهُ وراءَكُمْ ظِهْرِيًّا﴾</q>، يقول: أطعتم قومَكم، ونبذتم اللهَ وراءَ ظهوركم؛ فلم تُعَظِّموه، فمَن لم يُوَحِّدْه لَمْ يُعَظِّمْه{5}. (ز) ٣٦٣٠٩- قال سفيان الثوري -من طريق إسحاق بن أبي إسرائيل-: <q>﴿واتخذتموه وراءكم ظهريا﴾</q> كما يقول الرجل للرجل: خَلَّفْتُ حاجتي خلفَ ظهرك. فـ<q>﴿اتخذتموه وراءكم ظهريا﴾</q>: استخففتم بأمره، فإذا أراد الرجلُ قضاء حاجةِ صاحبه جعلها أمامه بين يديه، ولم يَسْتَخِفَّ بها{2}. (ز) ٣٦٣١٠- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- <q>﴿واتخذتموه ورآءكم ظهريًا﴾</q>، قال: الظِّهْرِيُّ: الفَضل؛ مثل الجمّال يحتاج معه إلى إبل ظِهرِي فضل لا يَحمِل عليها شيئًا إلا أن يحتاج إليها، فيقول: إنّما ربُّكم عندكم هكذا إن احتجتم إليه، فإن لم تحتاجوا فليس بشيء{17}٣٢٨١. (٨/١٣٤) ٣٢٨١ اختُلِف في هاء الكناية من قوله تعالى: <q>﴿واتَّخَذْتُمُوهُ وراءَكُمْ ظِهْرِيًّا﴾</q> على قولين: الأول: أنّها ترجع إلى الله تعالى، والمعنى: رميتم بأمر الله وراء ظهوركم. الثاني: أنها كناية عمّا جاء به شعيب ﵇. وعلَّق ابنُ عطية (٥/١٠) على القول الأول بقوله: «وهو عندي على حذف مضاف ولا بُدّ». ثم وجَّهه بأنه مبنيٌّ على أن كُفْر قوم شعيب ﵇ كان جحدًا بالله تعالى وجهلًا به. ورجَّح ابنُ جرير (١٢/٥٥٥) مستندًا إلى اللغة القول الأول، وهو قول ابن عباس وما في معناه، وعلَّل (١٢/٥٥٨) ذلك بقوله: «لقرب قوله: <q>﴿واتَّخَذْتُمُوهُ وراءَكُمْ ظِهْرِيًّا﴾</q> من قوله: <q>﴿أرَهْطِي أعَزُّ عَلَيْكُمْ مِنَ اللَّهِ﴾</q>، فكانت الهاء في قوله: <q>﴿واتَّخَذْتُمُوهُ﴾</q> بأن تكون مِن ذكر الله لقرب جوارها منه أشْبَه وأَوْلى». وذكر ابنُ عطية (٥/٩) أنّ الظهريّ: الشيء الذي يكون وراء الظهر، وهو يتصرف على وجهين: الأول: إما بأن يُطرَح. والثاني: إما بأن يُسنَد إليه ويُلجَأ. وزاد قولًا آخر عن فرقة: أنّ المعنى: «أترون رهطي أعز عليكم من الله وأنتم تتخذون الله سند ظهوركم وعماد آمالكم». ووجَّهه بأنّه مقتضٍ أنّ قوم شعيب كانوا يُقِرُّون بالخالق الرازق، ويعتقدون الأصنام وسائط ووسائل ونحو هذا، ثم ذكر قول ابن زيد وعلَّق (٥/١٠) عليه بقوله: «وهذا كله مما يُسْتَنَد إليه». <q>﴿إِنَّ رَبِّی بِمَا تَعۡمَلُونَ مُحِیطࣱ ۝٩٢﴾</q> - تفسير ٣٦٣١١- عن عبد الله بن عباس -من طريق جُوَيْبِر، عن الضَّحّاك- قال: <q>﴿يا قوم أرهطي أعز عليكم من الله﴾</q>؟ قالوا: بل الله. قال: فاتَّخَذتم الله وراءكم ظِهريًا؟ يعني: تركتم أمره وكذَّبتم نبيَّه، غير أنّ علم ربي أحاط بكم، <q>﴿إن ربي بما تعملون محيط﴾</q>. قال ابن عباس: وكان بعد الشِّرك أعظمُ ذنوبهم تطفيفَ المكيال والميزان، وبخسَ الناس أشياءَهم، معَ ذنوب كثيرة كانوا يأتونها، فبدأ شعيبٌ فدعاهم إلى عبادة الله، وكفِّ الظُّلم، وتركِ ما سوى ذلك{6}. (٨/١٣٠) ٣٦٣١٢- قال مقاتل بن سليمان: <q>﴿إنَّ رَبِّي بِما تَعْمَلُونَ مُحِيطٌ﴾</q>، يعني: مِن نقصان الكيل والميزان، يعني: أحاط علمُه بأعمالكم{5}. (ز) ٣٦٣١٣- عن مقاتل بن حيان -من طريق بُكَيْر بن معروف- قوله: <q>﴿بما تعملون محيط﴾</q>، يقول: أحاط عِلْمُه بأعمالهم{14}. (ز) ",footnotes:1:أخرجه ابن جرير ١٢/٥٥٥، وابن أبي حاتم ٦/٢٠٧٧.أخرجه ابن جرير ١٢/٥٥٦.أخرجه عبد الرزاق ١/٣١٢، وابن جرير ١٢/٥٥٦.أخرجه ابن أبي حاتم ٦/٢٠٧٧.تفسير مقاتل بن سليمان ٢/٢٩٦.أخرجه ابن عساكر ٢٣/٧٠-٧١، وقد سقط أول الأثر من المخطوط والمطبوع. وينظر: مختصر ابن منظور ١٠/٣١٠-٣١١. وعزاه السيوطي إلى إسحاق بن بشر.فضاء قصىً: أي: مكانًا واسعًا بعيدًا. تاج العروس (فضو، قصو).أخرجه ابن جرير ١٢/٥٥٥ مختصرا بلفظ:«قصًى»، وابن أبي حاتم ٦/٢٠٧٧.أخرجه ابن جرير ١٢/٥٥٧، وابن أبي حاتم ٦/٢٠٧٧. وعزاه السيوطي إلى أبي الشيخ.تفسير مجاهد ص٣٩٠، وأخرجه ابن جرير ١٢/٥٥٨، وابن أبي حاتم ٦/٢٠٧٧.عزاه السيوطي إلى أبي الشيخ.أخرجه ابن أبي حاتم ٦/٢٠٧٧.أخرجه ابن جرير ١٢/٥٥٦.أخرجه ابن أبي حاتم ٦/٢٠٧٨.تفسير مقاتل بن سليمان ٢/٢٩٦.أخرجه ابن جرير ١٢/٥٥٦.أخرجه ابن جرير ١٢/٥٥٦-٥٥٧، وابن أبي حاتم ٦/٢٠٧٨. وعزاه السيوطي إلى أبي الشيخ.أخرجه ابن عساكر ٢٣/٧٠-٧١، وقد سقط أول الأثر من المخطوط والمطبوع. وينظر: مختصر ابن منظور ١٠/٣١٠-٣١١. وعزاه السيوطي إلى إسحاق بن بشر.تفسير مقاتل بن سليمان ٢/٢٩٦.أخرجه ابن أبي حاتم ٦/٢٠٧٨.
11,93," <q>﴿وَیَـٰقَوۡمِ ٱعۡمَلُوا۟ عَلَىٰ مَكَانَتِكُمۡ إِنِّی عَـٰمِلࣱۖ﴾</q> - تفسير ٣٦٣١٤- عن عبد الله بن عباس -من طريق علي- قوله: <q>﴿يا قوم اعملوا على مكانتكم﴾</q>، قال: على ناحِيَتِكم{1}. (ز) ٣٦٣١٥- قال مقاتل بن سليمان: <q>﴿ويا قَوْمِ اعْمَلُوا عَلى مَكانَتِكُمْ﴾</q> هذا وعيد، يعني: على جَدِيلَتِكُم{2} التي أنتم عليها، <q>﴿إنِّي عامِلٌ﴾</q>{3}. (ز) <q>﴿سَوۡفَ تَعۡلَمُونَ﴾</q> - تفسير ٣٦٣١٦- عن الحسن البصري -من طريق إسماعيل بن مسلم- <q>﴿سوف تعلمون﴾</q>، قال: وعيد{1}. (ز) ٣٦٣١٧- قال مقاتل بن سليمان: <q>﴿سَوْفَ تَعْلَمُونَ﴾</q> هذا وعيد{3}. (ز) <q>﴿مَن یَأۡتِیهِ عَذَابࣱ یُخۡزِیهِ وَمَنۡ هُوَ كَـٰذِبࣱۖ﴾</q> - تفسير ٣٦٣١٨- عن عكرمة مولى ابن عباس -من طريق الحكم بن أبان- في قوله: <q>﴿من يأتيه عذاب يخزيه﴾</q>، قال: الغَرَق{6}. (ز) ٣٦٣١٩- قال مقاتل بن سليمان: <q>﴿مَن يَأْتِيهِ عَذابٌ يُخْزِيهِ﴾</q> يعني: يُذِلُّه، <q>﴿ومَن هُوَ كاذِبٌ﴾</q> بِنُزُول العذاب بكم؛ أنا أو أنتم، لقولهم: ليس بِنازِلٍ بِنا{3}. (ز) <q>﴿وَٱرۡتَقِبُوۤا۟ إِنِّی مَعَكُمۡ رَقِیبࣱ ۝٩٣﴾</q> - تفسير ٣٦٣٢٠- قال مقاتل بن سليمان: <q>﴿وارْتَقِبُوا إنِّي مَعَكُمْ رَقِيبٌ﴾</q>، يعني: انتظروا العذابَ؛ فإنِّي منتظرٌ بكم العذابَ في الدنيا{3}. (ز) ",footnotes:1:أخرجه ابن أبي حاتم ٦/٢٠٧٨.يقال: القوم على جَدِيلة أمرهم: أي: على حالتهم الأولى. النهاية (جدل).تفسير مقاتل بن سليمان ٢/٢٩٦.أخرجه ابن أبي حاتم ٦/٢٠٧٨.تفسير مقاتل بن سليمان ٢/٢٩٦.أخرجه ابن أبي حاتم ٦/٢٠٧٨. كذا أورده هنا! كما أورده في تفسير قول وعيد نوح لقومه: <q>﴿فَسَوْفَ تَعْلَمُونَ مَن يَأْتِيهِ عَذابٌ يُخْزِيهِ ويَحِلُّ عَلَيْهِ عَذابٌ مُقِيمٌ﴾</q> [هود:٣٩]، وهو أشبه بتفسيرها دون هذه الآية.تفسير مقاتل بن سليمان ٢/٢٩٦.تفسير مقاتل بن سليمان ٢/٢٩٦.
11,94," <q>﴿وَلَمَّا جَاۤءَ أَمۡرُنَا نَجَّیۡنَا شُعَیۡبࣰا وَٱلَّذِینَ ءَامَنُوا۟ مَعَهُۥ بِرَحۡمَةࣲ مِّنَّا وَأَخَذَتِ ٱلَّذِینَ ظَلَمُوا۟ ٱلصَّیۡحَةُ فَأَصۡبَحُوا۟ فِی دِیَـٰرِهِمۡ جَـٰثِمِینَ ۝٩٤﴾</q> - تفسير ٣٦٣٢١- عن عبد الله بن عباس: <q>﴿وأَخَذَتِ الَّذِينَ ظَلَمُوا الصَّيْحَةُ﴾</q>، يريد: صيحة جبرئيل ﵇{1}. (ز) ٣٦٣٢٢- عن محمد بن كعب القرظي -من طريق أبي معشر- قال: إنّ أهل مَدْيَنَ عُذِّبُوا ثلاثة أصناف من العذاب: أحدهم: الرجفة في دارهم حتى خرجوا منها، فلمّا خرجوا منها أصابهم فزعٌ شديد، ففَرِقُوا أن يدخلوا البيوت أن تسقط عليهم، فأرسل الله عليهم الظُّلَّة، فدخل تحتها رجلٌ، فقال: ما رأيت كاليوم ظِلًّا أطيب ولا أبرد، هلُمُّوا، أيها الناس. فدخلوا جميعًا تحت الظُّلَّة، فصاح فيهم صيحة واحدة، فماتوا جميعًا{2}. (ز) ٣٦٣٢٣- قال مقاتل بن سليمان: <q>﴿ولَمّا جاءَ أمْرُنا﴾</q> يعني: قولنا في العذاب <q>﴿نَجَّيْنا شُعَيْبًا والَّذِينَ آمَنُوا مَعَهُ بِرَحْمَةٍ مِنّا﴾</q> يعني: بنعمة مِنّا عليهم، <q>﴿وأَخَذَتِ الَّذِينَ ظَلَمُوا الصَّيْحَةُ﴾</q> يعني: صيحة جبريل ﵇، <q>﴿فَأَصْبَحُوا فِي دِيارِهِمْ جاثِمِينَ﴾</q> يعني: في منازلهم موتى{3}. (ز) ٣٦٣٢٤- عن محمد بن إسحاق -من طريق سلمة- قال: بلغني -والله أعلم-: أنّ الله سلَّط عليهم الحَرَّ، حتى إذ أنضجهم أنشأ لهم الظُّلَّة كالسحابة السوداء، فلما رأوها ابتدروها يستغيثون ببردها ما هم فيه، حتى إذا دخلوا تحتها أطبقت، فهلكوا جميعًا، ونجّى الله شعيبًا والذين آمنوا معه، فأصابه على قومه حُزْنٌ لِما نزل بهم مِن نقمة الله{2}. (ز) ٣٦٣٢٥- عن عبد الرحمن بن زيد بن أسلم -من طريق أصبغ بن الفرج- في قول الله: <q>﴿فأصبحوا في ديارهم جاثمين﴾</q>، قال: ميِّتين{2}. (ز) ",footnotes:1:أخرجه بكر بن سهل الدمياطي في تفسيره بإسناده -كما في تاريخ قزوين ٢/٢-.أخرجه ابن أبي حاتم ٦/٢٠٧٩.تفسير مقاتل بن سليمان ٢/٢٩٦.أخرجه ابن أبي حاتم ٦/٢٠٧٩.أخرجه ابن أبي حاتم ٦/٢٠٧٩.
11,95," <q>﴿كَأَن لَّمۡ یَغۡنَوۡا۟ فِیهَاۤۗ أَلَا بُعۡدࣰا لِّمَدۡیَنَ كَمَا بَعِدَتۡ ثَمُودُ ۝٩٥﴾</q> - تفسير ٣٦٣٢٦- عن عبد الله بن عباس -من طريق علي- قوله: <q>﴿كأن لم يغنوا فيها﴾</q>، قال: يقول: كأن لم يعيشوا فيها{1}. (ز) ٣٦٣٢٧- عن قتادة بن دعامة -من طريق مَعْمَر-، مثله{1}. (ز) ٣٦٣٢٨- قال مقاتل بن سليمان: <q>﴿كَأَنْ لَمْ يَغْنَوْا فِيها﴾</q> يعني: كأن لم يكونوا في الدنيا قطُّ، <q>﴿ألا بُعْدًا لِمَدْيَنَ﴾</q> في الهلاك <q>﴿كَما بَعِدَتْ ثَمُودُ﴾</q> يعني: كما هلكت ثمود، لأنّ كل واحدة منهما هلكت بالصَّيْحَة، فمِن ثَمَّ اختص ذِكْرُ ثمودٍ مِن بين الأُمَم{3}. (ز) ",footnotes:1:أخرجه ابن جرير ١٢/٥٦٠.أخرجه ابن جرير ١٢/٥٦٠.تفسير مقاتل بن سليمان ٢/٢٩٦.
11,96," <q>﴿وَلَقَدۡ أَرۡسَلۡنَا مُوسَىٰ بِـَٔایَـٰتِنَا وَسُلۡطَـٰنࣲ مُّبِینٍ ۝٩٦﴾</q> - تفسير ٣٦٣٢٩- عن قتادة بن دعامة -من طريق سعيد- قوله: <q>﴿وسلطان مبين﴾</q>، قال: سلطان مِن الله، وعُذْر مُبين{1}. (ز) ٣٦٣٣٠- قال مقاتل بن سليمان: <q>﴿ولَقَدْ أرْسَلْنا مُوسى بِآياتِنا﴾</q>، يعني: اليد، والعصا، <q>﴿وسلطان مبين﴾</q>{2}. (ز) ",footnotes:1:أخرجه ابن أبي حاتم ٦/٢٠٨٠.تفسير مقاتل بن سليمان ٢/٢٩٦.
11,97," <q>﴿إِلَىٰ فِرۡعَوۡنَ وَمَلَإِی۟هِۦ فَٱتَّبَعُوۤا۟ أَمۡرَ فِرۡعَوۡنَۖ وَمَاۤ أَمۡرُ فِرۡعَوۡنَ بِرَشِیدࣲ ۝٩٧﴾</q> - تفسير ٣٦٣٣١- قال مقاتل بن سليمان: <q>﴿إلى فِرْعَوْنَ ومَلَئِهِ﴾</q> يعني: أشراف قومه، <q>﴿فاتَّبَعُوا أمْرَ فِرْعَوْنَ﴾</q> في المؤمن حين قال: <q>﴿ما أُرِيكُمْ إلّا ما أرى﴾</q> [غافر:٢٩]، فأطاعوا فرعونَ في قوله، يقول الله ﷿: <q>﴿وما أمْرُ فِرْعَوْنَ بِرَشِيدٍ﴾</q> لهم، يعني: بِهَدْيٍ{1}. (ز) ",footnotes:1:تفسير مقاتل بن سليمان ٢/٢٩٦-٢٩٧.
