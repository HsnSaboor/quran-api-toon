quran[9]{c,v,t}:
  11,89,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَیَـٰقَوۡمِ لَا یَجۡرِمَنَّكُمۡ شِقَاقِیۤ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٦٢٥٦<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span>، قال: <span class="qpc-hafs">﴿شقاقي﴾</span>، قال: عَداوَتي{1}. (٨/١٣٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٦٢٥٧<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق عمران بن القطان- في قوله: <span class="qpc-hafs">﴿ويا قوم لا يجرمنكم شقاقي﴾</span>، قال: ضِراري{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٦٢٥٨<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق مَعْمَر- <span class="qpc-hafs">﴿لا يجرمنكم شقاقي﴾</span>: لا يَحْمِلَنَّكم فِراقي{3}. (٨/١٣٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٦٢٥٩<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- في قوله: <span class="qpc-hafs">﴿ويا قوم لا يجرِمَنَّكم شِقاقي﴾</span> الآية، يقول: لا يَحْمِلَنَّكم عَداوَتِي{4}. (٨/١٣١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٦٢٦٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ويا قَوْمِ لا يَجْرِمَنَّكُمْ شِقاقِي﴾</span>، يقول: لا تَحْمِلَنَّكم عَداوَتِي{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٦٢٦١<span class="dash">-</span></span> عن <span class="name-3">عبد الملك ابن جُرَيْج</span> -من طريق حجّاج- قوله: <span class="qpc-hafs">﴿لا يجرمنكم شقاقي﴾</span>، قال: عَداوَتي وبَغْضائي وفِراقي{6}<span class=comment-ref>٣٢٧٧</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٣٢٧٧</span> لم يذكر <u>ابنُ جرير</u> (١٢/٥٥١) في معنى: <span class="qpc-hafs">﴿لا يَجْرِمَنَّكُمْ شِقاقِي﴾</span> سوى قول قتادة، وابن جريج.</div></p><p><div></p><p><p><span class="item-no">٣٦٢٦٢<span class="dash">-</span></span> قال <span class="name-3">سفيان الثوري</span>، في قوله: <span class="qpc-hafs">﴿لا يجرمنكم شقاقي﴾</span>: لا تَحْمِلَنَّكم عَداوَتي{7}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿أَن یُصِیبَكُم مِّثۡلُ مَاۤ أَصَابَ قَوۡمَ نُوحٍ أَوۡ قَوۡمَ هُودٍ أَوۡ قَوۡمَ صَـٰلِحࣲۚ وَمَا قَوۡمُ لُوطࣲ مِّنكُم بِبَعِیدࣲ ۝٨٩﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٦٢٦٣<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق جويبر، عن الضحاك- قال: إنّ شعيبًا قال لقومه: يا قومِ، اذكروا قومَ نوح وعاد وثمود، وما قومُ لوط منكم ببعيد. وكان قومُ لوط أقربَهم إلى شعيب، وكانوا أقربَهم عهدًا بالهلاك{8}. (٨/١٣٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٦٢٦٤<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق مَعْمَر- في قوله: <span class="qpc-hafs">﴿وما قوم لوط منكم ببعيد﴾</span>، قال: إنّما كانوا حديثي عهدٍ قريبٍ بعد نوح وثمود{9}. (٨/١٣١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٦٢٦٥<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- في قوله: <span class="qpc-hafs">﴿ويا قوم لا يجرِمَنَّكم شِقاقي﴾</span> الآية، يقول: لا يَحْمِلنَّكم عداوتي على أن تَتَمادَوا في الضلال والكفر؛ فيصيبكم مِن العذاب ما أصابهم{4}. (٨/١٣١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٦٢٦٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿أنْ يُصِيبَكُمْ﴾</span> مِن العذاب في الدنيا <span class="qpc-hafs">﴿مِثْلُ ما أصابَ قَوْمَ نُوحٍ﴾</span> مِن الغَرَق، <span class="qpc-hafs">﴿أوْ قَوْمَ هُودٍ﴾</span> مِن الرِّيح، <span class="qpc-hafs">﴿أوْ قَوْمَ صالِحٍ﴾</span> مِن الصَّيْحَة، <span class="qpc-hafs">﴿وما قَوْمُ لُوطٍ﴾</span> أي: ما أصابهم مِن الخَسْف والحَصْب <span class="qpc-hafs">﴿مِنكُمْ بِبَعِيدٍ﴾</span> كان عذابُ قوم لوط أقربَ العذاب إلى قوم شعيب مِن غيرهم{5}<span class=comment-ref>٣٢٧٨</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٣٢٧٨</span> <span class="comment-type-4">ذكر</span> <u>ابنُ عطية</u> (٥/٨) أنّ قصة قوم لوط كانت أقربَ القصص عهدًا بقصة قوم شعيب، ثم أورد <b>احتمالًا</b> آخر، فقال: «وقد يحتمل أن يريد: وما منازل قوم لوط منكم ببعيد. فكأنه قال: وما قوم لوط منكم ببعيد بالمسافة. ويتضمن هذا القول ضرب المثل لهم بقوم لوط».</div></p><p><h3><span class="qpc-hafs">﴿أَن یُصِیبَكُم مِّثۡلُ مَاۤ أَصَابَ قَوۡمَ نُوحٍ أَوۡ قَوۡمَ هُودٍ أَوۡ قَوۡمَ صَـٰلِحࣲۚ وَمَا قَوۡمُ لُوطࣲ مِّنكُم بِبَعِیدࣲ ۝٨٩﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٣٦٢٦٧<span class="dash">-</span></span> عن أبي ليلى الكندي، قال: أشرف عثمانُ على الناس مِن دارِه وقد أحاطوا به، فقال: <span class="qpc-hafs">﴿ويا قوم لا يجرمنكم شقاقي أن يصيبكم مثل ما أصاب قوم نوح أو قوم هود أو قوم صالح وما قوم لوط منكم ببعيد﴾</span>، يا قومِ، لا تقتُلوني؛ إنّكم إن قتلتموني كنتم هكذا. وشبَّك بين أصابعه{12}. (٨/١٣١)</p></p><p></div></p></div>",footnotes:1:عزاه السيوطي إلى ابن المنذر.|2:أخرجه ابن أبي حاتم ٦/٢٠٧٥.|3:أخرجه ابن جرير ١٢/٥٥١، وابن أبي حاتم ٦/٢٠٧٤-٢٠٧٥. وعزاه السيوطي إلى أبي الشيخ.|4:أخرجه ابن أبي حاتم ٦/٢٠٧٥. وعزاه السيوطي إلى أبي الشيخ.|5:تفسير مقاتل بن سليمان ٢/٢٩٥.|6:أخرجه ابن جرير ١٢/٥٥١.|7:تفسير سفيان الثوري ص١٣٣.|8:أخرجه ابن عساكر ٢٣/٧٠-٧١، وقد سقط أول الأثر من المخطوط والمطبوع. وينظر: مختصر ابن منظور ١٠/٣١٠-٣١١. وعزاه السيوطي إلى إسحاق بن بشر.|9:أخرجه عبد الرزاق ١/٣١٠-٣١١، وابن جرير ١٢/٥٥١، وابن أبي حاتم ٦/٢٠٧٥.|10:أخرجه ابن أبي حاتم ٦/٢٠٧٥. وعزاه السيوطي إلى أبي الشيخ.|11:تفسير مقاتل بن سليمان ٢/٢٩٥.|12:أخرجه ابن أبي شيبة ١٤/٥٩٠-٥٩١، وابن أبي حاتم ٦/٢٠٧٥.
  11,90,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَٱسۡتَغۡفِرُوا۟ رَبَّكُمۡ ثُمَّ تُوبُوۤا۟ إِلَیۡهِۚ إِنَّ رَبِّی رَحِیمࣱ وَدُودࣱ ۝٩٠﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٦٢٦٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق جُوَيْبِر، عن الضَّحّاك- قال: <span class="qpc-hafs">﴿واستغفروا ربكم ثم توبوا إليه إن ربي رحيم﴾</span> لِمَن تاب إليه مِن الذنب، <span class="qpc-hafs">﴿ودود﴾</span> يعني: يُحِبُّه ثُمَّ يقذف له المَحَبَّة في قلوب عباده. فردُّوا عليه، فقالوا: <span class="qpc-hafs">﴿يا شعيب ما نفقه كثيرًا مما تقول وإنا لنراك فينا ضعيفًا﴾</span>{1}. (٨/١٣٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٦٢٦٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿واسْتَغْفِرُوا رَبَّكُمْ﴾</span> مِن الشِّرْك، <span class="qpc-hafs">﴿ثُمَّ تُوبُوا إلَيْهِ﴾</span> منها{2}، <span class="qpc-hafs">﴿إنَّ رَبِّي رَحِيمٌ﴾</span> لِمَن تاب وأطاعه، <span class="qpc-hafs">﴿ودُودٌ﴾</span> يعني: مُجِيب{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٦٢٧٠<span class="dash">-</span></span> عن <span class="name-3">سفيان الثوري</span>، في قوله: <span class="qpc-hafs">﴿ربي رحيم ودود﴾</span>، قال: المُحِبّ{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٦٢٧١<span class="dash">-</span></span> عن <span class="name-3">سفيان الثوري</span> -من طريق عيسى بن جعفر قاضي الرَّيِّ- في قوله: <span class="qpc-hafs">﴿إن ربي رحيم ودود﴾</span>: مُجِيب{5}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن عساكر ٢٣/٧٠-٧١، وقد سقط أول الأثر من المخطوط والمطبوع. وينظر: مختصر ابن منظور ١٠/٣١٠-٣١١. وعزاه السيوطي إلى إسحاق بن بشر.|2:كذا في هذا الموضع من مطبوعة المصدر، وتقدم في مواضع سابقة بلفظ: منه، وهو أشبه. وذكر محققه أنّه جاء في حاشية بعض النسخ أن تقدير «منها» أي: من معصية الشرك.|3:تفسير مقاتل بن سليمان ٢/٢٩٥.|4:تفسير سفيان الثوري ص١٣٣.|5:أخرجه ابن أبي حاتم ٦/٢٠٧٦.
  11,91,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿قَالُوا۟ یَـٰشُعَیۡبُ مَا نَفۡقَهُ كَثِیرࣰا مِّمَّا تَقُولُ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٦٢٧٢<span class="dash">-</span></span> عن <span class="name-3">سفيان الثوري</span> -من طريق مهران- <span class="qpc-hafs">﴿ما نفقه كثيرا مما تقول﴾</span>: ما نعرِف{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٦٢٧٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿قالُوا يا شُعَيْبُ ما نَفْقَهُ﴾</span> يعني: ما نَعْقِل <span class="qpc-hafs">﴿كَثِيرًا مِمّا تَقُولُ﴾</span> لنا مِن التوحيد، ومِن وفاء الكَيْل والميزان{2}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَإِنَّا لَنَرَىٰكَ فِینَا ضَعِیفࣰاۖ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٦٢٧٤<span class="dash">-</span></span> عن <span class="name-1">علي بن أبي طالب</span> أنّه خَطَب، فتلا هذه الآية في شعيب: <span class="qpc-hafs">﴿وإنا لنراك فينا ضعيفًا﴾</span>، قال: كان مَكْفُوفًا، فنَسَبُوه إلى الضَّعْف{3}. (٨/١٣٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٦٢٧٥<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق سعيد بن جبير- في قوله: <span class="qpc-hafs">﴿وإنا لنراك فينا ضعيفًا﴾</span>، قال: كان ضَرِيرَ البَّصَر{4}. (٨/١٣٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٦٢٧٦<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق جُوَيْبِر، عن الضحاك- قال: <span class="qpc-hafs">﴿وإنا لنراك فينا ضعيفًا﴾</span>، كان أعمى{5}. (٨/١٣٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٦٢٧٧<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span> -من طريق سالم- في قوله: <span class="qpc-hafs">﴿وإنا لنراك فينا ضعيفًا﴾</span>، قال: كان أعمى، وإنّما عَمِي مِن بُكائه مِن حُبِّ الله ﷿{6}. (٨/١٣١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٦٢٧٨<span class="dash">-</span></span> عن <span class="name-2">أبي صالح باذام</span>، في قوله: <span class="qpc-hafs">﴿وإنا لنراك فينا ضعيفًا﴾</span>، قال: كان ضَرِير البَصَر{3}. (٨/١٣٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٦٢٧٩<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق رجل- في قوله: <span class="qpc-hafs">﴿وإنا لنراك فينا ضعيفًا﴾</span>، قال: إنّما أنت واحد{8}. (٨/١٣٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٦٢٨٠<span class="dash">-</span></span> عن <span class="name-2">أبي رَوْق عطية بن الحارث الهمداني</span> -من طريق بشر- في قوله: <span class="qpc-hafs">﴿إنا لنراك فينا ضعيفا﴾</span>، قال: ذليلًا. قال: قالوا له: إنّ عشيرتك ليسوا على دينك؛ فأنت ذليلٌ ضعيف{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٦٢٨١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وإنّا لَنَراكَ فِينا ضَعِيفًا﴾</span>، يعني: ذليلًا، لا قُوَّة لك ولا حِيلَة{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٦٢٨٢<span class="dash">-</span></span> قال <span class="name-3">سفيان الثوري</span>، في قوله: <span class="qpc-hafs">﴿وإنا لنراك فينا ضعيفا﴾</span>، قال: في بصره ضَعْفٌ{11}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٦٢٨٣<span class="dash">-</span></span> عن <span class="name-3">سفيان الثوري</span> -من طريق أبي نعيم- في قوله: <span class="qpc-hafs">﴿وإنا لنراك فينا ضعيفًا﴾</span>، قال: كان أعمى، وكان يُقال له: خطيب الأنبياء{12}. (٨/١٣٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٦٢٨٤<span class="dash">-</span></span> عن <span class="name-3">شريك [بن عبد الله القاضي]</span> -من طريق عمرو بن عون، ومحمد بن الصباح- في قوله: <span class="qpc-hafs">﴿وإنا لنراك فينا ضعيفا﴾</span>، قال: أعمى{13}<span class=comment-ref>٣٢٧٩</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٣٢٧٩</span> نقل <u>ابنُ عطية</u> (٥/٩) عن سعيد بن جبير، وشريك القاضي «في قولهم: <span class="qpc-hafs">﴿ضَعِيفًا﴾</span>: أنّه كان ضرير البصر أعمى ... وقيل: كان ناحل البدن». ثم <span class="comment-type-2">انتقده</span> <span class="mustanad">مستندًا إلى الدلالة العقلية</span> قائلًا: «وهذا كله ضعيف ولا تقوم عليه حجة بضعف بصره أو بدنه». و<span class="comment-type-3">اختار</span> في «قولهم: <span class="qpc-hafs">﴿ضَعِيفًا﴾</span> أنّه: ضعيف الانتصار والقدرة، وأنّ رهطه الكفرة كانوا يراعون فيه».</div></p><p><h3><span class="qpc-hafs">﴿وَلَوۡلَا رَهۡطُكَ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٦٢٨٥<span class="dash">-</span></span> عن <span class="name-1">علي بن أبي طالب</span>، <span class="qpc-hafs">﴿ولولا رهطك لرجمناك﴾</span>، قال: فواللهِ الذي لا إله غيره، ما هابوا جلالَ ربهم، ما هابوا إلّا العشيرة{3}. (٨/١٣٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٦٢٨٦<span class="dash">-</span></span> عن <span class="name-1">زيد بن ثابت</span> -من طريق أبي الأحوص- قال: لو كان لِلُوطٍ مثلُ أصحابِ شُعَيْبٍ لَجاهَد بهم قومَه{15}. (٨/١٣٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٦٢٨٧<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق جويبر، عن الضحاك- قال: <span class="qpc-hafs">﴿ولولا رهطك﴾</span>، يعني: عشيرتك التي أنت منهم{16}. (٨/١٣٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٦٢٨٨<span class="dash">-</span></span> عن <span class="name-2">أبي رَوْق عطية بن الحارث الهمداني</span> -من طريق بشر- قوله: <span class="qpc-hafs">﴿ولولا رهطك لرجمناك﴾</span>، قال: أي: ولولا عشيرتُك نَحْفَظُك فيهم لَرجمناك{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٦٢٨٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ولَوْلا رَهْطُكَ لَرَجَمْناكَ﴾</span>، يعني: عشيرتك، وأقرباءك{18}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٦٢٩٠<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿ولولا رهطك لرجمناك﴾</span>، قال: لولا أن نتَّقِي قومَك ورهطك لرجمناك{19}. (٨/١٣٣)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿لَرَجَمۡنَـٰكَۖ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٦٢٩١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق جُوَيْبِر، عن الضحاك- قال: <span class="qpc-hafs">﴿لرجمناك﴾</span> يعني: لَقتلناك، <span class="qpc-hafs">﴿وما أنت علينا بعزيز﴾</span>{16}. (٨/١٣٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٦٢٩٢<span class="dash">-</span></span> عن <span class="name-2">أبي رَوْق عطية بن الحارث الهمداني</span> -من طريق بشر- قوله: <span class="qpc-hafs">﴿لرجمناك﴾</span>، أي: لَشَتَمْناك، وآذَيناك، ولَفَعَلْنا بك{21}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٦٢٩٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿لَرَجَمْناكَ﴾</span>: لقتلناك{18}<span class=comment-ref>٣٢٨٠</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٣٢٨٠</span> اختُلِف في معنى: <span class="qpc-hafs">﴿لَرَجَمْناكَ﴾</span> في هذه الآية على أقوال: <b>الأول:</b> لرجمناك بالحجارة. <b>الثاني:</b> لرجمناك بالسَّبِّ.</p><p>و<span class="comment-type-3">رجَّح</span> <u>ابنُ عطية</u> (٥/٩) <span class="mustanad">مستندًا إلى ظاهر اللفظ</span> القول الأول، و<span class="comment-type-4">علَّق</span> على القول الثاني بقوله: «وهذا أيضًا تستعمله العرب، <span class="mustanad">ومنه قوله تعالى</span>: <span class="qpc-hafs">﴿لأَرْجُمَنَّكَ واهْجُرْنِي مَلِيًّا﴾</span> [مريم:٤٦]».</div></p><p><h3><span class="qpc-hafs">﴿وَمَاۤ أَنتَ عَلَیۡنَا بِعَزِیزࣲ ۝٩١﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٦٢٩٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وما أنْتَ عَلَيْنا﴾</span> يعني: عندنا <span class="qpc-hafs">﴿بِعَزِيزٍ﴾</span> يعني: بعظيم -مثل قول السَّحَرة <span class="qpc-hafs">﴿بِعِزَّةِ فِرْعَوْنَ﴾</span> [الشعراء:٤٤]، يعنون: بعظمة فرعون-، يقولون: أنت علينا هَيِّن{18}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن أبي حاتم ٦/٢٠٧٦.|2:تفسير مقاتل بن سليمان ٢/٢٩٥.|3:عزاه السيوطي إلى أبي الشيخ.|4:أخرجه ابن أبي حاتم ٦/٢٠٧٦، والحاكم ٢/٥٦٨، والخطيب ١٠/٤٢٣، وابن عساكر ٢٣/٧١.|5:أخرجه ابن عساكر ٢٣/٧٠-٧١، وقد سقط أول الأثر من المخطوط والمطبوع. وينظر: مختصر ابن منظور ١٠/٣١٠-٣١١. وعزاه السيوطي إلى إسحاق بن بشر.|6:أخرجه ابن عساكر ٢٣/٧٢. وعزاه السيوطي إلى أبي الشيخ.|7:عزاه السيوطي إلى أبي الشيخ.|8:أخرجه ابن أبي حاتم ٦/٢٠٧٦. وعزاه السيوطي إلى أبي الشيخ.|9:أخرجه ابن أبي حاتم ٦/٢٠٧٦.|10:تفسير مقاتل بن سليمان ٢/٢٩٥.|11:تفسير سفيان الثوري ص١٣٣.|12:أخرجه ابن جرير ١٢/٥٥٣. وذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٢/٣٠٦-. وعزاه السيوطي إلى أبي الشيخ.|13:أخرجه ابن جرير ١٢/٥٥٣.|14:عزاه السيوطي إلى أبي الشيخ.|15:أخرجه سعيد بن منصور (١١٠٠ - تفسير).|16:أخرجه ابن عساكر ٢٣/٧٠-٧١. وينظر: مختصر ابن منظور ١٠/٣١٠-٣١١. وعزاه السيوطي إلى إسحاق بن بشر.|17:أخرجه ابن أبي حاتم ٦/٢٠٧٦.|18:تفسير مقاتل بن سليمان ٢/٢٩٥-٢٩٦.|19:أخرجه ابن جرير ١٢/٥٥٤، وابن أبي حاتم ٦/٢٠٧٧. وعزاه السيوطي إلى أبي الشيخ.|20:أخرجه ابن عساكر ٢٣/٧٠-٧١. وينظر: مختصر ابن منظور ١٠/٣١٠-٣١١. وعزاه السيوطي إلى إسحاق بن بشر.|21:أخرجه ابن أبي حاتم ٦/٢٠٧٧.|22:تفسير مقاتل بن سليمان ٢/٢٩٥-٢٩٦.|23:تفسير مقاتل بن سليمان ٢/٢٩٥-٢٩٦.
  11,92,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿قَالَ یَـٰقَوۡمِ أَرَهۡطِیۤ أَعَزُّ عَلَیۡكُم مِّنَ ٱللَّهِ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٦٢٩٥<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطية العوفي- قوله: <span class="qpc-hafs">﴿قال يا قوم أرهطي أعز عليكم من الله واتخذتموه وراءكم ظهريا﴾</span>: وذلك أنّ قومَ شعيب ورهطَه كانوا أعزَّ عليهم مِن الله، وصَغُرَ شأنُ اللهِ عندَهم، عزَّ ربُّنا وجَلَّ{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٦٢٩٦<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- قوله: <span class="qpc-hafs">﴿قال يا قوم أرهطي أعز عليكم من الله واتخذتموه وراءكم ظهريا﴾</span>، يقول: عزَّزْتم قومَكم، وأظهَرْتُم بربكم؟!{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٦٢٩٧<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق مَعْمَر- في قوله: <span class="qpc-hafs">﴿أرهطي أعز عليكم من الله﴾</span>، قال: أعززتم قومَكم، واغْتَرَرْتُم بربِّكم؟!{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٦٢٩٨<span class="dash">-</span></span> عن <span class="name-2">أبي روق عطية بن الحارث الهمداني</span> -من طريق بشر- قال: <span class="qpc-hafs">﴿يا قوم أرهطي أعز عليكم من الله﴾</span>، يقول: عشيرتي أعزُّ عليكم مِن الله؟!{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٦٢٩٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿قالَ يا قَوْمِ أرَهْطِي أعَزُّ عَلَيْكُمْ مِنَ اللَّهِ﴾</span>، يعني: أعظم عندكم مِن الله ﷿{5}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَٱتَّخَذۡتُمُوهُ وَرَاۤءَكُمۡ ظِهۡرِیًّاۖ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٦٣٠٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق جُوَيْبِر، عن الضَّحّاك- قال: <span class="qpc-hafs">﴿يا قوم أرهطي أعز عليكم من الله﴾</span>؟ قالوا: بل الله. قال: فاتَّخَذتم اللهَ وراءَكم ظِهريًا؟ يعني: تركتم أمرَه وكذَّبتم نبيَّه{6}. (٨/١٣٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٦٣٠١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- في قوله: <span class="qpc-hafs">﴿واتخذتموه ورآءكم ظهريًا﴾</span>، يقول: فَضاءً قَصًى{7}{8}. (٨/١٣٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٦٣٠٢<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق جابر- في قوله: <span class="qpc-hafs">﴿واتخذتموه ورآءكم ظهريًا﴾</span>، قال: نَبَذْتُم أمرَه{9}. (٨/١٣٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٦٣٠٣<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نَجِيح- <span class="qpc-hafs">﴿واتخذتموه وراءكم ظهريا﴾</span>، قال: استثناؤهم رهطَ شعيب، وتركهم ما جاء به شعيبٌ وراءَ ظهورهم ظهريًّا{10}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٦٣٠٤<span class="dash">-</span></span> عن <span class="name-2">الضحاك بن مزاحم</span>، <span class="qpc-hafs">﴿واتخذتموه ورآءكم ظهريًا﴾</span>، قال: تَهاوَنتُم به{11}. (٨/١٣٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٦٣٠٥<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق مَعْمَر- في قوله: <span class="qpc-hafs">﴿واتخذتموه ورآءكم ظهريًا﴾</span>، يقول: لا تخافونه{4}. (٨/١٣٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٦٣٠٦<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق مَعْمَر- <span class="qpc-hafs">﴿واتخذتموه وراءكم ظهريا﴾</span>، قال: لم تُراقِبوه في شيء، إنّما تراقبون قومي. <span class="qpc-hafs">﴿واتخذتموه وراءكم ظهريا﴾</span>، يقول: لا تخافونه{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٦٣٠٧<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- <span class="qpc-hafs">﴿أرَهْطِي أعَزُّ عَلَيْكُمْ مِنَ اللَّهِ واتَّخَذْتُمُوهُ وراءَكُمْ ظِهْرِيًّا﴾</span>: فجعلتموه خلف ظهوركم؛ فلم تُطِيعوه، ولم تخافوه{14}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٦٣٠٨<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿واتَّخَذْتُمُوهُ وراءَكُمْ ظِهْرِيًّا﴾</span>، يقول: أطعتم قومَكم، ونبذتم اللهَ وراءَ ظهوركم؛ فلم تُعَظِّموه، فمَن لم يُوَحِّدْه لَمْ يُعَظِّمْه{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٦٣٠٩<span class="dash">-</span></span> قال <span class="name-3">سفيان الثوري</span> -من طريق إسحاق بن أبي إسرائيل-: <span class="qpc-hafs">﴿واتخذتموه وراءكم ظهريا﴾</span> كما يقول الرجل للرجل: خَلَّفْتُ حاجتي خلفَ ظهرك. فـ<span class="qpc-hafs">﴿اتخذتموه وراءكم ظهريا﴾</span>: استخففتم بأمره، فإذا أراد الرجلُ قضاء حاجةِ صاحبه جعلها أمامه بين يديه، ولم يَسْتَخِفَّ بها{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٦٣١٠<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- <span class="qpc-hafs">﴿واتخذتموه ورآءكم ظهريًا﴾</span>، قال: الظِّهْرِيُّ: الفَضل؛ مثل الجمّال يحتاج معه إلى إبل ظِهرِي فضل لا يَحمِل عليها شيئًا إلا أن يحتاج إليها، فيقول: إنّما ربُّكم عندكم هكذا إن احتجتم إليه، فإن لم تحتاجوا فليس بشيء{17}<span class=comment-ref>٣٢٨١</span>. (٨/١٣٤)</p></p><p></div></p><p><div><span class=comment-ref>٣٢٨١</span> اختُلِف في هاء الكناية من قوله تعالى: <span class="qpc-hafs">﴿واتَّخَذْتُمُوهُ وراءَكُمْ ظِهْرِيًّا﴾</span> على قولين: <b>الأول:</b> أنّها ترجع إلى الله تعالى، والمعنى: رميتم بأمر الله وراء ظهوركم. <b>الثاني:</b> أنها كناية عمّا جاء به شعيب ﵇.</p><p>و<span class="comment-type-4">علَّق</span> <u>ابنُ عطية</u> (٥/١٠) على القول الأول بقوله: «وهو عندي على حذف مضاف ولا بُدّ». ثم <span class="comment-type-1">وجَّهه</span> بأنه مبنيٌّ على أن كُفْر قوم شعيب ﵇ كان جحدًا بالله تعالى وجهلًا به.</p><p>و<span class="comment-type-3">رجَّح</span> <u>ابنُ جرير</u> (١٢/٥٥٥) <span class="mustanad">مستندًا إلى اللغة</span> القول الأول، وهو قول ابن عباس وما في معناه، وعلَّل (١٢/٥٥٨) ذلك بقوله: «لقرب قوله: <span class="qpc-hafs">﴿واتَّخَذْتُمُوهُ وراءَكُمْ ظِهْرِيًّا﴾</span> من قوله: <span class="qpc-hafs">﴿أرَهْطِي أعَزُّ عَلَيْكُمْ مِنَ اللَّهِ﴾</span>، فكانت الهاء في قوله: <span class="qpc-hafs">﴿واتَّخَذْتُمُوهُ﴾</span> بأن تكون مِن ذكر الله لقرب جوارها منه أشْبَه وأَوْلى».</p><p>وذكر <u>ابنُ عطية</u> (٥/٩) أنّ الظهريّ: الشيء الذي يكون وراء الظهر، وهو يتصرف على وجهين: <b>الأول</b>: إما بأن يُطرَح. <b>والثاني</b>: إما بأن يُسنَد إليه ويُلجَأ. وزاد قولًا آخر عن فرقة: أنّ المعنى: «أترون رهطي أعز عليكم من الله وأنتم تتخذون الله سند ظهوركم وعماد آمالكم». و<span class="comment-type-1">وجَّهه</span> بأنّه مقتضٍ أنّ قوم شعيب كانوا يُقِرُّون بالخالق الرازق، ويعتقدون الأصنام وسائط ووسائل ونحو هذا، ثم ذكر قول ابن زيد و<span class="comment-type-4">علَّق</span> (٥/١٠) عليه بقوله: «وهذا كله مما يُسْتَنَد إليه».</div></p><p><h3><span class="qpc-hafs">﴿إِنَّ رَبِّی بِمَا تَعۡمَلُونَ مُحِیطࣱ ۝٩٢﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٦٣١١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق جُوَيْبِر، عن الضَّحّاك- قال: <span class="qpc-hafs">﴿يا قوم أرهطي أعز عليكم من الله﴾</span>؟ قالوا: بل الله. قال: فاتَّخَذتم الله وراءكم ظِهريًا؟ يعني: تركتم أمره وكذَّبتم نبيَّه، غير أنّ علم ربي أحاط بكم، <span class="qpc-hafs">﴿إن ربي بما تعملون محيط﴾</span>. قال ابن عباس: وكان بعد الشِّرك أعظمُ ذنوبهم تطفيفَ المكيال والميزان، وبخسَ الناس أشياءَهم، معَ ذنوب كثيرة كانوا يأتونها، فبدأ شعيبٌ فدعاهم إلى عبادة الله، وكفِّ الظُّلم، وتركِ ما سوى ذلك{6}. (٨/١٣٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٦٣١٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿إنَّ رَبِّي بِما تَعْمَلُونَ مُحِيطٌ﴾</span>، يعني: مِن نقصان الكيل والميزان، يعني: أحاط علمُه بأعمالكم{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٦٣١٣<span class="dash">-</span></span> عن <span class="name-3">مقاتل بن حيان</span> -من طريق بُكَيْر بن معروف- قوله: <span class="qpc-hafs">﴿بما تعملون محيط﴾</span>، يقول: أحاط عِلْمُه بأعمالهم{14}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ١٢/٥٥٥، وابن أبي حاتم ٦/٢٠٧٧.|2:أخرجه ابن جرير ١٢/٥٥٦.|3:أخرجه عبد الرزاق ١/٣١٢، وابن جرير ١٢/٥٥٦.|4:أخرجه ابن أبي حاتم ٦/٢٠٧٧.|5:تفسير مقاتل بن سليمان ٢/٢٩٦.|6:أخرجه ابن عساكر ٢٣/٧٠-٧١، وقد سقط أول الأثر من المخطوط والمطبوع. وينظر: مختصر ابن منظور ١٠/٣١٠-٣١١. وعزاه السيوطي إلى إسحاق بن بشر.|7:فضاء قصىً: أي: مكانًا واسعًا بعيدًا. تاج العروس (فضو، قصو).|8:أخرجه ابن جرير ١٢/٥٥٥ مختصرا بلفظ:«قصًى»، وابن أبي حاتم ٦/٢٠٧٧.|9:أخرجه ابن جرير ١٢/٥٥٧، وابن أبي حاتم ٦/٢٠٧٧. وعزاه السيوطي إلى أبي الشيخ.|10:تفسير مجاهد ص٣٩٠، وأخرجه ابن جرير ١٢/٥٥٨، وابن أبي حاتم ٦/٢٠٧٧.|11:عزاه السيوطي إلى أبي الشيخ.|12:أخرجه ابن أبي حاتم ٦/٢٠٧٧.|13:أخرجه ابن جرير ١٢/٥٥٦.|14:أخرجه ابن أبي حاتم ٦/٢٠٧٨.|15:تفسير مقاتل بن سليمان ٢/٢٩٦.|16:أخرجه ابن جرير ١٢/٥٥٦.|17:أخرجه ابن جرير ١٢/٥٥٦-٥٥٧، وابن أبي حاتم ٦/٢٠٧٨. وعزاه السيوطي إلى أبي الشيخ.|18:أخرجه ابن عساكر ٢٣/٧٠-٧١، وقد سقط أول الأثر من المخطوط والمطبوع. وينظر: مختصر ابن منظور ١٠/٣١٠-٣١١. وعزاه السيوطي إلى إسحاق بن بشر.|19:تفسير مقاتل بن سليمان ٢/٢٩٦.|20:أخرجه ابن أبي حاتم ٦/٢٠٧٨.
  11,93,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَیَـٰقَوۡمِ ٱعۡمَلُوا۟ عَلَىٰ مَكَانَتِكُمۡ إِنِّی عَـٰمِلࣱۖ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٦٣١٤<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- قوله: <span class="qpc-hafs">﴿يا قوم اعملوا على مكانتكم﴾</span>، قال: على ناحِيَتِكم{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٦٣١٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ويا قَوْمِ اعْمَلُوا عَلى مَكانَتِكُمْ﴾</span> هذا وعيد، يعني: على جَدِيلَتِكُم{2} التي أنتم عليها، <span class="qpc-hafs">﴿إنِّي عامِلٌ﴾</span>{3}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿سَوۡفَ تَعۡلَمُونَ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٦٣١٦<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق إسماعيل بن مسلم- <span class="qpc-hafs">﴿سوف تعلمون﴾</span>، قال: وعيد{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٦٣١٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿سَوْفَ تَعْلَمُونَ﴾</span> هذا وعيد{3}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿مَن یَأۡتِیهِ عَذَابࣱ یُخۡزِیهِ وَمَنۡ هُوَ كَـٰذِبࣱۖ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٦٣١٨<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span> -من طريق الحكم بن أبان- في قوله: <span class="qpc-hafs">﴿من يأتيه عذاب يخزيه﴾</span>، قال: الغَرَق{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٦٣١٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿مَن يَأْتِيهِ عَذابٌ يُخْزِيهِ﴾</span> يعني: يُذِلُّه، <span class="qpc-hafs">﴿ومَن هُوَ كاذِبٌ﴾</span> بِنُزُول العذاب بكم؛ أنا أو أنتم، لقولهم: ليس بِنازِلٍ بِنا{3}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَٱرۡتَقِبُوۤا۟ إِنِّی مَعَكُمۡ رَقِیبࣱ ۝٩٣﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٦٣٢٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وارْتَقِبُوا إنِّي مَعَكُمْ رَقِيبٌ﴾</span>، يعني: انتظروا العذابَ؛ فإنِّي منتظرٌ بكم العذابَ في الدنيا{3}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن أبي حاتم ٦/٢٠٧٨.|2:يقال: القوم على جَدِيلة أمرهم: أي: على حالتهم الأولى. النهاية (جدل).|3:تفسير مقاتل بن سليمان ٢/٢٩٦.|4:أخرجه ابن أبي حاتم ٦/٢٠٧٨.|5:تفسير مقاتل بن سليمان ٢/٢٩٦.|6:أخرجه ابن أبي حاتم ٦/٢٠٧٨. كذا أورده هنا! كما أورده في تفسير قول وعيد نوح لقومه: <span class="qpc-hafs">﴿فَسَوْفَ تَعْلَمُونَ مَن يَأْتِيهِ عَذابٌ يُخْزِيهِ ويَحِلُّ عَلَيْهِ عَذابٌ مُقِيمٌ﴾</span> [هود:٣٩]، وهو أشبه بتفسيرها دون هذه الآية.|7:تفسير مقاتل بن سليمان ٢/٢٩٦.|8:تفسير مقاتل بن سليمان ٢/٢٩٦.
  11,94,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَلَمَّا جَاۤءَ أَمۡرُنَا نَجَّیۡنَا شُعَیۡبࣰا وَٱلَّذِینَ ءَامَنُوا۟ مَعَهُۥ بِرَحۡمَةࣲ مِّنَّا وَأَخَذَتِ ٱلَّذِینَ ظَلَمُوا۟ ٱلصَّیۡحَةُ فَأَصۡبَحُوا۟ فِی دِیَـٰرِهِمۡ جَـٰثِمِینَ ۝٩٤﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٦٣٢١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>: <span class="qpc-hafs">﴿وأَخَذَتِ الَّذِينَ ظَلَمُوا الصَّيْحَةُ﴾</span>، يريد: صيحة جبرئيل ﵇{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٦٣٢٢<span class="dash">-</span></span> عن <span class="name-2">محمد بن كعب القرظي</span> -من طريق أبي معشر- قال: إنّ أهل مَدْيَنَ عُذِّبُوا ثلاثة أصناف من العذاب: أحدهم: الرجفة في دارهم حتى خرجوا منها، فلمّا خرجوا منها أصابهم فزعٌ شديد، ففَرِقُوا أن يدخلوا البيوت أن تسقط عليهم، فأرسل الله عليهم الظُّلَّة، فدخل تحتها رجلٌ، فقال: ما رأيت كاليوم ظِلًّا أطيب ولا أبرد، هلُمُّوا، أيها الناس. فدخلوا جميعًا تحت الظُّلَّة، فصاح فيهم صيحة واحدة، فماتوا جميعًا{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٦٣٢٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ولَمّا جاءَ أمْرُنا﴾</span> يعني: قولنا في العذاب <span class="qpc-hafs">﴿نَجَّيْنا شُعَيْبًا والَّذِينَ آمَنُوا مَعَهُ بِرَحْمَةٍ مِنّا﴾</span> يعني: بنعمة مِنّا عليهم، <span class="qpc-hafs">﴿وأَخَذَتِ الَّذِينَ ظَلَمُوا الصَّيْحَةُ﴾</span> يعني: صيحة جبريل ﵇، <span class="qpc-hafs">﴿فَأَصْبَحُوا فِي دِيارِهِمْ جاثِمِينَ﴾</span> يعني: في منازلهم موتى{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٦٣٢٤<span class="dash">-</span></span> عن <span class="name-3">محمد بن إسحاق</span> -من طريق سلمة- قال: بلغني -والله أعلم-: أنّ الله سلَّط عليهم الحَرَّ، حتى إذ أنضجهم أنشأ لهم الظُّلَّة كالسحابة السوداء، فلما رأوها ابتدروها يستغيثون ببردها ما هم فيه، حتى إذا دخلوا تحتها أطبقت، فهلكوا جميعًا، ونجّى الله شعيبًا والذين آمنوا معه، فأصابه على قومه حُزْنٌ لِما نزل بهم مِن نقمة الله{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٦٣٢٥<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق أصبغ بن الفرج- في قول الله: <span class="qpc-hafs">﴿فأصبحوا في ديارهم جاثمين﴾</span>، قال: ميِّتين{2}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه بكر بن سهل الدمياطي في تفسيره بإسناده -كما في تاريخ قزوين ٢/٢-.|2:أخرجه ابن أبي حاتم ٦/٢٠٧٩.|3:تفسير مقاتل بن سليمان ٢/٢٩٦.|4:أخرجه ابن أبي حاتم ٦/٢٠٧٩.|5:أخرجه ابن أبي حاتم ٦/٢٠٧٩.
  11,95,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿كَأَن لَّمۡ یَغۡنَوۡا۟ فِیهَاۤۗ أَلَا بُعۡدࣰا لِّمَدۡیَنَ كَمَا بَعِدَتۡ ثَمُودُ ۝٩٥﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٦٣٢٦<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- قوله: <span class="qpc-hafs">﴿كأن لم يغنوا فيها﴾</span>، قال: يقول: كأن لم يعيشوا فيها{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٦٣٢٧<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق مَعْمَر-، مثله{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٦٣٢٨<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿كَأَنْ لَمْ يَغْنَوْا فِيها﴾</span> يعني: كأن لم يكونوا في الدنيا قطُّ، <span class="qpc-hafs">﴿ألا بُعْدًا لِمَدْيَنَ﴾</span> في الهلاك <span class="qpc-hafs">﴿كَما بَعِدَتْ ثَمُودُ﴾</span> يعني: كما هلكت ثمود، لأنّ كل واحدة منهما هلكت بالصَّيْحَة، فمِن ثَمَّ اختص ذِكْرُ ثمودٍ مِن بين الأُمَم{3}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ١٢/٥٦٠.|2:أخرجه ابن جرير ١٢/٥٦٠.|3:تفسير مقاتل بن سليمان ٢/٢٩٦.
  11,96,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَلَقَدۡ أَرۡسَلۡنَا مُوسَىٰ بِـَٔایَـٰتِنَا وَسُلۡطَـٰنࣲ مُّبِینٍ ۝٩٦﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٦٣٢٩<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- قوله: <span class="qpc-hafs">﴿وسلطان مبين﴾</span>، قال: سلطان مِن الله، وعُذْر مُبين{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٦٣٣٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ولَقَدْ أرْسَلْنا مُوسى بِآياتِنا﴾</span>، يعني: اليد، والعصا، <span class="qpc-hafs">﴿وسلطان مبين﴾</span>{2}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن أبي حاتم ٦/٢٠٨٠.|2:تفسير مقاتل بن سليمان ٢/٢٩٦.
  11,97,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿إِلَىٰ فِرۡعَوۡنَ وَمَلَإِی۟هِۦ فَٱتَّبَعُوۤا۟ أَمۡرَ فِرۡعَوۡنَۖ وَمَاۤ أَمۡرُ فِرۡعَوۡنَ بِرَشِیدࣲ ۝٩٧﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٦٣٣١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿إلى فِرْعَوْنَ ومَلَئِهِ﴾</span> يعني: أشراف قومه، <span class="qpc-hafs">﴿فاتَّبَعُوا أمْرَ فِرْعَوْنَ﴾</span> في المؤمن حين قال: <span class="qpc-hafs">﴿ما أُرِيكُمْ إلّا ما أرى﴾</span> [غافر:٢٩]، فأطاعوا فرعونَ في قوله، يقول الله ﷿: <span class="qpc-hafs">﴿وما أمْرُ فِرْعَوْنَ بِرَشِيدٍ﴾</span> لهم، يعني: بِهَدْيٍ{1}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٢/٢٩٦-٢٩٧.