tafsir[7]{c,v,t}:
22,24," <q>﴿وَهُدُوۤا۟ إِلَى ٱلطَّیِّبِ مِنَ ٱلۡقَوۡلِ﴾</q> - تفسير ٥٠٢٧٣- عن عبد الله بن عباس -من طريق علي- في قوله: <q>﴿وهدوا إلى الطيب من القول﴾</q>، قال: أُلْهِموا{1}. (١٠/٤٤٧) ٥٠٢٧٤- قال عبد الله بن عباس: هو شهادة أن لا إله إلا الله{2}. (ز) ٥٠٢٧٥- عن أبي العالية الرِّياحِيِّ، في قوله: <q>﴿وهدوا إلى الطيب من القول﴾</q>، قال: في الخصومة؛ إذ قالوا: اللهُ مولانا ولا مولى لكم{3}. (١٠/٤٤٧) ٥٠٢٧٦- عن الضحاك بن مزاحم، <q>﴿وهدوا إلى الطيب من القول﴾</q>، قال: الإخلاص{4}. (١٠/٤٤٧) ٥٠٢٧٧- تفسير الحسن البصري، في قوله: <q>﴿وهدوا إلى الطيب من القول﴾</q>: الإيمان في الدنيا بالله{5}. (ز) ٥٠٢٧٨- قال إسماعيل السُّدِّيّ: أي: القرآن{2}. (ز) ٥٠٢٧٩- عن إسماعيل بن أبي خالد، <q>﴿وهدوا إلى الطيب من القول﴾</q>، قال: القرآن{7}. (١٠/٤٤٧) ٥٠٢٨٠- تفسير محمد بن السائب الكلبي: قوله: <q>﴿وهدوا إلى الطيب من القول﴾</q>، وهو: لا إله إلا الله{8}. (ز) ٥٠٢٨١- قال مقاتل بن سليمان: <q>﴿وهدوا﴾</q> في الدنيا <q>﴿إلى الطيب من القول﴾</q> يعني: التوحيد، وهو قول: لا إله إلا الله وحده لا شريك له. كقوله: <q>﴿كلمة طيبة﴾</q> [إبراهيم:٢٤]، يعني: التوحيد{9}. (ز) ٥٠٢٨٢- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- <q>﴿وهدوا إلى الطيب من القول﴾</q>، قال: لا إله إلا الله، والله أكبر، والحمد لله، الذي قال: <q>﴿اليه يصعد الكلم الطيب﴾</q> [فاطر:١٠]{10}٤٤٤٨. (١٠/٤٤٧) ٤٤٤٨ لم يذكر ابنُ جرير (١٦/٥٠٠) في معنى: <q>﴿وهُدُوا إلى الطَّيِّبِ مِنَ القَوْلِ﴾</q> سوى قول ابن عباس من طريق علي، وابن زيد. <q>﴿وَهُدُوۤا۟ إِلَىٰ صِرَ ٰ⁠طِ ٱلۡحَمِیدِ ۝٢٤﴾</q> - تفسير ٥٠٢٨٣- عن الضحاك بن مزاحم، <q>﴿وهدوا إلى صراط الحميد﴾</q>، قال: الإسلام{4}. (١٠/٤٤٧) ٥٠٢٨٤- عن إسماعيل بن أبي خالد، <q>﴿وهدوا إلى صراط الحميد﴾</q>، قال: الإسلام{7}. (١٠/٤٤٧) ٥٠٢٨٥- قال مقاتل بن سليمان: <q>﴿وهدوا إلى صراط﴾</q> يعني: دين الإسلام <q>﴿الحميد﴾</q> عند خلقه؛ يحمده أولياؤه{9}. (ز) ٥٠٢٨٦- قال يحيى بن سلّام: قوله: <q>﴿وهدوا﴾</q> يعني: في الدنيا <q>﴿إلى صراط الحميد﴾</q> وهو الله. وهو كقوله: <q>﴿وإنك لتهدي إلى صراط مستقيم﴾</q> أي: إلى الجنة، <q>﴿صراط الله﴾</q> [الشورى:٥٢-٥٣] طريق الله الذي هدى له عبادَه المؤمنين إلى الجنة{14}. (ز) ",footnotes:1:أخرجه ابن جرير ١٦/٥٠٠، وابن أبي حاتم -كما في الإتقان ٢/٣٠-. وعزاه السيوطي إلى ابن المنذر.تفسير البغوي ٥/٣٧٦.عزاه السيوطي إلى ابن أبي حاتم.عزاه السيوطي إلى ابن أبي شيبة، وابن المنذر، وابن أبي حاتم.علَّقه يحيى بن سلام ١/٣٦١.تفسير البغوي ٥/٣٧٦.أخرجه ابن المنذر -كما في فتح الباري ٨/٤٤١-. وعزاه السيوطي إلى ابن أبي حاتم.علَّقه يحيى بن سلام ١/٣٦١، وعقَّب عليه وعلى قول الحسن بقوله: وهو واحد.تفسير مقاتل بن سليمان ٣/١٢١.أخرجه ابن جرير ١٦/٥٠٠. وعزاه السيوطي إلى ابن أبي حاتم.عزاه السيوطي إلى ابن أبي شيبة، وابن المنذر، وابن أبي حاتم.أخرجه ابن المنذر -كما في فتح الباري ٨/٤٤١-. وعزاه السيوطي إلى ابن أبي حاتم.تفسير مقاتل بن سليمان ٣/١٢١.تفسير يحيى بن سلام ١/٣٦١.
22,25," <q>﴿إِنَّ ٱلَّذِینَ كَفَرُوا۟ وَیَصُدُّونَ عَن سَبِیلِ ٱللَّهِ﴾</q> - تفسير ٥٠٢٨٧- قال إسماعيل السُّدِّيّ: <q>﴿ويصدون عن سبيل الله﴾</q>، يعني: ويمنعون الناس عن دين الله الإسلام{1}. (ز) ٥٠٢٨٨- قال مقاتل بن سليمان: <q>﴿إن الذين كفروا ويصدون عن سبيل الله﴾</q> يقول ويمنعون الناس عن دين الله ﷿{2}. (ز) ٥٠٢٨٩- قال يحيى بن سلّام: <q>﴿ويصدون عن سبيل الله﴾</q>، يعني: الهدى، يعني: المشركين{3}. (ز) <q>﴿وَٱلۡمَسۡجِدِ ٱلۡحَرَامِ﴾</q> - تفسير ٥٠٢٩٠- عن عبد الله بن عباس، قال: الحرم كله هو المسجد الحرام{4}٤٤٤٩. (١٠/٤٤٨) ٤٤٤٩ نقل ابنُ عطية (٦/٢٣٢) عن فرقة أن «المسجد الحرام» أراد به: مكة كلها. ثم علَّق عليه بقوله: «وهذا صحيح، لكنه قصد بالذِّكر المهم المقصود من ذلك». ٥٠٢٩١- عن قتادة بن دعامة -من طريق سعيد- في قوله تعالى: <q>﴿إن الذين كفروا ويصدون عن سبيل الله والمسجد الحرام﴾</q>، قال: المسجد الحرام: مكة{5}. (ز) ٥٠٢٩٢- قال مقاتل بن سليمان: <q>﴿إن الذين كفروا ويصدون عن سبيل الله﴾</q> يقول: ويمنعون الناس عن دين الله ﷿، <q>﴿و﴾</q>عن <q>﴿المسجد الحرام﴾</q>{2}. (ز) ٥٠٢٩٣- قال يحيى بن سلّام: <q>﴿والمسجد الحرام﴾</q>، أي: ويصدون عن المسجد الحرام{3}. (ز) <q>﴿ٱلَّذِی جَعَلۡنَـٰهُ لِلنَّاسِ سَوَاۤءً ٱلۡعَـٰكِفُ فِیهِ وَٱلۡبَادِۚ﴾</q> - تفسير ٥٠٢٩٤- عن عبد الله بن عباس، قال: قال رسول الله ﷺ، في قول الله تعالى: <q>﴿سواء العاكف فيه والباد﴾</q>، قال: «سواء المقيم، والذي يرحل»{8}. (١٠/٤٥١) ٥٠٢٩٥- عن عبد الله بن عباس، في قوله: <q>﴿سواء﴾</q>: يعني: شرعًا واحدًا، <q>﴿العاكف فيه﴾</q> قال: أهل مكة في مكة أيام الحج، <q>﴿والباد﴾</q> قال: مَن كان في غير أهلها، مَن يعتكف فيه مِن الآفاق. قال: هم في منازل مكة سواء، فينبغي لأهل مكة أن يُوَسِّعوا لهم حتى يقضوا مناسكهم{9}. (١٠/٤٤٨) ٥٠٢٩٦- عن عبد الله بن عباس، في الآية، قال: البادي وأهل مكة سواء في المنزل والحرم{9}. (١٠/٤٤٨) ٥٠٢٩٧- عن عبد الله بن عباس -من طريق علي- <q>﴿سواء العاكف فيه والباد﴾</q>، قال: ينزل أهلُ مكة وغيرُهم في المسجد الحرام{11}. (١٠/٤٥١) ٥٠٢٩٨- عن عبد الله بن عباس، في قوله: <q>﴿سواء العاكف فيه والباد﴾</q>، قال: خَلْقُ الله فيه سواءٌ{12}. (١٠/٤٤٨) ٥٠٢٩٩- عن سعيد بن جبير -من طريق عبد الله بن مسلم-، مثله{13}. (١٠/٤٤٨) ٥٠٣٠٠- عن ابن حصين، قال: سألتُ سعيد بن جبير: أعتكفُ بمكة؟ قال: لا، أنت معتكف ما أقمت؛ قال الله: <q>﴿سواء العاكف فيه والباد﴾</q>{14}. (١٠/٤٤٩) ٥٠٣٠١- عن مجاهد بن جبر -من طريق منصور- في الآية، قال: الناس بمكة سواء، ليس أحد أحق بالمنازل من أحد{15}. (١٠/٤٤٩) ٥٠٣٠٢- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿سواء العاكف فيه﴾</q>: يعني: الساكن بمكة، <q>﴿والباد﴾</q> يعني: الجانب. يقول: حق الله ﷿ عليهما سواء{16}. (ز) ٥٠٣٠٣- عن مجاهد بن جبر -من طريق ابن مجاهد-: <q>﴿العاكف فيه﴾</q> الساكن فيه، <q>﴿والباد﴾</q> الجانب، يعني: من يعتقبه، أي: الذي ينتابه مِن الناس للحج والعمرة، سواء في حرمه ومناسكه وحقوقه{17}. (ز) ٥٠٣٠٤- عن مجاهد بن جبر= (ز) ٥٠٣٠٥- وعطاء [بن أبي رباح] -من طريق جابر- <q>﴿سواء العاكف فيه﴾</q> قالا: من أهله، <q>﴿والباد﴾</q> الذي يأتونه من غير أهله، هما في حرمته سواء{18}. (١٠/٤٤٨) ٥٠٣٠٦- عن أبي صالح [باذام] -من طريق عنبسة، عمَّن ذَكَره-: <q>﴿سواء العاكف فيه والباد﴾</q>، العاكف: أهله. والباد: المنتاب في المنزل سواء{19}. (ز) ٥٠٣٠٧- عن عطاء [بن أبي رباح] -من طريق عبد الملك- قال: الناس في البيت سواء{20}. (ز) ٥٠٣٠٨- قال الحسن البصري، في قوله: <q>﴿سواء العاكف فيه والباد﴾</q>: أي: في تعظيم حُرمَتِه، وقضاء النُّسُك فيه{21}. (ز) ٥٠٣٠٩- عن قتادة بن دعامة -من طريق سعيد- في الآية، قال: سواء في جواره وأمنه وحرمته؛ <q>﴿العاكف فيه﴾</q> أهل مكة، <q>﴿والباد﴾</q> مَن يعتكفه مِن أهل الآفاق{22}. (١٠/٤٤٩) ٥٠٣١٠- عن [عبد الرحمن] بن سابط -من طريق يزيد بن أبي زياد- في قوله: <q>﴿سواء العاكف فيه والباد﴾</q>، قال: كان الحُجّاج إذا قدموا مكة لم يكن أحدٌ مِن أهل مكة بأحقَّ بمنزله منهم، وكان الرجلُ إذا وجد سَعَةً نزل، ففشا فيهم السرقة، وكل إنسان يسرق من ناحيته، فاصطنع رجل بابًا، فأرسل إليه عمر: أتَّخَذْتَ بابًا مِن حُجّاج بيت الله؟ فقال: لا، إنّما جعلته ليحرز متاعهم. وهو قوله: <q>﴿سواء العاكف فيه والباد﴾</q>. قال: الباد فيه كالمقيم، ليس أحد أحقُّ بمنزله من أحد، إلا أن يكون أحد سبق إلى منزل{23}. (١٠/٤٥١) ٥٠٣١١- تفسير إسماعيل السُّدِّيّ: <q>﴿والباد﴾</q>، يعني: أهل مكة، هم في بيوتها شرع{24} سواء{25}. (ز) ٥٠٣١٢- قال مقاتل بن سليمان: <q>﴿الذي جعلناه للناس سواء العاكف فيه﴾</q> يعني: المقيم في الحرم، وهم أهل مكة، <q>﴿والباد﴾</q> يعني: مَن دخل مكة مِن غير أهلها{2}. (ز) ٥٠٣١٣- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿سواء العاكف فيه والباد﴾</q>، قال: العاكف فيه: المقيم بمكة. والباد: الذي يأتيه، هم فيه سواء في البيوت{19}. (ز) ٥٠٣١٤- قال يحيى بن سلّام: <q>﴿والمسجد الحرام الذي جعلناه للناس﴾</q> قبلة ونسكا، قوله: <q>﴿سواء العاكف فيه﴾</q> الساكن فيه{3}٤٤٥٠. (ز) ٤٤٥٠ أفادت الآثارُ اختلاف المفسرين في معنى: <q>﴿سَواءً العاكِفُ فِيهِ والبادِ﴾</q>؛ فقيل: إن العاكف والبادي يستويان في سكنى مكة والنزول بها، فليس أحدُهما أحقَّ بالمنزل من الآخر. وقيل: إنهما يستويان في تفضيله، وحرمته، وإقامة المناسك به. ورجَّح ابنُ جرير (١٦/٥٠٣) مستندًا إلى دلالة السياق القول الثاني، وهو قول مجاهد من طريق ابن أبي نجيح، وابن مجاهد، وعطاء، وعلَّل ذلك قائلًا: «لأنّ الله -تعالى ذِكْره- ذَكَر في أول الآية صدَّ مَن كَفَر به مَن أراد مِن المؤمنين قضاء نسكه في الحرم عن المسجد الحرام، فقال: <q>﴿إنَّ الَّذِينَ كَفَرُوا ويَصُدُّونَ عَنْ سَبِيلِ اللَّهِ والمَسْجِدِ الحَرامِ﴾</q>، ثم ذَكَر -جلَّ ثناؤه- صفة المسجد الحرام، فقال: <q>﴿الَّذِي جَعَلْناهُ لِلنّاسِ﴾</q>، فأخبر -جلَّ ثناؤه- أنه جعله للناس كلهم، والكافرون به يمنعون مَن أراده من المؤمنين به عنه، ثم قال: <q>﴿سَواءً العاكِفُ فِيهِ والبادِ﴾</q>، فكان معلومًا أنّ خبره عن استواء العاكف فيه والباد إنما هو في المعنى الذي ابتدأ اللهُ الخبر عن الكفار أنهم صدوا عنه المؤمنين به، وذلك لا شك طوافهم، وقضاء مناسكهم به، والمقام، لا الخبر عن ملكهم إيّاه وغير ملكهم». <q>﴿ٱلَّذِی جَعَلۡنَـٰهُ لِلنَّاسِ سَوَاۤءً ٱلۡعَـٰكِفُ فِیهِ وَٱلۡبَادِۚ﴾</q> - آثار متعلقة بالآية ٥٠٣١٥- عن ابن عمرو مرفوعًا: «مَن أكل كِراءَ بيوتِ مكة أكل نارًا»{29}. (١٠/٤٥٢) ٥٠٣١٦- عن ابن عمر، أنّ النبيَّ ﷺ قال: «مكة مباحة؛ لا تُؤَجَّر بيوتها، ولا تُباع رِباعُها{30}»{31}. (١٠/٤٥١) ٥٠٣١٧- عن عمر بن الخطاب، أنّ رجلًا قال له عند المروة: يا أمير المؤمنين، أقْطِعْنِي مكانًا لي ولِعَقِبِي. فأعرض عنه عمر، وقال: هو حَرَمُ الله، <q>﴿سواء العاكف فيه والباد﴾</q>{32}. (١٠/٤٥٠) ٥٠٣١٨- عن ابن عمر: أنّ عمر نهى أن تُغْلَق أبواب دور مكة؛ فإن الناس كانوا ينزلون منها حيث وُجِدُوا، حتى كانوا يضرِبون فساطِيطَهم في الدور{12}. (١٠/٤٥٠) <q>﴿وَمَن یُرِدۡ فِیهِ بِإِلۡحَادِۭ بِظُلۡمࣲ نُّذِقۡهُ مِنۡ عَذَابٍ أَلِیمࣲ ۝٢٥﴾</q> - نزول الآية ٥٠٣١٩- عن عبد الله بن عباس -من طريق سعيد بن جبير- قال: نزلت هذه الآيةُ في عبد الله بن أنيس؛ أنّ رسول الله ﷺ بعثه مع رجلين، أحدهما مهاجر، والآخر من الأنصار، فافتخروا في الأنساب، فغضب عبد الله بن أنيس، فقتل الأنصاريَّ، ثم ارْتَدَّ عن الإسلام، وهرب إلى مكة؛ فنزلت فيه: <q>﴿ومن يرد فيه بإلحاد بظلم﴾</q>{34}. (١٠/٤٥٣) ٥٠٣٢٠- قال مقاتل بن سليمان: نزلت في عبد الله بن أنس{35} بن خطل القرشي من بني تيم بن مُرَّة، وذلك أنّ رسول الله ﷺ بعث عبد الله مع رجلين؛ أحدهما مهاجر، والآخر مِن الأنصار، فافتخروا في الأنساب، فغضب ابن خطل، فقتل الأنصاريَّ، ثم هرب إلى مكة كافرًا، ورجع المهاجرُ إلى المدينة، فأمر النبيُّ ﷺ بقتل عبد الله يوم فتح مكة، فقتله أبو بَرْزَة الأسلمي، وسعد بن حُرَيْث القرشي أخو عمرو بن حريث{2}. (ز) <q>﴿وَمَن یُرِدۡ فِیهِ بِإِلۡحَادِۭ بِظُلۡمࣲ نُّذِقۡهُ مِنۡ عَذَابٍ أَلِیمࣲ ۝٢٥﴾</q> - تفسير الآية ٥٠٣٢١- عن عبد الله بن مسعود، رفعه -من طريق مرة- في قوله: <q>﴿ومن يرد فيه بالحاد بظلم﴾</q>، قال: «لو أنّ رجلا هَمَّ فيه بإلحاد وهو بعَدَن أبْيَن؛ لأذاقه الله تعالى عذابًا أليمًا»{37}. (١٠/٤٥٢) ٥٠٣٢٢- عن عبد الله بن مسعود -من طريق مُرَّة- قال: مَن هَمَّ بسيئة لم تُكْتَب عليه حتى يعملها، ولو أنّ رجلًا كان بعدن أبْيَن حدَّث نفسه بأن يلحد في البيت -والإلحاد فيه: أن يَسْتَحِلَّ فيه ما حَرَّم الله عليه-، فمات قبل أن يصل إلى ذلك؛ أذاقه اللهُ مِن عذاب أليم{38}. (١٠/٤٥٧) ٥٠٣٢٣- عن عبد الله بن مسعود -من طريق مُرَّة- في قوله: <q>﴿ومن يرد فيه بإلحاد بظلم نذقه من عذاب أليم﴾</q>، قال: مَن هَمَّ بخطيئة فلم يعملها في سوى البيت لم تُكْتَب عليه حتى يعملها، ومَن هَمَّ بخطيئة في البيت لم يُمِتْهُ الله مِن الدنيا حتى يذيقه مِن عذاب أليم{39}. (١٠/٤٥٣) ٥٠٣٢٤- عن عبد الله بن عمرو بن العاص -من طريق فاطمة السهمية- أنّه قال: الإلحاد: ظلم الخادم، فما فوق ذلك{40}. (ز) ٥٠٣٢٥- عن عبد الله بن عباس -من طريق سعيد بن جبير- قال: <q>﴿ومن يرد فيه بإلحاد بظلم﴾</q>، يعني: من لجأ إلى الحرم، <q>﴿بإلحاد﴾</q>، يعني: بمَيْل عن الإسلام{41}. (١٠/٤٥٣) ٥٠٣٢٦- عن عبد الله بن عباس -من طريق علي- في قوله: <q>﴿ومن يرد فيه بإلحاد بظلم﴾</q>، قال: بشِرْك{42}. (١٠/٤٥٤) ٥٠٣٢٧- عن عبد الله بن عباس -من طريق العوفي- في قوله: <q>﴿ومن يرد فيه بإلحاد بظلم﴾</q>، قال: أن تَسْتَحِلَّ مِن الحرام ما حَرَّم الله عليك؛ من لِسان، أو قتل، فتظلم مَن لا يظلمك، وتقتل مَن لا يقتلك، فإذا فعل ذلك فقد وجب له عذاب أليم{43}. (١٠/٤٥٤) ٥٠٣٢٨- قال عبد الله بن عباس -من طريق ابن جريج- <q>﴿بإلحاد بظلم﴾</q>، قال: الذي يريد استحلاله مُتَعَمِّدًا{44}. (ز) ٥٠٣٢٩- عن الربيع بن أنس، في قوله: <q>﴿ومن يرد فيه بإلحاد بظلم نذقه من عذاب أليم﴾</q>، قال: حدَّثنا رجلٌ سَمِعَه مِن عقب المهاجرين والأنصار أنّهم أخبروه: أنّ أيَّما أحدٍ أراد به ما أراد أصحابُ الفيل عجَّل لهم العقوبة في الدنيا. وقال: إنّما يؤتى استحلاله مِن قِبَل أهله. فأخبرني عنهم: أنّه وجد سطران بمكة مكتوبان في المقام؛ أما أحدهما فكتابته: بسم الله، والبركة، وضعتُ بيتي بمكة، طعام أهله اللحم والسمن والتمر، ومَن دخله كان آمنًا، لا يُحِلُّه إلا أهله. قال: لولا أنّ أهله هم الذين فعلوا به ما قد علمت لعجل لهم في الدنيا العذاب. قال: ثم أخبرني أن عبد الله بن عمرو بن العاص قال قبل أن يُستحَلَّ منه الذي استُحِلَّ، قال: أجده مكتوبًا في الكتاب الأول: عبدُ اللهِ يُسْتَحَلُّ بِه الحرمُ. وعنده عبد الله بن عمر بن الخطاب، وعبد الله بن الزبير، فقال عبد الله بن عمرو بن العاص، وعبد الله بن عمر بن الخطاب، قال كل واحد منهما: لستُ قارِبَه إلا حاجًّا أو معتمرًا، أو حاجة لا بُدَّ منها. وسكت عبد الله بن الزبير فلم يقل شيئًا، فاستُحِلَّ مِن بعد ذلك{9}. (١٠/٤٥٧) ٥٠٣٣٠- عن سعيد بن جبير، في الآية، قال: شَتْمُ الخادمِ في الحرم ظلمٌ، فما فوقه{9}. (١٠/٤٥٦) ٥٠٣٣١- عن مجاهد -من طريق القاسم بن أبي بزة- في قوله: <q>﴿ومن يرد فيه بإلحاد بظلم﴾</q>، قال: هو أن يُعْبَد فيه غير الله{43}. (١٠/٤٥٤) ٥٠٣٣٢- عن مجاهد -من طريق ابن أبي نجيح- <q>﴿ومن يرد فيه بإلحاد بظلم﴾</q>، قال: من يعمل فيه عملًا سَيِّئًا{48}. (١٠/٤٥٨) ٥٠٣٣٣- عن الضحاك بن مُزاحِم -من طريق فضيل بن غزوان- في قوله: <q>﴿ومن يرد فيه بإلحاد﴾</q>، قال: إنّ الرجل لَيَهِمَّ بالخطيئة بمكة، وهو بأرض أخرى، فتكتب عليه، وما عملها{49}. (١٠/٤٥٨) ٥٠٣٣٤- عن الضحاك بن مزاحم: هو أن تقتل فيه مَن لا يقتلك، أو تظلم فيه مَن لا يظلمك{50}. (ز) ٥٠٣٣٥- عن عطاء بن أبي رباح، <q>﴿ومن يرد فيه بإلحاد بظلم﴾</q>، قال: القَتْل، والشِّرْك{51}. (١٠/٤٥٨) ٥٠٣٣٦- عن عطاء [بن أبي رباح] -من طريق ابن أبي ليلى- قال: <q>﴿ومن يرد فيه بإلحاد﴾</q> يَعْبُد غيرَ الله{17}. (ز) ٥٠٣٣٧- عن ابن أبي مليكة، أنّه سُئِل عن قوله: <q>﴿ومن يرد فيه بإلحاد بظلم﴾</q>. قال: ما كُنّا نشكُّ أنها الذنوب، حتى جاء أعلاجٌ مِن أهل البصرة إلى أعلاجٍ مِن أهل الكوفة، فزعموا أنها الشِّرك{12}. (١٠/٤٥٨) ٥٠٣٣٨- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿ومن يرد فيه بإلحاد﴾</q>، قال: مَن لَجَأَ إلى الحرم لِيُشْرِك فيه عَذَّبه الله{54}. (١٠/٤٥٤) ٥٠٣٣٩- عن إسماعيل السُّدِّيّ -من طريق يحيى بن أبي أنيسة- قال: الإلحاد: الاستحلال، فإن قوله: <q>﴿ومن يرد فيه بإلحاد﴾</q> يعني: الظلم فيه، فيقول: مَن يستحله ظالِمًا فيعتدي فيه، فيُحلّ فيه ما حرّم الله{55}. (ز) ٥٠٣٤٠- قال إسماعيل السُّدِّيّ: إلا أن يتوب{56}. (ز) ٥٠٣٤١- عن حبيب بن أبي ثابت -من طريق أشعث- في قوله: <q>﴿ومن يرد فيه بإلحاد بظلم﴾</q>، قال: هم المُحْتَكِرون الطعام بمكة{44}. (١٠/٤٥٤) ٥٠٣٤٢- عن سليمان التيمي -من طريق ابنه المعتمر- قال: <q>﴿ومن يرد فيه بإلحاد بظلم﴾</q>، قال: هو الشِّرْك، مَن أشْرَك في بيت الله عَذَّبه الله{43}. (ز) ٥٠٣٤٣- عن أبي الحجّاج، في الآية، قال: إنّ الرَّجُلَ يُحَدِّث نفسَه أن يعمل ذنبًا بمكة، فيكتبه الله عليه ذنبًا{12}. (١٠/٤٥٩) ٥٠٣٤٤- قال مقاتل بن سليمان: <q>﴿ومن يرد فيه بإلحاد بظلم﴾</q> يقول: مَن لجأ إلى الحرم يميل فيه بشِرْك؛ <q>﴿نذقه من عذاب أليم﴾</q> يعني: وجيعًا{2}. (ز) ٥٠٣٤٥- تفسير محمد بن السائب الكلبي: الإلحاد: المَيْل عن عبادة الله إلى الشرك{25}. (ز) ٥٠٣٤٦- عن عبد الملك ابن جُرَيْج -من طريق سعيد بن سالم- في قوله: <q>﴿ومن يرد فيه بإلحادٍ بظلمٍ نذقه من عذاب أليم﴾</q> استحلالًا مُتَعَمِّدًا{62}. (ز) ٥٠٣٤٧- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قول الله: <q>﴿ومن يرد فيه بإلحاد بظلم نذقه من عذاب أليم﴾</q>، قال: الإلحاد: الظُّلْم في الحرم{44}. (ز) ٥٠٣٤٨- قال يحيى بن سلّام: قوله: <q>﴿ومن يرد فيه بإلحاد بظلم﴾</q> أي: بشِرك؛ <q>﴿نذقه من عذاب أليم﴾</q>{64}٤٤٥١. (ز) ٤٤٥١ أفادت الآثارُ اختلاف المفسرين في معنى: «الإلحاد بظلم» على أقوال: الأول: أنّه الشرك بالله بأن يُعبَد فيه غيرُ الله. الثاني: أنّه استحلال الحرام فيه أو فعله. الثالث: استحلال الحَرَم مُتَعَمِّدًا. الرابع: أنّه احتكار الطعام بمكة. الخامس: أنّه كل ما كان منهيًّا عنه مِن الفعل، حتى قول القائل: لا والله، وبلى والله. ورجَّح ابنُ جرير (١٦/٥١٠) مستندًا إلى دلالة العموم القول الثاني، وهو قول ابن عباس، وابن مسعود، ومجاهد من طريق ابن أبي نجيح، والضحاك، وابن زيد، وبيَّن علَّة ذلك بقوله: «وأولى الأقوال التي ذكرناها في تأويل ذلك بالصواب القولُ الذي ذكرناه عن ابن مسعود، وابن عباس، مِن أنه معنيٌّ بالظلم في هذا الموضع: كل معصية لله. وذلك أنّ الله عمَّ بقوله: <q>﴿ومَن يُرِدْ فِيهِ بِإلْحادٍ بِظُلْمٍ﴾</q> ولم يَخْصُصْ به ظلمًا دون ظلم في خبر ولا عقل؛ فهو على عمومه». وبيَّن ابنُ عطية (٦/٢٣٤-٢٣٥) عموم معنى الإلحاد لكل تلك الأقوال، فقال بعد سرده الأقوال الواردة في تفسير الإلحاد: «والعموم يأتي على هذا كله». وكذا ابنُ كثير (١٠/٤٠)، فقال: «وهذه الآثار وإن دلت على أنّ هذه الأشياء من الإلحاد، ولكن هو أعم من ذلك». <q>﴿وَمَن یُرِدۡ فِیهِ بِإِلۡحَادِۭ بِظُلۡمࣲ نُّذِقۡهُ مِنۡ عَذَابٍ أَلِیمࣲ ۝٢٥﴾</q> - آثار متعلقة بالآية ٥٠٣٤٩- عن يعلى بن أمية، عن رسول الله ﷺ، قال: «احتكار الطعام في الحرم إلحادٌ فيه»{65}. (١٠/٤٥٤) ٥٠٣٥٠- عن عبد الله بن عمر، قال: سمعتُ رسول الله ﷺ يقول: «احتكار الطعام بمكة إلحاد»{66}. (١٠/٤٥٥) ٥٠٣٥١- عن عمر بن الخطاب، قال: احتكار الطعام بمكة إلحاد بظلم{67}. (١٠/٤٥٥) ٥٠٣٥٢- عن عمر بن الخطاب -من طريق إسماعيل بن أُمَيَّة- قال: لَأن أُخْطِىء سبعينَ خطيئة برُكْبَة{68} أحبُّ إلَيَّ مِن أن أخطىء خطيئة واحدة بمكة{69}. (١/٦٥١) ٥٠٣٥٣- عن مجاهد، قال: رأيتُ عبد الله بن عمرو بعرفة ومنزله في الحِلِّ ومسجده في الحرم، فقلتُ له: لِمَ تفعل هذا؟ قال: لأنّ العمل فيه أفضل، والخطيئة فيه أعظم{70}. (١٠/٤٥٩) ٥٠٣٥٤- عن عبد الله بن عباس، قال: تجارة الأمير بمكة إلحاد{71}. (١٠/٤٥٦) ٥٠٣٥٥- عن عبد الله بن عباس -من طريق عبيد بن عمير- قال: أقبل تُبَّع يريد الكعبة، حتى إذا كان بكُراع الغَمِيم{72} بعث الله تعالى عليه ريحًا لا يكاد القائم يقوم إلا بمشقة، ويذهب القائم يقعد فيُصْرَع، وقامت عليه، ولقوا منها عناء، ودعا تُبَّعٌ حَبْرَيه، فسألهما: ما هذا الذي بُعِثَ عَلَيَّ؟ قالا: أوَتُؤَمِّنّا؟ قال: أنتم آمنون. قالا: فإنّك تريد بيتًا يمنعه الله مِمَّن أراده. قال: فما يُذهِب هذا عَنِّي؟ قالا: تَجَرَّد في ثوبين، ثم تقول: لبيك اللهم لبيك، ثم تدخل فتطوف به فلا تُهَيِّج أحدًا من أهله. قال: فإن أجمعتُ على هذا ذَهَبَتْ هذه الريحُ عَنِّي؟ قالا: نعم. فتَجَرَّد، ثُمَّ لَبّى، فأدبرت الريح كقطع الليل المظلم{73}. (١٠/٤٥٦) ٥٠٣٥٦- عن عبد الله بن عمر، قال: بيع الطعام بمكة إلحاد{74}. (١٠/٤٥٥) ٥٠٣٥٧- عن عبد الله بن عمر، قال: إنّ قولك في الحرم: كلا واللهِ، وبلى واللهِ؛ كاذبًا؛ إلحادٌ فيه{75}. (١٠/٤٥٦) ٥٠٣٥٨- عن مجاهد، قال: كان لعبد الله بن عمر فُسْطاطان؛ أحدهما في الحِل، والآخر في الحَرَم، فإذا أراد أن يُصَلِّي صلّى في الذي في الحرم، وإذا أراد أن يعاتب أهله عاتبهم في الذي في الحِل. فقيل له، فقال: كنا نُحَدَّث: أنّ مِن الإلحاد فيه أن يقول الرجل: كلا والله، وبلى والله{76}. (١٠/٤٥٥) ٥٠٣٥٩- عن مجاهد بن جبر، قال: تُضاعَف السيئات بمكة كما تُضاعَف الحسنات{77}. (١/٦٥١، ١٠/٤٥٨) ٥٠٣٦٠- عن مجاهد بن جبر -من طريق عثمان بن الأسود- قال: بيع الطعام بمكة إلحاد، وليس الجالب كالمقيم{78}. (ز) ٥٠٣٦١- عن عكرمة، قال: ما مِن عبد يَهِمُّ بذنب فيؤاخذه الله بشيء حتى يعمله، إلّا مَن هَمَّ بالبيت العتيق شَرًّا؛ فإنّه مَن همَّ به شَــــــرّا عجَّل الله له{12}. (١٠/٤٥٨) ٥٠٣٦٢- عن عبد الملك ابن جُرَيْج -من طريق مسلم بن خالد- قال: بلغني: أنّ الخطيئة بمكة مائة خطيئة، والحسنة على نحو ذلك{80}. (١/٦٥١) ",footnotes:1:علَّقه يحيى بن سلام ١/٣٦١.تفسير مقاتل بن سليمان ٣/١٢١.تفسير يحيى بن سلام ١/٣٦١.عزاه السيوطي إلى عبد حميد.أخرجه الفاكهي في أخبار مكة ٢/١٠٦ (١٢٢٥).تفسير مقاتل بن سليمان ٣/١٢١.تفسير يحيى بن سلام ١/٣٦١.أخرجه الطبراني في الكبير ١٢/٦٧ (١٢٤٩٦). وأورده الديلمي في الفردوس ٢/٣٣٦ (٣٥١٦). قال الهيثمي في المجمع ٧/٧٠ (١١١٨٣): «وفيه عبد الله بن مسلم بن هرمز، وهو ضعيف». وقال السيوطي: «بسند صحيح».عزاه السيوطي إلى ابن أبي حاتم.عزاه السيوطي إلى ابن أبي حاتم.أخرجه ابن جرير ١٦/٥٠٢. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.عزاه السيوطي إلى عبد بن حميد.أخرجه ابن أبي شيبة ٤/٧٩.أخرجه ابن جرير ١٦/٥٠٢. وعزاه السيوطي إلى عبد بن حميد.أخرجه ابن أبي شيبة ٤/٧٩ بلفظ: أهل مكة وغيرهم في المنازل سواء، وابن جرير ١٦/٥٠٢ بنحوه. وعزاه السيوطي إلى عبد بن حميد.تفسير مجاهد ص٤٧٨، وأخرجه ابن جرير ١٦/٥٠٣.أخرجه يحيى بن سلام ١/٣٦٢.أخرجه ابن جرير ١٦/٥٠٣. وأورده السيوطي مختصرًا بلفظ: سواء في تعظيم البلد وتحريمه. وعزاه إلى عبد بن حميد أيضًا.أخرجه ابن جرير ١٦/٥٠٢.أخرجه ابن أبي شيبة (ت: محمد عوامة) ٨/٧٣٩ (١٥٨٨٢).تفسير البغوي ٥/٣٧٦.أخرجه البيهقي في شعب الإيمان (٤٠١٥). وعلَّقه يحيى بن سلام ١/٣٦٢. وعزاه السيوطي إلى عبد بن حميد. وأخرج عبد الرزاق ٢/٣٤، وابن جرير ١٦/٥٠٢، تفسير هذه الآية عن قتادة من طريق معمر، بلفظ: سواء فيه أهله، وغير أهله. وفي تفسير البغوي ٥/٣٧٧، عنه: هما سواء في البيوت والمنازل.أخرجه ابن جرير ١٦/٥٠١، وابن أبي شيبة ٤/٧٩-٨٠ مختصرًا، بلفظ: البادي الذي يجيء من الحج والمقيمون؛ سواء في المنازل، ينزلون حيث شاءوا، ولا يَخْرُج رجل من بيته.كذا في المصدر.علَّقه يحيى بن سلام ١/٣٦٢.تفسير مقاتل بن سليمان ٣/١٢١.أخرجه ابن جرير ١٦/٥٠٢.تفسير يحيى بن سلام ١/٣٦١.أخرجه الأزرقي في أخبار مكة ٢/١٦٣، والدار قطني في سننه ٤/١٣ (٣٠١٦). قال الألباني في الضعيفة ٥/٢٠٨ (٢١٨٦): «ضعيف».رِباعها: منازلها. اللسان (ربع).عزاه السيوطي إلى ابن مردويه.أخرجه ابن سعد ٥/٤٦٥.عزاه السيوطي إلى عبد بن حميد.أخرجه ابن أبي حاتم -كما في تفسير ابن كثير ٥/٤١٢-، من طريق ابن لهيعة، عن عطاء بن دينار، عن سعيد بن جبير، عن ابن عباس به. وسنده ضعيف، فيه عبد الله بن لهيعة، وهو ضعيف كما في الميزان ٢/٤٧٥.كذا في المصدر، والمشهور أنه عبد الله بن خَطَل.تفسير مقاتل بن سليمان ٣/١٢١.أخرجه أحمد ٧/١٥٥ (٤٠٧١)، والحاكم ٢/٤٢٠ (٣٤٦١)، وابن جرير ١٦/٥٠٨، وابن أبي حاتم -كما في تفسير ابن كثير ٥/٤١١-، من طريق شعبة، عن السدي، عن مرة، عن عبد الله به. قال الحاكم: «هذا حديث صحيح، على شرط مسلم، ولم يخرجاه». ووافقه الذهبي. وقال ابن كثير: «هذا الإسناد صحيح، على شرط البخاري، ووقفه أشبه من رفعه؛ ولهذا صَمَّم شعبةُ على وقفه مِن كلام ابن مسعود، وكذلك رواه أسباط، وسفيان الثوري، عن السدي، عن مرة، عن ابن مسعود موقوفًا». وأورده الدارقطني في العلل الواردة في الحديث ٥/٢٦٩ (٨٧١).أخرجه ابن جرير ١٦/٥٠٨. وعزاه السيوطي إلى ابن أبي شيبة، وعبد بن حميد، وابن المنذر، وابن أبي حاتم.أخرجه الطبراني (٩٠٧٨). وعزاه السيوطي إلى سعيد بن منصور.أخرجه عبد الله بن وهب في الجامع ١/١٢٩-١٣٠ (٢٩٨).أخرجه ابن أبي حاتم -كما في تفسير ابن كثير ٥/٤٠٨-.أخرجه ابن جرير ١٦/٥٠٧. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.أخرجه ابن جرير ١٦/٥٠٧.أخرجه ابن جرير ١٦/٥٠٩.عزاه السيوطي إلى ابن أبي حاتم.عزاه السيوطي إلى ابن أبي حاتم.أخرجه ابن جرير ١٦/٥٠٧.أخرجه ابن جرير ١٦/٥٠٨. وعزاه السيوطي إلى ابن أبي شيبة، وعبد بن حميد، وابن المنذر.أخرجه ابن جرير ١٦/٥٠٨-٥٠٩. وعزاه السيوطي إلى ابن أبي شيبة، وابن المنذر.تفسير البغوي ٥/٣٧٧.عزاه السيوطي إلى سعيد بن منصور، وعبد بن حميد، وابن المنذر.أخرجه يحيى بن سلام ١/٣٦٢.عزاه السيوطي إلى عبد بن حميد.أخرجه عبد الرزاق ٢/٣٤، ويحيى بن سلام ١/٣٦٢، وابن جرير ١٦/٥٠٧، والبيهقي في شعب الإيمان (٤٠١٥).أخرجه الأزرقي في أخبار مكة ٢/٦٩٦.تفسير البغوي ٥/٣٧٨.أخرجه ابن جرير ١٦/٥٠٩.أخرجه ابن جرير ١٦/٥٠٧.عزاه السيوطي إلى عبد بن حميد.تفسير مقاتل بن سليمان ٣/١٢١.علَّقه يحيى بن سلام ١/٣٦٢.أخرجه الأزرقي في أخبار مكة ٢/٦٩٥.أخرجه ابن جرير ١٦/٥٠٩.تفسير يحيى بن سلام ١/٣٦٢.أخرجه أبو داود ٣/٣٦٩ (٢٠٢٠). قال ابن القطّان في بيان الوهم والإيهام ٥/٦٩ (٢٣١٥): «حديث لا يَصِح؛ لأن موسى بن باذان مجهول ... ولا يعرف روى عنه غير عمارة بن ثوبان، وهو روى عنه هذا الحديث. وعمارة أيضًا لا يعرف روى عنه غير ابن أخيه جعفر بن يحيى بن ثوبان، وهو روى عنه هذا الحديث، وجعفر أيضًا لا تعرف حاله. فهم كما ترى ثلاثة مجاهيل متتابعين في رواية هذا الحديث». وقال الذهبي في ميزان الاعتدال ١/٤٢٠ ترجمة جعفر بن يحيى ١٥٤٤: «حديث واهي الإسناد». وقال الألباني في ضعيف أبي داود ٢/١٩٢ (٣٤٦): «إسناده ضعيف؛ لجهالة ابن باذان فمَن دونه، وأعله البخاري بالوقف أيضًا، وأقرَّه المنذري».أخرجه الطبراني في الأوسط ٢/١٣٢-١٣٣ (١٤٨٥)، والبيهقي في شعب الإيمان ١٣/٥١٤-٥١٥ (١٠٧٠٨). قال الطبراني: «لم يرو هذا الحديث عن عطاء إلا ابن محيصن، تفرَّد به عبد الله بن المؤمل». وقال الهيثمي في المجمع ٤/١٠١ (٦٤٧٩): «رواه الطبراني في الأوسط، وفيه عبد الله بن المؤمل؛ وثَّقه ابن حبان وغيره، وضَعَّفه جماعة».أخرجه البخاري في تاريخه ٧/٢٥٥-٢٥٦. وعزاه السيوطي إلى سعيد بن منصور، وابن المنذر.ركبة: موضع بالحجاز. لسان العرب (ركب).أخرجه الأزرقي في تاريخ مكة ٢/١٣٤. وعزاه السيوطي إلى الجندي.أخرجه عبد الرزاق (٨٨٧٠). وعزاه السيوطي إلى عبد بن حميد.عزاه السيوطي إلى ابن أبي شيبة، وعبد بن حميد، وابن المنذر، وابن أبي حاتم.كُراع الغَمِيم: موضع بين مكة والمدينة. معجم البلدان ٤/٢١٤.أخرجه الحاكم ٢/٣٨٨.عزاه السيوطي إلى عبد بن حميد، وابن أبي حاتم.عزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.أخرجه ابن أبي شيبة (القسم الأول من الجزء الرابع) ص٢٨٥، وابن منيع -كما في المطالب (٤٠٤٧)-، وابن جرير ١٦/٥١٠. وعزاه السيوطي إلى سعيد بن منصور، وعبد بن حميد، وابن المنذر، وابن أبي حاتم، وابن مردويه.عزاه السيوطي إلى ابن أبي شيبة، وابن المنذر، والجندي.أخرجه سعيد بن منصور في سننه - التفسير ٦/٣٢٧ (١٤٧٦).عزاه السيوطي إلى عبد بن حميد.أخرجه الأزرقي في تاريخ مكة ٢/١٣٧.
22,26," <q>﴿وَإِذۡ بَوَّأۡنَا لِإِبۡرَ ٰ⁠هِیمَ﴾</q> - تفسير ٥٠٣٦٣- قال عبد الله بن عباس، في قوله: <q>﴿وإذ بوأنا﴾</q>: جعلنا{1}. (ز) ٥٠٣٦٤- قال الحسن البصري، في قوله: <q>﴿وإذ بوأنا﴾</q>: أنزلنا{1}. (ز) ٥٠٣٦٥- قال مقاتل بن سليمان: قوله ﷿: <q>﴿وإذ بوأنا لإبراهيم مكان البيت﴾</q> المعمور. قال: دَلَلْنا إبراهيم عليه{3}. (ز) ٥٠٣٦٦- قال مقاتل بن حيان: هيَّأنا{4}. (ز) ٥٠٣٦٧- قال يحيى بن سلّام: <q>﴿وإذ بوأنا لإبراهيم مكان البيت﴾</q>، يقول: أعلمناه{5}. (ز) <q>﴿وَإِذۡ بَوَّأۡنَا لِإِبۡرَ ٰ⁠هِیمَ مَكَانَ ٱلۡبَیۡتِ أَن لَّا تُشۡرِكۡ بِی شَیۡـࣰٔا﴾</q> - تفسير ٥٠٣٦٨- عن علي [بن أبي طالب] -من طريق حارثة بن مُضَرِّب- قال: لَمّا أُمِر إبراهيمُ ببناء البيت خرج معه إسماعيلُ وهاجر، فلمّا قدِم مكة رأى على رأسه في موضع البيت مثلَ الغمامة، فيه مثل الرأس، فكلَّمه، فقال: يا إبراهيم، ابْنِ على ظِلِّي -أو: على قدْرِي-، ولا تزِد ولا تنقص. فلمّا بنى خرج، وخلَّف إسماعيلَ وهاجر، وذلك حين يقول الله: <q>﴿واذ بوأنا لإبراهيم مكان البيت﴾</q>الآية{6}٤٤٥٢. (١٠/٤٥٩) ٤٤٥٢ علَّق ابنُ كثير (١/٢٨٥) بقوله: «ففي هذا السياق أنه بنى البيت قبل أن يفارقهما، وقد يحتمل -إن كان محفوظًا- أن يكون أولًا وضع له حوطًا وتحجيرًا، لا أنّه بناه إلى أعلاه، حتى كبر إسماعيل فبنياه معًا، كما قال الله». ٥٠٣٦٩- قال ابن المسيب: قال ابن أبي طالب: أقبل إبراهيمُ والملَكُ والصُّرَد{7} والسكينةُ دليلًا حتى تَبَّوَؤُا البيت كما تتبوأ العنكبوت{8}. (ز) ٥٠٣٧٠- عن عبد الله بن عمرو بن العاص، قال: لَمّا كان زمنُ الطوفان رُفِع البيت، وكان الأنبياء يحُجُّونه ولا يعلمون مكانه، حتى بوَّأه الله لإبراهيم، وأعلمه مكانه{9}. (ز) ٥٠٣٧١- عن عبد الله بن عباس -من طريق سعيد بن المسيب- قوله ﷿: <q>﴿وإذ بوأنا لإبراهيم مكان البيت﴾</q>، قال: كان موضعُ البيت ربوةً بيضاء، حولها حجارة مرسومة، حولها حَرَجَة{10} مِن سَمُر{11} نابت، وهو قوله ﷿: <q>﴿وإذ بوأنا لإبراهيم مكان البيت﴾</q>{12}. (ز) ٥٠٣٧٢- عن مجاهد بن جبر -من طريق خُصَيْف- قال: قال إبراهيم: ربنا أرنا مناسكنا. فأخذ جبريل ﵇ بيده، فذهب به حتى أتى به البيت، قال: ارفع القواعد. فرفع إبراهيم القواعد، وأتَمَّ البنيان{13}. (١/٧١١) ٥٠٣٧٣- عن مجاهد بن جبر، قال: قال الله لإبراهيم ﵇: قُمْ، فابنِ لي بيتًا. قال: أيْ رَبِّ، أين؟ قال: سأخبرك. فبعث الله إليه سحابةً لها رأس، فقالت: يا إبراهيم، إنّ ربك يأمرك أن تَخُطَّ قَدْرَ هذه السحابة. قال: فجعل إبراهيمُ ينظر إلى السحابة ويخط، فقال الرأس: قد فعلتَ؟ قال: نعم. فارتفعت السحابة، فحفر إبراهيمُ، فأبرز عن أساس ثابت مِن الأرض، فبنى إبراهيم ...{14}. (١/٧١٤) ٥٠٣٧٤- عن أبي قلابة عبد الله بن زيد الجرمي -من طريق أيوب- أنّه بلغه: أنّ الله -تبارك وتعالى- لَمّا أهبط آدمَ إلى الأرض قال: إنِّي منزلٌ معك بيتًا يُطاف حوله كما يُطاف حول عرشي، فلما كان رأس الطوفان رفعه الله، فكانت الأنبياء بعد ذلك تَحُجُّه، يقومون قريبًا، ولا يدرون أين موضعه، فبوَّأه الله لإبراهيم، فبناه مِن خمسة أجْبُل: من ثَبِير، ولبنان، وجبل الحرى{15}، وطور سيناء{16}. (ز) ٥٠٣٧٥- عن عطاء بن أبي رباح -من طريق سوار- قال: لَمّا أهبط الله آدمَ كان رِجلاه في الأرض ورأسُه في السماء، يسمع كلام أهل السماء ودعاءَهم، فأنس إليهم، فهابت الملائكة منه حتى شَكَت إلى الله في دعائها وفي صلاتها، فأخفضه الله إلى الأرض، فلما فقد ما كان يسمع منهم استوحش حتى شكا إلى الله في دعائه وفي صلاته، فوُجِّه إلى مكة، فكان موضع قدمه قرية، وخطوه مفازة، حتى انتهى إلى مكة، فأنزل الله ياقوتةً مِن ياقوت الجنة، فكانت على موضع البيت الآن، فلم يزل يُطاف به حتى أنزل اللهُ الطوفان، فرُفِعت تلك الياقوتة، حتى بعث الله إبراهيم فبناه، فذلك قول الله: <q>﴿واذ بوأنا لابراهيم مكان البيت﴾</q>{17}. (١٠/٤٦٠) ٥٠٣٧٦- عن معمر، عن قتادة، قال: وضع الله البيتَ مع آدم حين أهبط اللهُ آدم إلى الأرض، وكان مهبطه بأرض الهند، وكان رأسه في السماء ورِجلاه في الأرض، وكانت الملائكة تهابه، فنقص إلى ستين ذراعًا، فحزن آدمُ إذ فَقَد أصوات الملائكة وتسبيحَهم، فشكا ذلك إلى الله، فقال الله: يا آدم، إنِّي قد أهْبَطتُ لك بيتًا يُطاف به كما يُطاف حول عرشي، ويُصَلّى عنده كما يُصَلّى عند عرشي، فاخرج إليه. فخرج اليه آدم، ومدَّ له في خطوه، فكان بين كل خطوتين مفازة، فلم تزل تلك المفاوز بَعْدُ على ذلك. وأتى آدمُ، فطاف به ومَن بعده مِن الأنبياء.= (ز) ٥٠٣٧٧- قال معمر: وأخبرني أبان أنّ البيت أُهْبِط ياقوتة واحدة، أو درة واحدة. قال معمر: وبلغني: أنّ سفينة نوح طافت بالبيت سبعًا، حتى اذا أغرق الله قوم نوح فُقِد، وبقِيَ أساسه، فبوَّأه الله لإبراهيم، فبناه بعد ذلك، فذلك قول الله: <q>﴿واذ بوأنا لإبراهيم مكان البيت﴾</q>.= (ز) ٥٠٣٧٨- قال مَعْمَر: قال ابن جُرَيج: قال ناس: أرسل اللهُ سبحانه سحابةً فيها رأس، فقال الرأس: يا إبراهيم، إنّ ربك يأمرك أن تأخذ قدر هذه السحابة. فجعل ينظر إليها، ويخط قدرها، قال الرأس: قد فعلتَ؟ قال: نعم. ثم ارْتَفَعَتْ، فحفر، فأبرز عن أساس ثابت في الأرض.= (ز) ٥٠٣٧٩- قال ابن جريج: قال مجاهد: أقبل الملَك والصُّرَد والسكينةُ مع إبراهيم من الشام، فقالت السكينة: يا إبراهيم، ربِّض على البيت. قال: فلذلك لا يطوف البيتَ أعرابيٌّ ولا ملِك مِن هذه الملوك إلا رأيت عليه السكينة والوقار.= (ز) ٥٠٣٨٠- قال ابن جريج: وقال ابن المسيب: قال علي بن أبي طالب: وكان اللهُ استودع الركن أبا قبيس، فلمّا بنى إبراهيمُ ناداه أبو قبيس، فقال: يا إبراهيم، هذا الركن فِيَّ، فخده{18}. فحفر عنه، فوضعه، فلمّا فرغ إبراهيمُ مِن بنائه قال: قد فعلتُ، يا رب، فأرِنا مناسكنا -أبرِزها لنا، وعلِّمناها-. فبعث الله جبريلَ، فحجَّ به، حتى إذا رأى عرفة قال: قد عرفتُ. وكان أتاها قبل ذلك مرَّة، قال: فلذلك سُمِّيَت: عرفة، حتى إذا كان يوم النحر عرض له الشيطان، فقال: احصِبْ. فحصبه بسبع حصيات، ثم اليوم الثاني، فالثالث، فسدَّ ما بين الجبلين -يعني: إبليس-، فلذلك كان رمي الجمار، قال: اعلُ على ثبير. فعلاه، فنادى: يا عباد الله، أجيبوا الله، يا عباد الله، أطيعوا الله. فسمع دعوته مَن بين الأبحر السَّبْعِ مِمَّن كان في قلبه مثقالُ ذَرَّة من الإيمان، فهي التي أعطى الله إبراهيمَ في المناسك، قوله: لبيك اللهم لبيك. ولم يَزَلْ على وجه الأرض سبعةٌ مسلمون فصاعدًا، فلولا ذلك هلكت الأرض ومَن عليها{19}. (١٠/٤٦١-٤٦٢) ٥٠٣٨١- عن قتادة بن دعامة -من طريق سعيد بن بشير- وذكر قول الله -تبارك وتعالى-: <q>﴿وإذ بوأنا لإبراهيم مكان البيت﴾</q>، قال: هذا حرم الله قد طاف به آدمُ ومَن بعده، فلما كان إبراهيم أراه الله تعالى مكانة البيت، فاتَّبَع منه أثرًا قديمًا، فبناه مِن طور زيتا، وطور سينا، ومن جبل لبنان{20}، [و]مِن{21} أُحُدٍ وحراء، وجعل قواعده من حراء، ثم قال: <q>﴿وأذن في الناس بالحج﴾</q>{22}. (ز) ٥٠٣٨٢- عن إسماعيل السُّدِّيّ، قال: إنّ الله ﷿ أمر إبراهيم أن يبني البيت هو وإسماعيل، فانطلق إبراهيمُ حتى أتى مكة، فقام هو وإسماعيل، وأخذا المعاوِل لا يدريان أين البيت، فبعث الله ريحًا يُقال لها: ريح الخَجُوج، لها جناحان ورأس في صورة حيَّة، فكَنَسَت لهما ما حول الكعبة من البيت الأول، واتَّبعاها بالمعاول يحفران حتى وضعا الأساس، فذلك حين يقول الله: <q>﴿واذ بوأنا لابراهيم مكان البيت﴾</q>، فلما بنيا القواعد، فبلغ مكان الركن؛ قال إبراهيم لإسماعيل: اطلب لي حجرا حسنًا أضعه ههنا. قال: يا أبت، إني كسلان لَغِبٌ. قال: عليَّ ذلك. فانطلق يطلب له حجرًا، فأتاه بحجر، فلم يَرْضَه، فقال: ائتني بحجر أحسنَ مِن هذا. فانطلق يطلب له حجرًا، فجاءه جبريل بالحجر الأسود مِن الجَنَّة، وكان أبيضَ ياقوتة بيضاء مثل الثَّغامَة{23}، وكان آدم هَبَط به مِن الجنة، فاسْوَدَّ مِن خطايا الناس، فجاءه إسماعيل بحجر، فوجد عنده الركن، فقال: يا أبتِ، مَن جاءك بهذا؟ قال: جاءني به مَن هو أنشط منك. فبينما هما يدعوان بالكلمات التي ابتلى بها إبراهيمَ ربُّه، فلمّا فرغا من البنيان أمره الله أن ينادي، فقال: أذِّن في الناس بالحج{24}٤٤٥٣. (١٠/٤٦٢) ٤٤٥٣ علَّقَ ابن كثير (٢/٨٤) على أثر السّدّيّ بقوله: «في هذا السياق ما يَدُلُّ على أن قواعد البيت كانت مبنية قبل إبراهيم، وإنما هُدِي إبراهيمُ إليها، وبُوِّئ لها». ٥٠٣٨٣- قال محمد بن السائب الكلبي: بعث الله سحابةً بقدر البيت، فقامت بحِيال البيت، وفيها رأسٌ يتكلم: يا إبراهيم، ابْنِ على قَدْري. فبنى عليه{25}. (ز) ٥٠٣٨٤- قال مقاتل بن سليمان: قوله ﷿: <q>﴿وإذ بوأنا لإبراهيم مكان البيت﴾</q> المعمور. قال: دَلَلْنا إبراهيم عليه، فبناه مع ابنه إسماعيل ﵉، وليس له أثرٌ ولا أساس، كان الطوفان محا أثرَه، ورفعه الله ﷿ ليالي الطوفان إلى السماء، فعَمَرته الملائكة، وهو البيت المعمور، قال الله ﷿ لإبراهيم: <q>﴿أن لا تشرك بي شيئا﴾</q>{3}٤٤٥٤. (ز) ٤٤٥٤ حكى ابنُ عطية (٦/٢٣٧) قولين في المخاطب بقوله تعالى: <q>﴿أنْ لا تُشْرِكْ بِي شَيْئًا﴾</q>: الأول: هي مخاطبة لإبراهيم ﵇. الثاني: هي مخاطبة لمحمد ﷺ، وأمر بتطهير البيت، والأذان بالحج. ورجَّح القول الأول قائلًا: «والجمهور على أنّ ذلك إبراهيم ﵇، وهو الأصح». ولم يذكر مستندًا. <q>﴿وَإِذۡ بَوَّأۡنَا لِإِبۡرَ ٰ⁠هِیمَ مَكَانَ ٱلۡبَیۡتِ أَن لَّا تُشۡرِكۡ بِی شَیۡـࣰٔا﴾</q> - آثار متعلقة بالآية ٥٠٣٨٥- عن عائشة، قالت: قال رسول الله ﷺ: «دُثِرَ مكانُ البيت، فلم يَحُجَّه هودٌ، ولا صالح، حتى بوَّأه الله لإبراهيم»{27}. (١٠/٤٥٩) <q>﴿وَطَهِّرۡ بَیۡتِیَ﴾</q> - تفسير ٥٠٣٨٦- عن علقمة ابن أم علقمة مولاة عائشة، عن أمه، عن عائشة، قالت: كسوة البيت على الأمراء، ولكن طَيِّبوا البيت؛ فإنّ ذلك مِن تطهيره{28}. (ز) ٥٠٣٨٧- عن عبيد بن عمير -من طريق عطاء- قال: مِن الآفات، والريب{29}. (ز) ٥٠٣٨٨- عن مجاهد بن جبر -من طريق ليث- في قوله: <q>﴿وطهر بيتي﴾</q>، قال: مِن الشِّرك{29}. (ز) ٥٠٣٨٩- عن قتادة بن دعامة -من طريق مَعْمَر- <q>﴿طهرا بيتي﴾</q> [البقرة:١٢٥]، قال: مِن الشِّرك، وعبادة الأوثان{31}٤٤٥٥. (ز) ٤٤٥٥ لم يذكر ابنُ جرير (١٦/٥١٢-٥١٣) في معنى: <q>﴿وطَهِّرْ بَيْتِيَ﴾</q> سوى قول مجاهد، وعبيد بن عمير، وقتادة من طريق معمر. وقد ذكر ذلك مع غيره (٢/٥٣٢-٥٣٣) عند تفسير قوله تعالى: <q>﴿أن طهرا بيتي﴾</q> [البقرة:١٢٥]. ٥٠٣٩٠- عن قتادة بن دعامة -من طريق سعيد- قال: أيْ: مِن عبادة الأوثان، والشِّرك، وقول الزور، والمعاصي{32}. (ز) ٥٠٣٩١- تفسير إسماعيل السُّدِّيّ: قوله: <q>﴿أن لا تشرك بي شيئا وطهر بيتي﴾</q> مِن الأوثان، يعني: لا تَذَرْ حولَه وثنًا يُعْبَد مِن دون الله{33}. (ز) ٥٠٣٩٢- قال مقاتل بن سليمان: <q>﴿وطهر بيتي﴾</q> مِن الأوثان؛ لا تَنصِبْ حوله وثَنًا{3}. (ز) <q>﴿لِلطَّاۤىِٕفِینَ وَٱلۡقَاۤىِٕمِینَ وَٱلرُّكَّعِ ٱلسُّجُودِ ۝٢٦﴾</q> - تفسير ٥٠٣٩٣- عن عطاء، في قوله: <q>﴿للطائفين﴾</q> قال: الذين يطوفون به، <q>﴿والقائمين﴾</q> قال: المُصَلِّين عنده{35}. (١٠/٤٦٤) ٥٠٣٩٤- عن قتادة بن دعامة -من طريق معمر- قال: القائمون: المُصَلُّون{36}. (١٠/٤٦٤) ٥٠٣٩٥- عن قتادة بن دعامة -من طريق سعيد- قوله: <q>﴿للطائفين﴾</q> يعني: أهل الطواف، <q>﴿والقائمين﴾</q> قال: القائمون: أهل مكة{28}. (ز) ٥٠٣٩٦- عن أبان بن أبي عياش -من طريق المعلى بن هلال- في قوله: <q>﴿للطائفين﴾</q>، قال: الطائفون: الذين يطوفون بالبيت. والركع السجود: الذين يُصَلُّون إليه{28}. (ز) ٥٠٣٩٧- قال مقاتل بن سليمان: <q>﴿للطائفين﴾</q> بالبيت، <q>﴿والقائمين﴾</q> يعني: المقيمين بمكة مِن أهلها، <q>﴿والركع السجود﴾</q> يعني: في الصلوات الخمس، وفي الطواف حول البيت مِن أهل مكة وغيرهم، والبيت الحرام اليومَ مكان البيت المعمور، ولو أنّ حجرًا وقع مِن البيت المعمور وقع على البيت الحرام، وهو في العرض والطول مثله، إلّا أنّ قامته كما بين السماء والأرض{3}. (ز) ٥٠٣٩٨- قال سفيان الثوري، في قوله: <q>﴿وطهر بيتي للطائفين والقائمين﴾</q>: القائم: المُصَلِّي{40}. (ز) ٥٠٣٩٩- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿والقائمين والركع السجود﴾</q>، قال: القائم والراكع والساجد: هو المصلي. والطائف: هو الذي يطوف به{31}٤٤٥٦. (ز) ٤٤٥٦ لم يذكر ابنُ جرير (١٦/٥١٣) في معنى: <q>﴿والقائِمِينَ والرُّكَّعِ السُّجُودِ﴾</q> سوى قول عطاء، وقتادة من طريق معمر، وابن زيد. ٥٠٤٠٠- قال يحيى بن سلّام: <q>﴿والركع السجود﴾</q> أهل الصلاة يُصَلُّون إليه{42}. (ز) <q>﴿لِلطَّاۤىِٕفِینَ وَٱلۡقَاۤىِٕمِینَ وَٱلرُّكَّعِ ٱلسُّجُودِ ۝٢٦﴾</q> - من أحكام الآية ٥٠٤٠١- عن ابن عباس، قال: قال اللهُ لنبيه: <q>﴿وطهر بيتي للطائفين والقائمين والركع السجود﴾</q>، قال: طواف قبل الصلاة، وقد قال رسول الله ﷺ: «الطواف بالبيت بمنزلة الصلاة، إلّا أنّ الله قد أحَلَّ فيه المنطق، فمَن نطق فلا ينطق إلا بخير»{43}. (١٠/٤٦٤) ٥٠٤٠٢- عن عبد الله بن عباس -من طريق سعيد بن جبير- أنّه أتاه رجلٌ، فقال: أبْدَأُ بالصفا قبل المروة أو بالمروة قبل الصفا؟ وأُصَلِّي قبل أن أطوف أو أطوف قبل؟ وأحلق قبل أن أذبح أو أذبح قبل أن أحلق؟ فقال ابن عباس: خذوا ذلك مِن كتاب الله؛ فإنّه أجدر أن يحفظ، قال الله: <q>﴿إن الصفا والمروة من شعائر الله﴾</q> [البقرة:١٥٨] فالصفا قبل المروة، وقال: <q>﴿لا تحلقوا رؤوسكم حتى يبلغ الهدي محله﴾</q> [البقرة:١٩٦] فالذبح قبل الحلق، وقال: <q>﴿وطهر بيتي للطائفين والقائمين والركع السجود﴾</q> فالطواف قبل الصلاة{44}. (٢/٩٣) ",footnotes:1:تفسير الثعلبي ٧/١٧.تفسير الثعلبي ٧/١٧.تفسير مقاتل بن سليمان ٣/١٢٢.تفسير الثعلبي ٧/١٧، وتفسير البغوي ٥/٣٧٨ وأورد عقبه: وإنما ذكرنا مكان البيت؛ لأن الكعبة رفعت إلى السماء زمان الطوفان، ثم لَمّا أمر الله تعالى إبراهيم ببناء البيت لم يدْرِ أين يبني، فبعث الله ريحًا خَجُوجًا، فكَنَسَت له ما حول البيت على الأساس.تفسير يحيى بن سلام ١/٣٦٢.أخرجه ابن جرير في التفسير ٢/٥٦٠-٥٦١، وفي التاريخ ١/٢٥٢، والحاكم ٢/٥٥١.الصرد: طائر ضخم الرأس والمنقار، له ريش عظيم، نصفه أبيض ونصفه أسود. النهاية (صرد).أخرجه إسحاق البستي في تفسيره ص٣٥٠.أخرجه ابن أبي حاتم -كما في فتح الباري ٦/٤٠٢-.الحَرَجَة -بالتحريك-: مُجْتَمَع شجَر ملْتَفّ كالغَيْضَة. النهاية (حرج).السَّمُر: نوع من شجَرَ الطَّلح، الواحِدة سَمُرَةٌ. النهاية (سمر).أخرجه يحيى بن سلام ١/٣٦٢.أخرجه سعيد بن منصور (٢٢٠ - تفسير)، وابن أبي حاتم ١/٢٣٥، والأزرقي ١/٣٥ مطولًا.عزاه السيوطي إلى الجندي مطولًا.كذا في المصدر، وقال محققه: هكذا في الأصل، ولعل الصواب: وجبل حراء.أخرجه إسحاق البستي في تفسيره ص٣٥٢.أخرجه عبد الرزاق في المصنف (٩٠٩٠)، وابن جرير ٢/٥٥١. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.هكذا في الأصل.أخرجه عبد الرزاق (٩٠٩٤-٩٠٩٦، ٩٠٩٩)، وابن جرير ٢/٥٥١-٥٥٢، وابن أبي حاتم -كما في فتح الباري ٦/٤٠٩- مختصرًا. وعزاه السيوطي إلى ابن المنذر.وقع في المصدر: جبل لبيان، والظاهر أنه تصحيف؛ ففي سائر المصادر: جبل لبنان.سقطت الواو من المصدر، وقد أثبتناها من مختصره لابن منظور ١/٢٨٧.أخرجه ابن عساكر في تاريخ دمشق ٢/٣٤٧-٣٤٨.الثَّغامة: نبت أبيض الزهر والثمر، يُشَبَّه به الشَّيْب. وقيل: هي شجرة تَبْيَضُّ كأنها الثّلج. النهاية (ثغم).أخرجه ابن جرير ٢/٥٥٧-٥٥٨، ١٦/٥١٢، وابن أبي حاتم ١/٢٣٢-٢٣٣، والبيهقي في الدلائل ٢/٥٣.تفسير البغوي ٥/٣٧٨.تفسير مقاتل بن سليمان ٣/١٢٢.أخرجه وكيع في أخبار القضاة ١/٢٢١، وابن عدي في الكامل في الضعفاء ١/٤٠٦ (٧٩) في ترجمة إبراهيم بن محمد. وعزاه السيوطي إلى أبي الشيخ وابن مردويه والديلمي. قال ابن عدي: «منكر الحديث»، يعني: إبراهيم بن محمد. وقال السيوطي: «بسند ضعيف». وقال المناوي في التيسير ٢/٣: «بإسناد واه». وقال الألباني في الضعيفة ٨/٨٧ (٣٥٩٢): «منكر». وقال فيها ١١/٧٥٧ (٥٤٤٦): «ضعيف جدًّا».أخرجه يحيى بن سلام ١/٣٦٣.أخرجه الثوري في تفسيره ص٢١٠، وابن جرير ١٦/٥١٢.أخرجه الثوري في تفسيره ص٢١٠، وابن جرير ١٦/٥١٢.أخرجه ابن جرير ١٦/٥١٣.أخرجه يحيى بن سلّام ١/٣٦٣، وابن جرير ٢/٥٣٣.علَّقه يحيى بن سلام ١/٣٦٣.تفسير مقاتل بن سليمان ٣/١٢٢.أخرجه ابن جرير ١٦/٥١٣، وابن أبي حاتم ١/٢٢٨. وعزاه السيوطي إلى ابن أبي شيبة، وابن المنذر.أخرجه عبد الرزاق ٢/٣٦، وابن جرير ١٦/٥١٣.أخرجه يحيى بن سلام ١/٣٦٣.أخرجه يحيى بن سلام ١/٣٦٣.تفسير مقاتل بن سليمان ٣/١٢٢.تفسير الثوري ص٢١٠.أخرجه ابن جرير ١٦/٥١٣.تفسير يحيى بن سلّام ١/٣٦٣.أخرجه الحاكم ٢/٢٩٣ (٣٠٥٦)، من طريق يزيد بن هارون، أنبأ القاسم بن أبي أيوب، عن سعيد بن جبير، عن ابن عباس به ... ثم ساقه بنحوه من طريق حماد بن سلمة، عن عطاء بن السائب، عن سعيد بن جبير، عن ابن عباس به. قال الحاكم: «هذا حديث صحيح، على شرط مسلم، ولم يُخَرِّجاه». وقال ابن الملقن في البدر المنير ٢/٤٩٤: «وحديث حماد بن سلمة عن عطاء في المتابع الذي ذكره الحاكم إسناده جيد؛ فإنه سمع منه قبل الاختلاط». وقال في تحفة المحتاج ١/١٥٦ (٣٠): «والقاسم هذا ثقة، كما قاله أبو داود وغيره». وقال ابن حجر في التلخيص الحبير ١/٣٦٠ معلقًا على تصحيح الحاكم: «وهو كما قال، فإنّهم ثقات». وقال الألباني في الإرواء ١/١٥٤ (١٢١): «صحيح».أخرجه ابن أبي شيبة في مصنفه (ت: محمد عوامة) ٨/٥١٧ (١٤٩١٦)، والحاكم ٢/٢٧٠-٢٧١. وعزاه السيوطي إلى سعيد بن منصور.
22,27," <q>﴿وَأَذِّن فِی ٱلنَّاسِ بِٱلۡحَجِّ﴾</q> - تفسير ٥٠٤٠٣- عن عبد الله بن عباس -من طريق أبي الطفيل- قال: لَمّا أُمر إبراهيم أن يُؤَذِّن في الناس تواضعت له الجبال، ورُفِعت له الأرض، فقام، فقال: يا أيها الناس، أجيبوا ربَّكم{1}. (١٠/٤٦٩) ٥٠٤٠٤- عن عبد الله بن عباس -من طريق صالح مولى التَّوْأَمة- قال: قام إبراهيمُ النبيُّ عند البيت، فأذَّن في الناس بالحج، فسمعه أهلُ المشرق وأهلُ المغرب{2}. (ز) ٥٠٤٠٥- عن عبد الله بن عباس -من طريق قابوس بن أبي ظبيان، عن أبيه- قال: لَمّا فرغ إبراهيمُ مِن بناء البيت قال: ربِّ، قد فرغت. فقال: أذِّن في الناس بالحج. قال: ربِّ، وما يبلغ صوتي؟! قال: أذِّن وعلَيَّ البلاغُ. قال: ربِّ، كيف أقول؟ قال: يا أيها الناس، كُتِب عليكم الحجُّ إلى البيت العتيق. فسمعه مَن بين السماء والأرض، ألا ترى أنهم يجيئون مِن أقصى الأرض يُلَبُّون؟{3}. (١٠/٤٦٤) ٥٠٤٠٦- عن عبد الله بن عباس -من طريق سعيد بن جبير- قال: لَمّا بنى إبراهيمُ البيتَ أوحى الله إليه: أن أذِّن في الناس بالحج. فقال: ألا إنّ ربَّكم قد اتَّخَذ بيتًا، وأمركم أن تحجوه. فاستجاب له ما سمعه مِن حجر أو شجر أو أكَمَة أو تراب أو شيء؛ فقالوا: لبيك اللهم لبيك{4}. (١٠/٤٦٥) ٥٠٤٠٧- عن عبد الله بن عباس -من طريق مجاهد- في قوله: <q>﴿وأذن في الناس بالحج﴾</q>، قال: قام إبراهيمُ ﵇ على الحجر، فنادى: يا أيها الناس، كتب عليكم الحج. فأَسْمَع مَن في أصلاب الرجال وأرحام النساء، فأجاب مَن آمن مِمَّن سبق في علم الله أن يَحُجَّ إلى يوم القيامة: لبيك اللهم لبيك{5}. (١٠/٤٦٦) ٥٠٤٠٨- عن عبد الله بن عباس، قال: لَمّا أمر اللهُ إبراهيم أن يُنادي في الناس بالحَجِّ صعد أبا قبيس، فوضع أصبعيه في أذنيه، ثُمَّ نادى: يا أيها الناس، إنّ الله كتب عليكم الحجَّ، فأجيبوا ربَّكم. فأجابوه بالتلبية في أصلاب الرجال وأرحام النساء، وأوَّلُ مَن أجابه أهلُ اليمن، فليس حاجٌّ مِن يومئذ إلى أن تقوم الساعة إلا مَن كان أجابَ إبراهيمَ يومئذ{6}. (١٠/٤٦٥) ٥٠٤٠٩- عن عبد الله بن عباس، قال: صعد إبراهيم أبا قبيس، فقال: الله أكبر، الله أكبر، أشهد أن لا إله إلا الله، وأشهد أن إبراهيم رسول الله، أيها الناس، إنّ الله أمرني أن أنادي في الناس بالحج، أيها الناس، أجيبوا ربكم. فأجابه مَن أخذ الله ميثاقَه بالحج إلى يوم القيامة{6}. (١٠/٤٦٩) ٥٠٤١٠- عن عبد الله بن عباس -من طريق العوفي- في قوله: <q>﴿وأذن في الناس بالحج﴾</q>: يعني بالناس: أهل القبلة، ألم تسمع أنّه قال: <q>﴿ان أول بيت وضع للناس﴾</q> إلى قوله: <q>﴿ومن دخله كان آمنا﴾</q> [آل عمران:٩٦]؟ يقول: ومَن دخله مِن الناس الذين أمر أن يؤذن فيهم، وكتب عليهم الحج؛ فإنّه آمِن، فعَظِّموا حرمات الله تعالى، فإنّها مِن تقوى القلوب{8}. (١٠/٤٧٠) ٥٠٤١١- عن عبيد بن عمير، قال: لَمّا أُمِر إبراهيمُ ﵇ بدعاء الناس إلى الله استقبل المشرق، فدعا، ثم استقبل المغرب، فدعا، ثم استقبل الشام، فدعا، ثم استقبل اليمن، فدعا، فأُجِيب: لبيك لبيك{6}. (١٠/٤٦٦) ٥٠٤١٢- عن سعيد بن جبير، قال: أجاب إبراهيمَ كلُّ جِنِّيٍّ وإنسِيٍّ، وكلُّ شجر وحجر{10}. (١٠/٤٦٩) ٥٠٤١٣- عن سعيد بن جبير -من طريق عطاء بن السائب- <q>﴿وأذن في الناس بالحج﴾</q>، قال: وقَرَتْ في كلِّ ذكر وأنثى{5}. (١٠/٤٦٦) ٥٠٤١٤- عن سعيد بن جبير -من طريق عطاء- قال: لَمّا فرغ إبراهيمُ مِن بناء البيت أوحى اللهُ إليه أن أذِّن في الناس بالحج، فخرج، فنادى في الناس: يا أيها الناس، إنّ ربَّكم قد اتخذ بيتًا فحُجُّوه. فلم يسمعه حينئذ مِن إنس ولا جن ولا شجرة ولا أكَمَةٍ ولا تراب ولا جبل ولا ماء ولا شيء إلا قال: لبيك اللهم لبيك{12}. (١٠/٤٦٦) ٥٠٤١٥- عن مجاهد بن جبر، قال: لَمّا أذَّن إبراهيمُ بالحج قال: يا أيها الناس، أجيبوا ربَّكم. فلبّى كلُّ رَطْب ويابس{6}. (١٠/٤٦٧) ٥٠٤١٦- عن مجاهد بن جبر -من طريق ابن أبي نجيح- قال: لَمّا أُمِر إبراهيم أن يُؤَذِّن في الناس بالحجِّ قام على المقام، فنادى بصوت أسْمَعَ مَن بين المشرق والمغرب: يا أيها الناس، أجيبوا ربكم{14}. (١٠/٤٦٧) ٥٠٤١٧- عن مجاهد بن جبر -من طريق خُصَيْف- قال: قال جبريل لإبراهيم: <q>﴿وأذن في الناس بالحج﴾</q>. قال: كيف أؤذن؟ قال: قل: يا أيها الناس، أجيبوا إلى ربكم. ثلاث مرات، فأجاب العبادُ، فقالوا: لبيك اللهم لبيك، ربنا لبيك لبيك، اللهم ربنا لبيك. قال: فمَن أجاب إبراهيمَ يومئذ مِن الخلق فهو حاجٌّ{15}. (١/٧١١، ١٠/٤٦٧) ٥٠٤١٨- عن مجاهد بن جبر، قال: لما فرغ إبراهيمُ وإسماعيلُ مِن بناء البيت أمر إبراهيمَ أن يُؤَذِّن بالحج، فقام على الصَّفا، فنادى بصوتٍ سَمِعه ما بين المشرق والمغرب: يا أيها الناس، أجيبوا إلى ربكم. فأجابوه وهم في أصلاب آبائهم، فقالوا: لبيك. قال: فإنّما يَحُجُّ البيتَ اليومَ مَن أجاب إبراهيم يومئذ{10}. (١٠/٤٦٧) ٥٠٤١٩- عن مجاهد بن جبر -من طريق منصور- قال: قال إبراهيم: كيف أقول؟ قال: قل: يا أيها الناس، أجيبوا ربَّكم. فما خلق اللهُ مِن جبل ولا شجر ولا شيء مِن المطيعين له إلا ينادي: لبيك اللهم لبيك. فصارت التلبية{17}. (١٠/٤٦٨) ٥٠٤٢٠- عن مجاهد بن جبر -من طريق منصور- قوله: <q>﴿وأذن في الناس بالحج﴾</q>: قال إبراهيم: كيف أقول، يا رب؟ قال: قل: يا أيها الناس، استجيبوا لربكم. قال: فوَقَرَتْ في قلب كل مؤمن{8}. (ز) ٥٠٤٢١- عن مجاهد بن جبر -من طريق منصور- قال: أُمِر إبراهيمُ ﷺ أن يُؤَذِّن بالحج، فقام على المقام، فتطاول به حتى صار كأطول جبل، فنادى: يا أيها الناس، أجيبوا ربَّكم. مرتين، فأجابوه مِن تحت البحور السبع: لَبَّيك أجبنا، لبيك أطعنا. فمَن حَجَّ إلى يوم القيامة فهو مِمَّن استجاب له يومئذ، فوَقَرَتْ في نفس كل مسلم{19}. (١٠/٤٦٨) ٥٠٤٢٢- عن مجاهد بن جبر -من طريق سلمة- قال: قيل لإبراهيم: أذِّن في الناس بالحج. قال: يا رب، كيف أقول؟ قال: قل: لبيك اللهم لبيك. فكان إبراهيمُ أولَ مَن لَبّى{20}. (١٠/٤٦٨) ٥٠٤٢٣- عن عكرمة بن خالد المخزومي، قال: لَمّا أُمِر إبراهيم بالحج قام على المقام، فنادى نِداءً سمعه جميعُ أهل الأرض: ألا إنّ ربكم قد وضع بيتًا، وأمركم أن تحجوه. فجعل اللهُ في أثر قدميه آيةً في الصخرة{21}. (١٠/٤٦٨) ٥٠٤٢٤- عن الحسن البصري: أنّ قوله: <q>﴿وأذن في الناس بالحج﴾</q> كلام مُسْتَأْنَف، وأنّ المأمور بهذا التَّأْذِين محمدٌ ﷺ، أُمِر أن يفعل ذلك في حجة الوداع{22}. (ز) ٥٠٤٢٥- عن عطاء، قال: صعد إبراهيم على الصفا، فقال: يا أيها الناس، أجيبوا ربَّكم. فأَسْمَع مَن كان حيًّا في أصلاب الرجال{23}. (١٠/٤٦٨) ٥٠٤٢٦- عن إسماعيل السُّدِّيّ -من طريق أسباط- قال: لَمّا فرغ إبراهيمُ وإسماعيلُ مِن بُنيان البيت أمره الله أن يُنادي، فقال: <q>﴿وأَذِّنْ فِي النّاسِ بِالحَجِّ﴾</q>. فنادى بين أخْشَبَيْ مكة: يا أيها الناس، إنّ الله يأمركم أن تَحُجُّوا بيته. قال: فوَقَرَتْ في قلب كُلِّ مؤمن، فأجابه كلُّ شيء سمعه مِن جبل أو شجر أو دابة: لبيك لبيك. فأجابوه بالتلبية: لبيك اللهم لبيك. وأتاه مَن أتاه{24}. (ز) ٥٠٤٢٧- عن علي بن أبي طلحة: أنّ الله أوحى إلى إبراهيم ﵇: أن أذِّن في الناس بالحج. فقام على الحجر، فقال: يا أيها الناس، إنّ الله يأمركم بالحج. فأجابه مَن كان مخلوقًا في الأرض يومئذ، ومَن كان في أرحام النساء، ومَن كان في أصلاب الرجال، ومَن كان في البحور، فقالوا: لبيك اللهم لبيك{6}. (١٠/٤٦٧) ٥٠٤٢٨- قال مقاتل بن سليمان: <q>﴿وأذن﴾</q> يا إبراهيم <q>﴿في الناس﴾</q> يعني: المؤمنين <q>﴿بالحج﴾</q> فصعد أبا قبيس، وهو الجبلُ الذي الصفا في أصله، فنادى: يا أيها الناس، أجيبوا ربكم، إنّ الله ﷿ يأمركم أن تَحُجُّوا بيتَه. فسمع نداءَ إبراهيم ﵇ كلُّ مؤمن على ظهر الأرض، ويُقال: في أصلاب الرجال وأرحام النساء، فالتلبية اليوم جوابُ نداء إبراهيم ﵇ عن أمر ربِّه ﷿، فذلك قوله سبحانه: <q>﴿يأتوك رجالا﴾</q>{26}. (ز) <q>﴿یَأۡتُوكَ رِجَالࣰا وَعَلَىٰ كُلِّ ضَامِرࣲ﴾</q> - نزول الآية ٥٠٤٢٩- عن مجاهد بن جبر -من طريق عمر بن ذَرٍّ- قال: كانوا يَحُجُّون ولا يتزودون؛ فأنزل الله: <q>﴿وتزودوا﴾</q> [البقرة:١٩٧]، وكانوا يحجون ولا يركبون؛ فأنزل الله: <q>﴿يأتوك رجالا وعلى كل ضامر﴾</q>، فأمرهم بالزاد، ورخَّص لهم في الرُّكُوب، والمتجر{27}. (١٠/٤٧٢) <q>﴿یَأۡتُوكَ رِجَالࣰا﴾</q> - تفسير ٥٠٤٣٠- عن عبد الله بن عباس -من طريق ابن جُرَيْج- <q>﴿يأتوك رجالا﴾</q>، قال: مُشاة{28}. (١٠/٤٧١) ٥٠٤٣١- عن عبد الله بن عباس -من طريق قتادة- في قوله: <q>﴿يأتوك رجالا﴾</q>، قال: على أرجُلِهم{28}. (١٠/٤٧١) ٥٠٤٣٢- عن عبد الله بن عباس، في قوله: <q>﴿يأتوك رجالا وعلى كل ضامر﴾</q>، قال: هُم المُشاة والرُّكْبان{30}. (١٠/٤٧٢) ٥٠٤٣٣- عن محمد بن كعب القرظي، قال: سمعتُ عبد الله بن عباس يقول: ما آسى على شيء إلا أنِّي لم أكُن حججت راجِلًا؛ لأني سمعت الله يقول: <q>﴿يأتوك رجالا﴾</q>. وهكذا كان يقرؤها{31}. (١٠/٤٧٠) ٥٠٤٣٤- عن عبد الله بن عباس، قال: ما آسى على شيء فاتني إلا أني لم أحج ماشيًا حتى أدركني الكِبَر، أسمع الله تعالى يقول: <q>﴿يأتوك رجالا وعلى كل ضامر﴾</q>، فبدأ بالرِّجال قبل الرُّكْبان{32}. (١٠/٤٧٠) ٥٠٤٣٥- عن عكرمة مولى ابن عباس -من طريق عمران- <q>﴿رجالًا﴾</q>: على أرجُلِهم{33}. (ز) ٥٠٤٣٦- عن قتادة بن دعامة -من طريق سعيد- قوله: <q>﴿يأتوك رجالا﴾</q>، قال: مُشاة{2}. (ز) ٥٠٤٣٧- عن ابن جُرَيْج، قال: سُئِل عطاء [بن أبي رباح] عن الحجِّ؛ ماشيًا أو راكِبًا؟ فقال: أما سمعتَ الله -تبارك وتعالى- يقول: <q>﴿يأتوك رجالا وعلى كل ضامر﴾</q>{35}. (ز) ٥٠٤٣٨- قال مقاتل بن سليمان: <q>﴿يأتوك رجالا﴾</q>، يعني: على أرجلهم مُشاة{26}. (ز) <q>﴿وَعَلَىٰ كُلِّ ضَامِرࣲ﴾</q> - تفسير ٥٠٤٣٩- عن عبد الله بن عباس -من طريق ابن جُرَيْج- <q>﴿وعلى كل ضامر﴾</q>، قال: الإبل{37}. (١٠/٤٧١) ٥٠٤٤٠- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿وعلى كل ضامر﴾</q>، قال: لا تبلغه المُطِيُّ حتى تضمُر{38}. (١٠/٤٧٢) ٥٠٤٤١- عن عطاء الخراساني -من طريق يونس- في قول الله ﷿: <q>﴿يأتوك رجالا وعلى كل ضامر﴾</q>، قال: الإبل والدواب{39}. (ز) ٥٠٤٤٢- قال مقاتل بن سليمان: <q>﴿وعلى كل ضامر﴾</q>، يعني: الإبل{26}٤٤٥٧. (ز) ٤٤٥٧ ذكر ابنُ عطية (٦/٢٣٨) في معنى «الضامر» قولين: الأول: أنها الناقة. ثم علَّق عليه قائلًا: «فيجيء قوله تعالى: <q>﴿يَأْتِينَ﴾</q> مستقيمًا على هذا التأويل». والثاني: أنها كل ما اتَّصف بذلك من جمل وناقة وغير ذلك. ورجَّحه بقوله: «وهذا هو الأظهر». ولم يذكر مستندًا، ثم وجَّه هذا المعنى مع قوله: <q>﴿يَأْتِينَ﴾</q>، فقال: «لكنه يتضمن معنى الجماعات أو الرفاق، فيحسن لذلك قوله: <q>﴿يَأْتِينَ﴾</q>». <q>﴿یَأۡتِینَ مِن كُلِّ فَجٍّ عَمِیقࣲ ۝٢٧﴾</q> - تفسير ٥٠٤٤٣- عن عبد الله بن عباس -طريق العوفي- <q>﴿من كل فج عميق﴾</q>، قال: مكان بعيد{41}. (١٠/٤٧٠) ٥٠٤٤٤- عن عبد الله بن عباس: أنّ نافع بن الأزرق سأله عن قوله: <q>﴿من كل فج عميق﴾</q>. قال: طريق بعيد. قال: وهل تعرفُ العرب ذلك؟ قال: نعم، أما سمعت قولَ الشاعر: حازوا العِيالَ وسَدُّوا الفِجا ج بأجساد عادٍ لَها آبدات؟{42}. (١٠/٤٧٢) ٥٠٤٤٥- عن أبي العالية الرياحي، <q>﴿من كل فج عميق﴾</q>، قال: مكان بعيد{30}. (١٠/٤٧٣) ٥٠٤٤٦- عن مجاهد بن جَبْر، في قوله: <q>﴿من كل فج عميق﴾</q>، قال: طريق بعيد{44}. (١٠/٤٧٢) ٥٠٤٤٧- عن الضحاك بن مُزاحِم، مثله{10}. (١٠/٤٧٣) ٥٠٤٤٨- عن قتادة بن دعامة -من طريق مَعْمَر- <q>﴿فج عميق﴾</q>، قال: مكان بعيد{46}. (١٠/٤٧٣) ٥٠٤٤٩- عن قتادة بن دعامة -من طريق سعيد- قال: عمق ما بين تهامة والعراق، ويُؤتى مِن أبعد من ذلك{47}. (ز) ٥٠٤٥٠- قال مقاتل بن سليمان: <q>﴿يأتين من كل فج عميق﴾</q>، يعني: يجيء مِن كل مكان بعيد{26}. (ز) ٥٠٤٥١- قال يحيى بن سلّام، في قوله: <q>﴿يأتين من كل فج عميق﴾</q>: يعني: بعيد{49}. (ز) <q>﴿یَأۡتِینَ مِن كُلِّ فَجٍّ عَمِیقࣲ ۝٢٧﴾</q> - آثار متعلقة بالآية ٥٠٤٥٢- عن عليٍّ، رفعه: «لَمّا نادى إبراهيمُ بالحجِّ لَبّى الخلقُ، فمَن لَبّى تلبيةً واحدة حَجَّ واحدة، ومَن لَبّى مَرَّتين حجَّ حَجَّتين، ومَن زاد فبحساب ذلك»{50}. (١٠/٤٦٥) ٥٠٤٥٣- عن عبيد بن عمير، قال: لَقِي عمرُ بن الخطاب رَكْبًا يُريدون البيت، فقال: مَن أنتم؟ فأجابه أحدثهم سِنًّا، فقال: عباد الله المسلمون. فقال: مِن أين جئتم؟ قال: مِن الفجِّ العميق. قال: أين تُريدون؟ قال: البيت العتيق. فقال عمر: تَأَوَّلها، لعَمْرُ اللهِ. فقال عمر: مَن أميركم؟ فأشار إلى شيخ منهم، فقال عمر: بل أنت أميرُهم. لِأحدثهم سِنًّا الذي أجابه{51}. (١٠/٤٧٣) ٥٠٤٥٤- عن عبد الله بن عباس -من طريق سالم بن أبي الجعد- قال: أتدري كيف كانت التلبية؟ إنّ إبراهيم لَمّا أُمِر أن يُؤَذِّن في الناس بالحج؛ أُمِرَت الجبال فخفضت رؤوسها، ورُفِعَت له القرى، فأذَّن في الناس بالحج{52}. (١/٧١٥) ٥٠٤٥٥- عن عبد الله بن الزبير، قال: أُخِذَ الأذانُ مِن أذانِ إبراهيم في الحج: <q>﴿وأذن في الناس بالحج﴾</q>. قال: فأذَّن رسولُ الله ﷺ للصلاة{53}. (١٠/٤٦٦) ٥٠٤٥٦- عن مجاهد بن جبر -من طريق ابن أبي نجيح- قال: حجَّ إبراهيمُ وإسماعيلُ ماشِيَيْنِ{54}. (١٠/٤٧٠) ٥٠٤٥٧- عن وهب بن مُنَبِّه -من طريق عثمان بن ساج-: أنّ آدم لَمّا أُهْبِط إلى الأرض استوحش فيها؛ لِما رأى مِن سَعَتِها، ولم يَرَ فيها أحدًا غيره، فقال: يا ربِّ، أما لأرضك هذه عامِرٌ يُسَبِّحُك فيها ويُقَدِّس لك غيري؟ قال الله: إنِّي سأجعل فيها مِن ذُرِّيَّتِك مَن يُسَبِّح بحمدي، ويُقَدِّس لي، وسأجعل فيها بيوتًا ترفع لذكري، فيُسَبِّح فيها خلقي، سأُبَوِّئُك فيها بيتًا أختاره لنفسي، وأَخُصُّه بكرامتي، وأُوثِرُه على بيوت الأرض كلها باسمي، وأُسَمِّيه بيتي، أنظمه بعظمتي، وأحوزه بحُرْمَتي، وأجعله أحقَّ البيوت كلها وأولاها بذكري، وأَضَعُه في البقعة المباركة التي اخترت لنفسي، فإنِّي اخترتُ مكانه يوم خلقتُ السموات والأرض، وقبل ذلك قد كان بغيتي، فهو صفوتي مِن البيوت، ولست أسكنه، وليس ينبغي أن أسكن البيوت، ولا ينبغي لها أن تحملني، أجعل ذلك البيتَ لك ومَن بعدك حَرَمًا وأَمْنًا، أُحَرِّم بحُرْمَتِه ما فوقه وما تحته وما حوله، فمَن حرَّمه بحرمتي فقد عظَّم حرمتي، ومَن أحلَّه فقد أباح حرمتي، مَن أمَّن أهلَه استوجب بذلك أماني، ومَن أخافهم فقد أخْفَرني في ذِمَّتي، ومَن عظَّم شأنه فقد عَظُم في عيني، ومَن تهاون به صَغُر عندي، ولكل ملك حيازة، وبطن مكة حوزتي التي حُزْتُ لنفسي دون خلقي، فأنا الله ذو بَكَّة، أهلها خَفْرتي وجيران بيتي، وعُمّارها وزُوّارها وفْدِي وأضيافي في كَنَفي وضماني وذِمَّتي وجِواري، أجعله أولَ بيت وُضِع للناس، وأعمره بأهل السماء وأهل الأرض، يأتونه أفواجًا شُعْثًا غُبْرًا، على كُلِّ ضامر يأتين مِن كل فج عميق، يَعُجُّون بالتكبير عَجِيجًا، ويَرُجُّون بالتلبية رَجِيجًا، فمَنِ اعتمره لا يريد غيري فقد زارني، وضافني، ووفد إلَيَّ، ونزل بي، فحقٌّ لي أن أُتْحِفَه بكرامتي، وحقُّ الكريم أن يُكْرِم وفده وأضيافه وزُوّاره، وأن يسعف كلَّ واحد منهم بحاجته، تعمره -يا آدمُ- ما كُنتَ حَيًّا، ثم يعمره مِن بعدك الأممُ والقرونُ والأنبياءُ مِن ولدك، أُمَّة بعد أُمَّة، وقرنًا بعد قرن، ونبيًّا بعد نبي، حتى ينتهي ذلك إلى نبيٍّ مِن ولدك يُقال له: محمد، وهو خاتم النبيين، فأجعله من عُمّاره وسُكّانه وحُماته ووُلاته وحُجّابه وسُقاته، يكون أميني عليه ما كان حَيًّا، فإذا انقلب إلَيَّ وجدني قد ادَّخَرْتُ له مِن أجره ونصيبه ما يتمكن به مِن القُرْبَة إلَيَّ والوسيلة عندي، وأفضل المنازل في دار المقامة، وأجعل اسم ذلك البيت وذِكْرَه وشرفه ومجده وسناه ومكرمته لنبيٍّ مِن ولدك، يكون قبيل هذا النبي، وهو أبوه، يُقال له: إبراهيم، أرفع له قواعده، وأقضي على يديه عمارته، وأنيط له سقايته، وأُريه حِلَّه وحَرَمه ومواقفه، وأُعلمه مشاعره ومناسكه، وأَجعلُه أُمَّة واحدة قانتًا قائمًا بأمري، داعيًا إلى سبيلي، وأَجتبيه وأهديه إلى صراط مستقيم، أبتليه فيصبر، وأعافيه فيشكر، وآمره فيفعل، ويُنذر لي فيفي، ويَعِدُني فيُنجِز، أستجيب دعوتَه في ولده وذريته مِن بعده، وأُشَفِّعه فيهم، وأجعلهم أهلَ ذلك البيت وحُماته وسُقاته وخدمه وخزنته وحُجّابه، حتى يبتدعوا ويُغَيِّروا ويُبَدِّلوا، فإذا فعلوا ذلك فأنا أقدر القادرين على أن استبدل مَن أشاء بِمَن أشاء، وأجعلُ إبراهيم إمامَ ذلك البيت وأهلَ تلك الشريعة، يأتمُّ به مَن حضر تلك المواطن مِن جميع الإنس والجن، يَطَؤُون فيها آثاره، ويَتَّبعون فيها سُنَّته، ويقتدون فيها بهديه، فمَن فعل ذلك منهم أوْفى بنذره، واستكمل نُسُكَه، وأصاب بُغْيَته، ومَن لم يفعل ذلك منهم ضَيَّع نسكه، وأخطأ بغيته، ولم يوف بنذره، فمن سأل عنِّي يومئذ في تلك المواطن: أين أنا؟ فأنا مع الشُّعْثِ، الغُبْر، المُوفِين بنذرهم، المستكملين مناسكهم، المتبتلين إلى ربهم، الذي يعلم ما يبدون وما يكتمون{55}. (١/٦٧٨) ٥٠٤٥٨- عن عكرمة، ووهب بن منبه، رفعاه إلى ابن عباس، بمثله سواء{56}. (١/٦٨١) ",footnotes:1:أخرجه يحيى بن سلام ١/٣٦٤، وابن جرير ١٦/٥١٦-٥١٧، والطبراني (١٠٦٢٨)، والبيهقي في شعب الإيمان (٤٠٧٧). وعزاه السيوطي إلى ابن أبي حاتم.أخرجه يحيى بن سلام ١/٣٦٤.أخرجه ابن أبي شيبة ١١/٥١٨، وابن منيع -كما في المطالب (١١٩٦)-، وفتح الباري ٣/٤٠٩، وابن جرير ١٦/٥١٤-٥١٥، وابن أبي حاتم -كما في فتح الباري ٣/٤٠٩-، والحاكم ٢/٣٨٨-٣٨٩، والبيهقي في سننه ٥/١٧٦ واللفظ له. وعزاه السيوطي إلى ابن المنذر.أخرجه يحيى بن سلام ١/٣٦٤، وابن جرير ١٦/٥١٥، والحاكم ٢/٥٥٢، والبيهقي في سننه ٥/١٧٦، وفي الشعب (٣٩٩٨)، وفي الدلائل ٢/٥٤. وعزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ١٦/٥١٥.عزاه السيوطي إلى ابن أبي حاتم.عزاه السيوطي إلى ابن أبي حاتم.أخرجه ابن جرير ١٦/٥١٧.عزاه السيوطي إلى ابن أبي حاتم.عزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ١٦/٥١٥.أخرجه ابن جرير ١٦/٥١٦.عزاه السيوطي إلى ابن أبي حاتم.أخرجه البيهقي في الشعب (٤٠٠٠). وعزاه السيوطي إلى سعيد بن منصور، وابن المنذر، وابن أبي حاتم.أخرجه سعيد بن منصور (٢٢٠ - تفسير)، وابن أبي حاتم ١/٢٣٥، والأزرقي ١/٣٥ مطولًا. وعزاه السيوطي إلى عبد بن حميد.عزاه السيوطي إلى عبد بن حميد.أخرجه البيهقي في الشعب (٣٩٩٩). وعزاه السيوطي إلى سعيد بن منصور، وابن المنذر، وابن أبي حاتم.أخرجه ابن جرير ١٦/٥١٧.أخرجه الثوري في تفسيره ص٢١٠. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم بنحوه.أخرجه ابن جرير ١٦/٥١٧ من طريق سلمة. وعزاه السيوطي إلى عبد بن حميد.عزاه السيوطي إلى عبد بن حميد، وابن المنذر. وأخرجه ابن جرير ١٦/٥١٦ بنحوه من طريق داود دون آخره. وزاد فيه: قال داود: فأرجو مَن حج اليوم مِن إجابة إبراهيم ﵇. وأخرجه يحيى بن سلام ١/٣٦٣ من طريق قتادة بنحوه، وزاد فيه: فأسْمَعَ ما بين الخافقين أو المشرقين، وأقبل الناس: لبيك اللهم لبيك. ثم عقَّب عليه يحيى بن سلام بقوله: بلغني: أنه أجابه يومئذ مَن كان حاجًّا إلى يوم القيامة.تفسير الثعلبي ٧/١٨، وتفسير البغوي ٥/٣٧٩.عزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه ابن جرير ٢/٥٦٧ مطولًا.عزاه السيوطي إلى ابن أبي حاتم.تفسير مقاتل بن سليمان ٣/١٢٣.أخرجه عبد الرزاق ١/٧٧، وابن جرير ١٦/٥١٩ مرسلًا.أخرجه ابن جرير ١٦/٥١٨.أخرجه ابن جرير ١٦/٥١٨.عزاه السيوطي إلى ابن المنذر.أخرجه الخطيب في تاريخه ٧/٤٠٤-٤٠٥، وابن جرير ١٦/٥١٨.أخرجه ابن أبي شيبة ٤/٩٧-٩٨، وابن جرير ١٦/٥١٨ من طريق حجاج بن أرطاة بنحوه، وابن أبي حاتم -كما في فتح الباري ٣/٣٧٩-، والبيهقي ٤/٣٣١، وفي الشعب (٣٩٨٠)، من طريق محمد بن عطاء. وعزاه السيوطي إلى ابن سعد، وعبد بن حميد، وابن المنذر.أخرجه الحربي في غريب الحديث ٢/٤١٨.أخرجه يحيى بن سلام ١/٣٦٤.أخرجه الفاكهيُّ في أخبار مكة ١/٣٩٨ (٨٤٧).تفسير مقاتل بن سليمان ٣/١٢٣.أخرجه ابن جرير ١٦/٥١٩.أخرجه يحيى بن سلام ١/٣٦٤. وعزاه السيوطي إلى عبد بن حميد، وابن أبي حاتم.أخرجه أبو جعفر الرملي في جزئه ص١١٧ (تفسير عطاء الخراساني).تفسير مقاتل بن سليمان ٣/١٢٣.أخرجه ابن جرير ١٦/٥١٩، كذلك أخرجه بنحوه من طريق ابن جريج.عزاه السيوطي إلى الطستي في مسائله. وينظر: الإتقان ٣/٨٨٥.عزاه السيوطي إلى ابن المنذر.عزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.عزاه السيوطي إلى عبد بن حميد.أخرجه عبد الرزاق ٢/٣٦، وابن جرير ١٦/٥١٩.أخرجه يحيى بن سلام ١/٣٦٥.تفسير مقاتل بن سليمان ٣/١٢٣.تفسير يحيى بن سلام ١/٣٦٥.أورده الديلمي ٣/٤٢٥ (٥٣٠٣). قال السيوطي: «بسند واهٍ». وأورده ابن عراق في تنزيه الشريعة ٢/١٧٦ (٢٧)، وقال الشوكاني في الفوائد المجموعة ص١٠٩ (١٦): «قال في الذيل: هو مِن نسخة محمد بن الأشعث التي عامتها مناكير».أخرجه عبد الرزاق في المصنف (٣٨١٣).أخرجه الطيالسي (٢٨٢٠)، والبيهقي في الشعب (٤٠٧٧)، وأحمد ٤/٤٣٦-٤٣٧ (٢٧٠٧، ٢٧٠٨).عزاه السيوطي إلى أبي الشيخ في كتاب الأذان.أخرجه ابن أبي شيبة ٤/٩٨، وابن جرير ١٦/٥١٨. كما أخرجه يحيى بن سلام ١/٣٦٤ موقوفًا على ابن أبي نجيح. وقد أورد السيوطي ١٠/٤٧٠-٤٧١ آثارًا أخرى عن فضل الحج مشيًا.أخرجه الأزرقي في فضائل مكة ١/١٥-١٧، والبيهقي في الشعب (٣٩٨٥).عزاه السيوطي إلى الجندي.
22,28," <q>﴿لِّیَشۡهَدُوا۟ مَنَـٰفِعَ لَهُمۡ﴾</q> - تفسير ٥٠٤٥٩- عن عبد الله بن عباس -من طريق أبي رزين- <q>﴿ليشهدوا منافع لهم﴾</q>، قال: أسواقًا كانت لهم، ما ذكر الله منافع إلا الدنيا{1}. (١٠/٤٧٣) ٥٠٤٦٠- عن عبد الله بن عباس، في قوله: <q>﴿ليشهدوا منافع لهم﴾</q>، قال: منافع في الدنيا، ومنافع في الآخرة؛ فأمّا منافع الآخرة فرضوان الله، وأمّا منافع الدنيا فما يصيبون من لحوم البدن في ذلك اليوم والذبائح والتجارات{2}. (١٠/٤٧٣) ٥٠٤٦١- عن أبي رزين [مسعود بن مالك الأسدي] -من طريق عاصم بن بهدلة- في قوله: <q>﴿ليشهدوا منافع لهم﴾</q>، قال: أسواقهم{3}. (ز) ٥٠٤٦٢- قال سعيد بن المسيب: العفو والمغفرة{4}. (ز) ٥٠٤٦٣- عن سعيد بن جبير -من طريق واقد- <q>﴿ليشهدوا منافع لهم﴾</q>، قال: التجارة{5}. (ز) ٥٠٤٦٤- عن مجاهد بن جبر -من طريق ابن أبي نجيح- <q>﴿ليشهدوا منافع لهم﴾</q>، قال: الأجر في الآخرة، والتجارة في الدنيا{6}. (١٠/٤٧٤) ٥٠٤٦٥- عن مجاهد بن جبر -من طريق ابن أبي نجيح- <q>﴿ليشهدوا منافع لهم﴾</q>، قال: فيما يرضى اللهُ لهم مِن الدنيا والآخرة{7}. (ز) ٥٠٤٦٦- قال عطية العوفي: العفو والمغفرة{8}. (ز) ٥٠٤٦٧- عن أبي جعفر محمد بن علي -من طريق جابر- <q>﴿ليشهدوا منافع لهم﴾</q>، قال: العفو. وفي لفظ: مغفرة{9}. (ز) ٥٠٤٦٨- قال مقاتل بن سليمان: <q>﴿ليشهدوا منافع لهم﴾</q>، يعني: الأجر في الآخرة في مناسكهم{10}٤٤٥٨. (ز) ٤٤٥٨ أفادت الآثارُ اختلاف المفسرين في معنى «المنافع» على أقوال: الأول: أنها التجارة ومنافع الدنيا. الثاني: الأجر في الآخرة والتجارة في الدنيا. الثالث: العفو والمغفرة. ورجَّح ابنُ جرير (١٦/٥٢٢) مستندًا إلى دلالة العموم شمول المعنى لجميع المنافع، فقال: «وأولى الأقوال بالصواب قولُ مَن قال: عنى بذلك: ليشهدوا منافع لهم مِن العمل الذي يرضي الله والتجارة؛ وذلك أن الله عمَّ <q>﴿مَنافِعَ لَهُمْ﴾</q> جميع ما يشهد له الموسم، ويأتي له مكة أيام الموسم؛ من منافع الدنيا والآخرة، ولم يَخْصُصْ من ذلك شيئًا من منافعهم بخبرٍ ولا عقل، فذلك على العموم في المنافع التي وصَفْتُ». <q>﴿وَیَذۡكُرُوا۟ ٱسۡمَ ٱللَّهِ﴾</q> - تفسير ٥٠٤٦٩- عن قتادة بن دعامة، في قوله: <q>﴿ويذكروا اسم الله﴾</q>، قال: كان يقال: إذا ذبحتَ نسيكتك فقل: بسم الله، والله أكبر، اللهم هذا منك ولك عن فلان، ثم كل وأطعم -كما أمرك الله- الجارَ والأقرب فالأقرب{11}. (١٠/٤٧٤) ٥٠٤٧٠- قال مقاتل بن سليمان: <q>﴿و﴾</q> لكي <q>﴿يذكروا اسم الله﴾</q>{10}. (ز) ٥٠٤٧١- عن مقاتل [بن حيان]، في قوله: <q>﴿ويذكروا اسم الله﴾</q>، قال: فيما ينحرون مِن البُدن{2}٤٤٥٩. (١٠/٤٧٤) ٤٤٥٩ ذكر ابنُ عطية (٦/٢٣٩-٢٤٠) أنه قد يأتي «ذكر اسم الله» في الآية «بمعنى: حمده وتقديسه شكرًا على نعمته في الرزق، ويؤيده قوله -عليه الصلاة والسلام-: «إنها أيام أكل، وشُرب، وذِكر الله»»، وعليه فـ«يصح أن يريد بالاسم هاهنا: المسمى، بمعنى: ويذكروا الله، على تجوُّزٍ في هذه العبارة، إلا أن يقصد ذكر القلوب، ويحتمل أن يريد بالاسم التسميات، وذكر الله تعالى إنما هو بذكر أسمائه، ثم يذكر القلب السلطان والصفات». <q>﴿فِیۤ أَیَّامࣲ مَّعۡلُومَـٰتٍ عَلَىٰ مَا رَزَقَهُم مِّنۢ بَهِیمَةِ ٱلۡأَنۡعَـٰمِۖ﴾</q> - تفسير ٥٠٤٧٢- عن علي [بن أبي طالب]، قال: الأيام المعلومات: يوم النحر، وثلاثة أيام بعده{14}. (١٠/٤٧٥) ٥٠٤٧٣- عن عبد الله بن عباس، قال: عشر ذي الحجة، آخرها يوم النحر{15}. (١٠/٤٧٤) ٥٠٤٧٤- عن عبد الله بن عباس -من طريق عمرو بن دينار- قال: الأيام المعدودات: أيام التشريق. والأيام المعلومات: أيام العشر{16}. (ز) ٥٠٤٧٥- عن عبد الله بن عباس، في قوله: <q>﴿في أيام معلومات﴾</q>، قال: قبل يوم التروية بيوم، ويوم التروية، ويوم عرفة{17}. (١٠/٤٧٥) ٥٠٤٧٦- عن عبد الله بن عباس -من طريق سعيد بن جبير- قال: الأيام المعلومات: التي قبل يوم التروية، ويوم التروية، ويوم عرفة. والمعدودات: أيام التشريق{18}. (ز) ٥٠٤٧٧- عن عبد الله بن عباس -من طريق مِقْسَم- قال: الأيام المعلومات: يوم النحر، وثلاثة أيام بعده{19}. (١٠/٤٧٤) ٥٠٤٧٨- عن عبد الله بن عباس -من طريق عطية العوفي- <q>﴿في أيام معلومات﴾</q>: يعني: أيام التشريق{20}. (١٠/٤٧٤) ٥٠٤٧٩- عن عبد الله بن عمر -من طريق نافع- قال: الأيام المعلومات والمعدودات هن جميعهن أربعة أيام، فالمعلومات يوم النحر ويومان بعده، والمعدودات ثلاثة أيام بعد يوم النحر{21}٤٤٦٠. (١٠/٤٧٥) ٤٤٦٠ ذكر ابنُ كثير (١٠/٤٦) هذا الأثر من رواية ابن أبي حاتم بسنده عن أبيه، عن علي بن المديني، عن يحيى بن سعيد، عن ابن عجلان، عن نافع، عن ابن عمر موقوفًا، ثم علَّق عليه بقوله: «هذا إسناد صحيح إليه ... ويعضد هذا القول والذي قبله -وهو أن الأيام المعلومات: يوم النحر، وثلاثة أيام بعده- قوله تعالى: <q>﴿عَلى ما رَزَقَهُمْ مِن بَهِيمَةِ الأَنْعامِ﴾</q>، يعني به: ذكر الله عند ذبحها». وذكر ابنُ عطية (٦/٢٤٠) بأنّ مِمَّن قال بهذا القول مالك وأصحابه، ثم وجَّهه بقوله: «وحمل هؤلاء على هذا التفصيل أنهم أخذوا»ذكر اسم الله«هنا على الذبح للأضاحي والهدي وغيره، فاليوم الرابع لا يُضَحّى فيه عند مالك وجماعة، وأخذوا التَّعجُّل والتأخر بالنَّفْر في الأيام المعدودات، فتأمل هذا يَبِنْ لك قصدهم». ثم ذهب مستندًا إلى الظاهر من الآية إلى «أن تكون المعلومات والمعدودات بمعنًى، أي: تلك الأيام الفاضلة كلها، ويبقى أمر الذبح وأمر الاستعجال لا يتعلق بمعدود ولا بمعلوم، وتكون فائدة قوله: <q>﴿مَعْلُوماتٍ﴾</q> و<q>﴿مَعْدُوداتٍ﴾</q> [البقرة:٢٠٣] التحريض على هذه الأيام، وعلى اغتنام فضلها؛ إذ ليست كغيرها، فكأنه قال: هي مخصوصات فَلْتُغْتَنَم». ٥٠٤٨٠- عن عطاء= (ز) ٥٠٤٨١- ومجاهد بن جبر، قال: الأيام المعلومات: أيام العشر{22}. (١٠/٤٧٥) ٥٠٤٨٢- عن سعيد بن جبير= (ز) ٥٠٤٨٣- والحسن البصري، مثله{22}. (١٠/٤٧٥) ٥٠٤٨٤- عن الضَّحّاك بن مُزاحِم -من طريق عبيد بن سليمان-: <q>﴿في أيام معلومات﴾</q> يعني: أيام التشريق، <q>﴿على ما رزقهم من بهيمة الأنعام﴾</q> يعني: البدن{24}. (١٠/٤٧٥) ٥٠٤٨٥- عن قتادة بن دعامة -من طريق مَعْمَر- <q>﴿في أيام معلومات﴾</q>، قال: أيام العشر. والمعدودات: أيام التشريق{24}. (ز) ٥٠٤٨٦- قال محمد بن كعب القرظي: المعدودات والمعلومات واحدة{8}. (ز) ٥٠٤٨٧- قال مقاتل: المعلومات: أيام التشريق{4}. (ز) ٥٠٤٨٨- قال مقاتل بن سليمان: <q>﴿في أيام معلومات﴾</q> يعني: ثلاثة أيام؛ يوم النحر ويومين بعده إلى غروب الشمس، <q>﴿على ما رزقهم من بهيمة الأنعام﴾</q>{28}. (ز) ٥٠٤٨٩- قال يحيى بن سلّام: قوله: <q>﴿على ما رزقهم من بهيمة الأنعام﴾</q> يسمِّي إذا نحر أو ذبح، والأضحى ثلاثة أيام: يوم النحر ويومان بعده، ويوم النحر أفضلها{29}٤٤٦١. (ز) ٤٤٦١ ذكر ابنُ تيمية (٤/٤٢٣- ٤٢٤) قولين في: «ذكر اسم الله» بناءً على الخلاف الوارد في «الأيام المعلومات»، فمَن قال بأن «الأيام المعلومات»: أيام الذبح؛ قال بأن «ذكر اسم الله»: التسمية على الأضحية والهدي. ومَن قال بأن «الأيام المعلومات»: أيام العشر؛ قال بأن «ذكر اسم الله»: التكبير فيها. ثم ذكر استدلالات ومناقشات لكلا القولين ليس هذا موضع بسطها. <q>﴿فَكُلُوا۟ مِنۡهَا وَأَطۡعِمُوا۟ ٱلۡبَاۤىِٕسَ ٱلۡفَقِیرَ ۝٢٨﴾</q> - نزول الآية ٥٠٤٩٠- عن إبراهيم [النخعي]، قال: كان المشركون لا يأكلون مِن ذبائح نسائهم، فنزلت: <q>﴿فكلوا منها وأطعموا البائس الفقير﴾</q>، فرخص للمسلمين، فمن شاء أكل؛ ومن شاءلم يأكل{30}. (١٠/٤٧٥) ٥٠٤٩١- عن الحسن البصري -من طريق أبي بكر الهذلي- قال: كان الناسُ في الجاهلية إذا ذبحوا لَطَّخوا بالدماء وجه الكعبة، وشَرَّجُوا{31} اللحوم، فوضعوها على الحجارة، وقالوا: لا يحِلُّ لنا نأكل شيئًا جعلناه لله ﷿ حتى تأكله السباع والطير. فلما جاء الإسلام جاء الناسُ رسولَ الله ﷺ، فقالوا له: شيئًا كُنّا نصنعه في الجاهلية، ألا نصنعه الآن؟ فإنما هو لله ﷿. فأنزل الله ﷿: <q>﴿فكلوا منها وأطعموا﴾</q>. فقال رسول الله ﷺ: «لا تفعلوا؛ فإنّ ذلك ليس لله ﷿». قال الحسن: فلم يعزِم عليهم الأكل، فإن شئت فكُل، وإن شئت فدَع{32}. (ز) ٥٠٤٩٢- قال مقاتل بن سليمان: ... وذلك أنّ أهل الجاهلية كانوا لا يأكلون شيئًا مِن البُدُن، فأنزل الله ﷿: <q>﴿فكلوا منها وأطعموا﴾</q>{33}. (ز) <q>﴿فَكُلُوا۟ مِنۡهَا وَأَطۡعِمُوا۟ ٱلۡبَاۤىِٕسَ ٱلۡفَقِیرَ ۝٢٨﴾</q> - تفسير الآية ٥٠٤٩٣- عن عبد الله بن عباس -من طريق العوفي- في قوله: <q>﴿وأطعموا البائس﴾</q>، قال: الزَّمِن{34}. (١٠/٤٧٧) ٥٠٤٩٤- عن عبد الله بن عباس: أن نافع بن الأزرق قال له: أخبِرني عن قول الله: <q>﴿وأطعموا البائس الفقير﴾</q>. قال: البائِس: الذي لم يجد شيئًا من شِدَّة الحاجة. قال: وهل تعرف العرب ذلك؟ قال: نعم، أما سمعت طرفة وهو يقول: يغشاهم البائسُ المُدْقِعُ والضيـ ـفُ وجارٌ مجاورٌ جُنُبُ؟{35}. (١٠/٤٧٧) ٥٠٤٩٥- عن مجاهد بن جبر، في قوله: <q>﴿البائس الفقير﴾</q>، قال: هما سواء{14}. (١٠/٤٧٧) ٥٠٤٩٦- عن مجاهد بن جبر -من طريق أبي يحيى- قوله: <q>﴿فكلوا منها وأطعموا البائس الفقير﴾</q>، قال: الضعيف الفقير{37}. (ز) ٥٠٤٩٧- عن مجاهد بن جبر= (ز) ٥٠٤٩٨- وعكرمة مولى ابن عباس، قالا: البائس: الذي يمد كَفَّيه إلى الناس يسأل{22}. (١٠/٤٧٧) ٥٠٤٩٩- عن عكرمة مولى ابن عباس -من طريق عمر بن عطاء- قال: البائس: المُضطر الذي عليه البؤس، والفقير المتعفف{39}. (١٠/٤٧٧) ٥٠٥٠٠- عن قتادة بن دعامة، قال: <q>﴿البائس الفقير﴾</q> الذي به زَمانة وهو فقير{40}. (١٠/٤٧٧) ٥٠٥٠١- قال مقاتل بن سليمان: <q>﴿فكلوا منها وأطعموا البائس﴾</q>، يعني: الضرير الزَّمِن الفقير الذي ليس له شيء{10}. (ز) ٥٠٥٠٢- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿البائس الفقير﴾</q>، قال: هو القانِع{42}. (ز) <q>﴿فَكُلُوا۟ مِنۡهَا وَأَطۡعِمُوا۟ ٱلۡبَاۤىِٕسَ ٱلۡفَقِیرَ ۝٢٨﴾</q> - من أحكام الآية ٥٠٥٠٣- عن جابر بن عبد الله، قال: نَحَر رسولُ الله ﷺ ستةً وستين بدنة، ونحر عَلِيٌّ أربعة وثلاثين، ثم أمر رسول الله ﷺ مِن كل جزور بضعة، فجُعِلَت في قِدر، فأكل رسولُ الله ﷺ وعَلِيٌّ مِن اللحم، وحَسَوا مِن المَرَق. قال سفيان: لأنّ الله يقول: <q>﴿فكلوا منها﴾</q>{43}. (١٠/٤٧٧) ٥٠٥٠٤- عن مجاهد، في قوله: <q>﴿فكلوا منها﴾</q>: أنّ ابن مسعود كان يقول للذي يبعث بهديِهِ معه: كُلْ ثُلُثًا، وتَصَدَّق بالثُّلُث، واهدِ لآل عتبة ثلثًا{44}. (١٠/٤٧٦) ٥٠٥٠٥- عن ناعم مولى أم سلمة: أنّه حضر عليًّا بالكوفة يوم أضحى، فخطب ثم نزل، فاتبعته، فدعا بتيس، فذبحه، فذكر اسم الله، ثم قال: عن علي وعن آل علي. ثم لم يبرح حتى قسَّم لحمه، ففَضُلَ منه شيء، فبعثه إلى أهله{37}. (ز) ٥٠٥٠٦- عن عائشة ابنة سعد بن مالك -من طريق عثمان-: أنّ أباها كان يأكل من بدنته قبل أن يُطْعِم{46}. (ز) ٥٠٥٠٧- عن عبد الله بن عمر -من طريق نافع-: أنّه كان يُطْعم من بُدْنه [قبل أن] يأكل لا يرى بذلك بأسًا، يقول: <q>﴿فكلوا منها وأطعموا﴾</q>، وأطعموا منها وكلوا منها، هما سواء، لا يرى بأسًا أن يطعم منها قبل أن يأكل{37}. (ز) ٥٠٥٠٨- عن سعيد بن المسيب -من طريق الزهري- قال: ليس لصاحب البدنة منها إلا ربعُها{37}٤٤٦٢. (ز) ٤٤٦٢ علَّق ابنُ عطية (٦/٢٥١) على قول ابن مسعود، وابن المسيب قائلًا: «وهذا كله على جهة الاستحسان، لا على الفرض». ٥٠٥٠٩- عن مجاهد بن جبر -من طريق حُصين- في الآية، قال: هي رخصة، إن شاء أكل، وإن شاء لم يأكل؛ بمنزلة قوله: <q>﴿واذ حللتم فاصطادوا﴾</q> [المائدة:٢]، <q>﴿فإذا قضيت الصلاة فانتشروا في الأرض﴾</q> [الجمعة:١٠]. يعني: قوله: <q>﴿فكلوا منها وأطعموا القانع والمعتر﴾</q>{49}. (١٠/٤٧٦) ٥٠٥١٠- عن عطاء [بن أبي رباح] -من طريق ابن جريج- في قوله: <q>﴿فكلوا منها وأطعموا البائس الفقير﴾</q>، قال: كان لا يرى الأكل منها واجبًا{50}. (١٠/٤٧٦) ٥٠٥١١- عن عطاء، <q>﴿فكلوا منها وأطعموا﴾</q>، قال: إذا ذبحتم فابدءوا فكلوا وأطعِموا، وأقلِّوا لحوم الأضاحي عندكم{22}. (١٠/٤٧٦) ٥٠٥١٢- عن الحسن البصري -من طريق الحسن بن دينار- قال: هي مُقَدَّمة مُؤَخَّرة؛ <q>﴿فكلوا منها وأطعموا﴾</q> وأطعموا منها وكلوا، لا بأس أن يُطعم منها قبل أن يأكل، وإن شاء لم يأكل منها{46}. (ز) ٥٠٥١٣- قال يحيى بن سلّام: وبلغني عن الحسن [البصري] قال: لا يطعم من الأضحية أقلّ مِن الربع{53}. (ز) ٥٠٥١٤- عن محمد بن علي بن الحسين -من طريق ابنه جعفر- قال: أُطعِمُ البائسَ الفقيرَ ثلثًا، وأُطعِمُ القانعَ والمُعْتَرَّ ثلثًا، وأُطعِم أهلي ثلثًا{37}. (ز) ٥٠٥١٥- عن أبي صالح الحنفي، <q>﴿فكلوا منها وأطعموا البائس الفقير﴾</q>، قال: هي في الأضاحي{22}. (١٠/٤٧٦) ٥٠٥١٦- قال مقاتل بن سليمان: <q>﴿فكلوا منها وأطعموا﴾</q>، فليس الأكل بواجب، ولكنه رخصة، كقوله سبحانه: <q>﴿وإذا حللتم فاصطادوا﴾</q> [المائدة:٢]، وليس الصيد بواجب، ولكنه رخصة{33}. (ز) ",footnotes:1:أخرجه ابن جرير ١٦/٥٢٠ مختصرًا. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.عزاه السيوطي إلى ابن أبي حاتم.أخرجه ابن جرير ١٦/٥٢٠.تفسير الثعلبي ٧/١٩، وتفسير البغوي ٥/٣٧٩.أخرجه الثوري في تفسيره ص٢١١، وابن جرير ١٦/٥٢٠.أخرجه يحيى بن سلام ١/٣٦٥ من طريق عاصم بن حكيم، وابن جرير ١٦/٥٢١. وعزاه السيوطي إلى عبد بن حميد. وعقَّب عليه يحيى بن سلام بقوله: وذلك أنهم كانوا يتبايعون في الموسم، وكانت لهم في ذلك منفعة.أخرجه الثوري في تفسيره ص٢١١.تفسير الثعلبي ٧/١٩.أخرجه ابن جرير ١٦/٥٢١-٥٢٢.تفسير مقاتل بن سليمان ٣/١٢٣.عزاه السيوطي إلى عبد بن حميد، وابن أبي حاتم.تفسير مقاتل بن سليمان ٣/١٢٣.عزاه السيوطي إلى ابن أبي حاتم.عزاه السيوطي إلى ابن المنذر.أخرجه يحيى بن سلام ١/٣٦٥، ولم يتبين الراوي في المخطوط كما يفهم من كلام محققته. وعزاه السيوطي إلى أبي بكر المروزي في كتاب العيدين، وابن أبي حاتم بلفظ: الأيام المعلومات أيام العشر.أخرجه عبد بن حميد -كما في فتح الباري ٢/٤٥٨-.عزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه ابن مردويه -كما في فتح الباري ٢/٤٥٨-.أخرجه ابن أبي حاتم ٢/٣٦١. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه ابن جرير ١٦/٥٢٢-٥٢٣.أخرجه ابن أبي حاتم -كما في تفسير ابن كثير ٥/٤١٢. وعزاه السيوطي إلى ابن المنذر.عزاه السيوطي إلى عبد بن حميد.عزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ١٦/٥٢٣.أخرجه ابن جرير ١٦/٥٢٣.تفسير الثعلبي ٧/١٩.تفسير الثعلبي ٧/١٩، وتفسير البغوي ٥/٣٧٩.تفسير مقاتل بن سليمان ٣/١٢٣. وقد تقدم في تفسير قوله تعالى: <q>﴿واذْكُرُوا اللَّهَ فِي أيّامٍ مَعْدُوداتٍ﴾</q> [البقرة:٢٠٣] آثار أكثر مما ورد هنا.تفسير يحيى بن سلام ١/٣٦٥.عزاه السيوطي إلى عبد الرزاق، وسعيد بن منصور، وعبد بن حميد، وابن المنذر، وابن أبي حاتم، وهو مرسل.شَرَّجوا اللحوم: أي خلطوها بالشحم. اللسان (شرج).سيرة ابن إسحاق ص ٧٨-٧٩، وهو مرسل.تفسير مقاتل بن سليمان ٣/١٢٦.أخرجه ابن جرير ١٦/٥٢٤-٥٢٥.أخرجه الطستي -كما في الإتقان ٢/٧٧-.عزاه السيوطي إلى ابن المنذر.أخرجه يحيى بن سلام ١/٣٦٦.عزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ١٦/٥٢٥. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم بلفظ: الفقير الضعيف.علقه يحيى بن سلام ١/٣٦٦. وعزاه السيوطي إلى عبد بن حميد.تفسير مقاتل بن سليمان ٣/١٢٣.أخرجه ابن جرير ١٦/٥٢٥.أخرجه ابن حبان ٩/٣٢٨، ويحيى بن سلام ١/٣٦٧ كلاهما بنحوه من طرق، عن جعفر بن محمد، عن أبيه، عن جابر. وعزاه السيوطي إلى ابن أبي حاتم. إسناده صحيح.عزاه السيوطي إلى ابن أبي حاتم. وأخرجه يحيى بن سلام ١/٣٦٦ من طريق الحجاج بن أرطاة: أنه بعث بهدي مع علقمة، وأمره أن يأكل هو وأصحابه ثلثًا، وأن يبعث إلى أهل عتبة بن مسعود ثلثًا، وأن يطعم المساكين ثلثًا.أخرجه يحيى بن سلام ١/٣٦٦.أخرجه يحيى بن سلام ١/٣٦٧.أخرجه يحيى بن سلام ١/٣٦٦.أخرجه يحيى بن سلام ١/٣٦٦.أخرجه ابن جرير ١٦/٥٢٣-٥٢٤، والبيهقي في سننه ٥/٢٤١. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه ابن جرير ١٦/٥٢٣، وأخرجه عبد بن حميد -كما في فتح الباري ٣/٥٥٨- بلفظ: إن شاء أكل من الهدي والأضحية، وإن شاء لم يأكل.عزاه السيوطي إلى عبد بن حميد.أخرجه يحيى بن سلام ١/٣٦٧.علَّقه يحيى بن سلام ١/٣٦٦.أخرجه يحيى بن سلام ١/٣٦٦.عزاه السيوطي إلى عبد بن حميد.تفسير مقاتل بن سليمان ٣/١٢٦.
22,29," <q>﴿ثُمَّ لۡیَقۡضُوا۟ تَفَثَهُمۡ﴾</q> - تفسير ٥٠٥١٧- عن عبد الله بن عباس -من طريق عطية العوفي- قال: قضاء التَّفَث: قضاء النسك كله{1}. (١٠/٤٧٨) ٥٠٥١٨- عن عبد الله بن عباس -من طريق عطاء- أنّه قال في التَّفَث: حلق الرأس، والأخذ من العارِضَين، ونتف الإبط، وحلق العانَة، والوقوف بعرفة، والسعي بين الصفا والمروة، ورمي الجمار، وقصَّ الأظفار، وقص الشارب، والذبح{2}. (١٠/٤٧٨) ٥٠٥١٩- عن عبد الله بن عباس -من طريق علي- في قوله: <q>﴿ثم ليقضوا تفثهم﴾</q>، قال: يعني بالتفث: وضع إحرامهم؛ مِن حلق الرأس، ولبس الثياب، وقص الأظفار، ونحو ذلك{3}. (١٠/٤٧٨) ٥٠٥٢٠- عن عبد الله بن عمر -من طريق نافع- قال: التفث: المناسك كلها{4}. (١٠/٤٧٨) ٥٠٥٢١- عن مجاهد بن جبر -من طريق ابن أبي نجيح- <q>﴿ثم ليقضوا تفثهم﴾</q>، قال: حلق الرأس، والعانة، ونتف الإبط، وقص الشارب، والأظفار، ورمي الجمار، وقص اللحية{5}. (١٠/٤٧٩) ٥٠٥٢٢- عن الضَّحّاك بن مُزاحِم -من طريق عبيد- في قوله: <q>﴿ثم ليقضوا تفثهم﴾</q>، قال: حلق الرأس{6}. (ز) ٥٠٥٢٣- عن عكرمة مولى ابن عباس، <q>﴿ثم ليقضوا تفثهم﴾</q>، قال: التَّفَث: كل شيء أحرموا منه{7}. (١٠/٤٧٨) ٥٠٥٢٤- عن عكرمة مولى ابن عباس -من طريق خالد- قال: التفث: الشعر والظفر{8}. (ز) ٥٠٥٢٥- عن الحسن البصري -من طريق منصور- أنه قال: حلق الرأس{8}. (ز) ٥٠٥٢٦- عن الحسن البصري -من طريق المبارك بن فضالة- قال: التفث: ذا الشعث، وذا التقشف{10}. (ز) ٥٠٥٢٧- عن الحسن البصري -في تفسير عمرو [بن عبيد]- <q>﴿تفثهم﴾</q>: تقشف الإحرام برميهم الجمار يوم النحر؛ فقد حَلَّ لهم كل شيء غير النساء{11}. (ز) ٥٠٥٢٨- عن عطاء [بن أبي رباح] -من طريق قيس بن سعد- قال: التفث: حلق الشعر، وقطع الأظفار{10}. (ز) ٥٠٥٢٩- عن محمد بن كعب القرظي -من طريق موسى بن عقبة- قال: التفث: حلق العانة، ونتف الإبط، وأخذ من الشارب، وتقليم الأظافر{13}. (١٠/٤٧٩) ٥٠٥٣٠- عن محمد بن كعب القرظي -من طريق أبي صخر- أنّه كان يقول في هذه الآية: <q>﴿ثم ليقضوا تفثهم﴾</q>: رمي الجمار، وذبح الذبيحة، وأخذ مِن الشاربين، واللحية، والأظفار، والطواف بالبيت، وبالصفا والمروة{14}. (ز) ٥٠٥٣١- عن قتادة بن دعامة -من طريق معمر- قال: التفث: حلق الرأس{15}. (ز) ٥٠٥٣٢- عن عطاء بن السائب -من طريق جرير- قال: التفث: حلق الشعر، وقص الأظفار، والأخذ من الشارب، وحلق العانة، وأمر الحج كله{16}. (ز) ٥٠٥٣٣- عن عطاء الخراساني -من طريق يونس- في قول الله ﷿: <q>﴿ليقضوا تفثهم﴾</q>، قال: التفث: تفث الحج، حلق الرأس، ورمي الجمار، ونحو ذلك{17}. (ز) ٥٠٥٣٤- قال مقاتل بن سليمان: <q>﴿ثم ليقضوا تفثهم﴾</q>، يعني: حلق الرأس، والذَّبح، والجِمار{18}. (ز) ٥٠٥٣٥- عن عبد الملك ابن جُرَيْج -من طريق المحاربي، عن رجل- أنّه سُئِل عن قوله: <q>﴿ثم ليقضوا تفثهم﴾</q>. فقال: الأخذ من اللحية، ومِن الشارب، وتقليم الأظفار، ونتف الإبط، وحلق العانة، ورمي الجمار{19}. (ز) <q>﴿وَلۡیُوفُوا۟ نُذُورَهُمۡ﴾</q> - قراءات ٥٠٥٣٦- عن عاصم أنه قرأ: ‹ولْيُوَفُّواْ نُذُورَهُمْ› مثقله بجزم اللام، <q>﴿ولْيَطَّوَّفُواْ﴾</q> بجزم اللام مثقلة{20}. (١٠/٤٧٩) <q>﴿وَلۡیُوفُوا۟ نُذُورَهُمۡ﴾</q> - تفسير الآية ٥٠٥٣٧- عن عبد الله بن عباس -من طريق علي- في قوله: <q>﴿وليوفوا نذورهم﴾</q>، قال: يعني: نحر ما نذروا من البُدن{3}. (١٠/٤٧٨) ٥٠٥٣٨- عن عكرمة مولى ابن عباس، <q>﴿وليوفوا نذورهم﴾</q>، قال: هو الحجُّ{7}. (١٠/٤٧٨) ٥٠٥٣٩- عن مجاهد بن جبر -من طريق ابن أبي نجيح، وابن جُرَيْج- <q>﴿وليوفوا نذورهم﴾</q>، قال: نذر الحج، والهدي، وما نذره الإنسان مِن شيء يكون في الحج{23}. (١٠/٤٧٨) ٥٠٥٤٠- عن عطاء، أو مجاهد بن جبر -من طريق إبراهيم الخوزي- قال: نذور كانت عليهم؛ فأُمِروا بالذبح{24}. (ز) ٥٠٥٤١- عن قتادة بن دعامة -من طريق سعيد- قوله: <q>﴿وليوفوا نذورهم﴾</q>، قال: أيامٌ عَظَّمها الله؛ تُحْلَق فيها الأشعار، ويُوفى فيها بالنذر، وتُذبَح فيها الذبائح{11}. (ز) ٥٠٥٤٢- قال مقاتل بن سليمان: <q>﴿وليوفوا﴾</q> يعني: لكي يوفوا <q>﴿نذورهم﴾</q> في حجٍّ أو عمرة بما أوجبوا على أنفسهم مِن هديٍ أو غيره{18}. (ز) <q>﴿وَلۡیَطَّوَّفُوا۟﴾</q> - تفسير ٥٠٥٤٣- عن عبد الله بن عباس -من طريق علي- <q>﴿وليطوفوا﴾</q>، قال: يعني: زيارة البيت. وفي لفظ: هو طواف الزيارة يوم النحر{27}. (١٠/٤٧٩) ٥٠٥٤٤- عن عبد الله بن عباس، قال: طواف الوداع واجب، وهو قول الله: <q>﴿وليطوفوا بالبيت العتيق﴾</q>{28}. (١٠/٤٨١) ٥٠٥٤٥- عن أبي جمرة، قال: قال لي ابن عباس: أتقرأُ سورةَ الحج؟ يقول الله: <q>﴿ثم ليقضوا تفثهم وليوفوا نذورهم وليطوفوا بالبيت العتيق﴾</q>، قال: فإن آخر المناسك الطواف بالبيت{29}. (١٠/٤٨١) ٥٠٥٤٦- عن سعيد بن جبير -من طريق عبد الكريم- قال: هو طواف يوم النحر{30}. (ز) ٥٠٥٤٧- عن مجاهد بن جبر، في قوله: <q>﴿وليطوفوا﴾</q>، قال: هو الطواف الواجب يوم النحر{31}. (١٠/٤٧٩) ٥٠٥٤٨- عن الضحاك بن مزاحم، <q>﴿وليطوفوا﴾</q>، قال: طواف الزيارة{32}. (١٠/٤٧٩) ٥٠٥٤٩- عن الحسن البصري -من طريق أشعث- <q>﴿وليطوفوا بالبيت العتيق﴾</q>، قال: طواف الزيارة{33}. (ز) ٥٠٥٥٠- عن قتادة بن دعامة -من طريق سعيد- في قوله في هذه الآية: <q>﴿وليطوفوا بالبيت العتيق﴾</q>، قال: هو الطواف الواجب{11}. (ز) ٥٠٥٥١- عن عطاء [بن أبي رباح] -من طريق حجاج، وعبد الملك- في قوله: <q>﴿وليطوفوا بالبيت العتيق﴾</q>، قال: طواف يوم النحر{33}. (ز) ٥٠٥٥٢- عن عمرو بن أبي سلمة، قال: سألت زهير [بن محمد العنبري] عن قول الله: <q>﴿وليطوفوا بالبيت العتيق﴾</q>. قال: طواف الوداع{33}. (ز) <q>﴿بِٱلۡبَیۡتِ ٱلۡعَتِیقِ ۝٢٩﴾</q> - تفسير ٥٠٥٥٣- عن عبد الله بن الزبير، قال: قال رسول الله ﷺ: «إنما سمى الله البيت العتيق؛ لأن الله أعتقه مِن الجبابرة، فلم يظهر عليه جبّارٌ قطُّ»{37}. (١٠/٤٨٠) ٥٠٥٥٤- قال عبد الله بن الزبير -من طريق معمر، عن الزهري-: إنما سُمِّي: البيت العتيق؛ لأنّ الله أعتقه مِن الجبابرة{38}. (ز) ٥٠٥٥٥- عن عبد الله بن عباس، قال: البيت العتيق أُعْتِق مِن الجبابرة{39}. (١٠/٤٨٠) ٥٠٥٥٦- عن سعيد بن جبير، قال: إنما سُمِّي: البيت العتيق؛ لأنه أُعْتِق مِن الغرق في زمان نوح{40}. (١٠/٤٨٠) ٥٠٥٥٧- عن مجاهد بن جبر -من طريق ابن أبي نجيح- قال: إنما سُمِّي: البيت العتيق؛ لأنه أُعْتِق من الجبابرة، لم يَدَّعِهِ جبارٌ قط. وفي لفظ: فليس في الأرض جبّار يدَّعي أنه له{41}. (١٠/٤٨٠) ٥٠٥٥٨- عن مجاهد بن جبر -من طريق الحسن بن مسلم- قال: إنما سُمِّي: البيت العتيق؛ لأنه لم يُرِدْه أحدٌ بسوء إلا هلك{42}. (١٠/٤٨٠) ٥٠٥٥٩- عن مجاهد بن جبر -من طريق عبيد- قال: إنما سُمِّي: البيت العتيق؛ لأنه ليس لأحد فيه شيء{43}. (ز) ٥٠٥٦٠- عن الحسن البصري -من طريق قتادة- قال: إنما سُمِّي: العتيق؛ لأنه أول بيت وضع{44}. (١٠/٤٨١) ٥٠٥٦١- عن قتادة بن دعامة -من طريق سعيد- قوله: <q>﴿وليطوفوا بالبيت العتيق﴾</q>، قال: أعتقه الله من الجبابرة، كم من جبّار مُتْرَفٍ قد صار إليه يريد أن يهدمه، فحال الله بينه وبينه{45}. (ز) ٥٠٥٦٢- قال مقاتل بن سليمان: <q>﴿وليطوفوا بالبيت العتيق﴾</q>، أُعْتِق في الجاهلية مِن القتل، والسبي، والخراب{18}. (ز) ٥٠٥٦٣- قال سفيان الثوري: <q>﴿بالبيت العتيق﴾</q> عتق مِن الجبارة{47}، ليس لأحد فيه شيء{48}. (ز) ٥٠٥٦٤- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿البيت العتيق﴾</q>، قال: العتيق: القديم؛ لأنه قديم، كما يقال: السيف العتيق؛ لأنه أول بيت وضع للناس، بناه آدم، وهو أول مَن بناه، ثم بوَّأ الله موضعه لإبراهيم بعد الغرق، فبناه إبراهيم وإسماعيل{43}. (ز) ٥٠٥٦٥- قال سفيان بن عيينة: سُمِّي بذلك: عتيقًا؛ لأنه لم يُملَك قط{50}٤٤٦٣. (ز) ٤٤٦٣ أفادت الآثار اختلاف المفسرين في وجْه وصْف البيت بـ«العتيق» على أقوال: الأول: لأنّ الله أعتقه من الجبابرة. الثاني: لأنه لم يَمْلِكه أحدٌ من الناس. الثالث: سمي بذلك لقدمه. وبيَّن ابنُ جرير (١٦/٥٣١) أن لكل قول من هذه الأقوال وجْهٌ صحيح، ورجَّح أن أغلب معانيه في الظاهر هو القول الثالث، ثم بيَّن أنه إن صح الحديث الذي قال به أصحاب القول الأول لكان هذا القول أوْلى بالصحة، فقال: «ولكلِّ هذه الأقوال التي ذكرناها عمَّن ذكرناها عنه في قوله: <q>﴿البيت العتيق﴾</q> وجْه صحيح، غير أن الذي قاله ابن زيد أغلب معانيه عليه في الظاهر، غير أن الذي رُوِيَ عن ابن الزبير أوْلى بالصحة إن كان ما حدثني به محمد بن سهل البخاري قال: ثنا عبد الله بن صالح، قال: أخبرني الليث، عن عبد الرحمن بن خالد بن مسافر، عن الزهري، عن محمد بن عروة، عن عبد الله بن الزبير، قال: قال رسول الله ﷺ: «إنما سُمِّيَ: البيت العتيق؛ لأن الله أعتقه من الجبابرة، فلم يُظهَر عليه قطُّ» صحيحًا». وعلَّق ابنُ عطية (٦/٢٤٢) على القول الثالث قائلًا: «وهذا قول يعضده النظر؛ إذ هو أول بيت وضع للناس». غير أنه انتقده، ورجَّح القول الأول مستندًا إلى السنة، فذكر حديث ابن الزبير، ثم قال: «ولا نظر مع الحديث». وذَكَر ابن عطية قولًا آخر غير ما تقدم، وهو أن البيت سُمِّي: عتيقًا؛ لأنّ الله تعالى يُعتِق فيه رقاب المذنبين من العذاب، وانتقده مستندًا إلى لغة العرب بقوله: «وهذا يَرُدُّه التصريف». <q>﴿بِٱلۡبَیۡتِ ٱلۡعَتِیقِ ۝٢٩﴾</q> - من أحكام الآية ٥٠٥٦٦- عن عبد الله بن عباس، قال: لَمّا نزلت هذه الآية: <q>﴿وليطوفوا بالبيت العتيق﴾</q> طاف رسولُ الله ﷺ مِن ورائه{51}. (١٠/٤٨١) ٥٠٥٦٧- عن عبد الله بن عباس -من طريق طاووس أو غيره- قال: الحِجر مِن البيت؛ لأنّ رسول الله ﷺ طاف بالبيت مِن ورائه، وقال الله تعالى: <q>﴿وليطوفوا بالبيت العتيق﴾</q>{52}. (١٠/٤٨١) ٥٠٥٦٨- عن صُرَدِ بن أبي المُنازِل، قال: سمعتُ حبيب بن أبي فَضالة المكي قال: لَمّا بني هذا المسجدُ -مسجد الجامع- قال: وعمران بن حصين جالِسٌ، فذكروا عنده الشفاعة، فقال رجلٌ من القوم: يا أبا نُجَيْد، لَتُحَدِّثونا بأحاديث ما نجد لها أصلًا في القرآن؟ فغضِب عمران بن حصين، وقال لرجل: قرأت القرآن؟ قال: نعم. قال: وجدت فيه صلاة المغرب ثلاثًا، وصلاة العشاء أربعًا، وصلاة الغداة ركعتين، والأولى أربعًا، والعصر أربعًا؟ قال: لا، قال: فعَمَّن أخذتم هذا الشأن؟ ألستم أخذتموه عنّا، وأخذناه عن رسول الله ﷺ؟ أوَجدتم في كل أربعين درهمًا درهم؟ وفي كل كذا وكذا شاة؟ وفي كل كذا وكذا بعير كذا؟ أوجدتم في القرآن؟ قال: لا. قال: فعمَّن أخذتم هذا؟ أخذناه عن رسول الله ﷺ، وأخذتُموه عَنّا، قال: فهل وجدتم في القرآن <q>﴿وليطوفوا بالبيت العتيق﴾</q> [الحج:٢٩] وجدتم هذا: طوفوا سبعًا؟ واركعوا ركعتين خلف المقام؟ أوجدتم هذا في القرآن؟ عمَّن أخذتموه؟ ألستم أخذتموه عنا، وأخذناه عن نبي الله ﷺ؟ أوجدتم في القرآن: لا جَلَبَ ولا جَنَبَ ولا شِغار في الإسلام؟ قال: لا. قال: إنِّي سمعتُ رسول الله ﷺ يقول: «لا جَلَب، ولا جَنَب، ولا شِغار في الإسلام». أسمعتم الله يقول لأقوام في كتابه: <q>﴿ما سلككم في سقر، قالوا: لم نك من المصلين، ولم نك نطعم المسكين﴾</q> حتى بلغ <q>﴿فما تنفعهم شفاعة الشافعين﴾</q> [المدثر: ٤٢-٤٨]؟ قال: حبيب: أنا سمعت يقول: الشفاعة{53}{54}. (ز) ",footnotes:1:أخرجه ابن أبي شيبة ٤/٨٥، وابن جرير ١٦/٥٢٨، وابن أبي حاتم -كما في الإتقان ٢/٣٠-. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه ابن جرير ١٦/٥٢٦. وعزاه السيوطي إلى سعيد بن منصور، وعبد بن حميد، وابن المنذر، وابن أبي حاتم.أخرجه ابن جرير ١٦/٥٢٨، وابن أبي حاتم -كما في الإتقان ٢/٣٠-. وعزاه السيوطي إلى ابن المنذر.أخرجه ابن أبي شيبة ٤/٨٤، وابن جرير ١٦/٥٢٦. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه الثوري في تفسيره ص٢١١ من طريق ليث، ويحيى بن سلام ١/٣٦٧ بنحوه، وابن أبي شيبة٤/٨٤، وابن جرير ١٦/٥٢٧، وأبو جعفر الرملي في جزئه ص٥٦ (تفسير مسلم الزنجي). وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم. وفي تفسير الثعلبي ٧/٢٠ نحوه، وزاد في أوله: هو مناسك الحج.أخرجه إسحاق البستي في تفسيره ص٣٥٨، وابن جرير ١٦/٥٢٦.عزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ١٦/٥٢٦.أخرجه ابن جرير ١٦/٥٢٦.أخرجه يحيى بن سلام ١/٣٦٧.أخرجه يحيى بن سلام ١/٣٦٨.أخرجه يحيى بن سلام ١/٣٦٧.أخرجه ابن أبي شيبة ٤/٨٤.أخرجه ابن جرير ١٦/٥٢٦. وفي تفسير الثعلبي ٧/٢٠ نحوه، وزاد في أوله: هو مناسك الحج.أخرجه عبد الرزاق ٢/٣٧، ويحيى بن سلام ١/٣٦٧ من طريق سعيد.أخرجه ابن جرير ١٦/٥٢٨.أخرجه أبو جعفر الرملي في جزئه ص١١٧ (تفسير عطاء الخراساني).تفسير مقاتل بن سليمان ٣/١٢٣.أخرجه ابن جرير ١٦/٥٢٧.عزاه السيوطي إلى عبد بن حميد. وهي قراءة متواترة، قرأ بها أبو بكر عن عاصم، وقرأ ابن ذكوان: ‹ولِيُوفُواْ نُذُورَهُمْ› ‹ولِيَطَّوَّفُواْ› بكسر اللام فيهما، وقرأ بقية العشرة <q>﴿ولْيُوفُواْ نُذُورَهُمْ﴾</q> <q>﴿ولْيَطَّوَّفُواْ﴾</q> بإسكان اللام فيهما، مع إسكان الواو في الأول. انظر: النشر ٣٢٦، والإتحاف ص٣٩٨.أخرجه ابن جرير ١٦/٥٢٨، وابن أبي حاتم -كما في الإتقان ٢/٣٠-. وعزاه السيوطي إلى ابن المنذر.عزاه السيوطي إلى عبد بن حميد.أخرجه يحيى بن سلام ١/٣٦٨ من طريق عاصم بن حكيم، وابن أبي شيبة ٤/٨٤، وابن جرير ١٦/٥٢٩. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.أخرجه الثوري في تفسيره ص٢١٢.أخرجه يحيى بن سلام ١/٣٦٨.تفسير مقاتل بن سليمان ٣/١٢٣.أخرجه ابن جرير ١٦/٥٣٢ بلفظ: «زيارة البيت». وعزاه السيوطي إلى ابن جرير، وابن المنذر، ناسبًا اللفظ الثاني إلى ابن جرير، ولعل مراده لفظ ابن المنذر.عزاه السيوطي إلى ابن مردويه.أخرجه يحيى بن سلام ١/٣٦٩، وابن أبي حاتم -كما في تفسير ابن كثير ٥/٤١٣-، كما أخرج نحوه يحيى بن سلام ١/٣٦٩ من طريق سعيد بن جبير.أخرجه يحيى بن سلام ١/٣٦٩.علقه يحيى بن سلام ١/٣٦٩. وعزاه السيوطي إلى عبد بن حميد، وابن أبي حاتم.عزاه السيوطي إلى سعيد بن منصور، وعبد بن حميد.أخرجه ابن جرير ١٦/٥٣٢.أخرجه يحيى بن سلام ١/٣٦٨.أخرجه ابن جرير ١٦/٥٣٢.أخرجه ابن جرير ١٦/٥٣٢.أخرجه الترمذي ٥/٣٨٩-٣٩٠ (٣٤٤٢)، والحاكم ٢/٤٢١ (٣٤٦٥)، وابن جرير ١٦/٥٣١. قال الترمذي: «هذا حديث حسن غريب، وقد روي هذا الحديث عن الزهري، عن النبي ﷺ مرسلًا». وقال الحاكم: «هذا حديث صحيح، على شرط البخاري، ولم يخرجاه». وقال الذهبي في التلخيص: «على شرط مسلم». وقال الهيثمي في المجمع ٣/٢٩٦ (٥٧٦٦): «رواه البزار، وفيه عبد الله بن صالح كاتب الليث، قيل: ثقة مأمون، وقد ضعّفه الأئمة أحمد وغيره، وبقية رجاله ثقات». وقال الألباني في الضعيفة ٧/٢٠٧ (٣٢٢٢): «ضعيف».أخرجه عبد الرزاق ٢/٣٧، وابن جرير ١٦/٥٢٩.عزاه السيوطي إلى عبد بن حميد، وابن أبي حاتم.عزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.أخرجه ابن أبي شيبة ٤/١١١، وإسحاق البستي في تفسيره ص٣٦٢ مختصرًا، وابن جرير ١٦/٥٣٠. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.أخرجه يحيى بن سلام ١/٣٦٨. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.أخرجه ابن جرير ١٦/٥٣٠.أخرجه يحيى بن سلام ١/٣٦٨. وعزاه السيوطي إلى ابن أبي حاتم.أخرجه يحيى بن سلام ١/٣٦٨، وابن جرير ١٦/٥٣٠ مختصرًا من طريق أبي هلال.تفسير مقاتل بن سليمان ٣/١٢٣.كذا في المصدر.تفسير سفيان الثوري ص٢١٢.أخرجه ابن جرير ١٦/٥٣٠.تفسير الثعلبي ٧/٢٠، وتفسير البغوي ٥/٣٨٢.أخرجه ابن أبي حاتم -كما في تفسير ابن كثير ٥/٤١٨-، من طريق هشام بن حجر، عن رجل، عن ابن عباس به. وعزاه السيوطي إلى ابن مردويه. وسنده ضعيف؛ لجهالة شيخ هشام بن حجر.أخرجه الطبراني (١٠٩٨٨)، والحاكم ١/٤٦٠، والبيهقي في سننه ٥/٩٠. وعزاه السيوطي إلى سفيان بن عيينة.الجملة الأخيرة من هذا الأثر توضحها رواية ابن نصر والروياني؛ فهي عندهما بلفظ: قال حبيب: فأنا سمعت عمران بن حصين يقول: الشفاعة نافعة دون ما تسمعون.أخرجه الطبراني في الكبير ١٨/٢١٩ (٥٤٧) واللفظ له، ومحمد بن نصر المروزي في تعظيم قدر الصلاة ٢/١٠٠٧-١٠٠٨ (١٠٨١)، والروياني في المسند ١/١٢٣، وأخرجه أبو داود ٣/٩ (١٥٦١) مختصرًا. فيه صرد بن أبي المنازل؛ قال عنه الألباني في ضعيف أبي داود ٢/١٠٥ (٢٧٤): «هذا إسناد ضعيف؛ لجهالة صردٍ هذا، قال الذهبي: لا يعرف. وحبيب ... لم يوثقه غير ابن حبان. والحديث سكت عنه المنذري». وقد أورد السيوطي ١٠/٤٨٢-٤٨٦ آثارًا عديدة عن فضائل الطواف وآدابه.
22,30," <q>﴿ذَ ٰ⁠لِكَۖ وَمَن یُعَظِّمۡ حُرُمَـٰتِ ٱللَّهِ فَهُوَ خَیۡرࣱ لَّهُۥ عِندَ رَبِّهِۦۗ﴾</q> - تفسير ٥٠٥٦٩- عن مجاهد بن جبر -من طريق ابن أبي نجيح، وابن جُرَيج- في قوله: <q>﴿ذلك ومن يعظم حرمات الله﴾</q>، قال: الحرمة: مكة، والحج، والعمرة، وما نهى الله عنه مِن معاصيه كلها{1}. (١٠/٤٨٦) ٥٠٥٧٠- عن عطاء= (ز) ٥٠٥٧١- وعكرمة مولى ابن عباس، <q>﴿ذلك ومن يعظم حرمات الله﴾</q>، قالا: المعاصي{2}. (١٠/٤٨٦) ٥٠٥٧٢- قال مقاتل بن سليمان: <q>﴿ذلك ومن يعظم حرمات الله﴾</q> يعني: أمر المناسك كلها؛ <q>﴿فهو خير له عند ربه﴾</q> في الآخرة{3}. (ز) ٥٠٥٧٣- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿ومن يعظم حرمات الله﴾</q>، قال: الحرمات: المشعر الحرام، والبيت الحرام، والمسجد الحرام، والبلد الحرام{4}٤٤٦٤. (١٠/٤٨٧) ٤٤٦٤ رجَّح ابنُ القيم (٢/٢١٤) مستندًا إلى دلالة العموم بأنّ «الحرمات» تعمُّ هذه المعاني كلها، «وهي جمع حرمة، وهي: ما يجب احترامه وحفظه من الحقوق، والأشخاص، والأزمنة، والأماكن. فتعظيمها: توفيتها حقها، وحفظها من الإضاعة». <q>﴿ذَ ٰ⁠لِكَۖ وَمَن یُعَظِّمۡ حُرُمَـٰتِ ٱللَّهِ فَهُوَ خَیۡرࣱ لَّهُۥ عِندَ رَبِّهِۦۗ﴾</q> - آثار متعلقة بالآية ٥٠٥٧٤- عن عياش بن أبي ربيعة المخزومي، عن النبي ﷺ، قال: «لن تزال هذه الأمةُ بخير ما عَظَّموا هذه الحرمةَ حَقَّ تعظيمها -يعني: مكة-، فإذا ضَيَّعوا ذلك هلكوا»{5}. (١٠/٤٨٧) <q>﴿وَأُحِلَّتۡ لَكُمُ ٱلۡأَنۡعَـٰمُ إِلَّا مَا یُتۡلَىٰ عَلَیۡكُمۡۖ﴾</q> - تفسير ٥٠٥٧٥- عن قتادة بن دعامة -من طريق معمر- <q>﴿إلا ما يتلى عليكم﴾</q>، قال: إلا الميتة، وما لم يُذكَر اسم الله عليه{6}. (ز) ٥٠٥٧٦- قال مقاتل بن سليمان: <q>﴿وأحلت لكم﴾</q> بهيمة <q>﴿الأنعام﴾</q> التي حرموا للآلهة في سورة الأنعام، <q>﴿إلا ما يتلى عليكم﴾</q> من التحريم في أول سورة المائدة{3}. (ز) ٥٠٥٧٧- قال يحيى بن سلّام: قوله: <q>﴿وأحلت لكم الأنعام إلا ما يتلى عليكم﴾</q> في سورة المائدة [٣] مِن: <q>﴿الميتة والدم ولحم الخنزير وما أهل لغير الله به والمنخنقة والموقوذة والمتردية والنطيحة وما أكل السبع إلا ما ذكيتم وما ذبح على النصب﴾</q>. وقد فسرنا ذلك كله في سورة المائدة{8}. (ز) <q>﴿فَٱجۡتَنِبُوا۟ ٱلرِّجۡسَ مِنَ ٱلۡأَوۡثَـٰنِ﴾</q> - تفسير ٥٠٥٧٨- عن عبد الله بن عباس -من طريق العوفي- في قوله: <q>﴿فاجتنبوا الرجس من الاوثان﴾</q>، يقول: اجتنبوا طاعة الشيطان في عبادة الأوثان{9}. (١٠/٤٨٧) ٥٠٥٧٩- عن عبد الملك ابن جُرَيْج -من طريق حَجّاج- في قوله: <q>﴿الرجس من الأوثان﴾</q>، قال: عبادة الأوثان{9}. (ز) ٥٠٥٨٠- قال مقاتل بن سليمان: <q>﴿فاجتنبوا الرجس من الأوثان﴾</q>، فيها تقديم؛ يقول: اتقوا عبادة اللات والعزى ومناة، وهي الأوثان{3}. (ز) ٥٠٥٨١- قال يحيى بن سلّام: قوله: <q>﴿فاجتنبوا الرجس من الأوثان﴾</q> اجتنبوا الأوثان؛ فإنها رجس{8}٤٤٦٥. (ز) ٤٤٦٥ لم يذكر ابنُ جرير (١٦/٥٣٥) في معنى: <q>﴿فاجْتَنِبُوا الرِّجْسَ مِنَ الأَوْثانِ﴾</q> سوى قول ابن عباس، وابن جريج. وذكر ابنُ عطية (٦/٢٤٣-٢٤٤) احتمالين في معنى الآية، فقال: «والكلام يحتمل معنيين: أحدهما: أن تكون <q>﴿مِن﴾</q> لبيان الجنس، فيقع نهيه عن رجس الأوثان فقط، وتبقى سائر الأجناس نَهْيُها في غير هذا الموضع. والمعنى الثاني: أن تكون <q>﴿مِن﴾</q> لابتداء الغاية، فكأنه نهاهم عن الرجس عامًّا، ثم عيَّن لهم مبدأه الذي منه يلحقهم؛ إذ عبادة الوثن جامعة لكل فساد ورجس». <q>﴿وَٱجۡتَنِبُوا۟ قَوۡلَ ٱلزُّورِ ۝٣٠﴾</q> - نزول الآية ٥٠٥٨٢- عن مقاتل، عن محمد بن علي، في قوله تعالى: <q>﴿واجتنبوا قول الزور﴾</q>، قال: الكذب، وهو الشِّرْك في التَّلبية، وذلك أن الحُمْس -قريش، وخزاعة، وكنانة، وعامر بن صَعْصَعَة- في الجاهلية كانوا يقولون في التلبية: لبيك اللهم لبيك، لبيك لا شريك لك، إلا شريكًا هو لك، تملكه وما ملك. يعنون: الملائكة التي تُعبد، هذا هو قول الزور لقولهم: إلا شريكًا هو لك. وكان أهل اليمن في الجاهلية يقولون في التلبية: نحن عَرايا عك عك، إليك عانيَة، عبادك اليمانيَة، كيما نحج الثانيَة، على القِلاص{13} الناجيَة{14}. وكانت تميم تقول في إحرامها: لبيك ما نهارنا نجرُه{15}، إدلاجه وبرده وحرُّه، لا يتقي شيئًا ولا يضرُّه، حجًّا لرب مستقيم بِرُّه. وكانت ربيعة تقول: لبيك اللهم حجًّا حقًّا، تَعَبُّدًا ورِقًّا، لم نأتك للمَناحَةِ{16}، ولا حُبًّا للرَباحَة. وكانت قيس عيلان تقول: لبيك لولا أنّ بَكرًا دونكا، بنو أغيار وهم يلونكا، ببرك الناس ويفخرونكا، ما زال منا عجيجًا يأتونكا. وكانت جُرْهم تقول في إحرامها: لبيك إن جرهمًا عبادك، والناس طرف وهم تِلادك، وهم لعمري عَمَرُوا بلادك، لا يطاق ربنا بعادك{17}، وهم الأولون على ميعادك، وهم يُعادون كل مَن يعادك، حتى يقيموا الدين في وادك. وكانت قضاعة تقول: لبيك رب الحل والإحرام، ارحم مقام عبد وآم، أتوك يمشون على الأقدام. وكانت أسد وغطفان تقول في إحرامها بشعر اليمن: لبيك، إليك تعدو قلقًا وضِينُها{18}، معترضًا في بطنها جنينها، مخالفًا دين النصارى دينها. وكانت النساء تَطُفْن بالليل عراة، وقال بعضهم: لا بل نهارًا، تأخذ إحداهن حاشية برد تستر به، وتقول: اليوم يبدو بعضه أو كله، وما بدا منه فلا أُحِلُّه، كم من لبيب عقله يُضِلُّه، وناظر ينظر فما يَمَلُّه، ضخم من الجثم، عظيم ظلُّه. وكانت تلبية آدم ﵇: لبيك الله لبيك، عبد خلقته بيديك، كرمت فأعطيت، قربت فأدنيت، تباركت وتعاليت، أنت رب البيت. فأنزل الله ﷿: <q>﴿واجتنبوا قول الزور﴾</q>{19}. (ز) <q>﴿وَٱجۡتَنِبُوا۟ قَوۡلَ ٱلزُّورِ ۝٣٠﴾</q> - تفسير الآية ٥٠٥٨٣- عن أيمن بن خُرَيْم، قال: قام رسول الله ﷺ خطيبًا، فقال: «يا أيها الناس، عدَلَت شهادةُ الزور إشراكًا بالله» ثلاثًا. ثم قرأ: <q>﴿فاجتنبوا الرجس من الأوثان واجتنبوا قول الزور﴾</q>{20}. (١٠/٤٨٧) ٥٠٥٨٤- عن خُرَيْم بن فاتك الأسدي، قال: صلّى رسولُ الله ﷺ صلاة الصبح، فلما انصرف قائمًا قال: «عدَلَت شهادةُ الزور الإشراكَ بالله». ثلاث مرات، ثم تلا هذه الآية: <q>﴿واجتنبوا قول الزور حنفاء لله غير مشركين به﴾</q>{21}. (١٠/٤٨٨) ٥٠٥٨٥- عن عبد الله بن مسعود -من طريق وائل بن ربيعة- قال: شهادة الزور تعدل بالشرك بالله. ثم قرأ: <q>﴿فاجتنبوا الرجس من الاوثان واجتنبوا قول الزور﴾</q>{22}. (١٠/٤٨٨) ٥٠٥٨٦- عن عبد الله بن عباس -من طريق العوفي- في قوله: <q>﴿واجتنبوا قول الزور﴾</q>، يعني: الافتراء على الله، والتكذيب به{23}. (١٠/٤٨٧) ٥٠٥٨٧- عن مجاهد بن جبر -من طريق ابن أبي نجيح- <q>﴿واجتنبوا قول الزور﴾</q>، قال: الكَذِب{24}. (١٠/٤٨٨) ٥٠٥٨٨- عن وائل بن ربيعة -من طريق عاصم- قال: عدلت شهادة الزور الشرك. ثم قرأ هذه الآية: <q>﴿فاجتنبوا الرجس من الأوثان واجتنبوا قول الزور﴾</q>{25}. (ز) ٥٠٥٨٩- عن محمد بن علي -من طريق مقاتل- في قوله تعالى: <q>﴿واجتنبوا قول الزور﴾</q>، قال: الكذب، وهو الشِّرك في التَّلْبية{26}. (ز) ٥٠٥٩٠- عن مقاتل [بن حيان]: <q>﴿واجتنبوا قول الزور﴾</q>، يعني: الشرك بالكلام، وذلك أنهم كانوا يطوفون بالبيت، فيقولون في تلبيتهم: لبيك لا شريك لك، إلا شريكًا هو لك، تملكه وما ملك{27}. (١٠/٤٨٩) ٥٠٥٩١- قال مقاتل بن سليمان: <q>﴿واجتنبوا قول الزور﴾</q>، يقول: اتقوا الكذب، وهو الشرك. وفي موضع آخر: وهو الشرك في الإحرام{28}. (ز) ٥٠٥٩٢- قال يحيى بن سلّام: قوله: <q>﴿واجتنبوا قول الزور﴾</q>، وقول الزور: الكذب على الله، يعني: الشرك{8}. (ز) <q>﴿وَٱجۡتَنِبُوا۟ قَوۡلَ ٱلزُّورِ ۝٣٠﴾</q> - آثار متعلقة بالآية ٥٠٥٩٣- عن أبي بكرة، قال: قال رسول الله ﷺ: «ألا أنبئكم بأكبر الكبائر؟». قلنا: بلى، يا رسول الله. قال: «الإشراك بالله، وعقوق الوالدين». وكان مُتَّكِئًا فجلس، فقال: «ألا وقول الزور، ألا وشهادة الزور». فما زال يُكَرِّرها حتى قلنا: ليته سكت{30}. (١٠/٤٨٨) ",footnotes:1:أخرجه ابن جرير ١٦/٥٣٤. وعلَّقه يحيى بن سلام ١/٣٦٩. وعزاه السيوطي إلى ابن أبي شيبة، وعبد بن حميد، وابن المنذر، وابن أبي حاتم.عزاه السيوطي إلى عبد بن حميد.تفسير مقاتل بن سليمان ٣/١٢٣.أخرجه ابن جرير ١٦/٥٣٤ بزيادة: هؤلاء الحرمات.أخرجه أحمد ٣١/٣٩٥ (١٩٠٤٩)، وابن ماجه ٤/٢٩١ (٣١١٠) واللفظ له، من طريق يزيد بن أبي زياد، عن عبد الرحمن بن سابط، عن عياش بن أبي ربيعة المخزومي به. قال الحافظ في الفتح ٣/٤٤٩: «سنده حسن».أخرجه عبد الرزاق ٢/٣٧-٣٨، وابن جرير ١٦/٥٣٥.تفسير مقاتل بن سليمان ٣/١٢٣.تفسير يحيى بن سلام ١/٣٧٠.أخرجه ابن جرير ١٦/٥٣٥.أخرجه ابن جرير ١٦/٥٣٥.تفسير مقاتل بن سليمان ٣/١٢٣.تفسير يحيى بن سلام ١/٣٧٠.القِلاص: جمع قَلُوص، وهي الناقة الشابَّة. النهاية (قلص).الناجية: المسرعة. النهاية (نجا).في المصادر التي ضبطت هذه الكلمة: نَجُرُّه، بتشديد الراء، ولم يتبين لنا معناها، ولعلها: نَجْرُه، بتسكين الجيم، وضم الراء دون تشديد؛ يعني: أصله؛ لأن التلبية للشمس، كما في المحبر ص٣١٢ لابن حبيب البغدادي.المَناحة والنَّوح: النِّساء يَجْتَمِعْنَ للحُزن. اللسان (نوح).في المصدر: يعادك، بالياء المثناة التحتانية، ولعله خطأ طباعي، والصواب ما أثبتنا.الوَضِينُ: بِطان منسوج بعضه على بعض يشد به الرحل على البعير، أراد أنها سريعة الحركة، يصفها بالخفة وقلة الثبات كالحزام إذا كان رخوًا. اللسان (وضن).أخرجه مقاتل بن سليمان في تفسيره ٣/١٢٤-١٢٦ مرسلًا.أخرجه أحمد ٢٩/١٤٥ (١٧٦٠٣)، ٢٩/٥٨٠ (١٨٠٤٤)، ٣١/١٩٩ (١٨٩٠٢)، والترمذي ٤/٣٤١-٣٤٢ (٢٤٥٣)، وابن جرير ١٦/٥٣٧. قال الترمذي: «هذا حديث غريب، إنما نعرفه من حديث سفيان بن زياد، واختلفوا في رواية هذا الحديث عن سفيان بن زياد، ولا نعرف لأيمن بن خريم سماعًا من النبي ﷺ». وقال السيوطي في الحاوي للفتاوي ١/٤٢٧: «رواه أحمد في مسنده، والترمذي هكذا، وأيمن مختلف في صحبته، فذكره ابن منده وغيره في الصحابة، وقال العجلي: تابع صالح ثقة ... وله شاهد عن ابن مسعود».أخرجه أحمد ٣١/١٩٤ (١٨٨٩٨)، وأبو داود ٥/٤٥١ (٣٥٩٩)، وابن ماجه ٣/٤٥٥-٤٥٦ (٢٣٧٢)، وابن جرير ١٦/٥٣٧. قال العقيلي في الضعفاء الكبير ٣/٤٣٣: «هذا يُروى عن خريم بن فاتك بإسناد صالح مِن غير هذا الوجه». وقال ابن القطان في بيان الوهم والإيهام ٤/٥٤٨ (٢١٠١): «لا يصح ... وحبيب لا يعرف بغير هذا، ولا تعرف حاله، وزياد العصفري مجهول، فأما ابنه سفيان فثقة». وقال ابن الملقن في البدر المنير ٩/٥٧٦-٥٧٧ (١٥): «رجال إسناده كلهم محتج بهم في الصحيح، إلا حبيب بن النعمان الأسدي، فلم يرو له إلا (د ق)، ولا أعرف من جرحه ولا مَن عدّله». وقال ابن حجر في التلخيص الحبير ٤/٤٦٠ (٢٠٩٥): «إسناده مجهول». وقال الألباني في الضعيفة ٣/٢٣٥ (١١١٠): «ضعيف».أخرجه عبد الرزاق في مصنفه (١٥٣٩٥)، وابن جرير ١٦/٥٣٦، والطبراني (٨٥٦٩)، والبيهقي في شعب الإيمان، (٤٨٦٢). وعزاه السيوطي إلى الفريابي، وسعيد بن منصور، وعبد بن حميد، وابن المنذر، والخرائطي في مكارم الأخلاق.أخرجه ابن جرير ١٦/٥٣٦.أخرجه يحيى بن سلام ١/٣٧٠ من طريق عاصم بن حكيم، وابن جرير ١٦/٥٣٦. وعزاه السيوطي إلى ابن أبي شيبة، وعبد بن حميد، وابن المنذر، وابن أبي حاتم.أخرجه ابن أبي شيبة (ت: محمد عوامة) ١١/٦٢٥ (٢٣٤٩٨)، وابن جرير ١٦/٥٣٦.تفسير مقاتل بن سليمان ٣/١٢٤-١٢٦.عزاه السيوطي إلى ابن أبي حاتم.تفسير مقاتل بن سليمان ٣/١٢٣، ١٢٦.تفسير يحيى بن سلام ١/٣٧٠.أخرجه البخاري ٣/١٧٢ (٢٦٥٤)، ٨/٤ (٥٩٧٦)، ٨/٦١ (٦٢٧٣)، ٩/١٣-١٤ (٦٩١٩)، ومسلم ١/٩١ (٨٧)، وابن المنذر في تفسيره ٢/٦٦٤ (١٦٥٢).
