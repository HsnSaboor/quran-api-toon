quran[7]{c,v,t}:
  22,24,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَهُدُوۤا۟ إِلَى ٱلطَّیِّبِ مِنَ ٱلۡقَوۡلِ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٠٢٧٣<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- في قوله: <span class="qpc-hafs">﴿وهدوا إلى الطيب من القول﴾</span>، قال: أُلْهِموا{1}. (١٠/٤٤٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٢٧٤<span class="dash">-</span></span> قال <span class="name-1">عبد الله بن عباس</span>: هو شهادة أن لا إله إلا الله{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٢٧٥<span class="dash">-</span></span> عن <span class="name-2">أبي العالية الرِّياحِيِّ</span>، في قوله: <span class="qpc-hafs">﴿وهدوا إلى الطيب من القول﴾</span>، قال: في الخصومة؛ إذ قالوا: اللهُ مولانا ولا مولى لكم{3}. (١٠/٤٤٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٢٧٦<span class="dash">-</span></span> عن <span class="name-2">الضحاك بن مزاحم</span>، <span class="qpc-hafs">﴿وهدوا إلى الطيب من القول﴾</span>، قال: الإخلاص{4}. (١٠/٤٤٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٢٧٧<span class="dash">-</span></span> تفسير <span class="name-2">الحسن البصري</span>، في قوله: <span class="qpc-hafs">﴿وهدوا إلى الطيب من القول﴾</span>: الإيمان في الدنيا بالله{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٢٧٨<span class="dash">-</span></span> قال <span class="name-2">إسماعيل السُّدِّيّ</span>: أي: القرآن{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٢٧٩<span class="dash">-</span></span> عن <span class="name-2">إسماعيل بن أبي خالد</span>، <span class="qpc-hafs">﴿وهدوا إلى الطيب من القول﴾</span>، قال: القرآن{7}. (١٠/٤٤٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٢٨٠<span class="dash">-</span></span> تفسير <span class="name-3">محمد بن السائب الكلبي</span>: قوله: <span class="qpc-hafs">﴿وهدوا إلى الطيب من القول﴾</span>، وهو: لا إله إلا الله{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٢٨١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وهدوا﴾</span> في الدنيا <span class="qpc-hafs">﴿إلى الطيب من القول﴾</span> يعني: التوحيد، وهو قول: لا إله إلا الله وحده لا شريك له. كقوله: <span class="qpc-hafs">﴿كلمة طيبة﴾</span> [إبراهيم:٢٤]، يعني: التوحيد{9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٢٨٢<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- <span class="qpc-hafs">﴿وهدوا إلى الطيب من القول﴾</span>، قال: لا إله إلا الله، والله أكبر، والحمد لله، الذي قال: <span class="qpc-hafs">﴿اليه يصعد الكلم الطيب﴾</span> [فاطر:١٠]{10}<span class=comment-ref>٤٤٤٨</span>. (١٠/٤٤٧)</p></p><p></div></p><p><div><span class=comment-ref>٤٤٤٨</span> لم يذكر <u>ابنُ جرير</u> (١٦/٥٠٠) في معنى: <span class="qpc-hafs">﴿وهُدُوا إلى الطَّيِّبِ مِنَ القَوْلِ﴾</span> سوى قول ابن عباس من طريق علي، وابن زيد.</div></p><p><h3><span class="qpc-hafs">﴿وَهُدُوۤا۟ إِلَىٰ صِرَ ٰ⁠طِ ٱلۡحَمِیدِ ۝٢٤﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٠٢٨٣<span class="dash">-</span></span> عن <span class="name-2">الضحاك بن مزاحم</span>، <span class="qpc-hafs">﴿وهدوا إلى صراط الحميد﴾</span>، قال: الإسلام{4}. (١٠/٤٤٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٢٨٤<span class="dash">-</span></span> عن <span class="name-2">إسماعيل بن أبي خالد</span>، <span class="qpc-hafs">﴿وهدوا إلى صراط الحميد﴾</span>، قال: الإسلام{7}. (١٠/٤٤٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٢٨٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وهدوا إلى صراط﴾</span> يعني: دين الإسلام <span class="qpc-hafs">﴿الحميد﴾</span> عند خلقه؛ يحمده أولياؤه{9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٢٨٦<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: قوله: <span class="qpc-hafs">﴿وهدوا﴾</span> يعني: في الدنيا <span class="qpc-hafs">﴿إلى صراط الحميد﴾</span> وهو الله. وهو كقوله: <span class="qpc-hafs">﴿وإنك لتهدي إلى صراط مستقيم﴾</span> أي: إلى الجنة، <span class="qpc-hafs">﴿صراط الله﴾</span> [الشورى:٥٢-٥٣] طريق الله الذي هدى له عبادَه المؤمنين إلى الجنة{14}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ١٦/٥٠٠، وابن أبي حاتم -كما في الإتقان ٢/٣٠-. وعزاه السيوطي إلى ابن المنذر.تفسير البغوي ٥/٣٧٦.عزاه السيوطي إلى ابن أبي حاتم.عزاه السيوطي إلى ابن أبي شيبة، وابن المنذر، وابن أبي حاتم.علَّقه يحيى بن سلام ١/٣٦١.تفسير البغوي ٥/٣٧٦.أخرجه ابن المنذر -كما في فتح الباري ٨/٤٤١-. وعزاه السيوطي إلى ابن أبي حاتم.علَّقه يحيى بن سلام ١/٣٦١، وعقَّب عليه وعلى قول الحسن بقوله: وهو واحد.تفسير مقاتل بن سليمان ٣/١٢١.أخرجه ابن جرير ١٦/٥٠٠. وعزاه السيوطي إلى ابن أبي حاتم.عزاه السيوطي إلى ابن أبي شيبة، وابن المنذر، وابن أبي حاتم.أخرجه ابن المنذر -كما في فتح الباري ٨/٤٤١-. وعزاه السيوطي إلى ابن أبي حاتم.تفسير مقاتل بن سليمان ٣/١٢١.تفسير يحيى بن سلام ١/٣٦١.
  22,25,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿إِنَّ ٱلَّذِینَ كَفَرُوا۟ وَیَصُدُّونَ عَن سَبِیلِ ٱللَّهِ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٠٢٨٧<span class="dash">-</span></span> قال <span class="name-2">إسماعيل السُّدِّيّ</span>: <span class="qpc-hafs">﴿ويصدون عن سبيل الله﴾</span>، يعني: ويمنعون الناس عن دين الله الإسلام{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٢٨٨<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿إن الذين كفروا ويصدون عن سبيل الله﴾</span> يقول ويمنعون الناس عن دين الله ﷿{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٢٨٩<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿ويصدون عن سبيل الله﴾</span>، يعني: الهدى، يعني: المشركين{3}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَٱلۡمَسۡجِدِ ٱلۡحَرَامِ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٠٢٩٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، قال: الحرم كله هو المسجد الحرام{4}<span class=comment-ref>٤٤٤٩</span>. (١٠/٤٤٨)</p></p><p></div></p><p><div><span class=comment-ref>٤٤٤٩</span> نقل <u>ابنُ عطية</u> (٦/٢٣٢) عن فرقة أن «المسجد الحرام» أراد به: مكة كلها. ثم <span class="comment-type-4">علَّق</span> عليه بقوله: «وهذا صحيح، لكنه قصد بالذِّكر المهم المقصود من ذلك».</div></p><p><div></p><p><p><span class="item-no">٥٠٢٩١<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله تعالى: <span class="qpc-hafs">﴿إن الذين كفروا ويصدون عن سبيل الله والمسجد الحرام﴾</span>، قال: المسجد الحرام: مكة{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٢٩٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿إن الذين كفروا ويصدون عن سبيل الله﴾</span> يقول: ويمنعون الناس عن دين الله ﷿، <span class="qpc-hafs">﴿و﴾</span>عن <span class="qpc-hafs">﴿المسجد الحرام﴾</span>{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٢٩٣<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿والمسجد الحرام﴾</span>، أي: ويصدون عن المسجد الحرام{3}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿ٱلَّذِی جَعَلۡنَـٰهُ لِلنَّاسِ سَوَاۤءً ٱلۡعَـٰكِفُ فِیهِ وَٱلۡبَادِۚ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٠٢٩٤<span class="dash">-</span></span> عن عبد الله بن عباس، قال: قال رسول الله ﷺ، في قول الله تعالى: <span class="qpc-hafs">﴿سواء العاكف فيه والباد﴾</span>، قال: «<b>سواء المقيم، والذي يرحل</b>»{8}. (١٠/٤٥١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٢٩٥<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، في قوله: <span class="qpc-hafs">﴿سواء﴾</span>: يعني: شرعًا واحدًا، <span class="qpc-hafs">﴿العاكف فيه﴾</span> قال: أهل مكة في مكة أيام الحج، <span class="qpc-hafs">﴿والباد﴾</span> قال: مَن كان في غير أهلها، مَن يعتكف فيه مِن الآفاق. قال: هم في منازل مكة سواء، فينبغي لأهل مكة أن يُوَسِّعوا لهم حتى يقضوا مناسكهم{9}. (١٠/٤٤٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٢٩٦<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، في الآية، قال: البادي وأهل مكة سواء في المنزل والحرم{9}. (١٠/٤٤٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٢٩٧<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- <span class="qpc-hafs">﴿سواء العاكف فيه والباد﴾</span>، قال: ينزل أهلُ مكة وغيرُهم في المسجد الحرام{11}. (١٠/٤٥١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٢٩٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، في قوله: <span class="qpc-hafs">﴿سواء العاكف فيه والباد﴾</span>، قال: خَلْقُ الله فيه سواءٌ{12}. (١٠/٤٤٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٢٩٩<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span> -من طريق عبد الله بن مسلم-، مثله{13}. (١٠/٤٤٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٣٠٠<span class="dash">-</span></span> عن ابن حصين، قال: سألتُ <span class="name-2">سعيد بن جبير</span>: أعتكفُ بمكة؟ قال: لا، أنت معتكف ما أقمت؛ قال الله: <span class="qpc-hafs">﴿سواء العاكف فيه والباد﴾</span>{14}. (١٠/٤٤٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٣٠١<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق منصور- في الآية، قال: الناس بمكة سواء، ليس أحد أحق بالمنازل من أحد{15}. (١٠/٤٤٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٣٠٢<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿سواء العاكف فيه﴾</span>: يعني: الساكن بمكة، <span class="qpc-hafs">﴿والباد﴾</span> يعني: الجانب. يقول: حق الله ﷿ عليهما سواء{16}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٣٠٣<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن مجاهد-: <span class="qpc-hafs">﴿العاكف فيه﴾</span> الساكن فيه، <span class="qpc-hafs">﴿والباد﴾</span> الجانب، يعني: من يعتقبه، أي: الذي ينتابه مِن الناس للحج والعمرة، سواء في حرمه ومناسكه وحقوقه{17}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٣٠٤<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٣٠٥<span class="dash">-</span></span> و<span class="name-2">عطاء [بن أبي رباح]</span> -من طريق جابر- <span class="qpc-hafs">﴿سواء العاكف فيه﴾</span> قالا: من أهله، <span class="qpc-hafs">﴿والباد﴾</span> الذي يأتونه من غير أهله، هما في حرمته سواء{18}. (١٠/٤٤٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٣٠٦<span class="dash">-</span></span> عن <span class="name-2">أبي صالح [باذام]</span> -من طريق عنبسة، عمَّن ذَكَره-: <span class="qpc-hafs">﴿سواء العاكف فيه والباد﴾</span>، العاكف: أهله. والباد: المنتاب في المنزل سواء{19}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٣٠٧<span class="dash">-</span></span> عن <span class="name-2">عطاء [بن أبي رباح]</span> -من طريق عبد الملك- قال: الناس في البيت سواء{20}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٣٠٨<span class="dash">-</span></span> قال <span class="name-2">الحسن البصري</span>، في قوله: <span class="qpc-hafs">﴿سواء العاكف فيه والباد﴾</span>: أي: في تعظيم حُرمَتِه، وقضاء النُّسُك فيه{21}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٣٠٩<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في الآية، قال: سواء في جواره وأمنه وحرمته؛ <span class="qpc-hafs">﴿العاكف فيه﴾</span> أهل مكة، <span class="qpc-hafs">﴿والباد﴾</span> مَن يعتكفه مِن أهل الآفاق{22}. (١٠/٤٤٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٣١٠<span class="dash">-</span></span> عن [<span class="name-2">عبد الرحمن</span>] <span class="name-2">بن سابط</span> -من طريق يزيد بن أبي زياد- في قوله: <span class="qpc-hafs">﴿سواء العاكف فيه والباد﴾</span>، قال: كان الحُجّاج إذا قدموا مكة لم يكن أحدٌ مِن أهل مكة بأحقَّ بمنزله منهم، وكان الرجلُ إذا وجد سَعَةً نزل، ففشا فيهم السرقة، وكل إنسان يسرق من ناحيته، فاصطنع رجل بابًا، فأرسل إليه عمر: أتَّخَذْتَ بابًا مِن حُجّاج بيت الله؟ فقال: لا، إنّما جعلته ليحرز متاعهم. وهو قوله: <span class="qpc-hafs">﴿سواء العاكف فيه والباد﴾</span>. قال: الباد فيه كالمقيم، ليس أحد أحقُّ بمنزله من أحد، إلا أن يكون أحد سبق إلى منزل{23}. (١٠/٤٥١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٣١١<span class="dash">-</span></span> تفسير <span class="name-2">إسماعيل السُّدِّيّ</span>: <span class="qpc-hafs">﴿والباد﴾</span>، يعني: أهل مكة، هم في بيوتها شرع{24} سواء{25}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٣١٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿الذي جعلناه للناس سواء العاكف فيه﴾</span> يعني: المقيم في الحرم، وهم أهل مكة، <span class="qpc-hafs">﴿والباد﴾</span> يعني: مَن دخل مكة مِن غير أهلها{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٣١٣<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿سواء العاكف فيه والباد﴾</span>، قال: العاكف فيه: المقيم بمكة. والباد: الذي يأتيه، هم فيه سواء في البيوت{19}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٣١٤<span class="dash">-</span></span> قال <span class="name-3">يحيى بن</span> <span class="name-3">سلّام</span>: <span class="qpc-hafs">﴿والمسجد الحرام الذي جعلناه للناس﴾</span> قبلة ونسكا، قوله: <span class="qpc-hafs">﴿سواء العاكف فيه﴾</span> الساكن فيه{3}<span class=comment-ref>٤٤٥٠</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٤٤٥٠</span> أفادت الآثارُ اختلاف المفسرين في معنى: <span class="qpc-hafs">﴿سَواءً العاكِفُ فِيهِ والبادِ﴾</span>؛ <b>فقيل:</b> إن العاكف والبادي يستويان في سكنى مكة والنزول بها، فليس أحدُهما أحقَّ بالمنزل من الآخر. <b>وقيل:</b> إنهما يستويان في تفضيله، وحرمته، وإقامة المناسك به.</p><p>و<span class="comment-type-3">رجَّح</span> <u>ابنُ جرير</u> (١٦/٥٠٣) <span class="mustanad">مستندًا إلى دلالة السياق</span> القول الثاني، وهو قول مجاهد من طريق ابن أبي نجيح، وابن مجاهد، وعطاء، وعلَّل ذلك قائلًا: «لأنّ الله -تعالى ذِكْره- ذَكَر في أول الآية صدَّ مَن كَفَر به مَن أراد مِن المؤمنين قضاء نسكه في الحرم عن المسجد الحرام، فقال: <span class="qpc-hafs">﴿إنَّ الَّذِينَ كَفَرُوا ويَصُدُّونَ عَنْ سَبِيلِ اللَّهِ والمَسْجِدِ الحَرامِ﴾</span>، ثم ذَكَر -جلَّ ثناؤه- صفة المسجد الحرام، فقال: <span class="qpc-hafs">﴿الَّذِي جَعَلْناهُ لِلنّاسِ﴾</span>، فأخبر -جلَّ ثناؤه- أنه جعله للناس كلهم، والكافرون به يمنعون مَن أراده من المؤمنين به عنه، ثم قال: <span class="qpc-hafs">﴿سَواءً العاكِفُ فِيهِ والبادِ﴾</span>، فكان معلومًا أنّ خبره عن استواء العاكف فيه والباد إنما هو في المعنى الذي ابتدأ اللهُ الخبر عن الكفار أنهم صدوا عنه المؤمنين به، وذلك لا شك طوافهم، وقضاء مناسكهم به، والمقام، لا الخبر عن ملكهم إيّاه وغير ملكهم».</div></p><p><h3><span class="qpc-hafs">﴿ٱلَّذِی جَعَلۡنَـٰهُ لِلنَّاسِ سَوَاۤءً ٱلۡعَـٰكِفُ فِیهِ وَٱلۡبَادِۚ﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٥٠٣١٥<span class="dash">-</span></span> عن ابن عمرو مرفوعًا: «<b>مَن أكل كِراءَ بيوتِ مكة أكل نارًا</b>»{29}. (١٠/٤٥٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٣١٦<span class="dash">-</span></span> عن ابن عمر، أنّ النبيَّ ﷺ قال: «<b>مكة مباحة؛ لا تُؤَجَّر بيوتها، ولا تُباع رِباعُها</b>{30}»{31}. (١٠/٤٥١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٣١٧<span class="dash">-</span></span> عن <span class="name-1">عمر بن الخطاب</span>، أنّ رجلًا قال له عند المروة: يا أمير المؤمنين، أقْطِعْنِي مكانًا لي ولِعَقِبِي. فأعرض عنه عمر، وقال: هو حَرَمُ الله، <span class="qpc-hafs">﴿سواء العاكف فيه والباد﴾</span>{32}. (١٠/٤٥٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٣١٨<span class="dash">-</span></span> عن ابن عمر: أنّ <span class="name-1">عمر</span> نهى أن تُغْلَق أبواب دور مكة؛ فإن الناس كانوا ينزلون منها حيث وُجِدُوا، حتى كانوا يضرِبون فساطِيطَهم في الدور{12}. (١٠/٤٥٠)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَمَن یُرِدۡ فِیهِ بِإِلۡحَادِۭ بِظُلۡمࣲ نُّذِقۡهُ مِنۡ عَذَابٍ أَلِیمࣲ ۝٢٥﴾</span> - نزول الآية</h3></p><p><div></p><p><p><span class="item-no">٥٠٣١٩<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق سعيد بن جبير- قال: نزلت هذه الآيةُ في عبد الله بن أنيس؛ أنّ رسول الله ﷺ بعثه مع رجلين، أحدهما مهاجر، والآخر من الأنصار، فافتخروا في الأنساب، فغضب عبد الله بن أنيس، فقتل الأنصاريَّ، ثم ارْتَدَّ عن الإسلام، وهرب إلى مكة؛ فنزلت فيه: <span class="qpc-hafs">﴿ومن يرد فيه بإلحاد بظلم﴾</span>{34}. (١٠/٤٥٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٣٢٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: نزلت في عبد الله بن أنس{35} بن خطل القرشي من بني تيم بن مُرَّة، وذلك أنّ رسول الله ﷺ بعث عبد الله مع رجلين؛ أحدهما مهاجر، والآخر مِن الأنصار، فافتخروا في الأنساب، فغضب ابن خطل، فقتل الأنصاريَّ، ثم هرب إلى مكة كافرًا، ورجع المهاجرُ إلى المدينة، فأمر النبيُّ ﷺ بقتل عبد الله يوم فتح مكة، فقتله أبو بَرْزَة الأسلمي، وسعد بن حُرَيْث القرشي أخو عمرو بن حريث{2}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَمَن یُرِدۡ فِیهِ بِإِلۡحَادِۭ بِظُلۡمࣲ نُّذِقۡهُ مِنۡ عَذَابٍ أَلِیمࣲ ۝٢٥﴾</span> - تفسير الآية</h3></p><p><div></p><p><p><span class="item-no">٥٠٣٢١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن مسعود</span>، رفعه -من طريق مرة- في قوله: <span class="qpc-hafs">﴿ومن يرد فيه بالحاد بظلم﴾</span>، قال: «<b>لو أنّ رجلا هَمَّ فيه بإلحاد وهو بعَدَن أبْيَن؛ لأذاقه الله تعالى عذابًا أليمًا</b>»{37}. (١٠/٤٥٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٣٢٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن مسعود</span> -من طريق مُرَّة- قال: مَن هَمَّ بسيئة لم تُكْتَب عليه حتى يعملها، ولو أنّ رجلًا كان بعدن أبْيَن حدَّث نفسه بأن يلحد في البيت -والإلحاد فيه: أن يَسْتَحِلَّ فيه ما حَرَّم الله عليه-، فمات قبل أن يصل إلى ذلك؛ أذاقه اللهُ مِن عذاب أليم{38}. (١٠/٤٥٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٣٢٣<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن مسعود</span> -من طريق مُرَّة- في قوله: <span class="qpc-hafs">﴿ومن يرد فيه بإلحاد بظلم نذقه من عذاب أليم﴾</span>، قال: مَن هَمَّ بخطيئة فلم يعملها في سوى البيت لم تُكْتَب عليه حتى يعملها، ومَن هَمَّ بخطيئة في البيت لم يُمِتْهُ الله مِن الدنيا حتى يذيقه مِن عذاب أليم{39}. (١٠/٤٥٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٣٢٤<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عمرو بن العاص</span> -من طريق فاطمة السهمية- أنّه قال: الإلحاد: ظلم الخادم، فما فوق ذلك{40}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٣٢٥<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق سعيد بن جبير- قال: <span class="qpc-hafs">﴿ومن يرد فيه بإلحاد بظلم﴾</span>، يعني: من لجأ إلى الحرم، <span class="qpc-hafs">﴿بإلحاد﴾</span>، يعني: بمَيْل عن الإسلام{41}. (١٠/٤٥٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٣٢٦<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- في قوله: <span class="qpc-hafs">﴿ومن يرد فيه بإلحاد بظلم﴾</span>، قال: بشِرْك{42}. (١٠/٤٥٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٣٢٧<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق العوفي- في قوله: <span class="qpc-hafs">﴿ومن يرد فيه بإلحاد بظلم﴾</span>، قال: أن تَسْتَحِلَّ مِن الحرام ما حَرَّم الله عليك؛ من لِسان، أو قتل، فتظلم مَن لا يظلمك، وتقتل مَن لا يقتلك، فإذا فعل ذلك فقد وجب له عذاب أليم{43}. (١٠/٤٥٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٣٢٨<span class="dash">-</span></span> قال <span class="name-1">عبد الله بن عباس</span> -من طريق ابن جريج- <span class="qpc-hafs">﴿بإلحاد بظلم﴾</span>، قال: الذي يريد استحلاله مُتَعَمِّدًا{44}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٣٢٩<span class="dash">-</span></span> عن الربيع بن أنس، في قوله: <span class="qpc-hafs">﴿ومن يرد فيه بإلحاد بظلم نذقه من عذاب أليم﴾</span>، قال: حدَّثنا رجلٌ سَمِعَه مِن عقب المهاجرين والأنصار أنّهم أخبروه: أنّ أيَّما أحدٍ أراد به ما أراد أصحابُ الفيل عجَّل لهم العقوبة في الدنيا. وقال: إنّما يؤتى استحلاله مِن قِبَل أهله. فأخبرني عنهم: أنّه وجد سطران بمكة مكتوبان في المقام؛ أما أحدهما فكتابته: بسم الله، والبركة، وضعتُ بيتي بمكة، طعام أهله اللحم والسمن والتمر، ومَن دخله كان آمنًا، لا يُحِلُّه إلا أهله. قال: لولا أنّ أهله هم الذين فعلوا به ما قد علمت لعجل لهم في الدنيا العذاب. قال: ثم أخبرني أن عبد الله بن عمرو بن العاص قال قبل أن يُستحَلَّ منه الذي استُحِلَّ، قال: أجده مكتوبًا في الكتاب الأول: عبدُ اللهِ يُسْتَحَلُّ بِه الحرمُ. وعنده عبد الله بن عمر بن الخطاب، وعبد الله بن الزبير، فقال عبد الله بن عمرو بن العاص، وعبد الله بن عمر بن الخطاب، قال كل واحد منهما: لستُ قارِبَه إلا حاجًّا أو معتمرًا، أو حاجة لا بُدَّ منها. وسكت عبد الله بن الزبير فلم يقل شيئًا، فاستُحِلَّ مِن بعد ذلك{9}. (١٠/٤٥٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٣٣٠<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span>، في الآية، قال: شَتْمُ الخادمِ في الحرم ظلمٌ، فما فوقه{9}. (١٠/٤٥٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٣٣١<span class="dash">-</span></span> عن <span class="name-2">مجاهد</span> -من طريق القاسم بن أبي بزة- في قوله: <span class="qpc-hafs">﴿ومن يرد فيه بإلحاد بظلم﴾</span>، قال: هو أن يُعْبَد فيه غير الله{43}. (١٠/٤٥٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٣٣٢<span class="dash">-</span></span> عن <span class="name-2">مجاهد</span> -من طريق ابن أبي نجيح- <span class="qpc-hafs">﴿ومن يرد فيه بإلحاد بظلم﴾</span>، قال: من يعمل فيه عملًا سَيِّئًا{48}. (١٠/٤٥٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٣٣٣<span class="dash">-</span></span> عن <span class="name-2">الضحاك بن مُزاحِم</span> -من طريق فضيل بن غزوان- في قوله: <span class="qpc-hafs">﴿ومن يرد فيه بإلحاد﴾</span>، قال: إنّ الرجل لَيَهِمَّ بالخطيئة بمكة، وهو بأرض أخرى، فتكتب عليه، وما عملها{49}. (١٠/٤٥٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٣٣٤<span class="dash">-</span></span> عن <span class="name-2">الضحاك بن مزاحم</span>: هو أن تقتل فيه مَن لا يقتلك، أو تظلم فيه مَن لا يظلمك{50}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٣٣٥<span class="dash">-</span></span> عن <span class="name-2">عطاء بن أبي رباح</span>، <span class="qpc-hafs">﴿ومن يرد فيه بإلحاد بظلم﴾</span>، قال: القَتْل، والشِّرْك{51}. (١٠/٤٥٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٣٣٦<span class="dash">-</span></span> عن <span class="name-2">عطاء [بن أبي رباح]</span> -من طريق ابن أبي ليلى- قال: <span class="qpc-hafs">﴿ومن يرد فيه بإلحاد﴾</span> يَعْبُد غيرَ الله{17}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٣٣٧<span class="dash">-</span></span> عن <span class="name-2">ابن أبي مليكة</span>، أنّه سُئِل عن قوله: <span class="qpc-hafs">﴿ومن يرد فيه بإلحاد بظلم﴾</span>. قال: ما كُنّا نشكُّ أنها الذنوب، حتى جاء أعلاجٌ مِن أهل البصرة إلى أعلاجٍ مِن أهل الكوفة، فزعموا أنها الشِّرك{12}. (١٠/٤٥٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٣٣٨<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿ومن يرد فيه بإلحاد﴾</span>، قال: مَن لَجَأَ إلى الحرم لِيُشْرِك فيه عَذَّبه الله{54}. (١٠/٤٥٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٣٣٩<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق يحيى بن أبي أنيسة- قال: الإلحاد: الاستحلال، فإن قوله: <span class="qpc-hafs">﴿ومن يرد فيه بإلحاد﴾</span> يعني: الظلم فيه، فيقول: مَن يستحله ظالِمًا فيعتدي فيه، فيُحلّ فيه ما حرّم الله{55}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٣٤٠<span class="dash">-</span></span> قال <span class="name-2">إسماعيل السُّدِّيّ</span>: إلا أن يتوب{56}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٣٤١<span class="dash">-</span></span> عن <span class="name-2">حبيب بن أبي ثابت</span> -من طريق أشعث- في قوله: <span class="qpc-hafs">﴿ومن يرد فيه بإلحاد بظلم﴾</span>، قال: هم المُحْتَكِرون الطعام بمكة{44}. (١٠/٤٥٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٣٤٢<span class="dash">-</span></span> عن <span class="name-2">سليمان التيمي</span> -من طريق ابنه المعتمر- قال: <span class="qpc-hafs">﴿ومن يرد فيه بإلحاد بظلم﴾</span>، قال: هو الشِّرْك، مَن أشْرَك في بيت الله عَذَّبه الله{43}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٣٤٣<span class="dash">-</span></span> عن أبي الحجّاج، في الآية، قال: إنّ الرَّجُلَ يُحَدِّث نفسَه أن يعمل ذنبًا بمكة، فيكتبه الله عليه ذنبًا{12}. (١٠/٤٥٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٣٤٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ومن يرد فيه بإلحاد بظلم﴾</span> يقول: مَن لجأ إلى الحرم يميل فيه بشِرْك؛ <span class="qpc-hafs">﴿نذقه من عذاب أليم﴾</span> يعني: وجيعًا{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٣٤٥<span class="dash">-</span></span> تفسير <span class="name-3">محمد بن السائب الكلبي</span>: الإلحاد: المَيْل عن عبادة الله إلى الشرك{25}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٣٤٦<span class="dash">-</span></span> عن <span class="name-3">عبد الملك ابن جُرَيْج</span> -من طريق سعيد بن سالم- في قوله: <span class="qpc-hafs">﴿ومن يرد فيه بإلحادٍ بظلمٍ نذقه من عذاب أليم﴾</span> استحلالًا مُتَعَمِّدًا{62}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٣٤٧<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قول الله: <span class="qpc-hafs">﴿ومن يرد فيه بإلحاد بظلم نذقه من عذاب أليم﴾</span>، قال: الإلحاد: الظُّلْم في الحرم{44}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٣٤٨<span class="dash">-</span></span> قال <span class="name-3">يحيى بن</span> <span class="name-3">سلّام</span>: قوله: <span class="qpc-hafs">﴿ومن يرد فيه بإلحاد بظلم﴾</span> أي: بشِرك؛ <span class="qpc-hafs">﴿نذقه من عذاب أليم﴾</span>{64}<span class=comment-ref>٤٤٥١</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٤٤٥١</span> أفادت الآثارُ اختلاف المفسرين في معنى: «الإلحاد بظلم» على أقوال: <b>الأول:</b> أنّه الشرك بالله بأن يُعبَد فيه غيرُ الله. <b>الثاني:</b> أنّه استحلال الحرام فيه أو فعله. <b>الثالث:</b> استحلال الحَرَم مُتَعَمِّدًا. <b>الرابع:</b> أنّه احتكار الطعام بمكة. <b>الخامس:</b> أنّه كل ما كان منهيًّا عنه مِن الفعل، حتى قول القائل: لا والله، وبلى والله.</p><p>و<span class="comment-type-3">رجَّح</span> <u>ابنُ جرير</u> (١٦/٥١٠) <span class="mustanad">مستندًا إلى دلالة العموم</span> القول الثاني، وهو قول ابن عباس، وابن مسعود، ومجاهد من طريق ابن أبي نجيح، والضحاك، وابن زيد، وبيَّن علَّة ذلك بقوله: «وأولى الأقوال التي ذكرناها في تأويل ذلك بالصواب القولُ الذي ذكرناه عن ابن مسعود، وابن عباس، مِن أنه معنيٌّ بالظلم في هذا الموضع: كل معصية لله. وذلك أنّ الله عمَّ بقوله: <span class="qpc-hafs">﴿ومَن يُرِدْ فِيهِ بِإلْحادٍ بِظُلْمٍ﴾</span> ولم يَخْصُصْ به ظلمًا دون ظلم في خبر ولا عقل؛ فهو على عمومه».</p><p>و<span class="comment-type-4">بيَّن</span> <u>ابنُ عطية</u> (٦/٢٣٤-٢٣٥) عموم معنى الإلحاد لكل تلك الأقوال، فقال بعد سرده الأقوال الواردة في تفسير الإلحاد: «والعموم يأتي على هذا كله».</p><p>و<span class="comment-type-4">كذا</span> <u>ابنُ كثير</u> (١٠/٤٠)، فقال: «وهذه الآثار وإن دلت على أنّ هذه الأشياء من الإلحاد، ولكن هو أعم من ذلك».</div></p><p><h3><span class="qpc-hafs">﴿وَمَن یُرِدۡ فِیهِ بِإِلۡحَادِۭ بِظُلۡمࣲ نُّذِقۡهُ مِنۡ عَذَابٍ أَلِیمࣲ ۝٢٥﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٥٠٣٤٩<span class="dash">-</span></span> عن يعلى بن أمية، عن رسول الله ﷺ، قال: «<b>احتكار الطعام في الحرم إلحادٌ فيه</b>»{65}. (١٠/٤٥٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٣٥٠<span class="dash">-</span></span> عن عبد الله بن عمر، قال: سمعتُ رسول الله ﷺ يقول: «<b>احتكار الطعام بمكة إلحاد</b>»{66}. (١٠/٤٥٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٣٥١<span class="dash">-</span></span> عن <span class="name-1">عمر بن الخطاب</span>، قال: احتكار الطعام بمكة إلحاد بظلم{67}. (١٠/٤٥٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٣٥٢<span class="dash">-</span></span> عن <span class="name-1">عمر بن الخطاب</span> -من طريق إسماعيل بن أُمَيَّة- قال: لَأن أُخْطِىء سبعينَ خطيئة برُكْبَة{68} أحبُّ إلَيَّ مِن أن أخطىء خطيئة واحدة بمكة{69}. (١/٦٥١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٣٥٣<span class="dash">-</span></span> عن مجاهد، قال: رأيتُ <span class="name-1">عبد الله بن عمرو</span> بعرفة ومنزله في الحِلِّ ومسجده في الحرم، فقلتُ له: لِمَ تفعل هذا؟ قال: لأنّ العمل فيه أفضل، والخطيئة فيه أعظم{70}. (١٠/٤٥٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٣٥٤<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، قال: تجارة الأمير بمكة إلحاد{71}. (١٠/٤٥٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٣٥٥<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عبيد بن عمير- قال: أقبل تُبَّع يريد الكعبة، حتى إذا كان بكُراع الغَمِيم{72} بعث الله تعالى عليه ريحًا لا يكاد القائم يقوم إلا بمشقة، ويذهب القائم يقعد فيُصْرَع، وقامت عليه، ولقوا منها عناء، ودعا تُبَّعٌ حَبْرَيه، فسألهما: ما هذا الذي بُعِثَ عَلَيَّ؟ قالا: أوَتُؤَمِّنّا؟ قال: أنتم آمنون. قالا: فإنّك تريد بيتًا يمنعه الله مِمَّن أراده. قال: فما يُذهِب هذا عَنِّي؟ قالا: تَجَرَّد في ثوبين، ثم تقول: لبيك اللهم لبيك، ثم تدخل فتطوف به فلا تُهَيِّج أحدًا من أهله. قال: فإن أجمعتُ على هذا ذَهَبَتْ هذه الريحُ عَنِّي؟ قالا: نعم. فتَجَرَّد، ثُمَّ لَبّى، فأدبرت الريح كقطع الليل المظلم{73}. (١٠/٤٥٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٣٥٦<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عمر</span>، قال: بيع الطعام بمكة إلحاد{74}. (١٠/٤٥٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٣٥٧<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عمر</span>، قال: إنّ قولك في الحرم: كلا واللهِ، وبلى واللهِ؛ كاذبًا؛ إلحادٌ فيه{75}. (١٠/٤٥٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٣٥٨<span class="dash">-</span></span> عن مجاهد، قال: كان ل<span class="name-1">عبد الله بن عمر</span> فُسْطاطان؛ أحدهما في الحِل، والآخر في الحَرَم، فإذا أراد أن يُصَلِّي صلّى في الذي في الحرم، وإذا أراد أن يعاتب أهله عاتبهم في الذي في الحِل. فقيل له، فقال: كنا نُحَدَّث: أنّ مِن الإلحاد فيه أن يقول الرجل: كلا والله، وبلى والله{76}. (١٠/٤٥٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٣٥٩<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span>، قال: تُضاعَف السيئات بمكة كما تُضاعَف الحسنات{77}. (١/٦٥١، ١٠/٤٥٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٣٦٠<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق عثمان بن الأسود- قال: بيع الطعام بمكة إلحاد، وليس الجالب كالمقيم{78}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٣٦١<span class="dash">-</span></span> عن <span class="name-2">عكرمة</span>، قال: ما مِن عبد يَهِمُّ بذنب فيؤاخذه الله بشيء حتى يعمله، إلّا مَن هَمَّ بالبيت العتيق شَرًّا؛ فإنّه مَن همَّ به شَــــــرّا عجَّل الله له{12}. (١٠/٤٥٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٣٦٢<span class="dash">-</span></span> عن <span class="name-3">عبد الملك ابن جُرَيْج</span> -من طريق مسلم بن خالد- قال: بلغني: أنّ الخطيئة بمكة مائة خطيئة، والحسنة على نحو ذلك{80}. (١/٦٥١)</p></p><p></div></p></div>",footnotes:1:علَّقه يحيى بن سلام ١/٣٦١.تفسير مقاتل بن سليمان ٣/١٢١.تفسير يحيى بن سلام ١/٣٦١.عزاه السيوطي إلى عبد حميد.أخرجه الفاكهي في أخبار مكة ٢/١٠٦ (١٢٢٥).تفسير مقاتل بن سليمان ٣/١٢١.تفسير يحيى بن سلام ١/٣٦١.أخرجه الطبراني في الكبير ١٢/٦٧ (١٢٤٩٦). وأورده الديلمي في الفردوس ٢/٣٣٦ (٣٥١٦).</p><p>قال الهيثمي في المجمع ٧/٧٠ (١١١٨٣): «وفيه عبد الله بن مسلم بن هرمز، وهو ضعيف». وقال السيوطي: «بسند صحيح».عزاه السيوطي إلى ابن أبي حاتم.عزاه السيوطي إلى ابن أبي حاتم.أخرجه ابن جرير ١٦/٥٠٢. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.عزاه السيوطي إلى عبد بن حميد.أخرجه ابن أبي شيبة ٤/٧٩.أخرجه ابن جرير ١٦/٥٠٢. وعزاه السيوطي إلى عبد بن حميد.أخرجه ابن أبي شيبة ٤/٧٩ بلفظ: أهل مكة وغيرهم في المنازل سواء، وابن جرير ١٦/٥٠٢ بنحوه. وعزاه السيوطي إلى عبد بن حميد.تفسير مجاهد ص٤٧٨، وأخرجه ابن جرير ١٦/٥٠٣.أخرجه يحيى بن سلام ١/٣٦٢.أخرجه ابن جرير ١٦/٥٠٣. وأورده السيوطي مختصرًا بلفظ: سواء في تعظيم البلد وتحريمه. وعزاه إلى عبد بن حميد أيضًا.أخرجه ابن جرير ١٦/٥٠٢.أخرجه ابن أبي شيبة (ت: محمد عوامة) ٨/٧٣٩ (١٥٨٨٢).تفسير البغوي ٥/٣٧٦.أخرجه البيهقي في شعب الإيمان (٤٠١٥). وعلَّقه يحيى بن سلام ١/٣٦٢. وعزاه السيوطي إلى عبد بن حميد.</p><p>وأخرج عبد الرزاق ٢/٣٤، وابن جرير ١٦/٥٠٢، تفسير هذه الآية عن قتادة من طريق معمر، بلفظ: سواء فيه أهله، وغير أهله. وفي تفسير البغوي ٥/٣٧٧، عنه: هما سواء في البيوت والمنازل.أخرجه ابن جرير ١٦/٥٠١، وابن أبي شيبة ٤/٧٩-٨٠ مختصرًا، بلفظ: البادي الذي يجيء من الحج والمقيمون؛ سواء في المنازل، ينزلون حيث شاءوا، ولا يَخْرُج رجل من بيته.كذا في المصدر.علَّقه يحيى بن سلام ١/٣٦٢.تفسير مقاتل بن سليمان ٣/١٢١.أخرجه ابن جرير ١٦/٥٠٢.تفسير يحيى بن سلام ١/٣٦١.أخرجه الأزرقي في أخبار مكة ٢/١٦٣، والدار قطني في سننه ٤/١٣ (٣٠١٦).</p><p>قال الألباني في الضعيفة ٥/٢٠٨ (٢١٨٦): «ضعيف».رِباعها: منازلها. اللسان (ربع).عزاه السيوطي إلى ابن مردويه.أخرجه ابن سعد ٥/٤٦٥.عزاه السيوطي إلى عبد بن حميد.أخرجه ابن أبي حاتم -كما في تفسير ابن كثير ٥/٤١٢-، من طريق ابن لهيعة، عن عطاء بن دينار، عن سعيد بن جبير، عن ابن عباس به.</p><p>وسنده ضعيف، فيه عبد الله بن لهيعة، وهو ضعيف كما في الميزان ٢/٤٧٥.كذا في المصدر، والمشهور أنه عبد الله بن خَطَل.تفسير مقاتل بن سليمان ٣/١٢١.أخرجه أحمد ٧/١٥٥ (٤٠٧١)، والحاكم ٢/٤٢٠ (٣٤٦١)، وابن جرير ١٦/٥٠٨، وابن أبي حاتم -كما في تفسير ابن كثير ٥/٤١١-، من طريق شعبة، عن السدي، عن مرة، عن عبد الله به.</p><p>قال الحاكم: «هذا حديث صحيح، على شرط مسلم، ولم يخرجاه». ووافقه الذهبي. وقال ابن كثير: «هذا الإسناد صحيح، على شرط البخاري، ووقفه أشبه من رفعه؛ ولهذا صَمَّم شعبةُ على وقفه مِن كلام ابن مسعود، وكذلك رواه أسباط، وسفيان الثوري، عن السدي، عن مرة، عن ابن مسعود موقوفًا». وأورده الدارقطني في العلل الواردة في الحديث ٥/٢٦٩ (٨٧١).أخرجه ابن جرير ١٦/٥٠٨. وعزاه السيوطي إلى ابن أبي شيبة، وعبد بن حميد، وابن المنذر، وابن أبي حاتم.أخرجه الطبراني (٩٠٧٨). وعزاه السيوطي إلى سعيد بن منصور.أخرجه عبد الله بن وهب في الجامع ١/١٢٩-١٣٠ (٢٩٨).أخرجه ابن أبي حاتم -كما في تفسير ابن كثير ٥/٤٠٨-.أخرجه ابن جرير ١٦/٥٠٧. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.أخرجه ابن جرير ١٦/٥٠٧.أخرجه ابن جرير ١٦/٥٠٩.عزاه السيوطي إلى ابن أبي حاتم.عزاه السيوطي إلى ابن أبي حاتم.أخرجه ابن جرير ١٦/٥٠٧.أخرجه ابن جرير ١٦/٥٠٨. وعزاه السيوطي إلى ابن أبي شيبة، وعبد بن حميد، وابن المنذر.أخرجه ابن جرير ١٦/٥٠٨-٥٠٩. وعزاه السيوطي إلى ابن أبي شيبة، وابن المنذر.تفسير البغوي ٥/٣٧٧.عزاه السيوطي إلى سعيد بن منصور، وعبد بن حميد، وابن المنذر.أخرجه يحيى بن سلام ١/٣٦٢.عزاه السيوطي إلى عبد بن حميد.أخرجه عبد الرزاق ٢/٣٤، ويحيى بن سلام ١/٣٦٢، وابن جرير ١٦/٥٠٧، والبيهقي في شعب الإيمان (٤٠١٥).أخرجه الأزرقي في أخبار مكة ٢/٦٩٦.تفسير البغوي ٥/٣٧٨.أخرجه ابن جرير ١٦/٥٠٩.أخرجه ابن جرير ١٦/٥٠٧.عزاه السيوطي إلى عبد بن حميد.تفسير مقاتل بن سليمان ٣/١٢١.علَّقه يحيى بن سلام ١/٣٦٢.أخرجه الأزرقي في أخبار مكة ٢/٦٩٥.أخرجه ابن جرير ١٦/٥٠٩.تفسير يحيى بن سلام ١/٣٦٢.أخرجه أبو داود ٣/٣٦٩ (٢٠٢٠).</p><p>قال ابن القطّان في بيان الوهم والإيهام ٥/٦٩ (٢٣١٥): «حديث لا يَصِح؛ لأن موسى بن باذان مجهول ... ولا يعرف روى عنه غير عمارة بن ثوبان، وهو روى عنه هذا الحديث. وعمارة أيضًا لا يعرف روى عنه غير ابن أخيه جعفر بن يحيى بن ثوبان، وهو روى عنه هذا الحديث، وجعفر أيضًا لا تعرف حاله. فهم كما ترى ثلاثة مجاهيل متتابعين في رواية هذا الحديث». وقال الذهبي في ميزان الاعتدال ١/٤٢٠ ترجمة جعفر بن يحيى ١٥٤٤: «حديث واهي الإسناد». وقال الألباني في ضعيف أبي داود ٢/١٩٢ (٣٤٦): «إسناده ضعيف؛ لجهالة ابن باذان فمَن دونه، وأعله البخاري بالوقف أيضًا، وأقرَّه المنذري».أخرجه الطبراني في الأوسط ٢/١٣٢-١٣٣ (١٤٨٥)، والبيهقي في شعب الإيمان ١٣/٥١٤-٥١٥ (١٠٧٠٨).</p><p>قال الطبراني: «لم يرو هذا الحديث عن عطاء إلا ابن محيصن، تفرَّد به عبد الله بن المؤمل». وقال الهيثمي في المجمع ٤/١٠١ (٦٤٧٩): «رواه الطبراني في الأوسط، وفيه عبد الله بن المؤمل؛ وثَّقه ابن حبان وغيره، وضَعَّفه جماعة».أخرجه البخاري في تاريخه ٧/٢٥٥-٢٥٦. وعزاه السيوطي إلى سعيد بن منصور، وابن المنذر.ركبة: موضع بالحجاز. لسان العرب (ركب).أخرجه الأزرقي في تاريخ مكة ٢/١٣٤. وعزاه السيوطي إلى الجندي.أخرجه عبد الرزاق (٨٨٧٠). وعزاه السيوطي إلى عبد بن حميد.عزاه السيوطي إلى ابن أبي شيبة، وعبد بن حميد، وابن المنذر، وابن أبي حاتم.كُراع الغَمِيم: موضع بين مكة والمدينة. معجم البلدان ٤/٢١٤.أخرجه الحاكم ٢/٣٨٨.عزاه السيوطي إلى عبد بن حميد، وابن أبي حاتم.عزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.أخرجه ابن أبي شيبة (القسم الأول من الجزء الرابع) ص٢٨٥، وابن منيع -كما في المطالب (٤٠٤٧)-، وابن جرير ١٦/٥١٠. وعزاه السيوطي إلى سعيد بن منصور، وعبد بن حميد، وابن المنذر، وابن أبي حاتم، وابن مردويه.عزاه السيوطي إلى ابن أبي شيبة، وابن المنذر، والجندي.أخرجه سعيد بن منصور في سننه - التفسير ٦/٣٢٧ (١٤٧٦).عزاه السيوطي إلى عبد بن حميد.أخرجه الأزرقي في تاريخ مكة ٢/١٣٧.
  22,26,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَإِذۡ بَوَّأۡنَا لِإِبۡرَ ٰ⁠هِیمَ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٠٣٦٣<span class="dash">-</span></span> قال <span class="name-1">عبد الله بن عباس</span>، في قوله: <span class="qpc-hafs">﴿وإذ بوأنا﴾</span>: جعلنا{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٣٦٤<span class="dash">-</span></span> قال <span class="name-2">الحسن البصري</span>، في قوله: <span class="qpc-hafs">﴿وإذ بوأنا﴾</span>: أنزلنا{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٣٦٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: قوله ﷿: <span class="qpc-hafs">﴿وإذ بوأنا لإبراهيم مكان البيت﴾</span> المعمور. قال: دَلَلْنا إبراهيم عليه{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٣٦٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن حيان</span>: هيَّأنا{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٣٦٧<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿وإذ بوأنا لإبراهيم مكان البيت﴾</span>، يقول: أعلمناه{5}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَإِذۡ بَوَّأۡنَا لِإِبۡرَ ٰ⁠هِیمَ مَكَانَ ٱلۡبَیۡتِ أَن لَّا تُشۡرِكۡ بِی شَیۡـࣰٔا﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٠٣٦٨<span class="dash">-</span></span> عن <span class="name-1">علي [بن أبي طالب]</span> -من طريق حارثة بن مُضَرِّب- قال: لَمّا أُمِر إبراهيمُ ببناء البيت خرج معه إسماعيلُ وهاجر، فلمّا قدِم مكة رأى على رأسه في موضع البيت مثلَ الغمامة، فيه مثل الرأس، فكلَّمه، فقال: يا إبراهيم، ابْنِ على ظِلِّي -أو: على قدْرِي-، ولا تزِد ولا تنقص. فلمّا بنى خرج، وخلَّف إسماعيلَ وهاجر، وذلك حين يقول الله: <span class="qpc-hafs">﴿واذ بوأنا لإبراهيم مكان البيت﴾</span>الآية{6}<span class=comment-ref>٤٤٥٢</span>. (١٠/٤٥٩)</p></p><p></div></p><p><div><span class=comment-ref>٤٤٥٢</span> <span class="comment-type-4">علَّق</span> <u>ابنُ كثير</u> (١/٢٨٥) بقوله: «ففي هذا السياق أنه بنى البيت قبل أن يفارقهما، وقد يحتمل -إن كان محفوظًا- أن يكون أولًا وضع له حوطًا وتحجيرًا، لا أنّه بناه إلى أعلاه، حتى كبر إسماعيل فبنياه معًا، كما قال الله».</div></p><p><div></p><p><p><span class="item-no">٥٠٣٦٩<span class="dash">-</span></span> قال ابن المسيب: قال <span class="name-1">ابن أبي طالب</span>: أقبل إبراهيمُ والملَكُ والصُّرَد{7} والسكينةُ دليلًا حتى تَبَّوَؤُا البيت كما تتبوأ العنكبوت{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٣٧٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عمرو بن العاص</span>، قال: لَمّا كان زمنُ الطوفان رُفِع البيت، وكان الأنبياء يحُجُّونه ولا يعلمون مكانه، حتى بوَّأه الله لإبراهيم، وأعلمه مكانه{9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٣٧١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق سعيد بن المسيب- قوله ﷿: <span class="qpc-hafs">﴿وإذ بوأنا لإبراهيم مكان البيت﴾</span>، قال: كان موضعُ البيت ربوةً بيضاء، حولها حجارة مرسومة، حولها حَرَجَة{10} مِن سَمُر{11} نابت، وهو قوله ﷿: <span class="qpc-hafs">﴿وإذ بوأنا لإبراهيم مكان البيت﴾</span>{12}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٣٧٢<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق خُصَيْف- قال: قال إبراهيم: ربنا أرنا مناسكنا. فأخذ جبريل ﵇ بيده، فذهب به حتى أتى به البيت، قال: ارفع القواعد. فرفع إبراهيم القواعد، وأتَمَّ البنيان{13}. (١/٧١١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٣٧٣<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span>، قال: قال الله لإبراهيم ﵇: قُمْ، فابنِ لي بيتًا. قال: أيْ رَبِّ، أين؟ قال: سأخبرك. فبعث الله إليه سحابةً لها رأس، فقالت: يا إبراهيم، إنّ ربك يأمرك أن تَخُطَّ قَدْرَ هذه السحابة. قال: فجعل إبراهيمُ ينظر إلى السحابة ويخط، فقال الرأس: قد فعلتَ؟ قال: نعم. فارتفعت السحابة، فحفر إبراهيمُ، فأبرز عن أساس ثابت مِن الأرض، فبنى إبراهيم ...{14}. (١/٧١٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٣٧٤<span class="dash">-</span></span> عن <span class="name-2">أبي قلابة عبد الله بن زيد الجرمي</span> -من طريق أيوب- أنّه بلغه: أنّ الله -تبارك وتعالى- لَمّا أهبط آدمَ إلى الأرض قال: إنِّي منزلٌ معك بيتًا يُطاف حوله كما يُطاف حول عرشي، فلما كان رأس الطوفان رفعه الله، فكانت الأنبياء بعد ذلك تَحُجُّه، يقومون قريبًا، ولا يدرون أين موضعه، فبوَّأه الله لإبراهيم، فبناه مِن خمسة أجْبُل: من ثَبِير، ولبنان، وجبل الحرى{15}، وطور سيناء{16}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٣٧٥<span class="dash">-</span></span> عن <span class="name-2">عطاء بن أبي رباح</span> -من طريق سوار- قال: لَمّا أهبط الله آدمَ كان رِجلاه في الأرض ورأسُه في السماء، يسمع كلام أهل السماء ودعاءَهم، فأنس إليهم، فهابت الملائكة منه حتى شَكَت إلى الله في دعائها وفي صلاتها، فأخفضه الله إلى الأرض، فلما فقد ما كان يسمع منهم استوحش حتى شكا إلى الله في دعائه وفي صلاته، فوُجِّه إلى مكة، فكان موضع قدمه قرية، وخطوه مفازة، حتى انتهى إلى مكة، فأنزل الله ياقوتةً مِن ياقوت الجنة، فكانت على موضع البيت الآن، فلم يزل يُطاف به حتى أنزل اللهُ الطوفان، فرُفِعت تلك الياقوتة، حتى بعث الله إبراهيم فبناه، فذلك قول الله: <span class="qpc-hafs">﴿واذ بوأنا لابراهيم مكان البيت﴾</span>{17}. (١٠/٤٦٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٣٧٦<span class="dash">-</span></span> عن معمر، عن <span class="name-2">قتادة</span>، قال: وضع الله البيتَ مع آدم حين أهبط اللهُ آدم إلى الأرض، وكان مهبطه بأرض الهند، وكان رأسه في السماء ورِجلاه في الأرض، وكانت الملائكة تهابه، فنقص إلى ستين ذراعًا، فحزن آدمُ إذ فَقَد أصوات الملائكة وتسبيحَهم، فشكا ذلك إلى الله، فقال الله: يا آدم، إنِّي قد أهْبَطتُ لك بيتًا يُطاف به كما يُطاف حول عرشي، ويُصَلّى عنده كما يُصَلّى عند عرشي، فاخرج إليه. فخرج اليه آدم، ومدَّ له في خطوه، فكان بين كل خطوتين مفازة، فلم تزل تلك المفاوز بَعْدُ على ذلك. وأتى آدمُ، فطاف به ومَن بعده مِن الأنبياء.= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٣٧٧<span class="dash">-</span></span> قال معمر: وأخبرني <span class="name-2">أبان</span> أنّ البيت أُهْبِط ياقوتة واحدة، أو درة واحدة. قال معمر: وبلغني: أنّ سفينة نوح طافت بالبيت سبعًا، حتى اذا أغرق الله قوم نوح فُقِد، وبقِيَ أساسه، فبوَّأه الله لإبراهيم، فبناه بعد ذلك، فذلك قول الله: <span class="qpc-hafs">﴿واذ بوأنا لإبراهيم مكان البيت﴾</span>.= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٣٧٨<span class="dash">-</span></span> قال مَعْمَر: قال <span class="name-3">ابن جُرَيج</span>: قال ناس: أرسل اللهُ سبحانه سحابةً فيها رأس، فقال الرأس: يا إبراهيم، إنّ ربك يأمرك أن تأخذ قدر هذه السحابة. فجعل ينظر إليها، ويخط قدرها، قال الرأس: قد فعلتَ؟ قال: نعم. ثم ارْتَفَعَتْ، فحفر، فأبرز عن أساس ثابت في الأرض.= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٣٧٩<span class="dash">-</span></span> قال ابن جريج: قال <span class="name-2">مجاهد</span>: أقبل الملَك والصُّرَد والسكينةُ مع إبراهيم من الشام، فقالت السكينة: يا إبراهيم، ربِّض على البيت. قال: فلذلك لا يطوف البيتَ أعرابيٌّ ولا ملِك مِن هذه الملوك إلا رأيت عليه السكينة والوقار.= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٣٨٠<span class="dash">-</span></span> قال ابن جريج: وقال ابن المسيب: قال <span class="name-1">علي بن أبي طالب</span>: وكان اللهُ استودع الركن أبا قبيس، فلمّا بنى إبراهيمُ ناداه أبو قبيس، فقال: يا إبراهيم، هذا الركن فِيَّ، فخده{18}. فحفر عنه، فوضعه، فلمّا فرغ إبراهيمُ مِن بنائه قال: قد فعلتُ، يا رب، فأرِنا مناسكنا -أبرِزها لنا، وعلِّمناها-. فبعث الله جبريلَ، فحجَّ به، حتى إذا رأى عرفة قال: قد عرفتُ. وكان أتاها قبل ذلك مرَّة، قال: فلذلك سُمِّيَت: عرفة، حتى إذا كان يوم النحر عرض له الشيطان، فقال: احصِبْ. فحصبه بسبع حصيات، ثم اليوم الثاني، فالثالث، فسدَّ ما بين الجبلين -يعني: إبليس-، فلذلك كان رمي الجمار، قال: اعلُ على ثبير. فعلاه، فنادى: يا عباد الله، أجيبوا الله، يا عباد الله، أطيعوا الله. فسمع دعوته مَن بين الأبحر السَّبْعِ مِمَّن كان في قلبه مثقالُ ذَرَّة من الإيمان، فهي التي أعطى الله إبراهيمَ في المناسك، قوله: لبيك اللهم لبيك. ولم يَزَلْ على وجه الأرض سبعةٌ مسلمون فصاعدًا، فلولا ذلك هلكت الأرض ومَن عليها{19}. (١٠/٤٦١-٤٦٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٣٨١<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد بن بشير- وذكر قول الله -تبارك وتعالى-: <span class="qpc-hafs">﴿وإذ بوأنا لإبراهيم مكان البيت﴾</span>، قال: هذا حرم الله قد طاف به آدمُ ومَن بعده، فلما كان إبراهيم أراه الله تعالى مكانة البيت، فاتَّبَع منه أثرًا قديمًا، فبناه مِن طور زيتا، وطور سينا، ومن جبل لبنان{20}، [و]مِن{21} أُحُدٍ وحراء، وجعل قواعده من حراء، ثم قال: <span class="qpc-hafs">﴿وأذن في الناس بالحج﴾</span>{22}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٣٨٢<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span>، قال: إنّ الله ﷿ أمر إبراهيم أن يبني البيت هو وإسماعيل، فانطلق إبراهيمُ حتى أتى مكة، فقام هو وإسماعيل، وأخذا المعاوِل لا يدريان أين البيت، فبعث الله ريحًا يُقال لها: ريح الخَجُوج، لها جناحان ورأس في صورة حيَّة، فكَنَسَت لهما ما حول الكعبة من البيت الأول، واتَّبعاها بالمعاول يحفران حتى وضعا الأساس، فذلك حين يقول الله: <span class="qpc-hafs">﴿واذ بوأنا لابراهيم مكان البيت﴾</span>، فلما بنيا القواعد، فبلغ مكان الركن؛ قال إبراهيم لإسماعيل: اطلب لي حجرا حسنًا أضعه ههنا. قال: يا أبت، إني كسلان لَغِبٌ. قال: عليَّ ذلك. فانطلق يطلب له حجرًا، فأتاه بحجر، فلم يَرْضَه، فقال: ائتني بحجر أحسنَ مِن هذا. فانطلق يطلب له حجرًا، فجاءه جبريل بالحجر الأسود مِن الجَنَّة، وكان أبيضَ ياقوتة بيضاء مثل الثَّغامَة{23}، وكان آدم هَبَط به مِن الجنة، فاسْوَدَّ مِن خطايا الناس، فجاءه إسماعيل بحجر، فوجد عنده الركن، فقال: يا أبتِ، مَن جاءك بهذا؟ قال: جاءني به مَن هو أنشط منك. فبينما هما يدعوان بالكلمات التي ابتلى بها إبراهيمَ ربُّه، فلمّا فرغا من البنيان أمره الله أن ينادي، فقال: أذِّن في الناس بالحج{24}<span class=comment-ref>٤٤٥٣</span>. (١٠/٤٦٢)</p></p><p></div></p><p><div><span class=comment-ref>٤٤٥٣</span> <span class="comment-type-4">علَّقَ</span> <u>ابن كثير</u> (٢/٨٤) على أثر السّدّيّ بقوله: «في هذا السياق ما يَدُلُّ على أن قواعد البيت كانت مبنية قبل إبراهيم، وإنما هُدِي إبراهيمُ إليها، وبُوِّئ لها».</div></p><p><div></p><p><p><span class="item-no">٥٠٣٨٣<span class="dash">-</span></span> قال <span class="name-3">محمد بن السائب الكلبي</span>: بعث الله سحابةً بقدر البيت، فقامت بحِيال البيت، وفيها رأسٌ يتكلم: يا إبراهيم، ابْنِ على قَدْري. فبنى عليه{25}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٣٨٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: قوله ﷿: <span class="qpc-hafs">﴿وإذ بوأنا لإبراهيم مكان البيت﴾</span> المعمور. قال: دَلَلْنا إبراهيم عليه، فبناه مع ابنه إسماعيل ﵉، وليس له أثرٌ ولا أساس، كان الطوفان محا أثرَه، ورفعه الله ﷿ ليالي الطوفان إلى السماء، فعَمَرته الملائكة، وهو البيت المعمور، قال الله ﷿ لإبراهيم: <span class="qpc-hafs">﴿أن لا تشرك بي شيئا﴾</span>{3}<span class=comment-ref>٤٤٥٤</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٤٤٥٤</span> حكى <u>ابنُ عطية</u> (٦/٢٣٧) قولين في المخاطب بقوله تعالى: <span class="qpc-hafs">﴿أنْ لا تُشْرِكْ بِي شَيْئًا﴾</span>: <b>الأول:</b> هي مخاطبة لإبراهيم ﵇. <b>الثاني:</b> هي مخاطبة لمحمد ﷺ، وأمر بتطهير البيت، والأذان بالحج.</p><p>و<span class="comment-type-3">رجَّح</span> القول الأول قائلًا: «والجمهور على أنّ ذلك إبراهيم ﵇، وهو الأصح». ولم يذكر مستندًا.</div></p><p><h3><span class="qpc-hafs">﴿وَإِذۡ بَوَّأۡنَا لِإِبۡرَ ٰ⁠هِیمَ مَكَانَ ٱلۡبَیۡتِ أَن لَّا تُشۡرِكۡ بِی شَیۡـࣰٔا﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٥٠٣٨٥<span class="dash">-</span></span> عن عائشة، قالت: قال رسول الله ﷺ: «<b>دُثِرَ مكانُ البيت، فلم يَحُجَّه هودٌ، ولا صالح، حتى بوَّأه الله لإبراهيم</b>»{27}. (١٠/٤٥٩)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَطَهِّرۡ بَیۡتِیَ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٠٣٨٦<span class="dash">-</span></span> عن علقمة ابن أم علقمة مولاة عائشة، عن أمه، عن <span class="name-1">عائشة</span>، قالت: كسوة البيت على الأمراء، ولكن طَيِّبوا البيت؛ فإنّ ذلك مِن تطهيره{28}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٣٨٧<span class="dash">-</span></span> عن <span class="name-2">عبيد بن عمير</span> -من طريق عطاء- قال: مِن الآفات، والريب{29}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٣٨٨<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ليث- في قوله: <span class="qpc-hafs">﴿وطهر بيتي﴾</span>، قال: مِن الشِّرك{29}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٣٨٩<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق مَعْمَر- <span class="qpc-hafs">﴿طهرا بيتي﴾</span> [البقرة:١٢٥]، قال: مِن الشِّرك، وعبادة الأوثان{31}<span class=comment-ref>٤٤٥٥</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٤٤٥٥</span> لم يذكر <u>ابنُ جرير</u> (١٦/٥١٢-٥١٣) في معنى: <span class="qpc-hafs">﴿وطَهِّرْ بَيْتِيَ﴾</span> سوى قول مجاهد، وعبيد بن عمير، وقتادة من طريق معمر. وقد ذكر ذلك مع غيره (٢/٥٣٢-٥٣٣) عند تفسير قوله تعالى: <span class="qpc-hafs">﴿أن طهرا بيتي﴾</span> [البقرة:١٢٥].</div></p><p><div></p><p><p><span class="item-no">٥٠٣٩٠<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- قال: أيْ: مِن عبادة الأوثان، والشِّرك، وقول الزور، والمعاصي{32}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٣٩١<span class="dash">-</span></span> تفسير <span class="name-2">إسماعيل السُّدِّيّ</span>: قوله: <span class="qpc-hafs">﴿أن لا تشرك بي شيئا وطهر بيتي﴾</span> مِن الأوثان، يعني: لا تَذَرْ حولَه وثنًا يُعْبَد مِن دون الله{33}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٣٩٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وطهر بيتي﴾</span> مِن الأوثان؛ لا تَنصِبْ حوله وثَنًا{3}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿لِلطَّاۤىِٕفِینَ وَٱلۡقَاۤىِٕمِینَ وَٱلرُّكَّعِ ٱلسُّجُودِ ۝٢٦﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٠٣٩٣<span class="dash">-</span></span> عن <span class="name-2">عطاء</span>، في قوله: <span class="qpc-hafs">﴿للطائفين﴾</span> قال: الذين يطوفون به، <span class="qpc-hafs">﴿والقائمين﴾</span> قال: المُصَلِّين عنده{35}. (١٠/٤٦٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٣٩٤<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- قال: القائمون: المُصَلُّون{36}. (١٠/٤٦٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٣٩٥<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- قوله: <span class="qpc-hafs">﴿للطائفين﴾</span> يعني: أهل الطواف، <span class="qpc-hafs">﴿والقائمين﴾</span> قال: القائمون: أهل مكة{28}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٣٩٦<span class="dash">-</span></span> عن <span class="name-2">أبان بن أبي عياش</span> -من طريق المعلى بن هلال- في قوله: <span class="qpc-hafs">﴿للطائفين﴾</span>، قال: الطائفون: الذين يطوفون بالبيت. والركع السجود: الذين يُصَلُّون إليه{28}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٣٩٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿للطائفين﴾</span> بالبيت، <span class="qpc-hafs">﴿والقائمين﴾</span> يعني: المقيمين بمكة مِن أهلها، <span class="qpc-hafs">﴿والركع السجود﴾</span> يعني: في الصلوات الخمس، وفي الطواف حول البيت مِن أهل مكة وغيرهم، والبيت الحرام اليومَ مكان البيت المعمور، ولو أنّ حجرًا وقع مِن البيت المعمور وقع على البيت الحرام، وهو في العرض والطول مثله، إلّا أنّ قامته كما بين السماء والأرض{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٣٩٨<span class="dash">-</span></span> قال <span class="name-3">سفيان الثوري</span>، في قوله: <span class="qpc-hafs">﴿وطهر بيتي للطائفين والقائمين﴾</span>: القائم: المُصَلِّي{40}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٣٩٩<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿والقائمين والركع السجود﴾</span>، قال: القائم والراكع والساجد: هو المصلي. والطائف: هو الذي يطوف به{31}<span class=comment-ref>٤٤٥٦</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٤٤٥٦</span> لم يذكر <u>ابنُ جرير</u> (١٦/٥١٣) في معنى: <span class="qpc-hafs">﴿والقائِمِينَ والرُّكَّعِ السُّجُودِ﴾</span> سوى قول عطاء، وقتادة من طريق معمر، وابن زيد.</div></p><p><div></p><p><p><span class="item-no">٥٠٤٠٠<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿والركع السجود﴾</span> أهل الصلاة يُصَلُّون إليه{42}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿لِلطَّاۤىِٕفِینَ وَٱلۡقَاۤىِٕمِینَ وَٱلرُّكَّعِ ٱلسُّجُودِ ۝٢٦﴾</span> - من أحكام الآية</h3></p><p><div></p><p><p><span class="item-no">٥٠٤٠١<span class="dash">-</span></span> عن <span class="name-1">ابن عباس</span>، قال: قال اللهُ لنبيه: <span class="qpc-hafs">﴿وطهر بيتي للطائفين والقائمين والركع السجود﴾</span>، قال: طواف قبل الصلاة، وقد قال رسول الله ﷺ: «<b>الطواف بالبيت بمنزلة الصلاة، إلّا أنّ الله قد أحَلَّ فيه المنطق، فمَن نطق فلا ينطق إلا بخير</b>»{43}. (١٠/٤٦٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٤٠٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق سعيد بن جبير- أنّه أتاه رجلٌ، فقال: أبْدَأُ بالصفا قبل المروة أو بالمروة قبل الصفا؟ وأُصَلِّي قبل أن أطوف أو أطوف قبل؟ وأحلق قبل أن أذبح أو أذبح قبل أن أحلق؟ فقال ابن عباس: خذوا ذلك مِن كتاب الله؛ فإنّه أجدر أن يحفظ، قال الله: <span class="qpc-hafs">﴿إن الصفا والمروة من شعائر الله﴾</span> [البقرة:١٥٨] فالصفا قبل المروة، وقال: <span class="qpc-hafs">﴿لا تحلقوا رؤوسكم حتى يبلغ الهدي محله﴾</span> [البقرة:١٩٦] فالذبح قبل الحلق، وقال: <span class="qpc-hafs">﴿وطهر بيتي للطائفين والقائمين والركع السجود﴾</span> فالطواف قبل الصلاة{44}. (٢/٩٣)</p></p><p></div></p></div>",footnotes:1:تفسير الثعلبي ٧/١٧.تفسير الثعلبي ٧/١٧.تفسير مقاتل بن سليمان ٣/١٢٢.تفسير الثعلبي ٧/١٧، وتفسير البغوي ٥/٣٧٨ وأورد عقبه: وإنما ذكرنا مكان البيت؛ لأن الكعبة رفعت إلى السماء زمان الطوفان، ثم لَمّا أمر الله تعالى إبراهيم ببناء البيت لم يدْرِ أين يبني، فبعث الله ريحًا خَجُوجًا، فكَنَسَت له ما حول البيت على الأساس.تفسير يحيى بن سلام ١/٣٦٢.أخرجه ابن جرير في التفسير ٢/٥٦٠-٥٦١، وفي التاريخ ١/٢٥٢، والحاكم ٢/٥٥١.الصرد: طائر ضخم الرأس والمنقار، له ريش عظيم، نصفه أبيض ونصفه أسود. النهاية (صرد).أخرجه إسحاق البستي في تفسيره ص٣٥٠.أخرجه ابن أبي حاتم -كما في فتح الباري ٦/٤٠٢-.الحَرَجَة -بالتحريك-: مُجْتَمَع شجَر ملْتَفّ كالغَيْضَة. النهاية (حرج).السَّمُر: نوع من شجَرَ الطَّلح، الواحِدة سَمُرَةٌ. النهاية (سمر).أخرجه يحيى بن سلام ١/٣٦٢.أخرجه سعيد بن منصور (٢٢٠ - تفسير)، وابن أبي حاتم ١/٢٣٥، والأزرقي ١/٣٥ مطولًا.عزاه السيوطي إلى الجندي مطولًا.كذا في المصدر، وقال محققه: هكذا في الأصل، ولعل الصواب: وجبل حراء.أخرجه إسحاق البستي في تفسيره ص٣٥٢.أخرجه عبد الرزاق في المصنف (٩٠٩٠)، وابن جرير ٢/٥٥١. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.هكذا في الأصل.أخرجه عبد الرزاق (٩٠٩٤-٩٠٩٦، ٩٠٩٩)، وابن جرير ٢/٥٥١-٥٥٢، وابن أبي حاتم -كما في فتح الباري ٦/٤٠٩- مختصرًا. وعزاه السيوطي إلى ابن المنذر.وقع في المصدر: جبل لبيان، والظاهر أنه تصحيف؛ ففي سائر المصادر: جبل لبنان.سقطت الواو من المصدر، وقد أثبتناها من مختصره لابن منظور ١/٢٨٧.أخرجه ابن عساكر في تاريخ دمشق ٢/٣٤٧-٣٤٨.الثَّغامة: نبت أبيض الزهر والثمر، يُشَبَّه به الشَّيْب. وقيل: هي شجرة تَبْيَضُّ كأنها الثّلج. النهاية (ثغم).أخرجه ابن جرير ٢/٥٥٧-٥٥٨، ١٦/٥١٢، وابن أبي حاتم ١/٢٣٢-٢٣٣، والبيهقي في الدلائل ٢/٥٣.تفسير البغوي ٥/٣٧٨.تفسير مقاتل بن سليمان ٣/١٢٢.أخرجه وكيع في أخبار القضاة ١/٢٢١، وابن عدي في الكامل في الضعفاء ١/٤٠٦ (٧٩) في ترجمة إبراهيم بن محمد. وعزاه السيوطي إلى أبي الشيخ وابن مردويه والديلمي.</p><p>قال ابن عدي: «منكر الحديث»، يعني: إبراهيم بن محمد. وقال السيوطي: «بسند ضعيف». وقال المناوي في التيسير ٢/٣: «بإسناد واه». وقال الألباني في الضعيفة ٨/٨٧ (٣٥٩٢): «منكر». وقال فيها ١١/٧٥٧ (٥٤٤٦): «ضعيف جدًّا».أخرجه يحيى بن سلام ١/٣٦٣.أخرجه الثوري في تفسيره ص٢١٠، وابن جرير ١٦/٥١٢.أخرجه الثوري في تفسيره ص٢١٠، وابن جرير ١٦/٥١٢.أخرجه ابن جرير ١٦/٥١٣.أخرجه يحيى بن سلّام ١/٣٦٣، وابن جرير ٢/٥٣٣.علَّقه يحيى بن سلام ١/٣٦٣.تفسير مقاتل بن سليمان ٣/١٢٢.أخرجه ابن جرير ١٦/٥١٣، وابن أبي حاتم ١/٢٢٨. وعزاه السيوطي إلى ابن أبي شيبة، وابن المنذر.أخرجه عبد الرزاق ٢/٣٦، وابن جرير ١٦/٥١٣.أخرجه يحيى بن سلام ١/٣٦٣.أخرجه يحيى بن سلام ١/٣٦٣.تفسير مقاتل بن سليمان ٣/١٢٢.تفسير الثوري ص٢١٠.أخرجه ابن جرير ١٦/٥١٣.تفسير يحيى بن سلّام ١/٣٦٣.أخرجه الحاكم ٢/٢٩٣ (٣٠٥٦)، من طريق يزيد بن هارون، أنبأ القاسم بن أبي أيوب، عن سعيد بن جبير، عن ابن عباس به ... ثم ساقه بنحوه من طريق حماد بن سلمة، عن عطاء بن السائب، عن سعيد بن جبير، عن ابن عباس به.</p><p>قال الحاكم: «هذا حديث صحيح، على شرط مسلم، ولم يُخَرِّجاه». وقال ابن الملقن في البدر المنير ٢/٤٩٤: «وحديث حماد بن سلمة عن عطاء في المتابع الذي ذكره الحاكم إسناده جيد؛ فإنه سمع منه قبل الاختلاط». وقال في تحفة المحتاج ١/١٥٦ (٣٠): «والقاسم هذا ثقة، كما قاله أبو داود وغيره». وقال ابن حجر في التلخيص الحبير ١/٣٦٠ معلقًا على تصحيح الحاكم: «وهو كما قال، فإنّهم ثقات». وقال الألباني في الإرواء ١/١٥٤ (١٢١): «صحيح».أخرجه ابن أبي شيبة في مصنفه (ت: محمد عوامة) ٨/٥١٧ (١٤٩١٦)، والحاكم ٢/٢٧٠-٢٧١. وعزاه السيوطي إلى سعيد بن منصور.
  22,27,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَأَذِّن فِی ٱلنَّاسِ بِٱلۡحَجِّ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٠٤٠٣<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق أبي الطفيل- قال: لَمّا أُمر إبراهيم أن يُؤَذِّن في الناس تواضعت له الجبال، ورُفِعت له الأرض، فقام، فقال: يا أيها الناس، أجيبوا ربَّكم{1}. (١٠/٤٦٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٤٠٤<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق صالح مولى التَّوْأَمة- قال: قام إبراهيمُ النبيُّ عند البيت، فأذَّن في الناس بالحج، فسمعه أهلُ المشرق وأهلُ المغرب{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٤٠٥<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق قابوس بن أبي ظبيان، عن أبيه- قال: لَمّا فرغ إبراهيمُ مِن بناء البيت قال: ربِّ، قد فرغت. فقال: أذِّن في الناس بالحج. قال: ربِّ، وما يبلغ صوتي؟! قال: أذِّن وعلَيَّ البلاغُ. قال: ربِّ، كيف أقول؟ قال: يا أيها الناس، كُتِب عليكم الحجُّ إلى البيت العتيق. فسمعه مَن بين السماء والأرض، ألا ترى أنهم يجيئون مِن أقصى الأرض يُلَبُّون؟{3}. (١٠/٤٦٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٤٠٦<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق سعيد بن جبير- قال: لَمّا بنى إبراهيمُ البيتَ أوحى الله إليه: أن أذِّن في الناس بالحج. فقال: ألا إنّ ربَّكم قد اتَّخَذ بيتًا، وأمركم أن تحجوه. فاستجاب له ما سمعه مِن حجر أو شجر أو أكَمَة أو تراب أو شيء؛ فقالوا: لبيك اللهم لبيك{4}. (١٠/٤٦٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٤٠٧<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق مجاهد- في قوله: <span class="qpc-hafs">﴿وأذن في الناس بالحج﴾</span>، قال: قام إبراهيمُ ﵇ على الحجر، فنادى: يا أيها الناس، كتب عليكم الحج. فأَسْمَع مَن في أصلاب الرجال وأرحام النساء، فأجاب مَن آمن مِمَّن سبق في علم الله أن يَحُجَّ إلى يوم القيامة: لبيك اللهم لبيك{5}. (١٠/٤٦٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٤٠٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، قال: لَمّا أمر اللهُ إبراهيم أن يُنادي في الناس بالحَجِّ صعد أبا قبيس، فوضع أصبعيه في أذنيه، ثُمَّ نادى: يا أيها الناس، إنّ الله كتب عليكم الحجَّ، فأجيبوا ربَّكم. فأجابوه بالتلبية في أصلاب الرجال وأرحام النساء، وأوَّلُ مَن أجابه أهلُ اليمن، فليس حاجٌّ مِن يومئذ إلى أن تقوم الساعة إلا مَن كان أجابَ إبراهيمَ يومئذ{6}. (١٠/٤٦٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٤٠٩<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، قال: صعد إبراهيم أبا قبيس، فقال: الله أكبر، الله أكبر، أشهد أن لا إله إلا الله، وأشهد أن إبراهيم رسول الله، أيها الناس، إنّ الله أمرني أن أنادي في الناس بالحج، أيها الناس، أجيبوا ربكم. فأجابه مَن أخذ الله ميثاقَه بالحج إلى يوم القيامة{6}. (١٠/٤٦٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٤١٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق العوفي- في قوله: <span class="qpc-hafs">﴿وأذن في الناس بالحج﴾</span>: يعني بالناس: أهل القبلة، ألم تسمع أنّه قال: <span class="qpc-hafs">﴿ان أول بيت وضع للناس﴾</span> إلى قوله: <span class="qpc-hafs">﴿ومن دخله كان آمنا﴾</span> [آل عمران:٩٦]؟ يقول: ومَن دخله مِن الناس الذين أمر أن يؤذن فيهم، وكتب عليهم الحج؛ فإنّه آمِن، فعَظِّموا حرمات الله تعالى، فإنّها مِن تقوى القلوب{8}. (١٠/٤٧٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٤١١<span class="dash">-</span></span> عن <span class="name-2">عبيد بن عمير</span>، قال: لَمّا أُمِر إبراهيمُ ﵇ بدعاء الناس إلى الله استقبل المشرق، فدعا، ثم استقبل المغرب، فدعا، ثم استقبل الشام، فدعا، ثم استقبل اليمن، فدعا، فأُجِيب: لبيك لبيك{6}. (١٠/٤٦٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٤١٢<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span>، قال: أجاب إبراهيمَ كلُّ جِنِّيٍّ وإنسِيٍّ، وكلُّ شجر وحجر{10}. (١٠/٤٦٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٤١٣<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span> -من طريق عطاء بن السائب- <span class="qpc-hafs">﴿وأذن في الناس بالحج﴾</span>، قال: وقَرَتْ في كلِّ ذكر وأنثى{5}. (١٠/٤٦٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٤١٤<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span> -من طريق عطاء- قال: لَمّا فرغ إبراهيمُ مِن بناء البيت أوحى اللهُ إليه أن أذِّن في الناس بالحج، فخرج، فنادى في الناس: يا أيها الناس، إنّ ربَّكم قد اتخذ بيتًا فحُجُّوه. فلم يسمعه حينئذ مِن إنس ولا جن ولا شجرة ولا أكَمَةٍ ولا تراب ولا جبل ولا ماء ولا شيء إلا قال: لبيك اللهم لبيك{12}. (١٠/٤٦٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٤١٥<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span>، قال: لَمّا أذَّن إبراهيمُ بالحج قال: يا أيها الناس، أجيبوا ربَّكم. فلبّى كلُّ رَطْب ويابس{6}. (١٠/٤٦٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٤١٦<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- قال: لَمّا أُمِر إبراهيم أن يُؤَذِّن في الناس بالحجِّ قام على المقام، فنادى بصوت أسْمَعَ مَن بين المشرق والمغرب: يا أيها الناس، أجيبوا ربكم{14}. (١٠/٤٦٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٤١٧<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق خُصَيْف- قال: قال جبريل لإبراهيم: <span class="qpc-hafs">﴿وأذن في الناس بالحج﴾</span>. قال: كيف أؤذن؟ قال: قل: يا أيها الناس، أجيبوا إلى ربكم. ثلاث مرات، فأجاب العبادُ، فقالوا: لبيك اللهم لبيك، ربنا لبيك لبيك، اللهم ربنا لبيك. قال: فمَن أجاب إبراهيمَ يومئذ مِن الخلق فهو حاجٌّ{15}. (١/٧١١، ١٠/٤٦٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٤١٨<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span>، قال: لما فرغ إبراهيمُ وإسماعيلُ مِن بناء البيت أمر إبراهيمَ أن يُؤَذِّن بالحج، فقام على الصَّفا، فنادى بصوتٍ سَمِعه ما بين المشرق والمغرب: يا أيها الناس، أجيبوا إلى ربكم. فأجابوه وهم في أصلاب آبائهم، فقالوا: لبيك. قال: فإنّما يَحُجُّ البيتَ اليومَ مَن أجاب إبراهيم يومئذ{10}. (١٠/٤٦٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٤١٩<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق منصور- قال: قال إبراهيم: كيف أقول؟ قال: قل: يا أيها الناس، أجيبوا ربَّكم. فما خلق اللهُ مِن جبل ولا شجر ولا شيء مِن المطيعين له إلا ينادي: لبيك اللهم لبيك. فصارت التلبية{17}. (١٠/٤٦٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٤٢٠<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق منصور- قوله: <span class="qpc-hafs">﴿وأذن في الناس بالحج﴾</span>: قال إبراهيم: كيف أقول، يا رب؟ قال: قل: يا أيها الناس، استجيبوا لربكم. قال: فوَقَرَتْ في قلب كل مؤمن{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٤٢١<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق منصور- قال: أُمِر إبراهيمُ ﷺ أن يُؤَذِّن بالحج، فقام على المقام، فتطاول به حتى صار كأطول جبل، فنادى: يا أيها الناس، أجيبوا ربَّكم. مرتين، فأجابوه مِن تحت البحور السبع: لَبَّيك أجبنا، لبيك أطعنا. فمَن حَجَّ إلى يوم القيامة فهو مِمَّن استجاب له يومئذ، فوَقَرَتْ في نفس كل مسلم{19}. (١٠/٤٦٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٤٢٢<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق سلمة- قال: قيل لإبراهيم: أذِّن في الناس بالحج. قال: يا رب، كيف أقول؟ قال: قل: لبيك اللهم لبيك. فكان إبراهيمُ أولَ مَن لَبّى{20}. (١٠/٤٦٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٤٢٣<span class="dash">-</span></span> عن <span class="name-2">عكرمة بن خالد المخزومي</span>، قال: لَمّا أُمِر إبراهيم بالحج قام على المقام، فنادى نِداءً سمعه جميعُ أهل الأرض: ألا إنّ ربكم قد وضع بيتًا، وأمركم أن تحجوه. فجعل اللهُ في أثر قدميه آيةً في الصخرة{21}. (١٠/٤٦٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٤٢٤<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span>: أنّ قوله: <span class="qpc-hafs">﴿وأذن في الناس بالحج﴾</span> كلام مُسْتَأْنَف، وأنّ المأمور بهذا التَّأْذِين محمدٌ ﷺ، أُمِر أن يفعل ذلك في حجة الوداع{22}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٤٢٥<span class="dash">-</span></span> عن <span class="name-2">عطاء</span>، قال: صعد إبراهيم على الصفا، فقال: يا أيها الناس، أجيبوا ربَّكم. فأَسْمَع مَن كان حيًّا في أصلاب الرجال{23}. (١٠/٤٦٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٤٢٦<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- قال: لَمّا فرغ إبراهيمُ وإسماعيلُ مِن بُنيان البيت أمره الله أن يُنادي، فقال: <span class="qpc-hafs">﴿وأَذِّنْ فِي النّاسِ بِالحَجِّ﴾</span>. فنادى بين أخْشَبَيْ مكة: يا أيها الناس، إنّ الله يأمركم أن تَحُجُّوا بيته. قال: فوَقَرَتْ في قلب كُلِّ مؤمن، فأجابه كلُّ شيء سمعه مِن جبل أو شجر أو دابة: لبيك لبيك. فأجابوه بالتلبية: لبيك اللهم لبيك. وأتاه مَن أتاه{24}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٤٢٧<span class="dash">-</span></span> عن <span class="name-3">علي بن أبي طلحة</span>: أنّ الله أوحى إلى إبراهيم ﵇: أن أذِّن في الناس بالحج. فقام على الحجر، فقال: يا أيها الناس، إنّ الله يأمركم بالحج. فأجابه مَن كان مخلوقًا في الأرض يومئذ، ومَن كان في أرحام النساء، ومَن كان في أصلاب الرجال، ومَن كان في البحور، فقالوا: لبيك اللهم لبيك{6}. (١٠/٤٦٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٤٢٨<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وأذن﴾</span> يا إبراهيم <span class="qpc-hafs">﴿في الناس﴾</span> يعني: المؤمنين <span class="qpc-hafs">﴿بالحج﴾</span> فصعد أبا قبيس، وهو الجبلُ الذي الصفا في أصله، فنادى: يا أيها الناس، أجيبوا ربكم، إنّ الله ﷿ يأمركم أن تَحُجُّوا بيتَه. فسمع نداءَ إبراهيم ﵇ كلُّ مؤمن على ظهر الأرض، ويُقال: في أصلاب الرجال وأرحام النساء، فالتلبية اليوم جوابُ نداء إبراهيم ﵇ عن أمر ربِّه ﷿، فذلك قوله سبحانه: <span class="qpc-hafs">﴿يأتوك رجالا﴾</span>{26}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿یَأۡتُوكَ رِجَالࣰا وَعَلَىٰ كُلِّ ضَامِرࣲ﴾</span> - نزول الآية</h3></p><p><div></p><p><p><span class="item-no">٥٠٤٢٩<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق عمر بن ذَرٍّ- قال: كانوا يَحُجُّون ولا يتزودون؛ فأنزل الله: <span class="qpc-hafs">﴿وتزودوا﴾</span> [البقرة:١٩٧]، وكانوا يحجون ولا يركبون؛ فأنزل الله: <span class="qpc-hafs">﴿يأتوك رجالا وعلى كل ضامر﴾</span>، فأمرهم بالزاد، ورخَّص لهم في الرُّكُوب، والمتجر{27}. (١٠/٤٧٢)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿یَأۡتُوكَ رِجَالࣰا﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٠٤٣٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق ابن جُرَيْج- <span class="qpc-hafs">﴿يأتوك رجالا﴾</span>، قال: مُشاة{28}. (١٠/٤٧١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٤٣١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق قتادة- في قوله: <span class="qpc-hafs">﴿يأتوك رجالا﴾</span>، قال: على أرجُلِهم{28}. (١٠/٤٧١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٤٣٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، في قوله: <span class="qpc-hafs">﴿يأتوك رجالا وعلى كل ضامر﴾</span>، قال: هُم المُشاة والرُّكْبان{30}. (١٠/٤٧٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٤٣٣<span class="dash">-</span></span> عن محمد بن كعب القرظي، قال: سمعتُ <span class="name-1">عبد الله بن عباس</span> يقول: ما آسى على شيء إلا أنِّي لم أكُن حججت راجِلًا؛ لأني سمعت الله يقول: <span class="qpc-hafs">﴿يأتوك رجالا﴾</span>. وهكذا كان يقرؤها{31}. (١٠/٤٧٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٤٣٤<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، قال: ما آسى على شيء فاتني إلا أني لم أحج ماشيًا حتى أدركني الكِبَر، أسمع الله تعالى يقول: <span class="qpc-hafs">﴿يأتوك رجالا وعلى كل ضامر﴾</span>، فبدأ بالرِّجال قبل الرُّكْبان{32}. (١٠/٤٧٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٤٣٥<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span> -من طريق عمران- <span class="qpc-hafs">﴿رجالًا﴾</span>: على أرجُلِهم{33}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٤٣٦<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- قوله: <span class="qpc-hafs">﴿يأتوك رجالا﴾</span>، قال: مُشاة{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٤٣٧<span class="dash">-</span></span> عن ابن جُرَيْج، قال: سُئِل <span class="name-2">عطاء [بن أبي رباح]</span> عن الحجِّ؛ ماشيًا أو راكِبًا؟ فقال: أما سمعتَ الله -تبارك وتعالى- يقول: <span class="qpc-hafs">﴿يأتوك رجالا وعلى كل ضامر﴾</span>{35}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٤٣٨<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿يأتوك رجالا﴾</span>، يعني: على أرجلهم مُشاة{26}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَعَلَىٰ كُلِّ ضَامِرࣲ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٠٤٣٩<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق ابن جُرَيْج- <span class="qpc-hafs">﴿وعلى كل ضامر﴾</span>، قال: الإبل{37}. (١٠/٤٧١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٤٤٠<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿وعلى كل ضامر﴾</span>، قال: لا تبلغه المُطِيُّ حتى تضمُر{38}. (١٠/٤٧٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٤٤١<span class="dash">-</span></span> عن <span class="name-2">عطاء الخراساني</span> -من طريق يونس- في قول الله ﷿: <span class="qpc-hafs">﴿يأتوك رجالا وعلى كل ضامر﴾</span>، قال: الإبل والدواب{39}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٤٤٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وعلى كل ضامر﴾</span>، يعني: الإبل{26}<span class=comment-ref>٤٤٥٧</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٤٤٥٧</span> ذكر <u>ابنُ عطية</u> (٦/٢٣٨) في معنى «الضامر» قولين: <b>الأول:</b> أنها الناقة. ثم <span class="comment-type-4">علَّق</span> عليه قائلًا: «فيجيء قوله تعالى: <span class="qpc-hafs">﴿يَأْتِينَ﴾</span> مستقيمًا على هذا التأويل». <b>والثاني:</b> أنها كل ما اتَّصف بذلك من جمل وناقة وغير ذلك. و<span class="comment-type-3">رجَّحه</span> بقوله: «وهذا هو الأظهر». ولم يذكر مستندًا، ثم <span class="comment-type-1">وجَّه</span> هذا المعنى مع قوله: <span class="qpc-hafs">﴿يَأْتِينَ﴾</span>، فقال: «لكنه يتضمن معنى الجماعات أو الرفاق، فيحسن لذلك قوله: <span class="qpc-hafs">﴿يَأْتِينَ﴾</span>».</div></p><p><h3><span class="qpc-hafs">﴿یَأۡتِینَ مِن كُلِّ فَجٍّ عَمِیقࣲ ۝٢٧﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٠٤٤٣<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -طريق العوفي- <span class="qpc-hafs">﴿من كل فج عميق﴾</span>، قال: مكان بعيد{41}. (١٠/٤٧٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٤٤٤<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>: أنّ نافع بن الأزرق سأله عن قوله: <span class="qpc-hafs">﴿من كل فج عميق﴾</span>. قال: طريق بعيد. قال: وهل تعرفُ العرب ذلك؟ قال: نعم، أما سمعت قولَ الشاعر:</p><p>حازوا العِيالَ وسَدُّوا الفِجا ج بأجساد عادٍ لَها آبدات؟{42}. (١٠/٤٧٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٤٤٥<span class="dash">-</span></span> عن <span class="name-2">أبي العالية الرياحي</span>، <span class="qpc-hafs">﴿من كل فج عميق﴾</span>، قال: مكان بعيد{30}. (١٠/٤٧٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٤٤٦<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جَبْر</span>، في قوله: <span class="qpc-hafs">﴿من كل فج عميق﴾</span>، قال: طريق بعيد{44}. (١٠/٤٧٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٤٤٧<span class="dash">-</span></span> عن <span class="name-2">الضحاك بن مُزاحِم</span>، مثله{10}. (١٠/٤٧٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٤٤٨<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق مَعْمَر- <span class="qpc-hafs">﴿فج عميق﴾</span>، قال: مكان بعيد{46}. (١٠/٤٧٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٤٤٩<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- قال: عمق ما بين تهامة والعراق، ويُؤتى مِن أبعد من ذلك{47}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٤٥٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿يأتين من كل فج عميق﴾</span>، يعني: يجيء مِن كل مكان بعيد{26}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٤٥١<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>، في قوله: <span class="qpc-hafs">﴿يأتين من كل فج عميق﴾</span>: يعني: بعيد{49}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿یَأۡتِینَ مِن كُلِّ فَجٍّ عَمِیقࣲ ۝٢٧﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٥٠٤٥٢<span class="dash">-</span></span> عن عليٍّ، رفعه: «<b>لَمّا نادى إبراهيمُ بالحجِّ لَبّى الخلقُ، فمَن لَبّى تلبيةً واحدة حَجَّ واحدة، ومَن لَبّى مَرَّتين حجَّ حَجَّتين، ومَن زاد فبحساب ذلك</b>»{50}. (١٠/٤٦٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٤٥٣<span class="dash">-</span></span> عن عبيد بن عمير، قال: لَقِي <span class="name-1">عمرُ بن الخطاب</span> رَكْبًا يُريدون البيت، فقال: مَن أنتم؟ فأجابه أحدثهم سِنًّا، فقال: عباد الله المسلمون. فقال: مِن أين جئتم؟ قال: مِن الفجِّ العميق. قال: أين تُريدون؟ قال: البيت العتيق. فقال عمر: تَأَوَّلها، لعَمْرُ اللهِ. فقال عمر: مَن أميركم؟ فأشار إلى شيخ منهم، فقال عمر: بل أنت أميرُهم. لِأحدثهم سِنًّا الذي أجابه{51}. (١٠/٤٧٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٤٥٤<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق سالم بن أبي الجعد- قال: أتدري كيف كانت التلبية؟ إنّ إبراهيم لَمّا أُمِر أن يُؤَذِّن في الناس بالحج؛ أُمِرَت الجبال فخفضت رؤوسها، ورُفِعَت له القرى، فأذَّن في الناس بالحج{52}. (١/٧١٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٤٥٥<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن الزبير</span>، قال: أُخِذَ الأذانُ مِن أذانِ إبراهيم في الحج: <span class="qpc-hafs">﴿وأذن في الناس بالحج﴾</span>. قال: فأذَّن رسولُ الله ﷺ للصلاة{53}. (١٠/٤٦٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٤٥٦<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- قال: حجَّ إبراهيمُ وإسماعيلُ ماشِيَيْنِ{54}. (١٠/٤٧٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٤٥٧<span class="dash">-</span></span> عن <span class="name-2">وهب بن مُنَبِّه</span> -من طريق عثمان بن ساج-: أنّ آدم لَمّا أُهْبِط إلى الأرض استوحش فيها؛ لِما رأى مِن سَعَتِها، ولم يَرَ فيها أحدًا غيره، فقال: يا ربِّ، أما لأرضك هذه عامِرٌ يُسَبِّحُك فيها ويُقَدِّس لك غيري؟ قال الله: إنِّي سأجعل فيها مِن ذُرِّيَّتِك مَن يُسَبِّح بحمدي، ويُقَدِّس لي، وسأجعل فيها بيوتًا ترفع لذكري، فيُسَبِّح فيها خلقي، سأُبَوِّئُك فيها بيتًا أختاره لنفسي، وأَخُصُّه بكرامتي، وأُوثِرُه على بيوت الأرض كلها باسمي، وأُسَمِّيه بيتي، أنظمه بعظمتي، وأحوزه بحُرْمَتي، وأجعله أحقَّ البيوت كلها وأولاها بذكري، وأَضَعُه في البقعة المباركة التي اخترت لنفسي، فإنِّي اخترتُ مكانه يوم خلقتُ السموات والأرض، وقبل ذلك قد كان بغيتي، فهو صفوتي مِن البيوت، ولست أسكنه، وليس ينبغي أن أسكن البيوت، ولا ينبغي لها أن تحملني، أجعل ذلك البيتَ لك ومَن بعدك حَرَمًا وأَمْنًا، أُحَرِّم بحُرْمَتِه ما فوقه وما تحته وما حوله، فمَن حرَّمه بحرمتي فقد عظَّم حرمتي، ومَن أحلَّه فقد أباح حرمتي، مَن أمَّن أهلَه استوجب بذلك أماني، ومَن أخافهم فقد أخْفَرني في ذِمَّتي، ومَن عظَّم شأنه فقد عَظُم في عيني، ومَن تهاون به صَغُر عندي، ولكل ملك حيازة، وبطن مكة حوزتي التي حُزْتُ لنفسي دون خلقي، فأنا الله ذو بَكَّة، أهلها خَفْرتي وجيران بيتي، وعُمّارها وزُوّارها وفْدِي وأضيافي في كَنَفي وضماني وذِمَّتي وجِواري، أجعله أولَ بيت وُضِع للناس، وأعمره بأهل السماء وأهل الأرض، يأتونه أفواجًا شُعْثًا غُبْرًا، على كُلِّ ضامر يأتين مِن كل فج عميق، يَعُجُّون بالتكبير عَجِيجًا، ويَرُجُّون بالتلبية رَجِيجًا، فمَنِ اعتمره لا يريد غيري فقد زارني، وضافني، ووفد إلَيَّ، ونزل بي، فحقٌّ لي أن أُتْحِفَه بكرامتي، وحقُّ الكريم أن يُكْرِم وفده وأضيافه وزُوّاره، وأن يسعف كلَّ واحد منهم بحاجته، تعمره -يا آدمُ- ما كُنتَ حَيًّا، ثم يعمره مِن بعدك الأممُ والقرونُ والأنبياءُ مِن ولدك، أُمَّة بعد أُمَّة، وقرنًا بعد قرن، ونبيًّا بعد نبي، حتى ينتهي ذلك إلى نبيٍّ مِن ولدك يُقال له: محمد، وهو خاتم النبيين، فأجعله من عُمّاره وسُكّانه وحُماته ووُلاته وحُجّابه وسُقاته، يكون أميني عليه ما كان حَيًّا، فإذا انقلب إلَيَّ وجدني قد ادَّخَرْتُ له مِن أجره ونصيبه ما يتمكن به مِن القُرْبَة إلَيَّ والوسيلة عندي، وأفضل المنازل في دار المقامة، وأجعل اسم ذلك البيت وذِكْرَه وشرفه ومجده وسناه ومكرمته لنبيٍّ مِن ولدك، يكون قبيل هذا النبي، وهو أبوه، يُقال له: إبراهيم، أرفع له قواعده، وأقضي على يديه عمارته، وأنيط له سقايته، وأُريه حِلَّه وحَرَمه ومواقفه، وأُعلمه مشاعره ومناسكه، وأَجعلُه أُمَّة واحدة قانتًا قائمًا بأمري، داعيًا إلى سبيلي، وأَجتبيه وأهديه إلى صراط مستقيم، أبتليه فيصبر، وأعافيه فيشكر، وآمره فيفعل، ويُنذر لي فيفي، ويَعِدُني فيُنجِز، أستجيب دعوتَه في ولده وذريته مِن بعده، وأُشَفِّعه فيهم، وأجعلهم أهلَ ذلك البيت وحُماته وسُقاته وخدمه وخزنته وحُجّابه، حتى يبتدعوا ويُغَيِّروا ويُبَدِّلوا، فإذا فعلوا ذلك فأنا أقدر القادرين على أن استبدل مَن أشاء بِمَن أشاء، وأجعلُ إبراهيم إمامَ ذلك البيت وأهلَ تلك الشريعة، يأتمُّ به مَن حضر تلك المواطن مِن جميع الإنس والجن، يَطَؤُون فيها آثاره، ويَتَّبعون فيها سُنَّته، ويقتدون فيها بهديه، فمَن فعل ذلك منهم أوْفى بنذره، واستكمل نُسُكَه، وأصاب بُغْيَته، ومَن لم يفعل ذلك منهم ضَيَّع نسكه، وأخطأ بغيته، ولم يوف بنذره، فمن سأل عنِّي يومئذ في تلك المواطن: أين أنا؟ فأنا مع الشُّعْثِ، الغُبْر، المُوفِين بنذرهم، المستكملين مناسكهم، المتبتلين إلى ربهم، الذي يعلم ما يبدون وما يكتمون{55}. (١/٦٧٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٤٥٨<span class="dash">-</span></span> عن عكرمة، ووهب بن منبه، رفعاه إلى <span class="name-1">ابن عباس</span>، بمثله سواء{56}. (١/٦٨١)</p></p><p></div></p></div>",footnotes:1:أخرجه يحيى بن سلام ١/٣٦٤، وابن جرير ١٦/٥١٦-٥١٧، والطبراني (١٠٦٢٨)، والبيهقي في شعب الإيمان (٤٠٧٧). وعزاه السيوطي إلى ابن أبي حاتم.أخرجه يحيى بن سلام ١/٣٦٤.أخرجه ابن أبي شيبة ١١/٥١٨، وابن منيع -كما في المطالب (١١٩٦)-، وفتح الباري ٣/٤٠٩، وابن جرير ١٦/٥١٤-٥١٥، وابن أبي حاتم -كما في فتح الباري ٣/٤٠٩-، والحاكم ٢/٣٨٨-٣٨٩، والبيهقي في سننه ٥/١٧٦ واللفظ له. وعزاه السيوطي إلى ابن المنذر.أخرجه يحيى بن سلام ١/٣٦٤، وابن جرير ١٦/٥١٥، والحاكم ٢/٥٥٢، والبيهقي في سننه ٥/١٧٦، وفي الشعب (٣٩٩٨)، وفي الدلائل ٢/٥٤. وعزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ١٦/٥١٥.عزاه السيوطي إلى ابن أبي حاتم.عزاه السيوطي إلى ابن أبي حاتم.أخرجه ابن جرير ١٦/٥١٧.عزاه السيوطي إلى ابن أبي حاتم.عزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ١٦/٥١٥.أخرجه ابن جرير ١٦/٥١٦.عزاه السيوطي إلى ابن أبي حاتم.أخرجه البيهقي في الشعب (٤٠٠٠). وعزاه السيوطي إلى سعيد بن منصور، وابن المنذر، وابن أبي حاتم.أخرجه سعيد بن منصور (٢٢٠ - تفسير)، وابن أبي حاتم ١/٢٣٥، والأزرقي ١/٣٥ مطولًا. وعزاه السيوطي إلى عبد بن حميد.عزاه السيوطي إلى عبد بن حميد.أخرجه البيهقي في الشعب (٣٩٩٩). وعزاه السيوطي إلى سعيد بن منصور، وابن المنذر، وابن أبي حاتم.أخرجه ابن جرير ١٦/٥١٧.أخرجه الثوري في تفسيره ص٢١٠. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم بنحوه.أخرجه ابن جرير ١٦/٥١٧ من طريق سلمة. وعزاه السيوطي إلى عبد بن حميد.عزاه السيوطي إلى عبد بن حميد، وابن المنذر. وأخرجه ابن جرير ١٦/٥١٦ بنحوه من طريق داود دون آخره. وزاد فيه: قال داود: فأرجو مَن حج اليوم مِن إجابة إبراهيم ﵇. وأخرجه يحيى بن سلام ١/٣٦٣ من طريق قتادة بنحوه، وزاد فيه: فأسْمَعَ ما بين الخافقين أو المشرقين، وأقبل الناس: لبيك اللهم لبيك. ثم عقَّب عليه يحيى بن سلام بقوله: بلغني: أنه أجابه يومئذ مَن كان حاجًّا إلى يوم القيامة.تفسير الثعلبي ٧/١٨، وتفسير البغوي ٥/٣٧٩.عزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه ابن جرير ٢/٥٦٧ مطولًا.عزاه السيوطي إلى ابن أبي حاتم.تفسير مقاتل بن سليمان ٣/١٢٣.أخرجه عبد الرزاق ١/٧٧، وابن جرير ١٦/٥١٩ مرسلًا.أخرجه ابن جرير ١٦/٥١٨.أخرجه ابن جرير ١٦/٥١٨.عزاه السيوطي إلى ابن المنذر.أخرجه الخطيب في تاريخه ٧/٤٠٤-٤٠٥، وابن جرير ١٦/٥١٨.أخرجه ابن أبي شيبة ٤/٩٧-٩٨، وابن جرير ١٦/٥١٨ من طريق حجاج بن أرطاة بنحوه، وابن أبي حاتم -كما في فتح الباري ٣/٣٧٩-، والبيهقي ٤/٣٣١، وفي الشعب (٣٩٨٠)، من طريق محمد بن عطاء. وعزاه السيوطي إلى ابن سعد، وعبد بن حميد، وابن المنذر.أخرجه الحربي في غريب الحديث ٢/٤١٨.أخرجه يحيى بن سلام ١/٣٦٤.أخرجه الفاكهيُّ في أخبار مكة ١/٣٩٨ (٨٤٧).تفسير مقاتل بن سليمان ٣/١٢٣.أخرجه ابن جرير ١٦/٥١٩.أخرجه يحيى بن سلام ١/٣٦٤. وعزاه السيوطي إلى عبد بن حميد، وابن أبي حاتم.أخرجه أبو جعفر الرملي في جزئه ص١١٧ (تفسير عطاء الخراساني).تفسير مقاتل بن سليمان ٣/١٢٣.أخرجه ابن جرير ١٦/٥١٩، كذلك أخرجه بنحوه من طريق ابن جريج.عزاه السيوطي إلى الطستي في مسائله. وينظر: الإتقان ٣/٨٨٥.عزاه السيوطي إلى ابن المنذر.عزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.عزاه السيوطي إلى عبد بن حميد.أخرجه عبد الرزاق ٢/٣٦، وابن جرير ١٦/٥١٩.أخرجه يحيى بن سلام ١/٣٦٥.تفسير مقاتل بن سليمان ٣/١٢٣.تفسير يحيى بن سلام ١/٣٦٥.أورده الديلمي ٣/٤٢٥ (٥٣٠٣).</p><p>قال السيوطي: «بسند واهٍ». وأورده ابن عراق في تنزيه الشريعة ٢/١٧٦ (٢٧)، وقال الشوكاني في الفوائد المجموعة ص١٠٩ (١٦): «قال في الذيل: هو مِن نسخة محمد بن الأشعث التي عامتها مناكير».أخرجه عبد الرزاق في المصنف (٣٨١٣).أخرجه الطيالسي (٢٨٢٠)، والبيهقي في الشعب (٤٠٧٧)، وأحمد ٤/٤٣٦-٤٣٧ (٢٧٠٧، ٢٧٠٨).عزاه السيوطي إلى أبي الشيخ في كتاب الأذان.أخرجه ابن أبي شيبة ٤/٩٨، وابن جرير ١٦/٥١٨. كما أخرجه يحيى بن سلام ١/٣٦٤ موقوفًا على ابن أبي نجيح.</p><p><b>وقد أورد السيوطي ١٠/٤٧٠-٤٧١ آثارًا أخرى عن فضل الحج مشيًا.</b>أخرجه الأزرقي في فضائل مكة ١/١٥-١٧، والبيهقي في الشعب (٣٩٨٥).عزاه السيوطي إلى الجندي.
  22,28,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿لِّیَشۡهَدُوا۟ مَنَـٰفِعَ لَهُمۡ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٠٤٥٩<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق أبي رزين- <span class="qpc-hafs">﴿ليشهدوا منافع لهم﴾</span>، قال: أسواقًا كانت لهم، ما ذكر الله منافع إلا الدنيا{1}. (١٠/٤٧٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٤٦٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، في قوله: <span class="qpc-hafs">﴿ليشهدوا منافع لهم﴾</span>، قال: منافع في الدنيا، ومنافع في الآخرة؛ فأمّا منافع الآخرة فرضوان الله، وأمّا منافع الدنيا فما يصيبون من لحوم البدن في ذلك اليوم والذبائح والتجارات{2}. (١٠/٤٧٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٤٦١<span class="dash">-</span></span> عن <span class="name-2">أبي رزين [مسعود بن مالك الأسدي]</span> -من طريق عاصم بن بهدلة- في قوله: <span class="qpc-hafs">﴿ليشهدوا منافع لهم﴾</span>، قال: أسواقهم{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٤٦٢<span class="dash">-</span></span> قال <span class="name-2">سعيد بن المسيب</span>: العفو والمغفرة{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٤٦٣<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span> -من طريق واقد- <span class="qpc-hafs">﴿ليشهدوا منافع لهم﴾</span>، قال: التجارة{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٤٦٤<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- <span class="qpc-hafs">﴿ليشهدوا منافع لهم﴾</span>، قال: الأجر في الآخرة، والتجارة في الدنيا{6}. (١٠/٤٧٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٤٦٥<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- <span class="qpc-hafs">﴿ليشهدوا منافع لهم﴾</span>، قال: فيما يرضى اللهُ لهم مِن الدنيا والآخرة{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٤٦٦<span class="dash">-</span></span> قال <span class="name-2">عطية العوفي</span>: العفو والمغفرة{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٤٦٧<span class="dash">-</span></span> عن <span class="name-2">أبي جعفر محمد بن علي</span> -من طريق جابر- <span class="qpc-hafs">﴿ليشهدوا منافع لهم﴾</span>، قال: العفو. وفي لفظ: مغفرة{9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٤٦٨<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ليشهدوا منافع لهم﴾</span>، يعني: الأجر في الآخرة في مناسكهم{10}<span class=comment-ref>٤٤٥٨</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٤٤٥٨</span> أفادت الآثارُ اختلاف المفسرين في معنى «المنافع» على أقوال: <b>الأول:</b> أنها التجارة ومنافع الدنيا. <b>الثاني:</b> الأجر في الآخرة والتجارة في الدنيا. <b>الثالث:</b> العفو والمغفرة.</p><p>و<span class="comment-type-3">رجَّح</span> <u>ابنُ جرير</u> (١٦/٥٢٢) <span class="mustanad">مستندًا إلى دلالة العموم</span> شمول المعنى لجميع المنافع، فقال: «وأولى الأقوال بالصواب قولُ مَن قال: عنى بذلك: ليشهدوا منافع لهم مِن العمل الذي يرضي الله والتجارة؛ وذلك أن الله عمَّ <span class="qpc-hafs">﴿مَنافِعَ لَهُمْ﴾</span> جميع ما يشهد له الموسم، ويأتي له مكة أيام الموسم؛ من منافع الدنيا والآخرة، ولم يَخْصُصْ من ذلك شيئًا من منافعهم بخبرٍ ولا عقل، فذلك على العموم في المنافع التي وصَفْتُ».</div></p><p><h3><span class="qpc-hafs">﴿وَیَذۡكُرُوا۟ ٱسۡمَ ٱللَّهِ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٠٤٦٩<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span>، في قوله: <span class="qpc-hafs">﴿ويذكروا اسم الله﴾</span>، قال: كان يقال: إذا ذبحتَ نسيكتك فقل: بسم الله، والله أكبر، اللهم هذا منك ولك عن فلان، ثم كل وأطعم -كما أمرك الله- الجارَ والأقرب فالأقرب{11}. (١٠/٤٧٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٤٧٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿و﴾</span> لكي <span class="qpc-hafs">﴿يذكروا اسم الله﴾</span>{10}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٤٧١<span class="dash">-</span></span> عن <span class="name-3">مقاتل [بن حيان]</span>، في قوله: <span class="qpc-hafs">﴿ويذكروا اسم الله﴾</span>، قال: فيما ينحرون مِن البُدن{2}<span class=comment-ref>٤٤٥٩</span>. (١٠/٤٧٤)</p></p><p></div></p><p><div><span class=comment-ref>٤٤٥٩</span> <span class="comment-type-4">ذكر</span> <u>ابنُ عطية</u> (٦/٢٣٩-٢٤٠) أنه قد يأتي «ذكر اسم الله» في الآية «بمعنى: حمده وتقديسه شكرًا على نعمته في الرزق، ويؤيده قوله -عليه الصلاة والسلام-: «<b>إنها أيام أكل، وشُرب، وذِكر الله</b>»»، وعليه فـ«يصح أن يريد بالاسم هاهنا: المسمى، بمعنى: ويذكروا الله، على تجوُّزٍ في هذه العبارة، إلا أن يقصد ذكر القلوب، ويحتمل أن يريد بالاسم التسميات، وذكر الله تعالى إنما هو بذكر أسمائه، ثم يذكر القلب السلطان والصفات».</div></p><p><h3><span class="qpc-hafs">﴿فِیۤ أَیَّامࣲ مَّعۡلُومَـٰتٍ عَلَىٰ مَا رَزَقَهُم مِّنۢ بَهِیمَةِ ٱلۡأَنۡعَـٰمِۖ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٠٤٧٢<span class="dash">-</span></span> عن <span class="name-1">علي [بن أبي طالب]</span>، قال: الأيام المعلومات: يوم النحر، وثلاثة أيام بعده{14}. (١٠/٤٧٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٤٧٣<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، قال: عشر ذي الحجة، آخرها يوم النحر{15}. (١٠/٤٧٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٤٧٤<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عمرو بن دينار- قال: الأيام المعدودات: أيام التشريق. والأيام المعلومات: أيام العشر{16}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٤٧٥<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، في قوله: <span class="qpc-hafs">﴿في أيام معلومات﴾</span>، قال: قبل يوم التروية بيوم، ويوم التروية، ويوم عرفة{17}. (١٠/٤٧٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٤٧٦<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق سعيد بن جبير- قال: الأيام المعلومات: التي قبل يوم التروية، ويوم التروية، ويوم عرفة. والمعدودات: أيام التشريق{18}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٤٧٧<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق مِقْسَم- قال: الأيام المعلومات: يوم النحر، وثلاثة أيام بعده{19}. (١٠/٤٧٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٤٧٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطية العوفي- <span class="qpc-hafs">﴿في أيام معلومات﴾</span>: يعني: أيام التشريق{20}. (١٠/٤٧٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٤٧٩<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عمر</span> -من طريق نافع- قال: الأيام المعلومات والمعدودات هن جميعهن أربعة أيام، فالمعلومات يوم النحر ويومان بعده، والمعدودات ثلاثة أيام بعد يوم النحر{21}<span class=comment-ref>٤٤٦٠</span>. (١٠/٤٧٥)</p></p><p></div></p><p><div><span class=comment-ref>٤٤٦٠</span> ذكر <u>ابنُ كثير</u> (١٠/٤٦) هذا الأثر من رواية ابن أبي حاتم بسنده عن أبيه، عن علي بن المديني، عن يحيى بن سعيد، عن ابن عجلان، عن نافع، عن ابن عمر موقوفًا، ثم <span class="comment-type-4">علَّق</span> عليه بقوله: «هذا إسناد صحيح إليه ... ويعضد هذا القول والذي قبله -وهو أن الأيام المعلومات: يوم النحر، وثلاثة أيام بعده- قوله تعالى: <span class="qpc-hafs">﴿عَلى ما رَزَقَهُمْ مِن بَهِيمَةِ الأَنْعامِ﴾</span>، يعني به: ذكر الله عند ذبحها».</p><p>وذكر <u>ابنُ عطية</u> (٦/٢٤٠) بأنّ مِمَّن قال بهذا القول مالك وأصحابه، ثم <span class="comment-type-1">وجَّهه</span> بقوله: «وحمل هؤلاء على هذا التفصيل أنهم أخذوا»ذكر اسم الله«هنا على الذبح للأضاحي والهدي وغيره، فاليوم الرابع لا يُضَحّى فيه عند مالك وجماعة، وأخذوا التَّعجُّل والتأخر بالنَّفْر في الأيام المعدودات، فتأمل هذا يَبِنْ لك قصدهم». ثم <span class="comment-type-4">ذهب</span> <span class="mustanad">مستندًا إلى الظاهر من الآية</span> إلى «أن تكون المعلومات والمعدودات بمعنًى، أي: تلك الأيام الفاضلة كلها، ويبقى أمر الذبح وأمر الاستعجال لا يتعلق بمعدود ولا بمعلوم، وتكون فائدة قوله: <span class="qpc-hafs">﴿مَعْلُوماتٍ﴾</span> و<span class="qpc-hafs">﴿مَعْدُوداتٍ﴾</span> [البقرة:٢٠٣] التحريض على هذه الأيام، وعلى اغتنام فضلها؛ إذ ليست كغيرها، فكأنه قال: هي مخصوصات فَلْتُغْتَنَم».</div></p><p><div></p><p><p><span class="item-no">٥٠٤٨٠<span class="dash">-</span></span> عن <span class="name-2">عطاء</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٤٨١<span class="dash">-</span></span> و<span class="name-2">مجاهد بن جبر</span>، قال: الأيام المعلومات: أيام العشر{22}. (١٠/٤٧٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٤٨٢<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٤٨٣<span class="dash">-</span></span> و<span class="name-2">الحسن البصري</span>، مثله{22}. (١٠/٤٧٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٤٨٤<span class="dash">-</span></span> عن <span class="name-2">الضَّحّاك بن مُزاحِم</span> -من طريق عبيد بن سليمان-: <span class="qpc-hafs">﴿في أيام معلومات﴾</span> يعني: أيام التشريق، <span class="qpc-hafs">﴿على ما رزقهم من بهيمة الأنعام﴾</span> يعني: البدن{24}. (١٠/٤٧٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٤٨٥<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق مَعْمَر- <span class="qpc-hafs">﴿في أيام معلومات﴾</span>، قال: أيام العشر. والمعدودات: أيام التشريق{24}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٤٨٦<span class="dash">-</span></span> قال <span class="name-2">محمد بن كعب القرظي</span>: المعدودات والمعلومات واحدة{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٤٨٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل</span>: المعلومات: أيام التشريق{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٤٨٨<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿في أيام معلومات﴾</span> يعني: ثلاثة أيام؛ يوم النحر ويومين بعده إلى غروب الشمس، <span class="qpc-hafs">﴿على ما رزقهم من بهيمة الأنعام﴾</span>{28}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٤٨٩<span class="dash">-</span></span> قال <span class="name-3">يحيى بن</span> <span class="name-3">سلّام</span>: قوله: <span class="qpc-hafs">﴿على ما رزقهم من بهيمة الأنعام﴾</span> يسمِّي إذا نحر أو ذبح، والأضحى ثلاثة أيام: يوم النحر ويومان بعده، ويوم النحر أفضلها{29}<span class=comment-ref>٤٤٦١</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٤٤٦١</span> <span class="comment-type-4">ذكر</span> <u>ابنُ تيمية</u> (٤/٤٢٣- ٤٢٤) قولين في: «ذكر اسم الله» بناءً على الخلاف الوارد في «الأيام المعلومات»، <b>فمَن قال بأن «الأيام المعلومات»: أيام الذبح</b>؛ قال بأن «ذكر اسم الله»: التسمية على الأضحية والهدي. <b>ومَن قال بأن «الأيام المعلومات»: أيام العشر</b>؛ قال بأن «ذكر اسم الله»: التكبير فيها. ثم ذكر استدلالات ومناقشات لكلا القولين ليس هذا موضع بسطها.</div></p><p><h3><span class="qpc-hafs">﴿فَكُلُوا۟ مِنۡهَا وَأَطۡعِمُوا۟ ٱلۡبَاۤىِٕسَ ٱلۡفَقِیرَ ۝٢٨﴾</span> - نزول الآية</h3></p><p><div></p><p><p><span class="item-no">٥٠٤٩٠<span class="dash">-</span></span> عن إبراهيم [النخعي]، قال: كان المشركون لا يأكلون مِن ذبائح نسائهم، فنزلت: <span class="qpc-hafs">﴿فكلوا منها وأطعموا البائس الفقير﴾</span>، فرخص للمسلمين، فمن شاء أكل؛ ومن شاءلم يأكل{30}. (١٠/٤٧٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٤٩١<span class="dash">-</span></span> عن الحسن البصري -من طريق أبي بكر الهذلي- قال: كان الناسُ في الجاهلية إذا ذبحوا لَطَّخوا بالدماء وجه الكعبة، وشَرَّجُوا{31} اللحوم، فوضعوها على الحجارة، وقالوا: لا يحِلُّ لنا نأكل شيئًا جعلناه لله ﷿ حتى تأكله السباع والطير. فلما جاء الإسلام جاء الناسُ رسولَ الله ﷺ، فقالوا له: شيئًا كُنّا نصنعه في الجاهلية، ألا نصنعه الآن؟ فإنما هو لله ﷿. فأنزل الله ﷿: <span class="qpc-hafs">﴿فكلوا منها وأطعموا﴾</span>. فقال رسول الله ﷺ: «<b>لا تفعلوا؛ فإنّ ذلك ليس لله ﷿</b>». قال الحسن: فلم يعزِم عليهم الأكل، فإن شئت فكُل، وإن شئت فدَع{32}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٤٩٢<span class="dash">-</span></span> قال مقاتل بن سليمان: ... وذلك أنّ أهل الجاهلية كانوا لا يأكلون شيئًا مِن البُدُن، فأنزل الله ﷿: <span class="qpc-hafs">﴿فكلوا منها وأطعموا﴾</span>{33}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿فَكُلُوا۟ مِنۡهَا وَأَطۡعِمُوا۟ ٱلۡبَاۤىِٕسَ ٱلۡفَقِیرَ ۝٢٨﴾</span> - تفسير الآية</h3></p><p><div></p><p><p><span class="item-no">٥٠٤٩٣<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق العوفي- في قوله: <span class="qpc-hafs">﴿وأطعموا البائس﴾</span>، قال: الزَّمِن{34}. (١٠/٤٧٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٤٩٤<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>: أن نافع بن الأزرق قال له: أخبِرني عن قول الله: <span class="qpc-hafs">﴿وأطعموا البائس الفقير﴾</span>. قال: البائِس: الذي لم يجد شيئًا من شِدَّة الحاجة. قال: وهل تعرف العرب ذلك؟ قال: نعم، أما سمعت طرفة وهو يقول:</p><p>يغشاهم البائسُ المُدْقِعُ والضيـ ـفُ وجارٌ مجاورٌ جُنُبُ؟{35}. (١٠/٤٧٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٤٩٥<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span>، في قوله: <span class="qpc-hafs">﴿البائس الفقير﴾</span>، قال: هما سواء{14}. (١٠/٤٧٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٤٩٦<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق أبي يحيى- قوله: <span class="qpc-hafs">﴿فكلوا منها وأطعموا البائس الفقير﴾</span>، قال: الضعيف الفقير{37}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٤٩٧<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٤٩٨<span class="dash">-</span></span> و<span class="name-2">عكرمة مولى ابن عباس</span>، قالا: البائس: الذي يمد كَفَّيه إلى الناس يسأل{22}. (١٠/٤٧٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٤٩٩<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span> -من طريق عمر بن عطاء- قال: البائس: المُضطر الذي عليه البؤس، والفقير المتعفف{39}. (١٠/٤٧٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٥٠٠<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span>، قال: <span class="qpc-hafs">﴿البائس الفقير﴾</span> الذي به زَمانة وهو فقير{40}. (١٠/٤٧٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٥٠١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فكلوا منها وأطعموا البائس﴾</span>، يعني: الضرير الزَّمِن الفقير الذي ليس له شيء{10}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٥٠٢<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿البائس الفقير﴾</span>، قال: هو القانِع{42}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿فَكُلُوا۟ مِنۡهَا وَأَطۡعِمُوا۟ ٱلۡبَاۤىِٕسَ ٱلۡفَقِیرَ ۝٢٨﴾</span> - من أحكام الآية</h3></p><p><div></p><p><p><span class="item-no">٥٠٥٠٣<span class="dash">-</span></span> عن جابر بن عبد الله، قال: نَحَر رسولُ الله ﷺ ستةً وستين بدنة، ونحر عَلِيٌّ أربعة وثلاثين، ثم أمر رسول الله ﷺ مِن كل جزور بضعة، فجُعِلَت في قِدر، فأكل رسولُ الله ﷺ وعَلِيٌّ مِن اللحم، وحَسَوا مِن المَرَق. قال <span class="name-3">سفيان</span>: لأنّ الله يقول: <span class="qpc-hafs">﴿فكلوا منها﴾</span>{43}. (١٠/٤٧٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٥٠٤<span class="dash">-</span></span> عن مجاهد، في قوله: <span class="qpc-hafs">﴿فكلوا منها﴾</span>: أنّ <span class="name-1">ابن مسعود</span> كان يقول للذي يبعث بهديِهِ معه: كُلْ ثُلُثًا، وتَصَدَّق بالثُّلُث، واهدِ لآل عتبة ثلثًا{44}. (١٠/٤٧٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٥٠٥<span class="dash">-</span></span> عن ناعم مولى أم سلمة: أنّه حضر <span class="name-1">عليًّا</span> بالكوفة يوم أضحى، فخطب ثم نزل، فاتبعته، فدعا بتيس، فذبحه، فذكر اسم الله، ثم قال: عن علي وعن آل علي. ثم لم يبرح حتى قسَّم لحمه، ففَضُلَ منه شيء، فبعثه إلى أهله{37}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٥٠٦<span class="dash">-</span></span> عن عائشة ابنة <span class="name-1">سعد بن مالك</span> -من طريق عثمان-: أنّ <span class="name-1">أباها</span> كان يأكل من بدنته قبل أن يُطْعِم{46}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٥٠٧<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عمر</span> -من طريق نافع-: أنّه كان يُطْعم من بُدْنه [قبل أن] يأكل لا يرى بذلك بأسًا، يقول: <span class="qpc-hafs">﴿فكلوا منها وأطعموا﴾</span>، وأطعموا منها وكلوا منها، هما سواء، لا يرى بأسًا أن يطعم منها قبل أن يأكل{37}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٥٠٨<span class="dash">-</span></span> عن <span class="name-2">سعيد بن المسيب</span> -من طريق الزهري- قال: ليس لصاحب البدنة منها إلا ربعُها{37}<span class=comment-ref>٤٤٦٢</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٤٤٦٢</span> <span class="comment-type-4">علَّق</span> <u>ابنُ عطية</u> (٦/٢٥١) على قول ابن مسعود، وابن المسيب قائلًا: «وهذا كله على جهة الاستحسان، لا على الفرض».</div></p><p><div></p><p><p><span class="item-no">٥٠٥٠٩<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق حُصين- في الآية، قال: هي رخصة، إن شاء أكل، وإن شاء لم يأكل؛ بمنزلة قوله: <span class="qpc-hafs">﴿واذ حللتم فاصطادوا﴾</span> [المائدة:٢]، <span class="qpc-hafs">﴿فإذا قضيت الصلاة فانتشروا في الأرض﴾</span> [الجمعة:١٠]. يعني: قوله: <span class="qpc-hafs">﴿فكلوا منها وأطعموا القانع والمعتر﴾</span>{49}. (١٠/٤٧٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٥١٠<span class="dash">-</span></span> عن <span class="name-2">عطاء [بن أبي رباح]</span> -من طريق ابن جريج- في قوله: <span class="qpc-hafs">﴿فكلوا منها وأطعموا البائس الفقير﴾</span>، قال: كان لا يرى الأكل منها واجبًا{50}. (١٠/٤٧٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٥١١<span class="dash">-</span></span> عن <span class="name-2">عطاء</span>، <span class="qpc-hafs">﴿فكلوا منها وأطعموا﴾</span>، قال: إذا ذبحتم فابدءوا فكلوا وأطعِموا، وأقلِّوا لحوم الأضاحي عندكم{22}. (١٠/٤٧٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٥١٢<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق الحسن بن دينار- قال: هي مُقَدَّمة مُؤَخَّرة؛ <span class="qpc-hafs">﴿فكلوا منها وأطعموا﴾</span> وأطعموا منها وكلوا، لا بأس أن يُطعم منها قبل أن يأكل، وإن شاء لم يأكل منها{46}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٥١٣<span class="dash">-</span></span> قال يحيى بن سلّام: وبلغني عن <span class="name-2">الحسن [البصري]</span> قال: لا يطعم من الأضحية أقلّ مِن الربع{53}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٥١٤<span class="dash">-</span></span> عن <span class="name-2">محمد بن علي بن الحسين</span> -من طريق ابنه جعفر- قال: أُطعِمُ البائسَ الفقيرَ ثلثًا، وأُطعِمُ القانعَ والمُعْتَرَّ ثلثًا، وأُطعِم أهلي ثلثًا{37}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٥١٥<span class="dash">-</span></span> عن <span class="name-2">أبي صالح الحنفي</span>، <span class="qpc-hafs">﴿فكلوا منها وأطعموا البائس الفقير﴾</span>، قال: هي في الأضاحي{22}. (١٠/٤٧٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٥١٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فكلوا منها وأطعموا﴾</span>، فليس الأكل بواجب، ولكنه رخصة، كقوله سبحانه: <span class="qpc-hafs">﴿وإذا حللتم فاصطادوا﴾</span> [المائدة:٢]، وليس الصيد بواجب، ولكنه رخصة{33}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ١٦/٥٢٠ مختصرًا. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.عزاه السيوطي إلى ابن أبي حاتم.أخرجه ابن جرير ١٦/٥٢٠.تفسير الثعلبي ٧/١٩، وتفسير البغوي ٥/٣٧٩.أخرجه الثوري في تفسيره ص٢١١، وابن جرير ١٦/٥٢٠.أخرجه يحيى بن سلام ١/٣٦٥ من طريق عاصم بن حكيم، وابن جرير ١٦/٥٢١. وعزاه السيوطي إلى عبد بن حميد. وعقَّب عليه يحيى بن سلام بقوله: وذلك أنهم كانوا يتبايعون في الموسم، وكانت لهم في ذلك منفعة.أخرجه الثوري في تفسيره ص٢١١.تفسير الثعلبي ٧/١٩.أخرجه ابن جرير ١٦/٥٢١-٥٢٢.تفسير مقاتل بن سليمان ٣/١٢٣.عزاه السيوطي إلى عبد بن حميد، وابن أبي حاتم.تفسير مقاتل بن سليمان ٣/١٢٣.عزاه السيوطي إلى ابن أبي حاتم.عزاه السيوطي إلى ابن المنذر.أخرجه يحيى بن سلام ١/٣٦٥، ولم يتبين الراوي في المخطوط كما يفهم من كلام محققته. وعزاه السيوطي إلى أبي بكر المروزي في كتاب العيدين، وابن أبي حاتم بلفظ: الأيام المعلومات أيام العشر.أخرجه عبد بن حميد -كما في فتح الباري ٢/٤٥٨-.عزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه ابن مردويه -كما في فتح الباري ٢/٤٥٨-.أخرجه ابن أبي حاتم ٢/٣٦١. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه ابن جرير ١٦/٥٢٢-٥٢٣.أخرجه ابن أبي حاتم -كما في تفسير ابن كثير ٥/٤١٢. وعزاه السيوطي إلى ابن المنذر.عزاه السيوطي إلى عبد بن حميد.عزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ١٦/٥٢٣.أخرجه ابن جرير ١٦/٥٢٣.تفسير الثعلبي ٧/١٩.تفسير الثعلبي ٧/١٩، وتفسير البغوي ٥/٣٧٩.تفسير مقاتل بن سليمان ٣/١٢٣.</p><p><b>وقد تقدم في تفسير قوله تعالى:</b> <span class="qpc-hafs">﴿واذْكُرُوا اللَّهَ فِي أيّامٍ مَعْدُوداتٍ﴾</span> [البقرة:٢٠٣] <b>آثار أكثر مما ورد هنا</b>.تفسير يحيى بن سلام ١/٣٦٥.عزاه السيوطي إلى عبد الرزاق، وسعيد بن منصور، وعبد بن حميد، وابن المنذر، وابن أبي حاتم، وهو مرسل.شَرَّجوا اللحوم: أي خلطوها بالشحم. اللسان (شرج).سيرة ابن إسحاق ص ٧٨-٧٩، وهو مرسل.تفسير مقاتل بن سليمان ٣/١٢٦.أخرجه ابن جرير ١٦/٥٢٤-٥٢٥.أخرجه الطستي -كما في الإتقان ٢/٧٧-.عزاه السيوطي إلى ابن المنذر.أخرجه يحيى بن سلام ١/٣٦٦.عزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ١٦/٥٢٥. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم بلفظ: الفقير الضعيف.علقه يحيى بن سلام ١/٣٦٦. وعزاه السيوطي إلى عبد بن حميد.تفسير مقاتل بن سليمان ٣/١٢٣.أخرجه ابن جرير ١٦/٥٢٥.أخرجه ابن حبان ٩/٣٢٨، ويحيى بن سلام ١/٣٦٧ كلاهما بنحوه من طرق، عن جعفر بن محمد، عن أبيه، عن جابر. وعزاه السيوطي إلى ابن أبي حاتم.</p><p>إسناده صحيح.عزاه السيوطي إلى ابن أبي حاتم. وأخرجه يحيى بن سلام ١/٣٦٦ من طريق الحجاج بن أرطاة: أنه بعث بهدي مع علقمة، وأمره أن يأكل هو وأصحابه ثلثًا، وأن يبعث إلى أهل عتبة بن مسعود ثلثًا، وأن يطعم المساكين ثلثًا.أخرجه يحيى بن سلام ١/٣٦٦.أخرجه يحيى بن سلام ١/٣٦٧.أخرجه يحيى بن سلام ١/٣٦٦.أخرجه يحيى بن سلام ١/٣٦٦.أخرجه ابن جرير ١٦/٥٢٣-٥٢٤، والبيهقي في سننه ٥/٢٤١. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه ابن جرير ١٦/٥٢٣، وأخرجه عبد بن حميد -كما في فتح الباري ٣/٥٥٨- بلفظ: إن شاء أكل من الهدي والأضحية، وإن شاء لم يأكل.عزاه السيوطي إلى عبد بن حميد.أخرجه يحيى بن سلام ١/٣٦٧.علَّقه يحيى بن سلام ١/٣٦٦.أخرجه يحيى بن سلام ١/٣٦٦.عزاه السيوطي إلى عبد بن حميد.تفسير مقاتل بن سليمان ٣/١٢٦.
  22,29,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿ثُمَّ لۡیَقۡضُوا۟ تَفَثَهُمۡ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٠٥١٧<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطية العوفي- قال: قضاء التَّفَث: قضاء النسك كله{1}. (١٠/٤٧٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٥١٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطاء- أنّه قال في التَّفَث: حلق الرأس، والأخذ من العارِضَين، ونتف الإبط، وحلق العانَة، والوقوف بعرفة، والسعي بين الصفا والمروة، ورمي الجمار، وقصَّ الأظفار، وقص الشارب، والذبح{2}. (١٠/٤٧٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٥١٩<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- في قوله: <span class="qpc-hafs">﴿ثم ليقضوا تفثهم﴾</span>، قال: يعني بالتفث: وضع إحرامهم؛ مِن حلق الرأس، ولبس الثياب، وقص الأظفار، ونحو ذلك{3}. (١٠/٤٧٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٥٢٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عمر</span> -من طريق نافع- قال: التفث: المناسك كلها{4}. (١٠/٤٧٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٥٢١<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- <span class="qpc-hafs">﴿ثم ليقضوا تفثهم﴾</span>، قال: حلق الرأس، والعانة، ونتف الإبط، وقص الشارب، والأظفار، ورمي الجمار، وقص اللحية{5}. (١٠/٤٧٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٥٢٢<span class="dash">-</span></span> عن <span class="name-2">الضَّحّاك بن مُزاحِم</span> -من طريق عبيد- في قوله: <span class="qpc-hafs">﴿ثم ليقضوا تفثهم﴾</span>، قال: حلق الرأس{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٥٢٣<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span>، <span class="qpc-hafs">﴿ثم ليقضوا تفثهم﴾</span>، قال: التَّفَث: كل شيء أحرموا منه{7}. (١٠/٤٧٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٥٢٤<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span> -من طريق خالد- قال: التفث: الشعر والظفر{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٥٢٥<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق منصور- أنه قال: حلق الرأس{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٥٢٦<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق المبارك بن فضالة- قال: التفث: ذا الشعث، وذا التقشف{10}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٥٢٧<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -في تفسير عمرو [بن عبيد]- <span class="qpc-hafs">﴿تفثهم﴾</span>: تقشف الإحرام برميهم الجمار يوم النحر؛ فقد حَلَّ لهم كل شيء غير النساء{11}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٥٢٨<span class="dash">-</span></span> عن <span class="name-2">عطاء [بن أبي رباح]</span> -من طريق قيس بن سعد- قال: التفث: حلق الشعر، وقطع الأظفار{10}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٥٢٩<span class="dash">-</span></span> عن <span class="name-2">محمد بن كعب القرظي</span> -من طريق موسى بن عقبة- قال: التفث: حلق العانة، ونتف الإبط، وأخذ من الشارب، وتقليم الأظافر{13}. (١٠/٤٧٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٥٣٠<span class="dash">-</span></span> عن <span class="name-2">محمد بن كعب القرظي</span> -من طريق أبي صخر- أنّه كان يقول في هذه الآية: <span class="qpc-hafs">﴿ثم ليقضوا تفثهم﴾</span>: رمي الجمار، وذبح الذبيحة، وأخذ مِن الشاربين، واللحية، والأظفار، والطواف بالبيت، وبالصفا والمروة{14}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٥٣١<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- قال: التفث: حلق الرأس{15}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٥٣٢<span class="dash">-</span></span> عن <span class="name-2">عطاء بن السائب</span> -من طريق جرير- قال: التفث: حلق الشعر، وقص الأظفار، والأخذ من الشارب، وحلق العانة، وأمر الحج كله{16}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٥٣٣<span class="dash">-</span></span> عن <span class="name-2">عطاء الخراساني</span> -من طريق يونس- في قول الله ﷿: <span class="qpc-hafs">﴿ليقضوا تفثهم﴾</span>، قال: التفث: تفث الحج، حلق الرأس، ورمي الجمار، ونحو ذلك{17}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٥٣٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ثم ليقضوا تفثهم﴾</span>، يعني: حلق الرأس، والذَّبح، والجِمار{18}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٥٣٥<span class="dash">-</span></span> عن <span class="name-3">عبد الملك ابن جُرَيْج</span> -من طريق المحاربي، عن رجل- أنّه سُئِل عن قوله: <span class="qpc-hafs">﴿ثم ليقضوا تفثهم﴾</span>. فقال: الأخذ من اللحية، ومِن الشارب، وتقليم الأظفار، ونتف الإبط، وحلق العانة، ورمي الجمار{19}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَلۡیُوفُوا۟ نُذُورَهُمۡ﴾</span> - قراءات</h3></p><p><div></p><p><p><span class="item-no">٥٠٥٣٦<span class="dash">-</span></span> عن <span class="name-2">عاصم</span> أنه قرأ: ‹ولْيُوَفُّواْ نُذُورَهُمْ› مثقله بجزم اللام، <span class="qpc-hafs">﴿ولْيَطَّوَّفُواْ﴾</span> بجزم اللام مثقلة{20}. (١٠/٤٧٩)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَلۡیُوفُوا۟ نُذُورَهُمۡ﴾</span> - تفسير الآية</h3></p><p><div></p><p><p><span class="item-no">٥٠٥٣٧<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- في قوله: <span class="qpc-hafs">﴿وليوفوا نذورهم﴾</span>، قال: يعني: نحر ما نذروا من البُدن{3}. (١٠/٤٧٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٥٣٨<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span>، <span class="qpc-hafs">﴿وليوفوا نذورهم﴾</span>، قال: هو الحجُّ{7}. (١٠/٤٧٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٥٣٩<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح، وابن جُرَيْج- <span class="qpc-hafs">﴿وليوفوا نذورهم﴾</span>، قال: نذر الحج، والهدي، وما نذره الإنسان مِن شيء يكون في الحج{23}. (١٠/٤٧٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٥٤٠<span class="dash">-</span></span> عن <span class="name-2">عطاء</span>، أو <span class="name-2">مجاهد بن جبر</span> -من طريق إبراهيم الخوزي- قال: نذور كانت عليهم؛ فأُمِروا بالذبح{24}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٥٤١<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- قوله: <span class="qpc-hafs">﴿وليوفوا نذورهم﴾</span>، قال: أيامٌ عَظَّمها الله؛ تُحْلَق فيها الأشعار، ويُوفى فيها بالنذر، وتُذبَح فيها الذبائح{11}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٥٤٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وليوفوا﴾</span> يعني: لكي يوفوا <span class="qpc-hafs">﴿نذورهم﴾</span> في حجٍّ أو عمرة بما أوجبوا على أنفسهم مِن هديٍ أو غيره{18}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَلۡیَطَّوَّفُوا۟﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٠٥٤٣<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- <span class="qpc-hafs">﴿وليطوفوا﴾</span>، قال: يعني: زيارة البيت. وفي لفظ: هو طواف الزيارة يوم النحر{27}. (١٠/٤٧٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٥٤٤<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، قال: طواف الوداع واجب، وهو قول الله: <span class="qpc-hafs">﴿وليطوفوا بالبيت العتيق﴾</span>{28}. (١٠/٤٨١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٥٤٥<span class="dash">-</span></span> عن أبي جمرة، قال: قال لي <span class="name-1">ابن عباس</span>: أتقرأُ سورةَ الحج؟ يقول الله: <span class="qpc-hafs">﴿ثم ليقضوا تفثهم وليوفوا نذورهم وليطوفوا بالبيت العتيق﴾</span>، قال: فإن آخر المناسك الطواف بالبيت{29}. (١٠/٤٨١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٥٤٦<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span> -من طريق عبد الكريم- قال: هو طواف يوم النحر{30}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٥٤٧<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span>، في قوله: <span class="qpc-hafs">﴿وليطوفوا﴾</span>، قال: هو الطواف الواجب يوم النحر{31}. (١٠/٤٧٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٥٤٨<span class="dash">-</span></span> عن <span class="name-2">الضحاك بن مزاحم</span>، <span class="qpc-hafs">﴿وليطوفوا﴾</span>، قال: طواف الزيارة{32}. (١٠/٤٧٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٥٤٩<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق أشعث- <span class="qpc-hafs">﴿وليطوفوا بالبيت العتيق﴾</span>، قال: طواف الزيارة{33}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٥٥٠<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله في هذه الآية: <span class="qpc-hafs">﴿وليطوفوا بالبيت العتيق﴾</span>، قال: هو الطواف الواجب{11}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٥٥١<span class="dash">-</span></span> عن <span class="name-2">عطاء [بن أبي رباح]</span> -من طريق حجاج، وعبد الملك- في قوله: <span class="qpc-hafs">﴿وليطوفوا بالبيت العتيق﴾</span>، قال: طواف يوم النحر{33}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٥٥٢<span class="dash">-</span></span> عن عمرو بن أبي سلمة، قال: سألت <span class="name-3">زهير [بن محمد العنبري]</span> عن قول الله: <span class="qpc-hafs">﴿وليطوفوا بالبيت العتيق﴾</span>. قال: طواف الوداع{33}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿بِٱلۡبَیۡتِ ٱلۡعَتِیقِ ۝٢٩﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٠٥٥٣<span class="dash">-</span></span> عن عبد الله بن الزبير، قال: قال رسول الله ﷺ: «<b>إنما سمى الله البيت العتيق؛ لأن الله أعتقه مِن الجبابرة، فلم يظهر عليه جبّارٌ قطُّ</b>»{37}. (١٠/٤٨٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٥٥٤<span class="dash">-</span></span> قال <span class="name-1">عبد الله بن الزبير</span> -من طريق معمر، عن الزهري-: إنما سُمِّي: البيت العتيق؛ لأنّ الله أعتقه مِن الجبابرة{38}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٥٥٥<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، قال: البيت العتيق أُعْتِق مِن الجبابرة{39}. (١٠/٤٨٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٥٥٦<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span>، قال: إنما سُمِّي: البيت العتيق؛ لأنه أُعْتِق مِن الغرق في زمان نوح{40}. (١٠/٤٨٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٥٥٧<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- قال: إنما سُمِّي: البيت العتيق؛ لأنه أُعْتِق من الجبابرة، لم يَدَّعِهِ جبارٌ قط. وفي لفظ: فليس في الأرض جبّار يدَّعي أنه له{41}. (١٠/٤٨٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٥٥٨<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق الحسن بن مسلم- قال: إنما سُمِّي: البيت العتيق؛ لأنه لم يُرِدْه أحدٌ بسوء إلا هلك{42}. (١٠/٤٨٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٥٥٩<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق عبيد- قال: إنما سُمِّي: البيت العتيق؛ لأنه ليس لأحد فيه شيء{43}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٥٦٠<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق قتادة- قال: إنما سُمِّي: العتيق؛ لأنه أول بيت وضع{44}. (١٠/٤٨١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٥٦١<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- قوله: <span class="qpc-hafs">﴿وليطوفوا بالبيت العتيق﴾</span>، قال: أعتقه الله من الجبابرة، كم من جبّار مُتْرَفٍ قد صار إليه يريد أن يهدمه، فحال الله بينه وبينه{45}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٥٦٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وليطوفوا بالبيت العتيق﴾</span>، أُعْتِق في الجاهلية مِن القتل، والسبي، والخراب{18}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٥٦٣<span class="dash">-</span></span> قال <span class="name-3">سفيان الثوري</span>: <span class="qpc-hafs">﴿بالبيت العتيق﴾</span> عتق مِن الجبارة{47}، ليس لأحد فيه شيء{48}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٥٦٤<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿البيت العتيق﴾</span>، قال: العتيق: القديم؛ لأنه قديم، كما يقال: السيف العتيق؛ لأنه أول بيت وضع للناس، بناه آدم، وهو أول مَن بناه، ثم بوَّأ الله موضعه لإبراهيم بعد الغرق، فبناه إبراهيم وإسماعيل{43}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٥٦٥<span class="dash">-</span></span> قال <span class="name-3">سفيان بن عيينة</span>: سُمِّي بذلك: عتيقًا؛ لأنه لم يُملَك قط{50}<span class=comment-ref>٤٤٦٣</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٤٤٦٣</span> أفادت الآثار اختلاف المفسرين في وجْه وصْف البيت بـ«العتيق» على أقوال: <b>الأول:</b> لأنّ الله أعتقه من الجبابرة. <b>الثاني:</b> لأنه لم يَمْلِكه أحدٌ من الناس. <b>الثالث:</b> سمي بذلك لقدمه.</p><p><span class="comment-type-4">وبيَّن</span> <u>ابنُ جرير</u> (١٦/٥٣١) أن لكل قول من هذه الأقوال وجْهٌ صحيح، و<span class="comment-type-3">رجَّح</span> أن <span class="mustanad">أغلب معانيه في الظاهر</span> هو القول الثالث، ثم بيَّن أنه إن صح <span class="mustanad">الحديث</span> الذي قال به أصحاب القول الأول لكان هذا القول أوْلى بالصحة، فقال: «ولكلِّ هذه الأقوال التي ذكرناها عمَّن ذكرناها عنه في قوله: <span class="qpc-hafs">﴿البيت العتيق﴾</span> وجْه صحيح، غير أن الذي قاله ابن زيد أغلب معانيه عليه في الظاهر، غير أن الذي رُوِيَ عن ابن الزبير أوْلى بالصحة إن كان ما حدثني به محمد بن سهل البخاري قال: ثنا عبد الله بن صالح، قال: أخبرني الليث، عن عبد الرحمن بن خالد بن مسافر، عن الزهري، عن محمد بن عروة، عن عبد الله بن الزبير، قال: قال رسول الله ﷺ: «<b>إنما سُمِّيَ: البيت العتيق؛ لأن الله أعتقه من الجبابرة، فلم يُظهَر عليه قطُّ</b>» صحيحًا».</p><p>و<span class="comment-type-4">علَّق</span> <u>ابنُ عطية</u> (٦/٢٤٢) على القول الثالث قائلًا: «وهذا قول يعضده النظر؛ إذ هو أول بيت وضع للناس». غير أنه <span class="comment-type-2">انتقده</span>، و<span class="comment-type-3">رجَّح</span> القول الأول <span class="mustanad">مستندًا إلى السنة،</span> فذكر حديث ابن الزبير، ثم قال: «ولا نظر مع الحديث». وذَكَر ابن عطية <b>قولًا آخر</b> غير ما تقدم، وهو أن البيت سُمِّي: عتيقًا؛ لأنّ الله تعالى يُعتِق فيه رقاب المذنبين من العذاب، و<span class="comment-type-2">انتقده</span> <span class="mustanad">مستندًا إلى لغة العرب</span> بقوله: «وهذا يَرُدُّه التصريف».</div></p><p><h3><span class="qpc-hafs">﴿بِٱلۡبَیۡتِ ٱلۡعَتِیقِ ۝٢٩﴾</span> - من أحكام الآية</h3></p><p><div></p><p><p><span class="item-no">٥٠٥٦٦<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، قال: لَمّا نزلت هذه الآية: <span class="qpc-hafs">﴿وليطوفوا بالبيت العتيق﴾</span> طاف رسولُ الله ﷺ مِن ورائه{51}. (١٠/٤٨١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٥٦٧<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق طاووس أو غيره- قال: الحِجر مِن البيت؛ لأنّ رسول الله ﷺ طاف بالبيت مِن ورائه، وقال الله تعالى: <span class="qpc-hafs">﴿وليطوفوا بالبيت العتيق﴾</span>{52}. (١٠/٤٨١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٥٦٨<span class="dash">-</span></span> عن صُرَدِ بن أبي المُنازِل، قال: سمعتُ حبيب بن أبي فَضالة المكي قال: لَمّا بني هذا المسجدُ -مسجد الجامع- قال: وعمران بن حصين جالِسٌ، فذكروا عنده الشفاعة، فقال رجلٌ من القوم: يا أبا نُجَيْد، لَتُحَدِّثونا بأحاديث ما نجد لها أصلًا في القرآن؟ فغضِب عمران بن حصين، وقال لرجل: قرأت القرآن؟ قال: نعم. قال: وجدت فيه صلاة المغرب ثلاثًا، وصلاة العشاء أربعًا، وصلاة الغداة ركعتين، والأولى أربعًا، والعصر أربعًا؟ قال: لا، قال: فعَمَّن أخذتم هذا الشأن؟ ألستم أخذتموه عنّا، وأخذناه عن رسول الله ﷺ؟ أوَجدتم في كل أربعين درهمًا درهم؟ وفي كل كذا وكذا شاة؟ وفي كل كذا وكذا بعير كذا؟ أوجدتم في القرآن؟ قال: لا. قال: فعمَّن أخذتم هذا؟ أخذناه عن رسول الله ﷺ، وأخذتُموه عَنّا، قال: فهل وجدتم في القرآن <span class="qpc-hafs">﴿وليطوفوا بالبيت العتيق﴾</span> [الحج:٢٩] وجدتم هذا: طوفوا سبعًا؟ واركعوا ركعتين خلف المقام؟ أوجدتم هذا في القرآن؟ عمَّن أخذتموه؟ ألستم أخذتموه عنا، وأخذناه عن نبي الله ﷺ؟ أوجدتم في القرآن: لا جَلَبَ ولا جَنَبَ ولا شِغار في الإسلام؟ قال: لا. قال: إنِّي سمعتُ رسول الله ﷺ يقول: «<b>لا جَلَب، ولا جَنَب، ولا شِغار في الإسلام</b>». أسمعتم الله يقول لأقوام في كتابه: <span class="qpc-hafs">﴿ما سلككم في سقر، قالوا: لم نك من المصلين، ولم نك نطعم المسكين﴾</span> حتى بلغ <span class="qpc-hafs">﴿فما تنفعهم شفاعة الشافعين﴾</span> [المدثر: ٤٢-٤٨]؟ قال: حبيب: أنا سمعت يقول: الشفاعة{53}{54}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن أبي شيبة ٤/٨٥، وابن جرير ١٦/٥٢٨، وابن أبي حاتم -كما في الإتقان ٢/٣٠-. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه ابن جرير ١٦/٥٢٦. وعزاه السيوطي إلى سعيد بن منصور، وعبد بن حميد، وابن المنذر، وابن أبي حاتم.أخرجه ابن جرير ١٦/٥٢٨، وابن أبي حاتم -كما في الإتقان ٢/٣٠-. وعزاه السيوطي إلى ابن المنذر.أخرجه ابن أبي شيبة ٤/٨٤، وابن جرير ١٦/٥٢٦. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه الثوري في تفسيره ص٢١١ من طريق ليث، ويحيى بن سلام ١/٣٦٧ بنحوه، وابن أبي شيبة٤/٨٤، وابن جرير ١٦/٥٢٧، وأبو جعفر الرملي في جزئه ص٥٦ (تفسير مسلم الزنجي). وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم. وفي تفسير الثعلبي ٧/٢٠ نحوه، وزاد في أوله: هو مناسك الحج.أخرجه إسحاق البستي في تفسيره ص٣٥٨، وابن جرير ١٦/٥٢٦.عزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ١٦/٥٢٦.أخرجه ابن جرير ١٦/٥٢٦.أخرجه يحيى بن سلام ١/٣٦٧.أخرجه يحيى بن سلام ١/٣٦٨.أخرجه يحيى بن سلام ١/٣٦٧.أخرجه ابن أبي شيبة ٤/٨٤.أخرجه ابن جرير ١٦/٥٢٦. وفي تفسير الثعلبي ٧/٢٠ نحوه، وزاد في أوله: هو مناسك الحج.أخرجه عبد الرزاق ٢/٣٧، ويحيى بن سلام ١/٣٦٧ من طريق سعيد.أخرجه ابن جرير ١٦/٥٢٨.أخرجه أبو جعفر الرملي في جزئه ص١١٧ (تفسير عطاء الخراساني).تفسير مقاتل بن سليمان ٣/١٢٣.أخرجه ابن جرير ١٦/٥٢٧.عزاه السيوطي إلى عبد بن حميد.</p><p>وهي قراءة متواترة، قرأ بها أبو بكر عن عاصم، وقرأ ابن ذكوان: ‹ولِيُوفُواْ نُذُورَهُمْ› ‹ولِيَطَّوَّفُواْ› بكسر اللام فيهما، وقرأ بقية العشرة <span class="qpc-hafs">﴿ولْيُوفُواْ نُذُورَهُمْ﴾</span> <span class="qpc-hafs">﴿ولْيَطَّوَّفُواْ﴾</span> بإسكان اللام فيهما، مع إسكان الواو في الأول. انظر: النشر ٣٢٦، والإتحاف ص٣٩٨.أخرجه ابن جرير ١٦/٥٢٨، وابن أبي حاتم -كما في الإتقان ٢/٣٠-. وعزاه السيوطي إلى ابن المنذر.عزاه السيوطي إلى عبد بن حميد.أخرجه يحيى بن سلام ١/٣٦٨ من طريق عاصم بن حكيم، وابن أبي شيبة ٤/٨٤، وابن جرير ١٦/٥٢٩. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.أخرجه الثوري في تفسيره ص٢١٢.أخرجه يحيى بن سلام ١/٣٦٨.تفسير مقاتل بن سليمان ٣/١٢٣.أخرجه ابن جرير ١٦/٥٣٢ بلفظ: «زيارة البيت». وعزاه السيوطي إلى ابن جرير، وابن المنذر، ناسبًا اللفظ الثاني إلى ابن جرير، ولعل مراده لفظ ابن المنذر.عزاه السيوطي إلى ابن مردويه.أخرجه يحيى بن سلام ١/٣٦٩، وابن أبي حاتم -كما في تفسير ابن كثير ٥/٤١٣-، كما أخرج نحوه يحيى بن سلام ١/٣٦٩ من طريق سعيد بن جبير.أخرجه يحيى بن سلام ١/٣٦٩.علقه يحيى بن سلام ١/٣٦٩. وعزاه السيوطي إلى عبد بن حميد، وابن أبي حاتم.عزاه السيوطي إلى سعيد بن منصور، وعبد بن حميد.أخرجه ابن جرير ١٦/٥٣٢.أخرجه يحيى بن سلام ١/٣٦٨.أخرجه ابن جرير ١٦/٥٣٢.أخرجه ابن جرير ١٦/٥٣٢.أخرجه الترمذي ٥/٣٨٩-٣٩٠ (٣٤٤٢)، والحاكم ٢/٤٢١ (٣٤٦٥)، وابن جرير ١٦/٥٣١.</p><p>قال الترمذي: «هذا حديث حسن غريب، وقد روي هذا الحديث عن الزهري، عن النبي ﷺ مرسلًا». وقال الحاكم: «هذا حديث صحيح، على شرط البخاري، ولم يخرجاه». وقال الذهبي في التلخيص: «على شرط مسلم». وقال الهيثمي في المجمع ٣/٢٩٦ (٥٧٦٦): «رواه البزار، وفيه عبد الله بن صالح كاتب الليث، قيل: ثقة مأمون، وقد ضعّفه الأئمة أحمد وغيره، وبقية رجاله ثقات». وقال الألباني في الضعيفة ٧/٢٠٧ (٣٢٢٢): «ضعيف».أخرجه عبد الرزاق ٢/٣٧، وابن جرير ١٦/٥٢٩.عزاه السيوطي إلى عبد بن حميد، وابن أبي حاتم.عزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.أخرجه ابن أبي شيبة ٤/١١١، وإسحاق البستي في تفسيره ص٣٦٢ مختصرًا، وابن جرير ١٦/٥٣٠. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.أخرجه يحيى بن سلام ١/٣٦٨. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.أخرجه ابن جرير ١٦/٥٣٠.أخرجه يحيى بن سلام ١/٣٦٨. وعزاه السيوطي إلى ابن أبي حاتم.أخرجه يحيى بن سلام ١/٣٦٨، وابن جرير ١٦/٥٣٠ مختصرًا من طريق أبي هلال.تفسير مقاتل بن سليمان ٣/١٢٣.كذا في المصدر.تفسير سفيان الثوري ص٢١٢.أخرجه ابن جرير ١٦/٥٣٠.تفسير الثعلبي ٧/٢٠، وتفسير البغوي ٥/٣٨٢.أخرجه ابن أبي حاتم -كما في تفسير ابن كثير ٥/٤١٨-، من طريق هشام بن حجر، عن رجل، عن ابن عباس به. وعزاه السيوطي إلى ابن مردويه.</p><p>وسنده ضعيف؛ لجهالة شيخ هشام بن حجر.أخرجه الطبراني (١٠٩٨٨)، والحاكم ١/٤٦٠، والبيهقي في سننه ٥/٩٠. وعزاه السيوطي إلى سفيان بن عيينة.الجملة الأخيرة من هذا الأثر توضحها رواية ابن نصر والروياني؛ فهي عندهما بلفظ: قال حبيب: فأنا سمعت عمران بن حصين يقول: الشفاعة نافعة دون ما تسمعون.أخرجه الطبراني في الكبير ١٨/٢١٩ (٥٤٧) واللفظ له، ومحمد بن نصر المروزي في تعظيم قدر الصلاة ٢/١٠٠٧-١٠٠٨ (١٠٨١)، والروياني في المسند ١/١٢٣، وأخرجه أبو داود ٣/٩ (١٥٦١) مختصرًا.</p><p>فيه صرد بن أبي المنازل؛ قال عنه الألباني في ضعيف أبي داود ٢/١٠٥ (٢٧٤): «هذا إسناد ضعيف؛ لجهالة صردٍ هذا، قال الذهبي: لا يعرف. وحبيب ... لم يوثقه غير ابن حبان. والحديث سكت عنه المنذري».</p><p><b>وقد أورد السيوطي ١٠/٤٨٢-٤٨٦ آثارًا عديدة عن فضائل الطواف وآدابه.</b>
  22,30,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿ذَ ٰ⁠لِكَۖ وَمَن یُعَظِّمۡ حُرُمَـٰتِ ٱللَّهِ فَهُوَ خَیۡرࣱ لَّهُۥ عِندَ رَبِّهِۦۗ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٠٥٦٩<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح، وابن جُرَيج- في قوله: <span class="qpc-hafs">﴿ذلك ومن يعظم حرمات الله﴾</span>، قال: الحرمة: مكة، والحج، والعمرة، وما نهى الله عنه مِن معاصيه كلها{1}. (١٠/٤٨٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٥٧٠<span class="dash">-</span></span> عن <span class="name-2">عطاء</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٥٧١<span class="dash">-</span></span> و<span class="name-2">عكرمة مولى ابن عباس</span>، <span class="qpc-hafs">﴿ذلك ومن يعظم حرمات الله﴾</span>، قالا: المعاصي{2}. (١٠/٤٨٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٥٧٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ذلك ومن يعظم حرمات الله﴾</span> يعني: أمر المناسك كلها؛ <span class="qpc-hafs">﴿فهو خير له عند ربه﴾</span> في الآخرة{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٥٧٣<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿ومن يعظم حرمات الله﴾</span>، قال: الحرمات: المشعر الحرام، والبيت الحرام، والمسجد الحرام، والبلد الحرام{4}<span class=comment-ref>٤٤٦٤</span>. (١٠/٤٨٧)</p></p><p></div></p><p><div><span class=comment-ref>٤٤٦٤</span> <span class="comment-type-3">رجَّح</span> <u>ابنُ القيم</u> (٢/٢١٤) <span class="mustanad">مستندًا إلى دلالة العموم</span> بأنّ «الحرمات» تعمُّ هذه المعاني كلها، «وهي جمع حرمة، وهي: ما يجب احترامه وحفظه من الحقوق، والأشخاص، والأزمنة، والأماكن. فتعظيمها: توفيتها حقها، وحفظها من الإضاعة».</div></p><p><h3><span class="qpc-hafs">﴿ذَ ٰ⁠لِكَۖ وَمَن یُعَظِّمۡ حُرُمَـٰتِ ٱللَّهِ فَهُوَ خَیۡرࣱ لَّهُۥ عِندَ رَبِّهِۦۗ﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٥٠٥٧٤<span class="dash">-</span></span> عن عياش بن أبي ربيعة المخزومي، عن النبي ﷺ، قال: «<b>لن تزال هذه الأمةُ بخير ما عَظَّموا هذه الحرمةَ حَقَّ تعظيمها</b> -يعني: مكة-، <b>فإذا ضَيَّعوا ذلك هلكوا</b>»{5}. (١٠/٤٨٧)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَأُحِلَّتۡ لَكُمُ ٱلۡأَنۡعَـٰمُ إِلَّا مَا یُتۡلَىٰ عَلَیۡكُمۡۖ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٠٥٧٥<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- <span class="qpc-hafs">﴿إلا ما يتلى عليكم﴾</span>، قال: إلا الميتة، وما لم يُذكَر اسم الله عليه{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٥٧٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وأحلت لكم﴾</span> بهيمة <span class="qpc-hafs">﴿الأنعام﴾</span> التي حرموا للآلهة في سورة الأنعام، <span class="qpc-hafs">﴿إلا ما يتلى عليكم﴾</span> من التحريم في أول سورة المائدة{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٥٧٧<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: قوله: <span class="qpc-hafs">﴿وأحلت لكم الأنعام إلا ما يتلى عليكم﴾</span> في سورة المائدة [٣] مِن: <span class="qpc-hafs">﴿الميتة والدم ولحم الخنزير وما أهل لغير الله به والمنخنقة والموقوذة والمتردية والنطيحة وما أكل السبع إلا ما ذكيتم وما ذبح على النصب﴾</span>. وقد فسرنا ذلك كله في سورة المائدة{8}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿فَٱجۡتَنِبُوا۟ ٱلرِّجۡسَ مِنَ ٱلۡأَوۡثَـٰنِ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٠٥٧٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق العوفي- في قوله: <span class="qpc-hafs">﴿فاجتنبوا الرجس من الاوثان﴾</span>، يقول: اجتنبوا طاعة الشيطان في عبادة الأوثان{9}. (١٠/٤٨٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٥٧٩<span class="dash">-</span></span> عن <span class="name-3">عبد الملك ابن جُرَيْج</span> -من طريق حَجّاج- في قوله: <span class="qpc-hafs">﴿الرجس من الأوثان﴾</span>، قال: عبادة الأوثان{9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٥٨٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فاجتنبوا الرجس من الأوثان﴾</span>، فيها تقديم؛ يقول: اتقوا عبادة اللات والعزى ومناة، وهي الأوثان{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٥٨١<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: قوله: <span class="qpc-hafs">﴿فاجتنبوا الرجس من الأوثان﴾</span> اجتنبوا الأوثان؛ فإنها رجس{8}<span class=comment-ref>٤٤٦٥</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٤٤٦٥</span> لم يذكر <u>ابنُ جرير</u> (١٦/٥٣٥) في معنى: <span class="qpc-hafs">﴿فاجْتَنِبُوا الرِّجْسَ مِنَ الأَوْثانِ﴾</span> سوى قول ابن عباس، وابن جريج.</p><p>و<span class="comment-type-4">ذكر</span> <u>ابنُ عطية</u> (٦/٢٤٣-٢٤٤) احتمالين في معنى الآية، فقال: «والكلام يحتمل معنيين: <b>أحدهما</b>: أن تكون <span class="qpc-hafs">﴿مِن﴾</span> لبيان الجنس، فيقع نهيه عن رجس الأوثان فقط، وتبقى سائر الأجناس نَهْيُها في غير هذا الموضع. والمعنى <b>الثاني</b>: أن تكون <span class="qpc-hafs">﴿مِن﴾</span> لابتداء الغاية، فكأنه نهاهم عن الرجس عامًّا، ثم عيَّن لهم مبدأه الذي منه يلحقهم؛ إذ عبادة الوثن جامعة لكل فساد ورجس».</div></p><p><h3><span class="qpc-hafs">﴿وَٱجۡتَنِبُوا۟ قَوۡلَ ٱلزُّورِ ۝٣٠﴾</span> - نزول الآية</h3></p><p><div></p><p><p><span class="item-no">٥٠٥٨٢<span class="dash">-</span></span> عن مقاتل، عن <span class="name-2">محمد بن علي</span>، في قوله تعالى: <span class="qpc-hafs">﴿واجتنبوا قول الزور﴾</span>، قال: الكذب، وهو الشِّرْك في التَّلبية، وذلك أن الحُمْس -قريش، وخزاعة، وكنانة، وعامر بن صَعْصَعَة- في الجاهلية كانوا يقولون في التلبية: لبيك اللهم لبيك، لبيك لا شريك لك، إلا شريكًا هو لك، تملكه وما ملك. يعنون: الملائكة التي تُعبد، هذا هو قول الزور لقولهم: إلا شريكًا هو لك. وكان أهل اليمن في الجاهلية يقولون في التلبية: نحن عَرايا عك عك، إليك عانيَة، عبادك اليمانيَة، كيما نحج الثانيَة، على القِلاص{13} الناجيَة{14}. وكانت تميم تقول في إحرامها: لبيك ما نهارنا نجرُه{15}، إدلاجه وبرده وحرُّه، لا يتقي شيئًا ولا يضرُّه، حجًّا لرب مستقيم بِرُّه. وكانت ربيعة تقول: لبيك اللهم حجًّا حقًّا، تَعَبُّدًا ورِقًّا، لم نأتك للمَناحَةِ{16}، ولا حُبًّا للرَباحَة. وكانت قيس عيلان تقول: لبيك لولا أنّ بَكرًا دونكا، بنو أغيار وهم يلونكا، ببرك الناس ويفخرونكا، ما زال منا عجيجًا يأتونكا. وكانت جُرْهم تقول في إحرامها: لبيك إن جرهمًا عبادك، والناس طرف وهم تِلادك، وهم لعمري عَمَرُوا بلادك، لا يطاق ربنا بعادك{17}، وهم الأولون على ميعادك، وهم يُعادون كل مَن يعادك، حتى يقيموا الدين في وادك. وكانت قضاعة تقول: لبيك رب الحل والإحرام، ارحم مقام عبد وآم، أتوك يمشون على الأقدام. وكانت أسد وغطفان تقول في إحرامها بشعر اليمن: لبيك، إليك تعدو قلقًا وضِينُها{18}، معترضًا في بطنها جنينها، مخالفًا دين النصارى دينها. وكانت النساء تَطُفْن بالليل عراة، وقال بعضهم: لا بل نهارًا، تأخذ إحداهن حاشية برد تستر به، وتقول: اليوم يبدو بعضه أو كله، وما بدا منه فلا أُحِلُّه، كم من لبيب عقله يُضِلُّه، وناظر ينظر فما يَمَلُّه، ضخم من الجثم، عظيم ظلُّه. وكانت تلبية آدم ﵇: لبيك الله لبيك، عبد خلقته بيديك، كرمت فأعطيت، قربت فأدنيت، تباركت وتعاليت، أنت رب البيت. فأنزل الله ﷿: <span class="qpc-hafs">﴿واجتنبوا قول الزور﴾</span>{19}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَٱجۡتَنِبُوا۟ قَوۡلَ ٱلزُّورِ ۝٣٠﴾</span> - تفسير الآية</h3></p><p><div></p><p><p><span class="item-no">٥٠٥٨٣<span class="dash">-</span></span> عن أيمن بن خُرَيْم، قال: قام رسول الله ﷺ خطيبًا، فقال: «<b>يا أيها الناس، عدَلَت شهادةُ الزور إشراكًا بالله</b>» ثلاثًا. ثم قرأ: <span class="qpc-hafs">﴿فاجتنبوا الرجس من الأوثان واجتنبوا قول الزور﴾</span>{20}. (١٠/٤٨٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٥٨٤<span class="dash">-</span></span> عن خُرَيْم بن فاتك الأسدي، قال: صلّى رسولُ الله ﷺ صلاة الصبح، فلما انصرف قائمًا قال: «<b>عدَلَت شهادةُ الزور الإشراكَ بالله</b>». ثلاث مرات، ثم تلا هذه الآية: <span class="qpc-hafs">﴿واجتنبوا قول الزور حنفاء لله غير مشركين به﴾</span>{21}. (١٠/٤٨٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٥٨٥<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن مسعود</span> -من طريق وائل بن ربيعة- قال: شهادة الزور تعدل بالشرك بالله. ثم قرأ: <span class="qpc-hafs">﴿فاجتنبوا الرجس من الاوثان واجتنبوا قول الزور﴾</span>{22}. (١٠/٤٨٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٥٨٦<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق العوفي- في قوله: <span class="qpc-hafs">﴿واجتنبوا قول الزور﴾</span>، يعني: الافتراء على الله، والتكذيب به{23}. (١٠/٤٨٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٥٨٧<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- <span class="qpc-hafs">﴿واجتنبوا قول الزور﴾</span>، قال: الكَذِب{24}. (١٠/٤٨٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٥٨٨<span class="dash">-</span></span> عن <span class="name-2">وائل بن ربيعة</span> -من طريق عاصم- قال: عدلت شهادة الزور الشرك. ثم قرأ هذه الآية: <span class="qpc-hafs">﴿فاجتنبوا الرجس من الأوثان واجتنبوا قول الزور﴾</span>{25}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٥٨٩<span class="dash">-</span></span> عن <span class="name-2">محمد بن علي</span> -من طريق مقاتل- في قوله تعالى: <span class="qpc-hafs">﴿واجتنبوا قول الزور﴾</span>، قال: الكذب، وهو الشِّرك في التَّلْبية{26}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٥٩٠<span class="dash">-</span></span> عن <span class="name-3">مقاتل [بن حيان]</span>: <span class="qpc-hafs">﴿واجتنبوا قول الزور﴾</span>، يعني: الشرك بالكلام، وذلك أنهم كانوا يطوفون بالبيت، فيقولون في تلبيتهم: لبيك لا شريك لك، إلا شريكًا هو لك، تملكه وما ملك{27}. (١٠/٤٨٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٥٩١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿واجتنبوا قول الزور﴾</span>، يقول: اتقوا الكذب، وهو الشرك. وفي موضع آخر: وهو الشرك في الإحرام{28}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٠٥٩٢<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: قوله: <span class="qpc-hafs">﴿واجتنبوا قول الزور﴾</span>، وقول الزور: الكذب على الله، يعني: الشرك{8}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَٱجۡتَنِبُوا۟ قَوۡلَ ٱلزُّورِ ۝٣٠﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٥٠٥٩٣<span class="dash">-</span></span> عن أبي بكرة، قال: قال رسول الله ﷺ: «<b>ألا أنبئكم بأكبر الكبائر</b>؟». قلنا: بلى، يا رسول الله. قال: «<b>الإشراك بالله، وعقوق الوالدين</b>». وكان مُتَّكِئًا فجلس، فقال: «<b>ألا وقول الزور، ألا وشهادة الزور</b>». فما زال يُكَرِّرها حتى قلنا: ليته سكت{30}. (١٠/٤٨٨)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ١٦/٥٣٤. وعلَّقه يحيى بن سلام ١/٣٦٩. وعزاه السيوطي إلى ابن أبي شيبة، وعبد بن حميد، وابن المنذر، وابن أبي حاتم.عزاه السيوطي إلى عبد بن حميد.تفسير مقاتل بن سليمان ٣/١٢٣.أخرجه ابن جرير ١٦/٥٣٤ بزيادة: هؤلاء الحرمات.أخرجه أحمد ٣١/٣٩٥ (١٩٠٤٩)، وابن ماجه ٤/٢٩١ (٣١١٠) واللفظ له، من طريق يزيد بن أبي زياد، عن عبد الرحمن بن سابط، عن عياش بن أبي ربيعة المخزومي به.</p><p>قال الحافظ في الفتح ٣/٤٤٩: «سنده حسن».أخرجه عبد الرزاق ٢/٣٧-٣٨، وابن جرير ١٦/٥٣٥.تفسير مقاتل بن سليمان ٣/١٢٣.تفسير يحيى بن سلام ١/٣٧٠.أخرجه ابن جرير ١٦/٥٣٥.أخرجه ابن جرير ١٦/٥٣٥.تفسير مقاتل بن سليمان ٣/١٢٣.تفسير يحيى بن سلام ١/٣٧٠.القِلاص: جمع قَلُوص، وهي الناقة الشابَّة. النهاية (قلص).الناجية: المسرعة. النهاية (نجا).في المصادر التي ضبطت هذه الكلمة: نَجُرُّه، بتشديد الراء، ولم يتبين لنا معناها، ولعلها: نَجْرُه، بتسكين الجيم، وضم الراء دون تشديد؛ يعني: أصله؛ لأن التلبية للشمس، كما في المحبر ص٣١٢ لابن حبيب البغدادي.المَناحة والنَّوح: النِّساء يَجْتَمِعْنَ للحُزن. اللسان (نوح).في المصدر: يعادك، بالياء المثناة التحتانية، ولعله خطأ طباعي، والصواب ما أثبتنا.الوَضِينُ: بِطان منسوج بعضه على بعض يشد به الرحل على البعير، أراد أنها سريعة الحركة، يصفها بالخفة وقلة الثبات كالحزام إذا كان رخوًا. اللسان (وضن).أخرجه مقاتل بن سليمان في تفسيره ٣/١٢٤-١٢٦ مرسلًا.أخرجه أحمد ٢٩/١٤٥ (١٧٦٠٣)، ٢٩/٥٨٠ (١٨٠٤٤)، ٣١/١٩٩ (١٨٩٠٢)، والترمذي ٤/٣٤١-٣٤٢ (٢٤٥٣)، وابن جرير ١٦/٥٣٧.</p><p>قال الترمذي: «هذا حديث غريب، إنما نعرفه من حديث سفيان بن زياد، واختلفوا في رواية هذا الحديث عن سفيان بن زياد، ولا نعرف لأيمن بن خريم سماعًا من النبي ﷺ». وقال السيوطي في الحاوي للفتاوي ١/٤٢٧: «رواه أحمد في مسنده، والترمذي هكذا، وأيمن مختلف في صحبته، فذكره ابن منده وغيره في الصحابة، وقال العجلي: تابع صالح ثقة ... وله شاهد عن ابن مسعود».أخرجه أحمد ٣١/١٩٤ (١٨٨٩٨)، وأبو داود ٥/٤٥١ (٣٥٩٩)، وابن ماجه ٣/٤٥٥-٤٥٦ (٢٣٧٢)، وابن جرير ١٦/٥٣٧.</p><p>قال العقيلي في الضعفاء الكبير ٣/٤٣٣: «هذا يُروى عن خريم بن فاتك بإسناد صالح مِن غير هذا الوجه». وقال ابن القطان في بيان الوهم والإيهام ٤/٥٤٨ (٢١٠١): «لا يصح ... وحبيب لا يعرف بغير هذا، ولا تعرف حاله، وزياد العصفري مجهول، فأما ابنه سفيان فثقة». وقال ابن الملقن في البدر المنير ٩/٥٧٦-٥٧٧ (١٥): «رجال إسناده كلهم محتج بهم في الصحيح، إلا حبيب بن النعمان الأسدي، فلم يرو له إلا (د ق)، ولا أعرف من جرحه ولا مَن عدّله». وقال ابن حجر في التلخيص الحبير ٤/٤٦٠ (٢٠٩٥): «إسناده مجهول». وقال الألباني في الضعيفة ٣/٢٣٥ (١١١٠): «ضعيف».أخرجه عبد الرزاق في مصنفه (١٥٣٩٥)، وابن جرير ١٦/٥٣٦، والطبراني (٨٥٦٩)، والبيهقي في شعب الإيمان، (٤٨٦٢). وعزاه السيوطي إلى الفريابي، وسعيد بن منصور، وعبد بن حميد، وابن المنذر، والخرائطي في مكارم الأخلاق.أخرجه ابن جرير ١٦/٥٣٦.أخرجه يحيى بن سلام ١/٣٧٠ من طريق عاصم بن حكيم، وابن جرير ١٦/٥٣٦. وعزاه السيوطي إلى ابن أبي شيبة، وعبد بن حميد، وابن المنذر، وابن أبي حاتم.أخرجه ابن أبي شيبة (ت: محمد عوامة) ١١/٦٢٥ (٢٣٤٩٨)، وابن جرير ١٦/٥٣٦.تفسير مقاتل بن سليمان ٣/١٢٤-١٢٦.عزاه السيوطي إلى ابن أبي حاتم.تفسير مقاتل بن سليمان ٣/١٢٣، ١٢٦.تفسير يحيى بن سلام ١/٣٧٠.أخرجه البخاري ٣/١٧٢ (٢٦٥٤)، ٨/٤ (٥٩٧٦)، ٨/٦١ (٦٢٧٣)، ٩/١٣-١٤ (٦٩١٩)، ومسلم ١/٩١ (٨٧)، وابن المنذر في تفسيره ٢/٦٦٤ (١٦٥٢).