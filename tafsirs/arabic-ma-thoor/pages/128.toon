quran[8]{c,v,t}:
  6,1,"<div class=ar lang=ar><p><h3>مقدمة السورة</h3></p><p><div></p><p><p><span class="item-no">٢٤٤١٠<span class="dash">-</span></span> عن ابن عمر، قال: قال رسول الله ﷺ: «<b>نزلَت عليَّ سورةُ الأنعام جُملةً واحدةً، يُشَيِّعُها سبعون ألفَ مَلَكٍ، لهم زَجَلٌ</b>{1} <b>بالتسبيحِ والتحميد</b>»{2}. (٦/٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٤٤١١<span class="dash">-</span></span> عن أنس، قال: قال رسول الله ﷺ: «<b>نزَلَت سورة الأنعام ومعها مَوكِبٌ مِن الملائكة يَسُدُّ ما بينَ الخافِقَيْن</b>{3}، <b>لهم زَجَلٌ بالتَّسبيح والتقديس، والأرضُ تَرتَجُّ، ورسول الله ﷺ يقولُ: سبحانَ الله العظيم، سبحانَ الله العظيم</b>»{4}. (٦/٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٤٤١٢<span class="dash">-</span></span> عن أبيِّ بن كعب، قال: قال رسول الله ﷺ: «<b>أُنزِلت عليَّ سورةُ الأنعام جُملةً واحدةً، يُشيِّعُها سبعون ألفَ مَلَكٍ، لهم زَجَلٌ بالتسبيح والتحميد والتكبير والتهليل</b>»{5}. (٦/٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٤٤١٣<span class="dash">-</span></span> عن عبد الله بن مسعود، قال: نزلت سورة الأنعام يُشَيِّعُها سبعون ألفًا مِن الملائكة{6}. (٦/٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٤٤١٤<span class="dash">-</span></span> عن علي بن أبي طالب -من طريق أبي عبد الرحمن السُّلَمي- قال: أُنزِل القرآنُ خمسًا خمسًا، ومَن حفِظ خمسًا خمسًا لم يَنسَه، إلا سورةَ الأنعام، فإنها نزلت جُملةً في ألف، يُشَيِّعُها مِن كلِّ سماءٍ سبعون مَلَكًا، حتى أدَّوها إلى النبي ﷺ، ما قُرِئت على عليلٍ إلا شَفاه الله{7}. (٦/٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٤٤١٥<span class="dash">-</span></span> عن أسماء بنت يزيد، قالت: نزلت سورة الأنعام على النبي ﷺ وهو في مَسِير، في زَجَلٍ من الملائكة، وقد نُظِموا ما بينَ السماء والأرض{6}. (٦/٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٤٤١٦<span class="dash">-</span></span> عن أسماء بنت يزيد -من طريق شهر بن حوشب- قالت: نزلت سورةُ الأنعام على النبي ﷺ جُملةً واحدةً، وأنا آخِذةٌ بزِمامِ ناقةِ النبي ﷺ، إن كادت مِن ثِقَلِها لَتَكسِرُ عظام الناقة{9}. (٦/٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٤٤١٧<span class="dash">-</span></span> عن أسماء بنت يزيد -من طريق شَهْر بن حَوْشَب- قالت: نزلت الأنعام ومعها زجَلٌ من الملائكة، قد ملَئُوا ما بين السماء والأرض، وهي مكية، ومنها آيتان مهاجرتان: <span class="qpc-hafs">﴿قل تعالوا أتل ما حرم ربكم عليكم﴾</span> والتي بعدها [١٥١-١٥٢]{10}. (٦/٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٤٤١٨<span class="dash">-</span></span> عن عبد الله بن عباس -من طريق شهر بن حوشب- قال: أُنزلت سورةُ الأنعام بمكة{11}. (٦/٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٤٤١٩<span class="dash">-</span></span> عن عبد الله بن عباس -من طريق يوسف بن مهران- قال: نزلت سورةُ الأنعام بمكةَ ليلًا جُملةً، وحولَها سبعون ألفَ مَلكٍ يَجأَرُون بالتسبيح{12}. (٦/٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٤٤٢٠<span class="dash">-</span></span> عن عبد الله بن عباس -من طريق شهر بن حوشب- قال: أُنزِلت سورة الأنعام جميعًا بمكة، معها مَوكِبٌ مِن الملائكة يُشَيِّعونها، قد طَبَّقوا ما بينَ السماء والأرض، لهم زَجَلٌ بالتسبيح، حتى كادتِ الأرضُ أن تَرتَجَّ مِن زَجَلِهم بالتسبيح ارتجاجًا، فلمّا سمع النبي ﷺ زَجَلَهم بالتسبيحِ رَهِب من ذاك فخرَّ ساجدًا، حتى أُنزِلت عليه{13}. (٦/٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٤٤٢١<span class="dash">-</span></span> عن عبد الله بن عباس -من طريق أبي عمرو بن العلاء، عن مجاهد- قال: سورة الأنعام نزَلت بمكةَ جُملةً واحدة، فهي مكيةٌ، إلا ثلاثَ آياتٍ منها نزَلت بالمدينة: <span class="qpc-hafs">﴿قل تعالوا أتل﴾</span> إلى تمامِ الآيات الثلاث [١٥١-١٥٣]{14}. (٦/٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٤٤٢٢<span class="dash">-</span></span> عن عبد الله بن عباس -من طريق خصيف، عن مجاهد-: مكية{15}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٤٤٢٣<span class="dash">-</span></span> عن عبد الله بن عباس -من طريق عطاء الخراساني-: مكية، ونزلت بعد الحِجْر{16}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٤٤٢٤<span class="dash">-</span></span> عن أبي جُحَيفةَ وهب بن عبد الله، قال: نزلت الأنعام جميعًا، معها سبعون ألفَ مَلَك، كلُّها مكية، إلا: <span class="qpc-hafs">﴿ولو أننا نزلنا إليهم الملائكة﴾</span> [١١١]، فإنها مدنية{17}. (٦/٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٤٤٢٥<span class="dash">-</span></span> عن مجاهد بن جبر -من طريق فضيل الرقاشي- قال: نزلت سورة الأنعام كلُّها جُملةً، معها خمسمُائةِ مَلَك يَزِفُّونها، ويَحُفُّونها{18}. (٦/٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٤٤٢٦<span class="dash">-</span></span> عن مجاهد بن جبر، قال: نزَل جبريلُ مع سبعين ألفَ مَلَك معهم سورة الأنعام، لهم زَجَلٌ مِن التسبيح والتكبير والتهليل والتحميد{19}. (٦/١٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٤٤٢٧<span class="dash">-</span></span> عن عكرمة مولى ابن عباس= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٤٤٢٨<span class="dash">-</span></span> والحسن البصري -من طريق يزيد النحوي-: مكية{20}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٤٤٢٩<span class="dash">-</span></span> عن شهرِ بن حوشبٍ -من طريق ليث بن أبي سليم- قال: نزلت الأنعام جُملةً واحدة، معها رَجَزٌ من الملائكة، قد نُظِموا ما بين السماء الدنيا إلى الأرض. قال: وهي مكيةٌ، غيرَ آيتَين: <span class="qpc-hafs">﴿قل تعالوا أتل ما حرم ربكم عليكم﴾</span> والآيةُ التي بعدَها [١٥١-١٥٢]{21}. (٦/٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٤٤٣٠<span class="dash">-</span></span> عن عطاء، قال: أُنزِلت الأنعام جميعًا، ومعها سبعون ألفَ مَلَك{19}. (٦/٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٤٤٣١<span class="dash">-</span></span> عن قتادة بن دعامة -من طُرُق-: مكية{23}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٤٤٣٢<span class="dash">-</span></span> عن محمد ابن شهاب الزهري: مكية، ونزلت بعد الحِجْر{24}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٤٤٣٣<span class="dash">-</span></span> عن علي بن أبي طلحة: مكية{25}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٤٤٣٤<span class="dash">-</span></span> عن محمد بن السائب الكلبي، قال: نزَلت الأنعام كلُّها بمكة، إلا آيتَين نزَلتا بالمدينة في رجل من اليهود، وهو الذي قال: <span class="qpc-hafs">﴿ما أنزل الله على بشر من شيء﴾</span> الآية [٩١]{19}. (٦/٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٤٤٣٥<span class="dash">-</span></span> قال مقاتل بن سليمان: سورة الأنعام مكية كلها، إلا هذه الآيات. نزلت بالمدينة، ونزلت ليلًا، وهي خمس وستون ومائة آية كوفي. والآيات المدنية هي: <span class="qpc-hafs">﴿قُلْ تَعالَوْا أتْلُ ما حَرَّمَ رَبُّكُمْ عَلَيْكُمْ﴾</span> إلى قوله: <span class="qpc-hafs">﴿لَعَلَّكُمْ تَعْقِلُونَ﴾</span> [١٥١] وهي الآيات المحكمات، وقوله: <span class="qpc-hafs">﴿وما قَدَرُوا اللَّهَ حَقَّ قَدْرِهِ﴾</span> إلى آخر الآية [٩١]، وقوله: <span class="qpc-hafs">﴿ومَن أظْلَمُ مِمَّنِ افْتَرى عَلى اللَّهِ كَذِبًا أوْ قالَ أُوحِيَ إلَيَّ﴾</span> نزلت في مسيلمة، <span class="qpc-hafs">﴿ومَن قالَ سَأُنْزِلُ مِثْلَ ما أنْزَلَ اللَّهُ﴾</span> نزلت في عهد عبد الله بن سعد بن أبي سرح، وقوله: <span class="qpc-hafs">﴿ولَوْ تَرى إذِ الظّالِمُونَ فِي غَمَراتِ المَوْتِ﴾</span> [٩٣]، وقوله: <span class="qpc-hafs">﴿والَّذِينَ آتَيْناهُمُ الكِتابَ يَعْلَمُونَ أنَّهُ مُنَزَّلٌ مِن رَبِّكَ بِالحَقِّ﴾</span> [١١٤]، <span class="qpc-hafs">﴿الَّذِينَ آتَيْناهُمُ الكِتابَ يَعْرِفُونَهُ﴾</span> [٢٠]، هذه الآيات مدنيات، وسائرها مكي. نزل بها جبريل ﵇، ومعه سبعون ألف ملك، طبَّقوا ما بين السماء والأرض، لهم زَجَل بالتسبيح والتمجيد والتحميد، حتى كادت الأرض أن تَرْتَجَّ، فقال النبي ﷺ: «<b>سبحان الله العظيم وبحمده</b>». وخرَّ النبي ساجدًا، فيها خصومة مشركي العرب وأهل الكتاب{27}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٤٤٣٦<span class="dash">-</span></span> عن معمر بن راشد، قال: يُقال: إنّ سورة الأنعام أُنزِلت جُملة واحدة، معها الملائكة ما بين السماء والأرض، لهم زَجَل بالتسبيح{28}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٤٤٣٧<span class="dash">-</span></span> عن سفيان، قال: نزلت الأنعام كلُّها بمكة، إلا آيتَين نزَلتا بالمدينة في رجلٍ مِن اليهود، وهو الذي قال: <span class="qpc-hafs">﴿ما أنزل الله على بشر من شيء﴾</span>. وهو فِنْحاصُ اليهودي، أو مالكُ بن الصَّيف{19}. (٦/٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٤٤٣٨<span class="dash">-</span></span> عن <span class="name-1">عمر بن الخطاب</span> -من طريق عبد الله بن خليفة- قال: الأنعام مِن نَواجِب{30} القرآن{31}. (٦/٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٤٤٣٩<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن مسعود</span>، قال: الأنعام مِن نَواجِب القرآن{32}. (٦/٩)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿ٱلۡحَمۡدُ لِلَّهِ ٱلَّذِی خَلَقَ ٱلسَّمَـٰوَ ٰ⁠تِ وَٱلۡأَرۡضَ وَجَعَلَ ٱلظُّلُمَـٰتِ وَٱلنُّورَۖ ثُمَّ ٱلَّذِینَ كَفَرُوا۟ بِرَبِّهِمۡ یَعۡدِلُونَ ۝١﴾</span> - نزول الآية</h3></p><p><div></p><p><p><span class="item-no">٢٤٤٤٠<span class="dash">-</span></span> عن <span class="name-1">علي بن أبي طالب</span> -من طريق ابن أبزى- أنّه أتاه رجلٌ مِن الخوارج، فقال: <span class="qpc-hafs">﴿الحمد لله الذي خلق السموات والأرض وجعل الظلمات والنور ثم الذين كفروا بربهم يعدلون﴾</span>، أليس كذلك؟ قال: نعم. فانصرف عنه، ثم قال: ارجِع. فرجَع، فقال: أيْ فُلُ{33}، إنما أُنزِلت في أهل الكتاب{34}. (٦/١٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٤٤٤١<span class="dash">-</span></span> عن <span class="name-1">عبد الرحمن بن أبزى</span>، أنّه أتاه رجلٌ مِن الخوارج، فقرأ عليه: <span class="qpc-hafs">﴿الحمد لله الذي خلق السماوات والأرض وجعل الظلمات والنور﴾</span> الآية. ثم قال: أليس الذين كفروا بربِّهم يَعدِلون؟ قال: بلى. فانصرَف عنه الرجلُ، فقال له رجلٌ مِن القوم: يا ابن أبزى، إنّ هذا أراد تفسيرَ الآية غيرَ ما تَرى، إنّه رجلٌ مِن الخوارج. قال: رُدُّوه عَلَيَّ. فلما جاء، قال: أتَدرِي في مَن أُنزِلت هذه الآية؟ قال: لا. قال: نزلت في أهل الكتاب، فلا تَضَعها في غير موضعها{35}<span class=comment-ref>٢٢١٩</span>. (٦/١٢)</p></p><p></div></p><p><div><span class=comment-ref>٢٢١٩</span> <span class="comment-type-2">انتَقَد</span> <u>ابنُ عطية</u> ٣/٣١١ قول ابن أبزى بنزولها في أهل الكتاب بقوله: «وقول ابن أبزى بعيد». ولم يذكر مستندًا.</div></p><p><div></p><p><p><span class="item-no">٢٤٤٤٢<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق خصيف- قال: نزلت هذه الآية في الزنادقة: <span class="qpc-hafs">﴿الحمد لله الذي خلق السماوات والأرض وجعل الظلمات والنور﴾</span>. قال: قالوا: إنّ الله لم يَخلُق الظلمة، ولا الخنافِس، ولا العقارب، ولا شيئًا قبيحًا، وإنما خلق النور، وكلَّ شيءٍ حسن. فأُنزِلت فيهم هذه الآية{36}. (٦/١٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٤٤٤٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: فيها خصومة مشركي العرب وأهل الكتاب، وذلك أن قريشًا قالوا للنبي ﷺ: مَن ربك؟ فقال: «<b>ربي الأحد، الصمد، الذي لم يلد، ولم يولد، ولم يكن له كفوًا أحد</b>». فقالوا: أنت كذّاب، ما اختصك الله بشيء، وما أنت عليه بأكرم مِنّا. فأنزل الله ﷿: <span class="qpc-hafs">﴿الحَمْدُ لِلَّهِ الَّذِي خَلَقَ السَّماواتِ والأَرْضَ﴾</span>. فحمد نفسه، ودلَّ بصنعه على توحيده{37}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿ٱلۡحَمۡدُ لِلَّهِ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٢٤٤٤٤<span class="dash">-</span></span> قال <span class="name-1">عبد الله بن عباس</span>: افتتح الله الخلق بالحمد، فقال: <span class="qpc-hafs">﴿الحمد لله الذي خلق السموات والأرض﴾</span>. وختمه بالحمد، فقال: <span class="qpc-hafs">﴿وقضي بينهم بالحق﴾</span> أي: بين الخلائق، <span class="qpc-hafs">﴿وقيل الحمد لله رب العالمين﴾</span> [الزمر:٧٥]{38}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٤٤٤٥<span class="dash">-</span></span> عن <span class="name-2">الضحاك بن مزاحم</span> -من طريق يحيى بن عبد الرحمن- قال: الحمد لله رداء الله الرحمن تبارك وتعالى{39}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٤٤٤٦<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span>: <span class="qpc-hafs">﴿الحمد لله الذي خلق السماوات والأرض﴾</span>، حمِد نفسَه؛ فأعظَم خلقَه{19}. (٦/١٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٤٤٤٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿الحَمْدُ لِلَّهِ﴾</span>، فحمد نفسه، ودلَّ بصنعه على توحيده{37}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿ٱلَّذِی خَلَقَ ٱلسَّمَـٰوَ ٰ⁠تِ وَٱلۡأَرۡضَ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٢٤٤٤٨<span class="dash">-</span></span> قال <span class="name-2">وهب بن منبه</span>: أول ما خلق الله مكانًا مظلمًا، ثم خلق جوهرة، فأضاءت ذلك المكان، ثم نظر إلى الجوهرة نظر الهيبة فصارت ماء، فارتفع بخارها وزبدها، فخلق من البخار السماوات، ومن الزبد الأرضين{42}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٤٤٤٩<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿الحمد لله الذي خلق السماوات والأرض وجعل الظلمات والنور﴾</span>، قال: خلَق الله السماوات قبل الأرض{43}. (٦/١٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٤٤٥٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿الذي خلق السماوات والأرض﴾</span>، لم يخلقهما باطلًا، خلقهما لأمر هو كائن{44}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَجَعَلَ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٢٤٤٥١<span class="dash">-</span></span> عن <span class="name-2">أبي رَوْق عطية بن الحارث الهمداني</span> -من طريق بشر بن عمارة- قال: كلُّ شيءٍ في القرآن <span class="qpc-hafs">﴿جَعَل﴾</span> فهو: خَلَق{45}. (٦/١٣)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿ٱلظُّلُمَـٰتِ وَٱلنُّورَۖ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٢٤٤٥٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>: <span class="qpc-hafs">﴿وجعل الظلمات والنور﴾</span>، قال: الكفر، والإيمان{19}. (٦/١٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٤٤٥٣<span class="dash">-</span></span> قال <span class="name-2">الحسن البصري</span>: <span class="qpc-hafs">﴿وجعل الظلمات والنور﴾</span>، يعني: الكفر، والإيمان{47}<span class=comment-ref>٢٢٢٠</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٢٢٢٠</span> اختُلِف في المراد بقوله: <span class="qpc-hafs">﴿الظلمات والنور﴾</span>، <b>فقال قوم</b>: هما الليل، والنهار. و<b>قال آخرون</b>: الكفر، والإيمان.</p><p>و<span class="comment-type-2">انتقد</span> <u>ابنُ عطية</u> (٣/٣١٠) القول الثاني <span class="mustanad">مستندًا لمخالفته للغة العرب</span>، فقال: «وهذا غيرُ جيِّد؛ لأنه إخراج لفظ بيِّن في اللغة عن ظاهره الحقيقي إلى باطن لغير ضرورة، وهذا هو طريق اللغز الذي بَرِئ القرآنُ منه».</div></p><p><div></p><p><p><span class="item-no">٢٤٤٥٤<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿الحمد لله الذي خلق السماوات والأرض وجعل الظلمات والنور﴾</span>، قال: خلَق اللهُ السماوات قبل الأرض، والظلمةَ قبل النور، والجنةَ قبل النار{43}. (٦/١٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٤٤٥٥<span class="dash">-</span></span> قال <span class="name-2">قتادة بن دعامة</span>: <span class="qpc-hafs">﴿وجعل الظلمات والنور﴾</span>، يعني: الجنة، والنار{47}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٤٤٥٦<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- في قوله: <span class="qpc-hafs">﴿وجعل الظلمات والنور﴾</span>، قال: الظلماتُ ظلمةُ الليل، والنورُ نورُ النهار{50}. (٦/١٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٤٤٥٧<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- قوله: <span class="qpc-hafs">﴿وجعل الظلمات والنور﴾</span>، قال: خلق الظلمة قبل النور{51}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٤٤٥٨<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وجعل الظلمات والنور﴾</span>، يعني: الليل، والنهار{44}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿ثُمَّ ٱلَّذِینَ كَفَرُوا۟ بِرَبِّهِمۡ یَعۡدِلُونَ ۝١﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٢٤٤٥٩<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿ثم الذين كفروا بربهم يعدلون﴾</span>، قال: يُشرِكون{53}. (٦/١٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٤٤٦٠<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿ثم الذين كفروا بربهم يعدلون﴾</span>، قال: كذَب العادِلون بالله، فهؤلاء أهلُ الشرك{43}. (٦/١٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٤٤٦١<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿ثم الذين كفروا بربهم يعدلون﴾</span>، قال: هؤلاء أهل صُراحية{55}{56}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٤٤٦٢<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- في قوله: <span class="qpc-hafs">﴿ثم الذين كفروا بربهم يعدلون﴾</span>، قال: هم المشركون{57}. (٦/١٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٤٤٦٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثم رجع إلى أهل مكة، فقال: <span class="qpc-hafs">﴿ثم الذين كفروا﴾</span> من أهل مكة <span class="qpc-hafs">﴿بربهم يعدلون﴾</span> يعني: يُشرِكون{44}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٤٤٦٤<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿ثم الذين كفروا بربهم يعدلون﴾</span>، قال: الآلهةُ التي عبَدوها، عدَلوها بالله تعالى، وليس لله عِدْلٌ، ولا نِدٌّ، وليس معه آلهةٌ، ولا اتخَذ صاحبةً ولا ولدًا{59}<span class=comment-ref>٢٢٢١</span>. (٦/١٤)</p></p><p></div></p><p><div><span class=comment-ref>٢٢٢١</span> اختلف المفسرون فيمن عُنِي بهذه الآية على قولين: <b>الأول</b>: أهل الكتاب -كما مر في نزول الآية-. و<b>الثاني</b>: المشركون من عبدة الأوثان.</p><p>و<span class="comment-type-4">جمع</span> <u>ابنُ جرير</u> (٩/١٤٩) بين القولين مُبَيِّنًا اندراجهما تحت عموم الآية، فقال: «وأَوْلى الأقوال في ذلك بالصواب عندي أن يُقال: إنّ الله تعالى أخبر أنّ الذين كفروا بربهم يعدلون، فعمَّ بذلك جميع الكفار، ولم يخصص منهم بعضًا دون بعض، فجميعهم داخلون في ذلك: يهودهم، ونصاراهم، ومجوسهم، وعبدة الأوثان منهم، ومن غيرهم من سائر أصناف الكفر».</p><p>وبنحوه <span class="comment-type-4">جمع</span> <u>ابنُ عطية</u> (٣/٣١١). <span class="comment-type-2">وانتقد</span> مَن خصَّ نزول الآية بقوم، فقال: «ومَن خَصَّص من المفسرين في ذلك بعضًا دون بعض فلم يُصِب». ثم قال: «إلا أن السابق من حال النبي ﷺ أنّ الإشارة إلى عبدة الأوثان من العرب لمجاورتهم له».</div></p><p><h3><span class="qpc-hafs">﴿ثُمَّ ٱلَّذِینَ كَفَرُوا۟ بِرَبِّهِمۡ یَعۡدِلُونَ ۝١﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٢٤٤٦٥<span class="dash">-</span></span> عن عبد الله بن عمرو، عن النبي ﷺ أنّه قال: «<b>إنّ الله ﷿ خلق خلقه في ظلمة، ثم ألقى عليهم من نوره، فمَن أصابه يومئذ من ذلك النور اهتدى، ومَن أخطأه ضلَّ</b>»{60}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٤٤٦٦<span class="dash">-</span></span> عن <span class="name-2">كعب الأحبار</span> -من طريق عبد الله بن رباح- قال: فُتِحتِ التوراة بـ<span class="qpc-hafs">﴿الحمد لله الذي خلق السماوات والأرض وجعل الظلمات والنور ثم الذين كفروا بربهم يعدلون﴾</span>، وخُتِمت بـ<span class="qpc-hafs">﴿الحمد لله الذي لم يتخذ ولدا﴾</span> إلى قوله: <span class="qpc-hafs">﴿وكبره تكبيرا﴾</span> [الإسراء:١١١]{61}. (٦/١١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٤٤٦٧<span class="dash">-</span></span> وعن <span class="name-2">وهب بن منبه</span>، نحوه{62}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٤٤٦٨<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span>، قال: <span class="qpc-hafs">﴿الحمد لله الذي خلق السموات والأرض﴾</span>، فكان فيه ردٌّ على ثلاثةِ أديانٍ منهم، فكان فيه رَدٌّ على الدّهرِيَّة أنّ الأشياء كلَّها دائمةٌ. ثم قال: <span class="qpc-hafs">﴿وجعل الظلمات والنور﴾</span>، فكان فيه رَدٌّ على المجوس الذين زعَموا أنّ الظُّلمةَ والنورَ هما المُدَبِّران. وقال: <span class="qpc-hafs">﴿ثم الذين كفروا بربهم يعدلون﴾</span>، فكان فيه رَدٌّ على مُشركي العرب، ومَن دعا دونَ الله إلهًا{19}. (٦/١٣)</p></p><p></div></p></div>",footnotes:1:أي: صوت رفيع عال. النهاية (زجل).|2:أخرجه الطبراني في الصغير ١/١٤٥ (٢٢٠)، وأبو نعيم في الحلية ٣/٤٤، من طريق إسماعيل بن عمرو، عن يوسف بن عطية الصفار، عن ابن عون، عن نافع، عن ابن عمر به.</p><p>قال الطبراني: «لم يروه عن ابن عون إلا يوسف بن عطية، تفرد به إسماعيل بن عمرو». وقال أبو نعيم: «غريب من حديث ابن عون». وقال الهيثمي في المجمع ٧/٢٠ (١٠٩٩١): «فيه يوسف بن عطية الصفار، وهو ضعيف». وقال السيوطي في الإتقان في علوم القرآن ١/١٣٦: «وأخرج الطبراني من طريق يوسف بن عطية الصفار، وهو متروك ...». وقال في تحفة الأبرار بنكت الأذكار ص٧٣: «قال الحافظ: سند ضعيف». وقال الشوكاني في تحفة الذاكرين ص٤٠٤: «في إسناده عطية الصفار، وهو ضعيف».|3:الخافقين: هما طرفا السماء والأرض. وقيل: المغرب والمشرق. النهاية (خفق).|4:أخرجه الطبراني في الأوسط ٦/٢٩٢ (٦٤٤٧)، والبيهقي في الشعب ٤/٧٩ (٢٢١٠)، من طريق أحمد بن محمد بن أبي بكر السالمي، عن محمد بن إسماعيل بن أبي فديك، عن عمر بن طلحة، عن أبي سهيل نافع بن مالك، عن أنس بن مالك به.</p><p>قال الهيثمي في المجمع ٧/٢٠ (١٠٩٩٢): «رواه الطبراني، عن شيخه محمد بن عبد الله بن عرس، عن أحمد بن محمد بن أبي بكر السالمي، ولم أعرفهما، وبقية رجاله ثقات». وشيخ الطبراني هنا قد توبع، وقال السيوطي في الإتقان في علوم القرآن ١/١٣٨: «سند ضعيف». وقال في تحفة الأبرار بنكت الأذكار ص٧٣: «قال الحافظ: وابن مردويه عن أنس بن مالك بسند حسن». وقال السفيري في شرح البخاري ١/٢١٤: «سند ضعيف». وقال الشوكاني في تحفة الذاكرين ص٤٠٤: «في إسناده رجلان مجهولان». وقال الألباني في الضعيفة ١٢/٢٧٢ (٥٦٢٧): «منكر».|5:أخرجه الواحدي في التفسير الوسيط ٢/٢٥٠ (٣٢١)، من طريق سلام بن سليم المدائني، عن هارون بن كثير، عن زيد بن أسلم، عن أبيه، عن أبي أمامة، عن أبي بن كعب به. وأورده الثعلبي ٤/١٣١ وزاد في آخره: «... فمن قرأ سورة الأنعام صلى عليه أولئك السبعون ألف ملك بعدد كل آية من الأنعام يومًا وليلة».</p><p>قال ابن الصلاح في فتاويه ١/٢٤٩: «في إسناده ضعف، ولم نر له إسنادًا صحيحًا، وقد روي ما يخالفه، فروي أنها لم تنزل جملة واحدة، بل نزلت آيات منها بالمدينة...». وقال ابن تيمية في جامع المسائل (جمع: محمد عزير شمس) ٤/٣٥٤: «موضوع». وقال السيوطي في الإتقان في علوم القرآن ١/١٣٧: «فهذه شواهد يقوي بعضها بعضًا». وقال في تحفة الأبرار بنكت الأذكار ص٧٢-٧٣: «قال الحافظ: ورد أنها نزلت جملة واحدة في عدة أحاديث، فأخرجه أبو عبيد في فضائله، وابن المنذر، والطبراني عن ابن عباس بسند حسن، وأخرجه الطبراني، وابن مردويه، وأبو نعيم في الحلية بسند ضعيف عن ابن عمر، وأخرجه ابن مردويه عن ابن مسعود بسند ضعيف، وأخرجه الدارقطني في الأفراد، والطبراني في الأوسط، وابن مردويه عن أنس بن مالك بسند حسن، وأخرجه إسحاق بن راهويه في مسنده، والطبراني عن أسماء بنت يزيد بسند حسن، وأخرجه الحاكم في المستدرك عن جابر وقال: صحيح على شرط مسلم. وتعقبه الذهبي، فقال: أظن الحديث موضوعًا. وليس كما ظنَّ لما قدمته من شواهده. وفي الباب غير هذا من الواهيات ضعفًا وانقطاعًا، وفيما ذكرته كفاية ودلالة على أن لذلك أصلًا. انتهى». وقال المناوي في الفتح السماوي ٢/٦٢٩-٦٣٠ (٥١١): «أخرجه الثعلبي من حديث أبي بن كعب، قال الحافظ ابن حجر: فيه أبو عصمة، وهو متهم بالكذب، والجملة الأولى عند الطبراني في الصغير في ترجمة إبراهيم بن نائلة من حديث ابن عمر، وفيه يوسف بن عطية، وهو ضعيف».|6:عزاه السيوطي إلى ابن مردويه.|7:أخرجه البيهقي في شعب الإيمان (٢٤٣٥)، والخطيب في تاريخه ٧/٢٧١-٢٧٢.|8:عزاه السيوطي إلى ابن مردويه.|9:أخرجه الطبراني ٢٤/١٧٨ (٤٤٩، ٤٥٠). وعزاه السيوطي إلى ابن مردويه.|10:عزاه السيوطي إلى الخِلَعِيُّ في الخِلَعيّات.|11:أخرجه ابن الضريس في فضائل القرآن (١٨)، والبيهقي في الدلائل ٧/١٤٢-١٤٤ من طريق مجاهد. وعزاه السيوطي إلى أبي الشيخ، وابن مردويه.|12:أخرجه أبو عبيد في فضائل القرآن ص١٢٩، وابن الضريس في فضائل القرآن (١٩٦)، والطبراني (١٢٩٣٠). وعزاه السيوطي إلى ابن المنذر، وابن مردويه.|13:أخرجه ابن الضريس في فضائل القرآن (٢٠١).|14:أخرجه النحاس في ناسخه ص٤١٥.|15:أخرجه البيهقي في دلائل النبوة ٧/١٤٣-١٤٤.|16:أخرجه ابن الضريس في فضائل القرآن ١/٣٣-٣٥.|17:عزاه السيوطي إلى ابن المنذر.|18:أخرجه عبد الرزاق في تفسيره ١/٢٠٣. وعزاه السيوطي إلى الفريابي، وعبد بن حميد، وابن المنذر، وأبي الشيخ.|19:عزاه السيوطي إلى أبي الشيخ.|20:أخرجه البيهقي في دلائل النبوة ٧/١٤٢-١٤٣.|21:أخرجه إسحاق بن راهويه في مسنده (١٦). وعزاه السيوطي إلى الفريابي، وعبد بن حميد. كما أخرجه ابن أبي شيبة في مصنفه (ت: محمد عوامة) ١٥/٥١٤ (٣٠٧٧٢) مختصرًا دون ذكر الآيات المستثناة.|22:عزاه السيوطي إلى أبي الشيخ.|23:أخرجه الحارث المحاسبي في فهم القرآن ص٣٩٥-٣٩٦ من طريق سعيد، وأبو بكر ابن الأنباري -كما في الإتقان في علوم القرآن ١/٥٧- من طريق همام.|24:تنزيل القرآن ص٣٧-٤٢.|25:أخرجه أبو عبيد في فضائله (ت: الخياطي) ٢/٢٠٠.|26:عزاه السيوطي إلى أبي الشيخ.|27:تفسير مقاتل بن سليمان ١/٥٤٧-٥٤٨.|28:أخرجه عبد الرزاق ٢/٢٠٣.|29:عزاه السيوطي إلى أبي الشيخ.|30:نواجب القرآن: أي: أفاضل سُوَره. النهاية (نجب).|31:أخرجه أبو عبيد في فضائل القرآن ص١٢٩، والدارمي في مسنده ٢/٤٥٣. وعزاه السيوطي إلى محمد بن نصر في كتاب الصلاة، وأبي الشيخ.|32:عزاه السيوطي إلى محمد بن نصر.</p><p><b>وقد أورد السيوطي ٦/٨-١١ آثارًا أخرى في فضل السورة.</b>|33:معناه: يا فلان. النهاية (فلل).|34:أخرجه ابن أبي حاتم ٤/١٢٦٠ (٧٠٨٦)، من طريق علي بن الحسين، عن حفص بن عمر، عن عامر بن إبراهيم، عن يعقوب القمي، عن جعفر، عن ابن أبزى، عن علي به.|35:أخرجه ابن جرير ٩/١٤٨، وابن أبي حاتم ٤/١٢٦٠ (٧٠٨٧)، وأبو الشيخ في طبقات المحدثين ١/٣٥٣ مرسلًا.|36:أخرجه ابن أبي حاتم ٤/١٢٥٩. وعزاه السيوطي إلى أبي الشيخ.|37:تفسير مقاتل بن سليمان ١/٥٤٨-٥٤٩.|38:تفسير البغوي ٣/١٢٥.|39:أخرجه ابن أبي حاتم ٤/١٢٥٨.|40:عزاه السيوطي إلى أبي الشيخ.|41:تفسير مقاتل بن سليمان ١/٥٤٨-٥٤٩.|42:تفسير الثعلبي ٤/١٣٣.|43:أخرجه ابن جرير ٩/١٤٥، وابن أبي حاتم ٤/١٢٥٩. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وأبي الشيخ.|44:تفسير مقاتل بن سليمان ١/٥٤٩.|45:أخرجه ابن جرير ١/٤٧٥.|46:عزاه السيوطي إلى أبي الشيخ.|47:تفسير البغوي ٣/١٢٦.|48:أخرجه ابن جرير ٩/١٤٥، وابن أبي حاتم ٤/١٢٥٩. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وأبي الشيخ.|49:تفسير البغوي ٣/١٢٦.|50:أخرجه ابن جرير ٩/١٤٥، وابن أبي حاتم ٤/١٢٥٩-١٢٦٠.|51:أخرجه ابن أبي حاتم ٤/١٢٦٠.|52:تفسير مقاتل بن سليمان ١/٥٤٩.|53:تفسير مجاهد ص٣١٩، وأخرجه ابن جرير ٩/١٤٨، وابن أبي حاتم ٤/١٢٦٠. وعزاه السيوطي إلى ابن أبي شيبة، وعبد بن حميد، وابن المنذر، وأبي الشيخ.|54:أخرجه ابن جرير ٩/١٤٥، وابن أبي حاتم ٤/١٢٥٩. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وأبي الشيخ.|55:صراحة وصراحية: أي: خالصة. لسان العرب (صرح).|56:أخرجه ابن جرير ٩/١٤٨.|57:أخرجه ابن جرير ٩/١٤٩. وعلَّقه ابن أبي حاتم ٤/١٢٥٩-١٢٦٠ في معنى قوله: <span class="qpc-hafs">﴿ثم الذين كفروا بربهم يعدلون﴾</span>.|58:تفسير مقاتل بن سليمان ١/٥٤٩.|59:أخرجه ابن جرير ٩/١٤٩، وابن أبي حاتم ٤/١٢٦٠ من طريق أصبغ بن الفرج.|60:أخرجه أحمد ١١/٢١٩-٢٢٠ (٦٦٤٤)، والترمذي ٤/٥٨٧ (٢٨٣٣)، والحاكم ١/٨٤ (٨٣)، وابن أبي حاتم -كما في تفسير ابن كثير ٦/٥٣٥-، من طريق عبد الله بن الديلمي، عن عبد الله بن عمرو به.</p><p>قال الترمذي: «هذا حديث حسن». وقال الحاكم: «هذا حديث صحيح، قد تداوله الأئمة، وقد احتجا بجميع رواته، ثم لم يخرجاه، ولا أعلم له علة». وقال الذهبي في التلخيص: «على شرطهما، ولا علة له». وقال البوصيري في إتحاف الخيرة ١/١٦٦ (١٨٧): «سند صحيح». وقال الهيثمي في المجمع ٧/١٩٣-١٩٤ (١١٨١٢، ١١٨١٣): «رواه أحمد بإسنادين، والبزار، والطبراني، ورجال أحد إسنادي أحمد ثقات». وقال الألباني في الصحيحة ٣/٦٣-٦٤ (١٠٧٦): «إسناده صحيح».|61:أخرجه ابن الضريس في فضائل القرآن (١٩٧)، وابن جرير ٩/١٤٧ بلفظ: وخاتمة التوراة خاتمة هود. وعزاه السيوطي إلى ابن المنذر، وأبي الشيخ.|62:تفسير الثعلبي ٤/١٣٤.|63:عزاه السيوطي إلى أبي الشيخ.
  6,2,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿هُوَ ٱلَّذِی خَلَقَكُم مِّن طِینࣲ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٢٤٤٦٩<span class="dash">-</span></span> عن أبي هريرة، عن النبي ﷺ، قال: «<b>إنّ الله خلق آدم من تراب؛ جعله طينًا، ثم تركه حتى كان حمأً مسنونًا خلقه وصوره، ثم تركه حتى إذا كان صلصالًا كالفخار، فكان إبليس يمُرُّ به، فيقول: خُلِقْت لأمر عظيم. ثم نفخ الله فيه روحه</b>»{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٤٤٧٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي بن أبي طلحة- <span class="qpc-hafs">﴿هو الذي خلقكم من طين﴾</span>، يعني: آدم{2}. (٦/١٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٤٤٧١<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- <span class="qpc-hafs">﴿هو الذي خلقكم من طين﴾</span>، قال: هو آدم{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٤٤٧٢<span class="dash">-</span></span> عن <span class="name-2">الضحاك بن مزاحم</span> -من طريق عبيد بن سليمان- قال: خُلِق آدم من طين، وخُلِق الناس من سلالة من ماء مهين{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٤٤٧٣<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span>، في قوله: <span class="qpc-hafs">﴿هو الذي خلقكم من طين﴾</span>، قال: هذا بَدْءُ الخلق، خُلِق آدمُ من طين، ثم جُعِل نَسلُه مِن سلالة من ماء مَهِين{5}. (٦/١٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٤٤٧٤<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط-: أمّا <span class="qpc-hafs">﴿خلقكم من طين﴾</span> فآدم{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٤٤٧٥<span class="dash">-</span></span> قال <span class="name-2">إسماعيل السُّدِّيّ</span>: بعث الله جبريل إلى الأرض ليأتيه بطائفة منها، فقالت الأرض: إني أعوذ بالله منك أن تنقص مني. فرجع ولم يأخذ، وقال: يا ربِّ، إنها عاذت بك. فبعث ميكائيل، فاستعاذت، فرجع، فبعث ملك الموت، فعاذت منه بالله، فقال: وأنا أعوذ بالله أن أخالف أمره. فأخذ من وجه الأرض، وخلط التربة الحمراء والسوداء والبيضاء؛ فلذلك اختلفت ألوان بني آدم، ثم عجنها بالماء العذب والمالح والمر؛ فلذلك اختلفت أخلاقهم، فقال الله ﷿ لملك الموت: رحم جبرئيل وميكائيل الأرض، ولم ترحمها، لا جرم أجعل أرواح مَن أخلق من هذا الطين بيدك{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٤٤٧٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿هو الذي خلقكم من طين﴾</span>، يعني: آدم ﵇؛ لأنكم من ذريته{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٤٤٧٧<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿هو الذي خلقكم من طين ثم قضى أجلا وأجل مسمى عنده ثم أنتم تمترون﴾</span>، قال: خلق آدم من طين، ثم خلقنا من آدم حين أخذنا من ظهره، ثم أخذ الأجل والميثاق في أجل واحد مسمًى في هذه الحياة الدنيا{9}<span class=comment-ref>٢٢٢٢</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٢٢٢٢</span> لم يذكر <u>ابنُ جرير</u> (٩/١٤٩-١٥٠) غير هذا القول وما في معناه.</p><p>وساق <u>ابنُ عطية</u> (٣/٣١٢) هذا القول، ثم نقل عن فرقة أنها قالت: بل المعنى: أنّ النطفة التي يخلق منها الإنسان أصلها من طين، ثم يقلبها الله نطفة.</p><p>ثم <span class="comment-type-3">رجَّح</span> القول الأول، و<span class="comment-type-2">انتقد</span> القول الثاني <span class="mustanad">مستندًا إلى دلالة القرآن، والسنة</span>، فقال: «والقول الأول ألْيَق بالشريعة؛ لأن القول الثاني إنما يترتب على قول مَن يقول بأنّ الطين يرجع بعد التولد والاستحالات الكثيرة نطفة، وذلك مردود عند الأصوليين».</div></p><p><h3><span class="qpc-hafs">﴿ثُمَّ قَضَىٰۤ أَجَلࣰاۖ وَأَجَلࣱ مُّسَمًّى عِندَهُۥۖ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٢٤٤٧٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق سعيد بن جبير- في قوله: <span class="qpc-hafs">﴿ثم قضى أجلا﴾</span> قال: أجلُ الدنيا، وفي لفظٍ: أجلُ موتِه، <span class="qpc-hafs">﴿وأجل مسمى عنده﴾</span> قال: الآخرة، لا يَعلمُه إلا الله{10}. (٦/١٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٤٤٧٩<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطية العوفي- <span class="qpc-hafs">﴿قضى أجلا﴾</span>، قال: هو النومُ، يقبض فيه الروح، ثم يرجعُ إلى صاحبه حين اليقظة، <span class="qpc-hafs">﴿وأجل مسمى عنده﴾</span> قال: هو أجلُ موتِ الإنسان{11}<span class=comment-ref>٢٢٢٣</span>. (٦/١٥)</p></p><p></div></p><p><div><span class=comment-ref>٢٢٢٣</span> قال <u>ابنُ كثير</u> (٣/٢٣٥): «وهذا قول غريب».</div></p><p><div></p><p><p><span class="item-no">٢٤٤٨٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي بن أبي طلحة- <span class="qpc-hafs">﴿ثم قضى أجلا﴾</span> يعني: أجلَ الموت، <span class="qpc-hafs">﴿وأجل مسمى عنده﴾</span>: أجلُ الساعة، والوقوف عند الله{12}. (٦/١٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٤٤٨١<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span>، نحو ذلك{13}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٤٤٨٢<span class="dash">-</span></span> عن <span class="name-2">عطية بن سعد العوفي</span>، نحو ذلك{14}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٤٤٨٣<span class="dash">-</span></span> عن <span class="name-2">زيد بن أسلم</span>، نحو شطره الأول{14}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٤٤٨٤<span class="dash">-</span></span> عن <span class="name-2">الربيع بن أنس</span>، نحو شطره الثاني{14}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٤٤٨٥<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span>، في قوله: <span class="qpc-hafs">﴿ثم قضى أجلا﴾</span> قال: أجلُ الدنيا الموت، <span class="qpc-hafs">﴿وأجل مسمى عنده﴾</span> قال: الآخرةُ؛ البعث{17}. (٦/١٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٤٤٨٦<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- <span class="qpc-hafs">﴿أجَلًا﴾</span> قال: الآخرة عنده، <span class="qpc-hafs">﴿وأَجَلٌ مُسَمًّى﴾</span> قال: الدنيا{18}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٤٤٨٧<span class="dash">-</span></span> عن <span class="name-2">خالد بن معدان</span>، في قوله: <span class="qpc-hafs">﴿وأجل مسمى عنده﴾</span>، قال: أجل البعث{19}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٤٤٨٨<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span> -من طريق جابر- <span class="qpc-hafs">﴿ثم قضى أجلا﴾</span> قال: قضى أجل الدنيا، <span class="qpc-hafs">﴿وأجل مسمى عنده﴾</span> قال: هو أجل البعث{20}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٤٤٨٩<span class="dash">-</span></span> عن <span class="name-2">الضحاك بن مزاحم</span> -من طريق عبيد بن سليمان- <span class="qpc-hafs">﴿قضى أجلا وأجل مسمى عنده﴾</span> قال: قضى أجل الموت، وكل نفس أجلها الموت. قال: ولن يؤخر الله نفسًا إذا جاء أجلها، <span class="qpc-hafs">﴿وأجل مسمى عنده﴾</span> يعني: أجل الساعة ذهاب الدنيا، والإفضاء إلى الله{21}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٤٤٩٠<span class="dash">-</span></span> قال <span class="name-2">الضحاك بن مزاحم</span>، في قوله ﷿: <span class="qpc-hafs">﴿ثم قضى أجلا وأجل مسمى عنده﴾</span>: الأجل الأول من الولادة إلى الموت، والأجل الثاني من الموت إلى البعث، وهو البرزخ{22}<span class=comment-ref>٢٢٢٤</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٢٢٢٤</span> <span class="comment-type-4">علَّق</span> <u>ابنُ كثير</u> (٦/٩) على هذا القول الذي قاله الحسن من طريق أبي بكر الهذلي، وقتادة من طريق سعيد، والضحاك، بقوله: «هو يرجع إلى ما تقدم [يعني: إلى مَن قال بأن <span class="qpc-hafs">﴿أجلا﴾</span> الدنيا، و<span class="qpc-hafs">﴿أجل مسمى﴾</span> الآخرة]، وهو تقدير الأجل الخاص، وهو عمر كل إنسان، وتقدير الأجل العام، وهو عمر الدنيا بكمالها، ثم انتهائها وانقضائها وزوالها، وانتقالها والمصير إلى الدار الآخرة».</p><p>و<span class="comment-type-4">علَّق</span> عليه <u>ابنُ عطية</u> (٣/٣١٢) بقوله: «ووصفه بمسمًى عنده لأنّه استأثر بعلم وقت القيامة».</div></p><p><div></p><p><p><span class="item-no">٢٤٤٩١<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق أبي بكر الهذلي- في قوله: <span class="qpc-hafs">﴿قضى أجلا﴾</span> قال: ما بين أن يخلق إلى أن يموت، <span class="qpc-hafs">﴿وأجل مسمى عنده﴾</span> قال: ما بين أن يموت إلى أن يبعث{23}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٤٤٩٢<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- قوله: <span class="qpc-hafs">﴿ثم قضى أجلا وأجل مسمى عنده﴾</span>، كان يقول: أجل حياتك إلى أن تموت وأجل موتك إلى أن تبعث، فأنت بين أجلين من الله تعالى{24}. (٦/١٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٤٤٩٣<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٤٤٩٤<span class="dash">-</span></span> و<span class="name-2">الحسن البصري</span> -من طريق مَعْمَر- في قوله: <span class="qpc-hafs">﴿قضى أجلا﴾</span> قالا: قضى أجلَ الدنيا منذُ خُلِقتَ إلى أن تموت، <span class="qpc-hafs">﴿وأجل مسمى عنده﴾</span> قال: يوم القيامة{25}. (٦/١٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٤٤٩٥<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- <span class="qpc-hafs">﴿قضى أجلا﴾</span>، قال: أما <span class="qpc-hafs">﴿قضى أجلا﴾</span> فأجل الموت، <span class="qpc-hafs">﴿وأجل مسمى عنده﴾</span> يوم القيامة{26}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٤٤٩٦<span class="dash">-</span></span> عن <span class="name-2">عطاء الخراساني</span> -من طريق ابنه عثمان- أمّا قوله: <span class="qpc-hafs">﴿قضى أجلا﴾</span> فيقال: ما خلق في ستة أيام{27}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٤٤٩٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ثم قضى أجلا﴾</span> يعني: أجل ابن آدم من يوم ولد إلى أن يموت، <span class="qpc-hafs">﴿وأجل مسمى عنده﴾</span> يعني: البرزخ منذ يوم ولد إلى يوم يموت، إلى يوم القيامة{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٤٤٩٨<span class="dash">-</span></span> عن <span class="name-3">يونس بن يزيد الأيليِّ</span>: <span class="qpc-hafs">﴿قضى أجلا﴾</span> قال: ما خَلَق في ستة أيام، <span class="qpc-hafs">﴿وأجل مسمى عنده﴾</span> قال: ما كان بعدَ ذلك إلى يوم القيامة{29}. (٦/١٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٤٤٩٩<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿هو الذي خلقكم من طين ثم قضى أجلا وأجل مسمى عنده ثم أنتم تمترون﴾</span>، قال: خلق آدم من طين، ثم خلقنا من آدم، أخذنا من ظهره، ثم أخذ الأجل والميثاق في أجل واحد مسمًى في هذه الحياة الدنيا{26}<span class=comment-ref>٢٢٢٥</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٢٢٢٥</span> اختلف المفسرون في هذين الأجلين على خمسة أقوال: <b>الأول</b>: <span class="qpc-hafs">﴿أجَلًا﴾</span> الدنيا، <span class="qpc-hafs">﴿أجَلٌ مُسَمًّى﴾</span> الآخرة. <b>الثاني</b>: عكس هذا القول. <b>الثالث</b>: <span class="qpc-hafs">﴿أجَلًا﴾</span> أجل الإنسان من لدن ولادته إلى موته، والأجل المسمى عنده من وقت موته إلى حشره. <b>الرابع</b>: <span class="qpc-hafs">﴿أجَلًا﴾</span> وفاة الإنسان بالنوم، و<span class="qpc-hafs">﴿أجَلٌ مُسَمًّى﴾</span> وفاته بالموت. <b>الخامس</b>: الأجل الأول هو في وقت أخذ الميثاق على بني آدم حين استخرجهم من ظهر آدم، وبقي أجل واحد مسمًى في هذه الحياة الدنيا.</p><p>و<span class="comment-type-4">ذكر</span> <u>ابنُ عطية</u> (٣/٣١٢) أنّ المهدوي حكى عن فرقتين قولين آخرين: <b>الأول</b>: أنّ <span class="qpc-hafs">﴿أجلا﴾</span> ما عرف الناس من آجال الأهِلَّة والسنين والكوائن، و<span class="qpc-hafs">﴿أجل مسمى﴾</span> قيام الساعة. <b>الثاني</b>: أنّ <span class="qpc-hafs">﴿أجلا﴾</span> ما عرفناه من أنّه لا نبي بعد محمد ﷺ، و<span class="qpc-hafs">﴿أجل مسمى﴾</span> الآخرة.</p><p>و<span class="comment-type-3">رجَّح</span> <u>ابنُ جرير</u> (٩/١٥٤) القول الأول الذي قاله ابن عباس، وقتادة، والحسن، ومجاهد، وعكرمة، والسدي، <span class="mustanad">مستندًا إلى ظاهر الآية، والنظائر،</span> فقال: «لأنّه تعالى نبَّه خلقه على موضع حجته عليهم من أنفسهم، فقال لهم: أيها الناس، إنّ الذي يعدل به كفاركم الآلهة والأنداد هو الذي خلقكم فابتدأكم وأنشأكم من طين، فجعلكم صورًا أجسامًا أحياء بعد إذ كنتم طينًا جمادًا، ثم قضى آجال حياتكم لفنائكم ومماتكم، ليعيدكم ترابًا وطينًا كالذي كنتم قبل أن ينشئكم ويخلقكم. <span class="qpc-hafs">﴿وأجل مسمى عنده﴾</span> لإعادتكم أحياءً وأجسامًا كالذي كنتم قبل مماتكم. وذلك نظير قوله: <span class="qpc-hafs">﴿كيف تكفرون بالله وكنتم أمواتا فأحياكم ثم يميتكم ثم يحييكم ثم إليه ترجعون﴾</span> [البقرة:٢٨]».</p><p>و<span class="comment-type-1">وجَّهه</span> <u>ابنُ كثير</u> (٦/٩) بقوله: «وكأنّه مأخوذ من <span class="mustanad">قوله تعالى بعد هذا</span>: <span class="qpc-hafs">﴿وهو الذي يتوفاكم بالليل ويعلم ما جرحتم بالنهار ثم يبعثكم فيه ليقضى أجل مسمى ثم إليه مرجعكم﴾</span> [الأنعام:٦٠]».</p><p>و<span class="comment-type-4">علَّق</span> <u>ابنُ عطية</u> (٣/٣١٢) بعد ذكره لهذه الأقوال بقوله: «وينبغي أن تُتَأمَّل لفظة <span class="qpc-hafs">﴿قَضى﴾</span> في هذه الآية؛ فإنها تحتمل معنيين، فإن جُعلت بمعنى: قدَّر وكتب ورجعت إلى سابق علمه وقدره، فيقول: إن ذلك ولا بد قبل خلقه آدم من طين، وتخرج <span class="qpc-hafs">﴿ثم﴾</span> من معهودها في ترتيب زمني وقوع القصتين، ويبقى لها ترتيب زمني الإخبار عنه، كأنه قال: أخبركم أنه خلقكم من طين، ثم أخبركم أنه قضى أجلًا. وإن جعلت <span class="qpc-hafs">﴿قَضى﴾</span> بمعنى: أوجد وأظهر، ويرجع ذلك إلى صفة فعل، فيصح أن يكون خلق آدم من طين قبل إظهار هذا الأجل وإبدائه، وتكون <span class="qpc-hafs">﴿ثم﴾</span> على بابها في ترتيب زَمَنَي وقوع القضيتين».</div></p><p><h3><span class="qpc-hafs">﴿ثُمَّ أَنتُمۡ تَمۡتَرُونَ ۝٢﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٢٤٥٠٠<span class="dash">-</span></span> عن <span class="name-2">خالد بن مَعدانَ</span> -من طريق ثور- في قوله: <span class="qpc-hafs">﴿ثم أنتم تمترون﴾</span>، يقول: في البعث{31}. (٦/١٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٤٥٠١<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span>، في قوله: <span class="qpc-hafs">﴿ثم أنتم تمترون﴾</span>، قال: تَشُكُّون{5}. (٦/١٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٤٥٠٢<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- في قوله: <span class="qpc-hafs">﴿ثم أنتم تمترون﴾</span>، قال: تَشُكُّون{33}. (٦/١٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٤٥٠٣<span class="dash">-</span></span> عن <span class="name-2">الربيع بن أنس</span> -من طريق ابن المبارك- في قول الله: <span class="qpc-hafs">﴿ثم أنتم تمترون﴾</span>، يعني: الشك والريبة في أمر الساعة{31}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٤٥٠٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ثم أنتم تمترون﴾</span>، يعني: تَشُكُّون في البعث، يعني: كفار مكة{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٤٥٠٥<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- <span class="qpc-hafs">﴿ثم أنتم تمترون﴾</span>، قال: الشك. قال: وقرأ قول الله: <span class="qpc-hafs">﴿في مرية منه﴾</span> [الحج:٥٥]. قال: في شكٍّ منه{36}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه أبو يعلى ١١/٤٥٣ (٦٥٨٠)، من طريق إسماعيل بن رافع، عن المقبري، عن أبي هريرة به.</p><p>قال الهيثمي في المجمع ٨/١٩٧ (١٣٧٤٧): «فيه إسماعيل بن رافع، قال البخاري: ثقة مقارب الحديث. وضعفه الجمهور، وبقية رجاله رجال الصحيح». وقال البوصيري في إتحاف الخيرة ٧/١٣٦-١٣٧ (٦٥١٩): «هذا إسناد ضعيف، لضعف إسماعيل بن رافع».|2:عزاه السيوطي إلى ابن المنذر.|3:أخرجه ابن جرير ٩/١٥٠.|4:أخرجه ابن جرير ٩/١٥٠.|5:عزاه السيوطي إلى عبد بن حميد.|6:أخرجه ابن جرير ٩/١٥٠.|7:تفسير الثعلبي ٤/١٣٤.|8:تفسير مقاتل بن سليمان ١/٥٤٩.|9:أخرجه ابن جرير ٩/١٥٠، ١٥٣.|10:أخرجه ابن جرير ٩/١٥١، وابن أبي حاتم ٤/١٢٦٠-١٢٦٢، والحاكم ٢/٣١٥. وعزاه السيوطي إلى الفريابي، وابن أبي شيبة، وابن المنذر، وأبي الشيخ.|11:أخرجه ابن جرير ٩/١٥٣، وابن أبي حاتم ٤/١٢٦١.|12:أخرجه ابن جرير ٩/١٥٣، وابن أبي حاتم ٤/١٢٦١-١٢٦٢. وعزاه السيوطي إلى ابن المنذر.|13:علَّق ابن أبي حاتم ٤/١٢٦١ شطره الأول، وأخرج ٤/١٢٦١ شطره الثاني من طريق عطاء بن السائب.|14:علَّقه ابن أبي حاتم ٤/١٢٦١.|15:علَّقه ابن أبي حاتم ٤/١٢٦١.|16:علَّقه ابن أبي حاتم ٤/١٢٦١.|17:أخرجه ابن جرير ٩/١٥٢. وعلَّقه ابن أبي حاتم ٤/١٢٦١. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وأبي الشيخ.|18:تفسير مجاهد ص٣١٩، وأخرجه ابن جرير ٩/١٥٢.|19:علَّقه ابن أبي حاتم ٤/١٢٦٢.|20:أخرجه ابن جرير ٩/١٥٢، وفي لفظ: <span class="qpc-hafs">﴿ثم قضى أجلا﴾</span> قال: الموت.|21:أخرجه ابن جرير ٩/١٥١. وعلَّقه ابن أبي حاتم ٤/١٢٦١ بنحوه.|22:تفسير البغوي ٣/١٢٧.|23:أخرجه ابن جرير ٩/١٥٢.|24:أخرجه ابن جرير ٩/١٥٢. وعزا السيوطي إلى عبد بن حميد نحوه.|25:أخرجه عبد الرزاق ١/٢٠٣، وابن جرير ٩/١٥٢. وعلَّقه ابن أبي حاتم ٤/١٢٦١ بنحوه. وعزاه السيوطي إلى ابن المنذر، وأبي الشيخ. وأخرج أبو عمرو الداني في المكتفى ص٦٥ (٨) نحوه من طريق يحيى بن سلام.|26:أخرجه ابن جرير ٩/١٥٣.|27:أخرجه ابن أبي حاتم ٤/١٢٦١.|28:تفسير مقاتل بن سليمان ١/٥٤٩.|29:عزاه السيوطي إلى أبي الشيخ.|30:أخرجه ابن جرير ٩/١٥٣.|31:أخرجه ابن أبي حاتم ٤/١٢٦٢.|32:عزاه السيوطي إلى عبد بن حميد.|33:أخرجه ابن جرير ٩/١٥٤، وابن أبي حاتم ٤/١٢٦٢. وعزاه السيوطي إلى أبي الشيخ.|34:أخرجه ابن أبي حاتم ٤/١٢٦٢.|35:تفسير مقاتل بن سليمان ١/٥٤٩.|36:أخرجه ابن جرير ٩/١٥٤.
  6,3,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَهُوَ ٱللَّهُ فِی ٱلسَّمَـٰوَ ٰ⁠تِ وَفِی ٱلۡأَرۡضِ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٢٤٥٠٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وهو الله في السماوات﴾</span> أنّه واحد، <span class="qpc-hafs">﴿وفي الأرض﴾</span>{1}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿یَعۡلَمُ سِرَّكُمۡ وَجَهۡرَكُمۡ وَیَعۡلَمُ مَا تَكۡسِبُونَ ۝٣﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٢٤٥٠٧<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي بن أبي طلحة- قوله: <span class="qpc-hafs">﴿يعلم سركم﴾</span>، قال: السر: ما أسرَّ ابنُ آدم في نفسه{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٤٥٠٨<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span> -من طريق عطاء بن دينار- في قول الله: <span class="qpc-hafs">﴿يعلم سركم﴾</span>، قال: السِّرُّ: ما حدَّثْتَ به نفسَك{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٤٥٠٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿يعلم سركم وجهركم﴾</span> يعني: سرّ أعمالكم، وجهرها، <span class="qpc-hafs">﴿ويعلم ما تكسبون﴾</span> يعنى: ما تعملون من الخيرِ، والشرِّ{1}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ١/٥٤٩.|2:أخرجه ابن أبي حاتم ٤/١٢٦٢-١٢٦٣.|3:أخرجه ابن أبي حاتم ٤/١٢٦٣.|4:تفسير مقاتل بن سليمان ١/٥٤٩.
  6,4,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَمَا تَأۡتِیهِم مِّنۡ ءَایَةࣲ مِّنۡ ءَایَـٰتِ رَبِّهِمۡ إِلَّا كَانُوا۟ عَنۡهَا مُعۡرِضِینَ ۝٤﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٢٤٥١٠<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿وما تأتيهم من آية من آيات ربهم إلا كانوا عنها معرضين﴾</span>، يقول: ما يأتيهم مِن شيءٍ مِن كتاب الله إلا أعرَضوا عنه{1}. (٦/١٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٤٥١١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وما تأتيهم من آية من آيات ربهم﴾</span> يعني: انشقاق القمر <span class="qpc-hafs">﴿إلا كانوا عنها معرضين﴾</span> فلِمَ لا يتفكرون فيها فيعتبروا في توحيد الله؟!{2}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن أبي حاتم ٤/١٢٦٣.|2:تفسير مقاتل بن سليمان ١/٥٤٩.
  6,5,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿فَقَدۡ كَذَّبُوا۟ بِٱلۡحَقِّ لَمَّا جَاۤءَهُمۡ فَسَوۡفَ یَأۡتِیهِمۡ أَنۢبَـٰۤؤُا۟ مَا كَانُوا۟ بِهِۦ یَسۡتَهۡزِءُونَ ۝٥﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٢٤٥١٢<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿فقد كذبوا بالحق لما جاءهم فسوف يأتيهم أنباء ما كانوا به يستهزؤون﴾</span>، يقول: سيأتيهم يومَ القيامة أنباءُ ما استَهزَءُوا به من كتاب الله ﷿{1}. (٦/١٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٤٥١٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فقد كذبوا بالحق لما جاءهم﴾</span> يعني: القرآن، حين جاءهم به محمد ﷺ استهزءوا بالقرآن بأنّه ليس من الله، يعني: كفار مكة؛ منهم أبو جهل بن هشام، والوليد بن المغيرة، ومنبه ونبيه ابنا الحجاج، والعاص بن وائل السهمي، وأُبَيّ بن خلف، وعقبة بن أبي معيط، وعبد الله بن أبي أمية، وعتبة وشيبة ابنا ربيعة، وأبو البختري ابن هشام بن أسد، والحارث بن عامر بن نوفل، ومخرمة بن نوفل، وهشام بن عمرو بن ربيعة، وأبو سفيان بن حرب، وسهيل بن عمرو، وعمير بن وهب بن خلف، والحارث بن قيس، وعدي بن قيس، وعامر بن خالد الجمحي، والنضر بن الحارث، وزمعة بن الأسود، ومطعم بن عدي، وقرط بن عبد عمرو بن نوفل، والأخنس بن شريق، وحويطب بن عبد العزي، وأمية بن خلف، كلهم من قريش. يقول الله ﷿: <span class="qpc-hafs">﴿فسوف يأتيهم أنباء﴾</span> يعني: حديث <span class="qpc-hafs">﴿ما كانوا به﴾</span> بالعذاب <span class="qpc-hafs">﴿يستهزؤن﴾</span> بأنّه غير نازل بهم. ونظيرها في الشعراء، فنزل بهم العذاب ببدر{2}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن أبي حاتم ٤/١٢٦٣.|2:تفسير مقاتل بن سليمان ١/٥٤٩- ٥٥٠. وقوله: «ونظيرها في الشعراء» يشير إلى قوله تعالى: <span class="qpc-hafs">﴿فَقَدْ كَذَّبُوا فَسَيَأْتِيهِمْ أنْباءُ ما كانُوا بِهِ يَسْتَهْزِئُونَ﴾</span> [الشعراء:٦].
  6,6,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿أَلَمۡ یَرَوۡا۟ كَمۡ أَهۡلَكۡنَا مِن قَبۡلِهِم مِّن قَرۡنࣲ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٢٤٥١٤<span class="dash">-</span></span> عن <span class="name-2">أبي مالك غزوان الغفاري</span> -من طريق السدي- في قوله: <span class="qpc-hafs">﴿من قرن﴾</span>، قال: أُمَّة{1}. (٦/١٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٤٥١٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: وعظهم ليخافوا، فقال: <span class="qpc-hafs">﴿ألم يروا كم أهلكنا من قبلهم﴾</span> كفار مكة <span class="qpc-hafs">﴿من قرن﴾</span> من أُمَّة{2}<span class=comment-ref>٢٢٢٦</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٢٢٢٦</span> <span class="comment-type-4">ذكر</span> <u>ابنُ عطية</u> (٣/٣١٥-٣١٦) أنّه قيل أنّ القرن: الزمن نفسه. و<span class="comment-type-4">علَّق</span> عليه بقوله: «وهو على حذف مضاف، تقديره: من أهل قرن».</p><p>و<span class="comment-type-4">ذكر</span> أنه اختلف في مدة القرن على أقوال: <b>الأول</b>: أنه مائة سنة. <b>الثاني</b>: ثمانين سنة. <b>الثالث</b>: سبعين. <b>الربع</b>: ستين. <b>الخامس</b>: أربعين. <b>السادس</b>: ثلاثين. <b>السابع</b>: عشرين. <b>الثامن</b>: ثمانية عشر.</p><p><b>وبيَّن</b> أن الأكثر على القول الأول، ثم <span class="comment-type-4">علَّق</span> بقوله: «ويرجح ذلك الحديث الذي قال فيه رسول الله ﷺ: «أرأيتكم ليلتكم هذه، فإنّ على رأس مائة منها لا يبقى ممن هو اليوم على ظهر الأرض أحد». قال ابن عمر: يريد أنها تحرم ذلك القرن. وروي أن رسول الله ﷺ قال لعبد الله بن بسر: «تعيش قرنًا». فعاش مائة سنة».</p><p>و<span class="comment-type-4">بَيَّن</span> أن مَن قالوا بالقول الثاني والثالث والرابع تمسكوا بحديث: «معترك المنايا ما بين الستين والسبعين». و<span class="comment-type-4">علَّق</span> على القول الخامس بقوله: «وذكر الزهراوي في ذلك أنه عن النبي ﷺ». ثم <span class="comment-type-2">انتقد</span> هذه الأقوال عدا الأول، فقال: «وهذا كله ضعيف، وهذه طبقات وليست بقرون، إنما القرن أن يكون وفاة الأشياخ ثم ولادة الأطفال، ويظهر ذلك من قوله تعالى: <span class="qpc-hafs">﴿وأنشأنا من بعدهم قرنا آخرين﴾</span>».</div></p><p><h3><span class="qpc-hafs">﴿مَّكَّنَّـٰهُمۡ فِی ٱلۡأَرۡضِ مَا لَمۡ نُمَكِّن لَّكُمۡ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٢٤٥١٦<span class="dash">-</span></span> قال <span class="name-1">عبد الله بن عباس</span>: أمهلناهم في العمر، والأجسام، والأولاد؛ مثل قوم نوح، وعاد، وثمود{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٤٥١٧<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق مَعْمَر- في قوله: <span class="qpc-hafs">﴿مكناهم في الأرض ما لم نمكن لكم﴾</span>، يقول: أعطيناهم ما لم نُعطِكم{4}. (٦/١٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٤٥١٨<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿مكناهم في الأرض ما لم نمكن لكم﴾</span>، يقول: أعطيناهم من الخير والتمكين في البلاد ما لم نُعطِكم، يا أهل مكة{5}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَأَرۡسَلۡنَا ٱلسَّمَاۤءَ عَلَیۡهِم مِّدۡرَارࣰا﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٢٤٥١٩<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي بن أبي طلحة- في قوله: <span class="qpc-hafs">﴿وأرسلنا السماء عليهم مدرارا﴾</span>، يقول: يَتبعُ بعضُها بعضًا{6}. (٦/١٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٤٥٢٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وأرسلنا السماء عليهم مدرارا﴾</span> بالمطر، يعني: مُتتابِعًا{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٤٥٢١<span class="dash">-</span></span> عن هارون التيمي -من طريق أبي عيش- في قوله: <span class="qpc-hafs">﴿وأرسلنا السماء عليهم مدرارا﴾</span>، قال: المطرَ في إبّانِه{8}. (٦/١٨)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿فَأَهۡلَكۡنَـٰهُم بِذُنُوبِهِمۡ وَأَنشَأۡنَا مِنۢ بَعۡدِهِمۡ قَرۡنًا ءَاخَرِینَ ۝٦﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٢٤٥٢٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فأهلكناهم﴾</span> يعني: فعذَّبناهم <span class="qpc-hafs">﴿بذنوبهم﴾</span> يعني: بتكذيبهم رسلهم، <span class="qpc-hafs">﴿وأنشأنا من بعدهم قرنا آخرين﴾</span> يقول: وخلقنا من بعد هلاكهم قومًا آخرين{5}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿فَأَهۡلَكۡنَـٰهُم بِذُنُوبِهِمۡ وَأَنشَأۡنَا مِنۢ بَعۡدِهِمۡ قَرۡنًا ءَاخَرِینَ ۝٦﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٢٤٥٢٣<span class="dash">-</span></span> عن <span class="name-2">مالك بن دينار</span> -من طريق جعفر بن سليمان- يقول: إذا كان القحط بذنوبنا، وإذا كان الخصب يتلو هذه الآية: <span class="qpc-hafs">﴿وأرسلنا السماء عليهم مدرارا وجعلنا الأنهار تجري من تحتهم فأهلكناهم بذنوبهم وأنشأنا من بعدهم قرنا آخرين﴾</span>{10}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن أبي حاتم ٤/١٢٦٣.|2:تفسير مقاتل بن سليمان ١/٥٥٠. وسترد الآثار مفصلة في تحديد مدة القرن، وذلك عند تفسير قوله تعالى: <span class="qpc-hafs">﴿وكَمْ أهْلَكْنا مِنَ القُرُونِ مِن بَعْدِ نُوحٍ﴾</span> [الإسراء: ١٧]، وقوله تعالى: <span class="qpc-hafs">﴿وقُرُونًا بَيْنَ ذَلِكَ كَثِيرًا﴾</span> [الفرقان: ٣٨].|3:تفسير الثعلبي ٤/١٣٥.|4:أخرجه ابن جرير ٩/١٥٦-١٥٧، وابن أبي حاتم ٤/١٢٦٣. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وأبي الشيخ.|5:تفسير مقاتل بن سليمان ١/٥٥٠.|6:أخرجه ابن أبي حاتم ٤/١٢٦٣. وعزاه السيوطي إلى ابن المنذر، وأبي الشيخ.|7:تفسير مقاتل بن سليمان ١/٥٥٠.|8:أخرجه ابن أبي حاتم ٤/١٢٦٤. وعزاه السيوطي إلى أبي الشيخ.|9:تفسير مقاتل بن سليمان ١/٥٥٠.|10:أخرجه ابن أبي حاتم ٤/١٢٦٤.
  6,7,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَلَوۡ نَزَّلۡنَا عَلَیۡكَ كِتَـٰبࣰا فِی قِرۡطَاسࣲ فَلَمَسُوهُ بِأَیۡدِیهِمۡ لَقَالَ ٱلَّذِینَ كَفَرُوۤا۟ إِنۡ هَـٰذَاۤ إِلَّا سِحۡرࣱ مُّبِینࣱ ۝٧﴾</span> - نزول الآية</h3></p><p><div></p><p><p><span class="item-no">٢٤٥٢٤<span class="dash">-</span></span> قال <span class="name-2">الحسن البصري</span>: وذلك أنهم سألوا رسول الله ﷺ أن يأتيهم بآية؛ بكتاب يقرءونه، وقالوا: لن نؤمن لك حتى تنزل علينا كتابًا نقرؤه من الله إلى كلِّ رجل باسمه: أن آمِن بمحمد؛ فإنّه رسولي{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٤٥٢٥<span class="dash">-</span></span> قال <span class="name-3">محمد بن السائب الكلبي</span>، في قوله تعالى: <span class="qpc-hafs">﴿ولو نزلنا عليك كتابا في قرطاس﴾</span>: إنّ مشركي مكة قالوا: يا محمد، واللهِ، لا نؤمن لك حتى تأتينا بكتاب من عند الله، ومعه أربعة من الملائكة يشهدون أنّه من عند الله، وأنّك رسوله. فنزلت هذه الآية{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٤٥٢٦<span class="dash">-</span></span> عن <span class="name-3">مقاتل</span>: نزلت في النضر بن الحارث، وعبد الله بن أبي أمية، ونوفل بن خويلد، قالوا: يا محمد، لن نؤمن لك حتى تأتينا بكتاب من عند الله، ومعه أربعة من الملائكة، يشهدون عليه أنّه من عند الله، وأنك رسوله. فأنزل الله ﷿: <span class="qpc-hafs">﴿ولو نزلنا عليك كتابا في قرطاس﴾</span>{3}<span class=comment-ref>٢٢٢٧</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٢٢٢٧</span> <span class="comment-type-4">علَّق</span> <u>ابنُ عطية</u> (٣/٣١٧) بقوله: «ويشبه أنّ سبب هذه الآية اقتراحُ عبد الله بن أبي أمية وتعنته؛ إذ قال للنبي ﷺ: لا أؤمن لك حتى تصعد إلى السماء، ثم تنزل بكتاب فيه: من رب العزة إلى عبد الله بن أبي أمية، يأمرني بتصديقك، وما أراني مع هذا كنت أصدقك. ثم أسلم بعد ذلك عبد الله، وقتل شهيدًا في الطائف».</div></p><p><h3><span class="qpc-hafs">﴿وَلَوۡ نَزَّلۡنَا عَلَیۡكَ كِتَـٰبࣰا فِی قِرۡطَاسࣲ﴾</span> - تفسير الآية</h3></p><p><div></p><p><p><span class="item-no">٢٤٥٢٧<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطية العوفي- في قوله: <span class="qpc-hafs">﴿ولو نزلنا عليك كتابا في قرطاس فلمسوه بأيديهم﴾</span>، يقول: لو أنزَلنا مِن السماء صُحُفًا فيها كتاب، فلَمَسُوه بأيدِيهم، لَزادهم ذلك تَكذيبًا{4}. (٦/١٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٤٥٢٨<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق مَعْمَر- في قوله: <span class="qpc-hafs">﴿ولو نزلنا عليك كتابا في قرطاس﴾</span>، يقول: في صحيفة{5}. (٦/١٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٤٥٢٩<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- <span class="qpc-hafs">﴿ولو نزلنا عليك كتابا في قرطاس﴾</span>: الصحف{6}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿فَلَمَسُوهُ بِأَیۡدِیهِمۡ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٢٤٥٣٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق سعيد بن جبير- في قوله: <span class="qpc-hafs">﴿فلمسوه بأيديهم﴾</span>: مسُّوه، ونظروا إليه؛ لم يؤمنوا به{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٤٥٣١<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿فلمسوه بأيديهم﴾</span>، قال: فمَسُّوه، ونظَروا إليه؛ لم يُصَدِّقوا به{8}. (٦/١٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٤٥٣٢<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿فلمسوه بأيديهم﴾</span>، يقول: فعايَنوه مُعاينةً، ومَسُّوه بأيديهم{9}. (٦/١٨)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿لَقَالَ ٱلَّذِینَ كَفَرُوۤا۟ إِنۡ هَـٰذَاۤ إِلَّا سِحۡرࣱ مُّبِینࣱ ۝٧﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٢٤٥٣٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ولَوْ نَزَّلْنا عَلَيْكَ كِتابًا فِي قِرْطاسٍ فَلَمَسُوهُ بِأَيْدِيهِمْ﴾</span> ما صدَّقوا به، و<span class="qpc-hafs">﴿لَقالَ الَّذِينَ كَفَرُوا﴾</span> من أهل مكة: <span class="qpc-hafs">﴿إنْ هَذا﴾</span> يقول: ما هذا القرآن <span class="qpc-hafs">﴿إلّا سِحْرٌ مُبِينٌ﴾</span> يعني: بيِّنٌ{10}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير ابن أبي زمنين ٢/٥٩.|2:تفسير الثعلبي ٤/١٣٥، وأسباب النزول للواحدي ص٢١٦، وتفسير البغوي ٣/١٢٩.|3:تفسير الثعلبي ٤/١٣٥، وتفسير البغوي ٣/١٢٩.|4:أخرجه ابن جرير ٩/١٥٩، وابن أبي حاتم ٤/١٢٦٤. وعزاه السيوطي إلى ابن المنذر.|5:أخرجه عبد الرزاق ١/٢٠٣، وابن جرير ٩/١٥٩-١٦٠، وابن أبي حاتم ٤/١٢٦٤. وعزاه السيوطي إلى عبد بن حميد، وأبي الشيخ.|6:أخرجه ابن جرير ٩/١٥٩. وعلَّقه ابن أبي حاتم ٤/١٢٦٤.|7:أخرجه الحاكم (ت: مصطفى عطا) ٢/٣٤٤-٣٤٥ (٣٢٢٧).|8:تفسير مجاهد ص٣١٩، وأخرجه ابن جرير ٩/١٥٩، وابن أبي حاتم ٤/١٢٦٤، وعزاه السيوطي إلى ابن أبي شيبة، وعبد بن حميد، وابن المنذر، وأبي الشيخ.|9:أخرجه ابن جرير ٩/١٥٩، وابن أبي حاتم ٤/١٢٦٤. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.|10:تفسير مقاتل بن سليمان ١/٥٥٠.
  6,8,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَقَالُوا۟ لَوۡلَاۤ أُنزِلَ عَلَیۡهِ مَلَكࣱۖ وَلَوۡ أَنزَلۡنَا مَلَكࣰا لَّقُضِیَ ٱلۡأَمۡرُ ثُمَّ لَا یُنظَرُونَ ۝٨﴾</span> - نزول الآية</h3></p><p><div></p><p><p><span class="item-no">٢٤٥٣٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: نزلت في النضر بن الحارث، وعبد الله بن أمية بن المغيرة، ونوفل بن خويلد، كلهم من قريش{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٤٥٣٥<span class="dash">-</span></span> عن <span class="name-3">محمد بن إسحاق</span> -من طريق سلمة- قال: دعا رسول الله ﷺ قومَه إلى الإسلام، وكلَّمهم فأبلَغ إليهم -فيما بلَغَني-، فقال له زَمعةُ بن الأسود بن المطلب، والنضرُ بن الحارث بن كَلَدَة، وعَبدةُ بنُ عبد يغوث، وأُبيُّ بن خلف بن وهب، والعاصي بن وائل بن هشام: لو جُعِل معك -يا محمد- مَلَكٌ يُحَدِّثُ عنك الناس، ويُرى معك. فأنزل الله في ذلك من قولهم: <span class="qpc-hafs">﴿وقالوا لولا أنزل عليه ملك﴾</span> الآية{2}. (٦/١٩)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَقَالُوا۟ لَوۡلَاۤ أُنزِلَ عَلَیۡهِ مَلَكࣱۖ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٢٤٥٣٦<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span>، في قوله: <span class="qpc-hafs">﴿وقالوا لولا أنزل عليه ملك﴾</span>، قال: مَلَكٌ في صورة رجل{3}. (٦/١٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٤٥٣٧<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿وقالوا لولا أنزل عليه ملك﴾</span>، قال: في صورته{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٤٥٣٨<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وقالوا لولا﴾</span> يعني: هلّا <span class="qpc-hafs">﴿أنزل عليه ملك﴾</span> يعينه ويُصَدِّقه بما أرسل به. نظيرها في الفرقان{5}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَلَوۡ أَنزَلۡنَا مَلَكࣰا لَّقُضِیَ ٱلۡأَمۡرُ ثُمَّ لَا یُنظَرُونَ ۝٨﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٢٤٥٣٩<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق أبي رَوْق، عن الضحاك- <span class="qpc-hafs">﴿ولو أنزلنا ملكا﴾</span> قال: ولو أتاهم مَلَكٌ في صورتِه <span class="qpc-hafs">﴿لقضي الأمر﴾</span> لأهلكناهم، <span class="qpc-hafs">﴿ثم لا ينظرون﴾</span> لا يُؤَخَّرُون{6}. (٦/١٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٤٥٤٠<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿ولو أنزلنا ملكا لقضي الأمر﴾</span>، قال: لَقامت الساعة{7}<span class=comment-ref>٢٢٢٨</span>. (٦/١٩)</p></p><p></div></p><p><div><span class=comment-ref>٢٢٢٨</span> <span class="comment-type-2">انتَقَد</span> <u>ابنُ عطية</u> (٣/٣١٧) قول مجاهد بقوله: «وهذا ضعيف».</div></p><p><div></p><p><p><span class="item-no">٢٤٥٤١<span class="dash">-</span></span> قال <span class="name-2">الضحاك بن مزاحم</span>: لو أتاهم ملك في صورته لماتوا{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٤٥٤٢<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span> -من طريق سفيان الثوري، عن أبيه- <span class="qpc-hafs">﴿لقضي الأمر﴾</span>، قال: لَقامت الساعة{9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٤٥٤٣<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق مَعْمَر- في قوله: <span class="qpc-hafs">﴿ولو أنزلنا ملكا لقضي الأمر﴾</span>، يقول: لو أنزَل الله مَلَكًا ثم لم يُؤمِنوا لعَجَّل لهم العذاب{10}<span class=comment-ref>٢٢٢٩</span>. (٦/١٩)</p></p><p></div></p><p><div><span class=comment-ref>٢٢٢٩</span> <span class="comment-type-4">علَّق</span> <u>ابنُ عطية</u> (٣/٣١٧) على هذا القول بقوله: «وهذا قول حَسَن».</div></p><p><div></p><p><p><span class="item-no">٢٤٥٤٤<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- قوله: <span class="qpc-hafs">﴿ثم لا ينظرون﴾</span>، يقول: ثم لم يُنْظَروا{11}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٤٥٤٥<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- <span class="qpc-hafs">﴿ولو أنزلنا ملكا لقضي الأمر ثم لا ينظرون﴾</span>، يقول: لَجاءهم العذاب{12}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٤٥٤٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: يقول الله: <span class="qpc-hafs">﴿ولو أنزلنا ملكا﴾</span> فعاينوه <span class="qpc-hafs">﴿لقضي الأمر﴾</span> يعني: لنزل العذاب بهم، <span class="qpc-hafs">﴿ثم لا ينظرون﴾</span> يعني: ثم لا يُناظَر بهم حتى يعذبوا؛ لأنّ الرسل إذا كُذِّبت جاءت الملائكة بالعذاب{1}<span class=comment-ref>٢٢٣٠</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٢٢٣٠</span> اختلف المفسرون في معنى قوله: <span class="qpc-hafs">﴿لقضي الأمر﴾</span> على ثلاثة أقوال: <b>الأول</b>: لقامت الساعة. <b>والثاني</b>: لعجل لهم العذاب. <b>والثالث</b>: لماتوا من هول رؤية الملك.</p><p>و<span class="comment-type-3">رجَّح</span> <u>ابنُ عطية</u> (٣/٣١٧) القول الأخير <span class="mustanad">مستندًا إلى السياق</span>، فقال: «ويؤيد هذا التأويل ما بعده من قوله: <span class="qpc-hafs">﴿ولَوْ جَعَلْناهُ مَلَكًا لَجَعَلْناهُ رَجُلًا﴾</span>، فإنّ أهل التأويل مجمعون أن ذلك؛ لأنّهم لم يكونوا يطيقون رؤية الملك في صورته، فالأَوْلى في قوله: <span class="qpc-hafs">﴿لَقُضِيَ الأَمْرُ﴾</span> أي: لماتوا من هول رؤيته».</div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ١/٥٥٠-٥٥١.|2:أخرجه ابن أبي حاتم ٤/١٢٦٥. وعزاه السيوطي إلى ابن المنذر.|3:عزاه السيوطي إلى عبد بن حميد، وابن جرير، وابن المنذر، وابن أبي حاتم، وأبي الشيخ.|4:أخرجه ابن جرير ٩/١٦١، وابن أبي حاتم ٤/١٢٦٥. وفي تفسير مجاهد ص٣١٩: في صورة ملك.|5:تفسير مقاتل بن سليمان ١/٥٥٠. يشير إلى قوله تعالى: <span class="qpc-hafs">﴿وقالُوا مالِ هذا الرسول يَأْكُلُ الطَّعامَ ويَمْشِي فِي الأَسْواقِ لَوْلا أُنْزِلَ إلَيْهِ مَلَكٌ فَيَكُونَ مَعَهُ نَذِيرًا﴾</span> [الفرقان: ٧].|6:عزاه السيوطي إلى أبي الشيخ. وأخرجه ابن جرير ٩/١٦١-١٦٢ بلفظ: لو آتاهم ملك في صورته لماتوا، ثم لم يؤخروا طرفة عين، وابن أبي حاتم ٤/١٢٦٥-١٢٦٦ وفي آخره: <span class="qpc-hafs">﴿ثم لا ينظرون﴾</span> قال: ثم لا يؤمنون. ولعله تصحيف.|7:عزاه السيوطي إلى عبد بن حميد، وابن المنذر، وأبي الشيخ.|8:تفسير البغوي ٣/١٢٩.|9:أخرجه ابن جرير ٩/١٦١. وعلَّقه ابن أبي حاتم ٤/١٢٦٥.|10:أخرجه عبد الرزاق ١/٢٠٤، وابن جرير ٩/١٦١، وابن أبي حاتم ٤/١٢٦٥-١٢٦٦. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وأبي الشيخ.|11:أخرجه ابن أبي حاتم ٤/١٢٦٦.|12:أخرجه ابن جرير ٩/١٦٠. وعلَّقه ابن أبي حاتم ٤/١٢٦٥-١٢٦٦.|13:تفسير مقاتل بن سليمان ١/٥٥٠-٥٥١.