tafsir[8]{c,v,t}:
6,1," مقدمة السورة ٢٤٤١٠- عن ابن عمر، قال: قال رسول الله ﷺ: «نزلَت عليَّ سورةُ الأنعام جُملةً واحدةً، يُشَيِّعُها سبعون ألفَ مَلَكٍ، لهم زَجَلٌ{1} بالتسبيحِ والتحميد»{2}. (٦/٦) ٢٤٤١١- عن أنس، قال: قال رسول الله ﷺ: «نزَلَت سورة الأنعام ومعها مَوكِبٌ مِن الملائكة يَسُدُّ ما بينَ الخافِقَيْن{3}، لهم زَجَلٌ بالتَّسبيح والتقديس، والأرضُ تَرتَجُّ، ورسول الله ﷺ يقولُ: سبحانَ الله العظيم، سبحانَ الله العظيم»{4}. (٦/٧) ٢٤٤١٢- عن أبيِّ بن كعب، قال: قال رسول الله ﷺ: «أُنزِلت عليَّ سورةُ الأنعام جُملةً واحدةً، يُشيِّعُها سبعون ألفَ مَلَكٍ، لهم زَجَلٌ بالتسبيح والتحميد والتكبير والتهليل»{5}. (٦/٧) ٢٤٤١٣- عن عبد الله بن مسعود، قال: نزلت سورة الأنعام يُشَيِّعُها سبعون ألفًا مِن الملائكة{6}. (٦/٦) ٢٤٤١٤- عن علي بن أبي طالب -من طريق أبي عبد الرحمن السُّلَمي- قال: أُنزِل القرآنُ خمسًا خمسًا، ومَن حفِظ خمسًا خمسًا لم يَنسَه، إلا سورةَ الأنعام، فإنها نزلت جُملةً في ألف، يُشَيِّعُها مِن كلِّ سماءٍ سبعون مَلَكًا، حتى أدَّوها إلى النبي ﷺ، ما قُرِئت على عليلٍ إلا شَفاه الله{7}. (٦/٧) ٢٤٤١٥- عن أسماء بنت يزيد، قالت: نزلت سورة الأنعام على النبي ﷺ وهو في مَسِير، في زَجَلٍ من الملائكة، وقد نُظِموا ما بينَ السماء والأرض{6}. (٦/٦) ٢٤٤١٦- عن أسماء بنت يزيد -من طريق شهر بن حوشب- قالت: نزلت سورةُ الأنعام على النبي ﷺ جُملةً واحدةً، وأنا آخِذةٌ بزِمامِ ناقةِ النبي ﷺ، إن كادت مِن ثِقَلِها لَتَكسِرُ عظام الناقة{9}. (٦/٦) ٢٤٤١٧- عن أسماء بنت يزيد -من طريق شَهْر بن حَوْشَب- قالت: نزلت الأنعام ومعها زجَلٌ من الملائكة، قد ملَئُوا ما بين السماء والأرض، وهي مكية، ومنها آيتان مهاجرتان: <q>﴿قل تعالوا أتل ما حرم ربكم عليكم﴾</q> والتي بعدها [١٥١-١٥٢]{10}. (٦/٦) ٢٤٤١٨- عن عبد الله بن عباس -من طريق شهر بن حوشب- قال: أُنزلت سورةُ الأنعام بمكة{11}. (٦/٥) ٢٤٤١٩- عن عبد الله بن عباس -من طريق يوسف بن مهران- قال: نزلت سورةُ الأنعام بمكةَ ليلًا جُملةً، وحولَها سبعون ألفَ مَلكٍ يَجأَرُون بالتسبيح{12}. (٦/٥) ٢٤٤٢٠- عن عبد الله بن عباس -من طريق شهر بن حوشب- قال: أُنزِلت سورة الأنعام جميعًا بمكة، معها مَوكِبٌ مِن الملائكة يُشَيِّعونها، قد طَبَّقوا ما بينَ السماء والأرض، لهم زَجَلٌ بالتسبيح، حتى كادتِ الأرضُ أن تَرتَجَّ مِن زَجَلِهم بالتسبيح ارتجاجًا، فلمّا سمع النبي ﷺ زَجَلَهم بالتسبيحِ رَهِب من ذاك فخرَّ ساجدًا، حتى أُنزِلت عليه{13}. (٦/٥) ٢٤٤٢١- عن عبد الله بن عباس -من طريق أبي عمرو بن العلاء، عن مجاهد- قال: سورة الأنعام نزَلت بمكةَ جُملةً واحدة، فهي مكيةٌ، إلا ثلاثَ آياتٍ منها نزَلت بالمدينة: <q>﴿قل تعالوا أتل﴾</q> إلى تمامِ الآيات الثلاث [١٥١-١٥٣]{14}. (٦/٨) ٢٤٤٢٢- عن عبد الله بن عباس -من طريق خصيف، عن مجاهد-: مكية{15}. (ز) ٢٤٤٢٣- عن عبد الله بن عباس -من طريق عطاء الخراساني-: مكية، ونزلت بعد الحِجْر{16}. (ز) ٢٤٤٢٤- عن أبي جُحَيفةَ وهب بن عبد الله، قال: نزلت الأنعام جميعًا، معها سبعون ألفَ مَلَك، كلُّها مكية، إلا: <q>﴿ولو أننا نزلنا إليهم الملائكة﴾</q> [١١١]، فإنها مدنية{17}. (٦/٨) ٢٤٤٢٥- عن مجاهد بن جبر -من طريق فضيل الرقاشي- قال: نزلت سورة الأنعام كلُّها جُملةً، معها خمسمُائةِ مَلَك يَزِفُّونها، ويَحُفُّونها{18}. (٦/٨) ٢٤٤٢٦- عن مجاهد بن جبر، قال: نزَل جبريلُ مع سبعين ألفَ مَلَك معهم سورة الأنعام، لهم زَجَلٌ مِن التسبيح والتكبير والتهليل والتحميد{19}. (٦/١٣) ٢٤٤٢٧- عن عكرمة مولى ابن عباس= (ز) ٢٤٤٢٨- والحسن البصري -من طريق يزيد النحوي-: مكية{20}. (ز) ٢٤٤٢٩- عن شهرِ بن حوشبٍ -من طريق ليث بن أبي سليم- قال: نزلت الأنعام جُملةً واحدة، معها رَجَزٌ من الملائكة، قد نُظِموا ما بين السماء الدنيا إلى الأرض. قال: وهي مكيةٌ، غيرَ آيتَين: <q>﴿قل تعالوا أتل ما حرم ربكم عليكم﴾</q> والآيةُ التي بعدَها [١٥١-١٥٢]{21}. (٦/٩) ٢٤٤٣٠- عن عطاء، قال: أُنزِلت الأنعام جميعًا، ومعها سبعون ألفَ مَلَك{19}. (٦/٩) ٢٤٤٣١- عن قتادة بن دعامة -من طُرُق-: مكية{23}. (ز) ٢٤٤٣٢- عن محمد ابن شهاب الزهري: مكية، ونزلت بعد الحِجْر{24}. (ز) ٢٤٤٣٣- عن علي بن أبي طلحة: مكية{25}. (ز) ٢٤٤٣٤- عن محمد بن السائب الكلبي، قال: نزَلت الأنعام كلُّها بمكة، إلا آيتَين نزَلتا بالمدينة في رجل من اليهود، وهو الذي قال: <q>﴿ما أنزل الله على بشر من شيء﴾</q> الآية [٩١]{19}. (٦/٩) ٢٤٤٣٥- قال مقاتل بن سليمان: سورة الأنعام مكية كلها، إلا هذه الآيات. نزلت بالمدينة، ونزلت ليلًا، وهي خمس وستون ومائة آية كوفي. والآيات المدنية هي: <q>﴿قُلْ تَعالَوْا أتْلُ ما حَرَّمَ رَبُّكُمْ عَلَيْكُمْ﴾</q> إلى قوله: <q>﴿لَعَلَّكُمْ تَعْقِلُونَ﴾</q> [١٥١] وهي الآيات المحكمات، وقوله: <q>﴿وما قَدَرُوا اللَّهَ حَقَّ قَدْرِهِ﴾</q> إلى آخر الآية [٩١]، وقوله: <q>﴿ومَن أظْلَمُ مِمَّنِ افْتَرى عَلى اللَّهِ كَذِبًا أوْ قالَ أُوحِيَ إلَيَّ﴾</q> نزلت في مسيلمة، <q>﴿ومَن قالَ سَأُنْزِلُ مِثْلَ ما أنْزَلَ اللَّهُ﴾</q> نزلت في عهد عبد الله بن سعد بن أبي سرح، وقوله: <q>﴿ولَوْ تَرى إذِ الظّالِمُونَ فِي غَمَراتِ المَوْتِ﴾</q> [٩٣]، وقوله: <q>﴿والَّذِينَ آتَيْناهُمُ الكِتابَ يَعْلَمُونَ أنَّهُ مُنَزَّلٌ مِن رَبِّكَ بِالحَقِّ﴾</q> [١١٤]، <q>﴿الَّذِينَ آتَيْناهُمُ الكِتابَ يَعْرِفُونَهُ﴾</q> [٢٠]، هذه الآيات مدنيات، وسائرها مكي. نزل بها جبريل ﵇، ومعه سبعون ألف ملك، طبَّقوا ما بين السماء والأرض، لهم زَجَل بالتسبيح والتمجيد والتحميد، حتى كادت الأرض أن تَرْتَجَّ، فقال النبي ﷺ: «سبحان الله العظيم وبحمده». وخرَّ النبي ساجدًا، فيها خصومة مشركي العرب وأهل الكتاب{27}. (ز) ٢٤٤٣٦- عن معمر بن راشد، قال: يُقال: إنّ سورة الأنعام أُنزِلت جُملة واحدة، معها الملائكة ما بين السماء والأرض، لهم زَجَل بالتسبيح{28}. (ز) ٢٤٤٣٧- عن سفيان، قال: نزلت الأنعام كلُّها بمكة، إلا آيتَين نزَلتا بالمدينة في رجلٍ مِن اليهود، وهو الذي قال: <q>﴿ما أنزل الله على بشر من شيء﴾</q>. وهو فِنْحاصُ اليهودي، أو مالكُ بن الصَّيف{19}. (٦/٩) ٢٤٤٣٨- عن عمر بن الخطاب -من طريق عبد الله بن خليفة- قال: الأنعام مِن نَواجِب{30} القرآن{31}. (٦/٩) ٢٤٤٣٩- عن عبد الله بن مسعود، قال: الأنعام مِن نَواجِب القرآن{32}. (٦/٩) <q>﴿ٱلۡحَمۡدُ لِلَّهِ ٱلَّذِی خَلَقَ ٱلسَّمَـٰوَ ٰ⁠تِ وَٱلۡأَرۡضَ وَجَعَلَ ٱلظُّلُمَـٰتِ وَٱلنُّورَۖ ثُمَّ ٱلَّذِینَ كَفَرُوا۟ بِرَبِّهِمۡ یَعۡدِلُونَ ۝١﴾</q> - نزول الآية ٢٤٤٤٠- عن علي بن أبي طالب -من طريق ابن أبزى- أنّه أتاه رجلٌ مِن الخوارج، فقال: <q>﴿الحمد لله الذي خلق السموات والأرض وجعل الظلمات والنور ثم الذين كفروا بربهم يعدلون﴾</q>، أليس كذلك؟ قال: نعم. فانصرف عنه، ثم قال: ارجِع. فرجَع، فقال: أيْ فُلُ{33}، إنما أُنزِلت في أهل الكتاب{34}. (٦/١٢) ٢٤٤٤١- عن عبد الرحمن بن أبزى، أنّه أتاه رجلٌ مِن الخوارج، فقرأ عليه: <q>﴿الحمد لله الذي خلق السماوات والأرض وجعل الظلمات والنور﴾</q> الآية. ثم قال: أليس الذين كفروا بربِّهم يَعدِلون؟ قال: بلى. فانصرَف عنه الرجلُ، فقال له رجلٌ مِن القوم: يا ابن أبزى، إنّ هذا أراد تفسيرَ الآية غيرَ ما تَرى، إنّه رجلٌ مِن الخوارج. قال: رُدُّوه عَلَيَّ. فلما جاء، قال: أتَدرِي في مَن أُنزِلت هذه الآية؟ قال: لا. قال: نزلت في أهل الكتاب، فلا تَضَعها في غير موضعها{35}٢٢١٩. (٦/١٢) ٢٢١٩ انتَقَد ابنُ عطية ٣/٣١١ قول ابن أبزى بنزولها في أهل الكتاب بقوله: «وقول ابن أبزى بعيد». ولم يذكر مستندًا. ٢٤٤٤٢- عن مجاهد بن جبر -من طريق خصيف- قال: نزلت هذه الآية في الزنادقة: <q>﴿الحمد لله الذي خلق السماوات والأرض وجعل الظلمات والنور﴾</q>. قال: قالوا: إنّ الله لم يَخلُق الظلمة، ولا الخنافِس، ولا العقارب، ولا شيئًا قبيحًا، وإنما خلق النور، وكلَّ شيءٍ حسن. فأُنزِلت فيهم هذه الآية{36}. (٦/١٣) ٢٤٤٤٣- قال مقاتل بن سليمان: فيها خصومة مشركي العرب وأهل الكتاب، وذلك أن قريشًا قالوا للنبي ﷺ: مَن ربك؟ فقال: «ربي الأحد، الصمد، الذي لم يلد، ولم يولد، ولم يكن له كفوًا أحد». فقالوا: أنت كذّاب، ما اختصك الله بشيء، وما أنت عليه بأكرم مِنّا. فأنزل الله ﷿: <q>﴿الحَمْدُ لِلَّهِ الَّذِي خَلَقَ السَّماواتِ والأَرْضَ﴾</q>. فحمد نفسه، ودلَّ بصنعه على توحيده{37}. (ز) <q>﴿ٱلۡحَمۡدُ لِلَّهِ﴾</q> - تفسير ٢٤٤٤٤- قال عبد الله بن عباس: افتتح الله الخلق بالحمد، فقال: <q>﴿الحمد لله الذي خلق السموات والأرض﴾</q>. وختمه بالحمد، فقال: <q>﴿وقضي بينهم بالحق﴾</q> أي: بين الخلائق، <q>﴿وقيل الحمد لله رب العالمين﴾</q> [الزمر:٧٥]{38}. (ز) ٢٤٤٤٥- عن الضحاك بن مزاحم -من طريق يحيى بن عبد الرحمن- قال: الحمد لله رداء الله الرحمن تبارك وتعالى{39}. (ز) ٢٤٤٤٦- عن قتادة بن دعامة: <q>﴿الحمد لله الذي خلق السماوات والأرض﴾</q>، حمِد نفسَه؛ فأعظَم خلقَه{19}. (٦/١٢) ٢٤٤٤٧- قال مقاتل بن سليمان: <q>﴿الحَمْدُ لِلَّهِ﴾</q>، فحمد نفسه، ودلَّ بصنعه على توحيده{37}. (ز) <q>﴿ٱلَّذِی خَلَقَ ٱلسَّمَـٰوَ ٰ⁠تِ وَٱلۡأَرۡضَ﴾</q> - تفسير ٢٤٤٤٨- قال وهب بن منبه: أول ما خلق الله مكانًا مظلمًا، ثم خلق جوهرة، فأضاءت ذلك المكان، ثم نظر إلى الجوهرة نظر الهيبة فصارت ماء، فارتفع بخارها وزبدها، فخلق من البخار السماوات، ومن الزبد الأرضين{42}. (ز) ٢٤٤٤٩- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿الحمد لله الذي خلق السماوات والأرض وجعل الظلمات والنور﴾</q>، قال: خلَق الله السماوات قبل الأرض{43}. (٦/١٤) ٢٤٤٥٠- قال مقاتل بن سليمان: <q>﴿الذي خلق السماوات والأرض﴾</q>، لم يخلقهما باطلًا، خلقهما لأمر هو كائن{44}. (ز) <q>﴿وَجَعَلَ﴾</q> - تفسير ٢٤٤٥١- عن أبي رَوْق عطية بن الحارث الهمداني -من طريق بشر بن عمارة- قال: كلُّ شيءٍ في القرآن <q>﴿جَعَل﴾</q> فهو: خَلَق{45}. (٦/١٣) <q>﴿ٱلظُّلُمَـٰتِ وَٱلنُّورَۖ﴾</q> - تفسير ٢٤٤٥٢- عن عبد الله بن عباس: <q>﴿وجعل الظلمات والنور﴾</q>، قال: الكفر، والإيمان{19}. (٦/١٤) ٢٤٤٥٣- قال الحسن البصري: <q>﴿وجعل الظلمات والنور﴾</q>، يعني: الكفر، والإيمان{47}٢٢٢٠. (ز) ٢٢٢٠ اختُلِف في المراد بقوله: <q>﴿الظلمات والنور﴾</q>، فقال قوم: هما الليل، والنهار. وقال آخرون: الكفر، والإيمان. وانتقد ابنُ عطية (٣/٣١٠) القول الثاني مستندًا لمخالفته للغة العرب، فقال: «وهذا غيرُ جيِّد؛ لأنه إخراج لفظ بيِّن في اللغة عن ظاهره الحقيقي إلى باطن لغير ضرورة، وهذا هو طريق اللغز الذي بَرِئ القرآنُ منه». ٢٤٤٥٤- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿الحمد لله الذي خلق السماوات والأرض وجعل الظلمات والنور﴾</q>، قال: خلَق اللهُ السماوات قبل الأرض، والظلمةَ قبل النور، والجنةَ قبل النار{43}. (٦/١٤) ٢٤٤٥٥- قال قتادة بن دعامة: <q>﴿وجعل الظلمات والنور﴾</q>، يعني: الجنة، والنار{47}. (ز) ٢٤٤٥٦- عن إسماعيل السُّدِّيّ -من طريق أسباط- في قوله: <q>﴿وجعل الظلمات والنور﴾</q>، قال: الظلماتُ ظلمةُ الليل، والنورُ نورُ النهار{50}. (٦/١٤) ٢٤٤٥٧- عن إسماعيل السُّدِّيّ -من طريق أسباط- قوله: <q>﴿وجعل الظلمات والنور﴾</q>، قال: خلق الظلمة قبل النور{51}. (ز) ٢٤٤٥٨- قال مقاتل بن سليمان: <q>﴿وجعل الظلمات والنور﴾</q>، يعني: الليل، والنهار{44}. (ز) <q>﴿ثُمَّ ٱلَّذِینَ كَفَرُوا۟ بِرَبِّهِمۡ یَعۡدِلُونَ ۝١﴾</q> - تفسير ٢٤٤٥٩- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿ثم الذين كفروا بربهم يعدلون﴾</q>، قال: يُشرِكون{53}. (٦/١٤) ٢٤٤٦٠- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿ثم الذين كفروا بربهم يعدلون﴾</q>، قال: كذَب العادِلون بالله، فهؤلاء أهلُ الشرك{43}. (٦/١٤) ٢٤٤٦١- عن قتادة بن دعامة -من طريق سعيد- <q>﴿ثم الذين كفروا بربهم يعدلون﴾</q>، قال: هؤلاء أهل صُراحية{55}{56}. (ز) ٢٤٤٦٢- عن إسماعيل السُّدِّيّ -من طريق أسباط- في قوله: <q>﴿ثم الذين كفروا بربهم يعدلون﴾</q>، قال: هم المشركون{57}. (٦/١٤) ٢٤٤٦٣- قال مقاتل بن سليمان: ثم رجع إلى أهل مكة، فقال: <q>﴿ثم الذين كفروا﴾</q> من أهل مكة <q>﴿بربهم يعدلون﴾</q> يعني: يُشرِكون{44}. (ز) ٢٤٤٦٤- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿ثم الذين كفروا بربهم يعدلون﴾</q>، قال: الآلهةُ التي عبَدوها، عدَلوها بالله تعالى، وليس لله عِدْلٌ، ولا نِدٌّ، وليس معه آلهةٌ، ولا اتخَذ صاحبةً ولا ولدًا{59}٢٢٢١. (٦/١٤) ٢٢٢١ اختلف المفسرون فيمن عُنِي بهذه الآية على قولين: الأول: أهل الكتاب -كما مر في نزول الآية-. والثاني: المشركون من عبدة الأوثان. وجمع ابنُ جرير (٩/١٤٩) بين القولين مُبَيِّنًا اندراجهما تحت عموم الآية، فقال: «وأَوْلى الأقوال في ذلك بالصواب عندي أن يُقال: إنّ الله تعالى أخبر أنّ الذين كفروا بربهم يعدلون، فعمَّ بذلك جميع الكفار، ولم يخصص منهم بعضًا دون بعض، فجميعهم داخلون في ذلك: يهودهم، ونصاراهم، ومجوسهم، وعبدة الأوثان منهم، ومن غيرهم من سائر أصناف الكفر». وبنحوه جمع ابنُ عطية (٣/٣١١). وانتقد مَن خصَّ نزول الآية بقوم، فقال: «ومَن خَصَّص من المفسرين في ذلك بعضًا دون بعض فلم يُصِب». ثم قال: «إلا أن السابق من حال النبي ﷺ أنّ الإشارة إلى عبدة الأوثان من العرب لمجاورتهم له». <q>﴿ثُمَّ ٱلَّذِینَ كَفَرُوا۟ بِرَبِّهِمۡ یَعۡدِلُونَ ۝١﴾</q> - آثار متعلقة بالآية ٢٤٤٦٥- عن عبد الله بن عمرو، عن النبي ﷺ أنّه قال: «إنّ الله ﷿ خلق خلقه في ظلمة، ثم ألقى عليهم من نوره، فمَن أصابه يومئذ من ذلك النور اهتدى، ومَن أخطأه ضلَّ»{60}. (ز) ٢٤٤٦٦- عن كعب الأحبار -من طريق عبد الله بن رباح- قال: فُتِحتِ التوراة بـ<q>﴿الحمد لله الذي خلق السماوات والأرض وجعل الظلمات والنور ثم الذين كفروا بربهم يعدلون﴾</q>، وخُتِمت بـ<q>﴿الحمد لله الذي لم يتخذ ولدا﴾</q> إلى قوله: <q>﴿وكبره تكبيرا﴾</q> [الإسراء:١١١]{61}. (٦/١١) ٢٤٤٦٧- وعن وهب بن منبه، نحوه{62}. (ز) ٢٤٤٦٨- عن مجاهد بن جبر، قال: <q>﴿الحمد لله الذي خلق السموات والأرض﴾</q>، فكان فيه ردٌّ على ثلاثةِ أديانٍ منهم، فكان فيه رَدٌّ على الدّهرِيَّة أنّ الأشياء كلَّها دائمةٌ. ثم قال: <q>﴿وجعل الظلمات والنور﴾</q>، فكان فيه رَدٌّ على المجوس الذين زعَموا أنّ الظُّلمةَ والنورَ هما المُدَبِّران. وقال: <q>﴿ثم الذين كفروا بربهم يعدلون﴾</q>، فكان فيه رَدٌّ على مُشركي العرب، ومَن دعا دونَ الله إلهًا{19}. (٦/١٣) ",footnotes:1:أي: صوت رفيع عال. النهاية (زجل).أخرجه الطبراني في الصغير ١/١٤٥ (٢٢٠)، وأبو نعيم في الحلية ٣/٤٤، من طريق إسماعيل بن عمرو، عن يوسف بن عطية الصفار، عن ابن عون، عن نافع، عن ابن عمر به. قال الطبراني: «لم يروه عن ابن عون إلا يوسف بن عطية، تفرد به إسماعيل بن عمرو». وقال أبو نعيم: «غريب من حديث ابن عون». وقال الهيثمي في المجمع ٧/٢٠ (١٠٩٩١): «فيه يوسف بن عطية الصفار، وهو ضعيف». وقال السيوطي في الإتقان في علوم القرآن ١/١٣٦: «وأخرج الطبراني من طريق يوسف بن عطية الصفار، وهو متروك ...». وقال في تحفة الأبرار بنكت الأذكار ص٧٣: «قال الحافظ: سند ضعيف». وقال الشوكاني في تحفة الذاكرين ص٤٠٤: «في إسناده عطية الصفار، وهو ضعيف».الخافقين: هما طرفا السماء والأرض. وقيل: المغرب والمشرق. النهاية (خفق).أخرجه الطبراني في الأوسط ٦/٢٩٢ (٦٤٤٧)، والبيهقي في الشعب ٤/٧٩ (٢٢١٠)، من طريق أحمد بن محمد بن أبي بكر السالمي، عن محمد بن إسماعيل بن أبي فديك، عن عمر بن طلحة، عن أبي سهيل نافع بن مالك، عن أنس بن مالك به. قال الهيثمي في المجمع ٧/٢٠ (١٠٩٩٢): «رواه الطبراني، عن شيخه محمد بن عبد الله بن عرس، عن أحمد بن محمد بن أبي بكر السالمي، ولم أعرفهما، وبقية رجاله ثقات». وشيخ الطبراني هنا قد توبع، وقال السيوطي في الإتقان في علوم القرآن ١/١٣٨: «سند ضعيف». وقال في تحفة الأبرار بنكت الأذكار ص٧٣: «قال الحافظ: وابن مردويه عن أنس بن مالك بسند حسن». وقال السفيري في شرح البخاري ١/٢١٤: «سند ضعيف». وقال الشوكاني في تحفة الذاكرين ص٤٠٤: «في إسناده رجلان مجهولان». وقال الألباني في الضعيفة ١٢/٢٧٢ (٥٦٢٧): «منكر».أخرجه الواحدي في التفسير الوسيط ٢/٢٥٠ (٣٢١)، من طريق سلام بن سليم المدائني، عن هارون بن كثير، عن زيد بن أسلم، عن أبيه، عن أبي أمامة، عن أبي بن كعب به. وأورده الثعلبي ٤/١٣١ وزاد في آخره: «... فمن قرأ سورة الأنعام صلى عليه أولئك السبعون ألف ملك بعدد كل آية من الأنعام يومًا وليلة». قال ابن الصلاح في فتاويه ١/٢٤٩: «في إسناده ضعف، ولم نر له إسنادًا صحيحًا، وقد روي ما يخالفه، فروي أنها لم تنزل جملة واحدة، بل نزلت آيات منها بالمدينة...». وقال ابن تيمية في جامع المسائل (جمع: محمد عزير شمس) ٤/٣٥٤: «موضوع». وقال السيوطي في الإتقان في علوم القرآن ١/١٣٧: «فهذه شواهد يقوي بعضها بعضًا». وقال في تحفة الأبرار بنكت الأذكار ص٧٢-٧٣: «قال الحافظ: ورد أنها نزلت جملة واحدة في عدة أحاديث، فأخرجه أبو عبيد في فضائله، وابن المنذر، والطبراني عن ابن عباس بسند حسن، وأخرجه الطبراني، وابن مردويه، وأبو نعيم في الحلية بسند ضعيف عن ابن عمر، وأخرجه ابن مردويه عن ابن مسعود بسند ضعيف، وأخرجه الدارقطني في الأفراد، والطبراني في الأوسط، وابن مردويه عن أنس بن مالك بسند حسن، وأخرجه إسحاق بن راهويه في مسنده، والطبراني عن أسماء بنت يزيد بسند حسن، وأخرجه الحاكم في المستدرك عن جابر وقال: صحيح على شرط مسلم. وتعقبه الذهبي، فقال: أظن الحديث موضوعًا. وليس كما ظنَّ لما قدمته من شواهده. وفي الباب غير هذا من الواهيات ضعفًا وانقطاعًا، وفيما ذكرته كفاية ودلالة على أن لذلك أصلًا. انتهى». وقال المناوي في الفتح السماوي ٢/٦٢٩-٦٣٠ (٥١١): «أخرجه الثعلبي من حديث أبي بن كعب، قال الحافظ ابن حجر: فيه أبو عصمة، وهو متهم بالكذب، والجملة الأولى عند الطبراني في الصغير في ترجمة إبراهيم بن نائلة من حديث ابن عمر، وفيه يوسف بن عطية، وهو ضعيف».عزاه السيوطي إلى ابن مردويه.أخرجه البيهقي في شعب الإيمان (٢٤٣٥)، والخطيب في تاريخه ٧/٢٧١-٢٧٢.عزاه السيوطي إلى ابن مردويه.أخرجه الطبراني ٢٤/١٧٨ (٤٤٩، ٤٥٠). وعزاه السيوطي إلى ابن مردويه.عزاه السيوطي إلى الخِلَعِيُّ في الخِلَعيّات.أخرجه ابن الضريس في فضائل القرآن (١٨)، والبيهقي في الدلائل ٧/١٤٢-١٤٤ من طريق مجاهد. وعزاه السيوطي إلى أبي الشيخ، وابن مردويه.أخرجه أبو عبيد في فضائل القرآن ص١٢٩، وابن الضريس في فضائل القرآن (١٩٦)، والطبراني (١٢٩٣٠). وعزاه السيوطي إلى ابن المنذر، وابن مردويه.أخرجه ابن الضريس في فضائل القرآن (٢٠١).أخرجه النحاس في ناسخه ص٤١٥.أخرجه البيهقي في دلائل النبوة ٧/١٤٣-١٤٤.أخرجه ابن الضريس في فضائل القرآن ١/٣٣-٣٥.عزاه السيوطي إلى ابن المنذر.أخرجه عبد الرزاق في تفسيره ١/٢٠٣. وعزاه السيوطي إلى الفريابي، وعبد بن حميد، وابن المنذر، وأبي الشيخ.عزاه السيوطي إلى أبي الشيخ.أخرجه البيهقي في دلائل النبوة ٧/١٤٢-١٤٣.أخرجه إسحاق بن راهويه في مسنده (١٦). وعزاه السيوطي إلى الفريابي، وعبد بن حميد. كما أخرجه ابن أبي شيبة في مصنفه (ت: محمد عوامة) ١٥/٥١٤ (٣٠٧٧٢) مختصرًا دون ذكر الآيات المستثناة.عزاه السيوطي إلى أبي الشيخ.أخرجه الحارث المحاسبي في فهم القرآن ص٣٩٥-٣٩٦ من طريق سعيد، وأبو بكر ابن الأنباري -كما في الإتقان في علوم القرآن ١/٥٧- من طريق همام.تنزيل القرآن ص٣٧-٤٢.أخرجه أبو عبيد في فضائله (ت: الخياطي) ٢/٢٠٠.عزاه السيوطي إلى أبي الشيخ.تفسير مقاتل بن سليمان ١/٥٤٧-٥٤٨.أخرجه عبد الرزاق ٢/٢٠٣.عزاه السيوطي إلى أبي الشيخ.نواجب القرآن: أي: أفاضل سُوَره. النهاية (نجب).أخرجه أبو عبيد في فضائل القرآن ص١٢٩، والدارمي في مسنده ٢/٤٥٣. وعزاه السيوطي إلى محمد بن نصر في كتاب الصلاة، وأبي الشيخ.عزاه السيوطي إلى محمد بن نصر. وقد أورد السيوطي ٦/٨-١١ آثارًا أخرى في فضل السورة.معناه: يا فلان. النهاية (فلل).أخرجه ابن أبي حاتم ٤/١٢٦٠ (٧٠٨٦)، من طريق علي بن الحسين، عن حفص بن عمر، عن عامر بن إبراهيم، عن يعقوب القمي، عن جعفر، عن ابن أبزى، عن علي به.أخرجه ابن جرير ٩/١٤٨، وابن أبي حاتم ٤/١٢٦٠ (٧٠٨٧)، وأبو الشيخ في طبقات المحدثين ١/٣٥٣ مرسلًا.أخرجه ابن أبي حاتم ٤/١٢٥٩. وعزاه السيوطي إلى أبي الشيخ.تفسير مقاتل بن سليمان ١/٥٤٨-٥٤٩.تفسير البغوي ٣/١٢٥.أخرجه ابن أبي حاتم ٤/١٢٥٨.عزاه السيوطي إلى أبي الشيخ.تفسير مقاتل بن سليمان ١/٥٤٨-٥٤٩.تفسير الثعلبي ٤/١٣٣.أخرجه ابن جرير ٩/١٤٥، وابن أبي حاتم ٤/١٢٥٩. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وأبي الشيخ.تفسير مقاتل بن سليمان ١/٥٤٩.أخرجه ابن جرير ١/٤٧٥.عزاه السيوطي إلى أبي الشيخ.تفسير البغوي ٣/١٢٦.أخرجه ابن جرير ٩/١٤٥، وابن أبي حاتم ٤/١٢٥٩. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وأبي الشيخ.تفسير البغوي ٣/١٢٦.أخرجه ابن جرير ٩/١٤٥، وابن أبي حاتم ٤/١٢٥٩-١٢٦٠.أخرجه ابن أبي حاتم ٤/١٢٦٠.تفسير مقاتل بن سليمان ١/٥٤٩.تفسير مجاهد ص٣١٩، وأخرجه ابن جرير ٩/١٤٨، وابن أبي حاتم ٤/١٢٦٠. وعزاه السيوطي إلى ابن أبي شيبة، وعبد بن حميد، وابن المنذر، وأبي الشيخ.أخرجه ابن جرير ٩/١٤٥، وابن أبي حاتم ٤/١٢٥٩. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وأبي الشيخ.صراحة وصراحية: أي: خالصة. لسان العرب (صرح).أخرجه ابن جرير ٩/١٤٨.أخرجه ابن جرير ٩/١٤٩. وعلَّقه ابن أبي حاتم ٤/١٢٥٩-١٢٦٠ في معنى قوله: <q>﴿ثم الذين كفروا بربهم يعدلون﴾</q>.تفسير مقاتل بن سليمان ١/٥٤٩.أخرجه ابن جرير ٩/١٤٩، وابن أبي حاتم ٤/١٢٦٠ من طريق أصبغ بن الفرج.أخرجه أحمد ١١/٢١٩-٢٢٠ (٦٦٤٤)، والترمذي ٤/٥٨٧ (٢٨٣٣)، والحاكم ١/٨٤ (٨٣)، وابن أبي حاتم -كما في تفسير ابن كثير ٦/٥٣٥-، من طريق عبد الله بن الديلمي، عن عبد الله بن عمرو به. قال الترمذي: «هذا حديث حسن». وقال الحاكم: «هذا حديث صحيح، قد تداوله الأئمة، وقد احتجا بجميع رواته، ثم لم يخرجاه، ولا أعلم له علة». وقال الذهبي في التلخيص: «على شرطهما، ولا علة له». وقال البوصيري في إتحاف الخيرة ١/١٦٦ (١٨٧): «سند صحيح». وقال الهيثمي في المجمع ٧/١٩٣-١٩٤ (١١٨١٢، ١١٨١٣): «رواه أحمد بإسنادين، والبزار، والطبراني، ورجال أحد إسنادي أحمد ثقات». وقال الألباني في الصحيحة ٣/٦٣-٦٤ (١٠٧٦): «إسناده صحيح».أخرجه ابن الضريس في فضائل القرآن (١٩٧)، وابن جرير ٩/١٤٧ بلفظ: وخاتمة التوراة خاتمة هود. وعزاه السيوطي إلى ابن المنذر، وأبي الشيخ.تفسير الثعلبي ٤/١٣٤.عزاه السيوطي إلى أبي الشيخ.
6,2," <q>﴿هُوَ ٱلَّذِی خَلَقَكُم مِّن طِینࣲ﴾</q> - تفسير ٢٤٤٦٩- عن أبي هريرة، عن النبي ﷺ، قال: «إنّ الله خلق آدم من تراب؛ جعله طينًا، ثم تركه حتى كان حمأً مسنونًا خلقه وصوره، ثم تركه حتى إذا كان صلصالًا كالفخار، فكان إبليس يمُرُّ به، فيقول: خُلِقْت لأمر عظيم. ثم نفخ الله فيه روحه»{1}. (ز) ٢٤٤٧٠- عن عبد الله بن عباس -من طريق علي بن أبي طلحة- <q>﴿هو الذي خلقكم من طين﴾</q>، يعني: آدم{2}. (٦/١٥) ٢٤٤٧١- عن مجاهد بن جبر -من طريق ابن أبي نجيح- <q>﴿هو الذي خلقكم من طين﴾</q>، قال: هو آدم{3}. (ز) ٢٤٤٧٢- عن الضحاك بن مزاحم -من طريق عبيد بن سليمان- قال: خُلِق آدم من طين، وخُلِق الناس من سلالة من ماء مهين{3}. (ز) ٢٤٤٧٣- عن قتادة بن دعامة، في قوله: <q>﴿هو الذي خلقكم من طين﴾</q>، قال: هذا بَدْءُ الخلق، خُلِق آدمُ من طين، ثم جُعِل نَسلُه مِن سلالة من ماء مَهِين{5}. (٦/١٦) ٢٤٤٧٤- عن إسماعيل السُّدِّيّ -من طريق أسباط-: أمّا <q>﴿خلقكم من طين﴾</q> فآدم{3}. (ز) ٢٤٤٧٥- قال إسماعيل السُّدِّيّ: بعث الله جبريل إلى الأرض ليأتيه بطائفة منها، فقالت الأرض: إني أعوذ بالله منك أن تنقص مني. فرجع ولم يأخذ، وقال: يا ربِّ، إنها عاذت بك. فبعث ميكائيل، فاستعاذت، فرجع، فبعث ملك الموت، فعاذت منه بالله، فقال: وأنا أعوذ بالله أن أخالف أمره. فأخذ من وجه الأرض، وخلط التربة الحمراء والسوداء والبيضاء؛ فلذلك اختلفت ألوان بني آدم، ثم عجنها بالماء العذب والمالح والمر؛ فلذلك اختلفت أخلاقهم، فقال الله ﷿ لملك الموت: رحم جبرئيل وميكائيل الأرض، ولم ترحمها، لا جرم أجعل أرواح مَن أخلق من هذا الطين بيدك{7}. (ز) ٢٤٤٧٦- قال مقاتل بن سليمان: <q>﴿هو الذي خلقكم من طين﴾</q>، يعني: آدم ﵇؛ لأنكم من ذريته{8}. (ز) ٢٤٤٧٧- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿هو الذي خلقكم من طين ثم قضى أجلا وأجل مسمى عنده ثم أنتم تمترون﴾</q>، قال: خلق آدم من طين، ثم خلقنا من آدم حين أخذنا من ظهره، ثم أخذ الأجل والميثاق في أجل واحد مسمًى في هذه الحياة الدنيا{9}٢٢٢٢. (ز) ٢٢٢٢ لم يذكر ابنُ جرير (٩/١٤٩-١٥٠) غير هذا القول وما في معناه. وساق ابنُ عطية (٣/٣١٢) هذا القول، ثم نقل عن فرقة أنها قالت: بل المعنى: أنّ النطفة التي يخلق منها الإنسان أصلها من طين، ثم يقلبها الله نطفة. ثم رجَّح القول الأول، وانتقد القول الثاني مستندًا إلى دلالة القرآن، والسنة، فقال: «والقول الأول ألْيَق بالشريعة؛ لأن القول الثاني إنما يترتب على قول مَن يقول بأنّ الطين يرجع بعد التولد والاستحالات الكثيرة نطفة، وذلك مردود عند الأصوليين». <q>﴿ثُمَّ قَضَىٰۤ أَجَلࣰاۖ وَأَجَلࣱ مُّسَمًّى عِندَهُۥۖ﴾</q> - تفسير ٢٤٤٧٨- عن عبد الله بن عباس -من طريق سعيد بن جبير- في قوله: <q>﴿ثم قضى أجلا﴾</q> قال: أجلُ الدنيا، وفي لفظٍ: أجلُ موتِه، <q>﴿وأجل مسمى عنده﴾</q> قال: الآخرة، لا يَعلمُه إلا الله{10}. (٦/١٥) ٢٤٤٧٩- عن عبد الله بن عباس -من طريق عطية العوفي- <q>﴿قضى أجلا﴾</q>، قال: هو النومُ، يقبض فيه الروح، ثم يرجعُ إلى صاحبه حين اليقظة، <q>﴿وأجل مسمى عنده﴾</q> قال: هو أجلُ موتِ الإنسان{11}٢٢٢٣. (٦/١٥) ٢٢٢٣ قال ابنُ كثير (٣/٢٣٥): «وهذا قول غريب». ٢٤٤٨٠- عن عبد الله بن عباس -من طريق علي بن أبي طلحة- <q>﴿ثم قضى أجلا﴾</q> يعني: أجلَ الموت، <q>﴿وأجل مسمى عنده﴾</q>: أجلُ الساعة، والوقوف عند الله{12}. (٦/١٥) ٢٤٤٨١- عن سعيد بن جبير، نحو ذلك{13}. (ز) ٢٤٤٨٢- عن عطية بن سعد العوفي، نحو ذلك{14}. (ز) ٢٤٤٨٣- عن زيد بن أسلم، نحو شطره الأول{14}. (ز) ٢٤٤٨٤- عن الربيع بن أنس، نحو شطره الثاني{14}. (ز) ٢٤٤٨٥- عن مجاهد بن جبر، في قوله: <q>﴿ثم قضى أجلا﴾</q> قال: أجلُ الدنيا الموت، <q>﴿وأجل مسمى عنده﴾</q> قال: الآخرةُ؛ البعث{17}. (٦/١٦) ٢٤٤٨٦- عن مجاهد بن جبر -من طريق ابن أبي نجيح- <q>﴿أجَلًا﴾</q> قال: الآخرة عنده، <q>﴿وأَجَلٌ مُسَمًّى﴾</q> قال: الدنيا{18}. (ز) ٢٤٤٨٧- عن خالد بن معدان، في قوله: <q>﴿وأجل مسمى عنده﴾</q>، قال: أجل البعث{19}. (ز) ٢٤٤٨٨- عن عكرمة مولى ابن عباس -من طريق جابر- <q>﴿ثم قضى أجلا﴾</q> قال: قضى أجل الدنيا، <q>﴿وأجل مسمى عنده﴾</q> قال: هو أجل البعث{20}. (ز) ٢٤٤٨٩- عن الضحاك بن مزاحم -من طريق عبيد بن سليمان- <q>﴿قضى أجلا وأجل مسمى عنده﴾</q> قال: قضى أجل الموت، وكل نفس أجلها الموت. قال: ولن يؤخر الله نفسًا إذا جاء أجلها، <q>﴿وأجل مسمى عنده﴾</q> يعني: أجل الساعة ذهاب الدنيا، والإفضاء إلى الله{21}. (ز) ٢٤٤٩٠- قال الضحاك بن مزاحم، في قوله ﷿: <q>﴿ثم قضى أجلا وأجل مسمى عنده﴾</q>: الأجل الأول من الولادة إلى الموت، والأجل الثاني من الموت إلى البعث، وهو البرزخ{22}٢٢٢٤. (ز) ٢٢٢٤ علَّق ابنُ كثير (٦/٩) على هذا القول الذي قاله الحسن من طريق أبي بكر الهذلي، وقتادة من طريق سعيد، والضحاك، بقوله: «هو يرجع إلى ما تقدم [يعني: إلى مَن قال بأن <q>﴿أجلا﴾</q> الدنيا، و<q>﴿أجل مسمى﴾</q> الآخرة]، وهو تقدير الأجل الخاص، وهو عمر كل إنسان، وتقدير الأجل العام، وهو عمر الدنيا بكمالها، ثم انتهائها وانقضائها وزوالها، وانتقالها والمصير إلى الدار الآخرة». وعلَّق عليه ابنُ عطية (٣/٣١٢) بقوله: «ووصفه بمسمًى عنده لأنّه استأثر بعلم وقت القيامة». ٢٤٤٩١- عن الحسن البصري -من طريق أبي بكر الهذلي- في قوله: <q>﴿قضى أجلا﴾</q> قال: ما بين أن يخلق إلى أن يموت، <q>﴿وأجل مسمى عنده﴾</q> قال: ما بين أن يموت إلى أن يبعث{23}. (ز) ٢٤٤٩٢- عن قتادة بن دعامة -من طريق سعيد- قوله: <q>﴿ثم قضى أجلا وأجل مسمى عنده﴾</q>، كان يقول: أجل حياتك إلى أن تموت وأجل موتك إلى أن تبعث، فأنت بين أجلين من الله تعالى{24}. (٦/١٦) ٢٤٤٩٣- عن قتادة بن دعامة= (ز) ٢٤٤٩٤- والحسن البصري -من طريق مَعْمَر- في قوله: <q>﴿قضى أجلا﴾</q> قالا: قضى أجلَ الدنيا منذُ خُلِقتَ إلى أن تموت، <q>﴿وأجل مسمى عنده﴾</q> قال: يوم القيامة{25}. (٦/١٦) ٢٤٤٩٥- عن إسماعيل السُّدِّيّ -من طريق أسباط- <q>﴿قضى أجلا﴾</q>، قال: أما <q>﴿قضى أجلا﴾</q> فأجل الموت، <q>﴿وأجل مسمى عنده﴾</q> يوم القيامة{26}. (ز) ٢٤٤٩٦- عن عطاء الخراساني -من طريق ابنه عثمان- أمّا قوله: <q>﴿قضى أجلا﴾</q> فيقال: ما خلق في ستة أيام{27}. (ز) ٢٤٤٩٧- قال مقاتل بن سليمان: <q>﴿ثم قضى أجلا﴾</q> يعني: أجل ابن آدم من يوم ولد إلى أن يموت، <q>﴿وأجل مسمى عنده﴾</q> يعني: البرزخ منذ يوم ولد إلى يوم يموت، إلى يوم القيامة{8}. (ز) ٢٤٤٩٨- عن يونس بن يزيد الأيليِّ: <q>﴿قضى أجلا﴾</q> قال: ما خَلَق في ستة أيام، <q>﴿وأجل مسمى عنده﴾</q> قال: ما كان بعدَ ذلك إلى يوم القيامة{29}. (٦/١٦) ٢٤٤٩٩- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿هو الذي خلقكم من طين ثم قضى أجلا وأجل مسمى عنده ثم أنتم تمترون﴾</q>، قال: خلق آدم من طين، ثم خلقنا من آدم، أخذنا من ظهره، ثم أخذ الأجل والميثاق في أجل واحد مسمًى في هذه الحياة الدنيا{26}٢٢٢٥. (ز) ٢٢٢٥ اختلف المفسرون في هذين الأجلين على خمسة أقوال: الأول: <q>﴿أجَلًا﴾</q> الدنيا، <q>﴿أجَلٌ مُسَمًّى﴾</q> الآخرة. الثاني: عكس هذا القول. الثالث: <q>﴿أجَلًا﴾</q> أجل الإنسان من لدن ولادته إلى موته، والأجل المسمى عنده من وقت موته إلى حشره. الرابع: <q>﴿أجَلًا﴾</q> وفاة الإنسان بالنوم، و<q>﴿أجَلٌ مُسَمًّى﴾</q> وفاته بالموت. الخامس: الأجل الأول هو في وقت أخذ الميثاق على بني آدم حين استخرجهم من ظهر آدم، وبقي أجل واحد مسمًى في هذه الحياة الدنيا. وذكر ابنُ عطية (٣/٣١٢) أنّ المهدوي حكى عن فرقتين قولين آخرين: الأول: أنّ <q>﴿أجلا﴾</q> ما عرف الناس من آجال الأهِلَّة والسنين والكوائن، و<q>﴿أجل مسمى﴾</q> قيام الساعة. الثاني: أنّ <q>﴿أجلا﴾</q> ما عرفناه من أنّه لا نبي بعد محمد ﷺ، و<q>﴿أجل مسمى﴾</q> الآخرة. ورجَّح ابنُ جرير (٩/١٥٤) القول الأول الذي قاله ابن عباس، وقتادة، والحسن، ومجاهد، وعكرمة، والسدي، مستندًا إلى ظاهر الآية، والنظائر، فقال: «لأنّه تعالى نبَّه خلقه على موضع حجته عليهم من أنفسهم، فقال لهم: أيها الناس، إنّ الذي يعدل به كفاركم الآلهة والأنداد هو الذي خلقكم فابتدأكم وأنشأكم من طين، فجعلكم صورًا أجسامًا أحياء بعد إذ كنتم طينًا جمادًا، ثم قضى آجال حياتكم لفنائكم ومماتكم، ليعيدكم ترابًا وطينًا كالذي كنتم قبل أن ينشئكم ويخلقكم. <q>﴿وأجل مسمى عنده﴾</q> لإعادتكم أحياءً وأجسامًا كالذي كنتم قبل مماتكم. وذلك نظير قوله: <q>﴿كيف تكفرون بالله وكنتم أمواتا فأحياكم ثم يميتكم ثم يحييكم ثم إليه ترجعون﴾</q> [البقرة:٢٨]». ووجَّهه ابنُ كثير (٦/٩) بقوله: «وكأنّه مأخوذ من قوله تعالى بعد هذا: <q>﴿وهو الذي يتوفاكم بالليل ويعلم ما جرحتم بالنهار ثم يبعثكم فيه ليقضى أجل مسمى ثم إليه مرجعكم﴾</q> [الأنعام:٦٠]». وعلَّق ابنُ عطية (٣/٣١٢) بعد ذكره لهذه الأقوال بقوله: «وينبغي أن تُتَأمَّل لفظة <q>﴿قَضى﴾</q> في هذه الآية؛ فإنها تحتمل معنيين، فإن جُعلت بمعنى: قدَّر وكتب ورجعت إلى سابق علمه وقدره، فيقول: إن ذلك ولا بد قبل خلقه آدم من طين، وتخرج <q>﴿ثم﴾</q> من معهودها في ترتيب زمني وقوع القصتين، ويبقى لها ترتيب زمني الإخبار عنه، كأنه قال: أخبركم أنه خلقكم من طين، ثم أخبركم أنه قضى أجلًا. وإن جعلت <q>﴿قَضى﴾</q> بمعنى: أوجد وأظهر، ويرجع ذلك إلى صفة فعل، فيصح أن يكون خلق آدم من طين قبل إظهار هذا الأجل وإبدائه، وتكون <q>﴿ثم﴾</q> على بابها في ترتيب زَمَنَي وقوع القضيتين». <q>﴿ثُمَّ أَنتُمۡ تَمۡتَرُونَ ۝٢﴾</q> - تفسير ٢٤٥٠٠- عن خالد بن مَعدانَ -من طريق ثور- في قوله: <q>﴿ثم أنتم تمترون﴾</q>، يقول: في البعث{31}. (٦/١٧) ٢٤٥٠١- عن قتادة بن دعامة، في قوله: <q>﴿ثم أنتم تمترون﴾</q>، قال: تَشُكُّون{5}. (٦/١٦) ٢٤٥٠٢- عن إسماعيل السُّدِّيّ -من طريق أسباط- في قوله: <q>﴿ثم أنتم تمترون﴾</q>، قال: تَشُكُّون{33}. (٦/١٦) ٢٤٥٠٣- عن الربيع بن أنس -من طريق ابن المبارك- في قول الله: <q>﴿ثم أنتم تمترون﴾</q>، يعني: الشك والريبة في أمر الساعة{31}. (ز) ٢٤٥٠٤- قال مقاتل بن سليمان: <q>﴿ثم أنتم تمترون﴾</q>، يعني: تَشُكُّون في البعث، يعني: كفار مكة{8}. (ز) ٢٤٥٠٥- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- <q>﴿ثم أنتم تمترون﴾</q>، قال: الشك. قال: وقرأ قول الله: <q>﴿في مرية منه﴾</q> [الحج:٥٥]. قال: في شكٍّ منه{36}. (ز) ",footnotes:1:أخرجه أبو يعلى ١١/٤٥٣ (٦٥٨٠)، من طريق إسماعيل بن رافع، عن المقبري، عن أبي هريرة به. قال الهيثمي في المجمع ٨/١٩٧ (١٣٧٤٧): «فيه إسماعيل بن رافع، قال البخاري: ثقة مقارب الحديث. وضعفه الجمهور، وبقية رجاله رجال الصحيح». وقال البوصيري في إتحاف الخيرة ٧/١٣٦-١٣٧ (٦٥١٩): «هذا إسناد ضعيف، لضعف إسماعيل بن رافع».عزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ٩/١٥٠.أخرجه ابن جرير ٩/١٥٠.عزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ٩/١٥٠.تفسير الثعلبي ٤/١٣٤.تفسير مقاتل بن سليمان ١/٥٤٩.أخرجه ابن جرير ٩/١٥٠، ١٥٣.أخرجه ابن جرير ٩/١٥١، وابن أبي حاتم ٤/١٢٦٠-١٢٦٢، والحاكم ٢/٣١٥. وعزاه السيوطي إلى الفريابي، وابن أبي شيبة، وابن المنذر، وأبي الشيخ.أخرجه ابن جرير ٩/١٥٣، وابن أبي حاتم ٤/١٢٦١.أخرجه ابن جرير ٩/١٥٣، وابن أبي حاتم ٤/١٢٦١-١٢٦٢. وعزاه السيوطي إلى ابن المنذر.علَّق ابن أبي حاتم ٤/١٢٦١ شطره الأول، وأخرج ٤/١٢٦١ شطره الثاني من طريق عطاء بن السائب.علَّقه ابن أبي حاتم ٤/١٢٦١.علَّقه ابن أبي حاتم ٤/١٢٦١.علَّقه ابن أبي حاتم ٤/١٢٦١.أخرجه ابن جرير ٩/١٥٢. وعلَّقه ابن أبي حاتم ٤/١٢٦١. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وأبي الشيخ.تفسير مجاهد ص٣١٩، وأخرجه ابن جرير ٩/١٥٢.علَّقه ابن أبي حاتم ٤/١٢٦٢.أخرجه ابن جرير ٩/١٥٢، وفي لفظ: <q>﴿ثم قضى أجلا﴾</q> قال: الموت.أخرجه ابن جرير ٩/١٥١. وعلَّقه ابن أبي حاتم ٤/١٢٦١ بنحوه.تفسير البغوي ٣/١٢٧.أخرجه ابن جرير ٩/١٥٢.أخرجه ابن جرير ٩/١٥٢. وعزا السيوطي إلى عبد بن حميد نحوه.أخرجه عبد الرزاق ١/٢٠٣، وابن جرير ٩/١٥٢. وعلَّقه ابن أبي حاتم ٤/١٢٦١ بنحوه. وعزاه السيوطي إلى ابن المنذر، وأبي الشيخ. وأخرج أبو عمرو الداني في المكتفى ص٦٥ (٨) نحوه من طريق يحيى بن سلام.أخرجه ابن جرير ٩/١٥٣.أخرجه ابن أبي حاتم ٤/١٢٦١.تفسير مقاتل بن سليمان ١/٥٤٩.عزاه السيوطي إلى أبي الشيخ.أخرجه ابن جرير ٩/١٥٣.أخرجه ابن أبي حاتم ٤/١٢٦٢.عزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ٩/١٥٤، وابن أبي حاتم ٤/١٢٦٢. وعزاه السيوطي إلى أبي الشيخ.أخرجه ابن أبي حاتم ٤/١٢٦٢.تفسير مقاتل بن سليمان ١/٥٤٩.أخرجه ابن جرير ٩/١٥٤.
6,3," <q>﴿وَهُوَ ٱللَّهُ فِی ٱلسَّمَـٰوَ ٰ⁠تِ وَفِی ٱلۡأَرۡضِ﴾</q> - تفسير ٢٤٥٠٦- قال مقاتل بن سليمان: <q>﴿وهو الله في السماوات﴾</q> أنّه واحد، <q>﴿وفي الأرض﴾</q>{1}. (ز) <q>﴿یَعۡلَمُ سِرَّكُمۡ وَجَهۡرَكُمۡ وَیَعۡلَمُ مَا تَكۡسِبُونَ ۝٣﴾</q> - تفسير ٢٤٥٠٧- عن عبد الله بن عباس -من طريق علي بن أبي طلحة- قوله: <q>﴿يعلم سركم﴾</q>، قال: السر: ما أسرَّ ابنُ آدم في نفسه{2}. (ز) ٢٤٥٠٨- عن سعيد بن جبير -من طريق عطاء بن دينار- في قول الله: <q>﴿يعلم سركم﴾</q>، قال: السِّرُّ: ما حدَّثْتَ به نفسَك{3}. (ز) ٢٤٥٠٩- قال مقاتل بن سليمان: <q>﴿يعلم سركم وجهركم﴾</q> يعني: سرّ أعمالكم، وجهرها، <q>﴿ويعلم ما تكسبون﴾</q> يعنى: ما تعملون من الخيرِ، والشرِّ{1}. (ز) ",footnotes:1:تفسير مقاتل بن سليمان ١/٥٤٩.أخرجه ابن أبي حاتم ٤/١٢٦٢-١٢٦٣.أخرجه ابن أبي حاتم ٤/١٢٦٣.تفسير مقاتل بن سليمان ١/٥٤٩.
6,4," <q>﴿وَمَا تَأۡتِیهِم مِّنۡ ءَایَةࣲ مِّنۡ ءَایَـٰتِ رَبِّهِمۡ إِلَّا كَانُوا۟ عَنۡهَا مُعۡرِضِینَ ۝٤﴾</q> - تفسير ٢٤٥١٠- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿وما تأتيهم من آية من آيات ربهم إلا كانوا عنها معرضين﴾</q>، يقول: ما يأتيهم مِن شيءٍ مِن كتاب الله إلا أعرَضوا عنه{1}. (٦/١٧) ٢٤٥١١- قال مقاتل بن سليمان: <q>﴿وما تأتيهم من آية من آيات ربهم﴾</q> يعني: انشقاق القمر <q>﴿إلا كانوا عنها معرضين﴾</q> فلِمَ لا يتفكرون فيها فيعتبروا في توحيد الله؟!{2}. (ز) ",footnotes:1:أخرجه ابن أبي حاتم ٤/١٢٦٣.تفسير مقاتل بن سليمان ١/٥٤٩.
6,5," <q>﴿فَقَدۡ كَذَّبُوا۟ بِٱلۡحَقِّ لَمَّا جَاۤءَهُمۡ فَسَوۡفَ یَأۡتِیهِمۡ أَنۢبَـٰۤؤُا۟ مَا كَانُوا۟ بِهِۦ یَسۡتَهۡزِءُونَ ۝٥﴾</q> - تفسير ٢٤٥١٢- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿فقد كذبوا بالحق لما جاءهم فسوف يأتيهم أنباء ما كانوا به يستهزؤون﴾</q>، يقول: سيأتيهم يومَ القيامة أنباءُ ما استَهزَءُوا به من كتاب الله ﷿{1}. (٦/١٧) ٢٤٥١٣- قال مقاتل بن سليمان: <q>﴿فقد كذبوا بالحق لما جاءهم﴾</q> يعني: القرآن، حين جاءهم به محمد ﷺ استهزءوا بالقرآن بأنّه ليس من الله، يعني: كفار مكة؛ منهم أبو جهل بن هشام، والوليد بن المغيرة، ومنبه ونبيه ابنا الحجاج، والعاص بن وائل السهمي، وأُبَيّ بن خلف، وعقبة بن أبي معيط، وعبد الله بن أبي أمية، وعتبة وشيبة ابنا ربيعة، وأبو البختري ابن هشام بن أسد، والحارث بن عامر بن نوفل، ومخرمة بن نوفل، وهشام بن عمرو بن ربيعة، وأبو سفيان بن حرب، وسهيل بن عمرو، وعمير بن وهب بن خلف، والحارث بن قيس، وعدي بن قيس، وعامر بن خالد الجمحي، والنضر بن الحارث، وزمعة بن الأسود، ومطعم بن عدي، وقرط بن عبد عمرو بن نوفل، والأخنس بن شريق، وحويطب بن عبد العزي، وأمية بن خلف، كلهم من قريش. يقول الله ﷿: <q>﴿فسوف يأتيهم أنباء﴾</q> يعني: حديث <q>﴿ما كانوا به﴾</q> بالعذاب <q>﴿يستهزؤن﴾</q> بأنّه غير نازل بهم. ونظيرها في الشعراء، فنزل بهم العذاب ببدر{2}. (ز) ",footnotes:1:أخرجه ابن أبي حاتم ٤/١٢٦٣.تفسير مقاتل بن سليمان ١/٥٤٩- ٥٥٠. وقوله: «ونظيرها في الشعراء» يشير إلى قوله تعالى: <q>﴿فَقَدْ كَذَّبُوا فَسَيَأْتِيهِمْ أنْباءُ ما كانُوا بِهِ يَسْتَهْزِئُونَ﴾</q> [الشعراء:٦].
6,6," <q>﴿أَلَمۡ یَرَوۡا۟ كَمۡ أَهۡلَكۡنَا مِن قَبۡلِهِم مِّن قَرۡنࣲ﴾</q> - تفسير ٢٤٥١٤- عن أبي مالك غزوان الغفاري -من طريق السدي- في قوله: <q>﴿من قرن﴾</q>، قال: أُمَّة{1}. (٦/١٧) ٢٤٥١٥- قال مقاتل بن سليمان: وعظهم ليخافوا، فقال: <q>﴿ألم يروا كم أهلكنا من قبلهم﴾</q> كفار مكة <q>﴿من قرن﴾</q> من أُمَّة{2}٢٢٢٦. (ز) ٢٢٢٦ ذكر ابنُ عطية (٣/٣١٥-٣١٦) أنّه قيل أنّ القرن: الزمن نفسه. وعلَّق عليه بقوله: «وهو على حذف مضاف، تقديره: من أهل قرن». وذكر أنه اختلف في مدة القرن على أقوال: الأول: أنه مائة سنة. الثاني: ثمانين سنة. الثالث: سبعين. الربع: ستين. الخامس: أربعين. السادس: ثلاثين. السابع: عشرين. الثامن: ثمانية عشر. وبيَّن أن الأكثر على القول الأول، ثم علَّق بقوله: «ويرجح ذلك الحديث الذي قال فيه رسول الله ﷺ: «أرأيتكم ليلتكم هذه، فإنّ على رأس مائة منها لا يبقى ممن هو اليوم على ظهر الأرض أحد». قال ابن عمر: يريد أنها تحرم ذلك القرن. وروي أن رسول الله ﷺ قال لعبد الله بن بسر: «تعيش قرنًا». فعاش مائة سنة». وبَيَّن أن مَن قالوا بالقول الثاني والثالث والرابع تمسكوا بحديث: «معترك المنايا ما بين الستين والسبعين». وعلَّق على القول الخامس بقوله: «وذكر الزهراوي في ذلك أنه عن النبي ﷺ». ثم انتقد هذه الأقوال عدا الأول، فقال: «وهذا كله ضعيف، وهذه طبقات وليست بقرون، إنما القرن أن يكون وفاة الأشياخ ثم ولادة الأطفال، ويظهر ذلك من قوله تعالى: <q>﴿وأنشأنا من بعدهم قرنا آخرين﴾</q>». <q>﴿مَّكَّنَّـٰهُمۡ فِی ٱلۡأَرۡضِ مَا لَمۡ نُمَكِّن لَّكُمۡ﴾</q> - تفسير ٢٤٥١٦- قال عبد الله بن عباس: أمهلناهم في العمر، والأجسام، والأولاد؛ مثل قوم نوح، وعاد، وثمود{3}. (ز) ٢٤٥١٧- عن قتادة بن دعامة -من طريق مَعْمَر- في قوله: <q>﴿مكناهم في الأرض ما لم نمكن لكم﴾</q>، يقول: أعطيناهم ما لم نُعطِكم{4}. (٦/١٧) ٢٤٥١٨- قال مقاتل بن سليمان: <q>﴿مكناهم في الأرض ما لم نمكن لكم﴾</q>، يقول: أعطيناهم من الخير والتمكين في البلاد ما لم نُعطِكم، يا أهل مكة{5}. (ز) <q>﴿وَأَرۡسَلۡنَا ٱلسَّمَاۤءَ عَلَیۡهِم مِّدۡرَارࣰا﴾</q> - تفسير ٢٤٥١٩- عن عبد الله بن عباس -من طريق علي بن أبي طلحة- في قوله: <q>﴿وأرسلنا السماء عليهم مدرارا﴾</q>، يقول: يَتبعُ بعضُها بعضًا{6}. (٦/١٧) ٢٤٥٢٠- قال مقاتل بن سليمان: <q>﴿وأرسلنا السماء عليهم مدرارا﴾</q> بالمطر، يعني: مُتتابِعًا{5}. (ز) ٢٤٥٢١- عن هارون التيمي -من طريق أبي عيش- في قوله: <q>﴿وأرسلنا السماء عليهم مدرارا﴾</q>، قال: المطرَ في إبّانِه{8}. (٦/١٨) <q>﴿فَأَهۡلَكۡنَـٰهُم بِذُنُوبِهِمۡ وَأَنشَأۡنَا مِنۢ بَعۡدِهِمۡ قَرۡنًا ءَاخَرِینَ ۝٦﴾</q> - تفسير ٢٤٥٢٢- قال مقاتل بن سليمان: <q>﴿فأهلكناهم﴾</q> يعني: فعذَّبناهم <q>﴿بذنوبهم﴾</q> يعني: بتكذيبهم رسلهم، <q>﴿وأنشأنا من بعدهم قرنا آخرين﴾</q> يقول: وخلقنا من بعد هلاكهم قومًا آخرين{5}. (ز) <q>﴿فَأَهۡلَكۡنَـٰهُم بِذُنُوبِهِمۡ وَأَنشَأۡنَا مِنۢ بَعۡدِهِمۡ قَرۡنًا ءَاخَرِینَ ۝٦﴾</q> - آثار متعلقة بالآية ٢٤٥٢٣- عن مالك بن دينار -من طريق جعفر بن سليمان- يقول: إذا كان القحط بذنوبنا، وإذا كان الخصب يتلو هذه الآية: <q>﴿وأرسلنا السماء عليهم مدرارا وجعلنا الأنهار تجري من تحتهم فأهلكناهم بذنوبهم وأنشأنا من بعدهم قرنا آخرين﴾</q>{10}. (ز) ",footnotes:1:أخرجه ابن أبي حاتم ٤/١٢٦٣.تفسير مقاتل بن سليمان ١/٥٥٠. وسترد الآثار مفصلة في تحديد مدة القرن، وذلك عند تفسير قوله تعالى: <q>﴿وكَمْ أهْلَكْنا مِنَ القُرُونِ مِن بَعْدِ نُوحٍ﴾</q> [الإسراء: ١٧]، وقوله تعالى: <q>﴿وقُرُونًا بَيْنَ ذَلِكَ كَثِيرًا﴾</q> [الفرقان: ٣٨].تفسير الثعلبي ٤/١٣٥.أخرجه ابن جرير ٩/١٥٦-١٥٧، وابن أبي حاتم ٤/١٢٦٣. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وأبي الشيخ.تفسير مقاتل بن سليمان ١/٥٥٠.أخرجه ابن أبي حاتم ٤/١٢٦٣. وعزاه السيوطي إلى ابن المنذر، وأبي الشيخ.تفسير مقاتل بن سليمان ١/٥٥٠.أخرجه ابن أبي حاتم ٤/١٢٦٤. وعزاه السيوطي إلى أبي الشيخ.تفسير مقاتل بن سليمان ١/٥٥٠.أخرجه ابن أبي حاتم ٤/١٢٦٤.
6,7," <q>﴿وَلَوۡ نَزَّلۡنَا عَلَیۡكَ كِتَـٰبࣰا فِی قِرۡطَاسࣲ فَلَمَسُوهُ بِأَیۡدِیهِمۡ لَقَالَ ٱلَّذِینَ كَفَرُوۤا۟ إِنۡ هَـٰذَاۤ إِلَّا سِحۡرࣱ مُّبِینࣱ ۝٧﴾</q> - نزول الآية ٢٤٥٢٤- قال الحسن البصري: وذلك أنهم سألوا رسول الله ﷺ أن يأتيهم بآية؛ بكتاب يقرءونه، وقالوا: لن نؤمن لك حتى تنزل علينا كتابًا نقرؤه من الله إلى كلِّ رجل باسمه: أن آمِن بمحمد؛ فإنّه رسولي{1}. (ز) ٢٤٥٢٥- قال محمد بن السائب الكلبي، في قوله تعالى: <q>﴿ولو نزلنا عليك كتابا في قرطاس﴾</q>: إنّ مشركي مكة قالوا: يا محمد، واللهِ، لا نؤمن لك حتى تأتينا بكتاب من عند الله، ومعه أربعة من الملائكة يشهدون أنّه من عند الله، وأنّك رسوله. فنزلت هذه الآية{2}. (ز) ٢٤٥٢٦- عن مقاتل: نزلت في النضر بن الحارث، وعبد الله بن أبي أمية، ونوفل بن خويلد، قالوا: يا محمد، لن نؤمن لك حتى تأتينا بكتاب من عند الله، ومعه أربعة من الملائكة، يشهدون عليه أنّه من عند الله، وأنك رسوله. فأنزل الله ﷿: <q>﴿ولو نزلنا عليك كتابا في قرطاس﴾</q>{3}٢٢٢٧. (ز) ٢٢٢٧ علَّق ابنُ عطية (٣/٣١٧) بقوله: «ويشبه أنّ سبب هذه الآية اقتراحُ عبد الله بن أبي أمية وتعنته؛ إذ قال للنبي ﷺ: لا أؤمن لك حتى تصعد إلى السماء، ثم تنزل بكتاب فيه: من رب العزة إلى عبد الله بن أبي أمية، يأمرني بتصديقك، وما أراني مع هذا كنت أصدقك. ثم أسلم بعد ذلك عبد الله، وقتل شهيدًا في الطائف». <q>﴿وَلَوۡ نَزَّلۡنَا عَلَیۡكَ كِتَـٰبࣰا فِی قِرۡطَاسࣲ﴾</q> - تفسير الآية ٢٤٥٢٧- عن عبد الله بن عباس -من طريق عطية العوفي- في قوله: <q>﴿ولو نزلنا عليك كتابا في قرطاس فلمسوه بأيديهم﴾</q>، يقول: لو أنزَلنا مِن السماء صُحُفًا فيها كتاب، فلَمَسُوه بأيدِيهم، لَزادهم ذلك تَكذيبًا{4}. (٦/١٨) ٢٤٥٢٨- عن قتادة بن دعامة -من طريق مَعْمَر- في قوله: <q>﴿ولو نزلنا عليك كتابا في قرطاس﴾</q>، يقول: في صحيفة{5}. (٦/١٨) ٢٤٥٢٩- عن إسماعيل السُّدِّيّ -من طريق أسباط- <q>﴿ولو نزلنا عليك كتابا في قرطاس﴾</q>: الصحف{6}. (ز) <q>﴿فَلَمَسُوهُ بِأَیۡدِیهِمۡ﴾</q> - تفسير ٢٤٥٣٠- عن عبد الله بن عباس -من طريق سعيد بن جبير- في قوله: <q>﴿فلمسوه بأيديهم﴾</q>: مسُّوه، ونظروا إليه؛ لم يؤمنوا به{7}. (ز) ٢٤٥٣١- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿فلمسوه بأيديهم﴾</q>، قال: فمَسُّوه، ونظَروا إليه؛ لم يُصَدِّقوا به{8}. (٦/١٨) ٢٤٥٣٢- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿فلمسوه بأيديهم﴾</q>، يقول: فعايَنوه مُعاينةً، ومَسُّوه بأيديهم{9}. (٦/١٨) <q>﴿لَقَالَ ٱلَّذِینَ كَفَرُوۤا۟ إِنۡ هَـٰذَاۤ إِلَّا سِحۡرࣱ مُّبِینࣱ ۝٧﴾</q> - تفسير ٢٤٥٣٣- قال مقاتل بن سليمان: <q>﴿ولَوْ نَزَّلْنا عَلَيْكَ كِتابًا فِي قِرْطاسٍ فَلَمَسُوهُ بِأَيْدِيهِمْ﴾</q> ما صدَّقوا به، و<q>﴿لَقالَ الَّذِينَ كَفَرُوا﴾</q> من أهل مكة: <q>﴿إنْ هَذا﴾</q> يقول: ما هذا القرآن <q>﴿إلّا سِحْرٌ مُبِينٌ﴾</q> يعني: بيِّنٌ{10}. (ز) ",footnotes:1:تفسير ابن أبي زمنين ٢/٥٩.تفسير الثعلبي ٤/١٣٥، وأسباب النزول للواحدي ص٢١٦، وتفسير البغوي ٣/١٢٩.تفسير الثعلبي ٤/١٣٥، وتفسير البغوي ٣/١٢٩.أخرجه ابن جرير ٩/١٥٩، وابن أبي حاتم ٤/١٢٦٤. وعزاه السيوطي إلى ابن المنذر.أخرجه عبد الرزاق ١/٢٠٣، وابن جرير ٩/١٥٩-١٦٠، وابن أبي حاتم ٤/١٢٦٤. وعزاه السيوطي إلى عبد بن حميد، وأبي الشيخ.أخرجه ابن جرير ٩/١٥٩. وعلَّقه ابن أبي حاتم ٤/١٢٦٤.أخرجه الحاكم (ت: مصطفى عطا) ٢/٣٤٤-٣٤٥ (٣٢٢٧).تفسير مجاهد ص٣١٩، وأخرجه ابن جرير ٩/١٥٩، وابن أبي حاتم ٤/١٢٦٤، وعزاه السيوطي إلى ابن أبي شيبة، وعبد بن حميد، وابن المنذر، وأبي الشيخ.أخرجه ابن جرير ٩/١٥٩، وابن أبي حاتم ٤/١٢٦٤. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.تفسير مقاتل بن سليمان ١/٥٥٠.
6,8," <q>﴿وَقَالُوا۟ لَوۡلَاۤ أُنزِلَ عَلَیۡهِ مَلَكࣱۖ وَلَوۡ أَنزَلۡنَا مَلَكࣰا لَّقُضِیَ ٱلۡأَمۡرُ ثُمَّ لَا یُنظَرُونَ ۝٨﴾</q> - نزول الآية ٢٤٥٣٤- قال مقاتل بن سليمان: نزلت في النضر بن الحارث، وعبد الله بن أمية بن المغيرة، ونوفل بن خويلد، كلهم من قريش{1}. (ز) ٢٤٥٣٥- عن محمد بن إسحاق -من طريق سلمة- قال: دعا رسول الله ﷺ قومَه إلى الإسلام، وكلَّمهم فأبلَغ إليهم -فيما بلَغَني-، فقال له زَمعةُ بن الأسود بن المطلب، والنضرُ بن الحارث بن كَلَدَة، وعَبدةُ بنُ عبد يغوث، وأُبيُّ بن خلف بن وهب، والعاصي بن وائل بن هشام: لو جُعِل معك -يا محمد- مَلَكٌ يُحَدِّثُ عنك الناس، ويُرى معك. فأنزل الله في ذلك من قولهم: <q>﴿وقالوا لولا أنزل عليه ملك﴾</q> الآية{2}. (٦/١٩) <q>﴿وَقَالُوا۟ لَوۡلَاۤ أُنزِلَ عَلَیۡهِ مَلَكࣱۖ﴾</q> - تفسير ٢٤٥٣٦- عن مجاهد بن جبر، في قوله: <q>﴿وقالوا لولا أنزل عليه ملك﴾</q>، قال: مَلَكٌ في صورة رجل{3}. (٦/١٩) ٢٤٥٣٧- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿وقالوا لولا أنزل عليه ملك﴾</q>، قال: في صورته{4}. (ز) ٢٤٥٣٨- قال مقاتل بن سليمان: <q>﴿وقالوا لولا﴾</q> يعني: هلّا <q>﴿أنزل عليه ملك﴾</q> يعينه ويُصَدِّقه بما أرسل به. نظيرها في الفرقان{5}. (ز) <q>﴿وَلَوۡ أَنزَلۡنَا مَلَكࣰا لَّقُضِیَ ٱلۡأَمۡرُ ثُمَّ لَا یُنظَرُونَ ۝٨﴾</q> - تفسير ٢٤٥٣٩- عن عبد الله بن عباس -من طريق أبي رَوْق، عن الضحاك- <q>﴿ولو أنزلنا ملكا﴾</q> قال: ولو أتاهم مَلَكٌ في صورتِه <q>﴿لقضي الأمر﴾</q> لأهلكناهم، <q>﴿ثم لا ينظرون﴾</q> لا يُؤَخَّرُون{6}. (٦/١٩) ٢٤٥٤٠- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿ولو أنزلنا ملكا لقضي الأمر﴾</q>، قال: لَقامت الساعة{7}٢٢٢٨. (٦/١٩) ٢٢٢٨ انتَقَد ابنُ عطية (٣/٣١٧) قول مجاهد بقوله: «وهذا ضعيف». ٢٤٥٤١- قال الضحاك بن مزاحم: لو أتاهم ملك في صورته لماتوا{8}. (ز) ٢٤٥٤٢- عن عكرمة مولى ابن عباس -من طريق سفيان الثوري، عن أبيه- <q>﴿لقضي الأمر﴾</q>، قال: لَقامت الساعة{9}. (ز) ٢٤٥٤٣- عن قتادة بن دعامة -من طريق مَعْمَر- في قوله: <q>﴿ولو أنزلنا ملكا لقضي الأمر﴾</q>، يقول: لو أنزَل الله مَلَكًا ثم لم يُؤمِنوا لعَجَّل لهم العذاب{10}٢٢٢٩. (٦/١٩) ٢٢٢٩ علَّق ابنُ عطية (٣/٣١٧) على هذا القول بقوله: «وهذا قول حَسَن». ٢٤٥٤٤- عن قتادة بن دعامة -من طريق سعيد- قوله: <q>﴿ثم لا ينظرون﴾</q>، يقول: ثم لم يُنْظَروا{11}. (ز) ٢٤٥٤٥- عن إسماعيل السُّدِّيّ -من طريق أسباط- <q>﴿ولو أنزلنا ملكا لقضي الأمر ثم لا ينظرون﴾</q>، يقول: لَجاءهم العذاب{12}. (ز) ٢٤٥٤٦- قال مقاتل بن سليمان: يقول الله: <q>﴿ولو أنزلنا ملكا﴾</q> فعاينوه <q>﴿لقضي الأمر﴾</q> يعني: لنزل العذاب بهم، <q>﴿ثم لا ينظرون﴾</q> يعني: ثم لا يُناظَر بهم حتى يعذبوا؛ لأنّ الرسل إذا كُذِّبت جاءت الملائكة بالعذاب{1}٢٢٣٠. (ز) ٢٢٣٠ اختلف المفسرون في معنى قوله: <q>﴿لقضي الأمر﴾</q> على ثلاثة أقوال: الأول: لقامت الساعة. والثاني: لعجل لهم العذاب. والثالث: لماتوا من هول رؤية الملك. ورجَّح ابنُ عطية (٣/٣١٧) القول الأخير مستندًا إلى السياق، فقال: «ويؤيد هذا التأويل ما بعده من قوله: <q>﴿ولَوْ جَعَلْناهُ مَلَكًا لَجَعَلْناهُ رَجُلًا﴾</q>، فإنّ أهل التأويل مجمعون أن ذلك؛ لأنّهم لم يكونوا يطيقون رؤية الملك في صورته، فالأَوْلى في قوله: <q>﴿لَقُضِيَ الأَمْرُ﴾</q> أي: لماتوا من هول رؤيته». ",footnotes:1:تفسير مقاتل بن سليمان ١/٥٥٠-٥٥١.أخرجه ابن أبي حاتم ٤/١٢٦٥. وعزاه السيوطي إلى ابن المنذر.عزاه السيوطي إلى عبد بن حميد، وابن جرير، وابن المنذر، وابن أبي حاتم، وأبي الشيخ.أخرجه ابن جرير ٩/١٦١، وابن أبي حاتم ٤/١٢٦٥. وفي تفسير مجاهد ص٣١٩: في صورة ملك.تفسير مقاتل بن سليمان ١/٥٥٠. يشير إلى قوله تعالى: <q>﴿وقالُوا مالِ هذا الرسول يَأْكُلُ الطَّعامَ ويَمْشِي فِي الأَسْواقِ لَوْلا أُنْزِلَ إلَيْهِ مَلَكٌ فَيَكُونَ مَعَهُ نَذِيرًا﴾</q> [الفرقان: ٧].عزاه السيوطي إلى أبي الشيخ. وأخرجه ابن جرير ٩/١٦١-١٦٢ بلفظ: لو آتاهم ملك في صورته لماتوا، ثم لم يؤخروا طرفة عين، وابن أبي حاتم ٤/١٢٦٥-١٢٦٦ وفي آخره: <q>﴿ثم لا ينظرون﴾</q> قال: ثم لا يؤمنون. ولعله تصحيف.عزاه السيوطي إلى عبد بن حميد، وابن المنذر، وأبي الشيخ.تفسير البغوي ٣/١٢٩.أخرجه ابن جرير ٩/١٦١. وعلَّقه ابن أبي حاتم ٤/١٢٦٥.أخرجه عبد الرزاق ١/٢٠٤، وابن جرير ٩/١٦١، وابن أبي حاتم ٤/١٢٦٥-١٢٦٦. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وأبي الشيخ.أخرجه ابن أبي حاتم ٤/١٢٦٦.أخرجه ابن جرير ٩/١٦٠. وعلَّقه ابن أبي حاتم ٤/١٢٦٥-١٢٦٦.تفسير مقاتل بن سليمان ١/٥٥٠-٥٥١.
