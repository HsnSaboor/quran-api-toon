quran[9]{c,v,t}:
  41,12,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿فَقَضَىٰهُنَّ سَبۡعَ سَمَـٰوَاتࣲ فِی یَوۡمَیۡنِ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٨٣٨٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن مسعود</span>، و<span class="name-1">ناس من أصحاب النبي</span> ﷺ -من طريق السُّدّيّ، عن مُرَّة الهَمْدانِيّ-= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٨٣٨٣<span class="dash">-</span></span> و<span class="name-1">عبد الله بن عباس</span> -من طريق السُّدّيّ عن أبي مالك وأبي صالح- <span class="qpc-hafs">﴿ثم استوى إلى السماء وهي دخان﴾</span>: وكان ذلك الدُّخان من تنفُّس الماء حين تنفَّس، فجعلها سماءً واحدة، ثم فتَقها فجعلها سبع سماوات في يومين؛ في الخميس والجمعة، وإنما سُمي يوم الجمعة لأنه جُمِع فيه خلْق السماوات والأرض{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٨٣٨٤<span class="dash">-</span></span> عن <span class="name-2">أبي العالية الرِّياحيّ</span> -من طريق أبي جعفر الرازي- في قوله: <span class="qpc-hafs">﴿فقضاهن﴾</span>: خَلَقَهُنَّ{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٨٣٨٥<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدّيّ</span> -من طريق أسباط- <span class="qpc-hafs">﴿فَقَضاهُنَّ سَبْعَ سَماواتٍ فِي يَوْمَيْنِ﴾</span>، قال: استوى إلى السماء وهي دُخان مِن تنفُّس الماء حين تنفَّس، فجعلها سماء واحدة، ففتَقها، فجعلها سبع سماوات في يومين؛ في الخميس والجمعة، وإنما سُمي يوم الجمعة لأنه جُمع فيه خلْق السماوات والأرض{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٨٣٨٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فَقَضاهُنَّ سَبْعَ سَماواتٍ﴾</span> يقول: فخلَق السماوات السبع <span class="qpc-hafs">﴿فِي يَوْمَيْنِ﴾</span> الأحد والاثنين{4}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَأَوۡحَىٰ فِی كُلِّ سَمَاۤءٍ أَمۡرَهَاۚ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٨٣٨٧<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن مسعود</span>، و<span class="name-1">ناس من أصحاب النبي</span> ﷺ -من طريق السُّدّيّ، عن مُرَّة الهَمْدانِيّ-= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٨٣٨٨<span class="dash">-</span></span> و<span class="name-1">عبد الله بن عباس</span> -من طريق السُّدّيّ عن أبي مالك وأبي صالح- <span class="qpc-hafs">﴿وأوحى في كل سماء أمرها﴾</span>، قال: خلَق في كل سماء خلْقها من الملائكة، والخلْق الذي فيها، من البحار وجبال البَرَد، وما لا يُعلم{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٨٣٨٩<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطاء- <span class="qpc-hafs">﴿وأَوْحى فِي كُلِّ سَماءٍ أمْرَها﴾</span>: خلَق في كل سماء خَلْقها مِن الملائكة، وما فيها مِن البحار وجبال البَرَد، وما لا يعلمه إلا الله{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٨٣٩٠<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿وأَوْحى فِي كُلِّ سَماءٍ أمْرَها﴾</span>، قال: مِمّا أمر به، وأراده مِن خلْق النيِّرات والرجوم، وغير ذلك{7}. (١٣/٩٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٨٣٩١<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿وأَوْحى فِي كُلِّ سَماءٍ أمْرَها﴾</span>، قال: خلَق فيها شمسها، وقمرها، ونجومها، وصلاحها{8}. (١٣/٩٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٨٣٩٢<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدّيّ</span> -من طريق أسباط- <span class="qpc-hafs">﴿وأَوْحى فِي كُلِّ سَماءٍ أمْرَها﴾</span>، قال: خلَق في كل سماء خَلْقها مِن الملائكة، والخلْق الذي فيها مِن البحار وجبال البَرَد، وما لا يُعلم{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٨٣٩٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وأَوْحى﴾</span> يقول: وأمر <span class="qpc-hafs">﴿فِي كُلِّ سَماءٍ أمْرَها﴾</span> الذي أراده{4}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَزَیَّنَّا ٱلسَّمَاۤءَ ٱلدُّنۡیَا بِمَصَـٰبِیحَ وَحِفۡظࣰاۚ ذَ ٰ⁠لِكَ تَقۡدِیرُ ٱلۡعَزِیزِ ٱلۡعَلِیمِ ۝١٢﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٨٣٩٤<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن مسعود</span>، و<span class="name-1">ناس مِن أصحاب النبي</span> ﷺ -من طريق السُّدّيّ، عن مُرَّة الهَمْدانِيّ-= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٨٣٩٥<span class="dash">-</span></span> و<span class="name-1">عبد الله بن عباس</span> -من طريق السُّدّيّ عن أبي مالك وأبي صالح-: ثم زيّن السماء الدنيا بالكواكب، فجعلها زِينة وحِفْظًا تَحفَظ مِن الشياطين{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٨٣٩٦<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدّيّ</span> -من طريق أسباط- <span class="qpc-hafs">﴿وزَيَّنّا السَّماءَ الدُّنْيا بِمَصابِيحَ﴾</span> قال: ثم زيّن السماء الدنيا بالكواكب، فجعلها زينة، <span class="qpc-hafs">﴿وحِفْظًا﴾</span> مِن الشياطين{12}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٨٣٩٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وزَيَّنّا السَّماءَ الدُّنْيا﴾</span> يقول: لأنّها أدنى السماوات مِن الأرض <span class="qpc-hafs">﴿بِمَصابِيحَ﴾</span> يعني: الكواكب، <span class="qpc-hafs">﴿وحِفْظًا﴾</span> بالكواكب، يعني: ما يرمي الشياطين بالشهاب؛ لئلا يستمعوا إلى السماء، يقول: <span class="qpc-hafs">﴿ذلِكَ﴾</span> الذي ذَكر مِن صُنعه في هذه الآية <span class="qpc-hafs">﴿تَقْدِيرُ العَزِيزِ﴾</span> في مُلكه، <span class="qpc-hafs">﴿العَلِيمِ﴾</span> بخلْقه{4}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ١/٤٦٢ مطولًا.أخرجه ابن جرير -كما في الفتح ١٣/٤٠٥-.أخرجه ابن جرير ٢٠/٣٩٣.تفسير مقاتل بن سليمان ٣/٧٣٧.أخرجه ابن جرير ١/٤٦١ مطولًا.أخرجه البغوي ٧/١٦٦.أخرجه الفريابي -كما في تغليق التعليق ٤/٣٠٢، وفتح الباري ٨/٥٥٩-، وابن جرير ٢٠/٣٩٣ مختصرًا. وعلّقه البخاري في صحيحه ٤/١٨١٧. وذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٤/١٤٧- بنحوه. وعزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ٢٠/٣٩٣. وعزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ٢٠/٣٩٣.تفسير مقاتل بن سليمان ٣/٧٣٧.أخرجه ابن جرير ١/٤٦١ مطولًا.أخرجه ابن جرير ٢٠/٣٩٤.تفسير مقاتل بن سليمان ٣/٧٣٧.
  41,13,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿فَإِنۡ أَعۡرَضُوا۟ فَقُلۡ أَنذَرۡتُكُمۡ صَـٰعِقَةࣰ مِّثۡلَ صَـٰعِقَةِ عَادࣲ وَثَمُودَ ۝١٣﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٨٣٩٨<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- في قوله: <span class="qpc-hafs">﴿أنْذَرْتُكُمْ صاعِقَةً مِثْلَ صاعِقَةِ عادٍ وثَمُودَ﴾</span>، يقول: أنذرتكم وقِيعَةً مثل وقِيعَةِ عاد وثمود{1}. (١٣/٩٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٨٣٩٩<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدّيّ</span> -من طريق أسباط- <span class="qpc-hafs">﴿صاعِقَةً مِثْلَ صاعِقَةِ عادٍ وثَمُودَ﴾</span>، قال: عذاب مثل عذاب عاد وثمود{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٨٤٠٠<span class="dash">-</span></span> عن <span class="name-3">محمد بن السّائِب الكلبي</span>، قال: كل شيء في القرآن <span class="qpc-hafs">﴿صاعِقَةً﴾</span> فهو عذاب{3}. (١٣/٩٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٨٤٠١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فَإنْ أعْرَضُوا﴾</span> عن الإيمان، يعني: التوحيد <span class="qpc-hafs">﴿فَقُلْ أنْذَرْتُكُمْ صاعِقَةً﴾</span> في الدنيا <span class="qpc-hafs">﴿مِثْلَ صاعِقَةِ عادٍ وثَمُودَ﴾</span> يقول: مثل عذاب عاد وثمود. وإنما خَصَّ عادًا وثمود مِن بين الأمم لأنّ كفّار مكة قد عاينوا هلاكهم باليمن والحجر. كلُّ مَن يموت مِن عذاب، أو سَقَم، أو قتْل فهو مصعوق{4}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه عبد الرزاق ٢/١٨٤، وابن جرير ٢٠/٣٩٥ بنحوه. وعزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ٢٠/٣٩٥.عزاه السيوطي إلى عبد بن حميد، وابن المنذر.تفسير مقاتل بن سليمان ٣/٧٣٧.
  41,14,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿إِذۡ جَاۤءَتۡهُمُ ٱلرُّسُلُ مِنۢ بَیۡنِ أَیۡدِیهِمۡ وَمِنۡ خَلۡفِهِمۡ أَلَّا تَعۡبُدُوۤا۟ إِلَّا ٱللَّهَۖ قَالُوا۟ لَوۡ شَاۤءَ رَبُّنَا لَأَنزَلَ مَلَـٰۤىِٕكَةࣰ فَإِنَّا بِمَاۤ أُرۡسِلۡتُم بِهِۦ كَـٰفِرُونَ ۝١٤﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٨٤٠٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطية العَوفيّ- قوله: <span class="qpc-hafs">﴿فَإنْ أعْرَضُوا فَقُلْ أنْذَرْتُكُمْ صاعِقَةً مِثْلَ صاعِقَةِ عادٍ وثَمُودَ إذْ جاءَتْهُمُ الرُّسُلُ مِن بَيْنِ أيْدِيهِمْ ومِن خَلْفِهِمْ﴾</span>، قال: الرسل التي كانت قبل هود، والرسل الذين كانوا بعده، بعث الله قبله رسلًا، وبعث مِن بعده رسلًا{1}<span class=comment-ref>٥٧٤٠</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٥٧٤٠</span> قال <u>ابنُ جرير</u> (٢٠/٣٩٥-٣٩٦): «وعني بقوله: <span class="qpc-hafs">﴿من بين أيديهم﴾</span>: الرسل التي أتت إلى الذين هلكوا بالصاعقة من هاتين الأمتين. وعني بقوله: <span class="qpc-hafs">﴿ومن خلفهم﴾</span>: من خلف الرسل الذين بُعثوا إلى آبائهم رسلًا إليهم، وذلك أنّ الله بعث إلى عاد هودًا، فكذّبوه مِن بعد رسلٍ قد كانت تقدّمته إلى آبائهم أيضًا، فكذّبوهم، فأُهلكوا». ثم <span class="mustanad">استشهد لقوله بقول ابن عباس</span>.</p><p>و<span class="comment-type-2">انتقد</span> <u>ابنُ عطية</u> (٧/٤٦٩-٤٧٠) قول <u>ابن جرير</u> -<span class="mustanad">مستندًا إلى اللغة، والدلالة العقلية</span>-، فقال: «وأما الطبري فقال: الضمير في قوله: <span class="qpc-hafs">﴿ومن خلفهم﴾</span> عائد على الرسل، والضمير في قوله: <span class="qpc-hafs">﴿من بين أيديهم﴾</span> على الأمم، وتابعه الثعلبي، وهذا غير قويّ؛ لأنه يفرّق الضمائر، ويشعّب المعنى».</p><p>و<span class="comment-type-3">رجَّح</span> عودَ الضمير في قوله: <span class="qpc-hafs">﴿من بين أيديهم﴾</span> على مَن تقدّم مِن الرسل في الزمن، واتصلت نذارتهم إلى أعمار عاد وثمود، وبهذا الاتصال قامت الحجة. و<span class="comment-type-3">رجَّح</span> عودَ الضمير في قوله: <span class="qpc-hafs">﴿من خلفهم﴾</span> على مَن جاءهم مِن الرسل بعد اكتمال أعمارهم وبعد تقدّم وجودهم في الزمن، ثم قال: «وجاء مِن مجموع العبارة إقامة الحجة عليهم في أن الرسالة والنذارة عمّتهم خبرًا ومباشرة، ولا يتوجه أن يُجعل <span class="qpc-hafs">﴿ومن خلفهم﴾</span> عبارة عما أتى بعدهم في الزمن؛ لأن ذلك لا يلحقهم منه تقصير».</div></p><p><div></p><p><p><span class="item-no">٦٨٤٠٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثم قال: <span class="qpc-hafs">﴿إذْ جاءَتْهُمُ الرُّسُلُ مِن بَيْنِ أيْدِيهِمْ ومِن خَلْفِهِمْ﴾</span> يعني: من قبلهم ومن بعدهم، فقالوا لقومهم: <span class="qpc-hafs">﴿ألّا تَعْبُدُوا إلّا اللَّهَ﴾</span> يقول: وحِّدوا الله. <span class="qpc-hafs">﴿قالُوا﴾</span> للرسل: <span class="qpc-hafs">﴿لَوشاءَ رَبُّنا لَأَنْزَلَ مَلائِكَةً﴾</span> فكانوا إلينا رسلًا؛ <span class="qpc-hafs">﴿فَإنّا بِما أُرْسِلْتُمْ بِهِ﴾</span> يعني: بالتوحيد <span class="qpc-hafs">﴿كافِرُونَ﴾</span> لا نُؤمِن به{2}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ٢٠/٣٩٦.تفسير مقاتل بن سليمان ٣/٧٣٨.
  41,15,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿فَأَمَّا عَادࣱ فَٱسۡتَكۡبَرُوا۟ فِی ٱلۡأَرۡضِ بِغَیۡرِ ٱلۡحَقِّ وَقَالُوا۟ مَنۡ أَشَدُّ مِنَّا قُوَّةًۖ أَوَلَمۡ یَرَوۡا۟ أَنَّ ٱللَّهَ ٱلَّذِی خَلَقَهُمۡ هُوَ أَشَدُّ مِنۡهُمۡ قُوَّةࣰۖ وَكَانُوا۟ بِـَٔایَـٰتِنَا یَجۡحَدُونَ ۝١٥﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٨٤٠٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فَأَمّا عادٌ فاسْتَكْبَرُوا﴾</span> يعني: فتكبّروا عن الإيمان، وعمِلوا <span class="qpc-hafs">﴿فِي الأَرْضِ بِغَيْرِ الحَقِّ﴾</span> فخوّفهم هودٌ العذابَ، <span class="qpc-hafs">﴿وقالُوا مَن أشَدُّ مِنّا قُوَّةً﴾</span> يعني: بَطْشًا. قال: كان الرجلُ منهم ينزع الصخرة مِن الجبل لِشِدَّته، وكان طولُه اثنا عشر ذِراعًا، ويقال: ثمانية عشر ذِراعًا، وكانوا باليمن في حَضرمَوْت، <span class="qpc-hafs">﴿أوَلَمْ يَرَوْا﴾</span> يقول: أولم يعلموا <span class="qpc-hafs">﴿أنَّ اللَّهَ الَّذِي خَلَقَهُمْ هُوأَشَدُّ مِنهُمْ قُوَّةً﴾</span> يعني: بطشًا، <span class="qpc-hafs">﴿وكانُوا بِآياتِنا﴾</span> يعني: بالعذاب <span class="qpc-hafs">﴿يَجْحَدُونَ﴾</span> أنّه لا ينزل بهم، فأرسل الله عليهم الريح فأهلكتهم{1}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٣/٧٣٨.
  41,16,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿فَأَرۡسَلۡنَا عَلَیۡهِمۡ رِیحࣰا صَرۡصَرࣰا﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٨٤٠٥<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- <span class="qpc-hafs">﴿فَأَرْسَلْنا عَلَيْهِمْ رِيحًا صَرْصَرًا﴾</span>، قال: شديدة السموم{1}. (١٣/٩٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٨٤٠٦<span class="dash">-</span></span> عن <span class="name-2">الضَّحّاك بن مُزاحِم</span> -من طريق عبيد- قال في قوله: <span class="qpc-hafs">﴿رِيحًا صَرْصَرًا﴾</span>، يقول: ريحًا فيها برد شديد{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٨٤٠٧<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- في قوله: <span class="qpc-hafs">﴿رِيحًا صَرْصَرًا﴾</span>: باردة{3}. (١٣/٩٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٨٤٠٨<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدّيّ</span> -من طريق أسباط- <span class="qpc-hafs">﴿رِيحًا صَرْصَرًا﴾</span>، قال: باردة، ذات الصوت{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٨٤٠٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فَأَرْسَلْنا﴾</span> فأرسل اللهُ <span class="qpc-hafs">﴿عَلَيْهِمْ رِيحًا صَرْصَرًا﴾</span> يعني: باردة{5}<span class=comment-ref>٥٧٤١</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٥٧٤١</span> اختُلف في معنى الصرصر على قولين: <b>الأول</b>: أنها الريح الباردة. <b>الثاني</b>: الريح الشديدة.</p><p>و<span class="comment-type-3">رجَّح</span> <u>ابنُ جرير</u> (٢٠/٣٩٨) -<span class="mustanad">مستندًا إلى اللغة</span>- القولَ الثاني الذي قاله مجاهد، فقال: «وذلك أن قوله: <span class="qpc-hafs">﴿صرصرا﴾</span> إنما هو صوت الريح إذا هبّت بشدة، فسُمع لها كقول القائل: صرّر».</p><p>و<span class="comment-type-4">علَّق</span> <u>ابنُ عطية</u> (٧/٤٧١) على هذا القول بقوله: «وكذلك يجيء صوت الريح في كثير من الأوقات بحسب ما تلقى».</p><p>و<span class="comment-type-4">جمع</span> <u>ابنُ كثير</u> (١٢/٢٢٦) بين الأقوال <span class="mustanad">مستندًا للدلالة العقلية، والنظائر</span>، فقال: «والحق أنها متصفة بجميع ذلك؛ فإنها كانت ريحًا شديدة قوية؛ لتكون عقوبتهم مِن جنس ما اغتروا به من قواهم، وكانت باردة شديدة البرد جدًّا، كقوله تعالى: <span class="qpc-hafs">﴿بريح صرصر عاتية﴾</span> [الحاقة:٦]، أي: باردة شديدة، وكانت ذات صوت مزعج، ومنه سُمي النهر المشهور ببلاد المشرق: صرصرًا؛ لقوة صوت جريه».</p><p>وقد <span class="comment-type-4">ذكر</span> <u>ابنُ عطية</u> القولين الواردين على أنهما مغايران لقول <u>ابن جرير</u>؛ إذ رأى أن اشتقاقهما من الصّر، وجعل قول <u>ابن جرير</u> ثالثًا مُشتقًّا من الصرصر.</div></p><p><h3><span class="qpc-hafs">﴿فَأَرۡسَلۡنَا عَلَیۡهِمۡ رِیحࣰا صَرۡصَرࣰا﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٦٨٤١٠<span class="dash">-</span></span> عن ابن عباس، قال: ما هَبَّت ريحٌ قَطُّ إلّا جَثا النبيُّ ﷺ على ركبتيه، وقال: «<b>اللهم، اجعلها رحمة، ولا تجعلها عذابًا، اللهم، اجعلها رِياحًا، ولا تجعلها ريحًا</b>». قال ابن عباس: واللهِ، إنّ تفسير ذلك في كتاب الله: <span class="qpc-hafs">﴿أرسلنا عليهم ريحًا صرصرًا﴾</span>، و<span class="qpc-hafs">﴿أرسلنا عليهم الريح العقيم﴾</span> [الذاريات:٢٨]، وقال: <span class="qpc-hafs">﴿وأرسلنا الرياح لواقح﴾</span> [الحجر:٢٢]، و<span class="qpc-hafs">﴿يرسل الرياح مبشرات﴾</span> [الروم:٤٦]{6}. (٢/١١٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٨٤١١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عمرو</span> -من طريق عطاء- قال: الرياحُ ثمانٍ: أربعٌ منها عذاب، وأربعٌ منها رحمة؛ فأمّا العذاب منها: فالقاصف، والعاصف، والعقيم، والصرصر، قال الله تعالى: <span class="qpc-hafs">﴿رِيحًا صَرْصَرًا فِي أيّامٍ نَحِساتٍ﴾</span>، قال: مشؤومات. وأما رياح الرحمة: فالناشرات، والمبشّرات، والمُرسلات، والذّاريات{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٨٤١٢<span class="dash">-</span></span> عن <span class="name-1">جابر بن عبد اللّه</span> -من طريق أبي الزبير- قال: إذا أراد اللّه بقوم خيرًا أرسل عليهم المطرَ، وحبس عنهم كثرة الرّياح، وإذا أراد اللّه بقوم شرًّا حبس عنهم المطر، وأرسل عليهم كثرة الرّياح{8}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿فِیۤ أَیَّامࣲ نَّحِسَاتࣲ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٨٤١٣<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عمرو</span> -من طريق عطاء- قال: ...<span class="qpc-hafs">﴿رِيحًا صَرْصَرًا فِي أيّامٍ نَحِساتٍ﴾</span>، قال: مشؤومات ...{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٨٤١٤<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، في قوله: <span class="qpc-hafs">﴿فِي أيّامٍ نَحِساتٍ﴾</span>، قال: مَشْؤومات{10}. (١٣/٩٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٨٤١٥<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطية العَوفيّ- قوله: <span class="qpc-hafs">﴿فِي أيّامٍ نَحِساتٍ﴾</span>، قال: أيام متتابعات، أنزل الله فيهنّ العذاب{11}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٨٤١٦<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- <span class="qpc-hafs">﴿فِي أيّامٍ نَحِساتٍ﴾</span>، قال: مشائيم{12}. (١٣/٩٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٨٤١٧<span class="dash">-</span></span> عن <span class="name-2">الضَّحّاك بن مُزاحِم</span> -من طريق عبيد- <span class="qpc-hafs">﴿فِي أيّامٍ نَحِساتٍ﴾</span>، قال: شداد{13}<span class=comment-ref>٥٧٤٢</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٥٧٤٢</span> <span class="comment-type-4">علَّق</span> <u>ابنُ عطية</u> (٧/٤٧٢) على هذا القول الذي قاله الضَّحّاك، ومقاتل، بقوله: «وقال الضَّحّاك: معناه:شديدة، أي: شديدة البرد حتى كان البرد عذابًا لهم».</p><p>و<span class="comment-type-4">بنحوه</span> قال <u>ابنُ القيم</u> (٤/٤١٢).</div></p><p><div></p><p><p><span class="item-no">٦٨٤١٨<span class="dash">-</span></span> قال <span class="name-2">الضَّحّاك بن مُزاحِم</span> -من طريق مقاتل- <span class="qpc-hafs">﴿فِي أيّامٍ نَحِساتٍ﴾</span>: أمسك الله عنهم المطر ثلاث سنين، ودامت الرّياح عليهم مِن غير مطر{14}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٨٤١٩<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span>، <span class="qpc-hafs">﴿فِي أيّامٍ نَحِساتٍ﴾</span>، قال: مشائيم{15}. (١٣/٩٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٨٤٢٠<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- في قوله: <span class="qpc-hafs">﴿نَحِساتٍ﴾</span>، قال: مشؤومات، نَكِدات{16}. (١٣/٩٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٨٤٢١<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدّيّ</span> -من طريق أسباط- <span class="qpc-hafs">﴿فِي أيّامٍ نَحِساتٍ﴾</span>، قال: أيام مشؤومات عليهم{13}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٨٤٢٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فِي أيّامٍ نَحِساتٍ﴾</span>، يعني: شدادًا، وكانت ريح الدَّبور، فأهلكتهم{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٨٤٢٣<span class="dash">-</span></span> قال <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- قوله: <span class="qpc-hafs">﴿فِي أيّامٍ نَحِساتٍ﴾</span>، قال: النَّحس: الشرّ، أرسل عليهم ريحَ شرٍّ، ليس فيها مِن الخير شيء{13}<span class=comment-ref>٥٧٤٣</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٥٧٤٣</span> اختُلف في تفسير النّحِسات على أقوال: <b>الأول</b>: المشائيم. <b>الثاني</b>: المتتابعات. <b>الثالث</b>: أيام ذات شر. <b>الرابع</b>: الشداد.</p><p>و<span class="comment-type-3">رجَّح</span> <u>ابنُ جرير</u> (٢٠/٤٠١) -<span class="mustanad">مستندًا إلى لغة العرب</span>- القول الأول الذي قاله ابن عباس، وعبد الله بن عمرو، وعكرمة، ومجاهد، وقتادة، والسُّدّيّ، فقال: «لأن ذلك هو المعروف من معنى النحس في كلام العرب».</div></p><p><h3><span class="qpc-hafs">﴿لِّنُذِیقَهُمۡ عَذَابَ ٱلۡخِزۡیِ فِی ٱلۡحَیَوٰةِ ٱلدُّنۡیَاۖ وَلَعَذَابُ ٱلۡـَٔاخِرَةِ أَخۡزَىٰۖ وَهُمۡ لَا یُنصَرُونَ ۝١٦﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٨٤٢٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿لِنُذِيقَهُمْ﴾</span> يعني: لكي نُعَذِّبَهم <span class="qpc-hafs">﴿عَذابَ الخِزْيِ﴾</span> يعني: الهوان <span class="qpc-hafs">﴿فِي الحَياةِ الدُّنْيا﴾</span> فهو الريح، <span class="qpc-hafs">﴿ولَعَذابُ الآخِرَةِ أخْزى﴾</span> يعني: أشد وأكثر إهانة من الريح التي أهلكتهم في الدنيا، <span class="qpc-hafs">﴿وهُمْ لا يُنْصَرُونَ﴾</span> يعني: لا يسمعون من العذاب{5}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير مجاهد ص٥٨٥، وأخرجه ابن جرير ٢٠/٣٩٨. وعزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ٢٠/٣٩٨.أخرجه عبد الرزاق ٢/١٨٤، وابن جرير ٢٠/٣٩٨ من طريق سعيد. وعزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ٢٠/٣٩٨.تفسير مقاتل بن سليمان ٣/٧٣٨.أخرجه الشافعي في الأم ١/٢٨٩، وأبو الشيخ في العظمة ٤/١٣٥١-١٣٥٢.أخرجه ابن أبي الدنيا في المطر والرعد والبرق والريح -موسوعة الإمام ابن أبي الدنيا ٨/٤٥١ (١٧٤)-.أخرجه الثعلبي ٨/٢٨٩.أخرجه ابن أبي الدنيا في المطر والرعد والبرق والريح -موسوعة الإمام ابن أبي الدنيا ٨/٤٥١ (١٧٤)-.عزاه السيوطي إلى ابن أبي حاتم.أخرجه ابن جرير ٢٠/٣٩٩.تفسير مجاهد ص٥٨٥، وأخرجه الفريابي -كما في تغليق التعليق ٤/٣٠٤-، وابن جرير ٢٠/٣٩٩. وعلَّقه البخاري في صحيحه ٤/١٨١٧. وعزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ٢٠/٤٠٠.أخرجه الثعلبي في تفسيره ٨/٢٨٩، وتفسير البغوي ٧/١٦٩.عزاه السيوطي إلى عبد بن حميد.أخرجه عبد الرزاق ٢/١٨٤. وعزاه السيوطي إلى عبد بن حميد. وأخرجه ابن جرير ٢٠/٤٠٠ من طريق سعيد بلفظ: أيام -واللهِ- كانت مشؤومات على القوم.أخرجه ابن جرير ٢٠/٤٠٠.تفسير مقاتل بن سليمان ٣/٧٣٨.أخرجه ابن جرير ٢٠/٤٠٠.تفسير مقاتل بن سليمان ٣/٧٣٨.
  41,17,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَأَمَّا ثَمُودُ فَهَدَیۡنَـٰهُمۡ﴾</span> - قراءات</h3></p><p><div></p><p><p><span class="item-no">٦٨٤٢٥<span class="dash">-</span></span> عن النضر، عن هارون، قال: بلغني: أنّ أهل الكوفة يقرءون: (وأَمّا ثَمُودَ فَهَدَيْناهُمْ) نصب، <span class="qpc-hafs">﴿فاسْتَحَبُّواْ العَمى عَلى الهُدى﴾</span>{1}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَأَمَّا ثَمُودُ فَهَدَیۡنَـٰهُمۡ﴾</span> - تفسير الآية</h3></p><p><div></p><p><p><span class="item-no">٦٨٤٢٦<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- في قوله: <span class="qpc-hafs">﴿وأَمّا ثَمُودُ فَهَدَيْناهُمْ﴾</span>، قال: بيَّنّا لهم{2}. (١٣/٩٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٨٤٢٧<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطية العَوفيّ- قوله: <span class="qpc-hafs">﴿وأَمّا ثَمُودُ فَهَدَيْناهُمْ فاسْتَحَبُّوا العَمى عَلى الهُدى﴾</span>، قال: أرسل الله إليهم الرُّسُلَ بالهُدى، فاستحبُّوا العمى على الهُدى{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٨٤٢٨<span class="dash">-</span></span> قال <span class="name-2">مجاهد بن جبر</span>: <span class="qpc-hafs">﴿وأَمّا ثَمُودُ فَهَدَيْناهُمْ﴾</span> دعوناهم{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٨٤٢٩<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- في قوله تعالى: <span class="qpc-hafs">﴿فَهَدَيْناهُمْ فاسْتَحَبُّوا العَمى عَلى الهُدى فَأَخَذَتْهُمْ﴾</span>، يقول: بيَّنّا لهم، فاستحبُّوا العمى على الهُدى{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٨٤٣٠<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله تعالى: <span class="qpc-hafs">﴿وأَمّا ثَمُودُ فَهَدَيْناهُمْ﴾</span>: بيَّنّا لهم سبيل الخير والشر{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٨٤٣١<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدّيّ</span> -من طريق أسباط- <span class="qpc-hafs">﴿وأَمّا ثَمُودُ فَهَدَيْناهُمْ﴾</span>: بيَّنّا لهم{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٨٤٣٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثم ذكر ثمود، فقال: <span class="qpc-hafs">﴿وأَمّا ثَمُودُ فَهَدَيْناهُمْ﴾</span>، يعني: بيَّنّا لهم{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٨٤٣٣<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿وأَمّا ثَمُودُ فَهَدَيْناهُمْ﴾</span>، قال: أعلمناهم الهُدى والضلالة، ونهيناهم أن يتّبعوا الضلالة، وأمرناهم أن يتّبعوا الهدى{9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٨٤٣٤<span class="dash">-</span></span> عن <span class="name-3">سفيان الثوري</span>، في قوله: <span class="qpc-hafs">﴿وأَمّا ثَمُودُ فَهَدَيْناهُمْ﴾</span>، قال: دَعَوْناهم{10}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿فَٱسۡتَحَبُّوا۟ ٱلۡعَمَىٰ عَلَى ٱلۡهُدَىٰ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٨٤٣٥<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدّيّ</span> -من طريق أسباط- <span class="qpc-hafs">﴿فاسْتَحَبُّوا العَمى عَلى الهُدى﴾</span>، قال: اختاروا الضَّلالة والعمى على الهُدى{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٨٤٣٦<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدّيّ</span> -من طريق أسباط- قال: سألوا -يعني: صالحًا- أن يأتيهم بآية، فجاءهم بالناقة لها شِرب ولهم شِرب يوم معلوم، وقال: ذروها تأكل في أرض الله، ولا تمسوها بسوء. فأقرُّوا بها جميعًا، فذلك قوله: <span class="qpc-hafs">﴿فَهَدَيْناهُمْ فاسْتَحَبُّوا العَمى عَلى الهُدى﴾</span>، فكانوا قد أقرُّوا بها على وجه النفاق{12}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٨٤٣٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فاسْتَحَبُّوا العَمى عَلى الهُدى﴾</span>، يقول: اختاروا الكفر على الإيمان{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٨٤٣٨<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿فاسْتَحَبُّوا العَمى عَلى الهُدى﴾</span>، قال: استحبوا الضَّلالة على الهُدى. وقرأ: <span class="qpc-hafs">﴿كَذَلِكَ زَيَّنّا لِكُلِّ أُمَّةٍ عَمَلَهُمْ﴾</span> إلى آخر الآية [الأنعام:١٠٨]. قال: فزيَّن لثمود عملَها القبيح. وقرأ: <span class="qpc-hafs">﴿أفَمَن زُيِّنَ لَهُ سُوءُ عَمَلِهِ فَرَآهُ حَسَنًا فَإنَّ اللَّهَ يُضِلُّ مَن يَشاءُ﴾</span> إلى آخر الآية [فاطر:٨]{3}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿فَأَخَذَتۡهُمۡ صَـٰعِقَةُ ٱلۡعَذَابِ ٱلۡهُونِ بِمَا كَانُوا۟ یَكۡسِبُونَ ۝١٧﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٨٤٣٩<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدّيّ</span> -من طريق أسباط- <span class="qpc-hafs">﴿العَذابِ الهُونِ﴾</span>، قال: الهوان{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٨٤٤٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فَأَخَذَتْهُمْ صاعِقَةُ﴾</span> يعني: صَيحة جبريل ﵇ <span class="qpc-hafs">﴿العَذابِ الهُونِ بِما كانُوا يَكْسِبُونَ﴾</span> يعني: يعملون مِن الشرك{8}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه إسحاق البستي ص٢٩٠.</p><p>وقراءة (وأَمّا ثَمُودَ) بالنصب شاذة، تروى أيضًا عن ابن أبي إسحاق، وعيسى الثقفي. انظر: مختصر ابن خالويه ص١٣٤.أخرجه ابن جرير ٢٠/٤٠٠. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.أخرجه ابن جرير ٢٠/٤٠٤.تفسير البغوي ٧/١٦٩.أخرجه عبد الرزاق ٢/١٨٤-١٨٥، وابن جرير ٢٠/٤٠٤.أخرجه ابن جرير ٢٠/٤٠٠.أخرجه ابن جرير ٢٠/٤٠٢.تفسير مقاتل بن سليمان ٣/٧٣٩.أخرجه ابن جرير ٢٠/٤٠٣.تفسير سفيان الثوري ص٢٦٥.أخرجه ابن جرير ٢٠/٤٠٢.أخرجه ابن أبي حاتم ٩/٢٨٠٥.تفسير مقاتل بن سليمان ٣/٧٣٩.أخرجه ابن جرير ٢٠/٤٠٤.أخرجه ابن جرير ٢٠/٤٠٤.تفسير مقاتل بن سليمان ٣/٧٣٩.
  41,18,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَنَجَّیۡنَا ٱلَّذِینَ ءَامَنُوا۟ وَكَانُوا۟ یَتَّقُونَ ۝١٨﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٨٤٤١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثم قال: <span class="qpc-hafs">﴿ونَجَّيْنا الَّذِينَ آمَنُوا﴾</span> يعني: صدَّقوا بالتوحيد، مِن العذاب الذي نزل بكُفّارهم، <span class="qpc-hafs">﴿وكانُوا يَتَّقُونَ﴾</span> الشرك{1}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٣/٧٣٩.
  41,19,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَیَوۡمَ یُحۡشَرُ أَعۡدَاۤءُ ٱللَّهِ إِلَى ٱلنَّارِ فَهُمۡ یُوزَعُونَ ۝١٩﴾</span> الآيات - نزول الآيات</h3></p><p><div></p><p><p><span class="item-no">٦٨٤٤٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن مسعود</span> -من طريق أبي معمر عبد الله بن سَخْبرة- قال: كنتُ مُسْتَتِرًا بأستار الكعبة، فجاء ثلاثة نفر؛ قرشي وثَقَفيّان، أو ثَقَفيّ وقرشيان، كثيرٌ شحمُ بطونهم، قليلٌ فِقْهُ قلوبهم، فتكلّموا بكلامٍ لم أسمعه، فقال أحدهم: أترون أنّ الله يسمع كلامنا هذا؟ فقال الآخران: إنّا إذا رفعنا أصواتَنا سمعه، وإذا لم نرفعه لم يسمعه. فقال الآخر: إنْ سمع منه شيئًا سمعه كله. قال: فذكرتُ ذلك للنبي ﷺ؛ فأنزل الله: <span class="qpc-hafs">﴿وما كُنْتُمْ تَسْتَتِرُونَ أنْ يَشْهَدَ عَلَيْكُمْ سَمْعُكُمْ ولا أبْصارُكُمْ﴾</span> إلى قوله: <span class="qpc-hafs">﴿مِنَ الخاسِرِينَ﴾</span>{1}. (١٣/٩٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٨٤٤٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ويَوْمَ يُحْشَرُ أعْداءُ اللَّهِ إلى النّارِ فَهُمْ يُوزَعُونَ﴾</span> نزلت في صفوان بن أُميّة الجُمَحي، وفي ربيعة، وعبد ياليل ابني عمرو الثقفيين، إلى خمس آيات. ويقال: إنّ الثلاثة نفر: صفوان بن أُمية، وفرْقد بن ثُمامة، وأبو فاطمة، ... وذلك أنّ هؤلاء النفر الثلاثة كانوا في ظِلّ الكعبة يتكلّمون، فقال أحدهم: هل يعلم الله ما نقول؟ فقال الثاني: إنْ خفضْنا لم يعلم، وإنْ رفعْنا علِمه. فقال الثالث: إن كان الله يسمعُ إذا رفعْنا فإنه يسمع إذا خفضْنا. فسمع قولَهم عبدُ الله بن مسعود، فأخبَر بقولهم النبيَّ ﷺ؛ فأنزل الله في قولهم: <span class="qpc-hafs">﴿وما كُنْتُمْ تَسْتَتِرُونَ أنْ يَشْهَدَ عَلَيْكُمْ سَمْعُكُمْ ولا أبْصارُكُمْ﴾</span> الآية{2}<span class=comment-ref>٥٧٤٤</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٥٧٤٤</span> ساق <u>ابنُ عطية</u> هذا القول، ثم <span class="comment-type-4">علَّق</span> (٧/٤٧٦) بقوله: «ويشبه أن يكون هذا بعد فتح مكة، فالآية مدنية، ويشبه أن رسول الله ﷺ قرأ الآية متمثّلًا بها عند إخبار عبد الله إياه».</div></p><p><h3><span class="qpc-hafs">﴿وَیَوۡمَ یُحۡشَرُ أَعۡدَاۤءُ ٱللَّهِ إِلَى ٱلنَّارِ فَهُمۡ یُوزَعُونَ ۝١٩﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٨٤٤٤<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، في قوله: <span class="qpc-hafs">﴿يُوزَعُونَ﴾</span>، قال: يُدفَعون{3}. (١٣/٩٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٨٤٤٥<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق مقسم- <span class="qpc-hafs">﴿ويَوْمَ يُحْشَرُ أعْداءُ اللَّهِ إلى النّارِ فَهُمْ يُوزَعُونَ﴾</span>، قال: يُحبَس أوّلُهم على آخرهم{4}. (١٣/٩٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٨٤٤٦<span class="dash">-</span></span> عن <span class="name-2">أبي رَزِين [مسعود بن مالك الأسدي]</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٨٤٤٧<span class="dash">-</span></span> و<span class="name-2">مجاهد بن جبر</span>، مثله{5}. (١٣/٩٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٨٤٤٨<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق منصور- في قوله -جلّ وعزّ-: <span class="qpc-hafs">﴿يوم يحشر أعداء الله إلى النار فهم يوزعون﴾</span>، قال: يُحشَر أولُهم على آخرهم{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٨٤٤٩<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span>، في قوله: <span class="qpc-hafs">﴿فَهُمْ يُوزَعُونَ﴾</span>، قال: يُحْبَسُون بعضًا على بعض{5}. (١٣/٩٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٨٤٥٠<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿فَهُمْ يُوزَعُونَ﴾</span>، قال: عليهم وزَعَة، ترُدّ أوّلهم على آخرهم{8}. (١٣/٩٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٨٤٥١<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدّيّ</span> -من طريق أسباط- <span class="qpc-hafs">﴿فَهُمْ يُوزَعُونَ﴾</span>، قال: يُحبس أوّلهم على آخرهم{9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٨٤٥٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: قوله: <span class="qpc-hafs">﴿فَهُمْ يُوزَعُونَ﴾</span>، يعني: يُساقون إلى النار، تسوقهم خزنة جهنم{10}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٨٤٥٣<span class="dash">-</span></span> عن <span class="name-3">عبد الملك ابن جُريْج</span>، في قوله: <span class="qpc-hafs">﴿ويَوْمَ يُحْشَرُ أعْداءُ اللَّهِ إلى النّارِ فَهُمْ يُوزَعُونَ﴾</span>، قال: الوزَعَة: السّاقَةُ من الملائكة يسوقونهم إلى النار، ويردّون الآخر على الأول{11}. (١٣/٩٨)</p></p><p></div></p></div>",footnotes:1:أخرجه البخاري ٦/١٢٩ (٤٨١٧)، ومسلم ٤/٢١٤١ (٢٧٧٥)، وابن جرير٢٠/٤١١-٤١٢، وإسحاق البستي ص٢٩٠، كذلك أخرج نحوه من طريق وهب بن زمعة.تفسير مقاتل بن سليمان ٣/٧٣٩-٧٤٠.عزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.أخرجه الطبرانى (١٢٠٧٦).عزاه السيوطي إلى عبد بن حميد.أخرجه إسحاق البستي ص٢٩٠.عزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ٢٠/٤٠٥ بنحوه. وذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٤/١٤٩-. وعزاه السيوطي إلى عبد بن حميد. وفي تفسير الثعلبي ٨/٢٩٠، وتفسير البغوي ٧/١٦٩ بلفظ: يُحبس أولهم على آخرهم ليتلاحقوا.أخرجه ابن جرير ٢٠/٤٠٥.تفسير مقاتل بن سليمان ٣/٧٣٩.عزاه السيوطي إلى ابن المنذر.
  41,20,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿حَتَّىٰۤ إِذَا مَا جَاۤءُوهَا شَهِدَ عَلَیۡهِمۡ سَمۡعُهُمۡ وَأَبۡصَـٰرُهُمۡ وَجُلُودُهُم بِمَا كَانُوا۟ یَعۡمَلُونَ ۝٢٠﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٨٤٥٤<span class="dash">-</span></span> قال <span class="name-2">إسماعيل السُّدّيّ</span>: <span class="qpc-hafs">﴿حَتّى إذا ما جاؤُها شَهِدَ عَلَيْهِمْ سَمْعُهُمْ وأَبْصارُهُمْ وجُلُودُهُمْ﴾</span>، أراد بالجلود: الفرُوج{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٨٤٥٥<span class="dash">-</span></span> عن حَرْملة، أنّه سمِع <span class="name-2">عبيد الله بن أبي جعفر</span> يقول: <span class="qpc-hafs">﴿حَتّى إذا ما جاءُوها شَهِدَ عَلَيْهِمْ سَمْعُهُمْ وأَبْصارُهُمْ وجُلُودُهُمْ﴾</span>، قال: جلودهم: الفروج{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٨٤٥٦<span class="dash">-</span></span> عن <span class="name-2">زيد بن أسلم</span> -من طريق مُبشّر بن عبيد- في قوله: <span class="qpc-hafs">﴿وقالُوا لِجُلُودِهِمْ لِمَ شَهِدْتُمْ عَلَيْنا﴾</span>، قال: قالوا لفروجهم: لِمَ شهدتم علينا؟!{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٨٤٥٧<span class="dash">-</span></span> عن رجل مِن آل أبي عقيل -من طريق الحكم الثقفي- <span class="qpc-hafs">﴿وقالُوا لِجُلُودِهِمْ لِمَ شَهِدْتُمْ عَلَيْنا﴾</span>: إنما عنى: فروجهم، ولكن كنّى عنها{4}<span class=comment-ref>٥٧٤٥</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٥٧٤٥</span> <span class="comment-type-2">انتقد</span> <u>ابنُ جرير</u> (٢٠/٤٠٦) هذا القول الذي قاله السُّدّيّ، وابن زيد، وأبو جعفر، ورجل من آل عقيل -<span class="mustanad">مستندًا للأغلب من لغة العرب</span>- فقال: «وهذا القول الذي ذكرناه عمَّن ذكرنا عنه في معنى الجلود، وإن كان معنى يحتمله التأويل، فليس بالأغلب على معنى الجلود، ولا بالأشهر، وغير جائز نقل معنى ذلك المعروف على الشيء الأقرب إلى غيره إلا بحُجَّة يجب التسليم لها».</div></p><p><div></p><p><p><span class="item-no">٦٨٤٥٨<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿حَتّى إذا ما جاءُوها﴾</span> يعني: النار، وعاينوها؛ قيل لهم: أين شركاؤكم الذين كنتم تزعمون في الدنيا؟ قالوا عند ذلك: <span class="qpc-hafs">﴿واللَّهِ رَبِّنا ما كُنّا مُشْرِكِينَ﴾</span> [الأنعام:٢٣]. فختم اللهُ على أفواههم، وأوحى إلى الجوارح فنطقتْ بما كتمتِ الألسُن مِن الشرك؛ <span class="qpc-hafs">﴿شَهِدَ عَلَيْهِمْ سَمْعُهُمْ وأَبْصارُهُمْ وجُلُودُهُمْ﴾</span> وأيديهم وأرجلهم <span class="qpc-hafs">﴿بِما كانُوا يَعْمَلُونَ﴾</span> من الشرك{5}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير الثعلبي ٨/٢٩٠، وتفسير البغوي ٧/١٧٠.أخرجه عبد الله بن وهب في الجامع -تفسير القرآن ٢/٥٧ (١١٢)، وابن جرير ٢٠/٤٠٦.أخرجه ابن أبي الدنيا في التوبة -موسوعة الإمام ابن أبي الدنيا ٣/٤٢٥ (٢٠٣)-.أخرجه ابن جرير ٢٠/٤٠٦.تفسير مقاتل بن سليمان ٣/٧٣٩.