tafsir[9]{c,v,t}:
41,12," <q>﴿فَقَضَىٰهُنَّ سَبۡعَ سَمَـٰوَاتࣲ فِی یَوۡمَیۡنِ﴾</q> - تفسير ٦٨٣٨٢- عن عبد الله بن مسعود، وناس من أصحاب النبي ﷺ -من طريق السُّدّيّ، عن مُرَّة الهَمْدانِيّ-= (ز) ٦٨٣٨٣- وعبد الله بن عباس -من طريق السُّدّيّ عن أبي مالك وأبي صالح- <q>﴿ثم استوى إلى السماء وهي دخان﴾</q>: وكان ذلك الدُّخان من تنفُّس الماء حين تنفَّس، فجعلها سماءً واحدة، ثم فتَقها فجعلها سبع سماوات في يومين؛ في الخميس والجمعة، وإنما سُمي يوم الجمعة لأنه جُمِع فيه خلْق السماوات والأرض{1}. (ز) ٦٨٣٨٤- عن أبي العالية الرِّياحيّ -من طريق أبي جعفر الرازي- في قوله: <q>﴿فقضاهن﴾</q>: خَلَقَهُنَّ{2}. (ز) ٦٨٣٨٥- عن إسماعيل السُّدّيّ -من طريق أسباط- <q>﴿فَقَضاهُنَّ سَبْعَ سَماواتٍ فِي يَوْمَيْنِ﴾</q>، قال: استوى إلى السماء وهي دُخان مِن تنفُّس الماء حين تنفَّس، فجعلها سماء واحدة، ففتَقها، فجعلها سبع سماوات في يومين؛ في الخميس والجمعة، وإنما سُمي يوم الجمعة لأنه جُمع فيه خلْق السماوات والأرض{3}. (ز) ٦٨٣٨٦- قال مقاتل بن سليمان: <q>﴿فَقَضاهُنَّ سَبْعَ سَماواتٍ﴾</q> يقول: فخلَق السماوات السبع <q>﴿فِي يَوْمَيْنِ﴾</q> الأحد والاثنين{4}. (ز) <q>﴿وَأَوۡحَىٰ فِی كُلِّ سَمَاۤءٍ أَمۡرَهَاۚ﴾</q> - تفسير ٦٨٣٨٧- عن عبد الله بن مسعود، وناس من أصحاب النبي ﷺ -من طريق السُّدّيّ، عن مُرَّة الهَمْدانِيّ-= (ز) ٦٨٣٨٨- وعبد الله بن عباس -من طريق السُّدّيّ عن أبي مالك وأبي صالح- <q>﴿وأوحى في كل سماء أمرها﴾</q>، قال: خلَق في كل سماء خلْقها من الملائكة، والخلْق الذي فيها، من البحار وجبال البَرَد، وما لا يُعلم{5}. (ز) ٦٨٣٨٩- عن عبد الله بن عباس -من طريق عطاء- <q>﴿وأَوْحى فِي كُلِّ سَماءٍ أمْرَها﴾</q>: خلَق في كل سماء خَلْقها مِن الملائكة، وما فيها مِن البحار وجبال البَرَد، وما لا يعلمه إلا الله{6}. (ز) ٦٨٣٩٠- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿وأَوْحى فِي كُلِّ سَماءٍ أمْرَها﴾</q>، قال: مِمّا أمر به، وأراده مِن خلْق النيِّرات والرجوم، وغير ذلك{7}. (١٣/٩٦) ٦٨٣٩١- عن قتادة بن دعامة -من طريق سعيد- <q>﴿وأَوْحى فِي كُلِّ سَماءٍ أمْرَها﴾</q>، قال: خلَق فيها شمسها، وقمرها، ونجومها، وصلاحها{8}. (١٣/٩٦) ٦٨٣٩٢- عن إسماعيل السُّدّيّ -من طريق أسباط- <q>﴿وأَوْحى فِي كُلِّ سَماءٍ أمْرَها﴾</q>، قال: خلَق في كل سماء خَلْقها مِن الملائكة، والخلْق الذي فيها مِن البحار وجبال البَرَد، وما لا يُعلم{3}. (ز) ٦٨٣٩٣- قال مقاتل بن سليمان: <q>﴿وأَوْحى﴾</q> يقول: وأمر <q>﴿فِي كُلِّ سَماءٍ أمْرَها﴾</q> الذي أراده{4}. (ز) <q>﴿وَزَیَّنَّا ٱلسَّمَاۤءَ ٱلدُّنۡیَا بِمَصَـٰبِیحَ وَحِفۡظࣰاۚ ذَ ٰ⁠لِكَ تَقۡدِیرُ ٱلۡعَزِیزِ ٱلۡعَلِیمِ ۝١٢﴾</q> - تفسير ٦٨٣٩٤- عن عبد الله بن مسعود، وناس مِن أصحاب النبي ﷺ -من طريق السُّدّيّ، عن مُرَّة الهَمْدانِيّ-= (ز) ٦٨٣٩٥- وعبد الله بن عباس -من طريق السُّدّيّ عن أبي مالك وأبي صالح-: ثم زيّن السماء الدنيا بالكواكب، فجعلها زِينة وحِفْظًا تَحفَظ مِن الشياطين{5}. (ز) ٦٨٣٩٦- عن إسماعيل السُّدّيّ -من طريق أسباط- <q>﴿وزَيَّنّا السَّماءَ الدُّنْيا بِمَصابِيحَ﴾</q> قال: ثم زيّن السماء الدنيا بالكواكب، فجعلها زينة، <q>﴿وحِفْظًا﴾</q> مِن الشياطين{12}. (ز) ٦٨٣٩٧- قال مقاتل بن سليمان: <q>﴿وزَيَّنّا السَّماءَ الدُّنْيا﴾</q> يقول: لأنّها أدنى السماوات مِن الأرض <q>﴿بِمَصابِيحَ﴾</q> يعني: الكواكب، <q>﴿وحِفْظًا﴾</q> بالكواكب، يعني: ما يرمي الشياطين بالشهاب؛ لئلا يستمعوا إلى السماء، يقول: <q>﴿ذلِكَ﴾</q> الذي ذَكر مِن صُنعه في هذه الآية <q>﴿تَقْدِيرُ العَزِيزِ﴾</q> في مُلكه، <q>﴿العَلِيمِ﴾</q> بخلْقه{4}. (ز) ",footnotes:1:أخرجه ابن جرير ١/٤٦٢ مطولًا.أخرجه ابن جرير -كما في الفتح ١٣/٤٠٥-.أخرجه ابن جرير ٢٠/٣٩٣.تفسير مقاتل بن سليمان ٣/٧٣٧.أخرجه ابن جرير ١/٤٦١ مطولًا.أخرجه البغوي ٧/١٦٦.أخرجه الفريابي -كما في تغليق التعليق ٤/٣٠٢، وفتح الباري ٨/٥٥٩-، وابن جرير ٢٠/٣٩٣ مختصرًا. وعلّقه البخاري في صحيحه ٤/١٨١٧. وذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٤/١٤٧- بنحوه. وعزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ٢٠/٣٩٣. وعزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ٢٠/٣٩٣.تفسير مقاتل بن سليمان ٣/٧٣٧.أخرجه ابن جرير ١/٤٦١ مطولًا.أخرجه ابن جرير ٢٠/٣٩٤.تفسير مقاتل بن سليمان ٣/٧٣٧.
41,13," <q>﴿فَإِنۡ أَعۡرَضُوا۟ فَقُلۡ أَنذَرۡتُكُمۡ صَـٰعِقَةࣰ مِّثۡلَ صَـٰعِقَةِ عَادࣲ وَثَمُودَ ۝١٣﴾</q> - تفسير ٦٨٣٩٨- عن قتادة بن دعامة -من طريق معمر- في قوله: <q>﴿أنْذَرْتُكُمْ صاعِقَةً مِثْلَ صاعِقَةِ عادٍ وثَمُودَ﴾</q>، يقول: أنذرتكم وقِيعَةً مثل وقِيعَةِ عاد وثمود{1}. (١٣/٩٦) ٦٨٣٩٩- عن إسماعيل السُّدّيّ -من طريق أسباط- <q>﴿صاعِقَةً مِثْلَ صاعِقَةِ عادٍ وثَمُودَ﴾</q>، قال: عذاب مثل عذاب عاد وثمود{2}. (ز) ٦٨٤٠٠- عن محمد بن السّائِب الكلبي، قال: كل شيء في القرآن <q>﴿صاعِقَةً﴾</q> فهو عذاب{3}. (١٣/٩٦) ٦٨٤٠١- قال مقاتل بن سليمان: <q>﴿فَإنْ أعْرَضُوا﴾</q> عن الإيمان، يعني: التوحيد <q>﴿فَقُلْ أنْذَرْتُكُمْ صاعِقَةً﴾</q> في الدنيا <q>﴿مِثْلَ صاعِقَةِ عادٍ وثَمُودَ﴾</q> يقول: مثل عذاب عاد وثمود. وإنما خَصَّ عادًا وثمود مِن بين الأمم لأنّ كفّار مكة قد عاينوا هلاكهم باليمن والحجر. كلُّ مَن يموت مِن عذاب، أو سَقَم، أو قتْل فهو مصعوق{4}. (ز) ",footnotes:1:أخرجه عبد الرزاق ٢/١٨٤، وابن جرير ٢٠/٣٩٥ بنحوه. وعزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ٢٠/٣٩٥.عزاه السيوطي إلى عبد بن حميد، وابن المنذر.تفسير مقاتل بن سليمان ٣/٧٣٧.
41,14," <q>﴿إِذۡ جَاۤءَتۡهُمُ ٱلرُّسُلُ مِنۢ بَیۡنِ أَیۡدِیهِمۡ وَمِنۡ خَلۡفِهِمۡ أَلَّا تَعۡبُدُوۤا۟ إِلَّا ٱللَّهَۖ قَالُوا۟ لَوۡ شَاۤءَ رَبُّنَا لَأَنزَلَ مَلَـٰۤىِٕكَةࣰ فَإِنَّا بِمَاۤ أُرۡسِلۡتُم بِهِۦ كَـٰفِرُونَ ۝١٤﴾</q> - تفسير ٦٨٤٠٢- عن عبد الله بن عباس -من طريق عطية العَوفيّ- قوله: <q>﴿فَإنْ أعْرَضُوا فَقُلْ أنْذَرْتُكُمْ صاعِقَةً مِثْلَ صاعِقَةِ عادٍ وثَمُودَ إذْ جاءَتْهُمُ الرُّسُلُ مِن بَيْنِ أيْدِيهِمْ ومِن خَلْفِهِمْ﴾</q>، قال: الرسل التي كانت قبل هود، والرسل الذين كانوا بعده، بعث الله قبله رسلًا، وبعث مِن بعده رسلًا{1}٥٧٤٠. (ز) ٥٧٤٠ قال ابنُ جرير (٢٠/٣٩٥-٣٩٦): «وعني بقوله: <q>﴿من بين أيديهم﴾</q>: الرسل التي أتت إلى الذين هلكوا بالصاعقة من هاتين الأمتين. وعني بقوله: <q>﴿ومن خلفهم﴾</q>: من خلف الرسل الذين بُعثوا إلى آبائهم رسلًا إليهم، وذلك أنّ الله بعث إلى عاد هودًا، فكذّبوه مِن بعد رسلٍ قد كانت تقدّمته إلى آبائهم أيضًا، فكذّبوهم، فأُهلكوا». ثم استشهد لقوله بقول ابن عباس. وانتقد ابنُ عطية (٧/٤٦٩-٤٧٠) قول ابن جرير -مستندًا إلى اللغة، والدلالة العقلية-، فقال: «وأما الطبري فقال: الضمير في قوله: <q>﴿ومن خلفهم﴾</q> عائد على الرسل، والضمير في قوله: <q>﴿من بين أيديهم﴾</q> على الأمم، وتابعه الثعلبي، وهذا غير قويّ؛ لأنه يفرّق الضمائر، ويشعّب المعنى». ورجَّح عودَ الضمير في قوله: <q>﴿من بين أيديهم﴾</q> على مَن تقدّم مِن الرسل في الزمن، واتصلت نذارتهم إلى أعمار عاد وثمود، وبهذا الاتصال قامت الحجة. ورجَّح عودَ الضمير في قوله: <q>﴿من خلفهم﴾</q> على مَن جاءهم مِن الرسل بعد اكتمال أعمارهم وبعد تقدّم وجودهم في الزمن، ثم قال: «وجاء مِن مجموع العبارة إقامة الحجة عليهم في أن الرسالة والنذارة عمّتهم خبرًا ومباشرة، ولا يتوجه أن يُجعل <q>﴿ومن خلفهم﴾</q> عبارة عما أتى بعدهم في الزمن؛ لأن ذلك لا يلحقهم منه تقصير». ٦٨٤٠٣- قال مقاتل بن سليمان: ثم قال: <q>﴿إذْ جاءَتْهُمُ الرُّسُلُ مِن بَيْنِ أيْدِيهِمْ ومِن خَلْفِهِمْ﴾</q> يعني: من قبلهم ومن بعدهم، فقالوا لقومهم: <q>﴿ألّا تَعْبُدُوا إلّا اللَّهَ﴾</q> يقول: وحِّدوا الله. <q>﴿قالُوا﴾</q> للرسل: <q>﴿لَوشاءَ رَبُّنا لَأَنْزَلَ مَلائِكَةً﴾</q> فكانوا إلينا رسلًا؛ <q>﴿فَإنّا بِما أُرْسِلْتُمْ بِهِ﴾</q> يعني: بالتوحيد <q>﴿كافِرُونَ﴾</q> لا نُؤمِن به{2}. (ز) ",footnotes:1:أخرجه ابن جرير ٢٠/٣٩٦.تفسير مقاتل بن سليمان ٣/٧٣٨.
41,15," <q>﴿فَأَمَّا عَادࣱ فَٱسۡتَكۡبَرُوا۟ فِی ٱلۡأَرۡضِ بِغَیۡرِ ٱلۡحَقِّ وَقَالُوا۟ مَنۡ أَشَدُّ مِنَّا قُوَّةًۖ أَوَلَمۡ یَرَوۡا۟ أَنَّ ٱللَّهَ ٱلَّذِی خَلَقَهُمۡ هُوَ أَشَدُّ مِنۡهُمۡ قُوَّةࣰۖ وَكَانُوا۟ بِـَٔایَـٰتِنَا یَجۡحَدُونَ ۝١٥﴾</q> - تفسير ٦٨٤٠٤- قال مقاتل بن سليمان: <q>﴿فَأَمّا عادٌ فاسْتَكْبَرُوا﴾</q> يعني: فتكبّروا عن الإيمان، وعمِلوا <q>﴿فِي الأَرْضِ بِغَيْرِ الحَقِّ﴾</q> فخوّفهم هودٌ العذابَ، <q>﴿وقالُوا مَن أشَدُّ مِنّا قُوَّةً﴾</q> يعني: بَطْشًا. قال: كان الرجلُ منهم ينزع الصخرة مِن الجبل لِشِدَّته، وكان طولُه اثنا عشر ذِراعًا، ويقال: ثمانية عشر ذِراعًا، وكانوا باليمن في حَضرمَوْت، <q>﴿أوَلَمْ يَرَوْا﴾</q> يقول: أولم يعلموا <q>﴿أنَّ اللَّهَ الَّذِي خَلَقَهُمْ هُوأَشَدُّ مِنهُمْ قُوَّةً﴾</q> يعني: بطشًا، <q>﴿وكانُوا بِآياتِنا﴾</q> يعني: بالعذاب <q>﴿يَجْحَدُونَ﴾</q> أنّه لا ينزل بهم، فأرسل الله عليهم الريح فأهلكتهم{1}. (ز) ",footnotes:1:تفسير مقاتل بن سليمان ٣/٧٣٨.
41,16," <q>﴿فَأَرۡسَلۡنَا عَلَیۡهِمۡ رِیحࣰا صَرۡصَرࣰا﴾</q> - تفسير ٦٨٤٠٥- عن مجاهد بن جبر -من طريق ابن أبي نجيح- <q>﴿فَأَرْسَلْنا عَلَيْهِمْ رِيحًا صَرْصَرًا﴾</q>، قال: شديدة السموم{1}. (١٣/٩٧) ٦٨٤٠٦- عن الضَّحّاك بن مُزاحِم -من طريق عبيد- قال في قوله: <q>﴿رِيحًا صَرْصَرًا﴾</q>، يقول: ريحًا فيها برد شديد{2}. (ز) ٦٨٤٠٧- عن قتادة بن دعامة -من طريق معمر- في قوله: <q>﴿رِيحًا صَرْصَرًا﴾</q>: باردة{3}. (١٣/٩٧) ٦٨٤٠٨- عن إسماعيل السُّدّيّ -من طريق أسباط- <q>﴿رِيحًا صَرْصَرًا﴾</q>، قال: باردة، ذات الصوت{2}. (ز) ٦٨٤٠٩- قال مقاتل بن سليمان: <q>﴿فَأَرْسَلْنا﴾</q> فأرسل اللهُ <q>﴿عَلَيْهِمْ رِيحًا صَرْصَرًا﴾</q> يعني: باردة{5}٥٧٤١. (ز) ٥٧٤١ اختُلف في معنى الصرصر على قولين: الأول: أنها الريح الباردة. الثاني: الريح الشديدة. ورجَّح ابنُ جرير (٢٠/٣٩٨) -مستندًا إلى اللغة- القولَ الثاني الذي قاله مجاهد، فقال: «وذلك أن قوله: <q>﴿صرصرا﴾</q> إنما هو صوت الريح إذا هبّت بشدة، فسُمع لها كقول القائل: صرّر». وعلَّق ابنُ عطية (٧/٤٧١) على هذا القول بقوله: «وكذلك يجيء صوت الريح في كثير من الأوقات بحسب ما تلقى». وجمع ابنُ كثير (١٢/٢٢٦) بين الأقوال مستندًا للدلالة العقلية، والنظائر، فقال: «والحق أنها متصفة بجميع ذلك؛ فإنها كانت ريحًا شديدة قوية؛ لتكون عقوبتهم مِن جنس ما اغتروا به من قواهم، وكانت باردة شديدة البرد جدًّا، كقوله تعالى: <q>﴿بريح صرصر عاتية﴾</q> [الحاقة:٦]، أي: باردة شديدة، وكانت ذات صوت مزعج، ومنه سُمي النهر المشهور ببلاد المشرق: صرصرًا؛ لقوة صوت جريه». وقد ذكر ابنُ عطية القولين الواردين على أنهما مغايران لقول ابن جرير؛ إذ رأى أن اشتقاقهما من الصّر، وجعل قول ابن جرير ثالثًا مُشتقًّا من الصرصر. <q>﴿فَأَرۡسَلۡنَا عَلَیۡهِمۡ رِیحࣰا صَرۡصَرࣰا﴾</q> - آثار متعلقة بالآية ٦٨٤١٠- عن ابن عباس، قال: ما هَبَّت ريحٌ قَطُّ إلّا جَثا النبيُّ ﷺ على ركبتيه، وقال: «اللهم، اجعلها رحمة، ولا تجعلها عذابًا، اللهم، اجعلها رِياحًا، ولا تجعلها ريحًا». قال ابن عباس: واللهِ، إنّ تفسير ذلك في كتاب الله: <q>﴿أرسلنا عليهم ريحًا صرصرًا﴾</q>، و<q>﴿أرسلنا عليهم الريح العقيم﴾</q> [الذاريات:٢٨]، وقال: <q>﴿وأرسلنا الرياح لواقح﴾</q> [الحجر:٢٢]، و<q>﴿يرسل الرياح مبشرات﴾</q> [الروم:٤٦]{6}. (٢/١١٦) ٦٨٤١١- عن عبد الله بن عمرو -من طريق عطاء- قال: الرياحُ ثمانٍ: أربعٌ منها عذاب، وأربعٌ منها رحمة؛ فأمّا العذاب منها: فالقاصف، والعاصف، والعقيم، والصرصر، قال الله تعالى: <q>﴿رِيحًا صَرْصَرًا فِي أيّامٍ نَحِساتٍ﴾</q>، قال: مشؤومات. وأما رياح الرحمة: فالناشرات، والمبشّرات، والمُرسلات، والذّاريات{7}. (ز) ٦٨٤١٢- عن جابر بن عبد اللّه -من طريق أبي الزبير- قال: إذا أراد اللّه بقوم خيرًا أرسل عليهم المطرَ، وحبس عنهم كثرة الرّياح، وإذا أراد اللّه بقوم شرًّا حبس عنهم المطر، وأرسل عليهم كثرة الرّياح{8}. (ز) <q>﴿فِیۤ أَیَّامࣲ نَّحِسَاتࣲ﴾</q> - تفسير ٦٨٤١٣- عن عبد الله بن عمرو -من طريق عطاء- قال: ...<q>﴿رِيحًا صَرْصَرًا فِي أيّامٍ نَحِساتٍ﴾</q>، قال: مشؤومات ...{7}. (ز) ٦٨٤١٤- عن عبد الله بن عباس، في قوله: <q>﴿فِي أيّامٍ نَحِساتٍ﴾</q>، قال: مَشْؤومات{10}. (١٣/٩٧) ٦٨٤١٥- عن عبد الله بن عباس -من طريق عطية العَوفيّ- قوله: <q>﴿فِي أيّامٍ نَحِساتٍ﴾</q>، قال: أيام متتابعات، أنزل الله فيهنّ العذاب{11}. (ز) ٦٨٤١٦- عن مجاهد بن جبر -من طريق ابن أبي نجيح- <q>﴿فِي أيّامٍ نَحِساتٍ﴾</q>، قال: مشائيم{12}. (١٣/٩٧) ٦٨٤١٧- عن الضَّحّاك بن مُزاحِم -من طريق عبيد- <q>﴿فِي أيّامٍ نَحِساتٍ﴾</q>، قال: شداد{13}٥٧٤٢. (ز) ٥٧٤٢ علَّق ابنُ عطية (٧/٤٧٢) على هذا القول الذي قاله الضَّحّاك، ومقاتل، بقوله: «وقال الضَّحّاك: معناه:شديدة، أي: شديدة البرد حتى كان البرد عذابًا لهم». وبنحوه قال ابنُ القيم (٤/٤١٢). ٦٨٤١٨- قال الضَّحّاك بن مُزاحِم -من طريق مقاتل- <q>﴿فِي أيّامٍ نَحِساتٍ﴾</q>: أمسك الله عنهم المطر ثلاث سنين، ودامت الرّياح عليهم مِن غير مطر{14}. (ز) ٦٨٤١٩- عن عكرمة مولى ابن عباس، <q>﴿فِي أيّامٍ نَحِساتٍ﴾</q>، قال: مشائيم{15}. (١٣/٩٧) ٦٨٤٢٠- عن قتادة بن دعامة -من طريق معمر- في قوله: <q>﴿نَحِساتٍ﴾</q>، قال: مشؤومات، نَكِدات{16}. (١٣/٩٧) ٦٨٤٢١- عن إسماعيل السُّدّيّ -من طريق أسباط- <q>﴿فِي أيّامٍ نَحِساتٍ﴾</q>، قال: أيام مشؤومات عليهم{13}. (ز) ٦٨٤٢٢- قال مقاتل بن سليمان: <q>﴿فِي أيّامٍ نَحِساتٍ﴾</q>، يعني: شدادًا، وكانت ريح الدَّبور، فأهلكتهم{5}. (ز) ٦٨٤٢٣- قال عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- قوله: <q>﴿فِي أيّامٍ نَحِساتٍ﴾</q>، قال: النَّحس: الشرّ، أرسل عليهم ريحَ شرٍّ، ليس فيها مِن الخير شيء{13}٥٧٤٣. (ز) ٥٧٤٣ اختُلف في تفسير النّحِسات على أقوال: الأول: المشائيم. الثاني: المتتابعات. الثالث: أيام ذات شر. الرابع: الشداد. ورجَّح ابنُ جرير (٢٠/٤٠١) -مستندًا إلى لغة العرب- القول الأول الذي قاله ابن عباس، وعبد الله بن عمرو، وعكرمة، ومجاهد، وقتادة، والسُّدّيّ، فقال: «لأن ذلك هو المعروف من معنى النحس في كلام العرب». <q>﴿لِّنُذِیقَهُمۡ عَذَابَ ٱلۡخِزۡیِ فِی ٱلۡحَیَوٰةِ ٱلدُّنۡیَاۖ وَلَعَذَابُ ٱلۡـَٔاخِرَةِ أَخۡزَىٰۖ وَهُمۡ لَا یُنصَرُونَ ۝١٦﴾</q> - تفسير ٦٨٤٢٤- قال مقاتل بن سليمان: <q>﴿لِنُذِيقَهُمْ﴾</q> يعني: لكي نُعَذِّبَهم <q>﴿عَذابَ الخِزْيِ﴾</q> يعني: الهوان <q>﴿فِي الحَياةِ الدُّنْيا﴾</q> فهو الريح، <q>﴿ولَعَذابُ الآخِرَةِ أخْزى﴾</q> يعني: أشد وأكثر إهانة من الريح التي أهلكتهم في الدنيا، <q>﴿وهُمْ لا يُنْصَرُونَ﴾</q> يعني: لا يسمعون من العذاب{5}. (ز) ",footnotes:1:تفسير مجاهد ص٥٨٥، وأخرجه ابن جرير ٢٠/٣٩٨. وعزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ٢٠/٣٩٨.أخرجه عبد الرزاق ٢/١٨٤، وابن جرير ٢٠/٣٩٨ من طريق سعيد. وعزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ٢٠/٣٩٨.تفسير مقاتل بن سليمان ٣/٧٣٨.أخرجه الشافعي في الأم ١/٢٨٩، وأبو الشيخ في العظمة ٤/١٣٥١-١٣٥٢.أخرجه ابن أبي الدنيا في المطر والرعد والبرق والريح -موسوعة الإمام ابن أبي الدنيا ٨/٤٥١ (١٧٤)-.أخرجه الثعلبي ٨/٢٨٩.أخرجه ابن أبي الدنيا في المطر والرعد والبرق والريح -موسوعة الإمام ابن أبي الدنيا ٨/٤٥١ (١٧٤)-.عزاه السيوطي إلى ابن أبي حاتم.أخرجه ابن جرير ٢٠/٣٩٩.تفسير مجاهد ص٥٨٥، وأخرجه الفريابي -كما في تغليق التعليق ٤/٣٠٤-، وابن جرير ٢٠/٣٩٩. وعلَّقه البخاري في صحيحه ٤/١٨١٧. وعزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ٢٠/٤٠٠.أخرجه الثعلبي في تفسيره ٨/٢٨٩، وتفسير البغوي ٧/١٦٩.عزاه السيوطي إلى عبد بن حميد.أخرجه عبد الرزاق ٢/١٨٤. وعزاه السيوطي إلى عبد بن حميد. وأخرجه ابن جرير ٢٠/٤٠٠ من طريق سعيد بلفظ: أيام -واللهِ- كانت مشؤومات على القوم.أخرجه ابن جرير ٢٠/٤٠٠.تفسير مقاتل بن سليمان ٣/٧٣٨.أخرجه ابن جرير ٢٠/٤٠٠.تفسير مقاتل بن سليمان ٣/٧٣٨.
41,17," <q>﴿وَأَمَّا ثَمُودُ فَهَدَیۡنَـٰهُمۡ﴾</q> - قراءات ٦٨٤٢٥- عن النضر، عن هارون، قال: بلغني: أنّ أهل الكوفة يقرءون: (وأَمّا ثَمُودَ فَهَدَيْناهُمْ) نصب، <q>﴿فاسْتَحَبُّواْ العَمى عَلى الهُدى﴾</q>{1}. (ز) <q>﴿وَأَمَّا ثَمُودُ فَهَدَیۡنَـٰهُمۡ﴾</q> - تفسير الآية ٦٨٤٢٦- عن عبد الله بن عباس -من طريق علي- في قوله: <q>﴿وأَمّا ثَمُودُ فَهَدَيْناهُمْ﴾</q>، قال: بيَّنّا لهم{2}. (١٣/٩٧) ٦٨٤٢٧- عن عبد الله بن عباس -من طريق عطية العَوفيّ- قوله: <q>﴿وأَمّا ثَمُودُ فَهَدَيْناهُمْ فاسْتَحَبُّوا العَمى عَلى الهُدى﴾</q>، قال: أرسل الله إليهم الرُّسُلَ بالهُدى، فاستحبُّوا العمى على الهُدى{3}. (ز) ٦٨٤٢٨- قال مجاهد بن جبر: <q>﴿وأَمّا ثَمُودُ فَهَدَيْناهُمْ﴾</q> دعوناهم{4}. (ز) ٦٨٤٢٩- عن قتادة بن دعامة -من طريق معمر- في قوله تعالى: <q>﴿فَهَدَيْناهُمْ فاسْتَحَبُّوا العَمى عَلى الهُدى فَأَخَذَتْهُمْ﴾</q>، يقول: بيَّنّا لهم، فاستحبُّوا العمى على الهُدى{5}. (ز) ٦٨٤٣٠- عن قتادة بن دعامة -من طريق سعيد- في قوله تعالى: <q>﴿وأَمّا ثَمُودُ فَهَدَيْناهُمْ﴾</q>: بيَّنّا لهم سبيل الخير والشر{6}. (ز) ٦٨٤٣١- عن إسماعيل السُّدّيّ -من طريق أسباط- <q>﴿وأَمّا ثَمُودُ فَهَدَيْناهُمْ﴾</q>: بيَّنّا لهم{7}. (ز) ٦٨٤٣٢- قال مقاتل بن سليمان: ثم ذكر ثمود، فقال: <q>﴿وأَمّا ثَمُودُ فَهَدَيْناهُمْ﴾</q>، يعني: بيَّنّا لهم{8}. (ز) ٦٨٤٣٣- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿وأَمّا ثَمُودُ فَهَدَيْناهُمْ﴾</q>، قال: أعلمناهم الهُدى والضلالة، ونهيناهم أن يتّبعوا الضلالة، وأمرناهم أن يتّبعوا الهدى{9}. (ز) ٦٨٤٣٤- عن سفيان الثوري، في قوله: <q>﴿وأَمّا ثَمُودُ فَهَدَيْناهُمْ﴾</q>، قال: دَعَوْناهم{10}. (ز) <q>﴿فَٱسۡتَحَبُّوا۟ ٱلۡعَمَىٰ عَلَى ٱلۡهُدَىٰ﴾</q> - تفسير ٦٨٤٣٥- عن إسماعيل السُّدّيّ -من طريق أسباط- <q>﴿فاسْتَحَبُّوا العَمى عَلى الهُدى﴾</q>، قال: اختاروا الضَّلالة والعمى على الهُدى{7}. (ز) ٦٨٤٣٦- عن إسماعيل السُّدّيّ -من طريق أسباط- قال: سألوا -يعني: صالحًا- أن يأتيهم بآية، فجاءهم بالناقة لها شِرب ولهم شِرب يوم معلوم، وقال: ذروها تأكل في أرض الله، ولا تمسوها بسوء. فأقرُّوا بها جميعًا، فذلك قوله: <q>﴿فَهَدَيْناهُمْ فاسْتَحَبُّوا العَمى عَلى الهُدى﴾</q>، فكانوا قد أقرُّوا بها على وجه النفاق{12}. (ز) ٦٨٤٣٧- قال مقاتل بن سليمان: <q>﴿فاسْتَحَبُّوا العَمى عَلى الهُدى﴾</q>، يقول: اختاروا الكفر على الإيمان{8}. (ز) ٦٨٤٣٨- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿فاسْتَحَبُّوا العَمى عَلى الهُدى﴾</q>، قال: استحبوا الضَّلالة على الهُدى. وقرأ: <q>﴿كَذَلِكَ زَيَّنّا لِكُلِّ أُمَّةٍ عَمَلَهُمْ﴾</q> إلى آخر الآية [الأنعام:١٠٨]. قال: فزيَّن لثمود عملَها القبيح. وقرأ: <q>﴿أفَمَن زُيِّنَ لَهُ سُوءُ عَمَلِهِ فَرَآهُ حَسَنًا فَإنَّ اللَّهَ يُضِلُّ مَن يَشاءُ﴾</q> إلى آخر الآية [فاطر:٨]{3}. (ز) <q>﴿فَأَخَذَتۡهُمۡ صَـٰعِقَةُ ٱلۡعَذَابِ ٱلۡهُونِ بِمَا كَانُوا۟ یَكۡسِبُونَ ۝١٧﴾</q> - تفسير ٦٨٤٣٩- عن إسماعيل السُّدّيّ -من طريق أسباط- <q>﴿العَذابِ الهُونِ﴾</q>، قال: الهوان{3}. (ز) ٦٨٤٤٠- قال مقاتل بن سليمان: <q>﴿فَأَخَذَتْهُمْ صاعِقَةُ﴾</q> يعني: صَيحة جبريل ﵇ <q>﴿العَذابِ الهُونِ بِما كانُوا يَكْسِبُونَ﴾</q> يعني: يعملون مِن الشرك{8}. (ز) ",footnotes:1:أخرجه إسحاق البستي ص٢٩٠. وقراءة (وأَمّا ثَمُودَ) بالنصب شاذة، تروى أيضًا عن ابن أبي إسحاق، وعيسى الثقفي. انظر: مختصر ابن خالويه ص١٣٤.أخرجه ابن جرير ٢٠/٤٠٠. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.أخرجه ابن جرير ٢٠/٤٠٤.تفسير البغوي ٧/١٦٩.أخرجه عبد الرزاق ٢/١٨٤-١٨٥، وابن جرير ٢٠/٤٠٤.أخرجه ابن جرير ٢٠/٤٠٠.أخرجه ابن جرير ٢٠/٤٠٢.تفسير مقاتل بن سليمان ٣/٧٣٩.أخرجه ابن جرير ٢٠/٤٠٣.تفسير سفيان الثوري ص٢٦٥.أخرجه ابن جرير ٢٠/٤٠٢.أخرجه ابن أبي حاتم ٩/٢٨٠٥.تفسير مقاتل بن سليمان ٣/٧٣٩.أخرجه ابن جرير ٢٠/٤٠٤.أخرجه ابن جرير ٢٠/٤٠٤.تفسير مقاتل بن سليمان ٣/٧٣٩.
41,18," <q>﴿وَنَجَّیۡنَا ٱلَّذِینَ ءَامَنُوا۟ وَكَانُوا۟ یَتَّقُونَ ۝١٨﴾</q> - تفسير ٦٨٤٤١- قال مقاتل بن سليمان: ثم قال: <q>﴿ونَجَّيْنا الَّذِينَ آمَنُوا﴾</q> يعني: صدَّقوا بالتوحيد، مِن العذاب الذي نزل بكُفّارهم، <q>﴿وكانُوا يَتَّقُونَ﴾</q> الشرك{1}. (ز) ",footnotes:1:تفسير مقاتل بن سليمان ٣/٧٣٩.
41,19," <q>﴿وَیَوۡمَ یُحۡشَرُ أَعۡدَاۤءُ ٱللَّهِ إِلَى ٱلنَّارِ فَهُمۡ یُوزَعُونَ ۝١٩﴾</q> الآيات - نزول الآيات ٦٨٤٤٢- عن عبد الله بن مسعود -من طريق أبي معمر عبد الله بن سَخْبرة- قال: كنتُ مُسْتَتِرًا بأستار الكعبة، فجاء ثلاثة نفر؛ قرشي وثَقَفيّان، أو ثَقَفيّ وقرشيان، كثيرٌ شحمُ بطونهم، قليلٌ فِقْهُ قلوبهم، فتكلّموا بكلامٍ لم أسمعه، فقال أحدهم: أترون أنّ الله يسمع كلامنا هذا؟ فقال الآخران: إنّا إذا رفعنا أصواتَنا سمعه، وإذا لم نرفعه لم يسمعه. فقال الآخر: إنْ سمع منه شيئًا سمعه كله. قال: فذكرتُ ذلك للنبي ﷺ؛ فأنزل الله: <q>﴿وما كُنْتُمْ تَسْتَتِرُونَ أنْ يَشْهَدَ عَلَيْكُمْ سَمْعُكُمْ ولا أبْصارُكُمْ﴾</q> إلى قوله: <q>﴿مِنَ الخاسِرِينَ﴾</q>{1}. (١٣/٩٩) ٦٨٤٤٣- قال مقاتل بن سليمان: <q>﴿ويَوْمَ يُحْشَرُ أعْداءُ اللَّهِ إلى النّارِ فَهُمْ يُوزَعُونَ﴾</q> نزلت في صفوان بن أُميّة الجُمَحي، وفي ربيعة، وعبد ياليل ابني عمرو الثقفيين، إلى خمس آيات. ويقال: إنّ الثلاثة نفر: صفوان بن أُمية، وفرْقد بن ثُمامة، وأبو فاطمة، ... وذلك أنّ هؤلاء النفر الثلاثة كانوا في ظِلّ الكعبة يتكلّمون، فقال أحدهم: هل يعلم الله ما نقول؟ فقال الثاني: إنْ خفضْنا لم يعلم، وإنْ رفعْنا علِمه. فقال الثالث: إن كان الله يسمعُ إذا رفعْنا فإنه يسمع إذا خفضْنا. فسمع قولَهم عبدُ الله بن مسعود، فأخبَر بقولهم النبيَّ ﷺ؛ فأنزل الله في قولهم: <q>﴿وما كُنْتُمْ تَسْتَتِرُونَ أنْ يَشْهَدَ عَلَيْكُمْ سَمْعُكُمْ ولا أبْصارُكُمْ﴾</q> الآية{2}٥٧٤٤. (ز) ٥٧٤٤ ساق ابنُ عطية هذا القول، ثم علَّق (٧/٤٧٦) بقوله: «ويشبه أن يكون هذا بعد فتح مكة، فالآية مدنية، ويشبه أن رسول الله ﷺ قرأ الآية متمثّلًا بها عند إخبار عبد الله إياه». <q>﴿وَیَوۡمَ یُحۡشَرُ أَعۡدَاۤءُ ٱللَّهِ إِلَى ٱلنَّارِ فَهُمۡ یُوزَعُونَ ۝١٩﴾</q> - تفسير ٦٨٤٤٤- عن عبد الله بن عباس، في قوله: <q>﴿يُوزَعُونَ﴾</q>، قال: يُدفَعون{3}. (١٣/٩٨) ٦٨٤٤٥- عن عبد الله بن عباس -من طريق مقسم- <q>﴿ويَوْمَ يُحْشَرُ أعْداءُ اللَّهِ إلى النّارِ فَهُمْ يُوزَعُونَ﴾</q>، قال: يُحبَس أوّلُهم على آخرهم{4}. (١٣/٩٧) ٦٨٤٤٦- عن أبي رَزِين [مسعود بن مالك الأسدي]= (ز) ٦٨٤٤٧- ومجاهد بن جبر، مثله{5}. (١٣/٩٨) ٦٨٤٤٨- عن مجاهد بن جبر -من طريق منصور- في قوله -جلّ وعزّ-: <q>﴿يوم يحشر أعداء الله إلى النار فهم يوزعون﴾</q>، قال: يُحشَر أولُهم على آخرهم{6}. (ز) ٦٨٤٤٩- عن عكرمة مولى ابن عباس، في قوله: <q>﴿فَهُمْ يُوزَعُونَ﴾</q>، قال: يُحْبَسُون بعضًا على بعض{5}. (١٣/٩٨) ٦٨٤٥٠- عن قتادة بن دعامة -من طريق سعيد- <q>﴿فَهُمْ يُوزَعُونَ﴾</q>، قال: عليهم وزَعَة، ترُدّ أوّلهم على آخرهم{8}. (١٣/٩٨) ٦٨٤٥١- عن إسماعيل السُّدّيّ -من طريق أسباط- <q>﴿فَهُمْ يُوزَعُونَ﴾</q>، قال: يُحبس أوّلهم على آخرهم{9}. (ز) ٦٨٤٥٢- قال مقاتل بن سليمان: قوله: <q>﴿فَهُمْ يُوزَعُونَ﴾</q>، يعني: يُساقون إلى النار، تسوقهم خزنة جهنم{10}. (ز) ٦٨٤٥٣- عن عبد الملك ابن جُريْج، في قوله: <q>﴿ويَوْمَ يُحْشَرُ أعْداءُ اللَّهِ إلى النّارِ فَهُمْ يُوزَعُونَ﴾</q>، قال: الوزَعَة: السّاقَةُ من الملائكة يسوقونهم إلى النار، ويردّون الآخر على الأول{11}. (١٣/٩٨) ",footnotes:1:أخرجه البخاري ٦/١٢٩ (٤٨١٧)، ومسلم ٤/٢١٤١ (٢٧٧٥)، وابن جرير٢٠/٤١١-٤١٢، وإسحاق البستي ص٢٩٠، كذلك أخرج نحوه من طريق وهب بن زمعة.تفسير مقاتل بن سليمان ٣/٧٣٩-٧٤٠.عزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.أخرجه الطبرانى (١٢٠٧٦).عزاه السيوطي إلى عبد بن حميد.أخرجه إسحاق البستي ص٢٩٠.عزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ٢٠/٤٠٥ بنحوه. وذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٤/١٤٩-. وعزاه السيوطي إلى عبد بن حميد. وفي تفسير الثعلبي ٨/٢٩٠، وتفسير البغوي ٧/١٦٩ بلفظ: يُحبس أولهم على آخرهم ليتلاحقوا.أخرجه ابن جرير ٢٠/٤٠٥.تفسير مقاتل بن سليمان ٣/٧٣٩.عزاه السيوطي إلى ابن المنذر.
41,20," <q>﴿حَتَّىٰۤ إِذَا مَا جَاۤءُوهَا شَهِدَ عَلَیۡهِمۡ سَمۡعُهُمۡ وَأَبۡصَـٰرُهُمۡ وَجُلُودُهُم بِمَا كَانُوا۟ یَعۡمَلُونَ ۝٢٠﴾</q> - تفسير ٦٨٤٥٤- قال إسماعيل السُّدّيّ: <q>﴿حَتّى إذا ما جاؤُها شَهِدَ عَلَيْهِمْ سَمْعُهُمْ وأَبْصارُهُمْ وجُلُودُهُمْ﴾</q>، أراد بالجلود: الفرُوج{1}. (ز) ٦٨٤٥٥- عن حَرْملة، أنّه سمِع عبيد الله بن أبي جعفر يقول: <q>﴿حَتّى إذا ما جاءُوها شَهِدَ عَلَيْهِمْ سَمْعُهُمْ وأَبْصارُهُمْ وجُلُودُهُمْ﴾</q>، قال: جلودهم: الفروج{2}. (ز) ٦٨٤٥٦- عن زيد بن أسلم -من طريق مُبشّر بن عبيد- في قوله: <q>﴿وقالُوا لِجُلُودِهِمْ لِمَ شَهِدْتُمْ عَلَيْنا﴾</q>، قال: قالوا لفروجهم: لِمَ شهدتم علينا؟!{3}. (ز) ٦٨٤٥٧- عن رجل مِن آل أبي عقيل -من طريق الحكم الثقفي- <q>﴿وقالُوا لِجُلُودِهِمْ لِمَ شَهِدْتُمْ عَلَيْنا﴾</q>: إنما عنى: فروجهم، ولكن كنّى عنها{4}٥٧٤٥. (ز) ٥٧٤٥ انتقد ابنُ جرير (٢٠/٤٠٦) هذا القول الذي قاله السُّدّيّ، وابن زيد، وأبو جعفر، ورجل من آل عقيل -مستندًا للأغلب من لغة العرب- فقال: «وهذا القول الذي ذكرناه عمَّن ذكرنا عنه في معنى الجلود، وإن كان معنى يحتمله التأويل، فليس بالأغلب على معنى الجلود، ولا بالأشهر، وغير جائز نقل معنى ذلك المعروف على الشيء الأقرب إلى غيره إلا بحُجَّة يجب التسليم لها». ٦٨٤٥٨- قال مقاتل بن سليمان: <q>﴿حَتّى إذا ما جاءُوها﴾</q> يعني: النار، وعاينوها؛ قيل لهم: أين شركاؤكم الذين كنتم تزعمون في الدنيا؟ قالوا عند ذلك: <q>﴿واللَّهِ رَبِّنا ما كُنّا مُشْرِكِينَ﴾</q> [الأنعام:٢٣]. فختم اللهُ على أفواههم، وأوحى إلى الجوارح فنطقتْ بما كتمتِ الألسُن مِن الشرك؛ <q>﴿شَهِدَ عَلَيْهِمْ سَمْعُهُمْ وأَبْصارُهُمْ وجُلُودُهُمْ﴾</q> وأيديهم وأرجلهم <q>﴿بِما كانُوا يَعْمَلُونَ﴾</q> من الشرك{5}. (ز) ",footnotes:1:تفسير الثعلبي ٨/٢٩٠، وتفسير البغوي ٧/١٧٠.أخرجه عبد الله بن وهب في الجامع -تفسير القرآن ٢/٥٧ (١١٢)، وابن جرير ٢٠/٤٠٦.أخرجه ابن أبي الدنيا في التوبة -موسوعة الإمام ابن أبي الدنيا ٣/٤٢٥ (٢٠٣)-.أخرجه ابن جرير ٢٠/٤٠٦.تفسير مقاتل بن سليمان ٣/٧٣٩.
