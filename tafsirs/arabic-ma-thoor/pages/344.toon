quran[15]{c,v,t}:
23,28," <q>﴿فَإِذَا ٱسۡتَوَیۡتَ أَنتَ وَمَن مَّعَكَ عَلَى ٱلۡفُلۡكِ فَقُلِ ٱلۡحَمۡدُ لِلَّهِ ٱلَّذِی نَجَّىٰنَا مِنَ ٱلۡقَوۡمِ ٱلظَّـٰلِمِینَ ۝٢٨﴾</q> - تفسير ٥١٥٨١- قال مقاتل بن سليمان: ثم قال سبحانه: <q>﴿فإذا استويت أنت ومن معك﴾</q> مِن المؤمنين <q>﴿على الفلك﴾</q> يعني: السفينة؛ <q>﴿فقل الحمد لله الذي نجانا من القوم الظالمين﴾</q> يعني: المشركين{1}. (ز) ٥١٥٨٢- قال يحيى بن سلّام: قوله: <q>﴿فإذا استويت أنت ومن معك على الفلك﴾</q> كان معه امرأته، [وثلاثة] بنين له: سام، وحام، ويافث، ونساؤهم؛ فجميع مَن كان في السفينة ثمانية؛ <q>﴿فقل الحمد لله الذي نجانا من القوم الظالمين﴾</q> المشركين، وقال في آية أخرى: <q>﴿وقال اركبوا فيها بسم الله مجراها ومرساها إن ربي لغفور رحيم﴾</q> [هود:٤١]{2}. (ز) ",footnotes:1:تفسير مقاتل بن سليمان ٣/١٥٥.تفسير يحيى بن سلام ١/٣٩٩.
23,29," <q>﴿وَقُل رَّبِّ أَنزِلۡنِی مُنزَلࣰا مُّبَارَكࣰا وَأَنتَ خَیۡرُ ٱلۡمُنزِلِینَ ۝٢٩﴾</q> - قراءات ٥١٥٨٣- عن عاصم أنه قرأ: ‹أنزِلْنِي مَنزِلًا› بنصب الميم، وخفض الزاي{1}٤٥٤٠. (١٠/٥٨٥) ٤٥٤٠ اختُلِف في قراءة قوله: <q>﴿منزلا﴾</q>؛ فقرأ قوم بضم الميم، وفتح الزاي، وقرأ آخرون بفتح الميم، وكسر الزاي. وذكر ابنُ جرير (١٧/٣٨) أن الأولى بمعنى: أنزلني إنزالًا مباركًا. وأن الثانية بمعنى: أنزلني مكانًا مُباركًا وموضعًا. وبنحوه ابنُ عطية (٦/٢٩٢). <q>﴿وَقُل رَّبِّ أَنزِلۡنِی مُنزَلࣰا مُّبَارَكࣰا وَأَنتَ خَیۡرُ ٱلۡمُنزِلِینَ ۝٢٩﴾</q> - تفسير الآية ٥١٥٨٤- عن مجاهد بن جبر -من طريق ابن أبي نجيح، وابن جُرَيج- <q>﴿وقل رب أنزلني منزلا مباركا﴾</q>، قال: لنوح حين نزل مِن السفينة{2}. (١٠/٥٨٥) ٥١٥٨٥- عن قتادة بن دعامة -من طريق سعيد- <q>﴿وقل رب انزلني منزلا مباركا وأنت خير المنزلين﴾</q>، قال: يُعَلِّمكم كيف تقولون إذا ركبتم، وكيف تقولون إذا نزلتم، أمّا عند الركوب فـ:<q>﴿سبحان الذي سخر لنا هذا وما كنا له مقرنين وانا إلى ربنا لمنقلبون﴾</q> [الزخرف:١٣]، و<q>﴿بسم الله مجراها ومرساها إن ربي لغفور رحيم﴾</q> [هود:٤١]، وعند النزول: <q>﴿رب أنزلني منزلا مباركا وأنت خير المنزلين﴾</q>{3}. (١٠/٥٨٦) ٥١٥٨٦- عن قتادة بن دعامة -من طريق عثمان- قال: قد بَيَّن الله لكم ما تقولون إذا ركبتم في البر، وما تقولون إذا ركبتم في البحر؛ إذا ركبتم في البر قلتم: <q>﴿سبحان الذي سخر لنا هذا وما كنا له مقرنين (١٣) وإنا إلى ربنا لمنقلبون﴾</q> [الزخرف:١٣-١٤]، وإذا ركبتم في البحر قلتم: <q>﴿بسم الله مجراها ومرساها إن ربي لغفور رحيم﴾</q> [هود:٤١]{4}. (ز) ٥١٥٨٧- قال مقاتل بن سليمان: <q>﴿وقل رب أنزلني﴾</q> مِن السفينة <q>﴿منزلا مباركا وأنت خير المنزلين﴾</q> مِن غيرك. يعني بالبركة: أنّهم توالدوا وكثروا{5}. (ز) ٥١٥٨٨- قال يحيى بن سلّام: وسمعت الناس إذا نزلوا منزلًا قالوا هذا القول{6}. (ز) ",footnotes:1:عزاه السيوطي إلى عبد بن حميد. وهي قراءة أبي بكر عن عاصم، وقرأ بقية العشرة: <q>﴿مُنزَلًا﴾</q> بضم الميم، وفتح الزاي. انظر: النشر ٢/٣٢٨، والإتحاف ص٤٠٣.أخرجه يحيى بن سلام ١/٤٠٠ من طريق ابن مجاهد، وابن جرير ١٧/٣٨، وإسحاق البستي في تفسيره ص٣٩٤ من طريق ابن جريج. وعزاه السيوطي إلى ابن أبي شيبة، وعبد بن حميد، وابن المنذر، وابن أبي حاتم.أخرجه يحيى بن سلام ١/٣٩٩، وابن جرير ٢٠/٥٥٨-٥٥٩. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.أخرجه يحيى بن سلام ١/٣٩٩.تفسير مقاتل بن سليمان ٣/١٥٥.علَّقه يحيى بن سلام ١/٤٠٠.
23,30," <q>﴿إِنَّ فِی ذَ ٰ⁠لِكَ لَـَٔایَـٰتࣲ وَإِن كُنَّا لَمُبۡتَلِینَ ۝٣٠﴾</q> - تفسير ٥١٥٨٩- تفسير الحسن البصري: <q>﴿وإن كنا لمبتلين﴾</q> بالدين، يعني: ما أرسل به الرسل من عبادته{1}. (ز) ٥١٥٩٠- عن قتادة بن دعامة، <q>﴿إن في ذلك لآيات وان كنا لمبتلين﴾</q>، قال: ابتلى اللهُ الناسَ قبلكم{2}. (١٠/٥٨٦) ٥١٥٩١- قال مقاتل بن سليمان: <q>﴿إن في ذلك لآيات﴾</q> يقول: إنّ في هلاك قوم نوح بالغرق لعبرة لمن بعدهم، ثم قال: <q>﴿وإن﴾</q> يعني: وقد <q>﴿كنا لمبتلين﴾</q> بالغرق{3}. (ز) ٥١٥٩٢- قال يحيى بن سلّام: قوله: <q>﴿إن في ذلك﴾</q> مِن أمر قوم نوح وغرقهم <q>﴿لآيات﴾</q> لِمَن بعدهم{4}. (ز) ",footnotes:1:علَّقه يحيى بن سلام ١/٤٠٠.عزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.تفسير مقاتل بن سليمان ٣/١٥٥.تفسير يحيى بن سلام ١/٤٠٠.
23,31," <q>﴿ثُمَّ أَنشَأۡنَا مِنۢ بَعۡدِهِمۡ قَرۡنًا ءَاخَرِینَ ۝٣١﴾</q> - تفسير ٥١٥٩٣- عن أبي مالك غزوان الغفاري، في قوله: <q>﴿قرنا﴾</q>، قال: أُمَّة{1}. (١٠/٥٨٦) ٥١٥٩٤- قال مقاتل بن سليمان: <q>﴿ثم أنشأنا﴾</q> يعني: خلقنا <q>﴿من بعدهم﴾</q> يعني: مِن بعد قوم نوح <q>﴿قرنا آخرين﴾</q> وهم قوم هود ﵇{2}. (ز) ٥١٥٩٥- قال يحيى بن سلّام: قوله: <q>﴿ثم أنشأنا من بعدهم﴾</q> مِن بعد نوح <q>﴿قرنا آخرين﴾</q> يعني: عادًا{3}. (ز) ",footnotes:1:عزاه السيوطي إلى ابن أبي حاتم.تفسير مقاتل بن سليمان ٣/١٥٦.تفسير يحيى بن سلام ١/٤٠٠.
23,32," <q>﴿فَأَرۡسَلۡنَا فِیهِمۡ رَسُولࣰا مِّنۡهُمۡ أَنِ ٱعۡبُدُوا۟ ٱللَّهَ مَا لَكُم مِّنۡ إِلَـٰهٍ غَیۡرُهُۥۤۚ أَفَلَا تَتَّقُونَ ۝٣٢﴾</q> - تفسير ٥١٥٩٦- قال مقاتل بن سليمان: <q>﴿فأرسلنا فيهم رسولا منهم﴾</q> يعني: مِن أنفسهم؛ <q>﴿أن اعبدوا الله﴾</q> يعني: أن وحِّدوا الله، <q>﴿ما لكم من إله غيره﴾</q> يقول: ليس لكم رب غيره، <q>﴿أفلا تتقون﴾</q> يعني: أفَهَلّا تعبدون الله ﷿{1}. (ز) ٥١٥٩٧- قال يحيى بن سلّام: قوله: <q>﴿فأرسلنا فيهم رسولا منهم﴾</q> يعني: هودًا؛ <q>﴿أن اعبدوا الله ما لكم من إله غيره أفلا تتقون﴾</q>{2}. (ز) ",footnotes:1:تفسير مقاتل بن سليمان ٣/١٥٦.تفسير يحيى بن سلام ١/٤٠٠.
23,33," <q>﴿وَقَالَ ٱلۡمَلَأُ مِن قَوۡمِهِ ٱلَّذِینَ كَفَرُوا۟ وَكَذَّبُوا۟ بِلِقَاۤءِ ٱلۡـَٔاخِرَةِ وَأَتۡرَفۡنَـٰهُمۡ فِی ٱلۡحَیَوٰةِ ٱلدُّنۡیَا مَا هَـٰذَاۤ إِلَّا بَشَرࣱ مِّثۡلُكُمۡ یَأۡكُلُ مِمَّا تَأۡكُلُونَ مِنۡهُ وَیَشۡرَبُ مِمَّا تَشۡرَبُونَ ۝٣٣ وَلَىِٕنۡ أَطَعۡتُم بَشَرࣰا مِّثۡلَكُمۡ إِنَّكُمۡ إِذࣰا لَّخَـٰسِرُونَ ۝٣٤﴾</q> - تفسير ٥١٥٩٨- قال مقاتل بن سليمان: <q>﴿وقال الملأ﴾</q> يعني: الأشراف <q>﴿من قومه الذين كفروا﴾</q> بتوحيد الله ﷿، <q>﴿وكذبوا بلقاء الآخرة﴾</q> يعني: بالبعث الذي فيه جزاء الأعمال، <q>﴿وأترفناهم﴾</q> يعني: وأغنيناهم <q>﴿في الحياة الدنيا ما هذا﴾</q> يعنون: هودًا ﵇، <q>﴿إلا بشر مثلكم﴾</q> ليس له عليكم فضل؛ <q>﴿يأكل مما تأكلون منه ويشرب مما تشربون ولئن أطعتم بشرا مثلكم إنكم إذا لخاسرون﴾</q> يعني: لعَجَزة. مثلها في يوسف ﵇{1}. (ز) ٥١٥٩٩- قال يحيى بن سلّام: قوله: <q>﴿وقال الملأ من قومه الذين كفروا وكذبوا بلقاء الآخرة وأترفناهم في الحياة الدنيا﴾</q> وسَّعنا الدنيا عليهم، أي: في الرزق: <q>﴿ما هذا إلا بشر مثلكم يأكل مما تأكلون منه ويشرب مما تشربون (٣٣) ولئن أطعتم بشرا مثلكم﴾</q> فيما يدعوكم إليه <q>﴿إنكم إذا لخاسرون﴾</q> يعني: لعَجَزة{2}. (ز) ",footnotes:1:تفسير مقاتل بن سليمان ٣/١٥٦. ولعله يشير إلى قوله تعالى: <q>﴿قالُوا لَئِنْ أكَلَهُ الذِّئْبُ ونَحْنُ عُصْبَةٌ إنّا إذًا لَخاسِرُونَ﴾</q> [يوسف:١٤].تفسير يحيى بن سلام ١/٤٠٠.
  23,34,""
23,35," <q>﴿أَیَعِدُكُمۡ أَنَّكُمۡ إِذَا مِتُّمۡ وَكُنتُمۡ تُرَابࣰا وَعِظَـٰمًا أَنَّكُم مُّخۡرَجُونَ ۝٣٥﴾</q> - تفسير ٥١٦٠٠- قال مقاتل بن سليمان: <q>﴿أيعدكم﴾</q> هود <q>﴿أنكم إذا متم وكنتم ترابا وعظاما أنكم مخرجون﴾</q> من الأرض أحياء بعد الموت{1}. (ز) ٥١٦٠١- قال يحيى بن سلّام: قوله: <q>﴿أيعدكم﴾</q> يقوله بعضهم لبعض على الاستفهام <q>﴿أنكم إذا متم وكنتم ترابا وعظاما أنكم مخرجون﴾</q> مبعوثون، أي: قد وعدكم ذلك، تُكَذِّبون بالبعث{2}. (ز) ",footnotes:1:تفسير مقاتل بن سليمان ٣/١٥٦.تفسير يحيى بن سلام ١/٤٠٠.
23,36," <q>﴿هَیۡهَاتَ هَیۡهَاتَ لِمَا تُوعَدُونَ ۝٣٦﴾</q> - تفسير ٥١٦٠٢- عن عبد الله بن عباس -من طريق علي- في قوله: <q>﴿هيهات هيهات﴾</q>، قال: بعيد بعيد{1}. (١٠/٥٨٦) ٥١٦٠٣- عن قتادة بن دعامة -من طريق سعيد- قال: <q>﴿هيهات هيهات لما توعدون﴾</q>، قال: تَباعَد البعثُ في أنفس القوم {2}. (١٠/٥٨٦) ٥١٦٠٤- قال مقاتل بن سليمان: <q>﴿هيهات هيهات لما توعدون﴾</q>، يقول: هذا حديث قد درس، فلا يُذكَر{3}. (ز) ٥١٦٠٥- قال يحيى بن سلّام: أي: لا يبعثون. يقوله بعضهم لبعض{4}. (ز) ",footnotes:1:أخرجه ابن جرير ١٧/٤٥، وابن أبي حاتم -كما في تغليق التعليق ٤/٢٦٣-، والإتقان ٢/٣١. وعزاه السيوطي إلى ابن المنذر.أخرجه يحيى بن سلام ١/٤٠٠، وأخرجه عبد الرزاق ٢/٤٥، وعبد بن حميد -كما في فتح الباري ٨/٤٤٥-، وابن جرير ١٧/٤٢ من طريق معمر بلفظ: يعني: البعث. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم بلفظ: تباعد ذلك في أنفسهم، يعني: البعث بعد الموت.تفسير مقاتل بن سليمان ٣/١٥٦.تفسير يحيى بن سلام ١/٤٠٠.
23,37," <q>﴿إِنۡ هِیَ إِلَّا حَیَاتُنَا ٱلدُّنۡیَا نَمُوتُ وَنَحۡیَا وَمَا نَحۡنُ بِمَبۡعُوثِینَ ۝٣٧﴾</q> - تفسير ٥١٦٠٦- قال مقاتل بن سليمان: <q>﴿إن هي إلا حياتنا الدنيا نموت ونحيا﴾</q> يعني: نموت نحن، ويحيا آخرون من أصلابنا، فنحن كذلك أبدًا، <q>﴿وما نحن بمبعوثين﴾</q> بعد الموت. مثلُها في الجاثية{1}. (ز) ٥١٦٠٧- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿إن هي إلا حياتنا الدنيا نموت ونحيا وما نحن بمبعوثين﴾</q>، قال: يقول: ليس آخرة ولا بعث، يكفرون بالبعث، يقولون: إنما هي حياتنا هذه، ثم نموت ولا نحيا، يموت هؤلاء، ويحيا هؤلاء. يقولون: إنما الناس كالزرع، يُحصَد هذا، وينبت هذا. يقولون: يموت هؤلاء، ويأتي آخرون. وقرأ: <q>﴿وقال الذين كفروا هل ندلكم على رجل ينبئكم إذا مزقتم كل ممزق إنكم لفي خلق جديد﴾</q> [سبأ:٧]، وقرأ: <q>﴿لا تأتينا الساعة قل بلى وربي لتأتينكم﴾</q> [سبأ:٣]{2}. (ز) ٥١٦٠٨- قال يحيى بن سلّام: <q>﴿إن هي إلا حياتنا الدنيا نموت ونحيا﴾</q> أي: نموت ونُولَد، <q>﴿وما نحن بمبعوثين﴾</q>{3}. (ز) ",footnotes:1:تفسير مقاتل بن سليمان ٣/١٥٦. يريد قوله تعالى: <q>﴿وقالوا ما هي إلا حياتنا الدنيا نموت ونحيا وما يهلكنا إلا الدهر﴾</q> [الجاثية:٢٤].أخرجه ابن جرير ١٧/٤٤.تفسير يحيى بن سلام ١/٤٠٠.
23,38," <q>﴿إِنۡ هُوَ إِلَّا رَجُلٌ ٱفۡتَرَىٰ عَلَى ٱللَّهِ كَذِبࣰا وَمَا نَحۡنُ لَهُۥ بِمُؤۡمِنِینَ ۝٣٨﴾</q> - تفسير ٥١٦٠٩- قال يحيى بن سلّام: <q>﴿إن هو إلا رجل﴾</q> يعنون: هودًا <q>﴿افترى على الله كذبا﴾</q> يزعم أن الله أرسله، <q>﴿وما نحن له بمؤمنين﴾</q> أي: بمُصَدِّقين{1}. (ز) ",footnotes:1:تفسير يحيى بن سلام ١/٤٠٠.
23,39," <q>﴿قَالَ رَبِّ ٱنصُرۡنِی بِمَا كَذَّبُونِ ۝٣٩﴾</q> - تفسير ٥١٦١٠- قال مقاتل بن سليمان: <q>﴿قال﴾</q> هو: <q>﴿رب انصرني بما كذبون﴾</q>، وذلك أنّ هودًا ﵇ أخبرهم أنّ العذابَ نازِلٌ بهم في الدنيا، فكَذَّبوه، فقال: رب انصرني بما كذبون في أمر العذاب{1}. (ز) ",footnotes:1:تفسير مقاتل بن سليمان ٣/١٥٧.
23,40," <q>﴿قَالَ عَمَّا قَلِیلࣲ لَّیُصۡبِحُنَّ نَـٰدِمِینَ ۝٤٠﴾</q> - تفسير ٥١٦١١- قال يحيى بن سلّام: <q>﴿عما قليل﴾</q>، أي: عن قليل. والميم والألف صِلَةٌ في الكلام. وهو تفسير إسماعيل السُّدِّيّ{1}. (ز) ٥١٦١٢- قال مقاتل بن سليمان: <q>﴿قال عما قليل﴾</q> قال: عن قليل <q>﴿ليصبحن نادمين﴾</q>{2}. (ز) ",footnotes:1:علَّقه يحيى بن سلام ١/٤٠١.تفسير مقاتل بن سليمان ٣/١٥٧.
23,41," <q>﴿فَأَخَذَتۡهُمُ ٱلصَّیۡحَةُ بِٱلۡحَقِّ فَجَعَلۡنَـٰهُمۡ غُثَاۤءࣰۚ فَبُعۡدࣰا لِّلۡقَوۡمِ ٱلظَّـٰلِمِینَ ۝٤١﴾</q> - تفسير ٥١٦١٣- عن عبد الله بن عباس -من طريق العوفي- في قوله: <q>﴿فجعلناهم غثاء﴾</q>، قال: جُعِلوا كالشيء الميِّت البالي مِن الشجر{1}. (١٠/٥٨٦) ٥١٦١٤- عن مجاهد بن جبر -من طريق ابن جريج- قال: أولئك ثمود. يعني: قوله: <q>﴿فجعلناهم غثاء فبعدا للقوم الظالمين﴾</q>{2}. (ز) ٥١٦١٥- عن مجاهد بن جبر -من طريق ابن أبي نجيح- <q>﴿فجعلناهم غثاء﴾</q>، قال: كالرَّمِيمِ الهامِد الذي يحتمل السيل؛ ثمود احتُمِلُوا كذلك{3}. (١٠/٥٨٧) ٥١٦١٦- تفسير مجاهد بن جبر -من طريق أبي يحيى- <q>﴿فجعلناهم غثاء﴾</q>: كالشيء البالي{4}. (ز) ٥١٦١٧- تفسير الحسن البصري: قال الله: <q>﴿فأخذتهم الصيحة بالحق﴾</q>، الصيحة: العذاب{5}. (ز) ٥١٦١٨- عن قتادة بن دعامة -من طريق معمر- <q>﴿فجعلناهم غثاء﴾</q>، قال: هو الشيء البالي{6}. (١٠/٥٨٧) ٥١٦١٩- عن عبد الملك ابن جُرَيْج -من طريق حجاج- <q>﴿فجعلناهم غثاء﴾</q>، قال: كالرَّميم الهامد الذي يحتمل السيل{1}. (ز) ٥١٦٢٠- قال مقاتل بن سليمان: <q>﴿فأخذتهم الصيحة بالحق﴾</q> يعني: صيحة جبريل ﵇، فصاح صيحة واحدة، فماتوا أجمعين، فلم يَبْقَ منهم أحدٌ، <q>﴿فجعلناهم غثاء﴾</q> يعني: كالشيء البالي من نبت الأرض يَحْمِلُه السَّيْل، فشَبَّه أجسادَهم بالشيء البالي، <q>﴿فبعدا﴾</q> في الهلاك <q>﴿للقوم الظالمين﴾</q> يعني: المشركين{8}. (ز) ٥١٦٢١- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿فجعلناهم غثاء﴾</q>، قال: هذا مَثَل ضربه الله{2}. (ز) ٥١٦٢٢- قال يحيى بن سلّام: قال بعضهم: مَثَلُ النبات إذا صار غثاءً، فتَهَشَّم بعد إذ كان أخضر، <q>﴿فبعدا للقوم الظالمين﴾</q> المشركين{5}. (ز) ",footnotes:1:أخرجه ابن جرير ١٧/٤٦.أخرجه ابن جرير ١٧/٤٧.أخرجه ابن جرير ١٧/٤٧،٤٦، ومن طريق ابن جريج بلفظ: أولئك ثمود، يعني: قوله: <q>﴿فجعلناهم غثاء فبعدا للقوم الظالمين﴾</q>. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.أخرجه يحيى بن سلام ١/٤٠١.علَّقه يحيى بن سلام ١/٤٠١.أخرجه عبد الرزاق ٢/٤٥، وابن جرير ١٧/٤٧. وعزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ١٧/٤٦.تفسير مقاتل بن سليمان ٣/١٥٧.أخرجه ابن جرير ١٧/٤٧.علَّقه يحيى بن سلام ١/٤٠١.
23,42," <q>﴿ثُمَّ أَنشَأۡنَا مِنۢ بَعۡدِهِمۡ قُرُونًا ءَاخَرِینَ ۝٤٢ مَا تَسۡبِقُ مِنۡ أُمَّةٍ أَجَلَهَا وَمَا یَسۡتَـٔۡخِرُونَ ۝٤٣﴾</q> - تفسير ٥١٦٢٣- قال مقاتل بن سليمان: <q>﴿ثم أنشأنا﴾</q> يعني: خلقنا <q>﴿من بعدهم قرونا آخرين﴾</q> يعني: قومًا آخرين، فأهلكناهم بالعذاب في الدنيا، <q>﴿ما تسبق من أمة أجلها وما يستأخرون﴾</q> عنه{1}. (ز) ٥١٦٢٤- قال يحيى بن سلّام قوله: <q>﴿ثم أنشأنا من بعدهم﴾</q> من بعد الهالكين <q>﴿قرونا آخرين (٤٢) ما تسبق من أمة أجلها﴾</q> يعني: الوقت الذي يُهْلِكُها فيه، <q>﴿وما يستأخرون﴾</q> عن الوقت ساعةً، ولا يستقدمون من قبل الوقت{2}. (ز) ",footnotes:1:تفسير مقاتل بن سليمان ٣/١٥٧.تفسير يحيى بن سلام ١/٤٠١.
