quran[15]{c,v,t}:
  23,28,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿فَإِذَا ٱسۡتَوَیۡتَ أَنتَ وَمَن مَّعَكَ عَلَى ٱلۡفُلۡكِ فَقُلِ ٱلۡحَمۡدُ لِلَّهِ ٱلَّذِی نَجَّىٰنَا مِنَ ٱلۡقَوۡمِ ٱلظَّـٰلِمِینَ ۝٢٨﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥١٥٨١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثم قال سبحانه: <span class="qpc-hafs">﴿فإذا استويت أنت ومن معك﴾</span> مِن المؤمنين <span class="qpc-hafs">﴿على الفلك﴾</span> يعني: السفينة؛ <span class="qpc-hafs">﴿فقل الحمد لله الذي نجانا من القوم الظالمين﴾</span> يعني: المشركين{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥١٥٨٢<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: قوله: <span class="qpc-hafs">﴿فإذا استويت أنت ومن معك على الفلك﴾</span> كان معه امرأته، [وثلاثة] بنين له: سام، وحام، ويافث، ونساؤهم؛ فجميع مَن كان في السفينة ثمانية؛ <span class="qpc-hafs">﴿فقل الحمد لله الذي نجانا من القوم الظالمين﴾</span> المشركين، وقال في آية أخرى: <span class="qpc-hafs">﴿وقال اركبوا فيها بسم الله مجراها ومرساها إن ربي لغفور رحيم﴾</span> [هود:٤١]{2}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٣/١٥٥.|2:تفسير يحيى بن سلام ١/٣٩٩.
  23,29,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَقُل رَّبِّ أَنزِلۡنِی مُنزَلࣰا مُّبَارَكࣰا وَأَنتَ خَیۡرُ ٱلۡمُنزِلِینَ ۝٢٩﴾</span> - قراءات</h3></p><p><div></p><p><p><span class="item-no">٥١٥٨٣<span class="dash">-</span></span> عن <span class="name-2">عاصم</span> أنه قرأ: ‹أنزِلْنِي مَنزِلًا› بنصب الميم، وخفض الزاي{1}<span class=comment-ref>٤٥٤٠</span>. (١٠/٥٨٥)</p></p><p></div></p><p><div><span class=comment-ref>٤٥٤٠</span> اختُلِف في قراءة قوله: <span class="qpc-hafs">﴿منزلا﴾</span>؛ <b>فقرأ قوم</b> بضم الميم، وفتح الزاي، <b>وقرأ آخرون</b> بفتح الميم، وكسر الزاي.</p><p>و<span class="comment-type-4">ذكر</span> <u>ابنُ جرير</u> (١٧/٣٨) أن <b>الأولى بمعنى</b>: أنزلني إنزالًا مباركًا. وأن <b>الثانية بمعنى</b>: أنزلني مكانًا مُباركًا وموضعًا.</p><p>و<span class="comment-type-4">بنحوه</span> <u>ابنُ عطية</u> (٦/٢٩٢).</div></p><p><h3><span class="qpc-hafs">﴿وَقُل رَّبِّ أَنزِلۡنِی مُنزَلࣰا مُّبَارَكࣰا وَأَنتَ خَیۡرُ ٱلۡمُنزِلِینَ ۝٢٩﴾</span> - تفسير الآية</h3></p><p><div></p><p><p><span class="item-no">٥١٥٨٤<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح، وابن جُرَيج- <span class="qpc-hafs">﴿وقل رب أنزلني منزلا مباركا﴾</span>، قال: لنوح حين نزل مِن السفينة{2}. (١٠/٥٨٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥١٥٨٥<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿وقل رب انزلني منزلا مباركا وأنت خير المنزلين﴾</span>، قال: يُعَلِّمكم كيف تقولون إذا ركبتم، وكيف تقولون إذا نزلتم، أمّا عند الركوب فـ:<span class="qpc-hafs">﴿سبحان الذي سخر لنا هذا وما كنا له مقرنين وانا إلى ربنا لمنقلبون﴾</span> [الزخرف:١٣]، و<span class="qpc-hafs">﴿بسم الله مجراها ومرساها إن ربي لغفور رحيم﴾</span> [هود:٤١]، وعند النزول: <span class="qpc-hafs">﴿رب أنزلني منزلا مباركا وأنت خير المنزلين﴾</span>{3}. (١٠/٥٨٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥١٥٨٦<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق عثمان- قال: قد بَيَّن الله لكم ما تقولون إذا ركبتم في البر، وما تقولون إذا ركبتم في البحر؛ إذا ركبتم في البر قلتم: <span class="qpc-hafs">﴿سبحان الذي سخر لنا هذا وما كنا له مقرنين (١٣) وإنا إلى ربنا لمنقلبون﴾</span> [الزخرف:١٣-١٤]، وإذا ركبتم في البحر قلتم: <span class="qpc-hafs">﴿بسم الله مجراها ومرساها إن ربي لغفور رحيم﴾</span> [هود:٤١]{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥١٥٨٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وقل رب أنزلني﴾</span> مِن السفينة <span class="qpc-hafs">﴿منزلا مباركا وأنت خير المنزلين﴾</span> مِن غيرك. يعني بالبركة: أنّهم توالدوا وكثروا{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥١٥٨٨<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: وسمعت الناس إذا نزلوا منزلًا قالوا هذا القول{6}. (ز)</p></p><p></div></p></div>",footnotes:1:عزاه السيوطي إلى عبد بن حميد.</p><p>وهي قراءة أبي بكر عن عاصم، وقرأ بقية العشرة: <span class="qpc-hafs">﴿مُنزَلًا﴾</span> بضم الميم، وفتح الزاي. انظر: النشر ٢/٣٢٨، والإتحاف ص٤٠٣.|2:أخرجه يحيى بن سلام ١/٤٠٠ من طريق ابن مجاهد، وابن جرير ١٧/٣٨، وإسحاق البستي في تفسيره ص٣٩٤ من طريق ابن جريج. وعزاه السيوطي إلى ابن أبي شيبة، وعبد بن حميد، وابن المنذر، وابن أبي حاتم.|3:أخرجه يحيى بن سلام ١/٣٩٩، وابن جرير ٢٠/٥٥٨-٥٥٩. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.|4:أخرجه يحيى بن سلام ١/٣٩٩.|5:تفسير مقاتل بن سليمان ٣/١٥٥.|6:علَّقه يحيى بن سلام ١/٤٠٠.
  23,30,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿إِنَّ فِی ذَ ٰ⁠لِكَ لَـَٔایَـٰتࣲ وَإِن كُنَّا لَمُبۡتَلِینَ ۝٣٠﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥١٥٨٩<span class="dash">-</span></span> تفسير <span class="name-2">الحسن البصري</span>: <span class="qpc-hafs">﴿وإن كنا لمبتلين﴾</span> بالدين، يعني: ما أرسل به الرسل من عبادته{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥١٥٩٠<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span>، <span class="qpc-hafs">﴿إن في ذلك لآيات وان كنا لمبتلين﴾</span>، قال: ابتلى اللهُ الناسَ قبلكم{2}. (١٠/٥٨٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥١٥٩١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿إن في ذلك لآيات﴾</span> يقول: إنّ في هلاك قوم نوح بالغرق لعبرة لمن بعدهم، ثم قال: <span class="qpc-hafs">﴿وإن﴾</span> يعني: وقد <span class="qpc-hafs">﴿كنا لمبتلين﴾</span> بالغرق{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥١٥٩٢<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: قوله: <span class="qpc-hafs">﴿إن في ذلك﴾</span> مِن أمر قوم نوح وغرقهم <span class="qpc-hafs">﴿لآيات﴾</span> لِمَن بعدهم{4}. (ز)</p></p><p></div></p></div>",footnotes:1:علَّقه يحيى بن سلام ١/٤٠٠.|2:عزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.|3:تفسير مقاتل بن سليمان ٣/١٥٥.|4:تفسير يحيى بن سلام ١/٤٠٠.
  23,31,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿ثُمَّ أَنشَأۡنَا مِنۢ بَعۡدِهِمۡ قَرۡنًا ءَاخَرِینَ ۝٣١﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥١٥٩٣<span class="dash">-</span></span> عن <span class="name-2">أبي مالك غزوان الغفاري</span>، في قوله: <span class="qpc-hafs">﴿قرنا﴾</span>، قال: أُمَّة{1}. (١٠/٥٨٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥١٥٩٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ثم أنشأنا﴾</span> يعني: خلقنا <span class="qpc-hafs">﴿من بعدهم﴾</span> يعني: مِن بعد قوم نوح <span class="qpc-hafs">﴿قرنا آخرين﴾</span> وهم قوم هود ﵇{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥١٥٩٥<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: قوله: <span class="qpc-hafs">﴿ثم أنشأنا من بعدهم﴾</span> مِن بعد نوح <span class="qpc-hafs">﴿قرنا آخرين﴾</span> يعني: عادًا{3}. (ز)</p></p><p></div></p></div>",footnotes:1:عزاه السيوطي إلى ابن أبي حاتم.|2:تفسير مقاتل بن سليمان ٣/١٥٦.|3:تفسير يحيى بن سلام ١/٤٠٠.
  23,32,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿فَأَرۡسَلۡنَا فِیهِمۡ رَسُولࣰا مِّنۡهُمۡ أَنِ ٱعۡبُدُوا۟ ٱللَّهَ مَا لَكُم مِّنۡ إِلَـٰهٍ غَیۡرُهُۥۤۚ أَفَلَا تَتَّقُونَ ۝٣٢﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥١٥٩٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فأرسلنا فيهم رسولا منهم﴾</span> يعني: مِن أنفسهم؛ <span class="qpc-hafs">﴿أن اعبدوا الله﴾</span> يعني: أن وحِّدوا الله، <span class="qpc-hafs">﴿ما لكم من إله غيره﴾</span> يقول: ليس لكم رب غيره، <span class="qpc-hafs">﴿أفلا تتقون﴾</span> يعني: أفَهَلّا تعبدون الله ﷿{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥١٥٩٧<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: قوله: <span class="qpc-hafs">﴿فأرسلنا فيهم رسولا منهم﴾</span> يعني: هودًا؛ <span class="qpc-hafs">﴿أن اعبدوا الله ما لكم من إله غيره أفلا تتقون﴾</span>{2}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٣/١٥٦.|2:تفسير يحيى بن سلام ١/٤٠٠.
  23,33,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَقَالَ ٱلۡمَلَأُ مِن قَوۡمِهِ ٱلَّذِینَ كَفَرُوا۟ وَكَذَّبُوا۟ بِلِقَاۤءِ ٱلۡـَٔاخِرَةِ وَأَتۡرَفۡنَـٰهُمۡ فِی ٱلۡحَیَوٰةِ ٱلدُّنۡیَا مَا هَـٰذَاۤ إِلَّا بَشَرࣱ مِّثۡلُكُمۡ یَأۡكُلُ مِمَّا تَأۡكُلُونَ مِنۡهُ وَیَشۡرَبُ مِمَّا تَشۡرَبُونَ ۝٣٣ وَلَىِٕنۡ أَطَعۡتُم بَشَرࣰا مِّثۡلَكُمۡ إِنَّكُمۡ إِذࣰا لَّخَـٰسِرُونَ ۝٣٤﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥١٥٩٨<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وقال الملأ﴾</span> يعني: الأشراف <span class="qpc-hafs">﴿من قومه الذين كفروا﴾</span> بتوحيد الله ﷿، <span class="qpc-hafs">﴿وكذبوا بلقاء الآخرة﴾</span> يعني: بالبعث الذي فيه جزاء الأعمال، <span class="qpc-hafs">﴿وأترفناهم﴾</span> يعني: وأغنيناهم <span class="qpc-hafs">﴿في الحياة الدنيا ما هذا﴾</span> يعنون: هودًا ﵇، <span class="qpc-hafs">﴿إلا بشر مثلكم﴾</span> ليس له عليكم فضل؛ <span class="qpc-hafs">﴿يأكل مما تأكلون منه ويشرب مما تشربون ولئن أطعتم بشرا مثلكم إنكم إذا لخاسرون﴾</span> يعني: لعَجَزة. مثلها في يوسف ﵇{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥١٥٩٩<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: قوله: <span class="qpc-hafs">﴿وقال الملأ من قومه الذين كفروا وكذبوا بلقاء الآخرة وأترفناهم في الحياة الدنيا﴾</span> وسَّعنا الدنيا عليهم، أي: في الرزق: <span class="qpc-hafs">﴿ما هذا إلا بشر مثلكم يأكل مما تأكلون منه ويشرب مما تشربون (٣٣) ولئن أطعتم بشرا مثلكم﴾</span> فيما يدعوكم إليه <span class="qpc-hafs">﴿إنكم إذا لخاسرون﴾</span> يعني: لعَجَزة{2}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٣/١٥٦. ولعله يشير إلى قوله تعالى: <span class="qpc-hafs">﴿قالُوا لَئِنْ أكَلَهُ الذِّئْبُ ونَحْنُ عُصْبَةٌ إنّا إذًا لَخاسِرُونَ﴾</span> [يوسف:١٤].|2:تفسير يحيى بن سلام ١/٤٠٠.
  23,34,""
  23,35,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿أَیَعِدُكُمۡ أَنَّكُمۡ إِذَا مِتُّمۡ وَكُنتُمۡ تُرَابࣰا وَعِظَـٰمًا أَنَّكُم مُّخۡرَجُونَ ۝٣٥﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥١٦٠٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿أيعدكم﴾</span> هود <span class="qpc-hafs">﴿أنكم إذا متم وكنتم ترابا وعظاما أنكم مخرجون﴾</span> من الأرض أحياء بعد الموت{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥١٦٠١<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: قوله: <span class="qpc-hafs">﴿أيعدكم﴾</span> يقوله بعضهم لبعض على الاستفهام <span class="qpc-hafs">﴿أنكم إذا متم وكنتم ترابا وعظاما أنكم مخرجون﴾</span> مبعوثون، أي: قد وعدكم ذلك، تُكَذِّبون بالبعث{2}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٣/١٥٦.|2:تفسير يحيى بن سلام ١/٤٠٠.
  23,36,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿هَیۡهَاتَ هَیۡهَاتَ لِمَا تُوعَدُونَ ۝٣٦﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥١٦٠٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- في قوله: <span class="qpc-hafs">﴿هيهات هيهات﴾</span>، قال: بعيد بعيد{1}. (١٠/٥٨٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥١٦٠٣<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- قال: <span class="qpc-hafs">﴿هيهات هيهات لما توعدون﴾</span>، قال: تَباعَد البعثُ في أنفس القوم {2}. (١٠/٥٨٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥١٦٠٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿هيهات هيهات لما توعدون﴾</span>، يقول: هذا حديث قد درس، فلا يُذكَر{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥١٦٠٥<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: أي: لا يبعثون. يقوله بعضهم لبعض{4}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ١٧/٤٥، وابن أبي حاتم -كما في تغليق التعليق ٤/٢٦٣-، والإتقان ٢/٣١. وعزاه السيوطي إلى ابن المنذر.|2:أخرجه يحيى بن سلام ١/٤٠٠، وأخرجه عبد الرزاق ٢/٤٥، وعبد بن حميد -كما في فتح الباري ٨/٤٤٥-، وابن جرير ١٧/٤٢ من طريق معمر بلفظ: يعني: البعث. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم بلفظ: تباعد ذلك في أنفسهم، يعني: البعث بعد الموت.|3:تفسير مقاتل بن سليمان ٣/١٥٦.|4:تفسير يحيى بن سلام ١/٤٠٠.
  23,37,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿إِنۡ هِیَ إِلَّا حَیَاتُنَا ٱلدُّنۡیَا نَمُوتُ وَنَحۡیَا وَمَا نَحۡنُ بِمَبۡعُوثِینَ ۝٣٧﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥١٦٠٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿إن هي إلا حياتنا الدنيا نموت ونحيا﴾</span> يعني: نموت نحن، ويحيا آخرون من أصلابنا، فنحن كذلك أبدًا، <span class="qpc-hafs">﴿وما نحن بمبعوثين﴾</span> بعد الموت. مثلُها في الجاثية{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥١٦٠٧<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿إن هي إلا حياتنا الدنيا نموت ونحيا وما نحن بمبعوثين﴾</span>، قال: يقول: ليس آخرة ولا بعث، يكفرون بالبعث، يقولون: إنما هي حياتنا هذه، ثم نموت ولا نحيا، يموت هؤلاء، ويحيا هؤلاء. يقولون: إنما الناس كالزرع، يُحصَد هذا، وينبت هذا. يقولون: يموت هؤلاء، ويأتي آخرون. وقرأ: <span class="qpc-hafs">﴿وقال الذين كفروا هل ندلكم على رجل ينبئكم إذا مزقتم كل ممزق إنكم لفي خلق جديد﴾</span> [سبأ:٧]، وقرأ: <span class="qpc-hafs">﴿لا تأتينا الساعة قل بلى وربي لتأتينكم﴾</span> [سبأ:٣]{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥١٦٠٨<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿إن هي إلا حياتنا الدنيا نموت ونحيا﴾</span> أي: نموت ونُولَد، <span class="qpc-hafs">﴿وما نحن بمبعوثين﴾</span>{3}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٣/١٥٦. يريد قوله تعالى: <span class="qpc-hafs">﴿وقالوا ما هي إلا حياتنا الدنيا نموت ونحيا وما يهلكنا إلا الدهر﴾</span> [الجاثية:٢٤].|2:أخرجه ابن جرير ١٧/٤٤.|3:تفسير يحيى بن سلام ١/٤٠٠.
  23,38,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿إِنۡ هُوَ إِلَّا رَجُلٌ ٱفۡتَرَىٰ عَلَى ٱللَّهِ كَذِبࣰا وَمَا نَحۡنُ لَهُۥ بِمُؤۡمِنِینَ ۝٣٨﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥١٦٠٩<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿إن هو إلا رجل﴾</span> يعنون: هودًا <span class="qpc-hafs">﴿افترى على الله كذبا﴾</span> يزعم أن الله أرسله، <span class="qpc-hafs">﴿وما نحن له بمؤمنين﴾</span> أي: بمُصَدِّقين{1}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير يحيى بن سلام ١/٤٠٠.
  23,39,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿قَالَ رَبِّ ٱنصُرۡنِی بِمَا كَذَّبُونِ ۝٣٩﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥١٦١٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿قال﴾</span> هو: <span class="qpc-hafs">﴿رب انصرني بما كذبون﴾</span>، وذلك أنّ هودًا ﵇ أخبرهم أنّ العذابَ نازِلٌ بهم في الدنيا، فكَذَّبوه، فقال: رب انصرني بما كذبون في أمر العذاب{1}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٣/١٥٧.
  23,40,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿قَالَ عَمَّا قَلِیلࣲ لَّیُصۡبِحُنَّ نَـٰدِمِینَ ۝٤٠﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥١٦١١<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿عما قليل﴾</span>، أي: عن قليل. والميم والألف صِلَةٌ في الكلام. وهو تفسير <span class="name-2">إسماعيل السُّدِّيّ</span>{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥١٦١٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿قال عما قليل﴾</span> قال: عن قليل <span class="qpc-hafs">﴿ليصبحن نادمين﴾</span>{2}. (ز)</p></p><p></div></p></div>",footnotes:1:علَّقه يحيى بن سلام ١/٤٠١.|2:تفسير مقاتل بن سليمان ٣/١٥٧.
  23,41,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿فَأَخَذَتۡهُمُ ٱلصَّیۡحَةُ بِٱلۡحَقِّ فَجَعَلۡنَـٰهُمۡ غُثَاۤءࣰۚ فَبُعۡدࣰا لِّلۡقَوۡمِ ٱلظَّـٰلِمِینَ ۝٤١﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥١٦١٣<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق العوفي- في قوله: <span class="qpc-hafs">﴿فجعلناهم غثاء﴾</span>، قال: جُعِلوا كالشيء الميِّت البالي مِن الشجر{1}. (١٠/٥٨٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥١٦١٤<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن جريج- قال: أولئك ثمود. يعني: قوله: <span class="qpc-hafs">﴿فجعلناهم غثاء فبعدا للقوم الظالمين﴾</span>{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥١٦١٥<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- <span class="qpc-hafs">﴿فجعلناهم غثاء﴾</span>، قال: كالرَّمِيمِ الهامِد الذي يحتمل السيل؛ ثمود احتُمِلُوا كذلك{3}. (١٠/٥٨٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥١٦١٦<span class="dash">-</span></span> تفسير <span class="name-2">مجاهد بن جبر</span> -من طريق أبي يحيى- <span class="qpc-hafs">﴿فجعلناهم غثاء﴾</span>: كالشيء البالي{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥١٦١٧<span class="dash">-</span></span> تفسير <span class="name-2">الحسن البصري</span>: قال الله: <span class="qpc-hafs">﴿فأخذتهم الصيحة بالحق﴾</span>، الصيحة: العذاب{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥١٦١٨<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- <span class="qpc-hafs">﴿فجعلناهم غثاء﴾</span>، قال: هو الشيء البالي{6}. (١٠/٥٨٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥١٦١٩<span class="dash">-</span></span> عن <span class="name-3">عبد الملك ابن جُرَيْج</span> -من طريق حجاج- <span class="qpc-hafs">﴿فجعلناهم غثاء﴾</span>، قال: كالرَّميم الهامد الذي يحتمل السيل{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥١٦٢٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فأخذتهم الصيحة بالحق﴾</span> يعني: صيحة جبريل ﵇، فصاح صيحة واحدة، فماتوا أجمعين، فلم يَبْقَ منهم أحدٌ، <span class="qpc-hafs">﴿فجعلناهم غثاء﴾</span> يعني: كالشيء البالي من نبت الأرض يَحْمِلُه السَّيْل، فشَبَّه أجسادَهم بالشيء البالي، <span class="qpc-hafs">﴿فبعدا﴾</span> في الهلاك <span class="qpc-hafs">﴿للقوم الظالمين﴾</span> يعني: المشركين{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥١٦٢١<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿فجعلناهم غثاء﴾</span>، قال: هذا مَثَل ضربه الله{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥١٦٢٢<span class="dash">-</span></span> قال يحيى بن سلّام: قال بعضهم: مَثَلُ النبات إذا صار غثاءً، فتَهَشَّم بعد إذ كان أخضر، <span class="qpc-hafs">﴿فبعدا للقوم الظالمين﴾</span> المشركين{5}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ١٧/٤٦.|2:أخرجه ابن جرير ١٧/٤٧.|3:أخرجه ابن جرير ١٧/٤٧،٤٦، ومن طريق ابن جريج بلفظ: أولئك ثمود، يعني: قوله: <span class="qpc-hafs">﴿فجعلناهم غثاء فبعدا للقوم الظالمين﴾</span>. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.|4:أخرجه يحيى بن سلام ١/٤٠١.|5:علَّقه يحيى بن سلام ١/٤٠١.|6:أخرجه عبد الرزاق ٢/٤٥، وابن جرير ١٧/٤٧. وعزاه السيوطي إلى عبد بن حميد.|7:أخرجه ابن جرير ١٧/٤٦.|8:تفسير مقاتل بن سليمان ٣/١٥٧.|9:أخرجه ابن جرير ١٧/٤٧.|10:علَّقه يحيى بن سلام ١/٤٠١.
  23,42,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿ثُمَّ أَنشَأۡنَا مِنۢ بَعۡدِهِمۡ قُرُونًا ءَاخَرِینَ ۝٤٢ مَا تَسۡبِقُ مِنۡ أُمَّةٍ أَجَلَهَا وَمَا یَسۡتَـٔۡخِرُونَ ۝٤٣﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥١٦٢٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ثم أنشأنا﴾</span> يعني: خلقنا <span class="qpc-hafs">﴿من بعدهم قرونا آخرين﴾</span> يعني: قومًا آخرين، فأهلكناهم بالعذاب في الدنيا، <span class="qpc-hafs">﴿ما تسبق من أمة أجلها وما يستأخرون﴾</span> عنه{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥١٦٢٤<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span> قوله: <span class="qpc-hafs">﴿ثم أنشأنا من بعدهم﴾</span> من بعد الهالكين <span class="qpc-hafs">﴿قرونا آخرين (٤٢) ما تسبق من أمة أجلها﴾</span> يعني: الوقت الذي يُهْلِكُها فيه، <span class="qpc-hafs">﴿وما يستأخرون﴾</span> عن الوقت ساعةً، ولا يستقدمون من قبل الوقت{2}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٣/١٥٧.|2:تفسير يحيى بن سلام ١/٤٠١.