quran[7]{c,v,t}:
  24,37,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿رِجَالࣱ لَّا تُلۡهِیهِمۡ تِجَـٰرَةࣱ وَلَا بَیۡعٌ عَن ذِكۡرِ ٱللَّهِ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٣٦٢٢<span class="dash">-</span></span> عن أبي هريرة، عن رسول الله ﷺ، في قوله تعالى: <span class="qpc-hafs">﴿رجال لا تلهيهم تجارة ولا بيع عن ذكر الله﴾</span>، قال: «<b>هم الذين يضربون في الأرض يبتغون من فضل الله</b>»{1}. (١١/٨٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٣٦٢٣<span class="dash">-</span></span> عن أبي سعيد الخدري، عن النبي ﷺ، في قوله: <span class="qpc-hafs">﴿رجال لا تلهيهم تجارة ولا بيع عن ذكر الله﴾</span>، قال: «<b>هم الذين يضربون في الأرض يبتغون من فضل الله</b>»{2}. (١١/٨٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٣٦٢٤<span class="dash">-</span></span> عن <span class="name-1">أبي هريرة</span> -من طريق دراج- في قوله تعالى: <span class="qpc-hafs">﴿رجال لا تلهيهم تجارة ولا بيع عن ذكر الله﴾</span>، قال: هم الذين يضربون في الأرض يبتغون من فضل الله{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٣٦٢٥<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عكرمة – في قوله: <span class="qpc-hafs">﴿رجال لا تلهيهم تجارة ولا بيع عن ذكر الله﴾</span>، قال: أما -واللهِ- لقد كانوا تُجّارًا، فلم تكن تجارتُهم ولا بيعُهم يلهيهم عن ذكر الله{4}. (١١/٨٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٣٦٢٦<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عكرمة- في الآية، قال: ضرب الله هذا المثلَ -قوله: <span class="qpc-hafs">﴿مثل نوره كمشكاة﴾</span>- لأولئك القوم الذين لا تلهيهم تجارة ولا بيع عن ذكر الله، وكانوا أتجر الناس وأبيعهم، ولكن لم تكن تلهيهم تجارتهم ولا بيعُهم عن ذكر الله{5}. (١١/٨٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٣٦٢٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿رجال﴾</span> فيها تقديم، بالغدوِّ والعشيِّ. ثم نعتهم، فقال سبحانه: <span class="qpc-hafs">﴿لا تلهيهم تجارة﴾</span> يعني: شراء، <span class="qpc-hafs">﴿ولا بيع﴾</span>{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٣٦٢٨<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: قوله: <span class="qpc-hafs">﴿رجال لا تلهيهم تجارة ولا بيع﴾</span>، التجارة: الجالب. والبيع: الذي يبيع على يديه{7}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿رِجَالࣱ لَّا تُلۡهِیهِمۡ تِجَـٰرَةࣱ وَلَا بَیۡعٌ عَن ذِكۡرِ ٱللَّهِ﴾</span> - أحكام متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٥٣٦٢٩<span class="dash">-</span></span> عن أُمِّ سلمة، عن رسول الله ﷺ، قال: «<b>خير مساجد النساء قَعْرُ بيوتهنَّ</b>»{8}. (١١/٨٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٣٦٣٠<span class="dash">-</span></span> عن عبد الحميد بن المنذر بن أبي حميد الساعدي، عن أبيه، عن جدَّته أم حميد، قالت: قلتُ: يا رسول الله، يمنعنا أزواجُنا أن نصلي معكَ، ونُحِبُّ الصلاةَ معك. فقال رسول الله ﷺ: «<b>صلاتُكُنَّ في بيوتكن أفضلُ مِن صلاتكن في حُجَرِكُنَّ، وصلاتكن في حُجَرِكُنَّ أفضل من صلاتكن في الجماعة</b>»{9}. (١١/٨٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٣٦٣١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن مسعود</span> -من طريق أبي عمرو الشيباني- قال: ما صلَّت امرأةٌ قطُّ صلاةً أفضل مِن صلاة تُصَلِّيها في بيتها، إلا أن تُصَلِّي عند المسجد الحرام، إلا عجوز في مَنقَلَيْها. يعني: خُفَّيْها{10}. (١١/٨٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٣٦٣٢<span class="dash">-</span></span> عن همام، عن قتادة، أنّ <span class="name-2">كعب الأحبار</span> قال: صلاةُ المرأة في بيتها أفضلُ من صلاتها في صفتها، وصلاتها في صفتها أفضل من صلاتها في حجرتها. ثم يتبعه قتادة: وما سَتَرَ امرأةً فهو خيرٌ لها{11}<span class=comment-ref>٤٦٧٦</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٤٦٧٦</span> ذكر <u>ابنُ كثير</u> (٦/٦٨) بعض الأحاديث الدالة على أفضلية صلاة المرأة في بيتها، ثم قال <span class="comment-type-4">معلّقًا</span>: «هذا ويجوز لها شهود جماعة الرجال، بشرط أن لا تؤذي أحدًا مِن الرجال بظهور زينة، ولا ريحٍ طيب، كما ثبت في الصحيحين عن عبد الله بن عمر أنه قال: <span class="mustanad">قال رسول الله ﷺ</span>: «<b>لا تمنعوا إماء الله مساجد الله</b>»».</div></p><p><h3><span class="qpc-hafs">﴿عَن ذِكۡرِ ٱللَّهِ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٣٦٣٣<span class="dash">-</span></span> عن سيّار، قال: حُدِّثْتُ عن <span class="name-1">عبد الله بن مسعود</span> أنّه رأى ناسًا مِن أهل السوق سمعوا الأذان، فتركوا أمتعتهم وقاموا إلى الصلاة، فقال: هؤلاء الذين قال الله: <span class="qpc-hafs">﴿لا تلهيهم تجارة ولا بيع عن ذكر الله﴾</span>{12}. (١١/٨٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٣٦٣٤<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، في قوله: <span class="qpc-hafs">﴿رجال لا تلهيهم تجارة ولا بيع عن ذكر الله﴾</span>، قال: كانوا رجالًا يبتغون مِن فضل الله؛ يشترون ويبيعون، فإذا سمعوا النداءَ بالصلاة ألقوا ما أيديهم، وقاموا إلى المسجد، فصلوا{13}. (١١/٨٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٣٦٣٥<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- <span class="qpc-hafs">﴿رجال لا تلهيهم تجارة ولا بيع عن ذكر الله﴾</span>، قال: عن شهود الصلاة المكتوبة{14}. (١١/٨٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٣٦٣٦<span class="dash">-</span></span> عن <span class="name-2">عطاء</span>، مثله{15}. (١١/٨٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٣٦٣٧<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عمر</span> -من طريق عمرو بن دينار مولى آل الزبير، عن سالم بن عبد الله-: أنه كان في السوق، فأُقِيمت الصلاة، فأغلقوا حوانيتَهم، ثم دخلوا المسجد، فقال ابن عمر: فيهم نزلت: <span class="qpc-hafs">﴿رجال لا تلهيهم تجارة ولا بيع عن ذكر الله﴾</span>{16}. (١١/٨٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٣٦٣٨<span class="dash">-</span></span> عن <span class="name-2">إبراهيم [النخعي]</span> -من طريق أبي يزيد- في قوله ﷿: <span class="qpc-hafs">﴿رجال لا تلهيهم تجارة ولا بيع عن ذكر الله﴾</span>، قال: هم قوم من القبائل والأسواق، إذا حانت الصلاةُ لم يشغلهم{17}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٣٦٣٩<span class="dash">-</span></span> عن <span class="name-2">سعيد بن أبي الحسن</span> -من طريق عوف- في هذه الآية: <span class="qpc-hafs">﴿في بيوت أذن الله أن ترفع ويذكر فيها اسمه يسبح له فيها بالغدو والآصال رجال لا تلهيهم تجارة ولا بيع عن ذكر الله﴾</span>، قال: هم قوم في تجاراتهم وبيوعهم، لا تلهيهم تجاراتهم ولا بيوعهم عن ذكر الله{18}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٣٦٤٠<span class="dash">-</span></span> عن <span class="name-2">الضحاك بن مُزاحِم</span> -من طريق جُوَيْبِر- في قوله: <span class="qpc-hafs">﴿رجال لا تلهيهم تجارة ولا بيع عن ذكر الله﴾</span>، قال: هم في أسواقهم يبيعون ويشترون، فإذا جاء وقت الصلاة لم يلههم البيع والشراء عن الصلاة، <span class="qpc-hafs">﴿يخافون يوما تتقلب فيه القلوب والأبصار﴾</span>{19}. (١١/٨٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٣٦٤١<span class="dash">-</span></span> عن <span class="name-2">سالم بن عبد الله</span> -من طريق عمرو بن دينار مولى آل الزبير- أنّه نظر إلى قوم من السوق قاموا وتركوا بياعاتهم إلى الصلاة، فقال: هؤلاء الذين ذكر الله في كتابه: <span class="qpc-hafs">﴿لا تلهيهم تجارة ولا بيع عن ذكر الله﴾</span> الآية{20}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٣٦٤٢<span class="dash">-</span></span> عن <span class="name-2">عطاء [بن أبي رباح]</span> -من طريق طلحة بن عمرو- <span class="qpc-hafs">﴿رجال لا تلهيهم تجارة ولا بيع عن ذكر الله وإقام الصلاة﴾</span>، قال: كانوا لا يُلهيهم الشراءُ والبيعُ عن مواضع حقوقِ الله التي افترضها عليهم أن يُؤَدُّوها لأوقاتها{21}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٣٦٤٣<span class="dash">-</span></span> عن <span class="name-2">مطر الورّاق</span> -من طريق ابن شَوْذَب- في قول الله: <span class="qpc-hafs">﴿رجال لا تلهيهم تجارة ولا بيع عن ذكر الله﴾</span>، قال: أما إنّهم قد كانوا يشترون ويبيعون، ولكن كان أحدُهم إذا سمع النداءَ -وميزانُه في يده- خَفَضَه، وأقبل إلى الصلاة{22}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٣٦٤٤<span class="dash">-</span></span> قال <span class="name-2">إسماعيل السُّدِّيّ</span>: <span class="qpc-hafs">﴿عن ذكر الله﴾</span>، يعني: عن الصلوات الخمس{23}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٣٦٤٥<span class="dash">-</span></span> عن <span class="name-3">مقاتل بن حيان</span> -من طريق بُكَيْر بن معروف- <span class="qpc-hafs">﴿رجال لا تلهيهم تجارة ولا بيع عن ذكر الله﴾</span>: يعني: الذكر: الصلاة المفروضة{24}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٣٦٤٦<span class="dash">-</span></span> عن <span class="name-2">الربيع بن أنس</span>، نحو ذلك{25}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٣٦٤٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿عن ذكر الله﴾</span>، يعني: الصلوات المفروضة{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٣٦٤٨<span class="dash">-</span></span> عن يحيى بن حفص القارئ، قال: سمعتُ <span class="name-3">سفيان الثوريَّ</span> يقول في قول الله ﷿: <span class="qpc-hafs">﴿رجال لا تلهيهم تجارة ولا بيع عن ذكر الله﴾</span>، قال: كانوا يشترون ويبيعون، ولا يَدَعُون الصلواتِ المكتوباتِ في الجماعات{27}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٣٦٤٩<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: ذِكْرُ الله في هذا الموضع: الأذان{7}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَإِقَامِ ٱلصَّلَوٰةِ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٣٦٥٠<span class="dash">-</span></span> عن <span class="name-2">أبي العالية الرِّياحِيِّ</span> -من طريق الربيع- قال: <span class="qpc-hafs">﴿رجال لا تلهيهم تجارة ولا بيع عن ذكر الله وإقام الصلاة﴾</span>، يعني: الصلاة المفروضة{22}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٣٦٥١<span class="dash">-</span></span> عن عوف، عن سعيد بن أبي الحسن، عن رجل نسي عوفٌ اسمه، في: <span class="qpc-hafs">﴿وإقام الصلاة﴾</span>، قال: يقومون للصلاة عند مواقيت الصلاة{30}<span class=comment-ref>٤٦٧٧</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٤٦٧٧</span> لم يذكر <u>ابنُ جرير</u> (١٧/٣٢٣) غير القول الذي أسنده عوف.</div></p><p><div></p><p><p><span class="item-no">٥٣٦٥٢<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- قوله: <span class="qpc-hafs">﴿وإقام الصلاة﴾</span>، قال: إقامة الصلاة في جماعة{31}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٣٦٥٣<span class="dash">-</span></span> عن <span class="name-2">زيد بن أسلم</span> -من طريق عبد الله بن عيّاش- في قول الله: <span class="qpc-hafs">﴿وإقام الصلاة﴾</span>، قال: إقامة الدِّين{32}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٣٦٥٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وإقام الصلاة﴾</span>، يقول: لا تُلهيهم التجارةُ عن إقام الصلاة{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٣٦٥٥<span class="dash">-</span></span> عن <span class="name-3">مقاتل بن حيان</span> -من طريق بُكَيْر بن معروف- <span class="qpc-hafs">﴿وإقام الصلاة﴾</span>: يعني: لا يُلهيهم ذلك عن حضور الصلاة؛ أن يُقيموها كما أمرهم الله، وأن يحافظوا على مواقيتها وما استحفظهم الله فيها{31}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٣٦٥٦<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿وإقام الصلاة وإيتاء الزكاة﴾</span>، كانوا إذا سمعوا المؤذِّن تركوا بيعَهم، وقاموا إلى الصلاة. وذِكْر الله في هذا الموضع: الأذان، والصلاة: الصلوات الخمس{35}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَإِیتَاۤءِ ٱلزَّكَوٰةِ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٣٦٥٧<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- قوله: <span class="qpc-hafs">﴿وأقيموا الصلاة وآتوا الزكاة﴾</span> [البقرة:٤٣، ٨٣، ١١٠، النساء:٧٧، النور:٥٦، المزمل:٢٠]، <span class="qpc-hafs">﴿وكان يأمر أهله بالصلاة والزكاة﴾</span> [مريم:٥٥]، وقوله: <span class="qpc-hafs">﴿وأوصاني بالصلاة والزكاة﴾</span> [مريم:٣١]، وقوله: <span class="qpc-hafs">﴿ولولا فضل الله عليكم ورحمته ما زكا منكم من أحد أبدا﴾</span> [النور:٢١]، وقوله: <span class="qpc-hafs">﴿وحنانا من لدنا وزكاة﴾</span> [مريم:١٣]، ونحو هذا في القرآن، قال: يعني بالزكاة: طاعة الله، والإخلاص{36}<span class=comment-ref>٤٦٧٨</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٤٦٧٨</span> لم يذكر <u>ابنُ جرير</u> (١٧/٣٢٤) غير قول ابن عباس.</div></p><p><div></p><p><p><span class="item-no">٥٣٦٥٨<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وإيتاء الزكاة﴾</span>، يقول: لا تلهيهم التجارة عن إعطاء الزكاة{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٣٦٥٩<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: الزكاة المفروضة{7}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿یَخَافُونَ یَوۡمࣰا تَتَقَلَّبُ فِیهِ ٱلۡقُلُوبُ وَٱلۡأَبۡصَـٰرُ ۝٣٧﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٣٦٦٠<span class="dash">-</span></span> عن <span class="name-2">الضَّحّاك بن مُزاحِم</span> -من طريق جُوَيْبِر- في قوله: <span class="qpc-hafs">﴿يخافون يوما تتقلب فيه القلوب والأبصار﴾</span>، قال: تتقلب في الجوف، ولا تقدر تخرج حتى تقع في الحنجرة، فهو قوله: <span class="qpc-hafs">﴿إذ القلوب لدى الحناجر كاظمين﴾</span> [غافر:١٨]{31}. (١١/٨٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٣٦٦١<span class="dash">-</span></span> عن <span class="name-2">زيد بن أسلم</span> -من طريق عبد الله بن عياش- في قوله: <span class="qpc-hafs">﴿يخافون يوما﴾</span>، قال: يوم القيامة{40}. (١١/٨٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٣٦٦٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثم أخبر عنهم، فقال سبحانه: <span class="qpc-hafs">﴿يخافون يوما تتقلب فيه القلوب﴾</span> حين زالت مِن أماكنها مِن الصدور، فنَشبتْ في حلوقهم عند الحناجر. قال: <span class="qpc-hafs">﴿والأبصار﴾</span> يعني: تقلب أبصارُهم فتكون زُرقًا{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٣٦٦٣<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿يخافون يوما تتقلب فيه القلوب والأبصار﴾</span> قلوب الكفار وأبصارهم. وتقلُّب القلوب: أنّ القلوب انتُزِعَت مِن أماكنها، فغصَّت به الحناجر، فلا هي ترجع إلى أماكنها، ولا هي تخرج، وهو قوله: <span class="qpc-hafs">﴿إذ القلوب لدى الحناجر كاظمين﴾</span> [غافر:١٨]. وأما تقلُّب الأبصار: فالزَّرَقُ{42} بعد الكحل، والعمى بعد البصر{43}<span class=comment-ref>٤٦٧٩</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٤٦٧٩</span> ذكر <u>ابنُ عطية</u> (٦/٣٩٢ بتصرف) في قوله: <span class="qpc-hafs">﴿تتقلب فيه القلوب والأبصار﴾</span> قولين، فقال: «واختلف الناس في تقلب القلوب والأبصار، كيف هو؟ <b>فقالت فرقة</b>: يرى الناسُ الحقائقَ عيانًا، فتتقلب قلوب الشاكِّين ومعتقدي الضلال عن معتقداتها إلى اعتقاد الحق على وجهه، وكذلك الأبصار. <b>وقالت فرقة</b>: هو تقلُّبٌ على جمر جهنم». ثم <span class="comment-type-4">علّق</span> عليهما قائلًا: «ومقصد الآية هو وصف هول يوم القيامة، فأمّا القول الأول فليس يقتضي هولًا، وأما الثاني فليس التقلب في جمر جهنم في يوم القيامة، وإنما هو بعده». ثم <span class="comment-type-3">رجّح</span> <span class="mustanad">مستندًا إلى لغة العرب</span> أنّ "معنى الآية: أنّ ذلك اليوم لشدة هوله ومطلعه القلوب والأبصار فيه مضطربة قلقة متقلبة مِن طمعٍ في النجاة إلى طمع، ومِن حذرِ هلاك إلى حذر، ومِن نظرٍ في هول إلى النظر في الآخر، والعربُ تستعمل هذا المعنى في الحروب ونحوها، ومنه قول الشاعر:</p><p>بل كان قلبك في جناحي طائر".</div></p><p><h3><span class="qpc-hafs">﴿یَخَافُونَ یَوۡمࣰا تَتَقَلَّبُ فِیهِ ٱلۡقُلُوبُ وَٱلۡأَبۡصَـٰرُ ۝٣٧﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٥٣٦٦٤<span class="dash">-</span></span> عن أسماء بنت يزيد، قالت: قال رسول الله ﷺ: «<b>يجمع الله الناسَ يومَ القيامة في صعيدٍ واحد، يسمعهم الداعي، وينفذهم البصر، فيقوم منادٍ، فينادي: أين الذين كانوا يحمدون الله في السرّاء والضرّاء؟ فيقومون وهم قليل، فيدخلون الجنةَ بغير حساب، ثم يعود فينادي: أين الذين كانت تتجافى جنوبُهم عن المضاجع؟ فيقومون وهم قليل، فيدخلون الجنة بغير حساب، ثم يعود فينادي: أين الذين كانوا لا تلهيهم تجارة ولا بيع عن ذكر الله؟ فيقومون وهم قليل، فيدخلون الجنة بغير حساب، ثم يقوم سائر الناس فيُحاسَبون</b>»{44}. (١١/٨٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٣٦٦٥<span class="dash">-</span></span> عن أبي سعيد، عن رسول الله ﷺ، قال: «<b>يقول الرب ﷿: سيعلم أهلُ الجمع اليومَ مَن أهلُ الكرم</b>». فقيل: ومَن أهل الكرم، يا رسول الله؟ قال: «<b>أهل الذِّكر في المساجد</b>»{45}. (١١/٨٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٣٦٦٦<span class="dash">-</span></span> عن <span class="name-1">أبي الدَّرداء</span> -من طريق أبي عبد رب- قال: ما أُحِبُّ أن أبايع على هذا الدرج{46}، وأربح كل يوم ثلاثمائة دينار، وأشهدُ الصلاة في الجماعة، أما إنِّي لا أزعم أن ذلك ليس بحلال، ولكني أُحِبُّ أن أكون مِن الذين قال الله: <span class="qpc-hafs">﴿رجال لا تلهيهم تجارة ولا بيع عن ذكر الله﴾</span>{47}. (١١/٨٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٣٦٦٧<span class="dash">-</span></span> عن مسروق، قال: أُتي <span class="name-1">عبد الله بن مسعود</span> بشراب، فقال: أعطِ علقمة. فقال: إني صائم. فقال: أعط مسروقًا. فقال: إني صائم. قال: فأخذ عبد الله فشرب، ثم قرأ: <span class="qpc-hafs">﴿يخافون يومًا تتقلب فيه القلوب والأبصار﴾</span>{48}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن أبي الدنيا في كتاب إصلاح المال ص٧١ (٢٠٥)، وابن عبد الحكم في فتوح مصر ص٣١١، وابن أبي حاتم ٨/٢٦٠٧ (١٤٦٤٥). وأورده الديلمي في الفردوس ٥/٧٩ (٧٥١٢).</p><p>قال ابن أبي حاتم في علل الحديث ٣/٦٧٤ (١١٨١): «سمعت أبي يقول: هذا حديث منكر».|2:أورده الديلمي في الفردوس ٢/٢٧٧ (٣٢٨٤). وعزاه السيوطي إلى ابن مردويه.|3:أخرجه إسحاق البستي في تفسيره ص٤٧٧.|4:أخرجه الطبراني (١١٧٨٨). وعزاه السيوطي إلى ابن مردويه.|5:أخرجه ابن أبي حاتم ٨/٢٦٠٧، والحاكم ٢/٣٩٨، والبيهقي في الشعب (٢٩٢٢).|6:تفسير مقاتل بن سليمان ٣/٢٠١.|7:تفسير يحيى بن سلّام ١/٤٥١.|8:أخرجه أحمد ٤٤/١٦٤-١٦٥ (٢٦٥٤٢)، ٤٤/١٩٤-١٩٥ (٢٦٥٧٠)، وابن خزيمة ٣/١٧٥ (١٦٨٣)، والحاكم ١/٣٢٧ (٧٥٦).|9:أخرجه ابن أبي شيبة ٢/١٥٧ (٧٦٢٠) واللفظ له، والطبراني في الكبير ٢٥/١٤٨ (٣٥٦).</p><p>قال الهيثمي في المجمع ٢/٣٤ (٢١٠٧): «رواه الطبراني في الكبير، وفيه ابن لهيعة، وفيه كلام».|10:أخرجه ابن أبي شيبة ٢/٣٨٣-٣٨٤، وأخرجه يحيى بن سلّام ١/٤٥١ وآخره بلفظ: إلا أن يكون المسجد الحرام ومسجد النبي، إلا أن تخرج في منقليها. قال حماد: المنقلان: الخفان.|11:أخرجه يحيى بن سلّام ١/٤٥٢.|12:أخرجه ابن جرير ١٧/٣٢٢، والطبراني (٩٠٧٩)، والبيهقي في الشعب (٢٩١٧). وعزاه السيوطي إلى سعيد بن منصور.|13:عزاه السيوطي إلى ابن مردويه.|14:أخرجه ابن جرير ١٧/٣٢٢، وابن أبي حاتم ٨/٢٦٠٨. وعزاه السيوطي إلى عبد بن حميد.|15:عزاه السيوطي إلى الفريابي.|16:أخرجه عبد الرزاق ٢/٦١، وابن أبي حاتم ٨/٢٦٠٧. وعزاه السيوطي إلى عبد بن حميد، وابن جرير، وهو عنده موقوف على سالم، كما سيأتي.|17:أخرجه سعيد بن منصور في سننه - التفسير ٦/٤٥١ (١٦١١)، وأخرجه يحيى بن سلّام ١/٤٥١ من طريق مسلم أبي عبد الله بلفظ: قوم لا تلهيهم التجارة عن وقت الصلاة، وهم هؤلاء الذين سمى الله.|18:أخرجه ابن جرير ١٧/٣٢١، وابن أبي حاتم ٨/٢٦٠٨ (١٤٦٥٠)، وهو عند ابن جرير عن سعيد عن رجل نسي اسمه.|19:أخرجه ابن أبي حاتم ٨/٢٦٠٧.|20:أخرجه ابن جرير ١٧/٣٢١، وابن أبي حاتم ٨/٢٦٠٨.|21:أخرجه ابن أبي حاتم ٨/٢٦٠٨، وأبو نعيم في حلية الأولياء ٣/٣١٢.|22:أخرجه ابن أبي حاتم ٨/٢٦٠٨.|23:علَّقه يحيى بن سلّام ١/٤٥١.|24:أخرجه محمد بن نصر في تعظيم قدر الصلاة ١/١٢٨.|25:علَّقه ابن أبي حاتم ٨/٢٦٠٨.|26:تفسير مقاتل بن سليمان ٣/٢٠١.|27:أخرجه محمد بن نصر في تعظيم قدر الصلاة ١/١٢٩، وأبو نعيم في حلية الأولياء ٧/١٥، والبيهقي في شعب الإيمان ٦/١٩٥-١٩٦ (٢٦٦١).|28:تفسير يحيى بن سلّام ١/٤٥١.|29:أخرجه ابن أبي حاتم ٨/٢٦٠٨.|30:أخرجه ابن جرير ١٧/٣٢٣.|31:أخرجه ابن أبي حاتم ٨/٢٦٠٩.|32:أخرجه بن وهب في الجامع - تفسير القرآن ١/٥٩-٦٠ (١٣٣)، وابن أبي حاتم ٨/٢٦٠٨.|33:تفسير مقاتل بن سليمان ٣/٢٠١.|34:أخرجه ابن أبي حاتم ٨/٢٦٠٩.|35:تفسير يحيى بن سلّام ١/٤٥١. وجاءت فيه كلمة «الصلوات الخمس» بزيادة واو في أولها.|36:أخرجه ابن جرير ١٧/٣٢٣، وابن أبي حاتم ٨/٢٦٠٩.|37:تفسير مقاتل بن سليمان ٣/٢٠١.|38:تفسير يحيى بن سلّام ١/٤٥١.|39:أخرجه ابن أبي حاتم ٨/٢٦٠٩.|40:أخرجه ابن وهب في الجامع ١/٥٩-٦٠ (١٣٣)، وابن جرير ١٧/٣٢٥، وابن أبي حاتم ٨/٢٦٠٩.|41:تفسير مقاتل بن سليمان ٣/٢٠١.|42:الزَّرَقُ: البياض. اللسان (زرق).|43:تفسير يحيى بن سلّام ١/٤٥٢.|44:أخرجه إسحاق بن راهويه في مسنده ٥/١٧٩-١٨٠ (٢٣٠٥)، وهناد بن السري في كتاب الزهد ١/١٣٤ (١٧٦)، وابن أبي حاتم ٨/٢٦١٠ (١٤٦٦٣)، والثعلبي ٧/٣٣٢.</p><p>قال البوصيري في إتحاف الخيرة المهرة بعد أن ذكر إخراج البيهقي له ٨/٢٥٨ (٧٩٠٩): «رواه البيهقي بسند ضعيف».|45:أخرجه أحمد ١٨/١٩٥ (١١٦٥٢)، ١٨/٢٤٩ (١١٧٢٢)، وابن حبان ٣/٩٨ (٨١٦).</p><p>قال ابن عساكر في فضيلة ذكر الله ص٣٣-٣٥ (١٠): «الحديث غريب». وقال ابن القيسراني في ذخيرة الحفاظ ٥/٢٧٩٣ (٦٥٤٢): «قال أحمد بن حنبل: درّاج عن أبي الهيثم عن أبي سعيد الخدري: ضعيف». وقال الهيثمي في المجمع ١٠/٧٦ (١٦٧٦٣): «رواه أحمد بإسنادين، وأحدهما حسن».|46:يعني: الدرج من باب المسجد. كما عند أحمد في الزهد.|47:أخرجه أحمد في الزهد ص١٣٧. وعزاه السيوطي إلى عبد بن حميد.|48:أخرجه ابن أبي شيبة (ت: محمد عوامة) ١٩/١٧٦ (٣٥٧١٧)، والنسائي في الكبرى (ت: شعيب الأرناؤوط) ١٠/٤٠٣ (١١٨٤٤) وابن أبي حاتم ٨/٢٦٠٩، والطبراني في الكبير ٩/١٧٧ (٨٨٧٩)، والحاكم (ت: مصطفى عطا) ٢/٤٣٤ (٦٤٦، ٣٥٠٩) وفيها أنّ عبد الله ذكر أنه ليس صائمًا.
  24,38,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿لِیَجۡزِیَهُمُ ٱللَّهُ أَحۡسَنَ مَا عَمِلُوا۟ وَیَزِیدَهُم مِّن فَضۡلِهِۦۗ وَٱللَّهُ یَرۡزُقُ مَن یَشَاۤءُ بِغَیۡرِ حِسَابࣲ ۝٣٨﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٣٦٦٨<span class="dash">-</span></span> عن <span class="name-2">ميمون بن مِهران</span> -من طريق أبي المليح- <span class="qpc-hafs">﴿بغير حساب﴾</span>، قال: غَرْفًا{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٣٦٦٩<span class="dash">-</span></span> عن <span class="name-2">الوليد بن قيس</span>، نحو هذا{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٣٦٧٠<span class="dash">-</span></span> قال <span class="name-2">إسماعيل السُّدِّيّ</span>: <span class="qpc-hafs">﴿بغير حساب﴾</span>، يقول: ليس فيه تِباعة{3} فيما يَرْزُق، ويقول: أنا الملِك، أُعْطِي مَن شئتُ بغير حسابٍ أخافه مِن أحد، ليس فوقي مَلِك يحاسبني{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٣٦٧١<span class="dash">-</span></span> عن <span class="name-2">الربيع بن أنس</span> -من طريق عبد الله بن أبي جعفر، عن أبيه- في قوله: <span class="qpc-hafs">﴿يرزق من يشاء بغير حساب﴾</span>، قال: لا يخرجه بحساب يخاف أن يُنقِص ما عنده، إنّ الله لا ينقُصُ ما عنده{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٣٦٧٢<span class="dash">-</span></span> عن <span class="name-2">سليمان بن مهران الأعمش</span> -من طريق إسماعيل بن عبد الله الكندي- في قوله: <span class="qpc-hafs">﴿ويزيدهم من فضله﴾</span>، قال: الشفاعة لِمَن وجَبَتْ له النارُ مِمَّن صنع إليهم المعروفَ في الدنيا{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٣٦٧٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ليجزيهم الله أحسن ما﴾</span> يعني: الذي <span class="qpc-hafs">﴿عملوا﴾</span> مِن الخير، ولهم مساوئ، فلا يجزيهم بها، <span class="qpc-hafs">﴿ويزيدهم﴾</span> على أعمالهم <span class="qpc-hafs">﴿من فضله﴾</span> فضلًا على أعمالهم، <span class="qpc-hafs">﴿والله يرزق من يشاء بغير حساب﴾</span> يقول الله تعالى: ليس فوقي ملِك يحاسبني، أنا الملِك، أُعطي مَن شئتُ بغير حساب، لا أخاف مِن أحد يُحاسِبُني{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٣٦٧٤<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: قوله: <span class="qpc-hafs">﴿ليجزيهم الله أحسن ما عملوا﴾</span> ثوابَ ما عملوا؛ الجنة، <span class="qpc-hafs">﴿ويزيدهم من فضله﴾</span> فأهل الجنة أبدًا في مزيد ... <span class="qpc-hafs">﴿بغير حساب﴾</span> بغير أن يُحاسِب نفسه، أي: لا ينقص ما عند الله كما ينقص ما في أيدي الناس ... وبعضهم يقول: لا أحد يحاسبهم بما أعطاهم الله، كقوله: <span class="qpc-hafs">﴿لهم أجر غير ممنون﴾</span> [فصلت:٨] غير مَحْسوب{8}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن أبي حاتم ٨/٢٦١٠.|2:علَّقه ابن أبي حاتم ٨/٢٦١٠.|3:التِباعة: ما فيه إثم يُتَّبَع به. اللسان (تبع).|4:علَّقه يحيى بن سلّام ١/٤٥٣.|5:أخرجه ابن أبي حاتم ٨/٢٦١٠، وأورده ٣/٢٧٦ قبل ذلك عند تفسير قوله تعالى: <span class="qpc-hafs">﴿وترزق من تشاء بغير حساب﴾</span> [آل عمران:٢٧].|6:أخرجه ابن أبي حاتم ٨/٢٦١٠.|7:تفسير مقاتل بن سليمان ٣/٢٠١.|8:تفسير يحيى بن سلّام ١/٤٥٢-٤٥٣.
  24,39,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَٱلَّذِینَ كَفَرُوۤا۟ أَعۡمَـٰلُهُمۡ كَسَرَابِۭ بِقِیعَةࣲ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٣٦٧٥<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- في قوله: <span class="qpc-hafs">﴿كسراب بقيعة﴾</span>، يقول: أرض مستوية{1}. (١١/٨٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٣٦٧٦<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿كسراب بقيعة﴾</span>، قال: بقاع مِن الأرض، والسراب عملُ الكافر{2}. (١١/٨٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٣٦٧٧<span class="dash">-</span></span> قال <span class="name-2">مجاهد بن جبر</span>: <span class="qpc-hafs">﴿والذين كفروا أعمالهم كسراب بقيعة﴾</span>، وهو القاع القرقرة{3}{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٣٦٧٨<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿كسراب بقيعة﴾</span>، قال: بقيعة من الأرض{5}. (١١/٨٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٣٦٧٩<span class="dash">-</span></span> عن <span class="name-2">أبي صالح [باذام]</span> -من طريق السدي- قال: السراب: الرياح{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٣٦٨٠<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- قوله: <span class="qpc-hafs">﴿والذين كفروا اعمالهم كسراب بقيعة يحسبه الظمان ماء﴾</span>، قال: هذا مَثَل أعمال الكافر{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٣٦٨١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿والذين كفروا﴾</span> بتوحيد الله مثل <span class="qpc-hafs">﴿أعمالهم﴾</span> الخبيثة <span class="qpc-hafs">﴿كسراب بقيعة﴾</span> يعني ﷿ بالسراب: الذي يُرى في الشمس بأرض قاعٍ{8}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿یَحۡسَبُهُ ٱلظَّمۡـَٔانُ مَاۤءً حَتَّىٰۤ إِذَا جَاۤءَهُۥ لَمۡ یَجِدۡهُ شَیۡـࣰٔا وَوَجَدَ ٱللَّهَ عِندَهُۥ فَوَفَّىٰهُ حِسَابَهُۥۗ وَٱللَّهُ سَرِیعُ ٱلۡحِسَابِ ۝٣٩﴾</span> - نزول الآية</h3></p><p><div></p><p><p><span class="item-no">٥٣٦٨٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: نزلت في شيبة بن ربيعة بن عبد شمس بن عبد مناف، وكان يلتمس الدِّين في الجاهلية، ويلبس الصفر، فكفر في الإسلام{9}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿یَحۡسَبُهُ ٱلظَّمۡـَٔانُ مَاۤءً حَتَّىٰۤ إِذَا جَاۤءَهُۥ لَمۡ یَجِدۡهُ شَیۡـࣰٔا وَوَجَدَ ٱللَّهَ عِندَهُۥ فَوَفَّىٰهُ حِسَابَهُۥۗ وَٱللَّهُ سَرِیعُ ٱلۡحِسَابِ ۝٣٩﴾</span> - تفسير الآية</h3></p><p><div></p><p><p><span class="item-no">٥٣٦٨٣<span class="dash">-</span></span> عن إسماعيل السُّدِّيّ، عن أبيه، عن <span class="name-1">أصحاب محمد ﷺ</span>، قالوا: إنّ الكُفّار يُبعثون يوم القيامة وِرْدًَا عِطاشًا، فيقولون: أين الماء؟ فيُمَثَّل لهم السراب، فيحسبونه ماء، فينطلقون إليه، فيجدون الله عنده، فيوفيهم حسابَهم، والله سريع الحساب{10}. (١١/٨٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٣٦٨٤<span class="dash">-</span></span> قال <span class="name-1">أُبَيّ بن كعب</span> -من طريق أبي العالية-: ثُمَّ ضرب مَثَل الكافر، فقال: <span class="qpc-hafs">﴿والذين كفروا أعمالهم كسراب﴾</span>، قال: وكذلك الكافر يجيء يوم القيامة وهو يحسب أنّ له عند الله خيرًا، فلا يجده، ويُدْخِلُه اللهُ النارَ{11}. (١١/٦٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٣٦٨٥<span class="dash">-</span></span> قال <span class="name-1">عبد الله بن عباس</span>: <span class="qpc-hafs">﴿و﴾</span>مَثَل <span class="qpc-hafs">﴿الذين كفروا أعمالهم كسراب بقيعة﴾</span>، قال: أعمال الكفار إذا جاءوا رأوها مثلَ السراب إذا أتاه الرجل قد احتاج إلى الماء، فأتاه فلم يجده شيئًا، فذلك مَثَلُ عملِ الكافر يرى أنّ له ثوابًا، وليس له ثواب{12}. (١١/٥٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٣٦٨٦<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق العوفي- في قوله: <span class="qpc-hafs">﴿والذين كفروا أعمالهم كسراب﴾</span> الآية، قال: هو مَثَل ضربه الله لرجل عَطِش، فاشْتَدَّ عطشُه، فرأى سرابًا، فحسبه ماءً، فطلبه، فظنَّ أنه قدر عليه حتى أتاه، فلمّا أتاه لم يجده شيئًا، وقُبِض عند ذلك. يقول: الكافر كذلك السراب؛ يحسب أنّ عمله يُغني عنه أو نافعُه شيئًا، ولا يكون على شيء حتى يأتيه الموت، فإذا أتاه الموتُ لم يجد عمله أغنى عنه شيئًا، ولم ينفعه إلا كما نُفِع العطشان المشتد إلى السراب ...{13}. (١١/٨٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٣٦٨٧<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح - في قوله: <span class="qpc-hafs">﴿حتى اذا جاءه لم يجده شيئا﴾</span>: وإتيانه إيّاه: موته وفراقه الدنيا، <span class="qpc-hafs">﴿ووجد الله عنده﴾</span> ووجد الله عند فراقه الدنيا، <span class="qpc-hafs">﴿فوفاه حسابه﴾</span>{2}. (١١/٨٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٣٦٨٨<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- <span class="qpc-hafs">﴿سريع الحساب﴾</span>: أحصاه{15}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٣٦٨٩<span class="dash">-</span></span> عن <span class="name-2">الضَّحّاك بن مُزاحِم</span> -من طريق ابن سنان- <span class="qpc-hafs">﴿كسراب بقيعة﴾</span>، قال: مثل الكافر <span class="qpc-hafs">﴿كسراب بقيعة يحسبه الظمآن ماء﴾</span>، العطشان المشتد عطشًا رأى سرابًا، فحسبه ماء، فلما أتاه لم يجده شيئًا، <span class="qpc-hafs">﴿ووجد الله عنده فوفاه حسابه والله سريع الحساب﴾</span>{16}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٣٦٩٠<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق مَعْمَر- في قوله: <span class="qpc-hafs">﴿يحسبه الظمآن ماء﴾</span>: هو مَثَل ضربه الله لعمل الكافر، يقول: يحسب أنّه في شيء كما يحسب هذا السراب ماء، <span class="qpc-hafs">﴿حتى إذا جاءه لم يجده شيئا﴾</span>، وكذلك الكافر إذا مات لم يجد عمله شيئًا، <span class="qpc-hafs">﴿ووجد الله عنده فوفاه حسابه﴾</span>{17}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٣٦٩١<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط-: أنّ الكُفّار يُبعَثون قد انقطعت أعناقهم من العطش، فيُرفع لهم سرابٌ بقيعة من الأرض، فإذا نظروا إليه حسبوه ماءً، فيذهبون إليه ليشربوا منه، فلا يجدون شيئًا، والسراب مثلُ أعمال الكفار؛ كما ذهب ذلك السراب فلم يقدروا على أن يُصِيبوا منه شيئًا كذلك اضْمَحَلَّت أعمالُهم فلم يُصيبوا منها خيرًا، ويؤخذون، ثم يُحاسَبون{18}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٣٦٩٢<span class="dash">-</span></span> عن <span class="name-2">الربيع بن أنس</span> -من طريق سليمان بن عامر- في قوله: <span class="qpc-hafs">﴿حتى إذا جاءه لم يجده شيئًا ووجد الله عنده فوفاه حسابه﴾</span>: وأنّه لَمّا رأى السراب فحسبه ماءً فانتهى إليه، وأهلكه العطش فلم يُصِب ماءً، وانقطعت نفسُه، ففارق الدنيا، فوفاه الله حسابه، فلم يجد عند الله من الخيرات شيئًا{15}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٣٦٩٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿يحسبه الظمان﴾</span> يعني: العطشان <span class="qpc-hafs">﴿ماء﴾</span> فيطلبه، ويظن أنّه قادر عليه، <span class="qpc-hafs">﴿حتى إذا جاءه﴾</span> يعني: أتاه <span class="qpc-hafs">﴿لم يجده شيئا﴾</span> فهكذا الكافر إذا انتهى إلى عملِه يوم القيامة وجده لم يُغْنِ عنه شيئًا؛ لأنّه عَمِلَهُ في غير إيمان، كما لم يجد العطشان السراب شيئًا حتى انتهى إليه، فمات مِن العطش، فهكذا الكافرُ يهلك يوم القيامة كما هلك العطشان حين انتهى إلى السراب، يقول: <span class="qpc-hafs">﴿ووجد الله﴾</span> جل جلاله بالمرصاد <span class="qpc-hafs">﴿عنده﴾</span> عمله، <span class="qpc-hafs">﴿فوفاه حسابه﴾</span> يقول: فجازاه بعمله، لم يظلمه، <span class="qpc-hafs">﴿والله سريع الحساب﴾</span> يُخَوِّفه بالحساب كأنّه قد كان{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٣٦٩٤<span class="dash">-</span></span> قال <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿والذين كفروا﴾</span> إلى قوله: <span class="qpc-hafs">﴿ووجد الله عنده﴾</span>، قال: هذا مَثَل ضربه الله للذين كفروا؛ <span class="qpc-hafs">﴿أعمالهم كسراب بقيعة﴾</span> قد رأى السراب، ووثِق بنفسه أنّه ماء، فلما جاءه لم يجده شيئًا. قال: وهؤلاء ظنُّوا أن أعمالهم صالحة، وأنهم سيرجعون منها إلى خير، فلم يرجعوا منها إلا كما رجع صاحب السراب، فهذا مَثَلٌ ضربه الله -جلَّ ثناؤه، وتَقَدَّسَتْ أسماؤه-{21}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٣٦٩٥<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿يحسبه الظمان﴾</span> العطشان <span class="qpc-hafs">﴿ماء حتى إذا جاءه لم يجده شيئا﴾</span>، كقوله: <span class="qpc-hafs">﴿مَثَلُ الَّذِينَ كَفَرُوا بِرَبِّهِمْ أعْمالُهُمْ كَرَمادٍ اشْتَدَّتْ بِهِ الرِّيحُ فِي يَوْمٍ عاصِفٍ لا يَقْدِرُونَ مِمّا كَسَبُوا عَلى شَيْءٍ ذَلِكَ هُوَ الضَّلالُ البَعِيدُ﴾</span> [إبراهيم:١٨]، والعطشان مثل الكافر، والسراب مثل عمله، يحسب أنه يُغنِي عنه شيئًا حتى يأتيه الموت، فإذا جاءه الموتُ لم يجد عملَه أغنى عنه شيئًا إلا كما ينفع السراب العطشان ...، <span class="qpc-hafs">﴿ووجد الله عنده فوفاه حسابه﴾</span> ثواب عمله{22}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه أبن جرير ١٧/٣٢٨، وابن أبي حاتم ٨/٢٦١١.|2:أخرجه ابن جرير ١٧/٣٢٨، وابن أبي حاتم ٨/٢٦١١-٢٦١٢. وعزاه السيوطي إلى ابن أبي شيبة، وعبد بن حميد، وابن المنذر.|3:القَرْقَر: وسط القاع. اللسان (قرر).|4:علَّقه يحيى بن سلّام ١/٤٥٣.|5:أخرجه عبد الرزاق ٢/٦١ من طريق معمر، وابن جرير ١٧/٣٢٨-٣٢٩، وابن أبي حاتم ٨/٢٦١١ بلفظ: بفَلاة من الأرض. وعلَّقه يحيى بن سلّام ١/٤٥٣. وعزاه السيوطي إلى عبد بن حميد.|6:أخرجه ابن أبي حاتم ٨/٢٦١١.|7:أخرجه ابن أبي حاتم ٨/٢٦١١.|8:تفسير مقاتل بن سليمان ٣/٢٠١.|9:تفسير مقاتل بن سليمان ٣/٢٠١. وهو بنحوه في تفسير الثعلبي ٧/١١١، وتفسير البغوي ٦/٥٣ عن مقاتل مهملًا؛ إلا أن فيه «عتبة بن ربيعة» بدل «شيبة بن ربيعة».|10:أخرجه ابن أبي حاتم ٨/٢٦١١ من طريق إسرائيل، عن أبيه، عن أصحاب محمد ﷺ. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.|11:أخرجه ابن جرير ١٧/٣٢٧، وابن أبي حاتم ٨/٢٦١٠، والحاكم ٢/٣٩٩-٤٠٠. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن مردويه.|12:عزاه السيوطي إلى الفريابي.|13:أخرجه ابن جرير ١٧/٣٢٨، ٣٣٠، وابن أبي حاتم ٨/٢٦١١-٢٦١٢.|14:أخرجه ابن جرير ١٧/٣٢٨، وابن أبي حاتم ٨/٢٦١١-٢٦١٢. وعزاه السيوطي إلى ابن أبي شيبة، وعبد بن حميد، وابن المنذر.|15:أخرجه ابن أبي حاتم ٨/٢٦١٣.|16:أخرجه ابن أبي حاتم ٨/٢٦١٢.|17:أخرجه عبد الرزاق ٢/٦١، وابن جرير ١٧/٣٢٨، وأخرجه يحيى بن سلّام ١/٤٥٣ مختصرًا من طريق سعيد، وابن أبي حاتم ٨/٢٦١٢ من طريق سعيد بلفظ: هذا مثل ضربه الله لعمل الكافر يرى أنّ له خيرًا، وأنّه قام على خير، حتى إذا كان يوم القيامة لم يجد خيرًا قدَّمه، ولا سلفًا سلفه، ووجد الله عنده فوفاه حسابه.|18:أخرجه ابن أبي حاتم ٨/٢٦١٢-٢٦١٣.|19:أخرجه ابن أبي حاتم ٨/٢٦١٣.|20:تفسير مقاتل بن سليمان ٣/٢٠١.|21:أخرجه ابن جرير ١٧/٣٢٩، وابن أبي حاتم ٨/٢٦١٢ مختصرًا.|22:تفسير يحيى بن سلّام ١/٤٥٣.
  24,40,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿أَوۡ كَظُلُمَـٰتࣲ فِی بَحۡرࣲ لُّجِّیࣲّ یَغۡشَىٰهُ مَوۡجࣱ مِّن فَوۡقِهِۦ مَوۡجࣱ مِّن فَوۡقِهِۦ سَحَابࣱۚ ظُلُمَـٰتُۢ بَعۡضُهَا فَوۡقَ بَعۡضٍ إِذَاۤ أَخۡرَجَ یَدَهُۥ لَمۡ یَكَدۡ یَرَىٰهَاۗ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٣٦٩٦<span class="dash">-</span></span> قال <span class="name-1">أُبَيّ بن كعب</span> -من طريق أبي العالية-: وضرب مثلًا آخر للكافر، فقال: <span class="qpc-hafs">﴿أو كظلمات في بحر لجي﴾</span>، فهو يتقلب في خمس مِن الظُّلَم: فكلامه ظُلمة، وعمله ظُلمة، ومخرجه ظُلمة، ومدخله ظُلمة، ومصيره يوم القيامة إلى الظلمات إلى النار، فكذلك ميِّت الأحياء يمشي في الناس لا يدري ماذا له، وماذا عليه{1}. (١١/٦٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٣٦٩٧<span class="dash">-</span></span> عن <span class="name-1">أبي أمامة</span> -من طريق سليم بن عامر- أنّه قال: أيها الناس، إنّكم قد أصبحتم وأمسيتم في منزل تقتسمون فيه الحسناتِ والسيئاتِ، وتُوشِكون أن تظعنوا منه إلى منزل آخر، وهو القبر؛ بيت الوحدة، وبيت الظُّلمة، وبيت الضِّيق، إلا ما وسَّع الله، ثم تنتقلون إلى مواطن يوم القيامة، وإنكم لفي بعض المواطن حين يغشى الناسَ أمرٌ مِن أمر الله، فتبيض وجوه، وتسود وجوه، ثم تنتقلون إلى منزل آخر، فيغشى ظلمة شديدة، ثم يقسم النور، فيعطى المؤمن نورًا، ويترك الكافر والمنافق فلا يعطى شيئًا، وهو المثل الذي ضربه الله في كتابه: <span class="qpc-hafs">﴿أو كظلمات في بحر لجي﴾</span> إلى قوله: <span class="qpc-hafs">﴿فما له من نور﴾</span>، فلا يستضيء الكافر والمنافق بنور المؤمن، كما لا يستضيء الأعمى ببصر البصير{2}. (١١/٩٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٣٦٩٨<span class="dash">-</span></span> قال <span class="name-1">عبد الله بن عباس</span>: <span class="qpc-hafs">﴿أو كظلمات في بحر لجي﴾</span> إلى قوله: <span class="qpc-hafs">﴿لم يكد يراها﴾</span>، فذلك مثَل قلبِ الكافر، ظلمةٌ فوق ظلمةٍ{3}. (١١/٦٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٣٦٩٩<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق العوفي- في قوله: <span class="qpc-hafs">﴿أو كظلمات في بحر لجي﴾</span> قال: يعني بالظلمات: الأعمال. وبالبحر اللجي: قلب الإنسان، <span class="qpc-hafs">﴿يغشاه موج﴾</span> يعني بذلك: الغشاوة التي على القلب والسمع والبصر، وهو كقوله: <span class="qpc-hafs">﴿ختم الله على قلوبهم﴾</span> [البقرة:٧] الآية، وكقوله: <span class="qpc-hafs">﴿أفرأيت من اتخذ إلهه هواه﴾</span> إلى قوله: <span class="qpc-hafs">﴿أفلا تذكرون﴾</span> [الجاثية:٢٣]{4}<span class=comment-ref>٤٦٨٠</span>. (١١/٨٨)</p></p><p></div></p><p><div><span class=comment-ref>٤٦٨٠</span> <span class="comment-type-4">ذكر</span> <u>ابنُ عطية</u> (٦/٣٩٥) نحو قول ابن عباس، فقال: «وذهب بعض الناس إلى أنّ في هذا المثال أجزاء تُقابل أجزاء من المُمَثَّل فقال: الظلمات: الأعمال الفاسدة والمعتقدات الباطلة. والبحر اللجي: صدر الكافر وقلبه. واللجي معناه: ذو اللجة، وهي معظم الماء وغمره، واجتماع مائه أشد لظلمته. والموج هو: الضلال والجهالة التي غمرت قلبه والفِكَر المعوجة. والسحاب هو: شهوته في الكفر، وإعراضه عن الإيمان، وما رِين به على قلبه». ثم <span class="comment-type-4">علّق</span> بقوله: «وهذا التأويل سائغ، وألّا يُقدَّر هذا التقابلُ سائغٌ».</div></p><p><div></p><p><p><span class="item-no">٥٣٧٠٠<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق مَعْمَر- <span class="qpc-hafs">﴿أو كظلمات في بحر لجي يغشاه موج من فوقه موج﴾</span> الآية، قال: هذا مَثَلُ عمل الكافر، في ضلالات، ليس له مخرجٌ ولا منفذ، أعمى فيها لا يُبصِر{5}. (١١/٩٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٣٧٠١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثم ضرب الله ﷿ لشَيْبَةَ وكفرِه بالإيمان مثلًا آخر، فقال: <span class="qpc-hafs">﴿أو كظلمات في بحر لجي﴾</span>{6}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿أَوۡ كَظُلُمَـٰتࣲ فِی بَحۡرࣲ لُّجِّیࣲّ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٣٧٠٢<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق مَعْمَر- <span class="qpc-hafs">﴿أو كظلمات في بحر لجي﴾</span> الآية، قال: اللجي: العميق القَعْر{7}. (١١/٩٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٣٧٠٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿أو كظلمات في بحر لجي﴾</span>، يعني: في بحر عميق، والبحر إذا كان عميقًا كان أشد لظلمته. يعني بالظلمات: الظلمة التي فيها الكافر، والبحر اللجي قلب الكافر{8}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿یَغۡشَىٰهُ مَوۡجࣱ مِّن فَوۡقِهِۦ مَوۡجࣱ مِّن فَوۡقِهِۦ سَحَابࣱۚ ظُلُمَـٰتُۢ بَعۡضُهَا فَوۡقَ بَعۡضٍ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٣٧٠٤<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- قوله: <span class="qpc-hafs">﴿ظلمات بعضها فوق بعض﴾</span>، قال: الظلمات ثلاث ظلمات: ظلمة الليل، وظلمة البحر، وظلمة السحاب، وكذلك قلب الكافر ثلاث ظلمات: ظلمة القلب، وظلمة الصدر، وظلمة الجوف، كما ضرب مَثَل قلوب المؤمنين{9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٣٧٠٥<span class="dash">-</span></span> قال <span class="name-2">إسماعيل السُّدِّيّ</span>: يعني به: الكافر، يقول: قلبه مُظلم، في صدرٍ مظلم، في جسدٍ مظلم؛ قلبه بالشِّرك، وصدره بالكفر، وجسده بالشك، وهو النفاق{10}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٣٧٠٦<span class="dash">-</span></span> عن <span class="name-2">الربيع بن أنس</span> -من طريق سليمان بن عامر- في قوله: <span class="qpc-hafs">﴿ظلمات بعضها فوق بعض﴾</span>، قال: فكذلك مَثَل الكافر في البحر في ظلمة الليل في لُجَّة البحر، فهي ظلمات، إحداهن الليل <span class="qpc-hafs">﴿في بحر لجي يغشاه موج من فوقه موج﴾</span> إلى قوله: <span class="qpc-hafs">﴿فما له من نور﴾</span>، فهو يتقلب في خمس من الظلم؛ وذلك أنّ عمله كظلمة الليل في لجة البحر، يغشاه موج، مِن فوقه موج، مِن فوقه سحاب، ظلمات بعضها فوق بعض، فهذه خمسة من الظلم: فمدخله في ظلمة، ومخرجه في ظلمة، وكلامه في ظلمة، وعمله ظلمة، ومصيره إلى الظلمات يوم القيامة، فكذلك ميت الأحياء يمشي في الناس لا يدري ما له وماذا عليه. إنّ الله جعل طاعته نورًا، ومعصيته ظلمة، إنّ الإيمان في الدنيا هو النور يوم القيامة، ثم إنّه لا خير في قول ولا عمل ليس له أصل ولا فرع{9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٣٧٠٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿يغشاه موج﴾</span> فوق الماء، ثم يذهب عنه ذلك الموج، ثم يغشاه موج آخر مكان الموج الأول، فذلك قوله ﷿: <span class="qpc-hafs">﴿يغشاه موج من فوقه موج من فوقه سحاب ظلمات﴾</span>، فهي ظلمة الموج، وظلمة الليل، وظلمة البحر والسحاب، يقول: وهذه ظلمات <span class="qpc-hafs">﴿بعضها فوق بعض﴾</span>، فهكذا الكافر قلبُه مظلم، في صدر مُظلم، في جسد مُظلم، لا يُبصِر نور الإيمان، كما أنّ صاحب البحر <span class="qpc-hafs">﴿إذا أخرج يده لم يكد يراها﴾</span>{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٣٧٠٨<span class="dash">-</span></span> قال <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿أو كظلمات في بحر لجي يغشاه موج من فوقه موج﴾</span> إلى قوله: <span class="qpc-hafs">﴿ظلمات بعضها فوق بعض﴾</span>، قال: شرٌّ بعضه فوق بعض{13}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٣٧٠٩<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿يغشاه موج من فوقه موج﴾</span> ثم وصف ذلك الموج، فقال: <span class="qpc-hafs">﴿من فوقه سحاب ظلمات بعضها فوق بعض﴾</span> ظلمة البحر، وظلمة الموج، وظلمة السحاب، وظلمة الليل{14}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿إِذَاۤ أَخۡرَجَ یَدَهُۥ لَمۡ یَكَدۡ یَرَىٰهَاۗ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٣٧١٠<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق ميمون- قال: <span class="qpc-hafs">﴿إذا أخرج يده لم يكد يراها﴾</span>، قال: أما رأيت الرجلَ يقول: واللهِ، ما رأيتُها، وما كِدتُ أن أراها؟{15}. (١١/٩٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٣٧١١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿إذا أخرج يده﴾</span> في ظُلمة الماء <span class="qpc-hafs">﴿لم يكد يراها﴾</span> يعني: لم يرها البتَّة، فذلك قوله ﷿: <span class="qpc-hafs">﴿ومن لم يجعل الله له نورًا﴾</span>، <span class="qpc-hafs">﴿إذا أخرج يده لم يكد يراها﴾</span> لم يُقارب به البصر، كقول الرجل لم يُصِب، ولم يُقارِب{8}<span class=comment-ref>٤٦٨١</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٤٦٨١</span> ذكر <u>ابنُ عطية</u> (٦/٣٩٥-٣٩٦) في قوله: <span class="qpc-hafs">﴿إذا أخرج يده لم يكد يراها﴾</span> قولين: <b>الأول</b>: أنّ هذا الرجل المقدَّر في هذه الأحوال لم يرَ يده البتة. كما أفاده قول مقاتل. <b>الثاني</b>: أن هذا الرجل رأى يده بعد جهد وشدة.</p><p>وقد <span class="comment-type-4">بيّن</span> <u>ابنُ عطية</u> أن وجْه القول الثاني عند القائلين به أنّ «(كاد) إذا صحبها حرف النفي وجب الفعل الذي بعدها، وإذا لم يصحبها انتفى الفعل». ثم <span class="comment-type-4">علّق</span> قائلًا: «وهذا لازم متى كان حرف النفي بعد»كاد«داخلًا على الفعل الذي بعدها، تقول: كاد زيد يقوم. فالقيام منفي، فإذا قلت: كاد زيد أن لا يقوم. فالقيام واجب واقع ... فإذا كان حرف النفي مع»كاد«فالأمر محتمل؛ مرة يوجب الفعل، ومرة ينفيه، تقول: المفلوج لا يكاد يسكن. فهذا كلام صحيح تضمن نفي السكون، وتقول: رجل متكلم لا يكاد يسكن. فهذا كلام صحيح يتضمن إيجاب السكون بعد جهد ونادرًا، <span class="mustanad">ومنه قوله تعالى</span>: <span class="qpc-hafs">﴿فذبحوها وما كادوا يفعلون﴾</span> [البقرة:٧١] نفي مع»كاد«تضمن وجوب الذبح». ثم قال: «وقوله في هذه الآية: <span class="qpc-hafs">﴿لم يكد يراها﴾</span> نفي مع»كاد«يتضمن في أحد التأويلين نفي الرؤية، ولهذا ونحوه قال سيبويه ﵀: إنّ أفعال المقاربة لها نحو آخر. بمعنى: أنها دقيقة التصرف».</p><p>وذكر <u>ابنُ جرير</u> (١٧/٣٣٢) القولين، و<span class="comment-type-4">علّق</span> على الأول بأنه: «<span class="mustanad">أظهر معاني الكلمة من جهة ما تستعمل العرب</span> أكاد في كلامها». و<span class="comment-type-4">علّق</span> على الثاني بأنه: «أوضح من جهة التفسير، وهو أخفى معانيه».</div></p><p><div></p><p><p><span class="item-no">٥٣٧١٢<span class="dash">-</span></span> قال <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿إذا أخرج يده لم يكد يراها﴾</span>، يقول: إذا أخرج الناظرُ يده في هذه الظلمات لم يكد يراها{13}<span class=comment-ref>٤٦٨٢</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٤٦٨٢</span> لم يذكر <u>ابنُ جرير</u> (١٧/٣٣٠-٣٣١) في تفسير عموم الآية غير قول أُبَيٍّ، وقول ابن عباس من طريق العوفي، وقول قتادة من طريق معمر، وقول ابن زيد.</div></p><p><div></p><p><p><span class="item-no">٥٣٧١٣<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿إذا أخرج يده لم يكد يراها﴾</span> مِن شدة الظُّلمة{14}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَمَن لَّمۡ یَجۡعَلِ ٱللَّهُ لَهُۥ نُورࣰا فَمَا لَهُۥ مِن نُّورٍ ۝٤٠﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٣٧١٤<span class="dash">-</span></span> قال <span class="name-1">عبد الله بن عباس</span>: <span class="qpc-hafs">﴿ومن لم يجعل الله له نورا فما له من نور﴾</span> مَن لم يجعل الله له دِينًا وإيمانًا فلا دِين له{19}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٣٧١٥<span class="dash">-</span></span> عن ثابت البناني، قال: قال <span class="name-2">مُطَرِّف [بن عبد الله بن الشِّخِّير]</span>: الإنسان بمنزلة الحجر؛ إن جعل الله فيه خيرًا كان فيه. وقرأ قول الله سبحانه: <span class="qpc-hafs">﴿ومن لم يجعل الله نورًا فما له نور له﴾</span>. وقال مطرف: إنّ هاهنا قومًا يزعمون أنهم إن شاءوا دخلوا الجنة، وإن شاءوا دخلوا النار. ثم حلف مُطَرِّف بالله ثلاثة أيمان مجتهد: أن لا يدخل الجنة عبدٌ أبدًا إلا عبدٌ شاء أن يُدخله إياها عمدًا{20}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٣٧١٦<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- <span class="qpc-hafs">﴿ومن لم يجعل الله له نورًا﴾</span>، يقول: فما له إيمان{21}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٣٧١٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ومن لم يجعل الله له نورا﴾</span> يعني: الهُدى؛ الإيمان <span class="qpc-hafs">﴿فما له من نور﴾</span> يعني: مِن هُدى{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٣٧١٨<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿ومن لم يجعل الله له نورا فما له من نور﴾</span>، يعني: الكافر{14}<span class=comment-ref>٤٦٨٣</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٤٦٨٣</span> أفادت الآثارُ أن معنى قوله: <span class="qpc-hafs">﴿ومن لم يجعل الله له نورا فما له من نور﴾</span>: مَن لم يهده الله لم يهتد. وقد ذكر <u>ابنُ عطية</u> (٦/٣٩٦) إضافةً إلى هذا القول <b>قولًا آخر</b> هو: «مَن لم يرحمه الله وينوّر حاله بالعفو والرحمة فلا رحمة له». ثم <span class="comment-type-3">رجّح</span> <span class="mustanad">مستندًا إلى ظاهر اللفظ ودلالة العقل</span> القولَ الأول، فقال: «والأول أبين وأليق بلفظ الآية، وأيضًا فذلك متلازم؛ نور الآخرة إنما هو لمن نوّر قلبه في الدنيا وهُدِي، وقد قررت الشريعة أنّ من مرَّ لآخرته على كفره فهو غير مرحوم ولا مغفور له».</div></p></div>",footnotes:1:أخرجه ابن جرير ١٧/٣٣١، وابن أبي حاتم ٨/٢٦١٤، والحاكم ٢/٣٩٩-٤٠٠. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن مردويه.|2:أخرجه ابن أبي الدنيا في كتاب الأهوال -موسوعة الإمام ابن أبي الدنيا ٦/١٩٤-١٩٥ (١٤٠)- مطولًا. وعزاه السيوطي إلى ابن المنذر.|3:عزاه السيوطي إلى الفريابي.|4:أخرجه ابن جرير ١٧/٣٣١، وابن أبي حاتم ٨/٢٦١٣-٢٦١٤.|5:أخرجه عبد الرزاق ٢/٦١، وابن جرير ١٧/٣٣٠-٣٣١، وابن أبي حاتم ٨/٢٦١٣، وأخرجه يحيى بن سلّام ١/٤٥٤ من طريق سعيد بلفظ: مثل عمل الكافر في ضلالات متسكع فيها. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.|6:تفسير مقاتل بن سليمان ٣/٢٠٢. والمراد بشيبة: شيبة بن ربيعة بن عبد شمس بن عبد مناف، كما تقدم في نزول الآية السابقة.|7:أخرجه عبد الرزاق ٢/٦١، وابن جرير ١٧/٣٣٠-٣٣١، وابن أبي حاتم ٨/٢٦١٣. وعلَّقه يحيى بن سلّام ١/٤٥٤ وعقّب عليه بقوله: أي: غمر. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.|8:تفسير مقاتل بن سليمان ٣/٢٠٢.|9:أخرجه ابن أبي حاتم ٨/٢٦١٤.|10:علَّقه يحيى بن سلّام ١/٤٥٤.|11:أخرجه ابن أبي حاتم ٨/٢٦١٤.|12:تفسير مقاتل بن سليمان ٣/٢٠٢.|13:أخرجه ابن جرير ١٧/٣٣١، وأخرج ابن أبي حاتم ٨/٢٦١٥ الشطر الأول منه من طريق أصبغ.|14:تفسير يحيى بن سلّام ١/٤٥٤.|15:أخرجه ابن أبي حاتم ٨/٢٦١٥ (١٤٦٩٣). وعزاه السيوطي إلى عبد بن حميد.|16:تفسير مقاتل بن سليمان ٣/٢٠٢.|17:أخرجه ابن جرير ١٧/٣٣١، وأخرج ابن أبي حاتم ٨/٢٦١٥ الشطر الأول منه من طريق أصبغ.|18:تفسير يحيى بن سلّام ١/٤٥٤.|19:تفسير البغوي ٦/٥٣.|20:أخرجه عبد الله بن أحمد في زوائد الزهد ص٢٩٨، وأبو نعيم في حلية الأولياء ٢/٢٠١.|21:أخرجه ابن أبي حاتم ٨/٢٦١٥.|22:تفسير مقاتل بن سليمان ٣/٢٠٢.|23:تفسير يحيى بن سلّام ١/٤٥٤.
  24,41,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿أَلَمۡ تَرَ أَنَّ ٱللَّهَ یُسَبِّحُ لَهُۥ مَن فِی ٱلسَّمَـٰوَ ٰ⁠تِ وَٱلۡأَرۡضِ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٣٧١٩<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿ألم تر ان الله يسبح له﴾</span> إلى قوله: <span class="qpc-hafs">﴿كل قد علم صلاته وتسبيحه﴾</span>، قال: الصلاة للإنسان، والتسبيح لِما سِوى ذلك مِن خلقه{1}<span class=comment-ref>٤٦٨٤</span>. (١١/٩١)</p></p><p></div></p><p><div><span class=comment-ref>٤٦٨٤</span> لم يذكر <u>ابنُ جرير</u> (١٧/٣٣٣) غير قول مجاهد.</div></p><p><div></p><p><p><span class="item-no">٥٣٧٢٠<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿ألم تر أن الله يسبح له من في السماوات والأرض﴾</span>، قال: المؤمن يسجد طائعًا، والكافر يسجد كارهًا. وفي لفظ آخر: لم يَدَعْ شيئًا مِن خلقه إلا عَبَّدَهُ له طائعًا وكارهًا{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٣٧٢١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ألم تر أن الله يسبح له﴾</span> يقول: ألم تعلم أنّ الله يذكره <span class="qpc-hafs">﴿من في السماوات﴾</span> مِن الملائكة، <span class="qpc-hafs">﴿و﴾</span>مَن في <span class="qpc-hafs">﴿الأرض﴾</span> مِن المؤمنين مِن الإنس والجنِّ{3}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَٱلطَّیۡرُ صَـٰۤفَّـٰتࣲۖ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٣٧٢٢<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿والطير صافات﴾</span>، قال: بَسْطُ أجنحتهن{2}. (١١/٩١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٣٧٢٣<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿والطير صافات﴾</span>، قال: صافات بأجنحتها{5}. (١١/٩١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٣٧٢٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿والطير صافات﴾</span> الأجنحة{3}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿كُلࣱّ قَدۡ عَلِمَ صَلَاتَهُۥ وَتَسۡبِیحَهُۥۗ وَٱللَّهُ عَلِیمُۢ بِمَا یَفۡعَلُونَ ۝٤١﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٣٧٢٥<span class="dash">-</span></span> عن <span class="name-3">مِسْعَر</span> -من طريق سفيان بن عيينة- في قوله: <span class="qpc-hafs">﴿والطير صافات كل قد علم صلاته وتسبيحه﴾</span>، قال: قد سَمّى لها صلاةً، ولم يذكر ركوعًا ولا سجودًا{7}. (١١/٩١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٣٧٢٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿كل﴾</span> مَن فيها؛ في السموات والأرض <span class="qpc-hafs">﴿قد علم صلاته﴾</span> مِن الملائكة والمؤمنين مِن الجن والإنس، ثم قال ﷿: <span class="qpc-hafs">﴿وتسبيحه﴾</span> يعني: ويذكره كلُّ مخلوق بلُغَتِه، غير كفار الإنس والجن، <span class="qpc-hafs">﴿والله عليم بما يفعلون﴾</span>{3}<span class=comment-ref>٤٦٨٥</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٤٦٨٥</span> <span class="comment-type-4">ذكر</span> <u>ابنُ عطية</u> (٦/٣٩٧) في قوله: <span class="qpc-hafs">﴿كل قد علم صلاته وتسبيحه﴾</span> عدة أقوال، فقال: «وقوله: <span class="qpc-hafs">﴿كل قد علم صلاته وتسبيحه﴾</span> <b>قال الحسن</b>: المعنى: كل قد علم صلاة نفسه وتسبيح نفسه فهو يثابر عليهما ويؤديهما. و<b>قال مجاهد</b>: الصلاة للبشر، والتسبيح لما عداهم. و<b>قالت فرقة</b>: المعنى: كل قد علم صلاة الله وتسبيح الله اللذيْن أمر بهما وهَدى إليهما. فهذه إضافة خلق إلى خالق. <b>وقال الزجاج وغيره</b>: المعنى: كل قد علم الله صلاته وتسبيحه. فالضميران للكل».</div></p></div>",footnotes:1:أخرجه يحيى بن سلّام ١/٤٥٤ من طريق ابن مجاهد بلفظ: الصلاة للإنسان، يعني: المؤمن ...، وابن جرير ١٧/٣٣٣ من طريق ابن جريج أيضًا بنحوه، وابن أبي حاتم ٨/٢٦١٦، وأبو الشيخ في العظمة (١٢٢٨). وعزاه السيوطي إلى ابن أبي شيبة، وعبد بن حميد، وابن المنذر.|2:أخرجه ابن أبي حاتم ٨/٢٦١٦.|3:تفسير مقاتل بن سليمان ٣/٢٠٣.|4:أخرجه ابن أبي حاتم ٨/٢٦١٦.|5:أخرجه ابن أبي حاتم ٨/٢٦١٦. وعلَّقه يحيى بن سلّام ١/٤٥٤. وعزاه السيوطي إلى عبد بن حميد.|6:تفسير مقاتل بن سليمان ٣/٢٠٣.|7:أخرجه ابن أبي حاتم ٨/٢٦١٦ بنحوه. وعزاه السيوطي إلى أبي الشيخ في العظمة.|8:تفسير مقاتل بن سليمان ٣/٢٠٣.
  24,42,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَلِلَّهِ مُلۡكُ ٱلسَّمَـٰوَ ٰ⁠تِ وَٱلۡأَرۡضِۖ وَإِلَى ٱللَّهِ ٱلۡمَصِیرُ ۝٤٢﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٣٧٢٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ولله ملك السماوات والأرض وإلى الله المصير﴾</span> في الآخرة{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٣٧٢٨<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: قوله: <span class="qpc-hafs">﴿ولله ملك السموات والأرض وإلى الله المصير﴾</span> البعث{2}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٣/٢٠٣.|2:تفسير يحيى بن سلّام ١/٤٥٤.
  24,43,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿أَلَمۡ تَرَ أَنَّ ٱللَّهَ یُزۡجِی سَحَابࣰا﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٣٧٢٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ألم تر أن الله﴾</span> يقول: ألم تعلم أنّ الله <span class="qpc-hafs">﴿يزجي﴾</span> يعني: يسوق <span class="qpc-hafs">﴿سحابا﴾</span>{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٣٧٣٠<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: قوله: <span class="qpc-hafs">﴿ألم تر أن الله يزجي سحابا﴾</span> يُنشِئ سحابًا{2}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿ثُمَّ یُؤَلِّفُ بَیۡنَهُۥ ثُمَّ یَجۡعَلُهُۥ رُكَامࣰا﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٣٧٣١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ثم يؤلف بينه﴾</span> يعني: يضُمُّ بعضه إلى بعض، <span class="qpc-hafs">﴿ثم يجعله ركاما﴾</span> يعني: قِطعًا يحمل بعضها على إثر بعض، ثم يُؤَلِّف بينه، يعني: يضم السحاب بعضَه إلى بعض بعد الركام{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٣٧٣٢<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: قوله: <span class="qpc-hafs">﴿ثم يؤلف بينه﴾</span> يجمع بعضه إلى بعض، <span class="qpc-hafs">﴿ثم يجعله ركاما﴾</span> بعضه على بعض{4}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿فَتَرَى ٱلۡوَدۡقَ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٣٧٣٣<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span>، في قوله: <span class="qpc-hafs">﴿فترى الودق﴾</span>، قال: القَطْر{5}. (١١/٩٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٣٧٣٤<span class="dash">-</span></span> عن <span class="name-2">الضَّحّاك بن مُزاحِم</span> -من طريق جُوَيْبِر- في قوله: <span class="qpc-hafs">﴿فترى الودق﴾</span>، قال: المطر{6}. (١١/٩١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٣٧٣٥<span class="dash">-</span></span> قال <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿فترى الودق يخرج من خلاله﴾</span>، قال: الودق: القَطْر{7}<span class=comment-ref>٤٦٨٦</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٤٦٨٦</span> لم يذكر <u>ابنُ جرير</u> (١٧/٣٣٧) غير قول ابن زيد.</div></p><p><div></p><p><p><span class="item-no">٥٣٧٣٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فترى الودق﴾</span>، يقول: فترى المطر{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٣٧٣٧<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: قوله: <span class="qpc-hafs">﴿فترى الودق﴾</span>: المطر{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٣٧٣٨<span class="dash">-</span></span> عن أبي بَجيلة، عن أبيه، قال: <span class="qpc-hafs">﴿الودق﴾</span>: البرقُ{10}. (١١/٩٢)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿یَخۡرُجُ مِنۡ خِلَـٰلِهِۦ﴾</span> - قراءات</h3></p><p><div></p><p><p><span class="item-no">٥٣٧٣٩<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عمارة، عن رجل- أنّه قرأها: (مِن خَلَلِهِ) بفتح الخاء من غير ألف. قال هارون: فذكرت ذلك <span class="name-2">لأبي عمرو</span>، فقال: إنها لحسنة، ولكن <span class="qpc-hafs">﴿خِلالِهِ﴾</span> أعمُّ{11}. (١١/٩٢). (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٣٧٤٠<span class="dash">-</span></span> عن <span class="name-2">الضحاك بن مزاحم</span> -من طريق قتادة- أنّه قرأ هذا الحرف: <span class="qpc-hafs">﴿فَتَرى الوَدْقَ يَخْرُجُ مِن خِلالِهِ﴾</span>: (مِن خَلَلِهِ){12}<span class=comment-ref>٤٦٨٧</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٤٦٨٧</span> ذكر <u>ابنُ جرير</u> (١٧/٣٣٧) هذه القراءة، ثم <span class="comment-type-3">رجّح</span> <span class="mustanad">مستندًا إلى إجماع الحجة من القرّاء</span> قراءةَ <span class="qpc-hafs">﴿خلاله﴾</span>: «وأما قراء الأمصار فإنهم على القراءة الأخرى: <span class="qpc-hafs">﴿من خلاله﴾</span>، وهي التي نختار؛ لإجماع الحجة من القراء عليها».</div></p><p><h3><span class="qpc-hafs">﴿یَخۡرُجُ مِنۡ خِلَـٰلِهِۦ﴾</span> - تفسير الآية</h3></p><p><div></p><p><p><span class="item-no">٥٣٧٤١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿يخرج من خلاله﴾</span>، يقول: يخرج من خلال السحاب{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٣٧٤٢<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿من خلاله﴾</span>، قال: السحاب{14}. (١١/٩٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٣٧٤٣<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿يخرج من خلاله﴾</span> مِن خلل السحاب{4}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿یَخۡرُجُ مِنۡ خِلَـٰلِهِۦ﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٥٣٧٤٤<span class="dash">-</span></span> عن معاذ بن عبد الله بن خبيب الجهني، قال: رأيت ابنَ عباس مرَّ به تبيعٌ ابنُ امرأةِ كعب، فسلَّم عليه، فسأله ابن عباس: هل سمعت <span class="name-2">كعبًا</span> يقول في السحاب شيئًا؟ قال: نعم، سمعته يقول: إنّ السحاب غِربال المطر، لولا السحابُ حين ينزل الماءُ مِن السماء لفسد ما يقع عليه. قال: سمعتَ كعبًا يقول: في الأرض تنبت العام نبات، وعام قابل غيره؟ قال: نعم سمعتُه يقول: إنّ البذر ينزل من السماء. قال ابنُ عباس: وسمعتُ ذلك مِن كعب يقوله{16}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٣٧٤٥<span class="dash">-</span></span> عن <span class="name-2">عبيد بن عمير الليثي</span> -من طريق حبيب بن أبي ثابت- قال: الرياح أربعٌ، يبعث الله الريح الأولى فتَقُمُّ الأرض قَمًّا، ثم يبعث الثانية فتُنشئ سحابًا، ثم يبعث الثالثة فتُؤَلِّف بينه، فتجعله ركامًا، ثم يبعث الرابعة فتُمْطِره{17}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٣٧٤٦<span class="dash">-</span></span> عن <span class="name-2">وهب بن مُنَبِّه</span> -من طريق إدريس أبي الياس-: أنّ الأرض شَكَتْ إلى الله ﷿ أيام الطوفان؛ لأنّ الله ﷿ أرسل الماء بغير وزْن ولا كيل، فخرج الماءُ غضبًا لله ﷿، فخدش الأرض وخددها، فقالت: يا ربِّ، إنّ الماء خددني وخدشني. فقال الله ﷿فيما بلغني والله أعلم-: إنِّي سأجعل للماء غِربالًا لا يخددك ولا يخدشك. فجعل السحابَ غربالَ المطر{18}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَیُنَزِّلُ مِنَ ٱلسَّمَاۤءِ مِن جِبَالࣲ فِیهَا مِنۢ بَرَدࣲ فَیُصِیبُ بِهِۦ مَن یَشَاۤءُ وَیَصۡرِفُهُۥ عَن مَّن یَشَاۤءُۖ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٣٧٤٧<span class="dash">-</span></span> عن شهر بن حوشب، أنّ كعبًا سأل <span class="name-1">عبد الله بن عمرو</span> عن البرق. قال: هو ما يسبق من البرد. وقرأ: <span class="qpc-hafs">﴿جبال فيها من برد﴾</span>، <span class="qpc-hafs">﴿يكاد سنا برقه يذهب بالأبصار﴾</span>{19}. (١١/٩٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٣٧٤٨<span class="dash">-</span></span> قال <span class="name-1">عبد الله بن عباس</span>: أخبر الله ﷿ أنّ في السماء جبالًا مِن برد{20}<span class=comment-ref>٤٦٨٨</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٤٦٨٨</span> <span class="comment-type-4">قال</span> <u>ابنُ كثير</u> (٦/٧٢): «وقوله: <span class="qpc-hafs">﴿وينزل من السماء من جبال فيها من برد﴾</span> قال بعض النحاة: <span class="qpc-hafs">﴿من﴾</span> الأولى لابتداء الغاية، والثانية للتبعيض، والثالثة لبيان الجنس. وهذا إنّما يجيء على قول مَن ذهب مِن المفسرين إلى أن قوله: <span class="qpc-hafs">﴿من جبال فيها من برد﴾</span> معناه: أنّ في السماء جبال برد ينزل الله منها البرد. وأمّا من جعل الجبال ههنا عبارة عن السحاب، فإن <span class="qpc-hafs">﴿من﴾</span> الثانية عند هذا لابتداء الغاية أيضًا، لكنها بدل من الأولى».</div></p><p><div></p><p><p><span class="item-no">٥٣٧٤٩<span class="dash">-</span></span> عن <span class="name-2">عمرو بن دينار</span> -من طريق سفيان-يقول: <span class="qpc-hafs">﴿فيصيب به من يشاء﴾</span>: فهي تصيب{19}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٣٧٥٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وينزل من السماء من جبال فيها من برد فيصيب به﴾</span> بالبرد <span class="qpc-hafs">﴿من يشاء﴾</span> فيضر في زرعه وثمره، <span class="qpc-hafs">﴿ويصرفه عن من يشاء﴾</span> فلا يَضُرُّه في زرعه، ولا في ثمره{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٣٧٥١<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿وينزل من السماء من جبال فيها من برد﴾</span> ينزل من تلك الجبال التي هي مِن برد، إنّ في السماء جبالًا من برد، <span class="qpc-hafs">﴿فيصيب به من يشاء﴾</span> فيهلك الزرع، كقوله: <span class="qpc-hafs">﴿ريح فيها صر﴾</span> [آل عمران:١١٧] برد. وقال بعضهم: ريح باردة <span class="qpc-hafs">﴿أصابت﴾</span> الريحُ <span class="qpc-hafs">﴿حرث قوم ظلموا أنفسهم فأهلكته﴾</span> [آل عمران:١١٧]، وما أصاب العبادَ مِن مصيبة فبذنوبهم، وما يعفو الله عنه أكثر، كقوله: <span class="qpc-hafs">﴿وما أصابكم من مصيبة فبما كسبت أيديكم ويعفو عن كثير﴾</span> [الشورى:٣٠] ... <span class="qpc-hafs">﴿ويصرفه عن من يشاء﴾</span> يصرف ذلك البرد عمَّن يشاء{23}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَیُنَزِّلُ مِنَ ٱلسَّمَاۤءِ مِن جِبَالࣲ فِیهَا مِنۢ بَرَدࣲ فَیُصِیبُ بِهِۦ مَن یَشَاۤءُ وَیَصۡرِفُهُۥ عَن مَّن یَشَاۤءُۖ﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٥٣٧٥٢<span class="dash">-</span></span> عن نصر بن طريف، أنّ رجلًا قال لابن عباس: بِتنا الليلة نُمطر الضفادع. فقال <span class="name-1">ابن عباس</span>: صدق، إنّ في السماء بحارًا{24}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٣٧٥٣<span class="dash">-</span></span> عن <span class="name-2">كعب الأحبار</span> -من طريق قتادة- قال: لولا أنّ الجليد ينزل من السماء الرابعة لم يَمُرَّ بشيء إلا أهلكه{25}. (١١/٩٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٣٧٥٤<span class="dash">-</span></span> عن <span class="name-2">أبي جعفر</span> -من طريق زياد بن خثيمة- قال: الصاعقة تصيب المؤمن والكافر، ولا تصيب ذاكِرَ اللهِ ﷿{19}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿یَكَادُ سَنَا بَرۡقِهِۦ یَذۡهَبُ بِٱلۡأَبۡصَـٰرِ ۝٤٣﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٣٧٥٥<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطاء الخراساني- في قوله: <span class="qpc-hafs">﴿يكاد سنا برقه﴾</span>، يقول: ضَوْء برقه{27}. (١١/٩٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٣٧٥٦<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، أنّ نافع بن الأزرق قال له: أخبِرني عن قوله: <span class="qpc-hafs">﴿يكاد سنا برقه﴾</span>. قال: السنا: الضوء. قال: وهل تعرف العرب ذلك؟ قال: نعم، أما سمعت أبا سفيان بن الحارث وهو يقول:</p><p>يدعو إلى الحق لا يبغي به بدلًا يجلو بضوء سَناه داجِيَ الظُّلَمِ؟{28}. (١١/٩٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٣٧٥٧<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق مَعْمَر- <span class="qpc-hafs">﴿يكاد سنا برقه﴾</span>، قال: لمعان البرق{29}. (١١/٩٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٣٧٥٨<span class="dash">-</span></span> قال <span class="name-2">قتادة بن دعامة</span>: <span class="qpc-hafs">﴿يكاد سنا برقه﴾</span> أي: ضوء برقه <span class="qpc-hafs">﴿يذهب بالأبصار﴾</span>{30}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٣٧٥٩<span class="dash">-</span></span> عن <span class="name-2">عمرو بن دينار</span> -من طريق سفيان بن عيينة- في قوله: <span class="qpc-hafs">﴿يكاد سنا برقه يذهب بالأبصار﴾</span>، قال: لم أرَ أحدًا ذهب البرقُ ببصره، ولكن يُرسل الصواعقَ فيصيب بها من يشاء{31}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٣٧٦٠<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- قوله: <span class="qpc-hafs">﴿يكاد سنا برقه يذهب بالأبصار﴾</span>، يقول: فضوء برقه يلمع البصرُ مِنه{32}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٣٧٦١<span class="dash">-</span></span> عن <span class="name-2">عطاء الخراساني</span> -من طريق ابنه عثمان- <span class="qpc-hafs">﴿يكاد سنا برقه﴾</span>: فيُقال: يكاد ضوء برقه يذهب بالأبصار{32}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٣٧٦٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿يكاد سنا برقه﴾</span> يقول: ضوء برقه <span class="qpc-hafs">﴿يذهب بالأبصار﴾</span>{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٣٧٦٣<span class="dash">-</span></span> قال <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿يكاد سنا برقه يذهب بالأبصار﴾</span>، قال: سناه: ضوءه، يذهب بالأبصار{35}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿یَكَادُ سَنَا بَرۡقِهِۦ یَذۡهَبُ بِٱلۡأَبۡصَـٰرِ ۝٤٣﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٥٣٧٦٤<span class="dash">-</span></span> عن سليمان بن عويمر، عن عروة بن الزبير، قال: قال رسول الله ﷺ: «<b>إذا رأى أحدُكم البرقَ أو الودق فلا يُشِر إليه، ولينعت</b>»{36}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٣/٢٠٣.|2:تفسير يحيى بن سلّام ١/٤٥٤-٤٥٥. وقد أخرج ابن أبي حاتم ٨/٢٦١٧، في تفسير هذه الآية عن ابن عباس -من طريق علي- قوله: <span class="qpc-hafs">﴿يزجي سحابًا﴾</span>، يقول: يجري الفلك. وهو تفسير قوله تعالى: <span class="qpc-hafs">﴿رَبُّكُمُ الَّذِي يُزْجِي لَكُمُ الفُلْكَ فِي البَحْرِ﴾</span> [الإسراء:٦٦] كما في تفسير ابن جرير.|3:تفسير مقاتل بن سليمان ٣/٢٠٣.|4:تفسير يحيى بن سلّام ١/٤٥٤-٤٥٥.|5:عزاه السيوطي إلى ابن أبي شيبة، وابن المنذر.|6:أخرجه ابن أبي حاتم ٨/٢٦١٧-٢٦١٨.|7:أخرجه ابن جرير ١٧/٣٣٧.|8:تفسير مقاتل بن سليمان ٣/٢٠٣.|9:تفسير يحيى بن سلّام ١/٤٥٤-٤٥٥.|10:أخرجه ابن أبي حاتم ٨/٢٦١٨، وفيه: حدثني أبو تميلة، رجل من بني جمان. بدل: أبي بَجيلة.|11:أخرجه ابن جرير ١٧/٣٣٦-٣٣٧.</p><p>(مِن خَلَلِهِ) على الإفراد قراءة شاذة، تروى أيضًا عن ابن مسعود، والضحاك، وغيرهما. انظر: البحر المحيط ٦/٤٢٦.|12:أخرجه ابن جرير ١٧/٣٣٦.|13:تفسير مقاتل بن سليمان ٣/٢٠٣.|14:أخرجه ابن جرير ١٧/٣٣٧، وابن أبي حاتم ٨/٢٦١٨.|15:تفسير يحيى بن سلّام ١/٤٥٤-٤٥٥.|16:أخرجه ابن أبي حاتم ٨/٢٦١٧.|17:أخرجه ابن جرير ١٧/٣٣٦، وابن أبي حاتم ٨/٢٦١٧.|18:أخرجه الثعلبي في تفسيره ٧/٣٠٦.|19:أخرجه ابن أبي حاتم ٨/٢٦١٨.|20:تفسير البغوي ٦/٥٤.|21:أخرجه ابن أبي حاتم ٨/٢٦١٨.|22:تفسير مقاتل بن سليمان ٣/٢٠٣.|23:تفسير يحيى بن سلّام ١/٤٥٥.|24:أخرجه يحيى بن سلّام ١/٤٥٥.|25:أخرجه ابن أبي حاتم ٨/٢٦١٨، وأبو الشيخ في العظمة (٧٤٥).|26:أخرجه ابن أبي حاتم ٨/٢٦١٨.|27:أخرجه ابن جرير ١٧/٣٣٨، وابن أبي حاتم ٨/٢٦١٩. وعزاه السيوطي إلى ابن المنذر.|28:أخرجه الطستي -كما في الإتقان ٢/٧٠-.|29:أخرجه عبد الرزاق ٢/٦١-٦٢، وابن جرير ١٧/٣٣٨، وابن أبي حاتم ٨/٢٦١٩. وعزاه السيوطي إلى عبد بن حميد.|30:علَّقه يحيى بن سلّام ١/٤٥٥.|31:أخرجه إسحاق البستي في تفسيره ص٤٧٨، وابن أبي حاتم ٨/٢٦١٩.|32:أخرجه ابن أبي حاتم ٨/٢٦١٩.|33:أخرجه ابن أبي حاتم ٨/٢٦١٩.|34:تفسير مقاتل بن سليمان ٣/٢٠٣.|35:أخرجه ابن جرير ١٧/٣٣٨.|36:أخرجه عبد الرزاق ٣/٩٤ (٤٩١٧)، ويحيى بن سلّام ١/٤٥٥ مرسلًا.