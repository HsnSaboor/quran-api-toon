37,171," <q>﴿وَلَقَدۡ سَبَقَتۡ كَلِمَتُنَا لِعِبَادِنَا ٱلۡمُرۡسَلِینَ ۝١٧١ إِنَّهُمۡ لَهُمُ ٱلۡمَنصُورُونَ ۝١٧٢﴾</q> - تفسير ٦٦١٩٢- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿ولَقَدْ سَبَقَتْ كَلِمَتُنا﴾</q> الآية، قال: سبق هذا مِن الله أن ينصرهم{1}. (١٢/٤٩٤) ٦٦١٩٣- عن إسماعيل السُّدِّيّ -من طريق أسباط- في قوله: <q>﴿ولَقَدْ سَبَقَتْ كَلِمَتُنا﴾</q> الآية، قال: كانت الأنبياء تُقتَل وهم منصورون، والمؤمنون يُقتلون وهم منصورون، نُصِروا بالحُجَج في الدنيا والآخرة، ولم يُقتل نبيٌّ قطُّ ولا قوم يدعون إلى الحق من المؤمنين، فتذهب تلك الأُمَّة والقرن، حتى يبعث الله قومًا ينتصر بهم منهم{2}. (١٢/٤٩٥) ٦٦١٩٤- قال مقاتل بن سليمان: <q>﴿ولَقَدْ سَبَقَتْ كَلِمَتُنا﴾</q> بالنصر <q>﴿لِعِبادِنا المُرْسَلِينَ﴾</q> يعني: الأنبياء ﵈، يعني بالكلمة: قوله ﷿: <q>﴿كَتَبَ اللَّهُ لَأَغْلِبَنَّ أنا ورُسُلِي﴾</q> [المجادلة:٢١]، فهذه الكلمة التي سبقت للمرسلين، <q>﴿إنَّهُمْ لَهُمُ المَنصُورُونَ﴾</q> على كفار قريش{3}. (ز) ٦٦١٩٥- قال يحيى بن سلّام: قوله ﷿: <q>﴿ولَقَدْ سَبَقَتْ كَلِمَتُنا لِعِبادِنا المُرْسَلِينَ * إنَّهُمْ لَهُمُ المَنصُورُونَ﴾</q> في الدنيا، وبالحُجَّة في الآخرة{4}. (ز) ",footnotes:1:أخرجه ابن جرير ١٩/٦٥٧. وعزاه السيوطي إلى عبد بن حميد، وابن أبي حاتم.أخرجه ابن جرير ١٩/٦٥٧ مختصرًا. وعزاه السيوطي إلى ابن أبي حاتم.تفسير مقاتل بن سليمان ٣/٦٢٣.تفسير يحيى بن سلام ٢/٨٤٨.
  37,172,""
37,173," <q>﴿وَإِنَّ جُندَنَا لَهُمُ ٱلۡغَـٰلِبُونَ ۝١٧٣﴾</q> - تفسير ٦٦١٩٦- عن الحسن البصري، <q>﴿وإنَّ جُنْدَنا لَهُمُ الغالِبُونَ﴾</q>، قال: لم يُقتَل مِن الرسل أصحاب الشرائع أحدٌ قطُّ{1}. (ز) ٦٦١٩٧- عن قتادة بن دعامة -من طريق خليد- في قوله: <q>﴿وإن جندنا لهم الغالبون﴾</q>، قال: ولا أعلم أولئك إلا أهل الشام{2}. (ز) ٦٦١٩٨- قال مقاتل بن سليمان: <q>﴿وإنَّ جُنْدَنا﴾</q> حزبنا؛ يعني: المؤمنين <q>﴿لَهُمُ الغالِبُونَ﴾</q> الذين نجوا مِن عذاب الدنيا والآخرة{3}. (ز) ",footnotes:1:علقه يحيى بن سلام ٢/٨٤٨.أخرجه الفسوي في المعرفة والتاريخ ٢/٣٠٣، وابن عساكر في تاريخ دمشق ١/٢٨٧.تفسير مقاتل بن سليمان ٣/٦٢٣.
37,174," <q>﴿فَتَوَلَّ عَنۡهُمۡ حَتَّىٰ حِینࣲ ۝١٧٤﴾</q> - تفسير ٦٦١٩٩- قال عبد الله بن عباس: <q>﴿فَتَوَلَّ عَنْهُمْ حَتّى حِينٍ﴾</q>، يعني: الموت{1}. (ز) ٦٦٢٠٠- قال مجاهد بن جبر: <q>﴿فَتَوَلَّ عَنْهُمْ حَتّى حِينٍ﴾</q>، يعني: يوم بدر{1}. (ز) ٦٦٢٠١- عن قتادة بن دعامة -من طريق سعيد- <q>﴿فَتَوَلَّ عَنْهُمْ حَتّى حِينٍ﴾</q>، قال: إلى الموت{3}. (١٢/٤٩٥) ٦٦٢٠٢- عن إسماعيل السُّدِّيّ -من طريق أسباط- في قوله: <q>﴿فَتَوَلَّ عَنْهُمْ حَتّى حِينٍ﴾</q>، قال: يوم بدر{4}. (١٢/٤٩٦) ٦٦٢٠٣- عن زيد بن أسلم في قوله: <q>﴿فَتَوَلَّ عَنْهُمْ حَتّى حِينٍ﴾</q> قال: يوم القيامة{5}. (١٢/٤٩٥) ٦٦٢٠٤- قال مقاتل بن سليمان: <q>﴿فَتَوَلَّ عَنْهُمْ حَتّى حِينٍ﴾</q>، يقول الله ﷿ للنبي ﷺ: فأعرِض عن كُفّار مكة إلى العذاب؛ إلى القتل ببدر{6}. (ز) ٦٦٢٠٥- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿فَتَوَلَّ عَنْهُمْ حَتّى حِينٍ﴾</q>، قال: يوم القيامة{7}٥٥٢٩. (ز) ٥٥٢٩ اختُلِف في الحين المذكور في الآية على ثلاثة أقوال: الأول: أن المراد: إلى الموت. وهو قول قتادة. والثاني: أن المراد: إلى يوم بدر. وهو قول السديّ. والثالث: أن المراد: إلى يوم القيامة. وهو قول ابن زيد. وذَهَبَ ابنُ جرير (١٩/٦٥٩) إلى القول الثاني -وهو قول مجاهد، والسديّ- استنادًا إلى السياق، فقال: «هذا القول الذي قاله السدي أشبه بما دل عليه ظاهر التنزيل؛ وذلك أنّ الله توعدهم بالعذاب الذي كانوا يستعجلونه، فقال: <q>﴿أفبعذابنا يستعجلون﴾</q>، وأمر نبيَّه ﷺ أن يُعرِض عنهم إلى مجيء حينه، فتأويل الكلام: فتول عنهم -يا محمد- إلى حين مجيء عذابنا ونزوله بهم». <q>﴿فَتَوَلَّ عَنۡهُمۡ حَتَّىٰ حِینࣲ ۝١٧٤﴾</q> - النسخ في الآية ٦٦٢٠٦- عن قتادة بن دعامة -من طريق سعيد- <q>﴿فَتَوَلَّ عَنْهُمْ حَتّى حِينٍ﴾</q>، قال: نسخها القتال في سورة براءة: <q>﴿فاقْتُلُوا المُشْرِكِينَ حَيْثُ وجَدْتُمُوهُمْ﴾</q> [التوبة:٥]{8}. (ز) ٦٦٢٠٧- قال مقاتل بن حيان: <q>﴿فَتَوَلَّ عَنْهُمْ حَتّى حِينٍ﴾</q> نسختها آية القتال{1}٥٥٣٠. (ز) ٥٥٣٠ قال ابنُ عطية (٧/٣١٧ بتصرف): «وعد للنبي ﷺ، وأمر بالموادعة، وهذا مما نسخته آية السيف». ",footnotes:1:تفسير الثعلبي ٨/١٧٣، وتفسير البغوي ٤/٥٠.تفسير الثعلبي ٨/١٧٣، وتفسير البغوي ٤/٥٠.أخرجه ابن جرير ١٩/٦٥٨. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.أخرجه ابن جرير ١٩/٦٥٨. وعزاه السيوطي إلى ابن أبي حاتم.عزاه السيوطي إلى ابن أبي حاتم.تفسير مقاتل بن سليمان ٣/٦٢٣.أخرجه ابن جرير ١٩/٦٥٩.أخرجه يحيى بن سلام ٢/٨٤٨.تفسير الثعلبي ٨/١٧٣، وتفسير البغوي ٤/٥٠.
37,175," <q>﴿وَأَبۡصِرۡهُمۡ فَسَوۡفَ یُبۡصِرُونَ ۝١٧٥﴾</q> - تفسير ٦٦٢٠٨- عن الحسن البصري: <q>﴿وأَبْصِرْهُمْ فَسَوْفَ يُبْصِرُونَ﴾</q>، يعني: النفخة الأولى بها يهلك كفار آخر هذه الأمة الدّائنين بدِين أبي جهل وأصحابه{1}. (ز) ٦٦٢٠٩- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿وأَبْصِرْهُمْ فَسَوْفَ يُبْصِرُونَ﴾</q>، قال: أبصروا حين لم ينفعهم البصر{2}. (١٢/٤٩٥) ٦٦٢١٠- قال مقاتل بن سليمان: <q>﴿وأَبْصِرْهُمْ﴾</q> إذا نزل بهم العذاب ببدر، <q>﴿فَسَوْفَ يُبْصِرُونَ﴾</q> العذاب{3}. (ز) ٦٦٢١١- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿وأَبْصِرْهُمْ فَسَوْفَ يُبْصِرُونَ﴾</q>، يقول: أنظِرْهم فسوف يُبصرون ما لهم بعد اليوم. قال: يقول: يبصرون يوم القيامة ما ضيَّعوا مِن أمر الله، وكفرهم بالله ورسوله وكتابه. قال: فـ«أبصِرهم» و«أبصِر» واحد{4}. (ز) ٦٦٢١٢- قال يحيى بن سلّام: قال: <q>﴿وأَبْصِرْهُمْ فَسَوْفَ يُبْصِرُونَ﴾</q>، أي: فسوف يرون العذاب{5}. (ز) ",footnotes:1:علقه يحيى بن سلام ٢/٨٤٨.أخرجه ابن جرير ١٩/٦٥٩. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.تفسير مقاتل بن سليمان ٣/٦٢٣.أخرجه ابن جرير ١٩/٦٥٩.تفسير يحيى بن سلام ٢/٨٤٨.
37,176," <q>﴿أَفَبِعَذَابِنَا یَسۡتَعۡجِلُونَ ۝١٧٦﴾</q> - نزول الآية، وتفسيرها ٦٦٢١٣- عن عبد الله بن عباس، قال: قالوا: يا محمد، أرِنا العذابَ الذي تُخَوِّفنا به، عجِّله لنا. فنزلت: <q>﴿أفَبِعَذابِنا يَسْتَعْجِلُونَ﴾</q>{1}. (١٢/٤٩٦) ٦٦٢١٤- قال مقاتل بن سليمان: <q>﴿فَسَوْفَ يُبْصِرُونَ﴾</q> العذابَ، فقالوا للنبي ﷺ: متى هذا الوعد؟ تكذيبًا به؛ فأنزل الله ﷿: <q>﴿أفَبِعَذابِنا يَسْتَعْجِلُونَ﴾</q>{2}. (ز) ",footnotes:1:عزاه السيوطي إلى جويبر. قال السيوطي في لباب النقول ص١٦٧: «صحيح على شرط الشيخين».تفسير مقاتل بن سليمان ٣/٦٢٣-٦٢٤.
37,177," <q>﴿فَإِذَا نَزَلَ بِسَاحَتِهِمۡ فَسَاۤءَ صَبَاحُ ٱلۡمُنذَرِینَ ۝١٧٧﴾</q> - تفسير ٦٦٢١٥- عن إسماعيل السُّدِّيّ -من طريق أسباط- في قوله: في قوله: <q>﴿فَإذا نَزَلَ بِساحَتِهِمْ﴾</q> قال: بدارهم <q>﴿فَساءَ صَباحُ المُنْذَرِينَ﴾</q> قال: بئسما يُصبِحون{1}. (١٢/٤٩٦) ٦٦٢١٦- قال مقاتل بن سليمان: <q>﴿فَإذا نَزَلَ بِساحَتِهِمْ﴾</q> بحضرتهم <q>﴿فَساءَ صَباحُ﴾</q> فبئس صباح <q>﴿المُنْذَرِينَ﴾</q> الذين أنذروا العذاب{2}. (ز) <q>﴿فَإِذَا نَزَلَ بِسَاحَتِهِمۡ فَسَاۤءَ صَبَاحُ ٱلۡمُنذَرِینَ ۝١٧٧﴾</q> - آثار متعلقة بالآية ٦٦٢١٧- عن أنس بن مالك: أنّ رسول الله ﷺ غزا خيبر، فصلَّينا عندها صلاة الغداة بغَلَس، فركب نبيُّ الله ﷺ وركب أبو طلحة، وأنا رديف أبي طلحة، فأجرى نبي الله ﷺ في زقاق خيبر، وإنّ ركبتي لَتَمَسُّ فَخِذ نبيِّ الله ﷺ، ثم حسر الإزارَ عن فخذه حتى إني أنظر إلى بياض فخذ نبي الله ﷺ، فلما دخل القرية قال: «الله أكبر، خربت خيبر، إنا إذا نزلنا بساحة قوم <q>﴿فساء صباح المنذرين﴾</q>» قالها ثلاثًا{3}. (١٢/٤٩٦) ",footnotes:1:أخرجه ابن جرير ١٩/٦٦٠. وعزاه السيوطي إلى ابن أبي حاتم.تفسير مقاتل بن سليمان ٣/٦٢٣-٦٢٤.أخرجه البخاري ١/٨٣-٨٤ (٣٧١)، ١/١٢٥-١٢٦ (٦١٠)، ٤/٤٨ (٢٩٤٥)، ٤/٥٦-٥٧ (٢٩٩١)، ٤/٢٠٨ (٣٦٤٧)، ٥/١٣١-١٣٢ (٤١٩٧-٤١٩٩)، ٧/٩٥-٩٦ (٥٥٢٨)، وعبد الرزاق ٣/١٠٩ (٢٥٧٠) مختصرًا.
37,178," <q>﴿وَتَوَلَّ عَنۡهُمۡ حَتَّىٰ حِینࣲ ۝١٧٨﴾</q> - تفسير ٦٦٢١٨- عن مجاهد بن جبر، في قوله: <q>﴿وتَوَلَّ عَنْهُمْ حَتّى حِينٍ﴾</q>، قال: قيل له: أعرِض عنهم{1}. (١٢/٤٩٧) ٦٦٢١٩- قال إسماعيل السُّدِّيّ، في قوله: <q>﴿وتَوَلَّ عَنْهُمْ حَتّى حِينٍ﴾</q>: يعني: إلى حين آجالهم{2}. (ز) ٦٦٢٢٠- قال مقاتل بن سليمان: <q>﴿وتَوَلَّ عَنْهُمْ حَتّى حِينٍ﴾</q> أعرِض عنهم إلى تلك المدة؛ القتل ببدر{3}. (ز) <q>﴿وَتَوَلَّ عَنۡهُمۡ حَتَّىٰ حِینࣲ ۝١٧٨﴾</q> - النسخ في الآية ٦٦٢٢١- قال قتادة بن دعامة: <q>﴿وتَوَلَّ عَنْهُمْ حَتّى حِينٍ﴾</q> نسخها القتال، هي مثل الأولى{2}. (ز) ",footnotes:1:عزاه السيوطي إلى ابن أبي حاتم.علقه يحيى بن سلام ٢/٨٤٩.تفسير مقاتل بن سليمان ٣/٦٢٤.علقه يحيى بن سلام ٢/٨٤٩.
37,179," <q>﴿وَأَبۡصِرۡ فَسَوۡفَ یُبۡصِرُونَ ۝١٧٩﴾</q> - تفسير ٦٦٢٢٢- عن زيد بن أسلم، في قوله: <q>﴿وأَبْصِرْ فَسَوْفَ يُبْصِرُونَ﴾</q>، قال: يقول: يوم القيامة؛ ما صنعوا مِن أمر الله وكفرهم بالله ورسوله وكتابه. قال: أبصِر وأبصِرهم واحد{1}. (١٢/٤٩٧) ٦٦٢٢٣- قال مقاتل بن سليمان: <q>﴿وأَبْصِرْ﴾</q> وأبصر العذاب، <q>﴿فَسَوْفَ يُبْصِرُونَ﴾</q> العذاب{2}. (ز) ٦٦٢٢٤- قال يحيى بن سلّام: <q>﴿وأَبْصِرْ﴾</q> انتظر، <q>﴿فَسَوْفَ يُبْصِرُونَ﴾</q> فسوف يرون العذاب{3}. (ز) ",footnotes:1:عزاه السيوطي إلى ابن أبي حاتم.تفسير مقاتل بن سليمان ٣/٦٢٤.تفسير يحيى بن سلام ٢/٨٤٩.
37,180," <q>﴿سُبۡحَـٰنَ رَبِّكَ رَبِّ ٱلۡعِزَّةِ عَمَّا یَصِفُونَ ۝١٨٠﴾</q> - تفسير ٦٦٢٢٥- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿سُبْحانَ رَبِّكَ رَبِّ العِزَّةِ﴾</q> قال: سبَّح نفسه إذ كُذِب عليه وقيل عليه البهتان، <q>﴿عَمّا يَصِفُونَ﴾</q> قال: عما يكذبون{1}. (١٢/٤٩٧) ٦٦٢٢٦- قال مقاتل بن سليمان: ثم نزَّه نفسه عن قولهم، فقال ﷿: <q>﴿سُبْحانَ رَبِّكَ رَبِّ العِزَّةِ﴾</q> يعني: عزة مَن يَتَعَزَّز مِن ملوك الدنيا <q>﴿عَمّا يَصِفُونَ﴾</q> عمّا يقولون من الكذب: إنّ الملائكة بنات الله ﷿{2}. (ز) ٦٦٢٢٧- قال يحيى بن سلّام: <q>﴿سُبْحانَ رَبِّكَ﴾</q> يُنَزِّه نفسه <q>﴿رَبِّ العِزَّةِ عَمّا يَصِفُونَ﴾</q> عما يكذبون{3}. (ز) ",footnotes:1:أخرجه عبد الرزاق ٢/١٥٩ من طريق معمر، وابن جرير ١٩/٦٦١. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.تفسير مقاتل بن سليمان ٣/٦٢٤.تفسير يحيى بن سلام ٢/٨٤٩.
37,181," <q>﴿وَسَلَـٰمٌ عَلَى ٱلۡمُرۡسَلِینَ ۝١٨١ وَٱلۡحَمۡدُ لِلَّهِ رَبِّ ٱلۡعَـٰلَمِینَ ۝١٨٢﴾</q> - تفسير ٦٦٢٢٨- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿وسَلامٌ عَلى المُرْسَلِينَ﴾</q>، قال: قال رسول الله ﷺ: «إذا سَلَّمْتُم عَلَيَّ فسلِّموا على المرسلين؛ فإنّما أنا رسولٌ مِن المرسلين»{1}. (١٢/٤٩٧) ٦٦٢٢٩- عن أنس، قال: قال رسول الله ﷺ: «إذا سلَّمتُم عَلَيَّ فسَلِّموا على المرسلين؛ فإنما أنا رسول من المرسلين». قال أبو العوام: كان قتادة يذكر هذا الحديثَ إذا تلا هذه الآيات: <q>﴿سُبْحانَ رَبِّكَ رَبِّ العِزَّةِ عَمّا يَصِفُونَ * وسَلامٌ عَلى المُرْسَلِينَ * والحَمْدُ لِلَّهِ رَبِّ العالَمِينَ﴾</q> دبر الصلاة{2}. (١٢/٤٩٧) ٦٦٢٣٠- قال إسماعيل السُّدِّيّ: <q>﴿وسَلامٌ عَلى المُرْسَلِينَ﴾</q>، يعني: الثناء الحسن{3}. (ز) ٦٦٢٣١- قال مقاتل بن سليمان: <q>﴿وسَلامٌ عَلى المُرْسَلِينَ﴾</q> الذين بلَّغوا عن الله التوحيد، <q>﴿والحَمْدُ لِلَّهِ رَبِّ العالَمِينَ﴾</q> على هلاك الآخرين الذين لم يُوَحِّدوا ربهم{4}. (ز) <q>﴿وَسَلَـٰمٌ عَلَى ٱلۡمُرۡسَلِینَ ۝١٨١ وَٱلۡحَمۡدُ لِلَّهِ رَبِّ ٱلۡعَـٰلَمِینَ ۝١٨٢﴾</q> - آثار متعلقة بالآية ٦٦٢٣٢- عن عبد الله بن عباس، قال: كُنّا نعرِف انصرافَ رسول الله ﷺ مِن الصلاة بقوله: <q>﴿سُبْحانَ رَبِّكَ رَبِّ العِزَّةِ عَمّا يَصِفُونَ * وسَلامٌ عَلى المُرْسَلِينَ * والحَمْدُ لِلَّهِ رَبِّ العالَمِينَ﴾</q>{5}. (١٢/٤٩٨) ٦٦٢٣٣- عن أبي سعيد، عن رسول الله ﷺ: أنّه كان إذا أراد أن يُسلِّم من صلاته قال: <q>﴿سُبْحانَ رَبِّكَ رَبِّ العِزَّةِ عَمّا يَصِفُونَ * وسَلامٌ عَلى المُرْسَلِينَ * والحَمْدُ لِلَّهِ رَبِّ العالَمِينَ﴾</q>{6}. (١٢/٤٩٨) ٦٦٢٣٤- عن زيد بن أرقم، عن رسول الله ﷺ، قال: «من قال دبر كل صلاة: <q>﴿سُبْحانَ رَبِّكَ رَبِّ العِزَّةِ عَمّا يَصِفُونَ * وسَلامٌ عَلى المُرْسَلِينَ * والحَمْدُ لِلَّهِ رَبِّ العالَمِينَ﴾</q> ثلاث مرات؛ فقد اكتال بالمكيال الأوفى من الأجر»{7}. (١٢/٤٩٩) ٦٦٢٣٥- عن الشعبي، قال: قال رسول الله ﷺ: «مَن سرَّه أن يكتال بالمكيال الأوفى مِن الأجر يوم القيامة فليَقُل آخرَ مجلسه حين يريد أن يقوم: <q>﴿سُبْحانَ رَبِّكَ رَبِّ العِزَّةِ عَمّا يَصِفُونَ * وسَلامٌ عَلى المُرْسَلِينَ * والحَمْدُ لِلَّهِ رَبِّ العالَمِينَ﴾</q>»{8}. (١٢/٤٩٩) ٦٦٢٣٦- عن علي بن أبي طالب -من طريق الأصبغ بن نباتة- قال: مَن أحبَّ أن يكتال بالمكيال الأوفى مِن الأجر يوم القيامة فليكن آخرَ كلامه من مجلسه: <q>﴿سُبْحانَ رَبِّكَ رَبِّ العِزَّةِ عَمّا يَصِفُونَ * وسَلامٌ عَلى المُرْسَلِينَ * والحَمْدُ لِلَّهِ رَبِّ العالَمِينَ﴾</q>{9}. (ز) ",footnotes:1:أخرجه عبد الرزاق في تفسيره ٢/١٥٩، من طريق معمر مختصرًا، وابن جرير ١٩/٦٦١. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.أخرجه أبو الشيخ في طبقات المحدثين بأصبهان ٢/١٠-١١ المرفوع فقط، وأبو نعيم في أخبار أصبهان ١/١٤٩، ٢/٣١١، والثعلبي ٨/١٧٣. قال الألباني في الصحيحة ٦/١١٢٧: «وهذا إسناد حسن، لولا أن إبراهيم هذا ذكره ابن أبي حاتم في الجرح، وقال: سألت أبي عنه؟ فقال: لا أعرفه. وذكر أنه روى عنه النضر بن هشام الأصبهاني وعبد الرزاق بن بكر الأصبهاني. قلت: فهو على شرط ابن حبان في الثقات».علقه يحيى بن سلام ٢/٨٤٩.تفسير مقاتل بن سليمان ٣/٦٢٤.أخرجه الطبراني في الكبير ١١/١١٥ (١١٢٢١). قال الهيثمي المجمع ١٠/١٠٣ (١٦٩٢٧): «فيه محمد بن عبد الله بن عبيد بن عمير، وهو متروك». وقال الصالحي في سبل الهدى والرشاد ٨/١٦٩: «بسند ضعيف». وقال الألباني في الضعيفة ٩/٢١٦: «واهٍ، لا يفرح به».أخرجه الطيالسي في مسنده ٣/٦٥١-٦٥٢ (٢٣١٢)، وابن أبي شيبة في مصنفه ١/٢٦٩ (٣٠٩٧)، ومجاهد في تفسيره ص٥٧١. قال المناوي في التيسير ٢/٢٥٢: «وإسناده حسن». وقال الألباني في الضعيفة ٩/٢١٥ (٤٢٠١): «ضعيف جدًّا».أخرجه الطبراني في الكبير ٥/٢١١ (٥١٢٤). قال الهيثمي المجمع ١٠/١٠٢-١٠٣ (١٦٩٢٦): «فيه عبد المنعم بن بشير، وهو ضعيف جدًّا». وقال الألباني في الضعيفة ١٤/٦٩ (٦٥٢٩): «موضوع».أخرجه ابن أبي حاتم -كما في تفسير ابن كثير ٧/٤٢، وتخريج أحاديث الكشاف ٣/١٨٢- مرسلًا.أخرجه يحيى بن سلام ٢/٨٤٩.
  37,182,""
