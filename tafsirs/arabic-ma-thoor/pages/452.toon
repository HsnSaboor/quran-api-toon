37,164," <q>﴿وَمَا مِنَّاۤ إِلَّا لَهُۥ مَقَامࣱ مَّعۡلُومࣱ ۝١٦٤﴾</q> - نزول الآية، وتفسيرها ٦٦١٤٨- عن عبد الله بن عباس -من طريق عطية العوفي- في قوله: <q>﴿وما مِنّا إلّا لَهُ مَقامٌ مَعْلُومٌ﴾</q>، قال: الملائكة{1}. (١٢/٤٨٧) ٦٦١٤٩- عن سعيد بن جبير -من طريق عطاء بن دينار- <q>﴿وما مِنّا إلّا لَهُ مَقامٌ مَعْلُومٌ﴾</q>، قال: الملائكة؛ ما في السماء موضع إلا عليه مَلَكٌ إما ساجدًا أو قائمًا حتى تقوم الساعة{2}. (١٢/٤٨٧) ٦٦١٥٠- عن مجاهد بن جبر -من طريق ابن أبي نجيح-، مثله{3}. (١٢/٤٨٧) ٦٦١٥١- عن عكرمة مولى ابن عباس، <q>﴿وما مِنّا إلّا لَهُ مَقامٌ مَعْلُومٌ﴾</q>، قال: ذاك قول جبريل ﵇{4}. (١٢/٤٨٧) ٦٦١٥٢- عن قتادة بن دعامة، قال: كانوا يُصَلُّون الرجالُ والنساءُ جميعًا، حتى نزلت: <q>﴿وما مِنّا إلّا لَهُ مَقامٌ مَعْلُومٌ﴾</q> فتقدم الرجال وتأخَّر النساء{5}. (١٢/٤٨٩) ٦٦١٥٣- عن قتادة بن دعامة -من طريق سعيد- <q>﴿وما مِنّا إلّا لَهُ مَقامٌ مَعْلُومٌ * وإنّا لَنَحْنُ الصّافُّونَ * وإنّا لَنَحْنُ المُسَبِّحُونَ﴾</q>، قال: هذا قول الملائكة، يُنَزِّهون اللهَ عما قالت اليهودُ، حيث جعلوا بينه وبين الجنة نسبًا، ويخبرون بمكانهم في السموات في صفوفهم وتسبيحهم، وهو قوله في أول السورة: <q>﴿والصّافّاتِ صَفًّا﴾</q>، ليس في السموات موضع شبر إلا وعليه ملك قائم، أو راكع، أو ساجد{6}. (ز) ٦٦١٥٤- عن إسماعيل السُّدِّيّ -من طريق أسباط- في قوله: <q>﴿وما مِنّا إلّا لَهُ مَقامٌ مَعْلُومٌ﴾</q>، قال: الملائكة{7}. (ز) ٦٦١٥٥- قال إسماعيل السُّدِّيّ: <q>﴿وما مِنّا إلّا لَهُ مَقامٌ مَعْلُومٌ﴾</q>، يعني: في القربة والمشاهدة{8}. (ز) ٦٦١٥٦- قال إسماعيل السُّدِّيّ: <q>﴿إلّا لَهُ مَقامٌ مَعْلُومٌ﴾</q>، يعني: مكان معلوم يعبد الله فيه، وهم الملائكة{9}. (ز) ٦٦١٥٧- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿وما مِنّا إلّا لَهُ مَقامٌ مَعْلُومٌ﴾</q>، قال: هؤلاء الملائكة{7}٥٥٢٧. (ز) ٥٥٢٧ قال ابنُ عطية (٧/٣١٦) عند قوله تعالى: <q>﴿وما مِنّا إلّا لَهُ مَقامٌ مَعْلُومٌ﴾</q>: «هذا يؤيد أن <q>﴿الجِنَّة﴾</q> أراد بها: الملائكة،كأنه قال: ولقد علمت كذا، وإن قولنا لكذا، وتقدير الكلام: وما منا ملك». ",footnotes:1:أخرجه عبد الرزاق ٢/١٥٨ عن قتادة، وأخرجه ابن جرير ١٩/٦٥٤. وعزاه السيوطي إلى عبد بن حميد.أخرجه أبو الشيخ في العظمة (٥٠٨).تفسير مجاهد (٥٧١) مختصرًا، وأخرجه ابن جرير ١٩/٦٥٤. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.عزاه السيوطي إلى عبد بن حميد.عزاه السيوطي إلى ابن أبي حاتم.أخرجه يحيى بن سلام ٢/٨٤٧.أخرجه ابن جرير ١٩/٦٥١.تفسير الثعلبي ٨/١٧٢، وتفسير البغوي ٤/٥٠.علقه يحيى بن سلام ٢/٨٤٧.أخرجه ابن جرير ١٩/٦٥١.
37,165," <q>﴿وَإِنَّا لَنَحۡنُ ٱلصَّاۤفُّونَ ۝١٦٥ وَإِنَّا لَنَحۡنُ ٱلۡمُسَبِّحُونَ ۝١٦٦﴾</q> - نزول الآية ٦٦١٥٨- عن زيد بن مالك، قال: كان الناس يُصَلُّون مُتَبَدِّدين{1}؛ فأنزل الله: <q>﴿وإنّا لَنَحْنُ الصّافُّونَ﴾</q> فأمرهم أن يَصفُّوا{2}. (١٢/٤٨٩) ٦٦١٥٩- عن الوليد بن عبد الله بن أبي مغيث -من طريق ابن جريج- قال: كانوا لا يصُفُّون في الصلاة حتى نزلت: <q>﴿وإنّا لَنَحْنُ الصّافُّونَ﴾</q>{2}. (١٢/٤٨٩) ٦٦١٦٠- عن عبد الملك ابن جريج، قال: حُدِّثتُ: أنهم كانوا لا يصُفُّون حتى نزلت: <q>﴿وإنّا لَنَحْنُ الصّافُّون﴾</q>{4}. (١٢/٤٨٩) <q>﴿وَإِنَّا لَنَحۡنُ ٱلصَّاۤفُّونَ ۝١٦٥ وَإِنَّا لَنَحۡنُ ٱلۡمُسَبِّحُونَ ۝١٦٦﴾</q> - تفسير الآية ٦٦١٦١- عن عائشة، قالت: قال رسول الله ﷺ: «ما في السماء موضِعٌ قدمٍ إلا عليه مَلَك ساجد أو قائم». وذلك قول الملائكة: <q>﴿وما مِنّا إلّا لَهُ مَقامٌ مَعْلُومٌ * وإنّا لَنَحْنُ الصّافُّونَ﴾</q>{5}. (١٢/٤٨٨) ٦٦١٦٢- عن أنس، أنّ النبي ﷺ كان إذا قام إلى الصلاة قال: «استووا وتراصُّوا، يريدُ الله بكم هَدْي الملائكة». وقرأ رسول الله ﷺ: <q>﴿وإنّا لَنَحْنُ الصّافُّونَ * وإنّا لَنَحْنُ المُسَبِّحُونَ﴾</q>{6}. (١٢/٤٩٠) ٦٦١٦٣- عن العلاء بن سعد، أنّ رسول الله ﷺ قال يومًا لجلسائه: «أطَّت{7} السماء، وحُقَّ لها أن تئط؛ ليس منها موضع قدم إلا عليه ملك راكع أو ساجد». ثم قرأ: <q>﴿وإنّا لَنَحْنُ الصّافُّونَ * وإنّا لَنَحْنُ المُسَبِّحُونَ﴾</q>{8}. (١٢/٤٨٨) ٦٦١٦٤- عن الحسن البصري، قال: كانت أول صلاة صلاها رسول الله ﷺ الظهر، فأتاه جبريل، فقال: <q>﴿وإنّا لَنَحْنُ الصّافُّونَ * وإنّا لَنَحْنُ المُسَبِّحُونَ﴾</q>. فقام جبريل بين يديه، ورسول الله ﷺ خلفه، ثم صفَّ الناسُ خلفه، والنساءُ خلف الرجال، فصلى بهم الظهر أربعًا، حتى إذا كان عند العصر قام جبريل ففعل مثلها، ثم جاءه حين غربت الشمس فصلى بهم ثلاثًا، يقرأ في الركعتين الأوليين يجهر فيهما، ولم يُسمع في الثالثة، حتى إذا كان عند العشاء وغاب الشفق جاءه جبريل فصلى بالناس أربع ركعات، يجهر بالقراءة في ركعتين، حتى إذا أصبح ليلته أتاه فصلى ركعتين يجهر فيهما، ويطيل القراءة{9}. (١٢/٤٩٠) ٦٦١٦٥- عن أبي نضرة، قال: كان عمر بن الخطاب إذا أقيمت الصلاة قال: استووا، تقدَّم يا فلان، تأخَّر يا فلان، أقيموا صفوفكم، يريد الله بكم هَدْيَ الملائكة. ثم يتلو: <q>﴿وإنّا لَنَحْنُ الصّافُّونَ * وإنّا لَنَحْنُ المُسَبِّحُونَ﴾</q>{10}. (١٢/٤٩٠) ٦٦١٦٦- عن عبد الله بن مسعود -من طريق السُّدِّيّ- قال: إنّ مِن السماوات لَسماء ما فيها موضع شِبْر إلا وعليه جبهةُ ملَك أو قدماه قائمًا أو ساجدًا. ثم قرأ: <q>﴿وإنّا لَنَحْنُ الصّافُّونَ * وإنّا لَنَحْنُ المُسَبِّحُونَ﴾</q>{11}. (١٢/٤٨٨) ٦٦١٦٧- عن عبد الله بن عباس -من طريق عكرمة- في قوله: <q>﴿وإنّا لَنَحْنُ الصّافُّونَ﴾</q> قال: الملائكة، <q>﴿وإنّا لَنَحْنُ المُسَبِّحُونَ﴾</q> قال: الملائكة{12}. (١٢/٤٨٧) ٦٦١٦٨- قال عبد الله بن عباس: <q>﴿وإنّا لَنَحْنُ المُسَبِّحُونَ﴾</q> ما في السماوات موضع شبر إلا وعليه مَلَك مُصَلٍّ أو مُسَبِّح{13}. (ز) ٦٦١٦٩- عن مجاهد بن جبر -من طريق ابن جريج- <q>﴿وإنا لنحن الصافون﴾</q>: الملائكة{14}. (ز) ٦٦١٧٠- عن مجاهد بن جبر: <q>﴿وإنّا لَنَحْنُ الصّافُّونَ * وإنّا لَنَحْنُ المُسَبِّحُونَ﴾</q> قال: أطَّت السماء، وما تلام أن تئط؛ إن في السماء لسماء ما فيها موضع شبر إلا عليه جبهة ملك أو قدماه{15}. (١٢/٤٨٨) ٦٦١٧١- عن أبي صالح باذام، قال: لَمّا نزلت هذه الآية: <q>﴿إنَّ رَبَّكَ يَعْلَمُ أنَّكَ تَقُومُ أدْنى مِن ثُلُثَيِ اللَّيْلِ﴾</q> إلى قوله: <q>﴿عَلِمَ أنْ لَنْ تُحْصُوهُ﴾</q> [المزمل:٢٠]؛ قال جبريل: أشَقَّ ذلك عليكم؟ قال: «نعم». قال: <q>﴿وما مِنّا إلّا لَهُ مَقامٌ مَعْلُومٌ * وإنّا لَنَحْنُ الصّافُّونَ * وإنّا لَنَحْنُ المُسَبِّحُونَ﴾</q>{16}. (١٢/٤٩٣) ٦٦١٧٢- عن قتادة بن دعامة -من طريق معمر- <q>﴿وإنّا لَنَحْنُ الصّافُّونَ﴾</q>، قال: الملائكة{17}. (ز) ٦٦١٧٣- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿وإنّا لَنَحْنُ الصّافُّونَ﴾</q> قال: صفوف في السماء، <q>﴿وإنّا لَنَحْنُ المُسَبِّحُونَ﴾</q> أي: المصلون، هذا قول الملائكة. قال: يُثنون بمكانهم من العبادة{18}. (١٢/٤٩٤) ٦٦١٧٤- عن إسماعيل السُّدِّيّ -من طريق أسباط- في قوله: <q>﴿وإنّا لَنَحْنُ الصّافُّونَ﴾</q>، قال: للصلاة{19}. (ز) ٦٦١٧٥- قال محمد بن السائب الكلبي: <q>﴿وإنّا لَنَحْنُ الصّافُّون﴾</q> صفوف الملائكة في السماء للعبادة كصفوف الناس في الأرض{20}. (ز) ٦٦١٧٦- قال مقاتل بن سليمان: <q>﴿وما مِنّا إلّا لَهُ مَقامٌ مَعْلُومٌ * وإنّا لَنَحْنُ الصّافُّونَ﴾</q> يعني: صفوف الملائكة في السموات في الصلاة، <q>﴿وإنّا لَنَحْنُ المُسَبِّحُونَ﴾</q> يعني: المصلين. يخبر جبريلُ النبيَّ ﷺ بعبادتهم لربهم ﷿، فكيف يعبدهم كفار مكة؟!{21}. (ز) ٦٦١٧٧- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- <q>﴿وإنّا لَنَحْنُ الصّافُّونَ﴾</q>، قال: الملائكة، هذا كله لهم{22}٥٥٢٨. (ز) ٥٥٢٨ ذكر ابنُ عطية (٧/٣١٦) أن <q>﴿المُسَبِّحُونَ﴾</q> يحتمل أن يريد به: الصلاة، ويحتمل أن يريد به: قول: سبحان الله. ٦٦١٧٨- عن سفيان بن عيينة -من طريق ابن أبي عمر- في قوله: <q>﴿وإنا لنحن الصافون﴾</q>، قال: الملائكة قالت: نحن الصافون؛ يعني: صُفَّةً{14}. (ز) <q>﴿وَإِنَّا لَنَحۡنُ ٱلصَّاۤفُّونَ ۝١٦٥ وَإِنَّا لَنَحۡنُ ٱلۡمُسَبِّحُونَ ۝١٦٦﴾</q> - آثار متعلقة بالآية ٦٦١٧٩- عن أبي ذرٍّ، قال: قال رسول الله ﷺ: «إنِّي أرى ما لا ترون، وأسمع ما لا تسمعون، إنّ السماء أطَّت، وحُقّ لها أن تئط؛ ما فيها موضع أربع أصابع إلا وملك واضِعٌ جبهتَه ساجدًا لله»{24}. (١٢/٤٨٩) ٦٦١٨٠- عن جابر بن سمرة، قال: قال رسول الله ﷺ: «ألا تَصُفُّونَ كَما تَصُفُّ الملائكةُ عند ربها؟!». فقلنا: وكيف تَصُفُّ الملائكة عند ربها؟ قال: «يُتِمُّون الصفوف الأُوَل، ويتراصُّون في الصف»{25}. (١٢/٤٩١) ٦٦١٨١- عن حذيفة، قال: قال رسول الله ﷺ: «فُضِّلنا على الناس بثلاث: جُعلت صفوفنا كصفوف الملائكة، وجُعلت لنا الأرض كلها مسجدًا، وجُعلت تربتها لنا طهورًا إذا لم نجد الماء»{26}. (١٢/٤٩١) ",footnotes:1:متبددين: متفرقين. التاج (بدد).عزاه السيوطي إلى ابن أبي حاتم.عزاه السيوطي إلى ابن أبي حاتم.أخرجه عبد الرزاق في المصنف (٢٤٢٣). وعزاه السيوطي إلى ابن المنذر.أخرجه محمد بن نصر في تعظيم قدر الصلاة ١/٢٦٠ (٢٥٣)، وأبو الشيخ الأصبهاني في العظمة ٣/٩٨٤-٩٨٥ (٥٠٨)، وابن جرير ١٩/٦٥١-٦٥٢. وفيه أبو معاذ الفضل بن خالد النحوي. قال ابن كثير في تفسيره ٨/٢٧١: «وهذا مرفوع غريب جدًّا». وقال الألباني في الصحيحة ٣/٤٩ (١٠٥٩): «هذا إسناد حسن في الشواهد، رجاله ثقات غير الفضل هذا، فقد ترجمه ابن أبي حاتم (٣/٢/٦١) من رواية ثقتين عنه، ولم يذكر فيه جرحًا ولا تعديلًا، ثم روى من طريق مسلم بن صبيح عن أبي الضحى عن مسروق عن عبد الله بن مسعود ﵁ قال: فذكره موقوفًا عليه باختصار، وهو في حكم المرفوع، وإسناده صحيح».عزاه السيوطي إلى ابن مردويه.أطَّت: الأطيط صوت الأقتاب، أي: أن كثرة ما فيها من الملائكة قد أثقلها حتى أطَّت. النهاية (أطط).أخرجه محمد بن نصر في كتاب تعظيم قدر الصلاة ١/٢٦١-٢٦٢ (٢٥٥)، وابن عساكر في تاريخه ٥٢/٣٨١. قال ابن كثير ٨/٢٧١: «وهذا إسناد غريب جدًّا».أخرجه عبد الرزاق في المصنف (١٧٧١).أخرجه ابن جرير ١٩/٦٥٣ بنحوه، وابن أبي حاتم -كما في تفسير ابن كثير ٧/٣٩-. وعزاه السيوطي إلى عبد بن حميد.أخرجه عبد الرزاق ٢/١٥٨ من طريق مسروق، وابن جرير ١٩/٦٥٤ بنحوه، والطبراني (٩٠٤٢)، والبيهقي في شعب الإيمان (١٥٩). وعزاه السيوطي إلى الفريابي، وسعيد بن منصور، وعبد بن حميد، وابن المنذر، وابن أبي حاتم.أخرجه عبد بن حميد -كما في التغليق ٣/٤٩٤-، وأخرجه ابن جرير ١٩/٦٥٤ من طريق عطية العوفي بلفظ: الملائكة صافون تسبح لله ﷿.تفسير الثعلبي ٨/١٧٢.أخرجه إسحاق البستي ص٢٢٤.عزاه السيوطي إلى عبد بن حميد.أخرجه محمد بن نصر في مختصر قيام الليل (٥).أخرجه عبد الرزاق ٢/١٥٨، وابن جرير ١٩/٦٥٤ من طريق أبي هلال.أخرجه ابن جرير ١٩/٦٥٤ بنحوه. وعزاه السيوطي إلى عبد بن حميد، وابن أبي حاتم.أخرجه ابن جرير ١٩/٦٥٤.تفسير البغوي ٤/٥٠.تفسير مقاتل بن سليمان ٣/٦٢٣.أخرجه ابن جرير ١٩/٦٥٥.أخرجه إسحاق البستي ص٢٢٤.أخرجه أحمد ٣٥/٤٠٥-٤٠٦ (٢١٥١٦)، والترمذي ٤/٣٥١-٣٥٢ (٢٤٦٥)، وابن ماجه ٥/٢٨٣ (٤١٩٠)، والحاكم ٤/٥٨٧ (٨٦٣٣)، ٤/٦٢٣ (٨٧٢٦). قال الترمذي: «هذا حديث حسن غريب». وقال الحاكم: «هذا حديث صحيح الإسناد، ولم يخرجاه». وأورده الألباني في الصحيحة ٤/٢٩٩ (١٧٢٢).أخرجه مسلم ١/٣٢٢ (٤٣٠).أخرجه مسلم ١/٣٧١ (٥٢٢). وأورده الثعلبي ٣/٣١٧. وقد أورد السيوطي بعد تفسير الآيات ١٢/٤٩١-٤٩٣ آثارًا عن تسوية الصفوف في الصلاة وحكمها.
  37,166,""
37,167," <q>﴿وَإِن كَانُوا۟ لَیَقُولُونَ ۝١٦٧ لَوۡ أَنَّ عِندَنَا ذِكۡرࣰا مِّنَ ٱلۡأَوَّلِینَ ۝١٦٨ لَكُنَّا عِبَادَ ٱللَّهِ ٱلۡمُخۡلَصِینَ ۝١٦٩ فَكَفَرُوا۟ بِهِۦۖ فَسَوۡفَ یَعۡلَمُونَ ۝١٧٠﴾</q> - نزول الآيات، وتفسيرها ٦٦١٨٢- عن عبد الله بن عباس -من طريق عطية العوفي- في قوله: <q>﴿لَوْ أنَّ عِنْدَنا ذِكْرًا مِنَ الأَوَّلِينَ﴾</q> الآيات، قال: لما جاء المشركين من أهل مكة ذِكرُ الأولين وعِلْمُ الآخرين؛ كفروا بالكتاب، <q>﴿فَسَوْفَ يَعْلَمُونَ﴾</q>{1}. (١٢/٤٩٤) ٦٦١٨٣- عن الضحاك بن مزاحم -من طريق عبيد- في قوله: <q>﴿لَوْ أنَّ عِنْدَنا ذِكْرًا مِنَ الأَوَّلِينَ * لَكُنّا عِبادَ اللَّهِ المُخْلَصِينَ﴾</q>: هذا قول مشركي أهل مكة، فلمّا جاءهم ذِكر الأولين وعلم الآخرين كفروا به فسوف يعلمون{2}. (ز) ٦٦١٨٤- عن قتادة بن دعامة -من طريق معمر- في قوله: <q>﴿وإنْ كانُوا لَيَقُولُونَ * لَوْ أنَّ عِنْدَنا ذِكْرًا مِنَ الأَوَّلِينَ﴾</q>، قال: قول الناس، فلما جاءهم ما عرفوا كفروا به{3}. (ز) ٦٦١٨٥- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿وإنْ كانُوا لَيَقُولُونَ﴾</q>، قال: قالت هذه الأمة ذلك قبل أن يُبعث محمد ﷺ، فلما جاءهم محمد ﷺ كفروا به، <q>﴿فَسَوْفَ يَعْلَمُونَ﴾</q>{4}. (١٢/٤٩٤) ٦٦١٨٦- عن أبي هلال، أنّه بلغه: أنّ قريشًا كانت تقول: لو أنّ الله بعث مِنّا نبيًّا ما كانت أمة من الأمم أطوع لخالقها، ولا أسمع لنبيها، ولا أشد تمسُّكًا بكتابها مِنّا. فأنزل الله: <q>﴿وإنْ كانُوا لَيَقُولُونَ * لَوْ أنَّ عِنْدَنا ذِكْرًا مِنَ الأَوَّلِينَ﴾</q>، <q>﴿لَوْ أنّا أُنْزِلَ عَلَيْنا الكِتابُ لَكُنّا أهْدى مِنهُمْ﴾</q> [الأنعام:١٥٧]، <q>﴿وأَقْسَمُوا بِاللَّهِ جَهْدَ أيْمانِهِمْ لَئِنْ جاءَهُمْ نَذِيرٌ لَيَكُونُنَّ أهْدى مِن إحْدى الأُمَمِ﴾</q> [فاطر:٤٢]، وكانت اليهود تستفتح به على الأنصار فيقولون: إنّا نجد نبيًّا يَخْرُج{5}. (١٢/ ٣٠٨) ٦٦١٨٧- عن إسماعيل السُّدِّيّ -من طريق أسباط- في قوله: <q>﴿ذِكْرًا مِنَ الأَوَّلِينَ﴾</q>، قال: هؤلاء ناس من مشركي العرب قالوا: لو أنّ عندنا كتابًا من كتب الأولين، أو جاءنا علم من علم الأولين. قال: قد جاءكم محمد بذلك، <q>﴿فَكَفَرُوا بِهِ فَسَوْفَ يَعْلَمُونَ﴾</q> يقول: قد جاءكم محمد بذلك، فكفروا بالقرآن وبما جاء به محمد ﵇{6}. (ز) ٦٦١٨٨- عن عبد الملك ابن جريج، في قوله: <q>﴿وإنْ كانُوا لَيَقُولُونَ * لَوْ أنَّ عِنْدَنا ذِكْرًا مِنَ الأَوَّلِينَ﴾</q>، قال: قول أهل الشرك من أهل مكة، فلما جاءهم ذِكر الأولين وعلم الآخرين كفروا به{7}. (١٢/٤٩٤) ٦٦١٨٩- قال مقاتل بن سليمان: <q>﴿وإنْ كانُوا لَيَقُولُونَ﴾</q> كفار مكة: <q>﴿لَوْ أنَّ عِنْدَنا ذِكْرًا مِنَ الأَوَّلِينَ﴾</q> خبر الأمم الخالية كيف أهلكوا وما كان مِن أمرهم؛ <q>﴿لَكُنّا عِبادَ اللَّهِ المُخْلَصِينَ﴾</q> بالتوحيد. نزلت في الملأ من قريش، فقصَّ الله ﷿ عليهم خبر الأولين، وعلم الآخرين، <q>﴿فَكَفَرُوا بِهِ﴾</q> بالقرآن، <q>﴿فَسَوْفَ يَعْلَمُونَ﴾</q> هذا وعيد، يعني: القتل ببدر{8}. (ز) ٦٦١٩٠- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب-: رجع الحديثُ إلى الأولين أهل الشرك: <q>﴿وإنْ كانُوا لَيَقُولُونَ * لَوْ أنَّ عِنْدَنا ذِكْرًا مِنَ الأَوَّلِينَ﴾</q>{2}. (ز) ٦٦١٩١- قال يحيى بن سلّام: قوله ﷿: <q>﴿وإنْ كانُوا لَيَقُولُونَ﴾</q> يعني: قريشًا: <q>﴿لَوْ أنَّ عِنْدَنا ذِكْرًا مِنَ الأَوَّلِينَ﴾</q> مثل كتاب موسى وعيسى؛ <q>﴿لَكُنّا عِبادَ اللَّهِ المُخْلَصِينَ﴾</q> المؤمنين. قال الله: <q>﴿فَكَفَرُوا بِهِ﴾</q> بالقرآن{10}. (ز) ",footnotes:1:أخرجه ابن جرير ١٩/٦٥٦ من طريق محمد بن سعد العوفي، عن أبيه، قال: حدثني عمي الحسين بن الحسن، عن أبيه، عن جده عطية العوفي، عن ابن عباس به. وعزاه السيوطي إلى ابن مردويه. إسناده ضعيف، لكنها صحيفة صالحة ما لم تأت بمنكر أو مخالفة. وينظر: مقدمة الموسوعة.أخرجه ابن جرير ١٩/٦٥٦.أخرجه عبد الرزاق ٢/١٥٩.أخرجه ابن جرير ١٩/٦٥٥. وعزاه السيوطي إلى عبد بن حميد، وابن أبي حاتم.عزاه السيوطي إلى ابن أبي حاتم.أخرجه ابن جرير ١٩/٦٥٥، ٦٥٧. وعلَّقه يحيى بن سلام ٢/٨٤٧ بنحوه مختصرا.عزاه السيوطي إلى ابن المنذر.تفسير مقاتل بن سليمان ٣/٦٢٣.أخرجه ابن جرير ١٩/٦٥٦.تفسير يحيى بن سلام ٢/٨٤٧.
