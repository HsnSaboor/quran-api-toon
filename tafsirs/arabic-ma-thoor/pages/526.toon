quran[26]{c,v,t}:
  53,1,"<div class=ar lang=ar><p><h3>مقدمة السورة</h3></p><p><div></p><p><p><span class="item-no">٧٣١٠٦<span class="dash">-</span></span> عن عبد الله بن عباس، قال: نزلتْ سورة النجم بمكة{1}. (١٤/٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣١٠٧<span class="dash">-</span></span> عن عبد الله بن الزبير، مثله{2}. (١٤/٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣١٠٨<span class="dash">-</span></span> عن عبد الله بن عباس -من طريق عطاء الخُراسانيّ-: مكّيّة، ونزلتْ بعد <span class="qpc-hafs">﴿قل هو الله أحد﴾</span>{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣١٠٩<span class="dash">-</span></span> عن علي بن الحسين -من طريق الحسين بن واقد – أنه قال: ... وأول سورة علمها رسولُ الله ﷺ بمكة: <span class="qpc-hafs">﴿والنجم﴾</span>{4}.(ز) (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣١١٠<span class="dash">-</span></span> عن عكرمة مولى ابن عباس= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣١١١<span class="dash">-</span></span> والحسن البصري -من طريق يزيد النحوي-: مكّيّة{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣١١٢<span class="dash">-</span></span> عن قتادة بن دعامة -من طريق همّام-: مكّيّة{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣١١٣<span class="dash">-</span></span> عن محمد بن شهاب الزُّهريّ: مكّيّة، وسمّاها: <span class="qpc-hafs">﴿والنَّجْمِ﴾</span>، وذكر أنها نَزَلَتْ بعد سورة الإخلاص{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣١١٤<span class="dash">-</span></span> عن علي بن أبي طلحة: مكّيّة{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣١١٥<span class="dash">-</span></span> قال مقاتل بن سليمان: سورة النجم مكّيّة، عددها اثنتان وستون آية كوفي{9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣١١٦<span class="dash">-</span></span> عن أبي هريرة: أنّ رسول الله ﷺ سجد في سورة <span class="qpc-hafs">﴿والنَّجْمِ﴾</span>، وسجد مَن حضر؛ مِن الجن، والإنس، والشجر{10}. (١٤/٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣١١٧<span class="dash">-</span></span> عن أبي هريرة، قال: سجد رسول الله ﷺ والمسلمون في النجم، إلا رجلين من قريش، أرادا بذلك الشُّهرة{11}. (١٤/٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣١١٨<span class="dash">-</span></span> عن عبد الله بن عباس، قال: سجد النبيُّ ﷺ في النجم، وسجد معه المسلمون والمشركون، والجن والإنس{12}. (١٤/٦٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣١١٩<span class="dash">-</span></span> عن عبد الله بن مسعود -من طريق الأسود- قال: أول سورة أعلن بها النبيُّ ﷺ يقرؤها: <span class="qpc-hafs">﴿والنَّجْمِ﴾</span>{13}. (١٤/٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣١٢٠<span class="dash">-</span></span> عن عبد الله بن مسعود، قال: أول سورة نَزَلَتْ فيها سجدة <span class="qpc-hafs">﴿والنَّجْمِ﴾</span>، فسجد رسول الله ﷺ، وسجد الناس كلّهم، إلا رجلًا رأيتُه أخذ كفًّا مِن تراب، فسجد عليه، فرأيتُه بعد ذلك قُتل كافرًا، وهو أُمَيّة بن خلف{14}. (١٤/٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣١٢١<span class="dash">-</span></span> عن زيد بن ثابت، قال: قرأتُ النجم عند النبيِّ ﷺ، فلم يسجد فيها{15}. (١٤/٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣١٢٢<span class="dash">-</span></span> عن عائشة: أنّ النبيَّ ﷺ قرأ سورة النجم، فلما بلَغ السجدة سجد فيها{16}. (١٤/٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣١٢٣<span class="dash">-</span></span> عن المُطَّلب بن أبي وداعة، قال: قرأ النبيُّ ﷺ بمكة <span class="qpc-hafs">﴿والنَّجْمِ﴾</span>، فسجد، وسجد مَن عنده{17}. (١٤/٦٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣١٢٤<span class="dash">-</span></span> عن عبد الله بن عمر، قال: صلّى بنا رسول الله ﷺ، فقرأ النجم، فسجد بنا، فأطال السجود{18}. (١٤/٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣١٢٥<span class="dash">-</span></span> عن عبد الله بن عباس، قال: كان رسول الله ﷺ يسجد في النجم بمكة، فلما هاجر إلى المدينة تركها{2}. (١٤/٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣١٢٦<span class="dash">-</span></span> عن عبد الله بن عباس: أنّ رسول الله ﷺ لم يسجد في شيء مِن المفصّل منذ تَحَوَّل إلى المدينة{2}. (١٤/٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣١٢٧<span class="dash">-</span></span> عن أبي الدّرداء: أنّه سجد مع رسول الله ﷺ إحدى عشرة سجدة، منهنّ النجم{21}. (١٤/٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣١٢٨<span class="dash">-</span></span> عن عامر الشعبي، قال: ذُكر عند جابر بن عبد الله <span class="qpc-hafs">﴿والنَّجْمِ﴾</span>، فقال جابر: سجد بها رسول الله ﷺ، والمشركون، والجن، الإنس{2}. (١٤/٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣١٢٩<span class="dash">-</span></span> عن عامر الشعبي: أنّ رسول الله ﷺ قرأ <span class="qpc-hafs">﴿والنَّجْمِ﴾</span>، فسجد فيها المسلمون، والمشركون، والجن، والإنس{23}. (١٤/٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣١٣٠<span class="dash">-</span></span> عن أبي العالية الرّياحيّ: أنّ النبيَّ ﷺ سجد في النجمِ، والمسلمون{24}. (١٤/٥،٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣١٣١<span class="dash">-</span></span> عن الحسن البصري: أنّ النَّبِيّ ﷺ صلّى في كسوف الشمس ركعتين، فقرأ في إحداهما النجم{25}. (١٤/٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣١٣٢<span class="dash">-</span></span> عن محمد بن كعب القُرَظيّ: أنّ رسول الله ﷺ كان يسجد في <span class="qpc-hafs">﴿النَّجْمِ إذا هَوى﴾</span>{26}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣١٣٣<span class="dash">-</span></span> عن سبرة، قال: صلّى بنا <span class="name-1">عمرُ بن الخطاب</span> الفجر، فقرأ في الركعة الأولى سورة يوسف، ثم قرأ في الثانية النجم، فسجد، ثم قام، فقرأ: <span class="qpc-hafs">﴿إذا زُلْزِلَت﴾</span>، ثم ركع{27}. (١٤/٦٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣١٣٤<span class="dash">-</span></span> عن أبي هريرة: أنّ <span class="name-1">عمر بن الخطاب</span> قرأ لهم: <span class="qpc-hafs">﴿والنَّجْمِ إذا هَوى﴾</span>، فسجد فيها{28}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣١٣٥<span class="dash">-</span></span> عن محمد بن سيرين، أنه سُئل عن سجدة النجم. فقال: أُنبئتُ: أنّ <span class="name-1">عبد الله بن مسعود</span> كان إذا قرأها على الناس سجد، وإذا قرأها في صلاة ركع وسجد{29}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣١٣٦<span class="dash">-</span></span> عن أبي صخر، قال: بلَغني: أن <span class="name-1">عبد الله بن مسعود</span> كان يقول: عزائم سجود القرآن: <span class="qpc-hafs">﴿آلم تَنْزِيلُ﴾</span>، النجم، <span class="qpc-hafs">﴿اقْرَأْ بِاسْمِ رَبِّكَ﴾</span>{30}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣١٣٧<span class="dash">-</span></span> عن <span class="name-1">علي بن أبي طالب</span> -من طريق زرٍّ- قال: عزائم السجود أربع: <span class="qpc-hafs">﴿آلم تنزيل﴾</span> السجدة، و<span class="qpc-hafs">﴿حم﴾</span> السجدة، والنجم، و<span class="qpc-hafs">﴿اقرأ باسم ربك﴾</span>{31}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣١٣٨<span class="dash">-</span></span> عن نافع، قال: كان <span class="name-1">ابنُ عمر</span> إذا قرأ النجم وهو يريد أن يكون بعدها قراءة قرأها وسجد، وإذا انتهى إليها ركع وسجد{32}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَٱلنَّجۡمِ إِذَا هَوَىٰ ۝١﴾</span> - نزول الآيات</h3></p><p><div></p><p><p><span class="item-no">٧٣١٣٩<span class="dash">-</span></span> عن عبد الله بن عباس -من طريق سعيد بن جُبَير- قال: كنتُ جالسًا مع فِتية مِن بني هاشم عند النبي ﷺ؛ إذ انقضّ كوكبٌ، فقال النبي ﷺ: «<b>مَن انقضّ هذا النجم في منزله فهو الوصيُّ مِن بعدي</b>». فقام فِتيةٌ من بني هاشم، فنظروا، فإذا الكوكب قد انقضّ في منزل عَلِيٍّ، قالوا: يا رسول الله، قد غَويتَ في حُبّ عَلِيٍّ؟ فأنزل الله تعالى: <span class="qpc-hafs">﴿والنجم إذا هوى، ما ضل صاحبكم وما غوى، وما ينطق عن الهوى، إن هو إلا وحي يوحى﴾</span> إلى قوله: <span class="qpc-hafs">﴿وهو بالأفق الأعلى﴾</span> [النجم:١-٧]{33}<span class=comment-ref>٦٢٦٠</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٢٦٠</span> <span class="comment-type-2">انتقد</span> <u>ابنُ تيمية</u> في منهاج السنة النبوية (٧/ ٦٠ -٦٨) هذا الأثر <span class="mustanad">مستندًا إلى الإجماع، وأحوال النزول، والأدلة العقلية</span>، <span class="mustanad">والتاريخية،</span> فقال -بتصرف-: "والجواب من وجوه:</p><p><b>أحدها</b>: المطالبة بصحته، وذلك أن القول بلا علم حرام بالنص والإجماع....</p><p><b>الثاني</b>: أن هذا كذب باتفاق أهل العلم بالحديث ....</p><p><b>الوجه الثالث</b>: أنه مما يبين أنه كذب أن فيه ابن عباس شهد نزول سورة النجم حين انقض الكوكب في منزل علي، وسورة النجم باتفاق الناس من أول ما نزل بمكة، وابن عباس حين مات النبي ﷺ كان مراهقًا للبلوغ لم يحتلم بعد، هكذا ثبت عنه في الصحيحين. فعند نزول هذه الآية: إما أن ابن عباس لم يكن وُلد بعد، وإما أنه كان طفلًا لا يميز، فإن النبي ﷺ لما هاجر كان لابن عباس نحو خمس سنين، والأقرب أنه لم يكن وُلد عند نزول سورة النجم، فإنها من أوائل ما نزل من القرآن.</p><p><b>الوجه الرابع</b>: أنه لم ينقض قط كوكب إلى الأرض بمكة ولا بالمدينة ولا غيرهما، ولما بُعث النبي ﷺ كثر الرمي بالشهب، ومع هذا فلم ينزل كوكب إلى الأرض، وهذا ليس من الخوارق التي تعرف في العالم، بل هو من الخوارق التي لا يعرف مثلها في العالم، ولا يروي مثل هذا إلا مَن هو مِن أوقح الناس، وأجرؤهم على الكذب، وأقلهم حياء ودينًا، ولا يروج إلا على من هو مِن أجهل الناس وأحمقهم، وأقلهم معرفة وعلمًا.</p><p><b>الوجه الخامس</b>: أن نزول سورة النجم كان في أول الإسلام، وعلِيٌّ إذ ذاك كان صغيرًا، والأظهر أنه لم يكن احتلم ولا تزوج بفاطمة، ولا شُرع بعد فرائض الصلاة أربعًا وثلاثًا واثنين، ولا فرائض الزكاة، ولا حج البيت، ولا صوم رمضان، ولا عامة قواعد الإسلام. وأمر الوصية بالإمامة لو كان حقًّا إنما يكون في آخر الأمر كما ادعوه يوم غدير خم، فكيف يكون قد نزل في ذلك الوقت؟!</p><p><b>الوجه السادس</b>: أن أهل العلم بالتفسير متفقون على خلاف هذا، وأن النجم المقسم به: إما نجوم السماء، وإما نجوم القرآن، ونحو ذلك. ولم يقل أحد: إنه كوكب نزل في دار أحد بمكة.</p><p><b>الوجه السابع</b>: أن من قال لرسول الله ﷺ: «غويت» فهو كافر، والكفار لم يكن النبي ﷺ يأمرهم بالفروع قبل الشهادتين والدخول في الإسلام.</p><p><b>الوجه الثامن</b>: أن هذا النجم إن كان صاعقة فليس نزول الصاعقة في بيت شخص كرامة له، وإن كان من نجوم السماء فهذه لا تفارق الفلك، وإن كان مِن الشهب فهذه يُرمى بها رجومًا للشياطين، وهي لا تنزل إلى الأرض، ولو قُدِّر أن الشيطان الذي رمي بها وصل إلى بيت علِيٍّ حتى احترق بها فليس هذا كرامة له، مع أن هذا لم يقع قط".</div></p><p><h3><span class="qpc-hafs">﴿وَٱلنَّجۡمِ إِذَا هَوَىٰ ۝١﴾</span> - تفسير الآية</h3></p><p><div></p><p><p><span class="item-no">٧٣١٤٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، <span class="qpc-hafs">﴿والنَّجْمِ إذا هَوى﴾</span>، قال: الثُّريّا إذا تَدلّت{34}. (١٤/٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣١٤١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطية- <span class="qpc-hafs">﴿والنَّجْمِ إذا هَوى﴾</span>، قال: إذا انصبّ{35}. (١٤/٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣١٤٢<span class="dash">-</span></span> قال <span class="name-1">عبد الله بن عباس</span> -من طريق عكرمة- <span class="qpc-hafs">﴿والنَّجْمِ إذا هَوى﴾</span>: أنّه الرّجوم من النُّجوم{36}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣١٤٣<span class="dash">-</span></span> قال <span class="name-1">عبد الله بن عباس</span> -من طريق عطاء- <span class="qpc-hafs">﴿النَّجْمِ إذا هَوى﴾</span>: المراد بالنَّجْمِ: القرآن، سُمي: نجمًا؛ لأنه نزل نجومًا متفرقة في عشرين سنة{37}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣١٤٤<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿والنَّجْمِ إذا هَوى﴾</span>، قال: الثُّريّا إذا غابت. وفي لفظ: إذا سقطت مع الفجر. وفي لفظ: قال: الثُّريّا إذا وقعت{38}. (١٤/٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣١٤٥<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق الأعمش- <span class="qpc-hafs">﴿والنَّجْمِ إذا هَوى﴾</span>، قال: القرآن إذا نزل{39}. (١٤/٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣١٤٦<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span>، في قوله: <span class="qpc-hafs">﴿النَّجْمِ إذا هَوى﴾</span>، قال: أقسم ربّك بنجوم القرآن: ما ضلّ محمد ﷺ وما غوى{40}. (١٤/١٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣١٤٧<span class="dash">-</span></span> قال <span class="name-2">الضَّحّاك بن مُزاحِم</span>: هو النجم من نجوم القرآن إذا نزل، وكان ينزل نجومًا آية، وآيتان، وثلاث آيات، وأربع، وعشر، وسورة، وكان بين أوله وآخره ثلاث وعشرون سنة{41}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣١٤٨<span class="dash">-</span></span> عن <span class="name-3">محمد بن السّائِب الكلبي</span> -من طريق حيان-، مثله{42}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣١٤٩<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق معمر- <span class="qpc-hafs">﴿والنَّجْمِ إذا هَوى﴾</span>، قال: إذا غاب{43}. (١٤/٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣١٥٠<span class="dash">-</span></span> قال <span class="name-2">أبو حمزة الثُّمالِيّ</span>-من طريق علي بن علي- <span class="qpc-hafs">﴿والنَّجْمِ إذا هَوى﴾</span>، قال: يقال: هي النُّجوم إذا انتَثَرتْ يوم القيامة{44}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣١٥١<span class="dash">-</span></span> قال <span class="name-3">جعفر الصادق</span>: <span class="qpc-hafs">﴿والنَّجْمِ إذا هَوى﴾</span>، يعني: محمدًا ﷺ إذا نزل مِن السماء ليلة المعراج{42}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣١٥٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: أقسم الله ﷿ بـ<span class="qpc-hafs">﴿النَّجْمِ إذا هَوى﴾</span>، يقول: <span class="qpc-hafs">﴿ما كَذَبَ الفُؤادُ ما رَأى﴾</span>، وهي أول سورة أعلَنها النبيُّ ﷺ بمكة، فلما بلَغ آخرها سجد، وسجد مَن بحضرته مِن مؤمني الإنس والجن والشجر، وذلك أنّ كفار مكة قالوا: إنّ محمدًا يقول هذا القرآن مِن تلقاء نفسه، فأقسم الله بالقرآن، فقال: <span class="qpc-hafs">﴿والنَّجْمِ إذا هَوى﴾</span> يعني: مِن السماء إلى محمد ﷺ، مثل قوله: <span class="qpc-hafs">﴿فَلا أُقْسِمُ بِمَواقِعِ النُّجُومِ﴾</span> [الواقعة:٧٥]، وكان القرآن إذا نزل إنما ينزل نجومًا؛ ثلاث آيات، وأربع، ونحو ذلك، والسورة، والسورتان{46}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣١٥٣<span class="dash">-</span></span> عن <span class="name-3">سفيان [الثوري]</span> -من طريق مهران- <span class="qpc-hafs">﴿والنَّجْمِ إذا هَوى﴾</span>، قال: سقوط الثُّريّا{35}<span class=comment-ref>٦٢٦١</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٢٦١</span> اختُلف في معنى: <span class="qpc-hafs">﴿والنَّجْمِ﴾</span> على أقوال: <b>الأول:</b> والثريّا. <b>الثاني:</b> والقرآن. <b>الثالث:</b> النجم اسم جنس، والمعنى: والنجوم إذا هوت. <b>الرابع:</b> أنه محمد ﷺ إذا نزل من السماء ليلة المعراج.</p><p>و<span class="comment-type-1">وجَّه</span> <u>ابنُ عطية</u> (٨/١٠٤) القول الأول بقوله: «و<span class="qpc-hafs">﴿هَوى﴾</span> -على هذا القول- <b>يحتمل</b> الغروب، و<b>يحتمل</b> الانكدار». و<span class="comment-type-1">وجَّه</span> القول الثاني بقوله: «ويجيء <span class="qpc-hafs">﴿هَوى﴾</span> -على هذا التأويل- بمعنى: نزل». ثم <span class="comment-type-2">انتقده</span> <span class="mustanad">-مستندًا إلى اللغة-</span> قائلًا: «وفي هذا الهُوِىِّ بُعْدٌ وتحاملٌ على اللغة».</p><p>و<span class="comment-type-1">وجَّه</span> <u>ابنُ القيم</u> (٣/٦٤) القول الثاني بقوله: «وعلى هذا فسُمّي القرآن نجمًا لتفرقه في النزول، <span class="mustanad">والعرب تُسمي</span> التفرّق: تنجّمًا، والمفرَّق: نجمًا، ونجوم الكتاب: أقساطها ... وقوله: <span class="qpc-hafs">﴿هَوى﴾</span> على هذا القول، أي: نزل من علوّ إلى سفل».</p><p>و<span class="comment-type-3">رجَّح</span> <u>ابنُ جرير</u> (٢٢/٧) -<span class="mustanad">مستندًا إلى لغة العرب</span>- القول الأول، وهو قول مجاهد من طريق ابن أبي نجيح، وسفيان، وأحد أقوال ابن عباس، وعلَّل ذلك بأن «العرب تدعوها النجم». ونقل قولًا عن بعض أهل البصرة أن معنى: <span class="qpc-hafs">﴿والنَّجْمِ﴾</span>: «والنجوم، ذهب إلى لفظ الواحد وهو في معنى الجميع». ثم <span class="comment-type-2">انتقده</span> <span class="mustanad">-مستندًا إلى أقوال السلف-</span> قائلًا: «والقول الذي قاله مَن حكينا عنه مِن أهل البصرة قولٌ لا نعلم أحدًا من أهل التأويل قاله، وإن كان له وجْهٌ، فلذلك تركنا القول به».</p><p>ونقل <u>ابنُ عطية</u> (٨/١٠٥) اختلاف المفسرين في معنى «الهُوِيِّ» على القول الثالث، وأنه عند جمهور المفسرين: هوى للغروب. ثم <span class="comment-type-4">علَّق</span> عليه بقوله: «وهذا هو السابق إلى الفهم <span class="mustanad">من كلام العرب</span>». وعند أبي حمزة اليماني: هوى عند الانكدار في القيامة. ثم <span class="comment-type-1">وجَّهه</span> بقوله: «فهي بمعنى قوله تعالى: <span class="qpc-hafs">﴿وإذا الكَواكِبُ انْتَثَرَتْ﴾</span> [الانفطار:٢]». ونقل عن ابن عباس -في كتاب الثعلبي-: «هوى في الانقضاض في أثر العفْرِية»، ثم <span class="comment-type-4">علَّق</span> عليه بقوله: «وهذا القول <span class="mustanad">تساعده اللغة</span>». ثم <span class="comment-type-4">علَّق</span> على ما سبق بقوله: «والتأويلات في <span class="qpc-hafs">﴿هَوى﴾</span> محتملة كلُّها قويةٌ».</p><p>ونقل <u>ابنُ عطية</u> (٨/١٠٤) عن الزهراوي أن المعنى: «وربّ النَّجم». ثم <span class="comment-type-2">انتقده</span> -<span class="mustanad">مستندًا إلى مخالفة لفظ الآية</span>- قائلًا: «وفي هذا قلق مع لفظ الآية».</p><p>ونقل <u>ابنُ كثير</u> (١٣/٢٤٦) عن الضَّحّاك قوله: «<span class="qpc-hafs">﴿والنَّجْمِ إذا هَوى﴾</span> إذا رُمي به الشياطين». ثم <span class="comment-type-4">علَّق</span> عليه بقوله: «وهذا القول له اتجاه».</p><p>ونقل <u>ابنُ القيم</u> (٣/٦٥) هذا القول عن ابن عباس، فقال: «يعني: النجوم التي تُرمى بها الشياطين إذا سقطت في آثارها عند استراق السمع». ثم <span class="comment-type-3">رجَّحه</span> -<span class="mustanad">مستندًا إلى دلالة العقل</span>- قائلًا: «وهذا قول الحسن، وهو أظهر الأقوال. ويكون سبحانه قد أقسم بهذه الآية الظاهرة المشاهدة التي نصبها الله -سبحانه- آية وحفظًا للوحي مِن استراق الشياطين له على أن ما أتى به رسوله حقٌّ وصِدق، لا سبيل للشيطان ولا طريق له إليه، بل قد أُحرس بالنجم إذا هوى رصدًا بين يدي الوحي، وحرسًا له، وعلى هذا فالارتباط بين المُقسم به والمُقسم عليه في غاية الظهور، وفي المُقسم به دليل على المُقسم عليه».</p><p>و<span class="comment-type-2">انتقد</span> القول الأول والثاني والثالث -<span class="mustanad">مستندًا إلى المعهود من اللغة، والدلالة العقلية</span>- قائلًا: «وليس بالبيِّن تسمية القرآن عند نزوله بالنجم إذا هوى، ولا تسمية نزوله هويًا، ولا عُهد في القرآن ذلك فيُحمل هذا اللفظ عليه، وليس بالبيِّن تخصيص هذا القَسم بالثُّريّا وحدها إذا غابت، وليس بالبيِّن أيضًا القَسم بالنجوم عند انتشارها يوم القيامة، بل هذا مما يُقسم الرّبّ عليه ويدل عليه بآياته، فلا يجعله نفسه دليلًا؛ لعدم ظهوره للمخاطبين، ولا سيما منكرو البعث، فإنه سبحانه إنما استدل بما لا يمكن جحده ولا المكابرة فيه».</div></p><p><h3><span class="qpc-hafs">﴿وَٱلنَّجۡمِ إِذَا هَوَىٰ ۝١﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٧٣١٥٤<span class="dash">-</span></span> عن أبي هريرة مرفوعًا: «<b>ما طلع النَّجْم قطّ وفي الأرض من العاهة شيء إلا رُفع</b>». وأراد بالنَّجْمِ: الثُّريّا{48}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣١٥٥<span class="dash">-</span></span> عن طاووس، قال: لما تلا رسول الله ﷺ: <span class="qpc-hafs">﴿النَّجْمِ إذا هَوى﴾</span> قال عُتبة بن أبي لهب: كفرتُ بربّ النجم. فقال رسول الله ﷺ: «<b>سلّط اللهُ عليك كلبًا مِن كلابه</b>»{49}. (١٤/٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣١٥٦<span class="dash">-</span></span> عن أبي الضُّحى، قال: قال ابن أبي لهب: هو يكفر بالذي قال: <span class="qpc-hafs">﴿والنَّجْمِ إذا هَوى﴾</span>. فقال رسول الله ﷺ: «<b>عسى الله أن يُرسِل عليه كلبًا مِن كلابه</b>». فبلغ ذلك أباه، فأوصى أصحابه: إذا نَزَلَتْم منزلًا فاجعلوه وسطكم. ففعلوا، حتى إذا كان ليلةً بعث الله عليه سبعًا فقَتَله{50}. (١٤/٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣١٥٧<span class="dash">-</span></span> عن عكرمة مولى ابن عباس، قال: لَمّا نزلت: <span class="qpc-hafs">﴿والنَّجْمِ إذا هَوى﴾</span> قال عُتبة بن أبي لهب للنبي ﷺ: أنا كفرت بربّ النجمِ إذا هوى. فقال النبيُّ ﷺ: «<b>اللهم، أرْسِل عليه كلبًا من كلابك</b>». قال: فقال ابن عباس: فخرج إلى الشام في ركْبٍ فيهم هبّار بن الأسود، حتى إذا كانوا بوادي الغاضرة، وهي مُسْبعة، نزلوا ليلًا، فافترشوا صفًّا واحدًا، فقال عتبة: أتريدون أن تجعلوني حَجْرة؟ لا، واللهِ، لا أبِيتُ إلا وسطكم. قال هبّار: فما أنبهني إلا السّبع يَشَمّ رؤوسهم رجلًا رجلًا، حتى انتهى إليه، فالتقتْ أنيابه في صُدْغَيه{51}. (١٤/٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣١٥٨<span class="dash">-</span></span> عن قتادة بن دعامة -من طريق معمر- <span class="qpc-hafs">﴿والنَّجْمِ إذا هَوى﴾</span>، قال: قال عُتبة بن أبي لهب: إني كفرتُ بربّ النَّجْمِ. قال معمر: فأخبرني ابن طاووس، عن أبيه، أن النبيَّ ﷺ قال له: «<b>أما تخاف أن يُسَلِّط اللهُ عليك كلبه؟!</b>». فخرج ابنُ أبي لهب مع أناسٍ في سَفرٍ، حتى إذا كانوا ببعض الطريق سمعوا صوت الأسد، فقال: ما هو إلا يريدني. فاجتمع أصحابُه حوله، وجعلوه في وسطهم، حتى إذا ناموا جاء الأسد فأخذ هامَته{52}. (١٤/٨)</p></p><p></div></p></div>",footnotes:1:أخرجه أبو جعفر النحاس في الناسخ والمنسوخ ٣/٢٠ من طريق أبي عمرو بن العلاء عن مجاهد، والبيهقي في الدلائل ٧/١٤٤ من طريق خُصَيف عن مجاهد. وعزاه السيوطي إلى ابن مردويه.|2:عزاه السيوطي إلى ابن مردويه.|3:أخرجه ابن الضريس في فضائل القرآن ١/٣٣-٣٥.|4:أسباب النزول للواحدي ١/١٠٦.|5:أخرجه البيهقي في دلائل النبوة ٧/١٤٢-١٤٣.|6:أخرجه الحارث المحاسبي في فهم القرآن ص٣٩٥-٣٩٦ من طريق سعيد، وأبو بكر ابن الأنباري -كما في الإتقان ١/٥٧- من طريق همام.|7:تنزيل القرآن ص٣٧-٤٢.|8:أخرجه أبو عبيد في فضائله (ت: الخياطي) ٢/٢٠٠.|9:تفسير مقاتل بن سليمان ٤/١٥٧.|10:أخرجه الطحاوي في شرح معاني الآثار ١/٣٥٣ (٢٠٧٨)، والدارقطني في سننه ٢/٢٧٢ (١٥٢٣)، من طريق مخلد بن حسين، عن هشام، عن ابن سيرين، عن أبي هريرة به.</p><p>وسنده صحيح.|11:أخرجه أحمد ١٣/٤٠٤ (٨٠٣٤)، ١٥/٤٤٤ (٩٧١٢)، وابن أبي شيبة في مصنفه ٢/٨ (٤٢٨٣).</p><p>قال الهيثمي في المجمع ٢/٢٨٥ (٣٦٩٩): «رجاله ثقات».|12:أخرجه البخاري ٦/١٤٢ (٤٨٦٢)، والثعلبي ٩/١٥٩.|13:أخرجه ابن أبي شيبة في مصنفه (ت: محمد عوامة) ١٩/٦٠٠ (٣٧١٦٩). وعزاه السيوطي إلى ابن مردويه.|14:أخرجه ابن أبي شيبة ٢/٧، والبخاري (١٠٦٧، ١٠٧٠، ٣٨٥٣، ٣٩٧٢، ٤٨٦٣)، وأخرجه مسلم (٥٧٦)، وأبو داود (١٤٠٦)، والنسائي (٩٥٨) مختصرًا. وعزاه السيوطي إلى ابن مردويه.|15:أخرجه البخاري ٢/٤١ (١٠٧٢، ١٠٧٣)، ومسلم ١/٤٠٦ (٥٧٧)، والثعلبي ٩/١٥٩.|16:أخرجه الطبراني في الأوسط ٩/١١٥ (٩٢٨٦)، من طريق سليمان بن عبد الرحمن الدمشقي، عن عبد الرحمن بن بشير الشيباني، عن محمد بن إسحاق، عن الزُّهريّ، عن عروة، عن عائشة به.</p><p>قال الطبراني: «لم يَروِ هذا الحديث عن الزُّهريّ إلا محمد بن إسحاق، ولا عن محمد بن إسحاق إلا عبد الرحمن بن بشير، تفرد به سليمان بن عبد الرحمن». وقال الهيثمي في المجمع ٢/٢٨٥ (٣٧٠٠): «فيه عبد الرحمن بن بشير، وهو منكر الحديث».|17:أخرجه أحمد ٢٤/٢٠٦ (١٥٤٦٤)، ٢٩/٤٢٣ (١٧٨٩٢)، ٤٥/٢٢٠ (٢٧٢٤٦)، والحاكم ٣/٧٣٤ (٦٦٦٣)، من طريق عبد الرزاق، عن معمر، عن ابن طاووس، عن عكرمة بن خالد، عن المطلب بن أبي وداعة به.</p><p>وأخرجه أحمد ٢٤/٢٠٧-٢٠٨ (١٥٤٦٥)، ٢٩/٤٢٤ (١٧٨٩٣)، ٤٥/٢١٩ (٢٧٢٤٥)، والنسائي ٢/١٦٠ (٩٥٨)، من طريق رباح، عن معمر، عن ابن طاووس، عن عكرمة بن خالد، عن جعفر بن المطلب بن أبي وداعة، عن أبيه به.|18:أخرجه البيهقي في الكبرى ٣/٢٥٩ (٥٦٢٨)، من طريق عبد العزيز بن محمد، عن مصعب بن ثابت، عن نافع، عن ابن عمر به.</p><p>وسنده ضعيف؛ فيه عبد العزيز بن محمد الدراوردي، قال عنه ابن حجر في التقريب (٤١١٩): «صدوق، كان يحدّث من كتب غيره فيخطئ».</p><p>وفيه مصعب بن ثابت بن عبد الله بن الزبير بن العوام الأسدي، قال عنه ابن حجر في التقريب (٦٦٨٦): «ليّن الحديث».|19:عزاه السيوطي إلى ابن مردويه.|20:عزاه السيوطي إلى ابن مردويه.|21:أخرجه أحمد ٣٦/٢٢ (٢١٦٩٢)، ٤٥/٤٨٦ (٢٧٤٩٤).</p><p>وقال محققوه: «إسناده ضعيف».|22:عزاه السيوطي إلى ابن مردويه.|23:أخرجه ابن أبي شيبة ٢/٧-٨ مرسلًا.|24:أخرجه ابن أبي شيبة ٢/٧ مرسلًا.|25:أخرجه ابن أبي شيبة ٢/٤٧١ مرسلًا.|26:أخرجه عبد الله بن وهب في الجامع -تفسير القرآن ٣/١٠١ (٢٢٩) مرسلًا.|27:عزاه السيوطي إلى سعيد بن منصور.|28:أخرجه الثعلبي ٩/١٥٩.|29:أخرجه عبد الله بن وهب في الجامع -تفسير القرآن ٣/١٠٢ (٢٣٣).|30:أخرجه عبد الله بن وهب في الجامع -تفسير القرآن ٣/٩٥ (٢١٤).|31:أخرجه الشافعي في كتاب الأم ٨/٤١٥، والطبراني في الأوسط ٧/٣١٠ (٧٥٨٨) من طريق الحارث.|32:أخرجه عبد الله بن وهب في الجامع -تفسير القرآن ٣/١٠٢ (٢٣٤).|33:أخرجه ابن عساكر في تاريخ دمشق ٤١/٣٦٢.</p><p>وقال: «هذا حديث منكر، ومن بين أبي عمر وبين هشيم مجهولون لا يُعرفون».</p><p>وأورده ابن الجوزي في كتاب الموضوعات ١/ ٣٧٢ بإسناد آخر وسياق مختلف، عن محمد بن مروان عن الكلبي، عن أبي صالح، عن ابن عباس، قال: لما عرج بالنبي ﷺ إلى السماء السابعة، وأراه الله من العجائب في كل سماء، فلما أصبح جعل يحدث الناس من عجائب ربه، فكذبه من أهل مكة من كذبه، وصدقه من صدقه، فعند ذلك انقض نجم من السماء، فقال النبي ﷺ: «<b>في دار من وقع هذا النجم فهو خليفتي من بعدي</b>». قال: فطلبوا ذلك النجم، فوجدوه في دار علي بن أبي طالب ﵁. فقال أهل مكة: ضل محمد وغوى، وهوى إلى أهل بيته، ومال إلى ابن عمه علي بن أبي طالب. فعند ذلك نزلت هذه السورة. ثم قال ابن الجوزي: «هذا حديث موضوع، لا شك فيه، وما أبرد الذي وضعه، وما أبعد ما ذكر، وفى إسناده ظلمات». إلى أن قال: «والعجب من تغفيل من وضع هذا الحديث كيف رتب ما لا يصح في العقول مِن أن النجم يقع في دار ويثبت حتى يُرى، ومِن بلهه أنه وضع هذا الحديث على ابن عباس، وكان [ابن عباس] في زمن المعراج ابن سنتين، فكيف يشهد تلك الحالة ويرويها؟!».|34:عزاه السيوطي إلى ابن المنذر.|35:أخرجه ابن جرير ٢٢/٥.|36:تفسير الثعلبي ٩/١٣٥، وتفسير البغوي ٧/٣٩٧، وأوردا عقبه: يعني: ما يُرمى به الشياطين عند استراقهم السّمع.|37:تفسير البغوي ٧/٤٠٠.|38:تفسير مجاهد ص٦٢٥، وأخرجه عبد الرزاق ٢/٢٥٠، وابن جرير بنحوه ٢٢/٥. وعزاه ابن حجر في الفتح ٨/٦٠٤ إلى ابن عيينة في تفسيره مختصرًا، وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.|39:أخرجه ابن جرير ٢٢/٦ بنحوه.|40:عزاه السيوطي إلى سعيد بن منصور، وابن المنذر. وعزاه ابن حجر في الفتح ٨/٦٠٤ إلى ابن أبي حاتم بلفظ: النجم نجوم القرآن.|41:تفسير الثعلبي ٩/١٣٥.|42:تفسير الثعلبي ٩/١٣٥، وتفسير البغوي ٧/٤٠٠.|43:أخرجه عبد الرزاق ٢/٢٥٠.|44:أخرجه الثعلبي ٩/١٣٥، وهو في تفسير البغوي ٧/٤٠٠.|45:تفسير الثعلبي ٩/١٣٥، وتفسير البغوي ٧/٤٠٠.|46:تفسير مقاتل بن سليمان ٤/١٥٩.|47:أخرجه ابن جرير ٢٢/٥.|48:أخرجه أحمد ١٥/١٦ (٩٠٣٩)، ١٤/١٩٢ (٨٤٩٥)، والبزار في مسنده ١٦/١٨١ (٩٢٩٦) واللفظ له، من طريق عسل بن سفيان، عن عطاء، عن أبي هريرة به.</p><p>قال العقيلي في الضعفاء الكبير ٣/٤٢٦ (١٤٦٧) في ترجمة عسل بن سفيان: «في حديثه وهم، حدّثني آدم، قال: سمعت البخاري، قال: عسل بن سفيان اليربوعي، عن عطاء، فيه نظر». وقال البغوي في شرح السنة ٨/٩٨: «عسل بن سفيان أبو قرة اليربوعي، من أهل البصرة، فيه نظر». وقال ابن القيسراني في ذخيرة الحفاظ ١/٢٧٦ (١٩٧): «رواه أبو حنيفة، عن عطاء بن أبي رباح، عن أبي هريرة، ورواه عنه مصعب بن المقدام، ووكيع، ويزيد بن هارون، والحسن، ومحمد بن الحسن، وجعفر بن عون، وعبد الله بن عبد الرحمن المقري، وغيرهم. ولا يُحفظ عن عطاء إلا من روايته عن أبي حنيفة عنه. ورُوي عن عسل بن سفيان، عن عطاء مسندًا وموقوفًا. وعسل وأبو حنيفة سيّان في الضعف، على أنّ عسل مع ضعفه أحسن ضبطًا من أبي حنيفة». وهو كلام ابن عدي في الكامل ٨/٢٤٥. وقال الهيثمي في المجمع ٤/١٠٣ (٦٤٩٢، ٦٤٩٣): «فيه عسل بن سفيان؛ وثَّقه ابن حبان وقال: يخطئ ويخالف. وضعّفه جماعة، وبقية رجاله رجال الصحيح». وقال المناوي في التيسير ٢/٣٥٢: «إسناد حسن». وقال الألباني في الضعيفة ١/٥٧٢ (٣٩٧): «ضعيف».|49:أخرجه عبد الرزاق ٢/٢٥٠، وأبو نعيم (٣٨٣)، وابن جرير ٢٢/٧ بنحوه، تحت القول بأن معنى <span class="qpc-hafs">﴿والنَّجْمِ إذا هَوى﴾</span>: والقرآن إذا نزل.|50:عزاه السيوطي إلى أبي نعيم.|51:أخرجه أبو الفرج الأصبهاني في كتاب الأغاني ١٦/١٧٦.|52:أخرجه عبد الرزاق ٢/٢٥٠، وابن جرير ٢٢/٦ من طريق معمر وسعيد، تحت القول بأن معنى <span class="qpc-hafs">﴿والنَّجْمِ إذا هَوى﴾</span>: والقرآن إذا نزل.
  53,2,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿مَا ضَلَّ صَاحِبُكُمۡ وَمَا غَوَىٰ ۝٢﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٣١٥٩<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، في قوله: <span class="qpc-hafs">﴿والنَّجْمِ إذا هَوى ما ضَلَّ﴾</span>، قال: أقسم الله أنه ما ضلّ محمد وما غوى{1}. (١٤/١٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣١٦٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: فأقسم الله بالقرآن <span class="qpc-hafs">﴿ما ضَلَّ صاحِبُكُمْ محمد وما غَوى﴾</span> وما تكلّم بالباطل{2}. (ز)</p></p><p></div></p></div>",footnotes:1:عزاه السيوطي إلى ابن المنذر.|2:تفسير مقاتل بن سليمان ٤/١٥٩.
  53,3,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَمَا یَنطِقُ عَنِ ٱلۡهَوَىٰۤ ۝٣ إِنۡ هُوَ إِلَّا وَحۡیࣱ یُوحَىٰ ۝٤﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٣١٦١<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله <span class="qpc-hafs">﴿وما يَنْطِقُ عَنِ الهَوى﴾</span> قال: ما ينطق عن هواه <span class="qpc-hafs">﴿إنْ هُوَ إلّا وحْيٌ يُوحى﴾</span> قال: يُوحِي الله إلى جبريل، ويوحي جبريل إلى محمد ﷺ{1}. (١٤/١٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣١٦٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وما يَنْطِقُ﴾</span> محمدٌ هذا القرآن <span class="qpc-hafs">﴿عَنِ الهَوى﴾</span> مِن تلقاء نفسه، <span class="qpc-hafs">﴿إنْ هُوَ إلّا وحْيٌ يُوحى﴾</span> إليه. يقول: ما هذا القرآنُ إلا وحيٌ مِن الله تعالى، يأتيه به جبريلُ ﷺ{2}<span class=comment-ref>٦٢٦٢</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٢٦٢</span> نقل <u>ابنُ عطية</u> (٨/١٠٧) في قوله تعالى: <span class="qpc-hafs">﴿وما يَنْطِقُ عَنِ الهَوى﴾</span> عن بعض العلماء أن المعنى: «وما ينطق القرآن المُنزّل عن هوًى وشهوة». ثم <span class="comment-type-1">وجَّهه</span> بقوله: «ونسب تعالى النطق إليه من حيث يُفهم منه، <span class="mustanad">كما قال تعالى</span>: <span class="qpc-hafs">﴿هذا كِتابُنا يَنْطِقُ عَلَيْكُمْ بِالحَقِّ﴾</span> [الجاثية:٢٩]، وأسند الفعل إلى القرآن ولم يتقدم له ذكر لدلالة المعنى عليه».</p><p>وذكر <u>ابنُ القيم</u> (٣/٦٦) أن الضمير في قوله تعالى: <span class="qpc-hafs">﴿إنْ هُوَ إلاّ وحْيٌ يُوحى﴾</span> يعود على المصدر المفهوم من الفعل، أي: ما نطقه إلا وحي يوحى، ثم <span class="comment-type-4">علَّق</span> عليه بقوله: «وهذا أحسن من قول مَن جعل الضمير عائدًا إلى القرآن، فإنه <span class="mustanad">يعمّ</span> نطقه بالقرآن والسنة، وإنّ كليهما وحي يوحى».</div></p><p><h3><span class="qpc-hafs">﴿وَمَا یَنطِقُ عَنِ ٱلۡهَوَىٰۤ ۝٣ إِنۡ هُوَ إِلَّا وَحۡیࣱ یُوحَىٰ ۝٤﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٧٣١٦٣<span class="dash">-</span></span> عن أبي الحمراء، وحَبّة العُرَنيّ، قالا: لما أمر رسول الله ﷺ بسدّ الأبواب التي في المسجد، شقّ عليهم. قال حَبّة: إني لَأنظر إلى حمزة بن عبد المطلب وهو تحت قطيفةٍ حمراء، وعيناه تَذْرفان، وهو يقول: أخْرجتَ عمّك، وأبا بكر، وعمر، والعباس، وأسكنتَ ابنَ عمّك! فقال رجل يومئذ: ما يألو يرفعُ ابنَ عمّه. قال: فعلم رسول الله ﷺ أنّه قد شقّ عليهم، فدعا الصلاة جامعة، فلما اجتمعوا صعد المنبر، فلم يُسمع لرسول الله ﷺ خطبة قطّ كان أبلغ منها تمجيدًا وتوحيدًا، فلمّا فرغ قال: «<b>يا أيها الناس، ما أنا سددتُها، ولا أنا فتحتُها، ولا أنا أخرجتُكم وأسكنتُه</b>». ثم قرأ: <span class="qpc-hafs">﴿والنَّجْمِ إذا هَوى ما ضَلَّ صاحِبُكُمْ وما غَوى وما يَنْطِقُ عَنِ الهَوى إنْ هُوَ إلّا وحْيٌ يُوحى﴾</span>{3}. (١٤/١٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣١٦٤<span class="dash">-</span></span> عن أبي أُمامة، أنّ رسول الله ﷺ قال: «<b>ليَدْخُلنّ الجنةَ بشفاعة رجلٍ ليس بنبيٍّ مثلُ الحيَّيْن -أو مثل أحد الحيَّيْن- ربيعة ومُضر</b>». فقال رجل: يا رسول الله، وما ربيعة من مُضر؟ قال: «<b>إنما أقول ما أقول</b>»{4}. (١٤/١١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣١٦٥<span class="dash">-</span></span> عن أبي هريرة، عن النبيِّ ﷺ، قال: «<b>ما أخبرتُكم أنّه مِن عند الله فهو الذي لا شكّ فيه</b>»{5}. (١٤/١١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣١٦٦<span class="dash">-</span></span> عن أبي هريرة، عن رسول الله ﷺ، أنّه قال: «<b>لا أقول إلا حقًّا</b>». قال بعض أصحابه: فإنك تداعبنا، يا رسول الله. قال: «<b>إني لا أقول إلا حقًّا</b>»{6}. (١٤/١١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣١٦٧<span class="dash">-</span></span> عن حسّان بن عطية -من طريق الأوزاعي- قال: كان جبريل ﵇ يَنزِل على رسول الله ﷺ بالسنة كما ينزل عليه بالقرآن، ويعلمه إيّاها كما يعلمه القرآن{7}. (١٤/١٢)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ٢٢/٨. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.|2:تفسير مقاتل بن سليمان ٤/١٥٩.|3:عزاه السيوطي إلى ابن مردويه.|4:أخرجه أحمد ٣٦/٥٤٧، ٥٤٩ (٢٢٢١٥، ٢٢٢١٦)، ٣٦/٥٨٨ (٢٢٢٥٠)، ٣٦/٦٣٣-٦٣٤ (٢٢٢٩٧)، من طريق حريز بن عثمان، عن عبد الرحمن بن ميسرة، عن أبي أمامة به.</p><p>قال المنذري في الترغيب والترهيب ٤/٢٤١ (٥٥١٣): «إسناد جيد». وقال الذهبي في إثبات الشفاعة ص٤٦ (٣٥): «حديث قوي الإسناد». وقال الهيثمي في المجمع ١٠/٣٨١ (١٨٥٤٤): «رواه أحمد، والطبراني بأسانيد، ورجال أحمد وأحد أسانيد الطبراني رجالهم رجال الصحيح، غير عبد الرحمن بن ميسرة، وهو ثقة». وقال البوصيري في إتحاف الخيرة المهرة ٨/١٩٩ (٧٧٧٧): «رواته ثقات». وقال المناوي في فيض القدير ٥/٣٥٢ (٧٥٥٧): «رمز المصنف -السيوطي- لحُسنه». وقال في التيسير ٢/٣١٩: «إسناده كما قال المنذري جيد». وقال المظهري في تفسيره ٥/٤٨٠: «سند صحيح». وقال الألباني في الصحيحة ٥/٢١٠ (٢١٧٨): «إسناد حسن».|5:أخرجه البزار في مسنده ١٥/٣٤٠ (٨٩٠٠)، من طريق أحمد بن منصور، عن عبد الله بن صالح، عن الليث، عن ابن عجلان، عن زيد بن أسلم، عن أبي صالح، عن أبي هريرة به.</p><p>قال البزار: «وهذا الحديث لا نعلمه يُروى عن أبي هريرة إلا مِن هذا الوجه بهذا الإسناد». وقال الهيثمي في المجمع ١/١٧٩ (٨٣٨): «فيه أحمد بن منصور الرمادي، وهو ثقة، وفيه كلام لا يضرّ، وبقية رجاله رجال الصحيح، وعبد الله بن صالح مُختلفٌ فيه».|6:أخرجه أحمد ١٤/١٨٥ (٨٤٨١)، ١٤/٣٣٩ (٨٧٢٣) واللفظ له، والترمذي ٤/٩٥-٩٦ (٢١٠٨)، من طريق سعيد بن أبي سعيد، عن أبي هريرة به.</p><p>قال الترمذي: «هذا حديث حسن». وقال الهيثمي في المجمع ٩/١٧ (١٤٢٠١): «إسناده حسن». وقال المناوي في التيسير ١/٣٦٧: «إسناد حسن». وقال الألباني في الصحيحة ٤/٣٠٤-٣٠٥ (١٧٢٦): «إسناده حسن».|7:أخرجه أبو داود في المراسيل ص٢٦١، والدارمي ١/١٤٥، وابن بطة في الإبانة الكبرى ١/ ٢٥٥.
  53,4,"53:3"
  53,5,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿عَلَّمَهُۥ شَدِیدُ ٱلۡقُوَىٰ ۝٥﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٣١٦٨<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿عَلَّمَهُ شَدِيدُ القُوى﴾</span>: يعني: جبريل{1}. (١٤/١٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣١٦٩<span class="dash">-</span></span> عن <span class="name-2">الربيع بن أنس</span> -من طريق عن أبي جعفر- في قوله: <span class="qpc-hafs">﴿عَلَّمَهُ شَدِيدُ القُوى﴾</span>، قال: جبريل{2}. (١٤/١٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣١٧٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿عَلَّمَهُ شَدِيدُ القُوى﴾</span> يعني: القوة في كل شيء، يعني: جبريل{3}<span class=comment-ref>٦٢٦٣</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٢٦٣</span> <span class="comment-type-4">ذكر</span> <u>ابنُ عطية</u> (٨/١٠٧) أنّ الضمير في قوله تعالى: <span class="qpc-hafs">﴿عَلَّمَهُ﴾</span> «<b>يحتمل</b> أن يكون للقرآن، <span class="comment-type-3">والأظهر</span> أنه لمحمد ﷺ». ولم يذكر مستندًا، ثم نقل عن الحسن أن: «المعلِّم الشديد القوى هو الله تعالى». ثم <span class="comment-type-4">علَّق</span> بأن لفظ «القوَّة» «في جبريل ﵇ متمكِّن، ويؤيده قوله تعالى: <span class="qpc-hafs">﴿ذِي قُوَّةٍ عِنْدَ ذِي العَرْشِ مَكِينٍ﴾</span> [التكوير:٢٠]».</div></p></div>",footnotes:1:أخرجه ابن جرير بنحوه ٢٢/٩-١٠. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.|2:أخرجه ابن جرير بنحوه ٢٢/٩. وعزاه السيوطي إلى ابن أبي حاتم.|3:تفسير مقاتل بن سليمان ٤/١٥٩.
  53,6,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿ذُو مِرَّةࣲ فَٱسۡتَوَىٰ ۝٦﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٣١٧١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطية- في قوله: <span class="qpc-hafs">﴿ذُو مِرَّةٍ﴾</span>، قال: ذو خَلْق حَسن{1}. (١٤/١٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣١٧٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- في قوله: <span class="qpc-hafs">﴿ذُو مِرَّةٍ﴾</span>، قال: ذو مَنظر حَسن{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣١٧٣<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>: أن نافع بن الأزرق سأله عن قوله: <span class="qpc-hafs">﴿ذُو مِرَّةٍ﴾</span>. قال: ذو شِدّة في أمر الله. قال: وهل تعرف العرب ذلك؟ قال: نعم، أما سمعت قول نابغة بني ذُبيان:</p><p>فَديٌ أُقَرِّيه إذا ضافني وهْنًا قِرى ذي مِرّة حازم؟{3}. (١٤/١٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣١٧٤<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿عَلَّمَهُ شَدِيدُ القُوى ذُو مِرَّةٍ﴾</span>، قال: ذو قوة؛ جبريل{4}. (١٤/١٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣١٧٥<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿ذُو مِرَّةٍ﴾</span>، قال: ذو خَلْق طويل حَسن{5}. (١٤/١٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣١٧٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثم قال: <span class="qpc-hafs">﴿ذُو مِرَّةٍ﴾</span> يعني: جبريل ﵇، يقول: ذو قُوة <span class="qpc-hafs">﴿فاسْتَوى﴾</span> يعني: سويًّا، حسَن الخلق{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣١٧٧<span class="dash">-</span></span> عن <span class="name-3">سفيان [الثوري]</span> -من طريق مهران- <span class="qpc-hafs">﴿ذُو مِرَّةٍ﴾</span>، قال: ذو قُوّة{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣١٧٨<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿ذُو مِرَّةٍ فاسْتَوى﴾</span>، قال: ذو قُوة، المِرّة: القوة{8}<span class=comment-ref>٦٢٦٤</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٢٦٤</span> اختُلف في معنى: <span class="qpc-hafs">﴿ذُو مِرَّةٍ فاسْتَوى﴾</span> على قولين: <b>الأول:</b> ذو خَلْق حسن. <b>الثاني:</b> ذو قوَّة.</p><p>و<span class="comment-type-1">وجَّه</span> <u>ابنُ عطية</u> (٨/١٠٧) القول الثاني بقوله: «ومنه قول النبي ﷺ: «<b>لا تَحِلُّ الصدقة لغنيٍّ، ولا لذي مِرَّةٍ سَوِيٍّ</b>»».</p><p>و<span class="comment-type-3">رجَّح</span> <u>ابنُ جرير</u> (٢٢/١١) -<span class="mustanad">مستندًا إلى الدلالة العقلية-</span> «قول مَن قال: عُنِيَ بالمِرَّة: صحةُ الجسم وسلامته من الآفات والعاهات، والجسم إذا كان كذلك مِن الإنسان كان قويًّا». وعلَّل ذلك بقوله: «لأن المِرَّة واحدُ المِرَر، وإنما أريد به: ذو مِرَّةٍ سويَّةٍ، وإذا كانت المِرَّة صحيحة كان الإنسان صحيحًا، ومنه قول النبي ﷺ: «<b>لا تَحِلُّ الصدقة لغنيٍّ، ولا لذي مِرَّةٍ سَوِيٍّ</b>»».</p><p>وذكر <u>ابنُ عطية</u> (٨/١٠٨) القول الأول، ثم نقل <b>قولًا آخر</b> أن المعنى: «ذو جسم طويل حسن». ثم <span class="comment-type-2">انتقدهما</span> قائلًا: «وهذا كله ضعيف». <span class="comment-type-1">ولم يذكر مستندًا</span>.</p><p>و<span class="comment-type-4">علَّق</span> <u>ابنُ كثير</u> (١٣/٢٤٩) على القول الأول والثاني بقوله: «ولا منافاة بين القولين؛ فإنه ﵇ ذو مَنظر حسن، وقوة شديدة. وقد ورد الحديث الصحيح من رواية أبي هريرة وابن عمر ﵄ أن النبي ﷺ قال: «<b>لا تحل الصدقة لغنيٍّ، ولا لذي مرة سويٍّ</b>»».</p><p>و<span class="comment-type-1">وجَّه</span> <u>ابنُ جرير</u> (٢٢/١٢) «استوى» على القول بأن المتَّصف بقوله تعالى: <span class="qpc-hafs">﴿شَدِيدُ القُوى﴾</span> هو جبريل ﵇ بقوله: «وكأن قائل ذلك وجَّه معنى قوله: <span class="qpc-hafs">﴿فاسْتَوى﴾</span> أي: ارتفع واعتدل».</div></p></div>",footnotes:1:أخرجه ابن أبي حاتم -كما في الإتقان٢/٤٥-. وعزاه السيوطي إلى ابن المنذر.|2:أخرجه ابن جرير ٢٢/١٠.|3:أخرجه الطستي -كما في الإتقان ٢/٨٣-.|4:تفسير مجاهد ص٦٢٥، وأخرجه الفريابي -كما في تغليق التعليق ٤/٣٢٢، وفتح الباري ٨/٦٠٤-، وابن جرير ٢٢/١٠. وعزاه السيوطي إلى عبد بن حميد.|5:أخرجه ابن جرير بنحوه ٢٢/٩-١٠. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.|6:تفسير مقاتل بن سليمان ٤/١٥٩.|7:أخرجه ابن جرير ٢٢/١٠.|8:أخرجه ابن جرير ٢٢/١١.
  53,7,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَهُوَ بِٱلۡأُفُقِ ٱلۡأَعۡلَىٰ ۝٧﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٣١٧٩<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن مسعود</span> -من طريق مُرة-: أنّ رسول الله ﷺ لم يرَ جبريل في صورته إلا مرتين؛ أما واحدة فإنه سأله أن يراه في صورته، فأراه صورته، فسَدّ الأُفُق، وأما الثانية فإنه كان معه حيث صعد، فذلك قوله: <span class="qpc-hafs">﴿وهُوَ بِالأُفُقِ الأَعْلى﴾</span>، <span class="qpc-hafs">﴿لقد رأى من آيات ربه الكبرى﴾</span> قال: خَلْق جبريل{1}. (١٤/١٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣١٨٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، في قوله: <span class="qpc-hafs">﴿وهُوَ بِالأُفُقِ الأَعْلى﴾</span>، قال: مطلع الشمس{2}. (١٤/١٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣١٨١<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق معمر- في قوله: <span class="qpc-hafs">﴿وهُوَ بِالأُفُقِ الأَعْلى﴾</span>، قال: بأُفق المشرق الأعلى بينهما{3}. (١٤/١٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣١٨٢<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿وهُوَ بِالأُفُقِ الأَعْلى﴾</span>: والأُفق: الذي يأتي منه النهار{4}<span class=comment-ref>٦٢٦٥</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٢٦٥</span> نقل <u>ابنُ عطية</u> (٨/١٠٩) قول قتادة والحسن أن «الأفق الأعلى»: هو أُفُق مشرق الشمس. ثم <span class="comment-type-2">استدرك</span> عليه بقوله: «وهذا التخصيص لا دليل عليه».</div></p><p><div></p><p><p><span class="item-no">٧٣١٨٣<span class="dash">-</span></span> عن <span class="name-2">عطاء الخُراسانيّ</span> -من طريق يونس بن يزيد- في قول الله ﷿: <span class="qpc-hafs">﴿بالأفق الأعلى﴾</span>، قال: يُقال: مطلع الشمس{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣١٨٤<span class="dash">-</span></span> عن <span class="name-2">الربيع بن أنس</span> -من طريق أبي جعفر- <span class="qpc-hafs">﴿وهُوَ بِالأُفُقِ الأَعْلى﴾</span>، قال: السماء الأعلى، يعني: جبريل{4}<span class=comment-ref>٦٢٦٦</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٢٦٦</span> <span class="comment-type-3">رجَّح</span> <u>ابنُ جرير</u> (٢٢/١١) -<span class="mustanad">مستندًا إلى اللغة، والسياق، والنظائر-</span> أن قوله تعالى: <span class="qpc-hafs">﴿وهُوَ بِالأُفُقِ الأَعْلى﴾</span> يعني: محمدًا ﷺ، و<span class="comment-type-1">وجَّه</span> ذلك بقوله: "وذلك لَمّا أُسْرِي برسول الله ﷺ استوى هو وجبريل ﵉ بمطلع الشمس الأعلى، وعطف الأعلى، وعطف بقوله: <span class="qpc-hafs">﴿وهُوَ﴾</span> على ما في قوله: <span class="qpc-hafs">﴿فاسْتَوى﴾</span> من ذِكْرِ محمدٍ ﷺ، وأكثر كلام العرب إذا أرادوا العطف في مثل هذا الموضع أن يُظهِروا كناية المعطوف عليه، فيقولوا: استوى هو وفلانٌ. وقلَّما يقولون: استوى وفلانٌ. وقد ذكر الفراء عن بعض العرب أنه أنشده:</p><p>ألم تر أن النَّبْعَ يصلُبُ عودُه ولا يستوي والخِرْوعُ المتقصِّفُ</p><p>ومنه قول الله: <span class="qpc-hafs">﴿أئِذا كُنّا تُرابًا وآباؤُنا﴾</span> [النمل:٦٧]، فعطف بالآباء على المُكنّى في: <span class="qpc-hafs">﴿كُنّا﴾</span> من غير إظهار «نحن»، فكذلك قوله: <span class="qpc-hafs">﴿فاسْتَوى وهُوَ﴾</span>".</p><p>و<span class="comment-type-2">استدرك</span> <u>ابنُ عطية</u> (٨/١٠٨) على قول <u>ابن جرير</u> -<span class="mustanad">مستندًا إلى اللغة-</span> قائلًا: «وفي هذا التأويل العطف على المضمر المرفوع دون أن يؤكد، وذلك عند النحاة مستقبح».</p><p>و<span class="comment-type-4">علَّق</span> <u>ابنُ كثير</u> (١٣/٢٥٠) على قول <u>ابن جرير</u> بقوله: «وقد قال ابن جرير هاهنا قولًا لم أره لغيره، ولا حكاه هو عن أحد». ثم ذكر قوله وتوجيهه له من جهة العربية، ثم <span class="comment-type-2">استدرك</span> عليه -<span class="mustanad">مستندًا إلى التاريخ</span>- قائلًا: «وهذا الذي قاله من جهة العربية متجه، ولكن لا يساعده المعنى على ذلك؛ فإن هذه الرؤية لجبريل لم تكن ليلة الإسراء، بل قبلها، ورسول الله ﷺ في الأرض، فهبط عليه جبريل ﵇، وتدلى إليه، فاقترب منه وهو على الصورة التي خلقه الله عليها، له ستمائة جناح، ثم رآه بعد ذلك نزلة أخرى عند سدرة المنتهى -يعني: ليلة الإسراء- وكانت هذه الرؤية الأولى في أوائل البعثة بعد ما جاءه جبريل ﵇ أول مرة ...».</div></p><p><div></p><p><p><span class="item-no">٧٣١٨٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وهُوَ بِالأُفُقِ الأَعْلى﴾</span>، يعني: مِن قِبَل المطلع{7}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه أحمد ٦/٤١١ (٣٨٦٤)، وابن جرير ٢٢/٣٠ بلفظ قال: رأى جبريلَ في وبَر رجليه كالدُّر، مثل القطْر على البقْل، وابن أبي حاتم -كما في تفسير ابن كثير ٧/٤١٩-، والطبراني (١٠٥٤٧)، وأبو الشيخ (٣٦٦).|2:عزاه السيوطي إلى ابن المنذر.|3:أخرجه عبد الرزاق ٢/٢٥٠، وابن جرير ٢٢/١٣. وعزاه السيوطي إلى عبد بن حميد من طريق قتادة بلفظ: الأفق الأعلى على أُفق المشرق.|4:أخرجه ابن جرير ٢٢/١٣.|5:أخرجه أبو جعفر الرملي في جزئه (تفسير عطاء) ص١٠٨.|6:أخرجه ابن جرير ٢٢/١٣.|7:تفسير مقاتل بن سليمان ٤/١٥٩.
  53,8,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿ثُمَّ دَنَا فَتَدَلَّىٰ ۝٨﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٣١٨٦<span class="dash">-</span></span> عن عبد الله بن عباس، قال: قال النبي ﷺ: «<b>رأيتُ ربِّي في أحسن صورةٍ، فقال لي: يا محمد، هل تدري فيمَ يختصم الملأُ الأعلى؟ فقلتُ: لا، يا ربّ. فوضع يده بين كتفيّ، فوجدت بَرْدها بين ثدييّ، فعلمتُ ما في السماء والأرض، فقلتُ: يا ربّ، في الدّرجات والكفّارات، ونقْل الأقدام إلى الجماعات، وانتظار الصلاة بعد الصلاة. فقلتُ: يا ربِّ، إنّك اتخذتَ إبراهيم خليلًا، وكلّمتَ موسى تكليمًا، وفعلتَ، وفعلتَ. فقال: ألم أشرح لك صدرك؟! ألم أضع عنك وِزْرك؟! ألم أفعل بك؟! ألم أفعل؟! فأفضى إلَيّ بأشياء لم يُؤذن لي أن أُحَدِّثُكُمُوها، فذلك قوله: <span class="qpc-hafs">﴿ثُمَّ دَنا فَتَدَلّى فَكانَ قابَ قَوْسَيْنِ أوْ أدْنى فَأَوْحى إلى عَبْدِهِ ما أوْحى ما كَذَبَ الفُؤادُ ما رَأى﴾</span>. فجعل نورَ بصري في فؤادي، فنظرت إليه بفؤادي</b>»{1}. (١٤/٢١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣١٨٧<span class="dash">-</span></span> عن أنس بن مالك، قال: قال رسول الله ﷺ: «<b>لَمّا عُرِج بي مضى جبريلُ حتى جاء الجنة، فدخلتُ، فأُعطيتُ الكوثر، ثم مضى حتى جاء سِدرة المنتهى، فدنا ربُّك فتدلّى، فكان قاب قوسين أو أدنى</b>»{2}. (١٤/٢٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣١٨٨<span class="dash">-</span></span> عن أنس -من طريق كثير بن خنيس- [في قصة المعراج] قال: ... ثم مضى حتى جاء الجنة، فاستفتح، فقيل: مَن هذا؟ قال: جبريل. قيل: ومَن معك؟ قال: محمد. قال: وقد أُرسِل إليه؟ قال: نعم. ففُتِح. قال: «<b>فدخلت الجنة، فأُعطيت الكوثر، فإذا نهر في الجنة عِضادتاه</b>{3} <b>بيوت مجوَّفَةٌ من لؤلؤ</b>». ثم مضى حتى جاء سدرة المنتهى، <span class="qpc-hafs">﴿فتدلى* فكان قاب قوسين أو أدنى* فأوحى إلى عبده ما أوحى﴾</span>...{4}. (٩/١٥٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣١٨٩<span class="dash">-</span></span> عن محمد بن كعب القُرَظيّ، عن بعض أصحاب النبيِّ ﷺ، قال: قالوا: يا رسول الله، هل رأيتَ ربّك؟ قال: «<b>لم أره بعيني، ورأيته بفؤادي مرتين</b>». ثم تلا: <b><span class="qpc-hafs">﴿ثُمَّ دَنا فَتَدَلّى﴾</span></b>{5}. (١٤/٢٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣١٩٠<span class="dash">-</span></span> عن هبّار بن الأسود -من طريق عُروة- قال: كان أبو لهب وابنه عُتبة قد تجهّزا إلى الشام، وتجهّزتُ معهما، فقال ابن أبي لهب: واللهِ، لَأنطلِقنّ إلى محمد، فلَأوذينّه في ربّه. فانطلَق حتى أتاه، فقال: يا محمد، هو يكفر بالذي دنا فتدلّى، فكان قاب قوسين أو أدنى. فقال رسول الله ﷺ: «<b>اللهم، ابعث عليه كلبًا من كلابك</b>»{6}. (١٤/٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣١٩١<span class="dash">-</span></span> عن مسروق، قال: قلتُ ل<span class="name-1">عائشة</span>: ما قوله: <span class="qpc-hafs">﴿ثُمَّ دَنا فَتَدَلّى فَكانَ قابَ قَوْسَيْنِ أوْ أدْنى فَأَوْحى إلى عَبْدِهِ ما أوْحى﴾</span>؟ فقالت: إنّما ذاك جبريل، كان يأتيه في صورة الرجال، وإنّه أتاه في هذه المرة في صورته، فسدّ أُفق السماء{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣١٩٢<span class="dash">-</span></span> عن <span class="name-1">عائشة</span> -من طريق عروة- قالت: كان أول شأن رسول الله ﷺ أنّه رأى في منامه جبريل بأَجْياد{8}، ثم خرج لبعض حاجته، فصرخ به جبريل: يا محمد، يا محمد. فنظر يمينًا وشمالًا فلم ير شيئًا، ثلاثًا، ثم رفع بصره، فإذا هو ثاني إحدى رجليه على الأخرى على أُفق السماء، فقال: يا محمد، جبريل، جبريل. يُسكِّنه، فهرب النبيُّ ﷺ حتى دخل في الناس، فنظر فلم ير شيئًا، ثم خرج من الناس، فنظر فرآه، فذلك قول الله: <span class="qpc-hafs">﴿والنَّجْمِ إذا هَوى﴾</span> إلى قوله: <span class="qpc-hafs">﴿ثُمَّ دَنا فَتَدَلّى﴾</span>، يعني: جبريل إلى محمد{9}. (١٤/١٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣١٩٣<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطاء- في قوله: <span class="qpc-hafs">﴿ثُمَّ دَنا فَتَدَلّى﴾</span>، قال: هو محمد ﷺ، دنا فتدلى إلى ربه ﷿{10}. (١٤/١٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣١٩٤<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق أبي سلمة- في قوله: <span class="qpc-hafs">﴿ثُمَّ دَنا﴾</span>، قال دنا: ربه فتدلى{11}. (١٤/١٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣١٩٥<span class="dash">-</span></span> عن <span class="name-1">أنس بن مالك</span> -من طريق أبي نمر- يُحَدّث عن ليلة المسرى برسول الله ﷺ: أنه عَرج جبرائيل برسول الله ﷺ إلى السماء السابعة، ثم علا به بما لا يعلمه إلا الله، حتى جاء سِدْرة المنتهى، ودنا الجبّار ربُّ العزّة، فتدلّى، حتى كان منه قاب قوسين أو أدنى، فأوحى الله إليه ما شاء، فأوحى الله إليه فيما أوحى خمسين صلاة على أُمّته كل يوم وليلة. وذكر الحديث{12}<span class=comment-ref>٦٢٦٧</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٢٦٧</span> <span class="comment-type-4">علَّق</span> <u>ابنُ كثير</u> (١٣/٢٥٥ بتصرف) على هذه الرواية بأنه: «تكلّم كثيرٌ مِن الناس في متنها، وذكروا أشياء فيها مِن الغرابة، فإن صح فهو محمولٌ على وقت آخر وقصة أخرى، لا أنها تفسير لهذه الآية؛ فإن هذه كانت ورسول الله ﷺ في الأرض لا ليلة الإسراء، ولهذا قال بعده: <span class="qpc-hafs">﴿ولَقَدْ رَآَهُ نَزْلَةً أُخْرى عِنْدَ سِدْرَةِ المُنْتَهى﴾</span> [النجم:١٣-١٤]، فهذه هي ليلة الإسراء، والأولى كانت في الأرض».</div></p><p><div></p><p><p><span class="item-no">٧٣١٩٦<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- <span class="qpc-hafs">﴿فَكانَ قابَ قَوْسَيْنِ أوْ أدْنى﴾</span>، قال: الله من جبريل ﵇{13}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣١٩٧<span class="dash">-</span></span> قال <span class="name-2">الضَّحّاك بن مُزاحِم</span>: <span class="qpc-hafs">﴿ثُمَّ دَنا فَتَدَلّى﴾</span> دنا محمدٌ ﷺ مِن ربّه، فتدلّى، فأهوى للسجود، فكان منه قاب قوسين أو أدنى{14}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣١٩٨<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق معمر- <span class="qpc-hafs">﴿ثُمَّ دَنا فَتَدَلّى﴾</span>، قال: جبريل ﵇{15}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣١٩٩<span class="dash">-</span></span> عن عبّاد بن منصور، قال: سألتُ <span class="name-2">الحسن</span>، فقلتُ: <span class="qpc-hafs">﴿ثم دنا فتدلى﴾</span> مَن ذا، يا أبا سعيد؟ قال: ربي{16}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٢٠٠<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿ثُمَّ دَنا فَتَدَلّى﴾</span>: يعني: جبريل{17}. (١٤/١٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٢٠١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ثُمَّ دَنا﴾</span> الرّبُّ تعالى من محمد، <span class="qpc-hafs">﴿فَتَدَلّى﴾</span> وذلك ليلة أُسري بالنبي ﷺ إلى السماء السابعة{18}<span class=comment-ref>٦٢٦٨</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٢٦٨</span> اختُلِف في المراد بقوله تعالى: <span class="qpc-hafs">﴿ثُمَّ دَنا فَتَدَلّى﴾</span> على قولين: <b>الأول</b>: أنه الرب ﷿. <b>الثاني</b>: أنه جبريل ﵇.</p><p>و<span class="comment-type-3">رجَّح</span> <u>ابنُ عطية</u> (٥/١٩٧ دار الكتب العلمية) القول الثاني <span class="mustanad">مستندًا إلى السياق، والسنة</span>، فقال: «والصحيح عندي: أن جميع ما في هذه الآيات -أي: من قوله تعالى: <span class="qpc-hafs">﴿عَلَّمَهُ شَدِيدُ القُوى﴾</span>- هو مع جبريل ﵇، بدليل قوله تعالى: <span class="qpc-hafs">﴿ولَقَدْ رَآهُ نَزْلَةً أُخْرى﴾</span>، فإن ذلك يقضي بنزلة متقدمة، وما رُوي قطّ أنّ محمدًا ﷺ رأى ربَّه ﷿ قبل ليلة الإسراء، أما إن رؤية القلب لا تُمنَع بحال».</p><p>و<span class="comment-type-3">رجَّح</span> <u>ابنُ تيمية</u> (٦/١٣٠) -<span class="mustanad">مستندًا إلى أقوال السلف، والسياق</span>- أن الدُّنوّ والتَّدلي هو دنوّ جبريل ﵇ وتدلّيه، فقال: «الدنوّ والتدلّي في سورة النجم هو دنوّ جبريل وتدلّيه -كما قالت عائشة، وابن مسعود- والسياق يدُلُّ عليه، فإنه قال: <span class="qpc-hafs">﴿عَلَّمَهُ شَدِيدُ القُوى﴾</span> وهو جبريل، <span class="qpc-hafs">﴿ذُو مِرَّةٍ فاسْتَوى وهُوَ بِالأُفُقِ الأَعْلى ثُمَّ دَنا فَتَدَلّى﴾</span> فالضمائر كلها راجعة إلى هذا المُعلّم الشديد القوي، وهو ذو المِرّة، أي: القوة، وهو الذي استوى بالأُفق الأعلى، وهو الذي دنا فتدلّى، فكان مِن محمد ﷺ قدر قوسين أو أدنى، وهو الذي رآه نزلة أخرى عند سدرة المنتهى، رآه على صورته مرتين؛ مرة في الأرض، ومرة عند سدرة المنتهى».</div></p></div>",footnotes:1:أخرجه أحمد ٥/٤٣٧-٤٣٨ (٣٤٨٤)، والترمذي ٥/٤٤٢-٤٤٤ (٣٥١٤)، وعبد الرزاق ٣/١٢٦ (٢٦١٢)، من طريق معمر، عن أيوب، عن أبي قلابة، عن ابن عباس به.</p><p>وأخرجه ابن جرير ٢٢/٢٣ واللفظ له، من طريق أحمد بن عيسى التميمي، عن سليمان بن عمر بن سيار، عن أبيه، عن سعيد بن زربي، عن عمرو بن سليمان، عن عطاء، عن ابن عباس به.</p><p>قال الترمذي: «هذا حديث حسن غريب مِن هذا الوجه». وقال ابن كثير في تفسيره ٧/٤٥١ عن رواية ابن جرير: «إسناده ضعيف».|2:أخرجه ابن جرير ٢٢/١٩-٢٠، من طريق خلاد بن أسلم، عن النضر، عن محمد بن عمرو بن علقمة بن وقاص الليثي، عن كثير، عن أنس بن مالك به.</p><p>وسنده ضعيف؛ فيه كثير، وهو كثير بن سليم الضبي، قال عنه ابن حجر في تقريب التهذيب (٥٦١٣):«ضعيف».|3:العضادة: ناحية الطريق، والمراد: جانبا النهر. اللسان (عضد).|4:عزاه السيوطي إلى ابن مردويه مطولًا.|5:أخرجه ابن جرير ٢٢/١٩، من طريق ابن حميد، عن مهران، عن موسى بن عبيد الحميري، عن محمد بن كعب القُرَظيّ، عن بعض أصحاب النبي ﷺ به.</p><p>وسنده ضعيف؛ فيه موسى بن عبيدة الربذي، قال عنه ابن حجر في التقريب (٦٩٨٩): «ضعيف».</p><p>وأخرجه ابن أبي حاتم -كما في تفسير ابن كثير ٧/٤٢٤- مرسلًا، عن محمد بن كعب القرظي. وكذا عزاه السيوطي إلى عبد بن حميد، وابن المنذر.|6:أخرجه أبو نعيم في دلائل النبوة ص٤٥٤-٤٥٥ (٣٨٠)، وابن عساكر في تاريخ دمشق ٣٨/٣٠١-٣٠٢ كلاهما مطولًا، من طريق محمد بن حميد، عن سلمة بن الفضل، عن محمد بن إسحاق، عن عثمان بن عروة بن الزبير، عن أبيه، عن هبار بن الأسود به.</p><p>وسنده ضعيف؛ فيه محمد بن حميد الرازي، قال عنه ابن حجر في التقريب (٥٨٣٤): «حافظ ضعيف».|7:أخرجه ابن جرير ٢٢/١٨.|8:أجياد وجياد: موضع بمكة يلي الصفا. معجم البلدان ١/١٣٨، ٢/١٦٩. كان الاسم يطلق على شعبين كبيرين من شعاب مكة، وقد أصبحا اليوم مأهولين بأحياء عديدة مِن أحياء مكة، أشهرها: حي جِياد، والـمَصافي. معالم مكة التاريخية والأثرية لعاتق البلادي ص١٤.|9:أخرجه ابن جرير بنحوه ٢٢/١٧-١٨، وابن أبي حاتم -كما في تفسير ابن كثير ٧/٤٢٢، ٤٢٣-، والبيهقي في الدلائل ٢/٣٦٨.|10:أخرجه الطبراني (١١٣٢٨). وعزاه السيوطي إلى ابن أبي حاتم، وابن مردويه.|11:أخرجه ابن جرير ٢٢/١٤. وعزاه السيوطي إلى ابن مردويه.|12:أخرجه ابن جرير ٢٢/١٥، والثعلبي ٩/١٣٨.|13:تفسير مجاهد ص٦٢٥، وأخرجه ابن جرير ٢٢/١٩.|14:تفسير الثعلبي ٩/١٣٨، وتفسير البغوي ٧/٤٠٢.|15:أخرجه عبد الرزاق ٢/٢٥٠، وابن جرير ٢٢/١٤.|16:أخرجه ابن خزيمة في التوحيد ص٥٢٩.|17:أخرجه عبد الرزاق ٢/٢٥٠ من طريق معمر، وابن جرير ٢٢/١٤. وعزاه السيوطي إلى عبد بن حميد.|18:تفسير مقاتل بن سليمان ٤/١٦٠.
  53,9,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿فَكَانَ قَابَ قَوۡسَیۡنِ أَوۡ أَدۡنَىٰ ۝٩﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٣٢٠٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن مسعود</span> -من طريق زِرّ بن حُبَيْش- في قوله: <span class="qpc-hafs">﴿فَكانَ منه قابَ قَوْسَيْنِ﴾</span>، قال: رأى النبيُّ ﷺ جبريلَ له ستمائة جَناح{1}. (١٤/١٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٢٠٣<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن مسعود</span>، في قوله: <span class="qpc-hafs">﴿فَكانَ قابَ قَوْسَيْنِ﴾</span>، قال: دنا جبريلُ منه حتى كان قدر ذراع أو ذراعين{2}. (١٤/١٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٢٠٤<span class="dash">-</span></span> عن <span class="name-1">عائشة</span> -من طريق عروة- قالت: <span class="qpc-hafs">﴿فَكانَ قابَ قَوْسَيْنِ أوْ أدْنى﴾</span>، يقول: القاب: نصف الإصبع{3}. (١٤/١٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٢٠٥<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، في قوله: <span class="qpc-hafs">﴿فَكانَ قابَ قَوْسَيْنِ أوْ أدْنى﴾</span>، قال: كان دُنُوُّه قدرَ قوسين{4}. (١٤/١٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٢٠٦<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، في قوله: <span class="qpc-hafs">﴿فَكانَ قابَ قَوْسَيْنِ أوْ أدْنى﴾</span>، قال: كان بينه وبينه مقدار قوسين{5}. (١٤/١٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٢٠٧<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق زِرّ- في قوله: <span class="qpc-hafs">﴿فَكانَ قابَ قَوْسَيْنِ أوْ أدْنى﴾</span>، قال: القاب: القِيد، والقوسين: الذراعين{6}. (١٤/١٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٢٠٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، في قوله: <span class="qpc-hafs">﴿قابَ قَوْسَيْنِ﴾</span>، قال: ذراعين؛ القاب: المقدار، القوس: الذراع{7}. (١٤/١٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٢٠٩<span class="dash">-</span></span> عن <span class="name-1">أبي سعيد الخُدري</span>، قال: لَمّا أُسري بالنبي ﷺ اقترب مِن ربّه، <span class="qpc-hafs">﴿فَكانَ قابَ قَوْسَيْنِ أوْ أدْنى﴾</span> قال: ألم تر إلى القوس ما أقربها من الوَتر!{8}. (١٤/١٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٢١٠<span class="dash">-</span></span> عن <span class="name-2">أبي وائل شَقِيق بن سَلَمة</span>، في قوله: <span class="qpc-hafs">﴿فَكانَ قابَ قَوْسَيْنِ﴾</span>، قال: ذراعين، والقوس: الذراع يُقاس به كلُّ شيء{7}. (١٤/١٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٢١١<span class="dash">-</span></span> قال <span class="name-2">سعيد بن المسيّب</span>: <span class="qpc-hafs">﴿قابَ قَوْسَيْنِ أوْ أدْنى﴾</span> القاب: صدر القوس العربية، حيث يُشدّ عليه السّير الذي يتنكّبه صاحبه، ولكل قوسٍ قابٌ واحد، فأخبر أنّ قُرب جبرائيل من محمد ﷺ عند الوحي كقُرب قاب قوسين{10}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٢١٢<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جُبَير</span>، في الآية، قال: الذراع يُقاس به{7}. (١٤/١٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٢١٣<span class="dash">-</span></span> عن <span class="name-2">أبي رَزِين [مسعود بن مالك الأسدي]</span> -من طريق عاصم- <span class="qpc-hafs">﴿قابَ قَوْسَيْنِ﴾</span>، قال: ليست بهذه القوس، ولكن قدر الذراعين أو أدنى، والقاب: هو القِيد{12}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٢١٤<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿قابَ قَوْسَيْنِ﴾</span>، قال: حيث الوَتَر من القوس، يعني: ربّه{13}. (١٤/١٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٢١٥<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- <span class="qpc-hafs">﴿فَكانَ قابَ قَوْسَيْنِ أوْ أدْنى﴾</span>، قال: الله مِن جبريل ﵇{14}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٢١٦<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن جُرَيْج- في قوله: <span class="qpc-hafs">﴿ثُمَّ دَنا فَتَدَلّى فَكانَ قابَ قَوْسَيْنِ﴾</span> قال: حيث الوَتَر من القوس؛ الله من جبريل، <span class="qpc-hafs">﴿أوْ أدْنى﴾</span> من ذلك{15}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٢١٧<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق خُصَيف- <span class="qpc-hafs">﴿قابَ قَوْسَيْنِ﴾</span>، قال: قدر قوسين{16}. (١٤/١٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٢١٨<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٢١٩<span class="dash">-</span></span> و<span class="name-2">عكرمة مولى ابن عباس</span>، قالا: دنا منه، حتى كان بينه وبينه مثل ما بين كبِدها إلى الوَتَر{17}. (١٤/١٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٢٢٠<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span>، في قوله: <span class="qpc-hafs">﴿قابَ قَوْسَيْنِ﴾</span>، قال: مِن قِسِيِّكم هذه{7}. (١٤/١٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٢٢١<span class="dash">-</span></span> قال <span class="name-2">عطاء</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٢٢٢<span class="dash">-</span></span> و<span class="name-2">أبو إسحاق الهمداني</span>: <span class="qpc-hafs">﴿فَكانَ قابَ قَوْسَيْنِ﴾</span> قدر ذراعين، والقوس: الذِّراع، يُقاس بها كلّ شيء{19}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٢٢٣<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿فَكانَ قابَ قَوْسَيْنِ﴾</span> قال: قيد قوسين، <span class="qpc-hafs">﴿أوْ أدْنى﴾</span> قال: حيث الوَتَر من القوس؛ الله من جبريل{20}. (١٤/١٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٢٢٤<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span>، قال: ذُكِر لنا: أنّ القاب فُضَيْل طَرف القوس على الوَتَر{21}. (١٤/١٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٢٢٥<span class="dash">-</span></span> عن <span class="name-2">أبي إسحاق الهمداني</span> -من طريق عمرو بن ثابت- قال: هو ظُفْرُ القوس{22}{23}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٢٢٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فَكانَ﴾</span> منه <span class="qpc-hafs">﴿قابَ قَوْسَيْنِ﴾</span> يعني: قدر ما بين طرفي القوس مِن قِسيّ العرب، <span class="qpc-hafs">﴿أوْ أدْنى﴾</span> يعني: بل أدنى أو أقرب من ذلك{24}<span class=comment-ref>٦٢٦٩</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٢٦٩</span> <span class="comment-type-4">ذكر</span> <u>ابنُ القيم</u> (٣/٦٩) أنّ معنى: <span class="qpc-hafs">﴿فَكانَ قابَ قَوْسَيْنِ أوْ أدْنى﴾</span> أي: «بأنه قدر قوسين أو أدنى من ذلك، وليس هذا على وجه الشكّ، بل تحقيقٌ لقدر المسافة، وأنها لا تزيد عن قوسين ألبتة، <span class="mustanad">كما قال تعالى</span>: <span class="qpc-hafs">﴿وأَرْسَلْناهُ إلى مِائَةِ ألْفٍ أوْ يَزِيدُونَ﴾</span> [الصافات:١٤٧]، تحقيق لهذا العدد، وأنهم لا ينقصون عن مائة ألف رجل واحدًا، <span class="mustanad">ونظيره قوله</span>: <span class="qpc-hafs">﴿ثُمَّ قَسَتْ قُلُوبُكُمْ مِن بَعْدِ ذَلِكَ فَهِيَ كالحِجارَةِ أوْ أشَدُّ قَسْوَةً﴾</span> [البقرة:٧٤]، أي: لا تنقص قسوتها عن قسوة الحجارة، بل إن لم تزد على قسوة الحجارة لم تكن دونها». ثم <span class="comment-type-4">ذهب</span> إليه بقوله: «وهذا المعنى أحسن وألطف وأدقّ من قول مَن جعل <span class="qpc-hafs">﴿أو﴾</span> في هذه المواضع بمعنى: بل، ومن قول مَن جعلها للشكّ بالنسبة إلى الرأي، وقول مَن جعلها بمعنى: الواو. فتأمله».</div></p><p><div></p><p><p><span class="item-no">٧٣٢٢٧<span class="dash">-</span></span> عن <span class="name-3">سفيان بن عُيينة</span> -من طريق ابن أبي عمر- في قوله: <span class="qpc-hafs">﴿فَكانَ قابَ قَوْسَيْنِ﴾</span>، قال: ما بين وتَر القوس إلى كبِدها{25}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه البخاري (٤٨٥٦، ٤٨٥٧)، ومسلم (١٧٤)، والترمذي (٣٢٧٧)، وابن جرير ٢٢/١٧، والبيهقي ٢/٣٦٦. وعزاه السيوطي إلى ابن مردويه.|2:عزاه السيوطي إلى ابن جرير، وابن المنذر.|3:أخرجه ابن جرير ٢٢/١٧-١٨ بنحوه، وأخرجه ابن أبي حاتم -كما في تفسير ابن كثير ٧/٤٢٢-٤٢٣-، والبيهقي ٢/٣٦٨.|4:عزاه السيوطي إلى ابن المنذر، وابن أبي حاتم، وابن مردويه.|5:عزاه السيوطي إلى عَبد بن حُمَيد.|6:أخرجه الطبراني (١٢٦٠٣)، والضياء ١٠/٤٤ (٣٩). وعزاه السيوطي إلى مردويه.|7:عزاه السيوطي إلى الطبراني في السنة.|8:عزاه السيوطي إلى ابن المنذر، وابن مردويه.|9:عزاه السيوطي إلى الطبراني في السنة.|10:تفسير الثعلبي ٩/١٣٨.|11:عزاه السيوطي إلى الطبراني في السنة.|12:أخرجه ابن جرير ٢٢/١٦.|13:تفسير مجاهد ص٦٢٥، وأخرجه الفريابي -كما في التغليق ٤/٣٢٢-، وابن جرير ٢٢/١٥، والبيهقي (٩٢٧).|14:أخرجه ابن جرير ٢٢/١٩.|15:أخرجه إسحاق البستي ص٤٥٨، ٤٦٠.|16:أخرجه ابن جرير ٢٢/١٦. وعزاه السيوطي إلى الطبراني في السنة.|17:عزاه السيوطي إلى ابن المنذر. وأخرجه إسحاق البستي ص٤٥٩ من طريق جابر، بلفظ: حتى كان بينه وبينه قدر قوسين.|18:عزاه السيوطي إلى الطبراني في السنة.|19:تفسير الثعلبي ٩/١٣٩، وعقبه: وهي لغة بعض أهل الحجاز.|20:أخرجه ابن جرير ٢٢/١٥. وعزاه السيوطي إلى عبد بن حميد. كما أخرجه عبد الرزاق ٢/٢٥٠ من طريق معمر مقتصرًا على شطره الأول.|21:عزاه السيوطي إلى عبد بن حميد.|22:ظُفْر القوس: هو ما وراء مَعْقِد الوتر إلى طرف القوس. لسان العرب (ظفر).|23:أخرجه سعيد بن منصور في سننه -التفسير ٧/٤٤١ (٢٠٧٣).|24:تفسير مقاتل بن سليمان ٤/١٦٠.|25:أخرجه إسحاق البستي ص٤٦٠.
  53,10,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿فَأَوۡحَىٰۤ إِلَىٰ عَبۡدِهِۦ مَاۤ أَوۡحَىٰ ۝١٠﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٣٢٢٨<span class="dash">-</span></span> عن أنس، قال: قال رسول الله ﷺ: «<b>رأيتُ النور الأعظم، ولُطّ{1} دوني بحجاب رَفْرَفه الدُّر والياقوت، فأوحى الله إلَيَّ ما شاء أن يوحي</b>»{2}. (١٤/١٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٢٢٩<span class="dash">-</span></span> عن أنس بن مالك، أنّ رسول الله ﷺ قال: «<b>... ثم ذُهِب بي إلى السدرة</b>{3} <b>المنتهى، وإذا ورقها كآذان الفِيَلة، وإذا ثمرها كالقِلال</b>». قال: «<b>فلمّا غشِيَها مِن أمر الله ما غشي تغيَّرت، فما أحد مِن خلق الله يستطيع أن ينعتها مِن حُسْنِها، فأوحى الله إلَيَّ ما أوحى ...</b>»{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٢٣٠<span class="dash">-</span></span> عن <span class="name-1">عائشة</span> -من طريق عروة- قالت: <span class="qpc-hafs">﴿فَأَوْحى إلى عَبْدِهِ ما أوْحى﴾</span> جبريل إلى عبد ربّه{5}. (١٤/١٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٢٣١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عكرمة- في قوله: <span class="qpc-hafs">﴿فَأَوْحى إلى عَبْدِهِ ما أوْحى﴾</span>، قال: عبده محمد ﷺ{6}. (١٤/١٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٢٣٢<span class="dash">-</span></span> قال <span class="name-2">سعيد بن جُبَير</span>: <span class="qpc-hafs">﴿فَأَوْحى إلى عَبْدِهِ﴾</span> أوحى إليه: <span class="qpc-hafs">﴿ألَمْ يَجِدْكَ يَتِيمًا فَآوى﴾</span> [الضحى:٦] إلى قوله تعالى: <span class="qpc-hafs">﴿ورَفَعْنا لَكَ ذِكْرَكَ﴾</span> [الشرح:٤]{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٢٣٣<span class="dash">-</span></span> قال <span class="name-2">الحسن البصري</span> -من طريق قتادة- <span class="qpc-hafs">﴿فَأَوْحى إلى عَبْدِهِ ما أوْحى﴾</span>: جبريل{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٢٣٤<span class="dash">-</span></span> عن <span class="name-2">الربيع بن أنس</span> -من طريق أبي جعفر- <span class="qpc-hafs">﴿فَأَوْحى إلى عَبْدِهِ ما أوْحى﴾</span>، قال: على لسان جبريل{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٢٣٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فَأَوْحى إلى عَبْدِهِ﴾</span> محمد ﷺ <span class="qpc-hafs">﴿ما أوْحى﴾</span>{10}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٢٣٦<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿فَأَوْحى إلى عَبْدِهِ ما أوْحى﴾</span>، قال: أوحى جبريلُ إلى رسولِ الله ﷺ ما أوحى اللهُ إليه{8}<span class=comment-ref>٦٢٧٠</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٢٧٠</span> اختُلف في معنى: <span class="qpc-hafs">﴿فَأَوْحى إلى عَبْدِهِ ما أوْحى﴾</span> على قولين: <b>الأول:</b> فأوحى الله إلى عبده محمدٍ ﷺ وحْيَه. <b>الثاني:</b> فأوحى جبريل ﵇ إلى عبده محمد ﷺ ما أوحى إليه ربُّه.</p><p>و<span class="comment-type-1">وجَّه</span> <u>ابنُ جرير</u> (٢٢/٢٠) القول الثاني بقوله: «وقد يتوجَّه على هذا التأويل <span class="qpc-hafs">﴿ما﴾</span> لوجهين: <b>أحدهما</b>: أن تكون بمعنى: الذي، فيكون معنى الكلام: فأوحى إلى عبده الذي أوحاه إليه ربُّه. <b>والآخر</b>: أن تكون بمعنى المصدر». ثم <span class="comment-type-3">رجَّحه</span> <span class="mustanad">مستندًا إلى دلالة السياق</span>، وعلَّل ذلك بقوله: «لأن افتتاح الكلام جرى في أول السورة بالخبر عن محمد ﷺ، وعن جبريل ﵇، وقوله: <span class="qpc-hafs">﴿فَأَوْحى إلى عَبْدِهِ ما أوْحى﴾</span> في سياق ذلك، ولم يأت ما يدل على انصراف الخبر عنهما فيوجَّه ذلك إلى ما صُرِف إليه».</p><p>و<span class="comment-type-4">علَّق</span> <u>ابنُ كثير</u> (١٣/٢٥٦) على القول الأول والثاني بقوله: «وكلا المعنيين صحيح».</p><p>ونقل <u>ابنُ عطية</u> (٨/١١٠) عن بعض العلماء أن المعنى: «فأوحى الله تعالى إلى عبده جبريل ﵇ ما أوحى».</div></p><p><h3><span class="qpc-hafs">﴿فَأَوۡحَىٰۤ إِلَىٰ عَبۡدِهِۦ مَاۤ أَوۡحَىٰ ۝١٠﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٧٣٢٣٧<span class="dash">-</span></span> عن شُريح بن عبيد، قال: لَمّا صعد النبيُّ ﷺ إلى السماء، فأوحى الله إلى عبده ما أوحى، قال: «<b>فلمّا أحسّ جبريلُ بدنُوّ الربِّ خرَّ ساجدًا، فلم يزل يُسبّحه: سبحان ذي الجبروت والملكوت والكبرياء والعظمة. حتى قضى الله إلى عبده ما قضى، ثم رفع رأسه، فرأيتُه في خلْقه الذي خُلق عليه؛ منظوم أجنحته بالزَّبَرْجَد واللؤلؤ والياقوت، فخُيّل إلَيَّ أنّ ما بين عينيه قد سَدّ الأُفق، وكنتُ لا أراه قبل ذلك إلا على صور مختلفة، وأكثر ما كنتُ أراه على صورة دِحية الكلبي، وكنتُ أحيانًا لا أراه قبل ذلك إلا كما يرى الرجل صاحبه مِن وراء الغِربال</b>»{12}. (١٤/١٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٢٣٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عمر</span>: أنّ جبريل كان يأتي النبيَّ ﷺ في صورة دِحية الكلبيّ{13}. (١٤/١٨)</p></p><p></div></p></div>",footnotes:1:اللَّطّ: الستْر. لسان العرب (لطط).|2:أخرجه البزار في مسنده ١٤/١٠ (٧٣٨٩)، والطبراني في الأوسط ٦/٢١١ (٦٢١٤) كلاهما مطولًا، من طريق الحارث بن عبيد، عن أبي عمران الجوني، عن أنس بن مالك به.</p><p>قال البزار: «وهذا الحديث لا نعلم رواه إلا أنس، ولا نعلم رواه عن أبي عمران إلا الحارث بن عبيد، وكان رجلًا مشهورًا من أهل البصرة». وقال أبو نعيم في الحلية ٢/٣١٦: «غريب، لم نكتبه إلا من حديث أبي عمران، عن أنس، تفرَّد به عنه الحارث بن عبيد أبو قدامة». وقال ابن كثير في تفسيره ٧/٤٤٥ مُعَلِّقًا على كلام البزار: «قلت: الحارث بن عبيد هذا هو أبو قدامة الإيادي، أخرج له مسلم في صحيحه، إلا أنّ ابن معين ضعّفه، وقال: ليس هو بشيء. وقال الإمام أحمد: مضطرب الحديث. وقال أبو حاتم الرازي: كُتب حديثه، ولا يُحتجّ به. وقال ابن حبان: كثر وهْمه؛ فلا يجوز الاحتجاج به إذا انفرد. فهذا الحديث من غرائب رواياته، فإنّ فيه نكارة وغرابة ألفاظ وسياقًا عجيبًا، ولعله منام». وقال الذهبي في سير أعلام النبلاء ١/٢٧٣: «إسناده جيد حسن، والحارث من رجال مسلم». وقال الهيثمي في المجمع ١/٧٥ (٢٣٨): «رجاله رجال الصحيح». وقال ابن حجر في الفتح ٧/١٩٨ عن إسناد البزار: «ورجاله لا بأس بهم، إلا أنّ الدارقطني ذكر له علة تقتضي إرساله». وقال أيضًا في الفتح ٨/٦٠٩ معلقًا على كلام البزار: «قلتُ: وهو -الحارث بن عبيد- من رجال البخاري». وقال الألباني في الضعيفة ١١/٧٥٣ (٥٤٤٤): «ضعيف».|3:قال النووي في شرحه على مسلم ٢/٢١٤: «هكذا وقع في الأصول السدرة بالألف واللام، وفي الروايات بعد هذا: سدرة المنتهى».|4:أخرجه مسلم ١/١٤٥-١٤٦ (١٦٢) مطولًا.|5:عزاه السيوطي إلى ابن جرير، وابن أبي حاتم، والبيهقي في الدلائل.|6:أخرجه النسائي في الكبرى (١١٥٣٨)، وابن جرير ٢٢/٢٠ بنحوه. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم، وابن مردويه.|7:تفسير الثعلبي ٩/١٣٩، وتفسير البغوي ٧/٤٠٢. وذكره ابن كثير في تفسيره ٧/٤٤٨ دون عزو.|8:أخرجه ابن جرير ٢٢/٢١.|9:أخرجه ابن جرير ٢٢/٢١.|10:تفسير مقاتل بن سليمان ٤/١٦٠.|11:أخرجه ابن جرير ٢٢/٢١.|12:أخرجه أبو الشيخ في العظمة (٣٥٨)، وأبو نعيم (١٧٠).</p><p>وقال محقق العظمة: «ضعيف».|13:عزاه السيوطي إلى عبد بن حميد.
  53,11,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿مَا كَذَبَ ٱلۡفُؤَادُ مَا رَأَىٰۤ ۝١١﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٣٢٣٩<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن مسعود</span> -من طريق عبد الرحمن بن يزيد- في قوله: <span class="qpc-hafs">﴿ما كَذَبَ الفُؤادُ ما رَأى﴾</span>، قال: رأى رسولُ الله ﷺ جبريلَ عليه حُلَّتا رَفْرَف أخضر، قد ملأ ما بين السماء والأرض{1}. (١٤/١٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٢٤٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن مسعود</span> -من طريق زِرّ بن حُبَيْش- <span class="qpc-hafs">﴿ما كذب الفؤاد ما رأى﴾</span>، قال: رأى جبريلَ له ستمائة جناح{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٢٤١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق أبي العالية- في قوله: <span class="qpc-hafs">﴿ما كَذَبَ الفُؤادُ ما رَأى﴾</span>، قال: رآه بقلبه{3}. (١٤/١٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٢٤٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق أبي إسحاق، عمَّن سمِعه– يقول: <span class="qpc-hafs">﴿ما كَذَبَ الفُؤادُ ما رَأى﴾</span>، قال: رأى محمدٌ ربَّه{4}<span class=comment-ref>٦٢٧١</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٢٧١</span> <span class="comment-type-4">علَّق</span> <u>ابنُ كثير</u> (١٣/٢٥٦) على رواية ابن عباس التي أطلقت الرؤية بأنها محمولة على المقيّدة بالفؤاد.</div></p><p><div></p><p><p><span class="item-no">٧٣٢٤٣<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>: أنّ النبيَّ ﷺ رأى ربّه بعينه{5}<span class=comment-ref>٦٢٧٢</span>. (١٤/١٩)</p></p><p></div></p><p><div><span class=comment-ref>٦٢٧٢</span> <span class="comment-type-2">انتقد</span> <u>ابنُ كثير</u> (١٣/٢٥٦) هذه الرواية قائلًا: «ومَن رُوي عنه بالبصر فقد أغرب؛ فإنه لا يصح في ذلك شيء عن الصحابة ﵃».</div></p><p><div></p><p><p><span class="item-no">٧٣٢٤٤<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق الشعبي- قال: إنّ محمدًا رأى ربَّه مرتين؛ مرة ببصره، ومرة بفؤاده{6}. (١٤/٢٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٢٤٥<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق الشعبي- في قوله: <span class="qpc-hafs">﴿ما كَذَبَ الفُؤادُ ما رَأى ولَقَدْ رَآهُ نَزْلَةً أُخْرى﴾</span>، قال: رأى محمدٌ ربّه بقلبه مرتين{7}<span class=comment-ref>٦٢٧٣</span>. (١٤/١٨)</p></p><p></div></p><p><div><span class=comment-ref>٦٢٧٣</span> <span class="comment-type-2">استدرك</span> <u>ابنُ تيمية</u> (٦/١٣٢) على قول ابن عباس قائلًا: «وأمّا قول ابن عباس: رآه بفؤاده مرتين. فإن كان <span class="mustanad">استناده إلى قوله تعالى</span>: <span class="qpc-hafs">﴿ما كَذَبَ الفُؤادُ ما رَأى﴾</span> ثم قال: <span class="qpc-hafs">﴿ولَقَدْ رَآهُ نَزْلَةً أُخْرى﴾</span> -والظاهر أنه مستنده- فقد صحّ عنه ﷺ أن هذا المرئيَّ جبريلُ ﵇، رآه مرتين في صورته التي خلق عليها».</p><p>و<span class="comment-type-4">بنحوه</span> قال <u>ابنُ القيم</u> (٣/٧٣).</div></p><p><div></p><p><p><span class="item-no">٧٣٢٤٦<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عكرمة- قال: أتعجبون أن تكون الخُلّة لإبراهيم، والكلام لموسى، والرؤية لمحمد ﷺ؟!{8}. (١٤/٢١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٢٤٧<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق أبي سلمة- في قول الله: <span class="qpc-hafs">﴿ولَقَدْ رَآهُ نَزْلَةً أُخْرى عِنْدَ سِدْرَةِ المُنْتَهى﴾</span> قال: دنا ربّه فتدلّى، <span class="qpc-hafs">﴿فَكانَ قابَ قَوْسَيْنِ أوْ أدْنى فَأَوْحى إلى عَبْدِهِ ما أوْحى﴾</span> قال: قال ابن عباس: قد رآه النبي ﷺ{9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٢٤٨<span class="dash">-</span></span> عن <span class="name-2">أبي العالية الرِّياحيّ</span>، في قوله: <span class="qpc-hafs">﴿ما كَذَبَ الفُؤادُ ما رَأى﴾</span>، قال: محمدٌ رآه بفؤاده، ولم يَره بعينيه{10}. (١٤/٢٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٢٤٩<span class="dash">-</span></span> عن <span class="name-2">إبراهيم النَّخْعي</span>، قال: رأى جبريلَ في صورته{10}. (١٤/٢٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٢٥٠<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span> -من طريق عيسى بن عبيد- قال: رأى محمدٌ ﷺ ربَّه{12}. (١٤/٢١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٢٥١<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق معمر- <span class="qpc-hafs">﴿ما كَذَبَ الفُؤادُ ما رَأى﴾</span>، قال: رأى جبريلَ في صورته التي هي صورته. قال: وهو الذي رآه نَزْلةً أخرى{13}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٢٥٢<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق عمرو بن عُبيد-= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٢٥٣<span class="dash">-</span></span> و<span class="name-2">الأعرج</span>: <span class="qpc-hafs">﴿ما كَذَبَ الفُؤادُ ما رَأى﴾</span> حقيقة. يقول: أثبت ما رأى{14}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٢٥٤<span class="dash">-</span></span> عن <span class="name-2">أبي صالح باذام</span> -من طريق إسماعيل السُّدِّيّ- في قوله: <span class="qpc-hafs">﴿ما كَذَبَ الفُؤادُ ما رَأى﴾</span>، قال: رآه مرتين بفؤاده{15}. (١٤/٢٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٢٥٥<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- في قوله: <span class="qpc-hafs">﴿ما كَذَبَ الفُؤادُ ما رَأى﴾</span>، قال: رأى جبريلَ في صورته التي هي صورته{16}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٢٥٦<span class="dash">-</span></span> عن <span class="name-2">الربيع بن أنس</span> -من طريق حكّام، عن أبي جعفر-: <span class="qpc-hafs">﴿ما كَذَبَ الفُؤادُ﴾</span> فلم يَكْذِبْه <span class="qpc-hafs">﴿ما رَأى﴾</span> قال: رأى ربَّه{17}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٢٥٧<span class="dash">-</span></span> عن <span class="name-2">الربيع بن أنس</span> -من طريق مهران، عن أبي جعفر- <span class="qpc-hafs">﴿ما كَذَبَ الفُؤادُ ما رَأى﴾</span>، قال: رأى محمدٌ ربَّه بفؤاده{18}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٢٥٨<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ما كَذَبَ الفُؤادُ ما رَأى﴾</span>، يعني: ما كذب قلب محمد ﷺ ما رأى بَصره مِن أمر ربّه تلك الليلة{19}<span class=comment-ref>٦٢٧٤</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٢٧٤</span> اختُلف في الذي رآه النبي ﷺ على قولين: <b>الأول:</b> أنه رأى ربَّه ﷿. وهو قول ابن عباس، وعكرمة وما في معناه. <b>الثاني:</b> أنه رأى جبريل ﵇ في صورته التي خُلِق عليها. وهو قول عائشة، وابن مسعود ﵃، وما في معناه.</p><p>و<span class="comment-type-3">رجَّح</span> <u>ابنُ عطية</u> (٨/١١٠-١١٢) القول الثاني <span class="mustanad">مستندًا إلى السنة</span>، من حديث عائشة ﵂ [من طريق مسروق الآتي في تفسير قوله: <span class="qpc-hafs">﴿ولَقَدْ رَآهُ نَزْلَةً أُخْرى﴾</span>]، فقال: «وحديث عائشة عن النبي ﷺ قاطع لكل تأويل في اللفظ؛ لأن قول غيرها إنما هو منتزعٌ مِن ألفاظ القرآن».</p><p>و<span class="comment-type-4">علَّق</span> <u>ابنُ تيمية</u> (٦/١٣١) على القول الأول بقوله: «وليس قولُ ابن عباس أنّه رآه مُناقِضًا لهذا -أي: للقول الثاني-، ولا قوله رآه بفؤاده، وقد صحَّ عنه أنه قال: «<b>رأيتُ ربي</b> -<b>تبارك وتعالى</b>-». لكن لم يكن هذا في الإسراء، ولكن كان في المدينة لَمّا احتبس عنهم في صلاة الصبح، ثم أخبرهم عن رؤية ربّه -تبارك وتعالى- تلك الليلة في منامه. وعلى هذا بنى الإمام أحمد وقال: نعم رآه حقًّا، فإنّ رؤيا الأنبياء حقٌّ ولا بد».</div></p><p><h3><span class="qpc-hafs">﴿مَا كَذَبَ ٱلۡفُؤَادُ مَا رَأَىٰۤ ۝١١﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٧٣٢٥٩<span class="dash">-</span></span> عن أبي ذرّ، قال: سألتُ رسول الله ﷺ هل رأيتَ ربّك؟ فقال: «<b>نورٌ، أنّى أراه!</b>»{20}. (١٤/٢٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٢٦٠<span class="dash">-</span></span> عن أبي ذرٍّ، أنه سأل رسول الله ﷺ: هل رأيتَ ربّك؟ فقال: «<b>رأيتُ نورًا</b>»{20}. (١٤/٢٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٢٦١<span class="dash">-</span></span> عن أبي العالية، قال: سُئل رسول الله ﷺ: هل رأيتَ ربّك؟ قال: «<b>رأيتُ نهرًا، ورأيتُ وراء النهر حجابًا، ورأيتُ وراء الحجاب نورًا، لم أره غير ذلك</b>»{22}. (١٤/٢٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٢٦٢<span class="dash">-</span></span> عن <span class="name-1">عائشة</span> -من طريق عُروة- قالت: مَن زعم أنّ محمدًا ﷺ رأى ربَّه ﷿ فقد كذب{23}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٢٦٣<span class="dash">-</span></span> عن <span class="name-1">أنس بن مالك</span>، قال: رأى محمدٌ ربَّه{5}. (١٤/١٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٢٦٤<span class="dash">-</span></span> عن عبد الله بن أبي سلمة: أنّ عبد الله بن عمر بن الخطاب بعَث إلى <span class="name-1">عبد الله بن عباس</span> يسأله: هل رأى محمدٌ ربَّه؟ فأَرسَل إليه عبد الله بن عباس: أن نعم. فردّ عليه عبدُ الله بن عمر رسولَه: أن كيف رآه؟ فأَرسَل: إنه رآه في رَوْضة خضراء، دونه فراش من ذهب، على كرسيّ مِن ذهب، يحمله أربعة من الملائكة؛ مَلك في صورة رجل، ومَلك في صورة ثَوْر، ومَلك في صورة نسر، ومَلك في صورة أسد{25}. (١٤/٢١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٢٦٥<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جُبَير</span>، قال: ما أزعم أنه رآه، وما أزعم أنه لم يره{10}. (١٤/٢٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٢٦٦<span class="dash">-</span></span> عن المبارك بن فَضالة، قال: كان <span class="name-2">الحسن</span> يحلف بالله: لقد رأى محمد ربّه{27}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٢٦٧<span class="dash">-</span></span> عن <span class="name-3">موسى بن سالم</span>، قال: لم ير رسولُ الله ﷺ جبريلَ ﵇ في صورته إلا مرة واحدة، رآه وعليه ثياب خُضر فيها الدُّر{23}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه آدم بن أبي إياس -كما في تفسير مجاهد ص٦٢٥-، والترمذي (٣٢٨٣)، وابن جرير ٢٢/٢٥، والطبراني (٩٠٥٠)، وأبو الشيخ (٣٤٣)، والحاكم ٢/٤٦٨-٤٦٩، والبيهقي ٢/٣٦٧. وعزاه السيوطي إلى الفريابي، وأبي نعيم، وابن المنذر، وابن مردويه.|2:أخرجه البيهقي في دلائل النبوة ٢/٣٦٧.|3:أخرجه آدم بن أبي إياس -كما في تفسير مجاهد ص٦٢٥-، والترمذي (٣٢٨١)، وابن جرير بنحوه ٢٢/٢٢، ٢٤، وبمثله من طريق عكرمة، والطبراني (١٢٩٤١)، والحديث أخرجه مسلم (١٧٦/٢٨٤)، وأخرجه ابن مردويه -كما في الفتح ٨/٦٠٨- من طريق عطاء. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.|4:أخرجه ابن جرير ٢٢/٢٤١، والطبراني في المعجم الكبير ١٢/٣٧-٣٨ (١٢٤٠٠) من طريق سعيد بلفظ: رآه.|5:عزاه السيوطي إلى ابن مردويه.|6:أخرجه الطبراني (١٢٥٦٤). وعزاه السيوطي إلى ابن مردويه.|7:أخرجه أحمد ٣/٤٢٥ (١٩٥٦)، ومسلم (١٧٦/٢٨٥)، والطبراني (١١٤٥٥، ١٢٩٤١)، والبيهقي (٩٢٦). وعزاه السيوطي إلى ابن مردويه.|8:أخرجه ابن جرير ٢٢/٢٤ بنحوه، والنسائي في الكبرى (١١٥٣٩)، والحاكم ٢/٤٦٩. وعزاه السيوطي إلى ابن مردويه.|9:أخرجه ابن جرير ٢٢/٣٢.|10:عزاه السيوطي إلى عَبد بن حُمَيد.|11:عزاه السيوطي إلى عَبد بن حُمَيد.|12:أخرجه ابن جرير ٢٢/٢٢-٢٣ بنحوه، ومن طريق سالم وابن عباد أيضًا بنحوه.|13:أخرجه عبد الرزاق ٢/٢٥١، وابن جرير ٢٢/٢٦ عن قتادة.|14:أخرجه إسحاق البستي ص٤٦٠.|15:أخرجه ابن جرير ٢٢/٢٤. وعزاه السيوطي إلى عبد بن حميد.|16:أخرجه عبد الرزاق ٢/٢٥١، وابن جرير ٢٢/٢٦.|17:أخرجه ابن جرير ٢٢/٢٤.|18:أخرجه ابن جرير ٢٢/٢٥.|19:تفسير مقاتل بن سليمان ٤/١٦٠.|20:أخرجه مسلم ١/١٦١ (١٧٨).|21:أخرجه مسلم ١/١٦١ (١٧٨).|22:أخرجه ابن أبي حاتم -كما في تفسير ابن كثير ٧/٤٢٥-. وعزاه السيوطي إلى ابن المنذر.</p><p>وقال ابن كثير: «غريب جدًّا».|23:أخرجه آدم بن أبي إياس -كما في تفسير مجاهد ص٦٢٦-.|24:عزاه السيوطي إلى ابن مردويه.|25:أخرجه البيهقي (٩٣٤). وعزاه السيوطي إلى ابن إسحاق.</p><p>قال محقق الأسماء والصفات: «إسناده ضعيف ومتنه منكر». وذكره ابن الجوزي في العلل المتناهية ١/٢٣-٢٤، وقال: «هذا حديث لا يصح».|26:عزاه السيوطي إلى عَبد بن حُمَيد.|27:أخرجه عبد الرزاق ٢/٢٥٣.|28:أخرجه آدم بن أبي إياس -كما في تفسير مجاهد ص٦٢٦-.
  53,12,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿أَفَتُمَـٰرُونَهُۥ عَلَىٰ مَا یَرَىٰ ۝١٢﴾</span> - قراءات</h3></p><p><div></p><p><p><span class="item-no">٧٣٢٦٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> أنّه كان يقرأ: ‹أفَتَمْرُونَهُ›{1}. (١٤/١٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٢٦٩<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جُبَير</span> أنه كان يقرأ: ‹أفَتَمْرُونَهُ›{2}. (١٤/١٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٢٧٠<span class="dash">-</span></span> عن <span class="name-2">إبراهيم النَّخْعي</span> -من طريق مُغيرة- أنه كان يقرأ: ‹أفَتَمْرُونَهُ›{3}. (١٤/١٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٢٧١<span class="dash">-</span></span> عن عامر الشعبي، أنّ <span class="name-2">شُريحًا</span> كان يقرأ: <span class="qpc-hafs">﴿أفتُمارُونَهُ﴾</span> بالألف= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٢٧٢<span class="dash">-</span></span> وكان <span class="name-2">مسروق</span> يقرأ: ‹أفَتَمْرُونَهُ›{4}<span class=comment-ref>٦٢٧٥</span>. (١٤/١٩)</p></p><p></div></p><p><div><span class=comment-ref>٦٢٧٥</span> اختلفت القرأة في قراءة قوله تعالى: <span class="qpc-hafs">﴿أفَتُمارُونَهُ﴾</span> على قراءتين: <b>الأولى:</b> ‹أفَتَمْرُونَه› بفتح التاء بغير ألف، بمعنى: أفتَجْحدونه. <b>الثانية:</b> <span class="qpc-hafs">﴿أفَتُمارونَه﴾</span> بضم التاء وبألف، بمعنى: أفتُجادلونه.</p><p>و<span class="comment-type-3">رجَّح</span> <u>ابنُ جرير</u> (٢٢/٢٨): «أنهما قراءتان <span class="mustanad">معروفتان صحيحَتا المعنى</span>، وذلك أن المشركين قد جحدوا أن يكون رسول الله ﷺ رأى ما أراه الله ليلة أُسري به وجادلوه في ذلك، فبأيَّتِهما قرأ القارئ فمصيبٌ».</p><p>و<span class="comment-type-4">ذهب</span> <u>ابنُ القيم</u> (٣/٧١) إلى أن القراءة الثانية أولى، فقال: «القوم جمعوا بين الجدال والدفع والإنكار، فكان جدالهم جدال جحود ودفع، لا جدال استرشاد وتبيّن للحق، وإثبات الألف يدل على المجادلة، والإتيان بـ<span class="qpc-hafs">﴿على﴾</span> يدل على المكابرة، فكانت قراءة الألف <span class="mustanad">منتظمة للمعنيين جميعًا</span>؛ فهي أولى».</div></p><p><h3><span class="qpc-hafs">﴿أَفَتُمَـٰرُونَهُۥ عَلَىٰ مَا یَرَىٰ ۝١٢﴾</span> - تفسير الآية</h3></p><p><div></p><p><p><span class="item-no">٧٣٢٧٣<span class="dash">-</span></span> عن <span class="name-2">إبراهيم النَّخْعي</span> -من طريق مُغيرة- أنه كان يقرأ: ‹أفَتَمْرُونَهُ›، وفسّرها: أفتجحدونه. وقال: مَن قرأ <span class="qpc-hafs">﴿أفَتُمارُونَهُ﴾</span> قال: أفتجادلونه{3}. (١٤/١٩)</p></p><p></div></p></div>",footnotes:1:عزاه السيوطي إلى عَبد بن حُمَيد.</p><p>وهي قراءة متواترة، قرأ بها حمزة، والكسائي، وخلف، ويعقوب، وقرأ بقية العشرة: <span class="qpc-hafs">﴿أفتُمارُونَهُ﴾</span> بالألف. انظر: النشر ٢/٣٧٩، والإتحاف ص٥٢١.|2:عزاه السيوطي إلى ابن المنذر.|3:أخرجه ابن جرير ٢٢/٢٧، وسعيد بن منصور -كما في التغليق ٤/٣٢٣، وفتح الباري ٨/٦٠٥-، وعبد بن حميد -كما في التغليق ٤/٣٢٣-. وعزاه السيوطي إلى ابن المنذر.|4:عزاه السيوطي إلى عَبد بن حُمَيد.|5:أخرجه ابن جرير ٢٢/٢٧، وسعيد بن منصور -كما في التغليق ٤/٣٢٣، وفتح الباري ٨/٦٠٥-، وعبد بن حميد -كما في التغليق ٤/٣٢٣-. وعزاه السيوطي إلى ابن المنذر.
  53,13,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَلَقَدۡ رَءَاهُ نَزۡلَةً أُخۡرَىٰ ۝١٣﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٣٢٧٤<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن مسعود</span> -من طريق مُرَّة- <span class="qpc-hafs">﴿ولَقَدْ رَآهُ نَزْلَةً أُخْرى﴾</span>، قال: رأى جبريلَ معلِّقًا رِجله بسِدرة، عليها الدّر، كأنه قطْر المطر على البقْل{1}. (١٤/٢٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٢٧٥<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن مسعود</span> -من طريق عبد الرحمن بن يزيد- <span class="qpc-hafs">﴿ولَقَدْ رَآهُ نَزْلَةً أُخْرى﴾</span>، قال: رأى جبريلَ في رَفْرف، قد ملأ ما بين السماء والأرض{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٢٧٦<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن مسعود</span> -من طريق أبي وائل- <span class="qpc-hafs">﴿ولَقَدْ رَآهُ نَزْلَةً أُخْرى عِنْدَ سِدْرَةِ المُنْتَهى﴾</span>، قال: رأى رسولُ الله ﷺ جبريلَ في صورته عند السِّدرة، له ستمائة جَناح، جَناح منها سَدّ الأُفق، يتناثر من أجنحته التَّهاوِيلُ{3} والدُّر والياقوت، ما لا يعلمه إلا الله{4}. (١٤/٢٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٢٧٧<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن مسعود</span> -من طريق عاصم عن زِرّ بن حُبَيْش- في هذه الآية: <span class="qpc-hafs">﴿ولقد رآه نزلة أخرى عند سدرة المنتهى﴾</span>، قال: قال رسول الله ﷺ: «<b>رأيت جبريل صلى الله عليه و سلم وله ستمائة جناح، ينتثر من ريشه التهاويل؛ الدر والياقوت</b>»{5}. (١٤/١٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٢٧٨<span class="dash">-</span></span> عن مسروق، أنّ <span class="name-1">عائشة</span> قالت: يا أبا عائشة، مَن زعم أنّ محمدًا رأى ربّه فقد أعظم الفِرية على الله. قال: وكنتُ متكئًا، فجلستُ، فقلتُ: يا أُمّ المؤمنين، أنظِريني ولا تعجليني، أرأيتِ قول الله: <span class="qpc-hafs">﴿ولَقَدْ رَآهُ نَزْلَةً أُخْرى﴾</span>، <span class="qpc-hafs">﴿ولَقَدْ رَآهُ بِالأُفُقِ المُبِينِ﴾</span>. قالت: إنّما هو جبريلُ، رآه مرةً على خلْقه وصورته التي خُلِق عليها، ورآه مرة أخرى حين هبط من السماء إلى الأرض سادًّا عِظم خلْقه ما بين السماء والأرض. قالت: أنا أول مَن سأل النبي ﷺ عن هذه الآية، قال: هو جبريل ﵇{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٢٧٩<span class="dash">-</span></span> عن <span class="name-1">أبي هريرة</span> -من طريق عطاء- في قوله: <span class="qpc-hafs">﴿ولَقَدْ رَآهُ نَزْلَةً أُخْرى﴾</span>، قال: رأى جبريل ﵇{7}. (١٤/٢٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٢٨٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق أبي سلمة- في قول الله: <span class="qpc-hafs">﴿ولَقَدْ رَآهُ نَزْلَةً أُخْرى﴾</span>، قال: قد رأى النبيُّ ﷺ ربَّه ﷿{8}. (١٤/٢٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٢٨١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عكرمة- أنه قال: <span class="qpc-hafs">﴿ولَقَدْ رَآهُ نَزْلَةً أُخْرى﴾</span>، قال: إنّ رسول الله ﷺ رأى ربَّه بقلبه. فقال له رجلٌ عند ذلك: أليس <span class="qpc-hafs">﴿لا تُدْرِكُهُ الأَبْصارُ وهُوَ يُدْرِكُ الأَبْصارَ﴾</span> [الأنعام:١٠٣]؟ قال له عكرمة: أليس ترى السماء؟ قال: بلى. أفكلّها ترى؟!{9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٢٨٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عكرمة- أنّه سُئِل: هل رأى محمدٌ ربَّه؟ قال: نعم، رآه كأنّ قدميه على خُضرة، دونه سِتر مِن لؤلؤ. فقلت: يا ابن عباس، أليس يقول الله: <span class="qpc-hafs">﴿لا تُدْرِكُهُ الأَبْصارُ﴾</span> [الأنعام:١٠٣]؟ قال: لا أُمَّ لك، ذاك نوره الذي هو نوره، إذا تجلّى بنوره لا يدركه شيء{10}. (١٤/٢٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٢٨٣<span class="dash">-</span></span> عن <span class="name-2">مُرّة الهمداني</span> -من طريق قيس بن وهب- قال: لم يأتِه جبريلُ في صورته إلا مرتين، فرآه في خَضِرٍ، يتعلّق به الدُّر{11}. (١٤/٢٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٢٨٤<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق سلمة بن كهيل- <span class="qpc-hafs">﴿ولَقَدْ رَآهُ نَزْلَةً أُخْرى﴾</span>، قال: رأى جبريلَ في صورته مرتين{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٢٨٥<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span>، في قوله: <span class="qpc-hafs">﴿ولَقَدْ رَآهُ نَزْلَةً أُخْرى﴾</span>، قال: رأى نورًا عظيمًا عند سِدْرة المنتهى{13}. (١٤/٢٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٢٨٦<span class="dash">-</span></span> عن <span class="name-2">الربيع بن أنس</span> -من طريق أبي جعفر- <span class="qpc-hafs">﴿ولَقَدْ رَآهُ نَزْلَةً أُخْرى﴾</span>، قال: جبريل{14}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٢٨٧<span class="dash">-</span></span> عن <span class="name-3">العَوّام بن حَوْشَب</span> -من طريق هشيم- في قوله: <span class="qpc-hafs">﴿ولَقَدْ رَآَهُ نَزْلَةً أُخْرى﴾</span>، قال: رآه بقلبه، ولم يره ببصره{15}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٢٨٨<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>:<span class="qpc-hafs">﴿أفَتُمارُونَهُ عَلى ما يَرى ولَقَدْ رَآهُ نَزْلَةً أُخْرى﴾</span>، يقول: رأى محمدٌ ﷺ ربَّه بقلبه مرة أخرى{16}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ٢٢/٣٠، وأبو الشيخ (٣٥٠). وعزاه السيوطي إلى ابن مردويه.|2:أخرجه ابن جرير ٢٢/٣٠.|3:التَّهاوِيل: الأشياء المختلفة الألوان، وأراد بالتَّهاوِيل: تزايين ريشه، وما فيه من صفرة وحمرة وبياض وخضرة مثل تهاويل الرِّياض. النهاية، لسان العرب (هول).|4:أخرجه أبو الشيخ في العظمة (٣٥٧).|5:أخرجه آدم بن أبي إياس -كما في تفسير مجاهد ص٦٢٦-، وأحمد ٧/٤٠٤ (٤٣٩٦) واللفظ له، وابن جرير ٢٢/٢٥، من طريق حماد بن سلمة، عن عاصم بن بهدلة، عن زر، عن ابن مسعود به.</p><p>قال ابن كثير في تفسيره ٧/٤٥١ معلقًا على رواية أحمد: «وهذا إسناد جيد قوي». وقال الألباني في الصحيحة ٧/١٤١٥: «وهذا إسناد جيد قوي، كما قال ابن كثير».|6:أخرجه البخاري ٤/١١٥-١١٦ (٣٢٣٥)، ٦/١٤٠-١٤١ (٤٨٥٥)، ٩/١١٦ (٧٣٨٠)، ومسلم ١/١٥٩ (١٧٧) واللفظ له، وابن جرير ٢٢/٢٨-٣٠، والثعلبي ٩/١٤٢.|7:أخرجه مسلم (١٧٥)، والبيهقي ٢/٣٧١.|8:أخرجه الترمذي (٣٢٨٠)، والطبراني (١٠٧٢٧)، والبيهقي (٩٣٣). وعزاه السيوطي إلى ابن مردويه.|9:أخرجه ابن جرير ٢٢/٣٢.|10:أخرجه البيهقي (٩٣٥).|11:أخرجه آدم بن أبي إياس -كما في تفسير مجاهد ص٦٢٦-، وابن جرير ٢٢/٣٠ بنحوه، والبيهقي في التوحيد ص٨٩٦. وعزاه السيوطي إلى عَبد بن حُمَيد.|12:أخرجه ابن جرير ٢٢/٣٠.|13:عزاه السيوطي إلى عَبد بن حُمَيد.|14:أخرجه ابن جرير ٢٢/٣١.|15:ذيل صحيح ابن خزيمة (٢٣٥) رقم (٢٣٤/٣٣١٣). وعزاه إلى إتحاف المهرة لابن حجر ١٨/٤٢٨ (٢٣٨٨٢) مع أن ابن حجر عزاه لكتاب التوحيد لابن خزيمة.|16:تفسير مقاتل بن سليمان ٤/١٦٠
  53,14,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿عِندَ سِدۡرَةِ ٱلۡمُنتَهَىٰ ۝١٤﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٣٢٨٩<span class="dash">-</span></span> عن أنس بن مالك، في قوله تعالى: <span class="qpc-hafs">﴿عِنْدَ سِدْرَةِ المُنْتَهى﴾</span>، أنّ النبي ﷺ قال: «<b>رُفِعَتْ لي سِدرة منتهاها في السماء السابعة، نَبْقها مثل قِلال هَجَر، وورقها مثل آذان الفِيَلة، يخرج مِن ساقها نهران ظاهران، ونهران باطنان، قال: قلتُ: يا جبريل، ما هذان؟ قال: أمّا الباطنان ففي الجنة، وأما النهران الظاهران فالنيل والفُرات</b>»{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٢٩٠<span class="dash">-</span></span> عن أسماء بنت أبي بكر: سمعتُ النبيَّ ﷺ يَصِفُ سِدْرَة المنتهى، قال: «<b>يسير الراكب في الفَنَن منها مائةَ سنة، يستظلّ بالفَنَن منها مائةُ راكب، فيها فَراش مِن ذهب، كأنّ ثمرها القِلال</b>»{2}. (١٤/٢٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٢٩١<span class="dash">-</span></span> عن أبي جعفر الرازي، عن الربيع بن أنس، عن أبي العالية، عن أبي هريرة -أو غيره؛ شكّ أبو جعفر الرازي-، قال: لَمّا أُسري بالنبي ﷺ انتهى إلى السِّدرة، فقيل له: هذه السِّدرة، ينتهي إليها كلُّ أحد خلا مِن أُمّتك على سُنتك{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٢٩٢<span class="dash">-</span></span> عن مالك بن صعصعة، قال: قال نبي الله ﷺ: «<b>لما انتهيتُ إلى السماء السابعة أتيتُ على إبراهيم، فقلتُ: يا جبريل، مَن هذا؟ قال: هذا أبوك إبراهيم. فسلّمتُ عليه، فقال: مرحبًا بالابن الصالح والنبي الصالح. قال: ثم رُفِعَت لي سِدرةُ المنتهى</b>». فحدّث نبيُّ الله: أنّ نبْقها مثل قِلال هَجَر، وأنّ ورقها مثل آذان الفِيَلة{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٢٩٣<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن مسعود</span> -من طريق مُرة- قال: لَمّا أُسري برسول الله ﷺ انتُهي به إلى سِدرة المنتهى، وهي في السماء السادسة، إليها ينتهي ما يعرج من الأرواح، فيُقبض منها، وإليها ينتهي ما يهبط به من فوقها، فيُقبض منها{5}. (١٤/٢٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٢٩٤<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن مسعود</span> -من طريق الهُذيل بن شرحبيل- في قوله: <span class="qpc-hafs">﴿عِنْدَ سِدْرَةِ المُنْتَهى﴾</span>، قال: صُبْر الجنة -يعني: وسطها-، جُعِل عليها فُضول السُّندس والإستبرق{6}. (١٤/٢٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٢٩٥<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، أنّه سُئل عن سِدرة المنتهى. قال: إليها ينتهي عِلْمُ كلِّ عالم، وما وراءها لا يعلمه إلا الله{7}. (١٤/٢٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٢٩٦<span class="dash">-</span></span> عن ابن عباس -من طريق خالد بن عرعرة- أنّه سأل <span class="name-2">كعب الأحبار</span> عن قوله: <span class="qpc-hafs">﴿عِنْدَ سِدْرَةِ المُنْتَهى﴾</span>. فقال: هي سدرةٌ نابتة في السماء السابعة، ثم عَلَتْ، فانتهى عِلْمُ الخلائق إلى ما دونها. و<span class="qpc-hafs">﴿عِنْدَها جَنَّةُ المَأْوى﴾</span>، قال: جنة الشهداء{8}. (١٥/٣٠٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٢٩٧<span class="dash">-</span></span> عن ابن عباس -من طريق عكرمة- قال: سألتُ <span class="name-2">كعبًا</span>: ما سِدرة المنتهى؟ قال: سِدرة ينتهي إليها علم الملائكة، وعندها يجدون أمرَ الله، لا يجاوزها عِلم. وسألتُه عن جنة المأوى، فقال: جنة فيها طير خُضر، ترتقي فيها أرواح الشهداء{9}. (١٤/٢٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٢٩٨<span class="dash">-</span></span> عن شِمْر، قال: جاء ابنُ عباس إلى <span class="name-2">كعب</span>، فقال: حدِّثني عن سِدرة المنتهى. قال: إنها سِدرة في أصل العرش، إليها ينتهي عِلم كل عالم؛ ملَك مقرّب أو نبي مُرسل، ما خلفها غيبٌ، لا يعلمه إلا الله{10}. (١٤/٢٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٢٩٩<span class="dash">-</span></span> قال ابن عباس: <span class="qpc-hafs">﴿عِنْدَ سِدْرَةِ المُنْتَهى﴾</span> سألتُ <span class="name-2">كعبًا</span> عن سِدرة المنتهى. فقال: يُنتهى إليها بأرواح المؤمنين إذا ماتوا، لا يُجاوزها روحُ مؤمن؛ فإذا قُبِض المؤمن تبعه مُقَرَّبو أهلِ السماوات، حتى يُنتهى به إلى السّدرة، فيُوضع، ثم تصفُّ الملائكةُ المقرّبون، فيُصلّون عليه كما تُصلّون على موتاكم أنتم هاهنا، فذلك قوله: <span class="qpc-hafs">﴿سِدْرَةِ المُنْتَهى﴾</span>{11}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٣٠٠<span class="dash">-</span></span> عن <span class="name-2">كعب الأحبار</span> -من طريق عمرو بن مُرة- قال: سِدرة المنتهى ينتهي إليها أمرُ كل نبي ومَلك{12}. (١٤/٢٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٣٠١<span class="dash">-</span></span> عن <span class="name-2">كعب الأحبار</span> -من طريق هلال بن يِساف- قال: إنّها سِدرة على رؤوس حملة العرش، إليها ينتهي عِلم الخلائق، ثم ليس لأحد وراءها عِلم، فلذلك سُمّيت: سِدرة المنتهى؛ لانتهاء العلم إليها{13}. (١٤/٢٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٣٠٢<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ليث- في قوله: <span class="qpc-hafs">﴿سِدْرَةِ المُنْتَهى﴾</span>، قال: أول يوم من الآخرة وآخر يوم من الدنيا، فهو حيث ينتهي{14}. (١٤/٢٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٣٠٣<span class="dash">-</span></span> عن <span class="name-2">الضَّحّاك بن مُزاحِم</span> -من طريق يعلى- أنّه قيل له: لِمَ تُسمّى: سِدرة المنتهى؟ قال: لأنه ينتهي إليها كلُّ شيء مِن أمرِ الله، لا يعدوها{15}. (١٤/٢٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٣٠٤<span class="dash">-</span></span> عن <span class="name-2">الربيع بن أنس</span> -من طريق أبي جعفر- <span class="qpc-hafs">﴿عِنْدَ سِدْرَةِ المُنْتَهى﴾</span>، قال: إليها ينتهي كلُّ أحد خلا على سُنّة أحمد، فلذلك سُمّيت: المنتهى{16}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٣٠٥<span class="dash">-</span></span> عن <span class="name-2">الربيع بن أنس</span> -من طريق أبي جعفر- <span class="qpc-hafs">﴿سِدْرَةِ المُنْتَهى﴾</span>، قال: السّدرة: شجرة يسير الرّاكب في ظِلّها مائة عام لا يقطعها، وإنّ ورقة منها غَشَتِ الأُمّة كلها{17}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٣٠٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿عِنْدَ سِدْرَةِ المُنْتَهى﴾</span> أغصانها اللؤلؤ والياقوت والزَّبَرْجد، وهي شجرة عن يمين العرش فوق السماء السابعة العليا ... وإنما سُمّيت: المنتهى؛ لأنها ينتهي إليها عِلْمُ كلِّ مَلك مخلوق، ولا يعلم ما وراءها أحدٌ إلا الله ﷿، كلّ ورقة منها تُظِلُّ أُمّةً مِن الأمم، على كلّ ورقة منها مَلَك يذكرُ الله ﷿، ولو أنّ ورقة منها وُضِعَت في الأرض لأضاءت لأهل الأرض نورًا، تحمل لهم الحُلل والثمار من جميع الألوان، ولو أنّ رجلًا ركب حِقَّةً فطاف على ساقها ما بلغ المكان الذي ركب منه حتى يقتله الهَرَم، وهي طوبى التي ذكر الله تعالى في كتابه: <span class="qpc-hafs">﴿طُوبى لَهُمْ وحُسْنُ مَآبٍ﴾</span> [الرعد:٢٩]، ينبع مِن ساق السّدرة عينان؛ أحدهما السلسبيل، والأخرى الكوثر، فينفجر من الكوثر أربعة أنهار، التي ذكر الله تعالى في سورة محمد ﷺ؛ الماء، واللبن، والعسل، والخمر{18}<span class=comment-ref>٦٢٧٦</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٢٧٦</span> اختُلِف في سبب تسمية «سدرة المنتهى» بهذا الاسم على أقوال: <b>الأول:</b> لأنه ينتهي إليها علمُ كل عالم. <b>الثاني:</b> لانتهاء ما يَهبِط من فوقها ويَصْعَدُ من تحتها من أمر الله إليها. <b>الثالث:</b> لأنه إليها ينتهي كل مَن كان على سُنَّة رسول الله ﷺ ومنهاجه.</p><p>و<span class="comment-type-4">علَّق</span> <u>ابنُ عطية</u> (٨/١١٣) على القول الثالث بقوله: «وهم المؤمنون حقًّا مِن كلّ جيل».</p><p>و<span class="comment-type-3">رجَّح</span> <u>ابنُ جرير</u> (٢٢/٣٥) جواز كلّ الأقوال دون القطع بقول منها <span class="mustanad">لصحتها، وعدم دليل التعيين لواحد منها</span>، فقال: «وجائزٌ أن يكون قيل لها: سدرة المنتهى؛ لانتهاء عِلْمِ كلِّ عالمٍ من الخَلْقِ إليها، كما قال كعب، وجائزٌ أن يكون قيل لها ذلك لانتهاء ما يصعد من تحتها وينزل من فوقها إليها، كما رُوي عن عبد الله، وجائزٌ أن يكون قيل ذلك كذلك لانتهاء كلِّ مَن خلا من الناس على سُنَّة رسول الله ﷺ إليها، وجائزٌ أن يكون قيل لها ذلك لجميع ذلك، ولا خبر يقطع العذر بأنه قيل ذلك لها لبعض ذلك دون بعض، فلا قول فيه أصحُّ من القول الذي قال ربُّنا -جلَّ ثناؤه-، وهو أنها سدرة المنتهى».</div></p></div>",footnotes:1:أخرجه أحمد ٢٠/١٠٧ (١٢٦٧٣)، والحاكم ١/١٥٤ (٢٧١، ٢٧٢) واللفظ له، وآدم بن أبي إياس -كما في تفسير مجاهد ص٦٢٦-٦٢٧-، وعبد الرزاق ٣/٢٥٠ (٣٠٣١). وأصله في البخاري ٧/١٠٩ (٥٦١٠)، ومسلم ١/١٤٩ (١٦٤) مطولًا، كلاهما دون ذكر الآية.</p><p>قال الحاكم: «هذا حديث صحيح، على شرط الشيخين، ولم يخرجاه بهذه السياقة». ووافقه الذهبي في التلخيص. وقال الألباني في الصحيحة ١/٢٢٨ (١١٢): «وهذا سند صحيح، على شرط الشيخين».|2:أخرجه الترمذي ٤/٥٠٧ (٢٧١٦)، والحاكم ٢/٥١٠ (٣٧٤٨)، وابن جرير ٢٢/٣٨-٣٩، والثعلبي ٩/١٤٣، من طريق يونس بن بكير، عن محمد بن إسحاق، عن يحيى بن عباد بن عبد الله بن الزبير، عن أبيه، عن أسماء بنت أبي بكر به.</p><p>قال الترمذي: «هذا حديث حسن صحيح غريب». وقال الحاكم: «هذا حديث صحيح، على شرط مسلم، ولم يخرجاه». ووافقه الذهبي في التلخيص.|3:أخرجه ابن جرير ٢٢/٣٥. وسيأتي بتمامه مع تخريجه عند تفسير قوله تعالى: <span class="qpc-hafs">﴿إذْ يَغْشى السِّدْرَةَ ما يَغْشى﴾</span>.|4:أخرجه أحمد ٢٩/٣٧٣-٣٧٤ (١٧٨٣٤)، وابن حبان ١/٢٣٦-٢٣٩ (٤٨) مطولًا، ويحيى بن سلام ١/١٠١، وابن جرير ٢٢/٣٦ واللفظ له، من طريق قتادة، عن أنس بن مالك، عن مالك بن صعصعة به.</p><p>وسنده صحيح، وقد صححه ابن حبان.|5:أخرجه أحمد ٦/١٨١ (٣٦٦٥)، ومسلم (١٧٣)، والترمذي (٣٢٧٦)، وابن جرير ٢٢/٣٤، ٤١، والبيهقي ٢/٣٧٢-٣٧٣. وعزاه السيوطي إلى عبد بن حميد، وابن مردويه.|6:أخرجه ابن أبي شيبة ١٣/٩٧، وابن جرير ٢٢/٣٨، والطبراني (٩٠٥٦). وعزاه السيوطي إلى الفريابي.|7:عزاه السيوطي إلى عبد بن حميد، وابن أبي حاتم.|8:عزاه السيوطي إلى عبد بن حميد.|9:أخرجه ابن أبي شيبة ١٣/١٥٠.|10:أخرجه ابن جرير ٢٢/٣٣.|11:ذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٤/٣٠٦-.|12:أخرجه ابن أبي شيبة ١٤/٣٠٩.|13:أخرجه ابن جرير ٢٢/٣٣ بنحوه.|14:أخرجه ابن أبي شيبة ١٤/١٠١.|15:أخرجه ابن جرير ٢٢/٣٤، وابن أبي شيبة ١٣/٤٢٦. وعزاه السيوطي إلى عبد بن حميد.|16:أخرجه ابن جرير ٢٢/٣٤.|17:أخرجه ابن جرير ٢٢/٣٩.|18:تفسير مقاتل بن سليمان ٤/١٦٠.
  53,15,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿عِندَهَا جَنَّةُ ٱلۡمَأۡوَىٰۤ ۝١٥﴾</span> - قراءات</h3></p><p><div></p><p><p><span class="item-no">٧٣٣٠٧<span class="dash">-</span></span> عن <span class="name-1">علي بن أبي طالب</span> أنه قرأ: <span class="qpc-hafs">﴿جَنَّةُ المَأْوى﴾</span>{1}. (١٤/٢٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٣٠٨<span class="dash">-</span></span> عن حُصين، قال: قيل ل<span class="name-1">سعد بن مالك</span>: إنّ بعض الناس يقرأ: (عِندَها جَنَّهُ المَأْوى). فقال: أجَنَّه اللهُ{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٣٠٩<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، أنه قرأ: <span class="qpc-hafs">﴿عِندَها جَنَّةُ المَأْوى﴾</span>، وعاب على مَن قرأ: (جَنَّهُ المَأْوى){3}. (١٤/٢٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٣١٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن الزبير</span>، قال: مَن قرأ: (جَنَّهُ المَأْوى) فأجنَّه الله، إنما هي: <span class="qpc-hafs">﴿جَنَّةُ المَأْوى﴾</span>{4}. (١٤/٢٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٣١١<span class="dash">-</span></span> عن شَريك بن عبد الله بن أبي نمر، قال: سمعتُ <span class="name-1">أنس بن مالك</span> يقرأ: <span class="qpc-hafs">﴿عِندَها جَنَّةُ المَأْوى﴾</span> في حديث النبي ﷺ حين عُرج به، فقلتُ: إنّ ناسًا يقرؤون: (جَنَّهُ المَأْوى). قال: مَن قرأ: (جَنَّهُ المَأْوى) أجنَّه الشيطان{5}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿عِندَهَا جَنَّةُ ٱلۡمَأۡوَىٰۤ ۝١٥﴾</span> - تفسير الآية</h3></p><p><div></p><p><p><span class="item-no">٧٣٣١٢<span class="dash">-</span></span> عن <span class="name-1">علي بن أبي طالب</span> أنّه قرأ: <span class="qpc-hafs">﴿جَنَّةُ المَأْوى﴾</span>، قال: جنة المَبِيت{6}. (١٤/٢٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٣١٣<span class="dash">-</span></span> عن <span class="name-1">عائشة</span> -من طريق ابن أبي مُلَيْكَة- أنها قالت: جَنَّةٌ من الجنان{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٣١٤<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطية- <span class="qpc-hafs">﴿عِنْدَها جَنَّةُ المَأْوى﴾</span>، قال: هي عن يمين العرش، وهي منزل الشهداء{8}. (١٤/٢٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٣١٥<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق أبي العالية- <span class="qpc-hafs">﴿عِنْدَها جَنَّةُ المَأْوى﴾</span> قال: هو كقوله: <span class="qpc-hafs">﴿فَلَهُمْ جَنّاتُ المَأْوى نُزُلًا بِما كانُوا يَعْمَلُونَ﴾</span> [السجدة:١٩]{9}<span class=comment-ref>٦٢٧٧</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٢٧٧</span> لم يذكر <u>ابنُ جرير</u> (٢٢/٤٠) في معنى: <span class="qpc-hafs">﴿عِنْدَها جَنَّةُ المَأْوى﴾</span> سوى قول ابن عباس من طريق عطية، وأبي العالية، وقول قتادة.</p><p>ونقل <u>ابنُ عطية</u> (٨/١١٤) قول ابن عباس وقتادة أن المعنى: «هي جنة يأوي إليها أرواح الشهداء والمؤمنين، وليست بالجنة التي وُعد بها المؤمنون جنة النعيم». ثم <span class="comment-type-2">انتقده</span> -<span class="mustanad">مستندًا إلى عدم ثبوته</span>- قائلًا: «وهذا يحتاج إلى سند، وما أراه يصح عن ابن عباس ﵄». ثم نقل عن الحسن قوله: «هي الجنة التي وُعِد بها المؤمن العالم».</p><p>و<span class="comment-type-3">رجَّح</span> <u>ابنُ القيم</u> (٣/٧٥) -<span class="mustanad">مستندًا إلى النظائر-</span> أن <span class="qpc-hafs">﴿المأوى﴾</span> اسم مِن أسماء الجنة، فقال: «والصحيح: أنه اسم من أسماء الجنة، كما قال تعالى: <span class="qpc-hafs">﴿وأَمّا مَن خافَ مَقامَ رَبِّهِ ونَهى النَّفْسَ عَنِ الهَوى * فَإنَّ الجَنَّةَ هِيَ المَأْوى﴾</span> [النازعات:٤٠-٤١]».</div></p><p><div></p><p><p><span class="item-no">٧٣٣١٦<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>: <span class="qpc-hafs">﴿عِنْدَها جَنَّةُ المَأْوى﴾</span> جنّةٌ يأوي إليها جبريلُ والملائكةُ{10}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٣١٧<span class="dash">-</span></span> عن ابن عباس، أنّه سأل <span class="name-2">كعب الأحبار</span> عن جنة المأوى. فقال: جنةٌ فيها طير خُضر، ترتقي فيها أرواح الشهداء{11}. (١٤/٢٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٣١٨<span class="dash">-</span></span> عن أبي إسحاق الشيباني، قال: سُئل <span class="name-2">زِرّ بن حُبَيْش</span> وأنا أسمع: <span class="qpc-hafs">﴿عندها جَنَّةُ المأوى﴾</span>، أو (جَنَّةُ{12} المَأْوى)، فقال: جنَّة مِن الجنان{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٣١٩<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- في قوله تعالى: <span class="qpc-hafs">﴿جَنَّةُ المَأْوى﴾</span>، قال: منازل الشهداء{14}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٣٢٠<span class="dash">-</span></span> قال <span class="name-3">محمد بن السّائِب الكلبي</span>: <span class="qpc-hafs">﴿عِنْدَها جَنَّةُ المَأْوى﴾</span> يأوي إليها أرواح الشهداء{10}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٣٢١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿عِنْدَها جَنَّةُ المَأْوى﴾</span> تأوي إليها أرواحُ الشهداء، أحياء يُرزقون{16}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿عِندَهَا جَنَّةُ ٱلۡمَأۡوَىٰۤ ۝١٥﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٧٣٣٢٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن مسعود</span> -من طريق أبي الزعراء- قال: الجنة في السماء السابعة العليا، والنار في الأرض السابعة السفلى{17}. (١٤/٢٨)</p></p><p></div></p></div>",footnotes:1:عزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.</p><p>و<span class="qpc-hafs">﴿جَنَّةُ﴾</span> بالتاء قراءة العشرة.|2:أخرجه سعيد بن منصور في سننه -التفسير ٧/٤٥٠-٤٥١ (٢٠٧٨).</p><p>وهي قراءة شاذة. انظر: المحتسب ٢/٢٩٣.|3:عزاه السيوطي إلى عبد بن حميد، وابن جرير، وابن المنذر.|4:عزه السيوطي إلى عبد بن حميد.|5:أخرجه سعيد بن منصور في سننه -التفسير ٧/٤٥٢ (٢٠٨٠).|6:عزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.|7:أخرجه الفراء في معاني القرآن ٣/٩٧.|8:أخرجه ابن جرير ٢٢/٤٠. وعزاه السيوطي إلى ابن أبي حاتم.|9:أخرجه ابن جرير ٢٢/٤٠|10:تفسير البغوي ٧/٤٠٦.|11:أخرجه ابن أبي شيبة ١٣/١٥٠.|12:كذا ضبطت في المصدر، ولعلها: «جنَّه» كما في القراءة الشاذة.|13:أخرجه الفراء في معاني القرآن ٣/٩٧.|14:أخرجه عبد الرزاق ٢/٢٥٣، وابن جرير ٢٢/٤٠.|15:تفسير البغوي ٧/٤٠٦.|16:تفسير مقاتل بن سليمان ٤/١٦٠-١٦١.|17:أخرجه أبو الشيخ (٦٠٢).
  53,16,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿إِذۡ یَغۡشَى ٱلسِّدۡرَةَ مَا یَغۡشَىٰ ۝١٦﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٣٣٢٣<span class="dash">-</span></span> عن عبد الله بن عباس، <span class="qpc-hafs">﴿إذْ يَغْشى السِّدْرَةَ ما يَغْشى﴾</span>، قال رسول الله ﷺ: «<b>رأيتُها حتى استَثْبَتُّها، ثم حال دونها فَراش الذهب</b>»{1}. (١٤/٢٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٣٢٤<span class="dash">-</span></span> عن أنس، عن النبيِّ ﷺ، في قوله: <span class="qpc-hafs">﴿إذْ يَغْشى السِّدْرَةَ ما يَغْشى﴾</span>، قال: رآها ليلةَ أُسري به، يلوذ بها جَرادٌ مِن ذهب{2}. (١٤/٢٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٣٢٥<span class="dash">-</span></span> عن يعقوب بن زيد، قال: سُئل رسول الله ﷺ: ما رأيت يغشى السدرة؟ قال: «<b>رأيتها يغشاها فراشٌ من ذهب</b>»{3}. (١٤/٢٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٣٢٦<span class="dash">-</span></span> عن أنس بن مالك، أنّ رسول الله ﷺ قال: «<b>ركبتُ البراق، ثم ذهب بي إلى سِدرة المنتهى، فإذا ورقها كآذان الفِيَلة، وإذا ثمرها كالقِلال</b>». قال: «<b>فلما غَشِيها من أمر الله ما غَشِيها تغيّرت، فما أحد يستطيع أن يصفها من حُسنها</b>». قال: «<b>فأوحى الله إليّ ما أوحى</b>»{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٣٢٧<span class="dash">-</span></span> عن أنس بن مالك، قال: قال رسول الله ﷺ: «<b>لَمّا انتهيتُ إلى السدرة إذا ورقُها مثل آذان الفِيَلة، وإذا نبْقها أمثال القِلال، فلمّا غَشِيها مِن أمر الله ما غَشِي تحوّلت</b>». فذكر الياقوت{5}. (١٤/٢٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٣٢٨<span class="dash">-</span></span> عن أنس بن مالك، قال: قال رسول الله ﷺ: «<b>انتهيتُ إلى السِّدرة، فإذا نبْقُها مثل الجِرار، وإذا ورقها مثل آذان الفِيَلة، فلما غَشِيها مِن أمر الله ما غَشِيها تحوّلتْ ياقوتًا وزُمُرّدًا، ونحو ذلك</b>»{6}. (١٤/٢٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٣٢٩<span class="dash">-</span></span> عن أبي جعفر الرازي، عن الربيع بن أنس، عن أبي العالية أو غيره، عن أبي هريرة: أنّ رسول الله ﷺ أُتي بفرسٍ، فجعل كل خطوة منه أقصى بصره، فسار وسار معه جبريل ﵇، ... إلى أن قال: ثم مضى إلى السّدرة، فقيل له: هذه السّدرة المنتهى، ينتهي كلُّ أحد مِن أُمّتك خلا على سبيلك، وهي السّدرة المنتهى، تخرج مِن أصلها أنهارٌ مِن ماء غير آسِن، وأنهار مِن لبنٍ لم يتغيّر طعمه، وأنهار مِن خمرٍ لذّة للشاربين، وأنهار من عسل مُصفّى، وهي شجرة يسير الراكب في ظِلّها سبعين عامًا، وإنّ ورقةً منها مُظلّة الخَلْق، فغشيها نور وغشيها الملائكة. قال <span class="name-3">عيسى</span> -يعني: <span class="name-3">أبا جعفر الرازي</span>-: فذلك قوله: <span class="qpc-hafs">﴿إذْ يَغْشى السِّدْرَةَ ما يَغْشى﴾</span> ...، وفي لفظ عند ابن جرير: فغَشيها نور الخلاّق، وغَشِيتها الملائكة أمثال الغربان حين يَقَعْنَ على الشجر{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٣٣٠<span class="dash">-</span></span> عن عبد الرحمن بن زيد بن أسلم، في قوله: <span class="qpc-hafs">﴿إذْ يَغْشى السِّدْرَةَ ما يَغْشى﴾</span>، قال: قيل له: يا رسول الله، أيُّ شيء رأيتَ يغشى تلك السّدرة؟ قال: «<b>رأيتُها يغشاها فَراشٌ مِن ذهب، ورأيتُ على كل ورقة مِن ورقها مَلَكًا قائمًا يسبّح الله</b>»{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٣٣١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن مسعود</span> -من طريق مُرة- قال: <span class="qpc-hafs">﴿إذْ يَغْشى السِّدْرَةَ ما يَغْشى﴾</span>، قال: فَراشٌ من ذهب. قال: وأُعطي رسولُ الله ﷺ ثلاثًا؛ أُعطي الصلوات الخمس، وأُعطي خواتيم سورة البقرة، وغُفِر لِمَن لا يشرك بالله شيئًا مِن أُمّته المُقحِمات{9}{10}. (٩/٢١٦، ١٤/٢٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٣٣٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، <span class="qpc-hafs">﴿إذْ يَغْشى السِّدْرَةَ ما يَغْشى﴾</span>، قال: الملائكة{11}. (١٤/٢٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٣٣٣<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطية- قوله: <span class="qpc-hafs">﴿إذْ يَغْشى السِّدْرَةَ ما يَغْشى﴾</span>، قال: غَشِيها اللهُ، فرأى محمدٌ مِن آيات ربّه الكبرى{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٣٣٤<span class="dash">-</span></span> عن <span class="name-2">مصرِّف بن عمرو</span> -من طريق ابنه طلحة بن مصرِّف- قال: <span class="qpc-hafs">﴿إذ يغشى السدرة ما يغشى﴾</span>، قال: فَراشٌ مِن الذَّهب{13}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٣٣٥<span class="dash">-</span></span> عن <span class="name-2">مَسروق بن الأجْدع الهَمَداني</span> -من طريق مسلم- في قوله: <span class="qpc-hafs">﴿إذْ يَغْشى السِّدْرَةَ ما يَغْشى﴾</span>، قال: غَشِيها فَراشٌ مِن ذهب{14}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٣٣٦<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٣٣٧<span class="dash">-</span></span> و<span class="name-2">إبراهيم النَّخْعي</span> -من طريق مُغيرة- في قوله: <span class="qpc-hafs">﴿إذْ يَغْشى السِّدْرَةَ ما يَغْشى﴾</span>، قال: غَشِيها فَراشٌ مِن ذهب{14}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٣٣٨<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- <span class="qpc-hafs">﴿إذْ يَغْشى السِّدْرَةَ ما يَغْشى﴾</span>، قال: كان أغصان السِّدرة مِن لؤلؤ وياقوت وزَبَرْجَد، فرآها محمدٌ ﷺ بقلبه، ورأى ربَّه{16}<span class=comment-ref>٦٢٧٨</span>. (١٤/٢٨)</p></p><p></div></p><p><div><span class=comment-ref>٦٢٧٨</span> ذكر <u>ابنُ عطية</u> (٨/١١٤) قول مجاهد من طريق ابن أبي نجيح، وقول ابن مسعود وما في معناه، وقول أبي هريرة ﵄ وما في معناه، ثم <span class="comment-type-2">انتقدها</span> <span class="mustanad">-مستندًا إلى دلالة السنة</span>- قائلًا: «وقيل غير هذا مما هو تكلُّف في الآية؛ لأنّ الله تعالى أبهم ذلك، وهم يريدون شرحه، وقد قال رسول الله ﷺ: «<b>فغشيها ألوان لا أدري ما هي؟</b>»».</div></p><p><div></p><p><p><span class="item-no">٧٣٣٣٩<span class="dash">-</span></span> قال <span class="name-2">الحسن البصري</span>: <span class="qpc-hafs">﴿إذْ يَغْشى السِّدْرَةَ ما يَغْشى﴾</span> غَشِيها نورُ ربّ العزّة فاستنارت{17}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٣٤٠<span class="dash">-</span></span> قال <span class="name-2">إسماعيل السُّدِّيّ</span>: <span class="qpc-hafs">﴿إذْ يَغْشى السِّدْرَةَ ما يَغْشى﴾</span> مِن الطيور فوقها{18}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٣٤١<span class="dash">-</span></span> عن <span class="name-2">الربيع بن أنس</span> -من طريق أبي جعفر- <span class="qpc-hafs">﴿إذْ يَغْشى السِّدْرَةَ ما يَغْشى﴾</span>، قال: غَشِيها نورُ الربّ، وغَشِيتها الملائكةُ مِن حُبّ الله مثل الغِربان حين يقعن على الشجر{19}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٣٤٢<span class="dash">-</span></span> عن <span class="name-3">سلمة بن وهْرام</span>، <span class="qpc-hafs">﴿إذْ يَغْشى السِّدْرَةَ ما يَغْشى﴾</span>، قال: استَأذَنت الملائكة الرّبّ -تبارك وتعالى- أن ينظروا إلى النبيِّ ﷺ، فأَذِن لهم، فغَشِيت الملائكةُ السِّدرة لينظروا إلى النبيِّ ﷺ{20}. (١٤/٢٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٣٤٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل</span>: <span class="qpc-hafs">﴿إذْ يَغْشى السِّدْرَةَ ما يَغْشى﴾</span> تغشاها الملائكة أمثال الغربان{21}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه أبو يعلى في مسنده ٥/٦٣ (٢٦٥٦)، وابن جرير ٢٢/٤١، من طريق جويبر، عن الضَّحّاك، عن ابن عباس به.</p><p>قال الهيثمي في المجمع ٧/١١٤ (١١٣٧٣): «فيه جويبر، وهو ضعيف».|2:أخرجه الطبراني في مسند الشاميين ٤/٨٩ (٢٨١٢)، من طريق سعيد بن بشير، عن يزيد بن أبي مالك، عن أنس بن مالك به.</p><p>وسنده ضعيف؛ فيه سعيد بن بشير الأزدي، قال عنه ابن حجر في تقريب التهذيب (٢٢٧٦): «ضعيف».|3:أخرجه ابن جرير ٢٢/٤٢. وعزاه السيوطي إلى عبد بن حميد بلفظ: سئل النبي ﷺ: ما رأيت بفناء السِّدرة؟ قال: «فَراشًا من ذهب».|4:أخرجه مسلم ١/١٤٥-١٤٦ (١٦٢) مطولًا، وابن جرير ٢٢/٣٧ واللفظ له.|5:أخرجه ابن أبي شيبة في مصنفه ٦/٣١٥ (٣١٧١٧)، ٧/٢٩ (٣٣٩٦٥)، ٧/٣٣٦ (٣٦٥٧٨)، وابن أبي عاصم في السنة ١/٢٦٢ (٥٩١)، من طريق أبي خالد الأحمر، عن حميد، عن أنس به.</p><p>وسنده حسن.|6:أخرجه أحمد ١٩/٣١٣-٣١٤ (١٢٣٠١)، وابن جرير ٢٢/٣٦ واللفظ له، من طريق محمد بن أبي عدي، عن حميد، عن أنس به.</p><p>وسنده صحيح.|7:أخرجه البزار ١٧/٥-١٢ (٩٥١٨) مطولًا واللفظ له، وابن جرير ١٤/٤٢٤، ٢٢/٤٣، وابن أبي حاتم -كما في تفسير ابن كثير ٥/٣٨- جميعهم مطولًا، من طريق أبي جعفر الرازي، عن الربيع بن أنس، عن أبي العالية الرياحي، عن أبي هريرة به.</p><p>قال الذهبي في سير أعلام النبلاء ١/٢٢٧: «تفرَّد به أبو جعفر الرازي، وليس هو بالقوي، والحديث منكر، يشبه كلام القصّاص، إنما أوردته للمعرفة لا للحجة». وقال ابن كثير في تفسيره ٥/٣٢ عن رواية ابن جرير: «وهي مطوّلة جدًّا، وفيها غرابة». وقال في موضع آخر ٥/٣٨: «قلتُ: أبو جعفر الرازي قال فيه الحافظ أبو زرعة: الرازي يَهِم في الحديث كثيرًا. وقد ضعّفه غيره أيضًا، ووثّقه بعضهم، والأظهر أنه سيئ الحفظ، ففيما تفرد به نظر. وهذا الحديث في بعض ألفاظه غرابة ونكارة شديدة، وفيه شيء من حديث المنام من رواية سمرة بن جندب في المنام الطويل عند البخاري، ويشبه أن يكون مجموعًا مِن أحاديث شتى، أو منام أو قصة أخرى غير الإسراء». وقال الهيثمي في المجمع ١/٦٧-٧٢ (٢٣٥): «رجاله مُوثّقون، إلا أن الربيع بن أنس قال: عن أبي العالية أو غيره. فتابعيه مجهول».|8:أخرجه ابن جرير ٢٢/٤٢.|9:المُقْحِمات: الذنوب التي تُقْحِم أصحابها في النار، أي: تُلقيهم فيها. النهاية (قحم).|10:أخرجه أحمد ٦/١٨١ (٣٦٦٥)، ومسلم (١٧٣)، والترمذي (٣٢٧٦)، وابن جرير ٢٢/٤١، والبيهقي ٢/٣٧٢-٣٧٣. وعزاه السيوطي إلى عبد بن حميد، وابن مردويه.|11:عزاه السيوطي إلى عَبد بن حُمَيد، وابن المنذر، وابن أبي حاتم، وابن مردويه.|12:أخرجه ابن جرير ٢٢/٤٢.|13:أخرجه ابن الأعرابي في معجمه ٣/١٠١٣ (٢١٦٦).|14:أخرجه ابن جرير ٢٢/٤١.|15:أخرجه ابن جرير ٢٢/٤١.|16:تفسير مجاهد ص٦٢٧، وأخرجه ابن جرير ٢٢/٤٢، والبيهقي (٩٢٧).|17:تفسير الثعلبي ٩/١٤٣، وتفسير البغوي ٧/٤٠٦.|18:تفسير الثعلبي ٩/١٤٤، وتفسير البغوي ٧/٤٠٦.|19:أخرجه ابن جرير ٢٢/٤٣.|20:عزاه السيوطي إلى عبد بن حميد.|21:تفسير البغوي ٧/٤٠٦.
  53,17,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿مَا زَاغَ ٱلۡبَصَرُ وَمَا طَغَىٰ ۝١٧﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٣٣٤٤<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق مُسلِم البَطِين- في قوله: <span class="qpc-hafs">﴿ما زاغَ البَصَرُ﴾</span> قال: ما ذهب يمينًا ولا شمالًا، <span class="qpc-hafs">﴿وما طَغى﴾</span> قال: ما جاوز ما أُمر به{1}. (١٤/٢٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٣٤٥<span class="dash">-</span></span> عن <span class="name-2">محمد بن كعب القُرَظيّ</span> -من طريق موسى بن عُبيدة- <span class="qpc-hafs">﴿ما زاغَ البَصَرُ وما طَغى﴾</span>، قال: رأى جبريلَ في صورة المَلَك{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٣٤٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثم قال: <span class="qpc-hafs">﴿ما زاغَ البَصَرُ﴾</span> يعني: بصر محمد ﷺ، يعني: ما مال، <span class="qpc-hafs">﴿وما طَغى﴾</span> يعني: وما ظلم، لقد صدق محمدٌ ﷺ بما رأى تلك الليلة{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٣٤٧<span class="dash">-</span></span> عن <span class="name-3">محمد بن إسحاق</span> -من طريق سلمة- في قوله: <span class="qpc-hafs">﴿ما زاغَ البَصَرُ وما طَغى﴾</span>، قال: ما مال، وما ارتفع{2}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ٢٢/٤٤ بنحوه، والحاكم ٢/٤٦٩. وعزاه السيوطي إلى الفريابي، وعَبد بن حُمَيد، وابن المنذر، وابن أبي حاتم، وابن مردويه.|2:أخرجه ابن جرير ٢٢/٤٤.|3:تفسير مقاتل بن سليمان ٤/١٦١.|4:أخرجه ابن جرير ٢٢/٤٤.
  53,18,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿لَقَدۡ رَأَىٰ مِنۡ ءَایَـٰتِ رَبِّهِ ٱلۡكُبۡرَىٰۤ ۝١٨﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٣٣٤٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن مسعود</span> -من طريق مُرة- <span class="qpc-hafs">﴿لقد رأى من آيات ربه الكبرى﴾</span>، قال: خَلْق جبريل{1}. (١٤/١٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٣٤٩<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن مسعود</span> -من طريق علقمة- في قوله: <span class="qpc-hafs">﴿لَقَدْ رَأى مِن آياتِ رَبِّهِ الكُبْرى﴾</span>، قال: رأى رَفْرفًا أخضر مِن الجنة قد سَدّ الأُفق{2}. (١٤/٢٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٣٥٠<span class="dash">-</span></span> عن عامر الشعبي، قال: لقي عبدُ الله بن عباس كعبًا بعرفة، فسأله عن شيء، فكبّر حتى جاوبَته الجبال، فقال ابن عباس: إنّ بني هاشم تزعم أن تقول: إنّ محمدًا قد رأى ربّه مرتين. فقال <span class="name-2">كعب</span>: إنّ الله قَسم رؤيته وكلامه بين محمد وموسى ﵉؛ فرآه محمدٌ مرتين، وكلّم موسى مرتين.= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٣٥١<span class="dash">-</span></span> قال <span class="name-2">مسروق</span>: فدخلتُ علي <span class="name-1">عائشة</span> فقلتُ: هل رأى محمد ربّه؟ فقالت: لقد تكلّمت بشيء قَفَّ له شعري! فقلتُ: رويدًا. ثم قرأت: <span class="qpc-hafs">﴿لَقَدْ رَأى مِن آياتِ رَبِّهِ الكُبْرى﴾</span>. قالت: أين يُذهب بك؟! إنما هو جبريل، مَن أخبرك أنّ محمدًا رأى ربّه، أو كتم شيئا مما أُمر به، أو يعلم الخمس التي قال الله: <span class="qpc-hafs">﴿إنَّ اللَّهَ عِنْدَهُ عِلْمُ السّاعَةِ﴾</span> [لقمان:٣٤]؛ فقد أعظم الفِرية، ولكنه رأى جبريل، لم يره في صورته إلا مرتين؛ مَرّة عند سِدرة المنتهى، ومَرّة في جِياد، له ستمائة جناح، قد سَدّ الأُفق{3}. (١٤/٢٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٣٥٢<span class="dash">-</span></span> قال سفيان: وقال <span class="name-2">مجاهد</span>:  مِن نحو أجياد منسوجٌ بالدُّر والياقوت{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٣٥٣<span class="dash">-</span></span> قال <span class="name-2">الضَّحّاك بن مُزاحِم</span>: <span class="qpc-hafs">﴿لَقَدْ رَأى مِن آياتِ رَبِّهِ الكُبْرى﴾</span> رأى سِدرة المنتهى{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٣٥٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن حيّان</span>: <span class="qpc-hafs">﴿لَقَدْ رَأى مِن آياتِ رَبِّهِ الكُبْرى﴾</span> رأى جبريلَ في صورته التي تكون فيها في السماوات{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٣٥٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿لَقَدْ رَأى﴾</span> محمدٌ ﷺ <span class="qpc-hafs">﴿مِن آياتِ رَبِّهِ الكُبْرى﴾</span> وذلك أنّ النبي ﷺ رأى رَفْرفًا أخضر قد غطّى الأُفُق، فذلك <span class="qpc-hafs">﴿مِن آياتِ رَبِّهِ الكُبْرى﴾</span>{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٣٥٦<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿لَقَدْ رَأى مِن آياتِ رَبِّهِ الكُبْرى﴾</span>، قال: جبريل رآه في خَلْقه الذي يكون به في السماوات، قدْر قوسين مِن رسول الله ﷺ، فيما بينه وبينه{8}<span class=comment-ref>٦٢٧٩</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٢٧٩</span> نقل <u>ابنُ عطية</u> (٨/١١٥) عن جماعة من أهل التأويل أن معنى هذه الآية: «لقد رأى الكبرى من آيات ربِّه». ثم <span class="comment-type-1">وجَّهه</span> بقوله: «والمعنى: من آياتِ رَبِّهِ التي يمكن أن يراها البشر، فـ<span class="qpc-hafs">﴿الكُبْرى﴾</span> -على هذا- مفعول بـ<span class="qpc-hafs">﴿رَأى﴾</span>». ثم نقل عن آخرين أن المعنى: «لَقَدْ رَأى بعضًا من آيات ربِّه الكُبْرى». ثم <span class="comment-type-1">وجَّهه</span> بقوله: «فـ<span class="qpc-hafs">﴿الكُبْرى﴾</span> -على هذا- وصف لـ<span class="qpc-hafs">﴿آياتِ﴾</span>، والجمع مما لا يعقل في المؤنث يوصف أبدًا على حد وصف الواحدة».</div></p></div>",footnotes:1:أخرجه أحمد ٦/٤١١ (٣٨٦٤)، وأبو الشيخ في العظمة ٢/ ٧٩٢. وفي تفسير البغوي ٦/٤٠٨: رأى جبريلَ في صورته له ستمائة جناح.|2:أخرجه عبد الرزاق ٢/٢٥٣ من طريق الأعمش، والبخاري (٣٢٣٣، ٤٨٥٨)، وابن جرير ٢٢/٤٥ بنحوه من طرق، والطبراني (٩٠٥١، ٩٠٥٣)، والبيهقي ٢/٣٧٢. وعزاه السيوطي إلى الفريابي، وسعيد بن منصور، وعَبد بن حُمَيد، وابن المنذر، وابن أبي حاتم، وابن مردويه.|3:أخرجه عبد الرزاق ٢/٢٥٢، والترمذي (٣٢٧٨)، وابن جرير ٢٢/٣١، والحاكم ٢/٥٧٥-٥٧٦، وابن مردويه -كما في فتح الباري ٨/٦٠٦-٦٠٧-. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن مردويه.|4:أخرجه الفاكهي في أخبار مكة ٤/١١، يعني: رؤية رسول الله ﷺ لجبريل.|5:تفسير الثعلبي ٩/١٤٤.|6:تفسير الثعلبي ٩/١٤٤.|7:تفسير مقاتل بن سليمان ٤/١٦١.|8:أخرجه ابن جرير ٢٢/٤٦.
  53,19,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿أَفَرَءَیۡتُمُ ٱللَّـٰتَ وَٱلۡعُزَّىٰ ۝١٩﴾</span> - قراءات</h3></p><p><div></p><p><p><span class="item-no">٧٣٣٥٧<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> كان يقرأ: ‹اللّاتَّ› مُشدّدة{1}<span class=comment-ref>٦٢٨٠</span>. (١٤/٣١)</p></p><p></div></p><p><div><span class=comment-ref>٦٢٨٠</span> اختلفت القرأة في قراءة قوله تعالى: <span class="qpc-hafs">﴿اللّاتَ﴾</span> على قراءتين: <b>الأولى:</b> <span class="qpc-hafs">﴿اللّاتَ﴾</span> بتخفيف التاء، وهو تأنيث للفظ الجلالة «الله». <b>الثانية:</b> ‹اللّاتَّ› بتشديد التاء، على أنه صفة للوثن الذي عبدوه، وقالوا: كان رجلًا يَلُتُّ السّويق للحاج، فلما مات عكفوا على قبره فعبدوه.</p><p>و<span class="comment-type-3">رجَّح</span> <u>ابنُ جرير</u> (٢٢/٤٨) القراءة الأولى <span class="mustanad">مستندًا إلى إجماع الحجة من القرأة عليها</span>.</p><p>و<span class="comment-type-4">علَّق</span> <u>ابنُ تيمية</u> (٦/١٣٤) على القراءتين بقوله: «ولا منافاة بين القولين والقراءتين، فإنه كان رجل يَلُتُّ السّويق على حجر، وعكفوا على قبره، وسمّوه بهذا الاسم، وخففوه، وقصدوا أن يقولوا: هو الإله، كما كانوا يسمّون الأصنام آلهة، فاجتمع في الاسم هذا وهذا».</div></p><p><h3><span class="qpc-hafs">﴿أَفَرَءَیۡتُمُ ٱللَّـٰتَ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٣٣٥٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق مِقْسَم-: أنّ اللّات كانت بالطائف{2}. (١٤/٣١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٣٥٩<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق أبي الأشهب، عن أبي الجَوْزاء- قال: كان اللّات رجلًا يَلُتّ سَوِيقَ{3} الحاج. ولفظ عبد بن حميد: يَلُتّ السّويق يسقيه الحاج{4}. (١٤/٣٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٣٦٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عمرو بن مالك، عن أبي الجوزاء- قال: كان اللّات يَلُتّ السّويق على الحَجر، فلا يشرب منه أحد إلا سَمِن، فعبدوه{5}. (١٤/٣٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٣٦١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>: أن اللّات لما مات قال لهم عمرُو بنُ لُحيّ: إنه لم يمت، ولكنه دخل الصخرة. فعبدوها، وبنوا عليها بيتًا{6}. (١٤/٣٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٣٦٢<span class="dash">-</span></span> عن <span class="name-2">أبي الجَوْزاء</span>، قال: اللّات: حَجر كان يلتّ السّويق عليه، فسُمّي: اللّات{7}. (١٤/٣٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٣٦٣<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق منصور- في قوله: <span class="qpc-hafs">﴿أفَرَأَيْتُمُ اللّاتَ﴾</span>، قال: اللّات كان يَلُتّ السّويق بالطائف، فاعتكفوا على قبره{8}. (١٤/٣٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٣٦٤<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span>، قال: كانت اللّات رجلًا في الجاهلية على صخرة بالطائف، وكان له غنم، فكان يَسْلو{9} من رِسْلِها{10}، ويأخذ من زبيب الطائف والأَقِط{11} فيجعل منه حَيْسًا{12}، ويطعم من يمُرّ من الناس، فلما مات عبدوه، وقالوا: هو اللّات{13}. (١٤/٣١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٣٦٥<span class="dash">-</span></span> عن <span class="name-2">أبي صالح باذام</span> -من طريق إسرائيل- قال: اللّات الذي كان يقوم على آلهتهم، وكان يلُتّ لهم السّويق{14}. (١٤/٣٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٣٦٦<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿أفَرَأَيْتُمُ اللّاتَ﴾</span>: أما اللّات فكان بالطائف{15}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٣٦٧<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- في قوله: <span class="qpc-hafs">﴿أفَرَأَيْتُمُ اللّاتَ والعُزّى ومَناةَ﴾</span>، قال: آلهة كانوا يعبدونها، فكان اللّات لأهل الطائف، وكانت العُزّى لقريش بسُقام؛ شِعْبٌ ببطن نخلة، وكانت مَناة للأنصار بقُدَيْد{16}. (١٤/٣٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٣٦٨<span class="dash">-</span></span> قال <span class="name-3">محمد بن السّائِب الكلبي</span>: كان اللات رجلًا مِن ثَقيف يُقال له: صِرمة بن غنم، كان يسلأ السّمن فيضعها على صخرة، فيأتيه العرب، فيلتّ به أسوقتهم، فلمّا مات الرجل حولت ثَقيف تلك الصخرة إلى منازلهم فعبدوها، فهذه الطائف على موضع اللّات{17}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٣٦٩<span class="dash">-</span></span> عن <span class="name-3">عبد الملك ابن جُرَيْج</span>، في قوله: <span class="qpc-hafs">﴿أفَرَأَيْتُمُ اللّاتَ﴾</span>، قال: كان رجل مِن ثَقيف يَلُتّ السّويق بالزيت، فلما تُوفي جعلوا قبره وثنًا، وزعم الناسُ أنه عامر بن الظَّرِب، أحد عَدْوان{18}. (١٤/٣٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٣٧٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿أفَرَأَيْتُمُ اللّاتَ والعُزّى﴾</span> وإنما سُميت اللّات والعُزّى لأنهم أرادوا أن يُسمّوا الله، فمنعهم الله فصارت اللات، وأرادوا أن يُسمّوا: العزيز، فمنعهم، فصارت: العُزّى{19}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٣٧١<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿أفَرَأَيْتُمُ اللّاتَ﴾</span>، قال: اللّات: بيت كان بنخلة تعبده قريش{15}<span class=comment-ref>٦٢٨١</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٢٨١</span> ذكر <u>ابنُ عطية</u> (٨/١١٥-١١٦) أن «اللات» صنم كانت العرب تعظِّمُه، ثم نقل عن أبي عبيدة وغيره: أنه كان في الكعبة. ثم نقل قول قتادة: كان بالطائف. وقول ابن زيد: كان بنخلة عند سوق عكاظ. ثم <span class="comment-type-3">رجَّح</span> -<span class="mustanad">مستندًا إلى اللغة-</span> قائلًا: "وقول قتادة أرجح، ويؤيده قول الشاعر:</p><p>وفَرَّتْ ثقيفٌ إلى لاتِها بمُنْقَلَبِ الخائف الخاسر".</p><p>و<span class="comment-type-2">انتقد</span> <u>ابنُ تيمية</u> (٦/١٣٥) -<span class="mustanad">مستندًا إلى إجماع أهل السّير-</span> قول أبي عبيدة قائلًا: «وأما ما ذكره معمر بن المثنى من أنّ هذه الثلاثة كانت أصنامًا في جوف الكعبة من حجارة، فهو باطل باتفاق أهل العلم بهذا الشأن، وإنما كان في الكعبة»هُبل«الذي ارتجز له أبو سفيان يوم أحد، وقال: اعُل هُبل، اعُل هُبل. فقال النبي ﷺ: «<b>ألا تجيبوه؟</b>» قالوا: وما نقول؟ قال: «<b>قولوا: الله أعلى وأجلّ</b>»».</div></p><p><h3><span class="qpc-hafs">﴿وَٱلۡعُزَّىٰ ۝١٩﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٣٣٧٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق مِقْسَم-: أنّ العُزّى كانت ببطن نَخْلة{21}{2}. (١٤/٣١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٣٧٣<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جُبَير</span> -من طريق جعفر- قال: العُزّى حجَر أبيض{23}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٣٧٤<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق منصور- في قوله: <span class="qpc-hafs">﴿والعُزّى﴾</span>، قال: والعُزّى شجرات{24}. (١٤/٣٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٣٧٥<span class="dash">-</span></span> قال <span class="name-2">الضَّحّاك بن مُزاحِم</span>: <span class="qpc-hafs">﴿العُزّى﴾</span> هي صنم لغَطَفان، وضعها لهم سعد بن ظالم الغَطَفاني، وذلك أنه قدم مكة، فرأى الصفا والمروة، ورأى أهل مكة يطوفون بينهما، فعاد إلى بطن نخلة، وقال لقومه: إنّ لأهل مكة الصفا والمروة، وليستا لكم، ولهم إله يعبدونه، وليس لكم. قالوا: فما تأمرنا؟ قال: أنا أصنع لكم كذلك. فأخذ حجرًا من الصفا، وحجرًا من المروة، ونقلهما إلى نخلة، فوضع الذي أخذ من الصفا، فقال: هذا الصفا. ثم وضع الذي أخذه من المروة، فقال: هذه المروة. ثم أخذ ثلاثة أحجار، فأسندها إلى شجرة، فقال: هذا ربّكم. فجعلوا يطوفون بين الحجرين، ويعبدون الحجارة، حتى افتتح رسولُ الله ﷺ مكة، فأمر برفع الحجارة، وبعث خالد بن الوليد إلى العُزّى، فقطعها{25}<span class=comment-ref>٦٢٨٢</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٢٨٢</span> <span class="comment-type-1">وجَّه</span> <u>ابنُ تيمية</u> (٦/١٣٥) هذا القول بقوله: «وما ذكره بعض المفسرين من أن»العُزّى«كانت لغَطَفان؛ فذلك لأنّ غَطَفان كانت تعبدها، وهي في جهتها، وأهل مكة يحجُّون إليها، فإنّ العُزّى كانت ببطن نخلة من ناحية عرفات».</div></p><p><div></p><p><p><span class="item-no">٧٣٣٧٦<span class="dash">-</span></span> عن <span class="name-2">أبي صالح باذام</span> -من طريق إسرائيل- قال: والعُزّى بنخلة، نخلة كانوا يعلّقون عليها السيور والعِهن{26}. (١٤/٣٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٣٧٧<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿والعُزّى﴾</span>، قال: أمّا العُزّى فكانت ببطن نخلة، وأما مَناة فإنها كانت -فيما ذُكر- لخزاعة{27}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٣٧٨<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿والعُزّى﴾</span>: بيت بالطائف، تعبده ثَقيف{23}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَٱلۡعُزَّىٰ ۝١٩﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٧٣٣٧٩<span class="dash">-</span></span> عن أبي الطُّفيل، قال: لَمّا فتح رسولُ الله ﷺ مكة بعث خالد بن الوليد إلى نَخْلَة، وكان بها العُزّى، فأتاها خالد، وكانت على ثلاث سمُرات{29}، فقطع السمُرات، وهدم البيت الذي كان عليها، ثم أتى النبيَّ ﷺ، فأخبره، فقال: «<b>ارجع؛ فإنّك لم تصنع شيئًا</b>». فرجع خالد، فلما أبْصَرتْه السّدنة -وهم حَجَبتها- أمعَنوا في الجبل، وهم يقولون: يا عُزّى، يا عُزّى. فأتاها خالد، فإذا امرأة عُريانة ناشرة شعرها، تَحفِن{30} التراب على رأسها، فعمّمها بالسيف حتى قتلها، ثم رجع إلى رسول الله ﷺ، فأخبره، فقال: «<b>تلك العُزّى</b>»{31}. (١٤/٣٠)</p></p><p></div></p></div>",footnotes:1:عزاه السيوطي إلى سعيد بن منصور، والفاكهي.</p><p>وهي قراءة متواترة، قرأ بها رويس، وقرأ بقية العشرة: <span class="qpc-hafs">﴿اللّاتَ﴾</span> بالتخفيف. انظر: النشر ٢/٣٧٩، والإتحاف ص٥٢٢.|2:أخرجه الطبراني (١٢١٠٦). وعزاه السيوطي إلى ابن مردويه.|3:السَّوِيق: ما يُتخذ من الحنطة والشعير، ولَتَّ السَّوِيق: بَلَّه. لسان العرب (سوق)، (لتت).|4:أخرجه البخاري (٤٨٥٩)، وابن جرير ٢٢/٤٨ بنحوه. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن مردويه.|5:أخرجه ابن أبي حاتم -كما في فتح الباري ٨/٦١٢-. وعزاه السيوطي إلى ابن مردويه.|6:علقه الفاكهي في أخبار مكة ٥/١٦٤ (٧٦).|7:عزاه السيوطي إلى عَبد بن حُمَيد.|8:أخرجه ابن جرير ٢٢/٤٨. وعزاه السيوطي إلى عَبد بن حُمَيد، وابن المنذر.|9:أي: يأخذ سَلاها، وهو السمن. النهاية (سلا).|10:الرِّسْل: اللبن. النهاية (رسل).|11:الأَقِط: هو لبن مُجَفّف يابس مُسْتَحْجِر يُطبخ به. النهاية (أقط).|12:الحَيْس: هو الطعام المُتَّخَذ من التمر والأقِط والسَّمْن، وقد يُجْعل عِوَض الأقِط الدَّقِيق، أو الفَتِيتُ. النهاية (حيس).|13:عزاه السيوطي إلى سعيد بن منصور، والفاكهي.|14:أخرجه ابن جرير ٢٢/٤٨. وعزاه السيوطي إلى عَبد بن حُمَيد.|15:أخرجه ابن جرير ٢٢/٤٧.|16:أخرجه عبد الرزاق ٢/٢٥٣. وعزاه السيوطي إلى عَبد بن حُمَيد، وابن المنذر.|17:تفسير الثعلبي ٩/١٤٥، وتفسير البغوي ٧/٤٠٧.|18:عزاه السيوطي إلى ابن المنذر.|19:تفسير مقاتل بن سليمان ٤/١٦١.|20:أخرجه ابن جرير ٢٢/٤٧.|21:وهي نخلة الشامية، وادٍ لهُذيلٍ، على ليلتين من مكة. معجم البلدان ٤/١١٦، ٥/٢٧٧.|22:أخرجه الطبراني (١٢١٠٦). وعزاه السيوطي إلى ابن مردويه.|23:أخرجه ابن جرير ٢٢/٤٩.|24:أخرجه ابن جرير ٢٢/٤٩. وعزاه السيوطي إلى عَبد بن حُمَيد، وابن المنذر.|25:تفسير البغوي ٧/٤٠٨.|26:أخرجه ابن جرير ٢٢/٤٨ بنحوه. وعزاه السيوطي إلى عَبد بن حُمَيد.|27:أخرجه ابن جرير ٢٢/٥٠.|28:أخرجه ابن جرير ٢٢/٤٩.|29:سمُرات: جمع سَمُرة، ضَرْب من شجر الطلْح. النهاية (سمر).|30:الحَفْن: أخذك الشيء براحة كفك والأصابع مضمومة. لسان العرب (حفن).|31:أخرجه النسائي في الكبرى ١٠/٢٧٩ (١١٤٨٣)، وأبو يعلى في مسنده ٢/١٩٦ (٩٠٢)، من طريق محمد بن فضيل، عن الوليد بن جميع، عن أبي الطفيل به.</p><p>وسنده حسن.
  53,20,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَمَنَوٰةَ ٱلثَّالِثَةَ ٱلۡأُخۡرَىٰۤ ۝٢٠﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٣٣٨٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق مِقْسَم-: أنّ العُزّى كانت ببطن نخلة، وأنّ اللّات كانت بالطائف، وأن مَناة كانت بقُدَيْد{1}. (١٤/٣١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٣٨١<span class="dash">-</span></span> قال <span class="name-2">الضَّحّاك بن مُزاحِم</span>: مناة: صنم لهُذيل وخُزاعة، يعبدها أهل مكة{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٣٨٢<span class="dash">-</span></span> عن <span class="name-2">أبي صالح باذام</span> -من طريق إسرائيل- قال: اللّات الذي كان يقوم على آلهتهم، وكان يلُتّ لهم السّويق، والعُزّى بنخلة، نخلة كانوا يعلّقون عليها السيور والعِهن، ومَناة حجَر بقُدَيْد{3}. (١٤/٣٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٣٨٣<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد-: وأما مَناة فإنها كانت -فيما ذُكر- لخزاعة{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٣٨٤<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿ومَناةَ الثّالِثَةَ الأُخْرى﴾</span>، قال: أمّا مَناة فكانت بقُدَيْد، آلهة كانوا يعبدونها، يعني: اللّات، والعُزّى، ومَناة{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٣٨٥<span class="dash">-</span></span> عن <span class="name-3">ابن إسحاق</span>، قال: نصب عمرو بن لحي مناة على ساحل البحر مِمّا يلي قُدَيْد، يحجونها ويطوفونها، إذا طافوا بالبيت وأفاضوا من عرفات وفرغوا مِن منى أتوا مناة، فأهلُّوا لها، فمَن أهلَّ لها لم يطف بين الصفا والمروة{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٣٨٦<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿ومَناةَ الثّالِثَةَ الأُخْرى﴾</span>، قال: مَناة بيت كان بالمشلّل{7}، يعبده بنو كعب{4}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَمَنَوٰةَ ٱلثَّالِثَةَ ٱلۡأُخۡرَىٰۤ ۝٢٠﴾</span> - آثار متعلقة بالآيات{9}</h3></p><p><div></p><p><p><span class="item-no">٧٣٣٨٧<span class="dash">-</span></span> عن يونس بن محمد بن فضالة الظفري، عن أبيه، وكثير بن زيد، عن المُطَّلِب بن عبد الله بن حَنطَب، قالا: رأى رسولُ الله ﷺ من قومه كفًّا عنه، فجلس خاليًا، فتمنّى، فقال: «<b>ليتَه لا ينزل عليّ شيء ينفّرهم عَنِّي</b>». وقارب رسول الله ﷺ قومه، ودنا منهم، ودَنَوا منه، فجلس يومًا مجلسًا في نادٍ مِن تلك الأندية حول الكعبة، فقرأ عليهم: <span class="qpc-hafs">﴿والنجم إذا هوى﴾</span> حتى إذا بلغ: <span class="qpc-hafs">﴿أفرأيتم اللات والعزى ومناة الثالثة الأخرى﴾</span> ألقى الشيطان كلمتين على لسانه: تلك الغَرانيق العُلا، وإنّ شفاعتهنّ لتُرتجى. فتكلم رسول الله ﷺ بهما، ثم مضى فقرأ السورة كلّها، وسجد، وسجد القوم جميعًا، ورفع الوليد بن المغيرة ترابًا إلى جبهته، فسجد عليه، وكان شيخًا كبيرًا لا يقدر على السجود، ويقال: إنّ أبا أُحيحة سعيد بن العاص أخذ ترابًا، فسجد عليه، رفعه إلى جبهته، وكان شيخًا كبيرًا، فبعض الناس يقول: إنما الذي رفع التراب الوليد. وبعضهم يقول: أبو أُحيحة. وبعضهم يقول: كلاهما جميعًا فعل ذلك. فرضُوا بما تكلّم به رسول الله ﷺ، وقالوا: قد عرفنا أنّ الله يُحيي ويُميت ويخلُق ويرزُق، ولكن آلهتنا هذه تشفع لنا عنده، وأمّا إذ جعلتَ لها نصيبًا فنحن معك. فكبُر ذلك على رسول الله ﷺ من قولهم، حتى جلس في البيت، فلما أمسى أتاه جبريل ﵇، فعرض عليه السورة، فقال جبريل: ما جئتُك بهاتين الكلمتين. فقال رسول الله ﷺ: «<b>قلتُ على الله ما لم يقل</b>!». فأوحى الله إليه: <span class="qpc-hafs">﴿وإن كادوا ليفتنونك عن الذي أوحينا إليك لتفتري علينا غيره وإذًا لاتخذوك خليلًا﴾</span> إلى قوله: <span class="qpc-hafs">﴿ثم لا تجد لك علينا نصيرًا﴾</span> [الإسراء:٧٣-٧٥]{10}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٣٨٨<span class="dash">-</span></span> قال محمد بن السّائِب الكلبي: كان النبي ﷺ يُصلّي عند البيت، والمشركون جلوس، فقرأ: <span class="qpc-hafs">﴿والنَّجْمِ إذا هَوى﴾</span> فحدّث نفسه حتى إذا بلغ: <span class="qpc-hafs">﴿أفَرَأَيْتُمُ اللّاتَ والعُزّى ومَناةَ الثّالِثَةَ الأُخْرى﴾</span> ألقى الشيطان على لسانه: فإنّها مِن الغَرانيق العُلى -يعني: الملائكة-، وإنّ شفاعتها تُرتجى. أي: هي المرتجى. فلما انصرف النبي من صلاته قال المشركون: قد ذكر محمدٌ آلهتنا بخير. فقال النبي: «<b>واللهِ، ما كذلك نَزَلَتْ عليّ!</b>». فنزل عليه جبريل، فأخبره النبي، فقال: واللهِ، ما هكذا علّمتُك، وما جئت بها هكذا. فأنزل الله: <span class="qpc-hafs">﴿وما أرْسَلْنا مِن قَبْلِكَ مِن رَسُولٍ ولا نَبِيٍّ إلّا إذا تَمَنّى ألْقى الشَّيْطانُ فِي أُمْنِيَّتِهِ﴾</span> الآية [الحج:٥٢]{11}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه الطبراني (١٢١٠٦). وعزاه السيوطي إلى ابن مردويه.|2:تفسير الثعلبي ٩/١٤٦، وتفسير البغوي ٧/٤٠٨.|3:أخرجه ابن جرير ٢٢/٤٨ بنحوه. وعزاه السيوطي إلى عَبد بن حُمَيد.|4:أخرجه ابن جرير ٢٢/٥٠.|5:أخرجه ابن جرير ٢٢/٥٠.|6:أخرجه الفاكهي -كما في الفتح ٨/٦١٣-.|7:المشلَّل: جبل يُهبط منه إلى قُديد. تاج العروس (شلل).|8:أخرجه ابن جرير ٢٢/٥٠.|9:⟨تقدمت آثار عديدة مفصلة عند نزول قوله تعالى: <span class="qpc-hafs">﴿وما أرْسَلْنا مِن قَبْلِكَ مِن رَسُولٍ ولا نَبِيٍّ إلّا إذا تَمَنّى ألْقى الشَّيْطانُ فِي أُمْنِيَّتِهِ فَيَنْسَخُ اللَّهُ ما يُلْقِي الشَّيْطانُ ثُمَّ يُحْكِمُ اللَّهُ آياتِهِ واللَّهُ عَلِيمٌ حَكِيمٌ﴾</span>⟩{ع} [الحج:٥٢] ⟨وهذه روايات أخرى.⟩{ع}|10:أخرجه ابن سعد في الطبقات ١/١٧٤.|11:ذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٤/٣٠٩-٣١٠-.
  53,21,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿أَلَكُمُ ٱلذَّكَرُ وَلَهُ ٱلۡأُنثَىٰ ۝٢١﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٣٣٨٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ألَكُمُ الذَّكَرُ ولَهُ الأُنْثى﴾</span> حين قالوا: إنّ الملائكة بنات الله{1}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٤/١٦١.
  53,22,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿تِلۡكَ إِذࣰا قِسۡمَةࣱ ضِیزَىٰۤ ۝٢٢﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٣٣٩٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>: أنّ نافع بن الأزرق سأله عن قوله: <span class="qpc-hafs">﴿ضِيزى﴾</span>. قال: جائرة. قال: وهل تعرف العرب ذلك؟ قال: نعم، أما سمعت قول امرئ القيس:</p><p>ضازت بنو أسد بُحكمهم إذ يَعدِلون الرأس بالذَّنَب؟{1}. (١٤/٣٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٣٩١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عكرمة- في قوله: <span class="qpc-hafs">﴿قِسْمَةٌ ضِيزى﴾</span>، قال: جائرة، لا حقَّ فيها{2}. (١٤/٣٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٣٩٢<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿ضِيزى﴾</span>، قال: عوجاء{3}. (١٤/٣٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٣٩٣<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span>، في قوله: <span class="qpc-hafs">﴿ضِيزى﴾</span>، قال: منقوصة{4}. (١٤/٣٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٣٩٤<span class="dash">-</span></span> قال <span class="name-2">الضَّحّاك بن مُزاحِم</span>: <span class="qpc-hafs">﴿تِلْكَ إذًا قِسْمَةٌ ضِيزى﴾</span> ناقصة{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٣٩٥<span class="dash">-</span></span> قال <span class="name-2">الحسن البصري</span>: <span class="qpc-hafs">﴿تِلْكَ إذًا قِسْمَةٌ ضِيزى﴾</span> جائرة؛ أن جعلوا لله البنات ولهم الغلمان{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٣٩٦<span class="dash">-</span></span> قال <span class="name-2">محمد بن سيرين</span>: <span class="qpc-hafs">﴿تِلْكَ إذًا قِسْمَةٌ ضِيزى﴾</span> غير مستوية أن يكون لكم الذكر ولله الإناث{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٣٩٧<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- في قوله: <span class="qpc-hafs">﴿ضِيزى﴾</span>، قال: جائرة{8}. (١٤/٣٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٣٩٨<span class="dash">-</span></span> عن <span class="name-2">الضَّحّاك بن مُزاحِم</span>، مثله{9}. (١٤/٣٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٣٩٩<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿تِلْكَ إذًا قِسْمَةٌ ضِيزى﴾</span>، يقول: قِسمة جائرة{10}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٤٠٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿تِلْكَ إذًا قِسْمَةٌ ضِيزى﴾</span> يعني: جائرة عوجاء؛ أن يكون لهم الذَّكر وله الأنثى{11}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٤٠١<span class="dash">-</span></span> عن <span class="name-3">سفيان [الثوري]</span> -من طريق مهران- <span class="qpc-hafs">﴿تِلْكَ إذًا قِسْمَةٌ ضِيزى﴾</span>، قال: منقوصة{12}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٤٠٢<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿تِلْكَ إذًا قِسْمَةٌ ضِيزى﴾</span>، قال: جعلوا لله -تبارك وتعالى- بنات، وجعلوا الملائكة لله بنات، وعبدوهم. وقرأ: <span class="qpc-hafs">﴿أمِ اتَّخَذَ مِمّا يَخْلُقُ بَناتٍ وأَصْفاكُمْ بِالبَنِينَ *وإذا بُشِّرَ﴾</span> الآية [الزخرف:١٦-١٧]. وقرأ: <span class="qpc-hafs">﴿ويَجْعَلُونَ لِلَّهِ البَناتِ﴾</span> الآية إلى آخره [النحل:٥٧]، وقال: دَعَوا لله ولدًا، كما دَعَت اليهود والنصارى. وقرأ: <span class="qpc-hafs">﴿كَذَلِكَ قالَ الَّذِينَ مِن قَبْلِهِمْ﴾</span> [البقرة:١١٨]، قال: والضِّيزى في كلام العرب: المخالفة. وقرأ: <span class="qpc-hafs">﴿إنْ هِيَ إلّا أسْماءٌ سَمَّيْتُمُوها أنْتُمْ وآباؤُكُمْ﴾</span>{12}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه الطستي -كما في الإتقان ٢/٩٨-.|2:أخرجه ابن جرير ٢٢/٥٣ بنحوه.|3:تفسير مجاهد ص٦٢٧، وأخرجه الفريابي -كما في تغليق التعليق ٤/٣٢٢-، وابن جرير ٢٢/٥٣. وعزاه السيوطي إلى عبد بن حميد.|4:عزاه السيوطي إلى ابن المنذر.|5:تفسير الثعلبي ٩/١٤٦.|6:ذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٤/٣٠٩-.|7:تفسير الثعلبي ٩/١٤٦.|8:أخرجه عبد الرزاق ٢/٢٥٥، وابن جرير ٢٢/٥٣ بنحوه. وعزاه السيوطي إلى عبد بن حميد.|9:عزاه السيوطي إلى عبد بن حميد.|10:أخرجه ابن جرير ٢٢/٥٣.|11:تفسير مقاتل بن سليمان ٤/١٦١.|12:أخرجه ابن جرير ٢٢/٥٤.|13:أخرجه ابن جرير ٢٢/٥٤.
  53,23,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿إِنۡ هِیَ إِلَّاۤ أَسۡمَاۤءࣱ سَمَّیۡتُمُوهَاۤ أَنتُمۡ وَءَابَاۤؤُكُم مَّاۤ أَنزَلَ ٱللَّهُ بِهَا مِن سُلۡطَـٰنٍۚ إِن یَتَّبِعُونَ إِلَّا ٱلظَّنَّ وَمَا تَهۡوَى ٱلۡأَنفُسُۖ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٣٤٠٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثم ذكر آلهتهم، فقال: <span class="qpc-hafs">﴿إنْ هِيَ﴾</span> يقول: ما هي <span class="qpc-hafs">﴿إلّا أسْماءٌ سَمَّيْتُمُوها أنْتُمْ وآباؤُكُمْ ما أنْزَلَ اللَّهُ بِها مِن سُلْطانٍ﴾</span> بأنها آلهة. مثل قوله: <span class="qpc-hafs">﴿أمْ لَكُمْ سُلْطانٌ مُبِينٌ﴾</span> [الصافات:١٥٦]، يعني: كتابًا لهم فيه حُجّة. <span class="qpc-hafs">﴿إنْ يَتَّبِعُونَ إلّا الظَّنَّ﴾</span> يقول: ما لهم مِن علم بأنها آلهة إلا ظنًّا ما يستيفتون{1} بأنّ اللّات والعُزّى ومَناة آلهة، <span class="qpc-hafs">﴿وما تَهْوى الأَنْفُسُ﴾</span> يعني: القلوب{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٤٠٤<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب-: <span class="qpc-hafs">﴿إنْ هِيَ إلّا أسْماءٌ سَمَّيْتُمُوها أنْتُمْ وآباؤُكُمْ﴾</span> ما كذلكم قال الله، <span class="qpc-hafs">﴿ما أنزل الله بها من سلطان﴾</span> إلى آخر الآية{3}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَلَقَدۡ جَاۤءَهُم مِّن رَّبِّهِمُ ٱلۡهُدَىٰۤ ۝٢٣﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٣٤٠٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ولَقَدْ جاءَهُمْ مِن رَبِّهِمُ الهُدى﴾</span>، يعني: القرآن{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٤٠٦<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿ولَقَدْ جاءَهُمْ مِن رَبِّهِمُ الهُدى﴾</span>: فما انتفعوا به{5}. (ز)</p></p><p></div></p></div>",footnotes:1:كذا في مطبوعة المصدر. ولعلها: يستيقنون.|2:تفسير مقاتل بن سليمان ٤/١٦١-١٦٢.|3:أخرجه ابن جرير ٢٢/٥٥.|4:تفسير مقاتل بن سليمان ٤/١٦٢.|5:أخرجه ابن جرير ٢٢/٥٦
  53,24,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿أَمۡ لِلۡإِنسَـٰنِ مَا تَمَنَّىٰ ۝٢٤ فَلِلَّهِ ٱلۡـَٔاخِرَةُ وَٱلۡأُولَىٰ ۝٢٥﴾</span> - نزول الآية، وتفسيرها</h3></p><p><div></p><p><p><span class="item-no">٧٣٤٠٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿أمْ لِلْإنْسانِ ما تَمَنّى﴾</span> بأنّ الملائكة تشفع لهم، وذلك أنّ النبي ﷺ قرأ سورة النَّجْمِ، <span class="qpc-hafs">﴿واللَّيْلِ إذا يَغْشى﴾</span>، أعلنهما بمكة، فلما بلغ: <span class="qpc-hafs">﴿أفَرَأَيْتُمُ اللّاتَ والعُزّى ومَناةَ﴾</span> نَعس، فألقى الشيطان على لسانه: تلك الثالثة الأخرى، تلك الغَرانيق العُلا، عندها الشفاعة تُرتجى. يعني: الملائكة. ففرح كفار مكة، ورَجَوا أن يكون للملائكة شفاعة، فلمّا بلغ آخرَها سجد، وسجد المؤمنون تصديقًا لله تعالى، وسجد كفار مكة عند ذِكر الآلهة، غير أنّ الوليد بن المغيرة وكان شيخًا كبيرًا فرفع التراب إلى جبهته، فسجد عليه، فقال: يحيا كما تحيا أُمّ أيمن وصواحباتها. وكانت أُمّ أيمن خادم النبي ﷺ، وأيمن خادم النبي ﷺ قُتل يوم خيبر. وقال: <span class="qpc-hafs">﴿لَيَجْمَعَنَّكُمْ إلى يَوْمِ القِيامَةِ لا رَيْبَ فِيهِ﴾</span> [الأنعام:١٢] لا شكّ فيه. <span class="qpc-hafs">﴿لِيَجْزِيَ الَّذِينَ أساءُوا بِما عَمِلُوا ويَجْزِيَ الَّذِينَ أحْسَنُوا بِالحُسْنى﴾</span> فلمّا رَجوا أنّ للملائكة شفاعة أنزل الله تعالى: <span class="qpc-hafs">﴿فَلِلَّهِ الآخِرَةُ والأُولى﴾</span> يعني: الدنيا والآخرة{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٤٠٨<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿أمْ لِلْإنْسانِ ما تَمَنّى﴾</span>، قال: وإن كان محمد تمنّى هذا فذلك له{2}<span class=comment-ref>٦٢٨٣</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٢٨٣</span> لم يذكر <u>ابنُ جرير</u> (٢٢/٥٦) في معنى: <span class="qpc-hafs">﴿أمْ لِلإنْسانِ ما تَمَنّى﴾</span> سوى قول ابن زيد.</p><p>وذكر <u>ابنُ عطية</u> (٨/١١٩) أن الإنسان في الآية اسم جنس، ثم ذكر قول ابن زيد، ثم <span class="comment-type-4">علَّق</span> بقوله: «بمعنى: أنه لم ينل كرامتنا بتأميل، بل بفضلٍ من الله تعالى، أو بمعنى: بل إنّه تمنى كرامتنا فنالها، إذ الكلّ لله -تعالى- يهب مَن يشاء، وهذا ما تقتضيه الآية، وإن كان اللفظ يَعُمُّه».</div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٤/١٦٢-١٦٣.|2:أخرجه ابن جرير ٢٢/٥٦.
  53,25,"53:24"
  53,26,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَكَم مِّن مَّلَكࣲ فِی ٱلسَّمَـٰوَ ٰ⁠تِ لَا تُغۡنِی شَفَـٰعَتُهُمۡ شَیۡـًٔا إِلَّا مِنۢ بَعۡدِ أَن یَأۡذَنَ ٱللَّهُ لِمَن یَشَاۤءُ وَیَرۡضَىٰۤ ۝٢٦﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٣٤٠٩<span class="dash">-</span></span> قال <span class="name-1">عبد الله بن عباس</span>: <span class="qpc-hafs">﴿لا تُغْنِي شَفاعَتُهُمْ شَيْئًا إلّا مِن بَعْدِ أنْ يَأْذَنَ اللَّهُ لِمَن يَشاءُ ويَرْضى﴾</span> يريد: لا تشفع الملائكة إلا لمن ﵁{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٤١٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿لا تُغْنِي﴾</span> يقول: لا تنفع شفاعتهم شيئًا، استثنى فقال: <span class="qpc-hafs">﴿إلّا مِن بَعْدِ أنْ يَأْذَنَ اللَّهُ لِمَن يَشاءُ﴾</span> مِن بني آدم فيشفع له، أو يرضى الله له بالتوحيد{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٣٤١١<span class="dash">-</span></span> عن <span class="name-3">عبد الملك ابن جُرَيْج</span>، في قوله: <span class="qpc-hafs">﴿وكَمْ مِن مَلَكٍ فِي السَّماواتِ لا تُغْنِي شَفاعَتُهُمْ﴾</span>، قال: لقولهم: إنّ الغَرانِقة{3} لَيشفعون{4}. (١٤/٣٥)</p></p><p></div></p></div>",footnotes:1:تفسير البغوي ٧/٤١٠.|2:تفسير مقاتل بن سليمان ٤/١٦٣.|3:الغرانقة: جمع الغُرْنُوق والغُرْنَيْق، وهي في الأصل الذكور من طَير الماء، والمقصود هنا الأصنام، وكانوا يزعمون أن الأصنام تقربهم من الله وتشفع لهم، فشُبهت بالطيور التي تعلو في السماء وترتفع. النهاية (غَرْنَقَ).|4:عزاه السيوطي إلى ابن المنذر.