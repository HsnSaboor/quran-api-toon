quran[9]{c,v,t}:
  30,42,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿قُلۡ سِیرُوا۟ فِی ٱلۡأَرۡضِ فَٱنظُرُوا۟ كَیۡفَ كَانَ عَـٰقِبَةُ ٱلَّذِینَ مِن قَبۡلُۚ كَانَ أَكۡثَرُهُم مُّشۡرِكِینَ ۝٤٢﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٠٧٢٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿قُلْ سِيرُوا فِي الأَرْضِ فانْظُرُوا كَيْفَ كانَ عاقِبَةُ الَّذِينَ مِن قَبْلُ﴾</span> يعني: قبل كفار مكة مِن الأمم الخالية، <span class="qpc-hafs">﴿كانَ أكْثَرُهُمْ مُشْرِكِينَ﴾</span> فكان عاقبتهم الهلاك في الدنيا{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٠٧٢٤<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام:</span> <span class="qpc-hafs">﴿قُلْ سِيرُوا فِي الأَرْضِ فانْظُرُوا كَيْفَ كانَ عاقِبَةُ الَّذِينَ مِن قَبْلُ﴾</span> كان عاقبتهم أن دمَّر الله عليهم، ثم صيَّرهم إلى النار، <span class="qpc-hafs">﴿كانَ أكْثَرُهُمْ مُشْرِكِينَ﴾</span> أي: فأهلكهم{2}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٣/٤١٧.|2:تفسير يحيى بن سلام ٢/٦٦٣.
  30,43,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿فَأَقِمۡ وَجۡهَكَ لِلدِّینِ ٱلۡقَیِّمِ مِن قَبۡلِ أَن یَأۡتِیَ یَوۡمࣱ لَّا مَرَدَّ لَهُۥ مِنَ ٱللَّهِۖ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٠٧٢٥<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿فَأَقِمْ وجْهَكَ لِلدِّينِ القَيِّمِ﴾</span> قال: الإسلام، <span class="qpc-hafs">﴿مِن قَبْلِ أنْ يَأْتِيَ يَوْمٌ لا مَرَدَّ لَهُ مِنَ اللَّهِ﴾</span> قال: يوم القيامة{1}. (١١/٦٠٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٠٧٢٦<span class="dash">-</span></span> قال <span class="name-2">إسماعيل السُّدِّيّ:</span> <span class="qpc-hafs">﴿فَأَقِمْ وجْهَكَ لِلدِّينِ القَيِّمِ﴾</span> التوحيد{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٠٧٢٧<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام:</span> <span class="qpc-hafs">﴿فَأَقِمْ وجْهَكَ﴾</span> أي: وجهتك <span class="qpc-hafs">﴿لِلدِّينِ القَيِّمِ﴾</span> وهو الإسلام، <span class="qpc-hafs">﴿مِن قَبْلِ أنْ يَأْتِيَ يَوْمٌ لا مَرَدَّ لَهُ مِنَ اللَّهِ﴾</span> يعني: يوم القيامة{3}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿یَوۡمَىِٕذࣲ یَصَّدَّعُونَ ۝٤٣﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٠٧٢٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- في قوله: <span class="qpc-hafs">﴿يَوْمَئِذٍ يَصَّدَّعُونَ﴾</span>، قال: يتفرقون{4}. (١١/٦٠٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٠٧٢٩<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿يَوْمَئِذٍ يَصَّدَّعُونَ﴾</span>، قال: فريق في الجنة، وفريق في السعير{1}. (١١/٦٠٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٠٧٣٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿يَوْمَئِذٍ يَصَّدَّعُونَ﴾</span>، يعني: بعد الحساب، يَتَفَرَّقون إلى الجنة، وإلى النار{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٠٧٣١<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿يَوْمَئِذٍ يَصَّدَّعُونَ﴾</span>، قال:يتفرقون. وقرأ: <span class="qpc-hafs">﴿فَأَمّا الَّذِينَ آمَنُوا وعَمِلُوا الصّالِحاتِ فَهُمْ فِي رَوْضَةٍ يُحْبَرُونَ * وأَمّا الَّذِينَ كَفَرُوا وكَذَّبُوا بِآياتِنا ولِقاءِ الآخِرَةِ فَأُولَئِكَ فِي العَذابِ مُحْضَرُونَ﴾</span> [الروم:١٥-١٦]، قال: هذا حين يصدّعون؛ يتفرقون إلى الجنة والنار{7}. (١١/٦٠٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٠٧٣٢<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام:</span> <span class="qpc-hafs">﴿يَوْمَئِذٍ يَصَّدَّعُونَ﴾</span>، يعني: يتفرّقون؛ فريق في الجنة، وفريق في السعير{3}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ١٨/٥١٥. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.|2:علَّقه يحيى بن سلام ٢/٦٦٣.|3:تفسير يحيى بن سلام ٢/٦٦٣.|4:أخرجه ابن جرير ١٨/٥١٥، وابن أبي حاتم -كما في التغليق ٤/٢٧٩-. وعزاه السيوطي إلى ابن المنذر.|5:أخرجه ابن جرير ١٨/٥١٥. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.|6:تفسير مقاتل بن سليمان ٣/٤١٧.|7:أخرجه ابن جرير ١٨/٥١٥. وعزاه السيوطي إلى ابن أبي حاتم.|8:تفسير يحيى بن سلام ٢/٦٦٣.
  30,44,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿مَن كَفَرَ فَعَلَیۡهِ كُفۡرُهُۥۖ وَمَنۡ عَمِلَ صَـٰلِحࣰا فَلِأَنفُسِهِمۡ یَمۡهَدُونَ ۝٤٤﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٠٧٣٣<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبى نجيح- في قوله: <span class="qpc-hafs">﴿فَلِأَنْفُسِهِمْ يَمْهَدُونَ﴾</span>، قال: يُسَوُّون المضاجع في القبر{1}. (١١/٦٠٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٠٧٣٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿مَن كفر﴾</span> بالله <span class="qpc-hafs">﴿فعليه﴾</span> إثم كفره، <span class="qpc-hafs">﴿ومَن عَمِلَ صالِحًا فَلِأَنْفُسِهِمْ يَمْهَدُونَ﴾</span> يعني: يُقَدِّمون{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٠٧٣٥<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿مَن كَفَرَ فَعَلَيْهِ كُفْرُهُ﴾</span> يثاب عليه النار، <span class="qpc-hafs">﴿ومَن عَمِلَ صالِحًا فَلِأَنْفُسِهِمْ يَمْهَدُونَ﴾</span> يوطئون في الدنيا القرار في الآخرة بالعمل الصالح ... عن سعيد بن أبي هلال، قال: قال رسول الله ﷺ: «<b>نعمت المطية الدنيا! فارتحلوا تبلغكم الآخرة</b>». عن الخليل بن مرة ذكره بإسناده، قال: يقول الله -تبارك وتعالى-: ادخلوا الجنة برحمتي، واقتسموها بأعمالكم{3}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير مجاهد (٥٣٩)، وأخرجه الفريابي -كما في التغليق ٤/٢٧٩-، والبزار في البحر الزخار (مسند البزار) ٨/١٨٠ (٣٢١٣)، وابن جرير ١٨/٥١٦، وأبو نعيم في الحلية ٣/٢٧٩، والبيهقي في عذاب القبر (١٥٥). وعلقه يحيى بن سلام ٢/٦٦٤. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.|2:تفسير مقاتل بن سليمان ٣/٤١٧.|3:أورده يحيى بن سلام ٢/٦٦٣-٦٦٤.
  30,45,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿لِیَجۡزِیَ ٱلَّذِینَ ءَامَنُوا۟ وَعَمِلُوا۟ ٱلصَّـٰلِحَـٰتِ مِن فَضۡلِهِۦۤۚ إِنَّهُۥ لَا یُحِبُّ ٱلۡكَـٰفِرِینَ ۝٤٥﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٠٧٣٦<span class="dash">-</span></span> قال <span class="name-1">عبد الله بن عباس</span>: <span class="qpc-hafs">﴿لِيَجْزِيَ الَّذِينَ آمَنُوا وعَمِلُوا الصّالِحاتِ مِن فَضْلِهِ﴾</span> ليثيبهم اللهُ أكثرَ مِن ثواب أعمالهم{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٠٧٣٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان:</span> <span class="qpc-hafs">﴿لِيَجْزِيَ﴾</span> يعني: لكي يجزي اللهُ ﷿ في القيامة <span class="qpc-hafs">﴿الَّذِينَ آمَنُوا﴾</span> بتوحيد الله ﷿؛ <span class="qpc-hafs">﴿إنَّهُ لا يُحِبُّ الكافِرِينَ﴾</span> بتوحيد الله ﷿{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٠٧٣٨<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام:</span> <span class="qpc-hafs">﴿لِيَجْزِيَ الَّذِينَ آمَنُوا وعَمِلُوا الصّالِحاتِ مِن فَضْلِهِ﴾</span> فبفضله يدخلهم الجنة{3}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير البغوي ٦/٢٧٥.|2:تفسير مقاتل بن سليمان ٣/٤١٨.|3:تفسير يحيى بن سلام ٢/٦٦٤.
  30,46,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَمِنۡ ءَایَـٰتِهِۦۤ أَن یُرۡسِلَ ٱلرِّیَاحَ مُبَشِّرَ ٰ⁠تࣲ وَلِیُذِیقَكُم مِّن رَّحۡمَتِهِۦ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٠٧٣٩<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق عبد الله بن أبي نجيح- في قوله: <span class="qpc-hafs">﴿ومِن آياتِهِ أنْ يُرْسِلَ الرِّياحَ مُبَشِّراتٍ﴾</span> قال: بالمطر، <span class="qpc-hafs">﴿ولِيُذِيقَكُمْ مِن رَحْمَتِهِ﴾</span> قال: القَطْر{1}. (١١/٦٠٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٠٧٤٠<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿ولِيُذِيقَكُمْ مِن رَحْمَتِهِ﴾</span>، قال: المطر{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٠٧٤١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ومِن آياتِهِ﴾</span> يعني: ومِن علاماته ﷿وإن لم تروه- أن تعرفوا توحيده بصنعه ﷿ <span class="qpc-hafs">﴿أنْ يُرْسِلَ الرِّياحَ مُبَشِّراتٍ﴾</span> يعني: يستبشر بها الناس رجاء المطر، <span class="qpc-hafs">﴿ولِيُذِيقَكُمْ مِن رَحْمَتِهِ﴾</span> يقول: وليعطيكم مِن نعمته، يعني: المطر{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٠٧٤٢<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام:</span> <span class="qpc-hafs">﴿ولِيُذِيقَكُمْ مِن رَحْمَتِهِ﴾</span> وهو المطر{4}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَمِنۡ ءَایَـٰتِهِۦۤ أَن یُرۡسِلَ ٱلرِّیَاحَ مُبَشِّرَ ٰ⁠تࣲ وَلِیُذِیقَكُم مِّن رَّحۡمَتِهِۦ﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٦٠٧٤٣<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عمرو بن العاص</span> -من طريق عطاء- قال: الرياح ثمان؛ أربع منها عذاب، وأربع منها رحمة؛ فأما العذاب منها: فالقاصف، والعاصف، والعقيم، والصرصر، قال الله تعالى: <span class="qpc-hafs">﴿رِيحًا صَرْصَرًا فِي أيّامٍ نَحِساتٍ﴾</span> [فصلت:١٦]، قال: مشؤومات. وأما رياح الرحمة: فالناشرات، والمبشرات، والمرسلات، والذاريات{5}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَلِتَجۡرِیَ ٱلۡفُلۡكُ بِأَمۡرِهِۦ وَلِتَبۡتَغُوا۟ مِن فَضۡلِهِۦ وَلَعَلَّكُمۡ تَشۡكُرُونَ ۝٤٦﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٠٧٤٤<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span>، في قوله: <span class="qpc-hafs">﴿ولِتَجْرِيَ الفُلْكُ بِأَمْرِهِ﴾</span> قال: السفن في البحار، <span class="qpc-hafs">﴿ولِتَبْتَغُوا مِن فَضْلِهِ﴾</span> قال: التجارة في السفن{6}. (١١/٦٠٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٠٧٤٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ولِتَجْرِيَ الفُلْكُ﴾</span> في البحر <span class="qpc-hafs">﴿بأمره ولِتَبْتَغُوا﴾</span> في البحر <span class="qpc-hafs">﴿مِن فَضْلِهِ﴾</span> يعني: الرزق، كل هذا بالرياح، <span class="qpc-hafs">﴿ولَعَلَّكُمْ تَشْكُرُونَ﴾</span> ربَّ هذه النِّعَم؛ فتُوَحِّدونه{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٠٧٤٦<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿ولِتَجْرِيَ الفُلْكُ﴾</span> السفن، <span class="qpc-hafs">﴿ولَعَلَّكُمْ تَشْكُرُونَ﴾</span> أي: لكي تشكروا{4}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير مجاهد (٥٣٩)، وأخرجه ابن جرير ١٨/٥١٨. وعلقه يحيى بن سلام ٢/٦٦٤. وعزاه السيوطي إلى الفريابي، وابن المنذر، وابن أبي حاتم.|2:أخرجه ابن جرير ١٨/٥١٨.|3:تفسير مقاتل بن سليمان ٣/٤١٨.|4:تفسير يحيى بن سلام ٢/٦٦٤.|5:أخرجه ابن أبي الدنيا في كتاب المطر والرعد والبرق والريح -موسوعة الإمام ابن أبي الدنيا ٨/٤٥١ (١٧٤)-.|6:علَّقه يحيى بن سلام ٢/٦٦٤. وعزاه السيوطي إلى ابن جرير، والفريابي، وابن المنذر، وابن أبي حاتم.|7:تفسير مقاتل بن سليمان ٣/٤١٨.|8:تفسير يحيى بن سلام ٢/٦٦٤.
  30,47,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَلَقَدۡ أَرۡسَلۡنَا مِن قَبۡلِكَ رُسُلًا إِلَىٰ قَوۡمِهِمۡ فَجَاۤءُوهُم بِٱلۡبَیِّنَـٰتِ فَٱنتَقَمۡنَا مِنَ ٱلَّذِینَ أَجۡرَمُوا۟ۖ وَكَانَ حَقًّا عَلَیۡنَا نَصۡرُ ٱلۡمُؤۡمِنِینَ ۝٤٧﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٠٧٤٧<span class="dash">-</span></span> عن أبي الدرداء، في قوله تعالى: <span class="qpc-hafs">﴿وكانَ حَقًّا عَلَيْنا نَصْرُ المُؤْمِنِينَ﴾</span>، قال: سمعتُ رسول الله ﷺ يقول: «<b>ما من امرئ مسلم يرُدُّ عن عرض أخيه إلا كان حقًّا على الله أن يرُدَّ عنه نار جهنم يوم القيامة</b>». ثم تلا: <span class="qpc-hafs">﴿وكانَ حَقًّا عَلَيْنا نَصْرُ المُؤْمِنِينَ﴾</span>{1}. (١١/٦٠٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٠٧٤٨<span class="dash">-</span></span> قال <span class="name-2">الحسن البصري</span>: <span class="qpc-hafs">﴿وكانَ حَقًّا عَلَيْنا نَصْرُ المُؤْمِنِينَ﴾</span> أنجاهم مع الرسل مِن عذاب الأُمَم{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٠٧٤٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ولَقَدْ أرْسَلْنا مِن قَبْلِكَ رُسُلًا إلى قَوْمِهِمْ فَجاءُوهُمْ بِالبَيِّناتِ﴾</span> فأخبروا قومهم بالعذاب أنّه نازل بهم في الدنيا إن لم يؤمنوا، فكذبوهم بالعذاب أنه غير نازل بهم في الدنيا، فعذَّبهم الله ﷿، فذلك قوله: <span class="qpc-hafs">﴿فانْتَقَمْنا﴾</span> بالعذاب <span class="qpc-hafs">﴿مِنَ الَّذِينَ أجْرَمُوا﴾</span> يعني: الذين أشركوا، <span class="qpc-hafs">﴿وكانَ حَقًّا عَلَيْنا نَصْرُ المُؤْمِنِينَ﴾</span> يعني: المصدقين للأنبياء ﵈ بالعذاب، فكان نصرُهم أنّ الله ﷿ أنجاهم مِن العذاب مع الرسل{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٠٧٥٠<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿ولَقَدْ أرْسَلْنا مِن قَبْلِكَ رُسُلًا إلى قَوْمِهِمْ فَجاءُوهُمْ بِالبَيِّناتِ﴾</span> أي: فكذبوا، <span class="qpc-hafs">﴿فانْتَقَمْنا مِنَ الَّذِينَ أجْرَمُوا﴾</span> أشركوا، <span class="qpc-hafs">﴿وكانَ حَقًّا عَلَيْنا نَصْرُ المُؤْمِنِينَ﴾</span> إجابة دعاء الأنبياء على قومهم بالهلاك حين كذبوهم، فأُمِروا بالدعاء عليهم، ثم استجيب لهم، فأهلكهم الله{4}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه الطبراني في مكارم الأخلاق ص٣٦٢ (١٣٤)، والبغوي في شرح السنة ١٣/١٠٦ (٣٥٢٨)، والثعلبي ٧/٣٠٥-٣٠٦. وأخرجه أحمد ٤٥/٥٢٣-٥٢٤ (٢٧٥٣٦)، ٤٥/٥٢٨ (٢٧٥٤٣)، والترمذي ٤/٥٥ (٢٠٤٤) كلاهما دون ذكر الآية.</p><p>قال الترمذي: «هذا حديث حسن». وقال ابن القطان في بيان الوهم والإيهام ٣/٦٠١ (١٤٠٤) تعليقًا على كلام الترمذي: «ولم يبين لِمَ لا يصِحّ؛ وذلك -والله أعلم- لأنه من رواية ابن المبارك، عن أبي بكر النهشلي -وهو ثقة-، عن مرزوق أبي بكر التيمي، عن أم الدرداء، عن أبي الدرداء. ومرزوق هذا هو والد يحيى بن أبي بكير، وهو كوفي، يروي عنه الثوري وشريك وإسرائيل وليث بن أبي سليم وعمر بن محمد، وغيرهم، ولكنه مع ذلك لم تثبت عدالته، وهو شبيه بالمجهول الحال». وأورده الدارقطني في العلل ٦/٢٢٥ (١٠٩١). وقال الألباني في الضعيفة ٢/٥٠ (٥٨٠): «ضعيف».|2:تفسير الثعلبي ٧/٣٠٥، وتفسير البغوي ٦/٢٧٥.|3:تفسير مقاتل بن سليمان ٣/٤١٨.|4:تفسير يحيى بن سلام ٢/٦٦٥.
  30,48,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿ٱللَّهُ ٱلَّذِی یُرۡسِلُ ٱلرِّیَـٰحَ فَتُثِیرُ سَحَابࣰا فَیَبۡسُطُهُۥ فِی ٱلسَّمَاۤءِ كَیۡفَ یَشَاۤءُ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٠٧٥١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، قال في قوله: <span class="qpc-hafs">﴿اللَّهُ الَّذِي يُرْسِلُ الرِّياحَ فَتُثِيرُ سَحابًا فَيَبْسُطُهُ فِي السَّماءِ كَيْفَ يَشاءُ﴾</span>: يرسل الله الريح، فتحمل الماء من السحاب، فتمر به السحاب، فتَدِرُّ كما تدِرُّ الناقة، وثجّاج{1} مثل العَزالى{2}، غير أنه مُتَفَرِّق{3}. (١١/٦٠٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٠٧٥٢<span class="dash">-</span></span> عن <span class="name-2">عبيد بن عمير</span> -من طريق حبيب- <span class="qpc-hafs">﴿يُرْسِلُ الرِّياحَ فَتُثِيرُ سَحابًا﴾</span>، قال: الرياح أربع: يبعث الله ريحًا فتَقُمُّ الأرضَ قَمًّا، ثم يبعث الله الريح الثانية فتثير سحابًا، فيجعله في السماء كسفًا، ثم يبعث الله الريح الثالثة فتؤلف بينه، فيجعله ركامًا، ثم يبعث الريح الرابعة فتمطر{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٠٧٥٣<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿فَيَبْسُطُهُ فِي السَّماءِ﴾</span>، قال: يجمعه{5}. (١١/٦٠٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٠٧٥٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿اللَّهُ الَّذِي يُرْسِلُ الرِّياحَ فَتُثِيرُ سَحابًا فَيَبْسُطُهُ فِي السَّماءِ كَيْفَ يَشاءُ﴾</span> يجعل الريح السحاب قِطَعًا، يحمل بعضها على بعض، فيضمه، ثم يبسط السحاب في السماء كيف يشاء الله تعالى، إن شاء بسطه على مسيرة يومٍ أو بعض يوم أو مسيرة أيام يمطرون{6}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿ٱللَّهُ ٱلَّذِی یُرۡسِلُ ٱلرِّیَـٰحَ فَتُثِیرُ سَحَابࣰا فَیَبۡسُطُهُۥ فِی ٱلسَّمَاۤءِ كَیۡفَ یَشَاۤءُ﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٦٠٧٥٥<span class="dash">-</span></span> عن جابر، عن <span class="name-2">عطاء [بن أبي رباح]</span>، قال: السحاب يخرج من الأرض. ثم تلا: <span class="qpc-hafs">﴿الله الذي يرسل الرياح فتثير سحابا﴾</span>{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٠٧٥٦<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span>، قال: يرسل الله الريح، فتأتي بالسحابِ مِن بين الخافقين؛ طرف السماء والأرض حين يلتقيان، فتخرجه، ثم تنشره، فيبسطه في السماء كيف يشاء، فيسيل الماء على السحاب، ثم يمطر السحاب بعد ذلك{8}. (١١/٦٠٨)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَیَجۡعَلُهُۥ كِسَفࣰا فَتَرَى ٱلۡوَدۡقَ یَخۡرُجُ مِنۡ خِلَـٰلِهِۦۖ فَإِذَاۤ أَصَابَ بِهِۦ مَن یَشَاۤءُ مِنۡ عِبَادِهِۦۤ إِذَا هُمۡ یَسۡتَبۡشِرُونَ ۝٤٨﴾</span> - قراءات</h3></p><p><div></p><p><p><span class="item-no">٦٠٧٥٧<span class="dash">-</span></span> عن <span class="name-2">الضحاك بن مزاحم</span> أنّه كان يقرأ: (يَخْرُجُ مِن خَلَلَهِ)، أي: مِن خَلَل السحاب{9}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَیَجۡعَلُهُۥ كِسَفࣰا فَتَرَى ٱلۡوَدۡقَ یَخۡرُجُ مِنۡ خِلَـٰلِهِۦۖ فَإِذَاۤ أَصَابَ بِهِۦ مَن یَشَاۤءُ مِنۡ عِبَادِهِۦۤ إِذَا هُمۡ یَسۡتَبۡشِرُونَ ۝٤٨﴾</span> - تفسير الآية</h3></p><p><div></p><p><p><span class="item-no">٦٠٧٥٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، في قوله: <span class="qpc-hafs">﴿ويَجْعَلُهُ كِسَفًا﴾</span> قال: قِطَعًا يجعل بعضها فوق بعض، <span class="qpc-hafs">﴿فَتَرى الوَدْقَ﴾</span> قال: المطر، <span class="qpc-hafs">﴿يَخْرُجُ مِن خِلالِهِ﴾</span> قال: مِن بينه{10}. (١١/٦٠٩). (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٠٧٥٩<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿فَتَرى الوَدْقَ﴾</span>، قال: القَطْر{11}. (١١/٦٠٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٠٧٦٠<span class="dash">-</span></span> عن <span class="name-2">الضحاك بن مزاحم</span>، في قوله: <span class="qpc-hafs">﴿ويَجْعَلُهُ كِسَفًا﴾</span>، قال: سماء دون سماء{3}. (١١/٦٠٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٠٧٦١<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿ويَجْعَلُهُ كِسَفًا﴾</span>، قال: قِطعًا{5}. (١١/٦٠٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٠٧٦٢<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿يَخْرُجُ مِن خِلالِهِ﴾</span>، قال: مِن بين السحاب{14}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٠٧٦٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فَتَرى الوَدْقَ﴾</span> يعني: المطر <span class="qpc-hafs">﴿يخرج من خلاله﴾</span> يعني: مِن خلال السحاب، <span class="qpc-hafs">﴿فَإذا أصابَ بِهِ﴾</span> يعني: بالمطر <span class="qpc-hafs">﴿إذا هُمْ يَسْتَبْشِرُونَ﴾</span> يعني: إذا هم يفرحون بالمطر عليهم{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٠٧٦٤<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام:</span> <span class="qpc-hafs">﴿اللَّهُ الَّذِي يُرْسِلُ الرِّياحَ فَتُثِيرُ سَحابًا فَيَبْسُطُهُ فِي السَّماءِ كَيْفَ يَشاءُ ويَجْعَلُهُ كِسَفًا﴾</span> يعني: قِطَعًا بعضه على بعض، <span class="qpc-hafs">﴿يَخْرُجُ مِن خِلالِهِ﴾</span> مِن خلال السحاب{16}<span class=comment-ref>٥١١٧</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٥١١٧</span> ذكر <u>ابنُ عطية</u> (٧/٣٣) في عود الضمير من قوله: <span class="qpc-hafs">﴿من خلاله﴾</span> احتمالين: <b>الأول</b>: أن يعود على السحاب. كما ورد في أقوال السلف. <b>الثاني</b>: أن يعود على الكسف، وذلك على قراءة مَن سكَّن السين فيها.</div></p></div>",footnotes:1:ثجاج: شديد الانصباب. اللسان (ثجج).|2:العزالى: جمع العزلاء، وهو فم المزادة الأسفل. النهاية ٣/٢٣١.|3:عزاه السيوطي إلى ابن أبي حاتم.|4:أخرجه بن جرير ١٨/٥٢٠.|5:أخرجه ابن جرير ١٨/٥٢٠. وعزاه السيوطي إلى ابن أبي حاتم.|6:تفسير مقاتل بن سليمان ٣/٤١٩.|7:أخرجه ابن أبي حاتم ٨/٢٦١٧، وأبو الشيخ في العظمة ٤/١٢٣٥ (٧٠١).|8:أخرجه أبو الشيخ في العظمة (٨٣١).|9:علقه يحيى بن سلام ٢/٦٦٥.</p><p>وهي قراءة شاذة، تروى أيضًا عن علي بن أبي طالب، وابن عباس، والحسن. انظر: المحتسب ٢/١٦٤.|10:أخرجه أبو يعلى (٢٦٦٥). وعزاه السيوطي إلى ابن المنذر.|11:تفسير مجاهد (٥٤٠)، وأخرجه الفريابي -كما في التغليق ٤/٢٧٩-، وابن جرير ١٨/٥٢١، وإسحاق البستي ص٨٤ من طريق ابن جريج بلفظ: المطر. وكذا علَّقه يحيى بن سلام ٢/٦٦٥.|12:عزاه السيوطي إلى ابن أبي حاتم.|13:أخرجه ابن جرير ١٨/٥٢٠. وعزاه السيوطي إلى ابن أبي حاتم.|14:أخرجه ابن جرير ١٨/٥٢٠.|15:تفسير مقاتل بن سليمان ٣/٤١٩.|16:تفسير يحيى بن سلام ٢/٦٦٥.
  30,49,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَإِن كَانُوا۟ مِن قَبۡلِ أَن یُنَزَّلَ عَلَیۡهِم مِّن قَبۡلِهِۦ لَمُبۡلِسِینَ ۝٤٩﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٠٧٦٥<span class="dash">-</span></span> عن <span class="name-2">الضحاك بن مزاحم</span>، في قوله: <span class="qpc-hafs">﴿لَمُبْلِسِينَ﴾</span>، قال: لَقَنِطِين{1}. (١١/٦٠٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٠٧٦٦<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿لَمُبْلِسِينَ﴾</span>، قال: لَقَنِطِين{2}. (١١/٦٠٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٠٧٦٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وإنْ كانُوا مِن قَبْلِ أنْ يُنَزَّلَ عَلَيْهِمْ مِن قَبْلِهِ﴾</span> يعني: من قبل نزول المطر في السنين السبع، حين قحط عليهم المطر <span class="qpc-hafs">﴿لَمُبْلِسِينَ﴾</span> يعني: آيسِين مِن المطر{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٠٧٦٨<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام:</span> <span class="qpc-hafs">﴿وإنْ كانُوا مِن قَبْلِ أنْ يُنَزَّلَ عَلَيْهِمْ﴾</span> المطر <span class="qpc-hafs">﴿مِن قَبْلِهِ﴾</span> وهو كلام من كلام العرب مثنى، مثل قوله: <span class="qpc-hafs">﴿وهُمْ بِالآخِرَةِ هُمْ يُوقِنُونَ﴾</span> [النمل:٣]، وكقوله: <span class="qpc-hafs">﴿وهُمْ عَنِ الآخِرَةِ هُمْ غافِلُونَ﴾</span> [الروم:٧]، <span class="qpc-hafs">﴿لَمُبْلِسِينَ﴾</span> ليائسين من المطر، كقوله: <span class="qpc-hafs">﴿وهو الذي ينزل الغيث من بعد ما قنطوا﴾</span> [الشورى:٢٨]{4}<span class=comment-ref>٥١١٨</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٥١١٨</span> أورد <u>ابنُ تيمية</u> (٥/١٨٨-١٨٩) استشكال بعض الناس لتكرير قوله تعالى: <span class="qpc-hafs">﴿قبله﴾</span> بعدما قال: <span class="qpc-hafs">﴿وإن كانوا من قبل﴾</span>، ثم <span class="comment-type-4">أجاب</span> ﵀ بقوله: «وأما قوله: <span class="qpc-hafs">﴿من قبل أن ينزل عليهم من قبله﴾</span> فليس من التكرار، بل تحته معنى دقيق، والمعنى فيه: وإن كانوا من قبل أن ينزل عليهم الودق من قبل هذا النزول لمبلسين؛ فهنا قبليتان: قبلية لنزوله مطلقًا، وقبلية لذلك النزول المعين أن لا يكون متقدمًا على ذلك الوقت، فيئسوا قبل نزوله يأسين: يأسًا لعدمه مرئيًا، ويأسًا لتأخره عن وقته؛ فقبل الأولى ظرف اليأس، وقبل الثانية ظرف المجيء والإنزال. ففي الآية ظرفان معمولان وفعلان مختلفان عاملان فيهما، وهما الإنزال والإبلاس؛ فأحد الظرفين متعلق بالإبلاس، والثاني متعلق بالنزول، وتمثيل هذا: أن تقول إذا كنت معتادًا للعطاء من شخص فتأخر عن ذلك الوقت ثم أتاك به: قد كنتُ آيِسًا».</div></p></div>",footnotes:1:عزاه السيوطي إلى ابن أبي حاتم.|2:أخرجه ابن جرير ١٨/٥٢١ بلفظ: قانطين. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.|3:تفسير مقاتل بن سليمان ٣/٤١٩.|4:تفسير يحيى بن سلام ٢/٦٦٥.
  30,50,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿فَٱنظُرۡ إِلَىٰۤ ءَاثَـٰرِ رَحۡمَتِ ٱللَّهِ كَیۡفَ یُحۡیِ ٱلۡأَرۡضَ بَعۡدَ مَوۡتِهَاۤۚ إِنَّ ذَ ٰ⁠لِكَ لَمُحۡیِ ٱلۡمَوۡتَىٰۖ وَهُوَ عَلَىٰ كُلِّ شَیۡءࣲ قَدِیرࣱ ۝٥٠﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٦٠٧٦٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: قال اللهُ لنبيِّه محمد ﷺ: <span class="qpc-hafs">﴿فانْظُرْ﴾</span> يا محمد <span class="qpc-hafs">﴿إلى آثارِ رَحْمَتِ اللَّهِ﴾</span> يعني: النبت مِن آثار المطر؛ <span class="qpc-hafs">﴿كَيْفَ يُحْيِ الأَرْضَ بَعْدَ مَوْتِها﴾</span> بالمطر، فتنبت من بعد موتها حين لم يكن فيها نبت، <span class="qpc-hafs">﴿إنَّ ذَلِكَ﴾</span> يقول: إن هذا الذي فعل ما ترون <span class="qpc-hafs">﴿لَمُحْيِ المَوْتى﴾</span> في الآخرة؛ فلا تكذبوا بالبعث، يعني: كفار مكة، ثم قال تعالى: <span class="qpc-hafs">﴿وهُوَ عَلى كُلِّ شَيْءٍ قَدِيرٌ﴾</span> مِن البعث وغيره{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٦٠٧٧٠<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام:</span> <span class="qpc-hafs">﴿فانْظُرْ إلى آثارِ رَحْمَتِ اللَّهِ﴾</span> يعني: المطر، <span class="qpc-hafs">﴿كَيْفَ يُحْيِ الأَرْضَ بَعْدَ مَوْتِها﴾</span> يعني: النبات الذي أنبته الله -تبارك وتعالى- بذلك المطر، <span class="qpc-hafs">﴿إنَّ ذَلِكَ لَمُحْيِ المَوْتى وهُوَ عَلى كُلِّ شَيْءٍ قَدِيرٌ﴾</span> أي: فالذي أنبت هذا النبات بذلك المطر قادِرٌ على أن يبعث الخلق يوم القيامة{2}<span class=comment-ref>٥١١٩</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٥١١٩</span> ذكر <u>ابنُ عطية</u> (٧/٣٤) في فاعل <span class="qpc-hafs">﴿يحي﴾</span> احتمالين، فقال: «وقوله <span class="qpc-hafs">﴿كَيْفَ يُحْيِ﴾</span> يحتمل أن يكون الضمير الذي في الفعل للأثر، ويحتمل أن يكون لله تعالى». ثم <span class="comment-type-3">رجّح</span> الأخير بقوله: «وهذا أظهر». ولم يذكر مستندًا.</div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٣/٤١٩.|2:تفسير يحيى بن سلام ٢/٦٦٥-٦٦٦.