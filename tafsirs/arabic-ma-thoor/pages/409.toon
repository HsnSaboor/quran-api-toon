quran[9]{c,v,t}:
30,42," <q>﴿قُلۡ سِیرُوا۟ فِی ٱلۡأَرۡضِ فَٱنظُرُوا۟ كَیۡفَ كَانَ عَـٰقِبَةُ ٱلَّذِینَ مِن قَبۡلُۚ كَانَ أَكۡثَرُهُم مُّشۡرِكِینَ ۝٤٢﴾</q> - تفسير ٦٠٧٢٣- قال مقاتل بن سليمان: <q>﴿قُلْ سِيرُوا فِي الأَرْضِ فانْظُرُوا كَيْفَ كانَ عاقِبَةُ الَّذِينَ مِن قَبْلُ﴾</q> يعني: قبل كفار مكة مِن الأمم الخالية، <q>﴿كانَ أكْثَرُهُمْ مُشْرِكِينَ﴾</q> فكان عاقبتهم الهلاك في الدنيا{1}. (ز) ٦٠٧٢٤- قال يحيى بن سلّام: <q>﴿قُلْ سِيرُوا فِي الأَرْضِ فانْظُرُوا كَيْفَ كانَ عاقِبَةُ الَّذِينَ مِن قَبْلُ﴾</q> كان عاقبتهم أن دمَّر الله عليهم، ثم صيَّرهم إلى النار، <q>﴿كانَ أكْثَرُهُمْ مُشْرِكِينَ﴾</q> أي: فأهلكهم{2}. (ز) ",footnotes:1:تفسير مقاتل بن سليمان ٣/٤١٧.تفسير يحيى بن سلام ٢/٦٦٣.
30,43," <q>﴿فَأَقِمۡ وَجۡهَكَ لِلدِّینِ ٱلۡقَیِّمِ مِن قَبۡلِ أَن یَأۡتِیَ یَوۡمࣱ لَّا مَرَدَّ لَهُۥ مِنَ ٱللَّهِۖ﴾</q> - تفسير ٦٠٧٢٥- عن قتادة بن دعامة -من طريق سعيد- <q>﴿فَأَقِمْ وجْهَكَ لِلدِّينِ القَيِّمِ﴾</q> قال: الإسلام، <q>﴿مِن قَبْلِ أنْ يَأْتِيَ يَوْمٌ لا مَرَدَّ لَهُ مِنَ اللَّهِ﴾</q> قال: يوم القيامة{1}. (١١/٦٠٧) ٦٠٧٢٦- قال إسماعيل السُّدِّيّ: <q>﴿فَأَقِمْ وجْهَكَ لِلدِّينِ القَيِّمِ﴾</q> التوحيد{2}. (ز) ٦٠٧٢٧- قال يحيى بن سلّام: <q>﴿فَأَقِمْ وجْهَكَ﴾</q> أي: وجهتك <q>﴿لِلدِّينِ القَيِّمِ﴾</q> وهو الإسلام، <q>﴿مِن قَبْلِ أنْ يَأْتِيَ يَوْمٌ لا مَرَدَّ لَهُ مِنَ اللَّهِ﴾</q> يعني: يوم القيامة{3}. (ز) <q>﴿یَوۡمَىِٕذࣲ یَصَّدَّعُونَ ۝٤٣﴾</q> - تفسير ٦٠٧٢٨- عن عبد الله بن عباس -من طريق علي- في قوله: <q>﴿يَوْمَئِذٍ يَصَّدَّعُونَ﴾</q>، قال: يتفرقون{4}. (١١/٦٠٧) ٦٠٧٢٩- عن قتادة بن دعامة -من طريق سعيد- <q>﴿يَوْمَئِذٍ يَصَّدَّعُونَ﴾</q>، قال: فريق في الجنة، وفريق في السعير{1}. (١١/٦٠٧) ٦٠٧٣٠- قال مقاتل بن سليمان: <q>﴿يَوْمَئِذٍ يَصَّدَّعُونَ﴾</q>، يعني: بعد الحساب، يَتَفَرَّقون إلى الجنة، وإلى النار{6}. (ز) ٦٠٧٣١- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿يَوْمَئِذٍ يَصَّدَّعُونَ﴾</q>، قال:يتفرقون. وقرأ: <q>﴿فَأَمّا الَّذِينَ آمَنُوا وعَمِلُوا الصّالِحاتِ فَهُمْ فِي رَوْضَةٍ يُحْبَرُونَ * وأَمّا الَّذِينَ كَفَرُوا وكَذَّبُوا بِآياتِنا ولِقاءِ الآخِرَةِ فَأُولَئِكَ فِي العَذابِ مُحْضَرُونَ﴾</q> [الروم:١٥-١٦]، قال: هذا حين يصدّعون؛ يتفرقون إلى الجنة والنار{7}. (١١/٦٠٧) ٦٠٧٣٢- قال يحيى بن سلّام: <q>﴿يَوْمَئِذٍ يَصَّدَّعُونَ﴾</q>، يعني: يتفرّقون؛ فريق في الجنة، وفريق في السعير{3}. (ز) ",footnotes:1:أخرجه ابن جرير ١٨/٥١٥. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.علَّقه يحيى بن سلام ٢/٦٦٣.تفسير يحيى بن سلام ٢/٦٦٣.أخرجه ابن جرير ١٨/٥١٥، وابن أبي حاتم -كما في التغليق ٤/٢٧٩-. وعزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ١٨/٥١٥. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.تفسير مقاتل بن سليمان ٣/٤١٧.أخرجه ابن جرير ١٨/٥١٥. وعزاه السيوطي إلى ابن أبي حاتم.تفسير يحيى بن سلام ٢/٦٦٣.
30,44," <q>﴿مَن كَفَرَ فَعَلَیۡهِ كُفۡرُهُۥۖ وَمَنۡ عَمِلَ صَـٰلِحࣰا فَلِأَنفُسِهِمۡ یَمۡهَدُونَ ۝٤٤﴾</q> - تفسير ٦٠٧٣٣- عن مجاهد بن جبر -من طريق ابن أبى نجيح- في قوله: <q>﴿فَلِأَنْفُسِهِمْ يَمْهَدُونَ﴾</q>، قال: يُسَوُّون المضاجع في القبر{1}. (١١/٦٠٧) ٦٠٧٣٤- قال مقاتل بن سليمان: <q>﴿مَن كفر﴾</q> بالله <q>﴿فعليه﴾</q> إثم كفره، <q>﴿ومَن عَمِلَ صالِحًا فَلِأَنْفُسِهِمْ يَمْهَدُونَ﴾</q> يعني: يُقَدِّمون{2}. (ز) ٦٠٧٣٥- قال يحيى بن سلّام: <q>﴿مَن كَفَرَ فَعَلَيْهِ كُفْرُهُ﴾</q> يثاب عليه النار، <q>﴿ومَن عَمِلَ صالِحًا فَلِأَنْفُسِهِمْ يَمْهَدُونَ﴾</q> يوطئون في الدنيا القرار في الآخرة بالعمل الصالح ... عن سعيد بن أبي هلال، قال: قال رسول الله ﷺ: «نعمت المطية الدنيا! فارتحلوا تبلغكم الآخرة». عن الخليل بن مرة ذكره بإسناده، قال: يقول الله -تبارك وتعالى-: ادخلوا الجنة برحمتي، واقتسموها بأعمالكم{3}. (ز) ",footnotes:1:تفسير مجاهد (٥٣٩)، وأخرجه الفريابي -كما في التغليق ٤/٢٧٩-، والبزار في البحر الزخار (مسند البزار) ٨/١٨٠ (٣٢١٣)، وابن جرير ١٨/٥١٦، وأبو نعيم في الحلية ٣/٢٧٩، والبيهقي في عذاب القبر (١٥٥). وعلقه يحيى بن سلام ٢/٦٦٤. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.تفسير مقاتل بن سليمان ٣/٤١٧.أورده يحيى بن سلام ٢/٦٦٣-٦٦٤.
30,45," <q>﴿لِیَجۡزِیَ ٱلَّذِینَ ءَامَنُوا۟ وَعَمِلُوا۟ ٱلصَّـٰلِحَـٰتِ مِن فَضۡلِهِۦۤۚ إِنَّهُۥ لَا یُحِبُّ ٱلۡكَـٰفِرِینَ ۝٤٥﴾</q> - تفسير ٦٠٧٣٦- قال عبد الله بن عباس: <q>﴿لِيَجْزِيَ الَّذِينَ آمَنُوا وعَمِلُوا الصّالِحاتِ مِن فَضْلِهِ﴾</q> ليثيبهم اللهُ أكثرَ مِن ثواب أعمالهم{1}. (ز) ٦٠٧٣٧- قال مقاتل بن سليمان: <q>﴿لِيَجْزِيَ﴾</q> يعني: لكي يجزي اللهُ ﷿ في القيامة <q>﴿الَّذِينَ آمَنُوا﴾</q> بتوحيد الله ﷿؛ <q>﴿إنَّهُ لا يُحِبُّ الكافِرِينَ﴾</q> بتوحيد الله ﷿{2}. (ز) ٦٠٧٣٨- قال يحيى بن سلّام: <q>﴿لِيَجْزِيَ الَّذِينَ آمَنُوا وعَمِلُوا الصّالِحاتِ مِن فَضْلِهِ﴾</q> فبفضله يدخلهم الجنة{3}. (ز) ",footnotes:1:تفسير البغوي ٦/٢٧٥.تفسير مقاتل بن سليمان ٣/٤١٨.تفسير يحيى بن سلام ٢/٦٦٤.
30,46," <q>﴿وَمِنۡ ءَایَـٰتِهِۦۤ أَن یُرۡسِلَ ٱلرِّیَاحَ مُبَشِّرَ ٰ⁠تࣲ وَلِیُذِیقَكُم مِّن رَّحۡمَتِهِۦ﴾</q> - تفسير ٦٠٧٣٩- عن مجاهد بن جبر -من طريق عبد الله بن أبي نجيح- في قوله: <q>﴿ومِن آياتِهِ أنْ يُرْسِلَ الرِّياحَ مُبَشِّراتٍ﴾</q> قال: بالمطر، <q>﴿ولِيُذِيقَكُمْ مِن رَحْمَتِهِ﴾</q> قال: القَطْر{1}. (١١/٦٠٨) ٦٠٧٤٠- عن قتادة بن دعامة -من طريق سعيد- <q>﴿ولِيُذِيقَكُمْ مِن رَحْمَتِهِ﴾</q>، قال: المطر{2}. (ز) ٦٠٧٤١- قال مقاتل بن سليمان: <q>﴿ومِن آياتِهِ﴾</q> يعني: ومِن علاماته ﷿وإن لم تروه- أن تعرفوا توحيده بصنعه ﷿ <q>﴿أنْ يُرْسِلَ الرِّياحَ مُبَشِّراتٍ﴾</q> يعني: يستبشر بها الناس رجاء المطر، <q>﴿ولِيُذِيقَكُمْ مِن رَحْمَتِهِ﴾</q> يقول: وليعطيكم مِن نعمته، يعني: المطر{3}. (ز) ٦٠٧٤٢- قال يحيى بن سلّام: <q>﴿ولِيُذِيقَكُمْ مِن رَحْمَتِهِ﴾</q> وهو المطر{4}. (ز) <q>﴿وَمِنۡ ءَایَـٰتِهِۦۤ أَن یُرۡسِلَ ٱلرِّیَاحَ مُبَشِّرَ ٰ⁠تࣲ وَلِیُذِیقَكُم مِّن رَّحۡمَتِهِۦ﴾</q> - آثار متعلقة بالآية ٦٠٧٤٣- عن عبد الله بن عمرو بن العاص -من طريق عطاء- قال: الرياح ثمان؛ أربع منها عذاب، وأربع منها رحمة؛ فأما العذاب منها: فالقاصف، والعاصف، والعقيم، والصرصر، قال الله تعالى: <q>﴿رِيحًا صَرْصَرًا فِي أيّامٍ نَحِساتٍ﴾</q> [فصلت:١٦]، قال: مشؤومات. وأما رياح الرحمة: فالناشرات، والمبشرات، والمرسلات، والذاريات{5}. (ز) <q>﴿وَلِتَجۡرِیَ ٱلۡفُلۡكُ بِأَمۡرِهِۦ وَلِتَبۡتَغُوا۟ مِن فَضۡلِهِۦ وَلَعَلَّكُمۡ تَشۡكُرُونَ ۝٤٦﴾</q> - تفسير ٦٠٧٤٤- عن مجاهد بن جبر، في قوله: <q>﴿ولِتَجْرِيَ الفُلْكُ بِأَمْرِهِ﴾</q> قال: السفن في البحار، <q>﴿ولِتَبْتَغُوا مِن فَضْلِهِ﴾</q> قال: التجارة في السفن{6}. (١١/٦٠٨) ٦٠٧٤٥- قال مقاتل بن سليمان: <q>﴿ولِتَجْرِيَ الفُلْكُ﴾</q> في البحر <q>﴿بأمره ولِتَبْتَغُوا﴾</q> في البحر <q>﴿مِن فَضْلِهِ﴾</q> يعني: الرزق، كل هذا بالرياح، <q>﴿ولَعَلَّكُمْ تَشْكُرُونَ﴾</q> ربَّ هذه النِّعَم؛ فتُوَحِّدونه{3}. (ز) ٦٠٧٤٦- قال يحيى بن سلّام: <q>﴿ولِتَجْرِيَ الفُلْكُ﴾</q> السفن، <q>﴿ولَعَلَّكُمْ تَشْكُرُونَ﴾</q> أي: لكي تشكروا{4}. (ز) ",footnotes:1:تفسير مجاهد (٥٣٩)، وأخرجه ابن جرير ١٨/٥١٨. وعلقه يحيى بن سلام ٢/٦٦٤. وعزاه السيوطي إلى الفريابي، وابن المنذر، وابن أبي حاتم.أخرجه ابن جرير ١٨/٥١٨.تفسير مقاتل بن سليمان ٣/٤١٨.تفسير يحيى بن سلام ٢/٦٦٤.أخرجه ابن أبي الدنيا في كتاب المطر والرعد والبرق والريح -موسوعة الإمام ابن أبي الدنيا ٨/٤٥١ (١٧٤)-.علَّقه يحيى بن سلام ٢/٦٦٤. وعزاه السيوطي إلى ابن جرير، والفريابي، وابن المنذر، وابن أبي حاتم.تفسير مقاتل بن سليمان ٣/٤١٨.تفسير يحيى بن سلام ٢/٦٦٤.
30,47," <q>﴿وَلَقَدۡ أَرۡسَلۡنَا مِن قَبۡلِكَ رُسُلًا إِلَىٰ قَوۡمِهِمۡ فَجَاۤءُوهُم بِٱلۡبَیِّنَـٰتِ فَٱنتَقَمۡنَا مِنَ ٱلَّذِینَ أَجۡرَمُوا۟ۖ وَكَانَ حَقًّا عَلَیۡنَا نَصۡرُ ٱلۡمُؤۡمِنِینَ ۝٤٧﴾</q> - تفسير ٦٠٧٤٧- عن أبي الدرداء، في قوله تعالى: <q>﴿وكانَ حَقًّا عَلَيْنا نَصْرُ المُؤْمِنِينَ﴾</q>، قال: سمعتُ رسول الله ﷺ يقول: «ما من امرئ مسلم يرُدُّ عن عرض أخيه إلا كان حقًّا على الله أن يرُدَّ عنه نار جهنم يوم القيامة». ثم تلا: <q>﴿وكانَ حَقًّا عَلَيْنا نَصْرُ المُؤْمِنِينَ﴾</q>{1}. (١١/٦٠٨) ٦٠٧٤٨- قال الحسن البصري: <q>﴿وكانَ حَقًّا عَلَيْنا نَصْرُ المُؤْمِنِينَ﴾</q> أنجاهم مع الرسل مِن عذاب الأُمَم{2}. (ز) ٦٠٧٤٩- قال مقاتل بن سليمان: <q>﴿ولَقَدْ أرْسَلْنا مِن قَبْلِكَ رُسُلًا إلى قَوْمِهِمْ فَجاءُوهُمْ بِالبَيِّناتِ﴾</q> فأخبروا قومهم بالعذاب أنّه نازل بهم في الدنيا إن لم يؤمنوا، فكذبوهم بالعذاب أنه غير نازل بهم في الدنيا، فعذَّبهم الله ﷿، فذلك قوله: <q>﴿فانْتَقَمْنا﴾</q> بالعذاب <q>﴿مِنَ الَّذِينَ أجْرَمُوا﴾</q> يعني: الذين أشركوا، <q>﴿وكانَ حَقًّا عَلَيْنا نَصْرُ المُؤْمِنِينَ﴾</q> يعني: المصدقين للأنبياء ﵈ بالعذاب، فكان نصرُهم أنّ الله ﷿ أنجاهم مِن العذاب مع الرسل{3}. (ز) ٦٠٧٥٠- قال يحيى بن سلّام: <q>﴿ولَقَدْ أرْسَلْنا مِن قَبْلِكَ رُسُلًا إلى قَوْمِهِمْ فَجاءُوهُمْ بِالبَيِّناتِ﴾</q> أي: فكذبوا، <q>﴿فانْتَقَمْنا مِنَ الَّذِينَ أجْرَمُوا﴾</q> أشركوا، <q>﴿وكانَ حَقًّا عَلَيْنا نَصْرُ المُؤْمِنِينَ﴾</q> إجابة دعاء الأنبياء على قومهم بالهلاك حين كذبوهم، فأُمِروا بالدعاء عليهم، ثم استجيب لهم، فأهلكهم الله{4}. (ز) ",footnotes:1:أخرجه الطبراني في مكارم الأخلاق ص٣٦٢ (١٣٤)، والبغوي في شرح السنة ١٣/١٠٦ (٣٥٢٨)، والثعلبي ٧/٣٠٥-٣٠٦. وأخرجه أحمد ٤٥/٥٢٣-٥٢٤ (٢٧٥٣٦)، ٤٥/٥٢٨ (٢٧٥٤٣)، والترمذي ٤/٥٥ (٢٠٤٤) كلاهما دون ذكر الآية. قال الترمذي: «هذا حديث حسن». وقال ابن القطان في بيان الوهم والإيهام ٣/٦٠١ (١٤٠٤) تعليقًا على كلام الترمذي: «ولم يبين لِمَ لا يصِحّ؛ وذلك -والله أعلم- لأنه من رواية ابن المبارك، عن أبي بكر النهشلي -وهو ثقة-، عن مرزوق أبي بكر التيمي، عن أم الدرداء، عن أبي الدرداء. ومرزوق هذا هو والد يحيى بن أبي بكير، وهو كوفي، يروي عنه الثوري وشريك وإسرائيل وليث بن أبي سليم وعمر بن محمد، وغيرهم، ولكنه مع ذلك لم تثبت عدالته، وهو شبيه بالمجهول الحال». وأورده الدارقطني في العلل ٦/٢٢٥ (١٠٩١). وقال الألباني في الضعيفة ٢/٥٠ (٥٨٠): «ضعيف».تفسير الثعلبي ٧/٣٠٥، وتفسير البغوي ٦/٢٧٥.تفسير مقاتل بن سليمان ٣/٤١٨.تفسير يحيى بن سلام ٢/٦٦٥.
30,48," <q>﴿ٱللَّهُ ٱلَّذِی یُرۡسِلُ ٱلرِّیَـٰحَ فَتُثِیرُ سَحَابࣰا فَیَبۡسُطُهُۥ فِی ٱلسَّمَاۤءِ كَیۡفَ یَشَاۤءُ﴾</q> - تفسير ٦٠٧٥١- عن عبد الله بن عباس، قال في قوله: <q>﴿اللَّهُ الَّذِي يُرْسِلُ الرِّياحَ فَتُثِيرُ سَحابًا فَيَبْسُطُهُ فِي السَّماءِ كَيْفَ يَشاءُ﴾</q>: يرسل الله الريح، فتحمل الماء من السحاب، فتمر به السحاب، فتَدِرُّ كما تدِرُّ الناقة، وثجّاج{1} مثل العَزالى{2}، غير أنه مُتَفَرِّق{3}. (١١/٦٠٩) ٦٠٧٥٢- عن عبيد بن عمير -من طريق حبيب- <q>﴿يُرْسِلُ الرِّياحَ فَتُثِيرُ سَحابًا﴾</q>، قال: الرياح أربع: يبعث الله ريحًا فتَقُمُّ الأرضَ قَمًّا، ثم يبعث الله الريح الثانية فتثير سحابًا، فيجعله في السماء كسفًا، ثم يبعث الله الريح الثالثة فتؤلف بينه، فيجعله ركامًا، ثم يبعث الريح الرابعة فتمطر{4}. (ز) ٦٠٧٥٣- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿فَيَبْسُطُهُ فِي السَّماءِ﴾</q>، قال: يجمعه{5}. (١١/٦٠٩) ٦٠٧٥٤- قال مقاتل بن سليمان: <q>﴿اللَّهُ الَّذِي يُرْسِلُ الرِّياحَ فَتُثِيرُ سَحابًا فَيَبْسُطُهُ فِي السَّماءِ كَيْفَ يَشاءُ﴾</q> يجعل الريح السحاب قِطَعًا، يحمل بعضها على بعض، فيضمه، ثم يبسط السحاب في السماء كيف يشاء الله تعالى، إن شاء بسطه على مسيرة يومٍ أو بعض يوم أو مسيرة أيام يمطرون{6}. (ز) <q>﴿ٱللَّهُ ٱلَّذِی یُرۡسِلُ ٱلرِّیَـٰحَ فَتُثِیرُ سَحَابࣰا فَیَبۡسُطُهُۥ فِی ٱلسَّمَاۤءِ كَیۡفَ یَشَاۤءُ﴾</q> - آثار متعلقة بالآية ٦٠٧٥٥- عن جابر، عن عطاء [بن أبي رباح]، قال: السحاب يخرج من الأرض. ثم تلا: <q>﴿الله الذي يرسل الرياح فتثير سحابا﴾</q>{7}. (ز) ٦٠٧٥٦- عن إسماعيل السُّدِّيّ، قال: يرسل الله الريح، فتأتي بالسحابِ مِن بين الخافقين؛ طرف السماء والأرض حين يلتقيان، فتخرجه، ثم تنشره، فيبسطه في السماء كيف يشاء، فيسيل الماء على السحاب، ثم يمطر السحاب بعد ذلك{8}. (١١/٦٠٨) <q>﴿وَیَجۡعَلُهُۥ كِسَفࣰا فَتَرَى ٱلۡوَدۡقَ یَخۡرُجُ مِنۡ خِلَـٰلِهِۦۖ فَإِذَاۤ أَصَابَ بِهِۦ مَن یَشَاۤءُ مِنۡ عِبَادِهِۦۤ إِذَا هُمۡ یَسۡتَبۡشِرُونَ ۝٤٨﴾</q> - قراءات ٦٠٧٥٧- عن الضحاك بن مزاحم أنّه كان يقرأ: (يَخْرُجُ مِن خَلَلَهِ)، أي: مِن خَلَل السحاب{9}. (ز) <q>﴿وَیَجۡعَلُهُۥ كِسَفࣰا فَتَرَى ٱلۡوَدۡقَ یَخۡرُجُ مِنۡ خِلَـٰلِهِۦۖ فَإِذَاۤ أَصَابَ بِهِۦ مَن یَشَاۤءُ مِنۡ عِبَادِهِۦۤ إِذَا هُمۡ یَسۡتَبۡشِرُونَ ۝٤٨﴾</q> - تفسير الآية ٦٠٧٥٨- عن عبد الله بن عباس، في قوله: <q>﴿ويَجْعَلُهُ كِسَفًا﴾</q> قال: قِطَعًا يجعل بعضها فوق بعض، <q>﴿فَتَرى الوَدْقَ﴾</q> قال: المطر، <q>﴿يَخْرُجُ مِن خِلالِهِ﴾</q> قال: مِن بينه{10}. (١١/٦٠٩). (ز) ٦٠٧٥٩- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿فَتَرى الوَدْقَ﴾</q>، قال: القَطْر{11}. (١١/٦٠٩) ٦٠٧٦٠- عن الضحاك بن مزاحم، في قوله: <q>﴿ويَجْعَلُهُ كِسَفًا﴾</q>، قال: سماء دون سماء{3}. (١١/٦٠٩) ٦٠٧٦١- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿ويَجْعَلُهُ كِسَفًا﴾</q>، قال: قِطعًا{5}. (١١/٦٠٩) ٦٠٧٦٢- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿يَخْرُجُ مِن خِلالِهِ﴾</q>، قال: مِن بين السحاب{14}. (ز) ٦٠٧٦٣- قال مقاتل بن سليمان: <q>﴿فَتَرى الوَدْقَ﴾</q> يعني: المطر <q>﴿يخرج من خلاله﴾</q> يعني: مِن خلال السحاب، <q>﴿فَإذا أصابَ بِهِ﴾</q> يعني: بالمطر <q>﴿إذا هُمْ يَسْتَبْشِرُونَ﴾</q> يعني: إذا هم يفرحون بالمطر عليهم{6}. (ز) ٦٠٧٦٤- قال يحيى بن سلّام: <q>﴿اللَّهُ الَّذِي يُرْسِلُ الرِّياحَ فَتُثِيرُ سَحابًا فَيَبْسُطُهُ فِي السَّماءِ كَيْفَ يَشاءُ ويَجْعَلُهُ كِسَفًا﴾</q> يعني: قِطَعًا بعضه على بعض، <q>﴿يَخْرُجُ مِن خِلالِهِ﴾</q> مِن خلال السحاب{16}٥١١٧. (ز) ٥١١٧ ذكر ابنُ عطية (٧/٣٣) في عود الضمير من قوله: <q>﴿من خلاله﴾</q> احتمالين: الأول: أن يعود على السحاب. كما ورد في أقوال السلف. الثاني: أن يعود على الكسف، وذلك على قراءة مَن سكَّن السين فيها. ",footnotes:1:ثجاج: شديد الانصباب. اللسان (ثجج).العزالى: جمع العزلاء، وهو فم المزادة الأسفل. النهاية ٣/٢٣١.عزاه السيوطي إلى ابن أبي حاتم.أخرجه بن جرير ١٨/٥٢٠.أخرجه ابن جرير ١٨/٥٢٠. وعزاه السيوطي إلى ابن أبي حاتم.تفسير مقاتل بن سليمان ٣/٤١٩.أخرجه ابن أبي حاتم ٨/٢٦١٧، وأبو الشيخ في العظمة ٤/١٢٣٥ (٧٠١).أخرجه أبو الشيخ في العظمة (٨٣١).علقه يحيى بن سلام ٢/٦٦٥. وهي قراءة شاذة، تروى أيضًا عن علي بن أبي طالب، وابن عباس، والحسن. انظر: المحتسب ٢/١٦٤.أخرجه أبو يعلى (٢٦٦٥). وعزاه السيوطي إلى ابن المنذر.تفسير مجاهد (٥٤٠)، وأخرجه الفريابي -كما في التغليق ٤/٢٧٩-، وابن جرير ١٨/٥٢١، وإسحاق البستي ص٨٤ من طريق ابن جريج بلفظ: المطر. وكذا علَّقه يحيى بن سلام ٢/٦٦٥.عزاه السيوطي إلى ابن أبي حاتم.أخرجه ابن جرير ١٨/٥٢٠. وعزاه السيوطي إلى ابن أبي حاتم.أخرجه ابن جرير ١٨/٥٢٠.تفسير مقاتل بن سليمان ٣/٤١٩.تفسير يحيى بن سلام ٢/٦٦٥.
30,49," <q>﴿وَإِن كَانُوا۟ مِن قَبۡلِ أَن یُنَزَّلَ عَلَیۡهِم مِّن قَبۡلِهِۦ لَمُبۡلِسِینَ ۝٤٩﴾</q> - تفسير ٦٠٧٦٥- عن الضحاك بن مزاحم، في قوله: <q>﴿لَمُبْلِسِينَ﴾</q>، قال: لَقَنِطِين{1}. (١١/٦٠٩) ٦٠٧٦٦- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿لَمُبْلِسِينَ﴾</q>، قال: لَقَنِطِين{2}. (١١/٦٠٩) ٦٠٧٦٧- قال مقاتل بن سليمان: <q>﴿وإنْ كانُوا مِن قَبْلِ أنْ يُنَزَّلَ عَلَيْهِمْ مِن قَبْلِهِ﴾</q> يعني: من قبل نزول المطر في السنين السبع، حين قحط عليهم المطر <q>﴿لَمُبْلِسِينَ﴾</q> يعني: آيسِين مِن المطر{3}. (ز) ٦٠٧٦٨- قال يحيى بن سلّام: <q>﴿وإنْ كانُوا مِن قَبْلِ أنْ يُنَزَّلَ عَلَيْهِمْ﴾</q> المطر <q>﴿مِن قَبْلِهِ﴾</q> وهو كلام من كلام العرب مثنى، مثل قوله: <q>﴿وهُمْ بِالآخِرَةِ هُمْ يُوقِنُونَ﴾</q> [النمل:٣]، وكقوله: <q>﴿وهُمْ عَنِ الآخِرَةِ هُمْ غافِلُونَ﴾</q> [الروم:٧]، <q>﴿لَمُبْلِسِينَ﴾</q> ليائسين من المطر، كقوله: <q>﴿وهو الذي ينزل الغيث من بعد ما قنطوا﴾</q> [الشورى:٢٨]{4}٥١١٨. (ز) ٥١١٨ أورد ابنُ تيمية (٥/١٨٨-١٨٩) استشكال بعض الناس لتكرير قوله تعالى: <q>﴿قبله﴾</q> بعدما قال: <q>﴿وإن كانوا من قبل﴾</q>، ثم أجاب ﵀ بقوله: «وأما قوله: <q>﴿من قبل أن ينزل عليهم من قبله﴾</q> فليس من التكرار، بل تحته معنى دقيق، والمعنى فيه: وإن كانوا من قبل أن ينزل عليهم الودق من قبل هذا النزول لمبلسين؛ فهنا قبليتان: قبلية لنزوله مطلقًا، وقبلية لذلك النزول المعين أن لا يكون متقدمًا على ذلك الوقت، فيئسوا قبل نزوله يأسين: يأسًا لعدمه مرئيًا، ويأسًا لتأخره عن وقته؛ فقبل الأولى ظرف اليأس، وقبل الثانية ظرف المجيء والإنزال. ففي الآية ظرفان معمولان وفعلان مختلفان عاملان فيهما، وهما الإنزال والإبلاس؛ فأحد الظرفين متعلق بالإبلاس، والثاني متعلق بالنزول، وتمثيل هذا: أن تقول إذا كنت معتادًا للعطاء من شخص فتأخر عن ذلك الوقت ثم أتاك به: قد كنتُ آيِسًا». ",footnotes:1:عزاه السيوطي إلى ابن أبي حاتم.أخرجه ابن جرير ١٨/٥٢١ بلفظ: قانطين. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.تفسير مقاتل بن سليمان ٣/٤١٩.تفسير يحيى بن سلام ٢/٦٦٥.
30,50," <q>﴿فَٱنظُرۡ إِلَىٰۤ ءَاثَـٰرِ رَحۡمَتِ ٱللَّهِ كَیۡفَ یُحۡیِ ٱلۡأَرۡضَ بَعۡدَ مَوۡتِهَاۤۚ إِنَّ ذَ ٰ⁠لِكَ لَمُحۡیِ ٱلۡمَوۡتَىٰۖ وَهُوَ عَلَىٰ كُلِّ شَیۡءࣲ قَدِیرࣱ ۝٥٠﴾</q> - تفسير ٦٠٧٦٩- قال مقاتل بن سليمان: قال اللهُ لنبيِّه محمد ﷺ: <q>﴿فانْظُرْ﴾</q> يا محمد <q>﴿إلى آثارِ رَحْمَتِ اللَّهِ﴾</q> يعني: النبت مِن آثار المطر؛ <q>﴿كَيْفَ يُحْيِ الأَرْضَ بَعْدَ مَوْتِها﴾</q> بالمطر، فتنبت من بعد موتها حين لم يكن فيها نبت، <q>﴿إنَّ ذَلِكَ﴾</q> يقول: إن هذا الذي فعل ما ترون <q>﴿لَمُحْيِ المَوْتى﴾</q> في الآخرة؛ فلا تكذبوا بالبعث، يعني: كفار مكة، ثم قال تعالى: <q>﴿وهُوَ عَلى كُلِّ شَيْءٍ قَدِيرٌ﴾</q> مِن البعث وغيره{1}. (ز) ٦٠٧٧٠- قال يحيى بن سلّام: <q>﴿فانْظُرْ إلى آثارِ رَحْمَتِ اللَّهِ﴾</q> يعني: المطر، <q>﴿كَيْفَ يُحْيِ الأَرْضَ بَعْدَ مَوْتِها﴾</q> يعني: النبات الذي أنبته الله -تبارك وتعالى- بذلك المطر، <q>﴿إنَّ ذَلِكَ لَمُحْيِ المَوْتى وهُوَ عَلى كُلِّ شَيْءٍ قَدِيرٌ﴾</q> أي: فالذي أنبت هذا النبات بذلك المطر قادِرٌ على أن يبعث الخلق يوم القيامة{2}٥١١٩. (ز) ٥١١٩ ذكر ابنُ عطية (٧/٣٤) في فاعل <q>﴿يحي﴾</q> احتمالين، فقال: «وقوله <q>﴿كَيْفَ يُحْيِ﴾</q> يحتمل أن يكون الضمير الذي في الفعل للأثر، ويحتمل أن يكون لله تعالى». ثم رجّح الأخير بقوله: «وهذا أظهر». ولم يذكر مستندًا. ",footnotes:1:تفسير مقاتل بن سليمان ٣/٤١٩.تفسير يحيى بن سلام ٢/٦٦٥-٦٦٦.
