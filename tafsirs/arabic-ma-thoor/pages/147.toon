quran[4]{c,v,t}:
6,143," <q>﴿ثَمَـٰنِیَةَ أَزۡوَ ٰ⁠جࣲۖ مِّنَ ٱلضَّأۡنِ ٱثۡنَیۡنِ وَمِنَ ٱلۡمَعۡزِ ٱثۡنَیۡنِۗ﴾</q> - قراءات ٢٦٤٨٣- عن لهيعة بن عقبة: أنّه سمع أبان بن عثمان بن عفان يوم الجمعة على المنبر يقرأ سورة الأنعام: (مِنَ الضَّأْنِ اثْنانِ){1}. (ز) <q>﴿ثَمَـٰنِیَةَ أَزۡوَ ٰ⁠جࣲۖ مِّنَ ٱلضَّأۡنِ ٱثۡنَیۡنِ وَمِنَ ٱلۡمَعۡزِ ٱثۡنَیۡنِۗ﴾</q> - تفسير الآية ٢٦٤٨٤- عن عبد الله بن عباس -من طريق عطاء- قال: الأزواجُ الثمانية؛ من الإبل، والبقر، والضَّأْن، والمعز{2}. (٦/٢٣١) ٢٦٤٨٥- عن عبد الله بن عباس -من طريق عطية العوفي- في قوله: <q>﴿ثمانية أزواج من الضأن اثنين ومن المعز اثنين﴾</q>، قال: فهذه أربعة أزواج{3}. (٦/٢٣٢) ٢٦٤٨٦- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿ثمانية أزواج﴾</q>، قال: في شأن ما نَهى الله عنه؛ عن البحيرة، والسائبة{4}. (٦/٢٣١) ٢٦٤٨٧- عن الضحاك بن مُزاحِم -من طريق جُوَيْبِر-: <q>﴿من الضأن اثنين﴾</q> ذكر وأنثى، <q>﴿ومن البقر اثنين﴾</q> ذكر وأنثى، <q>﴿ومن الإبل اثنين﴾</q> ذكر وأنثى{5}. (ز) ٢٦٤٨٨- عن قتادة بن دعامة، <q>﴿ثمانية أزواج﴾</q>، قال: الذكر والأنثى زوجان{6}. (٦/٢٣١) ٢٦٤٨٩- عن إسماعيل السُّدِّيّ -من طريق أسباط- في قوله: <q>﴿ثمانية أزواج﴾</q> الآية، يقول: أنزَلتُ لكم ثمانيةَ أزواجٍ من هذا الذي عدَدْتُ، ذكرًا وأُنثى{7}. (٦/٢٣١) ٢٦٤٩٠- عن ليث بن أبي سليم -من طريق حسن بن صالح - قال: الجاموس والبُخْتِيُّ مِن الأزواج الثمانية{8}. (٦/٢٣١) ٢٦٤٩١- قال مقاتل بن سليمان: ثم قال: أنزل <q>﴿ثمانية أزواج﴾</q> قبل خلق آدم ﵇، <q>﴿من الضأن اثنين﴾</q> يعني: ذكرًا وأنثى، <q>﴿ومن المعز اثنين﴾</q> ذكرًا وأنثى{9}. (ز) ٢٦٤٩٢- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿ثَمانِيَةَ أزْواجٍ مِنَ الضَّأْنِ اثْنَيْنِ ومِنَ المَعْزِ اثْنَيْنِ﴾</q>، قال: الأنعام هي: الإبل، والضأن، والمعز، هذه الأنعام التي قال الله: <q>﴿ثمانيةأزواج﴾</q>{10}. (ز) <q>﴿قُلۡ ءَاۤلذَّكَرَیۡنِ حَرَّمَ أَمِ ٱلۡأُنثَیَیۡنِ أَمَّا ٱشۡتَمَلَتۡ عَلَیۡهِ أَرۡحَامُ ٱلۡأُنثَیَیۡنِۖ نَبِّـُٔونِی بِعِلۡمٍ إِن كُنتُمۡ صَـٰدِقِینَ ۝١٤٣﴾</q> - تفسير ٢٦٤٩٣- عن عبد الله بن عباس -من طريق عطية العوفي، وعلي بن أبي طلحة- في قوله: <q>﴿قل آلذكرين حرم أم الأنثيين﴾</q> يقول: لم أُحرِّمْ شيئًا مِن ذلك، <q>﴿أما اشتملت عليه أرحام الأنثيين﴾</q> يعني: هل تشتمِلُ الرَّحِمُ إلا على ذكر أو أنثى، فلِمَ تحرِّمون بعضًا وتُحِلُّون بعضًا؟ <q>﴿نبئوني بعلم إن كنتم صادقين﴾</q> يقول: كلُّه حلال، يعني: ما تقدَّم ذِكْرُه مما حرَّمه أهلُ الجاهلية{11}. (٦/٢٣٢) ٢٦٤٩٤- عن الحسن البصري -من طريق أبي رجاء - في قوله: <q>﴿أما اشتملت عليه أرحام الأنثيين﴾</q>، قال: ما حمَلت الرَّحِم{12}. (٦/٢٣٢) ٢٦٤٩٥- عن قتادة بن دعامة -من طريق سعيد- قوله: <q>﴿ثَمانِيَةَ أزْواجٍ مِنَ الضَّأْنِ اثْنَيْنِ ومِنَ المَعْزِ اثْنَيْنِ﴾</q> الآية: إنّ كُلَّ هذا لم أُحَرِّم منه قليلًا ولا كثيرًا، ذكرًا ولا أنثى{13}. (ز) ٢٦٤٩٦- عن قتادة بن دعامة -من طريق معمر- <q>﴿مِنَ الضَّأْنِ اثْنَيْنِ ومِنَ المَعْزِ اثْنَيْنِ﴾</q> قال: سَلْهُم <q>﴿آلذَّكَرَيْنِ حَرَّمَ أمِ الأُنْثَيَيْنِ أمّا اشْتَمَلَتْ عَلَيْهِ أرْحامُ الأُنْثَيَيْنِ﴾</q> أي: لم أحرم من هذا شيئًا، <q>﴿نَبِّئُونِي بِعِلْمٍ إنْ كُنْتُمْ صادِقِينَ﴾</q> فذكر من الإبل والبقر نحو ذلك{14}. (ز) ٢٦٤٩٧- عن إسماعيل السُّدِّيّ -من طريق أسباط- <q>﴿ثَمانِيَةَ أزْواجٍ مِنَ الضَّأْنِ اثْنَيْنِ ومِنَ المَعْزِ اثْنَيْنِ﴾</q>، <q>﴿ومِنَ الإبِلِ اثْنَيْنِ ومِنَ البَقَرِ اثْنَيْنِ﴾</q>، يقول: أنزلت لكم ثمانية أزواج من هذا الذي عدَدْتُ، ذكرًا وأنثى، فالذكرين حرَّمت عليكم أم الأنثيين، أمّا اشتملت عليه أرحام الأنثيين؟ يقول: أي: ما اشتملت عليه أرحام الأنثيين، ما تشتمل إلا على ذكر أو أنثى، فما حرَّمْتُ عليكم ذكرًا ولا أنثى من الثمانية، إنّما ذَكَر هذا مِن أجل ما حرَّموا من الأنعام{15}. (ز) ٢٦٤٩٨- قال مقاتل بن سليمان: <q>﴿قل﴾</q> يا محمد، لِمَن حرم ذكور الأنعام تارة وإناثها أخرى، ونسب ذلك إلى الله: <q>﴿آلذكرين﴾</q> من الضأن والمعز <q>﴿حرَّم﴾</q> الله <q>﴿عليكم أم الأنثيين﴾</q> منهما، <q>﴿أما اشتملت عليه أرحام الأنثيين﴾</q> ذَكَرًا كان أو أنثى؟ <q>﴿نبئوني بعلم﴾</q> عن كيفية تحريم ذلك؛ <q>﴿إن كنتم صادقين﴾</q> فيه. المعنى: من أين جاء التحريم؟ فإن كان مِن قبل الذُّكُورة فجميع الذكور حرام، أو الأنوثة فجميع الإناث، أو اشتمال الرحم فالزوجان، فمن أين التخصيص؟! والاستفهام للاستنكار. <q>﴿نبئوني بعلم إن كنتم صادقين﴾</q> يقول الله لنبيه ﷺ: قل لهم: نبئوني بعلم إن كنتم صادقين بأنّ الله حرَّم هذا{9}. (ز) ٢٦٤٩٩- قال عبد الملك ابن جُرَيْج -من طريق حجّاج- يقول: مِن أين حرَّمت هذا؟ من قِبَل الذكرين أم من قِبَل الأنثيين، أما اشتملت عليه أرحام الأنثيين؟ وإنها لا تشتمل إلا على ذكر أو أنثى، فمن أين جاء التحريم؟! فأجابوا هم: وجدنا آباءنا كذلك يفعلون{17}. (ز) ٢٦٥٠٠- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿قُلْ آلذَّكَرَيْنِ حَرَّمَ أمِ الأُنْثَيَيْنِ﴾</q>، قال: هذا لقولهم: <q>﴿ما فِي بُطُونِ هَذِهِ الأَنْعامُ خالِصَةٌ لِذُكُورِنا ومُحَرَّمٌ عَلى أزْواجِنا﴾</q> [الأنعام:١٣٩]. قال: وقال ابن زيد، في قوله: <q>﴿ثَمانِيَةَ أزْواجٍ مِنَ الضَّأْنِ اثْنَيْنِ ومِنَ المَعْزِ اثْنَيْنِ﴾</q>، قال: الأنعام هي: الإبل، والضأن، والمعز، هذه الأنعام التي قال الله: <q>﴿ثمانية أزواج﴾</q>. قال: وقال في قوله: <q>﴿هذه أنعام وحرث حجر﴾</q> [الأنعام:١٣٨]: نحتجرها على من نُريد وعمَّن نريد. وقوله: <q>﴿وأنْعامٌ حُرِّمَتْ ظُهُورُها﴾</q> قال: لا يركبها أحد، <q>﴿وأَنْعامٌ لا يَذْكُرُونَ اسْمَ اللَّهِ عَلَيْها﴾</q> فقال: <q>﴿آلذَّكَرَيْنِ حَرَّمَ أمِ الأُنْثَيَيْنِ﴾</q> أي: هذين حرَّم على هؤلاء، أي: أن تكون لهؤلاء حِلًّا، وعلى هؤلاء حرامًا؟!{10}. (ز) ",footnotes:1:أخرجه عبد الله بن وهب في الجامع - تفسير القرآن ٣/٤٥ (٨٩). وهي قراءة شاذة. انظر: مختصر ابن خالويه ص٤٦-٤٧.أخرجه ابن جرير ٣/٣٤٩، وابن أبي حاتم ١/٣٣٦ من طريقي عطاء والنعمان بن مالك، ٥/١٤٠٢، والبيهقي في سننه ٩/٢٧٢. وعزاه السيوطي إلى ابن أبي شيبة، وابن المنذر.أخرجه ابن جرير ٩/٦٢٨. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.تفسير مجاهد ص٣٣٠، وأخرجه ابن جرير ٩/٦٢٧، وكذلك من طريق ابن جريج، وابن أبي حاتم ٥/١٤٠٢. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وأبي الشيخ.أخرجه ابن جرير ٩/٦٢٤.عزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ٩/٦٢٧، وابن أبي حاتم ٥/١٤٠٢.أخرجه ابن أبي حاتم ٥/١٤٠٣.تفسير مقاتل بن سليمان ١/٥٩٣-٥٩٤.أخرجه ابن جرير ٩/٦٢٨، وابن أبي حاتم ٥/١٤٠٤.أخرجه ابن جرير ٩/٦٢٨، وابن أبي حاتم ٥/١٤٠٣. وعزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ٩/٦٢٧، وابن أبي حاتم ٥/١٤٠٣. وعزاه السيوطي إلى أبي الشيخ.أخرجه ابن جرير ٩/٦٢٦.أخرجه عبد الرزاق ٢/٢٢٠، وابن جرير ٩/٦٢٦، وابن أبي حاتم ٥/١٤٠٣-١٤٠٤.أخرجه ابن جرير ٩/٦٢٧، وابن أبي حاتم ٥/١٤٠٢-١٤٠٤.تفسير مقاتل بن سليمان ١/٥٩٣-٥٩٤.أخرجه ابن جرير ٩/٦٢٧.أخرجه ابن جرير ٩/٦٢٨، وابن أبي حاتم ٥/١٤٠٤.
6,144," <q>﴿وَمِنَ ٱلۡإِبِلِ ٱثۡنَیۡنِ وَمِنَ ٱلۡبَقَرِ ٱثۡنَیۡنِۗ﴾</q> - تفسير ٢٦٥٠١- عن الضحاك بن مُزاحِم -من طريق جُوَيْبِر-: <q>﴿من الضأن اثنين﴾</q> ذكر وأنثى، <q>﴿ومن البقر اثنين﴾</q> ذكر وأنثى، <q>﴿ومن الإبل اثنين﴾</q> ذكر وأنثى{1}. (ز) ٢٦٥٠٢- قال مقاتل بن سليمان: <q>﴿ومن الإبل اثنين﴾</q> ذكر وأنثى، <q>﴿ومن البقر اثنين﴾</q> ذكر وأنثى{2}. (ز) <q>﴿قُلۡ ءَاۤلذَّكَرَیۡنِ حَرَّمَ أَمِ ٱلۡأُنثَیَیۡنِ أَمَّا ٱشۡتَمَلَتۡ عَلَیۡهِ أَرۡحَامُ ٱلۡأُنثَیَیۡنِۖ أَمۡ كُنتُمۡ شُهَدَاۤءَ إِذۡ وَصَّىٰكُمُ ٱللَّهُ بِهَـٰذَاۚ فَمَنۡ أَظۡلَمُ مِمَّنِ ٱفۡتَرَىٰ عَلَى ٱللَّهِ كَذِبࣰا لِّیُضِلَّ ٱلنَّاسَ بِغَیۡرِ عِلۡمٍۚ إِنَّ ٱللَّهَ لَا یَهۡدِی ٱلۡقَوۡمَ ٱلظَّـٰلِمِینَ ۝١٤٤﴾</q> - نزول الآية، وتفسيرها ٢٦٥٠٣- عن إسماعيل السدي -من طريق أسباط- في قوله: <q>﴿آلذكرين حرم﴾</q> الآية، قال: إنّما ذكَر هذا مِن أجلِ ما حرَّموا مِن الأنعام، وكانوا يقولون: اللهُ أمرنا بهذا. فقال الله: <q>﴿فمن أظلم ممن افترى على الله كذبا ليضل الناس بغير علم﴾</q>{3}. (٦/٢٣٢) ٢٦٥٠٤- قال مقاتل بن سليمان: <q>﴿قل﴾</q> يا محمد: <q>﴿آلذكرين حرم أم الأنثيين﴾</q> يعني: من أين تحريم الأنعام؟ من قِبَل الذكرين أم قِبَل الأنثيين؟ <q>﴿أما اشتملت عليه أرحام الأنثيين﴾</q>؟ يقول: على ما اشتمل؟ ما يشتمل الرَّحِم إلا ذكرًا أو أنثى، فأين هذا الذي جاء التحريم من قِبَله؟ وما اشتمل الرَّحِم إلا على مثلها. يقول: ما تلد الغنم إلا الغنم، وما تلد الناقة إلا مثلها، يعني: أنّ الغنم لا تلد البقر، ولا البقر تلد الغنم. فإن قالوا: حرَّم الأنثيين. خصُّوا، ولم يجُزْ لهم أن يأكلوا الإناث من الأنعام، وإن قالوا: الذكرين. لم يجُزْ لهم أن يأكلوا ذكور الأنعام، فسكتوا. ثم قال: <q>﴿أم كنتم شهداء إذ وصاكم الله بهذا﴾</q> التحريم؟ فسكتوا، فلم يجيبوه، إلا أنّهم قالوا: حرَّمها آباؤنا. فقال لهم النبي ﷺ: «فمِن أين حرَّمه آباؤكم؟». قالوا: الله أمرهم بتحريمه. فأنزل الله: <q>﴿فمن أظلم﴾</q> يقول: فلا أحد أظلم <q>﴿ممن افترى على الله كذبا ليضل الناس بغير علم إن الله لا يهدي القوم الظالمين﴾</q>{2}. (ز) ٢٦٥٠٥- قال عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿أم كنتم شهداء إذ وصاكم الله بهذا﴾</q> الذي تقولون{5}. (ز) ",footnotes:1:أخرجه ابن جرير ٩/٦٢٤.تفسير مقاتل بن سليمان ١/٥٩٤-٥٩٥.أخرجه ابن جرير ٩/٦٣١ بنحوه، وابن أبي حاتم ٥/١٤٠٤.تفسير مقاتل بن سليمان ١/٥٩٤-٥٩٥.أخرجه ابن جرير ٩/٦٣٠.
6,145," <q>﴿قُل لَّاۤ أَجِدُ فِی مَاۤ أُوحِیَ إِلَیَّ مُحَرَّمًا عَلَىٰ طَاعِمࣲ یَطۡعَمُهُۥۤ إِلَّاۤ أَن یَكُونَ مَیۡتَةً أَوۡ دَمࣰا مَّسۡفُوحًا أَوۡ لَحۡمَ خِنزِیرࣲ فَإِنَّهُۥ رِجۡسٌ أَوۡ فِسۡقًا أُهِلَّ لِغَیۡرِ ٱللَّهِ بِهِۦۚ فَمَنِ ٱضۡطُرَّ غَیۡرَ بَاغࣲ وَلَا عَادࣲ فَإِنَّ رَبَّكَ غَفُورࣱ رَّحِیمࣱ ۝١٤٥﴾</q> - نزول الآية ٢٦٥٠٦- عن طاووس بن كيسان -من طريق ابنه- قال: إنّ أهل الجاهلية كانوا يُحَرِّمون أشياء، ويسْتَحِلُّون أشياء. فنزَلت: <q>﴿قل لا أجد فيما أوحي إلي محرما﴾</q> الآية{1}. (٦/٢٣٣) ٢٦٥٠٧- قال مقاتل بن سليمان: قالوا: يا محمد، فمِن أين حرَّمه آباؤنا؟ فأوحى الله إلى نبيه ﷺ: <q>﴿قل لا أجد في ما أوحي إلي محرما على طاعم يطعمه﴾</q>الآية{2}. (ز) <q>﴿قُل لَّاۤ أَجِدُ فِی مَاۤ أُوحِیَ إِلَیَّ مُحَرَّمًا عَلَىٰ طَاعِمࣲ یَطۡعَمُهُۥۤ﴾</q> الآية - تفسير ٢٦٥٠٨- عن عائشة -من طريق القاسم- أنّها كانت إذا سُئِلتْ عن كلِّ ذي ناب من السِّباع، ومِخْلَبٍ من الطير؛ قرَأت: <q>﴿قل لا أجد فيما أوحي إلي محرما﴾</q> الآية{3}. (٦/٢٣٤) ٢٦٥٠٩- عن عائشة= (ز) ٢٦٥١٠- وعبد الله بن عمر، قالا: لا بأس بأكل كلِّ شيء، إلا ما ذَكَر الله في هذه الآية: <q>﴿قل لا أجد فيما أوحي إلي محرما﴾</q> الآية{4}. (٦/٢٣٧) ٢٦٥١١- عن عمرو بن دينار، قال: قلتُ لجابر بن زيد: إنّهم يَزعُمون: أنّ رسول الله ﷺ نهى عن لحوم الحُمُر الأهلية زمَنَ خيبر. فقال: قد كان يقولُ ذلك الحكم بن عمرو الغفاري عندَنا بالبصرة عن رسول الله ﷺ، ولكن أبى ذلك البحرُ عبد الله بن عباس، وقرأ: <q>﴿قل لا أجد فيما أوحي إلي﴾</q> الآية{5}. (٦/٢٣٣) ٢٦٥١٢- عن عبد الله بن عباس أنّه سُئِل عن ثمن الكلب، والذئب، والهِرِّ، وأشباه ذلك. فقال: <q>﴿يا أيها الذين آمنوا لا تسألوا عن أشياء إن تبد لكم تسؤكم﴾</q> [المائدة:١٠١]، كان ناس من أصحاب رسول الله ﷺ يَكرهُون أشياء فلا يُحَرِّمونه، وإنّ الله أنزَل كتابًا، فأحَلَّ فيه حلالًا، وحرَّم فيه حرامًا، وأنزَل في كتابه: <q>﴿قل لا أجد فيما أوحي إلي محرما على طاعم يطعمه إلا أن يكون ميتة أو دما مسفوحا أو لحم خنزير﴾</q>{6}. (٦/٢٣٧) ٢٦٥١٣- عن عبد الله بن عباس -من طريق الضحّاك- أنّه تلا هذه الآية: <q>﴿قل لا أجد فيما أوحي إلي محرما﴾</q>، فقال: ما خلا هذا فهو حلال{7}. (٦/٢٣٣) ٢٦٥١٤- عن عبد الله بن عباس -من طريق أبي الشَّعثاء- قال: كان أهلُ الجاهلية يأكلون أشياء، ويتركون أشياء تقذُّرًا، فبعث الله نبيه، وأنزَل كتابه، وأحلَّ حلاله، وحرَّم حرامَه؛ فما أحلَّ فهو حلال، وما حرَّم فهو حرام، وما سكَت عنه فهو عفوٌ منه. ثم تلا هذه الآية: <q>﴿قل لا أجد فيما أوحي إلي محرما﴾</q> إلى آخر الآية{8}. (٦/٢٣٣) ٢٦٥١٥- عن عبد الله بن عباس -من طريق عكرمة- قال: ليس من الدوابِّ شيءٌ حرام إلا ما حرَّم الله في كتابه: <q>﴿قل لا أجد فيما أوحي إلي محرما﴾</q> الآية{9}. (٦/٢٣٤) ٢٦٥١٦- عن عبد الله بن عمر -من طريق عيسى بن نُمَيْلَةَ الفزاري، عن أبيه- أنّه سُئِل عن أكلِ القُنفُذ. فقرأ: <q>﴿قل لا أجد فيما أوحي إلي محرما﴾</q> الآية. فقال شيخٌ عندَه: سمِعتُ أبا هريرة يقول: ذُكِرَ عندَ النبي ﷺ، فقال: «خبيثةٌ من الخبائث». فقال ابن عمر: إن كان النبي ﷺ قاله فهو كما قال{10}٢٤٢٥. (٦/٢٣٤) ٢٤٢٥ قال ابنُ عطية (٣/٤٨٠-٤٨١): «هذه الآية نزلت بمكة، ولم يكن في الشريعة في ذلك الوقت شيءٌ مُحَرَّم غير هذه الأشياء، ثم نزلت سورة المائدة بالمدينة، وزِيدَ في المحرمات؛ كالمنخنقة، والموقوذة، والمتردية، والنطيحة. فإنّ هذه وإن كانت في حكم الميتة فكان في النظر احتمال أن تلحق بالمذكيات؛ لأنها بأسباب وليست حتف الأنف. فلما بيَّن النصُ إلحاقها بالميتة كان زيادة في المحرمات، ثم نزل النص على رسول الله ﷺ في تحريم الحمر بوحي غير معجز، وبتحريم كل ذي ناب من السباع، فهذه كلها زيادات في التحريم». وقال ابنُ كثير (٦/١٩٤): «قيل: معناه: لا أجد شيئًا مما حرَّمتم حرامًا سوى هذه. وقيل: معناه: لا أجد من الحيوانات شيئًا حرامًا سوى هذه. فعلى هذا يكون ما ورد من التحريمات بعد هذا في سورة المائدة وفي الأحاديث الواردة رافعًا لمفهوم هذه الآية، ومِن الناس مَن يسمي ذلك نسخًا، والأكثرون من المتأخرين لا يسمونه نسخًا؛ لأنّه من باب رفع مباح الأصل». وبنحو كلام ابن كثير قال ابنُ تيمية (٢/١٠٩). ٢٦٥١٧- قال مقاتل بن سليمان: <q>﴿قل لا أجد في ما أوحي إلي محرما على طاعم يطعمه﴾</q>، يعني: على آكل يأكله{2}. (ز) <q>﴿إِلَّاۤ أَن یَكُونَ مَیۡتَةً﴾</q> - تفسير ٢٦٥١٨- عن عبد الله بن عباس -من طريق عكرمة- أنّ شاةً لسَوْدَة بنت زَمْعَة ماتت، فقالت: يا رسول الله، ماتت فلانة. تعني: الشاة، قال: «فلولا أخَذْتم مَسْكَها{12}». قالت: يا رسول الله، أنأخُذُ مَسْكَ شاةٍ قد ماتت؟ فقرأ النبي ﷺ: «<q>﴿قل لا أجد فيما أوحي إلي محرما على طاعم يطعمه إلّا أنْ يَكُونَ مَيْتَةً﴾</q>، وإنكم لا تَطْعَمُونَه، وإنما تَدْبُغونه حتى تَنتَفِعُوا به». فأرسَلت إليها، فسَلَختْها، ثم دَبَغَته، فاتَّخذتْ منه قِربةً حتى تخرَّقت عندَها{13}. (٦/٢٣٤) ٢٦٥١٩- عن عبد الله بن عباس -من طريق عبيد الله بن عتبة- أنّه قرأ هذه الآية: <q>﴿قل لا أجد فيما أوحي إلي محرما على طاعم يطعمه إلا أن يكون ميتة﴾</q> إلى آخر الآية، وقال: إنّما حُرِّم من الميتة ما يُؤكلُ منها وهو اللحم، فأما الجِلد، والقَدُّ{14}، والسِنُّ، والعظمُ، والشَّعَر، والصوف؛ فهو حلال{15}. (٦/٢٣٥) ٢٦٥٢٠- عن مجاهد بن جبر -من طريق إبراهيم بن أبي بكر- <q>﴿قُلْ لا أجِدُ فِي ما أُوحِيَ إلَيَّ مُحَرَّمًا﴾</q>، قال: مِمّا كان في الجاهلية يأكلون، لا أجد محرمًا من ذلك <q>﴿على طاعم يطعمه، إلا أن يكون ميتة، أو دمًا مسفوحًا﴾</q>{16}. (ز) ٢٦٥٢١- عن طاووس بن كيسان -من طريق ابنه- <q>﴿قُلْ لا أجِدُ فِي ما أُوحِيَ إلَيَّ مُحَرَّمًا عَلى طاعِمٍ يَطْعَمُهُ﴾</q> قال: ما يُؤكَل. قلت: في الجاهلية؟ قال: نعم، وكذلك كان يقول: <q>﴿إلا أن يكون ميتة أودما مسفوحا﴾</q>{16}. (ز) <q>﴿أَوۡ دَمࣰا مَّسۡفُوحًا﴾</q> - تفسير ٢٦٥٢٢- عن عائشة -من طريق القاسم بن محمد- قالت، وذكرت هذه الآية: <q>﴿أو دما مسفوحا﴾</q>، قلت: وإنّ البُرْمةَ{18} لَيُرى في مائها الصُّفرة{19}. (ز) ٢٦٥٢٣- عن عبد الله بن عباس -من طريق علي بن أبي طلحة- في قوله: <q>﴿أو دما مسفوحا﴾</q>، قال: مُهَراقًا{20}. (٦/٢٣٥) ٢٦٥٢٤- عن عبد الله بن عباس -من طريق عكرمة- قال: كان أهل الجاهلية إذا ذبَحوا أودَجوا{21} الدابَّة، وأخذوا الدم، فأكَلوه، قالوا: هو دمٌ مسفوح{22}. (٦/٢٣٥) ٢٦٥٢٥- عن عكرمة، قال: جاء رجلٌ إلى عبد الله بن عباس، فقال له: آكُلُ الطِّحالَ؟ قال: نعم. قال: إنّ عامَّتَها دمٌ! قال: إنّما حرَّم الله الدم المسفوح{23}. (٦/٢٣٦) ٢٦٥٢٦- عن عبد الله بن عباس -من طريق عكرمة- قال: لا بأس بأكل الطِّحال. ثم تلا: <q>﴿قل لا أجد فيما أوحي إلي محرما﴾</q> الآية{24}. (ز) ٢٦٥٢٧- قال إبراهيم النخعي: لا بأس بالدم في عِرْق أو مُخٍّ، إلا المسفوح الذي تُعُمِّد ذلك{25}. (ز) ٢٦٥٢٨- عن عكرمة مولى ابن عباس -من طريق عمرو بن دينار- قال: لولا هذه الآية: <q>﴿أو دما مسفوحا﴾</q> لاتَّبَع المسلمون من العروق ما تَتَبَّع منه اليهود{26}. (٦/٢٣٦) ٢٦٥٢٩- عن أبي مِجْلَز لاحق بن حميد -من طريق عمران بن حُدَيْرٍ- في الدم يكون في مَذْبحِ الشاة، أو الدم يكون على أعلى القِدْر، قال: لا بأس، إنّما نُهِيَ عن الدم المسفوح{27}. (٦/٢٣٦) ٢٦٥٣٠- عن قتادة بن دعامة -من طريق مَعْمَر- قال: حُرِّم الدم ما كان مسفوحًا، فأمّا لحمٌ يُخالطُه الدم فلا بأسَ به{28}. (٦/٢٣٦) ٢٦٥٣١- قال مقاتل بن سليمان: <q>﴿أو دما مسفوحا﴾</q>، يعني: يَسيل{2}. (ز) ٢٦٥٣٢- عن عبد الملك ابن جُرَيْج، في قوله: <q>﴿أو دما مسفوحا﴾</q>، قال: المسفوح الذي يُهَراق، ولا بأسَ بما كان في العروق منها{30}. (٦/٢٣٦) ٢٦٥٣٣- عن سفيان بن عيينة -من طريق أحمد بن حنبل- يقول في قوله: <q>﴿أو دما مسفوحا﴾</q>، المسفوح: العَبِيطُ{9}. (ز) <q>﴿أَوۡ لَحۡمَ خِنزِیرࣲ فَإِنَّهُۥ رِجۡسٌ﴾</q> - تفسير ٢٦٥٣٤- عن الحسن البصري -من طريق عبّاد بن منصور- قوله: <q>﴿أو لحم خنزير﴾</q>، قال: حرَّم الله الميتة، والدم، ولحم الخنزير{22}. (ز) ٢٦٥٣٥- قال مقاتل بن سليمان: <q>﴿أوْ لَحْمَ خِنْزِيرٍ فَإنَّهُ رِجْسٌ﴾</q>، يعني: إثمًا{2}. (ز) <q>﴿أَوۡ فِسۡقًا أُهِلَّ لِغَیۡرِ ٱللَّهِ بِهِۦۚ﴾</q> - تفسير ٢٦٥٣٦- قال مقاتل بن سليمان: <q>﴿أو فسقا﴾</q> يعني: معصية <q>﴿أهل لغير الله به﴾</q> يعني: ذُبِح لغير الله{2}. (ز) ٢٦٥٣٧- قال مالك بن أنس: ... والفسوق: الذبح للأنصاب -والله أعلم-، قال الله -تبارك وتعالى-: <q>﴿أوْ فِسْقًا أُهِلَّ لِغَيْرِ اللَّهِ بِهِ﴾</q>{35}. (ز) <q>﴿فَمَنِ ٱضۡطُرَّ غَیۡرَ بَاغࣲ وَلَا عَادࣲ فَإِنَّ﴾</q> - تفسير ٢٦٥٣٨- قال مقاتل بن سليمان: <q>﴿فمن اضطر﴾</q> إلى شيء مما حرَّمْتُ عليه <q>﴿غير باغ﴾</q> ليستحله في دينه، <q>﴿ولا عاد﴾</q> يعني: ولا معتديًا لم يضطر إليه{36}. (ز) <q>﴿فَإِنَّ رَبَّكَ غَفُورࣱ رَّحِیمࣱ ۝١٤٥﴾</q> - تفسير ٢٦٥٣٩- عن سعيد بن جبير -من طريق عطاء- <q>﴿فإن ربك غفور﴾</q> يعني: لِما أُكِل من الحرام، <q>﴿رحيم﴾</q> يعني: رحيمًا به إذ أحَلَّ له الحرام في الاضطرار{37}. (ز) ٢٦٥٤٠- قال مقاتل بن سليمان: <q>﴿فإن ربك غفور﴾</q> لأكله الحرام، <q>﴿رحيم﴾</q> به إذا رخَّص له في الحرام في الاضطرار{2}. (ز) <q>﴿فَإِنَّ رَبَّكَ غَفُورࣱ رَّحِیمࣱ ۝١٤٥﴾</q> - أحكام متعلقة بالآية ٢٦٥٤١- عن ابن عمر، قال: نهى النبي ﷺ عن لحوم الحُمُر الأهلية يومَ خيبر{39}. (٦/٢٣٨) ٢٦٥٤٢- عن جابر بن عبد الله، قال: نهى النبي ﷺ يوم خيبر عن لحوم الحمُر الأهلية، ورخَّص في لحوم الخيل{40}. (٦/٢٣٨) ٢٦٥٤٣- عن أبي ثعلبة الخُشَنِيِّ: أنّ رسول الله ﷺ نهى عن أكلِ كلِّ ذي نابٍ من السِّباع{41}. (٦/٢٣٩) ٢٦٥٤٤- عن عبد الله بن عباس، قال: نهى رسول الله ﷺ عن كلِّ ذي نابٍ من السِّباع، وعن كلِّ ذي مِخْلَبٍ من الطير{42}. (٦/٢٣٩) ٢٦٥٤٥- عن خالد بن الوليد، قال: غزَوتُ مع رسول الله ﷺ يوم خيبر، فأتتِ اليهود، فشكَوْا أنّ الناس قد أسرعوا إلى حظائرِهم، فقال رسول الله ﷺ: «ألا لا تَحِلُّ أموالُ المعاهَدِين إلا بحقِّها، حرامٌ عليكم حَميرُ الأهلية، وخيلُها، وبغالُها، وكلُّ ذي نابٍ من السِّباع، وكلُّ ذي مِخْلَب من الطير»{43}. (٦/٢٣٩) ٢٦٥٤٦- عن جابر، قال: حرَّم رسول الله ﷺ يوم خيبر الحمُر الإنسيةَ، ولحومَ البغال، وكلَّ ذي نابٍ من السِّباع، وكلَّ ذي مِخْلَبٍ من الطير، وحرَّم المُجَثَّمَةَ{44}، والخُلْسةَ، والنُّهبةَ{45}. (٦/٢٣٩) ٢٦٥٤٧- عن جابر بن عبد الله: أنّ النبي ﷺ نهى عن أكْلِ الهِرَّة، وأكْلِ ثمنِها{46}. (٦/٢٤١) ٢٦٥٤٨- عن عبد الرحمن بن شِبْلٍ: أنّ رسول الله ﷺ نهى عن أكل لحم الضَّبِّ{47}. (٦/٢٤١) ٢٦٥٤٩- عن ابن عمر، قال: سُئِل النبي ﷺ عن الضَّبِّ. فقال: «لستُ آكُلُه، ولا أُحرِّمُه»{48}. (٦/٢٤١) ٢٦٥٥٠- عن خالد بن الوليد: أنّه دخل مع رسول الله ﷺ بيت ميمونة، فأُتِي بضَبٍّ محْنُوذٍ{49}، فأهوى إليه رسول الله ﷺ بيده، فقال بعض النِّسوة: أخْبِروا رسول الله ﷺ بما يريدُ أن يأكُلَ. فقالوا: هو ضبٌّ، يا رسول الله. فرفَع يده، فقلتُ: أحرامٌ هو، يا رسول الله؟ قال: «لا، ولكن لم يكن بأرض قومي، فأجِدُني أعافُه». قال خالد: فاجترَرْتُه، فأكلتُه، ورسول الله ﷺ ينظُرُ{50}. (٦/٢٤١) ٢٦٥٥١- عن خُزَيْمة بن جَزْءٍ السُّلَمي، قال: سألتُ رسول الله ﷺ عن أكل الضَّبُع، فقال: «ويأكُلُ الضَّبُعَ أحدٌ؟». وسألتُه عن أكل الذئب، قال: «ويأكُلُ الذئبَ أحدٌ فيه خير؟». وفي لفظ لابن ماجه: قلتُ: يا رسول الله، جئتُك لأَسألَكَ عن أحْناشِ الأرض، ما تقولُ في الثعلب؟ قال: «ومَن يأكُلُ الثعلب؟». قلتُ: ما تقول في الضَّبِّ؟ قال: «لا آكُلُه، ولا أُحرِّمُه». قلتُ: ولِمَ، يا رسول الله؟ قال: «فُقِدَت أُمةٌ من الأمم، ورأيتُ خَلْقًا رابَني». قلتُ: يا رسول الله، ما تقول في الأرنب؟ قال: «لا آكُلُه، ولا أُحرِّمُه». قلتُ: ولِمَ، يا رسول الله؟ قال: «نُبِّئْتُ أنها تَدْمى»{51}. (٦/٢٤٣) ٢٦٥٥٢- عن عبد الرحمن بن أبي عمار، قال: قلتُ لجابر: الضَّبُعُ، أصيدٌ هي؟ قال: نعم. قلتُ: آكُلُها؟ قال: نعم. قلتُ: أقاله رسول الله ﷺ؟ قال: نعم{52}. (٦/٢٤٤) ٢٦٥٥٣- عن جابر بن زيد، قال: سألتُ البحرَ -يعني: عبد الله بن عباس- في رجل ذبح، ونسي أن يذكر. فتلا هذه الآية: <q>﴿قل لا أجد في ما أوحي إلي محرما﴾</q>{53}. (ز) ٢٦٥٥٤- عن عبد الله بن عمر -من طريق عروة- قال: مَن يأكُلُ الغرابَ وقد سمّاه رسول الله ﷺ فاسقًا؟! واللهِ، ما هو من الطيبات{54}. (٦/٢٤٣) ٢٦٥٥٥- عن محمد بن علي ابن الحنفية -من طريق منذر- أنّه سُئِل عن أكل الجِرِّيثِ{55}. فقال: <q>﴿قل لا أجد فيما أوحي إلي محرما﴾</q> الآية{56}. (٦/٢٣٧) ٢٦٥٥٦- عن أبي يعلى عن محمد بن الحنفية، قال: سألتُه عن الطحال والجِرِّيِّ{57}. فتلا هذه الآية: <q>﴿قل لا أجد فيما أوحي إلي محرما﴾</q>{58}. (ز) ٢٦٥٥٧- عن زيد أبي أسامة، قال: سألتُ سالِم [بن عبد الله بن عمر]= (ز) ٢٦٥٥٨- والقاسم [بن محمد بن أبي بكر] عن كسب الحجام. فلم يريا به بأسًا، وتَلَوا: <q>﴿قل لا أجد فيما أوحي إلي محرما على طاعم يطعمه﴾</q> الآية{59}. (ز) ٢٦٥٥٩- عن عامر الشعبي: أنّه سُئِل عن لحم الفيل، والأسد. فتلا: <q>﴿قل لا أجد فيما أوحي إلي محرما﴾</q> الآية{60}. (٦/٢٣٧) ",footnotes:1:أخرجه ابن جرير ٩/٦٣٢، وابن أبي حاتم ٥/١٤٠٥. وعزاه السيوطي إلى عبد بن حميد.تفسير مقاتل بن سليمان ١/٥٩٥.أخرجه ابن جرير ٩/٦٣٥، وابن أبي شيبة في مصنفه (ت: محمد عوامة) ١٠/٤٥١ (٢٠٢٣٥)، وابن أبي حاتم ٥/١٤٠٧، والنحاس ص٤٣٤. وعزاه السيوطي إلى ابن المنذر، وأبي الشيخ، وابن مردويه.عزاه السيوطي إلى أبي الشيخ، وابن مردويه.أخرجه عبد الرزاق في مصنفه ٤/٥٢٥ (٨٧٢٧) بنحوه، وأحمد ٢٩/٤٠٥ (١٧٨٦١)، والبخاري (٥٥٢٩)، وأبو داود (٣٨٠٨)، والنحاس ص٤٣٤، وعند النحاس: عن عمرو بن دينار، عن جابر بن عبد الله. وعزاه السيوطي إلى ابن المنذر، وأبي الشيخ.عزاه السيوطي إلى ابن مردويه.أخرجه عبد الرزاق ١/٢٢٠. وعزاه السيوطي إلى عبد بن حميد.أخرجه أبو داود ٥/٦١٧-٦١٨ (٣٨٠٠)، والحاكم ٤/١٢٨ (٧١١٣)، وابن أبي حاتم ٥/١٤٠٤-١٤٠٥ (٨٠٠٠). قال الحاكم: «هذا حديث صحيح الإسناد، ولم يُخَرِّجاه». وقال الذهبي في التلخيص: «صحيح». وقال ابن كثير في تفسيره ٣/٣٥٣: «ورواه أبو داود منفردًا به».أخرجه ابن أبي حاتم ٥/١٤٠٦.أخرجه أحمد ١٤/٥١٥ (٨٩٥٤)، وأبو داود ٥/٦١٧ (٣٧٩٩)، وابن أبي حاتم ٥/١٤٠٦ (٨٠٠٧). قال الخطابي في معالم السنن ٤/٢٤٨: «ليس إسناده بذلك». وقال البيهقي في الكبرى ٩/٥٤٧ (١٩٤٣١): «هذا حديث لم يُرْوَ إلا بهذا الإسناد، وهو إسناد فيه ضعف». وقال في معرفة السنن والآثار ١٤/٩١ (١٩٢٤٥): «إسناد غير قوي، وراويه شيخ مجهول». وقال ابن حجر في بلوغ المرام ٢/١٧١ (١٣٢٦): «إسناده ضعيف». وقال الألباني في الإرواء ٨/١٤٤ (٢٤٩٢): «ضعيف».تفسير مقاتل بن سليمان ١/٥٩٥.المسْك: الجِلْد. النهاية ٤/٣٣١.أخرجه أحمد ٥/١٥٦ (٣٠٢٦)، وابن أبي حاتم ٥/١٤٠٥-١٤٠٦ (٨٠٠٣، ٨٠٠٥). وأخرجه البخاري ٨/١٣٩ (٦٦٨٦) مختصرًا دون ذكر الآية.القَدّ: جلد السَّخْلة. النهاية (قدد).أخرجه ابن أبي حاتم ٥/١٤٠٥ بنحوه. وعزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ٩/٦٣٣.أخرجه ابن جرير ٩/٦٣٣.البُرْمَة: القِدْر. النهاية (برم).أخرجه ابن جرير ٩/٦٣٥، وابن أبي شيبة في مصنفه (ت: محمد عوامة) ١٠/٤٥١ (٢٠٢٣٥)، وابن أبي حاتم ٥/١٤٠٧.أخرجه ابن جرير ٩/٦٣٤، وابن أبي حاتم ٥/١٤٠٦. وعزاه السيوطي إلى ابن المنذر، وأبي الشيخ.ودَجَ الدابة: قطع ودَجَها، وهو عِرْقٌ فِي العُنق يقطعه الذابح. اللسان (ودج).أخرجه ابن أبي حاتم ٥/١٤٠٧.أخرجه ابن أبي شيبة ٨/٨٦، وابن أبي حاتم ٥/١٤٠٦، والبيهقي في سننه١٠/٧. وعزاه السيوطي إلى ابن المنذر، وأبي الشيخ.أخرجه أبو نعيم في أخبار أصبهان ٢/٢٥٠. وعند ابن أبي حاتم ٥/١٤٠٦: عن عكرمة قال: جاء رجل إلى ابن عباس، فقال: آكل الطحال؟ قال: نعم. قال: إن عامتها دم؟ قال: إنما حرم الله الدم المسفوح. وذكره في الدر ١٣/٦٣٩.تفسير الثعلبي ٤/٢٠١، وتفسير البغوي ٣/١٩٨.أخرجه عبد الرزاق ١/٢٢٠، وسعيد بن منصور (٩٣٣ - تفسير)، وابن جرير ٩/٦٣٤، وابن أبي حاتم ٥/١٤٠٧. وعزاه السيوطي إلى ابن المنذر، وأبي الشيخ.أخرجه ابن جرير ٩/٦٣٤، وابن أبي حاتم ٤/١٤٠٩. وعزاه السيوطي إلى عبد بن حميد، وأبي الشيخ.أخرجه عبد الرزاق ١/٢٢١، وابن جرير ٩/٦٣٤، وابن أبي حاتم ٥/١٤٠٧. وعزاه السيوطي إلى عبد بن حميد.تفسير مقاتل بن سليمان ١/٥٩٥.عزاه السيوطي إلى ابن المنذر.أخرجه ابن أبي حاتم ٥/١٤٠٦.أخرجه ابن أبي حاتم ٥/١٤٠٧.تفسير مقاتل بن سليمان ١/٥٩٥.تفسير مقاتل بن سليمان ١/٥٩٥.الموطأ (ت: د. بشار عواد) ١/٥٢٢ (١١٥٣). هذا وقد تقدم تفصيل ذلك بما يغني عن إعادته في سورة البقرة [١٧٣] عند قوله تعالى: <q>﴿إنَّما حَرَّمَ عَلَيْكُمُ المَيْتَةَ والدَّمَ ولَحْمَ الخِنْزِيرِ وما أُهِلَّ بِهِ لِغَيْرِ اللَّهِ﴾</q>، وسورة المائدة [٣] في قوله تعالى: <q>﴿حُرِّمَتْ عَلَيْكُمُ المَيْتَةُ والدَّمُ ولَحْمُ الخِنْزِيرِ وما أُهِلَّ لِغَيْرِ اللَّهِ بِهِ﴾</q>.تفسير مقاتل بن سليمان ١/٥٩٥. كذلك تقدم تفصيل ذلك بما يغني عن إعادته عند تفسير الآية (٧٣) في سورة البقرة.أخرجه ابن أبي حاتم ٥/١٤٠٩.تفسير مقاتل بن سليمان ١/٥٩٥.أخرجه البخاري ٥/١٣٦ (٤٢١٧، ٤٢١٨)، ٧/٩٥ (٥٥٢١، ٥٥٢٢)، ومسلم ٣/١٥٣٨ (٥٦١).أخرجه البخاري ٧/٩٥ (٥٥٢٠، ٥٥٢٤)، ومسلم ٣/١٥٤١ (١٩٤١). وأورده الثعلبي ٦/٨.أخرجه البخاري ٧/٩٦ (٥٥٣٠)، ومسلم ٣/١٥٣٣ (١٩٣٢).أخرجه مسلم ٣/١٥٣٤ (١٩٣٤).أخرجه أحمد ٢٨/١٥-١٦ (١٦٨١٦)، ٢٨/١٩-٢٠ (١٦٨١٨)، وأبو داود ٥/٦٢٣ (٣٨٠٦) واللفظ له. قال الدارقطني في السنن ٥/٥١٨ (٤٧٧١): «وهذا حديث ضعيف، وزعم الواقدي أنّ خالد بن الوليد أسلم بعد فتح خيبر». وقال البيهقي في معرفة السنن والآثار ١٤/٩٦ (١٩٢٥٨): «فهذا حديث إسناده مضطرب، ومع اضطرابه مخالف لحديث الثقات». وقال ابن التركماني في الجوهر النقي ٩/٣٢٨: «ورجال هذا السند ثقات». وقال ابن حجر في التلخيص الحبير ٤/٣٧٤ (١٩٩٤): «حديث خالد لا يصح، فقد قال أحمد: إنه حديث منكر. وقال أبو داود: إنه منسوخ». وقال الألباني في الضعيفة ٨/٣٧٣ (٣٩٠٢): «ضعيف».المجثمة: كل حيوان ينصب ويرمى ليقتل، إلا أنها تكثر في الطير والأرانب وأشباه ذلك مما يجثم في الأرض، أي: يلزمها ويلتصق بها، وجثم الطائر جثومًا، وهي بمنزلة البروك للإبل. النهاية (جَثَمَ).أخرجه أحمد ٢٢/٣٥٤-٣٥٥ (١٤٤٦٣) واللفظ له، والترمذي ٣/٣٠٢ (١٥٤٧) مختصرًا. قال الترمذي: «حديث حسن غريب». وقال الهيثمي في المجمع ٥/٤٧ (٨٠٥٣): «رواه الترمذي باختصار، رواه الطبراني في الأوسط، والبزار باختصار، ورجالهما رجال الصحيح، خلا شيخ الطبراني عمر بن حفص السدوسي، وهو ثقة». وقال الألباني في الصحيحة ٤/٢٣٨: «ورجاله ثقات رجال مسلم، لكن عكرمة بن عمار صدوق يغلط».أخرجه أبو داود ٥/٣٤٧ (٣٤٨٠)، والترمذي ٣/١٣٠ (١٣٢٦)، وابن ماجه ٤/٣٩٥ (٣٢٥٠) واللفظ له، والحاكم ٢/٤٠ (٢٢٤٦). وفيه عمر بن زيد؛ قال الترمذي: «حديث غريب، وعمر بن زيد لا نعرف كبير أحد روى عنه غير عبد الرزاق». وقال الحاكم ٢/٤٠ (٢٢٤٦): «صحيح على شرط مسلم، ولم يخرجاه». وقال الذهبي في التلخيص: «عمر بن زيد واه». وقال البوصيري في إتحاف الخيرة ٥/٣٠٥ (٤٧٢٣): «هذا إسناد ضعيف». وقال الألباني في الإرواء ٨/١٤٠ (٢٤٨٧): «ضعيف».أخرجه أبو داود ٥/٦١٥ (٣٧٩٦). قال البغوي في شرح السنة ١١/٢٣٩: «ليس إسناده بذاك». وقال الجوزقاني في الأباطيل والمناكير ٢/٢٦٩-٢٧٠ (٦٠٨): «حديث منكر، وإسناده ليس بمتصل». وقال ابن الجوزي في العلل المتناهية ٢/١٧٢ (١٠٩٧): «هذا حديث لا يصح، وإسماعيل بن عياش ضعيف». وقال الزيلعي في نصب الراية ٤/١٩٥: «قال الخطابي: ليس إسناده بذاك. وقال البيهقي: لم يثبت إسناده، إنما تفرد به إسماعيل بن عياش، وليس بحجة». وقال ابن حجر في الفتح ٩/٦٦٥: «بسند حسن». وأورده الألباني في الصحيحة ٥/٥٠٥ (٢٣٩٠).أخرجه البخاري ٧/٩٧ (٥٥٣٦)، ومسلم ٣/١٥٤١، ١٥٤٢ (١٩٤٣).المحنوذ: المشوي بالحجارة المحماة. لسان العرب (حنذ).أخرجه البخاري ٧/٧١ (٥٣٩١)، ٧/٩٧ (٥٥٣٧)، ومسلم ٣/١٥٤٣ (١٩٤٥، ١٩٤٦).أخرجه ابن أبي شيبة ٨/٦٣، والترمذي ٣/٥٦٩ (١٨٩٥)، وابن ماجه ٤/٣٨٤ (٣٢٣٥)، ٤/٣٨٥ (٣٢٣٧)، ٤/٣٩١ (٣٢٤٥). قال الترمذي: «هذا حديث ليس إسناده بالقوي». وقال الجوزقاني في الأباطيل والمناكير ٢/٢٦٥ (٦٠٦): «هذا حديث باطل، وليس بصحيح». وقال ابن الجوزي في العلل المتناهية ٢/١٧٢-١٧٣ (١٠٩٩): «وهذا لا يصح». وقال البوصيري في مصباح الزجاجة ٣/٢٣٩: «إسناد حديثه ضعيف». وقال ابن حجر في التلخيص الحبير ٤/٣٧٦: «ضعيف». وقال الصالحي في سبل الهدى والرشاد ٧/٢١٨: «وروى ابن أبي شيبة بسند ضعيف». وقال الشوكاني في نيل الأوطار ٨/١٣٨: «الحديث ضعيف».أخرجه أحمد ٢٢/٧٢ (١٤١٦٥)، ٢٢/٣١٦ (١٤٤٢٥)، ٢٢/٣٤٣ (١٤٤٤٩)، والترمذي ٢/٣٧٠-٣٧١ (٨٦٧)، ٣/٥٦٨-٥٦٩ (١٨٩٤)، والنسائي ٥/١٩١ (٢٨٣٦)، ٧/٢٠٠ (٤٣٢٣)، وابن ماجه ٤/٣٨٥ (٣٢٣٦)، والحاكم ١/٦٢٢ (١٦٦٢)، وابن خزيمة ٤/٣١٤ (٢٦٤٥)، وابن حبان ٩/٢٧٨ (٣٩٦٥). قال الترمذي: «حديث حسن صحيح». وقال في العلل ص٢٩٧ (٥٥١) عن البخاري: «هو حديث صحيح». وقال الجوزقاني في الأباطيل والمناكير ٢/٢٦٦ (٦٠٧): «هذا حديث حسن». وقال ابن الملقن في البدر المنير ٩/٣٦٨: «هذا الحديث صحيح». وقال الألباني في الإرواء ٨/١٤٥ (٢٤٩٤): «صحيح».أخرجه ابن أبي حاتم ٥/١٤٠٥.أخرجه ابن ماجه (٣٢٤٨). صححه الألباني (صحيح سنن ابن ماجه-٢٦٢٨).الجِرِّيث: ضرب من السمك، ويقال له: الجِرِّيُّ. لسان العرب (جرث).أخرجه ابن أبي شيبة ٨/٨٦، ١٤٣. وعزاه السيوطي إلى أبي الشيخ.ضرب من السمك. لسان العرب (جرث).أخرجه عبد الرزاق في مصنفه ٤/٥٣٦ (٨٧٧٥)، وابن أبي شيبة في مصنفه (ت: محمد عوامة) ١٢/٣٦٥ (٢٤٨٥٢).أخرجه ابن أبي شيبة في مصنفه (ت: محمد عوامة) ١١/٦٧ (٢١٣٧٤).عزاه السيوطي إلى أبي الشيخ.
6,146," <q>﴿وَعَلَى ٱلَّذِینَ هَادُوا۟﴾</q> - تفسير ٢٦٥٦٠- عن مجاهد بن جبر -من طريق أبي بشر- قال: تَهَوَّدت اليهود يوم السبت{1}. (ز) ٢٦٥٦١- قال مقاتل بن سليمان: ثم بيَّن ما حَرَّم على اليهود{2}. (ز) <q>﴿حَرَّمۡنَا كُلَّ ذِی ظُفُرࣲۖ﴾</q> - تفسير ٢٦٥٦٢- عن عبد الله بن عباس -من طريق سعيد بن جبير- في قوله: <q>﴿وعلى الذين هادوا حرمنا كل ذي ظفر﴾</q>، قال: هو الذي ليس بمُنفَرِج الأصابع. يعني: ليس بمشقوق الأصابع؛ منها: الإبل، والنعام{3}. (٦/٢٤٤) ٢٦٥٦٣- عن الضحاك بن مزاحم= (ز) ٢٦٥٦٤- وعكرمة مولى ابن عباس= (ز) ٢٦٥٦٥- وعطاء الخراساني= (ز) ٢٦٥٦٦- ومقاتل بن حيان، نحو ذلك{4}. (ز) ٢٦٥٦٧- وعن إسماعيل السدي= (ز) ٢٦٥٦٨- وقتادة بن دعامة، نحو ذلك، وزاد فيه: والوز{4}. (ز) ٢٦٥٦٩- عن عبد الله بن عباس -من طريق علي بن أبي طلحة- <q>﴿وعلى الذين هادوا حرمنا كل ذي ظفر﴾</q>، قال: هو البعير، والنعامة{6}. (٦/٢٤٤) ٢٦٥٧٠- عن سعيد بن جبير -من طريق عطاء بن السائب- في قوله: <q>﴿وعلى الذين هادوا حرمنا كل ذي ظفر﴾</q>، قال: كل شيء متفرق الأصابع، ومنه الديك، وفي لفظ: هو ليس الذي بمنفرج الأصابع{7}. (ز) ٢٦٥٧١- عن مجاهد بن جبر -من طريق ابن جُرَيج- <q>﴿حرمنا كل ذي ظفر﴾</q>، قال: كلَّ شيءٍ لم تُفْرَجْ قوائمُه من البهائم، وما انفَرَج أكَلتْه اليهود. قال: انفَذَّت قوائمُ الدجاج والعصافير، فيهود تأكُلُه، ولم تُفرَجْ قائمة البعير؛ خفُّه، ولا خفُّ النعامة، ولا قائمةُ الوَزِّينةِ{8}، فلا تأكُلُ اليهود الإبل، ولا النعام، ولا الوَزِّينة، ولا كلَّ شيءٍ لم تُفْرَجْ قائمتُه كذلك، ولا تأكُلُ حمار الوحش{9}. (٦/٢٤٥) ٢٦٥٧٢- عن قتادة بن دعامة -من طريق سعيد- <q>﴿حرمنا كل ذي ظفر﴾</q>، قال: كان يُقال: هو البعير، والنعامة، في أشياءَ{10} من الطير، والحِيتان{11}. (٦/٢٤٥) ٢٦٥٧٣- عن قتادة بن دعامة -من طريق مَعْمَر- <q>﴿كل ذي ظفر﴾</q>، قال: الإبل والنعام، ظفر يد البعير ورجله، والنعام أيضًا كذلك، وحرم عليهم أيضًا من الطير البط وشبهه، وكل شيء ليس بمشقوق الأصابع{12}. (ز) ٢٦٥٧٤- عن إسماعيل السُّدِّيّ -من طريق أسباط-: أمّا <q>﴿كل ذي ظفر﴾</q> فالإبل، والنعام{13}. (ز) ٢٦٥٧٥- عن حنش الصنعاني -من طريق ربيعة بن أبي سليم - في قول الله: <q>﴿حرمنا﴾</q> عليهم، <q>﴿كل ذي ظفر﴾</q> إنّه الخنزير، والنعام، والبعير{14}. (ز) ٢٦٥٧٦- قال مقاتل بن سليمان: <q>﴿وعلى الذين هادوا حرمنا كل ذي ظفر﴾</q>، يعني: الإبل، والنعامة، والوَزُّ{15}، والبط، وكل شيء له خُفٌّ وظُفُر من الدوابِّ والطير، فهو عليهم حرام{2}. (ز) ٢٦٥٧٧- عن عبد الملك ابن جُرَيْج: <q>﴿حرمنا كل ذي ظفر﴾</q>، قال: كلَّ شيءٍ لم تُفْرَجْ قوائمُه من البهائم، وما انفَرَجَت قوائمُه أكَلُوه، ولا يأكلون البعير، ولا النعامة، ولا البطَّ، ولا الوَزَّ، ولا حمار الوَحْش{17}. (٦/٢٤٥) ٢٦٥٧٨- قال عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿وعلى الذين هادوا حرمنا كل ذي ظفر﴾</q>: الإبل قط{18}٢٤٢٦. (ز) ٢٤٢٦ أفادت الآثارُ الاختلافَ في المراد بقوله تعالى: <q>﴿كُلَّ ذِي ظُفُرٍ﴾</q> على قولين: أحدهما: أنّ المراد به: كل ما لم يكن مشقوق الأصابع من البهائم والطير؛ كالإبل، والنعام، والإوزّ، والبط. وهذا قول ابن عباس، ومجاهد، وسعيد بن جبير، وقتادة، والسديّ، وغيرهم. والآخر: أنّ المراد به: الإبل فقط. وهذا قول ابن زيد. ورجَّحَ ابنُ جرير (٩/٦٤١) القولَ الأولَ استنادًا إلى عموم الآية، وقول الأكثر، وقال: «لأنّ الله -جلَّ ثناؤه- أخبر أنه حرَّم على اليهود كلَّ ذي ظفر، فغير جائز إخراج شيء من عموم هذا الخبر، إلا ما أجمع أهل العلم أنه خارج منه. وإذ كان ذلك كذلك، وكان النعامُ وكلُّ ما لم يكن من البهائم والطير مما له ظفر غير منفرج الأصابع داخلًا في ظاهر التنزيل؛ وجب أن يُحْكَم له بأنه داخل في الخبر؛ إذ لم يأتِ بأن بعض ذلك غير داخلٍ في الآية خبرٌ عن الله ولا عن رسوله، وكانت الأمة أكثرها مُجْمِعٌ على أنه فيه داخلٌ». وحكى ابنُ عطية (٣/٤٨٣) تضعيف التخصيص الذي قال به ابن زيد. وذكر أنّ النقاش حكى عن ثعلب أنّ كل ما لا يصيد فهو ذو ظفر، وما يصيد فهو ذو مخلب. وعلَّق عليه بقوله: «وهذا غير مُطَّرِد؛ لأنّ الأسد ذو ظفر». <q>﴿وَمِنَ ٱلۡبَقَرِ وَٱلۡغَنَمِ حَرَّمۡنَا عَلَیۡهِمۡ شُحُومَهُمَاۤ﴾</q> - تفسير ٢٦٥٧٩- عن جابر بن عبد الله: سمعتُ النبي ﷺ قال: «قاتَل اللهُ اليهودَ؛ لَمّا حرَّم الله عليهم شحومَها جَمَلُوهُ{19}، ثم باعوه، فأَكَلُوها»{20}. (٦/٢٤٥) ٢٦٥٨٠- عن أسامة بن زيد، قال: قال رسول الله ﷺ: «لعن الله اليهود؛ حُرِّمت عليهم الشحوم، فباعُوها، وأَكَلُوا أثمانَها»{21}. (٦/٢٤٦) ٢٦٥٨١- عن عمر بن الخطاب، قال: قال رسول الله ﷺ: «لعن الله اليهود؛ حُرِّمَت عليهم الشحوم، فباعُوها، وأَكَلُوا أثمانَها»{22}. (٦/٢٤٦) ٢٦٥٨٢- عن أبي هريرة، قال: قال رسول الله ﷺ: «قاتل الله اليهود؛ حرَّم الله عليهم الشحوم، فباعوه، وأكَلوا ثمنَه»{23}. (٦/٢٤٦) ٢٦٥٨٣- عن ابن عباس، أنّ رسول الله ﷺ قال: «لعن الله اليهود -ثلاثًا-؛ إنّ الله حرَّم عليهم الشحوم، فباعُوها، وأكَلُوا أثمانَها، وإن الله لم يُحرِّمْ على قومٍ أكْلَ شيءٍ إلا حرَّم عليهم ثمنَه»{24}. (٦/٢٤٦) ٢٦٥٨٤- عن قتادة بن دعامة -من طريق سعيد- قال: <q>﴿ومِنَ البَقَرِ والغَنَمِ حَرَّمْنا عَلَيْهِمْ شُحُومَهُما﴾</q>: الثُّرُوب{25}. ذُكر لنا: أنّ نبي الله ﷺ كان يقول: «قاتل الله اليهود؛ حرَّم اللهُ عليهم الثُّرُوب، ثم أكلوا أثمانها»{26}. (ز) ٢٦٥٨٥- عن إسماعيل السُّدِّيّ -من طريق أسباط- في قوله: <q>﴿ومن البقر والغنم حرمنا عليهم شحومهما﴾</q>، قال: حرَّم الله عليهم الثَّرْبَ، وشحم الكُلْيَتَيْن{27}. (٦/٢٤٧) ٢٦٥٨٦- قال مقاتل بن سليمان: <q>﴿ومن البقر والغنم حرمنا عليهم شحومهما﴾</q>، وحرَّم عليهم الشحوم من البقر والغنم{2}. (ز) ٢٦٥٨٧- عن عبد الملك ابن جريج -من طريق حجاج- قال: إنّما حرَّم عليهم الثَّرْبَ، وشحم الكُلْيَة، وكلَّ شحم كان ليس في عظم{29}. (٦/٢٤٧) ٢٦٥٨٨- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿حرمنا عليهم شحومهما﴾</q>، قال: إنّما حرم عليهم الثُّرُوب والكُلْيَتَيْن{30}٢٤٢٧. (ز) ٢٤٢٧ أفادت الآثارُ الاختلاف في الشحوم التي أخبر الله تعالى أنه حرَّمها على اليهود من البقر والغنم على ثلاثة أقوال: أولها: أنّها شحوم الثُّرُوبِ خاصَّةً [والثروب، جمع ثَرْب: وهو شحم غشي الكرش والأمعاء، رقيق]. وهذا قول قتادة. ثانيها: أنّها كل شحم لم يكن مُختلطًا بعظم، ولا على عظم. وهذا قول ابن جريج. ثالثها: أنّها شحم الثَّرْب والكُلى. وهو قول السديّ، وابن زيد. وذَهَبَ ابنُ جرير (٩/٦٤٢) إلى أنّ المراد: كل شحم إلا ما استثني. استنادًا إلى العموم، والسنة، فقال: «والصواب في ذلك من القول أن يقال: إنّ الله أخبر أنه كان حرَّم على اليهود من البقر والغنم شحومهما إلا ما استثناه منها، مما حملت ظهورهما أو الحَوايا أو ما اختلط بعظم، فكل شحم سوى ما استثناه الله في كتابه من البقر والغنم فإنه كان محرَّمًا عليهم. وبنحو ذلك من القول تظاهرت الأخبار عن رسول الله ﷺ، وذلك قوله: «قاتل الله اليهود، حُرِّمَت عليهم الشحوم فجملوها، ثم باعوها وأكلوا أثمانها»». وبنحو ذلك قال ابنُ عطية (٣/٤٨٣). <q>﴿إِلَّا مَا حَمَلَتۡ ظُهُورُهُمَاۤ﴾</q> - تفسير ٢٦٥٨٩- عن عبد الله بن عباس -من طريق علي- في قوله: <q>﴿ومن البقر والغنم حرمنا عليهم شحومهما إلا ما حملت ظهورهما﴾</q>، يعني: ما عَلِق بالظَّهرِ من الشحم{31}. (٦/٢٤٧) ٢٦٥٩٠- عن الضحاك بن مُزاحِم= (ز) ٢٦٥٩١- ومقاتل بن حيان، نحو ذلك{4}. (ز) ٢٦٥٩٢- عن أبي صالح باذام -من طريق ابن أبي خالد- في قوله: <q>﴿إلا ما حملت ظهورهما﴾</q>، قال: الأَلْيةُ{33}. (٦/٢٤٧) ٢٦٥٩٣- عن إسماعيل السُّدِّيّ -من طريق أسباط-: أمّا <q>﴿ما حملت ظهورهما﴾</q> فالألْياتُ{34}. (ز) ٢٦٥٩٤- قال مقاتل بن سليمان: استثنى ما أحل لهم من الشحوم، فقال: <q>﴿إلا ما حملت ظهورهما﴾</q>. يعني: ظهور البقر، والغنم، والأكتاف، والألْيةُ{2}. (ز) <q>﴿أَوِ ٱلۡحَوَایَاۤ أَوۡ﴾</q> - تفسير ٢٦٥٩٥- عن عبد الله بن عباس -من طريق علي- في قوله: <q>﴿أو الحوايا﴾</q>: هو المِبْعَرُ{36}. (٦/٢٤٧) ٢٦٥٩٦- عن سعيد بن جبير -من طريق عطاء- <q>﴿أوالحوايا﴾</q>، قال: المَباعِر{37}. (ز) ٢٦٥٩٧- عن مجاهد بن جبر -من طريق ابن أبي نَجِيح- في قوله: <q>﴿أو الحوايا﴾</q>، قال: المَباعِر{38}. (٦/٢٤٧) ٢٦٥٩٨- عن مجاهد بن جبر -من طريق ابن أبي نجيح- <q>﴿الحوايا﴾</q>: المِبْعَرُ، والمَرْبِضُ{39}. (ز) ٢٦٥٩٩- عن الضحاك بن مزاحم -من طريق جويبر- في قوله: <q>﴿أو الحوايا﴾</q>، قال: المرابضُ، والمباعر{40}. (٦/٢٤٧) ٢٦٦٠٠- عن الضحاك بن مزاحم -من طريق عبيد بن سليمان-: أمّا قوله: <q>﴿أو الحوايا﴾</q> فالبطون غير الثروب{41}. (ز) ٢٦٦٠١- عن مقاتل بن حيان، مثل ذلك{42}. (ز) ٢٦٦٠٢- عن أبي صالح باذام، في قوله: <q>﴿أو الحوايا﴾</q>، قال: المِبْعَرُ{43}. (٦/٢٤٧) ٢٦٦٠٣- عن قتادة بن دعامة -من طريق سعيد- <q>﴿أوالحوايا﴾</q>، قال: المِبْعَر{44}. (ز) ٢٦٦٠٤- عن إسماعيل السدي -من طريق أسباط- <q>﴿أوالحوايا﴾</q>، قال: المباعِر{45}. (ز) ٢٦٦٠٥- عن عطاء الخراساني= (ز) ٢٦٦٠٦- ومقاتل بن حيان، نحو ذلك{46}. (ز) ٢٦٦٠٧- قال مقاتل بن سليمان: <q>﴿أو الحوايا﴾</q>، يعني: المِعى{2}. (ز) ٢٦٦٠٨- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- قال: <q>﴿الحوايا﴾</q>: المرابِض التي تكون فيها الأمعاء، تكون وسَطَها، وهي بنات اللَّبَن{48}، وهي في كلام العرب تُدْعى: المرابِض{49}٢٤٢٨. (٦/٢٤٨) ٢٤٢٨ ذكر ابنُ عطية (٣/٤٨٥) أنّ <q>﴿الحَوايا﴾</q> معطوف على ما في قول: <q>﴿إلّا ما حَمَلَتْ﴾</q>، فهي في موضع نصب عطفًا على المنصوب بالاستثناء، ثم ذكر أنّ البعض قال بعطفها على الشحوم. وانتَقَده مستندًا لظاهر لفظ الآية، فقال: «وعلى هذا تدخل <q>﴿الحَوايا﴾</q> في التحريم، وهذا قولٌ لا يعضده اللفظ ولا المعنى، بل يدفعانه». <q>﴿أَوۡ مَا ٱخۡتَلَطَ بِعَظۡمࣲۚ﴾</q> - تفسير ٢٦٦٠٩- عن عبد الله بن عباس، في قوله: <q>﴿أو ما اختلط بعظم﴾</q>، قال: الأَلْيَةُ؛ اخْتَلَط شحم الأَلْية بالعُصْعُص{50} فهو حلال، وكلُّ شحم القوائم والجنب والرأس والعين والأذن يقولون: قد اختلَط ذلك بعظم. فهو حلال لهم، إنما حرَّم عليهم الثَّرْبَ، وشحم الكُلْيَة، وكلَّ شيءٍ كان كذلك ليس في عظم{51}. (٦/٢٤٨) ٢٦٦١٠- عن الضحاك بن مُزاحِم -من طريق جُوَيبِر- في قوله: <q>﴿أو ما اختلط بعظم﴾</q>، قال: ما أُلْزِق بالعظم{52}. (٦/٢٤٧) ٢٦٦١١- عن أبي صالح باذام -من طريق ابن أبي خالد- في قوله: <q>﴿أو ما اختلط بعظم﴾</q>، قال: الشَّحْم{53}. (٦/٢٤٧) ٢٦٦١٢- عن إسماعيل السُّدِّيّ -من طريق أسباط- <q>﴿أو ما اختلط بعظم﴾</q>: فما كان من شحم على عظم{54}. (ز) ٢٦٦١٣- عن مقاتل بن حيان، نحو ذلك{42}. (ز) ٢٦٦١٤- قال مقاتل بن سليمان: <q>﴿أو ما اختلط﴾</q> من الشحم <q>﴿بعظم﴾</q>، فكلُّ هذا حلال لهم، وحُرِّم عليهم شحوم الكُلْيَتين، والثُّرُوبُ{2}. (ز) ٢٦٦١٥- عن عبد الملك ابن جُرَيْج -من طريق حجاج- <q>﴿أو ما اختلط بعظم﴾</q>، قال: شحم الأَلْية بالعُصْعُص، فهو حلال، وكل شيء في القوائم والجنب والرأس والعين قد اختلط بعظم، فهو حلال{57}. (ز) <q>﴿ذَ ٰ⁠لِكَ جَزَیۡنَـٰهُم بِبَغۡیِهِمۡۖ وَإِنَّا لَصَـٰدِقُونَ ۝١٤٦﴾</q> - تفسير ٢٦٦١٦- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿ذلك جزيناهم ببغيهم﴾</q>، قال: إنّما حرَّم الله ذلك عليهم عقوبةً ببغيِهم، فشدَّد عليهم بذلك، وما هو بخبيث{58}. (٦/٢٤٨) ٢٦٦١٧- قال مقاتل بن سليمان: <q>﴿ذلك﴾</q> التحريم <q>﴿جزيناهم ببغيهم﴾</q> يعني: عقوبة بقتلهم الأنبياء، وبصدِّهم عن سبيل الله، وبأكلهم الربا، واستحلالهم أموال الناس بالباطل، فهذا البغي، <q>﴿وإنا لصادقون﴾</q> بذلك{2}. (ز) ٢٦٦١٨- عن مقاتل بن حيان -من طريق بُكَيْر بن معروف- في قوله: <q>﴿ذلك جزيناهم ببغيهم﴾</q>، يقول: باستحلالهم ما كان الله حرَّم عليهم{60}. (ز) ٢٦٦١٩- قال عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿ذلك جزيناهم ببغيهم﴾</q>: فعلنا ذلك بهم ببغيهم{61}. (ز) ",footnotes:1:أخرجه ابن أبي حاتم ٥/١٤٠٩.تفسير مقاتل بن سليمان ١/٥٩٥.أخرجه ابن جرير ٩/٦٣٨ مختصرًا، وابن أبي حاتم ٥/١٤١٠.علَّقه ابن أبي حاتم ٥/١٤١٠.علَّقه ابن أبي حاتم ٥/١٤١٠.أخرجه ابن جرير ٩/٦٣٨، والبيهقي في سُنَنه ١٠/٥٣. وعزاه ابن حجر في الفتح ٨/٢٩٥ إلى ابن أبي حاتم. وعزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ٩/٦٣٩. وعلَّقه ابن أبي حاتم ٥/١٤١٠. وعزا السيوطي ٦/٢٤٥ إلى أبي الشيخ قوله: الديكُ منه.الوزِّينة: الإوزة. التاج (وزز).تفسير مجاهد ص٣٣٠، وأخرجه ابن جرير ٩/٦٤٠. وعلَّقه ابن أبي حاتم ٥/١٤١٠. وعزاه السيوطي إلى أبي الشيخ.كذا في المطبوع من الدر ٦/٢٤٥، وأخرجه ابن جرير ٩/٦٣٩ بلفظ: وأشباهه.أخرجه ابن جرير ٩/٦٣٩. وعزاه السيوطي إلى عبد بن حميد.أخرجه عبد الرزاق ٢/٢٢١، وابن جرير ٩/٦٣٩. وعلَّقه ابن أبي حاتم ٥/١٤١٠.أخرجه ابن جرير ٩/٦٤٠. وعلقه ابن أبي حاتم ٥/١٤١٠.أخرجه عبد الله بن وهب في الجامع - تفسير القرآن ١/٨١ (١٨٢).الوَزُّ، لغةٌ فِي الإوَزِّ، وهو من طير الماء. تاج العروس (وزز).تفسير مقاتل بن سليمان ١/٥٩٥.عزاه السيوطي إلى أبي الشيخ.أخرجه ابن جرير ٩/٦٤٠.جمَلُوه: أذابوه واستخرجوا دهنه. النهاية (جمل).أخرجه البخاري ٣/٨٤ (٢٢٣٦)، ٦/٥٧ (٤٦٣٣)، ومسلم ٣/١٢٠٧ (١٥٨١).أخرجه الحاكم ٤/٢١٥ (٧٤١٤)، والدارقطني في العلل الواردة في الأحاديث النبوية ١/٧٨ (٦) واللفظ له. قال البزار في مسنده ٧/٥٩ (٢٦٠٨): «وهذا الحديث لا نعلمه يروى عن أسامة إلا من هذا الوجه بهذا الإسناد». وقال الحاكم: «هذا حديث صحيح الإسناد، ولم يخرجاه». وقال الذهبي في التلخيص: «صحيح».أخرجه البخاري ٣/٨٢ (٢٢٢٣)، ٤/١٧٠ (٣٤٦٠)، ومسلم ٣/١٢٠٧ (١٥٨٢).أخرجه البخاري ٣/٨٢ (٢٢٢٤)، ٤/١٧٠ (٣٤٦٠)، ومسلم ٣/١٢٠٨ (١٥٨٣).أخرجه أحمد ٤/٩٥ (٢٢٢١)، ٤/٤١٦ (٢٦٧٨)، ٥/١١٥ (٢٩٦١)، وأبو داود ٥/٣٥٢ (٣٤٨٨). قال ابن الملقن في تحفة المحتاج ٢/٢٠٤ (١١٧٧): «بإسناد صحيح». وقال الرباعي في فتح الغفار ٣/١١٥٣ (٣٥٣٣): «ورجال إسناده ثقات».الثُّرُوبُ: الشحم الرقيق الذي يُغَشّي الكَرِش والأمعاء، الواحد: ثَرْب. النهاية (ثرب).أخرجه ابن جرير ٩/٦٤١.الكُلْيَتان، بالضم، من الإنسانِ وغيرِه من الحيوان: لحمتان حَمْراوانِ لازقتان بعَظْم الصُّلْبِ عند الخاصِرَتَيْن، في كُظْرَيْن من الشحم. تاج العروس (كلى). والأثر أخرجه ابن جرير ٩/٦٤٢، وابن أبي حاتم ٥/١٤١٠.تفسير مقاتل بن سليمان ١/٥٩٥.أخرجه ابن جرير ٩/٦٤٢. وعزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ٩/٦٤٢، وقال: هكذا هو في كتابي عن يونس، وأنا أحسب أنه الكلى.أخرجه ابن جرير ٩/٦٤٣، وابن أبي حاتم ٥/١٤١٠، والبيهقي في سننه ١٠/٨. وعزاه السيوطي إلى ابن المنذر.علَّقه ابن أبي حاتم ٥/١٤١٠.أخرجه ابن جرير ٩/٦٤٣، وابن أبي حاتم ٥/١٤١٠. وعزاه السيوطي إلى أبي الشيخ. والأَلْيَةُ: طرف الشاة. النهاية (ألا).أخرجه ابن جرير ٩/٦٤٣. وعلَقه ابن أبي حاتم ٥/١٤١٠.تفسير مقاتل بن سليمان ١/٥٩٥.أخرجه ابن جرير ٩/٦٤٤، وابن أبي حاتم ٥/١٤١٠، والبيهقي في سننه ١٠/٨. وعزاه السيوطي إلى ابن المنذر. والمبْعَرُ -بكسر الميم، وفتحها-: مكان البَعر من كل ذي أربع، والجمع: المباعر. لسان العرب (بعر).أخرجه ابن جرير ٩/٦٤٥. وعلَّقه ابن أبي حاتم ٥/١٤١٠-١٤١١.تفسير مجاهد ص٣٣٠، وأخرجه ابن جرير ٩/٦٤٤. وعلَّقه ابن أبي حاتم ٥/١٤١٠-١٤١١. وعزاه السيوطي إلى ابن أبي شيبة، وعبد بن حميد، وابن المنذر.أخرجه ابن جرير ٩/٦٤٤.أخرجه ابن جرير ٩/٦٤٥، وابن أبي حاتم ٥/١٤١١. وعزاه السيوطي إلى ابن أبي شيبة، وابن المنذر.أخرجه ابن جرير ٩/٦٤٥، كما أخرجه ابن أبي حاتم ٥/١٤١١ من طريق علي بن الحكم، ثم قال: وخالفه عبيد بن سلمان عن الضحاك فقال: يعني بالثروب: غير البطون.علَّقه ابن أبي حاتم ٥/١٤١١.علَّقه ابن أبي حاتم ٥/١٤١٠. وعزاه السيوطي إلى أبي الشيخ.أخرجه ابن جرير ٩/٦٤٥، وعبد الرزاق ٢/٢٢١ من طريق معمر. وعلقه ابن أبي حاتم ٥/١٤١٠، ١٤١١.أخرجه ابن جرير ٩/٦٤٥. وعلَّقه ابن أبي حاتم ٥/١٤١٠، ١٤١١.علَّقه ابن أبي حاتم ٥/١٤١٠، ١٤١١.تفسير مقاتل بن سليمان ١/٥٩٥.بنات اللَّبَن: ما صغُر من الأمعاء. لسان العرب (بنو).أخرجه ابن جرير ٩/٦٤٦، وابن أبي حاتم ٥/١٤١١ من طريق أصبغ.العُصْعُصُ والعَصْعَصُ: أصل الذَّنَبِ. لسان العرب (عصص).عزاه السيوطي إلى ابن المنذر، وأبي الشيخ.أخرجه ابن أبي حاتم ٥/١٤١١. وعزاه السيوطي إلى ابن أبي شيبة، وابن المنذر.أخرجه ابن أبي حاتم ٥/١٤١١. وعزاه السيوطي إلى أبي الشيخ.أخرجه ابن جرير ٩/٦٤٦. وعلَّقه ابن أبي حاتم ٥/١٤١١.علَّقه ابن أبي حاتم ٥/١٤١١.تفسير مقاتل بن سليمان ١/٥٩٥.أخرجه ابن جرير ٩/٦٤٦.أخرجه ابن جرير ٩/٦٤٧، وابن أبي حاتم ٥/١٤١١ كلاهما بلفظ: إنّما حرَّم ذلك عليهم عقوبة ببغيهم. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وأبي الشيخ.تفسير مقاتل بن سليمان ١/٥٩٥.أخرجه ابن أبي حاتم ٤/١١١٤، ٥/١٤١٢.أخرجه ابن جرير ٩/٦٤٧.
