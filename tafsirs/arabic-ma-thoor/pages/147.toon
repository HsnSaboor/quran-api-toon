quran[4]{c,v,t}:
  6,143,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿ثَمَـٰنِیَةَ أَزۡوَ ٰ⁠جࣲۖ مِّنَ ٱلضَّأۡنِ ٱثۡنَیۡنِ وَمِنَ ٱلۡمَعۡزِ ٱثۡنَیۡنِۗ﴾</span> - قراءات</h3></p><p><div></p><p><p><span class="item-no">٢٦٤٨٣<span class="dash">-</span></span> عن لهيعة بن عقبة: أنّه سمع <span class="name-2">أبان بن عثمان بن عفان</span> يوم الجمعة على المنبر يقرأ سورة الأنعام: (مِنَ الضَّأْنِ اثْنانِ){1}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿ثَمَـٰنِیَةَ أَزۡوَ ٰ⁠جࣲۖ مِّنَ ٱلضَّأۡنِ ٱثۡنَیۡنِ وَمِنَ ٱلۡمَعۡزِ ٱثۡنَیۡنِۗ﴾</span> - تفسير الآية</h3></p><p><div></p><p><p><span class="item-no">٢٦٤٨٤<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطاء- قال: الأزواجُ الثمانية؛ من الإبل، والبقر، والضَّأْن، والمعز{2}. (٦/٢٣١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٦٤٨٥<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطية العوفي- في قوله: <span class="qpc-hafs">﴿ثمانية أزواج من الضأن اثنين ومن المعز اثنين﴾</span>، قال: فهذه أربعة أزواج{3}. (٦/٢٣٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٦٤٨٦<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿ثمانية أزواج﴾</span>، قال: في شأن ما نَهى الله عنه؛ عن البحيرة، والسائبة{4}. (٦/٢٣١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٦٤٨٧<span class="dash">-</span></span> عن <span class="name-2">الضحاك بن مُزاحِم</span> -من طريق جُوَيْبِر-: <span class="qpc-hafs">﴿من الضأن اثنين﴾</span> ذكر وأنثى، <span class="qpc-hafs">﴿ومن البقر اثنين﴾</span> ذكر وأنثى، <span class="qpc-hafs">﴿ومن الإبل اثنين﴾</span> ذكر وأنثى{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٦٤٨٨<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span>، <span class="qpc-hafs">﴿ثمانية أزواج﴾</span>، قال: الذكر والأنثى زوجان{6}. (٦/٢٣١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٦٤٨٩<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- في قوله: <span class="qpc-hafs">﴿ثمانية أزواج﴾</span> الآية، يقول: أنزَلتُ لكم ثمانيةَ أزواجٍ من هذا الذي عدَدْتُ، ذكرًا وأُنثى{7}. (٦/٢٣١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٦٤٩٠<span class="dash">-</span></span> عن <span class="name-2">ليث بن أبي سليم</span> -من طريق حسن بن صالح - قال: الجاموس والبُخْتِيُّ مِن الأزواج الثمانية{8}. (٦/٢٣١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٦٤٩١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثم قال: أنزل <span class="qpc-hafs">﴿ثمانية أزواج﴾</span> قبل خلق آدم ﵇، <span class="qpc-hafs">﴿من الضأن اثنين﴾</span> يعني: ذكرًا وأنثى، <span class="qpc-hafs">﴿ومن المعز اثنين﴾</span> ذكرًا وأنثى{9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٦٤٩٢<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿ثَمانِيَةَ أزْواجٍ مِنَ الضَّأْنِ اثْنَيْنِ ومِنَ المَعْزِ اثْنَيْنِ﴾</span>، قال: الأنعام هي: الإبل، والضأن، والمعز، هذه الأنعام التي قال الله: <span class="qpc-hafs">﴿ثمانيةأزواج﴾</span>{10}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿قُلۡ ءَاۤلذَّكَرَیۡنِ حَرَّمَ أَمِ ٱلۡأُنثَیَیۡنِ أَمَّا ٱشۡتَمَلَتۡ عَلَیۡهِ أَرۡحَامُ ٱلۡأُنثَیَیۡنِۖ نَبِّـُٔونِی بِعِلۡمٍ إِن كُنتُمۡ صَـٰدِقِینَ ۝١٤٣﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٢٦٤٩٣<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطية العوفي، وعلي بن أبي طلحة- في قوله: <span class="qpc-hafs">﴿قل آلذكرين حرم أم الأنثيين﴾</span> يقول: لم أُحرِّمْ شيئًا مِن ذلك، <span class="qpc-hafs">﴿أما اشتملت عليه أرحام الأنثيين﴾</span> يعني: هل تشتمِلُ الرَّحِمُ إلا على ذكر أو أنثى، فلِمَ تحرِّمون بعضًا وتُحِلُّون بعضًا؟ <span class="qpc-hafs">﴿نبئوني بعلم إن كنتم صادقين﴾</span> يقول: كلُّه حلال، يعني: ما تقدَّم ذِكْرُه مما حرَّمه أهلُ الجاهلية{11}. (٦/٢٣٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٦٤٩٤<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق أبي رجاء - في قوله: <span class="qpc-hafs">﴿أما اشتملت عليه أرحام الأنثيين﴾</span>، قال: ما حمَلت الرَّحِم{12}. (٦/٢٣٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٦٤٩٥<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- قوله: <span class="qpc-hafs">﴿ثَمانِيَةَ أزْواجٍ مِنَ الضَّأْنِ اثْنَيْنِ ومِنَ المَعْزِ اثْنَيْنِ﴾</span> الآية: إنّ كُلَّ هذا لم أُحَرِّم منه قليلًا ولا كثيرًا، ذكرًا ولا أنثى{13}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٦٤٩٦<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- <span class="qpc-hafs">﴿مِنَ الضَّأْنِ اثْنَيْنِ ومِنَ المَعْزِ اثْنَيْنِ﴾</span> قال: سَلْهُم <span class="qpc-hafs">﴿آلذَّكَرَيْنِ حَرَّمَ أمِ الأُنْثَيَيْنِ أمّا اشْتَمَلَتْ عَلَيْهِ أرْحامُ الأُنْثَيَيْنِ﴾</span> أي: لم أحرم من هذا شيئًا، <span class="qpc-hafs">﴿نَبِّئُونِي بِعِلْمٍ إنْ كُنْتُمْ صادِقِينَ﴾</span> فذكر من الإبل والبقر نحو ذلك{14}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٦٤٩٧<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- <span class="qpc-hafs">﴿ثَمانِيَةَ أزْواجٍ مِنَ الضَّأْنِ اثْنَيْنِ ومِنَ المَعْزِ اثْنَيْنِ﴾</span>، <span class="qpc-hafs">﴿ومِنَ الإبِلِ اثْنَيْنِ ومِنَ البَقَرِ اثْنَيْنِ﴾</span>، يقول: أنزلت لكم ثمانية أزواج من هذا الذي عدَدْتُ، ذكرًا وأنثى، فالذكرين حرَّمت عليكم أم الأنثيين، أمّا اشتملت عليه أرحام الأنثيين؟ يقول: أي: ما اشتملت عليه أرحام الأنثيين، ما تشتمل إلا على ذكر أو أنثى، فما حرَّمْتُ عليكم ذكرًا ولا أنثى من الثمانية، إنّما ذَكَر هذا مِن أجل ما حرَّموا من الأنعام{15}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٦٤٩٨<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿قل﴾</span> يا محمد، لِمَن حرم ذكور الأنعام تارة وإناثها أخرى، ونسب ذلك إلى الله: <span class="qpc-hafs">﴿آلذكرين﴾</span> من الضأن والمعز <span class="qpc-hafs">﴿حرَّم﴾</span> الله <span class="qpc-hafs">﴿عليكم أم الأنثيين﴾</span> منهما، <span class="qpc-hafs">﴿أما اشتملت عليه أرحام الأنثيين﴾</span> ذَكَرًا كان أو أنثى؟ <span class="qpc-hafs">﴿نبئوني بعلم﴾</span> عن كيفية تحريم ذلك؛ <span class="qpc-hafs">﴿إن كنتم صادقين﴾</span> فيه. المعنى: من أين جاء التحريم؟ فإن كان مِن قبل الذُّكُورة فجميع الذكور حرام، أو الأنوثة فجميع الإناث، أو اشتمال الرحم فالزوجان، فمن أين التخصيص؟! والاستفهام للاستنكار. <span class="qpc-hafs">﴿نبئوني بعلم إن كنتم صادقين﴾</span> يقول الله لنبيه ﷺ: قل لهم: نبئوني بعلم إن كنتم صادقين بأنّ الله حرَّم هذا{9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٦٤٩٩<span class="dash">-</span></span> قال <span class="name-3">عبد الملك ابن جُرَيْج</span> -من طريق حجّاج- يقول: مِن أين حرَّمت هذا؟ من قِبَل الذكرين أم من قِبَل الأنثيين، أما اشتملت عليه أرحام الأنثيين؟ وإنها لا تشتمل إلا على ذكر أو أنثى، فمن أين جاء التحريم؟! فأجابوا هم: وجدنا آباءنا كذلك يفعلون{17}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٦٥٠٠<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿قُلْ آلذَّكَرَيْنِ حَرَّمَ أمِ الأُنْثَيَيْنِ﴾</span>، قال: هذا لقولهم: <span class="qpc-hafs">﴿ما فِي بُطُونِ هَذِهِ الأَنْعامُ خالِصَةٌ لِذُكُورِنا ومُحَرَّمٌ عَلى أزْواجِنا﴾</span> [الأنعام:١٣٩]. قال: وقال ابن زيد، في قوله: <span class="qpc-hafs">﴿ثَمانِيَةَ أزْواجٍ مِنَ الضَّأْنِ اثْنَيْنِ ومِنَ المَعْزِ اثْنَيْنِ﴾</span>، قال: الأنعام هي: الإبل، والضأن، والمعز، هذه الأنعام التي قال الله: <span class="qpc-hafs">﴿ثمانية أزواج﴾</span>. قال: وقال في قوله: <span class="qpc-hafs">﴿هذه أنعام وحرث حجر﴾</span> [الأنعام:١٣٨]: نحتجرها على من نُريد وعمَّن نريد. وقوله: <span class="qpc-hafs">﴿وأنْعامٌ حُرِّمَتْ ظُهُورُها﴾</span> قال: لا يركبها أحد، <span class="qpc-hafs">﴿وأَنْعامٌ لا يَذْكُرُونَ اسْمَ اللَّهِ عَلَيْها﴾</span> فقال: <span class="qpc-hafs">﴿آلذَّكَرَيْنِ حَرَّمَ أمِ الأُنْثَيَيْنِ﴾</span> أي: هذين حرَّم على هؤلاء، أي: أن تكون لهؤلاء حِلًّا، وعلى هؤلاء حرامًا؟!{10}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه عبد الله بن وهب في الجامع - تفسير القرآن ٣/٤٥ (٨٩).</p><p>وهي قراءة شاذة. انظر: مختصر ابن خالويه ص٤٦-٤٧.أخرجه ابن جرير ٣/٣٤٩، وابن أبي حاتم ١/٣٣٦ من طريقي عطاء والنعمان بن مالك، ٥/١٤٠٢، والبيهقي في سننه ٩/٢٧٢. وعزاه السيوطي إلى ابن أبي شيبة، وابن المنذر.أخرجه ابن جرير ٩/٦٢٨. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.تفسير مجاهد ص٣٣٠، وأخرجه ابن جرير ٩/٦٢٧، وكذلك من طريق ابن جريج، وابن أبي حاتم ٥/١٤٠٢. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وأبي الشيخ.أخرجه ابن جرير ٩/٦٢٤.عزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ٩/٦٢٧، وابن أبي حاتم ٥/١٤٠٢.أخرجه ابن أبي حاتم ٥/١٤٠٣.تفسير مقاتل بن سليمان ١/٥٩٣-٥٩٤.أخرجه ابن جرير ٩/٦٢٨، وابن أبي حاتم ٥/١٤٠٤.أخرجه ابن جرير ٩/٦٢٨، وابن أبي حاتم ٥/١٤٠٣. وعزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ٩/٦٢٧، وابن أبي حاتم ٥/١٤٠٣. وعزاه السيوطي إلى أبي الشيخ.أخرجه ابن جرير ٩/٦٢٦.أخرجه عبد الرزاق ٢/٢٢٠، وابن جرير ٩/٦٢٦، وابن أبي حاتم ٥/١٤٠٣-١٤٠٤.أخرجه ابن جرير ٩/٦٢٧، وابن أبي حاتم ٥/١٤٠٢-١٤٠٤.تفسير مقاتل بن سليمان ١/٥٩٣-٥٩٤.أخرجه ابن جرير ٩/٦٢٧.أخرجه ابن جرير ٩/٦٢٨، وابن أبي حاتم ٥/١٤٠٤.
  6,144,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَمِنَ ٱلۡإِبِلِ ٱثۡنَیۡنِ وَمِنَ ٱلۡبَقَرِ ٱثۡنَیۡنِۗ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٢٦٥٠١<span class="dash">-</span></span> عن <span class="name-2">الضحاك بن مُزاحِم</span> -من طريق جُوَيْبِر-: <span class="qpc-hafs">﴿من الضأن اثنين﴾</span> ذكر وأنثى، <span class="qpc-hafs">﴿ومن البقر اثنين﴾</span> ذكر وأنثى، <span class="qpc-hafs">﴿ومن الإبل اثنين﴾</span> ذكر وأنثى{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٦٥٠٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ومن الإبل اثنين﴾</span> ذكر وأنثى، <span class="qpc-hafs">﴿ومن البقر اثنين﴾</span> ذكر وأنثى{2}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿قُلۡ ءَاۤلذَّكَرَیۡنِ حَرَّمَ أَمِ ٱلۡأُنثَیَیۡنِ أَمَّا ٱشۡتَمَلَتۡ عَلَیۡهِ أَرۡحَامُ ٱلۡأُنثَیَیۡنِۖ أَمۡ كُنتُمۡ شُهَدَاۤءَ إِذۡ وَصَّىٰكُمُ ٱللَّهُ بِهَـٰذَاۚ فَمَنۡ أَظۡلَمُ مِمَّنِ ٱفۡتَرَىٰ عَلَى ٱللَّهِ كَذِبࣰا لِّیُضِلَّ ٱلنَّاسَ بِغَیۡرِ عِلۡمٍۚ إِنَّ ٱللَّهَ لَا یَهۡدِی ٱلۡقَوۡمَ ٱلظَّـٰلِمِینَ ۝١٤٤﴾</span> - نزول الآية، وتفسيرها</h3></p><p><div></p><p><p><span class="item-no">٢٦٥٠٣<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السدي</span> -من طريق أسباط- في قوله: <span class="qpc-hafs">﴿آلذكرين حرم﴾</span> الآية، قال: إنّما ذكَر هذا مِن أجلِ ما حرَّموا مِن الأنعام، وكانوا يقولون: اللهُ أمرنا بهذا. فقال الله: <span class="qpc-hafs">﴿فمن أظلم ممن افترى على الله كذبا ليضل الناس بغير علم﴾</span>{3}. (٦/٢٣٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٦٥٠٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿قل﴾</span> يا محمد: <span class="qpc-hafs">﴿آلذكرين حرم أم الأنثيين﴾</span> يعني: من أين تحريم الأنعام؟ من قِبَل الذكرين أم قِبَل الأنثيين؟ <span class="qpc-hafs">﴿أما اشتملت عليه أرحام الأنثيين﴾</span>؟ يقول: على ما اشتمل؟ ما يشتمل الرَّحِم إلا ذكرًا أو أنثى، فأين هذا الذي جاء التحريم من قِبَله؟ وما اشتمل الرَّحِم إلا على مثلها. يقول: ما تلد الغنم إلا الغنم، وما تلد الناقة إلا مثلها، يعني: أنّ الغنم لا تلد البقر، ولا البقر تلد الغنم. فإن قالوا: حرَّم الأنثيين. خصُّوا، ولم يجُزْ لهم أن يأكلوا الإناث من الأنعام، وإن قالوا: الذكرين. لم يجُزْ لهم أن يأكلوا ذكور الأنعام، فسكتوا. ثم قال: <span class="qpc-hafs">﴿أم كنتم شهداء إذ وصاكم الله بهذا﴾</span> التحريم؟ فسكتوا، فلم يجيبوه، إلا أنّهم قالوا: حرَّمها آباؤنا. فقال لهم النبي ﷺ: «<b>فمِن أين حرَّمه آباؤكم؟</b>». قالوا: الله أمرهم بتحريمه. فأنزل الله: <span class="qpc-hafs">﴿فمن أظلم﴾</span> يقول: فلا أحد أظلم <span class="qpc-hafs">﴿ممن افترى على الله كذبا ليضل الناس بغير علم إن الله لا يهدي القوم الظالمين﴾</span>{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٦٥٠٥<span class="dash">-</span></span> قال <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿أم كنتم شهداء إذ وصاكم الله بهذا﴾</span> الذي تقولون{5}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ٩/٦٢٤.تفسير مقاتل بن سليمان ١/٥٩٤-٥٩٥.أخرجه ابن جرير ٩/٦٣١ بنحوه، وابن أبي حاتم ٥/١٤٠٤.تفسير مقاتل بن سليمان ١/٥٩٤-٥٩٥.أخرجه ابن جرير ٩/٦٣٠.
  6,145,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿قُل لَّاۤ أَجِدُ فِی مَاۤ أُوحِیَ إِلَیَّ مُحَرَّمًا عَلَىٰ طَاعِمࣲ یَطۡعَمُهُۥۤ إِلَّاۤ أَن یَكُونَ مَیۡتَةً أَوۡ دَمࣰا مَّسۡفُوحًا أَوۡ لَحۡمَ خِنزِیرࣲ فَإِنَّهُۥ رِجۡسٌ أَوۡ فِسۡقًا أُهِلَّ لِغَیۡرِ ٱللَّهِ بِهِۦۚ فَمَنِ ٱضۡطُرَّ غَیۡرَ بَاغࣲ وَلَا عَادࣲ فَإِنَّ رَبَّكَ غَفُورࣱ رَّحِیمࣱ ۝١٤٥﴾</span> - نزول الآية</h3></p><p><div></p><p><p><span class="item-no">٢٦٥٠٦<span class="dash">-</span></span> عن <span class="name-2">طاووس بن كيسان</span> -من طريق ابنه- قال: إنّ أهل الجاهلية كانوا يُحَرِّمون أشياء، ويسْتَحِلُّون أشياء. فنزَلت: <span class="qpc-hafs">﴿قل لا أجد فيما أوحي إلي محرما﴾</span> الآية{1}. (٦/٢٣٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٦٥٠٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: قالوا: يا محمد، فمِن أين حرَّمه آباؤنا؟ فأوحى الله إلى نبيه ﷺ: <span class="qpc-hafs">﴿قل لا أجد في ما أوحي إلي محرما على طاعم يطعمه﴾</span>الآية{2}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿قُل لَّاۤ أَجِدُ فِی مَاۤ أُوحِیَ إِلَیَّ مُحَرَّمًا عَلَىٰ طَاعِمࣲ یَطۡعَمُهُۥۤ﴾</span> الآية - تفسير</h3></p><p><div></p><p><p><span class="item-no">٢٦٥٠٨<span class="dash">-</span></span> عن <span class="name-1">عائشة</span> -من طريق القاسم- أنّها كانت إذا سُئِلتْ عن كلِّ ذي ناب من السِّباع، ومِخْلَبٍ من الطير؛ قرَأت: <span class="qpc-hafs">﴿قل لا أجد فيما أوحي إلي محرما﴾</span> الآية{3}. (٦/٢٣٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٦٥٠٩<span class="dash">-</span></span> عن <span class="name-1">عائشة</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٦٥١٠<span class="dash">-</span></span> و<span class="name-1">عبد الله بن عمر</span>، قالا: لا بأس بأكل كلِّ شيء، إلا ما ذَكَر الله في هذه الآية: <span class="qpc-hafs">﴿قل لا أجد فيما أوحي إلي محرما﴾</span> الآية{4}. (٦/٢٣٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٦٥١١<span class="dash">-</span></span> عن عمرو بن دينار، قال: قلتُ لجابر بن زيد: إنّهم يَزعُمون: أنّ رسول الله ﷺ نهى عن لحوم الحُمُر الأهلية زمَنَ خيبر. فقال: قد كان يقولُ ذلك الحكم بن عمرو الغفاري عندَنا بالبصرة عن رسول الله ﷺ، ولكن أبى ذلك البحرُ <span class="name-1">عبد الله بن عباس</span>، وقرأ: <span class="qpc-hafs">﴿قل لا أجد فيما أوحي إلي﴾</span> الآية{5}. (٦/٢٣٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٦٥١٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> أنّه سُئِل عن ثمن الكلب، والذئب، والهِرِّ، وأشباه ذلك. فقال: <span class="qpc-hafs">﴿يا أيها الذين آمنوا لا تسألوا عن أشياء إن تبد لكم تسؤكم﴾</span> [المائدة:١٠١]، كان ناس من أصحاب رسول الله ﷺ يَكرهُون أشياء فلا يُحَرِّمونه، وإنّ الله أنزَل كتابًا، فأحَلَّ فيه حلالًا، وحرَّم فيه حرامًا، وأنزَل في كتابه: <span class="qpc-hafs">﴿قل لا أجد فيما أوحي إلي محرما على طاعم يطعمه إلا أن يكون ميتة أو دما مسفوحا أو لحم خنزير﴾</span>{6}. (٦/٢٣٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٦٥١٣<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق الضحّاك- أنّه تلا هذه الآية: <span class="qpc-hafs">﴿قل لا أجد فيما أوحي إلي محرما﴾</span>، فقال: ما خلا هذا فهو حلال{7}. (٦/٢٣٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٦٥١٤<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق أبي الشَّعثاء- قال: كان أهلُ الجاهلية يأكلون أشياء، ويتركون أشياء تقذُّرًا، فبعث الله نبيه، وأنزَل كتابه، وأحلَّ حلاله، وحرَّم حرامَه؛ فما أحلَّ فهو حلال، وما حرَّم فهو حرام، وما سكَت عنه فهو عفوٌ منه. ثم تلا هذه الآية: <span class="qpc-hafs">﴿قل لا أجد فيما أوحي إلي محرما﴾</span> إلى آخر الآية{8}. (٦/٢٣٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٦٥١٥<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عكرمة- قال: ليس من الدوابِّ شيءٌ حرام إلا ما حرَّم الله في كتابه: <span class="qpc-hafs">﴿قل لا أجد فيما أوحي إلي محرما﴾</span> الآية{9}. (٦/٢٣٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٦٥١٦<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عمر</span> -من طريق عيسى بن نُمَيْلَةَ الفزاري، عن أبيه- أنّه سُئِل عن أكلِ القُنفُذ. فقرأ: <span class="qpc-hafs">﴿قل لا أجد فيما أوحي إلي محرما﴾</span> الآية. فقال شيخٌ عندَه: سمِعتُ أبا هريرة يقول: ذُكِرَ عندَ النبي ﷺ، فقال: «<b>خبيثةٌ من الخبائث</b>». فقال ابن عمر: إن كان النبي ﷺ قاله فهو كما قال{10}<span class=comment-ref>٢٤٢٥</span>. (٦/٢٣٤)</p></p><p></div></p><p><div><span class=comment-ref>٢٤٢٥</span> <span class="comment-type-4">قال</span> <u>ابنُ عطية</u> (٣/٤٨٠-٤٨١): «هذه الآية نزلت بمكة، ولم يكن في الشريعة في ذلك الوقت شيءٌ مُحَرَّم غير هذه الأشياء، ثم نزلت سورة المائدة بالمدينة، وزِيدَ في المحرمات؛ كالمنخنقة، والموقوذة، والمتردية، والنطيحة. فإنّ هذه وإن كانت في حكم الميتة فكان في النظر احتمال أن تلحق بالمذكيات؛ لأنها بأسباب وليست حتف الأنف. فلما بيَّن النصُ إلحاقها بالميتة كان زيادة في المحرمات، ثم نزل النص على رسول الله ﷺ في تحريم الحمر بوحي غير معجز، وبتحريم كل ذي ناب من السباع، فهذه كلها زيادات في التحريم».</p><p>و<span class="comment-type-4">قال</span> <u>ابنُ كثير</u> (٦/١٩٤): «قيل: معناه: لا أجد شيئًا مما حرَّمتم حرامًا سوى هذه. وقيل: معناه: لا أجد من الحيوانات شيئًا حرامًا سوى هذه. فعلى هذا يكون ما ورد من التحريمات بعد هذا في سورة المائدة وفي الأحاديث الواردة رافعًا لمفهوم هذه الآية، ومِن الناس مَن يسمي ذلك نسخًا، والأكثرون من المتأخرين لا يسمونه نسخًا؛ لأنّه من باب رفع مباح الأصل».</p><p>وبنحو كلام ابن كثير <span class="comment-type-4">قال</span> <u>ابنُ تيمية</u> (٢/١٠٩).</div></p><p><div></p><p><p><span class="item-no">٢٦٥١٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿قل لا أجد في ما أوحي إلي محرما على طاعم يطعمه﴾</span>، يعني: على آكل يأكله{2}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿إِلَّاۤ أَن یَكُونَ مَیۡتَةً﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٢٦٥١٨<span class="dash">-</span></span> عن عبد الله بن عباس -من طريق عكرمة- أنّ شاةً لسَوْدَة بنت زَمْعَة ماتت، فقالت: يا رسول الله، ماتت فلانة. تعني: الشاة، قال: «<b>فلولا أخَذْتم مَسْكَها</b>{12}». قالت: يا رسول الله، أنأخُذُ مَسْكَ شاةٍ قد ماتت؟ فقرأ النبي ﷺ: «<b><span class="qpc-hafs">﴿قل لا أجد فيما أوحي إلي محرما على طاعم يطعمه إلّا أنْ يَكُونَ مَيْتَةً﴾</span>، وإنكم لا تَطْعَمُونَه، وإنما تَدْبُغونه حتى تَنتَفِعُوا به</b>». فأرسَلت إليها، فسَلَختْها، ثم دَبَغَته، فاتَّخذتْ منه قِربةً حتى تخرَّقت عندَها{13}. (٦/٢٣٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٦٥١٩<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عبيد الله بن عتبة- أنّه قرأ هذه الآية: <span class="qpc-hafs">﴿قل لا أجد فيما أوحي إلي محرما على طاعم يطعمه إلا أن يكون ميتة﴾</span> إلى آخر الآية، وقال: إنّما حُرِّم من الميتة ما يُؤكلُ منها وهو اللحم، فأما الجِلد، والقَدُّ{14}، والسِنُّ، والعظمُ، والشَّعَر، والصوف؛ فهو حلال{15}. (٦/٢٣٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٦٥٢٠<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق إبراهيم بن أبي بكر- <span class="qpc-hafs">﴿قُلْ لا أجِدُ فِي ما أُوحِيَ إلَيَّ مُحَرَّمًا﴾</span>، قال: مِمّا كان في الجاهلية يأكلون، لا أجد محرمًا من ذلك <span class="qpc-hafs">﴿على طاعم يطعمه، إلا أن يكون ميتة، أو دمًا مسفوحًا﴾</span>{16}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٦٥٢١<span class="dash">-</span></span> عن <span class="name-2">طاووس بن كيسان</span> -من طريق ابنه- <span class="qpc-hafs">﴿قُلْ لا أجِدُ فِي ما أُوحِيَ إلَيَّ مُحَرَّمًا عَلى طاعِمٍ يَطْعَمُهُ﴾</span> قال: ما يُؤكَل. قلت: في الجاهلية؟ قال: نعم، وكذلك كان يقول: <span class="qpc-hafs">﴿إلا أن يكون ميتة أودما مسفوحا﴾</span>{16}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿أَوۡ دَمࣰا مَّسۡفُوحًا﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٢٦٥٢٢<span class="dash">-</span></span> عن <span class="name-1">عائشة</span> -من طريق القاسم بن محمد- قالت، وذكرت هذه الآية: <span class="qpc-hafs">﴿أو دما مسفوحا﴾</span>، قلت: وإنّ البُرْمةَ{18} لَيُرى في مائها الصُّفرة{19}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٦٥٢٣<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي بن أبي طلحة- في قوله: <span class="qpc-hafs">﴿أو دما مسفوحا﴾</span>، قال: مُهَراقًا{20}. (٦/٢٣٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٦٥٢٤<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عكرمة- قال: كان أهل الجاهلية إذا ذبَحوا أودَجوا{21} الدابَّة، وأخذوا الدم، فأكَلوه، قالوا: هو دمٌ مسفوح{22}. (٦/٢٣٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٦٥٢٥<span class="dash">-</span></span> عن عكرمة، قال: جاء رجلٌ إلى <span class="name-1">عبد الله بن عباس</span>، فقال له: آكُلُ الطِّحالَ؟ قال: نعم. قال: إنّ عامَّتَها دمٌ! قال: إنّما حرَّم الله الدم المسفوح{23}. (٦/٢٣٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٦٥٢٦<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عكرمة- قال: لا بأس بأكل الطِّحال. ثم تلا: <span class="qpc-hafs">﴿قل لا أجد فيما أوحي إلي محرما﴾</span> الآية{24}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٦٥٢٧<span class="dash">-</span></span> قال <span class="name-2">إبراهيم النخعي</span>: لا بأس بالدم في عِرْق أو مُخٍّ، إلا المسفوح الذي تُعُمِّد ذلك{25}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٦٥٢٨<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span> -من طريق عمرو بن دينار- قال: لولا هذه الآية: <span class="qpc-hafs">﴿أو دما مسفوحا﴾</span> لاتَّبَع المسلمون من العروق ما تَتَبَّع منه اليهود{26}. (٦/٢٣٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٦٥٢٩<span class="dash">-</span></span> عن <span class="name-2">أبي مِجْلَز لاحق بن حميد</span> -من طريق عمران بن حُدَيْرٍ- في الدم يكون في مَذْبحِ الشاة، أو الدم يكون على أعلى القِدْر، قال: لا بأس، إنّما نُهِيَ عن الدم المسفوح{27}. (٦/٢٣٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٦٥٣٠<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق مَعْمَر- قال: حُرِّم الدم ما كان مسفوحًا، فأمّا لحمٌ يُخالطُه الدم فلا بأسَ به{28}. (٦/٢٣٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٦٥٣١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿أو دما مسفوحا﴾</span>، يعني: يَسيل{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٦٥٣٢<span class="dash">-</span></span> عن <span class="name-3">عبد الملك ابن جُرَيْج</span>، في قوله: <span class="qpc-hafs">﴿أو دما مسفوحا﴾</span>، قال: المسفوح الذي يُهَراق، ولا بأسَ بما كان في العروق منها{30}. (٦/٢٣٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٦٥٣٣<span class="dash">-</span></span> عن <span class="name-3">سفيان بن عيينة</span> -من طريق أحمد بن حنبل- يقول في قوله: <span class="qpc-hafs">﴿أو دما مسفوحا﴾</span>، المسفوح: العَبِيطُ{9}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿أَوۡ لَحۡمَ خِنزِیرࣲ فَإِنَّهُۥ رِجۡسٌ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٢٦٥٣٤<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق عبّاد بن منصور- قوله: <span class="qpc-hafs">﴿أو لحم خنزير﴾</span>، قال: حرَّم الله الميتة، والدم، ولحم الخنزير{22}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٦٥٣٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿أوْ لَحْمَ خِنْزِيرٍ فَإنَّهُ رِجْسٌ﴾</span>، يعني: إثمًا{2}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿أَوۡ فِسۡقًا أُهِلَّ لِغَیۡرِ ٱللَّهِ بِهِۦۚ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٢٦٥٣٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿أو فسقا﴾</span> يعني: معصية <span class="qpc-hafs">﴿أهل لغير الله به﴾</span> يعني: ذُبِح لغير الله{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٦٥٣٧<span class="dash">-</span></span> قال <span class="name-3">مالك بن أنس</span>: ... والفسوق: الذبح للأنصاب -والله أعلم-، قال الله -تبارك وتعالى-: <span class="qpc-hafs">﴿أوْ فِسْقًا أُهِلَّ لِغَيْرِ اللَّهِ بِهِ﴾</span>{35}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿فَمَنِ ٱضۡطُرَّ غَیۡرَ بَاغࣲ وَلَا عَادࣲ فَإِنَّ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٢٦٥٣٨<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فمن اضطر﴾</span> إلى شيء مما حرَّمْتُ عليه <span class="qpc-hafs">﴿غير باغ﴾</span> ليستحله في دينه، <span class="qpc-hafs">﴿ولا عاد﴾</span> يعني: ولا معتديًا لم يضطر إليه{36}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿فَإِنَّ رَبَّكَ غَفُورࣱ رَّحِیمࣱ ۝١٤٥﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٢٦٥٣٩<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span> -من طريق عطاء- <span class="qpc-hafs">﴿فإن ربك غفور﴾</span> يعني: لِما أُكِل من الحرام، <span class="qpc-hafs">﴿رحيم﴾</span> يعني: رحيمًا به إذ أحَلَّ له الحرام في الاضطرار{37}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٦٥٤٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فإن ربك غفور﴾</span> لأكله الحرام، <span class="qpc-hafs">﴿رحيم﴾</span> به إذا رخَّص له في الحرام في الاضطرار{2}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿فَإِنَّ رَبَّكَ غَفُورࣱ رَّحِیمࣱ ۝١٤٥﴾</span> - أحكام متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٢٦٥٤١<span class="dash">-</span></span> عن ابن عمر، قال: نهى النبي ﷺ عن لحوم الحُمُر الأهلية يومَ خيبر{39}. (٦/٢٣٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٦٥٤٢<span class="dash">-</span></span> عن جابر بن عبد الله، قال: نهى النبي ﷺ يوم خيبر عن لحوم الحمُر الأهلية، ورخَّص في لحوم الخيل{40}. (٦/٢٣٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٦٥٤٣<span class="dash">-</span></span> عن أبي ثعلبة الخُشَنِيِّ: أنّ رسول الله ﷺ نهى عن أكلِ كلِّ ذي نابٍ من السِّباع{41}. (٦/٢٣٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٦٥٤٤<span class="dash">-</span></span> عن عبد الله بن عباس، قال: نهى رسول الله ﷺ عن كلِّ ذي نابٍ من السِّباع، وعن كلِّ ذي مِخْلَبٍ من الطير{42}. (٦/٢٣٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٦٥٤٥<span class="dash">-</span></span> عن خالد بن الوليد، قال: غزَوتُ مع رسول الله ﷺ يوم خيبر، فأتتِ اليهود، فشكَوْا أنّ الناس قد أسرعوا إلى حظائرِهم، فقال رسول الله ﷺ: «<b>ألا لا تَحِلُّ أموالُ المعاهَدِين إلا بحقِّها، حرامٌ عليكم حَميرُ الأهلية، وخيلُها، وبغالُها، وكلُّ ذي نابٍ من السِّباع، وكلُّ ذي مِخْلَب من الطير</b>»{43}. (٦/٢٣٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٦٥٤٦<span class="dash">-</span></span> عن جابر، قال: حرَّم رسول الله ﷺ يوم خيبر الحمُر الإنسيةَ، ولحومَ البغال، وكلَّ ذي نابٍ من السِّباع، وكلَّ ذي مِخْلَبٍ من الطير، وحرَّم المُجَثَّمَةَ{44}، والخُلْسةَ، والنُّهبةَ{45}. (٦/٢٣٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٦٥٤٧<span class="dash">-</span></span> عن جابر بن عبد الله: أنّ النبي ﷺ نهى عن أكْلِ الهِرَّة، وأكْلِ ثمنِها{46}. (٦/٢٤١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٦٥٤٨<span class="dash">-</span></span> عن عبد الرحمن بن شِبْلٍ: أنّ رسول الله ﷺ نهى عن أكل لحم الضَّبِّ{47}. (٦/٢٤١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٦٥٤٩<span class="dash">-</span></span> عن ابن عمر، قال: سُئِل النبي ﷺ عن الضَّبِّ. فقال: «<b>لستُ آكُلُه، ولا أُحرِّمُه</b>»{48}. (٦/٢٤١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٦٥٥٠<span class="dash">-</span></span> عن خالد بن الوليد: أنّه دخل مع رسول الله ﷺ بيت ميمونة، فأُتِي بضَبٍّ محْنُوذٍ{49}، فأهوى إليه رسول الله ﷺ بيده، فقال بعض النِّسوة: أخْبِروا رسول الله ﷺ بما يريدُ أن يأكُلَ. فقالوا: هو ضبٌّ، يا رسول الله. فرفَع يده، فقلتُ: أحرامٌ هو، يا رسول الله؟ قال: «<b>لا، ولكن لم يكن بأرض قومي، فأجِدُني أعافُه</b>». قال خالد: فاجترَرْتُه، فأكلتُه، ورسول الله ﷺ ينظُرُ{50}. (٦/٢٤١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٦٥٥١<span class="dash">-</span></span> عن خُزَيْمة بن جَزْءٍ السُّلَمي، قال: سألتُ رسول الله ﷺ عن أكل الضَّبُع، فقال: «<b>ويأكُلُ الضَّبُعَ أحدٌ؟</b>». وسألتُه عن أكل الذئب، قال: «<b>ويأكُلُ الذئبَ أحدٌ فيه خير؟</b>». وفي لفظ لابن ماجه: قلتُ: يا رسول الله، جئتُك لأَسألَكَ عن أحْناشِ الأرض، ما تقولُ في الثعلب؟ قال: «<b>ومَن يأكُلُ الثعلب؟</b>». قلتُ: ما تقول في الضَّبِّ؟ قال: «لا آكُلُه، ولا أُحرِّمُه». قلتُ: ولِمَ، يا رسول الله؟ قال: «<b>فُقِدَت أُمةٌ من الأمم، ورأيتُ خَلْقًا رابَني</b>». قلتُ: يا رسول الله، ما تقول في الأرنب؟ قال: «<b>لا آكُلُه، ولا أُحرِّمُه</b>». قلتُ: ولِمَ، يا رسول الله؟ قال: «<b>نُبِّئْتُ أنها تَدْمى</b>»{51}. (٦/٢٤٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٦٥٥٢<span class="dash">-</span></span> عن عبد الرحمن بن أبي عمار، قال: قلتُ لجابر: الضَّبُعُ، أصيدٌ هي؟ قال: نعم. قلتُ: آكُلُها؟ قال: نعم. قلتُ: أقاله رسول الله ﷺ؟ قال: نعم{52}. (٦/٢٤٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٦٥٥٣<span class="dash">-</span></span> عن جابر بن زيد، قال: سألتُ البحرَ -يعني: <span class="name-1">عبد الله بن عباس</span>- في رجل ذبح، ونسي أن يذكر. فتلا هذه الآية: <span class="qpc-hafs">﴿قل لا أجد في ما أوحي إلي محرما﴾</span>{53}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٦٥٥٤<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عمر</span> -من طريق عروة- قال: مَن يأكُلُ الغرابَ وقد سمّاه رسول الله ﷺ فاسقًا؟! واللهِ، ما هو من الطيبات{54}. (٦/٢٤٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٦٥٥٥<span class="dash">-</span></span> عن <span class="name-2">محمد بن علي ابن الحنفية</span> -من طريق منذر- أنّه سُئِل عن أكل الجِرِّيثِ{55}. فقال: <span class="qpc-hafs">﴿قل لا أجد فيما أوحي إلي محرما﴾</span> الآية{56}. (٦/٢٣٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٦٥٥٦<span class="dash">-</span></span> عن أبي يعلى عن <span class="name-2">محمد بن الحنفية</span>، قال: سألتُه عن الطحال والجِرِّيِّ{57}. فتلا هذه الآية: <span class="qpc-hafs">﴿قل لا أجد فيما أوحي إلي محرما﴾</span>{58}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٦٥٥٧<span class="dash">-</span></span> عن زيد أبي أسامة، قال: سألتُ <span class="name-2">سالِم [بن عبد الله بن عمر]</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٦٥٥٨<span class="dash">-</span></span> و<span class="name-2">القاسم [بن محمد بن أبي بكر]</span> عن كسب الحجام. فلم يريا به بأسًا، وتَلَوا: <span class="qpc-hafs">﴿قل لا أجد فيما أوحي إلي محرما على طاعم يطعمه﴾</span> الآية{59}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٦٥٥٩<span class="dash">-</span></span> عن <span class="name-2">عامر الشعبي</span>: أنّه سُئِل عن لحم الفيل، والأسد. فتلا: <span class="qpc-hafs">﴿قل لا أجد فيما أوحي إلي محرما﴾</span> الآية{60}. (٦/٢٣٧)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ٩/٦٣٢، وابن أبي حاتم ٥/١٤٠٥. وعزاه السيوطي إلى عبد بن حميد.تفسير مقاتل بن سليمان ١/٥٩٥.أخرجه ابن جرير ٩/٦٣٥، وابن أبي شيبة في مصنفه (ت: محمد عوامة) ١٠/٤٥١ (٢٠٢٣٥)، وابن أبي حاتم ٥/١٤٠٧، والنحاس ص٤٣٤. وعزاه السيوطي إلى ابن المنذر، وأبي الشيخ، وابن مردويه.عزاه السيوطي إلى أبي الشيخ، وابن مردويه.أخرجه عبد الرزاق في مصنفه ٤/٥٢٥ (٨٧٢٧) بنحوه، وأحمد ٢٩/٤٠٥ (١٧٨٦١)، والبخاري (٥٥٢٩)، وأبو داود (٣٨٠٨)، والنحاس ص٤٣٤، وعند النحاس: عن عمرو بن دينار، عن جابر بن عبد الله. وعزاه السيوطي إلى ابن المنذر، وأبي الشيخ.عزاه السيوطي إلى ابن مردويه.أخرجه عبد الرزاق ١/٢٢٠. وعزاه السيوطي إلى عبد بن حميد.أخرجه أبو داود ٥/٦١٧-٦١٨ (٣٨٠٠)، والحاكم ٤/١٢٨ (٧١١٣)، وابن أبي حاتم ٥/١٤٠٤-١٤٠٥ (٨٠٠٠).</p><p>قال الحاكم: «هذا حديث صحيح الإسناد، ولم يُخَرِّجاه». وقال الذهبي في التلخيص: «صحيح». وقال ابن كثير في تفسيره ٣/٣٥٣: «ورواه أبو داود منفردًا به».أخرجه ابن أبي حاتم ٥/١٤٠٦.أخرجه أحمد ١٤/٥١٥ (٨٩٥٤)، وأبو داود ٥/٦١٧ (٣٧٩٩)، وابن أبي حاتم ٥/١٤٠٦ (٨٠٠٧).</p><p>قال الخطابي في معالم السنن ٤/٢٤٨: «ليس إسناده بذلك». وقال البيهقي في الكبرى ٩/٥٤٧ (١٩٤٣١): «هذا حديث لم يُرْوَ إلا بهذا الإسناد، وهو إسناد فيه ضعف». وقال في معرفة السنن والآثار ١٤/٩١ (١٩٢٤٥): «إسناد غير قوي، وراويه شيخ مجهول». وقال ابن حجر في بلوغ المرام ٢/١٧١ (١٣٢٦): «إسناده ضعيف». وقال الألباني في الإرواء ٨/١٤٤ (٢٤٩٢): «ضعيف».تفسير مقاتل بن سليمان ١/٥٩٥.المسْك: الجِلْد. النهاية ٤/٣٣١.أخرجه أحمد ٥/١٥٦ (٣٠٢٦)، وابن أبي حاتم ٥/١٤٠٥-١٤٠٦ (٨٠٠٣، ٨٠٠٥). وأخرجه البخاري ٨/١٣٩ (٦٦٨٦) مختصرًا دون ذكر الآية.القَدّ: جلد السَّخْلة. النهاية (قدد).أخرجه ابن أبي حاتم ٥/١٤٠٥ بنحوه. وعزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ٩/٦٣٣.أخرجه ابن جرير ٩/٦٣٣.البُرْمَة: القِدْر. النهاية (برم).أخرجه ابن جرير ٩/٦٣٥، وابن أبي شيبة في مصنفه (ت: محمد عوامة) ١٠/٤٥١ (٢٠٢٣٥)، وابن أبي حاتم ٥/١٤٠٧.أخرجه ابن جرير ٩/٦٣٤، وابن أبي حاتم ٥/١٤٠٦. وعزاه السيوطي إلى ابن المنذر، وأبي الشيخ.ودَجَ الدابة: قطع ودَجَها، وهو عِرْقٌ فِي العُنق يقطعه الذابح. اللسان (ودج).أخرجه ابن أبي حاتم ٥/١٤٠٧.أخرجه ابن أبي شيبة ٨/٨٦، وابن أبي حاتم ٥/١٤٠٦، والبيهقي في سننه١٠/٧. وعزاه السيوطي إلى ابن المنذر، وأبي الشيخ.أخرجه أبو نعيم في أخبار أصبهان ٢/٢٥٠. وعند ابن أبي حاتم ٥/١٤٠٦: عن عكرمة قال: جاء رجل إلى ابن عباس، فقال: آكل الطحال؟ قال: نعم. قال: إن عامتها دم؟ قال: إنما حرم الله الدم المسفوح. وذكره في الدر ١٣/٦٣٩.تفسير الثعلبي ٤/٢٠١، وتفسير البغوي ٣/١٩٨.أخرجه عبد الرزاق ١/٢٢٠، وسعيد بن منصور (٩٣٣ - تفسير)، وابن جرير ٩/٦٣٤، وابن أبي حاتم ٥/١٤٠٧. وعزاه السيوطي إلى ابن المنذر، وأبي الشيخ.أخرجه ابن جرير ٩/٦٣٤، وابن أبي حاتم ٤/١٤٠٩. وعزاه السيوطي إلى عبد بن حميد، وأبي الشيخ.أخرجه عبد الرزاق ١/٢٢١، وابن جرير ٩/٦٣٤، وابن أبي حاتم ٥/١٤٠٧. وعزاه السيوطي إلى عبد بن حميد.تفسير مقاتل بن سليمان ١/٥٩٥.عزاه السيوطي إلى ابن المنذر.أخرجه ابن أبي حاتم ٥/١٤٠٦.أخرجه ابن أبي حاتم ٥/١٤٠٧.تفسير مقاتل بن سليمان ١/٥٩٥.تفسير مقاتل بن سليمان ١/٥٩٥.الموطأ (ت: د. بشار عواد) ١/٥٢٢ (١١٥٣).</p><p><b>هذا وقد تقدم تفصيل ذلك بما يغني عن إعادته في سورة البقرة [١٧٣] عند قوله تعالى: <span class="qpc-hafs">﴿إنَّما حَرَّمَ عَلَيْكُمُ المَيْتَةَ والدَّمَ ولَحْمَ الخِنْزِيرِ وما أُهِلَّ بِهِ لِغَيْرِ اللَّهِ﴾</span>، وسورة المائدة [٣] في قوله تعالى: <span class="qpc-hafs">﴿حُرِّمَتْ عَلَيْكُمُ المَيْتَةُ والدَّمُ ولَحْمُ الخِنْزِيرِ وما أُهِلَّ لِغَيْرِ اللَّهِ بِهِ﴾</span>.</b>تفسير مقاتل بن سليمان ١/٥٩٥.</p><p><b>كذلك تقدم تفصيل ذلك بما يغني عن إعادته عند تفسير الآية (٧٣) في سورة البقرة</b>.أخرجه ابن أبي حاتم ٥/١٤٠٩.تفسير مقاتل بن سليمان ١/٥٩٥.أخرجه البخاري ٥/١٣٦ (٤٢١٧، ٤٢١٨)، ٧/٩٥ (٥٥٢١، ٥٥٢٢)، ومسلم ٣/١٥٣٨ (٥٦١).أخرجه البخاري ٧/٩٥ (٥٥٢٠، ٥٥٢٤)، ومسلم ٣/١٥٤١ (١٩٤١). وأورده الثعلبي ٦/٨.أخرجه البخاري ٧/٩٦ (٥٥٣٠)، ومسلم ٣/١٥٣٣ (١٩٣٢).أخرجه مسلم ٣/١٥٣٤ (١٩٣٤).أخرجه أحمد ٢٨/١٥-١٦ (١٦٨١٦)، ٢٨/١٩-٢٠ (١٦٨١٨)، وأبو داود ٥/٦٢٣ (٣٨٠٦) واللفظ له.</p><p>قال الدارقطني في السنن ٥/٥١٨ (٤٧٧١): «وهذا حديث ضعيف، وزعم الواقدي أنّ خالد بن الوليد أسلم بعد فتح خيبر». وقال البيهقي في معرفة السنن والآثار ١٤/٩٦ (١٩٢٥٨): «فهذا حديث إسناده مضطرب، ومع اضطرابه مخالف لحديث الثقات». وقال ابن التركماني في الجوهر النقي ٩/٣٢٨: «ورجال هذا السند ثقات». وقال ابن حجر في التلخيص الحبير ٤/٣٧٤ (١٩٩٤): «حديث خالد لا يصح، فقد قال أحمد: إنه حديث منكر. وقال أبو داود: إنه منسوخ». وقال الألباني في الضعيفة ٨/٣٧٣ (٣٩٠٢): «ضعيف».المجثمة: كل حيوان ينصب ويرمى ليقتل، إلا أنها تكثر في الطير والأرانب وأشباه ذلك مما يجثم في الأرض، أي: يلزمها ويلتصق بها، وجثم الطائر جثومًا، وهي بمنزلة البروك للإبل. النهاية (جَثَمَ).أخرجه أحمد ٢٢/٣٥٤-٣٥٥ (١٤٤٦٣) واللفظ له، والترمذي ٣/٣٠٢ (١٥٤٧) مختصرًا.</p><p>قال الترمذي: «حديث حسن غريب». وقال الهيثمي في المجمع ٥/٤٧ (٨٠٥٣): «رواه الترمذي باختصار، رواه الطبراني في الأوسط، والبزار باختصار، ورجالهما رجال الصحيح، خلا شيخ الطبراني عمر بن حفص السدوسي، وهو ثقة». وقال الألباني في الصحيحة ٤/٢٣٨: «ورجاله ثقات رجال مسلم، لكن عكرمة بن عمار صدوق يغلط».أخرجه أبو داود ٥/٣٤٧ (٣٤٨٠)، والترمذي ٣/١٣٠ (١٣٢٦)، وابن ماجه ٤/٣٩٥ (٣٢٥٠) واللفظ له، والحاكم ٢/٤٠ (٢٢٤٦).</p><p>وفيه عمر بن زيد؛ قال الترمذي: «حديث غريب، وعمر بن زيد لا نعرف كبير أحد روى عنه غير عبد الرزاق». وقال الحاكم ٢/٤٠ (٢٢٤٦): «صحيح على شرط مسلم، ولم يخرجاه». وقال الذهبي في التلخيص: «عمر بن زيد واه». وقال البوصيري في إتحاف الخيرة ٥/٣٠٥ (٤٧٢٣): «هذا إسناد ضعيف». وقال الألباني في الإرواء ٨/١٤٠ (٢٤٨٧): «ضعيف».أخرجه أبو داود ٥/٦١٥ (٣٧٩٦).</p><p>قال البغوي في شرح السنة ١١/٢٣٩: «ليس إسناده بذاك». وقال الجوزقاني في الأباطيل والمناكير ٢/٢٦٩-٢٧٠ (٦٠٨): «حديث منكر، وإسناده ليس بمتصل». وقال ابن الجوزي في العلل المتناهية ٢/١٧٢ (١٠٩٧): «هذا حديث لا يصح، وإسماعيل بن عياش ضعيف». وقال الزيلعي في نصب الراية ٤/١٩٥: «قال الخطابي: ليس إسناده بذاك. وقال البيهقي: لم يثبت إسناده، إنما تفرد به إسماعيل بن عياش، وليس بحجة». وقال ابن حجر في الفتح ٩/٦٦٥: «بسند حسن». وأورده الألباني في الصحيحة ٥/٥٠٥ (٢٣٩٠).أخرجه البخاري ٧/٩٧ (٥٥٣٦)، ومسلم ٣/١٥٤١، ١٥٤٢ (١٩٤٣).المحنوذ: المشوي بالحجارة المحماة. لسان العرب (حنذ).أخرجه البخاري ٧/٧١ (٥٣٩١)، ٧/٩٧ (٥٥٣٧)، ومسلم ٣/١٥٤٣ (١٩٤٥، ١٩٤٦).أخرجه ابن أبي شيبة ٨/٦٣، والترمذي ٣/٥٦٩ (١٨٩٥)، وابن ماجه ٤/٣٨٤ (٣٢٣٥)، ٤/٣٨٥ (٣٢٣٧)، ٤/٣٩١ (٣٢٤٥).</p><p>قال الترمذي: «هذا حديث ليس إسناده بالقوي». وقال الجوزقاني في الأباطيل والمناكير ٢/٢٦٥ (٦٠٦): «هذا حديث باطل، وليس بصحيح». وقال ابن الجوزي في العلل المتناهية ٢/١٧٢-١٧٣ (١٠٩٩): «وهذا لا يصح». وقال البوصيري في مصباح الزجاجة ٣/٢٣٩: «إسناد حديثه ضعيف». وقال ابن حجر في التلخيص الحبير ٤/٣٧٦: «ضعيف». وقال الصالحي في سبل الهدى والرشاد ٧/٢١٨: «وروى ابن أبي شيبة بسند ضعيف». وقال الشوكاني في نيل الأوطار ٨/١٣٨: «الحديث ضعيف».أخرجه أحمد ٢٢/٧٢ (١٤١٦٥)، ٢٢/٣١٦ (١٤٤٢٥)، ٢٢/٣٤٣ (١٤٤٤٩)، والترمذي ٢/٣٧٠-٣٧١ (٨٦٧)، ٣/٥٦٨-٥٦٩ (١٨٩٤)، والنسائي ٥/١٩١ (٢٨٣٦)، ٧/٢٠٠ (٤٣٢٣)، وابن ماجه ٤/٣٨٥ (٣٢٣٦)، والحاكم ١/٦٢٢ (١٦٦٢)، وابن خزيمة ٤/٣١٤ (٢٦٤٥)، وابن حبان ٩/٢٧٨ (٣٩٦٥).</p><p>قال الترمذي: «حديث حسن صحيح». وقال في العلل ص٢٩٧ (٥٥١) عن البخاري: «هو حديث صحيح». وقال الجوزقاني في الأباطيل والمناكير ٢/٢٦٦ (٦٠٧): «هذا حديث حسن». وقال ابن الملقن في البدر المنير ٩/٣٦٨: «هذا الحديث صحيح». وقال الألباني في الإرواء ٨/١٤٥ (٢٤٩٤): «صحيح».أخرجه ابن أبي حاتم ٥/١٤٠٥.أخرجه ابن ماجه (٣٢٤٨).</p><p>صححه الألباني (صحيح سنن ابن ماجه-٢٦٢٨).الجِرِّيث: ضرب من السمك، ويقال له: الجِرِّيُّ. لسان العرب (جرث).أخرجه ابن أبي شيبة ٨/٨٦، ١٤٣. وعزاه السيوطي إلى أبي الشيخ.ضرب من السمك. لسان العرب (جرث).أخرجه عبد الرزاق في مصنفه ٤/٥٣٦ (٨٧٧٥)، وابن أبي شيبة في مصنفه (ت: محمد عوامة) ١٢/٣٦٥ (٢٤٨٥٢).أخرجه ابن أبي شيبة في مصنفه (ت: محمد عوامة) ١١/٦٧ (٢١٣٧٤).عزاه السيوطي إلى أبي الشيخ.
  6,146,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَعَلَى ٱلَّذِینَ هَادُوا۟﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٢٦٥٦٠<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق أبي بشر- قال: تَهَوَّدت اليهود يوم السبت{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٦٥٦١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثم بيَّن ما حَرَّم على اليهود{2}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿حَرَّمۡنَا كُلَّ ذِی ظُفُرࣲۖ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٢٦٥٦٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق سعيد بن جبير- في قوله: <span class="qpc-hafs">﴿وعلى الذين هادوا حرمنا كل ذي ظفر﴾</span>، قال: هو الذي ليس بمُنفَرِج الأصابع. يعني: ليس بمشقوق الأصابع؛ منها: الإبل، والنعام{3}. (٦/٢٤٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٦٥٦٣<span class="dash">-</span></span> عن <span class="name-2">الضحاك بن مزاحم</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٦٥٦٤<span class="dash">-</span></span> و<span class="name-2">عكرمة مولى ابن عباس</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٦٥٦٥<span class="dash">-</span></span> و<span class="name-2">عطاء الخراساني</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٦٥٦٦<span class="dash">-</span></span> و<span class="name-3">مقاتل بن حيان</span>، نحو ذلك{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٦٥٦٧<span class="dash">-</span></span> وعن <span class="name-2">إسماعيل السدي</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٦٥٦٨<span class="dash">-</span></span> و<span class="name-2">قتادة بن دعامة</span>، نحو ذلك، وزاد فيه: والوز{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٦٥٦٩<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي بن أبي طلحة- <span class="qpc-hafs">﴿وعلى الذين هادوا حرمنا كل ذي ظفر﴾</span>، قال: هو البعير، والنعامة{6}. (٦/٢٤٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٦٥٧٠<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span> -من طريق عطاء بن السائب- في قوله: <span class="qpc-hafs">﴿وعلى الذين هادوا حرمنا كل ذي ظفر﴾</span>، قال: كل شيء متفرق الأصابع، ومنه الديك، وفي لفظ: هو ليس الذي بمنفرج الأصابع{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٦٥٧١<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن جُرَيج- <span class="qpc-hafs">﴿حرمنا كل ذي ظفر﴾</span>، قال: كلَّ شيءٍ لم تُفْرَجْ قوائمُه من البهائم، وما انفَرَج أكَلتْه اليهود. قال: انفَذَّت قوائمُ الدجاج والعصافير، فيهود تأكُلُه، ولم تُفرَجْ قائمة البعير؛ خفُّه، ولا خفُّ النعامة، ولا قائمةُ الوَزِّينةِ{8}، فلا تأكُلُ اليهود الإبل، ولا النعام، ولا الوَزِّينة، ولا كلَّ شيءٍ لم تُفْرَجْ قائمتُه كذلك، ولا تأكُلُ حمار الوحش{9}. (٦/٢٤٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٦٥٧٢<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿حرمنا كل ذي ظفر﴾</span>، قال: كان يُقال: هو البعير، والنعامة، في أشياءَ{10} من الطير، والحِيتان{11}. (٦/٢٤٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٦٥٧٣<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق مَعْمَر- <span class="qpc-hafs">﴿كل ذي ظفر﴾</span>، قال: الإبل والنعام، ظفر يد البعير ورجله، والنعام أيضًا كذلك، وحرم عليهم أيضًا من الطير البط وشبهه، وكل شيء ليس بمشقوق الأصابع{12}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٦٥٧٤<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط-: أمّا <span class="qpc-hafs">﴿كل ذي ظفر﴾</span> فالإبل، والنعام{13}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٦٥٧٥<span class="dash">-</span></span> عن <span class="name-2">حنش الصنعاني</span> -من طريق ربيعة بن أبي سليم - في قول الله: <span class="qpc-hafs">﴿حرمنا﴾</span> عليهم، <span class="qpc-hafs">﴿كل ذي ظفر﴾</span> إنّه الخنزير، والنعام، والبعير{14}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٦٥٧٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وعلى الذين هادوا حرمنا كل ذي ظفر﴾</span>، يعني: الإبل، والنعامة، والوَزُّ{15}، والبط، وكل شيء له خُفٌّ وظُفُر من الدوابِّ والطير، فهو عليهم حرام{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٦٥٧٧<span class="dash">-</span></span> عن <span class="name-3">عبد الملك ابن جُرَيْج</span>: <span class="qpc-hafs">﴿حرمنا كل ذي ظفر﴾</span>، قال: كلَّ شيءٍ لم تُفْرَجْ قوائمُه من البهائم، وما انفَرَجَت قوائمُه أكَلُوه، ولا يأكلون البعير، ولا النعامة، ولا البطَّ، ولا الوَزَّ، ولا حمار الوَحْش{17}. (٦/٢٤٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٦٥٧٨<span class="dash">-</span></span> قال <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿وعلى الذين هادوا حرمنا كل ذي ظفر﴾</span>: الإبل قط{18}<span class=comment-ref>٢٤٢٦</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٢٤٢٦</span> أفادت الآثارُ الاختلافَ في المراد بقوله تعالى: <span class="qpc-hafs">﴿كُلَّ ذِي ظُفُرٍ﴾</span> على قولين: <b>أحدهما</b>: أنّ المراد به: كل ما لم يكن مشقوق الأصابع من البهائم والطير؛ كالإبل، والنعام، والإوزّ، والبط. وهذا قول ابن عباس، ومجاهد، وسعيد بن جبير، وقتادة، والسديّ، وغيرهم. <b>والآخر</b>: أنّ المراد به: الإبل فقط. وهذا قول ابن زيد.</p><p>و<span class="comment-type-3">رجَّحَ</span> <u>ابنُ جرير</u> (٩/٦٤١) القولَ الأولَ <span class="mustanad">استنادًا إلى عموم الآية، وقول الأكثر</span>، وقال: «لأنّ الله -جلَّ ثناؤه- أخبر أنه حرَّم على اليهود كلَّ ذي ظفر، فغير جائز إخراج شيء من عموم هذا الخبر، إلا ما أجمع أهل العلم أنه خارج منه. وإذ كان ذلك كذلك، وكان النعامُ وكلُّ ما لم يكن من البهائم والطير مما له ظفر غير منفرج الأصابع داخلًا في ظاهر التنزيل؛ وجب أن يُحْكَم له بأنه داخل في الخبر؛ إذ لم يأتِ بأن بعض ذلك غير داخلٍ في الآية خبرٌ عن الله ولا عن رسوله، وكانت الأمة أكثرها مُجْمِعٌ على أنه فيه داخلٌ».</p><p>وحكى <u>ابنُ عطية</u> (٣/٤٨٣) تضعيف التخصيص الذي قال به ابن زيد. و<span class="comment-type-4">ذكر</span> أنّ النقاش حكى عن ثعلب أنّ كل ما لا يصيد فهو ذو ظفر، وما يصيد فهو ذو مخلب. و<span class="comment-type-4">علَّق</span> عليه بقوله: «وهذا غير مُطَّرِد؛ لأنّ الأسد ذو ظفر».</div></p><p><h3><span class="qpc-hafs">﴿وَمِنَ ٱلۡبَقَرِ وَٱلۡغَنَمِ حَرَّمۡنَا عَلَیۡهِمۡ شُحُومَهُمَاۤ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٢٦٥٧٩<span class="dash">-</span></span> عن جابر بن عبد الله: سمعتُ النبي ﷺ قال: «<b>قاتَل اللهُ اليهودَ؛ لَمّا حرَّم الله عليهم شحومَها جَمَلُوهُ</b>{19}، <b>ثم باعوه، فأَكَلُوها</b>»{20}. (٦/٢٤٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٦٥٨٠<span class="dash">-</span></span> عن أسامة بن زيد، قال: قال رسول الله ﷺ: «<b>لعن الله اليهود؛ حُرِّمت عليهم الشحوم، فباعُوها، وأَكَلُوا أثمانَها</b>»{21}. (٦/٢٤٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٦٥٨١<span class="dash">-</span></span> عن عمر بن الخطاب، قال: قال رسول الله ﷺ: «<b>لعن الله اليهود؛ حُرِّمَت عليهم الشحوم، فباعُوها، وأَكَلُوا أثمانَها</b>»{22}. (٦/٢٤٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٦٥٨٢<span class="dash">-</span></span> عن أبي هريرة، قال: قال رسول الله ﷺ: «<b>قاتل الله اليهود؛ حرَّم الله عليهم الشحوم، فباعوه، وأكَلوا ثمنَه</b>»{23}. (٦/٢٤٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٦٥٨٣<span class="dash">-</span></span> عن ابن عباس، أنّ رسول الله ﷺ قال: «<b>لعن الله اليهود</b> -ثلاثًا-؛ <b>إنّ الله حرَّم عليهم الشحوم، فباعُوها، وأكَلُوا أثمانَها، وإن الله لم يُحرِّمْ على قومٍ أكْلَ شيءٍ إلا حرَّم عليهم ثمنَه</b>»{24}. (٦/٢٤٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٦٥٨٤<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- قال: <span class="qpc-hafs">﴿ومِنَ البَقَرِ والغَنَمِ حَرَّمْنا عَلَيْهِمْ شُحُومَهُما﴾</span>: الثُّرُوب{25}. ذُكر لنا: أنّ نبي الله ﷺ كان يقول: «<b>قاتل الله اليهود؛ حرَّم اللهُ عليهم الثُّرُوب، ثم أكلوا أثمانها</b>»{26}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٦٥٨٥<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- في قوله: <span class="qpc-hafs">﴿ومن البقر والغنم حرمنا عليهم شحومهما﴾</span>، قال: حرَّم الله عليهم الثَّرْبَ، وشحم الكُلْيَتَيْن{27}. (٦/٢٤٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٦٥٨٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ومن البقر والغنم حرمنا عليهم شحومهما﴾</span>، وحرَّم عليهم الشحوم من البقر والغنم{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٦٥٨٧<span class="dash">-</span></span> عن <span class="name-3">عبد الملك ابن جريج</span> -من طريق حجاج- قال: إنّما حرَّم عليهم الثَّرْبَ، وشحم الكُلْيَة، وكلَّ شحم كان ليس في عظم{29}. (٦/٢٤٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٦٥٨٨<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿حرمنا عليهم شحومهما﴾</span>، قال: إنّما حرم عليهم الثُّرُوب والكُلْيَتَيْن{30}<span class=comment-ref>٢٤٢٧</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٢٤٢٧</span> أفادت الآثارُ الاختلاف في الشحوم التي أخبر الله تعالى أنه حرَّمها على اليهود من البقر والغنم على ثلاثة أقوال: <b>أولها</b>: أنّها شحوم الثُّرُوبِ خاصَّةً [والثروب، جمع ثَرْب: وهو شحم غشي الكرش والأمعاء، رقيق]. وهذا قول قتادة. <b>ثانيها</b>: أنّها كل شحم لم يكن مُختلطًا بعظم، ولا على عظم. وهذا قول ابن جريج. <b>ثالثها</b>: أنّها شحم الثَّرْب والكُلى. وهو قول السديّ، وابن زيد.</p><p>و<span class="comment-type-4">ذَهَبَ</span> <u>ابنُ جرير</u> (٩/٦٤٢) إلى أنّ المراد: كل شحم إلا ما استثني. <span class="mustanad">استنادًا إلى العموم، والسنة</span>، فقال: «والصواب في ذلك من القول أن يقال: إنّ الله أخبر أنه كان حرَّم على اليهود من البقر والغنم شحومهما إلا ما استثناه منها، مما حملت ظهورهما أو الحَوايا أو ما اختلط بعظم، فكل شحم سوى ما استثناه الله في كتابه من البقر والغنم فإنه كان محرَّمًا عليهم. وبنحو ذلك من القول تظاهرت الأخبار عن رسول الله ﷺ، وذلك قوله: «قاتل الله اليهود، حُرِّمَت عليهم الشحوم فجملوها، ثم باعوها وأكلوا أثمانها»».</p><p>و<span class="comment-type-4">بنحو</span> ذلك قال <u>ابنُ عطية</u> (٣/٤٨٣).</div></p><p><h3><span class="qpc-hafs">﴿إِلَّا مَا حَمَلَتۡ ظُهُورُهُمَاۤ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٢٦٥٨٩<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- في قوله: <span class="qpc-hafs">﴿ومن البقر والغنم حرمنا عليهم شحومهما إلا ما حملت ظهورهما﴾</span>، يعني: ما عَلِق بالظَّهرِ من الشحم{31}. (٦/٢٤٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٦٥٩٠<span class="dash">-</span></span> عن <span class="name-2">الضحاك بن مُزاحِم</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٦٥٩١<span class="dash">-</span></span> و<span class="name-3">مقاتل بن حيان</span>، نحو ذلك{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٦٥٩٢<span class="dash">-</span></span> عن <span class="name-2">أبي صالح باذام</span> -من طريق ابن أبي خالد- في قوله: <span class="qpc-hafs">﴿إلا ما حملت ظهورهما﴾</span>، قال: الأَلْيةُ{33}. (٦/٢٤٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٦٥٩٣<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط-: أمّا <span class="qpc-hafs">﴿ما حملت ظهورهما﴾</span> فالألْياتُ{34}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٦٥٩٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: استثنى ما أحل لهم من الشحوم، فقال: <span class="qpc-hafs">﴿إلا ما حملت ظهورهما﴾</span>. يعني: ظهور البقر، والغنم، والأكتاف، والألْيةُ{2}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿أَوِ ٱلۡحَوَایَاۤ أَوۡ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٢٦٥٩٥<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- في قوله: <span class="qpc-hafs">﴿أو الحوايا﴾</span>: هو المِبْعَرُ{36}. (٦/٢٤٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٦٥٩٦<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span> -من طريق عطاء- <span class="qpc-hafs">﴿أوالحوايا﴾</span>، قال: المَباعِر{37}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٦٥٩٧<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نَجِيح- في قوله: <span class="qpc-hafs">﴿أو الحوايا﴾</span>، قال: المَباعِر{38}. (٦/٢٤٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٦٥٩٨<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- <span class="qpc-hafs">﴿الحوايا﴾</span>: المِبْعَرُ، والمَرْبِضُ{39}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٦٥٩٩<span class="dash">-</span></span> عن <span class="name-2">الضحاك بن مزاحم</span> -من طريق جويبر- في قوله: <span class="qpc-hafs">﴿أو الحوايا﴾</span>، قال: المرابضُ، والمباعر{40}. (٦/٢٤٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٦٦٠٠<span class="dash">-</span></span> عن <span class="name-2">الضحاك بن مزاحم</span> -من طريق عبيد بن سليمان-: أمّا قوله: <span class="qpc-hafs">﴿أو الحوايا﴾</span> فالبطون غير الثروب{41}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٦٦٠١<span class="dash">-</span></span> عن <span class="name-3">مقاتل بن حيان</span>، مثل ذلك{42}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٦٦٠٢<span class="dash">-</span></span> عن <span class="name-2">أبي صالح باذام</span>، في قوله: <span class="qpc-hafs">﴿أو الحوايا﴾</span>، قال: المِبْعَرُ{43}. (٦/٢٤٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٦٦٠٣<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿أوالحوايا﴾</span>، قال: المِبْعَر{44}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٦٦٠٤<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السدي</span> -من طريق أسباط- <span class="qpc-hafs">﴿أوالحوايا﴾</span>، قال: المباعِر{45}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٦٦٠٥<span class="dash">-</span></span> عن <span class="name-2">عطاء الخراساني</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٦٦٠٦<span class="dash">-</span></span> و<span class="name-3">مقاتل بن حيان</span>، نحو ذلك{46}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٦٦٠٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿أو الحوايا﴾</span>، يعني: المِعى{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٦٦٠٨<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- قال: <span class="qpc-hafs">﴿الحوايا﴾</span>: المرابِض التي تكون فيها الأمعاء، تكون وسَطَها، وهي بنات اللَّبَن{48}، وهي في كلام العرب تُدْعى: المرابِض{49}<span class=comment-ref>٢٤٢٨</span>. (٦/٢٤٨)</p></p><p></div></p><p><div><span class=comment-ref>٢٤٢٨</span> <span class="comment-type-4">ذكر</span> <u>ابنُ عطية</u> (٣/٤٨٥) أنّ <span class="qpc-hafs">﴿الحَوايا﴾</span> معطوف على ما في قول: <span class="qpc-hafs">﴿إلّا ما حَمَلَتْ﴾</span>، فهي في موضع نصب عطفًا على المنصوب بالاستثناء، ثم ذكر أنّ البعض قال بعطفها على الشحوم. و<span class="comment-type-2">انتَقَده</span> <span class="mustanad">مستندًا لظاهر لفظ الآية</span>، فقال: «وعلى هذا تدخل <span class="qpc-hafs">﴿الحَوايا﴾</span> في التحريم، وهذا قولٌ لا يعضده اللفظ ولا المعنى، بل يدفعانه».</div></p><p><h3><span class="qpc-hafs">﴿أَوۡ مَا ٱخۡتَلَطَ بِعَظۡمࣲۚ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٢٦٦٠٩<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، في قوله: <span class="qpc-hafs">﴿أو ما اختلط بعظم﴾</span>، قال: الأَلْيَةُ؛ اخْتَلَط شحم الأَلْية بالعُصْعُص{50} فهو حلال، وكلُّ شحم القوائم والجنب والرأس والعين والأذن يقولون: قد اختلَط ذلك بعظم. فهو حلال لهم، إنما حرَّم عليهم الثَّرْبَ، وشحم الكُلْيَة، وكلَّ شيءٍ كان كذلك ليس في عظم{51}. (٦/٢٤٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٦٦١٠<span class="dash">-</span></span> عن <span class="name-2">الضحاك بن مُزاحِم</span> -من طريق جُوَيبِر- في قوله: <span class="qpc-hafs">﴿أو ما اختلط بعظم﴾</span>، قال: ما أُلْزِق بالعظم{52}. (٦/٢٤٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٦٦١١<span class="dash">-</span></span> عن <span class="name-2">أبي صالح باذام</span> -من طريق ابن أبي خالد- في قوله: <span class="qpc-hafs">﴿أو ما اختلط بعظم﴾</span>، قال: الشَّحْم{53}. (٦/٢٤٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٦٦١٢<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- <span class="qpc-hafs">﴿أو ما اختلط بعظم﴾</span>: فما كان من شحم على عظم{54}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٦٦١٣<span class="dash">-</span></span> عن <span class="name-3">مقاتل بن حيان</span>، نحو ذلك{42}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٦٦١٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿أو ما اختلط﴾</span> من الشحم <span class="qpc-hafs">﴿بعظم﴾</span>، فكلُّ هذا حلال لهم، وحُرِّم عليهم شحوم الكُلْيَتين، والثُّرُوبُ{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٦٦١٥<span class="dash">-</span></span> عن <span class="name-3">عبد الملك ابن جُرَيْج</span> -من طريق حجاج- <span class="qpc-hafs">﴿أو ما اختلط بعظم﴾</span>، قال: شحم الأَلْية بالعُصْعُص، فهو حلال، وكل شيء في القوائم والجنب والرأس والعين قد اختلط بعظم، فهو حلال{57}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿ذَ ٰ⁠لِكَ جَزَیۡنَـٰهُم بِبَغۡیِهِمۡۖ وَإِنَّا لَصَـٰدِقُونَ ۝١٤٦﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٢٦٦١٦<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿ذلك جزيناهم ببغيهم﴾</span>، قال: إنّما حرَّم الله ذلك عليهم عقوبةً ببغيِهم، فشدَّد عليهم بذلك، وما هو بخبيث{58}. (٦/٢٤٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٦٦١٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ذلك﴾</span> التحريم <span class="qpc-hafs">﴿جزيناهم ببغيهم﴾</span> يعني: عقوبة بقتلهم الأنبياء، وبصدِّهم عن سبيل الله، وبأكلهم الربا، واستحلالهم أموال الناس بالباطل، فهذا البغي، <span class="qpc-hafs">﴿وإنا لصادقون﴾</span> بذلك{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٦٦١٨<span class="dash">-</span></span> عن <span class="name-3">مقاتل بن حيان</span> -من طريق بُكَيْر بن معروف- في قوله: <span class="qpc-hafs">﴿ذلك جزيناهم ببغيهم﴾</span>، يقول: باستحلالهم ما كان الله حرَّم عليهم{60}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٦٦١٩<span class="dash">-</span></span> قال <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿ذلك جزيناهم ببغيهم﴾</span>: فعلنا ذلك بهم ببغيهم{61}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن أبي حاتم ٥/١٤٠٩.تفسير مقاتل بن سليمان ١/٥٩٥.أخرجه ابن جرير ٩/٦٣٨ مختصرًا، وابن أبي حاتم ٥/١٤١٠.علَّقه ابن أبي حاتم ٥/١٤١٠.علَّقه ابن أبي حاتم ٥/١٤١٠.أخرجه ابن جرير ٩/٦٣٨، والبيهقي في سُنَنه ١٠/٥٣. وعزاه ابن حجر في الفتح ٨/٢٩٥ إلى ابن أبي حاتم. وعزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ٩/٦٣٩. وعلَّقه ابن أبي حاتم ٥/١٤١٠. وعزا السيوطي ٦/٢٤٥ إلى أبي الشيخ قوله: الديكُ منه.الوزِّينة: الإوزة. التاج (وزز).تفسير مجاهد ص٣٣٠، وأخرجه ابن جرير ٩/٦٤٠. وعلَّقه ابن أبي حاتم ٥/١٤١٠. وعزاه السيوطي إلى أبي الشيخ.كذا في المطبوع من الدر ٦/٢٤٥، وأخرجه ابن جرير ٩/٦٣٩ بلفظ: وأشباهه.أخرجه ابن جرير ٩/٦٣٩. وعزاه السيوطي إلى عبد بن حميد.أخرجه عبد الرزاق ٢/٢٢١، وابن جرير ٩/٦٣٩. وعلَّقه ابن أبي حاتم ٥/١٤١٠.أخرجه ابن جرير ٩/٦٤٠. وعلقه ابن أبي حاتم ٥/١٤١٠.أخرجه عبد الله بن وهب في الجامع - تفسير القرآن ١/٨١ (١٨٢).الوَزُّ، لغةٌ فِي الإوَزِّ، وهو من طير الماء. تاج العروس (وزز).تفسير مقاتل بن سليمان ١/٥٩٥.عزاه السيوطي إلى أبي الشيخ.أخرجه ابن جرير ٩/٦٤٠.جمَلُوه: أذابوه واستخرجوا دهنه. النهاية (جمل).أخرجه البخاري ٣/٨٤ (٢٢٣٦)، ٦/٥٧ (٤٦٣٣)، ومسلم ٣/١٢٠٧ (١٥٨١).أخرجه الحاكم ٤/٢١٥ (٧٤١٤)، والدارقطني في العلل الواردة في الأحاديث النبوية ١/٧٨ (٦) واللفظ له.</p><p>قال البزار في مسنده ٧/٥٩ (٢٦٠٨): «وهذا الحديث لا نعلمه يروى عن أسامة إلا من هذا الوجه بهذا الإسناد». وقال الحاكم: «هذا حديث صحيح الإسناد، ولم يخرجاه». وقال الذهبي في التلخيص: «صحيح».أخرجه البخاري ٣/٨٢ (٢٢٢٣)، ٤/١٧٠ (٣٤٦٠)، ومسلم ٣/١٢٠٧ (١٥٨٢).أخرجه البخاري ٣/٨٢ (٢٢٢٤)، ٤/١٧٠ (٣٤٦٠)، ومسلم ٣/١٢٠٨ (١٥٨٣).أخرجه أحمد ٤/٩٥ (٢٢٢١)، ٤/٤١٦ (٢٦٧٨)، ٥/١١٥ (٢٩٦١)، وأبو داود ٥/٣٥٢ (٣٤٨٨).</p><p>قال ابن الملقن في تحفة المحتاج ٢/٢٠٤ (١١٧٧): «بإسناد صحيح». وقال الرباعي في فتح الغفار ٣/١١٥٣ (٣٥٣٣): «ورجال إسناده ثقات».الثُّرُوبُ: الشحم الرقيق الذي يُغَشّي الكَرِش والأمعاء، الواحد: ثَرْب. النهاية (ثرب).أخرجه ابن جرير ٩/٦٤١.الكُلْيَتان، بالضم، من الإنسانِ وغيرِه من الحيوان: لحمتان حَمْراوانِ لازقتان بعَظْم الصُّلْبِ عند الخاصِرَتَيْن، في كُظْرَيْن من الشحم. تاج العروس (كلى). والأثر أخرجه ابن جرير ٩/٦٤٢، وابن أبي حاتم ٥/١٤١٠.تفسير مقاتل بن سليمان ١/٥٩٥.أخرجه ابن جرير ٩/٦٤٢. وعزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ٩/٦٤٢، وقال: هكذا هو في كتابي عن يونس، وأنا أحسب أنه الكلى.أخرجه ابن جرير ٩/٦٤٣، وابن أبي حاتم ٥/١٤١٠، والبيهقي في سننه ١٠/٨. وعزاه السيوطي إلى ابن المنذر.علَّقه ابن أبي حاتم ٥/١٤١٠.أخرجه ابن جرير ٩/٦٤٣، وابن أبي حاتم ٥/١٤١٠. وعزاه السيوطي إلى أبي الشيخ.</p><p>والأَلْيَةُ: طرف الشاة. النهاية (ألا).أخرجه ابن جرير ٩/٦٤٣. وعلَقه ابن أبي حاتم ٥/١٤١٠.تفسير مقاتل بن سليمان ١/٥٩٥.أخرجه ابن جرير ٩/٦٤٤، وابن أبي حاتم ٥/١٤١٠، والبيهقي في سننه ١٠/٨. وعزاه السيوطي إلى ابن المنذر.</p><p>والمبْعَرُ -بكسر الميم، وفتحها-: مكان البَعر من كل ذي أربع، والجمع: المباعر. لسان العرب (بعر).أخرجه ابن جرير ٩/٦٤٥. وعلَّقه ابن أبي حاتم ٥/١٤١٠-١٤١١.تفسير مجاهد ص٣٣٠، وأخرجه ابن جرير ٩/٦٤٤. وعلَّقه ابن أبي حاتم ٥/١٤١٠-١٤١١. وعزاه السيوطي إلى ابن أبي شيبة، وعبد بن حميد، وابن المنذر.أخرجه ابن جرير ٩/٦٤٤.أخرجه ابن جرير ٩/٦٤٥، وابن أبي حاتم ٥/١٤١١. وعزاه السيوطي إلى ابن أبي شيبة، وابن المنذر.أخرجه ابن جرير ٩/٦٤٥، كما أخرجه ابن أبي حاتم ٥/١٤١١ من طريق علي بن الحكم، ثم قال: وخالفه عبيد بن سلمان عن الضحاك فقال: يعني بالثروب: غير البطون.علَّقه ابن أبي حاتم ٥/١٤١١.علَّقه ابن أبي حاتم ٥/١٤١٠. وعزاه السيوطي إلى أبي الشيخ.أخرجه ابن جرير ٩/٦٤٥، وعبد الرزاق ٢/٢٢١ من طريق معمر. وعلقه ابن أبي حاتم ٥/١٤١٠، ١٤١١.أخرجه ابن جرير ٩/٦٤٥. وعلَّقه ابن أبي حاتم ٥/١٤١٠، ١٤١١.علَّقه ابن أبي حاتم ٥/١٤١٠، ١٤١١.تفسير مقاتل بن سليمان ١/٥٩٥.بنات اللَّبَن: ما صغُر من الأمعاء. لسان العرب (بنو).أخرجه ابن جرير ٩/٦٤٦، وابن أبي حاتم ٥/١٤١١ من طريق أصبغ.العُصْعُصُ والعَصْعَصُ: أصل الذَّنَبِ. لسان العرب (عصص).عزاه السيوطي إلى ابن المنذر، وأبي الشيخ.أخرجه ابن أبي حاتم ٥/١٤١١. وعزاه السيوطي إلى ابن أبي شيبة، وابن المنذر.أخرجه ابن أبي حاتم ٥/١٤١١. وعزاه السيوطي إلى أبي الشيخ.أخرجه ابن جرير ٩/٦٤٦. وعلَّقه ابن أبي حاتم ٥/١٤١١.علَّقه ابن أبي حاتم ٥/١٤١١.تفسير مقاتل بن سليمان ١/٥٩٥.أخرجه ابن جرير ٩/٦٤٦.أخرجه ابن جرير ٩/٦٤٧، وابن أبي حاتم ٥/١٤١١ كلاهما بلفظ: إنّما حرَّم ذلك عليهم عقوبة ببغيهم. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وأبي الشيخ.تفسير مقاتل بن سليمان ١/٥٩٥.أخرجه ابن أبي حاتم ٤/١١١٤، ٥/١٤١٢.أخرجه ابن جرير ٩/٦٤٧.