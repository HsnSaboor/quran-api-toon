tafsir[28]{c,v,t}:
74,48," <q>﴿فَمَا تَنفَعُهُمۡ شَفَـٰعَةُ ٱلشَّـٰفِعِینَ ۝٤٨﴾</q> - تفسير ٧٩٩١٢- عن عبد الله بن مسعود، قال: قال رسول الله ﷺ: «لَيَخرُجنّ بشفاعتي من أهل الإيمان من النار، حتى لا يبقى فيها أحدٌ إلا أهل هذه الآية: <q>﴿ما سَلَكَكُمْ فِي سَقَرَ﴾</q> إلى قوله: <q>﴿شَفاعَةُ الشّافِعِينَ﴾</q>»{1}. (١٥/٨٧) ٧٩٩١٣- عن أنس، عن النبيِّ ﷺ، قال: «يُؤتى بأدنى أهل النار منزلة يوم القيامة، فيقول اللهُ له: تَفتدي بملء الأرض ذهبًا وفِضّة؟ فيقول: نعم، إن قَدَرتُ عليه. فيقول: كَذبتَ، قد كنتُ أسألك ما هو أيسرُ عليك مِن أن تسألني فأُعطيك، وتَستغفرني فأغفر لك، وتدعوني فأستجيب لك، فلم تَخفني ساعة قطّ من ليل ونهار، ولم تَرجُ ما عندي قطّ، ولم تَخشَ عقابي ساعة قطّ. وليس وراءه أحد إلا وهو شرٌّ منه، فيقال له: <q>﴿ما سَلَكَكُمْ فِي سَقَرَ قالُوا لَمْ نَكُ مِنَ المُصَلِّينَ﴾</q> إلى قوله: <q>﴿حَتّى أتانا اليَقِينُ﴾</q>، يقول الله: <q>﴿فَما تَنْفَعُهُمْ شَفاعَةُ الشّافِعِينَ﴾</q>»{2}. (١٥/٨٧) ٧٩٩١٤- عن حبيبة -أو أُمّ حبيبة- قالت: كُنّا في بيت عائشة، فدخل رسول الله ﷺ، فقال: «ما مِن مُسلِمَيْن يموت لهما ثلاثة من الولد أطفال لم يَبلغوا الحِنث إلا جيء بهم حتى يُوقفوا على باب الجنة، فيقال لهم: ادخلوا الجنة أنتم وآباؤكم». قال: فذلك قوله: <q>﴿فَما تَنْفَعُهُمْ شَفاعَةُ الشّافِعِينَ﴾</q>. فعقّب، قال: نَفعت الآباء شفاعة أبنائهم{3}. (ز) ٧٩٩١٥- عن عبد الله بن مسعود -من طريق أبي الزّعراء- قال: يُعذِّب الله قومًا مِن أهل الإيمان، ثم يُخرجهم بشفاعة محمد ﷺ، حتى لا يَبقى إلا مَن ذَكر الله: <q>﴿ما سَلَكَكُمْ فِي سَقَرَ﴾</q> إلى قوله: <q>﴿شَفاعَةُ الشّافِعِينَ﴾</q>{4}. (١٥/٨٩) ٧٩٩١٦- عن عبد الله [بن مسعود] -من طريق أبي الزّعراء- في حديث طويل عن آخر الزمان ومبدأ البعث، قال: ... ثم يَشفع الملائكة، والنَّبيّون، والشهداء، والصالحون، والمؤمنون، فيُشفِّعهم الله، قال: ثم يقول: أنا أرحم الراحمين. قال: فيُخرج من النار أكثرَ مما أُخرج مِن جميع الخَلْق برحمته، حتى ما يَترك فيها أحدًا فيه خير. ثم قرأ عبد الله: <q>﴿ما سَلَكَكُمْ فِي سَقَرَ﴾</q> قال: وجعل يعقِد حتى عدَّ أربعًا: <q>﴿قالُوا لَمْ نَكُ مِنَ المُصَلِّينَ ولَمْ نَكُ نُطْعِمُ المِسْكِينَ وكُنّا نَخُوضُ مَعَ الخائِضِينَ وكُنّا نُكَذِّبُ بِيَوْمِ الدِّينِ حَتّى أتانا اليَقِينُ فَما تَنْفَعُهُمْ شَفاعَةُ الشّافِعِينَ﴾</q> ثم قال عبد الله: أترون في هؤلاء خيرًا؟! ما تُرك فيها أحد فيه خير{5}. (ز) ٧٩٩١٧- قال عمران بن الحُصَين: الشفاعة نافعةٌ لكلّ واحد، دون هؤلاء الذين تَسمعون{6}. (ز) ٧٩٩١٨- عن عبد الرحمن بن ميمون الأَودي: أنّ كعب [الأحبار] دخل يومًا على عمر بن الخطاب، فقال له عمر: حَدِّثني إلى ما تنتهي شفاعة محمد ﷺ يوم القيامة؟ فقال كعب: قد أخبَرك الله في القرآن؛ إنّ الله يقول: <q>﴿ما سَلَكَكُمْ فِي سَقَرَ﴾</q> إلى قوله: <q>﴿اليَقِينُ﴾</q>. قال كعب: فيَشفع يومئذ حتى يَبلغ مَن لم يُصلِّ صلاة قطّ، ولم يُطعم مسكينًا قطّ، ولم يُؤمن ببعثٍ قطّ، فإذا بَلغت هؤلاء لم يبق أحد فيه خير{7}. (١٥/٨٧) ٧٩٩١٩- عن مجاهد بن جبر، <q>﴿فَما تَنْفَعُهُمْ شَفاعَةُ الشّافِعِينَ﴾</q>، قال: لا تنالهم شفاعة مَن يَشفع{8}. (١٥/٨٧) ٧٩٩٢٠- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿فَما تَنْفَعُهُمْ شَفاعَةُ الشّافِعِينَ﴾</q>، قال: تعلَّموا أن الله يُشَفِّع المؤمنين يوم القيامة بعضهم في بعض. قال: وذُكر لنا: أنّ نبي الله ﷺ قال: «إنّ في أمتي لَرجلًا ليُدخِلنّ الله الجنةَ بشفاعته أكثر من بني تميم». وقال الحسن البصري: أكثر من ربيعة ومُضر. قال: وكُنّا نُحدَّث أنّ الشهيد يَشفع في سبعين من أهل بيته{9}. (١٥/٨٦) ٧٩٩٢١- عن إسماعيل السُّدِّيّ -من طريق سفيان- <q>﴿فَما تَنْفَعُهُمْ شَفاعَةُ الشّافِعِينَ﴾</q>، قال: لا تَنالهم{10}. (ز) ٧٩٩٢٢- قال مقاتل بن سليمان: <q>﴿فَما تَنْفَعُهُمْ شَفاعَةُ الشّافِعِينَ﴾</q>، يعني: لا يَنالهم يومئذ شفاعة الملائكة والنَّبيّين{11}. (ز) <q>﴿فَمَا تَنفَعُهُمۡ شَفَـٰعَةُ ٱلشَّـٰفِعِینَ ۝٤٨﴾</q> - آثار متعلقة بالآية ٧٩٩٢٣- عن أنس، يقول: قال النبي ﷺ: «إنّ الرجل ليشفع للرجلين، والثلاثة، والرجل للرجال»{12}. (ز) ٧٩٩٢٤- عن أنس، قال: قال رسول الله ﷺ يَصِف أهلَ النار: «فيَمُرّ فيهم الرجل من أهل الجنة، فيقول الرجل منهم: يا فلان. قال: فيقول: ما تريد؟ فيقول: أما تذكر رجلًا سَقاك شربة يوم كذا وكذا؟ قال فيقول: وإنّك لَأنت هو؟ فيقول: نعم. فيَشفع له، فيُشفّع فيه. قال: ثم يَمُرّ بهم الرجل من أهل الجنة، فيقول: يا فلان، فيقول: ما تريد؟ فيقول: أما تَذكر رجلًا وهب لك وضوءًا يوم كذا وكذا؟ فيقول: إنك لأنت هو؟ فيقول: نعم. فيَشفع له، فيُشفّع فيه»{13}. (ز) ٧٩٩٢٥- عن يزيد بن صُهيب الفقير، قال: كُنّا بمكة ومعي طَلق بن حبيب، وكنا نرى رأي الخوارج، فبَلغنا أنّ جابر بن عبد الله يقول في الشفاعة، فأتيناه، فقلنا له: بلغنا عنك في الشفاعة قولٌ، اللهُ مخالفٌ لك فيها في كتابه. فنَظر في وجوهنا، فقال: مِن أهل العراق أنتم؟ قلنا: نعم. فتبَسّم، وقال: وأين تجدون في كتاب الله؟ قلت: حيث يقول: <q>﴿رَبَّنا إنَّكَ مَن تُدْخِلِ النّارَ فَقَدْ أخْزَيْتَهُ﴾</q> [آل عمران:١٩٢]، و<q>﴿يُرِيدُونَ أنْ يَخْرُجُوا مِنَ النّارِ وما هُمْ بِخارِجِينَ مِنها﴾</q> [المائدة:٣٧]، و<q>﴿كُلَّما أرادُوا أنْ يَخْرُجُوا مِنها أُعِيدُوا فِيها﴾</q> [السجدة:٢٠]، وأشباه هذا من القرآن. فقال: أنتم أعلم بكتاب الله أم أنا؟ قلنا: بل أنتَ أعلم به منّا. قال: فواللهِ، لقد شهدتُ تنزيل هذا على عهد رسول الله ﷺ وشفاعة الشافعين، ولقد سمعتُ تأويله من رسول الله ﷺ، وإنّ الشفاعة لنبيّه في كتاب الله؛ قال في السورة التي يذكر فيها المُدَّثِّر: <q>﴿ما سَلَكَكُمْ فِي سَقَرَ قالُوا لَمْ نَكُ مِنَ المُصَلِّينَ﴾</q> الآية، ألا تَرون أنها حلّتْ لِمن لا يُشرك بالله شيئًا؟ سمعتُ رسول الله ﷺ يقول: «إنّ الله خَلَق خَلْقًا، ولم يَستعن على ذلك، ولم يُشاور فيه أحدًا، فأَدخلَ مَن شاء الجنة برحمته، وأَدخلَ مَن شاء النار، ثم إنّ الله تحنّن على المُوحِّدين، فبَعث ملَكًا مِن قِبَله بماء ونور، فدَخل النار، فنَضح، فلم يُصب إلا مَن شاء، ولم يُصب إلا مَن خَرج من الدنيا لم يُشرك بالله شيئًا، فأَخرجَهم حتى جَعلهم بفناء الجنة، ثم رجع إلى ربّه، فأمدّه بماء ونور، ثم دَخل فنَضح، فلم يُصب إلا مَن شاء الله، ثم لم يُصب إلا مَن خرج من الدنيا لم يُشرك بالله شيئًا، فأَخرجَهم حتى جَعلهم بفناء الجنة، ثم أذِن الله للشفعاء، فشَفعوا لهم، فأَدخلهم الله الجنة برحمته وشفاعة الشافعين»{14}. (١٥/٨٨) ",footnotes:1:أخرجه ابن خسرو في مسند أبي حنيفة ١/٤٥١ (٤٨٩)، والحارثي في مسند أبي حنيفة ٢/٨٤٢ (١٤٩٧-١٥١٢)، من طريق أبي حنيفة، عن سلمة بن كُهيل، عن أبي الزّعراء، عن عبد الله بن مسعود به. وعزاه السيوطي إلى ابن مردويه. قال ابن خسرو: «روى الجماعة هذا الحديث موقوفًا على عبد الله بن مسعود».أخرجه الواحدي في التفسير الوسيط ٤/٣٨٦-٣٨٧ (١٢٥٧)، من طريق ليث، عن بشر، عن أنس بن مالك به. وعزاه السيوطي إلى ابن مردويه. وسنده ضعيف؛ فيه بشر، قال عنه ابن حجر في التقريب (٧١٠): «هو ابن دينار، مجهول». وفيه ليث بن أبي سليم، قال عنه ابن حجر في التقريب (٥٦٨٥): «صدوق، اختلط جدًّا، ولم يتميّز حديثه؛ فتُرك».أخرجه إسحاق بن راهويه في مسنده ٤/٢٥١ (٢٠٧٤)، والطبراني في الكبير ٢٤/٢٢٤ (٥٧٠)، بنحوه دون ذكر الآية، من طريق محمد بن سيرين، عن حبيبة به. ووقع عند إسحاق: حبيبة أو أُمّ حبيبة. وأخرجه الطبراني في الكبير ٢٤/٢٢٥ (٥٧١) بنحوه دون ذكر الآية، من طريق محمد بن سيرين، عن يزيد بن أبي بكرة، عن حبيبة به. وقال المنذري في الترغيب والترهيب ٣/٥٥-٥٦ (٣٠٥٧): «رواه الطبراني في الكبير، بإسناد حسن جيد». وقال الهيثمي في المجمع ٣/٧ (٣٩٧٧): «رواه الطبراني في الكبير، ورجاله رجال الصحيح، خلا يزيد بن أبي بكرة، وقد وثّقه ابن حبان، وأعاده بإسناد آخر، ورجاله ثقات، وليس فيه يزيد بن أبي بكرة». وأورده الألباني في الصحيحة ٧/١٢٢٨ (٣٤١٦).أخرجه البيهقي في البعث (٨٦).أخرجه ابن أبي شيبة في مصنفه (ت: محمد عوامة) ٢١/٢٨١-٢٨٥ (٣٨٧٩٢)، وابن جرير ٢٣/٤٥٣ بنحوه مختصرًا.تفسير البغوي ٨/٢٧٣.عزاه السيوطي إلى ابن مردويه.عزاه السيوطي إلى عَبد بن حُمَيد، وابن المنذر.أخرجه ابن جرير ٢٣/٤٥٣، وعبد الرزاق ٢/٣٣٠-٣٣١ من طريق معمر مختصرًا، ومثله ابن جرير ٢٣/٤٥٣. وعزاه السيوطي إلى عَبد بن حُمَيد، وابن المنذر.كتاب صفة النار-موسوعة الإمام ابن أبي الدنيا ٦/٤٢٨ (١٣٣)-.تفسير مقاتل بن سليمان ٤/٤٩٩.أخرجه عبد الرزاق ٣/٣٦٤ (٣٣٩٣) واللفظ له، وابن خزيمة في التوحيد ٢/٧٤٥، والبزار ١٣/٣١٩ (٦٩٢١) مختصرًا، من طريق معمر، عن ثابت، عن أنس بن مالك به. قال المنذري في الترغيب والترهيب ٤/٢٤١ (٥٥١٤): «رواته رواة الصحيح». وقال الهيثمي في المجمع ١٠/٣٨٢ (١٨٥٤٨): «رجاله رجال الصحيح».أخرجه ابن ماجه ٤/٦٤٤ (٣٦٨٥)، والبغوي في تفسيره ٨/٢٧٣-٢٧٤، واللفظ له، من طريق يزيد الرّقاشي، عن أنس بن مالك به. وقال البوصيري في مصباح الزجاجة ٤/١٠٥ (٧٨٢١): «إسناد ضعيف؛ لضعف يزيد بن أبان الرّقاشي». وقال الألباني في الضعيفة ١/٢١٠ (٩٣): «ضعيف».أخرجه ابن أبي حاتم، وابن مردويه -كما في تفسير ابن كثير ٣/٩٩-. وأصله في صحيح مسلم ١/٧٧ (١٩١)، وليس فيه ذكر آية سورة المدثر.
74,49," <q>﴿فَمَا لَهُمۡ عَنِ ٱلتَّذۡكِرَةِ مُعۡرِضِینَ ۝٤٩﴾</q> - نزول الآية ٧٩٩٢٦- قال مقاتل بن سليمان: <q>﴿فَما لَهُمْ عَنِ التَّذْكِرَةِ مُعْرِضِينَ﴾</q> نزلت هذه الآية في كفار قريش حين أعرَضوا ولم يؤمنوا{1}. (ز) <q>﴿فَمَا لَهُمۡ عَنِ ٱلتَّذۡكِرَةِ مُعۡرِضِینَ ۝٤٩﴾</q> - تفسير الآية ٧٩٩٢٧- عن قتادة بن دعامة -من طريق سعيد- <q>﴿فَما لَهُمْ عَنِ التَّذْكِرَةِ مُعْرِضِينَ﴾</q>، قال: عن القرآن{2}. (١٥/٩٠) ٧٩٩٢٨- قال مقاتل بن سليمان: <q>﴿فَما لَهُمْ عَنِ التَّذْكِرَةِ﴾</q> يعني: عن القرآن <q>﴿مُعرِضين﴾</q>{3}. (ز) ",footnotes:1:تفسير مقاتل بن سليمان ٤/٤٩٩-٥٠٠.أخرجه ابن جرير ٢٣/٤٥٤. وعزاه السيوطي إلى عَبد بن حُمَيد، وابن المنذر.أخرجه مقاتل بن سليمان ٤/٤٩٩-٥٠٠.
74,50," <q>﴿كَأَنَّهُمۡ حُمُرࣱ مُّسۡتَنفِرَةࣱ ۝٥٠﴾</q> - قراءات ٧٩٩٢٩- عن الحسن البصري= (ز) ٧٩٩٣٠- وأبي رجاء أنهما قرآ: ‹مُّسْتَنفَرَةٌ›، يعني: بنصب الفاء{1}. (١٥/٩٠) ٧٩٩٣١- عن عاصم بن أبي النجود أنه قرأ: <q>﴿كَأَنَّهُمْ حُمُرٌ﴾</q> مُثقّلة، <q>﴿مُسْتَنْفِرَةٌ﴾</q> بخفض الفاء{2}٦٨٩٠. (١٥/٩٠) ٦٨٩٠ ذكر ابنُ جرير (٢٣/٤٥٥) هذه القراءة، وقراءة مَن قرأ ذلك: ‹مُّسْتَنفَرَةٌ›، ثم قال معلقًا: «والصواب من القول في ذلك عندنا أنهما قراءتان معروفتان، صحيحتا المعنى، فبأيّتهما قرأ القارئ فمصيب». <q>﴿كَأَنَّهُمۡ حُمُرࣱ مُّسۡتَنفِرَةࣱ ۝٥٠﴾</q> - تفسير الآية ٧٩٩٣٢- قال مقاتل بن سليمان: شبّههم بالحُمُر الوحشية المذْعُورة، فقال: <q>﴿كَأَنَّهُمْ حُمُرٌ مُسْتَنْفِرَةٌ﴾</q> بترْكهم القرآن، إذا سمعوه فرُّوا منه مثل الحُمر{3}. (ز) ",footnotes:1:عزاه السيوطي إلى أبي عبيد، وابن المنذر. وهي قراءة متواترة، قرأ بها نافع، وأبو جعفر، وابن عامر، وقرأ بقية العشرة: <q>﴿مُّسْتَنْفِرَةٌ﴾</q> بكسر الفاء. انظر: النشر ٢/٣٩٣، والإتحاف ص٥٦٢.عزاه السيوطي إلى عَبد بن حُمَيد.تفسير مقاتل بن سليمان ٤/٥٠٠.
74,51," <q>﴿فَرَّتۡ مِن قَسۡوَرَةِۭ ۝٥١﴾</q> - تفسير ٧٩٩٣٣- عن أبي موسى الأشعري -من طريق أبي ظَبْيان- في قوله: <q>﴿فَرَّتْ مِن قَسْوَرَةٍ﴾</q>، قال: هم الرُّماة؛ رجال القَنص{1}. (١٥/٩٠) ٧٩٩٣٤- عن أبي هريرة -من طريق زيد بن أسلم- في قوله: <q>﴿فَرَّتْ مِن قَسْوَرَةٍ﴾</q>، قال: الأسد{2}. (١٥/٩٢) ٧٩٩٣٥- عن عبد الله بن عباس -من طريق عطية العَوفيّ- <q>﴿فَرَّتْ مِن قَسْوَرَةٍ﴾</q>، قال: القَسْورة: الرّجال الرُّماة؛ رجال القَنص{3}. (١٥/٩٠) ٧٩٩٣٦- عن عبد الله بن عباس -من طريق علي- في قوله: <q>﴿مِن قَسْوَرَةٍ﴾</q>، قال: هو بلسان العرب: الأسد، وبلسان الحبشة: قَسْورة{4}. (١٥/٩٢) ٧٩٩٣٧- عن عبد الله بن عباس -من طريق أبي حمزة- أنه سأله: القَسْورة الأسد؟ فقال: ما أعلمه بلغة أحد من العرب الأسد، هم عُصْبة الرجال{5}. (١٥/٩١) ٧٩٩٣٨- عن عبد الله بن عباس -من طريق يوسف بن مهران- أنه سئل عن قوله: <q>﴿فَرَّتْ مِن قَسْوَرَةٍ﴾</q>. قال: هو بالعربية: الأسد، وبالفارسية: شار، وبالنّبَطِيّة: أريا، وبالحبشية: قَسْورة{6}. (ز) ٧٩٩٣٩- عن عبد الله بن عباس، <q>﴿مِن قَسْوَرَةٍ﴾</q>، قال: مِن حبال الصيادين{7}. (١٥/٩١) ٧٩٩٤٠- عن عبد الله بن عباس -من طريق عطاء- <q>﴿مِن قَسْوَرَةٍ﴾</q>، قال: هو رِكْزُ الناس. يعني: أصواتهم{8}. (١٥/٩١) ٧٩٩٤١- عن عبد الله بن عباس -من طريق عبّاد بن عبد الرحمن مولى بني هاشم- أنه سئل عن القَسْورة. قال: جمْع الرجال، ألم تسمع ما قالتْ فلانة في الجاهلية: يا بنتي كوني خيْرةً لخَيِّره أخوالها في الحي مثل القَسْورهْ{9}. (ز) ٧٩٩٤٢- عن سعيد بن جُبَير -من طريق أبي بشر- <q>﴿فَرَّتْ مِن قَسْوَرَةٍ﴾</q>، قال: القُنّاص{10}. (١٥/٩١) ٧٩٩٤٣- عن مجاهد بن جبر -من طريق منصور- <q>﴿فَرَّتْ مِن قَسْوَرَةٍ﴾</q>، قال: الرُّماة{11}. (١٥/٩١) ٧٩٩٤٤- قال الضَّحّاك بن مُزاحِم: هم الرُّماة{12}. (ز) ٧٩٩٤٥- قال عكرمة مولى ابن عباس: <q>﴿قَسْوَرَةٍ﴾</q>، القَسْورة: هي مِن ظُلمة الليل{13}. (ز) ٧٩٩٤٦- عن عكرمة مولى ابن عباس، <q>﴿كَأَنَّهُمْ حُمُرٌ مُسْتَنْفِرَةٌ فَرَّتْ مِن قَسْوَرَةٍ﴾</q>، قال: وحشيّة فرّتْ من رُماتها{14}. (١٥/٩١) ٧٩٩٤٧- عن عكرمة مولى ابن عباس -من طريق سِماك- في قوله: <q>﴿فَرَّتْ مِن قَسْوَرَةٍ﴾</q>، قال: القَسْورة: الرُّماة. فقال رجل لعكرمة: هو الأسد بلسان الحبشة. فقال عكرمة: اسم الأسد بلسان الحبشة: عَنبَسة{15}. (ز) ٧٩٩٤٨- عن أبي مالك غَزْوان الغفاري، قال: القَسْورة: الرُّماة{14}. (١٥/٩١) ٧٩٩٤٩- عن عطاء بن أبي رباح، مثله{17}. (١٥/٩١) ٧٩٩٥٠- عن أبي المُتوكِّل [الناجي] -من طريق إسماعيل بن مسلم العبدي - قال: <q>﴿فَرَّتْ مِن قَسْوَرَةٍ﴾</q> هي لغَط القوم، وأصواتهم{18}. (ز) ٧٩٩٥١- عن قتادة بن دعامة -من طريق معمر- قال: القَسْورة: النَّبْل{19}. (١٥/٩١) ٧٩٩٥٢- عن قتادة بن دعامة -من طريق سعيد- <q>﴿فَرَّتْ مِن قَسْوَرَةٍ﴾</q>: وهم الرُّماة القُنّاص{20}. (ز) ٧٩٩٥٣- عن ابن لَهِيعة: أنّ يزيد بن أبي حبيب سُئل عن قول الله: <q>﴿فَرَّتْ مِن قَسْوَرَةٍ﴾</q>. فزعم أنه يقال: هم الرُّماة{21}. (ز) ٧٩٩٥٤- قال زيد بن أسلم: أي: من رجال أقوياء، وكلّ ضخم شديد عند العرب: قَسْوَر، وقَسْوَرة{13}. (ز) ٧٩٩٥٥- عن زيد بن أسلم -من طريق داود بن قيس- في قول الله: <q>﴿فَرَّتْ مِن قَسْوَرَةٍ﴾</q>، قال: هو الأسد{23}. (ز) ٧٩٩٥٦- قال مقاتل بن سليمان: <q>﴿فَرَّتْ مِن قَسْوَرَةٍ﴾</q>، يعني: الرُّماة، وقالوا: الأسد{24}. (ز) ٧٩٩٥٧- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- قال في قوله: <q>﴿فَرَّتْ مِن قَسْوَرَةٍ﴾</q>، قال: القَسْورة: الأسد{6}٦٨٩١. (ز) ٦٨٩١ قال ابنُ تيمية (٦/٤٢٨): «و<q>﴿قسورة﴾</q> يُراد به: الرامي، ويُراد به: الأسد». ",footnotes:1:أخرجه سعيد بن منصور وابن أبي حاتم -كما في فتح الباري ٨/٦٧٦-، وابن جرير ٢٣/٤٥٥، والحاكم ٢/٥٠٨. وعزاه السيوطي إلى عَبد بن حُمَيد، وابن المنذر.أخرجه عَبد بن حُمَيد -كما في تغليق التعليق ٤/٣٥٢-، والبزار (٢٢٧٧-كشف)، وابن جرير ٢٣/٤٥٩-٤٦٠، من طريق زيد، عن ابن سيلان. وعزاه السيوطي إلى ابن المنذر.أخرجه عبد الله بن وهب في الجامع -تفسير القرآن ١/١٠ (١٦) من طريق عطاء، وابن جرير ٢٣/٤٥٥، ٤٥٧ من طريق سليم، وعطاء أيضًا بنحوه. وعزاه السيوطي إلى عَبد بن حُمَيد، وابن أبي حاتم.أخرجه ابن جرير ٢٣/٤٦٠ بنحوه. وعزاه السيوطي إلى ابن أبي حاتم.أخرجه سعيد بن منصور -كما في فتح الباري ٨/٦٧٦-، وابن جرير ٢٣/٤٥٨. وعزاه السيوطي إلى عَبد بن حُمَيد، وابن المنذر، وابن أبي حاتم.أخرجه ابن جرير ٢٣/٤٦٠.عزاه السيوطي إلى ابن المنذر.أخرجه سفيان بن عُيينة -كما في فتح الباري ٨/٦٧٦-، وعبد الرزاق ٢/٣٣٢، وابن جرير ٢٣/٤٥٨. وعزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ٢٣/٤٥٨.أخرجه ابن جرير ٢٣/٤٥٧. وعزاه السيوطي إلى عَبد بن حُمَيد.أخرجه ابن جرير ٢٣/٤٥٥-٤٥٦، وبنحوه من طريق ابن أبي نجيح. وعزاه السيوطي إلى عَبد بن حُمَيد.تفسير الثعلبي ١٠/٧٨، وتفسير البغوي ٨/٢٧٤.تفسير الثعلبي ١٠/٧٩، وتفسير البغوي ٨/٢٧٤.عزاه السيوطي إلى عَبد بن حُمَيد.أخرجه ابن جرير ٢٣/٤٥٦، وبنحوه من طريق أبي رجاء.عزاه السيوطي إلى عَبد بن حُمَيد.أخرجه الخطيب في تاريخه ٩/١٨٦.أخرجه الثعلبي ١٠/٧٩، وتفسير البغوي ٨/٢٧٤.أخرجه عبد الرزاق ٢/٣٣٢، وابن جرير ٢٣/٤٥٧. وعزاه السيوطي إلى عَبد بن حُمَيد.أخرجه ابن جرير ٢٣/٤٥٧.أخرجه عبد الله بن وهب في الجامع -تفسير القرآن ١/١١٣-١١٤ (٢٦٠).تفسير الثعلبي ١٠/٧٩، وتفسير البغوي ٨/٢٧٤.أخرجه ابن جرير ٢٣/٤٥٩-٤٦٠، ومن طريق هشام أيضًا.تفسير مقاتل بن سليمان ٤/٥٠٠.أخرجه ابن جرير ٢٣/٤٦٠.
74,52," <q>﴿بَلۡ یُرِیدُ كُلُّ ٱمۡرِئࣲ مِّنۡهُمۡ أَن یُؤۡتَىٰ صُحُفࣰا مُّنَشَّرَةࣰ ۝٥٢﴾</q> - نزول الآية، وتفسيرها ٧٩٩٥٨- عن عبد الله بن عباس -من طريق زاذان- يقول: <q>﴿بَلْ يُرِيدُ كُلُّ امْرِئٍ مِنهُمْ أنْ يُؤْتى صُحُفًا مُنَشَّرَةً﴾</q>، كان المشركون يقولون: لو كان محمد صادقًا فليُصبح عند كلِّ رأس رجل منّا صحيفةٌ فيها براءته وأَمْنه مِن النار{1}. (ز) ٧٩٩٥٩- عن مجاهد بن جبر -من طريق ابن أبي نجيح- <q>﴿بَلْ يُرِيدُ كُلُّ امْرِئٍ مِنهُمْ أنْ يُؤْتى صُحُفًا مُنَشَّرَةً﴾</q>، قال: إلى فلان بن فلان مِن ربّ العالمين؛ يُصبح عند رأس كلّ رجل صحيفة موضوعة يقرؤها{2}. (١٥/٩٢) ٧٩٩٦٠- عن أبي صالح باذام -من طريق السُّدِّيّ- قال: قالوا: إن كان محمد صادقًا فليُصبح تحت رأس كلّ رجل منّا صحيفة فيها براءةٌ وأمَنَةٌ من النار. فنَزلت: <q>﴿بَلْ يُرِيدُ كُلُّ امْرِئٍ مِنهُمْ أنْ يُؤْتى صُحُفًا مُنَشَّرَةً﴾</q>{3}. (١٥/٩٢) ٧٩٩٦١- عن قتادة بن دعامة -من طريق سعيد- <q>﴿بَلْ يُرِيدُ كُلُّ امْرِئٍ مِنهُمْ أنْ يُؤْتى صُحُفًا مُنَشَّرَةً﴾</q>، قال: قد قال قائلون من الناس: يا محمد، إن سرَّك أن نتّبعك فأتِنا بكتاب خاصة إلى فلان وفلان، نُؤمر فيه باتّباعك. قال قتادة: يريدون أن يُؤتوا براءة بغير عمل{4}٦٨٩٢. (ز) ٦٨٩٢ لم يذكر ابنُ جرير (٢٣/٤٦١) غير قول قتادة، ومجاهد. ٧٩٩٦٢- قال مطر الوراق: كانوا يريدون أن يؤتوا براءة من غير عمل{1}. (ز) ٧٩٩٦٣- قال محمد بن السّائِب الكلبي: إنّ المشركين قالوا: يا محمد، بلَغنا أنّ الرجل من بني إسرائيل يُصبح مكتوب عند رأسه ذَنبه وكفّارته؛ فأتِنا بمثل ذلك. فكَرهه رسول الله ﷺ، وأنزل الله سبحانه هذه الآية: <q>﴿بَلْ يُرِيدُ كُلُّ امْرِئٍ مِنهُمْ أنْ يُؤْتى صُحُفًا مُنَشَّرَةً﴾</q>{6}. (ز) ٧٩٩٦٤- قال مقاتل بن سليمان: <q>﴿بَلْ يُرِيدُ كُلُّ امْرِئٍ مِنهُمْ أنْ يُؤْتى﴾</q> يقول: يُعطى <q>﴿صُحُفًا مُنَشَّرَةً﴾</q> فيها كتاب من الله تعالى. وذلك أنّ كفار مكة قالوا للنبي ﷺ: كان الرجل مِن بني إسرائيل ذَنبه وكفّارة ذَنبه يُصبح مكتوبًا عند رأسه، فهلا تُرينا مثل هؤلاء الآيات إن كنت رسولًا كما تزعم. فقال جبريل: إن شئتَ فعلنا بهم كفِعْلنا ببني إسرائيل، وأَخذناهم بما أخذنا به بني إسرائيل. فكَره النبي ﷺ، وقالوا: ليُصبح عند رأس كلّ رجل منّا كتابٌ منشور مِن الله بأنّ آلهتنا باطل، وأنّ الإله الذي في السماء حقٌّ، وأنك رسول، وأنّ الذي جئت به حقٌّ، وتجيء معك بملائكة يَشهدون بذلك كقول ابن أبي أُمَيّة في سورة بني إسرائيل{7}. (ز) ",footnotes:1:تفسير الثعلبي ١٠/٧٩.أخرجه ابن جرير ٢٣/٤٦١ بنحوه. وعزاه السيوطي إلى عَبد بن حُمَيد، وابن المنذر.عزاه السيوطي إلى عَبد بن حُمَيد، وابن جرير، وابن المنذر.أخرجه ابن جرير ٢٣/٤٦١.تفسير الثعلبي ١٠/٧٩.تفسير الثعلبي ١٠/٧٩. وبنحوه في تفسير البغوي ٨/٢٧٥ دون ذكر النزول.تفسير مقاتل بن سليمان ٤/٥٠٠. وآخره يشير إلى الآيات ٩٠-٩٣ من سورة الإسراء وهي: <q>﴿وقالُوا لَنْ نُؤْمِنَ لَكَ حَتّى تَفْجُرَ لَنا مِنَ الأَرْضِ يَنْبُوعًا، أوْ تَكُونَ لَكَ جَنَّةٌ مِن نَخِيلٍ وعِنَبٍ فَتُفَجِّرَ الأَنْهارَ خِلالَها تَفْجِيرًا، أوْ تُسْقِطَ السَّماءَ كَما زَعَمْتَ عَلَيْنا كِسَفًا أوْ تَأْتِيَ بِاللَّهِ والمَلائِكَةِ قَبِيلًا، أوْ يَكُونَ لَكَ بَيْتٌ مِن زُخْرُفٍ أوْ تَرْقى فِي السَّماءِ ولَنْ نُؤْمِنَ لِرُقِيِّكَ حَتّى تُنَزِّلَ عَلَيْنا كِتابًا نَقْرَؤُهُ قُلْ سُبْحانَ رَبِّي هَلْ كُنْتُ إلّا بَشرًا رَسُولًا﴾</q> [الإسراء:٩٠-٩٣].
74,53," <q>﴿كَلَّاۖ بَل لَّا یَخَافُونَ ٱلۡـَٔاخِرَةَ ۝٥٣﴾</q> - تفسير ٧٩٩٦٥- عن الحسن البصري -من طريق أبي الأشهب- <q>﴿كَلّا بَلْ لا يَخافُونَ الآخِرَةَ﴾</q>، قال: هذا الذي فَضحهم{1}. (١٥/٩٣) ٧٩٩٦٦- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿كَلّا بَلْ لا يَخافُونَ الآخِرَةَ﴾</q>، قال: ذلك الذي تَضَحَّك بالقوم وأَفسدهم؛ أنهم كانوا لا يَخافون الآخرة، ولا يُصدِّقون بها{2}. (١٥/٩٢) ٧٩٩٦٧- قال مقاتل بن سليمان: <q>﴿كَلّا﴾</q> لا يؤمنون بالصُّحف التي أرادوها، ثم استأنف فقال: <q>﴿بَلْ﴾</q> لكن <q>﴿لا يَخافُونَ﴾</q> عذاب <q>﴿الآخِرَةَ﴾</q>{3}. (ز) ",footnotes:1:أخرجه ابن أبي شيبة ١٤/٣٣.أخرجه ابن جرير ٢٣/٤٦٢. وعزاه السيوطي إلى عَبد بن حُمَيد، وابن المنذر.تفسير مقاتل بن سليمان ٤/٥٠٠-٥٠١.
74,54," <q>﴿كَلَّاۤ إِنَّهُۥ تَذۡكِرَةࣱ ۝٥٤ فَمَن شَاۤءَ ذَكَرَهُۥ ۝٥٥﴾</q> - تفسير ٧٩٩٦٨- عن قتادة بن دعامة -من طريق سعيد- في قوله <q>﴿كَلّا إنَّهُ تَذْكِرَةٌ﴾</q>، قال: هذا القرآن{1}. (١٥/٩٢) ٧٩٩٦٩- قال مقاتل بن سليمان: <q>﴿كَلّا إنَّهُ تَذْكِرَةٌ﴾</q> يعني: القرآن <q>﴿فَمَن شاءَ ذَكَرَهُ﴾</q> يعني: فَهِمَهُ، يعني: القرآن{2}. (ز) ",footnotes:1:أخرجه ابن جرير ٢٣/٤٦٣. وعزاه السيوطي إلى عَبد بن حُمَيد، وابن المنذر.تفسير مقاتل بن سليمان ٤/٥٠١.
  74,55,""
74,56," <q>﴿وَمَا یَذۡكُرُونَ إِلَّاۤ أَن یَشَاۤءَ ٱللَّهُۚ هُوَ أَهۡلُ ٱلتَّقۡوَىٰ وَأَهۡلُ ٱلۡمَغۡفِرَةِ ۝٥٦﴾</q> - تفسير ٧٩٩٧٠- عن أنس، عن النبيِّ ﷺ، قرأ هذه الآية: <q>﴿هُوَ أهْلُ التَّقْوى وأَهْلُ المَغْفِرَةِ﴾</q>، فقال: «قد قال ربكم: أنا أهْلٌ أنْ أُتَّقى فلا يُجعل معي إلهًا، فمَن اتقاني فلم يَجعل معي إلهًا فأنا أهْلٌ أنْ أغفر له»{1}. (١٥/٩٣) ٧٩٩٧١- عن عبد الله بن دينار، قال: سمعتُ أبا هريرة، وابن عمر، وابن عباس، يقولون: سُئِل رسول الله ﷺ عن قول الله: <q>﴿هُوَ أهْلُ التَّقْوى وأَهْلُ المَغْفِرَةِ﴾</q>. قال: «يقول الله: أنا أهْلٌ أنْ أُتقى فلا يُجعل معي شريك، فإذا اتُّقِيتُ ولم يُجعل معي شريك فأنا أهْلٌ أنْ أغفر ما سوى ذلك»{2}. (١٥/٩٤) ٧٩٩٧٢- عن الحسن البصري، قال: قال رسول الله ﷺ: «قال الله: لأنا أكرم وأعظم عفوًا من أنْ أستر على عبد لي في الدنيا ثم أفضحه بعد أن سَترتُه، ولا أزال أغفر لعبدي ما استغفرني». قال رسول الله ﷺ: «يقول الله تعالى: إني لأجدني أستحي مِن عبدي، يَرفع يديه إلَيَّ، ثم أردّهما. قالت الملائكة: إلهنا، ليس لذلك بأهل. قال الله: لكني أهْلُ التقوى وأهْلُ المغفرة، أشهدكم أني قد غفرتُ له». قال رسول الله ﷺ: «ويقول الله: إني لأستحي مِن عبدي وأَمَتي يَشيبان في الإسلام، ثم أُعذّبهما بعد ذلك في النار»{3}. (١٥/٩٤) ٧٩٩٧٣- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿هُوَ أهْلُ التَّقْوى وأَهْلُ المَغْفِرَةِ﴾</q>، قال: إنّ ربّنا محقوقٌ أن تُتقى محارمه، وهو أهْلٌ أن يغفر الذّنوب الكثيرة لعباده{4}. (١٥/٩٢) ٧٩٩٧٤- قال مقاتل بن سليمان: <q>﴿وما يَذْكُرُونَ﴾</q> يعني: وما يهتدون <q>﴿إلّا أنْ يَشاءَ اللَّهُ هُوَ أهْلُ التَّقْوى وأَهْلُ المَغْفِرَةِ﴾</q> يعني: الرّبّ -تبارك وتعالى- نفسه، يقول: هو أهْلٌ أن يُتقى ولا يُعصى، وهو أهْلُ المغفرة لمن يتوب من المعاصي{5}. (ز) ٧٩٩٧٥- عن عبد القُدُّوس بن بكر، قال: سمعت ابن النضر الحارثي يذكر في قوله ﷿: <q>﴿هو أهل التقوى وأهل المغفرة﴾</q>، قال: أنا أهْلٌ لأن يَتقيني عبدي، فإن لم يَفعل كنتُ أهلًا لأنْ أغفر له{6}. (ز) ",footnotes:1:أخرجه أحمد ١٩/٤٣٠ (١٢٤٤٢)، ٢١/١٧٨ (١٣٥٤٩)، وابن ماجه ٥/٣٥٥ (٤٢٩٩)، والترمذي ٥/٥٢٢ (٣٦١٧)، والحاكم ٢/٥٥٢ (٣٨٧٦)، وابن أبي حاتم -كما في تفسير ابن كثير ٨/٢٧٤-، والثعلبي ١٠/٨٠، من طريق سُهيل، عن ثابت البُناني، عن أنس بن مالك به. قال الترمذي: «هذا حديث غريب، وسُهيل ليس بالقوي في الحديث، وقد تفرد سُهيل -بن عبد الله القطعي- بهذا الحديث عن ثابت». وقال الحاكم: «هذا حديث صحيح الإسناد، ولم يخرجاه». ووافقه الذهبي في التلخيص. وقال في سير أعلام النبلاء ٥/٢٢٣: «هذا حديث حسن غريب». وقال ابن القيسراني في ذخيرة الحفاظ ٢/٧٧٤ (١٤٧٩): «رواه سُهيل بن أبي حزم، عن ثابت، عن أنس. ولم يُتابع عليه، وفيه ضعف». وقال ابن الديبع في مكفرات الذنوب ص٨٩: «إسناد جيد».أخرجه ابن مردويه -كما في تخريج الكشاف ٤/١٢٢-، من طريق أحمد بن عبد الرحمن بن مفضل الحراني، عن يحيى بن ساج الحراني، عن سليم بن عبد الله الأحمر، عن عبد الله بن دينار به. وفي سنده يحيى بن ساج الحراني، وسليم بن عبد الله الأحمر، ولم أقف لهما على ترجمة.أخرجه الحكيم الترمذي في نوادر الأصول ٢/٣٤ مرسلًا.أخرجه ابن جرير ٢٣/٤٦٤، كما أخرجه عبد الرزاق ٢/٣٣٢ من طريق معمر بنحوه، ومثله ابن جرير ٢٣/٤٦٤. وعزاه السيوطي إلى عَبد بن حُمَيد، وابن المنذر.تفسير مقاتل بن سليمان ٤/٥٠١.أخرجه أحمد في الزهد ٤٤١.
75,1," مقدمة السورة ٧٩٩٧٦- عن عبد الله بن عباس -من طريق مجاهد- قال: نزلت سورةُ القيامة -وفي لفظ: نزلت سورة: <q>﴿لا أُقْسِمُ بِيَوْمِ القِيامَةِ﴾</q> بمكة{1}. (١٥/٩٥) ٧٩٩٧٧- عن عبد الله بن عباس -من طريق عطاء الخُراسانيّ-: مكّيّة، وذكرها بمسمى: <q>﴿لا أُقْسِمُ بِيَوْمِ القِيامَةِ﴾</q>، ونزلت بعد سورة القارعة{2}. (ز) ٧٩٩٧٨- عن عبد الله بن الزُّبير، قال: نزلت سورة: <q>﴿لا أُقْسِمُ﴾</q> بمكة{3}. (١٥/٩٥) ٧٩٩٧٩- عن عكرمة مولى ابن عباس= (ز) ٧٩٩٨٠- والحسن البصري -من طريق يزيد النحوي-: مكّيّة، وذكراها بمسمى: <q>﴿لا أُقْسِمُ بِيَوْمِ القِيامَةِ﴾</q>{4}. (ز) ٧٩٩٨١- عن قتادة بن دعامة -من طرق-: مكّيّة{5}. (ز) ٧٩٩٨٢- عن محمد بن مسلم الزُّهريّ: سورة <q>﴿لا أُقْسِمُ بِيَوْمِ القِيامَةِ﴾</q> مكّيّة، ونزلت بعد القارعة{6}. (ز) ٧٩٩٨٣- عن علي بن أبي طلحة: مكّيّة، وذكرها بمسمى: <q>﴿لا أُقْسِمُ بِيَوْمِ القِيامَةِ﴾</q>، ونزلت بعد سورة القارعة{7}. (ز) ٧٩٩٨٤- قال مقاتل بن سليمان: سورة القيامة مكّيّة، عددها أربعون آية كوفي{8}٦٨٩٣. (ز) ٦٨٩٣ ذكر ابنُ عطية (٨/٤٦٩) أنّ هذه السورة مكّيّة بإجماع من أهل التأويل. ٧٩٩٨٥- عن قتادة، قال: حُدِّثنا أنّ عمر بن الخطاب قال: مَن سأل عن يوم القيامة فليقرأ هذه السورة{9}. (١٥/٩٥) <q>﴿لَاۤ أُقۡسِمُ بِیَوۡمِ ٱلۡقِیَـٰمَةِ ۝١﴾</q> - قراءات ٧٩٩٨٦- عن الحسن البصري= (ز) ٧٩٩٨٧- والأعرج أنهما كانا يقرآن: ‹لَأُقْسِمُ بِيَوْمِ القِيامَةِ›{10}٦٨٩٤. (ز) ٦٨٩٤ اختُلف في قراءة قوله: <q>﴿لا أقسم بيوم القيامة﴾</q>؛ فقرأ قوم: <q>﴿لا أقسم﴾</q> <q>﴿لا﴾</q> مفصولة من <q>﴿أقسم﴾</q>. وقرأ آخرون: <q>﴿لأقسم بيوم القيامة﴾</q>. وذكر ابنُ جرير (٢٣/٤٦٥) أنّ القراءة الثانية بمعنى: أُقسِم بيوم القيامة، ثم أُدخلتْ عليها لام القَسم. وذكر ابنُ عطية (٨/٤٧٠) أنّ القراءة الثانية تحتمل أمرين: الأول: أن تكون اللام دَخلتْ على فعل الحال، والتقدير: لأنا أُقسِم، فلا تلحق النون؛ لأنّ النون إنما تَدخل في الأكثر لتفرق بين فعل الحال والفعل المستقبل، فهي تَلزم المستقبل في الأكثر. الثاني: أن يكون الفعل خالصًا للاستقبال، فكان الوجه والأكثر أن تَلحق النون، إمّا الخفيفة وإما الثقيلة، ثم قال: «لكن قد ذكر سيبويه أنّ النون قد تَسقط مع إرادة الاستقبال وتُغني اللام عنها، كما تَسقط اللام وتُغني النون عنها». ورجَّح ابنُ جرير القراءة الأولى مستندًا إلى إجماع القراء، فقال: «والقراءة التي لا أستجيز غيرها في هذا الموضع <q>﴿لا﴾</q> مفصولة، <q>﴿أقسم﴾</q> مُبتدأة، على ما عليه قرأة الأمصار؛ لإجماع الحُجّة من القُراء عليه». <q>﴿لَاۤ أُقۡسِمُ بِیَوۡمِ ٱلۡقِیَـٰمَةِ ۝١﴾</q> - تفسير الآية ٧٩٩٨٨- عن سعيد بن جُبَير، قال: سألتُ ابن عباس عن قوله: <q>﴿لا أُقْسِمُ بِيَوْمِ القِيامَةِ﴾</q>. قال: يُقسِم ربّك بما شاء من خَلْقه{11}. (١٥/٩٥) ٧٩٩٨٩- عن سعيد بن جُبَير -من طريق الحسن بن مسلم بن يَنّاق- في قوله: <q>﴿لا أُقْسِمُ بِيَوْمِ القِيامَةِ﴾</q>، يقول: أُقسِم{12}. (١٥/٩٥) ٧٩٩٩٠- عن الحسن البصري -من طريق قتادة- قال: أقسَم بيوم القيامة، ولم يُقسِم بالنفس اللوامة{13}. (ز) ٧٩٩٩١- عن قتادة بن دعامة، <q>﴿لا أُقْسِمُ بِيَوْمِ القِيامَةِ﴾</q>، قال: يُقسِم الله بما شاء من خَلْقه{11}. (١٥/٩٥) ٧٩٩٩٢- عن قتادة بن دعامة -من طريق سعيد- قولَه: <q>﴿لا أُقْسِمُ بِيَوْمِ القِيامَةِ ولا أُقْسِمُ بِالنَّفْسِ اللَّوّامَةِ﴾</q>، قال: أقسَم بهما جميعًا{15}. (ز) ٧٩٩٩٣- قال مقاتل بن سليمان: ما أقسَم الله بالكافرين في القرآن في غير هذه السورة، قوله تعالى: <q>﴿لا أُقْسِمُ بِيَوْمِ القِيامَةِ﴾</q> نظيرها: <q>﴿واليَوْمِ المَوْعُودِ﴾</q> [البروج:٢]. قال: وكان أهل الجاهلية إذا أراد الرجل أن يُقسِم قال: لا أُقسِم{16}. (ز) ٧٩٩٩٤- عن أبي بكر بن عيّاش -من طريق أبي هشام الرفاعي- يقول: قوله: <q>﴿لا أُقْسِمُ﴾</q> توكيد للقَسَم، كقوله: لا واللهِ{17}٦٨٩٥٦٨٩٦. (ز) ٦٨٩٥ اختُلف في <q>﴿لا﴾</q> المُبتدأ بها في قوله تعالى: <q>﴿لا أقسم بيوم القيامة﴾</q> على ثلاثة أقوال: الأول: أنها صلة، ومعنى الكلام: أُقسِم بيوم القيامة. الثاني: أنها دخلت توكيدًا للكلام. الثالث: أنها ردٌّ لكلام مضى من كلام المشركين في إنكار البعث، ثم ابتدأ القَسم فقال: أُقسِم بيوم القيامة. ونسبه ابنُ جرير (٢٣/٤٦٨) لبعض نحاة الكوفة. وذكر أنّ مَن قال بالقول الثالث كان يقول: كلّ يمين قبلها ردّ لكلام، فلابد من تقديم «لا» قبلها؛ ليُفرَّق بذلك بين اليمين التي تكون جحدًا، واليمين التي تستأنف، ويقول: ألا ترى أنك تقول مُبتدئًا: واللهِ، إنّ الرسول لحقّ. وإذا قلتَ: لا، واللهِ إنّ الرسول لحقّ. فكأنك أكذبتَ قومًا أنكروه. ورجَّحه مستندًا إلى اللغة، فقال: «لأنّ المعروف من كلام الناس في محاوراتهم إذا قال أحدهم: لا واللهِ، لا فعلتُ كذا، أنه يقصد بـ»لا«ردّ الكلام، وبقوله: واللهِ، ابتداء يمين، وكذلك قولهم: لا أُقسِم بالله لا فعلتُ كذا. فإذا كان المعروف من معنى ذلك ما وصفنا فالواجب أن يكون سائر ما جاء من نظائره جاريًا مجراه، ما لم يخرج شيء من ذلك عن المعروف بما يجب التسليم له». ٦٨٩٦ اختُلف هل قوله: <q>﴿ولا أقسم بالنفس باللوامة﴾</q> قَسَم أم لا؟ على قولين: الأول: أنه تعالى أقسَم بالنفس اللوامة كما أقسَم بيوم القيامة؛ فيكونان قسمين. الثاني: أنه أقسَم بيوم القيامة ولم يُقسِم بالنفس اللوامة، ويكون تقدير الكلام: أُقسِم بيوم القيامة، ولا أُقسِم بالنفس اللوامة. ورجَّح ابنُ جرير (٢٣/٤٦٨) -مستندًا إلى اللغة- القول الأول الذي قاله ابن عباس، وقتادة، وذلك أنّ «الجميع من الحُجّة مُجمِعون على أنّ قوله: <q>﴿لا أقسم بيوم القيامة﴾</q> قَسَم، فكذلك قوله: <q>﴿ولا أقسم بالنفس اللوامة﴾</q> إلا أن تأتي حُجّة تدل على أنّ أحدهما قَسَم والآخر خبر. وقد دللنا على أنّ قراءة مَن قرأ الحرف الأول»لأقسم«بوصل اللام بـ»أقسم«قراءة غير جائزة بخلافها ما عليه الحُجّة مُجمِعة». ورجَّحه ابنُ كثير (١٤/١٩٢)، فقال: «والصحيح أنه أقسَم بهما جميعًا». ولم يذكر مستندًا. وذكر ابنُ عطية (٨/٤٧١) أنّ الجمهور على هذا القول. وذكر ابنُ كثير أنّ قراءة الوصل «لأقسم» توجّه القول الثاني الذي قاله الحسن؛ لأنه أثبتَ القَسَم بيوم القيامة، ونفى القَسَم بالنفس اللوامة. وانتقد ابنُ عطية القول الثاني، فقال: «وذلك قلق، وهو في القراءة الثانية أمكن» أي: قراءة: «لأقسم» بالوصل. <q>﴿لَاۤ أُقۡسِمُ بِیَوۡمِ ٱلۡقِیَـٰمَةِ ۝١﴾</q> - آثار متعلقة بالآية ٧٩٩٩٥- عن المُغيرة بن شعبة -من طريق زياد بن عِلاقة- قال: يقولون: القيامة القيامة، وإنما قيامة أحدهم موته{18}. (ز) ٧٩٩٩٦- عن أبي قيس، قال: شهدتُ جنازة فيها عَلقمة، فلما دُفِن قال: أمّا هذا فقد قامتْ قيامته{19}٦٨٩٧. (ز) ٦٨٩٧ ساق ابنُ عطية (٨/٤٦٩) هذين الأثرين، ثم علَّق، بقوله: «وقيامة الرجل في خاصته ليست بالقيامة الجامعة لجميع الخَلْق بعد البعث. لكن المُغيرة ﵁ كأنه قال هذا لمن يستبعد قيام الآخرة، ويظن طول الأمد بينه وبينها، فتوعّده بقيامة نفسه». ",footnotes:1:أخرجه أبو جعفر النحاس في الناسخ والمنسوخ ص٧٥٧ من طريق أبي عمرو بن العلاء عن مجاهد، والبيهقي في دلائل النبوة ٧/١٤٢-١٤٤ من طريق خُصَيف عن مجاهد. وعزاه السيوطي إلى ابن مردويه.أخرجه ابن الضريس في فضائل القرآن ١/٣٣-٣٥.عزاه السيوطي إلى ابن مردويه.أخرجه البيهقي في دلائل النبوة ٧/١٤٢-١٤٣.أخرجه الحارث المحاسبي في فهم القرآن ص٣٩٥-٣٩٦ من طريق سعيد، وأبو بكر ابن الأنباري -كما في الإتقان ١/٥٧- من طريق همام.تنزيل القرآن ص٣٧-٤٢.أخرجه أبو عبيد في فضائله (ت: الخياطي) ٢/٢٠٠.تفسير مقاتل بن سليمان ٤/٥٠٧.عزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه ابن جرير ٢٣/٤٦٥. وهي قراءة متواترة، قرأ بها ابن كثير بخلف عن البزي، وقرأ بقية العشرة: <q>﴿لَآ أُقْسِمُ﴾</q> بألف بعد اللام، وهي الرواية الثانية عن البزي. انظر: ٢/٢٨٢، والإتحاف ص٥٦٣.أخرجه ابن جرير ٢٣/٤٦٧، والحاكم ٢/٥٠٨-٥٠٩. وعزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ٢٣/٤٦٦ بلفظ: أقسم بيوم القيامة. وعزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ٢٣/٤٦٧-٤٦٨.أخرجه ابن جرير ٢٣/٤٦٧، والحاكم ٢/٥٠٨-٥٠٩. وعزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ٢٣/٤٦٧.تفسير مقاتل بن سليمان ٤/٥٠٩.أخرجه ابن جرير ٢٣/٤٦٦.أخرجه ابن جرير ٢٣/٤٦٨.أخرجه ابن جرير ٢٣/٤٦٩.
75,2," <q>﴿وَلَاۤ أُقۡسِمُ بِٱلنَّفۡسِ ٱللَّوَّامَةِ ۝٢﴾</q> - تفسير ٧٩٩٩٧- عن عبد الله بن عباس -من طريق علي- في قوله: <q>﴿بِالنَّفْسِ اللَّوّامَةِ﴾</q>، قال: المذمومة{1}. (١٥/٩٦) ٧٩٩٩٨- عن عبد الله بن عباس، <q>﴿بِالنَّفْسِ اللَّوّامَةِ﴾</q>، قال: التي تلوم على الخير والشر، تقول: لو فعلتُ كذا وكذا{2}. (١٥/٩٦) ٧٩٩٩٩- عن عبد الله بن عباس، <q>﴿بِالنَّفْسِ اللَّوّامَةِ﴾</q>، قال: تَندم على ما فاتَ، وتلوم عليه{3}. (١٥/٩٦) ٨٠٠٠٠- عن سعيد بن جُبَير، قال: سألتُ ابن عباس عن: <q>﴿ولا أُقْسِمُ بِالنَّفْسِ اللَّوّامَةِ﴾</q>. قال: النفس اللؤوم{4}. (١٥/٩٥) ٨٠٠٠١- عن سعيد بن جُبَير -من طريق الحسن بن مسلم- في قوله: <q>﴿ولا أُقْسِمُ بِالنَّفْسِ اللَّوّامَةِ﴾</q>، قال: تلوم على الخير والشرِّ{5}٦٨٩٨. (ز) ٦٨٩٨ ذكر ابنُ عطية (٨/٤٧١) أنّ النفس في هذه الآية اسم جنس لنفوس البشر، ثم ساق قول ابن جُبَير، وبيّن أنه قال بأنها اسم جنس. ٨٠٠٠٢- عن مجاهد بن جبر -من طريق ابن أبي نجيح- <q>﴿بِالنَّفْسِ اللَّوّامَةِ﴾</q>، قال: تَندم على ما فاتَ، وتلوم عليه{6}. (١٥/٩٧) ٨٠٠٠٣- عن عكرمة مولى ابن عباس -من طريق سِماك- <q>﴿ولا أُقْسِمُ بِالنَّفْسِ اللَّوّامَةِ﴾</q>، قال: تلوم على الخير والشر{5}. (ز) ٨٠٠٠٤- عن الحسن البصري، <q>﴿ولا أُقْسِمُ بِالنَّفْسِ اللَّوّامَةِ﴾</q>، قال: إنّ المؤمن لا تراه إلا يلوم نفسه: ما أردتُ بكلمتي؟! ما أردتُ بأكلتي؟! ما أردتُ بحديثى نفسي؟! ولا أراه إلا يُعاتبها، وإنّ الفاجر يمضي قُدُمًا لا يُعاتب نفسه{8}٦٨٩٩. (١٥/٩٧) ٦٨٩٩ ذكر ابنُ عطية (٨/٤٧١) أنّ الحسن قال: النفس اللوامة هي اللوامة لصاحبها في ترْك الطاعة ونحوه. وعلَّق عليه بقوله: «فهي -على هذا- ممدوحة، ولذلك أقسَم الله تعالى بها». ٨٠٠٠٥- عن قتادة بن دعامة -من طريق سعيد- <q>﴿ولا أُقْسِمُ بِالنَّفْسِ اللَّوّامَةِ﴾</q>، قال: اللوامة: الفاجرة. قال: لم يُقسِم بها{9}٦٩٠٠. (١٥/٩٦) ٦٩٠٠ ساق ابنُ عطية (٨/٤٧١) هذا القول، ثم علَّق بقوله: «فهي [أي: النفس] -على هذا- ذميمة، وعلى هذا التأويل يَحسن نفي القَسَم بها». ٨٠٠٠٦- عن محمد بن كعب القُرَظيّ -من طريق سعيد-: ما من نفس يوم القيامة، صالحة ولا غيرها، إلا وهو يلوم نفسه، وهو قول الله: <q>﴿النَّفْسِ اللَّوّامَةِ﴾</q>{10}. (ز) ٨٠٠٠٧- قال مقاتل بن سليمان: <q>﴿ولا أُقْسِمُ بِالنَّفْسِ اللَّوّامَةِ﴾</q> يقول: أُقْسِمُ بالنفس الكافرة التي تلوم نفسها في الآخرة، فتقول: <q>﴿يا لَيْتَنِي قَدَّمْتُ لِحَياتِي﴾</q> [الفجر:٢٤]، <q>﴿يا حَسْرَتا عَلى ما فَرَّطْتُ فِي جَنْبِ اللَّهِ﴾</q> [الزمر:٥٦]. يعني: في أمْر الله في الدنيا{11}٦٩٠١. (ز) ٦٩٠١ في وصف النفس باللوامة قولان: الأول: أنها صفة مدح، وهو قول مَن جعلها قَسمًا. الثاني: أنها صفة ذم، وهو قول مَن نفى أن يكون قَسمًا. ومَن جعلها مدحًا له في تفسيرها قولان: الأول: أنها التي تلوم على الخير والشر. الثاني: أنها تلوم على ما فاتَ وتَندم. ومَن جعلها صفة ذم له في تفسيرها قولان: الأول: أنها الفاجرة. الثاني: المذمومة. ورأى ابنُ جرير (٢٣/٤٧٠) تقارب هذه الأقوال، فقال: «وهذه الأقوال التي ذكرناها عمن ذكرناها عنه، وإن اختلفتْ بها ألفاظ قائليها، فمتقاربات المعاني». ثم رجَّح (٢٣/٤٧٠-٤٧١) القول بأنها صفة مدح، وهو القول الذي قاله ابن عباس، وسعيد بن جُبَير، وعكرمة، ومجاهد-مستندًا إلى إجماع القُراء على قراءة الفصل التي تفيد القسم-، فقال: «وأشبه القول في ذلك بظاهر التنزيل أنها تلوم صاحبها على الخير والشر، وتَندم على ما فاتَ، والقُراء كلّهم مُجمِعون على قراءة هذه بفصل <q>﴿لا﴾</q> من <q>﴿أقسم﴾</q>». وذكر ابنُ عطية (٨/٤٧١) قولًا بأنّ المراد: نفس آدم؛ لأنها لم تزل اللائمة له على فِعْله الذي أخرجه من الجنة. ثم قال: «وكلّ نفس متوسطة ليستْ بالمطمئنة ولا بالأمارة بالسوء فإنها لوامة في الطرفين؛ مرة تلوم على ترْك الطاعة، ومرة تلوم على فَوْت ما تشتهي، فإذا اطمأنتْ خلصتْ وصَفتْ». ",footnotes:1:أخرجه ابن جرير ٢٣/٤٧٠. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.عزاه السيوطي إلى عبد بن حميد، وابن المنذر.عزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ٢٣/٤٦٩، والحاكم ٢/٥٠٨-٥٠٩. وعزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ٢٣/٤٦٩.أخرجه ابن جرير ٢٣/٤٧٠. وعزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ٢٣/٤٦٩.ذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٥/٦٣-. وعزاه السيوطي إلى ابن أبي الدنيا في محاسبة النفس، وعبد بن حميد.أخرجه ابن جرير ٢٣/٤٧٠ مقتصرًا على قوله: «أي: الفاجرة»، والحاكم ٢/٥٠٨-٥٠٩. وعزاه السيوطي إلى ابن المنذر.أخرجه عبد الله بن وهب في الجامع -تفسير القرآن ٢/٩١-٩٢ (١٧٢).تفسير مقاتل بن سليمان ٤/٥٠٩.
75,3," <q>﴿أَیَحۡسَبُ ٱلۡإِنسَـٰنُ أَلَّن نَّجۡمَعَ عِظَامَهُۥ ۝٣﴾</q> - نزول الآية ٨٠٠٠٨- قال مقاتل بن سليمان: <q>﴿أيَحْسَبُ﴾</q> هذا الإنسان، يعني: عَدِيّ بن ربيعة بن أبي سَلمة خَتن الأَخْنس بن شَريق، وكان حليفًا لبني زهرة، فكَفر بالبعْث، وذلك أنه أتى رسول الله ﷺ، فقال: يا محمد، حدِّثني عن يوم القيامة متى يكون؟ وكيف أمرها وحالها؟ فأَخبَره النبيُّ ﷺ بذلك. فقال: لو عاينتُ ذلك اليوم سأومن بك. ثم قال: يا محمد، أوَيجمع الله العظامَ يوم القيامة؟ قال: «نعم». فاستهزأ منه؛ فأَنزَل الله -جلّ وعزّ-: <q>﴿لا أُقْسِمُ بِيَوْمِ القِيامَةِ ولا أُقْسِمُ بِالنَّفْسِ اللَّوّامَةِ أيَحْسَبُ الإنْسانُ ألَّنْ نَجْمَعَ عِظامَهُ﴾</q>{1}. (ز) <q>﴿أَیَحۡسَبُ ٱلۡإِنسَـٰنُ أَلَّن نَّجۡمَعَ عِظَامَهُۥ ۝٣﴾</q> - تفسير الآية ٨٠٠٠٩- قال مقاتل بن سليمان: <q>﴿أيَحْسَبُ الإنْسانُ ألَّنْ نَجْمَعَ عِظامَهُ﴾</q>، يقول: أن لن نَبعثه من بعد الموت، فأَقسَم الله تعالى أن يَبعثه كما كان{2}. (ز) ",footnotes:1:تفسير مقاتل بن سليمان ٤/٥٠٩-٥١٠.تفسير مقاتل بن سليمان ٤/٥١٠.
75,4," <q>﴿بَلَىٰ قَـٰدِرِینَ عَلَىٰۤ أَن نُّسَوِّیَ بَنَانَهُۥ ۝٤﴾</q> - نزول الآية ٨٠٠١٠- قال مقاتل بن سليمان: نزلت هذه الآية في عَدِيّ بن ربيعة، والأَخْنس بن شَريق{1}. (ز) <q>﴿بَلَىٰ قَـٰدِرِینَ عَلَىٰۤ أَن نُّسَوِّیَ بَنَانَهُۥ ۝٤﴾</q> - تفسير الآية ٨٠٠١١- عن عبد الله بن عباس -من طريق حُصَين- <q>﴿بَلى قادِرِينَ عَلى أنْ نُسَوِّيَ بَنانَهُ﴾</q>، قال: نَجعلها كفًّا ليس فيه أصابع{2}. (١٥/٩٧) ٨٠٠١٢- عن عبد الله بن عباس -من طريق مجاهد- <q>﴿بَلى قادِرِينَ عَلى أنْ نُسَوِّيَ بَنانَهُ﴾</q>، قال: نَجعله مثل خُفّ البعير{3}. (١٥/٩٧) ٨٠٠١٣- عن عبد الله بن عباس -من طريق عطية العَوفيّ- <q>﴿بَلى قادِرِينَ عَلى أنْ نُسَوِّيَ بَنانَهُ﴾</q>، قال: أنا قادر على أنْ أجعل كفَّه مُجَمَّرةً مثل خُفّ البعير{4}. (ز) ٨٠٠١٤- عن سعيد بن جُبَير، قال: سألتُ ابنَ عباس عن قوله: <q>﴿أيَحْسَبُ الإنْسانُ ألَّنْ نَجْمَعَ عِظامَهُ بَلى قادِرِينَ عَلى أنْ نُسَوِّيَ بَنانَهُ﴾</q>. قال: لو شاء لَجَعله خُفًّا أو حافرًا{5}. (١٥/٩٥) ٨٠٠١٥- عن مجاهد بن جبر -من طريق ابن أبي نجيح- <q>﴿عَلى أنْ نُسَوِّيَ بَنانَهُ﴾</q>، قال: يَجعل رِجليه كخُفّ البعير؛ فلا يَعمل بها شيئًا{6}. (١٥/٩٨) ٨٠٠١٦- عن عكرمة مولى ابن عباس -من طريق النَّضر- <q>﴿عَلى أنْ نُسَوِّيَ بَنانَهُ﴾</q>، قال: إن شاء ردّه مثل خُفّ البعير حتى لا يَنتفع به{7}. (١٥/٩٨) ٨٠٠١٧- عن الضَّحّاك بن مُزاحِم -من طريق عبيد- <q>﴿عَلى أنْ نُسَوِّيَ بَنانَهُ﴾</q>، قال: البنان: الأصابع. يقول: نحن قادرون على أن نَجعل بَنانه مثل خُفّ البعير{8}. (١٥/٩٨) ٨٠٠١٨- عن الحسن البصري -من طريق أبي رجاء- أنه قرأ هذه الآية: <q>﴿بَلى قادِرِينَ عَلى أنْ نُسَوِّيَ بَنانَهُ﴾</q>، فقال: إنّ الله أعفَّ مَطعم ابن آدم، ولم يَجعله خُفًّا ولا حافرًا، فهو يأكل بيديه، ويتّقي بها، وسائر الدواب إنما يتّقي الأرض بفَمِه{9}. (١٥/٩٨) ٨٠٠١٩- عن قتادة بن دعامة -من طريق معمر- <q>﴿بَلى قادِرِينَ عَلى أنْ نُسَوِّيَ بَنانَهُ﴾</q>، قال: لو شاء لجَعله كخُفّ البعير أو كحافر الدابة، ولكن جَعله الله خَلْقًا سَويًّا حسنًا جميلًا، تَقبض به وتَبسط به، يا ابن آدمَ{10}. (١٥/٩٧) ٨٠٠٢٠- قال محمد بن كعب القُرَظيّ -من طريق أبي صخر- <q>﴿بَلى قادِرِينَ عَلى أنْ نُسَوِّيَ بَنانَهُ﴾</q>، قال: لو شاء لَجَعله خنزيرًا حمارًا{11}. (ز) ٨٠٠٢١- عن غَيلان بن جرير، عن أصحابه، في قوله: <q>﴿بلى قادرين على أن نسوي بنانه﴾</q>، قال: قادرين على أن نَجعلها مثل رُبعٍ{12}. (ز) ٨٠٠٢٢- قال مقاتل بن سليمان: <q>﴿بَلى قادِرِينَ﴾</q> كُنّا قادرين <q>﴿عَلى أنْ نُسَوِّيَ بَنانَهُ﴾</q> أصابعه، يعني: على أن نُلحق الأصابع بالراحة، ونُسويّه حتى نَجعله مثل خُفّ البعير، فلا يَنتفع بها كما لا يَنتفع البعير بها ما كان حيًّا{1}٦٩٠٢. (ز) ٦٩٠٢ ذكر ابنُ عطية (٨/٤٧٢) أنّ المعنى: أنّ الكفار لمّا استبعدوا جمْع العظام بعد الفناء والإرمام، قيل لهم: إنما تُجمع ويُسوّى أكثرها تفرقًا وأدقّها أجزاء، وهي عظام الأنامل ومفاصلها، وهذا كلّه عند البعث. وبنحوه قال ابنُ القيم (٣/٢٢٦). ثم ساق ابنُ عطية هذا القول بأنّ المراد: جعل بَنان الإنسان في هذه الحياة بُضعة أو عظمًا واحدًا كخُفّ البعير لا تفاريق فيه. وعلَّق عليه بقوله: «فكأن المعنى: قادرين الآن في الدنيا على أن نَجعلها دون تفرّق، فتقِلّ منفعته بيده، فكأن التقدير: بلى نحن أهلٌ أن نجمعها، قادرين الآن على إزالة منفعته بيده، ففي هذا توعّد ما». وعلَّق ابنُ القيم (٣/٢٢٦) على هذا القول بقوله: «والمعنى على هذا القول: إنّا في الدنيا قادرون على أن نَجعل عظام بَنانه مجموعة دون تفرّق، فكيف لا نقدر على جمْعها بعد تفريقها، فهذا وجه من الاستدلال غير الأول، وهو الاستدلال بقدرته سبحانه على جمْع العظام بعد تفريقها». ورجح ابنُ عطية -مستندًا إلى السياق- أنّ المراد بالجمع في الآخرة، فقال: «والقول الأول أجرى مع رصف الكلام». ثم قال: «ولكن على هذا القول الآخر [أي:تسوية البنان في الدنيا] جمهور العلماء». وعلَّق ابنُ القيم (٣/٢٢٧) على القولين بقوله: «وهما وجهان حسنان، وكلّ منهما له ترجيح من وجه؛ فيرجّح الأول أنه هو المقصود، وهو الذي أنكره الكفار، وهو إجراء على نسق الكلام واطراده، ولأنّ الكلام لم يُسَق لجمْع العظام وتفريقها في الدنيا، وإنما سيق لجمْعها في الآخرة بعد تفرّقها بالموت. ويرجّح القول الثاني -ولعله قول جمهور المفسرين-، حتى إنّ فيهم من لم يذكر غيره، وأنه استدلال بآية ظاهرة مشهورة، وهي تفريق البنان مع انتظامها في كفّ واحد وارتباط بعضها ببعض فهي متفرّقة في عضو واحد، يَقبض منها واحدة ويَبسط أخرى ويُحرّك واحدة والأخرى ساكنة، ويَعمل بواحدة والأخرى مُعطّلة، وكلّها في كفّ واحد، قد جمَعها ساعد واحد، فلو شاء سبحانه لسَوّاها فجعلها صفة واحدة كباطن الكفّ، ففاتَه هذه المنافع والمصالح التي حَصلتْ بتفريقها، ففي هذا أعظم الأدلة على قدرته سبحانه على جمْع عظامه بعد الموت». ",footnotes:1:تفسير مقاتل بن سليمان ٤/٥١٠.أخرجه سعيد بن منصور في سننه -التفسير ٨/٢١٥ (٢٣٤٨).أخرجه عبد الرزاق ٢/٣٣٣، وابن جرير ٢٣/٤٧٢ بنحوه من طريق سعيد. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.أخرجه ابن جرير ٢٣/٤٧١.أخرجه ابن جرير ٢٣/٤٧١، والحاكم ٢/٥٠٨-٥٠٩. وعزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ٢٣/٤٧٢. وعزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ٢٣/٤٧٢ بنحوه. وعزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ٢٣/٤٧٣. وعزاه السيوطي إلى ابن المنذر بلفظ: على أن نَجعل يديه ورجليه مثل خُفّ البعير.أخرجه ابن جرير ٢٣/٤٧٢ بنحوه. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه عبد الرزاق ٢/٣٣٣، وابن جرير ٢٣/٤٧٣، كذلك من طريق سعيد. وعزاه السيوطي إلى عبد بن حميد.أخرجه عبد الله بن وهب في الجامع -تفسير القرآن ٢/١٤٧ (٢٩٧).أخرجه سعيد بن منصور في سننه -التفسير ٨/٢١٥ (٢٣٤٧). قال محققه: «كذا في الأصل، لكن وضع ضمة على الباء». والظاهر أنّ المراد: نجعلها مثل يد الرُبَع أو قدمه، والربع هو ولد الناقة في أول النتاج، ولا أصابع له، ويؤيده رواية ابن عباس السابقة: «كفًّا ليس فيه أصابع».تفسير مقاتل بن سليمان ٤/٥١٠.
75,5," <q>﴿بَلۡ یُرِیدُ ٱلۡإِنسَـٰنُ لِیَفۡجُرَ أَمَامَهُۥ ۝٥﴾</q> - تفسير ٨٠٠٢٣- عن عبد الله بن عباس -من طريق أبي الخير بن تميم، عن سعيد بن جُبَير- في قوله: <q>﴿بَلْ يُرِيدُ الإنْسانُ لِيَفْجُرَ أمامَهُ﴾</q>، قال: يمضي قُدُمًا{1}. (١٥/٩٨) ٨٠٠٢٤- عن عبد الله بن عباس -من طريق سعيد بن جُبَير- في قوله: <q>﴿بَلْ يُرِيدُ الإنْسانُ لِيَفْجُرَ أمامَهُ﴾</q>، قال: يقول: سوف أتوب{2}. (١٥/١٠٠) ٨٠٠٢٥- عن عبد الله بن عباس -من طريق سعيد بن جُبَير- <q>﴿بَلْ يُرِيدُ الإنْسانُ لِيَفْجُرَ أمامَهُ﴾</q>، قال: يُقدِّم الذَّنب، ويُؤخِّر التوبة{3}. (١٥/٩٩) ٨٠٠٢٦- عن عبد الله بن عباس -من طريق علي- في قوله: <q>﴿بَلْ يُرِيدُ الإنْسانُ لِيَفْجُرَ أمامَهُ﴾</q>، قال: هو الكافر يُكذّب بالحساب{4}. (١٥/٩٨) ٨٠٠٢٧- عن عبد الله بن عباس -من طريق عطية العَوفيّ- <q>﴿بَلْ يُرِيدُ الإنْسانُ لِيَفْجُرَ أمامَهُ﴾</q>: يعني: الأمل، يقول: أعمل ثم أتوب{5}. (١٥/٩٩) ٨٠٠٢٨- عن سعيد بن جُبَير -من طريق أبي إسحاق- <q>﴿لِيَفْجُرَ أمامَهُ﴾</q>، قال: سوف أتوب{6}. (ز) ٨٠٠٢٩- عن مجاهد بن جبر -من طريق ابن أبي نجيح- <q>﴿بَلْ يُرِيدُ الإنْسانُ لِيَفْجُرَ أمامَهُ﴾</q>، قال: يمضي أمامه راكبًا رأسه{7}. (١٥/٩٩) ٨٠٠٣٠- عن الضَّحّاك بن مُزاحِم -من طريق عبيد- يقول في قوله: <q>﴿بَلْ يُرِيدُ الإنْسانُ لِيَفْجُرَ أمامَهُ﴾</q>: هو الأمل؛ يُؤّمل الإنسان: أعيش وأُصيب من الدنيا كذا، وأُصيب كذا. ولا يَذكر الموت{6}. (ز) ٨٠٠٣١- عن عكرمة مولى ابن عباس -من طريق النَّضر- <q>﴿بَلْ يُرِيدُ الإنْسانُ لِيَفْجُرَ أمامَهُ﴾</q>، قال: قُدمًا لا يَنزع عن فُجور{6}. (ز) ٨٠٠٣٢- عن الحسن البصري -من طريق معمر- <q>﴿بَلْ يُرِيدُ الإنْسانُ لِيَفْجُرَ أمامَهُ﴾</q>، قال: يمضي قُدُمًا في معاصي الله{10}. (١٥/٩٩) ٨٠٠٣٣- عن الحسن البصري -من طريق قتادة- <q>﴿بَلْ يُرِيدُ الإنْسانُ لِيَفْجُرَ أمامَهُ﴾</q>، قال: لا تَلقى ابن آدم إلا تَنزع نفسه إلى معصية الله قُدُمًا قُدُمًا، إلا مَن قد عَصَم الله{1}. (ز) ٨٠٠٣٤- عن قتادة بن دعامة -من طريق سعيد- <q>﴿بَلْ يُرِيدُ الإنْسانُ لِيَفْجُرَ أمامَهُ﴾</q>، قال: لا تَلقى ابن آدم إلا تَنزع نفسه إلى معصية الله قُدُمًا قُدُمًا، إلا مَن عَصَم الله{12}. (١٥/٩٩) ٨٠٠٣٥- عن إسماعيل السُّدِّيّ -من طريق عمرو- <q>﴿بَلْ يُرِيدُ الإنْسانُ لِيَفْجُرَ أمامَهُ﴾</q>، قال: قُدُمًا{6}. (ز) ٨٠٠٣٦- عن إسماعيل السُّدِّيّ: <q>﴿بَلْ يُرِيدُ الإنْسانُ لِيَفْجُرَ أمامَهُ﴾</q>، يعني: لِيَظلم على قدر طاقته{14}٦٩٠٣. (ز) ٦٩٠٣ ذكر ابنُ عطية (٨/٤٧٢) أنّ الضمير في قوله: <q>﴿أمامه﴾</q> عائد على الإنسان على هذا القول الذي قاله ابن عباس من طريق أبي الخير، وابن جُبَير، والعَوفيّ، وقاله مجاهد، والحسن، وعكرمة، وابن جُبَير، والضَّحّاك، والسُّدِّيّ. ٨٠٠٣٧- قال مقاتل بن سليمان: <q>﴿بَلْ يُرِيدُ الإنْسانُ﴾</q> يعني: عديّ بن ربيعة <q>﴿لِيَفْجُرَ أمامَهُ﴾</q> يعني: تقديم المعصية وتأخير التوبة يومًا بيوم، يقول: سأتوب، حتى يموت على شرّ عَمَله، وقد أهلك أمامه{15}. (ز) ٨٠٠٣٨- قال عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿بَلْ يُرِيدُ الإنْسانُ لِيَفْجُرَ أمامَهُ﴾</q>، قال: يُكذّب بما أمامه يوم القيامة والحساب{16}٦٩٠٤. (ز) ٦٩٠٤ اختُلف في المراد بقوله: <q>﴿بل يريد الإنسان ليفجر أمامه﴾</q> على أقوال: الأول: معناه: أن يُعجِّل الذَّنب، ويُسوّف التوبة. الثاني: بل يريد أن يرتكب الآثام في الدنيا لقوة أمله، ولا يذكر الموت. الثالث: بل يريد الإنسان ليَكفر بالحقّ الذي بين يدي القيامة. الرابع: بل يريد الإنسان الكافر أن يُكذّب بالقيامة. ورجَّح ابنُ القيم (٣/٢٢٧-٢٢٨) -مستندًا إلى السياق، واللغة- القول الأخير الذي قاله ابن عباس من طريق علي، وقاله ابن زيد، فقال: «ويُرجّح هذا القول لفظة <q>﴿بلى﴾</q>؛ فإنها تُعطي أنّ الإنسان لم يؤمن بيوم القيامة، مع هذا البيان والحُجّة، بل هو مريد للتكذيب به، ويُرجّحه أيضًا أنّ السياق كلّه في ذم المُكذّب بيوم القيامة، لا في ذم العاصي والفاجر، وأيضًا فإنّ ما قبل الآية وما بعدها يدل على المراد. فإنه قال: <q>﴿أيَحْسَبُ الأِنْسانُ ألَّنْ نَجْمَعَ عِظامَهُ بَلى قادِرِينَ عَلى أنْ نُسَوِّيَ بَنانَهُ﴾</q> فأنكر -سبحانه- عليه حِسْبانه أنّ الله لا يَجمع عظامه، ثم قَرّر قدرته على ذلك، ثم أنكر عليه إرادة التكذيب بيوم القيامة. فالأول حِسبانٌ منه أن لا يُحييه بعد موته. والثاني: تكذيب منه بيوم البعث، وأنه يريد أن يُكذّب بما وضح وبان دليل وقوعه وثبوته؛ فهو مريد للتكذيب به. ثم أخبر عن تصريحه بالتكذيب، فقال: <q>﴿يَسْأَلُ أيّانَ يَوْمُ القِيامَةِ﴾</q>، فالأول إرادة التكذيب، والثاني نطق بالتكذيب وتكلم به». وبنحوه ابنُ كثير (١٤/١٩٤)، فقال: «وهذا هو الأظهر من المراد؛ ولهذا قال بعده: <q>﴿يسأل أيان يوم القيامة﴾</q> أي: يقول متى يكون يوم القيامة؟! وإنما سؤاله سؤال استبعاد لوقوعه، وتكذيب لوجوده، كما قال تعالى: <q>﴿ويقولون متى هذا الوعد إن كنتم صادقين قل لكم ميعاد يوم لا تستأخرون عنه ساعة ولا تستقدمون﴾</q> [سبأ:٢٩-٣٠]». وذكر ابنُ جرير (٢٣/٤٧٧) أنّ الضمير في قوله: <q>﴿أمامه﴾</q> على القول الثالث الذي قاله ابن عباس عائد على «يوم القيامة». وبنحوه قال ابنُ عطية (٨/٤٧٢)، ثم بيّن أنّ المعنى -على هذا القول-: «أنّ الإنسان هو في زمان وجوده أمام يوم القيامة وبين يديه، ويوم القيامة خلفه، فهو يريد شهواته ليَفْجُر في تكذيبه بالبعْث، وغير ذلك بين يدي يوم القيامة، وهو لا يعرف قدر الضرر الذي هو فيه». ",footnotes:1:أخرجه ابن جرير ٢٣/٤٧٥.أخرجه آدم بن أبي إياس -كما في تفسير مجاهد ص٦٨٦-، والفريابي -كما في التغليق ٤/٣٥٥-، وابن جرير ٢٣/٤٧٧-٤٧٨ في تفسير الآية التالية، والحاكم ٢/٥٠٩، والبيهقي (٧٢٣٢). وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.أخرجه ابن أبي الدنيا (٢٠٥)، والبيهقي (١٠٦٧٣).أخرجه ابن جرير ٢٣/٤٧٧ بنحوه، وابن أبي حاتم -كما في فتح الباري ٨/٦٨١-.أخرجه ابن جرير ٢٣/٤٧٥. وعلقه البخاري في صحيحه ٦/١٦٣.أخرجه ابن جرير ٢٣/٤٧٦.أخرجه ابن جرير ٢٣/٤٧٥. وعزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ٢٣/٤٧٦.أخرجه ابن جرير ٢٣/٤٧٦.أخرجه عبد الرزاق ٢/٣٣٣، وابن جرير ٢٣/٤٧٥-٤٧٦ بنحوه. وعزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ٢٣/٤٧٥.أخرجه ابن جرير ٢٣/٤٧٥-٤٧٦. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه ابن جرير ٢٣/٤٧٦.تفسير الثعلبي ١٠/٨٣.تفسير مقاتل بن سليمان ٤/٥١٠.أخرجه ابن جرير ٢٣/٤٧٧.
75,6," <q>﴿یَسۡـَٔلُ أَیَّانَ یَوۡمُ ٱلۡقِیَـٰمَةِ ۝٦﴾</q> - تفسير ٨٠٠٣٩- عن عبد الله بن عباس -من طريق سعيد بن جُبَير- في قوله: <q>﴿يَسْأَلُ أيّانَ يَوْمُ القِيامَةِ﴾</q> قال: يقول: متى يوم القيامة. قال: فبَيّن له؛ <q>﴿فَإذا بَرِقَ البَصَرُ﴾</q> [القيامة: ٧]{1}. (١٥/١٠٠) ٨٠٠٤٠- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿يَسْأَلُ أيّانَ يَوْمُ القِيامَةِ﴾</q> يقول: متى يوم القيامة؟! قال: وقال عمر بن الخطاب ﵁: مَن سأل عن يوم القيامة فليقرأ هذه السورة{2}. (١٥/٩٥، ٩٩) ٨٠٠٤١- قال مقاتل بن سليمان: <q>﴿يَسْأَلُ أيّانَ يَوْمُ القِيامَةِ﴾</q> يعني: يسأل عَدِيّ: متى يوم القيامة؟! تكذيبًا بها{3}. (ز) ٨٠٠٤٢- قال عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿يَسْأَلُ أيّانَ يَوْمُ القِيامَةِ﴾</q> متى يكون ذلك. فقرأ: <q>﴿وجُمِعَ الشَّمْسُ والقَمَرُ﴾</q> [القيامة:٩]، قال: فكذلك يكون يوم القيامة{4}. (ز) ",footnotes:1:أخرجه آدم بن أبي إياس -كما في تفسير مجاهد ص٦٨٦-، والفريابي -كما في التغليق ٤/٣٥٥-، وابن جرير ٢٣/٤٧٧-٤٧٨، والحاكم ٢/٥٠٩، والبيهقي (٧٢٣٢). وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.أخرجه ابن جرير ٢٣/٤٧٨. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.تفسير مقاتل بن سليمان ٤/٥١٠.أخرجه ابن جرير ٢٣/٤٧٨.
75,7," <q>﴿فَإِذَا بَرِقَ ٱلۡبَصَرُ ۝٧﴾</q> - قراءات ٨٠٠٤٣- عن هارون، قال: سألتُ أبا عمرو بن العلاء عنها، فقال: <q>﴿بَرِقَ﴾</q> -بالكسر- بمعنى: حار.= (ز) ٨٠٠٤٤- قال: وسألتُ عنها عبد الله ابن أبي إسحاق، فقال: ‹بَرَقَ› بالفتح. وقال: إنما بَرِق الحَنظل اليابس، وما بَرِق البصر؟! قال: فذكرتُ ذلك لأبي عمرو فقال: إنما يَبرُقُ الحَنظل والنار والبَرْق، وأما البصر فبَرِق عند الموت. قال: فأَخبرتُ بذلك أبا إسحاق، فقال: أخذتُ قراءتي عن الأشياخ؛ نصر بن عاصم وأصحابه. فذكرتُ ذلك لأبي عمرو، فقال: لكني لا آخذ عن نصر ولا عن أصحابه. كأنه يقول: آخذ عن أهل الحجاز{1}٦٩٠٥. (ز) ٦٩٠٥ اختُلف في قراءة قوله: <q>﴿برق﴾</q>؛ فقرأ قوم: ‹بَرَقَ› بفتح الراء. وقرا آخرون بكسرها. وذكر ابنُ جرير (٢٣/٤٧٨) أنّ معنى قراءة الفتح: شَخص، وفَتح عند الموت. وأنّ معنى قراءة الكسر: فَزع وشقّ. وبنحوه قال ابنُ عطية (٨/٤٧٣). وذكر ابنُ كثير (١٤/١٩٤) أنّ ما قاله أبو عمرو بن العلاء شبيه بقوله تعالى: <q>﴿لا يرتد إليهم طرفهم﴾</q> [إبراهيم:٤٣]، بل ينظرون من الفزع هكذا وهكذا، لا يَستقرّ لهم بصرٌ على شيء؛ من شدة الرُّعب. ورجَّح ابنُ جرير (٢٣/٤٧٩) قراءة الكسر مستندًا إلى اللغة، فقال: «وأولى القراءتين في ذلك عندنا بالصواب كسر الراء <q>﴿فإذا برق﴾</q>، بمعنى: فزعِ فشُقّ وفُتح من هول القيامة وفزَع الموت، وبذلك جاءت أشعار العرب». وذكر ابنُ عطية (٨/٤٧٣) أنّ المعنى متقارب في القراءتين. وبنحوه قال ابنُ كثير (١٤/١٩٤). <q>﴿فَإِذَا بَرِقَ ٱلۡبَصَرُ ۝٧﴾</q> - تفسير الآية ٨٠٠٤٥- عن عبد الله بن عباس -من طريق عطية العَوفيّ- في قوله: <q>﴿فَإذا بَرِقَ البَصَرُ﴾</q>: يعني: الموت{2}. (١٥/١٠٠) ٨٠٠٤٦- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿فَإذا بَرِقَ البَصَرُ﴾</q>، قال: عند الموت{3}. (١٥/١٠٠) ٨٠٠٤٧- قال الحسن البصري: <q>﴿فَإذا بَرِقَ البَصَرُ﴾</q>، يعني: يوم القيامة{4}. (ز) ٨٠٠٤٨- عن قتادة بن دعامة -من طريق سعيد- <q>﴿فَإذا بَرِقَ البَصَرُ﴾</q>، قال: شَخَص البصر{5}. (١٥/١٠٠) ٨٠٠٤٩- قال قتادة: شَخَص البصر، فلا يَطرِفُ مما يَرى من العجائب مما كان يُكذّب به في الدنيا أنه غير كائن{6}. (ز) ٨٠٠٥٠- قال محمد بن السّائِب الكلبي: <q>﴿فَإذا بَرِقَ البَصَرُ﴾</q> عند رؤية جهنم بَرق أبصار الكفار{7}. (ز) ٨٠٠٥١- قال مقاتل بن سليمان: <q>﴿فَإذا بَرِقَ البَصَرُ﴾</q> إذا شَخَص البصر، فلا يَطرِفُ مما يَرى من العجائب التي يراها مما كان يَكفر بها في الدنيا أنّه غير كائن، مثلها في سورة: <q>﴿ق والقُرْآنِ المَجِيد﴾</q>{8}. (ز) ",footnotes:1:أخرجه ابن جرير ٢٣/٤٧٨. و‹بَرَقَ›، و<q>﴿بَرِقَ﴾</q> قراءتان متواترتان، قرأ بالأولى منها نافع، وأبو جعفر، وقرأ بقية العشرة بالثانية. انظر: النشر ٢/٣٩٣، والإتحاف ص٥٦٣.أخرجه ابن جرير ٢٣/٤٨٠.أخرجه ابن جرير ٢٣/٤٨٠. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.ذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٥/٦٤-. وقال عقبه: أي: شَخَص لإجابة الداعي، كقوله: <q>﴿لا يَرْتَدُّ إلَيْهِمْ طَرْفُهُمْ﴾</q> [إبراهيم:٤٣].أخرجه عبد الرزاق ٢/٣٣٣، وابن جرير ٢٣/٤٨٠. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.تفسير الثعلبي ١٠/٨٤.تفسير البغوي ٨/٢٨١.تفسير مقاتل بن سليمان ٤/٥١٠. وفي تفسير الثعلبي ١٠/٨٤ نحوه منسوبًا إلى مقاتل دون تعيينه.
75,8," <q>﴿وَخَسَفَ ٱلۡقَمَرُ ۝٨﴾</q> - تفسير ٨٠٠٥٢- عن الحسن البصري -من طريق قتادة- <q>﴿وخَسَفَ القَمَرُ﴾</q>: هو ضوءه، يقول: ذَهب ضوءه{1}. (ز) ٨٠٠٥٣- عن قتادة بن دعامة -من طريق سعيد- <q>﴿وخَسَفَ القَمَرُ﴾</q>، يقول: وذَهب ضَوْءُ القمر؛ فلا ضوء له{2}. (١٥/١٠٠) ٨٠٠٥٤- قال مقاتل بن سليمان: <q>﴿وخَسَفَ القَمَرُ﴾</q> فذَهب ضوءه{3}. (ز) ",footnotes:1:أخرجه ابن جرير ٢٣/٤٨١.أخرجه ابن جرير ٢٣/٤٨١، كما أخرج عبد الرزاق ٢/٣٣٣ نحوه من طريق معمر. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.تفسير مقاتل بن سليمان ٤/٥١٠.
75,9," <q>﴿وَجُمِعَ ٱلشَّمۡسُ وَٱلۡقَمَرُ ۝٩﴾</q> - تفسير ٨٠٠٥٥- قال علي بن أبي طالب= (ز) ٨٠٠٥٦- وعبد الله بن عباس: <q>﴿وجُمِعَ الشَّمْسُ والقَمَرُ﴾</q> يُجعلان في نور الحُجُب{1}. (ز) ٨٠٠٥٧- عن عطاء بن يَسار -من طريق زيد بن أسلم- في قوله: <q>﴿وجُمِعَ الشَّمْسُ والقَمَرُ﴾</q>، قال: يُجمعان يوم القيامة، ثم يُقذفان في البحر، فيكون نار الله الكُبرى{2}. (١٥/١٠١) ٨٠٠٥٨- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿وخَسَفَ القَمَرُ وجُمِعَ الشَّمْسُ والقَمَرُ﴾</q>، قال: كُوِّرا يوم القيامة{3}. (١٥/١٠٠) ٨٠٠٥٩- قال الحسن البصري: <q>﴿وجُمِعَ الشَّمْسُ والقَمَرُ﴾</q>، أي: جَمَعهما جميعًا{4}. (ز) ٨٠٠٦٠- قال مقاتل بن سليمان: <q>﴿وجُمِعَ الشَّمْسُ والقَمَرُ﴾</q> كالبَقَرتَيْن المقْرُونَتَيْن يوم القيامة قِيامًا بين يدي الخلائق{5}. (ز) ٨٠٠٦١- عن عبد الملك ابن جُرَيْج، في قوله: <q>﴿وجُمِعَ الشَّمْسُ والقَمَرُ﴾</q>، قال: كُوِّرا يوم القيامة{6}. (١٥/١٠١) ٨٠٠٦٢- قال عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿وجُمِعَ الشَّمْسُ والقَمَرُ﴾</q>، قال: جُمعا، فرُمي بهما في الأرض. وقوله: <q>﴿إذا الشَّمْسُ كُوِّرَتْ﴾</q> [التكوير:١]، قال: كُوِّرت في الأرض والقمر معها{7}. (ز) ",footnotes:1:تفسير الثعلبي ١٠/٨٤.أخرجه ابن جرير ٢٣/٤٨٢. وعزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ٢٣/٤٨٢. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.ذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٥/٦٤-.تفسير مقاتل بن سليمان ٤/٥١٠.عزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ٢٣/٤٨٢.
75,10," <q>﴿یَقُولُ ٱلۡإِنسَـٰنُ یَوۡمَىِٕذٍ أَیۡنَ ٱلۡمَفَرُّ ۝١٠﴾</q> - قراءات ٨٠٠٦٣- عن عبد الله بن خالد، قال: قرأها ابن عباس: (أيْنَ المَفِرُّ) بنصب الميم وكسر الفاء.= (ز) ٨٠٠٦٤- قال: وقرأها يحيى بن وثّاب: <q>﴿أيْنَ المَفَرُّ﴾</q> بنصب الميم والفاء{1}٦٩٠٦. (١٥/١٠١) ٦٩٠٦ اختُلف في قراءة قوله: <q>﴿المفر﴾</q>؛ فقرأ قوم: <q>﴿المفَر﴾</q>. وقرأ آخرون: (المَفِرُّ). وذكر ابنُ عطية (٨/٤٧٤) أنّ قراءة الفتح على المصدر، أي: أين الفرار. وأنّ قراءة الكسر على معنى: أين موضع الفرار. وبنحوه قال ابنُ جرير (٢٣/٤٨٢-٤٨٤). ورجَّح ابنُ جرير (٢٣/٤٨٤) قراءة الفتح مستندًا إلى إجماع القُراء، والأشهر في اللغة، فقال: «لإجماع الحُجّة من القُراء عليها، وأنها اللغة المعروفة في العرب إذا أُريد بها الفرار، وهو في هذا الموضع: الفرار». <q>﴿یَقُولُ ٱلۡإِنسَـٰنُ یَوۡمَىِٕذٍ أَیۡنَ ٱلۡمَفَرُّ ۝١٠﴾</q> - تفسير الآية ٨٠٠٦٥- عن الأوزاعي، قال: سمعتُ بلال بن سعد يقول في قوله تعالى: <q>﴿ولو ترى إذ فزعوا فلا فوت﴾</q> [سبأ:٥١]. قال: ذلك قوله تعالى: <q>﴿يقول الإنسان يومئذ أين المفر﴾</q>{2}. (ز) ٨٠٠٦٦- قال مقاتل بن سليمان: <q>﴿يَقُولُ الإنْسانُ يَوْمَئِذٍ أيْنَ المَفَرُّ﴾</q>، يعني: أين المَهْرب حتى أُحْرِزَ{3} نفسي{4}. (ز) ",footnotes:1:عزاه السيوطي إلى أبي عبيد، وعبد بن حميد، وابن المنذر. و<q>﴿المَفَرُّ﴾</q> بفتح الميم ونصب الفاء قراءة العشرة، وأما (المَفِرُّ) بكسر الفاء فهي قراءة شاذة، تروى أيضًا عن الحسين بن علي، والحسن بن يزيد، والزهري. انظر: المحتسب ٢/٤١٣، ومختصر ابن خالويه ص١٦٦.أخرجه أبو نعيم في حلية الأولياء ٥/٢٢٧.أُحْرِز نفسي: أحفظها. النهاية (حرز).تفسير مقاتل بن سليمان ٤/٥١١.
75,11," <q>﴿كَلَّا لَا وَزَرَ ۝١١﴾</q> - تفسير ٨٠٠٦٧- عن عبد الله بن مسعود، في قوله: <q>﴿لا وزَرَ﴾</q>، قال: لا حِصْن{1}. (١٥/١٠٢) ٨٠٠٦٨- عن عبد الله بن عباس -من طريق علي- في قوله: <q>﴿لا وزَرَ﴾</q>، قال: لا حِرْز{2}. (١٥/١٠١) ٨٠٠٦٩- عن عبد الله بن عباس -من طريق عطية- في قوله: <q>﴿لا وزَرَ﴾</q>، قال: لا حِصْن، ولا مَلْجأ. وفي لفظ: لا جَبل{2}. (١٥/١٠١) ٨٠٠٧٠- عن عبد الله بن عباس: أنّ نافع بن الأزرق قال له: أخبِرني عن قوله: <q>﴿لا وزَرَ﴾</q>. قال: الوَزَرُ: المَلْجأُ. قال: وهل تعرف العرب ذلك؟ قال: نعم، أما سمعتَ عمرو بن كُلثوم وهو يقول{4}: لعَمْرك ما إن له صُحرةٌ{5} لعَمْرك ما إن له من وزَر{6}. (١٥/١٠١) ٨٠٠٧١- عن مُطَرِّف [بن عبد الله] بن الشِّخِّير -من طريق أدهم- <q>﴿لا وزَرَ﴾</q>، قال: لا جَبل{7}. (١٥/١٠٣) ٨٠٠٧٢- عن سعيد بن جُبَير -من طريق مولى للحسن- <q>﴿لا وزَرَ﴾</q>: لا حِصْن{8}. (١٥/١٠٢) ٨٠٠٧٣- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿لا وزَرَ﴾</q>، قال: لا جَبل{9}. (١٥/١٠٢) ٨٠٠٧٤- عن الضَّحّاك بن مُزاحِم، <q>﴿لا وزَرَ﴾</q>، قال: لا جَبل يُحرِزُهُ{10}. (١٥/١٠٣) ٨٠٠٧٥- عن الضَّحّاك بن مُزاحِم -من طريق عبيد- في قوله: <q>﴿لا وزَرَ﴾</q>، قال: يعني: الجَبل، بلغة حِمْيَر{11}. (١٥/١٠٣) ٨٠٠٧٦- عن الضَّحّاك بن مُزاحِم -من طريق أبي حُجَير- في قوله: <q>﴿لا وزَرَ﴾</q>: لا حِصْن{11}. (ز) ٨٠٠٧٧- عن عكرمة مولى ابن عباس-من طريق سعيد بن مسروق- في قوله: <q>﴿كلا لا وزر﴾</q>، قال: لا مَلْجأ، ولا مَنعًا{13}. (ز) ٨٠٠٧٨- عن أبي قلابة عبد الله بن زيد الجرمي، <q>﴿لا وزَرَ﴾</q>، قال: لا غار، لا مَلْجأ{14}. (١٥/١٠٢) ٨٠٠٧٩- عن أبي قِلابة عبد الله بن زيد الجرمي -من طريق شَبيب- في قوله: <q>﴿كَلّا لا وزَرَ﴾</q>، قال: لا حِصْن{15}. (١٥/١٠٢) ٨٠٠٨٠- عن الحسن البصري، في قوله: <q>﴿كَلّا لا وزَرَ﴾</q>، قال: كانت العرب إذا نزل بهم الأمر الشديد قالوا: الوَزَر الوَزَر. فلمّا أنْ جاء الله بالإسلام قال: <q>﴿كَلّا لا وزَرَ﴾</q>، قال: لا جَبل{16}. (١٥/١٠٢) ٨٠٠٨١- عن الحسن البصري -من طريق أبي رجاء- قال: كان الرجل يكون في ماشيته، فتَأتيه الخيل بَغْتة، فيقول له صاحبه: الوَزَر الوَزَر. أي: اقصِد الجبل؛ فتَحصّنْ به{17}. (١٥/١٠٢) ٨٠٠٨٢- عن عطية بن سعد العَوفيّ: لا حِصْن{10}. (١٥/١٠٢) ٨٠٠٨٣- عن قتادة بن دعامة -من طريق مسلم بن طهمان- في قوله: <q>﴿لا وزَرَ﴾</q>، يقول: لا حِصْن{19}. (ز) ٨٠٠٨٤- عن قتادة بن دعامة، قال: <q>﴿لا وزَرَ﴾</q>، قال: لا جَبل، ولا حِرْز، ولا مَلْجأ، ولا مَنجى{20}. (١٥/١٠٣) ٨٠٠٨٥- قال إسماعيل السُّدِّيّ: <q>﴿لا وزَرَ﴾</q> لا جَبل. وكانوا إذا فَزعوا لجؤوا إلى الجبل، فتَحصّنوا به، فقال الله تعالى: لا جَبل يومئذ يَمنعهم{21}. (ز) ٨٠٠٨٦- قال مقاتل بن سليمان: <q>﴿كَلّا لا وزَرَ﴾</q> يعني: لا جَبل يُحرِزُك، ويُسمّي حِمْيَرُ الجبل: وزَر{22}. (ز) ٨٠٠٨٧- قال عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿كَلّا لا وزَرَ﴾</q>، قال: لا مُتغيَّبَ يَتغيَّبُ فيه من ذلك الأمْر الذي لا مَنجى له منه{11}٦٩٠٧. (ز) ٦٩٠٧ ذكر ابنُ عطية (٨/٤٧٤) أنّ المفسرين عبّروا عن الوَزَر بالجبل، ونَقل عن مُطَرِّف بن الشِّخِّير وغيره أنهم قالوا: «كان وزَر فِرار العرب في بلادهم، فلذلك استُعمل». ثم رجَّح أنه المَلْجأ أيًّا كان، فقال: «والحقيقة أنه المَلْجأ؛ جبلًا كان أو حِصنًا أو سلاحًا أو رجلًا أو غيره». ولم يذكر مستندًا. ",footnotes:1:أخرجه ابن أبي حاتم -كما في فتح الباري ٨/٦٨١-. وعزاه السيوطي إلى ابن أبي الدنيا في الأهوال، وعبد بن حميد، وابن المنذر.أخرجه ابن جرير ٢٣/٤٨٤. وعزاه السيوطي إلى ابن أبي الدنيا في الأهوال، وعبد بن حميد، وابن المنذر، وابن أبي حاتم.أخرجه ابن جرير ٢٣/٤٨٤. وعزاه السيوطي إلى ابن أبي الدنيا في الأهوال، وعبد بن حميد، وابن المنذر، وابن أبي حاتم.البيت في مصدر التخريج وسيرة ابن هشام ١/٣٩، ٤٠ لابن الذئبة الثقفي، واسمه ربيعة بن عبد ليل بن سالم.أصحر المكان: اتسع. القاموس المحيط (صحر).عزاه السيوطي إلى الطستي، وهو في مسائل نافع (٤٣).أخرجه ابن جرير ٢٣/٤٨٥. وعزاه السيوطي إلى عبد بن حميد. وزاد ابن جرير في رواية: إنّ الناس إذا فَرُّوا قالوا عليك بالوَزَر.أخرجه ابن جرير ٢٣/٤٨٧. وعزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ٢٣/٤٨٦ بلفظ: لا مَلْجأ ولا جَبل. وعزاه السيوطي إلى عبد بن حميد.عزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ٢٣/٤٨٧.أخرجه ابن جرير ٢٣/٤٨٧.أخرجه سعيد بن منصور في سننه -التفسير ٨/٢١٧ (٢٣٥٠).عزاه السيوطي إلى عبد بن حميد، وابن جرير.أخرجه ابن جرير ٢٣/٤٨٦. وعزاه السيوطي إلى عبد بن حميد.عزاه السيوطي إلى عبد بن حميد. وأخرج آخره ابن جرير ٢٣/٤٨٥ من طريق قتادة، وأبي مودود.أخرجه ابن جرير ٢٣/٤٨٥-٤٨٦ بنحوه. وعزاه السيوطي إلى ابن المنذر.عزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ٢٣/٤٨٦.عزاه السيوطي إلى عبد بن حميد. وأخرجه عبد الرزاق ٢/٣٣٣ من طريق معمر بلفظ: لا جَبل، ومثله ابن جرير ٢٣/٤٨.تفسير الثعلبي ١٠/٨٥، وتفسير البغوي ٨/٢٨٢.تفسير مقاتل بن سليمان ٤/٥١١.أخرجه ابن جرير ٢٣/٤٨٧.
75,12," <q>﴿إِلَىٰ رَبِّكَ یَوۡمَىِٕذٍ ٱلۡمُسۡتَقَرُّ ۝١٢﴾</q> - تفسير ٨٠٠٨٨- قال عبد الله بن مسعود: <q>﴿إلى رَبِّكَ يَوْمَئِذٍ المُسْتَقَرُّ﴾</q> المصير والمرجع{1}. (ز) ٨٠٠٨٩- عن قتادة بن دعامة -من طريق سعيد- قال: <q>﴿إلى رَبِّكَ يَوْمَئِذٍ المُسْتَقَرُّ﴾</q>، قال: المُنتهى{2}. (١٥/١٠٣) ٨٠٠٩٠- قال إسماعيل السُّدِّيّ: <q>﴿إلى رَبِّكَ يَوْمَئِذٍ المُسْتَقَرُّ﴾</q> المُنتهى{1}. (ز) ٨٠٠٩١- قال مقاتل بن سليمان: <q>﴿إلى رَبِّكَ يَوْمَئِذٍ المُسْتَقَرُّ﴾</q>، يعني: المُنتهى يومئذ إلى الله ﷿، لا تَجد عنه مرحلًا{4}. (ز) ٨٠٠٩٢- قال عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿إلى رَبِّكَ يَوْمَئِذٍ المُسْتَقَرُّ﴾</q>، قال: استَقرّ أهل الجنة في الجنة، وأهل النار في النار. وقرأ قول الله: <q>﴿وإنَّ الدّارَ الآخِرَةَ لَهِيَ الحَيَوانُ لَوْ كانُوا يَعْلَمُونَ﴾</q> [العنكبوت:٦٤]{5}. (ز) ",footnotes:1:تفسير البغوي ٨/٢٨٢.أخرجه ابن جرير ٢٣/٤٨٨. وعزاه السيوطي إلى عبد بن حميد.تفسير البغوي ٨/٢٨٢.تفسير مقاتل بن سليمان ٤/٥١١.أخرجه ابن جرير ٢٣/٤٨٨.
75,13," <q>﴿یُنَبَّؤُا۟ ٱلۡإِنسَـٰنُ یَوۡمَىِٕذِۭ بِمَا قَدَّمَ وَأَخَّرَ ۝١٣﴾</q> - تفسير ٨٠٠٩٣- عن عبد الله بن مسعود -من طريق زياد بن أبي مريم- في قوله: <q>﴿يُنَبَّأُ الإنْسانُ يَوْمَئِذٍ بِما قَدَّمَ وأَخَّرَ﴾</q>، قال: بما قَدّم من عمله، وما أخَّر مِن سُنَّةٍ عُمِل بها مِن بعده؛ مِن خير أو شرٍّ{1}. (١٥/١٠٤) ٨٠٠٩٤- عن عبد الله بن عباس -من طريق علي- <q>﴿يُنَبَّأُ الإنْسانُ يَوْمَئِذٍ بِما قَدَّمَ وأَخَّرَ﴾</q>، قال: بما عَمِل قبل موته، وما سَنَّ فعُمِل به بعد موته{2}. (١٥/١٠٤) ٨٠٠٩٥- عن عبد الله بن عباس -من طريق عطية العَوفيّ- في قوله: <q>﴿يُنَبَّأُ الإنْسانُ يَوْمَئِذٍ بِما قَدَّمَ وأَخَّرَ﴾</q>، يقول: بما قَدّم مِن المعصية، وأَخَّر من الطاعة، فيُنبّأ بذلك{3}. (١٥/١٠٤) ٨٠٠٩٦- عن إبراهيم النَّخَعي= (ز) ٨٠٠٩٧- ومجاهد بن جبر -من طريق منصور- <q>﴿يُنَبَّأُ الإنْسانُ يَوْمَئِذٍ بِما قَدَّمَ وأَخَّرَ﴾</q>، قالا: بأول عَمَله وآخره{4}. (١٥/١٠٣) ٨٠٠٩٨- عن مجاهد بن جبر، قال: بلّغنا: أنّ نفس المؤمن لا تَخرج حتى يُعرض عليه عَمَله؛ خيره وشرّه{5}. (١٥/١٠٥) ٨٠٠٩٩- عن عكرمة مولى ابن عباس، في الآية، قال: بما قَدّم مِن الذّنوب والشر والخطايا، وما أخَّر من الخير{6}. (١٥/١٠٣) ٨٠١٠٠- عن الحسن البصري، في قوله: <q>﴿يُنَبَّأُ الإنْسانُ يَوْمَئِذٍ بِما قَدَّمَ وأَخَّرَ﴾</q>، قال: يُنزِّل مَلَك الموت عليه عند الموت حَفظته، فيُعرَض عليه الخير والشر، فإذا رأى حسنة بَهَش{7} وأَشرق، وإذا رأى سيئة غَضَّ وقَطَّب{8}. (١٥/١٠٤) ٨٠١٠١- قال عطاء: <q>﴿يُنَبَّأُ الإنْسانُ يَوْمَئِذٍ بِما قَدَّمَ وأَخَّرَ﴾</q> بما قَدّم في أول عُمره، وما أخَّر في آخر عُمره{9}. (ز) ٨٠١٠٢- عن أبي صالح باذام، في قوله: <q>﴿يُنَبَّأُ الإنْسانُ يَوْمَئِذٍ بِما قَدَّمَ وأَخَّرَ﴾</q>، قال: قَدّم مِن حسنة، أو أخَّر من سُنَّة حسنة عُمِل بها بعده؛ عِلمًا عَلّمه، صدقة أمَر بها{10}. (١٥/١٠٤) ٨٠١٠٣- عن قتادة بن دعامة -من طريق معمر- قال: <q>﴿يُنَبَّأُ الإنْسانُ يَوْمَئِذٍ بِما قَدَّمَ﴾</q> قال: مِن طاعة الله، <q>﴿وأَخَّرَ﴾</q> قال: وما ضيَّع من حقّ الله{11}. (١٥/١٠٣) ٨٠١٠٤- قال زيد بن أسلم: <q>﴿يُنَبَّأُ الإنْسانُ يَوْمَئِذٍ بِما قَدَّمَ وأَخَّرَ﴾</q> بما قَدّم من أمواله لنفسه، وما أخَّر خَلفه للورثة{9}. (ز) ٨٠١٠٥- قال مقاتل بن سليمان: <q>﴿يُنَبَّأُ الإنْسانُ يَوْمَئِذٍ بِما قَدَّمَ﴾</q> لآخرته، <q>﴿وأَخَّرَ﴾</q> مِن خير أو شرٍّ بعد موته في دنياه، فاستَنّ بها قومٌ بعده{13}. (ز) ٨٠١٠٦- قال عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿يُنَبَّأُ الإنْسانُ يَوْمَئِذٍ بِما قَدَّمَ وأَخَّرَ﴾</q>، قال: ما أخَّر: ما تَرك مِن العمل لم يَعمله؛ ما تَرك من طاعة الله لم يَعمل به، وما قَدّم: ما عَمِل من خير أو شرّ{14}٦٩٠٨. (ز) ٦٩٠٨ اختُلف في المراد بقوله: <q>﴿بما قدم وأخر﴾</q> على أقوال: الأول: ما قَدّم قبل موته، وما سَنّ فعُمِل به بعد موته. الثاني: ما قَدّم من معصية، وأَخَّر من طاعة. الثالث: بأول عَمَله، وآخره. الرابع: بما قَدّم من الطاعة، وأَخَّر من حقوق الله التي ضَيّعها. الخامس: ما قَدّم من خير أو شرّ مما عَمِله، وما أخَّر مما تَرك عَمَله من طاعة الله ﷿. ورجَّح ابنُ جرير (٢٣/٤٩١) العموم، فقال: «والصواب من القول في ذلك عندنا أنّ ذلك خبر من الله أنّ الإنسان يُنبّأ بكل ما قَدّم أمامه مما عَمِل من خير أو شرّ في حياته، وأَخَّر بعده من سُنّة حسنة أو سيئة مما قَدّم وأَخَّر، كذلك ما قَدّم من عَملٍ عَمِله من خير أو شرّ، وأَخَّر بعده من عَملٍ كان عليه فضَيّعه، فلم يعمله مما قَدّم وأَخَّر، ولم يخصص الله من ذلك بعضًا دون بعض، فكلّ ذلك مما يُنبّأ به الإنسان يوم القيامة». وذكر ابنُ عطية (٨/٤٧٤-٤٧٥) أنّ قوله تعالى: <q>﴿بما قدم وأخر﴾</q> قِسمة تستوفي كلّ عمل، أي: يُعلم بكل ما فعل ويجده مُحصلًا، ثم ساق الأقوال. ",footnotes:1:أخرجه عبد الرزاق ٢/٣٣٤، وابن جرير ٢٣/٤٨٩ بنحوه. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه ابن جرير ٢٣/٤٨٩. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.أخرجه ابن جرير ٢٣/٤٨٩.أخرجه ابن أبي شيبة ١٣/٥٥٢، وابن جرير ٢٣/٤٩٠. وعزاه السيوطي إلى عبد بن حميد.عزاه السيوطي إلى ابن أبي الدنيا.عزاه السيوطي إلى عبد بن حميد.يقال للإنسان إذا نظر إلى الشيء فأعجبه واشتهاه وأسرع نحوه: قد بَهَشَ إليه. النهاية (بهش).عزاه السيوطي إلى ابن أبي الدنيا في كتاب المحتضرين.تفسير الثعلبي ١٠/٨٥، وتفسير البغوي ٨/٢٨٣.عزاه السيوطي إلى ابن المنذر.أخرجه عبد الرزاق ٢/٣٣٣، وابن جرير ٢٣/٤٩٠، كذا من طريق سعيد أيضًا. وعزاه السيوطي إلى عبد بن حميد.تفسير الثعلبي ١٠/٨٥، وتفسير البغوي ٨/٢٨٣.تفسير مقاتل بن سليمان ٤/٥١١.أخرجه ابن جرير ٢٣/٤٩١.
75,14," <q>﴿بَلِ ٱلۡإِنسَـٰنُ عَلَىٰ نَفۡسِهِۦ بَصِیرَةࣱ ۝١٤﴾</q> - تفسير ٨٠١٠٧- عن عبد الله بن عباس -من طريق عطية العَوفيّ- <q>﴿بَلِ الإنْسانُ عَلى نَفْسِهِ بَصِيرَةٌ﴾</q>، قال: الإنسان شهيد على نفسه وحده{1}. (١٥/١٠٥) ٨٠١٠٨- عن سعيد بن جُبَير -من طريق موسى بن أبي عائشة-، مثله{2}. (١٥/١٠٥) ٨٠١٠٩- عن عبد الله بن عباس -من طريق علي- <q>﴿بَلِ الإنْسانُ عَلى نَفْسِهِ بَصِيرَةٌ﴾</q>، قال: سمْعه، وبصره، ويديه، ورجليه، وجوارحه{3}٦٩٠٩. (١٥/١٠٦) ٦٩٠٩ ساق ابنُ جرير (٢٣/٤٩٢) هذا القول، ثم علَّق بقوله: «والبصيرة -على هذا التأويل- ما ذكره ابن عباس مِن جوارح ابن آدم، وهي مرفوعة بقوله: <q>﴿على نفسه﴾</q>، والإنسان مرفوع بالعائد مِن ذكره في قوله: <q>﴿نفسه﴾</q>». ٨٠١١٠- قال أبو العالية الرِّياحيّ= (ز) ٨٠١١١- وعطاء: <q>﴿بَلِ الإنْسانُ عَلى نَفْسِهِ بَصِيرَةٌ﴾</q> بل الإنسان على نفسه شاهد{4}. (ز) ٨٠١١٢- قال عكرمة مولى ابن عباس= (ز) ٨٠١١٣- ومحمد بن السّائِب الكلبي: <q>﴿بَلِ الإنْسانُ عَلى نَفْسِهِ بَصِيرَةٌ﴾</q> معناه: بل الإنسان على نفسه مِن نفسه رُقباء يَرْقُبونه ويَشهدون عليه بعمله، وهي سمْعه وبصره وجوارحه{4}. (ز) ٨٠١١٤- عن عمران بن جُبَير، قال: قلتُ لعكرمة: <q>﴿بَلِ الإنْسانُ عَلى نَفْسِهِ بَصِيرَةٌ ولَوْ ألْقى مَعاذِيرَهُ﴾</q> فسكَتَ، وكان يَسْتاك، فقلتُ: إنّ الحسن قال: يا ابن آدم، عملك أحَقُّ بك. قال: صَدقتَ{6}. (١٥/١٠٦) ٨٠١١٥- عن قتادة بن دعامة -من طريق معمر- في قوله: <q>﴿بَلِ الإنْسانُ عَلى نَفْسِهِ بَصِيرَةٌ﴾</q>، قال: شاهدٌ عليها بعملها{7}. (١٥/١٠٥) ٨٠١١٦- عن قتادة بن دعامة -من طريق سعيد- <q>﴿بَلِ الإنْسانُ عَلى نَفْسِهِ بَصِيرَةٌ﴾</q>، قال: إذا شئتَ رأيتَه بصيرًا بعيوب الناس، غافلًا عن عَيْبه. قال: وكان يُقال: في الإنجيل مكتوب: يا ابن آدم، أتُبصر القَذاة في عين أخيك، ولا تُبصر الجِذْل{8} المُعتَرِض في عينك؟{9}. (١٥/١٠٦) ٨٠١١٧- قال مقاتل بن سليمان: يقول الله تعالى: <q>﴿بَلِ الإنْسانُ عَلى نَفْسِهِ بَصِيرَةٌ﴾</q> وذلك حين كُتمت الأَلسُن في سورة الأنعام، وخَتم الله عليها في سورة <q>﴿يس والقُرْآنِ الحَكِيمِ﴾</q>، فقال: <q>﴿اليَوْمَ نَخْتِمُ عَلى أفْواهِهِمْ﴾</q> [يس:٦٥]. فنَطقت الجوارح، وشَهدت على الأَلسُن بالشِّرك في هذه السورة، فلا شاهد أفضل من نفسك، فذلك قوله -تبارك وتعالى-: <q>﴿بَلِ الإنْسانُ عَلى نَفْسِهِ بَصِيرَةٌ﴾</q> يعني: جسده وجوارحه شاهدة عليه بعمله، فذلك قوله -تبارك وتعالى-: <q>﴿كَفى بِنَفْسِكَ اليَوْمَ عَلَيْكَ حَسِيبًا﴾</q> [الإسراء:١٤] يعني: شاهدًا{10}. (ز) ٨٠١١٨- قال عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿بَلِ الإنْسانُ عَلى نَفْسِهِ بَصِيرَةٌ﴾</q>، قال: هو شاهد على نفسه. وقرأ: <q>﴿اقْرَأْ كِتابَكَ كَفى بِنَفْسِكَ اليَوْمَ عَلَيْكَ حَسِيبًا﴾</q> [الإسراء:١٤]{11}٦٩١٠. (ز) ٦٩١٠ ذكر ابنُ جرير (٢٣/٤٩٣) أنّ مَن قال هذا القول جعل البصيرة خبرًا للإنسان، ورفع الإنسان بها. ثم قال: «ومَن قال هذه المقالة يقول: أُدخلت الهاء في قوله: <q>﴿بصيرة﴾</q> وهي خبر للإنسان، كما يقال للرجل: أنتَ حُجّة على نفسك، وهذا قول بعض نحويي البصرة. وكان بعضهم يقول: أُدخلت هذه الهاء في <q>﴿بصيرة﴾</q> وهي صفة للذكَر، كما أُدخلتْ في: راوية وعلامة». وذكر ابنُ عطية (٨/٤٧٥) أنّ قوله: <q>﴿بصيرة﴾</q> يحتمل هذا القول، ويكون المعنى: فيه وفي عقْله وفِطرته حُجّة وطليعة وشاهدٌ مُبصر على نفسه، والهاء للتأنيث، ولو اعتذر عن قبيح أفعاله فهو يَعلم قُبْحها، وكذلك لو استتر بستوره واختفى بأفعاله -على التأويلين- في المعاذير. ويحتمل أن يكون ابتداء، وخبره في قوله تعالى: <q>﴿على نفسه﴾</q> والهاء للتأنيث، ويراد بـ«البصيرة»: جوارحه أو الملائكة الحَفظة. كما قال ابن عباس، وعكرمة، والكلبي. ",footnotes:1:أخرجه عبد الرزاق ٢/٣٣٣-٣٣٤، وابن جرير ٢٣/٤٩٢-٤٩٣. وعزاه السيوطي إلى ابن المنذر.أخرجه ابن أبي شيبة ١٣/٥٤٠-٥٤١، وابن جرير ٢٣/٤٩٤ بنحوه.أخرجه ابن جرير ٢٣/٤٩١. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.تفسير الثعلبي ١٠/٨٦، وتفسير البغوي ٨/٢٨٣.تفسير الثعلبي ١٠/٨٦، وتفسير البغوي ٨/٢٨٣.أخرجه ابن جرير ٢٣/٤٩٤. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه عبد الرزاق ٢/٣٣٤، وابن جرير ٢٣/٤٩٢. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.القذاة: ما يقع في العين من تراب أو وسخ. والجذل: ما عظم من أصول الشجر المقطع. النهاية (قذا)، اللسان (جذل).أخرجه ابن جرير ٢٣/٤٩٢. وعزاه السيوطي إلى ابن المنذر.تفسير مقاتل بن سليمان ٤/٥١١.أخرجه ابن جرير ٢٣/٤٩٣.
75,15," <q>﴿وَلَوۡ أَلۡقَىٰ مَعَاذِیرَهُۥ ۝١٥﴾</q> - تفسير ٨٠١١٩- عن عبد الله بن عباس -من طريق العَوفيّ- في قوله: <q>﴿ولَوْ ألْقى مَعاذِيرَهُ﴾</q>، قال: ولو اعتذر{1}. (١٥/١٠٥) ٨٠١٢٠- عن سعيد بن جُبَير -من طريق موسى-، مثله{2}. (١٥/١٠٥) ٨٠١٢١- عن عبد الله بن عباس -من طريق زُرارة بن أوْفى- <q>﴿ولَوْ ألْقى مَعاذِيرَهُ﴾</q>، قال: ولو تَجرّد مِن ثيابه{3}. (١٥/١٠٦) ٨٠١٢٢- عن عبد الله بن عباس -من طريق عطية العَوفيّ- في قوله تعالى: <q>﴿ولَوْ ألْقى مَعاذِيرَهُ﴾</q>، قال: يعني: الاعتذار، ألم تسمع أنه قال: <q>﴿لا يَنفَعُ الظّالِمِينَ مَعْذِرَتُهُمْ﴾</q> [غافر:٥٢]، وقال الله: <q>﴿وأَلْقَوْا إلى اللهِ يَوْمَئِذٍ السَّلَمَ﴾</q> [النحل:٨٧]، وقوله: <q>﴿ما كُنّا نَعْمَلُ مِن سُوءٍ﴾</q> [النحل:٢٨]، وقولهم: <q>﴿والله ربنا ما كنا مشركين﴾</q> [الأنعام:٢٣]{4}. (ز) ٨٠١٢٣- عن مجاهد بن جبر -من طريق ابن أبي نجيح- <q>﴿عَلى نَفْسِهِ بَصِيرَةٌ ولَوْ ألْقى مَعاذِيرَهُ﴾</q>، قال: لو جادل عنها هو بصير عليها{5}. (١٥/١٠٥) ٨٠١٢٤- عن الضَّحّاك بن مُزاحِم، <q>﴿ولَوْ ألْقى مَعاذِيرَهُ﴾</q>، قال: حُجَّتَه{6}. (١٥/١٠٦) ٨٠١٢٥- عن الضَّحّاك بن مُزاحِم، <q>﴿ولَوْ ألْقى مَعاذِيرَهُ﴾</q>، قال: سُتورَه، بلغة أهل اليمن{7}. (١٥/١٠٦) ٨٠١٢٦- عن الحسن البصري -من طريق قتادة- <q>﴿ولَوْ ألْقى مَعاذِيرَهُ﴾</q>: لم تُقبل معاذيره{8}. (ز) ٨٠١٢٧- عن قتادة بن دعامة -من طريق معمر- في قوله: <q>﴿ولَوْ ألْقى مَعاذِيرَهُ﴾</q>، قال: لو اعتذر يومئذ بباطل لم يَقبل اللهُ ذلك منه يوم القيامة{9}. (١٥/١٠٥) ٨٠١٢٨- قال عطاء: <q>﴿ولَوْ ألْقى مَعاذِيرَهُ﴾</q>، يعني: يَشهد عليه الشاهد، ولو اعتذر وجادل عن نفسه لم يَنفعه{10}. (ز) ٨٠١٢٩- عن إسماعيل السُّدِّيّ -من طريق أبي حمزة- في قوله: <q>﴿ولَوْ ألْقى مَعاذِيرَهُ﴾</q>: ولو أرخى السُّتور، وأَغلق الأبواب{8}. (ز) ٨٠١٣٠- قال مقاتل بن سليمان: <q>﴿ولَوْ ألْقى مَعاذِيرَهُ﴾</q> ولو أدلى بحُجّته لم تَنفعه، وكان جسده عليه شاهدًا{12}. (ز) ٨٠١٣١- قال عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿ولَوْ ألْقى مَعاذِيرَهُ﴾</q>، قال: معاذيرهم التي يَعتذرون بها يوم القيامة، فلا يَنتفعون بها. قال: قوم لا يُؤذن لهم فيَعتذِرون، وقوم يُؤذن لهم فيَعتذِرون فلا يَنفعهم، ويَعتذِرون بالكذب{13}٦٩١١. (ز) ٦٩١١ اختُلف في المراد بقوله: <q>﴿ولو ألقى معاذيره﴾</q> على أقوال: الأول: لو اعتذر يومئذ لم يُقبل منه. الثاني: لو تَجرّد من ثيابه. الثالث: لو أظهر حُجّته. قاله السُّدِّيّ. الرابع: لو أرخى السُّتور وأغلق الأبواب. الخامس: بل للإنسان على نفسه شهود من نفسه، ولو اعتذر بالقول مما قد أتى من المآثم، وركب من المعاصي، وجادل بالباطل. ورجَّح ابنُ جرير (٢٣/٤٩٦) -مستندًا إلى السياق- أنّ أولى الأقوال بالصواب قول مَن قال: ولو اعتذر. فقال: «لأنّ ذلك أشبه المعاني بظاهر التنزيل؛ وذلك أنّ الله -جلّ ثناؤه- أخبَر عن الإنسان أنّ عليه شاهدًا من نفسه بقوله: <q>﴿بل الإنسان على نفسه بصيرة﴾</q> فكان الذي هو أولى أن يَتبع ذلك، ولو جادل عنها بالباطل، واعتذر بغير الحق، فشهادة نفسه عليه به أحقّ وأولى من اعتذاره بالباطل». ورجَّح ابنُ كثير (١٤/١٩٤) -مستندًا إلى النظائر- القول الأخير الذي قاله مجاهد، وعطاء، فقال: «والصحيح قول مجاهد وأصحابه، كقوله: <q>﴿ثم لم تكن فتنتهم إلا أن قالوا والله ربنا ما كنا مشركين﴾</q> [الأنعام:٢٣]، وكقوله: <q>﴿يوم يبعثهم الله جميعا فيحلفون له كما يحلفون لكم ويحسبون أنهم على شيء ألا إنهم هم الكاذبون﴾</q> [المجادلة:١٨]». وذكر ابنُ عطية (٨/٤٧٥) أنّ الحسن قال: المعنى: بل الإنسان على نفسه بَليّة ومِحنة، ووجَّهه بقوله: «كأنه ذهب إلى البصيرة التي هي طريقة الدّم، وداعية طلب الثأر». وانتقده بقوله: «وفي هذا نظر». ",footnotes:1:أخرجه عبد الرزاق ٢/٣٣٣-٣٣٤، وابن جرير ٢٣/٤٩٢-٤٩٣. وعزاه السيوطي إلى ابن المنذر.أخرجه ابن أبي شيبة ١٣/٥٤٠-٥٤١.عزاه السيوطي إلى ابن المنذر، وابن أبي حاتم. وأخرجه ابن جرير ٢٣/٤٩٤ دون قوله: من ثيابه.أخرجه ابن جرير ٢٣/٤٩٣-٤٩٤.أخرجه ابن جرير ٢٣/٤٩٤. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.عزاه السيوطي إلى عبد بن حميد، وابن المنذر.عزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ٢٣/٤٩٥.أخرجه عبد الرزاق ٢/٣٣٤، وابن جرير ٢٣/٤٩٥ بنحوه من طريق سعيد. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.تفسير البغوي ٨/٢٨٣.أخرجه ابن جرير ٢٣/٤٩٥.تفسير مقاتل بن سليمان ٤/٥١١.أخرجه ابن جرير ٢٣/٤٩٤.
75,16," <q>﴿لَا تُحَرِّكۡ بِهِۦ لِسَانَكَ لِتَعۡجَلَ بِهِۦۤ ۝١٦﴾</q> - نزول الآية، وتفسيرها ٨٠١٣٢- عن عبد الله بن عباس -من طريق سعيد بن جُبَير-: كان رسول الله ﷺ يُعالج من التنزيل شِدّة، فكان يُحرّك به لسانه وشَفتيه مخافة أن يَتفلَّتَ منه، يريد أن يَحفظه؛ فأنزل الله: <q>﴿لا تُحَرِّكْ بِهِ لِسانَكَ لِتَعْجَلَ بِهِ إنَّ عَلَيْنا جَمْعَهُ وقُرْآنَهُ﴾</q> قال: يقول: علينا أن نَجمعه في صدرك ثم تقرأه، <q>﴿فَإذا قَرَأْناهُ﴾</q> يقول: إذا أنزلناه عليك <q>﴿فاتَّبِعْ قُرْآنَهُ﴾</q> فاستَمِع له وأَنصِتْ، <q>﴿ثُمَّ إنَّ عَلَيْنا بَيانَهُ﴾</q> أن نُبيّنه بلسانك، وفي لفظ: علينا أن نَقرأه. فكان رسول الله ﷺ بعد ذلك إذا أتاه جبريل أطرق -وفي لفظ: استمَع-، فإذا ذَهب قرأه كما وعده الله ﷿{1}. (١٥/١٠٧) ٨٠١٣٣- عن عبد الله بن عباس، قال: كان النبيُّ ﷺ إذا نَزل عليه القرآنُ تَعجَّل بقراءته ليَحفظه؛ فنَزلت هذه الآية: <q>﴿لا تُحَرِّكْ بِهِ لِسانَكَ﴾</q>. وكان رسول الله ﷺ لا يَعلم خَتْم السورة حتى تَنزل عليه: بسم الله الرحمن الرحيم{2}. (١٥/١٠٧) ٨٠١٣٤- عن عبد الله بن عباس -من طريق عطية العَوفيّ-: كان رسول الله ﷺ لا يَفْتُر مِن القرآن مَخافة أن يَنساه، فقال الله: <q>﴿لا تُحَرِّكْ بِهِ لِسانَكَ لِتَعْجَلَ بِهِ﴾</q>{3}. (١٥/١٠٨) ٨٠١٣٥- عن سعيد بن جُبَير -من طريق عمرو بن دينار-: أنّ النبي ﷺ كان إذا نَزل عليه القرآن تَعجَّل به يريد حِفْظه؛ يُحرّك شَفتيه ليَحفظه؛ فأنزل الله: <q>﴿لا تُحَرِّكْ بِهِ لِسانَكَ لِتَعْجَلَ بِهِ إنَّ عَلَيْنا جَمْعَهُ وقُرْآنَهُ﴾</q>{4}. (ز) ٨٠١٣٦- عن سعيد بن جُبَير -من طريق موسى بن أبي عائشة- <q>﴿لا تُحَرِّكْ بِهِ لِسانَكَ لِتَعْجَلَ بِهِ﴾</q>، قال: كان جبريل يَنزل بالقرآن، فيُحرّك به لسانه، يَستعجل به؛ فقال: <q>﴿لا تُحَرِّكْ بِهِ لِسانَكَ لِتَعْجَلَ بِهِ﴾</q>{5}. (ز) ٨٠١٣٧- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿لا تُحَرِّكْ بِهِ لِسانَكَ﴾</q>، قال: كان يَستذكر القرآن مَخافة النسيان، فقيل له: كَفَيناكه، يا محمد{6}. (١٥/١٠٧) ٨٠١٣٨- عن الضَّحّاك بن مُزاحِم -من طريق عبيد- يقول في قوله: <q>﴿لا تُحَرِّكْ بِهِ لِسانَكَ﴾</q>، قال: كان النبي ﷺ إذا نَزل عليه الوحيُ مِن القرآن حَرّك به لسانه؛ مَخافة أن يَنساه{5}. (ز) ٨٠١٣٩- عن عامر الشعبي -من طريق داود بن أبي هند- <q>﴿لا تُحَرِّكْ بِهِ لِسانَكَ لِتَعْجَلَ بِهِ﴾</q>، قال: كان إذا نَزل عليه الوحيُ عَجِل يَتكلّم به مِن حُبِّه إيّاه؛ فنزل: <q>﴿لا تُحَرِّكْ بِهِ لِسانَكَ لِتَعْجَلَ بِهِ﴾</q>{5}. (ز) ٨٠١٤٠- عن الحسن البصري: <q>﴿لا تُحَرِّكْ بِهِ لِسانَكَ لِتَعْجَلَ بِهِ﴾</q> كان رسول الله إذا نَزل عليه القرآنُ يُدْئِب نفسه في قراءته، مَخافة أن يَنساه؛ فأنزل الله: <q>﴿لا تُحَرِّكْ بِهِ لِسانَكَ لِتَعْجَلَ بِهِ﴾</q>{9}. (ز) ٨٠١٤١- عن الحسن البصري -من طريق أبي رجاء- <q>﴿لا تُحَرِّكْ بِهِ لِسانَكَ لِتَعْجَلَ بِهِ﴾</q>، قال: كان رسول الله ﷺ يُحرّك به لسانه ليَستذكره، فقال الله: <q>﴿لا تُحَرِّكْ بِهِ لِسانَكَ لِتَعْجَلَ بِهِ﴾</q> إنّا سَنحفظه عليك{10}. (ز) ٨٠١٤٢- عن قتادة بن دعامة -من طريق سعيد- <q>﴿لا تُحَرِّكْ بِهِ لِسانَكَ لِتَعْجَلَ بِهِ﴾</q>، قال: كان نبي الله ﷺ يُحرّك لسانه بالقرآن مَخافة النسيان؛ فأَنزل الله ما تسمع{11}. (١٥/١٠٨) ٨٠١٤٣- عن قتادة بن دعامة -من طريق معمر- في قوله تعالى: <q>﴿لا تُحَرِّكْ بِهِ لِسانَكَ﴾</q>، قال: كان رسول الله ﷺ يَقرأ القرآن فيُكثر مَخافة أن يَنسى{12}. (ز) ٨٠١٤٤- قال مقاتل بن سليمان: <q>﴿لا تُحَرِّكْ بِهِ لِسانَكَ لِتَعْجَلَ بِهِ﴾</q> وذلك أنّ جبريل كان يأتي النبيَّ ﷺ بالوحي، فإذا قَرأه عليه تلاه النبيُّ ﷺ قبل أن يَفرغ جبريلُ مِن الوحي مَخافة أن لا يَحفظه، فقال الله تعالى: <q>﴿لا تُحَرِّكْ بِهِ لِسانَكَ﴾</q> بتلاوته قبل أن يَفرغ جبريل ﷺ <q>﴿لِتَعْجَلَ بِهِ﴾</q>{13}. (ز) ٨٠١٤٥- قال عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿لا تُحَرِّكْ بِهِ لِسانَكَ لِتَعْجَلَ بِهِ﴾</q>، قال: لا تَكلّم بالذي أوحينا إليك حتى يُقضى إليك وحيه، فإذا قَضينا إليك وحيُه فتَكلّم به{5}٦٩١٢. (ز) ٦٩١٢ اختُلف في السبب الذي من أجله قيل للنبي ﷺ: <q>﴿لا تحرك به لسانك لتعجل به﴾</q> على قولين: الأول: أنّ النبي ﷺ كان يُكثر تلاوة القرآن مَخافة نسيانه، فقيل له: <q>﴿لا تحرك به لسانك لتعجل به﴾</q> إنّ علينا أن نَجمعه لك، ونُقرئكه فلا تنسى. الثاني: أنه كان يُعجّل بذكره إذا نَزل عليه مِن حُبّه له وحلاوته في لسانه، فقيل له: لا تَعجل به، فإنه سَنحفظه عليك. ورجَّح ابنُ جرير (٢٣/٥٠٠) -مستندًا إلى الدلالة العقلية- القول الثاني الذي قاله ابن عباس من طريق ابن جُبَير، وقاله سعيد بن جُبَير، والشعبي، وابن زيد، والضَّحّاك، وانتقد الأول، فقال: «وذلك أنّ قوله: <q>﴿إن علينا جمعه وقرآنه﴾</q> يُنبئ أنه إنما نُهي عن تحريك اللسان به مُتعجّلًا فيه قبل جمْعه؛ ومعلوم أنّ دراسته للتذكُّر إنما كانت تكون من النبي ﷺ مِن بعد جمْع الله له ما يدرس من ذلك». ",footnotes:1:أخرجه البخاري ١/٨ (٥)، ٦/١٦٣ (٤٩٢٧-٤٩٢٩)، ٦/١٩٥ (٥٠٤٤)، ٩/١٥٣ (٧٥٢٤)، ومسلم ١/٣٣٠ (٤٤٨)، وابن جرير ٢٣/٤٩٧-٤٩٨، وابن أبي حاتم -كما في تفسير ابن كثير ٨/٢٧٩-.أخرجه ابن منده في الإيمان ٢/٦٩٧-٦٩٨ (٦٩٠)، وابن جرير ٢٣/٤٩٦-٤٩٧ كلاهما بنحوه. وعزاه السيوطي إلى ابن المنذر، وابن مردويه. قال ابن أبي حاتم في العلل ٤/٦٣٠ (١٦٩٠): «قال أبي: منهم مَن لا يقول في هذا الحديث: ابن عباس، ويُرسله، والمرسل أصح؛ حدثنا ابن أبي عمر، عن ابن عُيينة، عن عمرو، عن سعيد بن جُبَير، مرسل».أخرجه ابن جرير ٢٣/٤٩٩، ٥٠١. وعزاه السيوطي إلى ابن مردويه.أخرجه ابن جرير ٢٣/٤٩٧.أخرجه ابن جرير ٢٣/٤٩٨.أخرجه ابن جرير ٢٣/٤٩٩. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه ابن جرير ٢٣/٤٩٨.أخرجه ابن جرير ٢٣/٤٩٨.ذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٥/٦٤-٦٥-.أخرجه ابن جرير ٢٣/٤٩٩-٥٠٠.أخرجه ابن جرير ٢٣/٥٠٠. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه عبد الرزاق ٢/٣٣٤، وابن جرير ٢٣/٥٠٠.تفسير مقاتل بن سليمان ٤/٥١٢.أخرجه ابن جرير ٢٣/٤٩٨.
75,17," <q>﴿إِنَّ عَلَیۡنَا جَمۡعَهُۥ وَقُرۡءَانَهُۥ ۝١٧﴾</q> - تفسير ٨٠١٤٦- عن عبد الله بن عباس -من طريق سعيد بن جُبَير- <q>﴿إنَّ عَلَيْنا جَمْعَهُ وقُرْآنَهُ﴾</q>، قال: يقول: علينا أن نَجمعه في صدرك، ثم تَقرأه{1}. (١٥/١٠٧) ٨٠١٤٧- عن عبد الله بن عباس -من طريق عطية العَوفيّ-: <q>﴿إنَّ عَلَيْنا جَمْعَهُ﴾</q> أن نَجمعه لك، <q>﴿وقُرْآنَهُ﴾</q> أن نُقرِئَك فلا تَنسى{2}. (١٥/١٠٨) ٨٠١٤٨- عن الضَّحّاك بن مُزاحِم -من طريق عبيد- يقول في قوله: <q>﴿إنَّ عَلَيْنا جَمْعَهُ وقُرْآنَهُ﴾</q>، يقول: علينا أن نَجمعه لك حتى نُثبِّته في قلبك{3}. (ز) ٨٠١٤٩- عن قتادة بن دعامة -من طريق معمر- <q>﴿إنَّ عَلَيْنا جَمْعَهُ وقُرْآنَهُ﴾</q>، يقول: إنّ علينا حِفظه وتأليفه{4}. (١٥/١٠٨) ٨٠١٥٠- قال مقاتل بن سليمان: <q>﴿إنَّ عَلَيْنا جَمْعَهُ﴾</q> في قلبك، <q>﴿وقُرْآنَهُ﴾</q> عليك، يعني: نُقْريكه حتى تَحفظه{5}٦٩١٣. (ز) ٦٩١٣ اختُلف في المراد بقوله: <q>﴿وقرآنه﴾</q> على قولين: الأول: قراءته. الثاني: تأليفه. وذكر ابنُ جرير (٢٣/٥٠٢) أنه على القول الأول الذي قاله ابن عباس، والضَّحّاك فقد وجّه قوله تعالى: <q>﴿وقرآنه﴾</q> إلى أنه مصدر من قول القائل: قرأت أقرأ قرآنًا وقراءة. ووجَّه (٢٣/٥٠١-٥٠٢) القول الثاني الذي قاله قتادة بقوله: «كأن قتادة وجّه معنى القرآن إلى أنه مصدر، من قول القائل: قد قَرَأَتْ هذه الناقة في بطنها جنينًا؛ إذا ضَمّتْ رحمها على ولدها». وذكر ابنُ عطية (٨/٤٧٦-٤٧٧) أنّ قوله: <q>﴿وقرآنه﴾</q> يحتمل الأمرين. ",footnotes:1:جزء من الحديث المتقدم بتمامه قريبًا في نزول الآية.أخرجه ابن جرير ٢٣/٤٩٩، ٥٠١. وعزاه السيوطي إلى ابن مردويه.أخرجه ابن جرير ٢٣/٥٠١.أخرجه عبد الرزاق ٢/٣٣٤، وابن جرير ٢٣/٥٠١، ومن طريق سعيد أيضًا. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.تفسير مقاتل بن سليمان ٤/٥١٢.
75,18," <q>﴿فَإِذَا قَرَأۡنَـٰهُ﴾</q> - تفسير ٨٠١٥١- عن عبد الله بن عباس -من طريق سعيد بن جُبَير- <q>﴿فَإذا قَرَأْناهُ﴾</q>، يقول: إذا أنزلناه عليك{1}. (١٥/١٠٧) ٨٠١٥٢- عن عبد الله بن عباس -من طريق علي- <q>﴿فَإذا قَرَأْناهُ﴾</q>، قال: بَيَّنّاه{2}. (١٥/١٠٨) ٨٠١٥٣- قال مقاتل بن سليمان: <q>﴿فَإذا قَرَأْناهُ﴾</q> فإذا تَلوناه عليك، يقول: إذا تلا عليك جبريلُ ﷺ{3}. (ز) <q>﴿فَٱتَّبِعۡ قُرۡءَانَهُۥ ۝١٨﴾</q> - تفسير ٨٠١٥٤- عن عبد الله بن عباس -من طريق سعيد بن جُبَير- قال: <q>﴿فاتَّبِعْ قُرْآنَهُ﴾</q> فاستَمِع له وأَنصِتْ{4}. (١٥/١٠٧) ٨٠١٥٥- عن عبد الله بن عباس -من طريق عطية- قال: <q>﴿فاتَّبِعْ قُرْآنَهُ﴾</q>، يقول: إذا يُتلى عليك فاتّبع ما فيه{5}. (١٥/١٠٨) ٨٠١٥٦- عن عبد الله بن عباس -من طريق علي- <q>﴿فاتَّبِعْ قُرْآنَهُ﴾</q>، يقول: اعمل به{2}. (١٥/١٠٨) ٨٠١٥٧- عن الضَّحّاك بن مُزاحِم -من طريق عبيد- يقول في قوله: <q>﴿فاتَّبِعْ قُرْآنَهُ﴾</q>، يقول: اتّبع ما فيه{7}. (ز) ٨٠١٥٨- عن قتادة بن دعامة -من طريق معمر- <q>﴿فَإذا قَرَأْناهُ فاتَّبِعْ قُرْآنَهُ﴾</q>، يقول: اتّبع حلاله، واجتَنبْ حرامه{8}. (١٥/١٠٨) ٨٠١٥٩- قال مقاتل بن سليمان: <q>﴿فاتَّبِعْ قُرْآنَهُ﴾</q> فاتّبع ما فيه{3}٦٩١٤. (ز) ٦٩١٤ اختُلف في المراد بقوله: <q>﴿فإذا قرأناه فاتبع قرآنه﴾</q> على أقوال: الأول: فإذا بَيّناه فاعمل بما فيه. الثاني: فإذا أنزلناه فاستَمِع قرآنه. الثالث: فإذا تُلي عليك فاتّبع شرائعه وأحكامه. ورجَّح ابنُ جرير (٢٣/٥٠٣) -مستندًا إلى السياق- القول الأخير الذي قاله ابن عباس من طريق العَوفيّ، وقاله قتادة، والضَّحّاك، فقال: «لأنه قيل له: <q>﴿إن علينا جمعه﴾</q> في صدرك <q>﴿وقرآنه﴾</q>، وقد دللنا على أنّ معنى قوله: <q>﴿وقرآنه﴾</q> وقراءته، فقد بَيّن ذلك عن معنى قوله: <q>﴿فإذا قرأناه فاتبع قرآنه﴾</q>». وذكر ابنُ عطية (٨/٤٧٧ بتصرف) أنّ قوله: <q>﴿فاتبع﴾</q> يحتمل القول الثاني والثالث، فقال: «وقوله تعالى: <q>﴿فاتبع﴾</q> يحتمل أن يريد: بذِهْنك وفِكْرك، أي: فاستمع قراءته، ويحتمل أن يريد: فاتّبع في الأوامر والنواهي». ",footnotes:1:تقدم تخريجه بطوله قريبًا في نزول الآية.أخرجه ابن جرير ٢٣/٥٠٣، وابن أبي حاتم -كما في فتح الباري ٨/٦٨٢-. وعزاه السيوطي إلى ابن المنذر.تفسير مقاتل بن سليمان ٤/٥١٢.جزء من الحديث المتقدم بتمامه قريبًا في نزول الآية.أخرجه ابن جرير ٢٣/٤٩٩، ٥٠٢، ٥٠٤. وعزاه السيوطي إلى ابن مردويه.أخرجه ابن جرير ٢٣/٥٠٣، وابن أبي حاتم -كما في فتح الباري ٨/٦٨٢-. وعزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ٢٣/٥٠٣.أخرجه عبد الرزاق ٢/٣٣٤، وابن جرير ٢٣/٥٠٣، ومن طريق سعيد أيضًا. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.تفسير مقاتل بن سليمان ٤/٥١٢.
75,19," <q>﴿ثُمَّ إِنَّ عَلَیۡنَا بَیَانَهُۥ ۝١٩﴾</q> - تفسير ٨٠١٦٠- عن عبد الله بن عباس -من طريق سعيد بن جُبَير- قال: <q>﴿ثُمَّ إنَّ عَلَيْنا بَيانَهُ﴾</q> أن نُبيّنه بلسانك. وفي لفظ: علينا أن نَقرأه{1}. (١٥/١٠٧) ٨٠١٦١- عن عبد الله بن عباس -من طريق عطية- قال: <q>﴿ثُمَّ إنَّ عَلَيْنا بَيانَهُ﴾</q>، يقول: حلاله وحرامه، فذلك بيانه{2}. (١٥/١٠٨) ٨٠١٦٢- عن قتادة بن دعامة -من طريق سعيد- <q>﴿ثُمَّ إنَّ عَلَيْنا بَيانَهُ﴾</q>، قال: بيان حلاله وحرامه، وطاعته ومعصيته{3}. (١٥/١٠٨) ٨٠١٦٣- قال مقاتل بن سليمان: <q>﴿ثُمَّ إنَّ عَلَيْنا بَيانَهُ﴾</q>، يعني: أن نُبيّن لك حلاله وحرامه{4}. (ز) ",footnotes:1:جزء من الحديث المتقدم بتمامه قريبًا في نزول الآية.أخرجه ابن جرير ٢٣/٥٠٤. وعزاه السيوطي إلى ابن مردويه.أخرجه ابن جرير ٢٣/٥٠٤ بنحوه. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.تفسير مقاتل بن سليمان ٤/٥١٢.
