quran[28]{c,v,t}:
  74,48,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿فَمَا تَنفَعُهُمۡ شَفَـٰعَةُ ٱلشَّـٰفِعِینَ ۝٤٨﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٩٩١٢<span class="dash">-</span></span> عن عبد الله بن مسعود، قال: قال رسول الله ﷺ: «<b>لَيَخرُجنّ بشفاعتي من أهل الإيمان من النار، حتى لا يبقى فيها أحدٌ إلا أهل هذه الآية: <span class="qpc-hafs">﴿ما سَلَكَكُمْ فِي سَقَرَ﴾</span> إلى قوله: <span class="qpc-hafs">﴿شَفاعَةُ الشّافِعِينَ﴾</span></b>»{1}. (١٥/٨٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٩١٣<span class="dash">-</span></span> عن أنس، عن النبيِّ ﷺ، قال: «<b>يُؤتى بأدنى أهل النار منزلة يوم القيامة، فيقول اللهُ له: تَفتدي بملء الأرض ذهبًا وفِضّة؟ فيقول: نعم، إن قَدَرتُ عليه. فيقول: كَذبتَ، قد كنتُ أسألك ما هو أيسرُ عليك مِن أن تسألني فأُعطيك، وتَستغفرني فأغفر لك، وتدعوني فأستجيب لك، فلم تَخفني ساعة قطّ من ليل ونهار، ولم تَرجُ ما عندي قطّ، ولم تَخشَ عقابي ساعة قطّ. وليس وراءه أحد إلا وهو شرٌّ منه، فيقال له: <span class="qpc-hafs">﴿ما سَلَكَكُمْ فِي سَقَرَ قالُوا لَمْ نَكُ مِنَ المُصَلِّينَ﴾</span> إلى قوله: <span class="qpc-hafs">﴿حَتّى أتانا اليَقِينُ﴾</span>، يقول الله: <span class="qpc-hafs">﴿فَما تَنْفَعُهُمْ شَفاعَةُ الشّافِعِينَ﴾</span></b>»{2}. (١٥/٨٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٩١٤<span class="dash">-</span></span> عن حبيبة -أو أُمّ حبيبة- قالت: كُنّا في بيت عائشة، فدخل رسول الله ﷺ، فقال: «<b>ما مِن مُسلِمَيْن يموت لهما ثلاثة من الولد أطفال لم يَبلغوا الحِنث إلا جيء بهم حتى يُوقفوا على باب الجنة، فيقال لهم: ادخلوا الجنة أنتم وآباؤكم</b>». قال: فذلك قوله: <span class="qpc-hafs">﴿فَما تَنْفَعُهُمْ شَفاعَةُ الشّافِعِينَ﴾</span>. فعقّب، قال: نَفعت الآباء شفاعة أبنائهم{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٩١٥<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن مسعود</span> -من طريق أبي الزّعراء- قال: يُعذِّب الله قومًا مِن أهل الإيمان، ثم يُخرجهم بشفاعة محمد ﷺ، حتى لا يَبقى إلا مَن ذَكر الله: <span class="qpc-hafs">﴿ما سَلَكَكُمْ فِي سَقَرَ﴾</span> إلى قوله: <span class="qpc-hafs">﴿شَفاعَةُ الشّافِعِينَ﴾</span>{4}. (١٥/٨٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٩١٦<span class="dash">-</span></span> عن <span class="name-1">عبد الله [بن مسعود]</span> -من طريق أبي الزّعراء- في حديث طويل عن آخر الزمان ومبدأ البعث، قال: ... ثم يَشفع الملائكة، والنَّبيّون، والشهداء، والصالحون، والمؤمنون، فيُشفِّعهم الله، قال: ثم يقول: أنا أرحم الراحمين. قال: فيُخرج من النار أكثرَ مما أُخرج مِن جميع الخَلْق برحمته، حتى ما يَترك فيها أحدًا فيه خير. ثم قرأ <span class="name-1">عبد الله</span>: <span class="qpc-hafs">﴿ما سَلَكَكُمْ فِي سَقَرَ﴾</span> قال: وجعل يعقِد حتى عدَّ أربعًا: <span class="qpc-hafs">﴿قالُوا لَمْ نَكُ مِنَ المُصَلِّينَ ولَمْ نَكُ نُطْعِمُ المِسْكِينَ وكُنّا نَخُوضُ مَعَ الخائِضِينَ وكُنّا نُكَذِّبُ بِيَوْمِ الدِّينِ حَتّى أتانا اليَقِينُ فَما تَنْفَعُهُمْ شَفاعَةُ الشّافِعِينَ﴾</span> ثم قال <span class="name-1">عبد الله</span>: أترون في هؤلاء خيرًا؟! ما تُرك فيها أحد فيه خير{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٩١٧<span class="dash">-</span></span> قال <span class="name-1">عمران بن الحُصَين</span>: الشفاعة نافعةٌ لكلّ واحد، دون هؤلاء الذين تَسمعون{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٩١٨<span class="dash">-</span></span> عن عبد الرحمن بن ميمون الأَودي: أنّ <span class="name-2">كعب [الأحبار]</span> دخل يومًا على عمر بن الخطاب، فقال له عمر: حَدِّثني إلى ما تنتهي شفاعة محمد ﷺ يوم القيامة؟ فقال كعب: قد أخبَرك الله في القرآن؛ إنّ الله يقول: <span class="qpc-hafs">﴿ما سَلَكَكُمْ فِي سَقَرَ﴾</span> إلى قوله: <span class="qpc-hafs">﴿اليَقِينُ﴾</span>. قال كعب: فيَشفع يومئذ حتى يَبلغ مَن لم يُصلِّ صلاة قطّ، ولم يُطعم مسكينًا قطّ، ولم يُؤمن ببعثٍ قطّ، فإذا بَلغت هؤلاء لم يبق أحد فيه خير{7}. (١٥/٨٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٩١٩<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span>، <span class="qpc-hafs">﴿فَما تَنْفَعُهُمْ شَفاعَةُ الشّافِعِينَ﴾</span>، قال: لا تنالهم شفاعة مَن يَشفع{8}. (١٥/٨٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٩٢٠<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿فَما تَنْفَعُهُمْ شَفاعَةُ الشّافِعِينَ﴾</span>، قال: تعلَّموا أن الله يُشَفِّع المؤمنين يوم القيامة بعضهم في بعض. قال: وذُكر لنا: أنّ نبي الله ﷺ قال: «<b>إنّ في أمتي لَرجلًا ليُدخِلنّ الله الجنةَ بشفاعته أكثر من بني تميم</b>». وقال الحسن البصري: أكثر من ربيعة ومُضر. قال: وكُنّا نُحدَّث أنّ الشهيد يَشفع في سبعين من أهل بيته{9}. (١٥/٨٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٩٢١<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق سفيان- <span class="qpc-hafs">﴿فَما تَنْفَعُهُمْ شَفاعَةُ الشّافِعِينَ﴾</span>، قال: لا تَنالهم{10}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٩٢٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فَما تَنْفَعُهُمْ شَفاعَةُ الشّافِعِينَ﴾</span>، يعني: لا يَنالهم يومئذ شفاعة الملائكة والنَّبيّين{11}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿فَمَا تَنفَعُهُمۡ شَفَـٰعَةُ ٱلشَّـٰفِعِینَ ۝٤٨﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٧٩٩٢٣<span class="dash">-</span></span> عن أنس، يقول: قال النبي ﷺ: «<b>إنّ الرجل ليشفع للرجلين، والثلاثة، والرجل للرجال</b>»{12}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٩٢٤<span class="dash">-</span></span> عن أنس، قال: قال رسول الله ﷺ يَصِف أهلَ النار: «<b>فيَمُرّ فيهم الرجل من أهل الجنة، فيقول الرجل منهم: يا فلان. قال: فيقول: ما تريد؟ فيقول: أما تذكر رجلًا سَقاك شربة يوم كذا وكذا؟ قال فيقول: وإنّك لَأنت هو؟ فيقول: نعم. فيَشفع له، فيُشفّع فيه. قال: ثم يَمُرّ بهم الرجل من أهل الجنة، فيقول: يا فلان، فيقول: ما تريد؟ فيقول: أما تَذكر رجلًا وهب لك وضوءًا يوم كذا وكذا؟ فيقول: إنك لأنت هو؟ فيقول: نعم. فيَشفع له، فيُشفّع فيه</b>»{13}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٩٢٥<span class="dash">-</span></span> عن يزيد بن صُهيب الفقير، قال: كُنّا بمكة ومعي طَلق بن حبيب، وكنا نرى رأي الخوارج، فبَلغنا أنّ <span class="name-1">جابر بن عبد الله</span> يقول في الشفاعة، فأتيناه، فقلنا له: بلغنا عنك في الشفاعة قولٌ، اللهُ مخالفٌ لك فيها في كتابه. فنَظر في وجوهنا، فقال: مِن أهل العراق أنتم؟ قلنا: نعم. فتبَسّم، وقال: وأين تجدون في كتاب الله؟ قلت: حيث يقول: <span class="qpc-hafs">﴿رَبَّنا إنَّكَ مَن تُدْخِلِ النّارَ فَقَدْ أخْزَيْتَهُ﴾</span> [آل عمران:١٩٢]، و<span class="qpc-hafs">﴿يُرِيدُونَ أنْ يَخْرُجُوا مِنَ النّارِ وما هُمْ بِخارِجِينَ مِنها﴾</span> [المائدة:٣٧]، و<span class="qpc-hafs">﴿كُلَّما أرادُوا أنْ يَخْرُجُوا مِنها أُعِيدُوا فِيها﴾</span> [السجدة:٢٠]، وأشباه هذا من القرآن. فقال: أنتم أعلم بكتاب الله أم أنا؟ قلنا: بل أنتَ أعلم به منّا. قال: فواللهِ، لقد شهدتُ تنزيل هذا على عهد رسول الله ﷺ وشفاعة الشافعين، ولقد سمعتُ تأويله من رسول الله ﷺ، وإنّ الشفاعة لنبيّه في كتاب الله؛ قال في السورة التي يذكر فيها المُدَّثِّر: <span class="qpc-hafs">﴿ما سَلَكَكُمْ فِي سَقَرَ قالُوا لَمْ نَكُ مِنَ المُصَلِّينَ﴾</span> الآية، ألا تَرون أنها حلّتْ لِمن لا يُشرك بالله شيئًا؟ سمعتُ رسول الله ﷺ يقول: «<b>إنّ الله خَلَق خَلْقًا، ولم يَستعن على ذلك، ولم يُشاور فيه أحدًا، فأَدخلَ مَن شاء الجنة برحمته، وأَدخلَ مَن شاء النار، ثم إنّ الله تحنّن على المُوحِّدين، فبَعث ملَكًا مِن قِبَله بماء ونور، فدَخل النار، فنَضح، فلم يُصب إلا مَن شاء، ولم يُصب إلا مَن خَرج من الدنيا لم يُشرك بالله شيئًا، فأَخرجَهم حتى جَعلهم بفناء الجنة، ثم رجع إلى ربّه، فأمدّه بماء ونور، ثم دَخل فنَضح، فلم يُصب إلا مَن شاء الله، ثم لم يُصب إلا مَن خرج من الدنيا لم يُشرك بالله شيئًا، فأَخرجَهم حتى جَعلهم بفناء الجنة، ثم أذِن الله للشفعاء، فشَفعوا لهم، فأَدخلهم الله الجنة برحمته وشفاعة الشافعين</b>»{14}. (١٥/٨٨)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن خسرو في مسند أبي حنيفة ١/٤٥١ (٤٨٩)، والحارثي في مسند أبي حنيفة ٢/٨٤٢ (١٤٩٧-١٥١٢)، من طريق أبي حنيفة، عن سلمة بن كُهيل، عن أبي الزّعراء، عن عبد الله بن مسعود به. وعزاه السيوطي إلى ابن مردويه.</p><p>قال ابن خسرو: «روى الجماعة هذا الحديث موقوفًا على عبد الله بن مسعود».|2:أخرجه الواحدي في التفسير الوسيط ٤/٣٨٦-٣٨٧ (١٢٥٧)، من طريق ليث، عن بشر، عن أنس بن مالك به. وعزاه السيوطي إلى ابن مردويه.</p><p>وسنده ضعيف؛ فيه بشر، قال عنه ابن حجر في التقريب (٧١٠): «هو ابن دينار، مجهول». وفيه ليث بن أبي سليم، قال عنه ابن حجر في التقريب (٥٦٨٥): «صدوق، اختلط جدًّا، ولم يتميّز حديثه؛ فتُرك».|3:أخرجه إسحاق بن راهويه في مسنده ٤/٢٥١ (٢٠٧٤)، والطبراني في الكبير ٢٤/٢٢٤ (٥٧٠)، بنحوه دون ذكر الآية، من طريق محمد بن سيرين، عن حبيبة به. ووقع عند إسحاق: حبيبة أو أُمّ حبيبة.</p><p>وأخرجه الطبراني في الكبير ٢٤/٢٢٥ (٥٧١) بنحوه دون ذكر الآية، من طريق محمد بن سيرين، عن يزيد بن أبي بكرة، عن حبيبة به.</p><p>وقال المنذري في الترغيب والترهيب ٣/٥٥-٥٦ (٣٠٥٧): «رواه الطبراني في الكبير، بإسناد حسن جيد». وقال الهيثمي في المجمع ٣/٧ (٣٩٧٧): «رواه الطبراني في الكبير، ورجاله رجال الصحيح، خلا يزيد بن أبي بكرة، وقد وثّقه ابن حبان، وأعاده بإسناد آخر، ورجاله ثقات، وليس فيه يزيد بن أبي بكرة». وأورده الألباني في الصحيحة ٧/١٢٢٨ (٣٤١٦).|4:أخرجه البيهقي في البعث (٨٦).|5:أخرجه ابن أبي شيبة في مصنفه (ت: محمد عوامة) ٢١/٢٨١-٢٨٥ (٣٨٧٩٢)، وابن جرير ٢٣/٤٥٣ بنحوه مختصرًا.|6:تفسير البغوي ٨/٢٧٣.|7:عزاه السيوطي إلى ابن مردويه.|8:عزاه السيوطي إلى عَبد بن حُمَيد، وابن المنذر.|9:أخرجه ابن جرير ٢٣/٤٥٣، وعبد الرزاق ٢/٣٣٠-٣٣١ من طريق معمر مختصرًا، ومثله ابن جرير ٢٣/٤٥٣. وعزاه السيوطي إلى عَبد بن حُمَيد، وابن المنذر.|10:كتاب صفة النار-موسوعة الإمام ابن أبي الدنيا ٦/٤٢٨ (١٣٣)-.|11:تفسير مقاتل بن سليمان ٤/٤٩٩.|12:أخرجه عبد الرزاق ٣/٣٦٤ (٣٣٩٣) واللفظ له، وابن خزيمة في التوحيد ٢/٧٤٥، والبزار ١٣/٣١٩ (٦٩٢١) مختصرًا، من طريق معمر، عن ثابت، عن أنس بن مالك به.</p><p>قال المنذري في الترغيب والترهيب ٤/٢٤١ (٥٥١٤): «رواته رواة الصحيح». وقال الهيثمي في المجمع ١٠/٣٨٢ (١٨٥٤٨): «رجاله رجال الصحيح».|13:أخرجه ابن ماجه ٤/٦٤٤ (٣٦٨٥)، والبغوي في تفسيره ٨/٢٧٣-٢٧٤، واللفظ له، من طريق يزيد الرّقاشي، عن أنس بن مالك به.</p><p>وقال البوصيري في مصباح الزجاجة ٤/١٠٥ (٧٨٢١): «إسناد ضعيف؛ لضعف يزيد بن أبان الرّقاشي». وقال الألباني في الضعيفة ١/٢١٠ (٩٣): «ضعيف».|14:أخرجه ابن أبي حاتم، وابن مردويه -كما في تفسير ابن كثير ٣/٩٩-. وأصله في صحيح مسلم ١/٧٧ (١٩١)، وليس فيه ذكر آية سورة المدثر.
  74,49,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿فَمَا لَهُمۡ عَنِ ٱلتَّذۡكِرَةِ مُعۡرِضِینَ ۝٤٩﴾</span> - نزول الآية</h3></p><p><div></p><p><p><span class="item-no">٧٩٩٢٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فَما لَهُمْ عَنِ التَّذْكِرَةِ مُعْرِضِينَ﴾</span> نزلت هذه الآية في كفار قريش حين أعرَضوا ولم يؤمنوا{1}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿فَمَا لَهُمۡ عَنِ ٱلتَّذۡكِرَةِ مُعۡرِضِینَ ۝٤٩﴾</span> - تفسير الآية</h3></p><p><div></p><p><p><span class="item-no">٧٩٩٢٧<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿فَما لَهُمْ عَنِ التَّذْكِرَةِ مُعْرِضِينَ﴾</span>، قال: عن القرآن{2}. (١٥/٩٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٩٢٨<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فَما لَهُمْ عَنِ التَّذْكِرَةِ﴾</span> يعني: عن القرآن <span class="qpc-hafs">﴿مُعرِضين﴾</span>{3}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٤/٤٩٩-٥٠٠.|2:أخرجه ابن جرير ٢٣/٤٥٤. وعزاه السيوطي إلى عَبد بن حُمَيد، وابن المنذر.|3:أخرجه مقاتل بن سليمان ٤/٤٩٩-٥٠٠.
  74,50,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿كَأَنَّهُمۡ حُمُرࣱ مُّسۡتَنفِرَةࣱ ۝٥٠﴾</span> - قراءات</h3></p><p><div></p><p><p><span class="item-no">٧٩٩٢٩<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٩٣٠<span class="dash">-</span></span> و<span class="name-2">أبي رجاء</span> أنهما قرآ: ‹مُّسْتَنفَرَةٌ›، يعني: بنصب الفاء{1}. (١٥/٩٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٩٣١<span class="dash">-</span></span> عن <span class="name-2">عاصم بن أبي النجود</span> أنه قرأ: <span class="qpc-hafs">﴿كَأَنَّهُمْ حُمُرٌ﴾</span> مُثقّلة، <span class="qpc-hafs">﴿مُسْتَنْفِرَةٌ﴾</span> بخفض الفاء{2}<span class=comment-ref>٦٨٩٠</span>. (١٥/٩٠)</p></p><p></div></p><p><div><span class=comment-ref>٦٨٩٠</span> ذكر <u>ابنُ جرير</u> (٢٣/٤٥٥) هذه القراءة، وقراءة مَن قرأ ذلك: ‹مُّسْتَنفَرَةٌ›، ثم قال <span class="comment-type-4">معلقًا</span>: «والصواب من القول في ذلك عندنا أنهما قراءتان <span class="mustanad">معروفتان، صحيحتا المعنى</span>، فبأيّتهما قرأ القارئ فمصيب».</div></p><p><h3><span class="qpc-hafs">﴿كَأَنَّهُمۡ حُمُرࣱ مُّسۡتَنفِرَةࣱ ۝٥٠﴾</span> - تفسير الآية</h3></p><p><div></p><p><p><span class="item-no">٧٩٩٣٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: شبّههم بالحُمُر الوحشية المذْعُورة، فقال: <span class="qpc-hafs">﴿كَأَنَّهُمْ حُمُرٌ مُسْتَنْفِرَةٌ﴾</span> بترْكهم القرآن، إذا سمعوه فرُّوا منه مثل الحُمر{3}. (ز)</p></p><p></div></p></div>",footnotes:1:عزاه السيوطي إلى أبي عبيد، وابن المنذر.</p><p>وهي قراءة متواترة، قرأ بها نافع، وأبو جعفر، وابن عامر، وقرأ بقية العشرة: <span class="qpc-hafs">﴿مُّسْتَنْفِرَةٌ﴾</span> بكسر الفاء. انظر: النشر ٢/٣٩٣، والإتحاف ص٥٦٢.|2:عزاه السيوطي إلى عَبد بن حُمَيد.|3:تفسير مقاتل بن سليمان ٤/٥٠٠.
  74,51,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿فَرَّتۡ مِن قَسۡوَرَةِۭ ۝٥١﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٩٩٣٣<span class="dash">-</span></span> عن <span class="name-1">أبي موسى الأشعري</span> -من طريق أبي ظَبْيان- في قوله: <span class="qpc-hafs">﴿فَرَّتْ مِن قَسْوَرَةٍ﴾</span>، قال: هم الرُّماة؛ رجال القَنص{1}. (١٥/٩٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٩٣٤<span class="dash">-</span></span> عن <span class="name-1">أبي هريرة</span> -من طريق زيد بن أسلم- في قوله: <span class="qpc-hafs">﴿فَرَّتْ مِن قَسْوَرَةٍ﴾</span>، قال: الأسد{2}. (١٥/٩٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٩٣٥<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطية العَوفيّ- <span class="qpc-hafs">﴿فَرَّتْ مِن قَسْوَرَةٍ﴾</span>، قال: القَسْورة: الرّجال الرُّماة؛ رجال القَنص{3}. (١٥/٩٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٩٣٦<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- في قوله: <span class="qpc-hafs">﴿مِن قَسْوَرَةٍ﴾</span>، قال: هو بلسان العرب: الأسد، وبلسان الحبشة: قَسْورة{4}. (١٥/٩٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٩٣٧<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق أبي حمزة- أنه سأله: القَسْورة الأسد؟ فقال: ما أعلمه بلغة أحد من العرب الأسد، هم عُصْبة الرجال{5}. (١٥/٩١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٩٣٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق يوسف بن مهران- أنه سئل عن قوله: <span class="qpc-hafs">﴿فَرَّتْ مِن قَسْوَرَةٍ﴾</span>. قال: هو بالعربية: الأسد، وبالفارسية: شار، وبالنّبَطِيّة: أريا، وبالحبشية: قَسْورة{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٩٣٩<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، <span class="qpc-hafs">﴿مِن قَسْوَرَةٍ﴾</span>، قال: مِن حبال الصيادين{7}. (١٥/٩١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٩٤٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطاء- <span class="qpc-hafs">﴿مِن قَسْوَرَةٍ﴾</span>، قال: هو رِكْزُ الناس. يعني: أصواتهم{8}. (١٥/٩١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٩٤١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عبّاد بن عبد الرحمن مولى بني هاشم- أنه سئل عن القَسْورة. قال: جمْع الرجال، ألم تسمع ما قالتْ فلانة في الجاهلية:</p><p>يا بنتي كوني خيْرةً لخَيِّره</p><p>أخوالها في الحي مثل القَسْورهْ{9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٩٤٢<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جُبَير</span> -من طريق أبي بشر- <span class="qpc-hafs">﴿فَرَّتْ مِن قَسْوَرَةٍ﴾</span>، قال: القُنّاص{10}. (١٥/٩١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٩٤٣<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق منصور- <span class="qpc-hafs">﴿فَرَّتْ مِن قَسْوَرَةٍ﴾</span>، قال: الرُّماة{11}. (١٥/٩١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٩٤٤<span class="dash">-</span></span> قال <span class="name-2">الضَّحّاك بن مُزاحِم</span>: هم الرُّماة{12}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٩٤٥<span class="dash">-</span></span> قال <span class="name-2">عكرمة مولى ابن عباس</span>: <span class="qpc-hafs">﴿قَسْوَرَةٍ﴾</span>، القَسْورة: هي مِن ظُلمة الليل{13}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٩٤٦<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span>، <span class="qpc-hafs">﴿كَأَنَّهُمْ حُمُرٌ مُسْتَنْفِرَةٌ فَرَّتْ مِن قَسْوَرَةٍ﴾</span>، قال: وحشيّة فرّتْ من رُماتها{14}. (١٥/٩١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٩٤٧<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span> -من طريق سِماك- في قوله: <span class="qpc-hafs">﴿فَرَّتْ مِن قَسْوَرَةٍ﴾</span>، قال: القَسْورة: الرُّماة. فقال رجل لعكرمة: هو الأسد بلسان الحبشة. فقال عكرمة: اسم الأسد بلسان الحبشة: عَنبَسة{15}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٩٤٨<span class="dash">-</span></span> عن <span class="name-2">أبي مالك غَزْوان الغفاري</span>، قال: القَسْورة: الرُّماة{14}. (١٥/٩١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٩٤٩<span class="dash">-</span></span> عن <span class="name-2">عطاء بن أبي رباح</span>، مثله{17}. (١٥/٩١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٩٥٠<span class="dash">-</span></span> عن <span class="name-2">أبي المُتوكِّل [الناجي]</span> -من طريق إسماعيل بن مسلم العبدي - قال: <span class="qpc-hafs">﴿فَرَّتْ مِن قَسْوَرَةٍ﴾</span> هي لغَط القوم، وأصواتهم{18}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٩٥١<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- قال: القَسْورة: النَّبْل{19}. (١٥/٩١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٩٥٢<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿فَرَّتْ مِن قَسْوَرَةٍ﴾</span>: وهم الرُّماة القُنّاص{20}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٩٥٣<span class="dash">-</span></span> عن ابن لَهِيعة: أنّ <span class="name-2">يزيد بن أبي حبيب</span> سُئل عن قول الله: <span class="qpc-hafs">﴿فَرَّتْ مِن قَسْوَرَةٍ﴾</span>. فزعم أنه يقال: هم الرُّماة{21}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٩٥٤<span class="dash">-</span></span> قال <span class="name-2">زيد بن أسلم</span>: أي: من رجال أقوياء، وكلّ ضخم شديد عند العرب: قَسْوَر، وقَسْوَرة{13}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٩٥٥<span class="dash">-</span></span> عن <span class="name-2">زيد بن أسلم</span> -من طريق داود بن قيس- في قول الله: <span class="qpc-hafs">﴿فَرَّتْ مِن قَسْوَرَةٍ﴾</span>، قال: هو الأسد{23}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٩٥٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فَرَّتْ مِن قَسْوَرَةٍ﴾</span>، يعني: الرُّماة، وقالوا: الأسد{24}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٩٥٧<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- قال في قوله: <span class="qpc-hafs">﴿فَرَّتْ مِن قَسْوَرَةٍ﴾</span>، قال: القَسْورة: الأسد{6}<span class=comment-ref>٦٨٩١</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٨٩١</span> قال <u>ابنُ تيمية</u> (٦/٤٢٨): «و<span class="qpc-hafs">﴿قسورة﴾</span> يُراد به: الرامي، ويُراد به: الأسد».</div></p></div>",footnotes:1:أخرجه سعيد بن منصور وابن أبي حاتم -كما في فتح الباري ٨/٦٧٦-، وابن جرير ٢٣/٤٥٥، والحاكم ٢/٥٠٨. وعزاه السيوطي إلى عَبد بن حُمَيد، وابن المنذر.|2:أخرجه عَبد بن حُمَيد -كما في تغليق التعليق ٤/٣٥٢-، والبزار (٢٢٧٧-كشف)، وابن جرير ٢٣/٤٥٩-٤٦٠، من طريق زيد، عن ابن سيلان. وعزاه السيوطي إلى ابن المنذر.|3:أخرجه عبد الله بن وهب في الجامع -تفسير القرآن ١/١٠ (١٦) من طريق عطاء، وابن جرير ٢٣/٤٥٥، ٤٥٧ من طريق سليم، وعطاء أيضًا بنحوه. وعزاه السيوطي إلى عَبد بن حُمَيد، وابن أبي حاتم.|4:أخرجه ابن جرير ٢٣/٤٦٠ بنحوه. وعزاه السيوطي إلى ابن أبي حاتم.|5:أخرجه سعيد بن منصور -كما في فتح الباري ٨/٦٧٦-، وابن جرير ٢٣/٤٥٨. وعزاه السيوطي إلى عَبد بن حُمَيد، وابن المنذر، وابن أبي حاتم.|6:أخرجه ابن جرير ٢٣/٤٦٠.|7:عزاه السيوطي إلى ابن المنذر.|8:أخرجه سفيان بن عُيينة -كما في فتح الباري ٨/٦٧٦-، وعبد الرزاق ٢/٣٣٢، وابن جرير ٢٣/٤٥٨. وعزاه السيوطي إلى ابن المنذر.|9:أخرجه ابن جرير ٢٣/٤٥٨.|10:أخرجه ابن جرير ٢٣/٤٥٧. وعزاه السيوطي إلى عَبد بن حُمَيد.|11:أخرجه ابن جرير ٢٣/٤٥٥-٤٥٦، وبنحوه من طريق ابن أبي نجيح. وعزاه السيوطي إلى عَبد بن حُمَيد.|12:تفسير الثعلبي ١٠/٧٨، وتفسير البغوي ٨/٢٧٤.|13:تفسير الثعلبي ١٠/٧٩، وتفسير البغوي ٨/٢٧٤.|14:عزاه السيوطي إلى عَبد بن حُمَيد.|15:أخرجه ابن جرير ٢٣/٤٥٦، وبنحوه من طريق أبي رجاء.|16:عزاه السيوطي إلى عَبد بن حُمَيد.|17:أخرجه الخطيب في تاريخه ٩/١٨٦.|18:أخرجه الثعلبي ١٠/٧٩، وتفسير البغوي ٨/٢٧٤.|19:أخرجه عبد الرزاق ٢/٣٣٢، وابن جرير ٢٣/٤٥٧. وعزاه السيوطي إلى عَبد بن حُمَيد.|20:أخرجه ابن جرير ٢٣/٤٥٧.|21:أخرجه عبد الله بن وهب في الجامع -تفسير القرآن ١/١١٣-١١٤ (٢٦٠).|22:تفسير الثعلبي ١٠/٧٩، وتفسير البغوي ٨/٢٧٤.|23:أخرجه ابن جرير ٢٣/٤٥٩-٤٦٠، ومن طريق هشام أيضًا.|24:تفسير مقاتل بن سليمان ٤/٥٠٠.|25:أخرجه ابن جرير ٢٣/٤٦٠.
  74,52,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿بَلۡ یُرِیدُ كُلُّ ٱمۡرِئࣲ مِّنۡهُمۡ أَن یُؤۡتَىٰ صُحُفࣰا مُّنَشَّرَةࣰ ۝٥٢﴾</span> - نزول الآية، وتفسيرها</h3></p><p><div></p><p><p><span class="item-no">٧٩٩٥٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق زاذان- يقول: <span class="qpc-hafs">﴿بَلْ يُرِيدُ كُلُّ امْرِئٍ مِنهُمْ أنْ يُؤْتى صُحُفًا مُنَشَّرَةً﴾</span>، كان المشركون يقولون: لو كان محمد صادقًا فليُصبح عند كلِّ رأس رجل منّا صحيفةٌ فيها براءته وأَمْنه مِن النار{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٩٥٩<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- <span class="qpc-hafs">﴿بَلْ يُرِيدُ كُلُّ امْرِئٍ مِنهُمْ أنْ يُؤْتى صُحُفًا مُنَشَّرَةً﴾</span>، قال: إلى فلان بن فلان مِن ربّ العالمين؛ يُصبح عند رأس كلّ رجل صحيفة موضوعة يقرؤها{2}. (١٥/٩٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٩٦٠<span class="dash">-</span></span> عن <span class="name-2">أبي صالح باذام</span> -من طريق السُّدِّيّ- قال: قالوا: إن كان محمد صادقًا فليُصبح تحت رأس كلّ رجل منّا صحيفة فيها براءةٌ وأمَنَةٌ من النار. فنَزلت: <span class="qpc-hafs">﴿بَلْ يُرِيدُ كُلُّ امْرِئٍ مِنهُمْ أنْ يُؤْتى صُحُفًا مُنَشَّرَةً﴾</span>{3}. (١٥/٩٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٩٦١<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿بَلْ يُرِيدُ كُلُّ امْرِئٍ مِنهُمْ أنْ يُؤْتى صُحُفًا مُنَشَّرَةً﴾</span>، قال: قد قال قائلون من الناس: يا محمد، إن سرَّك أن نتّبعك فأتِنا بكتاب خاصة إلى فلان وفلان، نُؤمر فيه باتّباعك. قال <span class="name-2">قتادة</span>: يريدون أن يُؤتوا براءة بغير عمل{4}<span class=comment-ref>٦٨٩٢</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٨٩٢</span> لم يذكر <u>ابنُ جرير</u> (٢٣/٤٦١) غير قول قتادة، ومجاهد.</div></p><p><div></p><p><p><span class="item-no">٧٩٩٦٢<span class="dash">-</span></span> قال <span class="name-2">مطر الوراق</span>: كانوا يريدون أن يؤتوا براءة من غير عمل{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٩٦٣<span class="dash">-</span></span> قال <span class="name-3">محمد بن السّائِب الكلبي</span>: إنّ المشركين قالوا: يا محمد، بلَغنا أنّ الرجل من بني إسرائيل يُصبح مكتوب عند رأسه ذَنبه وكفّارته؛ فأتِنا بمثل ذلك. فكَرهه رسول الله ﷺ، وأنزل الله سبحانه هذه الآية: <span class="qpc-hafs">﴿بَلْ يُرِيدُ كُلُّ امْرِئٍ مِنهُمْ أنْ يُؤْتى صُحُفًا مُنَشَّرَةً﴾</span>{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٩٦٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿بَلْ يُرِيدُ كُلُّ امْرِئٍ مِنهُمْ أنْ يُؤْتى﴾</span> يقول: يُعطى <span class="qpc-hafs">﴿صُحُفًا مُنَشَّرَةً﴾</span> فيها كتاب من الله تعالى. وذلك أنّ كفار مكة قالوا للنبي ﷺ: كان الرجل مِن بني إسرائيل ذَنبه وكفّارة ذَنبه يُصبح مكتوبًا عند رأسه، فهلا تُرينا مثل هؤلاء الآيات إن كنت رسولًا كما تزعم. فقال جبريل: إن شئتَ فعلنا بهم كفِعْلنا ببني إسرائيل، وأَخذناهم بما أخذنا به بني إسرائيل. فكَره النبي ﷺ، وقالوا: ليُصبح عند رأس كلّ رجل منّا كتابٌ منشور مِن الله بأنّ آلهتنا باطل، وأنّ الإله الذي في السماء حقٌّ، وأنك رسول، وأنّ الذي جئت به حقٌّ، وتجيء معك بملائكة يَشهدون بذلك كقول ابن أبي أُمَيّة في سورة بني إسرائيل{7}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير الثعلبي ١٠/٧٩.|2:أخرجه ابن جرير ٢٣/٤٦١ بنحوه. وعزاه السيوطي إلى عَبد بن حُمَيد، وابن المنذر.|3:عزاه السيوطي إلى عَبد بن حُمَيد، وابن جرير، وابن المنذر.|4:أخرجه ابن جرير ٢٣/٤٦١.|5:تفسير الثعلبي ١٠/٧٩.|6:تفسير الثعلبي ١٠/٧٩. وبنحوه في تفسير البغوي ٨/٢٧٥ دون ذكر النزول.|7:تفسير مقاتل بن سليمان ٤/٥٠٠. وآخره يشير إلى الآيات ٩٠-٩٣ من سورة الإسراء وهي: <span class="qpc-hafs">﴿وقالُوا لَنْ نُؤْمِنَ لَكَ حَتّى تَفْجُرَ لَنا مِنَ الأَرْضِ يَنْبُوعًا، أوْ تَكُونَ لَكَ جَنَّةٌ مِن نَخِيلٍ وعِنَبٍ فَتُفَجِّرَ الأَنْهارَ خِلالَها تَفْجِيرًا، أوْ تُسْقِطَ السَّماءَ كَما زَعَمْتَ عَلَيْنا كِسَفًا أوْ تَأْتِيَ بِاللَّهِ والمَلائِكَةِ قَبِيلًا، أوْ يَكُونَ لَكَ بَيْتٌ مِن زُخْرُفٍ أوْ تَرْقى فِي السَّماءِ ولَنْ نُؤْمِنَ لِرُقِيِّكَ حَتّى تُنَزِّلَ عَلَيْنا كِتابًا نَقْرَؤُهُ قُلْ سُبْحانَ رَبِّي هَلْ كُنْتُ إلّا بَشرًا رَسُولًا﴾</span> [الإسراء:٩٠-٩٣].
  74,53,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿كَلَّاۖ بَل لَّا یَخَافُونَ ٱلۡـَٔاخِرَةَ ۝٥٣﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٩٩٦٥<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق أبي الأشهب- <span class="qpc-hafs">﴿كَلّا بَلْ لا يَخافُونَ الآخِرَةَ﴾</span>، قال: هذا الذي فَضحهم{1}. (١٥/٩٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٩٦٦<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿كَلّا بَلْ لا يَخافُونَ الآخِرَةَ﴾</span>، قال: ذلك الذي تَضَحَّك بالقوم وأَفسدهم؛ أنهم كانوا لا يَخافون الآخرة، ولا يُصدِّقون بها{2}. (١٥/٩٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٩٦٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿كَلّا﴾</span> لا يؤمنون بالصُّحف التي أرادوها، ثم استأنف فقال: <span class="qpc-hafs">﴿بَلْ﴾</span> لكن <span class="qpc-hafs">﴿لا يَخافُونَ﴾</span> عذاب <span class="qpc-hafs">﴿الآخِرَةَ﴾</span>{3}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن أبي شيبة ١٤/٣٣.|2:أخرجه ابن جرير ٢٣/٤٦٢. وعزاه السيوطي إلى عَبد بن حُمَيد، وابن المنذر.|3:تفسير مقاتل بن سليمان ٤/٥٠٠-٥٠١.
  74,54,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿كَلَّاۤ إِنَّهُۥ تَذۡكِرَةࣱ ۝٥٤ فَمَن شَاۤءَ ذَكَرَهُۥ ۝٥٥﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٩٩٦٨<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله <span class="qpc-hafs">﴿كَلّا إنَّهُ تَذْكِرَةٌ﴾</span>، قال: هذا القرآن{1}. (١٥/٩٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٩٦٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿كَلّا إنَّهُ تَذْكِرَةٌ﴾</span> يعني: القرآن <span class="qpc-hafs">﴿فَمَن شاءَ ذَكَرَهُ﴾</span> يعني: فَهِمَهُ، يعني: القرآن{2}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ٢٣/٤٦٣. وعزاه السيوطي إلى عَبد بن حُمَيد، وابن المنذر.|2:تفسير مقاتل بن سليمان ٤/٥٠١.
  74,55,"74:54"
  74,56,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَمَا یَذۡكُرُونَ إِلَّاۤ أَن یَشَاۤءَ ٱللَّهُۚ هُوَ أَهۡلُ ٱلتَّقۡوَىٰ وَأَهۡلُ ٱلۡمَغۡفِرَةِ ۝٥٦﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٩٩٧٠<span class="dash">-</span></span> عن أنس، عن النبيِّ ﷺ، قرأ هذه الآية: <span class="qpc-hafs">﴿هُوَ أهْلُ التَّقْوى وأَهْلُ المَغْفِرَةِ﴾</span>، فقال: «<b>قد قال ربكم: أنا أهْلٌ أنْ أُتَّقى فلا يُجعل معي إلهًا، فمَن اتقاني فلم يَجعل معي إلهًا فأنا أهْلٌ أنْ أغفر له</b>»{1}. (١٥/٩٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٩٧١<span class="dash">-</span></span> عن عبد الله بن دينار، قال: سمعتُ أبا هريرة، وابن عمر، وابن عباس، يقولون: سُئِل رسول الله ﷺ عن قول الله: <span class="qpc-hafs">﴿هُوَ أهْلُ التَّقْوى وأَهْلُ المَغْفِرَةِ﴾</span>. قال: «<b>يقول الله: أنا أهْلٌ أنْ أُتقى فلا يُجعل معي شريك، فإذا اتُّقِيتُ ولم يُجعل معي شريك فأنا أهْلٌ أنْ أغفر ما سوى ذلك</b>»{2}. (١٥/٩٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٩٧٢<span class="dash">-</span></span> عن الحسن البصري، قال: قال رسول الله ﷺ: «<b>قال الله: لأنا أكرم وأعظم عفوًا من أنْ أستر على عبد لي في الدنيا ثم أفضحه بعد أن سَترتُه، ولا أزال أغفر لعبدي ما استغفرني</b>». قال رسول الله ﷺ: «<b>يقول الله تعالى: إني لأجدني أستحي مِن عبدي، يَرفع يديه إلَيَّ، ثم أردّهما. قالت الملائكة: إلهنا، ليس لذلك بأهل. قال الله: لكني أهْلُ التقوى وأهْلُ المغفرة، أشهدكم أني قد غفرتُ له</b>». قال رسول الله ﷺ: «<b>ويقول الله: إني لأستحي مِن عبدي وأَمَتي يَشيبان في الإسلام، ثم أُعذّبهما بعد ذلك في النار</b>»{3}. (١٥/٩٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٩٧٣<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿هُوَ أهْلُ التَّقْوى وأَهْلُ المَغْفِرَةِ﴾</span>، قال: إنّ ربّنا محقوقٌ أن تُتقى محارمه، وهو أهْلٌ أن يغفر الذّنوب الكثيرة لعباده{4}. (١٥/٩٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٩٧٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وما يَذْكُرُونَ﴾</span> يعني: وما يهتدون <span class="qpc-hafs">﴿إلّا أنْ يَشاءَ اللَّهُ هُوَ أهْلُ التَّقْوى وأَهْلُ المَغْفِرَةِ﴾</span> يعني: الرّبّ -تبارك وتعالى- نفسه، يقول: هو أهْلٌ أن يُتقى ولا يُعصى، وهو أهْلُ المغفرة لمن يتوب من المعاصي{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٩٧٥<span class="dash">-</span></span> عن عبد القُدُّوس بن بكر، قال: سمعت <span class="name-3">ابن النضر الحارثي</span> يذكر في قوله ﷿: <span class="qpc-hafs">﴿هو أهل التقوى وأهل المغفرة﴾</span>، قال: أنا أهْلٌ لأن يَتقيني عبدي، فإن لم يَفعل كنتُ أهلًا لأنْ أغفر له{6}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه أحمد ١٩/٤٣٠ (١٢٤٤٢)، ٢١/١٧٨ (١٣٥٤٩)، وابن ماجه ٥/٣٥٥ (٤٢٩٩)، والترمذي ٥/٥٢٢ (٣٦١٧)، والحاكم ٢/٥٥٢ (٣٨٧٦)، وابن أبي حاتم -كما في تفسير ابن كثير ٨/٢٧٤-، والثعلبي ١٠/٨٠، من طريق سُهيل، عن ثابت البُناني، عن أنس بن مالك به.</p><p>قال الترمذي: «هذا حديث غريب، وسُهيل ليس بالقوي في الحديث، وقد تفرد سُهيل -بن عبد الله القطعي- بهذا الحديث عن ثابت». وقال الحاكم: «هذا حديث صحيح الإسناد، ولم يخرجاه». ووافقه الذهبي في التلخيص. وقال في سير أعلام النبلاء ٥/٢٢٣: «هذا حديث حسن غريب». وقال ابن القيسراني في ذخيرة الحفاظ ٢/٧٧٤ (١٤٧٩): «رواه سُهيل بن أبي حزم، عن ثابت، عن أنس. ولم يُتابع عليه، وفيه ضعف». وقال ابن الديبع في مكفرات الذنوب ص٨٩: «إسناد جيد».|2:أخرجه ابن مردويه -كما في تخريج الكشاف ٤/١٢٢-، من طريق أحمد بن عبد الرحمن بن مفضل الحراني، عن يحيى بن ساج الحراني، عن سليم بن عبد الله الأحمر، عن عبد الله بن دينار به.</p><p>وفي سنده يحيى بن ساج الحراني، وسليم بن عبد الله الأحمر، ولم أقف لهما على ترجمة.|3:أخرجه الحكيم الترمذي في نوادر الأصول ٢/٣٤ مرسلًا.|4:أخرجه ابن جرير ٢٣/٤٦٤، كما أخرجه عبد الرزاق ٢/٣٣٢ من طريق معمر بنحوه، ومثله ابن جرير ٢٣/٤٦٤. وعزاه السيوطي إلى عَبد بن حُمَيد، وابن المنذر.|5:تفسير مقاتل بن سليمان ٤/٥٠١.|6:أخرجه أحمد في الزهد ٤٤١.
  75,1,"<div class=ar lang=ar><p><h3>مقدمة السورة</h3></p><p><div></p><p><p><span class="item-no">٧٩٩٧٦<span class="dash">-</span></span> عن عبد الله بن عباس -من طريق مجاهد- قال: نزلت سورةُ القيامة -وفي لفظ: نزلت سورة: <span class="qpc-hafs">﴿لا أُقْسِمُ بِيَوْمِ القِيامَةِ﴾</span> بمكة{1}. (١٥/٩٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٩٧٧<span class="dash">-</span></span> عن عبد الله بن عباس -من طريق عطاء الخُراسانيّ-: مكّيّة، وذكرها بمسمى: <span class="qpc-hafs">﴿لا أُقْسِمُ بِيَوْمِ القِيامَةِ﴾</span>، ونزلت بعد سورة القارعة{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٩٧٨<span class="dash">-</span></span> عن عبد الله بن الزُّبير، قال: نزلت سورة: <span class="qpc-hafs">﴿لا أُقْسِمُ﴾</span> بمكة{3}. (١٥/٩٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٩٧٩<span class="dash">-</span></span> عن عكرمة مولى ابن عباس= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٩٨٠<span class="dash">-</span></span> والحسن البصري -من طريق يزيد النحوي-: مكّيّة، وذكراها بمسمى: <span class="qpc-hafs">﴿لا أُقْسِمُ بِيَوْمِ القِيامَةِ﴾</span>{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٩٨١<span class="dash">-</span></span> عن قتادة بن دعامة -من طرق-: مكّيّة{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٩٨٢<span class="dash">-</span></span> عن محمد بن مسلم الزُّهريّ: سورة <span class="qpc-hafs">﴿لا أُقْسِمُ بِيَوْمِ القِيامَةِ﴾</span> مكّيّة، ونزلت بعد القارعة{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٩٨٣<span class="dash">-</span></span> عن علي بن أبي طلحة: مكّيّة، وذكرها بمسمى: <span class="qpc-hafs">﴿لا أُقْسِمُ بِيَوْمِ القِيامَةِ﴾</span>، ونزلت بعد سورة القارعة{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٩٨٤<span class="dash">-</span></span> قال مقاتل بن سليمان: سورة القيامة مكّيّة، عددها أربعون آية كوفي{8}<span class=comment-ref>٦٨٩٣</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٨٩٣</span> <span class="comment-type-4">ذكر</span> <u>ابنُ عطية</u> (٨/٤٦٩) أنّ هذه السورة مكّيّة <span class="mustanad">بإجماع من أهل التأويل</span>.</div></p><p><div></p><p><p><span class="item-no">٧٩٩٨٥<span class="dash">-</span></span> عن قتادة، قال: حُدِّثنا أنّ <span class="name-1">عمر بن الخطاب</span> قال: مَن سأل عن يوم القيامة فليقرأ هذه السورة{9}. (١٥/٩٥)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿لَاۤ أُقۡسِمُ بِیَوۡمِ ٱلۡقِیَـٰمَةِ ۝١﴾</span> - قراءات</h3></p><p><div></p><p><p><span class="item-no">٧٩٩٨٦<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٩٨٧<span class="dash">-</span></span> و<span class="name-2">الأعرج</span> أنهما كانا يقرآن: ‹لَأُقْسِمُ بِيَوْمِ القِيامَةِ›{10}<span class=comment-ref>٦٨٩٤</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٨٩٤</span> اختُلف في قراءة قوله: <span class="qpc-hafs">﴿لا أقسم بيوم القيامة﴾</span>؛ <b>فقرأ قوم</b>: <span class="qpc-hafs">﴿لا أقسم﴾</span> <span class="qpc-hafs">﴿لا﴾</span> مفصولة من <span class="qpc-hafs">﴿أقسم﴾</span>. <b>وقرأ آخرون</b>: <span class="qpc-hafs">﴿لأقسم بيوم القيامة﴾</span>.</p><p>و<span class="comment-type-4">ذكر</span> <u>ابنُ جرير</u> (٢٣/٤٦٥) أنّ القراءة الثانية بمعنى: أُقسِم بيوم القيامة، ثم أُدخلتْ عليها لام القَسم.</p><p>و<span class="comment-type-4">ذكر</span> <u>ابنُ عطية</u> (٨/٤٧٠) أنّ القراءة الثانية تحتمل أمرين: <b>الأول</b>: أن تكون اللام دَخلتْ على فعل الحال، والتقدير: لأنا أُقسِم، فلا تلحق النون؛ لأنّ النون إنما تَدخل في الأكثر لتفرق بين فعل الحال والفعل المستقبل، فهي تَلزم المستقبل في الأكثر. <b>الثاني</b>: أن يكون الفعل خالصًا للاستقبال، فكان الوجه والأكثر أن تَلحق النون، إمّا الخفيفة وإما الثقيلة، ثم قال: «لكن قد ذكر سيبويه أنّ النون قد تَسقط مع إرادة الاستقبال وتُغني اللام عنها، كما تَسقط اللام وتُغني النون عنها».</p><p>و<span class="comment-type-3">رجَّح</span> <u>ابنُ جرير</u> القراءة الأولى <span class="mustanad">مستندًا إلى إجماع القراء</span>، فقال: «والقراءة التي لا أستجيز غيرها في هذا الموضع <span class="qpc-hafs">﴿لا﴾</span> مفصولة، <span class="qpc-hafs">﴿أقسم﴾</span> مُبتدأة، على ما عليه قرأة الأمصار؛ لإجماع الحُجّة من القُراء عليه».</div></p><p><h3><span class="qpc-hafs">﴿لَاۤ أُقۡسِمُ بِیَوۡمِ ٱلۡقِیَـٰمَةِ ۝١﴾</span> - تفسير الآية</h3></p><p><div></p><p><p><span class="item-no">٧٩٩٨٨<span class="dash">-</span></span> عن سعيد بن جُبَير، قال: سألتُ <span class="name-1">ابن عباس</span> عن قوله: <span class="qpc-hafs">﴿لا أُقْسِمُ بِيَوْمِ القِيامَةِ﴾</span>. قال: يُقسِم ربّك بما شاء من خَلْقه{11}. (١٥/٩٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٩٨٩<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جُبَير</span> -من طريق الحسن بن مسلم بن يَنّاق- في قوله: <span class="qpc-hafs">﴿لا أُقْسِمُ بِيَوْمِ القِيامَةِ﴾</span>، يقول: أُقسِم{12}. (١٥/٩٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٩٩٠<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق قتادة- قال: أقسَم بيوم القيامة، ولم يُقسِم بالنفس اللوامة{13}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٩٩١<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span>، <span class="qpc-hafs">﴿لا أُقْسِمُ بِيَوْمِ القِيامَةِ﴾</span>، قال: يُقسِم الله بما شاء من خَلْقه{11}. (١٥/٩٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٩٩٢<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- قولَه: <span class="qpc-hafs">﴿لا أُقْسِمُ بِيَوْمِ القِيامَةِ ولا أُقْسِمُ بِالنَّفْسِ اللَّوّامَةِ﴾</span>، قال: أقسَم بهما جميعًا{15}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٩٩٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ما أقسَم الله بالكافرين في القرآن في غير هذه السورة، قوله تعالى: <span class="qpc-hafs">﴿لا أُقْسِمُ بِيَوْمِ القِيامَةِ﴾</span> نظيرها: <span class="qpc-hafs">﴿واليَوْمِ المَوْعُودِ﴾</span> [البروج:٢]. قال: وكان أهل الجاهلية إذا أراد الرجل أن يُقسِم قال: لا أُقسِم{16}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٩٩٤<span class="dash">-</span></span> عن <span class="name-3">أبي بكر بن عيّاش</span> -من طريق أبي هشام الرفاعي- يقول: قوله: <span class="qpc-hafs">﴿لا أُقْسِمُ﴾</span> توكيد للقَسَم، كقوله: لا واللهِ{17}<span class=comment-ref>٦٨٩٥</span><span class=comment-ref>٦٨٩٦</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٨٩٥</span> اختُلف في <span class="qpc-hafs">﴿لا﴾</span> المُبتدأ بها في قوله تعالى: <span class="qpc-hafs">﴿لا أقسم بيوم القيامة﴾</span> على ثلاثة أقوال: <b>الأول</b>: أنها صلة، ومعنى الكلام: أُقسِم بيوم القيامة. <b>الثاني</b>: أنها دخلت توكيدًا للكلام. <b>الثالث</b>: أنها ردٌّ لكلام مضى من كلام المشركين في إنكار البعث، ثم ابتدأ القَسم فقال: أُقسِم بيوم القيامة. ونسبه <u>ابنُ جرير</u> (٢٣/٤٦٨) لبعض نحاة الكوفة. و<span class="comment-type-4">ذكر</span> أنّ مَن قال بالقول الثالث كان يقول: كلّ يمين قبلها ردّ لكلام، فلابد من تقديم «لا» قبلها؛ ليُفرَّق بذلك بين اليمين التي تكون جحدًا، واليمين التي تستأنف، ويقول: ألا ترى أنك تقول مُبتدئًا: واللهِ، إنّ الرسول لحقّ. وإذا قلتَ: لا، واللهِ إنّ الرسول لحقّ. فكأنك أكذبتَ قومًا أنكروه. و<span class="comment-type-3">رجَّحه</span> <span class="mustanad">مستندًا إلى اللغة</span>، فقال: «لأنّ المعروف من كلام الناس في محاوراتهم إذا قال أحدهم: لا واللهِ، لا فعلتُ كذا، أنه يقصد بـ»لا«ردّ الكلام، وبقوله: واللهِ، ابتداء يمين، وكذلك قولهم: لا أُقسِم بالله لا فعلتُ كذا. فإذا كان المعروف من معنى ذلك ما وصفنا فالواجب أن يكون سائر ما جاء من نظائره جاريًا مجراه، ما لم يخرج شيء من ذلك عن المعروف بما يجب التسليم له».</div></p><p><div><span class=comment-ref>٦٨٩٦</span> اختُلف هل قوله: <span class="qpc-hafs">﴿ولا أقسم بالنفس باللوامة﴾</span> قَسَم أم لا؟ على قولين: <b>الأول</b>: أنه تعالى أقسَم بالنفس اللوامة كما أقسَم بيوم القيامة؛ فيكونان قسمين. <b>الثاني</b>: أنه أقسَم بيوم القيامة ولم يُقسِم بالنفس اللوامة، ويكون تقدير الكلام: أُقسِم بيوم القيامة، ولا أُقسِم بالنفس اللوامة.</p><p>و<span class="comment-type-3">رجَّح</span> <u>ابنُ جرير</u> (٢٣/٤٦٨) -<span class="mustanad">مستندًا إلى اللغة</span>- القول الأول الذي قاله ابن عباس، وقتادة، وذلك أنّ «الجميع من الحُجّة مُجمِعون على أنّ قوله: <span class="qpc-hafs">﴿لا أقسم بيوم القيامة﴾</span> قَسَم، فكذلك قوله: <span class="qpc-hafs">﴿ولا أقسم بالنفس اللوامة﴾</span> إلا أن تأتي حُجّة تدل على أنّ أحدهما قَسَم والآخر خبر. وقد دللنا على أنّ قراءة مَن قرأ الحرف الأول»لأقسم«بوصل اللام بـ»أقسم«قراءة غير جائزة بخلافها ما عليه الحُجّة مُجمِعة».</p><p>و<span class="comment-type-3">رجَّحه</span> <u>ابنُ كثير</u> (١٤/١٩٢)، فقال: «والصحيح أنه أقسَم بهما جميعًا». ولم يذكر مستندًا.</p><p>و<span class="comment-type-4">ذكر</span> <u>ابنُ عطية</u> (٨/٤٧١) أنّ الجمهور على هذا القول.</p><p>و<span class="comment-type-4">ذكر</span> ابنُ كثير أنّ قراءة الوصل «لأقسم» توجّه القول الثاني الذي قاله الحسن؛ لأنه أثبتَ القَسَم بيوم القيامة، ونفى القَسَم بالنفس اللوامة.</p><p>و<span class="comment-type-2">انتقد</span> <u>ابنُ عطية</u> القول الثاني، فقال: «وذلك قلق، وهو في القراءة الثانية أمكن» أي: قراءة: «لأقسم» بالوصل.</div></p><p><h3><span class="qpc-hafs">﴿لَاۤ أُقۡسِمُ بِیَوۡمِ ٱلۡقِیَـٰمَةِ ۝١﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٧٩٩٩٥<span class="dash">-</span></span> عن <span class="name-1">المُغيرة بن شعبة</span> -من طريق زياد بن عِلاقة- قال: يقولون: القيامة القيامة، وإنما قيامة أحدهم موته{18}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٩٩٦<span class="dash">-</span></span> عن أبي قيس، قال: شهدتُ جنازة فيها <span class="name-2">عَلقمة</span>، فلما دُفِن قال: أمّا هذا فقد قامتْ قيامته{19}<span class=comment-ref>٦٨٩٧</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٨٩٧</span> ساق <u>ابنُ عطية</u> (٨/٤٦٩) هذين الأثرين، ثم <span class="comment-type-4">علَّق</span>، بقوله: «وقيامة الرجل في خاصته ليست بالقيامة الجامعة لجميع الخَلْق بعد البعث. لكن المُغيرة ﵁ كأنه قال هذا لمن يستبعد قيام الآخرة، ويظن طول الأمد بينه وبينها، فتوعّده بقيامة نفسه».</div></p></div>",footnotes:1:أخرجه أبو جعفر النحاس في الناسخ والمنسوخ ص٧٥٧ من طريق أبي عمرو بن العلاء عن مجاهد، والبيهقي في دلائل النبوة ٧/١٤٢-١٤٤ من طريق خُصَيف عن مجاهد. وعزاه السيوطي إلى ابن مردويه.|2:أخرجه ابن الضريس في فضائل القرآن ١/٣٣-٣٥.|3:عزاه السيوطي إلى ابن مردويه.|4:أخرجه البيهقي في دلائل النبوة ٧/١٤٢-١٤٣.|5:أخرجه الحارث المحاسبي في فهم القرآن ص٣٩٥-٣٩٦ من طريق سعيد، وأبو بكر ابن الأنباري -كما في الإتقان ١/٥٧- من طريق همام.|6:تنزيل القرآن ص٣٧-٤٢.|7:أخرجه أبو عبيد في فضائله (ت: الخياطي) ٢/٢٠٠.|8:تفسير مقاتل بن سليمان ٤/٥٠٧.|9:عزاه السيوطي إلى عبد بن حميد، وابن المنذر.|10:أخرجه ابن جرير ٢٣/٤٦٥.</p><p>وهي قراءة متواترة، قرأ بها ابن كثير بخلف عن البزي، وقرأ بقية العشرة: <span class="qpc-hafs">﴿لَآ أُقْسِمُ﴾</span> بألف بعد اللام، وهي الرواية الثانية عن البزي. انظر: ٢/٢٨٢، والإتحاف ص٥٦٣.|11:أخرجه ابن جرير ٢٣/٤٦٧، والحاكم ٢/٥٠٨-٥٠٩. وعزاه السيوطي إلى ابن المنذر.|12:أخرجه ابن جرير ٢٣/٤٦٦ بلفظ: أقسم بيوم القيامة. وعزاه السيوطي إلى ابن المنذر.|13:أخرجه ابن جرير ٢٣/٤٦٧-٤٦٨.|14:أخرجه ابن جرير ٢٣/٤٦٧، والحاكم ٢/٥٠٨-٥٠٩. وعزاه السيوطي إلى ابن المنذر.|15:أخرجه ابن جرير ٢٣/٤٦٧.|16:تفسير مقاتل بن سليمان ٤/٥٠٩.|17:أخرجه ابن جرير ٢٣/٤٦٦.|18:أخرجه ابن جرير ٢٣/٤٦٨.|19:أخرجه ابن جرير ٢٣/٤٦٩.
  75,2,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَلَاۤ أُقۡسِمُ بِٱلنَّفۡسِ ٱللَّوَّامَةِ ۝٢﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٩٩٩٧<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- في قوله: <span class="qpc-hafs">﴿بِالنَّفْسِ اللَّوّامَةِ﴾</span>، قال: المذمومة{1}. (١٥/٩٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٩٩٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، <span class="qpc-hafs">﴿بِالنَّفْسِ اللَّوّامَةِ﴾</span>، قال: التي تلوم على الخير والشر، تقول: لو فعلتُ كذا وكذا{2}. (١٥/٩٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٩٩٩٩<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، <span class="qpc-hafs">﴿بِالنَّفْسِ اللَّوّامَةِ﴾</span>، قال: تَندم على ما فاتَ، وتلوم عليه{3}. (١٥/٩٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٠٠٠<span class="dash">-</span></span> عن سعيد بن جُبَير، قال: سألتُ <span class="name-1">ابن عباس</span> عن: <span class="qpc-hafs">﴿ولا أُقْسِمُ بِالنَّفْسِ اللَّوّامَةِ﴾</span>. قال: النفس اللؤوم{4}. (١٥/٩٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٠٠١<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جُبَير</span> -من طريق الحسن بن مسلم- في قوله: <span class="qpc-hafs">﴿ولا أُقْسِمُ بِالنَّفْسِ اللَّوّامَةِ﴾</span>، قال: تلوم على الخير والشرِّ{5}<span class=comment-ref>٦٨٩٨</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٨٩٨</span> <span class="comment-type-4">ذكر</span> <u>ابنُ عطية</u> (٨/٤٧١) أنّ النفس في هذه الآية اسم جنس لنفوس البشر، ثم ساق قول ابن جُبَير، و<span class="comment-type-4">بيّن</span> أنه قال بأنها اسم جنس.</div></p><p><div></p><p><p><span class="item-no">٨٠٠٠٢<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- <span class="qpc-hafs">﴿بِالنَّفْسِ اللَّوّامَةِ﴾</span>، قال: تَندم على ما فاتَ، وتلوم عليه{6}. (١٥/٩٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٠٠٣<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span> -من طريق سِماك- <span class="qpc-hafs">﴿ولا أُقْسِمُ بِالنَّفْسِ اللَّوّامَةِ﴾</span>، قال: تلوم على الخير والشر{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٠٠٤<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span>، <span class="qpc-hafs">﴿ولا أُقْسِمُ بِالنَّفْسِ اللَّوّامَةِ﴾</span>، قال: إنّ المؤمن لا تراه إلا يلوم نفسه: ما أردتُ بكلمتي؟! ما أردتُ بأكلتي؟! ما أردتُ بحديثى نفسي؟! ولا أراه إلا يُعاتبها، وإنّ الفاجر يمضي قُدُمًا لا يُعاتب نفسه{8}<span class=comment-ref>٦٨٩٩</span>. (١٥/٩٧)</p></p><p></div></p><p><div><span class=comment-ref>٦٨٩٩</span> <span class="comment-type-4">ذكر</span> <u>ابنُ عطية</u> (٨/٤٧١) أنّ الحسن قال: النفس اللوامة هي اللوامة لصاحبها في ترْك الطاعة ونحوه. و<span class="comment-type-4">علَّق</span> عليه بقوله: «فهي -على هذا- ممدوحة، ولذلك أقسَم الله تعالى بها».</div></p><p><div></p><p><p><span class="item-no">٨٠٠٠٥<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿ولا أُقْسِمُ بِالنَّفْسِ اللَّوّامَةِ﴾</span>، قال: اللوامة: الفاجرة. قال: لم يُقسِم بها{9}<span class=comment-ref>٦٩٠٠</span>. (١٥/٩٦)</p></p><p></div></p><p><div><span class=comment-ref>٦٩٠٠</span> ساق <u>ابنُ عطية</u> (٨/٤٧١) هذا القول، ثم <span class="comment-type-4">علَّق</span> بقوله: «فهي [أي: النفس] -على هذا- ذميمة، وعلى هذا التأويل يَحسن نفي القَسَم بها».</div></p><p><div></p><p><p><span class="item-no">٨٠٠٠٦<span class="dash">-</span></span> عن <span class="name-2">محمد بن كعب القُرَظيّ</span> -من طريق سعيد-: ما من نفس يوم القيامة، صالحة ولا غيرها، إلا وهو يلوم نفسه، وهو قول الله: <span class="qpc-hafs">﴿النَّفْسِ اللَّوّامَةِ﴾</span>{10}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٠٠٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ولا أُقْسِمُ بِالنَّفْسِ اللَّوّامَةِ﴾</span> يقول: أُقْسِمُ بالنفس الكافرة التي تلوم نفسها في الآخرة، فتقول: <span class="qpc-hafs">﴿يا لَيْتَنِي قَدَّمْتُ لِحَياتِي﴾</span> [الفجر:٢٤]، <span class="qpc-hafs">﴿يا حَسْرَتا عَلى ما فَرَّطْتُ فِي جَنْبِ اللَّهِ﴾</span> [الزمر:٥٦]. يعني: في أمْر الله في الدنيا{11}<span class=comment-ref>٦٩٠١</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٩٠١</span> في وصف النفس باللوامة قولان: <b>الأول</b>: أنها صفة مدح، وهو قول مَن جعلها قَسمًا. <b>الثاني</b>: أنها صفة ذم، وهو قول مَن نفى أن يكون قَسمًا. ومَن جعلها مدحًا له في تفسيرها قولان: <b>الأول</b>: أنها التي تلوم على الخير والشر. <b>الثاني</b>: أنها تلوم على ما فاتَ وتَندم. ومَن جعلها صفة ذم له في تفسيرها قولان: <b>الأول</b>: أنها الفاجرة. <b>الثاني</b>: المذمومة.</p><p>و<span class="comment-type-4">رأى</span> <u>ابنُ جرير</u> (٢٣/٤٧٠) تقارب هذه الأقوال، فقال: «وهذه الأقوال التي ذكرناها عمن ذكرناها عنه، وإن اختلفتْ بها ألفاظ قائليها، فمتقاربات المعاني». ثم <span class="comment-type-3">رجَّح</span> (٢٣/٤٧٠-٤٧١) القول بأنها صفة مدح، وهو القول الذي قاله ابن عباس، وسعيد بن جُبَير، وعكرمة، ومجاهد-<span class="mustanad">مستندًا إلى إجماع القُراء على قراءة الفصل التي تفيد القسم</span>-، فقال: «وأشبه القول في ذلك بظاهر التنزيل أنها تلوم صاحبها على الخير والشر، وتَندم على ما فاتَ، والقُراء كلّهم مُجمِعون على قراءة هذه بفصل <span class="qpc-hafs">﴿لا﴾</span> من <span class="qpc-hafs">﴿أقسم﴾</span>».</p><p>و<span class="comment-type-4">ذكر</span> <u>ابنُ عطية</u> (٨/٤٧١) <b>قولًا</b> بأنّ المراد: نفس آدم؛ لأنها لم تزل اللائمة له على فِعْله الذي أخرجه من الجنة. ثم قال: «وكلّ نفس متوسطة ليستْ بالمطمئنة ولا بالأمارة بالسوء فإنها لوامة في الطرفين؛ مرة تلوم على ترْك الطاعة، ومرة تلوم على فَوْت ما تشتهي، فإذا اطمأنتْ خلصتْ وصَفتْ».</div></p></div>",footnotes:1:أخرجه ابن جرير ٢٣/٤٧٠. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.|2:عزاه السيوطي إلى عبد بن حميد، وابن المنذر.|3:عزاه السيوطي إلى ابن المنذر.|4:أخرجه ابن جرير ٢٣/٤٦٩، والحاكم ٢/٥٠٨-٥٠٩. وعزاه السيوطي إلى ابن المنذر.|5:أخرجه ابن جرير ٢٣/٤٦٩.|6:أخرجه ابن جرير ٢٣/٤٧٠. وعزاه السيوطي إلى عبد بن حميد.|7:أخرجه ابن جرير ٢٣/٤٦٩.|8:ذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٥/٦٣-. وعزاه السيوطي إلى ابن أبي الدنيا في محاسبة النفس، وعبد بن حميد.|9:أخرجه ابن جرير ٢٣/٤٧٠ مقتصرًا على قوله: «أي: الفاجرة»، والحاكم ٢/٥٠٨-٥٠٩. وعزاه السيوطي إلى ابن المنذر.|10:أخرجه عبد الله بن وهب في الجامع -تفسير القرآن ٢/٩١-٩٢ (١٧٢).|11:تفسير مقاتل بن سليمان ٤/٥٠٩.
  75,3,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿أَیَحۡسَبُ ٱلۡإِنسَـٰنُ أَلَّن نَّجۡمَعَ عِظَامَهُۥ ۝٣﴾</span> - نزول الآية</h3></p><p><div></p><p><p><span class="item-no">٨٠٠٠٨<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿أيَحْسَبُ﴾</span> هذا الإنسان، يعني: عَدِيّ بن ربيعة بن أبي سَلمة خَتن الأَخْنس بن شَريق، وكان حليفًا لبني زهرة، فكَفر بالبعْث، وذلك أنه أتى رسول الله ﷺ، فقال: يا محمد، حدِّثني عن يوم القيامة متى يكون؟ وكيف أمرها وحالها؟ فأَخبَره النبيُّ ﷺ بذلك. فقال: لو عاينتُ ذلك اليوم سأومن بك. ثم قال: يا محمد، أوَيجمع الله العظامَ يوم القيامة؟ قال: «<b>نعم</b>». فاستهزأ منه؛ فأَنزَل الله -جلّ وعزّ-: <span class="qpc-hafs">﴿لا أُقْسِمُ بِيَوْمِ القِيامَةِ ولا أُقْسِمُ بِالنَّفْسِ اللَّوّامَةِ أيَحْسَبُ الإنْسانُ ألَّنْ نَجْمَعَ عِظامَهُ﴾</span>{1}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿أَیَحۡسَبُ ٱلۡإِنسَـٰنُ أَلَّن نَّجۡمَعَ عِظَامَهُۥ ۝٣﴾</span> - تفسير الآية</h3></p><p><div></p><p><p><span class="item-no">٨٠٠٠٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿أيَحْسَبُ الإنْسانُ ألَّنْ نَجْمَعَ عِظامَهُ﴾</span>، يقول: أن لن نَبعثه من بعد الموت، فأَقسَم الله تعالى أن يَبعثه كما كان{2}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٤/٥٠٩-٥١٠.|2:تفسير مقاتل بن سليمان ٤/٥١٠.
  75,4,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿بَلَىٰ قَـٰدِرِینَ عَلَىٰۤ أَن نُّسَوِّیَ بَنَانَهُۥ ۝٤﴾</span> - نزول الآية</h3></p><p><div></p><p><p><span class="item-no">٨٠٠١٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: نزلت هذه الآية في عَدِيّ بن ربيعة، والأَخْنس بن شَريق{1}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿بَلَىٰ قَـٰدِرِینَ عَلَىٰۤ أَن نُّسَوِّیَ بَنَانَهُۥ ۝٤﴾</span> - تفسير الآية</h3></p><p><div></p><p><p><span class="item-no">٨٠٠١١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق حُصَين- <span class="qpc-hafs">﴿بَلى قادِرِينَ عَلى أنْ نُسَوِّيَ بَنانَهُ﴾</span>، قال: نَجعلها كفًّا ليس فيه أصابع{2}. (١٥/٩٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٠١٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق مجاهد- <span class="qpc-hafs">﴿بَلى قادِرِينَ عَلى أنْ نُسَوِّيَ بَنانَهُ﴾</span>، قال: نَجعله مثل خُفّ البعير{3}. (١٥/٩٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٠١٣<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطية العَوفيّ- <span class="qpc-hafs">﴿بَلى قادِرِينَ عَلى أنْ نُسَوِّيَ بَنانَهُ﴾</span>، قال: أنا قادر على أنْ أجعل كفَّه مُجَمَّرةً مثل خُفّ البعير{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٠١٤<span class="dash">-</span></span> عن سعيد بن جُبَير، قال: سألتُ <span class="name-1">ابنَ عباس</span> عن قوله: <span class="qpc-hafs">﴿أيَحْسَبُ الإنْسانُ ألَّنْ نَجْمَعَ عِظامَهُ بَلى قادِرِينَ عَلى أنْ نُسَوِّيَ بَنانَهُ﴾</span>. قال: لو شاء لَجَعله خُفًّا أو حافرًا{5}. (١٥/٩٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٠١٥<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- <span class="qpc-hafs">﴿عَلى أنْ نُسَوِّيَ بَنانَهُ﴾</span>، قال: يَجعل رِجليه كخُفّ البعير؛ فلا يَعمل بها شيئًا{6}. (١٥/٩٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٠١٦<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span> -من طريق النَّضر- <span class="qpc-hafs">﴿عَلى أنْ نُسَوِّيَ بَنانَهُ﴾</span>، قال: إن شاء ردّه مثل خُفّ البعير حتى لا يَنتفع به{7}. (١٥/٩٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٠١٧<span class="dash">-</span></span> عن <span class="name-2">الضَّحّاك بن مُزاحِم</span> -من طريق عبيد- <span class="qpc-hafs">﴿عَلى أنْ نُسَوِّيَ بَنانَهُ﴾</span>، قال: البنان: الأصابع. يقول: نحن قادرون على أن نَجعل بَنانه مثل خُفّ البعير{8}. (١٥/٩٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٠١٨<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق أبي رجاء- أنه قرأ هذه الآية: <span class="qpc-hafs">﴿بَلى قادِرِينَ عَلى أنْ نُسَوِّيَ بَنانَهُ﴾</span>، فقال: إنّ الله أعفَّ مَطعم ابن آدم، ولم يَجعله خُفًّا ولا حافرًا، فهو يأكل بيديه، ويتّقي بها، وسائر الدواب إنما يتّقي الأرض بفَمِه{9}. (١٥/٩٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٠١٩<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- <span class="qpc-hafs">﴿بَلى قادِرِينَ عَلى أنْ نُسَوِّيَ بَنانَهُ﴾</span>، قال: لو شاء لجَعله كخُفّ البعير أو كحافر الدابة، ولكن جَعله الله خَلْقًا سَويًّا حسنًا جميلًا، تَقبض به وتَبسط به، يا ابن آدمَ{10}. (١٥/٩٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٠٢٠<span class="dash">-</span></span> قال <span class="name-2">محمد بن كعب القُرَظيّ</span> -من طريق أبي صخر- <span class="qpc-hafs">﴿بَلى قادِرِينَ عَلى أنْ نُسَوِّيَ بَنانَهُ﴾</span>، قال: لو شاء لَجَعله خنزيرًا حمارًا{11}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٠٢١<span class="dash">-</span></span> عن غَيلان بن جرير، عن أصحابه، في قوله: <span class="qpc-hafs">﴿بلى قادرين على أن نسوي بنانه﴾</span>، قال: قادرين على أن نَجعلها مثل رُبعٍ{12}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٠٢٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿بَلى قادِرِينَ﴾</span> كُنّا قادرين <span class="qpc-hafs">﴿عَلى أنْ نُسَوِّيَ بَنانَهُ﴾</span> أصابعه، يعني: على أن نُلحق الأصابع بالراحة، ونُسويّه حتى نَجعله مثل خُفّ البعير، فلا يَنتفع بها كما لا يَنتفع البعير بها ما كان حيًّا{1}<span class=comment-ref>٦٩٠٢</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٩٠٢</span> <span class="comment-type-4">ذكر</span> <u>ابنُ عطية</u> (٨/٤٧٢) أنّ المعنى: أنّ الكفار لمّا استبعدوا جمْع العظام بعد الفناء والإرمام، قيل لهم: إنما تُجمع ويُسوّى أكثرها تفرقًا وأدقّها أجزاء، وهي عظام الأنامل ومفاصلها، وهذا كلّه عند البعث.</p><p>و<span class="comment-type-4">بنحوه</span> قال <u>ابنُ القيم</u> (٣/٢٢٦).</p><p>ثم ساق <u>ابنُ عطية</u> هذا القول بأنّ المراد: جعل بَنان الإنسان في هذه الحياة بُضعة أو عظمًا واحدًا كخُفّ البعير لا تفاريق فيه. و<span class="comment-type-4">علَّق</span> عليه بقوله: «فكأن المعنى: قادرين الآن في الدنيا على أن نَجعلها دون تفرّق، فتقِلّ منفعته بيده، فكأن التقدير: بلى نحن أهلٌ أن نجمعها، قادرين الآن على إزالة منفعته بيده، ففي هذا توعّد ما».</p><p>و<span class="comment-type-4">علَّق</span> <u>ابنُ القيم</u> (٣/٢٢٦) على هذا القول بقوله: «والمعنى على هذا القول: إنّا في الدنيا قادرون على أن نَجعل عظام بَنانه مجموعة دون تفرّق، فكيف لا نقدر على جمْعها بعد تفريقها، فهذا وجه من الاستدلال غير الأول، وهو الاستدلال بقدرته سبحانه على جمْع العظام بعد تفريقها».</p><p>و<span class="comment-type-3">رجح</span> <u>ابنُ عطية</u> -<span class="mustanad">مستندًا إلى السياق</span>- أنّ المراد بالجمع في الآخرة، فقال: «والقول الأول أجرى مع رصف الكلام». ثم قال: «ولكن على هذا القول الآخر [أي:تسوية البنان في الدنيا] جمهور العلماء».</p><p>و<span class="comment-type-4">علَّق</span> <u>ابنُ القيم</u> (٣/٢٢٧) على القولين بقوله: «وهما وجهان حسنان، وكلّ منهما له ترجيح من وجه؛ فيرجّح الأول أنه هو المقصود، وهو الذي أنكره الكفار، وهو إجراء على نسق الكلام واطراده، ولأنّ الكلام لم يُسَق لجمْع العظام وتفريقها في الدنيا، وإنما سيق لجمْعها في الآخرة بعد تفرّقها بالموت. ويرجّح القول الثاني -ولعله قول جمهور المفسرين-، حتى إنّ فيهم من لم يذكر غيره، وأنه استدلال بآية ظاهرة مشهورة، وهي تفريق البنان مع انتظامها في كفّ واحد وارتباط بعضها ببعض فهي متفرّقة في عضو واحد، يَقبض منها واحدة ويَبسط أخرى ويُحرّك واحدة والأخرى ساكنة، ويَعمل بواحدة والأخرى مُعطّلة، وكلّها في كفّ واحد، قد جمَعها ساعد واحد، فلو شاء سبحانه لسَوّاها فجعلها صفة واحدة كباطن الكفّ، ففاتَه هذه المنافع والمصالح التي حَصلتْ بتفريقها، ففي هذا أعظم الأدلة على قدرته سبحانه على جمْع عظامه بعد الموت».</div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٤/٥١٠.|2:أخرجه سعيد بن منصور في سننه -التفسير ٨/٢١٥ (٢٣٤٨).|3:أخرجه عبد الرزاق ٢/٣٣٣، وابن جرير ٢٣/٤٧٢ بنحوه من طريق سعيد. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.|4:أخرجه ابن جرير ٢٣/٤٧١.|5:أخرجه ابن جرير ٢٣/٤٧١، والحاكم ٢/٥٠٨-٥٠٩. وعزاه السيوطي إلى ابن المنذر.|6:أخرجه ابن جرير ٢٣/٤٧٢. وعزاه السيوطي إلى عبد بن حميد.|7:أخرجه ابن جرير ٢٣/٤٧٢ بنحوه. وعزاه السيوطي إلى عبد بن حميد.|8:أخرجه ابن جرير ٢٣/٤٧٣. وعزاه السيوطي إلى ابن المنذر بلفظ: على أن نَجعل يديه ورجليه مثل خُفّ البعير.|9:أخرجه ابن جرير ٢٣/٤٧٢ بنحوه. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.|10:أخرجه عبد الرزاق ٢/٣٣٣، وابن جرير ٢٣/٤٧٣، كذلك من طريق سعيد. وعزاه السيوطي إلى عبد بن حميد.|11:أخرجه عبد الله بن وهب في الجامع -تفسير القرآن ٢/١٤٧ (٢٩٧).|12:أخرجه سعيد بن منصور في سننه -التفسير ٨/٢١٥ (٢٣٤٧). قال محققه: «كذا في الأصل، لكن وضع ضمة على الباء». والظاهر أنّ المراد: نجعلها مثل يد الرُبَع أو قدمه، والربع هو ولد الناقة في أول النتاج، ولا أصابع له، ويؤيده رواية ابن عباس السابقة: «كفًّا ليس فيه أصابع».|13:تفسير مقاتل بن سليمان ٤/٥١٠.
  75,5,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿بَلۡ یُرِیدُ ٱلۡإِنسَـٰنُ لِیَفۡجُرَ أَمَامَهُۥ ۝٥﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٨٠٠٢٣<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق أبي الخير بن تميم، عن سعيد بن جُبَير- في قوله: <span class="qpc-hafs">﴿بَلْ يُرِيدُ الإنْسانُ لِيَفْجُرَ أمامَهُ﴾</span>، قال: يمضي قُدُمًا{1}. (١٥/٩٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٠٢٤<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق سعيد بن جُبَير- في قوله: <span class="qpc-hafs">﴿بَلْ يُرِيدُ الإنْسانُ لِيَفْجُرَ أمامَهُ﴾</span>، قال: يقول: سوف أتوب{2}. (١٥/١٠٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٠٢٥<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق سعيد بن جُبَير- <span class="qpc-hafs">﴿بَلْ يُرِيدُ الإنْسانُ لِيَفْجُرَ أمامَهُ﴾</span>، قال: يُقدِّم الذَّنب، ويُؤخِّر التوبة{3}. (١٥/٩٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٠٢٦<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- في قوله: <span class="qpc-hafs">﴿بَلْ يُرِيدُ الإنْسانُ لِيَفْجُرَ أمامَهُ﴾</span>، قال: هو الكافر يُكذّب بالحساب{4}. (١٥/٩٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٠٢٧<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطية العَوفيّ- <span class="qpc-hafs">﴿بَلْ يُرِيدُ الإنْسانُ لِيَفْجُرَ أمامَهُ﴾</span>: يعني: الأمل، يقول: أعمل ثم أتوب{5}. (١٥/٩٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٠٢٨<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جُبَير</span> -من طريق أبي إسحاق- <span class="qpc-hafs">﴿لِيَفْجُرَ أمامَهُ﴾</span>، قال: سوف أتوب{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٠٢٩<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- <span class="qpc-hafs">﴿بَلْ يُرِيدُ الإنْسانُ لِيَفْجُرَ أمامَهُ﴾</span>، قال: يمضي أمامه راكبًا رأسه{7}. (١٥/٩٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٠٣٠<span class="dash">-</span></span> عن <span class="name-2">الضَّحّاك بن مُزاحِم</span> -من طريق عبيد- يقول في قوله: <span class="qpc-hafs">﴿بَلْ يُرِيدُ الإنْسانُ لِيَفْجُرَ أمامَهُ﴾</span>: هو الأمل؛ يُؤّمل الإنسان: أعيش وأُصيب من الدنيا كذا، وأُصيب كذا. ولا يَذكر الموت{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٠٣١<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span> -من طريق النَّضر- <span class="qpc-hafs">﴿بَلْ يُرِيدُ الإنْسانُ لِيَفْجُرَ أمامَهُ﴾</span>، قال: قُدمًا لا يَنزع عن فُجور{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٠٣٢<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق معمر- <span class="qpc-hafs">﴿بَلْ يُرِيدُ الإنْسانُ لِيَفْجُرَ أمامَهُ﴾</span>، قال: يمضي قُدُمًا في معاصي الله{10}. (١٥/٩٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٠٣٣<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق قتادة- <span class="qpc-hafs">﴿بَلْ يُرِيدُ الإنْسانُ لِيَفْجُرَ أمامَهُ﴾</span>، قال: لا تَلقى ابن آدم إلا تَنزع نفسه إلى معصية الله قُدُمًا قُدُمًا، إلا مَن قد عَصَم الله{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٠٣٤<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿بَلْ يُرِيدُ الإنْسانُ لِيَفْجُرَ أمامَهُ﴾</span>، قال: لا تَلقى ابن آدم إلا تَنزع نفسه إلى معصية الله قُدُمًا قُدُمًا، إلا مَن عَصَم الله{12}. (١٥/٩٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٠٣٥<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق عمرو- <span class="qpc-hafs">﴿بَلْ يُرِيدُ الإنْسانُ لِيَفْجُرَ أمامَهُ﴾</span>، قال: قُدُمًا{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٠٣٦<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span>: <span class="qpc-hafs">﴿بَلْ يُرِيدُ الإنْسانُ لِيَفْجُرَ أمامَهُ﴾</span>، يعني: لِيَظلم على قدر طاقته{14}<span class=comment-ref>٦٩٠٣</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٩٠٣</span> <span class="comment-type-4">ذكر</span> <u>ابنُ عطية</u> (٨/٤٧٢) أنّ الضمير في قوله: <span class="qpc-hafs">﴿أمامه﴾</span> عائد على الإنسان على هذا القول الذي قاله ابن عباس من طريق أبي الخير، وابن جُبَير، والعَوفيّ، وقاله مجاهد، والحسن، وعكرمة، وابن جُبَير، والضَّحّاك، والسُّدِّيّ.</div></p><p><div></p><p><p><span class="item-no">٨٠٠٣٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿بَلْ يُرِيدُ الإنْسانُ﴾</span> يعني: عديّ بن ربيعة <span class="qpc-hafs">﴿لِيَفْجُرَ أمامَهُ﴾</span> يعني: تقديم المعصية وتأخير التوبة يومًا بيوم، يقول: سأتوب، حتى يموت على شرّ عَمَله، وقد أهلك أمامه{15}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٠٣٨<span class="dash">-</span></span> قال <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿بَلْ يُرِيدُ الإنْسانُ لِيَفْجُرَ أمامَهُ﴾</span>، قال: يُكذّب بما أمامه يوم القيامة والحساب{16}<span class=comment-ref>٦٩٠٤</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٩٠٤</span> اختُلف في المراد بقوله: <span class="qpc-hafs">﴿بل يريد الإنسان ليفجر أمامه﴾</span> على أقوال: <b>الأول</b>: معناه: أن يُعجِّل الذَّنب، ويُسوّف التوبة. <b>الثاني</b>: بل يريد أن يرتكب الآثام في الدنيا لقوة أمله، ولا يذكر الموت. <b>الثالث</b>: بل يريد الإنسان ليَكفر بالحقّ الذي بين يدي القيامة. <b>الرابع</b>: بل يريد الإنسان الكافر أن يُكذّب بالقيامة.</p><p>و<span class="comment-type-3">رجَّح</span> <u>ابنُ القيم</u> (٣/٢٢٧-٢٢٨) -<span class="mustanad">مستندًا إلى السياق، واللغة</span>- القول الأخير الذي قاله ابن عباس من طريق علي، وقاله ابن زيد، فقال: «ويُرجّح هذا القول لفظة <span class="qpc-hafs">﴿بلى﴾</span>؛ فإنها تُعطي أنّ الإنسان لم يؤمن بيوم القيامة، مع هذا البيان والحُجّة، بل هو مريد للتكذيب به، ويُرجّحه أيضًا أنّ السياق كلّه في ذم المُكذّب بيوم القيامة، لا في ذم العاصي والفاجر، وأيضًا فإنّ ما قبل الآية وما بعدها يدل على المراد. فإنه قال: <span class="qpc-hafs">﴿أيَحْسَبُ الأِنْسانُ ألَّنْ نَجْمَعَ عِظامَهُ بَلى قادِرِينَ عَلى أنْ نُسَوِّيَ بَنانَهُ﴾</span> فأنكر -سبحانه- عليه حِسْبانه أنّ الله لا يَجمع عظامه، ثم قَرّر قدرته على ذلك، ثم أنكر عليه إرادة التكذيب بيوم القيامة. فالأول حِسبانٌ منه أن لا يُحييه بعد موته. والثاني: تكذيب منه بيوم البعث، وأنه يريد أن يُكذّب بما وضح وبان دليل وقوعه وثبوته؛ فهو مريد للتكذيب به. ثم أخبر عن تصريحه بالتكذيب، فقال: <span class="qpc-hafs">﴿يَسْأَلُ أيّانَ يَوْمُ القِيامَةِ﴾</span>، فالأول إرادة التكذيب، والثاني نطق بالتكذيب وتكلم به».</p><p>و<span class="comment-type-4">بنحوه</span> <u>ابنُ كثير</u> (١٤/١٩٤)، فقال: «وهذا هو الأظهر من المراد؛ ولهذا قال بعده: <span class="qpc-hafs">﴿يسأل أيان يوم القيامة﴾</span> أي: يقول متى يكون يوم القيامة؟! وإنما سؤاله سؤال استبعاد لوقوعه، وتكذيب لوجوده، <span class="mustanad">كما قال تعالى</span>: <span class="qpc-hafs">﴿ويقولون متى هذا الوعد إن كنتم صادقين قل لكم ميعاد يوم لا تستأخرون عنه ساعة ولا تستقدمون﴾</span> [سبأ:٢٩-٣٠]».</p><p>و<span class="comment-type-4">ذكر</span> <u>ابنُ جرير</u> (٢٣/٤٧٧) أنّ الضمير في قوله: <span class="qpc-hafs">﴿أمامه﴾</span> على القول الثالث الذي قاله ابن عباس عائد على «يوم القيامة».</p><p>و<span class="comment-type-4">بنحوه</span> قال <u>ابنُ عطية</u> (٨/٤٧٢)، ثم <span class="comment-type-4">بيّن</span> أنّ المعنى -على هذا القول-: «أنّ الإنسان هو في زمان وجوده أمام يوم القيامة وبين يديه، ويوم القيامة خلفه، فهو يريد شهواته ليَفْجُر في تكذيبه بالبعْث، وغير ذلك بين يدي يوم القيامة، وهو لا يعرف قدر الضرر الذي هو فيه».</div></p></div>",footnotes:1:أخرجه ابن جرير ٢٣/٤٧٥.|2:أخرجه آدم بن أبي إياس -كما في تفسير مجاهد ص٦٨٦-، والفريابي -كما في التغليق ٤/٣٥٥-، وابن جرير ٢٣/٤٧٧-٤٧٨ في تفسير الآية التالية، والحاكم ٢/٥٠٩، والبيهقي (٧٢٣٢). وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.|3:أخرجه ابن أبي الدنيا (٢٠٥)، والبيهقي (١٠٦٧٣).|4:أخرجه ابن جرير ٢٣/٤٧٧ بنحوه، وابن أبي حاتم -كما في فتح الباري ٨/٦٨١-.|5:أخرجه ابن جرير ٢٣/٤٧٥. وعلقه البخاري في صحيحه ٦/١٦٣.|6:أخرجه ابن جرير ٢٣/٤٧٦.|7:أخرجه ابن جرير ٢٣/٤٧٥. وعزاه السيوطي إلى عبد بن حميد.|8:أخرجه ابن جرير ٢٣/٤٧٦.|9:أخرجه ابن جرير ٢٣/٤٧٦.|10:أخرجه عبد الرزاق ٢/٣٣٣، وابن جرير ٢٣/٤٧٥-٤٧٦ بنحوه. وعزاه السيوطي إلى عبد بن حميد.|11:أخرجه ابن جرير ٢٣/٤٧٥.|12:أخرجه ابن جرير ٢٣/٤٧٥-٤٧٦. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.|13:أخرجه ابن جرير ٢٣/٤٧٦.|14:تفسير الثعلبي ١٠/٨٣.|15:تفسير مقاتل بن سليمان ٤/٥١٠.|16:أخرجه ابن جرير ٢٣/٤٧٧.
  75,6,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿یَسۡـَٔلُ أَیَّانَ یَوۡمُ ٱلۡقِیَـٰمَةِ ۝٦﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٨٠٠٣٩<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق سعيد بن جُبَير- في قوله: <span class="qpc-hafs">﴿يَسْأَلُ أيّانَ يَوْمُ القِيامَةِ﴾</span> قال: يقول: متى يوم القيامة. قال: فبَيّن له؛ <span class="qpc-hafs">﴿فَإذا بَرِقَ البَصَرُ﴾</span> [القيامة: ٧]{1}. (١٥/١٠٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٠٤٠<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿يَسْأَلُ أيّانَ يَوْمُ القِيامَةِ﴾</span> يقول: متى يوم القيامة؟! قال: وقال <span class="name-1">عمر بن الخطاب</span> ﵁: مَن سأل عن يوم القيامة فليقرأ هذه السورة{2}. (١٥/٩٥، ٩٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٠٤١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿يَسْأَلُ أيّانَ يَوْمُ القِيامَةِ﴾</span> يعني: يسأل عَدِيّ: متى يوم القيامة؟! تكذيبًا بها{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٠٤٢<span class="dash">-</span></span> قال <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿يَسْأَلُ أيّانَ يَوْمُ القِيامَةِ﴾</span> متى يكون ذلك. فقرأ: <span class="qpc-hafs">﴿وجُمِعَ الشَّمْسُ والقَمَرُ﴾</span> [القيامة:٩]، قال: فكذلك يكون يوم القيامة{4}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه آدم بن أبي إياس -كما في تفسير مجاهد ص٦٨٦-، والفريابي -كما في التغليق ٤/٣٥٥-، وابن جرير ٢٣/٤٧٧-٤٧٨، والحاكم ٢/٥٠٩، والبيهقي (٧٢٣٢). وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.|2:أخرجه ابن جرير ٢٣/٤٧٨. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.|3:تفسير مقاتل بن سليمان ٤/٥١٠.|4:أخرجه ابن جرير ٢٣/٤٧٨.
  75,7,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿فَإِذَا بَرِقَ ٱلۡبَصَرُ ۝٧﴾</span> - قراءات</h3></p><p><div></p><p><p><span class="item-no">٨٠٠٤٣<span class="dash">-</span></span> عن هارون، قال: سألتُ <span class="name-2">أبا عمرو بن العلاء</span> عنها، فقال: <span class="qpc-hafs">﴿بَرِقَ﴾</span> -بالكسر- بمعنى: حار.= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٠٤٤<span class="dash">-</span></span> قال: وسألتُ عنها <span class="name-2">عبد الله ابن أبي إسحاق</span>، فقال: ‹بَرَقَ› بالفتح. وقال: إنما بَرِق الحَنظل اليابس، وما بَرِق البصر؟! قال: فذكرتُ ذلك لأبي عمرو فقال: إنما يَبرُقُ الحَنظل والنار والبَرْق، وأما البصر فبَرِق عند الموت. قال: فأَخبرتُ بذلك أبا إسحاق، فقال: أخذتُ قراءتي عن الأشياخ؛ نصر بن عاصم وأصحابه. فذكرتُ ذلك لأبي عمرو، فقال: لكني لا آخذ عن نصر ولا عن أصحابه. كأنه يقول: آخذ عن أهل الحجاز{1}<span class=comment-ref>٦٩٠٥</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٩٠٥</span> اختُلف في قراءة قوله: <span class="qpc-hafs">﴿برق﴾</span>؛ <b>فقرأ قوم</b>: ‹بَرَقَ› بفتح الراء. <b>وقرا آخرون</b> بكسرها.</p><p>و<span class="comment-type-4">ذكر</span> <u>ابنُ جرير</u> (٢٣/٤٧٨) أنّ معنى قراءة الفتح: شَخص، وفَتح عند الموت. وأنّ معنى قراءة الكسر: فَزع وشقّ. وبنحوه قال <u>ابنُ عطية</u> (٨/٤٧٣).</p><p>و<span class="comment-type-4">ذكر</span> <u>ابنُ كثير</u> (١٤/١٩٤) أنّ ما قاله أبو عمرو بن العلاء شبيه بقوله تعالى: <span class="qpc-hafs">﴿لا يرتد إليهم طرفهم﴾</span> [إبراهيم:٤٣]، بل ينظرون من الفزع هكذا وهكذا، لا يَستقرّ لهم بصرٌ على شيء؛ من شدة الرُّعب.</p><p>و<span class="comment-type-3">رجَّح</span> <u>ابنُ جرير</u> (٢٣/٤٧٩) قراءة الكسر <span class="mustanad">مستندًا إلى اللغة</span>، فقال: «وأولى القراءتين في ذلك عندنا بالصواب كسر الراء <span class="qpc-hafs">﴿فإذا برق﴾</span>، بمعنى: فزعِ فشُقّ وفُتح من هول القيامة وفزَع الموت، وبذلك جاءت أشعار العرب».</p><p>و<span class="comment-type-4">ذكر</span> <u>ابنُ عطية</u> (٨/٤٧٣) أنّ المعنى متقارب في القراءتين.</p><p>و<span class="comment-type-4">بنحوه</span> قال <u>ابنُ كثير</u> (١٤/١٩٤).</div></p><p><h3><span class="qpc-hafs">﴿فَإِذَا بَرِقَ ٱلۡبَصَرُ ۝٧﴾</span> - تفسير الآية</h3></p><p><div></p><p><p><span class="item-no">٨٠٠٤٥<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطية العَوفيّ- في قوله: <span class="qpc-hafs">﴿فَإذا بَرِقَ البَصَرُ﴾</span>: يعني: الموت{2}. (١٥/١٠٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٠٤٦<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿فَإذا بَرِقَ البَصَرُ﴾</span>، قال: عند الموت{3}. (١٥/١٠٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٠٤٧<span class="dash">-</span></span> قال <span class="name-2">الحسن البصري</span>: <span class="qpc-hafs">﴿فَإذا بَرِقَ البَصَرُ﴾</span>، يعني: يوم القيامة{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٠٤٨<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿فَإذا بَرِقَ البَصَرُ﴾</span>، قال: شَخَص البصر{5}. (١٥/١٠٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٠٤٩<span class="dash">-</span></span> قال <span class="name-2">قتادة</span>: شَخَص البصر، فلا يَطرِفُ مما يَرى من العجائب مما كان يُكذّب به في الدنيا أنه غير كائن{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٠٥٠<span class="dash">-</span></span> قال <span class="name-3">محمد بن السّائِب الكلبي</span>: <span class="qpc-hafs">﴿فَإذا بَرِقَ البَصَرُ﴾</span> عند رؤية جهنم بَرق أبصار الكفار{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٠٥١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فَإذا بَرِقَ البَصَرُ﴾</span> إذا شَخَص البصر، فلا يَطرِفُ مما يَرى من العجائب التي يراها مما كان يَكفر بها في الدنيا أنّه غير كائن، مثلها في سورة: <span class="qpc-hafs">﴿ق والقُرْآنِ المَجِيد﴾</span>{8}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ٢٣/٤٧٨.</p><p>و‹بَرَقَ›، و<span class="qpc-hafs">﴿بَرِقَ﴾</span> قراءتان متواترتان، قرأ بالأولى منها نافع، وأبو جعفر، وقرأ بقية العشرة بالثانية. انظر: النشر ٢/٣٩٣، والإتحاف ص٥٦٣.|2:أخرجه ابن جرير ٢٣/٤٨٠.|3:أخرجه ابن جرير ٢٣/٤٨٠. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.|4:ذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٥/٦٤-. وقال عقبه: أي: شَخَص لإجابة الداعي، كقوله: <span class="qpc-hafs">﴿لا يَرْتَدُّ إلَيْهِمْ طَرْفُهُمْ﴾</span> [إبراهيم:٤٣].|5:أخرجه عبد الرزاق ٢/٣٣٣، وابن جرير ٢٣/٤٨٠. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.|6:تفسير الثعلبي ١٠/٨٤.|7:تفسير البغوي ٨/٢٨١.|8:تفسير مقاتل بن سليمان ٤/٥١٠. وفي تفسير الثعلبي ١٠/٨٤ نحوه منسوبًا إلى مقاتل دون تعيينه.
  75,8,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَخَسَفَ ٱلۡقَمَرُ ۝٨﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٨٠٠٥٢<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق قتادة- <span class="qpc-hafs">﴿وخَسَفَ القَمَرُ﴾</span>: هو ضوءه، يقول: ذَهب ضوءه{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٠٥٣<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿وخَسَفَ القَمَرُ﴾</span>، يقول: وذَهب ضَوْءُ القمر؛ فلا ضوء له{2}. (١٥/١٠٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٠٥٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وخَسَفَ القَمَرُ﴾</span> فذَهب ضوءه{3}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ٢٣/٤٨١.|2:أخرجه ابن جرير ٢٣/٤٨١، كما أخرج عبد الرزاق ٢/٣٣٣ نحوه من طريق معمر. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.|3:تفسير مقاتل بن سليمان ٤/٥١٠.
  75,9,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَجُمِعَ ٱلشَّمۡسُ وَٱلۡقَمَرُ ۝٩﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٨٠٠٥٥<span class="dash">-</span></span> قال <span class="name-1">علي بن أبي طالب</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٠٥٦<span class="dash">-</span></span> و<span class="name-1">عبد الله بن عباس</span>: <span class="qpc-hafs">﴿وجُمِعَ الشَّمْسُ والقَمَرُ﴾</span> يُجعلان في نور الحُجُب{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٠٥٧<span class="dash">-</span></span> عن <span class="name-2">عطاء بن يَسار</span> -من طريق زيد بن أسلم- في قوله: <span class="qpc-hafs">﴿وجُمِعَ الشَّمْسُ والقَمَرُ﴾</span>، قال: يُجمعان يوم القيامة، ثم يُقذفان في البحر، فيكون نار الله الكُبرى{2}. (١٥/١٠١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٠٥٨<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿وخَسَفَ القَمَرُ وجُمِعَ الشَّمْسُ والقَمَرُ﴾</span>، قال: كُوِّرا يوم القيامة{3}. (١٥/١٠٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٠٥٩<span class="dash">-</span></span> قال <span class="name-2">الحسن البصري</span>: <span class="qpc-hafs">﴿وجُمِعَ الشَّمْسُ والقَمَرُ﴾</span>، أي: جَمَعهما جميعًا{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٠٦٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وجُمِعَ الشَّمْسُ والقَمَرُ﴾</span> كالبَقَرتَيْن المقْرُونَتَيْن يوم القيامة قِيامًا بين يدي الخلائق{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٠٦١<span class="dash">-</span></span> عن <span class="name-3">عبد الملك ابن جُرَيْج</span>، في قوله: <span class="qpc-hafs">﴿وجُمِعَ الشَّمْسُ والقَمَرُ﴾</span>، قال: كُوِّرا يوم القيامة{6}. (١٥/١٠١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٠٦٢<span class="dash">-</span></span> قال <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿وجُمِعَ الشَّمْسُ والقَمَرُ﴾</span>، قال: جُمعا، فرُمي بهما في الأرض. وقوله: <span class="qpc-hafs">﴿إذا الشَّمْسُ كُوِّرَتْ﴾</span> [التكوير:١]، قال: كُوِّرت في الأرض والقمر معها{7}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير الثعلبي ١٠/٨٤.|2:أخرجه ابن جرير ٢٣/٤٨٢. وعزاه السيوطي إلى ابن المنذر.|3:أخرجه ابن جرير ٢٣/٤٨٢. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.|4:ذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٥/٦٤-.|5:تفسير مقاتل بن سليمان ٤/٥١٠.|6:عزاه السيوطي إلى ابن المنذر.|7:أخرجه ابن جرير ٢٣/٤٨٢.
  75,10,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿یَقُولُ ٱلۡإِنسَـٰنُ یَوۡمَىِٕذٍ أَیۡنَ ٱلۡمَفَرُّ ۝١٠﴾</span> - قراءات</h3></p><p><div></p><p><p><span class="item-no">٨٠٠٦٣<span class="dash">-</span></span> عن عبد الله بن خالد، قال: قرأها <span class="name-1">ابن عباس</span>: (أيْنَ المَفِرُّ) بنصب الميم وكسر الفاء.= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٠٦٤<span class="dash">-</span></span> قال: وقرأها <span class="name-2">يحيى بن وثّاب</span>: <span class="qpc-hafs">﴿أيْنَ المَفَرُّ﴾</span> بنصب الميم والفاء{1}<span class=comment-ref>٦٩٠٦</span>. (١٥/١٠١)</p></p><p></div></p><p><div><span class=comment-ref>٦٩٠٦</span> اختُلف في قراءة قوله: <span class="qpc-hafs">﴿المفر﴾</span>؛ <b>فقرأ قوم:</b> <span class="qpc-hafs">﴿المفَر﴾</span>. و<b>قرأ آخرون</b>: (المَفِرُّ).</p><p>و<span class="comment-type-4">ذكر</span> <u>ابنُ عطية</u> (٨/٤٧٤) أنّ قراءة الفتح على المصدر، أي: أين الفرار. وأنّ قراءة الكسر على معنى: أين موضع الفرار.</p><p>وبنحوه قال <u>ابنُ جرير</u> (٢٣/٤٨٢-٤٨٤).</p><p>و<span class="comment-type-3">رجَّح</span> <u>ابنُ جرير</u> (٢٣/٤٨٤) قراءة الفتح <span class="mustanad">مستندًا إلى إجماع القُراء، والأشهر في اللغة</span>، فقال: «لإجماع الحُجّة من القُراء عليها، وأنها اللغة المعروفة في العرب إذا أُريد بها الفرار، وهو في هذا الموضع: الفرار».</div></p><p><h3><span class="qpc-hafs">﴿یَقُولُ ٱلۡإِنسَـٰنُ یَوۡمَىِٕذٍ أَیۡنَ ٱلۡمَفَرُّ ۝١٠﴾</span> - تفسير الآية</h3></p><p><div></p><p><p><span class="item-no">٨٠٠٦٥<span class="dash">-</span></span> عن الأوزاعي، قال: سمعتُ <span class="name-2">بلال بن سعد</span> يقول في قوله تعالى: <span class="qpc-hafs">﴿ولو ترى إذ فزعوا فلا فوت﴾</span> [سبأ:٥١]. قال: ذلك قوله تعالى: <span class="qpc-hafs">﴿يقول الإنسان يومئذ أين المفر﴾</span>{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٠٦٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿يَقُولُ الإنْسانُ يَوْمَئِذٍ أيْنَ المَفَرُّ﴾</span>، يعني: أين المَهْرب حتى أُحْرِزَ{3} نفسي{4}. (ز)</p></p><p></div></p></div>",footnotes:1:عزاه السيوطي إلى أبي عبيد، وعبد بن حميد، وابن المنذر.</p><p>و<span class="qpc-hafs">﴿المَفَرُّ﴾</span> بفتح الميم ونصب الفاء قراءة العشرة، وأما (المَفِرُّ) بكسر الفاء فهي قراءة شاذة، تروى أيضًا عن الحسين بن علي، والحسن بن يزيد، والزهري. انظر: المحتسب ٢/٤١٣، ومختصر ابن خالويه ص١٦٦.|2:أخرجه أبو نعيم في حلية الأولياء ٥/٢٢٧.|3:أُحْرِز نفسي: أحفظها. النهاية (حرز).|4:تفسير مقاتل بن سليمان ٤/٥١١.
  75,11,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿كَلَّا لَا وَزَرَ ۝١١﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٨٠٠٦٧<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن مسعود</span>، في قوله: <span class="qpc-hafs">﴿لا وزَرَ﴾</span>، قال: لا حِصْن{1}. (١٥/١٠٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٠٦٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- في قوله: <span class="qpc-hafs">﴿لا وزَرَ﴾</span>، قال: لا حِرْز{2}. (١٥/١٠١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٠٦٩<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطية- في قوله: <span class="qpc-hafs">﴿لا وزَرَ﴾</span>، قال: لا حِصْن، ولا مَلْجأ. وفي لفظ: لا جَبل{2}. (١٥/١٠١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٠٧٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>: أنّ نافع بن الأزرق قال له: أخبِرني عن قوله: <span class="qpc-hafs">﴿لا وزَرَ﴾</span>. قال: الوَزَرُ: المَلْجأُ. قال: وهل تعرف العرب ذلك؟ قال: نعم، أما سمعتَ عمرو بن كُلثوم وهو يقول{4}:</p><p>لعَمْرك ما إن له صُحرةٌ{5} لعَمْرك ما إن له من وزَر{6}. (١٥/١٠١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٠٧١<span class="dash">-</span></span> عن <span class="name-2">مُطَرِّف [بن عبد الله]</span> <span class="name-2">بن الشِّخِّير</span> -من طريق أدهم- <span class="qpc-hafs">﴿لا وزَرَ﴾</span>، قال: لا جَبل{7}. (١٥/١٠٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٠٧٢<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جُبَير</span> -من طريق مولى للحسن- <span class="qpc-hafs">﴿لا وزَرَ﴾</span>: لا حِصْن{8}. (١٥/١٠٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٠٧٣<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿لا وزَرَ﴾</span>، قال: لا جَبل{9}. (١٥/١٠٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٠٧٤<span class="dash">-</span></span> عن <span class="name-2">الضَّحّاك بن مُزاحِم</span>، <span class="qpc-hafs">﴿لا وزَرَ﴾</span>، قال: لا جَبل يُحرِزُهُ{10}. (١٥/١٠٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٠٧٥<span class="dash">-</span></span> عن <span class="name-2">الضَّحّاك بن مُزاحِم</span> -من طريق عبيد- في قوله: <span class="qpc-hafs">﴿لا وزَرَ﴾</span>، قال: يعني: الجَبل، بلغة حِمْيَر{11}. (١٥/١٠٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٠٧٦<span class="dash">-</span></span> عن <span class="name-2">الضَّحّاك بن مُزاحِم</span> -من طريق أبي حُجَير- في قوله: <span class="qpc-hafs">﴿لا وزَرَ﴾</span>: لا حِصْن{11}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٠٧٧<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span>-من طريق سعيد بن مسروق- في قوله: <span class="qpc-hafs">﴿كلا لا وزر﴾</span>، قال: لا مَلْجأ، ولا مَنعًا{13}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٠٧٨<span class="dash">-</span></span> عن <span class="name-2">أبي قلابة عبد الله بن زيد الجرمي</span>، <span class="qpc-hafs">﴿لا وزَرَ﴾</span>، قال: لا غار، لا مَلْجأ{14}. (١٥/١٠٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٠٧٩<span class="dash">-</span></span> عن <span class="name-2">أبي قِلابة عبد الله بن زيد الجرمي</span> -من طريق شَبيب- في قوله: <span class="qpc-hafs">﴿كَلّا لا وزَرَ﴾</span>، قال: لا حِصْن{15}. (١٥/١٠٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٠٨٠<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span>، في قوله: <span class="qpc-hafs">﴿كَلّا لا وزَرَ﴾</span>، قال: كانت العرب إذا نزل بهم الأمر الشديد قالوا: الوَزَر الوَزَر. فلمّا أنْ جاء الله بالإسلام قال: <span class="qpc-hafs">﴿كَلّا لا وزَرَ﴾</span>، قال: لا جَبل{16}. (١٥/١٠٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٠٨١<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق أبي رجاء- قال: كان الرجل يكون في ماشيته، فتَأتيه الخيل بَغْتة، فيقول له صاحبه: الوَزَر الوَزَر. أي: اقصِد الجبل؛ فتَحصّنْ به{17}. (١٥/١٠٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٠٨٢<span class="dash">-</span></span> عن <span class="name-2">عطية بن سعد العَوفيّ</span>: لا حِصْن{10}. (١٥/١٠٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٠٨٣<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق مسلم بن طهمان- في قوله: <span class="qpc-hafs">﴿لا وزَرَ﴾</span>، يقول: لا حِصْن{19}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٠٨٤<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span>، قال: <span class="qpc-hafs">﴿لا وزَرَ﴾</span>، قال: لا جَبل، ولا حِرْز، ولا مَلْجأ، ولا مَنجى{20}. (١٥/١٠٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٠٨٥<span class="dash">-</span></span> قال <span class="name-2">إسماعيل السُّدِّيّ</span>: <span class="qpc-hafs">﴿لا وزَرَ﴾</span> لا جَبل. وكانوا إذا فَزعوا لجؤوا إلى الجبل، فتَحصّنوا به، فقال الله تعالى: لا جَبل يومئذ يَمنعهم{21}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٠٨٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿كَلّا لا وزَرَ﴾</span> يعني: لا جَبل يُحرِزُك، ويُسمّي حِمْيَرُ الجبل: وزَر{22}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٠٨٧<span class="dash">-</span></span> قال <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿كَلّا لا وزَرَ﴾</span>، قال: لا مُتغيَّبَ يَتغيَّبُ فيه من ذلك الأمْر الذي لا مَنجى له منه{11}<span class=comment-ref>٦٩٠٧</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٩٠٧</span> <span class="comment-type-4">ذكر</span> <u>ابنُ عطية</u> (٨/٤٧٤) أنّ المفسرين عبّروا عن الوَزَر بالجبل، و<span class="comment-type-4">نَقل</span> عن مُطَرِّف بن الشِّخِّير وغيره أنهم قالوا: «كان وزَر فِرار العرب في بلادهم، فلذلك استُعمل». ثم <span class="comment-type-3">رجَّح</span> أنه المَلْجأ أيًّا كان، فقال: «والحقيقة أنه المَلْجأ؛ جبلًا كان أو حِصنًا أو سلاحًا أو رجلًا أو غيره». ولم يذكر مستندًا.</div></p></div>",footnotes:1:أخرجه ابن أبي حاتم -كما في فتح الباري ٨/٦٨١-. وعزاه السيوطي إلى ابن أبي الدنيا في الأهوال، وعبد بن حميد، وابن المنذر.|2:أخرجه ابن جرير ٢٣/٤٨٤. وعزاه السيوطي إلى ابن أبي الدنيا في الأهوال، وعبد بن حميد، وابن المنذر، وابن أبي حاتم.|3:أخرجه ابن جرير ٢٣/٤٨٤. وعزاه السيوطي إلى ابن أبي الدنيا في الأهوال، وعبد بن حميد، وابن المنذر، وابن أبي حاتم.|4:البيت في مصدر التخريج وسيرة ابن هشام ١/٣٩، ٤٠ لابن الذئبة الثقفي، واسمه ربيعة بن عبد ليل بن سالم.|5:أصحر المكان: اتسع. القاموس المحيط (صحر).|6:عزاه السيوطي إلى الطستي، وهو في مسائل نافع (٤٣).|7:أخرجه ابن جرير ٢٣/٤٨٥. وعزاه السيوطي إلى عبد بن حميد. وزاد ابن جرير في رواية: إنّ الناس إذا فَرُّوا قالوا عليك بالوَزَر.|8:أخرجه ابن جرير ٢٣/٤٨٧. وعزاه السيوطي إلى عبد بن حميد.|9:أخرجه ابن جرير ٢٣/٤٨٦ بلفظ: لا مَلْجأ ولا جَبل. وعزاه السيوطي إلى عبد بن حميد.|10:عزاه السيوطي إلى عبد بن حميد.|11:أخرجه ابن جرير ٢٣/٤٨٧.|12:أخرجه ابن جرير ٢٣/٤٨٧.|13:أخرجه سعيد بن منصور في سننه -التفسير ٨/٢١٧ (٢٣٥٠).|14:عزاه السيوطي إلى عبد بن حميد، وابن جرير.|15:أخرجه ابن جرير ٢٣/٤٨٦. وعزاه السيوطي إلى عبد بن حميد.|16:عزاه السيوطي إلى عبد بن حميد. وأخرج آخره ابن جرير ٢٣/٤٨٥ من طريق قتادة، وأبي مودود.|17:أخرجه ابن جرير ٢٣/٤٨٥-٤٨٦ بنحوه. وعزاه السيوطي إلى ابن المنذر.|18:عزاه السيوطي إلى عبد بن حميد.|19:أخرجه ابن جرير ٢٣/٤٨٦.|20:عزاه السيوطي إلى عبد بن حميد. وأخرجه عبد الرزاق ٢/٣٣٣ من طريق معمر بلفظ: لا جَبل، ومثله ابن جرير ٢٣/٤٨.|21:تفسير الثعلبي ١٠/٨٥، وتفسير البغوي ٨/٢٨٢.|22:تفسير مقاتل بن سليمان ٤/٥١١.|23:أخرجه ابن جرير ٢٣/٤٨٧.
  75,12,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿إِلَىٰ رَبِّكَ یَوۡمَىِٕذٍ ٱلۡمُسۡتَقَرُّ ۝١٢﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٨٠٠٨٨<span class="dash">-</span></span> قال <span class="name-1">عبد الله بن مسعود</span>: <span class="qpc-hafs">﴿إلى رَبِّكَ يَوْمَئِذٍ المُسْتَقَرُّ﴾</span> المصير والمرجع{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٠٨٩<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- قال: <span class="qpc-hafs">﴿إلى رَبِّكَ يَوْمَئِذٍ المُسْتَقَرُّ﴾</span>، قال: المُنتهى{2}. (١٥/١٠٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٠٩٠<span class="dash">-</span></span> قال <span class="name-2">إسماعيل السُّدِّيّ</span>: <span class="qpc-hafs">﴿إلى رَبِّكَ يَوْمَئِذٍ المُسْتَقَرُّ﴾</span> المُنتهى{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٠٩١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿إلى رَبِّكَ يَوْمَئِذٍ المُسْتَقَرُّ﴾</span>، يعني: المُنتهى يومئذ إلى الله ﷿، لا تَجد عنه مرحلًا{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٠٩٢<span class="dash">-</span></span> قال <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿إلى رَبِّكَ يَوْمَئِذٍ المُسْتَقَرُّ﴾</span>، قال: استَقرّ أهل الجنة في الجنة، وأهل النار في النار. وقرأ قول الله: <span class="qpc-hafs">﴿وإنَّ الدّارَ الآخِرَةَ لَهِيَ الحَيَوانُ لَوْ كانُوا يَعْلَمُونَ﴾</span> [العنكبوت:٦٤]{5}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير البغوي ٨/٢٨٢.|2:أخرجه ابن جرير ٢٣/٤٨٨. وعزاه السيوطي إلى عبد بن حميد.|3:تفسير البغوي ٨/٢٨٢.|4:تفسير مقاتل بن سليمان ٤/٥١١.|5:أخرجه ابن جرير ٢٣/٤٨٨.
  75,13,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿یُنَبَّؤُا۟ ٱلۡإِنسَـٰنُ یَوۡمَىِٕذِۭ بِمَا قَدَّمَ وَأَخَّرَ ۝١٣﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٨٠٠٩٣<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن مسعود</span> -من طريق زياد بن أبي مريم- في قوله: <span class="qpc-hafs">﴿يُنَبَّأُ الإنْسانُ يَوْمَئِذٍ بِما قَدَّمَ وأَخَّرَ﴾</span>، قال: بما قَدّم من عمله، وما أخَّر مِن سُنَّةٍ عُمِل بها مِن بعده؛ مِن خير أو شرٍّ{1}. (١٥/١٠٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٠٩٤<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- <span class="qpc-hafs">﴿يُنَبَّأُ الإنْسانُ يَوْمَئِذٍ بِما قَدَّمَ وأَخَّرَ﴾</span>، قال: بما عَمِل قبل موته، وما سَنَّ فعُمِل به بعد موته{2}. (١٥/١٠٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٠٩٥<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطية العَوفيّ- في قوله: <span class="qpc-hafs">﴿يُنَبَّأُ الإنْسانُ يَوْمَئِذٍ بِما قَدَّمَ وأَخَّرَ﴾</span>، يقول: بما قَدّم مِن المعصية، وأَخَّر من الطاعة، فيُنبّأ بذلك{3}. (١٥/١٠٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٠٩٦<span class="dash">-</span></span> عن <span class="name-2">إبراهيم النَّخَعي</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٠٩٧<span class="dash">-</span></span> و<span class="name-2">مجاهد بن جبر</span> -من طريق منصور- <span class="qpc-hafs">﴿يُنَبَّأُ الإنْسانُ يَوْمَئِذٍ بِما قَدَّمَ وأَخَّرَ﴾</span>، قالا: بأول عَمَله وآخره{4}. (١٥/١٠٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٠٩٨<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span>، قال: بلّغنا: أنّ نفس المؤمن لا تَخرج حتى يُعرض عليه عَمَله؛ خيره وشرّه{5}. (١٥/١٠٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠٠٩٩<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span>، في الآية، قال: بما قَدّم مِن الذّنوب والشر والخطايا، وما أخَّر من الخير{6}. (١٥/١٠٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠١٠٠<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span>، في قوله: <span class="qpc-hafs">﴿يُنَبَّأُ الإنْسانُ يَوْمَئِذٍ بِما قَدَّمَ وأَخَّرَ﴾</span>، قال: يُنزِّل مَلَك الموت عليه عند الموت حَفظته، فيُعرَض عليه الخير والشر، فإذا رأى حسنة بَهَش{7} وأَشرق، وإذا رأى سيئة غَضَّ وقَطَّب{8}. (١٥/١٠٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠١٠١<span class="dash">-</span></span> قال <span class="name-2">عطاء</span>: <span class="qpc-hafs">﴿يُنَبَّأُ الإنْسانُ يَوْمَئِذٍ بِما قَدَّمَ وأَخَّرَ﴾</span> بما قَدّم في أول عُمره، وما أخَّر في آخر عُمره{9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠١٠٢<span class="dash">-</span></span> عن <span class="name-2">أبي صالح باذام</span>، في قوله: <span class="qpc-hafs">﴿يُنَبَّأُ الإنْسانُ يَوْمَئِذٍ بِما قَدَّمَ وأَخَّرَ﴾</span>، قال: قَدّم مِن حسنة، أو أخَّر من سُنَّة حسنة عُمِل بها بعده؛ عِلمًا عَلّمه، صدقة أمَر بها{10}. (١٥/١٠٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠١٠٣<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- قال: <span class="qpc-hafs">﴿يُنَبَّأُ الإنْسانُ يَوْمَئِذٍ بِما قَدَّمَ﴾</span> قال: مِن طاعة الله، <span class="qpc-hafs">﴿وأَخَّرَ﴾</span> قال: وما ضيَّع من حقّ الله{11}. (١٥/١٠٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠١٠٤<span class="dash">-</span></span> قال <span class="name-2">زيد بن أسلم</span>: <span class="qpc-hafs">﴿يُنَبَّأُ الإنْسانُ يَوْمَئِذٍ بِما قَدَّمَ وأَخَّرَ﴾</span> بما قَدّم من أمواله لنفسه، وما أخَّر خَلفه للورثة{9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠١٠٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿يُنَبَّأُ الإنْسانُ يَوْمَئِذٍ بِما قَدَّمَ﴾</span> لآخرته، <span class="qpc-hafs">﴿وأَخَّرَ﴾</span> مِن خير أو شرٍّ بعد موته في دنياه، فاستَنّ بها قومٌ بعده{13}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠١٠٦<span class="dash">-</span></span> قال <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿يُنَبَّأُ الإنْسانُ يَوْمَئِذٍ بِما قَدَّمَ وأَخَّرَ﴾</span>، قال: ما أخَّر: ما تَرك مِن العمل لم يَعمله؛ ما تَرك من طاعة الله لم يَعمل به، وما قَدّم: ما عَمِل من خير أو شرّ{14}<span class=comment-ref>٦٩٠٨</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٩٠٨</span> اختُلف في المراد بقوله: <span class="qpc-hafs">﴿بما قدم وأخر﴾</span> على أقوال: <b>الأول</b>: ما قَدّم قبل موته، وما سَنّ فعُمِل به بعد موته. <b>الثاني</b>: ما قَدّم من معصية، وأَخَّر من طاعة. <b>الثالث</b>: بأول عَمَله، وآخره. <b>الرابع</b>: بما قَدّم من الطاعة، وأَخَّر من حقوق الله التي ضَيّعها. <b>الخامس</b>: ما قَدّم من خير أو شرّ مما عَمِله، وما أخَّر مما تَرك عَمَله من طاعة الله ﷿.</p><p>و<span class="comment-type-3">رجَّح</span> <u>ابنُ جرير</u> (٢٣/٤٩١) <span class="mustanad">العموم</span>، فقال: «والصواب من القول في ذلك عندنا أنّ ذلك خبر من الله أنّ الإنسان يُنبّأ بكل ما قَدّم أمامه مما عَمِل من خير أو شرّ في حياته، وأَخَّر بعده من سُنّة حسنة أو سيئة مما قَدّم وأَخَّر، كذلك ما قَدّم من عَملٍ عَمِله من خير أو شرّ، وأَخَّر بعده من عَملٍ كان عليه فضَيّعه، فلم يعمله مما قَدّم وأَخَّر، ولم يخصص الله من ذلك بعضًا دون بعض، فكلّ ذلك مما يُنبّأ به الإنسان يوم القيامة».</p><p>و<span class="comment-type-4">ذكر</span> <u>ابنُ عطية</u> (٨/٤٧٤-٤٧٥) أنّ قوله تعالى: <span class="qpc-hafs">﴿بما قدم وأخر﴾</span> قِسمة تستوفي كلّ عمل، أي: يُعلم بكل ما فعل ويجده مُحصلًا، ثم ساق الأقوال.</div></p></div>",footnotes:1:أخرجه عبد الرزاق ٢/٣٣٤، وابن جرير ٢٣/٤٨٩ بنحوه. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.|2:أخرجه ابن جرير ٢٣/٤٨٩. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.|3:أخرجه ابن جرير ٢٣/٤٨٩.|4:أخرجه ابن أبي شيبة ١٣/٥٥٢، وابن جرير ٢٣/٤٩٠. وعزاه السيوطي إلى عبد بن حميد.|5:عزاه السيوطي إلى ابن أبي الدنيا.|6:عزاه السيوطي إلى عبد بن حميد.|7:يقال للإنسان إذا نظر إلى الشيء فأعجبه واشتهاه وأسرع نحوه: قد بَهَشَ إليه. النهاية (بهش).|8:عزاه السيوطي إلى ابن أبي الدنيا في كتاب المحتضرين.|9:تفسير الثعلبي ١٠/٨٥، وتفسير البغوي ٨/٢٨٣.|10:عزاه السيوطي إلى ابن المنذر.|11:أخرجه عبد الرزاق ٢/٣٣٣، وابن جرير ٢٣/٤٩٠، كذا من طريق سعيد أيضًا. وعزاه السيوطي إلى عبد بن حميد.|12:تفسير الثعلبي ١٠/٨٥، وتفسير البغوي ٨/٢٨٣.|13:تفسير مقاتل بن سليمان ٤/٥١١.|14:أخرجه ابن جرير ٢٣/٤٩١.
  75,14,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿بَلِ ٱلۡإِنسَـٰنُ عَلَىٰ نَفۡسِهِۦ بَصِیرَةࣱ ۝١٤﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٨٠١٠٧<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطية العَوفيّ- <span class="qpc-hafs">﴿بَلِ الإنْسانُ عَلى نَفْسِهِ بَصِيرَةٌ﴾</span>، قال: الإنسان شهيد على نفسه وحده{1}. (١٥/١٠٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠١٠٨<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جُبَير</span> -من طريق موسى بن أبي عائشة-، مثله{2}. (١٥/١٠٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠١٠٩<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- <span class="qpc-hafs">﴿بَلِ الإنْسانُ عَلى نَفْسِهِ بَصِيرَةٌ﴾</span>، قال: سمْعه، وبصره، ويديه، ورجليه، وجوارحه{3}<span class=comment-ref>٦٩٠٩</span>. (١٥/١٠٦)</p></p><p></div></p><p><div><span class=comment-ref>٦٩٠٩</span> ساق <u>ابنُ جرير</u> (٢٣/٤٩٢) هذا القول، ثم <span class="comment-type-4">علَّق</span> بقوله: «والبصيرة -على هذا التأويل- ما ذكره ابن عباس مِن جوارح ابن آدم، وهي مرفوعة بقوله: <span class="qpc-hafs">﴿على نفسه﴾</span>، والإنسان مرفوع بالعائد مِن ذكره في قوله: <span class="qpc-hafs">﴿نفسه﴾</span>».</div></p><p><div></p><p><p><span class="item-no">٨٠١١٠<span class="dash">-</span></span> قال <span class="name-2">أبو العالية الرِّياحيّ</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠١١١<span class="dash">-</span></span> و<span class="name-2">عطاء</span>: <span class="qpc-hafs">﴿بَلِ الإنْسانُ عَلى نَفْسِهِ بَصِيرَةٌ﴾</span> بل الإنسان على نفسه شاهد{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠١١٢<span class="dash">-</span></span> قال <span class="name-2">عكرمة مولى ابن عباس</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠١١٣<span class="dash">-</span></span> و<span class="name-3">محمد بن السّائِب الكلبي</span>: <span class="qpc-hafs">﴿بَلِ الإنْسانُ عَلى نَفْسِهِ بَصِيرَةٌ﴾</span> معناه: بل الإنسان على نفسه مِن نفسه رُقباء يَرْقُبونه ويَشهدون عليه بعمله، وهي سمْعه وبصره وجوارحه{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠١١٤<span class="dash">-</span></span> عن عمران بن جُبَير، قال: قلتُ <span class="name-2">لعكرمة</span>: <span class="qpc-hafs">﴿بَلِ الإنْسانُ عَلى نَفْسِهِ بَصِيرَةٌ ولَوْ ألْقى مَعاذِيرَهُ﴾</span> فسكَتَ، وكان يَسْتاك، فقلتُ: إنّ <span class="name-2">الحسن</span> قال: يا ابن آدم، عملك أحَقُّ بك. قال: صَدقتَ{6}. (١٥/١٠٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠١١٥<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- في قوله: <span class="qpc-hafs">﴿بَلِ الإنْسانُ عَلى نَفْسِهِ بَصِيرَةٌ﴾</span>، قال: شاهدٌ عليها بعملها{7}. (١٥/١٠٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠١١٦<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿بَلِ الإنْسانُ عَلى نَفْسِهِ بَصِيرَةٌ﴾</span>، قال: إذا شئتَ رأيتَه بصيرًا بعيوب الناس، غافلًا عن عَيْبه. قال: وكان يُقال: في الإنجيل مكتوب: يا ابن آدم، أتُبصر القَذاة في عين أخيك، ولا تُبصر الجِذْل{8} المُعتَرِض في عينك؟{9}. (١٥/١٠٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠١١٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: يقول الله تعالى: <span class="qpc-hafs">﴿بَلِ الإنْسانُ عَلى نَفْسِهِ بَصِيرَةٌ﴾</span> وذلك حين كُتمت الأَلسُن في سورة الأنعام، وخَتم الله عليها في سورة <span class="qpc-hafs">﴿يس والقُرْآنِ الحَكِيمِ﴾</span>، فقال: <span class="qpc-hafs">﴿اليَوْمَ نَخْتِمُ عَلى أفْواهِهِمْ﴾</span> [يس:٦٥]. فنَطقت الجوارح، وشَهدت على الأَلسُن بالشِّرك في هذه السورة، فلا شاهد أفضل من نفسك، فذلك قوله -تبارك وتعالى-: <span class="qpc-hafs">﴿بَلِ الإنْسانُ عَلى نَفْسِهِ بَصِيرَةٌ﴾</span> يعني: جسده وجوارحه شاهدة عليه بعمله، فذلك قوله -تبارك وتعالى-: <span class="qpc-hafs">﴿كَفى بِنَفْسِكَ اليَوْمَ عَلَيْكَ حَسِيبًا﴾</span> [الإسراء:١٤] يعني: شاهدًا{10}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠١١٨<span class="dash">-</span></span> قال <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿بَلِ الإنْسانُ عَلى نَفْسِهِ بَصِيرَةٌ﴾</span>، قال: هو شاهد على نفسه. وقرأ: <span class="qpc-hafs">﴿اقْرَأْ كِتابَكَ كَفى بِنَفْسِكَ اليَوْمَ عَلَيْكَ حَسِيبًا﴾</span> [الإسراء:١٤]{11}<span class=comment-ref>٦٩١٠</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٩١٠</span> <span class="comment-type-4">ذكر</span> <u>ابنُ جرير</u> (٢٣/٤٩٣) أنّ مَن قال هذا القول جعل البصيرة خبرًا للإنسان، ورفع الإنسان بها. ثم قال: «ومَن قال هذه المقالة يقول: أُدخلت الهاء في قوله: <span class="qpc-hafs">﴿بصيرة﴾</span> وهي خبر للإنسان، كما يقال للرجل: أنتَ حُجّة على نفسك، وهذا قول بعض نحويي البصرة. وكان بعضهم يقول: أُدخلت هذه الهاء في <span class="qpc-hafs">﴿بصيرة﴾</span> وهي صفة للذكَر، كما أُدخلتْ في: راوية وعلامة».</p><p>و<span class="comment-type-4">ذكر</span> <u>ابنُ عطية</u> (٨/٤٧٥) أنّ قوله: <span class="qpc-hafs">﴿بصيرة﴾</span> يحتمل هذا القول، ويكون المعنى: فيه وفي عقْله وفِطرته حُجّة وطليعة وشاهدٌ مُبصر على نفسه، والهاء للتأنيث، ولو اعتذر عن قبيح أفعاله فهو يَعلم قُبْحها، وكذلك لو استتر بستوره واختفى بأفعاله -على التأويلين- في المعاذير. ويحتمل أن يكون ابتداء، وخبره في قوله تعالى: <span class="qpc-hafs">﴿على نفسه﴾</span> والهاء للتأنيث، ويراد بـ«البصيرة»: جوارحه أو الملائكة الحَفظة. كما قال ابن عباس، وعكرمة، والكلبي.</div></p></div>",footnotes:1:أخرجه عبد الرزاق ٢/٣٣٣-٣٣٤، وابن جرير ٢٣/٤٩٢-٤٩٣. وعزاه السيوطي إلى ابن المنذر.|2:أخرجه ابن أبي شيبة ١٣/٥٤٠-٥٤١، وابن جرير ٢٣/٤٩٤ بنحوه.|3:أخرجه ابن جرير ٢٣/٤٩١. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.|4:تفسير الثعلبي ١٠/٨٦، وتفسير البغوي ٨/٢٨٣.|5:تفسير الثعلبي ١٠/٨٦، وتفسير البغوي ٨/٢٨٣.|6:أخرجه ابن جرير ٢٣/٤٩٤. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.|7:أخرجه عبد الرزاق ٢/٣٣٤، وابن جرير ٢٣/٤٩٢. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.|8:القذاة: ما يقع في العين من تراب أو وسخ. والجذل: ما عظم من أصول الشجر المقطع. النهاية (قذا)، اللسان (جذل).|9:أخرجه ابن جرير ٢٣/٤٩٢. وعزاه السيوطي إلى ابن المنذر.|10:تفسير مقاتل بن سليمان ٤/٥١١.|11:أخرجه ابن جرير ٢٣/٤٩٣.
  75,15,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَلَوۡ أَلۡقَىٰ مَعَاذِیرَهُۥ ۝١٥﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٨٠١١٩<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق العَوفيّ- في قوله: <span class="qpc-hafs">﴿ولَوْ ألْقى مَعاذِيرَهُ﴾</span>، قال: ولو اعتذر{1}. (١٥/١٠٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠١٢٠<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جُبَير</span> -من طريق موسى-، مثله{2}. (١٥/١٠٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠١٢١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق زُرارة بن أوْفى- <span class="qpc-hafs">﴿ولَوْ ألْقى مَعاذِيرَهُ﴾</span>، قال: ولو تَجرّد مِن ثيابه{3}. (١٥/١٠٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠١٢٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطية العَوفيّ- في قوله تعالى: <span class="qpc-hafs">﴿ولَوْ ألْقى مَعاذِيرَهُ﴾</span>، قال: يعني: الاعتذار، ألم تسمع أنه قال: <span class="qpc-hafs">﴿لا يَنفَعُ الظّالِمِينَ مَعْذِرَتُهُمْ﴾</span> [غافر:٥٢]، وقال الله: <span class="qpc-hafs">﴿وأَلْقَوْا إلى اللهِ يَوْمَئِذٍ السَّلَمَ﴾</span> [النحل:٨٧]، وقوله: <span class="qpc-hafs">﴿ما كُنّا نَعْمَلُ مِن سُوءٍ﴾</span> [النحل:٢٨]، وقولهم: <span class="qpc-hafs">﴿والله ربنا ما كنا مشركين﴾</span> [الأنعام:٢٣]{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠١٢٣<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- <span class="qpc-hafs">﴿عَلى نَفْسِهِ بَصِيرَةٌ ولَوْ ألْقى مَعاذِيرَهُ﴾</span>، قال: لو جادل عنها هو بصير عليها{5}. (١٥/١٠٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠١٢٤<span class="dash">-</span></span> عن <span class="name-2">الضَّحّاك بن مُزاحِم</span>، <span class="qpc-hafs">﴿ولَوْ ألْقى مَعاذِيرَهُ﴾</span>، قال: حُجَّتَه{6}. (١٥/١٠٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠١٢٥<span class="dash">-</span></span> عن <span class="name-2">الضَّحّاك بن مُزاحِم</span>، <span class="qpc-hafs">﴿ولَوْ ألْقى مَعاذِيرَهُ﴾</span>، قال: سُتورَه، بلغة أهل اليمن{7}. (١٥/١٠٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠١٢٦<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق قتادة- <span class="qpc-hafs">﴿ولَوْ ألْقى مَعاذِيرَهُ﴾</span>: لم تُقبل معاذيره{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠١٢٧<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- في قوله: <span class="qpc-hafs">﴿ولَوْ ألْقى مَعاذِيرَهُ﴾</span>، قال: لو اعتذر يومئذ بباطل لم يَقبل اللهُ ذلك منه يوم القيامة{9}. (١٥/١٠٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠١٢٨<span class="dash">-</span></span> قال <span class="name-2">عطاء</span>: <span class="qpc-hafs">﴿ولَوْ ألْقى مَعاذِيرَهُ﴾</span>، يعني: يَشهد عليه الشاهد، ولو اعتذر وجادل عن نفسه لم يَنفعه{10}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠١٢٩<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أبي حمزة- في قوله: <span class="qpc-hafs">﴿ولَوْ ألْقى مَعاذِيرَهُ﴾</span>: ولو أرخى السُّتور، وأَغلق الأبواب{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠١٣٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ولَوْ ألْقى مَعاذِيرَهُ﴾</span> ولو أدلى بحُجّته لم تَنفعه، وكان جسده عليه شاهدًا{12}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠١٣١<span class="dash">-</span></span> قال <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿ولَوْ ألْقى مَعاذِيرَهُ﴾</span>، قال: معاذيرهم التي يَعتذرون بها يوم القيامة، فلا يَنتفعون بها. قال: قوم لا يُؤذن لهم فيَعتذِرون، وقوم يُؤذن لهم فيَعتذِرون فلا يَنفعهم، ويَعتذِرون بالكذب{13}<span class=comment-ref>٦٩١١</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٩١١</span> اختُلف في المراد بقوله: <span class="qpc-hafs">﴿ولو ألقى معاذيره﴾</span> على أقوال: <b>الأول</b>: لو اعتذر يومئذ لم يُقبل منه. <b>الثاني</b>: لو تَجرّد من ثيابه. <b>الثالث</b>: لو أظهر حُجّته. قاله السُّدِّيّ. <b>الرابع</b>: لو أرخى السُّتور وأغلق الأبواب. <b>الخامس</b>: بل للإنسان على نفسه شهود من نفسه، ولو اعتذر بالقول مما قد أتى من المآثم، وركب من المعاصي، وجادل بالباطل.</p><p>و<span class="comment-type-3">رجَّح</span> <u>ابنُ جرير</u> (٢٣/٤٩٦) -<span class="mustanad">مستندًا إلى السياق</span>- أنّ أولى الأقوال بالصواب قول مَن قال: ولو اعتذر. فقال: «لأنّ ذلك أشبه المعاني بظاهر التنزيل؛ وذلك أنّ الله -جلّ ثناؤه- أخبَر عن الإنسان أنّ عليه شاهدًا من نفسه بقوله: <span class="qpc-hafs">﴿بل الإنسان على نفسه بصيرة﴾</span> فكان الذي هو أولى أن يَتبع ذلك، ولو جادل عنها بالباطل، واعتذر بغير الحق، فشهادة نفسه عليه به أحقّ وأولى من اعتذاره بالباطل».</p><p>و<span class="comment-type-3">رجَّح</span> <u>ابنُ كثير</u> (١٤/١٩٤) -<span class="mustanad">مستندًا إلى النظائر</span>- القول الأخير الذي قاله مجاهد، وعطاء، فقال: «والصحيح قول مجاهد وأصحابه، كقوله: <span class="qpc-hafs">﴿ثم لم تكن فتنتهم إلا أن قالوا والله ربنا ما كنا مشركين﴾</span> [الأنعام:٢٣]، وكقوله: <span class="qpc-hafs">﴿يوم يبعثهم الله جميعا فيحلفون له كما يحلفون لكم ويحسبون أنهم على شيء ألا إنهم هم الكاذبون﴾</span> [المجادلة:١٨]».</p><p>و<span class="comment-type-4">ذكر</span> <u>ابنُ عطية</u> (٨/٤٧٥) أنّ الحسن قال: المعنى: بل الإنسان على نفسه بَليّة ومِحنة، و<span class="comment-type-1">وجَّهه</span> بقوله: «كأنه ذهب إلى البصيرة التي هي طريقة الدّم، وداعية طلب الثأر». و<span class="comment-type-2">انتقده</span> بقوله: «وفي هذا نظر».</div></p></div>",footnotes:1:أخرجه عبد الرزاق ٢/٣٣٣-٣٣٤، وابن جرير ٢٣/٤٩٢-٤٩٣. وعزاه السيوطي إلى ابن المنذر.|2:أخرجه ابن أبي شيبة ١٣/٥٤٠-٥٤١.|3:عزاه السيوطي إلى ابن المنذر، وابن أبي حاتم. وأخرجه ابن جرير ٢٣/٤٩٤ دون قوله: من ثيابه.|4:أخرجه ابن جرير ٢٣/٤٩٣-٤٩٤.|5:أخرجه ابن جرير ٢٣/٤٩٤. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.|6:عزاه السيوطي إلى عبد بن حميد، وابن المنذر.|7:عزاه السيوطي إلى ابن المنذر.|8:أخرجه ابن جرير ٢٣/٤٩٥.|9:أخرجه عبد الرزاق ٢/٣٣٤، وابن جرير ٢٣/٤٩٥ بنحوه من طريق سعيد. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.|10:تفسير البغوي ٨/٢٨٣.|11:أخرجه ابن جرير ٢٣/٤٩٥.|12:تفسير مقاتل بن سليمان ٤/٥١١.|13:أخرجه ابن جرير ٢٣/٤٩٤.
  75,16,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿لَا تُحَرِّكۡ بِهِۦ لِسَانَكَ لِتَعۡجَلَ بِهِۦۤ ۝١٦﴾</span> - نزول الآية، وتفسيرها</h3></p><p><div></p><p><p><span class="item-no">٨٠١٣٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق سعيد بن جُبَير-: كان رسول الله ﷺ يُعالج من التنزيل شِدّة، فكان يُحرّك به لسانه وشَفتيه مخافة أن يَتفلَّتَ منه، يريد أن يَحفظه؛ فأنزل الله: <span class="qpc-hafs">﴿لا تُحَرِّكْ بِهِ لِسانَكَ لِتَعْجَلَ بِهِ إنَّ عَلَيْنا جَمْعَهُ وقُرْآنَهُ﴾</span> قال: يقول: علينا أن نَجمعه في صدرك ثم تقرأه، <span class="qpc-hafs">﴿فَإذا قَرَأْناهُ﴾</span> يقول: إذا أنزلناه عليك <span class="qpc-hafs">﴿فاتَّبِعْ قُرْآنَهُ﴾</span> فاستَمِع له وأَنصِتْ، <span class="qpc-hafs">﴿ثُمَّ إنَّ عَلَيْنا بَيانَهُ﴾</span> أن نُبيّنه بلسانك، وفي لفظ: علينا أن نَقرأه. فكان رسول الله ﷺ بعد ذلك إذا أتاه جبريل أطرق -وفي لفظ: استمَع-، فإذا ذَهب قرأه كما وعده الله ﷿{1}. (١٥/١٠٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠١٣٣<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، قال: كان النبيُّ ﷺ إذا نَزل عليه القرآنُ تَعجَّل بقراءته ليَحفظه؛ فنَزلت هذه الآية: <span class="qpc-hafs">﴿لا تُحَرِّكْ بِهِ لِسانَكَ﴾</span>. وكان رسول الله ﷺ لا يَعلم خَتْم السورة حتى تَنزل عليه: بسم الله الرحمن الرحيم{2}. (١٥/١٠٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠١٣٤<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطية العَوفيّ-: كان رسول الله ﷺ لا يَفْتُر مِن القرآن مَخافة أن يَنساه، فقال الله: <span class="qpc-hafs">﴿لا تُحَرِّكْ بِهِ لِسانَكَ لِتَعْجَلَ بِهِ﴾</span>{3}. (١٥/١٠٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠١٣٥<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جُبَير</span> -من طريق عمرو بن دينار-: أنّ النبي ﷺ كان إذا نَزل عليه القرآن تَعجَّل به يريد حِفْظه؛ يُحرّك شَفتيه ليَحفظه؛ فأنزل الله: <span class="qpc-hafs">﴿لا تُحَرِّكْ بِهِ لِسانَكَ لِتَعْجَلَ بِهِ إنَّ عَلَيْنا جَمْعَهُ وقُرْآنَهُ﴾</span>{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠١٣٦<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جُبَير</span> -من طريق موسى بن أبي عائشة- <span class="qpc-hafs">﴿لا تُحَرِّكْ بِهِ لِسانَكَ لِتَعْجَلَ بِهِ﴾</span>، قال: كان جبريل يَنزل بالقرآن، فيُحرّك به لسانه، يَستعجل به؛ فقال: <span class="qpc-hafs">﴿لا تُحَرِّكْ بِهِ لِسانَكَ لِتَعْجَلَ بِهِ﴾</span>{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠١٣٧<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن</span> <span class="name-2">جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿لا تُحَرِّكْ بِهِ لِسانَكَ﴾</span>، قال: كان يَستذكر القرآن مَخافة النسيان، فقيل له: كَفَيناكه، يا محمد{6}. (١٥/١٠٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠١٣٨<span class="dash">-</span></span> عن <span class="name-2">الضَّحّاك بن مُزاحِم</span> -من طريق عبيد- يقول في قوله: <span class="qpc-hafs">﴿لا تُحَرِّكْ بِهِ لِسانَكَ﴾</span>، قال: كان النبي ﷺ إذا نَزل عليه الوحيُ مِن القرآن حَرّك به لسانه؛ مَخافة أن يَنساه{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠١٣٩<span class="dash">-</span></span> عن <span class="name-2">عامر الشعبي</span> -من طريق داود بن أبي هند- <span class="qpc-hafs">﴿لا تُحَرِّكْ بِهِ لِسانَكَ لِتَعْجَلَ بِهِ﴾</span>، قال: كان إذا نَزل عليه الوحيُ عَجِل يَتكلّم به مِن حُبِّه إيّاه؛ فنزل: <span class="qpc-hafs">﴿لا تُحَرِّكْ بِهِ لِسانَكَ لِتَعْجَلَ بِهِ﴾</span>{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠١٤٠<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span>: <span class="qpc-hafs">﴿لا تُحَرِّكْ بِهِ لِسانَكَ لِتَعْجَلَ بِهِ﴾</span> كان رسول الله إذا نَزل عليه القرآنُ يُدْئِب نفسه في قراءته، مَخافة أن يَنساه؛ فأنزل الله: <span class="qpc-hafs">﴿لا تُحَرِّكْ بِهِ لِسانَكَ لِتَعْجَلَ بِهِ﴾</span>{9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠١٤١<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق أبي رجاء- <span class="qpc-hafs">﴿لا تُحَرِّكْ بِهِ لِسانَكَ لِتَعْجَلَ بِهِ﴾</span>، قال: كان رسول الله ﷺ يُحرّك به لسانه ليَستذكره، فقال الله: <span class="qpc-hafs">﴿لا تُحَرِّكْ بِهِ لِسانَكَ لِتَعْجَلَ بِهِ﴾</span> إنّا سَنحفظه عليك{10}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠١٤٢<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿لا تُحَرِّكْ بِهِ لِسانَكَ لِتَعْجَلَ بِهِ﴾</span>، قال: كان نبي الله ﷺ يُحرّك لسانه بالقرآن مَخافة النسيان؛ فأَنزل الله ما تسمع{11}. (١٥/١٠٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠١٤٣<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- في قوله تعالى: <span class="qpc-hafs">﴿لا تُحَرِّكْ بِهِ لِسانَكَ﴾</span>، قال: كان رسول الله ﷺ يَقرأ القرآن فيُكثر مَخافة أن يَنسى{12}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠١٤٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿لا تُحَرِّكْ بِهِ لِسانَكَ لِتَعْجَلَ بِهِ﴾</span> وذلك أنّ جبريل كان يأتي النبيَّ ﷺ بالوحي، فإذا قَرأه عليه تلاه النبيُّ ﷺ قبل أن يَفرغ جبريلُ مِن الوحي مَخافة أن لا يَحفظه، فقال الله تعالى: <span class="qpc-hafs">﴿لا تُحَرِّكْ بِهِ لِسانَكَ﴾</span> بتلاوته قبل أن يَفرغ جبريل ﷺ <span class="qpc-hafs">﴿لِتَعْجَلَ بِهِ﴾</span>{13}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠١٤٥<span class="dash">-</span></span> قال <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿لا تُحَرِّكْ بِهِ لِسانَكَ لِتَعْجَلَ بِهِ﴾</span>، قال: لا تَكلّم بالذي أوحينا إليك حتى يُقضى إليك وحيه، فإذا قَضينا إليك وحيُه فتَكلّم به{5}<span class=comment-ref>٦٩١٢</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٩١٢</span> اختُلف في السبب الذي من أجله قيل للنبي ﷺ: <span class="qpc-hafs">﴿لا تحرك به لسانك لتعجل به﴾</span> على قولين: <b>الأول</b>: أنّ النبي ﷺ كان يُكثر تلاوة القرآن مَخافة نسيانه، فقيل له: <span class="qpc-hafs">﴿لا تحرك به لسانك لتعجل به﴾</span> إنّ علينا أن نَجمعه لك، ونُقرئكه فلا تنسى. <b>الثاني</b>: أنه كان يُعجّل بذكره إذا نَزل عليه مِن حُبّه له وحلاوته في لسانه، فقيل له: لا تَعجل به، فإنه سَنحفظه عليك.</p><p>و<span class="comment-type-3">رجَّح</span> <u>ابنُ جرير</u> (٢٣/٥٠٠) -<span class="mustanad">مستندًا إلى الدلالة العقلية</span>- القول الثاني الذي قاله ابن عباس من طريق ابن جُبَير، وقاله سعيد بن جُبَير، والشعبي، وابن زيد، والضَّحّاك، و<span class="comment-type-2">انتقد</span> الأول، فقال: «وذلك أنّ قوله: <span class="qpc-hafs">﴿إن علينا جمعه وقرآنه﴾</span> يُنبئ أنه إنما نُهي عن تحريك اللسان به مُتعجّلًا فيه قبل جمْعه؛ ومعلوم أنّ دراسته للتذكُّر إنما كانت تكون من النبي ﷺ مِن بعد جمْع الله له ما يدرس من ذلك».</div></p></div>",footnotes:1:أخرجه البخاري ١/٨ (٥)، ٦/١٦٣ (٤٩٢٧-٤٩٢٩)، ٦/١٩٥ (٥٠٤٤)، ٩/١٥٣ (٧٥٢٤)، ومسلم ١/٣٣٠ (٤٤٨)، وابن جرير ٢٣/٤٩٧-٤٩٨، وابن أبي حاتم -كما في تفسير ابن كثير ٨/٢٧٩-.|2:أخرجه ابن منده في الإيمان ٢/٦٩٧-٦٩٨ (٦٩٠)، وابن جرير ٢٣/٤٩٦-٤٩٧ كلاهما بنحوه. وعزاه السيوطي إلى ابن المنذر، وابن مردويه.</p><p>قال ابن أبي حاتم في العلل ٤/٦٣٠ (١٦٩٠): «قال أبي: منهم مَن لا يقول في هذا الحديث: ابن عباس، ويُرسله، والمرسل أصح؛ حدثنا ابن أبي عمر، عن ابن عُيينة، عن عمرو، عن سعيد بن جُبَير، مرسل».|3:أخرجه ابن جرير ٢٣/٤٩٩، ٥٠١. وعزاه السيوطي إلى ابن مردويه.|4:أخرجه ابن جرير ٢٣/٤٩٧.|5:أخرجه ابن جرير ٢٣/٤٩٨.|6:أخرجه ابن جرير ٢٣/٤٩٩. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.|7:أخرجه ابن جرير ٢٣/٤٩٨.|8:أخرجه ابن جرير ٢٣/٤٩٨.|9:ذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٥/٦٤-٦٥-.|10:أخرجه ابن جرير ٢٣/٤٩٩-٥٠٠.|11:أخرجه ابن جرير ٢٣/٥٠٠. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.|12:أخرجه عبد الرزاق ٢/٣٣٤، وابن جرير ٢٣/٥٠٠.|13:تفسير مقاتل بن سليمان ٤/٥١٢.|14:أخرجه ابن جرير ٢٣/٤٩٨.
  75,17,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿إِنَّ عَلَیۡنَا جَمۡعَهُۥ وَقُرۡءَانَهُۥ ۝١٧﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٨٠١٤٦<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق سعيد بن جُبَير- <span class="qpc-hafs">﴿إنَّ عَلَيْنا جَمْعَهُ وقُرْآنَهُ﴾</span>، قال: يقول: علينا أن نَجمعه في صدرك، ثم تَقرأه{1}. (١٥/١٠٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠١٤٧<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطية العَوفيّ-: <span class="qpc-hafs">﴿إنَّ عَلَيْنا جَمْعَهُ﴾</span> أن نَجمعه لك، <span class="qpc-hafs">﴿وقُرْآنَهُ﴾</span> أن نُقرِئَك فلا تَنسى{2}. (١٥/١٠٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠١٤٨<span class="dash">-</span></span> عن <span class="name-2">الضَّحّاك بن مُزاحِم</span> -من طريق عبيد- يقول في قوله: <span class="qpc-hafs">﴿إنَّ عَلَيْنا جَمْعَهُ وقُرْآنَهُ﴾</span>، يقول: علينا أن نَجمعه لك حتى نُثبِّته في قلبك{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠١٤٩<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- <span class="qpc-hafs">﴿إنَّ عَلَيْنا جَمْعَهُ وقُرْآنَهُ﴾</span>، يقول: إنّ علينا حِفظه وتأليفه{4}. (١٥/١٠٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠١٥٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿إنَّ عَلَيْنا جَمْعَهُ﴾</span> في قلبك، <span class="qpc-hafs">﴿وقُرْآنَهُ﴾</span> عليك، يعني: نُقْريكه حتى تَحفظه{5}<span class=comment-ref>٦٩١٣</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٩١٣</span> اختُلف في المراد بقوله: <span class="qpc-hafs">﴿وقرآنه﴾</span> على قولين: <b>الأول</b>: قراءته. <b>الثاني</b>: تأليفه.</p><p>و<span class="comment-type-4">ذكر</span> <u>ابنُ جرير</u> (٢٣/٥٠٢) أنه على القول الأول الذي قاله ابن عباس، والضَّحّاك فقد وجّه قوله تعالى: <span class="qpc-hafs">﴿وقرآنه﴾</span> إلى أنه مصدر من قول القائل: قرأت أقرأ قرآنًا وقراءة. و<span class="comment-type-1">وجَّه</span> (٢٣/٥٠١-٥٠٢) القول الثاني الذي قاله قتادة بقوله: «كأن قتادة وجّه معنى القرآن إلى أنه مصدر، من قول القائل: قد قَرَأَتْ هذه الناقة في بطنها جنينًا؛ إذا ضَمّتْ رحمها على ولدها».</p><p>و<span class="comment-type-4">ذكر</span> <u>ابنُ عطية</u> (٨/٤٧٦-٤٧٧) أنّ قوله: <span class="qpc-hafs">﴿وقرآنه﴾</span> يحتمل الأمرين.</div></p></div>",footnotes:1:جزء من الحديث المتقدم بتمامه قريبًا في نزول الآية.|2:أخرجه ابن جرير ٢٣/٤٩٩، ٥٠١. وعزاه السيوطي إلى ابن مردويه.|3:أخرجه ابن جرير ٢٣/٥٠١.|4:أخرجه عبد الرزاق ٢/٣٣٤، وابن جرير ٢٣/٥٠١، ومن طريق سعيد أيضًا. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.|5:تفسير مقاتل بن سليمان ٤/٥١٢.
  75,18,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿فَإِذَا قَرَأۡنَـٰهُ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٨٠١٥١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق سعيد بن جُبَير- <span class="qpc-hafs">﴿فَإذا قَرَأْناهُ﴾</span>، يقول: إذا أنزلناه عليك{1}. (١٥/١٠٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠١٥٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- <span class="qpc-hafs">﴿فَإذا قَرَأْناهُ﴾</span>، قال: بَيَّنّاه{2}. (١٥/١٠٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠١٥٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فَإذا قَرَأْناهُ﴾</span> فإذا تَلوناه عليك، يقول: إذا تلا عليك جبريلُ ﷺ{3}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿فَٱتَّبِعۡ قُرۡءَانَهُۥ ۝١٨﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٨٠١٥٤<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق سعيد بن جُبَير- قال: <span class="qpc-hafs">﴿فاتَّبِعْ قُرْآنَهُ﴾</span> فاستَمِع له وأَنصِتْ{4}. (١٥/١٠٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠١٥٥<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطية- قال: <span class="qpc-hafs">﴿فاتَّبِعْ قُرْآنَهُ﴾</span>، يقول: إذا يُتلى عليك فاتّبع ما فيه{5}. (١٥/١٠٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠١٥٦<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- <span class="qpc-hafs">﴿فاتَّبِعْ قُرْآنَهُ﴾</span>، يقول: اعمل به{2}. (١٥/١٠٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠١٥٧<span class="dash">-</span></span> عن <span class="name-2">الضَّحّاك بن مُزاحِم</span> -من طريق عبيد- يقول في قوله: <span class="qpc-hafs">﴿فاتَّبِعْ قُرْآنَهُ﴾</span>، يقول: اتّبع ما فيه{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠١٥٨<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- <span class="qpc-hafs">﴿فَإذا قَرَأْناهُ فاتَّبِعْ قُرْآنَهُ﴾</span>، يقول: اتّبع حلاله، واجتَنبْ حرامه{8}. (١٥/١٠٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠١٥٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فاتَّبِعْ قُرْآنَهُ﴾</span> فاتّبع ما فيه{3}<span class=comment-ref>٦٩١٤</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٩١٤</span> اختُلف في المراد بقوله: <span class="qpc-hafs">﴿فإذا قرأناه فاتبع قرآنه﴾</span> على أقوال: <b>الأول</b>: فإذا بَيّناه فاعمل بما فيه. <b>الثاني</b>: فإذا أنزلناه فاستَمِع قرآنه. <b>الثالث</b>: فإذا تُلي عليك فاتّبع شرائعه وأحكامه.</p><p>و<span class="comment-type-3">رجَّح</span> <u>ابنُ جرير</u> (٢٣/٥٠٣) -<span class="mustanad">مستندًا إلى السياق</span>- القول الأخير الذي قاله ابن عباس من طريق العَوفيّ، وقاله قتادة، والضَّحّاك، فقال: «لأنه قيل له: <span class="qpc-hafs">﴿إن علينا جمعه﴾</span> في صدرك <span class="qpc-hafs">﴿وقرآنه﴾</span>، وقد دللنا على أنّ معنى قوله: <span class="qpc-hafs">﴿وقرآنه﴾</span> وقراءته، فقد بَيّن ذلك عن معنى قوله: <span class="qpc-hafs">﴿فإذا قرأناه فاتبع قرآنه﴾</span>».</p><p>و<span class="comment-type-4">ذكر</span> <u>ابنُ عطية</u> (٨/٤٧٧ بتصرف) أنّ قوله: <span class="qpc-hafs">﴿فاتبع﴾</span> يحتمل القول الثاني والثالث، فقال: «وقوله تعالى: <span class="qpc-hafs">﴿فاتبع﴾</span> <b>يحتمل</b> أن يريد: بذِهْنك وفِكْرك، أي: فاستمع قراءته، <b>ويحتمل</b> أن يريد: فاتّبع في الأوامر والنواهي».</div></p></div>",footnotes:1:تقدم تخريجه بطوله قريبًا في نزول الآية.|2:أخرجه ابن جرير ٢٣/٥٠٣، وابن أبي حاتم -كما في فتح الباري ٨/٦٨٢-. وعزاه السيوطي إلى ابن المنذر.|3:تفسير مقاتل بن سليمان ٤/٥١٢.|4:جزء من الحديث المتقدم بتمامه قريبًا في نزول الآية.|5:أخرجه ابن جرير ٢٣/٤٩٩، ٥٠٢، ٥٠٤. وعزاه السيوطي إلى ابن مردويه.|6:أخرجه ابن جرير ٢٣/٥٠٣، وابن أبي حاتم -كما في فتح الباري ٨/٦٨٢-. وعزاه السيوطي إلى ابن المنذر.|7:أخرجه ابن جرير ٢٣/٥٠٣.|8:أخرجه عبد الرزاق ٢/٣٣٤، وابن جرير ٢٣/٥٠٣، ومن طريق سعيد أيضًا. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.|9:تفسير مقاتل بن سليمان ٤/٥١٢.
  75,19,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿ثُمَّ إِنَّ عَلَیۡنَا بَیَانَهُۥ ۝١٩﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٨٠١٦٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق سعيد بن جُبَير- قال: <span class="qpc-hafs">﴿ثُمَّ إنَّ عَلَيْنا بَيانَهُ﴾</span> أن نُبيّنه بلسانك. وفي لفظ: علينا أن نَقرأه{1}. (١٥/١٠٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠١٦١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطية- قال: <span class="qpc-hafs">﴿ثُمَّ إنَّ عَلَيْنا بَيانَهُ﴾</span>، يقول: حلاله وحرامه، فذلك بيانه{2}. (١٥/١٠٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠١٦٢<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿ثُمَّ إنَّ عَلَيْنا بَيانَهُ﴾</span>، قال: بيان حلاله وحرامه، وطاعته ومعصيته{3}. (١٥/١٠٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٨٠١٦٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ثُمَّ إنَّ عَلَيْنا بَيانَهُ﴾</span>، يعني: أن نُبيّن لك حلاله وحرامه{4}. (ز)</p></p><p></div></p></div>",footnotes:1:جزء من الحديث المتقدم بتمامه قريبًا في نزول الآية.|2:أخرجه ابن جرير ٢٣/٥٠٤. وعزاه السيوطي إلى ابن مردويه.|3:أخرجه ابن جرير ٢٣/٥٠٤ بنحوه. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.|4:تفسير مقاتل بن سليمان ٤/٥١٢.