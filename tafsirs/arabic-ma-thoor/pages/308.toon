tafsir[13]{c,v,t}:
19,39," <q>﴿وَأَنذِرۡهُمۡ یَوۡمَ ٱلۡحَسۡرَةِ إِذۡ قُضِیَ ٱلۡأَمۡرُ وَهُمۡ فِی غَفۡلَةࣲ وَهُمۡ لَا یُؤۡمِنُونَ ۝٣٩﴾</q> - تفسير ٤٦٦٥٦- عن أبي سعيد الخدري، قال: قال رسول الله ﷺ: «إذا دخل أهلُ الجنةِ الجنةَ، وأهلُ النارِ النارَ؛ يُجاء بالموت كأنّه كبش أملح، فيُوقَف بين الجنة والنار، فيقال: يا أهل الجنة، هل تعرفون هذا؟ فيَشْرَئِبُّون، وينظرون، ويقولون: نعم، هذا الموت. وكلُّهم قد رآه، ثُمَّ ينادي: يا أهل النار، هل تعرفون هذا؟ فيَشْرَئِبُّون، وينظرون، ويقولون: نعم، هذا الموت. وكلُّهم قد رآه، فيُؤمَر به، فيُذبَح، فيُقال: يا أهل الجنة، خُلودٌ فلا موت، ويا أهل النار، خلود فلا موت». ثم قرأ رسول الله ﷺ: <q>﴿وأنذرهم يوم الحسرة إذ قضي الأمر وهم في غفلة﴾</q>. وأشار بيده، وقال: «أهلُ الدنيا في غفلة»{1}٤١٧٣. (١٠/٧٣) ٤١٧٣ علَّق ابنُ كثير (٩/٢٤٨-٢٤٩) على هذا الحديث بقوله: «هكذا رواه الإمام أحمد، وقد أخرجه البخاري ومسلم في صحيحيهما، من حديث الأعمش، به. ولفظهما قريب من ذلك. وقد روى هذا الحديث الحسن بن عرفة: حدثني أسباط بن محمد، عن الأعمش، عن أبي صالح، عن أبي هريرة مرفوعًا، مثله. وفي سنن ابن ماجه وغيره، من حديث محمد بن عمرو، عن أبي سلمة، عن أبي هريرة بنحوه، وهو في الصحيحين عن ابن عمر. ورواه ابن جريج قال: قال ابن عباس: فذكر من قِبَلِهِ نحوه». ٤٦٦٥٧- عن أبي سعيد، عن النبي ﷺ، قوله: <q>﴿وهم في غفلة﴾</q>، قال: «في الدنيا»{2}. (ز) ٤٦٦٥٨- عن أبي هريرة، عن النبي ﷺ، في قوله: <q>﴿وأنذرهم يوم الحسرة﴾</q>، قال: «يُنادى: يا أهل الجنة. فيَشْرَئِبُّون، وينظرون، ويُنادى: يا أهل النار. فيَشْرَئِبُّون، وينظرون، فيُقال: ما تعرفون هذا؟ فيقولون: نعم. فيُجاء بالموت في صورة كبش أملح، فيُقال: هذا الموت. فيُقَرَّب، ويُذبَح، ثم يُقال: يا أهل الجنة، خلود ولا موت، ويا أهل النار، خلود لا موت». ثم قرأ: <q>﴿وأنذرهم يوم الحسرة إذ قضي الأمر﴾</q>{3}. (١٠/٧٤) ٤٦٦٥٩- عن عبد الله بن مسعود -من طريق زِر بن حُبَيْش- في قوله: <q>﴿وأنذرهم يوم الحسرة إذ قضي الأمر﴾</q>، قال: إذا دخل أهلُ الجنةِ الجنةَ، وأهلُ النارِ النارَ؛ أُتِي بالموت في صورة كبش أمْلَح، حتى يُوقَف بين الجنة والنار، ثم يُنادِي منادٍ: يا أهل الجنة، هذا الموتُ الذي كان يميت الناسَ في الدنيا. فلا يبقى أحدٌ في عِلِّيِّين، ولا في أسفل درجةٍ من الجنة إلا نظر إليه، ثم يُنادي: يا أهل النار، هذا الموت الذي كان يميت الناس في الدنيا. فلا يبقى أحد في ضَحْضاحٍ مِن نار، ولا أسفل دَرْكٍ مِن جهنم إلا نظر إليه، ثم يذبح بين الجنة والنار، ثم ينادي: يا أهل الجنة، هو الخلود أبد الآبدين، ويا أهل النار، هو الخلود أبد الآبدين. فيفرح أهلُ الجنة فرحةً لو كان أحدٌ ميِّتًا مِن فرح ماتوا، ويشهقُ أهلُ النار شَهْقَةً لو كان [أحدٌ] ميِّتًا مِن شهقة ماتوا، فذلك قوله: <q>﴿وأنذرهم يوم الحسرة إذ قضي الأمر﴾</q>. يقول: إذا ذُبِح الموت{4}. (١٠/٧٤) ٤٦٦٦٠- عن عبد الله بن مسعود -من طريق أبي الزَّعْراء- في قصة ذكرها، قال: ما مِن نفس إلا وهي تنظر إلى بيت في الجنة، وبيت في النار، وهو يوم الحسرة، فيرى أهلُ النارِ البيتَ الذي في الجنة، فيُقال لهم: لو عمِلتم. فتأخذهم الحسرة، ويرى أهلُ الجنة البيتَ الذي في النار، فيقال: لولا أن مَنَّ الله عليكم{5}. (ز) ٤٦٦٦١- عن أبي سعيد الخدري -من طريق أبي سفيان- قال: يُجاء بالموت في صورة كبش أمْلح، حتى يجعل على السور بين الجنة والنار، فيُقال: يا أهل الجنة، ويا أهل النار، هل تعرفون هذا؟ هذا الموت. فيقولون: نعم. فيُذبَح على السور وهم ينظرون، ثم يُنادي منادٍ هكذا: يا أهل الجنة، خلود فلا موت، ويا أهل النار، خلود فلا موت. وهو قوله: <q>﴿وأنذرهم يوم الحسرة إذ قضي الأمر﴾</q>{6}. (ز) ٤٦٦٦٢- عن عبد الله بن عباس -من طريق ابن جُرَيج- في قوله: <q>﴿وأنذرهم يوم الحسرة﴾</q>، قال: يُصَوِّرُ اللهُ الموتَ في صورة كبش أملح، فيُذبَح، فييأس أهلُ النار مِن الموت فيما يرجونه، فتأخذهم الحسرةُ مِن أجل الخلود في النار{7}. (١٠/٧٤) ٤٦٦٦٣- عن عبد الله بن عباس -من طريق علي- <q>﴿يوم الحسرة﴾</q>: هو مِن أسماء يوم القيامة. وقرأ: <q>﴿أن تقول نفس يا حسرتا على ما فرطت في جنب الله﴾</q> [الزمر:٥٦]{8}. (١٠/٧٥) ٤٦٦٦٤- عن عبد الله بن عباس -من طريق عثمان بن سليم- أنّه قال: يُجعل الموت في صورة كبش أملح، فيذبحه جبريلُ بين الجنة والنار، وهم ينظرون إليه، فيُقال لأهل الجنة: خلودٌ فلا موتَ فيها. ولأهل النار: خلودٌ فلا موتَ فيها. فلولا ما قضى الله ﷿ على أهل النار مِن تعمير أرواحهم في أبدانهم لَماتوا مِن الحسرة{9}. (ز) ٤٦٦٦٥- عن إسماعيل السُّدِّيّ: قوله: <q>﴿إذ قضي الأمر﴾</q>، يعني: إذ وجب العذابُ، فوقع أهل النار{10}. (ز) ٤٦٦٦٦- قال مقاتل بن سليمان: <q>﴿وأنذرهم﴾</q> يعني: كفار مكة <q>﴿يوم الحسرة﴾</q> يوم يُذْبَح الموت كأنّه كبش أملح ... <q>﴿إذ قضي الأمر﴾</q> يعني: إذا قضى العذاب، <q>﴿وهم في غفلة﴾</q> اليوم، <q>﴿وهم لا يؤمنون﴾</q> يعني: لا يُصَدِّقون بما يكون في الآخرة{11}. (ز) ٤٦٦٦٧- عن عبد الملك ابن جريج -من طريق حجاج- قال: يُحْشَر أهلُ النار حين يذبح الموت، والفريقان ينظرون، فذلك قوله: <q>﴿إذ قضي الأمر﴾</q> قال: ذُبِح الموت، <q>﴿وهم في غفلة﴾</q>{7}. (ز) ٤٦٦٦٨- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿وأنذرهم يوم الحسرة﴾</q>، قال: يوم القيامة. وقرأ <q>﴿أن تقول نفس يا حسرتا على ما فرطت في جنب الله﴾</q> [الزمر:٥٦]{13}٤١٧٤. (ز) ٤١٧٤ علَّق ابنُ عطية (٦/٣٥) على هذا القول بقوله: «وذلك أنّ أهل النار قد حصلوا مِن أول أمرهم في سخط الله وأمارته، فهم في حال حسرة، والأمر المقضي -على هذا- هو الحتم عليهم بالعذاب، وظهور إنفاذ ذلك عليهم». ٤٦٦٦٩- قال يحيى بن سلّام: قوله: <q>﴿وهم في غفلة﴾</q> في الدنيا. وهذا كلام مستقبل، يعني: المشركين. <q>﴿وهم لا يؤمنون﴾</q>{14}٤١٧٥. (ز) ٤١٧٥ ساق ابنُ عطية (٦/٣٥) هذه الأقوال، ثم قال: «ويحتمل أن يكون يوم الحسرة اسم جنس؛ لأن هذه حسرات كثيرة في مواطن عِدَّة، ومنها يوم القيامة، ومنها وقت أخذ الكتاب بالشمال، وغير ذلك». <q>﴿وَأَنذِرۡهُمۡ یَوۡمَ ٱلۡحَسۡرَةِ إِذۡ قُضِیَ ٱلۡأَمۡرُ وَهُمۡ فِی غَفۡلَةࣲ وَهُمۡ لَا یُؤۡمِنُونَ ۝٣٩﴾</q> - آثار متعلقة بالآية ٤٦٦٧٠- عن ابن عمر، قال: سمعتُ رسول الله يقول: «إذا صار أهلُ الجنة إلى الجنة، وصار أهلُ النار إلى النار؛ أُتِي بالموت حتى يُجعل بين الجنة والنار، ثم يُذبح، ثم يُنادي منادٍ: يا أهل الجنة، لا موت، ويا أهل النار، لا موت. فيزداد أهلُ الجنة فرحًا إلى فرحهم، ويزداد أهلُ النار حزنًا إلى حزنهم»{15}. (ز) ",footnotes:1:أخرجه البخاري ٦/٩٣-٩٤ (٤٧٣٠)، ومسلم ٤/٢١٨٨ (٢٨٤٩)، وأحمد ١٧/١٢٠ (١١٠٦٦) واللفظ له.أخرجه ابن حبان ٢/٤٢١-٤٢٢ (٦٥٢). وأصله في الصحيحين؛ البخاري ٦/٩٣-٩٤ (٤٧٣٠)، ومسلم ٤/٢١٨٨ (٢٨٤٩). قال المنذري في الترغيب والترهيب ٢/٣٤٢ (٢٦٤٦): «رواه ابن حبان في صحيحه، وهو في الصحيحين بمعناه».أخرجه النسائي في الكبرى ١٠/١٦٨ (١١٢٥٥)، وابن جرير ١٥/٥٤٦، من طريق أسباط بن محمد، عن الأعمش، عن أبي صالح، عن أبي هريرة به. إسناده صحيح، ولكن أعلّ الدارقطني في العلل ٨/١٦٦، و١١/٣٤٥ روايته من مسند أبي هريرة، وصوّب كونه من مسند أبي سعيد، فقال: «والصحيح حديث أبي سعيد الخدري».أخرجه ابن أبي حاتم -كما في تفسير ابن كثير ٥/٢٢٨-. وعزاه السيوطي إلى ابن مردويه.أخرجه يحيى بن سلام ١/٢٢٥، وابن جرير ١٥/٥٤٥.أخرجه يحيى بن سلام ١/٢٢٥.أخرجه ابن جرير ١٥/٥٤٦.كذا أورده السيوطي، وعزاه إلى ابن جرير، والذي في مطبوعة ابن جرير ١٥/٥٤٧ عن ابن عباس من طريق علي في تفسير هذه الآية: من أسماء يوم القيامة، عظمه الله، وحذره عباده، دون ذكر الآية. وإنما ذُكرت في أثر عبد الرحمن بن زيد بن أسلم الذي أورده ابن جرير قبله، وسيأتي بعد ثلاثة آثار.أخرجه مقاتل بن سليمان ٢/٦٢٨.علَّقه يحيى بن سلام ١/٢٢٥.تفسير مقاتل بن سليمان ٢/٦٢٨.أخرجه ابن جرير ١٥/٥٤٦.أخرجه ابن جرير ١٥/٥٤٧.تفسير يحيى بن سلام ١/٢٢٦.أخرجه مسلم ٤/٢١٨٩ (٢٨٥٠)، ويحيى بن سلام في تفسيره ١/٢٢٦.
19,40," <q>﴿إِنَّا نَحۡنُ نَرِثُ ٱلۡأَرۡضَ وَمَنۡ عَلَیۡهَا وَإِلَیۡنَا یُرۡجَعُونَ ۝٤٠﴾</q> - تفسير ٤٦٦٧١- قال مقاتل بن سليمان: <q>﴿إنا نحن نرث الأرض ومن عليها﴾</q>، يعني: نُميتهم، ويبقى الربُّ جل جلاله، ونَرِث أهلَ السماء وأهلَ الأرض. ثم قال سبحانه: <q>﴿وإلينا يرجعون﴾</q>، يعني: في الآخرة بعد الموت{1}. (ز) ٤٦٦٧٢- قال يحيى بن سلّام: قوله: <q>﴿إنا نحن نرث الأرض ومن عليها﴾</q> نُهْلِك الأرض ومن عليها، <q>﴿وإلينا يرجعون﴾</q> يوم القيامة{2}. (ز) <q>﴿إِنَّا نَحۡنُ نَرِثُ ٱلۡأَرۡضَ وَمَنۡ عَلَیۡهَا وَإِلَیۡنَا یُرۡجَعُونَ ۝٤٠﴾</q> - آثار متعلقة بالآية ٤٦٦٧٣- عن عمر بن عبد العزيز أنّه كتب إلى عامله بالكوفة: أما بعد، فإنّ الله كتب على خلقه حين خلقهم الموتَ، فجعل مصيرَهم إليه، وقال فيما أنزل في كتابه الصادق الذي حفظه بعلمه، وأشهد ملائكته على حفظه: أنّه يرث الأرض ومن عليها، وإليه يرجعون{3}. (١٠/٧٥) ",footnotes:1:تفسير مقاتل بن سليمان ٢/٦٢٩.تفسير يحيى بن سلام ١/٢٢٦.أخرجه ابن أبي حاتم -كما في تفسير ابن كثير (ط أولاد الشيخ) ٩/٢٥٠.
19,41," <q>﴿وَٱذۡكُرۡ فِی ٱلۡكِتَـٰبِ إِبۡرَ ٰ⁠هِیمَۚ إِنَّهُۥ كَانَ صِدِّیقࣰا نَّبِیًّا ۝٤١﴾</q> - تفسير ٤٦٦٧٤- عن إسماعيل السُّدِّيّ: <q>﴿واذكر في الكتاب إبراهيم﴾</q>، يقول: اذكر لأهل مكة أمرَ إبراهيم{1}. (ز) ٤٦٦٧٥- قال مقاتل بن سليمان: <q>﴿واذكر﴾</q> يا محمد، لأهل مكة <q>﴿في الكتاب﴾</q> يعني: في القرآن أمر <q>﴿إبراهيم إنه كان صديقا﴾</q> يعني: مؤمنًا بالله تعالى <q>﴿نبيا﴾</q>. مثل قوله سبحانه: <q>﴿وأمه صديقة﴾</q> [المائدة:٧٥]، يعني: مؤمنة{2}. (ز) ٤٦٦٧٦- قال يحيى بن سلام، في قوله: <q>﴿واذكر في الكتاب إبراهيم﴾</q>: أي: اقرأه عليهم{3}. (ز) ",footnotes:1:علَّقه يحيى بن سلام ١/٢٢٦.تفسير مقاتل بن سليمان ٢/٦٢٩.تفسير يحيى بن سلام ١/٢٢٦.
19,42," <q>﴿إِذۡ قَالَ لِأَبِیهِ یَـٰۤأَبَتِ لِمَ تَعۡبُدُ مَا لَا یَسۡمَعُ وَلَا یُبۡصِرُ وَلَا یُغۡنِی عَنكَ شَیۡـࣰٔا ۝٤٢﴾</q> - قراءات ٤٦٦٧٧- عن عبد الله بن عامر -من طريق ابن الحارث- قال: قراءة أهل الشام: ‹إذْ قالَ إبْراهِيمُ لِأَبِيهِ يَآ أبَتَ› بالنصب{1}. (ز) <q>﴿إِذۡ قَالَ لِأَبِیهِ یَـٰۤأَبَتِ لِمَ تَعۡبُدُ مَا لَا یَسۡمَعُ وَلَا یُبۡصِرُ وَلَا یُغۡنِی عَنكَ شَیۡـࣰٔا ۝٤٢﴾</q> - تفسير الآية ٤٦٦٧٨- قال مقاتل بن سليمان: <q>﴿إذ قال لأبيه﴾</q> آزر: <q>﴿يا أبت لم تعبد ما لا يسمع﴾</q> الصوتَ، <q>﴿ولا يبصر﴾</q> شيئًا، يعني: الأصنام، <q>﴿ولا يغني عنك شيئا﴾</q> في الآخرة{2}. (ز) <q>﴿إِذۡ قَالَ لِأَبِیهِ یَـٰۤأَبَتِ لِمَ تَعۡبُدُ مَا لَا یَسۡمَعُ وَلَا یُبۡصِرُ وَلَا یُغۡنِی عَنكَ شَیۡـࣰٔا ۝٤٢﴾</q> - آثار متعلقة بالآية ٤٦٦٧٩- عن أنس، قال: قال رسول الله ﷺ: «حقُّ الوالدِ على ولده ألا يُسَمِّيَه إلا بما سمى إبراهيمُ به أباه: يا أبت. ولا يسميه باسمه»{3}. (١٠/٧٥) ",footnotes:1:أخرجه إسحاق البستي في تفسيره ص١٩١. و‹يَآ أبَتَ› بفتح التاء قراءة متواترة، قرأ بها ابن عامر، وأبو جعفر، وقرأ بقية العشرة: <q>﴿يَآ أبَتِ﴾</q> بكسر التاء. انظر: الإتحاف ص٣٧٨.تفسير مقاتل بن سليمان ٢/٦٢٩.أخرجه الديلمي -كما في كنز العمال ١٦/٤٧٤ (٤٥٥١٣)-.
19,43," <q>﴿یَـٰۤأَبَتِ إِنِّی قَدۡ جَاۤءَنِی مِنَ ٱلۡعِلۡمِ مَا لَمۡ یَأۡتِكَ﴾</q> - تفسير ٤٦٦٨٠- قال مقاتل بن سليمان: <q>﴿يا أبت إني قد جاءني من العلم﴾</q> يعني: البيان <q>﴿ما لم يأتك﴾</q> يعني: ما يكون مِن بعد الموت{1}. (ز) ٤٦٦٨١- قال يحيى بن سلّام، في قوله: <q>﴿إني قد جاءني من العلم ما لم يأتك﴾</q>: يعني: النبوة{2}. (ز) <q>﴿فَٱتَّبِعۡنِیۤ أَهۡدِكَ صِرَ ٰ⁠طࣰا سَوِیࣰّا ۝٤٣﴾</q> - تفسير ٤٦٦٨٢- عن إسماعيل السُّدِّيّ: <q>﴿فاتبعني أهدك صراطا سويا﴾</q>، يعني: دينًا عدلًا، وهو الإسلام{3}. (ز) ٤٦٦٨٣- قال مقاتل بن سليمان: <q>﴿فاتبعني﴾</q> على ديني؛ <q>﴿أهدك صراطا سويا﴾</q> يعني: طريقًا عَدْلًا، يعني: دين الإسلام{1}. (ز) ٤٦٦٨٤- قال يحيى بن سلّام: قوله: <q>﴿فاتبعني أهدك صراطا سويا﴾</q> طريقًا مستقيمًا إلى الجنة{2}. (ز) ",footnotes:1:تفسير مقاتل بن سليمان ٢/٦٢٩.تفسير يحيى بن سلام ١/٢٢٦.علَّقه يحيى بن سلام ١/٢٢٦.تفسير مقاتل بن سليمان ٢/٦٢٩.تفسير يحيى بن سلام ١/٢٢٦.
19,44," <q>﴿یَـٰۤأَبَتِ لَا تَعۡبُدِ ٱلشَّیۡطَـٰنَۖ إِنَّ ٱلشَّیۡطَـٰنَ كَانَ لِلرَّحۡمَـٰنِ عَصِیࣰّا ۝٤٤﴾</q> - تفسير ٤٦٦٨٥- قال مقاتل بن سليمان: <q>﴿يا أبت لا تعبد الشيطان﴾</q> يعني: لا تُطِعِ الشيطان في العبادة؛ <q>﴿إن الشيطان كان للرحمن عصيا﴾</q> يعني: عاصيًا ملعونًا{1}. (ز) ٤٦٦٨٦- قال يحيى بن سلّام: <q>﴿يا أبت لا تعبد الشيطان إن الشيطان كان للرحمن عصيا﴾</q>، إنّ عبادة الوثن عبادةُ الشيطان؛ لأنّ الوَثَنَ لم يَدْعُه إلى عبادة نفسه، ولكن الشيطان دعاه إلى عبادته. كقوله: <q>﴿إن يدعون من دونه إلا إناثا﴾</q> إلا أمواتًا، شيئًا ليس فيه روح، <q>﴿وإن يدعون إلا شيطانا مريدا﴾</q> [النساء:١١٧]{2}٤١٧٦. (ز) ٤١٧٦ ذكر ابنُ عطية (٦/٣٦) أنّ قوله: <q>﴿لا تعبد الشيطان﴾</q> يحتمل أن يكون أبو إبراهيم ممن عبد الجن، ويحتمل أن يجعل طاعة الشيطان المُغْوي في عبادة الأوثان والكفر بالله؛ عبادة له. ",footnotes:1:تفسير مقاتل بن سليمان ٢/٦٢٩.تفسير يحيى بن سلام ١/٢٢٧.
19,45," <q>﴿یَـٰۤأَبَتِ إِنِّیۤ أَخَافُ أَن یَمَسَّكَ عَذَابࣱ مِّنَ ٱلرَّحۡمَـٰنِ فَتَكُونَ لِلشَّیۡطَـٰنِ وَلِیࣰّا ۝٤٥﴾</q> - تفسير ٤٦٦٨٧- قال مقاتل بن سليمان: <q>﴿يا أبت إني أخاف أن يمسك﴾</q> يعني: أن يُصيبك <q>﴿عذاب من الرحمن﴾</q> في الآخرة، <q>﴿فتكون للشيطان وليا﴾</q> يعني: قريبًا في الآخرة{1}. (ز) ٤٦٦٨٨- قال يحيى بن سلّام: قوله: <q>﴿يا أبت إني أخاف أن يمسك عذاب من الرحمن فتكون للشيطان وليا﴾</q>، أي: إنك إذا نزل بك العذابُ لم تُقْبَل توبتُك، وما لم ينزل العذابُ فتوبتُك مقبولةٌ إن تُبتَ. وقد كان إبراهيمُ يرجو أن يتوب، فلمّا مات على الكفر ذهب ذلك الرجاء{2}. (ز) ",footnotes:1:تفسير مقاتل بن سليمان ٢/٦٢٩. ولعل لفظ «قريبًا» تصحَّف من «قرينًا».تفسير يحيى بن سلام ١/٢٢٧.
19,46," <q>﴿قَالَ أَرَاغِبٌ أَنتَ عَنۡ ءَالِهَتِی یَـٰۤإِبۡرَ ٰ⁠هِیمُۖ﴾</q> - تفسير ٤٦٦٨٩- قال مقاتل بن سليمان: فردَّ عليه أبوه، فـ<q>﴿قال أراغب أنت عن آلهتي ياإبراهيم لئن لم تنته لأرجمنك﴾</q>{1}. (ز) ٤٦٦٩٠- قال يحيى بن سلّام: قوله: <q>﴿قال أراغب أنت عن آلهتي يا إبراهيم﴾</q> أن تعبدها{2}. (ز) <q>﴿لَىِٕن لَّمۡ تَنتَهِ لَأَرۡجُمَنَّكَۖ﴾</q> - تفسير ٤٦٦٩١- عن عبد الله بن عباس -من طريق عطاء- في قوله: <q>﴿لأرجمنك﴾</q>، قال: لأشتُمنَّك{3}. (١٠/٧٦) ٤٦٦٩٢- قال عبد الله بن عباس: لأضربنك{4}. (ز) ٤٦٦٩٣- عن الضحاك بن مزاحم -من طريق عبيد بن سليمان- يقول في قوله: <q>﴿لأرجمنك﴾</q>: يعني: رجم القول{5}. (ز) ٤٦٦٩٤- قال الضحاك بن مزاحم، في قوله: <q>﴿لأرجمنك﴾</q>: لأشتمنك{4}. (ز) ٤٦٦٩٥- قال عكرمة مولى ابن عباس: لأقتلنَّك بالحجارة{7}. (ز) ٤٦٦٩٦- عن إسماعيل السُّدِّيّ -من طريق أسباط-: <q>﴿لأرجمنك﴾</q> بالشتيمة والقول{8}. (ز) ٤٦٦٩٧- قال [أبو حمزة] الثُّمالِيُّ: كلُّ شيء في القرآن مِن ذكر المرجومين فإنّه يعني بذلك: القتل، إلا التي في سورة مريم: <q>﴿لئن لم تنته لأرجمنك﴾</q> فإنه يعني: لأشتمنَّك{9}. (ز) ٤٦٦٩٨- قال محمد بن السائب الكلبي، في قوله: <q>﴿لأرجمنك﴾</q>: لأشتمنك {4}. (ز) ٤٦٦٩٩- قال مقاتل بن سليمان: <q>﴿لئن لم تنته لأرجمنك﴾</q>، يعني: لئن لم تسكت لأشتمنك، ... وكُلُّ شيء في القرآن <q>﴿لأرجمنك﴾</q> يعني: به القتل، غير هذا {11}. (ز) ٤٦٧٠٠- قال عبد الملك ابن جُرَيْج -من طريق حجاج- في قوله: <q>﴿لئن لم تنته لأرجمنك﴾</q>، قال: بالقول؛ لأشتمنك{12}. (ز) ٤٦٧٠١- قال يحيى بن سلّام: قوله: <q>﴿لئن لم تنته﴾</q> عن شتمها وذمِّها؛ <q>﴿لأرجمنك﴾</q> بالحجارة، فلأقتلنك بها{2}٤١٧٧. (ز) ٤١٧٧ ذكر ابنُ عطية (٦/٣٧) أنّ من قال: معنى <q>﴿لأرجمنك﴾</q>: لأرجمنك بالحجارة، كقول مَن قال: المعنى: لأقتلنك. <q>﴿وَٱهۡجُرۡنِی مَلِیࣰّا ۝٤٦﴾</q> - تفسير ٤٦٧٠٢- عن عبد الله بن عباس، في قوله: <q>﴿واهجرني مليا﴾</q>، قال: حِينًا{14}. (١٠/٧٦) ٤٦٧٠٣- عن عبد الله بن عباس -من طريق علي- في قوله: <q>﴿واهجرني مليا﴾</q>، قال:اجْتَنِبْني سَوِيًّا{15}٤١٧٨. (١٠/٧٦) ٤١٧٨ ذكر ابنُ جرير (١٥/٥٥٤) أنّ مَن قالوا بهذا القول وجَّهوا معنى المَلِيِّ إلى قول الناس: فلان مَلِيٌّ بهذا الأمر: إذا كان مضطلعًا به غنيًّا منه. ثم قال: «وكأن معنى الكلام كان عندهم: واهجرني وعِرْضُك وافِرٌ من عقوبتي، وجسمُك مُعافًى مِن أذاي». وبنحوه ابنُ عطية (٦/٣٨). ٤٦٧٠٤- عن عبد الله بن عباس-من طريق العوفي- في قوله: <q>﴿واهجرني مليا﴾</q>، قال: اجتنبني سالِمًا قبل أن يصيبك مِنِّي عقوبة{16}٤١٧٩. (١٠/٧٦) ٤١٧٩ ذكر ابنُ عطية (٦/٣٧) أن قوله: <q>﴿واهجرني﴾</q> -على من تأول <q>﴿لأرجمنك﴾</q>: القتل والرجم بالحجارة- إنّما يَتَرَتَّب على أنه أمرٌ على حياته؛ كأنه قال: إن لم تنته قتلتك بالرجم، ثم قال له: واهْجُرْنِي، أي: مع انتهائك، كأنه جزم له الأمر بالهجرة، وإلا فمع الرجم لا تترتب الهجرة. ٤٦٧٠٥- عن عبد الله بن عباس: أنّ نافع بن الأزرق قال له: أخبِرني عن قوله: <q>﴿واهجرني مليا﴾</q>، ما المَلِيُّ؟ قال: طويلًا، قال فيه المهلهل: وتصدَّعتْ صُمُّ الجبالِ لموتهِ وبَكَتْ عليه المُرْمِلاتُ مَلِيّا{17}. (١٠/٧٧) ٤٦٧٠٦- عن سعيد بن جبير -من طريق أبي حصين- في قوله: <q>﴿واهجرني مليا﴾</q>، قال: دهرًا{18}. (١٠/٧٦) ٤٦٧٠٧- عن عكرمة مولى ابن عباس -من طريق حصين-، مثله{19}. (١٠/٧٦) ٤٦٧٠٨- عن مجاهد بن جبر -من طريق ابن أبي نَجِيحٍ- <q>﴿واهجرني مليا﴾</q>، قال: حينًا{20}. (١٠/٧٧) ٤٦٧٠٩- عن الضَّحّاك بن مُزاحِم -من طريق عبيد- يقول في قوله: <q>﴿واهجرني مليا﴾</q>: اجتنِبْني سالِمًا، لا يُصِيبُك مِنِّي مَعَرَّة{21}. (ز) ٤٦٧١٠- عن الحسن البصري -من طريق قتادة- في قوله: <q>﴿واهجرني مليا﴾</q>، قال: زمانًا طويلًا{22}٤١٨٠. (ز) ٤١٨٠ ذكر ابنُ جرير (١٥/٥٥٢) أنّ مَن قالوا بهذا القول وجَّهوا معنى المَلِيّ إلى المِلاوة من الزمان، وهو الطويل منه. وبنحوه ابنُ عطية (٦/٣٨). ٤٦٧١١- عن الحسن البصري، <q>﴿واهجرني مليا﴾</q>، قال: سالِمًا{23}. (١٠/٧٦) ٤٦٧١٢- عن عطية الجدلي [العوفي] -من طريق قُرَّة بن خالد- <q>﴿واهجرني مليا﴾</q>، قال: سالِمًا{24}. (ز) ٤٦٧١٣- قال عطاء: سالِمًا{25}. (ز) ٤٦٧١٤- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿واهجرني مليا﴾</q>، قال: سالِمًا{26}. (١٠/٧٦) ٤٦٧١٥- عن إسماعيل السُّدِّيّ -من طريق أسباط- <q>﴿واهجرني مليا﴾</q>، قال: أبدًا{27}. (ز) ٤٦٧١٦- قال محمد بن السائب الكلبي: اتركني واجنبني طويلًا فلا تكلمني{4}. (ز) ٤٦٧١٧- قال مقاتل بن سليمان: <q>﴿واهجرني مليا﴾</q>، يعني: أيام حياتك. ويقال: طويلًا، واعتَزِلْنِي وأطِل هجراني{1}. (ز) ٤٦٧١٨- عن محمد بن إسحاق -من طريق سلمة- <q>﴿واهجرني مليا﴾</q>، يقول: دهرًا، والدهر: الملِيُّ{27}. (ز) ٤٦٧١٩- قال يحيى بن سلّام: أي: وأطِل هُجراني{2}٤١٨١. (ز) ٤١٨١ اختُلِف في معنى قوله: <q>﴿مليا﴾</q>؛ فقال قوم: حينًا طويلًا ودهرًا. وقال آخرون: سويًّا سالِمًا مِن عقوبتي إيّاك. ورجَّح ابنُ جرير (١٥/٥٥٥) مستندًا إلى السياق القولَ الثاني الذي قاله ابن عباس، والضحاك، وقتادة، وعطية الجدلي. وانتقد الأول، فقال: «لأنه عقيب قوله: <q>﴿لئن لم تنته لأرجمنك﴾</q>، وذلك وعيد منه له إن لم ينته عن ذكر آلهته بالسوء أن يرجمه بالقول السيِّئ، والذي هو أولى بأن يتبع ذلك التقدم إليه بالانتهاء عنه قبل أن تناله العقوبة، فأمّا الأمر بطول هجره فلا وجْه له». ",footnotes:1:تفسير مقاتل بن سليمان ٢/٦٣٠.تفسير يحيى بن سلام ١/٢٢٨.أخرجه ابن أبي حاتم -كما في تغليق التعليق ٤/٢٤٨-. وعزاه السيوطي إلى ابن المنذر. وعزا الحافظ في فتح الباري ٨/٤٢٧ من وجه آخر عن ابن عباس قال: الرجم: الكلام. وفي المطبوع من تفسير ابن جرير ١٥/٥٥١ نحو ذلك من قول ابن جرير.تفسير الثعلبي ٦/٢١٧، وتفسير البغوي ٥/٢٣٤.أخرجه ابن جرير ١٥/٥٥٢، وإسحاق البستي في تفسيره ص١٩٢.تفسير الثعلبي ٦/٢١٧، وتفسير البغوي ٥/٢٣٤.تفسير البغوي ٥/٢٣٤.أخرجه ابن جرير ١٥/٥٥٢. وعلقه يحيى بن سلام ١/٢٢٧ مختصرًا.تفسير الثعلبي ٧/١٧٣.تفسير الثعلبي ٦/٢١٧، وتفسير البغوي ٥/٢٣٤.تفسير مقاتل بن سليمان ٢/٦٣٠. وقوله: «لأشتمنك» في تفسير الثعلبي ٦/٢١٧، وتفسير البغوي ٥/٢٣٤، منسوبًا إلى مقاتل مهملًا.أخرجه ابن جرير ١٥/٥٥٢.تفسير يحيى بن سلام ١/٢٢٨.عزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.أخرجه ابن جرير ١٥/٥٥٤، وابن أبي حاتم -كما في الإتقان ٢/٢٦-. وعزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ١٥/٥٥٤. وعزاه السيوطي إلى ابن أبي حاتم. وفي تفسير مقاتل بن سليمان ٢/٦٣٠: واعتزلني سالِمَ العِرْض لا يصيبك مني مَعَرَّة.أخرجه ابن الأنباري في الوقف والابتداء ١/٩١ (١١٦).أخرجه ابن جرير ١٥/٥٥٣. وعزاه السيوطي إلى عبد بن حميد، وابن أبي حاتم.أخرجه ابن جرير ١٥/٥٥٢. وعزاه السيوطي إلى عبد بن حميد. وفي تفسير البغوي ٥/٢٣٤: حينًا.أخرجه يحيى بن سلام ١/٢٢٧ من طريق عاصم بن حكيم، وابن جرير ١٥/٥٥٣، وإسحاق البستي في تفسيره ص١٩٢ من طريق ابن جريج. وعزاه السيوطي إلى عبد بن حميدأخرجه ابن جرير ١٥/٥٥٥، وإسحاق البستي في تفسيره ص١٩٢.أخرجه يحيى بن سلام ١/٢٢٧، وعبد الرزاق ٢/٨ من طريق معمر، ومن طريقه ابن جرير ١٥/٥٥٣.عزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ١٥/٥٥٥.تفسير الثعلبي ٦/٢١٧، وتفسير البغوي ٥/٢٣٥.أخرجه يحيى بن سلام ١/٢٢٧، وعبد الرزاق ٢/٩، وابن جرير ١٥/٥٥٤. وعزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ١٥/٥٥٣.تفسير الثعلبي ٦/٢١٧، وتفسير البغوي ٥/٢٣٤.تفسير مقاتل بن سليمان ٢/٦٣٠.أخرجه ابن جرير ١٥/٥٥٣.تفسير يحيى بن سلام ١/٢٢٨.
19,47," <q>﴿قَالَ سَلَـٰمٌ عَلَیۡكَۖ سَأَسۡتَغۡفِرُ لَكَ رَبِّیۤۖ﴾</q> - تفسير ٤٦٧٢٠- قال الحسن البصري: وهذه كلمة حِلْمٍ{1}. (ز) ٤٦٧٢١- عن إسماعيل السُّدِّيّ: <q>﴿قال﴾</q> إبراهيم: <q>﴿سلام عليك﴾</q> يعني: رُدَّ خيرًا{2}٤١٨٢. (ز) ٤١٨٢ ذكر ابنُ عطية (٦/٣٩) قولًا للسُّدِّيِّ بأنه أخَّره بالاستغفار إلى السحر. وانتقده مستندًا إلى دلالة العقل، فقال: «وهذا تعسُّف، وإنما ذكر ذلك في أمر يعقوب وبنيه، وأما هذا فوعدٌ باستغفار كثير مُؤتَنَف، فالسين مُتَمَكِّنة». ٤٦٧٢٢- قال مقاتل بن سليمان: <q>﴿قال﴾</q> إبراهيم: <q>﴿سلام عليك سأستغفر لك ربي﴾</q>{3}. (ز) ٤٦٧٢٣- قال يحيى بن سلّام: وأما قوله: <q>﴿سأستغفر لك ربي﴾</q> فهو قوله: <q>﴿وما كان استغفار إبراهيم لأبيه إلا عن موعدة وعدها إياه﴾</q> [التوبة:١١٤]{4}. (ز) <q>﴿إِنَّهُۥ كَانَ بِی حَفِیࣰّا ۝٤٧﴾</q> - تفسير ٤٦٧٢٤- عن عبد الله بن عباس -من طريق علي- في قوله: <q>﴿إنه كان بي حفيا﴾</q>، قال: لطيفًا{5}. (١٠/٧٧) ٤٦٧٢٥- عن مجاهد بن جبر، في قوله: <q>﴿إنه كان بي حفيا﴾</q>، قال: عوَّده الإجابة{6}. (١٠/٧٧) ٤٦٧٢٦- عن مجاهد بن جبر -من طريق ابنه عبد الوهاب- في قوله تعالى: <q>﴿سأستغفر لك ربي إنه كان بي حفيا﴾</q>، قال: رحيمًا{7}. (ز) ٤٦٧٢٧- عن الحسن البصري: <q>﴿إنه كان بي حفيا﴾</q> بدعائي، فلا يَرُدُّه عَلَيَّ{1}. (ز) ٤٦٧٢٨- عن محمد بن السائب الكلبي: إنه كان بي رحيمًا{1}. (ز) ٤٦٧٢٩- قال محمد بن السائب الكلبي: عالِمًا يستجيب لي إذا دعوتُه{10}. (ز) ٤٦٧٣٠- قال مقاتل بن سليمان: <q>﴿إنه كان بي حفيا﴾</q>، يعني: لطيفًا رحيمًا{11}. (ز) ٤٦٧٣١- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿إنه كان بي حفيا﴾</q>، قال: إنّه كان بي لطيفًا، فإنّ الحَفِيَّ: اللطيفُ{12}. (ز) ٤٦٧٣٢- قال يحيى بن سلّام: وقال بعضهم: لطيفًا{4}. (ز) ",footnotes:1:علَّقه يحيى بن سلام ١/٢٢٨.علقه يحيى بن سلام ١/٢٢٨.تفسير مقاتل بن سليمان ٢/٦٣٠.تفسير يحيى بن سلام ١/٢٢٨.أخرجه ابن جرير ١٠/٦١٤، ١٥/٥٥٦، وابن أبي حاتم ٥/١٦٢٨. وعزاه السيوطي إلى ابن المنذر.عزاه السيوطي إلى عبد بن حميد، وابن أبي حاتم.أخرجه أبو نعيم في حلية الأولياء ٣/٢٩٢.علَّقه يحيى بن سلام ١/٢٢٨.علَّقه يحيى بن سلام ١/٢٢٨.تفسير الثعلبي ٦/٢١٧، وتفسير البغوي ٥/٢٣٥.تفسير مقاتل بن سليمان ٢/٦٣٠. وهو في تفسير الثعلبي ٦/٢١٧، منسوبًا إلى مقاتل مهملًا.أخرجه ابن جرير ١٥/٥٥٦.تفسير يحيى بن سلام ١/٢٢٨.
19,48," <q>﴿وَأَعۡتَزِلُكُمۡ وَمَا تَدۡعُونَ مِن دُونِ ٱللَّهِ وَأَدۡعُوا۟ رَبِّی عَسَىٰۤ أَلَّاۤ أَكُونَ بِدُعَاۤءِ رَبِّی شَقِیࣰّا ۝٤٨﴾</q> - تفسير ٤٦٧٣٣- قال مقاتل بن سليمان: <q>﴿وأعتزلكم وما تدعون من دون الله﴾</q> وأعتزِلُ ما تعبدون مِن دون الله مِن الآلهة، فكان اعتزالُه إيّاهم أنّه فارقهم مِن كوثا، فهاجر منها إلى الأرض المقدسة، ثم قال إبراهيم: <q>﴿وأدعو ربي﴾</q> في الاستغفار لك، <q>﴿عسى ألا أكون بدعآء ربي شقيا﴾</q> يعني: خائِبًا بدعائي لك بالمغفرة{1}. (ز) ٤٦٧٣٤- قال يحيى بن سلّام: قوله: <q>﴿وأعتزلكم وما تدعون من دون الله﴾</q> يعني: أصنامهم، <q>﴿وأدعو ربي عسى ألا أكون بدعاء ربي شقيا﴾</q> أي: عسى أن أسْعَد به{2}. (ز) ",footnotes:1:تفسير مقاتل بن سليمان ٢/٦٣٠.تفسير يحيى بن سلام ١/٢٢٨.
19,49," <q>﴿فَلَمَّا ٱعۡتَزَلَهُمۡ وَمَا یَعۡبُدُونَ مِن دُونِ ٱللَّهِ وَهَبۡنَا لَهُۥۤ إِسۡحَـٰقَ وَیَعۡقُوبَۖ وَكُلࣰّا جَعَلۡنَا نَبِیࣰّا ۝٤٩﴾</q> - تفسير ٤٦٧٣٥- عن عبد الله بن عباس، في قوله: <q>﴿ووهبنا له إسحق ويعقوب﴾</q>، قال: يقول: وهبنا له إسحق ولدًا، ويعقوب ابنَ ابنِه{1}. (١٠/٧٧) ٤٦٧٣٦- قال مقاتل بن سليمان: <q>﴿فلما اعتزلهم و﴾</q> اعتزل <q>﴿ما يعبدون من دون الله﴾</q> مِن الآلهة، وهي الأصنام، وذهب مهاجرًا منها؛ <q>﴿وهبنا له﴾</q> بعد الهجرة إلى الأرض المقدسة <q>﴿إسحاق ويعقوب وكلا جعلنا نبيا﴾</q> يعني: إبراهيم، وإسحاق، ويعقوب{2}. (ز) ٤٦٧٣٧- قال يحيى بن سلّام: قوله: <q>﴿فلما اعتزلهم وما يعبدون من دون الله﴾</q> يعني: أصنامهم؛ <q>﴿وهبنا له إسحاق ويعقوب وكلا جعلنا نبيا﴾</q> أي: إبراهيم وإسحاق ويعقوب{3}. (ز) ",footnotes:1:عزاه السيوطي إلى ابن أبي حاتم.تفسير مقاتل بن سليمان ٢/٦٣٠.تفسير يحيى بن سلام ١/٢٢٨.
19,50," <q>﴿وَوَهَبۡنَا لَهُم مِّن رَّحۡمَتِنَا وَجَعَلۡنَا لَهُمۡ لِسَانَ صِدۡقٍ عَلِیࣰّا ۝٥٠﴾</q> - تفسير ٤٦٧٣٨- عن عبد الله بن عباس -من طريق علي- في قوله: <q>﴿وجعلنا لهم لسان صدق عليا﴾</q>، قال: الثناء الحسن{1}. (١٠/٧٧) ٤٦٧٣٩- قال محمد بن السائب الكلبي: <q>﴿ووهبنا لهم من رحمتنا﴾</q>: المال، والولد{2}. (ز) ٤٦٧٤٠- قال مقاتل بن سليمان: <q>﴿ووهبنا لهم من رحمتنا﴾</q> يعني: مِن نعمتنا، <q>﴿وجعلنا لهم لسان صدق عليا﴾</q> يعني: ثناءً حسنًا رفيقًا، يُثْنِي عليهم جميعُ أهل الأديان بعدهم{3}. (ز) ٤٦٧٤١- قال يحيى بن سلّام: قوله: <q>﴿ووهبنا لهم من رحمتنا﴾</q> النبوة، <q>﴿وجعلنا لهم لسان صدق عليا﴾</q> رفيعًا، سُنَّة يقتدي بهم مَن بعدَهم، وثناءٌ عليهم مِن بعدهم. كقوله: <q>﴿واجعل لي لسان صدق في الآخرين﴾</q> [الشعراء:٨٤]: أبْقَيْنا عليهم الثناء الحسن، وكقوله: <q>﴿وتركنا عليه في الآخرين﴾</q> [الصافات:٧٨]: أبقينا عليهم الثناء الحسن، وهو قوله: <q>﴿وآتيناه أجره في الدنيا﴾</q> [العنكبوت:٢٧]{4}. (ز) ",footnotes:1:أخرجه ابن جرير ١٥/٥٥٧، وابن أبي حاتم -كما في الإتقان ٢/٢٦-. وعزاه السيوطي إلى ابن المنذر.تفسير الثعلبي ٦/٢١٨، وتفسير البغوي ٥/٢٣٦.تفسير مقاتل بن سليمان ٢/٦٣٠.تفسير يحيى بن سلام ١/٢٢٨.
19,51," <q>﴿وَٱذۡكُرۡ فِی ٱلۡكِتَـٰبِ مُوسَىٰۤۚ إِنَّهُۥ كَانَ مُخۡلَصࣰا وَكَانَ رَسُولࣰا نَّبِیࣰّا ۝٥١﴾</q> - قراءات ٤٦٧٤٢- عن عاصم بن أبي النجود أنّه قرأ: <q>﴿إنّهُ كانَ مُخْلَصًا﴾</q> بنصب اللام{1}٤١٨٣. (١٠/٧٧) ٤١٨٣ اختُلِف في قراءة قوله: <q>﴿مخلصا﴾</q>، فقرأ قوم بفتح اللام، وقرأ غيرهم بكسرها. وذكر ابنُ جرير (١٥/٥٥٨) أنّ قراءة الكسر بمعنى: إنّه كان يخلص لله العبادة. وقراءة الفتح بمعنى: إنّ موسى كان الله قد أخلصه واصطفاه لرسالته. وبنحوه ابنُ عطية (٦/٤١)، وابنُ كثير (٩/٢٥٥). ورجَّح ابنُ جرير مستندًا إلى صحة المعنى صِحَّة كِلتا القراءتين، فقال: «والصواب مِن القول في ذلك عندي: أنه كان ﷺ مخلِصًا عبادة الله، مخلَصًا للرسالة والنبوة، فبأيتهما قرأ القارئ فمصيبٌ الصوابَ». <q>﴿وَٱذۡكُرۡ فِی ٱلۡكِتَـٰبِ مُوسَىٰۤۚ إِنَّهُۥ كَانَ مُخۡلَصࣰا وَكَانَ رَسُولࣰا نَّبِیࣰّا ۝٥١﴾</q> - تفسير الآية ٤٦٧٤٣- عن مجاهد بن جبر -من طريق ابن أبي نَجِيحٍ- في قوله: <q>﴿وكان رسولا نبيا﴾</q>، قال: النبيُّ وحده: الذي يُكلَّم، ويُنَزَّل عليه، ولا يُرْسَل. ولفظ ابن أبي حاتم: الأنبياء: الذين ليسوا برُسُل، يُوحى إلى أحدِهم، ولا يُرسَل إلى أحد. والرُّسُل: الأنبياء الذين يُوحى إليهم ويُرسَلون{2}. (١٠/٧٨) ٤٦٧٤٤- عن إسماعيل السُّدِّيّ: قوله: <q>﴿واذكر في الكتاب موسى﴾</q>، يقول: اذكر لأهل مكة أمر موسى، أي: اقْرَأهُ عليهم{3}. (ز) ٤٦٧٤٥- قال مقاتل بن سليمان: <q>﴿واذكر﴾</q> لأهل مكة <q>﴿في الكتاب موسى إنه كان مخلصا﴾</q> يعني: مُسْلِمًا مُوَحِّدًا، <q>﴿وكان رسولا نبيا﴾</q>{4}. (ز) ",footnotes:1:عزاه السيوطي إلى عبد بن حميد. وهي قراءة عاصم، وحمزة، والكسائي، وخلف العاشر، وقرأ بقية العشرة: ‹مُخْلِصًا› بكسر اللام. انظر: الإتحاف ص٣٧٨.أخرجه ابن جرير ١٥/٥٢٩. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.علَّقه يحيى بن سلام ١/٢٢٨.تفسير مقاتل بن سليمان ٢/٦٣٠.
