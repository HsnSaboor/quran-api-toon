quran[8]{c,v,t}:
12,79," <q>﴿قَالَ مَعَاذَ ٱللَّهِ أَن نَّأۡخُذَ إِلَّا مَن وَجَدۡنَا مَتَـٰعَنَا عِندَهُۥۤ إِنَّاۤ إِذࣰا لَّظَـٰلِمُونَ ۝٧٩﴾</q> - تفسير ٣٧٩١٦- عن إسماعيل السُّدِّيّ -من طريق أسباط- قال: فإذا أتيتم أباكم فاقرءوا عليه مِنِّي السلام، وقولوا له: إنّ ملِك مصر يدعو لك ألّا تموت حتى ترى ابنَك يوسف؛ حتّى يعلمَ أبوكم أنّ في الأرض صِدِّيقين مثله{1}. (٨/١٩٧) ٣٧٩١٧- قال مقاتل بن سليمان: قال يوسف: <q>﴿معاذ الله﴾</q> يقول: نعوذ بالله <q>﴿أن نأخذ﴾</q> يعني: أن نَحْبِس بالسرقة <q>﴿إلا من وجدنا متاعنا عنده إنا إذا لظالمون﴾</q> أن نأخذ البريءَ مكان السقيم{2}. (ز) ٣٧٩١٨- عن محمد بن إسحاق -من طريق سلمة- <q>﴿قال معاذ الله أن نأخذ إلا من وجدنا متاعنا عنده إنا إذا لظالمون﴾</q>، يقول: إن أخذنا غيرَ الذي وجدنا متاعنا عنده إنّا إذًا نفعل ما ليس لنا فِعْلُه، ونَجُور على الناس{3}. (ز) ",footnotes:1:أخرجه ابن جرير ١٣/ ٢٨٠، وابن أبي حاتم ٧/٢١٨١.تفسير مقاتل بن سليمان ٢/٣٤٧.أخرجه ابن جرير ١٣/٢٨٠.
12,80," <q>﴿فَلَمَّا ٱسۡتَیۡـَٔسُوا۟ مِنۡهُ﴾</q> - تفسير ٣٧٩١٩- قال مقاتل بن سليمان: <q>﴿فلما استيأسوا منه﴾</q>، يقول: يَئِسُوا مِن بنيامين{1}. (ز) ٣٧٩٢٠- عن محمد بن إسحاق -من طريق سلمة- <q>﴿فلما استيأسوا منه﴾</q>، قال: يئسوا مِنهُ، ورأوا شِدَّته في أمره{2}٣٤٢٨. (٨/٢٩٩) ٣٤٢٨ لم يذكر ابنُ جرير (١٣/٢٨١) غير قول محمد بن إسحاق. <q>﴿خَلَصُوا۟ نَجِیࣰّاۖ﴾</q> - تفسير ٣٧٩٢١- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿خَلَصُوا نَجِيًا﴾</q>، قال: وحدهم{3}. (٨/٢٩٩) ٣٧٩٢٢- عن إسماعيل السُّدِّيّ -من طريق أسباط- قال: فلمّا أيِسُوا منه، وأخرَج لهم شَمْعُونَ وقد كان ارْتَهَنَه؛ خَلَوْا بينهم <q>﴿نجيًا﴾</q> يَتَناجَوْن بينهم{4}. (٨/١٩٧) ٣٧٩٢٣- قال مقاتل بن سليمان: <q>﴿خلصوا نجيا﴾</q>، يعني: خَلَوْا يتناجون بينهم على حِدَةٍ{1}. (ز) ٣٧٩٢٤- عن محمد بن إسحاق -من طريق سلمة- <q>﴿فلما استيأسوا منه خلصوا نجيا﴾</q>، أي: خلا بعضهم ببعض، ثم قالوا: ماذا تَرَوْن؟{3}. (ز) ٣٧٩٢٥- عن سفيان الثوري، في قوله: <q>﴿فلما استيأسوا منه خلصوا نجيا﴾</q>، قال: تَشاوَرُوا تَشاوُرًا بوَسْوَسَة{7}. (ز) <q>﴿قَالَ كَبِیرُهُمۡ أَلَمۡ تَعۡلَمُوۤا۟ أَنَّ أَبَاكُمۡ قَدۡ أَخَذَ عَلَیۡكُم مَّوۡثِقࣰا مِّنَ ٱللَّهِ وَمِن قَبۡلُ مَا فَرَّطتُمۡ فِی یُوسُفَۖ﴾</q> - تفسير ٣٧٩٢٦- عن عبد الله بن عباس، في قوله: <q>﴿قال كبيرهم﴾</q>، قال: هو يَهُوذا، وهو أعقلهم{8}. (ز) ٣٧٩٢٧- عن كعب الأحبار، في قوله: <q>﴿قال كبيرهم﴾</q>، قال: هو رُوبِيل، وكان أسَنُّهُم، وهو الذي نهى إخوتَه عن قتله، وهو ابن خالة يوسف{9}. (ز) ٣٧٩٢٨- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿قال كبيرهم﴾</q>، قال: شَمْعُون الذي تخلَّف أكبرُهم عقلًا، وأكبر منه في الميلاد روبيل{10}. (٨/٢٩٩) ٣٧٩٢٩- عن الضَّحّاك بن مُزاحِم، في قوله: <q>﴿قال كبيرهم﴾</q>، قال: هو رُوبِيل، وكان أكبرَهم في السِّنِّ، وهو الذي نهى الإخوةَ عن قتل يوسف{11}. (ز) ٣٧٩٣٠- قال وهب بن مُنَبِّه، في قوله: <q>﴿قال كبيرهم﴾</q>: يهوذا، وكان أعقلَهم{9}. (ز) ٣٧٩٣١- عن وهب بن مُنَبِّه، قال: إنّ شمعان كان أشدَّ بني يعقوب بأسًا، وإنّه كان إذا غضب قام شعرُه وانتفخ، فلا يُطفِئ غضبُه شيءٌ إلا أن يَمَسَّه أحدٌ مِن آل يعقوب، وإنّه كان قد أغار مرَّةً على أهل قرية فدَمَّرهم، وإنّه غَضِب يومَ أُخِذ بنو يعقوب بالصُّواع غضبًا شديدًا حتى انتفخ، فأمر يوسفُ ﵇ ابنَه أن يَمَسَّه، فسكن غضبُه، وبرد، وقال: قد مسَّني يدٌ مِن آل يعقوب{13}. (٨/٣٠٠) ٣٧٩٣٢- عن قتادة بن دعامة -من طريق سعيد بن أبي عروبة- في قوله: <q>﴿قال كبيرُهُم﴾</q>، قال: هو روبيل، وهو الذي كان نهاهم عن قتله، وهو ابنُ خالته، وكان أكبرَ القوم{14}. (٨/٣٠٠) ٣٧٩٣٣- عن إسماعيل السُّدِّيّ-من طريق أسباط- قال: <q>﴿قال كبيرُهم﴾</q> وهو رُوبيل، ولم يكن بأكبرهم سِنًّا، ولكن كان كبيرَهم في العلم: <q>﴿ألم تعلموا أن أباكم قد أخذ عليكم موثقًا من الله ومن قبل ما فرطتم في يوسف فلن أبرح الأرض حتى يأذن لي أبى أو يحكم الله لي وهو خير الحاكمين﴾</q>. فأقام روبيل بمصر، وأَقْبَل التسعةُ إلى يعقوب، فأخبروه الخبر، فبكى، وقال: يا بَنِيَّ، ما تذهبون مِن مَرَّةٍ إلا نقصتم واحدًا؟! ذهبتُم فنقصتم يوسف، ثم ذهبتم الثانية فنقصتم شمعون، ثم ذهبتم الثالثة فنقصتم بنيامين ورُوبيل{15}. (٨/١٩٧) ٣٧٩٣٤- عن محمد بن السائب الكلبي، في قوله: <q>﴿قال كبيرهم﴾</q>، قال: هو يهوذا، وهو أعقلُهم{11}. (ز) ٣٧٩٣٥- قال مقاتل بن سليمان: وقال بعضُهم لبعض: <q>﴿قال كبيرهم﴾</q> يعني: عظيمهم في أنفسهم، وأعلمهم، وهو يهوذا، ولم يكن أكبرَهم في السن: <q>﴿ألم تعلموا أن أباكم قد أخذ عليكم موثقا من الله﴾</q> يعني: في أمر بنيامين لَتَأْتِينَّه به، <q>﴿ومن قبل﴾</q> بنيامين <q>﴿ما فرطتم في يوسف﴾</q> يعني: ضَيَّعْتُم{1}. (ز) ٣٧٩٣٦- عن محمد بن إسحاق -من طريق سلمة-: ... فقال رُوبِيل -كما ذُكِر لي، وكان كبيرَ القوم-: <q>﴿ألم تعلموا أن أباكم قد أخذ عليكم موثقا من الله ومن قبل ما فرطتم في يوسف﴾</q> الآية{18}. (ز) ٣٧٩٣٧- قال محمد بن إسحاق، في قوله: <q>﴿قال كبيرهم﴾</q>: لاوي{9}٣٤٢٩. (ز) ٣٤٢٩ اختُلِف في المعنيِّ بقوله: <q>﴿كبيرهم﴾</q> على أقوال: الأول: أنّ ذلك عُنِي به كبيرُهم في العقل والعلم، لا في السن، وهو شمعون في بعض الأقوال، ويهوذا في بعضها، ولاوي في بعضها الآخر. الثاني: أنّ ذلك عني به كبيرهم في السِّنِّ، وهو روبيل. وقد رجّح ابنُ جرير (١٣/٢٨٥) مستندًا إلى إجماع أهل التاريخ، وإلى اللغة القول الثاني، فقال: «وأولى الأقوال في ذلك بالصحة قولُ مَن قال: عنى بقوله: <q>﴿قال كبيرهم﴾</q>: روبيل؛ لإجماع جميعهم على أنّه كان أكبرهم سنًّا، ولا تفهم العرب في المخاطبة إذا قيل لهم: فلان كبير القوم. مطلقًا بغيرِ وصلٍ إلا أحد معنيين؛ إمّا في الرياسة عليهم والسؤدد، وإمّا في السن، فأمّا في العقل فإنهم إذا أرادوا ذلك وصلوه، فقالوا: هو كبيرهم في العقل. فأمّا إذا أطلق بغير صلته بذلك فلا يفهم إلا ما ذكرت. وقد قال أهل التأويل: لم يكن لشمعون -وإن كان قد كان مِن العلم والعقل بالمكان الذي جعله الله به- على إخوته رياسة وسُؤْدَد؛ فيُعْلَم بذلك أنه عُنِي بقوله: <q>﴿قال كبيرهم﴾</q>. فإذا كان ذلك كذلك فلم يبق إلا الوجه الآخر، وهو الكبر في السِّن، وقد قال الذين ذكرنا جميعًا: روبيل كان أكبر القوم سنًّا، فصحَّ بذلك القول الذي اخترناه». ووافقه ابنُ عطية (٥/١٣٠) بقوله: «وهذا أظهر». <q>﴿فَلَنۡ أَبۡرَحَ ٱلۡأَرۡضَ حَتَّىٰ یَأۡذَنَ لِیۤ أَبِیۤ﴾</q> - تفسير ٣٧٩٣٨- قال مقاتل بن سليمان: <q>﴿فلن أبرح الأرض﴾</q> يعني: أرض مصر<q>﴿حتى يأذن لي أبي﴾</q> في الرجعة{1}. (ز) ٣٧٩٣٩- عن محمد بن إسحاق -من طريق سلمة-: <q>﴿فلن أبرح الأرض﴾</q> التي أنا بها اليوم <q>﴿حتى يأذن لي أبي﴾</q> بالخروج منها{21}. (ز) ٣٧٩٤٠- عن الحميدي، قال حدَّثنا سفيان [بن عيينة]، قال: سمعتُ رجلًا سأل جابرًا الجعفي عن قوله: <q>﴿فلن أبرح الأرض حتى يأذن لي أبي أو يحكم الله لي وهو خير الحاكمين﴾</q>. قال جابر: لم يجئ تأويلُ هذه الآية بعدُ. قال سفيان: وكذب. قال الحميدي: فقلنا لسفيان: وما أراد بهذا؟ فقال: إنّ الرافضة تقول: إنّ عليًّا في السحاب، فلا يخرج مَعَ مَن خرج مِن ولده حتى ينادي مُنادٍ مِن السماء -يريد: أنّ عليًّا ينادي مِن السحاب-: اخرجوا مع فلان. يقول: فهذا تأويل هذه الآية، وكذب، هذه كانت في إخوة يوسف{22}. (ز) <q>﴿أَوۡ یَحۡكُمَ ٱللَّهُ لِیۖ وَهُوَ خَیۡرُ ٱلۡحَـٰكِمِینَ ۝٨٠﴾</q> - تفسير ٣٧٩٤١- عن مجاهد بن جبر، في قوله: <q>﴿أو يحكم الله لى﴾</q>، قال: أُقاتِل بالسيفِ حتى أُقْتَل{23}. (٨/٣٠٠) ٣٧٩٤٢- عن أبي صالح باذام -من طريق إسماعيل بن أبي خالد- في قوله: <q>﴿حتى يأذن لي أبي أو يحكم الله لي﴾</q>، قال: بالسَّيف{24}٣٤٣٠. (ز) ٣٤٣٠ وجَّه ابنُ جرير (١٣/٢٨٧) على قول أبي صالح، فقال: «وكأنّ أبا صالح وجّه تأويل قوله: <q>﴿أو يحكم الله لي﴾</q> إلى: أو يقضي الله لي بحربِ مَن منعني مِن الانصراف بأخي بنيامين إلى أبيه يعقوب، فأُحارِبُه». ٣٧٩٤٣- قال مقاتل بن سليمان: <q>﴿أو يحكم الله لي﴾</q> فيَرُدَّ عَلَيَّ بنيامين، <q>﴿وهو خير الحاكمين﴾</q> يعني: أفضل القاضِين{1}. (ز) ",footnotes:1:تفسير مقاتل بن سليمان ٢/٣٤٧.أخرجه ابن جرير ١٣/٢٨١، وابن أبي حاتم ٧/٢١٨١.أخرجه ابن جرير ١٣/٢٨٢، وابن أبي حاتم ٧/٢١٨١.أخرجه ابن جرير ١٣/ ٢٨٢، وابن أبي حاتم ٧/٢١٨١ مختصرًا.تفسير مقاتل بن سليمان ٢/٣٤٧.أخرجه ابن جرير ١٣/٢٨٢، وابن أبي حاتم ٧/٢١٨١.تفسير الثوري ص١٤٥.تفسير البغوي ٤/٢٦٥.تفسير الثعلبي ٥/٢٤٥.أخرجه ابن جرير ١٣/٢٨٣، وابن أبي حاتم ٧/٢١٨١. وعزاه السيوطي إلى ابن أبي شيبة، وابن المنذر، وأبي الشيخ.تفسير الثعلبي ٥/٢٤٥، وتفسير البغوي ٤/٢٦٥.تفسير الثعلبي ٥/٢٤٥.عزاه السيوطي إلى أبي الشيخ.أخرجه ابن جرير ١٣/٢٨٤، وابن أبي حاتم ٧/٢١٨١ بنحوه، كذلك من طريق سعيد بن بشير. كما أخرج نحوه عبد الرزاق في تفسيره ١/ ٣٢٧، وابن جرير ١٣/٢٨٤ من طريق مَعْمَر. وعزاه السيوطي إلى أبي الشيخ.أخرجه ابن جرير ١٣/٢٨٤ وفي آخره: وذهبتم الآن فنقصتم روبيل، وابن أبي حاتم ٧/٢١٨١، ٢١٨٢، ٢١٨٤. وفي تفسير الثعلبي ٥/٢٤٥، وتفسير البغوي ٤/٢٦٥ بنحوه، وفيه: وهو الذي نهى الإخوة عن قتل يوسف.تفسير الثعلبي ٥/٢٤٥، وتفسير البغوي ٤/٢٦٥.تفسير مقاتل بن سليمان ٢/٣٤٧.أخرجه ابن جرير ١٣/٢٨٤.تفسير الثعلبي ٥/٢٤٥.تفسير مقاتل بن سليمان ٢/٣٤٧.أخرجه ابن جرير ١٣/٢٨٦.أخرجه العقيلي في كتاب الضعفاء ١/٥١٨-٥١٩ (٩٢٦/٢٠)، وابن عدي في الكامل ٢/٣٣١، والفسوي في المعرفة والتاريخ ٢/٧١٥.عزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ١٣/٢٨٤، وابن أبي حاتم ٧/٢١٨٢.تفسير مقاتل بن سليمان ٢/٣٤٧.
12,81," <q>﴿ٱرۡجِعُوۤا۟ إِلَىٰۤ أَبِیكُمۡ فَقُولُوا۟ یَـٰۤأَبَانَاۤ إِنَّ ٱبۡنَكَ سَرَقَ وَمَا شَهِدۡنَاۤ إِلَّا بِمَا عَلِمۡنَا﴾</q> - قراءات ٣٧٩٤٤- عن عبد الله بن عباس أنّه قَرَأ: (إنَّ ابْنَكَ سُرِّقَ){1}٣٤٣١. (٨/٣٠٠) ٣٤٣١ علّق ابنُ جرير (١٣/٢٨٧) على هذه القراءة، فقال: «ورُوِي عن ابن عباس: (إنَّ ابْنَكَ سُرِّقَ) بضم السين وتشديد الراء، على وجه ما لم يُسَمَّ فاعله، بمعنى: أنه سُرِّق». وعلّق عليها ابنُ عطية (٣/٢٧٠) بقوله: «وكأنّ هذه القراءة فيها لهم تحرٍّ، ولم يقطعوا عليه بسرقة، وإنما أرادوا جُعِل سارقًا بما ظهر من الحال». <q>﴿ٱرۡجِعُوۤا۟ إِلَىٰۤ أَبِیكُمۡ فَقُولُوا۟ یَـٰۤأَبَانَاۤ إِنَّ ٱبۡنَكَ سَرَقَ وَمَا شَهِدۡنَاۤ إِلَّا بِمَا عَلِمۡنَا﴾</q> - تفسير الآية ٣٧٩٤٥- قال مقاتل بن سليمان: <q>﴿ارجعوا إلى أبيكم فقولوا يا أبانا إن ابنك سرق﴾</q> يعني: بنيامين، <q>﴿وما شهدنا إلا بما علمنا﴾</q> يعني: رَأَيْنا الصُّواعَ حين أُخْرِج مِن متاعه{2}. (ز) ٣٧٩٤٦- عن محمد بن إسحاق -من طريق سلمة-: <q>﴿ارجعوا إلى أبيكم﴾</q> فإنِّي ما كُنتُ راجِعًا حتى يأتيني أمره، <q>﴿فقولوا يا أبانا إن ابنك سرق، وما شهدنا إلا بما علمنا﴾</q> أي: قد وُجِدَت السرقة في رحِلِه ونحن ننظر، لا علم لنا بالغيب، <q>﴿وما كنا للغيب حافظين﴾</q>{3}٣٤٣٢. (ز) ٣٤٣٢ أفاد قولُ ابن إسحاق أنّ القائل: <q>﴿ارجعوا إلى أبيكم﴾</q> هو كبيرهم. وقد ذكر ذلك ابنُ عطية (٥/١٣١بتصرف)، ورجّحه بقوله: «وهو الأظهر». وذكر قولًا آخر أنّ قائل ذلك هو يوسف ﵇. ٣٧٩٤٧- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- قال: قال يعقوبُ ﵇ لبنيه: ما دَرى هذا الرجلُ أنّ السارق يُؤخَذ بسرقته إلا بقولكم. قالوا: <q>﴿وما شهدنا إلا بما علمنا﴾</q> لم نشهد أنّ السارق يُؤْخَذ بسرقته إلا وذاك الذي عَلِمْناه{4}٣٤٣٣. (٨/٣٠٠) ٣٤٣٣ اختُلِف في قوله: <q>﴿وما شهدنا إلا بما علمنا﴾</q> على قولين: الأول: أنّ معناه: وما قلنا: إنّه سرق. إلّا بظاهر علمنا حين رأينا صواعُ الملك في وعائه. الثاني: أنّ معناه: وما شهدنا عند يوسف بأنّ السارق يؤخذ بسرقته إلا بما علمنا. وقد رجّح ابنُ جرير (١٣/٢٩٠) مستندًا إلى السياق القول الأول، وعلَّل ذلك بقوله: «لأنّه عقيب قوله: <q>﴿إن ابنك سرق﴾</q>، فهو بأن يكون خبرًا عن شهادتهم بذلك أولى مِن أن يكون خبرًا عما هو منفصل». وبيّن ابنُ عطية (٥/١٣١-١٣٢) أنّ قوله: <q>﴿وما كنا للغيب حافظين﴾</q> على القول الأول معناه: والعلم في الغيب إلى الله، ليس ذلك في حفظنا. وعلى الثاني معناه: وما كُنّا للغيب حافظين أنّ السرقة تخرج مِن رَحِل أحدنا. ثم قال عقب ذكره الخلاف: «ويحتمل قوله: <q>﴿وما كُنّا لِلْغَيْبِ حافِظِينَ﴾</q> أي: حين واثقناك، إنّما قصدنا ألا يقع مِنّا نحن في جهته شيء يكرهه، ولم نعلم الغيب في أنّه سيأتي هو بما يوجب رِقَّه عندك إلا بما علمناه مِن ظاهر حاله، وما كنا بالليل حافظين لِما يقع مِن سرقته هو، أو التدليس عليه». <q>﴿ٱرۡجِعُوۤا۟ إِلَىٰۤ أَبِیكُمۡ فَقُولُوا۟ یَـٰۤأَبَانَاۤ إِنَّ ٱبۡنَكَ سَرَقَ وَمَا شَهِدۡنَاۤ إِلَّا بِمَا عَلِمۡنَا﴾</q> - آثار متعلقة بالآية ٣٧٩٤٨- عن قتادة، أنّ سليمان بن يسار حدَّث: أنّ عمر بن عبد العزيز قال: ما رأيتُ مثل القَسامَةِ قطُّ أُقِيدَ بها، واللهُ يقول: <q>﴿وأشهدوا ذوي عدل منكم﴾</q> [الطلاق:٢]. وقالت الأسباط: <q>﴿وما شهدنا إلا بما علمنا وما كنا للغيب حافظين﴾</q>. وقال الله: <q>﴿إلا من شهد بالحق وهم يعلمون﴾</q> [الزخرف:٨٦]{5}. (ز) ٣٧٩٤٩- عن إبراهيم النخعي -من طريق أبي معشر-: أنّه كرِه أن يكتم الرجلُ شهادتَه، فإذا اسْتُشْهِد شهَد. ويقرأ: <q>﴿وما شهدنا إلا بما علمنا﴾</q>{6}. (٨/٣٠١) <q>﴿وَمَا كُنَّا لِلۡغَیۡبِ حَـٰفِظِینَ ۝٨١﴾</q> - تفسير ٣٧٩٥٠- عن عبد الله بن عباس، في قوله: <q>﴿وما كنا للغيب حافظين﴾</q>، قال: ما كُنّا لليله ونهارِه ومجيئه وذهابه حافظين{7}. (ز) ٣٧٩٥١- عن عبد الله بن عباس -من طريق جُوَيْبِر، عن الضحاك- في قوله: <q>﴿وما كنا للغيب حافظين﴾</q>، قال: يعنون: أنّه سرق ليلًا وهم نيام. والغيب هو الليل بلغة حِمْيَر{8}. (ز) ٣٧٩٥٢- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿وما كنا للغيب حافظين﴾</q>، قال: لم نعلم أنّه سَيَسْرِق{9}. (٨/٣٠١) ٣٧٩٥٣- عن عكرمة مولى ابن عباس -من طريق يزيد- في قوله: <q>﴿وما كنا للغيب حافظين﴾</q>، قال: ما كُنّا نعلم أنّ ابنَك يسرق{10}. (٨/٣٠١) ٣٧٩٥٤- عن عكرمة مولى ابن عباس، في قوله: <q>﴿وما كنا للغيب حافظين﴾</q>، قال: وما كُنّا للغيب حافظين، فلَعَلَّها دُسَّت بالليل في رَحْله{7}. (ز) ٣٧٩٥٥- عن قتادة بن دعامة -من طريق مَعْمَر- في قوله: <q>﴿وما كنا للغيب حافظين﴾</q>، قال: يقولون: ما كُنّا نَظُنَّ أنّ ابنك يسرق{12}٣٤٣٤. (٨/٣٠١) ٣٤٣٤ لم يذكر ابنُ جرير (١٣/٢٨٩-٢٩٠) غير قول قتادة، وعكرمة من طريق يزيد، ومجاهد. ٣٧٩٥٦- قال مقاتل بن سليمان: <q>﴿وما كنا للغيب حافظين﴾</q>، يعني: وما كُنّا نرى أنه يسرق، ولو علمنا ما ذهبنا به معَنا{2}. (ز) ٣٧٩٥٧- عن محمد بن إسحاق -من طريق سلمة- <q>﴿وما كنا للغيب حافظين﴾</q>: فلا عِلْمَ لنا بالغيب{14}. (ز) ٣٧٩٥٨- عن عبد الرحمن بن زيد بن أسلم -من طريق أصبغ بن الفرج- يقول في قوله: <q>﴿وما كنا للغيب حافظين﴾</q>، قال: ما علِمنا مِن الغيب أنّه أخَذَ له شيئًا، ولا ظننّا ذلك، إنّما سألنا{15}: ما جزاء السارق؟{14}. (ز) ",footnotes:1:عزاه السيوطي إلى أبي الشيخ. وهي قراءة شاذة، تروى أيضًا عن أحمد بن جبير، وابن أبي شريح. انظر: مختصر ابن خالويه ص٦٩، والبحر المحيط ٥/٣٢٩.تفسير مقاتل بن سليمان ٢/٣٤٧.أخرجه ابن جرير ١٣/٢٨٨.أخرجه ابن جرير ١٣/٢٨٧-٢٨٨.أخرجه ابن أبي شيبة (ت: محمد عوامة) ١٤/٢٦٥-٢٦٦ (٢٨٣٨٥).أخرجه ابن أبي حاتم ٧/٢١٨٢.تفسير الثعلبي ٥/٢٤٦، وتفسير البغوي ٤/٢٦٦.تفسير الثعلبي ٥/٢٤٦.أخرجه ابن جرير ١٣/٢٨٩-٢٩٠ بلفظ: لم نشعر أنه سيسرق. وعزاه السيوطي إلى ابن أبى شيبة، وابن المنذر.أخرجه ابن جرير ١٣/٢٩٠، وابن أبي حاتم ٧/٢١٨٣. وعزاه السيوطي إلى أبي الشيخ.تفسير الثعلبي ٥/٢٤٦، وتفسير البغوي ٤/٢٦٦.أخرجه عبد الرزاق ١/٣٢٧، وابن جرير ١٣/٢٩٠، وابن أبي حاتم ٧/٢١٨٣. وعزاه السيوطي إلى ابن المنذر، وأبي الشيخ.تفسير مقاتل بن سليمان ٢/٣٤٧.أخرجه ابن أبي حاتم ٧/٢١٨٣.كذا في المطبوع، ولعلها: سُئلنا.أخرجه ابن أبي حاتم ٧/٢١٨٣.
12,82," <q>﴿وَسۡـَٔلِ ٱلۡقَرۡیَةَ ٱلَّتِی كُنَّا فِیهَا﴾</q> - تفسير ٣٧٩٥٩- عن عبد الله بن عباس -من طريق ابن جُرَيْج- <q>﴿وسئل القرية التي كنا فيها﴾</q>، قال: يعنون: مِصْر{1}٣٤٣٥. (٨/٣٠١) ٣٤٣٥ بيّن ابنُ عطية (٥/١٣٨) أنّ قول ابن عباس هذا على المجاز، والمراد: أهل مصر. ورجّحه بقوله: «هذا قول الجمهور، وهو الصحيح». ولم يذكر مستندًا، ثم ذكر قولًا آخر أنّ هذا مِن الحذف، وليس من المجاز. ٣٧٩٦٠- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿وسئل القرية﴾</q>، قال: مِصْر{2}. (٨/٣٠١) ٣٧٩٦١- قال مقاتل بن سليمان: <q>﴿واسأل القرية﴾</q> يعني: مِصْر <q>﴿التي كنا فيها﴾</q> أنّه سَرَق{3}. (ز) ٣٧٩٦٢- عن محمد بن إسحاق -من طريق سلمة- قال: قد عَرَف رُوبِيلُ في رَجْعِ قولِه لإخوته أنّهم أهل تُهْمَةٍ عند أبيهم؛ لِما كانوا صنعوا في يوسف. وقولهم له: <q>﴿اسأل القرية التي كنا فيها والعير التي أقبلنا فيها﴾</q>؛ فقد علِموا ما علِمنا، وشهدوا ما شهدنا إن كنتَ لا تصدقنا، <q>﴿وإنا لصادقون﴾</q>{4}. (ز) <q>﴿وَٱلۡعِیرَ ٱلَّتِیۤ أَقۡبَلۡنَا فِیهَاۖ وَإِنَّا لَصَـٰدِقُونَ ۝٨٢﴾</q> - تفسير ٣٧٩٦٣- عن مجاهد بن جبر -من طريق ابن جريج- في قوله: <q>﴿والعير﴾</q>، قال: هي حَمِير{5}. (ز) ٣٧٩٦٤- قال مقاتل بن سليمان: <q>﴿والعير التي أقبلنا فيها وإنا لصادقون﴾</q> فيما نقول{3}. (ز) ",footnotes:1:أخرجه ابن جرير ١٣/٢٩١. وعزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ١٣/٢٩٢، وابن أبي حاتم ٧/٢١٨٤. وعزاه السيوطي إلى أبي الشيخ.تفسير مقاتل بن سليمان ٢/٣٤٧.أخرجه ابن جرير ١٣/٢٩١، وابن أبي حاتم ٧/٢١٨٣.أخرجه ابن أبي حاتم ٧/٢١٨٣.تفسير مقاتل بن سليمان ٢/٣٤٧.
12,83," <q>﴿قَالَ بَلۡ سَوَّلَتۡ لَكُمۡ أَنفُسُكُمۡ أَمۡرࣰاۖ فَصَبۡرࣱ جَمِیلٌۖ﴾</q> - تفسير ٣٧٩٦٥- عن قتادة بن دعامة -من طريق سعيد بن أبي عروبة- قوله: <q>﴿بل سولت لكم أنفسكم أمرا﴾</q>، أي: زَيَّنت لكم أنفسُكم أمرًا{1}. (ز) ٣٧٩٦٦- قال مقاتل بن سليمان: قال لهم يعقوب: كُلَّما ذهبتم نقص منكم واحد! وكان يوسف ﵇ حبس بِنيامين، وأقام شمعون ويهوذا، فاتَّهمهم يعقوب ﵇، فـ<q>﴿قال بل سولت لكم﴾</q> يعني: ولكن زَيَّنَتْ لكم <q>﴿أنفسكم أمرا﴾</q> كان هو منكم هذا، <q>﴿فصبر جميل﴾</q> يعني: صبرًا حَسَنًا لا جَزَع فيه{2}. (ز) ٣٧٩٦٧- عن محمد بن إسحاق -من طريق سلمة- قال: فلمّا جاءوا بذلك إلى يعقوب -يعني: بقول روبيل له- اتَّهَمَهم، وظنَّ أنّ ذلك كفعلتهم بيوسف، ثم قال: <q>﴿بل سولت لكم أنفسكم أمرا فصبر جميل﴾</q>{3}. (ز) <q>﴿عَسَى ٱللَّهُ أَن یَأۡتِیَنِی بِهِمۡ جَمِیعًاۚ﴾</q> - تفسير ٣٧٩٦٨- عن قتادة بن دعامة -من طريق سعيد- وفي قوله: <q>﴿عسى الله أن يأتينى بهم جميعًا﴾</q> قال: بيوسف، وأخيه، وروبيل{4}٣٤٣٦. (٨/٣٠١) ٣٤٣٦ لم يذكر ابنُ جرير (١٣/٢٩٢) غير قول قتادة. ٣٧٩٦٩- قال مقاتل بن سليمان: <q>﴿عسى الله أن يأتيني بهم جميعا﴾</q>، يعني: بنيه الأربعة{2}. (ز) ٣٧٩٧٠- عن عبد الملك ابن جُرَيْج، في قوله: <q>﴿عسى الله أن يأتيني بهم جميعًا﴾</q>، قال: بيوسف، وأخيه، وكبيرهم الذي تَخَلَّف{6}. (٨/٣٠٢) ٣٧٩٧١- عن محمد بن إسحاق -من طريق سلمة- في قوله: <q>﴿عسى الله أن يأتيني بهم جميعًا﴾</q>، قال: أي: بيوسف، وأخيه، وروبيل{3}. (ز) <q>﴿إِنَّهُۥ هُوَ ٱلۡعَلِیمُ ٱلۡحَكِیمُ ۝٨٣﴾</q> - تفسير ٣٧٩٧٢- قال مقاتل بن سليمان: <q>﴿إنه هو العليم﴾</q> بخَلْقه، <q>﴿الحكيم﴾</q> يعني: الحاكم فيهم. ولم يُخْبِر اللهُ يعقوبَ بأمر يوسف؛ لِيَختبر صبرَه{2}. (ز) ",footnotes:1:أخرجه ابن أبي حاتم ٧/٢١٨٤.تفسير مقاتل بن سليمان ٢/٣٤٨.أخرجه ابن جرير ١٣/٢٩٢، وابن أبي حاتم ٧/٢١٨٤.أخرجه ابن جرير ١٣/٢٩٢، وابن أبي حاتم ٧/٢١٨٤. وعزاه السيوطي إلى أبي الشيخ.تفسير مقاتل بن سليمان ٢/٣٤٨.عزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ١٣/٢٩٢، وابن أبي حاتم ٧/٢١٨٤.تفسير مقاتل بن سليمان ٢/٣٤٨.
12,84," <q>﴿وَتَوَلَّىٰ عَنۡهُمۡ وَقَالَ یَـٰۤأَسَفَىٰ عَلَىٰ یُوسُفَ وَٱبۡیَضَّتۡ﴾</q> - تفسير ٣٧٩٧٣- عن عبد الله بن عباس -من طريق العوفي- في قوله: <q>﴿يا أسفي على يوسف﴾</q>، قال: يا حَزَنا على يوسف{1}. (٨/٣٠٣) ٣٧٩٧٤- وعن الضحاك بن مزاحم= (ز) ٣٧٩٧٥- وقتادة بن دعامة، مثل ذلك{2}. (ز) ٣٧٩٧٦- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿يا أسفي على يوسف﴾</q>، قال: يا جزَعا{3}. (٨/٣٠٣) ٣٧٩٧٧- عن مجاهد بن جبر -من طريق ابن أبي نجيح- قوله: <q>﴿يا أسفى﴾</q>: يا حَزَنا{4}. (ز) ٣٧٩٧٨- عن الضحاك بن مزاحم -من طريق جويبر-: <q>﴿يا أسفى﴾</q> يا حَزَنا <q>﴿على يوسف﴾</q>{5}. (ز) ٣٧٩٧٩- عن قتادة بن دعامة -من طريق مَعْمَر، وسعيد- في قوله: <q>﴿يا أسفي على يوسف﴾</q>، قال: يا حَزَنا على يوسف{6}. (٨/٣٠٣) ٣٧٩٨٠- قال مقاتل بن سليمان: <q>﴿وتولى عنهم﴾</q> يعني: وأعرض يعقوبُ عن بنيه، ثُمَّ أقبل على نفسه، <q>﴿وقال يا أسفى﴾</q> يعني: يا حزناه <q>﴿على يوسف﴾</q>{7}. (ز) ٣٧٩٨١- عن محمد بن إسحاق -من طريق سلمة- <q>﴿وتولى عنهم﴾</q>: أعْرَضَ عنهم، وتَتامَّ حزنُه، وبلغ مجهوده، حين لحق بيوسف أخوه، وهُيِّج عليه حزنُه على يوسف، فقال: <q>﴿يا أسفى على يوسف وابيضت عيناه من الحزن فهو كظيم﴾</q>{8}. (ز) <q>﴿وَٱبۡیَضَّتۡ عَیۡنَاهُ مِنَ ٱلۡحُزۡنِ﴾</q> - تفسير ٣٧٩٨٢- عن الحسن البصري -من طريق هشام- قال: كان مُنذُ خَرَجَ يوسفَ مِن عند يعقوب إلى يوم رجع ثمانون سنة، لم يُفارِق الحزنُ قلبَه، ودموعه تجرى على خدَّيْه، ولم يزل يبكى حتى ذهب بصرُه، واللهِ، ما على الأرض يومئذ خليقةٌ أكرمُ على الله مِن يعقوب ﵇{9}. (٨/٣٠٣) ٣٧٩٨٣- قال مقاتل بن سليمان: <q>﴿وابيضت عيناه﴾</q> سِتَّ سنين لم يُبْصِر بهما <q>﴿من الحزن﴾</q> على يوسف{10}. (ز) <q>﴿فَهُوَ كَظِیمࣱ ۝٨٤﴾</q> - تفسير ٣٧٩٨٤- عن عبد الله بن عباس، في قوله:<q>﴿فهو كظيم﴾</q>، قال: حزين{11}. (٨/٣٠٤) ٣٧٩٨٥- عن عبد الله بن عباس، في قوله: <q>﴿فهو كظيم﴾</q>، قال: مَهْمُوم{12}. (ز) ٣٧٩٨٦- عن عبد الله بن عباس: أنّ نافع بن الأزرق قال له: أخبِرني عن قوله: <q>﴿فهو كظيم﴾</q>، ما الكظيم؟ قال: المغموم، قال فيه قيس بن زهير: فإن أكُ كاظِمًا لِمصاب شاس فإني اليومَ منطلق لساني{13}. (٨/٣٠٤) ٣٧٩٨٧- عن عبد الله بن عباس -من طريق جُوَيْبِر، عن الضَّحّاك بن مُزاحِم-: أنّ نافع بن الأزرق قال له: فأخبرني عن قول الله ﷿ <q>﴿وهو كظيم﴾</q> [النحل:٥٨]، ما الكظيم؟ قال: الساكِت. قال: وهل كانت العرب تعرف ذلك ؟ قال: نعم، أما سمعت بقول زهير بن جذيمة العبسي: فإن تكُ كاظِمًا بمصاب شاس فإنِّي اليومَ منطلق لساني{14}. (ز) ٣٧٩٨٨- عن مجاهد بن جبر -من طريق ابن أبي نَجِيح- في قوله: <q>﴿فهو كظيم﴾</q>، قال: كظيم الحزن{15}. (٨/٣٠٤) ٣٧٩٨٩- عن مجاهد بن جبر -من طريق ابن أبي نجيح- <q>﴿فهو كظيم﴾</q>، قال: مَكْمُود{16}. (٨/٣٠٥) ٣٧٩٩٠- عن الضحاك بن مزاحم -من طريق جُوَيْبِر- قال: الكظيم: الكَميِدُ{17}. (٨/٣٠٥) ٣٧٩٩١- عن عكرمة مولى ابن عباس، في قوله: <q>﴿كظيم﴾</q>، قال: مكروب{18}. (٨/٣٠٥) ٣٧٩٩٢- عن العَطّاف بن خالد المخزومي، عن رجل حدَّثه، عن الحسن البصري أنّه كان يقرأ هذه الحروف: <q>﴿وابيضت عيناه من الحزن فهو كظيم﴾</q>، قال: النَّصَب{19}. (ز) ٣٧٩٩٣- عن قتادة بن دعامة -من طريق سعيد، ومَعْمَر- في قوله: <q>﴿فهو كظيم﴾</q>، قال: كظم على الحزن، فلم يقل إلا خيرًا. وفي لفظ: يُرَدِّدُ حزنه في جوفِه، ولم يتكلم بسوء{20}. (٨/٣٠٥) ٣٧٩٩٤- عن إسماعيل السُّدِّيّ -من طريق أسباط- قال: <q>﴿فهو كظيم﴾</q> مِن الغيظ{21}. (٨/١٩٨) ٣٧٩٩٥- عن عطاء الخراساني -من طريق يزيد بن زُرَيع- في قوله: <q>﴿فهو كظيم﴾</q>، قال: فهو مكروب{22}. (٨/٣٠٥) ٣٧٩٩٦- عن عطاء الخراساني، في قوله: <q>﴿فهو كظيم﴾</q>، قال: حَزِين{12}. (ز) ٣٧٩٩٧- قال مقاتل بن سليمان: <q>﴿فهو كظيم﴾</q>، يعني: مكروب، يَتَرَدَّد الحزنُ فِي قلبه{10}. (ز) ٣٧٩٩٨- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- قال: الكظيم: الذي لا يتكلم. بَلَغَ به الحزنُ حتى كان لا يُكَلِّمُهم{25}٣٤٣٧. (٨/٣٠٥) ٣٤٣٧ ذكر ابنُ عطية (٥/١٣٤) في قوله: <q>﴿كظيم﴾</q> احتمالين: الأول: أن يكون بمعنى: كاظم، كقوله: <q>﴿والكاظمين الغيظ﴾</q> [آل عمران:١٣٤]. وعلّق عليه قائلًا: «ووصف يعقوب بذلك لأنّه لم يَشْكُ إلى أحد، وإنما كان يكمد في نفسه، ويُمْسِك هَمَّه في صدره، وكان يكظمه -أي: يرده- إلى قلبه، ولا يرسله بالشكوى والغضب والضجر». الثاني: أن يكون بمعنى: مكظوم. وعلّق عليه قائلًا: «وقد وصف الله تعالى يونس ﵇ بمكظوم في قوله: <q>﴿إذ نادى وهو مكظوم﴾</q> [القلم:٤٨]، وهذا إنّما يَتَّجه على تقدير أنّه مليء بحزنه، فكأنّه كظم بثه في صدره». ثم رجّح الأول بقوله: "وجَرْيُ كظيم على باب كاظم أبين». ولم يذكر مستندًا. ثم ذكر قول مَن قال من السلف معناه: مكروب. ومَن قال: معناه: مكمود. وعلّق بقوله: «وذلك كله متقارب». <q>﴿فَهُوَ كَظِیمࣱ ۝٨٤﴾</q> - آثار متعلقة بالآية ٣٧٩٩٩- عن الأحنف بن قيس، أنّ النبيَّ ﷺ قال: «إنّ داود قال: يا ربِّ، إنّ بني إسرائيل يسألونك بإبراهيم وإسحاق ويعقوب، فاجعلني لهم رابعًا. فأوحى الله إليه: إنّ إبراهيم أُلقِىَ في النار بسببِي فصبر، وتلك بَلِيَّةٌ لم تَنَلْكَ، وإنّ إسحاق بذل مُهْجَةَ دمِه في سببِي فصبر، وتلك بَلِيَّةٌ لم تَنَلْكَ، وإنّ يعقوب أخذتُ منه حبيبَه حتى ابيضَّتْ عيناه مِن الحزن فصبر، وتلك بَلِيَّةٌ لم تَنَلْكَ»{26}. (٨/٣٠٤) ٣٨٠٠٠- عن سعيد بن جبير -من طريق سفيان العُصْفُري- قال: لم يُعطَ أحدٌ الاسترجاعَ غير هذه الأمة، ولو أُعطِيَها أحدٌ لأعطِيَها يعقوب، ألا تستمعون إلى قوله: <q>﴿يا أسفي على يوسف﴾</q>{27}٣٤٣٨. (٨/٣٠٣) ٣٤٣٨ ذكر ابنُ عطية (٨/١٣٤) نحو ما جاء في هذا القول، ثم علّق قائلًا: «ولا يبعد أن يجتمع الاسترجاع ويا أسَفى لهذه الأمة وليعقوب ﵇». ٣٨٠٠١- عن يونس، قال: لَمّا مات سعيدُ بن الحسن حَزِن عليه الحسن [البصري] حُزنًا شديدًا، فكُلِّم الحسن في ذلك، فقال: ما سمعتُ اللهَ عاب على يعقوب ﵇ الحزن{28}. (٨/٣٠٣) ٣٨٠٠٢- عن أبي رَوْق عطية بن الحارث الهمداني -من طريق أبي زهير، عن بعض أصحابه-قال: لَمّا احتَبَس يوسف ﵇ أخاه بسبب السرقة كَتَبَ إليه يعقوبُ ﵇: مِن يعقوب بن إسحاق بن إبراهيم خليل الله إلى يوسف عزيز فرعون، أمّا بعد، فإنّا أهلُ بيت مُوَكَّلٌ بنا البلاء؛ إنّ أبي إبراهيم ﵇ أُلقِيَ في النار في الله فصبر، فجعلها الله عليه بردًا وسلامًا، وإن أبي إسحاق ﵇ قُرِّب للذبح في الله فصبر، ففداه الله بذِبْحٍ عظيم، وإنّ الله كان وهَبَ لي قُرَّة عين فسَلَبَنِيه، فأذهب حزنُه بصري، وأيبس لحمي على عظمي، فلا ليلي ليل، ولا نهاري نهار، والأسير الذي في يديك بما ادُّعي عليه من السَّرَقِ أخوه لأمه، فكنت إذا ذَكَرْتُ أسفي عليه قرَّبته مِنِّي، فسلّى عنِّي بعض ما كنتُ أجِدُ، وقد بلغني أنّك حبستَه بسبب سرقة، فخلِّ سبيلَه، فإنِّي لم ألِد سارقًا، وليس بسارق، والسلام{29}. (٨/٣٠٢) ",footnotes:1:أخرجه ابن جرير ١٣/٢٩٣-٢٩٤، وابن أبي حاتم ٧/٢١٨٥. وعزاه السيوطي إلى ابن المنذر.علَّقه ابن أبي حاتم ٧/٢١٨٥.أخرجه ابن جرير ١٣/٢٩٤، وابن أبي حاتم ٧/٢١٨٥. وعزاه السيوطي إلى ابن أبي شيبة، وابن المنذر، وأبي الشيخ.أخرجه ابن جرير ١٣/٢٩٤.أخرجه ابن جرير ١٣/٢٩٥.أخرجه ابن جرير ١٣/٢٩٤. وعزاه السيوطي إلى ابن أبى شيبة، وابن المنذر.تفسير مقاتل بن سليمان ٢/٣٤٨.أخرجه ابن جرير ١٣/٢٩٣، وابن أبي حاتم ٧/٢١٨٤-٢١٨٥.أخرجه عبد الله بن أحمد في زوائد الزهد ص٨٤، وابن جرير ١٣/٣١٣، ٣٥٩. وعزاه السيوطي إلى أبي الشيخ.تفسير مقاتل بن سليمان ٢/٣٤٨. وبنحوه في تفسير الثعلبي ٥/٢٤٧ منسوبًا إلى مقاتل دون تعيينه.أخرجه ابن جرير ١٤/٢٥٦.تفسير الثعلبي ٥/٢٤٧.عزاه السيوطي إلى ابن الأنباري في الوقف.أخرجه الطبراني في المعجم الكبير (١٠/٢٤٨-٢٥٦) رقم (١٠٥٩٧) مطولا.أخرجه ابن جرير ١٣/٢٩٦، وابن أبي حاتم ٧/٢١٨٧. وعزاه السيوطي إلى ابن المنذر، وأبي الشيخ.أخرجه ابن جرير ١٣/٢٩٦.أخرجه ابن جرير ١٣/٢٩٧، وابن أبي حاتم ٧/٢١٨٧. وعزاه السيوطي إلى ابن المنذر، وأبي الشيخ.عزاه السيوطي إلى ابن أبي حاتم.أخرجه ابن وهب في الجامع ٣/٤٥ (٨٨).أخرجه ابن المبارك (٤٦٨)، وعبد الرزاق ١/٣٢٧، وابن جرير ١٣/٢٩٧، وابن أبي حاتم ٧/٢١٨٧. كما أخرجه ابن أبي الدنيا في كتاب الهم والحزن -موسوعة الإمام ابن أبي الدنيا ٣/٢٧٨ (٨٩)- من طريق همام. وعزاه السيوطي إلى ابن المنذر، وأبي الشيخ.أخرجه ابن جرير ١٣/٢٩٧. وعلَّقه ابن أبي حاتم ٧/٢١٨٧ بلفظ: الحزن.أخرجه ابن جرير ١٣/٢٩٧. وعزاه السيوطي إلى ابن المنذر.تفسير الثعلبي ٥/٢٤٧.تفسير مقاتل بن سليمان ٢/٣٤٨. وبنحوه في تفسير الثعلبي ٥/٢٤٧ منسوبًا إلى مقاتل دون تعيينه.أخرجه ابن جرير ١٣/٢٩٨. وعزاه السيوطي إلى أبي الشيخ.أخرجه ابن أبي حاتم ٧/٢١٨٦. ذكر ابنُ كثير ٨/٦٤ هذا الأثر مِن طريق ابن أبي حاتم، وفي إسناده علي بن زيد بن جدعان، ثم قال: «وهذا مرسل، وفيه نكارة؛ فإنّ الصحيح أنّ إسماعيل هو الذبيح، ولكن علي بن زيد بن جدعان له مناكير وغرائب كثيرة، والله أعلم. وأقرب ما في هذا أن يكون قد حكاه الأحنف بن قيس ﵀ عن بني إسرائيل ككعب ووهب ونحوهما».أخرجه عبد الرزاق ١/٣٢٧، وابن جرير ٢/٧٠٨، ١٣/٢٩٥، وابن أبي حاتم ٧/٢١٨٥. وعزاه السيوطي إلى ابن المنذر.أخرجه ابن سعد ٧/١٨٧، وابن أبي شيبة ١٣/٩٠، ٥٠٣. وعزاه السيوطي إلى أبي عبيد، وابن المنذر.أخرجه ابن أبي حاتم ٧/٢١٨٥.
12,85," <q>﴿قَالُوا۟ تَٱللَّهِ تَفۡتَؤُا۟ تَذۡكُرُ یُوسُفَ﴾</q> - تفسير ٣٨٠٠٣- عن عبد الله بن عباس -من طريق عكرمة- في قوله: <q>﴿تالله تفتؤا تذكر يوسف﴾</q>، قال: لا تزال تذكر يوسف{1}. (٨/٣٠٨) ٣٨٠٠٤- عن عبد الله بن عباس: أنّ نافع بن الأزرق قال له: أخبِرني عن قوله: <q>﴿تفتؤا تذكر يوسف﴾</q>. قال: لا تزال تذكر يوسف. قال: وهل تعرف العرب ذلك؟ قال: نعم، أما سمعت الشاعرَ وهو يقول: لعمرك لا تفتأ تذكر خالدًا وقد غاله ما غال تُبَّعَ مِن قبلُ{2}. (٨/٣٠٩) ٣٨٠٠٥- عن مجاهد بن جبر -من طريق ابن أبي نَجِيح- في قوله: <q>﴿قالوا تالله تفتؤا تذكر يوسف﴾</q>، قال: لا تَفْتُرُ مِن حُبِّ يوسف، لا تزال تذكر يوسف{3}٣٤٣٩. (٨/٣٠٨) ٣٤٣٩ ذكر ابنُ جرير (١٣/٢٩٨) قول مجاهد من طريق الحسن بن محمد، عن شبابة، عن ورقاء، عن ابن أبي نجيح، عن مجاهد في قوله: <q>﴿تفتأ﴾</q>: ما تفتر مِن حُبِّه، ثم علّق قائلًا: «كذا قال الحسن في حديثه، وهو غلط، إنما هو: تفتر من حبه، تزال تذكر يوسف». ٣٨٠٠٦- عن قتادة بن دعامة -من طريق سعيد، ومَعْمَر- في قوله: <q>﴿تفتؤا تذكر يوسف﴾</q>، قال: لا تزال تذكر يوسف{4}. (٨/٣٠٩) ٣٨٠٠٧- عن إسماعيل السُّدِّيّ -من طريق أسباط- قال: <q>﴿قالوا تالله تفتؤا تذكر يوسف﴾</q>، قال: لا تزال تذكر يوسف{5}. (٨/١٩٨) ٣٨٠٠٨- قال مقاتل بن سليمان: <q>﴿قالوا﴾</q> أي: قال بنوه يُعَيِّرونه: <q>﴿تالله تفتؤا﴾</q> يعني: واللهِ، ما تزال تذكر <q>﴿يوسف﴾</q>{6}. (ز) <q>﴿حَتَّىٰ تَكُونَ حَرَضًا﴾</q> - تفسير ٣٨٠٠٩- عن عبد الله بن عباس -من طريق عكرمة- في قوله: <q>﴿حتى تكون حرضًا﴾</q>، قال: دَنِفًا{7} مِن المرض{8}. (٨/٣٠٨) ٣٨٠١٠- عن عبد الله بن عباس -من طريق العوفي- قوله: <q>﴿حتى تكون حرضا﴾</q>، يعني: الجَهْدَ في المرض البالي{9}. (ز) ٣٨٠١١- عن عبد الله بن عباس: أنّ نافع بن الأزرق قال له: أخبِرني عن قوله: <q>﴿حتى تكون حرضًا﴾</q>. قال: الحَرَضُ: المُدْنَفُ الهالك مِن شِدَّة الوَجَع. قال: وهل تعرف العرب ذلك؟ قال: نعم، أما سمعت الشاعر وهو يقول: أمِن ذِكْرِ ليلى إن نَأَت غرْبَةٌ بها كأنك حَمٌّ للأطباء مُحْرَضُ{10}. (٨/٣١٠) ٣٨٠١٢- عن عبد الله بن عباس -من طريق جُوَيْبِر، عن الضَّحّاك بن مُزاحِم- أنّ نافع بن الأزرق قال له: فأخبِرني عن قول الله ﷿: <q>﴿حتى تكون حرضا﴾</q>. قال: الحرض: البالي. قال: وهل كانت العرب تعرف ذلك قبل أن ينزل الكتابُ على محمد ﷺ؟ قال: نعم، أما سمعت قول طرفة بن العبد: أمِن ذِكْرِ ليلى إن نأت غرْبَةٌ بها أعد حريضًا للكرا محرم{11}. (ز) ٣٨٠١٣- عن مجاهد بن جبر -من طريق ليث- في قوله: <q>﴿حتى تكون حرضًا﴾</q>، قال: الحرض: ما دُون الموت{12}. (٨/٣٠٨) ٣٨٠١٤- عن الضحاك بن مُزاحِم -من طريق جويبر- <q>﴿حتى تكون حرضًا﴾</q>، قال: الحرض: الشيء البالي{13}. (٨/٣٠٩) ٣٨٠١٥- عن الحسن البصري -من طريق أبي بكر الهذلي- <q>﴿حرضا﴾</q>، قال: هَرِمًا{14}. (ز) ٣٨٠١٦- قال الحسن البصري: كالشَّيء{15} المدقوق المكسور{16}. (ز) ٣٨٠١٧- عن قتادة بن دعامة -من طريق مَعْمَر- وفي قوله: <q>﴿حتى تكون حرضًا﴾</q>، قال: هَرِمًا{17}. (٨/٣٠٩) ٣٨٠١٨- عن إسماعيل السدي -من طريق أسباط- قال: <q>﴿حتى تكون حرضًا﴾</q>: باليًا{14}. (٨/١٩٨) ٣٨٠١٩- عن إسماعيل السدي -من طريق شعبة- قال: <q>﴿حتى تكون حرضًا﴾</q>: حتى تكاد أن تموت{19}. (ز) ٣٨٠٢٠- قال الربيع بن أنس: يابِس الجِلْد على العَظْم{16}. (ز) ٣٨٠٢١- عن أبي صَخْر [حميد بن زياد الخرّاط] -من طريق مفضل- في قوله: <q>﴿حرضا﴾</q>، قال: أمّا الحَرَض فيقولون: لا يَعْقِل، ولا يُنتَفَع به{19}. (ز) ٣٨٠٢٢- قال مقاتل بن سليمان: <q>﴿حتى تكون حرضا﴾</q>، يعني: الدَّنِف{22}. (ز) ٣٨٠٢٣- عن محمد بن إسحاق -من طريق سلمة- قال: لَمّا ذكر يعقوبُ يوسفَ <q>﴿قالوا﴾</q> يعني: ولده الذين حضروه في ذلك الوقت، جهلًا وظُلْمًا: <q>﴿تالله تفتأ تذكر يوسف حتى تكون حرضا﴾</q> أي: تكون فاسدًا، لا عَقْلَ لك، <q>﴿أو تكون من الهالكين﴾</q>{23}. (ز) ٣٨٠٢٤- عن سفيان الثوري، في قوله: <q>﴿حتى تكون حرضا﴾</q>، قال: تَبْلى{24}. (ز) ٣٨٠٢٥- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿حتى تكون حرضا أو تكون من الهالكين﴾</q>، قال: الحرض: الذي قد رُدَّ إلى أرْذَل العمر، حتى لا يعقل، أو تهلِكَ فتكونَ هالكًا قبلَ ذلك{25}٣٤٤٠. (ز) ٣٤٤٠ بيّن ابنُ عطية (٥/١٣٦-١٣٧بتصرف) أنّ <q>﴿حرضا﴾</q> معناه: «الذي قد نهكه الهرم، أو الحب، أو الحزن إلى حال فساد الأعضاء والبدن والحس». وذكر أنّ ذلك يوافق قراءة الجمهور <q>﴿حرضا﴾</q> بفتح الراء والحاء، ثم ذكر عدة قراءات أخرى، وعلّق عليها، فقال: «وقرأ الحسن بن أبي الحسن بضمهما، وقرأت فرقة: (حُرْضًا) بضم الحاء وسكون الراء. وهذا كله المصدر يوصف به المذكر والمؤنث والمفرد والجمع بلفظ واحد، كعدل وعدو، وقيل في قراءة الحسن: إنه يراد: فتات الأشنان، أي: باليًا متعتتًا، ويقال مِن هذا المعنى الذي هو شن الهم والهرم: رجل حارض». ثم قال: «والحرض بالجملة: الذي فسد ودنا موتُه». وذكر آثار السلف في هذا المعنى، ثم علّق قائلًا: «فكأنهم قالوا على جهة التعنيف له: أنت لا تزال تذكر يوسف إلى حال القرب مِن الهلاك، أو إلى الهلاك». <q>﴿أَوۡ تَكُونَ مِنَ ٱلۡهَـٰلِكِینَ ۝٨٥﴾</q> - تفسير ٣٨٠٢٦- عن عبد الله بن عباس -من طريق عكرمة- في قوله: <q>﴿أو تكون من الهالكين﴾</q>، قال: المَيِّتين{26}. (٨/٣٠٨) ٣٨٠٢٧- عن الربيع بن أنس، مثل ذلك{27}. (ز) ٣٨٠٢٨- عن مجاهد بن جبر -من طريق ليث- في قوله: <q>﴿أو تكون من الهالكين﴾</q>، قال: الموت{28}. (٨/٣٠٨) ٣٨٠٢٩- عن الضَّحّاك بن مُزاحِم -من طريق جُوَيْبِر- <q>﴿أو تكون من الهالكين﴾</q>، قال: المَيِّتين{29}. (٨/٣٠٩) ٣٨٠٣٠- عن الحسن البصري -من طريق أبي بكر الهذلي- <q>﴿أو تكون من الهالكين﴾</q>، قال: المَيِّتين{30}. (ز) ٣٨٠٣١- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿أو تكون من الهالكين﴾</q>، قال: أو تموت{31}. (٨/٣٠٩) ٣٨٠٣٢- عن إسماعيل السُّدِّيّ -من طريق أسباط- قال: <q>﴿أو تكون من الهالكين﴾</q>: المَيِّتين{32}. (٨/١٩٨) ٣٨٠٣٣- قال مقاتل بن سليمان: <q>﴿أو تكون من الهالكين﴾</q>، يعني: الميتين{6}. (ز) ٣٨٠٣٤- عن سفيان الثوري، في قوله: <q>﴿أو تكون من الهالكين﴾</q>، قال: الموت. يقول ذلك بعضُ ولدِ ولدِه{24}. (ز) ",footnotes:1:أخرجه ابن جرير ١٣/٢٩٩، ٣٠١، وزاد: قال: لا تفتر من حُبِّه، وابن أبي حاتم ٧/٢١٨٧-٢١٨٨. وعزاه السيوطي إلى ابن أبي شيبة، وابن المنذر، وأبي الشيخ.أخرجه في مسائل نافع ص٥٢، والطستي -كما في الإتقان ٢/٨٥-. وعزاه السيوطي إلى ابن الأنباري، والطستي.تفسير مجاهد ص٤٠٠، وأخرجه ابن جرير ١٣/٢٩٩، ٣٠٢، ٣٠٤، وابن أبي حاتم ٧/٢١٨٧-٢١٨٨. وعزاه السيوطي إلى ابن أبي شيبة، وابن المنذر.أخرجه عبد الرزاق ١/٣٢٧، وابن جرير ١٣/٢٩٩، ٣٠٢، ٣٠٥. وعزاه السيوطي إلى ابن المنذر، وأبي الشيخ.أخرجه ابن أبي حاتم ٧/٢١٨٧. وعزاه السيوطي إلى ابن جرير.تفسير مقاتل بن سليمان ٢/٣٤٨.رجل دَنَفٌ ودَنِفٌ ومُدْنِفٌ ومُدْنَفٌ: بَراهُ المرض حتى أشفى على الموت. لسان العرب (دنف).أخرجه ابن أبي حاتم ٧/٢١٨٧. وعزاه السيوطي إلى ابن أبي شيبة، وابن المنذر، وابن جرير، وأبي الشيخ.أخرجه ابن جرير ١٣/٣٠١.أخرجه في مسائل نافع ص٥٢. وعزاه السيوطي إلى ابن الأنباري، والطستي.أخرجه الطبراني في المعجم الكبير مطولًا ١٠/٢٤٨-٢٥٦ (١٠٥٩٧).أخرجه ابن جرير ١٣/٢٩٩، ٣٠٢، ٣٠٤، وابن أبي حاتم ٧/٢١٨٧-٢١٨٨. وعزاه السيوطي إلى ابن أبي شيبة، وابن المنذر.أخرجه ابن جرير ١٣/٣٠٣، وابن أبي حاتم ٧/٢١٨٨. وعزاه السيوطي إلى ابن أبي شيبة، وابن المنذر، وأبي الشيخ.أخرجه ابن جرير ١٣/٣٠٣.الشن: وعاء من أدم. النهاية (طبق).تفسير الثعلبي ٥/٢٤٨.أخرجه عبد الرزاق ١/٣٢٧، وابن جرير ١٣/٣٠٢-٣٠٣ ومن طريق سعيد بلفظ: حتى تبلى أو تهرم. وعزاه السيوطي إلى ابن المنذر، وأبي الشيخ.أخرجه ابن جرير ١٣/٣٠٣.أخرجه ابن أبي حاتم ٧/٢١٨٨.تفسير الثعلبي ٥/٢٤٨.أخرجه ابن أبي حاتم ٧/٢١٨٨.تفسير مقاتل بن سليمان ٢/٣٤٨. وبنحوه في تفسير الثعلبي ٥/٢٤٨ منسوبًا إلى مقاتل دون تعيينه.أخرجه ابن جرير ١٣/٣٠٣، وابن أبي حاتم ٧/٢١٨٥، ٢١٨٨.تفسير الثوري ص١٤٦.أخرجه ابن جرير ١٣/٣٠٤.أخرجه ابن جرير ١٣/٢٩٩، ٣٠١، وابن أبي حاتم ٧/٢١٨٧-٢١٨٨. وعزاه السيوطي إلى ابن أبي شيبة، وابن المنذر، وأبي الشيخ.علَّقه ابن أبي حاتم ٧/٢١٨٨.أخرجه ابن جرير ١٣/٢٩٩، ٣٠٢، ٣٠٤. وعلَّقه ابن أبي حاتم ٧/٢١٨٧-٢١٨٨. وعزاه السيوطي إلى ابن أبي شيبة، وابن المنذر.أخرجه ابن جرير ١٣/٣٠٣. وعلَّقه ابن أبي حاتم ٧/٢١٨٨. وعزاه السيوطي إلى ابن أبي شيبة، وابن المنذر، وأبي الشيخ.أخرجه ابن جرير ١٣/٣٠٥. وعلَّقه ابن أبي حاتم ٧/٢١٨٨.أخرجه عبد الرزاق ١/٣٢٧، وابن جرير ١٣/٢٩٩، ٣٠٢، ٣٠٥. وعلَّقه ابن أبي حاتم ٧/٢١٨٨. وعزاه السيوطي إلى ابن المنذر، وأبي الشيخ.أخرجه ابن جرير ١٣/٣٠٥، وابن أبي حاتم ٧/٢١٨٨.تفسير مقاتل بن سليمان ٢/٣٤٨.تفسير الثوري ص١٤٦.
12,86," <q>﴿قَالَ إِنَّمَاۤ أَشۡكُوا۟ بَثِّی وَحُزۡنِیۤ إِلَى ٱللَّهِ﴾</q> - تفسير ٣٨٠٣٥- عن عبد الله بن عباس -من طريق ابن جريج- في قوله: <q>﴿إنما أشكو بثي﴾</q>، قال: هَمِّي{1}. (٨/٣١٣) ٣٨٠٣٦- عن الحسن البصري -من طريق عوف- في قوله: <q>﴿أشكو بثي﴾</q> قال: حاجتي <q>﴿وحزني إلى الله﴾</q>{2}. (٨/٣١٣) ٣٨٠٣٧- عن قتادة بن دعامة -من طريق سعيد بن بشير- قوله: <q>﴿إنما أشكوا بثي وحزني إلى الله﴾</q>، قال: ذُكِرَ لنا: أنّ نبي الله يعقوب ﵇ لم يَزَل به شِدَّةُ بلاءٍ قطُّ إلا أتاهُ حُسْنُ ظنِّه بالله مِن وراء بلائه{3}. (ز) ٣٨٠٣٨- عن طلحة بن مُصَرِّف الأيامى -من طريق المبارك بن مجاهد، عن رجل مِن الأَزْد- قال: ثلاثةُ لا تذكُرهن، واجتنب ذِكرَهُنَّ: لا تَشْكُ مرضَك، ولا تشكُ مصيبتَك، ولا تُزَكِّ نفسَك. قال: وأُنبِئْتُ: أنّ يعقوب ﵇ دخل عليه جارٌ له، فقال: يا يعقوب، ما لي أراك قد انْهَشَمَتْ وفَنِيتَ ولم تبلغ مِن السِنِّ ما بلغ أبوك؟ قال: هشمني وأفناني ما ابتلاني الله به مِن هَمِّ يوسف وذِكْرِه. فأوحى الله إليه: يا يعقوب، أتشكوني إلى خلقي؟ فقال: يا ربِّ، خطيئةٌ أخطأتُها فاغفِرْها لي. قال: فإنِّي قد غفرت لكَ. فكان بعد ذلك إذا سُئِل قال: <q>﴿إنما أشكو بثي وحزني إلى الله﴾</q>{4}. (٨/٣١٠) ٣٨٠٣٩- قال مقاتل بن سليمان: <q>﴿قال﴾</q> لهم أبوهم: <q>﴿إنما أشكوا بثي﴾</q> يعني: ما بَثَّه فِيَّ الناسُ <q>﴿وحزني﴾</q> يعني: ما بَطَن <q>﴿إلى الله﴾</q>{5}. (ز) ٣٨٠٤٠- عن محمد بن إسحاق -من طريق سلمة- قال: قال يعقوب عن عِلْمٍ بالله: <q>﴿إنما أشكو بثي وحزني إلى الله وأعلم من الله ما لا تعلمون﴾</q>؛ لِما رأى مِن فظاظتِهم وغِلْظَتِهم وسوء لفظهم به: لم أشْكُ ذلك إليكم، <q>﴿وأعلم من الله ما لا تعلمون﴾</q>{6}٣٤٤١. (ز) ٣٤٤١ لم يذكر ابنُ جرير (١٣/٣٠٦) غير قول ابن إسحاق، والحسن، وابن عباس. ٣٨٠٤١- قال سفيان الثوري، في قوله: <q>﴿إنما أشكوا بثي﴾</q>، قال: هَمِّي{7}. (ز) ٣٨٠٤٢- عن النضر بن عربي، قال: بلغني: أنّ يعقوب ﵇ لَمّا طال حُزْنُه على يوسف ذهبت عيناه مِن الحزن، فجعل العُوّادُ يدخلون عليه، فيقولون: السلام عليك، يا نبيَّ الله، كيف تَجِدُك؟ فيقول: شيخ كبير قد ذهب بصري. فأوحى الله إليه: يا يعقوب، شكوتنى إلى عُوّادك؟! قال: أيْ ربِّ، هذا ذنبٌ عَمِلْتُه لا أعود إليه. فلم يزل بعد يقول: <q>﴿إنما أشكو بثى وحزنى إلى الله﴾</q>{8}. (٨/٣١٣) <q>﴿وَأَعۡلَمُ مِنَ ٱللَّهِ مَا لَا تَعۡلَمُونَ ۝٨٦﴾</q> - تفسير ٣٨٠٤٣- عن عبد الله بن عباس -من طريق العوفي- في قوله: <q>﴿وأعلم من الله ما لا تعلمون﴾</q>، يقول: أعلم أنّ رؤيا يوسف صادقة، وأنِّي سأسْجُدُ له{9}٣٤٤٢. (٨/٣١٤) ٣٤٤٢ لم يذكر ابنُ جرير (١٣/٣٠٧) غير قول ابن عباس. ٣٨٠٤٤- عن إسماعيل السُّدِّيّ -من طريق أسباط- <q>﴿قال إنما أشكو بثي وحزني إلى الله وأعلم من الله ما لا تعلمون﴾</q>، قال: فلمّا أخبروه بدعاء الملِك أحَسَّت نفسُ يعقوب، وقال: ما يكون في الأرض صِدِّيقٌ إلا نَبِيٌّ. فطَمِع، وقال: لعلَّه يوسف{10}. (٨/١٩٨) ٣٨٠٤٥- قال مقاتل بن سليمان: <q>﴿وأعلم من الله﴾</q> يعني: مِن تحقيق رؤيا يوسف أنّه كائن <q>﴿ما لا تعلمون﴾</q>{5}. (ز) ٣٨٠٤٦- قال سفيان الثوري، في قوله: <q>﴿وأعلم من الله ما لا تعلمون﴾</q>، قال: أعلم سيجعلون أنبياء -صلى الله عليهم-{12}٣٤٤٣. (ز) ٣٤٤٣ ذكر ابنُ عطية (٨/١٣٨) في معنى الآية احتمالين، فقال: «وقوله: <q>﴿أعْلَمُ مِنَ اللَّهِ ما لا تَعْلَمُونَ﴾</q> يحتمل أنّه أشار إلى حُسن ظنه بالله وجميل عادة الله عنده، ويحتمل أنّه أشار إلى الرؤيا المنتظرة، أو إلى ما وقع في نفسه عن قول ملك مصر: إني أدعو له برؤية ابنه قبل الموت. وهذا هو حُسْنُ الظَّنِّ». <q>﴿وَأَعۡلَمُ مِنَ ٱللَّهِ مَا لَا تَعۡلَمُونَ ۝٨٦﴾</q> - آثار متعلقة بالآية ٣٨٠٤٧- عن عبد الله بن عمرو، عن النبي ﷺ، قال: «مَن بَثَّ لم يصبِر». ثم قرأ: <q>﴿إنما أشكوا بثى وحزنى إلى الله﴾</q>{13}. (٨/٣١١) ٣٨٠٤٨- عن مسلم بن يَسار، عن سعد بن مسعود، قال: قال رسول الله ﷺ: «مَن بَثَّ فلم يصبِر». ثم قرأ: <q>﴿إنما أشكوا بثي وحزني إلى الله﴾</q>{14}. (٨/٣١١) ٣٨٠٤٩- عن مسلم بن يسار، يرفعه إلى النبي ﷺ، قال: «مَن بَثَّ لم يصبِر». ثم قرأ: <q>﴿إنما أشكو بثى وحزنى إلى الله﴾</q>{15}. (٨/٣١١) ٣٨٠٥٠- عن عبد الرحمن بن يَعْمَرَ، قال: قال رسول الله ﷺ: «مَن بَثَّ لم يصبر». ثم قرأ: <q>﴿إنما أشكوا بثى وحزنى إلى الله﴾</q>{16}. (٨/٣١١) ٣٨٠٥١- عن عبد الله بن عمر، قال: قال رسول الله ﷺ: «مِن كنوز البِرِّ: إخفاء الصَّدَقة، وكتمان المصائب والأمراض، ومَن بَثَّ لم يصبِر»{17}. (٨/٣١١) ٣٨٠٥٢- عن أنس بن مالك، قال: قال رسول الله ﷺ: «مَن أصبح حزينًا على الدنيا أصبح ساخِطًا على ربِّه، ومَن أصبح يشكو مصيبةً نَزَلَتْ به فإنّما يشكو الله، ومَن تضعضع لغَنِيٍّ لِينال مِن دنُياه أحبط اللهُ ثُلُثَي عمله، ومَن أُعْطِي القرآن فدخل النار فأبعده الله»{18}. (٨/٣١٢) ٣٨٠٥٣- عن عبد الله بن مسعود، مثله مرفوعًا{19}. (٨/٣١٢) ٣٨٠٥٤- عن أنس بن مالك، قال: قال رسول الله ﷺ: «كان ليعقوب ﵇ أخٌ مُؤاخٍ، فقال له ذات يوم: يا يعقوب، ما الذي أذهب بصرَك؟ وما الذي قَوَّس ظهرَك؟ قال: أمّا الذي أذهب بصري فالبكاء على يوسف، وأَمّا الذي قَوَّس ظهري فالحزن على بنيامين. فأتاه جبريل ﵇، فقال: يا يعقوب، إنّ الله ﷿ يُقرِئُك السلام، ويقول لك: أما تستحي؛ تشكوني إلى غيري؟! قال يعقوب ﵇: <q>﴿إنما أشكو بثى وحزنى إلى الله﴾</q>. فقال جبريل ﵇: اللهُ أعلمُ بما تشكو، يا يعقوب. ثم قال يعقوب: أما ترحم الشيخَ الكبيرَ؟ أذهبتَ بصري، وقوَّست ظهري، فأردُد عَلَيَّ رَيْحانَتِي، أشمه شمَّة قبل الموت، ثم اصنع بي ما أردتَ. فأتاه جبريل ﵇، فقال: يا يعقوب، إنّ الله يُقْرِئُك السلامَ، ويقول لك: أبْشِرْ، وليفرح قلبُك، فوَعِزَّتي، لو كانا مَيِّتَيْنِ لَنَشَرْتُهُما لكَ، فاصنع طعامًا للمساكين، فإنّ أحَبَّ عبادي إلَيَّ الأنبياءُ والمساكين، وتدري لِمَ أذهبتُ بصرَك، وقوَّستُ ظهرَك، وصنع إخوةُ يوسف به ما صنعوا؟ إنّكم ذبحتم شاةً، فأتاكم مسكينٌ وهو صائم، فلم تُطْعِمُوه منها شيئًا. فكان يعقوبُ ﵇ إذا أراد الغداء أمر مُناديًا يُنادِي: ألا مَن أراد الغداء مِن المساكين فلْيَتَغَدَّ مع يعقوب. وإذا كان صائمًا أمَر مناديًا فنادى: ألا مَن كان صائمًا مِن المساكين فلْيُفْطِر مع يعقوب{20}. (٨/٣١٥) ٣٨٠٥٥- عن العلاء بن عبد الرحمن بن يعقوب، قال: بلغني: أنّ رسول الله ﷺ قال: «ثلاث مِن كُنُوز البِرِّ: كتمان الصدقة، وكتمان المصيبة، وكتمان المرض»{21}. (٨/٣١٢) ٣٨٠٥٦- عن الحسن، عن النبي ﷺ أنّه سُئِل: ما بلغ وجْدُ يعقوب على ابنه؟ قال: «وجْدَ سبعين ثَكْلى». قيل: فما كان له مِن الأجر؟ قال: «أجر مائة شهيد، وما ساء ظنُّه بالله ساعةً مِن ليل أو نهار»{4}. (٨/٣٠٨) ٣٨٠٥٧- عن علقمة بن وقاص، قال: صلَّيْتُ خلف عمر بن الخطاب العشاء، فقرأ سورة يوسف، فلمّا أتى على ذِكْرِ يوسف ﵇ نَشَجَ{23} حتى سمعتُ نَشِيجَه وأنا في مؤخر الصُّفُوف{24}. (٨/٣١٤) ٣٨٠٥٨- عن عبد الله بن شدّاد، قال: سمعتُ نشيج عمر بن الخطاب وإنِّي لَفِي آخر الصفوف في صلاة الصبح، وهو يقرأ: <q>﴿إنما أشكو بثي وحزني إلى الله﴾</q>{25}. (٨/٣١٤) ٣٨٠٥٩- عن أبي الدرداء، قال: ثلاث مِن مِلاكِ أمرِك: أن لا تشكو مصيبتك، وأن لا تُحَدِّث بوَجَعِك، وأن لا تُزَكِّي نفسَك بلسانك{26}. (٨/٣١٢) ٣٨٠٦٠- عن سعيد بن جبير -من طريق ليث- قال: لَمّا دخل يعقوبُ على الملِك -وحاجباه قد سقطا على عينيه- قال الملِك: ما هذا؟ قال: السنون والأحزان، أو الهموم والأحزان. فقال ربُّه: يا يعقوب، لِمَ تشكوني إلى خلقي، ألم أفعل بك وأفعل؟!{27}. (ز) ٣٨٠٦١- عن مجاهد بن جبر -من طريق ليث بن أبي سليم- قال: حُدِّثتُ: أنّ جبريل ﵇ أتى يوسفَ ﵇ وهو في مصر في صورة رجل، فلمّا رآه يوسف ﵇ عرَفه، فقام إليه، فقال: أيُّها الملَك الطَّيِّب ريحُه، الطّاهِر ثيابُه، الكريم على ربه، هل لك بيعقوب مِن علم؟ قال: نعم. قال: فكيف هو؟ قال: ذهب بصرُه. قال: وما الذي أذهب بصرَه؟ قال: الحزن عليك. قال: فما أُعْطِي على ذلك؟ قال: أجر سبعين شهيدًا{28}. (٨/٣٠٦) ٣٨٠٦٢- عن عكرمة مولى ابن عباس -من طريق عمرو بن دينار- قال: أتى جبريلُ ﵇ يوسفَ ﵇ وهو في السجن، فسلَّم عليه، فقال له يوسف: أيُّها الملَك الكريم على ربِّه، الطيب ريحه، الطاهر ثيابه، هل لك عِلْمٌ بيعقوب؟ قال: نعم، ما أشد حزنه! قال: ماذا له مِن الأجر؟ قال: أجر سبعين ثكلى. قال: أفَتُرانِي لاقِيهِ؟ قال: نعم. فطابت نفسُ يوسف{29}. (٨/٣٠٧) ٣٨٠٦٣- عن الحسن البصري -من طريق عيسى بن يزيد- قال: قيل: ما بلغ وجْدُ يعقوب على ابنه؟ قال: وجْدَ سبعين ثَكْلى. قال: فما كان له مِن الأجر؟ قال: أجر مائة شهيد. قال: وما ساء ظنُّه بالله ساعةً مِن ليل ولا نهار{30}. (ز) ٣٨٠٦٤- عن الحسن البصري -من طريق الليث بن سعد، عمَّن يَرْضى- قال: مَن ابْتُلِي ببلاء، فكتمه ثلاثًا لا يشكو إلى أحد؛ أتاه الله برحمته{31}. (٨/٣١٢) ٣٨٠٦٥- عن وهب بن مُنَبِّه -من طريق عبد الصمد بن معقل- قال: وجدت في التوراة أربعة أسطر متوالية: مَن شكا مصيبتَه فإنّما يشكو ربَّه، ومَن تَضَعْضَعَ{32} لِغَنِيٍّ ذهب ثُلُثا دينه، ومَن حزِن على ما في يد غيرِه فقد سخط قضاءَ ربِّه، ومَن قرأ كتابَ الله فظَنَّ ألّا يُغفر له فهو مِن المستهزئين بآيات الله{33}. (٨/٣١٢) ٣٨٠٦٦- عن وهب بن مُنَبِّه -من طريق عبد الصمد بن معقل- قال: لَمّا أتى جبريلُ ﵇ يوسفَ ﵇ بالبُشْرى وهو في السِّجْن قال: هل تعرفُني، أيُّها الصِّدِّيق؟ قال: أرى صورةً طاهرةً، وريحًا طَيِّبةً لا تُشْبِه أرواحَ الخاطئين. قال: فإنِّي رسولُ رب العالمين، وأنا الروح الأمين. قال: فما الذي أدخلك إلى مدخل المذنبين، وأنت أطيب الطيبين، ورأس المقربين، وأمين رب العالمين؟ قال: ألم تعلم -يا يوسف- أنّ الله يُطَهِّر البيوت بطُهْر النَّبِيِّين؟ وأنّ الأرض التي يدخلونها هي أطهر الأرضين؟ وأنّ الله قد طَهَّر بك السِّجْنَ وما حوله، يا طَهِرَ{34} الطاهرين وابن المُطَهَّرين؟ إنّما يُتَطَهَّرُ بفَضْل طُهْرِك وطُهْرِ آبائك الصالحين المخلصين. قال: كيف تُسَمِّيني بأسماء الصِّدِّيقين، وتَعُدُّني مِن المُخْلِصين، وقد دخلتُ مَدْخَل المُذْنِبين، وسُمِّيتُ بالضالين المفسدين؟ قال: لم يفتن قلبَك الحزن، ولم يُدَنِّس حريتَك الرِّقُ، ولم تُطِع سيِّدتك في معصيةِ ربك، فلذلك سماك اللهُ بأسماء الصِّدِّيقين، وعَدَّك مع المخلصين، وألحقك بآبائك الصالحين. قال: هل لكَ عِلْمُ بيعقوب؟ قال: نعم، وهَبَ اللهُ له الصبرَ الجميل، وابتلاه بالحزن عليك فهو كظيم. قال: فما قَدْرُ حُزْنِه؟ قال: قدر سبعين ثكلى. قال: فماذا له مِن الأجر؟ قال: قدر مائة شهيد{35}. (٨/٣٠٧) ٣٨٠٦٧- عن وهب بن مُنَبِّه، قال: أوحى اللهُ تعالى إلى يعقوب: أتدري لِمَ عاقبتُك وحبستُ عنك يوسف ثمانين سنة؟ قال: لا، يا إلهي. قال: لأنّك قد شَوَيْتَ عَناقًا، وقترت على جارِك، وأكلت ولم تُطْعِمْه{36}. (ز) ٣٨٠٦٨- عن قتادة بن دعامة -من طريق سعيد- قال: ذُكِر لنا: أنّ يعقوب ﵇ لم تَزَل به شِدُّة بلاء قط إلا أتاه حُسنُ ظنِّه بالله مِن وراء بلائه{37}. (٨/٣١٤) ٣٨٠٦٩- عن حبيب بن أبي ثابت -من طريق أسلم-: أنّ يعقوب ﵇ كان قد سَقَط حاجِباه على عينيه مِن الكِبَر، فكان يرفعهما بخِرْقَة، فقيل له: ما بلغ بكَ هذا؟ قال: طول الزمان، وكثرة الأحزان. فأوحى الله إليه: يا يعقوب، أتشكوني؟ قال: يا ربِّ، خطيئة أخطأتها، فاغفر لي{38}. (٨/٣١٣) ٣٨٠٧٠- عن إسماعيل السُّدِّيّ -من طريق أسباط- قال: أتى جبريلُ يوسفَ وهو في السجن، فسلَّم عليه، وجاءه في صورة رجل حسن الوجه، طيِّب الريح، نَقِي الثياب، فقال له يوسف: أيها الملك الحسن الوجه، الكريم على ربِّه، الطيِّب ريحُه، حدثني كيف يعقوب؟ قال: حَزِن عليك حزنًا شديدًا. قال: فما بلغ مِن حُزْنِه؟ قال: حُزْن سبعين مُثكَلَة. قال: فما بلغ مِن أجره؟ قال: أجر سبعين شهيدًا. قال يوسف: فإلى مَن أوى بعدى؟ قال: إلى أخيك بنيامين. قال: فتُراني ألقاه؟ قال: نعم. فبكى يوسفُ لِما لَقِي أبوه بعده، ثم قال: ما أُبالي بما لقيت إنِ اللهُ أرانِيهِ{39}. (٨/١٩٨) ٣٨٠٧١- عن عمرو بن دينار: أنّه أُلقِي على يعقوب ﵇ حُزْنُ سبعين ثَكْلى، ومكَث في ذلك الحزن ثمانين عامًا{40}. (٨/٣٠٨) ٣٨٠٧٢- عن ليث بن أبى سليم -من طريق هشام-: أنّ جبريل ﵇ دخل على يوسف ﵇ في السِّجن، فعرفه، فقال له: أيُّها المَلَك الكريم على ربِّه، هل لك عِلْمٌ بيعقوب؟ قال: نعم. قال: ما فَعَلَ؟ قال: ابيَضَّت عيناه مِن الحزن عليك. قال: فماذا بلغ من حزنه؟ قال: حزن سبعين مُثْكَلَةٍ. قال: هل له على ذلك مِن أجر؟ قال: نعم، أجر مائة شهيد{41}. (٨/٣٠٥) ٣٨٠٧٣- عن ثابت بن أسلم البناني -من طريق ليث-، مثله سواء{42}. (٨/٣٠٦) ٣٨٠٧٤- عن ثور بن يزيد -من طريق يحيى بن واضح- قال: دخل يعقوبُ على فرعون وقد سقط حاجباه على عينيه، فقال: ما بلغ بك هذا، يا إبراهيم؟ فقالوا: إنّه يعقوب. فقال: ما بلغ بك هذا، يا يعقوب؟ قال: طول الزمان، وكثرة الأحزان. فقال الله: يا يعقوب، أتشكوني؟! فقال: يا ربِّ، خطيئةٌ أخطأتُها، فاغفرها لي{4}. (ز) ٣٨٠٧٥- قال سفيان الثوري: دخل على يوسف مَلَكٌ السِّجْنَ. فقال له يوسفُ: أيها الملك الطيب الريح، ما فعل يعقوب؟ ما بلغ حزنه؟ قال: بلغ حزن سبعين ثَكْلى{44}. (ز) ٣٨٠٧٦- عن عبد الله بن أبي جعفر -من طريق نافع بن يزيد- قال: دخل جبريل على يوسف في البئر أو في السِّجن، فقال له يوسف: يا جبريل، ما بلغ مِن حزن أبي؟ قال: حُزْن سبعين ثَكْلى. قال: فما بلغ أجرُه مِن الله؟ قال: أجر مائة شهيد{45}. (٨/٣٠٦) ٣٨٠٧٧- عن خلف بن حَوْشَب، مثله{46}. (٨/٣٠٦) ٣٨٠٧٨- عن عبد الرزاق، قال: بلغنا: أنّ يعقوب ﵇ قال: يا ربِّ، أذهبت ولدي، وأذهبتَ بصرى! قال: بلى، وعِزِّتي وجلالي، وإنِّي لَأَرْحَمُك، ولَأَرُدَّنَّ عليك بصرَك وولدك، وإنّما ابتليتك بهذه البلية لأنّك ذبحت جملًا فشويته، فوجد جارُك ريحه فلم تُنِلْه{47}. (٨/٣١٥) ",footnotes:1:أخرجه ابن جرير ١٣/٣٠٦. وعزاه السيوطي إلى ابن المنذر، وأبي الشيخ.أخرجه ابن جرير ١٣/٣٠٦. وعزاه السيوطي إلى ابن أبي شيبة، وابن المنذر، وأبي الشيخ.أخرجه ابن أبي حاتم ٧/٢١٨٩.أخرجه ابن جرير ١٣/٣٠٨.تفسير مقاتل بن سليمان ٢/٣٤٨.أخرجه ابن جرير ١٣/٣٠٦، وابن أبي حاتم ٧/٢١٨٩.تفسير سفيان الثوري ص١٤٦، وأخرجه ابن أبي حاتم ٧/٢١٨٩ من طريق أبي أحمد الزبيري.أخرجه ابن أبي حاتم ٧/٢١٨٦.أخرجه ابن جرير ١٣/٣٠٧، وابن أبي حاتم ٧/٢١٨٩.أخرجه ابن جرير ١٣/٣٠٧. وعزاه السيوطي إلى ابن أبي حاتم.تفسير مقاتل بن سليمان ٢/٣٤٨.تفسير سفيان الثوري ص١٤٦.عزاه السيوطي إلى ابن مردويه.أخرجه ابن منده -كما في أسد الغابة لابن الأثير ٢/٢٢١ (٢٠٤٤)، وكما في الإصابة لابن حجر ٣/٦٨-٦٩ (٣٢٠٩)- من طريق عبد الرحمن بن زياد بن أنعم، عن مسلم بن يسار، أنّ سعد بن مسعود، به، ورواه الثوري عن ابن أنعم، عن رجل سمّاه، عن النبي ﷺ، ورواه عبدالر زاق في تفسيره ٢/٣٢٧ عن ابن أنعم عن مسلم بن يسار مرسلًا. وفي إسناده اضطراب، وعبد الرحمن بن زياد بن أنعم الإفريقي ضعيف الحديث. ينظر: تهذيب التهذيب ٦/١٧٥.أخرجه عبد الرزاق ١/٣٢٧-٣٢٨، وابن جرير ١٣/٣١٣.عزاه السيوطي إلى ابن المنذر، وابن مردويه.أخرجه ابن عدى ٤/٢٠٥، ٦/٥١٧، والبيهقي في الشعب ١٢/٣٧٦ (٩٥٧٤)، ١٢/٣٧٧-٣٧٨ (٩٥٧٥، ٩٥٧٦، ٩٥٧٧). قال أبو نعيم في الحلية ٨/١٩٧: «غريب من حديث نافع وعبد العزيز، تفرَّد به عنه زافر». وقال ابن أبي حاتم في العلل ٦/٢٧١-٢٧٢ (٢٥١٨): «قال أبو زرعة: هذا حديث باطل». وأورده السيوطي في اللآلئ ٢/٣٢٩. وقال المناوي في التيسير ٢/٣٨٣: «وإسناده ضعيف». وقال الألباني في الضعيفة ٢/١٣٥ (٦٩٣): «ضعيف».أخرجه الطبراني في الصغير ٢/٣٠ (٧٢٦)، والبيهقي في الشعب ١٢/٣٧٣-٣٧٤ (٩٥٧١). قال البيهقي: «تفرَّد به وهب بن راشد بهذا الإسناد، وروي ذلك بإسناد آخر ضعيف». وقال ابن حبان في المجروحين ٣/٧٥ (١١٣٠): «وهب بن راشد شيخ يروي عن مالك بن دينار العجائب، لا يحل الرواية عنه، ولا الاحتجاج به». وقال ابن القيسراني في تذكرة الحفاظ ص٣٠٨-٣٠٩ (٧٧٥): «رواه وهب بن راشد، عن مالك بن دينار، عن أنس. ووهب هذا يروي العجائب عن مالك، لا تحل الرواية عنه، ويقال: إن هذا من كلام وهب بن منبه نفسه». وقال الهيثمي في المجمع ١٠/٢٤٨ (١٧٨١٩): «رواه الطبراني في الصغير، وفيه وهب بن راشد البصري صاحب ثابت، وهو متروك». وقال السخاوي في المقاصد الحسنة ص٦٤٠ بعد ذكره لهذه الرواية مع رواية أخرى: «وهما واهيان جدًّا». وأورده السيوطي في اللآلئ ٢/٢٦٩.أخرجه الشاشي في مسنده ٢/٨٧ (٦٠٩)، والبيهقي في الشعب ١٢/٣٧٤-٣٧٥ (٩٥٧٢)، والعقيلي في الضعفاء ٣/١٢٧. قال ابن الجوزي في الموضوعات ٣/١٣٤: «ليس فيها شيء صحيح ...، فيه عبيد الله بن موسى. قال العقيلي: هو مجهول، وحديثه غير محفوظ». وقال ابن حجر في لسان الميزان ٤/١١٦ (٢٣٧): «عبيد الله بن موسى بن معدان عن منصور لا يُعْرَف، وأتى بخبر منكر ذكره العقيلي انتهى. ونسبه العقيلي كوفيًّا، وقال: مجهول بالنقل، حديثه غير محفوظ». وأورده السيوطي في اللآلئ ٢/٢٦٩.أخرجه الحاكم ٢/٣٧٨، ٣٧٩ (٣٣٢٨، ٣٣٢٩)، وابن أبي حاتم ٧/٢١٨٨ (١١٩٠١). قال الحاكم: «هكذا في سماعي بخطِّ يد حفص بن عمر بن الزبير، وأظن الزبير وهِم مَن الراوي، فإنّه حفص بن عمر بن عبد الله بن أبي طلحة الأنصاري ابن أخي أنس بن مالك، فإن كان كذلك فالحديث صحيح». وقال ابن كثير في تفسيره ٤/٤٠٦ عن رواية ابن أبي حاتم: «وهذا حديث غريب، فيه نكارة». وقال الهيثمي في المجمع ٧/٤٠ (١١٠٨٩): «رواه الطبراني في الصغير، والأوسط، عن شيخه محمد بن أحمد الباهلي البصري، وهو ضعيف جدًّا». وقال الألباني في الضعيفة ١٤/٨٨٦ (٦٨٨٠): «منكر».أخرجه البيهقي (١٠٠٥١).أخرجه ابن جرير ١٣/٣٠٨.النشيج: صوت معه توجع وبكاء، كما يردد الصبي بكاءه في صدره. النهاية (نشج).أخرجه عبد الرزاق (٢٧٠٣)، والبيهقي (٢٠٥٨).أخرجه عبد الرزاق (٢٧١٦)، وسعيد بن منصور (١١٣٨- تفسير)، وابن سعد ٦/١٢٦، وابن أبي شيبة ١٤/٧، والبيهقي في شعب الإيمان (٢٠٥٧).أخرجه أحمد في الزهد ص١٤٣، والبيهقي (١٠٠٤٢).أخرجه ابن جرير ١٣/٣١٣.أخرجه ابن جرير ١٣/٣٠٩-٣١٠.أخرجه ابن جرير ١٣/٣١٢-٣١٣.أخرجه ابن جرير ١٣/٣٠٧.أخرجه ابن أبي الدنيا في المرض والكفارات (٢٢٧)، والبيهقي في الشُّعَب (١٠٠٥٢).أي: خضع وذل. النهاية (ضعضع).أخرجه أحمد في الزهد ص٨٥، والبيهقي (١٠٠٤٣).قال محققو المصدر: العبارة غير واضحة، وفي نسخة: يا أطهر.أخرجه ابن جرير ١٣/٣١٠-٣١١، وابن أبي حاتم ٧/٢١٤٠. وعزاه السيوطي إلى عَبد بن حُمَيد، وابن المنذر، وأبي الشيخ.تفسير الثعلبي ٥/٢٤٩، وتفسير البغوي ٤/٢٦٩.أخرجه ابن جرير ١٣/٣٠٧، وابن أبي حاتم ٧/٢١٨٩. وعزاه السيوطي إلى أبي الشيخ.أخرجه عبد الرزاق ١/٣١٩، وأحمد في الزهد ص٨٤، وابن جرير ١٣/٣٠٨، وابن أبي حاتم ٧/٢١٨٩. وعزاه السيوطي إلى ابن أبى شيبة، وابن المنذر، وأبي الشيخ.أخرجه ابن جرير ١٣/٣١٢، وابن أبي حاتم ٧/٢١٨٦.عزاه السيوطي إلى أحمد في الزهد.أخرجه ابن جرير ١٣/٣٠٩، وابن أبي حاتم ٧/٢١٨٦.أخرجه ابن جرير ١٣/٣١١-٣١٢.أخرجه ابن جرير ١٣/٣٠٨.تفسير الثوري ص١٤٥.أخرجه ابن جرير ١٣/٣١٠.أخرجه ابن أبى شيبة ١٣/٢١٢.عزاه السيوطي إلى ابن المنذر.
