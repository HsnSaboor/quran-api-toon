quran[8]{c,v,t}:
  12,79,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿قَالَ مَعَاذَ ٱللَّهِ أَن نَّأۡخُذَ إِلَّا مَن وَجَدۡنَا مَتَـٰعَنَا عِندَهُۥۤ إِنَّاۤ إِذࣰا لَّظَـٰلِمُونَ ۝٧٩﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٧٩١٦<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- قال: فإذا أتيتم أباكم فاقرءوا عليه مِنِّي السلام، وقولوا له: إنّ ملِك مصر يدعو لك ألّا تموت حتى ترى ابنَك يوسف؛ حتّى يعلمَ أبوكم أنّ في الأرض صِدِّيقين مثله{1}. (٨/١٩٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٩١٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: قال يوسف: <span class="qpc-hafs">﴿معاذ الله﴾</span> يقول: نعوذ بالله <span class="qpc-hafs">﴿أن نأخذ﴾</span> يعني: أن نَحْبِس بالسرقة <span class="qpc-hafs">﴿إلا من وجدنا متاعنا عنده إنا إذا لظالمون﴾</span> أن نأخذ البريءَ مكان السقيم{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٩١٨<span class="dash">-</span></span> عن <span class="name-3">محمد بن إسحاق</span> -من طريق سلمة- <span class="qpc-hafs">﴿قال معاذ الله أن نأخذ إلا من وجدنا متاعنا عنده إنا إذا لظالمون﴾</span>، يقول: إن أخذنا غيرَ الذي وجدنا متاعنا عنده إنّا إذًا نفعل ما ليس لنا فِعْلُه، ونَجُور على الناس{3}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ١٣/ ٢٨٠، وابن أبي حاتم ٧/٢١٨١.|2:تفسير مقاتل بن سليمان ٢/٣٤٧.|3:أخرجه ابن جرير ١٣/٢٨٠.
  12,80,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿فَلَمَّا ٱسۡتَیۡـَٔسُوا۟ مِنۡهُ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٧٩١٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فلما استيأسوا منه﴾</span>، يقول: يَئِسُوا مِن بنيامين{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٩٢٠<span class="dash">-</span></span> عن <span class="name-3">محمد بن إسحاق</span> -من طريق سلمة- <span class="qpc-hafs">﴿فلما استيأسوا منه﴾</span>، قال: يئسوا مِنهُ، ورأوا شِدَّته في أمره{2}<span class=comment-ref>٣٤٢٨</span>. (٨/٢٩٩)</p></p><p></div></p><p><div><span class=comment-ref>٣٤٢٨</span> لم يذكر <u>ابنُ جرير</u> (١٣/٢٨١) غير قول محمد بن إسحاق.</div></p><p><h3><span class="qpc-hafs">﴿خَلَصُوا۟ نَجِیࣰّاۖ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٧٩٢١<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿خَلَصُوا نَجِيًا﴾</span>، قال: وحدهم{3}. (٨/٢٩٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٩٢٢<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- قال: فلمّا أيِسُوا منه، وأخرَج لهم شَمْعُونَ وقد كان ارْتَهَنَه؛ خَلَوْا بينهم <span class="qpc-hafs">﴿نجيًا﴾</span> يَتَناجَوْن بينهم{4}. (٨/١٩٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٩٢٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿خلصوا نجيا﴾</span>، يعني: خَلَوْا يتناجون بينهم على حِدَةٍ{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٩٢٤<span class="dash">-</span></span> عن <span class="name-3">محمد بن إسحاق</span> -من طريق سلمة- <span class="qpc-hafs">﴿فلما استيأسوا منه خلصوا نجيا﴾</span>، أي: خلا بعضهم ببعض، ثم قالوا: ماذا تَرَوْن؟{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٩٢٥<span class="dash">-</span></span> عن <span class="name-3">سفيان الثوري</span>، في قوله: <span class="qpc-hafs">﴿فلما استيأسوا منه خلصوا نجيا﴾</span>، قال: تَشاوَرُوا تَشاوُرًا بوَسْوَسَة{7}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿قَالَ كَبِیرُهُمۡ أَلَمۡ تَعۡلَمُوۤا۟ أَنَّ أَبَاكُمۡ قَدۡ أَخَذَ عَلَیۡكُم مَّوۡثِقࣰا مِّنَ ٱللَّهِ وَمِن قَبۡلُ مَا فَرَّطتُمۡ فِی یُوسُفَۖ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٧٩٢٦<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، في قوله: <span class="qpc-hafs">﴿قال كبيرهم﴾</span>، قال: هو يَهُوذا، وهو أعقلهم{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٩٢٧<span class="dash">-</span></span> عن <span class="name-2">كعب الأحبار</span>، في قوله: <span class="qpc-hafs">﴿قال كبيرهم﴾</span>، قال: هو رُوبِيل، وكان أسَنُّهُم، وهو الذي نهى إخوتَه عن قتله، وهو ابن خالة يوسف{9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٩٢٨<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿قال كبيرهم﴾</span>، قال: شَمْعُون الذي تخلَّف أكبرُهم عقلًا، وأكبر منه في الميلاد روبيل{10}. (٨/٢٩٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٩٢٩<span class="dash">-</span></span> عن <span class="name-2">الضَّحّاك بن مُزاحِم</span>، في قوله: <span class="qpc-hafs">﴿قال كبيرهم﴾</span>، قال: هو رُوبِيل، وكان أكبرَهم في السِّنِّ، وهو الذي نهى الإخوةَ عن قتل يوسف{11}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٩٣٠<span class="dash">-</span></span> قال <span class="name-2">وهب بن مُنَبِّه</span>، في قوله: <span class="qpc-hafs">﴿قال كبيرهم﴾</span>: يهوذا، وكان أعقلَهم{9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٩٣١<span class="dash">-</span></span> عن <span class="name-2">وهب بن مُنَبِّه</span>، قال: إنّ شمعان كان أشدَّ بني يعقوب بأسًا، وإنّه كان إذا غضب قام شعرُه وانتفخ، فلا يُطفِئ غضبُه شيءٌ إلا أن يَمَسَّه أحدٌ مِن آل يعقوب، وإنّه كان قد أغار مرَّةً على أهل قرية فدَمَّرهم، وإنّه غَضِب يومَ أُخِذ بنو يعقوب بالصُّواع غضبًا شديدًا حتى انتفخ، فأمر يوسفُ ﵇ ابنَه أن يَمَسَّه، فسكن غضبُه، وبرد، وقال: قد مسَّني يدٌ مِن آل يعقوب{13}. (٨/٣٠٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٩٣٢<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد بن أبي عروبة- في قوله: <span class="qpc-hafs">﴿قال كبيرُهُم﴾</span>، قال: هو روبيل، وهو الذي كان نهاهم عن قتله، وهو ابنُ خالته، وكان أكبرَ القوم{14}. (٨/٣٠٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٩٣٣<span class="dash">-</span></span> عن <span class="name-2">إسماعيل</span> <span class="name-2">السُّدِّيّ</span>-من طريق أسباط- قال: <span class="qpc-hafs">﴿قال كبيرُهم﴾</span> وهو رُوبيل، ولم يكن بأكبرهم سِنًّا، ولكن كان كبيرَهم في العلم: <span class="qpc-hafs">﴿ألم تعلموا أن أباكم قد أخذ عليكم موثقًا من الله ومن قبل ما فرطتم في يوسف فلن أبرح الأرض حتى يأذن لي أبى أو يحكم الله لي وهو خير الحاكمين﴾</span>. فأقام روبيل بمصر، وأَقْبَل التسعةُ إلى يعقوب، فأخبروه الخبر، فبكى، وقال: يا بَنِيَّ، ما تذهبون مِن مَرَّةٍ إلا نقصتم واحدًا؟! ذهبتُم فنقصتم يوسف، ثم ذهبتم الثانية فنقصتم شمعون، ثم ذهبتم الثالثة فنقصتم بنيامين ورُوبيل{15}. (٨/١٩٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٩٣٤<span class="dash">-</span></span> عن <span class="name-3">محمد بن السائب الكلبي</span>، في قوله: <span class="qpc-hafs">﴿قال كبيرهم﴾</span>، قال: هو يهوذا، وهو أعقلُهم{11}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٩٣٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: وقال بعضُهم لبعض: <span class="qpc-hafs">﴿قال كبيرهم﴾</span> يعني: عظيمهم في أنفسهم، وأعلمهم، وهو يهوذا، ولم يكن أكبرَهم في السن: <span class="qpc-hafs">﴿ألم تعلموا أن أباكم قد أخذ عليكم موثقا من الله﴾</span> يعني: في أمر بنيامين لَتَأْتِينَّه به، <span class="qpc-hafs">﴿ومن قبل﴾</span> بنيامين <span class="qpc-hafs">﴿ما فرطتم في يوسف﴾</span> يعني: ضَيَّعْتُم{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٩٣٦<span class="dash">-</span></span> عن <span class="name-3">محمد بن إسحاق</span> -من طريق سلمة-: ... فقال رُوبِيل -كما ذُكِر لي، وكان كبيرَ القوم-: <span class="qpc-hafs">﴿ألم تعلموا أن أباكم قد أخذ عليكم موثقا من الله ومن قبل ما فرطتم في يوسف﴾</span> الآية{18}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٩٣٧<span class="dash">-</span></span> قال <span class="name-3">محمد بن إسحاق</span>، في قوله: <span class="qpc-hafs">﴿قال كبيرهم﴾</span>: لاوي{9}<span class=comment-ref>٣٤٢٩</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٣٤٢٩</span> اختُلِف في المعنيِّ بقوله: <span class="qpc-hafs">﴿كبيرهم﴾</span> على أقوال: <b>الأول</b>: أنّ ذلك عُنِي به كبيرُهم في العقل والعلم، لا في السن، وهو شمعون في بعض الأقوال، ويهوذا في بعضها، ولاوي في بعضها الآخر. <b>الثاني</b>: أنّ ذلك عني به كبيرهم في السِّنِّ، وهو روبيل.</p><p>وقد <span class="comment-type-3">رجّح</span> <u>ابنُ جرير</u> (١٣/٢٨٥) <span class="mustanad">مستندًا إلى إجماع أهل التاريخ، وإلى اللغة</span> القول الثاني، فقال: «وأولى الأقوال في ذلك بالصحة قولُ مَن قال: عنى بقوله: <span class="qpc-hafs">﴿قال كبيرهم﴾</span>: روبيل؛ لإجماع جميعهم على أنّه كان أكبرهم سنًّا، ولا تفهم العرب في المخاطبة إذا قيل لهم: فلان كبير القوم. مطلقًا بغيرِ وصلٍ إلا أحد معنيين؛ إمّا في الرياسة عليهم والسؤدد، وإمّا في السن، فأمّا في العقل فإنهم إذا أرادوا ذلك وصلوه، فقالوا: هو كبيرهم في العقل. فأمّا إذا أطلق بغير صلته بذلك فلا يفهم إلا ما ذكرت. وقد قال أهل التأويل: لم يكن لشمعون -وإن كان قد كان مِن العلم والعقل بالمكان الذي جعله الله به- على إخوته رياسة وسُؤْدَد؛ فيُعْلَم بذلك أنه عُنِي بقوله: <span class="qpc-hafs">﴿قال كبيرهم﴾</span>. فإذا كان ذلك كذلك فلم يبق إلا الوجه الآخر، وهو الكبر في السِّن، وقد قال الذين ذكرنا جميعًا: روبيل كان أكبر القوم سنًّا، فصحَّ بذلك القول الذي اخترناه».</p><p>و<span class="comment-type-4">وافقه</span> <u>ابنُ عطية</u> (٥/١٣٠) بقوله: «وهذا أظهر».</div></p><p><h3><span class="qpc-hafs">﴿فَلَنۡ أَبۡرَحَ ٱلۡأَرۡضَ حَتَّىٰ یَأۡذَنَ لِیۤ أَبِیۤ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٧٩٣٨<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فلن أبرح الأرض﴾</span> يعني: أرض مصر<span class="qpc-hafs">﴿حتى يأذن لي أبي﴾</span> في الرجعة{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٩٣٩<span class="dash">-</span></span> عن <span class="name-3">محمد بن إسحاق</span> -من طريق سلمة-: <span class="qpc-hafs">﴿فلن أبرح الأرض﴾</span> التي أنا بها اليوم <span class="qpc-hafs">﴿حتى يأذن لي أبي﴾</span> بالخروج منها{21}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٩٤٠<span class="dash">-</span></span> عن الحميدي، قال حدَّثنا <span class="name-3">سفيان [بن عيينة]</span>، قال: سمعتُ رجلًا سأل <span class="name-2">جابرًا الجعفي</span> عن قوله: <span class="qpc-hafs">﴿فلن أبرح الأرض حتى يأذن لي أبي أو يحكم الله لي وهو خير الحاكمين﴾</span>. قال جابر: لم يجئ تأويلُ هذه الآية بعدُ. قال <span class="name-3">سفيان</span>: وكذب. قال الحميدي: فقلنا لسفيان: وما أراد بهذا؟ فقال: إنّ الرافضة تقول: إنّ عليًّا في السحاب، فلا يخرج مَعَ مَن خرج مِن ولده حتى ينادي مُنادٍ مِن السماء -يريد: أنّ عليًّا ينادي مِن السحاب-: اخرجوا مع فلان. يقول: فهذا تأويل هذه الآية، وكذب، هذه كانت في إخوة يوسف{22}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿أَوۡ یَحۡكُمَ ٱللَّهُ لِیۖ وَهُوَ خَیۡرُ ٱلۡحَـٰكِمِینَ ۝٨٠﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٧٩٤١<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span>، في قوله: <span class="qpc-hafs">﴿أو يحكم الله لى﴾</span>، قال: أُقاتِل بالسيفِ حتى أُقْتَل{23}. (٨/٣٠٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٩٤٢<span class="dash">-</span></span> عن <span class="name-2">أبي صالح باذام</span> -من طريق إسماعيل بن أبي خالد- في قوله: <span class="qpc-hafs">﴿حتى يأذن لي أبي أو يحكم الله لي﴾</span>، قال: بالسَّيف{24}<span class=comment-ref>٣٤٣٠</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٣٤٣٠</span> <span class="comment-type-1">وجَّه</span> <u>ابنُ جرير</u> (١٣/٢٨٧) على قول أبي صالح، فقال: «وكأنّ أبا صالح وجّه تأويل قوله: <span class="qpc-hafs">﴿أو يحكم الله لي﴾</span> إلى: أو يقضي الله لي بحربِ مَن منعني مِن الانصراف بأخي بنيامين إلى أبيه يعقوب، فأُحارِبُه».</div></p><p><div></p><p><p><span class="item-no">٣٧٩٤٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿أو يحكم الله لي﴾</span> فيَرُدَّ عَلَيَّ بنيامين، <span class="qpc-hafs">﴿وهو خير الحاكمين﴾</span> يعني: أفضل القاضِين{1}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٢/٣٤٧.|2:أخرجه ابن جرير ١٣/٢٨١، وابن أبي حاتم ٧/٢١٨١.|3:أخرجه ابن جرير ١٣/٢٨٢، وابن أبي حاتم ٧/٢١٨١.|4:أخرجه ابن جرير ١٣/ ٢٨٢، وابن أبي حاتم ٧/٢١٨١ مختصرًا.|5:تفسير مقاتل بن سليمان ٢/٣٤٧.|6:أخرجه ابن جرير ١٣/٢٨٢، وابن أبي حاتم ٧/٢١٨١.|7:تفسير الثوري ص١٤٥.|8:تفسير البغوي ٤/٢٦٥.|9:تفسير الثعلبي ٥/٢٤٥.|10:أخرجه ابن جرير ١٣/٢٨٣، وابن أبي حاتم ٧/٢١٨١. وعزاه السيوطي إلى ابن أبي شيبة، وابن المنذر، وأبي الشيخ.|11:تفسير الثعلبي ٥/٢٤٥، وتفسير البغوي ٤/٢٦٥.|12:تفسير الثعلبي ٥/٢٤٥.|13:عزاه السيوطي إلى أبي الشيخ.|14:أخرجه ابن جرير ١٣/٢٨٤، وابن أبي حاتم ٧/٢١٨١ بنحوه، كذلك من طريق سعيد بن بشير. كما أخرج نحوه عبد الرزاق في تفسيره ١/ ٣٢٧، وابن جرير ١٣/٢٨٤ من طريق مَعْمَر. وعزاه السيوطي إلى أبي الشيخ.|15:أخرجه ابن جرير ١٣/٢٨٤ وفي آخره: وذهبتم الآن فنقصتم روبيل، وابن أبي حاتم ٧/٢١٨١، ٢١٨٢، ٢١٨٤. وفي تفسير الثعلبي ٥/٢٤٥، وتفسير البغوي ٤/٢٦٥ بنحوه، وفيه: وهو الذي نهى الإخوة عن قتل يوسف.|16:تفسير الثعلبي ٥/٢٤٥، وتفسير البغوي ٤/٢٦٥.|17:تفسير مقاتل بن سليمان ٢/٣٤٧.|18:أخرجه ابن جرير ١٣/٢٨٤.|19:تفسير الثعلبي ٥/٢٤٥.|20:تفسير مقاتل بن سليمان ٢/٣٤٧.|21:أخرجه ابن جرير ١٣/٢٨٦.|22:أخرجه العقيلي في كتاب الضعفاء ١/٥١٨-٥١٩ (٩٢٦/٢٠)، وابن عدي في الكامل ٢/٣٣١، والفسوي في المعرفة والتاريخ ٢/٧١٥.|23:عزاه السيوطي إلى ابن المنذر.|24:أخرجه ابن جرير ١٣/٢٨٤، وابن أبي حاتم ٧/٢١٨٢.|25:تفسير مقاتل بن سليمان ٢/٣٤٧.
  12,81,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿ٱرۡجِعُوۤا۟ إِلَىٰۤ أَبِیكُمۡ فَقُولُوا۟ یَـٰۤأَبَانَاۤ إِنَّ ٱبۡنَكَ سَرَقَ وَمَا شَهِدۡنَاۤ إِلَّا بِمَا عَلِمۡنَا﴾</span> - قراءات</h3></p><p><div></p><p><p><span class="item-no">٣٧٩٤٤<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> أنّه قَرَأ: (إنَّ ابْنَكَ سُرِّقَ){1}<span class=comment-ref>٣٤٣١</span>. (٨/٣٠٠)</p></p><p></div></p><p><div><span class=comment-ref>٣٤٣١</span> <span class="comment-type-4">علّق</span> <u>ابنُ جرير</u> (١٣/٢٨٧) على هذه القراءة، فقال: «ورُوِي عن ابن عباس: (إنَّ ابْنَكَ سُرِّقَ) بضم السين وتشديد الراء، على وجه ما لم يُسَمَّ فاعله، بمعنى: أنه سُرِّق».</p><p>و<span class="comment-type-4">علّق</span> عليها <u>ابنُ عطية</u> (٣/٢٧٠) بقوله: «وكأنّ هذه القراءة فيها لهم تحرٍّ، ولم يقطعوا عليه بسرقة، وإنما أرادوا جُعِل سارقًا بما ظهر من الحال».</div></p><p><h3><span class="qpc-hafs">﴿ٱرۡجِعُوۤا۟ إِلَىٰۤ أَبِیكُمۡ فَقُولُوا۟ یَـٰۤأَبَانَاۤ إِنَّ ٱبۡنَكَ سَرَقَ وَمَا شَهِدۡنَاۤ إِلَّا بِمَا عَلِمۡنَا﴾</span> - تفسير الآية</h3></p><p><div></p><p><p><span class="item-no">٣٧٩٤٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ارجعوا إلى أبيكم فقولوا يا أبانا إن ابنك سرق﴾</span> يعني: بنيامين، <span class="qpc-hafs">﴿وما شهدنا إلا بما علمنا﴾</span> يعني: رَأَيْنا الصُّواعَ حين أُخْرِج مِن متاعه{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٩٤٦<span class="dash">-</span></span> عن <span class="name-3">محمد بن إسحاق</span> -من طريق سلمة-: <span class="qpc-hafs">﴿ارجعوا إلى أبيكم﴾</span> فإنِّي ما كُنتُ راجِعًا حتى يأتيني أمره، <span class="qpc-hafs">﴿فقولوا يا أبانا إن ابنك سرق، وما شهدنا إلا بما علمنا﴾</span> أي: قد وُجِدَت السرقة في رحِلِه ونحن ننظر، لا علم لنا بالغيب، <span class="qpc-hafs">﴿وما كنا للغيب حافظين﴾</span>{3}<span class=comment-ref>٣٤٣٢</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٣٤٣٢</span> أفاد قولُ ابن إسحاق أنّ القائل: <span class="qpc-hafs">﴿ارجعوا إلى أبيكم﴾</span> هو كبيرهم. وقد <span class="comment-type-4">ذكر</span> ذلك <u>ابنُ عطية</u> (٥/١٣١بتصرف)، و<span class="comment-type-3">رجّحه</span> بقوله: «وهو الأظهر». وذكر <b>قولًا آخر</b> أنّ قائل ذلك هو يوسف ﵇.</div></p><p><div></p><p><p><span class="item-no">٣٧٩٤٧<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- قال: قال يعقوبُ ﵇ لبنيه: ما دَرى هذا الرجلُ أنّ السارق يُؤخَذ بسرقته إلا بقولكم. قالوا: <span class="qpc-hafs">﴿وما شهدنا إلا بما علمنا﴾</span> لم نشهد أنّ السارق يُؤْخَذ بسرقته إلا وذاك الذي عَلِمْناه{4}<span class=comment-ref>٣٤٣٣</span>. (٨/٣٠٠)</p></p><p></div></p><p><div><span class=comment-ref>٣٤٣٣</span> اختُلِف في قوله: <span class="qpc-hafs">﴿وما شهدنا إلا بما علمنا﴾</span> على قولين: <b>الأول</b>: أنّ معناه: وما قلنا: إنّه سرق. إلّا بظاهر علمنا حين رأينا صواعُ الملك في وعائه. <b>الثاني</b>: أنّ معناه: وما شهدنا عند يوسف بأنّ السارق يؤخذ بسرقته إلا بما علمنا.</p><p>وقد <span class="comment-type-3">رجّح</span> <u>ابنُ جرير</u> (١٣/٢٩٠) <span class="mustanad">مستندًا إلى السياق</span> القول الأول، وعلَّل ذلك بقوله: «لأنّه عقيب قوله: <span class="qpc-hafs">﴿إن ابنك سرق﴾</span>، فهو بأن يكون خبرًا عن شهادتهم بذلك أولى مِن أن يكون خبرًا عما هو منفصل».</p><p>و<span class="comment-type-4">بيّن</span> <u>ابنُ عطية</u> (٥/١٣١-١٣٢) أنّ قوله: <span class="qpc-hafs">﴿وما كنا للغيب حافظين﴾</span> على القول الأول معناه: والعلم في الغيب إلى الله، ليس ذلك في حفظنا. وعلى الثاني معناه: وما كُنّا للغيب حافظين أنّ السرقة تخرج مِن رَحِل أحدنا. ثم <span class="comment-type-4">قال</span> عقب ذكره الخلاف: «ويحتمل قوله: <span class="qpc-hafs">﴿وما كُنّا لِلْغَيْبِ حافِظِينَ﴾</span> أي: حين واثقناك، إنّما قصدنا ألا يقع مِنّا نحن في جهته شيء يكرهه، ولم نعلم الغيب في أنّه سيأتي هو بما يوجب رِقَّه عندك إلا بما علمناه مِن ظاهر حاله، وما كنا بالليل حافظين لِما يقع مِن سرقته هو، أو التدليس عليه».</div></p><p><h3><span class="qpc-hafs">﴿ٱرۡجِعُوۤا۟ إِلَىٰۤ أَبِیكُمۡ فَقُولُوا۟ یَـٰۤأَبَانَاۤ إِنَّ ٱبۡنَكَ سَرَقَ وَمَا شَهِدۡنَاۤ إِلَّا بِمَا عَلِمۡنَا﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٣٧٩٤٨<span class="dash">-</span></span> عن قتادة، أنّ سليمان بن يسار حدَّث: أنّ <span class="name-2">عمر بن عبد العزيز</span> قال: ما رأيتُ مثل القَسامَةِ قطُّ أُقِيدَ بها، واللهُ يقول: <span class="qpc-hafs">﴿وأشهدوا ذوي عدل منكم﴾</span> [الطلاق:٢]. وقالت الأسباط: <span class="qpc-hafs">﴿وما شهدنا إلا بما علمنا وما كنا للغيب حافظين﴾</span>. وقال الله: <span class="qpc-hafs">﴿إلا من شهد بالحق وهم يعلمون﴾</span> [الزخرف:٨٦]{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٩٤٩<span class="dash">-</span></span> عن <span class="name-2">إبراهيم النخعي</span> -من طريق أبي معشر-: أنّه كرِه أن يكتم الرجلُ شهادتَه، فإذا اسْتُشْهِد شهَد. ويقرأ: <span class="qpc-hafs">﴿وما شهدنا إلا بما علمنا﴾</span>{6}. (٨/٣٠١)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَمَا كُنَّا لِلۡغَیۡبِ حَـٰفِظِینَ ۝٨١﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٧٩٥٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، في قوله: <span class="qpc-hafs">﴿وما كنا للغيب حافظين﴾</span>، قال: ما كُنّا لليله ونهارِه ومجيئه وذهابه حافظين{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٩٥١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق جُوَيْبِر، عن الضحاك- في قوله: <span class="qpc-hafs">﴿وما كنا للغيب حافظين﴾</span>، قال: يعنون: أنّه سرق ليلًا وهم نيام. والغيب هو الليل بلغة حِمْيَر{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٩٥٢<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿وما كنا للغيب حافظين﴾</span>، قال: لم نعلم أنّه سَيَسْرِق{9}. (٨/٣٠١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٩٥٣<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span> -من طريق يزيد- في قوله: <span class="qpc-hafs">﴿وما كنا للغيب حافظين﴾</span>، قال: ما كُنّا نعلم أنّ ابنَك يسرق{10}. (٨/٣٠١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٩٥٤<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span>، في قوله: <span class="qpc-hafs">﴿وما كنا للغيب حافظين﴾</span>، قال: وما كُنّا للغيب حافظين، فلَعَلَّها دُسَّت بالليل في رَحْله{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٩٥٥<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق مَعْمَر- في قوله: <span class="qpc-hafs">﴿وما كنا للغيب حافظين﴾</span>، قال: يقولون: ما كُنّا نَظُنَّ أنّ ابنك يسرق{12}<span class=comment-ref>٣٤٣٤</span>. (٨/٣٠١)</p></p><p></div></p><p><div><span class=comment-ref>٣٤٣٤</span> لم يذكر <u>ابنُ جرير</u> (١٣/٢٨٩-٢٩٠) غير قول قتادة، وعكرمة من طريق يزيد، ومجاهد.</div></p><p><div></p><p><p><span class="item-no">٣٧٩٥٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وما كنا للغيب حافظين﴾</span>، يعني: وما كُنّا نرى أنه يسرق، ولو علمنا ما ذهبنا به معَنا{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٩٥٧<span class="dash">-</span></span> عن <span class="name-3">محمد بن إسحاق</span> -من طريق سلمة- <span class="qpc-hafs">﴿وما كنا للغيب حافظين﴾</span>: فلا عِلْمَ لنا بالغيب{14}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٩٥٨<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق أصبغ بن الفرج- يقول في قوله: <span class="qpc-hafs">﴿وما كنا للغيب حافظين﴾</span>، قال: ما علِمنا مِن الغيب أنّه أخَذَ له شيئًا، ولا ظننّا ذلك، إنّما سألنا{15}: ما جزاء السارق؟{14}. (ز)</p></p><p></div></p></div>",footnotes:1:عزاه السيوطي إلى أبي الشيخ.</p><p>وهي قراءة شاذة، تروى أيضًا عن أحمد بن جبير، وابن أبي شريح. انظر: مختصر ابن خالويه ص٦٩، والبحر المحيط ٥/٣٢٩.|2:تفسير مقاتل بن سليمان ٢/٣٤٧.|3:أخرجه ابن جرير ١٣/٢٨٨.|4:أخرجه ابن جرير ١٣/٢٨٧-٢٨٨.|5:أخرجه ابن أبي شيبة (ت: محمد عوامة) ١٤/٢٦٥-٢٦٦ (٢٨٣٨٥).|6:أخرجه ابن أبي حاتم ٧/٢١٨٢.|7:تفسير الثعلبي ٥/٢٤٦، وتفسير البغوي ٤/٢٦٦.|8:تفسير الثعلبي ٥/٢٤٦.|9:أخرجه ابن جرير ١٣/٢٨٩-٢٩٠ بلفظ: لم نشعر أنه سيسرق. وعزاه السيوطي إلى ابن أبى شيبة، وابن المنذر.|10:أخرجه ابن جرير ١٣/٢٩٠، وابن أبي حاتم ٧/٢١٨٣. وعزاه السيوطي إلى أبي الشيخ.|11:تفسير الثعلبي ٥/٢٤٦، وتفسير البغوي ٤/٢٦٦.|12:أخرجه عبد الرزاق ١/٣٢٧، وابن جرير ١٣/٢٩٠، وابن أبي حاتم ٧/٢١٨٣. وعزاه السيوطي إلى ابن المنذر، وأبي الشيخ.|13:تفسير مقاتل بن سليمان ٢/٣٤٧.|14:أخرجه ابن أبي حاتم ٧/٢١٨٣.|15:كذا في المطبوع، ولعلها: سُئلنا.|16:أخرجه ابن أبي حاتم ٧/٢١٨٣.
  12,82,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَسۡـَٔلِ ٱلۡقَرۡیَةَ ٱلَّتِی كُنَّا فِیهَا﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٧٩٥٩<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق ابن جُرَيْج- <span class="qpc-hafs">﴿وسئل القرية التي كنا فيها﴾</span>، قال: يعنون: مِصْر{1}<span class=comment-ref>٣٤٣٥</span>. (٨/٣٠١)</p></p><p></div></p><p><div><span class=comment-ref>٣٤٣٥</span> <span class="comment-type-4">بيّن</span> <u>ابنُ عطية</u> (٥/١٣٨) أنّ قول ابن عباس هذا على المجاز، والمراد: أهل مصر. و<span class="comment-type-3">رجّحه</span> بقوله: «هذا قول الجمهور، وهو الصحيح». ولم يذكر مستندًا، ثم ذكر <b>قولًا آخر</b> أنّ هذا مِن الحذف، وليس من المجاز.</div></p><p><div></p><p><p><span class="item-no">٣٧٩٦٠<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿وسئل القرية﴾</span>، قال: مِصْر{2}. (٨/٣٠١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٩٦١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿واسأل القرية﴾</span> يعني: مِصْر <span class="qpc-hafs">﴿التي كنا فيها﴾</span> أنّه سَرَق{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٩٦٢<span class="dash">-</span></span> عن <span class="name-3">محمد بن إسحاق</span> -من طريق سلمة- قال: قد عَرَف رُوبِيلُ في رَجْعِ قولِه لإخوته أنّهم أهل تُهْمَةٍ عند أبيهم؛ لِما كانوا صنعوا في يوسف. وقولهم له: <span class="qpc-hafs">﴿اسأل القرية التي كنا فيها والعير التي أقبلنا فيها﴾</span>؛ فقد علِموا ما علِمنا، وشهدوا ما شهدنا إن كنتَ لا تصدقنا، <span class="qpc-hafs">﴿وإنا لصادقون﴾</span>{4}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَٱلۡعِیرَ ٱلَّتِیۤ أَقۡبَلۡنَا فِیهَاۖ وَإِنَّا لَصَـٰدِقُونَ ۝٨٢﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٧٩٦٣<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن جريج- في قوله: <span class="qpc-hafs">﴿والعير﴾</span>، قال: هي حَمِير{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٩٦٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿والعير التي أقبلنا فيها وإنا لصادقون﴾</span> فيما نقول{3}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ١٣/٢٩١. وعزاه السيوطي إلى ابن المنذر.|2:أخرجه ابن جرير ١٣/٢٩٢، وابن أبي حاتم ٧/٢١٨٤. وعزاه السيوطي إلى أبي الشيخ.|3:تفسير مقاتل بن سليمان ٢/٣٤٧.|4:أخرجه ابن جرير ١٣/٢٩١، وابن أبي حاتم ٧/٢١٨٣.|5:أخرجه ابن أبي حاتم ٧/٢١٨٣.|6:تفسير مقاتل بن سليمان ٢/٣٤٧.
  12,83,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿قَالَ بَلۡ سَوَّلَتۡ لَكُمۡ أَنفُسُكُمۡ أَمۡرࣰاۖ فَصَبۡرࣱ جَمِیلٌۖ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٧٩٦٥<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد بن أبي عروبة- قوله: <span class="qpc-hafs">﴿بل سولت لكم أنفسكم أمرا﴾</span>، أي: زَيَّنت لكم أنفسُكم أمرًا{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٩٦٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: قال لهم يعقوب: كُلَّما ذهبتم نقص منكم واحد! وكان يوسف ﵇ حبس بِنيامين، وأقام شمعون ويهوذا، فاتَّهمهم يعقوب ﵇، فـ<span class="qpc-hafs">﴿قال بل سولت لكم﴾</span> يعني: ولكن زَيَّنَتْ لكم <span class="qpc-hafs">﴿أنفسكم أمرا﴾</span> كان هو منكم هذا، <span class="qpc-hafs">﴿فصبر جميل﴾</span> يعني: صبرًا حَسَنًا لا جَزَع فيه{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٩٦٧<span class="dash">-</span></span> عن <span class="name-3">محمد بن إسحاق</span> -من طريق سلمة- قال: فلمّا جاءوا بذلك إلى يعقوب -يعني: بقول روبيل له- اتَّهَمَهم، وظنَّ أنّ ذلك كفعلتهم بيوسف، ثم قال: <span class="qpc-hafs">﴿بل سولت لكم أنفسكم أمرا فصبر جميل﴾</span>{3}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿عَسَى ٱللَّهُ أَن یَأۡتِیَنِی بِهِمۡ جَمِیعًاۚ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٧٩٦٨<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- وفي قوله: <span class="qpc-hafs">﴿عسى الله أن يأتينى بهم جميعًا﴾</span> قال: بيوسف، وأخيه، وروبيل{4}<span class=comment-ref>٣٤٣٦</span>. (٨/٣٠١)</p></p><p></div></p><p><div><span class=comment-ref>٣٤٣٦</span> لم يذكر <u>ابنُ جرير</u> (١٣/٢٩٢) غير قول قتادة.</div></p><p><div></p><p><p><span class="item-no">٣٧٩٦٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿عسى الله أن يأتيني بهم جميعا﴾</span>، يعني: بنيه الأربعة{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٩٧٠<span class="dash">-</span></span> عن <span class="name-3">عبد الملك ابن جُرَيْج</span>، في قوله: <span class="qpc-hafs">﴿عسى الله أن يأتيني بهم جميعًا﴾</span>، قال: بيوسف، وأخيه، وكبيرهم الذي تَخَلَّف{6}. (٨/٣٠٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٩٧١<span class="dash">-</span></span> عن <span class="name-3">محمد بن إسحاق</span> -من طريق سلمة- في قوله: <span class="qpc-hafs">﴿عسى الله أن يأتيني بهم جميعًا﴾</span>، قال: أي: بيوسف، وأخيه، وروبيل{3}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿إِنَّهُۥ هُوَ ٱلۡعَلِیمُ ٱلۡحَكِیمُ ۝٨٣﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٧٩٧٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿إنه هو العليم﴾</span> بخَلْقه، <span class="qpc-hafs">﴿الحكيم﴾</span> يعني: الحاكم فيهم. ولم يُخْبِر اللهُ يعقوبَ بأمر يوسف؛ لِيَختبر صبرَه{2}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن أبي حاتم ٧/٢١٨٤.|2:تفسير مقاتل بن سليمان ٢/٣٤٨.|3:أخرجه ابن جرير ١٣/٢٩٢، وابن أبي حاتم ٧/٢١٨٤.|4:أخرجه ابن جرير ١٣/٢٩٢، وابن أبي حاتم ٧/٢١٨٤. وعزاه السيوطي إلى أبي الشيخ.|5:تفسير مقاتل بن سليمان ٢/٣٤٨.|6:عزاه السيوطي إلى ابن المنذر.|7:أخرجه ابن جرير ١٣/٢٩٢، وابن أبي حاتم ٧/٢١٨٤.|8:تفسير مقاتل بن سليمان ٢/٣٤٨.
  12,84,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَتَوَلَّىٰ عَنۡهُمۡ وَقَالَ یَـٰۤأَسَفَىٰ عَلَىٰ یُوسُفَ وَٱبۡیَضَّتۡ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٧٩٧٣<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق العوفي- في قوله: <span class="qpc-hafs">﴿يا أسفي على يوسف﴾</span>، قال: يا حَزَنا على يوسف{1}. (٨/٣٠٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٩٧٤<span class="dash">-</span></span> وعن <span class="name-2">الضحاك بن مزاحم</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٩٧٥<span class="dash">-</span></span> و<span class="name-2">قتادة بن دعامة</span>، مثل ذلك{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٩٧٦<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿يا أسفي على يوسف﴾</span>، قال: يا جزَعا{3}. (٨/٣٠٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٩٧٧<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- قوله: <span class="qpc-hafs">﴿يا أسفى﴾</span>: يا حَزَنا{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٩٧٨<span class="dash">-</span></span> عن <span class="name-2">الضحاك بن مزاحم</span> -من طريق جويبر-: <span class="qpc-hafs">﴿يا أسفى﴾</span> يا حَزَنا <span class="qpc-hafs">﴿على يوسف﴾</span>{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٩٧٩<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق مَعْمَر، وسعيد- في قوله: <span class="qpc-hafs">﴿يا أسفي على يوسف﴾</span>، قال: يا حَزَنا على يوسف{6}. (٨/٣٠٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٩٨٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وتولى عنهم﴾</span> يعني: وأعرض يعقوبُ عن بنيه، ثُمَّ أقبل على نفسه، <span class="qpc-hafs">﴿وقال يا أسفى﴾</span> يعني: يا حزناه <span class="qpc-hafs">﴿على يوسف﴾</span>{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٩٨١<span class="dash">-</span></span> عن <span class="name-3">محمد بن إسحاق</span> -من طريق سلمة- <span class="qpc-hafs">﴿وتولى عنهم﴾</span>: أعْرَضَ عنهم، وتَتامَّ حزنُه، وبلغ مجهوده، حين لحق بيوسف أخوه، وهُيِّج عليه حزنُه على يوسف، فقال: <span class="qpc-hafs">﴿يا أسفى على يوسف وابيضت عيناه من الحزن فهو كظيم﴾</span>{8}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَٱبۡیَضَّتۡ عَیۡنَاهُ مِنَ ٱلۡحُزۡنِ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٧٩٨٢<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق هشام- قال: كان مُنذُ خَرَجَ يوسفَ مِن عند يعقوب إلى يوم رجع ثمانون سنة، لم يُفارِق الحزنُ قلبَه، ودموعه تجرى على خدَّيْه، ولم يزل يبكى حتى ذهب بصرُه، واللهِ، ما على الأرض يومئذ خليقةٌ أكرمُ على الله مِن يعقوب ﵇{9}. (٨/٣٠٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٩٨٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وابيضت عيناه﴾</span> سِتَّ سنين لم يُبْصِر بهما <span class="qpc-hafs">﴿من الحزن﴾</span> على يوسف{10}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿فَهُوَ كَظِیمࣱ ۝٨٤﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٧٩٨٤<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، في قوله:<span class="qpc-hafs">﴿فهو كظيم﴾</span>، قال: حزين{11}. (٨/٣٠٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٩٨٥<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، في قوله: <span class="qpc-hafs">﴿فهو كظيم﴾</span>، قال: مَهْمُوم{12}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٩٨٦<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>: أنّ نافع بن الأزرق قال له: أخبِرني عن قوله: <span class="qpc-hafs">﴿فهو كظيم﴾</span>، ما الكظيم؟ قال: المغموم، قال فيه قيس بن زهير:</p><p>فإن أكُ كاظِمًا لِمصاب شاس فإني اليومَ منطلق لساني{13}. (٨/٣٠٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٩٨٧<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق جُوَيْبِر، عن الضَّحّاك بن مُزاحِم-: أنّ نافع بن الأزرق قال له: فأخبرني عن قول الله ﷿ <span class="qpc-hafs">﴿وهو كظيم﴾</span> [النحل:٥٨]، ما الكظيم؟ قال: الساكِت. قال: وهل كانت العرب تعرف ذلك ؟ قال: نعم، أما سمعت بقول زهير بن جذيمة العبسي:</p><p>فإن تكُ كاظِمًا بمصاب شاس فإنِّي اليومَ منطلق لساني{14}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٩٨٨<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نَجِيح- في قوله: <span class="qpc-hafs">﴿فهو كظيم﴾</span>، قال: كظيم الحزن{15}. (٨/٣٠٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٩٨٩<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- <span class="qpc-hafs">﴿فهو كظيم﴾</span>، قال: مَكْمُود{16}. (٨/٣٠٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٩٩٠<span class="dash">-</span></span> عن <span class="name-2">الضحاك بن مزاحم</span> -من طريق جُوَيْبِر- قال: الكظيم: الكَميِدُ{17}. (٨/٣٠٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٩٩١<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span>، في قوله: <span class="qpc-hafs">﴿كظيم﴾</span>، قال: مكروب{18}. (٨/٣٠٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٩٩٢<span class="dash">-</span></span> عن العَطّاف بن خالد المخزومي، عن رجل حدَّثه، عن <span class="name-2">الحسن البصري</span> أنّه كان يقرأ هذه الحروف: <span class="qpc-hafs">﴿وابيضت عيناه من الحزن فهو كظيم﴾</span>، قال: النَّصَب{19}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٩٩٣<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد، ومَعْمَر- في قوله: <span class="qpc-hafs">﴿فهو كظيم﴾</span>، قال: كظم على الحزن، فلم يقل إلا خيرًا. وفي لفظ: يُرَدِّدُ حزنه في جوفِه، ولم يتكلم بسوء{20}. (٨/٣٠٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٩٩٤<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- قال: <span class="qpc-hafs">﴿فهو كظيم﴾</span> مِن الغيظ{21}. (٨/١٩٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٩٩٥<span class="dash">-</span></span> عن <span class="name-2">عطاء الخراساني</span> -من طريق يزيد بن زُرَيع- في قوله: <span class="qpc-hafs">﴿فهو كظيم﴾</span>، قال: فهو مكروب{22}. (٨/٣٠٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٩٩٦<span class="dash">-</span></span> عن <span class="name-2">عطاء الخراساني</span>، في قوله: <span class="qpc-hafs">﴿فهو كظيم﴾</span>، قال: حَزِين{12}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٩٩٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فهو كظيم﴾</span>، يعني: مكروب، يَتَرَدَّد الحزنُ فِي قلبه{10}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٩٩٨<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- قال: الكظيم: الذي لا يتكلم. بَلَغَ به الحزنُ حتى كان لا يُكَلِّمُهم{25}<span class=comment-ref>٣٤٣٧</span>. (٨/٣٠٥)</p></p><p></div></p><p><div><span class=comment-ref>٣٤٣٧</span> ذكر <u>ابنُ عطية</u> (٥/١٣٤) في قوله: <span class="qpc-hafs">﴿كظيم﴾</span> احتمالين: <b>الأول</b>: أن يكون بمعنى: كاظم، كقوله: <span class="qpc-hafs">﴿والكاظمين الغيظ﴾</span> [آل عمران:١٣٤]. و<span class="comment-type-4">علّق</span> عليه قائلًا: «ووصف يعقوب بذلك لأنّه لم يَشْكُ إلى أحد، وإنما كان يكمد في نفسه، ويُمْسِك هَمَّه في صدره، وكان يكظمه -أي: يرده- إلى قلبه، ولا يرسله بالشكوى والغضب والضجر». <b>الثاني</b>: أن يكون بمعنى: مكظوم. و<span class="comment-type-4">علّق</span> عليه قائلًا: «وقد <span class="mustanad">وصف الله تعالى</span> يونس ﵇ بمكظوم في قوله: <span class="qpc-hafs">﴿إذ نادى وهو مكظوم﴾</span> [القلم:٤٨]، وهذا إنّما يَتَّجه على تقدير أنّه مليء بحزنه، فكأنّه كظم بثه في صدره».</p><p>ثم <span class="comment-type-3">رجّح</span> الأول بقوله: "وجَرْيُ كظيم على باب كاظم أبين». ولم يذكر مستندًا.</p><p>ثم ذكر قول مَن قال من السلف معناه: مكروب. ومَن قال: معناه: مكمود. و<span class="comment-type-4">علّق</span> بقوله: «وذلك كله متقارب».</div></p><p><h3><span class="qpc-hafs">﴿فَهُوَ كَظِیمࣱ ۝٨٤﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٣٧٩٩٩<span class="dash">-</span></span> عن الأحنف بن قيس، أنّ النبيَّ ﷺ قال: «<b>إنّ داود قال: يا ربِّ، إنّ بني إسرائيل يسألونك بإبراهيم وإسحاق ويعقوب، فاجعلني لهم رابعًا. فأوحى الله إليه: إنّ إبراهيم أُلقِىَ في النار بسببِي فصبر، وتلك بَلِيَّةٌ لم تَنَلْكَ، وإنّ إسحاق بذل مُهْجَةَ دمِه في سببِي فصبر، وتلك بَلِيَّةٌ لم تَنَلْكَ، وإنّ يعقوب أخذتُ منه حبيبَه حتى ابيضَّتْ عيناه مِن الحزن فصبر، وتلك بَلِيَّةٌ لم تَنَلْكَ</b>»{26}. (٨/٣٠٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٨٠٠٠<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span> -من طريق سفيان العُصْفُري- قال: لم يُعطَ أحدٌ الاسترجاعَ غير هذه الأمة، ولو أُعطِيَها أحدٌ لأعطِيَها يعقوب، ألا تستمعون إلى قوله: <span class="qpc-hafs">﴿يا أسفي على يوسف﴾</span>{27}<span class=comment-ref>٣٤٣٨</span>. (٨/٣٠٣)</p></p><p></div></p><p><div><span class=comment-ref>٣٤٣٨</span> ذكر <u>ابنُ عطية</u> (٨/١٣٤) نحو ما جاء في هذا القول، ثم <span class="comment-type-4">علّق</span> قائلًا: «ولا يبعد أن يجتمع الاسترجاع ويا أسَفى لهذه الأمة وليعقوب ﵇».</div></p><p><div></p><p><p><span class="item-no">٣٨٠٠١<span class="dash">-</span></span> عن يونس، قال: لَمّا مات سعيدُ بن الحسن حَزِن عليه <span class="name-2">الحسن [البصري]</span> حُزنًا شديدًا، فكُلِّم الحسن في ذلك، فقال: ما سمعتُ اللهَ عاب على يعقوب ﵇ الحزن{28}. (٨/٣٠٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٨٠٠٢<span class="dash">-</span></span> عن <span class="name-2">أبي رَوْق عطية بن الحارث الهمداني</span> -من طريق أبي زهير، عن بعض أصحابه-قال: لَمّا احتَبَس يوسف ﵇ أخاه بسبب السرقة كَتَبَ إليه يعقوبُ ﵇: مِن يعقوب بن إسحاق بن إبراهيم خليل الله إلى يوسف عزيز فرعون، أمّا بعد، فإنّا أهلُ بيت مُوَكَّلٌ بنا البلاء؛ إنّ أبي إبراهيم ﵇ أُلقِيَ في النار في الله فصبر، فجعلها الله عليه بردًا وسلامًا، وإن أبي إسحاق ﵇ قُرِّب للذبح في الله فصبر، ففداه الله بذِبْحٍ عظيم، وإنّ الله كان وهَبَ لي قُرَّة عين فسَلَبَنِيه، فأذهب حزنُه بصري، وأيبس لحمي على عظمي، فلا ليلي ليل، ولا نهاري نهار، والأسير الذي في يديك بما ادُّعي عليه من السَّرَقِ أخوه لأمه، فكنت إذا ذَكَرْتُ أسفي عليه قرَّبته مِنِّي، فسلّى عنِّي بعض ما كنتُ أجِدُ، وقد بلغني أنّك حبستَه بسبب سرقة، فخلِّ سبيلَه، فإنِّي لم ألِد سارقًا، وليس بسارق، والسلام{29}. (٨/٣٠٢)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ١٣/٢٩٣-٢٩٤، وابن أبي حاتم ٧/٢١٨٥. وعزاه السيوطي إلى ابن المنذر.|2:علَّقه ابن أبي حاتم ٧/٢١٨٥.|3:أخرجه ابن جرير ١٣/٢٩٤، وابن أبي حاتم ٧/٢١٨٥. وعزاه السيوطي إلى ابن أبي شيبة، وابن المنذر، وأبي الشيخ.|4:أخرجه ابن جرير ١٣/٢٩٤.|5:أخرجه ابن جرير ١٣/٢٩٥.|6:أخرجه ابن جرير ١٣/٢٩٤. وعزاه السيوطي إلى ابن أبى شيبة، وابن المنذر.|7:تفسير مقاتل بن سليمان ٢/٣٤٨.|8:أخرجه ابن جرير ١٣/٢٩٣، وابن أبي حاتم ٧/٢١٨٤-٢١٨٥.|9:أخرجه عبد الله بن أحمد في زوائد الزهد ص٨٤، وابن جرير ١٣/٣١٣، ٣٥٩. وعزاه السيوطي إلى أبي الشيخ.|10:تفسير مقاتل بن سليمان ٢/٣٤٨. وبنحوه في تفسير الثعلبي ٥/٢٤٧ منسوبًا إلى مقاتل دون تعيينه.|11:أخرجه ابن جرير ١٤/٢٥٦.|12:تفسير الثعلبي ٥/٢٤٧.|13:عزاه السيوطي إلى ابن الأنباري في الوقف.|14:أخرجه الطبراني في المعجم الكبير (١٠/٢٤٨-٢٥٦) رقم (١٠٥٩٧) مطولا.|15:أخرجه ابن جرير ١٣/٢٩٦، وابن أبي حاتم ٧/٢١٨٧. وعزاه السيوطي إلى ابن المنذر، وأبي الشيخ.|16:أخرجه ابن جرير ١٣/٢٩٦.|17:أخرجه ابن جرير ١٣/٢٩٧، وابن أبي حاتم ٧/٢١٨٧. وعزاه السيوطي إلى ابن المنذر، وأبي الشيخ.|18:عزاه السيوطي إلى ابن أبي حاتم.|19:أخرجه ابن وهب في الجامع ٣/٤٥ (٨٨).|20:أخرجه ابن المبارك (٤٦٨)، وعبد الرزاق ١/٣٢٧، وابن جرير ١٣/٢٩٧، وابن أبي حاتم ٧/٢١٨٧. كما أخرجه ابن أبي الدنيا في كتاب الهم والحزن -موسوعة الإمام ابن أبي الدنيا ٣/٢٧٨ (٨٩)- من طريق همام. وعزاه السيوطي إلى ابن المنذر، وأبي الشيخ.|21:أخرجه ابن جرير ١٣/٢٩٧. وعلَّقه ابن أبي حاتم ٧/٢١٨٧ بلفظ: الحزن.|22:أخرجه ابن جرير ١٣/٢٩٧. وعزاه السيوطي إلى ابن المنذر.|23:تفسير الثعلبي ٥/٢٤٧.|24:تفسير مقاتل بن سليمان ٢/٣٤٨. وبنحوه في تفسير الثعلبي ٥/٢٤٧ منسوبًا إلى مقاتل دون تعيينه.|25:أخرجه ابن جرير ١٣/٢٩٨. وعزاه السيوطي إلى أبي الشيخ.|26:أخرجه ابن أبي حاتم ٧/٢١٨٦.</p><p>ذكر ابنُ كثير ٨/٦٤ هذا الأثر مِن طريق ابن أبي حاتم، وفي إسناده علي بن زيد بن جدعان، ثم قال: «وهذا مرسل، وفيه نكارة؛ فإنّ الصحيح أنّ إسماعيل هو الذبيح، ولكن علي بن زيد بن جدعان له مناكير وغرائب كثيرة، والله أعلم. وأقرب ما في هذا أن يكون قد حكاه الأحنف بن قيس ﵀ عن بني إسرائيل ككعب ووهب ونحوهما».|27:أخرجه عبد الرزاق ١/٣٢٧، وابن جرير ٢/٧٠٨، ١٣/٢٩٥، وابن أبي حاتم ٧/٢١٨٥. وعزاه السيوطي إلى ابن المنذر.|28:أخرجه ابن سعد ٧/١٨٧، وابن أبي شيبة ١٣/٩٠، ٥٠٣. وعزاه السيوطي إلى أبي عبيد، وابن المنذر.|29:أخرجه ابن أبي حاتم ٧/٢١٨٥.
  12,85,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿قَالُوا۟ تَٱللَّهِ تَفۡتَؤُا۟ تَذۡكُرُ یُوسُفَ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٨٠٠٣<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عكرمة- في قوله: <span class="qpc-hafs">﴿تالله تفتؤا تذكر يوسف﴾</span>، قال: لا تزال تذكر يوسف{1}. (٨/٣٠٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٨٠٠٤<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>: أنّ نافع بن الأزرق قال له: أخبِرني عن قوله: <span class="qpc-hafs">﴿تفتؤا تذكر يوسف﴾</span>. قال: لا تزال تذكر يوسف. قال: وهل تعرف العرب ذلك؟ قال: نعم، أما سمعت الشاعرَ وهو يقول:</p><p>لعمرك لا تفتأ تذكر خالدًا وقد غاله ما غال تُبَّعَ مِن قبلُ{2}. (٨/٣٠٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٨٠٠٥<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نَجِيح- في قوله: <span class="qpc-hafs">﴿قالوا تالله تفتؤا تذكر يوسف﴾</span>، قال: لا تَفْتُرُ مِن حُبِّ يوسف، لا تزال تذكر يوسف{3}<span class=comment-ref>٣٤٣٩</span>. (٨/٣٠٨)</p></p><p></div></p><p><div><span class=comment-ref>٣٤٣٩</span> ذكر <u>ابنُ جرير</u> (١٣/٢٩٨) قول مجاهد من طريق الحسن بن محمد، عن شبابة، عن ورقاء، عن ابن أبي نجيح، عن مجاهد في قوله: <span class="qpc-hafs">﴿تفتأ﴾</span>: ما تفتر مِن حُبِّه، ثم <span class="comment-type-4">علّق</span> قائلًا: «كذا قال الحسن في حديثه، وهو غلط، إنما هو: تفتر من حبه، تزال تذكر يوسف».</div></p><p><div></p><p><p><span class="item-no">٣٨٠٠٦<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد، ومَعْمَر- في قوله: <span class="qpc-hafs">﴿تفتؤا تذكر يوسف﴾</span>، قال: لا تزال تذكر يوسف{4}. (٨/٣٠٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٨٠٠٧<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- قال: <span class="qpc-hafs">﴿قالوا تالله تفتؤا تذكر يوسف﴾</span>، قال: لا تزال تذكر يوسف{5}. (٨/١٩٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٨٠٠٨<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿قالوا﴾</span> أي: قال بنوه يُعَيِّرونه: <span class="qpc-hafs">﴿تالله تفتؤا﴾</span> يعني: واللهِ، ما تزال تذكر <span class="qpc-hafs">﴿يوسف﴾</span>{6}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿حَتَّىٰ تَكُونَ حَرَضًا﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٨٠٠٩<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عكرمة- في قوله: <span class="qpc-hafs">﴿حتى تكون حرضًا﴾</span>، قال: دَنِفًا{7} مِن المرض{8}. (٨/٣٠٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٨٠١٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق العوفي- قوله: <span class="qpc-hafs">﴿حتى تكون حرضا﴾</span>، يعني: الجَهْدَ في المرض البالي{9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٨٠١١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>: أنّ نافع بن الأزرق قال له: أخبِرني عن قوله: <span class="qpc-hafs">﴿حتى تكون حرضًا﴾</span>. قال: الحَرَضُ: المُدْنَفُ الهالك مِن شِدَّة الوَجَع. قال: وهل تعرف العرب ذلك؟ قال: نعم، أما سمعت الشاعر وهو يقول:</p><p>أمِن ذِكْرِ ليلى إن نَأَت غرْبَةٌ بها كأنك حَمٌّ للأطباء مُحْرَضُ{10}. (٨/٣١٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٨٠١٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق جُوَيْبِر، عن الضَّحّاك بن مُزاحِم- أنّ نافع بن الأزرق قال له: فأخبِرني عن قول الله ﷿: <span class="qpc-hafs">﴿حتى تكون حرضا﴾</span>. قال: الحرض: البالي. قال: وهل كانت العرب تعرف ذلك قبل أن ينزل الكتابُ على محمد ﷺ؟ قال: نعم، أما سمعت قول طرفة بن العبد:</p><p>أمِن ذِكْرِ ليلى إن نأت غرْبَةٌ بها أعد حريضًا للكرا محرم{11}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٨٠١٣<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ليث- في قوله: <span class="qpc-hafs">﴿حتى تكون حرضًا﴾</span>، قال: الحرض: ما دُون الموت{12}. (٨/٣٠٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٨٠١٤<span class="dash">-</span></span> عن <span class="name-2">الضحاك بن مُزاحِم</span> -من طريق جويبر- <span class="qpc-hafs">﴿حتى تكون حرضًا﴾</span>، قال: الحرض: الشيء البالي{13}. (٨/٣٠٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٨٠١٥<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق أبي بكر الهذلي- <span class="qpc-hafs">﴿حرضا﴾</span>، قال: هَرِمًا{14}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٨٠١٦<span class="dash">-</span></span> قال <span class="name-2">الحسن البصري</span>: كالشَّيء{15} المدقوق المكسور{16}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٨٠١٧<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق مَعْمَر- وفي قوله: <span class="qpc-hafs">﴿حتى تكون حرضًا﴾</span>، قال: هَرِمًا{17}. (٨/٣٠٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٨٠١٨<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السدي</span> -من طريق أسباط- قال: <span class="qpc-hafs">﴿حتى تكون حرضًا﴾</span>: باليًا{14}. (٨/١٩٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٨٠١٩<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السدي</span> -من طريق شعبة- قال: <span class="qpc-hafs">﴿حتى تكون حرضًا﴾</span>: حتى تكاد أن تموت{19}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٨٠٢٠<span class="dash">-</span></span> قال <span class="name-2">الربيع بن أنس</span>: يابِس الجِلْد على العَظْم{16}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٨٠٢١<span class="dash">-</span></span> عن <span class="name-3">أبي صَخْر [حميد بن زياد الخرّاط]</span> -من طريق مفضل- في قوله: <span class="qpc-hafs">﴿حرضا﴾</span>، قال: أمّا الحَرَض فيقولون: لا يَعْقِل، ولا يُنتَفَع به{19}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٨٠٢٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿حتى تكون حرضا﴾</span>، يعني: الدَّنِف{22}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٨٠٢٣<span class="dash">-</span></span> عن <span class="name-3">محمد بن إسحاق</span> -من طريق سلمة- قال: لَمّا ذكر يعقوبُ يوسفَ <span class="qpc-hafs">﴿قالوا﴾</span> يعني: ولده الذين حضروه في ذلك الوقت، جهلًا وظُلْمًا: <span class="qpc-hafs">﴿تالله تفتأ تذكر يوسف حتى تكون حرضا﴾</span> أي: تكون فاسدًا، لا عَقْلَ لك، <span class="qpc-hafs">﴿أو تكون من الهالكين﴾</span>{23}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٨٠٢٤<span class="dash">-</span></span> عن <span class="name-3">سفيان الثوري</span>، في قوله: <span class="qpc-hafs">﴿حتى تكون حرضا﴾</span>، قال: تَبْلى{24}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٨٠٢٥<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿حتى تكون حرضا أو تكون من الهالكين﴾</span>، قال: الحرض: الذي قد رُدَّ إلى أرْذَل العمر، حتى لا يعقل، أو تهلِكَ فتكونَ هالكًا قبلَ ذلك{25}<span class=comment-ref>٣٤٤٠</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٣٤٤٠</span> <span class="comment-type-4">بيّن</span> <u>ابنُ عطية</u> (٥/١٣٦-١٣٧بتصرف) أنّ <span class="qpc-hafs">﴿حرضا﴾</span> معناه: «الذي قد نهكه الهرم، أو الحب، أو الحزن إلى حال فساد الأعضاء والبدن والحس». وذكر أنّ ذلك يوافق قراءة الجمهور <span class="qpc-hafs">﴿حرضا﴾</span> بفتح الراء والحاء، ثم ذكر عدة قراءات أخرى، و<span class="comment-type-4">علّق</span> عليها، فقال: «وقرأ الحسن بن أبي الحسن بضمهما، وقرأت فرقة: (حُرْضًا) بضم الحاء وسكون الراء. وهذا كله المصدر يوصف به المذكر والمؤنث والمفرد والجمع بلفظ واحد، كعدل وعدو، وقيل في قراءة الحسن: إنه يراد: فتات الأشنان، أي: باليًا متعتتًا، ويقال مِن هذا المعنى الذي هو شن الهم والهرم: رجل حارض». ثم قال: «والحرض بالجملة: الذي فسد ودنا موتُه». وذكر آثار السلف في هذا المعنى، ثم <span class="comment-type-4">علّق</span> قائلًا: «فكأنهم قالوا على جهة التعنيف له: أنت لا تزال تذكر يوسف إلى حال القرب مِن الهلاك، أو إلى الهلاك».</div></p><p><h3><span class="qpc-hafs">﴿أَوۡ تَكُونَ مِنَ ٱلۡهَـٰلِكِینَ ۝٨٥﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٨٠٢٦<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عكرمة- في قوله: <span class="qpc-hafs">﴿أو تكون من الهالكين﴾</span>، قال: المَيِّتين{26}. (٨/٣٠٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٨٠٢٧<span class="dash">-</span></span> عن <span class="name-2">الربيع بن أنس</span>، مثل ذلك{27}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٨٠٢٨<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ليث- في قوله: <span class="qpc-hafs">﴿أو تكون من الهالكين﴾</span>، قال: الموت{28}. (٨/٣٠٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٨٠٢٩<span class="dash">-</span></span> عن <span class="name-2">الضَّحّاك بن مُزاحِم</span> -من طريق جُوَيْبِر- <span class="qpc-hafs">﴿أو تكون من الهالكين﴾</span>، قال: المَيِّتين{29}. (٨/٣٠٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٨٠٣٠<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق أبي بكر الهذلي- <span class="qpc-hafs">﴿أو تكون من الهالكين﴾</span>، قال: المَيِّتين{30}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٨٠٣١<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿أو تكون من الهالكين﴾</span>، قال: أو تموت{31}. (٨/٣٠٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٨٠٣٢<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- قال: <span class="qpc-hafs">﴿أو تكون من الهالكين﴾</span>: المَيِّتين{32}. (٨/١٩٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٨٠٣٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿أو تكون من الهالكين﴾</span>، يعني: الميتين{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٨٠٣٤<span class="dash">-</span></span> عن <span class="name-3">سفيان الثوري</span>، في قوله: <span class="qpc-hafs">﴿أو تكون من الهالكين﴾</span>، قال: الموت. يقول ذلك بعضُ ولدِ ولدِه{24}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ١٣/٢٩٩، ٣٠١، وزاد: قال: لا تفتر من حُبِّه، وابن أبي حاتم ٧/٢١٨٧-٢١٨٨. وعزاه السيوطي إلى ابن أبي شيبة، وابن المنذر، وأبي الشيخ.|2:أخرجه في مسائل نافع ص٥٢، والطستي -كما في الإتقان ٢/٨٥-. وعزاه السيوطي إلى ابن الأنباري، والطستي.|3:تفسير مجاهد ص٤٠٠، وأخرجه ابن جرير ١٣/٢٩٩، ٣٠٢، ٣٠٤، وابن أبي حاتم ٧/٢١٨٧-٢١٨٨. وعزاه السيوطي إلى ابن أبي شيبة، وابن المنذر.|4:أخرجه عبد الرزاق ١/٣٢٧، وابن جرير ١٣/٢٩٩، ٣٠٢، ٣٠٥. وعزاه السيوطي إلى ابن المنذر، وأبي الشيخ.|5:أخرجه ابن أبي حاتم ٧/٢١٨٧. وعزاه السيوطي إلى ابن جرير.|6:تفسير مقاتل بن سليمان ٢/٣٤٨.|7:رجل دَنَفٌ ودَنِفٌ ومُدْنِفٌ ومُدْنَفٌ: بَراهُ المرض حتى أشفى على الموت. لسان العرب (دنف).|8:أخرجه ابن أبي حاتم ٧/٢١٨٧. وعزاه السيوطي إلى ابن أبي شيبة، وابن المنذر، وابن جرير، وأبي الشيخ.|9:أخرجه ابن جرير ١٣/٣٠١.|10:أخرجه في مسائل نافع ص٥٢. وعزاه السيوطي إلى ابن الأنباري، والطستي.|11:أخرجه الطبراني في المعجم الكبير مطولًا ١٠/٢٤٨-٢٥٦ (١٠٥٩٧).|12:أخرجه ابن جرير ١٣/٢٩٩، ٣٠٢، ٣٠٤، وابن أبي حاتم ٧/٢١٨٧-٢١٨٨. وعزاه السيوطي إلى ابن أبي شيبة، وابن المنذر.|13:أخرجه ابن جرير ١٣/٣٠٣، وابن أبي حاتم ٧/٢١٨٨. وعزاه السيوطي إلى ابن أبي شيبة، وابن المنذر، وأبي الشيخ.|14:أخرجه ابن جرير ١٣/٣٠٣.|15:الشن: وعاء من أدم. النهاية (طبق).|16:تفسير الثعلبي ٥/٢٤٨.|17:أخرجه عبد الرزاق ١/٣٢٧، وابن جرير ١٣/٣٠٢-٣٠٣ ومن طريق سعيد بلفظ: حتى تبلى أو تهرم. وعزاه السيوطي إلى ابن المنذر، وأبي الشيخ.|18:أخرجه ابن جرير ١٣/٣٠٣.|19:أخرجه ابن أبي حاتم ٧/٢١٨٨.|20:تفسير الثعلبي ٥/٢٤٨.|21:أخرجه ابن أبي حاتم ٧/٢١٨٨.|22:تفسير مقاتل بن سليمان ٢/٣٤٨. وبنحوه في تفسير الثعلبي ٥/٢٤٨ منسوبًا إلى مقاتل دون تعيينه.|23:أخرجه ابن جرير ١٣/٣٠٣، وابن أبي حاتم ٧/٢١٨٥، ٢١٨٨.|24:تفسير الثوري ص١٤٦.|25:أخرجه ابن جرير ١٣/٣٠٤.|26:أخرجه ابن جرير ١٣/٢٩٩، ٣٠١، وابن أبي حاتم ٧/٢١٨٧-٢١٨٨. وعزاه السيوطي إلى ابن أبي شيبة، وابن المنذر، وأبي الشيخ.|27:علَّقه ابن أبي حاتم ٧/٢١٨٨.|28:أخرجه ابن جرير ١٣/٢٩٩، ٣٠٢، ٣٠٤. وعلَّقه ابن أبي حاتم ٧/٢١٨٧-٢١٨٨. وعزاه السيوطي إلى ابن أبي شيبة، وابن المنذر.|29:أخرجه ابن جرير ١٣/٣٠٣. وعلَّقه ابن أبي حاتم ٧/٢١٨٨. وعزاه السيوطي إلى ابن أبي شيبة، وابن المنذر، وأبي الشيخ.|30:أخرجه ابن جرير ١٣/٣٠٥. وعلَّقه ابن أبي حاتم ٧/٢١٨٨.|31:أخرجه عبد الرزاق ١/٣٢٧، وابن جرير ١٣/٢٩٩، ٣٠٢، ٣٠٥. وعلَّقه ابن أبي حاتم ٧/٢١٨٨. وعزاه السيوطي إلى ابن المنذر، وأبي الشيخ.|32:أخرجه ابن جرير ١٣/٣٠٥، وابن أبي حاتم ٧/٢١٨٨.|33:تفسير مقاتل بن سليمان ٢/٣٤٨.|34:تفسير الثوري ص١٤٦.
  12,86,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿قَالَ إِنَّمَاۤ أَشۡكُوا۟ بَثِّی وَحُزۡنِیۤ إِلَى ٱللَّهِ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٨٠٣٥<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق ابن جريج- في قوله: <span class="qpc-hafs">﴿إنما أشكو بثي﴾</span>، قال: هَمِّي{1}. (٨/٣١٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٨٠٣٦<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق عوف- في قوله: <span class="qpc-hafs">﴿أشكو بثي﴾</span> قال: حاجتي <span class="qpc-hafs">﴿وحزني إلى الله﴾</span>{2}. (٨/٣١٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٨٠٣٧<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد بن بشير- قوله: <span class="qpc-hafs">﴿إنما أشكوا بثي وحزني إلى الله﴾</span>، قال: ذُكِرَ لنا: أنّ نبي الله يعقوب ﵇ لم يَزَل به شِدَّةُ بلاءٍ قطُّ إلا أتاهُ حُسْنُ ظنِّه بالله مِن وراء بلائه{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٨٠٣٨<span class="dash">-</span></span> عن <span class="name-2">طلحة بن مُصَرِّف الأيامى</span> -من طريق المبارك بن مجاهد، عن رجل مِن الأَزْد- قال: ثلاثةُ لا تذكُرهن، واجتنب ذِكرَهُنَّ: لا تَشْكُ مرضَك، ولا تشكُ مصيبتَك، ولا تُزَكِّ نفسَك. قال: وأُنبِئْتُ: أنّ يعقوب ﵇ دخل عليه جارٌ له، فقال: يا يعقوب، ما لي أراك قد انْهَشَمَتْ وفَنِيتَ ولم تبلغ مِن السِنِّ ما بلغ أبوك؟ قال: هشمني وأفناني ما ابتلاني الله به مِن هَمِّ يوسف وذِكْرِه. فأوحى الله إليه: يا يعقوب، أتشكوني إلى خلقي؟ فقال: يا ربِّ، خطيئةٌ أخطأتُها فاغفِرْها لي. قال: فإنِّي قد غفرت لكَ. فكان بعد ذلك إذا سُئِل قال: <span class="qpc-hafs">﴿إنما أشكو بثي وحزني إلى الله﴾</span>{4}. (٨/٣١٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٨٠٣٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿قال﴾</span> لهم أبوهم: <span class="qpc-hafs">﴿إنما أشكوا بثي﴾</span> يعني: ما بَثَّه فِيَّ الناسُ <span class="qpc-hafs">﴿وحزني﴾</span> يعني: ما بَطَن <span class="qpc-hafs">﴿إلى الله﴾</span>{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٨٠٤٠<span class="dash">-</span></span> عن <span class="name-3">محمد بن إسحاق</span> -من طريق سلمة- قال: قال يعقوب عن عِلْمٍ بالله: <span class="qpc-hafs">﴿إنما أشكو بثي وحزني إلى الله وأعلم من الله ما لا تعلمون﴾</span>؛ لِما رأى مِن فظاظتِهم وغِلْظَتِهم وسوء لفظهم به: لم أشْكُ ذلك إليكم، <span class="qpc-hafs">﴿وأعلم من الله ما لا تعلمون﴾</span>{6}<span class=comment-ref>٣٤٤١</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٣٤٤١</span> لم يذكر <u>ابنُ جرير</u> (١٣/٣٠٦) غير قول ابن إسحاق، والحسن، وابن عباس.</div></p><p><div></p><p><p><span class="item-no">٣٨٠٤١<span class="dash">-</span></span> قال <span class="name-3">سفيان الثوري</span>، في قوله: <span class="qpc-hafs">﴿إنما أشكوا بثي﴾</span>، قال: هَمِّي{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٨٠٤٢<span class="dash">-</span></span> عن <span class="name-3">النضر بن عربي</span>، قال: بلغني: أنّ يعقوب ﵇ لَمّا طال حُزْنُه على يوسف ذهبت عيناه مِن الحزن، فجعل العُوّادُ يدخلون عليه، فيقولون: السلام عليك، يا نبيَّ الله، كيف تَجِدُك؟ فيقول: شيخ كبير قد ذهب بصري. فأوحى الله إليه: يا يعقوب، شكوتنى إلى عُوّادك؟! قال: أيْ ربِّ، هذا ذنبٌ عَمِلْتُه لا أعود إليه. فلم يزل بعد يقول: <span class="qpc-hafs">﴿إنما أشكو بثى وحزنى إلى الله﴾</span>{8}. (٨/٣١٣)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَأَعۡلَمُ مِنَ ٱللَّهِ مَا لَا تَعۡلَمُونَ ۝٨٦﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٨٠٤٣<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق العوفي- في قوله: <span class="qpc-hafs">﴿وأعلم من الله ما لا تعلمون﴾</span>، يقول: أعلم أنّ رؤيا يوسف صادقة، وأنِّي سأسْجُدُ له{9}<span class=comment-ref>٣٤٤٢</span>. (٨/٣١٤)</p></p><p></div></p><p><div><span class=comment-ref>٣٤٤٢</span> لم يذكر <u>ابنُ جرير</u> (١٣/٣٠٧) غير قول ابن عباس.</div></p><p><div></p><p><p><span class="item-no">٣٨٠٤٤<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- <span class="qpc-hafs">﴿قال إنما أشكو بثي وحزني إلى الله وأعلم من الله ما لا تعلمون﴾</span>، قال: فلمّا أخبروه بدعاء الملِك أحَسَّت نفسُ يعقوب، وقال: ما يكون في الأرض صِدِّيقٌ إلا نَبِيٌّ. فطَمِع، وقال: لعلَّه يوسف{10}. (٨/١٩٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٨٠٤٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وأعلم من الله﴾</span> يعني: مِن تحقيق رؤيا يوسف أنّه كائن <span class="qpc-hafs">﴿ما لا تعلمون﴾</span>{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٨٠٤٦<span class="dash">-</span></span> قال <span class="name-3">سفيان الثوري</span>، في قوله: <span class="qpc-hafs">﴿وأعلم من الله ما لا تعلمون﴾</span>، قال: أعلم سيجعلون أنبياء -صلى الله عليهم-{12}<span class=comment-ref>٣٤٤٣</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٣٤٤٣</span> <span class="comment-type-4">ذكر</span> <u>ابنُ عطية</u> (٨/١٣٨) في معنى الآية احتمالين، فقال: «وقوله: <span class="qpc-hafs">﴿أعْلَمُ مِنَ اللَّهِ ما لا تَعْلَمُونَ﴾</span> يحتمل أنّه أشار إلى حُسن ظنه بالله وجميل عادة الله عنده، ويحتمل أنّه أشار إلى الرؤيا المنتظرة، أو إلى ما وقع في نفسه عن قول ملك مصر: إني أدعو له برؤية ابنه قبل الموت. وهذا هو حُسْنُ الظَّنِّ».</div></p><p><h3><span class="qpc-hafs">﴿وَأَعۡلَمُ مِنَ ٱللَّهِ مَا لَا تَعۡلَمُونَ ۝٨٦﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٣٨٠٤٧<span class="dash">-</span></span> عن عبد الله بن عمرو، عن النبي ﷺ، قال: «<b>مَن بَثَّ لم يصبِر</b>». ثم قرأ: <span class="qpc-hafs">﴿إنما أشكوا بثى وحزنى إلى الله﴾</span>{13}. (٨/٣١١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٨٠٤٨<span class="dash">-</span></span> عن مسلم بن يَسار، عن سعد بن مسعود، قال: قال رسول الله ﷺ: «<b>مَن بَثَّ فلم يصبِر</b>». ثم قرأ: <span class="qpc-hafs">﴿إنما أشكوا بثي وحزني إلى الله﴾</span>{14}. (٨/٣١١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٨٠٤٩<span class="dash">-</span></span> عن مسلم بن يسار، يرفعه إلى النبي ﷺ، قال: «<b>مَن بَثَّ لم يصبِر</b>». ثم قرأ: <span class="qpc-hafs">﴿إنما أشكو بثى وحزنى إلى الله﴾</span>{15}. (٨/٣١١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٨٠٥٠<span class="dash">-</span></span> عن عبد الرحمن بن يَعْمَرَ، قال: قال رسول الله ﷺ: «<b>مَن بَثَّ لم يصبر</b>». ثم قرأ: <span class="qpc-hafs">﴿إنما أشكوا بثى وحزنى إلى الله﴾</span>{16}. (٨/٣١١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٨٠٥١<span class="dash">-</span></span> عن عبد الله بن عمر، قال: قال رسول الله ﷺ: «<b>مِن كنوز البِرِّ: إخفاء الصَّدَقة، وكتمان المصائب والأمراض، ومَن بَثَّ لم يصبِر</b>»{17}. (٨/٣١١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٨٠٥٢<span class="dash">-</span></span> عن أنس بن مالك، قال: قال رسول الله ﷺ: «<b>مَن أصبح حزينًا على الدنيا أصبح ساخِطًا على ربِّه، ومَن أصبح يشكو مصيبةً نَزَلَتْ به فإنّما يشكو الله، ومَن تضعضع لغَنِيٍّ لِينال مِن دنُياه أحبط اللهُ ثُلُثَي عمله، ومَن أُعْطِي القرآن فدخل النار فأبعده الله</b>»{18}. (٨/٣١٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٨٠٥٣<span class="dash">-</span></span> عن عبد الله بن مسعود، مثله مرفوعًا{19}. (٨/٣١٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٨٠٥٤<span class="dash">-</span></span> عن أنس بن مالك، قال: قال رسول الله ﷺ: «كان ليعقوب ﵇ أخٌ مُؤاخٍ، فقال له ذات يوم: يا يعقوب، ما الذي أذهب بصرَك؟ وما الذي قَوَّس ظهرَك؟ قال: أمّا الذي أذهب بصري فالبكاء على يوسف، وأَمّا الذي قَوَّس ظهري فالحزن على بنيامين. فأتاه جبريل ﵇، فقال: يا يعقوب، إنّ الله ﷿ يُقرِئُك السلام، ويقول لك: أما تستحي؛ تشكوني إلى غيري؟! قال يعقوب ﵇: <span class="qpc-hafs">﴿إنما أشكو بثى وحزنى إلى الله﴾</span>. فقال جبريل ﵇: اللهُ أعلمُ بما تشكو، يا يعقوب. ثم قال يعقوب: أما ترحم الشيخَ الكبيرَ؟ أذهبتَ بصري، وقوَّست ظهري، فأردُد عَلَيَّ رَيْحانَتِي، أشمه شمَّة قبل الموت، ثم اصنع بي ما أردتَ. فأتاه جبريل ﵇، فقال: يا يعقوب، إنّ الله يُقْرِئُك السلامَ، ويقول لك: أبْشِرْ، وليفرح قلبُك، فوَعِزَّتي، لو كانا مَيِّتَيْنِ لَنَشَرْتُهُما لكَ، فاصنع طعامًا للمساكين، فإنّ أحَبَّ عبادي إلَيَّ الأنبياءُ والمساكين، وتدري لِمَ أذهبتُ بصرَك، وقوَّستُ ظهرَك، وصنع إخوةُ يوسف به ما صنعوا؟ إنّكم ذبحتم شاةً، فأتاكم مسكينٌ وهو صائم، فلم تُطْعِمُوه منها شيئًا. فكان يعقوبُ ﵇ إذا أراد الغداء أمر مُناديًا يُنادِي: ألا مَن أراد الغداء مِن المساكين فلْيَتَغَدَّ مع يعقوب. وإذا كان صائمًا أمَر مناديًا فنادى: ألا مَن كان صائمًا مِن المساكين فلْيُفْطِر مع يعقوب{20}. (٨/٣١٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٨٠٥٥<span class="dash">-</span></span> عن العلاء بن عبد الرحمن بن يعقوب، قال: بلغني: أنّ رسول الله ﷺ قال: «<b>ثلاث مِن كُنُوز البِرِّ: كتمان الصدقة، وكتمان المصيبة، وكتمان المرض</b>»{21}. (٨/٣١٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٨٠٥٦<span class="dash">-</span></span> عن الحسن، عن النبي ﷺ أنّه سُئِل: ما بلغ وجْدُ يعقوب على ابنه؟ قال: «<b>وجْدَ سبعين ثَكْلى</b>». قيل: فما كان له مِن الأجر؟ قال: «<b>أجر مائة شهيد، وما ساء ظنُّه بالله ساعةً مِن ليل أو نهار</b>»{4}. (٨/٣٠٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٨٠٥٧<span class="dash">-</span></span> عن علقمة بن وقاص، قال: صلَّيْتُ خلف <span class="name-1">عمر بن الخطاب</span> العشاء، فقرأ سورة يوسف، فلمّا أتى على ذِكْرِ يوسف ﵇ نَشَجَ{23} حتى سمعتُ نَشِيجَه وأنا في مؤخر الصُّفُوف{24}. (٨/٣١٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٨٠٥٨<span class="dash">-</span></span> عن عبد الله بن شدّاد، قال: سمعتُ نشيج <span class="name-1">عمر بن الخطاب</span> وإنِّي لَفِي آخر الصفوف في صلاة الصبح، وهو يقرأ: <span class="qpc-hafs">﴿إنما أشكو بثي وحزني إلى الله﴾</span>{25}. (٨/٣١٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٨٠٥٩<span class="dash">-</span></span> عن <span class="name-1">أبي الدرداء</span>، قال: ثلاث مِن مِلاكِ أمرِك: أن لا تشكو مصيبتك، وأن لا تُحَدِّث بوَجَعِك، وأن لا تُزَكِّي نفسَك بلسانك{26}. (٨/٣١٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٨٠٦٠<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span> -من طريق ليث- قال: لَمّا دخل يعقوبُ على الملِك -وحاجباه قد سقطا على عينيه- قال الملِك: ما هذا؟ قال: السنون والأحزان، أو الهموم والأحزان. فقال ربُّه: يا يعقوب، لِمَ تشكوني إلى خلقي، ألم أفعل بك وأفعل؟!{27}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٨٠٦١<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ليث بن أبي سليم- قال: حُدِّثتُ: أنّ جبريل ﵇ أتى يوسفَ ﵇ وهو في مصر في صورة رجل، فلمّا رآه يوسف ﵇ عرَفه، فقام إليه، فقال: أيُّها الملَك الطَّيِّب ريحُه، الطّاهِر ثيابُه، الكريم على ربه، هل لك بيعقوب مِن علم؟ قال: نعم. قال: فكيف هو؟ قال: ذهب بصرُه. قال: وما الذي أذهب بصرَه؟ قال: الحزن عليك. قال: فما أُعْطِي على ذلك؟ قال: أجر سبعين شهيدًا{28}. (٨/٣٠٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٨٠٦٢<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span> -من طريق عمرو بن دينار- قال: أتى جبريلُ ﵇ يوسفَ ﵇ وهو في السجن، فسلَّم عليه، فقال له يوسف: أيُّها الملَك الكريم على ربِّه، الطيب ريحه، الطاهر ثيابه، هل لك عِلْمٌ بيعقوب؟ قال: نعم، ما أشد حزنه! قال: ماذا له مِن الأجر؟ قال: أجر سبعين ثكلى. قال: أفَتُرانِي لاقِيهِ؟ قال: نعم. فطابت نفسُ يوسف{29}. (٨/٣٠٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٨٠٦٣<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق عيسى بن يزيد- قال: قيل: ما بلغ وجْدُ يعقوب على ابنه؟ قال: وجْدَ سبعين ثَكْلى. قال: فما كان له مِن الأجر؟ قال: أجر مائة شهيد. قال: وما ساء ظنُّه بالله ساعةً مِن ليل ولا نهار{30}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٨٠٦٤<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق الليث بن سعد، عمَّن يَرْضى- قال: مَن ابْتُلِي ببلاء، فكتمه ثلاثًا لا يشكو إلى أحد؛ أتاه الله برحمته{31}. (٨/٣١٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٨٠٦٥<span class="dash">-</span></span> عن <span class="name-2">وهب بن مُنَبِّه</span> -من طريق عبد الصمد بن معقل- قال: وجدت في التوراة أربعة أسطر متوالية: مَن شكا مصيبتَه فإنّما يشكو ربَّه، ومَن تَضَعْضَعَ{32} لِغَنِيٍّ ذهب ثُلُثا دينه، ومَن حزِن على ما في يد غيرِه فقد سخط قضاءَ ربِّه، ومَن قرأ كتابَ الله فظَنَّ ألّا يُغفر له فهو مِن المستهزئين بآيات الله{33}. (٨/٣١٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٨٠٦٦<span class="dash">-</span></span> عن <span class="name-2">وهب بن مُنَبِّه</span> -من طريق عبد الصمد بن معقل- قال: لَمّا أتى جبريلُ ﵇ يوسفَ ﵇ بالبُشْرى وهو في السِّجْن قال: هل تعرفُني، أيُّها الصِّدِّيق؟ قال: أرى صورةً طاهرةً، وريحًا طَيِّبةً لا تُشْبِه أرواحَ الخاطئين. قال: فإنِّي رسولُ رب العالمين، وأنا الروح الأمين. قال: فما الذي أدخلك إلى مدخل المذنبين، وأنت أطيب الطيبين، ورأس المقربين، وأمين رب العالمين؟ قال: ألم تعلم -يا يوسف- أنّ الله يُطَهِّر البيوت بطُهْر النَّبِيِّين؟ وأنّ الأرض التي يدخلونها هي أطهر الأرضين؟ وأنّ الله قد طَهَّر بك السِّجْنَ وما حوله، يا طَهِرَ{34} الطاهرين وابن المُطَهَّرين؟ إنّما يُتَطَهَّرُ بفَضْل طُهْرِك وطُهْرِ آبائك الصالحين المخلصين. قال: كيف تُسَمِّيني بأسماء الصِّدِّيقين، وتَعُدُّني مِن المُخْلِصين، وقد دخلتُ مَدْخَل المُذْنِبين، وسُمِّيتُ بالضالين المفسدين؟ قال: لم يفتن قلبَك الحزن، ولم يُدَنِّس حريتَك الرِّقُ، ولم تُطِع سيِّدتك في معصيةِ ربك، فلذلك سماك اللهُ بأسماء الصِّدِّيقين، وعَدَّك مع المخلصين، وألحقك بآبائك الصالحين. قال: هل لكَ عِلْمُ بيعقوب؟ قال: نعم، وهَبَ اللهُ له الصبرَ الجميل، وابتلاه بالحزن عليك فهو كظيم. قال: فما قَدْرُ حُزْنِه؟ قال: قدر سبعين ثكلى. قال: فماذا له مِن الأجر؟ قال: قدر مائة شهيد{35}. (٨/٣٠٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٨٠٦٧<span class="dash">-</span></span> عن <span class="name-2">وهب بن مُنَبِّه</span>، قال: أوحى اللهُ تعالى إلى يعقوب: أتدري لِمَ عاقبتُك وحبستُ عنك يوسف ثمانين سنة؟ قال: لا، يا إلهي. قال: لأنّك قد شَوَيْتَ عَناقًا، وقترت على جارِك، وأكلت ولم تُطْعِمْه{36}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٨٠٦٨<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- قال: ذُكِر لنا: أنّ يعقوب ﵇ لم تَزَل به شِدُّة بلاء قط إلا أتاه حُسنُ ظنِّه بالله مِن وراء بلائه{37}. (٨/٣١٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٨٠٦٩<span class="dash">-</span></span> عن <span class="name-2">حبيب بن أبي ثابت</span> -من طريق أسلم-: أنّ يعقوب ﵇ كان قد سَقَط حاجِباه على عينيه مِن الكِبَر، فكان يرفعهما بخِرْقَة، فقيل له: ما بلغ بكَ هذا؟ قال: طول الزمان، وكثرة الأحزان. فأوحى الله إليه: يا يعقوب، أتشكوني؟ قال: يا ربِّ، خطيئة أخطأتها، فاغفر لي{38}. (٨/٣١٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٨٠٧٠<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- قال: أتى جبريلُ يوسفَ وهو في السجن، فسلَّم عليه، وجاءه في صورة رجل حسن الوجه، طيِّب الريح، نَقِي الثياب، فقال له يوسف: أيها الملك الحسن الوجه، الكريم على ربِّه، الطيِّب ريحُه، حدثني كيف يعقوب؟ قال: حَزِن عليك حزنًا شديدًا. قال: فما بلغ مِن حُزْنِه؟ قال: حُزْن سبعين مُثكَلَة. قال: فما بلغ مِن أجره؟ قال: أجر سبعين شهيدًا. قال يوسف: فإلى مَن أوى بعدى؟ قال: إلى أخيك بنيامين. قال: فتُراني ألقاه؟ قال: نعم. فبكى يوسفُ لِما لَقِي أبوه بعده، ثم قال: ما أُبالي بما لقيت إنِ اللهُ أرانِيهِ{39}. (٨/١٩٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٨٠٧١<span class="dash">-</span></span> عن <span class="name-2">عمرو بن دينار</span>: أنّه أُلقِي على يعقوب ﵇ حُزْنُ سبعين ثَكْلى، ومكَث في ذلك الحزن ثمانين عامًا{40}. (٨/٣٠٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٨٠٧٢<span class="dash">-</span></span> عن <span class="name-2">ليث بن أبى سليم</span> -من طريق هشام-: أنّ جبريل ﵇ دخل على يوسف ﵇ في السِّجن، فعرفه، فقال له: أيُّها المَلَك الكريم على ربِّه، هل لك عِلْمٌ بيعقوب؟ قال: نعم. قال: ما فَعَلَ؟ قال: ابيَضَّت عيناه مِن الحزن عليك. قال: فماذا بلغ من حزنه؟ قال: حزن سبعين مُثْكَلَةٍ. قال: هل له على ذلك مِن أجر؟ قال: نعم، أجر مائة شهيد{41}. (٨/٣٠٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٨٠٧٣<span class="dash">-</span></span> عن <span class="name-2">ثابت بن أسلم البناني</span> -من طريق ليث-، مثله سواء{42}. (٨/٣٠٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٨٠٧٤<span class="dash">-</span></span> عن <span class="name-3">ثور بن يزيد</span> -من طريق يحيى بن واضح- قال: دخل يعقوبُ على فرعون وقد سقط حاجباه على عينيه، فقال: ما بلغ بك هذا، يا إبراهيم؟ فقالوا: إنّه يعقوب. فقال: ما بلغ بك هذا، يا يعقوب؟ قال: طول الزمان، وكثرة الأحزان. فقال الله: يا يعقوب، أتشكوني؟! فقال: يا ربِّ، خطيئةٌ أخطأتُها، فاغفرها لي{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٨٠٧٥<span class="dash">-</span></span> قال <span class="name-3">سفيان الثوري</span>: دخل على يوسف مَلَكٌ السِّجْنَ. فقال له يوسفُ: أيها الملك الطيب الريح، ما فعل يعقوب؟ ما بلغ حزنه؟ قال: بلغ حزن سبعين ثَكْلى{44}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٨٠٧٦<span class="dash">-</span></span> عن <span class="name-3">عبد الله بن أبي جعفر</span> -من طريق نافع بن يزيد- قال: دخل جبريل على يوسف في البئر أو في السِّجن، فقال له يوسف: يا جبريل، ما بلغ مِن حزن أبي؟ قال: حُزْن سبعين ثَكْلى. قال: فما بلغ أجرُه مِن الله؟ قال: أجر مائة شهيد{45}. (٨/٣٠٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٨٠٧٧<span class="dash">-</span></span> عن <span class="name-3">خلف بن حَوْشَب</span>، مثله{46}. (٨/٣٠٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٨٠٧٨<span class="dash">-</span></span> عن <span class="name-3">عبد الرزاق</span>، قال: بلغنا: أنّ يعقوب ﵇ قال: يا ربِّ، أذهبت ولدي، وأذهبتَ بصرى! قال: بلى، وعِزِّتي وجلالي، وإنِّي لَأَرْحَمُك، ولَأَرُدَّنَّ عليك بصرَك وولدك، وإنّما ابتليتك بهذه البلية لأنّك ذبحت جملًا فشويته، فوجد جارُك ريحه فلم تُنِلْه{47}. (٨/٣١٥)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ١٣/٣٠٦. وعزاه السيوطي إلى ابن المنذر، وأبي الشيخ.|2:أخرجه ابن جرير ١٣/٣٠٦. وعزاه السيوطي إلى ابن أبي شيبة، وابن المنذر، وأبي الشيخ.|3:أخرجه ابن أبي حاتم ٧/٢١٨٩.|4:أخرجه ابن جرير ١٣/٣٠٨.|5:تفسير مقاتل بن سليمان ٢/٣٤٨.|6:أخرجه ابن جرير ١٣/٣٠٦، وابن أبي حاتم ٧/٢١٨٩.|7:تفسير سفيان الثوري ص١٤٦، وأخرجه ابن أبي حاتم ٧/٢١٨٩ من طريق أبي أحمد الزبيري.|8:أخرجه ابن أبي حاتم ٧/٢١٨٦.|9:أخرجه ابن جرير ١٣/٣٠٧، وابن أبي حاتم ٧/٢١٨٩.|10:أخرجه ابن جرير ١٣/٣٠٧. وعزاه السيوطي إلى ابن أبي حاتم.|11:تفسير مقاتل بن سليمان ٢/٣٤٨.|12:تفسير سفيان الثوري ص١٤٦.|13:عزاه السيوطي إلى ابن مردويه.|14:أخرجه ابن منده -كما في أسد الغابة لابن الأثير ٢/٢٢١ (٢٠٤٤)، وكما في الإصابة لابن حجر ٣/٦٨-٦٩ (٣٢٠٩)- من طريق عبد الرحمن بن زياد بن أنعم، عن مسلم بن يسار، أنّ سعد بن مسعود، به، ورواه الثوري عن ابن أنعم، عن رجل سمّاه، عن النبي ﷺ، ورواه عبدالر زاق في تفسيره ٢/٣٢٧ عن ابن أنعم عن مسلم بن يسار مرسلًا.</p><p>وفي إسناده اضطراب، وعبد الرحمن بن زياد بن أنعم الإفريقي ضعيف الحديث. ينظر: تهذيب التهذيب ٦/١٧٥.|15:أخرجه عبد الرزاق ١/٣٢٧-٣٢٨، وابن جرير ١٣/٣١٣.|16:عزاه السيوطي إلى ابن المنذر، وابن مردويه.|17:أخرجه ابن عدى ٤/٢٠٥، ٦/٥١٧، والبيهقي في الشعب ١٢/٣٧٦ (٩٥٧٤)، ١٢/٣٧٧-٣٧٨ (٩٥٧٥، ٩٥٧٦، ٩٥٧٧).</p><p>قال أبو نعيم في الحلية ٨/١٩٧: «غريب من حديث نافع وعبد العزيز، تفرَّد به عنه زافر». وقال ابن أبي حاتم في العلل ٦/٢٧١-٢٧٢ (٢٥١٨): «قال أبو زرعة: هذا حديث باطل». وأورده السيوطي في اللآلئ ٢/٣٢٩. وقال المناوي في التيسير ٢/٣٨٣: «وإسناده ضعيف». وقال الألباني في الضعيفة ٢/١٣٥ (٦٩٣): «ضعيف».|18:أخرجه الطبراني في الصغير ٢/٣٠ (٧٢٦)، والبيهقي في الشعب ١٢/٣٧٣-٣٧٤ (٩٥٧١).</p><p>قال البيهقي: «تفرَّد به وهب بن راشد بهذا الإسناد، وروي ذلك بإسناد آخر ضعيف». وقال ابن حبان في المجروحين ٣/٧٥ (١١٣٠): «وهب بن راشد شيخ يروي عن مالك بن دينار العجائب، لا يحل الرواية عنه، ولا الاحتجاج به». وقال ابن القيسراني في تذكرة الحفاظ ص٣٠٨-٣٠٩ (٧٧٥): «رواه وهب بن راشد، عن مالك بن دينار، عن أنس. ووهب هذا يروي العجائب عن مالك، لا تحل الرواية عنه، ويقال: إن هذا من كلام وهب بن منبه نفسه». وقال الهيثمي في المجمع ١٠/٢٤٨ (١٧٨١٩): «رواه الطبراني في الصغير، وفيه وهب بن راشد البصري صاحب ثابت، وهو متروك». وقال السخاوي في المقاصد الحسنة ص٦٤٠ بعد ذكره لهذه الرواية مع رواية أخرى: «وهما واهيان جدًّا». وأورده السيوطي في اللآلئ ٢/٢٦٩.|19:أخرجه الشاشي في مسنده ٢/٨٧ (٦٠٩)، والبيهقي في الشعب ١٢/٣٧٤-٣٧٥ (٩٥٧٢)، والعقيلي في الضعفاء ٣/١٢٧.</p><p>قال ابن الجوزي في الموضوعات ٣/١٣٤: «ليس فيها شيء صحيح ...، فيه عبيد الله بن موسى. قال العقيلي: هو مجهول، وحديثه غير محفوظ». وقال ابن حجر في لسان الميزان ٤/١١٦ (٢٣٧): «عبيد الله بن موسى بن معدان عن منصور لا يُعْرَف، وأتى بخبر منكر ذكره العقيلي انتهى. ونسبه العقيلي كوفيًّا، وقال: مجهول بالنقل، حديثه غير محفوظ». وأورده السيوطي في اللآلئ ٢/٢٦٩.|20:أخرجه الحاكم ٢/٣٧٨، ٣٧٩ (٣٣٢٨، ٣٣٢٩)، وابن أبي حاتم ٧/٢١٨٨ (١١٩٠١).</p><p>قال الحاكم: «هكذا في سماعي بخطِّ يد حفص بن عمر بن الزبير، وأظن الزبير وهِم مَن الراوي، فإنّه حفص بن عمر بن عبد الله بن أبي طلحة الأنصاري ابن أخي أنس بن مالك، فإن كان كذلك فالحديث صحيح». وقال ابن كثير في تفسيره ٤/٤٠٦ عن رواية ابن أبي حاتم: «وهذا حديث غريب، فيه نكارة». وقال الهيثمي في المجمع ٧/٤٠ (١١٠٨٩): «رواه الطبراني في الصغير، والأوسط، عن شيخه محمد بن أحمد الباهلي البصري، وهو ضعيف جدًّا». وقال الألباني في الضعيفة ١٤/٨٨٦ (٦٨٨٠): «منكر».|21:أخرجه البيهقي (١٠٠٥١).|22:أخرجه ابن جرير ١٣/٣٠٨.|23:النشيج: صوت معه توجع وبكاء، كما يردد الصبي بكاءه في صدره. النهاية (نشج).|24:أخرجه عبد الرزاق (٢٧٠٣)، والبيهقي (٢٠٥٨).|25:أخرجه عبد الرزاق (٢٧١٦)، وسعيد بن منصور (١١٣٨- تفسير)، وابن سعد ٦/١٢٦، وابن أبي شيبة ١٤/٧، والبيهقي في شعب الإيمان (٢٠٥٧).|26:أخرجه أحمد في الزهد ص١٤٣، والبيهقي (١٠٠٤٢).|27:أخرجه ابن جرير ١٣/٣١٣.|28:أخرجه ابن جرير ١٣/٣٠٩-٣١٠.|29:أخرجه ابن جرير ١٣/٣١٢-٣١٣.|30:أخرجه ابن جرير ١٣/٣٠٧.|31:أخرجه ابن أبي الدنيا في المرض والكفارات (٢٢٧)، والبيهقي في الشُّعَب (١٠٠٥٢).|32:أي: خضع وذل. النهاية (ضعضع).|33:أخرجه أحمد في الزهد ص٨٥، والبيهقي (١٠٠٤٣).|34:قال محققو المصدر: العبارة غير واضحة، وفي نسخة: يا أطهر.|35:أخرجه ابن جرير ١٣/٣١٠-٣١١، وابن أبي حاتم ٧/٢١٤٠. وعزاه السيوطي إلى عَبد بن حُمَيد، وابن المنذر، وأبي الشيخ.|36:تفسير الثعلبي ٥/٢٤٩، وتفسير البغوي ٤/٢٦٩.|37:أخرجه ابن جرير ١٣/٣٠٧، وابن أبي حاتم ٧/٢١٨٩. وعزاه السيوطي إلى أبي الشيخ.|38:أخرجه عبد الرزاق ١/٣١٩، وأحمد في الزهد ص٨٤، وابن جرير ١٣/٣٠٨، وابن أبي حاتم ٧/٢١٨٩. وعزاه السيوطي إلى ابن أبى شيبة، وابن المنذر، وأبي الشيخ.|39:أخرجه ابن جرير ١٣/٣١٢، وابن أبي حاتم ٧/٢١٨٦.|40:عزاه السيوطي إلى أحمد في الزهد.|41:أخرجه ابن جرير ١٣/٣٠٩، وابن أبي حاتم ٧/٢١٨٦.|42:أخرجه ابن جرير ١٣/٣١١-٣١٢.|43:أخرجه ابن جرير ١٣/٣٠٨.|44:تفسير الثوري ص١٤٥.|45:أخرجه ابن جرير ١٣/٣١٠.|46:أخرجه ابن أبى شيبة ١٣/٢١٢.|47:عزاه السيوطي إلى ابن المنذر.