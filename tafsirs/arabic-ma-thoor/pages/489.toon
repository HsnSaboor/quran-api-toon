tafsir[12]{c,v,t}:
42,52," <q>﴿وَكَذَ ٰ⁠لِكَ أَوۡحَیۡنَاۤ إِلَیۡكَ رُوحࣰا مِّنۡ أَمۡرِنَاۚ﴾</q> - تفسير ٦٩٢٢٨- عن عبد الله بن عباس، في قوله: <q>﴿وكَذَلِكَ أوْحَيْنا إلَيْكَ رُوحًا مِن أمْرِنا﴾</q>، قال: القرآن{1}. (١٣/١٨٢) ٦٩٢٢٩- قال عبد الله بن عباس: <q>﴿وكَذَلِكَ أوْحَيْنا إلَيْكَ رُوحًا مِن أمْرِنا﴾</q> نبوة{2}. (ز) ٦٩٢٣٠- عن الحسن البصري -من طريق قتادة- في قوله: <q>﴿رُوحًا مِن أمْرِنا﴾</q>، قال: رحمة مِن أمرنا{3}. (ز) ٦٩٢٣١- عن قتادة بن دعامة -من طريق معمر- في قوله تعالى: <q>﴿رُوحًا مِن أمْرِنا﴾</q>، قال: رحمة من عندنا{4}. (ز) ٦٩٢٣٢- عن إسماعيل السُّدّيّ -من طريق أسباط- في قوله: <q>﴿وكَذَلِكَ أوْحَيْنا إلَيْكَ رُوحًا مِن أمْرِنا﴾</q>، قال: وحيًا مِن أمرنا{3}. (ز) ٦٩٢٣٣- قال مالك بن دينار: <q>﴿وكَذَلِكَ أوْحَيْنا إلَيْكَ رُوحًا مِن أمْرِنا﴾</q>، يعني: القرآن. وكان يقول: يا أصحاب القرآن، ماذا زرع القرآنُ في قلوبكم، فإنّ القرآنَ ربيع القلوب كما أن الغيث ربيع الأرض{2}. (ز) ٦٩٢٣٤- قال الربيع [بن أنس]: <q>﴿وكَذَلِكَ أوْحَيْنا إلَيْكَ رُوحًا مِن أمْرِنا﴾</q> جبريل{7}. (ز) ٦٩٢٣٥- قال محمد بن السّائِب الكلبي: <q>﴿وكَذَلِكَ أوْحَيْنا إلَيْكَ رُوحًا مِن أمْرِنا﴾</q> كتابًا{8}. (ز) ٦٩٢٣٦- قال مقاتل بن سليمان: قوله تعالى: <q>﴿وكَذَلِكَ﴾</q> يعني: وهكذا <q>﴿أوْحَيْنا إلَيْكَ رُوحًا مِن أمْرِنا﴾</q> يعني: الوحي بأمرنا، كما أوحينا إلى الأنبياء مِن قبلك حين ذكر الأنبياء من قبله، فقال: <q>﴿وما كانَ لِبَشَرٍ أنْ يُكَلِّمَهُ اللَّهُ إلّا وحْيًا أوْ مِن وراءِ حِجابٍ أوْ يُرْسِلَ رَسُولًا فَيُوحِيَ بِإذْنِهِ ما يَشاءُ إنَّهُ عَلِيٌّ حَكِيمٌ﴾</q>{9}٥٨٣٢. (ز) ٥٨٣٢ ذكر ابنُ عطية (٧/٥٣١) أن قوله: <q>﴿من أمرنا﴾</q> يعني: «واحد من أمورنا». ثم ذكر احتمالًا آخر، فقال: «ويحتمل أن يكون الأمر بمعنى الكلام». <q>﴿مَا كُنتَ تَدۡرِی مَا ٱلۡكِتَـٰبُ وَلَا ٱلۡإِیمَـٰنُ﴾</q> - تفسير ٦٩٢٣٧- عن علي بن أبي طالب، قال: قيل للنبي ﷺ: هل عبدتَ وثنًا قطّ؟ قال: «لا». قالوا: فهل شربتَ خمرًا قط؟ قال: «لا، وما زلتُ أعرف الذي هم عليه كفرٌ، وما كنتُ أدري ما الكتاب ولا الإيمان». وبذلك نزل القرآن: <q>﴿ما كُنْتَ تَدْرِي ما الكِتابُ ولا الإيمانُ﴾</q>{10}. (١٣/١٨٢) ٦٩٢٣٨- قال أبو العالية الرِّياحي: <q>﴿ما كُنْتَ تَدْرِي ما الكِتابُ ولا الإيمانُ﴾</q>، يعني: الدعوة إلى الإيمان{11}. (ز) ٦٩٢٣٩- عن إسماعيل السُّدّيّ -من طريق أسباط- <q>﴿ما كُنْتَ تَدْرِي ما الكِتابُ ولا الإيمانُ﴾</q>: يعني: محمدًا ﷺ{12}. (ز) ٦٩٢٤٠- قال مقاتل بن سليمان: قوله: <q>﴿ما كُنْتَ تَدْرِي ما الكِتابُ﴾</q> يا محمد قبل الوحي ما الكتاب، <q>﴿ولا الإيمانُ﴾</q>{9}. (ز) <q>﴿وَلَـٰكِن جَعَلۡنَـٰهُ نُورࣰا نَّهۡدِی بِهِۦ مَن نَّشَاۤءُ مِنۡ عِبَادِنَاۚ﴾</q> - تفسير ٦٩٢٤١- قال عبد الله بن عباس: <q>﴿ولَكِنْ جَعَلْناهُ﴾</q>، يعني: الإيمان{2}٥٨٣٣. (ز) ٥٨٣٣ ذكر ابنُ القيم (٢/٤٣٤) في عود الضمير في قوله: <q>﴿جعلناه﴾</q> قولين: الأول: أنه عائد على الكتاب. الثاني: أنه عائد على الإيمان. ثم رجح أنّه عائد على الروح، ولم يذكر مستندًا، فقال: «والصحيح أنه يعود على الروح في قوله: <q>﴿روحا من أمرنا﴾</q>». وبنحوه قال ابنُ تيمية (٥/٥١٣-٥١٤)، وبيّن أنه يتناولهما؛ فالروح شامل الإيمان والقرآن. ٦٩٢٤٢- عن إسماعيل السُّدّيّ -من طريق أسباط- <q>﴿ولَكِنْ جَعَلْناهُ نُورًا نَهْدِي بِهِ مَن نَشاءُ مِن عِبادِنا﴾</q>: يعني: بالقرآن{3}. (ز) ٦٩٢٤٣- قال مقاتل بن سليمان: <q>﴿ولَكِنْ جَعَلْناهُ﴾</q> يعني: القرآن <q>﴿نُورًا﴾</q> يعني: ضياء مِن العمى <q>﴿نَهْدِي بِهِ﴾</q> يعني: بالقرآن من الضَّلالة إلى الهُدى <q>﴿مَن نَشاءُ مِن عِبادِنا﴾</q>{9}. (ز) <q>﴿وَإِنَّكَ لَتَهۡدِیۤ إِلَىٰ صِرَ ٰ⁠طࣲ مُّسۡتَقِیمࣲ ۝٥٢﴾</q> - تفسير ٦٩٢٤٤- عن مجاهد بن جبر -من طريق عيسى- <q>﴿وإنَّكَ لَتَهْدِي إلى صِراطٍ مُسْتَقِيمٍ﴾</q>، قال: تدعو{17}. (ز) ٦٩٢٤٥- عن قتادة بن دعامة -من طريق سعيد- <q>﴿وإنَّكَ لَتَهْدِي إلى صِراطٍ مُسْتَقِيمٍ﴾</q>، قال: قال الله: <q>﴿ولِكُلِّ قَوْمٍ هادٍ﴾</q> [الرعد:٧]، قال: داعٍ يدعو إلى الله تعالى{18}. (١٣/١٨٣) ٦٩٢٤٦- عن قتادة بن دعامة -من طريق معمر- في قوله تعالى: <q>﴿وإنَّكَ لَتَهْدِي إلى صِراطٍ مُسْتَقِيمٍ﴾</q>: لكلّ قومٍ هادٍ{19}. (ز) ٦٩٢٤٧- عن قتادة بن دعامة، <q>﴿وإنَّكَ لَتَهْدِي إلى صِراطٍ مُسْتَقِيمٍ﴾</q>، قال: تدعو إلى دين مستقيم{20}. (١٣/١٨٣) ٦٩٢٤٨- عن إسماعيل السُّدّيّ -من طريق أسباط- <q>﴿وإنَّكَ لَتَهْدِي إلى صِراطٍ مُسْتَقِيم﴾</q>، يقول: تدعو إلى دين مستقيم{12}٥٨٣٤. (ز) ٥٨٣٤ لم يذكر ابنُ جرير (٢٠/٥٤٣-٥٤٤) غير قول السُّدّي، وقول قتادة من طريق معمر. ٦٩٢٤٩- قال مقاتل بن سليمان: <q>﴿وإنَّكَ لَتَهْدِي إلى صِراطٍ مُسْتَقِيمٍ﴾</q>، يعني: إنك لتدعو إلى دين مستقيم، يعني: الإسلام{9}. (ز) ٦٩٢٥٠- عن عبد الملك ابن جُريْج، في قوله: <q>﴿وإنَّكَ لَتَهْدِي﴾</q>، قال: لتدعو{23}. (١٣/١٨٣) ٦٩٢٥١- قال يحيى بن سلّام: <q>﴿وإنك لتهدي إلى صراط مستقيم﴾</q>، أي: إلى الجنة {24}. (ز) ",footnotes:1:أخرجه ابن أبي حاتم -كما في التغليق ٤/٣٠٤-. وعزاه السيوطي إلى ابن المنذر.تفسير الثعلبي ٨/٣٢٦، وتفسير البغوي ٧/٢٠١.أخرجه ابن جرير٢٠/٥٤٢.أخرجه عبد الرزاق ٢/١٩٣.أخرجه ابن جرير٢٠/٥٤٢.تفسير الثعلبي ٨/٣٢٦، وتفسير البغوي ٧/٢٠١.تفسير البغوي ٧/٢٠١.تفسير الثعلبي ٨/٣٢٦، وتفسير البغوي ٦/٢٠١.تفسير مقاتل بن سليمان ٣/٧٧٦.أخرجه الواحدي في التفسير الوسيط ٤/٦٢ (٨٢٣)، من طريق إسماعيل بن يحيى بن عبيد الله التميمي، عن أبي سيار، عن الضحاك، عن النزال بن سبرة، عن علي بن أبي طالب به. وسنده ضعيف جدًّا؛ فيه إسماعيل بن يحيى بن عبيد الله، وهو متروك. كما في ميزان الاعتدال ١/٢٥٣.تفسير الثعلبي ٨/٣٢٦.أخرجه ابن جرير٢٠/٥٤٤.تفسير مقاتل بن سليمان ٣/٧٧٦.تفسير الثعلبي ٨/٣٢٦، وتفسير البغوي ٧/٢٠١.أخرجه ابن جرير٢٠/٥٤٢.تفسير مقاتل بن سليمان ٣/٧٧٦.أخرجه سفيان الثوري ص٢٦٩.أخرجه ابن جرير ٢٠/٥٤٣. وعزاه السيوطي إلى عَبد بن حُمَيد.أخرجه عبد الرزاق ٢/١٩٣، وابن جرير٢٠/٥٤٤.عزاه السيوطي إلى ابن جرير، وفي المطبوع منه مثله عن السُّدّي.أخرجه ابن جرير٢٠/٥٤٤.تفسير مقاتل بن سليمان ٣/٧٧٦.عزاه السيوطي إلى ابن المنذر.تفسير يحيى بن سلام ١/٣٦١.
42,53," <q>﴿صِرَ ٰ⁠طِ ٱللَّهِ ٱلَّذِی لَهُۥ مَا فِی ٱلسَّمَـٰوَ ٰ⁠تِ وَمَا فِی ٱلۡأَرۡضِۗ أَلَاۤ إِلَى ٱللَّهِ تَصِیرُ ٱلۡأُمُورُ ۝٥٣﴾</q> - تفسير ٦٩٢٥٢- قال مقاتل بن سليمان: <q>﴿صِراطِ اللَّهِ﴾</q> يقول: دين الله <q>﴿الَّذِي لَهُ ما فِي السَّماواتِ وما فِي الأَرْضِ﴾</q> خلْقه وعبيده، وفي قبضته، <q>﴿ألا إلى اللَّهِ تَصِيرُ الأُمُورُ﴾</q> يعني: أمور الخلائق في الآخرة تصير إليه، فيجزيهم بأعمالهم، والله غفور لذنوب العباد، رحيم بهم{1}. (ز) ٦٩٢٥٣- قال يحيى بن سلّام: <q>﴿صراط الله﴾</q> طريق الله الذي هدى له عبادَه المؤمنين إلى الجنة{2}. (ز) ",footnotes:1:تفسير مقاتل بن سليمان ٣/٧٧٦-٧٧٧.تفسير يحيى بن سلام ١/٣٦١.
43,1," مقدمة السورة ٦٩٢٥٤- عن عبد الله بن عباس -من طريق مجاهد-: مكية{1}. (ز) ٦٩٢٥٥- عن عبد الله بن عباس، قال: نزلت بمكة سورة «حم الزخرف»{2}. (١٣/١٨٤) ٦٩٢٥٦- عن عبد الله بن عباس -من طريق عطاء الخُراساني-: مكية، ونزلت بعد «حم عسق»{3}. (ز) ٦٩٢٥٧- عن عكرمة مولى ابن عباس= (ز) ٦٩٢٥٨- والحسن البصري -من طريق يزيد النحوي-: مكية، وسمّياها: «حم الزخرف»{4}. (ز) ٦٩٢٥٩- عن قتادة بن دعامة -من طرق-: مكية{5}. (ز) ٦٩٢٦٠- عن محمد بن شهاب الزّهري: مكية، وسمّاها: «حم الزخرف»، ونزلت بعد «حم عسق»{6}. (ز) ٦٩٢٦١- عن محمد بن شهاب الزهري -من طريق موسى بن عقبة- قال: بعث رسولُ الله ﷺ مصعبَ بن عمير، فنزل في بني غنم على أسعد بن زرارة، فجعل يدعو الناس، فجاء سعد بن معاذ، فتوعّده، فقال له أسعد بن زرارة: استمع مِن قوله، فإن سمعتَ منكرًا فاردُدْه بأهدى منه، وإن سمعتَ حقًّا فأجِبْ إليه. فقال: ماذا تقول؟ فقرأ عليه مصعب: <q>﴿حم * والكِتابِ المُبِينِ * إنّا جَعَلْناهُ قُرْآنًا عَرَبِيًّا لَعَلَّكُمْ تَعْقِلُونَ﴾</q>. قال سعد بن معاذ: ما أسمع إلا ما أعرف. فرجع وقد هداه الله{7}. (١٣/٨١) ٦٩٢٦٢- عن علي بن أبي طلحة: مكية{8}. (ز) ٦٩٢٦٣- قال مقاتل بن سليمان: سورة الزخرف مكية، عددها تسع وثمانون آية كوفية{9}٥٨٣٥. (ز) ٥٨٣٥ ذكر ابنُ عطية (٧/٥٣٢) أن هذه السورة مكية بإجماع من أهل العلم. ",footnotes:1:أخرجه أبو جعفر النحاس في الناسخ والمنسوخ ٢/٦١١ من طريق أبي عمرو بن العلاء عن مجاهد، والبيهقي في دلائل النبوة ٧/١٤٣-١٤٤ من طريق خُصيف عن مجاهد.عزاه السيوطي إلى ابن مردويه.أخرجه ابن الضريس في فضائل القرآن ١/٣٣-٣٥.أخرجه البيهقي في دلائل النبوة ٧/١٤٢-١٤٣.أخرجه الحارث المحاسبي في فهم القرآن ص٣٩٥-٣٩٦ من طريق سعيد، وأبو بكر ابن الأنباري -كما في الإتقان في علوم القرآن ١/٥٧- من طريق همام.تنزيل القرآن ص٣٧-٤٢.أخرجه البيهقي في الدلائل ٢/٤٣١-٤٣٢.أخرجه أبو عبيد في فضائله (ت: الخياطي) ٢/٢٠٠.تفسير مقاتل بن سليمان ٣/٧٨٧.
43,2," <q>﴿حمۤ ۝١ وَٱلۡكِتَـٰبِ ٱلۡمُبِینِ ۝٢﴾</q> - تفسير ٦٩٢٦٤- عن قتادة بن دعامة -من طريق سعيد- <q>﴿حم والكِتابِ المُبِينِ﴾</q>، قال: مُبين -واللهِ- بركته، وهُداه، ورُشده{1}. (ز) ٦٩٢٦٥- عن إسماعيل السُّدّيّ -من طريق أسباط- <q>﴿حم والكِتابِ المُبِينِ﴾</q>: هو هذا الكتاب المبين{1}. (ز) ٦٩٢٦٦- قال مقاتل بن سليمان: <q>﴿حم والكِتابِ المُبِينِ﴾</q>، يعني: البيِّنُ ما فيه{3}٥٨٣٦. (ز) ٥٨٣٦ ذكر ابنُ عطية (٧/٥٣٢) أن قوله: <q>﴿المُبِين﴾</q> يحتمل احتمالين: الأول: أن يكون مِن: أبان، الذي هو بمعنى: بان، أي: ظهر، فلا يحتاج إلى مفعول. الثاني: ويحتمل أن يكون مُعدًّى من: بان، فهذا لا بد له من مفعول، تقديره: المبين الهدى والشرع ونحوه. ",footnotes:1:أخرجه ابن جرير ٢٠/٥٤٦.أخرجه ابن جرير ٢٠/٥٤٦.تفسير مقاتل بن سليمان ٣/٧٨٩.
43,3," <q>﴿إِنَّا جَعَلۡنَـٰهُ قُرۡءَ ٰ⁠ نًا عَرَبِیࣰّا لَّعَلَّكُمۡ تَعۡقِلُونَ ۝٣﴾</q> - تفسير ٦٩٢٦٧- عن طاووس، قال: جاء رجلٌ إلى ابن عباس مِن حَضرمَوْت، فقال له: يا ابن عباس، أخبِرني عن القرآن، أكلامٌ مِن كلام الله، أمْ خلْق مِن خلْق الله؟ قال: بل كلام مِن كلام الله، أوَما سمعت الله يقول: <q>﴿وإنْ أحَدٌ مِنَ المُشْرِكِينَ اسْتَجارَكَ فَأَجِرْهُ حَتّى يَسْمَعَ كَلامَ اللَّهِ﴾</q> [التوبة:٦]؟ فقال له الرجل: أفرأيت قوله: <q>﴿إنّا جَعَلْناهُ قُرْآنًا عَرَبِيًّا﴾</q>؟ قال: كتبه الله في اللوح المحفوظ بالعربية، أما سمعت الله يقول: <q>﴿بَلْ هُوَ قُرْآنٌ مَجِيدٌ فِي لَوْحٍ مَحْفُوظٍ﴾</q> [البروج:٢١-٢٢]؟ المجيد: هو العزيز، أي: كتبه الله في اللوح المحفوظ{1}. (١٣/١٨٤) ٦٩٢٦٨- قال مقاتل بن سليمان: <q>﴿إنّا جَعَلْناهُ قُرْآنًا عَرَبِيًّا﴾</q> ليفقهوا ما فيه، ولو كان غير عربيٍّ ما عقلوه، <q>﴿لَعَلَّكُمْ تَعْقِلُونَ﴾</q> يقول: لكي تعقلون ما فيه{2}. (ز) ٦٩٢٦٩- عن مقاتل بن حيّان، قال: كلام أهل السماء العربية. ثم قرأ: <q>﴿حم والكِتابِ المُبِين إنّا جَعَلْناهُ قُرْآنًا عَرَبِيًّا﴾</q> الآيتين{3}. (١٣/١٨٤) ",footnotes:1:عزاه السيوطي إلى ابن مردويه.تفسير مقاتل بن سليمان ٣/٧٨٩.أخرجه ابن أبي شيبة ١٠/٤٥٩.
43,4," <q>﴿وَإِنَّهُۥ فِیۤ أُمِّ ٱلۡكِتَـٰبِ﴾</q> - تفسير ٦٩٢٧٠- عن أنس، أنّ رسول الله ﷺ قال: «إنّ الله كتب كتابًا قبل أن يخلق السماوات والأرض، وهو عنده فوق العرش، الخلْق منتهون إلى ما في ذلك الكتاب، وتصديقُ ذلك في كتاب الله: <q>﴿وإنَّهُ فِي أُمِّ الكِتابِ لَدَيْنا لَعَلِيٌّ حَكِيمٌ﴾</q>»{1}. (١٣/١٨٥) ٦٩٢٧١- عن عبد الله بن عباس -من طريق عروة بن عامر- قال: إنّ أول ما خلق الله من شيء القلم، فأمره أن يكتب ما هو كائِن إلى يوم القيامة، والكتاب عنده. ثم قرأ: <q>﴿وإنَّهُ فِي أُمِّ الكِتابِ لَدَيْنا لَعَلِيٌّ حَكِيمٌ﴾</q>{2}. (١٣/١٨٤) ٦٩٢٧٢- عن عكرمة مولى ابن عباس -من طريق عمران- <q>﴿وإنَّهُ فِي أُمِّ الكِتابِ لَدَيْنا﴾</q>، قال: أُمّ الكتاب: القرآن{3}. (ز) ٦٩٢٧٣- عن الحسن البصري، <q>﴿وإنَّهُ فِي أُمِّ الكِتابِ﴾</q>، قال: القرآن عند الله في أُمِّ الكتاب{4}. (١٣/١٨٥) ٦٩٢٧٤- عن عطية بن سعد [العوفي] -من طريق إدريس- في قول الله -تبارك وتعالى-: <q>﴿وإنَّهُ فِي أُمِّ الكِتابِ لَدَيْنا لَعَلِيٌّ حَكِيمٌ﴾</q>: يعني: القرآن في أُمّ الكتاب الذي عند الله، منه نُسِخ{3}. (ز) ٦٩٢٧٥- عن أبي صخر، قال: سمعت محمد بن كعب القُرظي يقول: أرأيتَ هؤلاء القدريين يؤمنون سورة: <q>﴿حم والكتاب المبين إنا جعلناه قرءانًا عربيًا لعلكم تعقلون وإنه في أم الكتاب لدينا لعليّ حكيم﴾</q>{6}. (ز) ٦٩٢٧٦- عن قتادة بن دعامة -من طريق معمر- في قوله: <q>﴿وإنَّهُ فِي أُمِّ الكِتابِ﴾</q>، قال: في أصل الكتاب، وجملته{7}. (١٣/١٨٥) ٦٩٢٧٧- عن عبد الرحمن بن عبد الله بن سابِط الجُمَحي، في قوله:<q>﴿وإنَّهُ فِي أُمِّ الكِتابِ﴾</q>، قال: في أُمّ الكتاب ما هو كائن إلى يوم القيامة، وُكِّل ثلاثة مِن الملائكة يحفظون، فوُكِّل جبريل بالوحي ينزل به إلى الرسل، وبالهلاك إذا أراد أن يُهلِك قومًا كان صاحب ذلك، ووُكِّل أيضًا بالنصر في الحروب إذا أراد الله أن ينصر، ووُكِّل ميكائيل بالقطر أن يحفظه، ووُكِّل بنبات الأرض أن يحفظه، ووُكِّل مَلك الموت بقبْض الأنفس، فإذا ذهبت الدنيا جُمِع بين حفظهم وحِفْظ أُمِّ الكتاب فوجدوه سواءً{8}. (١٣/١٨٥) ٦٩٢٧٨- عن إسماعيل السُّدّيّ -من طريق أسباط- <q>﴿وإنَّهُ فِي أُمِّ الكِتابِ﴾</q>، يقول: في الكتاب الذي عند الله في الأصل{3}. (ز) ٦٩٢٧٩- قال مقاتل بن سليمان: ثم قال: <q>﴿وإنَّهُ فِي أُمِّ الكِتابِ﴾</q> يقول لأهل مكة: إن كذَّبتم بهذا القرآن فإنّ نُسختَه في أصل الكتاب، يعني: اللوح المحفوظ <q>﴿لَدَيْنا لَعَلِيٌّ حَكِيمٌ﴾</q>{10}. (ز) ٦٩٢٨٠- عن عبد الملك ابن جُريْج، في قوله: <q>﴿وإنَّهُ فِي أُمِّ الكِتابِ لَدَيْنا﴾</q>، قال: الذّكر الحكيم فيه كلّ شيء كان، وكلّ شيء يكون، وما نزل من كتاب فمنه{4}. (١٣/١٨٥) <q>﴿لَدَیۡنَا لَعَلِیٌّ حَكِیمٌ ۝٤﴾</q> - تفسير ٦٩٢٨١- عن قتادة بن دعامة -من طريق سعيد-: <q>﴿لَدَيْنا﴾</q> أي: عندنا <q>﴿لَعَلِيٌّ حَكِيمٌ﴾</q> يخبر عن منزلته، وفضله، وشرفه{3}. (ز) ٦٩٢٨٢- قال مقاتل بن سليمان: <q>﴿لدينا لَعَلِيٌّ﴾</q> يقول: عندنا مرفوع، <q>﴿حَكِيمٌ﴾</q> يعني: مُحكَم مِن الباطل{10}٥٨٣٧. (ز) ٥٨٣٧ قال ابنُ القيم (٢/٤٣٦): «قوله: <q>﴿لدينا﴾</q> يجوز فيه أن تكون من صلة <q>﴿أُمّ الكتاب﴾</q>، أي: أنه في الكتاب الذي عندنا. وهذا اختيار ابن عباس. ويجوز أن يكون من صلة الخبر؛ أنه عليّ حكيم عندنا ليس هو كما عند المكذبين به، أي: وإن كذبتم به وكفرتم فهو عندنا في غاية الارتفاع والشرف». ",footnotes:1:أخرجه أبو نعيم في تاريخ أصبهان ١/٣٨٣، من طريق سعيد بن عيسى الكريزي أبي عثمان، ثنا أبو داود، ثنا همام بن يحيى، عن سعيد بن أبي عروبة، عن قتادة، عن أنس به. إسناده ضعيف؛ فيه سعيد بن عيسى الكريزي، قال عنه الدارقطني: «ضعيف». كما في لسان الميزان لابن حجر ٤/٧٠.أخرجه ابن جرير ٢٠/٥٤٦. وعزاه السيوطي إلى ابن أبي حاتم.أخرجه ابن جرير ٢٠/٥٤٧.عزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ٢٠/٥٤٧.أخرجه إسحاق البستي ص٣١١. ولفظ الأثر كذا ورد في المصدر.أخرجه عبد الرزاق ٢/١٩٤، وابن جرير ٢٠/٥٤٧ بنحوه، كذلك من طريق سعيد بنحوه.أخرجه ابن أبي شيبة ١٣/٤٣٠ مختصرًا، وأبو الشيخ في العظمة (٤٩٨). وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه ابن جرير ٢٠/٥٤٧.تفسير مقاتل بن سليمان ٣/٧٨٩.عزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ٢٠/٥٤٧.تفسير مقاتل بن سليمان ٣/٧٨٩.
43,5," <q>﴿أَفَنَضۡرِبُ عَنكُمُ ٱلذِّكۡرَ صَفۡحًا أَن كُنتُمۡ قَوۡمࣰا مُّسۡرِفِینَ ۝٥﴾</q> - قراءات ٦٩٢٨٣- عن عاصم، أنّه قرأ: <q>﴿أنْ كُنتُمْ﴾</q> بنصب الألف{1}٥٨٣٨. (١٣/١٨٨) ٥٨٣٨ اختُلف في قراءة قوله: <q>﴿أن كنتم﴾</q>؛ فقرأ قوم بفتح الهمزة، وقرأ غيرهم بكسرها. وذكر ابنُ جرير (٢٠/٥٥٠) أن قراءة الفتح بمعنى: لأن كنتم، وقراءة الكسر بمعنى: أفنضرب عنكم الذكر صفحًا إذ كنتم قومًا مسرفين. وبنحوه قال ابنُ عطية (٧/٥٣٤). ثم رجَّح ابنُ جرير (٢٠/٥٥١) صحة كلتا القراءتين مستندًا إلى شهرتهما، وصحة معناهما، وإلى لغة العرب، فقال: «والصواب مِن القول في ذلك عندنا: أنّ الكسر والفتح في الألف في هذا الموضع قراءتان مشهورتان في قرأة الأمصار صحيحتا المعنى، فبأيتهما قرأ القارئ فمصيب، وذلك أن العرب إذا تقدّم»أن«-وهي بمعنى الجزاء- فعلٌ مستقبِل كسروا ألفها أحيانًا، فمحّضوا لها الجزاء، فقالوا: أقوم إن قمت. وفتحوها أحيانًا، وهم ينوون ذلك المعنى، فقالوا: أقوم أن قمت. بتأويل: لأن قمت، فإذا كان الذي تقدمها من الفعل ماضيًا لم يتكلموا إلا بفتح الألف من»أن«فقالوا: قمتُ أَنْ قمتَ، وبذلك جاء التنزيل، وتتابع شعر الشعراء». <q>﴿أَفَنَضۡرِبُ عَنكُمُ ٱلذِّكۡرَ صَفۡحًا أَن كُنتُمۡ قَوۡمࣰا مُّسۡرِفِینَ ۝٥﴾</q> - تفسير الآية ٦٩٢٨٤- عن عبد الله بن عباس -من طريق عطية العَوفيّ- في قوله: <q>﴿أفَنَضْرِبُ عَنْكُمُ الذِّكْرَ صَفْحًا﴾</q>، قال: أحسبتم أنْ نصفح عنكم ولم تفعلوا ما أُمِرتُم به{2}. (١٣/١٨٦) ٦٩٢٨٥- عن مجاهد بن جبر -من طريق ابن أبي نجيح- <q>﴿أفَنَضْرِبُ عَنْكُمُ الذِّكْرَ صَفْحًا﴾</q>، قال: تُكَذِّبون بالقرآن، ثم لا تُعاقَبون عليه{3}. (١٣/١٨٦) ٦٩٢٨٦- عن الحسن البصري، قال: لم يبعث اللهُ رسولًا إلا أن أنزل عليه كتابًا، فإنْ قَبِله قومُه وإلّا رُفِع، فذلك قوله: <q>﴿أفَنَضْرِبُ عَنْكُمُ الذِّكْرَ صَفْحًا أنْ كُنْتُمْ قَوْمًا مُسْرِفِينَ﴾</q> لا تقبلونه، فتلقّته قلوب نقِيَّةٌ، قالوا: قَبِلناه، ربَّنا، قَبِلناه، ربَّنا. ولو لم يفعلوا لرُفِع، ولم يُترك منه شيء على ظهر الأرض{4}. (١٣/١٨٧) ٦٩٢٨٧- عن أبي صالح باذام -من طريق إسماعيل- <q>﴿أفَنَضْرِبُ عَنْكُمُ الذِّكْرَ صَفْحًا﴾</q>، قال: العذاب{5}. (١٣/١٨٦) ٦٩٢٨٨- عن قتادة بن دعامة -من طريق مَعْمَر- في قوله: <q>﴿أفَنَضْرِبُ عَنْكُمُ الذِّكْرَ صَفْحًا﴾</q>، قال: لو أنّ هذه الأمة لم يؤمنوا لضُرِب عنهم الذِّكر صفحًا{2}. (ز) ٦٩٢٨٩- عن قتادة بن دعامة -من طريق سعيد- <q>﴿أفنضرب عنكم الذّكر صفحًا ان كنتم قومًا مسرفين﴾</q>: أي: مشركين. واللهِ، لو أنّ هذا القرآن رُفِع حين ردَّه أوائلُ هذه الأمة لهلكوا، ولكنَّ الله عاد بعائدته ورحمته، كرّره عليهم، ودعاهم إليه عشرين سنة، أو ما شاء الله مِن ذلك{7}٥٨٣٩. (١٣/١٨٦) ٥٨٣٩ علَّق ابنُ كثير (١٢/٣٠٠) على هذا القول الذي قاله قتادة، وابن زيد، والحسن، فقال: «وقول قتادة لطيف المعنى جدًّا، وحاصله أنه يقول في معناه: إنّه تعالى من لطفه ورحمته بخلْقه لا يترك دعاءهم إلى الخير والذّكر الحكيم -وهو القرآن-، وإن كانوا مسرفين معرضين عنه، بل يأمر به ليهتدي مَن قَدّر هدايته، وتقوم الحجة على مَن كَتب شقاوته». ٦٩٢٩٠- عن إسماعيل السُّدّيّ -من طريق أسباط- <q>﴿أفَنَضْرِبُ عَنْكُمُ الذِّكْرَ صَفْحًا﴾</q>، قال: أفنضرب عنكم العذاب{8}. (ز) ٦٩٢٩١- عن محمد بن السّائِب الكلبي: <q>﴿صَفْحًا﴾</q> أنَذَرُ الذِّكرَ مِن أجلكم؟!{9}. (ز) ٦٩٢٩٢- قال محمد بن السّائِب الكلبي: <q>﴿أفَنَضْرِبُ عَنْكُمُ الذِّكْرَ صَفْحًا﴾</q> أفنترككم سُدًى؛ لا نأمركم، ولا ننهاكم{10}. (ز) ٦٩٢٩٣- قال مقاتل بن سليمان: قوله: <q>﴿أفَنَضْرِبُ عَنْكُمُ الذِّكْرَ صَفْحًا﴾</q> يقول لأهل مكة: أفنُذهِب عنكم هذا القرآن سُدًى؛ لا تُسألون عن تكذيبٍ به <q>﴿أنْ كُنْتُمْ قَوْمًا مُسْرِفِينَ﴾</q> يعني: مشركين{11}. (ز) ٦٩٢٩٤- قال عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿أفَنَضْرِبُ عَنْكُمُ الذِّكْرَ صَفْحًا﴾</q> قال: الذِّكر ما أُنزل عليهم مما أمرهم الله به ونهاهم <q>﴿صَفْحًا﴾</q> لا نذكر لكم منه شيئًا{12}٥٨٤٠. (ز) ٥٨٤٠ اختُلف في المراد بالذِّكْر على قولين: الأول: أنّه ذِكْر العذاب، فالمعنى: أفنُمْسِكُ عن عذابكم ونترُكُكم على كفركم؟!. الثاني: أنه القرآن، فالمعنى: أفنُمْسِكُ عن إنزال القرآن من أجل أنكم لا تؤمِنون به؟! ورجَّح ابنُ جرير (٢٠/٥٥٠) -مستندًا إلى السياق- القولَ الأول الذي قاله ابن عباس، والسُّدّيّ، ومجاهد، وأبو صالح، ومقاتل، فقال: «لأنّ الله -تبارك وتعالى- أتْبَع ذلك خبرَه عن الأمم السالفة قبل الأُمَّة التي توعّدها بهذه الآية في تكذيبها رسلها، وما أحلّ بها مِن نقمته، ففي ذلك دليلٌ على أنّ قوله: <q>﴿أفنضرب عنكم الذكر صفحا﴾</q> وعيدٌ منه للمخاطبين به مِن أهل الشِّرك؛ إذ سلكوا في التكذيب بما جاءهم عن الله رسولهم مسلك الماضين قبلهم». وقال ابنُ عطية (٧/٥٣٣-٥٣٤): "قوله تعالى: <q>﴿صَفْحًا﴾</q> انتصابه كانتصاب <q>﴿صُنْعَ اللَّهِ﴾</q> [النمل:٨٨]، فيحتمل أن يكون بمعنى: العفو والغفر للذنب، فكأنه يقول: أفنترك تذكيركم وتخويفكم عفوًا عنكم وغفرًا لإجرامكم أن كنتم، أو من أجل أن كنتم قومًا مسرفين، هذا لا يصلح، وهذا قول ابن عباس ومجاهد، ويحتمل قوله: <q>﴿صَفْحًا﴾</q> أن يكون بمعنى: مغفولًا عنه، أي: نتركه يمرُّ لا تؤخذون بقوله ولا بتدبُّره ولا تُنَبهون عليه، وهذا المعنى نظير قول الشاعر: تمر الصبا صفحًا بساكن ذي الغضا ويصدع قلبي إن يهب هبوبها أي: تمر مغفولًا عنها، فكأن هذا المعنى: أفنترككم سدًى، وهذا هو منحى قتادة وغيره، ومن اللفظة قول كثير: صفوحًا فما تلقاك إلا بخيلة فمَن ملّ منها ذلك الوصل ملّت". ",footnotes:1:عزاه السيوطي إلى عبد بن حميد. وهي قراءة العشرة، ماعدا نافعًا، وأبا جعفر، وحمزة، والكسائي، وخلفًا العاشر؛ فإنهم قرؤوا: ‹إن كُنتُمْ› بكسر الهمزة. انظر: النشر ٢/٣٦٨، والإتحاف ص٤٩٤.أخرجه ابن جرير ٢٠/٥٤٩.تفسير مجاهد ص٥٩٢، وأخرجه الفريابي -كما في التغليق ٤/٣٠٦، والفتح ٨/٥٦٦-، وابن جرير ٢٠/٥٤٨. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.عزاه السيوطي إلى محمد بن نصر في كتاب الصلاة.أخرجه ابن جرير ٢٠/٥٤٨. وعزاه السيوطي إلى ابن أبي حاتم.أخرجه ابن جرير ٢٠/٥٤٩.أخرجه ابن جرير ٢٠/٥٤٩، وإسحاق البستي ص٣١٣، وابن أبي حاتم -كما في الفتح ٨/٥٦٩-. وعزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ٢٠/٥٤٨.ذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٤/١٧٥-.تفسير الثعلبي ٨/٣٢٨، وتفسير البغوي ٧/٢٠٦.تفسير مقاتل بن سليمان ٣/٧٨٩.أخرجه ابن جرير ٢٠/٥٤٩-٥٥٠.
43,6," <q>﴿وَكَمۡ أَرۡسَلۡنَا مِن نَّبِیࣲّ فِی ٱلۡأَوَّلِینَ ۝٦ وَمَا یَأۡتِیهِم مِّن نَّبِیٍّ إِلَّا كَانُوا۟ بِهِۦ یَسۡتَهۡزِءُونَ ۝٧﴾</q> - تفسير ٦٩٢٩٥- قال مقاتل بن سليمان: <q>﴿وما يَأْتِيهِمْ مِن نَبِيٍّ﴾</q> ينذرهم العذاب <q>﴿إلّا كانُوا بِهِ﴾</q> يعني: بالعذاب <q>﴿يسْتَهْزِئُونَ﴾</q> بأنّه غيرُ نازِل بهم{1}. (ز) ",footnotes:1:تفسير مقاتل بن سليمان ٣/٧٨٩.
  43,7,""
43,8," <q>﴿فَأَهۡلَكۡنَاۤ أَشَدَّ مِنۡهُم بَطۡشࣰا وَمَضَىٰ مَثَلُ ٱلۡأَوَّلِینَ ۝٨﴾</q> - تفسير ٦٩٢٩٦- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿ومَضى مَثَلُ الأَوَّلِينَ﴾</q>، قال: سُنّتهم{1}. (١٣/١٨٧) ٦٩٢٩٧- عن قتادة بن دعامة -من طريق سعيد- <q>﴿ومَضى مَثَلُ الأَوَّلِينَ﴾</q>، قال: عقوبة الأولين{2}. (١٣/١٨٧) ٦٩٢٩٨- قال مقاتل بن سليمان: <q>﴿فَأَهْلَكْنا﴾</q> بالعذاب <q>﴿أشَدَّ مِنهُمْ بَطْشًا﴾</q> يعني: قُوَّة، <q>﴿ومَضى مَثَلُ﴾</q> يعني: شبه <q>﴿الأَوَّلِينَ﴾</q> في العقوبة حين كذّبوا رسلهم، يقول: هكذا أمتك -يا محمد- في سُنَّة مَن مضى مِن الأمم الخالية في الهلاك{3}. (ز) ",footnotes:1:تفسير مجاهد ص٥٩٢ بلفظ: مضى سنة الأولين، يقول: ينصر الله أنبياءه. وأخرجه الفريابي -كما في التغليق ٤/٣٠٦، وفتح الباري ٨/٥٦٦-٥٦٧-، وابن جرير ٢٠/٥٥٣. وعزاه السيوطي إلى عَبد بن حُمَيد، وابن المنذر.أخرجه عبد الرزاق ٢/١٩٤ من طريق معمر، وعبد بن حميد -كما في التغليق ٤/٣٠٩-، وابن جرير ٢٠/٥٥٣. وعزاه السيوطي إلى ابن أبي حاتم.تفسير مقاتل بن سليمان ٣/٧٨٩.
43,9," <q>﴿وَلَىِٕن سَأَلۡتَهُم مَّنۡ خَلَقَ ٱلسَّمَـٰوَ ٰ⁠تِ وَٱلۡأَرۡضَ لَیَقُولُنَّ خَلَقَهُنَّ ٱلۡعَزِیزُ ٱلۡعَلِیمُ ۝٩﴾</q> - تفسير ٦٩٢٩٩- قال مقاتل بن سليمان: <q>﴿ولَئِنْ سَأَلْتَهُمْ﴾</q> يقول لنبيّه ﷺ: لَئِن سألتَ كفار مكة: <q>﴿مَن خَلَقَ السَّماواتِ والأَرْضَ لَيَقُولُنَّ خَلَقَهُنَّ العَزِيزُ﴾</q> في مُلكه، <q>﴿العَلِيمُ﴾</q> بخلْقه{1}. (ز) ",footnotes:1:تفسير مقاتل بن سليمان ٣/٧٨٩-٧٩٠.
43,10," <q>﴿ٱلَّذِی جَعَلَ لَكُمُ ٱلۡأَرۡضَ مَهۡدࣰا وَجَعَلَ لَكُمۡ فِیهَا سُبُلࣰا لَّعَلَّكُمۡ تَهۡتَدُونَ ۝١٠﴾</q> - قراءات ٦٩٣٠٠- عن عاصم، أنّه قرأ: <q>﴿جَعَلَ لَكُمُ الأَرْضَ مَهْدًا﴾</q> بنصب الميم بغير الألف{1}٥٨٤١. (١٣/١٨٨) ٥٨٤١ اختُلف في قراءة قوله: <q>﴿مهدًا﴾</q>؛ فقرأ قوم: ‹مِهادًا›، وقرأ آخرون: <q>﴿مهدًا﴾</q>. وذكر ابنُ عطية (٧/٥٣٥) القراءتين، ثم علَّق بقوله: «والمعنى واحد، أي: يُتمهد ويُتصرف فيها». <q>﴿ٱلَّذِی جَعَلَ لَكُمُ ٱلۡأَرۡضَ مَهۡدࣰا وَجَعَلَ لَكُمۡ فِیهَا سُبُلࣰا لَّعَلَّكُمۡ تَهۡتَدُونَ ۝١٠﴾</q> - تفسير الآية ٦٩٣٠١- عن قتادة بن دعامة -من طريق سعيد- <q>﴿وجَعَلَ لَكُمْ فِيها سُبُلًا﴾</q>: أي: طُرُقًا{2}. (ز) ٦٩٣٠٢- عن إسماعيل السُّدّيّ -من طريق أسباط- <q>﴿الَّذِي جَعَلَ لَكُمُ الأَرْضَ مَهْدًا﴾</q> قال: بساطًا، <q>﴿وجَعَلَ لَكُمْ فِيها سُبُلًا﴾</q> قال: الطرق{3}. (ز) ٦٩٣٠٣- قال مقاتل بن سليمان: <q>﴿الَّذِي جَعَلَ لَكُمُ الأَرْضَ مَهْدًا﴾</q> يعني: فُرُشًا، <q>﴿وجَعَلَ لَكُمْ فِيها سُبُلًا﴾</q> يعني: طرقًا تسلكونها؛ <q>﴿لَعَلَّكُمْ تَهْتَدُونَ﴾</q> يقول: لكي تعرفوا طرقها{4}٥٨٤٢. (ز) ٥٨٤٢ ذكر ابنُ عطية (٧/٥٣٥) هذا القول، ثم قال: «ويحتمل أن يريد: تهتدون بالنظر والاعتبار». ",footnotes:1:عزاه السيوطي إلى عبد بن حميد. وهي قراءة متواترة، قرأ بها عاصم، وحمزة، والكسائي، وخلف العاشر، وقرأ بقية العشرة: ‹مِهادًا› بكسر الميم وفتح الهاء وألف بعدها. انظر: النشر ٢/٣٢٠.أخرجه عبد الرزاق ٢/١٩٤ من طريق معمر، وابن جرير ٢٠/٥٥٤.أخرجه ابن جرير ٢٠/٥٥٤.تفسير مقاتل بن سليمان ٣/٧٩٠.
