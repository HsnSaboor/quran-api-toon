quran[5]{c,v,t}:
  2,1,"<div class=ar lang=ar><p><h3>مقدمة السورة</h3></p><p><div></p><p><p><span class="item-no">٢٢٤<span class="dash">-</span></span> عن عائشة أم المؤمنين، قالت: لقد نزل بمكة على محمد ﷺ -وإنِّي لَجاريةٌ ألعب-: <span class="qpc-hafs">﴿بل الساعة موعدهم والساعة أدهى وأمر﴾</span> [القمر:٤٦]، وما نزلت سورة البقرة والنساء إلا وأنا عنده{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٢٥<span class="dash">-</span></span> عن عبد الله بن عباس -من طرق- قال: نزلت بالمدينة سورة البقرة{2}. (١/٩٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٢٦<span class="dash">-</span></span> عن عبد الله بن عباس -من طريق خُصَيْفٍ، عن مجاهد-: مَدَنِيَّة{3}. (١/٩٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٢٧<span class="dash">-</span></span> عن عبد الله بن عباس -من طريق عطاء الخراساني-: مدنية، وهي أول ما نزل بالمدينة، نزلت بعد المطففين{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٢٨<span class="dash">-</span></span> عن عبد الله بن الزبير، قال: أُنزِل بالمدينة سورة البقرة{5}. (١/٩٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٢٩<span class="dash">-</span></span> عن عكرمة -من طريق عطاء الخراساني- قال: أول سورة نزلت بالمدينة سورة البقرة{6}. (١/٩٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٣٠<span class="dash">-</span></span> عن عكرمة، والحسن البصري -من طريق يزيدَ النحويِّ-: مدنية{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٣١<span class="dash">-</span></span> عن قتادة -من طرق-: مدنية{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٣٢<span class="dash">-</span></span> عن محمد بن مسلم الزهري: مدنية، نزلت بعد الفاتحة{9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٣٣<span class="dash">-</span></span> عن علي بن أبي طلحة: مدنية{10}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٣٤<span class="dash">-</span></span> قال مقاتل بن سليمان: مدنية، وهي ست وثمانون ومائتا آية{11}<span class=comment-ref>٢٩</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٢٩</span> قال ابنُ كثير (١/٢٤٨): «والبقرة جميعها مدنية بلا خلاف». ثم ذكر الروايات عن السلف في بيان مدنية السورة، ثم قال: «وهكذا قال غيرُ واحد من الأئمة، والعلماء، والمفسرين، ولا خلاف فيه».</div></p><p><div></p><p><p><span class="item-no">٢٣٥<span class="dash">-</span></span> عن أبي أُمامة الباهلي، قال: سمعتُ رسول الله ﷺ يقول: «<b>اقرءوا القرآن؛ فإنه يأتي يوم القيامة شفيعًا لأصحابه، اقرءوا الزهراوين؛ سورة البقرة وسورة آل عمران؛ فإنهما يأتيان يوم القيامة كأنهما غَيايَتان</b>{12}، <b>أو كأنهما غَمامَتان، أو كأنهما فِرقان</b>{13} <b>من طير صَوافَّ</b>{14}، <b>تُحاجّانِ عن صاحبهما، اقرءوا سورة البقرة؛ فإنّ أخذها بركة، وتركها حسرة، ولا تستطيعها البَطَلَة</b>{15}»{16}. (١/٩٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٣٦<span class="dash">-</span></span> عن سَهْل بن سَعْد السّاعِدِيّ، قال: قال رسول الله ﷺ: «<b>إنّ لكل شيء سَنامًا</b>{17}، <b>وسَنام القرآن سورة البقرة، من قرأها في بيته نهارًا لم يدخله الشيطان ثلاثة أيام، ومن قرأها في بيته ليلًا لم يدخله الشيطان ثلاث ليال</b>»{18}. (١/١٠٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٣٧<span class="dash">-</span></span> عن أبي هريرة، قال: قال رسول الله ﷺ: «<b>إن لكل شيء سنامًا، وإنّ سنام القرآن البقرة، وفيها آية هي سيدة آي القرآن؛ آية الكرسي، لا تُقرأ في بيت فيه شيطان إلا خرج منه</b>»{19}. (١/١٠٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٣٨<span class="dash">-</span></span> عن مَعْقِلِ بن يَسار، أنّ رسول الله ﷺ قال: «<b>البقرة سنام القرآن، وذُرْوتُه</b>{20}؛ <b>نزل مع كل آية منها ثمانون مَلَكًا، واستُخْرِجَت: <span class="qpc-hafs">﴿الله لا إله إلا هو الحي القيوم﴾</span></b> [البقرة:٢٥٥] <b>من تحت العرش، فوُصِلَت بها</b>»{21}. (١/١٠٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٣٩<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن مسعود</span>، قال: إنّ لكل شيء سنامًا، وسنام القرآن البقرة، وإنّ الشيطان إذا سمع سورة البقرة تُقرأ خرج من البيت الذي يُقرأ فيه وله ضَريط{22}. (١/١٠٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٤٠<span class="dash">-</span></span> عن <span class="name-1">السائب بن خبّاب</span> -ويُقال: له صحبة- قال: البقرة سنام القرآن{23}. (١/١٠٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٤١<span class="dash">-</span></span> عن أبي سعيد الخُدْرِيِّ، قال: قال رسول الله ﷺ: «<b>السورة التي يُذْكَر فيها البقرة فُسطاطُ القرآن{24}، فتَعَلَّمُوها؛ فإنّ تعلمها بركة، وتركها حسرة، ولا تستطيعها البَطَلَة</b>»{25}. (١/١٠٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٤٢<span class="dash">-</span></span> عن خالد بن مَعْدان موقوفًا، مثله{26}. (١/١٠٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٤٣<span class="dash">-</span></span> عن ربيعة الجُرَشِيِّ، قال: سُئِل رسول الله ﷺ: أيُّ القرآن أفضل؟ قال: «<b>السورة التي تُذكر فيها البقرة</b>». قيل: فأيُّ البقرة أفضل؟ قال: «<b>آية الكرسي، وخواتيم سورة البقرة نزلت من تحت العرش</b>»{27}. (١/١٠٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٤٤<span class="dash">-</span></span> عن أنس، قال: قال رسول الله ﷺ: «<b>لا تقولوا: سورة البقرة، ولا سورة آل عمران، ولا سورة النساء، وكذلك القرآن كله، ولكن قولوا: السورة التي يُذكر فيها البقرة، والسورة التي يُذكر فيها آل عمران، وكذلك القرآن كله</b>»{28}<span class=comment-ref>٣٠</span>. (١/٩٥)</p></p><p></div></p><p><div><span class=comment-ref>٣٠</span> <span class="comment-type-2">انتَقَدَ</span> <u>ابنُ كثير</u> (١/٢٤٩) هذا الحديث، <span class="mustanad">مستندًا إلى السنة، وأقوال السلف</span>، فقال: «هذا حديثٌ غريبٌ، لا يصح رفعُه ... وقد ثبت في الصحيحين عن ابن مسعود: أنّه رمى الجمرة ... ثم قال: هذا مقام الذي أنزلت عليه سورة البقرة». وذكر آثارًا أخرى.</div></p><p><div></p><p><p><span class="item-no">٢٤٥<span class="dash">-</span></span> عن جامع بن شَدّاد، قال: كُنّا في غَزاةٍ فيها عبد الرحمن بن يزيد، ففشا في الناس أنّ ناسًا يكرهون أن يقولوا: سورة البقرة وآل عمران، حتى يقولوا: السورة التي يذكر فيها البقرة، والسورة التي يذكر فيها آل عمران. فقال عبد الرحمن: إنِّي لَمَعَ <span class="name-1">عبدِ الله بن مسعود</span> إذ استبطن الوادي، فجعل الجمرة على حاجبه الأيمن، ثم استقبل الكعبة، فرماها بسبع حَصَياتٍ، يكبّر مع كل حصاة، فلما فرغ قال: من ههنا -والذي لا إله غيره- رمى الذي أُنزِلت عليه سورة البقرة{29}. (١/٩٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٤٦<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عمر</span> -من طريق نافع- قال: لا تقولوا: سورة البقرة. ولكن قولوا: السورة التي يُذكر فيها البقرة{30}. (١/٩٥)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿الۤمۤ ۝١﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٢٤٧<span class="dash">-</span></span> عن ابن عباس، عن جابر بن عبد الله بن رِئاب، قال: مرَّ أبو ياسر بن أخْطَبَ في رجال من يهودَ برسول الله ﷺ، وهو يتلو فاتحة سورة البقرة: <span class="qpc-hafs">﴿الم ذلك الكتاب﴾</span>، فأتى أخاه حُيَيّ بن أخْطَب في رجال من اليهود، فقال: تعلمون -والله- لقد سمعت محمدًا يتلو فيما أُنزِل عليه: <span class="qpc-hafs">﴿الم ذلك الكتاب﴾</span>. فقالوا: أنتَ سَمِعْتَه؟ قال: نعم. فمشى حُيَيٌّ في أولئك النفر إلى رسول الله ﷺ، فقالوا: يا محمد، ألم يُذكر أنك تتلو فيما أُنزِل عليك: <span class="qpc-hafs">﴿الم ذلك الكتاب﴾</span>؟ قال: «<b>بلى</b>». قالوا: قد جاءك بهذا جبريل من عند الله؟ قال: «<b>نعم</b>». قالوا: لقد بعث الله قبلك أنبياء، ما نعلمه بَيَّن لنبيٍّ منهم ما مُدَّة ملكه، وما أجل أمته غيرك. فقال حُيَيُّ بن أخطب -وأقبل على مَن كان معه-: الألِف واحدة، واللام ثلاثون، والميم أربعون، فهذه إحدى وسبعون سنة، أفتدخلون في دين نبيٍّ إنما مدة ملكه وأجل أمته إحدى وسبعون سنة؟! ثم أقبل على رسول الله ﷺ، فقال: يا محمد، هل مع هذا غيره؟ قال: «<b>نعم</b>». قال: وما ذاك؟ قال: «<b><span class="qpc-hafs">﴿المص﴾</span></b>». قال: هذه أثقل وأطول؛ الألف واحدة، واللام ثلاثون، والميم أربعون، والصاد تسعون، فهذه إحدى وستون ومائة سنة، هل مع هذا يا محمد غيره؟ قال: «<b>نعم</b>». قال: وما ذاك؟ قال «<b><span class="qpc-hafs">﴿الر﴾</span></b>». قال: هذه أثقل وأطول؛ الألف واحدة، واللام ثلاثون، والراء مائتان، فهذه إحدى وثلاثون ومائتا سنة، فهل مع هذا يا محمد غيره؟ قال: «<b>نعم</b>، <b><span class="qpc-hafs">﴿المر﴾</span></b>». قال: فهذه أثقل وأطول؛ الألف واحدة، واللام ثلاثون، والميم أربعون، والراء مائتان، فهذه إحدى وسبعون سنة ومائتان. ثم قال: لقد لُبّس علينا أمرك، يا محمد، حتى ما ندري أقليلًا أُعْطِيتَ أم كثيرًا؟ ثم قاموا، فقال أبو ياسر لأخيه حُيَيّ ومَن معه مِن الأحبار: ما يُدريكم، لعله قد جُمع هذا لمحمد كلُّه؛ إحدى وسبعون، وإحدى وستون ومائة، وإحدى وثلاثون ومائتان، وإحدى وسبعون ومائتان، فذلك سبعمائة وأربع وثلاثون. فقالوا: لقد تشابه علينا أمره. فيزعمون أن هذه الآيات نزلت فيهم: <span class="qpc-hafs">﴿هو الذي أنزل عليك الكتاب منه آيات محكمات هن أم الكتاب وأخر متشابهات﴾</span> [آل عمران:٧]{31}<span class=comment-ref>٣١</span>. (١/١٢٤)</p></p><p></div></p><p><div><span class=comment-ref>٣١</span> <span class="comment-type-2">انتَقَد</span> <u>ابنُ كثير</u> (١/٢٥٧-٢٥٨) هذا الحديث، فقال: «وأمّا مَن زعم أنها دالَّةٌ على معرفة المُدَد، وأنه يُسْتَخرج من ذلك أوقات الحوادث والفتن والملاحم؛ فقد ادَّعى ما ليس له، وطار في غير مطاره، وقد ورد في ذلك حديث ضعيف، وهو مع ذلك أدل على بطلان هذا المسلك من التمسك به على صحته». ثمَّ ساق الأثر، وتعقَّبه بقوله: «فهذا الحديث مداره على محمد بن السائب الكلبي، وهو ممن لا يحتج بما انفرد به، ثم كان مقتضى هذا المسلك إن كان صحيحًا أن يُحسَبَ ما لكل حرف من الحروف الأربعة عشر التي ذكرناها، وذلك يبلغ منه جملة كثيرة، وإن حُسبَت مع التكرر فأتم وأعظم».</div></p><p><div></p><p><p><span class="item-no">٢٤٨<span class="dash">-</span></span> قال <span class="name-1">أبو بكر الصديق</span>: في كل كتاب سِرٌّ، وسِرُّ الله تعالى في القرآن أوائل السور{32}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٤٩<span class="dash">-</span></span> وقال <span class="name-1">علي بن أبي طالب</span>: لكل كتاب صفوة، وصفوة هذا الكتاب حروف التهجي{32}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٥٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن مسعود</span> -من طريق مُرَّة الهمداني- في قوله: <span class="qpc-hafs">﴿الم﴾</span>، قال: هو اسم الله الأعظم{34}. (١/١٢٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٥١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن مسعود</span> و<span class="name-1">ناس من أصحاب النبي</span> ﷺ -من طريق السدي، عن مُرَّة الهمداني-= (١/١٢١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٥٢<span class="dash">-</span></span> و<span class="name-1">عبد الله بن عباس</span> -من طريق السُّدِّي، عن أبي مالك وأبي صالح- قالوا: <span class="qpc-hafs">﴿الم﴾</span> حروف اشْتُقَّتْ من حروف هجاء أسماء الله{35}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٥٣<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق أبي الضُّحى- في قوله <span class="qpc-hafs">﴿الم﴾</span>، قال: أنا الله أعلم{36}. (١/١٢١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٥٤<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق سعيد بن جبير- في قوله: <span class="qpc-hafs">﴿الم﴾</span>، و<span class="qpc-hafs">﴿حم﴾</span>، و<span class="qpc-hafs">﴿ن﴾</span>، قال: اسم مُقَطَّع{37}<span class=comment-ref>٣٢</span>. (١/١٢١)</p></p><p></div></p><p><div><span class=comment-ref>٣٢</span> بيَّن <u>ابنُ جرير</u> (١/٢١٥-٢١٨) أنّ أقوال ابن مسعود من طريق السدي، وابن عباس من طريق السدي وأبي الضحى، وسعيد ابن جبير، المراد بها: أنها حروف مقطعة من أسماء وأفعال،كل حرف من ذلك لمعنًى غير معنى الحرف الآخر.</p><p>ثم <span class="comment-type-1">وجَّه</span> ذلك بأن القائلين بها نَحَوْا بذلك منحى العرب في الاكتفاء بذكر حرف واحد من الكلمة إذا كان فيه دلالة على ما حُذِف منها، وأن ذلك مستفيضٌ ظاهرٌ في كلام العرب، ثم استشهد على صحة ذلك عند العرب بأبيات من الشعر، وبيَّن أن الأمر في الحروف المقطعة على هذا القول كذلك، في كون كل حرف منها دالًّا على كلمة تامة.</p><p>و<span class="comment-type-2">انتقد</span> <u>ابنُ كثير</u> (١/٢٥٣) هذا بقوله: «وما أنشدوه من الشواهد على صحة إطلاق الحرف الواحد على بقية الكلمة، فإنّ في السياق ما يدل على ما حُذف بخلاف هذا».</p><p>و<span class="comment-type-3">رجَّح</span> <u>ابنُ عطية</u> (١/١٠١) أنّ الصواب في هذه الحروف تَلَمُّسُ تفسيرِها، وأن ذلك قول الجمهور، معلِّلًا ذلك بصنيع العرب الذي أشار إليه ابن جرير.</div></p><p><div></p><p><p><span class="item-no">٢٥٥<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي بن أبي طلحة- في قوله: <span class="qpc-hafs">﴿الم﴾</span>، و<span class="qpc-hafs">﴿المص﴾</span>، و<span class="qpc-hafs">﴿الر﴾</span>، و<span class="qpc-hafs">﴿المر﴾</span>، و<span class="qpc-hafs">﴿كهيعص﴾</span>، و<span class="qpc-hafs">﴿طه﴾</span>، و<span class="qpc-hafs">﴿طسم﴾</span>، و<span class="qpc-hafs">﴿طس﴾</span>، و<span class="qpc-hafs">﴿يس﴾</span>، و<span class="qpc-hafs">﴿ص﴾</span>، و<span class="qpc-hafs">﴿حم﴾</span>، و<span class="qpc-hafs">﴿ق﴾</span>، و<span class="qpc-hafs">﴿ن﴾</span>، قال: هو قَسَمٌ أقْسَمَه الله، وهو من أسماء الله{38}. (١/١٢١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٥٦<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، قال: فواتح السور أسماء من أسماء الله{39}. (١/١٢٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٥٧<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق السدي- في قوله: <span class="qpc-hafs">﴿الم﴾</span>، و<span class="qpc-hafs">﴿حم﴾</span>، و<span class="qpc-hafs">﴿طس﴾</span>، قال: هي اسم الله الأعظم{40}. (١/١٢٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٥٨<span class="dash">-</span></span> عن <span class="name-2">أبي العالية</span> -من طريق الربيع بن أنس- في قول الله -تعالى ذِكْرُه-: <span class="qpc-hafs">﴿الم﴾</span>، قال: هذه الأحرف من التسعة والعشرين حرفًا، دارت فيها الألسن كلها، ليس منها حرف إلا وهو مفتاح اسم من أسمائه، وليس منها حرف إلا وهو في آلائه وبلائه، وليس منها حرفٌ إلا وهو في مدة قوم وآجالهم. وقال عيسى ابن مريم: وعجيب ينطقون في أسمائه، ويعيشون في رزقه، فكيف يكفرون؟! قال: فالألف: مفتاح اسمه الله، واللام: مفتاح اسمه لطيف، والميم: مفتاح اسمه مجيد. والألف: آلاء الله، واللام: لطفه، والميم: مجده. الألف: سنة، واللام: ثلاثون سنة، والميم: أربعون{41}. (١/١٢٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٥٩<span class="dash">-</span></span> عن <span class="name-2">الربيع بن أنس</span> -من طريق أبي جعفر الرازي-، مثله{42}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٦٠<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span> -من طريق عطاء بن السائب- في قوله: <span class="qpc-hafs">﴿الم﴾</span>، قال: أنا الله أعلم{43}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٦١<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span> أنّه قال: هي أسماء الله تعالى مُقَطَّعة، لو علم الناسُ تَأْلِيفَها لَعَلِمُوا اسم الله الأعظم{44}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٦٢<span class="dash">-</span></span> عن <span class="name-2">مجاهد</span> -من طريق شبل، عن ابن أبي نَجِيح- في قوله: <span class="qpc-hafs">﴿الم﴾</span>، قال: اسم من أسماء القرآن{45}. (١/١٢٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٦٣<span class="dash">-</span></span> عن <span class="name-2">مجاهد</span> -من طريق ابن جُرَيْج- قال: <span class="qpc-hafs">﴿الم﴾</span>، و<span class="qpc-hafs">﴿حم﴾</span>، و<span class="qpc-hafs">﴿ألمص﴾</span>، و<span class="qpc-hafs">﴿ص﴾</span> فواتح افتتح الله بها القرآن{46}<span class=comment-ref>٣٣</span>. (١/١٢٣)</p></p><p></div></p><p><div><span class=comment-ref>٣٣</span> <span class="comment-type-1">وجَّه</span> <u>ابنُ جرير</u> (١/٢١٥) ذلك بما نقله عن بعض أهل العربية أنه قال: «ذلك أدِلَّةٌ على انقضاء سُورة وابتداءٍ في أخرى، وعلامةٌ لانقطاع ما بينهما، كما جعلت (بل) في ابتداء قصيدةٍ دلالةً على ابتداء فيها، وانقضاءِ أخرى قَبلها، كما ذكرنا عن العرب إذا أرادوا الابتداءَ في إنشاد قصيدة، قالوا: بل ... و(بل) ليست من البيت ولا داخلةً في وزنه، ولكن لِيَدُلَّ به على قطع كلام وابتداء آخر».</p><p>وذكر نحوه <u>ابنُ عطية</u> (١/١٠٠).</div></p><p><div></p><p><p><span class="item-no">٢٦٤<span class="dash">-</span></span> عن <span class="name-2">مجاهد</span> -من طريق خُصَيْف- قال: فواتح السور كلها <span class="qpc-hafs">﴿الم﴾</span>، و<span class="qpc-hafs">﴿الر﴾</span>، و<span class="qpc-hafs">﴿حم﴾</span>، و<span class="qpc-hafs">﴿ق﴾</span>، وغير ذلك هجاء موضوع{47}. (١/١٢٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٦٥<span class="dash">-</span></span> وقال <span class="name-2">مجاهد</span>: هي أسماء السور{48}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٦٦<span class="dash">-</span></span> عن <span class="name-2">الضحاك بن مُزاحِم</span> -من طريق أبي رَوْق- قال: <span class="qpc-hafs">﴿الم﴾</span>: أنا الله أعلم{49}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٦٧<span class="dash">-</span></span> عن <span class="name-2">عكرمة</span> -من طريق خالد الحذاء- قال: <span class="qpc-hafs">﴿الم﴾</span> قَسَمٌ{50}. (١/١٢٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٦٨<span class="dash">-</span></span> عن <span class="name-2">سالم بن عبد الله</span>، قال: <span class="qpc-hafs">﴿الم﴾</span>، و<span class="qpc-hafs">﴿حم﴾</span>، و<span class="qpc-hafs">﴿ن﴾</span>، ونحوها أسماء الله مُقَطَّعَة{51}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٦٩<span class="dash">-</span></span> عن داود بن أبي هند، قال: كنت أسأل <span class="name-2">الشعبي</span> عن فواتح السور. فقال: يا داود، إنّ لكل كتاب سِرًّا، وإنّ سِرَّ هذا القرآن فواتح السور، فدعها وسَلْ عمّا بدا لك{52}. (١/١٢٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٧٠<span class="dash">-</span></span> عن <span class="name-2">عامر الشعبي</span> -من طريق إسماعيل بن سالم- أنّه سُئِل عن فواتح السور؛ نحو: <span class="qpc-hafs">﴿الم﴾</span>، و<span class="qpc-hafs">﴿ألر﴾</span>. قال: هي أسماء من أسماء الله، مُقَطَّعة الهجاء، فإذا وصَلْتَها كانَتِ اسمًا من أسماء الله{53}. (١/١٢٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٧١<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span>، قال: <span class="qpc-hafs">﴿الم﴾</span>، و<span class="qpc-hafs">﴿طسم﴾</span> فواتح يفتتح الله بها السور{54}. (١/١٢٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٧٢<span class="dash">-</span></span> قال يحيى بن سلام: كان <span class="name-2">الحسن</span> يقول: ما أدري ما تفسير <span class="qpc-hafs">﴿الم﴾</span>، و<span class="qpc-hafs">﴿الر﴾</span>، و<span class="qpc-hafs">﴿ألمص﴾</span>، وأشباه ذلك من حروف المعجم{55}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٧٣<span class="dash">-</span></span> عن <span class="name-2">قتادة</span> -من طريق مَعْمَر- في قوله: <span class="qpc-hafs">﴿الم﴾</span>، قال: اسم من أسماء القرآن{56}. (١/١٢٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٧٤<span class="dash">-</span></span> قال <span class="name-2">محمد بن كعب القرظي</span>: الألف: آلاء الله، واللام: لطفه، والميم: ملكه{57}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٧٥<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السدي</span> -من طريق إسماعيل بن أبي خالد- قال: فواتح السور كلها من أسماء الله{58}. (١/١٢٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٧٦<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّي</span> -من طريق أسباط- قال: أما <span class="qpc-hafs">﴿الم﴾</span> فهو حرف اشْتُقَّ من حروف اسم الله{59}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٧٧<span class="dash">-</span></span> عن <span class="name-2">زيد بن أسلم</span> -من طريق ابنه عبد الرحمن- قال: <span class="qpc-hafs">﴿الم﴾</span> ونحوها أسماء السور{60}<span class=comment-ref>٣٤</span>. (١/١٢٤)</p></p><p></div></p><p><div><span class=comment-ref>٣٤</span> <span class="comment-type-4">علَّق</span> <u>ابنُ كثير</u> (١/٢٥٠) على هذا الأثر بقوله: «ويعتضد هذا بما ورد في الصحيحين، عن أبي هريرة: أنّ رسول الله ﷺ كان يقرأ في صلاة الصبح يوم الجمعة: <span class="qpc-hafs">﴿ألم﴾</span> السجدة، و<span class="qpc-hafs">﴿هل أتى على الإنسان﴾</span>».</div></p><p><div></p><p><p><span class="item-no">٢٧٨<span class="dash">-</span></span> عن <span class="name-2">زيد بن أسلم</span>: <span class="qpc-hafs">﴿الم﴾</span> اسم من أسماء القرآن{61}<span class=comment-ref>٣٥</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٣٥</span> <span class="comment-type-1">وجَّه</span> <u>ابنُ جرير</u> (١/٢١٣-٢١٥) هذا الأثر بتوجيهين: <b>الأول</b>: أن <span class="qpc-hafs">﴿ألم﴾</span> اسم للقرآن، فيكون تأويل <span class="qpc-hafs">﴿ألم ذَلِكَ الكِتابُ﴾</span> على معنى القسم، كأنه قال: والقرآن، هذا الكتاب لا ريب فيه. <b>الثاني</b>: أنه اسمٌ من أسماء السورة التي تُعرف به، فيَفهم السامع من القائل يقول: قرأت اليوم <span class="qpc-hafs">﴿ألمص﴾</span>، <span class="qpc-hafs">﴿ن﴾</span>، أيَّ السُّوَر التي قرأها من سُوَر القرآن.</p><p><span class="comment-type-1">ووجَّهه</span> <u>ابنُ كثير</u> (١/٢٥١) بقوله: «ولعلَّ هذا يرجع إلى معنى قول عبد الرحمن بن زيد: أنّه اسم من أسماء السور، فإنّ كل سورة يُطْلَق عليها اسم القرآن، فإنه يبعد أن يكون <span class="qpc-hafs">﴿ألمص﴾</span> اسمًا للقرآن كله؛ لأن المتبادر إلى فهم سامع من يقول: قرأت <span class="qpc-hafs">﴿ألمص﴾</span>. إنما ذلك عبارة عن سورة الأعراف، لا لمجموع القرآن».</div></p><p><div></p><p><p><span class="item-no">٢٧٩<span class="dash">-</span></span> عن <span class="name-2">الربيع بن أنس</span>: في قوله: <span class="qpc-hafs">﴿الم﴾</span>، قال: ألف: مفتاح اسمه الله، ولام: مفتاح اسمه لطيف، وميم: مفتاح اسمه مجيد{62}. (١/١٢٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٨٠<span class="dash">-</span></span> عن <span class="name-2">الربيع بن أنس</span> -من طريق أبي جعفر الرازي- في قول الله: <span class="qpc-hafs">﴿الم﴾</span>، قال: هذه الأحرف من التسعة والعشرين حرفًا، دارت فيها الألسُن كلها، ليس منها حرفٌ إلا وهو مِفتاح اسم من أسمائه، وليس منها حرف إلا وهو في آلائه وبَلائه، وليس منها حرف إلا وهو في مُدّةِ قوم وآجالهم. وقال عيسى ابن مريم وعجب: ينطقون في أسمائه، ويعيشون في رزقه، فكيف يكفرون به؟! قال: الألف: مفتاح اسمه «الله»، واللام: مفتاح اسمه «لطيف»، والميم: مفتاح اسمه «مجيد». والألف: آلاء الله، واللام: لطفه، والميم: مجده. الألف: سنةٌ، واللام: ثلاثون سنة، والميم: أربعون سنة{63}<span class=comment-ref>٣٦</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٣٦</span> بيَّن <u>ابنُ جرير</u> (١/٢١٨-٢٢٠) أنّ القائلين بذلك <span class="comment-type-1">وجَّهوا</span> ذلك إلى أنّ كلَّ حرف من الحروف المقطعة بعضُ حروفِ كلمةٍ تامة استُغْنِيَ بدلالته عَلى تَمامه عن ذكر تمامه، وإنما أُفْرِد كلُّ حرف من ذلك، وقصَّر به عن تمام حروف الكلمة، أنّ جميعَ حُروف الكلمة لو أُظْهِرت لم تدلّ الكلمة التي تُظهر إلا على معنى واحد، لا على معنيين وأكثر منهما، وإذا كان الله -جل ثناؤه- قد أراد الدلالة بكلّ حرف منها على معانٍ كثيرة لشيء واحد لم يَجُز إلا أن يُفرَد الحرفُ الدالُّ على تلك المعاني، لِيَعلمَ المخاطبون به أنّ الله ﷿لم يقصد بما خاطبهم به مَعنًى واحدًا، وإنما قصد الدلالةَ به على أشياء كثيرة.</p><p>و<span class="comment-type-2">انتقد</span> <u>ابنُ كثير</u> (١/٢٥٣-٢٥٤ بتصرف) هذا التوجيه بقوله: «هذا ليس كما ذكره أبو العالية -يعني الأثر السابق-، فإنّ أبا العالية زعم أنّ الحرف دلَّ على هذا، وعلى هذا، وعلى هذا معًا ...، ودلالة الحرف الواحد على اسم يمكن أن يدل على اسم آخر من غير أن يكون أحدهما أولى من الآخر في التقدير أو الإضمار بوضع ولا بغيره، فهذا مما لا يُفْهَم إلا بتوقيف، والمسألة مختلف فيها، وليس فيها إجماع حتى يُحكَم به».</div></p><p><div></p><p><p><span class="item-no">٢٨١<span class="dash">-</span></span> قال <span class="name-2">أبو رَوْق عطية بن الحارث الهمداني</span>: إنها تسكيت للكفار، وذلك أنّ رسول الله ﷺ كان يجهر بالقراءة في الصلوات كلها، وكان المشركون يقولون: <span class="qpc-hafs">﴿لا تسمعوا لهذا القرآن والغوا فيه لعلكم تغلبون﴾</span> [فصلت:٢٦]، فربما صَفَّقوا، وربما صَفَّرُوا، وربما لَغطوا لِيُغَلِّطُوا النبيَّ ﷺ، فلما رأى رسول الله ذلك أسَرَّ في الظُّهْر والعصر، وجهر في سائرها، وكانوا أيضًا يأتونه ويُؤْذُونه، فأنزل الله تعالى هذه الحروف المقطعة، فلمّا سمعوها بَقَوْا مُتَحَيِّرِين مُتَفَكِّرِين؛ فاشتغلوا بذلك عن إيذائه وتغليطِه، فكان ذلك سببًا لاستماعهم، وطريقًا إلى انتفاعهم{64}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٨٢<span class="dash">-</span></span> عن <span class="name-3">جعفر الصادق</span>-من طريق علي بن موسى الرِّضا-: وقد سُئِل عن قوله: <span class="qpc-hafs">﴿الم﴾</span>. فقال: في الألف ست صفات من صفات الله: الابتداء؛ لأن الله تعالى ابتدأ جميع الخلق، والألف ابتداء الحروف. والاستواء؛ فهو عادل غير جائر، والألف مُسْتَوٍ بذاته. والانفراد؛ والله فَرْد، والألف فَرْد. واتصال الخلق بالله؛ والله لا وصلة له بالخلق، وكلهم يحتاجون إليه، والله غنيٌّ عنهم، وكذلك الألف لا يتصل بحرف، والحروف متصلة به، وهو منقطع عن غيره، والله بائن بجميع صفاته من خلقه. ومعناه من الألفة؛ فكما أن الله سبب إلْفَةِ الخلق، فكذلك الألف، عليه تَأَلَّفت الحروف، وهو سبب إلْفَتُها{65}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٨٣<span class="dash">-</span></span> عن <span class="name-3">ابن جُرَيْج</span> -من طريق حَجّاج- قال: <span class="qpc-hafs">﴿الم﴾</span> اسم من أسماء القرآن{66}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٨٤<span class="dash">-</span></span> عن <span class="name-3">ابن جُرَيْج</span> -من طريق محمد بن ثور- قال: إنّ اليهود كانوا يَجِدون محمدًا وأمته: أنّ محمدًا مبعوث. ولا يدرون ما مُدَّة أُمَّة محمد، فلمّا بعث الله محمدًا ﷺ، وأنزل <span class="qpc-hafs">﴿الم﴾</span>؛ قالوا: قد كُنّا نعلم أن هذه الأمة مبعوثة، وكنا لا ندري كم مدتها، فإن كان محمد صادقًا فهو نبي هذه الأمة، قد بُيّن لنا كم مدة محمد -لأن <span class="qpc-hafs">﴿الم﴾</span> في حساب جُمَّلِهم{67} إحدى وسبعون سنة-، فما نصنع بدين إنما هو واحد وسبعون سنة؟! فلمّا نزلت <span class="qpc-hafs">﴿الر﴾</span> -وكانت في حساب جُمَّلهم مائتي سنة وإحدى وثلاثين سنة-، فقالوا: هذه الآن مائتان وإحدى وثلاثون سنة، وواحدة وسبعون. قيل: ثم أُنزل <span class="qpc-hafs">﴿المر﴾</span> -فكان في حساب جُمَّلِهم مائتي سنة وإحدى وسبعين سنة- في نحو هذا من صدور السور. فقالوا: قد التبس علينا أمرُه{68}. (١/١٢٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٨٥<span class="dash">-</span></span> وقال <span class="name-3">عبد الرحمن بن زيد بن أسلم</span>: هي أسماء السور المُفْتَتَحَة بها{44}<span class=comment-ref>٣٧</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٣٧</span> <span class="comment-type-3">رجَّح</span> <u>ابنُ جرير</u> (١/٢٢٣-٢٢٥) أنّ الحروف المقطعة في فواتح السور تحوي سائر ما قاله مفسرو السلف؛ لأن الله -جلّ ثناؤه- لو أراد بذلك الدلالة على معنًى واحد دون سائر المعاني غيره لأبان ذلك لهم رسول الله ﷺ، وفي تركه ﷺ إبانةَ ذلك أوضحُ الدليل على أنه مُرادٌ به جميعُ وجوهه التي هو لها محتمل، إذ لم يكن مستحيلًا في العقل وجهٌ منها أن يكون من تأويله ومعناه، كما كان غير مستحيل اجتماعُ المعاني الكثيرة للكلمة الواحدة باللفظ الواحد في كلام واحد.</p><p>ونقل <u>ابنُ عطية</u> (١/٩٩-١٠١) اختلافًا في التكلم في تفسير الحروف المقطعة، أو الامتناع عن تفسيرها، ثم قال: «والصواب ما قاله الجمهور: أن تُفَسَّر هذه الحروف، ويُلْتَمَس لها التأويل».</p><p>و<span class="comment-type-4">علَّق</span> <u>ابنُ كثير</u> (١/٢٥٥-٢٥٧)، فقال: «ولم يُجمِع العلماء فيها على شيء معين، وإنما اختلفوا، فمَن ظهر له بعض الأقوال بدليلٍ فعليه اتِّباعه، وإلا فالوقف حتى يتبين».</p><p>وفي بيان الحكمة من إيراد هذه الحروف في أوائل السور نقل <u>ابنُ كثير</u> (١/٢٥٧) قولَ مَن قال: «إنما ذُكِرَت هذه الأحرف في أوائل السور التي ذُكِرَت فيها بيانًا لإعجاز القرآن، وأن الخلق عاجزون عن معارضته بمثله، هذا مع أنه تركب من هذه الحروف المقطعة التي يتخاطبون بها». ثم <span class="comment-type-3">رجَّح</span> ذلك بقوله: «ولهذا كل سورة افتتحت بالحروف فلا بد أن يذكر فيها الانتصار للقرآن، وبيان إعجازه وعظمته، وهذا معلوم بالاستقراء، وهو الواقع في تسع وعشرين سورة، ولهذا يقول تعالى: <span class="qpc-hafs">﴿ألم * ذَلِكَ الكِتابُ لا رَيْبَ فِيهِ﴾</span> [البقرة:١-٢]، <span class="qpc-hafs">﴿ألم * اللَّهُ لا إلَهَ إلا هُوَ الحَيُّ القَيُّومُ * نزلَ عَلَيْكَ الكِتابَ بِالحَقِّ مُصَدِّقًا لِما بَيْنَ يَدَيْهِ﴾</span> [آل عمران:١-٣]، <span class="qpc-hafs">﴿ألمص * كِتابٌ أُنزلَ إلَيْكَ فَلا يَكُنْ فِي صَدْرِكَ حَرَجٌ مِنهُ﴾</span> [الأعراف:١-٢]، <span class="qpc-hafs">﴿ألر كِتابٌ أنزلْناهُ إلَيْكَ لِتُخْرِجَ النّاسَ مِنَ الظُّلُماتِ إلى النُّورِ بِإذْنِ رَبِّهِمْ﴾</span> [إبراهيم:١] ... وغير ذلك من الآيات الدالة على صحة ما ذهب إليه هؤلاء لِمَن أمْعَن النظر».</div></p><p><h3><span class="qpc-hafs">﴿الۤمۤ ۝١﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٢٨٦<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، قال: آخرُ حرف عارَضَ به جبريلُ ﵇ النبي ﷺ: <span class="qpc-hafs">﴿ألم ذلك الكتاب لا ريب فيه هدىً للمتقين﴾</span>{70}. (١/١٢٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٨٧<span class="dash">-</span></span> عن <span class="name-2">أبي عبد الرحمن السلمي</span>: أنّه كان يَعُدُّ <span class="qpc-hafs">﴿الم﴾</span>، و<span class="qpc-hafs">﴿حم﴾</span> آية{71}. (١/١١٨)</p></p><p></div></p></div>",footnotes:1:أخرجه البخاري ٦/١٨٥ (٤٩٩٣).|2:أخرجه أبو جعفر النحاس في الناسخ والمنسوخ ٢/٣١٧. وعزاه السيوطي إلى ابن مردويه.</p><p>قال السيوطي في الإتقان في علوم القرآن ١/٥٠: «إسناده جيد، رجاله كلهم ثقات، من علماء العربية المشهورين».|3:أخرجه البيهقي في دلائل النبوة ٧/١٤٣-١٤٤.|4:أخرجه ابن الضريس في فضائل القرآن ١/٣٣-٣٥.|5:عزاه السيوطي إلى ابن مردويه.|6:أخرجه الثعلبي في تفسيره ١/١٣٥، والواحدي في أسباب النزول ص١٢١. وعزاه السيوطي إلى أبي داود في الناسخ والمنسوخ.|7:أخرجه البيهقي في دلائل النبوة ٧/١٤٢-١٤٣.|8:أخرجه الحارث المحاسبي في فهم القرآن ص٣٩٥ من طريق سعيد ومعمر، وأبو بكر ابن الأنباري -كما في الإتقان ١/٥٧- من طريق همام.|9:تنزيل القرآن ص ٣٧، ٤٢.|10:أخرجه أبو عبيد في فضائله (ت: الخياطي) ٢/٢٠٠.|11:تفسير مقاتل بن سليمان ١/٨٣.|12:مثنّى غَيايةٍ -بياءين مثناتين تحتيتين- وقد ذكر لها في القاموس عدة معانٍ، المناسب منها هنا هو: كل ما أظلَّ الإنسان من فوق رأسه كالسَّحابة ونحوها. (غيي).|13:أي قطيعان، وفي القاموس: والفِرْق -بالكسر-: القطيع من الغنم العظيم ومن البقر أو الظباء أو من الغنم فقط أو من الغنم الضالَّة، أو ما دون المئة، والقِسم من كل شيء ... إلخ. (فَرَقَ).|14:صواف: باسطات أجنحتها. لسان العرب (صفف).|15:في صحيح مسلم: البَطَلة: السَّحرة. وفي النهاية في غريب الحديث (بطل): قيل هم السحرة. يقال: أبطل إذا جاء بالباطل.|16:أخرجه مسلم ١/٥٥٣ (٨٠٤).|17:سنام الشيء: أعلاه. لسان العرب (سنم).|18:أخرجه ابن حبان ٣/٥٩ (٧٨٠).</p><p>قال الهيثمي في المجمع ٦/٣١٢ (١٠٨١٧): «فيه سعيد بن خالد الخزاعي المدني، وهو ضعيف». [كذا في المجمع: سعيد بن خالد، والصحيح: خالد بن سعيد، كما في سند ابن حبان. من حاشية تخريج ابن حبان ٣/٦٠]. وقال الألباني في الضعيفة ٣/٥٢٥ (١٣٤٩): «ضعيف».|19:أخرجه الترمذي ٥/١٤٨ (٣٠٩٤)، والحاكم ١/٧٤٨ (٢٠٥٨، ٢٠٥٩، ٢٠٦٠)، ٢/٢٨٥ (٣٠٢٧)، وسعيد بن منصور في التفسير من سننه ٣/٩٥٠ (٤٢٤).</p><p>قال الترمذي: «هذا حديث غريب، لا نعرفه إلا من حديث حكيم بن جبير، وقد تكلم شعبة في حكيم بن جبير، وضعّفه». وقال الحاكم: «هذا حديث صحيح الإسناد، ولم يُخَرِّجاه». وقال الألباني في الضعيفة ٣/٥٢٤ (١٣٤٨): «ضعيف، غير أنّ طرفه الأول قد وجد ما يشهد له».|20:ذروة السنام: أعلاه. لسان العرب (ذرا).|21:أخرجه أحمد ٣٣/٤١٧ (٢٠٣٠٠).</p><p>قال الهيثمي في المجمع ٦/٣١١ (١٠٨١٠): «في سنن أبي داود منه طرف، رواه أحمد، وفيه راوٍ لم يُسَمّ، وبقية رجاله رجال الصحيح، ورواه الطبراني، وأسقط المبهم». وقال الألباني في الضعيفة ١٤/٧٨٧ (٦٨٤٣): «منكر».|22:أخرجه الدارمي ٢/٤٤٧، وابن الضريس (١٧٧)، والطبراني (٨٦٤٤)، والحاكم ١/٥٦١، والبيهقي في الشعب (٢٤٨٧). وذكره محمد بن نصر في قيام الليل ص٦٨ دون إسناد.|23:أخرجه البخاري في تاريخه ٤/١٥١-١٥٢.|24:البقرة فُسطاط القرآن: أي أنّ سوره تجتمع حولها، كما أنّ فسطاط المِصْرِ: مجتمع أهله حول جامعه. ينظر: لسان العرب (فسط).|25:أورده الديلمي ٢/٣٤٤ (٣٥٥٩).</p><p>قال الألباني في الضعيفة ٨/٢١٤ (٣٧٣٨): «موضوع».|26:أخرجه الدارمي ٢/٤٤٦.|27:أخرجه البغوي في معجم الصحابة ٢/٤٠٠ (٧٦٤)، وابن عساكر في تاريخه -كما في مختصر ابن منظور ٨/٢٨٠-.</p><p>وفي إسناده عبد الله بن لهيعة، وهو ضعيف. انظر ترجمته في: ميزان الاعتدال ٢/٤٧٥، وتهذيب التهذيب ٥/٣٧٣. وفي سماع ربيعة الجرشي من النبي ﷺ كلام، قال البغوي: «يُحَدِّث عن النبي ﷺ، ويُشَكُّ في سماعه».|28:أخرجه الطبراني في الأوسط ٦/٤٧ (٥٧٥٥)، والبيهقي في الشعب ٤/١٧٢ (٢٣٤٦).</p><p>قال البيهقي: «عبيس بن ميمون منكر الحديث، وهو لا يصح، وإنما يروى فيه عن ابن عمر من قوله». وقال الهيثمي في المجمع ٧/١٥٧ (١١٦١٧): «وفيه عبيس بن ميمون، وهو متروك».|29:أخرجه أبو داود الطيالسي ١/٢٥١ (٣١٨)، وأخرج النسائي ٥/٢٧٤ (٣٠٧٣)، والبيهقي ٥/٢١٠ (٩٥٤٧) عن الأعمش أنّه سمع الحجاج بن يوسف ينهى عن التسمية بسورة كذا. وأصل الحديث عند البخاري ٢/١٧٧ (١٧٤٧)، ومسلم ٢/٩٤٢ (١٢٩٦) دون ذكر سبب القصة.|30:أخرجه البيهقي في الشعب (٢٥٨٣).</p><p><b>وقد ذكر السيوطي بعد هذا ١/٩٥-١١٨ آثارًا عديدة في فضائل سورة البقرة.</b>|31:أخرجه البخاري في تاريخه ٢/٢٠٨ (٢٢٠٩)، وابن جرير ١/٢٢١-٢٢٢.</p><p>قال ابن جرير (١/٢١٠): «كرهنا ذكر الذي حُكيَ ذلك عنه، إذ كان الذي رواه ممن لا يُعتمد على روايته ونقله». وقال السيوطي: «بسند ضعيف».|32:تفسير الثعلبي ١/١٣٦، وتفسير البغوي ١/٥٨.|33:تفسير الثعلبي ١/١٣٦، وتفسير البغوي ١/٥٨.|34:أخرجه ابن جرير ١/٢٠٦.|35:أخرجه ابن جرير ١/٢٠٨، والبيهقي في الأسماء والصفات (١٦٨)، وعند ابن أبي حاتم من قول السدي كما سيأتي. وذكره السيوطي مقتصرًا على ابن مسعود.|36:أخرجه ابن جرير ١/٢٠٨، وابن أبي حاتم ١/٣٢، والنحاس في القطع والائتناف ص١١١، وابن النجار في تاريخه ١٧/٣-٤. وعزاه السيوطي إلى وكيع، وعبد بن حميد، وابن المنذر.|37:أخرجه ابن جرير ١/٢٠٧، ٢٠/٢٧٤، ٢٣/١٤٢-١٤٣، وابن أبي حاتم ١/٣٢. وعزاه السيوطي إلى ابن مردويه.|38:أخرجه ابن جرير ١/٢٠٧، ١٠/٥٣، ١٥/٤٥٢، ١٦/٧، ١٧/٥٤٢، ١٨/٥، ١٩/٣٩٨، ٢٠/٦، ٢٧٤، ٢١/٤٠٠، وابن مردويه -كما في تخريج أحاديث الكشاف للزيلعي ١/٣٤-، وابن أبي حاتم ٥/١٤٣٧، ٨/٢٧٤٧، ٩/٢٨٣٨-٢٨٣٩، والبيهقي في الأسماء والصفات ص١٦٣. وعزاه السيوطي إلى ابن المنذر.|39:أخرجه ابن مردويه -كما في تخريج أحاديث الكشاف للزيلعي ١/٣٤-.|40:أخرجه ابن جرير ١/٢٠٦، وابن أبي حاتم ١/٣٢، ٨/٢٨٣٨، ٣٠٢٩.|41:أخرجه ابن أبي حاتم ١/٣٣، ٢/٥٨٤. وعزاه السيوطي إلى ابن جرير، وهو عنده من قول الربيع -كما سيأتي-.|42:أخرجه ابن جرير ١/٢٠٩-٢١٠، وابن أبي حاتم ١/٣٣، ٢/٥٨٤.|43:أخرجه ابن جرير ١/٢٠٨، والنحاس في معاني القرآن ١/٧٣. وعلَّقه ابن أبي حاتم ١/٣٢.|44:تفسير الثعلبي ١/١٣٦، وتفسير البغوي ١/٥٩.|45:أخرجه ابن جرير ١/٢٠٤، وابن أبي حاتم ١/٣٣.|46:أخرجه ابن جرير ١/٢٠٥، وابن أبي حاتم ٥/١٤٣٧، كما أخرجه ابن جرير من طريق سفيان، عن ابن أبي نجيح. وعزاه السيوطي إلى ابن المنذر، وأبي الشيخ ابن حيان.|47:أخرجه ابن جرير ١/٢٠٩. وعزاه السيوطي إلى ابن المنذر.|48:تفسير البغوي ١/٥٩.|49:تفسير مقاتل بن سليمان ١/٢٨. وعلَّقه ابن أبي حاتم ١/٣٢.|50:أخرجه ابن جرير ١/٢٠٧، وابن أبي حاتم ١/٣٣.|51:أخرجه ابن جرير ١/٢٠٧.|52:عزاه السيوطي إلى ابن المنذر، وأبي الشيخ ابن حيّان في التفسير.|53:أخرجه ابن أبي حاتم ١/٣٢، وابن جرير ١/٢٠٦ مختصرًا. وعزاه السيوطي إلى ابن أبي شيبة في تفسيره، وعبد بن حميد، وابن المنذر.|54:عزاه السيوطي إلى ابن المنذر. وأخرج نحوه ابن أبي حاتم ٨/٢٧٤٧ من طريق أبي بكر الهذلي، بلفظ: فواتح افتتح الله بها كتابه، أو القرآن.|55:تفسير ابن أبي زمنين ١/١٢٠.|56:أخرجه عبد الرزاق ١/٣٩، وابن جرير ١/٢٠٤. وعلّقه ابن أبي حاتم ١/٣٣. وعزاه السيوطي إلى عبد بن حميد.|57:تفسير الثعلبي ١/١٣٩، وتفسير البغوي ١/٥٨.|58:أخرجه البيهقي في الأسماء والصفات (١٦٩). وعزاه السيوطي إلى أبي الشيخ.|59:أخرجه ابن أبي حاتم ١/٣٢.|60:أخرجه عبد الله بن وهب في الجامع - تفسير القرآن ٢/١٦٢ (٣٤٠)، وابن جرير ١/٢٠٦ من طريقه.|61:علّقه ابن أبي حاتم ١/٣٣.|62:عزاه السيوطي إلى عبد بن حميد.|63:أخرجه ابن جرير ١/٢٠٩. وعلّق ابن أبي حاتم ١/٣٣ نحوه.|64:تفسير الثعلبي ١/١٣٧.|65:أخرجه الثعلبي ١/١٤٠.|66:أخرجه ابن جرير ١/٢٠٤.|67:حساب الجُمل: طريقة لتسجيل الأعداد والتواريخ باستعمال الحروف الأبجدية؛ إذ يعطى كل حرف رقمًا معينًا يدل عليه؛ فتكوَّن من هذه الحروف جملة تدل على رقم أو تاريخ مقصود، وبالعكس تستخدم الأرقام للوصول إلى الجمل والنصوص. تنظر: الموسوعة العربية العالمية (حساب الجمل).|68:أخرجه ابن المنذر ١/١١١.|69:تفسير الثعلبي ١/١٣٦، وتفسير البغوي ١/٥٩.|70:عزاه السيوطي إلى أبي نصر السِّجْزِيِّ في الإبانة.|71:عزاه السيوطي إلى وكيع، وعبد بن حميد.
  2,2,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿ذَ ٰ⁠لِكَ ٱلۡكِتَـٰبُ لَا رَیۡبَۛ فِیهِۛ هُدࣰى لِّلۡمُتَّقِینَ ۝٢ ٱلَّذِینَ یُؤۡمِنُونَ بِٱلۡغَیۡبِ وَیُقِیمُونَ ٱلصَّلَوٰةَ وَمِمَّا رَزَقۡنَـٰهُمۡ یُنفِقُونَ ۝٣ وَٱلَّذِینَ یُؤۡمِنُونَ بِمَاۤ أُنزِلَ إِلَیۡكَ وَمَاۤ أُنزِلَ مِن قَبۡلِكَ وَبِٱلۡـَٔاخِرَةِ هُمۡ یُوقِنُونَ ۝٤ أُو۟لَـٰۤىِٕكَ عَلَىٰ هُدࣰى مِّن رَّبِّهِمۡۖ وَأُو۟لَـٰۤىِٕكَ هُمُ ٱلۡمُفۡلِحُونَ ۝٥﴾</span> - نزول الآيات</h3></p><p><div></p><p><p><span class="item-no">٢٨٨<span class="dash">-</span></span> عن <span class="name-2">أبي العالية</span> -من طريق الربيع بن أنس- قال: هذه الأربع الآيات من فاتحة السورة في المؤمنين{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٨٩<span class="dash">-</span></span> عن <span class="name-2">مجاهد</span> -من طريق ابن أبي نَجِيح- قال: من أول البقرة أربع آيات في نَعْت المؤمنين، وآيتان في نعت الكافرين، وثلاث عشرة آية في نعت المنافقين، ومن أربعين آية إلى عشرين ومائة في بني إسرائيل{2}. (١/١٢٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٩٠<span class="dash">-</span></span> عن <span class="name-2">مجاهد</span>، قال: هؤلاء الآيات الأربع في أول سورة البقرة إلى <span class="qpc-hafs">﴿المفلحون﴾</span> نزلت في نعت المؤمنين، واثنتان من بعدها إلى <span class="qpc-hafs">﴿عظيم﴾</span> نزلت في نعت الكافرين، وإلى العشرين نزلت في المنافقين{3}. (١/١٢٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٩١<span class="dash">-</span></span> عن عبد العزيز: سأله{4} <span class="name-2">عطاء بن أبي رباح</span> عن قومٍ يشهدون على الناس بالشرك والكفر. فأنكر ذلك وأباه، ثم قال: أنا أقرأ عليك بعث{5} المؤمنين، وبعث الكافرين، وبعث المنافقين، ففيها: بسم الله الرحمن{6} <span class="qpc-hafs">﴿الم ذلك الكتاب لا ريب فيه هدى للمتقين﴾</span> إلى قوله: <span class="qpc-hafs">﴿عذاب أليم بما كانوا يكذبون﴾</span>، ثم قال: هذا بعث المؤمنين، وبعث الكافرين، وبعث المنافقين{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٩٢<span class="dash">-</span></span> عن <span class="name-2">قتادة</span> -من طريق مَعْمَر- في قوله: <span class="qpc-hafs">﴿ومن الناس من يقول ءامنا بالله وباليوم الأخر وما هم بمؤمنين﴾</span> حتى بلغ: <span class="qpc-hafs">﴿فما ربحت تجرتهم وما كانوا مهتدين﴾</span>، قال: هذه في المنافقين{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٩٣<span class="dash">-</span></span> عن <span class="name-2">الربيع بن أنس</span> -من طريق أبي جعفر الرازي- قال: أربع آيات من فاتحة سورة البقرة في الذين آمنوا، وآيتان في قادة الأحزاب{9}. (١/١٢٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٩٤<span class="dash">-</span></span> قال <span class="name-2">أبو رَوْق عطية بن الحارث الهمداني</span> -من طريق الهُذَيْل بن حبيب-: هذه{10} للعرب خاصة{11}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٩٥<span class="dash">-</span></span> عن <span class="name-3">[محمد بن السائب] الكلبي</span> -من طريق الهُذَيل بن حبيب-: قالت اليهود –جُدَيٌّ، وحُيَيٌّ، ومَن معهما-: نَحْنُ المتقون، الَّذِين يؤمنون بالغيب، آمنا بمحمد قبل أن يُبْعَث. قال الكلبي: هاتان الآيتان{12} نزلتا فى اليهود{11}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٩٦<span class="dash">-</span></span> قال مقاتل بن سليمان: <span class="qpc-hafs">﴿ذلك الكتاب﴾</span> وذلك أنّ كعب بن الأشرف، وكعب بن أُسَيْد لَمّا دعاهما النبي ﷺ إلى الإسلام قالا: ما أنزل الله كتابًا من بعد موسى. تكذيبًا به، فأنزل الله ﷿ في قولهما: <span class="qpc-hafs">﴿ألم، ذلك الكتاب لا ريب فيه﴾</span>{14}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٩٧<span class="dash">-</span></span> قال مقاتل بن سليمان: لَمّا سمع أبو ياسر بن أخْطَب اليهودي بهؤلاء الآيات قال لأخيه جُدَيّ بن أخطب: لقد سمعتُ من محمد كلمات أنزلهن الله على موسى بن عمران. فقال جُدَيٌّ لأخيه: لا تَعْجَل حتى تَتَثَبَّتَ في أمره. فعَمَدَ أبو ياسر وجُدَيُّ ابنا أخْطَب، وكعب بن الأشرف، وكعب بن أُسَيْد، ومالك بن الضَّيْف، وحُيَيّ بن أخْطَب، وسعيد بن عمرو الشاعر، وأبو لُبابة بن عمرو، ورؤساء اليهود، فأتَوُا النبي ﷺ، فقال جُدَيٌّ للنبي ﷺ: يا أبا القاسم، أخْبَرَني أبو ياسر بكلمات تقولهنَّ آنفًا. فقرأهنَّ النبي ﷺ، فقال جُدَيٌّ: صدقتم، أمّا <span class="qpc-hafs">﴿ألم، ذلك الكتاب لا ريب فيه هدى للمتقين، الذين يؤمنون بالغيب ويقيمون الصلاة ومما رزقناهم ينفقون﴾</span> فنحن هم، وأما <span class="qpc-hafs">﴿الذين يؤمنون بما أنزل إليك﴾</span> فهو كتابك، <span class="qpc-hafs">﴿وما أنزل من قبلك﴾</span> فهو كتابنا، <span class="qpc-hafs">﴿وبالآخرة هم يوقنون أولئك على هدى من ربهم وأولئك هم المفلحون﴾</span> فأنتم هم، قد آمنتم بما أُنزِل إليكم وإلينا، وآمنتم بالجنة والنار، فآيتان فينا، وآيتان فيكم. ثم قالوا للنبي ﷺ: نَنشُدُكَ بالله أنّها نزلت عليك من السماء؟ فقال النبي ﷺ: «<b>أشهد بالله أنها نزلت عَلَيَّ من السماء</b>». فذلك قوله سبحانه في يونس [٥٣]: <span class="qpc-hafs">﴿ويستنبئونك أحق هو قل إي وربي﴾</span>، يعني: ويستخبرونك أحق هو؟ <span class="qpc-hafs">﴿قل إي وربي﴾</span> يعني: بلى وربي، <span class="qpc-hafs">﴿إنه لحق﴾</span> ...{15}. فآيتان من أول هذه السورة نزلتا في أصحاب النبي ﷺ المهاجرين والأنصار، والآيتان اللتان تلِيانِهِما نزلتا في مشركي العرب، وثلاث عشرة آية في المنافقين من أهل التوراة{16}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٢٩٨<span class="dash">-</span></span> عن <span class="name-3">سفيان الثوري</span>: نزلت أربعُ آيات من أول البقرة في نعت المؤمنين، وثلاث آيات في نعت الكافرين، وثلاث عشرة آية في نعت المنافقين{17}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿ذَ ٰ⁠لِكَ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٢٩٩<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق ابن جُرَيْج- في قوله: <span class="qpc-hafs">﴿ذلك الكتاب﴾</span>، قال: هذا الكتاب{18}. (١/١٢٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٠٠<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٠١<span class="dash">-</span></span> و<span class="name-2">زيد بن أسلم</span>، مثله{19}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٠٢<span class="dash">-</span></span> و<span class="name-3">مقاتل بن حيان</span> -من طريق بُكَيْر بن معروف-، مثله{20}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٠٣<span class="dash">-</span></span> عن <span class="name-2">عكرمة</span> -من طريق خالد الحذاء-، مثله{21}. (١/١٢٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٠٤<span class="dash">-</span></span> عن <span class="name-2">مجاهد</span> -من طريق ابن جُرَيْج- <span class="qpc-hafs">﴿ذلك الكتاب﴾</span>، قال: هو هذا الكتاب{22}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٠٥<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق الحكم بن ظُهَيْر- في قوله: <span class="qpc-hafs">﴿ذلك الكتاب﴾</span>، قال: هذا الكتاب{23}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٠٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ذلك الكتاب﴾</span>، بمعنى: هذا الكتاب{14}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٠٧<span class="dash">-</span></span> عن <span class="name-3">ابن جُريج</span> -من طريق حجاج- قوله: <span class="qpc-hafs">﴿ذلك الكتاب﴾</span>: هذا الكتاب{18}<span class=comment-ref>٣٨</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٣٨</span> <span class="comment-type-1">وجَّه</span> <u>ابنُ جرير</u> (١/٢٢٨-٢٣٠) مجيء النص القرآني باسم الإشارة <span class="qpc-hafs">﴿ذلك﴾</span> الدال على الإشارة إلى غائب، وتفسير المفسرين له بـ«هذا» الدال على الإشارة إلى حاضر، بقوله: «لأنه -جلّ ذِكْرُه- لَمّا قدم قبلَ <span class="qpc-hafs">﴿ذلك الكتاب﴾</span>: <span class="qpc-hafs">﴿ألم﴾</span>، قال لنبيه ﷺ: يا محمد، هذا الذي ذكرته وبيَّنته لك الكتابُ. ولذلك حَسُن وضع <span class="qpc-hafs">﴿ذلك﴾</span> في مكان (هذا)،لأنه أُشِير به إلى الخبر عما تضمَّنهُ قوله: <span class="qpc-hafs">﴿ألم﴾</span> من المعاني، بعد تقضّي الخبر عنه بـ<span class="qpc-hafs">﴿ألم﴾</span> ... فأخبر به بـ<span class="qpc-hafs">﴿ذلك﴾</span> لانقضائه، ومصير الخبر عنه كالخبر عن الغائب، وترجمهُ المفسِّرون أنه بمعنى: هذا؛ لقرب الخبر عنه من انقضائه، فكان كالمشاهَد المشار إليه بـ: هذا».</p><p>وذكر نحوه <u>ابنُ عطية</u> (١/١٠٢).</p><p>وقال <u>ابنُ تيمية</u> (١/١٤٤): «ذلك أنه لما أنزل قوله: <span class="qpc-hafs">﴿ذَلِكَ الكِتابُ﴾</span> ... لم يكن الكتاب المشار إليه قد أُنزِل تلك الساعة، وإنما كان قد أُنزِل قبل ذلك، فصار كالغائب الذي يشار إليه كما يشار إلى الغائب، وهو باعتبار حضوره عند النبي ﷺ يُشار إليه كما يشار إلى الحاضر ... ولهذا قال غير واحد من السلف: <span class="qpc-hafs">﴿ذلك الكتاب﴾</span>، أي: هذا الكتاب».</p><p>وقال <u>ابنُ كثير</u> (١/٢٥٨-٢٥٩): «والعرب تُقارِض بين هذين الاسمين من أسماء الإشارة، فيستعملون كلًّا منهما مكان الآخر، وهذا معروف في كلامهم».</div></p><p><h3><span class="qpc-hafs">﴿ذَ ٰ⁠لِكَ ٱلۡكِتَـٰبُ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٠٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن مسعود</span> و<span class="name-1">ناس من أصحاب النبي</span> ﷺ -من طريق السُّدِّي، عن مُرَّة الهمداني-= (١/١٢٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٠٩<span class="dash">-</span></span> و<span class="name-1">عبد الله بن عباس</span> -من طريق السُّدِّي، عن أبي مالك وأبي صالح-: <span class="qpc-hafs">﴿الكتاب﴾</span>: القرآن{26}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣١٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق أبي الضُّحى- قال: معناه: ذلك الكتاب الذي أخبرتك أن أُوحيه إليك{27}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣١١<span class="dash">-</span></span> قال <span class="name-2">سعيد بن جبير</span>: هو اللوح المحفوظ{27}<span class=comment-ref>٣٩</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٣٩</span> <span class="comment-type-1">وجَّه</span> <u>ابن عطية</u> (١/١٠٢، ١٠٣) قول سعيد بن جبير بقوله: «أي: الكتاب الذي هو القدر».</p><p><span class="comment-type-4">وزاد</span> أقوالًا أخرى في معنى الآية: «فقيل: ما قد كان نزل من القرآن، ... وقيل: إنّ الله قد كان وعد نبيه أن ينزل عليه كتابًا لا يمحوه الماء، فأشار إلى ذلك الوعد. وقال الكسائي: <span class="qpc-hafs">﴿ذلِكَ﴾</span> إشارة إلى القرآن الذي في السماء لم ينزل بعد. وقيل: إن الله قد كان وعد أهل الكتاب أن ينزل على محمد كتابًا، فالإشارة إلى ذلك الوعد. وقيل: إن الإشارة إلى حروف المعجم في قول مَن قال: <span class="qpc-hafs">﴿الم﴾</span> حروف المعجم التي تحديتكم بالنظم منها».</div></p><p><div></p><p><p><span class="item-no">٣١٢<span class="dash">-</span></span> عن <span class="name-2">عكرمة</span> -من طريق الهُذَيْل بن حبيب، عن أبي بكر الهُذَلِيِّ-: هو التوراة، والإنجيل، والكتب المتقدمة{29}<span class=comment-ref>٤٠</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٤٠</span> <span class="comment-type-1">وجَّه</span> <u>ابنُ جرير</u> (١/٢٣١) هذا القول، فقال: «وإذا وُجّه تأويل <span class="qpc-hafs">﴿ذلك﴾</span> إلى هذا الوجه، فلا مؤونة فيه على متأوِّله ... لأن تأويل <span class="qpc-hafs">﴿ذلك﴾</span> يكون حينئذ إخبارًا عن غائب على صحة».</p><p>و<span class="comment-type-2">انتقده</span> <u>ابنُ كثير</u> (١/٢٥٩) بقوله: «ومَن قال: إنّ المراد بذلك الكتاب الإشارة إلى التوراة والإنجيل ... فقد أبعد النجعة، وأغرق في النزع، وتكلف ما لا علم له به».</div></p><p><div></p><p><p><span class="item-no">٣١٣<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق أبي بكر الهُذَلِيّ- في قول الله: <span class="qpc-hafs">﴿الكتاب﴾</span>، قال: القرآن{30}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣١٤<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، مثل ذلك{31}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣١٥<span class="dash">-</span></span> قال <span class="name-2">عطاء بن السائب</span>: <span class="qpc-hafs">﴿ذلك الكتاب﴾</span> الذي وعدتكم يوم الميثاق{27}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣١٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ذلك الكتاب﴾</span> بمعنى: هذا الكتاب الذي كفرت به اليهود{14}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿لَا رَیۡبَۛ فِیهِۛ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣١٧<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن مسعود</span>، و<span class="name-1">ناس من أصحاب النبي</span> ﷺ -من طريق السُّدِّي، عن مُرَّة الهمداني-= (١/١٢٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣١٨<span class="dash">-</span></span> و<span class="name-1">عبد الله بن عباس</span> -من طريق السُّدِّي، عن أبي مالك وأبي صالح- <span class="qpc-hafs">﴿لا ريب فيه﴾</span>: لا شك فيه{26}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣١٩<span class="dash">-</span></span> عن <span class="name-1">أبي الدرداء</span> -من طريق عبد الرحمن بن مسعود الفَزارِيِّ- قال: الرَّيْب: الشَّكُّ من الكفر{35}. (١/١٢٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٢٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>: أنّ نافعَ بن الأزرق قال له: أخبِرني عن قوله ﷿: <span class="qpc-hafs">﴿لا ريب فيه﴾</span>. قال: لا شَكَّ فيه. قال: وهل تعرفُ العرب ذلك؟ قال: نعم، أما سمعتَ ابن الزِّبَعْرى وهو يقول:</p><p>ليس في الحقِّ يا أُمامةُ رَيْبُ إنما الرَّيْبُ ما يقولُ الكَذوبُ{36}. (١/١٢٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٢١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق ابن إسحاق، عن محمد بن أبي محمد، عن عكرمة أو عن سعيد بن جبير- في قوله: <span class="qpc-hafs">﴿لا ريب فيه﴾</span>، قال: لا شَكَّ فيه{37}. (١/١٢٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٢٢<span class="dash">-</span></span> عن <span class="name-2">مجاهد</span> -من طريق ابن جُرَيْج-، مثله{38}. (١/١٢٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٢٣<span class="dash">-</span></span> عن <span class="name-2">قتادة</span> -من طريق مَعْمَر- في قوله: <span class="qpc-hafs">﴿لا ريب فيه﴾</span>، قال: لا شَكَّ فيه{39}. (١/١٢٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٢٤<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق الحكم بن ظُهَيْر- قال: <span class="qpc-hafs">﴿لا ريب فيه﴾</span>: لا شكَّ فيه{40}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٢٥<span class="dash">-</span></span> عن <span class="name-2">الربيع بن أنس</span> -من طريق أبي جعفر الرازي- قوله: <span class="qpc-hafs">﴿لا ريب فيه﴾</span>، يقول: لا شكَّ فيه{41}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٢٦<span class="dash">-</span></span> قال <span class="name-2">أبو رَوْق عطية بن الحارث الهمداني</span> -من طريق الهُذَيْل بن حبيب- في قوله: <span class="qpc-hafs">﴿لا ريب فيه﴾</span>: لا شكَّ فيه{11}<span class=comment-ref>٤١</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٤١</span> <span class="comment-type-1">وجَّه</span> <u>ابن عطية</u> (١/١٠٣) هذا المعنى بقوله: «والمعنى: أنه في ذاته لا ريب فيه، وإن وقع ريب للكفار». وزاد قولين آخرين: <b>الأول</b>: أن «لفظ قوله: <span class="qpc-hafs">﴿لا ريب فيه﴾</span> لفظ الخبر، ومعناه النهي». <b>والثاني</b>: «هو عموم يراد به الخصوص، أي: عند المؤمنين». ثم <span class="comment-type-2">انتقده</span> قائلًا: «وهذا ضعيف».</div></p><p><div></p><p><p><span class="item-no">٣٢٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿لا ريب فيه﴾</span>، يعني: لا شكَّ فيه أنّه من الله جاء، وهو أنزله على محمد ﷺ{14}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٢٨<span class="dash">-</span></span> قال ابن أبي حاتم: ولا أعلم في هذا الحرف اختلافًا بين المفسرين؛ منهم <span class="name-1">ابن عباس</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٢٩<span class="dash">-</span></span> و<span class="name-2">سعيد بن جبير</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٣٠<span class="dash">-</span></span> و<span class="name-2">أبو مالك</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٣١<span class="dash">-</span></span> و<span class="name-2">نافع مولى ابن عمر</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٣٢<span class="dash">-</span></span> و<span class="name-2">عطاء بن أبي رباح</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٣٣<span class="dash">-</span></span> و<span class="name-2">أبو العالية</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٣٤<span class="dash">-</span></span> و<span class="name-2">الربيع بن أنس</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٣٥<span class="dash">-</span></span> و<span class="name-2">قتادة</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٣٦<span class="dash">-</span></span> و<span class="name-3">مقاتل بن حيان</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٣٧<span class="dash">-</span></span> و<span class="name-2">السُّدِّيّ</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٣٨<span class="dash">-</span></span> و<span class="name-2">إسماعيل بن أبي خالد</span>{44}<span class=comment-ref>٤٢</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٤٢</span> <span class="comment-type-1">وجَّه</span> <u>ابنُ تيمية</u> (١/١٣٧) تفسير الريب بالشك بأنه تقريب للمعنى، فقال: «فهذا تقريب، وإلا فالريب فيه اضطراب وحركة ... فكما أنّ اليقين ضُمِّن السكون والطمأنينة، فالريب ضده ضُمِّن الاضطراب والحركة، ولفظ الشك وإن قيل: إنه يستلزم هذا المعنى؛ لكن لفظه لا يدل عليه».</div></p><p><h3><span class="qpc-hafs">﴿هُدࣰى﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٣٩<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن مسعود</span>، و<span class="name-1">ناس من أصحاب النبي</span> ﷺ -من طريق السُّدِّي، عن مُرَّة الهمداني-= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤٠<span class="dash">-</span></span> و<span class="name-1">عبد الله بن عباس</span> -من طريق السُّدِّي، عن أبي مالك وأبي صالح- <span class="qpc-hafs">﴿هدى للمتقين﴾</span>، يقول: نور للمتقين{45}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤١<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span> -من طريق عطاء بن دينار- <span class="qpc-hafs">﴿هدى للمتقين﴾</span>: تبيان للمتقين{46}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤٢<span class="dash">-</span></span> عن <span class="name-2">عامر الشعبي</span> -من طريق بيان- في قوله: <span class="qpc-hafs">﴿هدى﴾</span>، قال: من الضلالة{47}. (١/١٣٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤٣<span class="dash">-</span></span> عن <span class="name-2">قتادة</span>، في قوله: <span class="qpc-hafs">﴿هدى للمتقين﴾</span>، قال: جعله الله هُدًى وضياء لِمَن صدَّق به، ونورًا للمتقين{48}. (١/١٣٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤٤<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط بن نصر-: وأمّا <span class="qpc-hafs">﴿هدى للمتقين﴾</span>: نور للمتقين{49}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤٥<span class="dash">-</span></span> قال <span class="name-2">أبو رَوْق عطية بن الحارث الهمداني</span> -من طريق الهُذَيْل بن حبيب- في قوله: <span class="qpc-hafs">﴿هدى للمتقين﴾</span>، قال: كرامة لهم هداهم إليه{11}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿هدى للمتقين﴾</span> هَذا القرآن هُدًى من الضلالة{14}<span class=comment-ref>٤٣</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٤٣</span> حكم <u>ابنُ كثير</u> (١/٢٦٠) على هذه الأقوال الواردة في معنى <span class="qpc-hafs">﴿هدى﴾</span> بقوله: «وكل ذلك صحيح».</div></p><p><h3><span class="qpc-hafs">﴿لِّلۡمُتَّقِینَ ۝٢﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٤٧<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن مسعود</span>، و<span class="name-1">ناس من أصحاب النبي</span> ﷺ -من طريق السُّدِّيّ، عن مُرَّة الهمداني-= (١/١٣٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤٨<span class="dash">-</span></span> و<span class="name-1">عبد الله بن عباس</span> -من طريق السُّدِّي، عن أبي مالك وأبي صالح- <span class="qpc-hafs">﴿هدًى للمتقين﴾</span>، قال: هم المؤمنون{52}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٤٩<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق ابن إسحاق بسنده- في قوله: <span class="qpc-hafs">﴿هدى للمتقين﴾</span>، أي: الذين يَحْذَرُون من الله عقوبته في ترك ما يعرفون من الهُدى، ويرجون رحمته في التصديق بما جاء منه{53}. (١/١٣٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق أبي رَوْق، عن الضحاك- في قوله: <span class="qpc-hafs">﴿هدى للمتقين﴾</span>، قال: للمؤمنين الذين يَتَّقون الشرك، ويعملون بطاعتي{54}. (١/١٣٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥١<span class="dash">-</span></span> عن <span class="name-2">الحسن [البصري]</span> -من طريق سفيان، عن رجل- قوله: <span class="qpc-hafs">﴿للمتقين﴾</span>، قال: اتَّقَوْا ما حُرِّم عليهم، وأدَّوْا ما افتُرِض عليهم{55}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٢<span class="dash">-</span></span> عن <span class="name-2">قتادة</span> -من طريق سعيد بن أبي عروبة- <span class="qpc-hafs">﴿هدى للمتقين﴾</span>، قال: هم مَن نعتَهم ووصفَهم فأثبت صفتهم، فقال: <span class="qpc-hafs">﴿الَّذِينَ يُؤْمِنُونَ بِالغَيْبِ ويُقِيمُونَ الصَّلاةَ ومِمّا رَزَقْناهُمْ يُنْفِقُونَ﴾</span>{56}. (١/١٣٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٣<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيِّ</span> -من طريق أسباط- <span class="qpc-hafs">﴿هدى للمتقين﴾</span>، قال: نور للمتقين، وهم المؤمنون{57}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٤<span class="dash">-</span></span> عن أبي بكر ابن عيّاش، قال: سألني الأعمش عن المتقين. قال: فأجبتُه. فقال لي: سل عنها <span class="name-3">الكَلْبيّ</span>. فسألتُه، فقال: الذين يَجتنِبُون كبائِرَ الإثم.= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٥<span class="dash">-</span></span> قال: فرجَعْت إلى <span class="name-2">الأعمش</span>، فقال: نُرى أنه كذلك. ولم ينكره{58}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿للمتقين﴾</span> من الشرك، نعتهم فقال -سبحانه-: <span class="qpc-hafs">﴿الذين يؤمنون بالغيب ...﴾</span> الآيات{59}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٧<span class="dash">-</span></span> عن <span class="name-3">سفيان الثوري</span>، قال: إنما سُمُّوا المتقين لأنهم اتَّقَوْا ما لا يُتَّقى{60}<span class=comment-ref>٤٤</span>. (١/١٣٢)</p></p><p></div></p><p><div><span class=comment-ref>٤٤</span> <span class="comment-type-3">رجَّح</span> <u>ابنُ جرير</u> (١/٢٣٩) العمومَ في معنى المتقين <span class="mustanad">مستندًا إلى دلالة العموم</span>، فقال: «وذلك أنّ الله أبهم وصْفَهُم بالتقوى، فلم يحصُرْ تقواهم إيّاه على بعضِ ما هو أهلٌ له منهم دون بعض، فليس لأحد من الناس أن يحصُر معنى ذلك على وصْفهم بشيء من تقوى الله دون شيء، إلا بحجة يجبُ التسليمُ لها».</div></p><p><h3><span class="qpc-hafs">﴿لِّلۡمُتَّقِینَ ۝٢﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٣٥٨<span class="dash">-</span></span> عن عطية السَّعْدِيّ -وكان من الصحابة- قال: قال رسول الله ﷺ:»<b>لا يبلغ العبد أن يكون من المتقين حتى يَدَع ما لا بأس به حَذَرًا لِما به البأس</b>»{61}. (١/١٣١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٩<span class="dash">-</span></span> عن <span class="name-1">معاذ بن جبل</span> -من طريق أبي عَفِيف- قال: يُحْبَس الناس يوم القيامة في بقيعٍ واحد، فينادي مُنادٍ: أين المتقون؟ فيقومون في كَنَفٍ{62} من الرحمن، لا يحتجب الله منهم ولا يستتر. قيل: مَن المتقون؟ قال: قوم اتَّقَوُا الشِّرْك وعبادة الأوثان، وأخلصوا لله العبادة، فيمرون إلى الجنة{63}. (١/١٣٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٦٠<span class="dash">-</span></span> عن أبي <span class="name-1">الدرداء</span>، قال: تمامُ التقوى أن يتقي اللهَ العبدُ، حتى يتَّقِيَه من مثقال ذرة، وحتى يترك بعض ما يرى أنه حلالٌ خشيةَ أن يكون حرامًا، يكون حجابًا بينه وبين الحرام{64}. (١/١٣٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٦١<span class="dash">-</span></span> عن محمد بن يزيد الرَّحَبِيِّ، قال: قيل <span class="name-1">لأبي الدرداء</span>: إنّه ليس أحدٌ له بيت في الأنصار إلا قال شعرًا، فما لك لا تقول؟ قال: وأنا قلت، فاستمعوه:</p><p>يريد المرء أن يُعْطى مُناه ويأبى الله إلا ما أرادا</p><p>يقول المرء: فائدتي وذُخْرِي وتقوى الله أفضلُ ما استفادا{60}. (١/١٣٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٦٢<span class="dash">-</span></span> عن <span class="name-1">أبي هريرة</span>، أنّ رجلًا قال له: ما التَّقوى؟ قال: اتخذتَ طريقًا ذا شوك؟ قال: نعم. قال: فكيف صنعت؟ قال: إذا رأيتُ الشوك عدلتُ عنه، أو جاوزتُه، أو قَصُرْتُ عنه. قال: ذاك التقوى{66}. (١/١٣١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٦٣<span class="dash">-</span></span> قال <span class="name-1">ابن عباس</span>: المُتَّقِي: مَن يَتَّقي الشِّركَ، والكبائرَ، والفواحشَ{67}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٦٤<span class="dash">-</span></span> وقال <span class="name-1">ابن عمر</span>: التقوى: أن لا ترى نفسك خيرًا من أحد{67}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٦٥<span class="dash">-</span></span> قال عمر بن الخطاب ل<span class="name-2">كعب الأحبار</span>: حَدِّثني عن التقوى. فقال: هل أخذت طريقًا ذا شوك؟ قال: نعم. قال: فما عملتَ فيه؟ قال: حَذِرْتُ، وشَمَّرْتُ. قال كعب: ذلك التقوى{67}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٦٦<span class="dash">-</span></span> عن وهب بن كَيْسان، قال: كتب <b>رجلٌ</b> إلى عبد الله بن الزبير بموعظة: أمّا بعد، فإنّ لأهل التقوى علامات يُعرَفون بها، ويعرفونها من أنفسهم؛ مِن صبرٍ على البلاء، ورِضًى بالقضاء، وشكرِ النَّعْماء، وذُلٍّ لحُكْمِ القرآن{70}. (١/١٣٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٦٧<span class="dash">-</span></span> عن <span class="name-2">أبي العفيف</span> -وكان من أصحاب معاذ بن جبل- قال: يدخل أهلُ الجنةِ الجنةَ على أربعة أصناف: المتقين، ثم الشاكرين، ثم الخائفين، ثم أصحاب اليمين{71}. (١/١٣٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٦٨<span class="dash">-</span></span> عن <span class="name-2">أبي رجاء</span>، قال: من سَرَّه أن يكون مُتَّقِيًا فليكن أذلَّ من قَعُود إبل، كل من أتى عليه أرْغاه{72}. (٣/١٣٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٦٩<span class="dash">-</span></span> عن <span class="name-2">طَلْق بن حبيب</span> -من طريق عاصم- أنه قيل له: ألا تَجْمَع لنا التقوى في كلام يسير نَرْوِيه؟ فقال: التقوى: العمل بطاعة الله، على نورٍ من الله، رجاءَ رحمة الله. والتقوى: ترك معاصي الله، على نور من الله، مخافةَ عذاب الله{73}. (١/١٣١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٠<span class="dash">-</span></span> عن <span class="name-2">عمر بن عبد العزيز</span>، قال: ليس تقوى الله بصيام النهار، ولا بقيام الليل، والتخليط فيما بين ذلك، ولكن تقوى الله: ترك ما حرم الله، وأداء ما افترض الله، فمن رُزق بعد ذلك خيرًا فهو خير إلى خير{60}. (١/١٣٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧١<span class="dash">-</span></span> عن <span class="name-2">عمر بن عبد العزيز</span>: أنّه لما ولِي حَـمِد الله، وأثنى عليه، ثم قال: أُوصيكم بتقوى الله؛ فإن تقوى الله خَلَفٌ من كل شيء، وليس من تقوى الله خلف{60}. (١/١٣٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٢<span class="dash">-</span></span> عن <span class="name-2">عمر بن عبد العزيز</span>، قال: يا أيها الناس، اتقوا الله؛ فإنه ليس من هالك إلا له خَلَفٌ، إلا التقوى{60}. (١/١٣٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٣<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span>، قال: ما زالت التقوى بالمتقين حتى تركوا كثيرًا من الحلال مخافةَ الحرام{60}. (١/١٣٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٤<span class="dash">-</span></span> وقال <span class="name-2">شَهْر بن حَوْشَب</span>: المُتَّقِي: الذي يترك ما لا بأس به حذرًا لِما به بأس{78}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٥<span class="dash">-</span></span> عن <span class="name-2">ميمون بن مِهْران</span> -من طريق جعفر- قال: لا يكون الرجل من المتقين حتى يحاسب نفسه أشد من محاسبة شريكه؛ حتى يعلم من أين مطعمه، ومن أين ملبسه، ومن أين مشربه، أمن حِلٍّ ذلك أم من حرام؟{79}. (١/١٣٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٦<span class="dash">-</span></span> عن <span class="name-2">قتادة</span>، قال: لَمّا خلق الله الجنة قال لها: تكلمي. قالت: طوبى للمتقين{80}. (١/١٣٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٧<span class="dash">-</span></span> عن <span class="name-2">عون بن عبد الله</span>، قال: تمام التقوى أن تبتغي عِلم ما لم تعلم منها إلى ما قد عَلِمت منها{81}. (١/١٣٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٨<span class="dash">-</span></span> عن <span class="name-2">عون بن عبد الله</span>، قال: فواتح التقوى حسن النية، وخواتمها التوفيق، والعبد فيما بين ذلك بين هَلَكات وشُبُهات، ونفس تَحْطِبُ على سَلْوِها، وعدو مَكِيد غير غافل ولا عاجز{82}. (١/١٣٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٧٩<span class="dash">-</span></span> عن <span class="name-2">إياس بن معاوية</span>، قال: رأس التقوى ومُعظَمُه ألّا تعبد شيئًا دون الله، ثم تَتَفاضَل الناس بالتُّقى والنُّهى{60}. (١/١٣٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٨٠<span class="dash">-</span></span> عن <span class="name-2">مالك بن دينار</span>، قال: القيامة عُرْسُ المتقين{60}. (١/١٣٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٨١<span class="dash">-</span></span> عن <span class="name-2">سعيد بن أبي سعيد المَقْبُرِيّ</span>، قال: بلَغَنا: أنّ رجلًا جاء إلى عيسى، فقال: يا معلم الخير، كيف أكون تقيًّا لله كما ينبغي له؟ قال: بيسير من الأمر؛ تُحِبُّ الله بقلبك كله، وتعمل بكَدْحِك وقُوتِك ما استطعت، وتَرْحَمُ ابنَ جنسك كما ترحم نفسك. قال: مَن ابن جنسي، يا معلم الخير؟ قال: ولد آدم كلهم، وما لا تحب أن يؤتى إليك فلا تأتِه إلى أحد، فأنت تقيٌّ لله حقًّا{85}. (١/١٣٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٨٢<span class="dash">-</span></span> قال <span class="name-3">سفيان الثوري</span>: المتقي: هو الذي اتَّقى الدنيا وأَقَلَّها{86}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٨٣<span class="dash">-</span></span> قال <span class="name-3">سفيان الثوري</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٨٤<span class="dash">-</span></span> و<span class="name-3">الفُضَيْل</span>: هو الذي يُحِبُّ للناس ما يُحِبُّ لنفسه{86}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٨٥<span class="dash">-</span></span> قال <span class="name-3">الفضيل</span>: لا يكون العبد من المتقين حتى يأمنه عدوُّه كما يأمنه صديقُه{86}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٨٦<span class="dash">-</span></span> عن <span class="name-3">عبد الله بن المبارك</span>، قال: لو أن رجلًا اتَّقى مائة شيء، ولم يتق شيئًا واحدًا؛ لم يكن من المتقين{60}. (١/١٣٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٨٧<span class="dash">-</span></span> عن <span class="name-3">عبد الله بن المبارك</span>، قال: قال داود لابنه سليمان ﵉: يا بُنَيَّ، إنما يُسْتَدَلُّ على تقوى الرجل بثلاثة أشياء: بِحُسْن توكله على الله فيما نابه، وبُحسن رضاه فيما آتاه، وبُحسن زهده فيما فاته{60}. (١/١٣٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٨٨<span class="dash">-</span></span> عن <span class="name-3">سَهْم بن مِنجاب</span>، قال: مَعْدِنٌ من التقوى؛ لا يزال لسانك رَطْبًا من ذكر الله{60}. (١/١٣٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٨٩<span class="dash">-</span></span> عن [<span class="name-3">أبي</span>] <span class="name-3">مُحْرِزٍ الطُّفاوِيّ</span>، قال: كيف يرجو مفاتيح التقوى من يُؤْثِر على الآخرة الدنيا؟!{60}. (١/١٣٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٩٠<span class="dash">-</span></span> عن محمد بن يوسف الفِرْيابِيّ، قال: قلتُ لسفيان: أرى الناس يقولون: <span class="name-3">سفيان الثوري</span>. وأنت تنام الليل! فقال لي: اسكت، مَلاك هذا الأمر التقوى{60}. (١/١٣٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٩١<span class="dash">-</span></span> عن شَبِيبِ بْنِ شَيْبَةَ، قال: تكلم رجل من الحكماء عند عبد الملك بن مروان، فوصف المُتَّقِيَ، فقال: رجل آثَرَ الله على خلقه، وآثر الآخرة على الدنيا، ولم تَكْرُثُه المطالب، ولم تمنعه المطامع، نظر ببصر قلبه إلى معالي إرادته فسما لها مُلْتَمِسًا لها، فدهره محزون، يبيت إذا نام الناس ذا شُجُون، ويصبح مغمومًا في الدنيا مسجون، قد انقطعت من همته الراحة دون منيته، فشفاؤه القرآن، ودواؤه الكلمة من الحكمة والموعظة الحسنة، لا يرى منها الدنيا عوضًا، ولا يستريح إلى لذة سواها. فقال عبد الملك: أشهد أنّ هذا أرخى بالًا مِنّا، وأنعم عيشًا{94}. (١/١٣٥)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿ٱلَّذِینَ یُؤۡمِنُونَ بِٱلۡغَیۡبِ﴾</span> - نزول الآية</h3></p><p><div></p><p><p><span class="item-no">٣٩٢<span class="dash">-</span></span> عن عبد الله بن مسعود، وناس من أصحاب النبي ﷺ -من طريق السُّدِّيّ، عن مُرَّة الهمداني-= (١/١٣٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٩٣<span class="dash">-</span></span> وعبد الله بن عباس -من طريق السُّدِّيّ، عن أبي مالك وأبي صالح-: أمّا <span class="qpc-hafs">﴿الَّذِينَ يُؤْمِنُونَ بِالغَيْبِ﴾</span> فهم المؤمنون من العرب{95}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٩٤<span class="dash">-</span></span> وعن إسماعيل السدي -من طريق أسباط-، مثله{57}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٩٥<span class="dash">-</span></span> قال مقاتل بن سليمان: هاتان الآيتان نزلتا في مؤمني أصحاب النبي ﷺ، والمهاجرين{59}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿ٱلَّذِینَ یُؤۡمِنُونَ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٩٦<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن مسعود</span> -من طريق أبي الأحوص- قال: الإيمان: التصديق{98}. (١/١٣٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٩٧<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي بن أبي طلحة، وابن إسحاق بسنده- في قوله: <span class="qpc-hafs">﴿الذين يؤمنون﴾</span>، قال: يُصَدِّقون{99}. (١/١٣٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٩٨<span class="dash">-</span></span> عن <span class="name-2">محمد ابن شهاب الزهري</span> -من طريق مَعْمَر- قال: الإيمانُ العملُ{98}<span class=comment-ref>٤٥</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٤٥</span> <span class="comment-type-3">رجَّح</span> <u>ابنُ جرير</u> (١/٢٤١) شمول معنى الإيمان للقول والاعتقاد والعمل، فقال: «والإيمان: كلمة جامعةٌ للإقرار بالله، وكتُبه، ورسلِه، وتصديق الإقرار بالفعل. وإذْ كان ذلك كذلك فالذي هو أولى بتأويل الآيةِ، وأشبه بصفة القوم: أن يكونوا موصوفين بالتصديق بالغَيْبِ قولًا واعتقادًا وعملًا؛ إذ كان -جلّ ثناؤه- لم يحصُرْهم من معنى الإيمان على معنى دون معنى».</p><p>وقال <u>ابنُ كثير</u> (١/٢٦٤): «أما الإيمان في اللغة: فيطلق على التصديق المحض. وقد يستعمل في القرآن والمراد به ذلك، كما قال تعالى: <span class="qpc-hafs">﴿يؤمن بالله ويؤمن للمؤمنين﴾</span> [التوبة:٦١] ...، وكذلك إذا اسْتُعْمِل مقرونًا مع الأعمال؛ كقوله: <span class="qpc-hafs">﴿إلا الذين آمنوا وعملوا الصالحات﴾</span> [الانشقاق:٢٥]، فأما إذا اسْتُعْمِل مطلقًا فالإيمان الشرعي المطلوب لا يكون إلا اعتقادًا وقولًا وعملًا».</div></p><p><div></p><p><p><span class="item-no">٣٩٩<span class="dash">-</span></span> عن <span class="name-2">الربيع بن أنس</span> -من طريق أبي جعفر الرازي- <span class="qpc-hafs">﴿يؤمنون﴾</span>: يخشون{98}<span class=comment-ref>٤٦</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٤٦</span> بيَّن <u>ابنُ جرير</u> (١/٢٤١) اندراج الخشية تحت معنى الإيمان، فقال: «وقد تدخل الخشية لله في معنى الإيمان، الذي هو تصديق القول بالعمل».</div></p><p><h3><span class="qpc-hafs">﴿بِٱلۡغَیۡبِ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٠٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن مسعود</span>، و<span class="name-1">ناس من أصحاب النبي</span> ﷺ -من طريق السدي، عن مرة الهمداني-= (١/١٣٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٠١<span class="dash">-</span></span> و<span class="name-1">عبد الله بن عباس</span> -من طريق السُّدِّي، عن أبي مالك وأبي صالح-: أمّا <span class="qpc-hafs">﴿الذين يؤمنون بالغيب﴾</span>، أما الغيب: فما غاب عن العباد من أمر الجنة والنار، وما ذكر الله في القرآن لم يكن تصديقهم بذلك من قِبَل أصلِ كتاب أو علم كان عندهم{102}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٠٢<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّي</span> -من طريق أسباط-، مثله{103}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٠٣<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق ابن إسحاق بسنده- في قوله: <span class="qpc-hafs">﴿بالغيب﴾</span>، قال: بما جاء منه، يعني: من الله{104}. (١/١٣٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٠٤<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>: أنّ نافع بن الأزرق قال له: أخبِرْني عن قوله ﷿: <span class="qpc-hafs">﴿الذين يؤمنون بالغيب﴾</span>. قال: ما غاب عنهم من أمر الجنة والنار. قال: وهل تعرف العرب ذلك؟ قال: نعم، أما سمعت أبا سفيان بن الحارث يقول:</p><p>وبالغيب آمنّا وقد كان قومُنا يُصَلُّون للأوثان قبل محمد{105}. (١/١٣٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٠٥<span class="dash">-</span></span> عن <span class="name-2">زِرِّ بن حُبَيْش</span> -من طريق عاصم- قال: الغيب: القرآن{106}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٠٦<span class="dash">-</span></span> عن <span class="name-2">أبي العالية</span> -من طريق الربيع بن أنس- في قوله: <span class="qpc-hafs">﴿الذين يؤمنون بالغيب﴾</span>، قال: بالله، وملائكته، ورسله، واليوم الآخر، وجنته، وناره، ولقائه، ويؤمنون بالحياة بعد الموت، وبالبعث؛ فهذا غيب كله{107}. (١/١٣٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٠٧<span class="dash">-</span></span> عن <span class="name-2">مجاهد</span> -من طريق عثمان بن الأسود- <span class="qpc-hafs">﴿الذين يؤمنون بالغيب﴾</span>، قال: يؤمنون بالله{108}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٠٨<span class="dash">-</span></span> قال <span class="name-2">الحسن [البصري]</span>: يعني: بالآخرة{109}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٠٩<span class="dash">-</span></span> عن <span class="name-2">عطاء بن أبي رباح</span> -من طريق عثمان بن الأسود- في قوله تعالى: <span class="qpc-hafs">﴿الذين يؤمنون بالغيب﴾</span>، قال: مَن آمن بالله فقد آمن بالغيب{110}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٠<span class="dash">-</span></span> عن <span class="name-2">قتادة</span> -من طريق سعيد بن أبي عَرُوبة- في قوله: <span class="qpc-hafs">﴿الذين يؤمنون بالغيب﴾</span>، قال: آمنوا بالبعث بعد الموت، والحساب، والجنة، والنار، وصدَّقوا بموعود الله الذي وعد في القرآن{111}. (١/١٣٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١١<span class="dash">-</span></span> عن <span class="name-2">زيد بن أسلم</span> -من طريق عبد الله بن جعفر- <span class="qpc-hafs">﴿الذين يؤمنون بالغيب﴾</span>، قال: بالقدر{103}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٢<span class="dash">-</span></span> عن <span class="name-2">الربيع بن أنس</span>، <span class="qpc-hafs">﴿الذين يؤمنون بالغيب﴾</span>: آمنوا بالله، وملائكته، ورُسُلِه، واليومِ الآخِر، وجَنّته، وناره، ولقائه، وآمنوا بالحياة بعد الموت؛ فهذا غيبٌ كله{113}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٣<span class="dash">-</span></span> عن <span class="name-2">إسماعيل بن أبي خالد</span> -من طريق إبراهيم بن حميد- <span class="qpc-hafs">﴿يؤمنون بالغيب﴾</span>، قال: بغيب الإسلام{103}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٤<span class="dash">-</span></span> قال <span class="name-3">محمد بن السائب الكلبي</span>: بما نزل من القرآن، وبما لم يجِئْ بعدُ{115}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿هدى للمتقين﴾</span>، ثم نعتهم فقال سبحانه: <span class="qpc-hafs">﴿الذين يؤمنون بالغيب﴾</span>، يعني: يؤمنون بالقرآن أنه من الله تعالى جاء، وهو أنزله على محمد ﷺ، فيُحِلُّون حلاله، ويُحَرِّمون حرامه، ويعملون بما فيه{59}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٦<span class="dash">-</span></span> قال <span class="name-3">ابن جُرَيْج</span>: بالوحي{117}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٧<span class="dash">-</span></span> قال عبد الله بن هانئ: هو ما غاب عنهم من علوم القرآن{118}<span class=comment-ref>٤٧</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٤٧</span> <span class="comment-type-3">رجَّح</span> <u>ابنُ عطية</u> (١/١٠٥)، و<u>ابنُ تيمية</u> (١/١٣٦)، و<u>ابنُ كثير</u> (١/٢٦٥) القول <span class="mustanad">بالعموم</span> في معنى الغيب.</p><p>و<span class="comment-type-4">جمع</span> <u>ابنُ عطية</u> بين تلك الأقوال بقوله: «وهذه الأقوال لا تتعارض، بل يقع الغيب على جميعها».</p><p>و<span class="comment-type-4">جمع</span> <u>ابنُ كثير</u> بينها، فقال: «وأما الغيب المراد هاهنا فقد اختلفت عبارات السلف فيه، وكلها صحيحة ترجع إلى أن الجميع مراد، فكل هذه متقاربة في معنى واحد؛ لأن جميع هذه المذكورات من الغيب الذي يجب الإيمان به».</div></p><p><h3><span class="qpc-hafs">﴿بِٱلۡغَیۡبِ﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٤١٨<span class="dash">-</span></span> عن تُوَيْلَةَ بنت أسْلَم، قالت: صَلَّيْتُ الظهر أو العصر في مسجد بني حارثة، فاستقبلنا مسجد إيلِياء{119}، فصلَّيْنا سجدتين، ثم جاءنا مَن يُخْبِرُنا: أنَّ رسول الله ﷺ قد استقبل البيت الحرام، فتحول الرجال مكان النساء، والنساء مكان الرجال، فصلَّيْنا السجدتين الباقِيَتَيْن ونحن مستقبلو البيت الحرام، فبلغ رسولَ الله ﷺ ذلك، فقال: «<b>أولئك قوم آمنوا بالغيب</b>»{120}. (١/١٣٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٩<span class="dash">-</span></span> عن الحارث بن قيس، أنّه قال لابن مسعود: عند الله نحتسب ما سبقتمونا به -يا أصحاب محمد- من رؤية رسول الله ﷺ. فقال <span class="name-1">ابن مسعود</span>: عند الله نحتسب إيمانكم بمحمد ﷺ ولم تروه، إنّ أمر محمد كان بيّنًا لِمن رآه، والذي لا إله غيره ما آمن أحدٌ أفضل من إيمان بغيب. ثم قرأ: <span class="qpc-hafs">﴿ألم ذلك الكتاب لا ريب فيه﴾</span> إلى قوله: <span class="qpc-hafs">﴿المفلحون﴾</span>{121}. (١/١٣٩)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَیُقِیمُونَ ٱلصَّلَوٰةَ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٢٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي بن أبي طلحة- في قوله: <span class="qpc-hafs">﴿ويُقِيمُونَ الصلاة﴾</span>، قال: الصلوات الخمس{122}. (١/١٤٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٢١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق ابن إسحاق بسنده- في قوله: <span class="qpc-hafs">﴿ويُقِيمُونَ الصلاة﴾</span>، قال: يُقِيمُونها بفروضها{123}. (١/١٤٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٢٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق أبي رَوْق، عن الضحاك- قال: إقامة الصلاة: إتمامُ الركوعِ والسجودِ والتلاوةِ، والخشوعُ، والإقبالُ عليها فيها{124}. (١/١٤٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٢٣<span class="dash">-</span></span> عن <span class="name-2">الضحاك</span> -من طريق جُوَيْبِر- في قوله: <span class="qpc-hafs">﴿ويُقِيمُونَ الصلاة﴾</span>، يعني: الصلاة المفروضة{124}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٢٤<span class="dash">-</span></span> عن أبي سعيد، أنّه سمع <span class="name-2">الحسن</span> يقول في قول الله: <span class="qpc-hafs">﴿ويقيمون الصلاة﴾</span>، قال: يقيمون الصلوات الخمس بوضوئها، وركوعها، وسجودها، وخشوعها، في مواقيتها{126}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٢٥<span class="dash">-</span></span> عن <span class="name-2">قتادة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿ويُقِيمُونَ الصلاة﴾</span>، قال: إقامة الصلاة: المحافظة على مواقيتها، ووضوئها، وركوعها، وسجودها{48}. (١/١٤٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٢٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ويُقِيمُونَ الصلاة﴾</span> المكتوبة الخمس، يعني: يقيمون ركوعها، وسجودها، في مواقيتها{14}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٢٧<span class="dash">-</span></span> عن <span class="name-3">مقاتل بن حيان</span> -من طريق بُكَيْر بن معروف- في قوله: <span class="qpc-hafs">﴿ويُقِيمُونَ الصلاة﴾</span>، قال: إقامتها: المحافظة على مواقيتها، وإسباغ الطهور فيها، وتمام ركوعها وسجودها، وتلاوة القران فيها، والتشهد، والصلاة على النبي ﷺ؛ فهذا إقامتها{129}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَمِمَّا رَزَقۡنَـٰهُمۡ یُنفِقُونَ ۝٣﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٢٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن مسعود</span>، و<span class="name-1">ناس من أصحاب النبي</span> ﷺ -من طريق السُّدِّي، عن مُرَّة الهمداني-= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٢٩<span class="dash">-</span></span> و<span class="name-1">عبد الله بن عباس</span> -من طريق السُّدِّي، عن أبي مالك وأبي صالح-: هي نَفقَةُ الرَّجُل على أهله، وهذا قبل أن تنزِل الزكاة{130}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٣٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي بن أبي طلحة- في قوله: <span class="qpc-hafs">﴿ومِمّا رَزَقْناهُمْ يُنْفِقُونَ﴾</span>، قال: زكاة أموالهم{131}. (١/١٤٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٣١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق ابن إسحاق بسنده- في قوله: <span class="qpc-hafs">﴿ومما رزقناهم ينفقون﴾</span>، قال: يُؤَدُّون الزكاة احتسابًا لها{132}. (١/١٤٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٣٢<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span>، في قوله: <span class="qpc-hafs">﴿ومما رزقناهم ينفقون﴾</span>، قال: إنما يعني الزكاة خاصة، دون سائر النفقات، لا يَذكرُ الصلاة إلا ذَكرَ معها الزكاة، فإذا لم يُسَمِّ الزكاة قال في إثر ذكر الصلاة: <span class="qpc-hafs">﴿ومما رزقناهم ينفقون﴾</span>{133}. (١/١٤٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٣٣<span class="dash">-</span></span> عن <span class="name-2">الضحاك</span> -من طريق جُوَيْبِر- في قوله: <span class="qpc-hafs">﴿ومما رزقناهم ينفقون﴾</span>، قال: كانت النفقات قُرْبانًا يتقربون بها إلى الله على قدر ميسورهم وجُهْدِهم، حتى نزلت فرائض الصدقات في سورة براءة، هُنَّ الناسخات المُبَيِّنات{134}. (١/١٤٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٣٤<span class="dash">-</span></span> عن <span class="name-2">قتادة</span>، في قوله: <span class="qpc-hafs">﴿ومما رزقناهم ينفقون﴾</span>، قال: أنفَقوا في فرائض الله التي افترض الله عليهم في طاعته وسبيله{48}. (١/١٤٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٣٥<span class="dash">-</span></span> عن <span class="name-2">قتادة</span> -من طريق سعيد- <span class="qpc-hafs">﴿ومما رزقناهم ينفقون﴾</span>، قال: فأنفِقوا مما أعطاكم الله، فإنما هذه الأموال عَوارٍ وودائع عندك، يا ابن آدم، أوشكت أن تفارقها{136}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٣٦<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span>: <span class="qpc-hafs">﴿ومما رزقناهم ينفقون﴾</span> فهي نفقة الرجل على أهله، وهذا قبل أن تنزل الزكاة{136}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٣٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ومِمّا رَزَقْناهُمْ﴾</span> من الأموال <span class="qpc-hafs">﴿يُنْفِقُونَ﴾</span> يعني: الزكاة المفروضة. نظيرها في لقمان{138}<span class=comment-ref>٤٨</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٤٨</span> <span class="comment-type-3">رجَّح</span> <u>ابنُ جرير</u> (١/٢٥٠)، و<u>ابنُ عطية</u> (١/١٠٧)، و<u>ابنُ كثير</u> (١/٢٦٩-٢٧٠) شمول معنى <span class="qpc-hafs">﴿ينفقون﴾</span> لكل أنواع النفقات؛ لأن الله مدحهم بالإنفاق، ولم يخصص نوعًا من أنواع الإنفاق.</p><p><span class="comment-type-1">ووجَّه</span> <u>ابن عطية</u> أقوال السلف بأن: «الآية تعمّ الجميع، وهذه الأقوال تمثيل لا خلاف».</div></p><p><div></p><p><p><span class="item-no">٤٣٨<span class="dash">-</span></span> قال أبو توبة الربيع بن نافع: سئل <span class="name-3">سفيان بن عيينة</span> عن قوله: <span class="qpc-hafs">﴿ومما رزقناهم ينفقون﴾</span>. قال: القرآن؛ ألم تسمع إلى قوله تعالى: <span class="qpc-hafs">﴿ولقد آتيناك سبعًا من المثاني والقرآن العظيم﴾</span> [الحجر: ٨٧]، وإلى قوله: <span class="qpc-hafs">﴿ورزق ربك خير وأبقى﴾</span> [طه: ١٣١]؟! ...{139}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَٱلَّذِینَ یُؤۡمِنُونَ بِمَاۤ أُنزِلَ إِلَیۡكَ وَمَاۤ أُنزِلَ مِن قَبۡلِكَ﴾</span> - نزول الآية</h3></p><p><div></p><p><p><span class="item-no">٤٣٩<span class="dash">-</span></span> عن عبد الله بن مسعود، وناس من أصحاب النبي ﷺ -من طريق السُّدِّيّ، عن مُرَّة الهمداني-= (١/١٣٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٤٠<span class="dash">-</span></span> وعبد الله بن عباس -من طريق السُّدِّيّ، عن أبي مالك وأبي صالح- <span class="qpc-hafs">﴿والَّذِينَ يُؤْمِنُونَ بِما أُنْزِلَ إلَيْكَ﴾</span>: المؤمنون من أهل الكتاب{140}<span class=comment-ref>٤٩</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٤٩</span> <span class="comment-type-3">رجَّح</span> <u>ابنُ جرير</u> (١/٢٤٦-٢٤٧) <span class="mustanad">مستندًا إلى أحوال النزول، والسياق، ودلالة العقل</span>، قولَ ابن مسعود، وابن عباس من طريق السدي: أنّ المراد بقوله: <span class="qpc-hafs">﴿الذين يؤمنون بالغيب﴾</span>: مؤمنو العرب، وأنّ المراد بقوله تعالى: <span class="qpc-hafs">﴿والذين يؤمنون بما أنزل إليك وما أنزل من قبلك﴾</span>: مؤمنو أهل الكتاب، وذلك أنه تعالى قال: <span class="qpc-hafs">﴿والذين يؤمنون بما أنزل إليك وما أنزل من قبلك﴾</span>، ولم يكن للعرب كتابٌ قبل الكتاب الذي أنزله الله ﷿ على محمد ﷺ، وبأنّ الله صنَّف الكافرين في الآيات بعدها إلى صنفين: منافق، وكافر، فكذلك المؤمنون صنَّفهم إلى عربيٍّ، وكتابيٍّ.</p><p>و<span class="comment-type-2">انتقد</span> <u>ابنُ تيمية</u> (١/١٢٧) هذا القول، ووصفه بالغلط؛ لأن «مشركي العرب إن لم يؤمنوا بما أنُزِل إليه وما أنُزِل من قبله لم يكونوا مُفْلِحين، وأهل الكتاب إن لم يؤمنوا بالغيب ويقيموا الصلاة ومما رزقناهم ينفقون لم يكونوا مفلحين؛ ولهذا قال تعالى: <span class="qpc-hafs">﴿أولئك على هدى من ربهم وأولئك هم المفلحون﴾</span>، فدلَّ على أنهم صنف واحد».</p><p>ولم ير <u>ابنُ عطية</u> (١/١٠٨) تعارضًا بين قول من جعل الآيتين في صنف واحد، أو فسر كل آية بصنف منهما، فقال: «وهذه الأقوال لا تتعارض».</p><p>و<span class="comment-type-3">رجَّح</span> <u>ابنُ تيمية</u> (١/١٢٧-١٢٨، ١٤٢) أن الآيات صفة لموصوف واحد، وأن عطف الشيء على الشيء قد يكون لتغاير الصفات، وإن كانت الذات واحدة.</p><p>وبنحوه قال <u>ابنُ كثير</u> (١/٢٧٢-٢٧٤)، فقد <span class="comment-type-3">رجَّح</span> أن الآيات عامة في كل مؤمن اتصف بها، وذلك أنه ليس تصح واحدة من هذه الصفات دون الأخرى، بل كل واحدة مستلزمة للأخرى وشرط معها، وقوّى قولَه <span class="mustanad">بعدد من الآيات</span> الدالة على أمر جميع المؤمنين بالإيمان بالله ورسله وكتبه، كقوله تعالى: <span class="qpc-hafs">﴿يا أيُّها الَّذِينَ آمَنُوا آمِنُوا بِاللَّهِ ورَسُولِهِ والكِتابِ الَّذِي نَزَّلَ عَلى رَسُولِهِ والكِتابِ الَّذِي أنْزَلَ مِن قَبْلُ﴾</span> الآية [النساء:١٣٦]، وقوله: <span class="qpc-hafs">﴿ولا تُجادِلُوا أهْلَ الكِتابِ إلّا بِالَّتِي هِيَ أحْسَنُ إلّا الَّذِينَ ظَلَمُوا مِنهُمْ وقُولُوا آمَنّا بِالَّذِي أُنْزِلَ إلَيْنا وأُنْزِلَ إلَيْكُمْ﴾</span> [العنكبوت:٤٦]، وغيرها.</p><p>وبيَّن <u>ابنُ عطية</u> (١/١٠٨) اختلاف الإعراب على كلا القولين، فقال: «فمن جعل الآيتين في صنف واحد فإعراب <span class="qpc-hafs">﴿والَّذِينَ﴾</span> خفض على العطف، ويصح أن يكون رفعًا على الاستئناف، أي: وهم الذين. ومن جعل الآيتين في صنفين فإعراب <span class="qpc-hafs">﴿والذين﴾</span> رفع على الابتداء، وخبره <span class="qpc-hafs">﴿أُولئِكَ عَلى هُدىً﴾</span>، ويحتمل أن يكون عطفًا».</div></p><p><div></p><p><p><span class="item-no">٤٤١<span class="dash">-</span></span> عن إسماعيل السُّدِّيّ: <span class="qpc-hafs">﴿والَّذِينَ يُؤْمِنُونَ بِما أُنْزِلَ إلَيْكَ وما أُنْزِلَ مِن قَبْلِكَ وبالآخرة هم يوقنون﴾</span>، قال: هؤلاء المؤمنون من أهل الكتاب، ثم جمع الفريقين{141}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٤٢<span class="dash">-</span></span> قال مقاتل بن سليمان: ثم ذكر مؤمني أهل التوراة؛ عبد الله بن سَلام وأصحابه، منهم أُسَيْد بن زيد، وأسد بن كعب، وسَلام بن قيس، وثعلبة بن عمر، وابن يامين واسمه سَلام، فقال: <span class="qpc-hafs">﴿والَّذِينَ يُؤْمِنُونَ بِما أُنْزِلَ إلَيْكَ﴾</span>{14}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَٱلَّذِینَ یُؤۡمِنُونَ بِمَاۤ أُنزِلَ إِلَیۡكَ وَمَاۤ أُنزِلَ مِن قَبۡلِكَ﴾</span> - تفسير الآية</h3></p><p><div></p><p><p><span class="item-no">٤٤٣<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق ابن إسحاق بسنده- في قوله: <span class="qpc-hafs">﴿والَّذِينَ يُؤْمِنُونَ بِما أُنْزِلَ إلَيْكَ وما أُنْزِلَ مِن قَبْلِكَ﴾</span>، أي: يُصَدِّقُونك بما جئتَ به من الله، وما جاء به مَن قبلك مِن المرسلين، لا يُفرِّقون بينهم، ولا يجحدون ما جاؤوهم به من ربهم{143}<span class=comment-ref>٥٠</span>. (١/١٤٧)</p></p><p></div></p><p><div><span class=comment-ref>٥٠</span> <span class="comment-type-4">علَّق</span> <u>ابنُ جرير</u> (١/٢٥٢) على أثر ابن عباس بأنه وإن كانت الآيات في صفات المؤمنين إلا أنها تعريض بذم كفار أهل الكتاب في زعمهم الإيمانَ بالرسل، وأنهم مهتدون، وأنّه لن يدخل الجنة إلا من كان هودًا أو نصارى، وهم كاذبون فيما زعموا.</div></p><p><div></p><p><p><span class="item-no">٤٤٤<span class="dash">-</span></span> عن <span class="name-2">قتادة</span>، في قوله: <span class="qpc-hafs">﴿والَّذِينَ يُؤْمِنُونَ بِما أُنْزِلَ إلَيْكَ﴾</span> قال: هو الفرقان الذي فرق الله به بين الحق والباطل، <span class="qpc-hafs">﴿وما أُنْزِلَ مِن قَبْلِكَ﴾</span> قال: الكتب التي خَلَت قبله{144}. (١/١٤٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٤٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿والَّذِينَ يُؤْمِنُونَ بِما أُنْزِلَ إلَيْكَ﴾</span> يعني: يُصَدِّقون بما أنزل إليك يا محمد من القرآن أنّه من الله، <span class="qpc-hafs">﴿وما أُنْزِلَ مِن قَبْلِكَ﴾</span> على الأنبياء، يعني: التوراة، والإنجيل، والزبور{14}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَبِٱلۡـَٔاخِرَةِ هُمۡ یُوقِنُونَ ۝٤﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٤٦<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق ابن إسحاق بسنده- في قوله: <span class="qpc-hafs">﴿وبِالآخِرَةِ هُمْ يُوقِنُونَ﴾</span>، أي: بالبعث، والقيامة، والجنة، والنار، والحساب، والميزان، أي: لا هؤلاء الذين يزعمون أنهم آمنوا بما كان قبلك، ويَكْفُرُون بما جاءك من ربك{146}. (١/١٤٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٤٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وبِالآخِرَةِ هُمْ يُوقِنُونَ﴾</span>، يعني: يُصَدِّقون بالبعث الذي فيه جزاء الأعمال بأنّه كائن{147}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿أُو۟لَـٰۤىِٕكَ عَلَىٰ هُدࣰى مِّن رَّبِّهِمۡۖ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٤٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن مسعود</span>، و<span class="name-1">ناس من أصحاب النبي</span> ﷺ -من طريق السُّدِّي، عن مُرَّة الهمداني-= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٤٩<span class="dash">-</span></span> و<span class="name-1">عبد الله بن عباس</span> -من طريق السُّدِّي، عن أبي مالك وأبي صالح-: أمّا <span class="qpc-hafs">﴿الذين يؤمنون بالغيب﴾</span> فهم المؤمنون من العرب، <span class="qpc-hafs">﴿والَّذِينَ يُؤْمِنُونَ بِما أُنْزِلَ إلَيْكَ﴾</span> المؤمنون من أهل الكتاب، ثم جمع الفريقين، فقال: <span class="qpc-hafs">﴿أولئك على هدى﴾</span> الآية{148}. (١/١٣٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٥٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق ابن إسحاق بسنده- <span class="qpc-hafs">﴿أُولَئِكَ عَلى هُدًى مِن رَبِّهِمْ﴾</span>، أي: على نور من ربهم، واستقامة على ما جاءهم{149}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٥١<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span> -من طريق عطاء بن دينار- في قوله: <span class="qpc-hafs">﴿أُولَئِكَ عَلى هُدًى مِن رَبِّهِمْ﴾</span>، قال: على بَيِّنَة من ربهم{150}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَأُو۟لَـٰۤىِٕكَ هُمُ ٱلۡمُفۡلِحُونَ ۝٥﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٥٢<span class="dash">-</span></span> عن عبد الله بن عمرو، قال: قيل: يا رسول الله، إنّا نقرأ من القرآن فنرجو، ونقرأ فنكاد نيأس. فقال: «<b>ألا أخبركم عن أهل الجنة وأهل النار</b>؟» قالوا: بلى، يا رسول الله. فقال: <b><span class="qpc-hafs">﴿ألم ذلك الكتاب لا ريب فيه هدى للمتقين﴾</span></b> إلى قوله: <b><span class="qpc-hafs">﴿المفلحون﴾</span> «هؤلاء أهل الجنة</b>». قالوا: إنّا نرجو أن نكون هؤلاء. ثم قال: <b><span class="qpc-hafs">﴿إن الذين كفروا سواء عليهم أأنذرتهم﴾</span></b> إلى قوله: <b><span class="qpc-hafs">﴿عظيم﴾</span></b> «<b>هؤلاء أهل النار</b>». قلنا: لسنا هم، يا رسول الله؟ قال: «<b>أجل</b>»{151}. (١/١٥٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٥٣<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق ابن إسحاق بسنده- <span class="qpc-hafs">﴿وأُولَئِكَ هُمُ المُفْلِحُونَ﴾</span>، أي: الذين أدْركوا ما طلبوا، ونَجَوْا من شَرِّ ما مِنه هَرَبُوا{152}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٥٤<span class="dash">-</span></span> عن <span class="name-2">قتادة</span> -من طريق شَيْبان بن عبد الرحمن- في قوله: <span class="qpc-hafs">﴿أولئك على هدى من ربهم وأولئك هم المفلحون﴾</span>، قال: اسْتَحَقَّوُا الهدى والفلاح بحق، فأحقه الله لهم، وهذا نَعْتُ أهل الإيمان. ثم نَعَتَ المشركين، فقال: <span class="qpc-hafs">﴿إن الذين كفروا سواء عليهم﴾</span> الآيتين{153}. (١/١٤٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٥٥<span class="dash">-</span></span> <span class="name-3">قال مقاتل بن سليمان</span>: ثم جمعهم جميعًا، فقال سبحانه: <span class="qpc-hafs">﴿أولئك على هدى من ربهم وأولئك هم المفلحون﴾</span>{14}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن أبي حاتم ١/٣٩ (٨٧).|2:تفسير مجاهد ص١٩٥، وأخرج نحوه ابن جرير ١/٢٤٥-٢٤٦. وعزاه السيوطي إلى الفِرْيابيِّ، وعبد بن حميد، وابن المنذر، وابن الضريس.|3:عزاه السيوطي إلى وكيع، ومن طريقه أخرج ابن جرير ١/٢٤٦ نحوه عن رجل عن مجاهد. وعند الواحدي في أسباب النزول ص١٢١ نحوه من طريق ابن أبي نجيح.|4:كذا في المصدر، ولعل الصواب دون هاء.|5:كذا في المطبوع في جميع المواطن من هذه الرواية (بعث)، وفي طبعة أخرى من الحلية: (نعت) أي: صفة، وهو أشبه.|6:كذا في المطبوع دون (الرحيم).|7:أخرجه أبو نعيم في حلية الأولياء ٨/١٩٣.|8:أخرجه عبد الرزاق ١/٣٩.|9:أخرجه ابن جرير ١/٢٤٥.|10:قوله: «هذه» يشير إلى قول الله تعالى: <span class="qpc-hafs">﴿الذين يؤمنون بالغيب﴾</span> إلى قوله: <span class="qpc-hafs">﴿ينفقون﴾</span>.|11:تفسير مقاتل بن سليمان ١/٢٩.|12:قوله: «هاتان الآيتان» يشير إلى قول الله تعالى: <span class="qpc-hafs">﴿الذين يؤمنون بالغيب﴾</span> إلى قوله: <span class="qpc-hafs">﴿ينفقون﴾</span>.|13:تفسير مقاتل بن سليمان ١/٢٩.|14:تفسير مقاتل بن سليمان ١/٨١.|15:ذكر هنا القصة بطولها بنحو ما في حديث جابر بن عبد الله بن رِئاب السابق في حساب الجُمَّل، ثم أورد أيضًا نزول أول سورة آل عمران لنفس السبب.|16:تفسير مقاتل بن سليمان ١/٨٤-٨٨.|17:تفسير سفيان الثوري ص٤١.|18:أخرجه ابن جرير ١/٢٢٩.|19:علَّقه ابن أبي حاتم ١/٣٣.|20:أخرجه ابن أبي حاتم ١/٣٣.|21:أخرجه ابن جرير ١/٢٢٨. وعزاه السيوطي إلى ابن الأنباري في المصاحف.|22:أخرجه ابن جرير ١/٢٢٨.|23:أخرجه ابن جرير ١/٢٢٨. وعلَّقه ابن أبي حاتم ١/٣٣.|24:تفسير مقاتل بن سليمان ١/٨١.|25:أخرجه ابن جرير ١/٢٢٩.|26:أخرجه ابن جرير ١/٢٣٢، والحاكم ٢/٢٦٠ مقتصرًا على ابن مسعود.|27:تفسير الثعلبي ١/١٤١.|28:تفسير الثعلبي ١/١٤١.|29:تفسير مقاتل بن سليمان ١/٤١. وينظر: تفسير الثعلبي ١/١٤١.|30:أخرجه ابن أبي حاتم ١/٣٤.|31:علَّقه ابن أبي حاتم ١/٣٤.|32:تفسير الثعلبي ١/١٤١.|33:تفسير مقاتل بن سليمان ١/٨١.|34:أخرجه ابن جرير ١/٢٣٢، والحاكم ٢/٢٦٠ مقتصرًا على ابن مسعود.|35:أخرجه أحمد في الزهد ص١٤١، وابن أبي حاتم ١/٣٤ (٥٥).|36:عزاه السيوطي إلى الطستي في مسائله عن ابن عباس. وينظر: الإتقان ٢/١٠٣.|37:أخرجه ابن إسحاق -كما في سيرة ابن هشام ١/٥٣٠-، وابن جرير ١/٢٣٢، وابن أبي حاتم ١/٣٤، ٦٣.|38:أخرجه ابن جرير ١/٢٣١.|39:أخرجه عبد الرزاق ١/٣٩. وعزاه السيوطي إلى عبد بن حميد.|40:أخرجه ابن جرير ١/٢٣٢.|41:أخرجه ابن جرير ١/٢٣٣.|42:تفسير مقاتل بن سليمان ١/٢٩.|43:تفسير مقاتل بن سليمان ١/٨١.|44:تفسير ابن أبي حاتم ١/٣٤.|45:أخرجه ابن جرير ١/٢٣٤.|46:أخرجه ابن أبي حاتم ١/٣٤ (٥٩).|47:أخرجه ابن جرير ١/٢٣٤، وابن أبي حاتم ١/٣٤ (٥٨). وعزاه السيوطي إلى وكيع.|48:عزاه السيوطي إلى عبد بن حميد.|49:أخرجه ابن أبي حاتم ١/٣٤ (٥٨).|50:تفسير مقاتل بن سليمان ١/٢٩.|51:تفسير مقاتل بن سليمان ١/٨١.|52:أخرجه ابن جرير ١/٢٣٨. وعزاه السيوطي إليه مقتصرًا على ابن مسعود.|53:سيرة ابن هشام ١/٥٣٠، وابن جرير ١/٢٣٧، وابن أبي حاتم ١/٣٥.|54:أخرجه ابن جرير ١/٢٣٨-٢٣٩.|55:أخرجه ابن جرير ١/٢٣٧.|56:أخرجه ابن جرير ١/٢٣٨، وابن أبي حاتم ١/٣٥.|57:أخرجه ابن أبي حاتم ١/٣٥.|58:أخرجه ابن جرير ١/٢٣٨.|59:تفسير مقاتل ١/٨١.|60:عزاه السيوطي إلى ابن أبي الدنيا.|61:أخرجه الترمذي ٤/٤٤٤ (٢٦١٩)، وابن ماجه ٥/٢٩٨ (٤٢١٥)، والحاكم ٤/٣٥٥ (٧٨٩٩)، وابن أبي حاتم ١/٣٥ (٦١).</p><p>قال الترمذي: «حسن غريب، لا نعرفه إلا من هذا الوجه». وقال الحاكم: «هذا حديث صحيح الإسناد، ولم يُخَرِّجاه». وقال الذهبي «صحيح». وقال ابن رجب في فتح الباري ١/١٦: «وفي إسناده بعضُ مقال».|62:قال في القاموس: أنتَ في كَنَفِ -محرّكةً- الله تعالى: في حِرْزِه وستره. (كنف)، ونحوه في اللسان (كنف).|63:أخرجه ابن أبي حاتم ١/٣٥ (٦١).|64:عزاه السيوطي إلى أحمد في الزهد، وابن أبي الدنيا.|65:عزاه السيوطي إلى ابن أبي الدنيا.|66:عزاه السيوطي إلى ابن أبي الدنيا في كتاب التقوى.|67:تفسير الثعلبي ١/١٤٢، وتفسير البغوي ١/٦٠.|68:تفسير الثعلبي ١/١٤٢، وتفسير البغوي ١/٦٠.|69:تفسير الثعلبي ١/١٤٢، وتفسير البغوي ١/٦٠.|70:أخرجه أبو نعيم في الحلية ١/٣٣٦. وعزاه السيوطي إلى ابن أبي الدنيا. وعند الثعلبي ١/١٤٤ عن بعض فقهاء أهل المدينة.|71:أخرجه ابن أبي حاتم ٤/١٣٠٨ (٧٣٩٥).|72:عزاه السيوطي إلى ابن أبي الدنيا.</p><p>ومعنى أرغاه: قهره وأذله؛ لأن البعير إنما يرغو عن ذل واستكانة، وإنما خص القعود لأنّ الفتي من الإبل يكون كثير الرغاء. النهاية ٢/٢٤٠.|73:أخرجه ابن أبي شيبة ١٣/٤٨٨، وابن أبي حاتم ١/٩٨. وعزاه السيوطي إلى ابن أبي الدنيا.|74:عزاه السيوطي إلى ابن أبي الدنيا.|75:عزاه السيوطي إلى ابن أبي الدنيا.|76:عزاه السيوطي إلى ابن أبي الدنيا.|77:عزاه السيوطي إلى ابن أبي الدنيا.|78:تفسير الثعلبي ١/١٤٣، وتفسير البغوي ١/٦٠.|79:أخرجه ابن أبي شيبة ١٣/٥١٩، ١٤/٣٦، وأبو نعيم ٤/٨٩ واللفظ له.|80:أخرجه ابن أبي الدنيا في صفة الجنة (٣٩).|81:أخرجه ابن أبي شيبة ١٣/٤٢٨. وعزاه السيوطي إلى ابن أبي الدنيا.|82:عزاه السيوطي إلى ابن أبي الدنيا. وقد رواه أبو نعيم في الحلية ٤/٢٥٠، من طريق ابن أبي الدنيا، وفيه قوله: «شلوها» بالشين المعجمة، ورواه كذلك ابن عساكر في تاريخ دمشق ٤٧/٧٦، من طريق ابن أبي الدنيا، وفيه أيضًا: «يكيد» بدل مكيد.|83:عزاه السيوطي إلى ابن أبي الدنيا.|84:عزاه السيوطي إلى ابن أبي الدنيا.|85:أخرجه أحمد في الزهد (ص٥٩). وعزاه السيوطي إلى ابن أبي الدنيا.|86:تفسير الثعلبي ١/١٤٣.|87:تفسير الثعلبي ١/١٤٣.|88:تفسير الثعلبي ١/١٤٣.|89:عزاه السيوطي إلى ابن أبي الدنيا.|90:عزاه السيوطي إلى ابن أبي الدنيا.|91:عزاه السيوطي إلى ابن أبي الدنيا.|92:عزاه السيوطي إلى ابن أبي الدنيا.|93:عزاه السيوطي إلى ابن أبي الدنيا.|94:أخرجه ابن أبي الدنيا في كتاب الهم والحزن ص٨٠ (١١٩).|95:أخرجه ابن جرير ١/٢٤٤. وعزاه السيوطي إليه مقتصرًا على ابن مسعود.|96:أخرجه ابن أبي حاتم ١/٣٥.|97:تفسير مقاتل ١/٨١.|98:أخرجه ابن جرير ١/٢٤٠.|99:أخرجه ابن جرير ١/٢٤٠-٢٤١. وينظر: سيرة ابن هشام ١/٥٣٠.|100:أخرجه ابن جرير ١/٢٤٠.|101:أخرجه ابن جرير ١/٢٤٠.|102:أخرجه ابن جرير ١/٢٤١. وعزاه السيوطي إليه مقتصرًا على ابن مسعود.|103:أخرجه ابن أبي حاتم ١/٣٦.|104:أخرجه ابن إسحاق -كما في سيرة ابن هشام ١/٥٣٠-، وابن جرير ١/٢٤٠-٢٤١ واللفظ له.|105:مسائل نافع بن الأزرق (٢٧٢).|106:أخرجه ابن أبي حاتم ١/٣٦ (٦٩)، وفي تفسير الثعلبي ١/١٤٧، وتفسير البغوي١/٦٢: بالوحي.|107:أخرجه ابن أبي حاتم ١/٣٦ (٦٧)، وهو عند ابن جرير من قول الربيع -كما سيأتي-.|108:أخرجه الحربي في غريب الحديث ٢/٦١١.|109:تفسير الثعلبي ١/١٤٧.|110:أخرجه ابن أبي حاتم ١/٣٦ (٧٠).|111:عزاه السيوطي إلى عبد بن حميد. وأخرجه يحيى بن سلّام في تفسيره ١/٢٣١، وابن جرير ١/٢٤٢ بنحوه.|112:أخرجه ابن أبي حاتم ١/٣٦.|113:أخرجه ابن جرير ١/٢٤٢.|114:أخرجه ابن أبي حاتم ١/٣٦.|115:تفسير الثعلبي ١/١٤٧، وتفسير البغوي ١/٦٢.|116:تفسير مقاتل ١/٨١.|117:تفسير البغوي ١/٦٢.|118:تفسير الثعلبي ١/١٤٧. وعبد الله بن هانئ لعله أبو الزعراء صاحب ابن مسعود. ينظر: تهذيب الكمال ٣٣/ ٣٢٧.|119:إيلِياء: مدينة بيت المقدس. لسان العرب (إيل).</p><p>ونقل <u>ابن عطية</u> عن طائفة أن: «معناه: يصدقون إذا غابوا وخلوا، لا كالمنافقين الذين يؤمنون إذا حضروا، ويكفرون إذا غابوا».|120:أخرجه الطبراني في الكبير ٢٤/٢٠٧ (٥٣٠) دون اللفظ النبوي، ورواه ٢٥/٤٣ (٨٢) بلفظه الذي هنا، ولكنه سمى الراوية أم نويلة بنت مسلم، وأخرجه ابن أبي حاتم في تفسيره ١/٣٧ (٧٣) بزيادة اللفظ النبوي.</p><p>قال ابن كثير في تفسيره ١/١٦٨ عن رواية ابن أبي حاتم: «هذا حديث غريب من هذا الوجه». وقال الهيثمي في المجمع ٢/١٤ (١٩٧٨): «فيه إسحاق بن إدريس الأسواري، وهو ضعيف متروك». وقال عن رواية الطبراني التي ليس فيها الزيادة ٢/١٤ (١٩٧٧): «رجاله مُوَثَّقُون».|121:جمع السيوطي بين روايتين لهذا الأثر: إحداهما من أوله إلى قوله: «ولم تروه». وقد أخرجها سفيان بن عيينة، وعنه سعيد بن منصور (١٨١-تفسير) عن الحارث بن قيس. والثانية من قوله: «إن أمر محمد» إلى آخره. وقد أخرجها سعيد بن منصور في سننه (١٨٠-تفسير)، وابن منيع -كما في المطالب العالية (٣٢١٣)-، وابن أبي حاتم ١/٣٦ (٦٦)، والحاكم ٢/٢٦٠، وابن مردويه -كما في تفسير ابن كثير ١/٦٣-، وابن منده في الإيمان ٢/٣٧١ (٢٠٩)، والبغوي في التفسير ١/٦٢ من طريق عبد الرحمن بن يزيد، عن ابن مسعود.|122:أخرجه ابن جرير ١١/٣٠، وابن أبي حاتم ٦/٢٦٢. وعزاه السيوطي إلى ابن إسحاق.|123:أخرجه ابن جرير ١/٢٤٧، وابن أبي حاتم ١/٣٧. وعزاه السيوطي إلى ابن إسحاق.|124:أخرجه ابن جرير ١/٢٤٨.|125:أخرجه ابن جرير ١/٢٤٨.|126:أخرجه محمد بن نصر في تعظيم قدر الصلاة ص١٣٤.|127:عزاه السيوطي إلى عبد بن حميد.|128:تفسير مقاتل بن سليمان ١/٨١.|129:أخرجه ابن أبي حاتم ١/٣٧.|130:أخرجه ابن جرير ١/٢٥٠.|131:أخرجه ابن جرير ١/١١، ٤٩، ٢/٣٠، وابن أبي حاتم ٦/٢٦٣.|132:أخرجه ابن إسحاق -كما في سيرة ابن هشام ١/٥٣٠-، وابن جرير ١/٢٤٩، وابن أبي حاتم ١/٣٧.|133:عزاه السيوطي إلى ابن المنذر.|134:أخرجه ابن جرير ١/٢٤٩.|135:عزاه السيوطي إلى عبد بن حميد.|136:أخرجه ابن أبي حاتم ١/٣٨.|137:أخرجه ابن أبي حاتم ١/٣٨.|138:تفسير مقاتل بن سليمان ١/٨١. وآخره يشير إلى قوله تعالى: <span class="qpc-hafs">﴿الَّذِينَ يُقِيمُونَ الصَّلاةَ ويُؤْتُونَ الزَّكاةَ وهُمْ بِالآخِرَةِ هُمْ يُوقِنُونَ﴾</span> [لقمان:٤].|139:أخرجه أبو نعيم في حلية الأولياء ٧/٣٠١.|140:أخرجه ابن جرير ١/٢٥١، وأخرجه ابن أبي حاتم ١/٣٨ من قول السدي -كما سيأتي-. وعزاه السيوطي إلى ابن جرير مقتصرًا على ابن مسعود.|141:أخرجه ابن أبي حاتم ١/٤٠.|142:تفسير مقاتل بن سليمان ١/٨١.|143:أخرجه ابن إسحاق -كما في سيرة ابن هشام ١/٥٣٠-، وابن جرير ١/٢٥٠، وابن أبي حاتم ١/٣٨.|144:عزاه السيوطي إلى عبد بن حميد. وأخرج ابن أبي حاتم ١/٣٨ نحوه من طريق سعيد.|145:تفسير مقاتل بن سليمان ١/٨١.|146:أخرجه ابن إسحاق -كما في سيرة ابن هشام ١/٥٣٠-، وابن جرير ١/٢٥٢، وابن أبي حاتم ١/٣٨.|147:تفسير مقاتل بن سليمان ١/٨١-٨٢.|148:أخرجه ابن جرير ١/٢٤٤، ٢٥١، ٢٥٣، وأخرجه ابن حاتم من قول السدي ١/٣٥، ٣٦، ٣٨. وعزاه السيوطي إلى ابن جرير عن ابن مسعود.|149:أخرجه ابن جرير ١/٢٥٦ وابن أبي حاتم ١/٣٩. وعند النحاس في معاني القرآن ١/٨٥ عن ابن إسحاق من قوله.|150:أخرجه ابن أبي حاتم ١/٣٩.|151:أخرجه ابن أبي حاتم ١/٣٩ (٨٦).</p><p>وفي إسناده عبدالله بن لهيعة، وهو ضعيف. انظر: ميزان الاعتدال ٢/٤٧٥.|152:أخرجه ابن جرير ١/٢٥٦، وابن أبي حاتم ١/٣٩.|153:أخرجه ابن أبي حاتم ١/٤٠. وعزاه السيوطي إلى عبد بن حميد.|154:تفسير مقاتل بن سليمان ١/٨١.
