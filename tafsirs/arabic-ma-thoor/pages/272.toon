quran[12]{c,v,t}:
  16,43,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَمَاۤ أَرۡسَلۡنَا مِن قَبۡلِكَ إِلَّا رِجَالࣰا نُّوحِیۤ إِلَیۡهِمۡۖ فَسۡـَٔلُوۤا۟ أَهۡلَ ٱلذِّكۡرِ إِن كُنتُمۡ لَا تَعۡلَمُونَ ۝٤٣﴾</span> - نزول الآية، وتفسيرها</h3></p><p><div></p><p><p><span class="item-no">٤١٢٣٩<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق أبي روق، عن الضحاك- قال: لما بعث الله محمدًا ﷺ رسولًا أنكرت العرب ذلك، أو من أنكر منهم، فقالوا: الله أعظم من أن يكون رسوله بشرًا مثل محمد. فأنزل الله: <span class="qpc-hafs">﴿أكان للناس عجبًا أن أوحينا إلى رجل منهم﴾</span> [يونس:٢]، وقال: ‹ومَآ أرْسَلْنا مِن قَبْلِكَ إلّا رِجالًا يُوحى{1} إلَيْهِمْ فاسْأَلُوا أهْلَ الذِّكْرِ إن كُنتُمْ لا تَعْلَمُونَ›. يعني: فاسألوا أهل الذكر؛ يعني: أهل الكتب الماضية: أبشرًا كانت الرسل الذين أتتكم أم ملائكة؟ فإن كانوا ملائكة أتتكم، وإن كانوا بشرًا فلا تُنكروا أن يكون رسولًا. ثم قال: ‹ومَآ أرْسَلْنا مِن قَبْلِكَ إلّا رِجالًا يُوحى إلَيْهِم مِّنْ أهْلِ القُرى› [يوسف:١٠٩]، أي: ليسوا من أهل السماء كما قلتُم{2}. (٩/٥٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٢٤٠<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span>، في قوله: <span class="qpc-hafs">﴿فسئلوا أهل الذّكر﴾</span>، قال: نزلت في عبد الله بن سلام، ونفر من أهل التوراة، كانوا أهل الكتب، يقول: فاسألوهم <span class="qpc-hafs">﴿إن كنتم لا تعلمون﴾</span>{3}. (٩/٥١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٢٤١<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span>، في قوله: <span class="qpc-hafs">﴿وما أرسلنا من قبلك إلا رجالًا﴾</span>، قال: قالت العرب: لولا أُنزل علينا الملائكة؟ قال الله: ما أرسَلتُ الرسلَ إلا بشرًا{3}. (٩/٥١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٢٤٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وما أرسلنا من قبلك إلا رجالا نوحي إليهم﴾</span>، نزلت في أبي جهل بن هشام، والوليد بن المغيرة، وعقبة بن أبي معيط، وذلك أنهم قالوا في «سبحان»: <span class="qpc-hafs">﴿أبعث الله بشرا رسولا﴾</span> [الإسراء:٩٤]، يأكل، ويشرب، وتَرَك الملائكة؟! فأنزل الله ﷿: <span class="qpc-hafs">﴿وما أرسلنا من قبلك﴾</span> يا محمد ﷺ <span class="qpc-hafs">﴿إلا رجالا نوحي إليهم﴾</span>{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٢٤٣<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>، في قوله: <span class="qpc-hafs">﴿وما أرسلنا من قبلك إلا رجالا نوحي إليهم فاسألوا أهل الذكر إن كنتم لا تعلمون﴾</span>: يقول للمشركين{6}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿فَسۡـَٔلُوۤا۟ أَهۡلَ ٱلذِّكۡرِ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤١٢٤٤<span class="dash">-</span></span> عن جابر بن عبد الله، قال: قال رسول الله ﷺ: «<b>لا ينبغي للعالم أن يَسْكت عن علمه، ولا ينبغي للجاهل أن يَسْكُت على جهله، وقد قال الله</b>: <span class="qpc-hafs">﴿فسئلوا أهل الذكر إن كنتم لا تعلمون﴾</span>»{7}. (٩/٥٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٢٤٥<span class="dash">-</span></span> عن أنس بن مالك، قال: سمعت رسول الله ﷺ يقول: «<b>إن الرجل لَيُصلِّي ويصوم ويحجُّ ويعتمر ويغزو، وإنه لمنافق</b>». قيل: يا رسول الله، بماذا دخل عليه النفاق؟ قال: «<b>يطعن على إمامِه، وإمامُه مَن قال الله في كتابه</b>: <span class="qpc-hafs">﴿فسئلوا أهل الذكر إن كنتم لا تعلمون﴾</span>»{8}. (٩/٥٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٢٤٦<span class="dash">-</span></span> عن محمد بن المنكدر، قال: قال رسول الله ﷺ: «<b>لا ينبغي لعالم أن يسكت على علمه، ولا لجاهل أن يسكت على جهله، وقد قال الله:</b> <span class="qpc-hafs">﴿فسئلوا أهل الذّكر إن كنتم لا تعلمون﴾</span>. <b>فينبغي للمؤمن أن يعرف علمه؛ على هدًى أم على ضلالة</b>»{9}. (٩/٥٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٢٤٧<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق أبي روق، عن الضحاك- قال: يعني: <span class="qpc-hafs">﴿فاسألوا أهل الذكر﴾</span>، يعني: أهل الكتب الماضية: أبشرًا كانت الرسل الذين أتتكم، أم ملائكة؟ فإن كانوا ملائكة أتتكم{10}، وإن كانوا بشرًا فلا تُنكروا أن يكون رسولًا{11}. (٩/٥٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٢٤٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق أبي يحيى، عن مجاهد-: <span class="qpc-hafs">﴿فسئلوا أهل الذّكر﴾</span>، قال لمشركي قريش: إن محمدًا في التوراة والإنجيل{12}. (٩/٥١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٢٤٩<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ليث- <span class="qpc-hafs">﴿فاسألوا أهل الذكر﴾</span>، قال: أهل التوراة{13}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٢٥٠<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن جريج- قوله: <span class="qpc-hafs">﴿وما أرسلنا من قبلك إلا رجالا نوحي إليهم فاسألوا أهل الذكر إن كنتم لا تعلمون﴾</span>، قال: هم أهل الكتاب{13}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٢٥١<span class="dash">-</span></span> قال <span class="name-2">الحسن البصري</span>: يعني: أهل الكتابين{15}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٢٥٢<span class="dash">-</span></span> قال <span class="name-2">قتادة بن دعامة</span>: يعني: أهل التوراة، هي مثل قوله: <span class="qpc-hafs">﴿فاسألوا أهل الذكر إن كنتم لا تعلمون﴾</span> [الأنبياء:٧]{15}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٢٥٣<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span>، في قوله: <span class="qpc-hafs">﴿فسئلوا﴾</span> يا معشر العرب <span class="qpc-hafs">﴿أهل الذّكر﴾</span> وهم أهل الكتاب من اليهود والنصارى، الذين جاءتهم الرسل قبلكم{3}. (٩/٥١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٢٥٤<span class="dash">-</span></span> قال <span class="name-2">إسماعيل السُّدِّيّ</span>: <span class="qpc-hafs">﴿فاسألوا أهل الذكر﴾</span>، يعني: التوراة، عبد الله بن سلام وأصحابه الذين أسلموا{15}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٢٥٥<span class="dash">-</span></span> عن <span class="name-2">أبي جعفر [محمد الباقر]</span> -من طريق جابر- <span class="qpc-hafs">﴿فاسألوا أهل الذكر إن كنتم لا تعلمون﴾</span>، قال: نحن أهل الذكر{19}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٢٥٦<span class="dash">-</span></span> عن سفيان، قال: سألت [<span class="name-2">سليمان بن مهران</span>] <span class="name-2">الأعمش</span> عن قوله: <span class="qpc-hafs">﴿فاسألوا أهل الذكر﴾</span>. قال: سمعنا أنّه مَن أسلم مِن أهل التوراة والإنجيل{13}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٢٥٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثم قال: <span class="qpc-hafs">﴿فسألوا أهل الذكر﴾</span>، يعني: التوراة{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٢٥٨<span class="dash">-</span></span> عن <span class="name-3">معمر بن راشد</span> -من طريق عبد الرزاق- في قوله: <span class="qpc-hafs">﴿فاسألوا أهل الذكر إن كنتم لا تعلمون﴾</span>، قال: أهل التوراة، فاسألوهم: هل جاءهم إلا رجال يوحى إليهم{22}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٢٥٩<span class="dash">-</span></span> عن <span class="name-3">خارجة بن مصعب</span> -من طريق عبد الله بن عثمان- في قوله ﷿: <span class="qpc-hafs">﴿فسألوا أهل الذكر﴾</span>، قال: أهل العلم{23}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٢٦٠<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿فاسألوا أهل الذكر إن كنتم لا تعلمون﴾</span>، قال: الذكر: القرآن. وقرأ: <span class="qpc-hafs">﴿إنا نحن نزلنا الذكر وإنا له لحافظون﴾</span> [الحجر:٩]، وقرأ: <span class="qpc-hafs">﴿إن الذين كفروا بالذكر لما جاءهم﴾</span> [فصلت:٤١] الآية{19}<span class=comment-ref>٣٦٦٩</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٣٦٦٩</span> الآية ردٌّ على كفار قريش في استبعادهم أن يبعث الله من البشر رسولًا، وقد اختُلِفَ في المعني بـ«أهل الذكر» في هذه الآية على أقوال: <b>الأول:</b> أهل الكتاب من اليهود والنصارى. <b>الثاني:</b> مَن أسلم مِن أهل الكتاب. <b>الثالث:</b> أهل القرآن. وزاد <u>ابن عطية</u> (٥/٣٥٨ ط: دار الكتب العلمية) <b>قولًا</b> نقله عن الزجاج أن أهل الذكر: عام في كل من يُعزى إلى علم.</p><p>و<span class="comment-type-3">استظهر</span> <u>ابن عطية</u> <span class="mustanad">مستندًا إلى الدلالة العقلية</span> القول الأول، وهو قول ابن عباس، فقال: «والأظهر في هذا كله قول ابن عباس ﵄ أن يكون أهل الذكر هنا: أحبار اليهود والنصارى الذين لم يُسلِموا، وهم في هذه النازلة خاصة إنما يُخبِرون بأن الرسل من البشر، وإخبارهم حجَّة على هؤلاء، فإنهم لم يزالوا مصدِّقين لهم، ولا يتهمون بشهادة لنا لأنهم مدافعون في صدر ملة محمد ﷺ -قاتلهم الله-، وهذا هو كسر حجتهم من مذهبهم، لا أنّا افتقرنا إلى شهادة هؤلاء، بل الحق واضح في نفسه، وقد أرسلت قريش إلى يهود يثرب يسألون ويُسنِدون إليهم».</p><p>و<span class="comment-type-2">انتقد</span> القول الثاني والثالث <span class="mustanad">مستندًا إلى الدلالة العقلية</span> قائلًا: «وهذان القولان فيهما ضعف؛ لأنه لا حجَّة على الكفار في إخبار المؤمنين بما ذُكِر، لأنهم يكذبون هذه الصنائف».</p><p>و<span class="comment-type-2">استدرك</span> <u>ابنُ كثير</u> (٨/٣١٤) على القول الثالث -وهو قول ابن زيد، وأبي جعفر- <span class="mustanad">مستندًا إلى الدلالة العقلية</span> قائلًا: «وقول عبد الرحمن بن زيد: الذكر: القرآن. واستشهد بقوله: <span class="qpc-hafs">﴿إنّا نَحْنُ نزلْنا الذِّكْرَ وإنّا لَهُ لَحافِظُونَ﴾</span> [الحجر:٩] صحيح، لكن ليس هو المراد هاهنا؛ لأن المخالف لا يرجع في إثباته بعد إنكاره إليه. وكذا قول أبي جعفر الباقر: نحن أهل الذكر».</p><p>و<span class="comment-type-1">وجَّه</span> قول أبي جعفر الباقر: نحن أهل الذكر. بقوله: «ومراده أن هذه الأمة أهل الذكر صحيح؛ فإن هذه الأمة أعلم من جميع الأمم السالفة، وعلماء أهل بيت رسول الله ﵈ والرحمة من خير العلماء إذا كانوا على السنة المستقيمة، كعلي، وابن عباس، وابني علي: الحسن والحسين، ومحمد بن الحنفية، وعلي بن الحسين زين العابدين، وعلي بن عبد الله بن عباس، وأبي جعفر الباقر: وهو محمد بن علي بن الحسين، وجعفر ابنه، وأمثالهم وأضرابهم وأشكالهم، ممن هو متمسك بحبل الله المتين، وصراطه المستقيم، وعرف لكل ذي حقٍّ حقَّه، ونزَّل كلًّا المنزل الذي أعطاه الله ورسوله، واجتمع إليه قلوب عباده المؤمنين».</div></p><p><h3><span class="qpc-hafs">﴿إِن كُنتُمۡ لَا تَعۡلَمُونَ ۝٤٣﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤١٢٦١<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span>، في قوله: <span class="qpc-hafs">﴿إن كنتم لا تعلمون﴾</span>: أنّ الرسل الذين كانوا قبل محمد ﷺ كانوا بشرًا مثله، فإنهم سيخبرونكم أنهم كانوا بشرًا مثله{3}. (٩/٥١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٢٦٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿إن كنتم لا تعلمون﴾</span> بأن الرسل كانوا من البشر؛ فسيخبرونكم أن الله ﷿ لم يبعث رسولًا إلا من الإنس{5}. (ز)</p></p><p></div></p></div>",footnotes:1:قرأ حفص عن عاصم: <span class="qpc-hafs">﴿نُوحِي﴾</span> بالنون وكسر الحاء، وقرأ الباقون: ‹يُوحى› بالياء وفتح الحاء هنا وفي يوسف. ينظر: النشر ٢/٢٢٢.|2:أخرجه ابن جرير ١٤/٢٢٨، ٢٠/٥٨٣-٥٨٤، وابن أبي حاتم ٦/١٩٢٢، من طريق بشر بن عمارة، عن أبي روق، عن الضحاك، عن ابن عباس به.</p><p>إسناده ضعيف جدًّا؛ فيه بشر بن عمارة، قال عنه ابن حجر في التقريب (٦٩٧): «ضعيف». والضحّاك يرسل كثيرًا، ولم يسمع من ابن عباس، كما في جامع التحصيل للعلائي ص١٩٩.|3:عزاه السيوطي إلى ابن أبي حاتم.|4:عزاه السيوطي إلى ابن أبي حاتم.|5:تفسير مقاتل بن سليمان ٢/٤٧٠.|6:تفسير يحيى بن سلام ١/٦٦.|7:أخرجه الطبراني في الأوسط ٥/٢٩٨ (٥٣٦٥). وأورده الديلمي في الفردوس ٥/١٣٩ (٧٧٤٨).</p><p>قال العراقي في تخريج أحاديث الإحياء ص١٦: «أخرجه الطبراني في الأوسط، وابن مردويه في التفسير ... من حديث جابر بسند ضعيف». وقال الهيثمي في المجمع ١/١٦٤-١٦٥ (٧٥١): «رواه الطبراني في الأوسط، وفيه محمد بن أبي حميد، وقد أجمعوا على ضعفه».|8:عزاه السيوطي إلى ابن مَرْدُويَه.|9:عزاه السيوطي إلى عبد بن حميد.|10:عند ابن جرير ١٤/٢٢٨ بلفظ: أنكرتم.|11:أخرجه ابن جرير ١٤/٢٢٨. وعزاه السيوطي إلى ابن أبي حاتم.|12:أخرجه ابن جرير ١٤/٢٢٧-٢٢٨. وعزاه السيوطي إلى الفريابي، وعبد بن حميد، وابن المنذر، وابن أبي حاتم، وابن مَرْدُويَه بنحوه.|13:أخرجه ابن جرير ١٤/٢٢٧.|14:أخرجه ابن جرير ١٤/٢٢٧.|15:علَّقه يحيى بن سلام ١/٦٦.|16:علَّقه يحيى بن سلام ١/٦٦.|17:عزاه السيوطي إلى ابن أبي حاتم.|18:علَّقه يحيى بن سلام ١/٦٦.|19:أخرجه ابن جرير ١٤/٢٢٨.|20:أخرجه ابن جرير ١٤/٢٢٧.|21:تفسير مقاتل بن سليمان ٢/٤٧٠.|22:أخرجه عبد الرزاق ٦/١٢٥ (١٠٢٠٩).|23:أخرجه أبو جعفر الرملي في جزئه ص١٢٥.|24:أخرجه ابن جرير ١٤/٢٢٨.|25:عزاه السيوطي إلى ابن أبي حاتم.|26:تفسير مقاتل بن سليمان ٢/٤٧٠.
  16,44,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿بِٱلۡبَیِّنَـٰتِ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤١٢٦٣<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿بالبيّنات﴾</span>، قال: الآيات{1}. (٩/٥٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٢٦٤<span class="dash">-</span></span> عن إسماعيل السُّدِّيّ، عن أصحابه، في قوله: <span class="qpc-hafs">﴿بالبيّنات والزّبر﴾</span>، قال: البيّنات: الحلال والحرام الذي كانت تجيء به الأنبياء{2}. (٩/٥٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٢٦٥<span class="dash">-</span></span> قال <span class="name-2">إسماعيل السُّدِّيّ</span>: <span class="qpc-hafs">﴿بالبينات﴾</span>، يعني: بالآيات التي كانت تجيء بها الأنبياء إلى قومهم{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٢٦٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: يعني <span class="qpc-hafs">﴿بالبينات﴾</span>: بالآيات{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٢٦٧<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: وفيها تقديم: وما أرسلنا من قبلك بالبينات والزبر الكتب إلا رجالا يُوحى إليهم{5}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَٱلزُّبُرِۗ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤١٢٦٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق العوفي- <span class="qpc-hafs">﴿والزبر﴾</span>، قال: الزبر: الكُتُب{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٢٦٩<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿والزّبر﴾</span>، قال: الكتب{1}. (٩/٥٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٢٧٠<span class="dash">-</span></span> عن <span class="name-2">الضحاك بن مزاحم</span> -من طريق عبيد بن سليمان- قال في قوله: <span class="qpc-hafs">﴿والزبر﴾</span>، يعني: بالكُتُب{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٢٧١<span class="dash">-</span></span> عن إسماعيل السُّدِّيّ، عن أصحابه، في قوله: <span class="qpc-hafs">﴿والزّبر﴾</span>: كتب الأنبياء{2}. (٩/٥٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٢٧٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿والزبر﴾</span>، يعني: حديث الكتب{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٢٧٣<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿والزبر﴾</span>، يعني: وحديث الكتاب، وما كان قبلهم من المواعظ{5}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَأَنزَلۡنَاۤ إِلَیۡكَ ٱلذِّكۡرَ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤١٢٧٤<span class="dash">-</span></span> عن إسماعيل السدي، عن أصحابه، في قوله: <span class="qpc-hafs">﴿وأنزلنا إليك الذّكر﴾</span>، قال: هو القرآن{2}. (٩/٥٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٢٧٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وأنزلنا إليك الذكر﴾</span>، يعني: القرآن{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٢٧٦<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿وأنزلنا إليك الذكر﴾</span> القرآن{5}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿لِتُبَیِّنَ لِلنَّاسِ مَا نُزِّلَ إِلَیۡهِمۡ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤١٢٧٧<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span>، في قوله: <span class="qpc-hafs">﴿لِتُبيّن للنّاس ما نُزّل إليهم﴾</span>، قال: ما أُحِلَّ لهم، وما حُرِّم عليهم{2}<span class=comment-ref>٣٦٧٠</span>. (٩/٥٣)</p></p><p></div></p><p><div><span class=comment-ref>٣٦٧٠</span> <span class="comment-type-4">ذكر</span> <u>ابنُ عطية</u> (٥/٣٥٩) احتمالين في معنى: <span class="qpc-hafs">﴿لِتُبَيِّنَ﴾</span>، فقال: «<b>يحتمل</b> أن يريد: لتُبَيِّن بِسَرْدِك نص القرآن ما نزل. <b>ويحتمل</b> أن يريد: لتُبَيِّن بتفسيرك المجمل، وبشرحك ما أشكل مما نُزِّل». ثم <span class="comment-type-4">علَّق</span> بقوله: «فيدخل في هذا ما تُبَيِّنُه السنة من أمر الشريعة. وهذا قول مجاهد».</div></p><p><div></p><p><p><span class="item-no">٤١٢٧٨<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span>، في قوله: <span class="qpc-hafs">﴿لتبيّن للنّاس ما نُزّل إليهم﴾</span>، قال: أرسله الله إليهم ليَتَّخِذَ بذلك الحجّة عليهم{2}. (٩/٥٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٢٧٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿لتبين للناس ما نزل إليهم﴾</span> من ربهم{4}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿لِتُبَیِّنَ لِلنَّاسِ مَا نُزِّلَ إِلَیۡهِمۡ﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٤١٢٨٠<span class="dash">-</span></span> عن حذيفة بن اليمان، قال: قام فينا رسول الله ﷺ مقامًا، ما ترك شيئًا يكون في مقامه ذلك إلى قيام الساعة إلا حدَّث به، حَفِظه مَن حَفِظه، ونسيه مَن نسيه، قد علمه أصحابي هؤلاء، وإنه ليكون منه الشيء قد نسيتُه فأراه فأذكره كما يذكر الرجلُ وجهَ الرجل إذا غاب عنه، ثم إذا رآه عرفه{18}. (٩/٥٣)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَلَعَلَّهُمۡ یَتَفَكَّرُونَ ۝٤٤﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤١٢٨١<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق الثوري- في قوله: <span class="qpc-hafs">﴿ولعلهم يتفكّرون﴾</span>، قال: يُطيعون{19}. (٩/٥٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٢٨٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ولعلهم﴾</span> يعني: لكي <span class="qpc-hafs">﴿يتفكرون﴾</span> فيؤمنوا{4}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ١٤/٢٣١. وعزاه السيوطي إلى ابن أبي شيبة، وابن المنذر، وابن أبي حاتم.|2:عزاه السيوطي إلى ابن أبي حاتم.|3:علَّقه يحيى بن سلام ١/٦٦.|4:تفسير مقاتل بن سليمان ٢/٤٧٠.|5:تفسير يحيى بن سلام ١/٦٦.|6:أخرجه ابن جرير ١٤/٢٣١.|7:أخرجه ابن جرير ١٤/٢٣١. وعزاه السيوطي إلى ابن أبي شيبة، وابن المنذر، وابن أبي حاتم.|8:أخرجه ابن جرير ١٤/٢٣١.|9:عزاه السيوطي إلى ابن أبي حاتم.|10:تفسير مقاتل بن سليمان ٢/٤٧٠.|11:تفسير يحيى بن سلام ١/٦٦.|12:عزاه السيوطي إلى ابن أبي حاتم.|13:تفسير مقاتل بن سليمان ٢/٤٧٠.|14:تفسير يحيى بن سلام ١/٦٦.|15:عزاه السيوطي إلى ابن أبي حاتم.|16:عزاه السيوطي إلى ابن أبي حاتم.|17:تفسير مقاتل بن سليمان ٢/٤٧٠.|18:أخرجه البخاري ٨/١٢٣ (٦٦٠٤)، ومسلم ٤/٢٢١٧ (٢٨٩١).|19:أخرجه ابن جرير ١٤/٢٣٢.|20:تفسير مقاتل بن سليمان ٢/٤٧٠.
  16,45,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿أَفَأَمِنَ ٱلَّذِینَ مَكَرُوا۟ ٱلسَّیِّـَٔاتِ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤١٢٨٣<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿أفأمن الذين مكروا السيّئات﴾</span>، قال: هو نمرود بن كنعان وقومه{1}. (٩/٥٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٢٨٤<span class="dash">-</span></span> عن <span class="name-2">الضحاك بن مزاحم</span>، في قوله: <span class="qpc-hafs">﴿أفأمن الذين مكروا السيّئات﴾</span>، قال: تكذيبُهم الرسل وأعمالهم بالمعاصي{2}. (٩/٥٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٢٨٥<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿أفأمن الذين مكروا السيّئات﴾</span>، أي: الشّرك{3}<span class=comment-ref>٣٦٧١</span>. (٩/٥٤)</p></p><p></div></p><p><div><span class=comment-ref>٣٦٧١</span> <span class="comment-type-3">رجَّح</span> <u>ابنُ جرير</u> (١٤/٢٣٣) <span class="mustanad">مستندًا إلى السياق</span> أنّ المقصود بقوله تعالى: <span class="qpc-hafs">﴿أفَأَمِنَ الَّذِينَ مَكَرُوا السَّيِّئاتِ﴾</span> هم مشركو مكة، ومكرهم السيئات: شركهم وتكذيبهم، وعلَّل ذلك بقوله: «لأن ذلك تهديدٌ من الله أهل الشرك به، وهو عقيب قوله: <span class="qpc-hafs">﴿وما أرْسَلْنا مِن قَبْلِكَ إلا رِجالا نُوحِي إلَيْهِمْ فاسْأَلُوا أهْلَ الذِّكْرِ إنْ كُنْتُمْ لا تَعْلَمُونَ﴾</span>، فكان تهديدُ مَن لم يُقِرَّ بحجَّة الله الذي جرى الكلام بخطابه قبل ذلك أحْرى من الخبر عمَّن انقطع ذِكْرُه عنه». ثم ذكر أثر قتادة.</p><p>و<span class="comment-type-3">استظهر</span> ذلك <u>ابنُ عطية</u> (٥/٣٥٩)، ولم يذكر مستندًا.</div></p><p><div></p><p><p><span class="item-no">٤١٢٨٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثم خوف كفار مكة، فقال سبحانه: <span class="qpc-hafs">﴿أفأمن الذين مكروا السيئات﴾</span>، يعني: الذين قالوا الشرك{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٢٨٧<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: قوله: <span class="qpc-hafs">﴿أفأمن الذين مكروا السيئات﴾</span> عملوا السيئات. والسيئات هاهنا: الشرك{5}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿أَن یَخۡسِفَ ٱللَّهُ بِهِمُ ٱلۡأَرۡضَ أَوۡ یَأۡتِیَهُمُ ٱلۡعَذَابُ مِنۡ حَیۡثُ لَا یَشۡعُرُونَ ۝٤٥﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤١٢٨٨<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿أن يخسف الله بهم الأرض﴾</span> يعني: جانبًا منها، <span class="qpc-hafs">﴿أو يأتيهم﴾</span> غير الخسف <span class="qpc-hafs">﴿العذاب من حيث لا يشعرون﴾</span> يعني: لا يعلمون أنه يأتيهم منه{4}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ١٤/٢٣٣. وعزاه السيوطي إلى ابن أبي شيبة، وابن المنذر.|2:عزاه السيوطي إلى ابن أبي حاتم.|3:أخرجه يحيى بن سلام ١/٦٦، وابن جرير ١٤/٢٣٣. وعزاه السيوطي إلى ابن أبي حاتم.|4:تفسير مقاتل بن سليمان ٢/٤٧١.|5:تفسير يحيى بن سلام ١/٦٦.|6:تفسير مقاتل بن سليمان ٢/٤٧١.
  16,46,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿أَوۡ یَأۡخُذَهُمۡ فِی تَقَلُّبِهِمۡ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤١٢٨٩<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- في قوله: <span class="qpc-hafs">﴿أو يأخُذَهُم في تقلّبهم﴾</span>، قال: في اختلافهم{1}. (٩/٥٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٢٩٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق العوفي- في قوله: <span class="qpc-hafs">﴿أو يأخذهم في تقلّبهم﴾</span>، قال: إن شئت أخذتُه في سَفَره{2}. (٩/٥٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٢٩١<span class="dash">-</span></span> عن <span class="name-2">الضحاك بن مزاحم</span>، في قوله: <span class="qpc-hafs">﴿أو يأخذهم في تقلّبهم﴾</span>، يعني: على أيّ حالٍ كانوا بالليل والنهار{3}. (٩/٥٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٢٩٢<span class="dash">-</span></span> تفسير <span class="name-2">الحسن البصري</span>، قال: <span class="qpc-hafs">﴿أو يأخذهم في تقلبهم﴾</span> في البلاد في أسفارهم في غير قرار{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٢٩٣<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- في قوله: <span class="qpc-hafs">﴿أو يأخذهم في تقلّبهم﴾</span>، قال: في أسفارهم{5}. (٩/٥٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٢٩٤<span class="dash">-</span></span> تفسير <span class="name-3">محمد بن السائب الكلبي</span>: <span class="qpc-hafs">﴿أو يأخذهم في تقلبهم﴾</span> في البلاد بالليل والنهار{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٢٩٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span> في قوله تعالى: <span class="qpc-hafs">﴿أو يأخذهم﴾</span> العذاب <span class="qpc-hafs">﴿في تقلبهم﴾</span> في الليل والنهار{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٢٩٦<span class="dash">-</span></span> عن <span class="name-3">عبد الملك ابن جريج</span> -من طريق حجاج- <span class="qpc-hafs">﴿أو يأخذهم في تقلبهم﴾</span>، قال: التقلب: أن يأخذهم بالليل والنهار{8}<span class=comment-ref>٣٦٧٢</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٣٦٧٢</span> <span class="comment-type-4">علَّق</span> <u>ابنُ كثير</u> (٨/٣١٦) على قول الضحاك، وقول محمد بن السائب، ومقاتل، وابن جريج، من طريق حجاج أن قوله تعالى: <span class="qpc-hafs">﴿فِي تَقَلُّبِهِمْ﴾</span> معناه: بالليل والنهار، بقوله: «<span class="mustanad">كقوله تعالى</span>: <span class="qpc-hafs">﴿أفَأَمِنَ أهْلُ القُرى أنْ يَأْتِيَهُمْ بَأْسُنا بَياتًا وهُمْ نائِمُونَ * أوَأَمِنَ أهْلُ القُرى أنْ يَأْتِيَهُمْ بَأْسُنا ضُحًى وهُمْ يَلْعَبُونَ﴾</span> [الأعراف:٩٧-٩٨]».</div></p><p><div></p><p><p><span class="item-no">٤١٢٩٧<span class="dash">-</span></span> عن <span class="name-3">عبد الملك ابن جريج</span>، في قوله: <span class="qpc-hafs">﴿أو يأخذهم في تقلبهم﴾</span>، قال: في إقبالهم وإدبارهم{9}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿فَمَا هُم بِمُعۡجِزِینَ ۝٤٦﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤١٢٩٨<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فما هم بمعجزين﴾</span>، يعني: سابقي الله ﷿ بأعمالهم الخبيثة حتى يجزيهم بها{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٢٩٩<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿فما هم بمعجزين﴾</span> بسابقين{11}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ١٤/٢٣٤. وعزاه السيوطي إلى ابن أبي حاتم.|2:أخرجه ابن جرير ١٤/٢٣٤، ٢٣٧. وعزاه السيوطي إلى ابن أبي حاتم.|3:عزاه السيوطي إلى ابن جرير، وابن أبي حاتم.|4:علَّقه يحيى بن سلام ١/٦٦.|5:أخرجه عبد الرزاق ١/٣٥٦، وابن جرير ١٤/٢٣٤ ومن طريق سعيد أيضًا. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.|6:علَّقه يحيى بن سلام ١/٦٧.|7:تفسير مقاتل بن سليمان ٢/٤٧١.|8:أخرجه ابن جرير ١٤/٢٣٤.|9:تفسير البغوي ٥/٢١.|10:تفسير مقاتل بن سليمان ٢/٤٧١.|11:تفسير يحيى بن سلام ١/٦٦.
  16,47,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿أَوۡ یَأۡخُذَهُمۡ عَلَىٰ تَخَوُّفࣲ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤١٣٠٠<span class="dash">-</span></span> عن <span class="name-1">عمر بن الخطاب</span> -من طريق إبراهيم بن عامر بن مسعود، عن رجل- أنّه سألهم عن هذه الآية: <span class="qpc-hafs">﴿أو يأخذهم على تخوّف﴾</span>. فقالوا: ما نرى إلا أنه عند تنقُّص ما نُرَدِّدُه من الآيات. فقال عمر: ما أرى إلا أنه على ما تَنتَقِصون من معاصي الله. قال: فخرج رجل ممن كان عند عمر، فلقي أعرابيًّا فقال: يا فلان، ما فعل ربُّك؟ قال: قد تَخَيَّفتُه. يعني: تَنقَّصتُه. قال: فرجَع إلى عمر، فأخبره، فقال: قدَّر الله ذلك{1}. (٩/٥٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٣٠١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق العوفي- وفي قوله: <span class="qpc-hafs">﴿أو يأخذهم على تخوّف﴾</span>، يقول: إن شئتُ أخذتُه على إثر موت صاحبه، نُخَوِّفُ بذلك{2}. (٩/٥٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٣٠٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق الضحاك- في قوله: <span class="qpc-hafs">﴿أو يأخذهم على تخوّف﴾</span>، قال: تنقُّص من أعمالهم{3}. (٩/٥٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٣٠٣<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطاء الخراساني- في قوله: <span class="qpc-hafs">﴿أو يأخذهم على تخوّف﴾</span>، قال: التنقُّص والتقريع{4}. (٩/٥٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٣٠٤<span class="dash">-</span></span> عن <span class="name-2">سعيد بن المسيب</span> -من طريق يحيى بن سعيد- في قول الله: <span class="qpc-hafs">﴿أو يأخذهم على تخوف﴾</span> أنّه على عجل{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٣٠٥<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿أو يأخذهم على تخوّف﴾</span>، قال: يأخُذهم بنقْصِ بعضهم بعضًا{6}. (٩/٥٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٣٠٦<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿أو يأخذهم على تخوّف﴾</span>، قال: يأخذهم بنقص النِّعَم، نقص من عاهدهم من هذا، وهو نمروذ بن كنعان وقومه{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٣٠٧<span class="dash">-</span></span> تفسير <span class="name-2">مجاهد بن جبر</span> -من طريق ابن مجاهد- من قوله: <span class="qpc-hafs">﴿مكروا السيئات﴾</span> إلى قوله: <span class="qpc-hafs">﴿على تخوف﴾</span>: بعض ما أوعدهم من هذا، وهو نمرود بن كنعان وقومه{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٣٠٨<span class="dash">-</span></span> عن <span class="name-2">الضحاك بن مزاحم</span> -من طريق عبيد بن سليمان- في قوله: <span class="qpc-hafs">﴿أو يأخذهم على تخوّف﴾</span>، يعني: أن يأخذ بعضًا بالعذاب ويترك بعضًا، وذلك أنه كان يعذِّب القرية فيُهلِكُها، ويترك الأخرى{9}<span class=comment-ref>٣٦٧٣</span>. (٩/٥٤)</p></p><p></div></p><p><div><span class=comment-ref>٣٦٧٣</span> <span class="comment-type-4">ذكر</span> <u>ابنُ عطية</u> (٥/٣٦١) أن «هذا التنقيص يتَّجه الوعيد به على معنيين: <b>أحدهما</b>: أن يهلكهم ويخرج أرواحهم على تخوف، أي: أفذاذًا، يتَنَقَّصَهم بذلك الشيء بعد الشيء». ثم <span class="comment-type-4">علَّق</span> عليه بقوله: «وهذا لا يدَّعي أحد أنه يأمنه، وكأن هذا الوعيد إنما يكون بعذاب ما يلقون بعد الموت، وإلا فهكذا تهلك الأمم كلها، <span class="mustanad">ويؤيد هذا قوله</span>: <span class="qpc-hafs">﴿فَإنَّ رَبَّكُمْ لَرَؤُفٌ رَحِيمٌ﴾</span>، أي: أن هذه الرتبة من الوعيد فيها رأفة ورحمة وإمهال ليتوب التائب ويرجع الراجع». «<b>والآخر</b>: ما قال الضحاك: أن يأخذ بالعذاب طائفة أو قرية، ويترك أخرى، ثم كذلك حتى يهلك الكل».</div></p><p><div></p><p><p><span class="item-no">٤١٣٠٩<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد-: <span class="qpc-hafs">﴿أو يأخذهم على تخوف﴾</span>، فيعاقب، أو يتجاوز{10}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٣١٠<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق شيبان- في قول الله ﷿: <span class="qpc-hafs">﴿أو يأخذهم على تخوف﴾</span>، قال: على تنقص{11}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٣١١<span class="dash">-</span></span> تفسير <span class="name-2">إسماعيل السُّدِّيّ</span>: <span class="qpc-hafs">﴿أو يأخذهم على تخوف﴾</span> على تنقص{12}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٣١٢<span class="dash">-</span></span> عن <span class="name-3">محمد بن السائب الكلبي</span> -من طريق معمر- في قوله: <span class="qpc-hafs">﴿على تخوف﴾</span>، قال: على تنقُّص. يقول: يُصابون في أطراف قراهم بالشيء، حتى يأتي ذلك عليهم{13}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٣١٣<span class="dash">-</span></span> قال <span class="name-3">محمد بن السائب الكلبي</span>: مِن الخوف، أي: يعذب طائفة، فيتخوف الآخرون أن يصيبهم مثل ما أصابهم{14}<span class=comment-ref>٣٦٧٤</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٣٦٧٤</span> <span class="comment-type-4">علق</span> <u>ابنُ عطية</u> (٥/٣٦١) على قول محمد بن السائب الكلبي قائلًا: «وفي هذا تكلُّف ما».</div></p><p><div></p><p><p><span class="item-no">٤١٣١٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿أو يأخذهم على تخوف﴾</span>، يقول: يأخذ أهل هذه القرية بالعذاب، ويترك الأخرى قريبًا منها؛ لكي يخافوا فيعتبروا، يخوفهم بمثل ذلك{15}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٣١٥<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿أو يأخذهم على تخوّف﴾</span>، قال: كان يقال: التَّخَوُّف: هو التَّنَقُّص؛ ينتَقِصْهم من البلدان والأطراف{9}. (٩/٥٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٣١٦<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿أو يأخذهم على تخوف﴾</span>، يهلك القرية يخوف بهلاكها القرية الأخرى لعلهم يرجعون، لعل من بقي ممن هو على دينهم –الشرك- أن يرجعوا إلى الإيمان{17}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿فَإِنَّ رَبَّكُمۡ لَرَءُوفࣱ رَّحِیمٌ ۝٤٧﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤١٣١٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فإن ربكم لرؤف﴾</span> يعني: يرِقُّ لهم، <span class="qpc-hafs">﴿رحيم﴾</span> بهم حين لا يعجل عليهم بالعقوبة{15}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٣١٨<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿على تخوف﴾</span> على تنقص، أن يبتليهم بالجهد حتى يرقوا ويقل عددهم، فإن تابوا وأصلحوا كشف عنهم. فذلك قوله: <span class="qpc-hafs">﴿فإن ربكم لرءوف رحيم﴾</span>، أي: إن تابوا وأصلحوا{17}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ١٤/٢٣٦.|2:أخرجه ابن جرير ١٤/٢٣٧. وعزاه السيوطي إلى ابن أبي حاتم.|3:أخرجه ابن أبي حاتم -كما في فتح الباري ٨/٣٨٦-.|4:أخرجه ابن جرير ١٤/٢٣٧.|5:أخرجه ابن وهب في الجامع ٢/١٥٤ (٣١٥).|6:أخرجه ابن جرير ١٤/٢٣٧. وعزاه السيوطي إلى ابن أبي شيبة، وابن المنذر.|7:تفسير مجاهد ص٤٢٢.|8:أخرجه يحيى بن سلام ١/٦٧.|9:أخرجه ابن جرير ١٤/٢٣٨. وعزاه السيوطي إلى ابن أبي حاتم.|10:أخرجه ابن جرير ١٤/٢٣٨.|11:أخرجه الزجاجي في الأمالي ص٣٧.|12:علَّقه يحيى بن سلام ١/٦٧.|13:أخرجه عبد الرزاق في تفسيره ٢/٣٥٦.|14:تفسير الثعلبي ٦/١٩، وتفسير البغوي ٥/٢١.|15:تفسير مقاتل بن سليمان ٢/٤٧١.|16:أخرجه ابن جرير ١٤/٢٣٨. وعزاه السيوطي إلى ابن أبي حاتم.|17:تفسير يحيى بن سلام ١/٦٧.|18:تفسير مقاتل بن سليمان ٢/٤٧١.|19:تفسير يحيى بن سلام ١/٦٧.
  16,48,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿أَوَلَمۡ یَرَوۡا۟ إِلَىٰ مَا خَلَقَ ٱللَّهُ مِن شَیۡءࣲ یَتَفَیَّؤُا۟ ظِلَـٰلُهُۥ عَنِ ٱلۡیَمِینِ وَٱلشَّمَاۤىِٕلِ سُجَّدࣰا لِّلَّهِ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤١٣١٩<span class="dash">-</span></span> عن عمر بن الخطاب، قال: قال رسول الله ﷺ: «<b>أربع قبل الظهر بعد الزَّوال، تُحسب بمثلهن من صلاة السّحر</b>». قال رسول الله ﷺ: «<b>وليس من شيء إلا وهو يُسبح الله تلك الساعة</b>». ثم قرأ: <span class="qpc-hafs">﴿يتفيّؤا ظلاله عن اليمين والشّمآئل سجّدًا لله﴾</span> الآية كلّها{1}. (٩/٥٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٣٢٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- في قوله: <span class="qpc-hafs">﴿يتفيّؤا ظلاله﴾</span>، قال: تتميَّل{2}. (٩/٥٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٣٢١<span class="dash">-</span></span> قال <span class="name-1">عبد الله بن عباس</span>: ‹تَتَفَيَّأُ ظِلالُهُ›: تتهيأ{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٣٢٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق العوفي- قوله: <span class="qpc-hafs">﴿أولم يروا إلى ما خلق الله من شيء يتفيأ ظلاله﴾</span>: ما خلق من شيء عن يمينه وشمائله -فلفظ <span class="qpc-hafs">﴿ما﴾</span> لفظ عن اليمين والشمائل- قال: ألم تر أنك إذا صليت الفجر كان ما بين مطلع الشمس إلى مغربها ظلًّا؟ ثم بعث الله عليه الشمس دليلًا، وقبض الله الظل{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٣٢٣<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن جريج- في الآية، قال: فَيْءُ كلِّ شيء ظِلُّه، وسجود كلِّ شيء فيئُه؛ سجود الجبال فيئُها{5}. (٩/٥٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٣٢٤<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق منصور- في الآية، قال: إذا زالت الشمس سجد كلُّ شيء لله{6}. (٩/٥٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٣٢٥<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span>، في قوله: <span class="qpc-hafs">﴿يتفيّؤا ظلاله عن اليمين والشّمآئل﴾</span>، قال: الغدوّ والآصال، إذا فاء ظلُّ كلِّ شيء، أما الظِّلُّ بالغداة فعن اليمين، وأما بالعَشِيِّ فعن الشمائل، إذا كان بالغداة سجدت لله، وإذا كان بالعَشِيّ سجدت له{7}. (٩/٥٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٣٢٦<span class="dash">-</span></span> عن <span class="name-2">الضحاك بن مزاحم</span> -من طريق ثابت- في قوله: <span class="qpc-hafs">﴿أو لم يروا إلى ما خلق الله من شيء يتفيّؤا ظلاله﴾</span>، قال: إذا فاء الفيء توجَّه كلُّ شيء ساجدًا لله قِبَلَ القبلة من بيت أو شجر. قال: فكانوا يستحِبُّون الصلاة عند ذلك{8}. (٩/٥٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٣٢٧<span class="dash">-</span></span> عن <span class="name-2">الضحاك بن مزاحم</span> -من طريق ثابت- في الآية، قال: إذا فاء الفيء لم يبق شيءٌ مِن دابة ولا طائر إلا خَرَّ لله ساجدًا{9}. (٩/٥٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٣٢٨<span class="dash">-</span></span> عن <span class="name-2">الضحاك بن مزاحم</span> -من طريق عبيد بن سليمان- في قوله: <span class="qpc-hafs">﴿يتفيؤ ظلاله عن اليمين والشمائل﴾</span>، قال: يعني بالغدو والآصال: تسجد الظلال لله غدوة إلى أن يفيء الظل، ثم تسجد لله إلى الليل، يعني: ظل كل شيء{10}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٣٢٩<span class="dash">-</span></span> عن <span class="name-2">الضحاك بن مزاحم</span>، في قوله ﷿: <span class="qpc-hafs">﴿عن اليمين والشمائل سجدا لله﴾</span>، قال: أما اليمين: فأول النهار، والشمال: آخر النهار، تسجد الظلال لله{11}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٣٣٠<span class="dash">-</span></span> قال <span class="name-2">الحسن البصري</span>: ربما كان الفيء عن اليمين، وربما كان عن الشمال{12}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٣٣١<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿أولم يروا إلى ما خلق الله من شيء يتفيّؤا ظلاله عن اليمين والشّمآئل سجّدًا لله﴾</span>، قال: ظِلُّ كلِّ شيء: فَيْئُه، وظلُّ كلِّ شيء: سجوده، فاليمين أول النهار، والشمائل آخر النهار{13}. (٩/٥٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٣٣٢<span class="dash">-</span></span> عن <span class="name-2">سعد بن إبراهيم</span> -من طريق موسى بن عبيدة- قال: صلُّوا صلاة الآصال حين يفيء الفيء قبل النداء بالظهر، من صلّاها فكأنما تهجَّد بالليل{14}. (٩/٥٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٣٣٣<span class="dash">-</span></span> قال <span class="name-3">محمد بن السائب الكلبي</span>: وهذا يكون قبل طلوع الشمس وبعد غروبها، فعند ذلك يكون الظل عن اليمين والشمال، ولا يكون ذلك في ساعة إلا قبل طلوع الشمس وبعد غروبها{12}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٣٣٤<span class="dash">-</span></span> عن <span class="name-3">محمد بن السائب الكلبي</span>، في قوله ﷿: <span class="qpc-hafs">﴿عن اليمين والشمائل سجدا لله﴾</span>، قال: الظل قبل طلوع الشمس عن يمينك وعن شمالك وقدامك وخلفك، وكذلك إذا غابت، فإذا طلعت كان من قدامك، وإذا ارتفعت كان عن يمينك، ثم بعده كان خلفك، فإذا كان قبل أن تغرب الشمس كان عن يسارك، فهذا تفيُّؤه، وتقلبه، وهو سجوده{11}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٣٣٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثم وعظ كفار مكة؛ ليعتبروا في صنعه، فقال سبحانه: <span class="qpc-hafs">﴿أولم يروا إلى ما خلق الله من شيء﴾</span> في الأرض <span class="qpc-hafs">﴿يتفيؤا ظلاله عن اليمين والشمائل سجدا﴾</span> وذلك أنّ الشجر، والبنيان، والجبال، والدواب، وكل شيء، إذا طلعت عليه الشمس يتحول ظلُّ كل شيء عن اليمين قِبَل المغرب، فذلك قوله سبحانه: <span class="qpc-hafs">﴿يتفيؤا ظلاله﴾</span> يعني: يتحول الظل، فإذا زالت الشمس تحول الظل عن الشمال قِبَل المشرق، كسجود كل شيء في الأرض لله تعالى ظله في النهار <span class="qpc-hafs">﴿سجدا لله﴾</span>{17}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٣٣٦<span class="dash">-</span></span> عن <span class="name-3">عبد الملك ابن جريج</span> -من طريق حجاج- <span class="qpc-hafs">﴿يتفيؤ ظلاله عن اليمين والشمائل﴾</span>، قال: الغدو والآصال؛ إذا فاءت الظلال -ظلال كل شيء- بالغدو سجدت لله، وإذا فاءت بالعشي سجدت لله{10}<span class=comment-ref>٣٦٧٥</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٣٦٧٥</span> <span class="comment-type-1">وجَّه</span> <u>ابنُ عطية</u> (٥/٣٦٤) قول ابن عباس من طريق العوفي بقوله: «وعلى هذا فأول ذرور الشمس [طلوعها] فالظل عن يمين مستقبل الجنوب، ثم يبدأُ الانحراف فهو عن الشمائل؛ لأنها حركات كثيرة وظلال مقطعة، فهي شمائل كثيرة، وكان الظل عن اليمين متصلًا واحدًا عامًّا لكلِّ شيءٍ، وفي هذا القول تجوُّز في <span class="qpc-hafs">﴿يَتَفَيَّأُ﴾</span>». و<span class="comment-type-1">وجَّه</span> قول قتادة، وابن جريج بقوله: «ومن ذهب إلى أن اليمين: من غدوة النهار إلى الزوال، ثم يكون من الزوال إلى المغيب عن الشمال -وهو قول قتادة، وابن جريج-، فإنما يترتب له ذلك فيما قدره مستقبل الجنوب، والاعتبار في هذه الآية عندي إنما هو مستقبل الجنوب». ثم ذكر <b>قولًا</b> عن بعض الناس، و<span class="comment-type-2">انتقده</span>، فقال: «وما قاله بعض الناس من: أن اليمين أول دفعة للظل بعد الزوال، ثم الآخر إلى الغروب هي عن الشمائل، ولذلك جمع الشَّمائل وأفرد اليمين. فتخليط من القول يبطل من جهات». ولم يذكرها.</div></p><p><div></p><p><p><span class="item-no">٤١٣٣٧<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: قوله: <span class="qpc-hafs">﴿أولم يروا إلى ما خلق الله من شيء يتفيأ ظلاله﴾</span> يعني: ظل كل شيء من الفيء <span class="qpc-hafs">﴿عن اليمين والشمائل﴾</span> والفيء: الظل <span class="qpc-hafs">﴿سجدا لله﴾</span> فظل كل شيء: سجوده{19}<span class=comment-ref>٣٦٧٦</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٣٦٧٦</span> اختلف في معنى: <span class="qpc-hafs">﴿سُجَّدًا لِلَّهِ﴾</span> في هذه الآية على أقوال: <b>الأول:</b> أن ظل كل شيء سجوده. <b>الثاني:</b> أن سجود الظلال سجود أشخاصها. <b>الثالث:</b> أن سجود الظلال كسجود الأشخاص تسجد لله خاضعة.</p><p>و<span class="comment-type-1">وجَّه</span> <u>ابنُ عطية</u> (٥/٣٦٥) القول الأول بقوله: «هو سجود عبادة حقيقية». و<span class="comment-type-1">وجَّه</span> القول الثالث بقوله: «عبَّر عن الخضوع والطاعة وميلان الظلال ودورانها بالسجود».</p><p>و<span class="comment-type-3">رجَّح</span> <u>ابنُ جرير</u> (١٤/٢٤٢) <span class="mustanad">مستندًا إلى دلالة اللغة، وأقوال السلف</span> القول الثالث، وهو قول ابن عباس من طريق العوفي، فقال: «وأولى الأقوال في ذلك بالصواب أن يقال: إن الله أخبر في هذه الآية أن ظلال الأشياء هي التي تسجد. وسجودها: مَيَلانُها ودَوَرانُها من جانبٍ إلى جانبٍ، وناحيةٍ إلى ناحيةٍ. كما قال ابن عباس. يقال من ذلك: سجَدَتِ النخلة إذا مالت، وسجَدَ البعير وأسْجَدَ: إذا مَيَّل للركوب».</div></p><p><h3><span class="qpc-hafs">﴿أَوَلَمۡ یَرَوۡا۟ إِلَىٰ مَا خَلَقَ ٱللَّهُ مِن شَیۡءࣲ یَتَفَیَّؤُا۟ ظِلَـٰلُهُۥ عَنِ ٱلۡیَمِینِ وَٱلشَّمَاۤىِٕلِ سُجَّدࣰا لِّلَّهِ﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٤١٣٣٨<span class="dash">-</span></span> عن أبي غالب الشّيباني، قال: أمواج البحر صلاته{20}. (٩/٥٨)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَهُمۡ دَ ٰ⁠خِرُونَ ۝٤٨﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤١٣٣٩<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿وهم داخرون﴾</span>، قال: صاغرون{21}. (٩/٥٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٣٤٠<span class="dash">-</span></span> عن <span class="name-2">الضحاك بن مزاحم</span> -من طريق ثابت- <span class="qpc-hafs">﴿يتفيؤ ظلاله﴾</span>، قال: سجد ظل المؤمن طوعًا، وظل الكافر كرهًا{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٣٤١<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿وهم داخرون﴾</span>، قال: صاغرون{23}. (٩/٥٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٣٤٢<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span>: فسجد ظل الكافر كرهًا، يسجد ظله والكافر كاره{24}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٣٤٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: يقول <span class="qpc-hafs">﴿وهم داخرون﴾</span>، يعني: صاغرون{17}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه الترمذي ٥/٣٥٦ (٣٣٩٤). وأورده الثعلبي ٦/٢٠.</p><p>قال الترمذي: «هذا حديث غريب، لا نعرفه إلا من حديث علي بن عاصم». وأورده الألباني في الصحيحة ٣/٤١٦-٤١٧ (١٤٣١).|2:أخرجه ابن جرير ١٤/٢٤٠. وعلقه البخاري ١/١١٣. وعزاه السيوطي إلى ابن أبي حاتم.|3:علقه البخاري ٤/١٧٣٩. قال الحافظ ابن حجر في فتح الباري ٨/٣٨٥: «كذا فيه، والصواب: تتميَّل. وقد تقدم بيانه في كتاب الصلاة». يشير إلى الأثر السابق.</p><p>وقراءة التاء هي قراءة أبي عمرو ويعقوب، وقرأ الباقون بالياء. انظر: النشر ٢/٣٠٤.|4:أخرجه ابن جرير ١٤/٢٤٢.|5:أخرجه ابن جرير ١٤/٢٤٢ بنحوه. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.|6:أخرجه ابن جرير ١٤/٢٤١.|7:عزاه السيوطي إلى ابن جرير، وابن المنذر. والأثر عند ابن جرير بنحوه من قول ابن جريج كما سيأتي.|8:أخرجه ابن جرير ١٤/٢٤١. وعزاه السيوطي إلى ابن أبي حاتم.|9:أخرجه أبو الشيخ في العظمة (١٢١٢). وعزاه السيوطي إلى ابن أبي حاتم.|10:أخرجه ابن جرير ١٤/٢٤٠.|11:تفسير الثعلبي ٦/٢٠، وتفسير البغوي ٥/٢١.|12:علَّقه يحيى بن سلام ١/٦٧.|13:أخرجه يحيى بن سلام ١/٦٧ مختصرًا، وعبد الرزاق ١/٣٥٦ من طريق معمر، وابن جرير ١٤/٢٣٩ مختصرًا. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.|14:أخرجه ابن أبي شيبة ١/٤٠٤.|15:علَّقه يحيى بن سلام ١/٦٧.|16:تفسير الثعلبي ٦/٢٠، وتفسير البغوي ٥/٢١.|17:تفسير مقاتل بن سليمان ٢/٤٧١.|18:أخرجه ابن جرير ١٤/٢٤٠.|19:تفسير يحيى بن سلام ١/٦٧.|20:عزاه السيوطي إلى ابن أبي حاتم.|21:أخرجه ابن جرير ١٤/٢٤٣. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.|22:أخرجه ابن جرير ١٤/٢٤١.|23:أخرجه عبد الرزاق ١/٣٥٦ من طريق معمر، وابن جرير ١٤/٢٤٣. وعلقه يحيى بن سلام ١/٦٧. وعزاه السيوطي إلى ابن المنذر.|24:علقه يحيى بن سلام ١/٦٧.|25:تفسير مقاتل بن سليمان ٢/٤٧١.
  16,49,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَلِلَّهِ یَسۡجُدُ مَا فِی ٱلسَّمَـٰوَ ٰ⁠تِ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤١٣٤٤<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span>، في الآية، قال: يسجد من في السماوات طوعًا{1}. (٩/٥٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٣٤٥<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿ولله يسجد ما في السماوات وما في الأرض من دآبّة﴾</span>، قال: لم يدع شيئًا من خلقه إلا عبَّده له؛ طائعًا أو كارهًا{2}. (٩/٥٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٣٤٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: إذا قال: <span class="qpc-hafs">﴿ما في السماوات﴾</span> يعني: من الملائكة وغيرهم، وكل شيء في السماء، والأرض، والجبال، والأشجار، وكل شيء في الأرض. وإذا قال: <span class="qpc-hafs">﴿من في السموات﴾</span> يعني: كل ذي روح من الملائكة، والآدميين، والطير، والوحوش، والدواب، والسباع، والهوام، والحيتان في الماء، وكل ذي روح أيضًا، يسجدون{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٣٤٧<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: قوله: <span class="qpc-hafs">﴿ولله يسجد ما في السموات﴾</span> الملائكة{4}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَمَا فِی ٱلۡأَرۡضِ مِن دَاۤبَّةࣲ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤١٣٤٨<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span>، في الآية، قال: يسجد من في السماوات طوعًا، ومن في الأرض طوعًا وكرهًا{1}. (٩/٥٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٣٤٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ولِلَّهِ يَسْجُدُ ما فِي السَّماواتِ﴾</span> من الملائكة، <span class="qpc-hafs">﴿وما فِي الأَرْضِ مِن دابَّةٍ﴾</span> أيضًا يسجدون{3}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَٱلۡمَلَـٰۤىِٕكَةُ وَهُمۡ لَا یَسۡتَكۡبِرُونَ ۝٤٩﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤١٣٥٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثم نعت الله الملائكة، فقال: <span class="qpc-hafs">﴿والملائكة وهم لا يستكبرون﴾</span>، يعني: لا يتكبرون عن السجود{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٣٥١<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: قوله: <span class="qpc-hafs">﴿وهم لا يستكبرون﴾</span> عن عبادة الله، يعني: الملائكة{4}. (ز)</p></p><p></div></p></div>",footnotes:1:عزاه السيوطي إلى ابن أبي حاتم.|2:أخرجه ابن جرير ١٤/٢٤٨. وعزاه السيوطي إلى ابن أبي حاتم.|3:تفسير مقاتل بن سليمان ٢/٤٧١.|4:تفسير يحيى بن سلام ١/٦٨.|5:عزاه السيوطي إلى ابن أبي حاتم.|6:تفسير مقاتل بن سليمان ٢/٤٧١.|7:تفسير مقاتل بن سليمان ٢/٤٧١-٤٧٢.|8:تفسير يحيى بن سلام ١/٦٨.
  16,50,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿یَخَافُونَ رَبَّهُم مِّن فَوۡقِهِمۡ وَیَفۡعَلُونَ مَا یُؤۡمَرُونَ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤١٣٥٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق ابن أبي نجيح، عن مجاهد- في قوله: <span class="qpc-hafs">﴿يخافون ربّهم من فوقهم﴾</span>، قال: مخافة الإجلال{1}. (٩/٥٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٣٥٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿يخافون ربهم من فوقهم﴾</span> الذي هو فوقهم؛ لأن الله تعالى فوق كل شيء؛ خلق العرش، والعرش فوق كل شيء، <span class="qpc-hafs">﴿ويفعلون ما يؤمرون﴾</span>{2}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه الخطيب في تاريخه ١/٣٣١.|2:تفسير مقاتل بن سليمان ٢/٤٧٢.
  16,51,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَقَالَ ٱللَّهُ لَا تَتَّخِذُوۤا۟ إِلَـٰهَیۡنِ ٱثۡنَیۡنِۖ إِنَّمَا هُوَ إِلَـٰهࣱ وَ ٰ⁠حِدࣱ فَإِیَّـٰیَ فَٱرۡهَبُونِ ۝٥١﴾</span> - نزول الآية</h3></p><p><div></p><p><p><span class="item-no">٤١٣٥٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وقالَ اللَّهُ لا تَتَّخِذُوا إلهَيْنِ اثْنَيْنِ﴾</span>، وذلك أنّ رجلًا من المسلمين دعا الله ﷿ في صلاته، ودعا الرحمن. فقال رجل من المشركين: أليس يزعم محمد ﷺ وأصحابه أنهم يعبدون ربًّا واحدًا، فما بال هذا يدعو ربين اثنين؟! فأنزل الله ﷿ في قوله: <span class="qpc-hafs">﴿لا تَتَّخِذُوا إلهَيْنِ اثْنَيْنِ﴾</span>{1}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَقَالَ ٱللَّهُ لَا تَتَّخِذُوۤا۟ إِلَـٰهَیۡنِ ٱثۡنَیۡنِۖ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤١٣٥٥<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿وقال الله لا تتخذوا إلهين اثنين﴾</span>، أي: لا تعبدوا مع الله غيره{2}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿إِنَّمَا هُوَ إِلَـٰهࣱ وَ ٰ⁠حِدࣱ فَإِیَّـٰیَ فَٱرۡهَبُونِ ۝٥١﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤١٣٥٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿إنَّما هُوَ إلهٌ واحِدٌ فَإيّايَ فارْهَبُونِ﴾</span>، يعني: إيّاي فخافون في ترك التوحيد، فمَن لم يوحد فله النار{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٣٥٧<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿إنما هو إله واحد فإياي فارهبون﴾</span> فخافون{2}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿إِنَّمَا هُوَ إِلَـٰهࣱ وَ ٰ⁠حِدࣱ فَإِیَّـٰیَ فَٱرۡهَبُونِ ۝٥١﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٤١٣٥٨<span class="dash">-</span></span> عن سعد بن أبي وقاص، قال: مَرَّ النبي ﷺ وأنا أدعو بأصابعي، فقال النبي ﷺ: «<b>أحِّدْ، أحِّدْ</b>». وأشار بالسبّابة{5}. (٩/٥٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٣٥٩<span class="dash">-</span></span> عن <span class="name-1">عائشة</span> -من طريق قتادة، عن رجل- أنها رأت امرأةً تدعو وهي رافعة إصبعيها التي تلي الإبهامين، فقالت لها: إنما الله إله واحد. فنهتها عن ذلك{6}. (٩/٦٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٣٦٠<span class="dash">-</span></span> عن نافع، أن <span class="name-1">عبد الله بن عمر</span> رأى رجلًا يشير بإصبعيه، فقال له ابن عمر: إنما الله إلهٌ واحدٌ؛ فأشِرْ بإصبع واحدة إذا أشَرْت{7}. (٩/٦٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٣٦١<span class="dash">-</span></span> عن <span class="name-2">محمد بن سيرين</span> -من طريق ابن عون- قال: كانوا إذا رأوا إنسانًا يدعو بإصْبَعَيه ضربوا إحداهما، وقالوا: <span class="qpc-hafs">﴿إنّما هو إلهٌ واحدٌ﴾</span>{8}. (٩/٥٩)</p></p><p></div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٢/٤٧٢.|2:تفسير يحيى بن سلام ١/٦٨.|3:تفسير مقاتل بن سليمان ٢/٤٧٢.|4:تفسير يحيى بن سلام ١/٦٨.|5:أخرجه أبو داود ٢/٦١٥ (١٤٩٩)، والنسائي ٣/٣٨ (١٢٧٣) والحاكم ١/٧١٩ (١٩٦٦).</p><p>قال الحاكم: «هذا حديث صحيح الإسنادين جميعًا، فأما حديث أبي معاوية فهو صحيح على شرطهما إن كان أبو صالح السمان سمع من سعد». وذكر الدارقطني في العلل ٤/٣٩٧ (٦٥٥) الاختلاف في إسناده على صحابيّه، ورجَّح أنه من حديث سعد. وقال الألباني في صحيح أبي داود ٥/٢٣٥ (١٣٤٤): «إسناده صحيح، على شرط الشيخين».|6:أخرجه عبد الرزاق في مصنفه (٣٢٤٣).|7:أخرجه عبد الرزاق في مصنفه (٣٢٤١).|8:أخرجه ابن أبي شيبة ١٠/٣٨٢.
  16,52,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَلَهُۥ مَا فِی ٱلسَّمَـٰوَ ٰ⁠تِ وَٱلۡأَرۡضِ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤١٣٦٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثم عظَّم الربُّ -تبارك وتعالى- نفسه من أن يكون معه إله آخر، فقال ﷿: <span class="qpc-hafs">﴿ولَهُ ما فِي السَّماواتِ والأَرْضِ﴾</span> مِن الخلق؛ عبيده، وفي ملكه{1}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَلَهُ ٱلدِّینُ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤١٣٦٣<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن جريج- في قوله: <span class="qpc-hafs">﴿وله الدّين واصِبًا﴾</span>، قال: <span class="qpc-hafs">﴿الدّين﴾</span>: الإخلاص{2}. (٩/٦٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٣٦٤<span class="dash">-</span></span> عن <span class="name-2">أبي صالح باذام</span>، في قوله: <span class="qpc-hafs">﴿وله الدّين واصبًا﴾</span>، قال: لا إله إلا الله{3}. (٩/٦٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٣٦٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ولَهُ الدِّينُ﴾</span>، يعني: الإسلام{1}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَاصِبًاۚ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤١٣٦٦<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق أبي نضرة- في قوله: <span class="qpc-hafs">﴿وله الدّين واصِبًا﴾</span>، قال: دائمًا{5}. (٩/٦١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٣٦٧<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عكرمة- في قوله: <span class="qpc-hafs">﴿وله الدّين واصِبًا﴾</span>، قال: واجبًا{6}<span class=comment-ref>٣٦٧٧</span>. (٩/٦١)</p></p><p></div></p><p><div><span class=comment-ref>٣٦٧٧</span> ذكر <u>ابنُ عطية</u> (٥/٣٦٨) عن ابن عباس أن «الواصب» بمعنى: الواجب. و<span class="comment-type-4">علّق</span> عليه بقوله: «وهذا نحو قوله: الواصب: الدائم». وذكر <u>ابنُ عطية</u> في معنى الواصب <b>قولًا آخر</b>: أن معناه: التعب. ثم <span class="comment-type-4">علّق</span> عليه قائلًا: «فـ»واصب" على هذا جار على النسب، أي: ذا وصب، <span class="mustanad">كما قال</span>:</p><p>أضحى فؤادي به فاتنًا</p><p>وهذا كثير".</div></p><p><div></p><p><p><span class="item-no">٤١٣٦٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، أن نافع بن الأزرق قال له: أخبِرني عن قوله: <span class="qpc-hafs">﴿وله الدّين واصِبًا﴾</span>، ما الواصِب؟ قال: الدائم، قال فيه أُمَيَّة بن أبي الصَّلت:</p><p>وله الدّين واصبًا وله الملـ ـك وحَمْدٌ له على كلّ حال{7}. (٩/٦١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٣٦٩<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن جريج- في قوله: <span class="qpc-hafs">﴿واصِبًا﴾</span>: دائمًا{8}. (٩/٦٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٣٧٠<span class="dash">-</span></span> عن <span class="name-2">الضحاك بن مزاحم</span> -من طريق جويبر- <span class="qpc-hafs">﴿وله الدين واصبا﴾</span>، قال: دائمًا{9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٣٧١<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span> -من طريق أبي حصين- في قوله: <span class="qpc-hafs">﴿وله الدين واصبا﴾</span>، قال: دائمًا{10}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٣٧٢<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span>، في الآية، قال: إنّ هذا الدينَ دينٌ واصبٌ، شَغَل الناس، وحال بينهم وبين كثير من شهواتهم، فما يستطيعه إلا مَن عرَف فضله، ورجا عاقبته{11}. (٩/٦١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٣٧٣<span class="dash">-</span></span> عن <span class="name-2">ميمون بن مهران</span> -من طريق جعفر بن برقان- قال: دائمًا{12}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٣٧٤<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿وله الدين واصبا﴾</span>، أي: دائمًا؛ فإنّ الله تبارك وتعالى لم يدع شيئًا مِن خلقه إلا عبده، طائعًا أو كارهًا{13}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٣٧٥<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- <span class="qpc-hafs">﴿واصبا﴾</span>، قال: دائمًا، ألا ترى أنه يقول: <span class="qpc-hafs">﴿عذاب واصب﴾</span> [الصافات:٩]، أي: دائم{14}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٣٧٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>، في قوله: <span class="qpc-hafs">﴿واصِبًا﴾</span>: دائمًا{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٣٧٧<span class="dash">-</span></span> عن <span class="name-3">سفيان الثوري</span>، في قوله: <span class="qpc-hafs">﴿وله الدين واصبا﴾</span>، قال: دائمًا{16}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٣٧٨<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿وله الدين واصبا﴾</span>، قال: دائمًا، والواصِب: الدائم{17}<span class=comment-ref>٣٦٧٨</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٣٦٧٨</span> في معنى الواصب قولان: <b>الأول</b>: أنه الواجب. <b>الثاني</b>: أنه الدائم.</p><p>وقد ذكر <u>ابنُ جرير</u> (١٤/٢٤٦) القولين، و<span class="comment-type-4">جمع</span> بينهما <span class="mustanad">مستندًا إلى اللغة، والنظائر،</span> فقال: "وقوله: <span class="qpc-hafs">﴿وله الدين واصبا﴾</span> يقول -جل ثناؤه-: وله الطاعة والإخلاص دائمًا ثابتًا واجبًا. يُقال منه: وصب الدين يصب وصوبًا ووصبًا، كما قال الديلي:</p><p>لا أبتغي الحمد القليل بقاؤه ... يومًا بذم الدهر أجمع واصبًا</p><p>ومنه قول الله: <span class="qpc-hafs">﴿ولهم عذاب واصب﴾</span> [الصافات:٩]".</div></p><p><h3><span class="qpc-hafs">﴿أَفَغَیۡرَ ٱللَّهِ تَتَّقُونَ ۝٥٢﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤١٣٧٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿أفَغَيْرَ اللَّهِ﴾</span> من الآلهة <span class="qpc-hafs">﴿تَتَّقُونَ﴾</span> يعني: تعبدون، يعني: كفار مكة{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٣٨٠<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿أفغير الله تتقون﴾</span>، يعني: تعبدون، يعني: المشركين، على الاستفهام، أي: قد فعلتم فعبدتم الأوثان من دونه{19}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٢/٤٧٢.|2:أخرجه ابن جرير ١٤/٢٤٩، وأيضًا من طريق ابن أبي نجيح. وعزاه السيوطي إلى ابن أبي شيبة، وابن المنذر، وابن أبي حاتم.|3:عزاه السيوطي إلى ابن أبي حاتم.|4:تفسير مقاتل بن سليمان ٢/٤٧٢.|5:أخرجه ابن جرير ١٤/٢٤٧. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.|6:أخرجه ابن جرير ١٤/٢٤٩. وعزاه السيوطي إلى الفريابي.|7:عزاه السيوطي إلى ابن الأنباريّ في الوقف والابتداء.|8:أخرجه ابن جرير ١٤/٢٤٨، ومن طريق ابن أبي نجيح أيضًا. وعلقه يحيى بن سلام ١/٦٨. وعزاه السيوطي إلى ابن أبي شيبة، وابن المنذر، وابن أبي حاتم.|9:أخرجه ابن جرير ١٤/٢٤٨.|10:أخرجه ابن جرير ١٤/٢٤٧.|11:عزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.|12:أخرجه يحيى بن سلام ١/٦٨.|13:أخرجه ابن جرير ١٤/٢٤٨، وأخرجه يحيى بن سلام ١/٦٨ مقتصرًا على قوله: دائمًا.|14:أخرجه عبد الرزاق في تفسيره ٢/٣٥٧، وابن جرير ١٤/٢٤٨.|15:تفسير مقاتل بن سليمان ٢/٤٧٢.|16:تفسير الثوري ص١٦٥.|17:أخرجه ابن جرير ١٤/٢٤٩.|18:تفسير مقاتل بن سليمان ٢/٤٧٢.|19:تفسير يحيى بن سلام ١/٦٨.
  16,53,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَمَا بِكُم مِّن نِّعۡمَةࣲ فَمِنَ ٱللَّهِۖ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤١٣٨١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثم ذكَّرهم النِّعَم، فقال سبحانه: <span class="qpc-hafs">﴿وما بِكُمْ مِن نِعْمَةٍ فَمِنَ اللَّهِ﴾</span>؛ ليوحدوا ربَّ هذه النعم. يعني بالنِّعَم: الخير، والعافية{1}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿ثُمَّ إِذَا مَسَّكُمُ ٱلضُّرُّ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤١٣٨٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- قال: الضر: السقم{2}<span class=comment-ref>٣٦٧٩</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٣٦٧٩</span> لم يذكر <u>ابنُ جرير</u> (١٤/٢٥٢) غير قول ابن عباس.</div></p><p><div></p><p><p><span class="item-no">٤١٣٨٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ثُمَّ إذا مَسَّكُمُ الضُّرُّ﴾</span>، يعني: الشدة، وهو الجوع، والبلاء، وهو قحط المطر بمكة سبع سنين{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٣٨٤<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: قوله: <span class="qpc-hafs">﴿ثم إذا مسكم الضر﴾</span> المرض، وذهاب الأموال، والشدائد{4}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿فَإِلَیۡهِ تَجۡـَٔرُونَ ۝٥٣﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤١٣٨٥<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿فإليه تجأرون﴾</span>، قال: تتضرَّعون دعاء{5}. (٩/٦١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٣٨٦<span class="dash">-</span></span> قال <span class="name-2">مجاهد بن جبر</span>: <span class="qpc-hafs">﴿تجأرون﴾</span>: تصرخون{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٣٨٧<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span>، في قوله: <span class="qpc-hafs">﴿فإليه تجأرون﴾</span>، يقول: تَضِجُّون بالدعاء{7}. (٩/٦١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٣٨٨<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فَإلَيْهِ تَجْئَرُونَ﴾</span>، يعني: تَضَرَّعون بالدعاء؛ لا تدعون غيره أن يكشف عنكم ما نزل بكم من البلاء والدعاء حين قالوا في حم الدخان [١٢]: <span class="qpc-hafs">﴿رَبَّنا اكْشِفْ عَنّا العَذابَ إنّا مُؤْمِنُونَ﴾</span>، يعني: مُصَدِّقين بالتوحيد{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٣٨٩<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: قوله: <span class="qpc-hafs">﴿فإليه تجأرون﴾</span>: تدعونه، ولا تدعون الأوثان{4}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٢/٤٧٢.|2:أخرجه ابن جرير ١٤/٢٥٢.|3:تفسير مقاتل بن سليمان ٢/٤٧٣.|4:تفسير يحيى بن سلام ١/٦٨.|5:أخرجه ابن جرير ١٤/٢٥١-٢٥٢. وعزاه السيوطي إلى ابن أبي شيبة، وابن المنذر، وابن أبي حاتم.|6:علَّقه يحيى بن سلام ١/٦٨.|7:عزاه السيوطي إلى ابن أبي حاتم.|8:تفسير مقاتل بن سليمان ٢/٤٧٣.|9:تفسير يحيى بن سلام ١/٦٨.
  16,54,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿ثُمَّ إِذَا كَشَفَ ٱلضُّرَّ عَنكُمۡ إِذَا فَرِیقࣱ مِّنكُم بِرَبِّهِمۡ یُشۡرِكُونَ ۝٥٤﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤١٣٩٠<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span>، في قوله: <span class="qpc-hafs">﴿ثم إذا كشف الضُّر﴾</span> الآية، قال: الخلقُ كلُّهم مُقِرُّون لله أنه ربُّهم، ثم يُشْرِكون بعد ذلك{1}. (٩/٦٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٣٩١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ثُمَّ إذا كَشَفَ الضُّرَّ عَنْكُمْ﴾</span> يعني: الشدة، وهو الجوع، وأرسل السماء بالمطر مدرارًا <span class="qpc-hafs">﴿إذا فَرِيقٌ مِنكُمْ بِرَبِّهِمْ يُشْرِكُونَ﴾</span> يعني: يتركون التوحيد لله تعالى في الرخاء؛ فيعبدون غيره، وقد وحَّدُوه في الضر{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤١٣٩٢<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿إذا فريق منكم بربهم يشركون﴾</span>، يعني بالفريق: المشركين{3}. (ز)</p></p><p></div></p></div>",footnotes:1:عزاه السيوطي إلى ابن أبي حاتم.|2:تفسير مقاتل بن سليمان ٢/٤٧٣.|3:تفسير يحيى بن سلام ١/٦٨.