quran[12]{c,v,t}:
16,43," <q>﴿وَمَاۤ أَرۡسَلۡنَا مِن قَبۡلِكَ إِلَّا رِجَالࣰا نُّوحِیۤ إِلَیۡهِمۡۖ فَسۡـَٔلُوۤا۟ أَهۡلَ ٱلذِّكۡرِ إِن كُنتُمۡ لَا تَعۡلَمُونَ ۝٤٣﴾</q> - نزول الآية، وتفسيرها ٤١٢٣٩- عن عبد الله بن عباس -من طريق أبي روق، عن الضحاك- قال: لما بعث الله محمدًا ﷺ رسولًا أنكرت العرب ذلك، أو من أنكر منهم، فقالوا: الله أعظم من أن يكون رسوله بشرًا مثل محمد. فأنزل الله: <q>﴿أكان للناس عجبًا أن أوحينا إلى رجل منهم﴾</q> [يونس:٢]، وقال: ‹ومَآ أرْسَلْنا مِن قَبْلِكَ إلّا رِجالًا يُوحى{1} إلَيْهِمْ فاسْأَلُوا أهْلَ الذِّكْرِ إن كُنتُمْ لا تَعْلَمُونَ›. يعني: فاسألوا أهل الذكر؛ يعني: أهل الكتب الماضية: أبشرًا كانت الرسل الذين أتتكم أم ملائكة؟ فإن كانوا ملائكة أتتكم، وإن كانوا بشرًا فلا تُنكروا أن يكون رسولًا. ثم قال: ‹ومَآ أرْسَلْنا مِن قَبْلِكَ إلّا رِجالًا يُوحى إلَيْهِم مِّنْ أهْلِ القُرى› [يوسف:١٠٩]، أي: ليسوا من أهل السماء كما قلتُم{2}. (٩/٥٠) ٤١٢٤٠- عن سعيد بن جبير، في قوله: <q>﴿فسئلوا أهل الذّكر﴾</q>، قال: نزلت في عبد الله بن سلام، ونفر من أهل التوراة، كانوا أهل الكتب، يقول: فاسألوهم <q>﴿إن كنتم لا تعلمون﴾</q>{3}. (٩/٥١) ٤١٢٤١- عن إسماعيل السُّدِّيّ، في قوله: <q>﴿وما أرسلنا من قبلك إلا رجالًا﴾</q>، قال: قالت العرب: لولا أُنزل علينا الملائكة؟ قال الله: ما أرسَلتُ الرسلَ إلا بشرًا{3}. (٩/٥١) ٤١٢٤٢- قال مقاتل بن سليمان: <q>﴿وما أرسلنا من قبلك إلا رجالا نوحي إليهم﴾</q>، نزلت في أبي جهل بن هشام، والوليد بن المغيرة، وعقبة بن أبي معيط، وذلك أنهم قالوا في «سبحان»: <q>﴿أبعث الله بشرا رسولا﴾</q> [الإسراء:٩٤]، يأكل، ويشرب، وتَرَك الملائكة؟! فأنزل الله ﷿: <q>﴿وما أرسلنا من قبلك﴾</q> يا محمد ﷺ <q>﴿إلا رجالا نوحي إليهم﴾</q>{5}. (ز) ٤١٢٤٣- قال يحيى بن سلّام، في قوله: <q>﴿وما أرسلنا من قبلك إلا رجالا نوحي إليهم فاسألوا أهل الذكر إن كنتم لا تعلمون﴾</q>: يقول للمشركين{6}. (ز) <q>﴿فَسۡـَٔلُوۤا۟ أَهۡلَ ٱلذِّكۡرِ﴾</q> - تفسير ٤١٢٤٤- عن جابر بن عبد الله، قال: قال رسول الله ﷺ: «لا ينبغي للعالم أن يَسْكت عن علمه، ولا ينبغي للجاهل أن يَسْكُت على جهله، وقد قال الله: <q>﴿فسئلوا أهل الذكر إن كنتم لا تعلمون﴾</q>»{7}. (٩/٥٢) ٤١٢٤٥- عن أنس بن مالك، قال: سمعت رسول الله ﷺ يقول: «إن الرجل لَيُصلِّي ويصوم ويحجُّ ويعتمر ويغزو، وإنه لمنافق». قيل: يا رسول الله، بماذا دخل عليه النفاق؟ قال: «يطعن على إمامِه، وإمامُه مَن قال الله في كتابه: <q>﴿فسئلوا أهل الذكر إن كنتم لا تعلمون﴾</q>»{8}. (٩/٥٢) ٤١٢٤٦- عن محمد بن المنكدر، قال: قال رسول الله ﷺ: «لا ينبغي لعالم أن يسكت على علمه، ولا لجاهل أن يسكت على جهله، وقد قال الله: <q>﴿فسئلوا أهل الذّكر إن كنتم لا تعلمون﴾</q>. فينبغي للمؤمن أن يعرف علمه؛ على هدًى أم على ضلالة»{9}. (٩/٥٢) ٤١٢٤٧- عن عبد الله بن عباس -من طريق أبي روق، عن الضحاك- قال: يعني: <q>﴿فاسألوا أهل الذكر﴾</q>، يعني: أهل الكتب الماضية: أبشرًا كانت الرسل الذين أتتكم، أم ملائكة؟ فإن كانوا ملائكة أتتكم{10}، وإن كانوا بشرًا فلا تُنكروا أن يكون رسولًا{11}. (٩/٥٠) ٤١٢٤٨- عن عبد الله بن عباس -من طريق أبي يحيى، عن مجاهد-: <q>﴿فسئلوا أهل الذّكر﴾</q>، قال لمشركي قريش: إن محمدًا في التوراة والإنجيل{12}. (٩/٥١) ٤١٢٤٩- عن مجاهد بن جبر -من طريق ليث- <q>﴿فاسألوا أهل الذكر﴾</q>، قال: أهل التوراة{13}. (ز) ٤١٢٥٠- عن مجاهد بن جبر -من طريق ابن جريج- قوله: <q>﴿وما أرسلنا من قبلك إلا رجالا نوحي إليهم فاسألوا أهل الذكر إن كنتم لا تعلمون﴾</q>، قال: هم أهل الكتاب{13}. (ز) ٤١٢٥١- قال الحسن البصري: يعني: أهل الكتابين{15}. (ز) ٤١٢٥٢- قال قتادة بن دعامة: يعني: أهل التوراة، هي مثل قوله: <q>﴿فاسألوا أهل الذكر إن كنتم لا تعلمون﴾</q> [الأنبياء:٧]{15}. (ز) ٤١٢٥٣- عن إسماعيل السُّدِّيّ، في قوله: <q>﴿فسئلوا﴾</q> يا معشر العرب <q>﴿أهل الذّكر﴾</q> وهم أهل الكتاب من اليهود والنصارى، الذين جاءتهم الرسل قبلكم{3}. (٩/٥١) ٤١٢٥٤- قال إسماعيل السُّدِّيّ: <q>﴿فاسألوا أهل الذكر﴾</q>، يعني: التوراة، عبد الله بن سلام وأصحابه الذين أسلموا{15}. (ز) ٤١٢٥٥- عن أبي جعفر [محمد الباقر] -من طريق جابر- <q>﴿فاسألوا أهل الذكر إن كنتم لا تعلمون﴾</q>، قال: نحن أهل الذكر{19}. (ز) ٤١٢٥٦- عن سفيان، قال: سألت [سليمان بن مهران] الأعمش عن قوله: <q>﴿فاسألوا أهل الذكر﴾</q>. قال: سمعنا أنّه مَن أسلم مِن أهل التوراة والإنجيل{13}. (ز) ٤١٢٥٧- قال مقاتل بن سليمان: ثم قال: <q>﴿فسألوا أهل الذكر﴾</q>، يعني: التوراة{5}. (ز) ٤١٢٥٨- عن معمر بن راشد -من طريق عبد الرزاق- في قوله: <q>﴿فاسألوا أهل الذكر إن كنتم لا تعلمون﴾</q>، قال: أهل التوراة، فاسألوهم: هل جاءهم إلا رجال يوحى إليهم{22}. (ز) ٤١٢٥٩- عن خارجة بن مصعب -من طريق عبد الله بن عثمان- في قوله ﷿: <q>﴿فسألوا أهل الذكر﴾</q>، قال: أهل العلم{23}. (ز) ٤١٢٦٠- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿فاسألوا أهل الذكر إن كنتم لا تعلمون﴾</q>، قال: الذكر: القرآن. وقرأ: <q>﴿إنا نحن نزلنا الذكر وإنا له لحافظون﴾</q> [الحجر:٩]، وقرأ: <q>﴿إن الذين كفروا بالذكر لما جاءهم﴾</q> [فصلت:٤١] الآية{19}٣٦٦٩. (ز) ٣٦٦٩ الآية ردٌّ على كفار قريش في استبعادهم أن يبعث الله من البشر رسولًا، وقد اختُلِفَ في المعني بـ«أهل الذكر» في هذه الآية على أقوال: الأول: أهل الكتاب من اليهود والنصارى. الثاني: مَن أسلم مِن أهل الكتاب. الثالث: أهل القرآن. وزاد ابن عطية (٥/٣٥٨ ط: دار الكتب العلمية) قولًا نقله عن الزجاج أن أهل الذكر: عام في كل من يُعزى إلى علم. واستظهر ابن عطية مستندًا إلى الدلالة العقلية القول الأول، وهو قول ابن عباس، فقال: «والأظهر في هذا كله قول ابن عباس ﵄ أن يكون أهل الذكر هنا: أحبار اليهود والنصارى الذين لم يُسلِموا، وهم في هذه النازلة خاصة إنما يُخبِرون بأن الرسل من البشر، وإخبارهم حجَّة على هؤلاء، فإنهم لم يزالوا مصدِّقين لهم، ولا يتهمون بشهادة لنا لأنهم مدافعون في صدر ملة محمد ﷺ -قاتلهم الله-، وهذا هو كسر حجتهم من مذهبهم، لا أنّا افتقرنا إلى شهادة هؤلاء، بل الحق واضح في نفسه، وقد أرسلت قريش إلى يهود يثرب يسألون ويُسنِدون إليهم». وانتقد القول الثاني والثالث مستندًا إلى الدلالة العقلية قائلًا: «وهذان القولان فيهما ضعف؛ لأنه لا حجَّة على الكفار في إخبار المؤمنين بما ذُكِر، لأنهم يكذبون هذه الصنائف». واستدرك ابنُ كثير (٨/٣١٤) على القول الثالث -وهو قول ابن زيد، وأبي جعفر- مستندًا إلى الدلالة العقلية قائلًا: «وقول عبد الرحمن بن زيد: الذكر: القرآن. واستشهد بقوله: <q>﴿إنّا نَحْنُ نزلْنا الذِّكْرَ وإنّا لَهُ لَحافِظُونَ﴾</q> [الحجر:٩] صحيح، لكن ليس هو المراد هاهنا؛ لأن المخالف لا يرجع في إثباته بعد إنكاره إليه. وكذا قول أبي جعفر الباقر: نحن أهل الذكر». ووجَّه قول أبي جعفر الباقر: نحن أهل الذكر. بقوله: «ومراده أن هذه الأمة أهل الذكر صحيح؛ فإن هذه الأمة أعلم من جميع الأمم السالفة، وعلماء أهل بيت رسول الله ﵈ والرحمة من خير العلماء إذا كانوا على السنة المستقيمة، كعلي، وابن عباس، وابني علي: الحسن والحسين، ومحمد بن الحنفية، وعلي بن الحسين زين العابدين، وعلي بن عبد الله بن عباس، وأبي جعفر الباقر: وهو محمد بن علي بن الحسين، وجعفر ابنه، وأمثالهم وأضرابهم وأشكالهم، ممن هو متمسك بحبل الله المتين، وصراطه المستقيم، وعرف لكل ذي حقٍّ حقَّه، ونزَّل كلًّا المنزل الذي أعطاه الله ورسوله، واجتمع إليه قلوب عباده المؤمنين». <q>﴿إِن كُنتُمۡ لَا تَعۡلَمُونَ ۝٤٣﴾</q> - تفسير ٤١٢٦١- عن إسماعيل السُّدِّيّ، في قوله: <q>﴿إن كنتم لا تعلمون﴾</q>: أنّ الرسل الذين كانوا قبل محمد ﷺ كانوا بشرًا مثله، فإنهم سيخبرونكم أنهم كانوا بشرًا مثله{3}. (٩/٥١) ٤١٢٦٢- قال مقاتل بن سليمان: <q>﴿إن كنتم لا تعلمون﴾</q> بأن الرسل كانوا من البشر؛ فسيخبرونكم أن الله ﷿ لم يبعث رسولًا إلا من الإنس{5}. (ز) ",footnotes:1:قرأ حفص عن عاصم: <q>﴿نُوحِي﴾</q> بالنون وكسر الحاء، وقرأ الباقون: ‹يُوحى› بالياء وفتح الحاء هنا وفي يوسف. ينظر: النشر ٢/٢٢٢.أخرجه ابن جرير ١٤/٢٢٨، ٢٠/٥٨٣-٥٨٤، وابن أبي حاتم ٦/١٩٢٢، من طريق بشر بن عمارة، عن أبي روق، عن الضحاك، عن ابن عباس به. إسناده ضعيف جدًّا؛ فيه بشر بن عمارة، قال عنه ابن حجر في التقريب (٦٩٧): «ضعيف». والضحّاك يرسل كثيرًا، ولم يسمع من ابن عباس، كما في جامع التحصيل للعلائي ص١٩٩.عزاه السيوطي إلى ابن أبي حاتم.عزاه السيوطي إلى ابن أبي حاتم.تفسير مقاتل بن سليمان ٢/٤٧٠.تفسير يحيى بن سلام ١/٦٦.أخرجه الطبراني في الأوسط ٥/٢٩٨ (٥٣٦٥). وأورده الديلمي في الفردوس ٥/١٣٩ (٧٧٤٨). قال العراقي في تخريج أحاديث الإحياء ص١٦: «أخرجه الطبراني في الأوسط، وابن مردويه في التفسير ... من حديث جابر بسند ضعيف». وقال الهيثمي في المجمع ١/١٦٤-١٦٥ (٧٥١): «رواه الطبراني في الأوسط، وفيه محمد بن أبي حميد، وقد أجمعوا على ضعفه».عزاه السيوطي إلى ابن مَرْدُويَه.عزاه السيوطي إلى عبد بن حميد.عند ابن جرير ١٤/٢٢٨ بلفظ: أنكرتم.أخرجه ابن جرير ١٤/٢٢٨. وعزاه السيوطي إلى ابن أبي حاتم.أخرجه ابن جرير ١٤/٢٢٧-٢٢٨. وعزاه السيوطي إلى الفريابي، وعبد بن حميد، وابن المنذر، وابن أبي حاتم، وابن مَرْدُويَه بنحوه.أخرجه ابن جرير ١٤/٢٢٧.أخرجه ابن جرير ١٤/٢٢٧.علَّقه يحيى بن سلام ١/٦٦.علَّقه يحيى بن سلام ١/٦٦.عزاه السيوطي إلى ابن أبي حاتم.علَّقه يحيى بن سلام ١/٦٦.أخرجه ابن جرير ١٤/٢٢٨.أخرجه ابن جرير ١٤/٢٢٧.تفسير مقاتل بن سليمان ٢/٤٧٠.أخرجه عبد الرزاق ٦/١٢٥ (١٠٢٠٩).أخرجه أبو جعفر الرملي في جزئه ص١٢٥.أخرجه ابن جرير ١٤/٢٢٨.عزاه السيوطي إلى ابن أبي حاتم.تفسير مقاتل بن سليمان ٢/٤٧٠.
16,44," <q>﴿بِٱلۡبَیِّنَـٰتِ﴾</q> - تفسير ٤١٢٦٣- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿بالبيّنات﴾</q>، قال: الآيات{1}. (٩/٥٣) ٤١٢٦٤- عن إسماعيل السُّدِّيّ، عن أصحابه، في قوله: <q>﴿بالبيّنات والزّبر﴾</q>، قال: البيّنات: الحلال والحرام الذي كانت تجيء به الأنبياء{2}. (٩/٥٣) ٤١٢٦٥- قال إسماعيل السُّدِّيّ: <q>﴿بالبينات﴾</q>، يعني: بالآيات التي كانت تجيء بها الأنبياء إلى قومهم{3}. (ز) ٤١٢٦٦- قال مقاتل بن سليمان: يعني <q>﴿بالبينات﴾</q>: بالآيات{4}. (ز) ٤١٢٦٧- قال يحيى بن سلّام: وفيها تقديم: وما أرسلنا من قبلك بالبينات والزبر الكتب إلا رجالا يُوحى إليهم{5}. (ز) <q>﴿وَٱلزُّبُرِۗ﴾</q> - تفسير ٤١٢٦٨- عن عبد الله بن عباس -من طريق العوفي- <q>﴿والزبر﴾</q>، قال: الزبر: الكُتُب{6}. (ز) ٤١٢٦٩- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿والزّبر﴾</q>، قال: الكتب{1}. (٩/٥٣) ٤١٢٧٠- عن الضحاك بن مزاحم -من طريق عبيد بن سليمان- قال في قوله: <q>﴿والزبر﴾</q>، يعني: بالكُتُب{6}. (ز) ٤١٢٧١- عن إسماعيل السُّدِّيّ، عن أصحابه، في قوله: <q>﴿والزّبر﴾</q>: كتب الأنبياء{2}. (٩/٥٣) ٤١٢٧٢- قال مقاتل بن سليمان: <q>﴿والزبر﴾</q>، يعني: حديث الكتب{4}. (ز) ٤١٢٧٣- قال يحيى بن سلّام: <q>﴿والزبر﴾</q>، يعني: وحديث الكتاب، وما كان قبلهم من المواعظ{5}. (ز) <q>﴿وَأَنزَلۡنَاۤ إِلَیۡكَ ٱلذِّكۡرَ﴾</q> - تفسير ٤١٢٧٤- عن إسماعيل السدي، عن أصحابه، في قوله: <q>﴿وأنزلنا إليك الذّكر﴾</q>، قال: هو القرآن{2}. (٩/٥٣) ٤١٢٧٥- قال مقاتل بن سليمان: <q>﴿وأنزلنا إليك الذكر﴾</q>، يعني: القرآن{4}. (ز) ٤١٢٧٦- قال يحيى بن سلّام: <q>﴿وأنزلنا إليك الذكر﴾</q> القرآن{5}. (ز) <q>﴿لِتُبَیِّنَ لِلنَّاسِ مَا نُزِّلَ إِلَیۡهِمۡ﴾</q> - تفسير ٤١٢٧٧- عن مجاهد بن جبر، في قوله: <q>﴿لِتُبيّن للنّاس ما نُزّل إليهم﴾</q>، قال: ما أُحِلَّ لهم، وما حُرِّم عليهم{2}٣٦٧٠. (٩/٥٣) ٣٦٧٠ ذكر ابنُ عطية (٥/٣٥٩) احتمالين في معنى: <q>﴿لِتُبَيِّنَ﴾</q>، فقال: «يحتمل أن يريد: لتُبَيِّن بِسَرْدِك نص القرآن ما نزل. ويحتمل أن يريد: لتُبَيِّن بتفسيرك المجمل، وبشرحك ما أشكل مما نُزِّل». ثم علَّق بقوله: «فيدخل في هذا ما تُبَيِّنُه السنة من أمر الشريعة. وهذا قول مجاهد». ٤١٢٧٨- عن قتادة بن دعامة، في قوله: <q>﴿لتبيّن للنّاس ما نُزّل إليهم﴾</q>، قال: أرسله الله إليهم ليَتَّخِذَ بذلك الحجّة عليهم{2}. (٩/٥٣) ٤١٢٧٩- قال مقاتل بن سليمان: <q>﴿لتبين للناس ما نزل إليهم﴾</q> من ربهم{4}. (ز) <q>﴿لِتُبَیِّنَ لِلنَّاسِ مَا نُزِّلَ إِلَیۡهِمۡ﴾</q> - آثار متعلقة بالآية ٤١٢٨٠- عن حذيفة بن اليمان، قال: قام فينا رسول الله ﷺ مقامًا، ما ترك شيئًا يكون في مقامه ذلك إلى قيام الساعة إلا حدَّث به، حَفِظه مَن حَفِظه، ونسيه مَن نسيه، قد علمه أصحابي هؤلاء، وإنه ليكون منه الشيء قد نسيتُه فأراه فأذكره كما يذكر الرجلُ وجهَ الرجل إذا غاب عنه، ثم إذا رآه عرفه{18}. (٩/٥٣) <q>﴿وَلَعَلَّهُمۡ یَتَفَكَّرُونَ ۝٤٤﴾</q> - تفسير ٤١٢٨١- عن مجاهد بن جبر -من طريق الثوري- في قوله: <q>﴿ولعلهم يتفكّرون﴾</q>، قال: يُطيعون{19}. (٩/٥٣) ٤١٢٨٢- قال مقاتل بن سليمان: <q>﴿ولعلهم﴾</q> يعني: لكي <q>﴿يتفكرون﴾</q> فيؤمنوا{4}. (ز) ",footnotes:1:أخرجه ابن جرير ١٤/٢٣١. وعزاه السيوطي إلى ابن أبي شيبة، وابن المنذر، وابن أبي حاتم.عزاه السيوطي إلى ابن أبي حاتم.علَّقه يحيى بن سلام ١/٦٦.تفسير مقاتل بن سليمان ٢/٤٧٠.تفسير يحيى بن سلام ١/٦٦.أخرجه ابن جرير ١٤/٢٣١.أخرجه ابن جرير ١٤/٢٣١. وعزاه السيوطي إلى ابن أبي شيبة، وابن المنذر، وابن أبي حاتم.أخرجه ابن جرير ١٤/٢٣١.عزاه السيوطي إلى ابن أبي حاتم.تفسير مقاتل بن سليمان ٢/٤٧٠.تفسير يحيى بن سلام ١/٦٦.عزاه السيوطي إلى ابن أبي حاتم.تفسير مقاتل بن سليمان ٢/٤٧٠.تفسير يحيى بن سلام ١/٦٦.عزاه السيوطي إلى ابن أبي حاتم.عزاه السيوطي إلى ابن أبي حاتم.تفسير مقاتل بن سليمان ٢/٤٧٠.أخرجه البخاري ٨/١٢٣ (٦٦٠٤)، ومسلم ٤/٢٢١٧ (٢٨٩١).أخرجه ابن جرير ١٤/٢٣٢.تفسير مقاتل بن سليمان ٢/٤٧٠.
16,45," <q>﴿أَفَأَمِنَ ٱلَّذِینَ مَكَرُوا۟ ٱلسَّیِّـَٔاتِ﴾</q> - تفسير ٤١٢٨٣- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿أفأمن الذين مكروا السيّئات﴾</q>، قال: هو نمرود بن كنعان وقومه{1}. (٩/٥٣) ٤١٢٨٤- عن الضحاك بن مزاحم، في قوله: <q>﴿أفأمن الذين مكروا السيّئات﴾</q>، قال: تكذيبُهم الرسل وأعمالهم بالمعاصي{2}. (٩/٥٤) ٤١٢٨٥- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿أفأمن الذين مكروا السيّئات﴾</q>، أي: الشّرك{3}٣٦٧١. (٩/٥٤) ٣٦٧١ رجَّح ابنُ جرير (١٤/٢٣٣) مستندًا إلى السياق أنّ المقصود بقوله تعالى: <q>﴿أفَأَمِنَ الَّذِينَ مَكَرُوا السَّيِّئاتِ﴾</q> هم مشركو مكة، ومكرهم السيئات: شركهم وتكذيبهم، وعلَّل ذلك بقوله: «لأن ذلك تهديدٌ من الله أهل الشرك به، وهو عقيب قوله: <q>﴿وما أرْسَلْنا مِن قَبْلِكَ إلا رِجالا نُوحِي إلَيْهِمْ فاسْأَلُوا أهْلَ الذِّكْرِ إنْ كُنْتُمْ لا تَعْلَمُونَ﴾</q>، فكان تهديدُ مَن لم يُقِرَّ بحجَّة الله الذي جرى الكلام بخطابه قبل ذلك أحْرى من الخبر عمَّن انقطع ذِكْرُه عنه». ثم ذكر أثر قتادة. واستظهر ذلك ابنُ عطية (٥/٣٥٩)، ولم يذكر مستندًا. ٤١٢٨٦- قال مقاتل بن سليمان: ثم خوف كفار مكة، فقال سبحانه: <q>﴿أفأمن الذين مكروا السيئات﴾</q>، يعني: الذين قالوا الشرك{4}. (ز) ٤١٢٨٧- قال يحيى بن سلّام: قوله: <q>﴿أفأمن الذين مكروا السيئات﴾</q> عملوا السيئات. والسيئات هاهنا: الشرك{5}. (ز) <q>﴿أَن یَخۡسِفَ ٱللَّهُ بِهِمُ ٱلۡأَرۡضَ أَوۡ یَأۡتِیَهُمُ ٱلۡعَذَابُ مِنۡ حَیۡثُ لَا یَشۡعُرُونَ ۝٤٥﴾</q> - تفسير ٤١٢٨٨- قال مقاتل بن سليمان: <q>﴿أن يخسف الله بهم الأرض﴾</q> يعني: جانبًا منها، <q>﴿أو يأتيهم﴾</q> غير الخسف <q>﴿العذاب من حيث لا يشعرون﴾</q> يعني: لا يعلمون أنه يأتيهم منه{4}. (ز) ",footnotes:1:أخرجه ابن جرير ١٤/٢٣٣. وعزاه السيوطي إلى ابن أبي شيبة، وابن المنذر.عزاه السيوطي إلى ابن أبي حاتم.أخرجه يحيى بن سلام ١/٦٦، وابن جرير ١٤/٢٣٣. وعزاه السيوطي إلى ابن أبي حاتم.تفسير مقاتل بن سليمان ٢/٤٧١.تفسير يحيى بن سلام ١/٦٦.تفسير مقاتل بن سليمان ٢/٤٧١.
16,46," <q>﴿أَوۡ یَأۡخُذَهُمۡ فِی تَقَلُّبِهِمۡ﴾</q> - تفسير ٤١٢٨٩- عن عبد الله بن عباس -من طريق علي- في قوله: <q>﴿أو يأخُذَهُم في تقلّبهم﴾</q>، قال: في اختلافهم{1}. (٩/٥٤) ٤١٢٩٠- عن عبد الله بن عباس -من طريق العوفي- في قوله: <q>﴿أو يأخذهم في تقلّبهم﴾</q>، قال: إن شئت أخذتُه في سَفَره{2}. (٩/٥٤) ٤١٢٩١- عن الضحاك بن مزاحم، في قوله: <q>﴿أو يأخذهم في تقلّبهم﴾</q>، يعني: على أيّ حالٍ كانوا بالليل والنهار{3}. (٩/٥٤) ٤١٢٩٢- تفسير الحسن البصري، قال: <q>﴿أو يأخذهم في تقلبهم﴾</q> في البلاد في أسفارهم في غير قرار{4}. (ز) ٤١٢٩٣- عن قتادة بن دعامة -من طريق معمر- في قوله: <q>﴿أو يأخذهم في تقلّبهم﴾</q>، قال: في أسفارهم{5}. (٩/٥٤) ٤١٢٩٤- تفسير محمد بن السائب الكلبي: <q>﴿أو يأخذهم في تقلبهم﴾</q> في البلاد بالليل والنهار{6}. (ز) ٤١٢٩٥- قال مقاتل بن سليمان في قوله تعالى: <q>﴿أو يأخذهم﴾</q> العذاب <q>﴿في تقلبهم﴾</q> في الليل والنهار{7}. (ز) ٤١٢٩٦- عن عبد الملك ابن جريج -من طريق حجاج- <q>﴿أو يأخذهم في تقلبهم﴾</q>، قال: التقلب: أن يأخذهم بالليل والنهار{8}٣٦٧٢. (ز) ٣٦٧٢ علَّق ابنُ كثير (٨/٣١٦) على قول الضحاك، وقول محمد بن السائب، ومقاتل، وابن جريج، من طريق حجاج أن قوله تعالى: <q>﴿فِي تَقَلُّبِهِمْ﴾</q> معناه: بالليل والنهار، بقوله: «كقوله تعالى: <q>﴿أفَأَمِنَ أهْلُ القُرى أنْ يَأْتِيَهُمْ بَأْسُنا بَياتًا وهُمْ نائِمُونَ * أوَأَمِنَ أهْلُ القُرى أنْ يَأْتِيَهُمْ بَأْسُنا ضُحًى وهُمْ يَلْعَبُونَ﴾</q> [الأعراف:٩٧-٩٨]». ٤١٢٩٧- عن عبد الملك ابن جريج، في قوله: <q>﴿أو يأخذهم في تقلبهم﴾</q>، قال: في إقبالهم وإدبارهم{9}. (ز) <q>﴿فَمَا هُم بِمُعۡجِزِینَ ۝٤٦﴾</q> - تفسير ٤١٢٩٨- قال مقاتل بن سليمان: <q>﴿فما هم بمعجزين﴾</q>، يعني: سابقي الله ﷿ بأعمالهم الخبيثة حتى يجزيهم بها{7}. (ز) ٤١٢٩٩- قال يحيى بن سلّام: <q>﴿فما هم بمعجزين﴾</q> بسابقين{11}. (ز) ",footnotes:1:أخرجه ابن جرير ١٤/٢٣٤. وعزاه السيوطي إلى ابن أبي حاتم.أخرجه ابن جرير ١٤/٢٣٤، ٢٣٧. وعزاه السيوطي إلى ابن أبي حاتم.عزاه السيوطي إلى ابن جرير، وابن أبي حاتم.علَّقه يحيى بن سلام ١/٦٦.أخرجه عبد الرزاق ١/٣٥٦، وابن جرير ١٤/٢٣٤ ومن طريق سعيد أيضًا. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.علَّقه يحيى بن سلام ١/٦٧.تفسير مقاتل بن سليمان ٢/٤٧١.أخرجه ابن جرير ١٤/٢٣٤.تفسير البغوي ٥/٢١.تفسير مقاتل بن سليمان ٢/٤٧١.تفسير يحيى بن سلام ١/٦٦.
16,47," <q>﴿أَوۡ یَأۡخُذَهُمۡ عَلَىٰ تَخَوُّفࣲ﴾</q> - تفسير ٤١٣٠٠- عن عمر بن الخطاب -من طريق إبراهيم بن عامر بن مسعود، عن رجل- أنّه سألهم عن هذه الآية: <q>﴿أو يأخذهم على تخوّف﴾</q>. فقالوا: ما نرى إلا أنه عند تنقُّص ما نُرَدِّدُه من الآيات. فقال عمر: ما أرى إلا أنه على ما تَنتَقِصون من معاصي الله. قال: فخرج رجل ممن كان عند عمر، فلقي أعرابيًّا فقال: يا فلان، ما فعل ربُّك؟ قال: قد تَخَيَّفتُه. يعني: تَنقَّصتُه. قال: فرجَع إلى عمر، فأخبره، فقال: قدَّر الله ذلك{1}. (٩/٥٥) ٤١٣٠١- عن عبد الله بن عباس -من طريق العوفي- وفي قوله: <q>﴿أو يأخذهم على تخوّف﴾</q>، يقول: إن شئتُ أخذتُه على إثر موت صاحبه، نُخَوِّفُ بذلك{2}. (٩/٥٤) ٤١٣٠٢- عن عبد الله بن عباس -من طريق الضحاك- في قوله: <q>﴿أو يأخذهم على تخوّف﴾</q>، قال: تنقُّص من أعمالهم{3}. (٩/٥٥) ٤١٣٠٣- عن عبد الله بن عباس -من طريق عطاء الخراساني- في قوله: <q>﴿أو يأخذهم على تخوّف﴾</q>، قال: التنقُّص والتقريع{4}. (٩/٥٥) ٤١٣٠٤- عن سعيد بن المسيب -من طريق يحيى بن سعيد- في قول الله: <q>﴿أو يأخذهم على تخوف﴾</q> أنّه على عجل{5}. (ز) ٤١٣٠٥- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿أو يأخذهم على تخوّف﴾</q>، قال: يأخُذهم بنقْصِ بعضهم بعضًا{6}. (٩/٥٥) ٤١٣٠٦- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿أو يأخذهم على تخوّف﴾</q>، قال: يأخذهم بنقص النِّعَم، نقص من عاهدهم من هذا، وهو نمروذ بن كنعان وقومه{7}. (ز) ٤١٣٠٧- تفسير مجاهد بن جبر -من طريق ابن مجاهد- من قوله: <q>﴿مكروا السيئات﴾</q> إلى قوله: <q>﴿على تخوف﴾</q>: بعض ما أوعدهم من هذا، وهو نمرود بن كنعان وقومه{8}. (ز) ٤١٣٠٨- عن الضحاك بن مزاحم -من طريق عبيد بن سليمان- في قوله: <q>﴿أو يأخذهم على تخوّف﴾</q>، يعني: أن يأخذ بعضًا بالعذاب ويترك بعضًا، وذلك أنه كان يعذِّب القرية فيُهلِكُها، ويترك الأخرى{9}٣٦٧٣. (٩/٥٤) ٣٦٧٣ ذكر ابنُ عطية (٥/٣٦١) أن «هذا التنقيص يتَّجه الوعيد به على معنيين: أحدهما: أن يهلكهم ويخرج أرواحهم على تخوف، أي: أفذاذًا، يتَنَقَّصَهم بذلك الشيء بعد الشيء». ثم علَّق عليه بقوله: «وهذا لا يدَّعي أحد أنه يأمنه، وكأن هذا الوعيد إنما يكون بعذاب ما يلقون بعد الموت، وإلا فهكذا تهلك الأمم كلها، ويؤيد هذا قوله: <q>﴿فَإنَّ رَبَّكُمْ لَرَؤُفٌ رَحِيمٌ﴾</q>، أي: أن هذه الرتبة من الوعيد فيها رأفة ورحمة وإمهال ليتوب التائب ويرجع الراجع». «والآخر: ما قال الضحاك: أن يأخذ بالعذاب طائفة أو قرية، ويترك أخرى، ثم كذلك حتى يهلك الكل». ٤١٣٠٩- عن قتادة بن دعامة -من طريق سعيد-: <q>﴿أو يأخذهم على تخوف﴾</q>، فيعاقب، أو يتجاوز{10}. (ز) ٤١٣١٠- عن قتادة بن دعامة -من طريق شيبان- في قول الله ﷿: <q>﴿أو يأخذهم على تخوف﴾</q>، قال: على تنقص{11}. (ز) ٤١٣١١- تفسير إسماعيل السُّدِّيّ: <q>﴿أو يأخذهم على تخوف﴾</q> على تنقص{12}. (ز) ٤١٣١٢- عن محمد بن السائب الكلبي -من طريق معمر- في قوله: <q>﴿على تخوف﴾</q>، قال: على تنقُّص. يقول: يُصابون في أطراف قراهم بالشيء، حتى يأتي ذلك عليهم{13}. (ز) ٤١٣١٣- قال محمد بن السائب الكلبي: مِن الخوف، أي: يعذب طائفة، فيتخوف الآخرون أن يصيبهم مثل ما أصابهم{14}٣٦٧٤. (ز) ٣٦٧٤ علق ابنُ عطية (٥/٣٦١) على قول محمد بن السائب الكلبي قائلًا: «وفي هذا تكلُّف ما». ٤١٣١٤- قال مقاتل بن سليمان: <q>﴿أو يأخذهم على تخوف﴾</q>، يقول: يأخذ أهل هذه القرية بالعذاب، ويترك الأخرى قريبًا منها؛ لكي يخافوا فيعتبروا، يخوفهم بمثل ذلك{15}. (ز) ٤١٣١٥- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿أو يأخذهم على تخوّف﴾</q>، قال: كان يقال: التَّخَوُّف: هو التَّنَقُّص؛ ينتَقِصْهم من البلدان والأطراف{9}. (٩/٥٦) ٤١٣١٦- قال يحيى بن سلّام: <q>﴿أو يأخذهم على تخوف﴾</q>، يهلك القرية يخوف بهلاكها القرية الأخرى لعلهم يرجعون، لعل من بقي ممن هو على دينهم –الشرك- أن يرجعوا إلى الإيمان{17}. (ز) <q>﴿فَإِنَّ رَبَّكُمۡ لَرَءُوفࣱ رَّحِیمٌ ۝٤٧﴾</q> - تفسير ٤١٣١٧- قال مقاتل بن سليمان: <q>﴿فإن ربكم لرؤف﴾</q> يعني: يرِقُّ لهم، <q>﴿رحيم﴾</q> بهم حين لا يعجل عليهم بالعقوبة{15}. (ز) ٤١٣١٨- قال يحيى بن سلّام: <q>﴿على تخوف﴾</q> على تنقص، أن يبتليهم بالجهد حتى يرقوا ويقل عددهم، فإن تابوا وأصلحوا كشف عنهم. فذلك قوله: <q>﴿فإن ربكم لرءوف رحيم﴾</q>، أي: إن تابوا وأصلحوا{17}. (ز) ",footnotes:1:أخرجه ابن جرير ١٤/٢٣٦.أخرجه ابن جرير ١٤/٢٣٧. وعزاه السيوطي إلى ابن أبي حاتم.أخرجه ابن أبي حاتم -كما في فتح الباري ٨/٣٨٦-.أخرجه ابن جرير ١٤/٢٣٧.أخرجه ابن وهب في الجامع ٢/١٥٤ (٣١٥).أخرجه ابن جرير ١٤/٢٣٧. وعزاه السيوطي إلى ابن أبي شيبة، وابن المنذر.تفسير مجاهد ص٤٢٢.أخرجه يحيى بن سلام ١/٦٧.أخرجه ابن جرير ١٤/٢٣٨. وعزاه السيوطي إلى ابن أبي حاتم.أخرجه ابن جرير ١٤/٢٣٨.أخرجه الزجاجي في الأمالي ص٣٧.علَّقه يحيى بن سلام ١/٦٧.أخرجه عبد الرزاق في تفسيره ٢/٣٥٦.تفسير الثعلبي ٦/١٩، وتفسير البغوي ٥/٢١.تفسير مقاتل بن سليمان ٢/٤٧١.أخرجه ابن جرير ١٤/٢٣٨. وعزاه السيوطي إلى ابن أبي حاتم.تفسير يحيى بن سلام ١/٦٧.تفسير مقاتل بن سليمان ٢/٤٧١.تفسير يحيى بن سلام ١/٦٧.
16,48," <q>﴿أَوَلَمۡ یَرَوۡا۟ إِلَىٰ مَا خَلَقَ ٱللَّهُ مِن شَیۡءࣲ یَتَفَیَّؤُا۟ ظِلَـٰلُهُۥ عَنِ ٱلۡیَمِینِ وَٱلشَّمَاۤىِٕلِ سُجَّدࣰا لِّلَّهِ﴾</q> - تفسير ٤١٣١٩- عن عمر بن الخطاب، قال: قال رسول الله ﷺ: «أربع قبل الظهر بعد الزَّوال، تُحسب بمثلهن من صلاة السّحر». قال رسول الله ﷺ: «وليس من شيء إلا وهو يُسبح الله تلك الساعة». ثم قرأ: <q>﴿يتفيّؤا ظلاله عن اليمين والشّمآئل سجّدًا لله﴾</q> الآية كلّها{1}. (٩/٥٧) ٤١٣٢٠- عن عبد الله بن عباس -من طريق علي- في قوله: <q>﴿يتفيّؤا ظلاله﴾</q>، قال: تتميَّل{2}. (٩/٥٦) ٤١٣٢١- قال عبد الله بن عباس: ‹تَتَفَيَّأُ ظِلالُهُ›: تتهيأ{3}. (ز) ٤١٣٢٢- عن عبد الله بن عباس -من طريق العوفي- قوله: <q>﴿أولم يروا إلى ما خلق الله من شيء يتفيأ ظلاله﴾</q>: ما خلق من شيء عن يمينه وشمائله -فلفظ <q>﴿ما﴾</q> لفظ عن اليمين والشمائل- قال: ألم تر أنك إذا صليت الفجر كان ما بين مطلع الشمس إلى مغربها ظلًّا؟ ثم بعث الله عليه الشمس دليلًا، وقبض الله الظل{4}. (ز) ٤١٣٢٣- عن مجاهد بن جبر -من طريق ابن جريج- في الآية، قال: فَيْءُ كلِّ شيء ظِلُّه، وسجود كلِّ شيء فيئُه؛ سجود الجبال فيئُها{5}. (٩/٥٧) ٤١٣٢٤- عن مجاهد بن جبر -من طريق منصور- في الآية، قال: إذا زالت الشمس سجد كلُّ شيء لله{6}. (٩/٥٧) ٤١٣٢٥- عن مجاهد بن جبر، في قوله: <q>﴿يتفيّؤا ظلاله عن اليمين والشّمآئل﴾</q>، قال: الغدوّ والآصال، إذا فاء ظلُّ كلِّ شيء، أما الظِّلُّ بالغداة فعن اليمين، وأما بالعَشِيِّ فعن الشمائل، إذا كان بالغداة سجدت لله، وإذا كان بالعَشِيّ سجدت له{7}. (٩/٥٧) ٤١٣٢٦- عن الضحاك بن مزاحم -من طريق ثابت- في قوله: <q>﴿أو لم يروا إلى ما خلق الله من شيء يتفيّؤا ظلاله﴾</q>، قال: إذا فاء الفيء توجَّه كلُّ شيء ساجدًا لله قِبَلَ القبلة من بيت أو شجر. قال: فكانوا يستحِبُّون الصلاة عند ذلك{8}. (٩/٥٦) ٤١٣٢٧- عن الضحاك بن مزاحم -من طريق ثابت- في الآية، قال: إذا فاء الفيء لم يبق شيءٌ مِن دابة ولا طائر إلا خَرَّ لله ساجدًا{9}. (٩/٥٦) ٤١٣٢٨- عن الضحاك بن مزاحم -من طريق عبيد بن سليمان- في قوله: <q>﴿يتفيؤ ظلاله عن اليمين والشمائل﴾</q>، قال: يعني بالغدو والآصال: تسجد الظلال لله غدوة إلى أن يفيء الظل، ثم تسجد لله إلى الليل، يعني: ظل كل شيء{10}. (ز) ٤١٣٢٩- عن الضحاك بن مزاحم، في قوله ﷿: <q>﴿عن اليمين والشمائل سجدا لله﴾</q>، قال: أما اليمين: فأول النهار، والشمال: آخر النهار، تسجد الظلال لله{11}. (ز) ٤١٣٣٠- قال الحسن البصري: ربما كان الفيء عن اليمين، وربما كان عن الشمال{12}. (ز) ٤١٣٣١- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿أولم يروا إلى ما خلق الله من شيء يتفيّؤا ظلاله عن اليمين والشّمآئل سجّدًا لله﴾</q>، قال: ظِلُّ كلِّ شيء: فَيْئُه، وظلُّ كلِّ شيء: سجوده، فاليمين أول النهار، والشمائل آخر النهار{13}. (٩/٥٦) ٤١٣٣٢- عن سعد بن إبراهيم -من طريق موسى بن عبيدة- قال: صلُّوا صلاة الآصال حين يفيء الفيء قبل النداء بالظهر، من صلّاها فكأنما تهجَّد بالليل{14}. (٩/٥٧) ٤١٣٣٣- قال محمد بن السائب الكلبي: وهذا يكون قبل طلوع الشمس وبعد غروبها، فعند ذلك يكون الظل عن اليمين والشمال، ولا يكون ذلك في ساعة إلا قبل طلوع الشمس وبعد غروبها{12}. (ز) ٤١٣٣٤- عن محمد بن السائب الكلبي، في قوله ﷿: <q>﴿عن اليمين والشمائل سجدا لله﴾</q>، قال: الظل قبل طلوع الشمس عن يمينك وعن شمالك وقدامك وخلفك، وكذلك إذا غابت، فإذا طلعت كان من قدامك، وإذا ارتفعت كان عن يمينك، ثم بعده كان خلفك، فإذا كان قبل أن تغرب الشمس كان عن يسارك، فهذا تفيُّؤه، وتقلبه، وهو سجوده{11}. (ز) ٤١٣٣٥- قال مقاتل بن سليمان: ثم وعظ كفار مكة؛ ليعتبروا في صنعه، فقال سبحانه: <q>﴿أولم يروا إلى ما خلق الله من شيء﴾</q> في الأرض <q>﴿يتفيؤا ظلاله عن اليمين والشمائل سجدا﴾</q> وذلك أنّ الشجر، والبنيان، والجبال، والدواب، وكل شيء، إذا طلعت عليه الشمس يتحول ظلُّ كل شيء عن اليمين قِبَل المغرب، فذلك قوله سبحانه: <q>﴿يتفيؤا ظلاله﴾</q> يعني: يتحول الظل، فإذا زالت الشمس تحول الظل عن الشمال قِبَل المشرق، كسجود كل شيء في الأرض لله تعالى ظله في النهار <q>﴿سجدا لله﴾</q>{17}. (ز) ٤١٣٣٦- عن عبد الملك ابن جريج -من طريق حجاج- <q>﴿يتفيؤ ظلاله عن اليمين والشمائل﴾</q>، قال: الغدو والآصال؛ إذا فاءت الظلال -ظلال كل شيء- بالغدو سجدت لله، وإذا فاءت بالعشي سجدت لله{10}٣٦٧٥. (ز) ٣٦٧٥ وجَّه ابنُ عطية (٥/٣٦٤) قول ابن عباس من طريق العوفي بقوله: «وعلى هذا فأول ذرور الشمس [طلوعها] فالظل عن يمين مستقبل الجنوب، ثم يبدأُ الانحراف فهو عن الشمائل؛ لأنها حركات كثيرة وظلال مقطعة، فهي شمائل كثيرة، وكان الظل عن اليمين متصلًا واحدًا عامًّا لكلِّ شيءٍ، وفي هذا القول تجوُّز في <q>﴿يَتَفَيَّأُ﴾</q>». ووجَّه قول قتادة، وابن جريج بقوله: «ومن ذهب إلى أن اليمين: من غدوة النهار إلى الزوال، ثم يكون من الزوال إلى المغيب عن الشمال -وهو قول قتادة، وابن جريج-، فإنما يترتب له ذلك فيما قدره مستقبل الجنوب، والاعتبار في هذه الآية عندي إنما هو مستقبل الجنوب». ثم ذكر قولًا عن بعض الناس، وانتقده، فقال: «وما قاله بعض الناس من: أن اليمين أول دفعة للظل بعد الزوال، ثم الآخر إلى الغروب هي عن الشمائل، ولذلك جمع الشَّمائل وأفرد اليمين. فتخليط من القول يبطل من جهات». ولم يذكرها. ٤١٣٣٧- قال يحيى بن سلّام: قوله: <q>﴿أولم يروا إلى ما خلق الله من شيء يتفيأ ظلاله﴾</q> يعني: ظل كل شيء من الفيء <q>﴿عن اليمين والشمائل﴾</q> والفيء: الظل <q>﴿سجدا لله﴾</q> فظل كل شيء: سجوده{19}٣٦٧٦. (ز) ٣٦٧٦ اختلف في معنى: <q>﴿سُجَّدًا لِلَّهِ﴾</q> في هذه الآية على أقوال: الأول: أن ظل كل شيء سجوده. الثاني: أن سجود الظلال سجود أشخاصها. الثالث: أن سجود الظلال كسجود الأشخاص تسجد لله خاضعة. ووجَّه ابنُ عطية (٥/٣٦٥) القول الأول بقوله: «هو سجود عبادة حقيقية». ووجَّه القول الثالث بقوله: «عبَّر عن الخضوع والطاعة وميلان الظلال ودورانها بالسجود». ورجَّح ابنُ جرير (١٤/٢٤٢) مستندًا إلى دلالة اللغة، وأقوال السلف القول الثالث، وهو قول ابن عباس من طريق العوفي، فقال: «وأولى الأقوال في ذلك بالصواب أن يقال: إن الله أخبر في هذه الآية أن ظلال الأشياء هي التي تسجد. وسجودها: مَيَلانُها ودَوَرانُها من جانبٍ إلى جانبٍ، وناحيةٍ إلى ناحيةٍ. كما قال ابن عباس. يقال من ذلك: سجَدَتِ النخلة إذا مالت، وسجَدَ البعير وأسْجَدَ: إذا مَيَّل للركوب». <q>﴿أَوَلَمۡ یَرَوۡا۟ إِلَىٰ مَا خَلَقَ ٱللَّهُ مِن شَیۡءࣲ یَتَفَیَّؤُا۟ ظِلَـٰلُهُۥ عَنِ ٱلۡیَمِینِ وَٱلشَّمَاۤىِٕلِ سُجَّدࣰا لِّلَّهِ﴾</q> - آثار متعلقة بالآية ٤١٣٣٨- عن أبي غالب الشّيباني، قال: أمواج البحر صلاته{20}. (٩/٥٨) <q>﴿وَهُمۡ دَ ٰ⁠خِرُونَ ۝٤٨﴾</q> - تفسير ٤١٣٣٩- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿وهم داخرون﴾</q>، قال: صاغرون{21}. (٩/٥٨) ٤١٣٤٠- عن الضحاك بن مزاحم -من طريق ثابت- <q>﴿يتفيؤ ظلاله﴾</q>، قال: سجد ظل المؤمن طوعًا، وظل الكافر كرهًا{6}. (ز) ٤١٣٤١- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿وهم داخرون﴾</q>، قال: صاغرون{23}. (٩/٥٨) ٤١٣٤٢- عن قتادة بن دعامة: فسجد ظل الكافر كرهًا، يسجد ظله والكافر كاره{24}. (ز) ٤١٣٤٣- قال مقاتل بن سليمان: يقول <q>﴿وهم داخرون﴾</q>، يعني: صاغرون{17}. (ز) ",footnotes:1:أخرجه الترمذي ٥/٣٥٦ (٣٣٩٤). وأورده الثعلبي ٦/٢٠. قال الترمذي: «هذا حديث غريب، لا نعرفه إلا من حديث علي بن عاصم». وأورده الألباني في الصحيحة ٣/٤١٦-٤١٧ (١٤٣١).أخرجه ابن جرير ١٤/٢٤٠. وعلقه البخاري ١/١١٣. وعزاه السيوطي إلى ابن أبي حاتم.علقه البخاري ٤/١٧٣٩. قال الحافظ ابن حجر في فتح الباري ٨/٣٨٥: «كذا فيه، والصواب: تتميَّل. وقد تقدم بيانه في كتاب الصلاة». يشير إلى الأثر السابق. وقراءة التاء هي قراءة أبي عمرو ويعقوب، وقرأ الباقون بالياء. انظر: النشر ٢/٣٠٤.أخرجه ابن جرير ١٤/٢٤٢.أخرجه ابن جرير ١٤/٢٤٢ بنحوه. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.أخرجه ابن جرير ١٤/٢٤١.عزاه السيوطي إلى ابن جرير، وابن المنذر. والأثر عند ابن جرير بنحوه من قول ابن جريج كما سيأتي.أخرجه ابن جرير ١٤/٢٤١. وعزاه السيوطي إلى ابن أبي حاتم.أخرجه أبو الشيخ في العظمة (١٢١٢). وعزاه السيوطي إلى ابن أبي حاتم.أخرجه ابن جرير ١٤/٢٤٠.تفسير الثعلبي ٦/٢٠، وتفسير البغوي ٥/٢١.علَّقه يحيى بن سلام ١/٦٧.أخرجه يحيى بن سلام ١/٦٧ مختصرًا، وعبد الرزاق ١/٣٥٦ من طريق معمر، وابن جرير ١٤/٢٣٩ مختصرًا. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.أخرجه ابن أبي شيبة ١/٤٠٤.علَّقه يحيى بن سلام ١/٦٧.تفسير الثعلبي ٦/٢٠، وتفسير البغوي ٥/٢١.تفسير مقاتل بن سليمان ٢/٤٧١.أخرجه ابن جرير ١٤/٢٤٠.تفسير يحيى بن سلام ١/٦٧.عزاه السيوطي إلى ابن أبي حاتم.أخرجه ابن جرير ١٤/٢٤٣. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.أخرجه ابن جرير ١٤/٢٤١.أخرجه عبد الرزاق ١/٣٥٦ من طريق معمر، وابن جرير ١٤/٢٤٣. وعلقه يحيى بن سلام ١/٦٧. وعزاه السيوطي إلى ابن المنذر.علقه يحيى بن سلام ١/٦٧.تفسير مقاتل بن سليمان ٢/٤٧١.
16,49," <q>﴿وَلِلَّهِ یَسۡجُدُ مَا فِی ٱلسَّمَـٰوَ ٰ⁠تِ﴾</q> - تفسير ٤١٣٤٤- عن الحسن البصري، في الآية، قال: يسجد من في السماوات طوعًا{1}. (٩/٥٨) ٤١٣٤٥- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿ولله يسجد ما في السماوات وما في الأرض من دآبّة﴾</q>، قال: لم يدع شيئًا من خلقه إلا عبَّده له؛ طائعًا أو كارهًا{2}. (٩/٥٨) ٤١٣٤٦- قال مقاتل بن سليمان: إذا قال: <q>﴿ما في السماوات﴾</q> يعني: من الملائكة وغيرهم، وكل شيء في السماء، والأرض، والجبال، والأشجار، وكل شيء في الأرض. وإذا قال: <q>﴿من في السموات﴾</q> يعني: كل ذي روح من الملائكة، والآدميين، والطير، والوحوش، والدواب، والسباع، والهوام، والحيتان في الماء، وكل ذي روح أيضًا، يسجدون{3}. (ز) ٤١٣٤٧- قال يحيى بن سلّام: قوله: <q>﴿ولله يسجد ما في السموات﴾</q> الملائكة{4}. (ز) <q>﴿وَمَا فِی ٱلۡأَرۡضِ مِن دَاۤبَّةࣲ﴾</q> - تفسير ٤١٣٤٨- عن الحسن البصري، في الآية، قال: يسجد من في السماوات طوعًا، ومن في الأرض طوعًا وكرهًا{1}. (٩/٥٨) ٤١٣٤٩- قال مقاتل بن سليمان: <q>﴿ولِلَّهِ يَسْجُدُ ما فِي السَّماواتِ﴾</q> من الملائكة، <q>﴿وما فِي الأَرْضِ مِن دابَّةٍ﴾</q> أيضًا يسجدون{3}. (ز) <q>﴿وَٱلۡمَلَـٰۤىِٕكَةُ وَهُمۡ لَا یَسۡتَكۡبِرُونَ ۝٤٩﴾</q> - تفسير ٤١٣٥٠- قال مقاتل بن سليمان: ثم نعت الله الملائكة، فقال: <q>﴿والملائكة وهم لا يستكبرون﴾</q>، يعني: لا يتكبرون عن السجود{7}. (ز) ٤١٣٥١- قال يحيى بن سلّام: قوله: <q>﴿وهم لا يستكبرون﴾</q> عن عبادة الله، يعني: الملائكة{4}. (ز) ",footnotes:1:عزاه السيوطي إلى ابن أبي حاتم.أخرجه ابن جرير ١٤/٢٤٨. وعزاه السيوطي إلى ابن أبي حاتم.تفسير مقاتل بن سليمان ٢/٤٧١.تفسير يحيى بن سلام ١/٦٨.عزاه السيوطي إلى ابن أبي حاتم.تفسير مقاتل بن سليمان ٢/٤٧١.تفسير مقاتل بن سليمان ٢/٤٧١-٤٧٢.تفسير يحيى بن سلام ١/٦٨.
16,50," <q>﴿یَخَافُونَ رَبَّهُم مِّن فَوۡقِهِمۡ وَیَفۡعَلُونَ مَا یُؤۡمَرُونَ﴾</q> - تفسير ٤١٣٥٢- عن عبد الله بن عباس -من طريق ابن أبي نجيح، عن مجاهد- في قوله: <q>﴿يخافون ربّهم من فوقهم﴾</q>، قال: مخافة الإجلال{1}. (٩/٥٨) ٤١٣٥٣- قال مقاتل بن سليمان: <q>﴿يخافون ربهم من فوقهم﴾</q> الذي هو فوقهم؛ لأن الله تعالى فوق كل شيء؛ خلق العرش، والعرش فوق كل شيء، <q>﴿ويفعلون ما يؤمرون﴾</q>{2}. (ز) ",footnotes:1:أخرجه الخطيب في تاريخه ١/٣٣١.تفسير مقاتل بن سليمان ٢/٤٧٢.
16,51," <q>﴿وَقَالَ ٱللَّهُ لَا تَتَّخِذُوۤا۟ إِلَـٰهَیۡنِ ٱثۡنَیۡنِۖ إِنَّمَا هُوَ إِلَـٰهࣱ وَ ٰ⁠حِدࣱ فَإِیَّـٰیَ فَٱرۡهَبُونِ ۝٥١﴾</q> - نزول الآية ٤١٣٥٤- قال مقاتل بن سليمان: <q>﴿وقالَ اللَّهُ لا تَتَّخِذُوا إلهَيْنِ اثْنَيْنِ﴾</q>، وذلك أنّ رجلًا من المسلمين دعا الله ﷿ في صلاته، ودعا الرحمن. فقال رجل من المشركين: أليس يزعم محمد ﷺ وأصحابه أنهم يعبدون ربًّا واحدًا، فما بال هذا يدعو ربين اثنين؟! فأنزل الله ﷿ في قوله: <q>﴿لا تَتَّخِذُوا إلهَيْنِ اثْنَيْنِ﴾</q>{1}. (ز) <q>﴿وَقَالَ ٱللَّهُ لَا تَتَّخِذُوۤا۟ إِلَـٰهَیۡنِ ٱثۡنَیۡنِۖ﴾</q> - تفسير ٤١٣٥٥- قال يحيى بن سلّام: <q>﴿وقال الله لا تتخذوا إلهين اثنين﴾</q>، أي: لا تعبدوا مع الله غيره{2}. (ز) <q>﴿إِنَّمَا هُوَ إِلَـٰهࣱ وَ ٰ⁠حِدࣱ فَإِیَّـٰیَ فَٱرۡهَبُونِ ۝٥١﴾</q> - تفسير ٤١٣٥٦- قال مقاتل بن سليمان: <q>﴿إنَّما هُوَ إلهٌ واحِدٌ فَإيّايَ فارْهَبُونِ﴾</q>، يعني: إيّاي فخافون في ترك التوحيد، فمَن لم يوحد فله النار{1}. (ز) ٤١٣٥٧- قال يحيى بن سلّام: <q>﴿إنما هو إله واحد فإياي فارهبون﴾</q> فخافون{2}. (ز) <q>﴿إِنَّمَا هُوَ إِلَـٰهࣱ وَ ٰ⁠حِدࣱ فَإِیَّـٰیَ فَٱرۡهَبُونِ ۝٥١﴾</q> - آثار متعلقة بالآية ٤١٣٥٨- عن سعد بن أبي وقاص، قال: مَرَّ النبي ﷺ وأنا أدعو بأصابعي، فقال النبي ﷺ: «أحِّدْ، أحِّدْ». وأشار بالسبّابة{5}. (٩/٥٩) ٤١٣٥٩- عن عائشة -من طريق قتادة، عن رجل- أنها رأت امرأةً تدعو وهي رافعة إصبعيها التي تلي الإبهامين، فقالت لها: إنما الله إله واحد. فنهتها عن ذلك{6}. (٩/٦٠) ٤١٣٦٠- عن نافع، أن عبد الله بن عمر رأى رجلًا يشير بإصبعيه، فقال له ابن عمر: إنما الله إلهٌ واحدٌ؛ فأشِرْ بإصبع واحدة إذا أشَرْت{7}. (٩/٦٠) ٤١٣٦١- عن محمد بن سيرين -من طريق ابن عون- قال: كانوا إذا رأوا إنسانًا يدعو بإصْبَعَيه ضربوا إحداهما، وقالوا: <q>﴿إنّما هو إلهٌ واحدٌ﴾</q>{8}. (٩/٥٩) ",footnotes:1:تفسير مقاتل بن سليمان ٢/٤٧٢.تفسير يحيى بن سلام ١/٦٨.تفسير مقاتل بن سليمان ٢/٤٧٢.تفسير يحيى بن سلام ١/٦٨.أخرجه أبو داود ٢/٦١٥ (١٤٩٩)، والنسائي ٣/٣٨ (١٢٧٣) والحاكم ١/٧١٩ (١٩٦٦). قال الحاكم: «هذا حديث صحيح الإسنادين جميعًا، فأما حديث أبي معاوية فهو صحيح على شرطهما إن كان أبو صالح السمان سمع من سعد». وذكر الدارقطني في العلل ٤/٣٩٧ (٦٥٥) الاختلاف في إسناده على صحابيّه، ورجَّح أنه من حديث سعد. وقال الألباني في صحيح أبي داود ٥/٢٣٥ (١٣٤٤): «إسناده صحيح، على شرط الشيخين».أخرجه عبد الرزاق في مصنفه (٣٢٤٣).أخرجه عبد الرزاق في مصنفه (٣٢٤١).أخرجه ابن أبي شيبة ١٠/٣٨٢.
16,52," <q>﴿وَلَهُۥ مَا فِی ٱلسَّمَـٰوَ ٰ⁠تِ وَٱلۡأَرۡضِ﴾</q> - تفسير ٤١٣٦٢- قال مقاتل بن سليمان: ثم عظَّم الربُّ -تبارك وتعالى- نفسه من أن يكون معه إله آخر، فقال ﷿: <q>﴿ولَهُ ما فِي السَّماواتِ والأَرْضِ﴾</q> مِن الخلق؛ عبيده، وفي ملكه{1}. (ز) <q>﴿وَلَهُ ٱلدِّینُ﴾</q> - تفسير ٤١٣٦٣- عن مجاهد بن جبر -من طريق ابن جريج- في قوله: <q>﴿وله الدّين واصِبًا﴾</q>، قال: <q>﴿الدّين﴾</q>: الإخلاص{2}. (٩/٦٠) ٤١٣٦٤- عن أبي صالح باذام، في قوله: <q>﴿وله الدّين واصبًا﴾</q>، قال: لا إله إلا الله{3}. (٩/٦٠) ٤١٣٦٥- قال مقاتل بن سليمان: <q>﴿ولَهُ الدِّينُ﴾</q>، يعني: الإسلام{1}. (ز) <q>﴿وَاصِبًاۚ﴾</q> - تفسير ٤١٣٦٦- عن عبد الله بن عباس -من طريق أبي نضرة- في قوله: <q>﴿وله الدّين واصِبًا﴾</q>، قال: دائمًا{5}. (٩/٦١) ٤١٣٦٧- عن عبد الله بن عباس -من طريق عكرمة- في قوله: <q>﴿وله الدّين واصِبًا﴾</q>، قال: واجبًا{6}٣٦٧٧. (٩/٦١) ٣٦٧٧ ذكر ابنُ عطية (٥/٣٦٨) عن ابن عباس أن «الواصب» بمعنى: الواجب. وعلّق عليه بقوله: «وهذا نحو قوله: الواصب: الدائم». وذكر ابنُ عطية في معنى الواصب قولًا آخر: أن معناه: التعب. ثم علّق عليه قائلًا: «فـ»واصب" على هذا جار على النسب، أي: ذا وصب، كما قال: أضحى فؤادي به فاتنًا وهذا كثير". ٤١٣٦٨- عن عبد الله بن عباس، أن نافع بن الأزرق قال له: أخبِرني عن قوله: <q>﴿وله الدّين واصِبًا﴾</q>، ما الواصِب؟ قال: الدائم، قال فيه أُمَيَّة بن أبي الصَّلت: وله الدّين واصبًا وله الملـ ـك وحَمْدٌ له على كلّ حال{7}. (٩/٦١) ٤١٣٦٩- عن مجاهد بن جبر -من طريق ابن جريج- في قوله: <q>﴿واصِبًا﴾</q>: دائمًا{8}. (٩/٦٠) ٤١٣٧٠- عن الضحاك بن مزاحم -من طريق جويبر- <q>﴿وله الدين واصبا﴾</q>، قال: دائمًا{9}. (ز) ٤١٣٧١- عن عكرمة مولى ابن عباس -من طريق أبي حصين- في قوله: <q>﴿وله الدين واصبا﴾</q>، قال: دائمًا{10}. (ز) ٤١٣٧٢- عن الحسن البصري، في الآية، قال: إنّ هذا الدينَ دينٌ واصبٌ، شَغَل الناس، وحال بينهم وبين كثير من شهواتهم، فما يستطيعه إلا مَن عرَف فضله، ورجا عاقبته{11}. (٩/٦١) ٤١٣٧٣- عن ميمون بن مهران -من طريق جعفر بن برقان- قال: دائمًا{12}. (ز) ٤١٣٧٤- عن قتادة بن دعامة -من طريق سعيد- <q>﴿وله الدين واصبا﴾</q>، أي: دائمًا؛ فإنّ الله تبارك وتعالى لم يدع شيئًا مِن خلقه إلا عبده، طائعًا أو كارهًا{13}. (ز) ٤١٣٧٥- عن قتادة بن دعامة -من طريق معمر- <q>﴿واصبا﴾</q>، قال: دائمًا، ألا ترى أنه يقول: <q>﴿عذاب واصب﴾</q> [الصافات:٩]، أي: دائم{14}. (ز) ٤١٣٧٦- قال مقاتل بن سليمان، في قوله: <q>﴿واصِبًا﴾</q>: دائمًا{1}. (ز) ٤١٣٧٧- عن سفيان الثوري، في قوله: <q>﴿وله الدين واصبا﴾</q>، قال: دائمًا{16}. (ز) ٤١٣٧٨- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿وله الدين واصبا﴾</q>، قال: دائمًا، والواصِب: الدائم{17}٣٦٧٨. (ز) ٣٦٧٨ في معنى الواصب قولان: الأول: أنه الواجب. الثاني: أنه الدائم. وقد ذكر ابنُ جرير (١٤/٢٤٦) القولين، وجمع بينهما مستندًا إلى اللغة، والنظائر، فقال: "وقوله: <q>﴿وله الدين واصبا﴾</q> يقول -جل ثناؤه-: وله الطاعة والإخلاص دائمًا ثابتًا واجبًا. يُقال منه: وصب الدين يصب وصوبًا ووصبًا، كما قال الديلي: لا أبتغي الحمد القليل بقاؤه ... يومًا بذم الدهر أجمع واصبًا ومنه قول الله: <q>﴿ولهم عذاب واصب﴾</q> [الصافات:٩]". <q>﴿أَفَغَیۡرَ ٱللَّهِ تَتَّقُونَ ۝٥٢﴾</q> - تفسير ٤١٣٧٩- قال مقاتل بن سليمان: <q>﴿أفَغَيْرَ اللَّهِ﴾</q> من الآلهة <q>﴿تَتَّقُونَ﴾</q> يعني: تعبدون، يعني: كفار مكة{1}. (ز) ٤١٣٨٠- قال يحيى بن سلّام: <q>﴿أفغير الله تتقون﴾</q>، يعني: تعبدون، يعني: المشركين، على الاستفهام، أي: قد فعلتم فعبدتم الأوثان من دونه{19}. (ز) ",footnotes:1:تفسير مقاتل بن سليمان ٢/٤٧٢.أخرجه ابن جرير ١٤/٢٤٩، وأيضًا من طريق ابن أبي نجيح. وعزاه السيوطي إلى ابن أبي شيبة، وابن المنذر، وابن أبي حاتم.عزاه السيوطي إلى ابن أبي حاتم.تفسير مقاتل بن سليمان ٢/٤٧٢.أخرجه ابن جرير ١٤/٢٤٧. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.أخرجه ابن جرير ١٤/٢٤٩. وعزاه السيوطي إلى الفريابي.عزاه السيوطي إلى ابن الأنباريّ في الوقف والابتداء.أخرجه ابن جرير ١٤/٢٤٨، ومن طريق ابن أبي نجيح أيضًا. وعلقه يحيى بن سلام ١/٦٨. وعزاه السيوطي إلى ابن أبي شيبة، وابن المنذر، وابن أبي حاتم.أخرجه ابن جرير ١٤/٢٤٨.أخرجه ابن جرير ١٤/٢٤٧.عزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.أخرجه يحيى بن سلام ١/٦٨.أخرجه ابن جرير ١٤/٢٤٨، وأخرجه يحيى بن سلام ١/٦٨ مقتصرًا على قوله: دائمًا.أخرجه عبد الرزاق في تفسيره ٢/٣٥٧، وابن جرير ١٤/٢٤٨.تفسير مقاتل بن سليمان ٢/٤٧٢.تفسير الثوري ص١٦٥.أخرجه ابن جرير ١٤/٢٤٩.تفسير مقاتل بن سليمان ٢/٤٧٢.تفسير يحيى بن سلام ١/٦٨.
16,53," <q>﴿وَمَا بِكُم مِّن نِّعۡمَةࣲ فَمِنَ ٱللَّهِۖ﴾</q> - تفسير ٤١٣٨١- قال مقاتل بن سليمان: ثم ذكَّرهم النِّعَم، فقال سبحانه: <q>﴿وما بِكُمْ مِن نِعْمَةٍ فَمِنَ اللَّهِ﴾</q>؛ ليوحدوا ربَّ هذه النعم. يعني بالنِّعَم: الخير، والعافية{1}. (ز) <q>﴿ثُمَّ إِذَا مَسَّكُمُ ٱلضُّرُّ﴾</q> - تفسير ٤١٣٨٢- عن عبد الله بن عباس -من طريق علي- قال: الضر: السقم{2}٣٦٧٩. (ز) ٣٦٧٩ لم يذكر ابنُ جرير (١٤/٢٥٢) غير قول ابن عباس. ٤١٣٨٣- قال مقاتل بن سليمان: <q>﴿ثُمَّ إذا مَسَّكُمُ الضُّرُّ﴾</q>، يعني: الشدة، وهو الجوع، والبلاء، وهو قحط المطر بمكة سبع سنين{3}. (ز) ٤١٣٨٤- قال يحيى بن سلّام: قوله: <q>﴿ثم إذا مسكم الضر﴾</q> المرض، وذهاب الأموال، والشدائد{4}. (ز) <q>﴿فَإِلَیۡهِ تَجۡـَٔرُونَ ۝٥٣﴾</q> - تفسير ٤١٣٨٥- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿فإليه تجأرون﴾</q>، قال: تتضرَّعون دعاء{5}. (٩/٦١) ٤١٣٨٦- قال مجاهد بن جبر: <q>﴿تجأرون﴾</q>: تصرخون{6}. (ز) ٤١٣٨٧- عن إسماعيل السُّدِّيّ، في قوله: <q>﴿فإليه تجأرون﴾</q>، يقول: تَضِجُّون بالدعاء{7}. (٩/٦١) ٤١٣٨٨- قال مقاتل بن سليمان: <q>﴿فَإلَيْهِ تَجْئَرُونَ﴾</q>، يعني: تَضَرَّعون بالدعاء؛ لا تدعون غيره أن يكشف عنكم ما نزل بكم من البلاء والدعاء حين قالوا في حم الدخان [١٢]: <q>﴿رَبَّنا اكْشِفْ عَنّا العَذابَ إنّا مُؤْمِنُونَ﴾</q>، يعني: مُصَدِّقين بالتوحيد{3}. (ز) ٤١٣٨٩- قال يحيى بن سلّام: قوله: <q>﴿فإليه تجأرون﴾</q>: تدعونه، ولا تدعون الأوثان{4}. (ز) ",footnotes:1:تفسير مقاتل بن سليمان ٢/٤٧٢.أخرجه ابن جرير ١٤/٢٥٢.تفسير مقاتل بن سليمان ٢/٤٧٣.تفسير يحيى بن سلام ١/٦٨.أخرجه ابن جرير ١٤/٢٥١-٢٥٢. وعزاه السيوطي إلى ابن أبي شيبة، وابن المنذر، وابن أبي حاتم.علَّقه يحيى بن سلام ١/٦٨.عزاه السيوطي إلى ابن أبي حاتم.تفسير مقاتل بن سليمان ٢/٤٧٣.تفسير يحيى بن سلام ١/٦٨.
16,54," <q>﴿ثُمَّ إِذَا كَشَفَ ٱلضُّرَّ عَنكُمۡ إِذَا فَرِیقࣱ مِّنكُم بِرَبِّهِمۡ یُشۡرِكُونَ ۝٥٤﴾</q> - تفسير ٤١٣٩٠- عن قتادة بن دعامة، في قوله: <q>﴿ثم إذا كشف الضُّر﴾</q> الآية، قال: الخلقُ كلُّهم مُقِرُّون لله أنه ربُّهم، ثم يُشْرِكون بعد ذلك{1}. (٩/٦٢) ٤١٣٩١- قال مقاتل بن سليمان: <q>﴿ثُمَّ إذا كَشَفَ الضُّرَّ عَنْكُمْ﴾</q> يعني: الشدة، وهو الجوع، وأرسل السماء بالمطر مدرارًا <q>﴿إذا فَرِيقٌ مِنكُمْ بِرَبِّهِمْ يُشْرِكُونَ﴾</q> يعني: يتركون التوحيد لله تعالى في الرخاء؛ فيعبدون غيره، وقد وحَّدُوه في الضر{2}. (ز) ٤١٣٩٢- قال يحيى بن سلّام: <q>﴿إذا فريق منكم بربهم يشركون﴾</q>، يعني بالفريق: المشركين{3}. (ز) ",footnotes:1:عزاه السيوطي إلى ابن أبي حاتم.تفسير مقاتل بن سليمان ٢/٤٧٣.تفسير يحيى بن سلام ١/٦٨.
