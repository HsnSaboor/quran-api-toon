quran[3]{c,v,t}:
  4,24,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَٱلۡمُحۡصَنَـٰتُ مِنَ ٱلنِّسَاۤءِ إِلَّا مَا مَلَكَتۡ أَیۡمَـٰنُكُمۡۖ﴾</span> - قراءات</h3></p><p><div></p><p><p><span class="item-no">١٧١٥٩<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن مسعود</span> أنّه قرأ: <span class="qpc-hafs">﴿والمُحْصَناتِ مِنَ النِّسَآءِ﴾</span> بنصب الصاد= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧١٦٠<span class="dash">-</span></span> وكان <span class="name-2">يحيى بن وثاب</span> يقرأ: (والمُحْصِناتِ) بكسر الصاد{1}. (٤/٣٢٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧١٦١<span class="dash">-</span></span> عن <span class="name-2">الأسود</span> أنّه كان ربما قرأ: <span class="qpc-hafs">﴿والمُحْصَناتِ﴾</span>، وربما قرأ (والمُحْصِناتِ){2}. (٤/٣٢٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧١٦٢<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> أنه كان يقرأ كل شيء في القرآن: (والمُحْصِناتِ) بكسر الصاد، إلا التي في النساء: <span class="qpc-hafs">﴿والمُحْصَناتُ مِنَ النِّسَآءِ﴾</span> بالنصبِ{3}<span class=comment-ref>١٥٩٧</span>. (٤/٣٢٣)</p></p><p></div></p><p><div><span class=comment-ref>١٥٩٧</span> قُرِئَ قوله تعالى: <span class="qpc-hafs">﴿والمحصَنات﴾</span> بفتح الصاد، وكسرها، أما قراءة <span class="qpc-hafs">﴿والمحصَنات﴾</span> بفتح الصاد، فعلى معنى: أنّ النساء أحصنَهنّ غيرُهنّ: مِن زوج، أو إسلام، أو عِفَّة، أوحُرِّيَّة. وأما قراءة <span class="qpc-hafs">﴿والمحصِنات﴾</span> بكسر الصاد، فعلى معنى: أنّ النساء أحصَنَّ أنفسَهنّ بهذه الوجوه أو بعضها.</p><p>وقال <u>ابنُ جرير</u> (٦/٥٩٨): «الصواب عندنا من القول في ذلك: أنّهما قراءتان مستفيضتان في قراءة الأمصار مع اتفاق ذلك في المعنى؛ فبأيتهما قرأ القارئ فمصيبٌ الصواب، إلا في الحرف الأول من سورة النساء، وهو قوله: <span class="qpc-hafs">﴿والمحصنات من النساء إلا ما ملكت أيمانكم﴾</span>، فإنِّي لا أستجيزُ الكسر في صاده؛ لاتفاق قراءة الأمصار على فتحها. ولو كانت القراءة بكسرها مستفيضة استفاضتها بفتحها كان صوابًا القراءة بها كذلك».</div></p><p><h3><span class="qpc-hafs">﴿وَٱلۡمُحۡصَنَـٰتُ مِنَ ٱلنِّسَاۤءِ إِلَّا مَا مَلَكَتۡ أَیۡمَـٰنُكُمۡۖ﴾</span> - نزول الآية</h3></p><p><div></p><p><p><span class="item-no">١٧١٦٣<span class="dash">-</span></span> عن <span class="name-1">أبي سعيد الخدري</span>: أنّ رسول الله ﷺ بعث يوم حُنَيْن جيشًا إلى أوْطاس، فلقوا عدوًّا، فقاتلوهم، فظهروا عليهم، وأصابوا لهم سَبايا، فكان ناسٌ مِن أصحاب رسول الله ﷺ تَحَرَّجوا من غشيانهن؛ من أجل أزواجِهِنَّ من المشركين؛ فأنزل الله في ذلك: <span class="qpc-hafs">﴿والمحصنات من النساء إلا ما ملكت أيمانكم﴾</span>. يقول: إلا ما أفاء اللهُ عليكم. فاستحللنا بذلك فروجَهُنَّ{4}. (٤/٣١٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧١٦٤<span class="dash">-</span></span> عن رزين الجُرْجانِيِّ، قال: سألتُ <span class="name-2">سعيدَ بن جبير</span> عن هذه الآية: <span class="qpc-hafs">﴿والمحصنات من النساء﴾</span>. قال: لا علم لي بها. فسألت <span class="name-2">الضحاك بن مزاحم</span> -وذكرت قول سعيد بن جبير-، فقال: أشهدُ لَسَمِعْتُه يسأل عنها عبد الله بن عباس، فقال ابنُ عباس: نزلت يوم خيبر، لَمّا فتح رسول الله ﷺ أصاب المسلمون مِن نساء أهل الكتاب لهن أزواج، فكان الرجل إذا أراد أن يأتي امرأة منهنَّ قالت: إن لي زوجًا. فسُئِل رسول الله ﷺ عن ذلك؛ فأنزل الله ﷿ هذه الآية: <span class="qpc-hafs">﴿والمحصنات من النساء﴾</span> الآية. يعني: السَّبِيَّة من المشركين تُصابُ، لا بأس بذلك. فذكرت ذلك لسعيد بن جبير، فقال: صدق{5}. (٤/٣١٧) (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧١٦٥<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span> -من طريق سالم- في الآية، قال: نزلت في نساء أهل حُنَيْن، لَمّا افتتح رسول الله ﷺ حُنَيْنًا أصاب المسلمون سبايا، فكان الرجلُ إذا أراد أن يأتي المرأةَ مِنهُنَّ قالت: إنّ لي زوجًا. فأتَوا النبي ﷺ، فذكروا ذلك له؛ فأنزل الله تعالى: <span class="qpc-hafs">﴿والمحصنات من النساء إلا ما ملكت أيمانكم﴾</span>. قال: السبايا مِن ذوات الأزواج{6}. (٤/٣١٧-٣١٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧١٦٦<span class="dash">-</span></span> عن <span class="name-2">عامر الشعبي</span> -من طريق زكريا- في الآية، قال: نزلت يوم أوْطاس{7}. (٤/٣٢٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧١٦٧<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span>: أنّ هذه الآية التي في سورة النساء: <span class="qpc-hafs">﴿والمحصنات من النساء إلا ما ملكت أيمانكم﴾</span> نزلت في امرأةٍ يُقال لها: معاذة. وكانت تحت شيخ مِن بني سَدُوس يُقال له: شجاع بن الحارث. وكان معها ضَرَّة لها قد ولدت لشجاع أولادًا رِجالًا، وإنّ شجاعًا انطلق يَمِير أهله مِن هَجَر، فمَرَّ بمعاذةَ ابنُ عمٍّ لها، فقالت له: احملني إلى أهلي؛ فإنّه ليس عند هذا الشيخ خير. فاحتملها، فانطلق بها، فوافق ذلك جيئة الشيخ، فانطلق إلى رسول الله ﷺ، فقال: يا رسول الله وأفضلَ العرب، إنِّي خرجت أبغيها الطعام في رجب، فتَوَلَّتْ وأَلَطَّتْ بالذَّنَب{8}، وهُنَّ شرٌّ غالِبٌ لِمَن غلب، رأت غلامًا وارِكًا على قَتَب{9}، لها وله أرَبٌ. فقال رسول الله ﷺ: «<b>عليَّ عليَّ، فإن كان الرجل كشف بها ثوبًا فارجموها، وإلا فردوا على الشيخ امرأته</b>». فانطلق مالكُ بن شجاع وابن ضَرَّتِها، فطلبها، فجاء بها، ونزلت بيتها{2}. (٤/٣٢٤)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَٱلۡمُحۡصَنَـٰتُ مِنَ ٱلنِّسَاۤءِ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">١٧١٦٨<span class="dash">-</span></span> عن أبي هريرة، قال: قال النبي ﷺ: «<b>الإحصان إحصانان: إحصانُ نكاح، وإحصان عفاف</b>»{11}. (٤/٣٢٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧١٦٩<span class="dash">-</span></span> عن <span class="name-1">عمر بن الخطاب</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧١٧٠<span class="dash">-</span></span> و<span class="name-2">عَبيدة السلماني</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧١٧١<span class="dash">-</span></span> و<span class="name-2">أبي العالية الرياحي</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧١٧٢<span class="dash">-</span></span> و<span class="name-2">إسماعيل السُّدِّيّ</span>، في قوله: <span class="qpc-hafs">﴿والمحصنات من النساء﴾</span>: العفائف مِن النساء{12}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧١٧٣<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن مسعود</span> -من طريق إبراهيم- في قوله: <span class="qpc-hafs">﴿والمحصنات من النساء إلا ما ملكت أيمانكم﴾</span>، قال: ذوات الأزواج من المسلمين والمشركين{13}. (٤/٣١٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧١٧٤<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن مسعود</span> -من طريق أبي قلابة- <span class="qpc-hafs">﴿والمحصنات من النساء﴾</span>، قال: سبايا كان لَهُنَّ أزواجٌ قبل أن يُسْبَيْنَ{14}. (٤/٣٢٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧١٧٥<span class="dash">-</span></span> عن <span class="name-1">علي بن أبي طالب</span> -من طريق إبراهيم- في قوله: <span class="qpc-hafs">﴿والمحصنات من النساء إلا ما ملكت أيمانكم﴾</span>، قال: ذوات الأزواج من المشركين{15}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧١٧٦<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق العوفي- <span class="qpc-hafs">﴿والمحصنات من النساء﴾</span>، يعني بذلك: ذوات الأزواج من النساء، لا يَحِلُّ نِكاحُهُنَّ. يقول: لا تَخْلِب{16} ولا تَعِدْ فتنشِز على بعلها، وكلُّ امرأة لا تُنكح إلا ببينة ومهر فهي مِن المُحْصَنات التي حرَّم{17}. (٤/٣٢٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧١٧٧<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق العوفي- <span class="qpc-hafs">﴿والمحصنات من النساء﴾</span>، قال: ذوات الأزواج{18}. (٤/٣١٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧١٧٨<span class="dash">-</span></span> وعن <span class="name-2">محمد بن علي</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧١٧٩<span class="dash">-</span></span> و<span class="name-2">مجاهد بن جبر</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧١٨٠<span class="dash">-</span></span> و<span class="name-2">الضحاك بن مُزاحِم</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧١٨١<span class="dash">-</span></span> و<span class="name-2">سعيد بن جبير</span>، مثل ذلك{19}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧١٨٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق مجاهد- في قوله: <span class="qpc-hafs">﴿والمحصنات﴾</span>، قال: العفيفة العاقلة، مِن مسلمة أو مِن أهل الكتاب{20}<span class=comment-ref>١٥٩٨</span>. (٤/٣٢٢)</p></p><p></div></p><p><div><span class=comment-ref>١٥٩٨</span> <span class="comment-type-4">علَّقَ</span> <u>ابنُ عطية</u> (٢/٥١٤) على قول ابن عباس هذا بقوله: «بهذا التأويل يرجع معنى الآية إلى تحريم الزنا».</div></p><p><div></p><p><p><span class="item-no">١٧١٨٣<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عمر</span> -من طريق نافع- أنّه كان لا يرى مُشرِكة مُحصَنة، يعني: اليهوديات والنصرانيات{18}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧١٨٤<span class="dash">-</span></span> عن <span class="name-1">أنس بن مالك</span> -من طريق أبي مِجْلَز- <span class="qpc-hafs">﴿والمحصنات من النساء﴾</span>، قال: ذوات الأزواج الحرائر حرامٌ إلا ما ملكت أيمانكم{22}. (٤/٣١٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧١٨٥<span class="dash">-</span></span> عن <span class="name-2">سعيد بن المسيب</span> -من طريق مالك، عن الزهري- <span class="qpc-hafs">﴿والمحصنات من النساء﴾</span>، قال: هُنَّ أُولاتُ الأزواج، ويرجع ذلك إلى أن حرَّم الله الزِّنا{23}. (٤/٣٢٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧١٨٦<span class="dash">-</span></span> عن الزهري، قال: كان <span class="name-2">سعيد بن المسيب</span> يقول في قول الله تعالى: <span class="qpc-hafs">﴿والمحصنات من النساء﴾</span>: هُنَّ ذوات الأزواج، حرَّم اللهُ نكاحهن مع أزواجهن، فالمُحصَنة بالعفاف والمُحصَنة بالزوج حُرِّمتا كلتيهما، إلا أنّ ملك يمينك مِن النساء مِن الإماء لك حلالٌ إذا لم يكن للأمة زوجٌ، وقد تكون الأمةُ مُحْصَنَةً وليس لها زوجٌ؛ سَمّاها اللهُ مُحْصَنَةً{24}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧١٨٧<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span> -من طريق جعفر- في قوله: <span class="qpc-hafs">﴿والمحصنات من النساء إلا ما ملكت أيمانكم﴾</span>، قال: الأربع، فما بعدهُنَّ حرام{25}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧١٨٨<span class="dash">-</span></span> عن <span class="name-2">إبراهيم النخعي</span> -من طريق الصَّلْت- قال: كلُّ ذاتِ زوجٍ عليك حرامٌ، إلّا ما أصَبْتَ مِن السَّبايا{26}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧١٨٩<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نَجِيح- <span class="qpc-hafs">﴿والمحصنات من النساء﴾</span>، قال: نُهِينَ عن الزِّنا{27}. (٤/٣٢٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧١٩٠<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن إدريس، عن بعض أصحابه- <span class="qpc-hafs">﴿والمحصنات من النساء إلا ما ملكت أيمانكم﴾</span>، قال: العفائِف{28}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧١٩١<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق أشْعَث- قال: كُلُّ ذاتِ زوجٍ عليك حرامٌ، إلّا ما مَلَكَتْ يمينُك، يعني: مِن السبايا{29}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧١٩٢<span class="dash">-</span></span> عن <span class="name-2">الحسن بن محمد [بن الحنفية]</span> -من طريق قيس بن مسلم-، مثله{30}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧١٩٣<span class="dash">-</span></span> عن <span class="name-2">مَكْحُول الشامي</span> -من طريق عبد الكريم- <span class="qpc-hafs">﴿والمحصنات من النساء﴾</span>، قال: كُلُّ ذاتِ زوجٍ عليكم حرامٌ{31}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧١٩٤<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- <span class="qpc-hafs">﴿والمحصنات من النساء﴾</span>، قال: الخامِسةُ حرامٌ، كحُرْمَة الأمهات والأخوات{28}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧١٩٥<span class="dash">-</span></span> عن عَزْرَة -من طريق سليمان- في قوله: <span class="qpc-hafs">﴿والمحصنات من النساء﴾</span>، قال: الحرائر{33}<span class=comment-ref>١٥٩٩</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>١٥٩٩</span> <span class="comment-type-4">علَّقَ</span> <u>ابنُ عطية</u> (٢/٥١٤) على هذا القول، فقال: «ويكون <span class="qpc-hafs">﴿إلا ما ملكت أيمانكم﴾</span> معناه: بنكاح، هذا على اتصال الاستثناء، وإن أريد: الإماء؛ فيكون الاستثناء منقطعًا».</div></p><p><div></p><p><p><span class="item-no">١٧١٩٦<span class="dash">-</span></span> عن عَزْرَة -من طريق سليمان- في قوله ﷿: <span class="qpc-hafs">﴿والمحصنات من النساء إلا ما ملكت أيمانكم﴾</span>، قال: أربعٌ أحلَّهُنَّ الله، وحَرَّم ما سوى ذلك{34}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَٱلۡمُحۡصَنَـٰتُ مِنَ ٱلنِّسَاۤءِ إِلَّا مَا مَلَكَتۡ أَیۡمَـٰنُكُمۡۖ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">١٧١٩٧<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن مسعود</span> -من طريق إبراهيم- في قوله: <span class="qpc-hafs">﴿والمحصنات من النساء إلا ما ملكت أيمانكم﴾</span>، قال: كُلُّ ذاتِ زوجٍ عليك حرامٌ، إلا ما اشتريتَ بمالِك. وكان يقول: بيعُ الأَمَةِ طلاقُها{35}. (٤/٣١٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧١٩٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن مسعود</span> -من طريق أبي قِلابة- قال: إذا بِيعَتِ الأمةُ ولها زوجٌ فسيِّدُها أحَقُّ بِبُضْعِها{36}. (٤/٣١٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧١٩٩<span class="dash">-</span></span> عن <span class="name-1">أُبَيِّ بن كعب</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧٢٠٠<span class="dash">-</span></span> و<span class="name-1">جابر بن عبد الله</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧٢٠١<span class="dash">-</span></span> و<span class="name-1">أنس بن مالك</span> -من طريق قتادة- قالوا: بيعُ الأمةِ طلاقُها{37}. (٤/٣١٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧٢٠٢<span class="dash">-</span></span> عن <span class="name-1">علي بن أبي طالب</span> -من طريق إبراهيم- في قوله: <span class="qpc-hafs">﴿والمحصنات من النساء إلا ما ملكت أيمانكم﴾</span>، قال: المشركاتُ إذا سُبِين حَلَّت له{38}. (٤/٣١٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧٢٠٣<span class="dash">-</span></span> عن <span class="name-1">علي بن أبي طالب</span> -من طريق إبراهيم- في قوله: <span class="qpc-hafs">﴿والمحصنات من النساء إلا ما ملكت أيمانكم﴾</span>، قال: ذوات الأزواج من المشركين{39}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧٢٠٤<span class="dash">-</span></span> عن <span class="name-1">أبي سعيد الخُدْرِيِّ</span> -من طريق حبيب بن أبي ثابت- قال: كان النساء يأتيننا، ثم يُهاجِرُ أزواجُهُنَّ، فمُنِعْناهُنَّ بقوله: <span class="qpc-hafs">﴿والمحصنات من النساء﴾</span>{40}<span class=comment-ref>١٦٠٠</span>. (٤/٣٢٠)</p></p><p></div></p><p><div><span class=comment-ref>١٦٠٠</span> <span class="comment-type-4">علَّقَ</span> <u>ابنُ عطية</u> (٢/٥١٤) على قول أبي سعيد هذا بقوله: «هذا قولٌ يرجع إلى ما قد ذُكِر من الأقوال».</div></p><p><div></p><p><p><span class="item-no">١٧٢٠٥<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق سعيد بن جبير- في قوله: <span class="qpc-hafs">﴿والمحصنات من النساء إلا ما ملكت أيمانكم﴾</span>، قال: كُلُّ ذاتِ زوجٍ إتيانُها زِنا، إلا ما سَبَيْتَ{41}. (٤/٣١٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧٢٠٦<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق سعيد بن جبير- في قوله: <span class="qpc-hafs">﴿والمحصنات من النساء إلا ما ملكت أيمانكم﴾</span>، قال: هُنَّ السبايا اللاتي لَهُنَّ الأزواج، فلا بأس بمجامَعَتِهِنَّ إذا اسْتَبْرَأْنَ{42}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧٢٠٧<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي بن أبي طلحة- في الآية، يقول: كلُّ امرأة لها زوجٌ فهي عليكَ حرام، إلّا أمَةً ملكتَها ولها زوجٌ بأرض الحرب، فهي لك حلالٌ إذا اسْتَبْرَأْتَها{43}. (٤/٣١٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧٢٠٨<span class="dash">-</span></span> وعن <span class="name-2">مكحول الشامي</span> -من طريق عبد الكريم-، نحو ذلك{44}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧٢٠٩<span class="dash">-</span></span> وعن <span class="name-2">إبراهيم النخعي</span> -من طريق الصَّلْت بن بَهْرام-، نحوه{45}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧٢١٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق العوفي- <span class="qpc-hafs">﴿والمحصنات من النساء﴾</span>، يعني بذلك: ذوات الأزواج من النساء، لا يَحِلُّ نكاحُهُنَّ. يقول: لا تَخْلِب ولا تَعِدْ فَتَنشُزَ على بَعْلِها، وكُلُّ امرأةٍ لا تُنكَح إلا ببَيِّنةً ومهرٍ فهي من المحصنات التي حرَّم، <span class="qpc-hafs">﴿إلا ما ملكت أيمانكم﴾</span> يعني: التي أحَلَّ اللهُ مِن النساء، وهو ما أحَلَّ مِن حرائر النساء مثنى وثلاث ورباع{46}. (٤/٣٢١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧٢١١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عكرمة- <span class="qpc-hafs">﴿والمحصنات من النساء﴾</span>، قال: لا يحِلُّ له أن يتزوَّج فوقَ أربع، فما زاد فهو عليه حرامٌ كأُمِّه وأُختِه{47}. (٤/٣٢١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧٢١٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي بن أبي طلحة- في قوله: <span class="qpc-hafs">﴿إلا ما ملكت أيمانكم﴾</span>، قال: إلا الأربع اللاتي ينكحن بالبينة والمهر{48}. (٤/٣٢٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧٢١٣<span class="dash">-</span></span> عن ابن جريج، عن <span class="name-2">عطاء [بن أبي رباح]</span> في قوله: <span class="qpc-hafs">﴿والمحصنات من النساء إلا ما ملكت أيمانكم﴾</span> قال: الزنا،= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧٢١٤<span class="dash">-</span></span> وقال <span class="name-2">مجاهد</span>: هو الزنا،= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧٢١٥<span class="dash">-</span></span> وقال <span class="name-2">عكرمة</span>: هو الزنا،= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧٢١٦<span class="dash">-</span></span> وقال <span class="name-1">ابن عباس</span>: هو الزنا، <span class="qpc-hafs">﴿إلا ما ملكت أيمانكم﴾</span> ينزع الرجل وليدةَ امرأةَ عبده فيطؤها إن شاء، وقال غيره: سبايا العدوِّ يُوطَأْنَ إذا ما سُبِيَتْ أزواجُهُنَّ{49}. (٤/٣٢٢) (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧٢١٧<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عمير بن مريم- في قوله: <span class="qpc-hafs">﴿والمحصنات من النساء إلا ما ملكت أيمانكم﴾</span>، قال: هي حِلٌّ للرجل، إلا ما أنكَحَ مِمّا مَلَكَتْ يمينُه، فإنّها لا تَحِلُّ له{18}. (٤/٣٢٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧٢١٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عكرمة- قال: طلاق الأمة سِتٌّ{51}: بيعُها طلاقها، وعِتْقُها طلاقها، وهِبَتُها طلاقها، وبراءتها طلاقها، وطلاق زوجها طلاقُها{52}. (٤/٣١٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧٢١٩<span class="dash">-</span></span> عن عمرو بن مُرَّة، قال: قال رجل لسعيد بن جبير: أما رأيتَ <span class="name-1">عبد الله بن عباس</span> حين سُئِل عن هذه الآية: <span class="qpc-hafs">﴿والمحصنات من النساء﴾</span>؛ فلم يَقُل فيها شيئًا؟ فقال: كان لا يعلمُها{40}<span class=comment-ref>١٦٠١</span>. (٤/٣٢٢)</p></p><p></div></p><p><div><span class=comment-ref>١٦٠١</span> <span class="comment-type-4">علَّقَ</span> <u>ابن عطية</u> (٢/٥١٤) بقوله: «ولا أدري كيف نسب هذا القول إلى ابن عباس؟!».</div></p><p><div></p><p><p><span class="item-no">١٧٢٢٠<span class="dash">-</span></span> عن <span class="name-1">أنس بن مالك</span> -من طريق أبي مِجْلَز- قال في قوله: <span class="qpc-hafs">﴿والمحصنات﴾</span> ذوات الأزواج الحرائر، ثم قال: <span class="qpc-hafs">﴿إلا ما ملكت أيمانكم﴾</span> فإذا هو لا يرى بما مَلَك اليمين بأسًا أن ينزع الرجلُ الجاريةَ من عبده فيَطَأُها{54}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧٢٢١<span class="dash">-</span></span> عن <span class="name-2">عَبِيدَة السَّلْمانِيِّ</span> -من طريق ابن سيرين- قال: أحَلَّ اللهُ لك أربعًا في أول السورة، وحَرَّم نكاحَ كُلِّ مُحْصَنَةٍ بعد الأربع، إلا ما ملكت يمينك{55}. (٤/٣٢١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧٢٢٢<span class="dash">-</span></span> قال عبد الله بن وهب: وسمعتُ اللَّيْث بن سعد يُحَدِّث أنّ <span class="name-2">عمر بن عبد العزيز</span> قال في قول الله: <span class="qpc-hafs">﴿والمحصنات من النساء إلا ما ملكت أيمانكم كتاب الله عليكم﴾</span>، قال عمر: كتابٌ عليكم أحَلَّ لكم أربعًا، وما ملكت أيمانكم بعد الأربع الحرائرِ{56}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧٢٢٣<span class="dash">-</span></span> عن <span class="name-2">أبي العالية الرِّياحِيِّ</span> -من طريق أبي جعفر- قال: يقول: <span class="qpc-hafs">﴿فانكحوا ما طاب لكم من النساء مثنى وثلاث ورباع﴾</span>، ثُمَّ حَرَّم ما حَرَّم مِن النَّسَبِ والصِّهر، ثم قال: <span class="qpc-hafs">﴿والمحصنات من النساء إلا ما ملكت أيمانكم﴾</span>، فرجع إلى أول السورة إلى أربعٍ، فقال: هُنَّ حرامٌ أيضًا، إلّا لِمَن نَكَح بصَداقٍ، وبَيِّنَةٍ، وشهود{57}. (٤/٣٢١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧٢٢٤<span class="dash">-</span></span> عن <span class="name-2">سعيد بن المسيب</span> -من طريق مَعْمَر، عن الزهري- <span class="qpc-hafs">﴿والمحصنات من النساء﴾</span>، قال: هُنَّ ذوات الأزواج، حَرَّم اللهُ نِكاحَهُنَّ إلا ما ملكت يمينُك، فبيعُها طلاقُها{58}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧٢٢٥<span class="dash">-</span></span> قال <span class="name-2">الحسن البصري</span> -من طريق معمر-، مثل ذلك{58}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧٢٢٦<span class="dash">-</span></span> عن <span class="name-2">إبراهيم النخعي</span> -من طريق أبي معشر- قال: بيعُها طلاقُها. قال: فقيل لإبراهيم: فبيعُه؟ قال: ذلك ما لا نقول فيه شيئًا{36}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧٢٢٧<span class="dash">-</span></span> قال مالك بن أنس: وبلغني عن <span class="name-2">عمر بن عبد العزيز</span>: أنّه كتب إلى أبي بكر ابن حزمٍ يقول: تسألني عن الرجل يَجْمَعُ بين المرأةِ وابنتِها مِن مِلْك اليمين، فلا تُقِرَّنَّ ذلك لأحدٍ فعلَه؛ فقد نَزَلَ في القرآن النهيُ -يعني: عنه-، وإنّما اسْتَحَلَّ مِن ذلك مَنِ اسْتَحَلَّه لقول الله تبارك وتعالى: <span class="qpc-hafs">﴿إلا ما ملكت أيمانكم﴾</span>{61}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧٢٢٨<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جَبْر</span> -من طريق عبد الرحمن بن يحيى- قال: لو أعلم مَن يُفَسِّر لي هذه الآيةَ لَضَرَبْتُ إليه أكبادَ الإبل؛ قوله: <span class="qpc-hafs">﴿والمحصنات من النساء﴾</span> الآية{40}<span class=comment-ref>١٦٠٢</span>. (٤/٣٢٢)</p></p><p></div></p><p><div><span class=comment-ref>١٦٠٢</span> <span class="comment-type-4">علَّقَ</span> <u>ابنُ عطية</u> (٢/٥١٤ بتصرف) على قول مجاهد هذا بقوله: «لا أدري كيف انتهى مجاهد إلى هذا القول؟!».</div></p><p><div></p><p><p><span class="item-no">١٧٢٢٩<span class="dash">-</span></span> عن <span class="name-2">أبي قِلابة عبد الله بن زيد الجَرْمِيِّ</span> -من طريق خالد- في قوله: <span class="qpc-hafs">﴿والمحصنات من النساء إلا ما ملكت أيمانكم﴾</span>، قال: ما سَبَيْتُم من النساء، إذا سُبِيَتِ المرأةِ ولها زوجٌ في قومها فلا بأس أن يَطَأَها{63}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧٢٣٠<span class="dash">-</span></span> عن أبي السوداء، قال: سألتُ <span class="name-2">عكرمة مولى ابن عباس</span> عن هذه الآية: <span class="qpc-hafs">﴿والمحصنات من النساء﴾</span>. فقال: لا أدري.= (٤/٣٢٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧٢٣١<span class="dash">-</span></span> وسألتُ <span class="name-2">عامر الشعبي</span>، فقال: هي كُلُّ ذاتِ زَوْجٍ{64}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧٢٣٢<span class="dash">-</span></span> عن <span class="name-2">طاووس بن كَيْسان</span> -من طريق ابنه- في قوله: <span class="qpc-hafs">﴿إلا ما ملكت يمينك﴾</span>، قال: فزوجُك مِمّا مَلَكَتْ يمينُك. يقول: حرَّم اللهُ الزِّنا، لا يَحِلُّ لك أن تَطَأَ امرأةً إلا ما ملكت يمينك{65}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧٢٣٣<span class="dash">-</span></span> عن <span class="name-2">أبي مِجْلَز لاحِق بن حميد</span> -من طريق أيوب بن أبي العوجاء- في قوله: <span class="qpc-hafs">﴿والمحصنات من النساء إلا ما ملكت أيمانكم﴾</span>، قال: نساء أهل الكتاب{66}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧٢٣٤<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق قتادة- في قوله: <span class="qpc-hafs">﴿والمحصنات من النساء إلا ما ملكت أيمانكم﴾</span>، قال: إذا كان لها زوجٌ فبَيْعُها طلاقُها{37}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧٢٣٥<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق عوف- قال: بيعُ الأَمَةِ طلاقُها، وبيعُه طلاقُها{52}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧٢٣٦<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق أشْعَث- قال: كُلُّ ذاتِ زوجٍ عليك حرامٌ، إلا ما ملكت يمينك مِن السبايا. يريد: <span class="qpc-hafs">﴿والمحصنات من النساء﴾</span>{69}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧٢٣٧<span class="dash">-</span></span> عن سفيان بن حسين، قال: سمعت رجلًا يسأل الحسن -و<span class="name-2">الفرزدقُ</span> عنده- عن قول الله -تبارك وتعالى-: <span class="qpc-hafs">﴿والمحصنات من النساء إلا ما ملكت أيمانكم﴾</span>. فقال الفرزدقُ: تسألُ أبا سعيد وقد قلتُ بذلك شعرًا؟! فقال له الحسنُ: وما قُلْتَ؟ قال: قُلْتُ:</p><p>وذاتِ خليل أنكَحَتْها رماحُنا حلالًا فمَن يبني بها لم يُطَلِّقِ= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧٢٣٨<span class="dash">-</span></span> قال: فتبسَّمَ <span class="name-2">الحسنُ [البصري]</span>، ولم يَرُدَّ عليه ما قال، قال: يَحِلُّ لكم السبايا أن تَطَؤُوهُنَّ بمِلْك اليمين، مِن غير أن يُطَلِّقَهُنَّ أزواجُهُنَّ{70}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧٢٣٩<span class="dash">-</span></span> قال <span class="name-2">عطاء [بن أبي رباح]</span> -من طريق ابن جُرَيْج-: أراد بقوله: <span class="qpc-hafs">﴿إلا ما ملكت أيمانكم﴾</span> أن تكون أمَتُه في نكاحِ عبدِه، فيجوز أن ينزِعها منه{71}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧٢٤٠<span class="dash">-</span></span> عن <span class="name-2">مكحول الشامي</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿والمحصنات من النساء إلا ما ملكت أيمانكم﴾</span>، قال: السَّبايا{63}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧٢٤١<span class="dash">-</span></span> عن <span class="name-2">مكحول الشامي</span> -من طريق ابن جُرَيْج- قال: أربع{73}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧٢٤٢<span class="dash">-</span></span> عن <span class="name-2">محمد بن كعب القرظي</span> -من طريق أبي صَخْر- أنّه قال: السَّبِيَّةُ لها زوجٌ بأرضها، يسبيها المسلمون، فتباع في الغنائم، فتُشْتَرى ولها زوجٌ؛ فهي حلالٌ{74}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧٢٤٣<span class="dash">-</span></span> وعن <span class="name-2">مكحول الشامي</span>، نحو ذلك{75}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧٢٤٤<span class="dash">-</span></span> عن <span class="name-2">محمد ابن شهاب الزهري</span> -من طريق عُقيل- أنّه سُئِل عن قوله: <span class="qpc-hafs">﴿والمحصنات من النساء﴾</span>. قال: نرى أنّه حَرَّم في هذه الآية المحصناتِ مِن النساء ذوات الأزواج أن ينكحن مع أزواجهن، والمحصناتِ العفائف، ولا يحللن إلا بنكاحٍ أو ملك يمين. والإحصانُ إحصانان: إحصانُ تزويج، وإحصان عفافٍ في الحرائر والمملوكات، كلُّ ذلك حَرَّم اللهُ إلا بنكاح، أو مِلْكِ يمين{33}. (٤/٣٢٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧٢٤٥<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿والمحصنات من النساء إلا ما ملكت أيمانكم﴾</span>، قال: كُلُّ امرأةٍ مُحْصَنَةٍ لها زوجٌ فهي مُحَرَّمَةٌ، إلا ما ملكت يمينك مِن السَّبْيِ وهي محصنة لها زوج؛ فلا تحرم عليك به.= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧٢٤٦<span class="dash">-</span></span> قال: كان <span class="name-2">أبي</span> يقول ذلك{63}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧٢٤٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿والمحصنات من النساء﴾</span>، يعني: وكل امرأة أيضًا فنكاحها حرامٌ مع ما حرم من النسب والصِّهْر. ثم استثنى من المحصنات، فقال سبحانه: <span class="qpc-hafs">﴿إلا ما ملكت أيمانكم﴾</span> من الحرائر مثنى وثلاث ورباع{78}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧٢٤٨<span class="dash">-</span></span> قال <span class="name-3">الليث [بن سعد]</span>: ويقول آخرون من أهل العلم: <span class="qpc-hafs">﴿والمحصنات من النساء إلا ما ملكت أيمانكم﴾</span> السبايا اللاتي لَهُنَّ أزواج في أرض الشرك، ولا بأس أن يُوطَأْنَ في الإسلام، وإن كان لَهُنَّ أزواجٌ في الشِّرك لم يُفارِقُوهُنَّ{79}<span class=comment-ref>١٦٠٣</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>١٦٠٣</span> أصل الإحصان: المنع والحِفظ، وتستعمله العرب في أربعة أشياء: في الزواج، وفي الحرية، وفي الإسلام، وفي العفة. وعلى ذلك تصرفت اللفظة في كتاب الله ﷿. وبناء على الاستعمال اللغوي اختلف المفسِّرون في المراد بالمحصنات في قوله تعالى: <span class="qpc-hafs">﴿والمحصنات من النساء إلا ما ملكت أيمانكم﴾</span> على ثمانية أقوال: <b>أولها</b>: أنّ المراد بهن: ذوات الأزواج. ومعنى الآية: وذوات الأزواج حرام على غير أزواجهن، إلا ما ملكت أيمانكم بالسبي. وهذا قول عليٍّ، وابن عباس، وأبي قلابة، والزهري، ومكحول، وابن زيد. <b>وثانيها</b>: أنّ المراد بهن: ذوات الأزواج. ومعنى الآية: وذوات الأزواج حرامٌ على غير أزواجهن، إلا ما ملكت أيمانكم من الإماء بالشراء؛ فبيعُ الأَمَةِ طلاقُها. وهذا قول ابن مسعود، وأُبَيِّ بن كعب، وجابر بن عبد الله، وأنس بن مالك، وسعيد بن المسيب، والحسن، وابن عباس من طريق عكرمة. <b>وثالثها</b>: أنّ المراد بهن: ذوات الأزواج. غير أنّ الذي حرّم منهن في هذه الآية الزِّنا بِهِنَّ، ولا يُبحْنَ إلا بخُلُوٍّ من زوج أو بملك يمين. وهذا قول ابن عباس من طريق عليّ بن أبي طلحة، ومجاهد من طريق ابن أبي نجيح. <b>ورابعها</b>: أنّ المراد بهن: ذوات الأزواج. ونزلت هذه الآية في نساءٍ كُنَّ هاجَرن إلى رسول الله ﷺ ولهن أزواج، فتزوجهن المسلمون، ثم قدم أزواجهن مهاجرين، فنهي المسلمون عن نكاحهن. وهذا قول أبي سعيد الخدريِّ. <b>وخامسها</b>: أنّ المراد بهن: العفائف. ومعنى الآية: والعفائف من النساء حرام عليكم أيضًا، إلا ما ملكت أيمانكم بالنكاح أو ملك اليمين. وهذا قول عمر، وسعيد بن جبير، وأبي العالية، وعبيدة السلمانيِّ، وعطاء، والسديِّ. <b>وسادسها</b>: أنّ المراد بهن: العفائف، وذوات الأزواج. ومعنى الآية: والعفائف وذوات الأزواج حرامٌ كلٌّ من الصنفين، إلا ما ملكت أيمانكم بنكاح، أو ملك يمين. وهذا قول الزهريّ. <b>وسابعها</b>: أنّ المراد بهن: الحرائر. وهذا قول عَزْرة. و<b>ثامنها</b>: أنّ المراد بهن: نساء أهل الكتاب. وهذا قول أبي مجلز.</p><p>و<span class="comment-type-4">ذَهَبَ</span> <u>ابنُ كثير</u> (٣/٤٢٤) إلى القول الأول <span class="mustanad">مستندًا إلى سبب النزول</span>، حيث بَيَّنَ أنّ معناها: «وحرم عليكم الأجنبيات المحصنات، وهنّ المزوَّجات، <span class="qpc-hafs">﴿إلا ما ملكت أيمانكم﴾</span> يعني: إلا ما ملكتموهن بالسبي؛ فإنه يحل لكم وطؤهن إذا استبرأتموهن؛ فإنّ الآية نزلت في ذلك».</p><p>و<span class="comment-type-4">ذَهَبَ</span> <u>ابنُ عطية</u> (٢/٥١٤) إلى القول السادس، وهو أنّ المراد بهن: العفائف وذوات الأزواج، <span class="mustanad">مستندًا إلى العمومِ</span>، حيث قال: «هذا قول حسنٌ، عمَّمَ لفظَ الإحصان، ولفظ ملك اليمين».</p><p>و<span class="comment-type-3">رجَّحَ</span> <u>ابنُ جرير</u> (٦/٥٧٥-٥٧٦) أنّ الآية تَعُمُّ كُلَّ ما ذُكِرَ <span class="mustanad">مستندًا إلى العمومِ، وعدم المخصّص</span>.</p><p>و<span class="comment-type-2">انتَقَدَ</span> <u>ابنُ جرير</u> (٦/٥٧٥-٥٧٦ بتصرف) القولَ بأنّ بيع الأمة طلاقها، الذي يفيده القول الثاني؛ <span class="mustanad">استنادًا إلى السُّنَّة، والدلالة العقلية</span>، فقال: «وأما الأَمَة التي لها زوجٌ، فإنها لا تَحِلُّ لمالكها إلا بعد طلاق زوجها إياها، أو وفاته وانقضاء عدتها منه. فأمّا بيعُ سيِّدها إيّاها فغيرُ موجِبٍ بينها وبين زوجها فِراقًا ولا تحليلًا لمشتريها؛ لِصِحَّة الخبر عن رسول الله ﷺ: أنه خَيَّرَ بَرِيرة إذ أعتقتها عائشةُ بين المُقام مع زوجها الذي كان سادَتُها زوَّجوها منه في حال رِقِّها، وبين فراقه، ولو كان عِتقُها وزوالُ مِلك عائشة إيّاها لها طلاقًا لم يكن لتخيير النبيِّ ﷺ إياها بين المقام مع زوجها والفراق معنًى».</p><p>وزاد <u>ابنُ القيم</u> (١/٢٧٠-٢٧١): «أنّه لو كان صحيحًا لكان وطؤها حلالًا لسيِّدها إذا زوَّجها؛ لأنها ملك يمينه، فكما اجتمع مِلك سيدها لها وحِلُّها للزوج فكذلك يجتمع مِلْكُ مشتريها لها وحِلُّها للزوج، وتناول اللفظ لهما واحدٌ ما دامت مُزَوَّجة. الثاني: أنّ المشتريَ خليفةُ البائع، فانتقل إليه بعقد الشراء ما كان يملكه بائعُها، وهو كان يملك رقبتها مسلوبةً مَنفَعَة البضع».</div></p><p><h3><span class="qpc-hafs">﴿كِتَـٰبَ ٱللَّهِ عَلَیۡكُمۡۚ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">١٧٢٤٩<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عكرمة- <span class="qpc-hafs">﴿كتاب الله عليكم﴾</span> قال: هذا النَسَب، <span class="qpc-hafs">﴿وأحل لكم ما وراء ذلكم﴾</span> قال: ما وراء هذا النسب{80}. (٤/٣٢٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧٢٥٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق ابن جُرَيج- <span class="qpc-hafs">﴿كتاب الله عليكم﴾</span>، قال: واحدة إلى أربع في النكاح{81}. (٤/٣٢٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧٢٥١<span class="dash">-</span></span> عن <span class="name-2">عَبِيدة السَّلْمانِيِّ</span> -من طريق ابن سيرين- في قوله: <span class="qpc-hafs">﴿كتاب الله عليكم﴾</span>، قال: الأربع{82}<span class=comment-ref>١٦٠٤</span>. (٤/٣٢٤)</p></p><p></div></p><p><div><span class=comment-ref>١٦٠٤</span> <span class="comment-type-4">علَّقَ</span> <u>ابنُ عطية</u> (٢/٥١٥-٥١٦) على قول عبيدة وما ماثله بقوله: «في هذا بُعْدٌ، والأظهر أنّ قوله: <span class="qpc-hafs">﴿كتاب الله عليكم﴾</span> إنّما هو إشارةٌ إلى التحريمِ الحاجزِ بين الناس وبين ما كانت العرب تفعله».</div></p><p><div></p><p><p><span class="item-no">١٧٢٥٢<span class="dash">-</span></span> عن <span class="name-1">عمر بن الخطاب</span> -من طريق عَبيدة-، مثله{83}. (٤/٣٢٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧٢٥٣<span class="dash">-</span></span> وعن <span class="name-2">سعيد بن جبير</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧٢٥٤<span class="dash">-</span></span> و<span class="name-2">الحسن البصري</span>، نحو ذلك{84}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧٢٥٥<span class="dash">-</span></span> عن الليث بن سعد، أنّ <span class="name-2">عمر بن عبد العزيز</span> في قول الله: <span class="qpc-hafs">﴿والمحصنات من النساء إلا ما ملكت أيمانكم كتاب الله عليكم﴾</span> قال: كتابٌ عليكم أحلَّ لكم أربعًا، وما ملكت أيمانكم بعد الأربع الحرائر{85}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧٢٥٦<span class="dash">-</span></span> عن <span class="name-2">إبراهيم النخعي</span> -من طريق منصور- <span class="qpc-hafs">﴿كتاب الله عليكم﴾</span>، قال: ما حرم عليكم{86}. (٤/٣٢٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧٢٥٧<span class="dash">-</span></span> عن ابن جُرَيْج، قال: سألتُ <b>⟨عطاء</b> [بن أبي رباح]⟩{ت} عنها. فقال: <span class="qpc-hafs">﴿كتاب الله عليكم﴾</span>، قال: هو الذي كتب عليكم الأربع أن لا تزيدوا{87}. (٤/٣٢١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧٢٥٨<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- <span class="qpc-hafs">﴿كتاب الله عليكم﴾</span>، قال: الأربع{88}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧٢٥٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿كتاب الله عليكم﴾</span>، يعني: فريضة الله لكم بتحليل أربع{78}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧٢٦٠<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿كتاب الله عليكم﴾</span>، قال: هذا أمرُ الله عليكم. قال: يُرِيد ما حَرَّم عليهم مِن هؤلاء، وما أحَلَّ لهم. وقرأ: <span class="qpc-hafs">﴿وأحل لكم ما وراء ذلكم أن تبتغوا بأموالكم﴾</span> إلى آخر الآية، قال: <span class="qpc-hafs">﴿كتاب الله عليكم﴾</span> الذي كتبه، وأمره الذي أمركم به. <span class="qpc-hafs">﴿كتاب الله عليكم﴾</span>: أمر الله{90}<span class=comment-ref>١٦٠٥</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>١٦٠٥</span> قال <u>ابنُ جرير</u> (٦/٥٧٨-٥٧٩) <span class="comment-type-3">مُرَجِّحًا</span> في معنى قوله تعالى: <span class="qpc-hafs">﴿كتاب الله عليكم﴾</span>: «يعني -تعالى ذِكْرُه-: كتابًا من الله عليكم. فأخرج الكتابَ مَصْدَرًا مِن غير لفظه». <span class="mustanad">واستند في ذلك إلى آثار السلف والسياق</span>، وقال: «وإنّما جاز ذلك لأنّ قوله تعالى: <span class="qpc-hafs">﴿حرِّمت عليكم أمهاتكم﴾</span> إلى قوله: <span class="qpc-hafs">﴿كتابَ الله عليكم﴾</span> بمعنى: كَتب اللهُ تحريم ما حرَّم من ذلك، وتحليلَ ما حَلَّل مِن ذلك عليكم كتابًا».</p><p>وبنحوه قال <u>ابنُ تيمية</u> (٢/٢٢٨)، و<u>ابنُ كثير</u> (٣/٤٢٧).</div></p><p><h3><span class="qpc-hafs">﴿وَأُحِلَّ لَكُم مَّا وَرَاۤءَ ذَ ٰ⁠لِكُمۡ﴾</span> - قراءات</h3></p><p><div></p><p><p><span class="item-no">١٧٢٦١<span class="dash">-</span></span> عن الأعمش، في قراءة <span class="name-1">عبد الله بن مسعود</span>: (كِتابَ اللهِ عَلَيْكُمْ أُحِلَّ لَكُمْ) بغير واو{91}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧٢٦٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، أنّه قرأ: <span class="qpc-hafs">﴿وأُحِلَّ لَكُمْ﴾</span> بضم الألف وكسر الحاء{92}<span class=comment-ref>١٦٠٦</span>. (٤/٣٢٥)</p></p><p></div></p><p><div><span class=comment-ref>١٦٠٦</span> <span class="comment-type-4">علَّقَ</span> <u>ابنُ عطية</u> (٢/٥١٦) على قراءة <span class="qpc-hafs">﴿وأُحِلَّ﴾</span> بضم الهمزة وكسر الحاء بقوله: «هذه مُناسِبة لقوله: <span class="qpc-hafs">﴿حُرِّمَتْ عَلَيْكُمْ﴾</span>».</p><p>وبنحو ذلك قال <u>ابنُ جرير</u> (٦/٥٨٣).</div></p><p><div></p><p><p><span class="item-no">١٧٢٦٣<span class="dash">-</span></span> عن <span class="name-2">عاصم بن أبي النجود</span> أنّه قرأ: <span class="qpc-hafs">﴿وأَحَلَّ لَكُم﴾</span> بنصب الألف{93}<span class=comment-ref>١٦٠٧</span>. (٤/٣٢٥)</p></p><p></div></p><p><div><span class=comment-ref>١٦٠٧</span> <span class="comment-type-4">علَّقَ</span> <u>ابنُ عطية</u> (٢/٥١٦) على قراءة <span class="qpc-hafs">﴿وأَحَلَّ لكم﴾</span> بفتح الألف والحاء بقوله: «هذه مُناسِبة لقوله: <span class="qpc-hafs">﴿كِتابَ اللَّهِ﴾</span>؛ إذ المعنى: كَتَبَ اللهُ ذلك كتابًا».</p><p>وبنحو ذلك قال <u>ابنُ جرير</u> (٦/٥٨٣)، ثم قال: «والذي نقول في ذلك أنهما قراءتان معروفتان مستفيضتان في قَرَأَة الإسلام، غير مختلفتي المعنى، فبأيَّ ذلك قرأ القارئُ فمصيبٌ الحقَّ».</div></p><p><h3><span class="qpc-hafs">﴿وَأُحِلَّ لَكُم مَّا وَرَاۤءَ ذَ ٰ⁠لِكُمۡ﴾</span> - تفسير الآية</h3></p><p><div></p><p><p><span class="item-no">١٧٢٦٤<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عكرمة- <span class="qpc-hafs">﴿كتاب الله عليكم﴾</span> قال: هذا النَسَب، <span class="qpc-hafs">﴿وأحل لكم ما وراء ذلكم﴾</span> قال: ما وراء هذا النسب{80}. (٤/٣٢٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧٢٦٥<span class="dash">-</span></span> عن <span class="name-2">عَبيدة السلماني</span> -من طريق ابن سيرين- <span class="qpc-hafs">﴿وأحل لكم ما وراء ذلكم﴾</span>، قال: مِن الإماء. يعني: السَّرارِي{95}. (٤/٣٢٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧٢٦٦<span class="dash">-</span></span> عن <span class="name-2">عَبيدة السلماني</span> -من طريق ابن سيرين- <span class="qpc-hafs">﴿وأحل لكم ما وراء ذلكم﴾</span>، يعني: ما دون الأربع{96}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧٢٦٧<span class="dash">-</span></span> عن <span class="name-2">أبي مالك غَزْوان الغِفارِيِّ</span> -من طريق السُّدِّيِّ- قال: <span class="qpc-hafs">﴿وراء﴾</span>: أمام، في القرآن كله، غير حرفين: <span class="qpc-hafs">﴿وأحل لكم ما وراء ذلكم﴾</span> يعني: سوى ذلكم، <span class="qpc-hafs">﴿فمن ابتغى وراء ذلك﴾</span> [المؤمنون:٧] يعني: سِوى ذلك{97}. (٤/٣٢٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧٢٦٨<span class="dash">-</span></span> عن <span class="name-2">عطاء [بن أبي رباح]</span> -من طريق ابن جُرَيْج- <span class="qpc-hafs">﴿وأحل لكم ما وراء ذلكم﴾</span>، قال: ما وراء ذات القرابة{96}. (٤/٣٢٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧٢٦٩<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دِعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿وأحل لكم ما وراء ذلكم﴾</span>، قال: ما مَلَكَتْ أيمانُكم{99}. (٤/٣٢٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧٢٧٠<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- <span class="qpc-hafs">﴿وأحل لكم ما وراء ذلكم﴾</span>، قال: ما دون الأربع{100}. (٤/٣٢٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧٢٧١<span class="dash">-</span></span> عن <span class="name-2">خُصيف بن عبد الرحمن</span> -من طريق محمد بن سلمة- في قوله: <span class="qpc-hafs">﴿وأحل لكم﴾</span>، يقول: التزويج{80}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧٢٧٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وأحل لكم ما وراء ذلكم﴾</span>، يعني: ما وراء الأربع{102}<span class=comment-ref>١٦٠٨</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>١٦٠٨</span> اختُلِف في معنى قوله تعالى: <span class="qpc-hafs">﴿وأُحِلَّ لَكُم مّا ورَآءَ ذَلِكُمْ﴾</span> على ثلاثة أقوال: <b>أولها</b>: أنّ المعنى: أُحِلَّ لكم ما دون الخمس، أن تبتغوا بأموالكم على وجه النكاح. وهذا قول السديّ، وعبيدة. <b>وثانيها</b>: أنّ المعنى: أُحِلَّ لكم ما وراء مَن سمّي لكم تحريمه مِن أقاربكم. وهذا قول عطاء. <b>وثالثها</b>: أنّ المعنى: أُحِلَّ لكم ما وراء ذلكم مما ملكت أيمانكم. وهذا قول قتادة.</p><p>و<span class="comment-type-3">رجَّحَ</span> <u>ابنُ جرير</u> (٦/٥٨٢) أنّ الآية تشمل جميع تلك المعاني <span class="mustanad">استنادًا إلى دلالة السياق، والعموم</span>، فقال: «أوْلى الأقوال في ذلك بالصواب ما نحن مبيِّنوه، وهو أنّ الله -جل ثناؤه- بيَّن لعباده المحرَّماتِ بالنسب والصهر، ثُمَّ المحرمات من المحصنات من النساء، ثم أخبرهم -جلَّ ثناؤه- أنّه قد أحلَّ لهم ما عدا هؤلاء المحرَّمات المبيَّنات في هاتين الآيتين أن نَبْتغيه بأموالنا نكاحًا وملك يمين، لا سفاحًا. فإن قال قائل: عرفنا المحلَّلات اللواتي هُنَّ وراء المحرَّمات بالأنساب والأصهار، فما المحلَّلات من المحصَنات والمحرمات منهن؟ قيل: هو ما دون الخمس مِن واحدة إلى أربع -على ما ذكرنا عن عبيدة والسدي- من الحرائر، فأما ما عدا ذوات الأزواج فغيرُ عددٍ محصورٍ بملك اليمين. وإنما قلنا: إنّ ذلك كذلك لأنّ قوله: <span class="qpc-hafs">﴿وأحل لكم ما وراء ذلكم﴾</span> عامٌّ في كل مُحَلَّل لنا مِن النساء أن نبتغيها بأموالنا. فليس توجيه معنى ذلك إلى بعضٍ مِنهُنَّ بأولى مِن بعض، إلا أن تقوم بأن ذلك كذلك حجَّة يجب التسليم لها، ولا حُجة بأن ذلك كذلك».</p><p>و<span class="comment-type-4">ذَهَبَ</span>إلى ذلك أيضًا <u>ابن عطية</u> (٢/٥١٦).</p><p>و<span class="comment-type-4">ذَهَبَ</span> <u>ابنُ كثير</u> (٣/٤٢٧) إلى القول الثاني، و<span class="comment-type-2">اسْتَدْرَكَ</span> على القول الأول بقوله: «هذا بعيد، والصحيح قول عطاء».</div></p><p><h3><span class="qpc-hafs">﴿أَن تَبۡتَغُوا۟ بِأَمۡوَ ٰ⁠لِكُم مُّحۡصِنِینَ غَیۡرَ مُسَـٰفِحِینَۚ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">١٧٢٧٣<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق أبي السمح مولى بني هاشم، عن رجل- أنّه سُئِل عن السفاح. قال: الزِّنا{95}. (٤/٣٢٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧٢٧٤<span class="dash">-</span></span> وعن <span class="name-2">إسماعيل السُّدِّيّ</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧٢٧٥<span class="dash">-</span></span> و<span class="name-3">مقاتل بن حيان</span>، نحو ذلك{104}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧٢٧٦<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي بن أبي طلحة- قوله: <span class="qpc-hafs">﴿أن تبتغوا﴾</span>، قال: في الشِّراء والبيع{95}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧٢٧٧<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿محصنين﴾</span> قال: متناكحين، <span class="qpc-hafs">﴿غير مسافحين﴾</span> قال: غير زانين بكل زانية{106}. (٤/٣٢٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧٢٧٨<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق سليمان بن المغيرة- أنّه سُئِل: ما المُسافِحَة؟ قال: هي التي لا يزني إليها رجلٌ بعينه إلا تَبِعَتْه{107}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧٢٧٩<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- <span class="qpc-hafs">﴿محصنين غير مسافحين﴾</span>، يقول: محصنين غير زناة{108}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧٢٨٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿أن تبتغوا بأموالكم محصنين﴾</span> لفروجهن، <span class="qpc-hafs">﴿غير مسافحين﴾</span> بالزِّنا علانِيَةً{109}<span class=comment-ref>١٦٠٩</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>١٦٠٩</span> قال <u>ابنُ جرير</u> (٦/٥٨٤) مُبَيِّنًا معنى الآية: «يعني بقوله -جل ثناؤه-: <span class="qpc-hafs">﴿محصنين﴾</span>: أعِفّاء بابتغائكم ما وراء ما حُرِّم عليكم من النساء بأموالكم، <span class="qpc-hafs">﴿غير مسافحين﴾</span> يقول: غيرَ مُزانِينَ». <span class="mustanad">واستند في ذلك إلى أقوال السلف</span>.</p><p>وبنحوه قال <u>ابنُ عطية</u> (٢/٥١٦).</div></p><p><div></p><p><p><span class="item-no">١٧٢٨١<span class="dash">-</span></span> عن <span class="name-3">مقاتل بن حيان</span> -من طريق بُكَير بن معروف- قوله: <span class="qpc-hafs">﴿محصنين﴾</span>، قال: لفروجهن{95}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿فَمَا ٱسۡتَمۡتَعۡتُم بِهِۦ مِنۡهُنَّ فَـَٔاتُوهُنَّ أُجُورَهُنَّ فَرِیضَةࣰۚ﴾</span> - قراءات</h3></p><p><div></p><p><p><span class="item-no">١٧٢٨٢<span class="dash">-</span></span> عن سعيد بن جبير، قال: في قراءة <span class="name-1">أُبَيِّ بن كعب</span>: (فَما اسْتَمْتَعْتُم بِهِ مِنهُنَّ إلى أجَلٍ مُّسَمًّى){111}. (٤/٣٢٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧٢٨٣<span class="dash">-</span></span> عن قتادة، قال: في قراءة <span class="name-1">أُبَيِّ بن كعب</span>: (فَما اسْتَمْتَعْتُم بِهِ مِنهُنَّ إلى أجَلٍ مُّسَمًّى){112}. (٤/٣٢٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧٢٨٤<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطاء- أنّه سمعه يقرؤها: (فَما اسْتَمْتَعْتُم بِهِ مِنهُنَّ إلىَ أجَلٍ مُسَمًّى فَآتُوهُنَّ أُجُورَهُنَّ).= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧٢٨٥<span class="dash">-</span></span> وقال ابنُ عباس: في حرف <span class="name-1">أُبَيٍّ</span>: (إلى أجَلٍ مُّسَمًّى){113}. (٤/٣٢٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧٢٨٦<span class="dash">-</span></span> عن أبي نَضْرَة: أنّه قرأ على <span class="name-1">ابن عباس</span>: <span class="qpc-hafs">﴿فَما اسْتَمْتَعْتُمْ بِهِ مِنهُنَّ فَآتُوهُنَّ أُجُورَهُنَّ فَرِيضَةً﴾</span> فقال ابنُ عباس: (فَما اسْتَمْتَعْتُم بِهِ مِنهُنَّ إلى أجَلٍ مُّسَمًّى). فقلتُ: ما نقرؤها كذلك. فقال ابنُ عباس: واللهِ، لَأنزلها اللهُ كذلك{114}. (٤/٣٢٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧٢٨٧<span class="dash">-</span></span> عن حبيب بن أبي ثابت، عن أبيه -من طريق يحيى بن عيسى، عن نصير بن أبي الأشعث- قال: أعطاني ابنُ عبّاس مصحفًا، فقال: هذا على قراءة <span class="name-1">أُبَيٍّ</span>. قال يحيى: فرأيتُ المصحف عند نصيرٍ فيه: (فَما اسْتَمْتَعْتُم بِهِ مِنهُنَّ إلى أجَلٍ مُّسَمًّى){115}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧٢٨٨<span class="dash">-</span></span> عن عمرو بن مُرَّة: أنّه سمع <span class="name-2">سعيد بن جبير</span> يقرأ: (فَما اسْتَمْتَعْتُم بِهِ مِنهُنَّ إلى أجَلٍ مُّسَمًّى){115}<span class=comment-ref>١٦١٠</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>١٦١٠</span> <span class="comment-type-2">انتَقَدَ</span> <u>ابنُ جرير</u> (٦/٥٨٩) هذه القراءة <span class="mustanad">لمخالفتها مصاحف المسلمين</span>، فقال: «أمّا ما رُوِي عن أبي بن كعب وابن عباس مِن قراءتهما: (فَما اسْتَمْتَعْتُم بِهِ مِنهُنَّ إلى أجَلٍ مُّسَمًّى) فقِراءةٌ بخلاف ما جاءت به مصاحفُ المسلمين، وغيرُ جائز لأحد أن يُلْحِق في كتاب الله تعالى شيئًا لم يأتِ به الخبرُ القاطِعُ العذرَ عَمَّن لا يجوز خلافُه».</p><p>وبنحو ذلك قال <u>ابنُ تيمية</u> (٢/٢٢٧)، وزاد: «هذا الحرفُ -إن كان نزل- فلا ريب أنه ليس ثابتًا مِن القراءة المشهورة، فيكون منسوخًا، ويكون نزولُه لَمّا كانت المتعةُ مباحةً، فلمّا حُرِّمت نُسِخ هذا الحرف، ويكون الأمرُ بالإيتاء في الوقت تنبيهًا على الإيتاء في النكاح المطلق. وغاية ما يقال: إنهما قراءتان، وكلاهما حقٌّ. والأمر بالإيتاء في الاستمتاع إلى أجل مسمى واجب إذا كان ذلك حلالًا، وإنما يكون ذلك إذا كان الاستمتاع إلى أجل مسمى حلالًا، وهذا كان في أول الإسلام، فليس في الآية ما يدلُّ على أن الاستمتاع بها إلى أجل مسمى حلال؛ فإنه لم يقل: وأُحِلَّ لكم أن تستمتعوا بهن إلى أجل مسمى. بل قال: <span class="qpc-hafs">﴿فما استمتعتم به منهن فآتوهن أجورهن﴾</span>. فهذا يتناول ما وقع مِن الاستمتاع: سواء كان حلالًا، أو كان في وطء شبهة، ولهذا يجب المهرُ في النكاح الفاسد بالسُّنَّة والاتفاق. والمتمتع إذا اعتقد حِلَّ المتعة وفعلها فعليه المهر، وأمّا الاستمتاع المحرم فلم تتناوله الآية؛ فإنّه لو استمتع بالمرأة من غير عقد مع مطاوعتها لكان زنا، ولا مهر فيه. وإن كانت مستكرهة ففيه نزاع مشهور».</div></p><p><h3><span class="qpc-hafs">﴿فَمَا ٱسۡتَمۡتَعۡتُم بِهِۦ مِنۡهُنَّ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">١٧٢٨٩<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي بن أبي طلحة- في قوله: <span class="qpc-hafs">﴿فما استمتعتم به منهن فآتوهن أجورهن فريضة﴾</span>، قال: والاستمتاعُ هو النكاحُ{117}. (٤/٣٢٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧٢٩٠<span class="dash">-</span></span> وعن <span class="name-2">محمد ابن شهاب الزهري</span>، نحو ذلك{118}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧٢٩١<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نَجِيح- <span class="qpc-hafs">﴿فما استمتعتم به منهن﴾</span>، قال: يعني: نكاح المتعة{119}. (٤/٣٢٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧٢٩٢<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- <span class="qpc-hafs">﴿فما استمتعتم به منهن﴾</span>، قال: النكاح{120}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧٢٩٣<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق مَعْمَر- في قوله: <span class="qpc-hafs">﴿فما استمتعتم به منهن﴾</span>، قال: هو النكاح{121}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧٢٩٤<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- في قوله: (فَما اسْتَمْتَعْتُم بِهِ مِنهُنَّ إلى أجَلٍ مُّسَمًّى فَآتُوهُنَّ أُجُورَهُنَّ فَرِيضَةً ولا جُناحَ عَلَيْكُمْ فِيما تَراضَيْتُم بِهِ مِن بَعْدِ الفَرِيضَةِ)، قال: فهذه المتعة؛ الرجل ينكح المرأةَ بشرطٍ إلى أجل مُسَمًّى، ويشهد شاهدين، وينكح بإذن وليها، وإذا انقضت المُدَّةُ فليس له عليها سبيل، وهي منه بريَّة، وعليها أن تستبرِئ ما في رحمها، وليس بينهما ميراث، ليس يرِث واحدٌ منهما صاحبه{122}. (٤/٣٢٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧٢٩٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثُمَّ ذكر المتعة، فقال: <span class="qpc-hafs">﴿فما استمتعتم به منهن﴾</span> إلى أجل مسمى{109}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧٢٩٦<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهْب- في قوله: <span class="qpc-hafs">﴿فما استمتعتم به منهن فآتوهن أجورهن فريضة﴾</span> الآية، قال: والاستمتاعُ هو النِّكاحُ ههنا إذا دخل بها{124}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧٢٩٧<span class="dash">-</span></span> عن <span class="name-3">سفيان بن عيينة</span> -من طريق ابن أبي عمر- أنّه قال في قوله: <span class="qpc-hafs">﴿فما استمتعتم به منهن فآتوهن أجورهن﴾</span>، قال: هذا في المُتْعَةِ، كانوا قد أُمِروا بها قبل أن يُنْهَوْا عنها{107}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿فَمَا ٱسۡتَمۡتَعۡتُم بِهِۦ مِنۡهُنَّ﴾</span> - النسخ في الآية</h3></p><p><div></p><p><p><span class="item-no">١٧٢٩٨<span class="dash">-</span></span> عن عمر أنّه خطب، فقال: ما بالُ رجالٍ ينكحون هذه المُتْعَةَ وقد نهى رسول الله ﷺ عنها؟! لا أُوتى بأحدٍ نكحها إلا رَجَمْتُه{126}. (٤/٣٣٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧٢٩٩<span class="dash">-</span></span> عن علي بن أبي طالب، قال: نهى رسول الله ﷺ عن المُتْعَةِ، وإنّما كانت لِمَن لم يجِدْ، فلمّا نزل النِّكاحُ، والطلاق، والعِدَّة، والميراثُ بين الزوج والمرأة؛ نُسِخَت{127}. (٤/٣٣١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧٣٠٠<span class="dash">-</span></span> عن علي بن أبي طالب، أنّه قال لابن عباس: إنّك رجل تائِهٌ، إنّ رسول الله ﷺ نَهى عنِ المُتعة{128}. (٤/٣٣٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧٣٠١<span class="dash">-</span></span> عن علي بن أبي طالب: أنّ رسول الله ﷺ نهى عن متعة النساء يوم خيبر، وعن أكل لحوم الحُمُرِ الإنسِيَّة{129}. (٤/٣٣٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧٣٠٢<span class="dash">-</span></span> عن أبي ذَرٍّ، قال: إنّما أُحِلَّت لأصحابِ رسول الله ﷺ مُتعةُ النساء ثلاثةَ أيام، ثُمَّ نهى عنها رسول الله ﷺ{130}. (٤/٣٣٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧٣٠٣<span class="dash">-</span></span> عن سَبْرَة الجهني، قال: أذِنَ لنا رسول الله ﷺ عامَ فتح مكة في متعة النساء، فخرَجتُ أنا ورجلٌ مِن قومي، ولي عليه فَضْلٌ في الجَمال، وهو قريب مِن الدَّمامة، مع كل واحد منا بُردٌ، أما بُرْدِي فخَلِقٌ، وأما بُرْدُ ابنِ عمي فبُرْدٌ جديدٌ غَضٌّ، حتى إذا كُنّا بأعلى مكة تَلَقَّتْنا فتاةٌ مِثل البَكْرَة العَنَطْنَطَة{131}، فقلنا: هل لكِ أن يستمتع منكِ أحدُنا؟ قالت: وما تبذلان؟ فنشر كلُّ واحدٍ منا بُرْدَه، فجعلت تنظر إلى الرجلين، فإذا رآها صاحبي قال: إنّ بُردَ هذا خَلِقٌ مَحٌّ{132}، وبُردي جديد غَضٌّ. فتقول: وبرد هذا لا بأس به. ثم استمتعتُ منها، فلم تخرج حتى حرَّمها رسول الله ﷺ{133}. (٤/٣٣٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧٣٠٤<span class="dash">-</span></span> عن سَبْرَة، قال: رأيتُ رسول الله ﷺ قائمًا بين الركن والباب، وهو يقول: «<b>يا أيها الناس، إني كنت أذِنتُ لكم في الاستمتاع، ألا وإنّ الله حرَّمها إلى يوم القيامة، فمَن كان عنده مِنهُنَّ شيءٌ فليخل سبيلَها، ولا تأخذوا مما آتيتموهن شيئًا</b>»{134}. (٤/٣٣٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧٣٠٥<span class="dash">-</span></span> عن سلمة بن الأكوع، قال: رخَّص لنا رسول الله ﷺ في مُتعةِ النساء عام أوْطاسٍ ثلاثة أيام، ثم نهى عنها بعدها{135}. (٤/٣٣٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧٣٠٦<span class="dash">-</span></span> عن عروة بن الزبير: أنّ خَوْلَة بنت حكيم دخلت على <span class="name-1">عمر بن الخطاب</span>، فقالت: إنّ ربيعة بن أمية استمتع بامرأة مُوَلَّدةٍ، فحملت منه، فخرج عمر بن الخطاب يَجُرُّ رِداءَه فزِعًا، فقال: هذه المتعة، ولو كنت تقدمت فيها لرجمت{136}. (٤/٣٣٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧٣٠٧<span class="dash">-</span></span> عن سعيد بن المسيب، قال: نهى <span class="name-1">عمر</span> عن مُتعتَين: متعة النساء، ومتعة الحجِّ{137}. (٤/٣٣٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧٣٠٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن مسعود</span>، قال: كُنّا نغزو مع رسول الله ﷺ وليس معنا نساؤُنا، فقلنا: ألا نَسْتَخْصِي. فنهانا عن ذلك، ورَخَّص لنا أن نتزوج المرأةَ بالثوب إلى أجل. ثم قرأ عبد الله: <span class="qpc-hafs">﴿يا أيها الذين آمنوا لا تحرموا طيبات ما أحل الله لكم﴾</span> [المائدة:٨٧]{138}. (٤/٣٢٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧٣٠٩<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن مسعود</span> -من طريق الحكم، عن أصحاب عبد الله- قال: المتعة منسوخةٌ، نسخها الطلاقُ، والصَّدقةُ، والعِدَّةُ، والميراثُ{139}. (٤/٣٣١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧٣١٠<span class="dash">-</span></span> عن <span class="name-1">علي بن أبي طالب</span> -من طريق الحارث- قال: نَسَخَ رمضانُ كُلَّ صوم، ونسخت الزكاةُ كلَّ صدقة، ونسخ المتعةَ الطلاقُ والعِدَّةُ والميراثُ، ونسخت الضَحِيَّةُ كلَّ ذبيحة{140}. (٤/٣٣١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧٣١١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق محمد بن كعب القرظي- قال: كان متعة النساء في أول الإسلام،كان الرجل يَقْدُمُ البلدةَ ليس معه مَن يُصْلِحُ له ضَيْعَتَه، ولا يَحْفَظُ متاعَه؛ فيتزوج المرأةَ إلى قَدْرِ ما يرى أنه يَفرُغُ من حاجته، فتَنظُرُ له متاعَه، وتُصْلِح له ضيعتَه. وكان يقرأ: (فَما اسْتَمْتَعْتُم بِهِ مِنهُنَّ إلى أجَلٍ مُّسَمًّى) نسختها: <span class="qpc-hafs">﴿محصنين غير مسافحين﴾</span>. وكان الإحصانُ بيد الرجل؛ يُمسِك متى شاء، ويُطلِق متى شاء{141}. (٤/٣٢٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧٣١٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق محمد بن كعب- قال: كانت المتعة في أول الإسلام، وكانوا يقرأون هذه الآية: (فَما اسْتَمْتَعْتُم بِهِ مِنهُنَّ إلى أجَلٍ مُّسَمًّى) الآية. فكان الرجل يقدم البلدة، ليس له بها معرفة؛ فيتزوَّج بقدَرْ ما يرى أنه يفرغ مِن حاجته؛ لتحفظ متاعه، وتصلح له شأنه، حتى نزلت هذه الآية: <span class="qpc-hafs">﴿حرمت عليكم أمهاتكم﴾</span> إلى آخر الآية. فنسخ الأولى، فحُرِّمت المتعة، وتصديقُها من القرآن: <span class="qpc-hafs">﴿إلا على أزواجهم أو ما ملكت أيمانهم﴾</span> [المؤمنون:٦، المعارج:٣٠]. وما سوى هذا الفرج فهو حرامٌ{142}. (٤/٣٢٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧٣١٣<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطاء- في قوله: <span class="qpc-hafs">﴿فما استمتعتم به منهن فآتوهن أجورهن فريضة﴾</span>، قال: نسختها: <span class="qpc-hafs">﴿يا أيها النبي إذا طلقتم النساء فطلقوهن لعدتهن﴾</span> [الطلاق:١]، <span class="qpc-hafs">﴿والمطلقات يتربصن بأنفسهن ثلاثة قروء﴾</span> [البقرة:٢٢٨]، <span class="qpc-hafs">﴿واللائي يئسن من المحيض من نسائكم إن ارتبتم فعدتهن ثلاثة أشهر﴾</span> [الطلاق:٤]{143}. (٤/٣٣٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧٣١٤<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق أبي جمرة- أنّه سُئِل عن مُتعَةِ النساء. فرخَّص فيها، فقال له مولًى له: إنّما كان ذلك وفي النساء قِلَّة، والحال شديد. فقال: نعم{144}. (٤/٣٣١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧٣١٥<span class="dash">-</span></span> عن خالد بن المهاجر، قال: أرخص <span class="name-1">ابنُ عباس</span> للناس في المتعة، فقال له ابن عمرة الأنصاري: ما هذا يا ابن عباس؟! فقال ابن عباس: فُعِلَت مع إمام المتقين.= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧٣١٦<span class="dash">-</span></span> فقال <span class="name-1">ابن أبي عمرة</span>: اللهم غُفْرًا، إنما كانت المتعةُ رخصةً، كالضرورة إلى الميتة والدم ولحم الخنزير، ثم أحكم اللهُ الدِّينَ بعد{145}. (٤/٣٣٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧٣١٧<span class="dash">-</span></span> عن سعيد بن جبير، أنّه قال <span class="name-1">لابن عباس</span>: ماذا صنعتَ؟ ذهب الركاب بفُتْياك، وقالت فيه الشعراء. قال: وما قالوا؟ قلت: قالوا:</p><p>أقول للشيخ لما طال مجلسه يا صاحِ هل لك في فتيا ابن عباس</p><p>هل لك في رَخْصَة الأطراف آنِسَةٍ تكون مثواك حتى مصدر الناس</p><p>فقال: إنا لله وإنا إليه راجعون، لا واللهِ، ما بهذا أفتيتُ، ولا هذا أردتُ، ولا أحللتُها إلا للمضطر. وفي لفظ: ولا أحللتُ منها إلا ما أحلَّ اللهُ من الميتة والدم ولحم الخنزير{146}. (٤/٣٣٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧٣١٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطاء- قال: يرحم اللهُ <span class="name-1">عمرَ</span>، ما كانت المتعةُ إلا رحمةً من الله، رَحِم بها أُمَّةَ محمد ﷺ، ولولا نهيُه عنها ما احتاج إلى الزِّنا إلا شَقِيٌّ. قال: وهي التي في سورة النساء: <span class="qpc-hafs">﴿فما استمتعتم به منهن﴾</span> إلى كذا وكذا مِن الأجل على كذا وكذا. قال: وليس بينهما وِراثة، فإن بدا لهما أن يَتراضَيا بعد الأجل فنَعَم، وإن تفرقا فنَعَم، وليس بينهما نكاح. وأخبر أنّه سمع ابن عباس يراها الآن حلالًا{147}. (٤/٣٣٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧٣١٩<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عمار مولى الشريد- قال: سألتُ ابن عباس عن المتعة، أسفاح هي أم نكاح؟ فقال: لا سفاح، ولا نكاح. قلت: فما هي؟ قال: هي المتعة كما قال الله. قلت: هل لها مِن عِدَّة؟ قال: نعم، عِدَّتُها حَيْضَةٌ. قلت: هل يتوارثان؟ قال: لا{148}. (٤/٣٣٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧٣٢٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عمر</span> -من طريق نافع- أنّه سُئِل عن المتعة. فقال: حرام.= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧٣٢١<span class="dash">-</span></span> فقيل له: إنّ <span class="name-1">ابن عباس</span> يُفْتِي بها. = (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧٣٢٢<span class="dash">-</span></span> قال: فهلا تَزَمْزَم{149} بها في زمان <span class="name-1">عمر</span>{150}. (٤/٣٣٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧٣٢٣<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عمر</span> -من طريق نافع- قال: لا يَحِلُّ لرجل أن ينكح امرأة إلا نكاح الإسلام، يُمْهِرُها، ويَرِثُها، وتَرِثُه، ولا يقاضيها على أجل أنها امرأته؛ فإن مات أحدُهما لم يتوارثا{151}. (٤/٣٣٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧٣٢٤<span class="dash">-</span></span> عن <span class="name-2">سعيد بن المسيب</span> -من طريق داود بن أبي هند- قال: نسخت آيةُ الميراثِ المتعةَ{152}. (٤/٣٣٠-٣٣١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧٣٢٥<span class="dash">-</span></span> عن الحسن البصري -من طريق قتادة- قال: واللهِ، ما كانت المتعةُ إلا ثلاثةَ أيام، أذِن لهم رسول الله ﷺ فيها، ما كانت قبل ذلك ولا بعد{137}. (٤/٣٣٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧٣٢٦<span class="dash">-</span></span> عن <span class="name-2">الحكم [بن عتيبة]</span> -من طريق شعبة- أنّه سُئِل عن هذه الآية: أمنسوخة؟ قال: لا.= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧٣٢٧<span class="dash">-</span></span> وقال <span class="name-1">عليٌّ</span>: لولا أنّ <span class="name-1">عمر</span> نهى عن المتعة ما زَنى إلا شَقِيٌّ{154}. (٤/٣٣١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧٣٢٨<span class="dash">-</span></span> قال <span class="name-3">محمد بن السائب الكلبي</span>: كان هذا في بدء الإسلام، أحلَّها رسول الله ﷺ بثلاثة أيام، ثُمَّ حرَّمها، وذلك أنّه كان إذا تَمَّ الأجلُ الذي بينهما أعطاها أجرَها الذي كان شَرَطَ لها، ثم قال: زيديني في الأيامِ وأزِيدُكِ في الأجر. فإن شاءتْ فعلَتْ، فإذا تمَّ الأجلُ الذي بينهما أعطاها الأجرَ، وفارقها، ثُمَّ نسخت بآية الطلاق والعِدَّة والميراث{155}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧٣٢٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: نسختها آيةُ الطلاق، وآية المواريث. ثُمَّ إنّ رسول الله ﷺ نهى عن المتعة بعد نزول هذه الآية مِرارًا، والله تعالى يقول: <span class="qpc-hafs">﴿وما آتاكم الرسول فخذوه وما نهاكم عنه فانتهوا﴾</span>{109}<span class=comment-ref>١٦١١</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>١٦١١</span> قال <u>ابنُ كثير</u> (٣/٤٢٨): «قد استُدِلَّ بعموم هذه الآية على نكاح المتعة، ولا شكَّ أنه كان مشروعًا في ابتداء الإسلام، ثُمَّ نُسِخَ بعد ذلك».</p><p>وبنحوه قال <u>ابنُ عطية</u> (٢/٥١٧).</div></p><p><h3><span class="qpc-hafs">﴿فَـَٔاتُوهُنَّ أُجُورَهُنَّ فَرِیضَةࣰۚ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">١٧٣٣٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي بن أبي طلحة- في قوله: <span class="qpc-hafs">﴿فما استمتعتم به منهن فآتوهن أجورهن فريضة﴾</span>، يقول: إذا تزوَّج الرجلُ منكم المرأةَ، ثم نكحها مرَّةً واحدة، فقد وجب صَداقُها كله. والاستمتاع هو النكاح، وهو قوله: <span class="qpc-hafs">﴿وآتو النساء صدقاتهن نحلة﴾</span> [النساء:٤]{157}. (٤/٣٢٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧٣٣١<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق يونس- <span class="qpc-hafs">﴿فما استمتعتم به منهن فآتوهن أجورهن﴾</span>، قال: التزوُّج، والمهر{107}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧٣٣٢<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دِعامة</span>: <span class="qpc-hafs">﴿فآتوهن أجورهن فريضة﴾</span>، قال: ما تَراضَوْا عليه مِن قليل أو كثير{2}. (٤/٣٣٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧٣٣٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فآتوهن أجورهن فريضة﴾</span>، يعني: أعطوهن مهورَهن{109}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧٣٣٤<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿فما استمتعتم به منهن فآتوهن أجورهن فريضة﴾</span> الآية، قال: هذا النكاح، وما في القرآنِ إلا نكاح، إذا أخذتها واستمتعت بها فأعطِها أجرَها؛ الصَّداق، فإن وضَعَتْ لك منه شيئًا فهو لك سائغٌ، فرض الله عليها العِدَّة، وفرض لها الميراث{124}<span class=comment-ref>١٦١٢</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>١٦١٢</span> أفادت الآثارُ الاختلافَ في تأويل قوله تعالى: <span class="qpc-hafs">﴿فما استمتعتم به منهن فآتوهن أجورهن فريضة﴾</span> على قولين: <b>أحدهما</b>: أنّ المعنى: فإذا استمتعتم بالزوجة، ووقع الوطء ولو مَرَّةً؛ فقد وجب إعطاء الأجر، وهو المهر كله. وهذا قول ابن عباس من طريق علي بن أبي طلحة، ومجاهد، والحسن، وابن زيد، وغيرهم. <b>والآخر</b>: أنّ الآية في نكاح المتعة. وهذا قول ثانٍ لابن عباس من طرق، ومجاهد، وقول السديّ، وغيره.</p><p>و<span class="comment-type-3">رَجَّحَ</span> <u>ابنُ جرير</u> (٦/٥٨٨) القول الأولَ <span class="mustanad">استنادًا إلى السُنَّة</span>، فقال: «أوْلى التأويلين في ذلك بالصواب تأويلُ مَن تأوله: فما نكحتموه منهن فجامعتموه فآتوهن أجورهن؛ لقيام الحجة بتحريم الله متعة النساء على غير وجه النكاح الصحيح أو الملك الصحيح على لسان رسوله ﷺ. حدثنا ابن وكيع، قال: ثنا أبي، عن عبد العزيز بن عمر بن عبد العزيز، قال: ثني الربيع بن سبرة الجهني، عن أبيه، أنّ النبي ﷺ قال: «استمتعوا من هذه النساء». والاستمتاع عندنا يومئذ التزويج».</div></p><p><h3><span class="qpc-hafs">﴿وَلَا جُنَاحَ عَلَیۡكُمۡ فِیمَا تَرَ ٰ⁠ضَیۡتُم بِهِۦ مِنۢ بَعۡدِ ٱلۡفَرِیضَةِۚ إِنَّ ٱللَّهَ كَانَ عَلِیمًا حَكِیمࣰا ۝٢٤﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">١٧٣٣٥<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي بن أبي طلحة- في قوله: <span class="qpc-hafs">﴿ولا جناح عليكم فيما تراضيتم به من بعد الفريضة﴾</span>، قال: التراضي أن يوفي لها صَداقها، ثُمَّ يُخَيِّرها{162}. (٤/٣٣٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧٣٣٦<span class="dash">-</span></span> عن <span class="name-2">ربيعة</span> -من طريق يونس- في الآية، قال: إن أعطت زوجَها من بعد الفريضة، أو وضعت إليه، فذلك الذي قال{163}. (٤/٣٣٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧٣٣٧<span class="dash">-</span></span> عن <span class="name-2">محمد ابن شهاب الزهري</span>، في الآية، قال: نزل ذلك في النكاح، فإذا فرض الصَّداق فلا جناح عليهما فيما تراضيا به مِن بعد الفريضة، من إنجاز صَداقٍ قليلٍ أو كثير{164}. (٤/٣٣٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧٣٣٨<span class="dash">-</span></span> عن <span class="name-2">محمد ابن شهاب الزهري</span> -من طريق ابن جُرَيْج- في الرجل يتزوج المرأة، ويُسَمِّي لها صَداقًا، هل يصلح له أن يدخل عليها ولم يُعْطِها؟ قال: فإنّ الله يقول: <span class="qpc-hafs">﴿ولا جناح عليكم فيما تراضيتم به من بعد الفريضة﴾</span>، فإذا فرض الصَّداق فلا جناح عليه في الدخول عليها، وقد مضت السُّنَّةُ أن يُقَدِّم لها شيئًا مِن كسوة أو نفقة{165}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧٣٣٩<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- في قوله: <span class="qpc-hafs">﴿ولا جناح عليكم فيما تراضيتم به من بعد الفريضة﴾</span>، قال: إن شاء أرضاها مِن بعد الفريضة الأولى -يعني: الأجرة التي أعطاها على تَمَتُّعِه بها- قبل انقضاء الأجل بينهما، فقال: أتمتع منك أيضًا بكذا وكذا. فازداد قبل أن يَسْتَبْرِئَ رَحِمُها، ثم تنقضي المُدَّة. وهو قوله: <span class="qpc-hafs">﴿فيما تراضيتم به من بعد الفريضة﴾</span>{166}. (٤/٣٣٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧٣٤٠<span class="dash">-</span></span> عن <span class="name-2">حضرمي</span> -من طريق المعتمر بن سليمان، عن أبيه- أنّ رجالًا كانوا يفرضون المهر، ثُمَّ عسى أن يدرك أحدُهم العسرةَ؛ فقال الله: <span class="qpc-hafs">﴿ولا جناح عليكم فيما تراضيتم به من بعد الفريضة﴾</span>{167}. (٤/٣٣٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧٣٤١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ولا جناح عليكم فيما تراضيتم به من بعد الفريضة﴾</span> يقول: لا حرج عليكم فيما زِدتُم مِن المهر وازْدَدتُم في الأجل بعد الأمر الأول، <span class="qpc-hafs">﴿إن الله كان عليما﴾</span> بخلقه، <span class="qpc-hafs">﴿حكيما﴾</span> في أمره{109}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧٣٤٢<span class="dash">-</span></span> عن <span class="name-3">مقاتل بن حَيّان</span> -من طريق بُكَيْر- قوله: <span class="qpc-hafs">﴿من بعد الفريضة﴾</span>، يعني: ما بعد تسمية الأوَّل{169}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧٣٤٣<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في الآية، قال: إن وضَعَتْ لك منه شيئًا فهو لك سائِغٌ{170}<span class=comment-ref>١٦١٣</span>. (٤/٣٣٦)</p></p><p></div></p><p><div><span class=comment-ref>١٦١٣</span> أفادت الآثارُ الاختلافَ في معنى قوله تعالى: <span class="qpc-hafs">﴿ولا جُناحَ عَلَيْكُمْ فِيما تَراضَيْتُم بِهِ مِن بَعْدِ الفَرِيضَةِ﴾</span> على أربعة أقوال: <b>أولها</b>: أنّ المعنى: ولا حرج عليكم أيها الأزواج إن أدركتكم عسرةٌ بعد أن فرضتم لنسائِكم أُجورَهُنَّ فريضةً فيما تراضيتم به، من حط وبراءة، بعد الفرض الذي سلف منكم لهن ما كنتم فرضتم. وهذا قول الحضرميّ. <b>وثانيها</b>: أنّ المعنى: ولا جناح عليكم أيها الناس فيما تراضيتم أنتم والنساء اللواتي استمتعتم بهن إلى أجل مسمى، إذا انقضى الأجل الذي بينكم أن يزدنكم في الأجل وتزيدوهن من الأجر والفريضة قبل أن يستبرئن أرحامهن. وهذا قول السديّ. <b>وثالثها</b>: أنّ المعنى: ولا جناح عليكم أيها الناس فيما تراضيتم به أنتم ونساؤكم بعد أن تؤتوهن أجورهم على استمتاعكم بهن من مقامٍ وفراقٍ. وهذا قول ابن عباس. <b>ورابعها</b>: أنّ المعنى: ولا جناح عليكم فيما وضعت عنكم نساؤكم من صدقاتهن من بعد الفريضة. وهذا قول ابن زيد.</p><p>و<span class="comment-type-3">رجَّحَ</span> <u>ابنُ جرير</u> (٦/٥٩١) ما أفاده القولان الأول والرابع؛ <span class="mustanad">استنادًا إلى النظائر</span>، فقال: «أولى هذه الأقوال بالصواب قولُ من قال: معنى ذلك: ولا حرج عليكم أيُّها الناس فيما تراضيتم به أنتم ونساؤكم من بعد إعطائهن أجورَهُنَّ على النكاح الذي جرى بينكم وبينهن من حَطِّ ما وجب لهن عليكم، أو إبراءٍ، أو تأخيرٍ ووضع. وذلك نظيرُ قوله -جلَّ ثناؤه-: <span class="qpc-hafs">﴿وآتوا النساء صدقاتهن نحلة فإن طبن لكم عن شيء منه نفسا فكلوه هنيئا مريئا﴾</span> [النساء:٤]».</p><p>و<span class="comment-type-2">اسْتَدْرَكَ</span> على ما قاله السديُّ بقوله: «أما الذي قاله السديُّ فقولٌ لا معنى له؛ لفساد القول بإحلال جماع امرأة بغير نكاح، ولا ملك يمين».</div></p></div>",footnotes:1:عزاه السيوطي إلى عَبد بن حُمَيد.</p><p>وقراءة ابن مسعود <span class="qpc-hafs">﴿والمُحْصَناتِ﴾</span> بفتح الصاد هي قراءة العشرة هنا، وقرأها الكسائي بكسرها في غير هذا الموضع، أما قراءة يحيى (والمُحْصِناتِ) بكسر الصاد هنا فهي شاذة. انظر: النشر ٢/٢٤٩، وإعراب القراءات الشواذ ١/٣٧٧، والبحر المحيط ٣/٢٢٢.|2:عزاه السيوطي إلى عَبد بن حُمَيد.|3:أخرجه سعيد بن منصور (٦١٠ - تفسير). وعزاه السيوطي إلى عَبد بن حُمَيد.|4:أخرجه مسلم ٢/١٠٧٩-١٠٨٠ (١٤٥٦)، والواحدي في أسباب النزول ص١٤٨-١٤٩، وعبد الرزاق ١/٤٤٦ (٥٤٩)، وابن جرير ٦/٥٦٣، ٥٦٤، ٥٦٥، ٥٧٨، وابن المنذر ٢/٦٣٥ (١٥٦٥)، وابن أبي حاتم ٣/٩١٦ (٥١١٣). وأورده يحيى بن سلام -كما في تفسير ابن أبي زمنين ١/٣٦٠-، والثعلبي ٣/٢٨٥.|5:أخرجه الطبراني في الكبير ١٢/١١٥ (١٢٦٣٧)، وفي الأوسط ٤/٢٩٧ (٤٢٥١)، والجرجاني في تاريخ جرجان ص٢١٢ (٣٢٧).</p><p>قال الطبراني في الأوسط: «لم يروه عن سالم الأفطس إلا محمد بن مسلم بن أبي الوضاح». وقال الهيثمي في المجمع ٧/٣ (١٠٩١٩): «رواه الطبراني في الكبير والأوسط، ورزين الجرجاني لم أعرفه، وبقية رجاله ثقات».|6:أخرجه ابن أبي شيبة في المصنف ٤/٢٦٨.|7:أخرجه ابن أبي شيبة ٤/٢٦٦.|8:ألطت بالذنب: أراد: منعت بُضْعَها، من لطَّت الناقة بذنبها، إذا سدّت فرجها به إذا أرادها الفحل. النهاية (لطط).|9:واركًا على قتب: أي: جالسًا بوَرِكه، وهي ما فوق الفخذ على قتب، وهو للجمل كالإكاف لغيره. النهاية (ورك، قتب).|10:عزاه السيوطي إلى عَبد بن حُمَيد.|11:أخرجه البزار ١٤/٢٢٤ (٧٧٩٠)، والطبراني في الأوسط ١/١١ (٢٠)، وابن أبي حاتم ٣/٩١٥ (٥١٠٥)، ٨/٢٥٢٨ (١٤١٥٨).</p><p>قال البزار: «وهذا الحديث لا نعلمه يروى عن أبي هريرة إلا من هذا الوجه، ولا نعلمه يروى عن النبي ﷺ إلا من هذا الوجه بهذا الإسناد، ومبشر بن عبيد لين الحديث، وقد روى عنه بقية بن الوليد ويزيد بن هارون وغيرهما». وقال ابن أبي حاتم: «قال أبي: هذا حديث منكر». وقال الطبراني: «لم يروِ هذا الحديثَ عن الزهري إلا مبشر بن عبيد». وقال الدارقطني ٩/١٣٣ (١٦٧٧): «يرويه مبشر بن عبيد، عن الزهري، عن سعيد، عن أبي هريرة مرفوعًا، ومبشر متروك الحديث، يشبه أن يكون مِن كلام الزهري، بل هو محفوظ عن عقيل ومعمر، عن الزهري قوله ورأيه». وقال ابن القيسراني في أطراف الغرائب والأفراد ٥/١٦٨ (٥٠٢٩): «تفرَّد به مبشر بن عبيد عن الزهري عنه، ورواه عقيل ومعمر عن الزهري من قوله، وهو المحفوظ». وقال الهيثمي في المجمع ٦/٢٦٣ (١٠٥٨٥): «فيه مبشر بن عبيد، وهو متروك». وقال الألباني في الضعيفة ٢/٢١٠ (٧٩٧): «موضوع».|12:تفسير الثعلبي ٣/٢٨٥.|13:أخرجه ابن أبي شيبة ٤/٢٦٥، ٢٦٦، ٢٦٧، والطبراني (٩٠٣٦)، وابن جرير ٦/٥٧١ واللفظ له. وعزاه السيوطي إلى الفريابي.|14:أخرجه ابن أبي شيبة (ت: محمد عوامة) ٩/٢٥٣ (١٧١٦١).|15:أخرجه ابن أبي شيبة في مصنفه (ت: محمد عوامة) ٩/٢٥٣ (١٧١٦٠)، والطبراني في المعجم الكبير ٩/٢١٣ (٩٠٣٦) ولفظه: المشركات إذا سُبِينَ حَلَّتْ له.|16:لا تخلب: من الخلابة، وهي الخداع بالقول اللطيف. النهاية (خلب).|17:أخرجه ابن جرير ٦/٥٧٢، وابن أبي حاتم ٣/٩١٥.|18:أخرجه ابن أبي حاتم ٣/٩١٥.|19:علَّقه ابن أبي حاتم ٣/٩١٥.|20:أخرجه سعيد بن منصور (٦١١ - تفسير)، وابن جرير ٦/٥٧٠، وابن المنذر ٢/٦٣٩ بلفظ: العفيفة الغافلة.|21:أخرجه ابن أبي حاتم ٣/٩١٥.|22:أخرجه ابن أبي شيبة في المصنف ٤/٢٦٦، وابن المنذر (١٥٧٤).|23:أخرجه مالك ٢/٥٤١ واللفظ له، وعبد الرزاق ١/١٥٣، وابن أبي شيبة ٤/٢٦٦، وابن المنذر ٢/٦٣٨، والبيهقي ٧/١٦٧. وعزاه السيوطي إلى عبد بن حميد.|24:أخرجه ابن أبي حاتم ٤/٢٠٤.|25:أخرجه ابن أبي شيبة (ت: محمد عوامة) ٩/٢٥٥ (١٧١٧٠)، وابن جرير ٦/٥٦٩.|26:أخرجه ابن أبي شيبة (ت: محمد عوامة) ٩/٢٥٣ (١٧١٦٥)، وابن جرير ٦/٥٧٢ مختصرًا.|27:أخرجه ابن أبي شيبة ٤/٢٦٨-٢٦٩، وابن جرير ٦/٥٧١ ولفظه: نهى عن الزنا؛ أن تنكح المرأة زوجين.|28:أخرجه ابن جرير ٦/٥٧٠.|29:أخرجه ابن أبي شيبة في مصنفه (ت: محمد عوامة) ٩/٢٥٤ (١٧١٦٧). وعلَّقه ابن أبي حاتم ٣/٩١٥ مختصرًا.|30:أخرجه ابن أبي شيبة في مصنفه (ت: محمد عوامة) ٩/٢٥٤ (١٧١٦٨).|31:أخرجه ابن أبي شيبة في مصنفه (ت: محمد عوامة) ٩/٢٥٥ (١٧١٧٥)، وابن جرير ٦/٥٧٢. وعلَّقه ابن أبي حاتم ٣/٩١٥.|32:أخرجه ابن جرير ٦/٥٧٠.|33:أخرجه ابن جرير ٦/٥٧٣.|34:أخرجه ابن المنذر ٢/٦٣٧-٦٣٨.|35:أخرجه ابن أبي شيبة ٤/٢٦٧، وابن جرير ٦/٥٦٥، وابن المنذر (١٥٦٩). وعزاه السيوطي إلى عبد بن حميد.|36:أخرجه ابن جرير ٦/٥٦٨.|37:أخرجه ابن جرير ٦/٥٦٦.|38:أخرجه ابن أبي شيبة ٤/٢٦٥، ٢٦٦، ٢٦٧، والطبراني (٩٠٣٦). وعزاه السيوطي إلى الفريابي.|39:أخرجه ابن جرير ٦/٥٧١.|40:أخرجه ابن جرير ٦/٥٧٤.|41:أخرجه ابن أبي شيبة ٤/٢٦٨، وابن جرير ٦/٥٦٢، وابن المنذر (١٥٦٧)، والحاكم ٢/٣٠٤، والبيهقي ٧/١٦٧. وعزاه السيوطي إلى عبد بن حميد.|42:تفسير مجاهد بن جبر ص٢٧١.|43:أخرجه ابن جرير ٦/٥٦٢، وابن المنذر ٢/٦٣٥ بلفظ: إذا اشتريتها، وابن أبي حاتم ٣/٩١٦.|44:أخرجه ابن جرير ٦/٥٧٢ مختصرًا. وعلَّقه ابن أبي حاتم ٣/٩١٦.|45:أخرجه ابن جرير ٦/٥٧٢ مختصرًا.|46:أخرجه ابن جرير ٦/٥٧٢، وابن أبي حاتم ٣/٩١٥، ٩١٧.|47:أخرجه ابن المنذر ٢/٦٣٧. وعزاه السيوطي إلى عبد بن حميد.|48:أخرجه ابن جرير ٦/٥٧١، وابن أبي حاتم ٣/٩١٦، والطبراني (١١٧٧٢) بنحوه.|49:أخرجه ابن أبي شيبة في مصنفه (ت: محمد عوامة) ٩/٢٥٤ (١٧١٦٩)، ٩/٢٥٦ (١٧١٧٨)، وابن المنذر من قول ابن عباس ومن بعده ٢/٦٣٩، وقول عطاء ٢/٦٣٨. وعزاه السيوطي إليهما مقتصرًا على قول ابن عباس.|50:أخرجه ابن أبي حاتم ٣/٩١٥.|51:لم يرد في المصدر إلا خمسًا.|52:أخرجه ابن جرير ٦/٥٦٧.|53:أخرجه ابن جرير ٦/٥٧٤.|54:أخرجه إسماعيل القاضي في أحكام القرآن-كما في تغليق التعليق ٤/ ٣٩٩، والفتح ٩/١٥٤.|55:أخرجه عبد الرزاق ١/١٥٣، وابن أبي شيبة ٤/٢٦٦، وابن جرير ٦/٥٦٩.|56:أخرجه عبد الله بن وهب في الجامع ١/٨٠ (١٧٨).|57:أخرجه ابن جرير ٦/٥٦٨-٥٦٩. وعزاه السيوطي إلى عبد بن حميد.|58:أخرجه عبد الرزاق ١/١٥٣، وابن جرير ٦/٥٦٦. وعلَّقه ابن أبي حاتم ٣/٩١٥ مختصرًا.|59:أخرجه عبد الرزاق ١/١٥٣، وابن جرير ٦/٥٦٦. وعلَّقه ابن أبي حاتم ٣/٩١٥ مختصرًا.|60:أخرجه ابن جرير ٦/٥٦٨.|61:المدونة للإمام مالك ٢/٢٠٣.|62:أخرجه ابن جرير ٦/٥٧٤.|63:أخرجه ابن جرير ٦/٥٦٣.|64:أخرجه ابن أبي شيبة في مصنفه (ت: محمد عوامة) ٩/٢٥٥ (١٧١٧٦). وعلَّقه ابن أبي حاتم ٣/٩١٥ عن الشعبي.|65:أخرجه عبد الرزاق ١/١٥٣، وابن جرير ٦/٥٦٩.|66:أخرجه ابن جرير ٦/٥٧٢.|67:أخرجه ابن جرير ٦/٥٦٦.|68:أخرجه ابن جرير ٦/٥٦٧.|69:أخرجه ابن أبي شيبة في مصنفه (ت: محمد عوامة) ٩/٢٥٥ (١٧١٧٤).|70:أخرجه ابن أبي الدنيا في كتاب الأشراف -موسوعة الإمام ابن أبي الدنيا ٨/٢٩٥ (٣٨٣)-.|71:تفسير الثعلبي ٣/٢٨٥، وتفسير البغوي ٢/١٩٢.|72:أخرجه ابن جرير ٦/٥٦٣.|73:أخرجه ابن أبي شيبة في مصنفه (ت: محمد عوامة) ٩/٢٥٥ (١٧١٧١).|74:أخرجه مالك في المدونة ٢/٢١٨، وابن أبي حاتم ٣/٩١٦.|75:علَّقه ابن أبي حاتم ٣/٩١٦.|76:أخرجه ابن جرير ٦/٥٧٣.|77:أخرجه ابن جرير ٦/٥٦٣.|78:تفسير مقاتل بن سليمان ١/٣٦٦.|79:أخرجه عبد الله بن وهب في الجامع - تفسير القرآن ١/٨٠ (١٧٩).|80:أخرجه ابن أبي حاتم ٣/٩١٧.|81:أخرجه ابن المنذر ٢/٦٣٩.|82:أخرجه ابن جرير ٦/٥٦٩، وابن المنذر ٢/٦٤٠، وابن أبي حاتم ٣/٩١٧. وعزاه السيوطي إلى عَبد بن حُمَيد.|83:أخرجه ابن جرير ٦/٥٦٩.|84:أخرجه ابن أبي شيبة (ت: محمد عوامة) ٩/٢٥٥ (١٧١٧٠) عن سعيد بن جبير من طريق جعفر. وعلَّقه ابن أبي حاتم ٣/٩١٧.|85:أخرجه عبد الله بن وهب في الجامع - تفسير القرآن ١/٨٠ (١٧٨). وعلَّقه ابن أبي حاتم ٣/٩١٧.|86:أخرجه ابن جرير ٦/٥٧٩، وابن المنذر ٢/٦٤٠، وابن أبي حاتم ٣/٩١٧. وعزاه السيوطي إلى عبد بن حميد.|87:أخرجه ابن جرير ٦/٥٧٩. وعزاه السيوطي إليه فقط بلفظ: حرم ما فوق الأربع منهن. وعلَّقه ابن أبي حاتم ٣/٩١٧.|88:أخرجه ابن جرير ٦/٥٨٠. وعلَّقه ابن أبي حاتم ٣/٩١٧.|89:تفسير مقاتل بن سليمان ١/٣٦٦.|90:أخرجه ابن جرير ٦/٥٨٠.|91:أخرجه ابن أبي داود في المصاحف ١/٣١٢.</p><p>وهي قراءة شاذة لمخالفتها رسم المصاحف.|92:أخرجه عبد بن حميد كما في قطعة من تفسيره ص٨٣.</p><p>وهي قراءة متواترة، قرأ بها أبو جعفر، وحمزة، والكسائي، وخلف العاشر، وحفص، وقرأ بقية العشرة: ‹وأَحَلَّ لَكُم› بفتح الهمزة والحاء. ينظر: النشر ٢/٢٣٩، والإتحاف ص٢٣٩.|93:أخرجه عَبد بن حُمَيد كما في قطعة من تفسيره ص٨٣.|94:أخرجه ابن أبي حاتم ٣/٩١٧.|95:أخرجه ابن أبي حاتم ٣/٩١٨.|96:أخرجه ابن جرير ٦/٥٨١.|97:عزاه السيوطي إلى ابن أبي حاتم، وجزء منه في المطبوع من تفسيره ٣/٩١٧.|98:أخرجه ابن جرير ٦/٥٨١.|99:أخرجه ابن جرير ٦/٥٨٢، وابن المنذر ٢/٦٤٠.|100:أخرجه ابن جرير ٦/٥٨١، وابن أبي حاتم ٣/٩١٨.|101:أخرجه ابن أبي حاتم ٣/٩١٧.|102:تفسير مقاتل بن سليمان ١/٣٦٦-٣٦٧.|103:أخرجه ابن أبي حاتم ٣/٩١٨.|104:علَّقه ابن أبي حاتم ٣/٩١٨.|105:أخرجه ابن أبي حاتم ٣/٩١٨.|106:أخرجه ابن جرير ٦/٥٨٤، وابن المنذر ٢/٦٤١ من طريقي ابن جُرَيج وابن أبي نَجِيح، وابن أبي حاتم ٣/٩١٨. وعزاه السيوطي إلى عَبد بن حُمَيد.|107:أخرجه ابن أبي حاتم ٣/٩١٩.|108:أخرجه ابن جرير ٦/٥٨٤.|109:تفسير مقاتل بن سليمان ١/٣٦٧.|110:أخرجه ابن أبي حاتم ٣/٩١٨.|111:أخرجه ابن أبي داود في المصاحف ص٥٣.</p><p>وهي قراءة شاذة، قرأ بها أيضًا ابن عباس، وابن جبير. ينظر: الجامع لأحكام القرآن ٦/٢١٥، والبحر المحيط ٣/٢٢٥.|112:أخرجه ابن جرير ٦/٥٨٨. وعزاه السيوطي إلى عبد بن حميد.|113:أخرجه عبد الرزاق (١٤٠٢٢)، وابن المنذر ٢/٦٤١ دون آخره.|114:أخرجه ابن جرير ٦/٥٨٧، والحاكم ٢/٣٠٥. وعزاه السيوطي إلى عبد بن حميد، وابن الأنباري في المصاحف.|115:أخرجه ابن جرير ٦/٥٨٨.|116:أخرجه ابن جرير ٦/٥٨٨.|117:أخرجه ابن جرير ٦/٥٨٥، وابن المنذر ٢/٦٤٢، ٦٤٥، وابن أبي حاتم ٣/٩١٩.|118:علَّقه ابن أبي حاتم ٣/٩١٩.|119:أخرجه ابن جرير ٦/٥٨٦. وعزاه السيوطي إلى عبد بن حميد.|120:أخرجه ابن جرير ٦/٥٨٥، وابن المنذر ٢/٦٤١. وعلَّقه ابن أبي حاتم ٣/٩١٩.|121:أخرجه عبد الرزاق ١/١٥٤، وابن جرير ٦/٥٨٥. وعلَّقه ابن أبي حاتم ٣/٩١٩.|122:أخرجه ابن جرير ٦/٥٨٦.|123:تفسير مقاتل بن سليمان ١/٣٦٧.|124:أخرجه ابن جرير ٦/٥٨٥.|125:أخرجه ابن أبي حاتم ٣/٩١٩.|126:أخرجه البزار ١/٢٤٦ (١٣٥)، والبيهقيُّ في الكبرى ٧/٣٣٦ (١٤١٧١). وأورده الثعلبي ٣/٢٨٧. وأصله عند ابن ماجه ٣/١٣٨ (١٩٦٣)، ولفظه: إنّ رسول الله ﷺ أذِن لنا في المُتعة ثلاثًا، ثُمَّ حرَّمها، واللهِ، لا أعلم أحدًا يتمتع وهو مُحْصَنٌ إلا رجمته بالحجارة، إلا أن يأتيني بأربعةٍ يشهدون أنّ رسول الله أحلَّها بعد إذ حرَّمها.</p><p>إسناد ابن ماجه قال عنه ابن الملقن في شرح البخاري ٢٤/٣٦٢ وابن حجر في التلخيص الحبير ٣/١١٧١: «صحيح».|127:أخرجه الدارقطني في سننه ٤/٣٨٤ (٣٦٤٥)، والبيهقي في الكبرى ٧/٣٣٨ (١٤١٨١).</p><p>قال الحازمي في الاعتبار في الناسخ والمنسوخ ص١٧٧: «هذا حديث غريب من هذا الوجه، وقد صحَّ الحديثُ عن علي في هذا الباب من غير وجه، ورواه عنه الكوفيون من طرق، وهو أشهر من أن ينكر، وأكثر من أن يحصر». وقال الزيلعي ٣/١٨٠: «وضعَّفه ابن القطان في كتابه». وأورده الألباني في الصحيحة ٣/١٨٠ (٢٤٠٢).|128:أخرجه عبد الرزاق ٧/٥٠١ (١٤٠٣٢)، وأبو عوانة في مستخرجه ٣/٢٧ (٤٠٧٧)، ٣/٢٨ (٤٠٧٨، ٤٠٧٩)، ٥/٢٨ (٧٦٤٨، ٧٦٤٩). وأصل الحديث عند مسلم ٢/١٠٢٨ (١٤٠٧)، ولم يصرح بذكر ابن عباس.</p><p>قال الطبراني في الأوسط ٥/٣٤٥ (٥٥٠٤): «لم يرو هذا الحديثَ عن سفيان الثوري إلا عبثر بن القاسم، تفرد به سعيد بن عمرو». وقال الهيثمي في المجمع ٤/٢٦٥ (٧٣٩١): «رواه الطبراني في الأوسط، ورجاله رجال الصحيح». وقال الفسوي في المعرفة والتاريخ ٢/٧٣٧: «لفظ حسن».|129:أخرجه البخاري ٥/١٣٥ (٤٢١٦)، ومسلم ٢/١٠٢٧، ١٠٢٨ (١٤٠٧)، ٣/١٥٣٧ (١٤٠٧). وأورده الثعلبي ٣/٢٨٧.|130:أخرجه البيهقي في الكبرى ٧/٣٣٧ (١٤١٧٦)، وابن شاهين في ناسخ الحديث ومنسوخه ص٣٥١ (٤٢٧).</p><p>قال الذهبي في المهذب ٦/٢٧٨٠: «فيه انقطاع».|131:البكرة: هي الفتيّة من الإبل، أي: الشابة القوية. اللسان (بكر). والعنطنطة: الطويلة العنق في اعتدال وحسن قوام. النهاية (عنط).|132:المح: الخَلَق البالي. النهاية (محح).|133:أخرجه مسلم ٢/١٠٢٤ (١٤٠٦).|134:أخرجه مسلم ٢/١٠٢٥ (١٤٠٦).|135:أخرجه مسلم ٢/١٠٢٣ (١٤٠٥).|136:أخرجه مالك ٢/٥٤٢، وعبد الرزاق (١٤٠٣٨).|137:أخرجه ابن أبي شيبة ٤/٢٩٣.|138:أخرجه البخاري ٧/٤ (٥٠٧٥)، ومسلم ٢/١٠٢٢ (١٤٠٤)، وابن أبي حاتم ٤/١١٨٨ (٦٦٩٣)، ٤/١١٨٨ (٦٦٩٣).|139:أخرجه عبد الرزاق (١٤٠٤٤)، وابن المنذر ٢/٦٤٤، والبيهقي ٧/٢٠٧.|140:أخرجه عبد الرزاق (١٤٠٤٦)، وابن المنذر ٢/٦٤٥ مختصرًا.|141:أخرجه ابن أبي حاتم ٣/٩١٩، وسقطت منها جملة: وكان يقرأ: (فما استمتعتم به منهن إلى أجل مسمى)، وهي مثبتة في النسخة المرقومة بالآلة الكاتبة التي حققها د. حكمت بشير ٣/٢٤.|142:أخرجه الطبراني (١٠٧٨٢)، والبيهقي في سُنَنِه ٧/٢٠٥-٢٠٦.|143:أخرجه ابن المنذر (١٥٩٤)، والنحاس ص٣٢٥-٣٢٦. وعزاه السيوطي إلى أبي داود في ناسخه.|144:أخرجه البخاري (٥١١٦).|145:أخرجه عبد الرزاق (١٤٠٣٣).|146:أخرجه ابن المنذر (١٥٩٣)، والطبراني (١٠٦٠١)، والبيهقي ٧/٢٠٥. وعزاه السيوطي إلى ابن جرير في تهذيبه.|147:أخرجه عبد الرزاق (١٤٠٢١، ١٤٠٢٢)، وابن المنذر (١٥٩٠).|148:أخرجه ابن المنذر (١٥٩٢).|149:والزمزمة: صوت خفيّ لا يكاد يفهم. النهاية (زمزم).|150:أخرجه ابن أبي شيبة ٤/٢٩٣. وعزاه السيوطي إلى ابن جرير في تهذيبه.|151:أخرجه البيهقي ٧/٢٠٧.|152:أخرجه ابن المنذر ٢/٦٤٥، وابن أبي حاتم ٣/٩١٩، والنحاس ص٣٢٦، والبيهقي ٧/٢٠٧. وعزاه السيوطي إلى أبي داود في ناسخه.|153:أخرجه ابن أبي شيبة ٤/٢٩٣.|154:أخرجه عبد الرزاق (١٤٠٢٩)، وابن جرير ٦/٥٨٨. وعزاه السيوطي إلى أبي داود في ناسخه.|155:تفسير الثعلبي ٣/٢٨٧.|156:تفسير مقاتل بن سليمان ١/٣٦٧.|157:أخرجه ابن جرير ٦/٥٨٥، وابن المنذر ٢/٦٤٢، ٦٤٣، ٦٤٥، وابن أبي حاتم ٣/٩١٩ مختصرًا، والنحاس في ناسخه ص٣٢٩.|158:أخرجه ابن أبي حاتم ٣/٩١٩.|159:عزاه السيوطي إلى عَبد بن حُمَيد.|160:تفسير مقاتل بن سليمان ١/٣٦٧.|161:أخرجه ابن جرير ٦/٥٨٥.|162:أخرجه ابن جرير ٦/٥٩٠-٥٩١، وابن المنذر ٢/٦٤٦، وابن أبي حاتم ٣/٩٢٠. وعزاه السيوطي إلى النحاس في ناسخه.|163:أخرجه ابن أبي حاتم ٣/٩٢٠. وعزاه السيوطي إلى أبي داود في ناسخه.|164:عزاه السيوطي إلى أبي داود في ناسخه.|165:أخرجه عبد الرزاق في مصنفه ٦/١٨٢(١٠٤٢٧).|166:أخرجه ابن جرير ٦/٥٩٠.|167:أخرجه ابن جرير ٦/٥٨٩-٥٩٠.|168:تفسير مقاتل بن سليمان ١/٣٦٧.|169:أخرجه ابن أبي حاتم ٣/٩٢٠.|170:أخرجه ابن جرير ٦/٥٩١.
  4,25,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَمَن لَّمۡ یَسۡتَطِعۡ مِنكُمۡ طَوۡلًا﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">١٧٣٤٤<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي بن أبي طلحة- <span class="qpc-hafs">﴿ومن لم يستطع منكم طولا﴾</span>، يقول: مَن لم يكن له سَعَةٌ{1}. (٤/٣٣٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧٣٤٥<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق النزال بن سبرة- قال: مَن ملك ثلاثمائة درهم فقد وجب عليه الحجُّ، وحَرُم عليه نكاح الإماء{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧٣٤٦<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span> -من طريق أبي بشر- قوله: <span class="qpc-hafs">﴿ومن لم يستطع منكم طولا﴾</span>، قال: الطَّوْلُ: الغِنى{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧٣٤٧<span class="dash">-</span></span> عن <span class="name-2">أبي مالك غَزْوان الغِفارِيِّ</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧٣٤٨<span class="dash">-</span></span> و<span class="name-2">عطاء الخراساني</span>، نحو ذلك{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧٣٤٩<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نَجِيح- <span class="qpc-hafs">﴿ومن لم يستطع منكم طولا﴾</span>، يعني: مَن لم يجد مِنكم غِنًى{5}. (٤/٣٣٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧٣٥٠<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- <span class="qpc-hafs">﴿ومن لم يستطع منكم طولا﴾</span>، قال: أمّا قوله <span class="qpc-hafs">﴿طولا﴾</span> فسَعَةٌ مِن المال{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧٣٥١<span class="dash">-</span></span> عن <span class="name-2">ربيعة [بن أبي عبد الرحمن]</span> -من طريق عبد الجبّار بن عمر- أنّه قال في قول الله: <span class="qpc-hafs">﴿ومن لم يستطع منكم طولا﴾</span>، قال: الطَّوْلُ: الهوى. قال: ينكِحُ الأمةَ إذا كان هواه فيها{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧٣٥٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ومن لم يستطع منكم طولا﴾</span>، يقول: مَن لم يجد منكم سَعَةً من المال{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧٣٥٣<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿ومن لم يستطع منكم طولا﴾</span> الآية، قال: <span class="qpc-hafs">﴿طولًا﴾</span>: لا يجد ما ينكح به حُرَّة{9}<span class=comment-ref>١٦١٤</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>١٦١٤</span> أفادت الآثارُ الاختلافَ في معنى الطَّوْلِ في الآية على قولين: <b>أحدهما</b>: أنّ معناه: الفضل، والمال، والسّعة. وهذا قول ابن عباس، ومجاهد، وسعيد بن جبير، وقتادة، وابن زيد، والسدي. <b>والآخر</b>: المراد: أنّ معناه: الهوى. وهذا قول ربيعة، وإبراهيم النخعي، وجابر، وعطاء.</p><p>و<span class="comment-type-3">رجَّحَ</span> <u>ابن جرير</u> (٦/٥٩٤-٥٩٥) القولَ الأولَ، و<span class="comment-type-2">انتَقَدَ</span> القولَ الثاني <span class="mustanad">مستندًا إلى الإجماع، ودلالة النظير، والعقل</span>، وعَلَّلَ ذلك بـ: «إجماع الجميع على أنّ الله -تبارك وتعالى- لم يُحَرِّم شيئًا من الأشياء سوى نكاح الإماء لواجد الطَّوْل إلى الحُرَّة، فأَحَلَّ ما حَرَّم مِن ذلك عند غلبته المحرم عليه له لقضاء لذة. فإن كان ذلك إجماعًا من الجميع فيما عدا نكاح الإماء لواجد الطول فمِثلُه في التحريم نكاحُ الإماء لواجد الطَّول: لا يحل له مِن أجل غلبة هوى سره فيها؛ لأنّ ذلك مع وجوده الطول إلى الحرة منه قضاء لذة وشهوة، وليس بموضع ضرورة تدفع ترخصه كالميتة للمضطر الذي يخاف هلاك نفسه فيترخص في أكلها ليحيي بها نفسه، وما أشبه ذلك من المحرمات اللواتي رخص الله لعباده في حال الضرورة والخوف على أنفسهم الهلاك منه ما حَرَّم عليهم منها في غيرها من الأحوال، ولم يرخص الله -تبارك وتعالى- لعبد في حرام لقضاء لذة. وفي إجماع الجميع على أنّ رجلًا لو غلبه هوى امرأة حرة أو أمةٍ أنها لا تحل له إلا بنكاح أو شراء على ما أذن الله به؛ ما يُوَضِّحُ فسادَ قولِ مَن قال: معنى الطول في هذا الموضع: الهوى، وأجاز لواجد الطَّول لحرة نكاح الإماء. فتأويلُ الآية إذ كان الأمر على ما وصفنا: ومَن لم يجد منكم سعةً مِن مال لنكاح الحرائر فلينكح مِمّا ملكت أيمانُكم».</div></p><p><h3><span class="qpc-hafs">﴿وَمَن لَّمۡ یَسۡتَطِعۡ مِنكُمۡ طَوۡلًا أَن یَنكِحَ ٱلۡمُحۡصَنَـٰتِ ٱلۡمُؤۡمِنَـٰتِ فَمِن مَّا مَلَكَتۡ أَیۡمَـٰنُكُم﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">١٧٣٥٤<span class="dash">-</span></span> عن الحسن البصري: أنّ رسول الله ﷺ نهى أن تُنكَح الأَمَةُ على الحُرَّة، وتُنكَح الحُرَّة على الأَمَة، ومَن وجد طَوْلًا لحُرَّة فلا ينكح أمَةً{10}. (٤/٣٣٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧٣٥٥<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن مسعود</span> -من طريق أبي عبيدة بن عبد الله- قال: إنّما أحلَّ اللهُ نكاحَ الإماء إن لم يستطع طَوْلًا، وخَشِيَ العَنَت على نفسه{11}. (٤/٣٣٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧٣٥٦<span class="dash">-</span></span> عن <span class="name-1">جابر بن عبد الله</span> -من طريق حماد، عن أبي الزبير- أنّه سُئِل عن الحُرِّ يتزوج الأَمَة. فقال: إذا كان ذا طَوْلٍ فلا. قيل: إن وقع حُبُّ الأَمَةِ في نفسه؟ قال: إن خَشِيَ العَنَتَ فليتزوجها{12}. (ز) (٤/٣٣٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧٣٥٧<span class="dash">-</span></span> عن عبيدة، عن <span class="name-2">عامر الشعبي</span>، قال: لا يتزوج الحُرُّ الأَمَةَ إلِّا أن لا يَجِدَ.= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧٣٥٨<span class="dash">-</span></span> وكان <span class="name-2">إبراهيم [النخعي]</span> يقول: لا بأس به{13}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧٣٥٩<span class="dash">-</span></span> كتب عبد الحميد بن عبد الرحمن إلى [<span class="name-2">عامر</span>] <span class="name-2">الشعبي</span> يسأله عن تزويج الأمة. فقال: إذا وجد الرجلُ طَوْل الحُرِّةِ فتزويج الأمةِ عليه بمنزلة الميتةِ والدمِ ولحمِ الخنزير{14}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧٣٦٠<span class="dash">-</span></span> قال <span class="name-2">عامر الشعبي</span>: إذا كانت عند رجل أمَةٌ، فَتَزَوَّج حُرَّةً؛ فقد حَرُمَتْ عليه. والأَمَةُ مثل المضطر، يَحِلُّ له الدم ولحم الخنزير، فإذا وجد طعامًا حَرُم عليه{15}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧٣٦١<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ليث- قال: مِمّا وسَّعَ اللهُ به على هذه الأُمَّةِ نكاحَ الأَمَةِ، والنصرانية، واليهودية، وإن كان مُوسِرًا{16}. (٤/٣٣٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧٣٦٢<span class="dash">-</span></span> عن عبد الرزاق، عن الثوري، عن ليث، عن <span class="name-2">مجاهد</span>، في الرجل ينكِحُ الأمةَ، قال: هو مِمّا وسَّعَ اللهُ به على هذه الأُمَّةِ؛ نكاح الأمة والنصرانية وإن كان مُوسِرًا.= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧٣٦٣<span class="dash">-</span></span> وبه يأخذ <span class="name-3">سفيان</span>، يقول: لا بأس بنكاح الأَمَة.= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧٣٦٤<span class="dash">-</span></span> ثم ذكر حديث ابن أبي ليلى، عن المنهال، عن عباد بن عبد الله، عن <span class="name-1">علي</span>، قال: إذا نُكحت الحُرَّةُ على الأَمَة كان للحرة يومان، وللأمة يوم. وذلك أنِّي سألته عن نكاح الأمة، فحدثني حديث عليٍّ هذا، وقال: لم ير به عليٌّ بأسًا{17}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧٣٦٥<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق أشعث- قال: إنّما رُخِّص لهذه الأُمَّة في نكاح نساء أهل الكتاب، ولم يُرَخَّص لهم في الإماء{18}. (٤/٣٣٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧٣٦٦<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق منصور- أنّه كان يكره نكاح الإماء في زمانه، وقال: إنما رُخِّص فيهنَّ إذا لم يجد طَوْلًا لِلْحُرَّة{19}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧٣٦٧<span class="dash">-</span></span> عن <span class="name-2">عطاء [بن أبي رباح]</span> -من طريق ابن جُرَيْج- يقول: لا نكره أن ينكح ذو اليَسار الأَمَةَ إذا خَشِي أن يَشْقى بها{20}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧٣٦٨<span class="dash">-</span></span> عن سعيد، قال: سألتُ <span class="name-2">الحكم [بن عتيبة]</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧٣٦٩<span class="dash">-</span></span> و<span class="name-2">حماد [بن أبي سليمان]</span> عن الرجل يتزوَّجُ الأمة. قال: إذا خَشِي العَنَت فلا بأس{21}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧٣٧٠<span class="dash">-</span></span> عن <span class="name-2">ربيعة [بن أبي عبد الرحمن]</span> -من طريق عبد الجبار بن عمر- أنّه قال في قول الله: <span class="qpc-hafs">﴿ومن لم يستطع منكم طولا﴾</span>، قال: الطَّوْلُ: الهوى. قال: ينكِحُ الأَمَة إذا كان هواه فيها{22}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧٣٧١<span class="dash">-</span></span> قال ابن زيد: كان <span class="name-2">ربيعة [بن أبي عبد الرحمن]</span> يُلَيِّن فيه بعضَ التَّلْيِين، كان يقول: إذا خشي على نفسه إذا أحبَّها -أي: الأمة-، وإن كان يقْدِرُ على نكاح غيرها، فإنِّي أرى أن ينكحها{9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧٣٧٢<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿أن ينكح المحصنات المؤمنات فمن ما ملكت أيمانكم من فتياتكم المؤمنات﴾</span>، قال: لا يجِدُ ما ينكِحُ به حُرَّةً، فينكح هذه الأَمَةَ، فيتَعَفَّفُ بها، ويكفيه أهلُها مُؤْنَتها، ولم يُحِلَّ اللهُ ذلك لأحدٍ إلّا ألّا يَجِدَ ما ينكح به حُرَّةً وينفق عليها، ولم يَحِلَّ له حتى يخشى العَنَت{24}<span class=comment-ref>١٦١٥</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>١٦١٥</span> قال <u>ابنُ جرير</u> (٦/٥٩٥) مُبَيِّنًا معنى الآية: «يعني بذلك: ومَن لم يستطع منكم أيها الناس طولًا -يعني: من الأحرار- أن ينكح المحصنات، وهُنَّ الحرائر المؤمنات اللواتي قد صَدَّقن بتوحيد الله، وبما جاء رسول الله ﷺ من الحق». <span class="mustanad">واستند في ذلك إلى أقوال السلف.</span></div></p><p><h3><span class="qpc-hafs">﴿أَن یَنكِحَ ٱلۡمُحۡصَنَـٰتِ ٱلۡمُؤۡمِنَـٰتِ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">١٧٣٧٣<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي بن أبي طلحة- <span class="qpc-hafs">﴿أن ينكح المحصنات﴾</span>، يقول: الحرائر{25}. (٤/٣٣٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧٣٧٤<span class="dash">-</span></span> وعن <span class="name-2">عطية [العوفي]</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧٣٧٥<span class="dash">-</span></span> و<span class="name-3">مقاتل بن حيان</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧٣٧٦<span class="dash">-</span></span> و<span class="name-2">قتادة بن دِعامة</span>، نحو ذلك{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧٣٧٧<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نَجِيح- <span class="qpc-hafs">﴿أن ينكح المحصنات﴾</span>، يعني: الحرائر{27}. (٤/٣٣٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧٣٧٨<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- <span class="qpc-hafs">﴿أن ينكح المحصنات المؤمنات﴾</span>، قال: أمّا المحصناتُ فالعفائف{14}<span class=comment-ref>١٦١٦</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>١٦١٦</span> <span class="comment-type-2">انتَقَدَ</span> <u>ابنُ عطية</u> (٢/٥٢٠) هذا القول قائِلًا: «هو ضعيف؛ لأنّ الإماء يَقَعْنَ تحته».</div></p><p><h3><span class="qpc-hafs">﴿فَمِن مَّا مَلَكَتۡ أَیۡمَـٰنُكُم مِّن فَتَیَـٰتِكُمُ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">١٧٣٧٩<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق سعيد بن جبير- قال: لا يتزوج الحُرُّ مِن الإماء إلا واحدة{29}. (٤/٣٣٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧٣٨٠<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span> -من طريق أبي بشر- <span class="qpc-hafs">﴿أن ينكح المحصنات المؤمنات، فمن ما ملكت أيمانكم من فتياتكم المؤمنات﴾</span>، قال: أمّا مَن لم يجد ما ينكح به الحُرَّةَ تَزَوَّجَ الأَمَةَ{30}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧٣٨١<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- قال: فلينكح الأمةَ المؤمنةَ{27}. (٤/٣٣٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧٣٨٢<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دِعامة</span> -من طريق سعيد- قال: إنّما أحَلَّ اللهُ واحدةً لِمَن خشي العنت على نفسه، ولا يجد طَوْلًا{32}. (٤/٣٣٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧٣٨٣<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- <span class="qpc-hafs">﴿من فتياتكم﴾</span>، قال: مِن إمائكم{30}. (٤/٣٣٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧٣٨٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: فليتزوج مِن الإماء، <span class="qpc-hafs">﴿فمن ما ملكت أيمانكم﴾</span> يعني: الوَلائد، فتزوجوا <span class="qpc-hafs">﴿من فتياتكم المؤمنات﴾</span>، يعني: الولائد{8}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿مِّن فَتَیَـٰتِكُمُ ٱلۡمُؤۡمِنَـٰتِۚ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">١٧٣٨٥<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي بن أبي طلحة- <span class="qpc-hafs">﴿فمن ما ملكت أيمانكم من فتياتكم المؤمنات﴾</span>، قال: فلينكح مِن إماء المؤمنين{35}. (٤/٣٣٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧٣٨٦<span class="dash">-</span></span> وعن <span class="name-2">إسماعيل السُّدِّيّ</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧٣٨٧<span class="dash">-</span></span> و<span class="name-3">مقاتل بن حيان</span>، نحو ذلك{36}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧٣٨٨<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- قال: لا يصلح نكاحُ إماءِ أهل الكتاب؛ إنّ الله يقول: <span class="qpc-hafs">﴿من فتياتكم المؤمنات﴾</span>{37}. (٤/٣٣٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧٣٨٩<span class="dash">-</span></span> وعن <span class="name-2">مكحول الشامي</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧٣٩٠<span class="dash">-</span></span> و<span class="name-2">قتادة بن دعامة</span>، نحو ذلك{36}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧٣٩١<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق يونس- قال: كان يكره أن يتزوج الأمة النصرانية أو اليهودية. قال: إنّما رُخِّص في الأمة المسلمة، قال الله -جلَّ وعزَّ-: <span class="qpc-hafs">﴿من فتياتكم المؤمنات﴾</span> لمن لم يجد طَوْلًا{39}. (ز) (٤/٣٣٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧٣٩٢<span class="dash">-</span></span> عن ابن وهب، عن الليث، عن <span class="name-2">يحيى بن سعيد</span> أنّه قال: لا ينبغي لأحد من المسلمين أن يتزوج أمَةً مملوكة مِن أهل الكتاب؛ لأنّ الله قال: <span class="qpc-hafs">﴿من فتياتكم المؤمنات﴾</span>، وقال: <span class="qpc-hafs">﴿والمحصنات من الذين أوتوا الكتاب من قبلكم﴾</span> [المائدة:٥]، وليست الأمة بمُحْصَنة{40}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧٣٩٣<span class="dash">-</span></span> عن أبي مَيْسَرَة -من طريق مُغِيرة- أنّه قال: إماءُ أهلِ الكتاب بمنزلة الحرائر{41}<span class=comment-ref>١٦١٧</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>١٦١٧</span> قال <u>ابنُ جرير</u> (٦/٦٠٠ بتصرف) <span class="comment-type-4">مُعلِّقًا</span> على هذا القول: «قال ذلك جماعةٌ مِن أهل العراق، منهم أبو حنيفة وأصحابه، واعتلُّوا لقولهم بقول الله: <span class="qpc-hafs">﴿أُحِلَّ لَكُمُ الطَّيِّباتُ وطَعامُ الَّذِينَ أُوتُوا الكِتابَ حِلٌّ لَكُمْ وطَعامُكُمْ حِلٌّ لَهُمْ والمُحْصَناتُ مِنَ المُؤْمِناتِ والمُحْصَناتُ مِنَ الَّذِينَ أُوتُوا الكِتابَ مِن قَبْلِكُمْ إذا آتَيْتُمُوهُنَّ أُجُورَهُنَّ﴾</span> [المائدة:٥]. قالوا: فقد أحل الله محصنات أهل الكتاب عامًّا، فليس لأحد أن يخُصَّ مِنهُنَّ أمَةً ولا حُرَّةً. قالوا: ومعنى قوله: <span class="qpc-hafs">﴿فتياتكم المؤمنات﴾</span>: غير المشركات من عَبَدَة الأوثان».</div></p><p><div></p><p><p><span class="item-no">١٧٣٩٤<span class="dash">-</span></span> عن <span class="name-3">أبي حنيفة</span>، نحو ذلك{42}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧٣٩٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ... فيُكْرَه للعبد المسلم أن يتزوَّج وليدةً مِن أهل الكتاب؛ لأنّ ولده يصير عبدًا. فإن تزوَّجها، وولدت له؛ فإنّه يشتري من سيِّده رَضِي أو كره، ويسعى في ثمنه{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧٣٩٦<span class="dash">-</span></span> عن الوليد بن مسلم، قال: سمعت <span class="name-3">أبا عمرو [الأوزاعي]</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧٣٩٧<span class="dash">-</span></span> و<span class="name-3">سعيد بن عبد العزيز</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧٣٩٨<span class="dash">-</span></span> و<span class="name-3">أبا بكر بن عبد الله ابن أبي مريم</span>، يقولون: لا يحِلُّ لحُرٍّ مسلم ولا لعبدٍ مسلم الأمةُ النصرانيةُ؛ لأنّ الله يقول: <span class="qpc-hafs">﴿من فتياتكم المؤمنات﴾</span>، يعني: بالنكاح{44}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧٣٩٩<span class="dash">-</span></span> قال <span class="name-3">مالك بن أنس</span>: لا يحل نكاحُ أمَةٍ يهودية ولا نصرانية؛ لأنّ الله -تبارك وتعالى- يقول في كتابه: <span class="qpc-hafs">﴿والمحصنات من المؤمنات، والمحصنات من الذين أوتوا الكتاب من قبلكم﴾</span> [المائدة:٥]، فهُنَّ الحرائرُ من اليهوديات والنصرانيات. وقال الله -تبارك وتعالى-: <span class="qpc-hafs">﴿ومن لم يستطع منكم طولا أن ينكح المحصنات المؤمنات فمن ما ملكت أيمانكم من فتياتكم المؤمنات﴾</span>، فهُنَّ الإماء المؤمنات{45}<span class=comment-ref>١٦١٨</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>١٦١٨</span> المراد بالفتيات في الآية: الإماء. واختُلِف في نكاح الإماء غير المؤمنات على قولين: <b>أحدهما</b>: أنّه لا يجوز، فالإيمان شرط في نكاحهن، بدلالة قوله تعالى: <span class="qpc-hafs">﴿من فتياتكم المؤمنات﴾</span>. <b>والآخر</b>: أنّه جائز، بدلالة آية المائدة، وأما ما ورد هنا فهو على سبيل الندب، والإرشاد للأفضل، وليس شرطًا.</p><p>و<span class="comment-type-3">رَجَّحَ</span> <u>ابنُ جرير</u> (٦/٦٠٠) القولَ الأولَ، وهو قول مجاهد، وأبي عمرو، وسعيد بن عبد العزيز، ومالك بن أنس، وأبي بكر بن عبد الله بن أبي مريم <span class="mustanad">استنادًا إلى ظاهر الآية</span>، فقال: «أوْلى القولين في ذلك بالصواب قولُ مَن قال: هو دلالة على تحريم نكاح إماء أهل الكتاب؛ فإنّهُنَّ لا يحللن إلا بملك اليمين؛ وذلك أنّ الله -جل ثناؤه- أحلَّ نكاح الإماء بشروط، فما لم تجتمع الشروط التي سماهن فيهنَّ فغيرُ جائز لمسلم نكاحهن».</p><p>و<span class="comment-type-2">انتَقَدَ</span> (٦/٦٠١ بتصرف) القولَ الثاني <span class="mustanad">بأنّ آية النساء مُخَصِّصَة لآية المائدة</span>، فقال: «إن قال قائل: فإنّ الآية التي في المائدة تدل على إباحتهن بالنكاح. قيل: إنّ التي في المائدة قد أبان أنّ حكمها في خاصٍّ مِن محصناتهم وأنها معنيٌّ بها حرائرهم دون إمائهم قولُه: <span class="qpc-hafs">﴿من فتياتكم المؤمنات﴾</span>، فغيرُ جائزٍ أن يحكم لإحداهما بأنها دافعةٌ حكمَ الأخرى، إلا بحُجَّةٍ يجب التسليمُ لها من خبر أو قياس، ولا خبر بذلك ولا قياس، والآية محتملة ما قلنا: والمحصنات من حرائر الذين أوتوا الكتاب من قبلكم دون إمائهم».</div></p><p><h3><span class="qpc-hafs">﴿وَٱللَّهُ أَعۡلَمُ بِإِیمَـٰنِكُمۚ بَعۡضُكُم مِّنۢ بَعۡضࣲۚ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">١٧٤٠٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثُمَّ قال سبحانه: <span class="qpc-hafs">﴿والله أعلم بإيمانكم﴾</span> من غيره ...، <span class="qpc-hafs">﴿بعضكم من بعض﴾</span> يتزوج هذا وليدةَ هذا، وهذا وليدةَ هذا{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧٤٠١<span class="dash">-</span></span> عن <span class="name-3">مقاتل بن حيان</span> -من طريق بُكَيْر بن معروف- قال: ثُمَّ قال في التقديم: <span class="qpc-hafs">﴿والله أعلم بإيمانكم بعضكم من بعض﴾</span>، يقول: أنتم إخوةٌ بعضُكم من بعض{14}<span class=comment-ref>١٦١٩</span>. (٤/٣٣٩)</p></p><p></div></p><p><div><span class=comment-ref>١٦١٩</span> قال <u>ابنُ جرير</u> (٦/٦٠١) في بيان معنى الآية: «هذا من المُؤَخَّر الذي معناه التقديم. وتأويل ذلك: ومَن لم يستطع منكم طولًا أن ينكح المحصنات المؤمنات فمما ملكت أيمانكم من فتياتكم المؤمنات، فلينكح بعضُكم من بعض، بمعنى: فلينكح هذا فتاة هذا».</p><p>و<span class="comment-type-2">اسْتَدْرَكَ</span> <u>ابن عطية</u> (٢/٥٢٢) على كلام <u>ابن جرير</u> قائلًا: «هذا قولٌ ضعيفٌ»، ولم يذكر مستندًا.</div></p><p><h3><span class="qpc-hafs">﴿فَٱنكِحُوهُنَّ بِإِذۡنِ أَهۡلِهِنَّ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">١٧٤٠٢<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- <span class="qpc-hafs">﴿فانكحوهن بإذن أهلهن﴾</span> قال: بإذن مواليهن، <span class="qpc-hafs">﴿وآتوهن أجورهن﴾</span> قال: مهورهن{48}. (٤/٣٣٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧٤٠٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثُمَّ قال سبحانه: <span class="qpc-hafs">﴿فانكحوهن بإذن أهلهن﴾</span>، يقول: تزوجوا الولائد بإذن أربابهن{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧٤٠٤<span class="dash">-</span></span> عن <span class="name-3">مقاتل بن حيان</span> -من طريق بُكَيْر بن معروف- قوله: <span class="qpc-hafs">﴿بإذن أهلهن﴾</span>، قال: يعني: بإذن أربابهن{50}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَءَاتُوهُنَّ أُجُورَهُنَّ بِٱلۡمَعۡرُوفِ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">١٧٤٠٥<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- <span class="qpc-hafs">﴿وآتوهن أجورهن﴾</span>، قال: مُهورَهُنَّ{51}. (٤/٣٣٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧٤٠٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وآتوهن أجورهن﴾</span> يقول: وأعطوهن مهورَهن <span class="qpc-hafs">﴿بالمعروف﴾</span>{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧٤٠٧<span class="dash">-</span></span> عن <span class="name-3">مقاتل بن حيان</span> -من طريق بُكَيْر بن معروف- قوله: <span class="qpc-hafs">﴿وآتوهن أجورهن﴾</span> يعني: مهورهن <span class="qpc-hafs">﴿بالمعروف﴾</span>{50}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧٤٠٨<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- <span class="qpc-hafs">﴿وآتوهن أجورهن﴾</span>، قال: الصَّداق{54}<span class=comment-ref>١٦٢٠</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>١٦٢٠</span> قال <u>ابنُ جرير</u> (٦/٦٠٢): «يعني بقوله -جلَّ ثناؤه-: <span class="qpc-hafs">﴿فانكحوهن﴾</span> فتزوجوهُنَّ. وبقوله: <span class="qpc-hafs">﴿بإذن أهلهن﴾</span> بإذن أربابهن، وأمرهم إيّاكم بنكاحهن ورضاهم. ويعني بقوله: <span class="qpc-hafs">﴿وآتوهن أجورهن﴾</span> وأعطوهن مهورهن». <span class="mustanad">واستدَلَّ بأثر ابن زيد</span>.</div></p><p><h3><span class="qpc-hafs">﴿مُحۡصَنَـٰتٍ غَیۡرَ مُسَـٰفِحَـٰتࣲ وَلَا مُتَّخِذَ ٰ⁠تِ أَخۡدَانࣲۚ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">١٧٤٠٩<span class="dash">-</span></span> عن <span class="name-1">أبي هريرة</span>، في قوله: <span class="qpc-hafs">﴿ولا متخذات أخدان﴾</span>، قال: أخِلّاء{55}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧٤١٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي بن أبي طلحة- <span class="qpc-hafs">﴿محصنات غير مسافحات﴾</span> يعني: عفائف، غير زوانٍ في سِرٍّ ولا علانية، <span class="qpc-hafs">﴿ولا متخذات أخدان﴾</span> يعني: أخِلّاء{56}. (٤/٣٣٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧٤١١<span class="dash">-</span></span> وعن <span class="name-3">مقاتل بن حيان</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧٤١٢<span class="dash">-</span></span> و<span class="name-2">مجاهد بن جبر</span>، نحوه{55}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧٤١٣<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق العوفي- قال: المسافحاتُ: المعلِنات بالزنا. والمتخذات أخدان: ذاتُ الخَلِيل الواحد. قال: كان أهلُ الجاهلية يُحَرِّمون ما ظهر مِن الزِّنا، ويَسْتَحِلُّون ما خَفِي، يقولون: أمّا ما ظهر منه فهو لُؤْم، وأمّا ما خفي فلا بأس بذلك. فأنزل الله: <span class="qpc-hafs">﴿ولا تقربوا الفواحش ما ظهر منها وما بطن﴾</span> [الأنعام:١٥١]{58}. (٤/٣٣٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧٤١٤<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نَجِيح- في قوله: <span class="qpc-hafs">﴿ولا متخذات أخدان﴾</span>، قال: الخليلة يتخذها الرجل، والمرأة تتخذ الخليل{59}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧٤١٥<span class="dash">-</span></span> عن <span class="name-2">الضحاك بن مُزاحِم</span> -من طريق عبيد بن سليمان- يقول في قوله: <span class="qpc-hafs">﴿محصنات غير مسافحات ولا متخذات أخدان﴾</span>: أما المحصنات فهن الحرائر، يقول: تزوج حرة. وأما المسافحات: فهن المعلنات بغير مهر. وأما متخذات أخدان: فذات الخليل الواحد المُسْتَسِرَّة به. نهى اللهُ عن ذلك{60}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧٤١٦<span class="dash">-</span></span> عن <span class="name-2">عامر الشعبي</span> -من طريق داود- في هذه الآية: <span class="qpc-hafs">﴿غير مسافحات ولا متخذات أخدان﴾</span>، قال: الزِّنا زِناءان؛ المسافحة: السوق القائمة. والمتخذات أخدان: التي تتخذ خِدنًا واحدًا. فحرَّمهما الله جميعًا{61}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧٤١٧<span class="dash">-</span></span> عن <span class="name-2">عامر الشعبي</span> -من طريق إسماعيل بن سالم- قال: الزِّنا وجهان قبيحان: أحدُهما أخبثُ من الآخر؛ فأمّا الذي هو أخبثُهما فالمسافِحة التي تفجر بمن أتاها، وأما الآخر فذات الخِدْن{62}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧٤١٨<span class="dash">-</span></span> قال <span class="name-2">الحسن البصري</span> في قوله: <span class="qpc-hafs">﴿ولا متخدات أخدان﴾</span>: الصديق{55}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧٤١٩<span class="dash">-</span></span> قال <span class="name-2">الحسن البصري</span>: المسافِحة: هي أنّ كل مَن دعاها تبعته. وذات أخدان: أي: تختصُّ بواحد لا تزني إلا معه. والعرب كانت تُحَرِّم الأولى، وتُجَوِّزُ الثانية{64}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧٤٢٠<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دِعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿محصنات غير مسافحات ولا متخذات أخدان﴾</span>، قال: المسافحة: البغِيُّ التي تُؤاجِرُ نفسَها مَن عَرَض لها. وذات الخدن: ذات الخليل الواحد. فنهاهم الله عن نكاحهما جميعًا{65}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧٤٢١<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- قال: أما المحصناتُ فالعفائِفُ<span class=comment-ref>١٦٢١</span>، فلتُنكَحُ الأَمَةُ بإذن أهلِها مُحْصَنَةً -والمحصنات: العفائف-، غيرَ مُسافِحَةٍ -والمسافِحة: المُعالِنة بالزِّنا-، ولا متخذةً صديقًا{66}. (ز)</p></p><p></div></p><p><div><span class=comment-ref>١٦٢١</span> قال <u>ابنُ عطية</u> (٢/٥٢٢) <span class="comment-type-1">مُوَجِّهًا</span>: «الظاهر أنّه بمعنى: عفيفات؛ إذ غير ذلك مِن وجوه الإحصان بعيد، إلا مسلمات فإنّه يقرب».</div></p><p><div></p><p><p><span class="item-no">١٧٤٢٢<span class="dash">-</span></span> عن <span class="name-2">عطاء الخراساني</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧٤٢٣<span class="dash">-</span></span> و<span class="name-2">يحيى بن أبي كثير</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧٤٢٤<span class="dash">-</span></span> و<span class="name-3">مقاتل بن حيان</span>، في قوله: <span class="qpc-hafs">﴿ولا متخذات أخدان﴾</span>، قالوا: أخِلّاء{55}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧٤٢٥<span class="dash">-</span></span> قال <span class="name-2">أبو سعيد</span> -من طريق خلاد بن سليمان- في هذه الآية: <span class="qpc-hafs">﴿ولا متخذات أخدان﴾</span>، قال: وهو الصَدِيق{68}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧٤٢٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿محصنات﴾</span> عفائف لفروجهن، <span class="qpc-hafs">﴿غير مسافحات﴾</span> غير معلِنات بالزِّنا، <span class="qpc-hafs">﴿ولا متخذات أخدان﴾</span> يعني: أخِلّاء في السِّرِّ، فيزني بها سِرًّا{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧٤٢٧<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿محصنات غير مسافحات ولا متخذات أخدان﴾</span>، قال: المُسافِح: الذي يلقى المرأةَ فيفجر بها، ثم يذهب وتذهب. والمخادِن: الذي يقيم معها على معصيةِ الله وتقيم معه، فذاك الأخدان{62}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿فَإِذَاۤ أُحۡصِنَّ﴾</span> - قراءات</h3></p><p><div></p><p><p><span class="item-no">١٧٤٢٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن مسعود</span>، قرأ: ‹فَإذا أحْصَنَّ› بنصب الألف. وقال: إحصانُها: إسلامُها{71}. (٤/٣٤٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧٤٢٩<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق الحكم، عن سعيد ين جبير- أنّه قرأها: <span class="qpc-hafs">﴿فَإذا أُحْصِنَّ﴾</span>. يعني: برفع الألف. ويقول: أُحْصِنَّ بالأزواج. يقول: لا تُجلد أمَةٌ حتى تُزَوَّجَ{72}. (٤/٤٣٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧٤٣٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عكرمة- أنّه كان يقرأ: <span class="qpc-hafs">﴿فَإذا أُحْصِنَّ﴾</span>، يقول: فإذا تَزَوَجَّن{73}. (٤/٣٤١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧٤٣١<span class="dash">-</span></span> عن مغيرة: أنّ <span class="name-2">إبراهيم النخعي</span> كان يقرأ: ‹فَإذَآ أحْصَنَّ›. قال: إذا أسْلَمْنَ.= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧٤٣٢<span class="dash">-</span></span> وكان <span class="name-2">مجاهد</span> يقرأ: <span class="qpc-hafs">﴿فَإذا أُحْصِنَّ﴾</span>. يقول: إذا تَزَوَّجْنَ، ما لم تُزَوَّج فلا حَدَّ عليها{74}<span class=comment-ref>١٦٢٢</span>. (٤/٣٤٠)</p></p><p></div></p><p><div><span class=comment-ref>١٦٢٢</span> <span class="comment-type-4">علَّقَ</span> <u>ابنُ جرير</u> (٦/٦٠٥، ٦٠٨بتصرف) على القراءتين بقوله: «الصوابُ من القول في ذلك عندي: أنّهما قراءتان معروفتان مستفيضتان في أمصار الإسلام، فبأيتهما قرأ القارئ فمصيبٌ في قراءته الصوابَ، غير أنّ الذي نختار لمن قرأ: <span class="qpc-hafs">﴿مُحْصَناتٍ غَيْرَ مُسافِحاتٍ﴾</span> بفتح الصاد في هذا الموضع، أن يقرأ: <span class="qpc-hafs">﴿فَإذا أُحْصِنَّ فَإنْ أتَيْنَ بِفاحِشَةٍ﴾</span> بضم الألف. ولِمَن قرأ: ‹مُحْصِناتٍ› بكسر الصاد فيه، أن يقرأ: ‹فَإذَآ أحْصَنَّ› بفتح الألف؛ لتأتلف قراءة القارئ على معنًى واحد وسياق واحد؛ لقرب قوله: <span class="qpc-hafs">﴿محصنات﴾</span>، من قوله: <span class="qpc-hafs">﴿فإذا أحصن﴾</span>. ولو خالف من ذلك لم يكن لحنًا، غيرَ أنّ وجه القراءةِ ما وصفتُ».</div></p><p><h3><span class="qpc-hafs">﴿فَإِذَاۤ أُحۡصِنَّ﴾</span> - تفسير الآية</h3></p><p><div></p><p><p><span class="item-no">١٧٤٣٣<span class="dash">-</span></span> عن علي بن أبي طالب، قال: قال رسول الله ﷺ: <span class="qpc-hafs">﴿فَإذا أُحْصِنَّ﴾</span>، قال: «<b>إحصانُها: إسلامها</b>».= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧٤٣٤<span class="dash">-</span></span> وقال <span class="name-1">علي</span>: اجلِدُوهُنَّ{75}. (٤/٣٣٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧٤٣٥<span class="dash">-</span></span> عن عبد الله بن عباس، قال: قال رسول الله ﷺ: «<b>ليس على الأَمَةِ حَدٌّ حتى تُحَصَّن بزوج، فإذا أُحْصِنَت بزوجٍ فعليها نصفُ ما على المحصنات</b>»{76}. (٤/٣٤١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧٤٣٦<span class="dash">-</span></span> عن زيد بن خالد الجهني: أنّ النبي ﷺ سُئِل عن الأَمَةِ إذا زَنَت ولم تُحْصَن. قال: «<b>اجلدوها، ثم إن زنت فاجلدوها، ثم إن زنت فاجلدوها، ثم بيعوها ولو بضَفِيرٍ</b>»{77}<span class=comment-ref>١٦٢٣</span>. (٤/٣٤١-٣٤٢)</p></p><p></div></p><p><div><span class=comment-ref>١٦٢٣</span> <span class="comment-type-4">علَّق</span> <u>ابنُ عطية</u> (٢/٥٢٣-٥٢٤): «هذا الحديثُ والسؤالُ مِن الصحابة يقتضي أنّهم فهموا مِن القرآن أنّ معنى <span class="qpc-hafs">﴿أحصن﴾</span>: تَزَوَّجن. وجواب النبي ﷺ على ذلك يقتضي تقرير المعنى. ومن أراد أن يضعف قولَ مَن قال: إنّه الإسلام. بأن الصفة لهن بالإيمان قد تقدمت وتقررت، فذلك غير لازم؛ لأنه جائز أن يقطع في الكلام ويزيد: فإذا كن على هذه الحالة المتقدمة من الإيمان <span class="qpc-hafs">﴿فإن أتين بفاحشة فعليهن﴾</span>. وذلك سائغ صحيح».</p><p>و<span class="comment-type-2">اسْتَدْرَكَ</span> <u>ابنُ جرير</u> (٦/٦٠٧) <span class="mustanad">مستندًا إلى الإطلاق في اللفظ</span> قائلًا: «ليس في رواية مَن روى عن النبي ﷺ: أنّه سُئل عن الأمة تزني قبل أن تُحصن. بيانُ أن التي سُئِل عنها النبيُّ ﷺ هي التي تزني قبل التزويج، فيكون ذلك حُجَّة لِمُحْتَجٍّ في أنّ الإحصان الذي سنّ ﷺ حدَّ الإماء في الزنا هو الإسلام دون التزويج، ولا أنه هو التزويجُ دون الإسلام».</div></p><p><div></p><p><p><span class="item-no">١٧٤٣٧<span class="dash">-</span></span> عن أبي هريرة، قال: سمعتُ النبي ﷺ يقول: «<b>إذا زَنَتْ أمةُ أحدكم، فتبين زناها؛ فليجلدها الحدَّ، ولا يُثَرِّب عليها، ثم إن زنت الثالثة فتبين زناها فليبِعها، ولو بحبل من شعر</b>»{78}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧٤٣٨<span class="dash">-</span></span> عن <span class="name-1">عمر بن الخطاب</span> -من طريق محمد ابن شهاب الزهري- أنّه جلد ولائِد أبكارًا من ولائد الإمارة في الزِّنا{79}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧٤٣٩<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن مسعود</span> -من طريق مَعْقِل بن مُقَرِّن- أنّه سُئِل عن أمَةٍ زَنَتْ وليس لها زوج. فقال: اجلدوها خمسين جلدة. قال: إنّها لم تحصن. قال: إسلامُها إحصانُها{80}. (٤/٣٤٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧٤٤٠<span class="dash">-</span></span> وعن <span class="name-1">عبد الله بن عمر</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧٤٤١<span class="dash">-</span></span> و<span class="name-2">الأسود بن يزيد</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧٤٤٢<span class="dash">-</span></span> و<span class="name-2">سعيد بن جبير</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧٤٤٣<span class="dash">-</span></span> و<span class="name-2">عطاء</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧٤٤٤<span class="dash">-</span></span> و<span class="name-2">زر بن حبيش</span>، أنّهم قالوا: إحصانُها: إسلامُها{81}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧٤٤٥<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي بن أبي طلحة- <span class="qpc-hafs">﴿فإذا أحصن فإن أتين بفاحشة﴾</span>، يعني: إذا تزوَّجَتْ حُرًّا ثُمَّ زَنَت{82}. (٤/٣٣٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧٤٤٦<span class="dash">-</span></span> وعن <span class="name-2">عامر الشعبي</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧٤٤٧<span class="dash">-</span></span> و<span class="name-2">سعيد بن جبير</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧٤٤٨<span class="dash">-</span></span> و<span class="name-2">مجاهد بن جبر</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧٤٤٩<span class="dash">-</span></span> و<span class="name-2">الحسن البصري</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧٤٥٠<span class="dash">-</span></span> و<span class="name-2">قتادة بن دعامة</span>، نحو ذلك{83}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧٤٥١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق الحكم، عن سعيد بن جبير- قال: إنّما قال الله: <span class="qpc-hafs">﴿فَإذا أُحْصِنَّ﴾</span>، يعني: بالأزواج{84}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧٤٥٢<span class="dash">-</span></span> وعن <span class="name-2">الحسن البصري</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧٤٥٣<span class="dash">-</span></span> و<span class="name-2">مجاهد بن جبر</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧٤٥٤<span class="dash">-</span></span> و<span class="name-2">عكرمة مولى ابن عباس</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧٤٥٥<span class="dash">-</span></span> و<span class="name-2">قتادة بن دِعامة</span>، نحو ذلك{81}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧٤٥٦<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عمرو بن مرة، عن سعيد بن جبير- قال: إنّما قال الله: <span class="qpc-hafs">﴿فإذا أحصن فإن أتين بفاحشة فعليهن﴾</span> فليس يكون عليها حَدٌّ حتى تُحْصَن{86}. (٤/٣٤١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧٤٥٧<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>: أنّه كان لا يرى على الأمة حَدًّا حتى تزوج زوجًا حُرًّا{87}. (٤/٣٤١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧٤٥٨<span class="dash">-</span></span> وعن <span class="name-2">طاووس بن كيسان</span>، نحوه{88}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧٤٥٩<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق الشعبي- أنّه أصاب جاريةً له قد كانت زَنَتْ، وقال: أحصنتُها{89}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧٤٦٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عمر</span> -من طريق سالم- قال في الأَمَة إذا كانت ليست بذات زوجٍ فزَنَتْ: جُلِدَتْ نصف ما على المحصنات من العذاب{90}. (٤/٣٤٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧٤٦١<span class="dash">-</span></span> عن <span class="name-1">أنس بن مالك</span> -من طريق ثمامة بن عبد الله بن أنس- أنّه كان يضرب إماءَه الحَدَّ إذا زَنَيْنَ؛ تَزَوَّجْنَ أولم يَتَزَوَّجْنَ{91}. (٤/٣٤٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧٤٦٢<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span> -من طريق عمرو بن مُرَّة- يقول: لا تضرب الأمةُ إذا زَنَتْ ما لم تتزوج{92}<span class=comment-ref>١٦٢٤</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>١٦٢٤</span> <span class="comment-type-4">علَّقَ</span> <u>ابن كثير</u> (٣/٤٣٨) على قول سعيد هذا بقوله: «هذا إسناد صحيح عنه، ومذهب غريب إن أراد أنها لا تُضْرَب أصلًا لا حدًّا، وكأنه أخذ بمفهوم الآية، ولم يبلغه الحديث، وإن كان أراد أنها لا تُضْرَبُ حدًّا، ولا ينفي ضربها تأديبًا، فهو كقول ابن عباس ومَن تبعه في ذلك».</div></p><p><div></p><p><p><span class="item-no">١٧٤٦٣<span class="dash">-</span></span> عن <span class="name-2">إبراهيم النخعي</span> -من طريق مغيرة- ‹فَإذَآ أحْصَنَّ›. قال: إذا أسلمن{93}. (٤/٣٤٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧٤٦٤<span class="dash">-</span></span> عن <span class="name-2">سالم [بن عبد الله بن عمر]</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧٤٦٥<span class="dash">-</span></span> و<span class="name-2">القاسم [بن محمد بن أبي بكر]</span> -من طريق جابر- قالا: إحصانُها: إسلامُها وعفافُها، في قوله: <span class="qpc-hafs">﴿فإذا أحصن﴾</span>{94}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧٤٦٦<span class="dash">-</span></span> عن <span class="name-2">عامر الشعبي</span> -من طريق إسماعيل بن سالم- أنّه تلا هذه الآية: <span class="qpc-hafs">﴿فإذا أحصن﴾</span>. قال: يقول: إذا أسْلَمْنَ{95}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧٤٦٧<span class="dash">-</span></span> عن <span class="name-2">عامر الشعبي</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧٤٦٨<span class="dash">-</span></span> و<span class="name-2">إبراهيم النخعي</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧٤٦٩<span class="dash">-</span></span> و<span class="name-2">مجاهد بن جبر</span>، قالوا: لا يُحْصَن الحُرُّ إلا بالمسلمة الحُرَّة، ولا يُحْصَن بالمملوكة، ولا باليهودية، ولا بالنصرانية{81}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧٤٧٠<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ليث- قال: إحصانُ الأمة أن ينكحها الحُرُّ، وإحصانُ العبدِ أن ينكح الحُرَّة{92}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧٤٧١<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق قتادة- في قوله: <span class="qpc-hafs">﴿فإذا أحصن﴾</span>، قال: أحْصَنَتْهُنَّ البُعُولة{98}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧٤٧٢<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دِعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿فإذا أحصن﴾</span>، قال: أحصنتهنَّ البعولة{99}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧٤٧٣<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- <span class="qpc-hafs">﴿فإذا أحصن﴾</span>، يقول: إذا أسْلَمْنَ{79}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧٤٧٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فإذا أحصن﴾</span>، يعني: أسْلَمْنَ{101}<span class=comment-ref>١٦٢٥</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>١٦٢٥</span> أفادت الآثارُ الاختلافَ في معنى قوله تعالى: <span class="qpc-hafs">﴿فإذا أحصنّ﴾</span> على قولين: <b>أحدهما</b>: أنّ معناه: فإذا أسلمْنَ. وهذا قول عمر، وابن مسعود، والشعبي، وإبراهيم النخعي، والسدي، وسالم، والقاسم. <b>والآخر</b>: أنّ معناه: فإذا تزوجْنَ. وهذا قول ابن عباس، وعكرمة، ومجاهد، وسعيد بن جبير، والحسن، وقتادة، وغيرهم.</p><p>و<span class="comment-type-3">رجَّحَ</span> <u>ابنُ كثير</u> (٣/٤٣٤) القولَ الثاني ا<span class="mustanad">ستنادًا إلى السياق</span>، فقال: «الأظهر -والله أعلم- أنّ المراد بالإحصان هاهنا: التزويج؛ لأن سياق الآية يدل عليه، حيث يقول ﷾: <span class="qpc-hafs">﴿ومن لم يستطع منكم طولا أن ينكح المحصنات المؤمنات فمن ما ملكت أيمانكم من فتياتكم﴾</span> والله أعلم. والآية الكريمة سياقها كلها في الفتيات المؤمنات، فتعين أنّ المراد بقوله: <span class="qpc-hafs">﴿فإذا أحصن﴾</span> أي: تزوجن».</p><p>ثم أورد على كلٍّ من القولين إشكالًا على مذهب الجمهور، فقال: «يقولون: إنّ الأمة إذا زنت فعليها خمسون جلدة، سواء كانت مسلمة أو كافرة، مزوجة أو بكرًا. مع أن مفهوم الآية يقتضي أنه لا حدَّ على غير المحصنة ممن زنى من الإماء. وقد اختلفت أجوبتهم عن ذلك». وذكر أجوبة يطول ذكرها هنا، فلتراجع.</p><p>و<span class="comment-type-2">انتَقَدَ</span> <u>ابنُ جرير</u> (٦/٦٠٧-٦٠٨) قولَ مَن قصرها على التزويج؛ لأنها في سياق الفتيات المؤمنات، وبيّنَ أنّ الآية تحتمل التأويلين <span class="mustanad">استنادًا إلى صحته لغةً وعقلًا</span>، فقال: «غير مستحيل في الكلام أن يكون معنى ذلك: ومن لم يستطع منكم طولًا أن ينكح المحصنات المؤمنات فمما ملكت أيمانكم من فتياتكم المؤمنات، فإذا هنَّ آمنَّ فإن أتين بفاحشة فعليهن نصفُ ما على المحصنات من العذاب. فيكون الخبرُ مبتدأ عما يجب عليهنّ من الحدّ إذا أتين بفاحشة بعد إيمانهن، بعد البيان عما لا يجوز لناكحهن من المؤمنين من نكاحهن، وعمن يجوز نكاحه له منهن. فإذ كان ذلك غير مستحيل في الكلام، فغيرُ جائز لأحد صَرْف معناه إلى أنه التزويج دون الإسلام، من أجل ما تقدّم من وصف الله إيّاهن بالإيمان».</div></p><p><h3><span class="qpc-hafs">﴿فَإِنۡ أَتَیۡنَ بِفَـٰحِشَةࣲ فَعَلَیۡهِنَّ نِصۡفُ مَا عَلَى ٱلۡمُحۡصَنَـٰتِ مِنَ ٱلۡعَذَابِۚ﴾</span> - قراءات</h3></p><p><div></p><p><p><span class="item-no">١٧٤٧٥<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن مسعود</span> -من طريق أبي عبيدة بن عبد الله- أنّه كان يقرؤها: (فَإذَآ أحْصَنَّ فَإنْ أتَيْنَ بِفاحِشَةٍ فَعَلَيْهِنَّ نِصْفُ ما عَلى المُحْصَناتِ مِنَ العَذابِ خَمْسُونَ جَلْدَةً ولا نَفْيَ ولا رَجْمَ){102}. (٤/٣٤٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧٤٧٦<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span>، قال: في بعض القراءة: (فَإنْ أتَواْ أوْ أتَيْنَ بِفاحِشَةٍ){103}. (٤/٣٤٢)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿فَإِنۡ أَتَیۡنَ بِفَـٰحِشَةࣲ فَعَلَیۡهِنَّ نِصۡفُ مَا عَلَى ٱلۡمُحۡصَنَـٰتِ مِنَ ٱلۡعَذَابِۚ﴾</span> - تفسير الآية</h3></p><p><div></p><p><p><span class="item-no">١٧٤٧٧<span class="dash">-</span></span> عن <span class="name-1">عمر بن الخطاب</span> -من طريق عبد الله بن عياش بن أبي ربيعة- قال: أمرني عمر في فتيةٍ من قريش، فجَلَدْنا ولائدَ مِن ولائد الإمارة خمسين في الزِّنا{104}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧٤٧٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي بن أبي طلحة- <span class="qpc-hafs">﴿فعليهن نصف ما على المحصنات من العذاب﴾</span>، قال: مِن الجلد{105}. (٤/٣٣٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧٤٧٩<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span> -من طريق عطاء بن دينار- قوله: <span class="qpc-hafs">﴿فإن أتين بفاحشة﴾</span> يقول: فإن جئن بالزِّنا <span class="qpc-hafs">﴿فعليهن﴾</span> قال: فعلى الولاية <span class="qpc-hafs">﴿نصف ما على المحصنات﴾</span> قال: فعلى الولاية نصف ما على الحُرَّة مِن الجلد، وهي خمسون جلدة{106}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧٤٨٠<span class="dash">-</span></span> وعن <span class="name-2">إسماعيل السُّدِّيّ</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧٤٨١<span class="dash">-</span></span> و<span class="name-3">مقاتل بن حيان</span>، نحو ذلك{83}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧٤٨٢<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دِعامة</span> -من طريق سعيد- قوله: <span class="qpc-hafs">﴿فإن أتين بفاحشة فعليهن نصف ما على المحصنات من العذاب﴾</span>، قال: خمسون جلدة، ولا نفي، ولا رجم{108}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧٤٨٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فإن أتين بفاحشة﴾</span> يقول: فإن جئن بالزِّنا <span class="qpc-hafs">﴿فعليهن نصف ما على المحصنات من العذاب﴾</span> يعني: خمسين جلدة، نصف ما على الحُرَّة إذا زَنَتْ{101}<span class=comment-ref>١٦٢٦</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>١٦٢٦</span> <span class="comment-type-4">بيَّن</span> <u>ابنُ كثير</u> (٣/٤٤١ بتصرف) القولَ في حكم الأَمَة إذا زنت، فقال: «ملخص الآية: أنها إذا زنت أقوال: <b>أحدها</b>: أنها تجلد خمسين قبل الإحصان وبعده، وهل تنفى؟ فيه ثلاثة أقوال: أولها: أنها تنفى عنه. وثانيها: لا تنفى عنه مطلقًا. وثالثها: أنها تنفى نصف سنة، وهو نصف نفي الحرة. وهذا الخلاف في مذهب الشافعي. وأما أبو حنيفة فعنده أنّ النفي تعزيرٌ ليس من تمام الحد، وإنما هو رأي الإمام؛ إن شاء فعله وإن شاء تركه في حق الرجال والنساء. وعند مالك أنّ النفي إنما هو على الرجال، وأما النساء فلا؛ لأن ذلك مضاد لصيانتهن. والله أعلم. <b>والثاني</b>: أنّ الأَمَة إذا زنت تجلد خمسين بعد الإحصان، وتضرب قبله تأديبًا غير محدود بعدد محصور، وقد تقدم ما رواه ابن جرير عن سعيد بن جبير: أنها لا تضرب قبل الإحصان. وإن أراد نفيَه فيكون مذهبًا بالتأويل، وإلا فهو كالقول الثاني. <b>والثالث</b>: أنها تجلد قبل الإحصان مائة وبعده خمسين، كما هو المشهور عن داود، وهو أضعف الأقوال. <b>والرابع</b>: أنها تجلد قبل الإحصان خمسين وترجم بعده، وهو قول أبي ثور، وهو ضعيف أيضًا».</p><p>و<span class="comment-type-4">ذَهَبَ</span> <u>ابنُ جرير</u> (٦/٦١٢-٦١٣) <span class="mustanad">استنادًا إلى ظاهر الآية</span>، <span class="mustanad">وأقوال السلف</span> إلى أنّ على الأمة إذا زنت نصف المائة، ونصف المدة، فقال في تأويل قوله تعالى: <span class="qpc-hafs">﴿فعليهن نصف ما على المحصنات من العذاب﴾</span>: «يقول: فعليهن نصف ما على الحرائر من الحدِّ إذا هُنَّ زَنين قبل الإحصان بالأزواج. والعذاب الذي ذكره الله -تبارك وتعالى- في هذا الموضع هو الحدُّ، وذلك النصف الذي جعله الله عذابًا لمن أتى بالفاحشة من الإماء إذا هُنَّ أحصن: خمسون جلدة، ونَفي ستة أشهر، وذلك نصف عام؛ لأنّ الواجب على الحرة إذا هي أتت بفاحشة قبل الإحصان بالزوج جلد مائة، ونفي حَوْلٍ؛ فالنصف من ذلك خمسون جلدة، ونفي نصف سنة، وذلك الذي جعله الله عذابًا للإماء المحصنات إذا هن أتين بفاحشة».</div></p><p><h3><span class="qpc-hafs">﴿فَإِنۡ أَتَیۡنَ بِفَـٰحِشَةࣲ فَعَلَیۡهِنَّ نِصۡفُ مَا عَلَى ٱلۡمُحۡصَنَـٰتِ مِنَ ٱلۡعَذَابِۚ﴾</span> - آثار متعلقة بأحكام الآية</h3></p><p><div></p><p><p><span class="item-no">١٧٤٨٤<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عكرمة- قال: حَدُّ العبد يفتري على الحُرِّ أربعون{110}. (٤/٣٤٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧٤٨٥<span class="dash">-</span></span> عن <span class="name-2">عطاء [بن أبي رباح]</span> -من طريق ابن جُرَيْج- قال: إن افترى عبدٌ على حُرٍّ جُلِد أربعين؛ أحصن بنكاح امرأة أو لم يحصن. قلت: فإنهم يقولون: يجلد ثمانين. فأنكر ذلك، وتلا: <span class="qpc-hafs">﴿والذين يرمون المحصنات ثم لم يأتوا بأربعة شهداء فاجلدوهم ثمانين جلدة ولا تقبلوا لهم شهادة أبدا﴾</span>، ولا شهادة لعبد{111}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧٤٨٦<span class="dash">-</span></span> قال <span class="name-2">محمد ابن شهاب الزهري</span> -من طريق ابن أبي ذئب-: يجلد العبد في الفرية على الحُرِّ ثمانين{112}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿ذَ ٰ⁠لِكَ لِمَنۡ خَشِیَ ٱلۡعَنَتَ مِنكُمۡۚ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">١٧٤٨٧<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي بن أبي طلحة- <span class="qpc-hafs">﴿ذلك لمن خشي العنت﴾</span>، قال: الزِّنا، وهو الفجور، فليس لأحد من الأحرار أن ينكح أمةً إلّا ألّا يقدر على حُرَّةٍ، وهو يخشى العَنَت{113}. (٤/٣٣٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧٤٨٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>: أنّ نافع بن الأزرق سأله عن العَنَت. قال: الإثم. قال: وهل تعرف العرب ذلك؟ قال: نعم، أما سمعت قول الشاعر:</p><p>رأيتك تبتغي عَنَتِي وتسعى على السّاعِي عَلَيَّ بغير دخل{114}. (٤/٣٤٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧٤٨٩<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span> -من طريق أبي بشر- قال: العَنَتُ: الزِّنا{115}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧٤٩٠<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ليث- قوله: <span class="qpc-hafs">﴿لمن خشي العنت منكم﴾</span>، قال: الزِّنا{116}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧٤٩١<span class="dash">-</span></span> عن <span class="name-2">الضحاك بن مُزاحِم</span> -من طريق جُوَيْبِر- في قوله: <span class="qpc-hafs">﴿لمن خشي العنت منكم﴾</span>، قال: الزِّنا{117}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧٤٩٢<span class="dash">-</span></span> عن <span class="name-2">عامر الشعبي</span> -من طريق عبيدة- قال: العَنَت: الزِّنا{118}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧٤٩٣<span class="dash">-</span></span> وعن <span class="name-2">الحسن البصري</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧٤٩٤<span class="dash">-</span></span> و<span class="name-2">إسماعيل السُّدِّيّ</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧٤٩٥<span class="dash">-</span></span> و<span class="name-2">قتادة بن دِعامة</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧٤٩٦<span class="dash">-</span></span> و<span class="name-2">عمرو بن دينار</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧٤٩٧<span class="dash">-</span></span> و<span class="name-3">مقاتل بن حيان</span>، نحو ذلك{83}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧٤٩٨<span class="dash">-</span></span> عن <span class="name-2">عطية العوفي</span> -من طريق فضيل بن مرزوق- في قوله: <span class="qpc-hafs">﴿ذلك لمن خشي العنت منكم﴾</span>، قال: الزِّنا{120}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧٤٩٩<span class="dash">-</span></span> قال <span class="name-2">قتادة بن دِعامة</span>: إنّما أمر الله بنكاح الإماء المؤمنات لِمَن خشي العَنَت على نفسه، والعَنَتُ: الضيق، أي: لا يجد ما يَسْتَعِفُّ به، ولا يصبر؛ فيزني{121}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧٥٠٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ذلك﴾</span> التزويج للولائد <span class="qpc-hafs">﴿لمن خشي العنت منكم﴾</span> يعني: الإثم في دينه، وهو الزِّنا{122}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧٥٠١<span class="dash">-</span></span> قال <span class="name-3">مالك بن أنس</span>: ولا ينبغي لحُرِّ أن يتزوج أمَةً وهو يجد طَوْلًا لحُرَّة، ولا يتزوج أمَةً إذا لم يجد طَوْلًا لحُرَّة، إلا أن يخشى العَنَت؛ وذلك أنّ الله -تبارك وتعالى- قال في كتابه: <span class="qpc-hafs">﴿ومن لم يستطع منكم طولًا أن ينكح المحصنات المؤمنات فمن ما ملكت أيمانكم من فتياتكم المؤمنات﴾</span>، وقال: <span class="qpc-hafs">﴿ذلك لمن خشي العنت منكم﴾</span>. قال مالك: والعَنَتُ: هو الزِّنا{123}<span class=comment-ref>١٦٢٧</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>١٦٢٧</span> اختُلِف في معنى العنت في الآية على ثلاثة أقوال: <b>أولها</b>: أنّه الزِّنا. <b>وثانيها</b>: أنه الإثم. <b>وثالثها</b>: أنه الحدّ.</p><p>قال <u>ابنُ جرير</u> (٦/٦١٦) <span class="comment-type-1">مُوَجِّهًا</span> للأقوالِ: «الصواب من القول في قوله: <span class="qpc-hafs">﴿ذلك لمن خشي العنت منكم﴾</span>: ذلك لمن خاف منكم ضررًا في دينه وبَدنِه، وذلك أنّ العنت هو ما ضرّ الرجل، يقال منه: قد عَنِتَ فلان فهو يَعْنَتُ عَنتًا. إذا أتى ما يَضرّه في دين أو دنيا، ومنه قول الله تبارك وتعالى: <span class="qpc-hafs">﴿ودُّوا ما عَنِتُّمْ﴾</span>، ويقال: قد أعنتني فلان فهو يُعنِتني. إذا نالني بمضرة. وقد قيل: العنت: الهلاك. <b>فالذين وجهوا</b> تأويل ذلك إلى الزِّنا قالوا: الزِّنا ضَرَرٌ في الدين، وهو من العنت. <b>والذين وجّهوه</b> إلى الإثم قالوا: الآثام كلها ضرر في الدين، وهي من العنت. <b>والذين وجهوه</b> إلى العقوبة التي تعنته في بدنه من الحدّ فإنهم قالوا: الحدُّ مضرّة على بدن المحدود في دنياه، وهو من العنت. وقد عمّ الله بقوله: <span class="qpc-hafs">﴿لمن خشي العنت منكم﴾</span> جميعَ معاني العنت».</p><p>و<span class="comment-type-4">ذَهَبَ</span> <u>ابنُ عطية</u> (٢/٥٢٤) <span class="mustanad">استنادًا إلى عموم لفظ الآية</span> أنّ الآية تحتمل ذلك كله.</p><p>و<span class="comment-type-3">رَجَّح</span> <u>ابنُ جرير</u> (٦/٦١٦) أنّ المرادَ: الزنا؛ لأنّ مردّ ذلك كله إليه، <span class="mustanad">استنادًا إلى لغة العرب، واتفاق أهل التأويل</span>، فقال: «ويجمع جميعَ ذلك الزّنا؛ لأنه يوجب العقوبةَ على صاحبه في الدنيا بما يُعنِت بدنه، ويكتسب به إثمًا ومضرّة في دينه ودنياه. وقد اتفق أهلُ التأويل الذي هم أهله على أن ذلك معناه، فهو وإن كان في عينه لذةً وقضاءَ شهوة، فإنه بأدائه إلى العنت منسوبٌ إليه موصوف به؛ إذ كان للعنت سببًا».</div></p><p><h3><span class="qpc-hafs">﴿وَأَن تَصۡبِرُوا۟ خَیۡرࣱ لَّكُمۡۗ وَٱللَّهُ غَفُورࣱ رَّحِیمࣱ ۝٢٥﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">١٧٥٠٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن مسعود</span> -من طريق أبي عبيدة بن عبد الله- <span class="qpc-hafs">﴿وأن تصبروا خير لكم﴾</span>، قال: عن نكاح الإماء{124}. (٤/٣٤٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧٥٠٣<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي بن أبي طلحة- قال: <span class="qpc-hafs">﴿وأن تصبروا﴾</span> عن نكاح الإماء فهو <span class="qpc-hafs">﴿خير لكم﴾</span>{125}. (٤/٣٣٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧٥٠٤<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span> -من طريق أبي بشر- <span class="qpc-hafs">﴿وأن تصبروا خير لكم﴾</span>، قال: عن نكاح الإماء{126}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧٥٠٥<span class="dash">-</span></span> وقال <span class="name-2">الضحاك بن مزاحم</span>، كذلك{127}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧٥٠٦<span class="dash">-</span></span> وعن <span class="name-2">جابر بن زيد</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧٥٠٧<span class="dash">-</span></span> و<span class="name-2">الحسن البصري</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧٥٠٨<span class="dash">-</span></span> و<span class="name-3">مقاتل بن حيان</span>، نحو ذلك{128}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧٥٠٩<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ليث- <span class="qpc-hafs">﴿وأن تصبروا خير لكم﴾</span>، قال: عن نكاح الإماء{129}. (٤/٣٤٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧٥١٠<span class="dash">-</span></span> عن <span class="name-2">طاووس بن كيسان</span> -من طريق ابن طاووس- <span class="qpc-hafs">﴿وأن تصبروا خير لكم﴾</span>، قال: أن تصبروا عن نكاح الأَمَة خيرٌ لكم{130}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧٥١١<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span> -من طريق ابن جُرَيج-: وأن تصبروا عن نكاح الأمة خيرٌ، وهو حِلٌّ لكم؛ استرقاقُ أولادهن{131}. (٤/٣٤٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧٥١٢<span class="dash">-</span></span> عن <span class="name-2">عطية العوفي</span> -من طريق فضيل بن مرزوق- في قوله: <span class="qpc-hafs">﴿وأن تصبروا خير لكم﴾</span>، قال: أن تصبروا عن نكاح الإماء خير لكم{132}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧٥١٣<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دِعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿وأن تصبروا خير لكم﴾</span>، يقول: وأن تصبروا عن نكاحهن -يعني: نكاح الإماء- خيرٌ لكم{132}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧٥١٤<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- في الآية، قال: إن تصبر ولا تنكح الأمة -فيكون ولدك مملوكين- فهو خير لك{134}. (٤/٣٤٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧٥١٥<span class="dash">-</span></span> عن <span class="name-3">محمد بن إسحاق</span> -من طريق سلمة- قوله: <span class="qpc-hafs">﴿والله غفور﴾</span> أي: غفر الذنب، <span class="qpc-hafs">﴿رحيم﴾</span> قال: يرحم العباد على ما فيهم{135}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧٥١٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وأن﴾</span> يعني: ولَئن <span class="qpc-hafs">﴿تصبروا﴾</span> عن تزويج الأمة <span class="qpc-hafs">﴿خير لكم﴾</span> من تزويجهن، <span class="qpc-hafs">﴿والله غفور﴾</span> لتزويجه الأمة، <span class="qpc-hafs">﴿رحيم﴾</span> به حين رَخَّص له في تزويجها إذا لم يَجِد طَوْلًا، يعني: سَعَة في تزويج الحُرَّة{122}<span class=comment-ref>١٦٢٨</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>١٦٢٨</span> <span class="comment-type-4">بَيَّن</span> <u>ابن جرير</u> (٦/٦١٧) معنى الآية <span class="mustanad">مستندًا إلى أقوال السلف</span>، فقال: «يعني -جل ثناؤه- بذلك: وأن تصبروا أيها الناس عن نكاح الإماء خيرٌ لكم، والله غفور لكم نكاحَ الإماء أن تنكحوهن على ما أحلّ لكم وأذن لكم به، وما سلف منكم في ذلك؛ إن أصلحتم أمورَ أنفسكم فيما بينكم وبين الله، رحيمٌ بكم إذ أذن لكم في نكاحهن عند الافتقار وعدم الطَّوْل للحُرَّة».</p><p>وقال <u>ابنُ كثير</u> (٣/٤٤٢): «من هذه الآية الكريمة استدلَّ جمهورُ العلماء في جواز نكاح الإماء على أنّه لا بد من عدم الطول لنكاح الحرائر، ومن خوف العنت؛ لما في نكاحهن من مفسدةِ رقِّ الأولاد، ولما فيهن من الدناءة في العدول عن الحرائر إليهن. وخالف الجمهورَ أبو حنيفة وأصحابه في اشتراط الأمرين، فقالوا: متى لم يكن الرجل مُزَوَّجًا بحُرَّة جاز له نكاح الأمة المؤمنة والكتابية أيضًا، سواء كان واجدًا الطول لحرة أم لا، وسواء خاف العنت أم لا، وعمدتهم فيما ذهبوا إليه قوله تعالى: <span class="qpc-hafs">﴿والمحصنات من الذين أوتوا الكتاب من قبلكم﴾</span> [المائدة:٥] أي: العفائف، وهو يعمّ الحرائر والإماء، وهذه الآية عامة، وهذه أيضًا ظاهرة في الدلالة على ما قاله الجمهور».</div></p><p><h3><span class="qpc-hafs">﴿وَأَن تَصۡبِرُوا۟ خَیۡرࣱ لَّكُمۡۗ وَٱللَّهُ غَفُورࣱ رَّحِیمࣱ ۝٢٥﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">١٧٥١٧<span class="dash">-</span></span> عن يونس بن مِرداس -وكان خادمًا لأنس- قال: كُنت بين أنس وأبي هريرة، فقال أنس: سمعتُ رسول الله ﷺ يقول: «<b>مَن أحَبَّ أن يلقى الله طاهرًا مُطَهَّرًا فليتزوج الحرائر</b>». فقال أبو هريرة: سمعتُ رسول الله ﷺ يقول: «<b>الحرائر صلاح البيت، والإماء فساد البيت</b>»{137}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧٥١٨<span class="dash">-</span></span> عن <span class="name-1">عمر بن الخطاب</span> -من طريق سعيد بن المسيب- قال: إذا نكح العبدُ الحُرَّةَ فقد أعتق نصفه، وإذا نكح الحرُّ الأمةَ فقد أرَقَّ نصفه{138}. (٤/٣٤٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧٥١٩<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق العوام، عمَّن حدَّثه- قال: ما تَزَحَّف ناكِحُ الإماءِ عن الزِّنا إلا قليلًا{139}. (٤/٣٤٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧٥٢٠<span class="dash">-</span></span> عن <span class="name-1">أبي هريرة</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧٥٢١<span class="dash">-</span></span> و<span class="name-2">سعيد بن جبير</span> -من طريق ابن جريج-، مثله{140}. (٤/٣٤٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧٥٢٢<span class="dash">-</span></span> عن <span class="name-2">عامر الشعبي</span> -من طريق حميد- قال: نكاح الأمة كالميتة والدم ولحم الخنزير؛ لا يَحِلُّ إلا للمضطر{32}. (٤/٣٤٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧٥٢٣<span class="dash">-</span></span> عن <span class="name-2">طاووس بن كيسان</span> -من طريق ابن طاووس- قال: لا تجتمع الأَمَةُ والحُرَّةُ في النكاح عند الرجل{142}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ٦/٥٩٢، وابن المنذر ٢/٦٤٦، وابن أبي حاتم ٣/٩٢٠، والبيهقي في سُنَنِه ٧/١٧٣.|2:أخرجه الثعلبي ٣/٢٨٩.|3:أخرجه سعيد بن منصور في سننه (ت: سعد آل حميد) ٤/١٢٢٨ (٦١٧) وزاد: إذا لم يجد ما ينكح به الحرةَ تزوج أمةً، وابن جرير ٦/٥٩٢. وعلَّقه ابن أبي حاتم ٣/٩٢٠. وفي لفظ عند ابن جرير ٦/٥٩٢: السعة.|4:علَّقه ابن أبي حاتم ٣/٩٢٠.|5:أخرجه عبد الله بن وهب في الجامع - تفسير القرآن ٢/٨٩ (١٦٨) واللفظ له، وابن جرير ٦/٥٩٦، وابن المنذر ٢/٦٤٦، والبيهقي ٧/١٧٤. وعلَّقه ابن أبي حاتم ٣/٩٢٠. وعزاه السيوطي إلى عبد بن حميد.|6:أخرجه ابن جرير ٦/٥٩٣. وعلَّقه ابن أبي حاتم ٣/٩٢٠ بلفظ: الطَّوْلُ: الغِنى.|7:أخرجه عبد الله بن وهب في الجامع - تفسير القرآن ٢/٨٩ (١٦٨)، وابن جرير ٦/٥٩٣، وابن أبي حاتم ٣/٩٢٠.|8:تفسير مقاتل بن سليمان ١/٣٦٧.|9:أخرجه ابن جرير ٦/٥٩٣.|10:أخرجه عبد الرزاق (١٣٠٩٩، ١٣١٠١)، وابن أبي شيبة ٤/١٤٨، وابن جرير ٦/٥٩٧.|11:أخرجه ابن المنذر ٢/٦٤٧-٦٤٨.|12:أخرجه ابن جرير ٦/٥٩٤ واللفظ له، وابن المنذر ٢/٦٤٨ بلفظ: مَن وجد صداق حُرِّةٍ فلا ينكح أمَةً.|13:أخرجه ابن جرير ٦/٥٩٤. وعلَّق ابن المنذر ٢/٦٤٨ نحوه عن الشعبي.|14:أخرجه ابن أبي حاتم ٣/٩٢١.|15:ذكره عبد بن حميد كما في قطعة من تفسيره ص٨٣.|16:أخرجه ابن أبي شيبة ٤/١٤٧، وابن المنذر ٢/٦٤٨.|17:أخرجه ابن المنذر ٢/٦٤٨.|18:أخرجه ابن أبي شيبة ٤/١٦٠.|19:أخرجه البيهقي ٧/١٧٥.|20:أخرجه ابن جرير ٦/٥٩٤.|21:أخرجه ابن المنذر ٢/٦٤٩.|22:أخرجه ابن جرير ٦/٥٩٣، وابن أبي حاتم ٣/٩٢٠.|23:أخرجه ابن جرير ٦/٥٩٣.|24:أخرجه ابن جرير ٦/٥٩٧.|25:أخرجه ابن جرير ٦/٥٩٦، وابن المنذر ١/٦٤٧، وابن أبي حاتم ٣/٩٢٠، والبيهقي في سُنَنِه ٧/١٧٣.|26:علَّقه ابن أبي حاتم ٣/٩٢٠.|27:أخرجه ابن جرير ٦/٥٩٦، وابن المنذر ٢/٦٤٧، والبيهقي ٧/١٧٤. وعزاه السيوطي إلى عبد بن حميد.|28:أخرجه ابن أبي حاتم ٣/٩٢١.|29:أخرجه ابن أبي شيبة ٤/١٤٧، والبيهقي ٧/١٧٣.|30:أخرجه ابن جرير ٦/٥٩٦.|31:أخرجه ابن جرير ٦/٥٩٦، وابن المنذر ٢/٦٤٧، والبيهقي ٧/١٧٤. وعزاه السيوطي إلى عبد بن حميد.|32:أخرجه ابن أبي شيبة ٤/١٤٧.|33:أخرجه ابن جرير ٦/٥٩٦.|34:تفسير مقاتل بن سليمان ١/٣٦٧.|35:أخرجه ابن جرير ٦/٥٩٦، وابن المنذر (١٦٠١، ١٦٠٢، ١٦٣٥)، وابن أبي حاتم ٣/٩٢٠-٩٢٢، ٩٢٤، والبيهقي في سُنَنِه ٧/١٧٣.|36:علَّقه ابن أبي حاتم ٣/٩٢١.|37:أخرجه عبد الرزاق (١٣١٠٦)، وسعيد بن منصور (٦١٩ - تفسير)، وابن أبي شيبة ٤/١٦٠، والبيهقي ٧/١٧٧، كما أخرج ابن أبي حاتم ٣/٩٢١ نحوه من طريق ليث.|38:علَّقه ابن أبي حاتم ٣/٩٢١.|39:أخرجه ابن المنذر ٢/٦٤٩-٦٥٠. وذكر السيوطي نحوه بلفظ: إنما رخص في الأمة المسلمة لمن لم يجد طَوْلًا، وعزاه إليه وإلى البيهقي.|40:المدونة للإمام مالك ٢/٢١٩.|41:أخرجه ابن أبي شيبة ٤/١٦٠، وابن جرير ٦/٦٠٠.|42:علَّقه ابن جرير ٦/٦٠٠.|43:تفسير مقاتل بن سليمان ١/٣٦٧.|44:أخرجه ابن جرير ٦/٥٩٩.|45:الموطأ (ت: د. بشار عواد) ٢/٤٨ (١٥٥٠)، وأخرج ابن جرير ٦/٥٩٩ نحوه من طريق الوليد بن مسلم كما في الأثر السابق.|46:تفسير مقاتل بن سليمان ١/٣٦٧.|47:أخرجه ابن أبي حاتم ٣/٩٢١.|48:أخرجه ابن المنذر ٢/٦٥٠، وابن أبي حاتم ٣/٩٢٢ بنحوه.|49:تفسير مقاتل بن سليمان ١/٣٦٧.|50:أخرجه ابن أبي حاتم ٣/٩٢٢.|51:أخرجه ابن المنذر ٢/٦٥٠.|52:تفسير مقاتل بن سليمان ١/٣٦٧.|53:أخرجه ابن أبي حاتم ٣/٩٢٢.|54:أخرجه ابن جرير ٦/٦٠٢.|55:علَّقه ابن أبي حاتم ٣/٩٢٢.|56:أخرجه ابن جرير ٦/٦٠٣، وابن المنذر (١٦٠١، ١٦٠٢، ١٦٣٥)، وابن أبي حاتم ٣/٩٢٠-٩٢٢، ٩٢٤، والبيهقي في سُنَنِه ٧/١٧٣.|57:علَّقه ابن أبي حاتم ٣/٩٢٢.|58:أخرجه ابن جرير ٦/٦٠٣.|59:أخرجه ابن جرير ٦/٦٠٤، وابن المنذر ٢/٦٥١ من طريق ابن جُرَيج وزاد: فيقيم عليها وتقيم عليه، فأولئك الأخدان. وعلَّقه ابن أبي حاتم ٣/٩٢٢.|60:أخرجه ابن جرير ٦/٦٠٤، وابن المنذر ٢/٦٥١ من طريق جُوَيْبِر ولفظه: <span class="qpc-hafs">﴿ولا متخذات أخدان﴾</span> قال: أخِلّاء. وعلَّقه ابن أبي حاتم ٣/٩٢٢-٩٢٣.|61:أخرجه ابن المنذر ٢/٦٥١، وابن جرير ٦/٦٠٣ بلفظ: الزنا زناءان: تزني بالخِدن ولا تزني بغيره، وتكون المرأة سَوْمًا. وعلَّق ابن أبي حاتم ٣/٩٢٢ بعضه.|62:أخرجه ابن جرير ٦/٦٠٥.|63:علَّقه ابن أبي حاتم ٣/٩٢٢.|64:تفسير البغوي ٢/١٩٧.|65:أخرجه ابن جرير ٦/٦٠٤.|66:أخرجه ابن جرير ٦/٦٠٤. وعلَّق ابن أبي حاتم ٣/٩٢٢ بعضه.|67:علَّقه ابن أبي حاتم ٣/٩٢٢.|68:أخرجه عبد الله بن وهب في الجامع - تفسير القرآن ١/٩٨ (٢٢٤). وأورد قبله قول خلاد عن أبي سعيد هذا: «وكان قرأ القرآن على أبي هريرة». ولم نقف عليه.|69:تفسير مقاتل بن سليمان ١/٣٦٧.|70:أخرجه ابن جرير ٦/٦٠٥.|71:عزاه السيوطي إلى عَبد بن حُمَيد.</p><p>وهي قراءة متواترة، قرأ بها حمزة، والكسائي، وخلف العاشر، وشعبة، وقرأ بقية العشرة <span class="qpc-hafs">﴿فَإذا أُحْصِنَّ﴾</span> بضم الهمزة، وكسر الصاد. انظر: النشر ٢/٢٤٩، والإتحاف ص٢٤٠.|72:أخرجه ابن المنذر ٢/٦٥٢، وابن أبي حاتم ٣/٩٢٣ دون ذكر القراءة، والضياء في المختارة ١٠/١٥٦. وعزاه السيوطي إلى ابن مردويه.|73:أخرجه ابن أبي شيبة ٤/٣٩٤، وابن جرير ٦/٦١١.|74:أخرجه سعيد بن منصور (٦١٢ - تفسير). وعزاه السيوطي إلى عبد بن حميد.|75:أخرجه ابن أبي حاتم ٣/٩٢٣ (٥١٥٧).</p><p>وقال: «حديث منكر». وقال ابن كثير في تفسيره ٢/٢٦١: «وفي إسناده ضعف، ومنهم لم يُسَمَّ، ومثله لا تقوم به حجة».|76:أخرجه الطبراني في الأوسط ١/١٥٣ (٤٧٨)، ٤/١٤٧ (٣٨٣٤).</p><p>قال الطبراني: «لم يرفع هذا الحديثَ عن سفيان إلا عبد الله بن عمران العابدي». وقال البيهقي في معرفة السنن ١٢/٣٣٥ (١٦٩١٠، ١٦٩١١): «وهذا خطأ، ليس هذا من قول النبي ﷺ، إنما هو من قول ابن عباس، قاله أبو بكر محمد بن إسحاق بن خزيمة». وقال ابن القيسراني في أطراف الغرائب ٣/١٧٨ (٢٣٥٨): «غريب من حديث مسعر عن عمرو عنه، تفرد به سفيان بن عيينة عنه، وعنه عبد الله بن عمران العابدي مرفوعًا إلى النبي وغيره، يرويه عن ابن عيينة موقوفًا، ورواه ابن صاعد عنه مرة بتمامه، ومرة لم يجاوز به: «ليس على الأمة حد حتى تحصن»». وقال ابن الجوزي في العلل المتناهية ٢/٣٠٩ (١٣٢٧): «قال ابن شاهين: قد قيل: إن هذا الحديث موقوف على ابن عباس. ولا نعلم أحدًا جوّده غير عبد الله بن عمران». وقال ابن حجر في الفتح ١٢/١٦١: «وسنده حسن، لكن اختلف في رفعه ووقفه، والأرجح وقفه، وبذلك جزم ابن خزيمة وغيره».|77:أخرجه البخاري ٣/٧١ (٢١٥٣)، ٣/١٥٠ (٢٥٥٥)، ٣/٨٣ (٢٢٣٢)، ٨/١٧١ (٦٨٣٧)، ومسلم ٣/١٣٢٩ (١٧٠٣).|78:أخرجه البخاري ٣/٨٣ (٢٢٣٤)، ٨/١٧٢ (٦٨٣٩)، ومسلم ٣/١٣٢٨ (١٧٠٣)، وابن جرير ٦/٦٠٦.|79:أخرجه ابن جرير ٦/٦١٠.|80:أخرجه عبد الرزاق (١٣٦٠٤)، وابن جرير ٦/٦٠٩، وابن المنذر (١٦٢١)، والطبراني (٩٦٩١). وعزاه السيوطي إلى عبد بن حميد.|81:علَّقه ابن أبي حاتم ٣/٩٢٣.|82:أخرجه ابن جرير ٦/٦١١، وابن أبي حاتم ٣/٩٢٤. وعزاه السيوطي إلى ابن المنذر، والبيهقي في سُنَنِه.|83:علَّقه ابن أبي حاتم ٣/٩٢٤.|84:تقدم تخريجه قريبًا.|85:علَّقه ابن أبي حاتم ٣/٩٢٣.|86:أخرجه سعيد بن منصور (٦١٦ - تفسير)، وابن المنذر ٢/٦٥٢.|87:أخرجه عبد الرزاق (١٣٦١٨)، والبيهقي ٨/٢٤٣. وعزاه السيوطي إلى سعيد بن منصور.|88:تفسير البغوي ٢/١٩٨.|89:أخرجه ابن جرير ٦/٦١٢.|90:أخرجه عبد الرزاق (١٣٦١٠).|91:أخرجه ابن المنذر ٢/٦٥٣. وعزاه السيوطي إلى سعيد بن منصور.|92:أخرجه ابن جرير ٦/٦١١.|93:أخرجه ابن جرير ٦/٦١٠. وعلَّقه ابن أبي حاتم ٣/٩٢٣.|94:أخرجه ابن جرير ٦/٦١١. وعلَّقه ابن أبي حاتم ٣/٩٢٣.|95:أخرجه ابن جرير ٦/٦١٠، كما أخرج نحوه من طريق أشعث. وعلَّق ابن أبي حاتم ٣/٩٢٣ نحوه.|96:علَّقه ابن أبي حاتم ٣/٩٢٣.|97:أخرجه ابن جرير ٦/٦١١.|98:أخرجه ابن أبي شيبة في مصنفه (ت: محمد عوامة) ٩/٤٥٦ (١٧٨٦٩)، وابن جرير ٦/٦١٢، وابن المنذر ٢/٦٥٢.|99:أخرجه ابن أبي شيبة في مصنفه (ت: محمد عوامة) ٩/٤٥٦ (١٧٨٦٩)، وأخرجه ابن جرير ٦/٦١٢، وابن المنذر ٢/٦٥٢. وذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ١/٣٦٢-.|100:أخرجه ابن جرير ٦/٦١٠.|101:تفسير مقاتل بن سليمان ١/٣٦٧-٣٦٨.|102:أخرجه ابن المنذر ٢/٦٥٤. وعزاه السيوطي إليه فقط دون لفظ: كان يقرؤها.</p><p>وقراءة ابن مسعود شاذة؛ لمخالفتها رسم المصاحف.|103:عزاه السيوطي إلى عَبد بن حُمَيد.</p><p>وهي قراءة شاذة؛ لمخالفتها رسم المصاحف.|104:تفسير البغوي ٢/١٩٧-١٩٨.|105:أخرجه ابن أبي حاتم ٣/٩٢٤ واللفظ له، وابن جرير ٦/٦١٣ ومعنى لفظه: خمسون جلدة ونفي ستة أشهر. وعزاه السيوطي إلى ابن المنذر، والبيهقي في سُنَنِه.|106:أخرجه ابن أبي حاتم ٣/٩٢٣-٩٢٤.|107:علَّقه ابن أبي حاتم ٣/٩٢٤.|108:أخرجه ابن جرير ٦/٦١٣.|109:تفسير مقاتل بن سليمان ١/٣٦٧-٣٦٨.|110:أخرجه عبد الرزاق (١٣٧٩٠)، وابن المنذر ٢/٦٥٤.|111:أخرجه ابن المنذر ٢/٦٥٤.|112:أخرجه ابن المنذر ٢/٦٥٥.|113:أخرجه ابن أبي حاتم ٣/٩٢٤، والبيهقي في سُنَنِه ٧/١٧٣واللفظ لهما، كما أخرجه ابن جرير ٦/٦١٤، وابن المنذر ١/٦٥٥ مختصرًا.|114:عزاه السيوطي إلى الطستي في مسائله -كما في الإتقان ٢/٩١-.|115:أخرجه سعيد بن منصور في سننه (ت: سعد آل حميد) ٤/١٢٣١ (٦٢١).|116:أخرجه ابن جرير ٦/٦١٤. وعلَّقه ابن أبي حاتم ٣/٩٢٤.|117:أخرجه سعيد بن منصور (ت: سعد آل حميد) ٤/١٢٣١ (٦٢١)، وابن جرير ٦/٦١٥. وعلَّقه ابن أبي حاتم ٣/٩٢٤.|118:أخرجه ابن جرير ٦/٦١٥، وابن المنذر ٢/٦٥٥ عن الشعبي من طريق مغيرة.|119:علَّقه ابن أبي حاتم ٣/٩٢٤.|120:أخرجه ابن جرير ٦/٦١٥. وعلَّقه ابن أبي حاتم ٣/٩٢٤.|121:ذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ١/٣٦٢-.|122:تفسير مقاتل بن سليمان ١/٣٦٨.|123:موطأ مالك (ت: د. بشار عواد) ٢/٤٣-٤٤ (١٥٣٦).|124:أخرجه ابن المنذر ٢/٦٥٧.|125:أخرجه ابن جرير ٦/٦١٨، وابن المنذر ٢/٦٥٦، وابن أبي حاتم ٣/٩٢٤، والبيهقي في سُنَنِه ٧/١٧٣.|126:أخرجه سعيد بن منصور في سننه (ت: سعد آل حميد) ٤/١٢٢٨ (٦١٨)، وابن المنذر ٢/٦٥٦. وعلَّقه ابن أبي حاتم ٣/٩٢٥.|127:علَّقه ابن المنذر ٢/٦٥٦.|128:علَّقه ابن أبي حاتم ٣/٩٢٥.|129:أخرجه ابن جرير ٦/٦١٧، وابن المنذر ٢/٦٥٧ من طريق ابن أبي نجيح. وعلَّقه ابن أبي حاتم ٣/٩٢٥. وعزاه السيوطي إلى عبد بن حميد.|130:أخرجه عبد الرزاق في تفسيره ٢/٥٧، ومصنفه ٧/٢٦٧ (١٣٠٩٧)، وابن جرير ٦/٦١٨. وعلَّقه ابن المنذر ٢/٦٥٦، وابن أبي حاتم ٣/٩٢٥.|131:أخرجه ابن المنذر ٢/٦٥٦.|132:أخرجه ابن جرير ٦/٦١٨. وعلَّقه ابن أبي حاتم ٣/٩٢٥.|133:أخرجه ابن جرير ٦/٦١٨. وعلَّقه ابن أبي حاتم ٣/٩٢٥.|134:أخرجه ابن جرير ٦/٦١٧. وعلَّقه ابن أبي حاتم ٣/٩٢٥.|135:أخرجه ابن أبي حاتم ٣/٩٢٥.|136:تفسير مقاتل بن سليمان ١/٣٦٨.|137:أخرجه ابن ماجه ٣/٦٥ (١٨٦٢) دون كلام أبي هريرة. وأورده الثعلبي ٣/٢٨٩-٢٩٠ واللفظ له.</p><p>قال ابن عدي في الكامل ٤/٣٢٥ في ترجمة سلام بن سليمان: «لا أعلم رواه عن كثير بن سليم عن الضحاك عن ابن عباس إلا سلام هذا، وغيره قال: عن كثير بن سليم، عن الضحاك، عن النبي ﷺ مرسلًا، وروي عن نهشل عن الضحاك، عن ابن عباس، عن النبي ﷺ». وقال البوصيري في مصباح الزجاجة ٢/٩٨-٩٩: «هذا إسناد فيه كثير بن سليم، وهو ضعيف، وسلام هو ابن سليمان بن سوار المدائني ابن أخي شبابة بن سوار، قال ابن عدي: عنده مناكير. وقال العقيلي: في حديثه مناكير. ورواه أبو الفرج ابن الجوزي في الموضوعات من طريق هشام بن عمار به، وأعله بكثير بن سليمان، فقال: قال ابن حبان: يروى عن أنس بن مالك ما ليس من حديثه ويضع عليه». وقال ابن كثير في تفسيره ٦/١٢: «في إسناده ضعف». وقال السخاوي في المقاصد الحسنة ص٣٠٤ (٣٩٩): «وأحمد بن محمد متروك، كذبه أبو حاتم، ويونس مجهول». وقال المناوي في فيض القدير ٣/٤١١ (٣٨١١): «قال السخاوي وغيره: وفيه متروك». وقال في الفتح السماوي ٢/٤٧٨ (٣٥٨): «قال الحافظ ابن حجر: في إسناده أحمد بن محمد، وهو متروك، وكذبه أبو حاتم، ويونس لا نعرفه». وقال العجلوني في كشف الخفاء ١/٤٠٧ (١١٢٣): «رواه الثعلبي، بسند فيه أحمد بن محمد اليماني، متروك، عن يونس بن مرداس خادم أنس، وهو مجهول». وقال الشوكاني في الفوائد المجموعة ص١٢٣: «رواه ابن عدي عن علي وابن عباس، مرفوعًا، وفي إسناده خمسة كذابون». وقال الألباني في الضعيفة ٣/٦١١ (١٤١٧): «ضعيف». وقال في ٨/٢١ (٣٥٢٢): «موضوع».|138:أخرجه عبد الرزاق (١٣١٠٣)، وابن أبي شيبة ٤/١٤٧.|139:أخرجه سعيد بن منصور (٦٢٠ - تفسير)، وابن أبي شيبة ٤/١٤٦، وابن جرير ٦/٦١٤ بلفظ: ما ازلَحَفَّ.|140:أخرجه عبد الرزاق (١٣١٠٠)، كما أخرجه سعيد بن منصور في سننه (ت: سعد آل حميد) ٤/١٢٢٨ (٦١٨) عن سعيد بن جبير من طريق أبي بشر، كلاهما بلفظ: ما ازلَحَفَّ.|141:أخرجه ابن أبي شيبة ٤/١٤٧.|142:أخرجه عبد الرزاق في مصنفه ٧/٢٦٧ (١٣٠٩٧).
  4,26,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿یُرِیدُ ٱللَّهُ لِیُبَیِّنَ لَكُمۡ وَیَهۡدِیَكُمۡ سُنَنَ ٱلَّذِینَ مِن قَبۡلِكُمۡ وَیَتُوبَ عَلَیۡكُمۡۗ وَٱللَّهُ عَلِیمٌ حَكِیمࣱ ۝٢٦﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">١٧٥٢٤<span class="dash">-</span></span> قال <span class="name-2">الحسن البصري</span>: يعلمكم ما تأتون وما تَذَرون{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧٥٢٥<span class="dash">-</span></span> قال <span class="name-2">عطاء</span>: يبين لكم ما يُقَرِّبكم منه{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧٥٢٦<span class="dash">-</span></span> قال <span class="name-3">محمد بن السائب الكلبي</span>: يبين لكم أنّ الصبر عن نكاح الإماء خير لكم، <span class="qpc-hafs">﴿ويتوب عليكم﴾</span> أي: يتجاوز عنكم ما أصبتم قبل أن يبين لكم{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧٥٢٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿يريد الله ليبين لكم﴾</span> يعني: أن يبين لكم، <span class="qpc-hafs">﴿ويهديكم سنن الذين من قبلكم﴾</span> يعني: شرائع هدى مَن كان قبلكم من المؤمنين مِن تحريم النسب والصهر، <span class="qpc-hafs">﴿ويتوب عليكم﴾</span> يعني: ويتجاوز عنكم من نكاحكم، يعني: من تزويجكم إيّاهُنَّ مِن قَبْلِ التحريم، <span class="qpc-hafs">﴿والله عليم حكيم﴾</span>{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٧٥٢٨<span class="dash">-</span></span> عن <span class="name-3">مقاتل بن حيان</span> -من طريق بُكَيْر بن معروف- <span class="qpc-hafs">﴿يريد الله ليبين لكم ويهديكم سنن الذين من قبلكم﴾</span>، قال: من تحريم الأمهات والبنات، كذلك كان سنة الذين من قبلكم{5}<span class=comment-ref>١٦٢٩</span>. (٤/٣٤٥)</p></p><p></div></p><p><div><span class=comment-ref>١٦٢٩</span> <span class="comment-type-1">وجَّه</span> <u>ابن عطية</u> (٢/٥٢٦) هذا المعنى، فقال: «يظهر من قُوَّة هذا الكلام: أنَّ شرعتنا في المشروعات كشرعة من قبلنا. وليس ذلك كذلك، وإنما هذه الهداية في أحد أمرين: إما في أنّا خوطبنا في كل قصة نهيًا وأمرًا كما خوطبوا هم أيضًا في قصصهم، وشرع لنا كما شرع لهم، فهدينا سننهم في ذلك، وإن اختلفت أحكامنا وأحكامهم. والأمر الثاني: أن هدينا سننهم في أن أطعنا وسمعنا كما سمعوا وأطاعوا، فوقع التماثل من هذه الجهة».</div></p></div>",footnotes:1:تفسير الثعلبي ٣/٢٩٠.|2:تفسير الثعلبي ٣/٢٩٠، وتفسير البغوي ٢/١٩٨.|3:تفسير الثعلبي ٣/٢٩٠، وتفسير البغوي ٢/١٩٨ في شطره الأول.|4:تفسير مقاتل بن سليمان ١/٣٦٨.|5:أخرجه ابن أبي حاتم ٣/٩٢٥-٩٢٦.