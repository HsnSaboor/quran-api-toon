quran[19]{c,v,t}:
  26,1,"<div class=ar lang=ar><p><h3>مقدمة السورة</h3></p><p><div></p><p><p><span class="item-no">٥٥٥٦١<span class="dash">-</span></span> عن عبد الله بن عباس -من طريق خُصَيْف، عن مجاهد-: مكية{1}. (١١/٢٣٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٥٥٦٢<span class="dash">-</span></span> عن عبد الله بن عباس -من طريق أبي عمرو بن العلاء، عن مجاهد- قال: سورة الشعراء نزلت بمكة، سوى خمس آيات مِن آخرها نَزَلْن بالمدينة: <span class="qpc-hafs">﴿والشعراء يتبعهم الغاوون﴾</span> إلى آخرها [٢٢٤- ٢٢٧]{2}. (١١/٢٣٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٥٥٦٣<span class="dash">-</span></span> عن عبد الله بن عباس -من طريق عطاء الخراساني- قال: نزلت سورة <span class="qpc-hafs">﴿طسم﴾</span> الشعراء بمكة، ونزلت بعد الواقعة{3}. (١١/٢٣٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٥٥٦٤<span class="dash">-</span></span> عن عبد الله بن الزبير، قال: أُنزلت سورة الشعراء بمكة{4}. (١١/٢٣٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٥٥٦٥<span class="dash">-</span></span> عن عكرمة مولى ابن عباس= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٥٥٦٦<span class="dash">-</span></span> والحسن البصري -من طريق يزيد النحوي-: مكية، وسمَّياها: <span class="qpc-hafs">﴿طسم﴾</span>{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٥٥٦٧<span class="dash">-</span></span> عن قتادة بن دعامة -من طرق-: مكية{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٥٥٦٨<span class="dash">-</span></span> عن محمد ابن شهاب الزهري: مكية، ونزلت بعد الواقعة{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٥٥٦٩<span class="dash">-</span></span> عن علي بن أبي طلحة: مكية{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٥٥٧٠<span class="dash">-</span></span> قال مقاتل بن سليمان: مكية، غير آيتين فإنّهما مدنيتان: أحدهما: قوله تعالى: <span class="qpc-hafs">﴿أولم يكن لهم آية أن يعلمه﴾</span> الآية [١٩٧]، والأخرى: قوله تعالى: <span class="qpc-hafs">﴿والشعراء يتبعهم الغاوون﴾</span> [٢٢٤]. وبعض أهل التفسير يقول: إنّ مِن قوله تعالى: <span class="qpc-hafs">﴿والشعراء﴾</span> إلى آخرها -وهُنَّ أربع آيات [٢٢٤-٢٢٧]- مدنيات{9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٥٥٧١<span class="dash">-</span></span> قال يحيى بن سلّام: مكية كلها{10}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٥٥٧٢<span class="dash">-</span></span> عن مَعْدِيكرِبَ، قال: أتينا عبدَ الله بن مسعود نسأله عن <span class="qpc-hafs">﴿طسم﴾</span> الشعراء، قال: ليست معي، ولكن عليكم بِمَن أخذها مِن رسول الله ﷺ، عليكم بأبي عبد الله خباب بن الأَرَتَّ{11}. (١١/٢٣٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٥٥٧٣<span class="dash">-</span></span> عن مَعْدِيكرِبَ، قال: أتينا عبدَ الله بن مسعود، فسألناه أن يقرأ علينا: «طسم» المائتين، فقال: ما هي معي، ولكن عليكم بِمَن أخذها مِن رسول الله ﷺ؛ خَبّاب بن الأَرَتَّ. فأتيت خَبّابًا، فقلتُ: كيف كان رسول الله ﷺ يقرأ: <span class="qpc-hafs">﴿طسم﴾</span>، أو: <span class="qpc-hafs">﴿طس﴾</span> [النمل:١]؟ فقال: كلٌّ كان رسول الله ﷺ يقرأ{12}. (١١/٤٢١)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿طسۤمۤ ۝١﴾</span> - نزول الآية</h3></p><p><div></p><p><p><span class="item-no">٥٥٥٧٤<span class="dash">-</span></span> عن علي بن أبي طالب، قال: لَمّا نزلت هذه الآية <span class="qpc-hafs">﴿طسم﴾</span>؛ قال رسول الله ﷺ: <b>«الطاء: طور سيناء، والسين: الإسكندرية، والميم: مكة»</b>{13}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿طسۤمۤ ۝١﴾</span> - تفسير الآية</h3></p><p><div></p><p><p><span class="item-no">٥٥٥٧٥<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عكرمة- قال: <span class="qpc-hafs">﴿طسم﴾</span> عجزت العلماء عن تفسيرها{14}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٥٥٧٦<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي بن أبي طلحة- في قوله: <span class="qpc-hafs">﴿طسم﴾</span>، قال: فإنّه قَسَمٌ أقسمه الله، وهو مِن أسماء الله{15}<span class=comment-ref>٤٧٨١</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٤٧٨١</span> <span class="comment-type-1">وجّه</span> <u>ابنُ جرير</u> (١٧/٥٤٢) معنى الآية على قول ابن عباس، فقال: «فتأويل الكلام على قول ابن عباس: والسميعِ، إنّ هذه الآيات التي أنزلتها على محمد ﷺ في هذه السورة لآيات الكتاب الذي أنزلته إليه مِن قبلها الذي بُيِّن -لِمَن تدبَّره بفهم، وفكر فيه بعقل- أنّه مِن عند الله جل جلاله، لم يتخرصه محمد ﷺ، ولم يَتَقَوَّله من عنده، بل أوحاه إليه ربه».</p><p>وقال <u>ابنُ عطية</u> (٦/٥٦٨): «مَن قال: إنّ هذه الحروف مِن أسماء الله تعالى. قال: إنّ الطّاء مِن الطَّوْل الذي لله تعالى، والسّين مِن السّلام، والميم من المنعم، أو مِن الرحيم، ونحو هذا».</div></p><p><div></p><p><p><span class="item-no">٥٥٥٧٧<span class="dash">-</span></span> عن شعبة، قال: سألت السُّدِّيّ عن قوله جل وعز: <span class="qpc-hafs">﴿طسم﴾</span>. قال: قال <span class="name-1">ابن عباس</span>: هو اسم الله الأعظم{16}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٥٥٧٨<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span>: أنّه هجاء مقطوع{17}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٥٥٧٩<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span>: اسم للسورة{14}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٥٥٨٠<span class="dash">-</span></span> عن أبي بكر الهذلي أنّه سأل <span class="name-2">الحسن البصري</span> عن قول الله ﷿: <span class="qpc-hafs">﴿طسم﴾</span>. فقال: فواتِحُ افتتح اللهُ بها كتابَه، أو القرآن{19}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٥٥٨١<span class="dash">-</span></span> قال <span class="name-2">الحسن البصري</span>: لا أدري ما تفسيرها، غير أنّ قومًا مِن السلف كانوا يقولون فيها وأشباهها: أسماء السور، ومفاتحها{20}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٥٥٨٢<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق مَعْمَر- قال: اسم مِن أسماء القرآن{21}. (١١/٢٣٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٥٥٨٣<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- قوله: <span class="qpc-hafs">﴿طسم﴾</span>، قال: اسم مِن أسماء القرآن، أقسم به ربُّك{22}. (١١/٤٢١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٥٥٨٤<span class="dash">-</span></span> عن <span class="name-2">محمد بن كعب القرظي</span> -من طريق محمد بن إسحاق- في قوله <span class="qpc-hafs">﴿طسم﴾</span>، قال: الطاء مِن ذي الطَّوْل، والسين مِن القدوس، والميم مِن الرحمن{19}. (١١/٢٣٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٥٥٨٥<span class="dash">-</span></span> قال <span class="name-2">محمد بن كعب القرظي</span>: أقسم اللهُ بطَوْله، وسنائه، وملكه{14}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٥٥٨٦<span class="dash">-</span></span> قال <span class="name-2">إسماعيل السُّدِّيّ</span>: هذه حروف مِن الهجاء مِن الأسماء المُقَطَّعة{17}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٥٥٨٧<span class="dash">-</span></span> قال <span class="name-2">أبو رَوْق</span>: اسم مِن أسماء القرآن، أقسم الله به{26}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٥٥٨٨<span class="dash">-</span></span> قال <span class="name-3">جعفر الصادق</span>: الطاء: شجرة طوبى، والسين: سدرة المنتهى، والميم: محمد المصطفى ﷺ{26}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه البيهقي في دلائل النبوة ٧/١٤٣-١٤٤.أخرجه النحاس ص٦٠٧.أخرجه ابن الضريس في فضائل القرآن ١/٣٣-٣٥. وعزا السيوطي إلى ابن مردويه أوله.عزاه السيوطي إلى ابن مردويه.أخرجه البيهقي في دلائل النبوة ٧/١٤٢-١٤٣.أخرجه الحارث المحاسبي في فهم القرآن ص٣٩٥-٣٩٦ من طريق سعيد، وأبو بكر بن الأنباري -كما في الإتقان في علوم القرآن ١/٥٧- من طريق همام.تنزيل القرآن ص٣٧-٤٢.أخرجه أبو عبيد في فضائله (ت: الخياطي) ٢/٢٠٠.تفسير مقاتل ٣/٢٥٧.تفسير يحيى بن سلام ٢/٤٩٥.أخرجه أبو نعيم في الحلية ١/١٤٣.أخرجه أحمد ٧/٨٧ (٣٩٨٠). وعزاه السيوطي إلى ابن مردويه.</p><p>قال الهيثمي في المجمع ٧/٨٤ (١١٢٤٢): «رجاله ثقات». وقال السيوطي: «سند جيد».أخرجه الثعلبي ٧/١٥٦، من طريق عبد الله بن محمد بن عقيل، عن محمد بن الحنفية، عن علي بن أبي طالب به. وأورده الديلمي في الفردوس ٢/٤٥٩ (٣٩٦٤).</p><p>وسنده ضعيف؛ فيه عبد الله بن محمد بن عقيل، قال عنه ابن حجر في التقريب (٣٥٩٢): «صدوق، في حديثه لين، ويُقال: تغير بأخرة».تفسير الثعلبي ٧/١٥٦، وتفسير البغوي ٦/١٠٥.أخرجه ابن جرير ١٧/٥٤٢، وابن أبي حاتم ٨/٢٧٤٧، ٩/٢٩٣٨.أخرجه إسحاق البستي في تفسيره ص٥٣٠، وابن أبي حاتم ٩/٢٩٣٨، وفيه: سألت السدي عن قوله: <span class="qpc-hafs">﴿الم﴾</span> و<span class="qpc-hafs">﴿حم﴾</span> و<span class="qpc-hafs">﴿طسم﴾</span>.علَّقه ابن أبي حاتم ٨/٢٧٤٧.تفسير الثعلبي ٧/١٥٦، وتفسير البغوي ٦/١٠٥.أخرجه ابن أبي حاتم ٨/٢٧٤٧.علَّقه يحيى بن سلام ٢/٤٩٥.أخرجه يحيى بن سلام ٢/٤٩٥ من طريق عثمان، وعبد الرزاق ٢/٧٣، وابن جرير ١٧/٥٤٢، وابن أبي حاتم ٨/٢٧٤٧ من طريق سعيد. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه يحيى بن سلام ٢/٤٩٥، وابن أبي حاتم ٩/٢٩٣٨.أخرجه ابن أبي حاتم ٨/٢٧٤٧.تفسير الثعلبي ٧/١٥٦، وتفسير البغوي ٦/١٠٥.علَّقه ابن أبي حاتم ٨/٢٧٤٧.تفسير الثعلبي ٧/١٥٦.تفسير الثعلبي ٧/١٥٦.
  26,2,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿تِلۡكَ ءَایَـٰتُ ٱلۡكِتَـٰبِ ٱلۡمُبِینِ ۝٢﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٥٥٨٩<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span> -من طريق عطاء بن دينار- في قول الله: <span class="qpc-hafs">﴿الكتاب﴾</span>: يعني: القرآن{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٥٥٩٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٥٥٩١<span class="dash">-</span></span> و<span class="name-2">الحسن البصري</span>، مثل ذلك{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٥٥٩٢<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق أبي بكر- في هذه الآية: <span class="qpc-hafs">﴿تلك آيات الكتاب﴾</span>، قال: التوراة، والزَّبور{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٥٥٩٣<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد بن بشير- <span class="qpc-hafs">﴿الر تلك آيات الكتاب﴾</span> قال: الكتب التي خَلَتْ قَبْلَ القرآن <span class="qpc-hafs">﴿المبين﴾</span> قال: إي، واللهِ، تبين بركته، وهداه، ورشده{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٥٥٩٤<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد بن أبي عروبة- قوله: <span class="qpc-hafs">﴿طسم. تلك آيات الكتاب المبين﴾</span>: يعني: مبين -واللهِ- بركته ورشده وهُداه{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٥٥٩٥<span class="dash">-</span></span> عن <span class="name-2">مطر الورّاق</span> -من طريق الحسين بن واقد- <span class="qpc-hafs">﴿تلك آيات﴾</span>، قال: الزَّبور{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٥٥٩٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿تلك آيات الكتاب المبين﴾</span>، يعني ﷿: ما بيَّن فيه مِن أمره ونهيه، وحلاله وحرامه{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٥٥٩٧<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: قوله: <span class="qpc-hafs">﴿تلك آيات الكتاب﴾</span> هذه آيات الكتاب؛ القرآن، <span class="qpc-hafs">﴿المبين﴾</span> البيِّن{8}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن أبي حاتم ٨/٢٧٤٨.علَّقه ابن أبي حاتم ٨/٢٧٤٨.أخرجه ابن أبي حاتم ٨/٢٧٤٨، كما أورده عند تفسير قوله تعالى: <span class="qpc-hafs">﴿الر تِلْكَ آياتُ الكِتابِ الحَكِيمِ﴾</span> [يونس:١]، وقوله تعالى: <span class="qpc-hafs">﴿المر تِلْكَ آياتُ الكِتابِ﴾</span> [الرعد:١]، وصنع مثل مع الأثرين التاليين عن قتادة، ومطر الورّاق.أخرجه ابن أبي حاتم ٨/٢٧٤٨.أخرجه ابن جرير ١٨/١٤٩ في تفسير نظير هذه الآية في سورة القصص [٢]، وأشار قبل إيراده إلى أن المراد بالكتاب: القرآن.أخرجه ابن أبي حاتم ٨/٢٧٤٨.تفسير مقاتل بن سليمان ٣/٢٥٨.تفسير يحيى بن سلام ٢/٤٩٥.
  26,3,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿لَعَلَّكَ بَـٰخِعࣱ نَّفۡسَكَ أَلَّا یَكُونُوا۟ مُؤۡمِنِینَ ۝٣﴾</span> - نزول الآية</h3></p><p><div></p><p><p><span class="item-no">٥٥٥٩٨<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿لعلك باخع نفسك﴾</span> وذلك حين كذَّب به كُفّار مكة؛ منهم: الوليد بن المغيرة، وأبو جهل، وأمية بن خلف، فشَقَّ على النبي ﷺ تكذيبُهم إيّاه؛ فأنزل الله ﷿: <span class="qpc-hafs">﴿لعلك باخع نفسك﴾</span>{1}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿لَعَلَّكَ بَـٰخِعࣱ نَّفۡسَكَ أَلَّا یَكُونُوا۟ مُؤۡمِنِینَ ۝٣﴾</span> - تفسير الآية</h3></p><p><div></p><p><p><span class="item-no">٥٥٥٩٩<span class="dash">-</span></span> قال <span class="name-1">عبد الله بن عباس</span> -من طريق ابن جُرَيْج- <span class="qpc-hafs">﴿باخع نفسك﴾</span>: قاتِلٌ نفسَك{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٥٦٠٠<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق أبي يحيى- قوله: <span class="qpc-hafs">﴿لعلك باخع نفسك ألا يكونوا مؤمنين﴾</span>، قال: لعلَّك قاتِلٌ نفسَك إن لم يؤمنوا بهذا القرآن{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٥٦٠١<span class="dash">-</span></span> عن عبيد، قال: سمعتُ <span class="name-2">الضَّحاكَ بنَ مُزاحِم</span> يقول في قوله: <span class="qpc-hafs">﴿لعلك باخع نفسك﴾</span>: قاتل نفسك عليهم حِرْصًا{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٥٦٠٢<span class="dash">-</span></span> وعن <span class="name-2">الحسن البصري</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٥٦٠٣<span class="dash">-</span></span> و<span class="name-2">عكرمة مولى ابن عباس</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٥٦٠٤<span class="dash">-</span></span> و<span class="name-2">عطية العوفي</span>، مثل ذلك{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٥٦٠٥<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق مَعْمَر- في قوله: <span class="qpc-hafs">﴿لعلك باخع نفسك﴾</span>، قال: لعلك قاتِلٌ نفسَك{6}. (١١/٢٣٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٥٦٠٦<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- قوله: <span class="qpc-hafs">﴿لعلك باخع نفسك﴾</span>، قال: قاتل نفسك حزنًا إن لم يؤمنوا{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٥٦٠٧<span class="dash">-</span></span> عن <span class="name-2">عطاء الخراساني</span> -من طريق ابنه عثمان-: أمّا <span class="qpc-hafs">﴿لعلك باخع نفسك﴾</span> فيُقال: فعلَّك مُخْرِج نفسَك، وقاتلُها{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٥٦٠٨<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿لعلك﴾</span> يا محمد <span class="qpc-hafs">﴿باخع نفسك﴾</span> يعني: قاتلًا نفسك حزنًا؛ <span class="qpc-hafs">﴿ألا يكونوا مؤمنين﴾</span> يعني: ألّا يكونوا مُصَدِّقين بالقول بأنّه مِن عند الله ﷿. نظيرها في الكهف [٦]: <span class="qpc-hafs">﴿فَلَعَلَّكَ باخِعٌ نَفْسَكَ عَلى آثارِهِمْ﴾</span>{9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٥٦٠٩<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿لعلك باخع نفسك ألا يكونوا مؤمنين﴾</span>، قال: لعلك مِن الحِرْص على إيمانهم مُخْرِجٌ نفسَك مِن جسدك. قال: ذلك البَخْعُ{10}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٥٦١٠<span class="dash">-</span></span> عن <span class="name-3">سفيان بن عيينة</span> -من طريق ابن أبي عمر- في قوله: <span class="qpc-hafs">﴿لعلك باخع نفسك﴾</span>، قال: قاتِلٌ نفسَك{11}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٥٦١١<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: أي: فلا تفعل{12}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٣/٢٥٨ وهو مرسل.أخرجه ابن جرير ١٧/٥٤٣.أخرجه يحيى بن سلام ٢/٤٩٥، وابن أبي حاتم ٨/٢٧٤٨.أخرجه ابن جرير ١٧/٥٤٤، وإسحاق البستي في تفسيره ص٥٣٠. وعلَّقه ابن أبي حاتم ٨/٢٧٤٨.علَّقه ابن أبي حاتم ٨/٢٧٤٨.أخرجه عبد الرزاق ٢/٧٣، وابن جرير ١٧/٥٤٣. وعلَّقه ابن أبي حاتم ٨/٢٧٤٨-٢٧٥٠. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه ابن أبي حاتم ٨/٢٧٤٩.أخرجه ابن أبي حاتم ٨/٢٧٤٩.تفسير مقاتل بن سليمان ٣/٢٥٨.أخرجه ابن جرير ١٧/٥٤٣، وابن أبي حاتم ٨/٢٧٤٩ من طريق أصبغ.أخرجه إسحاق البستي في تفسيره ص٥٣٠.تفسير يحيى بن سلام ٢/٤٩٥، ذكره مُعَقبًا على تفسير مجاهد السابق.
  26,4,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿إِن نَّشَأۡ نُنَزِّلۡ عَلَیۡهِم مِّنَ ٱلسَّمَاۤءِ ءَایَةࣰ﴾</span> - نزول الآية</h3></p><p><div></p><p><p><span class="item-no">٥٥٦١٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق الكلبي، عن أبي صالح- حدَّثه، قال: نزلت هذه الآيةُ فينا وفي بني أُمَيَّة، قال: ستكون لنا عليهم الدولة، فتَذِلُّ لنا أعناقُهم بعدَ صعوبة، وهوان بعد عزة{1}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿إِن نَّشَأۡ نُنَزِّلۡ عَلَیۡهِم مِّنَ ٱلسَّمَاۤءِ ءَایَةࣰ﴾</span> - تفسير الآية</h3></p><p><div></p><p><p><span class="item-no">٥٥٦١٣<span class="dash">-</span></span> عن <span class="name-3">عبد الملك ابن جُرَيْج</span> -من طريق حجاج- <span class="qpc-hafs">﴿ألا يكونوا مؤمنين، إن نشأ ننزل عليهم من السماء آية﴾</span>، قال: لو شاء اللهُ لأراهم أمرًا مِن أمره، لا يعمل أحدٌ مِنهم بعده بمعصية{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٥٦١٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿إن نشأ﴾</span> يعني: لو نشاء <span class="qpc-hafs">﴿ننزل عليهم من السماء آية﴾</span>{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٥٦١٥<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>، في قوله: <span class="qpc-hafs">﴿إن نشأ ننزل عليهم من السماء آية فظلت أعناقهم﴾</span>: يعني: فصارت أعناقهم <span class="qpc-hafs">﴿لها﴾</span> للآية{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٥٦١٦<span class="dash">-</span></span> عن دازان -من طريق محمد بن كثير- في قوله: <span class="qpc-hafs">﴿ننزل عليهم من السماء﴾</span>: الشمس مِن مغربها{5}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿فَظَلَّتۡ أَعۡنَـٰقُهُمۡ لَهَا خَـٰضِعِینَ ۝٤﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٥٦١٧<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>: أنّ نافع بن الأزرق سأله عن قوله: <span class="qpc-hafs">﴿فظلت أعناقهم لها خاضعين﴾</span>. قال: العُنُق: الجماعة من الناس. قال: وهل تعرف العرب ذلك؟ قال: نعم، أما سمعت الحارثَ بن هشام وهو يقول ويذكر أبا جهل:</p><p>يخبرنا المخبر أن عمْرًا أمام القوم مِن عُنُق مَخِيل{6}{7}؟. (١١/٢٣٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٥٦١٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق العوفي- قوله: <span class="qpc-hafs">﴿فظلت أعناقهم لها خاضعين﴾</span>، قال: مُلْقِين أعناقَهم{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٥٦١٩<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، قوله: <span class="qpc-hafs">﴿فظلت أعناقهم لها خاضعين﴾</span>، قال: ذليلين{9}. (١١/٢٣٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٥٦٢٠<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن جريج- في قوله: <span class="qpc-hafs">﴿فظلت أعناقهم لها خاضعين﴾</span>، قال: فظلُّوا خاضعةً أعناقُهم لها{10}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٥٦٢١<span class="dash">-</span></span> قال <span class="name-2">مجاهد بن جبر</span>: أراد بالأعناق ههنا: الرؤساء، والكبراء{11}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٥٦٢٢<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق مَعْمَر- في قوله: <span class="qpc-hafs">﴿إن نشأ ننزل عليهم من السماء آية فظلت أعناقهم لها خاضعين﴾</span>، قال: لو شاء اللهُ أنزل عليهم آيةً يذِلُّون بها، فلا يلوي أحدُهم منهم عنقَه إلى معصية الله{12}. (١١/٢٣٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٥٦٢٣<span class="dash">-</span></span> عن <span class="name-2">أبي حمزة الثمالي</span> -من طريق علي بن علي- في هذه الآية قال: بلغنا- والله أعلم- أنّها صوت يُسمع من السماء في النصف من شهر رمضان تخرج له العواتق من البيوت{13}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٥٦٢٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فظلت﴾</span> يعني: فمالت <span class="qpc-hafs">﴿أعناقهم لها﴾</span> يعني: للآية <span class="qpc-hafs">﴿خاضعين﴾</span> يعني: مُقبلين إليها، مؤمنين بالآية{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٥٦٢٥<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿فظلت أعناقهم لها خاضعين﴾</span>، قال: الخاضِع الذَّلِيل{15}. (١١/٢٣٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٥٦٢٦<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: وذلك أنهم كانوا يسألون النبيَّ أن يأتيهم بآية، فهذا جوابٌ لقولهم{16}<span class=comment-ref>٤٧٨٢</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٤٧٨٢</span> أفادت الآثارُ اختلافَ السلف فيما عنى الله بقوله: <span class="qpc-hafs">﴿فظلت أعناقهم﴾</span>؛ <b>فقيل</b>: الجارحة المعلومة، أي: أعناق الرجال الذين نزلت عليهم الآية من السماء. <b>وقيل</b>: أراد بالأعناق: الكبراء والسادة. <b>وقيل</b>: الأعناق: الجماعة من الناس.</p><p>وقد <span class="comment-type-3">رجّح</span> <u>ابنُ جرير</u> (١٧/٥٤٨) القول الأول <span class="mustanad">مستندًا إلى اللغة، وأقوال أهل التأويل</span>، فقال: «وأولى الأقوال في ذلك بالصواب وأشبهها بما قال أهل التأويل في ذلك أن تكون الأعناق: هي أعناق الرجال. وأن يكون معنى الكلام: فظلت أعناقهم ذليلة للآية التي يُنزلها الله عليهم من السماء».</p><p>و<span class="comment-type-4">علّق</span> <u>ابنُ عطية</u> (٦/٤٧٠-٤٧١) على القول الأول، فقال: «فعلى هذا التأويل ليس في قوله: <span class="qpc-hafs">﴿خاضِعِينَ﴾</span> موضع قول». وقال: "فمعنى هذا التأويل: أن نتكلم على قوله: <span class="qpc-hafs">﴿خاضِعِينَ﴾</span> كيف جُمعَ جمْع مَن يعقل؟ وذلك متخرج على نحوين من كلام العرب: <b>أحدهما</b>: أنّ الإضافة إلى مَن يعقل أفادت حُكْمَه لِمَن لا يعقل، كما تفيد الإضافة إلى المؤنث تأنيث علامة المذكر، ومنه قول الأعشى:</p><p>كما شرقت صدر القناة من الدم</p><p>وهذا كثير. <b>والنحو الآخر</b>: أنّ الأعناق لَمّا وُصِفَت بفعل لا يكون إلا مقصود البشر، وهو الخضوع، إذ هو فعل يتبع أمرًا في النفس؛ جُمِعَت فيه جمع من يعقل. وهذا <span class="mustanad">نظير قوله تعالى</span>: <span class="qpc-hafs">﴿أتَيْنا طائِعِينَ﴾</span> [فصلت:١١]، وقوله: <span class="qpc-hafs">﴿رَأَيْتُهُمْ لِي ساجِدِينَ﴾</span> [يوسف:٤]".</div></p></div>",footnotes:1:أخرجه الثعلبي ٧/١٥٧.</p><p>إسناده ضعيف جدًّا. وينظر: مقدمة الموسوعة.</p><p>وقال ابن عاشور في التحرير ١٩/٩٧: «ومن بدع التفاسير وركيكها ما نسبه الثعلبي إلى ابن عباس -فذكره- وهذا مِن تحريف كلم القرآن عن مواضعه، ونحاشي ابن عباس ﵁ أن يقوله، وهو الذي دعا له رسول الله ﷺ بأن يعلمه التأويل. وهذا من موضوعات دعاة المُسَوِّدة مثل أبي مسلم الخراساني، وكم لهم في الموضوعات مِن اختلاق، والقرآن أجلُّ مِن أن يتعرض لهذه السفاسف».أخرجه ابن جرير ١٧/٥٤٥.تفسير مقاتل بن سليمان ٣/٢٥٨.تفسير يحيى بن سلام ٢/٤٩٥.أخرجه ابن أبي حاتم ٨/٢٧٤٩، كذا في المطبوع: عن دازان! ولم يتبين لنا من هو، ولم نجد في شيوخ محمد بن كثير العبدي (ت٢٢٣) مَن اسمه دازان أو قريبًا منه كزاذان، وقد يكون في المطبوع سقط وتحريف.مَخِيل: رَجُل أخْيَل ومَخِيل ومَخْيُول ومخول إذا كانت به الخال، وهو شامة سوداء في البدن. اللسان (خول).عزاه السيوطي إلى الطستي. والأثر في مسائل نافع (٢٥٤).أخرجه ابن جرير ١٧/٥٤٥.عزاه السيوطي إلى ابن جرير. وعند ابن جرير الأثر السابق.أخرجه ابن جرير ١٧/٥٤٥. وعلَّقه يحيى بن سلام ٢/٤٩٦.تفسير الثعلبي ٧/١٥٨، وتفسير البغوي ٦/١٠٦.أخرجه عبد الرزاق ٢/٧٣، وابن جرير ١٧/٥٤٤، وابن أبي حاتم ٨/٢٧٥٠. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه الثعلبي ٧/١٥٧.تفسير مقاتل بن سليمان ٣/٢٥٨.أخرجه ابن جرير ١٧/٥٤٥، وابن أبي حاتم ٨/٢٧٥٠ من طريق أصبغ.تفسير يحيى بن سلام ٢/٤٩٦.
  26,5,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَمَا یَأۡتِیهِم مِّن ذِكۡرࣲ مِّنَ ٱلرَّحۡمَـٰنِ مُحۡدَثٍ إِلَّا كَانُوا۟ عَنۡهُ مُعۡرِضِینَ ۝٥﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٥٦٢٧<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿وما يأتيهم من ذكر من الرحمن محدث﴾</span> الآية، يقول: ما يأتيهم مِن شيء مِن كتاب الله إلا أعْرَضوا عنه{1}. (١١/٢٣٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٥٦٢٨<span class="dash">-</span></span> قال <span class="name-2">قتادة بن دعامة</span>: <span class="qpc-hafs">﴿من الرحمن محدث إلا كانوا عنه معرضين﴾</span>، أي: كُلَّما نزل مِن القرآن شيءٌ جحدوا به{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٥٦٢٩<span class="dash">-</span></span> قال <span class="name-3">محمد بن السائب الكلبي</span>: كلما نزل شيء مِن القرآن بعد شيء فهو أحدثُ مِن الأول{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٥٦٣٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وما يأتيهم من ذكر من الرحمن محدث﴾</span> يقول: ما يُحْدِث اللهُ ﷿ إلى النبي ﷺ مِن القرآن <span class="qpc-hafs">﴿إلا كانوا عنه﴾</span> يعني: عن الإيمان بالقرآن <span class="qpc-hafs">﴿معرضين﴾</span>{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٥٦٣١<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: قوله: <span class="qpc-hafs">﴿وما يأتيهم من ذكر﴾</span>، يعني: القرآن{5}<span class=comment-ref>٤٧٨٣</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٤٧٨٣</span> أفادت الآثارُ تفسيرَ السلف للذِّكر بأنه القرآن، وقد ذكر <u>ابنُ عطية</u> (٦/٤٧١) في معنى الذكر <b>قولًا آخر</b> أن المراد به: محمد ﷺ. ثم <span class="comment-type-4">علّق</span> عليه، فقال: «وقالت فرقة: يحتمل أن يريد بـ»الذكر«: محمد ﷺ، <span class="mustanad">كما قال تعالى</span> في آية أخرى: <span class="qpc-hafs">﴿قَدْ أنْزَلَ اللَّهُ إلَيْكُمْ ذِكْرًا﴾</span> [الطلاق:١٠]، فيكون وصفه بالمحدث مُتَمَكِّنًا». يعني: فيكون وصف الذكر بالمحدث -على القول بأنه محمد ﷺ- له نفسه على الحقيقة، لا يحتاج إلى تأويل؛ بخلاف القول بأنه القرآن فإنه يحتاج إلى أن يقال: محدث الإتيان، أي: مجيء القرآن للبشر كان شيئًا بعد شيء، لا هو في نفسه. ثم <span class="comment-type-3">رجّح</span> القول الأول <span class="mustanad">لأنّه الأفصح</span> بقوله: «والقول الأول أفصح».</div></p></div>",footnotes:1:أخرجه ابن أبي حاتم ٨/٢٧٤٨. وعزاه السيوطي إلى عبد الرزاق، وعبد بن حميد، وابن جرير، وابن المنذر.علَّقه يحيى بن سلام ٢/٤٩٦.تفسير البغوي ٦/١٠٧.تفسير مقاتل بن سليمان ٣/٢٥٨.تفسير يحيى بن سلام ٢/٤٩٦.
  26,6,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿فَقَدۡ كَذَّبُوا۟ فَسَیَأۡتِیهِمۡ أَنۢبَـٰۤؤُا۟ مَا كَانُوا۟ بِهِۦ یَسۡتَهۡزِءُونَ ۝٦﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٥٦٣٢<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿فسيأتيهم﴾</span> يعني: يوم القيامة <span class="qpc-hafs">﴿أنباء ما﴾</span> استهزأوا به من كتاب الله{1}. (١١/٢٣٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٥٦٣٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فقد كذبوا بالحق﴾</span> يعني: بالقرآن <span class="qpc-hafs">﴿لما جاءهم﴾</span> يعني: حين جاءهم به محمد ﷺ، <span class="qpc-hafs">﴿فسيأتيهم أنباء﴾</span> يعني: حديث <span class="qpc-hafs">﴿ما كانوا به يستهزؤن﴾</span> وذلك أنّهم حين كذَّبوا بالقرآن أوْعَدَهُم الله ﷿ بالقتل ببدر{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٥٦٣٤<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿فقد كذبوا فسيأتيهم﴾</span> في الآخرة <span class="qpc-hafs">﴿أنباء ما كانوا به يستهزءون﴾</span> في الدنيا، وهو عذاب النار، فسيأتيهم تحقيق ذلك الخبر بدخولهم النار{3}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن أبي حاتم ٨/٢٧٤٨. وعزاه السيوطي إلى عبد الرزاق، وعبد بن حميد، وابن جرير، وابن المنذر.تفسير مقاتل بن سليمان ٣/٢٥٨.تفسير يحيى بن سلام ٢/٤٩٦.
  26,7,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿أَوَلَمۡ یَرَوۡا۟ إِلَى ٱلۡأَرۡضِ كَمۡ أَنۢبَتۡنَا فِیهَا مِن كُلِّ زَوۡجࣲ كَرِیمٍ ۝٧﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٥٦٣٥<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span> -من طريق عطاء بن دينار- قوله: <span class="qpc-hafs">﴿كريم﴾</span>: يعني: حسن{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٥٦٣٦<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿كم أنبتنا فيها من كل زوج كريم﴾</span>، قال: مِن نبات الأرض مِمّا يأكل الناس والأنعام{2}. (١١/٢٣٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٥٦٣٧<span class="dash">-</span></span> عن <span class="name-2">عامر الشعبي</span>، <span class="qpc-hafs">﴿كم أنبتنا فيها من كل زوج كريم﴾</span>، قال: الناسُ مِن نباتِ الأرض؛ فمَن دخل الجنة فهو كريمٌ، ومَن دخل النار فهو لئيمٌ{3}. (١١/٢٣٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٥٦٣٨<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق مَعْمَر- في قوله: <span class="qpc-hafs">﴿كم أنبتنا فيها من كل زوج كريم﴾</span>، قال: حَسَن{4}. (١١/٢٣٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٥٦٣٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثم وعَظَهم ليعتبروا، فقال ﷿: <span class="qpc-hafs">﴿أولم يروا إلى الأرض كم أنبتنا فيها من كل زوج كريم﴾</span>، يقول: كم أخرجنا مِن الأرض مِن كلِّ صِنف مِن ألوان النَّبت حَسَن{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٥٦٤٠<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: وهذا على الاستفهام، أي: قد رأوا كم أنبتنا في الأرض مِن كل زوج كريم مِمّا رَأَوْا{6}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن أبي حاتم ٨/٢٧٥٠.أخرجه ابن جرير ١٧/٥٥٠، كذلك من طريق ابن جريج، وابن أبي حاتم ٨/٢٧٥٠. وعزاه السيوطي إلى الفريابي، وعبد بن حميد، وابن المنذر. وعلَّق يحيى بن سلام ٢/٤٩٦ نحوه وزاد: وكل ما ينبت في الأرض فالواحد منه زوج.أخرجه ابن أبي حاتم ٨/٢٧٥٠. وعزاه السيوطي إلى الفريابي، وعبد بن حميد، وابن المنذر.أخرجه عبد الرزاق ٢/٧٣، وابن جرير ١٧/٥٥٠. وعلَّقه ابن أبي حاتم ٨/٢٧٥٠. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.تفسير مقاتل بن سليمان ٣/٢٥٨-٢٥٩.تفسير يحيى بن سلام ٢/٤٩٦.
  26,8,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿إِنَّ فِی ذَ ٰ⁠لِكَ لَـَٔایَةࣰۖ وَمَا كَانَ أَكۡثَرُهُم مُّؤۡمِنِینَ ۝٨﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٥٦٤١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق سعيد بن جبير- <span class="qpc-hafs">﴿ان في ذلك لآية﴾</span>، قال: علامة، ألم تر إلى الرجل إذا أراد أن يُرسل إلى أهله في حاجةٍ أرسل بخاتمه، أو بثوبه؛ فعرفوا أنّه حق{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٥٦٤٢<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span>، نحو ذلك{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٥٦٤٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿إن في ذلك لآية﴾</span> يقول: إنّ في النبت لعِبْرَة في توحيد الله ﷿ أنّه واحد، <span class="qpc-hafs">﴿وما كان أكثرهم﴾</span> يعني: أهل مكة <span class="qpc-hafs">﴿مؤمنين﴾</span> يعني: مُصَدِّقين بالتوحيد{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٥٦٤٤<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿إن في ذلك لآية﴾</span> لَمَعرِفة بأنّ الذي أنبت هذه الأزواج في الأرض قادِرٌ على أن يُحْيِي الموتى، قال: <span class="qpc-hafs">﴿وما كان أكثرهم مؤمنين﴾</span> يعني: مَن مضى مِن الأمم{4}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن أبي حاتم ٨/٢٧٥١، وأخرجه إسحاق البستي في تفسيره ص٥٣٥ بلفظ: هو الرجل يقول لأهله: علامة ما بيني وبينكم أن أرسل إليكم بخاتمي، أو آية كذا وكذا.أخرجه ابن أبي حاتم ٨/٢٧٥١.تفسير مقاتل بن سليمان ٣/٢٥٩.تفسير يحيى بن سلام ٢/٤٩٦.
  26,9,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَإِنَّ رَبَّكَ لَهُوَ ٱلۡعَزِیزُ ٱلرَّحِیمُ ۝٩﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٥٦٤٥<span class="dash">-</span></span> عن <span class="name-2">أبي العالية الرِّياحِيِّ</span> -من طريق الربيع بن أنس- <span class="qpc-hafs">﴿العزيز﴾</span>، قال: عزيز في نقمته إذا انتقم{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٥٦٤٦<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٥٦٤٧<span class="dash">-</span></span> <span class="name-2">والربيع بن أنس</span>، نحو ذلك{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٥٦٤٨<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span> -من طريق عطاء بن دينار- في قول الله: <span class="qpc-hafs">﴿الرحيم﴾</span>: يعني: رحيمًا بهم بعد التوبة{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٥٦٤٩<span class="dash">-</span></span> عن <span class="name-3">عبد الملك ابن جُرَيْج</span> -من طريق حجّاج- قال: كل شيءٍ في «الشعراء» من قوله: «عزيزٌ رحيم» فهو ما أهلك مِمَّن مضى مِن الأمم. يقول: عزيزٌ حين انتقم مِن أعدائه، رحيمٌ بالمؤمنين حين أنجاهم مِمّا أهلك به أعداءَه{4}<span class=comment-ref>٤٧٨٤</span>. (١١/٢٣٩)</p></p><p></div></p><p><div><span class=comment-ref>٤٧٨٤</span> بيّن <u>ابنُ جرير</u> (١٧/٥٥١) أن تفسير ابن جريج للـ<span class="qpc-hafs">﴿العزيز الرحيم﴾</span> غير متحقق في هذا الموطن، ومتحققٌ في بقية مواطن السورة، و<span class="comment-type-4">علّق</span> على تفسيره بقوله: «ولعلَّ ابن جريج بقوله هذا أراد ما كان مِن ذلك عقيب خبر الله عن إهلاكه مَن أهلك مِن الأمم، وذلك إن شاء الله إذا كان عقيب خبرهم كذلك». و<span class="comment-type-3">رجّح</span> <span class="mustanad">مستندًا إلى السياق</span> و<span class="comment-type-2">منتقدًا</span> قول ابن جريج أنّ معنى الآية: «إنّ ربك -يا محمد- لهو العزيز في نقمته، لا يمتنع عليه أحدٌ أراد الانتقام منه. <span class="qpc-hafs">﴿الرحيم﴾</span> يعني: أنه ذو الرحمة بِمَن تاب مِن خلقه مِن كفره ومعصيته، أن يعاقبه على ما سلف من جرمه بعد توبته. وإنما اخترنا القول الذي اخترناه في ذلك في هذا الموضع لأنّ قوله: <span class="qpc-hafs">﴿وإن ربك لهو العزيز الرحيم﴾</span> عقيب وعيد الله قومًا مِن أهل الشرك والتكذيب بالبعث لم يكونوا أهلكوا، فيوجه إلى أنه خبر مِن الله عن فعله بهم وإهلاكه».</div></p><p><div></p><p><p><span class="item-no">٥٥٦٥٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وإن ربك لهو العزيز﴾</span> في نقمته منهم ببدر، <span class="qpc-hafs">﴿الرحيم﴾</span> حين لا يعجل عليهم بالعقوبة إلى الوقت{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٥٦٥١<span class="dash">-</span></span> عن <span class="name-3">محمد بن إسحاق</span> -من طريق سلمة- <span class="qpc-hafs">﴿العزيز﴾</span>، قال: العزيز في نصرته مِمَّن كفر به إذا شاء{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٥٦٥٢<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: قوله ﷿: <span class="qpc-hafs">﴿وإن ربك لهو العزيز﴾</span> في نقمته، <span class="qpc-hafs">﴿الرحيم﴾</span> بخلقه، فأمّا المؤمن فتَتِمُّ عليه الرحمة في الآخرة، وأمّا الكافر فهو ما أعطاه في الدنيا، فليس له إلا رحمة الدنيا، وهي زائلة عنه، وليس له في الآخرة نصيب{7}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن أبي حاتم ٨/٢٧٥١.علَّقه ابن أبي حاتم ٨/٢٧٥١.أخرجه ابن أبي حاتم ٨/٢٧٥١.أخرجه ابن جرير ١٧/٥٥١.تفسير مقاتل بن سليمان ٣/٢٥٩، زاد محققه بعد كلمة «الوقت»: «المحدد لهم»؛ ليتضح المعنى.أخرجه ابن أبي حاتم ٨/٢٧٥١.تفسير يحيى بن سلام ٢/٤٩٦.
  26,10,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَإِذۡ نَادَىٰ رَبُّكَ مُوسَىٰۤ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٥٦٥٣<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- <span class="qpc-hafs">﴿وإذ نادى ربك موسى﴾</span>، قال: حين نُودِي مِن جانب الطور الأيمن{1}. (١١/٢٤٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٥٦٥٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وإذ نادى ربك﴾</span> يقول: وإذ أمر ربك -يا محمد- <span class="qpc-hafs">﴿موسى﴾</span>{2}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن أبي حاتم ٨/٢٧٥١.تفسير مقاتل بن سليمان ٣/٢٥٩.
  26,11,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿أَنِ ٱئۡتِ ٱلۡقَوۡمَ ٱلظَّـٰلِمِینَ ۝١٠ قَوۡمَ فِرۡعَوۡنَۚ أَلَا یَتَّقُونَ ۝١١﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٥٦٥٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿أن ائت القوم الظالمين﴾</span> يعني: المشركين؛ <span class="qpc-hafs">﴿قوم فرعون﴾</span> واسمه: فيطوس، بأرض مصر، وقل لهم يا موسى: <span class="qpc-hafs">﴿ألا يتقون﴾</span> يعني: ألا يعبدون الله ﷿{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٥٦٥٦<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: قوله ﷿: <span class="qpc-hafs">﴿قوم فرعون ألا يتقون﴾</span>، أي: فليتقوا الله{2}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٣/٢٥٩.تفسير يحيى بن سلام ٢/٤٩٦.
  26,12,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿قَالَ رَبِّ إِنِّیۤ أَخَافُ أَن یُكَذِّبُونِ ۝١٢ وَیَضِیقُ صَدۡرِی وَلَا یَنطَلِقُ لِسَانِی فَأَرۡسِلۡ إِلَىٰ هَـٰرُونَ ۝١٣﴾</span> - قراءات</h3></p><p><div></p><p><p><span class="item-no">٥٥٦٥٧<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: وهي تقرأ على وجهين: <span class="qpc-hafs">﴿ويَضِيقُ صَدْرِي﴾</span> بالرفع <span class="qpc-hafs">﴿ولا يَنْطَلِقُ لِسانِي﴾</span>، والحرف الآخر بالنصب: ‹ويَضِيقَ صَدْرِي ولا يَنْطَلِقَ لِسانِي›، أي: إني أخاف أن يكذبون، وأخاف أن يضيق صدري، ولا ينطلق لساني{1}<span class=comment-ref>٤٧٨٥</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٤٧٨٥</span> <span class="comment-type-4">علّق</span> <u>ابنُ عطية</u> (٦/٤٧٢) على القراءتين بقوله: «فقراءة الرفع هي إخبار مِن موسى بوقوع ضيق صدره وعدم انطلاق لسانه، وبهذا رجح أبو حاتم هذه القراءة، وقراءة النصب تقتضي أنّ ذلك داخل تحت خوفه، وهو عطف على <span class="qpc-hafs">﴿يُكَذِّبُونِ﴾</span>». ثم قال <span class="comment-type-3">مُرَجِّحًا</span> قراءة الرفع فيهما <span class="mustanad">لدلالة المعنى</span>: «وقد يكون عدم انطلاق اللسان بالقول لغموض المعاني التي تطلب لها ألفاظ محررة، فإذا كان هذا في وقت ضيق صدر ولم ينطلق اللسان، وقد قال موسى ﵇: <span class="qpc-hafs">﴿واحْلُلْ عُقْدَةً مِن لِسانِي﴾</span> [طه:٢٧]؛ فالراجح قراءة الرفع».</div></p><p><h3><span class="qpc-hafs">﴿قَالَ رَبِّ إِنِّیۤ أَخَافُ أَن یُكَذِّبُونِ ۝١٢ وَیَضِیقُ صَدۡرِی وَلَا یَنطَلِقُ لِسَانِی فَأَرۡسِلۡ إِلَىٰ هَـٰرُونَ ۝١٣﴾</span> - تفسير الآية</h3></p><p><div></p><p><p><span class="item-no">٥٥٦٥٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق سعيد بن جبير- قال: شكى موسى إلى ربِّه ما يتخوف مِن آل فرعون في القتيل وعُقْدة لسانه، فإنّه كان في لسانه عُقْدَةٌ تمنعه مِن كثير مِن الكلام، فآتاه الله سُؤْلَه، فحَلَّ عقدة لسانه. وفي قوله: <span class="qpc-hafs">﴿فارسل إلى هارون﴾</span> قال: سأل ربَّه أن يُعينه بأخيه هارون؛ يكون له رِدْئًا، ويتكلم عنه بكثير مِمّا لا يُفْصِح به لسانُه{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٥٦٥٩<span class="dash">-</span></span> قال <span class="name-2">إسماعيل السُّدِّيّ</span>: <span class="qpc-hafs">﴿فأرسل إلى هارون﴾</span>، يعني: مع هارون{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٥٦٦٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿قال﴾</span> موسى: <span class="qpc-hafs">﴿رب إني أخاف أن يكذبون﴾</span> فيما أقول، <span class="qpc-hafs">﴿و﴾</span>أخاف أن <span class="qpc-hafs">﴿يضيق صدري﴾</span> يعني: يضيق قلبي، <span class="qpc-hafs">﴿ولا ينطلق لساني﴾</span> بالبلاغ؛ <span class="qpc-hafs">﴿فأرسل إلى هارون﴾</span> يقول: فأرسل معي هارون. كقوله في النساء: <span class="qpc-hafs">﴿ولا تأكلوا أموالهم إلى أموالكم﴾</span> [النساء:٤]، يعني: مع أموالكم{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٥٦٦١<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: قال موسى: <span class="qpc-hafs">﴿ويضيق صدري﴾</span> فلا ينشرح بتبليغ الرسالة، فشجعني حتى أُبَلِّغ الرسالة، <span class="qpc-hafs">﴿ولا ينطلق لساني﴾</span> للعُقدة التي كانت في لسانه؛ <span class="qpc-hafs">﴿فأرسل إلى هارون﴾</span>، كقوله: <span class="qpc-hafs">﴿رب اشرح لي صدري (٢٥) ويسر لي أمري (٢٦) واحلل عقدة من لساني (٢٧) يفقهوا قولي (٢٨) واجعل لي وزيرا من أهلي (٢٩) هارون أخي (٣٠) اشدد به أزري (٣١) وأشركه في أمري (٣٢)﴾</span> [طه:٢٥-٣٢]، ففعل الله ذلك به، وأَشْرَكَه معه في الرسالة{5}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير يحيى بن سلام ٢/٤٩٧.</p><p>وهما قراءتان متواترتان، قرأ العشرة ما عدا يعقوب بالرفع فيهما، أما يعقوب فقرأ بالنصب فيهما. انظر: النشر ٢/٣٣٥، والإتحاف ص٤٢٠.أخرجه ابن أبي حاتم ٨/٢٧٥٢.علَّقه يحيى بن سلام ٢/٤٩٧.تفسير مقاتل بن سليمان ٣/٢٥٩.تفسير يحيى بن سلام ٢/٤٩٧.
  26,13,""
  26,14,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَلَهُمۡ عَلَیَّ ذَنۢبࣱ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٥٦٦٢<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿ولهم علي ذنب﴾</span>، قال: قَتْلُ النَّفْسِ التي قَتَل فيهم{1}. (١١/٢٤٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٥٦٦٣<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق مَعْمَر- في قوله: <span class="qpc-hafs">﴿ولهم علي ذنب﴾</span>، قال: قَتْل النفس{2}. (١١/٢٤٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٥٦٦٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ولهم علي ذنب﴾</span> يعني: عندي ذنب، يعني: قتل النفس؛ <span class="qpc-hafs">﴿فأخاف أن يقتلون﴾</span>{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٥٦٦٥<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: يعني: القِبْطِيّ الذي قتله خطأً، حيث وكَزَه، فمات{4}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿فَأَخَافُ أَن یَقۡتُلُونِ ۝١٤﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٥٦٦٦<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق سعيد بن جبير- يعني: قوله: <span class="qpc-hafs">﴿فأخاف ان يقتلون﴾</span>، قال: شكى موسى ﷺ إلى ربِّه ما يَتَخَوَّفُ مِن آل فرعون في القتيل{5}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ١٧/٥٥٣، وابن أبي حاتم ٨/٢٧٥٢، وأخرجه يحيى بن سلام ٢/٤٩٧ من طريق عاصم بن حكيم، وإسحاق البستي في تفسيره ص٥٣١ من طريق ابن جريج. وعزاه السيوطي إلى الفريابي، وابن أبي شيبة، وعبد بن حميد، وابن المنذر.أخرجه عبد الرزاق ٢/٧٣، وابن جرير ١٧/٥٥٣، وابن أبي حاتم ٨/٢٧٥٢-٢٧٥٥ من طريق سعيد. وعلَّقه يحيى بن سلام ٢/٤٩٧. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.تفسير مقاتل بن سليمان ٣/٢٥٩.تفسير يحيى بن سلام ٢/٤٩٧.أخرجه ابن أبي حاتم ٨/٢٧٥٢.
  26,15,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿قَالَ كَلَّاۖ فَٱذۡهَبَا بِـَٔایَـٰتِنَاۤۖ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٥٦٦٧<span class="dash">-</span></span> عن <span class="name-2">محمد بن كعب القرظي</span> -من طريق أبي معشر - يعني: قوله: <span class="qpc-hafs">﴿قال كلا﴾</span>، قال: يقول الجبّار ﷿: <span class="qpc-hafs">﴿كلا﴾</span>{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٥٦٦٨<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿قال كلا فاذهبا بآياتنا﴾</span> لا تخافا القتلَ{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٥٦٦٩<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿قال﴾</span> الله: <span class="qpc-hafs">﴿كلا﴾</span> ليسوا بالذين يَصِلون إلى قتلك حتى تُبَلِّغ عَنِّي الرسالة. ثم استأنف الكلام، فقال: <span class="qpc-hafs">﴿فاذهبا بآياتنا﴾</span>{3}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿إِنَّا مَعَكُم مُّسۡتَمِعُونَ ۝١٥﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٥٦٧٠<span class="dash">-</span></span> عن <span class="name-2">وهب بن مُنَبِّه</span> -من طريق عبد الصمد بن معقل- قال: قال لموسى -يعني: ربّه ﷿: إنِّي قد أقمتُك اليوم في مقامٍ لا ينبغي لبشر بعدك أن يقوم مقامك؛ أدْنَيْتُك وقرَّبتُك حتى سمعتَ كلامي، وكنت بأقرب الأمكنة مِنِّي، فانطلِق برسالتي، فإنّك بعيني وسمعي، وإنّ معك يدي وبصري{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٥٦٧١<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿إنا معكم مستمعون﴾</span> كقوله: <span class="qpc-hafs">﴿إنني معكما أسمع وأرى﴾</span> [طه:٤٦]{3}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن أبي حاتم ٨/٢٧٥٢.تفسير مقاتل بن سليمان ٣/٢٥٩.تفسير يحيى بن سلام ٢/٤٩٨.أخرجه ابن أبي حاتم ٨/٢٧٥٣.تفسير يحيى بن سلام ٢/٤٩٨.
  26,16,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿فَأۡتِیَا فِرۡعَوۡنَ فَقُولَاۤ إِنَّا رَسُولُ رَبِّ ٱلۡعَـٰلَمِینَ ۝١٦ أَنۡ أَرۡسِلۡ مَعَنَا بَنِیۤ إِسۡرَ ٰ⁠ۤءِیلَ ۝١٧﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٥٦٧٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق سعيد بن جبير- قال: فانطلقا جميعًا، فأقاما على بابه حينًا لا يُؤذَن لهما، ثم أذِن لهما بعد حِجاب شديد، فقالا: <span class="qpc-hafs">﴿إنا رسولا ربك﴾</span> [طه:٤٧]. <span class="qpc-hafs">﴿قالَ فَمَن رَبُّكُما يا مُوسى﴾</span> [طه:٤٩]. فأخبراه الذي قصَّ الله ﷿ في القرآن ... قال فرعون لموسى وهارون: ما تريدان؟ وذكَّره القتيلَ، فاعتذر بما سمعت، فقال: أريد أن تؤمن بالله ﷿، وأن ترسل معي بني إسرائيل{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٥٦٧٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فأتيا فرعون فقولا إنا رسول رب العالمين﴾</span> كقوله سبحانه: <span class="qpc-hafs">﴿فأتياه فقولا إنا رسولا ربك﴾</span> [طه:٤٧]، يعني: نفسه وهارون رسولا ربك، لقول فرعون: أنا الرب والإله. ثم انقطع الكلام. ثم انطلق موسى ﷺ إلى مصر، وهارون بمصر، فانطلقا كلاهما إلى فرعون، فلم يأذن لهما سنةً في الدخول، فلمّا دخلا عليه قال موسى لفرعون: <span class="qpc-hafs">﴿إنا﴾</span> يعني: نفسه وهارون ﵇ <span class="qpc-hafs">﴿رسول رب العالمين* أن أرسل معنا بني إسرائيل﴾</span> إلى أرض فلسطين، لا تَسْتَعْبِدْهم{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٥٦٧٤<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿فأتيا فرعون فقولا﴾</span> يقول: لموسى وهارون، <span class="qpc-hafs">﴿إنا رسول رب العالمين﴾</span> وهي كلمة من كلام العرب، يقول الرجل للرجل: مَن كان رسولك إلى فلان؟ فيقول: فلان وفلان وفلان. قوله ﷿: <span class="qpc-hafs">﴿أن أرسل معنا بني إسرائيل﴾</span> ولا تمنعهم مِن الإيمان، ولا تأخذ منهم الجِزية. وكان بنو إسرائيل في القِبْط بمنزِلة أهلِ الجِزْية فينا، وهو كقوله: <span class="qpc-hafs">﴿أن أدوا إلي عباد الله﴾</span> [الدخان:١٨]، يعني: بني إسرائيل{3}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن أبي حاتم ٨/٢٧٥٣.تفسير مقاتل بن سليمان ٣/٢٥٩-٢٦٠.تفسير يحيى بن سلام ٢/٤٩٨.
  26,17,""
  26,18,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿قَالَ أَلَمۡ نُرَبِّكَ فِینَا وَلِیدࣰا وَلَبِثۡتَ فِینَا مِنۡ عُمُرِكَ سِنِینَ ۝١٨﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٥٦٧٥<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق السُّدِّيّ، عن أبي مالك- <span class="qpc-hafs">﴿ولبثت فينا من عمرك سنين﴾</span>، قال: عشر سنين{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٥٦٧٦<span class="dash">-</span></span> قال يحيى بن سلّام: بلغني عن <span class="name-1">ابن عباس</span>: أنّ موسى لَمّا دخل على فرعون عَرَفه عدوُّ الله، فقال: <span class="qpc-hafs">﴿ألم نربك فينا وليدا ولبثت فينا من عمرك سنين﴾</span>، لِمَ تدَّعِ هذه النبوة التي تدَّعيها اليوم؟!{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٥٦٧٧<span class="dash">-</span></span> قال يحيى بن سلّام: بلغني عن <span class="name-1">عبد الله بن عباس</span>: أنّ موسى لَمّا دخل على فِرعون قال له فرعون: مَن أنت؟ قال: أنا رسول الله. قال: ليس عن هذا أسألك، ولكن: مَن أنت، وابن مَن أنت؟ قال: أنا موسى بن عمران. فقال: <span class="qpc-hafs">﴿ألم نربك فينا وليدا﴾</span> إلى آخر الآية{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٥٦٧٨<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق مَعْمَر- في قوله: <span class="qpc-hafs">﴿ألم نربك فينا وليدا﴾</span>، قال: التقطه آلُ فِرعون، فرَبَّوْه وليدًا، حتى كان رجلًا{4}. (١١/٢٤٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٥٦٧٩<span class="dash">-</span></span> تفسير <span class="name-2">إسماعيل السُّدِّيّ</span>: قوله: <span class="qpc-hafs">﴿قال ألم نربك فينا وليدا﴾</span>، يعني: عبدًا{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٥٦٨٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: فعرف فرعونُ موسى؛ لأنه ربّاه في بيته، فلمّا قتَلَ موسى ﵇ النفسَ هرب من مصر، فلمّا أتاه قال فرعونُ له: <span class="qpc-hafs">﴿ألم نربك فينا وليدا﴾</span> يعني: صبيًّا، <span class="qpc-hafs">﴿ولبثت فينا﴾</span> يعني: عندنا <span class="qpc-hafs">﴿من عمرك سنين﴾</span> يعني: ثلاثين سنة{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٥٦٨١<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿وليدا﴾</span>، يقول: صغيرًا{7}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن عساكر في تاريخ دمشق ٦١/٥٨.علَّقه يحيى بن سلام ٢/٤٩٨.علَّقه يحيى بن سلام ٢/٤٩٨.أخرجه عبد الرزاق ٢/٧٣، وابن أبي حاتم ٨/٢٧٥٣ من طريق سعيد. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.علَّقه يحيى بن سلام ٢/٤٩٨.تفسير مقاتل بن سليمان ٣/٢٦٠.تفسير يحيى بن سلام ٢/٤٩٨.
  26,19,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَفَعَلۡتَ فَعۡلَتَكَ ٱلَّتِی فَعَلۡتَ﴾</span> - قراءات</h3></p><p><div></p><p><p><span class="item-no">٥٥٦٨٢<span class="dash">-</span></span> عن <span class="name-2">عامر الشعبي</span> -من طريق السري بن إسماعيل- أنّه قرأ ذلك: (وفَعَلْتَ فِعْلَتَكَ) بكسر الفاء{1}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَفَعَلۡتَ فَعۡلَتَكَ ٱلَّتِی فَعَلۡتَ﴾</span> - تفسير الآية</h3></p><p><div></p><p><p><span class="item-no">٥٥٦٨٣<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿وفعلت فعلتك التي فعلت﴾</span>، قال: قتل النفس أيضًا{2}. (١١/٢٤٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٥٦٨٤<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿وفعلت فعلتك التي فعلت﴾</span>، قال: قَتَلْتَ النفس التي قتلتَ{3}. (١١/٢٤٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٥٦٨٥<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: قوله ﷿: <span class="qpc-hafs">﴿وفعلت فعلتك التي فعلت﴾</span>، يعني: النفس التي قتل{4}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَأَنتَ مِنَ ٱلۡكَـٰفِرِینَ ۝١٩﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٥٥٦٨٦<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق العوفي- في قوله: <span class="qpc-hafs">﴿وفعلت فعلتك التي فعلت وأنت من الكافرين﴾</span>، قال: كافِرًا للنعمة، إنّ فرعون لم يكن يعلم ما الكفر{5}. (١١/٢٤١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٥٦٨٧<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span> -من طريق عطاء بن دينار- في قوله: <span class="qpc-hafs">﴿وفعلت فعلتك التي فعلت وأنت من الكافرين﴾</span>، قال: مِن فرعون على موسى حين ربّاه. يقول: كفرت نعمتي{6}. (١١/٢٤١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٥٦٨٨<span class="dash">-</span></span> قال <span class="name-2">الحسن البصري</span>: <span class="qpc-hafs">﴿وأنت من الكافرين﴾</span> بأنِّي إله{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٥٦٨٩<span class="dash">-</span></span> قال <span class="name-2">إسماعيل السُّدِّيّ</span>: <span class="qpc-hafs">﴿من الكافرين﴾</span>، يعني: الكافرين لنعمتي إذ ربَّيتُك صغيرًا، وأحسنتُ إليك{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٥٦٩٠<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- <span class="qpc-hafs">﴿وفعلت فعلتك التي فعلت وأنت من الكافرين﴾</span>: يعني: على ديننا هذا الذي تَعِيب{9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٥٦٩١<span class="dash">-</span></span> عن <span class="name-3">محمد بن إسحاق</span> -من طريق سلمة- قال: فلمّا وقف على فرعون قال: إنِّي رسول رب العالمين. فعرفه فرعون، قال: <span class="qpc-hafs">﴿ألم نربك فينا وليدا ولبثت فينا من عمرك سنين وفعلت فعلتك التي فعلت وانت من الكافرين﴾</span> أي: لإحساني إليك، وفضلي عليك، ولم تشكر نعمتي ولا صنيعي، ثم قتلت رجلًا مِن شيعتي!{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٥٦٩٢<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿وفعلت فعلتك التي فعلت وأنت من الكافرين﴾</span>، قال: ربَّيناك فينا وليدًا، فهذا الذي كافأتنا؛ أن قتلت مِنّا نفسًا، وكفرت نعمتنا!{11}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٥٥٦٩٣<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿وأنت من الكافرين﴾</span> لنعمتنا، أي: إنا ربَّيْناك{4}<span class=comment-ref>٤٧٨٦</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٤٧٨٦</span> اختلف السلف في تفسير قوله تعالى: <span class="qpc-hafs">﴿وأنت من الكافرين﴾</span> على قولين: <b>الأول</b>: أنّ المراد به: أنت من الكافرين بالله على ديننا. وهو قول السدي -من طريق أسباط- وغيره. <b>الثاني</b>: أنت من الكافرين بنعمتنا. وهو قول ابن عباس، وابن زيد وغيرهما.</p><p>وقد <span class="comment-type-3">رجّح</span> <u>ابنُ جرير</u> (١٧/٥٥٦) <span class="mustanad">مستندًا إلى الدلالة العقلية</span> القول الثاني، وعلَّل ذلك بقوله: «لأنّ فرعون لم يكن مُقِرًّا لله بالربوبية، وإنما كان يزعم أنه هو الرب». ثم <span class="comment-type-2">انتقد</span> القول الأول، فقال: «فغير جائز أن يقول لموسى -إن كان موسى كان عنده على دينه يوم قتل القتيل. على ما قاله السدي-: فعلت الفعلة وأنت من الكافرين، [و]الإيمان عنده: هو دينه الذي كان عليه موسى عنده». ثم <span class="comment-type-1">وجّهه</span> بقوله: «إلا أن يقول قائل: إنما أراد: وأنت من الكافرين يومئذ -يا موسى- على قولك اليوم، فيكون ذلك وجهًا يتوجه».</p><p>وقال <u>ابنُ عطية</u> (٦/٤٧٤-٤٧٥): «وقوله: <span class="qpc-hafs">﴿وأَنْتَ مِنَ الكافِرِينَ﴾</span> يحتمل ثلاثة أوجه: <b>أحدها</b>: أن يريد: وقتلت القبطي وأَنتَ في قتلك إيّاه مِنَ الكافِرِينَ؛ إذ هو نفس لا يحل قتله. قاله الضحاك، أو يريد: وأنت من الكافرين بنعمتي في قتلك إياه. قاله ابن زيد. وهذان بمعنًى واحد في حق لفظ الكفر، وإنما اختلفا باشتراك لفظ الكفر. <b>والثاني</b>: أن يكون بمعنى الهزؤ؛ أي: وأنت على هذا الدين، وأنت من الكافرين بزعمك. قاله السدي. <b>والثالث</b>: هو قول الحسن، أن يريد: وأنت من الكافرين الآن، يعني فرعون: بالعقيدة التي يكون بيَّنها، فيكون الكلام مقطوعًا من قوله: <span class="qpc-hafs">﴿وفَعَلْتَ فَعْلَتَكَ﴾</span>، وإنما هو إخبارٌ مبتدأٌ أنّه كان من الكافرين. وهذا التأويل أيضًا يحتمل أن يريد به: كفر النعمة».</div></p></div>",footnotes:1:أخرجه الفراء في معاني القرآن ٢/٢٧٩. وعلَّقه ابن جرير ١٧/٥٥٥.</p><p>وهي قراءة شاذة. انظر: مختصر ابن خالويه ص١٠٧، والمحتسب ٢/١٢٧.أخرجه ابن جرير ١٧/٥٥٥، وابن أبي حاتم ٨/٢٧٥٤. وعزاه السيوطي إلى الفريابي، وابن أبي شيبة، وعبد بن حميد، وابن المنذر.أخرجه ابن أبي حاتم ٨/٢٧٥٤. وعزاه السيوطي أيضًا إلى عبد الرزاق، وعبد بن حميد، وابن المنذر.تفسير يحيى بن سلام ٢/٤٩٩.أخرجه ابن جرير ١٧/٥٥٦.أخرجه ابن أبي حاتم ٨/٢٧٥٤.علَّقه يحيى بن سلام ٢/٤٩٩. وجاء عن الحسن في تفسير البغوي ٦/١٠٩: يعني: وأنت من الكافرين بإلهك، وكنت على ديننا هذا الذي تعيبه.علَّقه يحيى بن سلام ٢/٤٩٩.أخرجه ابن جرير ١٧/٥٥٦، وابن أبي حاتم ٨/٢٧٥٤. وفي تفسير البغوي ٦/١٠٩: يعني: وأنت من الكافرين بإلهك، وكنت على ديننا هذا الذي تعيبه.أخرجه ابن أبي حاتم ٨/٢٧٥٤.أخرجه ابن جرير ١٧/٥٥٦، وابن أبي حاتم ٨/٢٧٥٤ من طريق أصبغ.تفسير يحيى بن سلام ٢/٤٩٩.