tafsir[19]{c,v,t}:
26,1," مقدمة السورة ٥٥٥٦١- عن عبد الله بن عباس -من طريق خُصَيْف، عن مجاهد-: مكية{1}. (١١/٢٣٧) ٥٥٥٦٢- عن عبد الله بن عباس -من طريق أبي عمرو بن العلاء، عن مجاهد- قال: سورة الشعراء نزلت بمكة، سوى خمس آيات مِن آخرها نَزَلْن بالمدينة: <q>﴿والشعراء يتبعهم الغاوون﴾</q> إلى آخرها [٢٢٤- ٢٢٧]{2}. (١١/٢٣٧) ٥٥٥٦٣- عن عبد الله بن عباس -من طريق عطاء الخراساني- قال: نزلت سورة <q>﴿طسم﴾</q> الشعراء بمكة، ونزلت بعد الواقعة{3}. (١١/٢٣٧) ٥٥٥٦٤- عن عبد الله بن الزبير، قال: أُنزلت سورة الشعراء بمكة{4}. (١١/٢٣٧) ٥٥٥٦٥- عن عكرمة مولى ابن عباس= (ز) ٥٥٥٦٦- والحسن البصري -من طريق يزيد النحوي-: مكية، وسمَّياها: <q>﴿طسم﴾</q>{5}. (ز) ٥٥٥٦٧- عن قتادة بن دعامة -من طرق-: مكية{6}. (ز) ٥٥٥٦٨- عن محمد ابن شهاب الزهري: مكية، ونزلت بعد الواقعة{7}. (ز) ٥٥٥٦٩- عن علي بن أبي طلحة: مكية{8}. (ز) ٥٥٥٧٠- قال مقاتل بن سليمان: مكية، غير آيتين فإنّهما مدنيتان: أحدهما: قوله تعالى: <q>﴿أولم يكن لهم آية أن يعلمه﴾</q> الآية [١٩٧]، والأخرى: قوله تعالى: <q>﴿والشعراء يتبعهم الغاوون﴾</q> [٢٢٤]. وبعض أهل التفسير يقول: إنّ مِن قوله تعالى: <q>﴿والشعراء﴾</q> إلى آخرها -وهُنَّ أربع آيات [٢٢٤-٢٢٧]- مدنيات{9}. (ز) ٥٥٥٧١- قال يحيى بن سلّام: مكية كلها{10}. (ز) ٥٥٥٧٢- عن مَعْدِيكرِبَ، قال: أتينا عبدَ الله بن مسعود نسأله عن <q>﴿طسم﴾</q> الشعراء، قال: ليست معي، ولكن عليكم بِمَن أخذها مِن رسول الله ﷺ، عليكم بأبي عبد الله خباب بن الأَرَتَّ{11}. (١١/٢٣٧) ٥٥٥٧٣- عن مَعْدِيكرِبَ، قال: أتينا عبدَ الله بن مسعود، فسألناه أن يقرأ علينا: «طسم» المائتين، فقال: ما هي معي، ولكن عليكم بِمَن أخذها مِن رسول الله ﷺ؛ خَبّاب بن الأَرَتَّ. فأتيت خَبّابًا، فقلتُ: كيف كان رسول الله ﷺ يقرأ: <q>﴿طسم﴾</q>، أو: <q>﴿طس﴾</q> [النمل:١]؟ فقال: كلٌّ كان رسول الله ﷺ يقرأ{12}. (١١/٤٢١) <q>﴿طسۤمۤ ۝١﴾</q> - نزول الآية ٥٥٥٧٤- عن علي بن أبي طالب، قال: لَمّا نزلت هذه الآية <q>﴿طسم﴾</q>؛ قال رسول الله ﷺ: «الطاء: طور سيناء، والسين: الإسكندرية، والميم: مكة»{13}. (ز) <q>﴿طسۤمۤ ۝١﴾</q> - تفسير الآية ٥٥٥٧٥- عن عبد الله بن عباس -من طريق عكرمة- قال: <q>﴿طسم﴾</q> عجزت العلماء عن تفسيرها{14}. (ز) ٥٥٥٧٦- عن عبد الله بن عباس -من طريق علي بن أبي طلحة- في قوله: <q>﴿طسم﴾</q>، قال: فإنّه قَسَمٌ أقسمه الله، وهو مِن أسماء الله{15}٤٧٨١. (ز) ٤٧٨١ وجّه ابنُ جرير (١٧/٥٤٢) معنى الآية على قول ابن عباس، فقال: «فتأويل الكلام على قول ابن عباس: والسميعِ، إنّ هذه الآيات التي أنزلتها على محمد ﷺ في هذه السورة لآيات الكتاب الذي أنزلته إليه مِن قبلها الذي بُيِّن -لِمَن تدبَّره بفهم، وفكر فيه بعقل- أنّه مِن عند الله جل جلاله، لم يتخرصه محمد ﷺ، ولم يَتَقَوَّله من عنده، بل أوحاه إليه ربه». وقال ابنُ عطية (٦/٥٦٨): «مَن قال: إنّ هذه الحروف مِن أسماء الله تعالى. قال: إنّ الطّاء مِن الطَّوْل الذي لله تعالى، والسّين مِن السّلام، والميم من المنعم، أو مِن الرحيم، ونحو هذا». ٥٥٥٧٧- عن شعبة، قال: سألت السُّدِّيّ عن قوله جل وعز: <q>﴿طسم﴾</q>. قال: قال ابن عباس: هو اسم الله الأعظم{16}. (ز) ٥٥٥٧٨- عن مجاهد بن جبر: أنّه هجاء مقطوع{17}. (ز) ٥٥٥٧٩- عن مجاهد بن جبر: اسم للسورة{14}. (ز) ٥٥٥٨٠- عن أبي بكر الهذلي أنّه سأل الحسن البصري عن قول الله ﷿: <q>﴿طسم﴾</q>. فقال: فواتِحُ افتتح اللهُ بها كتابَه، أو القرآن{19}. (ز) ٥٥٥٨١- قال الحسن البصري: لا أدري ما تفسيرها، غير أنّ قومًا مِن السلف كانوا يقولون فيها وأشباهها: أسماء السور، ومفاتحها{20}. (ز) ٥٥٥٨٢- عن قتادة بن دعامة -من طريق مَعْمَر- قال: اسم مِن أسماء القرآن{21}. (١١/٢٣٧) ٥٥٥٨٣- عن قتادة بن دعامة -من طريق سعيد- قوله: <q>﴿طسم﴾</q>، قال: اسم مِن أسماء القرآن، أقسم به ربُّك{22}. (١١/٤٢١) ٥٥٥٨٤- عن محمد بن كعب القرظي -من طريق محمد بن إسحاق- في قوله <q>﴿طسم﴾</q>، قال: الطاء مِن ذي الطَّوْل، والسين مِن القدوس، والميم مِن الرحمن{19}. (١١/٢٣٧) ٥٥٥٨٥- قال محمد بن كعب القرظي: أقسم اللهُ بطَوْله، وسنائه، وملكه{14}. (ز) ٥٥٥٨٦- قال إسماعيل السُّدِّيّ: هذه حروف مِن الهجاء مِن الأسماء المُقَطَّعة{17}. (ز) ٥٥٥٨٧- قال أبو رَوْق: اسم مِن أسماء القرآن، أقسم الله به{26}. (ز) ٥٥٥٨٨- قال جعفر الصادق: الطاء: شجرة طوبى، والسين: سدرة المنتهى، والميم: محمد المصطفى ﷺ{26}. (ز) ",footnotes:1:أخرجه البيهقي في دلائل النبوة ٧/١٤٣-١٤٤.أخرجه النحاس ص٦٠٧.أخرجه ابن الضريس في فضائل القرآن ١/٣٣-٣٥. وعزا السيوطي إلى ابن مردويه أوله.عزاه السيوطي إلى ابن مردويه.أخرجه البيهقي في دلائل النبوة ٧/١٤٢-١٤٣.أخرجه الحارث المحاسبي في فهم القرآن ص٣٩٥-٣٩٦ من طريق سعيد، وأبو بكر بن الأنباري -كما في الإتقان في علوم القرآن ١/٥٧- من طريق همام.تنزيل القرآن ص٣٧-٤٢.أخرجه أبو عبيد في فضائله (ت: الخياطي) ٢/٢٠٠.تفسير مقاتل ٣/٢٥٧.تفسير يحيى بن سلام ٢/٤٩٥.أخرجه أبو نعيم في الحلية ١/١٤٣.أخرجه أحمد ٧/٨٧ (٣٩٨٠). وعزاه السيوطي إلى ابن مردويه. قال الهيثمي في المجمع ٧/٨٤ (١١٢٤٢): «رجاله ثقات». وقال السيوطي: «سند جيد».أخرجه الثعلبي ٧/١٥٦، من طريق عبد الله بن محمد بن عقيل، عن محمد بن الحنفية، عن علي بن أبي طالب به. وأورده الديلمي في الفردوس ٢/٤٥٩ (٣٩٦٤). وسنده ضعيف؛ فيه عبد الله بن محمد بن عقيل، قال عنه ابن حجر في التقريب (٣٥٩٢): «صدوق، في حديثه لين، ويُقال: تغير بأخرة».تفسير الثعلبي ٧/١٥٦، وتفسير البغوي ٦/١٠٥.أخرجه ابن جرير ١٧/٥٤٢، وابن أبي حاتم ٨/٢٧٤٧، ٩/٢٩٣٨.أخرجه إسحاق البستي في تفسيره ص٥٣٠، وابن أبي حاتم ٩/٢٩٣٨، وفيه: سألت السدي عن قوله: <q>﴿الم﴾</q> و<q>﴿حم﴾</q> و<q>﴿طسم﴾</q>.علَّقه ابن أبي حاتم ٨/٢٧٤٧.تفسير الثعلبي ٧/١٥٦، وتفسير البغوي ٦/١٠٥.أخرجه ابن أبي حاتم ٨/٢٧٤٧.علَّقه يحيى بن سلام ٢/٤٩٥.أخرجه يحيى بن سلام ٢/٤٩٥ من طريق عثمان، وعبد الرزاق ٢/٧٣، وابن جرير ١٧/٥٤٢، وابن أبي حاتم ٨/٢٧٤٧ من طريق سعيد. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه يحيى بن سلام ٢/٤٩٥، وابن أبي حاتم ٩/٢٩٣٨.أخرجه ابن أبي حاتم ٨/٢٧٤٧.تفسير الثعلبي ٧/١٥٦، وتفسير البغوي ٦/١٠٥.علَّقه ابن أبي حاتم ٨/٢٧٤٧.تفسير الثعلبي ٧/١٥٦.تفسير الثعلبي ٧/١٥٦.
26,2," <q>﴿تِلۡكَ ءَایَـٰتُ ٱلۡكِتَـٰبِ ٱلۡمُبِینِ ۝٢﴾</q> - تفسير ٥٥٥٨٩- عن سعيد بن جبير -من طريق عطاء بن دينار- في قول الله: <q>﴿الكتاب﴾</q>: يعني: القرآن{1}. (ز) ٥٥٥٩٠- عن عبد الله بن عباس= (ز) ٥٥٥٩١- والحسن البصري، مثل ذلك{2}. (ز) ٥٥٥٩٢- عن الحسن البصري -من طريق أبي بكر- في هذه الآية: <q>﴿تلك آيات الكتاب﴾</q>، قال: التوراة، والزَّبور{3}. (ز) ٥٥٥٩٣- عن قتادة بن دعامة -من طريق سعيد بن بشير- <q>﴿الر تلك آيات الكتاب﴾</q> قال: الكتب التي خَلَتْ قَبْلَ القرآن <q>﴿المبين﴾</q> قال: إي، واللهِ، تبين بركته، وهداه، ورشده{1}. (ز) ٥٥٥٩٤- عن قتادة بن دعامة -من طريق سعيد بن أبي عروبة- قوله: <q>﴿طسم. تلك آيات الكتاب المبين﴾</q>: يعني: مبين -واللهِ- بركته ورشده وهُداه{5}. (ز) ٥٥٥٩٥- عن مطر الورّاق -من طريق الحسين بن واقد- <q>﴿تلك آيات﴾</q>، قال: الزَّبور{1}. (ز) ٥٥٥٩٦- قال مقاتل بن سليمان: <q>﴿تلك آيات الكتاب المبين﴾</q>، يعني ﷿: ما بيَّن فيه مِن أمره ونهيه، وحلاله وحرامه{7}. (ز) ٥٥٥٩٧- قال يحيى بن سلّام: قوله: <q>﴿تلك آيات الكتاب﴾</q> هذه آيات الكتاب؛ القرآن، <q>﴿المبين﴾</q> البيِّن{8}. (ز) ",footnotes:1:أخرجه ابن أبي حاتم ٨/٢٧٤٨.علَّقه ابن أبي حاتم ٨/٢٧٤٨.أخرجه ابن أبي حاتم ٨/٢٧٤٨، كما أورده عند تفسير قوله تعالى: <q>﴿الر تِلْكَ آياتُ الكِتابِ الحَكِيمِ﴾</q> [يونس:١]، وقوله تعالى: <q>﴿المر تِلْكَ آياتُ الكِتابِ﴾</q> [الرعد:١]، وصنع مثل مع الأثرين التاليين عن قتادة، ومطر الورّاق.أخرجه ابن أبي حاتم ٨/٢٧٤٨.أخرجه ابن جرير ١٨/١٤٩ في تفسير نظير هذه الآية في سورة القصص [٢]، وأشار قبل إيراده إلى أن المراد بالكتاب: القرآن.أخرجه ابن أبي حاتم ٨/٢٧٤٨.تفسير مقاتل بن سليمان ٣/٢٥٨.تفسير يحيى بن سلام ٢/٤٩٥.
26,3," <q>﴿لَعَلَّكَ بَـٰخِعࣱ نَّفۡسَكَ أَلَّا یَكُونُوا۟ مُؤۡمِنِینَ ۝٣﴾</q> - نزول الآية ٥٥٥٩٨- قال مقاتل بن سليمان: <q>﴿لعلك باخع نفسك﴾</q> وذلك حين كذَّب به كُفّار مكة؛ منهم: الوليد بن المغيرة، وأبو جهل، وأمية بن خلف، فشَقَّ على النبي ﷺ تكذيبُهم إيّاه؛ فأنزل الله ﷿: <q>﴿لعلك باخع نفسك﴾</q>{1}. (ز) <q>﴿لَعَلَّكَ بَـٰخِعࣱ نَّفۡسَكَ أَلَّا یَكُونُوا۟ مُؤۡمِنِینَ ۝٣﴾</q> - تفسير الآية ٥٥٥٩٩- قال عبد الله بن عباس -من طريق ابن جُرَيْج- <q>﴿باخع نفسك﴾</q>: قاتِلٌ نفسَك{2}. (ز) ٥٥٦٠٠- عن مجاهد بن جبر -من طريق أبي يحيى- قوله: <q>﴿لعلك باخع نفسك ألا يكونوا مؤمنين﴾</q>، قال: لعلَّك قاتِلٌ نفسَك إن لم يؤمنوا بهذا القرآن{3}. (ز) ٥٥٦٠١- عن عبيد، قال: سمعتُ الضَّحاكَ بنَ مُزاحِم يقول في قوله: <q>﴿لعلك باخع نفسك﴾</q>: قاتل نفسك عليهم حِرْصًا{4}. (ز) ٥٥٦٠٢- وعن الحسن البصري= (ز) ٥٥٦٠٣- وعكرمة مولى ابن عباس= (ز) ٥٥٦٠٤- وعطية العوفي، مثل ذلك{5}. (ز) ٥٥٦٠٥- عن قتادة بن دعامة -من طريق مَعْمَر- في قوله: <q>﴿لعلك باخع نفسك﴾</q>، قال: لعلك قاتِلٌ نفسَك{6}. (١١/٢٣٨) ٥٥٦٠٦- عن إسماعيل السُّدِّيّ -من طريق أسباط- قوله: <q>﴿لعلك باخع نفسك﴾</q>، قال: قاتل نفسك حزنًا إن لم يؤمنوا{7}. (ز) ٥٥٦٠٧- عن عطاء الخراساني -من طريق ابنه عثمان-: أمّا <q>﴿لعلك باخع نفسك﴾</q> فيُقال: فعلَّك مُخْرِج نفسَك، وقاتلُها{7}. (ز) ٥٥٦٠٨- قال مقاتل بن سليمان: <q>﴿لعلك﴾</q> يا محمد <q>﴿باخع نفسك﴾</q> يعني: قاتلًا نفسك حزنًا؛ <q>﴿ألا يكونوا مؤمنين﴾</q> يعني: ألّا يكونوا مُصَدِّقين بالقول بأنّه مِن عند الله ﷿. نظيرها في الكهف [٦]: <q>﴿فَلَعَلَّكَ باخِعٌ نَفْسَكَ عَلى آثارِهِمْ﴾</q>{9}. (ز) ٥٥٦٠٩- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿لعلك باخع نفسك ألا يكونوا مؤمنين﴾</q>، قال: لعلك مِن الحِرْص على إيمانهم مُخْرِجٌ نفسَك مِن جسدك. قال: ذلك البَخْعُ{10}. (ز) ٥٥٦١٠- عن سفيان بن عيينة -من طريق ابن أبي عمر- في قوله: <q>﴿لعلك باخع نفسك﴾</q>، قال: قاتِلٌ نفسَك{11}. (ز) ٥٥٦١١- قال يحيى بن سلّام: أي: فلا تفعل{12}. (ز) ",footnotes:1:تفسير مقاتل بن سليمان ٣/٢٥٨ وهو مرسل.أخرجه ابن جرير ١٧/٥٤٣.أخرجه يحيى بن سلام ٢/٤٩٥، وابن أبي حاتم ٨/٢٧٤٨.أخرجه ابن جرير ١٧/٥٤٤، وإسحاق البستي في تفسيره ص٥٣٠. وعلَّقه ابن أبي حاتم ٨/٢٧٤٨.علَّقه ابن أبي حاتم ٨/٢٧٤٨.أخرجه عبد الرزاق ٢/٧٣، وابن جرير ١٧/٥٤٣. وعلَّقه ابن أبي حاتم ٨/٢٧٤٨-٢٧٥٠. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه ابن أبي حاتم ٨/٢٧٤٩.أخرجه ابن أبي حاتم ٨/٢٧٤٩.تفسير مقاتل بن سليمان ٣/٢٥٨.أخرجه ابن جرير ١٧/٥٤٣، وابن أبي حاتم ٨/٢٧٤٩ من طريق أصبغ.أخرجه إسحاق البستي في تفسيره ص٥٣٠.تفسير يحيى بن سلام ٢/٤٩٥، ذكره مُعَقبًا على تفسير مجاهد السابق.
26,4," <q>﴿إِن نَّشَأۡ نُنَزِّلۡ عَلَیۡهِم مِّنَ ٱلسَّمَاۤءِ ءَایَةࣰ﴾</q> - نزول الآية ٥٥٦١٢- عن عبد الله بن عباس -من طريق الكلبي، عن أبي صالح- حدَّثه، قال: نزلت هذه الآيةُ فينا وفي بني أُمَيَّة، قال: ستكون لنا عليهم الدولة، فتَذِلُّ لنا أعناقُهم بعدَ صعوبة، وهوان بعد عزة{1}. (ز) <q>﴿إِن نَّشَأۡ نُنَزِّلۡ عَلَیۡهِم مِّنَ ٱلسَّمَاۤءِ ءَایَةࣰ﴾</q> - تفسير الآية ٥٥٦١٣- عن عبد الملك ابن جُرَيْج -من طريق حجاج- <q>﴿ألا يكونوا مؤمنين، إن نشأ ننزل عليهم من السماء آية﴾</q>، قال: لو شاء اللهُ لأراهم أمرًا مِن أمره، لا يعمل أحدٌ مِنهم بعده بمعصية{2}. (ز) ٥٥٦١٤- قال مقاتل بن سليمان: <q>﴿إن نشأ﴾</q> يعني: لو نشاء <q>﴿ننزل عليهم من السماء آية﴾</q>{3}. (ز) ٥٥٦١٥- قال يحيى بن سلّام، في قوله: <q>﴿إن نشأ ننزل عليهم من السماء آية فظلت أعناقهم﴾</q>: يعني: فصارت أعناقهم <q>﴿لها﴾</q> للآية{4}. (ز) ٥٥٦١٦- عن دازان -من طريق محمد بن كثير- في قوله: <q>﴿ننزل عليهم من السماء﴾</q>: الشمس مِن مغربها{5}. (ز) <q>﴿فَظَلَّتۡ أَعۡنَـٰقُهُمۡ لَهَا خَـٰضِعِینَ ۝٤﴾</q> - تفسير ٥٥٦١٧- عن عبد الله بن عباس: أنّ نافع بن الأزرق سأله عن قوله: <q>﴿فظلت أعناقهم لها خاضعين﴾</q>. قال: العُنُق: الجماعة من الناس. قال: وهل تعرف العرب ذلك؟ قال: نعم، أما سمعت الحارثَ بن هشام وهو يقول ويذكر أبا جهل: يخبرنا المخبر أن عمْرًا أمام القوم مِن عُنُق مَخِيل{6}{7}؟. (١١/٢٣٩) ٥٥٦١٨- عن عبد الله بن عباس -من طريق العوفي- قوله: <q>﴿فظلت أعناقهم لها خاضعين﴾</q>، قال: مُلْقِين أعناقَهم{2}. (ز) ٥٥٦١٩- عن عبد الله بن عباس، قوله: <q>﴿فظلت أعناقهم لها خاضعين﴾</q>، قال: ذليلين{9}. (١١/٢٣٩) ٥٥٦٢٠- عن مجاهد بن جبر -من طريق ابن جريج- في قوله: <q>﴿فظلت أعناقهم لها خاضعين﴾</q>، قال: فظلُّوا خاضعةً أعناقُهم لها{10}. (ز) ٥٥٦٢١- قال مجاهد بن جبر: أراد بالأعناق ههنا: الرؤساء، والكبراء{11}. (ز) ٥٥٦٢٢- عن قتادة بن دعامة -من طريق مَعْمَر- في قوله: <q>﴿إن نشأ ننزل عليهم من السماء آية فظلت أعناقهم لها خاضعين﴾</q>، قال: لو شاء اللهُ أنزل عليهم آيةً يذِلُّون بها، فلا يلوي أحدُهم منهم عنقَه إلى معصية الله{12}. (١١/٢٣٨) ٥٥٦٢٣- عن أبي حمزة الثمالي -من طريق علي بن علي- في هذه الآية قال: بلغنا- والله أعلم- أنّها صوت يُسمع من السماء في النصف من شهر رمضان تخرج له العواتق من البيوت{13}. (ز) ٥٥٦٢٤- قال مقاتل بن سليمان: <q>﴿فظلت﴾</q> يعني: فمالت <q>﴿أعناقهم لها﴾</q> يعني: للآية <q>﴿خاضعين﴾</q> يعني: مُقبلين إليها، مؤمنين بالآية{3}. (ز) ٥٥٦٢٥- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿فظلت أعناقهم لها خاضعين﴾</q>، قال: الخاضِع الذَّلِيل{15}. (١١/٢٣٩) ٥٥٦٢٦- قال يحيى بن سلّام: وذلك أنهم كانوا يسألون النبيَّ أن يأتيهم بآية، فهذا جوابٌ لقولهم{16}٤٧٨٢. (ز) ٤٧٨٢ أفادت الآثارُ اختلافَ السلف فيما عنى الله بقوله: <q>﴿فظلت أعناقهم﴾</q>؛ فقيل: الجارحة المعلومة، أي: أعناق الرجال الذين نزلت عليهم الآية من السماء. وقيل: أراد بالأعناق: الكبراء والسادة. وقيل: الأعناق: الجماعة من الناس. وقد رجّح ابنُ جرير (١٧/٥٤٨) القول الأول مستندًا إلى اللغة، وأقوال أهل التأويل، فقال: «وأولى الأقوال في ذلك بالصواب وأشبهها بما قال أهل التأويل في ذلك أن تكون الأعناق: هي أعناق الرجال. وأن يكون معنى الكلام: فظلت أعناقهم ذليلة للآية التي يُنزلها الله عليهم من السماء». وعلّق ابنُ عطية (٦/٤٧٠-٤٧١) على القول الأول، فقال: «فعلى هذا التأويل ليس في قوله: <q>﴿خاضِعِينَ﴾</q> موضع قول». وقال: "فمعنى هذا التأويل: أن نتكلم على قوله: <q>﴿خاضِعِينَ﴾</q> كيف جُمعَ جمْع مَن يعقل؟ وذلك متخرج على نحوين من كلام العرب: أحدهما: أنّ الإضافة إلى مَن يعقل أفادت حُكْمَه لِمَن لا يعقل، كما تفيد الإضافة إلى المؤنث تأنيث علامة المذكر، ومنه قول الأعشى: كما شرقت صدر القناة من الدم وهذا كثير. والنحو الآخر: أنّ الأعناق لَمّا وُصِفَت بفعل لا يكون إلا مقصود البشر، وهو الخضوع، إذ هو فعل يتبع أمرًا في النفس؛ جُمِعَت فيه جمع من يعقل. وهذا نظير قوله تعالى: <q>﴿أتَيْنا طائِعِينَ﴾</q> [فصلت:١١]، وقوله: <q>﴿رَأَيْتُهُمْ لِي ساجِدِينَ﴾</q> [يوسف:٤]". ",footnotes:1:أخرجه الثعلبي ٧/١٥٧. إسناده ضعيف جدًّا. وينظر: مقدمة الموسوعة. وقال ابن عاشور في التحرير ١٩/٩٧: «ومن بدع التفاسير وركيكها ما نسبه الثعلبي إلى ابن عباس -فذكره- وهذا مِن تحريف كلم القرآن عن مواضعه، ونحاشي ابن عباس ﵁ أن يقوله، وهو الذي دعا له رسول الله ﷺ بأن يعلمه التأويل. وهذا من موضوعات دعاة المُسَوِّدة مثل أبي مسلم الخراساني، وكم لهم في الموضوعات مِن اختلاق، والقرآن أجلُّ مِن أن يتعرض لهذه السفاسف».أخرجه ابن جرير ١٧/٥٤٥.تفسير مقاتل بن سليمان ٣/٢٥٨.تفسير يحيى بن سلام ٢/٤٩٥.أخرجه ابن أبي حاتم ٨/٢٧٤٩، كذا في المطبوع: عن دازان! ولم يتبين لنا من هو، ولم نجد في شيوخ محمد بن كثير العبدي (ت٢٢٣) مَن اسمه دازان أو قريبًا منه كزاذان، وقد يكون في المطبوع سقط وتحريف.مَخِيل: رَجُل أخْيَل ومَخِيل ومَخْيُول ومخول إذا كانت به الخال، وهو شامة سوداء في البدن. اللسان (خول).عزاه السيوطي إلى الطستي. والأثر في مسائل نافع (٢٥٤).أخرجه ابن جرير ١٧/٥٤٥.عزاه السيوطي إلى ابن جرير. وعند ابن جرير الأثر السابق.أخرجه ابن جرير ١٧/٥٤٥. وعلَّقه يحيى بن سلام ٢/٤٩٦.تفسير الثعلبي ٧/١٥٨، وتفسير البغوي ٦/١٠٦.أخرجه عبد الرزاق ٢/٧٣، وابن جرير ١٧/٥٤٤، وابن أبي حاتم ٨/٢٧٥٠. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه الثعلبي ٧/١٥٧.تفسير مقاتل بن سليمان ٣/٢٥٨.أخرجه ابن جرير ١٧/٥٤٥، وابن أبي حاتم ٨/٢٧٥٠ من طريق أصبغ.تفسير يحيى بن سلام ٢/٤٩٦.
26,5," <q>﴿وَمَا یَأۡتِیهِم مِّن ذِكۡرࣲ مِّنَ ٱلرَّحۡمَـٰنِ مُحۡدَثٍ إِلَّا كَانُوا۟ عَنۡهُ مُعۡرِضِینَ ۝٥﴾</q> - تفسير ٥٥٦٢٧- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿وما يأتيهم من ذكر من الرحمن محدث﴾</q> الآية، يقول: ما يأتيهم مِن شيء مِن كتاب الله إلا أعْرَضوا عنه{1}. (١١/٢٣٨) ٥٥٦٢٨- قال قتادة بن دعامة: <q>﴿من الرحمن محدث إلا كانوا عنه معرضين﴾</q>، أي: كُلَّما نزل مِن القرآن شيءٌ جحدوا به{2}. (ز) ٥٥٦٢٩- قال محمد بن السائب الكلبي: كلما نزل شيء مِن القرآن بعد شيء فهو أحدثُ مِن الأول{3}. (ز) ٥٥٦٣٠- قال مقاتل بن سليمان: <q>﴿وما يأتيهم من ذكر من الرحمن محدث﴾</q> يقول: ما يُحْدِث اللهُ ﷿ إلى النبي ﷺ مِن القرآن <q>﴿إلا كانوا عنه﴾</q> يعني: عن الإيمان بالقرآن <q>﴿معرضين﴾</q>{4}. (ز) ٥٥٦٣١- قال يحيى بن سلّام: قوله: <q>﴿وما يأتيهم من ذكر﴾</q>، يعني: القرآن{5}٤٧٨٣. (ز) ٤٧٨٣ أفادت الآثارُ تفسيرَ السلف للذِّكر بأنه القرآن، وقد ذكر ابنُ عطية (٦/٤٧١) في معنى الذكر قولًا آخر أن المراد به: محمد ﷺ. ثم علّق عليه، فقال: «وقالت فرقة: يحتمل أن يريد بـ»الذكر«: محمد ﷺ، كما قال تعالى في آية أخرى: <q>﴿قَدْ أنْزَلَ اللَّهُ إلَيْكُمْ ذِكْرًا﴾</q> [الطلاق:١٠]، فيكون وصفه بالمحدث مُتَمَكِّنًا». يعني: فيكون وصف الذكر بالمحدث -على القول بأنه محمد ﷺ- له نفسه على الحقيقة، لا يحتاج إلى تأويل؛ بخلاف القول بأنه القرآن فإنه يحتاج إلى أن يقال: محدث الإتيان، أي: مجيء القرآن للبشر كان شيئًا بعد شيء، لا هو في نفسه. ثم رجّح القول الأول لأنّه الأفصح بقوله: «والقول الأول أفصح». ",footnotes:1:أخرجه ابن أبي حاتم ٨/٢٧٤٨. وعزاه السيوطي إلى عبد الرزاق، وعبد بن حميد، وابن جرير، وابن المنذر.علَّقه يحيى بن سلام ٢/٤٩٦.تفسير البغوي ٦/١٠٧.تفسير مقاتل بن سليمان ٣/٢٥٨.تفسير يحيى بن سلام ٢/٤٩٦.
26,6," <q>﴿فَقَدۡ كَذَّبُوا۟ فَسَیَأۡتِیهِمۡ أَنۢبَـٰۤؤُا۟ مَا كَانُوا۟ بِهِۦ یَسۡتَهۡزِءُونَ ۝٦﴾</q> - تفسير ٥٥٦٣٢- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿فسيأتيهم﴾</q> يعني: يوم القيامة <q>﴿أنباء ما﴾</q> استهزأوا به من كتاب الله{1}. (١١/٢٣٨) ٥٥٦٣٣- قال مقاتل بن سليمان: <q>﴿فقد كذبوا بالحق﴾</q> يعني: بالقرآن <q>﴿لما جاءهم﴾</q> يعني: حين جاءهم به محمد ﷺ، <q>﴿فسيأتيهم أنباء﴾</q> يعني: حديث <q>﴿ما كانوا به يستهزؤن﴾</q> وذلك أنّهم حين كذَّبوا بالقرآن أوْعَدَهُم الله ﷿ بالقتل ببدر{2}. (ز) ٥٥٦٣٤- قال يحيى بن سلّام: <q>﴿فقد كذبوا فسيأتيهم﴾</q> في الآخرة <q>﴿أنباء ما كانوا به يستهزءون﴾</q> في الدنيا، وهو عذاب النار، فسيأتيهم تحقيق ذلك الخبر بدخولهم النار{3}. (ز) ",footnotes:1:أخرجه ابن أبي حاتم ٨/٢٧٤٨. وعزاه السيوطي إلى عبد الرزاق، وعبد بن حميد، وابن جرير، وابن المنذر.تفسير مقاتل بن سليمان ٣/٢٥٨.تفسير يحيى بن سلام ٢/٤٩٦.
26,7," <q>﴿أَوَلَمۡ یَرَوۡا۟ إِلَى ٱلۡأَرۡضِ كَمۡ أَنۢبَتۡنَا فِیهَا مِن كُلِّ زَوۡجࣲ كَرِیمٍ ۝٧﴾</q> - تفسير ٥٥٦٣٥- عن سعيد بن جبير -من طريق عطاء بن دينار- قوله: <q>﴿كريم﴾</q>: يعني: حسن{1}. (ز) ٥٥٦٣٦- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿كم أنبتنا فيها من كل زوج كريم﴾</q>، قال: مِن نبات الأرض مِمّا يأكل الناس والأنعام{2}. (١١/٢٣٩) ٥٥٦٣٧- عن عامر الشعبي، <q>﴿كم أنبتنا فيها من كل زوج كريم﴾</q>، قال: الناسُ مِن نباتِ الأرض؛ فمَن دخل الجنة فهو كريمٌ، ومَن دخل النار فهو لئيمٌ{3}. (١١/٢٣٩) ٥٥٦٣٨- عن قتادة بن دعامة -من طريق مَعْمَر- في قوله: <q>﴿كم أنبتنا فيها من كل زوج كريم﴾</q>، قال: حَسَن{4}. (١١/٢٣٨) ٥٥٦٣٩- قال مقاتل بن سليمان: ثم وعَظَهم ليعتبروا، فقال ﷿: <q>﴿أولم يروا إلى الأرض كم أنبتنا فيها من كل زوج كريم﴾</q>، يقول: كم أخرجنا مِن الأرض مِن كلِّ صِنف مِن ألوان النَّبت حَسَن{5}. (ز) ٥٥٦٤٠- قال يحيى بن سلّام: وهذا على الاستفهام، أي: قد رأوا كم أنبتنا في الأرض مِن كل زوج كريم مِمّا رَأَوْا{6}. (ز) ",footnotes:1:أخرجه ابن أبي حاتم ٨/٢٧٥٠.أخرجه ابن جرير ١٧/٥٥٠، كذلك من طريق ابن جريج، وابن أبي حاتم ٨/٢٧٥٠. وعزاه السيوطي إلى الفريابي، وعبد بن حميد، وابن المنذر. وعلَّق يحيى بن سلام ٢/٤٩٦ نحوه وزاد: وكل ما ينبت في الأرض فالواحد منه زوج.أخرجه ابن أبي حاتم ٨/٢٧٥٠. وعزاه السيوطي إلى الفريابي، وعبد بن حميد، وابن المنذر.أخرجه عبد الرزاق ٢/٧٣، وابن جرير ١٧/٥٥٠. وعلَّقه ابن أبي حاتم ٨/٢٧٥٠. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.تفسير مقاتل بن سليمان ٣/٢٥٨-٢٥٩.تفسير يحيى بن سلام ٢/٤٩٦.
26,8," <q>﴿إِنَّ فِی ذَ ٰ⁠لِكَ لَـَٔایَةࣰۖ وَمَا كَانَ أَكۡثَرُهُم مُّؤۡمِنِینَ ۝٨﴾</q> - تفسير ٥٥٦٤١- عن عبد الله بن عباس -من طريق سعيد بن جبير- <q>﴿ان في ذلك لآية﴾</q>، قال: علامة، ألم تر إلى الرجل إذا أراد أن يُرسل إلى أهله في حاجةٍ أرسل بخاتمه، أو بثوبه؛ فعرفوا أنّه حق{1}. (ز) ٥٥٦٤٢- عن سعيد بن جبير، نحو ذلك{2}. (ز) ٥٥٦٤٣- قال مقاتل بن سليمان: <q>﴿إن في ذلك لآية﴾</q> يقول: إنّ في النبت لعِبْرَة في توحيد الله ﷿ أنّه واحد، <q>﴿وما كان أكثرهم﴾</q> يعني: أهل مكة <q>﴿مؤمنين﴾</q> يعني: مُصَدِّقين بالتوحيد{3}. (ز) ٥٥٦٤٤- قال يحيى بن سلّام: <q>﴿إن في ذلك لآية﴾</q> لَمَعرِفة بأنّ الذي أنبت هذه الأزواج في الأرض قادِرٌ على أن يُحْيِي الموتى، قال: <q>﴿وما كان أكثرهم مؤمنين﴾</q> يعني: مَن مضى مِن الأمم{4}. (ز) ",footnotes:1:أخرجه ابن أبي حاتم ٨/٢٧٥١، وأخرجه إسحاق البستي في تفسيره ص٥٣٥ بلفظ: هو الرجل يقول لأهله: علامة ما بيني وبينكم أن أرسل إليكم بخاتمي، أو آية كذا وكذا.أخرجه ابن أبي حاتم ٨/٢٧٥١.تفسير مقاتل بن سليمان ٣/٢٥٩.تفسير يحيى بن سلام ٢/٤٩٦.
26,9," <q>﴿وَإِنَّ رَبَّكَ لَهُوَ ٱلۡعَزِیزُ ٱلرَّحِیمُ ۝٩﴾</q> - تفسير ٥٥٦٤٥- عن أبي العالية الرِّياحِيِّ -من طريق الربيع بن أنس- <q>﴿العزيز﴾</q>، قال: عزيز في نقمته إذا انتقم{1}. (ز) ٥٥٦٤٦- عن قتادة بن دعامة= (ز) ٥٥٦٤٧- والربيع بن أنس، نحو ذلك{2}. (ز) ٥٥٦٤٨- عن سعيد بن جبير -من طريق عطاء بن دينار- في قول الله: <q>﴿الرحيم﴾</q>: يعني: رحيمًا بهم بعد التوبة{1}. (ز) ٥٥٦٤٩- عن عبد الملك ابن جُرَيْج -من طريق حجّاج- قال: كل شيءٍ في «الشعراء» من قوله: «عزيزٌ رحيم» فهو ما أهلك مِمَّن مضى مِن الأمم. يقول: عزيزٌ حين انتقم مِن أعدائه، رحيمٌ بالمؤمنين حين أنجاهم مِمّا أهلك به أعداءَه{4}٤٧٨٤. (١١/٢٣٩) ٤٧٨٤ بيّن ابنُ جرير (١٧/٥٥١) أن تفسير ابن جريج للـ<q>﴿العزيز الرحيم﴾</q> غير متحقق في هذا الموطن، ومتحققٌ في بقية مواطن السورة، وعلّق على تفسيره بقوله: «ولعلَّ ابن جريج بقوله هذا أراد ما كان مِن ذلك عقيب خبر الله عن إهلاكه مَن أهلك مِن الأمم، وذلك إن شاء الله إذا كان عقيب خبرهم كذلك». ورجّح مستندًا إلى السياق ومنتقدًا قول ابن جريج أنّ معنى الآية: «إنّ ربك -يا محمد- لهو العزيز في نقمته، لا يمتنع عليه أحدٌ أراد الانتقام منه. <q>﴿الرحيم﴾</q> يعني: أنه ذو الرحمة بِمَن تاب مِن خلقه مِن كفره ومعصيته، أن يعاقبه على ما سلف من جرمه بعد توبته. وإنما اخترنا القول الذي اخترناه في ذلك في هذا الموضع لأنّ قوله: <q>﴿وإن ربك لهو العزيز الرحيم﴾</q> عقيب وعيد الله قومًا مِن أهل الشرك والتكذيب بالبعث لم يكونوا أهلكوا، فيوجه إلى أنه خبر مِن الله عن فعله بهم وإهلاكه». ٥٥٦٥٠- قال مقاتل بن سليمان: <q>﴿وإن ربك لهو العزيز﴾</q> في نقمته منهم ببدر، <q>﴿الرحيم﴾</q> حين لا يعجل عليهم بالعقوبة إلى الوقت{5}. (ز) ٥٥٦٥١- عن محمد بن إسحاق -من طريق سلمة- <q>﴿العزيز﴾</q>، قال: العزيز في نصرته مِمَّن كفر به إذا شاء{1}. (ز) ٥٥٦٥٢- قال يحيى بن سلّام: قوله ﷿: <q>﴿وإن ربك لهو العزيز﴾</q> في نقمته، <q>﴿الرحيم﴾</q> بخلقه، فأمّا المؤمن فتَتِمُّ عليه الرحمة في الآخرة، وأمّا الكافر فهو ما أعطاه في الدنيا، فليس له إلا رحمة الدنيا، وهي زائلة عنه، وليس له في الآخرة نصيب{7}. (ز) ",footnotes:1:أخرجه ابن أبي حاتم ٨/٢٧٥١.علَّقه ابن أبي حاتم ٨/٢٧٥١.أخرجه ابن أبي حاتم ٨/٢٧٥١.أخرجه ابن جرير ١٧/٥٥١.تفسير مقاتل بن سليمان ٣/٢٥٩، زاد محققه بعد كلمة «الوقت»: «المحدد لهم»؛ ليتضح المعنى.أخرجه ابن أبي حاتم ٨/٢٧٥١.تفسير يحيى بن سلام ٢/٤٩٦.
26,10," <q>﴿وَإِذۡ نَادَىٰ رَبُّكَ مُوسَىٰۤ﴾</q> - تفسير ٥٥٦٥٣- عن إسماعيل السُّدِّيّ -من طريق أسباط- <q>﴿وإذ نادى ربك موسى﴾</q>، قال: حين نُودِي مِن جانب الطور الأيمن{1}. (١١/٢٤٠) ٥٥٦٥٤- قال مقاتل بن سليمان: <q>﴿وإذ نادى ربك﴾</q> يقول: وإذ أمر ربك -يا محمد- <q>﴿موسى﴾</q>{2}. (ز) ",footnotes:1:أخرجه ابن أبي حاتم ٨/٢٧٥١.تفسير مقاتل بن سليمان ٣/٢٥٩.
26,11," <q>﴿أَنِ ٱئۡتِ ٱلۡقَوۡمَ ٱلظَّـٰلِمِینَ ۝١٠ قَوۡمَ فِرۡعَوۡنَۚ أَلَا یَتَّقُونَ ۝١١﴾</q> - تفسير ٥٥٦٥٥- قال مقاتل بن سليمان: <q>﴿أن ائت القوم الظالمين﴾</q> يعني: المشركين؛ <q>﴿قوم فرعون﴾</q> واسمه: فيطوس، بأرض مصر، وقل لهم يا موسى: <q>﴿ألا يتقون﴾</q> يعني: ألا يعبدون الله ﷿{1}. (ز) ٥٥٦٥٦- قال يحيى بن سلّام: قوله ﷿: <q>﴿قوم فرعون ألا يتقون﴾</q>، أي: فليتقوا الله{2}. (ز) ",footnotes:1:تفسير مقاتل بن سليمان ٣/٢٥٩.تفسير يحيى بن سلام ٢/٤٩٦.
26,12," <q>﴿قَالَ رَبِّ إِنِّیۤ أَخَافُ أَن یُكَذِّبُونِ ۝١٢ وَیَضِیقُ صَدۡرِی وَلَا یَنطَلِقُ لِسَانِی فَأَرۡسِلۡ إِلَىٰ هَـٰرُونَ ۝١٣﴾</q> - قراءات ٥٥٦٥٧- قال يحيى بن سلّام: وهي تقرأ على وجهين: <q>﴿ويَضِيقُ صَدْرِي﴾</q> بالرفع <q>﴿ولا يَنْطَلِقُ لِسانِي﴾</q>، والحرف الآخر بالنصب: ‹ويَضِيقَ صَدْرِي ولا يَنْطَلِقَ لِسانِي›، أي: إني أخاف أن يكذبون، وأخاف أن يضيق صدري، ولا ينطلق لساني{1}٤٧٨٥. (ز) ٤٧٨٥ علّق ابنُ عطية (٦/٤٧٢) على القراءتين بقوله: «فقراءة الرفع هي إخبار مِن موسى بوقوع ضيق صدره وعدم انطلاق لسانه، وبهذا رجح أبو حاتم هذه القراءة، وقراءة النصب تقتضي أنّ ذلك داخل تحت خوفه، وهو عطف على <q>﴿يُكَذِّبُونِ﴾</q>». ثم قال مُرَجِّحًا قراءة الرفع فيهما لدلالة المعنى: «وقد يكون عدم انطلاق اللسان بالقول لغموض المعاني التي تطلب لها ألفاظ محررة، فإذا كان هذا في وقت ضيق صدر ولم ينطلق اللسان، وقد قال موسى ﵇: <q>﴿واحْلُلْ عُقْدَةً مِن لِسانِي﴾</q> [طه:٢٧]؛ فالراجح قراءة الرفع». <q>﴿قَالَ رَبِّ إِنِّیۤ أَخَافُ أَن یُكَذِّبُونِ ۝١٢ وَیَضِیقُ صَدۡرِی وَلَا یَنطَلِقُ لِسَانِی فَأَرۡسِلۡ إِلَىٰ هَـٰرُونَ ۝١٣﴾</q> - تفسير الآية ٥٥٦٥٨- عن عبد الله بن عباس -من طريق سعيد بن جبير- قال: شكى موسى إلى ربِّه ما يتخوف مِن آل فرعون في القتيل وعُقْدة لسانه، فإنّه كان في لسانه عُقْدَةٌ تمنعه مِن كثير مِن الكلام، فآتاه الله سُؤْلَه، فحَلَّ عقدة لسانه. وفي قوله: <q>﴿فارسل إلى هارون﴾</q> قال: سأل ربَّه أن يُعينه بأخيه هارون؛ يكون له رِدْئًا، ويتكلم عنه بكثير مِمّا لا يُفْصِح به لسانُه{2}. (ز) ٥٥٦٥٩- قال إسماعيل السُّدِّيّ: <q>﴿فأرسل إلى هارون﴾</q>، يعني: مع هارون{3}. (ز) ٥٥٦٦٠- قال مقاتل بن سليمان: <q>﴿قال﴾</q> موسى: <q>﴿رب إني أخاف أن يكذبون﴾</q> فيما أقول، <q>﴿و﴾</q>أخاف أن <q>﴿يضيق صدري﴾</q> يعني: يضيق قلبي، <q>﴿ولا ينطلق لساني﴾</q> بالبلاغ؛ <q>﴿فأرسل إلى هارون﴾</q> يقول: فأرسل معي هارون. كقوله في النساء: <q>﴿ولا تأكلوا أموالهم إلى أموالكم﴾</q> [النساء:٤]، يعني: مع أموالكم{4}. (ز) ٥٥٦٦١- قال يحيى بن سلّام: قال موسى: <q>﴿ويضيق صدري﴾</q> فلا ينشرح بتبليغ الرسالة، فشجعني حتى أُبَلِّغ الرسالة، <q>﴿ولا ينطلق لساني﴾</q> للعُقدة التي كانت في لسانه؛ <q>﴿فأرسل إلى هارون﴾</q>، كقوله: <q>﴿رب اشرح لي صدري (٢٥) ويسر لي أمري (٢٦) واحلل عقدة من لساني (٢٧) يفقهوا قولي (٢٨) واجعل لي وزيرا من أهلي (٢٩) هارون أخي (٣٠) اشدد به أزري (٣١) وأشركه في أمري (٣٢)﴾</q> [طه:٢٥-٣٢]، ففعل الله ذلك به، وأَشْرَكَه معه في الرسالة{5}. (ز) ",footnotes:1:تفسير يحيى بن سلام ٢/٤٩٧. وهما قراءتان متواترتان، قرأ العشرة ما عدا يعقوب بالرفع فيهما، أما يعقوب فقرأ بالنصب فيهما. انظر: النشر ٢/٣٣٥، والإتحاف ص٤٢٠.أخرجه ابن أبي حاتم ٨/٢٧٥٢.علَّقه يحيى بن سلام ٢/٤٩٧.تفسير مقاتل بن سليمان ٣/٢٥٩.تفسير يحيى بن سلام ٢/٤٩٧.
  26,13,""
26,14," <q>﴿وَلَهُمۡ عَلَیَّ ذَنۢبࣱ﴾</q> - تفسير ٥٥٦٦٢- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿ولهم علي ذنب﴾</q>، قال: قَتْلُ النَّفْسِ التي قَتَل فيهم{1}. (١١/٢٤٠) ٥٥٦٦٣- عن قتادة بن دعامة -من طريق مَعْمَر- في قوله: <q>﴿ولهم علي ذنب﴾</q>، قال: قَتْل النفس{2}. (١١/٢٤٠) ٥٥٦٦٤- قال مقاتل بن سليمان: <q>﴿ولهم علي ذنب﴾</q> يعني: عندي ذنب، يعني: قتل النفس؛ <q>﴿فأخاف أن يقتلون﴾</q>{3}. (ز) ٥٥٦٦٥- قال يحيى بن سلّام: يعني: القِبْطِيّ الذي قتله خطأً، حيث وكَزَه، فمات{4}. (ز) <q>﴿فَأَخَافُ أَن یَقۡتُلُونِ ۝١٤﴾</q> - تفسير ٥٥٦٦٦- عن عبد الله بن عباس -من طريق سعيد بن جبير- يعني: قوله: <q>﴿فأخاف ان يقتلون﴾</q>، قال: شكى موسى ﷺ إلى ربِّه ما يَتَخَوَّفُ مِن آل فرعون في القتيل{5}. (ز) ",footnotes:1:أخرجه ابن جرير ١٧/٥٥٣، وابن أبي حاتم ٨/٢٧٥٢، وأخرجه يحيى بن سلام ٢/٤٩٧ من طريق عاصم بن حكيم، وإسحاق البستي في تفسيره ص٥٣١ من طريق ابن جريج. وعزاه السيوطي إلى الفريابي، وابن أبي شيبة، وعبد بن حميد، وابن المنذر.أخرجه عبد الرزاق ٢/٧٣، وابن جرير ١٧/٥٥٣، وابن أبي حاتم ٨/٢٧٥٢-٢٧٥٥ من طريق سعيد. وعلَّقه يحيى بن سلام ٢/٤٩٧. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.تفسير مقاتل بن سليمان ٣/٢٥٩.تفسير يحيى بن سلام ٢/٤٩٧.أخرجه ابن أبي حاتم ٨/٢٧٥٢.
26,15," <q>﴿قَالَ كَلَّاۖ فَٱذۡهَبَا بِـَٔایَـٰتِنَاۤۖ﴾</q> - تفسير ٥٥٦٦٧- عن محمد بن كعب القرظي -من طريق أبي معشر - يعني: قوله: <q>﴿قال كلا﴾</q>، قال: يقول الجبّار ﷿: <q>﴿كلا﴾</q>{1}. (ز) ٥٥٦٦٨- قال مقاتل بن سليمان: <q>﴿قال كلا فاذهبا بآياتنا﴾</q> لا تخافا القتلَ{2}. (ز) ٥٥٦٦٩- قال يحيى بن سلّام: <q>﴿قال﴾</q> الله: <q>﴿كلا﴾</q> ليسوا بالذين يَصِلون إلى قتلك حتى تُبَلِّغ عَنِّي الرسالة. ثم استأنف الكلام، فقال: <q>﴿فاذهبا بآياتنا﴾</q>{3}. (ز) <q>﴿إِنَّا مَعَكُم مُّسۡتَمِعُونَ ۝١٥﴾</q> - تفسير ٥٥٦٧٠- عن وهب بن مُنَبِّه -من طريق عبد الصمد بن معقل- قال: قال لموسى -يعني: ربّه ﷿: إنِّي قد أقمتُك اليوم في مقامٍ لا ينبغي لبشر بعدك أن يقوم مقامك؛ أدْنَيْتُك وقرَّبتُك حتى سمعتَ كلامي، وكنت بأقرب الأمكنة مِنِّي، فانطلِق برسالتي، فإنّك بعيني وسمعي، وإنّ معك يدي وبصري{4}. (ز) ٥٥٦٧١- قال يحيى بن سلّام: <q>﴿إنا معكم مستمعون﴾</q> كقوله: <q>﴿إنني معكما أسمع وأرى﴾</q> [طه:٤٦]{3}. (ز) ",footnotes:1:أخرجه ابن أبي حاتم ٨/٢٧٥٢.تفسير مقاتل بن سليمان ٣/٢٥٩.تفسير يحيى بن سلام ٢/٤٩٨.أخرجه ابن أبي حاتم ٨/٢٧٥٣.تفسير يحيى بن سلام ٢/٤٩٨.
26,16," <q>﴿فَأۡتِیَا فِرۡعَوۡنَ فَقُولَاۤ إِنَّا رَسُولُ رَبِّ ٱلۡعَـٰلَمِینَ ۝١٦ أَنۡ أَرۡسِلۡ مَعَنَا بَنِیۤ إِسۡرَ ٰ⁠ۤءِیلَ ۝١٧﴾</q> - تفسير ٥٥٦٧٢- عن عبد الله بن عباس -من طريق سعيد بن جبير- قال: فانطلقا جميعًا، فأقاما على بابه حينًا لا يُؤذَن لهما، ثم أذِن لهما بعد حِجاب شديد، فقالا: <q>﴿إنا رسولا ربك﴾</q> [طه:٤٧]. <q>﴿قالَ فَمَن رَبُّكُما يا مُوسى﴾</q> [طه:٤٩]. فأخبراه الذي قصَّ الله ﷿ في القرآن ... قال فرعون لموسى وهارون: ما تريدان؟ وذكَّره القتيلَ، فاعتذر بما سمعت، فقال: أريد أن تؤمن بالله ﷿، وأن ترسل معي بني إسرائيل{1}. (ز) ٥٥٦٧٣- قال مقاتل بن سليمان: <q>﴿فأتيا فرعون فقولا إنا رسول رب العالمين﴾</q> كقوله سبحانه: <q>﴿فأتياه فقولا إنا رسولا ربك﴾</q> [طه:٤٧]، يعني: نفسه وهارون رسولا ربك، لقول فرعون: أنا الرب والإله. ثم انقطع الكلام. ثم انطلق موسى ﷺ إلى مصر، وهارون بمصر، فانطلقا كلاهما إلى فرعون، فلم يأذن لهما سنةً في الدخول، فلمّا دخلا عليه قال موسى لفرعون: <q>﴿إنا﴾</q> يعني: نفسه وهارون ﵇ <q>﴿رسول رب العالمين* أن أرسل معنا بني إسرائيل﴾</q> إلى أرض فلسطين، لا تَسْتَعْبِدْهم{2}. (ز) ٥٥٦٧٤- قال يحيى بن سلّام: <q>﴿فأتيا فرعون فقولا﴾</q> يقول: لموسى وهارون، <q>﴿إنا رسول رب العالمين﴾</q> وهي كلمة من كلام العرب، يقول الرجل للرجل: مَن كان رسولك إلى فلان؟ فيقول: فلان وفلان وفلان. قوله ﷿: <q>﴿أن أرسل معنا بني إسرائيل﴾</q> ولا تمنعهم مِن الإيمان، ولا تأخذ منهم الجِزية. وكان بنو إسرائيل في القِبْط بمنزِلة أهلِ الجِزْية فينا، وهو كقوله: <q>﴿أن أدوا إلي عباد الله﴾</q> [الدخان:١٨]، يعني: بني إسرائيل{3}. (ز) ",footnotes:1:أخرجه ابن أبي حاتم ٨/٢٧٥٣.تفسير مقاتل بن سليمان ٣/٢٥٩-٢٦٠.تفسير يحيى بن سلام ٢/٤٩٨.
  26,17,""
26,18," <q>﴿قَالَ أَلَمۡ نُرَبِّكَ فِینَا وَلِیدࣰا وَلَبِثۡتَ فِینَا مِنۡ عُمُرِكَ سِنِینَ ۝١٨﴾</q> - تفسير ٥٥٦٧٥- عن عبد الله بن عباس -من طريق السُّدِّيّ، عن أبي مالك- <q>﴿ولبثت فينا من عمرك سنين﴾</q>، قال: عشر سنين{1}. (ز) ٥٥٦٧٦- قال يحيى بن سلّام: بلغني عن ابن عباس: أنّ موسى لَمّا دخل على فرعون عَرَفه عدوُّ الله، فقال: <q>﴿ألم نربك فينا وليدا ولبثت فينا من عمرك سنين﴾</q>، لِمَ تدَّعِ هذه النبوة التي تدَّعيها اليوم؟!{2}. (ز) ٥٥٦٧٧- قال يحيى بن سلّام: بلغني عن عبد الله بن عباس: أنّ موسى لَمّا دخل على فِرعون قال له فرعون: مَن أنت؟ قال: أنا رسول الله. قال: ليس عن هذا أسألك، ولكن: مَن أنت، وابن مَن أنت؟ قال: أنا موسى بن عمران. فقال: <q>﴿ألم نربك فينا وليدا﴾</q> إلى آخر الآية{2}. (ز) ٥٥٦٧٨- عن قتادة بن دعامة -من طريق مَعْمَر- في قوله: <q>﴿ألم نربك فينا وليدا﴾</q>، قال: التقطه آلُ فِرعون، فرَبَّوْه وليدًا، حتى كان رجلًا{4}. (١١/٢٤٠) ٥٥٦٧٩- تفسير إسماعيل السُّدِّيّ: قوله: <q>﴿قال ألم نربك فينا وليدا﴾</q>، يعني: عبدًا{2}. (ز) ٥٥٦٨٠- قال مقاتل بن سليمان: فعرف فرعونُ موسى؛ لأنه ربّاه في بيته، فلمّا قتَلَ موسى ﵇ النفسَ هرب من مصر، فلمّا أتاه قال فرعونُ له: <q>﴿ألم نربك فينا وليدا﴾</q> يعني: صبيًّا، <q>﴿ولبثت فينا﴾</q> يعني: عندنا <q>﴿من عمرك سنين﴾</q> يعني: ثلاثين سنة{6}. (ز) ٥٥٦٨١- قال يحيى بن سلّام: <q>﴿وليدا﴾</q>، يقول: صغيرًا{7}. (ز) ",footnotes:1:أخرجه ابن عساكر في تاريخ دمشق ٦١/٥٨.علَّقه يحيى بن سلام ٢/٤٩٨.علَّقه يحيى بن سلام ٢/٤٩٨.أخرجه عبد الرزاق ٢/٧٣، وابن أبي حاتم ٨/٢٧٥٣ من طريق سعيد. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.علَّقه يحيى بن سلام ٢/٤٩٨.تفسير مقاتل بن سليمان ٣/٢٦٠.تفسير يحيى بن سلام ٢/٤٩٨.
26,19," <q>﴿وَفَعَلۡتَ فَعۡلَتَكَ ٱلَّتِی فَعَلۡتَ﴾</q> - قراءات ٥٥٦٨٢- عن عامر الشعبي -من طريق السري بن إسماعيل- أنّه قرأ ذلك: (وفَعَلْتَ فِعْلَتَكَ) بكسر الفاء{1}. (ز) <q>﴿وَفَعَلۡتَ فَعۡلَتَكَ ٱلَّتِی فَعَلۡتَ﴾</q> - تفسير الآية ٥٥٦٨٣- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿وفعلت فعلتك التي فعلت﴾</q>، قال: قتل النفس أيضًا{2}. (١١/٢٤٠) ٥٥٦٨٤- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿وفعلت فعلتك التي فعلت﴾</q>، قال: قَتَلْتَ النفس التي قتلتَ{3}. (١١/٢٤٠) ٥٥٦٨٥- قال يحيى بن سلّام: قوله ﷿: <q>﴿وفعلت فعلتك التي فعلت﴾</q>، يعني: النفس التي قتل{4}. (ز) <q>﴿وَأَنتَ مِنَ ٱلۡكَـٰفِرِینَ ۝١٩﴾</q> - تفسير ٥٥٦٨٦- عن عبد الله بن عباس -من طريق العوفي- في قوله: <q>﴿وفعلت فعلتك التي فعلت وأنت من الكافرين﴾</q>، قال: كافِرًا للنعمة، إنّ فرعون لم يكن يعلم ما الكفر{5}. (١١/٢٤١) ٥٥٦٨٧- عن سعيد بن جبير -من طريق عطاء بن دينار- في قوله: <q>﴿وفعلت فعلتك التي فعلت وأنت من الكافرين﴾</q>، قال: مِن فرعون على موسى حين ربّاه. يقول: كفرت نعمتي{6}. (١١/٢٤١) ٥٥٦٨٨- قال الحسن البصري: <q>﴿وأنت من الكافرين﴾</q> بأنِّي إله{7}. (ز) ٥٥٦٨٩- قال إسماعيل السُّدِّيّ: <q>﴿من الكافرين﴾</q>، يعني: الكافرين لنعمتي إذ ربَّيتُك صغيرًا، وأحسنتُ إليك{8}. (ز) ٥٥٦٩٠- عن إسماعيل السُّدِّيّ -من طريق أسباط- <q>﴿وفعلت فعلتك التي فعلت وأنت من الكافرين﴾</q>: يعني: على ديننا هذا الذي تَعِيب{9}. (ز) ٥٥٦٩١- عن محمد بن إسحاق -من طريق سلمة- قال: فلمّا وقف على فرعون قال: إنِّي رسول رب العالمين. فعرفه فرعون، قال: <q>﴿ألم نربك فينا وليدا ولبثت فينا من عمرك سنين وفعلت فعلتك التي فعلت وانت من الكافرين﴾</q> أي: لإحساني إليك، وفضلي عليك، ولم تشكر نعمتي ولا صنيعي، ثم قتلت رجلًا مِن شيعتي!{6}. (ز) ٥٥٦٩٢- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿وفعلت فعلتك التي فعلت وأنت من الكافرين﴾</q>، قال: ربَّيناك فينا وليدًا، فهذا الذي كافأتنا؛ أن قتلت مِنّا نفسًا، وكفرت نعمتنا!{11}. (ز) ٥٥٦٩٣- قال يحيى بن سلّام: <q>﴿وأنت من الكافرين﴾</q> لنعمتنا، أي: إنا ربَّيْناك{4}٤٧٨٦. (ز) ٤٧٨٦ اختلف السلف في تفسير قوله تعالى: <q>﴿وأنت من الكافرين﴾</q> على قولين: الأول: أنّ المراد به: أنت من الكافرين بالله على ديننا. وهو قول السدي -من طريق أسباط- وغيره. الثاني: أنت من الكافرين بنعمتنا. وهو قول ابن عباس، وابن زيد وغيرهما. وقد رجّح ابنُ جرير (١٧/٥٥٦) مستندًا إلى الدلالة العقلية القول الثاني، وعلَّل ذلك بقوله: «لأنّ فرعون لم يكن مُقِرًّا لله بالربوبية، وإنما كان يزعم أنه هو الرب». ثم انتقد القول الأول، فقال: «فغير جائز أن يقول لموسى -إن كان موسى كان عنده على دينه يوم قتل القتيل. على ما قاله السدي-: فعلت الفعلة وأنت من الكافرين، [و]الإيمان عنده: هو دينه الذي كان عليه موسى عنده». ثم وجّهه بقوله: «إلا أن يقول قائل: إنما أراد: وأنت من الكافرين يومئذ -يا موسى- على قولك اليوم، فيكون ذلك وجهًا يتوجه». وقال ابنُ عطية (٦/٤٧٤-٤٧٥): «وقوله: <q>﴿وأَنْتَ مِنَ الكافِرِينَ﴾</q> يحتمل ثلاثة أوجه: أحدها: أن يريد: وقتلت القبطي وأَنتَ في قتلك إيّاه مِنَ الكافِرِينَ؛ إذ هو نفس لا يحل قتله. قاله الضحاك، أو يريد: وأنت من الكافرين بنعمتي في قتلك إياه. قاله ابن زيد. وهذان بمعنًى واحد في حق لفظ الكفر، وإنما اختلفا باشتراك لفظ الكفر. والثاني: أن يكون بمعنى الهزؤ؛ أي: وأنت على هذا الدين، وأنت من الكافرين بزعمك. قاله السدي. والثالث: هو قول الحسن، أن يريد: وأنت من الكافرين الآن، يعني فرعون: بالعقيدة التي يكون بيَّنها، فيكون الكلام مقطوعًا من قوله: <q>﴿وفَعَلْتَ فَعْلَتَكَ﴾</q>، وإنما هو إخبارٌ مبتدأٌ أنّه كان من الكافرين. وهذا التأويل أيضًا يحتمل أن يريد به: كفر النعمة». ",footnotes:1:أخرجه الفراء في معاني القرآن ٢/٢٧٩. وعلَّقه ابن جرير ١٧/٥٥٥. وهي قراءة شاذة. انظر: مختصر ابن خالويه ص١٠٧، والمحتسب ٢/١٢٧.أخرجه ابن جرير ١٧/٥٥٥، وابن أبي حاتم ٨/٢٧٥٤. وعزاه السيوطي إلى الفريابي، وابن أبي شيبة، وعبد بن حميد، وابن المنذر.أخرجه ابن أبي حاتم ٨/٢٧٥٤. وعزاه السيوطي أيضًا إلى عبد الرزاق، وعبد بن حميد، وابن المنذر.تفسير يحيى بن سلام ٢/٤٩٩.أخرجه ابن جرير ١٧/٥٥٦.أخرجه ابن أبي حاتم ٨/٢٧٥٤.علَّقه يحيى بن سلام ٢/٤٩٩. وجاء عن الحسن في تفسير البغوي ٦/١٠٩: يعني: وأنت من الكافرين بإلهك، وكنت على ديننا هذا الذي تعيبه.علَّقه يحيى بن سلام ٢/٤٩٩.أخرجه ابن جرير ١٧/٥٥٦، وابن أبي حاتم ٨/٢٧٥٤. وفي تفسير البغوي ٦/١٠٩: يعني: وأنت من الكافرين بإلهك، وكنت على ديننا هذا الذي تعيبه.أخرجه ابن أبي حاتم ٨/٢٧٥٤.أخرجه ابن جرير ١٧/٥٥٦، وابن أبي حاتم ٨/٢٧٥٤ من طريق أصبغ.تفسير يحيى بن سلام ٢/٤٩٩.
