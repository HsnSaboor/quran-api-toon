quran[6]{c,v,t}:
  3,10,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿إِنَّ ٱلَّذِینَ كَفَرُوا۟ لَن تُغۡنِیَ عَنۡهُمۡ أَمۡوَ ٰ⁠لُهُمۡ وَلَاۤ أَوۡلَـٰدُهُم مِّنَ ٱللَّهِ شَیۡـࣰٔاۖ وَأُو۟لَـٰۤىِٕكَ هُمۡ وَقُودُ ٱلنَّارِ ۝١٠﴾</span> - نزول الآية</h3></p><p><div></p><p><p><span class="item-no">١٢١١٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿إن الذين كفروا﴾</span> نَزَلَتْ في كعب بن الأشرف{1}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿إِنَّ ٱلَّذِینَ كَفَرُوا۟ لَن تُغۡنِیَ عَنۡهُمۡ أَمۡوَ ٰ⁠لُهُمۡ وَلَاۤ أَوۡلَـٰدُهُم مِّنَ ٱللَّهِ شَیۡـࣰٔاۖ وَأُو۟لَـٰۤىِٕكَ هُمۡ وَقُودُ ٱلنَّارِ ۝١٠﴾</span> - تفسير الآية</h3></p><p><div></p><p><p><span class="item-no">١٢١١٣<span class="dash">-</span></span> عن <span class="name-2">كَعْب الأَحْبار</span> -من طريق عبد الله بن الحارث بن نَوْفَل- يقول: <span class="qpc-hafs">﴿الذين كفروا﴾</span>، قال: هؤلاء أهلُ النار{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢١١٤<span class="dash">-</span></span> عن <span class="name-3">محمد بن السائب الكلبي</span>، في قوله تعالى: <span class="qpc-hafs">﴿من الله﴾</span>، أي: مِن عذاب الله{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢١١٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿إن الذين كفروا﴾</span> يعني: اليهود خاصَّةً <span class="qpc-hafs">﴿لن تغني عنهم﴾</span> يعني: لا <span class="qpc-hafs">﴿أموالهم ولا أولادهم من الله شيئا وأولئك هم وقود النار﴾</span> يعني: اليهود{1}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ١/٢٦٥.|2:أخرجه ابن أبي حاتم ٢/٦٠٣.|3:تفسير البغوي ٢/١٢.|4:تفسير مقاتل بن سليمان ١/٢٦٥.
  3,11,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿كَدَأۡبِ ءَالِ فِرۡعَوۡنَ وَٱلَّذِینَ مِن قَبۡلِهِمۡۚ كَذَّبُوا۟ بِـَٔایَـٰتِنَا فَأَخَذَهُمُ ٱللَّهُ بِذُنُوبِهِمۡۗ وَٱللَّهُ شَدِیدُ ٱلۡعِقَابِ ۝١١﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">١٢١١٦<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق أبي رَوْق، عن الضَّحّاك- في قوله: <span class="qpc-hafs">﴿كدأب آل فرعون﴾</span>، قال: كصنيع آل فرعون{1}. (٣/٤٧٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢١١٧<span class="dash">-</span></span> عن <span class="name-2">أبي مالك غَزْوان الغِفارِيِّ</span>، نحو ذلك{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢١١٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، في قوله: <span class="qpc-hafs">﴿كدأب آل فرعون﴾</span>، قال: كفِعْل{3}. (٣/٤٧٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢١١٩<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جَبْر</span> -من طريق جابر- في قوله: <span class="qpc-hafs">﴿كدأب آل فرعون﴾</span>، قال: كفِعْلِ آلِ فرعون، كشَأْنِ آل فرعون{4}. (٣/٤٧٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢١٢٠<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span> -من طريق جابر-، مثله{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢١٢١<span class="dash">-</span></span> عن <span class="name-2">الضَّحّاك بن مُزاحِم</span> -من طريق جُوَيْبِر- <span class="qpc-hafs">﴿كدأب آل فرعون﴾</span>، قال: كعَمَلِ آل فرعون{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢١٢٢<span class="dash">-</span></span> عن <span class="name-3">عبد الملك ابن جُرَيْج</span>، كذلك{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢١٢٣<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span>: هذا مَثَلٌ ضربه الله لِمُشركي العرب؛ يقول: كفروا، وصنعوا كصنيع آل فرعون والذين مِن قبلهم مِن الكفار{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢١٢٤<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيِّ</span> -من طريق أسباط-: <span class="qpc-hafs">﴿كدأب آل فرعون والذين من قبلهم كذبوا بآياتنا فأخذهم الله بذنوبهم﴾</span>، ذَكَرَ الذين كفروا، فقال: تكذيبُهم كمثل تكذيب الذين مِن قبلهم في الجُحود والتَّكْذِيب{9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢١٢٥<span class="dash">-</span></span> عن <span class="name-2">عطاء [بن أبي رباح]</span>، في قوله: <span class="qpc-hafs">﴿كدأب آل فرعون﴾</span>، قال: كسُنَّةِ آل فرعون{10}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢١٢٦<span class="dash">-</span></span> عن <span class="name-2">الربيع بن أنس</span> -من طريق أبي جعفر- <span class="qpc-hafs">﴿كدأب آل فرعون﴾</span>، يقول: كسُنَّتهم{11}. (٣/٤٧٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢١٢٧<span class="dash">-</span></span> عن <span class="name-2">الربيع بن أنس</span>، أنّه قال: كشَبِيه آل فرعون{12}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢١٢٨<span class="dash">-</span></span> عن <span class="name-2">أبي رَوْقٍ عَطِيَّة بنِ الحارث الهمداني</span>، في قوله: <span class="qpc-hafs">﴿كدأب آل فرعون﴾</span>: كفعل آلِ فرعون وصنيعهم في الكفر والتكذيب{13}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢١٢٩<span class="dash">-</span></span> قال <span class="name-3">مُقاتِل بن سليمان</span>: <span class="qpc-hafs">﴿كدأب آل فرعون﴾</span> يعني: كأشباه آل فرعون في التكذيب، <span class="qpc-hafs">﴿والذين من قبلهم﴾</span> مِن الأُمَمِ الخاليةِ قبل آل فرعون، والأُمَمُ الخاليةُ قبل آل فرعون: قومُ نوح، وعاد، وثمود، وقوم إبراهيم، وقوم لوط، وقوم شعيب، <span class="qpc-hafs">﴿كذبوا بآياتنا﴾</span> يعني: بأنّهم كذبوا أيضًا بالعذاب في الدنيا بأنّه غيرُ نازِلٍ بهم، <span class="qpc-hafs">﴿فأخذهم الله بذنوبهم﴾</span> يعني: في الدنيا، فعاقبهم الله، <span class="qpc-hafs">﴿والله شديد العقاب﴾</span> يعني: إذا عاقَبَ{14}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢١٣٠<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهْب- في قوله: <span class="qpc-hafs">﴿كدأب آل فرعون﴾</span>، قال: كأعمالهم، كفعلهم، كتكذيبهم حين كذَّبوا الرُّسُل. وقرأ قول الله: <span class="qpc-hafs">﴿مثل دأب قوم نوح﴾</span> [غافر:٣١]. أن يصيبَكم مثلَ الذي أصابهم عليه من عذاب الله. قال: الدَّأْبُ: العَمَلُ{15}<span class=comment-ref>١١٢٣</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>١١٢٣</span> اختلف المفسرون في الدأب؛ فقيل: الصنيع، والسُّنَّة، والفِعْل، والشبه.</p><p>و<span class="comment-type-4">ذَكَر</span> <u>ابنُ عطية</u> (٢/١٦٥-١٦٦) أن الدَّأْب والدَّأَب مصدر دأب يدأب: إذا لازَمَ فِعْلَ شيءٍ ودام عليه مجتهدًا فيه، واعتبر أنّ عبارة المفسرين راجعة إلى هذا المعنى، فقال: «واختلفت عبارة المفسرين في تفسير الدأب، وذلك كله راجع إلى المعنى الذي ذكرناه».</p><p>وقال <u>ابنُ كثير</u> (٣/٢٢) بتقارب الأقوال الواردة في الدأب، فقال بعد ذِكرها: «والألفاظ متقاربة».</p><p>و<span class="comment-type-4">ذكر</span> <u>ابنُ عطية</u> (٢/١٦٦) أن الآيات هنا تحتمل احتمالين: <b>الأول</b>: الآيات المتلُوَّة. <b>الثاني</b>: الآيات المنصوبة.</div></p></div>",footnotes:1:أخرجه ابن جرير ٥/٢٣٦، وابن أبي حاتم ٢/٦٠٣، ٥/١٧١٨.|2:علَّقه ابن أبي حاتم ٢/٦٠٣.|3:عزاه السيوطي إلى ابن المنذر، وأبي الشيخ.|4:أخرجه ابن جرير ٥/٢٣٦. وعزا السيوطيُّ شطرَه الأول إلى أبي الشيخ.|5:أخرجه ابن جرير ٥/٢٣٦. وعلَّقه ابن أبي حاتم ٢/٦٠٣.|6:أخرجه عبد بن حميد كما في قطعة من تفسيره ص٢٣، وابن جرير ٥/٢٣٥، وابن المنذر ١/١٣٦ من طريق سلمة بن نُبيط بلفظ: كفعل. وعلَّقه ابن أبي حاتم ٢/٦٠٣.|7:علَّقه ابن المنذر ١/١٣٦.|8:ذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ١/٢٧٨-.|9:أخرجه ابن جرير ٥/٢٣٦، وابن أبي حاتم ٢/٦٠٣.|10:تفسير البغوي ٢/١٢.|11:أخرجه ابن جرير ٥/٢٣٥.|12:علَّقه ابنُ أبي حاتم ٢/٦٠٣. وهو بنفس اللفظ في نسخة د. حكمت بشير ص٩٢، مكتبة الدار بالمدينة، ط١، ١٤٠٨ﻫ. وفي تفسير الثعلبي (ط: دار التفسير) ٨/٧٨: كشبه آل فرعون وشأنهم.|13:تفسير الثعلبي ٣/١٨.|14:تفسير مقاتل بن سليمان ١/٢٦٥.|15:أخرجه ابن جرير ٥/٢٣٦
  3,12,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿قُل لِّلَّذِینَ كَفَرُوا۟ سَتُغۡلَبُونَ وَتُحۡشَرُونَ إِلَىٰ جَهَنَّمَۖ وَبِئۡسَ ٱلۡمِهَادُ ۝١٢﴾</span> - نزول الآية</h3></p><p><div></p><p><p><span class="item-no">١٢١٣١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق أبي صالح-: إنّ يهود أهل المدينة قالوا لَمّا هَزَمَ اللهُ المشركين يوم بدر: هذا -واللهِ- النبيُّ الأُمِّيُّ الذي بشَّرَنا به موسى، ونَجِده في كتابنا بنَعْتِه وصِفَتِه، وأنّه لا تُرَدُّ له راية. وأرادوا تصديقه واتِّباعه، ثم قال بعضُهم لبعض: لا تعجلوا، حتى ننظر إلى وقْعَةٍ له أخرى. فلمّا كان يوم أحد، ونُكِبَ{1} أصحابُ رسول الله ﷺ؛ شكُّوا، وقالوا: لا واللهِ، ما هو به. وغلب عليهم الشقاءُ فلم يُسْلِمُوا، وكان بينهم وبين رسول الله ﷺ عَهْدٌ إلى مُدَّةٍ، فنقضوا ذلك العهدَ، وانطلق كعبُ بنُ الأشرف في سِتِّين راكبًا إلى أهل مكة؛ أبي سفيان وأصحابِه، فوافقوهم، وأَجْمَعُوا أمرَهم، وقالوا: لَتَكُونَنَّ كلِمَتُنا واحدة. ثُمَّ رجعوا إلى المدينة؛ فأنزل الله تعالى فيهم هذه الآية{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢١٣٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>-من طريق ابن إسحاق بسنده-: أنّ رسول الله ﷺ لَمّا أصاب مِن أهل بدرٍ ما أصاب، ورَجَع إلى المدينة؛ جَمَع اليهودَ في سوق بَنِي قَيْنُقاع، وقال: «<b>يا معشرَ يهود، أسْلِمُوا قبل أن يُصيبَكُم اللهُ بما أصاب قُرَيْشًا»</b>. فقالوا: يا محمد، لا يَغُرَّنَّك مِن نفسك أن قتلت نفرًا مِن قريش كانوا أغمارًا ولا يعرفون القتال، إنّك -واللهِ- لو قاتلتَنا لعرفتَ أنّا نحنُ الناس، وأنّك لم تَلْقَ مثلَنا. فأنزل اللهُ: <span class="qpc-hafs">﴿قل للذين كفروا ستغلبون﴾</span> إلى قوله: <span class="qpc-hafs">﴿لأولي الأبصار﴾</span>{3}. (٣/٤٧٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢١٣٣<span class="dash">-</span></span> عن <span class="name-2">عاصم بن عمر بن قتادة</span> -من طريق ابن إسحاق-، مثله{4}. (٣/٤٧٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢١٣٤<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق ابن إسحاق بسنده- قال: ما نزلت هؤلاء الآيات إلا فيهم: <span class="qpc-hafs">﴿قل للذين كفروا ستغلبون وتحشرون إلى جهنم وبئس المهاد﴾</span> إلى <span class="qpc-hafs">﴿لأولي الأبصار﴾</span>{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢١٣٥<span class="dash">-</span></span> عن <span class="name-2">عكرمة</span> مولى ابن عباس -من طريق ابن جُرَيْج- قال: قال فِنْحاص اليهوديُّ في يوم بدر: لا يَغُرَّنَّ محمدًا أن غَلَب قُرَيْشًا وقتلهم؛ إنّ قريشًا لا تُحْسِنُ القتالَ. فنزلت هذه الآية: <span class="qpc-hafs">﴿قل للذين كفروا ستغلبون وتحشرون إلى جهنم وبئس المهاد﴾</span>{6}<span class=comment-ref>١١٢٤</span>. (٣/٤٧٣-٤٧٤)</p></p><p></div></p><p><div><span class=comment-ref>١١٢٤</span> <span class="comment-type-3">رَجَّح</span> <u>ابنُ جرير</u> (٥/٢٤٠-٢٤١) نزولَ الآية في اليهود <span class="mustanad">مستندًا إلى أقوال السلف</span>، فقال بعد ذكره لهذه الآثار: «فكُلُّ هذه الأخبار تُنبِئُ عن أنّ المخاطبين بقوله: <span class="qpc-hafs">﴿ستغلبون وتحشرون إلى جهنم وبئس المهاد﴾</span> هم اليهود المقول لهم: <span class="qpc-hafs">﴿قد كان لكم آية في فئتين﴾</span> الآية».</p><p>وذكر <u>ابنُ عطية</u> (٢/١٦٧) أنّ هناك مَن قال بنزول الآية في جميع معاصري النبي ﷺ، ثُمَّ قال: «وتظاهرت رواياتٌ بأنّ المراد: يهود المدينة».</div></p><p><h3><span class="qpc-hafs">﴿قُل لِّلَّذِینَ كَفَرُوا۟ سَتُغۡلَبُونَ وَتُحۡشَرُونَ إِلَىٰ جَهَنَّمَۖ وَبِئۡسَ ٱلۡمِهَادُ ۝١٢﴾</span> - تفسير الآية</h3></p><p><div></p><p><p><span class="item-no">١٢١٣٦<span class="dash">-</span></span> عن <span class="name-2">عمر بن عبد العزيز</span> -من طريق خلف أبي الفضل القرشي- قال: قول الله: <span class="qpc-hafs">﴿قل للذين كفروا ستغلبون وتحشرون إلى جهنم وبئس المهاد﴾</span>، فأخبر بعذابهم بالقتل في الدنيا، وفي الآخرة بالنار، وهم أحياءٌ بمكة{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢١٣٧<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿وبئس المهاد﴾</span>، قال: بِئْسَما مَهَدُوا لأنفسهم{8}<span class=comment-ref>١١٢٥</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>١١٢٥</span> <span class="comment-type-4">عَلَّق</span> <u>ابنُ عطية</u> (٢/١٦٧) على قول مجاهد بقوله: «فكأنّ المعنى: وبئس فعلُهم الذي أدّاهم إلى جهنم».</div></p><p><div></p><p><p><span class="item-no">١٢١٣٨<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿قل للذين كفروا﴾</span> من أهل مكة يوم بدر، <span class="qpc-hafs">﴿ستغلبون وتحشرون إلى جهنم﴾</span> في الآخرة، <span class="qpc-hafs">﴿وبئس المهاد﴾</span> يقول: بِئْسَما مَهَدُوا لأنفسهم. فقال النبي ﷺ للكُفّارِ يوم بَدْرٍ: <b>«إنّ الله غالِبُكم، وسوف يحشركم إلى جهنم»</b>. فقال أبو جهل: يا ابن أبي كَبْشَةَ، هل هذا إلا مِثْلُ ما كنتَ تُحَدِّثُنا به؟!{9}. (ز)</p></p><p></div></p></div>",footnotes:1:نُكِبَ الجيش: هُزِم. والنَّكبة: ما يصيب الإنسان من الحوادث. انظر: النهاية، وإتحاف الفاضل بالفعل المبني لغير الفاعل لابن علاّن (نكب).|2:أورده الواحديُّ في أسباب النزول ص٩٨، والثعلبي ٣/١٩-٢٠.|3:أخرجه أبو داود ٤/٦١٦ (٣٠٠١)، وابن جرير ٥/٢٣٩، وابن المنذر ١/١٣٧ (٢٧٢).</p><p>ذكر الحافظ ابن حجر في الفتح ٧/٣٣٢ أن إسناده حسن، وينظر: مقدمة الموسوعة. وقال الألباني في ضعيف سنن أبي داود ٢/٤٣٠ (٥٢٤): «إسناده ضعيف؛ محمد ابن أبي محمد مجهول لا يُعْرَف».|4:أخرجه ابن إسحاق -كما في سيرة ابن هشام ٢/٤٧-، وابن جرير ٥/٢٣٩، وابن أبي حاتم ٢/٦٠٤.|5:أخرجه ابن جرير ٥/٢٤٠.</p><p>إسناده جيد. وينظر: مقدمة الموسوعة.|6:أخرجه ابن جرير ٥/٢٤٠، وابن المنذر (٢٧١).|7:أخرجه ابن أبي حاتم ٢/٦٠٤.|8:أخرجه ابن جرير ٥/٢٤١، وابن أبي حاتم ٢/٦٠٤، وابن المنذر ١/١٣٨ من طريق ابن جريج، وعبد بن حميد كما في قطعة من تفسيره ص٢٣.|9:تفسير مقاتل بن سليمان ١/٢٦٥.
  3,13,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿قَدۡ كَانَ لَكُمۡ ءَایَةࣱ فِی فِئَتَیۡنِ ٱلۡتَقَتَاۖ فِئَةࣱ تُقَـٰتِلُ فِی سَبِیلِ ٱللَّهِ وَأُخۡرَىٰ كَافِرَةࣱ یَرَوۡنَهُم مِّثۡلَیۡهِمۡ رَأۡیَ ٱلۡعَیۡنِۚ وَٱللَّهُ یُؤَیِّدُ بِنَصۡرِهِۦ مَن یَشَاۤءُۚ إِنَّ فِی ذَ ٰ⁠لِكَ لَعِبۡرَةࣰ لِّأُو۟لِی ٱلۡأَبۡصَـٰرِ ۝١٣﴾</span> - نزول الآية</h3></p><p><div></p><p><p><span class="item-no">١٢١٣٩<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق العوفي- في قوله: <span class="qpc-hafs">﴿قد كان لكم آية في فئتين﴾</span> الآية، قال: أُنزِلت في التخفيف يوم بدر على المؤمنين؛ كانوا يومئذ ثلاثمائة وثلاثة عشر رجلًا، وكان المشركون مِثْلَيْهم ستةً وعشرين وستمائة، فأيّد اللهُ المؤمنين، فكان هذا في التخفيف على المؤمنين{1}<span class=comment-ref>١١٢٦</span>. (٣/٤٧٥)</p></p><p></div></p><p><div><span class=comment-ref>١١٢٦</span> <span class="comment-type-2">انتَقَدَ</span> <u>ابنُ جرير</u> (٥/٢٤٧) قولَ ابن عباس <span class="mustanad">مستندًا لمخالفته ما تَواتَرَتْ به الأخبارُ مِن عدد المسلمين يوم بدر</span>، فقال: «وهذه الروايةُ خلافُ ما تظاهرت به الأخبار عن عِدَّة المشركين يوم بدر، وذلك أنّ الناس إنما اختلفوا في عددهم على وجهين؛ فقال بعضهم: كان عددهم ألفًا. وقال بعضهم: ما بين التسعمائة إلى الألف».</div></p><p><div></p><p><p><span class="item-no">١٢١٤٠<span class="dash">-</span></span> عن <span class="name-2">عكرمة</span> مولى ابن عباس، قال: في أهل بدرٍ نزلت: <span class="qpc-hafs">﴿وإذ يعدكم الله إحدى الطائفتين أنها لكم﴾</span> [الأنفال:٧]، وفيهم نزلت: <span class="qpc-hafs">﴿سيهزم الجمع﴾</span> [القمر:٤٥] الآية، وفيهم نزلت: <span class="qpc-hafs">﴿حتى إذا أخذنا مترفيهم بالعذاب﴾</span> [المؤمنون:٦٤]، وفيهم نزلت: <span class="qpc-hafs">﴿ليقطع طرفا من الذين كفروا﴾</span> [آل عمران:١٢٧]، وفيهم نزلت: <span class="qpc-hafs">﴿ليس لك من الأمر شيء﴾</span> [آل عمران:١٢٨]، وفيهم نزلت: <span class="qpc-hafs">﴿ألم تر إلى الذين بدلوا نعمة الله كفرا﴾</span> [إبراهيم:٢٨]، وفيهم نزلت: <span class="qpc-hafs">﴿ولا تكونوا كالذين خرجوا من ديارهم بطرا ورئاء﴾</span> [الأنعام:٤٧]، وفيهم نزلت: <span class="qpc-hafs">﴿قد كان لكم آية في فئتين التقتا﴾</span>{2}. (٣/٤٧٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢١٤١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: قوله سبحانه: <span class="qpc-hafs">﴿قد كان لكم آية في فئتين﴾</span>، وذلك أنّ بني قَيْنُقاع مِن اليهود أتَوُا النبيَّ ﷺ بعد قتال بدر يوعدونه القتالَ كما قُتِل كُفّارُ مكة يوم بدر؛ فأنزل الله ﷿: <span class="qpc-hafs">﴿قد كان لكم آية﴾</span>{3}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿قَدۡ كَانَ لَكُمۡ ءَایَةࣱ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">١٢١٤٢<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دِعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿قد كان لكم آية﴾</span>، قال: عِبْرَة وتَفَكُّرٌ{4}. (٣/٤٧٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢١٤٣<span class="dash">-</span></span> عن <span class="name-2">الربيع بن أنس</span> -من طريق أبي جعفر- في قوله: <span class="qpc-hafs">﴿قد كان لكم آية﴾</span>، يقول: قد كان لكم في هؤلاء عِبْرَة ومُتَفَكَّر{5}. (٣/٤٧٥)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿فِی فِئَتَیۡنِ ٱلۡتَقَتَاۖ فِئَةࣱ تُقَـٰتِلُ فِی سَبِیلِ ٱللَّهِ وَأُخۡرَىٰ كَافِرَةࣱ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">١٢١٤٤<span class="dash">-</span></span> عن عليِّ بن أبي طالب، قال: سار رسول الله ﷺ إلى بدر، فسَبَقْنا المشركين إليها، فوجدنا فيها رجلين؛ منهم رجلٌ مِن قريش، ومولًى لعُقْبَة بن أبي مُعَيْط، فأمّا القُرَشِيُّ فانفَلَتَ، وأمّا مولى عُقْبَة فأخذناه، فجعلنا نقول: كم القوم؟ فيقول: هم -واللهِ- كثيرٌ شديدٌ بأسُهم. فجعل المسلمون إذا قال ذلك ضربوه، حتى انتَهَوْا به إلى رسول الله ﷺ، فقال له: <b>«كم القوم؟»</b>. فقال: هم –واللهِ- كثيرٌ شديدٌ بأسُهم. فجَهَدَ{6} النبي ﷺ على أن يخبرهم كم هم، فأبى. ثُمَّ إنّ رسول الله ﷺ سأله: <b>«كم يَنحَرُون مِن الجُزُر؟»</b>. قال: عشرةً كُلَّ يوم. قال رسول الله ﷺ: <b>«القومُ ألفٌ»</b>{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢١٤٥<span class="dash">-</span></span> عن عروة بن الزبير، قال: بعث النبي ﷺ نفرًا من أصحابه إلى ماء بدر يلتمسون الخبر له عليه، فأصابوا راوِيةً{8} من قريش، فيها أسْلم غلام بني الحجاج، وعَرِيضٌ أبو يسار غلام بني العاص، فأتَوْا بهما رسولَ الله ﷺ، فقال رسول الله ﷺ لهما: <b>«كم القوم؟»</b>. قالا: كثير. قال: <b>«ما عِدَّتُهم؟».</b> قالا: لا ندري. قال: <b>«كم ينحرون كلَّ يوم؟»</b>. قالا: يومًا تسعًا، ويومًا عشرًا. قال رسول الله ﷺ: <b>«القومُ ما بين التسعمائة إلى الألف»</b>{9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢١٤٦<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن مسعود</span> -من طريق أبي عبيدة- قال: أسَرْنا رجلًا منهم -يعني: من المشركين- يومَ بدر، فقلنا: كم كنتم؟ قال: ألفًا{10}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢١٤٧<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق ابن إسحاق بسنده- <span class="qpc-hafs">﴿قد كان لكم آية في فئتين التقتا فئة تقاتل في سبيل الله﴾</span> قال: أصحاب رسول الله ﷺ ببدر، <span class="qpc-hafs">﴿وأخرى كافرة﴾</span> فئة قريش الكُفّار{11}. (٣/٤٧٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢١٤٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق مِقْسَم-: أنّ أهل بدر كانوا ثلاثمائة وثلاثة عشر؛ المهاجرون منهم خمسة وسبعون، وكانت هزيمة بدرٍ لِسَبْعَ عَشْرَةَ مِن رمضان، لَيْلَةَ جُمْعَة{12}. (٣/٤٧٥-٤٧٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢١٤٩<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نَجِيح- قوله: <span class="qpc-hafs">﴿فئة تقاتل في سبيل الله﴾</span> قال: محمد ﷺ وأصحابه، <span class="qpc-hafs">﴿وأخرى كافرة﴾</span> قال: مشركي قريش يوم بدر{13}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢١٥٠<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿قد كان لكم آية في فئتين﴾</span>، قال: في محمد وأصحابه، ومشركي قريش يوم بدر{14}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢١٥١<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span> -من طريق ابن جريج- قال: <span class="qpc-hafs">﴿قد كان لكم آية في فئتين التقتا فئة تقاتل في سبيل الله﴾</span> محمد ﷺ وأصحابه، <span class="qpc-hafs">﴿وأخرى كافرة﴾</span> قريش يوم بدر{15}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢١٥٢<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دِعامة</span> -من طريق سعيد- قوله: <span class="qpc-hafs">﴿قد كان لكم آية في فئتين التقتا فئة تقاتل في سبيل الله وأخرى كافرة يرونهم مثليهم رأي العين﴾</span>، قال: ذلكم يوم بدر، ألفٌ المشركون أو قاربوا، وكان أصحاب رسول الله ﷺ ثلاثمائة وبضعة عشر رجلًا{16}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢١٥٣<span class="dash">-</span></span> عن <span class="name-2">الربيع بن أنس</span> -من طريق أبي جعفر- في قوله: <span class="qpc-hafs">﴿قد كان لكم آية﴾</span>، يقول: قد كان لكم في هؤلاء عِبْرَةٌ ومُتَفَكَّر، أيَّدهم اللهُ ونصرهم على عدوِّهم، وذلك يوم بدر، كان المشركون تسعمائة وخمسين رجلًا، وكان أصحاب محمد ﷺ ثلاثمائة وثلاثة عشر رجلًا{17}. (٣/٤٧٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢١٥٤<span class="dash">-</span></span> عن <span class="name-3">عبد الملك ابن جُرَيْج</span> -من طريق حجاج-: كان أصحابُ رسول الله ﷺ ثلاثمائة وبضعة عشر، والمشركون ما بين التسعمائة إلى الألف{18}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢١٥٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: وقوله سبحانه: <span class="qpc-hafs">﴿قد كان لكم آية في فئتين﴾</span>، وذلك أنّ بَنِي قَيْنُقاع من اليهود أتَوُا النبي ﷺ بعد قتال بدر يُوعِدُونه القتالَ كما قُتِل كفارُ مكة يوم بدر؛ فأنزل الله ﷿: <span class="qpc-hafs">﴿قد كان لكم آية﴾</span> معشر اليهود، يعني: عبرة <span class="qpc-hafs">﴿في فئتين التقتا﴾</span> فئة المشركين، وفئة المؤمنين يوم بدر التقتا؛ <span class="qpc-hafs">﴿فئة تقاتل في سبيل الله﴾</span> وهو النبي ﷺ وأصحابه يوم بدر، <span class="qpc-hafs">﴿وأخرى كافرة﴾</span> أبو جهل والمشركين{19}، <span class="qpc-hafs">﴿يرونهم مثليهم﴾</span> رأتِ اليهودُ أنّ الكفار مِثْلُ المؤمنين في الكثرة <span class="qpc-hafs">﴿رأي العين﴾</span>، وكان الكفار يومئذ سبعمائة رجل، عليهم أبو جهل. وذلك أنّ النبي ﷺ وأصحابه كانوا ثلاثمائة وثلاثة عشر رجلًا، بين كُلِّ أربعةٍ بعيرٌ، ومعهم فَرَسان؛ أحدُهما مع أبي مَرْثَدٍ الغَنَوِيِّ، والآخَرُ مع المِقْداد بن الأسود الكِندِيِّ، ومعهم سِتَّةُ أدْراعٍ، والمشركون ألف رجل، سبعمائة دارِع{20}، عليهم أبو جهل، وثلاثمائة حاسِر{21}، ثم حبس الأَخْنَسُ بنُ شَرِيق ثلاثمائةِ رجلٍ من بني زُهْرة عن قتال النبي ﷺ؛ فبقي المشركون في سبعمائة رجل{22}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿یَرَوۡنَهُم مِّثۡلَیۡهِمۡ رَأۡیَ ٱلۡعَیۡنِۚ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">١٢١٥٦<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن مسعود</span>، في قوله: <span class="qpc-hafs">﴿قد كان لكم آية في فئتين﴾</span> الآية، قال: هذا يوم بدر، نظرنا إلى المشركين فرأيناهم يُضْعِفون علينا، ثم نظرنا إليهم فما رأيناهم يزيدون علينا رجلًا واحدًا، وذلك قول الله: <span class="qpc-hafs">﴿وإذ يريكموهم إذ التقيتم في أعينكم قليلا ويقللكم في أعينهم﴾</span> [الأنفال:٤٤]{23}<span class=comment-ref>١١٢٧</span>. (٣/٤٧٥)</p></p><p></div></p><p><div><span class=comment-ref>١١٢٧</span> اختلف المفسرون في أي الفئتين رأت صاحبتها مثلها، <b>فذهب قومٌ</b> إلى أنّ الفئة المسلمة هي التي رأت الأخرى مثلَيْ أنفسها، وهؤلاء منهم من قال: قلَّلَها الله ﷿ في أعينها حتى رأتها مثلَيْ عدد أنفسها، ثم قلَّلها في حال أخرى، فرأتها مثل عدد أنفسها وذكر <u>ابنُ جرير</u> (٥/٢٤٦) أن التقليل على هذا القول الذي قال به ابن مسعود له معنيان: <b>أحدهما</b>: أن يكون أحد المِثْلَين هو العدد الذي مثل الفئة التي رأتهم، والمثل الآخر هو الضعف الزائد على عددهم. <b>ثانيهما</b>: هو أن أراهم عدد المشركين مثل عددهم لا يزيدون عليهم، وذلك هو الذي قال الله -جلَّ ثناؤه- فيه: <span class="qpc-hafs">﴿وإذ يريكموهم إذ التقيتم في أعينكم قليلا﴾</span> [الأنفال:٤٤]. ومنهم مَن قال: لم يُقلَّلُوا في أعينهم، ولكن الله أيدهم بنصره.</p><p>و<span class="comment-type-2">انتَقَد</span> <u>ابنُ جرير</u> (٥/٢٤٧) القول بعدم التقليل <span class="mustanad">مستندًا لمخالفته ما تواترت به الأخبار من عدد المسلمين يوم بدر</span>، فقال: «وهذه الرواية خلاف ما تظاهرت به الأخبار عن عِدَّة المشركين يوم بدر، وذلك أنّ الناس إنما اختلفوا في عددهم على وجْهَين، فقال بعضهم: كان عددهم ألفًا، وقال بعضهم: ما بين التسعمائة إلى الألف».</p><p>وبنحو <span class="comment-type-2">نقده قال</span> <u>ابنُ كثير</u> (٣/٢٥).</p><p>و<span class="comment-type-3">رجَّح</span> <u>ابنُ جرير</u> (٥/٢٤٩) القول الأول الذي قاله ابن مسعود، فقال بعد ذكره لروايات عن أن عدد المسلمين في بدر زاد على التسعمائة: «فإذا كان ما قاله مَن حكَيْناه ممن ذكر أن عددهم كان زائدًا على التسعمائة، فالتأويل الأول الذي قلناه على الرواية التي روينا عن ابن مسعود أولى بتأويل الآية».</p><p>و<span class="comment-type-2">انتَقَدَ</span> <u>ابنُ جرير</u> (٥/٢٥١ بتصرف) قول مَن قال إن الفئة التي رأت هي الفئة الكافرة. <span class="mustanad">مستندًا لمخالفته لظاهر القرآن</span> فقال: «وهذا خلاف ما دل عليه ظاهر التنزيل؛ لأن الله -جل ثناؤه- قال في كتابه: <span class="qpc-hafs">﴿وإذ يريكموهم إذ التقيتم في أعينكم قليلا ويقللكم في أعينهم﴾</span> فأخبر أن كُلًّا من الطائفتين قلَّل عددهم في مرأى الأخرى».</p><p>وبنحوه <span class="comment-type-2">انتقده</span> <u>ابن عطية</u> (٢/١٦٩).</div></p><p><div></p><p><p><span class="item-no">١٢١٥٧<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دِعامة</span> -من طريق مَعْمَر- في قوله: <span class="qpc-hafs">﴿قد كان لكم آية في فئتين التقتا فئة﴾</span> إلى قوله: <span class="qpc-hafs">﴿رأي العين﴾</span>، قال: يُضْعِفون عليهم، فقتلوا منهم سبعين، وأسروا سبعين يوم بدر{24}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢١٥٨<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿يرونهم مثليهم﴾</span>، رأت اليهودُ أنّ الكُفّار مثل المؤمنين في الكثرة <span class="qpc-hafs">﴿رأي العين﴾</span>{22}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَٱللَّهُ یُؤَیِّدُ بِنَصۡرِهِۦ مَن یَشَاۤءُۚ إِنَّ فِی ذَ ٰ⁠لِكَ لَعِبۡرَةࣰ لِّأُو۟لِی ٱلۡأَبۡصَـٰرِ ۝١٣﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">١٢١٥٩<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>: أنّ نافع بن الأزرق سأله عن قوله: <span class="qpc-hafs">﴿يؤيد بنصره من يشاء﴾</span>. قال: يُقَوِّي بنصره مَن يشاء. قال: وهل تعرف العربُ ذلك؟ قال: نعم، أما سمعتَ قولَ حسّان بن ثابت:</p><p>برجال لستمو أمثالهم أيّدوا جبريل نصرًا فنزل؟{26}. (٣/٤٧٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢١٦٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق العوفي- قوله: <span class="qpc-hafs">﴿والله يؤيد بنصره من يشاء﴾</span>، يعني: فأيّد الله المؤمنين بنصره. قال: كان هذا في التخفيف على المؤمنين{27}. (٣/٤٧٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢١٦١<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دِعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿إن في ذلك لعبرة لأولي الأبصار﴾</span>، يقول: لقد كان لهم في هؤلاء عِبْرَةٌ وتَفَكُّرٌ، أيّدهم الله، ونصرهم على عدوّهم{28}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢١٦٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿والله يؤيد بنصره﴾</span> يعني: بنصره <span class="qpc-hafs">﴿من يشاء﴾</span>؛ فينصره الله ﷿؛ القليل على الكثير، <span class="qpc-hafs">﴿إن في ذلك﴾</span> يعني: يقوي في نصرهم، نصر المؤمنين وهم قليل، وهزيمة الكفار وهم كثير، <span class="qpc-hafs">﴿لعبرة لأولي الأبصار﴾</span> يعني: الناظرين في أمر الله ﷿ وطاعته، لَعِبْرَةً وتفكرًا لأولي الأبصار حين أظهر الله ﷿ القليل على الكثير{29}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ٥/٢٤٦-٢٤٧، وابن أبي حاتم ٢/٦٠٦ مختصرًا.</p><p>الإسناد ضعيف، لكنها صحيفة صالحة ما لم تأتِ بمنكر أو مخالفة. ينظر: مقدمة الموسوعة.|2:أخرجه عبد الرزاق ٥/٣٦١-٣٦٢ (٩٧٣٤) عن مَعْمَر، قال: أخبَرَني مَن سمع عكرمة يقول ... وذكره.</p><p>وهذا إسناد ضعيف؛ فيه رجل مُبْهَم.|3:تفسير مقاتل بن سليمان ١/٢٦٥.|4:أخرجه ابن جرير ٥/٢٤١، وابن المنذر ١/١٣٨.|5:أخرجه ابن جرير ٢/٢٤٢، وابن أبي حاتم ٢/٦٠٤.|6:جَهَدَ الرجل في الشيء، أي: جَدَّ فيه وبالغ. النهاية (جهد).|7:أخرجه أحمد ٢/٢٥٩ (٩٤٨)، وابن جرير ٥/٢٤٧.</p><p>قال الهيثمي في المجمع ٦/٧٦ (٩٩٥٣): «روى أبو داود منه طرفًا، رواه أحمد، والبزّار، ورجال أحمد رجال الصحيح، غير حارثة ابن مضرب، وهو ثقة».|8:الراوية: أصل الراوية يُطلق على البعير أو البغل أو الحمار الذي يُستقى عليه الماء، ويُطلق أيضًا على المَزادة، وهي الوعاء الذي كون فيه الماء، وقد يُطلق أيضًا على الرجل المُسْتقي. اللسان والقاموس (روي).|9:أخرجه ابن إسحاق -كما في سيرة ابن هشام ١/٦١٦- مرسلًا، ومن طريقه ابن جرير ٥/٢٤٨.|10:أخرجه ابن جرير ٥/٢٤٨، ٢٥١، والثعلبي ٣/٢٢، ٤/٣٦٢.</p><p>إسناده ضعيف؛ أبو عبيدة لم يسمع من أبيه عبد الله بن مسعود، كما في تحفة التحصيل ص١٦٥.|11:أخرجه ابن إسحاق -كما في سيرة ابن هشام ٢/٤٧-، وابن جرير ٥/٢٤٢، وابن أبي حاتم ٢/٦٠٥.|12:أخرجه ابن أبي شيبة ١٤/٣٨٢.|13:أخرجه ابن جرير ٥/٢٤٢، وابن المنذر ١/١٣٨ من طريق ابن جُرَيْج، وابن أبي حاتم ٢/٦٠٥.|14:أخرجه ابن جرير ٥/٢٤٢، وابن المنذر ١/١٣٨ من طريق ابن جريج.|15:أخرجه ابن جرير ٥/٢٤٢.|16:أخرجه ابن جرير ٥/٢٤٨، وابن المنذر ١/١٣٩. وذكر نحوه يحيى بن سلام -كما في تفسير ابن أبي زمنين ١/٢٧٧-. وأخرجه عبد بن حميد كما في قطعة من تفسيره ص٢٣ ولكنّه ذكر أنّ المشركين كانوا تسعمائة وخمسين رجلًا.|17:أخرجه ابن جرير ٢/٢٤٢، ٢٤٩، وابن أبي حاتم ٢/٦٠٤، ٦٠٥.|18:أخرجه ابن جرير ٥/٢٤٩.|19:كذا في المطبوع، والصواب: المشركون.|20:الدّارع: هو لابس الدِّرْع. النهاية (حسر)، والقاموس (درع).|21:الحاسِر: هو الذي لا دِرْعَ عليه ولا مِغْفَر. النهاية (حسر).|22:تفسير مقاتل بن سليمان ١/٢٦٥-٢٦٦.|23:أخرجه ابن جرير ٥/٢٤٥، وابن أبي حاتم ٢/٦٠٦ (٣٢٤٤).</p><p>إسناده ضعيف؛ فيه أسباط بن نصر الهمداني، قال ابن حجر في التقريب (٣٢٣): «صدوق، كثير الخطأ، يُغرِب».|24:أخرجه عبد الرزاق ١/١١٦، وابن جرير ٥/٢٤٩، وابن أبي حاتم ٢/٦٠٦.|25:تفسير مقاتل بن سليمان ١/٢٦٥-٢٦٦.|26:أخرجه الطستي في مسائله -كما في الإتقان ٢/٧٣-.|27:أخرجه ابن جرير ٥/٢٤٦-٢٤٧، وابن أبي حاتم ٢/٦٠٦. وقد تقدّم بتمامه في نزول الآية.|28:أخرجه عبد بن حميد كما في قطعة من تفسيره ص٢٣، وابن جرير ٥/٢٥٣، وابن المنذر ١/١٣٩.|29:تفسير مقاتل بن سليمان ١/٢٦٦.
  3,14,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿زُیِّنَ لِلنَّاسِ حُبُّ ٱلشَّهَوَ ٰ⁠تِ مِنَ ٱلنِّسَاۤءِ وَٱلۡبَنِینَ﴾</span> - نزول الآية، وتفسيرها</h3></p><p><div></p><p><p><span class="item-no">١٢١٦٣<span class="dash">-</span></span> عن <span class="name-1">عمر بن الخطاب</span> -من طريق أبي بكر بن حفص بن عمر بن سعد- أنّه قال: قرأ عمر هذه الآية: <span class="qpc-hafs">﴿زين للناس حب الشهوات من النساء﴾</span>، فبكى عمر، وقال: نزلت بعد ماذا؟ بعد ما زيّنها{1}. (٣/٤٧٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢١٦٤<span class="dash">-</span></span> عن <span class="name-1">عمر بن الخطاب</span> -من طريق أبي بكر بن حفص بن عمر بن سعد- أنّه قال: لَمّا نزلت <span class="qpc-hafs">﴿زين للناس حب الشهوات﴾</span> إلى آخر الآية؛ قال عمر: الآن يا ربّ؟! حين زينتَها لنا. فنزلت: <span class="qpc-hafs">﴿قل أؤنبئكم﴾</span> [آل عمران:١٥] الآية كلها{2}. (٣/٤٧٦-٤٧٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢١٦٥<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق أبي الأَشْهَب- في قوله: <span class="qpc-hafs">﴿زين للناس﴾</span> الآية، قال: مَن زَيَّنَها؟ ما أحد أشدَّ لها ذمًّا مِن خالقها{3}<span class=comment-ref>١١٢٨</span>. (٣/٤٧٧)</p></p><p></div></p><p><div><span class=comment-ref>١١٢٨</span> لم يذكر <u>ابنُ جرير</u> (٥/٢٥٤) غيرَ هذا القول.</div></p><p><div></p><p><p><span class="item-no">١٢١٦٦<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق عبّاد بن منصور-في قوله: <span class="qpc-hafs">﴿زيّن للناس﴾</span> الآية، قال: زَيَّن لهم الشيطانُ{4}<span class=comment-ref>١١٢٩</span>. (٣/٤٧٧)</p></p><p></div></p><p><div><span class=comment-ref>١١٢٩</span> اختلف المفسرون في مَن المُزَيِّنُ هنا؟ <b>فذهب قومٌ</b> إلى أنّه الله، <b>وذهب قوم</b> إلى أنّه الشيطان. وذكر <u>ابنُ عطية</u> (٢/١٧٠) أنّ ظاهر قول عمر: الآن، يا ربّ. مع القول الأوّل، وظاهرُ قول الحسن مع الثاني.</p><p>ثُمَّ أفاد (٢/١٧١) احتمالَ الآية لِكِلا المعنيين، فقال: «وإذا قِيل: زَيَّن الله. فمعناه: بالإيجاد، والتهيئة للانتفاع، وإنشاء الجِبِلَّة [على] المَيْل إلى هذه الأشياء. وإذا قيل: زَيَّن الشيطانُ. فمعناه: بالوسوسة، والخديعة، وتحسين أخذها من غير وجوهها. والآية تحتملُ هذين النوعين مِن التزيين، ولا يختلف مع هذا النظر».</div></p><p><div></p><p><p><span class="item-no">١٢١٦٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿زيّن للنّاس﴾</span> يعني: الكفار <span class="qpc-hafs">﴿حبّ الشهوات من النساء والبنين﴾</span>{5}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَٱلۡقَنَـٰطِیرِ ٱلۡمُقَنطَرَةِ مِنَ ٱلذَّهَبِ وَٱلۡفِضَّةِ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">١٢١٦٨<span class="dash">-</span></span> عن أبي هريرة، قال: قال رسول الله ﷺ: <b>«القِنطارُ: اثنا عشر ألف أُوقِيَّة»</b>{6}. (٣/٤٧٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢١٦٩<span class="dash">-</span></span> عن أنس بن مالك، قال: سُئِل رسول الله ﷺ عن قول الله: <span class="qpc-hafs">﴿والقناطير المقنطرة﴾</span>. قال: <b>«القنطارُ: ألفا أُوقِيَّة»</b>{7}. (٣/٤٧٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢١٧٠<span class="dash">-</span></span> عن أنس بن مالك، قال: قال رسول الله ﷺ: <b>«القِنطارُ: ألفُ دينار»</b>{8}. (٣/٤٧٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢١٧١<span class="dash">-</span></span> عن أُبَيِّ بن كعب، قال: قال رسول الله ﷺ: <b>«والقنطارُ: ألفُ أُوقِيَّة ومائتا أُوقِيَّة»</b>{9}. (٣/٤٧٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢١٧٢<span class="dash">-</span></span> عن أنس بن مالك، عن رسول الله ﷺ: <span class="qpc-hafs">﴿وآتيتم إحداهن قنطارا﴾</span>، قال: <b>«ألفا مئين».</b> يعني: ألفين{10}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢١٧٣<span class="dash">-</span></span> عن أبي الدَّرْداء، قال: قال رسول الله ﷺ: <b>«مَن قرأ في ليلة مائةَ آية لم يُكْتَب مِن الغافلين، ومَن قرأ بمائتي آية بُعِث مِن القانتين، ومَن قرأ خمسمائة آية إلى ألف آية أصبح له قِنطارٌ من الأجر، والقنطارُ مِثلُ التَّلِّ العظيم»</b>{11}. (٣/٤٧٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢١٧٤<span class="dash">-</span></span> عن الحسن، قال: قال رسول الله ﷺ: <b>«القنطارُ: ألفٌ ومائتا دينار»</b>{12}. (٣/٤٧٩،٤٧٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢١٧٥<span class="dash">-</span></span> عن <span class="name-1">معاذ بن جبل</span> -من طريق سالم بن أبي الجَعْد- قال: القنطارُ: ألفٌ ومائتا أُوقِيَّة{13}<span class=comment-ref>١١٣٠</span>. (٣/٤٧٩)</p></p><p></div></p><p><div><span class=comment-ref>١١٣٠</span> <span class="comment-type-3">رجَّح</span> <u>ابنُ عطية</u> (٢/١٧١ بتصرف) هذا القولَ، فقال: «اختلف الناس في تحرير حدِّه كم هو؟ فروى أُبَي بن كعب عن النَّبي ﵇ أنّه قال: <b>«القنطار ألف ومائتا أوقية»</b>. وهو أصح الأقوال». ولم يذكر مستندًا. ثُمَّ قال بعد ذلك: «لكنَّ القنطار على هذا يختلف باختلاف البلاد في قدر الأُوقِيَّة».</div></p><p><div></p><p><p><span class="item-no">١٢١٧٦<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عمر</span> -من طريق أبي طَيْبَة- قال: القنطارُ: ألفٌ ومائتا أُوقِيَّة{14}. (٣/٤٧٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢١٧٧<span class="dash">-</span></span> عن <span class="name-1">أبي هريرة</span>، مثله{15}. (٣/٤٧٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢١٧٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عمر</span> -من طريق عطاء الخراساني- أنّه سُئِل: ما القنطار؟ قال: سبعون ألفًا{16}. (٣/٤٨٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢١٧٩<span class="dash">-</span></span> عن <span class="name-1">أبي سعيد الخدري</span> -من طريق أبي نَضْرَة- قال: القِنطارُ: مِلْءُ مَسْكِ{17} الثَّورِ ذهبًا{18}. (٣/٤٨٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢١٨٠<span class="dash">-</span></span> وعن <span class="name-2">حماد بن زيد</span> -من طريق محمد بن موسى الحَرَشِيّ- مرفوعًا، والموقوف أصحّ{19}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢١٨١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق العوفي- قال: القنطارُ: ألفٌ ومائتا دينار، ومِن الفضّة ألفٌ ومائتا مِثْقال{20}. (٣/٤٧٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢١٨٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>: أنّ نافع بن الأزرق قال له: أخبِرْني عن قوله ﷿: <span class="qpc-hafs">﴿والقناطير﴾</span>. قال: أمّا قولُنا أهلَ البيت فإنّا نقولُ: القِنطارُ: عَشَرَةُ آلافِ مِثقال. وأمّا بنو حِسْلٍ فإنّهم يقولون: مِلْءُ مَسْكِ ثَوْرٍ ذهبًا أو فضة. قال: فهل تعرف العرب ذلك؟ قال: نعم، أما سمعت عَدِيَّ بنَ زيد وهو يقول:</p><p>وكانوا ملوك الرُّوم تُجْبى إليهم قناطيرُها مِن بين قُلٍّ وزائد{21}. (٣/٤٨٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢١٨٣<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢١٨٤<span class="dash">-</span></span> و<span class="name-2">عكرمة مولى ابن عباس</span>: القنطارُ: هو مائة ألف، ومائة مَن، ومائة رِطْل، ومائة مِثقال، ومائة درهم{22}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢١٨٥<span class="dash">-</span></span> عن <span class="name-2">سعيد بن المسيب</span>، قال: القنطارُ: ثمانون ألفًا{23}. (٣/٤٨٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢١٨٦<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span>، قال: القنطارُ: سبعون ألف دينار{23}. (٣/٤٨٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢١٨٧<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- قوله: <span class="qpc-hafs">﴿القناطير المقنطرة﴾</span>، قال: فالقنطارُ سبعون ألفًا{25}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢١٨٨<span class="dash">-</span></span> عن <span class="name-2">طاووس بن كَيْسان</span>، نحو ذلك{19}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢١٨٩<span class="dash">-</span></span> عن <span class="name-2">الضحاك بن مُزاحِم</span> -من طريق جُوَيْبِر- قال: القنطارُ: ألفُ دِينار، ومن الوَرِق: اثنا عشر ألف درهم{27}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢١٩٠<span class="dash">-</span></span> عن <span class="name-2">الضَّحّاك بن مُزاحِم</span> -من طريق جُوَيْبِر- في قوله: <span class="qpc-hafs">﴿القناطير﴾</span>، قال: مِن العرب مَن يقول: القنطارُ: ألفُ دينار. ومنهم مَن يقول: اثنا عشر ألفًا{25}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢١٩١<span class="dash">-</span></span> عن <span class="name-2">الضحاك بن مُزاحِم</span>: <span class="qpc-hafs">﴿المقنطرة﴾</span>: المُحَصَّنَة المُحْكَمة{22}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢١٩٢<span class="dash">-</span></span> عن <span class="name-2">أبي نَضْرَة [المنذر بن مالك العَبْدِيِّ]</span> -من طريق سعيد الجُرَيريِّ- قال: مِلْءُ مَسْكِ ثَوْرٍ ذَهَبًا{30}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢١٩٣<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق يونس- قال: القِنطارُ: ألفٌ ومائتا دينار{31}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢١٩٤<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق قتادة-: أنّ القنطار: اثنا عشر ألفًا{32}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢١٩٥<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق عوف- قال: القنطارُ: ألفُ دينار؛ دِيَةُ أحدِكم{33}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢١٩٦<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق مبارك- قال: القنطارُ: ألفٌ ومائتا دينار، وهي دِيَةُ الرَّجُل{34}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢١٩٧<span class="dash">-</span></span> عن <span class="name-2">أبي صالح [باذام]</span>، قال: القنطارُ: مائةُ رِطْلٍ{23}. (٣/٤٨٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢١٩٨<span class="dash">-</span></span> عن <span class="name-2">أبي جعفر [محمد بن علي بن الحسين]</span> -من طريق سعيد بن طَرِيف- قال: القِنطارُ: خمسةَ عشرَ ألفَ مثقالٍ، والمثقالُ: أربعةٌ وعشرون قيراطًا{25}. (٣/٤٨١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢١٩٩<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دِعامة</span> -من طريق مَعْمَر- قال: كنا نُحَدَّث: أنّ القِنطار: مائةُ رِطْلٍ مِن الذهب، أو ثمانون ألفًا مِن الوَرِق{37}. (٣/٤٨٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٢٠٠<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيِّ</span> -من طريق أسباط-: القنطار يكون مائة رطل، وهو ثمانيةُ آلاف مِثقال{38}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٢٠١<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيِّ</span>: أربعةُ آلاف مِثقال{22}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٢٠٢<span class="dash">-</span></span> عن <span class="name-2">عاصم بن أبي النَّجُود</span> -من طريق العلاء بن المُسَيّب- قال: القنطارُ: ألفٌ ومائتا أوقية{14}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٢٠٣<span class="dash">-</span></span> عن <span class="name-2">الربيع بن أنس</span> -من طريق أبي جعفر- <span class="qpc-hafs">﴿والقناطير المقنطرة﴾</span>، قال: المالُ الكثيرُ، بعضُه على بعض{30}<span class=comment-ref>١١٣١</span>. (٣/٤٨١)</p></p><p></div></p><p><div><span class=comment-ref>١١٣١</span> <span class="comment-type-3">رجَّح</span> <u>ابنُ جرير</u> (٥/٢٦٠ بتصرف) قول الربيع والضحاك بعدمِ حَدِّ القنطارِ بحَدٍّ معلوم، <span class="mustanad">مستندًا إلى أنّ العرب لم تكن تحدُّه بِحَدٍّ</span>، وإلا لَما وقع الاختلافُ، فقال: «وقد ذكر بعضُ أهل العلم بكلام العرب: أنّ العرب لا تَحُدُّ القِنطارَ بمِقدارٍ معلوم مِن الوَزْنِ، ولكنها تقول: هو قَدْرٌ ووَزْنٌ، وقد ينبغي أن يكون ذلك كذلك؛ لأنّ ذلك لو كان محدودًا قدرُه عندها لم يكن بين مُتَقَدِّمِي أهلِ التأويل فيه كُلُّ هذا الاختلاف. فالصواب في ذلك أن يُقال كما قال الربيع بن أنس، ولا يُحَدَّ قَدْرُ وزنه بحَدٍّ».</p><p>وكذا <span class="comment-type-3">رجَّحه</span> <u>ابنُ كثير</u> (٣/٢٨).</p><p>وذكر <u>ابنُ جرير</u> (٥/٢٦٠) أنّ <span class="qpc-hafs">﴿المقنطرة﴾</span>: هي المُضَعَّفة، فقال: «وأمّا <span class="qpc-hafs">﴿المقنطرة﴾</span>: فهي المُضَعَّفَة، وكأن القناطير ثلاثة، والمقنطرة تسعة، وهو كما قال الربيع بن أنس».</p><p><span class="comment-type-2">وانتقدَهُ</span> <u>ابنُ عطية</u> (٢/١٧٢) بقوله: «وهذا ضُعْفُ نَظَرٍ، وكلامٌ غيرُ صحيح». ولم يذكر سبب ذلك.</div></p><p><div></p><p><p><span class="item-no">١٢٢٠٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿والقناطير المقنطرة﴾</span> يعني: المال الكثير <span class="qpc-hafs">﴿من الذهب والفضة﴾</span>، فأمّا الذهبُ: فهو ألف دينار ومائتا دينار، والفضة: ألفٌ ومائتا مِثقال{5}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿ٱلۡمُقَنطَرَةِ مِنَ ٱلذَّهَبِ وَٱلۡفِضَّةِ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">١٢٢٠٥<span class="dash">-</span></span> عن <span class="name-2">الضَّحّاك بن مُزاحِم</span> -من طريق عبيد- في قوله: <span class="qpc-hafs">﴿والقناطير المقنطرة﴾</span>، يعني: المال الكثير من الذهب والفضة{43}. (٣/٤٨١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٢٠٦<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دِعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿والقناطير المقنطرة من الذهب والفضة﴾</span>، قال: والمقنطرة: المال الكثير، بعضُه على بعض{44}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٢٠٧<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- <span class="qpc-hafs">﴿المقنطرة﴾</span>، يعني: المضروبة، حتى صارت دنانير أو دراهم{45}<span class=comment-ref>١١٣٢</span>. (٣/٤٨١)</p></p><p></div></p><p><div><span class=comment-ref>١١٣٢</span> اختُلِف في معنى <span class="qpc-hafs">﴿المقنطرة﴾</span>؛ <b>فذهب بعضهم</b> إلى أنّها: المال الكثير بعضه فوق بعض. <b>وذهب بعضهم</b> إلى أنها: المضروبة حتى صارت دنانيرَ ودراهمَ.</p><p>و<span class="comment-type-4">ذَهَب</span> <u>ابنُ عطية</u> (٢/١٧٣) إلى أنّ <span class="qpc-hafs">﴿المقنطرة﴾</span> فيها إشارةٌ لحضور المال الفعلي، وذاك أشهى للنفس، فقال بعد ذكره لكِلا القولين: «والذي أقول: إنها إشارةٌ إلى حضور المال، وكونه عتيدًا، فذلك أشهى».</div></p><p><div></p><p><p><span class="item-no">١٢٢٠٨<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- في قوله: <span class="qpc-hafs">﴿من الذهب والفضة﴾</span>، قال: دنانير رباع{46}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَٱلۡخَیۡلِ ٱلۡمُسَوَّمَةِ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">١٢٢٠٩<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق العوفي- <span class="qpc-hafs">﴿والخيل المسومة﴾</span>، قال: الراعية{47}. (٣/٤٨١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٢١٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق مجاهد-، مثله{48}. (٣/٤٨١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٢١١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- <span class="qpc-hafs">﴿والخيل المسومة﴾</span>: يعني: مُعْلَمَة{49}. (٣/٤٨١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٢١٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عكرمة- قال: <span class="qpc-hafs">﴿والخيل المسومة﴾</span>: الرّاعِيَة، والمُطَهَّمَة{50} الحِسان. ثُمَّ قرأ: <span class="qpc-hafs">﴿شجر فيه تسيمون﴾</span>{46}. (٣/٤٨٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٢١٣<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span> -من طريق حبيب بن أبي ثابت- قال: هي الرّاتِعة{52}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٢١٤<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span> -من طريق حبيب بن أبي ثابت-: الخيل المسومة، قال: الرّاعِيَةُ التي تَرْعى{53}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٢١٥<span class="dash">-</span></span> وعن <span class="name-3">أبي سِنان [سعيد بن سنان البرجمي]</span>، نحو ذلك{54}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٢١٦<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق حبيب بن أبي ثابت- <span class="qpc-hafs">﴿والخيل المسومة﴾</span>، قال: المُطَهَّمَة الحِسان{55}. (٣/٤٨٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٢١٧<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ليث- أنّه كان يقول: الخيل الرّاعِية{47}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٢١٨<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نَجِيح- في قوله ﷿: <span class="qpc-hafs">﴿والخيل المسومة﴾</span>، قال: المُصَوَّرَة حُسْنًا{57}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٢١٩<span class="dash">-</span></span> عن <span class="name-2">الضحاك بن مُزاحِم</span>، في قوله: <span class="qpc-hafs">﴿والخيل المسومة﴾</span>، قال: الرّاعِيَة{58}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٢٢٠<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span> -من طريق بشير بن أبي عمرو الخَوْلاني- في قوله: <span class="qpc-hafs">﴿والخيل المسومة﴾</span>، قال: تسويمُها: حُسْنُها{59}. (٣/٤٨٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٢٢١<span class="dash">-</span></span> عن <span class="name-2">مكحول الدمشقي</span> -من طريق الوليد، عن بعض شيوخه- في قوله: <span class="qpc-hafs">﴿والخيل المسومة﴾</span>، قال: الغُرَّة، والتَّحْجِيل{60}. (٣/٤٨٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٢٢٢<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> –من طريق قتادة- <span class="qpc-hafs">﴿والخيل المسومة﴾</span>، قال: المُسَرَّحة في الرَّعْيِ{61}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٢٢٣<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق عبّاد بن منصور- قوله: <span class="qpc-hafs">﴿والخيل المسومة﴾</span>، قال: تَسَوَّمَ المسلمون سِيما، والمشركون سِيماهم، وكان سِيماهم الصُّوف، وقَلَّ ما التَقَتْ فِئتان إلا تَسَوَّمُوا أخيالَهم{60}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٢٢٤<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دِعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿والخيل المسومة﴾</span>، قال: وسيماها: شِيَتُها{49}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٢٢٥<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دِعامة</span> -من طريق مَعْمَر- في قوله: <span class="qpc-hafs">﴿والخيل المسوّمة﴾</span>، قال: شِيَةُ الخيل في وجوهها{64}<span class=comment-ref>١١٣٣</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>١١٣٣</span> <span class="comment-type-4">علَّق</span> <u>ابنُ عطية</u> (٢/١٧٤) على هذا القول بقوله: "ويشهد لهذا القول بيتُ لبيد:</p><p>وغداة قاع القرنتين أتينهم زجلًا يلوح خلالها التّسويم".</div></p><p><div></p><p><p><span class="item-no">١٢٢٢٦<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيِّ</span> -من طريق أسباط- <span class="qpc-hafs">﴿والخيل المسومة والأنعام﴾</span>، قال: الراعية{65}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٢٢٧<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيِّ</span> -من طريق أسباط- <span class="qpc-hafs">﴿والخيل المسومة والأنعام﴾</span>: الرائعة{49}<span class=comment-ref>١١٣٤</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>١١٣٤</span> اختلف المفسرون في معنى <span class="qpc-hafs">﴿المسومة﴾</span>؛ <b>فذهب قوم</b> إلى أنها: الراعية. و<b>ذهب قوم</b> إلى أنها: المُعَدّة للجهاد. و<b>قال آخرون</b> بأنها: الحِسان. و<b>قال غيرهم</b> بأنها: المُعْلَمة.</p><p>وهو ما <span class="comment-type-3">رجَّحه</span> <u>ابنُ جرير</u> (٥/٢٦٥) <span class="mustanad">مستنًدا إلى اللغة،</span> فقال: "أوْلى هذه الأقوال بالصواب في تأويل قوله: <span class="qpc-hafs">﴿والخيل المسومة﴾</span>: المُعْلمة بالشِّياتِ الحِسانِ الرائعة حُسنًا مَن رآها؛ لأنّ التسويم في كلام العرب هو الإعلام، فالخيل الحسان مُعْلمة بإعلام الله إيّاها بالحسن من ألوانها وشياتها وهيئاتها، وهي المُطَهَّمة أيضًا، ومن ذلك قول نابغة بني ذبيان في صفة الخيل:</p><p>بسمر كالقداح مسومات... عليها معشر أشباه جن</p><p>يعني بالمسومات: المعلمات، وقول لبيد:</p><p>وغداة قاع القرنتين أتينهم... زجلًا يلوح خلالها التسويم".</p><p>ثُمَّ <span class="comment-type-4">جَمَع</span> (٥/٢٦٥) بين تفسير المسومَة بالمُعْلَمَة، والمطهّمة، والرائعة، فقال: «فمعنى تأويل مَن تأوّل ذلك: المطهّمة، والمعْلَمة، والرائعة؛ واحدٌ».</div></p><p><div></p><p><p><span class="item-no">١٢٢٢٨<span class="dash">-</span></span> عن <span class="name-2">عبد الله بن عبد الرحمن بن أبْزى</span> -من طريق طلحة القنّاد- قال: الرّاعِية{67}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٢٢٩<span class="dash">-</span></span> عن <span class="name-2">مطر الوَرّاق</span> -من طريق ابن شَوْذَب- في قول الله تعالى: <span class="qpc-hafs">﴿المسوّمة﴾</span>، قال: منطقة بحمرة{60}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٢٣٠<span class="dash">-</span></span> عن <span class="name-2">الربيع بن أنس</span> -من طريق أبي جعفر- قوله: <span class="qpc-hafs">﴿والخيل المسومة﴾</span>، قال: الخيل الرّاعية{69}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٢٣١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿والخيل المسومة﴾</span>، يعني: السّائِمة، وهي الرّاعِية{5}<span class=comment-ref>١١٣٥</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>١١٣٥</span> <span class="comment-type-1">وجَّه</span> <u>ابنُ جرير</u> (٥/٢٦٦ بتصرف) هذا القول الذي قال به سعيد بن جبير، وابن أبزى، وابن عباس من طريق العوفي، والربيع، والحسن من طريق قتادة، ومجاهد من طريق ليث بقوله: «وأما قولُ مَن تأوّله بمعنى: الراعية؛ فإنّه ذهب إلى قول القائل: أسَمْتُ الماشيةَ فأنا أُسِيمها إسامةً: إذا رَعَيْتَها الكلأ والعشب، كما قال الله ﷿: <span class="qpc-hafs">﴿ومنه شجر فيه تسيمون﴾</span> [النحل:١٠]، بمعنى: تَرْعَون، فإذا أُرِيد أنّ الماشية هي التي رَعَتْ قيل: سامتِ الماشيةُ تسوم سَوْمًا، ولذلك قيل: إبل سائمة. بمعنى: راعية».</p><p>وبنحوه قال <u>ابنُ عطية</u> (٢/١٧٣).</p><p>ثم <span class="comment-type-2">انتَقَد</span> <u>ابنُ جرير</u> (٥/٢٦٦) هذا القول <span class="mustanad">مستندًا إلى اللغة</span>، فقال: «غير أنّه غيرُ مُسْتَفِيضٍ في كلامهم: سَوَّمْتُ الماشية، بمعنى: أرعيتها، وإنّما يُقال إذا أريد ذلك: أسمتها. فإذا كان ذلك كذلك فتوجيه تأويل <span class="qpc-hafs">﴿المسومة﴾</span> إلى أنها: المُعْلَمَة؛ بما وصفنا من المعاني التي تقدم ذكرنا لها أصحُّ».</div></p><p><div></p><p><p><span class="item-no">١٢٢٣٢<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- <span class="qpc-hafs">﴿والخيل المسوّمة﴾</span>، قال: المُعَدَّةُ للجهاد{71}<span class=comment-ref>١١٣٦</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>١١٣٦</span> <span class="comment-type-2">انتَقَدَ</span> <u>ابنُ جرير</u> (٥/٢٦٦) قولَ ابن زيد بقوله: «وأما الذي قاله ابن زيد فتأويلٌ مِن معنى <span class="qpc-hafs">﴿المسومة﴾</span> بمَعْزِل».</p><p>وكذا <span class="comment-type-4">عَلَّق</span> عليه <u>ابنُ عطية</u> (٢/١٧٤) فقال: «قوله: للجهاد. ليس من تفسير اللَّفْظَة».</div></p><p><h3><span class="qpc-hafs">﴿وَٱلۡأَنۡعَـٰمِ وَٱلۡحَرۡثِۗ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">١٢٢٣٣<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- <span class="qpc-hafs">﴿والأنعام والحرث﴾</span>، قال: الأنعام: الراعية{60}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٢٣٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿والأنعام﴾</span> وهي: الإبل، والبقر، والغنم، <span class="qpc-hafs">﴿والحرث﴾</span>{5}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿ذَ ٰ⁠لِكَ مَتَـٰعُ ٱلۡحَیَوٰةِ ٱلدُّنۡیَاۖ وَٱللَّهُ عِندَهُۥ حُسۡنُ ٱلۡمَـَٔابِ ۝١٤﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">١٢٢٣٥<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- في قوله: <span class="qpc-hafs">﴿والله عنده حسن المآب﴾</span>، قال: حسن المُنقَلَب، وهي الجنة{74}. (٣/٤٨٢-٤٨٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٢٣٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: الذي ذكر في هذه الآية: <span class="qpc-hafs">﴿متاع الحياة الدنيا والله عنده حسن المآب﴾</span>، يعني: حسن المرجع، وهي الجنّة{5}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿ذَ ٰ⁠لِكَ مَتَـٰعُ ٱلۡحَیَوٰةِ ٱلدُّنۡیَاۖ وَٱللَّهُ عِندَهُۥ حُسۡنُ ٱلۡمَـَٔابِ ۝١٤﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">١٢٢٣٧<span class="dash">-</span></span> عن أنس بن مالك، قال: قال رسول الله ﷺ: <b>«حُبِّب إلَيَّ مِن دنياكم النساءُ والطِّيبُ، وجُعِلَتْ قُرَّةُ عيني في الصلاة»</b>{76}. (٣/٤٧٧-٤٧٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٢٣٨<span class="dash">-</span></span> عن عبد الله بن عمرو، عن رسول الله ﷺ، قال: <b>«الدنيا متاعٌ، وخيرُ متاعِها المرأةُ الصالحةُ»</b>{77}. (٣/٤٨٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٢٣٩<span class="dash">-</span></span> عن <span class="name-1">عمر بن الخطاب</span> -من طريق عبد الله بن أرقم- أنّه جاء إلى عُمَر بحِلْيَةِ آنِيَةٍ وفِضَّةٍ، فقال عمر: اللَّهُمَّ، إنّك ذكرت هذا المالَ، فقلتَ: <span class="qpc-hafs">﴿زين للناس حب الشهوات﴾</span> حتى ختم الآية. وقلتَ: <span class="qpc-hafs">﴿لكيلا تأسوا على ما فاتكم ولا تفرحوا بما آتاكم﴾</span> [الحديد:٥٣]. وإنّا لا نستطيع إلا أن نفرح بما زَيَّنتَ لنا، اللَّهُمَّ، فاجعلنا نُنفِقه في حقٍّ، وأعوذ بك من شرِّه{78}. (٣/٤٧٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٢٤٠<span class="dash">-</span></span> عن قتادة، في الآية، قال: ذُكِر لنا: أنّ <span class="name-1">عمر بن الخطاب</span> كان يقول: اللَّهُمَّ، زَيَّنتَ لنا الدنيا، وأنبأتَنا أنّ ما بعدها خيرٌ منها، فاجعل حظَّنا في الذي هو خيرٌ وأبقى{79}. (٣/٤٨٣)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن المنذر (٢٧٩).|2:أخرجه ابن جرير ٥/٢٥٤، وابن أبي حاتم ٢/٦٠٦ (٣٢٤٧).</p><p>إسناده ضعيف؛ أبو بكر بن حفص بن عمر بن سعد لم يدرك عمرَ بن الخطاب؛ فإن جدَّه عمر بن سعد بن أبي وقاص وُلِد يوم مات عمر بن الخطاب، كما في التقريب (٤٩٣٧).|3:أخرجه ابن جرير ٥/٢٥٤، وابن أبي حاتم ٢/٦٠٧. وعزاه السيوطي إلى عبد بن حميد.|4:أخرجه ابن أبي حاتم ٢/٦٠٧.|5:تفسير مقاتل بن سليمان ١/٢٦٦.|6:أخرجه أحمد ١٤/٣٦٦ (٨٧٥٨)، وابن ماجه ٤/٦٣٠ (٣٦٦٠)، والدارمي ٢/٥٥٨-٥٥٩ (٣٤٦٤)، وابن حبان ٦/٣١١ (٢٥٧٣).</p><p>قال الدارقطني في العلل ٨/١٦٩ (١٤٨٦): «يرويه عاصم بن أبي النجود، واختُلِف عنه؛ فرواه عبد الصمد بن عبد الوارث وأبو عليّ الحنفي عبيد الله بن عبد المجيد عن حماد بن سلمة، عن عاصم، عن أبي صالح، عن أبي هريرة، عن النبي ﷺ. وغيره يرويه عن حماد بن سلمة موقوفًا. وكذلك قال حمّاد بن زيد عن عاصم، والموقوف أشبه». وقال البوصيري في «مصباح الزجاجة» ٤/٩٨: «إسناده صحيح». وقال الألباني في الضعيفة ٩/٧٢ (٤٠٧٦): «ضعيف».|7:أخرجه الحاكم ٢/١٩٤ (٢٧٣١).</p><p>قال الحاكم: «هذا حديث صحيح، على شرط الشيخين، ولم يخرجاه». وقال الذهبي في التلخيص: «على شرط البخاري ومسلم». وأورده الألباني في الضعيفة ٩/٧٤-٧٥ (٤٠٧٦).|8:أخرجه ابن أبي حاتم ٢/٦٠٨ (٣٢٥٥)، ٣/٩٠٦ (٥٠٥٤). وأورده الثعلبي ٣/٢٤.</p><p>إسناده ضعيف؛ فيه يزيد بن أبان الرقاشي القاصّ، قال ابن حجر في التقريب (٧٧٣٣): «زاهد ضعيف».|9:أخرجه ابن جرير ٥/٢٥٥. وأورده الثعلبي ٦/٥٤.</p><p>قال ابن كثير في تفسيره ٢/٢٠: «وهذا حديث مُنكَرٌ أيضًا، والأقربُ أن يكون موقوفًا على أُبَيِّ بن كعب، كغيره من الصحابة». وقال الألباني في الضعيفة ٩/٧٤ (٤٠٧٦): «هذا إسناد ضعيف جِدًّا».|10:أخرجه ابن جرير ٥/٢٦١.</p><p>قال ابن جرير ٥/٢٦٠: «خبرٌ لو صَحَّ سندُه لم نَعدُهُ إلى غيره».|11:أخرجه الدارمي مختصرًا ٢/٥٥٨ (٣٤٦٣)، وابن أبي شيبة ٦/١٣٤ (٣٠٠٨٢)، وعبد بن حميد في مسنده ١/٩٨ (٢٠٠).</p><p>قال الهيثمي في المجمع ٢/٢٦٨ (٣٦١٤): «رواه الطبراني في الكبير، وفيه موسى بن عبيدة الربذي، والغالب عليه الضعف، وقد اختَلَفَ قولُ أحمدَ وابنِ معين فيه».|12:أخرجه ابن جرير ٥/٢٥٥.</p><p>قال ابن كثير في تفسيره ٢/٢١: «وروى ابن جرير عن الحسن البصري مرسلًا عنه، وموقوفًا عليه».|13:أخرجه ابن جرير ٥/٢٥٤-٢٥٥، وابن أبي حاتم ٢/٦٠٨، ٣/٩٠٦، والبيهقي في سُنَنِه ٧/٢٣٣. وعزاه السيوطي إلى عبد بن حميد.|14:أخرجه ابن جرير ٥/٢٥٥.|15:أخرجه ابن جرير ٥/٢٥٥، والبيهقي ٧/٢٣٣. وعزاه السيوطي إلى عبد بن حميد.|16:أخرجه ابن جرير ٥/٢٥٩، وابن أبي حاتم ٢/٦٠٩، ٣/٩٠٧.|17:المَسْك: الجلد. اللسان (مسك).|18:أخرجه ابن أبي حاتم ٢/٦٠٨-٦٠٩، ٣/٩٠٧، والبيهقي ٧/٢٣٣. وعزاه السيوطي إلى عبد بن حُمَيْد.|19:علَّقه ابن أبي حاتم ٢/٦٠٩.|20:أخرجه ابن جرير ٥/٢٥٦. وعلَّقه البيهقي ٧/٢٣٣.|21:مسائل نافع (٢٧٥). وعزاه السيوطي إلى الطستي.|22:تفسير البغوي ٢/١٥، وتفسير الثعلبي ٣/٢٤.|23:عزاه السيوطي إلى عبد بن حميد.|24:عزاه السيوطي إلى عبد بن حميد.|25:أخرجه ابن أبي حاتم ٢/٦٠٩.|26:علَّقه ابن أبي حاتم ٢/٦٠٩.|27:أخرجه عبد بن حميد كما في قطعة من تفسيره ص٢٣، وابن جرير ٥/٢٥٦.|28:أخرجه ابن أبي حاتم ٢/٦٠٩.|29:تفسير البغوي ٢/١٥، وتفسير الثعلبي ٣/٢٤.|30:أخرجه ابن جرير ٥/٢٥٩.|31:أخرجه ابن جرير ٥/٢٥٦، وابن أبي حاتم ٢/٦٠٩.|32:أخرجه ابن جرير ٥/٢٥٧. وعلَّقه ابن أبي حاتم ٢/٦٠٩.|33:أخرجه ابن جرير ٥/٢٥٧.|34:أخرجه عَبد بن حُمَيد كما في قطعة من تفسيره ص٢٤، ٨١.|35:عزاه السيوطي إلى عبد بن حميد.|36:أخرجه ابن أبي حاتم ٢/٦٠٩.|37:أخرجه ابن جرير ٥/٢٥٨. وعزاه السيوطي إلى عبد بن حميد.|38:أخرجه ابن جرير ٥/٢٥٨.|39:تفسير البغوي ٢/١٥، وتفسير الثعلبي ٣/٢٤.|40:أخرجه ابن جرير ٥/٢٥٥.|41:أخرجه ابن جرير ٥/٢٥٩.|42:تفسير مقاتل بن سليمان ١/٢٦٦.|43:أخرجه ابن جرير ٥/٢٦٠.|44:أخرجه ابن جرير ٥/٢٦٠، وابن المنذر ١/١٤٠.|45:أخرجه ابن جرير ٥/٢٦٠-٢٦١، وابن أبي حاتم ٢/٦٠٩.|46:أخرجه ابن أبي حاتم ٢/٦١٠.|47:أخرجه ابن جرير ٥/٢٦٢.|48:أخرجه ابن المنذر (٢٨٦).|49:أخرجه ابن جرير ٥/٢٦٤.|50:المطهّم من الناس والخيل: الحسن التام، كل شيء منه على تمامه، فهو بارع الجمال. لسان العرب (طهم).|51:أخرجه ابن أبي حاتم ٢/٦١٠.|52:أخرجه سفيان الثوري في تفسيره ص٧٥. وعزاه الحافظ ابن حجر في الفتح ٨/٢١٠ إلى تفسير سفيان بلفظ: الراعية.|53:أخرجه عبد الرزاق ١/١١٧، وعبد بن حميد كما في قطعة من تفسيره ص٢٤، وابن جرير ٥/٢٦١، وابن أبي حاتم ٢/٦١٠.|54:علّقه ابن أبي حاتم ٢/٦١٠.|55:أخرجه سفيان الثوري ص٣٤، وعبد الرزاق ١/١١٧، وابن جرير ٥/٢٦٣، وابن المنذر ١/١٤٠ من طريق ابن جريج، ولفظه: المطهّمة المشوبة حُسْنًا. وعزاه السيوطي إلى عبد بن حميد.|56:أخرجه ابن جرير ٥/٢٦٢.|57:أخرجه أبو جعفر الرملي في جزئه ص٧٢ (تفسير مسلم الزنجي). وفي ابن جرير ٥/٢٦٣ عنه: المطهّمة حُسْنًا.|58:علّقه ابن المنذر ١/١٤٢.|59:أخرجه ابن جرير ٥/٢٦٣-٢٦٤. وعزاه السيوطي إلى عبد بن حميد.|60:أخرجه ابن أبي حاتم ٢/٦١١.|61:أخرجه ابن جرير ٥/٢٦٢. وعلَّقه ابن المنذر ١/١٤١.|62:أخرجه ابن أبي حاتم ٢/٦١١.|63:أخرجه ابن جرير ٥/٢٦٤.|64:أخرجه عبد الرزاق ١/١١٧، وابن جرير ٥/٢٦٤، وابن المنذر ١/١٤١.|65:أخرجه ابن جرير ٥/٢٦٤. وعلَّقه ابن أبي حاتم ٢/٦١٠.|66:أخرجه ابن جرير ٥/٢٦٤.|67:أخرجه ابن جرير ٥/٢٦٢. وعلَّقه ابن المنذر ١/١٤١، وابن أبي حاتم ٢/٦١٠.|68:أخرجه ابن أبي حاتم ٢/٦١١.|69:أخرجه ابن جرير ٥/٢٦٢. وعلَّقه ابن أبي حاتم ٢/٦١٠.|70:تفسير مقاتل بن سليمان ١/٢٦٦.|71:أخرجه ابن جرير ٥/٢٦٥.|72:أخرجه ابن أبي حاتم ٢/٦١١.|73:تفسير مقاتل بن سليمان ١/٢٦٦.|74:أخرجه ابن جرير ٥/٢٦٧.|75:تفسير مقاتل بن سليمان ١/٢٦٦.|76:أخرجه أحمد ١٩/٣٠٥ (١٢٢٩٣)، ١٩/٣٠٧ (١٢٢٩٤)، ٢٠/٣٥١ (١٣٠٥٧)، ٢١/٤٣٣ (١٤٠٣٧)، والنسائي ٧/٦١ (٣٩٣٩-٣٩٤٠)، والحاكم ٢/١٧٤ (٢٦٧٦)، وابن أبي حاتم ٢/٦٠٧ (٣٢٥٢).</p><p>قال الحاكم: «هذا حديث صحيح، على شرط مسلم، ولم يخرجاه». وقال الذهبي في التلخيص: «على شرط مسلم». وقال ابن الملقن في البدر المنير ١/٥٠١: «إسناده صحيح». وقال ابن حجر في التلخيص الحبير ٣/٢٥٤: «إسناده حسن».|77:أخرجه مسلم ٢/١٠٩٠ (١٤٦٧).|78:أخرجه ابن أبي شيبة ١٢/٥٧٨، وعبد الله بن أحمد في زوائد الزهد ص١١٥، وابن أبي حاتم ٢/٦٠٧.|79:أخرجه ابن المنذر (٢٨٩)، وابن أبي حاتم ٢/٦١٢. وعزاه السيوطي إلى عبد بن حميد.
  3,15,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿قُلۡ أَؤُنَبِّئُكُم بِخَیۡرࣲ مِّن ذَ ٰ⁠لِكُمۡۖ لِلَّذِینَ ٱتَّقَوۡا۟ عِندَ رَبِّهِمۡ جَنَّـٰتࣱ تَجۡرِی مِن تَحۡتِهَا ٱلۡأَنۡهَـٰرُ خَـٰلِدِینَ فِیهَا وَأَزۡوَ ٰ⁠جࣱ مُّطَهَّرَةࣱ وَرِضۡوَ ٰ⁠نࣱ مِّنَ ٱللَّهِۗ وَٱللَّهُ بَصِیرُۢ بِٱلۡعِبَادِ ۝١٥﴾</span> - نزول الآية</h3></p><p><div></p><p><p><span class="item-no">١٢٢٤١<span class="dash">-</span></span> عن <span class="name-1">عمر بن الخطاب</span> -من طريق أبي بكر بن حفص بن عمر بن سعد- أنّه قال: لَمّا نزلت: <span class="qpc-hafs">﴿زين للناس حب الشهوات﴾</span> إلى آخر الآية؛ قال عمر: الآن، يا ربِّ، حين زينتَها لنا. فنزلت: <span class="qpc-hafs">﴿قل أؤنبئكم﴾</span> الآية كلها{1}. (٣/٤٧٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٢٤٢<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جَبْر</span> -من طريق ليث- قال: آية أُنزِلت في هذه الأُمَّة: <span class="qpc-hafs">﴿قل أؤنبئكم بخير من ذلكم﴾</span>، قال <span class="name-1">عمر بن الخطاب</span>: الآن، يا ربِّ{2}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿قُلۡ أَؤُنَبِّئُكُم بِخَیۡرࣲ مِّن ذَ ٰ⁠لِكُمۡۖ لِلَّذِینَ ٱتَّقَوۡا۟ عِندَ رَبِّهِمۡ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">١٢٢٤٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿قل﴾</span> للكفار: <span class="qpc-hafs">﴿أؤنبئكم بخير من ذلكم﴾</span>، يعني: ما ذكره في هذه الآية، <span class="qpc-hafs">﴿للذين اتقوا عند ربهم جنات﴾</span>{3}<span class=comment-ref>١١٣٧</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>١١٣٧</span> اختلف في موضع نهاية الاستفهام من قوله تعالى: <span class="qpc-hafs">﴿قُلْ أؤُنَبِّئُكُمْ بِخَيْرٍ مِن ذَلِكُمْ لِلَّذِينَ اتَّقَوْا عِنْدَ رَبِّهِمْ جَنّاتٌ﴾</span> على قولين: <b>الأول:</b> أن الكلام الذي أُمِر النبي ﷺ بقوله تمَّ في قوله تعالى: <span class="qpc-hafs">﴿عِنْدَ رَبِّهِمْ﴾</span>، و<span class="qpc-hafs">﴿جَنّاتٌ﴾</span> على هذا مرتفعٌ بالابتداء المضمر، تقديره: ذلك جناتٌ. <b>الثاني:</b> أن الكلام تمَّ في قوله: <span class="qpc-hafs">﴿مِن ذلِكُمْ﴾</span>، وأن قوله <span class="qpc-hafs">﴿لِلَّذِينَ﴾</span> خبر متقدم، و<span class="qpc-hafs">﴿جَنّاتٌ﴾</span> رفع بالابتداء.</p><p>و<span class="comment-type-3">رجَّح</span> <u>ابن جرير</u> (٥/٢٧٠) القول الثاني، فقال: «وأولى هذه الأقوال عندي بالصواب قول من جعل الاستفهام متناهيًا عند قوله: <span class="qpc-hafs">﴿بِخَيرٍ مِن ذَلِكُم﴾</span>، والخبر بعده مبتدأ عمَّن له الجنات بقوله: <span class="qpc-hafs">﴿للذِينَ اتَّقَوا عِنْدَ رَبِّهِم جَنّاتٌ﴾</span>، فيكون مخرجُ ذلك مخرجَ الخبر، وهو إبانةٌ عن معنى»الخير«الذي قال: أؤنبئكم به؟ فلا يكون بالكلام حينئذٍ حاجةٌ إلى ضمير».</p><p><span class="comment-type-4">وعلَّق</span> <u>ابن عطية</u> (٢/١٧٦) بقوله: «وعلى التأويل الأول يجوز في <span class="qpc-hafs">﴿جَنّات﴾</span> الخفض بدلًا من خير، ولا يجوز ذلك على التأويل الثاني، والتأويلان محتملان».</div></p><p><h3><span class="qpc-hafs">﴿جَنَّـٰتࣱ تَجۡرِی مِن تَحۡتِهَا ٱلۡأَنۡهَـٰرُ خَـٰلِدِینَ فِیهَا﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">١٢٢٤٤<span class="dash">-</span></span> عن أبي هريرة، قال رسول الله ﷺ: «<b>أنهارُ الجنةِ تَفَجَّرُ من تحت تلال -أو من تحت جبال- المِسْكِ</b>»{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٢٤٥<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن مسعود</span> -من طريق علقمة- قال: الجنة سَجْسَجٌ{5}، لا حرّ فيها ولا برد{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٢٤٦<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن مسعود</span> -من طريق مسروق- قال: أنهار الجنة تَفَجَّرُ من جبل مِسْكٍ{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٢٤٧<span class="dash">-</span></span> عن <span class="name-2">أبي مالك غَزْوان الغفاري</span> -من طريق السدي- قوله: <span class="qpc-hafs">﴿تجري من تحتها الأنهار﴾</span>، يعني: المساكن تجري أسفلَها أنهارٌ{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٢٤٨<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿جنات تجري من تحتها الأنهار﴾</span> وذلك أنّ العيون تجرى من تحت البساتين، <span class="qpc-hafs">﴿خالدين فيها﴾</span> لا يموتون{3}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَأَزۡوَ ٰ⁠جࣱ مُّطَهَّرَةࣱ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">١٢٢٤٩<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي بن أبي طلحة- <span class="qpc-hafs">﴿وأزواج مطهرة﴾</span>، قال: مُطَهَّرَةٌ من القَذَر والأذى{10}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٢٥٠<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿أزواج مطهرة﴾</span>، قال: مُطَهَّرَةٌ من الحيض، والغائط، والبول، والنُّخام، والبُزاق، والمني، والولد{10}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٢٥١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وأزواج مطهرة﴾</span> مِن الحيض، والغائط، والبول، والبُزاق، والمُخاط، ومِن القَذَرِ كُلِّه{12}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَرِضۡوَ ٰ⁠نࣱ مِّنَ ٱللَّهِۗ وَٱللَّهُ بَصِیرُۢ بِٱلۡعِبَادِ ۝١٥﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">١٢٢٥٢<span class="dash">-</span></span> عن أبي سعيد الخدري، قال رسول الله ﷺ: «<b>يقول الله ﷿: يا أهل الجنة. فيقولون: لبَّيْك ربَّنا وسَعْدَيْك. فيقول: هل رَضِيتُم؟. فيقولون: وما لنا لا نرضى وقد أعطيتَنا ما لم تُعْطِ أحدًا مِن خلقك؟! فيقول: ألا أُعْطِيكم أفضلَ من ذلك؟ قالوا: يا ربِّ، وأيُّ شيء أفضلُ من ذلك؟ قال: أُحِلُّ عليكم رضواني؛ فلا أسخط عليكم أبدًا</b>»{13}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٢٥٣<span class="dash">-</span></span> عن <span class="name-1">جابر بن عبد الله</span> -من طريق محمد بن المنكدر- قال: إذا دخل أهلُ الجنَّةِ الجنَّةَ قال اللهُ ﷿: أُعْطِيكم أفضلَ مِن هذا؟ فيقولون: أيْ ربَّنا، أيُّ شيءٍ أفضلُ مِن هذا؟ قال: رضواني{14}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٢٥٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ورضوان من الله﴾</span> أكبر، يعني: رِضا اللهِ عنهم، <span class="qpc-hafs">﴿والله بصير بالعباد﴾</span>، يعني: بأعمالهم{3}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ٥/٢٥٤، وابن أبي حاتم ٢/٦٠٦.|2:مصنف ابن أبي شيبة (ت: محمد عوامة) ١٩/٥٠٧ (٣٦٨٧٤).|3:تفسير مقاتل بن سليمان ١/٢٦٦.|4:أخرجه ابن حبان ١٦/٤٢٣ (٧٤٠٨)، وابن أبي حاتم ١/٦٥ (٢٥٢)، ٢/٦١٢ (٣٢٨٣)، ١٠/٣٤٢١ (١٩٢٦٧). وذكر الحديث العقيلي في الضعفاء ٢/٣٢٦ (٩١٧).</p><p>قال المنذري في الترغيب ٣/١٠٠ (٢٦٢): «رواه الطبراني في الأوسط، ورواته ثقات، إلا شيخه المقدام بن داود، وقد وُثِّق». وحسّن إسناده العراقيُّ في المغني عن حمل الأسفار ٤/٥٢٢.|5:أي: معتدل لا حر ولا قر. النهاية ٢/٣٤٣ (سج).|6:أخرجه ابن أبي حاتم ٢/٦١٢.|7:أخرجه ابن أبي حاتم ٢/٦١٢.|8:أخرجه ابن أبي حاتم ٢/٦١٢ (٦١٣).|9:تفسير مقاتل بن سليمان ١/٢٦٦.|10:أخرجه ابن أبي حاتم ٢/٦١٣.|11:أخرجه ابن أبي حاتم ٢/٦١٣.|12:تفسير مقاتل بن سليمان ١/٢٦٦.</p><p><b>وقد تقدم تفصيل أكثر لألفاظ الآية عند قوله تعالى: <span class="qpc-hafs">﴿وبَشِّرِ الَّذِينَ آمَنُوا وعَمِلُوا الصّالِحاتِ أنَّ لَهُمْ جَنّاتٍ تَجْرِي مِن تَحْتِها الأَنْهارُ كُلَّما رُزِقُوا مِنها مِن ثَمَرَةٍ رِزْقًا قالُوا هَذا الَّذِي رُزِقْنا مِن قَبْلُ وأُتُوا بِهِ مُتَشابِهًا ولَهُمْ فِيها أزْواجٌ مُطَهَّرَةٌ وهُمْ فِيها خالِدُونَ (٢٥)﴾</span> [البقرة:٢٥].</b>|13:أخرجه البخاري ٨/١١٤ (٦٥٤٩)، ٩/١٥١ (٧٥١٨)، ومسلم ٤/٢١٧٦ (٢٨٢٩)، وابن جرير ١١/٥٦٤، وابن أبي حاتم ٢/٦١٣ (٣٢٨٨).|14:أخرجه ابن جرير ٥/٢٧١، وابن أبي حاتم ٢/٦١٣، والحاكم ١/٥٦.|15:تفسير مقاتل بن سليمان ١/٢٦٦.