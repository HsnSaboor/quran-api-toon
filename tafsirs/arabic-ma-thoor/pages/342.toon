quran[17]{c,v,t}:
23,1," مقدمة السورة ٥١٢٩٤- عن عبد الله بن عباس -من طريق مجاهد-: مكية{1}. (١٠/٥٥٣) ٥١٢٩٥- عن عبد الله بن عباس، قال: نزلت بمكة سورة المؤمنين{2}. (١٠/٥٥٣) ٥١٢٩٦- عن عبد الله بن عباس -من طريق عطاء الخراساني-: مكية، ونزلت بعد الأنبياء{3}. (ز) ٥١٢٩٧- عن علي بن الحسين -من طريق الحسين بن واقد- قال: آخر سورة نزلت على رسول الله ﷺ بمكة: المؤمنون. ويُقال: العنكبوت{4}. (ز) ٥١٢٩٨- عن عكرمة مولى ابن عباس= (ز) ٥١٢٩٩- والحسن البصري -من طريق يزيد النحوي-: مكية{5}. (ز) ٥١٣٠٠- عن قتادة بن دعامة -من طرق-: مكية{6}. (ز) ٥١٣٠١- عن محمد ابن شهاب الزهري: مكية، ونزلت بعد الأنبياء{7}. (ز) ٥١٣٠٢- عن علي بن أبي طلحة: مكية{8}. (ز) ٥١٣٠٣- قال مقاتل بن سليمان: مكية كلها، وهي مائة وثماني عشرة آية كوفية{9}. (ز) ٥١٣٠٤- قال يحيى بن سلّام: مكية كلها{10}. (ز) ٥١٣٠٥- عن عبد الله بن السائب، قال: صلّى النبيُّ ﷺ الصبح بمكة، فاستفتح سورة المؤمنين، حتى إذا جاء ذكر موسى وهارون -أو ذكر عيسى{11}- أخذت النبي ﷺ سَعْلَةٌ{12} فركع{13}. (١٠/٥٥٣) <q>﴿قَدۡ أَفۡلَحَ ٱلۡمُؤۡمِنُونَ ۝١﴾</q> - قراءات ٥١٣٠٦- عن طلحة بن مُصَرِّف أنه كان يقرأ (قَدْ أفْلَحُ المُؤْمِنُونَ) برفع أفلح{14}٤٥١٩. (١٠/٥٥٥) ٤٥١٩ انتقد ابن عطية (٦/٢٧٨) هذا القراءة بقوله: «وهي قراءة مردودة». ٥١٣٠٧- عن عيسى بن عمر، قال: سمعت طلحة بن مُصَرِّف يقرأ: (قَدْ أفْلَحُواْ المُؤْمِنُونَ) فقلت له: أتلحن؟ قال: نعم كما يلحن أصحابي{15}. (ز) ٥١٣٠٨- عن عاصم بن أبي النجود أنّه قرأ بنصب: <q>﴿أفْلَحَ﴾</q>{16}. (١٠/٥٥٦) <q>﴿قَدۡ أَفۡلَحَ ٱلۡمُؤۡمِنُونَ ۝١﴾</q> - تفسير الآية ٥١٣٠٩- عن عبد الله بن عباس: أنّ نافع بن الأزرق سأله عن قوله: <q>﴿قد أفلح المؤمنون﴾</q>. قال: فازوا وسعِدوا. قال: وهل تعرف العرب ذلك؟ قال: نعم، أما سمعت قول لبيد: فاعقلي إن كنت ما تعقلي ولقد أفلح من كان عَقِل؟{17}. (١٠/٥٥٦) ٥١٣١٠- قال عبد الله بن عباس: قد سعد المُصَدِّقون بالتوحيد، وبَقُوا في الجنة{18}. (ز) ٥١٣١١- عن سعيد بن جبير، في قوله: <q>﴿قد أفلح المؤمنون﴾</q>: يعني: سعِد المُصَدِّقون بتوحيد الله{19}. (١٠/٥٥٥) ٥١٣١٢- قال مقاتل بن سليمان: <q>﴿قد أفلح المؤمنون﴾</q>، يعني: سعِد المؤمنون، يعني: المُصَدِّقين بتوحيد الله ﷿{20}. (ز) ٥١٣١٣- قال يحيى بن سلّام: قوله: <q>﴿قد أفلح المؤمنون﴾</q> قد سعد المؤمنون، والسعداء أهل الجنة{10}. (ز) <q>﴿قَدۡ أَفۡلَحَ ٱلۡمُؤۡمِنُونَ ۝١﴾</q> - آثار متعلقة بالآية ٥١٣١٤- عن عمر بن الخطاب، قال: كان إذا أُنزِل على رسول الله ﷺ الوحي يُسمَع عند وجهه كدويِّ النحل، فأنزل عليه يومًا، فمكثنا ساعة، فسُرِّي عنه، فاستقبل القبلة، فرفع يديه، فقال: «اللهم، زِدْنا ولا تنقصنا، وأكرِمْنا ولا تُهِنّا، وأعْطِنا ولا تحرمنا، وآثِرْنا ولا تُؤْثِر علينا، وارضَ عنا وأَرْضِنا». ثم قال: «لقد أُنزِلَت عَلَيَّ عشر آيات، مَن أقامهنَّ دخل الجنة». ثم قرأ: <q>﴿قد أفلح المؤمنون﴾</q> حتى ختم العشر{22}. (١٠/٥٥٤) ٥١٣١٥- عن يزيد بن بابَنُوس، قال: قلنا لعائشة: كيف كان خُلُق رسول الله ﷺ؟ قالت: كان خُلُقه القرآن. ثم قالت: تقرأ سورة المؤمنين؟ اقرأ: <q>﴿قد أفلح المؤمنون﴾</q>. فقرأ حتى بلغ العشر، فقالت: هكذا كان خلق رسول الله ﷺ{23}. (١٠/٥٥٤) ٥١٣١٦- عن أنس، قال: قال رسول الله ﷺ: «خلق الله جنة عدن، وغرس أشجارها بيده، وقال لها: تكلَّمي. فقالت: قد أفلح المؤمنون»{24}. (١٠/٥٥٤) ٥١٣١٧- عن ابن عباس، مثله{25}. (١٠/٥٥٣) ٥١٣١٨- عن قتادة -من طريق معمر- في قوله: <q>﴿قد أفلح المؤمنون﴾</q>، قال: قال كعب [الأحبار]: لم يخلق الله بيده إلا ثلاثة؛ خلق آدم بيده، وكتب التوراة بيده، وغرس جنة عدن بيده، ثم قال: تكلمي. فقالت: قد أفلح المؤمنون. لِما عَلِمَت فيها مِن الكرامة{26}. (١٠/٥٥٥) ٥١٣١٩- عن أبي العالية الرِّياحِيِّ -من طريق أبي خلدة- قال: لَمّا خلق اللهُ الجنةَ قال: قد أفلح المؤمنون. فأنزل الله به قرآنًا{27}. (١٠/٥٥٥) ٥١٣٢٠- عن مجاهد بن جبر -من طريق عبد العزيز بن رُفيع- قال: لَمّا غرس الله الجنة نظر إليها، فقال: قد أفلح المؤمنون{27}. (١٠/٥٥٥) ٥١٣٢١- عن ميسرة -من طريق عطاء- قال: لم يخلق الله شيئًا بيده غير أربعة أشياء: خلق آدم بيده، وكتب الألواح بيده، والتوراة بيده، وغرس عدنًا بيده، ثم قال: قد أفلح المؤمنون{27}. (ز) ٥١٣٢٢- عن المعلى بن هلال، قال: إنّ الله خلق الجنة بيده، فجعل لَبِنَة ذهب، ولَبِنَة فضة، ومِلاطُها المِسْك، ثم جعل فيها ما جعل، ثم نظر فيها، فقال: <q>﴿قد أفلح المؤمنون﴾</q>، ثم أغلق بابها، فليس يَعْلَمُ ما فيها ملكٌ مُقَرَّب، ولا نبيٌّ مُرسَل. قال: فالذي يوجد مِن بَرْد السَّحَرْ وطيبه فهو ما يخرج مِن خُلَل الباب{30}. (ز) ",footnotes:1:أخرجه أبو جعفر النحاس في الناسخ والمنسوخ ٢/٥٣٥ من طريق أبي عمرو بن العلاء عن مجاهد، والبيهقي في دلائل النبوة ٧/١٤٣-١٤٤ من طريق خصيف عن مجاهد.عزاه السيوطي إلى ابن مردويه.أخرجه ابن الضريس في فضائل القرآن ١/٣٣-٣٥.أخرجه الواحدي في أسباب النُّزول ١/١٠٦.أخرجه البيهقي في دلائل النبوة ٧/١٤٢-١٤٣.أخرجه الحارث المحاسبي في فهم القرآن ص٣٩٥-٣٩٦ من طريق سعيد، وأبو بكر بن الأنباري -كما في الإتقان في علوم القرآن ١/٥٧- من طريق همام.تنزيل القرآن ص٣٧-٤٢.أخرجه أبو عبيد في فضائله (ت: الخياطي) ٢/٢٠٠.تفسير مقاتل بن سليمان ٣/١٥١.تفسير يحيى بن سلام ١/٣٩٢.الشك من محمد بن عباد بن جعفر أحد رواة الحديث.السعلة: المرة من السعال، والمراد: أنه أخذته سعلة فعيي بالقراءة. ينظر: غريب الحديث للخطابي ١/١٦١.أخرجه مسلم ١/ ٣٣٦ (٤٥٥).عزاه السيوطي إلى عبد بن حميد. والقراءة شاذة، قيل: اجتزأ بالضمة عن الواو، وأصلها «أفلحوا المؤمنون»على لغة «أكلوني البراغيث»، ويروى عن طلحة أيضًا (قَدْ أفْلَحُواْ) بإلحاق واو. وورد عند أبي حيان (قَدْ أُفْلِحَ) مبنيًا للمفعول. وقراءة العشرة <q>﴿قَدْ أفْلَحَ﴾</q> بفتح الحاء. انظر: مختصر ابن خالويه ص٩٩، والكشاف للزمخشري ٢/٣٥٦، والبحر المحيط ٦/٣٩٥.أخرجه ابن الأنباري في الوقف والابتداء ٢/٧٨٩ (١٦٤).عزاه السيوطي إلى عبد بن حميد.أخرجه الطستي -كما في الإتقان ٢/٧٣-. وعزاه السيوطي إلى الطستي في مسائله.تفسير البغوي ٥/٤٠٨.عزاه السيوطي إلى ابن أبي حاتم.تفسير مقاتل بن سليمان ٣/١٥٢.تفسير يحيى بن سلام ١/٣٩٢.أخرجه أحمد ١/٣٥٠-٣٥١ (٢٢٣)، والترمذي ٥/٣٩١-٣٩٢ (٣٤٤٦، ٣٤٤٧)، والحاكم ١/٧١٧ (١٩٦١)، ٢/٤٢٥ (٣٤٧٩)، والثعلبي ٧/٤١. فيه يونس بن سليم؛ قال الترمذي بعد الحديث الثاني: «وهذا أصح من الحديث الأول». ثم قال: «سمعت إسحاق بن منصور يقول: روى أحمد بن حنبل، وعلي بن المديني، وإسحاق بن إبراهيم، عن عبد الرزاق، عن يونس بن سليم، عن يونس بن يزيد، عن الزهري هذا الحديث، ومن سمع من عبد الرزاق قديمًا فإنهم إنما يذكرون فيه: عن يونس بن يزيد، وبعضهم لا يذكر فيه: عن يونس بن يزيد، ومن ذكر فيه يونس بن يزيد فهو أصح، وكان عبد الرزاق ربما ذكر في هذا الحديث: يونس بن يزيد، وربما لم يذكره، وإذا لم يذكر فيه يونس، فهو مرسل». وقال الحاكم: «هذا حديث صحيح الإسناد، ولم يخرجاه». وقال الذهبي في التلخيص: «سُئِل عبدالرزاق عن شيخه ذا -يونس بن سليم-. فقال: لا أظنه شيء». وقال العقيلي في الضعفاء ٤/٤٦٠ (٢٠٩٢): «يونس بن سليم الصنعاني لا يتابع على حديثه، ولا يعرف إلا به». وقال ابن أبي حاتم ٤/٦٨٧-٦٨٨ (١٧٣٦): «قال أبي: روى عبد الرزاق هذا الحديث مرة أخرى، فقال: عن يونس بن سليم، عن يونس بن يزيد، ويونس بن سليم لا أعرفه، ولا يعرف هذا الحديث من حديث الزهري». وقال البغوي في شرح السنة ٥/١٧٧(١٣٧٦): «هذا حديث حسن». وقال ابن كثير في تفسيره ٥/٣٥٩: «قال الترمذي: منكر، لا نعرف أحدًا رواه غير يونس بن سليم، ويونس لا نعرفه». وقال الألباني في الضعيفة ٣/٣٩٤ (١٢٤٢): «منكر».أخرجه الحاكم ٢/٤٢٦ (٣٤٨١). قال الحاكم: «هذا حديث صحيح الإسناد، ولم يخرجاه».أخرجه الحاكم ٢/٤٢٦ (٣٤٨٠). قال الحاكم: «هذا حديث صحيح الإسناد، ولم يخرجاه». وقال الذهبي في التلخيص: «بل ضعيف». وقال ابن القيسراني في ذخيرة الحفاظ ٣/١٢٩٣ (٢٧٨٦): «رواه علي بن عاصم عن حميد الطويل، عن أنس. وعلي هذا متروك الحديث». وقال الألباني في الضعيفة ٣/٤٤٣ (١٢٨٣): «ضعيف».أخرجه الطبراني في الكبير ١١/١٨٤ (١١٤٣٩)، وأبو نعيم في صفة الجنة ١/٤١ (١٦)، ومقاتل في تفسيره ٣/٥٤، والثعلبي ٧/٣٧-٣٨. في سنده بقية، قال الطبراني في الأوسط ١/٢٢٤ (٧٣٨): «لم يرو هذين الحديثين عن ابن جريج إلا بقية، تَفَرَّد بهما هشام بن خالد». وأورده ابن عدي في الكامل ٦/٣٢٩، وقال المنذري في الترغيب ٣/٢٥٨ (٣٩٤٢): «رواه الطبراني في الكبير والأوسط بإسنادين أحدهما جيد». وقال الذهبي في ميزان الاعتدال: «هذا باطل». وقال ابن كثير في تفسيره ٥/٤٦٠: «بقية عن الحجازيين ضعيف». وقال الهيثمي في المجمع ١٠/٣٩٦-٣٩٧ (١٨٦٣٨، ١٨٦٣٩): «رواه الطبراني في الأوسط والكبير، وأحد إسنادي الطبراني في الأوسط جيد». وقال المناوي في التيسير ٢/٣٠٢ عن رواية الطبراني: «بإسنادين أحدهما جيد». وقال الألباني في الضعيفة ٣/٤٤٤: «إسناد ضعيف من أجل عنعنة بقية».أخرجه عبد الرزاق ٢/٤٣، ويحيى بن سلام ١/٣٩٢ من طريق سعيد، وابن جرير ١٧/٥.أخرجه ابن جرير ١٧/٦.أخرجه ابن جرير ١٧/٦.أخرجه ابن جرير ١٧/٦.علَّقه يحيى بن سلام ١/٣٩٢.
23,2," <q>﴿ٱلَّذِینَ هُمۡ فِی صَلَاتِهِمۡ خَـٰشِعُونَ ۝٢﴾</q> - نزول الآية ٥١٣٢٣- عن أبي هريرة -من طريق محمد بن سيرين-: أنّ النبي ﷺ كان إذا صلّى رفع بصره إلى السماء؛ فنزلت: <q>﴿الذين هم في صلاتهم خاشعون﴾</q>. فطأطأ رأسه{1}. (١٠/٥٥٧) ٥١٣٢٤- عن محمد بن سيرين، قال: نُبِّئتُ: أنّ رسول الله ﷺ كان إذا صلى يرفع بصره إلى السماء؛ فنزلت: <q>﴿الذين هم في صلاتهم خاشعون﴾</q>{2}. (١٠/٥٥٦) ٥١٣٢٥- عن محمد بن سيرين، قال: كان النبيُّ ﷺ يرفع بصره إلى السماء، فأمره بالخشوع، فرمى ببصره نحو مسجده{3}. (١٠/٥٥٦) ٥١٣٢٦- عن محمد بن سيرين، قال: كان النبي ﷺ إذا قام في الصلاة نظر هكذا وهكذا؛ يمينًا وشمالًا؛ فنزلت: <q>﴿الذين هم في صلاتهم خاشعون﴾</q>. فحَنى رأسه{4}. (١٠/٥٥٦) ٥١٣٢٧- عن محمد بن سيرين، قال: كان رسول الله ﷺ مما ينظر إلى الشيء في الصلاة، فيرفع بصره، حتى نزلت آية -إن لم تكن هذه فلا أدري ما هي-: <q>﴿الذين هم في صلاتهم خاشعون﴾</q>. فوضع رأسه{5}. (١٠/٥٥٧) ٥١٣٢٨- عن محمد بن سيرين -من طريق الحجاج الصواف- قال: كان أصحاب رسول الله ﷺ يرفعون أبصارهم إلى السماء في الصلاة، ويلتفتون يمينًا وشمالًا؛ فأنزل الله: <q>﴿قد أفلح المؤمنون الذين هم في صلاتهم خاشعون﴾</q>. فقالوا برؤوسهم، فلم يرفعوا أبصارهم بعد ذلك في الصلاة، ولم يلتفتوا يمينًا ولا شمالًا{6}. (١٠/٥٥٧) ٥١٣٢٩- عن محمد بن سيرين -من طريق هشام بن حسان- قال: كانوا يلتفتون في صلاتهم حتى نزلت هذه الآية، فغضوا أبصارهم، فكان أحدهم ينظر إلى موضع سجوده{7}. (ز) ٥١٣٣٠- عن ابن عون، قال: كان النبي ﷺ إذا صلّى قال برأسه كذا وكذا، يمينًا وشمالًا، حتى نزلت: <q>﴿قد أفلح المؤمنون* الذين هم في صلاتهم خالدون﴾</q>. فقال هكذا؛ نكس رأسه{8}. (ز) <q>﴿ٱلَّذِینَ هُمۡ فِی صَلَاتِهِمۡ خَـٰشِعُونَ ۝٢﴾</q> - تفسير الآية ٥١٣٣١- عن علي [بن أبي طالب] -من طريق أبي سنان، عن رجل من قومه- أنه سُئِل عن قوله: <q>﴿الذين هم في صلاتهم خاشعون﴾</q>. قال: الخشوع في القلب، وأن تُلين كنفك للمرء المسلم، وألا تلتفت في صلاتك{9}. (١٠/٥٥٨) ٥١٣٣٢- عن عبد الله بن عباس -من طريق علي- في قوله: <q>﴿الذين هم في صلاتهم خاشعون﴾</q>، قال: خائفون ساكنون{10}. (١٠/٥٥٨) ٥١٣٣٣- عن عبد الله بن عمر، في قوله: <q>﴿الذين هم في صلاتهم خاشعون﴾</q>، قال: كانوا إذا قاموا في الصلاة أقبلوا على صلاتهم، وخفضوا أبصارهم إلى موضع سجودهم، وعلموا أنّ الله يُقْبِل عليهم، فلا يلتفتون يمينًا ولا شمالًا{11}. (١٠/٥٥٨) ٥١٣٣٤- عن سعيد بن جبير: يعني متواضعين، لا يعرف مَن على يمينه ولا مَن على يساره، ولا يلتفت مِن الخشوع لله ﷿{12}. (ز) ٥١٣٣٥- عن إبراهيم النخعي -من طريق مغيرة- <q>﴿الذين هم في صلاتهم خاشعون﴾</q>، قال: الخشوع في القلب. وقال: ساكنون{13}. (١٠/٥٥٩) ٥١٣٣٦- عن أبي قلابة، قال: سألتُ مسلمَ بن يسار عن الخشوع في الصلاة. فقال: تضع بصرك حيث تسجد{14}. (١٠/٥٦٠) ٥١٣٣٧- عن مجاهد بن جبر -من طريق منصور- في الآية، قال: الخشوع في الصلاة: السكون فيها{15}. (١٠/٥٥٩) ٥١٣٣٨- عن مجاهد بن جبر -من طريق ليث- قال: الخشوع: غضُّ البصر، وخَفْض الجناح{16}. (ز) ٥١٣٣٩- عن الحسن البصري -من طريق عمرو [بن عبيد]- قوله: <q>﴿الذين هم في صلاتهم خاشعون﴾</q>، قال: الخشوع: الخوف الثابت في القلب{16}. (ز) ٥١٣٤٠- عن الحسن البصري -من طريق أبي شَوْذَب- في قوله: <q>﴿الذين هم في صلاتهم خاشعون﴾</q>، قال: كان خشوعهم في قلوبهم، فغضوا بذلك أبصارهم، وخفضوا لذلك الجناح{18}. (١٠/٥٥٩) ٥١٣٤١- عن معمر، في قوله: <q>﴿الذين هم في صلاتهم خاشعون﴾</q>، قال الحسن: خائفون.= (ز) ٥١٣٤٢- وقال قتادة: الخشوع في القلب{19}. (ز) ٥١٣٤٣- عن ابن جريج، قال: قال عطاء بن أبي رباح في قوله: <q>﴿الذين هم في صلاتهم خاشعون﴾</q>، قال: التَّخَشُّع في الصلاة.= (ز) ٥١٣٤٤- وقال لي غير عطاء: كان النبيُّ ﷺ إذا قام في الصلاة نظر عن يمينه ويساره ووجاهه، حتى نزلت: <q>﴿قد أفلح المؤمنون الذين هم في صلاتهم خاشعون﴾</q>. فما رُئِي بعد ذلك ينظر إلا إلى الأرض{20}. (ز) ٥١٣٤٥- عن قتادة بن دعامة -من طريق معمر- قال: الخشوع في القلب، وهو الخوفُ وغضُّ البصر في الصلاة{21}. (١٠/٥٥٩) ٥١٣٤٦- قال قتادة بن دعامة -من طريق خُلَيد بن دَعْلج-: هو وضع اليمين على الشمال في الصلاة{22}. (ز) ٥١٣٤٧- عن محمد ابن شهاب الزهري -من طريق مَعْمَر- <q>﴿الذين هم في صلاتهم خاشعون﴾</q>، قال: هو سكون المرء في صلاته{23}. (١٠/٥٥٩) ٥١٣٤٨- عن عطاء الخراساني -من طريق يونس بن يزيد- في قول الله ﷿: <q>﴿في صلاتهم خاشعون﴾</q>، قال: الخشوع: خشوع القلب والطَّرْف{24}. (ز) ٥١٣٤٩- قال مقاتل بن سليمان: ثم نعتهم، فقال سبحانه: <q>﴿الذين هم في صلاتهم خاشعون﴾</q>، يقول: متواضعون، يعني: إذا صلّى لم يعرف مَن عن يمينه، ومَن عن شماله{25}. (ز) ٥١٣٥٠- عن الثوري، عن أبي سنان الشيباني، عن رجل، أنه سُئِل عن قوله: <q>﴿الذين هم في صلاتهم خاشعون﴾</q>، قال: لا تلتفت في صلاتك، وأن تُلِين كتفك للرجل المسلم{26}٤٥٢٠. (ز) ٤٥٢٠ اختُلِف في الذي عُنِي به في هذا الموضع من الخشوع؛ فقال بعضهم: عني به: سكون الأطراف في الصلاة. وقال آخرون: الخوف. ورجَّح ابنُ جرير (١٧/١٠) صوابَ كلا القولين للعموم، فقال -بعد أن ذكر أن الخشوع: التذلل والخضوع-: «وإذ كان ذلك كذلك، ولم يكن الله -تعالى ذكره- دلَّ على أن مراده مِن ذلك معنًى دون معنًى في عقل ولا خبر؛ كان معلومًا أن معنى مراده من ذلك العموم. وإذ كان ذلك كذلك فتأويل الكلام ما وصفتُ مِن قبلُ مِن أنّه: والذين هم في صلاتهم متذللون لله بأداء ما ألزمهم مِن فرضه وعبادته، وإذا تذلل لله فيها العبد رُئيت ذلة خضوعه في سكون أطرافه، وشغله بفرضه، وتركه ما أمر بتركه فيها». وعلَّق ابنُ تيمية (٤/٤٥٤) بقوله: «الخشوع يتضمن السكينة والتواضع جميعًا». <q>﴿ٱلَّذِینَ هُمۡ فِی صَلَاتِهِمۡ خَـٰشِعُونَ ۝٢﴾</q> - آثار متعلقة بالآية ٥١٣٥١- عن أبي بكر الصديق، قال: قال رسول الله ﷺ: «تَعَوَّذوا بالله مِن خشوع النفاق». قالوا: يا رسول الله، وما خشوع النفاق؟ قال: «خشوع البدن، ونفاق القلب»{27}. (١٠/٥٥٨) ٥١٣٥٢- عن أم رومان والدة عائشة، قالت: رآني أبو بكر الصديق ﵁ أتَمَيَّل في صلاتي، فزَجَرَني زَجْرَة كدت أنصرف مِن صلاتي، قال: سمعتُ رسول الله ﷺ يقول: «إذا قام أحدكم في الصلاة فليُسْكِنْ أطرافه، لا يتميَّل تَمَيُّل اليهود؛ فإنّ سكون الأطراف في الصلاة من تمام الصلاة»{28}. (١٠/٥٦٠) ٥١٣٥٣- عن أبي هريرة، عن رسول الله ﷺ أنّه رأى رجلًا يعبث بلحيته في صلاته، فقال: «لو خشع قلب هذا خشعت جوارحه»{29}. (١٠/٥٦٠) ٥١٣٥٤- عن أبي هريرة أنّه قال في مرضه: أقْعِدوني، أقْعِدوني؛ فإنّ عندي وديعة أوْدَعَنِيها رسولُ الله ﷺ، قال: «لا يلتفت أحدكم في صلاته، فإن كان لا بد فاعلًا ففي غير ما افترض الله عليه»{30}. (١٠/٥٦١) ٥١٣٥٥- عن عائشة، قالت: سألتُ رسول الله ﷺ عن الالتفات في الصلاة. فقال: «هو اختلاسٌ يختلسه الشيطان مِن صلاة العبد»{31}. (١٠/٥٦٠) ٥١٣٥٦- عن أبي اليَسَر، أنّ رسول الله ﷺ قال: «منكم مَن يصلي الصلاة كاملة، ومنكم مَن يصلي النصف، والثلث، والربع» حتى بلغ العُشر{32}. (١٠/٥٦٤) ٥١٣٥٧- عن جابر بن سمرة، قال: قال رسول الله ﷺ: «لَيَنْتَهِيَنَّ قومٌ يرفعون أبصارهم إلى السماء في الصلاة، أو لا ترجع إليهم»{33}. (١٠/٥٦٤) ٥١٣٥٨- عن أنس بن مالك، أنّ النبي ﷺ قال: «ما بال أقوام يرفعون أبصارهم إلى السماء في صلاتهم؟!». فاشتدَّ في ذلك حتى قال: «لينتهُنَّ عن ذلك، أو لتخطفن أبصارهم»{34}. (١٠/٥٦٤) ٥١٣٥٩- عن أبي الدرداء، قال: استعيذوا بالله من خشوع النفاق. قيل له: وما خشوع النفاق؟ قال: أن ترى الجسد خاشعًا، والقلب ليس بخاشع{35}. (١٠/٥٥٨) ٥١٣٦٠- عن أبي الدرداء -من طريق جعفر بن كثير السهمي- قال: إيّاكم والالتفاتَ في الصلاة؛ فإنّه لا صلاة للمُتَلَفِّت، وإن غُلِبْتُم على تَطَوُّعٍ فلا تُغلَبوا على المكتوبة{36}. (١٠/٥٦١) ٥١٣٦١- عن عبد الله بن مسعود، قال: إنّ الله لا يزال مُقْبِلًا على العبد ما دام في صلاته ما لم يُحدِث، أو يلتفت{37}. (١٠/٥٦١) ٥١٣٦٢- عن أبي عبيدة: أنّ عبد الله بن مسعود كان إذا قام في الصلاة خفض فيها بصره، ويديه، وصوته{38}. (ز) ٥١٣٦٣- عن عبد الله بن مسعود، قال: لَيَنتَهِيَنَّ أقوامٌ يرفعون أبصارهم إلى السماء في الصلاة، أو لا ترجع إليهم{39}. (١٠/٥٦٤) ٥١٣٦٤- عن حذيفة بن اليمان، قال: أما يخشى أحدكم اذا رفع بصره إلى السماء أن لا يرجع إليه بصره؟! يعني: وهو في الصلاة{40}. (١٠/٥٦٥) ٥١٣٦٥- عن مجاهد، عن عبد الله بن الزبير أنّه كان يقوم للصلاة كأنه عُود= (ز) ٥١٣٦٦- وكان أبو بكر يفعل ذلك= (ز) ٥١٣٦٧- وقال مجاهد بن جبر: هو الخشوع في الصلاة{41}. (١٠/٥٦٠) ٥١٣٦٨- عن عطاء، قال: سمعت أبا هريرة يقول: إذا صليتَ فإنّ ربَّك أمامك، وأنت مناجيه؛ فلا تلتفت.= (ز) ٥١٣٦٩- قال عطاء: وبلغني أنّ الربَّ يقول: يا ابن آدم، إلى مَن تلتفت؟! أنا خيرٌ لك مِمَّن تلتفت إليه{42}. (١٠/٥٦١) ٥١٣٧٠- عن كعب [الأحبار]، قال: إذا قام الرجل في الصلاة أقبل الله عليه بوجهه ما لم يلتفت{36}. (١٠/٥٦٢) ٥١٣٧١- قال مجاهد بن جبر: كان أهل العلم يكرهون إذا قام الرجل في صلاته أن يعبث بشيء من يديه، أو يلتفت، أو يهتم بشيء من أمر الدنيا{44}. (ز) ٥١٣٧٢- عن ابن جريج، قال: قلتُ لعطاء [بن أبي رباح]: أقبض بكَفِّي اليمنى على عضدي اليسرى، وكفي اليسرى على عَضُدي اليمنى؟ فكرهه، وقال: إنّما الصلاة خشوع، قال الله: <q>﴿الذين هم في صلاتهم خاشعون﴾</q>، فقد عرفتم الركوع والسجود والتكبير، ولا يَعْرِف كثيرٌ مِن الناس الخشوعَ{45}. (ز) ",footnotes:1:أخرجه الحاكم ٢/٤٢٦ (٣٤٨٣). قال الحاكم: «هذا حديث صحيح، على شرط الشيخين، لولا خلاف فيه على محمد، فقد قيل عنه مرسلًا، ولم يخرجاه». وقال الذهبي في التلخيص: «الصحيح مرسل». وقال البيهقي في الكبرى ٢/٤٠٢ (٣٥٤٢): «ورواه حماد بن زيد عن أيوب مرسلًا، وهذا هو المحفوظ». وقال الألباني في الإرواء عقب كلام الذهبي ٢/٧٣: «تبين لي أخيرًا أنّ هذا القول هو الصواب».أخرجه ابن جرير ١٧/٧، والبيهقي في سننه ٢/٢٨٣ مرسلًا.أخرجه عبد الرزاق (٣٢٦١) مرسلًا.أخرجه أبو داود في مراسيله ص٨٩، والبيهقي في سننه ٢/٢٨٣. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.أخرجه عبد الرزاق (٣٢٦٢)، وابن أبي شيبة ٢/٢٤٠، وابن جرير١٧/٧ مرسلًا، وزاد ابن جرير في آخره: وقال محمد: وكانوا يقولون: لا يجاوز بصره مصلاه، فإن كان قد استعاد النظر فليغمض. وقد ذكره ابن كثير في تفسيره ٥/٤٦١ بلفظ: «اعتاد» بدل «استعاد».أخرجه ابن جرير ١٧/٧ مرسلًا. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.أخرجه يحيى بن سلام ١/٣٩٣، وإسحاق البستي في تفسيره ص٣٨٣.أخرجه إسحاق البستي في تفسيره ص٣٨٤ مرسلًا.أخرجه ابن المبارك في الزهد (١١٤٨)، وعبد الرزاق ٢/٤٣، وابن جرير ١٧/٩، والحاكم ٢/٣٩٣، والبيهقي في سننه ٢/٢٧٩. وعزاه السيوطي إلى الفريابي، وعبد بن حميد، وابن المنذر، وابن أبي حاتم.أخرجه ابن جرير ١٧/١٠، وابن أبي حاتم -كما في الإتقان ٢/٣١-. وعزاه السيوطي إلى ابن المنذر.عزاه السيوطي إلى ابن مردويه.تفسير الثعلبي ٧/٤٠، وتفسير البغوي ٥/٤٠٨ دون قوله: متواضعين.أخرجه ابن أبي شيبة ١٣/٥٥٣، وابن جرير ١٧/٩. وعزاه السيوطي إلى عبد بن حميد.أخرجه ابن سعد ٧/١٨٦.أخرجه ابن المبارك في الزهد (١٦٩، ١١٤٩)، وعبد الرزاق (٣٢٦٢)، وابن جرير ١٧/٨. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه يحيى بن سلام ١/٣٩٢.أخرجه يحيى بن سلام ١/٣٩٢.أخرجه ابن جرير ١٧/٨-٩. وعزاه السيوطي إلى ابن أبي حاتم.أخرجه يحيى بن سلام ١/٣٩٣ عن الحسن، وابن جرير ١٧/١٠.أخرجه ابن جرير ١٧/٩.أخرجه ابن جرير ١٧/١٠. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.تفسير الثعلبي ٧/٣٩.أخرجه ابن جرير ١٧/٨. وعزاه السيوطي إلى عبد الرزاق، وعبد بن حميد، وابن أبي حاتم.أخرجه أبو جعفر الرملي في جزئه ص١٠٢ (تفسير عطاء الخراساني).تفسير مقاتل بن سليمان ٣/١٥٢. وفي تفسير الثعلبي ٧/٣٨، وتفسير البغوي ٥/٤٠٨ مثل أوله منسوبًا إلى مقاتل دون تعيينه.أخرجه عبد الرزاق في مصنفه ٢/٢٥٥ (٣٢٦٣).أخرجه البيهقي في شعب الإيمان ٩/٢٢٠-٢٢١ (٦٥٦٨). وأورده الحكيم الترمذي في نوادر الأصول ٣/٢١٠. وقال العراقي في تخريج الإحياء ص١٢٤٣: «أخرجه البيهقي في الشعب من حديث أبي بكر الصديق، وفيه الحارث بن عبيد الإيادي، ضعّفه أحمدُ وابن معين».أخرجه أبو نعيم في حلية الأولياء ٩/٣٠٤، والأصبهاني في الترغيب والترهيب ٢/٤١٧ (١٩٠٢)، وفي سنده الهيثم بن خالد.أورده الحكيم الترمذي في نوادر الأصول ٣/٢١٠. قال العراقي في تخريج الإحياء ص١٧٨: «بسند ضعيف». وقال المناوي في فيض القدير ٥/٣١٩: «قال الزين العراقي في شرح الترمذي: وسليمان بن عمرو -وهو أبو داود النخعي- متفق على ضعفه، وإنما يعرف هذا عن ابن المسيب. وقال في المغني: سنده ضعيف، والمعروف أنه من قول سعيد، ورواه ابن أبي شيبة في مصنفه، وفيه رجل لم يسم. وقال ولده: فيه سليمان بن عمرو، مجمع على ضعفه». وقال الألوسي في تفسيره ٩/٢٠٧: «بسند ضعيف». وقال الزيلعي في تخريج الكشاف ٢/٤٠٠: «وسليمان بن عمرو هذا يشبه أن يكون هو أبو داود النخعي، فإني لم أجد أحدًا في هذه الطبقة غيره، وقد اتفقوا على ضعفه، قال ابن عدي: أجمعوا على أنه يضع الحديث». وقال الألباني في الإرواء ٢/٩٢ (٣٧٣): «موضوع».أخرجه ابن أبي شيبة في مصنفه ١/٣٩٥ (٤٥٤٤)، من طريق وكيع، قال: حدثنا أبو عبيدة الناجي، عن الحسن، عن أبي هريرة به. إسناده ضعيف لانقطاعه؛ فإن الحسن لم يسمع من أبي هريرة، قال أيوب وعلي بن زيد وبهز بن أسد: «لم يسمع الحسن من أبي هريرة». وقال يونس بن عبيد: «ما رآه قط». وذكر أبو زرعة وأبو حاتم أن من قال عن الحسن: «حدثنا أبو هريرة» فقد أخطأ. كما في جامع التحصيل للعلائي ص١٦٤.أخرجه البخاري ١/١٥٠ (٧٥١)، ٤/١٢٥ (٣٢٩١).أخرجه أحمد ٢٤/٢٨٠ (١٥٥٢٢). قال النووي في خلاصة الأحكام ١/٤٧٧ (١٥٧٨): «رواه النسائي، بإسناد صحيح». وقال المنذري في الترغيب والترهيب ١/٢٠٢ (٧٦٥): «رواه النسائي، بإسناد حسن»، وقال المناوي في فيض القدير ٢/٣٣٤: «قال الحافظ الزين العراقي: رجاله رجال الصحيح».أخرجه مسلم ١/٣٢١ (٤٢٨).أخرجه البخاري ١/١٥٠ (٧٥٠).أخرجه ابن المبارك (١٤٣)، وابن أبي شيبة ١٤/٥٩، وأحمد في الزهد ص١٤٢.أخرجه ابن أبي شيبة ٢/٤١.أخرجه ابن أبي شيبة ٢/٤٠.أخرجه يحيى بن سلام ١/٣٩٣.أخرجه ابن أبي شيبة ٢/٢٤٠، والطبراني (٩١٧٤، ٩١٧٥).أخرجه ابن أبي شيبة ٢/٢٤٠.أخرجه ابن أبي شيبة ٢/٣٤٠، وأحمد في فضائل الصحابة (٢٣٠). وعزاه السيوطي إلى أحمد في الزهد، وابن سعد.أخرجه عبد الرزاق (٣٢٧٠)، وابن أبي شيبة ٢/٤١.أخرجه ابن أبي شيبة ٢/٤١.علَّقه يحيى بن سلام ١/٣٩٢.أخرجه محمد بن نصر في تعظيم قدر الصلاة ١/١٩٠.
23,3," <q>﴿وَٱلَّذِینَ هُمۡ عَنِ ٱللَّغۡوِ مُعۡرِضُونَ ۝٣﴾</q> - تفسير ٥١٣٧٣- عن عبد الله بن عباس -من طريق علي- في قوله: <q>﴿والذين هم عن اللغو معرضون﴾</q>، قال: الباطل{1}. (١٠/٥٦٥) ٥١٣٧٤- قال عبد الله بن عباس: عن الحلف الكاذب{2}. (ز) ٥١٣٧٥- عن الحسن البصري -من طريق معمر- في قوله: <q>﴿والذين هم عن اللغو مغرضون﴾</q>، قال: عن المعاصي{3}. (١٠/٥٦٥) ٥١٣٧٦- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿والذين هم عن اللغو معرضون﴾</q>، قال: أتاهم -واللهِ- مِن أمر الله ما وقَذَهُم{4} عن الباطل{5}. (١٠/٥٦٥) ٥١٣٧٧- قال مقاتل بن سليمان: <q>﴿والذين هم عن اللغو معرضون﴾</q>، يعني: اللغو: الشتم والأذى إذا سمعوه مِن كفار مكة لإسلامهم، وفيهم نزلت: <q>﴿وإذا مروا باللغو مروا كراما﴾</q> [الفرقان:٧٢]، يعني: معرضين عنه{6}. (ز) ٥١٣٧٨- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿والذين هم عن اللغو معرضون﴾</q>، قال: النبي ﷺ ومَن معه مِن صحابته مِمَن آمن به واتبعه وصدقه، كانوا عن اللغو معرضين{7}. (ز) ٥١٣٧٩- قال يحيى بن سلّام: واللغو: الباطل، وهو تفسير السُّدِّيّ.= (ز) ٥١٣٨٠- قال يحيى بن سلّام: ويقال: الكذب. وهو واحد، وهو الشرك{8}٤٥٢١. (ز) ٤٥٢١ ذكر ابنُ كثير (١٠/١٠٨) أن اللغو يشمل: الشرك -كما قاله بعضهم-، والمعاصي -كما قاله آخرون -، وما لا فائدة فيه مِن الأقوال والأفعال، كما قال تعالى: <q>﴿وإذا مروا باللغو مروا كراما﴾</q> [الفرقان:٧٢]. ",footnotes:1:أخرجه ابن جرير ١٧/١١. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.تفسير الثعلبي ٧/٣٩.أخرجه عبد الرزاق ٢/٤٣، وابن جرير ١٧/١١. وعزاه السيوطي إلى ابن المنذر.الوَقْذُ: هو المنع من انتهاك ما لا يحل ولا يَجْمُل. النهاية (وقذ).أخرجه ابن المبارك في الزهد (١٧٠، ٨٠١).تفسير مقاتل بن سليمان ٣/١٥٢.أخرجه ابن جرير ١٧/١١.تفسير يحيى بن سلام ١/٣٩٣.
23,4," <q>﴿وَٱلَّذِینَ هُمۡ لِلزَّكَوٰةِ فَـٰعِلُونَ ۝٤﴾</q> - تفسير ٥١٣٨١- عن سعيد بن جبير -من طريق عطاء بن دينار- في قوله: <q>﴿والذين هم للزكاة فاعلون﴾</q>: يعني: الأموال{1}. (١٠/٥٦٥) ٥١٣٨٢- قال مقاتل بن سليمان: <q>﴿والذين هم للزكاة فاعلون﴾</q>، يعني: زكاة أموالهم{2}. (ز) ٥١٣٨٣- قال يحيى بن سلّام: قوله: <q>﴿والذين هم للزكاة فاعلون﴾</q> يُؤَدُّون الزكاة المفروضة{3}٤٥٢٢. (ز) ٤٥٢٢ ذكر ابنُ عطية (٦/٢٧٩) أن هذا القول بيِّن، ثم ذكر احتمالًا آخر، فقال: «ويحتمل اللفظ أن يريد بالزكاة: الفضائل، كأنه أراد الأزكى مِن كل فعل، كما قال تعالى: <q>﴿خَيْرًا مِنهُ زَكاةً وأَقْرَبَ رُحْمًا﴾</q> [الكهف:٨١]». وعلَّق ابنُ كثير (١٠/١٠٨)بقوله: «الأكثرون على أن المراد بالزكاة هاهنا: زكاة الأموال، مع أن هذه الآية مكية، وإنما فرضت الزكاة بالمدينة في سنة اثنتين من الهجرة. والظاهر أن التي فرضت بالمدينة إنما هي ذات النصب والمقادير الخاصة، وإلا فالظاهر أن أصل الزكاة كان واجبًا بمكة، كما قال تعالى في سورة الأنعام [١٤١]، وهي مكية: <q>﴿وآتوا حقه يوم حصاده﴾</q>». ثم ذكر احتمالًا آخر، فقال: «وقد يحتمل أن يكون المراد بالزكاة هاهنا: زكاة النفس من الشرك والدنس، كقوله: <q>﴿قد أفلح من زكاها. وقد خاب من دساها﴾</q> [الشمس:٩-١٠]، وكقوله: <q>﴿وويل للمشركين. الذين لا يؤتون الزكاة﴾</q> [فصلت:٦-٧]، على أحد القولين في تفسيرها. وقد يحتمل أن يكون كلا الأمرين مرادًا، وهو زكاة النفوس وزكاة الأموال؛ فإنه من جملة زكاة النفوس، والمؤمن الكامل هو الذي يتعاطى هذا وهذا». ",footnotes:1:أخرجه ابن أبي حاتم ٢/٤٨٥.تفسير مقاتل بن سليمان ٣/١٥٢.تفسير يحيى بن سلام ١/٣٩٣.
23,5," <q>﴿وَٱلَّذِینَ هُمۡ لِفُرُوجِهِمۡ حَـٰفِظُونَ ۝٥ إِلَّا عَلَىٰۤ أَزۡوَ ٰ⁠جِهِمۡ أَوۡ مَا مَلَكَتۡ أَیۡمَـٰنُهُمۡ فَإِنَّهُمۡ غَیۡرُ مَلُومِینَ ۝٦﴾</q> - تفسير ٥١٣٨٤- عن عبد الله بن عباس -من طريق العوفي- قوله: <q>﴿والذين هم لفروجهم حافظون إلا على أزواجهم أو ما ملكت أيمانهم فإنهم غير ملومين﴾</q>، يقول: رضي الله لهم إتيانهم أزواجهم، وما ملكت أيمانهم{1}. (ز) ٥١٣٨٥- عن عبد الله بن عباس -من طريق محمد بن كعب- قال: إنما كانت المتعة في أول الإسلام، كان الرجل يقدم البلدة ليس له بها معرفة، فيتزوج المرأة بقدر ما يرى أنه يقيم، فتحفظ له متاعه، وتُصلِح له شيئه، حتى إذا نزلت الآية: <q>﴿إلا على أزواجهم أو ما ملكت أيمانهم﴾</q>، قال ابن عباس: فكل فَرْج سواهما فهو حرام{2}. (ز) ٥١٣٨٦- عن سعيد بن جبير، في قوله: <q>﴿والذين هم لفروجهم حافظون﴾</q> يعني: عن الفواحش، <q>﴿إلا على أزواجهم أو ما ملكت أيمانهم﴾</q> يعني: ولائدَهم، <q>﴿فإنهم غير ملومين﴾</q> قال: لا يُلامُون على جماع أزواجهم وولائدهم{3}. (١٠/٥٦٥) ٥١٣٨٧- عن محمد بن كعب القرظي، قال: كلُّ فَرْج عليك حرام إلا فرجين؛ قال الله: <q>﴿إلا على أزواجهم أو ما ملكت ايمانهم﴾</q>{3}. (١٠/٥٦٦) ٥١٣٨٨- عن إسماعيل السُّدِّيّ، في قوله: <q>﴿إلا على أزواجهم﴾</q> يعني: إلا من امرأته، <q>﴿أو ما ملكت أيمانهم﴾</q> قال: أمَته{3}. (١٠/٥٦٦) ٥١٣٨٩- قال مقاتل بن سليمان: <q>﴿والذين هم لفروجهم حافظون﴾</q> عن الفواحش. ثم استثنى، فقال سبحانه: <q>﴿إلا على أزواجهم﴾</q> يعني: حلائلهم، <q>﴿أو ما ملكت أيمانهم﴾</q> من الولائد؛ <q>﴿فإنهم غير ملومين﴾</q> يعني: لا يُلامون على الحلال{6}. (ز) ٥١٣٩٠- قال يحيى بن سلّام: قوله: <q>﴿والذين هم لفروجهم حافظون﴾</q> مِن الزنا، <q>﴿إلا على أزواجهم﴾</q> إن شاء تزوج واحدة، وإن شاء تزوج اثنتين، وإن شاء ثلاثًا، وإن شاء أربعًا، لا يَحِلُّ له ما فوق ذلك، <q>﴿أو ما ملكت أيمانهم﴾</q> يطأ بملك يمينه كم شاء، <q>﴿فإنهم غير ملومين﴾</q> في أزواجهم، أو ما ملكت أيمانهم، لا لوم عليهم في ذلك، أي: لا إثم عليهم{7}. (ز) ",footnotes:1:أخرجه ابن جرير ١٧/١٢.أخرجه الترمذي ٢/٥٩٤ (١١٥٠)، والطبراني، والبيهقي.عزاه السيوطي إلى ابن أبي حاتم.عزاه السيوطي إلى ابن أبي حاتم.عزاه السيوطي إلى ابن أبي حاتم.تفسير مقاتل بن سليمان ٣/١٥٢.تفسير يحيى بن سلام ١/٣٩٣.
  23,6,""
23,7," <q>﴿فَمَنِ ٱبۡتَغَىٰ وَرَاۤءَ ذَ ٰ⁠لِكَ فَأُو۟لَـٰۤىِٕكَ هُمُ ٱلۡعَادُونَ ۝٧﴾</q> - تفسير ٥١٣٩١- عن عبد الله بن عباس -من طريق العوفي- قال: نهاهم الله نهيًا شديدًا، فقال: <q>﴿فمن ابتغى وراء ذلك فأولئك هم العادون﴾</q>، فسَمّى الزاني مِن العادِين{1}. (ز) ٥١٣٩٢- عن أبي عبد الرحمن [السلمي] -من طريق عطاء- في قوله: <q>﴿فمن ابتغى وراء ذلك فاولئك هم العادون﴾</q>، قال: الزِّنا{2}. (١٠/٥٦٦) ٥١٣٩٣- عن سعيد بن جبير، في قوله: <q>﴿فمن ابتغى وراء ذلك﴾</q>: يعني: فمَن طلب الفواحش بعد الأزواج والولائد؛ طَلَب ما لم يَحِلَّ، <q>﴿فأولئك هم العادون﴾</q> يعني: المعتدين في دينهم{3}. (١٠/٥٦٥) ٥١٣٩٤- عن أفلح، عن القاسم [بن محمد]، قال: سُئِل عن <q>﴿الذين هم لفروجهم حافظون إلا على أزواجهم، أو ما ملكت أيمانهم فإنهم غير ملومين فمن ابتغى وراء ذلك فأولئك هم العادون﴾</q>، فمن ابتغى وراء ذلك، فهو عادٍ{4}. (ز) ٥١٣٩٥- عن قتادة بن دعامة، في قوله: <q>﴿فمن ابتغى وراء ذلك فأولئك هم العادون﴾</q>، يقول: مَن تَعَدّى الحلال أصابه الحرام{5}. (١٠/٥٦٦) ٥١٣٩٦- قال إسماعيل السُّدِّيّ: <q>﴿فأولئك هم العادون﴾</q>، أي: فأولئك هم المعتدون، أي: الظالمون أنفسهم بركوب المعصية{6}. (ز) ٥١٣٩٧- قال مقاتل بن سليمان: <q>﴿فمن ابتغى وراء ذلك فأولئك هم العادون﴾</q>، يقول: فمَن ابتغى الفواحش بعد الحلال فهو مُعْتَدٍ{7}. (ز) ٥١٣٩٨- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿فأولئك هم العادون﴾</q>، قال: الذين يَتَعَدُّون الحلال إلى الحرام{8}. (ز) ٥١٣٩٩- قال يحيى بن سلّام: قوله: <q>﴿فمن ابتغى وراء ذلك﴾</q> وراء أزواجه أو ما ملكت يمينه؛ <q>﴿فأولئك هم العادون﴾</q> الزناة، تَعَدَّوُا الحلالَ إلى الحرام{9}. (ز) <q>﴿فَمَنِ ٱبۡتَغَىٰ وَرَاۤءَ ذَ ٰ⁠لِكَ فَأُو۟لَـٰۤىِٕكَ هُمُ ٱلۡعَادُونَ ۝٧﴾</q> - من أحكام الآية ٥١٤٠٠- عن ابن أبي مليكة، قال: سُئِلَت عائشة عن متعة النساء. فقالت: بيني وبينكم كتاب الله. وقرأت: <q>﴿والذين هم لفروجهم حافظون إلا على ازواجهم أو ما ملكت أيمانهم﴾</q>. فمَن ابتغى وراء ما زَوَّجه الله أو مَلَّكه فقد عَدا{10}. (١٠/٥٦٧) ٥١٤٠١- عن القاسم بن محمد -من طريق الزهري- أنّه سُئِل عن المتعة. فقال: إنِّي لأرى تحريمها في القرآن. ثم تلا: <q>﴿والذين هم لفروجهم حافظون إلا على أزواجهم أو ما ملكت أيمانهم﴾</q>{11}. (١٠/٥٦٧) <q>﴿فَمَنِ ٱبۡتَغَىٰ وَرَاۤءَ ذَ ٰ⁠لِكَ فَأُو۟لَـٰۤىِٕكَ هُمُ ٱلۡعَادُونَ ۝٧﴾</q> - مسألة ٥١٤٠٢- عن سعيد بن جبير، قال: عذَّب اللهُ أُمَّة كانوا يعبثون بمذاكيرهم{12}. (ز) ٥١٤٠٣- قال ابن جريج: سألت عطاءً عنه{13}. فقال: مكروه، سمعتُ أنّ قومًا يحشرون وأيديهم حبالى، فأظن أنهم هؤلاء{12}. (ز) ٥١٤٠٤- عن قتادة، قال: تَسَرَّتِ امرأةٌ غلامًا لها، فذُكِرَت لعمر، فسألها: ما حَمَلَكِ على هذا؟ فقالت: كنت أرى أنه يَحِلُّ لي ما يحل للرجل مِن مِلْك اليمين. فاستشار عمرُ فيها أصحابَ النبي ﷺ، فقالوا: تَأَوَّلَتْ كتاب الله على غير تأويله. فقال عمر: لا جرم، واللهِ، لا أُحِلُّك لِحُرٍّ بعده أبدًا. كأنّه عاقبها بذلك، ودَرَأ الحد عنها، وأمر العبد أن لا يقربها{15}٤٥٢٣. (١٠/٥٦٧) ٤٥٢٣ علَّق ابنُ كثير (١٠/١٠٩) على هذا الأثر بقوله: «هذا أثر غريب منقطع، ذكره ابن جرير في أول تفسير سورة المائدة، وهو هاهنا أليق». ثم وجَّهه بقوله: «وإنما حرمها على الرجال معاملة لها بنقيض قصدها». ٥١٤٠٥- عن أبي بكر بن عبد الله أنّه سمع أباه يقول: حَضَرْتُ عمر بن عبد العزيز جاءته امرأةٌ مِن العرب بغلام لها رُوِمِيٍّ، فقالت: إنِّي اسْتَسْرَرْتُه، فمنعني بنو عمي، وإنما أنا بمنزلة الرجل تكون له الوليدة فيطؤها، فانْهَ عَنِّي بني عمي. فقال لها عمر: أتزوجت قبله؟ قالت: نعم. قال: أما -واللهِ- لولا منزلتك مِن الجهالة لرجمتك بالحجارة{16}. (١٠/٥٦٧) ٥١٤٠٦- عن إبراهيم النخعي -من طريق حماد- قال: لا يصلح للعبد أن يَتَسَرّى. ثم تلا هذه الآية <q>﴿إلا على أزواجهم أو ما ملكت أيمانهم﴾</q>. فليست له بزوجة، ولا مِلك يمين.= (ز) ٥١٤٠٧- قال محمد [بن الحسن]: وبه نأخذ.= (ز) ٥١٤٠٨- وهو قول أبي حنيفة{17}. (ز) ٥١٤٠٩- عن شعبة، قال: سألت حماد [بن أبي سليمان] عن ذلك{18}. فقال: ألم تسمع، ولكن الله يقول: <q>﴿إلا على أزواجهم أو ما ملكت أيمانهم﴾</q>{19}. (ز) ٥١٤١٠- عن عبد الله بن عمر أنه سُئِل عن امرأة أحَلَّت جاريتها لزوجها. فقال: لا يَحِلُّ لكَ أن تطأ فرجًا، إلا فرجًا؛ إن شِئت بِعْتَ، وإن شئت وهبت، وإن شئت أعتقت{20}. (١٠/٥٦٨) ٥١٤١١- عن سعيد بن وهب، قال: جاء رجل إلى ابن عمر، فقال: ان أمي كانت لها جارية، وإنها أحَلَّتْها لي، أطوف عليها؟ فقال: لا تَحِلُّ لك ألّا أن تشتريها، أو تهبها لك{21}. (١٠/٥٦٨) ٥١٤١٢- عن عبد الله بن عباس، قال: اذا أحلَّت امرأة الرجل، أو ابنته، أو أخته، له جاريتها، فليُصِبها، وهي لها{22}. (١٠/٥٦٨) ٥١٤١٣- عن محمد بن سيرين، قال: الفَرْجُ لا يُعار{23}. (١٠/٥٦٩) ٥١٤١٤- عن الحسن البصري، قال: لا يُعارُ الفَرْجُ{23}. (١٠/٥٦٩) ",footnotes:1:أخرجه ابن جرير ١٧/١٢.أخرجه ابن جرير ١٧/١٣. وعزاه السيوطي إلى عبد بن حميد.عزاه السيوطي إلى ابن أبي حاتم.أخرجه ابن أبي شيبة (ت: محمد عوامة) ٩/٤٣٥ (١٧٧٩٠).علَّقه يحيى بن سلام ١/٣٩٣. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.علَّقه يحيى بن سلام ١/٣٩٣.تفسير مقاتل بن سليمان ٣/١٥٢.أخرجه ابن جرير ١٧/١٣.تفسير يحيى بن سلام ١/٣٩٣.أخرجه الحاكم ٢/٣٠٥، ٣٩٣. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.أخرجه عبد الرزاق في تفسيره ٢/٤٤، وفي مصنفه ٧/٥٠٢-٥٠٣ (١٤٠٣٦). وعزاه السيوطي إلى أبي داود في ناسخه.تفسير البغوي ٥/٤١٠.أي: عن حكم الاستمناء باليد.تفسير البغوي ٥/٤١٠.أخرجه عبد الرزاق (١٢٨١٨).أخرجه عبد الرزاق (١٢٨٢١).الآثار لمحمد بن الحسن الشيباني ١/٤١٨.أي: عن أن يتسرى العبد.أخرجه ابن أبي شيبة (ت: محمد عوامة) ٩/١١٠ (١٦٥٤٧).أخرجه عبد الرزاق (١٢٨٤٧)، وابن أبي شيبة ٤/٣٣٨.أخرجه عبد الرزاق (١٢٨٤٨).أخرجه عبد الرزاق (١٢٨٥٢).أخرجه ابن أبي شيبة ٤/٣٣٩.أخرجه ابن أبي شيبة ٤/٣٣٩.
23,8," <q>﴿وَٱلَّذِینَ هُمۡ لِأَمَـٰنَـٰتِهِمۡ وَعَهۡدِهِمۡ رَ ٰ⁠عُونَ ۝٨﴾</q> - تفسير ٥١٤١٥- عن سعيد بن جبير، في قوله: <q>﴿والذين هم لأماناتهم﴾</q>: يعني بهذا ما ائْتُمِنوا عليه فيما بينهم وبين الناس، <q>﴿وعهدهم﴾</q> قال: يوفون العهد، <q>﴿راعون﴾</q> قال: حافِظون{1}. (١٠/٥٦٥) ٥١٤١٦- قال مقاتل بن سليمان: <q>﴿والذين هم لأماناتهم وعهدهم راعون﴾</q>، يقول: يُحافِظون على أداء الأمانة، ووفاء العهد{2}. (ز) ٥١٤١٧- قال يحيى بن سلّام: قوله: <q>﴿والذين هم لأماناتهم وعهدهم راعون﴾</q> يُؤَدُّون الأمانة، ويُوفون بالعهد{3}. (ز) ",footnotes:1:عزاه السيوطي إلى ابن أبي حاتم.تفسير مقاتل بن سليمان ٣/١٥٢.تفسير يحيى بن سلام ١/٣٩٣.
23,9," <q>﴿وَٱلَّذِینَ هُمۡ عَلَىٰ صَلَوَ ٰ⁠تِهِمۡ یُحَافِظُونَ ۝٩﴾</q> - تفسير ٥١٤١٨- عن عبد الله بن مسعود -من طريق القاسم- أنّه قيل له: إنّ الله يُكْثِر ذكر الصلاة في القرآن: <q>﴿الذين هم على صلاتهم دائمون﴾</q> [المعارج:٢٢]، <q>﴿والذين هم على صلواتهم يحافظون﴾</q>. قال: ذاك على مواقيتها. قالوا: ما كُنّا نرى ذلك إلا على تركها. قال: تركها الكفر{1}. (١٠/٥٦٩) ٥١٤١٩- عن مسروق بن الأجدع -من طريق أبي الضُّحى- قال: ما كان في القرآن <q>﴿يحافظون﴾</q> فهو على مواقيت الصلاة{2}. (١٠/٥٦٩) ٥١٤٢٠- عن إبراهيم النخعي -من طريق منصور- <q>﴿على صلواتهم يحافظون﴾</q>، قال: دائمون. قال: يعني بها: المكتوبة{3}. (ز) ٥١٤٢١- عن [أبي الضحى] مسلم بن صبيح -من طريق الأعمش- قال: <q>﴿الذين هم على صلواتهم يحافظون﴾</q>، قال: إقام الصلاة لوقتها{3}. (ز) ٥١٤٢٢- عن عكرمة مولى ابن عباس، في قوله: <q>﴿والذين هم على صلواتهم يحافظون﴾</q>، قال: على المكتوبة{5}. (١٠/٥٧٠) ٥١٤٢٣- عن أبي صالح [باذام]، في قوله: <q>﴿والذين هم على صلواتهم يحافظون﴾</q>، قال: المكتوبة، والذي في «سأل» [المعارج:٣٤]: التطوع{6}٤٥٢٤. (١٠/٥٦٩) ٤٥٢٤ نسب ابن تيمية هذا القول لابن جريج، ثم انتقده (٤/٤٥٢) بقوله: «وهو قول ضعيف». ٥١٤٢٤- عن قتادة، في قوله: <q>﴿والذين هم على صلواتهم يحافظون﴾</q>، قال: أي: على وضوئها، ومواقيتها، وركوعها، وسجودها{7}. (١٠/٥٦٩) ٥١٤٢٥- قال مقاتل بن سليمان: <q>﴿والذين هم على صلواتهم يحافظون﴾</q> على المواقيت{8}. (ز) ٥١٤٢٦- قال يحيى بن سلّام: قوله: <q>﴿والذين هم على صلواتهم يحافظون﴾</q> يحافظون على الصلوات الخمس{9}. (ز) <q>﴿وَٱلَّذِینَ هُمۡ عَلَىٰ صَلَوَ ٰ⁠تِهِمۡ یُحَافِظُونَ ۝٩﴾</q> - آثار متعلقة بالآية ٥١٤٢٧- عن قتادة، عن حنظلة الكاتب، أنّ رسول الله ﷺ قال: «مَن حافَظ على الصلوات الخمس؛ على وضوئهن، ومواقيتهن، وركوعهن، وسجودهن، وعلم أنّه حقٌّ لله عليه؛ دخل الجنة». أو قال: «وجبت له الجنة». وقال سعيد: حُرِّم على النار{10}. (ز) ",footnotes:1:أخرجه الطبراني (٨٩٣٨). وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم، وأبي الشيخ.أخرجه ابن جرير ١٧/١٤، وابن أبي حاتم ٤/١٣٤٦. وعزاه السيوطي إلى سعيد بن منصور.أخرجه ابن جرير ١٧/١٤.أخرجه ابن جرير ١٧/١٤.عزاه السيوطي إلى عبد بن حميد.عزاه السيوطي إلى ابن المنذر.علَّقه يحيى بن سلام ١/٣٩٣. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.تفسير مقاتل بن سليمان ٣/١٥٢.تفسير يحيى بن سلام ١/٣٩٣.أخرجه أحمد ٣٠/٢٨٧ (١٨٣٤٥)، ٣٠/٢٨٨ (١٨٣٤٦). وأورده يحيى بن سلام ١/٣٩٣. قال ابن مندة في معرفة الصحابة ص٣٧٦: «هكذا رواه سعيد عن قتادة، مرسل». قال المنذري في الترغيب ١/١٥١ (٥٥٧): «رواه أحمد، بإسناد جيد، ورواته رواة الصحيح». وقال ابن كثير في السيرة ٤/٦٧٤: «تفرَّد به أحمد، وهو مُنقَطِع بين قتادة وحنظلة». وقال البوصيري في إتحاف الخيرة ١/٤١٥ (٧٦٣): «رواه أحمد بن حنبل في مسنده، بإسناد الصحيح». وقال ابن الديبع في مكفرات الذنوب ص٧٨: «أخرجه الطبراني في الكبير، والإمام أحمد، ورجاله رجال الصحيح».
23,10," <q>﴿أُو۟لَـٰۤىِٕكَ هُمُ ٱلۡوَ ٰ⁠رِثُونَ ۝١٠﴾</q> - تفسير ٥١٤٢٨- عن أبي هريرة، قال: قال رسول الله ﷺ: «ما منكم مِن أحد إلا وله منزلان؛ منزل في الجنة، ومنزل في النار، فإذا مات فدخل النار؛ ورِث أهل الجنة منزله، فذلك قوله: <q>﴿أولئك هم الوارثون﴾</q>»{1}. (١٠/٥٧٠) ٥١٤٢٩- عن أبي هريرة -من طريق أبي صالح، والأعمش- في قوله: <q>﴿أولئك هم الوارثون﴾</q>، قال: يَرِثون مساكنَهم، ومساكنَ إخوانهم التي أُعِدَّت لهم لو أطاعوا الله{2}. (١٠/٥٧٠) ٥١٤٣٠- عن عبد الملك ابن جُرَيْج -من طريق حجّاج- قال: <q>﴿الوارثون﴾</q>، <q>﴿الجنة أورثتموها﴾</q> [الأعراف:٤٣]، <q>﴿الجنة التي نورث من عبادنا﴾</q> [مريم:٦٣] هُنَّ سواء.= (ز) ٥١٤٣١- قال ابن جُرَيج: قال مجاهد: يَرِث الذي مِن أهل الجنة أهلَه وأهلَ غيره، ومنزلَ الذين من أهل النار، هم يَرِثون أهل النار، فلهم منزلان في الجنة وأهلان؛ وذلك أنه منزل في الجنة، ومنزل في النار، فأمّا المؤمن فيبني منزله الذي في الجنة، ويهدِم منزله الذي في النار، وأما الكافر فيهدم منزله الذي في الجنة، ويبني منزله الذي في النار{3}. (ز) ٥١٤٣٢- قال مقاتل بن سليمان: ثم أخبر بثوابهم، فقال: <q>﴿أولئك هم الوارثون﴾</q>{4}. (ز) ٥١٤٣٣- قال يحيى بن سلّام: قال: <q>﴿أولئك هم الوارثون﴾</q>، ليس مِن واحد إلا قد أعدَّ الله له منزلًا وأهلًا في الجنة، فإن أطاع الله صار إلى ما أُعِدَّ له، وإن عصى الله صرف الله ذلك المنزل عنه فأعطاه المؤمنَ؛ ما أعدَّ الله للمؤمنين، فوَرَّث المؤمنين تلك المنازل والأزواج، فهو قوله: <q>﴿أولئك هم الوارثون﴾</q>{5}. (ز) ",footnotes:1:أخرجه ابن ماجه ٥/٣٨٩ (٤٣٤١)، والحاكم ٢/٤٢٧ (٣٤٨٥)، وابن جرير ١٧/١٥، وابن أبي حاتم -كما في تفسير ابن كثير ٥/٤٦٤-. وأورده الثعلبي ٧/٤٠. قال الحاكم: «هذا حديث صحيح، على شرط الشيخين، ولم يخرجاه». قال القرطبي في تفسيره ١٢/١٠٨: «إسناده صحيح». وقال ابن حجر في الفتح ١١/٤٤٢: «بسند صحيح». وقال البوصيري في مصباح الزجاجة ٤/٢٦٦: «هذا إسناد صحيح، على شرط الشيخين». وقال الألباني في الصحيحة ٥/٣٤٨ (٢٢٧٩): «هذا إسناد صحيح، على شرط الشيخين».أخرجه عبد الرزاق ٢/٤٤، وابن جرير ١٧/١٥، والحاكم ٢/٣٩٣. وعزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ١٧/١٥-١٦.تفسير مقاتل بن سليمان ٣/١٥٢.تفسير يحيى بن سلام ١/٣٩٤.
23,11," <q>﴿ٱلَّذِینَ یَرِثُونَ ٱلۡفِرۡدَوۡسَ هُمۡ فِیهَا خَـٰلِدُونَ ۝١١﴾</q> - تفسير ٥١٤٣٤- عن أنس: أن الرُّبَيِّعَ بنت النضر أتت رسول الله ﷺ، وكان ابنها الحارث بن سراقة أُصِيب يوم بدر؛ أصابه سهْمُ غَرْبٍ{1}، فقالت: أخْبِرْني عن حارثة؛ فإن كان أصاب الجنة احْتَسَبْتُ وصبرت، وإن كان لم يُصِبِ الجنةَ اجتهدت في الدعاء. فقال النبي ﷺ: «يا أم حارثة، إنها جنان في جنة، وإنّ ابنك أصاب الفردوس الأعلى، والفردوس ربوة الجنة، وأوسطها، وأفضلها»{2}. (١٠/٥٧١) ٥١٤٣٥- عن صالح مولى التَّوْأَمة، عن أبي هريرة، قال: الفردوس: جبلٌ في الجنة تَفَجَّر منه أنهار الجنة{3}. (ز) ٥١٤٣٦- عن مجاهد بن جبر -من طريق ابن جريج- في قوله: <q>﴿الذين يرثون الفردوس﴾</q>، قال: الفردوس: بستان، بالرومية{4}. (ز) ٥١٤٣٧- قال سفيان بن عيينة في تفسير مجاهد: <q>﴿الفردوس﴾</q>، قال: هو البستان بالرومية، وهو المخصوص بالحسن. وقرأ سفيان: <q>﴿قد أفلح المؤمنون﴾</q> حتى بلغ <q>﴿أؤلئك هم الوارثون*الذين يرثون الفردوس هم فيها خالدون﴾</q>{5}. (ز) ٥١٤٣٨- عن مجاهد بن جبر -من طريق ابن جريج- قال: عدن: حديقة في الجنة، قصرها فيها عَدْنُها{6}، خَلَقها بيده، تفتح كل فجر فينظر فيها، ثم يقول: قد أفلح المؤمنون. قال: هي الفردوس أيضًا تلك الحديقة. قال مجاهد: غَرَسها الله بيده، فلما بلغت قال: قد أفلح المؤمنون. ثم أمر بها تغلق، فلا ينظر فيها خَلْقٌ، ولا مَلَكٌ مُقَرَّب، ثم تفتح كل سَحَر، فينظر فيها، فيقول: قد أفلح المؤمنون. ثم تغلق إلى مثلها{7}. (ز) ٥١٤٣٩- قال عكرمة مولى ابن عباس: هي الجنة، بلسان الحبش{8}. (ز) ٥١٤٤٠- تفسير الحسن البصري: <q>﴿الذين يرثون الفردوس هم فيها خالدون﴾</q>، والفردوس اسمٌ مِن أسماء الجنة{9}. (ز) ٥١٤٤١- قال إسماعيل السُّدِّيّ: هي البساتين التي عليها الحِيطان، بلسان الروم{8}. (ز) ٥١٤٤٢- عن عبد الملك ابن جُرَيج -من طريق حجّاج- في <q>﴿الفردوس﴾</q>، قال: بستان، بالرومية{11}. (ز) ٥١٤٤٣- قال مقاتل بن سليمان: ثم بَيَّن ما يَرِثون، فقال: <q>﴿الذين يرثون الفردوس﴾</q> يعني: البستان عليه الحيطان، بالرومية، <q>﴿هم فيها خالدون﴾</q> يعني: في الجنة لا يموتون{12}. (ز) ٥١٤٤٤- قال يحيى بن سلّام: وبلغني أنّها بالرومية{9}. (ز) <q>﴿ٱلَّذِینَ یَرِثُونَ ٱلۡفِرۡدَوۡسَ هُمۡ فِیهَا خَـٰلِدُونَ ۝١١﴾</q> - آثار متعلقة بالآية ٥١٤٤٥- عن قتادة، عن كعب [الأحبار]، قال: خلق الله بيده جَنَّة الفردوس، غرسها بيده، ثم قال: تَكَلَّمي. قالت: طوبى للمتقين{14}. (ز) ٥١٤٤٦- عن أبي داود نُفَيْع، قال: لَمّا خلقها اللهُ قال لها: تَزَيَّني. فتزينت، ثم قال لها: تكلمي. فقالت: طوبى لِمَن رَضِيتَ عنه{14}. (ز) ",footnotes:1:سَهْمُ غَرْبٍ -بفتح الراء وسكونها، وبالإضافة وغير الإضافة-: أي لا يُعْرَف رامِيه. وقيل: هو بالسكون إذا أتاه من حيث لا يَدْرِي، وبالفتح إذا رماه فأَصاب غيره. النهاية (غرب).أخرجه البخاري ٤/٢٠ (٢٨٠٩)، ٨/١١٦-١١٧ (٦٥٦٧) بنحوه دون قوله: «والفردوس ربوة الجنة، وأوسطها، وأفضلها»، والترمذي ٥/٣٩٢-٣٩٣ (٣٤٤٨) واللفظ له إلا أنه قال فيه: «خير» مكان «الجنة»، وابن جرير مختصرًا ١٥/٤٣٦. قال الترمذي: «حديث حسن صحيح غريب».أخرجه يحيى بن سلام ١/٣٩٤.أخرجه ابن جرير ١٧/١٦.أخرجه إسحاق البستي في تفسيره ص٣٨٦.عَدَنَ بها: أقام بها، ومنه سُمِّيت: جنة عدْن، أي: جَنَّة إقامة. النهاية (عدن).أخرجه ابن جرير ١٧/١٦، وابن أبي الدنيا في كتاب صفة الجنة -موسوعة الإمام ابن أبي الدنيا ٦/٣٢١ (٢٩)- بنحوه.تفسير الثعلبي ٧/٤٠.علَّقه يحيى بن سلام ١/٣٩٤.تفسير الثعلبي ٧/٤٠.أخرجه إسحاق البستي في تفسيره ص٣٨٧.تفسير مقاتل بن سليمان ٣/١٥٢.علَّقه يحيى بن سلام ١/٣٩٤.أخرجه ابن جرير ١٧/١٧.أخرجه ابن جرير ١٧/١٧.
23,12," <q>﴿وَلَقَدۡ خَلَقۡنَا ٱلۡإِنسَـٰنَ مِن سُلَـٰلَةࣲ مِّن طِینࣲ ۝١٢﴾</q> - تفسير ٥١٤٤٧- عن عبد الله بن عباس -من طريق أبي يحيى- في قوله: <q>﴿من سلالة﴾</q>، قال: السلالة: صَفْوُ الماءِ الرقيق الذي يكون منه الولد{1}٤٥٢٥. (١٠/٥٧١) ٤٥٢٥ وجَّه ابنُ عطية (٦/٢٨١ بتصرف) قول ابن عباس بقوله: «وهذا على أنّه اسم الجنس، ويَتَرَتَّب عليه أنه سلالة من حيث كان الكل عن آدم أو عن الأبوين المتقدمين بما يكون من الطين، وذلك السبع الذي جعل الله رِزق ابن آدم فيها، وسيجيء قولَ ابن عباس فيها -إن شاء الله-، وعلى هذا يجيء قول ابن عباس: إنّ»السلالة«هي صفوة الماء، يعني: المني». ٥١٤٤٨- عن مجاهد بن جبر، <q>﴿ولقد خلقنا الانسان من سلالة من طين﴾</q>، قال: هو الطين النَّدِيُّ إذا قبضت عليه خرج ماؤه مِن بين أصابعك{2}. (١٠/٥٧١) ٥١٤٤٩- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿من سلالة﴾</q>، قال: مِن مَنِيِّ آدم{3}٤٥٢٦. (١٠/٥٧١) ٤٥٢٦ علَّق ابن عطية (٦/٢٨٢) على قول مجاهد بقوله: «وهذا بَيِّن؛ إذ آدمُ من طين، وذريته مِن سلالة، وما يكون عن الشيء فهو سلالته». ٥١٤٥٠- عن عكرمة مولى ابن عباس -من طريق أبي رجاء- <q>﴿ولقد خلقنا الانسان من سلالة﴾</q>، قال: اسْتُلَّ اسْتِلالًا{4}. (١٠/٥٧١) ٥١٤٥١- عن خالد بن معدان، قال: الإنسان خُلِق مِن طين، وإنّما تلين القلوب في الشتاء{5}. (١٠/٥٧٢) ٥١٤٥٢- عن قتادة بن دعامة -من طريق مَعْمَر- في الآية، قال: استُلَّ آدم مِن طين، وخُلِقَت ذريته مِن ماء مهين{6}. (١٠/٥٧٢) ٥١٤٥٣- عن قتادة بن دعامة، في قوله: <q>﴿ولقد خلقنا الانسان من سلالة من طين﴾</q>، قال: بَدْءُ آدمَ؛ خُلِق مِن طين{7}. (١٠/٥٧١) ٥١٤٥٤- قال محمد بن السائب الكلبي: مِن نطفة سُلَّتْ مِن طين، والطين آدم ﵇{8}. (ز) ٥١٤٥٥- قال مقاتل بن سليمان: قوله ﷿: <q>﴿ولقد خلقنا الإنسان﴾</q> يعني: آدم ﷺ <q>﴿من سلالة من طين﴾</q> والسلالة: إذا عُصِر الطِّين انسلَّ الطينُ والماءُ مِن بين أصابعه{9}. (ز) ٥١٤٥٦- قال سفيان الثوري، في قوله: <q>﴿لقد خلقنا الإنسان من سلالة﴾</q>: آدم{10}. (ز) ٥١٤٥٧- عن أبي يحيى -من طريق أبي المنهال- في قوله: <q>﴿ولقد خلقنا الإنسان من سلالة من طين﴾</q>، قال: مِن صَفْوة الماء{11}. (ز) ٥١٤٥٨- قال يحيى بن سلّام: قوله: <q>﴿ولقد خلقنا الإنسان من سلالة من طين﴾</q>، قال: والسلالة: النطفة تَنسِل مِن الرجل، وكان بدء ذلك مِن طين؛ خلق الله آدم مِن طين، ثم جعل نسله بعدُ مِن سلالة مِن ماء مهين ضعيف، يعني: النطفة{12}٤٥٢٧. (ز) ٤٥٢٧ اختُلِف في المعنِيِّ بالإنسان في قوله تعالى: <q>﴿ولَقَدْ خَلَقْنا الإنْسانَ﴾</q> على قولين: أحدهما: أنه آدم ﵇، وإنما قيل: <q>﴿مِن سُلالة﴾</q> لأنه استُلَّ من كل الأرض. والثاني: أنه ابن آدم، والسُّلالة: النطفة استُلَّت من الطين، والطين: آدم ﵇. ورجَّح ابنُ جرير (١٧/١٩) مستندًا إلى السياق واللغة القولَ الثاني الذي قاله ابن عباس مِن طريق أبي يحيى، ومجاهد، والكلبي «لدلالة قوله: <q>﴿ثم جعلناه نطفة في قرار مكين﴾</q> على أنّ ذلك كذلك؛ لأنّه معلوم أنّه لم يَصِر في قرار مكين إلا بعد خلقه في صُلْب الفحل، ومِن بعد تَحَوُّلِه مِن صلبه صار في قرار مكين، والعرب تسمي ولد الرجل ونطفته: سليله وسلالته. لأنهما مسلولان منه». وعلَّق ابنُ عطية (٦/٢٨١) على القول الثاني بقوله: «وهذه الفرقة يَتَرَتَّب مع قولها عود الضمير في <q>﴿جعلناه﴾</q>، <q>﴿وأنشأنه﴾</q>». ورجَّح ابنُ كثير (١٠/١١٢) القول الأول مستندًا إلى السياق، ودلالة القرآن، فقال: «وهذا أظهر في المعنى، وأقرب إلى السياق، فإنّ آدم ﵇ خُلِق مِن طين لازب، وهو الصلصال مِن الحمأ المسنون، وذلك مخلوق من التراب، كما قال تعالى: <q>﴿ومن آياته أن خلقكم من تراب ثم إذا أنتم بشر تنتشرون﴾</q> [الروم:٢٠]». ",footnotes:1:عزاه السيوطي إلى ابن المنذر، وابن أبي حاتم. وأخرجه ابن جرير ١٧/١٩، بلفظ: صِفوة الماء. وكلاهما بمعنًى واحد. وهو خيار الشيء وخلاصته وما صفا منه. ينظر: النهاية (صفو).عزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.أخرجه ابن جرير ١٧/١٩، وإسحاق البستي في تفسيره ص٣٨٣ من طريق ابن جريج. وعزاه السيوطي إلى عبد بن حميد.أخرجه إسحاق البستي في تفسيره ص٣٨٩ بلفظ: سل استلالًا. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.عزاه السيوطي إلى ابن أبي حاتم.أخرجه عبد الرزاق ٢/٤٤، وابن جرير ١٧/١٨.عزاه السيوطي إلى عبد بن حميد، وابن أبي حاتم.تفسير البغوي ٥/٤١١.تفسير مقاتل بن سليمان ٣/١٥٣.تفسير الثوري ص٢١٦.أخرجه إسحاق البستي في تفسيره ص٣٨٩.تفسير يحيى بن سلام ١/٣٩٤.
23,13," <q>﴿ثُمَّ جَعَلۡنَـٰهُ نُطۡفَةࣰ فِی قَرَارࣲ مَّكِینࣲ ۝١٣﴾</q> - تفسير ٥١٤٥٩- عن عبد الله بن عباس مرفوعًا: «النُّطْفَة التي يُخلق منها الولد تَرْعُدُ لها الأعضاءُ والعروق كلها، إذا خرجت وقَعَتْ في الرَّحِم»{1}. (١٠/٥٧٢) ٥١٤٦٠- عن عبد الله بن مسعود، قال: إنّ النطفة إذا وقعت في الرَّحِم طارت في كل شعر وظفر، فتمكث أربعين يومًا، ثم تنحدر في الرَّحِم فتكون عَلَقَة{2}. (١٠/٥٧٢) ٥١٤٦١- عن قتادة بن دعامة، في قوله: <q>﴿ولقد خلقنا الانسان من سلالة من طين﴾</q> قال: بدء آدم خلق من طين، <q>﴿ثم جعلناه نطفة﴾</q> قال: ذرية آدم{3}. (١٠/٥٧١) ٥١٤٦٢- قال مقاتل بن سليمان: <q>﴿ثم جعلناه نطفة﴾</q> يعني: ذرية آدم <q>﴿في قرار مكين﴾</q> يعني: الرحم، تمكن النطفة في الرحم{4}. (ز) ٥١٤٦٣- قال يحيى بن سلّام: قوله: <q>﴿ثم جعلناه نطفة في قرار مكين﴾</q> الرحم{5}. (ز) ",footnotes:1:عزاه السيوطي إلى الديلمي بسند واهٍ. موضوع، ذكره الشوكاني في الفوائد المجموعة ص٢٣٨.أخرجه ابن أبي حاتم -كما في جامع العلوم والحكم ١/١١٢-.عزاه السيوطي إلى عبد بن حميد، وابن أبي حاتم.تفسير مقاتل بن سليمان ٣/١٥٣.تفسير يحيى بن سلام ١/٣٩٤.
23,14," <q>﴿ثُمَّ خَلَقۡنَا ٱلنُّطۡفَةَ عَلَقَةࣰ﴾</q> - تفسير ٥١٤٦٤- قال مقاتل بن سليمان: <q>﴿ثم خلقنا النطفة علقة﴾</q>، يقول: تَحَوَّل الماءُ فصار دمًا{1}. (ز) ٥١٤٦٥- قال يحيى بن سلّام: قوله: <q>﴿ثم خلقنا النطفة علقة فخلقنا العلقة مضغة﴾</q>، يكون في بطن أُمِّه نطفة أربعين ليلة، ثم علقة أربعين ليلة، ثم يكون مضغة أربعين ليلة{2}. (ز) <q>﴿فَخَلَقۡنَا ٱلۡعَلَقَةَ مُضۡغَةࣰ﴾</q> - تفسير ٥١٤٦٦- قال مقاتل بن سليمان: <q>﴿فخلقنا العلقة مضغة﴾</q>، يعني: فتَحَوَّل الدمُ فصار لحمًا مثل المضغة{1}. (ز) <q>﴿فَخَلَقۡنَا ٱلۡمُضۡغَةَ عِظَـٰمࣰا فَكَسَوۡنَا ٱلۡعِظَـٰمَ لَحۡمࣰا﴾</q> - قراءات ٥١٤٦٧- عن عبد الله بن عباس أنه كان يقرأ: <q>﴿فَخَلَقْنا المُضْغَةَ عِظامًا﴾</q>{4}. (١٠/٥٧٣) ٥١٤٦٨- عن قتادة بن دعامة أنه كان يقرأ: (فَخَلَقْنا المُضْغَةَ عَظْمًا فَكَسَوْنا العِظامَ لَحْمًا){5}. (١٠/٥٧٣) ٥١٤٦٩- عن عاصم أنه قرأ: ‹فَخَلَقْنا المُضْغَةَ عَظْمًا› بغير ألف، ‹فَكَسَوْنا العَظْمَ› على واحدة{6}. (١٠/٥٧٤) ٥١٤٧٠- قال يحيى بن سلّام: قال: <q>﴿فَخَلَقْنا المُضْغَةَ عِظامًا﴾</q> يعني: جماعة العظام في قراءة مَن قرأها: ‹عَظْمًا›، وهي تقرأ: <q>﴿عِظامًا﴾</q> يعني: جماعة العظام عظمًا عظمًا ...، <q>﴿فَكَسَوْنا العِظامَ﴾</q> وبعضهم يقرأها: ‹العَظْمَ›{2}٤٥٢٨. (ز) ٤٥٢٨ اختُلِف في قراءة قوله: <q>﴿عظاما﴾</q>؛ فقرأها قوم: <q>﴿عظاما﴾</q> في الموضعين، وقرأها آخرون: ‹عَظْمًا›. ورجَّح ابنُ جرير (١٧/٢١) القراءة الأولى مستندًا إلى إجماع القراء، فقال: «والقراءة التي نختار في ذلك الجماع [يعني: قراءة الجمع: <q>﴿عِظامًا﴾</q>]؛ لإجماع الحجة من القرأة عليه». <q>﴿ثُمَّ أَنشَأۡنَـٰهُ خَلۡقًا ءَاخَرَۚ﴾</q> - تفسير ٥١٤٧١- عن علي بن أبي طالب -من طريق زيد بن علي، عن أبيه- قال: إذا نَمَت النطفةُ أربعة أشهر بُعِث إليها ملك، فنفخ فيها الروح في الظلمات الثلاث، فذلك قوله: <q>﴿ثم أنشأناه خلقا آخر﴾</q>، يعني: نفخ الروح فيه{8}. (١٠/٥٧٨) ٥١٤٧٢- عن عبد الله بن عباس، <q>﴿ثم أنشأناه خلقا آخر﴾</q>، قال: الشَّعَر والأسنان{9}. (١٠/٥٧٤) ٥١٤٧٣- عن عبد الله بن عباس -من طريق عطاء- <q>﴿ثم أنشأناه خلقا آخر﴾</q>، قال: نفخ الروح فيه{10}. (١٠/٥٧٤) ٥١٤٧٤- عن عبد الله بن عباس -من طريق عطية العوفي- في قوله: <q>﴿ثم أنشأناه خلقا آخر﴾</q>، يقول: خرج من بطن أمه بعد ما خُلِق، فكان مِن بدء خلقه الآخر أن اسْتَهَلَّ، ثم كان مِن خلقه أن دَلَّه على ثدي أمه، ثم كان مِن خلقه أن علم كيف يبسط رجليه، إلى أن قعد، إلى أن حَبا، إلى أن قام على رجليه، إلى أن مشى، إلى أن فُطِم، فعلم كيف يشرب ويأكل مِن الطعام، إلى أن بلغ الحُلُم، إلى أن بلغ أن يَتَقَلَّب في البلاد{11}. (١٠/٥٧٨) ٥١٤٧٥- عن عبد الله بن عمر: استواء الشباب{12}. (ز) ٥١٤٧٦- عن أبي العالية الرِّياحِيِّ -من طريق الربيع- <q>﴿ثم أنشأناه خلقا آخر﴾</q>، قال: جعل فيه الروح{13}. (١٠/٥٧٤) ٥١٤٧٧- عن مجاهد بن جبر -من طريق ابن جريج-= (ز) ٥١٤٧٨- وعكرمة مولى ابن عباس -من طريق عبد الرحمن بن الأصبهاني-، مثله{14}. (١٠/٥٧٤) ٥١٤٧٩- عن مجاهد بن جبر -من طريق ابن جريج- <q>﴿ثم أنشأناه خلقا آخر﴾</q>، قال: حين استوى به الشباب{15}. (١٠/٥٧٤) ٥١٤٨٠- عن الضحاك بن مزاحم، <q>﴿ثم أنشأناه خلقا آخر﴾</q>، قال: الأسنان والشَّعَر. قيل: أليس قد يُولَد وعلى رأسه الشَّعَر؟ قال: فأين العانة والإبط؟{6}. (١٠/٥٧٥) ٥١٤٨١- عن الضحاك بن مزاحم -من طريق عبيد- <q>﴿ثم أنشأناه خلقا آخر﴾</q>، قال: يُقال: الخلق الآخر بعد خروجه مِن بطن أمه بسِنِّه وشعَره{17}. (ز) ٥١٤٨٢- عن الضحاك بن مزاحم -من طريق عبيد- قال في قوله: <q>﴿ثم أنشأناه خلقا﴾</q>: يعني: الروح، نفخ فيه بعد الخلق{18}. (ز) ٥١٤٨٣- عن عامر الشعبي -من طريق داود بن أبي هند- <q>﴿ثم أنشأناه خلقا آخر﴾</q>، قال: نفخ فيه الروح{19}. (ز) ٥١٤٨٤- قال قتادة: وقال الحسن البصري: الروح{20}. (ز) ٥١٤٨٥- عن قتادة بن دعامة -من طريق سعيد-: <q>﴿ثم أنشأناه خلقا آخر﴾</q>، يقول: أنبت به الشَّعَر.= (ز) ٥١٤٨٦- قال: وقال الحسن: ذكرًا وأنثى{21}. (١٠/٥٧٤) ٥١٤٨٧- عن قتادة بن دعامة -من طريق معمر- <q>﴿ثم أنشأناه خلقا آخر﴾</q>، قال: يقول بعضهم: هو نبات الشَّعَر. وبعضهم يقول: هو نفخ الروح{22}. (١٠/٥٧٩) ٥١٤٨٨- قال محمد بن السائب الكلبي: الروح وهو في بطن أُمِّه{23}. (ز) ٥١٤٨٩- قال مقاتل بن سليمان: <q>﴿فخلقنا المضغة عظاما فكسونا العظام لحما ثم أنشأناه﴾</q> يقول: خلقناه <q>﴿خلقا آخر﴾</q> يعني: الروح، ينفخ فيه بعد خلقه{1}. (ز) ٥١٤٩٠- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿ثم أنشأناه خلقا آخر﴾</q>، قال: الرُّوح الذي جعله فيه{25}٤٥٢٩. (ز) ٤٥٢٩ اختُلِف في الخلق الآخر على أقوال: الأول: نفخ الروح فيه. الثاني: تصريفه إياه في الأحوال بعد الولادة؛ في الطفولة، والكهولة، والاغتذاء، ونبات الشعر، والسن، ونحو ذلك من أحوال الأحياء في الدنيا. الثالث: كمال الشباب. ورجَّح ابنُ جرير (١٧/٢٤-٢٥) مستندًا إلى الدلالات العقلية القولَ الأول الذي قاله علي بن أبي طالب، وابن عباس من طريق عطاء، وعكرمة، والشعبي، ومجاهد، وأبو العالية، والضحاك، وابن زيد، والحسن، والكلبي، ومقاتل، فقال: «وذلك أنه بِنَفْخِ الروحِ فيه يتحول خلقًا آخر إنسانًا، وكان قبل ذلك بالأحوال التي وصفه الله أنه كان بها؛ من نطفة وعلقة ومضغة وعظم، وبنفخ الروح فيه؛ يتحول عن تلك المعاني كلها إلى معنى الإنسانية، كما تَحول أبوه آدم بنفخ الروح في الطينة التي خلق منها إنسانًا وخلقًا آخر غير الطين الذي خُلِق منه». ولم ير ابنُ كثير (١٠/١١٤) منافاة بين هذا القول والقول الثاني الذي قاله ابن عباس من طريق العوفي، وقتادة، والضحاك، فقال: «ولا منافاة؛ فإنه من ابتداء نفخ الروح فيه شرع في هذه التنقلات والأحوال». وساق ابنُ عطية (٦/٢٨٣) الأقوال، ثم انتقد ما فيها من تخصيص، مستندًا إلى دلالة العموم، فقال: «وهذا التخصيص كله لا وجه له، وإنما هو عامٌّ في هذا وغيرِه مِن وجوه النطق والإدراك وحسن المحاولة؛ هو بها آخَرَ، وأول رتبة من كونه آخَرَ هي نفخ الروح فيه، والطرف الآخر من كونه آخَرَ تحصيله المعقولات». <q>﴿ثُمَّ أَنشَأۡنَـٰهُ خَلۡقًا ءَاخَرَۚ﴾</q> - أحكام متعلقة بالآية ٥١٤٩١- عن عبيد بن رفاعة، قال: أفاضوا في ذكر العِزْلِ، وفي القوم عمر وعلي ورفاعة بن رافع، فقالوا: لا بأس. فقال بعضهم: إنّها الموءودة الصغرى. فقال علي بن أبي طالب: إنها لا تكون موءودة حتى تمر بسبع تارات، قال الله تعالى: <q>﴿ولقد خلقنا الإنسان من سلالة من طين* ثم جعلناه نطفة في قرار مكين﴾</q> إلى قوله: <q>﴿فتبارك الله أحسن الخالقين﴾</q>. فتَفَرَّقوا على قول عليٍّ: أنه لا بأس{26}. (١٠/٥٧٣) ٥١٤٩٢- عن مجاهد، قال: سألنا عبد الله بن عباس عن العَزْل. فقال: اذهبوا، فاسألوا الناس، ثم ائتوني وأخبروني. فسألوا، ثم أخبروه أنهم قالوا: إنّها الموءودة الصغرى. وتلا هذه الآية: <q>﴿ولقد خلقنا الانسان من سلالة﴾</q> حتى فرغ منها، ثم قال: كيف تكون مِن الموءودة حتى تَمُرَّ على هذه الخلق؟!{27}. (١٠/٥٧٢) ٥١٤٩٣- عن ابن جريج، قال: قيل لعبد الله بن عباس: إنّ ابن عمر يكره العَزْل. فقرأ: <q>﴿ولقد خلقنا الإنسان من سلالة من طين* ثم جعلناه نطفة في قرار مكين* ثم خلقنا النطفة علقة فخلقنا العلقة مضغة فخلقنا المضغة عظاما فكسونا العظام لحما ثم أنشأناه خلقا آخر﴾</q>، وهل تكون الموؤدة إلا بعد هذا؟!{28}. (ز) ٥١٤٩٤- عن عبد الله بن مسعود -من طريق أبي عمرو الشيباني- قال في العَزْل: هي الموءودة الخَفِيَّة{29}. (١٠/٥٧٣) ٥١٤٩٥- عن علي بن أبي طالب -من طريق محمد بن الحنفية- أنّه سُئِل عن عَزْل النساء. فقال: ذلك الوَأْد الخَفِيِّ{30}. (١٠/٥٧٣) <q>﴿فَتَبَارَكَ ٱللَّهُ أَحۡسَنُ ٱلۡخَـٰلِقِینَ ۝١٤﴾</q> - تفسير ٥١٤٩٦- عن مجاهد بن جبر -من طريق ليث- <q>﴿فتبارك الله أحسن الخالقين﴾</q>، قال: يصنعون، ويصنع الله، واللهُ خير الصانعين{31}. (١٠/٥٧٩) ٥١٤٩٧- عن عبد الملك ابن جُرَيج -من طريق حجاج- <q>﴿فتبارك الله أحسن الخالقين﴾</q>، قال: عيسى ابن مريم يَخْلُقُ{32}. (١٠/٥٧٩) ٥١٤٩٨- قال مقاتل بن سليمان: <q>﴿فتبارك الله أحسن الخالقين﴾</q>، يقول: هو أحسن المُصَوِّرين، يعني: مِن الذين خلقوا التماثيل وغيرها التي لا يتحرك منها شيء{1}. (ز) ٥١٤٩٩- قال يحيى بن سلّام: قال: <q>﴿فتبارك الله﴾</q> وهو من باب البَرَكة، كقوله: <q>﴿فتعالى الله﴾</q>. قوله: <q>﴿أحسن الخالقين﴾</q> إن العباد قد يخلقون، يُشبِّهون بخلق الله، ولا يستطيعون أن ينفخوا فيه الروح ... عن أبي هريرة، قال: قال رسول الله ﷺ: «قال الله: مَن أظلم مِمَّن يخلق كخلقي، فليخلقوا ذبابًا، أو ذَرَّة، أو بعوضة»{34}٤٥٣٠. (ز) ٤٥٣٠ رجَّح ابنُ جرير (١٧/٢٥) مستندًا إلى اللغة القول الذي قاله مجاهد، فقال: «لأنّ العرب تسمي كل صانع: خالقًا». <q>﴿فَتَبَارَكَ ٱللَّهُ أَحۡسَنُ ٱلۡخَـٰلِقِینَ ۝١٤﴾</q> - آثار متعلقة بالآية ٥١٥٠٠- عن زيد بن ثابت، قال: أملى عَلَيَّ رسولُ الله ﷺ هذه الآية: <q>﴿ولقد خلقنا الانسان من سلالة من طين﴾</q> إلى قوله: <q>﴿خلقا آخر﴾</q>. فقال معاذ بن جبل: فتبارك الله أحسن الخالقين. فضحك رسول الله ﷺ، فقال له معاذ: مِمَّ ضحكت، يا رسول الله؟ قال: «بها خُتِمَتْ، <q>﴿فتبارك الله أحسن الخالقين﴾</q>»{35}٤٥٣١. (١٠/٥٨٠) ٤٥٣١ انتقد ابنُ كثير (١٠/١١٦) هذا القول مستندًا إلى أحوال النزول، فقال: «جابر بن يزيد الجعفي ضعيف جدًّا، وفي خبره هذا نكارة شديدة، وذلك أن السورة مكية، وزيد بن ثابت إنما كتب الوحي بالمدينة، وكذلك إسلام معاذ بن جبل إنما كان بالمدينة أيضًا». ٥١٥٠١- عن أنس، قال: قال عمر بن الخطاب: وافقتُ ربي في أربع؛ قلت: يا رسول الله، لو صَلَّينا خلف المقام؟ فأنزل الله: <q>﴿واتخذوا من مقام إبراهيم مصلى﴾</q> [البقرة:١٢٥]. وقلت: يا رسول الله، لو اتخذتَ على نسائك حجابًا؛ فإنّه يدخل عليك البرُّ والفاجر؟ فأنزل الله: <q>﴿واذا سألتموهن متاعا فاسألوهن من وراء حجاب﴾</q> [الأحزاب:٥٣]. وقلت لأزواج النبيِّ ﷺ: لَتَنتَهُنَّ أو لَيُبَدِّلَنَّه الله أزواجًا خيرًا مِنكُنَّ. فأنزلت: <q>﴿عسى ربه إن طلقكن﴾</q> [التحريم:٥] الآية. ونزلت: <q>﴿ولقد خلقنا الانسان من سلالة من طين﴾</q> الآيةَ إلى قوله: <q>﴿ثم أنشأناه خلقا آخر﴾</q>. فقلت أنا: فتبارك الله أحسن الخالقين. فنزلت: <q>﴿فتبارك الله أحسن الخالقين﴾</q>{36}. (١٠/٥٧٩) ٥١٥٠٢- عن عبد الله بن عباس، قال: لَمّا نزلت: <q>﴿ولقد خلقنا الانسان من سلالة من طين﴾</q> إلى آخر الآيةِ قال عمر: فتبارك الله أحسن الخالقين. فنزلت: <q>﴿فتبارك الله أحسن الخالقين﴾</q>{37}. (١٠/٥٨٠) ٥١٥٠٣- عن صالح أبي الخليل، قال: لَمّا نزلت هذه الآية على النبي ﷺ: <q>﴿ولقد خلقنا الانسان من سلالة من طين﴾</q> إلى قوله: <q>﴿ثم أنشأناه خلقا آخر﴾</q>. قال عمر: فتبارك الله أحسن الخالقين. فقال: «والذي نفسي بيده، إنّها خُتِمَت بالذي تكلَّمْتَ به، يا عمر»{38}. (١٠/٥٧٥) ٥١٥٠٤- قال مقاتل بن سليمان: <q>﴿فخلقنا المضغة عظاما فكسونا العظام لحما ثم أنشأناه خلقا آخر﴾</q>، قال عمر بن الخطاب قبل أن يُتِمَّ النبيُّ ﷺ الآية: تبارك الله أحسن الخالقين. فقال النبي ﷺ: «هكذا أُنزِلَت، يا عمر»{1}. (ز) ٥١٥٠٥- عن وهب بن مُنَبِّه، قال: خلق اللهُ ابن آدم كما شاء وبما شاء، فكان كذلك، <q>﴿فتبارك الله أحسن الخالقين﴾</q>، خُلق مِن التراب والماء، فمِنه شعره ولحمه ودمه وعظامه وجسده، فهذا بَدْءُ الخلق الذي خلق الله منه ابنَ آدم، ثم جُعلت فيه النفس، فبها يقوم ويقعد، ويسمع ويُبصِر، ويعلم ما تعلم الدوابُّ، ويَتَّقي ما تَتَّقي، ثم جُعِل فيه الروح، فبِه عُرِف الحقُّ مِن الباطل، والرشد مِن الغي، وبه حذر وتقدم واستتر، وتعلَّم ودَبَّر الأمور كلها، فمِن التراب يبوسته، ومِن الماء رطوبته، فهذا بدء الخلق الذي خلق الله منه ابنَ آدم كما أحبَّ أن يكون، ثم جعل فيه من هذه الفِطَر الأربع، فالأنواع من الخلق أربعة في جسد ابن آدم، فهي قَوام جسده ومَلاكه -بإذن الله-، وهي: المِرَّةُ{40} السوداء، والمرة الصفراء، والدم، والبلغم، فيبوسته وحرارته من النَّفْس، ومسكنها في الدم، وبرودته من قِبَل الروح، ومسكنه في البَلْغَم، فإذا اعتدلت هذه الفِطَر في الجسد فكان من كلِّ واحدٍ ربعٌ كان جسدًا كاملًا وجسمًا صحيحًا، وإن كثر واحد منها على صاحبه علاها وقهرها، وأدخل عليها السقم من ناحيته، وإن قلَّ عنها واحد منها غلبت عليه وقهرته ومالت به، فضعُفت عن قوتِها، وعجزت عن طاقتِها، وأدخل عليها السقم من ناحيته، فالطبيب العالم بالداء والدواء يعلم من الجسد حيث أتى سَقَمُه؛ أمن نقصان أم من زيادة{41}. (١٠/٥٧٧-٥٧٨) ",footnotes:1:تفسير مقاتل بن سليمان ٣/١٥٣.تفسير يحيى بن سلام ١/٣٩٤.تفسير مقاتل بن سليمان ٣/١٥٣.عزاه السيوطي إلى ابن أبي شيبة، وعبد بن حميد، وابن المنذر. و<q>﴿عِظامًا فَكَسَوْنا العِظامَ﴾</q> بكسر العين وفتح الظاء هي قراءة العشرة، ما عدا ابن عامر، وأبا بكر عن عاصم، فإنهما قرآ: ‹عَظْمًا فَكَسَوْنا العَظْمَ› بفتح العين وإسكان الظاء من دون ألف بعدها. انظر: النشر ٢/٣٢٨، والإتحاف ص٤٠٢.عزاه السيوطي إلى ابن أبي شيبة، وابن المنذر.عزاه السيوطي إلى عبد بن حميد.تفسير يحيى بن سلام ١/٣٩٤.أخرجه ابن أبي حاتم -كما في تفسير ابن كثير ٥/٤٦١-.عزاه السيوطي إلى ابن أبي حاتم.أخرجه ابن جرير ١٧/٢٢ كذلك من طريق ابن جريج، وإسحاق البستي في تفسيره ص٣٩١. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه ابن جرير ١٧/٢٣-٢٤.تفسير الثعلبي ٧/٤٢.أخرجه ابن جرير ١٧/٢٣ بلفظ: نفَخ فيه الروح، فهو الخلق الآخر الذي ذكر. وعزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ١٧/٢٣، وإسحاق البستي في تفسيره ص٣٩٠ عن مجاهد من طريق منصور بلفظ: نفخ فيه الروح. وعزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ١٧/٢٤، وإسحاق البستي في تفسيره ص٣٩١، كما أخرجه يحيى بن سلام ١/٣٩٥ من طريق ابن مجاهد، وابن جرير من طريق ابن أبي نجيح. وعزاه السيوطي إلى عبد حميد، وابن المنذر، وابن أبي حاتم.عزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ١٧/٢٤، وإسحاق البستي في تفسيره ص٣٩٢.أخرجه ابن جرير ١٧/٢٣، وإسحاق البستي في تفسيره ص٣٩٢.أخرجه ابن جرير ١٧/٢٢.أخرجه يحيى بن سلام ١/٣٩٥.أخرجه يحيى بن سلام ١/٣٩٥ عن قتادة من طريق سعيد، ومن طريق أبي هلال الراسبي، وعن الحسن من طريق عمرو. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه عبد الرزاق ٢/٤٤، وابن جرير ١٧/٢٤.علَّقه يحيى بن سلام ١/٣٩٥.تفسير مقاتل بن سليمان ٣/١٥٣.أخرجه ابن جرير ١٧/٢٣.أخرجه الطبراني (٤٥٣٦). وهو عند أحمد ٣٥/٢١-٢٣ دون مسألة العزل.أخرجه عبد الرزاق (١٢٥٧٠)، وإسحاق البستي في تفسيره ص٣٩٠ بنحوه. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.أخرجه إسحاق البستي في تفسيره ص٣٨٧.أخرجه عبد الرزاق (١٢٥٨٠).أخرجه عبد الرزاق (١٢٥٧٩).أخرجه ابن جرير ١٧/٢٥.أخرجه ابن جرير ١٧/٢٥. والمعنى -كما قال ابن جرير-: أن عيسى ابن مريم كان يخلق [بإذن الله]، فأخبر -جل ثناؤه- عن نفسه أنه يخلق أحسن مما كان يخلق.تفسير مقاتل بن سليمان ٣/١٥٣.تفسير يحيى بن سلام ١/٣٩٥ واللفظ له. وأخرجه البخاري ٧/١٦٧-١٦٨ (٥٩٥٣)، ٩/١٦١ (٧٥٥٩) بنحوه.أخرجه الطبراني في الأوسط ٥/٥٦ (٤٦٥٧)، وابن أبي حاتم -كما في تفسير ابن كثير ٥/٤٦٩-. قال الهيثمي في المجمع ٧/٧٢ (١١١٨٧): «رواه الطبراني في الأوسط، وفيه جابر الجعفي، وهو ضعيف وقد وُثِّق، وبقية رجاله رجال الصحيح». وقال البوصيري في إتحاف الخيرة ٦/٢٤٧ (٥٧٦٧): «هذا إسناد فيه جابر الجعفي، وهو ضعيف».أخرجه الطيالسي (٤١)، ويحيى بن سلام ١/٣٩٥، وابن أبي حاتم -كما في تفسير ابن كثير ٥/٤٦٣-، وابن عساكر ٤٤/١١٣-١١٤. والحديث عند البخاري (٤٤٨٣) بدون ذكر: <q>﴿فتبارك الله أحسن الخالقين﴾</q>. وعزاه السيوطي إلى ابن مردويه.أخرجه الطبراني (١٢٢٤٤). وعزاه السيوطي إلى أبي نعيم في فضائل الصحابة، وابن مردويه. قال الهيثمي في مجمع الزوائد ٩/٦٨: «فيه أبو عبيدة بن الفضيل بن عياض، وهو لين، وبقية رجاله ثقات».أخرجه ابن شاهين في شرح مذاهب أهل السنة ص١٩٥ (١٣٧). وعزاه السيوطي إلى ابن أبي شيبة، وعبد بن حميد، وابن المنذر.تفسير مقاتل بن سليمان ٣/١٥٣.المِرَّةُ: مزاج من أمزجة البدن، وهي إحدى الطبائع الأربع، تجمع على: مِرَر. التاج (مرر).أخرجه أبو الشيخ في العظمة (١٠٨٠). وعزاه السيوطي إلى ابن أبي حاتم.
23,15," <q>﴿ثُمَّ إِنَّكُم بَعۡدَ ذَ ٰ⁠لِكَ لَمَیِّتُونَ ۝١٥ ثُمَّ إِنَّكُمۡ یَوۡمَ ٱلۡقِیَـٰمَةِ تُبۡعَثُونَ ۝١٦﴾</q> - تفسير ٥١٥٠٦- قال مقاتل بن سليمان: <q>﴿ثم إنكم بعد ذلك﴾</q> الخَلْق؛ بعد ما ذكر مِن تمام خلق الإنسان <q>﴿لميتون﴾</q> عند آجالكم، <q>﴿ثم إنكم﴾</q> بعد الموت <q>﴿يوم القيامة تبعثون﴾</q> يعني: تَحْيَوْن بعد الموت{1}. (ز) ٥١٥٠٧- قال يحيى بن سلّام: قوله: <q>﴿ثم إنكم بعد ذلك﴾</q> بعدما ينفخ فيه الروح <q>﴿لميتون﴾</q> إذا جاء أجله، <q>﴿ثم إنكم يوم القيامة تبعثون﴾</q>{2}. (ز) ",footnotes:1:تفسير مقاتل بن سليمان ٣/١٥٣.تفسير يحيى بن سلام ١/٣٩٦.
  23,16,""
23,17," <q>﴿وَلَقَدۡ خَلَقۡنَا فَوۡقَكُمۡ سَبۡعَ طَرَاۤىِٕقَ﴾</q> - تفسير ٥١٥٠٨- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿ولقد خلقنا فوقكم سبع طرائق﴾</q>، قال: السموات السبع{1}. (١٠/٥٨٠) ٥١٥٠٩- قال مقاتل بن سليمان: <q>﴿ولقد خلقنا فوقكم سبع طرآئق﴾</q>، يعني: سموات، غلظ كل سماء مسيرة خمسمائة عام، وبين كل سماء مسيرة خمسمائة عام{2}. (ز) ٥١٥١٠- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قول الله: <q>﴿ولقد خلقنا فوقكم سبع طرائق﴾</q>، قال: الطرائق: السماوات{3}. (ز) ٥١٥١١- عن سفيان بن عيينة -من طريق ابن أبي عمر- في قوله: <q>﴿سبع طرائق﴾</q>، قال: سبع سموات{4}. (ز) ٥١٥١٢- قال يحيى بن سلّام: طبقة طبقة، بعضها فوق بعض، كقوله: <q>﴿ألم تروا كيف خلق الله سبع سموات طباقا﴾</q> [نوح:١٥] طبقة [طبقة]، بعضها فوق بعض{5}. (ز) <q>﴿وَمَا كُنَّا عَنِ ٱلۡخَلۡقِ غَـٰفِلِینَ ۝١٧﴾</q> - تفسير ٥١٥١٣- قال الحسن البصري: <q>﴿وما كنّا عن الخلق غافلين﴾</q> أن ينزِل عليهم ما يُحييهم مِن المطر{6}. (ز) ٥١٥١٤- عن قتادة بن دعامة، في قوله: <q>﴿وما كنا عن الخلق غافلين﴾</q>، قال: لو كان الله مُغْفِلًا شيئًا أغفل ما تُعْفِي الرياح مِن هذه الآثار. يعني: الخُطا{7}. (١٠/٥٨١) ٥١٥١٥- قال مقاتل بن سليمان: <q>﴿وما كنا عن الخلق غافلين﴾</q>، يعني: عن خلق السماء وغيره{2}. (ز) ٥١٥١٦- قال يحيى بن سلّام: قوله: <q>﴿وما كنا عن الخلق غافلين﴾</q> أن ننزل عليهم ما يُحْيِيهم، وما يُصْلِحهم مِن هذا المطر{5}. (ز) ",footnotes:1:أخرجه أبو الشيخ (٥٦٠)، وإسحاق البستي في تفسيره ص٣٩٢ من طريق ابن جريج. وعلَّقه يحيى بن سلام ١/٣٩٦. وعزاه السيوطي إلى ابن أبي شيبة، وابن المنذر، وابن أبي حاتم.تفسير مقاتل بن سليمان ٣/١٥٣.أخرجه ابن جرير ١٧/٢٧.أخرجه ابن عيينة في تفسيره -كما في الفتح ٨/٤٤٥-، وإسحاق البستي في تفسيره ص٣٩٢. وعلقه البخاري ٤/١٧٦٩.تفسير يحيى بن سلام ١/٣٩٦.تفسير الثعلبي ٧/٤٣.عزاه السيوطي إلى ابن أبي حاتم.تفسير مقاتل بن سليمان ٣/١٥٣.تفسير يحيى بن سلام ١/٣٩٦.
