tafsir[9]{c,v,t}:
29,15," <q>﴿فَأَنجَیۡنَـٰهُ وَأَصۡحَـٰبَ ٱلسَّفِینَةِ﴾</q> - تفسير ٥٩٦٧٠- عن عبد الله بن عباس -من طريق عكرمة- قال: كان مع نوح في السفينة ثمانون رجلًا معهم أهلوهم، وأنهم كانوا في السفينة مائة وخمسين يومًا{1}. (ز) ٥٩٦٧١- عن مجاهد بن جبر -من طريق يونس بن خباب- في قوله: <q>﴿فأنجيناه وأصحاب السفينة﴾</q>، قال: كانوا سبعة: نوح، وثلاثة بنيه، ونساء بنيه{2}. (١١/٥٣٨) ٥٩٦٧٢- عن محمد بن السائب الكلبي -من طريق معمر-: يذكر أنهم كانوا ثلاثين أو نحو ذلك{3}. (ز) ٥٩٦٧٣- قال مقاتل بن سليمان: <q>﴿فأنجيناه﴾</q> يعني: نوحًا ﵇، <q>﴿وأصحاب السفينة﴾</q> مِن الغرق{4}. (ز) ٥٩٦٧٤- قال يحيى بن سلّام: قال الله: <q>﴿فأنجيناه﴾</q> يعني: نوحًا، <q>﴿وأصحاب السفينة﴾</q> يعني: مَن كان مع نوح في السفينة{5}. (ز) <q>﴿وَجَعَلۡنَـٰهَاۤ ءَایَةࣰ لِّلۡعَـٰلَمِینَ ۝١٥﴾</q> - تفسير ٥٩٦٧٥- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿وجعلناها آية للعالمين﴾</q>، قال: أبقاها الله آية، فهي على الجودِيِّ، <q>﴿للعالمين﴾</q>، أي: للناس {6}٥٠٣٠. (١١/٥٣٩) ٥٠٣٠ لم يذكر ابنُ جرير (١٨/٣٧٢) غير قول قتادة، وبيّن أن الآية تحتمل وجهًا آخر، فقال: «ولو قيل: معنى: <q>﴿وجعلناها آية للعالمين﴾</q>: وجعلنا عقوبتنا إياهم آية للعالمين، وجعل الهاء والألف في قوله: <q>﴿وجعلناها﴾</q> كناية عن العقوبة أو السخط، ونحو ذلك، إذ كان قد تقدم ذلك في قوله: <q>﴿فأخذهم الطوفان وهم ظالمون﴾</q> كان وجهًا من التأويل». وزاد ابنُ عطية (٤/٣١٠) وجهًا ثالثًا، فقال: «ويحتمل أن يعود على النجاة». وقال ابنُ كثير (١٠/٤٩٩): «وقوله: <q>﴿وجعلناها آية للعالمين﴾</q> أي: وجعلنا تلك السفينة باقية؛ إما عينها، كما قال قتادة: إنها بقيت إلى أول الإسلام على جبل الجودي. أو نوعها جعله للناس تذكرة لنِعَمِه على الخلق، كيف نجّاهم من الطوفان، كما قال تعالى: <q>﴿وآية لهم أنا حملنا ذريتهم في الفلك المشحون. وخلقنا لهم من مثله ما يركبون. وإن نشأ نغرقهم فلا صريخ لهم ولا هم ينقذون. إلا رحمة منا ومتاعا إلى حين﴾</q> [يس:٤١-٤٤]». ٥٩٦٧٦- عن قتادة بن دعامة -من طريق سعيد- قال: أبقاها الله بِباقِرْدى{7} من أرض الجزيرة، حتى أدركها أوائلُ هذه الأمة، وكم من سفينة كانت بعدها فصارت رَمْدَدًا{8}{9}. (ز) ٥٩٦٧٧- تفسير إسماعيل السُّدِّيّ: قال الله: <q>﴿وجعلناها آية﴾</q> يعني: عبرة <q>﴿للعالمين﴾</q>{10}. (ز) ٥٩٦٧٨- قال مقاتل بن سليمان: <q>﴿وجعلناها﴾</q> يعني: السفينة <q>﴿آيةً للعالمين﴾</q> يعني: لِمَن بعدهم مِن الناس{4}. (ز) ٥٩٦٧٩- قال يحيى بن سلّام: بلغني: أنهم كانوا يجدون مِن مساميرها بعدما بُعِث النبيُّ ﵇{9}. (ز) ",footnotes:1:أخرجه ابن أبي حاتم ٩/٣٠٤٣.أخرجه عبد الرزاق في تفسيره ٢/٩٩. وعزاه السيوطي إلى ابن المنذر.أخرجه عبد الرزاق في تفسيره ٢/٩٩.تفسير مقاتل بن سليمان ٣/٣٧٧.تفسير يحيى بن سلّام ٢/٦٢١.أخرجه ابن جرير ١٨/٣٧٢، وابن أبي حاتم ٩/٣٠٤٣. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.باقردى: بكسر القاف في الكتب، وأهلها يفتحونها، كورة من ناحية جزيرة ابن عمر في شرقي دجلة قرب جبل الجودي. معجم البلدان (باقردى)، و(بازبدى).رِمدِد: هالكة. لسان العرب (رمد).تفسير يحيى بن سلّام ٢/٦٢٢.علَّقه يحيى بن سلّام ٢/٦٢١.تفسير مقاتل بن سليمان ٣/٣٧٧.تفسير يحيى بن سلّام ٢/٦٢٢.
29,16," <q>﴿وَإِبۡرَ ٰ⁠هِیمَ إِذۡ قَالَ لِقَوۡمِهِ ٱعۡبُدُوا۟ ٱللَّهَ وَٱتَّقُوهُۖ﴾</q> - تفسير ٥٩٦٨٠- تفسير إسماعيل السُّدِّيّ: في قوله: <q>﴿واتقوه﴾</q>، يقول: واخشوه{1}. (ز) ٥٩٦٨١- قال مقاتل بن سليمان: <q>﴿وإبراهيم إذ قال لقومه اعبدوا الله﴾</q> يعني: وحِّدوا الله، <q>﴿واتقوه﴾</q> يعني: واخشوه{2}. (ز) ٥٩٦٨٢- قال يحيى بن سلّام: <q>﴿وإبراهيم﴾</q> أي: وأرسلنا إبراهيم إلى قومه. وهذا تَبَعٌ للكلام الأول لقوله في نوح: <q>﴿ولقد أرسلنا نوحا إلى قومه﴾</q>، قال: <q>﴿إذ قال لقومه اعبدوا الله﴾</q> يعني: وحِّدوا الله{3}. (ز) <q>﴿ذَ ٰ⁠لِكُمۡ خَیۡرࣱ لَّكُمۡ إِن كُنتُمۡ تَعۡلَمُونَ ۝١٦﴾</q> - تفسير ٥٩٦٨٣- عن سعيد بن جبير -من طريق عطاء- في قول الله: <q>﴿خير لكم﴾</q>، يعني: أفضل لكم{4}. (ز) ٥٩٦٨٤- قال مقاتل بن سليمان: <q>﴿ذلكم﴾</q> يعني: عبادة الله <q>﴿خيرٌ لكم﴾</q> مِن عبادة الأوثان، <q>﴿إن كنتم تعلمون﴾</q> ولكنكم لا تعلمون{2}. (ز) ",footnotes:1:علقه يحيى بن سلّام ٢/٦٢٢.تفسير مقاتل بن سليمان ٣/٣٧٧.تفسير يحيى بن سلّام ٢/٦٢٢.أخرجه ابن أبي حاتم ٩/٣٠٤٣.تفسير مقاتل بن سليمان ٣/٣٧٧.
29,17," <q>﴿إِنَّمَا تَعۡبُدُونَ مِن دُونِ ٱللَّهِ أَوۡثَـٰنࣰا وَتَخۡلُقُونَ إِفۡكًاۚ إِنَّ ٱلَّذِینَ تَعۡبُدُونَ مِن دُونِ ٱللَّهِ لَا یَمۡلِكُونَ لَكُمۡ رِزۡقࣰا فَٱبۡتَغُوا۟ عِندَ ٱللَّهِ ٱلرِّزۡقَ وَٱعۡبُدُوهُ وَٱشۡكُرُوا۟ لَهُۥۤۖ إِلَیۡهِ تُرۡجَعُونَ ۝١٧﴾</q> - قراءات ٥٩٦٨٥- عن الأعمش: في قراءة عبد الله [بن مسعود]: (إنَّما اتَّخَذْتُم مِّن دُونِ اللَّهِ أوْثانًا وتَخْلُقُونَ إفْكًا){1}. (ز) ٥٩٦٨٦- عن أبي عبد الرحمن السلمي أنه قرأ: (وتَخَلَّقُونَ إفْكًا) بفتح الخاء وتشديد اللام، مِن التخلُّق{2}٥٠٣١. (ز) ٥٠٣١ علّق ابنُ عطية (٦/٦٣٣) على هذه القراءة فقال: «والإفك على هذه القراءة: الكذب». ٥٩٦٨٧- عن عاصم بن أبي النجود أنه قرأ: <q>﴿وتَخْلُقُونَ إفْكًا﴾</q> خفيفتين{3}٥٠٣٢. (١١/٥٤٠) ٥٠٣٢ نسب ابنُ جرير (١٨/٣٧٥) قراءة التخفيف إلى جميع قراء الأمصار، ورجّحها مستندًا لإجماع الحجة من القراء بقوله: «والصواب من القراءة في ذلك عندنا ما عليه قراء الأمصار؛ لإجماع الحُجَّة مِن القُرّاء عليه». <q>﴿إِنَّمَا تَعۡبُدُونَ مِن دُونِ ٱللَّهِ أَوۡثَـٰنࣰا﴾</q> - تفسير ٥٩٦٨٨- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿إنما تعبدون من دون الله أوثانا﴾</q>، قال: أصنامًا{4}. (١١/٥٣٩) ٥٩٦٨٩- قال مقاتل بن سليمان: <q>﴿إنما تعبدون من دون الله أوثانًا﴾</q>، يعني: أصنامًا{5}. (ز) <q>﴿وَتَخۡلُقُونَ إِفۡكًاۚ﴾</q> - تفسير ٥٩٦٩٠- عن عبد الله بن عباس -من طريق علي بن أبي طلحة- في قوله: <q>﴿وتخلقون إفكا﴾</q>، قال: تصنعون كذِبًا{6}. (١١/٥٣٩) ٥٩٦٩١- عن مجاهد بن جبر -من طريق ابن أبي نجيح-، مثله{7}. (١١/٥٣٩) ٥٩٦٩٢- وعن الحسن البصري= (ز) ٥٩٦٩٣- وعكرمة مولى ابن عباس، مثل ذلك{8}. (ز) ٥٩٦٩٤- عن عبد الله بن عباس -من طريق عطاء الخراساني- في قوله: <q>﴿وتخلقون إفكا﴾</q>، قال: تنحتون، تُصَوِّرون إفكًا{9}. (ز) ٥٩٦٩٥- عن عبد الله بن عباس -من طريق عطية العوفي- <q>﴿وتخلقون إفكا﴾</q>، يقول: وتقولون إفكًا{10}. (ز) ٥٩٦٩٦- وعن إسماعيل السُّدِّيّ، مثل ذلك{11}. (ز) ٥٩٦٩٧- عن عبد الله بن عباس -من طريق علي بن أبي طلحة- في قوله: <q>﴿وتخلقون إفكا﴾</q>، يقول: وتَضَعُون{12}. (ز) ٥٩٦٩٨- وعن قتادة بن دعامة، مثل ذلك{8}. (ز) ٥٩٦٩٩- عن مجاهد بن جبر: <q>﴿وتخلقون إفكا﴾</q>، يقول: كذِبًا{14}. (ز) ٥٩٧٠٠- قال مجاهد بن جبر: تصنعون أصنامًا بأيديكم، فتسمونها آلهة{15}. (ز) ٥٩٧٠١- عن الحسن البصري -من طريق معمر- في قوله: <q>﴿وتخلقون إفكا﴾</q>، قال: تنحتون{16}. (١١/٥٣٩) ٥٩٧٠٢- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿وتخلقون إفكا﴾</q>، قال: تصنعون أصنامًا{17}. (١١/٥٣٩) ٥٩٧٠٣- عن قتادة بن دعامة -من طريق سعيد- <q>﴿وتخلقون إفكا﴾</q>: تُصَوِّرون، وتَكْذِبون{18}. (ز) ٥٩٧٠٤- تفسير إسماعيل السُّدِّيّ: <q>﴿وتخلقون إفكا﴾</q>، يعني: تَخْرُصون كذبًا{14}. (ز) ٥٩٧٠٥- عن عطاء الخراساني -من طريق يونس بن يزيد- في قول الله ﷿: <q>﴿وتخلقون إفكا﴾</q>، قال: تنحتون وتُصَوِّرون إفكًا{20}. (ز) ٥٩٧٠٦- قال مقاتل بن سليمان: <q>﴿وتخلقون إفكًا﴾</q>، يعني: تعملونها بأيديكم، ثم تزعمون أنها آلهة كذبًا وأنتم تنحتونها، فذلك قوله ﷿: <q>﴿واللَّهُ خَلَقَكُمْ وما تَعْمَلُونَ﴾</q> [الصافات:٩٦] بأيديكم من الأصنام{5}. (ز) ٥٩٧٠٧- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿وتخلقون إفكا﴾</q>: الأوثان التي ينحتونها بأيديهم{9}. (ز) ٥٩٧٠٨- قال يحيى بن سلّام: <q>﴿وتخلقون﴾</q> قال: أي: وتصنعون <q>﴿إفكا﴾</q> يعني: كذبًا، كقوله: <q>﴿أتَعْبُدُونَ ما تَنْحِتُونَ﴾</q> [الصافات:٩٥]{23}٥٠٣٣. (ز) ٥٠٣٣ اختلف السلف في تفسير قوله: <q>﴿وتخلقون إفكا﴾</q> على أقوال: الأول: وتصنعون كذبًا. الثاني: وتقولون كذبًا. الثالث: وتنحتون إفكًا. وقد رجّح ابنُ جرير (١٨/٣٧٤) القول الأول، فقال: «وأولى الأقوال في ذلك بالصواب قولُ مَن قال: معناه: وتصنعون كذبًا». ولم يذكر مستندًا. <q>﴿إِنَّ ٱلَّذِینَ تَعۡبُدُونَ مِن دُونِ ٱللَّهِ لَا یَمۡلِكُونَ لَكُمۡ رِزۡقࣰا﴾</q> - تفسير ٥٩٧٠٩- عن قتادة بن دعامة -من طريق سعيد- قوله: <q>﴿إن الذين تعبدون من دون الله﴾</q> هذا الوَثَن، وهذا الحَجَر{12}. (ز) ٥٩٧١٠- قال مقاتل بن سليمان: قال سبحانه: <q>﴿إن الذين تعبدون من دون الله﴾</q> مِن الآلهة <q>﴿لا يملكون﴾</q> يقول: لا يقدرون <q>﴿لكم رزقًا﴾</q> على رزق{5}. (ز) <q>﴿فَٱبۡتَغُوا۟ عِندَ ٱللَّهِ ٱلرِّزۡقَ وَٱعۡبُدُوهُ وَٱشۡكُرُوا۟ لَهُۥۤۖ إِلَیۡهِ تُرۡجَعُونَ ۝١٧﴾</q> - تفسير ٥٩٧١١- عن قتادة بن دعامة -من طريق سعيد- قال: كرامةً أكرمكم الله بها، فاشكروا لله نِعَمَه{12}. (ز) ٥٩٧١٢- قال مقاتل بن سليمان: <q>﴿فابتغوا عند الله الرزق واعبدوه﴾</q> يعني: وحِّدوه، <q>﴿واشكروا له﴾</q> واشكروا اللهَ في النِّعَم، فإنّ مصيركم إليه، فذلك قوله تعالى: <q>﴿إليه ترجعون﴾</q> أحياءً بعد الموت{5}. (ز) ٥٩٧١٣- قال يحيى بن سلّام، في قوله: <q>﴿إن الذين تعبدون من دون الله لا يملكون لكم رزقا فابتغوا عند الله الرزق﴾</q>: فإنّ هذه الأوثان لا تملك لكم رزقًا <q>﴿واعبدوه واشكروا له﴾</q> أي: فابتغوا عند الله الرزق؛ بأن تعبدوه وتشكروه؛ يرزقكم، <q>﴿إليه ترجعون﴾</q> يوم القيامة{23}. (ز) <q>﴿فَٱبۡتَغُوا۟ عِندَ ٱللَّهِ ٱلرِّزۡقَ وَٱعۡبُدُوهُ وَٱشۡكُرُوا۟ لَهُۥۤۖ إِلَیۡهِ تُرۡجَعُونَ ۝١٧﴾</q> - آثار متعلقة بالآية ٥٩٧١٤- عن جبلة بن سحيمٍ، قال: سألتُ عبد الله بن عمر عن صلاة المريض على العود؟ قال: لا آمركم أن تتخذوا مِن دون الله أوثانًا، إن استطعت أن تُصَلِّي قائمًا، وإلا فقاعدًا، وإلا فمضطجعًا{29}. (١١/٥٤٠) ٥٩٧١٥- عن محمد بن كعب القرظي -من طريق موسى بن عبيدة- قال: إنّ كل عملٍ عُمِلَ لله فهو شُكْرٌ لأَنْعُمِ الله{12}. (ز) ",footnotes:1:أخرجه ابن أبي داود في المصاحف ١/٣٢٨. والقراءة شاذة.علقه ابن جرير ١٨/٣٧٥. وهي قراءة شاذة، تروى أيضًا عن زيد بن علي. انظر: المحتسب ٢/١٦٠، ومختصر ابن خالويه ص١١٦.عزاه السيوطي إلى عبد بن حميد. وهي قراءة العشرة.أخرجه ابن جرير ١٨/٣٧٣، وابن أبي حاتم ٩/٣٠٤٣. وعزاه السيوطي إلى عبد بن حميد.تفسير مقاتل بن سليمان ٣/٣٧٧.أخرج ابن جرير ١٨/٣٧٣، وابن أبي حاتم ٩/٣٠٤٤. وعزاه السيوطي إلى ابن المنذر.عزاه السيوطي إلى الفريابي. وأخرجه ابن جرير ١٨/٣٧٤ بلفظ: تقولون كذبًا. وكذلك إسحاق البستي في تفسيره ص٦٩ من طريق ابن جريج.علقه ابن أبي حاتم ٩/٣٠٤٤.أخرجه ابن جرير ١٨/٣٧٤.أخرجه ابن جرير ١٨/٣٧٤، وابن أبي حاتم ٩/٣٠٤٤.علَّقه ابن أبي حاتم ٩/٣٠٤٤.أخرجه ابن أبي حاتم ٩/٣٠٤٤.علقه ابن أبي حاتم ٩/٣٠٤٤.علقه يحيى بن سلّام في تفسيره ٢/٦٢٢.تفسير الثعلبي ٧/٢٧٤، وتفسير البغوي ٦/٢٣٦.أخرجه عبد الرزاق في تفسيره ٢/٩٦. وعزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ١٨/٣٧٣-٣٧٤. وعزاه السيوطي إلى عبد بن حميد.أخرجه الحربي في غريب الحديث ١/٢٥.علقه يحيى بن سلّام في تفسيره ٢/٦٢٢.أخرجه أبو جعفر الرملي في جزئه (تفسير عطاء الخراساني) ص١٠٠، وأخرجه ابن أبي حاتم ٩/٣٠٤٤ من طريق عثمان بن عطاء بلفظ: وتصورون إفكًا.تفسير مقاتل بن سليمان ٣/٣٧٧.أخرجه ابن جرير ١٨/٣٧٤.تفسير يحيى بن سلّام ٢/٦٢٢.أخرجه ابن أبي حاتم ٩/٣٠٤٤.تفسير مقاتل بن سليمان ٣/٣٧٧.أخرجه ابن أبي حاتم ٩/٣٠٤٤.تفسير مقاتل بن سليمان ٣/٣٧٧.تفسير يحيى بن سلّام ٢/٦٢٢.أخرجه ابن أبي شيبة ١/٢٧٣.أخرجه ابن أبي حاتم ٩/٣٠٤٤.
29,18," <q>﴿وَإِن تُكَذِّبُوا۟ فَقَدۡ كَذَّبَ أُمَمࣱ مِّن قَبۡلِكُمۡۖ﴾</q> - تفسير ٥٩٧١٦- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿وإن تكذبوا فقد كذب أمم من قبلكم﴾</q>، قال: يُعَزِّي نبيَّه ﷺ{1}٥٠٣٤. (ز) ٥٠٣٤ علّق ابنُ كثير (١٠/٥٠١) على قول قتادة، فقال: «وهذا مِن قتادة يقتضي أنّه قد انقطع الكلام الأول، واعترض بهذا إلى قوله: <q>﴿فما كان جواب قومه﴾</q>». ثم رجّح مستندًا إلى السياق أنه من كلام إبراهيم ﵇، فقال: «والظاهر من السياق أنّ كل هذا من كلام إبراهيم الخليل ﵇، يحتج عليهم لإثبات المعاد؛ لقوله بعد هذا كله: <q>﴿فما كان جواب قومه﴾</q>». ٥٩٧١٧- قال مقاتل بن سليمان: <q>﴿وإن تكذبوا﴾</q> يعني: كفار مكة يكذبوا محمدًا ﷺ بالعذاب وبالبعث؛ <q>﴿فقد كذب أممٌ من قبلكم﴾</q> يعني: مِن قبل كفار مكة كذَّبوا رسلهم بالعذاب{2}. (ز) ٥٩٧١٨- قال يحيى بن سلّام، في قوله: <q>﴿وإن تكذبوا فقد كذب أمم من قبلكم﴾</q>: أي: فأهلكهم الله، يحذرهم أن ينزل بهم ما نزل بهم إن لم يؤمنوا{3}. (ز) <q>﴿وَمَا عَلَى ٱلرَّسُولِ إِلَّا ٱلۡبَلَـٰغُ ٱلۡمُبِینُ ۝١٨﴾</q> - تفسير ٥٩٧١٩- عن سعيد بن جبير -من طريق عطاء- <q>﴿المبين﴾</q>: يعني: البيِّن{1}. (ز) ٥٩٧٢٠- قال مقاتل بن سليمان: <q>﴿وما على الرسول إلا البلاغ المبين﴾</q>، يقول: وما على النبي ﷺ إلا أن يُبَيِّن لكم أمرَ العذاب{2}. (ز) ٥٩٧٢١- قال يحيى بن سلّام: <q>﴿وما على الرسول إلا البلاغ المبين﴾</q>، ليس عليه أن يكره الناس على الإيمان، كقوله: <q>﴿ولو شاء ربك لآمن من في الأرض كلهم جميعا أفأنت تكره الناس حتى يكونوا مؤمنين﴾</q> [يونس:٩٩]، أي: إنك لا تستطيع أن تكرههم، وإنما يؤمن مَن أراد الله أن يؤمن. وكقوله: <q>﴿إنك لا تهدي من أحببت ولكن الله يهدي من يشاء﴾</q> [القصص:٥٦]{3}. (ز) ",footnotes:1:أخرجه ابن أبي حاتم ٩/٣٠٤٥.تفسير مقاتل بن سليمان ٣/٣٧٧.تفسير يحيى بن سلّام ٢/٦٢٣.أخرجه ابن أبي حاتم ٩/٣٠٤٥.تفسير مقاتل بن سليمان ٣/٣٧٧.تفسير يحيى بن سلّام ٢/٦٢٣.
29,19," <q>﴿أَوَلَمۡ یَرَوۡا۟ كَیۡفَ یُبۡدِئُ ٱللَّهُ ٱلۡخَلۡقَ ثُمَّ یُعِیدُهُۥۤۚ﴾</q> - تفسير ٥٩٧٢٢- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿كيف يبدئ الله الخلق ثم يعيده﴾</q>، قال: يبعثه{1}٥٠٣٥. (١١/٥٣٩) ٥٠٣٥ لم يذكر ابنُ جرير (١٨/٣٧٧) غير قول قتادة. ٥٩٧٢٣- عن الربيع بن أنس -من طريق أبي جعفر- في قوله: <q>﴿أولم يروا كيف يبدئ الله الخلق ثم يعيده﴾</q>: قَدِّروا كيف يُبْدِئ الله الخلق؛ خلق أنفسهم، ثم يعيدهم إلى التراب{2}. (ز) ٥٩٧٢٤- قال مقاتل بن سليمان: <q>﴿أولم يروا كيف يبدئ الله الخلق ثم يعيده﴾</q> كما خلقهم، يقول: أوَلَم يعلم كفار مكة كيف بدأ الله ﷿ خلق الإنسان من نطفة، ثم من علقة، ثم من مضغة، ثم عظامًا، ثم لحمًا، ولم يكونوا شيئًا، ثم هلكوا، ثم يعيدهم في الآخرة{3}. (ز) ٥٩٧٢٥- قال يحيى بن سلّام: <q>﴿أولم يروا كيف يبدئ الله الخلق﴾</q>، بلى قد رأوا أنّ الله تبارك وتعالى خلق العباد. قال: <q>﴿ثم يعيده﴾</q> يعني: البعث، يخبر أنه يبعث العباد، والمشركون على خلاف ذلك، لا يُقِرُّون بالبعث{4}. (ز) <q>﴿إِنَّ ذَ ٰ⁠لِكَ عَلَى ٱللَّهِ یَسِیرࣱ ۝١٩﴾</q> - تفسير ٥٩٧٢٦- عن عبد الله بن عباس -من طريق سعيد بن جبير- في قوله: <q>﴿يسير﴾</q>: يعني: هيِّنًا{2}. (ز) ٥٩٧٢٧- قال مقاتل بن سليمان: <q>﴿إن ذلك على الله يسيرٌ﴾</q>، يقول: إعادتهم في الآخرة على الله ﷿ هيِّن{3}. (ز) ٥٩٧٢٨- قال يحيى بن سلّام: <q>﴿إن ذلك على الله يسير﴾</q> خلقُهم وبعثُهم{4}. (ز) ",footnotes:1:أخرجه ابن جرير ١٨/٣٧٧، وابن أبي حاتم ٩/٣٠٤٥. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه ابن أبي حاتم ٩/٣٠٤٥.تفسير مقاتل بن سليمان ٣/٣٧٨.تفسير يحيى بن سلّام ٢/٦٢٣.أخرجه ابن أبي حاتم ٩/٣٠٤٥.تفسير مقاتل بن سليمان ٣/٣٧٨.تفسير يحيى بن سلّام ٢/٦٢٣.
29,20," <q>﴿قُلۡ سِیرُوا۟ فِی ٱلۡأَرۡضِ فَٱنظُرُوا۟ كَیۡفَ بَدَأَ ٱلۡخَلۡقَۚ﴾</q> - تفسير ٥٩٧٢٩- عن الحسن البصري -من طريق عباد بن منصور- أنه سئل عن قوله: <q>﴿سيروا في الأرض﴾</q>، فقال: لم يسيروا في الأرض{1}. (ز) ٥٩٧٣٠- عن قتادة بن دعامة -من طريق سعيد- وفي قوله: <q>﴿فانظروا كيف بدأ الخلق﴾</q>، قال: خلق السموات والأرض{2}. (١١/٥٣٩) ٥٩٧٣١- عن الربيع بن أنس -من طريق أبي جعفر- قوله: <q>﴿أولم يروا كيف يبدئ الله الخلق ثم يعيده﴾</q>، قال: خلق أنفسهم ثم يعيدهم إلى التراب، ثم قد ساروا في الأرض، فرأوا كيف يبدئ الله الخلق في قرون قد أتوا عليها قد هلكوا{1}. (ز) ٥٩٧٣٢- قال مقاتل بن سليمان: ثم قال للنبي ﷺ: <q>﴿قل﴾</q> لهم: <q>﴿سيروا في الأرض﴾</q>؛ ليعتبروا في أمر البعث <q>﴿فانظروا كيف بدأ الخلق﴾</q>، يعني: خلق السموات والأرض وما فيها من الخلق؛ لأنهم يعلمون أن الله ﷿ خلق الأشياء كلها{4}. (ز) ٥٩٧٣٣- قال يحيى بن سلّام: ثم قال للنبي ﵇: <q>﴿قل﴾</q> لهم: <q>﴿سيروا في الأرض فانظروا كيف بدأ الخلق﴾</q> حيثما ساروا؛ رأوا خلق الله الذي خلق{5}. (ز) <q>﴿ثُمَّ ٱللَّهُ یُنشِئُ ٱلنَّشۡأَةَ ٱلۡـَٔاخِرَةَۚ إِنَّ ٱللَّهَ عَلَىٰ كُلِّ شَیۡءࣲ قَدِیرࣱ ۝٢٠﴾</q> - تفسير ٥٩٧٣٤- عن عبد الله بن عباس -من طريق عطية العوفي- في قوله: <q>﴿النشأة الآخرة﴾</q>، قال: هي الحياة بعد الموت، وهو النشور{6}. (١١/٥٤١) ٥٩٧٣٥- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿ثم الله ينشئ النشأة الآخرة﴾</q>، قال: البعث بعد الموت{2}. (١١/٥٣٩) ٥٩٧٣٦- قال مقاتل بن سليمان: <q>﴿ثم﴾</q> إن <q>﴿الله ينشئ النشأة الآخرة﴾</q>، يعني: بعد الخلق الأول، يقول: هكذا يخلق الخلق الآخر، يعني: البعث بعد الموت كما بدأ الخلق الأول، إنما ذكر النشأة الآخرة؛ لأنها بعد الخلق الأول، <q>﴿إن الله على كل شيءٍ﴾</q> من البعث وغيره <q>﴿قديرٌ﴾</q>{4}. (ز) ٥٩٧٣٧- قال يحيى بن سلّام: <q>﴿ثم الله ينشئ﴾</q> يخلق <q>﴿النشأة الآخرة﴾</q> الخلق الآخر، يعني: البعث، أي: أنه خلقهم، وأنه يبعثهم{5}. (ز) ",footnotes:1:أخرجه ابن أبي حاتم ٩/٣٠٤٦.أخرجه ابن جرير ١٨/٣٧٧، وابن أبي حاتم ٩/٣٠٤٦. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه ابن أبي حاتم ٩/٣٠٤٦.تفسير مقاتل بن سليمان ٣/٣٧٨.تفسير يحيى بن سلّام ٢/٦٢٣.أخرجه ابن جرير ١٨/٣٧٨.أخرجه ابن جرير ١٨/٣٧٧، وابن أبي حاتم ٩/٣٠٤٦. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.تفسير مقاتل بن سليمان ٣/٣٧٨.تفسير يحيى بن سلّام ٢/٦٢٣.
29,21," <q>﴿یُعَذِّبُ مَن یَشَاۤءُ وَیَرۡحَمُ مَن یَشَاۤءُۖ﴾</q> - تفسير ٥٩٧٣٨- عن سفيان -من طريق أبي خالد- قال في قوله: <q>﴿يعذب من يشاء ويرحم من يشاء﴾</q>، قال: يغفر لمن يشاء العظيمَ، ويعذب من يشاء على الصغير{1}. (ز) ٥٩٧٣٩- قال يحيى بن سلّام: <q>﴿يعذب من يشاء ويرحم من يشاء﴾</q> يعذب الكافر بالنار، ويرحم المؤمن فيدخله الجنة{2}. (ز) <q>﴿وَإِلَیۡهِ تُقۡلَبُونَ ۝٢١﴾</q> - تفسير ٥٩٧٤٠- قال مقاتل بن سليمان: <q>﴿وإليه تقلبون﴾</q>، يعني: وإليه ترجعون بعد الموت يوم القيامة، فيجزيكم بأعمالكم{3}. (ز) ٥٩٧٤١- قال يحيى بن سلّام: <q>﴿وإليه تقلبون﴾</q>، أي: وإليه ترجعون يوم القيامة{2}. (ز) ",footnotes:1:أخرجه ابن أبي حاتم ٩/٣٠٤٦.تفسير يحيى بن سلّام ٢/٦٢٤.تفسير مقاتل بن سليمان ٣/٣٧٨.تفسير يحيى بن سلّام ٢/٦٢٤.
29,22," <q>﴿وَمَاۤ أَنتُم بِمُعۡجِزِینَ فِی ٱلۡأَرۡضِ وَلَا فِی ٱلسَّمَاۤءِۖ﴾</q> - تفسير ٥٩٧٤٢- عن عبد الله بن الزبير -من طريق هشام بن عروة- <q>﴿معجزين﴾</q>: يعني: مُثَبِّطين{1}. (ز) ٥٩٧٤٣- تفسير إسماعيل السُّدِّيّ: <q>﴿وما أنتم بمعجزين في الأرض ولا في السماء﴾</q>، يعني: ما أنتم بسابقي الله بأعمالكم الخبيثة، فتفوتوه هربًا{2}. (ز) ٥٩٧٤٤- قال مقاتل بن سليمان في قوله: <q>﴿وما أنتم بمعجزين﴾</q>، يعني: كفار مكة بمعجزين، يعني: بسابقين الله ﷿ فتفوتوه، <q>﴿في الأرض﴾</q> كنتم، <q>﴿ولا في السماء﴾</q> كنتم أينما كنتم؛ حتى يجزيكم بأعمالكم السيئة{3}. (ز) ٥٩٧٤٥- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿وما أنتم بمعجزين في الأرض ولا في السماء﴾</q>، قال: لا يعجزه أهل الأرضين في الأرضين، ولا أهل السماوات في السماوات؛ إن عصوه. وقرأ: <q>﴿لا يعزب عنه مثقال ذرة في السموات ولا في الأرض ولا أصغر من ذلك ولا أكبر إلا في كتاب مبين﴾</q> [سبأ:٣]{4}٥٠٣٦. (ز) ٥٠٣٦ لم يذكر ابن جرير (١٨/٣٧٩) من أقوال السلف غير قول ابن زيد، وذكر قولًا عن بعض أهل اللغة، فقال: «وقال في ذلك بعض أهل العربية من أهل البصرة: وما أنتم بمعجزين مَن في الأرض ولا من في السماء معجزين». ثم رجّحه على قولٍ آخر لأهل العربية بقوله: «وهذا القول أصح عندي في المعنى من القول الآخر» يعني: الوجه الثالث الذي ذكره بقوله: «ولو قال قائل: معناه: ولا أنتم بمعجزين في الأرض، ولا أنتم لو كنتم في السماء بمعجزين، كان مذهبًا». وذكر ابنُ عطية (٦/٦٣٥) إضافة إلى قول ابن زيد قولين آخرين، فقال: «ويحتمل أن يريد بالسماء: الهواء علوًّا، أي: ليس للإنسان حيلة صَعَدَ أو نَزَلَ. حكى نحوه الزهراوي. ويحتمل أن يريد: السماء المعروفة، أي: لستم بِمُعْجِزِين في الأرض، ولو كنتم في السماء. وقال ابن زيد: معناه: ولا مَن في السماء معجز إن عصى». ثم رجّح الاحتمال الثاني بقوله: «والتأويل الأوسط أحسنها» ولم يذكر مستندًا. ٥٩٧٤٦- قال يحيى بن سلّام: <q>﴿وما أنتم بمعجزين في الأرض ولا في السماء﴾</q>، أي: فتسبقونا حتى لا نقدر عليكم فنعذبكم. يقوله للمشركين{5}. (ز) <q>﴿وَمَا لَكُم مِّن دُونِ ٱللَّهِ مِن وَلِیࣲّ وَلَا نَصِیرࣲ ۝٢٢﴾</q> - تفسير ٥٩٧٤٧- تفسير إسماعيل السُّدِّيّ: قال: <q>﴿وما لكم من دون الله من ولي﴾</q>، يعني: من قريب يمنعكم، يعني: الكفار{2}. (ز) ٥٩٧٤٨- قال مقاتل بن سليمان، في قوله: <q>﴿وما لكم من دون الله من وليٍ﴾</q>: يعني: من قريب لينفعكم، <q>﴿ولا نصيرٍ﴾</q> يعني: ولا مانع يمنعكم من الله ﷿{3}. (ز) ٥٩٧٤٩- قال يحيى بن سلّام: يقول: <q>﴿من ولي﴾</q> يمنعكم من عذابه{5}. (ز) ",footnotes:1:أخرجه ابن أبي حاتم ٩/٣٠٤٦.علقه يحيى بن سلّام ٢/٦٢٤.تفسير مقاتل بن سليمان ٣/٣٧٨.أخرجه ابن جرير ١٨/٣٧٨، وابن أبي حاتم ٩/٣٠٤٧ من طريق أصبغ بن الفرج.تفسير يحيى بن سلّام ٢/٦٢٤.علقه يحيى بن سلّام ٢/٦٢٤.تفسير مقاتل بن سليمان ٣/٣٧٨.تفسير يحيى بن سلّام ٢/٦٢٤.
29,23," <q>﴿وَٱلَّذِینَ كَفَرُوا۟ بِـَٔایَـٰتِ ٱللَّهِ وَلِقَاۤىِٕهِۦۤ﴾</q> - تفسير ٥٩٧٥٠- عن سعيد بن جبير -من طريق عطاء- في قول الله: <q>﴿لقائه﴾</q>، قال: البعث في الآخرة{1}. (ز) ٥٩٧٥١- عن إسماعيل السُّدِّيّ -من طريق أسباط- <q>﴿كفروا بآيات الله﴾</q>، قال: ما آياتُ الله إلا محمدٌ ﷺ{1}. (ز) ٥٩٧٥٢- قال مقاتل بن سليمان: <q>﴿والذين كفروا بآيات الله﴾</q> يعني: بالقرآن، <q>﴿ولقائه﴾</q> وكفروا بالبعث {3}. (ز) <q>﴿أُو۟لَـٰۤىِٕكَ یَىِٕسُوا۟ مِن رَّحۡمَتِی وَأُو۟لَـٰۤىِٕكَ لَهُمۡ عَذَابٌ أَلِیمࣱ ۝٢٣﴾</q> - تفسير ٥٩٧٥٣- تفسير إسماعيل السُّدِّيّ: في قوله: <q>﴿وأولئك لهم عذاب أليم﴾</q>، يعني: مُوجِع، يعني به: عذاب جهنم{4}. (ز) ٥٩٧٥٤- قال مقاتل بن سليمان: <q>﴿أولئك يئسوا من رحمتي﴾</q> يعني: مِن جنتي، <q>﴿وأولئك لهم عذابٌ أليمٌ﴾</q> يعني: وجيعًا{3}. (ز) ٥٩٧٥٥- قال يحيى بن سلّام: <q>﴿والذين كفروا بآيات الله ولقائه أولئك يئسوا من رحمتي﴾</q>، يعني: من جنتي{6}. (ز) ",footnotes:1:أخرجه ابن أبي حاتم ٩/٣٠٤٧.أخرجه ابن أبي حاتم ٩/٣٠٤٧.تفسير مقاتل بن سليمان ٣/٣٧٨.علقه يحيى بن سلّام ٢/٦٢٤.تفسير مقاتل بن سليمان ٣/٣٧٨.تفسير يحيى بن سلّام ٢/٦٢٤.
