quran[9]{c,v,t}:
  3,1,"<div class=ar lang=ar><p><h3>مقدمة السورة{1}</h3></p><p><div></p><p><p><span class="item-no">١١٨١٨<span class="dash">-</span></span> عن عبد الله بن عباس، قال: نزلت سورةُ آل عمران بالمدينة{2}. (٣/٤٣٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٨١٩<span class="dash">-</span></span> عن عبد الله بن عباس - من طريق عطاء الخراساني-: مدنية، نزلت بعد الأنفال{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٨٢٠<span class="dash">-</span></span> عن عكرمة مولى ابن عباس= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٨٢١<span class="dash">-</span></span> والحسن البصري -من طريق يزيد النحوي- قالا: مدنية{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٨٢٢<span class="dash">-</span></span> عن قتادة بن دِعامة -من طُرُق-: مدنية{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٨٢٣<span class="dash">-</span></span> عن محمد ابن شهاب الزهري، قال: مدنية، نزلت بعد الفاتحة{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٨٢٤<span class="dash">-</span></span> عن علي بن أبي طلحة، قال: مدنية{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٨٢٥<span class="dash">-</span></span> قال مقاتل بن سليمان: مدنية كلها{8}<span class=comment-ref>١٠٨٧</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>١٠٨٧</span> <span class="comment-type-3">رَجَّح</span> <u>ابنُ كثير</u> (٣/٥) مدنيةَ السورة <span class="mustanad">مستندًا إلى أحوال النزول</span>، فقال: «هي مدنية؛ لأنّ صدرها إلى ثلاث وثمانين آية منها نزلت في وفد نجران، وكان قدومهم في سنة تسع من الهجرة».</p><p>وقال <u>ابنُ عطية</u> (٢/١٤٧): «هذه السورة مدنية <span class="mustanad">بالإجماع</span> فيما علمتُ».</div></p><p><div></p><p><p><span class="item-no">١١٨٢٦<span class="dash">-</span></span> عن <span class="name-2">الربيع بن أنس</span> -من طريق أبي جعفر- قال: إنّ النصارى أتَوا رسولَ الله ﷺ، فخاصموه في عيسى ابن مريم، وقالوا له: مَن أبوه؟ وقالوا على الله الكذب والبهتان، فقال لهم النبي ﷺ: «<b>ألستم تعلمون أنّه لا يكون ولدٌ إلا وهو يُشْبِه أباه؟</b>». قالوا: بلى. قال: «<b>ألستم تعلمون أنّ ربنا حَيٌّ لا يموت، وأنّ عيسى يأتي عليه الفناء</b>؟». قالوا: بلى. قال: «<b>ألستم تعلمون أنّ ربَّنا قَيِّمٌ على كل شيء يَكْلَؤُه ويحفظه ويرزقه</b>؟». قالوا: بلى. قال: «<b>فهل يملك عيسى مِن ذلك شيئًا</b>؟» قالوا: لا. قال: «<b>أفلستم تعلمون أنّ الله لا يخفى عليه شيء في الأرض ولا في السماء</b>؟» قالوا: بلى. قال: «<b>فهل يعلم عيسى من ذلك شيئًا إلا ما علم</b>؟». قالوا: لا. قال: «<b>فإنّ ربَّنا صَوَّرَ عيسى في الرَّحِم كيف شاء. ألستم تعلمون أنّ ربَّنا لا يأكل الطعام، ولا يشرب الشراب، ولا يحدث الحدث</b>؟». قالوا: بلى. قال: «<b>ألستم تعلمون أنّ عيسى حَمَلَتْهُ أمُّه كما تحمل المرأةُ، ثُمَّ وضَعَتْه كما تَضَعُ المرأةُ ولدَها، ثُمَّ غُذِّي كما تُغَذِّي المرأةُ الصبيَّ، ثُمَّ كان يأكل الطعام ويشرب الشراب ويحدث الحدث</b>؟». قالوا: بلى. قال: «<b>فكيف يكون هذا كما زعمتم</b>؟». فعرفوا، ثم أبَوْا إلا جُحودًا؛ فأنزل الله: <span class="qpc-hafs">﴿الم الله لا إله إلا هو الحي القيوم﴾</span>{9}. (٣/٤٤٣-٤٤٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٨٢٧<span class="dash">-</span></span> عن <span class="name-3">محمد بن جعفر بن الزبير</span>، قال: قدِم على النبيِّ ﷺ وفدُ نجران سِتُّون راكبًا، فيهم أربعة عشر رجلًا مِن أشرافهم، فكلَّم رسولَ الله ﷺ منهم أبو حارثة بن عَلْقَمة، والعاقب عبد المسيح، والأَيْهَم السيِّد، وهو من النصرانيّة على دين الملك مع اختلاف من أمرهم؛ يقولون: هو الله. ويقولون: هو ولد الله. ويقولون: هو ثالث ثلاثة. كذلك قول النصرانية، فهم يحتجّون في قولهم، يقولون: هو الله بأنّه كان يُحْيِي الموتى، ويُبْرِئُ الأسقام، ويخبر بالغيوب، ويخلق من الطين كهيئة الطير ثم ينفخ فيه فيكون طيرًا، وذلك كلّه بإذن الله ليجعله آيةً للناس. ويحتجّون في قولهم بأنّه ولد بأنهم يقولون: لم يكن له أب يُعْلَم، وقد تكلم في المهد شيئًا لم يصنعه أحدٌ مِن ولد آدم قبله. ويحتجّون في قولهم أنّه ثالث ثلاثة بقول الله: فعلنا، وأمرنا، وخلقنا، وقضينا. فيقولون: لو كان واحدًا ما قال إلا: فعلتُ، وأمرتُ، وقضيتُ، وخلقتُ. ولكنه هو وعيسى ومريم، ففي كل ذلك من قولهم نزل القرآن، وذكر الله لنبيه فيه قولهم، فلمّا كلّمه الحبران قال لهما رسول الله ﷺ: «<b>أسلِما»</b>. قالا: قد أسلمنا قبلك. قال: <b>«كذبتُما، منعكما من الإسلام دعاؤُكما لله ولدًا، وعبادتُكما الصليبَ، وأكلُكما الخنزيرَ</b>». قالا: فمَن أبوه، يا محمد؟ فصَمَتَ، فلم يُجِبْهما شيئًا؛ فأنزل الله في ذلك مِن قولهم واختلافِ أمرِهم كلِّه صدرَ سورة آل عمران إلى بضع وثمانين آية منها. فافتتح السورة بتنزيه نفسِه مما قالوه، وتوحيده إياها بالخلق والأمر لا شريك له فيه، وردّ عليهم ما ابتدعوا من الكفر وجعلوا معه مِن الأنداد، واحتجاجًا عليهم بقولهم في صاحبهم ليعرّفهم بذلك ضلالته؛ فقال: <span class="qpc-hafs">﴿الم الله لا إله إلا هو الحي القيوم﴾</span> أي: ليس معه غيره شريك في أمره، <span class="qpc-hafs">﴿الحي﴾</span> الذي لا يموت، وقد مات عيسى في قولهم، <span class="qpc-hafs">﴿القيّوم﴾</span> القائم على سلطانه لا يزول، وقد زال عيسى{10}. (٣/٤٤٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٨٢٨<span class="dash">-</span></span> عن <span class="name-2">محمد بن سهل بن أبي أمامة</span>{11} -من طريق ابن إسحاق- قال: لَمّا قَدِم أهلُ نجران على رسول الله ﷺ يسألونه عن عيسى ابن مريم؛ نزلت فيهم فاتحةُ آل عمران إلى رأس الثمانين منها{12}. (٣/٤٤٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٨٢٩<span class="dash">-</span></span> عن <span class="name-3">محمد بن السائب الكلبي</span>، أنّه قال: نزلت هذه الآياتُ في وفد نجران، وكانوا ستين راكبًا ...{13}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٨٣٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: اجتمعت نصارى نجران، فمنهم السَّيِّدُ والعاقبُ، فقالوا: نشهد أنّ عيسى هو الله. فأنزل الله ﷿ تكذيبًا لقولهم: <span class="qpc-hafs">﴿الم﴾</span> يخبره أنّه <span class="qpc-hafs">﴿الله لا إله إلا هو الحي القيوم﴾</span>{8}. (ز)</p></p><p></div></p></div>",footnotes:1:⟨أورد السيوطي ٣/٤٣٨-٤٣٩ ضمنها عددًا من الآثار في فضائل السورة.⟩{ع}أخرجه ابن الضُّريس في فضائل القرآن ص٣٣ (١٧).</p><p>وإسناده ضعيف جِدًّا؛ فيه عمر بن هارون البلخي متروك، وشيخه عثمان بن عطاء الخراساني ضعيف، يرويه عن أبيه عطاء بن أبي مسلم الخراساني، وهو صدوق يَهِم كثيرًا ويُرْسِل ويُدَلِّس، وقد عنعن. ينظر على الترتيب: التقريب (٥٠١٤، ٤٥٣٤، ٤٦٣٣).</p><p>وأخرجه البيهقي في الدلائل ٧/١٤٣-١٤٤ من وجه آخر من طريق عبد العزيز بن عبد الرحمن، عن خصيف، عن مجاهد، عن ابن عباس.</p><p>قال الذهبي في الميزان ٢/٦٣١: «عبد العزيز بن عبد الرحمن البالسي عن خصيف، اتَّهمه الإمام أحمد... وقال ابن حبان: لا يحلّ الاحتجاج به بحال. وقال النسائي وغيره: ليس بثقة. وضرب أحمد بن حنبل على حديثه». وخصيف هو ابن عبد الرحمن الجزري، صدوق سيئ الحفظ خلط بأخرة. كما في التقريب (١٧٢٨).أخرجه ابن الضُّريس في فضائل القرآن ١/٣٣-٣٥.أخرجه البيهقي في دلائل النبوة ٧/١٤٢-١٤٣.أخرجه الحارث المحاسبي في فهم القرآن ص٣٩٥ من طريقي معمر وسعيد، وأبو بكر بن الأنباري -كما في الإتقان في علوم القرآن ١/٥٧- من طريق همام. كما أخرج ابن المنذر ١/١٠٧ نحوه من طريق سعيد: أنّ الذي نزل بالمدينة من القرآن البقرة، وآل عمران ...تنزيل القرآن ص٣٧-٤٢.أخرجه أبو عبيد في فضائله (ت: الخياطي) ٢/٢٠٠.تفسير مقاتل بن سليمان ١/٢٦٢.أخرجه ابن جرير ٥/١٧٤-١٧٥ مرسلًا، وكذا ابن أبي حاتم ٢/٥٨٥ (٣١٢٤)، ٨/٢٥١٤ (١٤٠٧٦) واللفظ له.</p><p>وأبو جعفر الرازي صدوق سَيِّءُ الحفظ، كما في التقريب (٨٠٧٧).أخرجه ابن إسحاق -كما في سيرة ابن هشام ١/٥٧٥- عن محمد بن جعفر بن الزبير، ومن طريقه ابن جرير ٥/١٧١-١٧٤، وابن المنذر ١/١٠٩-١١١ (١٩٩).</p><p>إسناده معضل؛ محمد بن جعفر بن الزبير بن العوام الأسدي المدني ثقة من أتباع التابعين، توفي سنة بضع عشرة ومائة كما في التقريب (٥٨١٩). والراوي عنه محمد بن إسحاق بن يسار إمام المغازي صدوق يدلّس كما في التقريب (٥٧٦٢) وقد عنعن.كذا في المصدر وفي الدر، ولعلّه: محمد بن أبي أمامة بن سهل بن حنيف، من الذين عاصروا صغار التابعين. ينظر: تقريب التهذيب (٥٧٤٨).أخرجه البيهقي في الدلائل ٥/٣٨٥ من طريق محمد بن إسحاق، قال: حدثني محمد بن سهل بن أبي أمامة.</p><p>وهذا إسناد مرسل أو معضل؛ فإنّ ابن إسحاق من صغار التابعين الذين رأوا بعض الصحابة ولم يثبت لهم السماع منهم كما في التقريب (٥٧٦٢)، وروايته إنما هي عن التابعين فمَن دونهم.تفسير البغوي ٢/٥، وتفسير الثعلبي ٣/٦.تفسير مقاتل بن سليمان ١/٢٦٢.
  3,2,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿الۤمۤ ۝١ ٱللَّهُ لَاۤ إِلَـٰهَ إِلَّا هُوَ ٱلۡحَیُّ ٱلۡقَیُّومُ ۝٢﴾</span> - قراءات</h3></p><p><div></p><p><p><span class="item-no">١١٨٣١<span class="dash">-</span></span> عن <span class="name-1">أُبَيِّ بن كعب</span> أنّه قرأ: <span class="qpc-hafs">﴿الحي القيّوم﴾</span>{1}<span class=comment-ref>١٠٨٨</span>. (٣/٤٤٠)</p></p><p></div></p><p><div><span class=comment-ref>١٠٨٨</span> <span class="comment-type-3">رَجَّح</span> <u>ابنُ جرير</u> (٥/١٧٦) قراءة <span class="qpc-hafs">﴿القيّوم﴾</span> <span class="mustanad">مستندًا إلى استفاضة القراءة بها، وخطّ المصحف</span>، فقال: «والقراءة التي لا يجوز غيرها عندنا في ذلك ما جاءت به قراءة المسلمين نقلًا مستفيضًا، عن غير تشاعر ولا تواطؤ، وِراثَةً، وما كان مثبتًا في مصاحفهم، وذلك قراءة مَن قرأ: <span class="qpc-hafs">﴿الحي القيوم﴾</span>».</div></p><p><div></p><p><p><span class="item-no">١١٨٣٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن مسعود</span> -من طريق أبي خالد الكناني- أنّه كان يقرؤها: (الحَيُّ القَيّامُ){2}. (٣/٤٤٠، ٤٤٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٨٣٣<span class="dash">-</span></span> عن سليمان الأعمش، قال: في قراءة <span class="name-1">عبد الله بن مسعود</span>: (الحَيُّ القَيّامُ){3}. (٣/٤٤٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٨٣٤<span class="dash">-</span></span> عن <span class="name-2">علقمة بن قيس</span> -من طريق أبي مَعْمَر- أنّه كان يقرأ: (الحَيُّ القَيّامُ){4}. (٣/٤٤١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٨٣٥<span class="dash">-</span></span> عن <span class="name-2">علقمة بن قيس</span> -من طريق أبي مَعْمَر- أنّه قرأ: (الحَيُّ القَيِّمُ){5}. (٣/٤٤٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٨٣٦<span class="dash">-</span></span> عن أبي مَعْمَر، قال: سمعتُ <span class="name-2">علقمة</span> يقرأ: (الحَيُّ القَيِّمُ).= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٨٣٧<span class="dash">-</span></span> وكان <span class="name-2">أصحاب عبد الله</span> يقرؤون: (الحَيُّ القَيّامُ){6}. (٣/٤٤١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٨٣٨<span class="dash">-</span></span> عن <span class="name-2">سليمان بن مهران الأعمش</span> -من طريق أبي نُعيم- أنّه قرأ: (الحَيُّ القَيّامُ){7}<span class=comment-ref>١٠٨٩</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>١٠٨٩</span> ذكر <u>ابنُ جرير</u> (٥/١٧٧) أنّ معاني هذه القراءات متقاربة، ثم قال: «ومعنى ذلك كله: القَيِّمُ بحفظ كل شيء، ورزقِه، وتدبيرِه، وتصريفِه فيما شاء وأحب مِن تغيير وتبديل وزيادة ونقص».</p><p>وذكر <u>ابنُ عطية</u> (٢/١٤٩-١٥٠) أنّ مَن قرأ <span class="qpc-hafs">﴿القيّوم﴾</span> فذلك وزنه: فَيْعُول، ومن قرأ (القيّام) فوزنه: فَيْعال، ومَن قرأ (القَيِّم) فوزنه: فيْعل -ونحوه عند <u>ابن جرير</u> (٥/١٧٩)-. ثم <span class="comment-type-4">عَلَّق مُوَجِّهًا</span> بقوله: «وهذا كله مِن: قام بالأمر يقوم به إذا اضطلع بحفظه وبجميع ما يحتاج إليه في وجوده، والله تعالى القيّام على كل شيء بما ينبغي له أو فيه أو عليه».</div></p><p><h3><span class="qpc-hafs">﴿الۤمۤ ۝١ ٱللَّهُ لَاۤ إِلَـٰهَ إِلَّا هُوَ﴾</span>{8} - تفسير</h3></p><p><div></p><p><p><span class="item-no">١١٨٣٩<span class="dash">-</span></span> عن <span class="name-3">محمد بن جعفر بن الزبير</span> -من طريق ابن إسحاق- <span class="qpc-hafs">﴿الله لا إله إلا هو الحي القيوم﴾</span>: أي: ليس معه غيرُه شريكٌ في أمره{9}. (٣/٤٤١-٤٤٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٨٤٠<span class="dash">-</span></span> عن <span class="name-3">محمد بن إسحاق</span> -من طريق سلمة- قوله: <span class="qpc-hafs">﴿الم الله لا إله إلا هو الحي القيوم﴾</span>: ففَتَح السورةَ بتبرئته نفسَه مِمّا قالوا، وتوحيدِه إيّاها بالخلق والأمر لا شريك له فيه، ورَدَّ عليهم ما ابتدعوا من الكفر وجعلوا معه من الأنداد، واحتجاجًا عليهم بقولهم في صاحبهم ليعرفوا بذلك ضلالتهم؛ فقال: <span class="qpc-hafs">﴿الله لا إله إلا هو﴾</span>. أي: ليس معه غيره شريك في أمره{10}<span class=comment-ref>١٠٩٠</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>١٠٩٠</span> <span class="comment-type-4">ذكر</span> <u>ابنُ عطية</u> (٢/١٤٧) أنّ الجرجانيَّ ذهب في النظم إلى أنّ أحسن الأقوال: أن يكون <span class="qpc-hafs">﴿الم﴾</span> إشارة إلى حروف المعجم، كأنه يقول: هذه الحروف كتابك أو نحو هذا، <span class="mustanad">ويدل قوله</span>: <span class="qpc-hafs">﴿الله لا إله إلا هو الحي القيوم نزل عليك الكتاب﴾</span> على ما ترك ذكره مما هو خبر عن الحروف، وأنّ ذلك في نظمه مثل قوله تعالى: <span class="qpc-hafs">﴿أفمن شرح الله صدره للإسلام فهو على نور من ربه﴾</span>، وترك الجواب لدلالة قوله: <span class="qpc-hafs">﴿فويل للقاسية قلوبهم من ذكر الله﴾</span> [الزمر:٢١] تقديره: كمن قسا قلبه. و<span class="comment-type-4">ذكر</span> <u>ابنُ عطية</u> (٢/١٤٨) أنه يحسن في هذا القول أن يكون <span class="qpc-hafs">﴿نزل﴾</span> خبر قوله: <span class="qpc-hafs">﴿الله﴾</span> حتى يرتبط الكلام إلى هذا المعنى. و<span class="comment-type-2">انتقده</span> فقال: «وهذا الذي ذكره القاضي الجرجاني فيه نظر؛ لأن مُثُله ليست صحيحة الشبه بالمعنى الذي نحا إليه». ثم قال: «وما قاله في الآية محتمل». ثم <span class="comment-type-4">ذكر</span> أنّ «الأبرع في نظم الآية أن يكون <span class="qpc-hafs">﴿الم﴾</span> لا يضم ما بعدها إلى نفسها في المعنى، وأن يكون <span class="qpc-hafs">﴿الله لا إله إلا هو الحي القيوم﴾</span> كلامًا مبتدأً جزمًا جملةً رادَّةً على نصارى نجران الذين وفدوا على رسول الله ﷺ فحاجُّوه في عيسى ابن مريم وقالوا: إنه الله».</div></p><p><h3><span class="qpc-hafs">﴿ٱلۡحَیُّ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">١١٨٤١<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دِعامة</span> -من طريق سعيد- قوله: <span class="qpc-hafs">﴿الحي﴾</span>: الذي لا يموت{10}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٨٤٢<span class="dash">-</span></span> عن <span class="name-3">محمد بن جعفر بن الزبير</span> -من طريق ابن إسحاق- <span class="qpc-hafs">﴿الحي﴾</span>: الذي لا يموت. وقد مات عيسى وصُلِب في قولهم، يعني: في قول الأحبار الذين حاجّوا رسول الله ﷺ مِن نصارى أهل نجران{12}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٨٤٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: قوله: <span class="qpc-hafs">﴿الحي﴾</span>، يعني: الحي الذي لا يموت{13}<span class=comment-ref>١٠٩١</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>١٠٩١</span> اختُلِف في معنى الحيّ؛ <b>فقال قوم</b>: هو وصْفٌ مِن الله لنفسه بالبقاء، ونَفْيٌ للموت عنها. و<b>قال غيرهم</b>: هو وصفٌ لنفسه بأنّه المُتَيَسِّرُ له تدبير ما أراد، وأنّه ليس كمن لا تدبير له مِن الآلهة والأنداد. و<b>قال آخرون</b>: معنى ذلك: أنّ له الحياة الدائمة التي لم تزل ولا تزال كذلك. ولم ينسب <u>ابن جرير</u> (٥/١٧٧) القولين الأخيرين، ثُمَّ قال: «ومعنى ذلك عندي: أنّه وصَفَ نفسَه بالحياة الدائمة التي لا فناءَ لها ولا انقطاعَ، ونفى عنها ما هو حالٌّ بكل ذي حياة مِن خلقه مِن الفناء وانقطاع الحياة عند مجيء أجله، فأخبر عبادَه أنّه المستوجبُ على خلقه العبادةَ والألوهةَ، والحيُّ: الذي لا يموت، ولا يبيد كما يموت كُلُّ مَن اتخذ مِن دونِه ربًّا، وأنّ الإله هو الدائم الذي لا يموت، ولا يبيد، ولا يفنى، وذلك الله الذي لا إله إلا هو».</div></p><p><h3><span class="qpc-hafs">﴿ٱلۡقَیُّومُ ۝٢﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">١١٨٤٤<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نَجِيح- قال: <span class="qpc-hafs">﴿القيوم﴾</span>: القائمُ على كل شيء{14}<span class=comment-ref>١٠٩٢</span>. (٣/٤٤٠)</p></p><p></div></p><p><div><span class=comment-ref>١٠٩٢</span> <span class="comment-type-3">رَجَّح</span> <u>ابنُ جرير</u> (٥/١٧٨-١٧٩) قولَ مجاهد والربيع <span class="mustanad">مستندًا إلى اللغة</span>، فقال: «وأَوْلى التأويلين بالصواب ما قاله مجاهد والربيع ... مِن قول العرب: فلانٌ قائمٌ بأمر هذه البلدة، تعني بذلك: المُتَوَلِّي تدبيرَ أمرها».</div></p><p><div></p><p><p><span class="item-no">١١٨٤٥<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق سفيان بن حسين- <span class="qpc-hafs">﴿القيّوم﴾</span>: الذي لا زوال له{10}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٨٤٦<span class="dash">-</span></span> قال <span class="name-2">الحسن البصري</span>: يعني: القائم على كُلِّ نفس بما كسبت، حتّى يجزيها بعملها{16}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٨٤٧<span class="dash">-</span></span> قال <span class="name-2">قتادة بن دِعامة</span>: القائم على كل شيء{17}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٨٤٨<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دِعامة</span> -من طريق سلام بن أبي مُطِيع- في قوله: <span class="qpc-hafs">﴿القيّوم﴾</span>: القيّم على الخلق بأعمالهم، وأرزاقهم، وآجالهم{18}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٨٤٩<span class="dash">-</span></span> عن <span class="name-2">الربيع بن أنس</span> -من طريق أبي جعفر- <span class="qpc-hafs">﴿القيّوم﴾</span>: قَيِّمٌ على كل شيء يَكْلَؤُه، ويحفظه، ويرزقه{19}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٨٥٠<span class="dash">-</span></span> عن <span class="name-3">محمد بن جعفر بن الزبير</span> -من طريق ابن إسحاق- <span class="qpc-hafs">﴿القيّوم﴾</span>: القَيّام على مكانه مِن سلطانه في خلقه لا يزول، وقد زال عيسى في قولهم -يعني: في قول الأحبار الذين حاجّوا النبي ﷺ من أهل نجران في عيسى- عن مكانه الذي كان به، وذهب عنه إلى غيره{20}. (٣/٤٤١-٤٤٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٨٥١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿القيّوم﴾</span>، يعني: القائم على كل نفس بما كَسَبَتْ{13}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٨٥٢<span class="dash">-</span></span> عن <span class="name-3">محمد بن إسحاق</span> -من طريق عبد الله بن إدريس- قوله: <span class="qpc-hafs">﴿القيوم﴾</span>: القائم على مكانته الذي لا يزول، وعيسى لحمٌ ودم، وقد قضي عليه بالموت، زال عن مكانه الذي يُحدث به{10}<span class=comment-ref>١٠٩٣</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>١٠٩٣</span> ذكر <u>ابنُ جرير</u> (٥/١٧٨) أنّ مَن قالوا بهذا القول <span class="comment-type-1">وجَّهوه</span> إلى القيام الدائم الذي لا زوال معه ولا انتقال، وأنّ الله ﷿ إنّما نفى عن نفسه بوصفها بذلك التغيرَ والتنقلَ من مكان إلى مكان، وحدوثَ التبدل الذي يحدث في الآدميين وسائر خلقه غيرهم.</div></p><p><h3><span class="qpc-hafs">﴿ٱلۡقَیُّومُ ۝٢﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">١١٨٥٣<span class="dash">-</span></span> عن أسماء يعني: بنت يزيد -من طريق شَهْر بن حوشب- أنّها سمعت رسول الله ﷺ يقول: <b>«إنّ هاتين الآيتين اسمُ الله الأعظم <span class="qpc-hafs">﴿ألـم الله لا إله إلا هو الحي القيوم﴾</span>، <span class="qpc-hafs">﴿وإلهكم إله واحد لا إله إلا هو الرحمن الرحيم</b>﴾</span> [البقرة:١٦٣]»{23}. (٢/١٠٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٨٥٤<span class="dash">-</span></span> عن عبد الله بن العلاء، حدّثني <span class="name-2">القاسمُ أبو عبد الرحمن</span>، قال: إنّ اسم الله الأعظم في ثلاث سور من القرآن: في سورة البقرة، وآل عمران، وطه. قال الشيخ: التَمَسْتُها، فوجدتُ في البقرة [٢٥٥] آيةَ الكرسي: <span class="qpc-hafs">﴿الله لا إله إلا هو الحي القيوم﴾</span>، وفاتحة آل عمران: <span class="qpc-hafs">﴿الم الله لا إله إلا هو الحي القيوم﴾</span>، وفي طه [١١١]: <span class="qpc-hafs">﴿وعنت الوجوه للحي القيوم﴾</span>{24}. (ز)</p></p><p></div></p></div>",footnotes:1:عزاه السيوطي إلى ابن الأنباري في المصاحف.أخرجه أبو عبيد ص١٦٨، وسعيد بن منصور في سننه (٤٨٩- تفسير)، والطبراني (٨٦٩٠).</p><p>وهي قراءة شاذة، تنسب إلى عمر بن الخطاب، وعثمان بن عفان، وابن مسعود، والنخعي، والأعمش، وغيرهم. ينظر: المحتسب ٢/١٥١.أخرجه ابن أبي داود ص٥٩.أخرجه ابن جرير ٥/١٧٥-١٧٦. وعزاه السيوطي إلى ابن الأنباري.أخرجه ابن جرير ٥/١٧٥.</p><p>وهي قراءة شاذة. ينظر: المحتسب ٢/١٥١.عزاه السيوطي إلى ابن الأنباري. وأخرجه ابن جرير ٥/١٧٥ دون قوله: كان أصحاب عبد الله يقرؤون: (الحَيُّ القَيّامُ). وفي أوله: عن إبراهيم، عن أبي معمر، قال: سمعت علقمة يقرأ: (الحَيُّ القَيِّمُ). قلت: أنت سمعته؟ قال: لا أدري.أخرجه عبد بن حميد كما في قطعة من تفسيره ص١٩.تقدّم تفسير <span class="qpc-hafs">﴿الـم﴾</span> في سورة البقرة.سيرة ابن هشام ١/٥٧٣، وأخرجه ابن جرير ٥/١٧١-١٧٤، وابن المنذر (١٩٩).أخرجه ابن أبي حاتم ٢/٥٨٦.أخرجه ابن أبي حاتم ٢/٥٨٦.أخرجه ابن جرير ٥/١٧٦.تفسير مقاتل بن سليمان ١/٢٦٢.أخرجه ابن جرير ٥/١٧٨، وابن المنذر ١/١١٣ من طريق ابن جُرَيْج. وعزاه السيوطي إلى عَبد بن حُمَيد.أخرجه ابن أبي حاتم ٢/٥٨٦.علقه يحيى بن سلام ١/٢٨١، وينظر: تفسير ابن أبي زمنين ١/٢٧٤.علقه يحيى بن سلام ١/٢٨١.أخرجه ابن أبي حاتم ٢/٩٢، ٥٨٦.أخرجه ابن جرير ٥/١٧٨.أخرجه ابن إسحاق -كما في سيرة ابن هشام ١/٥٧٣-، وابن جرير ٥/١٧٨، وابن المنذر (١٩٩).تفسير مقاتل بن سليمان ١/٢٦٢.أخرجه ابن أبي حاتم ٢/٥٨٦.أخرجه أحمد ٤٥/٥٨٤ (٢٧٦١١)، وأبو داود ٢/٦١٣ (١٤٩٦)، والترمذي ٦/٨٨ (٣٧٨٢)، وابن ماجه ٥/٢٤ (٣٨٥٥)، وابن أبي حاتم ١/٢٧٢ (١٤٦٠)، ٢/٥٨٣ (٣١١٥).</p><p>قال الترمذي: «هذا حديث حسن صحيح». وقال الألباني في صحيح سنن أبي داود ٥/٢٣٤ (١٣٤٣): «حديث حسن، وصحَّحه الترمذي».أخرجه الفريابي في فضائل القرآن ص١٥٨ (٤٨).
  3,3,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿نَزَّلَ عَلَیۡكَ ٱلۡكِتَـٰبَ بِٱلۡحَقِّ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">١١٨٥٥<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دِعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿نزّل عليك الكتاب﴾</span>، قال: القرآن{1}. (٣/٤٤٤-٤٤٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٨٥٦<span class="dash">-</span></span> عن <span class="name-3">محمد بن جعفر بن الزبير</span> -من طريق ابن إسحاق- <span class="qpc-hafs">﴿نزّل عليك الكتاب بالحق﴾</span>، أي: بالصدق فيما اختَلَفوا فيه{2}<span class=comment-ref>١٠٩٤</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>١٠٩٤</span> ذكر <u>ابنُ عطية</u> (٢/١٥٠) أنّ قوله <span class="qpc-hafs">﴿بِالحَقِّ﴾</span> يحتمل معنيين: <b>إحداهما</b>: أن يكون المعنى: ضَمَّنه الحقائقَ مِن خبره وأمره ونهيه ومواعظه. <b>والثاني</b>: أن يكون المعنى: أنّه نَزَّل الكتابَ باستحقاق أن ينزل لِما فيه مِن المصلحة الشاملة، وليس ذلك على أنّه واجبٌ على الله تعالى أن يفعله. ثم أفاد دخول هذا القولِ في المعنى الأول.</div></p><p><div></p><p><p><span class="item-no">١١٨٥٧<span class="dash">-</span></span> عن <span class="name-3">محمد بن إسحاق</span> -من طريق ابن إدريس- قوله: <span class="qpc-hafs">﴿نزل عليك الكتاب بالحق﴾</span>، يقول: بالفصل في الذي ادَّعَوْا مِن الباطل{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٨٥٨<span class="dash">-</span></span> عن <span class="name-3">محمد بن إسحاق</span> -من طريق سلمة- قوله: <span class="qpc-hafs">﴿نزّل عليك الكتاب بالحقّ﴾</span>، أي: بالصِّدْق فيما اختلفوا فيه{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٨٥٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿نزل عليك الكتاب﴾</span> يا محمد <span class="qpc-hafs">﴿بالحق﴾</span>، لم يُنزله باطلًا. يعني: القرآن{5}<span class=comment-ref>١٠٩٥</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>١٠٩٥</span> <span class="comment-type-4">ذكر</span> <u>ابنُ عطية</u> (٢/١٥٠) أن <span class="qpc-hafs">﴿الكتاب﴾</span> في هذا الموضع هو القرآن <span class="mustanad">باتفاق من المفسرين</span>.</div></p><p><h3><span class="qpc-hafs">﴿مُصَدِّقࣰا لِّمَا بَیۡنَ یَدَیۡهِ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">١١٨٦٠<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نَجِيح- في قوله: <span class="qpc-hafs">﴿نزل عليك الكتاب بالحق مصدّقًا لما بين يديه﴾</span>، قال: لِما قبلَه مِن كتاب، أو رسول{6}. (٣/٤٤٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٨٦١<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق عَبّاد بن منصور- <span class="qpc-hafs">﴿مصدقا لما بين يديه﴾</span>، يقول: مِن البيِّنات التي أُنزِلت على نوح، وإبراهيم، وهود، والأنبياء، وأُنزِل على داود الزبور{3}. (٣/٤٤٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٨٦٢<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دِعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿مصدقًا لما بين يديه﴾</span>، يقول: مِن الكتب التي قد خَلَتْ قبلَه{8}. (٣/٤٤٤-٤٤٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٨٦٣<span class="dash">-</span></span> عن <span class="name-2">الربيع بن أنس</span> -من طريق أبي جعفر- قوله: <span class="qpc-hafs">﴿نزل عليك الكتاب بالحق مصدقا لما بين يديه﴾</span>، يقول: مُصَدِّقًا لِما قبلَه مِن كتاب، ورسول{9}<span class=comment-ref>١٠٩٦</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>١٠٩٦</span> لم يذكر <u>ابنُ جرير</u> (٥/١٨٠) غيرَ هذا القول وما في معناه.</div></p><p><div></p><p><p><span class="item-no">١١٨٦٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿مصدّقا لما بين يديه﴾</span> مِن الكتاب. يقول: محمدٌ ﵇ مُصَدِّقٌ للكتب التي كانت قبلَه{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٨٦٥<span class="dash">-</span></span> عن <span class="name-3">عبد الملك بن جُرَيْج</span>، في قوله: <span class="qpc-hafs">﴿مصدقا لما بين يديه﴾</span>، قال: التوراة، والإنجيل{11}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَأَنزَلَ ٱلتَّوۡرَىٰةَ وَٱلۡإِنجِیلَ ۝٣﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">١١٨٦٦<span class="dash">-</span></span> عن <span class="name-3">محمد بن جعفر بن الزبير</span> -من طريق ابن إسحاق-: <span class="qpc-hafs">﴿وأنزل التوراة والإنجيل﴾</span>، التوراة على موسى، والإنجيل على عيسى، كما أنزل الكتب على مَن كان قبله{12}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٨٦٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وأنزل التوراة﴾</span> على موسى، <span class="qpc-hafs">﴿والإنجيل﴾</span> على عيسى{5}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَأَنزَلَ ٱلتَّوۡرَىٰةَ وَٱلۡإِنجِیلَ ۝٣﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">١١٨٦٨<span class="dash">-</span></span> عن واثِلَة بن الأَسْقَع، أنّ النبي ﷺ قال: «<b>وأُنزِلت التوراةُ لِسِتٍّ مَضَيْنَ مِن رمضان، وأُنزِل الإنجيل لثلاث عشرة خَلَتْ مِن رمضان»</b>{14}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ٥/١٨١-١٨٣، وابن أبي حاتم ٢/٥٨٧. وعزاه السيوطي إلى عَبد بن حُمَيد.أخرجه ابن جرير ٥/١٨٠-١٨١.أخرجه ابن أبي حاتم ٢/٥٨٧.أخرجه ابن أبي حاتم ٢/٥٨٧، وابن المنذر ١/١١٤ من طريق إبراهيم بن سعد.تفسير مقاتل بن سليمان ١/٢٦٢.أخرجه ابن جرير ٥/١٨٠، وابن أبي حاتم ٢/٥٨٧. وعزاه السيوطي إلى الفريابي، وعبد بن حميد.أخرجه ابن أبي حاتم ٢/٥٨٧.أخرجه ابن جرير ٥/١٨١-١٨٣. وعزاه السيوطي إلى عَبد بن حُمَيد.أخرجه ابن جرير ٥/١٨١. وعلَّقه ابنُ أبي حاتم ٢/٥٨٧.تفسير مقاتل بن سليمان ١/٢٦٢.علَّقه ابن المنذر ١/١١٤.أخرجه ابن جرير ٥/١٨١-١٨٣.تفسير مقاتل بن سليمان ١/٢٦٢.أخرجه أحمد ٢٨/١٩١ (١٦٩٨٤)، وابن جرير ٣/١٨٩، وابن أبي حاتم ١/٣١٠ (١٦٤٩)، ٢/٥٨٧ (٣١٣٧)، ٥/١٥٨٢ (٨٣٣٧)، ٨/٢٥١٦ (١٤٠٨٠).</p><p>قال الهيثميُّ في المجمع ١/١٩٧ (٩٥٩): «رواه أحمد، والطبراني في الكبير والأوسط، وفيه عمران بن داوَر القَطّان، ضعّفه يحيى، ووثّقه ابن حبان، وقال أحمد: أرجو أن يكون صالح الحديث. وبقية رجاله ثقات». وقال الألباني في الصحيحة ٤/١٠٤ (١٥٧٥): «إسناده حَسَن».
  3,4,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿مِن قَبۡلُ هُدࣰى لِّلنَّاسِ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">١١٨٦٩<span class="dash">-</span></span> عن <span class="name-2">عامر الشعبي</span> -من طريق بيان- في قوله: <span class="qpc-hafs">﴿هدى للناس﴾</span>، قال: هُدًى مِن الضلالة{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٨٧٠<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دِعامة</span> -من طريق سعيد-: <span class="qpc-hafs">﴿وأنزل التوراة والإنجيل من قبل هدى للناس﴾</span>، هُما كتابان أنزلهما اللهُ، فيهما بيانٌ مِن الله، وعِصْمَةٌ لِمَن أخذ به، وصَدَّق به، وعَمِل بما فيه{2}. (٣/٤٤٤-٤٤٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٨٧١<span class="dash">-</span></span> قال <span class="name-2">إسماعيل السُّدِّيّ</span>: في الآية تقديم وتأخير، تقديرها: وأنزل التوراةَ والإنجيلَ والفرقانَ هُدًى للناس{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٨٧٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿من قبل﴾</span> هذا القرآن، ثم قال: <span class="qpc-hafs">﴿التوراة والإنجيل﴾</span> هما <span class="qpc-hafs">﴿هدى للناس﴾</span>{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٨٧٣<span class="dash">-</span></span> عن <span class="name-3">عبد الملك بن جُرَيْج</span> -من طريق محمد بن ثور-: <span class="qpc-hafs">﴿وأنزل التوراة والإنجيل﴾</span>، أُنزِلت التوراة والإنجيل قبلَ القرآن{5}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَأَنزَلَ ٱلۡفُرۡقَانَۗ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">١١٨٧٤<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق عبّاد بن منصور- في قوله: <span class="qpc-hafs">﴿وأنزل الفرقان﴾</span>، قال: هو كتابٌ بِحَقٍّ{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٨٧٥<span class="dash">-</span></span> عن <span class="name-2">أبي صالح باذام</span> -من طريق إسماعيل بن أبي خالد- في قوله: <span class="qpc-hafs">﴿الفرقان﴾</span>، قال: التوراة{7}<span class=comment-ref>١٠٩٧</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>١٠٩٧</span> <span class="comment-type-2">انتَقَدَ</span> <u>ابنُ كثير</u> (٣/٦) قولَ أبي صالح <span class="mustanad">مستندًا إلى دلالة عقلية</span>، فقال: «وأمّا ما رواه ابنُ أبي حاتم عن أبي صالح أنّ المراد هاهنا بالفرقان: التوراة. فضعيف؛ لِتَقَدُّمِ ذِكْرِها».</div></p><p><div></p><p><p><span class="item-no">١١٨٧٦<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دِعامة</span> -من طريق سعيد- قوله: <span class="qpc-hafs">﴿وأنزل الفرقان﴾</span>، قال: هو القرآن، فرَّق به بين الحق والباطل، فأحَلَّ فيه حلالَه، وحَرَّم فيه حرامَه، وشرع فيه شرائعه، وحَدَّ فيه حدوده، وفرض فيه فرائضه، وبَيَّنَ فيه بيانه، وأمر بطاعته، ونهى عن معصيته{8}. (٣/٤٤٤-٤٤٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٨٧٧<span class="dash">-</span></span> عن <span class="name-3">محمد بن جعفر بن الزبير</span> -من طريق ابن إسحاق- <span class="qpc-hafs">﴿وأنزل الفرقان﴾</span>: أي: الفَصْلَ بين الحق والباطل فيما اخْتَلَف فيه الأحزابُ مِن أمرِ عيسى وغيرِه{9}. (٣/٤٤٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٨٧٨<span class="dash">-</span></span> عن <span class="name-2">الربيع بن أنس</span> -من طريق أبي جعفر- <span class="qpc-hafs">﴿وأنزل الفرقان﴾</span>، قال: الفرقان: القرآن، فَرَّق بين الحقِّ والباطل{10}<span class=comment-ref>١٠٩٨</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>١٠٩٨</span> <span class="comment-type-4">عَلَّق</span> <u>ابنُ تيمية</u> (٢/١٤-١٥)، فقال: «قال قتادةُ والربيعُ: هو القرآن، فرَّق فيه بين الحلال والحرام، والحق والباطل. وهذا لأنّ الشيء الواحد إذا كان له وصفان كبيران فهو مع وصف كالشيء الواحد، وهو مع الوصفين بمنزلة الاثنين، حتى لو كثرت صفاته لتنزل منزلة أشخاص، ألا ترى أنّ الرجل الذي يحسن الحساب والطب بمنزلة حاسب وطبيب».</div></p><p><div></p><p><p><span class="item-no">١١٨٧٩<span class="dash">-</span></span> وعن <span class="name-2">عطاء</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٨٨٠<span class="dash">-</span></span> و<span class="name-2">مجاهد بن جبر</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٨٨١<span class="dash">-</span></span> و<span class="name-2">مِقْسَم</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٨٨٢<span class="dash">-</span></span> و<span class="name-3">مقاتل بن حيان،</span> نحو ذلك{11}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٨٨٣<span class="dash">-</span></span> عن <span class="name-3">محمد بن إسحاق</span> -من طريق إبراهيم بن سعد- <span class="qpc-hafs">﴿وأنزل الفرقان﴾</span>: أي: الفصلَ بين الحق والباطل فيما اختَلَفَ فيه الأحزاب مِن أمر عيسى وغيرِه{12}<span class=comment-ref>١٠٩٩</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>١٠٩٩</span> اختلف المفسرون في المراد بالفرقان؛ <b>فذهب قوم</b> إلى أنّه مصدر، والمراد: الفصل بين الحق والباطل في أمر عيسى. <b>وذهب قومٌ</b> إلى أنّه القرآن، والمراد: الفصل بين الحق والباطل في أحكام الشرائع.</p><p>و<span class="comment-type-3">رَجَّح</span> <u>ابنُ جرير</u> (٥/١٨٣-١٨٤) القولَ الأول الذي قاله ابنُ الزبير وابنُ إسحاق <span class="mustanad">مُسْتَنِدًا إلى دلالة القرآن، والسياق</span>؛ لتقدّم ذِكْرِ القرآن في قوله: <span class="qpc-hafs">﴿نزل عليك الكتاب بالحق مصدقا﴾</span>، ولا شكَّ أنّ ذلك الكتاب هو القرآن لا غيره، فلا وجه لتكريره مرّة أخرى؛ إذ لا فائدة في تكريره، ولأنّ الله عَقَّب قولَه: <span class="qpc-hafs">﴿وأنزل الفرقان﴾</span> بقوله: <span class="qpc-hafs">﴿إن الذين كفروا بآيات الله﴾</span>، وهذا وعيدٌ صريحٌ لِمَن جَحَدَ الفَصْلَ الذي أنزله الله فرقانًا بين الحق والباطل وعانده.</p><p>وكذا <span class="comment-type-3">رجَّح</span> <u>ابنُ كثير</u> (٣/٦) هذا القول.</p><p>و<span class="comment-type-1">وجَّه</span> <u>ابنُ عطية</u> (٢/١٥٤) تفسيرَ الفرقان بالقرآن لكونه يُفَرِّق بين الحق والباطل، ثُمَّ <span class="comment-type-4">جَمَع</span> بين القولين، فقال: «والفرقانُ يَعُمُّ هذا كلَّه».</p><p>و<span class="comment-type-4">ذكر</span> أنّ بعض المفسرين قال بأنّ الفرقان هنا كل أمر فرق بين الحق والباطل، فيما قدم وحدث، و<span class="comment-type-4">علَّق</span> عليه، بقوله: «فيدخل في هذا التأويل طوفان نوح، وفرق البحر لغرق فرعون، ويوم بدر، وسائر أفعال الله تعالى المفرقة بين الحق والباطل، فكأنه تعالى ذكر الكتاب العزيز، ثم التوراة والإنجيل، ثم كل أفعاله ومخلوقاته التي فرقت بين الحق والباطل، كما فعلت هذه الكتب، ثم توعد تعالى الكفار عمومًا بالعذاب الشديد، وذلك يعم عذاب الدنيا بالسيف والغلبة، وعذاب الآخرة بالنار». ثم <span class="comment-type-4">بيَّن</span> أنّ الإشارة بهذا الوعيد إلى نصارى نجران، و<span class="comment-type-4">ذكر</span> أنّ النقّاش قال بأنّه إلى اليهود؛ كعب بن الأشرف، وكعب بن أسد، وبني أخطب وغيرهم.</div></p><p><div></p><p><p><span class="item-no">١١٨٨٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: يعني: قال سبحانه: <span class="qpc-hafs">﴿وأنزل الفرقان﴾</span>، يعني: القرآن بعد التوراة والإنجيل، والفرقان يعني به: المُخْرِج في الدِّين من الشُّبْهَةِ والضلالة، فيه بيان كُلِّ شيء يكون إلى يوم القيامة. نظيرُها في الأنبياء [٤٨]: <span class="qpc-hafs">﴿ولقد آتينا موسى وهارون الفرقان﴾</span>، يعني: المخرج من الشبهات، وفي البقرة [١٨٥]: <span class="qpc-hafs">﴿وبينات من الهدى والفرقان﴾</span>{13}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿إِنَّ ٱلَّذِینَ كَفَرُوا۟ بِـَٔایَـٰتِ ٱللَّهِ لَهُمۡ عَذَابࣱ شَدِیدࣱۗ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">١١٨٨٥<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دِعامة</span> -من طريق سعيد- قوله: <span class="qpc-hafs">﴿عذاب﴾</span>، أي: عقوبة الآخرة{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٨٨٦<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيِّ</span> -من طريق أسباط- قوله: <span class="qpc-hafs">﴿بآيات الله﴾</span>: بمحمد ﷺ{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٨٨٧<span class="dash">-</span></span> عن <span class="name-2">الربيع بن أنس</span> -من طريق أبي جعفر- في قوله: <span class="qpc-hafs">﴿إن الذين كفروا بآيات الله لهم عذاب شديد﴾</span>، يعني: النصارى{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٨٨٨<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثُمَّ قال سبحانه: <span class="qpc-hafs">﴿إن الذين كفروا بآيات الله﴾</span>، يعني: القرآن، وهم اليهود، كفروا بالقرآن، منهم: حُيَيّ، وجُدَيّ، وأبو ياسر بنو أخْطَب، وكعب بن الأشرف، وكعب بن أُسَيْد، وزيد بن التابوه، وغيرهم، <span class="qpc-hafs">﴿لهم عذاب﴾</span> في الآخرة <span class="qpc-hafs">﴿شديد﴾</span>{13}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَٱللَّهُ عَزِیزࣱ ذُو ٱنتِقَامٍ ۝٤﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">١١٨٨٩<span class="dash">-</span></span> عن <span class="name-3">محمد بن جعفر بن الزبير</span> -من طريق ابن إسحاق- <span class="qpc-hafs">﴿إن الذين كفروا بآيات الله لهم عذاب شديد والله عزيز ذو انتقام﴾</span>، أي: أنّ الله مُنتَقِمٌ مِمَّن كَفَر بآياته، بعد علمه بها ومعرفته بما جاء منه فيها{18}<span class=comment-ref>١١٠٠</span>. (٣/٤٤٥)</p></p><p></div></p><p><div><span class=comment-ref>١١٠٠</span> لم يذكر <u>ابنُ جرير</u> (٥/١٨٤) غير هذا القول.</div></p><p><div></p><p><p><span class="item-no">١١٨٩٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿الله عزيز ذو انتقام﴾</span>، يعني: عزيز في ملكه، منيع شديد الانتقام من أهل مكة، هذا وعيد لِمَن خالف أمره{13}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٨٩١<span class="dash">-</span></span> عن <span class="name-3">محمد بن إسحاق</span> -من طريق إبراهيم بن سعد- <span class="qpc-hafs">﴿والله عزيز ذو انتقام﴾</span>: إنّ الله مُنتَقِم مِمَّن كفر بآياته بعد علمه بها، ومعرفته بما جاء منه فيها{20}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٨٩٢<span class="dash">-</span></span> عن <span class="name-3">محمد بن إسحاق</span> -من طريق ابن إدريس- قوله: <span class="qpc-hafs">﴿والله عزيز ذو انتقام﴾</span>: عزيزٌ ذو بَطْشٍ مِمَّن أراد{6}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن أبي حاتم ٢/٥٨٨.أخرجه ابن جرير ٥/١٨١-١٨٣، وابن أبي حاتم ٢/٥٨٨ من طريق شيبان. وعزاه السيوطي إلى عَبد بن حُمَيد.تفسير البغوي ٢/٦، وتفسير الثعلبي ٣/٩.تفسير مقاتل بن سليمان ١/٢٦٢.أخرجه ابن المنذر ١/١١٥.أخرجه ابن أبي حاتم ٢/٥٨٩.أخرجه ابن المنذر ١/١١٦.أخرجه ابن جرير ٥/١٨٣، وابن أبي حاتم ٢/٥٨٨-٥٨٩ من طريق شيبان. وعزاه السيوطي إلى عَبد بن حُمَيد.أخرجه ابن جرير ٥/١٨٢.أخرجه ابن جرير ٥/١٨٣.علَّقه ابن أبي حاتم ٢/٥٨٨.أخرجه ابن المنذر ١/١١٥-١١٦.تفسير مقاتل بن سليمان ١/٢٦٣.أخرجه ابن أبي حاتم ٢/٥٨٩.أخرجه ابن أبي حاتم ٢/٥٨٩.أخرجه ابن أبي حاتم ٢/٥٨٩.تفسير مقاتل بن سليمان ١/٢٦٣.أخرجه ابن جرير ٥/١٨٤-١٨٥.تفسير مقاتل بن سليمان ١/٢٦٣.أخرجه ابن المنذر ١/١٢٤، وابن أبي حاتم ٢/٥٨٩ من طريق سلمة.أخرجه ابن أبي حاتم ٢/٥٨٩.
  3,5,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿إِنَّ ٱللَّهَ لَا یَخۡفَىٰ عَلَیۡهِ شَیۡءࣱ فِی ٱلۡأَرۡضِ وَلَا فِی ٱلسَّمَاۤءِ ۝٥﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">١١٨٩٣<span class="dash">-</span></span> عن <span class="name-3">محمد بن جعفر بن الزبير</span> -من طريق ابن إسحاق- <span class="qpc-hafs">﴿إن الله لا يخفى عليه شيء في الأرض ولا في السماء﴾</span>: أي: قد علم ما يُرِيدون، وما يَكِيدون، وما يُضاهون بقولهم في عيسى، إذ جعلوه ربًّا وإلهًا، وعندهم من عِلْمِه غير ذلك؛ غِرَّةً بالله، وكفرًا به{1}. (٣/٤٤٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٨٩٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿إن الله لا يخفى عليه شيء في الأرض ولا في السماء﴾</span>، يعني: شيء من أهل السماء، ولا من أهل الأرض، كُلُّ ذلك عنده{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٨٩٥<span class="dash">-</span></span> عن <span class="name-3">محمد بن إسحاق</span> -من طريق عبد الله بن إدريس- قوله: <span class="qpc-hafs">﴿إن الله لا يخفى عليه شيء في الأرض ولا في السماء﴾</span>: لا يخفى عليه في الأرض ولا في السماء مِمّا جاءوا يريدون، ويَكِيدُون{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٨٩٦<span class="dash">-</span></span> عن <span class="name-3">محمد بن إسحاق</span> -من طريق إبراهيم بن سعد- <span class="qpc-hafs">﴿إن الله لا يخفى عليه شيء في الأرض ولا في السماء﴾</span>: أي: قد علم ما يُريدون، وما يَكيدون، وما يُضاهِئُون بقولهم في عيسى، إذ جعلوه ربًّا وإلهًا، وعندهم من عِلْمِه غير ذلك؛ غِرَّةً بالله، وكفرًا به{4}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ٥/١٨٢-١٨٦.تفسير مقاتل بن سليمان ١/٢٦٣.أخرجه ابن أبي حاتم ٢/٥٩٠.أخرجه ابن المنذر ١/١٢٤-١٢٥، وابن أبي حاتم ٢/٥٩٠ من طريق سلمة.
  3,6,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿هُوَ ٱلَّذِی یُصَوِّرُكُمۡ فِی ٱلۡأَرۡحَامِ كَیۡفَ یَشَاۤءُۚ﴾</span> - نزول الآية</h3></p><p><div></p><p><p><span class="item-no">١١٨٩٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿هو الذي يصوّركم في الأرحام كيف يشاء﴾</span> نزلت في عيسى ابن مريم ﷺ، خلقه من غير أب، ذكرًا وأنثى، سويًّا وغير سويٍّ، <span class="qpc-hafs">﴿لا إله إلا هو العزيز﴾</span> في ملكه، <span class="qpc-hafs">﴿الحكيم﴾</span> في أمره. نزلت هذه الآية في قولهم، وما قالوا من البهتان والزور لعيسى ﷺ{1}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿هُوَ ٱلَّذِی یُصَوِّرُكُمۡ فِی ٱلۡأَرۡحَامِ كَیۡفَ یَشَاۤءُۚ﴾</span> - تفسير الآية</h3></p><p><div></p><p><p><span class="item-no">١١٨٩٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن مسعود</span>، في قوله: <span class="qpc-hafs">﴿يصوركم في الأرحام كيف يشاء﴾</span>، قال: ذكورًا، وإناثًا{2}. (٣/٤٤٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٨٩٩<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن مسعود</span> -من طريق أيّوب بن عبد الله الفهري- قال: <span class="qpc-hafs">﴿هو الذي يصوّركم في الأرحام كيف يشاء﴾</span>، قال: يُؤتى بما في الأرحام، فينظر فيها ثلاث ساعات{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٩٠٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن مسعود</span> و<span class="name-1">ناس من أصحاب النبي</span> ﷺ -من طريق السدي، عن مرة الهمداني-= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٩٠١<span class="dash">-</span></span> و<span class="name-1">عبد الله بن عباس</span> -من طريق السدي، عن أبي مالك وأبي صالح- في قوله: <span class="qpc-hafs">﴿هو الذي يصوّركم في الأرحام كيف يشاء﴾</span>، قال: إذا وقعت النطفة في الأرحام طارت في الجسد أربعين يومًا، ثم تكون علقة أربعين يومًا، ثم تكون مضغة أربعين يومًا، فإذا بلغ أن يُخْلق بعث الله مَلَكًا يُصَوِّرها، فيأتي الملَك بتراب بين أصبعيه، فيخلط فيه المضغة، ثم يعجنه بها، ثم يُصَوِّره كما يؤمر، ثم يقول: أذَكَرٌ أم أنثى؟ أشقيٌّ أم سعيد؟ وما رِزقه؟ وما عمره؟ وما أثره؟ وما مصائبه؟ فيقول الله، ويكتب الملَك، فإذا مات ذلك الجسدُ دُفِن حيث أُخِذ ذلك التراب{4}. (٣/٤٤٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٩٠٢<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دِعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿هو الذي يصوّركم في الأرحام كيف يشاء﴾</span>، قال: قادِرٌ -واللهِ- ربُّنا أن يُصَوِّر عباده في الأرحام كيف يشاء؛ من ذكر أو أنثى، أو أسود أو أحمر، تامٍّ خَلْقُه وغيرِ تامٍّ{5}. (٣/٤٤٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٩٠٣<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيِّ</span> -من طريق أسباط- في قوله: <span class="qpc-hafs">﴿هو الذي يصوّركم في الأرحام كيف يشاء﴾</span>، قال: إذا وقعت النُّطْفَةُ في الرَّحِم طارت في الجسد أربعين يومًا، ثم تكون علقة أربعين يومًا، ثم تكون مضغة أربعين يومًا، فإذا بلغ أن يُخْلَق بعث الله ملَكًا يُصَوِّرُها، فيأتي الملَك بتراب بين أصبعيه، فيخلط فيه المضغة، ثم يعجنه بها، ثم يصوره كما يؤمر، ثم يقول: أذَكرٌ أم أنثى؟ أشقيٌّ أم سعيد؟ وما رِزقه؟ وما عمره؟ وما أثره؟ وما مصائبه؟ فيقول الله، ويكتب الملَك، فإذا مات ذلك الجسدُ دُفِن حيث أُخِذ ذلك التراب{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٩٠٤<span class="dash">-</span></span> عن <span class="name-2">الربيع بن أنس</span> -من طريق أبي جعفر- <span class="qpc-hafs">﴿هو الذي يصوّركم في الأرحام كيف يشاء﴾</span>: أي: أنه صوَّر عيسى في الرَّحِم كيف شاء{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٩٠٥<span class="dash">-</span></span> عن <span class="name-3">محمد بن جعفر بن الزبير</span> -من طريق ابن إسحاق- <span class="qpc-hafs">﴿هو الذي يصوّركم في الأرحام كيف يشاء﴾</span>: قد كان عيسى مِمَّن صُوِّر في الأرحام، لا يدفعون ذلك ولا يُنكِرُونه، كما صُوِّر غيرُه من بني آدم، فكيف يكون إلهًا وقد كان بذلك المَنزِل؟!{8}. (٣/٤٤٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٩٠٦<span class="dash">-</span></span> عن <span class="name-3">محمد بن إسحاق</span> -من طريق إبراهيم بن سعد-، مثله{9}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿لَاۤ إِلَـٰهَ إِلَّا هُوَ ٱلۡعَزِیزُ ٱلۡحَكِیمُ ۝٦﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">١١٩٠٧<span class="dash">-</span></span> عن <span class="name-2">أبي العالية الرِّياحِيِّ</span> -من طريق الربيع- في قوله: <span class="qpc-hafs">﴿العزيز الحكيم﴾</span>، قال: العزيزُ في نِقمته إذا انتقم، الحكيمُ في أمره{10}. (٣/٤٤٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٩٠٨<span class="dash">-</span></span> عن <span class="name-3">محمد بن جعفر بن الزبير</span> -من طريق ابن إسحاق- قال: ثُمَّ قال -يعني: الرَّبَّ ﷿ إنزاهًا لنفسه، وتوحيدًا لها مِمّا جعلوا معه: <span class="qpc-hafs">﴿لا إله إلا هو العزيز الحكيم﴾</span>، قال: العزيزُ في نُصْرَتِه مِمَّن كَفَر به إذا شاء، والحكيم في عُذْرِه وحُجَّته إلى عباده{11}<span class=comment-ref>١١٠١</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>١١٠١</span> لم يذكر <u>ابنُ جرير</u> (٥/١٨٤) غير هذا القول وما في معناه.</div></p><p><div></p><p><p><span class="item-no">١١٩٠٩<span class="dash">-</span></span> عن <span class="name-3">محمد بن إسحاق</span> -من طريق إبراهيم بن سعد-، مثله{12}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٩١٠<span class="dash">-</span></span> عن <span class="name-2">الربيع بن أنس</span> -من طريق أبي جعفر- <span class="qpc-hafs">﴿لا إله إلا هو العزيز الحكيم﴾</span>، يقول: عزيز في نِقْمَتِه، حكيم في أمره{11}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٩١١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿العزيز﴾</span> في ملكه، <span class="qpc-hafs">﴿الحكيم﴾</span> في أمره{1}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ١/٢٦٣.أخرجه ابن المنذر (٢١٥).أخرجه ابن أبي حاتم ٢/٥٩٠.أخرجه ابن جرير ٥/١٨٦-١٨٧.أخرجه ابن جرير ٥/١٨٧، وابن أبي حاتم ٢/٥٩٠-٥٩١ من طريق شيبان. وعزاه السيوطي إلى عَبد بن حُمَيد.أخرجه ابن أبي حاتم ٢/٥٩٠.أخرجه ابن جرير ٥/١٨٦.أخرجه ابن جرير ٥/١٨٢، ١٨٦.أخرجه ابن المنذر ١/١٢٥.أخرجه ابن أبي حاتم ٢/٥١٩.أخرجه ابن جرير ٥/١٨٨.أخرجه ابن المنذر ١/١٢٥، وابن أبي حاتم ٢/٥٩١ مختصرًا.أخرجه ابن جرير ٥/١٨٨.تفسير مقاتل بن سليمان ١/٢٦٣.
  3,7,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿هُوَ ٱلَّذِیۤ أَنزَلَ عَلَیۡكَ ٱلۡكِتَـٰبَ مِنۡهُ ءَایَـٰتࣱ مُّحۡكَمَـٰتٌ هُنَّ أُمُّ ٱلۡكِتَـٰبِ وَأُخَرُ مُتَشَـٰبِهَـٰتࣱۖ فَأَمَّا ٱلَّذِینَ فِی قُلُوبِهِمۡ زَیۡغࣱ فَیَتَّبِعُونَ مَا تَشَـٰبَهَ مِنۡهُ ٱبۡتِغَاۤءَ ٱلۡفِتۡنَةِ وَٱبۡتِغَاۤءَ تَأۡوِیلِهِۦۖ وَمَا یَعۡلَمُ تَأۡوِیلَهُۥۤ إِلَّا ٱللَّهُۗ وَٱلرَّ ٰ⁠سِخُونَ فِی ٱلۡعِلۡمِ یَقُولُونَ ءَامَنَّا بِهِۦ كُلࣱّ مِّنۡ عِندِ رَبِّنَاۗ وَمَا یَذَّكَّرُ إِلَّاۤ أُو۟لُوا۟ ٱلۡأَلۡبَـٰبِ ۝٧﴾</span> - نزول الآية</h3></p><p><div></p><p><p><span class="item-no">١١٩١٢<span class="dash">-</span></span> عن عبد الله بن عباس، عن <span class="name-1">جابر بن عبد الله بن رئاب</span> -من طريق ابن إسحاق، عن الكلبي، عن أبي صالح- قال: مَرَّ أبو ياسر بن أخْطَب، فجاء رجلٌ من يهود لرسول الله ﷺ، وهو يتلو فاتحة سورة البقرة: <span class="qpc-hafs">﴿الم ذلك الكتاب لا ريب فيه﴾</span>. فأتى أخاه حُيَيَّ بن أخْطَبَ في رِجالٍ من اليهود، فقال: أتعلمون، واللهِ، لقد سمعتُ محمدًا يتلو فيما أنزل عليه: <span class="qpc-hafs">﴿الم ذلك الكتاب﴾</span>. فقال: أنت سمعتَه؟ قال: نعم. فمشى حتى وافى أولئك النفر إلى رسول الله ﷺ، فقالوا: ألم تقل: إنّك تتلو فيما أُنزل عليك: <span class="qpc-hafs">﴿الم ذلك الكتاب﴾</span>؟ فقال: «<b>بلى»</b>. فقالوا: لقد بُعث بذلك أنبياء، ما نعلمُه بُيِّن لنبيٍّ منهم ما مُدَّةُ مُلْكِه وما أجَلُ{1} أُمَّتِهِ غيرَك! الألف واحدة، واللام ثلاثون، والميم أربعون، فهذه إحدى وسبعون سنة. ثم قال: يا محمد، هل مع هذا غيره؟ قال: <b>«نعم</b>، <b><span class="qpc-hafs">﴿المص﴾</span></b>». قال: هذه أثقلُ وأطولُ، الألف واحدة، واللام ثلاثون، والميم أربعون، والصاد تسعون، فهذه إحدى وثلاثون ومائة، هل مع هذا غيره؟ قال: <b>«نعم</b>، <b><span class="qpc-hafs">﴿الر﴾</span></b>». قال: هذه أثقل وأطول، الألف واحدة، واللام ثلاثون، والراء مائتان، هذه إحدى وثلاثون ومائتا سنة، هل مع هذا غيره؟ قال: <b>«نعم</b>، <b><span class="qpc-hafs">﴿المر﴾</span>»</b>. قال: هذه أثقل وأطول، هذه إحدى وسبعون ومائتان. ثُمَّ قال: لقد لُبِّس علينا أمرُك حتى ما ندري أقليلًا أُعطيتَ أم كثيرًا؟! ثم قال: قوموا عنه. ثم قال أبو ياسر لأخيه ومَن معه: ما يدريكم، لعلَّه قد جُمِع هذا كله لمحمد؟! إحدى وسبعون، وإحدى وثلاثون ومائة، وإحدى وثلاثون ومائتان، وإحدى وسبعون ومائتان، فذلك سبعمائة وأربع سنين. فقالوا: لقد تشابه علينا أمرُه. فيزعمون: أنّ هذه الآيات نزلت فيهم: <span class="qpc-hafs">﴿هو الذي أنزل عليك الكتاب منه آيات محكمات هن أم الكتاب وأخر متشابهات﴾</span>{2}. (٣/٤٥٠-٤٥٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٩١٣<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، و<span class="name-1">جابر بن رئاب</span> -من طريق سعيد بن جبير-: أنّ أبا ياسر بن أخْطَب مَرَّ بالنبي ﷺ وهو يقرأ فاتحة الكتاب، و<span class="qpc-hafs">﴿الم ذلك الكتاب﴾</span>. فذكر القصّة{3}. (٣/٤٥٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٩١٤<span class="dash">-</span></span> وعن <span class="name-3">عبد الملك ابن جُرَيْج</span> -من طريق محمد بن ثور- نحوه{4}. (٣/٤٥٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٩١٥<span class="dash">-</span></span> عن الربيع: أنّ النصارى قالوا لرسول الله ﷺ: ألستَ تزعم أنّ عيسى كلمة الله وروح منه؟ قال: <b>«بلى»</b>. قالوا: فحسبُنا. فأنزل الله: <span class="qpc-hafs">﴿فأما الذين في قلوبهم زيغ فيتبعون ما تشابه منه ابتغاء الفتنة﴾</span>{5}. (٣/٤٥٨)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿هُوَ ٱلَّذِیۤ أَنزَلَ عَلَیۡكَ ٱلۡكِتَـٰبَ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">١١٩١٦<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن مسعود</span>، قال: إنّ القرآن أُنزِل على نبيِّكم ﷺ من سبعة أبواب، على سبعة أحرف، وإنّ الكتاب قبلكم كان ينزل من باب واحد، على حرف واحد{6}. (٣/٤٥٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٩١٧<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span> -من طريق عطاء بن دينار- في قول الله: <span class="qpc-hafs">﴿هو الذي أنزل عليك الكتاب﴾</span>، يعني: القرآن{7}<span class=comment-ref>١١٠٢</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>١١٠٢</span> نَقَل <u>ابنُ عَطِيَّة</u> (٢/١٥٥) <span class="mustanad">الإجماعَ</span> على أنّ المراد بـ<span class="qpc-hafs">﴿الكتاب﴾</span>: القرآن، فقال: «و<span class="qpc-hafs">﴿الكتاب﴾</span> في هذه الآية: القرآن، بإجماعٍ من المتأولين».</div></p><p><h3><span class="qpc-hafs">﴿مِنۡهُ ءَایَـٰتࣱ مُّحۡكَمَـٰتٌ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">١١٩١٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عبد الله بن قيس- أنّه قال: في قوله: <span class="qpc-hafs">﴿منه آيات محكمات﴾</span>، قال: الثلاث آيات من آخر سورة الأنعام محكمات؛ <span class="qpc-hafs">﴿قل تعالوا﴾</span> والآيتان بعدها [الأنعام:١٥١-١٥٣]{8}. (٣/٤٤٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٩١٩<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق العَوّام، عمَّن حَدَّثه- في قوله: <span class="qpc-hafs">﴿آيات محكمات﴾</span>، قال: مِن ههنا: <span class="qpc-hafs">﴿قل تعالوا﴾</span> إلى آخر ثلاث آيات [الأنعام:١٥١-١٥٣]، ومِن ههنا: <span class="qpc-hafs">﴿وقضى ربك ألا تعبدوا إلا إياه﴾</span> إلى ثلاث آيات بعدها [الإسراء:٢٣-٢٥]{9}<span class=comment-ref>١١٠٣</span>. (٣/٤٤٧)</p></p><p></div></p><p><div><span class=comment-ref>١١٠٣</span> <span class="comment-type-4">عَلَّق</span> <u>ابنُ عطية</u> (٢/١٥٦) على قول ابن عباس هذا بقوله: «وهذا عندي مِثالٌ أعْطاهُ في المُحْكَمات».</div></p><p><div></p><p><p><span class="item-no">١١٩٢٠<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span>، نحو ذلك{10}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٩٢١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، قال: <span class="qpc-hafs">﴿محكمات﴾</span>: الحلالُ، والحرام{11}. (٣/٤٤٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٩٢٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن مسعود</span> و<span class="name-1">ناس من أصحاب النبي</span> ﷺ -من طريق السُّدِّيِّ، عن مُرَّة الهمداني-= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٩٢٣<span class="dash">-</span></span> و<span class="name-1">عبد الله بن عباس</span> -من طريق السدي، عن أبي مالك وأبي صالح- في قوله: <span class="qpc-hafs">﴿هو الذي أنزل عليك الكتاب منه آيات محكمات هن أم الكتاب﴾</span> إلى قوله: <span class="qpc-hafs">﴿كل من عند ربنا﴾</span>: أمّا الآيات المحكمات فهُنَّ الناسخات التي يُعْمَل بهن، وأما المُتشابهات فهنَّ المنسوخات{12}<span class=comment-ref>١١٠٤</span>. (٣/٤٤٨)</p></p><p></div></p><p><div><span class=comment-ref>١١٠٤</span> <span class="comment-type-4">علَّق</span> <u>ابنُ عطية</u> (٢/١٥٦) على هذا القول الذي قال به ابن مسعود، وابن عباس -من طريق علي، والعوفي- وقتادة، والربيع، والضحاك، بقوله: «وهذا عندي على جهة التَّمْثِيل، أي: يوجد الإحكام في هذا، والتشابهُ في هذا، لا أنّه وقْفٌ على هذا النوع من الآيات».</div></p><p><div></p><p><p><span class="item-no">١١٩٢٤<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عليٍّ- قال: <span class="qpc-hafs">﴿محكمات﴾</span>: ناسخه، وحلاله، وحرامه، وحدوده، وفرائضه، وما يُؤمَن به، ويُعمَل به{13}. (٣/٤٤٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٩٢٥<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق العوفي- قال: <span class="qpc-hafs">﴿محكمات﴾</span>: الناسخ الذي يُدان به، ويُعمَل به{14}. (٣/٤٤٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٩٢٦<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عليِّ بن أبي طلحة- قوله: <span class="qpc-hafs">﴿هو الذي أنزل عليك الكتاب منه آيات محكمات هنّ أم الكتاب﴾</span>: المحكمات: ناسخه، وحلاله، وحرامه، وحدوده، وفرائضه، وما يُؤمَن به، ويُعْمَل به{15}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٩٢٧<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نَجِيح- قال: المحكماتُ: ما فيه الحلالُ والحرامُ، وما سوى ذلك منه مُتشابِهٌ يُصَدِّقُ بعضُه بعضًا. مثل قوله: <span class="qpc-hafs">﴿وما يضل به إلا الفاسقين﴾</span> [البقرة:٢٦]، ومثل قوله: <span class="qpc-hafs">﴿كذلك يجعل الله الرجس على الذين لا يؤمنون﴾</span> [الأنعام:١٢٥]، ومثل قوله: <span class="qpc-hafs">﴿والذين اهتدوا زادهم هدى وآتاهم تقواهم﴾</span> [محمد:١٧]{16}<span class=comment-ref>١١٠٥</span>. (٣/٤٤٨)</p></p><p></div></p><p><div><span class=comment-ref>١١٠٥</span> <span class="comment-type-2">انتَقَدَ</span> <u>ابنُ كثير</u> (٣/٨-٩) <span class="mustanad">مستندًا إلى القرآن</span> كونَ قولِ مجاهد تفسيرًا لهذه الآية بقوله: «وهذا إنّما هو في تفسير قوله: <span class="qpc-hafs">﴿كتابًا متشابهًا مثاني﴾</span> [الزمر:٢٣]، هناك ذكروا: أنّ المتشابه هو الكلام الذي يكون في سياق واحد، والمثاني هو الكلام في شيئين متقابلين؛ كصفة الجنة وصفة النار، وذكر حال الأبرار ثم حال الفجار ونحو ذلك، فأمّا هاهنا فالمتشابه هو الذي يقابل المُحْكَم».</p><p>و<span class="comment-type-4">بنحوه</span> قال <u>ابنُ تيمية</u> (٢/٢٩)، وزاد فقال: «كذلك قوله: <span class="qpc-hafs">﴿فيتبعون ما تشابه منه ابتغاء الفتنة﴾</span> لو أريد بالمتشابه تصديق بعضه بعضًا لكان اتِّباع ذلك غير محذور، وليس في كونه يُصَدِّق بعضه بعضًا ما يمنع ابتغاء تأويله».</div></p><p><div></p><p><p><span class="item-no">١١٩٢٨<span class="dash">-</span></span> عن <span class="name-2">الضحاك بن مُزاحِم</span> -من طريق سلمة بن نُبَيْط- قال: المُحْكَم: ما لم يُنسَخ{17}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٩٢٩<span class="dash">-</span></span> عن <span class="name-2">الضحاك بن مُزاحِم</span> -من طريق جُوَيْبِر- في قوله: <span class="qpc-hafs">﴿آيات محكمات هن أم الكتاب﴾</span>، قال: النّاسِخات{18}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٩٣٠<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span>، مثله{19}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٩٣١<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٩٣٢<span class="dash">-</span></span> و<span class="name-2">مجاهد بن جبر</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٩٣٣<span class="dash">-</span></span> و<span class="name-2">قتادة بن دِعامة</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٩٣٤<span class="dash">-</span></span> و<span class="name-2">الضحاك بن مُزاحِم</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٩٣٥<span class="dash">-</span></span> و<span class="name-3">مقاتل بن حيان</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٩٣٦<span class="dash">-</span></span> و<span class="name-2">الربيع بن أنس</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٩٣٧<span class="dash">-</span></span> و<span class="name-2">إسماعيل السُّدِّيّ</span>، قالوا: المُحْكَم: الذي يُعْمَل به{10}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٩٣٨<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دِعامة</span> -من طريق مَعْمَر- في قوله: <span class="qpc-hafs">﴿آيات محكمات﴾</span>، قال: المُحْكَم: ما يُعمَل به{21}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٩٣٩<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دِعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿هو الذي أنزل عليك الكتاب منه آيات محكمات هن أم الكتاب﴾</span>: والمُحْكَمات: الناسخُ الذي يُعْمَل به؛ ما أحَلَّ الله فيه حلالَه، وحرَّم فيه حرامَه، وأما المتشابهات: فالمنسوخُ الذي لا يُعْمَل به، ويُؤْمَنُ به{22}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٩٤٠<span class="dash">-</span></span> عن <span class="name-2">الربيع بن أنس</span> -من طريق سليمان بن عامر- قال: المُحْكَمات: هي الآمِرَةُ، الزّاجِرَةُ{23}. (٣/٤٤٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٩٤١<span class="dash">-</span></span> عن <span class="name-2">الربيع بن أنس</span> -من طريق أبي جعفر- <span class="qpc-hafs">﴿هو الذي أنزل عليك الكتاب منه آيات محكمات هن أم الكتاب وأخر متشابهات﴾</span>، قال: المُحْكَمات: الناسِخُ الذي يُعْمَلُ به{24}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٩٤٢<span class="dash">-</span></span> عن <span class="name-3">محمد بن جعفر بن الزبير</span> -من طريق ابن إسحاق- قال: المُحْكَمات حُجَّةُ الرَّبِّ، وعِصْمَةُ العبادِ، ودفعُ الخصومِ والباطلِ، ليس لها تصريفٌ ولا تحريفٌ عَمّا وُضِعَتْ عليه، <span class="qpc-hafs">﴿وأخر متشابهات﴾</span> في الصِّدق، لَهُنَّ تصريفٌ وتحريفٌ وتأويلٌ، ابتلى اللهُ فيهِنَّ العبادَ كما ابتلاهم في الحلال والحرام، لا يُصْرَفْنَ إلى الباطل، ولا يُحَرَّفْنَ عن الحقِّ{25}<span class=comment-ref>١١٠٦</span>. (٣/٤٤٩)</p></p><p></div></p><p><div><span class=comment-ref>١١٠٦</span> <span class="comment-type-3">رجَّح</span> <u>ابنُ عطية</u> (٢/١٥٧)، و<u>ابنُ كثير</u> (٣/٩) قولَ ابن الزبير من طريق ابن إسحاق، وقال <u>ابنُ عطية</u>: «وهذا أحسن الأقوال في هذه الآية». ولم يذكرا مستندًا.</div></p><p><div></p><p><p><span class="item-no">١١٩٤٣<span class="dash">-</span></span> قال <span class="name-3">محمد بن إسحاق</span> -من طريق سلمة-: <span class="qpc-hafs">﴿منه آيات محكمات﴾</span>، فهُنَّ حُجَّةُ الرَّبِّ، وعِصْمَةُ العباد، ودَمْغُ الخصومِ والباطلِ، ليس لَهُنَّ تصريفٌ ولا تحريفٌ عما وُضِعْنَ عليه{26}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٩٤٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثُمَّ قال سبحانه: <span class="qpc-hafs">﴿هو الذي أنزل عليك الكتاب منه آيات محكمات﴾</span>، يُعْمَل بِهِنَّ، وهُنَّ الآيات التي في الأنعام [١٥١-١٥٣] قوله سبحانه: <span class="qpc-hafs">﴿قل تعالوا أتل ما حرم ربكم عليكم ألا تشركوا به شيئا وبالوالدين إحسانا﴾</span> إلى ثلاث آيات آخرهن: <span class="qpc-hafs">﴿لعلكم تتقون﴾</span>{27}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٩٤٥<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- وقرأ: <span class="qpc-hafs">﴿الر كتاب أحكمت آياته ثم فصلت من لدن حكيم خبير﴾</span> [هود:١]، قال: وذَكَرَ حديثَ رسول الله ﷺ في أربع وعشرين آية منها، وحديثَ نوح في أربع وعشرين آية منها، ثُمَّ قال: <span class="qpc-hafs">﴿تلك من أنباء الغيب﴾</span> [هود:٤٩]، ثم ذَكَر: <span class="qpc-hafs">﴿وإلى عاد﴾</span> [هود:٥٠] فقرأ حتى بلغ: <span class="qpc-hafs">﴿استغفروا ربكم﴾</span> [هود:٥٢]، ثُمَّ مَضى، ثُمَّ ذَكَر صالحًا وإبراهيم ولوطًا وشعيبًا، وفرغ من ذلك، وهذا يقينٌ، ذلك يقينٌ أُحْكِمَت آياته ثُمَّ فُصِّلَتْ. قال: والمتشابهُ ذِكْرُ موسى في أمْكِنَةٍ كثيرة، وهو متشابه، وهو كُلُّه معنًى واحد ومتشابه: <span class="qpc-hafs">﴿فاسلك فيها﴾</span> [المؤمنون:٢٧]، <span class="qpc-hafs">﴿احمل فيها﴾</span> [هود:٤٠]. <span class="qpc-hafs">﴿اسلك يدك﴾</span> [القصص:٣٢]، <span class="qpc-hafs">﴿وأدخل يدك﴾</span> [النمل:١٢]. <span class="qpc-hafs">﴿حية تسعى﴾</span> [طه:٢٠]، <span class="qpc-hafs">﴿ثعبان مبين﴾</span> [الأعراف:١٠٧، والشعراء:٣٢]. قال: ثم ذكر هودًا في عشر آيات منها، وصالحًا في ثماني آيات منها، وإبراهيم في ثماني آيات أخرى، ولوطًا في ثماني آيات منها، وشعيبًا في ثلاث عشرة آية، وموسى في أربع آيات، كل هذا يقضي بين الأنبياء وبين قومهم في هذه السورة، فانتهى ذلك إلى مائة آية من سورة هود، ثم قال: <span class="qpc-hafs">﴿ذلك من أنباء القرى نقصه عليك منها قائم وحصيد﴾</span> [هود:١٠٠]. وقال في المتشابه من القرآن: مَن يُرِدِ الله به البلاءَ والضلالةَ يقولُ: ما شَأْنُ هذا لا يكون هكذا؟! وما شأَنْ هذا لا يكون هكذا؟!{28}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿هُنَّ أُمُّ ٱلۡكِتَـٰبِ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">١١٩٤٦<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span> -من طريق عطاء بن دينار- <span class="qpc-hafs">﴿هنّ أم الكتاب﴾</span>، قال: أصلُ الكتاب؛ لأنّهُنَّ مكتوبات في جميع الكتب{29}. (٣/٤٤٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٩٤٧<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جَبْر</span>، في قوله: <span class="qpc-hafs">﴿هن أم الكتاب﴾</span>، يعني: ما فيه من الحلال والحرام، وما سوى ذلك منه مُتشابِهٌ{30}<span class=comment-ref>١١٠٧</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>١١٠٧</span> نقل <u>ابنُ عطية</u> (٢/١٥٧) خِلافَ المفسرين في تعيين المحكم والمتشابه.</p><p>و<span class="comment-type-1">وجَّه</span> بعض الأقوال بأنّها خارِجةٌ على المثال.</p><p>ثُمَّ <span class="comment-type-2">انتَقَدَ</span> حَصْرَ المعنى في قولٍ منها <span class="mustanad">مستندًا إلى دلالة عقلية</span>، فقال بعد ذكره لقول ابن عباس، وابن مسعود، والربيع، وقتادة، والضحاك، وما في معناها: «وهذه الأقوال وما ضارعها يضعفها أنّ أهل الزَّيْغِ لا تَعَلُّقَ لهم بنوعٍ مِمّا ذُكِر دون سواه».</div></p><p><div></p><p><p><span class="item-no">١١٩٤٨<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق مالك بن دينار- في قوله: <span class="qpc-hafs">﴿أم الكتاب﴾</span>، قال: الحلال، والحرام. قلتُ له: فـ<span class="qpc-hafs">﴿الحمد لله رب العالمين﴾</span>؟ قال: هذه أمُّ القرآن{31}. (٣/٤٤٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٩٤٩<span class="dash">-</span></span> عن <span class="name-2">يحيى بن يَعْمُر</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٩٥٠<span class="dash">-</span></span> و<span class="name-2">أبي فاخِتَة</span> -من طريق إسحاق بن سويد- أنّهما تَراجَعا هذه الآية: <span class="qpc-hafs">﴿هن أم الكتاب﴾</span>، فقال <span class="name-2">أبو فاخِتَة</span>: هُنَّ فواتحُ السُّوَرِ منها يُسْتَخْرَجُ القرآن؛ <span class="qpc-hafs">﴿الم ذلك الكتاب﴾</span> منها اسْتُخْرِجَتِ البقرةُ، و<span class="qpc-hafs">﴿الم الله لا إله إلا هو الحي القيوم﴾</span> منها اسْتُخْرِجَت آلُ عمران. قال <span class="name-2">يحيى</span>: هُنَّ اللاتي فيهِنَّ الفرائض، والأمر، والنهي، والحلالُ، والحدودُ، وعِمادُ الدِّين. وضرب لذلك مثلًا، فقال: أمُّ القرى: مكة. وأمُّ خراسان: مَرْو. وأمُّ المسافرين: الذين يجعلون إليه أمرهم، ويُعْنى بهم في سفرهم. قال: فذاك أُمُّهُم{32}<span class=comment-ref>١١٠٨</span>. (٣/٤٤٨-٤٤٩)</p></p><p></div></p><p><div><span class=comment-ref>١١٠٨</span> <span class="comment-type-2">انتَقَدَ</span> <u>ابنُ عطية</u> (٢/١٥٨-١٥٩) قولَ أبي فاختة: أنّ أُمَّ الكتاب هي فواتح السور؛ لمخالفته <span class="mustanad">ظاهر القرآن</span>، فقال: «وهذا قولٌ مُتَداعٍ للسقوط مُضْطَرِبٌ، لم ينظر قائلُه أوَّلَ الآية وآخرَها ومقصدَها. وإنّما معنى الآية: الإنحاءُ على أهلِ الزيغ والإشارة بذلك؛ أوّلًا إلى نصارى نجران وإلى اليهود الذين كانوا معاصرين لمحمد ﵇، فإنّهم كانوا يعترضون معاني القرآن، ثم تَعُمُّ بعد ذلك كُلَّ زائغ».</div></p><p><div></p><p><p><span class="item-no">١١٩٥١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: يقول: <span class="qpc-hafs">﴿هن أمّ الكتاب﴾</span>، يعني: أصلَ الكتاب؛ لأنّهُنَّ في اللوح المحفوظ مكتوبات، وهُنَّ مُحَرّمات على الأُمَم كُلِّها في كتابهم، وإنّما تَسَمَّيْنَ أُمَّ الكتاب لأَنَّهُنَّ مكتوباتٌ في جميع الكتب التي أنزلها الله -تبارك وتعالى- على جميع الأنبياء، وليس مِن أهل دِين إلا وهو يُوصى بِهِنَّ{33}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٩٥٢<span class="dash">-</span></span> عن <span class="name-3">مقاتل بن حيان</span> -من طريق بُكَيْر بن معروف- قال: إنّما قال: <span class="qpc-hafs">﴿هن أم الكتاب﴾</span> لأنّه ليس مِن أهل دينٍ إلا يَرْضى بِهِنَّ{34}. (٣/٤٤٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٩٥٣<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم -</span>من طريق ابن وهْب- في قوله: <span class="qpc-hafs">﴿هن أم الكتاب﴾</span>، قال: هُنَّ جِماعُ الكِتاب{35}<span class=comment-ref>١١٠٩</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>١١٠٩</span> ذكر <u>ابن عطية</u> (٢/١٥٨) أن المهدويَّ والنقّاش قالا: كل آية محكمة في كتاب الله يقال لها: أم الكتاب. وانتقده <span class="mustanad">مستندًا إلى ظاهر الآية</span>، فقال: «وهذا مردود، بل جميع المحكم هو أم الكتاب». وذكر أنّ النقّاش قال بأن مثال ذلك كما تقول: كلكم عَلَيَّ أسدٌ ضارٍ. وانتقد مثاله بأنه غير مُحْكم.</div></p><p><h3><span class="qpc-hafs">﴿وَأُخَرُ مُتَشَـٰبِهَـٰتࣱۖ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">١١٩٥٤<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عليٍّ- قال: <span class="qpc-hafs">﴿متشابهات﴾</span>: منسوخه، ومُقَدَّمه، ومُؤَخَّره، وأمثاله، وأقسامه، وما يُؤْمَن به ولا يُعْمَل به{13}. (٣/٤٤٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٩٥٥<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق العوفي- قال: <span class="qpc-hafs">﴿متشابهات﴾</span>: المنسوخات التي لا يُدان بِهِنَّ{14}. (٣/٤٤٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٩٥٦<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق باذام-: المتشابه: حروفُ التَّهَجِّي في أوائل السُّوَر{38}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٩٥٧<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن مسعود</span> و<span class="name-1">ناس من أصحاب النبي</span> ﷺ -من طريق السُّدِّيِّ، عن مُرَّة الهمداني-= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٩٥٨<span class="dash">-</span></span> و<span class="name-1">عبد الله بن عباس</span> -من طريق السدي، عن أبي مالك وأبي صالح- في قوله: <span class="qpc-hafs">﴿متشابهات﴾</span>: فَهُنَّ المنسوخات{12}. (٣/٤٤٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٩٥٩<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span>، قال: المتشابهاتُ: آياتٌ في القرآن يَتَشابَهْنَ على الناس إذا قَرَأُوهُنَّ، ومِن أجل ذلك يَضِلُّ مَن ضَلَّ، فكُلُّ فِرْقَةٍ يقرؤون آيةً من القرآن يزعمون أنها لهم، فمنها يتبع الحروريَّةُ مِن المتشابه قولَ الله: <span class="qpc-hafs">﴿ومن لم يحكم بما أنزل الله فأولئك هم الكافرون﴾</span> [المائدة:٤٤]، ثُمَّ يقرؤون معها: <span class="qpc-hafs">﴿والذين كفروا بربهم يعدلون﴾</span> [الأنعام:١]، فإذا رأوا الإمامَ يحكم بغير الحقِّ قالوا: قد كفر، فمَن كفر فقد عدل بربه، ومَن عدل بِرَبِّه فقد أشرك برَبِّه، فهؤلاء الأئِمَّةُ مُشْرِكون{40}. (٣/٤٤٩-٤٥٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٩٦٠<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جَبْر</span> -من طريق ابن جُرَيْج- <span class="qpc-hafs">﴿وأخر متشابهات﴾</span>، قال: يُصَدِّقُ بعضه بعضًا{23}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٩٦١<span class="dash">-</span></span> عن <span class="name-2">الضَّحّاك بن مُزاحِم</span> -من طريق جُوَيْبِر- <span class="qpc-hafs">﴿وأخر متشابهات﴾</span>، قال: ما نُسِخ وتُرِك يُتْلى{42}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٩٦٢<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دِعامة</span> -من طريق سعيد-: <span class="qpc-hafs">﴿وأخر متشابهات﴾</span>، أمّا المتشابهات: فالمنسوخُ الذي لا يُعْمَل به، ويُؤْمَنُ به{43}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٩٦٣<span class="dash">-</span></span> عن <span class="name-2">الربيع بن أنس</span> -من طريق أبي جعفر- قال: والمتشابهاتُ: المنسوخُ الذي لا يُعْمَلُ به، ويُؤْمَنُ به{44}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٩٦٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثُمَّ قال ﷿: <span class="qpc-hafs">﴿وأخر متشابهات﴾</span>: <span class="qpc-hafs">﴿الم﴾</span>، <span class="qpc-hafs">﴿المص﴾</span>، <span class="qpc-hafs">﴿المر﴾</span>، <span class="qpc-hafs">﴿الر﴾</span>، شُبّه على اليهود كَم تَمْلِكُ هذه الأُمَّةُ مِن السنين، والمتشابهات هؤلاء الكلمات الأربع{45}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٩٦٥<span class="dash">-</span></span> عن <span class="name-3">مقاتل بن حيان</span> -من طريق بُكَيْر بن معروف- قال: <span class="qpc-hafs">﴿وأخر متشابهات﴾</span>، يعني فيما بَلَغَنا: <span class="qpc-hafs">﴿الم﴾</span>، و<span class="qpc-hafs">﴿المص﴾</span>، و<span class="qpc-hafs">﴿المر﴾</span>، و<span class="qpc-hafs">﴿الر﴾</span>{46}. (٣/٤٤٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٩٦٦<span class="dash">-</span></span> عن <span class="name-3">محمد بن إسحاق</span> -من طريق ابن إدريس- <span class="qpc-hafs">﴿وأخر متشابهات﴾</span>، قال: لَمْ يُفَصَّل فيهِنَّ القولُ كفَصْلِه في المحكمات، تَتَشابَهُ في عقول الرجال، ويَتَخالَجُها التَّأْوِيلُ، فابتلى اللهُ فيها العبادَ كابتلائهم في الحلال والحرام{46}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٩٦٧<span class="dash">-</span></span> عن <span class="name-3">محمد بن إسحاق</span> -من طريق زياد- <span class="qpc-hafs">﴿وأخر متشابهات﴾</span>، قال: في الصِّدق، لَهُنَّ تحريفٌ، وتصريفٌ، وتأويلٌ، ابتلى الله فيهِنَّ العبادَ كما ابتلاهم في الحلال والحرام، أن يُصْرفن إلى الباطل، ولا يُحَرَّفْنَ عن الحقِّ{48}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿فَأَمَّا ٱلَّذِینَ فِی قُلُوبِهِمۡ زَیۡغࣱ﴾</span> - نزول الآية</h3></p><p><div></p><p><p><span class="item-no">١١٩٦٨<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span>، أنّه قال: نزلت في الخوارج{30}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٩٦٩<span class="dash">-</span></span> عن <span class="name-2">الربيع بن أنس</span> -من طريق أبي جعفر- قال: عمدوا -يعني: الوفد الذين قدموا على رسول الله ﷺ مِن نصارى نجران- فخاصموا النبيَّ ﷺ، قالوا: ألستَ تزعم أنّه كلمةُ الله، وروحٌ منه؟ قال: «<b>بلى</b>». قالوا: فحسبنا. فأنزل الله ﷿: <span class="qpc-hafs">﴿فأما الذين في قلوبهم زيغ فيتبعون ما تشابه منه ابتغاء الفتنة﴾</span>. ثم إنّ الله -جلَّ ثناؤُه- أنزل: <span class="qpc-hafs">﴿إن مثل عيسى عند الله كمثل آدم﴾</span> [آل عمران:٥٩]{50}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿فَأَمَّا ٱلَّذِینَ فِی قُلُوبِهِمۡ زَیۡغࣱ﴾</span> - تفسير الآية</h3></p><p><div></p><p><p><span class="item-no">١١٩٧٠<span class="dash">-</span></span> عن أبي أُمامة، عن النبي ﷺ، في قوله: <span class="qpc-hafs">﴿فأما الذين في قلوبهم زيغ فيتبعون ما تشابه منه﴾</span> قال: <b>«هم الخوارج»</b>. وفي قوله: <span class="qpc-hafs">﴿يوم تبيض وجوه وتسود وجوه﴾</span> [آل عمران:١٠٦] قال: <b>«هم الخوارج»</b>{51}<span class=comment-ref>١١١٠</span>. (٣/٤٥٤)</p></p><p></div></p><p><div><span class=comment-ref>١١١٠</span> <span class="comment-type-4">علَّق</span> <u>ابن كثير</u> (٣/١٢) على هذه الرواية بقوله: «وهذا الحديث أقل أقسامه أن يكون موقوفًا من كلام الصحابي، ومعناه صحيح؛ فإن أوَّل بدعة وقعت في الإسلام فتنة الخوارج، وكان مبدؤهم بسبب الدنيا حين قسَّم رسول الله ﷺ غنائم حُنَين، فكأنهم رأوا في عقولهم الفاسدة أنه لم يعدل في القسمة، ففاجؤوه بهذه المقالة، فقال قائلهم -وهو ذو الخويصرة، بقر الله خاصرته-: اعدل فإنك لم تعدل. فقال له رسول الله ﷺ: «لقد خِبتُ وخسرتُ إن لم أكن أعدل، أيأمنُني على أهل الأرض ولا تأمنوني؟!»».</div></p><p><div></p><p><p><span class="item-no">١١٩٧١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن مسعود</span> و<span class="name-1">ناس من أصحاب النبي</span> ﷺ -من طريق السُّدِّي، عن مُرَّة الهمداني-= (٣/٤٥٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٩٧٢<span class="dash">-</span></span> و<span class="name-1">عبد الله بن عباس</span> -من طريق السُّدِّيِّ، عن أبي مالك وأبي صالح- في قوله: <span class="qpc-hafs">﴿فأما الذين في قلوبهم زيغ﴾</span>، أما الزَّيْغُ: فالشكُّ{52}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٩٧٣<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي بن أبي طلحة- <span class="qpc-hafs">﴿فأما الذين في قلوبهم زيغ﴾</span>: يعني: أهل الشَّك، فيحملون المُحْكَم على المتشابه، والمتشابه على المُحْكَم، ويُلَبِّسُون؛ فلَبَّسَ اللهُ عليهم{53}. (٣/٤٥٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٩٧٤<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> –من طريق عطاء بن أبي رباح- <span class="qpc-hafs">﴿فأما الذين في قلوبهم زيغ﴾</span>، قال: هم أصحاب الخصومات والمِراء في دِين الله{54}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٩٧٥<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جَبْر</span> -من طريق ابن أبي نَجِيح- في قول الله: <span class="qpc-hafs">﴿في قلوبهم زيغ﴾</span>، قال: شَكٌّ{55}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٩٧٦<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دِعامة</span>، في قوله: <span class="qpc-hafs">﴿فأما الذين في قلوبهم زيغ﴾</span> الآية، قال: طلبَ القومُ التأويلَ، فأخطأوا التأويل، وأصابوا الفتنة، واتَّبعوا ما تشابه منه؛ فهلكوا بين ذلك{56}. (٣/٤٦٥-٤٦٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٩٧٧<span class="dash">-</span></span> عن مَعْمَر، قال: كان <span class="name-2">قتادةُ</span> إذا قرأ هذه الآية: <span class="qpc-hafs">﴿فأما الذين في قلوبهم زيغ﴾</span> قال: إن لم يكونوا الحَرُورِيَّةَ{57} والسَّبائِيَّة{58} فلا أدري مَن هم؟! ولَعَمْرِي، لَقد كان في أهل بدر والحديبية الذين شهدوا مع رسول الله ﷺ بيعةَ الرضوان من المهاجرين والأنصار خَبَرٌ لِمَنِ اسْتَخْبَر، وعِبْرَةٌ لِمَنِ اسْتَعْبَر، لِمَن كان يعقل أو يُبْصر. إنّ الخوارج خرجوا وأصحابُ رسول الله ﷺ يومئذ كثير بالمدينة والشام والعراق، وأزواجُه يومئذٍ أحياء، واللهِ، إنْ خرج منهم ذكرٌ ولا أنثى حَرُورِيًّا قط، ولا رضُوا الذي هم عليه، ولا مالَؤُوهم فيه، بل كانوا يُحَدِّثون بعَيْبِ رسول الله ﷺ إيّاهم، ونعتِه الذي نعتهم به، وكانوا يُبْغِضونهم بقلوبهم، ويعادونهم بألسنتهم، وتَشْتَدُّ -واللهِ- عليهم أيديهم إذا لَقوهم. ولعَمْرِي، لو كان أمرُ الخوارج هُدًى لاجتمع، ولكنَّه كان ضلالًا فتَفَرَّق، وكذلك الأمرُ إذا كان مِن عند غير الله وجدت فيه اختلافًا كثيرًا، فقد ألاصُوا{59} هذا الأمرَ مُنذُ زمان طويل، فهل أفلحوا فيه يومًا أو أنجحوا؟ يا سبحان الله! كيف لا يعتبر آخِرُ هؤلاء القوم بأوَّلِهم؟! لو كانوا على هُدًى قد أظهره الله وأَفْلَجَه ونصره، ولكنهم كانوا على باطلٍ أكذبه الله وأَدْحَضَه، فهم كما رأيتَهم؛ كُلَّما خرج لهم قَرْنٌ أدْحَضَ اللهُ حُجَّتهم، وأَكْذَب أُحْدُوثَتَهُم، وأَهْرَقَ دِماءَهم، وإن كتموا كان قَرْحًا في قلوبهم، وغمًّا عليهم، وإن أظهروه أهْراقَ اللهُ دِماءَهم، ذاكم -واللهِ- دينُ سُوءٍ؛ فاجْتَنِبُوه. واللهِ، إنّ اليهودية لَبِدْعَة، وإنّ النصرانية لَبِدْعَة، وإنّ الحَرُورِيَّة لَبِدْعَة، وإنّ السَّبائِيَّة لَبِدْعَة، ما نزل بِهِنَّ كتابٌ، ولا سَنَّهُنَّ نبيٌّ{60}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٩٧٨<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span>، في قول الله <span class="qpc-hafs">﴿في قلوبهم زيغ﴾</span>، قال: شَكٌّ{61}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٩٧٩<span class="dash">-</span></span> عن <span class="name-3">محمد بن جعفر بن الزبير</span> -من طريق ابن إسحاق- <span class="qpc-hafs">﴿فأما الذين في قلوبهم زيغ﴾</span>، أي: مَيْلٌ عن الهدى{62}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٩٨٠<span class="dash">-</span></span> عن <span class="name-3">محمد بن السائب الكلبي</span>: هم اليهود، طَلَبوا عِلْمَ أجلِ هذه الأمّة واستخراجها بحساب الجُمَّل{63}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٩٨١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فأما الذين في قلوبهم زيغ﴾</span>، يعني: مَيْل عن الهدى، وهو الشَّكُّ، فهُم اليهودُ{45}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٩٨٢<span class="dash">-</span></span> عن <span class="name-3">مقاتل بن حَيّان</span> -من طريق بُكَيْر بن معروف- في قوله: <span class="qpc-hafs">﴿فأما الذين في قلوبهم زيغ﴾</span>، يعني: حُيَيّ بن أخْطَب، وأصحابه مِن اليهود{65}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٩٨٣<span class="dash">-</span></span> عن <span class="name-3">عبد الملك بن جُرَيْج</span>، قال: <span class="qpc-hafs">﴿الذين في قلوبهم زيغ﴾</span> المنافقون{66}. (٣/٤٥٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٩٨٤<span class="dash">-</span></span> عن <span class="name-3">محمد بن إسحاق</span> -من طريق سلمة- <span class="qpc-hafs">﴿فأما الذين في قلوبهم زيغ﴾</span>: أي: مَيْل عن الهدى{67}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿فَیَتَّبِعُونَ مَا تَشَـٰبَهَ مِنۡهُ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">١١٩٨٥<span class="dash">-</span></span> عن عائشة -من طريق عبد الله بن أبي مُلَيْكة- قالت: قرأ رسول الله ﷺ: <span class="qpc-hafs">﴿هو الذي أنزل عليك الكتاب﴾</span> إلى قوله: <span class="qpc-hafs">﴿وما يذكر إلا أولو الألباب﴾</span>، فقال: <b>«فإذا رأيتُم الذين يُجادلون فيه فهُم الذين عنى اللهُ؛ فاحذروهم»</b>{68}. (٣/٤٥٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٩٨٦<span class="dash">-</span></span> عن حذيفة، عن رسول الله ﷺ، قال: <b>«إنّ في أُمَّتي قومًا يقرؤون القرآن، ينثُرُونَه نَثْر الدَّقَل{69}، يتأَوَّلونه على غير تأويله»</b>{70}. (٣/٤٥٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٩٨٧<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي بن أبي طلحة- <span class="qpc-hafs">﴿فيتّبعون ما تشابه منه﴾</span>، قال: فيحمِلُون المُحْكمَ على المتشابه، والمتشابِهَ على المُحْكَم، ويُلَبِّسُون؛ فلبَّس الله عليهم{71}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٩٨٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي بن أبي طلحة- في قوله -جلَّ وعَزَّ-: <span class="qpc-hafs">﴿فأما الذين في قلوبهم زيغ فيتّبعون ما تشابه منه﴾</span>، وقوله: <span class="qpc-hafs">﴿وتقطّعوا أمرهم بينهم﴾</span> [الأنبياء:٩٣]، وقوله ﷿: <span class="qpc-hafs">﴿إذا سمعتم آيات الله يكفر بها﴾</span> [النساء:١٤٠]، وقوله: <span class="qpc-hafs">﴿ولا تتبعوا السبل﴾</span> [الأنعام:١٥٣]، وقوله: <span class="qpc-hafs">﴿أقيموا الدين ولا تتفرقوا فيه﴾</span> [الشورى:١٣]، ونحو هذا في القرآن، قال: أمر الله المؤمنين بالجماعة، ونهاهم عن الاختلاف والفرقة في القرآن، وأخبرهم: إنّما هلك مَن كان قبلكم بالمِراء والخصومات في دين الله{72}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٩٨٩<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن جُرَيْج- في قوله: <span class="qpc-hafs">﴿فيتبعون ما تشابه منه﴾</span>، قال: الباب الذي ضلّوا منه، وهلكوا فيه ابتغاءَ تأويله{73}. (٣/٤٥٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٩٩٠<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- في قوله: <span class="qpc-hafs">﴿فيتّبعون ما تشابه منه﴾</span>، قال: يتّبعون المنسوخ والناسخ، فيقولون: ما بالُ هذه الآية عُمِل بها كذا وكذا مكان هذه الآية، فتُرِكت الأولى وعُمِل بهذه الأخرى؟ هلّا كان العملُ بهذه الآية قبل أن تجيء الأولى التي نُسخت! وما بالُه يَعِدُ العذابَ مَن عمِل عمَلًا يُعَذِّبُه بالنار، وفي مكان آخر مَن عمِله فإنّه لم يُوجِب له النار؟{74}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٩٩١<span class="dash">-</span></span> عن <span class="name-3">محمد بن جعفر بن الزبير</span> -من طريق ابن إسحاق- <span class="qpc-hafs">﴿فيتّبعون ما تشابه منه﴾</span>: أي: ما تَحَرَّفَ منه وتَصَرَّف، ليُصَدِّقُوا به ما ابْتَدَعُوا وأَحْدَثُوا، لِيَكُونَ لَهُم حُجَّةً على ما قالوا وشُبْهَةً{75}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٩٩٢<span class="dash">-</span></span> عن <span class="name-3">محمد بن إسحاق</span> -من طريق زياد-، مثله{76}<span class=comment-ref>١١١١</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>١١١١</span> اختلف المفسرون فيمَن عُني بهذه الآية؛ <b>فقال قومٌ</b>: عُنِي به الوفد من نصارى نجران الذين خاصموا الرسول ﷺ في أمر عيسى. و<b>ذهب آخرون</b> إلى نزولها في أبي ياسر بن أخطب، وأخيه، والنفر الذين ناظروا الرسول ﷺ في قدر مدة أُكله وأُكل أمته (أي: أجله في الدنيا)، وأرادوا عِلْمَ ذلك مِن قِبَل الحروف المقطعة. و<b>قال آخرون</b>: بل عنى اللهُ ﷿ بذلك كُلَّ مُبْتَدِعٍ في دينه.</p><p>و<span class="comment-type-4">قدَّم</span> <u>ابنُ جرير</u> (٥/٢١١-٢١٢) القولين الأولين، فقال: «والذي يَدُلُّ عليه ظاهرُ هذه الآية أنّها نزلت في الذين جادلوا رسول الله ﷺ بمتشابه ما أُنزِل إليه مِن كتاب الله؛ إمّا في أمر عيسى، وإمّا في مدة أُكله وأُكل أمته».</p><p>ثُمَّ <span class="comment-type-3">رَجَّح</span> القولَ الثاني منهما <span class="mustanad">مستندًا إلى ظاهر الآية</span>، فقال: «وهو بأن تكون في الذين جادلوا رسول الله ﷺ بمتشابهه في مدته ومده أمته أشبهُ؛ لأنّ قوله: <span class="qpc-hafs">﴿وما يعلم تأويله إلا الله﴾</span> دالٌّ على أنّ ذلك إخبارٌ عن المُدَّة التي أرادوا عِلْمَها من قِبَل المتشابه الذي لا يعلمه إلا الله، فأمّا أمر عيسى وأسبابُه فقد أعلم اللهُ ذلك نبيَّه محمدًا ﷺ وأُمَّتَه وبَيَّنَه لهم، فمعلومٌ أنّه لم يَعْنِ إلا ما كان خَفِيًّا عن الآحاد».</p><p>ثُمَّ <span class="comment-type-4">أفاد</span> (٥/٢١٤ بتصرف) انسحابَ الآيةِ بعد ذلك على كُلِّ مبتدع، فقال: «وهذه الآيةُ وإن كانت نزلت فيمَن ذكرنا أنّها نزلت فيه من أهل الشرك؛ فإنّه مَعْنِيٌّ بها كُلُّ مُبْتَدِعٍ في دين الله بِدْعَةً، فمال قلبُه إليها، تأويلًا منه لبعض متشابه آي القرآن، ثم حاجَّ به وجادلَ به أهل الحق، وعدل عن الواضح مِن أدلة آيِه المحكمات؛ إرادةً منه بذلك اللبس على أهل الحقِّ، وطلبًا لعلم تأويل ما تشابه عليه من ذلك كائنًا مَن كان».</p><p>و<span class="comment-type-3">رَجَّح</span> <u>ابنُ عطية</u> (٢/١٦٠) عمومَ المعنى.</div></p><p><h3><span class="qpc-hafs">﴿ٱبۡتِغَاۤءَ ٱلۡفِتۡنَةِ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">١١٩٩٣<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن جُرَيْج- في قوله: <span class="qpc-hafs">﴿ابتغاء الفتنة﴾</span>، قال: الشُّبُهات، بها أُهْلِكوا{77}. (٣/٤٥٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٩٩٤<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق سفيان بن حسين- في قوله: <span class="qpc-hafs">﴿ابتغاء الفتنة﴾</span>، قال: الضلالة{78}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٩٩٥<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- <span class="qpc-hafs">﴿ابتغاء الفتنة﴾</span>، قال: إرادة الشِّرْك{79}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٩٩٦<span class="dash">-</span></span> عن <span class="name-2">الربيع بن أنس</span> -من طريق أبي جعفر- في قوله: <span class="qpc-hafs">﴿ابتغاء الفتنة﴾</span>، يعني: الشِّرْك{80}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٩٩٧<span class="dash">-</span></span> عن <span class="name-3">مقاتل بن حيان</span>، نحو ذلك{81}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٩٩٨<span class="dash">-</span></span> عن <span class="name-3">محمد بن جعفر بن الزبير</span> -من طريق ابن إسحاق- في قوله: <span class="qpc-hafs">﴿ابتغاء الفتنة﴾</span>، أي: اللَّبْس{82}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١١٩٩٩<span class="dash">-</span></span> عن <span class="name-3">محمد بن إسحاق</span> -من طريق زياد-، مثله{83}<span class=comment-ref>١١١٢</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>١١١٢</span> <span class="comment-type-3">رَجَّح</span> <u>ابنُ جرير</u> (٥/٢١٤-٢١٥) قولَ مجاهد، وابن الزبير، وابن إسحاق <span class="mustanad">مستندًا إلى أحوال النزول</span>، فقال: «وإنّما قلنا: القول الذي ذكرنا أنّه أولى التأويلين بقوله: <span class="qpc-hafs">﴿ابتغاء الفتنة﴾</span> لأنّ الذين نزلت فيهم هذه الآية كانوا أهل شرك، وإنّما أرادوا بطلب تأويل ما طلبوا تأويله اللبسَ على المسلمين والاحتجاج به عليهم ليصدّوهم عَمّا هم عليه من الحقّ، فلا معنى لأن يُقال: فعلوا ذلك إرادة الشرك، وهم قد كانوا مشركين».</div></p><p><div></p><p><p><span class="item-no">١٢٠٠٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فيتبعون ما تشابه منه ابتغاء الفتنة﴾</span>، يعني: ابتغاء الكفر{45}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَٱبۡتِغَاۤءَ تَأۡوِیلِهِۦۖ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">١٢٠٠١<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق عبّاد بن منصور- في قوله: <span class="qpc-hafs">﴿وابتغاء تأويله﴾</span>، قال: تأويله القضاء به يوم القيامة{85}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٠٠٢<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دِعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿فأما الذين في قلوبهم زيغ فيتبعون ما تشابه منه ابتغاء الفتنة وابتغاء تأويله﴾</span>، قال: طلب القومُ التأويلَ فأخطَؤُوا التأويلَ، وأصابوا الفتنةَ، فاتَّبعوا ما تشابه منه؛ فهلكوا مِن ذلك{86}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٠٠٣<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيِّ</span> -من طريق أسباط- <span class="qpc-hafs">﴿وابتغاء تأويله﴾</span>، قال: أرادوا أن يعلموا تأويلَ القرآن، وهو عَواقِبُه{87}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٠٠٤<span class="dash">-</span></span> عن <span class="name-3">محمد بن جعفر بن الزبير</span> -من طريق ابن إسحاق- <span class="qpc-hafs">﴿وابتغاء تأويله﴾</span>، قال: وذلك على ما ركِبوا مِن الضلالة في قولهم: خلقنا، وقضينا{88}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٠٠٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وابتغاء تأويله﴾</span>، يعني: مُنتَهى ما يكون، وكم يكون، يريد بذلك الملك{45}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٠٠٦<span class="dash">-</span></span> عن <span class="name-3">مقاتل بن حَيّان</span> -من طريق بُكَيْر بن معروف- قوله: <span class="qpc-hafs">﴿ابتغاء تأويله﴾</span>، قال: ابتغاء ما يكون، وكم يكون{85}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٠٠٧<span class="dash">-</span></span> عن <span class="name-3">محمد بن إسحاق</span> –من طريق إبراهيم بن سعد- <span class="qpc-hafs">﴿وابتغاء تأويله﴾</span>، قال: ذلك ما رَكِبوا مِن الضَّلال في قولهم: خلقنا، وقضينا. يقول: <span class="qpc-hafs">﴿وما يعلم تأويله﴾</span> الذي به أراد وما أرادوا <span class="qpc-hafs">﴿إلا الله﴾</span>{91}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٠٠٨<span class="dash">-</span></span> عن <span class="name-3">محمد بن إسحاق</span> -من طريق ابن إدريس- قوله: <span class="qpc-hafs">﴿ابتغاء تأويله﴾</span>، قال: ما تَأَوَّلوا وزَيَّنُوا مِن الضلالة؛ لِيَجِيء لهم الَّذي في أيديهم مِن البدعة، ليكون لهم به حُجَّةً على مَن خالفهم للتَّصْرِيف والتَّحْرِيف الذي ابْتُلُوا به؛ كمَيْلِ الأهواء، وزَيْغِ القلوب، والتَّنكِيبِ عن الحق الذي أحْدَثوا مِن البِدْعة{85}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَمَا یَعۡلَمُ تَأۡوِیلَهُۥۤ إِلَّا ٱللَّهُۗ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">١٢٠٠٩<span class="dash">-</span></span> عن عبد الله بن عباس، قال: قال رسول الله ﷺ: «<b>أُنزِل القرآنُ على سبعة أحرف: حلالٍ وحرامٍ لا يُعْذَر أحدٌ بالجهالة به، وتفسيرٌ تُفَسِّرُه العرب، وتفسيرٌ تُفَسِّره العلماء، ومُتشابِهٍ لا يعلمه إلا الله، ومَنِ ادَّعى علمَه سوى الله فهو كاذِبٌ</b>»{93}. (٣/٤٦١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٠١٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي بن أبي طلحة- <span class="qpc-hafs">﴿وما يعلم تأويله إلا الله﴾</span>، قال: تأويله يوم القيامة لا يعلمه إلا الله{94}<span class=comment-ref>١١١٣</span>. (٣/٤٥٢)</p></p><p></div></p><p><div><span class=comment-ref>١١١٣</span> اختلف المفسّرون في معنى التأويل في قوله: <span class="qpc-hafs">﴿وابتغاء تأويله﴾</span>؛ <b>فقال بعضهم</b>: الأجل الذي أرادت اليهود أن تعرفه من انقضاء مُدَّةِ أمر النبي ﷺ وأُمَّتِه مِن قِبَل الحروف المقطّعة. و<b>قال آخرون</b>: بل معنى ذلك: عواقب القرآن، وقالوا: إنّما أرادوا أن يعلموا متى يجيء ناسخُ الأحكام التي كان الله -جل ثناؤه- شرعها لأهل الإسلام قبل مجيئه. و<b>قال آخرون</b>: بل معنى ذلك: وابتغاء تأويل ما تشابه مِن آي القرآن يتأوّلونه إذ كان ذا وجوه وتصاريف في التأويلات على ما في قلوبهم من الزيغ، وما ركبوه من الضلالة.</p><p>و<span class="comment-type-3">رَجَّح</span> <u>ابنُ جرير</u> (٥/٢١٦-٢١٧) القولَ الأول الذي قاله ابن عباس، والثاني الذي قاله السدي، <span class="mustanad">مستندًا إلى ظاهر الآية</span>، حيث إنّ طلب القوم معرفةَ الوقت الذي هو جاء قبل مجيئه، المحجوب علمه عنهم وعن غيرهم؛ موافق لإخبار الله بأنّه تأويلٌ لا يعلمه إلا هو، أمّا غيره من التأويل فقد عُلِم واشْتَهَر. لكنَّه <span class="comment-type-2">استَدْرَك</span> (٥/٢١٦-٢١٧) على القول الثاني الذي قاله السّدّي حَصْرَه معنى الآية في أنّ القوم طلبوا معرفة وقتِ مجيء الناسخ لِما قد أُحْكِم قبل ذلك.</div></p><p><div></p><p><p><span class="item-no">١٢٠١١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق ابن جريج- <span class="qpc-hafs">﴿وما يعلم تأويله إلا الله﴾</span>، قال: جزاءَه وثوابَه يوم القيامة{91}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٠١٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق مجاهد- <span class="qpc-hafs">﴿وما يعلم تأويله إلا الله﴾</span>، قال: تأويل القرآن{96}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٠١٣<span class="dash">-</span></span> عن هشام بن <span class="name-2">عروة بن الزبير</span> قال: كان <span class="name-2">أبي</span> يقول في هذه الآية <span class="qpc-hafs">﴿وما يعلم تأويله إلا الله والراسخون في العلم﴾</span>: إنّ الراسخين في العلم لا يعلمون تأويله، ولكنّهم يقولون: <span class="qpc-hafs">﴿آمنا به كل من عند ربنا﴾</span>{97}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٠١٤<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جَبْر</span> -من طريق ابن أبي نَجِيح- <span class="qpc-hafs">﴿وما يعلم تأويله إلا الله﴾</span>، قال: العِبارَة{96}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٠١٥<span class="dash">-</span></span> عن <span class="name-2">الضَّحاك بن مُزاحِم</span> -من طريق جُوَيْبِر- <span class="qpc-hafs">﴿وما يعلم تأويله إلا الله﴾</span>، قال لنا: ثوابه{96}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٠١٦<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط-: قال الله: <span class="qpc-hafs">﴿وما يعلم تأويله إلا الله﴾</span>، وتأويله: عواقبه؛ متى يأتي الناسخُ منه فينسخ المنسوخ{100}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٠١٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: يقول الله ﷿: <span class="qpc-hafs">﴿وما يعلم تأويله إلا الله﴾</span>، كم يملكون مِن السنين، يعني: أُمَّة محمد ﷺ، يملكون إلى يوم القيامة، إلا أيّامًا يبتليهم الله ﷿ بالدَّجّال{45}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٠١٨<span class="dash">-</span></span> عن <span class="name-3">مقاتل بن حَيّان</span> -من طريق بُكَيْر بن معروف- يقول الله: <span class="qpc-hafs">﴿وما يعلم تأويله إلا الله﴾</span>، قال: كم يملكون إلا الله{96}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٠١٩<span class="dash">-</span></span> عن <span class="name-3">محمد بن إسحاق</span> -من طريق ابن إدريس- قوله: <span class="qpc-hafs">﴿وما يعلم تأويله إلا الله﴾</span>، أي: ما يعلم ما حرَّفوا وتأويلَه إلا الله الذي يعلم سرائرَ العباد وأعمالَهم{96}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٠٢٠<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق أصْبَغ- <span class="qpc-hafs">﴿وما يعلم تأويله﴾</span>، قال: تحقيقه{96}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَمَا یَعۡلَمُ تَأۡوِیلَهُۥۤ إِلَّا ٱللَّهُۗ﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">١٢٠٢١<span class="dash">-</span></span> عن أبي مالك الأَشْعَرِيِّ، أنّه سمع رسول الله ﷺ يقول: «<b>لا أخاف على أُمَّتِي إلا ثلاثَ خِلال: أن يَكْثُر لهم المالُ فيتحاسدوا فيقتتلوا، وأن يُفْتَح لهم الكتابُ فيأخذه المؤمن يبتغي تأويله <span class="qpc-hafs">﴿وما يعلم تأويله إلا الله والراسخون في العلم يقولون آمنا به كل من عند ربنا وما يذكر إلا أولوا الألباب﴾</span>، وأن يزداد علمُهم فيُضَيِّعُوه ولا يُبالُوا به</b>»{105}. (٣/٤٥٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٠٢٢<span class="dash">-</span></span> عن أبي هريرة، أنّ رسول الله ﷺ قال: «<b>نزل القرآنُ على سبعة أحرف، المِراءُ في القرآن كُفْرٌ؛ ما عرفتم منه فاعملوا به، وما جهِلْتُم منه فَرُدُّوه إلى عالِمِه»</b>{106}. (٣/٤٥٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٠٢٣<span class="dash">-</span></span> عن أبي هريرة، قال: قال رسول الله ﷺ: <b>«أعْرِبوا القرآنَ، واتَّبِعوا غرائبَه، وغرائبُه: فرائضُه وحدودُه؛ فإنّ القرآن نزل على خمسة أوجه: حلال، وحرام، ومحكم، ومتشابه، وأمثال. فاعملوا بالحلال، واجتنبوا الحرام، واتَّبِعوا المحكم، وآمِنوا بالمتشابه، واعْتَبِروا بالأمثال»</b>{107}. (٣/٤٥٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٠٢٤<span class="dash">-</span></span> عن عمرو بن شعيب، عن أبيه، عن جدِّه: أنّ رسول الله ﷺ خرج على قوم يتراجعون في القرآن وهو مُغضَب، فقال: «<b>بهذا ضَلَّتِ الأممُ قبلَكم باختلافهم على أنبيائهم، وضَرْبِ الكتابِ بعضِه ببعض. قال: وإنّ القرآن لَمْ ينزل لِيُكَذِّبَ بعضُه بعضًا، ولكن نزل أن يُصَدِّق بعضُه بعضًا؛ فما عرفتم منه فاعملوا به، وما تشابه عليكم فآمِنوا به»</b>{108}. (٣/٤٥٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٠٢٥<span class="dash">-</span></span> عن عمرو بن شعيب، عن أبيه، عن جده [من وجه آخر]: سَمِع رسولُ الله ﷺ قومًا يَتَدارَأُون{109}، فقال: <b>«إنّما هَلَك مَن كان قبلكم بهذا، ضربوا كتاب الله بعضه ببعض، وإنّما نزل كتابُ الله يُصَدِّق بعضُه بعضًا؛ فلا تُكَذِّبوا بعضَه ببعض، فما علِمْتُم منه فقولوا، وما جهِلْتُم فكِلُوه إلى عالِمِه»</b>{110}. (٣/٤٥٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٠٢٦<span class="dash">-</span></span> عن عمر بن أبي سلمة، أنّ النبي ﷺ قال لعبد الله بن مسعود: «إ<b>نَّ الكُتُبَ كانت تنزل مِن السماء مِن باب واحد، وإنّ القرآن نزل من سبعة أبواب على سبعة أحرف: حلالٍ، وحرامٍ، ومُحْكَمٍ، ومُتشابِهٍ، وضرب أمثالٍ، وآمِرٍ، وزاجِرٍ؛ فأحِلَّ حلالَه، وحَرِّم حرامَه، واعْمَل بمُحْكَمِه، وقِف عند متشابهه، واعْتَبِر أمثالَه، فإنّ كُلًّا مِن عند الله</b>، <b><span class="qpc-hafs">﴿وما يذكر إلا أولوا الألباب﴾</span>»</b>{111}. (٣/٤٥٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٠٢٧<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن مسعود</span> -من طريق القاسم بن عبد الرحمن- قال: أُنزِل القرآن على خمسة أوجه: حرام، وحلال، ومحكم، ومتشابه، وأمثال؛ فأحِلّ الحلال، وحَرِّم الحرام، وآمِن بالمتشابه، واعْمَل بالمحكم، واعْتَبِر بالأمثال{112}. (٣/٤٥٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٠٢٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، قال: إنّ القرآن ذو شُجُونٍ وفُنُونٍ، وظُهورٍ وبطون، لا تنقضي عجائبُه، ولا تُبْلَغ غايَتُه، فمَن أوْغَلَ فيه برِفْقٍ نَجا، ومَن أوْغَل فيه بعُنفٍ غَوى، أخبارٌ وأمثال، وحرام وحلال، وناسخ ومنسوخ، ومُحْكَم ومتشابه، وظَهْرٌ وبَطْن، فظهره التلاوة، وبطنه التأويل، فجالِسوا به العلماء، وجانِبوا به السفهاء، وإيّاكم وزَلَّةَ العالِم{113}. (٣/٤٥٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٠٢٩<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق طاووس- وذُكِر عنده الخوارج، وما يلقون عند الفرار، فقال: يُؤْمِنون بمُحْكَمِه، ويهلكون عند متشابهه. وقرأ ابن عباس: <span class="qpc-hafs">﴿وما يعلم تأويله إلا الله﴾</span> الآية{114}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٠٣٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق أبي الزِّناد- قال: التفسيرُ على أربعة أوْجُهٍ: وجهٍ تعرفه العرب مِن كلامها، وتفسيرٍ لا يُعْذَر أحدٌ بجهالته، وتفسيرٍ يعلمه العلماء، وتفسيرٍ لا يعلمه إلا الله{115}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٠٣١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق الكلبي، عن أبي صالح- قال: تفسير القرآن على أربعة وجوه: تفسير يعلمه العلماء، وتفسير لا يُعْذَر الناس بجهالته مِن حلال أو حرام، وتفسيرٌ تعرفه العربُ بلغتها، وتفسير لا يعلم تأويلَه إلا الله، مَنِ ادَّعى علمَه فهو كاذب{116}. (٣/٤٦٠)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَٱلرَّ ٰ⁠سِخُونَ فِی ٱلۡعِلۡمِ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">١٢٠٣٢<span class="dash">-</span></span> عن أنس بن مالك: سُئِل رسول الله ﷺ: مَنِ الراسخون في العلم؟ قال: «<b>مَن صدَق حديثُه، وبَرَّ في يمينه، وعفَّ بطنُه وفرجُه، فذلك الراسخون في العلم»</b>{117}. (٣/٤٦٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٠٣٣<span class="dash">-</span></span> عن أنس بن مالك، وأبي أُمامَة، وواثِلة بن الأَسْقَع، وأبي الدرداء: أنّ رسول الله ﷺ سُئِل عن <span class="qpc-hafs">﴿والراسخون في العلم﴾</span>. فقال: «<b>مَن بَرَّت يمينُه، وصَدَق لسانُه، واسْتَقام قلبُه، ومَن عَفَّ بطنُه وفَرْجُه؛ فذلك مِن الراسخين في العلم</b>»{118}. (٣/٤٦٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٠٣٤<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق مجاهد- قال: <span class="qpc-hafs">﴿والراسخون في العلم يقولون آمنا به﴾</span>، قال: الراسخون الذين يقولون: آمنا به كُلٌّ مِن عند ربِّنا{119}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٠٣٥<span class="dash">-</span></span> عن ابن عباس -من طريق ابن جُرَيْج- قال <span class="name-1">عبد الله بن سلام</span>: <span class="qpc-hafs">﴿والراسخون في العلم﴾</span> وعِلْمُهم: قولُهم.= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٠٣٦<span class="dash">-</span></span> قال <span class="name-3">ابن جُرَيْج</span>: <span class="qpc-hafs">﴿والراسخون في العلم يقولون آمنا به﴾</span>، وهم الذين يقولون: <span class="qpc-hafs">﴿ربنا لا تزغ قلوبنا﴾</span>، ويقولون: <span class="qpc-hafs">﴿ربنا إنك جامع الناس ليوم لا ريب فيه﴾</span> الآية{120}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٠٣٧<span class="dash">-</span></span> عن <span class="name-2">مسروق بن الأَجْدَع</span> -من طريق إبراهيم- قال: لَقِيتُ زيدًا، فوَجَدتُه مِن الراسخين في العلم{121}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٠٣٨<span class="dash">-</span></span> قال <span class="name-3">مُقاتِل بن سليمان</span>: ثُمَّ استأنف، فقال: <span class="qpc-hafs">﴿والراسخون في العلم﴾</span>، يعني: المُتَدارِسُون عِلْمَ التوراة؛ فهم عبدُ الله بنُ سلام وأصحابُه مِن مؤمني أهلِ التوراة{45}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٠٣٩<span class="dash">-</span></span> عن <span class="name-3">مُقاتِل بن حَيّان</span> -من طريق بُكَيْر بن معروف- قوله: <span class="qpc-hafs">﴿والراسخون في العلم﴾</span>: يعني: عبد الله بن سلام وأصحابه مِن مؤمني أهل الكتاب مِن أهل التوراة{121}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٠٤٠<span class="dash">-</span></span> عن <span class="name-3">نافع بن يزيد</span> -من طريق ابن وهْب- قال: يُقال: <span class="qpc-hafs">﴿والراسخون في العلم﴾</span>: المتواضعون [المُتَذَلِّلون] لله في مرضاته، فلا يتعاطون مَن فوقهم، ولا يحقرون مَن دونهم{124}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَٱلرَّ ٰ⁠سِخُونَ فِی ٱلۡعِلۡمِ یَقُولُونَ ءَامَنَّا بِهِۦ كُلࣱّ﴾</span> - قراءات</h3></p><p><div></p><p><p><span class="item-no">١٢٠٤١<span class="dash">-</span></span> عن الأعمش، قال: في قراءة <span class="name-1">عبد الله بن مسعود</span>: (وإنْ حَقِيقَةُ تَأْوِيلِهِ عِندَ اللهِ والرّاسِخُونَ فِي العِلْمِ يَقُولُونَ آمَنّا بِهِ){125}. (٣/٤٥٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٠٤٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق طاووس- أنّه كان يقرؤها: (وما يَعْلَمُ تَأْوِيلَهُ إلّا اللهُ ويَقُولُ الرّاسِخُونَ فِي العِلْمِ آمَنّا بِهِ){126}<span class=comment-ref>١١١٤</span>. (٣/٤٥٨)</p></p><p></div></p><p><div><span class=comment-ref>١١١٤</span> اختلف القُرّاءُ في الوقف في هذه الآية؛ فمنهم من يقف على قوله: <span class="qpc-hafs">﴿إلا الله﴾</span>. ومنهم مَن يقف عند قوله: <span class="qpc-hafs">﴿والراسخون في العلم﴾</span>.</p><p>وصَوَّب <u>ابنُ تيمية</u> (٢/٢٥) كليهما، فقال: «وكلتا القراءتين حقٌّ، ويُراد بالأولى المتشابه في نفسه الذي استأثر الله بعلم تأويله، ويُراد بالثانية المتشابه الإضافي الذي يعرف الراسخون تفسيرَه، وهو تأويله. <span class="mustanad">ومثل هذا يقع في القرآن كقوله</span>: <span class="qpc-hafs">﴿وإن كان مكرهم لتزول منه الجبال﴾</span> و›لَتَزُولُ‹، فيه قراءتان مشهورتان بالنفي والإثبات، وكُلُّ قراءةٍ لها معنًى صحيحٌ».</div></p><p><h3><span class="qpc-hafs">﴿وَٱلرَّ ٰ⁠سِخُونَ فِی ٱلۡعِلۡمِ یَقُولُونَ ءَامَنَّا بِهِۦ كُلࣱّ﴾</span> - تفسير الآية</h3></p><p><div></p><p><p><span class="item-no">١٢٠٤٣<span class="dash">-</span></span> عن عبد الله بن مسعود، عن النبي ﷺ، قال: «<b>كان الكتابُ الأوَّلُ ينزل من باب واحد على حرف واحد، ونزل القرآنُ من سبعة أبواب على سبعة أحرف: زاجِر، وآمِر، وحلال، وحرام، ومحكم، ومتشابه، وأمثال؛ فأحِلُّوا حلالَه، وحرِّموا حرامَه، وافعلوا ما أُمِرْتُم به، وانتهوا عَمّا نُهِيتُم عنه، واعْتَبِرُوا بأمثالِه، واعْمَلُوا بمُحْكَمِه، وآمنوا بمُتَشابِهه، وقولوا: <span class="qpc-hafs">﴿آمنا به كل من عند ربنا﴾</span>»</b>{127}. (٣/٤٥٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٠٤٤<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن مسعود</span>، موقوفًا{113}. (٣/٤٥٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٠٤٥<span class="dash">-</span></span> عن عليٍّ، أنّ النبي ﷺ قال في خُطْبَتِه: <b>«أيُّها الناسُ، قد بَيَّن اللهُ لكم في مُحْكَم كتابه ما أحَلَّ لكم، وما حَرَّم عليكم؛ فأَحِلُّوا حلالَه، وحَرِّموا حرامه، وآمِنوا بمُتَشابِهه، واعْمَلُوا بمُحْكَمِه، واعْتَبِرُوا بأمْثالِه»</b>{129}. (٣/٤٥٦-٤٥٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٠٤٦<span class="dash">-</span></span> عن <span class="name-1">عائشة</span> -من طريق ابن أبي مُلَيْكَة- أنّه قرأ عليها هؤلاء الآيات، فقالَتْ: كان رسوخُهم في العلم أنْ آمَنُوا بمُحْكَمه ومتشابهه، <span class="qpc-hafs">﴿وما يعلم تأويله إلا الله﴾</span> ولم يعلموا تأويلَه{130}. (٣/٤٥٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٠٤٧<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق العوفي-: <span class="qpc-hafs">﴿يقولون آمنا به﴾</span>؛ نؤمن بالمُحْكَم ونَدِين به، ونُؤْمِنُ بالمتشابه ولا ندين به، وهو مِن عند الله كُلِّه{131}. (٣/٤٦١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٠٤٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق مجاهد- قال: أنا مِمَّن يعلم تأويلَه{132}<span class=comment-ref>١١١٥</span>. (٣/٤٦١)</p></p><p></div></p><p><div><span class=comment-ref>١١١٥</span> ورَدَ عن ابن عباس تارَةً أنّ الراسخين لهم عِلْمٌ بالمتشابه، وأخرى تُفِيد عدمَ علمهم.</p><p>وذَكَر <u>ابنُ عطية</u> (٢/١٦٢) أنّ إعراب الراسخين يحتمل الوجهين؛ ولذلك قال ابنُ عباس بهما.</p><p>و<span class="comment-type-4">عَلَّق</span> <u>ابنُ تيمية</u> (٢/١٥ بتصرف) على ورود القولين عن ابن عباس بقوله: «وكِلا القولين حقٌّ باعتبار؛ ولهذا نُقِل عن ابن عباس هذا وهذا، وكلاهما حقٌّ».</div></p><p><div></p><p><p><span class="item-no">١٢٠٤٩<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق مجاهد- <span class="qpc-hafs">﴿يقولون آمنا به﴾</span>: يعني: ما نُسِخ، وما لم يُنسَخ{121}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٠٥٠<span class="dash">-</span></span> وعن <span class="name-1">عائشة</span>، نحو ذلك{134}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٠٥١<span class="dash">-</span></span> عن <span class="name-2">أبي الشَّعْثاء جابر بن زيد</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٠٥٢<span class="dash">-</span></span> و<span class="name-2">أبي نَهِيكٍ</span>، قالا: إنّكم تَصِلُون هذه الآيةَ، وهي مقطوعةٌ: <span class="qpc-hafs">﴿وما يعلم تأويله إلا الله والراسخون في العلم يقولون آمنا به كل من عند ربنا﴾</span>، فانتهى علمُهم إلى قولهم الذي قالوا{135}. (٣/٤٥٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٠٥٣<span class="dash">-</span></span> عن <span class="name-2">عروة بن الزبير</span> -من طريق هشام بن عُرْوَة- قال: <span class="qpc-hafs">﴿الراسخون في العلم﴾</span> لا يعلمون تأويله، ولكنَّهم يقولون: <span class="qpc-hafs">﴿آمنا به كل من عند ربنا﴾</span>{136}. (٣/٤٥٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٠٥٤<span class="dash">-</span></span> عن <span class="name-2">عمر بن عبد العزيز</span> -من طريق عمرو بن عثمان- قال: انتهى عِلْمُ الراسخين في العلم بتأويل القرآن إلى أن قالوا: <span class="qpc-hafs">﴿آمنا به كل من عند ربنا﴾</span>{137}<span class=comment-ref>١١١٦</span>. (٣/٤٥٩)</p></p><p></div></p><p><div><span class=comment-ref>١١١٦</span> ذكر <u>ابنُ جرير</u> (٥/٢٢١) أنّ مَن قال بهذا القول الذي قال به ابن عباس من طريق طاووس، وعائشة، وعروة، وعمر بن عبد العزيز، ومالك، وأبي نهيك الأسدي؛ فإنَّه يرفع <span class="qpc-hafs">﴿والراسخون في العلم﴾</span> بالابتداء في قول البصريين، ويجعل خبره <span class="qpc-hafs">﴿يقولون آمنا به﴾</span>. وأمّا في قول بعض الكوفيين فبالعائِد من ذكرهم في <span class="qpc-hafs">﴿يقولون﴾</span>، وفي قول بعضهم بجملة الخبر عنهم، وهي: <span class="qpc-hafs">﴿يقولون﴾</span>.</div></p><p><div></p><p><p><span class="item-no">١٢٠٥٥<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نَجِيح- قال: <span class="qpc-hafs">﴿والراسخون في العلم﴾</span> يعلمون تأويله، و<span class="qpc-hafs">﴿يقولون آمنا به﴾</span>{138}. (٣/٤٦٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٠٥٦<span class="dash">-</span></span> عن <span class="name-2">الضَّحّاك بن مُزاحِم</span> -من طريق أبي مُصْلِح- <span class="qpc-hafs">﴿وما يعلم تأويله إلا الله والراسخون في العلم﴾</span>، يقول: الرّاسِخُون يعلمون تأويلَه، لو لم يعلموا تأويلَه لم يعلموا ناسِخَه مِن منسوخه، ولم يعلموا حلالَه مِن حرامه، ولا محكمَه مِن متشابهه{139}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٠٥٧<span class="dash">-</span></span> عن <span class="name-2">الضَّحّاك بن مُزاحِم</span> -من طريق جُوَيْبِر- في قوله: <span class="qpc-hafs">﴿والراسخون في العلم﴾</span>: يعملون به، يقولون: نعمل بالمُحْكَم ونؤمن به، ونُؤْمِن بالمتشابه ولا نعمل به، وكُلٌّ مِن عندِ ربنا{140}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٠٥٨<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دِعامة</span> -من طريق شَيْبان- <span class="qpc-hafs">﴿يقولون آمنا به﴾</span>، قال: آمنوا بمتشابهه، وعملوا بمُحْكَمِه، فأحلُّوا حلالَه، وحرَّموا حرامَه{141}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٠٥٩<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيِّ</span> -من طريق أسباط- <span class="qpc-hafs">﴿والراسخون في العلم﴾</span> قال: هم المؤمنون؛ فإنّهم <span class="qpc-hafs">﴿يقولون آمنا به﴾</span> بناسخه ومنسوخه، <span class="qpc-hafs">﴿كل من عند ربنا﴾</span>{142}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٠٦٠<span class="dash">-</span></span> عن <span class="name-2">الربيع بن أنس</span> -من طريق أبي جعفر- قال: <span class="qpc-hafs">﴿والراسخون في العلم﴾</span> يعلمون تأويله، و<span class="qpc-hafs">﴿يقولون آمنا به﴾</span>{143}<span class=comment-ref>١١١٧</span>. (٣/٤٦١)</p></p><p></div></p><p><div><span class=comment-ref>١١١٧</span> ذَكَرَ <u>ابنُ جرير</u> (٥/٢٢١) أنّ مَن قال بهذا القول الذي قال به ابن عباس من طريق مجاهد، والربيع، وابن الزبير؛ فإنّه عطف بـ«الراسخين» على اسم «الله»، فرفعهم بالعطف عليه.</div></p><p><div></p><p><p><span class="item-no">١٢٠٦١<span class="dash">-</span></span> عن <span class="name-3">محمد بن جعفر بن الزبير</span> -من طريق ابن إسحاق- قال: <span class="qpc-hafs">﴿وما يعلم تأويله﴾</span> الذي أراد ما أراد <span class="qpc-hafs">﴿إلا الله والراسخون في العلم يقولون آمنا به﴾</span>، فكيف يخْتَلِفُ وهو قولٌ واحد مِن رَبٍّ واحد؟! ثُمَّ رَدُّوا تأويلَ المتشابه على ما عرفوا مِن تأويل المُحْكَمَةِ التي لا تأويل لأحدٍ فيها إلا تأويل واحد، فاتَّسق بقولهم الكتابُ، وصَدَّق بعضُه بعضًا، فنَفَذَتْ به الحُجَّة، وظهر به العُذْر، وزاح به الباطل، ودَمَغ به الكفر{144}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٠٦٢<span class="dash">-</span></span> عن <span class="name-3">محمد بن إسحاق</span> -من طريق ابن إدريس- قوله: <span class="qpc-hafs">﴿والراسخون في العلم يقولون آمنا به﴾</span>، قال: لم تكن معرفتهم إيّاه أن يفقهوه على الشَّكِّ، ولكنهم خَلَصَت{145} الأعمالُ منهم، ونفذ عِلْمُهم أن عرفوا الله بعدله؛ لم يكن لِيَخْتَلِف شيءٌ مِمّا جاء منه، فرَدُّوا المتشابه على المُحْكَم، فقالوا: <span class="qpc-hafs">﴿كل من عند ربنا﴾</span>{146}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٠٦٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿يقولون آمنا به كل من عند ربنا﴾</span>، يعني: قليله وكثيره مِن عند ربنا{45}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٠٦٤<span class="dash">-</span></span> عن <span class="name-3">مالك بن أنس</span> -من طريق أشْهَب- في قوله: <span class="qpc-hafs">﴿وما يعلم تأويله إلا الله﴾</span>، قال: ثُمَّ ابتدأ فقال: <span class="qpc-hafs">﴿والراسخون في العلم يقولون آمنا به﴾</span>، وليس يعلمون تأويلَه{148}<span class=comment-ref>١١١٨</span>. (٣/٤٦٠)</p></p><p></div></p><p><div><span class=comment-ref>١١١٨</span> اختُلِف في كلمة <span class="qpc-hafs">﴿الراسخون﴾</span>؛ أهِي مُسْتَأْنَفَةٌ، أم معطوفة. و<span class="comment-type-3">رَجَّح</span> <u>ابنُ جرير</u> (٥/٢٢١-٢٢٢) القولَ الأوّل الذي قال به ابن عباس من طريق طاووس، وعائشة، وعروة، وعمر بن عبد العزيز، ومالك، وأبو نهيك الأسدي <span class="mustanad">مُسْتَنِدًا إلى القراءات، ودلالة العقل</span>، وعلّل ذلك بأنّ الراسخين لا يعلمون تأويل المتشابه الذي ذكره الله ﷿ في هذه الآية، ولِمُوافقتِه لِما بَلَغَهُ مِن قراءة أُبَيٍّ وابن عباس: (ويَقُولُ الرّاسِخُونَ فِي العِلْمِ)، وقراءة عبد الله: (إن تَأْوِيلُهُ إلّا عِندَ اللهِ والرّاسِخُونَ فِي العِلْمِ يَقُولُونَ).</p><p>ورأى <u>ابنُ عطية</u> (٥/١٦١-١٦٢) قُرْبَ الخلاف بين القولين، فذكر أنّ المحكم هو المُتَّضِحُ المعنى لِكُلِّ مَن يفهم كلام العرب، والمُتشابِهُ يَتَنَوَّعُ؛ فمِنه ما لا يُعْلَمُ البَتَّةَ كأمر الروح، ومنه ما يُحْمَل على وجوهٍ في اللغة ويَحتاج إلى إزالةِ ما يعلق به من لَبْسٍ. فإن جعلنا <span class="qpc-hafs">﴿والراسخون﴾</span> معطوفة على اسم الله؛ فالمعنى: إدخالهم في علم التأويل لا على الكمال، فذلك ليس إلا لله، بل علمُهم إنّما هو في النوع الثاني من المتشابه، وإن جعلنا قوله: <span class="qpc-hafs">﴿والرّاسِخُونَ﴾</span> رفعًا بالابتداء مقطوعًا مما قبله؛ فتسميتُهم راسخين يقتضي بأنّهم يعلمون أكثر من المحكم الذي يستوي في علمه جميعُ مَن يفهم كلام العرب.</p><p>وكذا رأى <u>ابنُ تيمية</u> (٢/١٩) عدمَ المنافاة بين القولين، فقال: «إنّ السلف كان أكثرهم يقفون عند قوله: <span class="qpc-hafs">﴿وما يَعْلَمُ تَأْوِيلَهُ إلا اللَّهُ﴾</span>، بناءً على أنّ التأويل الذي هو الحقيقة التي استأثر الله بعلمها لا يعلمها إلا هو، وطائفة منهم كمجاهد وابن قتيبة وغيرهما قالوا: بل الراسخون يعلمون التأويل. ومرادهم بالتأويل المعنى الثاني، وهو: التفسير. فليس بين القولين تناقُضٌ في المعنى».</div></p><p><h3><span class="qpc-hafs">﴿كُلࣱّ مِّنۡ عِندِ رَبِّنَاۗ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">١٢٠٦٥<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق مجاهد- <span class="qpc-hafs">﴿كل من عند ربّنا﴾</span>: يعني: ما نُسِخ منه، وما لم يُنسَخ{149}. (٣/٤٦٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٠٦٦<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دِعامة</span> -من طريق سعيد- قوله: <span class="qpc-hafs">﴿وما يعلم تأويله إلا الله﴾</span> والراسخون في العلم قالوا: <span class="qpc-hafs">﴿كل من عند ربنا﴾</span> آمنوا بمتشابهه، وعملوا بمُحْكَمه{150}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٠٦٧<span class="dash">-</span></span> عن <span class="name-2">الربيع بن أنس</span> -من طريق أبي جعفر- في قوله: <span class="qpc-hafs">﴿كل من عند ربنا﴾</span>: يقولون: المُحْكَم والمُتشابه مِن عند ربِّنا{151}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٠٦٨<span class="dash">-</span></span> عن <span class="name-3">محمد بن جعفر بن الزُّبَيْر</span> -من طريق ابن إسحاق- قال: ثم رَدُّوا تأويلَ المتشابه على ما عرفوا مِن تأويل المُحْكَمَةِ التي لا تأويلَ لأحدٍ فيها إلا تأويلٌ واحد؛ فاتَّسَقَ بقولهم الكتابُ، وصَدَّقَ بعضُه بعضًا، فنَفَذَتْ به الحُجَّةُ، وظهر به العُذْرُ، وزاح به الباطل، ودُمِغَ به الكُفْرُ{144}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٠٦٩<span class="dash">-</span></span> عن <span class="name-3">محمد بن إسحاق</span> -من طريق سلمة-، مثله{153}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَمَا یَذَّكَّرُ إِلَّاۤ أُو۟لُوا۟ ٱلۡأَلۡبَـٰبِ ۝٧﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">١٢٠٧٠<span class="dash">-</span></span> عن <span class="name-3">محمد بن جعفر بن الزُّبَيْر</span> -من طريق ابن إسحاق- <span class="qpc-hafs">﴿وما يذّكر إلا أولو الألباب﴾</span>، يقول: وما يذَّكَّرُ في مثل هذا -يعني: في رَدِّ تأويل المتشابه إلى ما قد عُرِفَ مِن تأويل المُحْكَمِ حتى يَتَّسِقا على معنًى واحد- إلا أولو الألبابِ{154}<span class=comment-ref>١١١٩</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>١١١٩</span> لم يذكر <u>ابنُ جرير</u> (٥/٢٢٧) غيرَ هذا القول.</div></p><p><div></p><p><p><span class="item-no">١٢٠٧١<span class="dash">-</span></span> عن <span class="name-3">مقاتل بن حيّان</span> -من طريق بُكَيْر بن معروف- قوله: <span class="qpc-hafs">﴿وما يذكر إلا أولوا الألباب﴾</span>: إلا كُلُّ ذِي لُبٍّ{155}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٠٧٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وما يذكر إلا أولوا الألباب﴾</span>، فما يَسْمَعُ إلا أولو الألباب، يعني: مَن كان له لُبٌّ وعَقْلٌ، يعني: ابن سلام وأصحابه، فيعلمون أنّ كُلَّ شيء مِن هذا وغيره مِن عند الله{45}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَمَا یَذَّكَّرُ إِلَّاۤ أُو۟لُوا۟ ٱلۡأَلۡبَـٰبِ ۝٧﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">١٢٠٧٣<span class="dash">-</span></span> عن أبي هريرة، قال: قال رسول الله ﷺ: «<b>الجِدالُ في القرآن كُفْرٌ</b>»{157}. (٣/٤٦٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٠٧٤<span class="dash">-</span></span> عن ابن عمرو: أنّ رسول الله ﷺ خَرَجَ على أصحابه وهم يَتَنازَعُون في القرآن، هذا يَنزِعُ{158} بآية، وهذا يَنزِعُ بآية؛ فكأنّما فُقِئَ في وجْهِه حَبُّ الرُّمّان، فقال: «<b>ألِهَذا خُلِقْتُم؟! أو لِهَذا أُمِرْتُم؟! أن تضربوا كتابَ الله بعضَه ببعض؟! انظروا ما أُمِرْتُم به فاتَّبِعُوه، وما نُهِيتُم عنه فانتهوا»</b>{159}. (٣/٤٦٤-٤٦٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٠٧٥<span class="dash">-</span></span> عن عبد الله بن عمرو، قال: خرج رسول الله ﷺ ومِن وراء حُجْرَتِه قومٌ يتجادلون في القرآن؛ فخَرَجَ مُحْمَرَّةً وجْنَتاه، كأنّما تَقْطُرانِ دمًا، فقال: <b>«يا قوم، لا تُجادِلوا بالقرآن؛ فإنّما ضَلَّ مَن كان قبلكم بجدالهم. إنّ القرآن لم ينزل لِيُكَذِّبَ بعضُه بعضًا، ولكن نزل لِيُصَدِّق بعضُه بعضًا، فما كان مِن مُحْكَمِه فاعملوا به، وما كان مِن متشابهه فآمِنوا به»</b>{160}. (٣/٤٦٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٠٧٦<span class="dash">-</span></span> عن <span class="name-1">عمر بن الخطاب</span>، قال: إنّه سيأتيكم ناسٌ يُجادِلُونكم بشُبُهاتِ القُرآن، فخُذُوهم بالسُّنَنِ؛ فإنّ أصحاب السُّنَنِ أعلمُ بكتاب الله{161}. (٣/٤٦٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٠٧٧<span class="dash">-</span></span> عن <span class="name-1">عمر بن الخطاب</span> -من طريق السّائِب بن يزيد- أنّ رجلًا قال لعمر: إنِّي مررتُ برجلٍ يسألُ عن تفسير مُشْكِل القرآن. فقال عمر: اللَّهُمَّ، أمْكِنِّي مِنهُ. فدخل الرجلُ يومًا على عمر، فسأله، فقام عمرُ، فحَسَر عن ذِراعَيْه، وجعل يَجْلِدُه، ثم قال: ألْبِسُوه تُبّانًا{162}، واحمِلوه على قَتَبٍ{163}، وابلُغُوا به حَيَّهُ، ثم لْيَقُم خطيبٌ فلْيَقُلْ: إنّ صَبِيغًا طَلَبَ العِلْمَ فأخطأه. فلم يزل وضيعًا في قومه بعد أن كان سيِّدًا فيهم{164}. (٣/٤٦٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٠٧٨<span class="dash">-</span></span> عن <span class="name-1">عمر بن الخطاب</span> -من طريق سليمان بن يسار-: أنّ رجلًا يُقال له: صَبِيغ؛ قَدِم المدينة، فجعل يسأل عن مُتَشابِهِ القُرْآن، فأرسل إليه عمرُ وقد أعَدَّ له عَراجِينَ النَّخْلِ، فقال: مَن أنت؟ فقال: أنا عبدُ الله صَبِيغٌ. فقال: وأنا عبدُ الله عُمرُ. فأخذ عمرُ عُرْجُونًا مِن تِلْك العَراجِين، فضربه حتى دَمّى رأسَه، فقال: يا أمير المؤمنين، حسبُك؛ قد ذهب الذي كنتُ أجِدُ في رأسي{165}. (٣/٤٦٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٠٧٩<span class="dash">-</span></span> عن محمد بن سيرين، قال: كتب <span class="name-1">عمر بن الخطاب</span> إلى أبي موسى الأشعري: أن لا يجالِس صَبِيغًا، وأن يُحرَم عطاءَه ورزقَه{166}. (٣/٤٦٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٠٨٠<span class="dash">-</span></span> عن <span class="name-1">معاذ بن جبل</span>، قال: القرآنُ منارٌ كمنارِ الطريق، ولا يخفى على أحد، فما عرفتم منه فلا تسألوا عنه أحدًا، وما شككتم فيه فكِلوه إلى عالمه{167}. (٣/٤٥٩-٤٦٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٠٨١<span class="dash">-</span></span> عن <span class="name-1">أُبَيِّ بن كعب</span> -من طريق عبد الرحمن بن أبزى- قال: كتابُ الله ما استبان منه فاعمل به، وما اشتبه عليك فآمِن به، وكِلْه إلى عالمه{167}. (٣/٤٥٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٠٨٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن مسعود</span>، قال: إنّ للقرآن منارًا كمنار الطريق، فما عرفتم فتمسكوا به، وما اشتبه عليكم فذَرُوه{167}. (٣/٤٥٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٠٨٣<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عكرمة- قال: كلَّ القرآن أعْلَمُ تأويله إلا أربعًا: <span class="qpc-hafs">﴿غسلين﴾</span> [الحاقة:٣٦]، <span class="qpc-hafs">﴿وحنانًا﴾</span> [مريم:١٣]، والأواه، <span class="qpc-hafs">﴿والرقيم﴾</span> [الكهف:٩]{170}. (ز)</p></p><p></div></p></div>",footnotes:1:عند ابن جرير: أُكْلُ.أخرجه ابن إسحاق -كما في سيرة ابن هشام ١/٥٤٥-٥٤٦-، والبخاري في التاريخ الكبير ٢/٢٠٨ (٢٢٠٩)، وابن جرير ١/٢٢١-٢٢٢.</p><p>قال ابنُ كثير في تفسيره ١/١٦٢: «فهذا مداره على محمد بن السائب الكلبي، وهو ممن لا يُحْتَجُّ بما انفرد به». وقال السيوطي في الدر ١/١٢٤: «بسند ضعيف».عزاه السيوطي إلى يونس بن بكير في المغازي.أخرجه ابن المنذر (٢٠٠)، ووصفه السيوطي بأنه مِن وجهٍ آخرَ مُعْضلًا.أخرجه ابن جرير ٥/٢٠٥-٢٠٦، وابن أبي حاتم ٢/٥٩٦ (٣١٨٧) مرسلًا.أخرجه ابن أبي داود في المصاحف ص١٨.أخرجه ابن أبي حاتم ٢/٥٩١.أخرجه سعيد بن منصور (٤٩٣ - تفسير)، وابن أبي حاتم ٢/٥٩٢ (٣١٦٨)، والحاكم ٢/٢٨٨. وعزاه السيوطي إلى ابن مردويه.أخرجه ابن جرير ٥/١٩٣، وابن المنذر (٢٢١)، وابن أبي حاتم ٢/٥٩٢. وعزاه السيوطي إلى عبد بن حميد.علَّقه ابن أبي حاتم ٢/٥٩٢.عزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ٥/١٩٤.أخرجه ابن جرير ٥/١٩٣، وابن المنذر (٢١٧)، وابن أبي حاتم ٢/٥٩٣ (٣١٦٧، ٣١٧٤).أخرجه ابن جرير ٥/١٩٣-١٩٤.أخرجه ابن جرير ٥/١٩٣.أخرجه ابن جرير ٥/١٩٦. وعزاه السيوطي إلى عَبد بن حُمَيد، والفريابي.أخرجه ابن جرير ٥/١٩٥، وابن المنذر ١/١١٧، وعبد بن حميد كما في قطعة من تفسيره ص٢٠.أخرجه الثوري في تفسيره ص٧٥، وعبد بن حميد كما في قطعة من تفسيره ص٢٠، وابن جرير ٥/١٩٥.تفسير البغوي ٢/٨.علَّقه ابن أبي حاتم ٢/٥٩٢.أخرجه عبد الرزاق ١/١١٥، وابن جرير ٥/١٩٤.أخرجه ابن جرير ٥/١٩٤، وابن المنذر ١/١١٧-١١٨ بعضَه.أخرجه ابن أبي حاتم ٢/٥٩٣.أخرجه ابن جرير ٥/١٩٥.أخرجه ابن جرير ٥/١٩٧، وابن أبي حاتم ٢/٥٩١.أخرجه ابن أبي حاتم ٢/٥٩٢.تفسير مقاتل بن سليمان ١/٢٦٣.أخرجه ابن جرير ٥/١٩٧-١٩٨.أخرجه ابن أبي حاتم ٢/٥٩٣ (٣١٧٣).ذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ١/٢٧٥-.أخرجه ابن جرير ١٣/٥٧١.أخرجه ابن جرير ٥/٢٠١، وابن أبي حاتم ٢/٥٩٢. وعزاه السيوطي إلى عبد بن حميد، وابن الضُّرَيس.تفسير مقاتل بن سليمان ١/٢٦٣-٢٦٤.أخرجه ابن أبي حاتم ٢/٥٩٣، ٥٩٤ (٣١٧٣، ٣١٧٦).أخرجه ابن جرير ٥/٢٠١-٢٠٢.أخرجه ابن جرير ٥/١٩٣، وابن المنذر (٢١٧)، وابن أبي حاتم ٢/٥٩٣ (٣١٦٧، ٣١٧٤).أخرجه ابن جرير ٥/١٩٣-١٩٤.تفسير البغوي ٢/٩، وتفسير الثعلبي ٣/١١. وتمام الأثر سبق في سبب النزول.أخرجه ابن جرير ٥/١٩٤.أخرجه ابن المنذر (٢٢٨).أخرجه ابن أبي حاتم ٢/٥٩٣.أخرجه ابن جرير ٥/١٩٥، وأخرجه الثوري في تفسيره ص٧٥ دون قول: وتُرك يُتلى، وعبد بن حميد كما في قطعة من تفسيره ص٢٠، وابن المنذر ١/١٢٠. وعلَّقه ابن أبي حاتم ٢/٥٩٣. كما أخرج ابن جرير ٥/١٩٥ نحوه من طريق سلمة بن نُبَيْط.أخرجه ابن المنذر ١/١٢٠، وعبد بن حميد كما في قطعة من تفسيره ص٢١. وعلّقه ابن أبي حاتم ٢/٥٩٣.أخرجه ابن جرير ٥/١٩٥. وعلّقه ابن أبي حاتم ٢/٥٩٣.تفسير مقاتل بن سليمان ١/٢٦٤.أخرجه ابن أبي حاتم ٢/٥٩٤.أخرجه ابن أبي حاتم ٢/٥٩٤.أخرجه ابن المنذر ١/١٢٠، وابن أبي حاتم ٢/٥٩٤ من طريق سلمة.ذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ١/٢٧٥-.أخرجه ابن جرير ٥/٢٠٥ مرسلًا.أخرجه أحمد ٣٦/٥٩٤ (٢٢٢٥٩) واللفظ له، وابن أبي حاتم ٢/٥٩٤ (٣١٧٩).</p><p>وفي إسناده أبو غالب البصري الراوي عن أبي أمامة، وهو مختلف فيه، قال ابن حجر في التقريب (٨٣٦٢): «صدوق يخطئ».أخرجه ابن جرير ٥/٢٠٣.أخرجه ابن جرير ٥/٢٠٣-٢٠٤، وابن المنذر ١/١٢٢، وابن أبي حاتم ٢/٥٩٥.أخرجه الهروي في ذمِّ الكلام وأهله ٢/٦٣.أخرجه ابن جرير ٥/٢٠٣، وابن المنذر ١/١٢٢. وعلّقه ابن أبي حاتم ٢/٥٩٥.عزاه السيوطي إلى عَبد بن حُمَيد.الحرورية: هم فرقة الخوارج، وسمُّوا بهذا الاسم لأنهم بعد خروجهم على عليٍّ ﵁ ورفضهم التحكيم، نزلوا بموضع قرب الكوفة يقال له: حروراء. ينظر: مقالات الإسلاميّين ١/٢٠٧، ومعجم البلدان ٢/٣٣٦.السبائية: إحدى فرق الشيعة الغالية، وهي تنتسب إلى عبد الله بن سبأ، ومن جهالاتهم زعمهم أنّ عليًا لم يمت وأنه يرجع إلى الدنيا قبل يوم القيامة فيملأُ الأرض عدلًا كما ملئت جورًا. ينظر: مقالات الإسلاميين ١/٨٦، والملل والنحل ١/٣٦٥.ألاص الأمر: حرّكه وأداره لينتزعه. لسان العرب (لوص).أخرجه عبد الرزاق ١/١١٥-١١٦، وابن جرير ٥/٢٠٧-٢٠٨ واللفظ له.علَّقه ابن أبي حاتم ٢/٥٩٥.أخرجه ابن جرير ٥/٢٠٢-٢٠٣.تفسير البغوي ٢/٩، وتفسير الثعلبي ٣/١٢.تفسير مقاتل بن سليمان ١/٢٦٤.أخرجه ابن أبي حاتم ٢/٥٩٥، وابن المنذر ١/١٢٣ من طريق إسحاق.علَّقه ابن جرير ٥/٢٠٤.أخرجه ابن أبي حاتم ٢/٥٩٥، وابن المنذر ١/١٢٣ من طريق زياد.أخرجه أحمد ٤٠/٢٥٥ (٢٤٢١٠)، وابن ماجه ١/٣٢ (٤٧)، وابن حبان ١/٢٧٧ (٧٦)، وعبد الرزاق في تفسيره ١/٣٨٤ (٣٧٦)، وابن جرير ٥/٢٠٨، ٢٠٩، ٢١١.الدقل: رديء التمر ويابسه. مادة (دقل).أخرجه أبو يعلى -كما عند البوصيري في إتحاف الخيرة ٦/٣٤٥ (٥٩٩٠)-.</p><p>قال البوصيري: «هذا إسناد رواته ثقات، وأبو موسى هو محمد بن المثنى البصري».أخرجه ابن جرير ٥/٢٠٤، وابن أبي حاتم ٢/٥٩٥.أخرجه ابن المنذر ١/١٢٧.أخرجه ابن جرير ٥/٢٠٥. وعزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ٥/٢٠٥، وابن أبي حاتم ٢/٥٩٦.أخرجه ابن جرير ٥/٢٠٤.أخرجه ابن المنذر ١/١٢٨، وابن أبي حاتم ٢/٥٩٦ مختصرًا من طريق سلمة.أخرجه ابن جرير ٥/٢٠٥، ٢١٣ واللفظ له، وابن المنذر ١/١٢٨، وابن أبي حاتم ٢/٥٩٦. وعزاه السيوطي إلى عبد بن حميد.أخرجه الحربيُّ في غريب الحديث ٣/٩٣١. وذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ١/٢٧٥- بلفظ: طلب الضلالة.أخرجه ابن جرير ٥/٢١٢، وابن أبي حاتم ٢/٥٩٦.أخرجه ابن جرير ٥/٢١٢. وعلّقه ابن أبي حاتم ٢/٥٩٦.علَّقه ابن أبي حاتم ٢/٥٩٦.أخرجه ابن جرير ٥/٢١٣.أخرجه ابن المنذر ١/١٢٨، وابن أبي حاتم ٢/٥٩٧ من طريق سلمة.تفسير مقاتل بن سليمان ١/٢٦٤.أخرجه ابن أبي حاتم ٢/٥٩٧.أخرجه ابن جرير ٥/٢٠٨.أخرجه ابن جرير ٥/٢١٦، وابن أبي حاتم ٢/٥٩٧.أخرجه ابن جرير ٥/٢١٦.تفسير مقاتل بن سليمان ١/٢٦٤.أخرجه ابن أبي حاتم ٢/٥٩٧.أخرجه ابن المنذر ١/١٢٩.أخرجه ابن أبي حاتم ٢/٥٩٧.أخرجه ابن جرير ١/٧٠.</p><p>قال ابن جرير: «خبر في إسناده نظر». وقال ابن كثير في تفسيره ١/١٥: «والنظر الذي أشار إليه في إسناده هو من جهة محمد بن السائب الكلبي؛ فإنه متروك الحديث؛ لكن قد يكون إنّما وهِم في رفعه، ولعله من كلام ابن عباس، كما تقدم». وقال الألباني في الضعيفة ١٣/٣٧١ (٦١٦٣): «ضعيف جِدًّا».أخرجه ابن جرير ٥/٢١٥، وابن المنذر ١/١٢٩، وابن أبي حاتم ٢/٥٩٧.أخرجه ابن المنذر ١/١٢٩.أخرجه ابن أبي حاتم ٢/٥٩٨.أخرجه عبد الله بن وهب في الجامع ١/٦٤ (١٤٢)، وابن جرير ٥/٢١٩.أخرجه ابن أبي حاتم ٢/٥٩٨.أخرجه ابن أبي حاتم ٢/٥٩٨.أخرجه ابن جرير ٥/٢١٦، وابن أبي حاتم ٢/٥٩٨.تفسير مقاتل بن سليمان ١/٢٦٤.أخرجه ابن أبي حاتم ٢/٥٩٨.أخرجه ابن أبي حاتم ٢/٥٩٨.أخرجه ابن أبي حاتم ٢/٥٩٨.أخرجه الطبراني في الكبير ٣/٢٩٣ (٣٤٤٢).</p><p>قال ابن كثير في تفسيره ٢/١١: «غريب جِدًّا». وقال الهيثمي في المجمع ١/١٢٧-١٢٨ (٥٣٤): «فيه محمد بن إسماعيل بن عياش عن أبيه، ولم يسمع من أبيه». وقال الألباني في الضعيفة ١٢/٢٣٩ (٥٦٠٧): «ضعيف».أخرجه أحمد ١٣/٣٦٩ (٧٩٨٩)، وابن جرير ١/٢١.</p><p>قال الهيثمي في المجمع ٧/١٥١ (١١٥٧٥): «رواه كله أحمد بإسنادين، ورجال أحدهما رجال الصحيح». وقال الألباني في الصحيحة ٤/٢٧ (١٥٢٢): «قلت: وسنده صحيح، على شرط الشيخين، وصحّحه ابن حبان، وقد تابعه على الجملة الثانية منه محمد بن عمرو الليثي، حدثنا أبو سلمة عن أبي هريرة به».أخرجه البيهقي في الشعب ٣/٥٤٨ (٢٠٩٥).</p><p>قال الألباني في الضعيفة ٣/٥٢٣ (١٣٤٦): «ضعيف جِدًّا».أخرجه ابن سعد ٤/١٤٦، وابن أبي عاصم في الآحاد والمثاني ٢/١٠٩ (٨١٢).</p><p>قال الألباني في الصحيحة ٤/٢٨: «بسند حسن».يتدارأون: أي: يختلفون ويتدافعون في الخصومة. مادة (درأ).أخرجه أحمد ١١/٣٥٣-٣٥٤ (٦٧٤١).أخرجه الطبراني في الكبير ٩/٢٦ (٨٢٩٦)، والشجري في ترتيب الأمالي ١/١١٥ (٤٤١).</p><p>قال الهيثمي في المجمع ٧/١٥٣ (١١٥٨٣): «رواه الطبراني، وفيه عمار بن مطر، وهو ضعيف جِدًّا، وقد وثّقه بعضهم».أخرجه ابن الضريس (١٢٩)، وابن جرير ١/٦٤، وابن المنذر (٢٦١).عزاه السيوطي إلى ابن أبي حاتم.أخرجه ابن جرير ٥/٢١٤.أخرجه ابن جرير ١/٧٠.أخرجه ابن جرير ١/٧٠، وابن المنذر ١/١٣١. وعزاه السيوطي إلى ابن الأنباري في كتاب الوقف.أخرجه ابن عساكر في تاريخه ٥٥/١٩٥-١٩٦ (٦٩٦١).</p><p>إسناده ضعيف جِدًّا؛ فيه عبد الله بن يزيد بن آدم، قال عنه الذهبي في الميزان ٢/٥٢٦: «قال أحمد: أحاديثه موضوعة. وقال الجوزجاني: أحاديثه منكرة».أخرجه الطبراني في الكبير ٨/١٥٢ (٧٦٥٨)، والشجري في الأمالي ١/٧٨ (٢٩٢) كلاهما بدون: «واستقام قلبه»، وابن جرير ٥/٢٢٣ عن أبي الدرداء وأبي أمامة، وابن أبي حاتم ٢/٥٩٩ (٣٢٠٥)، ٤/١١١٦ (٦٢٦٨). وأورده الثعلبي ٣/١٥-١٦.</p><p>قال الهيثمي في المجمع ٦/٣٢٤ (١٠٨٨٧): «رواه الطبراني، وعبد الله بن يزيد ضعيف».أخرجه ابن جرير ٥/٢٢٤.أخرجه ابن جرير ٥/٢٢٤-٢٢٥.أخرجه ابن أبي حاتم ٢/٦٠٠.تفسير مقاتل بن سليمان ١/٢٦٤.أخرجه ابن أبي حاتم ٢/٦٠٠.أخرجه ابن المنذر ١/١٣٣-١٣٤.أخرجه ابن أبي داود في المصاحف ص٥٩.</p><p>وهي قراءة شاذّة. ينظر: البحر المحيط ٢/٤٠١.أخرجه عبد الرزاق في تفسيره ١/١١٦، وابن جرير ٥/٢١٨، وابن المنذر (٢٥٤)، وابن الأنباري في كتاب الأضداد ص٤٢٦، والحاكم ٢/٢٨٩. وعزاه السيوطي إلى عبد بن حميد.</p><p>وهي قراءة شاذّة. ينظر: البحر المحيط ٢/٤٠١.أخرجه ابن حبان ٣/٢٠ (٧٤٥)، والحاكم ١/٧٣٩ (٢٠٣١)، ٢/٣١٧ (٣١٤٤)، وابن جرير ١/٦٢-٦٣.</p><p>قال الحاكم: «هذا حديث صحيح الإسناد، ولم يخرجاه». وقال الذهبي في التلخيص: «منقطع». وقال الطحاوي في مشكل الآثار ٨/١١٥ (٣١٠٣): «كان أهل العلم بالأسانيد يدفعون هذا الحديث؛ لانقطاعه في إسناده، ولأنّ أبا سلمة لا يَتَهَيَّأ في سِنِّه لقاءُ عبد الله بن مسعود، ولا أخذُه إيّاه عنه». وقال ابن حجر في الفتح ٩/٢٩: «قال ابن عبد البر: هذا حديث لا يثبت؛ لأنّه من رواية أبي سلمة بن عبد الرحمن عن ابن مسعود، ولم يَلْقَ ابنَ مسعود، وقد رَدَّه قومٌ مِن أهل النظر؛ منهم أبو جعفر أحمد بن أبي عمران. قلتُ: وأطنب الطبريُّ في مقدّمة تفسيره في الرَّدِّ على مَن قال به، وحاصله: أنّه يستحيل أن يجتمع في الحرف الواحد هذه الأوجه السبعة، وقد صحّح الحديثَ المذكور ابنُ حبان، والحاكمُ، وفي تصحيحه نظر؛ لانقطاعه بين أبي سلمة وابن مسعود، وقد أخرجه البيهقي مِن وجهٍ آخر عن الزهري عن أبي سلمة مرسلًا، وقال: هذا مرسل جيد». وحسّنه الألباني في الصحيحة ٢/١٣٤ (٥٨٧).عزاه السيوطي إلى ابن أبي حاتم.عزاه السيوطي إلى ابن النجار في تاريخ بغداد.</p><p>قال السيوطي: «سندٌ واهٍ».أخرجه ابن جرير ٥/٢١٨، وابن المنذر ١/١٣١، ١٣٣ (٢٥٦)، وابن أبي حاتم ٢/٥٩٩ (٣٢٠٨).أخرجه ابن جرير ٥/٢٢٦، وابن أبي حاتم ٢/٦٠١ (٣٢١٧).أخرجه ابن جرير ٥/٢٢٠، وابن المنذر (٢٥٨)، وابن الأنباري في الأضداد ص٤٢٤.أخرجه ابن أبي حاتم ٢/٦٠٠.علَّقه ابن أبي حاتم ٢/٦٠٠.أخرجه ابن جرير ٥/٢١٩ عن أبي نَهِيك فقط من طريق عبيد الله، وابن أبي حاتم ٢/٥٩٩ (٣٢٠٦).أخرجه ابن جرير ٥/٢١٨-٢١٩، وابن أبي حاتم ٢/٥٩٩.أخرجه ابن جرير ٥/٢١٩. وعزاه السيوطي إلى عبد بن حميد.أخرجه عبد بن حميد -كما في الفتح للحافظ ابن حجر ٨/٢١٠-، وابن جرير ٥/٢٢٠، وابن الأنباري في كتاب الأضداد ص٤٢٤.أخرجه ابن أبي حاتم ٢/٥٩٩.أخرجه ابن جرير ٥/٢٢٦، وابن أبي حاتم ٢/٦٠١. وعلّق ابنُ المنذر ١/١٣٤ نحوه، وزاد في آخره: وكُلٌّ طَيِّب.أخرجه ابن أبي حاتم ٢/٦٠٠. وعلَّق ابن المنذر ١/١٣٤ نحوه.أخرجه ابن جرير ٥/٢٢٤. وعلَّقه ابن أبي حاتم ٢/٦٠٠.أخرجه ابن جرير ٥/٢٢٠.أخرجه ابن جرير ٥/٢٢٠-٢٢١.خَلَصَت: صار خالصًا، وأخلص لله ترك الرياء، وأخلص دينه لله: أمحَضَه. اللسان والقاموس (خلص).أخرجه ابن أبي حاتم ٢/٦٠٠-٦٠١.تفسير مقاتل بن سليمان ١/٢٦٤.أخرجه ابن جرير ٥/٢١٩.أخرجه ابن جرير ٥/٢٢٥، وابن المنذر (٢٦٤)، وابن أبي حاتم ٢/٦٠٠ (٣٢١٤).أخرجه ابن جرير ٥/٢٢٥.أخرجه ابن جرير ٥/٢٢٦.أخرجه ابن جرير ٥/٢٢٠-٢٢١.أخرجه ابن أبي حاتم ٢/٦٠١، وبنحوه مختصرًا من طريق ابن إدريس.أخرجه ابن جرير ٥/٢٢٧.أخرجه ابن أبي حاتم ٢/٦٠١.تفسير مقاتل بن سليمان ١/٢٦٤.أخرجه أحمد ١٢/٤٧٦ (٧٥٠٨)، ١٦/١٥٥ (١٠٢٠٢)، ١٦/٢٦٠ (١٠٤١٤)، وأبو داود ٧/١٢ (٤٦٠٣)، وابن حِبّان ٤/٣٢٤ (١٤٦٤)، والحاكم ٢/٢٤٣ (٢٨٨٣). ولفظ أبي داود وابنِ حِبّان: «الـمِراءُ بالقرآن».</p><p>قال الحاكم: «حديث المعتمر عن محمد بن عمرو صحيحٌ، على شرط مسلم، ولم يخرجاه، فأما عمر بن أبي سلمة فإنّهما لم يحتجّا به». وحسّنه ابنُ القَيِّم في تهذيب سنن أبي داود ١٢/٣٥٣.يَنزِع: أي: يجُرُّها إلى نفسه، ويستدل بها على مقصوده. تاج العروس (نزع).عزاه السيوطي إلى نصر المقدسي في الحجة، وأخرجه ابن أبي عاصم في السنة ١/١٧٧ (٤٠٦) بلفظ: «يتنازعون في القدر».</p><p>قال الألباني في ظلال الجنة ١/١٩١ عن رواية ابن أبي عاصم: «إسناده حسن؛ للخلاف المعروف في عمرو بن شعيب عن أبيه عن جده».أخرجه الحارث في مسنده ٢/٧٤٠ (٧٣٥).</p><p>قال البوصيري في إتحاف الخيرة ٦/٣٢٣-٣٢٤ (٥٩٣٦): «رواه ابن ماجه في سننه مختصرًا بإسناد صحيح من طريق أبي معاوية عن داود به».أخرجه الدارمي ١/٤٩.التبان: سراويل صغير، مقدار شبر يستر العورة المغلظة فقط، يكون للملاحين. وقيل: التبان شبه السراويل الصغير. مادة (تبن).القتب: إكاف البعير. مادة (قتب).أخرجه ابن عساكر ٢٣/٤١٢. وعزاه السيوطي إلى ابن الأنباري في المصاحف، ونصر المقدسي في الحجة.أخرجه الدارمي ١/٥٤. وعزاه السيوطي إلى نصر المقدسي في الحجة.أخرجه ابن عساكر ٢٣/٤١٣.أخرجه ابن أبي شيبة ١٠/٤٨٩.أخرجه ابن أبي شيبة ١٠/٤٨٩.أخرجه ابن أبي شيبة ١٠/٤٨٩.أخرجه الثعلبي ٣/١٤. وقال عقبه: وهذا إنما قاله ابن عباس في وقت، ثم علمها بعد ذلك وفسرها.
  3,8,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿رَبَّنَا لَا تُزِغۡ قُلُوبَنَا بَعۡدَ إِذۡ هَدَیۡتَنَا وَهَبۡ لَنَا مِن لَّدُنكَ رَحۡمَةًۚ إِنَّكَ أَنتَ ٱلۡوَهَّابُ ۝٨﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">١٢٠٨٤<span class="dash">-</span></span> عن أمّ سلمة -من طريق شهر بن حَوْشَب- أنّ النبي ﷺ كان يقول: «<b>يا مُقَلِّبَ القلوبِ، ثَبِّتْ قلبي على دينك</b>». ثم قرأ: <span class="qpc-hafs">﴿ربنا لا تزغ قلوبنا بعد إذ هديتنا﴾</span> الآية{1}. (٣/٤٦٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٠٨٥<span class="dash">-</span></span> عن عائشة، قالت: كان رسول الله ﷺ كثيرًا ما يدعو: «<b>يا مُقَلِّب القلوب، ثَبِّت قلبي على دينك</b>». قلتُ: يا رسول الله، ما أكثرَ ما تدعو بهذا الدعاء! فقال: «<b>ليس مِن قلب إلا وهو بين أصبعين من أصابع الرحمن؛ إذا شاء أن يُقِيمه أقامه، وإذا شاء أن يُزِيغه أزاغه، أما تسمعين قوله تعالى: <span class="qpc-hafs">﴿ربنا لا تزغ قلوبنا بعد إذ هديتنا وهب لنا من لدنك رحمة إنك أنت الوهاب﴾</span>؟!»</b>{2}. <b>ولفظ ابن أبي شيبة: «إذا شاء أن يقلبه إلى هُدًى قلبه، وإذا شاء أن يقلبه إلى ضلال قلبه»</b>{3}. (٣/٤٦٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٠٨٦<span class="dash">-</span></span> قال <span class="name-2">الحسن البصري</span>: هذا دعاءٌ أمَرَ اللهُ المؤمنين أن يَدْعُوا به{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٠٨٧<span class="dash">-</span></span> عن <span class="name-3">محمد بن جعفر بن الزبير</span> -من طريق ابن إسحاق- في قوله: <span class="qpc-hafs">﴿ربنا لا تزغ قلوبنا﴾</span>، أي: لا تُمِل قلوبَنا، وإن مِلْنا بأَحْداثِنا{5}{6}<span class=comment-ref>١١٢٠</span>. (٣/٤٧٠)</p></p><p></div></p><p><div><span class=comment-ref>١١٢٠</span> لم يذكر <u>ابنُ جرير</u> (٥/٢٢٨) غير هذا القول.</div></p><p><div></p><p><p><span class="item-no">١٢٠٨٨<span class="dash">-</span></span> عن <span class="name-3">محمد بن إسحاق</span> -من طريق إبراهيم بن سعد-، مثله{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٠٨٩<span class="dash">-</span></span> عن <span class="name-3">محمد بن إسحاق</span> -من طريق إدريس- قوله: <span class="qpc-hafs">﴿ربنا لا تزغ قلوبنا بعد إذ هديتنا﴾</span>: أي: بعد ما بَصَّرْتَنا مِن الهُدى فيما جاء به أهلُ البِدْعَةِ والضَّلالة{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٠٩٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: قال ابن سلام وأصحابه: <span class="qpc-hafs">﴿ربنا لا تزغ قلوبنا بعد إذ هديتنا﴾</span>: لا تُمِلْ قلوبَنا، يعني: لا تُحَوِّل قلوبَنا عن الهُدى بعدما هديتنا، كما أزَغْتَ اليهودَ عن الهُدى{9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٠٩١<span class="dash">-</span></span> عن <span class="name-3">مقاتل بن حيان</span> -من طريق بُكَيْر- قال: دعا عبدُ الله بن سلام وأصحابُه ربَّهم، فقالوا: <span class="qpc-hafs">﴿ربنا لا تزغ قلوبنا بعد إذا هديتنا﴾</span> كما أزغت قلوب اليهود بعد إذ هديتهم، <span class="qpc-hafs">﴿وهب لنا من لدنك رحمة إنك أنت الوهاب﴾</span>{10}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَهَبۡ لَنَا مِن لَّدُنكَ رَحۡمَةًۚ إِنَّكَ أَنتَ ٱلۡوَهَّابُ ۝٨﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">١٢٠٩٢<span class="dash">-</span></span> قال <span class="name-2">الضَّحّاك بن مُزاحِم</span>: <span class="qpc-hafs">﴿رحمة﴾</span>: تَجاوُزًا ومغفرة{11}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٠٩٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وهب لنا من لدنك﴾</span> يعني: مِن عندك <span class="qpc-hafs">﴿رحمة إنك أنت الوهاب﴾</span> للرَّحْمة{9}<span class=comment-ref>١١٢١</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>١١٢١</span> <span class="comment-type-4">ذكر</span> <u>ابنُ عطية</u> (٢/١٦٤) أن هذه الآية تحتمل احتمالين: <b>الأول</b>: أن تكون هذه الآية حكاية عن الراسخين في العلم، أنهم يقولون هذا مع قولهم: <span class="qpc-hafs">﴿آمنا به﴾</span>. <b>الثاني</b>: أن يكون المعنى منقطعًا مِن الأول، لما ذكر أهل الزيغ وذكر نقيضهم، وظهر ما بين الحالتين عقَّب ذلك بأن علَّم عباده الدعاء إليه في أن لا يكونوا من الطائفة الذميمة التي ذكرت، وهي أهل الزيغ.</div></p><p><div></p><p><p><span class="item-no">١٢٠٩٤<span class="dash">-</span></span> عن <span class="name-3">محمد بن إسحاق</span> -من طريق إبراهيم بن سعد- <span class="qpc-hafs">﴿ربنا لا تزغ قلوبنا بعد إذ هديتنا﴾</span> أي: لا تُمِلْ قلوبنا، وإن مِلْنا بأَحْداثِنا، <span class="qpc-hafs">﴿وهب لنا من لدنك رحمة إنك أنت الوهاب﴾</span>. ثُمَّ عَرَّض بما شاء أن يُعَرِّض مِن التَّرْهِيب والتَّرْغِيب، والذِّكْرِ لِمَن شاء أن يذكر، ثم قال: <span class="qpc-hafs">﴿شهد الله أنه لا إله إلا هو والملائكة وأولو العلم قائمًا بالقسط﴾</span> بخِلاف ما قالوا{13}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَهَبۡ لَنَا مِن لَّدُنكَ رَحۡمَةًۚ إِنَّكَ أَنتَ ٱلۡوَهَّابُ ۝٨﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">١٢٠٩٥<span class="dash">-</span></span> عن عائشة: أنّ رسول الله ﷺ كان إذا استيقظ مِن الليل قال: «<b>لا إله إلا أنت، سُبحانك، اللَّهُمَّ، إنِّي أستغفرُك لذنبي، وأسألك رحمتَك، اللَّهُمَّ، زِدْنِي عِلمًا، ولا تُزِغْ قلبي بعد إذ هديتني، وهَبْ لي مِن لدنك رحمة؛ إنّك أنت الوهّاب»</b>{14}. (٣/٤٧١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٠٩٦<span class="dash">-</span></span> عن أُمِّ سلمة: أنّ رسول الله ﷺ كان يُكْثِر في دُعائِه أن يقول: «<b>اللَّهُمَّ مُقَلِّبَ القلوب، ثَبِّت قلبي على دينك».</b> قلتُ: يا رسول الله، وإنّ القلوبَ لَتَتَقَلَّبُ؟ قال: <b>«نعم، ما مِن خلقِ الله مِن بشرٍ من بني آدم إلا وقلبُه بين أصبعين من أصابع الله؛ فإن شاء اللهُ أقامَه، وإن شاء أزاغه، فنسأل الله ربَّنا أن لا يزيغ قلوبنا بعد إذ هدانا الله، ونسأله أن يَهَبَ لنا مِن لدُنه رحمةً؛ إنّه هو الوهّاب»</b>. قلتُ: يا رسول الله، ألا تُعَلمْني دعوةً أدعو بها لنفسي. قال: <b>«بلى، قولي: اللَّهُمَّ ربَّ النبي محمد، اغفر لي ذنبي، وأَذْهِب غَيْظ قلبي، وأَجِرْنِي مِن مُضِلّات الفِتَنِ ما أحْيَيْتَنِي»</b>{15}. (٣/٤٦٦-٤٦٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٠٩٧<span class="dash">-</span></span> عن النّواس بن سَمعان: سمعتُ رسول الله ﷺ يقول: <b>«الميزان بيد الرحمن؛ يرفع أقوامًا ويضع آخرين إلى يوم القيامة، وقلبُ ابنِ آدم بين أصبعين من أصابع الرحمن؛ إذا شاء أقامه، وإذا شاء أزاغه».</b> وكان يقول: <b>«يا مُقَلِّب القلوب، ثبِّتْ قلبي على دينِك»</b>{16}. (٣/٤٦٩-٤٧٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٠٩٨<span class="dash">-</span></span> عن عبد الله بن عمرو، أنّه سَمِع رسول الله ﷺ يقول: <b>«إنّ قلوب بني آدم كلَّها بين أصبعين من أصابع الرحمن كقلب واحد يصرّفه كيف يشاء»</b>. ثم قال رسول الله ﷺ: <b>«اللَّهُمَّ يا مُصَرِّف القلوب، صَرِّف قلوبَنا إلى طاعتك»</b>{17}. (٣/٤٧١-٤٧٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢٠٩٩<span class="dash">-</span></span> عن جابر، قال: كان رسول الله ﷺ يُكْثِر أن يقول: <b>«يا مُقَلِّب القلوب، ثبِّت قلوبَنا على دينك».</b> قلنا: يا رسول الله، تخافُ علينا وقد آمَنّا بِك؟ فقال: «<b>إنّ قلوب بني آدم بين أصبعين من أصابع الرحمن كقلبٍ واحدٍ يقول به هكذا</b>»{18}. ولفظ الطبراني: «<b>إنّ قلب ابن آدم بين أصبعين من أصابع الله ﷿؛ فإذا شاء أن يُقِيمه أقامه، وإذا شاء أن يُزِيغه أزاغه</b>»{19}. (٣/٤٦٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢١٠٠<span class="dash">-</span></span> عن أنس، قال: كان النبي ﷺ يُكْثِرُ أن يقول: <b>«يا مُقَلِّب القلوب، ثبِّتْ قلبي على دينك»</b>. قالوا: يا رسول الله، آمنّا بِك وبما جئتَ به، فهل تخافُ علينا؟ قال: <b>«نعم».</b> قال: <b>«إنّ القلوب بين أصبعين من أصابع الله، يُقَلِّبُها»</b>{20}. (٣/٤٦٧-٤٦٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢١٠١<span class="dash">-</span></span> عن أبي عبيدة بن الجراح، أنّ رسول الله ﷺ قال: <b>«إنّ قلبَ ابنِ آدم مِثْلُ قلبِ العصفور، يَتَقَلَّبُ في اليوم سبعَ مرّات»</b>{21}. (٣/٤٦٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢١٠٢<span class="dash">-</span></span> عن المِقداد، قال: سمعتُ رسول الله ﷺ يقول: <b>«لَقَلْبُ ابنِ آدم أشَدُّ انقِلابًا مِن القِدْر إذا اجْتَمَعَ غَلَيانًا»</b>{22}. (٣/٤٧٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢١٠٣<span class="dash">-</span></span> عن أبي موسى الأشعري، عن النبي ﷺ، قال: <b>«إنّ هذا القلبَ كريشةٍ بِفَلاةٍ من الأرض، تُقِيمُها الرِّيحُ ظَهْرًا لِبَطْنٍ»</b>{23}. (٣/٤٦٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢١٠٤<span class="dash">-</span></span> عن <span class="name-1">أبي موسى الأشعري</span>، قال: إنّما سُمِّي القلبُ قلبًا لِتَقَلُّبِه، وإنّما مَثَلُ القَلْبِ مَثَلُ رِيشَةٍ بِفَلاةٍ مِن الأرض{24}. (٣/٤٦٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢١٠٥<span class="dash">-</span></span> عن <span class="name-1">أبي أيُّوب الأنصاري</span>، قال: لَيَأْتِيَنَّ على الرجل أحايِينُ وما في جِلْدِه مَوْضِعُ إبْرَةٍ مِن النفاق، ولَيَأْتِيَنَّ عليه أحايِينُ وما في جِلْدِه مَوْضِعُ إبْرَةٍ مِن إيمان{25}. (٣/٤٧١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢١٠٦<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق سعيد بن جبير- قال: إنّما سُمِّي: القَلْبُ؛ لأنّه يَتَقَلَّبُ{26}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢١٠٧<span class="dash">-</span></span> قال <span class="name-3">عبد الله بن وهب</span>: إذا خاف الوَسْوَسَةَ [يعني: المأموم] فلْيَقْرَأْ فيما يُسِرُّ فيه الإمام، فليقرأ ما فيه مِن القرآن دعاء: <span class="qpc-hafs">﴿ربنا لا تزغ قلوبنا﴾</span> الآية أو نحوه{27}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه الترمذي ٦/١٢٥ (٣٨٣١)، وابن جرير ٥/٢٢٩، وابن أبي حاتم ٢/٦٠١-٦٠٢ (٣٢٢٢).</p><p>قال الترمذي: «هذا حديث حسن». وقال ابن جرير ١٢/٤٣٥: «ولا نعلم لشهر سماعًا يصحّ عن أم سلمة». وقال الهيثمي في المجمع ٦/٣٢٥ (١٠٨٨٨): «قلت: روى الترمذي بعضه. رواه أحمد، وفيه شهر بن حوشب، وهو ضعيف وقد وثق». وقال في ١٠/١٧٦ (١٧٣٨١): «رواه أحمد، وإسناده حسن». وقال الألباني في الصحيحة ٥/١٢٦ (٢٠٩١): «وقال الترمذي: حديث حسن. قلت: يعني لغيره، وهو كما قال أو أعلى؛ لأن شهرًا هذا وإن كان سيِّء الحفظ فحديثه هذا له شواهد تقويه».أخرجه أحمد ٤١/١٥١ (٢٤٦٠٤)، ٤٣/٢٣٠ (٢٦١٣٣).</p><p>قال ابن كثير في تفسيره ٢/١٤: «غريب من هذا الوجه، ولكن أصله ثابت في الصحيحين، وغيرهما من طرق كثيرة بدون زيادة ذكر هذه الآية الكريمة».أخرجه ابن أبي شيبة ٦/٢٥ (٢٩١٩٩).ذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ١/٢٧٦-٢٧٧-.الأحداث جمع حَدَث وهو الفعل. يسألون الله أن يثبّت قلوبهم بالإيمان وإن مالت أفعالهم إلى بعض المعصية. تفسير الطبري بتحقيق أحمد شاكر ٦/٢١٢.أخرجه ابن جرير ٥/٢٢٨.أخرجه ابن المنذر ١/١٣٥، وابن أبي حاتم ٢/٦٠١ من طريق سلمة.أخرجه ابن أبي حاتم ٢/٦٠٢.تفسير مقاتل بن سليمان ١/٢٦٤.أخرجه الترمذي (٣٥٢٢)، وابن أبي حاتم ٢/٦٠٢.تفسير البغوي ٢/١١، وتفسير الثعلبي ٣/١٧.تفسير مقاتل بن سليمان ١/٢٦٤.أخرجه ابن المنذر ١/١٣٥.أخرجه أبو داود ٧/٣٩٩ (٥٠٦١)، وابن حبان ١٢/٣٤١ (٥٥٣١)، والحاكم ١/٧٢٤ (١٩٨١).</p><p>قال الحاكم: «هذا حديث صحيح الإسناد، ولم يخرجاه».أخرجه أحمد ٤٤/١٣٨ (٢٦٥١٩) مختصرًا، ٤٤/٢٠٠ (٢٦٥٧٦)، ٤٤/٢٧٨ (٢٦٦٧٩)، وابن جرير ٥/٢٢٩.</p><p>قال ابن جرير ١٢/٤٣٥: «ولا نعلم لشهر سماعًا يَصِحُّ عن أم سلمة». وقال الهيثمي في المجمع ٦/٣٢٥ (١٠٨٨٨): «قلت: روى الترمذي بعضه. رواه أحمد، وفيه شهر بن حوشب، وهو ضعيف وقد وُثِّق». وقال في ١٠/١٧٦ (١٧٣٨١): «قلت: عند الترمذي بعضه. رواه أحمد، وإسناده حسن».أخرجه أحمد ٢٩/١٧٨ (١٧٦٣٠)، وابن ماجه ١/١٣٧-١٣٨ (١٩٩)، وابن حبان ٣/٢٢٢ (٩٤٣)، والحاكم ١/٧٠٦ (١٩٢٦)، ٢/٣١٧ (٣١٤١)، ٤/٣٥٧ (٧٩٠٧).</p><p>قال الحاكم ٢/٣١٧ (٣١٤١): «هذا حديث صحيح، على شرط الشيخين، ولم يخرجاه». وقال الذهبي في التلخيص: «على شرط البخاري ومسلم». وقال البوصيري في مصباح الزجاجة ١/٢٧ (٦٩): «إسناده صحيح».أخرجه مسلم ٤/٢٠٤٥ (٢٦٥٤).أخرجه الحاكم ٢/٣١٧ (٣١٤٠)، وابن جرير ٥/٢٣٠.</p><p>قال الحاكم: «هذا حديث صحيح، على شرط مسلم، ولم يخرجاه هكذا، إنما تفرد مسلم بإخراج حديث عبد الله بن عمرو: «<b>قلوب بني آدم</b>» فقط». وقال الذهبي في التلخيص: «على شرط مسلم». وقال الهيثمي في المجمع ١٠/١٧٦ (١٧٣٨٢): «رواه أبو يعلى، ورجاله رجال الصحيح».عزاه السيوطيُّ إلى الطبراني في السُّنَّة.أخرجه أحمد ١٩/١٦٠ (١٢١٠٧)، ٢١/٢٥٩ (١٣٦٩٦)، والترمذي ٤/٢١٩ (٢٢٧٧)، وابن ماجه ٥/٩ (٣٨٣٤).</p><p>قال الترمذي: «هذا حديث حسن، وهكذا روى غير واحد عن الأعمش عن أبي سفيان عن أنس، وروى بعضهم عن الأعمش عن أبي سفيان عن جابر عن النبي ﷺ، وحديث أبي سفيان عن أنس أصحّ».أخرجه الحاكم ٤/٣٤٢ (٧٨٥٠)، ٤/٣٦٥ (٧٩٣٥).</p><p>قال الحاكم: «هذا حديث صحيح، على شرط مسلم، ولم يخرجاه». وقال الذهبي في التلخيص: «فيه انقطاع». وقال الألباني في الضعيفة ٧/١٧٠ (٣١٨٦): «ضعيف».أخرجه أحمد ٣٩/٢٣٨ (٢٣٨١٦)، والحاكم ٢/٣١٧ (٣١٤٢).</p><p>قال الحاكم: «هذا حديث صحيح، على شرط البخاري، ولم يخرجاه». وقال الذهبي في التخليص: «على شرط البخاري». وقال البزار في مسنده ٦/٤٧ (٢١١٢): «وهذا الكلام لا نحفظه إلا عن المقداد عن النبي ﷺ، إلا رجل قلبه فجعله عن المقدام، والصواب عندنا هو المقداد، وإسناده إسناد حسن». وأورده الألباني في الصحيحة ٤/٣٧٥ (١٧٧٢).أخرجه أحمد ٣٢/٥٢٩ (١٩٧٥٧) واللفظ له، وابن ماجه ١/٦٦ (٨٨).</p><p>قال عبد الله بن أحمد: «قال أبي: ولم يرفعه إسماعيلُ عن الجريري».عزاه السيوطي إلى ابن أبي الدنيا في الإخلاص.أخرجه الحكيم الترمذي ١/٢٧٤.أخرجه ابن المنذر ١/١٢٢.جامع ابن وهب ١/٦٧-٦٨ (١٥١).
  3,9,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿رَبَّنَاۤ إِنَّكَ جَامِعُ ٱلنَّاسِ لِیَوۡمࣲ لَّا رَیۡبَ فِیهِۚ إِنَّ ٱللَّهَ لَا یُخۡلِفُ ٱلۡمِیعَادَ ۝٩﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">١٢١٠٨<span class="dash">-</span></span> عن أُمِّ هانئ، أنّ رسول الله ﷺ قال: <b>«إنّ الله يجمع الأوَّلين والآخِرين في صعيدٍ واحدٍ يومَ القيامة»</b>{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢١٠٩<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عكرمة- في قول الله: <span class="qpc-hafs">﴿إن الله لا يخلف الميعاد﴾</span>، قال: ميعاد مَن قال: لا إله إلا الله{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">١٢١١٠<span class="dash">-</span></span> قال <span class="name-3">مُقاتِل بن سليمان</span>: ثُمَّ قال ابن سلام وأصحابُه: <span class="qpc-hafs">﴿ربنا إنك جامع الناس ليوم لا ريب فيه﴾</span> يعني: ليوم القيامة، <span class="qpc-hafs">﴿إن الله لا يخلف الميعاد﴾</span> في البعث بأنّك تجمع الناس في الآخرة{3}<span class=comment-ref>١١٢٢</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>١١٢٢</span> <span class="comment-type-4">ذكر</span> <u>ابن عطية</u> (٢/١٦٥) أن قوله تعالى: <span class="qpc-hafs">﴿إن الله لا يخلف الميعاد﴾</span>يحتمل احتمالين: <b>الأول:</b> أن يكون إخبارًا منه لمحمدٍ ﷺ وأمته. <b>الثاني</b>: أن يكون حكايةً من قول الداعين، ففي ذلك إقرار بصفة ذات الله تعالى.</div></p><p><h3><span class="qpc-hafs">﴿رَبَّنَاۤ إِنَّكَ جَامِعُ ٱلنَّاسِ لِیَوۡمࣲ لَّا رَیۡبَ فِیهِۚ إِنَّ ٱللَّهَ لَا یُخۡلِفُ ٱلۡمِیعَادَ ۝٩﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">١٢١١١<span class="dash">-</span></span> عن جعفر بن محمد الخُلْدِيّ، قال: رُوِي عن النبي ﷺ أنّه قال: <b>«مَن قرأ هذه الآيةَ على شَيْءٍ ضاع مِنهُ رَدَّه اللهُ عليه</b>: <b><span class="qpc-hafs">﴿ربنا إنك جامع الناس ليوم لا ريب فيه إن الله لا يخلف الميعاد﴾</span>، اللَّهُمَّ يا جامعَ الناسِ ليوم لا ريب فيه، اجْمَع بيني وبين مالي؛ إنّك على كل شيء قدير»</b>{4}. (٣/٤٧٢)</p></p><p></div></p></div>",footnotes:1:أخرجه الطبراني في الأوسط ٢/٨٧ (١٣٣٦)، وابن أبي حاتم ٢/٦٠٢ (٣٢٢٥)، ٩/٣٠٤٩ (١٧٢٤٢).</p><p>قال الطبراني: «لا يُرْوى هذا الحديثُ عن أُمِّ هانئ إلا بهذا الإسناد، تفرد به أبو عاصم الثقفي الكوفي». وقال الهيثمي في المجمع ١٠/٣٥٦ (١٨٤٢٥): «فيه أبو عاصم الربيع بن إسماعيل، منكر الحديث، قاله أبو حاتم». وهو متفق عليه من حديث أبي هريرة.أخرجه ابن أبي حاتم ٢/٦٠٢. كما أورده عند تفسير قوله تعالى: <span class="qpc-hafs">﴿رَبَّنا وآتِنا ما وعَدْتَنا عَلى رُسُلِكَ ولا تُخْزِنا يَوْمَ القِيامَةِ إنَّكَ لا تُخْلِفُ المِيعادَ (١٩٤)﴾</span> [آل عمران:١٩٤]، وهو ألصق بتفسيرها.تفسير مقاتل بن سليمان ١/٢٦٤.أخرجه ابن النَّجّار في ذيل تاريخ بغداد ١٨/١٤.</p><p>وهذا مُعْضَل، جعفر بن محمد الخلدي في طبقة شيوخ الدارقطني، توفي سنة ٣٤٨هـ، ترجمته في تاريخ بغداد ٧/٢٢٦، وقد ذكره بلا إسناد وبصيغة التمريض. ثم في إسناده أبو العز أحمد بن عبيد الله بن كادش، قال الذهبي ١/١١٨: «أقَرَّ بوَضْعِ حديثٍ، وتاب وأناب».