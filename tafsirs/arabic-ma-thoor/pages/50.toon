tafsir[9]{c,v,t}:
3,1," مقدمة السورة{1} ١١٨١٨- عن عبد الله بن عباس، قال: نزلت سورةُ آل عمران بالمدينة{2}. (٣/٤٣٨) ١١٨١٩- عن عبد الله بن عباس - من طريق عطاء الخراساني-: مدنية، نزلت بعد الأنفال{3}. (ز) ١١٨٢٠- عن عكرمة مولى ابن عباس= (ز) ١١٨٢١- والحسن البصري -من طريق يزيد النحوي- قالا: مدنية{4}. (ز) ١١٨٢٢- عن قتادة بن دِعامة -من طُرُق-: مدنية{5}. (ز) ١١٨٢٣- عن محمد ابن شهاب الزهري، قال: مدنية، نزلت بعد الفاتحة{6}. (ز) ١١٨٢٤- عن علي بن أبي طلحة، قال: مدنية{7}. (ز) ١١٨٢٥- قال مقاتل بن سليمان: مدنية كلها{8}١٠٨٧. (ز) ١٠٨٧ رَجَّح ابنُ كثير (٣/٥) مدنيةَ السورة مستندًا إلى أحوال النزول، فقال: «هي مدنية؛ لأنّ صدرها إلى ثلاث وثمانين آية منها نزلت في وفد نجران، وكان قدومهم في سنة تسع من الهجرة». وقال ابنُ عطية (٢/١٤٧): «هذه السورة مدنية بالإجماع فيما علمتُ». ١١٨٢٦- عن الربيع بن أنس -من طريق أبي جعفر- قال: إنّ النصارى أتَوا رسولَ الله ﷺ، فخاصموه في عيسى ابن مريم، وقالوا له: مَن أبوه؟ وقالوا على الله الكذب والبهتان، فقال لهم النبي ﷺ: «ألستم تعلمون أنّه لا يكون ولدٌ إلا وهو يُشْبِه أباه؟». قالوا: بلى. قال: «ألستم تعلمون أنّ ربنا حَيٌّ لا يموت، وأنّ عيسى يأتي عليه الفناء؟». قالوا: بلى. قال: «ألستم تعلمون أنّ ربَّنا قَيِّمٌ على كل شيء يَكْلَؤُه ويحفظه ويرزقه؟». قالوا: بلى. قال: «فهل يملك عيسى مِن ذلك شيئًا؟» قالوا: لا. قال: «أفلستم تعلمون أنّ الله لا يخفى عليه شيء في الأرض ولا في السماء؟» قالوا: بلى. قال: «فهل يعلم عيسى من ذلك شيئًا إلا ما علم؟». قالوا: لا. قال: «فإنّ ربَّنا صَوَّرَ عيسى في الرَّحِم كيف شاء. ألستم تعلمون أنّ ربَّنا لا يأكل الطعام، ولا يشرب الشراب، ولا يحدث الحدث؟». قالوا: بلى. قال: «ألستم تعلمون أنّ عيسى حَمَلَتْهُ أمُّه كما تحمل المرأةُ، ثُمَّ وضَعَتْه كما تَضَعُ المرأةُ ولدَها، ثُمَّ غُذِّي كما تُغَذِّي المرأةُ الصبيَّ، ثُمَّ كان يأكل الطعام ويشرب الشراب ويحدث الحدث؟». قالوا: بلى. قال: «فكيف يكون هذا كما زعمتم؟». فعرفوا، ثم أبَوْا إلا جُحودًا؛ فأنزل الله: <q>﴿الم الله لا إله إلا هو الحي القيوم﴾</q>{9}. (٣/٤٤٣-٤٤٤) ١١٨٢٧- عن محمد بن جعفر بن الزبير، قال: قدِم على النبيِّ ﷺ وفدُ نجران سِتُّون راكبًا، فيهم أربعة عشر رجلًا مِن أشرافهم، فكلَّم رسولَ الله ﷺ منهم أبو حارثة بن عَلْقَمة، والعاقب عبد المسيح، والأَيْهَم السيِّد، وهو من النصرانيّة على دين الملك مع اختلاف من أمرهم؛ يقولون: هو الله. ويقولون: هو ولد الله. ويقولون: هو ثالث ثلاثة. كذلك قول النصرانية، فهم يحتجّون في قولهم، يقولون: هو الله بأنّه كان يُحْيِي الموتى، ويُبْرِئُ الأسقام، ويخبر بالغيوب، ويخلق من الطين كهيئة الطير ثم ينفخ فيه فيكون طيرًا، وذلك كلّه بإذن الله ليجعله آيةً للناس. ويحتجّون في قولهم بأنّه ولد بأنهم يقولون: لم يكن له أب يُعْلَم، وقد تكلم في المهد شيئًا لم يصنعه أحدٌ مِن ولد آدم قبله. ويحتجّون في قولهم أنّه ثالث ثلاثة بقول الله: فعلنا، وأمرنا، وخلقنا، وقضينا. فيقولون: لو كان واحدًا ما قال إلا: فعلتُ، وأمرتُ، وقضيتُ، وخلقتُ. ولكنه هو وعيسى ومريم، ففي كل ذلك من قولهم نزل القرآن، وذكر الله لنبيه فيه قولهم، فلمّا كلّمه الحبران قال لهما رسول الله ﷺ: «أسلِما». قالا: قد أسلمنا قبلك. قال: «كذبتُما، منعكما من الإسلام دعاؤُكما لله ولدًا، وعبادتُكما الصليبَ، وأكلُكما الخنزيرَ». قالا: فمَن أبوه، يا محمد؟ فصَمَتَ، فلم يُجِبْهما شيئًا؛ فأنزل الله في ذلك مِن قولهم واختلافِ أمرِهم كلِّه صدرَ سورة آل عمران إلى بضع وثمانين آية منها. فافتتح السورة بتنزيه نفسِه مما قالوه، وتوحيده إياها بالخلق والأمر لا شريك له فيه، وردّ عليهم ما ابتدعوا من الكفر وجعلوا معه مِن الأنداد، واحتجاجًا عليهم بقولهم في صاحبهم ليعرّفهم بذلك ضلالته؛ فقال: <q>﴿الم الله لا إله إلا هو الحي القيوم﴾</q> أي: ليس معه غيره شريك في أمره، <q>﴿الحي﴾</q> الذي لا يموت، وقد مات عيسى في قولهم، <q>﴿القيّوم﴾</q> القائم على سلطانه لا يزول، وقد زال عيسى{10}. (٣/٤٤٠) ١١٨٢٨- عن محمد بن سهل بن أبي أمامة{11} -من طريق ابن إسحاق- قال: لَمّا قَدِم أهلُ نجران على رسول الله ﷺ يسألونه عن عيسى ابن مريم؛ نزلت فيهم فاتحةُ آل عمران إلى رأس الثمانين منها{12}. (٣/٤٤٣) ١١٨٢٩- عن محمد بن السائب الكلبي، أنّه قال: نزلت هذه الآياتُ في وفد نجران، وكانوا ستين راكبًا ...{13}. (ز) ١١٨٣٠- قال مقاتل بن سليمان: اجتمعت نصارى نجران، فمنهم السَّيِّدُ والعاقبُ، فقالوا: نشهد أنّ عيسى هو الله. فأنزل الله ﷿ تكذيبًا لقولهم: <q>﴿الم﴾</q> يخبره أنّه <q>﴿الله لا إله إلا هو الحي القيوم﴾</q>{8}. (ز) ",footnotes:1:⟨أورد السيوطي ٣/٤٣٨-٤٣٩ ضمنها عددًا من الآثار في فضائل السورة.⟩{ع}أخرجه ابن الضُّريس في فضائل القرآن ص٣٣ (١٧). وإسناده ضعيف جِدًّا؛ فيه عمر بن هارون البلخي متروك، وشيخه عثمان بن عطاء الخراساني ضعيف، يرويه عن أبيه عطاء بن أبي مسلم الخراساني، وهو صدوق يَهِم كثيرًا ويُرْسِل ويُدَلِّس، وقد عنعن. ينظر على الترتيب: التقريب (٥٠١٤، ٤٥٣٤، ٤٦٣٣). وأخرجه البيهقي في الدلائل ٧/١٤٣-١٤٤ من وجه آخر من طريق عبد العزيز بن عبد الرحمن، عن خصيف، عن مجاهد، عن ابن عباس. قال الذهبي في الميزان ٢/٦٣١: «عبد العزيز بن عبد الرحمن البالسي عن خصيف، اتَّهمه الإمام أحمد... وقال ابن حبان: لا يحلّ الاحتجاج به بحال. وقال النسائي وغيره: ليس بثقة. وضرب أحمد بن حنبل على حديثه». وخصيف هو ابن عبد الرحمن الجزري، صدوق سيئ الحفظ خلط بأخرة. كما في التقريب (١٧٢٨).أخرجه ابن الضُّريس في فضائل القرآن ١/٣٣-٣٥.أخرجه البيهقي في دلائل النبوة ٧/١٤٢-١٤٣.أخرجه الحارث المحاسبي في فهم القرآن ص٣٩٥ من طريقي معمر وسعيد، وأبو بكر بن الأنباري -كما في الإتقان في علوم القرآن ١/٥٧- من طريق همام. كما أخرج ابن المنذر ١/١٠٧ نحوه من طريق سعيد: أنّ الذي نزل بالمدينة من القرآن البقرة، وآل عمران ...تنزيل القرآن ص٣٧-٤٢.أخرجه أبو عبيد في فضائله (ت: الخياطي) ٢/٢٠٠.تفسير مقاتل بن سليمان ١/٢٦٢.أخرجه ابن جرير ٥/١٧٤-١٧٥ مرسلًا، وكذا ابن أبي حاتم ٢/٥٨٥ (٣١٢٤)، ٨/٢٥١٤ (١٤٠٧٦) واللفظ له. وأبو جعفر الرازي صدوق سَيِّءُ الحفظ، كما في التقريب (٨٠٧٧).أخرجه ابن إسحاق -كما في سيرة ابن هشام ١/٥٧٥- عن محمد بن جعفر بن الزبير، ومن طريقه ابن جرير ٥/١٧١-١٧٤، وابن المنذر ١/١٠٩-١١١ (١٩٩). إسناده معضل؛ محمد بن جعفر بن الزبير بن العوام الأسدي المدني ثقة من أتباع التابعين، توفي سنة بضع عشرة ومائة كما في التقريب (٥٨١٩). والراوي عنه محمد بن إسحاق بن يسار إمام المغازي صدوق يدلّس كما في التقريب (٥٧٦٢) وقد عنعن.كذا في المصدر وفي الدر، ولعلّه: محمد بن أبي أمامة بن سهل بن حنيف، من الذين عاصروا صغار التابعين. ينظر: تقريب التهذيب (٥٧٤٨).أخرجه البيهقي في الدلائل ٥/٣٨٥ من طريق محمد بن إسحاق، قال: حدثني محمد بن سهل بن أبي أمامة. وهذا إسناد مرسل أو معضل؛ فإنّ ابن إسحاق من صغار التابعين الذين رأوا بعض الصحابة ولم يثبت لهم السماع منهم كما في التقريب (٥٧٦٢)، وروايته إنما هي عن التابعين فمَن دونهم.تفسير البغوي ٢/٥، وتفسير الثعلبي ٣/٦.تفسير مقاتل بن سليمان ١/٢٦٢.
3,2," <q>﴿الۤمۤ ۝١ ٱللَّهُ لَاۤ إِلَـٰهَ إِلَّا هُوَ ٱلۡحَیُّ ٱلۡقَیُّومُ ۝٢﴾</q> - قراءات ١١٨٣١- عن أُبَيِّ بن كعب أنّه قرأ: <q>﴿الحي القيّوم﴾</q>{1}١٠٨٨. (٣/٤٤٠) ١٠٨٨ رَجَّح ابنُ جرير (٥/١٧٦) قراءة <q>﴿القيّوم﴾</q> مستندًا إلى استفاضة القراءة بها، وخطّ المصحف، فقال: «والقراءة التي لا يجوز غيرها عندنا في ذلك ما جاءت به قراءة المسلمين نقلًا مستفيضًا، عن غير تشاعر ولا تواطؤ، وِراثَةً، وما كان مثبتًا في مصاحفهم، وذلك قراءة مَن قرأ: <q>﴿الحي القيوم﴾</q>». ١١٨٣٢- عن عبد الله بن مسعود -من طريق أبي خالد الكناني- أنّه كان يقرؤها: (الحَيُّ القَيّامُ){2}. (٣/٤٤٠، ٤٤٤) ١١٨٣٣- عن سليمان الأعمش، قال: في قراءة عبد الله بن مسعود: (الحَيُّ القَيّامُ){3}. (٣/٤٤٠) ١١٨٣٤- عن علقمة بن قيس -من طريق أبي مَعْمَر- أنّه كان يقرأ: (الحَيُّ القَيّامُ){4}. (٣/٤٤١) ١١٨٣٥- عن علقمة بن قيس -من طريق أبي مَعْمَر- أنّه قرأ: (الحَيُّ القَيِّمُ){5}. (٣/٤٤٤) ١١٨٣٦- عن أبي مَعْمَر، قال: سمعتُ علقمة يقرأ: (الحَيُّ القَيِّمُ).= (ز) ١١٨٣٧- وكان أصحاب عبد الله يقرؤون: (الحَيُّ القَيّامُ){6}. (٣/٤٤١) ١١٨٣٨- عن سليمان بن مهران الأعمش -من طريق أبي نُعيم- أنّه قرأ: (الحَيُّ القَيّامُ){7}١٠٨٩. (ز) ١٠٨٩ ذكر ابنُ جرير (٥/١٧٧) أنّ معاني هذه القراءات متقاربة، ثم قال: «ومعنى ذلك كله: القَيِّمُ بحفظ كل شيء، ورزقِه، وتدبيرِه، وتصريفِه فيما شاء وأحب مِن تغيير وتبديل وزيادة ونقص». وذكر ابنُ عطية (٢/١٤٩-١٥٠) أنّ مَن قرأ <q>﴿القيّوم﴾</q> فذلك وزنه: فَيْعُول، ومن قرأ (القيّام) فوزنه: فَيْعال، ومَن قرأ (القَيِّم) فوزنه: فيْعل -ونحوه عند ابن جرير (٥/١٧٩)-. ثم عَلَّق مُوَجِّهًا بقوله: «وهذا كله مِن: قام بالأمر يقوم به إذا اضطلع بحفظه وبجميع ما يحتاج إليه في وجوده، والله تعالى القيّام على كل شيء بما ينبغي له أو فيه أو عليه». <q>﴿الۤمۤ ۝١ ٱللَّهُ لَاۤ إِلَـٰهَ إِلَّا هُوَ﴾</q>{8} - تفسير ١١٨٣٩- عن محمد بن جعفر بن الزبير -من طريق ابن إسحاق- <q>﴿الله لا إله إلا هو الحي القيوم﴾</q>: أي: ليس معه غيرُه شريكٌ في أمره{9}. (٣/٤٤١-٤٤٢) ١١٨٤٠- عن محمد بن إسحاق -من طريق سلمة- قوله: <q>﴿الم الله لا إله إلا هو الحي القيوم﴾</q>: ففَتَح السورةَ بتبرئته نفسَه مِمّا قالوا، وتوحيدِه إيّاها بالخلق والأمر لا شريك له فيه، ورَدَّ عليهم ما ابتدعوا من الكفر وجعلوا معه من الأنداد، واحتجاجًا عليهم بقولهم في صاحبهم ليعرفوا بذلك ضلالتهم؛ فقال: <q>﴿الله لا إله إلا هو﴾</q>. أي: ليس معه غيره شريك في أمره{10}١٠٩٠. (ز) ١٠٩٠ ذكر ابنُ عطية (٢/١٤٧) أنّ الجرجانيَّ ذهب في النظم إلى أنّ أحسن الأقوال: أن يكون <q>﴿الم﴾</q> إشارة إلى حروف المعجم، كأنه يقول: هذه الحروف كتابك أو نحو هذا، ويدل قوله: <q>﴿الله لا إله إلا هو الحي القيوم نزل عليك الكتاب﴾</q> على ما ترك ذكره مما هو خبر عن الحروف، وأنّ ذلك في نظمه مثل قوله تعالى: <q>﴿أفمن شرح الله صدره للإسلام فهو على نور من ربه﴾</q>، وترك الجواب لدلالة قوله: <q>﴿فويل للقاسية قلوبهم من ذكر الله﴾</q> [الزمر:٢١] تقديره: كمن قسا قلبه. وذكر ابنُ عطية (٢/١٤٨) أنه يحسن في هذا القول أن يكون <q>﴿نزل﴾</q> خبر قوله: <q>﴿الله﴾</q> حتى يرتبط الكلام إلى هذا المعنى. وانتقده فقال: «وهذا الذي ذكره القاضي الجرجاني فيه نظر؛ لأن مُثُله ليست صحيحة الشبه بالمعنى الذي نحا إليه». ثم قال: «وما قاله في الآية محتمل». ثم ذكر أنّ «الأبرع في نظم الآية أن يكون <q>﴿الم﴾</q> لا يضم ما بعدها إلى نفسها في المعنى، وأن يكون <q>﴿الله لا إله إلا هو الحي القيوم﴾</q> كلامًا مبتدأً جزمًا جملةً رادَّةً على نصارى نجران الذين وفدوا على رسول الله ﷺ فحاجُّوه في عيسى ابن مريم وقالوا: إنه الله». <q>﴿ٱلۡحَیُّ﴾</q> - تفسير ١١٨٤١- عن قتادة بن دِعامة -من طريق سعيد- قوله: <q>﴿الحي﴾</q>: الذي لا يموت{10}. (ز) ١١٨٤٢- عن محمد بن جعفر بن الزبير -من طريق ابن إسحاق- <q>﴿الحي﴾</q>: الذي لا يموت. وقد مات عيسى وصُلِب في قولهم، يعني: في قول الأحبار الذين حاجّوا رسول الله ﷺ مِن نصارى أهل نجران{12}. (ز) ١١٨٤٣- قال مقاتل بن سليمان: قوله: <q>﴿الحي﴾</q>، يعني: الحي الذي لا يموت{13}١٠٩١. (ز) ١٠٩١ اختُلِف في معنى الحيّ؛ فقال قوم: هو وصْفٌ مِن الله لنفسه بالبقاء، ونَفْيٌ للموت عنها. وقال غيرهم: هو وصفٌ لنفسه بأنّه المُتَيَسِّرُ له تدبير ما أراد، وأنّه ليس كمن لا تدبير له مِن الآلهة والأنداد. وقال آخرون: معنى ذلك: أنّ له الحياة الدائمة التي لم تزل ولا تزال كذلك. ولم ينسب ابن جرير (٥/١٧٧) القولين الأخيرين، ثُمَّ قال: «ومعنى ذلك عندي: أنّه وصَفَ نفسَه بالحياة الدائمة التي لا فناءَ لها ولا انقطاعَ، ونفى عنها ما هو حالٌّ بكل ذي حياة مِن خلقه مِن الفناء وانقطاع الحياة عند مجيء أجله، فأخبر عبادَه أنّه المستوجبُ على خلقه العبادةَ والألوهةَ، والحيُّ: الذي لا يموت، ولا يبيد كما يموت كُلُّ مَن اتخذ مِن دونِه ربًّا، وأنّ الإله هو الدائم الذي لا يموت، ولا يبيد، ولا يفنى، وذلك الله الذي لا إله إلا هو». <q>﴿ٱلۡقَیُّومُ ۝٢﴾</q> - تفسير ١١٨٤٤- عن مجاهد بن جبر -من طريق ابن أبي نَجِيح- قال: <q>﴿القيوم﴾</q>: القائمُ على كل شيء{14}١٠٩٢. (٣/٤٤٠) ١٠٩٢ رَجَّح ابنُ جرير (٥/١٧٨-١٧٩) قولَ مجاهد والربيع مستندًا إلى اللغة، فقال: «وأَوْلى التأويلين بالصواب ما قاله مجاهد والربيع ... مِن قول العرب: فلانٌ قائمٌ بأمر هذه البلدة، تعني بذلك: المُتَوَلِّي تدبيرَ أمرها». ١١٨٤٥- عن الحسن البصري -من طريق سفيان بن حسين- <q>﴿القيّوم﴾</q>: الذي لا زوال له{10}. (ز) ١١٨٤٦- قال الحسن البصري: يعني: القائم على كُلِّ نفس بما كسبت، حتّى يجزيها بعملها{16}. (ز) ١١٨٤٧- قال قتادة بن دِعامة: القائم على كل شيء{17}. (ز) ١١٨٤٨- عن قتادة بن دِعامة -من طريق سلام بن أبي مُطِيع- في قوله: <q>﴿القيّوم﴾</q>: القيّم على الخلق بأعمالهم، وأرزاقهم، وآجالهم{18}. (ز) ١١٨٤٩- عن الربيع بن أنس -من طريق أبي جعفر- <q>﴿القيّوم﴾</q>: قَيِّمٌ على كل شيء يَكْلَؤُه، ويحفظه، ويرزقه{19}. (ز) ١١٨٥٠- عن محمد بن جعفر بن الزبير -من طريق ابن إسحاق- <q>﴿القيّوم﴾</q>: القَيّام على مكانه مِن سلطانه في خلقه لا يزول، وقد زال عيسى في قولهم -يعني: في قول الأحبار الذين حاجّوا النبي ﷺ من أهل نجران في عيسى- عن مكانه الذي كان به، وذهب عنه إلى غيره{20}. (٣/٤٤١-٤٤٢) ١١٨٥١- قال مقاتل بن سليمان: <q>﴿القيّوم﴾</q>، يعني: القائم على كل نفس بما كَسَبَتْ{13}. (ز) ١١٨٥٢- عن محمد بن إسحاق -من طريق عبد الله بن إدريس- قوله: <q>﴿القيوم﴾</q>: القائم على مكانته الذي لا يزول، وعيسى لحمٌ ودم، وقد قضي عليه بالموت، زال عن مكانه الذي يُحدث به{10}١٠٩٣. (ز) ١٠٩٣ ذكر ابنُ جرير (٥/١٧٨) أنّ مَن قالوا بهذا القول وجَّهوه إلى القيام الدائم الذي لا زوال معه ولا انتقال، وأنّ الله ﷿ إنّما نفى عن نفسه بوصفها بذلك التغيرَ والتنقلَ من مكان إلى مكان، وحدوثَ التبدل الذي يحدث في الآدميين وسائر خلقه غيرهم. <q>﴿ٱلۡقَیُّومُ ۝٢﴾</q> - آثار متعلقة بالآية ١١٨٥٣- عن أسماء يعني: بنت يزيد -من طريق شَهْر بن حوشب- أنّها سمعت رسول الله ﷺ يقول: «إنّ هاتين الآيتين اسمُ الله الأعظم <q>﴿ألـم الله لا إله إلا هو الحي القيوم﴾</q>، <q>﴿وإلهكم إله واحد لا إله إلا هو الرحمن الرحيم﴾</q> [البقرة:١٦٣]»{23}. (٢/١٠٦) ١١٨٥٤- عن عبد الله بن العلاء، حدّثني القاسمُ أبو عبد الرحمن، قال: إنّ اسم الله الأعظم في ثلاث سور من القرآن: في سورة البقرة، وآل عمران، وطه. قال الشيخ: التَمَسْتُها، فوجدتُ في البقرة [٢٥٥] آيةَ الكرسي: <q>﴿الله لا إله إلا هو الحي القيوم﴾</q>، وفاتحة آل عمران: <q>﴿الم الله لا إله إلا هو الحي القيوم﴾</q>، وفي طه [١١١]: <q>﴿وعنت الوجوه للحي القيوم﴾</q>{24}. (ز) ",footnotes:1:عزاه السيوطي إلى ابن الأنباري في المصاحف.أخرجه أبو عبيد ص١٦٨، وسعيد بن منصور في سننه (٤٨٩- تفسير)، والطبراني (٨٦٩٠). وهي قراءة شاذة، تنسب إلى عمر بن الخطاب، وعثمان بن عفان، وابن مسعود، والنخعي، والأعمش، وغيرهم. ينظر: المحتسب ٢/١٥١.أخرجه ابن أبي داود ص٥٩.أخرجه ابن جرير ٥/١٧٥-١٧٦. وعزاه السيوطي إلى ابن الأنباري.أخرجه ابن جرير ٥/١٧٥. وهي قراءة شاذة. ينظر: المحتسب ٢/١٥١.عزاه السيوطي إلى ابن الأنباري. وأخرجه ابن جرير ٥/١٧٥ دون قوله: كان أصحاب عبد الله يقرؤون: (الحَيُّ القَيّامُ). وفي أوله: عن إبراهيم، عن أبي معمر، قال: سمعت علقمة يقرأ: (الحَيُّ القَيِّمُ). قلت: أنت سمعته؟ قال: لا أدري.أخرجه عبد بن حميد كما في قطعة من تفسيره ص١٩.تقدّم تفسير <q>﴿الـم﴾</q> في سورة البقرة.سيرة ابن هشام ١/٥٧٣، وأخرجه ابن جرير ٥/١٧١-١٧٤، وابن المنذر (١٩٩).أخرجه ابن أبي حاتم ٢/٥٨٦.أخرجه ابن أبي حاتم ٢/٥٨٦.أخرجه ابن جرير ٥/١٧٦.تفسير مقاتل بن سليمان ١/٢٦٢.أخرجه ابن جرير ٥/١٧٨، وابن المنذر ١/١١٣ من طريق ابن جُرَيْج. وعزاه السيوطي إلى عَبد بن حُمَيد.أخرجه ابن أبي حاتم ٢/٥٨٦.علقه يحيى بن سلام ١/٢٨١، وينظر: تفسير ابن أبي زمنين ١/٢٧٤.علقه يحيى بن سلام ١/٢٨١.أخرجه ابن أبي حاتم ٢/٩٢، ٥٨٦.أخرجه ابن جرير ٥/١٧٨.أخرجه ابن إسحاق -كما في سيرة ابن هشام ١/٥٧٣-، وابن جرير ٥/١٧٨، وابن المنذر (١٩٩).تفسير مقاتل بن سليمان ١/٢٦٢.أخرجه ابن أبي حاتم ٢/٥٨٦.أخرجه أحمد ٤٥/٥٨٤ (٢٧٦١١)، وأبو داود ٢/٦١٣ (١٤٩٦)، والترمذي ٦/٨٨ (٣٧٨٢)، وابن ماجه ٥/٢٤ (٣٨٥٥)، وابن أبي حاتم ١/٢٧٢ (١٤٦٠)، ٢/٥٨٣ (٣١١٥). قال الترمذي: «هذا حديث حسن صحيح». وقال الألباني في صحيح سنن أبي داود ٥/٢٣٤ (١٣٤٣): «حديث حسن، وصحَّحه الترمذي».أخرجه الفريابي في فضائل القرآن ص١٥٨ (٤٨).
3,3," <q>﴿نَزَّلَ عَلَیۡكَ ٱلۡكِتَـٰبَ بِٱلۡحَقِّ﴾</q> - تفسير ١١٨٥٥- عن قتادة بن دِعامة -من طريق سعيد- في قوله: <q>﴿نزّل عليك الكتاب﴾</q>، قال: القرآن{1}. (٣/٤٤٤-٤٤٥) ١١٨٥٦- عن محمد بن جعفر بن الزبير -من طريق ابن إسحاق- <q>﴿نزّل عليك الكتاب بالحق﴾</q>، أي: بالصدق فيما اختَلَفوا فيه{2}١٠٩٤. (ز) ١٠٩٤ ذكر ابنُ عطية (٢/١٥٠) أنّ قوله <q>﴿بِالحَقِّ﴾</q> يحتمل معنيين: إحداهما: أن يكون المعنى: ضَمَّنه الحقائقَ مِن خبره وأمره ونهيه ومواعظه. والثاني: أن يكون المعنى: أنّه نَزَّل الكتابَ باستحقاق أن ينزل لِما فيه مِن المصلحة الشاملة، وليس ذلك على أنّه واجبٌ على الله تعالى أن يفعله. ثم أفاد دخول هذا القولِ في المعنى الأول. ١١٨٥٧- عن محمد بن إسحاق -من طريق ابن إدريس- قوله: <q>﴿نزل عليك الكتاب بالحق﴾</q>، يقول: بالفصل في الذي ادَّعَوْا مِن الباطل{3}. (ز) ١١٨٥٨- عن محمد بن إسحاق -من طريق سلمة- قوله: <q>﴿نزّل عليك الكتاب بالحقّ﴾</q>، أي: بالصِّدْق فيما اختلفوا فيه{4}. (ز) ١١٨٥٩- قال مقاتل بن سليمان: <q>﴿نزل عليك الكتاب﴾</q> يا محمد <q>﴿بالحق﴾</q>، لم يُنزله باطلًا. يعني: القرآن{5}١٠٩٥. (ز) ١٠٩٥ ذكر ابنُ عطية (٢/١٥٠) أن <q>﴿الكتاب﴾</q> في هذا الموضع هو القرآن باتفاق من المفسرين. <q>﴿مُصَدِّقࣰا لِّمَا بَیۡنَ یَدَیۡهِ﴾</q> - تفسير ١١٨٦٠- عن مجاهد بن جبر -من طريق ابن أبي نَجِيح- في قوله: <q>﴿نزل عليك الكتاب بالحق مصدّقًا لما بين يديه﴾</q>، قال: لِما قبلَه مِن كتاب، أو رسول{6}. (٣/٤٤٤) ١١٨٦١- عن الحسن البصري -من طريق عَبّاد بن منصور- <q>﴿مصدقا لما بين يديه﴾</q>، يقول: مِن البيِّنات التي أُنزِلت على نوح، وإبراهيم، وهود، والأنبياء، وأُنزِل على داود الزبور{3}. (٣/٤٤٤) ١١٨٦٢- عن قتادة بن دِعامة -من طريق سعيد- في قوله: <q>﴿مصدقًا لما بين يديه﴾</q>، يقول: مِن الكتب التي قد خَلَتْ قبلَه{8}. (٣/٤٤٤-٤٤٥) ١١٨٦٣- عن الربيع بن أنس -من طريق أبي جعفر- قوله: <q>﴿نزل عليك الكتاب بالحق مصدقا لما بين يديه﴾</q>، يقول: مُصَدِّقًا لِما قبلَه مِن كتاب، ورسول{9}١٠٩٦. (ز) ١٠٩٦ لم يذكر ابنُ جرير (٥/١٨٠) غيرَ هذا القول وما في معناه. ١١٨٦٤- قال مقاتل بن سليمان: <q>﴿مصدّقا لما بين يديه﴾</q> مِن الكتاب. يقول: محمدٌ ﵇ مُصَدِّقٌ للكتب التي كانت قبلَه{5}. (ز) ١١٨٦٥- عن عبد الملك بن جُرَيْج، في قوله: <q>﴿مصدقا لما بين يديه﴾</q>، قال: التوراة، والإنجيل{11}. (ز) <q>﴿وَأَنزَلَ ٱلتَّوۡرَىٰةَ وَٱلۡإِنجِیلَ ۝٣﴾</q> - تفسير ١١٨٦٦- عن محمد بن جعفر بن الزبير -من طريق ابن إسحاق-: <q>﴿وأنزل التوراة والإنجيل﴾</q>، التوراة على موسى، والإنجيل على عيسى، كما أنزل الكتب على مَن كان قبله{12}. (ز) ١١٨٦٧- قال مقاتل بن سليمان: <q>﴿وأنزل التوراة﴾</q> على موسى، <q>﴿والإنجيل﴾</q> على عيسى{5}. (ز) <q>﴿وَأَنزَلَ ٱلتَّوۡرَىٰةَ وَٱلۡإِنجِیلَ ۝٣﴾</q> - آثار متعلقة بالآية ١١٨٦٨- عن واثِلَة بن الأَسْقَع، أنّ النبي ﷺ قال: «وأُنزِلت التوراةُ لِسِتٍّ مَضَيْنَ مِن رمضان، وأُنزِل الإنجيل لثلاث عشرة خَلَتْ مِن رمضان»{14}. (ز) ",footnotes:1:أخرجه ابن جرير ٥/١٨١-١٨٣، وابن أبي حاتم ٢/٥٨٧. وعزاه السيوطي إلى عَبد بن حُمَيد.أخرجه ابن جرير ٥/١٨٠-١٨١.أخرجه ابن أبي حاتم ٢/٥٨٧.أخرجه ابن أبي حاتم ٢/٥٨٧، وابن المنذر ١/١١٤ من طريق إبراهيم بن سعد.تفسير مقاتل بن سليمان ١/٢٦٢.أخرجه ابن جرير ٥/١٨٠، وابن أبي حاتم ٢/٥٨٧. وعزاه السيوطي إلى الفريابي، وعبد بن حميد.أخرجه ابن أبي حاتم ٢/٥٨٧.أخرجه ابن جرير ٥/١٨١-١٨٣. وعزاه السيوطي إلى عَبد بن حُمَيد.أخرجه ابن جرير ٥/١٨١. وعلَّقه ابنُ أبي حاتم ٢/٥٨٧.تفسير مقاتل بن سليمان ١/٢٦٢.علَّقه ابن المنذر ١/١١٤.أخرجه ابن جرير ٥/١٨١-١٨٣.تفسير مقاتل بن سليمان ١/٢٦٢.أخرجه أحمد ٢٨/١٩١ (١٦٩٨٤)، وابن جرير ٣/١٨٩، وابن أبي حاتم ١/٣١٠ (١٦٤٩)، ٢/٥٨٧ (٣١٣٧)، ٥/١٥٨٢ (٨٣٣٧)، ٨/٢٥١٦ (١٤٠٨٠). قال الهيثميُّ في المجمع ١/١٩٧ (٩٥٩): «رواه أحمد، والطبراني في الكبير والأوسط، وفيه عمران بن داوَر القَطّان، ضعّفه يحيى، ووثّقه ابن حبان، وقال أحمد: أرجو أن يكون صالح الحديث. وبقية رجاله ثقات». وقال الألباني في الصحيحة ٤/١٠٤ (١٥٧٥): «إسناده حَسَن».
3,4," <q>﴿مِن قَبۡلُ هُدࣰى لِّلنَّاسِ﴾</q> - تفسير ١١٨٦٩- عن عامر الشعبي -من طريق بيان- في قوله: <q>﴿هدى للناس﴾</q>، قال: هُدًى مِن الضلالة{1}. (ز) ١١٨٧٠- عن قتادة بن دِعامة -من طريق سعيد-: <q>﴿وأنزل التوراة والإنجيل من قبل هدى للناس﴾</q>، هُما كتابان أنزلهما اللهُ، فيهما بيانٌ مِن الله، وعِصْمَةٌ لِمَن أخذ به، وصَدَّق به، وعَمِل بما فيه{2}. (٣/٤٤٤-٤٤٥) ١١٨٧١- قال إسماعيل السُّدِّيّ: في الآية تقديم وتأخير، تقديرها: وأنزل التوراةَ والإنجيلَ والفرقانَ هُدًى للناس{3}. (ز) ١١٨٧٢- قال مقاتل بن سليمان: <q>﴿من قبل﴾</q> هذا القرآن، ثم قال: <q>﴿التوراة والإنجيل﴾</q> هما <q>﴿هدى للناس﴾</q>{4}. (ز) ١١٨٧٣- عن عبد الملك بن جُرَيْج -من طريق محمد بن ثور-: <q>﴿وأنزل التوراة والإنجيل﴾</q>، أُنزِلت التوراة والإنجيل قبلَ القرآن{5}. (ز) <q>﴿وَأَنزَلَ ٱلۡفُرۡقَانَۗ﴾</q> - تفسير ١١٨٧٤- عن الحسن البصري -من طريق عبّاد بن منصور- في قوله: <q>﴿وأنزل الفرقان﴾</q>، قال: هو كتابٌ بِحَقٍّ{6}. (ز) ١١٨٧٥- عن أبي صالح باذام -من طريق إسماعيل بن أبي خالد- في قوله: <q>﴿الفرقان﴾</q>، قال: التوراة{7}١٠٩٧. (ز) ١٠٩٧ انتَقَدَ ابنُ كثير (٣/٦) قولَ أبي صالح مستندًا إلى دلالة عقلية، فقال: «وأمّا ما رواه ابنُ أبي حاتم عن أبي صالح أنّ المراد هاهنا بالفرقان: التوراة. فضعيف؛ لِتَقَدُّمِ ذِكْرِها». ١١٨٧٦- عن قتادة بن دِعامة -من طريق سعيد- قوله: <q>﴿وأنزل الفرقان﴾</q>، قال: هو القرآن، فرَّق به بين الحق والباطل، فأحَلَّ فيه حلالَه، وحَرَّم فيه حرامَه، وشرع فيه شرائعه، وحَدَّ فيه حدوده، وفرض فيه فرائضه، وبَيَّنَ فيه بيانه، وأمر بطاعته، ونهى عن معصيته{8}. (٣/٤٤٤-٤٤٥) ١١٨٧٧- عن محمد بن جعفر بن الزبير -من طريق ابن إسحاق- <q>﴿وأنزل الفرقان﴾</q>: أي: الفَصْلَ بين الحق والباطل فيما اخْتَلَف فيه الأحزابُ مِن أمرِ عيسى وغيرِه{9}. (٣/٤٤٥) ١١٨٧٨- عن الربيع بن أنس -من طريق أبي جعفر- <q>﴿وأنزل الفرقان﴾</q>، قال: الفرقان: القرآن، فَرَّق بين الحقِّ والباطل{10}١٠٩٨. (ز) ١٠٩٨ عَلَّق ابنُ تيمية (٢/١٤-١٥)، فقال: «قال قتادةُ والربيعُ: هو القرآن، فرَّق فيه بين الحلال والحرام، والحق والباطل. وهذا لأنّ الشيء الواحد إذا كان له وصفان كبيران فهو مع وصف كالشيء الواحد، وهو مع الوصفين بمنزلة الاثنين، حتى لو كثرت صفاته لتنزل منزلة أشخاص، ألا ترى أنّ الرجل الذي يحسن الحساب والطب بمنزلة حاسب وطبيب». ١١٨٧٩- وعن عطاء= (ز) ١١٨٨٠- ومجاهد بن جبر= (ز) ١١٨٨١- ومِقْسَم= (ز) ١١٨٨٢- ومقاتل بن حيان، نحو ذلك{11}. (ز) ١١٨٨٣- عن محمد بن إسحاق -من طريق إبراهيم بن سعد- <q>﴿وأنزل الفرقان﴾</q>: أي: الفصلَ بين الحق والباطل فيما اختَلَفَ فيه الأحزاب مِن أمر عيسى وغيرِه{12}١٠٩٩. (ز) ١٠٩٩ اختلف المفسرون في المراد بالفرقان؛ فذهب قوم إلى أنّه مصدر، والمراد: الفصل بين الحق والباطل في أمر عيسى. وذهب قومٌ إلى أنّه القرآن، والمراد: الفصل بين الحق والباطل في أحكام الشرائع. ورَجَّح ابنُ جرير (٥/١٨٣-١٨٤) القولَ الأول الذي قاله ابنُ الزبير وابنُ إسحاق مُسْتَنِدًا إلى دلالة القرآن، والسياق؛ لتقدّم ذِكْرِ القرآن في قوله: <q>﴿نزل عليك الكتاب بالحق مصدقا﴾</q>، ولا شكَّ أنّ ذلك الكتاب هو القرآن لا غيره، فلا وجه لتكريره مرّة أخرى؛ إذ لا فائدة في تكريره، ولأنّ الله عَقَّب قولَه: <q>﴿وأنزل الفرقان﴾</q> بقوله: <q>﴿إن الذين كفروا بآيات الله﴾</q>، وهذا وعيدٌ صريحٌ لِمَن جَحَدَ الفَصْلَ الذي أنزله الله فرقانًا بين الحق والباطل وعانده. وكذا رجَّح ابنُ كثير (٣/٦) هذا القول. ووجَّه ابنُ عطية (٢/١٥٤) تفسيرَ الفرقان بالقرآن لكونه يُفَرِّق بين الحق والباطل، ثُمَّ جَمَع بين القولين، فقال: «والفرقانُ يَعُمُّ هذا كلَّه». وذكر أنّ بعض المفسرين قال بأنّ الفرقان هنا كل أمر فرق بين الحق والباطل، فيما قدم وحدث، وعلَّق عليه، بقوله: «فيدخل في هذا التأويل طوفان نوح، وفرق البحر لغرق فرعون، ويوم بدر، وسائر أفعال الله تعالى المفرقة بين الحق والباطل، فكأنه تعالى ذكر الكتاب العزيز، ثم التوراة والإنجيل، ثم كل أفعاله ومخلوقاته التي فرقت بين الحق والباطل، كما فعلت هذه الكتب، ثم توعد تعالى الكفار عمومًا بالعذاب الشديد، وذلك يعم عذاب الدنيا بالسيف والغلبة، وعذاب الآخرة بالنار». ثم بيَّن أنّ الإشارة بهذا الوعيد إلى نصارى نجران، وذكر أنّ النقّاش قال بأنّه إلى اليهود؛ كعب بن الأشرف، وكعب بن أسد، وبني أخطب وغيرهم. ١١٨٨٤- قال مقاتل بن سليمان: يعني: قال سبحانه: <q>﴿وأنزل الفرقان﴾</q>، يعني: القرآن بعد التوراة والإنجيل، والفرقان يعني به: المُخْرِج في الدِّين من الشُّبْهَةِ والضلالة، فيه بيان كُلِّ شيء يكون إلى يوم القيامة. نظيرُها في الأنبياء [٤٨]: <q>﴿ولقد آتينا موسى وهارون الفرقان﴾</q>، يعني: المخرج من الشبهات، وفي البقرة [١٨٥]: <q>﴿وبينات من الهدى والفرقان﴾</q>{13}. (ز) <q>﴿إِنَّ ٱلَّذِینَ كَفَرُوا۟ بِـَٔایَـٰتِ ٱللَّهِ لَهُمۡ عَذَابࣱ شَدِیدࣱۗ﴾</q> - تفسير ١١٨٨٥- عن قتادة بن دِعامة -من طريق سعيد- قوله: <q>﴿عذاب﴾</q>، أي: عقوبة الآخرة{6}. (ز) ١١٨٨٦- عن إسماعيل السُّدِّيِّ -من طريق أسباط- قوله: <q>﴿بآيات الله﴾</q>: بمحمد ﷺ{6}. (ز) ١١٨٨٧- عن الربيع بن أنس -من طريق أبي جعفر- في قوله: <q>﴿إن الذين كفروا بآيات الله لهم عذاب شديد﴾</q>، يعني: النصارى{6}. (ز) ١١٨٨٨- قال مقاتل بن سليمان: ثُمَّ قال سبحانه: <q>﴿إن الذين كفروا بآيات الله﴾</q>، يعني: القرآن، وهم اليهود، كفروا بالقرآن، منهم: حُيَيّ، وجُدَيّ، وأبو ياسر بنو أخْطَب، وكعب بن الأشرف، وكعب بن أُسَيْد، وزيد بن التابوه، وغيرهم، <q>﴿لهم عذاب﴾</q> في الآخرة <q>﴿شديد﴾</q>{13}. (ز) <q>﴿وَٱللَّهُ عَزِیزࣱ ذُو ٱنتِقَامٍ ۝٤﴾</q> - تفسير ١١٨٨٩- عن محمد بن جعفر بن الزبير -من طريق ابن إسحاق- <q>﴿إن الذين كفروا بآيات الله لهم عذاب شديد والله عزيز ذو انتقام﴾</q>، أي: أنّ الله مُنتَقِمٌ مِمَّن كَفَر بآياته، بعد علمه بها ومعرفته بما جاء منه فيها{18}١١٠٠. (٣/٤٤٥) ١١٠٠ لم يذكر ابنُ جرير (٥/١٨٤) غير هذا القول. ١١٨٩٠- قال مقاتل بن سليمان: <q>﴿الله عزيز ذو انتقام﴾</q>، يعني: عزيز في ملكه، منيع شديد الانتقام من أهل مكة، هذا وعيد لِمَن خالف أمره{13}. (ز) ١١٨٩١- عن محمد بن إسحاق -من طريق إبراهيم بن سعد- <q>﴿والله عزيز ذو انتقام﴾</q>: إنّ الله مُنتَقِم مِمَّن كفر بآياته بعد علمه بها، ومعرفته بما جاء منه فيها{20}. (ز) ١١٨٩٢- عن محمد بن إسحاق -من طريق ابن إدريس- قوله: <q>﴿والله عزيز ذو انتقام﴾</q>: عزيزٌ ذو بَطْشٍ مِمَّن أراد{6}. (ز) ",footnotes:1:أخرجه ابن أبي حاتم ٢/٥٨٨.أخرجه ابن جرير ٥/١٨١-١٨٣، وابن أبي حاتم ٢/٥٨٨ من طريق شيبان. وعزاه السيوطي إلى عَبد بن حُمَيد.تفسير البغوي ٢/٦، وتفسير الثعلبي ٣/٩.تفسير مقاتل بن سليمان ١/٢٦٢.أخرجه ابن المنذر ١/١١٥.أخرجه ابن أبي حاتم ٢/٥٨٩.أخرجه ابن المنذر ١/١١٦.أخرجه ابن جرير ٥/١٨٣، وابن أبي حاتم ٢/٥٨٨-٥٨٩ من طريق شيبان. وعزاه السيوطي إلى عَبد بن حُمَيد.أخرجه ابن جرير ٥/١٨٢.أخرجه ابن جرير ٥/١٨٣.علَّقه ابن أبي حاتم ٢/٥٨٨.أخرجه ابن المنذر ١/١١٥-١١٦.تفسير مقاتل بن سليمان ١/٢٦٣.أخرجه ابن أبي حاتم ٢/٥٨٩.أخرجه ابن أبي حاتم ٢/٥٨٩.أخرجه ابن أبي حاتم ٢/٥٨٩.تفسير مقاتل بن سليمان ١/٢٦٣.أخرجه ابن جرير ٥/١٨٤-١٨٥.تفسير مقاتل بن سليمان ١/٢٦٣.أخرجه ابن المنذر ١/١٢٤، وابن أبي حاتم ٢/٥٨٩ من طريق سلمة.أخرجه ابن أبي حاتم ٢/٥٨٩.
3,5," <q>﴿إِنَّ ٱللَّهَ لَا یَخۡفَىٰ عَلَیۡهِ شَیۡءࣱ فِی ٱلۡأَرۡضِ وَلَا فِی ٱلسَّمَاۤءِ ۝٥﴾</q> - تفسير ١١٨٩٣- عن محمد بن جعفر بن الزبير -من طريق ابن إسحاق- <q>﴿إن الله لا يخفى عليه شيء في الأرض ولا في السماء﴾</q>: أي: قد علم ما يُرِيدون، وما يَكِيدون، وما يُضاهون بقولهم في عيسى، إذ جعلوه ربًّا وإلهًا، وعندهم من عِلْمِه غير ذلك؛ غِرَّةً بالله، وكفرًا به{1}. (٣/٤٤٥) ١١٨٩٤- قال مقاتل بن سليمان: <q>﴿إن الله لا يخفى عليه شيء في الأرض ولا في السماء﴾</q>، يعني: شيء من أهل السماء، ولا من أهل الأرض، كُلُّ ذلك عنده{2}. (ز) ١١٨٩٥- عن محمد بن إسحاق -من طريق عبد الله بن إدريس- قوله: <q>﴿إن الله لا يخفى عليه شيء في الأرض ولا في السماء﴾</q>: لا يخفى عليه في الأرض ولا في السماء مِمّا جاءوا يريدون، ويَكِيدُون{3}. (ز) ١١٨٩٦- عن محمد بن إسحاق -من طريق إبراهيم بن سعد- <q>﴿إن الله لا يخفى عليه شيء في الأرض ولا في السماء﴾</q>: أي: قد علم ما يُريدون، وما يَكيدون، وما يُضاهِئُون بقولهم في عيسى، إذ جعلوه ربًّا وإلهًا، وعندهم من عِلْمِه غير ذلك؛ غِرَّةً بالله، وكفرًا به{4}. (ز) ",footnotes:1:أخرجه ابن جرير ٥/١٨٢-١٨٦.تفسير مقاتل بن سليمان ١/٢٦٣.أخرجه ابن أبي حاتم ٢/٥٩٠.أخرجه ابن المنذر ١/١٢٤-١٢٥، وابن أبي حاتم ٢/٥٩٠ من طريق سلمة.
3,6," <q>﴿هُوَ ٱلَّذِی یُصَوِّرُكُمۡ فِی ٱلۡأَرۡحَامِ كَیۡفَ یَشَاۤءُۚ﴾</q> - نزول الآية ١١٨٩٧- قال مقاتل بن سليمان: <q>﴿هو الذي يصوّركم في الأرحام كيف يشاء﴾</q> نزلت في عيسى ابن مريم ﷺ، خلقه من غير أب، ذكرًا وأنثى، سويًّا وغير سويٍّ، <q>﴿لا إله إلا هو العزيز﴾</q> في ملكه، <q>﴿الحكيم﴾</q> في أمره. نزلت هذه الآية في قولهم، وما قالوا من البهتان والزور لعيسى ﷺ{1}. (ز) <q>﴿هُوَ ٱلَّذِی یُصَوِّرُكُمۡ فِی ٱلۡأَرۡحَامِ كَیۡفَ یَشَاۤءُۚ﴾</q> - تفسير الآية ١١٨٩٨- عن عبد الله بن مسعود، في قوله: <q>﴿يصوركم في الأرحام كيف يشاء﴾</q>، قال: ذكورًا، وإناثًا{2}. (٣/٤٤٥) ١١٨٩٩- عن عبد الله بن مسعود -من طريق أيّوب بن عبد الله الفهري- قال: <q>﴿هو الذي يصوّركم في الأرحام كيف يشاء﴾</q>، قال: يُؤتى بما في الأرحام، فينظر فيها ثلاث ساعات{3}. (ز) ١١٩٠٠- عن عبد الله بن مسعود وناس من أصحاب النبي ﷺ -من طريق السدي، عن مرة الهمداني-= (ز) ١١٩٠١- وعبد الله بن عباس -من طريق السدي، عن أبي مالك وأبي صالح- في قوله: <q>﴿هو الذي يصوّركم في الأرحام كيف يشاء﴾</q>، قال: إذا وقعت النطفة في الأرحام طارت في الجسد أربعين يومًا، ثم تكون علقة أربعين يومًا، ثم تكون مضغة أربعين يومًا، فإذا بلغ أن يُخْلق بعث الله مَلَكًا يُصَوِّرها، فيأتي الملَك بتراب بين أصبعيه، فيخلط فيه المضغة، ثم يعجنه بها، ثم يُصَوِّره كما يؤمر، ثم يقول: أذَكَرٌ أم أنثى؟ أشقيٌّ أم سعيد؟ وما رِزقه؟ وما عمره؟ وما أثره؟ وما مصائبه؟ فيقول الله، ويكتب الملَك، فإذا مات ذلك الجسدُ دُفِن حيث أُخِذ ذلك التراب{4}. (٣/٤٤٦) ١١٩٠٢- عن قتادة بن دِعامة -من طريق سعيد- <q>﴿هو الذي يصوّركم في الأرحام كيف يشاء﴾</q>، قال: قادِرٌ -واللهِ- ربُّنا أن يُصَوِّر عباده في الأرحام كيف يشاء؛ من ذكر أو أنثى، أو أسود أو أحمر، تامٍّ خَلْقُه وغيرِ تامٍّ{5}. (٣/٤٤٦) ١١٩٠٣- عن إسماعيل السُّدِّيِّ -من طريق أسباط- في قوله: <q>﴿هو الذي يصوّركم في الأرحام كيف يشاء﴾</q>، قال: إذا وقعت النُّطْفَةُ في الرَّحِم طارت في الجسد أربعين يومًا، ثم تكون علقة أربعين يومًا، ثم تكون مضغة أربعين يومًا، فإذا بلغ أن يُخْلَق بعث الله ملَكًا يُصَوِّرُها، فيأتي الملَك بتراب بين أصبعيه، فيخلط فيه المضغة، ثم يعجنه بها، ثم يصوره كما يؤمر، ثم يقول: أذَكرٌ أم أنثى؟ أشقيٌّ أم سعيد؟ وما رِزقه؟ وما عمره؟ وما أثره؟ وما مصائبه؟ فيقول الله، ويكتب الملَك، فإذا مات ذلك الجسدُ دُفِن حيث أُخِذ ذلك التراب{3}. (ز) ١١٩٠٤- عن الربيع بن أنس -من طريق أبي جعفر- <q>﴿هو الذي يصوّركم في الأرحام كيف يشاء﴾</q>: أي: أنه صوَّر عيسى في الرَّحِم كيف شاء{7}. (ز) ١١٩٠٥- عن محمد بن جعفر بن الزبير -من طريق ابن إسحاق- <q>﴿هو الذي يصوّركم في الأرحام كيف يشاء﴾</q>: قد كان عيسى مِمَّن صُوِّر في الأرحام، لا يدفعون ذلك ولا يُنكِرُونه، كما صُوِّر غيرُه من بني آدم، فكيف يكون إلهًا وقد كان بذلك المَنزِل؟!{8}. (٣/٤٤٥) ١١٩٠٦- عن محمد بن إسحاق -من طريق إبراهيم بن سعد-، مثله{9}. (ز) <q>﴿لَاۤ إِلَـٰهَ إِلَّا هُوَ ٱلۡعَزِیزُ ٱلۡحَكِیمُ ۝٦﴾</q> - تفسير ١١٩٠٧- عن أبي العالية الرِّياحِيِّ -من طريق الربيع- في قوله: <q>﴿العزيز الحكيم﴾</q>، قال: العزيزُ في نِقمته إذا انتقم، الحكيمُ في أمره{10}. (٣/٤٤٦) ١١٩٠٨- عن محمد بن جعفر بن الزبير -من طريق ابن إسحاق- قال: ثُمَّ قال -يعني: الرَّبَّ ﷿ إنزاهًا لنفسه، وتوحيدًا لها مِمّا جعلوا معه: <q>﴿لا إله إلا هو العزيز الحكيم﴾</q>، قال: العزيزُ في نُصْرَتِه مِمَّن كَفَر به إذا شاء، والحكيم في عُذْرِه وحُجَّته إلى عباده{11}١١٠١. (ز) ١١٠١ لم يذكر ابنُ جرير (٥/١٨٤) غير هذا القول وما في معناه. ١١٩٠٩- عن محمد بن إسحاق -من طريق إبراهيم بن سعد-، مثله{12}. (ز) ١١٩١٠- عن الربيع بن أنس -من طريق أبي جعفر- <q>﴿لا إله إلا هو العزيز الحكيم﴾</q>، يقول: عزيز في نِقْمَتِه، حكيم في أمره{11}. (ز) ١١٩١١- قال مقاتل بن سليمان: <q>﴿العزيز﴾</q> في ملكه، <q>﴿الحكيم﴾</q> في أمره{1}. (ز) ",footnotes:1:تفسير مقاتل بن سليمان ١/٢٦٣.أخرجه ابن المنذر (٢١٥).أخرجه ابن أبي حاتم ٢/٥٩٠.أخرجه ابن جرير ٥/١٨٦-١٨٧.أخرجه ابن جرير ٥/١٨٧، وابن أبي حاتم ٢/٥٩٠-٥٩١ من طريق شيبان. وعزاه السيوطي إلى عَبد بن حُمَيد.أخرجه ابن أبي حاتم ٢/٥٩٠.أخرجه ابن جرير ٥/١٨٦.أخرجه ابن جرير ٥/١٨٢، ١٨٦.أخرجه ابن المنذر ١/١٢٥.أخرجه ابن أبي حاتم ٢/٥١٩.أخرجه ابن جرير ٥/١٨٨.أخرجه ابن المنذر ١/١٢٥، وابن أبي حاتم ٢/٥٩١ مختصرًا.أخرجه ابن جرير ٥/١٨٨.تفسير مقاتل بن سليمان ١/٢٦٣.
3,7," <q>﴿هُوَ ٱلَّذِیۤ أَنزَلَ عَلَیۡكَ ٱلۡكِتَـٰبَ مِنۡهُ ءَایَـٰتࣱ مُّحۡكَمَـٰتٌ هُنَّ أُمُّ ٱلۡكِتَـٰبِ وَأُخَرُ مُتَشَـٰبِهَـٰتࣱۖ فَأَمَّا ٱلَّذِینَ فِی قُلُوبِهِمۡ زَیۡغࣱ فَیَتَّبِعُونَ مَا تَشَـٰبَهَ مِنۡهُ ٱبۡتِغَاۤءَ ٱلۡفِتۡنَةِ وَٱبۡتِغَاۤءَ تَأۡوِیلِهِۦۖ وَمَا یَعۡلَمُ تَأۡوِیلَهُۥۤ إِلَّا ٱللَّهُۗ وَٱلرَّ ٰ⁠سِخُونَ فِی ٱلۡعِلۡمِ یَقُولُونَ ءَامَنَّا بِهِۦ كُلࣱّ مِّنۡ عِندِ رَبِّنَاۗ وَمَا یَذَّكَّرُ إِلَّاۤ أُو۟لُوا۟ ٱلۡأَلۡبَـٰبِ ۝٧﴾</q> - نزول الآية ١١٩١٢- عن عبد الله بن عباس، عن جابر بن عبد الله بن رئاب -من طريق ابن إسحاق، عن الكلبي، عن أبي صالح- قال: مَرَّ أبو ياسر بن أخْطَب، فجاء رجلٌ من يهود لرسول الله ﷺ، وهو يتلو فاتحة سورة البقرة: <q>﴿الم ذلك الكتاب لا ريب فيه﴾</q>. فأتى أخاه حُيَيَّ بن أخْطَبَ في رِجالٍ من اليهود، فقال: أتعلمون، واللهِ، لقد سمعتُ محمدًا يتلو فيما أنزل عليه: <q>﴿الم ذلك الكتاب﴾</q>. فقال: أنت سمعتَه؟ قال: نعم. فمشى حتى وافى أولئك النفر إلى رسول الله ﷺ، فقالوا: ألم تقل: إنّك تتلو فيما أُنزل عليك: <q>﴿الم ذلك الكتاب﴾</q>؟ فقال: «بلى». فقالوا: لقد بُعث بذلك أنبياء، ما نعلمُه بُيِّن لنبيٍّ منهم ما مُدَّةُ مُلْكِه وما أجَلُ{1} أُمَّتِهِ غيرَك! الألف واحدة، واللام ثلاثون، والميم أربعون، فهذه إحدى وسبعون سنة. ثم قال: يا محمد، هل مع هذا غيره؟ قال: «نعم، <q>﴿المص﴾</q>». قال: هذه أثقلُ وأطولُ، الألف واحدة، واللام ثلاثون، والميم أربعون، والصاد تسعون، فهذه إحدى وثلاثون ومائة، هل مع هذا غيره؟ قال: «نعم، <q>﴿الر﴾</q>». قال: هذه أثقل وأطول، الألف واحدة، واللام ثلاثون، والراء مائتان، هذه إحدى وثلاثون ومائتا سنة، هل مع هذا غيره؟ قال: «نعم، <q>﴿المر﴾</q>». قال: هذه أثقل وأطول، هذه إحدى وسبعون ومائتان. ثُمَّ قال: لقد لُبِّس علينا أمرُك حتى ما ندري أقليلًا أُعطيتَ أم كثيرًا؟! ثم قال: قوموا عنه. ثم قال أبو ياسر لأخيه ومَن معه: ما يدريكم، لعلَّه قد جُمِع هذا كله لمحمد؟! إحدى وسبعون، وإحدى وثلاثون ومائة، وإحدى وثلاثون ومائتان، وإحدى وسبعون ومائتان، فذلك سبعمائة وأربع سنين. فقالوا: لقد تشابه علينا أمرُه. فيزعمون: أنّ هذه الآيات نزلت فيهم: <q>﴿هو الذي أنزل عليك الكتاب منه آيات محكمات هن أم الكتاب وأخر متشابهات﴾</q>{2}. (٣/٤٥٠-٤٥٢) ١١٩١٣- عن عبد الله بن عباس، وجابر بن رئاب -من طريق سعيد بن جبير-: أنّ أبا ياسر بن أخْطَب مَرَّ بالنبي ﷺ وهو يقرأ فاتحة الكتاب، و<q>﴿الم ذلك الكتاب﴾</q>. فذكر القصّة{3}. (٣/٤٥٢) ١١٩١٤- وعن عبد الملك ابن جُرَيْج -من طريق محمد بن ثور- نحوه{4}. (٣/٤٥٢) ١١٩١٥- عن الربيع: أنّ النصارى قالوا لرسول الله ﷺ: ألستَ تزعم أنّ عيسى كلمة الله وروح منه؟ قال: «بلى». قالوا: فحسبُنا. فأنزل الله: <q>﴿فأما الذين في قلوبهم زيغ فيتبعون ما تشابه منه ابتغاء الفتنة﴾</q>{5}. (٣/٤٥٨) <q>﴿هُوَ ٱلَّذِیۤ أَنزَلَ عَلَیۡكَ ٱلۡكِتَـٰبَ﴾</q> - تفسير ١١٩١٦- عن عبد الله بن مسعود، قال: إنّ القرآن أُنزِل على نبيِّكم ﷺ من سبعة أبواب، على سبعة أحرف، وإنّ الكتاب قبلكم كان ينزل من باب واحد، على حرف واحد{6}. (٣/٤٥٧) ١١٩١٧- عن سعيد بن جبير -من طريق عطاء بن دينار- في قول الله: <q>﴿هو الذي أنزل عليك الكتاب﴾</q>، يعني: القرآن{7}١١٠٢. (ز) ١١٠٢ نَقَل ابنُ عَطِيَّة (٢/١٥٥) الإجماعَ على أنّ المراد بـ<q>﴿الكتاب﴾</q>: القرآن، فقال: «و<q>﴿الكتاب﴾</q> في هذه الآية: القرآن، بإجماعٍ من المتأولين». <q>﴿مِنۡهُ ءَایَـٰتࣱ مُّحۡكَمَـٰتٌ﴾</q> - تفسير ١١٩١٨- عن عبد الله بن عباس -من طريق عبد الله بن قيس- أنّه قال: في قوله: <q>﴿منه آيات محكمات﴾</q>، قال: الثلاث آيات من آخر سورة الأنعام محكمات؛ <q>﴿قل تعالوا﴾</q> والآيتان بعدها [الأنعام:١٥١-١٥٣]{8}. (٣/٤٤٧) ١١٩١٩- عن عبد الله بن عباس -من طريق العَوّام، عمَّن حَدَّثه- في قوله: <q>﴿آيات محكمات﴾</q>، قال: مِن ههنا: <q>﴿قل تعالوا﴾</q> إلى آخر ثلاث آيات [الأنعام:١٥١-١٥٣]، ومِن ههنا: <q>﴿وقضى ربك ألا تعبدوا إلا إياه﴾</q> إلى ثلاث آيات بعدها [الإسراء:٢٣-٢٥]{9}١١٠٣. (٣/٤٤٧) ١١٠٣ عَلَّق ابنُ عطية (٢/١٥٦) على قول ابن عباس هذا بقوله: «وهذا عندي مِثالٌ أعْطاهُ في المُحْكَمات». ١١٩٢٠- عن سعيد بن جبير، نحو ذلك{10}. (ز) ١١٩٢١- عن عبد الله بن عباس، قال: <q>﴿محكمات﴾</q>: الحلالُ، والحرام{11}. (٣/٤٤٨) ١١٩٢٢- عن عبد الله بن مسعود وناس من أصحاب النبي ﷺ -من طريق السُّدِّيِّ، عن مُرَّة الهمداني-= (ز) ١١٩٢٣- وعبد الله بن عباس -من طريق السدي، عن أبي مالك وأبي صالح- في قوله: <q>﴿هو الذي أنزل عليك الكتاب منه آيات محكمات هن أم الكتاب﴾</q> إلى قوله: <q>﴿كل من عند ربنا﴾</q>: أمّا الآيات المحكمات فهُنَّ الناسخات التي يُعْمَل بهن، وأما المُتشابهات فهنَّ المنسوخات{12}١١٠٤. (٣/٤٤٨) ١١٠٤ علَّق ابنُ عطية (٢/١٥٦) على هذا القول الذي قال به ابن مسعود، وابن عباس -من طريق علي، والعوفي- وقتادة، والربيع، والضحاك، بقوله: «وهذا عندي على جهة التَّمْثِيل، أي: يوجد الإحكام في هذا، والتشابهُ في هذا، لا أنّه وقْفٌ على هذا النوع من الآيات». ١١٩٢٤- عن عبد الله بن عباس -من طريق عليٍّ- قال: <q>﴿محكمات﴾</q>: ناسخه، وحلاله، وحرامه، وحدوده، وفرائضه، وما يُؤمَن به، ويُعمَل به{13}. (٣/٤٤٧) ١١٩٢٥- عن عبد الله بن عباس -من طريق العوفي- قال: <q>﴿محكمات﴾</q>: الناسخ الذي يُدان به، ويُعمَل به{14}. (٣/٤٤٧) ١١٩٢٦- عن عبد الله بن عباس -من طريق عليِّ بن أبي طلحة- قوله: <q>﴿هو الذي أنزل عليك الكتاب منه آيات محكمات هنّ أم الكتاب﴾</q>: المحكمات: ناسخه، وحلاله، وحرامه، وحدوده، وفرائضه، وما يُؤمَن به، ويُعْمَل به{15}. (ز) ١١٩٢٧- عن مجاهد بن جبر -من طريق ابن أبي نَجِيح- قال: المحكماتُ: ما فيه الحلالُ والحرامُ، وما سوى ذلك منه مُتشابِهٌ يُصَدِّقُ بعضُه بعضًا. مثل قوله: <q>﴿وما يضل به إلا الفاسقين﴾</q> [البقرة:٢٦]، ومثل قوله: <q>﴿كذلك يجعل الله الرجس على الذين لا يؤمنون﴾</q> [الأنعام:١٢٥]، ومثل قوله: <q>﴿والذين اهتدوا زادهم هدى وآتاهم تقواهم﴾</q> [محمد:١٧]{16}١١٠٥. (٣/٤٤٨) ١١٠٥ انتَقَدَ ابنُ كثير (٣/٨-٩) مستندًا إلى القرآن كونَ قولِ مجاهد تفسيرًا لهذه الآية بقوله: «وهذا إنّما هو في تفسير قوله: <q>﴿كتابًا متشابهًا مثاني﴾</q> [الزمر:٢٣]، هناك ذكروا: أنّ المتشابه هو الكلام الذي يكون في سياق واحد، والمثاني هو الكلام في شيئين متقابلين؛ كصفة الجنة وصفة النار، وذكر حال الأبرار ثم حال الفجار ونحو ذلك، فأمّا هاهنا فالمتشابه هو الذي يقابل المُحْكَم». وبنحوه قال ابنُ تيمية (٢/٢٩)، وزاد فقال: «كذلك قوله: <q>﴿فيتبعون ما تشابه منه ابتغاء الفتنة﴾</q> لو أريد بالمتشابه تصديق بعضه بعضًا لكان اتِّباع ذلك غير محذور، وليس في كونه يُصَدِّق بعضه بعضًا ما يمنع ابتغاء تأويله». ١١٩٢٨- عن الضحاك بن مُزاحِم -من طريق سلمة بن نُبَيْط- قال: المُحْكَم: ما لم يُنسَخ{17}. (ز) ١١٩٢٩- عن الضحاك بن مُزاحِم -من طريق جُوَيْبِر- في قوله: <q>﴿آيات محكمات هن أم الكتاب﴾</q>، قال: النّاسِخات{18}. (ز) ١١٩٣٠- عن عكرمة مولى ابن عباس، مثله{19}. (ز) ١١٩٣١- عن عكرمة مولى ابن عباس= (ز) ١١٩٣٢- ومجاهد بن جبر= (ز) ١١٩٣٣- وقتادة بن دِعامة= (ز) ١١٩٣٤- والضحاك بن مُزاحِم= (ز) ١١٩٣٥- ومقاتل بن حيان= (ز) ١١٩٣٦- والربيع بن أنس= (ز) ١١٩٣٧- وإسماعيل السُّدِّيّ، قالوا: المُحْكَم: الذي يُعْمَل به{10}. (ز) ١١٩٣٨- عن قتادة بن دِعامة -من طريق مَعْمَر- في قوله: <q>﴿آيات محكمات﴾</q>، قال: المُحْكَم: ما يُعمَل به{21}. (ز) ١١٩٣٩- عن قتادة بن دِعامة -من طريق سعيد- <q>﴿هو الذي أنزل عليك الكتاب منه آيات محكمات هن أم الكتاب﴾</q>: والمُحْكَمات: الناسخُ الذي يُعْمَل به؛ ما أحَلَّ الله فيه حلالَه، وحرَّم فيه حرامَه، وأما المتشابهات: فالمنسوخُ الذي لا يُعْمَل به، ويُؤْمَنُ به{22}. (ز) ١١٩٤٠- عن الربيع بن أنس -من طريق سليمان بن عامر- قال: المُحْكَمات: هي الآمِرَةُ، الزّاجِرَةُ{23}. (٣/٤٤٨) ١١٩٤١- عن الربيع بن أنس -من طريق أبي جعفر- <q>﴿هو الذي أنزل عليك الكتاب منه آيات محكمات هن أم الكتاب وأخر متشابهات﴾</q>، قال: المُحْكَمات: الناسِخُ الذي يُعْمَلُ به{24}. (ز) ١١٩٤٢- عن محمد بن جعفر بن الزبير -من طريق ابن إسحاق- قال: المُحْكَمات حُجَّةُ الرَّبِّ، وعِصْمَةُ العبادِ، ودفعُ الخصومِ والباطلِ، ليس لها تصريفٌ ولا تحريفٌ عَمّا وُضِعَتْ عليه، <q>﴿وأخر متشابهات﴾</q> في الصِّدق، لَهُنَّ تصريفٌ وتحريفٌ وتأويلٌ، ابتلى اللهُ فيهِنَّ العبادَ كما ابتلاهم في الحلال والحرام، لا يُصْرَفْنَ إلى الباطل، ولا يُحَرَّفْنَ عن الحقِّ{25}١١٠٦. (٣/٤٤٩) ١١٠٦ رجَّح ابنُ عطية (٢/١٥٧)، وابنُ كثير (٣/٩) قولَ ابن الزبير من طريق ابن إسحاق، وقال ابنُ عطية: «وهذا أحسن الأقوال في هذه الآية». ولم يذكرا مستندًا. ١١٩٤٣- قال محمد بن إسحاق -من طريق سلمة-: <q>﴿منه آيات محكمات﴾</q>، فهُنَّ حُجَّةُ الرَّبِّ، وعِصْمَةُ العباد، ودَمْغُ الخصومِ والباطلِ، ليس لَهُنَّ تصريفٌ ولا تحريفٌ عما وُضِعْنَ عليه{26}. (ز) ١١٩٤٤- قال مقاتل بن سليمان: ثُمَّ قال سبحانه: <q>﴿هو الذي أنزل عليك الكتاب منه آيات محكمات﴾</q>، يُعْمَل بِهِنَّ، وهُنَّ الآيات التي في الأنعام [١٥١-١٥٣] قوله سبحانه: <q>﴿قل تعالوا أتل ما حرم ربكم عليكم ألا تشركوا به شيئا وبالوالدين إحسانا﴾</q> إلى ثلاث آيات آخرهن: <q>﴿لعلكم تتقون﴾</q>{27}. (ز) ١١٩٤٥- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- وقرأ: <q>﴿الر كتاب أحكمت آياته ثم فصلت من لدن حكيم خبير﴾</q> [هود:١]، قال: وذَكَرَ حديثَ رسول الله ﷺ في أربع وعشرين آية منها، وحديثَ نوح في أربع وعشرين آية منها، ثُمَّ قال: <q>﴿تلك من أنباء الغيب﴾</q> [هود:٤٩]، ثم ذَكَر: <q>﴿وإلى عاد﴾</q> [هود:٥٠] فقرأ حتى بلغ: <q>﴿استغفروا ربكم﴾</q> [هود:٥٢]، ثُمَّ مَضى، ثُمَّ ذَكَر صالحًا وإبراهيم ولوطًا وشعيبًا، وفرغ من ذلك، وهذا يقينٌ، ذلك يقينٌ أُحْكِمَت آياته ثُمَّ فُصِّلَتْ. قال: والمتشابهُ ذِكْرُ موسى في أمْكِنَةٍ كثيرة، وهو متشابه، وهو كُلُّه معنًى واحد ومتشابه: <q>﴿فاسلك فيها﴾</q> [المؤمنون:٢٧]، <q>﴿احمل فيها﴾</q> [هود:٤٠]. <q>﴿اسلك يدك﴾</q> [القصص:٣٢]، <q>﴿وأدخل يدك﴾</q> [النمل:١٢]. <q>﴿حية تسعى﴾</q> [طه:٢٠]، <q>﴿ثعبان مبين﴾</q> [الأعراف:١٠٧، والشعراء:٣٢]. قال: ثم ذكر هودًا في عشر آيات منها، وصالحًا في ثماني آيات منها، وإبراهيم في ثماني آيات أخرى، ولوطًا في ثماني آيات منها، وشعيبًا في ثلاث عشرة آية، وموسى في أربع آيات، كل هذا يقضي بين الأنبياء وبين قومهم في هذه السورة، فانتهى ذلك إلى مائة آية من سورة هود، ثم قال: <q>﴿ذلك من أنباء القرى نقصه عليك منها قائم وحصيد﴾</q> [هود:١٠٠]. وقال في المتشابه من القرآن: مَن يُرِدِ الله به البلاءَ والضلالةَ يقولُ: ما شَأْنُ هذا لا يكون هكذا؟! وما شأَنْ هذا لا يكون هكذا؟!{28}. (ز) <q>﴿هُنَّ أُمُّ ٱلۡكِتَـٰبِ﴾</q> - تفسير ١١٩٤٦- عن سعيد بن جبير -من طريق عطاء بن دينار- <q>﴿هنّ أم الكتاب﴾</q>، قال: أصلُ الكتاب؛ لأنّهُنَّ مكتوبات في جميع الكتب{29}. (٣/٤٤٩) ١١٩٤٧- عن مجاهد بن جَبْر، في قوله: <q>﴿هن أم الكتاب﴾</q>، يعني: ما فيه من الحلال والحرام، وما سوى ذلك منه مُتشابِهٌ{30}١١٠٧. (ز) ١١٠٧ نقل ابنُ عطية (٢/١٥٧) خِلافَ المفسرين في تعيين المحكم والمتشابه. ووجَّه بعض الأقوال بأنّها خارِجةٌ على المثال. ثُمَّ انتَقَدَ حَصْرَ المعنى في قولٍ منها مستندًا إلى دلالة عقلية، فقال بعد ذكره لقول ابن عباس، وابن مسعود، والربيع، وقتادة، والضحاك، وما في معناها: «وهذه الأقوال وما ضارعها يضعفها أنّ أهل الزَّيْغِ لا تَعَلُّقَ لهم بنوعٍ مِمّا ذُكِر دون سواه». ١١٩٤٨- عن الحسن البصري -من طريق مالك بن دينار- في قوله: <q>﴿أم الكتاب﴾</q>، قال: الحلال، والحرام. قلتُ له: فـ<q>﴿الحمد لله رب العالمين﴾</q>؟ قال: هذه أمُّ القرآن{31}. (٣/٤٤٩) ١١٩٤٩- عن يحيى بن يَعْمُر= (ز) ١١٩٥٠- وأبي فاخِتَة -من طريق إسحاق بن سويد- أنّهما تَراجَعا هذه الآية: <q>﴿هن أم الكتاب﴾</q>، فقال أبو فاخِتَة: هُنَّ فواتحُ السُّوَرِ منها يُسْتَخْرَجُ القرآن؛ <q>﴿الم ذلك الكتاب﴾</q> منها اسْتُخْرِجَتِ البقرةُ، و<q>﴿الم الله لا إله إلا هو الحي القيوم﴾</q> منها اسْتُخْرِجَت آلُ عمران. قال يحيى: هُنَّ اللاتي فيهِنَّ الفرائض، والأمر، والنهي، والحلالُ، والحدودُ، وعِمادُ الدِّين. وضرب لذلك مثلًا، فقال: أمُّ القرى: مكة. وأمُّ خراسان: مَرْو. وأمُّ المسافرين: الذين يجعلون إليه أمرهم، ويُعْنى بهم في سفرهم. قال: فذاك أُمُّهُم{32}١١٠٨. (٣/٤٤٨-٤٤٩) ١١٠٨ انتَقَدَ ابنُ عطية (٢/١٥٨-١٥٩) قولَ أبي فاختة: أنّ أُمَّ الكتاب هي فواتح السور؛ لمخالفته ظاهر القرآن، فقال: «وهذا قولٌ مُتَداعٍ للسقوط مُضْطَرِبٌ، لم ينظر قائلُه أوَّلَ الآية وآخرَها ومقصدَها. وإنّما معنى الآية: الإنحاءُ على أهلِ الزيغ والإشارة بذلك؛ أوّلًا إلى نصارى نجران وإلى اليهود الذين كانوا معاصرين لمحمد ﵇، فإنّهم كانوا يعترضون معاني القرآن، ثم تَعُمُّ بعد ذلك كُلَّ زائغ». ١١٩٥١- قال مقاتل بن سليمان: يقول: <q>﴿هن أمّ الكتاب﴾</q>، يعني: أصلَ الكتاب؛ لأنّهُنَّ في اللوح المحفوظ مكتوبات، وهُنَّ مُحَرّمات على الأُمَم كُلِّها في كتابهم، وإنّما تَسَمَّيْنَ أُمَّ الكتاب لأَنَّهُنَّ مكتوباتٌ في جميع الكتب التي أنزلها الله -تبارك وتعالى- على جميع الأنبياء، وليس مِن أهل دِين إلا وهو يُوصى بِهِنَّ{33}. (ز) ١١٩٥٢- عن مقاتل بن حيان -من طريق بُكَيْر بن معروف- قال: إنّما قال: <q>﴿هن أم الكتاب﴾</q> لأنّه ليس مِن أهل دينٍ إلا يَرْضى بِهِنَّ{34}. (٣/٤٤٩) ١١٩٥٣- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهْب- في قوله: <q>﴿هن أم الكتاب﴾</q>، قال: هُنَّ جِماعُ الكِتاب{35}١١٠٩. (ز) ١١٠٩ ذكر ابن عطية (٢/١٥٨) أن المهدويَّ والنقّاش قالا: كل آية محكمة في كتاب الله يقال لها: أم الكتاب. وانتقده مستندًا إلى ظاهر الآية، فقال: «وهذا مردود، بل جميع المحكم هو أم الكتاب». وذكر أنّ النقّاش قال بأن مثال ذلك كما تقول: كلكم عَلَيَّ أسدٌ ضارٍ. وانتقد مثاله بأنه غير مُحْكم. <q>﴿وَأُخَرُ مُتَشَـٰبِهَـٰتࣱۖ﴾</q> - تفسير ١١٩٥٤- عن عبد الله بن عباس -من طريق عليٍّ- قال: <q>﴿متشابهات﴾</q>: منسوخه، ومُقَدَّمه، ومُؤَخَّره، وأمثاله، وأقسامه، وما يُؤْمَن به ولا يُعْمَل به{13}. (٣/٤٤٧) ١١٩٥٥- عن عبد الله بن عباس -من طريق العوفي- قال: <q>﴿متشابهات﴾</q>: المنسوخات التي لا يُدان بِهِنَّ{14}. (٣/٤٤٧) ١١٩٥٦- عن عبد الله بن عباس -من طريق باذام-: المتشابه: حروفُ التَّهَجِّي في أوائل السُّوَر{38}. (ز) ١١٩٥٧- عن عبد الله بن مسعود وناس من أصحاب النبي ﷺ -من طريق السُّدِّيِّ، عن مُرَّة الهمداني-= (ز) ١١٩٥٨- وعبد الله بن عباس -من طريق السدي، عن أبي مالك وأبي صالح- في قوله: <q>﴿متشابهات﴾</q>: فَهُنَّ المنسوخات{12}. (٣/٤٤٨) ١١٩٥٩- عن سعيد بن جبير، قال: المتشابهاتُ: آياتٌ في القرآن يَتَشابَهْنَ على الناس إذا قَرَأُوهُنَّ، ومِن أجل ذلك يَضِلُّ مَن ضَلَّ، فكُلُّ فِرْقَةٍ يقرؤون آيةً من القرآن يزعمون أنها لهم، فمنها يتبع الحروريَّةُ مِن المتشابه قولَ الله: <q>﴿ومن لم يحكم بما أنزل الله فأولئك هم الكافرون﴾</q> [المائدة:٤٤]، ثُمَّ يقرؤون معها: <q>﴿والذين كفروا بربهم يعدلون﴾</q> [الأنعام:١]، فإذا رأوا الإمامَ يحكم بغير الحقِّ قالوا: قد كفر، فمَن كفر فقد عدل بربه، ومَن عدل بِرَبِّه فقد أشرك برَبِّه، فهؤلاء الأئِمَّةُ مُشْرِكون{40}. (٣/٤٤٩-٤٥٠) ١١٩٦٠- عن مجاهد بن جَبْر -من طريق ابن جُرَيْج- <q>﴿وأخر متشابهات﴾</q>، قال: يُصَدِّقُ بعضه بعضًا{23}. (ز) ١١٩٦١- عن الضَّحّاك بن مُزاحِم -من طريق جُوَيْبِر- <q>﴿وأخر متشابهات﴾</q>، قال: ما نُسِخ وتُرِك يُتْلى{42}. (ز) ١١٩٦٢- عن قتادة بن دِعامة -من طريق سعيد-: <q>﴿وأخر متشابهات﴾</q>، أمّا المتشابهات: فالمنسوخُ الذي لا يُعْمَل به، ويُؤْمَنُ به{43}. (ز) ١١٩٦٣- عن الربيع بن أنس -من طريق أبي جعفر- قال: والمتشابهاتُ: المنسوخُ الذي لا يُعْمَلُ به، ويُؤْمَنُ به{44}. (ز) ١١٩٦٤- قال مقاتل بن سليمان: ثُمَّ قال ﷿: <q>﴿وأخر متشابهات﴾</q>: <q>﴿الم﴾</q>، <q>﴿المص﴾</q>، <q>﴿المر﴾</q>، <q>﴿الر﴾</q>، شُبّه على اليهود كَم تَمْلِكُ هذه الأُمَّةُ مِن السنين، والمتشابهات هؤلاء الكلمات الأربع{45}. (ز) ١١٩٦٥- عن مقاتل بن حيان -من طريق بُكَيْر بن معروف- قال: <q>﴿وأخر متشابهات﴾</q>، يعني فيما بَلَغَنا: <q>﴿الم﴾</q>، و<q>﴿المص﴾</q>، و<q>﴿المر﴾</q>، و<q>﴿الر﴾</q>{46}. (٣/٤٤٩) ١١٩٦٦- عن محمد بن إسحاق -من طريق ابن إدريس- <q>﴿وأخر متشابهات﴾</q>، قال: لَمْ يُفَصَّل فيهِنَّ القولُ كفَصْلِه في المحكمات، تَتَشابَهُ في عقول الرجال، ويَتَخالَجُها التَّأْوِيلُ، فابتلى اللهُ فيها العبادَ كابتلائهم في الحلال والحرام{46}. (ز) ١١٩٦٧- عن محمد بن إسحاق -من طريق زياد- <q>﴿وأخر متشابهات﴾</q>، قال: في الصِّدق، لَهُنَّ تحريفٌ، وتصريفٌ، وتأويلٌ، ابتلى الله فيهِنَّ العبادَ كما ابتلاهم في الحلال والحرام، أن يُصْرفن إلى الباطل، ولا يُحَرَّفْنَ عن الحقِّ{48}. (ز) <q>﴿فَأَمَّا ٱلَّذِینَ فِی قُلُوبِهِمۡ زَیۡغࣱ﴾</q> - نزول الآية ١١٩٦٨- عن الحسن البصري، أنّه قال: نزلت في الخوارج{30}. (ز) ١١٩٦٩- عن الربيع بن أنس -من طريق أبي جعفر- قال: عمدوا -يعني: الوفد الذين قدموا على رسول الله ﷺ مِن نصارى نجران- فخاصموا النبيَّ ﷺ، قالوا: ألستَ تزعم أنّه كلمةُ الله، وروحٌ منه؟ قال: «بلى». قالوا: فحسبنا. فأنزل الله ﷿: <q>﴿فأما الذين في قلوبهم زيغ فيتبعون ما تشابه منه ابتغاء الفتنة﴾</q>. ثم إنّ الله -جلَّ ثناؤُه- أنزل: <q>﴿إن مثل عيسى عند الله كمثل آدم﴾</q> [آل عمران:٥٩]{50}. (ز) <q>﴿فَأَمَّا ٱلَّذِینَ فِی قُلُوبِهِمۡ زَیۡغࣱ﴾</q> - تفسير الآية ١١٩٧٠- عن أبي أُمامة، عن النبي ﷺ، في قوله: <q>﴿فأما الذين في قلوبهم زيغ فيتبعون ما تشابه منه﴾</q> قال: «هم الخوارج». وفي قوله: <q>﴿يوم تبيض وجوه وتسود وجوه﴾</q> [آل عمران:١٠٦] قال: «هم الخوارج»{51}١١١٠. (٣/٤٥٤) ١١١٠ علَّق ابن كثير (٣/١٢) على هذه الرواية بقوله: «وهذا الحديث أقل أقسامه أن يكون موقوفًا من كلام الصحابي، ومعناه صحيح؛ فإن أوَّل بدعة وقعت في الإسلام فتنة الخوارج، وكان مبدؤهم بسبب الدنيا حين قسَّم رسول الله ﷺ غنائم حُنَين، فكأنهم رأوا في عقولهم الفاسدة أنه لم يعدل في القسمة، ففاجؤوه بهذه المقالة، فقال قائلهم -وهو ذو الخويصرة، بقر الله خاصرته-: اعدل فإنك لم تعدل. فقال له رسول الله ﷺ: «لقد خِبتُ وخسرتُ إن لم أكن أعدل، أيأمنُني على أهل الأرض ولا تأمنوني؟!»». ١١٩٧١- عن عبد الله بن مسعود وناس من أصحاب النبي ﷺ -من طريق السُّدِّي، عن مُرَّة الهمداني-= (٣/٤٥٢) ١١٩٧٢- وعبد الله بن عباس -من طريق السُّدِّيِّ، عن أبي مالك وأبي صالح- في قوله: <q>﴿فأما الذين في قلوبهم زيغ﴾</q>، أما الزَّيْغُ: فالشكُّ{52}. (ز) ١١٩٧٣- عن عبد الله بن عباس -من طريق علي بن أبي طلحة- <q>﴿فأما الذين في قلوبهم زيغ﴾</q>: يعني: أهل الشَّك، فيحملون المُحْكَم على المتشابه، والمتشابه على المُحْكَم، ويُلَبِّسُون؛ فلَبَّسَ اللهُ عليهم{53}. (٣/٤٥٢) ١١٩٧٤- عن عبد الله بن عباس –من طريق عطاء بن أبي رباح- <q>﴿فأما الذين في قلوبهم زيغ﴾</q>، قال: هم أصحاب الخصومات والمِراء في دِين الله{54}. (ز) ١١٩٧٥- عن مجاهد بن جَبْر -من طريق ابن أبي نَجِيح- في قول الله: <q>﴿في قلوبهم زيغ﴾</q>، قال: شَكٌّ{55}. (ز) ١١٩٧٦- عن قتادة بن دِعامة، في قوله: <q>﴿فأما الذين في قلوبهم زيغ﴾</q> الآية، قال: طلبَ القومُ التأويلَ، فأخطأوا التأويل، وأصابوا الفتنة، واتَّبعوا ما تشابه منه؛ فهلكوا بين ذلك{56}. (٣/٤٦٥-٤٦٦) ١١٩٧٧- عن مَعْمَر، قال: كان قتادةُ إذا قرأ هذه الآية: <q>﴿فأما الذين في قلوبهم زيغ﴾</q> قال: إن لم يكونوا الحَرُورِيَّةَ{57} والسَّبائِيَّة{58} فلا أدري مَن هم؟! ولَعَمْرِي، لَقد كان في أهل بدر والحديبية الذين شهدوا مع رسول الله ﷺ بيعةَ الرضوان من المهاجرين والأنصار خَبَرٌ لِمَنِ اسْتَخْبَر، وعِبْرَةٌ لِمَنِ اسْتَعْبَر، لِمَن كان يعقل أو يُبْصر. إنّ الخوارج خرجوا وأصحابُ رسول الله ﷺ يومئذ كثير بالمدينة والشام والعراق، وأزواجُه يومئذٍ أحياء، واللهِ، إنْ خرج منهم ذكرٌ ولا أنثى حَرُورِيًّا قط، ولا رضُوا الذي هم عليه، ولا مالَؤُوهم فيه، بل كانوا يُحَدِّثون بعَيْبِ رسول الله ﷺ إيّاهم، ونعتِه الذي نعتهم به، وكانوا يُبْغِضونهم بقلوبهم، ويعادونهم بألسنتهم، وتَشْتَدُّ -واللهِ- عليهم أيديهم إذا لَقوهم. ولعَمْرِي، لو كان أمرُ الخوارج هُدًى لاجتمع، ولكنَّه كان ضلالًا فتَفَرَّق، وكذلك الأمرُ إذا كان مِن عند غير الله وجدت فيه اختلافًا كثيرًا، فقد ألاصُوا{59} هذا الأمرَ مُنذُ زمان طويل، فهل أفلحوا فيه يومًا أو أنجحوا؟ يا سبحان الله! كيف لا يعتبر آخِرُ هؤلاء القوم بأوَّلِهم؟! لو كانوا على هُدًى قد أظهره الله وأَفْلَجَه ونصره، ولكنهم كانوا على باطلٍ أكذبه الله وأَدْحَضَه، فهم كما رأيتَهم؛ كُلَّما خرج لهم قَرْنٌ أدْحَضَ اللهُ حُجَّتهم، وأَكْذَب أُحْدُوثَتَهُم، وأَهْرَقَ دِماءَهم، وإن كتموا كان قَرْحًا في قلوبهم، وغمًّا عليهم، وإن أظهروه أهْراقَ اللهُ دِماءَهم، ذاكم -واللهِ- دينُ سُوءٍ؛ فاجْتَنِبُوه. واللهِ، إنّ اليهودية لَبِدْعَة، وإنّ النصرانية لَبِدْعَة، وإنّ الحَرُورِيَّة لَبِدْعَة، وإنّ السَّبائِيَّة لَبِدْعَة، ما نزل بِهِنَّ كتابٌ، ولا سَنَّهُنَّ نبيٌّ{60}. (ز) ١١٩٧٨- عن إسماعيل السُّدِّيّ، في قول الله <q>﴿في قلوبهم زيغ﴾</q>، قال: شَكٌّ{61}. (ز) ١١٩٧٩- عن محمد بن جعفر بن الزبير -من طريق ابن إسحاق- <q>﴿فأما الذين في قلوبهم زيغ﴾</q>، أي: مَيْلٌ عن الهدى{62}. (ز) ١١٩٨٠- عن محمد بن السائب الكلبي: هم اليهود، طَلَبوا عِلْمَ أجلِ هذه الأمّة واستخراجها بحساب الجُمَّل{63}. (ز) ١١٩٨١- قال مقاتل بن سليمان: <q>﴿فأما الذين في قلوبهم زيغ﴾</q>، يعني: مَيْل عن الهدى، وهو الشَّكُّ، فهُم اليهودُ{45}. (ز) ١١٩٨٢- عن مقاتل بن حَيّان -من طريق بُكَيْر بن معروف- في قوله: <q>﴿فأما الذين في قلوبهم زيغ﴾</q>، يعني: حُيَيّ بن أخْطَب، وأصحابه مِن اليهود{65}. (ز) ١١٩٨٣- عن عبد الملك بن جُرَيْج، قال: <q>﴿الذين في قلوبهم زيغ﴾</q> المنافقون{66}. (٣/٤٥٢) ١١٩٨٤- عن محمد بن إسحاق -من طريق سلمة- <q>﴿فأما الذين في قلوبهم زيغ﴾</q>: أي: مَيْل عن الهدى{67}. (ز) <q>﴿فَیَتَّبِعُونَ مَا تَشَـٰبَهَ مِنۡهُ﴾</q> - تفسير ١١٩٨٥- عن عائشة -من طريق عبد الله بن أبي مُلَيْكة- قالت: قرأ رسول الله ﷺ: <q>﴿هو الذي أنزل عليك الكتاب﴾</q> إلى قوله: <q>﴿وما يذكر إلا أولو الألباب﴾</q>، فقال: «فإذا رأيتُم الذين يُجادلون فيه فهُم الذين عنى اللهُ؛ فاحذروهم»{68}. (٣/٤٥٣) ١١٩٨٦- عن حذيفة، عن رسول الله ﷺ، قال: «إنّ في أُمَّتي قومًا يقرؤون القرآن، ينثُرُونَه نَثْر الدَّقَل{69}، يتأَوَّلونه على غير تأويله»{70}. (٣/٤٥٥) ١١٩٨٧- عن عبد الله بن عباس -من طريق علي بن أبي طلحة- <q>﴿فيتّبعون ما تشابه منه﴾</q>، قال: فيحمِلُون المُحْكمَ على المتشابه، والمتشابِهَ على المُحْكَم، ويُلَبِّسُون؛ فلبَّس الله عليهم{71}. (ز) ١١٩٨٨- عن عبد الله بن عباس -من طريق علي بن أبي طلحة- في قوله -جلَّ وعَزَّ-: <q>﴿فأما الذين في قلوبهم زيغ فيتّبعون ما تشابه منه﴾</q>، وقوله: <q>﴿وتقطّعوا أمرهم بينهم﴾</q> [الأنبياء:٩٣]، وقوله ﷿: <q>﴿إذا سمعتم آيات الله يكفر بها﴾</q> [النساء:١٤٠]، وقوله: <q>﴿ولا تتبعوا السبل﴾</q> [الأنعام:١٥٣]، وقوله: <q>﴿أقيموا الدين ولا تتفرقوا فيه﴾</q> [الشورى:١٣]، ونحو هذا في القرآن، قال: أمر الله المؤمنين بالجماعة، ونهاهم عن الاختلاف والفرقة في القرآن، وأخبرهم: إنّما هلك مَن كان قبلكم بالمِراء والخصومات في دين الله{72}. (ز) ١١٩٨٩- عن مجاهد بن جبر -من طريق ابن جُرَيْج- في قوله: <q>﴿فيتبعون ما تشابه منه﴾</q>، قال: الباب الذي ضلّوا منه، وهلكوا فيه ابتغاءَ تأويله{73}. (٣/٤٥٣) ١١٩٩٠- عن إسماعيل السُّدِّيّ -من طريق أسباط- في قوله: <q>﴿فيتّبعون ما تشابه منه﴾</q>، قال: يتّبعون المنسوخ والناسخ، فيقولون: ما بالُ هذه الآية عُمِل بها كذا وكذا مكان هذه الآية، فتُرِكت الأولى وعُمِل بهذه الأخرى؟ هلّا كان العملُ بهذه الآية قبل أن تجيء الأولى التي نُسخت! وما بالُه يَعِدُ العذابَ مَن عمِل عمَلًا يُعَذِّبُه بالنار، وفي مكان آخر مَن عمِله فإنّه لم يُوجِب له النار؟{74}. (ز) ١١٩٩١- عن محمد بن جعفر بن الزبير -من طريق ابن إسحاق- <q>﴿فيتّبعون ما تشابه منه﴾</q>: أي: ما تَحَرَّفَ منه وتَصَرَّف، ليُصَدِّقُوا به ما ابْتَدَعُوا وأَحْدَثُوا، لِيَكُونَ لَهُم حُجَّةً على ما قالوا وشُبْهَةً{75}. (ز) ١١٩٩٢- عن محمد بن إسحاق -من طريق زياد-، مثله{76}١١١١. (ز) ١١١١ اختلف المفسرون فيمَن عُني بهذه الآية؛ فقال قومٌ: عُنِي به الوفد من نصارى نجران الذين خاصموا الرسول ﷺ في أمر عيسى. وذهب آخرون إلى نزولها في أبي ياسر بن أخطب، وأخيه، والنفر الذين ناظروا الرسول ﷺ في قدر مدة أُكله وأُكل أمته (أي: أجله في الدنيا)، وأرادوا عِلْمَ ذلك مِن قِبَل الحروف المقطعة. وقال آخرون: بل عنى اللهُ ﷿ بذلك كُلَّ مُبْتَدِعٍ في دينه. وقدَّم ابنُ جرير (٥/٢١١-٢١٢) القولين الأولين، فقال: «والذي يَدُلُّ عليه ظاهرُ هذه الآية أنّها نزلت في الذين جادلوا رسول الله ﷺ بمتشابه ما أُنزِل إليه مِن كتاب الله؛ إمّا في أمر عيسى، وإمّا في مدة أُكله وأُكل أمته». ثُمَّ رَجَّح القولَ الثاني منهما مستندًا إلى ظاهر الآية، فقال: «وهو بأن تكون في الذين جادلوا رسول الله ﷺ بمتشابهه في مدته ومده أمته أشبهُ؛ لأنّ قوله: <q>﴿وما يعلم تأويله إلا الله﴾</q> دالٌّ على أنّ ذلك إخبارٌ عن المُدَّة التي أرادوا عِلْمَها من قِبَل المتشابه الذي لا يعلمه إلا الله، فأمّا أمر عيسى وأسبابُه فقد أعلم اللهُ ذلك نبيَّه محمدًا ﷺ وأُمَّتَه وبَيَّنَه لهم، فمعلومٌ أنّه لم يَعْنِ إلا ما كان خَفِيًّا عن الآحاد». ثُمَّ أفاد (٥/٢١٤ بتصرف) انسحابَ الآيةِ بعد ذلك على كُلِّ مبتدع، فقال: «وهذه الآيةُ وإن كانت نزلت فيمَن ذكرنا أنّها نزلت فيه من أهل الشرك؛ فإنّه مَعْنِيٌّ بها كُلُّ مُبْتَدِعٍ في دين الله بِدْعَةً، فمال قلبُه إليها، تأويلًا منه لبعض متشابه آي القرآن، ثم حاجَّ به وجادلَ به أهل الحق، وعدل عن الواضح مِن أدلة آيِه المحكمات؛ إرادةً منه بذلك اللبس على أهل الحقِّ، وطلبًا لعلم تأويل ما تشابه عليه من ذلك كائنًا مَن كان». ورَجَّح ابنُ عطية (٢/١٦٠) عمومَ المعنى. <q>﴿ٱبۡتِغَاۤءَ ٱلۡفِتۡنَةِ﴾</q> - تفسير ١١٩٩٣- عن مجاهد بن جبر -من طريق ابن جُرَيْج- في قوله: <q>﴿ابتغاء الفتنة﴾</q>، قال: الشُّبُهات، بها أُهْلِكوا{77}. (٣/٤٥٣) ١١٩٩٤- عن الحسن البصري -من طريق سفيان بن حسين- في قوله: <q>﴿ابتغاء الفتنة﴾</q>، قال: الضلالة{78}. (ز) ١١٩٩٥- عن إسماعيل السُّدِّيّ -من طريق أسباط- <q>﴿ابتغاء الفتنة﴾</q>، قال: إرادة الشِّرْك{79}. (ز) ١١٩٩٦- عن الربيع بن أنس -من طريق أبي جعفر- في قوله: <q>﴿ابتغاء الفتنة﴾</q>، يعني: الشِّرْك{80}. (ز) ١١٩٩٧- عن مقاتل بن حيان، نحو ذلك{81}. (ز) ١١٩٩٨- عن محمد بن جعفر بن الزبير -من طريق ابن إسحاق- في قوله: <q>﴿ابتغاء الفتنة﴾</q>، أي: اللَّبْس{82}. (ز) ١١٩٩٩- عن محمد بن إسحاق -من طريق زياد-، مثله{83}١١١٢. (ز) ١١١٢ رَجَّح ابنُ جرير (٥/٢١٤-٢١٥) قولَ مجاهد، وابن الزبير، وابن إسحاق مستندًا إلى أحوال النزول، فقال: «وإنّما قلنا: القول الذي ذكرنا أنّه أولى التأويلين بقوله: <q>﴿ابتغاء الفتنة﴾</q> لأنّ الذين نزلت فيهم هذه الآية كانوا أهل شرك، وإنّما أرادوا بطلب تأويل ما طلبوا تأويله اللبسَ على المسلمين والاحتجاج به عليهم ليصدّوهم عَمّا هم عليه من الحقّ، فلا معنى لأن يُقال: فعلوا ذلك إرادة الشرك، وهم قد كانوا مشركين». ١٢٠٠٠- قال مقاتل بن سليمان: <q>﴿فيتبعون ما تشابه منه ابتغاء الفتنة﴾</q>، يعني: ابتغاء الكفر{45}. (ز) <q>﴿وَٱبۡتِغَاۤءَ تَأۡوِیلِهِۦۖ﴾</q> - تفسير ١٢٠٠١- عن الحسن البصري -من طريق عبّاد بن منصور- في قوله: <q>﴿وابتغاء تأويله﴾</q>، قال: تأويله القضاء به يوم القيامة{85}. (ز) ١٢٠٠٢- عن قتادة بن دِعامة -من طريق سعيد- <q>﴿فأما الذين في قلوبهم زيغ فيتبعون ما تشابه منه ابتغاء الفتنة وابتغاء تأويله﴾</q>، قال: طلب القومُ التأويلَ فأخطَؤُوا التأويلَ، وأصابوا الفتنةَ، فاتَّبعوا ما تشابه منه؛ فهلكوا مِن ذلك{86}. (ز) ١٢٠٠٣- عن إسماعيل السُّدِّيِّ -من طريق أسباط- <q>﴿وابتغاء تأويله﴾</q>، قال: أرادوا أن يعلموا تأويلَ القرآن، وهو عَواقِبُه{87}. (ز) ١٢٠٠٤- عن محمد بن جعفر بن الزبير -من طريق ابن إسحاق- <q>﴿وابتغاء تأويله﴾</q>، قال: وذلك على ما ركِبوا مِن الضلالة في قولهم: خلقنا، وقضينا{88}. (ز) ١٢٠٠٥- قال مقاتل بن سليمان: <q>﴿وابتغاء تأويله﴾</q>، يعني: مُنتَهى ما يكون، وكم يكون، يريد بذلك الملك{45}. (ز) ١٢٠٠٦- عن مقاتل بن حَيّان -من طريق بُكَيْر بن معروف- قوله: <q>﴿ابتغاء تأويله﴾</q>، قال: ابتغاء ما يكون، وكم يكون{85}. (ز) ١٢٠٠٧- عن محمد بن إسحاق –من طريق إبراهيم بن سعد- <q>﴿وابتغاء تأويله﴾</q>، قال: ذلك ما رَكِبوا مِن الضَّلال في قولهم: خلقنا، وقضينا. يقول: <q>﴿وما يعلم تأويله﴾</q> الذي به أراد وما أرادوا <q>﴿إلا الله﴾</q>{91}. (ز) ١٢٠٠٨- عن محمد بن إسحاق -من طريق ابن إدريس- قوله: <q>﴿ابتغاء تأويله﴾</q>، قال: ما تَأَوَّلوا وزَيَّنُوا مِن الضلالة؛ لِيَجِيء لهم الَّذي في أيديهم مِن البدعة، ليكون لهم به حُجَّةً على مَن خالفهم للتَّصْرِيف والتَّحْرِيف الذي ابْتُلُوا به؛ كمَيْلِ الأهواء، وزَيْغِ القلوب، والتَّنكِيبِ عن الحق الذي أحْدَثوا مِن البِدْعة{85}. (ز) <q>﴿وَمَا یَعۡلَمُ تَأۡوِیلَهُۥۤ إِلَّا ٱللَّهُۗ﴾</q> - تفسير ١٢٠٠٩- عن عبد الله بن عباس، قال: قال رسول الله ﷺ: «أُنزِل القرآنُ على سبعة أحرف: حلالٍ وحرامٍ لا يُعْذَر أحدٌ بالجهالة به، وتفسيرٌ تُفَسِّرُه العرب، وتفسيرٌ تُفَسِّره العلماء، ومُتشابِهٍ لا يعلمه إلا الله، ومَنِ ادَّعى علمَه سوى الله فهو كاذِبٌ»{93}. (٣/٤٦١) ١٢٠١٠- عن عبد الله بن عباس -من طريق علي بن أبي طلحة- <q>﴿وما يعلم تأويله إلا الله﴾</q>، قال: تأويله يوم القيامة لا يعلمه إلا الله{94}١١١٣. (٣/٤٥٢) ١١١٣ اختلف المفسّرون في معنى التأويل في قوله: <q>﴿وابتغاء تأويله﴾</q>؛ فقال بعضهم: الأجل الذي أرادت اليهود أن تعرفه من انقضاء مُدَّةِ أمر النبي ﷺ وأُمَّتِه مِن قِبَل الحروف المقطّعة. وقال آخرون: بل معنى ذلك: عواقب القرآن، وقالوا: إنّما أرادوا أن يعلموا متى يجيء ناسخُ الأحكام التي كان الله -جل ثناؤه- شرعها لأهل الإسلام قبل مجيئه. وقال آخرون: بل معنى ذلك: وابتغاء تأويل ما تشابه مِن آي القرآن يتأوّلونه إذ كان ذا وجوه وتصاريف في التأويلات على ما في قلوبهم من الزيغ، وما ركبوه من الضلالة. ورَجَّح ابنُ جرير (٥/٢١٦-٢١٧) القولَ الأول الذي قاله ابن عباس، والثاني الذي قاله السدي، مستندًا إلى ظاهر الآية، حيث إنّ طلب القوم معرفةَ الوقت الذي هو جاء قبل مجيئه، المحجوب علمه عنهم وعن غيرهم؛ موافق لإخبار الله بأنّه تأويلٌ لا يعلمه إلا هو، أمّا غيره من التأويل فقد عُلِم واشْتَهَر. لكنَّه استَدْرَك (٥/٢١٦-٢١٧) على القول الثاني الذي قاله السّدّي حَصْرَه معنى الآية في أنّ القوم طلبوا معرفة وقتِ مجيء الناسخ لِما قد أُحْكِم قبل ذلك. ١٢٠١١- عن عبد الله بن عباس -من طريق ابن جريج- <q>﴿وما يعلم تأويله إلا الله﴾</q>، قال: جزاءَه وثوابَه يوم القيامة{91}. (ز) ١٢٠١٢- عن عبد الله بن عباس -من طريق مجاهد- <q>﴿وما يعلم تأويله إلا الله﴾</q>، قال: تأويل القرآن{96}. (ز) ١٢٠١٣- عن هشام بن عروة بن الزبير قال: كان أبي يقول في هذه الآية <q>﴿وما يعلم تأويله إلا الله والراسخون في العلم﴾</q>: إنّ الراسخين في العلم لا يعلمون تأويله، ولكنّهم يقولون: <q>﴿آمنا به كل من عند ربنا﴾</q>{97}. (ز) ١٢٠١٤- عن مجاهد بن جَبْر -من طريق ابن أبي نَجِيح- <q>﴿وما يعلم تأويله إلا الله﴾</q>، قال: العِبارَة{96}. (ز) ١٢٠١٥- عن الضَّحاك بن مُزاحِم -من طريق جُوَيْبِر- <q>﴿وما يعلم تأويله إلا الله﴾</q>، قال لنا: ثوابه{96}. (ز) ١٢٠١٦- عن إسماعيل السُّدِّيّ -من طريق أسباط-: قال الله: <q>﴿وما يعلم تأويله إلا الله﴾</q>، وتأويله: عواقبه؛ متى يأتي الناسخُ منه فينسخ المنسوخ{100}. (ز) ١٢٠١٧- قال مقاتل بن سليمان: يقول الله ﷿: <q>﴿وما يعلم تأويله إلا الله﴾</q>، كم يملكون مِن السنين، يعني: أُمَّة محمد ﷺ، يملكون إلى يوم القيامة، إلا أيّامًا يبتليهم الله ﷿ بالدَّجّال{45}. (ز) ١٢٠١٨- عن مقاتل بن حَيّان -من طريق بُكَيْر بن معروف- يقول الله: <q>﴿وما يعلم تأويله إلا الله﴾</q>، قال: كم يملكون إلا الله{96}. (ز) ١٢٠١٩- عن محمد بن إسحاق -من طريق ابن إدريس- قوله: <q>﴿وما يعلم تأويله إلا الله﴾</q>، أي: ما يعلم ما حرَّفوا وتأويلَه إلا الله الذي يعلم سرائرَ العباد وأعمالَهم{96}. (ز) ١٢٠٢٠- عن عبد الرحمن بن زيد بن أسلم -من طريق أصْبَغ- <q>﴿وما يعلم تأويله﴾</q>، قال: تحقيقه{96}. (ز) <q>﴿وَمَا یَعۡلَمُ تَأۡوِیلَهُۥۤ إِلَّا ٱللَّهُۗ﴾</q> - آثار متعلقة بالآية ١٢٠٢١- عن أبي مالك الأَشْعَرِيِّ، أنّه سمع رسول الله ﷺ يقول: «لا أخاف على أُمَّتِي إلا ثلاثَ خِلال: أن يَكْثُر لهم المالُ فيتحاسدوا فيقتتلوا، وأن يُفْتَح لهم الكتابُ فيأخذه المؤمن يبتغي تأويله <q>﴿وما يعلم تأويله إلا الله والراسخون في العلم يقولون آمنا به كل من عند ربنا وما يذكر إلا أولوا الألباب﴾</q>، وأن يزداد علمُهم فيُضَيِّعُوه ولا يُبالُوا به»{105}. (٣/٤٥٤) ١٢٠٢٢- عن أبي هريرة، أنّ رسول الله ﷺ قال: «نزل القرآنُ على سبعة أحرف، المِراءُ في القرآن كُفْرٌ؛ ما عرفتم منه فاعملوا به، وما جهِلْتُم منه فَرُدُّوه إلى عالِمِه»{106}. (٣/٤٥٧) ١٢٠٢٣- عن أبي هريرة، قال: قال رسول الله ﷺ: «أعْرِبوا القرآنَ، واتَّبِعوا غرائبَه، وغرائبُه: فرائضُه وحدودُه؛ فإنّ القرآن نزل على خمسة أوجه: حلال، وحرام، ومحكم، ومتشابه، وأمثال. فاعملوا بالحلال، واجتنبوا الحرام، واتَّبِعوا المحكم، وآمِنوا بالمتشابه، واعْتَبِروا بالأمثال»{107}. (٣/٤٥٧) ١٢٠٢٤- عن عمرو بن شعيب، عن أبيه، عن جدِّه: أنّ رسول الله ﷺ خرج على قوم يتراجعون في القرآن وهو مُغضَب، فقال: «بهذا ضَلَّتِ الأممُ قبلَكم باختلافهم على أنبيائهم، وضَرْبِ الكتابِ بعضِه ببعض. قال: وإنّ القرآن لَمْ ينزل لِيُكَذِّبَ بعضُه بعضًا، ولكن نزل أن يُصَدِّق بعضُه بعضًا؛ فما عرفتم منه فاعملوا به، وما تشابه عليكم فآمِنوا به»{108}. (٣/٤٥٥) ١٢٠٢٥- عن عمرو بن شعيب، عن أبيه، عن جده [من وجه آخر]: سَمِع رسولُ الله ﷺ قومًا يَتَدارَأُون{109}، فقال: «إنّما هَلَك مَن كان قبلكم بهذا، ضربوا كتاب الله بعضه ببعض، وإنّما نزل كتابُ الله يُصَدِّق بعضُه بعضًا؛ فلا تُكَذِّبوا بعضَه ببعض، فما علِمْتُم منه فقولوا، وما جهِلْتُم فكِلُوه إلى عالِمِه»{110}. (٣/٤٥٥) ١٢٠٢٦- عن عمر بن أبي سلمة، أنّ النبي ﷺ قال لعبد الله بن مسعود: «إنَّ الكُتُبَ كانت تنزل مِن السماء مِن باب واحد، وإنّ القرآن نزل من سبعة أبواب على سبعة أحرف: حلالٍ، وحرامٍ، ومُحْكَمٍ، ومُتشابِهٍ، وضرب أمثالٍ، وآمِرٍ، وزاجِرٍ؛ فأحِلَّ حلالَه، وحَرِّم حرامَه، واعْمَل بمُحْكَمِه، وقِف عند متشابهه، واعْتَبِر أمثالَه، فإنّ كُلًّا مِن عند الله، <q>﴿وما يذكر إلا أولوا الألباب﴾</q>»{111}. (٣/٤٥٦) ١٢٠٢٧- عن عبد الله بن مسعود -من طريق القاسم بن عبد الرحمن- قال: أُنزِل القرآن على خمسة أوجه: حرام، وحلال، ومحكم، ومتشابه، وأمثال؛ فأحِلّ الحلال، وحَرِّم الحرام، وآمِن بالمتشابه، واعْمَل بالمحكم، واعْتَبِر بالأمثال{112}. (٣/٤٥٧) ١٢٠٢٨- عن عبد الله بن عباس، قال: إنّ القرآن ذو شُجُونٍ وفُنُونٍ، وظُهورٍ وبطون، لا تنقضي عجائبُه، ولا تُبْلَغ غايَتُه، فمَن أوْغَلَ فيه برِفْقٍ نَجا، ومَن أوْغَل فيه بعُنفٍ غَوى، أخبارٌ وأمثال، وحرام وحلال، وناسخ ومنسوخ، ومُحْكَم ومتشابه، وظَهْرٌ وبَطْن، فظهره التلاوة، وبطنه التأويل، فجالِسوا به العلماء، وجانِبوا به السفهاء، وإيّاكم وزَلَّةَ العالِم{113}. (٣/٤٥٨) ١٢٠٢٩- عن عبد الله بن عباس -من طريق طاووس- وذُكِر عنده الخوارج، وما يلقون عند الفرار، فقال: يُؤْمِنون بمُحْكَمِه، ويهلكون عند متشابهه. وقرأ ابن عباس: <q>﴿وما يعلم تأويله إلا الله﴾</q> الآية{114}. (ز) ١٢٠٣٠- عن عبد الله بن عباس -من طريق أبي الزِّناد- قال: التفسيرُ على أربعة أوْجُهٍ: وجهٍ تعرفه العرب مِن كلامها، وتفسيرٍ لا يُعْذَر أحدٌ بجهالته، وتفسيرٍ يعلمه العلماء، وتفسيرٍ لا يعلمه إلا الله{115}. (ز) ١٢٠٣١- عن عبد الله بن عباس -من طريق الكلبي، عن أبي صالح- قال: تفسير القرآن على أربعة وجوه: تفسير يعلمه العلماء، وتفسير لا يُعْذَر الناس بجهالته مِن حلال أو حرام، وتفسيرٌ تعرفه العربُ بلغتها، وتفسير لا يعلم تأويلَه إلا الله، مَنِ ادَّعى علمَه فهو كاذب{116}. (٣/٤٦٠) <q>﴿وَٱلرَّ ٰ⁠سِخُونَ فِی ٱلۡعِلۡمِ﴾</q> - تفسير ١٢٠٣٢- عن أنس بن مالك: سُئِل رسول الله ﷺ: مَنِ الراسخون في العلم؟ قال: «مَن صدَق حديثُه، وبَرَّ في يمينه، وعفَّ بطنُه وفرجُه، فذلك الراسخون في العلم»{117}. (٣/٤٦٠) ١٢٠٣٣- عن أنس بن مالك، وأبي أُمامَة، وواثِلة بن الأَسْقَع، وأبي الدرداء: أنّ رسول الله ﷺ سُئِل عن <q>﴿والراسخون في العلم﴾</q>. فقال: «مَن بَرَّت يمينُه، وصَدَق لسانُه، واسْتَقام قلبُه، ومَن عَفَّ بطنُه وفَرْجُه؛ فذلك مِن الراسخين في العلم»{118}. (٣/٤٦٠) ١٢٠٣٤- عن عبد الله بن عباس -من طريق مجاهد- قال: <q>﴿والراسخون في العلم يقولون آمنا به﴾</q>، قال: الراسخون الذين يقولون: آمنا به كُلٌّ مِن عند ربِّنا{119}. (ز) ١٢٠٣٥- عن ابن عباس -من طريق ابن جُرَيْج- قال عبد الله بن سلام: <q>﴿والراسخون في العلم﴾</q> وعِلْمُهم: قولُهم.= (ز) ١٢٠٣٦- قال ابن جُرَيْج: <q>﴿والراسخون في العلم يقولون آمنا به﴾</q>، وهم الذين يقولون: <q>﴿ربنا لا تزغ قلوبنا﴾</q>، ويقولون: <q>﴿ربنا إنك جامع الناس ليوم لا ريب فيه﴾</q> الآية{120}. (ز) ١٢٠٣٧- عن مسروق بن الأَجْدَع -من طريق إبراهيم- قال: لَقِيتُ زيدًا، فوَجَدتُه مِن الراسخين في العلم{121}. (ز) ١٢٠٣٨- قال مُقاتِل بن سليمان: ثُمَّ استأنف، فقال: <q>﴿والراسخون في العلم﴾</q>، يعني: المُتَدارِسُون عِلْمَ التوراة؛ فهم عبدُ الله بنُ سلام وأصحابُه مِن مؤمني أهلِ التوراة{45}. (ز) ١٢٠٣٩- عن مُقاتِل بن حَيّان -من طريق بُكَيْر بن معروف- قوله: <q>﴿والراسخون في العلم﴾</q>: يعني: عبد الله بن سلام وأصحابه مِن مؤمني أهل الكتاب مِن أهل التوراة{121}. (ز) ١٢٠٤٠- عن نافع بن يزيد -من طريق ابن وهْب- قال: يُقال: <q>﴿والراسخون في العلم﴾</q>: المتواضعون [المُتَذَلِّلون] لله في مرضاته، فلا يتعاطون مَن فوقهم، ولا يحقرون مَن دونهم{124}. (ز) <q>﴿وَٱلرَّ ٰ⁠سِخُونَ فِی ٱلۡعِلۡمِ یَقُولُونَ ءَامَنَّا بِهِۦ كُلࣱّ﴾</q> - قراءات ١٢٠٤١- عن الأعمش، قال: في قراءة عبد الله بن مسعود: (وإنْ حَقِيقَةُ تَأْوِيلِهِ عِندَ اللهِ والرّاسِخُونَ فِي العِلْمِ يَقُولُونَ آمَنّا بِهِ){125}. (٣/٤٥٨) ١٢٠٤٢- عن عبد الله بن عباس -من طريق طاووس- أنّه كان يقرؤها: (وما يَعْلَمُ تَأْوِيلَهُ إلّا اللهُ ويَقُولُ الرّاسِخُونَ فِي العِلْمِ آمَنّا بِهِ){126}١١١٤. (٣/٤٥٨) ١١١٤ اختلف القُرّاءُ في الوقف في هذه الآية؛ فمنهم من يقف على قوله: <q>﴿إلا الله﴾</q>. ومنهم مَن يقف عند قوله: <q>﴿والراسخون في العلم﴾</q>. وصَوَّب ابنُ تيمية (٢/٢٥) كليهما، فقال: «وكلتا القراءتين حقٌّ، ويُراد بالأولى المتشابه في نفسه الذي استأثر الله بعلم تأويله، ويُراد بالثانية المتشابه الإضافي الذي يعرف الراسخون تفسيرَه، وهو تأويله. ومثل هذا يقع في القرآن كقوله: <q>﴿وإن كان مكرهم لتزول منه الجبال﴾</q> و›لَتَزُولُ‹، فيه قراءتان مشهورتان بالنفي والإثبات، وكُلُّ قراءةٍ لها معنًى صحيحٌ». <q>﴿وَٱلرَّ ٰ⁠سِخُونَ فِی ٱلۡعِلۡمِ یَقُولُونَ ءَامَنَّا بِهِۦ كُلࣱّ﴾</q> - تفسير الآية ١٢٠٤٣- عن عبد الله بن مسعود، عن النبي ﷺ، قال: «كان الكتابُ الأوَّلُ ينزل من باب واحد على حرف واحد، ونزل القرآنُ من سبعة أبواب على سبعة أحرف: زاجِر، وآمِر، وحلال، وحرام، ومحكم، ومتشابه، وأمثال؛ فأحِلُّوا حلالَه، وحرِّموا حرامَه، وافعلوا ما أُمِرْتُم به، وانتهوا عَمّا نُهِيتُم عنه، واعْتَبِرُوا بأمثالِه، واعْمَلُوا بمُحْكَمِه، وآمنوا بمُتَشابِهه، وقولوا: <q>﴿آمنا به كل من عند ربنا﴾</q>»{127}. (٣/٤٥٦) ١٢٠٤٤- عن عبد الله بن مسعود، موقوفًا{113}. (٣/٤٥٦) ١٢٠٤٥- عن عليٍّ، أنّ النبي ﷺ قال في خُطْبَتِه: «أيُّها الناسُ، قد بَيَّن اللهُ لكم في مُحْكَم كتابه ما أحَلَّ لكم، وما حَرَّم عليكم؛ فأَحِلُّوا حلالَه، وحَرِّموا حرامه، وآمِنوا بمُتَشابِهه، واعْمَلُوا بمُحْكَمِه، واعْتَبِرُوا بأمْثالِه»{129}. (٣/٤٥٦-٤٥٧) ١٢٠٤٦- عن عائشة -من طريق ابن أبي مُلَيْكَة- أنّه قرأ عليها هؤلاء الآيات، فقالَتْ: كان رسوخُهم في العلم أنْ آمَنُوا بمُحْكَمه ومتشابهه، <q>﴿وما يعلم تأويله إلا الله﴾</q> ولم يعلموا تأويلَه{130}. (٣/٤٥٨) ١٢٠٤٧- عن عبد الله بن عباس -من طريق العوفي-: <q>﴿يقولون آمنا به﴾</q>؛ نؤمن بالمُحْكَم ونَدِين به، ونُؤْمِنُ بالمتشابه ولا ندين به، وهو مِن عند الله كُلِّه{131}. (٣/٤٦١) ١٢٠٤٨- عن عبد الله بن عباس -من طريق مجاهد- قال: أنا مِمَّن يعلم تأويلَه{132}١١١٥. (٣/٤٦١) ١١١٥ ورَدَ عن ابن عباس تارَةً أنّ الراسخين لهم عِلْمٌ بالمتشابه، وأخرى تُفِيد عدمَ علمهم. وذَكَر ابنُ عطية (٢/١٦٢) أنّ إعراب الراسخين يحتمل الوجهين؛ ولذلك قال ابنُ عباس بهما. وعَلَّق ابنُ تيمية (٢/١٥ بتصرف) على ورود القولين عن ابن عباس بقوله: «وكِلا القولين حقٌّ باعتبار؛ ولهذا نُقِل عن ابن عباس هذا وهذا، وكلاهما حقٌّ». ١٢٠٤٩- عن عبد الله بن عباس -من طريق مجاهد- <q>﴿يقولون آمنا به﴾</q>: يعني: ما نُسِخ، وما لم يُنسَخ{121}. (ز) ١٢٠٥٠- وعن عائشة، نحو ذلك{134}. (ز) ١٢٠٥١- عن أبي الشَّعْثاء جابر بن زيد= (ز) ١٢٠٥٢- وأبي نَهِيكٍ، قالا: إنّكم تَصِلُون هذه الآيةَ، وهي مقطوعةٌ: <q>﴿وما يعلم تأويله إلا الله والراسخون في العلم يقولون آمنا به كل من عند ربنا﴾</q>، فانتهى علمُهم إلى قولهم الذي قالوا{135}. (٣/٤٥٩) ١٢٠٥٣- عن عروة بن الزبير -من طريق هشام بن عُرْوَة- قال: <q>﴿الراسخون في العلم﴾</q> لا يعلمون تأويله، ولكنَّهم يقولون: <q>﴿آمنا به كل من عند ربنا﴾</q>{136}. (٣/٤٥٩) ١٢٠٥٤- عن عمر بن عبد العزيز -من طريق عمرو بن عثمان- قال: انتهى عِلْمُ الراسخين في العلم بتأويل القرآن إلى أن قالوا: <q>﴿آمنا به كل من عند ربنا﴾</q>{137}١١١٦. (٣/٤٥٩) ١١١٦ ذكر ابنُ جرير (٥/٢٢١) أنّ مَن قال بهذا القول الذي قال به ابن عباس من طريق طاووس، وعائشة، وعروة، وعمر بن عبد العزيز، ومالك، وأبي نهيك الأسدي؛ فإنَّه يرفع <q>﴿والراسخون في العلم﴾</q> بالابتداء في قول البصريين، ويجعل خبره <q>﴿يقولون آمنا به﴾</q>. وأمّا في قول بعض الكوفيين فبالعائِد من ذكرهم في <q>﴿يقولون﴾</q>، وفي قول بعضهم بجملة الخبر عنهم، وهي: <q>﴿يقولون﴾</q>. ١٢٠٥٥- عن مجاهد بن جبر -من طريق ابن أبي نَجِيح- قال: <q>﴿والراسخون في العلم﴾</q> يعلمون تأويله، و<q>﴿يقولون آمنا به﴾</q>{138}. (٣/٤٦٦) ١٢٠٥٦- عن الضَّحّاك بن مُزاحِم -من طريق أبي مُصْلِح- <q>﴿وما يعلم تأويله إلا الله والراسخون في العلم﴾</q>، يقول: الرّاسِخُون يعلمون تأويلَه، لو لم يعلموا تأويلَه لم يعلموا ناسِخَه مِن منسوخه، ولم يعلموا حلالَه مِن حرامه، ولا محكمَه مِن متشابهه{139}. (ز) ١٢٠٥٧- عن الضَّحّاك بن مُزاحِم -من طريق جُوَيْبِر- في قوله: <q>﴿والراسخون في العلم﴾</q>: يعملون به، يقولون: نعمل بالمُحْكَم ونؤمن به، ونُؤْمِن بالمتشابه ولا نعمل به، وكُلٌّ مِن عندِ ربنا{140}. (ز) ١٢٠٥٨- عن قتادة بن دِعامة -من طريق شَيْبان- <q>﴿يقولون آمنا به﴾</q>، قال: آمنوا بمتشابهه، وعملوا بمُحْكَمِه، فأحلُّوا حلالَه، وحرَّموا حرامَه{141}. (ز) ١٢٠٥٩- عن إسماعيل السُّدِّيِّ -من طريق أسباط- <q>﴿والراسخون في العلم﴾</q> قال: هم المؤمنون؛ فإنّهم <q>﴿يقولون آمنا به﴾</q> بناسخه ومنسوخه، <q>﴿كل من عند ربنا﴾</q>{142}. (ز) ١٢٠٦٠- عن الربيع بن أنس -من طريق أبي جعفر- قال: <q>﴿والراسخون في العلم﴾</q> يعلمون تأويله، و<q>﴿يقولون آمنا به﴾</q>{143}١١١٧. (٣/٤٦١) ١١١٧ ذَكَرَ ابنُ جرير (٥/٢٢١) أنّ مَن قال بهذا القول الذي قال به ابن عباس من طريق مجاهد، والربيع، وابن الزبير؛ فإنّه عطف بـ«الراسخين» على اسم «الله»، فرفعهم بالعطف عليه. ١٢٠٦١- عن محمد بن جعفر بن الزبير -من طريق ابن إسحاق- قال: <q>﴿وما يعلم تأويله﴾</q> الذي أراد ما أراد <q>﴿إلا الله والراسخون في العلم يقولون آمنا به﴾</q>، فكيف يخْتَلِفُ وهو قولٌ واحد مِن رَبٍّ واحد؟! ثُمَّ رَدُّوا تأويلَ المتشابه على ما عرفوا مِن تأويل المُحْكَمَةِ التي لا تأويل لأحدٍ فيها إلا تأويل واحد، فاتَّسق بقولهم الكتابُ، وصَدَّق بعضُه بعضًا، فنَفَذَتْ به الحُجَّة، وظهر به العُذْر، وزاح به الباطل، ودَمَغ به الكفر{144}. (ز) ١٢٠٦٢- عن محمد بن إسحاق -من طريق ابن إدريس- قوله: <q>﴿والراسخون في العلم يقولون آمنا به﴾</q>، قال: لم تكن معرفتهم إيّاه أن يفقهوه على الشَّكِّ، ولكنهم خَلَصَت{145} الأعمالُ منهم، ونفذ عِلْمُهم أن عرفوا الله بعدله؛ لم يكن لِيَخْتَلِف شيءٌ مِمّا جاء منه، فرَدُّوا المتشابه على المُحْكَم، فقالوا: <q>﴿كل من عند ربنا﴾</q>{146}. (ز) ١٢٠٦٣- قال مقاتل بن سليمان: <q>﴿يقولون آمنا به كل من عند ربنا﴾</q>، يعني: قليله وكثيره مِن عند ربنا{45}. (ز) ١٢٠٦٤- عن مالك بن أنس -من طريق أشْهَب- في قوله: <q>﴿وما يعلم تأويله إلا الله﴾</q>، قال: ثُمَّ ابتدأ فقال: <q>﴿والراسخون في العلم يقولون آمنا به﴾</q>، وليس يعلمون تأويلَه{148}١١١٨. (٣/٤٦٠) ١١١٨ اختُلِف في كلمة <q>﴿الراسخون﴾</q>؛ أهِي مُسْتَأْنَفَةٌ، أم معطوفة. ورَجَّح ابنُ جرير (٥/٢٢١-٢٢٢) القولَ الأوّل الذي قال به ابن عباس من طريق طاووس، وعائشة، وعروة، وعمر بن عبد العزيز، ومالك، وأبو نهيك الأسدي مُسْتَنِدًا إلى القراءات، ودلالة العقل، وعلّل ذلك بأنّ الراسخين لا يعلمون تأويل المتشابه الذي ذكره الله ﷿ في هذه الآية، ولِمُوافقتِه لِما بَلَغَهُ مِن قراءة أُبَيٍّ وابن عباس: (ويَقُولُ الرّاسِخُونَ فِي العِلْمِ)، وقراءة عبد الله: (إن تَأْوِيلُهُ إلّا عِندَ اللهِ والرّاسِخُونَ فِي العِلْمِ يَقُولُونَ). ورأى ابنُ عطية (٥/١٦١-١٦٢) قُرْبَ الخلاف بين القولين، فذكر أنّ المحكم هو المُتَّضِحُ المعنى لِكُلِّ مَن يفهم كلام العرب، والمُتشابِهُ يَتَنَوَّعُ؛ فمِنه ما لا يُعْلَمُ البَتَّةَ كأمر الروح، ومنه ما يُحْمَل على وجوهٍ في اللغة ويَحتاج إلى إزالةِ ما يعلق به من لَبْسٍ. فإن جعلنا <q>﴿والراسخون﴾</q> معطوفة على اسم الله؛ فالمعنى: إدخالهم في علم التأويل لا على الكمال، فذلك ليس إلا لله، بل علمُهم إنّما هو في النوع الثاني من المتشابه، وإن جعلنا قوله: <q>﴿والرّاسِخُونَ﴾</q> رفعًا بالابتداء مقطوعًا مما قبله؛ فتسميتُهم راسخين يقتضي بأنّهم يعلمون أكثر من المحكم الذي يستوي في علمه جميعُ مَن يفهم كلام العرب. وكذا رأى ابنُ تيمية (٢/١٩) عدمَ المنافاة بين القولين، فقال: «إنّ السلف كان أكثرهم يقفون عند قوله: <q>﴿وما يَعْلَمُ تَأْوِيلَهُ إلا اللَّهُ﴾</q>، بناءً على أنّ التأويل الذي هو الحقيقة التي استأثر الله بعلمها لا يعلمها إلا هو، وطائفة منهم كمجاهد وابن قتيبة وغيرهما قالوا: بل الراسخون يعلمون التأويل. ومرادهم بالتأويل المعنى الثاني، وهو: التفسير. فليس بين القولين تناقُضٌ في المعنى». <q>﴿كُلࣱّ مِّنۡ عِندِ رَبِّنَاۗ﴾</q> - تفسير ١٢٠٦٥- عن عبد الله بن عباس -من طريق مجاهد- <q>﴿كل من عند ربّنا﴾</q>: يعني: ما نُسِخ منه، وما لم يُنسَخ{149}. (٣/٤٦٢) ١٢٠٦٦- عن قتادة بن دِعامة -من طريق سعيد- قوله: <q>﴿وما يعلم تأويله إلا الله﴾</q> والراسخون في العلم قالوا: <q>﴿كل من عند ربنا﴾</q> آمنوا بمتشابهه، وعملوا بمُحْكَمه{150}. (ز) ١٢٠٦٧- عن الربيع بن أنس -من طريق أبي جعفر- في قوله: <q>﴿كل من عند ربنا﴾</q>: يقولون: المُحْكَم والمُتشابه مِن عند ربِّنا{151}. (ز) ١٢٠٦٨- عن محمد بن جعفر بن الزُّبَيْر -من طريق ابن إسحاق- قال: ثم رَدُّوا تأويلَ المتشابه على ما عرفوا مِن تأويل المُحْكَمَةِ التي لا تأويلَ لأحدٍ فيها إلا تأويلٌ واحد؛ فاتَّسَقَ بقولهم الكتابُ، وصَدَّقَ بعضُه بعضًا، فنَفَذَتْ به الحُجَّةُ، وظهر به العُذْرُ، وزاح به الباطل، ودُمِغَ به الكُفْرُ{144}. (ز) ١٢٠٦٩- عن محمد بن إسحاق -من طريق سلمة-، مثله{153}. (ز) <q>﴿وَمَا یَذَّكَّرُ إِلَّاۤ أُو۟لُوا۟ ٱلۡأَلۡبَـٰبِ ۝٧﴾</q> - تفسير ١٢٠٧٠- عن محمد بن جعفر بن الزُّبَيْر -من طريق ابن إسحاق- <q>﴿وما يذّكر إلا أولو الألباب﴾</q>، يقول: وما يذَّكَّرُ في مثل هذا -يعني: في رَدِّ تأويل المتشابه إلى ما قد عُرِفَ مِن تأويل المُحْكَمِ حتى يَتَّسِقا على معنًى واحد- إلا أولو الألبابِ{154}١١١٩. (ز) ١١١٩ لم يذكر ابنُ جرير (٥/٢٢٧) غيرَ هذا القول. ١٢٠٧١- عن مقاتل بن حيّان -من طريق بُكَيْر بن معروف- قوله: <q>﴿وما يذكر إلا أولوا الألباب﴾</q>: إلا كُلُّ ذِي لُبٍّ{155}. (ز) ١٢٠٧٢- قال مقاتل بن سليمان: <q>﴿وما يذكر إلا أولوا الألباب﴾</q>، فما يَسْمَعُ إلا أولو الألباب، يعني: مَن كان له لُبٌّ وعَقْلٌ، يعني: ابن سلام وأصحابه، فيعلمون أنّ كُلَّ شيء مِن هذا وغيره مِن عند الله{45}. (ز) <q>﴿وَمَا یَذَّكَّرُ إِلَّاۤ أُو۟لُوا۟ ٱلۡأَلۡبَـٰبِ ۝٧﴾</q> - آثار متعلقة بالآية ١٢٠٧٣- عن أبي هريرة، قال: قال رسول الله ﷺ: «الجِدالُ في القرآن كُفْرٌ»{157}. (٣/٤٦٥) ١٢٠٧٤- عن ابن عمرو: أنّ رسول الله ﷺ خَرَجَ على أصحابه وهم يَتَنازَعُون في القرآن، هذا يَنزِعُ{158} بآية، وهذا يَنزِعُ بآية؛ فكأنّما فُقِئَ في وجْهِه حَبُّ الرُّمّان، فقال: «ألِهَذا خُلِقْتُم؟! أو لِهَذا أُمِرْتُم؟! أن تضربوا كتابَ الله بعضَه ببعض؟! انظروا ما أُمِرْتُم به فاتَّبِعُوه، وما نُهِيتُم عنه فانتهوا»{159}. (٣/٤٦٤-٤٦٥) ١٢٠٧٥- عن عبد الله بن عمرو، قال: خرج رسول الله ﷺ ومِن وراء حُجْرَتِه قومٌ يتجادلون في القرآن؛ فخَرَجَ مُحْمَرَّةً وجْنَتاه، كأنّما تَقْطُرانِ دمًا، فقال: «يا قوم، لا تُجادِلوا بالقرآن؛ فإنّما ضَلَّ مَن كان قبلكم بجدالهم. إنّ القرآن لم ينزل لِيُكَذِّبَ بعضُه بعضًا، ولكن نزل لِيُصَدِّق بعضُه بعضًا، فما كان مِن مُحْكَمِه فاعملوا به، وما كان مِن متشابهه فآمِنوا به»{160}. (٣/٤٦٥) ١٢٠٧٦- عن عمر بن الخطاب، قال: إنّه سيأتيكم ناسٌ يُجادِلُونكم بشُبُهاتِ القُرآن، فخُذُوهم بالسُّنَنِ؛ فإنّ أصحاب السُّنَنِ أعلمُ بكتاب الله{161}. (٣/٤٦٤) ١٢٠٧٧- عن عمر بن الخطاب -من طريق السّائِب بن يزيد- أنّ رجلًا قال لعمر: إنِّي مررتُ برجلٍ يسألُ عن تفسير مُشْكِل القرآن. فقال عمر: اللَّهُمَّ، أمْكِنِّي مِنهُ. فدخل الرجلُ يومًا على عمر، فسأله، فقام عمرُ، فحَسَر عن ذِراعَيْه، وجعل يَجْلِدُه، ثم قال: ألْبِسُوه تُبّانًا{162}، واحمِلوه على قَتَبٍ{163}، وابلُغُوا به حَيَّهُ، ثم لْيَقُم خطيبٌ فلْيَقُلْ: إنّ صَبِيغًا طَلَبَ العِلْمَ فأخطأه. فلم يزل وضيعًا في قومه بعد أن كان سيِّدًا فيهم{164}. (٣/٤٦٣) ١٢٠٧٨- عن عمر بن الخطاب -من طريق سليمان بن يسار-: أنّ رجلًا يُقال له: صَبِيغ؛ قَدِم المدينة، فجعل يسأل عن مُتَشابِهِ القُرْآن، فأرسل إليه عمرُ وقد أعَدَّ له عَراجِينَ النَّخْلِ، فقال: مَن أنت؟ فقال: أنا عبدُ الله صَبِيغٌ. فقال: وأنا عبدُ الله عُمرُ. فأخذ عمرُ عُرْجُونًا مِن تِلْك العَراجِين، فضربه حتى دَمّى رأسَه، فقال: يا أمير المؤمنين، حسبُك؛ قد ذهب الذي كنتُ أجِدُ في رأسي{165}. (٣/٤٦٢) ١٢٠٧٩- عن محمد بن سيرين، قال: كتب عمر بن الخطاب إلى أبي موسى الأشعري: أن لا يجالِس صَبِيغًا، وأن يُحرَم عطاءَه ورزقَه{166}. (٣/٤٦٣) ١٢٠٨٠- عن معاذ بن جبل، قال: القرآنُ منارٌ كمنارِ الطريق، ولا يخفى على أحد، فما عرفتم منه فلا تسألوا عنه أحدًا، وما شككتم فيه فكِلوه إلى عالمه{167}. (٣/٤٥٩-٤٦٠) ١٢٠٨١- عن أُبَيِّ بن كعب -من طريق عبد الرحمن بن أبزى- قال: كتابُ الله ما استبان منه فاعمل به، وما اشتبه عليك فآمِن به، وكِلْه إلى عالمه{167}. (٣/٤٥٩) ١٢٠٨٢- عن عبد الله بن مسعود، قال: إنّ للقرآن منارًا كمنار الطريق، فما عرفتم فتمسكوا به، وما اشتبه عليكم فذَرُوه{167}. (٣/٤٥٩) ١٢٠٨٣- عن عبد الله بن عباس -من طريق عكرمة- قال: كلَّ القرآن أعْلَمُ تأويله إلا أربعًا: <q>﴿غسلين﴾</q> [الحاقة:٣٦]، <q>﴿وحنانًا﴾</q> [مريم:١٣]، والأواه، <q>﴿والرقيم﴾</q> [الكهف:٩]{170}. (ز) ",footnotes:1:عند ابن جرير: أُكْلُ.أخرجه ابن إسحاق -كما في سيرة ابن هشام ١/٥٤٥-٥٤٦-، والبخاري في التاريخ الكبير ٢/٢٠٨ (٢٢٠٩)، وابن جرير ١/٢٢١-٢٢٢. قال ابنُ كثير في تفسيره ١/١٦٢: «فهذا مداره على محمد بن السائب الكلبي، وهو ممن لا يُحْتَجُّ بما انفرد به». وقال السيوطي في الدر ١/١٢٤: «بسند ضعيف».عزاه السيوطي إلى يونس بن بكير في المغازي.أخرجه ابن المنذر (٢٠٠)، ووصفه السيوطي بأنه مِن وجهٍ آخرَ مُعْضلًا.أخرجه ابن جرير ٥/٢٠٥-٢٠٦، وابن أبي حاتم ٢/٥٩٦ (٣١٨٧) مرسلًا.أخرجه ابن أبي داود في المصاحف ص١٨.أخرجه ابن أبي حاتم ٢/٥٩١.أخرجه سعيد بن منصور (٤٩٣ - تفسير)، وابن أبي حاتم ٢/٥٩٢ (٣١٦٨)، والحاكم ٢/٢٨٨. وعزاه السيوطي إلى ابن مردويه.أخرجه ابن جرير ٥/١٩٣، وابن المنذر (٢٢١)، وابن أبي حاتم ٢/٥٩٢. وعزاه السيوطي إلى عبد بن حميد.علَّقه ابن أبي حاتم ٢/٥٩٢.عزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ٥/١٩٤.أخرجه ابن جرير ٥/١٩٣، وابن المنذر (٢١٧)، وابن أبي حاتم ٢/٥٩٣ (٣١٦٧، ٣١٧٤).أخرجه ابن جرير ٥/١٩٣-١٩٤.أخرجه ابن جرير ٥/١٩٣.أخرجه ابن جرير ٥/١٩٦. وعزاه السيوطي إلى عَبد بن حُمَيد، والفريابي.أخرجه ابن جرير ٥/١٩٥، وابن المنذر ١/١١٧، وعبد بن حميد كما في قطعة من تفسيره ص٢٠.أخرجه الثوري في تفسيره ص٧٥، وعبد بن حميد كما في قطعة من تفسيره ص٢٠، وابن جرير ٥/١٩٥.تفسير البغوي ٢/٨.علَّقه ابن أبي حاتم ٢/٥٩٢.أخرجه عبد الرزاق ١/١١٥، وابن جرير ٥/١٩٤.أخرجه ابن جرير ٥/١٩٤، وابن المنذر ١/١١٧-١١٨ بعضَه.أخرجه ابن أبي حاتم ٢/٥٩٣.أخرجه ابن جرير ٥/١٩٥.أخرجه ابن جرير ٥/١٩٧، وابن أبي حاتم ٢/٥٩١.أخرجه ابن أبي حاتم ٢/٥٩٢.تفسير مقاتل بن سليمان ١/٢٦٣.أخرجه ابن جرير ٥/١٩٧-١٩٨.أخرجه ابن أبي حاتم ٢/٥٩٣ (٣١٧٣).ذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ١/٢٧٥-.أخرجه ابن جرير ١٣/٥٧١.أخرجه ابن جرير ٥/٢٠١، وابن أبي حاتم ٢/٥٩٢. وعزاه السيوطي إلى عبد بن حميد، وابن الضُّرَيس.تفسير مقاتل بن سليمان ١/٢٦٣-٢٦٤.أخرجه ابن أبي حاتم ٢/٥٩٣، ٥٩٤ (٣١٧٣، ٣١٧٦).أخرجه ابن جرير ٥/٢٠١-٢٠٢.أخرجه ابن جرير ٥/١٩٣، وابن المنذر (٢١٧)، وابن أبي حاتم ٢/٥٩٣ (٣١٦٧، ٣١٧٤).أخرجه ابن جرير ٥/١٩٣-١٩٤.تفسير البغوي ٢/٩، وتفسير الثعلبي ٣/١١. وتمام الأثر سبق في سبب النزول.أخرجه ابن جرير ٥/١٩٤.أخرجه ابن المنذر (٢٢٨).أخرجه ابن أبي حاتم ٢/٥٩٣.أخرجه ابن جرير ٥/١٩٥، وأخرجه الثوري في تفسيره ص٧٥ دون قول: وتُرك يُتلى، وعبد بن حميد كما في قطعة من تفسيره ص٢٠، وابن المنذر ١/١٢٠. وعلَّقه ابن أبي حاتم ٢/٥٩٣. كما أخرج ابن جرير ٥/١٩٥ نحوه من طريق سلمة بن نُبَيْط.أخرجه ابن المنذر ١/١٢٠، وعبد بن حميد كما في قطعة من تفسيره ص٢١. وعلّقه ابن أبي حاتم ٢/٥٩٣.أخرجه ابن جرير ٥/١٩٥. وعلّقه ابن أبي حاتم ٢/٥٩٣.تفسير مقاتل بن سليمان ١/٢٦٤.أخرجه ابن أبي حاتم ٢/٥٩٤.أخرجه ابن أبي حاتم ٢/٥٩٤.أخرجه ابن المنذر ١/١٢٠، وابن أبي حاتم ٢/٥٩٤ من طريق سلمة.ذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ١/٢٧٥-.أخرجه ابن جرير ٥/٢٠٥ مرسلًا.أخرجه أحمد ٣٦/٥٩٤ (٢٢٢٥٩) واللفظ له، وابن أبي حاتم ٢/٥٩٤ (٣١٧٩). وفي إسناده أبو غالب البصري الراوي عن أبي أمامة، وهو مختلف فيه، قال ابن حجر في التقريب (٨٣٦٢): «صدوق يخطئ».أخرجه ابن جرير ٥/٢٠٣.أخرجه ابن جرير ٥/٢٠٣-٢٠٤، وابن المنذر ١/١٢٢، وابن أبي حاتم ٢/٥٩٥.أخرجه الهروي في ذمِّ الكلام وأهله ٢/٦٣.أخرجه ابن جرير ٥/٢٠٣، وابن المنذر ١/١٢٢. وعلّقه ابن أبي حاتم ٢/٥٩٥.عزاه السيوطي إلى عَبد بن حُمَيد.الحرورية: هم فرقة الخوارج، وسمُّوا بهذا الاسم لأنهم بعد خروجهم على عليٍّ ﵁ ورفضهم التحكيم، نزلوا بموضع قرب الكوفة يقال له: حروراء. ينظر: مقالات الإسلاميّين ١/٢٠٧، ومعجم البلدان ٢/٣٣٦.السبائية: إحدى فرق الشيعة الغالية، وهي تنتسب إلى عبد الله بن سبأ، ومن جهالاتهم زعمهم أنّ عليًا لم يمت وأنه يرجع إلى الدنيا قبل يوم القيامة فيملأُ الأرض عدلًا كما ملئت جورًا. ينظر: مقالات الإسلاميين ١/٨٦، والملل والنحل ١/٣٦٥.ألاص الأمر: حرّكه وأداره لينتزعه. لسان العرب (لوص).أخرجه عبد الرزاق ١/١١٥-١١٦، وابن جرير ٥/٢٠٧-٢٠٨ واللفظ له.علَّقه ابن أبي حاتم ٢/٥٩٥.أخرجه ابن جرير ٥/٢٠٢-٢٠٣.تفسير البغوي ٢/٩، وتفسير الثعلبي ٣/١٢.تفسير مقاتل بن سليمان ١/٢٦٤.أخرجه ابن أبي حاتم ٢/٥٩٥، وابن المنذر ١/١٢٣ من طريق إسحاق.علَّقه ابن جرير ٥/٢٠٤.أخرجه ابن أبي حاتم ٢/٥٩٥، وابن المنذر ١/١٢٣ من طريق زياد.أخرجه أحمد ٤٠/٢٥٥ (٢٤٢١٠)، وابن ماجه ١/٣٢ (٤٧)، وابن حبان ١/٢٧٧ (٧٦)، وعبد الرزاق في تفسيره ١/٣٨٤ (٣٧٦)، وابن جرير ٥/٢٠٨، ٢٠٩، ٢١١.الدقل: رديء التمر ويابسه. مادة (دقل).أخرجه أبو يعلى -كما عند البوصيري في إتحاف الخيرة ٦/٣٤٥ (٥٩٩٠)-. قال البوصيري: «هذا إسناد رواته ثقات، وأبو موسى هو محمد بن المثنى البصري».أخرجه ابن جرير ٥/٢٠٤، وابن أبي حاتم ٢/٥٩٥.أخرجه ابن المنذر ١/١٢٧.أخرجه ابن جرير ٥/٢٠٥. وعزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ٥/٢٠٥، وابن أبي حاتم ٢/٥٩٦.أخرجه ابن جرير ٥/٢٠٤.أخرجه ابن المنذر ١/١٢٨، وابن أبي حاتم ٢/٥٩٦ مختصرًا من طريق سلمة.أخرجه ابن جرير ٥/٢٠٥، ٢١٣ واللفظ له، وابن المنذر ١/١٢٨، وابن أبي حاتم ٢/٥٩٦. وعزاه السيوطي إلى عبد بن حميد.أخرجه الحربيُّ في غريب الحديث ٣/٩٣١. وذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ١/٢٧٥- بلفظ: طلب الضلالة.أخرجه ابن جرير ٥/٢١٢، وابن أبي حاتم ٢/٥٩٦.أخرجه ابن جرير ٥/٢١٢. وعلّقه ابن أبي حاتم ٢/٥٩٦.علَّقه ابن أبي حاتم ٢/٥٩٦.أخرجه ابن جرير ٥/٢١٣.أخرجه ابن المنذر ١/١٢٨، وابن أبي حاتم ٢/٥٩٧ من طريق سلمة.تفسير مقاتل بن سليمان ١/٢٦٤.أخرجه ابن أبي حاتم ٢/٥٩٧.أخرجه ابن جرير ٥/٢٠٨.أخرجه ابن جرير ٥/٢١٦، وابن أبي حاتم ٢/٥٩٧.أخرجه ابن جرير ٥/٢١٦.تفسير مقاتل بن سليمان ١/٢٦٤.أخرجه ابن أبي حاتم ٢/٥٩٧.أخرجه ابن المنذر ١/١٢٩.أخرجه ابن أبي حاتم ٢/٥٩٧.أخرجه ابن جرير ١/٧٠. قال ابن جرير: «خبر في إسناده نظر». وقال ابن كثير في تفسيره ١/١٥: «والنظر الذي أشار إليه في إسناده هو من جهة محمد بن السائب الكلبي؛ فإنه متروك الحديث؛ لكن قد يكون إنّما وهِم في رفعه، ولعله من كلام ابن عباس، كما تقدم». وقال الألباني في الضعيفة ١٣/٣٧١ (٦١٦٣): «ضعيف جِدًّا».أخرجه ابن جرير ٥/٢١٥، وابن المنذر ١/١٢٩، وابن أبي حاتم ٢/٥٩٧.أخرجه ابن المنذر ١/١٢٩.أخرجه ابن أبي حاتم ٢/٥٩٨.أخرجه عبد الله بن وهب في الجامع ١/٦٤ (١٤٢)، وابن جرير ٥/٢١٩.أخرجه ابن أبي حاتم ٢/٥٩٨.أخرجه ابن أبي حاتم ٢/٥٩٨.أخرجه ابن جرير ٥/٢١٦، وابن أبي حاتم ٢/٥٩٨.تفسير مقاتل بن سليمان ١/٢٦٤.أخرجه ابن أبي حاتم ٢/٥٩٨.أخرجه ابن أبي حاتم ٢/٥٩٨.أخرجه ابن أبي حاتم ٢/٥٩٨.أخرجه الطبراني في الكبير ٣/٢٩٣ (٣٤٤٢). قال ابن كثير في تفسيره ٢/١١: «غريب جِدًّا». وقال الهيثمي في المجمع ١/١٢٧-١٢٨ (٥٣٤): «فيه محمد بن إسماعيل بن عياش عن أبيه، ولم يسمع من أبيه». وقال الألباني في الضعيفة ١٢/٢٣٩ (٥٦٠٧): «ضعيف».أخرجه أحمد ١٣/٣٦٩ (٧٩٨٩)، وابن جرير ١/٢١. قال الهيثمي في المجمع ٧/١٥١ (١١٥٧٥): «رواه كله أحمد بإسنادين، ورجال أحدهما رجال الصحيح». وقال الألباني في الصحيحة ٤/٢٧ (١٥٢٢): «قلت: وسنده صحيح، على شرط الشيخين، وصحّحه ابن حبان، وقد تابعه على الجملة الثانية منه محمد بن عمرو الليثي، حدثنا أبو سلمة عن أبي هريرة به».أخرجه البيهقي في الشعب ٣/٥٤٨ (٢٠٩٥). قال الألباني في الضعيفة ٣/٥٢٣ (١٣٤٦): «ضعيف جِدًّا».أخرجه ابن سعد ٤/١٤٦، وابن أبي عاصم في الآحاد والمثاني ٢/١٠٩ (٨١٢). قال الألباني في الصحيحة ٤/٢٨: «بسند حسن».يتدارأون: أي: يختلفون ويتدافعون في الخصومة. مادة (درأ).أخرجه أحمد ١١/٣٥٣-٣٥٤ (٦٧٤١).أخرجه الطبراني في الكبير ٩/٢٦ (٨٢٩٦)، والشجري في ترتيب الأمالي ١/١١٥ (٤٤١). قال الهيثمي في المجمع ٧/١٥٣ (١١٥٨٣): «رواه الطبراني، وفيه عمار بن مطر، وهو ضعيف جِدًّا، وقد وثّقه بعضهم».أخرجه ابن الضريس (١٢٩)، وابن جرير ١/٦٤، وابن المنذر (٢٦١).عزاه السيوطي إلى ابن أبي حاتم.أخرجه ابن جرير ٥/٢١٤.أخرجه ابن جرير ١/٧٠.أخرجه ابن جرير ١/٧٠، وابن المنذر ١/١٣١. وعزاه السيوطي إلى ابن الأنباري في كتاب الوقف.أخرجه ابن عساكر في تاريخه ٥٥/١٩٥-١٩٦ (٦٩٦١). إسناده ضعيف جِدًّا؛ فيه عبد الله بن يزيد بن آدم، قال عنه الذهبي في الميزان ٢/٥٢٦: «قال أحمد: أحاديثه موضوعة. وقال الجوزجاني: أحاديثه منكرة».أخرجه الطبراني في الكبير ٨/١٥٢ (٧٦٥٨)، والشجري في الأمالي ١/٧٨ (٢٩٢) كلاهما بدون: «واستقام قلبه»، وابن جرير ٥/٢٢٣ عن أبي الدرداء وأبي أمامة، وابن أبي حاتم ٢/٥٩٩ (٣٢٠٥)، ٤/١١١٦ (٦٢٦٨). وأورده الثعلبي ٣/١٥-١٦. قال الهيثمي في المجمع ٦/٣٢٤ (١٠٨٨٧): «رواه الطبراني، وعبد الله بن يزيد ضعيف».أخرجه ابن جرير ٥/٢٢٤.أخرجه ابن جرير ٥/٢٢٤-٢٢٥.أخرجه ابن أبي حاتم ٢/٦٠٠.تفسير مقاتل بن سليمان ١/٢٦٤.أخرجه ابن أبي حاتم ٢/٦٠٠.أخرجه ابن المنذر ١/١٣٣-١٣٤.أخرجه ابن أبي داود في المصاحف ص٥٩. وهي قراءة شاذّة. ينظر: البحر المحيط ٢/٤٠١.أخرجه عبد الرزاق في تفسيره ١/١١٦، وابن جرير ٥/٢١٨، وابن المنذر (٢٥٤)، وابن الأنباري في كتاب الأضداد ص٤٢٦، والحاكم ٢/٢٨٩. وعزاه السيوطي إلى عبد بن حميد. وهي قراءة شاذّة. ينظر: البحر المحيط ٢/٤٠١.أخرجه ابن حبان ٣/٢٠ (٧٤٥)، والحاكم ١/٧٣٩ (٢٠٣١)، ٢/٣١٧ (٣١٤٤)، وابن جرير ١/٦٢-٦٣. قال الحاكم: «هذا حديث صحيح الإسناد، ولم يخرجاه». وقال الذهبي في التلخيص: «منقطع». وقال الطحاوي في مشكل الآثار ٨/١١٥ (٣١٠٣): «كان أهل العلم بالأسانيد يدفعون هذا الحديث؛ لانقطاعه في إسناده، ولأنّ أبا سلمة لا يَتَهَيَّأ في سِنِّه لقاءُ عبد الله بن مسعود، ولا أخذُه إيّاه عنه». وقال ابن حجر في الفتح ٩/٢٩: «قال ابن عبد البر: هذا حديث لا يثبت؛ لأنّه من رواية أبي سلمة بن عبد الرحمن عن ابن مسعود، ولم يَلْقَ ابنَ مسعود، وقد رَدَّه قومٌ مِن أهل النظر؛ منهم أبو جعفر أحمد بن أبي عمران. قلتُ: وأطنب الطبريُّ في مقدّمة تفسيره في الرَّدِّ على مَن قال به، وحاصله: أنّه يستحيل أن يجتمع في الحرف الواحد هذه الأوجه السبعة، وقد صحّح الحديثَ المذكور ابنُ حبان، والحاكمُ، وفي تصحيحه نظر؛ لانقطاعه بين أبي سلمة وابن مسعود، وقد أخرجه البيهقي مِن وجهٍ آخر عن الزهري عن أبي سلمة مرسلًا، وقال: هذا مرسل جيد». وحسّنه الألباني في الصحيحة ٢/١٣٤ (٥٨٧).عزاه السيوطي إلى ابن أبي حاتم.عزاه السيوطي إلى ابن النجار في تاريخ بغداد. قال السيوطي: «سندٌ واهٍ».أخرجه ابن جرير ٥/٢١٨، وابن المنذر ١/١٣١، ١٣٣ (٢٥٦)، وابن أبي حاتم ٢/٥٩٩ (٣٢٠٨).أخرجه ابن جرير ٥/٢٢٦، وابن أبي حاتم ٢/٦٠١ (٣٢١٧).أخرجه ابن جرير ٥/٢٢٠، وابن المنذر (٢٥٨)، وابن الأنباري في الأضداد ص٤٢٤.أخرجه ابن أبي حاتم ٢/٦٠٠.علَّقه ابن أبي حاتم ٢/٦٠٠.أخرجه ابن جرير ٥/٢١٩ عن أبي نَهِيك فقط من طريق عبيد الله، وابن أبي حاتم ٢/٥٩٩ (٣٢٠٦).أخرجه ابن جرير ٥/٢١٨-٢١٩، وابن أبي حاتم ٢/٥٩٩.أخرجه ابن جرير ٥/٢١٩. وعزاه السيوطي إلى عبد بن حميد.أخرجه عبد بن حميد -كما في الفتح للحافظ ابن حجر ٨/٢١٠-، وابن جرير ٥/٢٢٠، وابن الأنباري في كتاب الأضداد ص٤٢٤.أخرجه ابن أبي حاتم ٢/٥٩٩.أخرجه ابن جرير ٥/٢٢٦، وابن أبي حاتم ٢/٦٠١. وعلّق ابنُ المنذر ١/١٣٤ نحوه، وزاد في آخره: وكُلٌّ طَيِّب.أخرجه ابن أبي حاتم ٢/٦٠٠. وعلَّق ابن المنذر ١/١٣٤ نحوه.أخرجه ابن جرير ٥/٢٢٤. وعلَّقه ابن أبي حاتم ٢/٦٠٠.أخرجه ابن جرير ٥/٢٢٠.أخرجه ابن جرير ٥/٢٢٠-٢٢١.خَلَصَت: صار خالصًا، وأخلص لله ترك الرياء، وأخلص دينه لله: أمحَضَه. اللسان والقاموس (خلص).أخرجه ابن أبي حاتم ٢/٦٠٠-٦٠١.تفسير مقاتل بن سليمان ١/٢٦٤.أخرجه ابن جرير ٥/٢١٩.أخرجه ابن جرير ٥/٢٢٥، وابن المنذر (٢٦٤)، وابن أبي حاتم ٢/٦٠٠ (٣٢١٤).أخرجه ابن جرير ٥/٢٢٥.أخرجه ابن جرير ٥/٢٢٦.أخرجه ابن جرير ٥/٢٢٠-٢٢١.أخرجه ابن أبي حاتم ٢/٦٠١، وبنحوه مختصرًا من طريق ابن إدريس.أخرجه ابن جرير ٥/٢٢٧.أخرجه ابن أبي حاتم ٢/٦٠١.تفسير مقاتل بن سليمان ١/٢٦٤.أخرجه أحمد ١٢/٤٧٦ (٧٥٠٨)، ١٦/١٥٥ (١٠٢٠٢)، ١٦/٢٦٠ (١٠٤١٤)، وأبو داود ٧/١٢ (٤٦٠٣)، وابن حِبّان ٤/٣٢٤ (١٤٦٤)، والحاكم ٢/٢٤٣ (٢٨٨٣). ولفظ أبي داود وابنِ حِبّان: «الـمِراءُ بالقرآن». قال الحاكم: «حديث المعتمر عن محمد بن عمرو صحيحٌ، على شرط مسلم، ولم يخرجاه، فأما عمر بن أبي سلمة فإنّهما لم يحتجّا به». وحسّنه ابنُ القَيِّم في تهذيب سنن أبي داود ١٢/٣٥٣.يَنزِع: أي: يجُرُّها إلى نفسه، ويستدل بها على مقصوده. تاج العروس (نزع).عزاه السيوطي إلى نصر المقدسي في الحجة، وأخرجه ابن أبي عاصم في السنة ١/١٧٧ (٤٠٦) بلفظ: «يتنازعون في القدر». قال الألباني في ظلال الجنة ١/١٩١ عن رواية ابن أبي عاصم: «إسناده حسن؛ للخلاف المعروف في عمرو بن شعيب عن أبيه عن جده».أخرجه الحارث في مسنده ٢/٧٤٠ (٧٣٥). قال البوصيري في إتحاف الخيرة ٦/٣٢٣-٣٢٤ (٥٩٣٦): «رواه ابن ماجه في سننه مختصرًا بإسناد صحيح من طريق أبي معاوية عن داود به».أخرجه الدارمي ١/٤٩.التبان: سراويل صغير، مقدار شبر يستر العورة المغلظة فقط، يكون للملاحين. وقيل: التبان شبه السراويل الصغير. مادة (تبن).القتب: إكاف البعير. مادة (قتب).أخرجه ابن عساكر ٢٣/٤١٢. وعزاه السيوطي إلى ابن الأنباري في المصاحف، ونصر المقدسي في الحجة.أخرجه الدارمي ١/٥٤. وعزاه السيوطي إلى نصر المقدسي في الحجة.أخرجه ابن عساكر ٢٣/٤١٣.أخرجه ابن أبي شيبة ١٠/٤٨٩.أخرجه ابن أبي شيبة ١٠/٤٨٩.أخرجه ابن أبي شيبة ١٠/٤٨٩.أخرجه الثعلبي ٣/١٤. وقال عقبه: وهذا إنما قاله ابن عباس في وقت، ثم علمها بعد ذلك وفسرها.
3,8," <q>﴿رَبَّنَا لَا تُزِغۡ قُلُوبَنَا بَعۡدَ إِذۡ هَدَیۡتَنَا وَهَبۡ لَنَا مِن لَّدُنكَ رَحۡمَةًۚ إِنَّكَ أَنتَ ٱلۡوَهَّابُ ۝٨﴾</q> - تفسير ١٢٠٨٤- عن أمّ سلمة -من طريق شهر بن حَوْشَب- أنّ النبي ﷺ كان يقول: «يا مُقَلِّبَ القلوبِ، ثَبِّتْ قلبي على دينك». ثم قرأ: <q>﴿ربنا لا تزغ قلوبنا بعد إذ هديتنا﴾</q> الآية{1}. (٣/٤٦٦) ١٢٠٨٥- عن عائشة، قالت: كان رسول الله ﷺ كثيرًا ما يدعو: «يا مُقَلِّب القلوب، ثَبِّت قلبي على دينك». قلتُ: يا رسول الله، ما أكثرَ ما تدعو بهذا الدعاء! فقال: «ليس مِن قلب إلا وهو بين أصبعين من أصابع الرحمن؛ إذا شاء أن يُقِيمه أقامه، وإذا شاء أن يُزِيغه أزاغه، أما تسمعين قوله تعالى: <q>﴿ربنا لا تزغ قلوبنا بعد إذ هديتنا وهب لنا من لدنك رحمة إنك أنت الوهاب﴾</q>؟!»{2}. ولفظ ابن أبي شيبة: «إذا شاء أن يقلبه إلى هُدًى قلبه، وإذا شاء أن يقلبه إلى ضلال قلبه»{3}. (٣/٤٦٧) ١٢٠٨٦- قال الحسن البصري: هذا دعاءٌ أمَرَ اللهُ المؤمنين أن يَدْعُوا به{4}. (ز) ١٢٠٨٧- عن محمد بن جعفر بن الزبير -من طريق ابن إسحاق- في قوله: <q>﴿ربنا لا تزغ قلوبنا﴾</q>، أي: لا تُمِل قلوبَنا، وإن مِلْنا بأَحْداثِنا{5}{6}١١٢٠. (٣/٤٧٠) ١١٢٠ لم يذكر ابنُ جرير (٥/٢٢٨) غير هذا القول. ١٢٠٨٨- عن محمد بن إسحاق -من طريق إبراهيم بن سعد-، مثله{7}. (ز) ١٢٠٨٩- عن محمد بن إسحاق -من طريق إدريس- قوله: <q>﴿ربنا لا تزغ قلوبنا بعد إذ هديتنا﴾</q>: أي: بعد ما بَصَّرْتَنا مِن الهُدى فيما جاء به أهلُ البِدْعَةِ والضَّلالة{8}. (ز) ١٢٠٩٠- قال مقاتل بن سليمان: قال ابن سلام وأصحابه: <q>﴿ربنا لا تزغ قلوبنا بعد إذ هديتنا﴾</q>: لا تُمِلْ قلوبَنا، يعني: لا تُحَوِّل قلوبَنا عن الهُدى بعدما هديتنا، كما أزَغْتَ اليهودَ عن الهُدى{9}. (ز) ١٢٠٩١- عن مقاتل بن حيان -من طريق بُكَيْر- قال: دعا عبدُ الله بن سلام وأصحابُه ربَّهم، فقالوا: <q>﴿ربنا لا تزغ قلوبنا بعد إذا هديتنا﴾</q> كما أزغت قلوب اليهود بعد إذ هديتهم، <q>﴿وهب لنا من لدنك رحمة إنك أنت الوهاب﴾</q>{10}. (ز) <q>﴿وَهَبۡ لَنَا مِن لَّدُنكَ رَحۡمَةًۚ إِنَّكَ أَنتَ ٱلۡوَهَّابُ ۝٨﴾</q> - تفسير ١٢٠٩٢- قال الضَّحّاك بن مُزاحِم: <q>﴿رحمة﴾</q>: تَجاوُزًا ومغفرة{11}. (ز) ١٢٠٩٣- قال مقاتل بن سليمان: <q>﴿وهب لنا من لدنك﴾</q> يعني: مِن عندك <q>﴿رحمة إنك أنت الوهاب﴾</q> للرَّحْمة{9}١١٢١. (ز) ١١٢١ ذكر ابنُ عطية (٢/١٦٤) أن هذه الآية تحتمل احتمالين: الأول: أن تكون هذه الآية حكاية عن الراسخين في العلم، أنهم يقولون هذا مع قولهم: <q>﴿آمنا به﴾</q>. الثاني: أن يكون المعنى منقطعًا مِن الأول، لما ذكر أهل الزيغ وذكر نقيضهم، وظهر ما بين الحالتين عقَّب ذلك بأن علَّم عباده الدعاء إليه في أن لا يكونوا من الطائفة الذميمة التي ذكرت، وهي أهل الزيغ. ١٢٠٩٤- عن محمد بن إسحاق -من طريق إبراهيم بن سعد- <q>﴿ربنا لا تزغ قلوبنا بعد إذ هديتنا﴾</q> أي: لا تُمِلْ قلوبنا، وإن مِلْنا بأَحْداثِنا، <q>﴿وهب لنا من لدنك رحمة إنك أنت الوهاب﴾</q>. ثُمَّ عَرَّض بما شاء أن يُعَرِّض مِن التَّرْهِيب والتَّرْغِيب، والذِّكْرِ لِمَن شاء أن يذكر، ثم قال: <q>﴿شهد الله أنه لا إله إلا هو والملائكة وأولو العلم قائمًا بالقسط﴾</q> بخِلاف ما قالوا{13}. (ز) <q>﴿وَهَبۡ لَنَا مِن لَّدُنكَ رَحۡمَةًۚ إِنَّكَ أَنتَ ٱلۡوَهَّابُ ۝٨﴾</q> - آثار متعلقة بالآية ١٢٠٩٥- عن عائشة: أنّ رسول الله ﷺ كان إذا استيقظ مِن الليل قال: «لا إله إلا أنت، سُبحانك، اللَّهُمَّ، إنِّي أستغفرُك لذنبي، وأسألك رحمتَك، اللَّهُمَّ، زِدْنِي عِلمًا، ولا تُزِغْ قلبي بعد إذ هديتني، وهَبْ لي مِن لدنك رحمة؛ إنّك أنت الوهّاب»{14}. (٣/٤٧١) ١٢٠٩٦- عن أُمِّ سلمة: أنّ رسول الله ﷺ كان يُكْثِر في دُعائِه أن يقول: «اللَّهُمَّ مُقَلِّبَ القلوب، ثَبِّت قلبي على دينك». قلتُ: يا رسول الله، وإنّ القلوبَ لَتَتَقَلَّبُ؟ قال: «نعم، ما مِن خلقِ الله مِن بشرٍ من بني آدم إلا وقلبُه بين أصبعين من أصابع الله؛ فإن شاء اللهُ أقامَه، وإن شاء أزاغه، فنسأل الله ربَّنا أن لا يزيغ قلوبنا بعد إذ هدانا الله، ونسأله أن يَهَبَ لنا مِن لدُنه رحمةً؛ إنّه هو الوهّاب». قلتُ: يا رسول الله، ألا تُعَلمْني دعوةً أدعو بها لنفسي. قال: «بلى، قولي: اللَّهُمَّ ربَّ النبي محمد، اغفر لي ذنبي، وأَذْهِب غَيْظ قلبي، وأَجِرْنِي مِن مُضِلّات الفِتَنِ ما أحْيَيْتَنِي»{15}. (٣/٤٦٦-٤٦٧) ١٢٠٩٧- عن النّواس بن سَمعان: سمعتُ رسول الله ﷺ يقول: «الميزان بيد الرحمن؛ يرفع أقوامًا ويضع آخرين إلى يوم القيامة، وقلبُ ابنِ آدم بين أصبعين من أصابع الرحمن؛ إذا شاء أقامه، وإذا شاء أزاغه». وكان يقول: «يا مُقَلِّب القلوب، ثبِّتْ قلبي على دينِك»{16}. (٣/٤٦٩-٤٧٠) ١٢٠٩٨- عن عبد الله بن عمرو، أنّه سَمِع رسول الله ﷺ يقول: «إنّ قلوب بني آدم كلَّها بين أصبعين من أصابع الرحمن كقلب واحد يصرّفه كيف يشاء». ثم قال رسول الله ﷺ: «اللَّهُمَّ يا مُصَرِّف القلوب، صَرِّف قلوبَنا إلى طاعتك»{17}. (٣/٤٧١-٤٧٢) ١٢٠٩٩- عن جابر، قال: كان رسول الله ﷺ يُكْثِر أن يقول: «يا مُقَلِّب القلوب، ثبِّت قلوبَنا على دينك». قلنا: يا رسول الله، تخافُ علينا وقد آمَنّا بِك؟ فقال: «إنّ قلوب بني آدم بين أصبعين من أصابع الرحمن كقلبٍ واحدٍ يقول به هكذا»{18}. ولفظ الطبراني: «إنّ قلب ابن آدم بين أصبعين من أصابع الله ﷿؛ فإذا شاء أن يُقِيمه أقامه، وإذا شاء أن يُزِيغه أزاغه»{19}. (٣/٤٦٩) ١٢١٠٠- عن أنس، قال: كان النبي ﷺ يُكْثِرُ أن يقول: «يا مُقَلِّب القلوب، ثبِّتْ قلبي على دينك». قالوا: يا رسول الله، آمنّا بِك وبما جئتَ به، فهل تخافُ علينا؟ قال: «نعم». قال: «إنّ القلوب بين أصبعين من أصابع الله، يُقَلِّبُها»{20}. (٣/٤٦٧-٤٦٨) ١٢١٠١- عن أبي عبيدة بن الجراح، أنّ رسول الله ﷺ قال: «إنّ قلبَ ابنِ آدم مِثْلُ قلبِ العصفور، يَتَقَلَّبُ في اليوم سبعَ مرّات»{21}. (٣/٤٦٨) ١٢١٠٢- عن المِقداد، قال: سمعتُ رسول الله ﷺ يقول: «لَقَلْبُ ابنِ آدم أشَدُّ انقِلابًا مِن القِدْر إذا اجْتَمَعَ غَلَيانًا»{22}. (٣/٤٧٠) ١٢١٠٣- عن أبي موسى الأشعري، عن النبي ﷺ، قال: «إنّ هذا القلبَ كريشةٍ بِفَلاةٍ من الأرض، تُقِيمُها الرِّيحُ ظَهْرًا لِبَطْنٍ»{23}. (٣/٤٦٨) ١٢١٠٤- عن أبي موسى الأشعري، قال: إنّما سُمِّي القلبُ قلبًا لِتَقَلُّبِه، وإنّما مَثَلُ القَلْبِ مَثَلُ رِيشَةٍ بِفَلاةٍ مِن الأرض{24}. (٣/٤٦٨) ١٢١٠٥- عن أبي أيُّوب الأنصاري، قال: لَيَأْتِيَنَّ على الرجل أحايِينُ وما في جِلْدِه مَوْضِعُ إبْرَةٍ مِن النفاق، ولَيَأْتِيَنَّ عليه أحايِينُ وما في جِلْدِه مَوْضِعُ إبْرَةٍ مِن إيمان{25}. (٣/٤٧١) ١٢١٠٦- عن عبد الله بن عباس -من طريق سعيد بن جبير- قال: إنّما سُمِّي: القَلْبُ؛ لأنّه يَتَقَلَّبُ{26}. (ز) ١٢١٠٧- قال عبد الله بن وهب: إذا خاف الوَسْوَسَةَ [يعني: المأموم] فلْيَقْرَأْ فيما يُسِرُّ فيه الإمام، فليقرأ ما فيه مِن القرآن دعاء: <q>﴿ربنا لا تزغ قلوبنا﴾</q> الآية أو نحوه{27}. (ز) ",footnotes:1:أخرجه الترمذي ٦/١٢٥ (٣٨٣١)، وابن جرير ٥/٢٢٩، وابن أبي حاتم ٢/٦٠١-٦٠٢ (٣٢٢٢). قال الترمذي: «هذا حديث حسن». وقال ابن جرير ١٢/٤٣٥: «ولا نعلم لشهر سماعًا يصحّ عن أم سلمة». وقال الهيثمي في المجمع ٦/٣٢٥ (١٠٨٨٨): «قلت: روى الترمذي بعضه. رواه أحمد، وفيه شهر بن حوشب، وهو ضعيف وقد وثق». وقال في ١٠/١٧٦ (١٧٣٨١): «رواه أحمد، وإسناده حسن». وقال الألباني في الصحيحة ٥/١٢٦ (٢٠٩١): «وقال الترمذي: حديث حسن. قلت: يعني لغيره، وهو كما قال أو أعلى؛ لأن شهرًا هذا وإن كان سيِّء الحفظ فحديثه هذا له شواهد تقويه».أخرجه أحمد ٤١/١٥١ (٢٤٦٠٤)، ٤٣/٢٣٠ (٢٦١٣٣). قال ابن كثير في تفسيره ٢/١٤: «غريب من هذا الوجه، ولكن أصله ثابت في الصحيحين، وغيرهما من طرق كثيرة بدون زيادة ذكر هذه الآية الكريمة».أخرجه ابن أبي شيبة ٦/٢٥ (٢٩١٩٩).ذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ١/٢٧٦-٢٧٧-.الأحداث جمع حَدَث وهو الفعل. يسألون الله أن يثبّت قلوبهم بالإيمان وإن مالت أفعالهم إلى بعض المعصية. تفسير الطبري بتحقيق أحمد شاكر ٦/٢١٢.أخرجه ابن جرير ٥/٢٢٨.أخرجه ابن المنذر ١/١٣٥، وابن أبي حاتم ٢/٦٠١ من طريق سلمة.أخرجه ابن أبي حاتم ٢/٦٠٢.تفسير مقاتل بن سليمان ١/٢٦٤.أخرجه الترمذي (٣٥٢٢)، وابن أبي حاتم ٢/٦٠٢.تفسير البغوي ٢/١١، وتفسير الثعلبي ٣/١٧.تفسير مقاتل بن سليمان ١/٢٦٤.أخرجه ابن المنذر ١/١٣٥.أخرجه أبو داود ٧/٣٩٩ (٥٠٦١)، وابن حبان ١٢/٣٤١ (٥٥٣١)، والحاكم ١/٧٢٤ (١٩٨١). قال الحاكم: «هذا حديث صحيح الإسناد، ولم يخرجاه».أخرجه أحمد ٤٤/١٣٨ (٢٦٥١٩) مختصرًا، ٤٤/٢٠٠ (٢٦٥٧٦)، ٤٤/٢٧٨ (٢٦٦٧٩)، وابن جرير ٥/٢٢٩. قال ابن جرير ١٢/٤٣٥: «ولا نعلم لشهر سماعًا يَصِحُّ عن أم سلمة». وقال الهيثمي في المجمع ٦/٣٢٥ (١٠٨٨٨): «قلت: روى الترمذي بعضه. رواه أحمد، وفيه شهر بن حوشب، وهو ضعيف وقد وُثِّق». وقال في ١٠/١٧٦ (١٧٣٨١): «قلت: عند الترمذي بعضه. رواه أحمد، وإسناده حسن».أخرجه أحمد ٢٩/١٧٨ (١٧٦٣٠)، وابن ماجه ١/١٣٧-١٣٨ (١٩٩)، وابن حبان ٣/٢٢٢ (٩٤٣)، والحاكم ١/٧٠٦ (١٩٢٦)، ٢/٣١٧ (٣١٤١)، ٤/٣٥٧ (٧٩٠٧). قال الحاكم ٢/٣١٧ (٣١٤١): «هذا حديث صحيح، على شرط الشيخين، ولم يخرجاه». وقال الذهبي في التلخيص: «على شرط البخاري ومسلم». وقال البوصيري في مصباح الزجاجة ١/٢٧ (٦٩): «إسناده صحيح».أخرجه مسلم ٤/٢٠٤٥ (٢٦٥٤).أخرجه الحاكم ٢/٣١٧ (٣١٤٠)، وابن جرير ٥/٢٣٠. قال الحاكم: «هذا حديث صحيح، على شرط مسلم، ولم يخرجاه هكذا، إنما تفرد مسلم بإخراج حديث عبد الله بن عمرو: «قلوب بني آدم» فقط». وقال الذهبي في التلخيص: «على شرط مسلم». وقال الهيثمي في المجمع ١٠/١٧٦ (١٧٣٨٢): «رواه أبو يعلى، ورجاله رجال الصحيح».عزاه السيوطيُّ إلى الطبراني في السُّنَّة.أخرجه أحمد ١٩/١٦٠ (١٢١٠٧)، ٢١/٢٥٩ (١٣٦٩٦)، والترمذي ٤/٢١٩ (٢٢٧٧)، وابن ماجه ٥/٩ (٣٨٣٤). قال الترمذي: «هذا حديث حسن، وهكذا روى غير واحد عن الأعمش عن أبي سفيان عن أنس، وروى بعضهم عن الأعمش عن أبي سفيان عن جابر عن النبي ﷺ، وحديث أبي سفيان عن أنس أصحّ».أخرجه الحاكم ٤/٣٤٢ (٧٨٥٠)، ٤/٣٦٥ (٧٩٣٥). قال الحاكم: «هذا حديث صحيح، على شرط مسلم، ولم يخرجاه». وقال الذهبي في التلخيص: «فيه انقطاع». وقال الألباني في الضعيفة ٧/١٧٠ (٣١٨٦): «ضعيف».أخرجه أحمد ٣٩/٢٣٨ (٢٣٨١٦)، والحاكم ٢/٣١٧ (٣١٤٢). قال الحاكم: «هذا حديث صحيح، على شرط البخاري، ولم يخرجاه». وقال الذهبي في التخليص: «على شرط البخاري». وقال البزار في مسنده ٦/٤٧ (٢١١٢): «وهذا الكلام لا نحفظه إلا عن المقداد عن النبي ﷺ، إلا رجل قلبه فجعله عن المقدام، والصواب عندنا هو المقداد، وإسناده إسناد حسن». وأورده الألباني في الصحيحة ٤/٣٧٥ (١٧٧٢).أخرجه أحمد ٣٢/٥٢٩ (١٩٧٥٧) واللفظ له، وابن ماجه ١/٦٦ (٨٨). قال عبد الله بن أحمد: «قال أبي: ولم يرفعه إسماعيلُ عن الجريري».عزاه السيوطي إلى ابن أبي الدنيا في الإخلاص.أخرجه الحكيم الترمذي ١/٢٧٤.أخرجه ابن المنذر ١/١٢٢.جامع ابن وهب ١/٦٧-٦٨ (١٥١).
3,9," <q>﴿رَبَّنَاۤ إِنَّكَ جَامِعُ ٱلنَّاسِ لِیَوۡمࣲ لَّا رَیۡبَ فِیهِۚ إِنَّ ٱللَّهَ لَا یُخۡلِفُ ٱلۡمِیعَادَ ۝٩﴾</q> - تفسير ١٢١٠٨- عن أُمِّ هانئ، أنّ رسول الله ﷺ قال: «إنّ الله يجمع الأوَّلين والآخِرين في صعيدٍ واحدٍ يومَ القيامة»{1}. (ز) ١٢١٠٩- عن عبد الله بن عباس -من طريق عكرمة- في قول الله: <q>﴿إن الله لا يخلف الميعاد﴾</q>، قال: ميعاد مَن قال: لا إله إلا الله{2}. (ز) ١٢١١٠- قال مُقاتِل بن سليمان: ثُمَّ قال ابن سلام وأصحابُه: <q>﴿ربنا إنك جامع الناس ليوم لا ريب فيه﴾</q> يعني: ليوم القيامة، <q>﴿إن الله لا يخلف الميعاد﴾</q> في البعث بأنّك تجمع الناس في الآخرة{3}١١٢٢. (ز) ١١٢٢ ذكر ابن عطية (٢/١٦٥) أن قوله تعالى: <q>﴿إن الله لا يخلف الميعاد﴾</q>يحتمل احتمالين: الأول: أن يكون إخبارًا منه لمحمدٍ ﷺ وأمته. الثاني: أن يكون حكايةً من قول الداعين، ففي ذلك إقرار بصفة ذات الله تعالى. <q>﴿رَبَّنَاۤ إِنَّكَ جَامِعُ ٱلنَّاسِ لِیَوۡمࣲ لَّا رَیۡبَ فِیهِۚ إِنَّ ٱللَّهَ لَا یُخۡلِفُ ٱلۡمِیعَادَ ۝٩﴾</q> - آثار متعلقة بالآية ١٢١١١- عن جعفر بن محمد الخُلْدِيّ، قال: رُوِي عن النبي ﷺ أنّه قال: «مَن قرأ هذه الآيةَ على شَيْءٍ ضاع مِنهُ رَدَّه اللهُ عليه: <q>﴿ربنا إنك جامع الناس ليوم لا ريب فيه إن الله لا يخلف الميعاد﴾</q>، اللَّهُمَّ يا جامعَ الناسِ ليوم لا ريب فيه، اجْمَع بيني وبين مالي؛ إنّك على كل شيء قدير»{4}. (٣/٤٧٢) ",footnotes:1:أخرجه الطبراني في الأوسط ٢/٨٧ (١٣٣٦)، وابن أبي حاتم ٢/٦٠٢ (٣٢٢٥)، ٩/٣٠٤٩ (١٧٢٤٢). قال الطبراني: «لا يُرْوى هذا الحديثُ عن أُمِّ هانئ إلا بهذا الإسناد، تفرد به أبو عاصم الثقفي الكوفي». وقال الهيثمي في المجمع ١٠/٣٥٦ (١٨٤٢٥): «فيه أبو عاصم الربيع بن إسماعيل، منكر الحديث، قاله أبو حاتم». وهو متفق عليه من حديث أبي هريرة.أخرجه ابن أبي حاتم ٢/٦٠٢. كما أورده عند تفسير قوله تعالى: <q>﴿رَبَّنا وآتِنا ما وعَدْتَنا عَلى رُسُلِكَ ولا تُخْزِنا يَوْمَ القِيامَةِ إنَّكَ لا تُخْلِفُ المِيعادَ (١٩٤)﴾</q> [آل عمران:١٩٤]، وهو ألصق بتفسيرها.تفسير مقاتل بن سليمان ١/٢٦٤.أخرجه ابن النَّجّار في ذيل تاريخ بغداد ١٨/١٤. وهذا مُعْضَل، جعفر بن محمد الخلدي في طبقة شيوخ الدارقطني، توفي سنة ٣٤٨هـ، ترجمته في تاريخ بغداد ٧/٢٢٦، وقد ذكره بلا إسناد وبصيغة التمريض. ثم في إسناده أبو العز أحمد بن عبيد الله بن كادش، قال الذهبي ١/١١٨: «أقَرَّ بوَضْعِ حديثٍ، وتاب وأناب».
