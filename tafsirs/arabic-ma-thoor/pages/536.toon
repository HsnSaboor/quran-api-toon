quran[26]{c,v,t}:
56,51," <q>﴿ثُمَّ إِنَّكُمۡ أَیُّهَا ٱلضَّاۤلُّونَ ٱلۡمُكَذِّبُونَ ۝٥١﴾</q> - تفسير ٧٥١٦٥- عن عبد الله بن عباس -من طريق السُّدِّيّ، عن أبي مالك وأبي صالح- <q>﴿ثُمَّ إنَّكُمْ أيُّها الضّالُّونَ المُكَذِّبُونَ﴾</q>، قال: المشركون المُكذِّبون{1}. (١٤/٢٥٠) ٧٥١٦٦- قال مقاتل بن سليمان: ثم ذكر طعامهم وشرابهم في الآخرة، فقال: <q>﴿ثُمَّ إنَّكُمْ﴾</q> يا أهل مكة <q>﴿أيُّها الضّالُّونَ﴾</q> عن الهدى، يعني: المشركين، ثم قال: <q>﴿المُكَذِّبُونَ﴾</q> بالبعث؛ لقولهم: أوَ يَبعث آباءنا الأوّلين؟!{2}. (ز) ",footnotes:1:عزاه السيوطي إلى ابن مردويه.تفسير مقاتل بن سليمان ٤/٢٢١-٢٢٢.
56,52," <q>﴿لَـَٔاكِلُونَ مِن شَجَرࣲ مِّن زَقُّومࣲ ۝٥٢ فَمَالِـُٔونَ مِنۡهَا ٱلۡبُطُونَ ۝٥٣﴾</q> - تفسير ٧٥١٦٧- عن عبد الله بن عباس -من طريق السُّدِّيّ، عن أبي مالك وأبي صالح- <q>﴿لَآكِلُونَ مِن شَجَرٍ مِن زَقُّومٍ﴾</q>، قال: والزَّقوم إذا أكلوا منه غَصُّوا، والزَّقوم شجرة{1}. (١٤/٢٥٠) ٧٥١٦٨- عن عبد الله بن عباس -من طريق السُّدِّيّ، عن أبي مالك وأبي صالح- <q>﴿فَمالِئُونَ مِنها البُطُونَ﴾</q>، قال: يملؤون من الزَّقوم بطونهم{1}. (١٤/٢٥٠-٢٥١) ٧٥١٦٩- قال مقاتل بن سليمان: <q>﴿لَآكِلُونَ مِن شَجَرٍ مِن زَقُّومٍ فَمالِئُونَ مِنها﴾</q> يعني: مِن طلْعها وثمرها <q>﴿البُطُونَ﴾</q>{3}. (ز) ",footnotes:1:عزاه السيوطي إلى ابن مردويه.عزاه السيوطي إلى ابن مردويه.تفسير مقاتل بن سليمان ٤/٢٢١-٢٢٢.
  56,53,""
56,54," <q>﴿فَشَـٰرِبُونَ عَلَیۡهِ مِنَ ٱلۡحَمِیمِ ۝٥٤﴾</q> - تفسير ٧٥١٧٠- عن عبد الله بن عباس -من طريق السُّدِّيّ، عن أبي مالك وأبي صالح- <q>﴿فَشارِبُونَ عَلَيْهِ مِنَ الحَمِيمِ﴾</q>، يقول: على الزّقوم الحميم{1}. (١٤/٢٥١) ٧٥١٧١- قال مقاتل بن سليمان: <q>﴿فَشارِبُونَ عَلَيْهِ﴾</q> يعني: على الأكل <q>﴿مِنَ الحَمِيمِ﴾</q> يعني: الشراب الحار الذي قد انتهى حرُّه{2}. (ز) ",footnotes:1:عزاه السيوطي إلى ابن مردويه.تفسير مقاتل بن سليمان ٤/٢٢١-٢٢٢.
56,55," <q>﴿فَشَـٰرِبُونَ شُرۡبَ ٱلۡهِیمِ ۝٥٥﴾</q> - قراءات ٧٥١٧٢- عن عبد الله بن عمر: أنّ رسول الله ﷺ قرأ في الواقعة: ‹فَشارِبُونَ شَرْبَ الهِيمِ› بفتح الشين من <q>﴿شُرب﴾</q>{1}. (١٤/٢١١) ٧٥١٧٣- عن أنس بن مالك، قال: كان النبيُّ ﷺ يقرأ: ‹شَرْبَ الهِيمِ›{2}. (١٤/٢١١) ٧٥١٧٤- قرأ عاصم: <q>﴿شُرْبَ الهِيمِ﴾</q> برفع الشين{3}٦٤٤٢. (١٤/٢١١) ٦٤٤٢ اختلفت القرأة في قراءة قوله تعالى: <q>﴿شُرْبَ الهِيمِ﴾</q> على قراءتين: الأولى: <q>﴿شُرْبَ الهيم﴾</q> بضم الشين. الثانية: ‹شَرْبَ الهِيمِ› بفتح الشين. ورجَّح ابنُ جرير (٢٢/٣٤٢) «أنهما قراءتان، قد قرأ بكلِّ واحدةٍ منهما علماءُ من القرأة، مع تقارب معنيَيْهما، فبأيَّتِهما قرأ القارئ فمصيبٌ في قراءته؛ لأن ذلك في فتحه وضمِّه نظير فتح قولهم: الضَّعف، والضُّعف وضمِّه». <q>﴿فَشَـٰرِبُونَ شُرۡبَ ٱلۡهِیمِ ۝٥٥﴾</q> - تفسير الآية ٧٥١٧٥- عن عبد الله بن عباس -من طريق سفيان- في قوله: <q>﴿شُرْبَ الهِيمِ﴾</q>، قال: الإبل العِطاش{4}. (١٤/٢١١) ٧٥١٧٦- عن عبد الله بن عباس، أنّ نافع بن الأزرق قال له: أخبِرني عن قوله ﷿: <q>﴿فَشارِبُونَ شُرْبَ الهِيمِ﴾</q>. قال: الإبل يأخذها داء يُقال له: الهِيم، فلا تَروى مِن الماء، فشبّه الله تعالى شُرب أهل النار مِن الحميم بمنزلة الإبل الهِيم. قال: وهل تعرف العرب ذلك؟ قال: نعم، أما سمعتَ لَبيد بن ربيعة وهو يقول: أجَزتُ إلى مَعارِفها بِشُعْثٍ وأطْلاحٍ{5} من العِيديِّ{6} هِيمِ؟!{7}. (١٤/٢١٢) ٧٥١٧٧- عن عبد الله بن عباس، في قوله: <q>﴿فَشارِبُونَ شُرْبَ الهِيمِ﴾</q>، قال: هُيام الأرض، يعني: الرّمال{8}٦٤٤٣. (١٤/٢١٣) ٦٤٤٣ ذكر ابنُ عطية (٨/٢٠٣) قول ابن عباس، وسفيان الثوري: أنّ «الهيم هنا: الرمال التي لا تُرْوى بالماء». ثم وجَّهه بقوله: «وذلك أن الهَيام -بفتح الهاء-: هو الرّمل الدِّق الغَمْر المتراكم». ٧٥١٧٨- عن عبد الله بن عباس -من طريق السُّدِّيّ، عن أبي مالك وأبي صالح- <q>﴿فَشارِبُونَ شُرْبَ الهِيمِ﴾</q>: هي الرّمال، لو مطرت عليها السماء أبدًا لم يُرَ فيها مستنقع{2}. (١٤/٢٥١) ٧٥١٧٩- عن سعيد بن جُبَير، <q>﴿شُرْبَ الهِيمِ﴾</q>، قال: الإبل{10}. (١٤/٢١٣) ٧٥١٨٠- عن مجاهد بن جبر -من طريق ابن أبي نجيح- <q>﴿شُرْبَ الهِيمِ﴾</q>، قال: الإبل الهُيَّم{11}. (١٤/٢١٣) ٧٥١٨١- عن مجاهد بن جبر -من طريق ابن أبي نجيح- <q>﴿شُرْبَ الهِيمِ﴾</q>، قال: الإبل الظّماء{12}. (١٤/٢١٣) ٧٥١٨٢- عن مجاهد بن جبر -من طريق جابر- <q>﴿شُرْبَ الهِيمِ﴾</q>: هو داء يكون في الإبل تشرب فلا تَروى{12}. (ز) ٧٥١٨٣- عن الضَّحّاك بن مُزاحِم -من طريق عبيد- <q>﴿شُرْبَ الهِيمِ﴾</q>، قال: الهيم: الإبل العِطاش، تشرب فلا تَروى، يأخذها داء يقال له: الهُيام{14}. (١٤/٢١٣) ٧٥١٨٤- قال الضَّحّاك بن مُزاحِم: <q>﴿الهِيمِ﴾</q> الأرض السّهلة ذات الرّمل{15}. (ز) ٧٥١٨٥- عن عكرمة مولى ابن عباس -من طريق عمران- <q>﴿فَشارِبُونَ شُرْبَ الهِيمِ﴾</q>، قال: الإبل المِراض تمصّ الماء مصًّا، ولا تَروى{16}. (١٤/٢١٢) ٧٥١٨٦- عن عكرمة مولى ابن عباس -من طريق يزيد- في قوله: <q>﴿فَشارِبُونَ شُرْبَ الهِيمِ﴾</q>، قال: الإبل يأخذها العِطاش، فلا تزال تشرب حتى تهلك{17}. (ز) ٧٥١٨٧- عن أبي مجلز [لاحق بن حميد]، <q>﴿فَشارِبُونَ شُرْبَ الهِيمِ﴾</q>، قال: كان المِراض تمصّ الماء مصًّا، ولا تَروى{18}. (١٤/٢١٢) ٧٥١٨٨- عن الحسن البصري، قال: <q>﴿الهِيمِ﴾</q> الإبل العِطاش{10}. (١٤/٢١٣) ٧٥١٨٩- عن قتادة بن دعامة، <q>﴿فَشارِبُونَ شُرْبَ الهِيمِ﴾</q>، قال: ضوالّ الإبل، دوابّ لا تَروى{10}. (١٤/٢١٢) ٧٥١٩٠- عن قتادة بن دعامة -من طريق معمر- في قوله تعالى: <q>﴿شُرْبَ الهِيمِ﴾</q>، قال: الإبل العِطاش{21}. (ز) ٧٥١٩١- عن قتادة بن دعامة -من طريق سعيد- قوله: <q>﴿فَشارِبُونَ شُرْبَ الهِيمِ﴾</q>، قال: داءٌ بالإبل لا تَروى معه{22}. (ز) ٧٥١٩٢- عن محمد بن السّائِب الكلبي: <q>﴿شُرْبَ الهِيمِ﴾</q>، يعني: الإبل العِطاش{23}. (ز) ٧٥١٩٣- قال مقاتل بن سليمان: <q>﴿فَشارِبُونَ شُرْبَ الهِيمِ﴾</q> يعني بالهِيم: الإبل، يأخذها داء يُقال له: الهِيم، فلا تَروى من الشراب، وذلك أنه يُلقى على أهل النار العطش كلّ يوم مرتين حتى يشربوا الشراب الهِيم{24}. (ز) ٧٥١٩٤- عن سفيان [الثوري] -من طريق مهران- <q>﴿الهِيمِ﴾</q>، قال: السّهلة{25}. (ز) ",footnotes:1:أخرجه الطبراني في الأوسط ٩/١٤٥ (٩٣٧١)، وتمام في فوائده ١/٢١٦ (٥١١)، وابن عساكر في تاريخ دمشق ٦٤/٢٢٩-٢٣٠. وأخرجه الحاكم ٢/٢٧٤ (٢٩٨٧) بضم الشين، وفي إسناده سلام بن سليمان المدايني. قال ابن حبان في المجروحين ١/٣٤٢ (٤٣٣): «سلام بن سليمان شيخ يروي عن أبي عمرو بن العلاء أشياء لا يُتابع عليها، لا يجوز الاحتجاج به إذا انفرد، روى عن أبي عمرو بن العلاء، عن نافع، عن ابن عمر، أنّ رسول الله ﷺ قرأ: ‹فَشارِبُونَ شَرْبَ الهِيمِ›، في أشياء يروي مثل هذا لا توافق حديث الثقات، بل يباين حديث الأثبات». وقال ابن عدي في الكامل ٤/٣٢٣ (٧٧٢): «سلام بن سليمان بن سوار الثقفي المدائني الضرير ...، وهو عندي منكر الحديث». وقال الحاكم: «هذا حديث صحيح الإسناد، ولم يخرجاه». وقال الذهبي في التلخيص: «سلام ضعيف». و‹شَرْبَ الهِيمٍ› بفتح الشين قراءة العشرة ما عدا نافعًا، وأبا جعفر، وعاصمًا، وحمزة؛ فإنهم قرؤوا: <q>﴿شُرْبَ الهِيمِ﴾</q> بضم الشين. انظر: النشر ٢/٣٨٣، والإتحاف ص٥٢٧.عزاه السيوطي إلى ابن مردويه.عزاه السيوطي إلى ابن حميد.أخرجه ابن جرير ٢٢/٣٤٣-٣٤٤ بنحوه من طريق علي، والعَوفيّ. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.يقال: ناقة طَلِيحُ أسفار إذا جَهَدَها السير وهَزَلها. لسان العرب (طلح).العِيديّة: إبل منسوبة إلى العيد، والعيد: قبيلة من مَهْرة، وإبل مَهْرة موصوفة بالنجابة. لسان العرب (رهن، عود).عزاه السيوطي إلى الطستي، وهو في مسائل نافع (٢٥٧).عزاه السيوطي إلى سفيان بن عيينة في جامعه.عزاه السيوطي إلى ابن مردويه.عزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ٢٢/٣٤٤. وعزاه السيوطي إلى عبد بن حميد.تفسير مجاهد ص٦٤٤.تفسير مجاهد ص٦٤٤.أخرجه ابن جرير ٢٢/٣٤٤. وعزا السيوطي إلى عبد بن حميد نحوه.تفسير الثعلبي ٩/٢١٤، وتفسير البغوي ٨/١٩.أخرجه ابن جرير ٢٢/٣٤٣. وعزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ٢٢/٣٤٣، وبنحوه من طريق خُصَيف.عزاه السيوطي إلى سعيد بن منصور، وابن المنذر.عزاه السيوطي إلى عبد بن حميد.عزاه السيوطي إلى عبد بن حميد.أخرجه عبد الرزاق ٢/٢٧٢.أخرجه ابن جرير ٢٢/٣٤٤.ذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٤/٣٤١-.تفسير مقاتل بن سليمان ٤/٢٢١-٢٢٢.أخرجه ابن جرير ٢٢/٣٤٤. وفي تفسير الثعلبي ٩/٢١٤، وتفسير البغوي ٨/١٩ عن سفيان: <q>﴿الهِيمِ﴾</q>: الأرض السّهلة ذات الرّمل.
56,56," <q>﴿هَـٰذَا نُزُلُهُمۡ یَوۡمَ ٱلدِّینِ ۝٥٦﴾</q> - تفسير ٧٥١٩٥- عن عبد الله بن عباس -من طريق السُّدِّيّ، عن أبي مالك وأبي صالح- <q>﴿هَذا نُزُلُهُمْ يَوْمَ الدِّينِ﴾</q>: كرامة يوم الحساب{1}. (١٤/٢٥١) ٧٥١٩٦- قال مقاتل بن سليمان: <q>﴿هَذا﴾</q> الذي ذُكر مِن الزّقوم والشراب <q>﴿نُزُلُهُمْ يَوْمَ الدِّينِ﴾</q> يعني: يوم الحساب{2}. (ز) ",footnotes:1:عزاه السيوطي إلى ابن مردويه.تفسير مقاتل بن سليمان ٤/٢٢١-٢٢٢.
56,57," <q>﴿نَحۡنُ خَلَقۡنَـٰكُمۡ فَلَوۡلَا تُصَدِّقُونَ ۝٥٧﴾</q> - تفسير ٧٥١٩٧- عن عبد الله بن عباس -من طريق السُّدِّيّ، عن أبي مالك وأبي صالح- <q>﴿نَحْنُ خَلَقْناكُمْ فَلَوْلا تُصَدِّقُونَ﴾</q>، يقول: أفلا تُصدِّقون{1}. (١٤/٢٥١) ٧٥١٩٨- قال مقاتل بن سليمان: <q>﴿نَحْنُ خَلَقْناكُمْ﴾</q> ولم تكونوا شيئًا وأنتم تعلمون <q>﴿فَلَوْلا﴾</q> يعني: فهلّا <q>﴿تُصَدِّقُونَ﴾</q>{2}. (ز) ",footnotes:1:عزاه السيوطي إلى ابن مردويه.تفسير مقاتل بن سليمان ٤/٢٢١-٢٢٢.
56,58," <q>﴿أَفَرَءَیۡتُم مَّا تُمۡنُونَ ۝٥٨ ءَأَنتُمۡ تَخۡلُقُونَهُۥۤ أَمۡ نَحۡنُ ٱلۡخَـٰلِقُونَ ۝٥٩﴾</q> - تفسير ٧٥١٩٩- عن عبد الله بن عباس -من طريق السُّدِّيّ، عن أبي مالك وأبي صالح- <q>﴿أفَرَأَيْتُمْ ما تُمْنُونَ﴾</q>، يقول: هذا ماء الرجل{1}. (١٤/٢٥١) ٧٥٢٠٠- قال مقاتل بن سليمان: <q>﴿أفَرَأَيْتُمْ ما تُمْنُونَ﴾</q> يعني: النُّطفة؛ الماء الدّافق، <q>﴿أأَنْتُمْ تَخْلُقُونَهُ﴾</q> بشرًا، <q>﴿أمْ نَحْنُ الخالِقُونَ﴾</q> له؟ بل نحن نخلقه{2}. (ز) <q>﴿أَفَرَءَیۡتُم مَّا تُمۡنُونَ ۝٥٨ ءَأَنتُمۡ تَخۡلُقُونَهُۥۤ أَمۡ نَحۡنُ ٱلۡخَـٰلِقُونَ ۝٥٩﴾</q> - آثار متعلقة بالآية ٧٥٢٠١- عن حُجْر المَدَريّ، قال: بتُّ عند علِيٍّ، فسمعتُه وهو يُصلّي بالليل يقرأ، فمرّ بهذه الآية: <q>﴿أفَرَأَيْتُمْ ما تُمْنُونَ أأَنْتُمْ تَخْلُقُونَهُ أمْ نَحْنُ الخالِقُونَ﴾</q>. قال: بل أنتَ، يا ربّ. ثلاثًا. ثم قرأ: <q>﴿أأنتم تزرعونه﴾</q>. قال: بل أنتَ، يا ربّ. ثلاثًا. ثم قرأ: <q>﴿أأَنْتُمْ أنْزَلْتُمُوهُ مِنَ المُزْنِ﴾</q>. قال: بل أنتَ، يا ربّ. ثلاثًا. ثم قرأ: <q>﴿أأَنْتُمْ أنْشَأْتُمْ شَجَرَتَها﴾</q>. قال: بل أنت، يا ربّ. ثلاثًا{3}. (١٤/٢١٣) ",footnotes:1:عزاه السيوطي إلى ابن مردويه.تفسير مقاتل بن سليمان ٤/٢٢٢.أخرجه عبد الرزاق في مصنفه (٤٠٥٣)، والحاكم ٢/٤٧٧، والبيهقي في سننه ٢/٣١١.
  56,59,""
56,60," <q>﴿نَحۡنُ قَدَّرۡنَا بَیۡنَكُمُ ٱلۡمَوۡتَ وَمَا نَحۡنُ بِمَسۡبُوقِینَ ۝٦٠﴾</q> - تفسير ٧٥٢٠٢- عن عبد الله بن عباس -من طريق السُّدِّيّ، عن أبي مالك وأبي صالح-: <q>﴿نَحْنُ قَدَّرْنا بَيْنَكُمُ المَوْتَ﴾</q> في المتعجّل والمتأخّر، <q>﴿وما نَحْنُ بِمَسْبُوقِينَ﴾</q>{1}. (١٤/٢٥١) ٧٥٢٠٣- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿نَحْنُ قَدَّرْنا بَيْنَكُمُ المَوْتَ﴾</q>، قال: المتأخّر والمتعجّل{2}٦٤٤٤. (١٤/٢١٤) ٦٤٤٤ ذكر ابنُ عطية (٨/٢٠٤) أنّ الآية تحتمل أن تكون بمعنى: «سوَّيْنا وعدَّلْنا التَّقدُّم والتَّأخُّر». ثم وجَّهه بقوله: «أي: جعلنا الموت رُتَبًا، ليس يموت العالمَ دفعة واحدة، بل بترتيبٍ لا يعدوه أحد». ٧٥٢٠٤- عن الضَّحّاك بن مُزاحِم -من طريق جويبر- في قوله: <q>﴿نَحْنُ قَدَّرْنا بَيْنَكُمُ المَوْتَ﴾</q>، قال: تقديره أن جعل أهل الأرض وأهل السماء فيه سواء؛ شريفهم وضعيفهم{3}. (١٤/٢١٤) ٧٥٢٠٥- قال مقاتل بن سليمان: <q>﴿نَحْنُ قَدَّرْنا بَيْنَكُمُ المَوْتَ﴾</q> فمنكم مَن يموت صغيرًا، ومنكم مَن يموت كبيرًا، أو يموت شابًّا، أو شيخًا، أو يبلغ أرذَل العمر. ثم خوّفهم، فقال: <q>﴿وما نَحْنُ بِمَسْبُوقِينَ﴾</q> يعني: بمُعجَزين إنْ أردنا ذلك{4}. (ز) ",footnotes:1:عزاه السيوطي إلى ابن مردويه.تفسير مجاهد ص٦٤٤، وأخرجه ابن جرير ٢٢/٣٤٦-٣٤٧. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه أبو الشيخ في العظمة (١٨٠).تفسير مقاتل بن سليمان ٤/٢٢٢.
56,61," <q>﴿عَلَىٰۤ أَن نُّبَدِّلَ أَمۡثَـٰلَكُمۡ وَنُنشِئَكُمۡ فِی مَا لَا تَعۡلَمُونَ ۝٦١﴾</q> - تفسير ٧٥٢٠٦- عن عبد الله بن عباس -من طريق السُّدِّيّ، عن أبي مالك وأبي صالح- <q>﴿عَلى أنْ نُبَدِّلَ أمْثالَكُمْ﴾</q> فيقول: نذهب بكم، ونجيء بغيركم، <q>﴿ونُنْشِئَكُمْ فِي ما لا تَعْلَمُونَ﴾</q> يقول: نخلقكم فيما لا تعلمون؛ إن نشأ خلقناكم قِردة، وإن نشأ خلقناكم خنازير{1}. (١٤/٢٥١) ٧٥٢٠٧- قال سعيد بن المسيّب: <q>﴿ونُنْشِئَكُمْ فِي ما لا تَعْلَمُونَ﴾</q> يعني: في حواصل طير، تكون بِبَرَهُوت، كأنها الخطاطيف. وبَرَهُوت: وادٍ باليمن{2}. (ز) ٧٥٢٠٨- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿ونُنْشِئَكُمْ فِي ما لا تَعْلَمُونَ﴾</q>، قال: في أي خلْقٍ شئنا{3}. (١٤/٢١٤) ٧٥٢٠٩- قال الحسن البصري: <q>﴿ونُنْشِئَكُمْ فِي ما لا تَعْلَمُونَ﴾</q> أي: نبدّل صفاتكم، ونجعلكم قِردة وخنازير كما فعلنا بمن كان قبلكم{2}٦٤٤٥. (ز) ٦٤٤٥ وجَّه ابنُ عطية (٨/٢٠٤) قول الحسن بقوله: «تأوَّل الحسن هذا؛ لأنّ الآية تنحو إلى الوعيد». ٧٥٢١٠- قال إسماعيل السُّدِّيّ: <q>﴿ونُنْشِئَكُمْ فِي ما لا تَعْلَمُونَ﴾</q> نخلُقكم في سوء خلقكم{5}. (ز) ٧٥٢١١- قال مقاتل بن سليمان: <q>﴿عَلى أنْ نُبَدِّلَ أمْثالَكُمْ﴾</q> على أن نخلُق مثلكم أو أمثل منكم، <q>﴿ونُنْشِئَكُمْ﴾</q> يعني: ونخلقكم سوى خلْقكم <q>﴿فِي ما لا تَعْلَمُونَ﴾</q> من الصورة{6}. (ز) ",footnotes:1:عزاه السيوطي إلى ابن مردويه.تفسير الثعلبي ٩/٢١٥، وتفسير البغوي ٨/٢٠.تفسير مجاهد ص٦٤٤، وأخرجه ابن جرير ٢٢/٣٤٦. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.تفسير الثعلبي ٩/٢١٥، وتفسير البغوي ٨/٢٠.تفسير الثعلبي ٩/٢١٥.تفسير مقاتل بن سليمان ٤/٢٢٢.
56,62," <q>﴿وَلَقَدۡ عَلِمۡتُمُ ٱلنَّشۡأَةَ ٱلۡأُولَىٰ فَلَوۡلَا تَذَكَّرُونَ ۝٦٢﴾</q> - تفسير ٧٥٢١٢- عن عبد الله بن عباس -من طريق السُّدِّيّ، عن أبي مالك وأبي صالح- <q>﴿ولَقَدْ عَلِمْتُمُ النَّشْأَةَ الأُولى فَلَوْلا تَذَكَّرُونَ﴾</q>، يقول: فهلّا تذكَّرون{1}. (١٤/٢٥١) ٧٥٢١٣- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿ولَقَدْ عَلِمْتُمُ النَّشْأَةَ الأُولى﴾</q>: إذ لم تكونوا شيئًا{2}. (١٤/٢١٤) ٧٥٢١٤- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿ولَقَدْ عَلِمْتُمُ النَّشْأَةَ الأُولى﴾</q>، قال: خلْق آدم ﵇{3}. (١٤/٢١٤) ٧٥٢١٥- عن أبي عمران الجَوْني -من طريق جعفر بن سليمان- يقرأ هذه الآية: <q>﴿ولَقَدْ عَلِمْتُمُ النَّشْأَةَ الأُولى﴾</q>، قال: هو خلْق آدم{4}. (ز) ٧٥٢١٦- عن الضَّحّاك بن مُزاحِم{5} -من طريق جويبر- في قوله: <q>﴿ولَقَدْ عَلِمْتُمُ النَّشْأَةَ الأُولى﴾</q> قال: خلْق آدم وخلْقكم، <q>﴿فَلَوْلا تَذَكَّرُونَ﴾</q> فهلّا تصدّقون{6}. (ز) ٧٥٢١٧- قال مقاتل بن سليمان: <q>﴿ولَقَدْ عَلِمْتُمُ النَّشْأَةَ الأُولى﴾</q> يعني: الخلْق الأول حين خُلقتم من نطفة، ثم من علقة، ثم من مُضغة، ولم تكونوا شيئًا، <q>﴿فَلَوْلا﴾</q> يعني: فهلّا <q>﴿تَذَكَّرُونَ﴾</q> في البعث أنّه قادر على أن يبعثكم، كما خلقكم أول مرّة ولم تكونوا شيئًا{7}٦٤٤٦. (ز) ٦٤٤٦ نقل ابنُ عطية (٨/٢٠٥) عن أكثر المفسرين قولهم: «أشار إلى خلْق آدم ﵇، ووقف عليه؛ لأنك لا تجد أحدًا ينكر أنه من ولد آدم ﵇، وأنه من طين». ونقل عن بعضهم قولهم: «أراد تعالى بالنَّشأة الأولى: نشأة إنسان في طفولته، فيَعلم المرء نشأته كيف كانت بما يَرى من نشأة غيره». ",footnotes:1:عزاه السيوطي إلى ابن مردويه.تفسير مجاهد ص٦٤٤، وأخرجه ابن جرير ٢٢/٣٤٧. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه عبد الرزاق ٢/٢٧٢، وابن جرير ٢٢/٣٤٧. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه ابن جرير ٢٢/٣٤٧.جاء في طبعة الكتاب بتحقيق: د. رضاء الله المباركفوري ص١٤٣ (٩٥) طمس مكان القائل، وقال المحقق: لعل المطموس: عن الضَّحّاك. وفي طبعة الكتاب بتحقيق: أبي بكر سعداوي ٣/٢٧١ (٢٠٩) روى الأثر عن الضَّحّاك دون إسناد.أخرجه ابن أبي الدنيا في الأهوال ٦/١٧٥ (٩٤).تفسير مقاتل بن سليمان ٤/٢٢٢.
56,63," <q>﴿أَفَرَءَیۡتُم مَّا تَحۡرُثُونَ ۝٦٣ ءَأَنتُمۡ تَزۡرَعُونَهُۥۤ أَمۡ نَحۡنُ ٱلزَّ ٰ⁠رِعُونَ ۝٦٤﴾</q> - تفسير ٧٥٢١٨- عن أبي هريرة، قال: قال رسول الله ﷺ: «لا يقولنّ أحدكم: زرعتُ. ولكن ليقُلْ: حرثتُ». قال أبو هريرة: ألم تسمعوا الله يقول: <q>﴿أفَرَأَيْتُمْ ما تَحْرُثُونَ أأَنْتُمْ تَزْرَعُونَهُ أمْ نَحْنُ الزّارِعُونَ﴾</q>{1}. (١٤/٢١٥)= (ز) ٧٥٢١٩- عن أبي عبد الرحمن السلمي -من طريق عطاء- بمثله من قوله غير مرفوع{2}. (١٤/٢١٥) ٧٥٢٢٠- عن عبد الله بن عباس -من طريق السُّدِّيّ، عن أبي مالك وأبي صالح- <q>﴿أفَرَأَيْتُمْ ما تَحْرُثُونَ﴾</q> يقول: ما تزرعون، <q>﴿أأَنْتُمْ تَزْرَعُونَهُ أمْ نَحْنُ الزّارِعُونَ﴾</q> يقول: أليس نحن الذي نُنبِته، أم أنتم المُنبِتون؟{3}. (١٤/٢٥١) ٧٥٢٢١- عن مجاهد بن جبر، في قوله: <q>﴿أأَنْتُمْ تَزْرَعُونَهُ﴾</q>، قال: تُنبِتونه{4}. (١٤/٢١٥) ٧٥٢٢٢- قال مقاتل بن سليمان: <q>﴿أفَرَأَيْتُمْ ما تَحْرُثُونَ أأَنْتُمْ تَزْرَعُونَهُ أمْ نَحْنُ الزّارِعُونَ﴾</q> يعني: نحن الحافظون، يقول: أنتم تنبتونه أم نحن المنبتون له؟{5}. (ز) <q>﴿أَفَرَءَیۡتُم مَّا تَحۡرُثُونَ ۝٦٣ ءَأَنتُمۡ تَزۡرَعُونَهُۥۤ أَمۡ نَحۡنُ ٱلزَّ ٰ⁠رِعُونَ ۝٦٤﴾</q> - آثار متعلقة بالآية ٧٥٢٢٣- عن مجاهد بن جبر -من طريق ليث- لا تقُلْ: زرعتُ. ولكن قل: حرثتُ. إنّ الله هو الزارع{6}. (١٤/٢١٥) ",footnotes:1:أخرجه ابن حبان ١٣/٣٠ (٥٧٢٣)، وابن جرير ٢٢/٣٤٨، والثعلبي ٩/٢١٥، وفيه مسلم الجرمي. قال الطبراني في المعجم الأوسط ٨/٨٠ (٨٠٢٤): «لم يرو هذا الحديث عن هشام إلا مخلد، تفرّد به مسلم الجرمي». وقال البيهقي في الكبرى ٦/٢٢٨ (١١٧٥١) بعد أن ذكره من قول مجاهد: «وقد روي فيه حديث مرفوع غير قوي». وقال الزيلعي في تخريج أحاديث الكشاف ٣/٤٠٩ (١٢٩٠): «ذكره عبد الحق في أحكامه في باب إحياء الموات من جهة البزار، وسكت عنه، فهو صحيح عنده، وأقرّه ابن القطان على ذلك». وقال الهيثمي في المجمع ٤/١٢٠ (٦٥٩٣): «رواه الطبراني في الأوسط، والبزار، وفيه مسلم بن أبي مسلم الجرمي، ولم أجد من ترجمه، وبقية رجاله ثقات». قال ابن حجر في الفتح ٥/٤ عن رواية ابن أبي حاتم: «ورجاله ثقات، إلا أن مسلم بن أبي مسلم الجرمي قال فيه ابن حبان: ربما أخطأ». وقال الألباني في الصحيحة ٦/٧١٥ (٢٨٠١): «وهذا إسناد جيد، رجاله ثقات رجال مسلم، غير مسلم بن أبي مسلم الجرمي».أخرجه ابن أبي حاتم -كما في تفسير ابن كثير ٨/١٧-، وعبد بن حميد -كما في الفتح ٥/٤-. وعزاه السيوطي إلى عبد بن حميد بلفظ: عن أبي عبد الرحمن أنه كره أن يقول: زرعتُ، ويقول: حرثتُ.عزاه السيوطي إلى ابن مردويه.عزاه السيوطي إلى ابن المنذر.تفسير مقاتل بن سليمان ٤/٢٢٢.أخرجه البيهقي في سننه ٦/١٣٨.
  56,64,""
56,65," <q>﴿لَوۡ نَشَاۤءُ لَجَعَلۡنَـٰهُ حُطَـٰمࣰا﴾</q> - تفسير ٧٥٢٢٤- قال عطاء: <q>﴿لَوْ نَشاءُ لَجَعَلْناهُ حُطامًا﴾</q> تِبنًا لا قمح فيه{1}. (ز) ٧٥٢٢٥- قال مقاتل بن سليمان: <q>﴿لَوْ نَشاءُ﴾</q> إذا أدرك وبلغ <q>﴿لَجَعَلْناهُ حُطامًا﴾</q> يعني: هالكًا{2}. (ز) <q>﴿فَظَلۡتُمۡ تَفَكَّهُونَ ۝٦٥﴾</q> - تفسير ٧٥٢٢٦- عن عبد الله بن عباس -من طريق عطية العَوفيّ- في قوله: <q>﴿فَظَلْتُمْ تَفَكَّهُونَ﴾</q>، قال: تَعجّبون{3}. (١٤/٢١٥) ٧٥٢٢٧- عن عبد الله بن عباس -من طريق السُّدِّيّ، عن أبي مالك وأبي صالح- <q>﴿لَوْ نَشاءُ لَجَعَلْناهُ حُطامًا فَظَلْتُمْ تَفَكَّهُونَ﴾</q>، يقول: تَندَّمون{4}. (١٤/٢٥١) ٧٥٢٢٨- عن مجاهد بن جبر -من طريق ابن أبي نجيح- <q>﴿فَظَلْتُمْ تَفَكَّهُونَ﴾</q>، قال: تعَجّبون{5}. (ز) ٧٥٢٢٩- عن الحسن البصري، مثله{6}. (ز) ٧٥٢٣٠- عن عكرمة مولى ابن عباس -من طريق يزيد- في قوله: <q>﴿فَظَلْتُمْ تَفَكَّهُونَ﴾</q>، يقول: تَلاومون{7}. (ز) ٧٥٢٣١- عن الحسن البصري -من طريق أبي رجاء- <q>﴿فَظَلْتُمْ تَفَكَّهُونَ﴾</q>، قال: تَندَّمون{8}٦٤٤٧. (١٤/٢١٥) ٦٤٤٧ وجَّه ابنُ كثير (١٣/٣٨٥) قول الحسن، وقتادة من طريق سعيد بقوله: «ومعناه: إما على ما أنفقتم، أو على ما أسلفتم من الذنوب». ٧٥٢٣٢- قال عطاء= (ز) ٧٥٢٣٣- ومحمد بن السّائِب الكلبي: <q>﴿فَظَلْتُمْ تَفَكَّهُونَ﴾</q> تتعجّبون بما نزل بكم في زرعكم{1}. (ز) ٧٥٢٣٤- عن قتادة بن دعامة -من طريق معمر- <q>﴿فَظَلْتُمْ تَفَكَّهُونَ﴾</q>، قال: تَعجّبون{10}. (ز) ٧٥٢٣٥- عن قتادة بن دعامة -من طريق سعيد- قوله: <q>﴿فَظَلْتُمْ تَفَكَّهُونَ﴾</q>، قال: تَندَّمون{11}. (ز) ٧٥٢٣٦- قال مقاتل بن سليمان: <q>﴿فَظَلْتُمْ تَفَكَّهُونَ﴾</q>، يعني: تعجَّبون{12}. (ز) ٧٥٢٣٧- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿فَظَلْتُمْ تَفَكَّهُونَ﴾</q>، قال: تتفجّعون حين صَنع بحرثكم ما صَنع به. وقرأ قول الله ﷿: <q>﴿إنّا لَمُغْرَمُونَ بَلْ نَحْنُ مَحْرُومُونَ﴾</q> [الواقعة:٦٦-٦٧]، وقرأ قول الله: <q>﴿وإذا انْقَلَبُوا إلى أهْلِهِمُ انْقَلَبُوا فَكِهِينَ﴾</q> [المطففين:٣١]، قال: هؤلاء ناعمين. وقرأ قول الله -جلّ وعزّ-: <q>﴿كَمْ تَرَكُوا مِن جَنّاتٍ وعُيُونٍ﴾</q> إلى قوله: <q>﴿ونَعْمَةٍ كانُوا فِيها فاكِهِينَ﴾</q> [الدخان:٢٥-٢٧]{13}٦٤٤٨. (ز) ٦٤٤٨ اختُلف في معنى: <q>﴿فَظَلْتُمْ تَفَكَّهُونَ﴾</q> في هذه الآية على أقوال: الأول: تتعجَّبون مما نزل بكم في زرعكم. الثاني: تتلاومون. الثالث: تندَّمون. الرابع: تفجَّعون. ورجَّح ابنُ جرير (٢٢/٣٥١) -مستندًا إلى اللغة- القول الأول، وهو قول ابن عباس، ومجاهد، وقتادة، ومقاتل، وعلَّل ذلك بأن أصله: «من التفكُّه بالحديث: إذا حدَّث الرجلُ الرجلَ بالحديث يُعْجَب منه، ويَلْهى به، فكذلك ذلك، وكأن معنى الكلام: فأقمتم تتعجَّبون، يُعَجِّب بعضكم بعضًا مما نزل بكم». واستدرك ابنُ عطية (٨/٢٠٦) على هذه الأقوال الأربعة بقوله: «وهذا كلّه تفسير لا يخصُّ اللفظة، والذي يخصُّ اللفظة هو: تطرحون الفكاهة عن أنفسكم، وهي المَسَرَّة والجزل، ورجلٌ فَكِهٌ: إذا كان منبسط النفس غير مكترث بالشيء». ",footnotes:1:تفسير البغوي ٨/٢٠.تفسير مقاتل بن سليمان ٤/٢٢٢.أخرجه ابن جرير ٢٢/٣٤٩.عزاه السيوطي إلى ابن مردويه.أخرجه عبد الرزاق ٢/٢٧٢، وابن جرير ٢٢/٣٤٩، وابن أبي حاتم -كما في الفتح ٨/٦٢٦- بلفظ: تتعجبون مما نزل بكم في زرعكم.أخرجه ابن المنذر -كما في الفتح ٨/٦٢٦-.أخرجه ابن جرير ٢٢/٣٤٩-٣٥٠، وبمثله من طريق سماك.أخرجه ابن جرير ٢٢/٣٥٠. وعزاه السيوطي إلى عبد بن حميد.تفسير البغوي ٨/٢٠.أخرجه ابن جرير ٢٢/٣٤٩، وعبد الرزاق -كما في الفتح ٨/٦٢٦-.أخرجه ابن جرير ٢٢/٣٥٠.تفسير مقاتل بن سليمان ٤/٢٢٢. وفي تفسير البغوي ٨/٢٠ بنحوه منسوبًا إلى مقاتل دون تعيينه.أخرجه ابن جرير ٢٢/٣٥٠، ٣٥١.
56,66," <q>﴿إِنَّا لَمُغۡرَمُونَ ۝٦٦﴾</q> - تفسير ٧٥٢٣٨- عن عبد الله بن عباس -من طريق السُّدِّيّ، عن أبي مالك وأبي صالح- <q>﴿إنّا لَمُغْرَمُونَ﴾</q>، يقول: إنّا لَمُوّارٌ به{1}. (١٤/٢٥١) ٧٥٢٣٩- قال عبد الله بن عباس، في قوله: <q>﴿إنّا لَمُغْرَمُونَ﴾</q> معذَّبون{2}. (ز) ٧٥٢٤٠- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿إنّا لَمُغْرَمُونَ﴾</q>، قال: مُلقَون للشرّ{3}. (١٤/٢١٦) ٧٥٢٤١- قال مجاهد بن جبر -من طريق معمر- في قوله: <q>﴿إنّا لَمُغْرَمُونَ﴾</q>، أي: لَمُولع بنا{4}. (ز) ٧٥٢٤٢- عن عكرمة مولى ابن عباس -من طريق يزيد النحوي- في قوله: <q>﴿إنّا لَمُغْرَمُونَ﴾</q>، قال: إنّا لَمُولع بنا{5}. (ز) ٧٥٢٤٣- قال الضَّحّاك بن مُزاحِم: <q>﴿إنّا لَمُغْرَمُونَ﴾</q> غرمنا أموالنا، وصار ما أنفقنا غُرمًا علينا، والمُغرم الذي ذهب مالُه بغير عِوَض{2}. (ز) ٧٥٢٤٤- عن قتادة بن دعامة -من طريق سعيد- <q>﴿إنّا لَمُغْرَمُونَ﴾</q>: أي: مُعذّبون{7}. (ز) ٧٥٢٤٥- عن قتادة بن دعامة -من طريق شعبة- <q>﴿لَمُغْرَمُونَ﴾</q>: لَملزمون{8}. (ز) ٧٥٢٤٦- قال مقاتل بن سليمان: وقلتم: <q>﴿إنّا لَمُغْرَمُونَ﴾</q>، يعني: إنّا لَمُولع بنا الغُرم{9}٦٤٤٩. (ز) ٦٤٤٩ اختُلف في معنى: <q>﴿إنّا لَمُغْرَمُونَ﴾</q> على أقوال: الأول: إنّا لَمُولعٌ بنا. الثاني: إنّا لَمعذَّبون. الثالث: لَمُلْقَون للشر. ورجَّح ابنُ جرير (٢٢/٣٥٢) -مستندًا إلى لغة العرب- القول الثاني، وهو قول قتادة، وعلَّل ذلك بقوله: «وذلك أن الغرام عند العرب: العذاب». واستشهد ببيتٍ من الشعر. ووجَّه ابنُ عطية (٨/٢٠٦) القول الثاني بأنه: «من الغرام وهو أشد العذاب، ومنه قوله تعالى: <q>﴿إنَّ عَذابَها كانَ غَرامًا﴾</q> [الفرقان:٦٥]». واستشهد له ببيت من الشعر، وذكر احتمالًا آخر: «أن يكون المعنى: إنّا لمحمَّلون الغرام». ثم وجَّهه بقوله: «أي: غرمنا في النفقة، وذهب زرعنا، تقول: غَرِمَ الرجل وأَغْرَمْتُه فهو مُغْرم». ",footnotes:1:عزاه السيوطي إلى ابن مردويه.تفسير البغوي ٨/٢١.تفسير مجاهد ص٦٤٤، وأخرجه ابن جرير ٢٢/٣٥٢، والفريابي -كما في تغليق التعليق ٤/٣٣٥-. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه عبد الرزاق ٢/٢٧٣، وابن جرير ٢٢/٣٥١.أخرجه ابن جرير ٢٢/٣٥١.تفسير البغوي ٨/٢١.أخرجه ابن جرير ٢٢/٣٥٢.أخرجه ابن أبي حاتم -كما في الفتح ٨/٦٢٦-.تفسير مقاتل بن سليمان ٤/٢٢٢.
56,67," <q>﴿بَلۡ نَحۡنُ مَحۡرُومُونَ ۝٦٧﴾</q> - تفسير ٧٥٢٤٧- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿بَلْ نَحْنُ مَحْرُومُونَ﴾</q>، قال: مَحدُودون{1}٦٤٥٠. (١٤/٢١٦) ٦٤٥٠ وجَّه ابنُ كثير (١٣/٣٨٥) قول مجاهد بقوله: «يعني: لا حظّ لنا». ٧٥٢٤٨- عن قتادة بن دعامة -من طريق سعيد- <q>﴿بَلْ نَحْنُ مَحْرُومُونَ﴾</q>، قال: جُوزينا، فحُرمنا{2}. (ز) ٧٥٢٤٩- عن قتادة بن دعامة -من طريق معمر- في قوله: <q>﴿بَلْ نَحْنُ مَحْرُومُونَ﴾</q>، قال: أي: محارَفون{3}٦٤٥١. (ز) ٦٤٥١ وجَّه ابن كثير (١٣/٣٨٥) قول قتادة بقوله: «أي: لا يثبت لنا مال، ولا ينتج لنا ربح». ٧٥٢٥٠- عن زيد بن أسلم -من طريق ابن عيّاش- في قول الله: <q>﴿والَّذِينَ فِي أمْوالِهِمْ حَقٌّ مَعْلُومٌ لِلسّائِلِ والمَحْرُومِ﴾</q> [المعارج:٢٤-٢٥]: ... والمحروم: الذي يُصاب زرعه أو حرْثه أو نسل ماشيته، فيكون له حقّ على مَن لم يُصِبْه من المسلمين، كما قال لأصحاب الجنة حين أهلك جنّتهم، فقالوا: <q>﴿بَلْ نَحْنُ مَحْرُومُونَ﴾</q> [القلم:٢٧]، وقال أيضًا: <q>﴿لَوْ نَشاءُ لَجَعَلْناهُ حُطامًا فَظَلْتُمْ تَفَكَّهُونَ إنّا لَمُغْرَمُونَ بَلْ نَحْنُ مَحْرُومُونَ﴾</q> [الواقعة:٦٥-٦٧]{4}. (ز) ٧٥٢٥١- قال مقاتل بن سليمان: <q>﴿بَلْ نَحْنُ مَحْرُومُونَ﴾</q>، ولقُلتم: بل حُرمنا خيرها{5}. (ز) ",footnotes:1:تفسير مجاهد ص٦٤٤، وأخرجه ابن جرير ٢٢/٣٥٢-٣٥٤، والفريابي -كما في تغليق التعليق ٤/٣٣٥-. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه ابن جرير ٢٢/٣٥٣.أخرجه عبد الرزاق في تفسيره ٢/٢٧٢، وابن جرير ٢٢/٣٥٣.أخرجه عبد الله بن وهب في الجامع -تفسير القرآن ١/٦١-٦٢ (١٣٦).تفسير مقاتل بن سليمان ٤/٢٢٢.
56,68," <q>﴿أَفَرَءَیۡتُمُ ٱلۡمَاۤءَ ٱلَّذِی تَشۡرَبُونَ ۝٦٨ ءَأَنتُمۡ أَنزَلۡتُمُوهُ مِنَ ٱلۡمُزۡنِ أَمۡ نَحۡنُ ٱلۡمُنزِلُونَ ۝٦٩﴾</q> - تفسير ٧٥٢٥٢- عن عبد الله -من طريق قيس بن سكن- قال: إنّ الله -تبارك وتعالى- يُنشِئ السحاب، فيُرسل الريح، فتؤلّف السحاب، فتُدِرُّ كما تُدِرُّ اللّقحة. وقرأ: <q>﴿أأَنْتُمْ أنْزَلْتُمُوهُ مِنَ المُزْنِ أمْ نَحْنُ المُنْزِلُونَ﴾</q>{1}. (ز) ٧٥٢٥٣- عن عبد الله بن عباس -من طريق عطية العَوفيّ- <q>﴿أأَنْتُمْ أنْزَلْتُمُوهُ مِنَ المُزْنِ﴾</q>، قال: السّحاب{2}. (١٤/٢١٦) ٧٥٢٥٤- عن عبد الله بن عباس -من طريق السُّدِّيّ، عن أبي مالك وأبي صالح- <q>﴿أأَنْتُمْ أنْزَلْتُمُوهُ مِن المُزْنِ﴾</q>، يقول: من السحاب{3}. (١٤/٢٥١) ٧٥٢٥٥- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿أأَنْتُمْ أنْزَلْتُمُوهُ مِن المُزْنِ﴾</q>، قال: السحاب{4}. (١٤/٢١٦) ٧٥٢٥٦- عن الحسن البصري= (ز) ٧٥٢٥٧- وقتادة بن دعامة - من طريق سعيد-، مثله{5}. (١٤/٢١٦) ٧٥٢٥٨- قال مقاتل بن سليمان: <q>﴿أأَنْتُمْ أنْزَلْتُمُوهُ مِنَ المُزْنِ﴾</q> يعني: من السحاب، <q>﴿أمْ نَحْنُ المُنْزِلُونَ﴾</q>{6}. (ز) ٧٥٢٥٩- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿أأَنْتُمْ أنْزَلْتُمُوهُ مِنَ المُزْنِ أمْ نَحْنُ المُنْزِلُونَ﴾</q> قال: المُزْن: السّحاب اسمها، <q>﴿أنْزَلْتُمُوهُ مِنَ المُزْنِ﴾</q> قال: السّحاب{7}. (ز) ",footnotes:1:أخرجه البزار في البحر الزخار المعروف بمسند البزار ٨/١٧٩-١٨٠ (٣٢١٢).أخرجه ابن جرير ٢٢/٣٥٤. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.عزاه السيوطي إلى ابن مردويه.تفسير مجاهد ص٦٤٥، وأخرجه ابن جرير ٢٢/٣٥٢-٣٥٤، والفريابي -كما في تغليق التعليق ٤/٣٣٥-. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.عزاه السيوطي إلى عبد بن حميد. وأخرجه ابن جرير ٢٢/٣٥٤ عن قتادة.تفسير مقاتل بن سليمان ٤/٢٢٣.أخرجه ابن جرير ٢٢/٣٥١، ٣٥٤.
  56,69,""
56,70," <q>﴿لَوۡ نَشَاۤءُ جَعَلۡنَـٰهُ أُجَاجࣰا فَلَوۡلَا تَشۡكُرُونَ ۝٧٠﴾</q> - تفسير ٧٥٢٦٠- قال عبد الله بن عباس: <q>﴿لَوْ نَشاءُ جَعَلْناهُ أُجاجًا﴾</q> شديد المُلوحة{1}. (ز) ٧٥٢٦١- عن عبد الله بن عباس -من طريق السُّدِّيّ، عن أبي مالك وأبي صالح- <q>﴿لَوْ نَشاءُ جَعَلْناهُ أُجاجًا﴾</q> يقول: مُرًّا؛ <q>﴿فَلَوْلا تَشْكُرُونَ﴾</q> يقول: فهلّا تشكرون{2}. (١٤/٢٥١) ٧٥٢٦٢- عن عبد الله بن عباس = (ز) ٧٥٢٦٣- ومجاهد بن جبر= (ز) ٧٥٢٦٤- وقتادة بن دعامة، في قوله: <q>﴿أُجاجًا﴾</q>: منصبًّا{3}. (ز) ٧٥٢٦٥- قال الحسن البصري: <q>﴿لَوْ نَشاءُ جَعَلْناهُ أُجاجًا﴾</q> مُرًّا{1}. (ز) ٧٥٢٦٦- عن قتادة بن دعامة: الأجاج: المرّ{5}. (ز) ٧٥٢٦٧- قال مقاتل بن سليمان: <q>﴿لَوْ نَشاءُ﴾</q> بعد العُذُوبة <q>﴿جَعَلْناهُ أُجاجًا﴾</q> يعني: مالِحًا، مُرًّا مِن شدة المُلوحة؛ <q>﴿فَلَوْلا﴾</q> يعني: فهلّا <q>﴿تَشْكُرُونَ﴾</q> ربَّ هذه النّعم، فتوحّدونه حين سقاكم ماءً عذبًا{6}. (ز) <q>﴿لَوۡ نَشَاۤءُ جَعَلۡنَـٰهُ أُجَاجࣰا فَلَوۡلَا تَشۡكُرُونَ ۝٧٠﴾</q> - آثار متعلقة بالآية ٧٥٢٦٨- عن أبي جعفر، عن النبيِّ ﷺ أنه كان إذا شرب الماء، قال: «الحمد لله الذي سقانا عَذبًا فُراتًا برحمته، ولم يجعله مِلْحًا أُجاجًا بذنوبنا»{7}. (١٤/٢١٦) ",footnotes:1:تفسير البغوي ٨/٢١.عزاه السيوطي إلى ابن مردويه.أخرجه ابن جرير -كما في الفتح ٥/٢٩-.تفسير البغوي ٨/٢١.أخرجه ابن أبي حاتم -كما في الفتح ٥/٢٩-. وفي المطبوع من تفسير عبد الرزاق ٢/٧٠ من طريق معمر، ومن تفسير ابن أبي حاتم ٨/٢٧٠٨ من طريق سعيد، عند قوله تعالى: <q>﴿وهذا ملح أجاج﴾</q> [الفرقان:٥٣].تفسير مقاتل بن سليمان ٤/٢٢٣.أخرجه ابن أبي حاتم -كما في تفسير ابن كثير ٨/١٨-. ضعّفه الألباني في السلسلة الضعيفة (٤٢٠٢).
56,71," <q>﴿أَفَرَءَیۡتُمُ ٱلنَّارَ ٱلَّتِی تُورُونَ ۝٧١﴾</q> - تفسير ٧٥٢٦٩- عن عبد الله بن عباس -من طريق السُّدِّيّ، عن أبي مالك وأبي صالح- <q>﴿أفَرَأَيْتُمُ النّارَ الَّتِي تُورُونَ﴾</q>، يقول: تَقدَحون{1}. (١٤/٢٥١) ٧٥٢٧٠- قال مقاتل بن سليمان: <q>﴿أفَرَأَيْتُمُ النّارَ الَّتِي تُورُونَ﴾</q> يعني: تُوقِدون مِن الشجر والحجارة والقَصب، إلا العُنّاب{2}. (ز) ",footnotes:1:عزاه السيوطي إلى ابن مردويه.تفسير مقاتل بن سليمان ٤/٢٢٣.
56,72," <q>﴿ءَأَنتُمۡ أَنشَأۡتُمۡ شَجَرَتَهَاۤ أَمۡ نَحۡنُ ٱلۡمُنشِـُٔونَ ۝٧٢﴾</q> - تفسير ٧٥٢٧١- عن عبد الله بن عباس -من طريق السُّدِّيّ، عن أبي مالك وأبي صالح- <q>﴿أأَنْتُمْ أنْشَأْتُمْ﴾</q> يقول: خلَقتم <q>﴿شَجَرَتَها أمْ نَحْنُ المُنْشِئُونَ﴾</q> قال: وهي مِن كلّ شجرة، إلا في العُنّاب{1}، وتكون في الحجارة{2}. (١٤/٢٥١-٢٥٢) ٧٥٢٧٢- قال مقاتل بن سليمان: <q>﴿أأَنْتُمْ أنْشَأْتُمْ﴾</q> يعني: خلقتم شجرتها، <q>﴿أمْ نَحْنُ المُنْشِئُونَ﴾</q> يعني: الخالقون{3}٦٤٥٢. (ز) ٦٤٥٢ نقل ابنُ عطية (٨/٢٠٧) في معنى: <q>﴿أأَنْتُمْ أنْشَأْتُمْ شَجَرَتَها﴾</q> عن بعض أهل النظر قولهم: «أراد بالشجرة: نفس النار». ثم وجَّهه بقوله: «كأنه تعالى يقول: نوعها أو جنسها، فاستعار الشجرة لذلك». ثم انتقده قائلًا: «وهو قولٌ فيه تكلُّف». ",footnotes:1:العناب: شجر شائك مِن الفصيلة السدرية، يبلغ ارتفاعه ستة أمتار، ويطلق العناب على ثمره أيضًا، وهو أحمر حلو لذيذ الطعم على شكل ثمرة النبق. الوسيط (عنب).عزاه السيوطي إلى ابن مردويه.تفسير مقاتل بن سليمان ٤/٢٢٣.
56,73," <q>﴿نَحۡنُ جَعَلۡنَـٰهَا تَذۡكِرَةࣰ﴾</q> - تفسير ٧٥٢٧٣- عن عبد الله بن عباس، <q>﴿نَحْنُ جَعَلْناها تَذْكِرَةً﴾</q>، قال: تذكرةٌ للنار الكبرى{1}. (١٤/٢١٦) ٧٥٢٧٤- عن عبد الله بن عباس -من طريق السُّدِّيّ، عن أبي مالك وأبي صالح- <q>﴿نَحْنُ جَعَلْناها تَذْكِرَةً﴾</q>، يقول: يتذكّر بها نار الآخرة العليا{2}. (١٤/٢٥٢) ٧٥٢٧٥- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿نَحْنُ جَعَلْناها تَذْكِرَةً﴾</q>، قال: هذه النار تذكرةٌ للنار الكبرى{3}. (١٤/٢١٦) ٧٥٢٧٦- قال عكرمة مولى ابن عباس: <q>﴿تَذْكِرَةً﴾</q> تذكرةٌ للنار الكبرى؛ إذا رآها الرائي ذَكر جهنم{4}. (ز) ٧٥٢٧٧- قال عطاء: <q>﴿تَذْكِرَةً﴾</q> موعظة يتّعظ بها المؤمن{4}. (ز) ٧٥٢٧٨- عن قتادة بن دعامة -من طريق معمر- <q>﴿نَحْنُ جَعَلْناها تَذْكِرَةً﴾</q>، قال: تذكرةٌ للنار الكبرى{6}. (١٤/٢١٧) ٧٥٢٧٩- قال مقاتل بن سليمان: <q>﴿نَحْنُ جَعَلْناها﴾</q> هذه النار التي في الدنيا <q>﴿تَذْكِرَةً﴾</q> لنار جهنم الكبرى{7}. (ز) <q>﴿وَمَتَـٰعࣰا لِّلۡمُقۡوِینَ ۝٧٣﴾</q> - تفسير ٧٥٢٨٠- عن عبد الله بن عباس -من طريق علي- <q>﴿ومَتاعًا لِلْمُقْوِينَ﴾</q>، قال: للمسافرين{8}. (١٤/٢١٦) ٧٥٢٨١- عن عبد الله بن عباس -من طريق السُّدِّيّ، عن أبي مالك وأبي صالح- <q>﴿ومَتاعًا لِلْمُقْوِينَ﴾</q>، قال: والمُقوِي: هو الذي لا يجد نارًا، فيُخْرِج زِنده، فيستنوِر ناره، فهي متاعٌ له{2}. (١٤/٢٥٢) ٧٥٢٨٢- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿ومَتاعًا لِلْمُقْوِينَ﴾</q>، قال: للمستمتعين؛ الناس أجمعين. وفي لفظ: للحاضر، والبادي{10}. (١٤/٢١٦) ٧٥٢٨٣- عن الضَّحّاك بن مُزاحِم -من طريق عبيد- يقول في قوله: <q>﴿ومَتاعًا لِلْمُقْوِينَ﴾</q>، قال: للمسافرين{11}. (ز) ٧٥٢٨٤- قال عكرمة مولى ابن عباس: <q>﴿ومَتاعًا لِلْمُقْوِينَ﴾</q>، يعني: للمُستمتعين بها مِن الناس أجمعين، المسافرين والحاضرين، يستضيئون بها في الظّلمة، ويصْطَلون مِن البرد، وينتفعون بها في الطّبخ والخبز{12}. (ز) ٧٥٢٨٥- عن الحسن البصري، <q>﴿ومَتاعًا لِلْمُقْوِينَ﴾</q>، قال: للمسافرين{13}. (١٤/٢١٧) ٧٥٢٨٦- عن قتادة بن دعامة -من طريق سعيد- <q>﴿ومَتاعًا لِلْمُقْوِينَ﴾</q>، قال: للمسافرين؛ كم مِن قوم قد سافروا، ثم أرْمَلوا، فأجّجوا نارًا، فاستدفؤوا بها، وانتفعوا بها!{14}. (١٤/٢١٧) ٧٥٢٨٧- قال إسماعيل السُّدِّيّ = (ز) ٧٥٢٨٨- والربيع بن أنس: <q>﴿ومَتاعًا لِلْمُقْوِينَ﴾</q> يعني: للمنزلين المقترين المُرملين، الذين لا زاد معهم، يعني: نارًا يُوقدون، فيختبزون بها{15}. (ز) ٧٥٢٨٩- عن خُصَيف -من طريق عتاب بن بشير- في قوله: <q>﴿ومَتاعًا لِلْمُقْوِينَ﴾</q>، قال: للخلق{11}. (ز) ٧٥٢٩٠- قال مقاتل بن سليمان: وهي <q>﴿مَتاعًا لِلْمُقْوِينَ﴾</q>، يعني: متاعًا للمسافرين لِمَن كان بأرض فَلاة وللأعراب{17}. (ز) ٧٥٢٩١- قال عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿ومَتاعًا لِلْمُقْوِينَ﴾</q>، قال: المُقوِي: الجائع. وفي كلام العرب يقول: أقويتُ من هكذا وكذا. ما أكلْتُ مِن هكذا وكذا شيئًا{18}٦٤٥٣. (ز) ٦٤٥٣ اختُلف في معنى: «المُقْوِين» في هذه الآية على أقوال: الأول: المسافرون. الثاني: المستمتعون بها. الثالث: الجائعون. ورجَّح ابنُ جرير (٢٢/٣٥٨) -مستندًا إلى اللغة- القول الأول، وهو قول ابن عباس، والضَّحّاك، والحسن، وقتادة، ومقاتل، فقال: «وأولى الأقوال في ذلك بالصواب عندي قولُ مَن قال: عُنِيَ بذلك: للمسافر الذي لا زاد معه، ولا شيء له. وأصله من قولهم: أقْوَت الدار: إذا خَلَت من أهلها وسكانها». واستشهد ببيتٍ من الشعر. وعلَّق ابنُ كثير (١٣/٣٨٧) على القول الثاني بقوله: «وهذا التفسير أعمُّ مِن غيره، فإنّ الحاضر والبادي مِن غني وفقير، الكلّ محتاجون للطبخ والاصطلاء والإضاءة وغير ذلك من المنافع. ثم مِن لطف الله تعالى أنْ أودعها في الأحجار، وخالص الحديد، بحيث يتمكّن المسافر مِن حمْل ذلك في متاعه وبين ثيابه، فإذا احتاج إلى ذلك في منزله أخرج زِنده وأورى، وأوقد ناره فاطبخ بها واصطلى، واشتوى واستأنس بها، وانتفع بها سائر الانتفاعات؛ فلهذا أفرد المسافرون، وإن كان ذلك عامًّا في حق الناس كلّهم». وذكر ابنُ عطية (٨/٢٠٧) أن معنى «المُقْوِين» في هذه الآية: «الكائنون في الأرض القواء، وهي الفيافي». ثم ذكر أنّ بعض الناس «عبر في تفسير»المُقْوِين«بأشياء ضعيفة، كقول ابن زيد: للجائعين ونحوه». ولم يذكر مستندًا، ثم علَّق على القول الأول بقوله: «ومَن قال: معناه: للمسافرين. فهو نحو ما قلناه، وهي عبارة ابن عباس ﵄، تقول: أصبح الرجل: دخل في الصباح، وأَصْحَرَ: دخل في الصحراء، وأقوى: دخل في الأرض القَواء، ومنه: أقْوَت الدار، أقوى الطَّلَلُ، أي: صار قواءً ...». وذكر ابنُ القيم (٣/١١٤) أنّ «المُقْوين»: هم المسافرون. ثم علَّق بقوله: «وخصّ المُقْوين بالذكر، وإن كانت منفعتها عامةً للمسافرين والمقيمين تنبيهًا لعباده -والله أعلم بمراده مِن كلامه- على أنهم كلّهم مسافرون، وأنهم في هذه الدار على جناح سفر ليسوا هم مقيمين ولا مستوطنين، وأنهم عابرو سبيل وأبناء سفر». ",footnotes:1:أخرجه ابن أبي حاتم من طريق علي -كما في الإتقان ٢/٤٧-. وعزاه السيوطي إلى عبد بن حميد، وابن جرير، وابن المنذر، وابن مردويه.عزاه السيوطي إلى ابن مردويه.تفسير مجاهد ص٦٤٥، وأخرجه ابن جرير ٢٢/٣٥٥-٣٥٦ بنحوه من طريق جابر، وهناد (٢٣٧). وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.تفسير البغوي ٨/٢١.تفسير البغوي ٨/٢١.أخرجه عبد الرزاق ٢/٢٧٣، وابن جرير ٢٢/٣٥٥. وعزاه السيوطي إلى عبد بن حميد.تفسير مقاتل بن سليمان ٤/٢٢٣. وفي تفسير البغوي ٨/٢١ نحوه عن مقاتل دون تعيينه.أخرجه ابن جرير ٢٢/٣٥٦، وبمثله من طريق عطية، وابن أبي حاتم -كما في الإتقان ٢/٤٧-. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن مردويه.عزاه السيوطي إلى ابن مردويه.تفسير مجاهد ص٦٤٥، وأخرجه ابن جرير ٢٢/٣٥٥-٣٥٧، وبنحوه من طريق جابر، وهناد (٢٣٧). وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه ابن جرير ٢٢/٣٥٧.تفسير البغوي ٨/٢٢.ذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٤/٣٤٢-. وعزاه السيوطي إلى عبد بن حميد.أخرجه عبد الرزاق ٢/٢٧٣، وابن جرير ٢٢/٣٥٧ كلاهما من طريق معمر بنحوه. وعزاه السيوطي إلى عبد بن حميد.تفسير الثعلبي ٩/٢١٧.أخرجه ابن جرير ٢٢/٣٥٧.تفسير مقاتل بن سليمان ٤/٢٢٣.أخرجه ابن جرير ٢٢/٣٥٨.
56,74," <q>﴿فَسَبِّحۡ بِٱسۡمِ رَبِّكَ ٱلۡعَظِیمِ ۝٧٤﴾</q> - تفسير ٧٥٢٩٢- عن عبد الله بن عباس -من طريق السُّدِّيّ، عن أبي مالك وأبي صالح- <q>﴿فَسَبِّحْ بِاسْمِ رَبِّكَ العَظِيمِ﴾</q>، يقول: فَصَلِّ لربّك العظيم{1}. (١٤/٢٥٢) ٧٥٢٩٣- قال مقاتل بن سليمان: <q>﴿فَسَبِّحْ﴾</q> يقول: اذكر التوحيد <q>﴿بِاسْمِ رَبِّكَ﴾</q> يا محمد <q>﴿العَظِيمِ﴾</q> يعني: الكبير، فلا أكبر منه{2}. (ز) ",footnotes:1:عزاه السيوطي إلى ابن مردويه.تفسير مقاتل بن سليمان ٤/٢٢٣.
56,75," <q>﴿فَلَاۤ أُقۡسِمُ بِمَوَ ٰ⁠قِعِ ٱلنُّجُومِ ۝٧٥﴾</q> - قراءات ٧٥٢٩٤- عن عبد الله بن مسعود -من طريق أبي حَرِيز قاضي سجستان- أنه قرأ: ‹فَلَآ أُقْسِمُ بِمَوْقِعِ النُّجُومِ›{1}. (ز) ٧٥٢٩٥- عن مُغيرة، عن إبراهيم أنه كان يقرأ: <q>﴿فَلَآ أُقْسِمُ بِمَواقِعِ النُّجُومِ﴾</q>{2}. (ز) ٧٥٢٩٦- عن عاصم أنه قرأ: <q>﴿فَلَآ أُقْسِمُ﴾</q> ممدودة مرفوعة الألف <q>﴿بِمَواقِعِ النُّجُومِ﴾</q> على الجماع{3}٦٤٥٤. (١٤/٢١٧) ٦٤٥٤ اختلفت القرأة في قراءة قوله تعالى: <q>﴿بِمَواقِعِ النُّجُومِ﴾</q> على قراءتين: الأولى: <q>﴿بمواقع النجوم﴾</q> على الجمع. الثانية: ‹بِمَوْقِعِ النُّجُومِ› على الإفراد. ورجَّح ابنُ جرير (٢٢/٣٦٢) «أنهما قراءتان معروفتان بمعنًى واحد، فبأيَّتِهما قرأ القارئ فمصيبٌ». ووجَّه ابنُ القيم (٣/١١٦) القراءة الثانية بقوله: «ومن قرأ ‹بِمَوْقِعِ النُّجُومِ› على الإفراد؛ فلدلالة الواحد المضاف إلى الجمع على التعدد، والموقع اسم جنس، والمصادر إذا اختلفت جُمعت، وإذا كان النوع واحدًا أُفردت، قال تعالى: <q>﴿إنَّ أنْكَرَ الأَصْواتِ لَصَوْتُ الحَمِيرِ﴾</q> [لقمان:١٩]، فجمع الأصوات لتعدد النوع، وأفرد صوت الحمير لوحدته، فإفراد موقع النجوم لوحدة المضاف إليه، وتعدد الموقع لتعدده؛ إذ لكل نجم موقع». ونحوه قال ابنُ عطية (٨/٢٠٩). <q>﴿فَلَاۤ أُقۡسِمُ بِمَوَ ٰ⁠قِعِ ٱلنُّجُومِ ۝٧٥﴾</q> - نزول الآيات ٧٥٢٩٧- عن عبد الله بن عباس -من طريق أبي زُمَيْل- قال: مُطِر الناسُ على عهد النبي ﷺ، فقال النبي ﷺ: «أصبح مِن الناس شاكر، ومنهم كافر، قالوا: هذه رحمة الله. وقال بعضهم: لقد صدق نَوء كذا وكذا». قال: فنَزَلَتْ هذه الآية: <q>﴿فَلا أُقْسِمُ بِمَواقِعِ النُّجُومِ﴾</q> حتى بلغ: <q>﴿وتَجْعَلُونَ رِزْقَكُمْ أنَّكُمْ تُكَذِّبُونَ﴾</q>{4}. (ز) <q>﴿فَلَاۤ أُقۡسِمُ﴾</q> - تفسير ٧٥٢٩٨- عن عبد الله بن عباس -من طريق السُّدِّيّ، عن أبي مالك وأبي صالح- في قوله: <q>﴿فَلا أُقْسِمُ﴾</q> يقول: أقسم <q>﴿بِمَواقِعِ النُّجُومِ﴾</q>{5}. (١٤/٢٥٢) ٧٥٢٩٩- عن سعيد بن جُبَير -من طريق الحسن بن مسلم- <q>﴿فَلا أُقْسِمُ﴾</q>، قال: أقسم{6}٦٤٥٥. (١٤/٢١٧) ٦٤٥٥ نقل ابنُ عطية (٨/٢٠٨) في معنى: «لا» من قوله تعالى: <q>﴿فَلا أُقْسِمُ﴾</q> عن سعيد بن جُبَير، وبعض النحويين قولهم: هي نافية. ثم وجَّهه بقوله: «كأنه تعالى يقول: فَلا صحة لما يقوله الكفار، ثم ابتدأ -تبارك وتعالى- فقال: <q>﴿أُقْسِمُ﴾</q>». ونقل ابنُ كثير (١٣/٣٨٩) عن الضَّحّاك من طريق جويبر قوله: «إنّ الله لا يقسم بشيء مِن خلْقه، ولكنه استفتاح يستفتح به كلامه». ثم انتقده قائلًا: «وهذا القول ضعيف». ولم يذكر مستندًا. <q>﴿بِمَوَ ٰ⁠قِعِ ٱلنُّجُومِ ۝٧٥﴾</q> - تفسير ٧٥٣٠٠- عن عبد الله بن مسعود -من طريق المنهال بن عمرو- <q>﴿فَلا أُقْسِمُ بِمَواقِعِ النُّجُومِ﴾</q>، قال: بمحكم القرآن، فكان يَنزِل على النبيِّ ﷺ نجومًا{7}. (١٤/٢١٩) ٧٥٣٠١- عن عبد الله بن عباس -من طريق سعيد بن جُبَير- في قوله: <q>﴿فَلا أُقْسِمُ بِمَواقِعِ النُّجُومِ﴾</q> قال: القرآن، <q>﴿وإنَّهُ لَقَسَمٌ لَوْ تَعْلَمُونَ عَظِيمٌ﴾</q> قال: القرآن{8}. (١٤/٢١٨) ٧٥٣٠٢- عن عبد الله بن عباس -من طريق سعيد بن جُبَير- قال: أُنزِل القرآنُ في ليلة القدر مِن السماء العليا إلى السماء الدنيا جُملة واحدة، ثم فُرّق في السنين. وفي لفظ: ثم نزل من السماء الدنيا إلى الأرض نجومًا{9}. ثم قرأ: <q>﴿فَلا أُقْسِمُ بِمَواقِعِ النُّجُومِ﴾</q>{10}. (١٤/٢١٨) ٧٥٣٠٣- عن عبد الله بن عباس: <q>﴿فَلا أُقْسِمُ بِمَواقِعِ النُّجُومِ﴾</q> بألفٍ. قال: نجوم القرآن حين ينزل{5}. (١٤/٢١٩) ٧٥٣٠٤- عن عبد الله بن عباس، قال: أُنزِل القرآنُ إلى السماء الدنيا جملة واحدة، ثم أُنزِل إلى الأرض نجومًا؛ ثلاث آيات، وخمس آيات، وأقلّ، وأكثر، فقال: <q>﴿فَلا أُقْسِمُ بِمَواقِعِ النُّجُومِ﴾</q>{12}. (١٤/٢١٩) ٧٥٣٠٥- عن عبد الله بن عباس -من طريق عطية- <q>﴿فَلا أُقْسِمُ بِمَواقِعِ النُّجُومِ﴾</q>، قال: مستقرّ الكتاب؛ أوّله وآخره{13}. (١٤/٢٢٠) ٧٥٣٠٦- عن عبد الله بن عباس -من طريق السُّدِّيّ، عن أبي مالك وأبي صالح-: أنّ عُلَيَّة بن الأسود أو نافع بن الحكم أتاه، فقال له: يا ابن عباس، إني أقرأ آيات من كتاب الله، أخشى أن يكون قد دخلني منها شيء. قال ابن عباس: ولِمَ ذلك؟ قال: لأني أسمع الله يقول: <q>﴿إنّا أنْزَلْناهُ فِي لَيْلَةِ القَدْرِ﴾</q> [القدر:١]، ويقول: <q>﴿إنّا أنْزَلْناهُ فِي لَيْلَةٍ مُبارَكَةٍ إنّا كُنّا مُنْذِرِينَ﴾</q> [الدخان:٣]، ويقول في آية أخرى: <q>﴿شَهْرُ رَمَضانَ الَّذِي أُنْزِلَ فِيهِ القُرْآنُ﴾</q> [البقرة:١٨٥]، وقد نزل في الشهور كلّها شوال وغيره. قال ابن عباس: ويلك، إنّ جملة القرآن أُنزل من السماء في ليلة القدر إلى بدء موقع النجوم. يقول: إلى سماء الدنيا، فنزل به جبريل في ليلة منه، وهي ليلة القَدْر المباركة، وهي في رمضان، ثم نزل به على محمد ﷺ في عشرين سنة؛ الآية والآيتين والأكثر، فذلك قوله: <q>﴿فَلا أُقْسِمُ﴾</q> يقول: أقسم <q>﴿بِمَواقِعِ النُّجُومِ﴾</q>{5}. (١٤/٢٥٢) ٧٥٣٠٧- عن مجاهد بن جبر -من طريق الأعمش- <q>﴿فَلا أُقْسِمُ بِمَواقِعِ النُّجُومِ﴾</q>، قال: هو مُحكَم القرآن{15}. (١٤/٢١٩) ٧٥٣٠٨- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿فَلا أُقْسِمُ بِمَواقِعِ النُّجُومِ﴾</q>، قال: نجوم السماء{16}. (١٤/٢١٨) ٧٥٣٠٩- عن مجاهد بن جبر -من طريق ابن أبي نجيح- قوله: <q>﴿بِمَواقِعِ النُّجُومِ﴾</q>، قال: في السماء، ويقال: مطالعها ومساقطها{17}. (ز) ٧٥٣١٠- عن عكرمة مولى ابن عباس -من طريق يزيد- في قوله: <q>﴿فَلا أُقْسِمُ بِمَواقِعِ النُّجُومِ﴾</q>، قال: أنزل الله القرآن نجومًا؛ ثلاث آيات، وأربع آيات، وخمس آيات{13}. (ز) ٧٥٣١١- عن عكرمة مولى ابن عباس -من طريق المعتمر، عن أبيه-: إنّ القرآن نزل جميعًا، فوُضِع بمواقع النجوم، فجعل جبريل يأتي بالسورة، وإنّما نزل جميعًا في ليلة القَدْر{13}. (ز) ٧٥٣١٢- قال الحسن البصري -من طريق قتادة- في قوله: <q>﴿فَلا أُقْسِمُ بِمَواقِعِ النُّجُومِ﴾</q>، قال: انكدارها، وانتثارها يوم القيامة{20}. (١٤/٢١٨) ٧٥٣١٣- عن الحسن البصري، <q>﴿فَلا أُقْسِمُ بِمَواقِعِ النُّجُومِ﴾</q>، قال: بمغايبها{3}. (١٤/٢١٨) ٧٥٣١٤- قال عطاء: <q>﴿فَلا أُقْسِمُ بِمَواقِعِ النُّجُومِ﴾</q>، أراد: منازلها{22}. (ز) ٧٥٣١٥- عن قتادة بن دعامة -من طريق سعيد- <q>﴿فَلا أُقْسِمُ بِمَواقِعِ النُّجُومِ﴾</q>، قال: بمساقطها{20}. (١٤/٢١٨) ٧٥٣١٦- عن قتادة بن دعامة -من طريق معمر- في قوله: <q>﴿فَلا أُقْسِمُ بِمَواقِعِ النُّجُومِ﴾</q>، قال: بمنازل النجوم{24}. (١٤/٢١٨) ٧٥٣١٧- قال محمد بن السّائِب الكلبي -من طريق معمر- <q>﴿فَلا أُقْسِمُ بِمَواقِعِ النُّجُومِ﴾</q>: هو القرآن كان ينزل نجومًا{25}. (ز) ٧٥٣١٨- قال مقاتل بن سليمان: <q>﴿فَلا أُقْسِمُ بِمَواقِعِ النُّجُومِ﴾</q> يعني: بمساقط النجوم مِن القرآن كلّه أوله وآخره في ليلة القَدْر، نزل من اللوح المحفوظ مِن السماء السابعة إلى السماء الدنيا إلى السّفرة، وهم الكتبة من الملائكة، نظيرها في <q>﴿عبس وتولى﴾</q> [١٥-١٦]: <q>﴿بِأَيْدِي سَفَرَةٍ كِرامٍ بَرَرَةٍ﴾</q>{26}٦٤٥٦. (ز) ٦٤٥٦ اختُلف في معنى: «النجوم» التي أقسم بمواقعها في هذه الآية على قولين: الأول: أنها نجوم السماء. وفي مواقعها ثلاثة أقوال: أحدها: منازلها. ثانيها: مساقطها. ثالثها: انتثارها عند قيام الساعة. الثاني: أنها آيات القرآن، ومواقعها: نزولها شيئًا بعد شيء. ووجَّه ابنُ القيم (٣/١١٥) قول مَن قال: إنها نجوم السماء، ومواقعها: مساقطها. بقوله: «وعلى هذا فتكون المناسبة بين ذِكر النجوم في القسم وبين المُقسم عليه وهو القرآن من وجوه: أحدها: أنّ النجوم جعلها الله يُهتدى بها في ظلمات البر والبحر، وآيات القرآن يُهتدى بها في ظلمات الجهل والغي، فتلك هداية في الظلمات الحسية، وآيات القرآن في الظلمات المعنوية؛ فجمع بين الهدايتين، مع ما في النجوم من الرجوم للشياطين، وفي آيات القرآن من رجوم شياطين الإنس والجن، والنجوم آياته المشهودة المعاينة، والقرآن آياته المتلوة السمعية، مع ما في مواقعها عند الغروب من العِبرة والدلالة على آياته القرآنية ومواقعها عند النزول». وعلَّق ابنُ عطية (٨/٢٠٩) على القول الثاني بقوله: «ويؤيد هذا القول عوْد الضمير على القرآن في قوله سبحانه: <q>﴿إنَّهُ لَقُرْآنٌ كَرِيمٌ﴾</q>، وذلك أنّ ذِكْرَه لم يتقدم إلا على هذا التأويل، ومَن لا يتأول هذا التأويل يقول: إنّ الضمير يعود على القرآن وإن لم يتقدم له ذِكر لشهرة الأمر ووضوح المعنى، كقوله تعالى: <q>﴿حَتّى تَوارَتْ بِالحِجابِ﴾</q> [ص: ٣٢]، و<q>﴿كُلُّ مَن عَلَيْها فانٍ﴾</q> [الرحمن: ٢٦] وغير ذلك». ورجَّح ابن جرير (٢٢/٣٦١) -مستندًا إلى الأغلب في اللغة- أنه قسمٌ بمساقط النجوم ومغايبها في السماء، وهو قول مجاهد من طريق ابن أبي نجيح، وقول الحسن، وقتادة من طريق سعيد، وعلَّل ذلك بقوله: «وذلك أن المواقع جمع موقع، والموقع المَفْعِل، من وقَع يَقَعُ مَوقِعًا، فالأغلب من معانيه والأظهر من تأويله ما قلنا في ذلك، ولذلك قلنا: هو أوْلى معانيه به». وزاد ابن عطية (ينظر: ٨/٢١٠) قولًا أنّ مواقع النجوم: عند الانقضاض إثر العفاريت. ",footnotes:1:أخرجه الفراء في معاني القرآن ٣/٩٤. وهي قراءة متواترة، قرأ بها حمزة، والكسائي، وخلف، وقرأ بقية العشرة: <q>﴿بِمَواقِعِ﴾</q> على الجمع. انظر: النشر ٢/٣٨٣، والإتحاف ص٥٣١.أخرجه سعيد بن منصور في سننه -التفسير ٨/١٧ (٢١٦٣). قال المحقق: رُسمت في الأصل بألف بعد الواو، والقراءة المنسوبة لإبراهيم بلا ألف وبإسكان الواو؛ على الإفراد (بمَوْقِع).عزاه السيوطي إلى عبد بن حميد.أخرجه مسلم ١/٨٤ (٧٣).عزاه السيوطي إلى ابن مردويه.أخرجه ابن جرير ٢٢/٣٥٩.أخرجه الفراء في معاني القرآن ٣/١٢٩. وذكر السيوطي أنه بسند صحيح.أخرجه ابن جرير ٣/١٩١، ومحمد بن نصر في مختصر قيام الليل ص١٠٤، والطبراني (١٢٤٢٦). وعزاه السيوطي إلى عبد بن حميد، وابن أبي حاتم، وابن المنذر، وابن مردويه.نجومًا: مفرقًا، ويقال: نجمت المال: إذا وزعته. التاج (نجم).أخرجه آدم بن أبي إياس -كما في تفسير مجاهد ص٦٤٥- بنحوه، والنسائي في الكبرى (١١٥٦٥)، وابن جرير ٢٢/٣٥٩، ومحمد بن نصر ص١٠٤، والحاكم ٢/٥٣٠، والبيهقي في شعب الإيمان (٢٢٥٠). وعزاه السيوطي إلى ابن مردويه.عزاه السيوطي إلى ابن مردويه.عزاه السيوطي إلى ابن المنذر، وابن الأنباري في كتاب المصاحف، وابن مردويه.أخرجه ابن جرير ٢٢/٣٦٠.عزاه السيوطي إلى ابن مردويه.أخرجه ابن جرير ٢٢/٣٦٠، ومحمد بن نصر ص١٠٤ بلفظ: النجوم: القرآن، وابن الضريس (١٣٠).تفسير مجاهد ص٦٤٥، وأخرجه ابن جرير ٢٢/٣٦٠-٣٦١. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.تفسير مجاهد ص٦٤٥، وأخرجه ابن جرير ٢٢/٣٦٠.أخرجه ابن جرير ٢٢/٣٦٠.أخرجه ابن جرير ٢٢/٣٦٠.أخرجه ابن جرير ٢٢/٣٦١. وعزاه السيوطي إلى عبد بن حميد.عزاه السيوطي إلى عبد بن حميد.تفسير البغوي ٨/٢٢.أخرجه ابن جرير ٢٢/٣٦١. وعزاه السيوطي إلى عبد بن حميد.أخرجه عبد الرزاق ٢/٢٧٣، وابن جرير ٢٢/٣٦١.أخرجه عبد الرزاق ٢/٢٧٣.تفسير مقاتل بن سليمان ٤/٢٢٣.
56,76," <q>﴿وَإِنَّهُۥ لَقَسَمࣱ لَّوۡ تَعۡلَمُونَ عَظِیمٌ ۝٧٦﴾</q> - تفسير ٧٥٣١٩- عن عبد الله بن عباس -من طريق سعيد بن جُبَير- <q>﴿وإنَّهُ لَقَسَمٌ لَوْ تَعْلَمُونَ عَظِيمٌ﴾</q>: هذا القرآن قَسمٌ عظيم{1}. (١٤/٢١٨) ٧٥٣٢٠- عن عبد الله بن عباس -من طريق السُّدِّيّ، عن أبي مالك وأبي صالح-: <q>﴿وإنَّهُ لَقَسَمٌ﴾</q> والقَسم قَسمٌ إلى قوله: <q>﴿لا يَمَسُّهُ إلّا المُطَهَّرُونَ﴾</q>{2}. (١٤/٢٥٢) ٧٥٣٢١- قال مقاتل بن سليمان: ثم عظّم القَسَم، فقال: <q>﴿وإنَّهُ لَقَسَمٌ لَوْ تَعْلَمُونَ عَظِيمٌ﴾</q>{3}. (ز) ",footnotes:1:أخرجه آدم بن أبي إياس -كما في تفسير مجاهد ص٦٤٥-. وعزا السيوطيُّ نحوه إلى عبد بن حميد، وابن أبي حاتم، وابن المنذر، وابن مردويه.عزاه السيوطي إلى ابن مردويه.تفسير مقاتل بن سليمان ٤/٢٢٣.
