quran[26]{c,v,t}:
  56,51,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿ثُمَّ إِنَّكُمۡ أَیُّهَا ٱلضَّاۤلُّونَ ٱلۡمُكَذِّبُونَ ۝٥١﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٥١٦٥<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق السُّدِّيّ، عن أبي مالك وأبي صالح- <span class="qpc-hafs">﴿ثُمَّ إنَّكُمْ أيُّها الضّالُّونَ المُكَذِّبُونَ﴾</span>، قال: المشركون المُكذِّبون{1}. (١٤/٢٥٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٥١٦٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثم ذكر طعامهم وشرابهم في الآخرة، فقال: <span class="qpc-hafs">﴿ثُمَّ إنَّكُمْ﴾</span> يا أهل مكة <span class="qpc-hafs">﴿أيُّها الضّالُّونَ﴾</span> عن الهدى، يعني: المشركين، ثم قال: <span class="qpc-hafs">﴿المُكَذِّبُونَ﴾</span> بالبعث؛ لقولهم: أوَ يَبعث آباءنا الأوّلين؟!{2}. (ز)</p></p><p></div></p></div>",footnotes:1:عزاه السيوطي إلى ابن مردويه.تفسير مقاتل بن سليمان ٤/٢٢١-٢٢٢.
  56,52,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿لَـَٔاكِلُونَ مِن شَجَرࣲ مِّن زَقُّومࣲ ۝٥٢ فَمَالِـُٔونَ مِنۡهَا ٱلۡبُطُونَ ۝٥٣﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٥١٦٧<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق السُّدِّيّ، عن أبي مالك وأبي صالح- <span class="qpc-hafs">﴿لَآكِلُونَ مِن شَجَرٍ مِن زَقُّومٍ﴾</span>، قال: والزَّقوم إذا أكلوا منه غَصُّوا، والزَّقوم شجرة{1}. (١٤/٢٥٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٥١٦٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق السُّدِّيّ، عن أبي مالك وأبي صالح- <span class="qpc-hafs">﴿فَمالِئُونَ مِنها البُطُونَ﴾</span>، قال: يملؤون من الزَّقوم بطونهم{1}. (١٤/٢٥٠-٢٥١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٥١٦٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿لَآكِلُونَ مِن شَجَرٍ مِن زَقُّومٍ فَمالِئُونَ مِنها﴾</span> يعني: مِن طلْعها وثمرها <span class="qpc-hafs">﴿البُطُونَ﴾</span>{3}. (ز)</p></p><p></div></p></div>",footnotes:1:عزاه السيوطي إلى ابن مردويه.عزاه السيوطي إلى ابن مردويه.تفسير مقاتل بن سليمان ٤/٢٢١-٢٢٢.
  56,53,""
  56,54,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿فَشَـٰرِبُونَ عَلَیۡهِ مِنَ ٱلۡحَمِیمِ ۝٥٤﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٥١٧٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق السُّدِّيّ، عن أبي مالك وأبي صالح- <span class="qpc-hafs">﴿فَشارِبُونَ عَلَيْهِ مِنَ الحَمِيمِ﴾</span>، يقول: على الزّقوم الحميم{1}. (١٤/٢٥١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٥١٧١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فَشارِبُونَ عَلَيْهِ﴾</span> يعني: على الأكل <span class="qpc-hafs">﴿مِنَ الحَمِيمِ﴾</span> يعني: الشراب الحار الذي قد انتهى حرُّه{2}. (ز)</p></p><p></div></p></div>",footnotes:1:عزاه السيوطي إلى ابن مردويه.تفسير مقاتل بن سليمان ٤/٢٢١-٢٢٢.
  56,55,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿فَشَـٰرِبُونَ شُرۡبَ ٱلۡهِیمِ ۝٥٥﴾</span> - قراءات</h3></p><p><div></p><p><p><span class="item-no">٧٥١٧٢<span class="dash">-</span></span> عن عبد الله بن عمر: أنّ رسول الله ﷺ قرأ في الواقعة: ‹فَشارِبُونَ شَرْبَ الهِيمِ› بفتح الشين من <span class="qpc-hafs">﴿شُرب﴾</span>{1}. (١٤/٢١١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٥١٧٣<span class="dash">-</span></span> عن أنس بن مالك، قال: كان النبيُّ ﷺ يقرأ: ‹شَرْبَ الهِيمِ›{2}. (١٤/٢١١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٥١٧٤<span class="dash">-</span></span> قرأ <span class="name-2">عاصم</span>: <span class="qpc-hafs">﴿شُرْبَ الهِيمِ﴾</span> برفع الشين{3}<span class=comment-ref>٦٤٤٢</span>. (١٤/٢١١)</p></p><p></div></p><p><div><span class=comment-ref>٦٤٤٢</span> اختلفت القرأة في قراءة قوله تعالى: <span class="qpc-hafs">﴿شُرْبَ الهِيمِ﴾</span> على قراءتين: <b>الأولى:</b> <span class="qpc-hafs">﴿شُرْبَ الهيم﴾</span> بضم الشين. <b>الثانية:</b> ‹شَرْبَ الهِيمِ› بفتح الشين.</p><p>و<span class="comment-type-3">رجَّح</span> <u>ابنُ جرير</u> (٢٢/٣٤٢) «أنهما قراءتان، قد قرأ بكلِّ واحدةٍ منهما علماءُ من القرأة، مع تقارب معنيَيْهما، فبأيَّتِهما قرأ القارئ فمصيبٌ في قراءته؛ لأن ذلك في فتحه وضمِّه نظير فتح قولهم: الضَّعف، والضُّعف وضمِّه».</div></p><p><h3><span class="qpc-hafs">﴿فَشَـٰرِبُونَ شُرۡبَ ٱلۡهِیمِ ۝٥٥﴾</span> - تفسير الآية</h3></p><p><div></p><p><p><span class="item-no">٧٥١٧٥<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق سفيان- في قوله: <span class="qpc-hafs">﴿شُرْبَ الهِيمِ﴾</span>، قال: الإبل العِطاش{4}. (١٤/٢١١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٥١٧٦<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، أنّ نافع بن الأزرق قال له: أخبِرني عن قوله ﷿: <span class="qpc-hafs">﴿فَشارِبُونَ شُرْبَ الهِيمِ﴾</span>. قال: الإبل يأخذها داء يُقال له: الهِيم، فلا تَروى مِن الماء، فشبّه الله تعالى شُرب أهل النار مِن الحميم بمنزلة الإبل الهِيم. قال: وهل تعرف العرب ذلك؟ قال: نعم، أما سمعتَ لَبيد بن ربيعة وهو يقول:</p><p>أجَزتُ إلى مَعارِفها بِشُعْثٍ وأطْلاحٍ{5} من العِيديِّ{6} هِيمِ؟!{7}. (١٤/٢١٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٥١٧٧<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، في قوله: <span class="qpc-hafs">﴿فَشارِبُونَ شُرْبَ الهِيمِ﴾</span>، قال: هُيام الأرض، يعني: الرّمال{8}<span class=comment-ref>٦٤٤٣</span>. (١٤/٢١٣)</p></p><p></div></p><p><div><span class=comment-ref>٦٤٤٣</span> ذكر <u>ابنُ عطية</u> (٨/٢٠٣) قول ابن عباس، وسفيان الثوري: أنّ «الهيم هنا: الرمال التي لا تُرْوى بالماء». ثم <span class="comment-type-1">وجَّهه</span> بقوله: «وذلك أن الهَيام -بفتح الهاء-: هو الرّمل الدِّق الغَمْر المتراكم».</div></p><p><div></p><p><p><span class="item-no">٧٥١٧٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق السُّدِّيّ، عن أبي مالك وأبي صالح- <span class="qpc-hafs">﴿فَشارِبُونَ شُرْبَ الهِيمِ﴾</span>: هي الرّمال، لو مطرت عليها السماء أبدًا لم يُرَ فيها مستنقع{2}. (١٤/٢٥١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٥١٧٩<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جُبَير</span>، <span class="qpc-hafs">﴿شُرْبَ الهِيمِ﴾</span>، قال: الإبل{10}. (١٤/٢١٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٥١٨٠<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- <span class="qpc-hafs">﴿شُرْبَ الهِيمِ﴾</span>، قال: الإبل الهُيَّم{11}. (١٤/٢١٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٥١٨١<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- <span class="qpc-hafs">﴿شُرْبَ الهِيمِ﴾</span>، قال: الإبل الظّماء{12}. (١٤/٢١٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٥١٨٢<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق جابر- <span class="qpc-hafs">﴿شُرْبَ الهِيمِ﴾</span>: هو داء يكون في الإبل تشرب فلا تَروى{12}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٥١٨٣<span class="dash">-</span></span> عن <span class="name-2">الضَّحّاك بن مُزاحِم</span> -من طريق عبيد- <span class="qpc-hafs">﴿شُرْبَ الهِيمِ﴾</span>، قال: الهيم: الإبل العِطاش، تشرب فلا تَروى، يأخذها داء يقال له: الهُيام{14}. (١٤/٢١٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٥١٨٤<span class="dash">-</span></span> قال <span class="name-2">الضَّحّاك بن مُزاحِم</span>: <span class="qpc-hafs">﴿الهِيمِ﴾</span> الأرض السّهلة ذات الرّمل{15}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٥١٨٥<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span> -من طريق عمران- <span class="qpc-hafs">﴿فَشارِبُونَ شُرْبَ الهِيمِ﴾</span>، قال: الإبل المِراض تمصّ الماء مصًّا، ولا تَروى{16}. (١٤/٢١٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٥١٨٦<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span> -من طريق يزيد- في قوله: <span class="qpc-hafs">﴿فَشارِبُونَ شُرْبَ الهِيمِ﴾</span>، قال: الإبل يأخذها العِطاش، فلا تزال تشرب حتى تهلك{17}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٥١٨٧<span class="dash">-</span></span> عن <span class="name-2">أبي مجلز [لاحق بن حميد]</span>، <span class="qpc-hafs">﴿فَشارِبُونَ شُرْبَ الهِيمِ﴾</span>، قال: كان المِراض تمصّ الماء مصًّا، ولا تَروى{18}. (١٤/٢١٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٥١٨٨<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span>، قال: <span class="qpc-hafs">﴿الهِيمِ﴾</span> الإبل العِطاش{10}. (١٤/٢١٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٥١٨٩<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span>، <span class="qpc-hafs">﴿فَشارِبُونَ شُرْبَ الهِيمِ﴾</span>، قال: ضوالّ الإبل، دوابّ لا تَروى{10}. (١٤/٢١٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٥١٩٠<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- في قوله تعالى: <span class="qpc-hafs">﴿شُرْبَ الهِيمِ﴾</span>، قال: الإبل العِطاش{21}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٥١٩١<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- قوله: <span class="qpc-hafs">﴿فَشارِبُونَ شُرْبَ الهِيمِ﴾</span>، قال: داءٌ بالإبل لا تَروى معه{22}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٥١٩٢<span class="dash">-</span></span> عن <span class="name-3">محمد بن السّائِب الكلبي</span>: <span class="qpc-hafs">﴿شُرْبَ الهِيمِ﴾</span>، يعني: الإبل العِطاش{23}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٥١٩٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فَشارِبُونَ شُرْبَ الهِيمِ﴾</span> يعني بالهِيم: الإبل، يأخذها داء يُقال له: الهِيم، فلا تَروى من الشراب، وذلك أنه يُلقى على أهل النار العطش كلّ يوم مرتين حتى يشربوا الشراب الهِيم{24}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٥١٩٤<span class="dash">-</span></span> عن <span class="name-3">سفيان [الثوري]</span> -من طريق مهران- <span class="qpc-hafs">﴿الهِيمِ﴾</span>، قال: السّهلة{25}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه الطبراني في الأوسط ٩/١٤٥ (٩٣٧١)، وتمام في فوائده ١/٢١٦ (٥١١)، وابن عساكر في تاريخ دمشق ٦٤/٢٢٩-٢٣٠. وأخرجه الحاكم ٢/٢٧٤ (٢٩٨٧) بضم الشين، وفي إسناده سلام بن سليمان المدايني.</p><p>قال ابن حبان في المجروحين ١/٣٤٢ (٤٣٣): «سلام بن سليمان شيخ يروي عن أبي عمرو بن العلاء أشياء لا يُتابع عليها، لا يجوز الاحتجاج به إذا انفرد، روى عن أبي عمرو بن العلاء، عن نافع، عن ابن عمر، أنّ رسول الله ﷺ قرأ: ‹فَشارِبُونَ شَرْبَ الهِيمِ›، في أشياء يروي مثل هذا لا توافق حديث الثقات، بل يباين حديث الأثبات». وقال ابن عدي في الكامل ٤/٣٢٣ (٧٧٢): «سلام بن سليمان بن سوار الثقفي المدائني الضرير ...، وهو عندي منكر الحديث». وقال الحاكم: «هذا حديث صحيح الإسناد، ولم يخرجاه». وقال الذهبي في التلخيص: «سلام ضعيف».</p><p>و‹شَرْبَ الهِيمٍ› بفتح الشين قراءة العشرة ما عدا نافعًا، وأبا جعفر، وعاصمًا، وحمزة؛ فإنهم قرؤوا: <span class="qpc-hafs">﴿شُرْبَ الهِيمِ﴾</span> بضم الشين. انظر: النشر ٢/٣٨٣، والإتحاف ص٥٢٧.عزاه السيوطي إلى ابن مردويه.عزاه السيوطي إلى ابن حميد.أخرجه ابن جرير ٢٢/٣٤٣-٣٤٤ بنحوه من طريق علي، والعَوفيّ. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.يقال: ناقة طَلِيحُ أسفار إذا جَهَدَها السير وهَزَلها. لسان العرب (طلح).العِيديّة: إبل منسوبة إلى العيد، والعيد: قبيلة من مَهْرة، وإبل مَهْرة موصوفة بالنجابة. لسان العرب (رهن، عود).عزاه السيوطي إلى الطستي، وهو في مسائل نافع (٢٥٧).عزاه السيوطي إلى سفيان بن عيينة في جامعه.عزاه السيوطي إلى ابن مردويه.عزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ٢٢/٣٤٤. وعزاه السيوطي إلى عبد بن حميد.تفسير مجاهد ص٦٤٤.تفسير مجاهد ص٦٤٤.أخرجه ابن جرير ٢٢/٣٤٤. وعزا السيوطي إلى عبد بن حميد نحوه.تفسير الثعلبي ٩/٢١٤، وتفسير البغوي ٨/١٩.أخرجه ابن جرير ٢٢/٣٤٣. وعزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ٢٢/٣٤٣، وبنحوه من طريق خُصَيف.عزاه السيوطي إلى سعيد بن منصور، وابن المنذر.عزاه السيوطي إلى عبد بن حميد.عزاه السيوطي إلى عبد بن حميد.أخرجه عبد الرزاق ٢/٢٧٢.أخرجه ابن جرير ٢٢/٣٤٤.ذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٤/٣٤١-.تفسير مقاتل بن سليمان ٤/٢٢١-٢٢٢.أخرجه ابن جرير ٢٢/٣٤٤. وفي تفسير الثعلبي ٩/٢١٤، وتفسير البغوي ٨/١٩ عن سفيان: <span class="qpc-hafs">﴿الهِيمِ﴾</span>: الأرض السّهلة ذات الرّمل.
  56,56,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿هَـٰذَا نُزُلُهُمۡ یَوۡمَ ٱلدِّینِ ۝٥٦﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٥١٩٥<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق السُّدِّيّ، عن أبي مالك وأبي صالح- <span class="qpc-hafs">﴿هَذا نُزُلُهُمْ يَوْمَ الدِّينِ﴾</span>: كرامة يوم الحساب{1}. (١٤/٢٥١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٥١٩٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿هَذا﴾</span> الذي ذُكر مِن الزّقوم والشراب <span class="qpc-hafs">﴿نُزُلُهُمْ يَوْمَ الدِّينِ﴾</span> يعني: يوم الحساب{2}. (ز)</p></p><p></div></p></div>",footnotes:1:عزاه السيوطي إلى ابن مردويه.تفسير مقاتل بن سليمان ٤/٢٢١-٢٢٢.
  56,57,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿نَحۡنُ خَلَقۡنَـٰكُمۡ فَلَوۡلَا تُصَدِّقُونَ ۝٥٧﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٥١٩٧<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق السُّدِّيّ، عن أبي مالك وأبي صالح- <span class="qpc-hafs">﴿نَحْنُ خَلَقْناكُمْ فَلَوْلا تُصَدِّقُونَ﴾</span>، يقول: أفلا تُصدِّقون{1}. (١٤/٢٥١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٥١٩٨<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿نَحْنُ خَلَقْناكُمْ﴾</span> ولم تكونوا شيئًا وأنتم تعلمون <span class="qpc-hafs">﴿فَلَوْلا﴾</span> يعني: فهلّا <span class="qpc-hafs">﴿تُصَدِّقُونَ﴾</span>{2}. (ز)</p></p><p></div></p></div>",footnotes:1:عزاه السيوطي إلى ابن مردويه.تفسير مقاتل بن سليمان ٤/٢٢١-٢٢٢.
  56,58,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿أَفَرَءَیۡتُم مَّا تُمۡنُونَ ۝٥٨ ءَأَنتُمۡ تَخۡلُقُونَهُۥۤ أَمۡ نَحۡنُ ٱلۡخَـٰلِقُونَ ۝٥٩﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٥١٩٩<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق السُّدِّيّ، عن أبي مالك وأبي صالح- <span class="qpc-hafs">﴿أفَرَأَيْتُمْ ما تُمْنُونَ﴾</span>، يقول: هذا ماء الرجل{1}. (١٤/٢٥١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٥٢٠٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿أفَرَأَيْتُمْ ما تُمْنُونَ﴾</span> يعني: النُّطفة؛ الماء الدّافق، <span class="qpc-hafs">﴿أأَنْتُمْ تَخْلُقُونَهُ﴾</span> بشرًا، <span class="qpc-hafs">﴿أمْ نَحْنُ الخالِقُونَ﴾</span> له؟ بل نحن نخلقه{2}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿أَفَرَءَیۡتُم مَّا تُمۡنُونَ ۝٥٨ ءَأَنتُمۡ تَخۡلُقُونَهُۥۤ أَمۡ نَحۡنُ ٱلۡخَـٰلِقُونَ ۝٥٩﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٧٥٢٠١<span class="dash">-</span></span> عن حُجْر المَدَريّ، قال: بتُّ عند <span class="name-1">علِيٍّ</span>، فسمعتُه وهو يُصلّي بالليل يقرأ، فمرّ بهذه الآية: <span class="qpc-hafs">﴿أفَرَأَيْتُمْ ما تُمْنُونَ أأَنْتُمْ تَخْلُقُونَهُ أمْ نَحْنُ الخالِقُونَ﴾</span>. قال: بل أنتَ، يا ربّ. ثلاثًا. ثم قرأ: <span class="qpc-hafs">﴿أأنتم تزرعونه﴾</span>. قال: بل أنتَ، يا ربّ. ثلاثًا. ثم قرأ: <span class="qpc-hafs">﴿أأَنْتُمْ أنْزَلْتُمُوهُ مِنَ المُزْنِ﴾</span>. قال: بل أنتَ، يا ربّ. ثلاثًا. ثم قرأ: <span class="qpc-hafs">﴿أأَنْتُمْ أنْشَأْتُمْ شَجَرَتَها﴾</span>. قال: بل أنت، يا ربّ. ثلاثًا{3}. (١٤/٢١٣)</p></p><p></div></p></div>",footnotes:1:عزاه السيوطي إلى ابن مردويه.تفسير مقاتل بن سليمان ٤/٢٢٢.أخرجه عبد الرزاق في مصنفه (٤٠٥٣)، والحاكم ٢/٤٧٧، والبيهقي في سننه ٢/٣١١.
  56,59,""
  56,60,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿نَحۡنُ قَدَّرۡنَا بَیۡنَكُمُ ٱلۡمَوۡتَ وَمَا نَحۡنُ بِمَسۡبُوقِینَ ۝٦٠﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٥٢٠٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق السُّدِّيّ، عن أبي مالك وأبي صالح-: <span class="qpc-hafs">﴿نَحْنُ قَدَّرْنا بَيْنَكُمُ المَوْتَ﴾</span> في المتعجّل والمتأخّر، <span class="qpc-hafs">﴿وما نَحْنُ بِمَسْبُوقِينَ﴾</span>{1}. (١٤/٢٥١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٥٢٠٣<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿نَحْنُ قَدَّرْنا بَيْنَكُمُ المَوْتَ﴾</span>، قال: المتأخّر والمتعجّل{2}<span class=comment-ref>٦٤٤٤</span>. (١٤/٢١٤)</p></p><p></div></p><p><div><span class=comment-ref>٦٤٤٤</span> ذكر <u>ابنُ عطية</u> (٨/٢٠٤) أنّ الآية تحتمل أن تكون بمعنى: «سوَّيْنا وعدَّلْنا التَّقدُّم والتَّأخُّر». ثم <span class="comment-type-1">وجَّهه</span> بقوله: «أي: جعلنا الموت رُتَبًا، ليس يموت العالمَ دفعة واحدة، بل بترتيبٍ لا يعدوه أحد».</div></p><p><div></p><p><p><span class="item-no">٧٥٢٠٤<span class="dash">-</span></span> عن <span class="name-2">الضَّحّاك بن مُزاحِم</span> -من طريق جويبر- في قوله: <span class="qpc-hafs">﴿نَحْنُ قَدَّرْنا بَيْنَكُمُ المَوْتَ﴾</span>، قال: تقديره أن جعل أهل الأرض وأهل السماء فيه سواء؛ شريفهم وضعيفهم{3}. (١٤/٢١٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٥٢٠٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿نَحْنُ قَدَّرْنا بَيْنَكُمُ المَوْتَ﴾</span> فمنكم مَن يموت صغيرًا، ومنكم مَن يموت كبيرًا، أو يموت شابًّا، أو شيخًا، أو يبلغ أرذَل العمر. ثم خوّفهم، فقال: <span class="qpc-hafs">﴿وما نَحْنُ بِمَسْبُوقِينَ﴾</span> يعني: بمُعجَزين إنْ أردنا ذلك{4}. (ز)</p></p><p></div></p></div>",footnotes:1:عزاه السيوطي إلى ابن مردويه.تفسير مجاهد ص٦٤٤، وأخرجه ابن جرير ٢٢/٣٤٦-٣٤٧. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه أبو الشيخ في العظمة (١٨٠).تفسير مقاتل بن سليمان ٤/٢٢٢.
  56,61,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿عَلَىٰۤ أَن نُّبَدِّلَ أَمۡثَـٰلَكُمۡ وَنُنشِئَكُمۡ فِی مَا لَا تَعۡلَمُونَ ۝٦١﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٥٢٠٦<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق السُّدِّيّ، عن أبي مالك وأبي صالح- <span class="qpc-hafs">﴿عَلى أنْ نُبَدِّلَ أمْثالَكُمْ﴾</span> فيقول: نذهب بكم، ونجيء بغيركم، <span class="qpc-hafs">﴿ونُنْشِئَكُمْ فِي ما لا تَعْلَمُونَ﴾</span> يقول: نخلقكم فيما لا تعلمون؛ إن نشأ خلقناكم قِردة، وإن نشأ خلقناكم خنازير{1}. (١٤/٢٥١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٥٢٠٧<span class="dash">-</span></span> قال <span class="name-2">سعيد بن المسيّب</span>: <span class="qpc-hafs">﴿ونُنْشِئَكُمْ فِي ما لا تَعْلَمُونَ﴾</span> يعني: في حواصل طير، تكون بِبَرَهُوت، كأنها الخطاطيف. وبَرَهُوت: وادٍ باليمن{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٥٢٠٨<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿ونُنْشِئَكُمْ فِي ما لا تَعْلَمُونَ﴾</span>، قال: في أي خلْقٍ شئنا{3}. (١٤/٢١٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٥٢٠٩<span class="dash">-</span></span> قال <span class="name-2">الحسن البصري</span>: <span class="qpc-hafs">﴿ونُنْشِئَكُمْ فِي ما لا تَعْلَمُونَ﴾</span> أي: نبدّل صفاتكم، ونجعلكم قِردة وخنازير كما فعلنا بمن كان قبلكم{2}<span class=comment-ref>٦٤٤٥</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٤٤٥</span> <span class="comment-type-1">وجَّه</span> <u>ابنُ عطية</u> (٨/٢٠٤) قول الحسن بقوله: «تأوَّل الحسن هذا؛ لأنّ الآية تنحو إلى الوعيد».</div></p><p><div></p><p><p><span class="item-no">٧٥٢١٠<span class="dash">-</span></span> قال <span class="name-2">إسماعيل السُّدِّيّ</span>: <span class="qpc-hafs">﴿ونُنْشِئَكُمْ فِي ما لا تَعْلَمُونَ﴾</span> نخلُقكم في سوء خلقكم{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٥٢١١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿عَلى أنْ نُبَدِّلَ أمْثالَكُمْ﴾</span> على أن نخلُق مثلكم أو أمثل منكم، <span class="qpc-hafs">﴿ونُنْشِئَكُمْ﴾</span> يعني: ونخلقكم سوى خلْقكم <span class="qpc-hafs">﴿فِي ما لا تَعْلَمُونَ﴾</span> من الصورة{6}. (ز)</p></p><p></div></p></div>",footnotes:1:عزاه السيوطي إلى ابن مردويه.تفسير الثعلبي ٩/٢١٥، وتفسير البغوي ٨/٢٠.تفسير مجاهد ص٦٤٤، وأخرجه ابن جرير ٢٢/٣٤٦. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.تفسير الثعلبي ٩/٢١٥، وتفسير البغوي ٨/٢٠.تفسير الثعلبي ٩/٢١٥.تفسير مقاتل بن سليمان ٤/٢٢٢.
  56,62,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَلَقَدۡ عَلِمۡتُمُ ٱلنَّشۡأَةَ ٱلۡأُولَىٰ فَلَوۡلَا تَذَكَّرُونَ ۝٦٢﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٥٢١٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق السُّدِّيّ، عن أبي مالك وأبي صالح- <span class="qpc-hafs">﴿ولَقَدْ عَلِمْتُمُ النَّشْأَةَ الأُولى فَلَوْلا تَذَكَّرُونَ﴾</span>، يقول: فهلّا تذكَّرون{1}. (١٤/٢٥١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٥٢١٣<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿ولَقَدْ عَلِمْتُمُ النَّشْأَةَ الأُولى﴾</span>: إذ لم تكونوا شيئًا{2}. (١٤/٢١٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٥٢١٤<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿ولَقَدْ عَلِمْتُمُ النَّشْأَةَ الأُولى﴾</span>، قال: خلْق آدم ﵇{3}. (١٤/٢١٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٥٢١٥<span class="dash">-</span></span> عن <span class="name-2">أبي عمران الجَوْني</span> -من طريق جعفر بن سليمان- يقرأ هذه الآية: <span class="qpc-hafs">﴿ولَقَدْ عَلِمْتُمُ النَّشْأَةَ الأُولى﴾</span>، قال: هو خلْق آدم{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٥٢١٦<span class="dash">-</span></span> عن <span class="name-2">الضَّحّاك بن مُزاحِم</span>{5} -من طريق جويبر- في قوله: <span class="qpc-hafs">﴿ولَقَدْ عَلِمْتُمُ النَّشْأَةَ الأُولى﴾</span> قال: خلْق آدم وخلْقكم، <span class="qpc-hafs">﴿فَلَوْلا تَذَكَّرُونَ﴾</span> فهلّا تصدّقون{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٥٢١٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ولَقَدْ عَلِمْتُمُ النَّشْأَةَ الأُولى﴾</span> يعني: الخلْق الأول حين خُلقتم من نطفة، ثم من علقة، ثم من مُضغة، ولم تكونوا شيئًا، <span class="qpc-hafs">﴿فَلَوْلا﴾</span> يعني: فهلّا <span class="qpc-hafs">﴿تَذَكَّرُونَ﴾</span> في البعث أنّه قادر على أن يبعثكم، كما خلقكم أول مرّة ولم تكونوا شيئًا{7}<span class=comment-ref>٦٤٤٦</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٤٤٦</span> نقل <u>ابنُ عطية</u> (٨/٢٠٥) عن أكثر المفسرين قولهم: «أشار إلى خلْق آدم ﵇، ووقف عليه؛ لأنك لا تجد أحدًا ينكر أنه من ولد آدم ﵇، وأنه من طين». ونقل عن بعضهم قولهم: «أراد تعالى بالنَّشأة الأولى: نشأة إنسان في طفولته، فيَعلم المرء نشأته كيف كانت بما يَرى من نشأة غيره».</div></p></div>",footnotes:1:عزاه السيوطي إلى ابن مردويه.تفسير مجاهد ص٦٤٤، وأخرجه ابن جرير ٢٢/٣٤٧. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه عبد الرزاق ٢/٢٧٢، وابن جرير ٢٢/٣٤٧. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه ابن جرير ٢٢/٣٤٧.جاء في طبعة الكتاب بتحقيق: د. رضاء الله المباركفوري ص١٤٣ (٩٥) طمس مكان القائل، وقال المحقق: لعل المطموس: عن الضَّحّاك. وفي طبعة الكتاب بتحقيق: أبي بكر سعداوي ٣/٢٧١ (٢٠٩) روى الأثر عن الضَّحّاك دون إسناد.أخرجه ابن أبي الدنيا في الأهوال ٦/١٧٥ (٩٤).تفسير مقاتل بن سليمان ٤/٢٢٢.
  56,63,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿أَفَرَءَیۡتُم مَّا تَحۡرُثُونَ ۝٦٣ ءَأَنتُمۡ تَزۡرَعُونَهُۥۤ أَمۡ نَحۡنُ ٱلزَّ ٰ⁠رِعُونَ ۝٦٤﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٥٢١٨<span class="dash">-</span></span> عن أبي هريرة، قال: قال رسول الله ﷺ: «<b>لا يقولنّ أحدكم: زرعتُ. ولكن ليقُلْ: حرثتُ</b>». قال <span class="name-1">أبو هريرة</span>: ألم تسمعوا الله يقول: <span class="qpc-hafs">﴿أفَرَأَيْتُمْ ما تَحْرُثُونَ أأَنْتُمْ تَزْرَعُونَهُ أمْ نَحْنُ الزّارِعُونَ﴾</span>{1}. (١٤/٢١٥)= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٥٢١٩<span class="dash">-</span></span> عن <span class="name-2">أبي عبد الرحمن السلمي</span> -من طريق عطاء- بمثله من قوله غير مرفوع{2}. (١٤/٢١٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٥٢٢٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق السُّدِّيّ، عن أبي مالك وأبي صالح- <span class="qpc-hafs">﴿أفَرَأَيْتُمْ ما تَحْرُثُونَ﴾</span> يقول: ما تزرعون، <span class="qpc-hafs">﴿أأَنْتُمْ تَزْرَعُونَهُ أمْ نَحْنُ الزّارِعُونَ﴾</span> يقول: أليس نحن الذي نُنبِته، أم أنتم المُنبِتون؟{3}. (١٤/٢٥١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٥٢٢١<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span>، في قوله: <span class="qpc-hafs">﴿أأَنْتُمْ تَزْرَعُونَهُ﴾</span>، قال: تُنبِتونه{4}. (١٤/٢١٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٥٢٢٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿أفَرَأَيْتُمْ ما تَحْرُثُونَ أأَنْتُمْ تَزْرَعُونَهُ أمْ نَحْنُ الزّارِعُونَ﴾</span> يعني: نحن الحافظون، يقول: أنتم تنبتونه أم نحن المنبتون له؟{5}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿أَفَرَءَیۡتُم مَّا تَحۡرُثُونَ ۝٦٣ ءَأَنتُمۡ تَزۡرَعُونَهُۥۤ أَمۡ نَحۡنُ ٱلزَّ ٰ⁠رِعُونَ ۝٦٤﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٧٥٢٢٣<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ليث- لا تقُلْ: زرعتُ. ولكن قل: حرثتُ. إنّ الله هو الزارع{6}. (١٤/٢١٥)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن حبان ١٣/٣٠ (٥٧٢٣)، وابن جرير ٢٢/٣٤٨، والثعلبي ٩/٢١٥، وفيه مسلم الجرمي.</p><p>قال الطبراني في المعجم الأوسط ٨/٨٠ (٨٠٢٤): «لم يرو هذا الحديث عن هشام إلا مخلد، تفرّد به مسلم الجرمي». وقال البيهقي في الكبرى ٦/٢٢٨ (١١٧٥١) بعد أن ذكره من قول مجاهد: «وقد روي فيه حديث مرفوع غير قوي». وقال الزيلعي في تخريج أحاديث الكشاف ٣/٤٠٩ (١٢٩٠): «ذكره عبد الحق في أحكامه في باب إحياء الموات من جهة البزار، وسكت عنه، فهو صحيح عنده، وأقرّه ابن القطان على ذلك». وقال الهيثمي في المجمع ٤/١٢٠ (٦٥٩٣): «رواه الطبراني في الأوسط، والبزار، وفيه مسلم بن أبي مسلم الجرمي، ولم أجد من ترجمه، وبقية رجاله ثقات». قال ابن حجر في الفتح ٥/٤ عن رواية ابن أبي حاتم: «ورجاله ثقات، إلا أن مسلم بن أبي مسلم الجرمي قال فيه ابن حبان: ربما أخطأ». وقال الألباني في الصحيحة ٦/٧١٥ (٢٨٠١): «وهذا إسناد جيد، رجاله ثقات رجال مسلم، غير مسلم بن أبي مسلم الجرمي».أخرجه ابن أبي حاتم -كما في تفسير ابن كثير ٨/١٧-، وعبد بن حميد -كما في الفتح ٥/٤-. وعزاه السيوطي إلى عبد بن حميد بلفظ: عن أبي عبد الرحمن أنه كره أن يقول: زرعتُ، ويقول: حرثتُ.عزاه السيوطي إلى ابن مردويه.عزاه السيوطي إلى ابن المنذر.تفسير مقاتل بن سليمان ٤/٢٢٢.أخرجه البيهقي في سننه ٦/١٣٨.
  56,64,""
  56,65,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿لَوۡ نَشَاۤءُ لَجَعَلۡنَـٰهُ حُطَـٰمࣰا﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٥٢٢٤<span class="dash">-</span></span> قال <span class="name-2">عطاء</span>: <span class="qpc-hafs">﴿لَوْ نَشاءُ لَجَعَلْناهُ حُطامًا﴾</span> تِبنًا لا قمح فيه{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٥٢٢٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿لَوْ نَشاءُ﴾</span> إذا أدرك وبلغ <span class="qpc-hafs">﴿لَجَعَلْناهُ حُطامًا﴾</span> يعني: هالكًا{2}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿فَظَلۡتُمۡ تَفَكَّهُونَ ۝٦٥﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٥٢٢٦<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطية العَوفيّ- في قوله: <span class="qpc-hafs">﴿فَظَلْتُمْ تَفَكَّهُونَ﴾</span>، قال: تَعجّبون{3}. (١٤/٢١٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٥٢٢٧<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق السُّدِّيّ، عن أبي مالك وأبي صالح- <span class="qpc-hafs">﴿لَوْ نَشاءُ لَجَعَلْناهُ حُطامًا فَظَلْتُمْ تَفَكَّهُونَ﴾</span>، يقول: تَندَّمون{4}. (١٤/٢٥١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٥٢٢٨<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- <span class="qpc-hafs">﴿فَظَلْتُمْ تَفَكَّهُونَ﴾</span>، قال: تعَجّبون{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٥٢٢٩<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span>، مثله{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٥٢٣٠<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span> -من طريق يزيد- في قوله: <span class="qpc-hafs">﴿فَظَلْتُمْ تَفَكَّهُونَ﴾</span>، يقول: تَلاومون{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٥٢٣١<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق أبي رجاء- <span class="qpc-hafs">﴿فَظَلْتُمْ تَفَكَّهُونَ﴾</span>، قال: تَندَّمون{8}<span class=comment-ref>٦٤٤٧</span>. (١٤/٢١٥)</p></p><p></div></p><p><div><span class=comment-ref>٦٤٤٧</span> <span class="comment-type-1">وجَّه</span> <u>ابنُ كثير</u> (١٣/٣٨٥) قول الحسن، وقتادة من طريق سعيد بقوله: «ومعناه: إما على ما أنفقتم، أو على ما أسلفتم من الذنوب».</div></p><p><div></p><p><p><span class="item-no">٧٥٢٣٢<span class="dash">-</span></span> قال <span class="name-2">عطاء</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٥٢٣٣<span class="dash">-</span></span> و<span class="name-3">محمد بن السّائِب الكلبي</span>: <span class="qpc-hafs">﴿فَظَلْتُمْ تَفَكَّهُونَ﴾</span> تتعجّبون بما نزل بكم في زرعكم{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٥٢٣٤<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- <span class="qpc-hafs">﴿فَظَلْتُمْ تَفَكَّهُونَ﴾</span>، قال: تَعجّبون{10}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٥٢٣٥<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- قوله: <span class="qpc-hafs">﴿فَظَلْتُمْ تَفَكَّهُونَ﴾</span>، قال: تَندَّمون{11}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٥٢٣٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فَظَلْتُمْ تَفَكَّهُونَ﴾</span>، يعني: تعجَّبون{12}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٥٢٣٧<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿فَظَلْتُمْ تَفَكَّهُونَ﴾</span>، قال: تتفجّعون حين صَنع بحرثكم ما صَنع به. وقرأ قول الله ﷿: <span class="qpc-hafs">﴿إنّا لَمُغْرَمُونَ بَلْ نَحْنُ مَحْرُومُونَ﴾</span> [الواقعة:٦٦-٦٧]، وقرأ قول الله: <span class="qpc-hafs">﴿وإذا انْقَلَبُوا إلى أهْلِهِمُ انْقَلَبُوا فَكِهِينَ﴾</span> [المطففين:٣١]، قال: هؤلاء ناعمين. وقرأ قول الله -جلّ وعزّ-: <span class="qpc-hafs">﴿كَمْ تَرَكُوا مِن جَنّاتٍ وعُيُونٍ﴾</span> إلى قوله: <span class="qpc-hafs">﴿ونَعْمَةٍ كانُوا فِيها فاكِهِينَ﴾</span> [الدخان:٢٥-٢٧]{13}<span class=comment-ref>٦٤٤٨</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٤٤٨</span> اختُلف في معنى: <b><span class="qpc-hafs">﴿فَظَلْتُمْ تَفَكَّهُونَ﴾</span></b> في هذه الآية على أقوال: <b>الأول:</b> تتعجَّبون مما نزل بكم في زرعكم. <b>الثاني:</b> تتلاومون. <b>الثالث:</b> تندَّمون. <b>الرابع:</b> تفجَّعون.</p><p>و<span class="comment-type-3">رجَّح</span> <u>ابنُ جرير</u> (٢٢/٣٥١) -<span class="mustanad">مستندًا إلى اللغة</span>- القول الأول، وهو قول ابن عباس، ومجاهد، وقتادة، ومقاتل، وعلَّل ذلك بأن أصله: «من التفكُّه بالحديث: إذا حدَّث الرجلُ الرجلَ بالحديث يُعْجَب منه، ويَلْهى به، فكذلك ذلك، وكأن معنى الكلام: فأقمتم تتعجَّبون، يُعَجِّب بعضكم بعضًا مما نزل بكم».</p><p>و<span class="comment-type-2">استدرك</span> <u>ابنُ عطية</u> (٨/٢٠٦) على هذه الأقوال الأربعة بقوله: «وهذا كلّه تفسير لا يخصُّ اللفظة، والذي يخصُّ اللفظة هو: تطرحون الفكاهة عن أنفسكم، وهي المَسَرَّة والجزل، ورجلٌ فَكِهٌ: إذا كان منبسط النفس غير مكترث بالشيء».</div></p></div>",footnotes:1:تفسير البغوي ٨/٢٠.تفسير مقاتل بن سليمان ٤/٢٢٢.أخرجه ابن جرير ٢٢/٣٤٩.عزاه السيوطي إلى ابن مردويه.أخرجه عبد الرزاق ٢/٢٧٢، وابن جرير ٢٢/٣٤٩، وابن أبي حاتم -كما في الفتح ٨/٦٢٦- بلفظ: تتعجبون مما نزل بكم في زرعكم.أخرجه ابن المنذر -كما في الفتح ٨/٦٢٦-.أخرجه ابن جرير ٢٢/٣٤٩-٣٥٠، وبمثله من طريق سماك.أخرجه ابن جرير ٢٢/٣٥٠. وعزاه السيوطي إلى عبد بن حميد.تفسير البغوي ٨/٢٠.أخرجه ابن جرير ٢٢/٣٤٩، وعبد الرزاق -كما في الفتح ٨/٦٢٦-.أخرجه ابن جرير ٢٢/٣٥٠.تفسير مقاتل بن سليمان ٤/٢٢٢. وفي تفسير البغوي ٨/٢٠ بنحوه منسوبًا إلى مقاتل دون تعيينه.أخرجه ابن جرير ٢٢/٣٥٠، ٣٥١.
  56,66,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿إِنَّا لَمُغۡرَمُونَ ۝٦٦﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٥٢٣٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق السُّدِّيّ، عن أبي مالك وأبي صالح- <span class="qpc-hafs">﴿إنّا لَمُغْرَمُونَ﴾</span>، يقول: إنّا لَمُوّارٌ به{1}. (١٤/٢٥١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٥٢٣٩<span class="dash">-</span></span> قال <span class="name-1">عبد الله بن عباس</span>، في قوله: <span class="qpc-hafs">﴿إنّا لَمُغْرَمُونَ﴾</span> معذَّبون{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٥٢٤٠<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿إنّا لَمُغْرَمُونَ﴾</span>، قال: مُلقَون للشرّ{3}. (١٤/٢١٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٥٢٤١<span class="dash">-</span></span> قال <span class="name-2">مجاهد بن جبر</span> -من طريق معمر- في قوله: <span class="qpc-hafs">﴿إنّا لَمُغْرَمُونَ﴾</span>، أي: لَمُولع بنا{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٥٢٤٢<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span> -من طريق يزيد النحوي- في قوله: <span class="qpc-hafs">﴿إنّا لَمُغْرَمُونَ﴾</span>، قال: إنّا لَمُولع بنا{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٥٢٤٣<span class="dash">-</span></span> قال <span class="name-2">الضَّحّاك بن مُزاحِم</span>: <span class="qpc-hafs">﴿إنّا لَمُغْرَمُونَ﴾</span> غرمنا أموالنا، وصار ما أنفقنا غُرمًا علينا، والمُغرم الذي ذهب مالُه بغير عِوَض{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٥٢٤٤<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿إنّا لَمُغْرَمُونَ﴾</span>: أي: مُعذّبون{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٥٢٤٥<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق شعبة- <span class="qpc-hafs">﴿لَمُغْرَمُونَ﴾</span>: لَملزمون{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٥٢٤٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: وقلتم: <span class="qpc-hafs">﴿إنّا لَمُغْرَمُونَ﴾</span>، يعني: إنّا لَمُولع بنا الغُرم{9}<span class=comment-ref>٦٤٤٩</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٤٤٩</span> اختُلف في معنى: <b><span class="qpc-hafs">﴿إنّا لَمُغْرَمُونَ﴾</span></b> على أقوال: <b>الأول:</b> إنّا لَمُولعٌ بنا. <b>الثاني:</b> إنّا لَمعذَّبون. <b>الثالث:</b> لَمُلْقَون للشر.</p><p>و<span class="comment-type-3">رجَّح</span> <u>ابنُ جرير</u> (٢٢/٣٥٢) -<span class="mustanad">مستندًا إلى لغة العرب</span>- القول الثاني، وهو قول قتادة، وعلَّل ذلك بقوله: «وذلك أن الغرام عند العرب: العذاب». واستشهد ببيتٍ من الشعر.</p><p>و<span class="comment-type-1">وجَّه</span> <u>ابنُ عطية</u> (٨/٢٠٦) القول الثاني بأنه: «من الغرام وهو أشد العذاب، ومنه قوله تعالى: <span class="qpc-hafs">﴿إنَّ عَذابَها كانَ غَرامًا﴾</span> [الفرقان:٦٥]». واستشهد له ببيت من الشعر، وذكر احتمالًا آخر: «أن يكون المعنى: إنّا لمحمَّلون الغرام». ثم <span class="comment-type-1">وجَّهه</span> بقوله: «أي: غرمنا في النفقة، وذهب زرعنا، تقول: غَرِمَ الرجل وأَغْرَمْتُه فهو مُغْرم».</div></p></div>",footnotes:1:عزاه السيوطي إلى ابن مردويه.تفسير البغوي ٨/٢١.تفسير مجاهد ص٦٤٤، وأخرجه ابن جرير ٢٢/٣٥٢، والفريابي -كما في تغليق التعليق ٤/٣٣٥-. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه عبد الرزاق ٢/٢٧٣، وابن جرير ٢٢/٣٥١.أخرجه ابن جرير ٢٢/٣٥١.تفسير البغوي ٨/٢١.أخرجه ابن جرير ٢٢/٣٥٢.أخرجه ابن أبي حاتم -كما في الفتح ٨/٦٢٦-.تفسير مقاتل بن سليمان ٤/٢٢٢.
  56,67,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿بَلۡ نَحۡنُ مَحۡرُومُونَ ۝٦٧﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٥٢٤٧<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿بَلْ نَحْنُ مَحْرُومُونَ﴾</span>، قال: مَحدُودون{1}<span class=comment-ref>٦٤٥٠</span>. (١٤/٢١٦)</p></p><p></div></p><p><div><span class=comment-ref>٦٤٥٠</span> <span class="comment-type-1">وجَّه</span> <u>ابنُ كثير</u> (١٣/٣٨٥) قول مجاهد بقوله: «يعني: لا حظّ لنا».</div></p><p><div></p><p><p><span class="item-no">٧٥٢٤٨<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿بَلْ نَحْنُ مَحْرُومُونَ﴾</span>، قال: جُوزينا، فحُرمنا{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٥٢٤٩<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- في قوله: <span class="qpc-hafs">﴿بَلْ نَحْنُ مَحْرُومُونَ﴾</span>، قال: أي: محارَفون{3}<span class=comment-ref>٦٤٥١</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٤٥١</span> <span class="comment-type-1">وجَّه</span> <u>ابن كثير</u> (١٣/٣٨٥) قول قتادة بقوله: «أي: لا يثبت لنا مال، ولا ينتج لنا ربح».</div></p><p><div></p><p><p><span class="item-no">٧٥٢٥٠<span class="dash">-</span></span> عن <span class="name-2">زيد بن أسلم</span> -من طريق ابن عيّاش- في قول الله: <span class="qpc-hafs">﴿والَّذِينَ فِي أمْوالِهِمْ حَقٌّ مَعْلُومٌ لِلسّائِلِ والمَحْرُومِ﴾</span> [المعارج:٢٤-٢٥]: ... والمحروم: الذي يُصاب زرعه أو حرْثه أو نسل ماشيته، فيكون له حقّ على مَن لم يُصِبْه من المسلمين، كما قال لأصحاب الجنة حين أهلك جنّتهم، فقالوا: <span class="qpc-hafs">﴿بَلْ نَحْنُ مَحْرُومُونَ﴾</span> [القلم:٢٧]، وقال أيضًا: <span class="qpc-hafs">﴿لَوْ نَشاءُ لَجَعَلْناهُ حُطامًا فَظَلْتُمْ تَفَكَّهُونَ إنّا لَمُغْرَمُونَ بَلْ نَحْنُ مَحْرُومُونَ﴾</span> [الواقعة:٦٥-٦٧]{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٥٢٥١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿بَلْ نَحْنُ مَحْرُومُونَ﴾</span>، ولقُلتم: بل حُرمنا خيرها{5}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير مجاهد ص٦٤٤، وأخرجه ابن جرير ٢٢/٣٥٢-٣٥٤، والفريابي -كما في تغليق التعليق ٤/٣٣٥-. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه ابن جرير ٢٢/٣٥٣.أخرجه عبد الرزاق في تفسيره ٢/٢٧٢، وابن جرير ٢٢/٣٥٣.أخرجه عبد الله بن وهب في الجامع -تفسير القرآن ١/٦١-٦٢ (١٣٦).تفسير مقاتل بن سليمان ٤/٢٢٢.
  56,68,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿أَفَرَءَیۡتُمُ ٱلۡمَاۤءَ ٱلَّذِی تَشۡرَبُونَ ۝٦٨ ءَأَنتُمۡ أَنزَلۡتُمُوهُ مِنَ ٱلۡمُزۡنِ أَمۡ نَحۡنُ ٱلۡمُنزِلُونَ ۝٦٩﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٥٢٥٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله</span> -من طريق قيس بن سكن- قال: إنّ الله -تبارك وتعالى- يُنشِئ السحاب، فيُرسل الريح، فتؤلّف السحاب، فتُدِرُّ كما تُدِرُّ اللّقحة. وقرأ: <span class="qpc-hafs">﴿أأَنْتُمْ أنْزَلْتُمُوهُ مِنَ المُزْنِ أمْ نَحْنُ المُنْزِلُونَ﴾</span>{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٥٢٥٣<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطية العَوفيّ- <span class="qpc-hafs">﴿أأَنْتُمْ أنْزَلْتُمُوهُ مِنَ المُزْنِ﴾</span>، قال: السّحاب{2}. (١٤/٢١٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٥٢٥٤<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق السُّدِّيّ، عن أبي مالك وأبي صالح- <span class="qpc-hafs">﴿أأَنْتُمْ أنْزَلْتُمُوهُ مِن المُزْنِ﴾</span>، يقول: من السحاب{3}. (١٤/٢٥١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٥٢٥٥<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿أأَنْتُمْ أنْزَلْتُمُوهُ مِن المُزْنِ﴾</span>، قال: السحاب{4}. (١٤/٢١٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٥٢٥٦<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٥٢٥٧<span class="dash">-</span></span> و<span class="name-2">قتادة بن دعامة</span> - من طريق سعيد-، مثله{5}. (١٤/٢١٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٥٢٥٨<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿أأَنْتُمْ أنْزَلْتُمُوهُ مِنَ المُزْنِ﴾</span> يعني: من السحاب، <span class="qpc-hafs">﴿أمْ نَحْنُ المُنْزِلُونَ﴾</span>{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٥٢٥٩<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿أأَنْتُمْ أنْزَلْتُمُوهُ مِنَ المُزْنِ أمْ نَحْنُ المُنْزِلُونَ﴾</span> قال: المُزْن: السّحاب اسمها، <span class="qpc-hafs">﴿أنْزَلْتُمُوهُ مِنَ المُزْنِ﴾</span> قال: السّحاب{7}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه البزار في البحر الزخار المعروف بمسند البزار ٨/١٧٩-١٨٠ (٣٢١٢).أخرجه ابن جرير ٢٢/٣٥٤. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.عزاه السيوطي إلى ابن مردويه.تفسير مجاهد ص٦٤٥، وأخرجه ابن جرير ٢٢/٣٥٢-٣٥٤، والفريابي -كما في تغليق التعليق ٤/٣٣٥-. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.عزاه السيوطي إلى عبد بن حميد. وأخرجه ابن جرير ٢٢/٣٥٤ عن قتادة.تفسير مقاتل بن سليمان ٤/٢٢٣.أخرجه ابن جرير ٢٢/٣٥١، ٣٥٤.
  56,69,""
  56,70,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿لَوۡ نَشَاۤءُ جَعَلۡنَـٰهُ أُجَاجࣰا فَلَوۡلَا تَشۡكُرُونَ ۝٧٠﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٥٢٦٠<span class="dash">-</span></span> قال <span class="name-1">عبد الله بن عباس</span>: <span class="qpc-hafs">﴿لَوْ نَشاءُ جَعَلْناهُ أُجاجًا﴾</span> شديد المُلوحة{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٥٢٦١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق السُّدِّيّ، عن أبي مالك وأبي صالح- <span class="qpc-hafs">﴿لَوْ نَشاءُ جَعَلْناهُ أُجاجًا﴾</span> يقول: مُرًّا؛ <span class="qpc-hafs">﴿فَلَوْلا تَشْكُرُونَ﴾</span> يقول: فهلّا تشكرون{2}. (١٤/٢٥١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٥٢٦٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> = (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٥٢٦٣<span class="dash">-</span></span> و<span class="name-2">مجاهد بن جبر</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٥٢٦٤<span class="dash">-</span></span> و<span class="name-2">قتادة بن دعامة</span>، في قوله: <span class="qpc-hafs">﴿أُجاجًا﴾</span>: منصبًّا{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٥٢٦٥<span class="dash">-</span></span> قال <span class="name-2">الحسن البصري</span>: <span class="qpc-hafs">﴿لَوْ نَشاءُ جَعَلْناهُ أُجاجًا﴾</span> مُرًّا{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٥٢٦٦<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span>: الأجاج: المرّ{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٥٢٦٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿لَوْ نَشاءُ﴾</span> بعد العُذُوبة <span class="qpc-hafs">﴿جَعَلْناهُ أُجاجًا﴾</span> يعني: مالِحًا، مُرًّا مِن شدة المُلوحة؛ <span class="qpc-hafs">﴿فَلَوْلا﴾</span> يعني: فهلّا <span class="qpc-hafs">﴿تَشْكُرُونَ﴾</span> ربَّ هذه النّعم، فتوحّدونه حين سقاكم ماءً عذبًا{6}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿لَوۡ نَشَاۤءُ جَعَلۡنَـٰهُ أُجَاجࣰا فَلَوۡلَا تَشۡكُرُونَ ۝٧٠﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٧٥٢٦٨<span class="dash">-</span></span> عن أبي جعفر، عن النبيِّ ﷺ أنه كان إذا شرب الماء، قال: «<b>الحمد لله الذي سقانا عَذبًا فُراتًا برحمته، ولم يجعله مِلْحًا أُجاجًا بذنوبنا</b>»{7}. (١٤/٢١٦)</p></p><p></div></p></div>",footnotes:1:تفسير البغوي ٨/٢١.عزاه السيوطي إلى ابن مردويه.أخرجه ابن جرير -كما في الفتح ٥/٢٩-.تفسير البغوي ٨/٢١.أخرجه ابن أبي حاتم -كما في الفتح ٥/٢٩-. وفي المطبوع من تفسير عبد الرزاق ٢/٧٠ من طريق معمر، ومن تفسير ابن أبي حاتم ٨/٢٧٠٨ من طريق سعيد، عند قوله تعالى: <span class="qpc-hafs">﴿وهذا ملح أجاج﴾</span> [الفرقان:٥٣].تفسير مقاتل بن سليمان ٤/٢٢٣.أخرجه ابن أبي حاتم -كما في تفسير ابن كثير ٨/١٨-.</p><p>ضعّفه الألباني في السلسلة الضعيفة (٤٢٠٢).
  56,71,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿أَفَرَءَیۡتُمُ ٱلنَّارَ ٱلَّتِی تُورُونَ ۝٧١﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٥٢٦٩<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق السُّدِّيّ، عن أبي مالك وأبي صالح- <span class="qpc-hafs">﴿أفَرَأَيْتُمُ النّارَ الَّتِي تُورُونَ﴾</span>، يقول: تَقدَحون{1}. (١٤/٢٥١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٥٢٧٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿أفَرَأَيْتُمُ النّارَ الَّتِي تُورُونَ﴾</span> يعني: تُوقِدون مِن الشجر والحجارة والقَصب، إلا العُنّاب{2}. (ز)</p></p><p></div></p></div>",footnotes:1:عزاه السيوطي إلى ابن مردويه.تفسير مقاتل بن سليمان ٤/٢٢٣.
  56,72,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿ءَأَنتُمۡ أَنشَأۡتُمۡ شَجَرَتَهَاۤ أَمۡ نَحۡنُ ٱلۡمُنشِـُٔونَ ۝٧٢﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٥٢٧١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق السُّدِّيّ، عن أبي مالك وأبي صالح- <span class="qpc-hafs">﴿أأَنْتُمْ أنْشَأْتُمْ﴾</span> يقول: خلَقتم <span class="qpc-hafs">﴿شَجَرَتَها أمْ نَحْنُ المُنْشِئُونَ﴾</span> قال: وهي مِن كلّ شجرة، إلا في العُنّاب{1}، وتكون في الحجارة{2}. (١٤/٢٥١-٢٥٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٥٢٧٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿أأَنْتُمْ أنْشَأْتُمْ﴾</span> يعني: خلقتم شجرتها، <span class="qpc-hafs">﴿أمْ نَحْنُ المُنْشِئُونَ﴾</span> يعني: الخالقون{3}<span class=comment-ref>٦٤٥٢</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٤٥٢</span> نقل <u>ابنُ عطية</u> (٨/٢٠٧) في معنى: <span class="qpc-hafs">﴿أأَنْتُمْ أنْشَأْتُمْ شَجَرَتَها﴾</span> عن بعض أهل النظر قولهم: «أراد بالشجرة: نفس النار». ثم <span class="comment-type-1">وجَّهه</span> بقوله: «كأنه تعالى يقول: نوعها أو جنسها، فاستعار الشجرة لذلك». ثم <span class="comment-type-2">انتقده</span> قائلًا: «وهو قولٌ فيه تكلُّف».</div></p></div>",footnotes:1:العناب: شجر شائك مِن الفصيلة السدرية، يبلغ ارتفاعه ستة أمتار، ويطلق العناب على ثمره أيضًا، وهو أحمر حلو لذيذ الطعم على شكل ثمرة النبق. الوسيط (عنب).عزاه السيوطي إلى ابن مردويه.تفسير مقاتل بن سليمان ٤/٢٢٣.
  56,73,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿نَحۡنُ جَعَلۡنَـٰهَا تَذۡكِرَةࣰ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٥٢٧٣<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، <span class="qpc-hafs">﴿نَحْنُ جَعَلْناها تَذْكِرَةً﴾</span>، قال: تذكرةٌ للنار الكبرى{1}. (١٤/٢١٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٥٢٧٤<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق السُّدِّيّ، عن أبي مالك وأبي صالح- <span class="qpc-hafs">﴿نَحْنُ جَعَلْناها تَذْكِرَةً﴾</span>، يقول: يتذكّر بها نار الآخرة العليا{2}. (١٤/٢٥٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٥٢٧٥<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿نَحْنُ جَعَلْناها تَذْكِرَةً﴾</span>، قال: هذه النار تذكرةٌ للنار الكبرى{3}. (١٤/٢١٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٥٢٧٦<span class="dash">-</span></span> قال <span class="name-2">عكرمة مولى ابن عباس</span>: <span class="qpc-hafs">﴿تَذْكِرَةً﴾</span> تذكرةٌ للنار الكبرى؛ إذا رآها الرائي ذَكر جهنم{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٥٢٧٧<span class="dash">-</span></span> قال <span class="name-2">عطاء</span>: <span class="qpc-hafs">﴿تَذْكِرَةً﴾</span> موعظة يتّعظ بها المؤمن{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٥٢٧٨<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- <span class="qpc-hafs">﴿نَحْنُ جَعَلْناها تَذْكِرَةً﴾</span>، قال: تذكرةٌ للنار الكبرى{6}. (١٤/٢١٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٥٢٧٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿نَحْنُ جَعَلْناها﴾</span> هذه النار التي في الدنيا <span class="qpc-hafs">﴿تَذْكِرَةً﴾</span> لنار جهنم الكبرى{7}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَمَتَـٰعࣰا لِّلۡمُقۡوِینَ ۝٧٣﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٥٢٨٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- <span class="qpc-hafs">﴿ومَتاعًا لِلْمُقْوِينَ﴾</span>، قال: للمسافرين{8}. (١٤/٢١٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٥٢٨١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق السُّدِّيّ، عن أبي مالك وأبي صالح- <span class="qpc-hafs">﴿ومَتاعًا لِلْمُقْوِينَ﴾</span>، قال: والمُقوِي: هو الذي لا يجد نارًا، فيُخْرِج زِنده، فيستنوِر ناره، فهي متاعٌ له{2}. (١٤/٢٥٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٥٢٨٢<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿ومَتاعًا لِلْمُقْوِينَ﴾</span>، قال: للمستمتعين؛ الناس أجمعين. وفي لفظ: للحاضر، والبادي{10}. (١٤/٢١٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٥٢٨٣<span class="dash">-</span></span> عن <span class="name-2">الضَّحّاك بن مُزاحِم</span> -من طريق عبيد- يقول في قوله: <span class="qpc-hafs">﴿ومَتاعًا لِلْمُقْوِينَ﴾</span>، قال: للمسافرين{11}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٥٢٨٤<span class="dash">-</span></span> قال <span class="name-2">عكرمة مولى ابن عباس</span>: <span class="qpc-hafs">﴿ومَتاعًا لِلْمُقْوِينَ﴾</span>، يعني: للمُستمتعين بها مِن الناس أجمعين، المسافرين والحاضرين، يستضيئون بها في الظّلمة، ويصْطَلون مِن البرد، وينتفعون بها في الطّبخ والخبز{12}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٥٢٨٥<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span>، <span class="qpc-hafs">﴿ومَتاعًا لِلْمُقْوِينَ﴾</span>، قال: للمسافرين{13}. (١٤/٢١٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٥٢٨٦<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿ومَتاعًا لِلْمُقْوِينَ﴾</span>، قال: للمسافرين؛ كم مِن قوم قد سافروا، ثم أرْمَلوا، فأجّجوا نارًا، فاستدفؤوا بها، وانتفعوا بها!{14}. (١٤/٢١٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٥٢٨٧<span class="dash">-</span></span> قال <span class="name-2">إسماعيل السُّدِّيّ</span> = (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٥٢٨٨<span class="dash">-</span></span> و<span class="name-2">الربيع بن أنس</span>: <span class="qpc-hafs">﴿ومَتاعًا لِلْمُقْوِينَ﴾</span> يعني: للمنزلين المقترين المُرملين، الذين لا زاد معهم، يعني: نارًا يُوقدون، فيختبزون بها{15}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٥٢٨٩<span class="dash">-</span></span> عن <span class="name-2">خُصَيف</span> -من طريق عتاب بن بشير- في قوله: <span class="qpc-hafs">﴿ومَتاعًا لِلْمُقْوِينَ﴾</span>، قال: للخلق{11}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٥٢٩٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: وهي <span class="qpc-hafs">﴿مَتاعًا لِلْمُقْوِينَ﴾</span>، يعني: متاعًا للمسافرين لِمَن كان بأرض فَلاة وللأعراب{17}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٥٢٩١<span class="dash">-</span></span> قال <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿ومَتاعًا لِلْمُقْوِينَ﴾</span>، قال: المُقوِي: الجائع. وفي كلام العرب يقول: أقويتُ من هكذا وكذا. ما أكلْتُ مِن هكذا وكذا شيئًا{18}<span class=comment-ref>٦٤٥٣</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٤٥٣</span> اختُلف في معنى: «المُقْوِين» في هذه الآية على أقوال: <b>الأول:</b> المسافرون. <b>الثاني:</b> المستمتعون بها. <b>الثالث:</b> الجائعون.</p><p>و<span class="comment-type-3">رجَّح</span> <u>ابنُ جرير</u> (٢٢/٣٥٨) -<span class="mustanad">مستندًا إلى اللغة</span>- القول الأول، وهو قول ابن عباس، والضَّحّاك، والحسن، وقتادة، ومقاتل، فقال: «وأولى الأقوال في ذلك بالصواب عندي قولُ مَن قال: عُنِيَ بذلك: للمسافر الذي لا زاد معه، ولا شيء له. وأصله من قولهم: أقْوَت الدار: إذا خَلَت من أهلها وسكانها». واستشهد ببيتٍ من الشعر.</p><p>و<span class="comment-type-4">علَّق</span> <u>ابنُ كثير</u> (١٣/٣٨٧) على القول الثاني بقوله: «وهذا التفسير أعمُّ مِن غيره، فإنّ الحاضر والبادي مِن غني وفقير، الكلّ محتاجون للطبخ والاصطلاء والإضاءة وغير ذلك من المنافع. ثم مِن لطف الله تعالى أنْ أودعها في الأحجار، وخالص الحديد، بحيث يتمكّن المسافر مِن حمْل ذلك في متاعه وبين ثيابه، فإذا احتاج إلى ذلك في منزله أخرج زِنده وأورى، وأوقد ناره فاطبخ بها واصطلى، واشتوى واستأنس بها، وانتفع بها سائر الانتفاعات؛ فلهذا أفرد المسافرون، وإن كان ذلك عامًّا في حق الناس كلّهم».</p><p>وذكر <u>ابنُ عطية</u> (٨/٢٠٧) أن معنى «المُقْوِين» في هذه الآية: «الكائنون في الأرض القواء، وهي الفيافي». ثم ذكر أنّ بعض الناس «عبر في تفسير»المُقْوِين«بأشياء ضعيفة، كقول ابن زيد: للجائعين ونحوه». ولم يذكر مستندًا، ثم <span class="comment-type-4">علَّق</span> على القول الأول بقوله: «ومَن قال: معناه: للمسافرين. فهو نحو ما قلناه، وهي عبارة ابن عباس ﵄، تقول: أصبح الرجل: دخل في الصباح، وأَصْحَرَ: دخل في الصحراء، وأقوى: دخل في الأرض القَواء، ومنه: أقْوَت الدار، أقوى الطَّلَلُ، أي: صار قواءً ...».</p><p>وذكر <u>ابنُ القيم</u> (٣/١١٤) أنّ «المُقْوين»: هم المسافرون. ثم <span class="comment-type-4">علَّق</span> بقوله: «وخصّ المُقْوين بالذكر، وإن كانت منفعتها عامةً للمسافرين والمقيمين تنبيهًا لعباده -والله أعلم بمراده مِن كلامه- على أنهم كلّهم مسافرون، وأنهم في هذه الدار على جناح سفر ليسوا هم مقيمين ولا مستوطنين، وأنهم عابرو سبيل وأبناء سفر».</div></p></div>",footnotes:1:أخرجه ابن أبي حاتم من طريق علي -كما في الإتقان ٢/٤٧-. وعزاه السيوطي إلى عبد بن حميد، وابن جرير، وابن المنذر، وابن مردويه.عزاه السيوطي إلى ابن مردويه.تفسير مجاهد ص٦٤٥، وأخرجه ابن جرير ٢٢/٣٥٥-٣٥٦ بنحوه من طريق جابر، وهناد (٢٣٧). وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.تفسير البغوي ٨/٢١.تفسير البغوي ٨/٢١.أخرجه عبد الرزاق ٢/٢٧٣، وابن جرير ٢٢/٣٥٥. وعزاه السيوطي إلى عبد بن حميد.تفسير مقاتل بن سليمان ٤/٢٢٣. وفي تفسير البغوي ٨/٢١ نحوه عن مقاتل دون تعيينه.أخرجه ابن جرير ٢٢/٣٥٦، وبمثله من طريق عطية، وابن أبي حاتم -كما في الإتقان ٢/٤٧-. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن مردويه.عزاه السيوطي إلى ابن مردويه.تفسير مجاهد ص٦٤٥، وأخرجه ابن جرير ٢٢/٣٥٥-٣٥٧، وبنحوه من طريق جابر، وهناد (٢٣٧). وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.أخرجه ابن جرير ٢٢/٣٥٧.تفسير البغوي ٨/٢٢.ذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٤/٣٤٢-. وعزاه السيوطي إلى عبد بن حميد.أخرجه عبد الرزاق ٢/٢٧٣، وابن جرير ٢٢/٣٥٧ كلاهما من طريق معمر بنحوه. وعزاه السيوطي إلى عبد بن حميد.تفسير الثعلبي ٩/٢١٧.أخرجه ابن جرير ٢٢/٣٥٧.تفسير مقاتل بن سليمان ٤/٢٢٣.أخرجه ابن جرير ٢٢/٣٥٨.
  56,74,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿فَسَبِّحۡ بِٱسۡمِ رَبِّكَ ٱلۡعَظِیمِ ۝٧٤﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٥٢٩٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق السُّدِّيّ، عن أبي مالك وأبي صالح- <span class="qpc-hafs">﴿فَسَبِّحْ بِاسْمِ رَبِّكَ العَظِيمِ﴾</span>، يقول: فَصَلِّ لربّك العظيم{1}. (١٤/٢٥٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٥٢٩٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فَسَبِّحْ﴾</span> يقول: اذكر التوحيد <span class="qpc-hafs">﴿بِاسْمِ رَبِّكَ﴾</span> يا محمد <span class="qpc-hafs">﴿العَظِيمِ﴾</span> يعني: الكبير، فلا أكبر منه{2}. (ز)</p></p><p></div></p></div>",footnotes:1:عزاه السيوطي إلى ابن مردويه.تفسير مقاتل بن سليمان ٤/٢٢٣.
  56,75,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿فَلَاۤ أُقۡسِمُ بِمَوَ ٰ⁠قِعِ ٱلنُّجُومِ ۝٧٥﴾</span> - قراءات</h3></p><p><div></p><p><p><span class="item-no">٧٥٢٩٤<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن مسعود</span> -من طريق أبي حَرِيز قاضي سجستان- أنه قرأ: ‹فَلَآ أُقْسِمُ بِمَوْقِعِ النُّجُومِ›{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٥٢٩٥<span class="dash">-</span></span> عن مُغيرة، عن <span class="name-2">إبراهيم</span> أنه كان يقرأ: <span class="qpc-hafs">﴿فَلَآ أُقْسِمُ بِمَواقِعِ النُّجُومِ﴾</span>{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٥٢٩٦<span class="dash">-</span></span> عن <span class="name-2">عاصم</span> أنه قرأ: <span class="qpc-hafs">﴿فَلَآ أُقْسِمُ﴾</span> ممدودة مرفوعة الألف <span class="qpc-hafs">﴿بِمَواقِعِ النُّجُومِ﴾</span> على الجماع{3}<span class=comment-ref>٦٤٥٤</span>. (١٤/٢١٧)</p></p><p></div></p><p><div><span class=comment-ref>٦٤٥٤</span> اختلفت القرأة في قراءة قوله تعالى: <b><span class="qpc-hafs">﴿بِمَواقِعِ النُّجُومِ﴾</span></b> على قراءتين: <b>الأولى:</b> <span class="qpc-hafs">﴿بمواقع النجوم﴾</span> على الجمع. <b>الثانية:</b> ‹بِمَوْقِعِ النُّجُومِ› على الإفراد.</p><p>و<span class="comment-type-3">رجَّح</span> <u>ابنُ جرير</u> (٢٢/٣٦٢) «أنهما قراءتان معروفتان بمعنًى واحد، فبأيَّتِهما قرأ القارئ فمصيبٌ».</p><p>و<span class="comment-type-1">وجَّه</span> <u>ابنُ القيم</u> (٣/١١٦) القراءة الثانية بقوله: «ومن قرأ ‹بِمَوْقِعِ النُّجُومِ› على الإفراد؛ فلدلالة الواحد المضاف إلى الجمع على التعدد، والموقع اسم جنس، والمصادر إذا اختلفت جُمعت، وإذا كان النوع واحدًا أُفردت، قال تعالى: <b><span class="qpc-hafs">﴿إنَّ أنْكَرَ الأَصْواتِ لَصَوْتُ الحَمِيرِ﴾</span></b> [لقمان:١٩]، فجمع الأصوات لتعدد النوع، وأفرد صوت الحمير لوحدته، فإفراد موقع النجوم لوحدة المضاف إليه، وتعدد الموقع لتعدده؛ إذ لكل نجم موقع».</p><p>و<span class="comment-type-4">نحوه</span> قال <u>ابنُ عطية</u> (٨/٢٠٩).</div></p><p><h3><span class="qpc-hafs">﴿فَلَاۤ أُقۡسِمُ بِمَوَ ٰ⁠قِعِ ٱلنُّجُومِ ۝٧٥﴾</span> - نزول الآيات</h3></p><p><div></p><p><p><span class="item-no">٧٥٢٩٧<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق أبي زُمَيْل- قال: مُطِر الناسُ على عهد النبي ﷺ، فقال النبي ﷺ: «<b>أصبح مِن الناس شاكر، ومنهم كافر، قالوا: هذه رحمة الله. وقال بعضهم: لقد صدق نَوء كذا وكذا</b>». قال: فنَزَلَتْ هذه الآية: <span class="qpc-hafs">﴿فَلا أُقْسِمُ بِمَواقِعِ النُّجُومِ﴾</span> حتى بلغ: <span class="qpc-hafs">﴿وتَجْعَلُونَ رِزْقَكُمْ أنَّكُمْ تُكَذِّبُونَ﴾</span>{4}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿فَلَاۤ أُقۡسِمُ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٥٢٩٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق السُّدِّيّ، عن أبي مالك وأبي صالح- في قوله: <span class="qpc-hafs">﴿فَلا أُقْسِمُ﴾</span> يقول: أقسم <span class="qpc-hafs">﴿بِمَواقِعِ النُّجُومِ﴾</span>{5}. (١٤/٢٥٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٥٢٩٩<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جُبَير</span> -من طريق الحسن بن مسلم- <span class="qpc-hafs">﴿فَلا أُقْسِمُ﴾</span>، قال: أقسم{6}<span class=comment-ref>٦٤٥٥</span>. (١٤/٢١٧)</p></p><p></div></p><p><div><span class=comment-ref>٦٤٥٥</span> نقل <u>ابنُ عطية</u> (٨/٢٠٨) في معنى: «لا» من قوله تعالى: <b><span class="qpc-hafs">﴿فَلا أُقْسِمُ﴾</span></b> عن سعيد بن جُبَير، وبعض النحويين قولهم: هي نافية. ثم <span class="comment-type-1">وجَّهه</span> بقوله: «كأنه تعالى يقول: فَلا صحة لما يقوله الكفار، ثم ابتدأ -تبارك وتعالى- فقال: <span class="qpc-hafs">﴿أُقْسِمُ﴾</span>».</p><p>ونقل <u>ابنُ كثير</u> (١٣/٣٨٩) عن الضَّحّاك من طريق جويبر قوله: «إنّ الله لا يقسم بشيء مِن خلْقه، ولكنه استفتاح يستفتح به كلامه». ثم <span class="comment-type-2">انتقده</span> قائلًا: «وهذا القول ضعيف». ولم يذكر مستندًا.</div></p><p><h3><span class="qpc-hafs">﴿بِمَوَ ٰ⁠قِعِ ٱلنُّجُومِ ۝٧٥﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٥٣٠٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن مسعود</span> -من طريق المنهال بن عمرو- <span class="qpc-hafs">﴿فَلا أُقْسِمُ بِمَواقِعِ النُّجُومِ﴾</span>، قال: بمحكم القرآن، فكان يَنزِل على النبيِّ ﷺ نجومًا{7}. (١٤/٢١٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٥٣٠١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق سعيد بن جُبَير- في قوله: <span class="qpc-hafs">﴿فَلا أُقْسِمُ بِمَواقِعِ النُّجُومِ﴾</span> قال: القرآن، <span class="qpc-hafs">﴿وإنَّهُ لَقَسَمٌ لَوْ تَعْلَمُونَ عَظِيمٌ﴾</span> قال: القرآن{8}. (١٤/٢١٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٥٣٠٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق سعيد بن جُبَير- قال: أُنزِل القرآنُ في ليلة القدر مِن السماء العليا إلى السماء الدنيا جُملة واحدة، ثم فُرّق في السنين. وفي لفظ: ثم نزل من السماء الدنيا إلى الأرض نجومًا{9}. ثم قرأ: <span class="qpc-hafs">﴿فَلا أُقْسِمُ بِمَواقِعِ النُّجُومِ﴾</span>{10}. (١٤/٢١٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٥٣٠٣<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>: <span class="qpc-hafs">﴿فَلا أُقْسِمُ بِمَواقِعِ النُّجُومِ﴾</span> بألفٍ. قال: نجوم القرآن حين ينزل{5}. (١٤/٢١٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٥٣٠٤<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، قال: أُنزِل القرآنُ إلى السماء الدنيا جملة واحدة، ثم أُنزِل إلى الأرض نجومًا؛ ثلاث آيات، وخمس آيات، وأقلّ، وأكثر، فقال: <span class="qpc-hafs">﴿فَلا أُقْسِمُ بِمَواقِعِ النُّجُومِ﴾</span>{12}. (١٤/٢١٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٥٣٠٥<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطية- <span class="qpc-hafs">﴿فَلا أُقْسِمُ بِمَواقِعِ النُّجُومِ﴾</span>، قال: مستقرّ الكتاب؛ أوّله وآخره{13}. (١٤/٢٢٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٥٣٠٦<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق السُّدِّيّ، عن أبي مالك وأبي صالح-: أنّ عُلَيَّة بن الأسود أو نافع بن الحكم أتاه، فقال له: يا ابن عباس، إني أقرأ آيات من كتاب الله، أخشى أن يكون قد دخلني منها شيء. قال ابن عباس: ولِمَ ذلك؟ قال: لأني أسمع الله يقول: <span class="qpc-hafs">﴿إنّا أنْزَلْناهُ فِي لَيْلَةِ القَدْرِ﴾</span> [القدر:١]، ويقول: <span class="qpc-hafs">﴿إنّا أنْزَلْناهُ فِي لَيْلَةٍ مُبارَكَةٍ إنّا كُنّا مُنْذِرِينَ﴾</span> [الدخان:٣]، ويقول في آية أخرى: <span class="qpc-hafs">﴿شَهْرُ رَمَضانَ الَّذِي أُنْزِلَ فِيهِ القُرْآنُ﴾</span> [البقرة:١٨٥]، وقد نزل في الشهور كلّها شوال وغيره. قال ابن عباس: ويلك، إنّ جملة القرآن أُنزل من السماء في ليلة القدر إلى بدء موقع النجوم. يقول: إلى سماء الدنيا، فنزل به جبريل في ليلة منه، وهي ليلة القَدْر المباركة، وهي في رمضان، ثم نزل به على محمد ﷺ في عشرين سنة؛ الآية والآيتين والأكثر، فذلك قوله: <span class="qpc-hafs">﴿فَلا أُقْسِمُ﴾</span> يقول: أقسم <span class="qpc-hafs">﴿بِمَواقِعِ النُّجُومِ﴾</span>{5}. (١٤/٢٥٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٥٣٠٧<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق الأعمش- <span class="qpc-hafs">﴿فَلا أُقْسِمُ بِمَواقِعِ النُّجُومِ﴾</span>، قال: هو مُحكَم القرآن{15}. (١٤/٢١٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٥٣٠٨<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿فَلا أُقْسِمُ بِمَواقِعِ النُّجُومِ﴾</span>، قال: نجوم السماء{16}. (١٤/٢١٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٥٣٠٩<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- قوله: <span class="qpc-hafs">﴿بِمَواقِعِ النُّجُومِ﴾</span>، قال: في السماء، ويقال: مطالعها ومساقطها{17}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٥٣١٠<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span> -من طريق يزيد- في قوله: <span class="qpc-hafs">﴿فَلا أُقْسِمُ بِمَواقِعِ النُّجُومِ﴾</span>، قال: أنزل الله القرآن نجومًا؛ ثلاث آيات، وأربع آيات، وخمس آيات{13}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٥٣١١<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span> -من طريق المعتمر، عن أبيه-: إنّ القرآن نزل جميعًا، فوُضِع بمواقع النجوم، فجعل جبريل يأتي بالسورة، وإنّما نزل جميعًا في ليلة القَدْر{13}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٥٣١٢<span class="dash">-</span></span> قال <span class="name-2">الحسن البصري</span> -من طريق قتادة- في قوله: <span class="qpc-hafs">﴿فَلا أُقْسِمُ بِمَواقِعِ النُّجُومِ﴾</span>، قال: انكدارها، وانتثارها يوم القيامة{20}. (١٤/٢١٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٥٣١٣<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span>، <span class="qpc-hafs">﴿فَلا أُقْسِمُ بِمَواقِعِ النُّجُومِ﴾</span>، قال: بمغايبها{3}. (١٤/٢١٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٥٣١٤<span class="dash">-</span></span> قال <span class="name-2">عطاء</span>: <span class="qpc-hafs">﴿فَلا أُقْسِمُ بِمَواقِعِ النُّجُومِ﴾</span>، أراد: منازلها{22}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٥٣١٥<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿فَلا أُقْسِمُ بِمَواقِعِ النُّجُومِ﴾</span>، قال: بمساقطها{20}. (١٤/٢١٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٥٣١٦<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- في قوله: <span class="qpc-hafs">﴿فَلا أُقْسِمُ بِمَواقِعِ النُّجُومِ﴾</span>، قال: بمنازل النجوم{24}. (١٤/٢١٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٥٣١٧<span class="dash">-</span></span> قال <span class="name-3">محمد بن السّائِب الكلبي</span> -من طريق معمر- <span class="qpc-hafs">﴿فَلا أُقْسِمُ بِمَواقِعِ النُّجُومِ﴾</span>: هو القرآن كان ينزل نجومًا{25}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٥٣١٨<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فَلا أُقْسِمُ بِمَواقِعِ النُّجُومِ﴾</span> يعني: بمساقط النجوم مِن القرآن كلّه أوله وآخره في ليلة القَدْر، نزل من اللوح المحفوظ مِن السماء السابعة إلى السماء الدنيا إلى السّفرة، وهم الكتبة من الملائكة، نظيرها في <span class="qpc-hafs">﴿عبس وتولى﴾</span> [١٥-١٦]: <span class="qpc-hafs">﴿بِأَيْدِي سَفَرَةٍ كِرامٍ بَرَرَةٍ﴾</span>{26}<span class=comment-ref>٦٤٥٦</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٦٤٥٦</span> اختُلف في معنى: «النجوم» التي أقسم بمواقعها في هذه الآية على قولين: <b>الأول:</b> أنها نجوم السماء. وفي مواقعها ثلاثة أقوال: <b>أحدها:</b> منازلها. <b>ثانيها:</b> مساقطها. <b>ثالثها:</b> انتثارها عند قيام الساعة. <b>الثاني:</b> أنها آيات القرآن، ومواقعها: نزولها شيئًا بعد شيء.</p><p>و<span class="comment-type-1">وجَّه</span> <u>ابنُ القيم</u> (٣/١١٥) قول مَن قال: إنها نجوم السماء، ومواقعها: مساقطها. بقوله: «وعلى هذا فتكون المناسبة بين ذِكر النجوم في القسم وبين المُقسم عليه وهو القرآن من وجوه: <b>أحدها</b>: أنّ النجوم جعلها الله يُهتدى بها في ظلمات البر والبحر، وآيات القرآن يُهتدى بها في ظلمات الجهل والغي، فتلك هداية في الظلمات الحسية، وآيات القرآن في الظلمات المعنوية؛ فجمع بين الهدايتين، مع ما في النجوم من الرجوم للشياطين، وفي آيات القرآن من رجوم شياطين الإنس والجن، والنجوم آياته المشهودة المعاينة، والقرآن آياته المتلوة السمعية، مع ما في مواقعها عند الغروب من العِبرة والدلالة على آياته القرآنية ومواقعها عند النزول».</p><p>و<span class="comment-type-4">علَّق</span> <u>ابنُ عطية</u> (٨/٢٠٩) على القول الثاني بقوله: «ويؤيد هذا القول عوْد الضمير على القرآن في قوله سبحانه: <span class="qpc-hafs">﴿إنَّهُ لَقُرْآنٌ كَرِيمٌ﴾</span>، وذلك أنّ ذِكْرَه لم يتقدم إلا على هذا التأويل، ومَن لا يتأول هذا التأويل يقول: إنّ الضمير يعود على القرآن وإن لم يتقدم له ذِكر لشهرة الأمر ووضوح المعنى، كقوله تعالى: <b><span class="qpc-hafs">﴿حَتّى تَوارَتْ بِالحِجابِ﴾</span></b> [ص: ٣٢]، و<b><span class="qpc-hafs">﴿كُلُّ مَن عَلَيْها فانٍ﴾</span></b> [الرحمن: ٢٦] وغير ذلك».</p><p><span class="comment-type-3">ورجَّح</span> <u>ابن جرير</u> (٢٢/٣٦١) -<span class="mustanad">مستندًا إلى الأغلب في اللغة</span>- أنه قسمٌ بمساقط النجوم ومغايبها في السماء، وهو قول مجاهد من طريق ابن أبي نجيح، وقول الحسن، وقتادة من طريق سعيد، وعلَّل ذلك بقوله: «وذلك أن المواقع جمع موقع، والموقع المَفْعِل، من وقَع يَقَعُ مَوقِعًا، فالأغلب من معانيه والأظهر من تأويله ما قلنا في ذلك، ولذلك قلنا: هو أوْلى معانيه به».</p><p>وزاد <u>ابن عطية</u> (ينظر: ٨/٢١٠) قولًا أنّ مواقع النجوم: عند الانقضاض إثر العفاريت.</div></p></div>",footnotes:1:أخرجه الفراء في معاني القرآن ٣/٩٤.</p><p>وهي قراءة متواترة، قرأ بها حمزة، والكسائي، وخلف، وقرأ بقية العشرة: <span class="qpc-hafs">﴿بِمَواقِعِ﴾</span> على الجمع. انظر: النشر ٢/٣٨٣، والإتحاف ص٥٣١.أخرجه سعيد بن منصور في سننه -التفسير ٨/١٧ (٢١٦٣). قال المحقق: رُسمت في الأصل بألف بعد الواو، والقراءة المنسوبة لإبراهيم بلا ألف وبإسكان الواو؛ على الإفراد (بمَوْقِع).عزاه السيوطي إلى عبد بن حميد.أخرجه مسلم ١/٨٤ (٧٣).عزاه السيوطي إلى ابن مردويه.أخرجه ابن جرير ٢٢/٣٥٩.أخرجه الفراء في معاني القرآن ٣/١٢٩.</p><p>وذكر السيوطي أنه بسند صحيح.أخرجه ابن جرير ٣/١٩١، ومحمد بن نصر في مختصر قيام الليل ص١٠٤، والطبراني (١٢٤٢٦). وعزاه السيوطي إلى عبد بن حميد، وابن أبي حاتم، وابن المنذر، وابن مردويه.نجومًا: مفرقًا، ويقال: نجمت المال: إذا وزعته. التاج (نجم).أخرجه آدم بن أبي إياس -كما في تفسير مجاهد ص٦٤٥- بنحوه، والنسائي في الكبرى (١١٥٦٥)، وابن جرير ٢٢/٣٥٩، ومحمد بن نصر ص١٠٤، والحاكم ٢/٥٣٠، والبيهقي في شعب الإيمان (٢٢٥٠). وعزاه السيوطي إلى ابن مردويه.عزاه السيوطي إلى ابن مردويه.عزاه السيوطي إلى ابن المنذر، وابن الأنباري في كتاب المصاحف، وابن مردويه.أخرجه ابن جرير ٢٢/٣٦٠.عزاه السيوطي إلى ابن مردويه.أخرجه ابن جرير ٢٢/٣٦٠، ومحمد بن نصر ص١٠٤ بلفظ: النجوم: القرآن، وابن الضريس (١٣٠).تفسير مجاهد ص٦٤٥، وأخرجه ابن جرير ٢٢/٣٦٠-٣٦١. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر.تفسير مجاهد ص٦٤٥، وأخرجه ابن جرير ٢٢/٣٦٠.أخرجه ابن جرير ٢٢/٣٦٠.أخرجه ابن جرير ٢٢/٣٦٠.أخرجه ابن جرير ٢٢/٣٦١. وعزاه السيوطي إلى عبد بن حميد.عزاه السيوطي إلى عبد بن حميد.تفسير البغوي ٨/٢٢.أخرجه ابن جرير ٢٢/٣٦١. وعزاه السيوطي إلى عبد بن حميد.أخرجه عبد الرزاق ٢/٢٧٣، وابن جرير ٢٢/٣٦١.أخرجه عبد الرزاق ٢/٢٧٣.تفسير مقاتل بن سليمان ٤/٢٢٣.
  56,76,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَإِنَّهُۥ لَقَسَمࣱ لَّوۡ تَعۡلَمُونَ عَظِیمٌ ۝٧٦﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٧٥٣١٩<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق سعيد بن جُبَير- <span class="qpc-hafs">﴿وإنَّهُ لَقَسَمٌ لَوْ تَعْلَمُونَ عَظِيمٌ﴾</span>: هذا القرآن قَسمٌ عظيم{1}. (١٤/٢١٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٥٣٢٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق السُّدِّيّ، عن أبي مالك وأبي صالح-: <span class="qpc-hafs">﴿وإنَّهُ لَقَسَمٌ﴾</span> والقَسم قَسمٌ إلى قوله: <span class="qpc-hafs">﴿لا يَمَسُّهُ إلّا المُطَهَّرُونَ﴾</span>{2}. (١٤/٢٥٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٧٥٣٢١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثم عظّم القَسَم، فقال: <span class="qpc-hafs">﴿وإنَّهُ لَقَسَمٌ لَوْ تَعْلَمُونَ عَظِيمٌ﴾</span>{3}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه آدم بن أبي إياس -كما في تفسير مجاهد ص٦٤٥-. وعزا السيوطيُّ نحوه إلى عبد بن حميد، وابن أبي حاتم، وابن المنذر، وابن مردويه.عزاه السيوطي إلى ابن مردويه.تفسير مقاتل بن سليمان ٤/٢٢٣.