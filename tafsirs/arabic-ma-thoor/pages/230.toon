quran[10]{c,v,t}:
  11,72,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿ءَأَلِدُ وَأَنَا۠ عَجُوزࣱ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٥٩١٧<span class="dash">-</span></span> قال <span class="name-2">مجاهد بن جبر</span>، في قوله: <span class="qpc-hafs">﴿أألد وأنا عجوز﴾</span>: كانت لِتسع وتسعين سنة{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٩١٨<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿ءألد وأنا عجوز وهذا بعلي شيخًا﴾</span>، قال: وهي يومئذ ابنة سبعين{2}. (٨/١٠٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٩١٩<span class="dash">-</span></span> عن محمد بن إسحاق -من طريق سلمة- قال: ذكر أبي، عن بعض مَن قرأ الكتاب: أنّها كانت بنت تسعين سنة{3}<span class=comment-ref>٣٢٥١</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٣٢٥١</span> ذكر <u>ابنُ عطية</u> (٤/٦١٣) بعض الأقوال في سِنِّ سارة وإبراهيم ﵇ ساعة هذه المقالة، و<span class="comment-type-2">استدرك</span> عليها، فقال: «ورُوِي أنّ سارة كانت وقت هذه المقالة مِن تسع وتسعين سنة. وقيل: من تسعين. قاله ابن إسحاق. وقيل: من ثمانين. وكذلك قيل في إبراهيم ﵇: إنه كان مائة وعشرين سنة. وقيل: مائة سنة. وغير ذلك مما يحتاج إلى سند».</div></p><p><div></p><p><p><span class="item-no">٣٥٩٢٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿قالَتْ﴾</span> سارة: <span class="qpc-hafs">﴿يا ويْلَتى أأَلِدُ وأَنا عَجُوزٌ﴾</span>{4}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَهَـٰذَا بَعۡلِی﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٥٩٢١<span class="dash">-</span></span> عن <span class="name-2">أبي مالك غزوان الغفاري</span> -من طريق السدي- في قوله: <span class="qpc-hafs">﴿بعلي﴾</span>، قال: زَوْجي{5}. (٨/١٠٢)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَهَـٰذَا بَعۡلِی شَیۡخًاۖ﴾</span> - قراءات</h3></p><p><div></p><p><p><span class="item-no">٣٥٩٢٢<span class="dash">-</span></span> عن الأعمش: في قراءة <span class="name-1">عبد الله [بن مسعود]</span>: (وهَذا بَعْلِي شَيْخٌ) بالرفع{6}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَهَـٰذَا بَعۡلِی شَیۡخًاۖ﴾</span> - تفسير الآية</h3></p><p><div></p><p><p><span class="item-no">٣٥٩٢٣<span class="dash">-</span></span> قال <span class="name-2">مجاهد بن جبر</span>، في قوله: <span class="qpc-hafs">﴿وهذا بعلي شيخا﴾</span>: كان سِنُّ إبراهيم مائةَ سنة{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٩٢٤<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿ءألد وأنا عجوز وهذا بعلي شيخًا﴾</span>، قال: وهي يومئذ ابنةُ سبعين، وهو يومئذ ابن تسعين سنة{2}. (٨/١٠٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٩٢٥<span class="dash">-</span></span> عن ضرار بن مُرَّة، عن شيخ مِن أهل المسجد، قال: بُشِّر إبراهيم بعد سبع عشرة ومائة سنة{9}. (٨/١٠٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٩٢٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وهَذا بَعْلِي شَيْخًا﴾</span>، وهو ابن سبعين سنة{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٩٢٧<span class="dash">-</span></span> عن <span class="name-3">محمد بن إسحاق</span> -من طريق سلمة- ذكر لي، عن بعض مَن قرأ الكتاب، <span class="qpc-hafs">﴿وهذا بعلي شيخا﴾</span>: أنّ إبراهيم ابن عشرين ومائة سنة{3}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿إِنَّ هَـٰذَا لَشَیۡءٌ عَجِیبࣱ ۝٧٢﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٥٩٢٨<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿إنَّ هَذا لَشَيْءٌ عَجِيبٌ﴾</span>، يعني: لَأَمْرٌ عجيب أن يكون الولدُ مِن الشيخين الكبيرين{4}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير الثعلبي ٥/١٧٩، وتفسير البغوي ٤/١٨٩.أخرجه ابن أبي حاتم ٦/٢٠٥٦. وعزاه السيوطي إلى أبي الشيخ.أخرجه ابن جرير ١٢/٤٨٤، وابن أبي حاتم ٦/٢٠٥٦.تفسير مقاتل بن سليمان ٢/٢٩١.أخرجه ابن أبي حاتم ٦/٢٠٥٦.أخرجه ابن أبي داود في المصاحف ١/٣١٩.</p><p>وهي قراءة شاذة، تروى عن الأعمش أيضًا. انظر: مختصر ابن خالويه ص٦٥، والمحتسب ١/٣٢٤.تفسير الثعلبي ٥/١٧٩، وتفسير البغوي ٤/١٨٩.أخرجه ابن أبي حاتم ٦/٢٠٥٦. وعزاه السيوطي إلى أبي الشيخ.عزاه السيوطي إلى أبي الشيخ.تفسير مقاتل بن سليمان ٢/٢٩١.أخرجه ابن جرير ١٢/٤٨٤، وابن أبي حاتم ٦/٢٠٥٦.تفسير مقاتل بن سليمان ٢/٢٩١.
  11,73,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿قَالُوۤا۟ أَتَعۡجَبِینَ مِنۡ أَمۡرِ ٱللَّهِۖ رَحۡمَتُ ٱللَّهِ وَبَرَكَـٰتُهُۥ عَلَیۡكُمۡ أَهۡلَ ٱلۡبَیۡتِۚ إِنَّهُۥ حَمِیدࣱ مَّجِیدࣱ ۝٧٣﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٥٩٢٩<span class="dash">-</span></span> عن <span class="name-2">وهب بن مُنَبِّه</span> -من طريق عبد الصمد- قال: لَمّا أتى الملائكةُ إبراهيمَ ﵇ فرآهم راعه هيئتُهم وجمالهم، فسلَّموا عليه، وجلسوا إليه، فقام فأَمَر بعجل سمين، فحُنِذ له، فقَرَّب إليهم الطعام، فلمّا رأى أيديهم لا تصل إليه نكرهم، وأوجس منهم خيفة، وسارة وراء البيت تسمع، قالوا: لا تخف، إنّا نبشرك بغلام حليم مبارك. وبشَّر به امرأتَه سارة، فضحِكت، وعجِبَت، كيف يكون لي ولد وأنا عجوز وهو شيخ كبير؟! فقالوا: لا تعجبي مِن أمر الله؛ فإنّه قادِرٌ على ما يشاء، فقد وهبه الله لكم، فأبشِروا به{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٩٣٠<span class="dash">-</span></span> عن <span class="name-2">زيد بن علي</span>، قال: قالت سارة لَمّا بَشَّرَتْها الملائكةُ ﵈: <span class="qpc-hafs">﴿يا ويلتى ءألد وأنا عجوز وهذا بعلي شيخًا إن هذا لشيء عجيب﴾</span>. فقالت الملائكة ترُدُّ على سارة: <span class="qpc-hafs">﴿أتعجبين من أمر الله رحمت الله وبركاته عليكم أهل البيت إنه حميد مجيد﴾</span>. قال: فهو كقوله: <span class="qpc-hafs">﴿وجعلها كلمة باقية في عقبه﴾</span> [الزخرف:٢٨]، فمحمد ﷺ وآله مِن عَقِب إبراهيم{2}. (٨/١٠٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٩٣١<span class="dash">-</span></span> عن <span class="name-2">ضمرة بن حبيب</span> -من طريق أبي بكر بن مريم-: أنّ سارة لَمّا بشَّرها الرُّسُل بإسحاق قال: بينما هي تمشي وتُحَدِّثُهم آنَسَتْ بالحيضة، فحاضَتْ قبل أن تحمِل بإسحاق، فكان مِن قولها للرسل حين بشَّروها: قد كنت شابَّةً وكان إبراهيمُ شابّا فلم أحبل، فحين كبِرت وكبر أأَلِدُ؟ قالوا: أتعجبين مِن ذلك، يا سارة؟ فإنّ الله قد صنع بكم ما هو أعظم من ذلك؛ إنّ الله قد جعل رحمته وبركاته عليكم أهل البيت، إنّه حميد مجيد{3}. (٨/١٠١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٩٣٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿قالُوا﴾</span> قال جبريل لها: <span class="qpc-hafs">﴿أتَعْجَبِينَ مِن أمْرِ اللَّهِ﴾</span> أن يخلق ولدًا مِن الشيخين، <span class="qpc-hafs">﴿رَحْمَتُ اللَّهِ وبَرَكاتُهُ﴾</span> يعني: نعمة الله وبركاته <span class="qpc-hafs">﴿عَلَيْكُمْ أهْلَ البَيْتِ﴾</span> يعني بالبركة: ما جعل اللهُ مِنهم مِن الذرية، <span class="qpc-hafs">﴿إنَّهُ حَمِيدٌ﴾</span> في خلقه، <span class="qpc-hafs">﴿مَجِيدٌ﴾</span> يعني: كريم{4}<span class=comment-ref>٣٢٥٢</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٣٢٥٢</span> <span class="comment-type-4">ذكر</span> <u>ابنُ عطية</u> (٤/٦١٣) أنّ قوله: <span class="qpc-hafs">﴿مِن أمْرِ اللَّهِ﴾</span> يحتمل احتمالين: <b>الأول</b>: أن يريد واحدَ الأمور، أي: مِن الولادة في هذه السن. <b>الثاني</b>: أن يريد: مصدر أمر، أي: مما أمر الله في هذه النازلة.</div></p><p><h3><span class="qpc-hafs">﴿قَالُوۤا۟ أَتَعۡجَبِینَ مِنۡ أَمۡرِ ٱللَّهِۖ رَحۡمَتُ ٱللَّهِ وَبَرَكَـٰتُهُۥ عَلَیۡكُمۡ أَهۡلَ ٱلۡبَیۡتِۚ إِنَّهُۥ حَمِیدࣱ مَّجِیدࣱ ۝٧٣﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٣٥٩٣٣<span class="dash">-</span></span> عن زينب بنت أبي سلمة: أنّ رسول الله ﷺ كان عند أُمِّ سلمة، فحمل حَسَنًا مِن شِقٍّ، وحُسَيْنًا مِن شِقٍّ، وفاطمة في حِجْرِه، فقال: <span class="qpc-hafs">﴿رَحْمَتُ اللَّهِ وبَرَكاتُهُ عَلَيْكُمْ أهْلَ البَيْتِ إنَّهُ حَمِيدٌ مَجِيدٌ﴾</span>{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٩٣٤<span class="dash">-</span></span> عن عطاء بن أبي رباح، في قوله: <span class="qpc-hafs">﴿رحمت الله وبركاته عليكم أهل البيت﴾</span>، قال: كنت عند <span class="name-1">ابن عباس</span>، إذ جاءه رجلٌ، فسلَّم عليه، فقلت: وعليكم السلام ورحمة الله وبركاته ومغفرته. فقال ابن عباس: انتهِ إلى ما انتهت إليه الملائكة. ثم تلا: <span class="qpc-hafs">﴿رحمت الله وبركاته عليكم أهل البيت﴾</span>{6}. (٨/١٠٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٩٣٥<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق محمد بن عطاء-: أنّ سائلًا قام على الباب وهو عند ميمونة، فقال: السلام عليكم أهل البيت ورحمة الله وبركاته ومغفرته. فقال ابنُ عباس: انتهوا بالتحية إلى ما قال الله: <span class="qpc-hafs">﴿رحمت الله وبركاته﴾</span>{7}. (٨/١٠٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٩٣٦<span class="dash">-</span></span> عن عطاء، قال: كنتُ عند <span class="name-1">ابن عباس</span>، فجاء سائلٌ، فقال: السلام عليكم ورحمة الله وبركاته ومغفرته ورضوانه. فقال ابن عباس: ما هذا السلام؟ -وغَضِبَ حتى احْمَرَّت وجنتاه- إنّ الله حدَّ السلام حدًّا، ثم انتهى ونهى عمّا وراء ذلك. ثم قرأ: <span class="qpc-hafs">﴿رحمت الله وبركاته عليكم أهل البيت إنه حميد مجيد﴾</span>{8}. (٨/١٠٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٩٣٧<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عمر</span> -من طريق عبد الله بن بابَيْهِ- أنّ رجلًا قال له: سلامٌ عليك ورحمة الله وبركاته ومغفرته. فانتَهَرَهُ ابنُ عمر، وقال: حسبُك إذا انتهيت إلى «وبركاته»؛ إلى ما قال الله{9}. (٨/١٠٣)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ١٢/٤٧٥.عزاه السيوطي إلى أبي الشيخ.أخرجه ابن أبي حاتم ٦/٢٠٥٥-٢٠٥٦.تفسير مقاتل بن سليمان ٢/٢٩١.أخرجه الطبراني في الأوسط ٨/١١٧ (٨١٤١).أخرجه ابن أبي حاتم ٦/٢٠٥٧، والحاكم ٢/٣٤٤، والبيهقي في شعب الإيمان (٨٨٧٧). وعزاه السيوطي إلى ابن المنذر.أخرجه البيهقي في شعب الإيمان (٨٨٧٨، ٨٨٧٩) بنحوه.أخرجه البيهقي في شعب الإيمان (٨٨٧٨). وعزاه السيوطي إلى أبي الشيخ.أخرجه البيهقي في شعب الإيمان (٨٨٨٠).
  11,74,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿فَلَمَّا ذَهَبَ عَنۡ إِبۡرَ ٰ⁠هِیمَ ٱلرَّوۡعُ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٥٩٣٨<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿فلما ذهب عن إبراهيم الروع﴾</span>، قال: الفَرَق{1}. (٨/١٠٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٩٣٩<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿فلما ذهب عن إبراهيم الروع﴾</span>، قال: الخوف{2}. (٨/١٠٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٩٤٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فَلَمّا ذَهَبَ عَنْ إبْراهِيمَ الرَّوْعُ﴾</span>، يعني: الخوف{3}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَجَاۤءَتۡهُ ٱلۡبُشۡرَىٰ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٥٩٤١<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span> -من طريق داود- يعني قوله: <span class="qpc-hafs">﴿البشرى﴾</span>: بَشَّر بنُبُوَّته{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٩٤٢<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد-: <span class="qpc-hafs">﴿وجآءته البشرى﴾</span> بإسحاق{5}. (٨/١٠٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٩٤٣<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق مَعْمَر- في قوله: <span class="qpc-hafs">﴿وجاءته البشرى﴾</span>، قال: حين أخبروه أنّهم أُرْسِلُوا إلى قوم لوط، وأنّهم ليسوا إيّاه يريدون{6}. (٨/١٠٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٩٤٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وجاءَتْهُ البُشْرى﴾</span> في الوَلَد{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٩٤٥<span class="dash">-</span></span> عن <span class="name-3">محمد بن إسحاق</span> -من طريق سلمة-: <span class="qpc-hafs">﴿فلما ذهب عن إبراهيم الروع وجاءته البشرى﴾</span> بإسحاق ويعقوب ولدًا مِن صُلْب إسحاق، وأمِن مِمّا كان يخاف؛ قال: <span class="qpc-hafs">﴿الحمد لله الذي وهب لي على الكبر إسماعيل وإسحاق إن ربي لسميع الدعاء﴾</span> [إبراهيم:٣٩]. وقد قيل: معنى ذلك: وجاءته البشرى أنّهم ليسوا إيّاه يُرِيدون{8}<span class=comment-ref>٣٢٥٣</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٣٢٥٣</span> ذكر <u>ابنُ عطية</u> (٤/٦١٥) في <span class="qpc-hafs">﴿البشرى﴾</span> احتمالين: <b>الأول:</b> البشرى بالولد. <b>الثاني:</b> البُشرى بأنّ المراد غيره. ثم <span class="comment-type-3">رجَّح</span> الأول بقوله: «والأوَّل أبْيَن». ولم يذكر مستندًا.</div></p><p><h3><span class="qpc-hafs">﴿یُجَـٰدِلُنَا فِی قَوۡمِ لُوطٍ ۝٧٤﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٥٩٤٦<span class="dash">-</span></span> عن <span class="name-1">حذيفة بن اليمان</span> -من طريق قتادة- قال: لَمّا أُرْسِلَت الرُّسُل إلى قوم لوط ليُهِلكوهم قيل لهم: لا تُهْلِكوا قومَ لوط حتى يشهد عليهم لوطٌ ثلاث مرات. وكان طريقُهم على إبراهيم خليل الرحمن، قال: <span class="qpc-hafs">﴿فلما ذهب عن إبراهيم الروع وجاءته البشرى يجادلنا في قوم لوط﴾</span>. وكانت مجادلتُه إيّاهم قال: أرأيتُم إن كان فيها خمسون مِن المؤمنين أتُهلكونهم؟ قالوا: لا. قال: فأربعون؟ قالوا: لا. حتى انتهى إلى عشرة أو خمسة{9}. (٨/١١٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٩٤٧<span class="dash">-</span></span> عن <span class="name-1">عبد الرحمن بن سمرة</span> -من طريق أبي نضرة-: أنّه رأى مِن حَبَشِيَّةٍ شيئًا كَرِهَه، فأنكره، فقال لهم: أتدرون فيكم يكرهون هذا؟ قالوا: نعم. قال: فلله الحمد، إن إبراهيم ﵇ لَمّا جاءت الملائكة فجادلهم في قوم لوط كانوا أربع قريات، في كل قرية مائة ألف مقاتل، فقال لهم: أرأيتم إن كان في هؤلاء مائة يكرهون هذا، أمُهْلِكوهم أنتم؟ قالوا: لا. قال: فتسعون. قال: لا. حتى صار إلى عشرة. قال: أرأيتُم إن كان فيهم عشرةٌ يكرهون هذا أمُهْلِكوهم أنتم؟ قالوا: <span class="qpc-hafs">﴿نحن أعلم بمن فيها لننجينه وأهله إلا امرأته كانت من الغابرين﴾</span> [العنكبوت:٣٢]{10}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٩٤٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق سعيد بن جبير- قال: لَمّا جاءت الملائكةُ إلى إبراهيم قالوا لإبراهيم: إن كان فيها خمسةٌ يُصَلُّون رُفِع عنهم العذاب{11}. (٨/١٠٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٩٤٩<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق الضحاك- قال: لَمّا بُشِّر إبراهيم بقول الله <span class="qpc-hafs">﴿فلما ذهب عن إبراهيم الروع وجاءته البشرى﴾</span> بإسحاق، <span class="qpc-hafs">﴿يجادلنا في قوم لوط﴾</span>. وإنّما كان جداله أنّه قال: يا جبريل، أين تريدون؟ وإلى مَن بُعِثتم؟ قال: إلى قوم لوط، وقد أُمِرْنا بعذابهم. فقال إبراهيم: إنّ فيها لوطًا. قالوا: <span class="qpc-hafs">﴿نحن أعلم بمن فيها لننجينه وأهله إلا امرأته﴾</span> [العنكبوت:٣٢]. وكانت -زعموا- تسمّى: والِقَة، فقال إبراهيم: إن كان فيهم مائة مؤمن تعذبونهم؟ قال جبريل: لا. قال: فإن كان فيهم تسعون مؤمنون تعذبونهم؟ قال جبريل: لا. قال: فإن كان فيهم ثمانون مؤمنون تعذبونهم؟ قال جبريل: لا. حتى انتهى في العدد إلى واحد مؤمن، قال جبريل: لا. فلمّا لم يذكروا لإبراهيم أنّ فيها مؤمنًا واحدًا، قال: إنّ فيها لوطًا. قالوا: <span class="qpc-hafs">﴿نحن أعلم بمن فيها لننجينه وأهله إلا امرأته﴾</span> [العنكبوت:٣٢]{12}. (٨/٩٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٩٥٠<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span> -من طريق جعفر- في قوله: <span class="qpc-hafs">﴿يجادلنا في قوم لوط﴾</span>. قال: لَمّا جاء جبريل إلى إبراهيم ﵇، وأخبره أنّه مُهلِكُ قومِ لوط؛ قال: أتُهلِك قرية فيها أربعمائة مؤمن؟ قال: لا. قال: فثلاثمائة مؤمن؟ قال: لا. قال: فمِائتا مؤمن؟ قال: لا. قال: فمائة؟ قال: لا. قال: فخمسون مؤمنًا؟ قال: لا. قال: فأربعون مؤمنًا؟ قال: لا. قال: فأربعة عشر مؤمنًا؟ قال: لا. وظنَّ إبراهيمُ أنهم أربعة عشر بامرأة لوط، وكان فيها ثلاثة عشر مؤمنًا، وقد عرف ذلك جبريلُ{13}. (٨/١٠٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٩٥١<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قوله: <span class="qpc-hafs">﴿يجادلنا في قوم لوط﴾</span>، قال: يُخاصِمنا{14}. (٨/١٠٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٩٥٢<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- في قوله: <span class="qpc-hafs">﴿يُجادلنا في قوم لوط﴾</span>، قال: إنّه قال لهم يومئذ: أرأيتم إن كان فيهم خمسون مِن المسلمين؟ قال: إن كان فيها خمسون لم نُعَذِّبهم. قال: أربعون؟ قال: وأربعون. قال: ثلاثون؟ قال: ثلاثون. حتى بلغوا عشرة، قال: فإن كان فيهم عشرة؟ قال: ما قوم لا يكون فيهم عشرة فيهم خير. قال قتادة: إنّه كان في قرية لوط أربعة آلاف ألف إنسان، أو ما شاء الله من ذلك{15}. (٨/١٠٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٩٥٣<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط-: <span class="qpc-hafs">﴿فلما ذهب عن إبراهيم الروع، وجاءته البشرى﴾</span>؛ <span class="qpc-hafs">﴿قال فما خطبكم أيها المرسلون﴾</span>؟ [الحجر:٥٧] قالوا: إنّا أُرْسِلنا إلى قوم لوط. فجادَلَهم في قوم لوط، قال: أرأيتُم إن كان فيها مائة من المسلمين أتُهْلِكُونهم؟ قالوا: لا. فلم يزل يَحُطُّ حتى بلغ عشرة مِن المسلمين، فقالوا: لا نُعَذِّبهم إن كان فيهم عشرة من المسلمين. ثم قالوا: يا إبراهيم، أعرض عن هذا، إنّه ليس فيها إلا أهل بيت مِن المؤمنين هو لوط وأهل بيته، وهو قول الله ﷿: <span class="qpc-hafs">﴿يجادلنا في قوم لوط﴾</span>. فقالت الملائكة: <span class="qpc-hafs">﴿يا إبراهيم أعرض عن هذا إنه قد جاء أمر ربك وإنهم آتيهم عذاب غير مردود﴾</span>{16}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٩٥٤<span class="dash">-</span></span> عن أبي المثنى، ومسلم أبي حسبة الأشجعي -من طريق صفوان- قالا: <span class="qpc-hafs">﴿فلما ذهب عن إبراهيم الروع﴾</span> إلى آخر الآية. قال إبراهيم: أتُعذب عالما من عالمك كثيرا فيهم مائة رجل يعبدك؟ قال: لا وعزتي، ولا خمسين. قال: فأربعين؟ فثلاثين؟ حتى انتهى إلى خمسة. قال: لا، وعِزَّتي، لا أُعَذِّبهم، ولو كان فيهم خمسة يعبدونني. قال الله ﷿: <span class="qpc-hafs">﴿فما وجدنا فيها غير بيت من المسلمين﴾</span> [الذاريات:٣٦] لوطًا وابنتيه. قال: فحلَّ بهم العذاب، قال الله ﷿: <span class="qpc-hafs">﴿وتركنا فيها آية للذين يخافون العذاب الأليم﴾</span> [الذاريات:٣٧]. وقال: <span class="qpc-hafs">﴿فلما ذهب عن إبراهيم الروع وجاءته البشرى يجادلنا﴾</span>{17}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٩٥٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿يُجادِلُنا﴾</span> يعني: يُخاصمنا إبراهيم <span class="qpc-hafs">﴿فِي قَوْمِ لُوطٍ﴾</span> كقوله في الرعد [١٣]: <span class="qpc-hafs">﴿يُجادِلُونَ فِي اللَّهِ﴾</span>، ومثل قوله: <span class="qpc-hafs">﴿قالُوا يا نُوحُ قَدْ جادَلْتَنا فَأَكْثَرْتَ جِدالَنا﴾</span> [هود:٣٢]. وخصومة إبراهيم ﵇ أنّه قال: يا ربِّ، أتهلكهم إن كان في قوم لوط خمسون رجلًا مؤمنين؟ قال جبريل ﵇: لا. فما زال إبراهيم ﵇ ينقص خمسة خمسة حتى انتهى إلى خمسة أبيات{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٩٥٦<span class="dash">-</span></span> قال <span class="name-3">عبد الملك ابن جُرَيْج</span> -من طريق حجّاج- قال إبراهيم: أتهلكونهم إن وجدتم فيها مائة مؤمن؟ ثم تسعين، حتى هبط إلى خمسة. قال: وكان في قرية لوط أربعة آلاف ألف{19}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٩٥٧<span class="dash">-</span></span> عن <span class="name-3">محمد بن إسحاق</span> -من طريق سلمة- قال: <span class="qpc-hafs">﴿فلما ذهب عن إبراهيم الروع وجاءته البشرى﴾</span>، يعني: إبراهيم، جادل عن قوم لوط لِيَرُدَّ عنهم العذاب. قال: فيزعم أهل التوراة: أنّ مجادلة إبراهيم إيّاهم -حين جادلهم في قوم لوط لِيَرُدَّ عنهم العذاب- إنّما قال للرسل فيما يكلمهم به: أرأيتم إن كان فيهم مائة مؤمن أتهلكونهم؟ قالوا: لا. قال: أفرأيتم إن كانوا تسعين؟ قالوا: لا. قال: أفرأيتم إن كانوا ثمانين؟ قالوا: لا. قال: أفرأيتم إن كانوا سبعين؟ قالوا: لا. قال: أفرأيتم إن كانوا ستين؟ قالوا لا. قال: أفرأيتم إن كانوا خمسين؟ قالوا لا. قال: أفرأيتم إن كان رجلًا واحدًا مسلمًا؟ قالوا: لا. قال: فلمّا لم يذكروا لإبراهيم أنّ فيها مؤمنًا واحدًا قال: <span class="qpc-hafs">﴿إن فيها لوطا﴾</span>. يدفع به عنهم العذاب، <span class="qpc-hafs">﴿قالوا نحن أعلم بمن فيها لننجينه وأهله إلا امرأته كانت من الغابرين﴾</span> [العنكبوت:٣٢]. قالوا: <span class="qpc-hafs">﴿يا إبراهيم أعرض عن هذا إنه قد جاء أمر ربك، وإنهم آتيهم عذاب غير مردود﴾</span>{16}<span class=comment-ref>٣٢٥٤</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٣٢٥٤</span> ذكر <u>ابنُ عطية</u> (٤/٦١٦) في صورة جدال إبراهيم ﵇ أنها «كانت أن قال إبراهيم ﵇: إن كان فيهم مائة مؤمن أتعذبونهم؟ قالوا لا، قال: أفَتِسْعون؟ قالوا: لا، قال: أفثمانون؟ فلم يزل كذلك حتى بلغ خمسة ووقف عند ذلك، وقد عد في بيت لوط ﵇ امرأته، فوجدهم ستة بها، فطمع في نجاتهم، ولم يشعر أنها من الكفرة، وكان ذلك من إبراهيم ﵇ حرصًا على إيمان تلك الأُمَّة ونجاتها». ثم <span class="comment-type-4">علَّق</span> بقوله: «وقد كثر اختلاف رواة المفسرين لهذه الأعداد في قول إبراهيم ﵇، والمعنى كله نحو مما ذكرته». ونقل عن فرقة في قوله تعالى: <span class="qpc-hafs">﴿يُجادِلُنا فِي قَوْمِ لُوطٍ﴾</span> أنّ المعنى: «يجادلنا في مؤمني قوم لوط». ثم <span class="comment-type-2">انتقده</span> قائلًا: «وهذا ضعيف».</div></p><p><div></p><p><p><span class="item-no">٣٥٩٥٨<span class="dash">-</span></span> قال <span class="name-3">معمر بن راشد</span> -من طريق محمد بن ثور-: بلغنا: أنّه كان في قرية لوطٍ أربعةُ آلاف ألف إنسان، أو ما شاء الله من ذلك{21}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ١٢/٤٨٧، وابن أبي حاتم ٦/٢٠٥٨. وعزاه السيوطي إلى ابن المنذر، وأبي الشيخ.أخرجه ابن جرير ١٢/٤٨٦، وابن أبي حاتم ٦/٢٠٥٧. وعزاه السيوطي إلى ابن المنذر.تفسير مقاتل بن سليمان ٢/٢٩١.أخرجه ابن أبي حاتم ٦/٢٠٥٧.أخرجه ابن جرير ١٢/٤٨٨، وابن أبي حاتم ٦/٢٠٥٧. وعزاه السيوطي إلى ابن المنذر.أخرجه عبد الرزاق ١/٣٠٨-٣٠٩، وابن جرير ١٢/٤٨٦-٤٨٧. وعزاه السيوطي إلى أبي الشيخ.تفسير مقاتل بن سليمان ٢/٢٩١.أخرجه ابن جرير ١٢/٤٨٦.أخرجه عبد الرزاق ١/٣٠٧، وابن جرير ١٢/٤٩٥، ٥١٨، وفي التاريخ ١/٢٨٩، ٢٩٩، ٣٠٣، وابن أبي حاتم ٦/٢٠٦٠ من طريق جندب بن عبد الله. وعزاه السيوطي إلى ابن المنذر.أخرجه ابن أبي حاتم ٦/٢٠٥٨.أخرجه ابن جرير ١٢/٤٨٩-٤٩٠، وفي تاريخه ١/٢٩٨. وعزاه السيوطي إلى ابن المنذر.أخرجه ابن عساكر ٥٠/٣١٠، ٣١٥. وعزاه السيوطي إلى إسحاق بن بشر.أخرجه ابن جرير ١٢/٤٨٩، وابن أبي حاتم ٦/٢٠٥٨.تفسير مجاهد ص٣٨٩، وأخرجه ابن جرير ١٢/٤٨٧-٤٨٨، وابن أبي حاتم ٦/٢٠٥٨. وعزاه السيوطي إلى ابن المنذر، وأبي الشيخ.أخرجه عبد الرزاق ١/٣٠٨-٣٠٩، وابن جرير ١٢/٤٩٠. وذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٢/٣٠٠-. وعزاه السيوطي إلى أبي الشيخ.أخرجه ابن جرير ١٢/٤٩١.أخرجه ابن جرير ١٢/٤٩٢. قال الشيخ شاكر في تحقيقه لتفسير ابن جرير ١٥/٤٠٥: "وأبو المثنى كأنه يعني: مسلم بن المثني الكوفي المؤذن، روى عن ابن عمر، مترجم في التهذيب، والكبير ٤/١/٢٥٦، وابن أبي حاتم ٤/١/١٩٥. وأما أبو الحبيل الأشجعي فلست أجد من يُسَمّى هكذا، وظني أنه قد وقع في هذا الإسناد خطأ، فصوابه عندي: قال: حدثنا أبو المثنى مسلم، والحسيل الأشجعي. والحسيل الأشجعي -فيما أرجح-: الحسيل بن عبد الرحمن الأشجعي، ويقال أيضًا: حسين، روى عن سعد بن أبي وقاص، مترجم في التهذيب، وابن أبي حاتم ١/٢/٥٨. هذا، وفي النفس شيء من حقيقة هذا الإسناد.تفسير مقاتل بن سليمان ٢/٢٩١.أخرجه ابن جرير ١٢/٤٩٢.أخرجه ابن جرير ١٢/٤٩١.أخرجه ابن جرير ١٢/٤٩٠.
  11,75,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿إِنَّ إِبۡرَ ٰ⁠هِیمَ لَحَلِیمٌ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٥٩٥٩<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق مجاهد- قال: الحِلْمُ يجمع لصاحبه شرفَ الدنيا والآخرة؛ ألم تسمع اللهَ وصَفَ نبيَّه ﷺ بالحِلْم، فقال: <span class="qpc-hafs">﴿إن إبراهيم لحليم أواه منيب﴾</span>{1}. (٨/١٠٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٩٦٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق أبي الجَوْزاء- في قوله: <span class="qpc-hafs">﴿إن إبراهيم لحليم أواه منيب﴾</span>، قال: كان مِن حِلْمِه أنّه كان إذا آذاه الرجل من قومه قال له: هداك الله{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٩٦١<span class="dash">-</span></span> عن <span class="name-2">عمرو بن ميمون</span>، قال: الحليم: المُسَبِّح{3}. (٨/١٠٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٩٦٢<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق عبد الوهاب، عن رجل سَمّاه- في قوله: <span class="qpc-hafs">﴿إن إبراهيم لحليم﴾</span>، قال: الحليم: الرَّحيم{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٩٦٣<span class="dash">-</span></span> عن يونس، قال: سمعتُ <span class="name-2">الحسن</span> يقول: ما سمعتُ اللهَ نَحَل عبادَه شيئًا أقلَّ مِن الحِلم؛ فإنّه قال: <span class="qpc-hafs">﴿إنَّ إبْراهِيمَ لَحَلِيمٌ﴾</span>، وقال: <span class="qpc-hafs">﴿فَبَشَّرْناهُ بِغُلامٍ حَلِيمٍ﴾</span> [الصافات:١٠١]{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٩٦٤<span class="dash">-</span></span> عن <span class="name-2">ضمرة بن حبيب</span>، قال: الحِلمُ أرفعُ مِن العَقْل؛ لأنّ الله ﷿ تَسَمّى به{3}. (٨/١٠٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٩٦٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: قال تعالى: <span class="qpc-hafs">﴿إنَّ إبْراهِيمَ لَحَلِيمٌ﴾</span>، يعني: لعليم{7}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿أَوَّ ٰ⁠هࣱ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٥٩٦٦<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن مسعود</span> -من طريق زِر بن حُبَيْش- في قول الله: <span class="qpc-hafs">﴿إنَّ إبْراهِيمَ لَحَلِيمٌ أوّاهٌ مُنِيبٌ﴾</span>، قال: الأوّاه: الدّعّاءُ{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٩٦٧<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن مسعود</span> -من طريق يزيد بن أبي حبيب-: إنّ الأوّاه عند الله: الرحيم. قال <span class="name-2">يزيد</span>: يُقال: إنّ الأوّاه الذي إذا ذكر خطيئتَه تَوَجَّع منها، ثُمَّ استغفر ربه{9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٩٦٨<span class="dash">-</span></span> عن <span class="name-2">كعب الأحبار</span> -من طريق عبد الله بن رباح- في قوله: <span class="qpc-hafs">﴿إن إبراهيم لحليم أواه﴾</span>، قال: كان إذا ذكر النار قال: أوَّه مِن عذاب الله، أوَّه{10}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٩٦٩<span class="dash">-</span></span> عن <span class="name-2">عمرو بن ميمون</span>، قال: الأواه: الرحيم. والحليم: المُسَبِّح{3}. (٨/١٠٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٩٧٠<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق أبي يحيى- <span class="qpc-hafs">﴿أواه منيب﴾</span>، قال: القانِت الرَّجّاع{12}<span class=comment-ref>٣٢٥٥</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٣٢٥٥</span> لم يذكر <u>ابنُ جرير</u> (١٢/٤٩٣) في معنى: <span class="qpc-hafs">﴿أواَّهٌ مُنِيبٌ﴾</span> سوى قول مجاهد بن جبر.</div></p><p><div></p><p><p><span class="item-no">٣٥٩٧١<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق أبي يحيى- <span class="qpc-hafs">﴿أواه﴾</span>، قال: فَقِيه مُوقِن{10}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٩٧٢<span class="dash">-</span></span> عن <span class="name-2">عامر الشعبي</span> -من طريق زكريا- قال: الأوّاه: المُسَبِّح{10}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٩٧٣<span class="dash">-</span></span> عن <span class="name-2">عمرو بن دينار</span>: أنّ عبيد بن عمير كان إذا ذكر النار قال: أوَّه أوَّه. وذلك قوله: <span class="qpc-hafs">﴿أواه منيب﴾</span>{15}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٩٧٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿أوّاهٌ﴾</span>، يعني: مُوقِن{7}<span class=comment-ref>٣٢٥٦</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٣٢٥٦</span> ذكر <u>ابنُ عطية</u> (٤/٦١٦) أنّ الأوّاه معناه: الخائِف الذي يُكْثِرُ التَّأَوُّهَ مِن خوف الله تعالى، ثم <span class="comment-type-4">علَّق</span> بقوله: «وللمفسرين في الأوّاه عباراتٌ، كلها ترجع إلى ما ذكرته، وتلزمه».</div></p><p><h3><span class="qpc-hafs">﴿مُّنِیبࣱ ۝٧٥﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٥٩٧٥<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق الضَّحّاك- قال: المنيب: المُقبِل إلى طاعة الله{10}. (٨/١٠٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٩٧٦<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٩٧٧<span class="dash">-</span></span> و<span class="name-2">عكرمة مولى ابن عباس</span> -من طريق جابر- قالا: المُنيب: المُخْبِت{10}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٩٧٨<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق عمرو بن عبيد- في قوله: <span class="qpc-hafs">﴿إن إبراهيم لحليم أواه منيب﴾</span>، قال: كان إذا قال قال لله، وإذا عمِل عَمِل لله، وإذا نوى نوى لله{19}. (٨/١٠٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٩٧٩<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span>، قال: المنيب: المُخْلِص{20}. (٨/١٠٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٩٨٠<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- قال: اللهُ يثني عليه: <span class="qpc-hafs">﴿إن إبراهيم لحليم أواه منيب﴾</span>، والمنيب: التائب{10}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٩٨١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿مُنِيبٌ﴾</span>: مخلص{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٩٨٢<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span>، قال: المنيبُ إلى الله: المُطِيع لله الذي أناب إلى طاعة الله وأمره، ورجع عن الأمور التي كان عليها قبل ذلك{20}. (٨/١٠٦)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن أبي الدنيا في كتاب الحلم -موسوعة الإمام ابن أبي الدنيا ٢/٥٣ (٥٨)-. وعزاه السيوطي إلى أبي الشيخ.أخرجه ابن أبي حاتم ٦/٢٠٥٨.عزاه السيوطي إلى أبي الشيخ.أخرجه ابن أبي حاتم ٦/٢٠٥٨.أخرجه الحكيم الترمذي في نوادر الأصول (ت: إسماعيل إبراهيم عوض) ٢/٧٠٧.عزاه السيوطي إلى أبي الشيخ.تفسير مقاتل بن سليمان ٢/٢٩١.أخرجه عبد الله بن وهب في الجامع - تفسير القرآن ٢/٩٩-١٠٠ (١٩٤).أخرجه عبد الله بن وهب في الجامع - تفسير القرآن ٢/١٣٩-١٤٠ (٢٨٢).أخرجه ابن أبي حاتم ٦/٢٠٥٩.عزاه السيوطي إلى أبي الشيخ.أخرجه ابن جرير ١٢/٤٩٣.أخرجه ابن أبي حاتم ٦/٢٠٥٩.أخرجه ابن أبي حاتم ٦/٢٠٥٩.أخرجه عبد الرزاق ١/٣٠٩.تفسير مقاتل بن سليمان ٢/٢٩١.أخرجه ابن أبي حاتم ٦/٢٠٥٩.أخرجه ابن أبي حاتم ٦/٢٠٥٩.أخرجه البيهقي في شعب الإيمان (٦٨٩١).عزاه السيوطي إلى ابن أبي حاتم.أخرجه ابن أبي حاتم ٦/٢٠٥٩.تفسير مقاتل بن سليمان ٢/٢٩١.عزاه السيوطي إلى ابن أبي حاتم.
  11,76,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿یَـٰۤإِبۡرَ ٰ⁠هِیمُ أَعۡرِضۡ عَنۡ هَـٰذَاۤۖ إِنَّهُۥ قَدۡ جَاۤءَ أَمۡرُ رَبِّكَۖ وَإِنَّهُمۡ ءَاتِیهِمۡ عَذَابٌ غَیۡرُ مَرۡدُودࣲ ۝٧٦﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٥٩٨٣<span class="dash">-</span></span> عن <span class="name-2">كعب الأحبار</span> -من طريق عبد الله بن رباح- قال: فكلَّمهم إبراهيمُ في أمر قوم لوط: إن كان فيهم ...، قالوا: <span class="qpc-hafs">﴿يا إبراهيم أعرض عن هذا إنه قد جاء أمر ربك﴾</span>{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٩٨٤<span class="dash">-</span></span> قال <span class="name-3">محمد بن السائب الكلبي</span>: سأل إبراهيم ربَّه ألّا يُهْلِك لوطًا وأهله، وأن يعفو عن قوم لوط، فقيل: <span class="qpc-hafs">﴿يا إبراهيم أعرض عن هذا إنه قد جاء أمر ربك وإنهم آتيهم عذاب غير مردود﴾</span>{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٩٨٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: وقال جبريلُ لإبراهيم: <span class="qpc-hafs">﴿يا إبْراهِيمُ أعْرِضْ عَنْ هَذا﴾</span> الجدالَ. حين قال: أتهلُكهم إن كان فيهم كذا وكذا. ثم قال جبريل ﵇: <span class="qpc-hafs">﴿إنَّهُ قَدْ جاءَ أمْرُ رَبِّكَ﴾</span> يعني: قول ربك في نزول العذاب بهم، <span class="qpc-hafs">﴿وإنَّهُمْ آتِيهِمْ عَذابٌ غَيْرُ مَرْدُودٍ﴾</span> يعني: غير مدفوع عنهم، يعني: الخَسف، والحَصْب بالحجارة{3}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن أبي حاتم ٦/٢٠٥٩.ذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٢/٣٠٠-.تفسير مقاتل بن سليمان ٢/٢٩٢.
  11,77,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَلَمَّا جَاۤءَتۡ رُسُلُنَا لُوطࣰا﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٥٩٨٦<span class="dash">-</span></span> عن <span class="name-2">وهب بن مُنَبِّه</span> -من طريق عبد الصمد- يقول: كان أهل سدوم الذين فيهم لوط قومًا قد اسْتَغْنَوْا عن النِّساء بالرجال، فلمّا رأى اللهُ ذلك بعث الملائكةَ لِيُعَذِّبوهم، فأتوا إبراهيم، وكان مِن أمره وأمرهم ما ذكر اللهُ في كتابه، فلمّا بشَّروا سارة بالولد قاموا، وقام معهم إبراهيم يمشي، قال: أخبِروني لِمَ بُعِثْتُم؟ وما خطبكم؟ قالوا: إنّا أُرْسِلنا إلى أهل سدوم لِنُدَمِّرها، وإنّهم قوم سوء قد اسْتَغْنَوا بالرجال عن النساء. قال إبراهيم: أرأيتم إن كان فيهم خمسون رجلًا صالحًا؟ قالوا: إذن لا نُعَذِّبَهم. فجعل ينقص حتى قال: أهل البيت؟ قالوا: فإن كان فيها بيت صالح؟ قال: فلوط وأهل بيته؟ قالوا: إنّ امرأتَه هواها معهم. فلمّا يئِس إبراهيمُ انصرف، ومَضَوْا إلى أهل سدوم، فدخلوا على لوط، فلمّا رأتهم امرأته أعجبها حسنُهم وجمالهم، فأرسلت إلى أهل القرية: إنّه قد نزل بنا قوم لم يُرَ قومٌ قطُّ أحسن منهم ولا أجمل. فتسامعوا بذلك، فغشوا دار لوط مِن كل ناحية، وتَسَوَّروا عليهم الجدران، فلقيهم لوط، فقال: يا قومِ، لا تفضحوني في ضيفي، وأنا أُزَوِّجكم بناتي؛ فهُنَّ أطهر لكم. فقالوا: لو كُنّا نريد بناتك لقد عرفنا مكانهن. فقال: <span class="qpc-hafs">﴿لو أن لي بكم قوة أو آوي إلى ركن شديد﴾</span>. فَوَجَدَ{1} عليه الرسل، قالوا: إنّ ركنك لشديد، <span class="qpc-hafs">﴿وإنهم آتيهم عذاب غير مردود﴾</span>{2}. (٨/٩٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٩٨٧<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد بن بشير- قال: أتَتِ الملائكةُ لوطًا وهو في مزرعةٍ له، وقال اللهُ للملائكة: إن شَهِد لوطٌ عليهم أربع شهادات فقد أذِنتُ لكم في هلكتهم. فقالوا: يا لوط، إنّا نُرِيد أن نُضيفَك الليلة. فقال: وما بلغكم مِن أمرهم؟ قالوا: وما أمرُهم؟ قال: أشهد باللهِ إنّها لَشَرُّ قريةٍ في الأرض عملًا. يقول ذلك أربع مرات، فشهد عليهم لوط أربع شهادات، فدخلوا معه منزله{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٩٨٨<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- قال: خَرَجَتِ الملائكةُ مِن عند إبراهيم نحو قريةِ لوط، فأتوها نصف النهار، فلمّا بلغوا نهر سَدُوم لقوا ابنةَ لوط تَسْتَقِي مِن الماء لأهلها، وكانت له ابنتان؛ اسم الكبرى: ريثا، والصغرى: زُغرتا، فقالوا لها: يا جارية، هل مِن منزل؟ قالت: نعم، فمكانكم لا تدخلوا حتى آتيكم. فَرِقَتْ عليهم مِن قومها، فأتت أباها، فقالت: يا أبتاه، أرادك فتيان على باب المدينة، ما رأيت وجهَ قوم أحسن منهم، لا يأخذهم قومك فيفضحوهم. وقد كان قومه نهوه أن يضيف رجلًا، فقالوا: خلِّ عنا فَلْنُضِفِ الرجال. فجاء بهم، فلم يعلم أحدٌ إلا أهلُ بيت لوط، فخرجت امرأته، فأخبرت قومها، قالت: إنّ في بيت لوط رجالًا ما رأيتُ مثل وجوههم قطُّ. فجاءه قومُه يُهْرَعون إليه{4}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿سِیۤءَ بِهِمۡ وَضَاقَ بِهِمۡ ذَرۡعࣰا﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٥٩٨٩<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- في قوله: <span class="qpc-hafs">﴿ولما جاءت رسلنا لوطًا سيء بهم وضاق بهم ذرعًا﴾</span>، قال: ساء ظنًّا بقومه، وضاق ذرعًا بأضيافه{5}<span class=comment-ref>٣٢٥٧</span>. (٨/١٠٦)</p></p><p></div></p><p><div><span class=comment-ref>٣٢٥٧</span> لم يذكر <u>ابنُ جرير</u> (١٢/٤٩٥) في معنى: <span class="qpc-hafs">﴿سِيءَ بِهِمْ وضاقَ بِهِمْ ذَرْعًا﴾</span> سوى قول ابن عباس.</div></p><p><div></p><p><p><span class="item-no">٣٥٩٩٠<span class="dash">-</span></span> عن <span class="name-2">كعب الأحبار</span> -من طريق عبد الله بن رباح- <span class="qpc-hafs">﴿سيء بهم وضاق بهم ذرعا﴾</span>: ساء مكانهم لِما رأى منهم مِن الحال{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٩٩١<span class="dash">-</span></span> عن <span class="name-2">الضحاك بن مزاحم</span>، قال: ساءه مكانهم لِما رأى بهم من الجَمال{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٩٩٢<span class="dash">-</span></span> قال <span class="name-2">الحسن البصري</span>: <span class="qpc-hafs">﴿ولما جاءت رسلنا لوطا سيء بهم﴾</span>: ساءه دخولهم؛ لِما تخوف عليهم مِن قومه{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٩٩٣<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق مَعْمَر- في الآية، قال: ساء ظنًّا بقومه، يَتَخَوَّفُهم على أضيافه، وضاق ذرعًا بضيفه مخافةً عليهم{9}. (٨/١٠٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٩٩٤<span class="dash">-</span></span> قال <span class="name-3">محمد بن السائب الكلبي</span>: <span class="qpc-hafs">﴿وضاق بهم ذرعا﴾</span>، لم يَدْرِ أين يُنزِلُهم. قال: وكان قوم لوط لا يُؤْوُونَ ضيفًا بليل، وكانوا يعترضون مَن مَرَّ بالطريق نهارًا للفاحشة، فلمّا جاءت الملائكة لوطًا حين أمسوا كرِهَهم، ولم يستطع دفعهم، فقال: <span class="qpc-hafs">﴿هذا يوم عصيب﴾</span>{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٩٩٥<span class="dash">-</span></span> عن <span class="name-3">محمد بن إسحاق</span> -من طريق سلمة- قال: خرجت الرُّسُل -فيما يزعم أهلُ التوراة- مِن عند إبراهيم إلى لوط بالمؤتفكة، فلمّا جاءت الرسل لوطًا <span class="qpc-hafs">﴿سيء بهم وضاق بهم ذرعا﴾</span>، وذلك مِن تَخَوُّف قومه عليهم أن يفضحوه في ضيفه، فقال: <span class="qpc-hafs">﴿هذا يوم عصيب﴾</span>{11}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٩٩٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: قوله: <span class="qpc-hafs">﴿ولَمّا جاءَتْ رُسُلُنا﴾</span> جبريل، وميكائيل، وإسرافيل، ومَلَك الموت <span class="qpc-hafs">﴿لُوطًا سِيءَ بِهِمْ﴾</span> يعني: كَرِهَهم؛ لصنيع قومه بالرجال؛ مخافة أن يفضحوهم، <span class="qpc-hafs">﴿وضاقَ بِهِمْ ذَرْعًا﴾</span>{12}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَقَالَ هَـٰذَا یَوۡمٌ عَصِیبࣱ ۝٧٧﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٥٩٩٧<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- في قوله: <span class="qpc-hafs">﴿وقال هذا يوم عصيب﴾</span>، يقول: شديد{13}. (٨/١٠٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٩٩٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>: أنّ نافع بن الأزرق قال له: أخبِرني عن قوله ﷿: <span class="qpc-hafs">﴿يوم عصيب﴾</span>. قال: يوم شديد. قال: وهل تعرفُ العرب ذلك؟ قال: نعم، أما سمعت الشاعر وهو يقول:</p><p>هم ضربوا قوانِسَ{14} خَيْلِ حُجْرٍ بِجَنْبِ الرَّدْهِ في يومٍ عَصيبِ</p><p>وقال عدي بن زيد:</p><p>فكنت لِزازَ{15} خَصمِك لم أُعرِّدْ{16} وقد سَلَكُوك في يومٍ عصيبِ{17}. (٨/١٠٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٥٩٩٩<span class="dash">-</span></span> عن <span class="name-2">كعب الأحبار</span> -من طريق عبد الله بن رباح- <span class="qpc-hafs">﴿وقال هذا يوم عصيب﴾</span>، قال: يوم سُوءٍ مِن قومي{18}. (٨/٩٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٦٠٠٠<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- <span class="qpc-hafs">﴿وقالَ هَذا يَوْمٌ عَصِيبٌ﴾</span>: شديد{19}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٦٠٠١<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق مَعْمَر- في قوله تعالى: <span class="qpc-hafs">﴿هذا يوم عصيب﴾</span>، قال: شديد{20}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٦٠٠٢<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السدي</span>، مثل ذلك{21}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٦٠٠٣<span class="dash">-</span></span> عن <span class="name-2">محمد بن كعب القُرَظِيِّ</span> -من طريق موسى بن عبيدة- <span class="qpc-hafs">﴿وقال هذا يوم عصيب﴾</span>، قال: يَعْصِبُ شَرُّهُ{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٦٠٠٤<span class="dash">-</span></span> قال <span class="name-3">محمد بن السائب الكلبي</span>: <span class="qpc-hafs">﴿هذا يوم عصيب﴾</span>: شديد{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٦٠٠٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وقالَ﴾</span> جبريل: <span class="qpc-hafs">﴿هَذا يَوْمٌ عَصِيبٌ﴾</span>. يعني: فظيعٌ فاشٍ شَرُّه عليهم{12}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٦٠٠٦<span class="dash">-</span></span> عن <span class="name-3">محمد بن إسحاق</span> -من طريق سلمة- قال: <span class="qpc-hafs">﴿هذا يوم عصيب﴾</span>، أي: يوم بلاء وشِدَّة{25}<span class=comment-ref>٣٢٥٨</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٣٢٥٨</span> لم يذكر <u>ابنُ جرير</u> (١٢/٤٩٨-٤٩٩) في معنى: <span class="qpc-hafs">﴿وقالَ هَذا يَوْمٌ عَصِيبٌ﴾</span> سوى قول ابن عباس، وقتادة، وابن إسحاق.</div></p><p><div></p><p><p><span class="item-no">٣٦٠٠٧<span class="dash">-</span></span> عن <span class="name-3">جعفر</span>{26} -من طريق الحسن بن عمرو بن شقيق- <span class="qpc-hafs">﴿وقال هذا يوم عصيب﴾</span>، قال: يوم سيء مِن قومي{6}. (ز)</p></p><p></div></p></div>",footnotes:1:الوَجْد: الحزن. تاج العروس (وجد).أخرجه ابن جرير ١٢/٥٢٠، وفي تاريخه ١/٣٠٤. وعزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ١٢/٤٩٦.أخرجه ابن جرير ١٢/٤٩٦، وابن أبي حاتم ٦/٢٠٦٠.أخرجه ابن جرير ١٢/٤٩٥، وابن أبي حاتم ٦/٢٠٦١. وعزاه السيوطي إلى أبي الشيخ.أخرجه ابن أبي حاتم ٦/٢٠٦١.عزاه الحافظ ابن حجر في الفتح ٨/٣٥٠ إلى ابن أبي حاتم.ذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٢/٣٠١-.أخرجه عبد الرزاق ٢/٩٧. وعزاه السيوطي إلى عبد بن حميد.ذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٢/٣٠١-.أخرجه ابن جرير ١٢/٤٩٧.تفسير مقاتل بن سليمان ٢/٢٩٢.أخرجه ابن جرير ١٢/٤٩٩، وابن أبي حاتم ٦/٢٠٦١. وعزاه السيوطي إلى أبي الشيخ.قَوْنَس الفَرَس: ما بين أُذنيه، وقيل: مُقَدَّمُ رأسه. لسان العرب (قنس).يقال: جعلت فلانًا لزازًا لفلان، أي: لا يدعه يخالف ولا يعاند. لسان العرب (لزز).عرد الرجل عن قرنه: إذا أحجم ونكل. لسان العرب (عرد).أخرجه الطستي -كما في الإتقان ٢/٨٧-. وعزاه السيوطي إلى ابن الأنباري في الوقف والابتداء.أخرجه ابن أبي الدنيا في كتاب العقوبات -موسوعة الإمام ابن أبي الدنيا ٤/٤٦٤ (١٤٩)-. وعزاه السيوطي إلى عبد الله بن أحمد في زوائد الزهد.أخرجه ابن جرير ١٢/٤٩٨.أخرجه عبد الرزاق ١/٣٠٩، وابن جرير ١٢/٤٩٩. وعلَّقه ابن أبي حاتم ٦/٢٠٦١.علَّقه ابن أبي حاتم ٦/٢٠٦١أخرجه ابن أبي حاتم ٦/٢٠٦١.ذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٢/٣٠١-.تفسير مقاتل بن سليمان ٢/٢٩٢.أخرجه ابن جرير ١٢/٤٩٩.لعله جعفر بن سليمان الضبعى (ت:١٧٨)، ينظر: التاريخ الكبير للبخاري ٢/ ٣٠٠.أخرجه ابن أبي حاتم ٦/٢٠٦١.
  11,78,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَجَاۤءَهُۥ قَوۡمُهُۥ یُهۡرَعُونَ إِلَیۡهِ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٦٠٠٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- في قوله: <span class="qpc-hafs">﴿وجاءه قومه يهرعون إليه﴾</span>، قال: يُسْرِعون{1}. (٨/١٠٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٦٠٠٩<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق الضحاك- في قوله: <span class="qpc-hafs">﴿وجآءه قومه يهرعون إليه﴾</span>، قال: يَسْعَوْنَ إليه{2}. (٨/١٠٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٦٠١٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>: أنّ نافع بن الأزرق قال له: أخبِرني عن قوله ﷿: <span class="qpc-hafs">﴿يهرعون إليه﴾</span>. قال: يُقبِلون إليه بالغَضَب. قال: وهل تعرف العرب ذلك؟ قال: نعم، أما سمعتَ الشاعرَ وهو يقول:</p><p>أتونا يهرعون وهم أُسارى سيوفهم على رغم الأُنوف{3}. (٨/١٠٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٦٠١١<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نجيح- في قول الله: <span class="qpc-hafs">﴿يهرعون إليه﴾</span>، قال: يُهَرْوِلُون إليه، وهو الإسراع في المشي{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٦٠١٢<span class="dash">-</span></span> عن <span class="name-2">الضحاك بن مزاحم</span> -من طريق جُوَيْبِر- <span class="qpc-hafs">﴿وجاءه قومه يهرعون إليه﴾</span>، قال: يَسْعَوْن إليه{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٦٠١٣<span class="dash">-</span></span> قال <span class="name-2">الحسن البصري</span>: مَشْيٌ بين مشيتين{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٦٠١٤<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق مَعْمَر- في قوله تعالى: <span class="qpc-hafs">﴿يهرعون إليه﴾</span>، قال: يُسْرِعون إليه{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٦٠١٥<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- <span class="qpc-hafs">﴿وجاءه قومه يهرعون إليه﴾</span>: يُسْرِعون إليه المشي{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٦٠١٦<span class="dash">-</span></span> عن <span class="name-3">شمر بن عطية</span> -من طريق حفص بن حميد- قال: أقبلوا يُسْرِعون مشيًا بين الهَرْولةِ والجَمْزِ{9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٦٠١٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وجاءَهُ قَوْمُهُ يُهْرَعُونَ إلَيْهِ﴾</span>، يعني: يُسْرِعون إليه مُشاةً إلى لوط{10}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٦٠١٨<span class="dash">-</span></span> قال <span class="name-3">سفيان الثوري</span>: <span class="qpc-hafs">﴿يهرعون إليه﴾</span>: يُسْرِعون إليه{11}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٦٠١٩<span class="dash">-</span></span> عن <span class="name-3">سفيان بن عيينة</span> -من طريق سوار بن عبد الله- في قوله: <span class="qpc-hafs">﴿يهرعون إليه﴾</span>، قال: كأنّهم يدفعون{5}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَمِن قَبۡلُ كَانُوا۟ یَعۡمَلُونَ ٱلسَّیِّـَٔاتِۚ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٦٠٢٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- في قوله: <span class="qpc-hafs">﴿ومن قبل كانوا يعملون السيئات﴾</span>، قال: يأتون الرِّجال{13}. (٨/١٠٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٦٠٢١<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- في قوله: <span class="qpc-hafs">﴿ومن قبل كانوا يعملون السيئات﴾</span>، يقول: يَنكِحون الرِّجال{14}. (٨/١٠٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٦٠٢٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ومِن قَبْلُ﴾</span> أن نبعث لوطًا <span class="qpc-hafs">﴿كانُوا يَعْمَلُونَ السَّيِّئاتِ﴾</span> يعني: نكاح الرجال{10}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٦٠٢٣<span class="dash">-</span></span> عن <span class="name-3">عبد الملك ابن جُرَيْج</span> -من طريق حجاج- <span class="qpc-hafs">﴿ومِن قَبْلُ كانُوا يَعْمَلُونَ السَّيِّئاتِ﴾</span>، قال: يأتون الرجال{16}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَمِن قَبۡلُ كَانُوا۟ یَعۡمَلُونَ ٱلسَّیِّـَٔاتِۚ﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٣٦٠٢٤<span class="dash">-</span></span> عن <span class="name-2">جامع بن شداد أبي صخرة</span> -من طريق عمر بن أبي زايدة- قال: كانت اللُّوطِيَّةُ في قوم لوطٍ في النساء قبل أن تكون في الرجال بأربعين سنة{17}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿قَالَ یَـٰقَوۡمِ هَـٰۤؤُلَاۤءِ بَنَاتِی هُنَّ أَطۡهَرُ لَكُمۡۖ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٦٠٢٥<span class="dash">-</span></span> عن <span class="name-1">حذيفة بن اليمان</span> -من طريق قتادة- قال: عَرَض عليهم بناتِه تزويجًا، وأراد أن يَقِي أضيافه بتزويج بناته{18}<span class=comment-ref>٣٢٥٩</span>. (٨/١١٠)</p></p><p></div></p><p><div><span class=comment-ref>٣٢٥٩</span> ساق <u>ابنُ عطية</u> (٤/٦١٩) هذا القول، ثم <span class="comment-type-4">علَّق</span> بقوله: «وذلك على أن كانت سُنَّتُهم جوازَ نكاح الكافر المؤمنة، أو على أنّ في ضمن كلامه أن يؤمنوا».</div></p><p><div></p><p><p><span class="item-no">٣٦٠٢٦<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، في قوله: <span class="qpc-hafs">﴿قال يا قوم هؤلاء بناتي﴾</span>، قال: ما عَرَضَ لوطٌ ﵇ بناتِه على قومه لا سفاحًا ولا نكاحًا، إنما قال: هؤلاء بناتي نساؤُكم. لأنّ النَّبِيَّ إذا كان بين ظهري قوم فهو أبوهم، قال الله في القرآن: (وأَزْواجُهُ أُمَّهاتُهُمْ وهُوَ أبُوهُمْ) في قراءة أُبَيٍّ{19}. (٨/١٠٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٦٠٢٧<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق جُوَيْبِر، ومقاتل- قال: لَمّا سَمِعت الفَسَقَة بأضياف لوط جاءوا إلى باب لوط، فأغلق لوطٌ عليهم البابَ دونهم، ثم اطَّلَع عليهم، فقال: <span class="qpc-hafs">﴿هؤلاء بناتي﴾</span>. يعرض عليهم بناته بالنِّكاح والتزويج، ولم يَعرِضها عليهم للفاحشة، وكانوا كُفّارًا، وبناته مسلمات، فلمّا رأى البلاء وخاف الفضيحة عرض عليهم التَّزْوِيج، وكان اسم ابنتيه إحداهما: رعوثا، والأخرى: رميثا، ويقال: زبوثا{20}. (٨/١٠٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٦٠٢٨<span class="dash">-</span></span> عن <span class="name-2">كعب الأحبار</span> -من طريق عبد الله بن رباح-: <span class="qpc-hafs">﴿يا قوم هؤلاء بناتي هن أطهر لكم﴾</span> تَزَوَّجُوهُنَّ{21}. (٨/٩٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٦٠٢٩<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span> -من طريق أبي بشر- قال: إنّما دعاهم إلى نسائهم، وكلُّ نبيٍّ أبو أُمَّته{22}. (٨/١٠٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٦٠٣٠<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ليث- في قوله: <span class="qpc-hafs">﴿هؤلاء بناتي﴾</span>، قال: لم يَكُنَّ بناتِه، ولكِن كُنَّ مِن أُمَّتِه، وكلُّ نَبِيٍّ أبو أُمَّتِه، وقال في بعض القراءة: (النَّبِيُّ أوْلى بِالمُؤْمِنِينَ مِن أنفُسِهِمْ وأَزْواجُهُ أُمَّهاتُهُمْ وهُوَ أبٌ لَّهُمْ){23}. (٨/١٠٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٦٠٣١<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ليث- في قوله: <span class="qpc-hafs">﴿هؤلاء بناتي هن أطهر لكم﴾</span>، قال: كلُّ نبيٍّ أبو أُمَّتِه، فأمّا لُوطٌ فإنّه لم تكن له إلا ابنتان{24}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٦٠٣٢<span class="dash">-</span></span> عن <span class="name-2">وهب بن مُنَبِّه</span> -من طريق عبد الصمد بن معقل- قال: فدخلوا على لوط -يعني: الملائكة-، فلمّا رأتهم امرأتُه أعجبها حسنُهم وجمالُهم، فأرسلت إلى أهل القرية: إنّه قد نزل بِنا قومٌ لم يُرَ قومٌ قطُّ أحسن منهم ولا أجمل. فتسامعوا بذلك، فغشوا دار لوط مِن كل ناحية، وتسَوَّروا عليهم الجدران، فلقيهم لوط، فقال: يا قومِ، لا تفضحوني في ضيفي، وأنا أُزَوِّجكم بناتي؛ فهُنَّ أطهر لكم. فقالوا: لو كُنّا نريد بناتك لقد عرفنا مكانهن، ولكن لا بُدَّ لنا مِن هؤلاء القوم الذين نزلوا بك، خلِّ بيننا وبينهم{25}. (٨/٩٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٦٠٣٣<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- في قوله: <span class="qpc-hafs">﴿هؤلاء بناتي هنَّ أطهر لكم﴾</span>، قال: أمَرهم لوطٌ بتزويج النساء، وقال: <span class="qpc-hafs">﴿هن أطهر لكم﴾</span>{26}. (٨/١١٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٦٠٣٤<span class="dash">-</span></span> عن معمر، قال: وبلغني هذا أيضًا عن <span class="name-2">مجاهد</span>{27}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٦٠٣٥<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السدي</span> -من طريق أسباط-: <span class="qpc-hafs">﴿وجاءه قومه يهرعون إليه﴾</span> قالوا: أو لم نَنْهَك أن تضيف العالمين؟ قال: <span class="qpc-hafs">﴿هؤلاء بناتي هن أطهر لكم﴾</span> إن كنتم فاعلين، <span class="qpc-hafs">﴿أليس منكم رجل رشيد﴾</span>؟{28}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٦٠٣٦<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السدي</span> -من طريق الحكم بن ظهير- في قوله: <span class="qpc-hafs">﴿هؤلاء بناتي﴾</span>، قال: عرض عليهم نساءَ أُمَّته، كلُّ نبيٍّ فهو أبو أمته. وفي قراءة عبد الله: (النَّبِيُّ أوْلى بِالمُؤْمِنِينَ مِن أنفُسِهِمْ وهُوَ أبٌ لَّهُمْ وأَزْواجُهُ أُمَّهاتُهُمْ){29}. (٨/١٠٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٦٠٣٧<span class="dash">-</span></span> عن <span class="name-2">عبد الله بن أبي نجيح</span> -من طريق إسماعيل بن علية- يقول في قوله: <span class="qpc-hafs">﴿هن أطهر لكم﴾</span>، قال: ما عرض عليهم نكاحًا ولا سِفاحًا{30}<span class=comment-ref>٣٢٦٠</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٣٢٦٠</span> نقل <u>ابنُ عطية</u> (٤/٦١٩) عن أبي عبيدة أنّ قول لوط ﵇: <span class="qpc-hafs">﴿هَؤُلاءِ بَناتِي هُنَّ أطْهَرُ لَكُمْ﴾</span>: إنّما كان مُدافَعةً، ولم يُرِد إمضاءه، ثم <span class="comment-type-2">انتقده</span> <span class="mustanad">مستندًا إلى الدلالة العقلية</span>، فقال: «وهو ضعيف، وهذا كما يُقال لِمَن ينهى عن مال الغير: الخنزير أحلُّ لك مِن هذا. وهذا التَّنَطُّع ليس مِن كلام الأنبياء -صلى الله عليهم وسلم-».</div></p><p><div></p><p><p><span class="item-no">٣٦٠٣٨<span class="dash">-</span></span> عن <span class="name-2">الربيع بن أنس</span> -من طريق أبي جعفر- في قوله: <span class="qpc-hafs">﴿هؤلاء بناتي هن أطهر لكم﴾</span>، يعني: التَّزويج{31}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٦٠٣٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿قالَ﴾</span> لوط: <span class="qpc-hafs">﴿يا قَوْمِ هَؤُلاءِ بَناتِي﴾</span> ريثا، وزعوثا، فتزوجوهما، <span class="qpc-hafs">﴿هُنَّ أطْهَرُ لَكُمْ﴾</span> يعني: أحَلُّ لكم مِن إتيان الرجال{10}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٦٠٤٠<span class="dash">-</span></span> عن <span class="name-3">محمد بن إسحاق</span> -من طريق سلمة- قال: لَمّا جاءت الرسل لوطًا أقبل قومُه إليهم حين أُخْبِروا بهم يُهْرَعون إليه، فيزعمون -والله أعلم-: أنّ امرأة لوط هي التي أخبرتهم بمكانهم، وقالت: إنّ عند لوط لَضِيفانًا ما رأيت أحسن ولا أجمل قطُّ منهم. وكانوا يأتون الرجال شهوة مِن دون النساء، فاحشة لم يسبقهم بها أحد من العالمين، فلمّا جاءوه قالوا: <span class="qpc-hafs">﴿أولم ننهك عن العالمين﴾</span> [الحجر:٧٠]، أي: ألم نقل لك: لا يَقْرَبَنَّك أحدٌ، فإنّا لن نجد عندك أحدًا إلا فعلنا به الفاحشة. <span class="qpc-hafs">﴿قال يا قوم هؤلاء بناتي هن أطهر لكم﴾</span>، فأنا أفدي ضيفي منكم بِهِنَّ. ولم يَدْعُهم إلّا إلى الحلال مِن النكاح{28}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿فَٱتَّقُوا۟ ٱللَّهَ وَلَا تُخۡزُونِ فِی ضَیۡفِیۤۖ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٦٠٤١<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span>: <span class="qpc-hafs">﴿ولا تخزون في ضيفي﴾</span>، يقول: ولا تفضحوني{34}. (٨/١١١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٦٠٤٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فاتَّقُوا اللَّهَ﴾</span> في معصيته، <span class="qpc-hafs">﴿ولا تُخْزُونِ فِي ضَيْفِي﴾</span>{10}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿أَلَیۡسَ مِنكُمۡ رَجُلࣱ رَّشِیدࣱ ۝٧٨﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٦٠٤٣<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، <span class="qpc-hafs">﴿أليس منكم رجل رشيد﴾</span>، قال: يأمر بالمعروف، وينهى عن المنكر{36}. (٨/١٠٩، ١١١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٦٠٤٤<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عكرمة- في قوله: <span class="qpc-hafs">﴿أليس منكم رجل رشيد﴾</span>، قال: واحد يقول: لا إله إلا الله{37}. (٨/١١١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٦٠٤٥<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span>، مثله{38}. (٨/١١١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٦٠٤٦<span class="dash">-</span></span> عن <span class="name-2">أبي مالك غزوان الغفاري</span> -من طريق السدي- <span class="qpc-hafs">﴿أليس منكم رجل رشيد﴾</span>، قال: رجل يأمر بمعروف، وينهى عن المنكر{18}. (٨/١١١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٦٠٤٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ألَيْسَ مِنكُمْ رَجُلٌ رَشِيدٌ﴾</span>، يقول: ما منكم رجل مُرْشِد{10}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٦٠٤٨<span class="dash">-</span></span> عن <span class="name-3">محمد بن إسحاق</span> -من طريق سلمة- <span class="qpc-hafs">﴿فاتقوا الله ولا تخزون في ضيفي أليس منكم رجل رشيد﴾</span>، أي: رجل يعرف الحق، يأمر بالمعروف، وينهى عن المنكر{41}<span class=comment-ref>٣٢٦١</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٣٢٦١</span> لم يذكر <u>ابنُ جرير</u> (١٢/٥٠٧) في معنى: <span class="qpc-hafs">﴿ألَيْسَ مِنكُمْ رَجُلٌ رَشِيدٌ﴾</span> سوى قول ابن إسحاق.</div></p></div>",footnotes:1:أخرجه ابن جرير ١٢/٥٠١، وابن أبي حاتم ٦/٢٠٦١. وعلَّقه البخاري في صحيحه ٤/١٧٣٦ بلفظ: مسرعين.أخرجه ابن أبي حاتم ٦/٢٠٦١. وعزاه السيوطي إلى أبي الشيخ.أخرجه الطستي -كما في الإتقان ٢/٨٦-.تفسير مجاهد ص٣٨٩، وأخرجه ابن جرير ١٢/٥٠٠، وابن أبي حاتم ٦/٢٠٦٢.أخرجه ابن جرير ١٢/٥٠٠.تفسير الثعلبي ٥/١٨١، وتفسير البغوي ٤/١٩١.أخرجه عبد الرزاق ١/٣٠٩، وابن جرير ١٢/٥٠٠.أخرجه ابن جرير ١٢/٥٠١. وعلَّقه ابن أبي حاتم ٦/٢٠٦١.أخرجه ابن جرير ١٢/٥٠١.</p><p>والجَمْز: ضرب من السير سريع. النهاية (جمز).تفسير مقاتل بن سليمان ٢/٢٩٢.علَّقه ابن جرير ١٢/٥٠١.أخرجه ابن جرير ١٢/٥٠٠.عزاه السيوطي إلى ابن جرير، وابن أبي حاتم.أخرجه ابن أبي حاتم ٦/٢٠٦٢. وعزاه السيوطي إلى أبي الشيخ.تفسير مقاتل بن سليمان ٢/٢٩٢.أخرجه ابن جرير ١٢/٥٠٢.أخرجه ابن أبي حاتم ٦/٢٠٦٢.أخرجه ابن أبي حاتم ٦/٢٠٦٣.عزاه السيوطي إلى أبي الشيخ.</p><p>والقراءة شاذة. انظر: مصنف عبد الرزاق ١٠/١٨١ (١٨٧٤٨)، وروح المعاني ٢١/١٥٢.أخرجه ابن عساكر ٥٠/٣١٣. وعزاه السيوطي إلى إسحاق بن بشر.أخرجه ابن أبي الدنيا في كتاب العقوبات -موسوعة الإمام ابن أبي الدنيا ٤/٤٦٤ (١٤٩)-، وابن أبي حاتم ٦/٢٠٦٢. وعزاه السيوطي إلى عبد الله بن أحمد في زوائد الزهد.أخرجه ابن جرير ١٢/٥٠٣-٥٠٤، وابن أبي حاتم ٦/٢٠٦٢.أخرجه ابن جرير ١٢/٥٠٢-٥٠٣، وابن أبي حاتم ٦/٢٠٦٢. وعزاه السيوطي إلى أبي الشيخ.</p><p>والقراءة شاذة.أخرجه سفيان الثوري في تفسيره ص١٣١.أخرجه ابن جرير في تفسيره ١٢/٥٢٠، وفي تاريخه ١/٣٠٤، وابن أبي حاتم ٦/٢٠٦٣. وعزاه السيوطي إلى ابن المنذر.أخرجه عبد الزاق ١/٣٠٦، وابن جرير ١٢/٥٠٢. وذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٢/٣٠١-. وعزاه السيوطي إلى أبي الشيخ.أخرجه عبد الرزاق ١/٣٠٦، وابن جرير ١٢/٥٠٢.أخرجه ابن جرير ١٢/٥٠٤.أخرجه ابن عساكر ٥٠/٣١٧. وعزاه السيوطي إلى ابن أبي الدنيا.أخرجه ابن جرير ١٢/٥٠٣، وابن أبي حاتم ٦/٢٠٦٣.أخرجه ابن جرير ١٢/٥٠٣.تفسير مقاتل بن سليمان ٢/٢٩٢.أخرجه ابن جرير ١٢/٥٠٤.عزاه السيوطي إلى أبي الشيخ.تفسير مقاتل بن سليمان ٢/٢٩٢.عزاه السيوطي إلى أبي الشيخ. وأخرج هذا اللفظ ابن عساكر ٥٠/٣١٣ في رواية طويلة من طريق جويبر ومقاتل، وعزاها السيوطي إلى إسحاق بن بشر.أخرجه ابن أبي حاتم ٦/٢٠٦٣، والبيهقي في الأسماء والصفات (٢٠٥).عزاه السيوطي إلى أبي الشيخ. وينظر: تفسير البغوي ٤/١٩٢.أخرجه ابن أبي حاتم ٦/٢٠٦٣.تفسير مقاتل بن سليمان ٢/٢٩٢.أخرجه ابن جرير ١٢/٥٠٧.
  11,79,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿قَالُوا۟ لَقَدۡ عَلِمۡتَ مَا لَنَا فِی بَنَاتِكَ مِنۡ حَقࣲّ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٦٠٤٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿قالُوا لَقَدْ عَلِمْتَ ما لَنا فِي بَناتِكَ مِن حَقٍّ﴾</span>، يعنون: مِن حاجَةٍ{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٦٠٥٠<span class="dash">-</span></span> عن <span class="name-3">محمد بن إسحاق</span> -من طريق سلمة- قال: <span class="qpc-hafs">﴿قالوا لقد علمت ما لنا في بناتك من حق﴾</span>، أي: مِن أزواج{2}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَإِنَّكَ لَتَعۡلَمُ مَا نُرِیدُ ۝٧٩﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٦٠٥١<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- في قوله: <span class="qpc-hafs">﴿قالوا لقد علمت ما لنا في بناتك من حق وإنك لتعلم ما نريد﴾</span>، قال: إنّما نُريد الرِّجال{3}. (٨/١١١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٦٠٥٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وإنَّكَ لَتَعْلَمُ ما نُرِيدُ﴾</span> أنّهم يريدون الأضياف{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٦٠٥٣<span class="dash">-</span></span> عن <span class="name-3">محمد بن إسحاق</span> -من طريق سلمة- <span class="qpc-hafs">﴿وإنك لتعلم ما نريد﴾</span>، أي: إنّ بُغْيَتَنا لَغَيْرُ ذلك{3}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٢/٢٩٢.أخرجه ابن جرير ١٢/٥٠٧، وابن أبي حاتم ٦/٢٠٦٣.أخرجه ابن جرير ١٢/٥٠٨، وابن أبي حاتم ٦/٢٠٦٤.تفسير مقاتل بن سليمان ٢/٢٩٢.أخرجه ابن جرير ١٢/٥٠٨، وابن أبي حاتم ٦/٢٠٦٤.
  11,80,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿قَالَ لَوۡ أَنَّ لِی بِكُمۡ قُوَّةً أَوۡ ءَاوِیۤ إِلَىٰ رُكۡنࣲ شَدِیدࣲ ۝٨٠﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٦٠٥٤<span class="dash">-</span></span> عن أبي هريرة، في قوله: <span class="qpc-hafs">﴿أو ءاوي إلى ركن شديد﴾</span>، قال: قال رسول الله ﷺ: «<b>رَحِم الله لوطًا، كان يأوي إلى ركن شديد</b> -يعني: الله تعالى-، <b>فما بعث اللهُ بعده نبيًّا إلا في ثَرْوَةٍ</b>{1} <b>مِن قومه</b>»{2}. (٨/١١٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٦٠٥٥<span class="dash">-</span></span> عن قتادة، قال: ذُكِر لنا: أنّ نبي الله ﷺ كان إذا قرأ هذه الآية قال: «<b>رَحِم الله لوطًا، إن كان لَيَأْوِي إلى رُكْنٍ شديد</b>». وذُكر لنا: أنّ الله لم يبعث نبيًّا بعد لوط إلا في ثروة من قومه، حتى بعث الله نبيَّكم ﷺ في ثروة مِن قومه{3}. (٨/١١٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٦٠٥٦<span class="dash">-</span></span> عن <span class="name-1">علي بن أبي طالب</span> أنّه خطب، فقال: عشيرةُ الرجل للرجل خيرٌ مِن الرجل لعشيرته، إنّه إن كفَّ يدَه عنهم كفَّ يدًا واحدة وكفُّوا عنه أيديًا كثيرة، مع مودَّتِهم وحِفاظِهم ونصرتِهم، حتى لَرُبَّما غَضِب الرجلُ للرجل وما يعرفه إلا بحسبه، وسأتلو عليكم بذلك آياتٍ مِن كتاب الله تعالى. فتلا هذه الآية: <span class="qpc-hafs">﴿لو أن لي بكم قوة أو ءاوي إلى ركن شديد﴾</span>. قال عليٌّ: والركن الشديد: العشيرة، فلم يكن للوط ﵇ عشيرة، فوالذي لا إله غيره، ما بعث الله نبيًّا بعد لوط إلا في ثروة مِن قومه{4}. (٨/١١٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٦٠٥٧<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق الضَّحّاك- في قوله: <span class="qpc-hafs">﴿أو ءاوي إلى ركن شديد﴾</span>، قال: عشيرة{5}. (٨/١١١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٦٠٥٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق جُوَيْبِر، ومقاتل- قال: ... فلمّا لم يتناهوا، ولم يَرُدَّهم قوله، ولم يقبلوا شيئًا مِمّا عرض عليهم مِن أمر بناته؛ قال: <span class="qpc-hafs">﴿لو أن لي بكم قوة أو ءاوي إلى ركن شديد﴾</span>. يعني: عشيرة أو شيعة تنصُرُني، لَحُلْتُ بينكم وبين هذا{6}. (٨/١٠٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٦٠٥٩<span class="dash">-</span></span> عن <span class="name-2">كعب الأحبار</span> -من طريق عبد الله بن رباح- قال: <span class="qpc-hafs">﴿لو أن لي بكم قوة أو ءاوي إلى ركن شديد﴾</span>، قال: إلى عشيرة تمنع. فبلغني: أنّه لم يُبْعَث بعد لوط رسولٌ إلا في عِزٍّ مِن قومه{7}. (٨/٩٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٦٠٦٠<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> -من طريق مبارك بن فضالة- <span class="qpc-hafs">﴿أو آوي إلى ركن شديد﴾</span>، قال: إلى رُكْنٍ مِن الناس{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٦٠٦١<span class="dash">-</span></span> عن [<span class="name-2">الحسن البصري</span>] -من طريق مبارك- في قوله: <span class="qpc-hafs">﴿أو آوي إلى ركن شديد﴾</span>، قال: إلى ركن من الناس شديدٍ يمنعونه، لا واللهِ، ما جادلوه حتى قال: <span class="qpc-hafs">﴿أليس منكم رجل رشيد﴾</span>{9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٦٠٦٢<span class="dash">-</span></span> قال <span class="name-2">الحسن البصري</span>: فلم يبعث الله سبحانه بعد لوطٍ نبيًّا إلا في عِزٍّ مِن قومه، وكانت امرأةُ لوطٍ منافقةً؛ تُظْهِر الإسلام، وقلبُها على الكُفْر{10}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٦٠٦٣<span class="dash">-</span></span> عن <span class="name-2">وهب بن مُنَبِّه</span> -من طريق عبد الصمد-: قال لوط ﵇: <span class="qpc-hafs">﴿لو أن لي بكم قوة أو ءاوي إلى ركن شديد﴾</span>. فوجد عليه الرسل، وقالوا: يا لوط، إنّ ركنك لَشَدِيدٌ{11}. (٨/١١٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٦٠٦٤<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿أو آوي إلى ركن شديد﴾</span>، قال: العشيرة{12}. (٨/١١٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٦٠٦٥<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط-: قال لوطٌ: <span class="qpc-hafs">﴿لو أن لي بكم قوة أو ءاوي إلى ركن شديد﴾</span>، يقول: إلى جُندٍ شديد لَقاتَلْتُكُم{13}. (٨/١١١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٦٠٦٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿قالَ لَوْ أنَّ لِي بِكُمْ قُوَّةً﴾</span> يعني: بَطْشًا، <span class="qpc-hafs">﴿أوْ آوِي إلى رُكْنٍ شَدِيدٍ﴾</span> يعني: منيع، يعني: رهط، يعني: عشيرة؛ لَمَنَعْتُكم مِمّا تريدون{14}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٦٠٦٧<span class="dash">-</span></span> عن <span class="name-3">محمد بن إسحاق</span> -من طريق سلمة- قال: <span class="qpc-hafs">﴿لو أن لي بكم قوة أو آوي إلى ركن شديد﴾</span>، أي: عشيرة تمنعني، أو شيعة تنصرني؛ لَحُلْتُ بينكم وبين هذا{8}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿قَالَ لَوۡ أَنَّ لِی بِكُمۡ قُوَّةً أَوۡ ءَاوِیۤ إِلَىٰ رُكۡنࣲ شَدِیدࣲ ۝٨٠﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٣٦٠٦٨<span class="dash">-</span></span> عن أبي هريرة، أنّ النبي ﷺ قال: «<b>يغفِر الله لِلُوطٍ، إن كان لَيَأْوِي إلى ركن شديد</b>»{16}. (٨/١١٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٦٠٦٩<span class="dash">-</span></span> عن أبي بن كعب، قال: قال رسول الله ﷺ: «<b>رَحِم الله لوطًا، إن كان لَيأوي إلى ركن شديد</b>»{17}. (٨/١١٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٦٠٧٠<span class="dash">-</span></span> عن الحسن، أنّ هذه الآية لَمّا نزلت: <span class="qpc-hafs">﴿لو أن لي بكم قوة أو ءاوي إلى ركن شديد﴾</span> قال رسول الله ﷺ: «<b>رَحِم اللهُ أخي لوطًا، لقد كان يأوي إلى ركن شديد، فلِأَيِّ شيء استكان!</b>»{18}<span class=comment-ref>٣٢٦٢</span>. (٨/١١٢)</p></p><p></div></p><p><div><span class=comment-ref>٣٢٦٢</span> <span class="comment-type-4">علَّق</span> <u>ابنُ عطية</u> (٤/٦٢١) على هذا الحديث بقوله: «هذا نقدٌ لأن يلفظ لوط ﵇ هذه الألفاظ، وإلا فحالة النبي ﷺ وقت طُرِح سَلا الجزور، ومع أهل الطائف، وفي غير موطن تقتضي مقالة لوط، لكن محمدًا ﷺ لم ينطق بشيءٍ من ذلك عزامة منه ونجدة، وإنما خشي لوط ﵇ أن يُمْهِل الله أولئك العصاة حتى يعصوه في الأضياف كما أمهلهم فيما قبل ذلك مِن معاصيهم فيمن مضى، فتمنّى ركنًا من البشر يعاجلهم به، وهو يعلم أنّ الله تعالى مِن وراء عقابهم».</div></p><p><div></p><p><p><span class="item-no">٣٦٠٧١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عكرمة- قال: ما بعث الله نبيًّا بعد لوطٍ إلا في عِزٍّ مِن قومه{19}. (٨/١١٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٦٠٧٢<span class="dash">-</span></span> عن <span class="name-3">عبد الملك ابن جُرَيْج</span> -من طريق حجّاج- في قوله: <span class="qpc-hafs">﴿أو ءاوي إلى ركن شديد﴾</span>، قال: بلغني: أنّه لم يُبعَث نبيٌّ بعد لوطٍ إلا في ثروة مِن قومه، حتى النبي ﷺ{8}. (٨/١١٢)</p></p><p></div></p></div>",footnotes:1:الثروة: العدد الكثير. النهاية (ثرا).أخرجه أحمد ١٤/٥٣٩ (٨٩٨٧)، ١٦/٥٢٤ (١٠٩٠٣)، والترمذي ٥/٣٤٧-٣٤٨ (٣٣٧٨، ٣٣٧٩) بنحوه، وابن حبان ١٤/٨٦ (٦٢٠٦)، ١٤/٨٧-٨٨ (٦٢٠٧)، والحاكم ٢/٦١١ (٤٠٥٤)، وابن جرير ١٢/٥١٠، ٥١١، ٥١٢، وابن أبي حاتم ٦/٢٠٦٤ (١١٠٧٦)، من طريق محمد بن عمرو، عن أبي سلمة، عن أبي هريرة به.</p><p>قال الترمذي: «وهذا حديث حسن». وقال الحاكم: «هذا حديث صحيح، على شرط مسلم، ولم يخرجاه بهذه الزيادة، إنّما اتفقا على حديث الزهري عن سعيد وأبي عبيد عن أبي هريرة مختصرًا». وقال ابن كثير في البداية والنهاية ١/٤٧٨: «حديث مُنكَر مِن هذا الوجه». وينظر: الألباني في الصحيحة ٤/١٥٢ (١٦١٧)، ٤/٤٨٢-٤٨٥ (١٨٦٧).أخرجه ابن عساكر في تاريخه ٦٤/١٧٢ بنحوه، وعبد الرزاق في تفسيره ٢/٣٥١ (١٧٣٤، ١٧٣٥)، وابن جرير ١٢/٥١٢-٥١٣ واللفظ له.عزاه السيوطي إلى أبي الشيخ.أخرجه ابن أبي حاتم ٦/٢٠٦٤.أخرجه ابن عساكر ٥٠/٣١٣. وعزاه السيوطي إلى إسحاق بن بشر.أخرجه ابن أبي الدنيا في كتاب العقوبات -موسوعة الإمام ابن أبي الدنيا ٤/٤٦٤ (١٤٩)-، وابن أبي حاتم ٦/٢٠٦٤. وعزاه السيوطي إلى عبد الله بن أحمد في زوائد الزهد.أخرجه ابن جرير ١٢/٥٠٩.أخرجه ابن أبي حاتم ٦/٢٠٦٤، وفيه: عن الحسين. وهو تحريف.ذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٢/٣٠٢-.أخرجه ابن جرير في تفسيره ١٢/٥١٣، ٥٢٠، وفي تاريخه ١/٣٠٠.أخرجه عبد الرزاق ١/٣١١، وابن جرير ١٢/٥٠٩-٥١٠، وابن عساكر ٥٠/٣١٠. وذكر نحوه يحيى بن سلام -كما في تفسير ابن أبي زمنين ٢/٣٠٢-.أخرجه ابن جرير ١٢/٥٠٩، وابن أبي حاتم ٦/٢٠٦٤.تفسير مقاتل بن سليمان ٢/٢٩٢.أخرجه ابن جرير ١٢/٥٠٩.أخرجه البخاري ٤/١٤٨ (٣٣٧٥)، ومسلم ٤/١٨٤٠ (١٥١)، وسعيد بن منصور في التفسير من سننه ٥/٣٥٦-٣٥٧ (١٠٩٧).عزاه السيوطي إلى ابن مردويه.أخرجه ابن جرير ١٢/٥١٠.أخرجه سعيد بن منصور (١٠٩٨- تفسير). وعزاه السيوطي إلى أبي الشيخ.أخرجه ابن جرير ١٢/٥٠٩.
  11,81,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿قَالُوا۟ یَـٰلُوطُ إِنَّا رُسُلُ رَبِّكَ لَن یَصِلُوۤا۟ إِلَیۡكَۖ فَأَسۡرِ بِأَهۡلِكَ بِقِطۡعࣲ مِّنَ ٱلَّیۡلِ وَلَا یَلۡتَفِتۡ مِنكُمۡ أَحَدٌ إِلَّا ٱمۡرَأَتَكَۖ إِنَّهُۥ مُصِیبُهَا مَاۤ أَصَابَهُمۡۚ إِنَّ مَوۡعِدَهُمُ ٱلصُّبۡحُۚ أَلَیۡسَ ٱلصُّبۡحُ بِقَرِیبࣲ ۝٨١﴾</span> - قراءات</h3></p><p><div></p><p><p><span class="item-no">٣٦٠٧٣<span class="dash">-</span></span> عن هارون، قال: في حرف <span class="name-1">ابن مسعود</span>: (فَأَسْرِ بِأَهْلِكَ بِقِطْعٍ مِّنَ الَّليْلِ إلّا امْرَأَتَكَ){1}<span class=comment-ref>٣٢٦٣</span>. (٨/١١٨)</p></p><p></div></p><p><div><span class=comment-ref>٣٢٦٣</span> <span class="comment-type-4">علَّق</span> <u>ابنُ جرير</u> (١٢/٥٢٥) على هذا الأثر بقوله: «وهذا يدُلُّ على صحة القراءة في المرأة بالنصب».</p><p>واختلف القرأة في قراءة قوله تعالى: <span class="qpc-hafs">﴿إلا امْرَأَتَكَ﴾</span> على قراءتين: <b>الأولى:</b> <span class="qpc-hafs">﴿إلا امرأتَكَ﴾</span> بالنصب. <b>الثانية:</b> ‹إلّا امْرَأتُكَ› بالرفع. و<span class="comment-type-4">بيَّن</span> <u>ابنُ جرير</u> (١٢/٥١٤-٥١٥) أنّ المعنى على القراءة الأولى: «فأَسْرِ بأهلك إلا امرأتَك، وعلى أنّ لوطًا أُمِر أن يسري بأهله سوى زوجته، فإنه نُهِيَ أن يَسْرِيَ بها، وأُمِرَ بتخليفها مع قومها». و<span class="comment-type-4">بيَّن</span> المعنى على القراءة الثانية بقوله: «ولا يلتفت منكم أحدٌ إلا امرأتُك، وإن لوطًا قد أخرجها معه، وأنه نُهِيَ لوطٌ ومَن معه ممن أسرى معه، أن يَلْتَفِتَ سوى زوجته، وإنها التفتت، فهَلَكَت لذلك».</p><p>و<span class="comment-type-1">وجَّه</span> <u>ابنُ القيم</u> (٢/٦٠) القراءة الثانية بقوله: «الاستثناء منقطع في قراءة الرفع، ويكون ‹امْرَأتُكَ› مبتدأ، وخبره ما بعده. وهذا التوجيه أولى من أن يُجعَل الاستثناء في قراءة من نصب من قوله: <span class="qpc-hafs">﴿فَأَسْرِ بِأَهْلِكَ﴾</span>، وفي قراءة من رفع مِن قوله: <span class="qpc-hafs">﴿ولا يَلْتَفِتْ مِنكُمْ أحَدٌ﴾</span>، ويكون الاستثناء على هذا مِن <span class="qpc-hafs">﴿فَأَسْرِ بِأَهْلِكَ﴾</span> رفعًا ونصبًا، وإنما قلنا إنّه أولى لأنّ المعنى عليه، فإنّ الله تعالى أمره أن يسري بأهله إلا امرأته، ولو كان الاستثناء مِن الالتفات لكان قد نهى المسري بهم عن الالتفات وأذن فيه لامرأته، وهذا ممتنع لوجهين: أحدهما: أنه لم يأمره أن يسرى بامرأته، ولا دخلت في أهله الذين وعد بنجاتهم. والثاني: أنه لم يكلفهم بعدم الالتفات، ويأذن فيه للمرأة».</div></p><p><h3><span class="qpc-hafs">﴿قَالُوا۟ یَـٰلُوطُ إِنَّا رُسُلُ رَبِّكَ لَن یَصِلُوۤا۟ إِلَیۡكَۖ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٦٠٧٤<span class="dash">-</span></span> عن عبد الرحمن بن بشر الأنصاري، أنّ رسول الله ﷺ قال: «<b>إنّ الناس كانوا أنذروا قومَ لوط، فجاءتهم الملائكةُ عَشِيَّةً، فمرُّوا بناديهم، فقال قوم لوط بعضُهم لبعض: لا تُنَفِّروهم. ولم يَرَوا قومًا قط أحسن مِن الملائكة، فلمّا دخلوا على لوط ﵇ راوَدُوه عن ضيفه، فلم يزل بهم حتى عرض عليهم بناته، فأبوا، فقالت الملائكة:</b> <span class="qpc-hafs">﴿إنا رسل ربك لن يصلوا إليك﴾</span>. <b>قال: رسل ربي؟ قالوا: نعم. قال لوط: فالآن إذن</b>{2}. (٨/١١٤)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٦٠٧٥<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق جويبر، ومقاتل- قال: ... فلمّا لم يتناهوا، ولم يَرُدَّهم قوله، ولم يقبلوا شيئًا مِمّا عرض عليهم من أمر بناته؛ قال: <span class="qpc-hafs">﴿لو أن لي بكم قوة أو ءاوي إلى ركن شديد﴾</span>. يعني: عشيرة أو شيعة تنصُرُني؛ لحُلت بينكم وبين هذا. فكسروا الباب، ودخلوا عليه، وتحوَّل جبريل في صورته التي يكون فيها في السماء، ثم قال: يا لوط، لا تخف، نحن الملائكة، لن يَصِلوا إليك، وأُمِرنا بعذابهم. فقال لوط: يا جبريل، الآن تعذبهم. وهو شديدُ الأسَف عليهم، قال جبريل: موعدُهم الصبح، أليس الصبح بقريب؟ قال ابن عباس: إنّ الله يُعَبِّي العذاب في أول الليل إذا أراد أن يُعذِّب قومًا، ثم يعذبهم في وجه الصبح. قال: فهُيِّئَت الحجارة لقوم لوطٍ في أول الليل لتُرسَل عليهم غُدْوَةً، وكذلك عُذِّبَت الأمم -عاد وثمود- بالغداة، فلما كان عند وجه الصبح عمد جبريل إلى قرى لوط بما فيها؛ من رجالها، ونسائها، وثمارها، وطيرها، فحَواها وطَواها، ثُمَّ قَلَعَها مِن تُخُومِ{3} الثَّرى{4}، ثُمَّ احتمَلها مِن تحت جناحه، ثم رفعها إلى السماء الدنيا، فسمع سكانُ سماء الدنيا أصواتَ الكلاب والطير والرجال والنساء مِن تحت جناح جبريل، ثم أرسلها منكوسة، ثم أتبعها بالحجارة، وكانت الحجارة للرُّعاة والتُّجّار ومَن كان خارِجًا عن مدائنهم{5}. (٨/١٠٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٦٠٧٦<span class="dash">-</span></span> عن <span class="name-2">كعب الأحبار</span> -من طريق عبد الله بن رباح- قال: ... لَمّا رأت الرسلُ ما قد لَقِيَ لوطٌ في سببهم قالوا: <span class="qpc-hafs">﴿يا لوط إنا رُسُلُ ربك﴾</span> إنا ملائكة، <span class="qpc-hafs">﴿لن يصلوا إليك فأسر بأهلك بقطع من الليل ولا يلتفت منكم أحد إلا امرأتك﴾</span> إلى قوله: <span class="qpc-hafs">﴿أليس الصبح بقريب﴾</span>. فخرج عليهم جبريل ﵇، فضرب وجوهَهم بجناحه ضربةً، فطمس أعينهم، والطمس: ذهاب الأعين، ثم احتمل جبريل وجه أرضهم حتى سمع أهل سماء الدنيا نُباح كلابهم وأصوات ديوكهم، ثم قلبها عليهم، قال: <span class="qpc-hafs">﴿وأمطرنا عليهم حجارة من سجيل﴾</span>. قال: على أهل بواديهم، وعلى رعائهم، وعلى مسافرهم، فلم يبق منهم أحد{6}. (٨/٩٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٦٠٧٧<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span> -من طريق جعفر- قال: فمَضَتِ الرُّسُلُ مِن عند إبراهيم إلى لوط، فلمّا أتوا لوطًا -وكان مِن أمرهم ما ذكر الله- قال جبريل للوط: يا لوط، <span class="qpc-hafs">﴿إنا مهلكو أهل هذه القرية إن أهلها كانوا ظالمين﴾</span> [العنكبوت:٣١]. فقال لهم لوط: أهلِكوهم الساعةَ. فقال له جبريل ﵇: <span class="qpc-hafs">﴿إن موعدهم الصبح أليس الصبح بقريب﴾</span>؟ فأنزلت على لوط: <span class="qpc-hafs">﴿أليس الصبح بقريب﴾</span>؟ قال: فأمره أن يسري بأهله بقطع من الليل، ولا يلتفت منهم أحد إلا امرأته. قال: فسار، فلمّا كانت الساعة التي أهلكوا فيها أدخل جبريل جناحَه، فرفعها حتى سمع أهل السماء صياح الديكة، ونُباح الكلاب، فجعل عاليها سافلها، وأمطر عليها حجارة من سجيل. قال: وسمعت امرأةُ لوط الهَدَّةَ{7}، فقالت: واقوماه. فأدركها حجرٌ، فقتلها{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٦٠٧٨<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد بن بشير- قال: انطلقت امرأتُه -يعني: امرأة لوط- حين رأتهم -يعني: حين رأت الرسل- إلى قومها، فقالت: إنّه قد ضافه الليلةَ قومٌ ما رأيت مثلَهم قطُّ أحسنَ وجوهًا، ولا أطيب ريحًا. فجاءوا يُهْرَعون إليه، فبادرهم لوطٌ إلى أن يَزْحَمَهم على الباب، فقال: <span class="qpc-hafs">﴿هؤلاء بناتي إن كنتم فاعلين﴾</span> [الحجر:٧١]. فقالوا: <span class="qpc-hafs">﴿أولم ننهك عن العالمين﴾</span> [الحجر:٧٠]. فدخلوا على الملائكة، فتناولتهم الملائكة، وطمست أعينهم، فقالوا: يا لوطُ، جئتنا بقومٍ سَحَرَةٍ سحرونا، كما أنت حتى تُصْبِح. قال: فاحتمل جبريل قُرَيّات لوط الأربع، في كل قرية مائة ألف، فرفعهم على جناحه بين السماء والأرض، حتى سمع أهل السماء الدنيا أصوات دِيَكَتِهم، ثم قَلَبَهم، فجعل الله عاليها سافلها{9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٦٠٧٩<span class="dash">-</span></span> عن <span class="name-2">محمد بن كعب القرظي</span> -من طريق محمد بن إسحاق- قال: إنّ الرُّسُلَ عند ذلك سَفَعُوا{10} في وجوه القوم الذين جاءوا لوطًا من قومه يُراوِدُونه عن ضيفه، فرجعوا عُمْيانًا. قال: يقول الله: <span class="qpc-hafs">﴿ولقد راودوه عن ضيفه فطمسنا أعينهم﴾</span> [القمر:٣٧]{11}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٦٠٨٠<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- قال: لَمّا قال لوط: <span class="qpc-hafs">﴿لو أن لي بكم قوة أو آوي إلى ركن شديد﴾</span> بسط حينئذٍ جبريلُ ﵇ جناحيه، ففقأ أعينَهم، وخرجوا يدوسُ بعضُهم في أدبار بعض عميانًا، يقولون: النَّجاءَ النَّجاءَ؛ فإنّ في بيت لوط أسْحَرَ قومٍ في الأرض. فذلك قوله: <span class="qpc-hafs">﴿ولقد راودوه عن ضيفه فطمسنا أعينهم﴾</span> [القمر:٣٧]. وقالوا للوط: <span class="qpc-hafs">﴿إنا رسل ربك لن يصلوا إليك فأسر بأهلك بقطع من الليل ولا يلتفت منكم أحد إلا امرأتك إنه مصيبها﴾</span>، واتبع أدبار أهلك، يقول: سر بهم، <span class="qpc-hafs">﴿وامضوا حيث تؤمرون﴾</span> [الحجر:٦٥]، فأخرجهم الله إلى الشام، وقال لوط: أهلِكُوهم الساعة. فقالوا: إنا لم نؤمر إلا بالصبح، أليس الصبح بقريب؟ فلمّا أن كان السَّحَر خرج لوطٌ وأهلُه مَعَه{12} امرأتُه، فذلك قوله: <span class="qpc-hafs">﴿إلا آل لوط نجيناهم بسحر﴾</span> [القمر:٣٤]{13}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٦٠٨١<span class="dash">-</span></span> عن <span class="name-3">شمر بن عطية</span> -من طريق حفص بن حميد- قال: كان لوطٌ أخَذ على امرأته أن لا تُذِيع شيئًا مِن سِرِّ أضيافه. قال: فلمّا دخل عليه جبريل ومَن معه رَأَتْهم في صورةٍ لم تر مثلَها قطُّ، فانطلقت تسعى إلى قومها، فأتت الناديَ، فقالت بيدها هكذا، وأقبلوا يُهْرَعون مشيًا بين الهرولة والجَمْزِ، فلمّا انتهوا إلى لوط، وقال لهم لوطٌ ما قال الله في كتابه، قال جبريل: <span class="qpc-hafs">﴿يا لوط إنا رسل ربك لن يصلوا إليك﴾</span>. قال: فقال بيده، فطَمَس أعينهم، فجعلوا يطلبونهم، يَلْمَسون الحيطان، وهم لا يُبْصِرون{14}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٦٠٨٢<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿قالُوا يا لُوطُ﴾</span> قال جبريل للوط: <span class="qpc-hafs">﴿إنّا رُسُلُ رَبِّكَ لَنْ يَصِلُوا إلَيْكَ﴾</span> بسوءٍ. لأنهم قالوا للوط: إنّا نرى معك رجالًا سحروا أبصارنا، فستعلم غدًا ما تلقى أنتَ في أهلك. فقال جبريل ﵇: <span class="qpc-hafs">﴿إنّا رُسُلُ رَبِّكَ لَنْ يَصِلُوا إلَيْكَ﴾</span>{15}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٦٠٨٣<span class="dash">-</span></span> عن <span class="name-3">محمد بن إسحاق</span> -من طريق سلمة- قال: لَمّا قال لوطٌ لقومه: <span class="qpc-hafs">﴿لو أن لي بكم قوة أو آوي إلى ركن شديد﴾</span> والرسل تسمع ما يقول، وما يُقال له، ويرون ما هو فيه مِن كَرْبِ ذلك، فلمّا رأوا ما بلغه؛ <span class="qpc-hafs">﴿قالوا يا لوط إنا رسل ربك لن يصلوا إليك﴾</span> أي: بشيء تكرهه{16}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٦٠٨٤<span class="dash">-</span></span> قال <span class="name-3">سفيان الثوري</span>: لما جاء الرسل إلى لوط تبعهم أهل قريته، وكان لهم جمال، فلم يقولوا لهم شيئًا، فلما دخلوا على لوطٍ، ورأوا مَوْجِدَةَ{17} لوط عليهم، وما قد دخله مِن خَشْيَتِهم؛ قالوا: <span class="qpc-hafs">﴿إنا رسل ربك لن يصلوا إليك﴾</span>. فلما دنوا أخذوا التراب، فرموهم به، ففَقَئُوا أعينَهم، فذلك قوله: <span class="qpc-hafs">﴿فطمسنا أعينهم﴾</span>، فرجعوا إلى أصحابهم وهم يقولون: سِحْرٌ سحرونا. فقال لوط للرُّسُل: الآنَ الآنَ. يعني: هلاكهم، فقالوا: <span class="qpc-hafs">﴿إن موعدهم الصبح﴾</span> -فقال <span class="name-1">ابن عباس</span>: ثلاثة أحرف في القرآن لا يحفظون{18}، ألا ترى أنّه قول الله: <span class="qpc-hafs">﴿أليس الصبح بقريب﴾</span>، والحرفان الآخران، ثم أتبعهم <span class="qpc-hafs">﴿إن الملوك إذا دخلوا قرية أفسدوها وجعلوا أعزة أهلها أذله﴾</span> قال الله: <span class="qpc-hafs">﴿وكذلك يفعلون﴾</span> [النمل:٣٤]. وقول ليوسف: <span class="qpc-hafs">﴿ليعلم أني لم أخنه بالغيب وأن الله لا يهدي كيد الخائنين﴾</span> فقال له مَلَكٌ مِن الملائكة: ولا حين هممت قال: <span class="qpc-hafs">﴿وما أبرئ نفسي﴾</span> [يوسف:٥٢] فرجع.- فرفع جبريل ﵇ القريةَ بجناحه، فدَحْدَها{19} وما فيها، حتى أسمع أهل السماء الدنيا أصواتهم، ثم قلبها، ثُمَّ تتبع مَن شَذَّ منهم بالحجارة{20}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿فَأَسۡرِ بِأَهۡلِكَ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٦٠٨٥<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- في قوله: <span class="qpc-hafs">﴿فأسر بأهلك﴾</span>، يقول: سِرْ بهم{21}. (٨/١١٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٦٠٨٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فَأَسْرِ بِأَهْلِكَ﴾</span>، يعني: امرأته، وابنتيه{22}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿بِقِطۡعࣲ مِّنَ ٱلَّیۡلِ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٦٠٨٧<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق ابن جُرَيْج- في قوله: <span class="qpc-hafs">﴿بقطع من الليل﴾</span>، قال: جوف الليل{23}. (٨/١١٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٦٠٨٨<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- في قوله: <span class="qpc-hafs">﴿بقطع﴾</span>، قال: سواد مِن الليل{24}. (٨/١١٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٦٠٨٩<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق علي- في قوله: <span class="qpc-hafs">﴿بقطع من الليل﴾</span>: بطائفة مِن الليل{25}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٦٠٩٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>: أنّ نافع بن الأزرق قال له: أخبِرني عن قول الله: <span class="qpc-hafs">﴿فأسر بأهلك بقطع من الليل﴾</span>، ما القِطْع؟ قال: آخِر الليلُ سَحَر، قال مالك بن كنانة:</p><p>ونائحة تقوم بقطع ليل على رجُل أهانته شَعُوب{26}{27}. (٨/١١٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٦٠٩١<span class="dash">-</span></span> قال <span class="name-2">الضحاك بن مزاحم</span>، في قوله: <span class="qpc-hafs">﴿بقطع من الليل﴾</span>: ببَقِيَّة{28}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٦٠٩٢<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- في قوله: <span class="qpc-hafs">﴿بقطع من الليل﴾</span>، قال: بطائِفَة من الليل{29}. (٨/١١٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٦٠٩٣<span class="dash">-</span></span> قال <span class="name-2">قتادة بن دعامة</span>، في قوله: <span class="qpc-hafs">﴿بقطع من الليل﴾</span>: بعد مُضِيِّ أوله{28}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٦٠٩٤<span class="dash">-</span></span> قال <span class="name-2">قتادة بن دعامة</span>، في قوله: <span class="qpc-hafs">﴿فأسر بأهلك بقطع من الليل﴾</span>: أي: سِرْ بهم في ظُلْمَةٍ مِن الليل{31}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٦٠٩٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿بِقِطْعٍ مِنَ اللَّيْلِ﴾</span>، يعني: ببعض الليل{22}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٦٠٩٦<span class="dash">-</span></span> عن <span class="name-3">أبي صخر [حميد بن زياد]</span>-من طريق المفضل بن فضالة- في قوله: <span class="qpc-hafs">﴿فأسر بأهلك بقطع من الليل﴾</span>، قال: السَّحَر الأول{21}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَلَا یَلۡتَفِتۡ مِنكُمۡ أَحَدٌ إِلَّا ٱمۡرَأَتَكَۖ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٦٠٩٧<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق الضحاك- في قوله: <span class="qpc-hafs">﴿ولا يلتفت منكم أحد﴾</span>، قال: لا يَتَخَلَّف{21}<span class=comment-ref>٣٢٦٤</span>. (٨/١١٨)</p></p><p></div></p><p><div><span class=comment-ref>٣٢٦٤</span> <span class="comment-type-3">استظهر</span> <u>ابنُ عطية</u> (٤/٦٢٥) في <span class="qpc-hafs">﴿يلتفت﴾</span> أنّها مِن التفات البصر، ثم نقل عن فرقة في قوله تعالى: <span class="qpc-hafs">﴿يَلْتَفِتْ﴾</span>: أنها «من لَفَتَ الشيء يلفته إذا ثَناه ولواه، والمعنى: ولا يَتَثَبَّط». ثم <span class="comment-type-2">استدرك</span> على قولهم قائلًا: «وهذا شاذٌّ مع صِحَّته».</div></p><p><div></p><p><p><span class="item-no">٣٦٠٩٨<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن جُرَيْج- في قوله: <span class="qpc-hafs">﴿ولا يلتفت منكم أحد﴾</span>، قال: لا ينظر وراءَه أحدٌ{35}. (٨/١١٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٦٠٩٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ولا يَلْتَفِتْ مِنكُمْ أحَدٌ﴾</span> ألْبَتَّة <span class="qpc-hafs">﴿إلّا امْرَأَتَكَ﴾</span> فإنها تلتفت، يقول: لا ينظر منكم أحدٌ وراءَه. ثم استثنى: <span class="qpc-hafs">﴿إلّا امْرَأَتَكَ﴾</span> تلتفت{15}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿إِنَّهُۥ مُصِیبُهَا مَاۤ أَصَابَهُمۡۚ إِنَّ مَوۡعِدَهُمُ ٱلصُّبۡحُۚ أَلَیۡسَ ٱلصُّبۡحُ بِقَرِیبࣲ ۝٨١﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٣٦١٠٠<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span> -من طريق جعفر- قال: قال له لوط: أهلِكوهم الساعةَ. قال له جبريل ﵇: إنّ موعدهم الصبح، أليس الصبح بقريب؟! فأُنزِلت على لوط: <span class="qpc-hafs">﴿أليس الصبح بقريب﴾</span>. قال: فأمره أن يسري بأهله بقِطْع من الليل، ولا يلتفت منهم أحد إلا امرأته، فسار، فلمّا كانت الساعةُ التي أُهلِكوا فيها أدْخَلَ جبريلُ ﵇ جناحه، فرفعها حتى سمع أهل السماء صياح الديكة ونباح الكلاب، فجعل عاليَها سافلها، وأمطر عليها حجارة من سجيل، وسمعت امرأة لوطٍ الهدَّة، فقالت: واقوماه! فأدركها حجرٌ فقتلها{37}. (٨/١١٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٦١٠١<span class="dash">-</span></span> قال <span class="name-2">قتادة بن دعامة</span>، في قوله: <span class="qpc-hafs">﴿يا لوط إنا رسل ربك لن يصلوا إليك فأسر بأهلك بقطع من الليل﴾</span> أي: سر بهم في ظُلْمَةٍ من الليل، <span class="qpc-hafs">﴿ولا يلتفت منكم أحد إلا امرأتك إنه مصيبها ما أصابهم﴾</span> فقال: لا؛ بل أهلكوهم الساعةَ! فقالوا: <span class="qpc-hafs">﴿إن موعدهم الصبح أليس الصبح بقريب﴾</span>. فطمس جبريلُ ﵇ أعينَهم بأحد جناحيه، فبقوا ليلتهم لا يُبْصِرون{31}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٦١٠٢<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- قال: ذُكِر لنا: أنّها كانت مع لوط لَمّا خرج مِن القرية، فسمعت الصوتَ، فالتَفَتَتْ، فأرسل اللهُ عليها حجرًا، فأهلكها، فهي معلوم مكانُها شاذَّةً عن القوم، وهي في مصحف <span class="name-1">عبد الله [بن مسعود]</span>: (ولَقَدْ وفَيْنَآ إلَيْهِ أهْلَهُ كُلَّهُمْ إلّا عَجُوزًا فِي الغبر). قال: ولَمّا قيل له: <span class="qpc-hafs">﴿إن موعدهم الصبح﴾</span>. قال: إنِّي أريد أعجَلَ من ذلك. قال: <span class="qpc-hafs">﴿أليس الصبح بقريب﴾</span>{39}. (٨/١١٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٦١٠٣<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- قال: قال لوط: أهلِكوهم الساعةَ. قالوا: إنّا لم نؤمر إلا بالصبح، <span class="qpc-hafs">﴿أليس الصبح بقريب﴾</span>؟!{40}. (٨/١١٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٦١٠٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿إنَّهُ مُصِيبُها﴾</span> مِن العذاب <span class="qpc-hafs">﴿ما أصابَهُمْ﴾</span> يعني: قوم لوط، فالتَفَتَتْ، فأصابها حجرٌ، فقتلها. ثم قال: <span class="qpc-hafs">﴿إنَّ مَوْعِدَهُمُ الصُّبْحُ﴾</span> ثم يهلكون، قال لوط لجبريل: عَجِّل عَلَيَّ بهلاكهم الآنَ. فردَّ عليه جبريل: <span class="qpc-hafs">﴿ألَيْسَ الصُّبْحُ بِقَرِيبٍ﴾</span>؟!{15}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٣٦١٠٥<span class="dash">-</span></span> عن <span class="name-3">محمد بن إسحاق</span> -من طريق سلمة- <span class="qpc-hafs">﴿إن موعدهم الصبح أليس الصبح بقريب﴾</span>، أي: إنّما ينزل بهم العذابُ مِن صبح ليلتِك هذه، فامضِ لِما تُؤْمَر{42}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ١٢/٥٢٥، وابن أبي داود في المصاحف ١/٣١٩. وعزاه السيوطي إلى أبي عبيد.</p><p>(فَأَسْرِ بِأَهْلِكَ بِقِطْعٍ مِّنَ الَّليْلِ إلّا امْرَأَتَكَ) بحذف <span class="qpc-hafs">﴿ولا يلتفت منكم أحد﴾</span> قراءة شاذة.</p><p><span class="qpc-hafs">﴿إلّا امْرَأَتَكَ﴾</span> بالنصب قراءة متواترة، قرأ بها العشرة ما عدا ابن كثير، وأبا عمرو، وهما قرآ بالرفع. انظر: النشر ٢/٢٩٠، والإتحاف ص٣٢٥.أخرجه ابن أبي حاتم ٦/٢٠٦٠ (١١٠٥٠)، ٦/٢٠٦٦ (١١٠٩١)، ٩/٣٠٥٧ (١٧٢٨٥).التَّخْمُ: مُنتهى كل قرية أو أرض. لسان العرب (تَخَمَ).الثَّرى: التُّراب. النهاية (ثرا).أخرجه ابن عساكر ٥٠/٣١٣. وعزاه السيوطي إلى إسحاق بن بشر.أخرجه ابن أبي الدنيا في كتاب العقوبات -موسوعة الإمام ابن أبي الدنيا ٤/٤٦٤ (١٤٩)-. وعزاه السيوطي إلى عبد الله بن أحمد في زوائد الزهد.الهَدَّة: صوت شديد تسمعه من سقوط ركن أو حائط أو ناحية جبل. لسان العرب (هدد).أخرجه ابن جرير ١٢/٥١٥.أخرجه ابن جرير ١٢/٥١٧.أي: لطموا. لسان العرب (سفع).أخرجه ابن جرير ١٢/٥٢٣.ذكر محققو تفسير ابن جرير أن بعده في تاريخ ابن جرير: «إلا».أخرجه ابن جرير ١٢/٥١٩.أخرجه ابن جرير ١٢/٥١٦، وابن أبي حاتم ٦/٢٠٦٢.تفسير مقاتل بن سليمان ٢/٢٩٢-٢٩٣.أخرجه ابن جرير ١٢/٥٢٣، وابن أبي حاتم ٦/٢٠٦٥ مختصرًا.أي: غضب. النهاية (وجد).كذا في المطبوع، وظاهرٌ ما في الأثر من سقط أو تصحيف. ومراد ابن عباس هنا الموصول لفظًا المفصول معنى. ينظر: الإتقان ١/ ٣٠٩.ذكر محقق المصدر أنها كذا بالأصل.تفسير سفيان الثوري ص١٣١-١٣٢.أخرجه ابن أبي حاتم ٦/٢٠٦٥.تفسير مقاتل بن سليمان ٢/٢٩٣.أخرجه ابن جرير ١٢/٥٢٤. وعزاه السيوطي إلى ابن المنذر، وأبي الشيخ.أخرجه ابن أبي حاتم ٦/٢٠٦٥. وعزاه السيوطي إلى ابن جرير، وابن المنذر. ولفظ ابن جرير ما سيأتي.أخرجه ابن جرير ١٢/٥٢٤.شَعُوب: من أسماء المنية. النهاية (شعب).عزاه السيوطي إلى ابن الأنباري في الوقف والابتداء.تفسير البغوي ٤/١٩٣.أخرجه عبد الرزاق ١/٣٠٩، وابن جرير ١٢/٥٢٤.تفسير البغوي ٤/١٩٣.ذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٢/٣٠٢-.تفسير مقاتل بن سليمان ٢/٢٩٣.أخرجه ابن أبي حاتم ٦/٢٠٦٥.أخرجه ابن أبي حاتم ٦/٢٠٦٥.أخرجه ابن جرير ١٢/٥٢٤، وابن أبي حاتم ٦/٢٠٦٦. وعزاه السيوطي إلى ابن المنذر.تفسير مقاتل بن سليمان ٢/٢٩٢-٢٩٣.أخرجه ابن جرير في التفسير ١٢/٥١٥-٥١٦، وفي التاريخ ١/٣٠١، وابن أبي حاتم ٦/٢٠٦٧ مختصرًا. وعزاه السيوطي إلى ابن المنذر.ذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٢/٣٠٢-.أخرجه ابن أبي حاتم ٦/٢٠٦٦ وليس فيه قراءة ابن مسعود. وعزاه السيوطي إلى أبي الشيخ.</p><p>وقراءة ابن مسعود شاذة.أخرجه ابن جرير ١٢/٥١٩، وابن أبي حاتم ٦/٢٠٦٧.تفسير مقاتل بن سليمان ٢/٢٩٢-٢٩٣.أخرجه ابن جرير ١٢/٥٢٣، وابن أبي حاتم ٦/٢٠٦٧.