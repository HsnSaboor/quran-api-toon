quran[10]{c,v,t}:
11,72," <q>﴿ءَأَلِدُ وَأَنَا۠ عَجُوزࣱ﴾</q> - تفسير ٣٥٩١٧- قال مجاهد بن جبر، في قوله: <q>﴿أألد وأنا عجوز﴾</q>: كانت لِتسع وتسعين سنة{1}. (ز) ٣٥٩١٨- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿ءألد وأنا عجوز وهذا بعلي شيخًا﴾</q>، قال: وهي يومئذ ابنة سبعين{2}. (٨/١٠٢) ٣٥٩١٩- عن محمد بن إسحاق -من طريق سلمة- قال: ذكر أبي، عن بعض مَن قرأ الكتاب: أنّها كانت بنت تسعين سنة{3}٣٢٥١. (ز) ٣٢٥١ ذكر ابنُ عطية (٤/٦١٣) بعض الأقوال في سِنِّ سارة وإبراهيم ﵇ ساعة هذه المقالة، واستدرك عليها، فقال: «ورُوِي أنّ سارة كانت وقت هذه المقالة مِن تسع وتسعين سنة. وقيل: من تسعين. قاله ابن إسحاق. وقيل: من ثمانين. وكذلك قيل في إبراهيم ﵇: إنه كان مائة وعشرين سنة. وقيل: مائة سنة. وغير ذلك مما يحتاج إلى سند». ٣٥٩٢٠- قال مقاتل بن سليمان: <q>﴿قالَتْ﴾</q> سارة: <q>﴿يا ويْلَتى أأَلِدُ وأَنا عَجُوزٌ﴾</q>{4}. (ز) <q>﴿وَهَـٰذَا بَعۡلِی﴾</q> - تفسير ٣٥٩٢١- عن أبي مالك غزوان الغفاري -من طريق السدي- في قوله: <q>﴿بعلي﴾</q>، قال: زَوْجي{5}. (٨/١٠٢) <q>﴿وَهَـٰذَا بَعۡلِی شَیۡخًاۖ﴾</q> - قراءات ٣٥٩٢٢- عن الأعمش: في قراءة عبد الله [بن مسعود]: (وهَذا بَعْلِي شَيْخٌ) بالرفع{6}. (ز) <q>﴿وَهَـٰذَا بَعۡلِی شَیۡخًاۖ﴾</q> - تفسير الآية ٣٥٩٢٣- قال مجاهد بن جبر، في قوله: <q>﴿وهذا بعلي شيخا﴾</q>: كان سِنُّ إبراهيم مائةَ سنة{1}. (ز) ٣٥٩٢٤- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿ءألد وأنا عجوز وهذا بعلي شيخًا﴾</q>، قال: وهي يومئذ ابنةُ سبعين، وهو يومئذ ابن تسعين سنة{2}. (٨/١٠٢) ٣٥٩٢٥- عن ضرار بن مُرَّة، عن شيخ مِن أهل المسجد، قال: بُشِّر إبراهيم بعد سبع عشرة ومائة سنة{9}. (٨/١٠٢) ٣٥٩٢٦- قال مقاتل بن سليمان: <q>﴿وهَذا بَعْلِي شَيْخًا﴾</q>، وهو ابن سبعين سنة{4}. (ز) ٣٥٩٢٧- عن محمد بن إسحاق -من طريق سلمة- ذكر لي، عن بعض مَن قرأ الكتاب، <q>﴿وهذا بعلي شيخا﴾</q>: أنّ إبراهيم ابن عشرين ومائة سنة{3}. (ز) <q>﴿إِنَّ هَـٰذَا لَشَیۡءٌ عَجِیبࣱ ۝٧٢﴾</q> - تفسير ٣٥٩٢٨- قال مقاتل بن سليمان: <q>﴿إنَّ هَذا لَشَيْءٌ عَجِيبٌ﴾</q>، يعني: لَأَمْرٌ عجيب أن يكون الولدُ مِن الشيخين الكبيرين{4}. (ز) ",footnotes:1:تفسير الثعلبي ٥/١٧٩، وتفسير البغوي ٤/١٨٩.أخرجه ابن أبي حاتم ٦/٢٠٥٦. وعزاه السيوطي إلى أبي الشيخ.أخرجه ابن جرير ١٢/٤٨٤، وابن أبي حاتم ٦/٢٠٥٦.تفسير مقاتل بن سليمان ٢/٢٩١.أخرجه ابن أبي حاتم ٦/٢٠٥٦.أخرجه ابن أبي داود في المصاحف ١/٣١٩. وهي قراءة شاذة، تروى عن الأعمش أيضًا. انظر: مختصر ابن خالويه ص٦٥، والمحتسب ١/٣٢٤.تفسير الثعلبي ٥/١٧٩، وتفسير البغوي ٤/١٨٩.أخرجه ابن أبي حاتم ٦/٢٠٥٦. وعزاه السيوطي إلى أبي الشيخ.عزاه السيوطي إلى أبي الشيخ.تفسير مقاتل بن سليمان ٢/٢٩١.أخرجه ابن جرير ١٢/٤٨٤، وابن أبي حاتم ٦/٢٠٥٦.تفسير مقاتل بن سليمان ٢/٢٩١.
11,73," <q>﴿قَالُوۤا۟ أَتَعۡجَبِینَ مِنۡ أَمۡرِ ٱللَّهِۖ رَحۡمَتُ ٱللَّهِ وَبَرَكَـٰتُهُۥ عَلَیۡكُمۡ أَهۡلَ ٱلۡبَیۡتِۚ إِنَّهُۥ حَمِیدࣱ مَّجِیدࣱ ۝٧٣﴾</q> - تفسير ٣٥٩٢٩- عن وهب بن مُنَبِّه -من طريق عبد الصمد- قال: لَمّا أتى الملائكةُ إبراهيمَ ﵇ فرآهم راعه هيئتُهم وجمالهم، فسلَّموا عليه، وجلسوا إليه، فقام فأَمَر بعجل سمين، فحُنِذ له، فقَرَّب إليهم الطعام، فلمّا رأى أيديهم لا تصل إليه نكرهم، وأوجس منهم خيفة، وسارة وراء البيت تسمع، قالوا: لا تخف، إنّا نبشرك بغلام حليم مبارك. وبشَّر به امرأتَه سارة، فضحِكت، وعجِبَت، كيف يكون لي ولد وأنا عجوز وهو شيخ كبير؟! فقالوا: لا تعجبي مِن أمر الله؛ فإنّه قادِرٌ على ما يشاء، فقد وهبه الله لكم، فأبشِروا به{1}. (ز) ٣٥٩٣٠- عن زيد بن علي، قال: قالت سارة لَمّا بَشَّرَتْها الملائكةُ ﵈: <q>﴿يا ويلتى ءألد وأنا عجوز وهذا بعلي شيخًا إن هذا لشيء عجيب﴾</q>. فقالت الملائكة ترُدُّ على سارة: <q>﴿أتعجبين من أمر الله رحمت الله وبركاته عليكم أهل البيت إنه حميد مجيد﴾</q>. قال: فهو كقوله: <q>﴿وجعلها كلمة باقية في عقبه﴾</q> [الزخرف:٢٨]، فمحمد ﷺ وآله مِن عَقِب إبراهيم{2}. (٨/١٠٢) ٣٥٩٣١- عن ضمرة بن حبيب -من طريق أبي بكر بن مريم-: أنّ سارة لَمّا بشَّرها الرُّسُل بإسحاق قال: بينما هي تمشي وتُحَدِّثُهم آنَسَتْ بالحيضة، فحاضَتْ قبل أن تحمِل بإسحاق، فكان مِن قولها للرسل حين بشَّروها: قد كنت شابَّةً وكان إبراهيمُ شابّا فلم أحبل، فحين كبِرت وكبر أأَلِدُ؟ قالوا: أتعجبين مِن ذلك، يا سارة؟ فإنّ الله قد صنع بكم ما هو أعظم من ذلك؛ إنّ الله قد جعل رحمته وبركاته عليكم أهل البيت، إنّه حميد مجيد{3}. (٨/١٠١) ٣٥٩٣٢- قال مقاتل بن سليمان: <q>﴿قالُوا﴾</q> قال جبريل لها: <q>﴿أتَعْجَبِينَ مِن أمْرِ اللَّهِ﴾</q> أن يخلق ولدًا مِن الشيخين، <q>﴿رَحْمَتُ اللَّهِ وبَرَكاتُهُ﴾</q> يعني: نعمة الله وبركاته <q>﴿عَلَيْكُمْ أهْلَ البَيْتِ﴾</q> يعني بالبركة: ما جعل اللهُ مِنهم مِن الذرية، <q>﴿إنَّهُ حَمِيدٌ﴾</q> في خلقه، <q>﴿مَجِيدٌ﴾</q> يعني: كريم{4}٣٢٥٢. (ز) ٣٢٥٢ ذكر ابنُ عطية (٤/٦١٣) أنّ قوله: <q>﴿مِن أمْرِ اللَّهِ﴾</q> يحتمل احتمالين: الأول: أن يريد واحدَ الأمور، أي: مِن الولادة في هذه السن. الثاني: أن يريد: مصدر أمر، أي: مما أمر الله في هذه النازلة. <q>﴿قَالُوۤا۟ أَتَعۡجَبِینَ مِنۡ أَمۡرِ ٱللَّهِۖ رَحۡمَتُ ٱللَّهِ وَبَرَكَـٰتُهُۥ عَلَیۡكُمۡ أَهۡلَ ٱلۡبَیۡتِۚ إِنَّهُۥ حَمِیدࣱ مَّجِیدࣱ ۝٧٣﴾</q> - آثار متعلقة بالآية ٣٥٩٣٣- عن زينب بنت أبي سلمة: أنّ رسول الله ﷺ كان عند أُمِّ سلمة، فحمل حَسَنًا مِن شِقٍّ، وحُسَيْنًا مِن شِقٍّ، وفاطمة في حِجْرِه، فقال: <q>﴿رَحْمَتُ اللَّهِ وبَرَكاتُهُ عَلَيْكُمْ أهْلَ البَيْتِ إنَّهُ حَمِيدٌ مَجِيدٌ﴾</q>{5}. (ز) ٣٥٩٣٤- عن عطاء بن أبي رباح، في قوله: <q>﴿رحمت الله وبركاته عليكم أهل البيت﴾</q>، قال: كنت عند ابن عباس، إذ جاءه رجلٌ، فسلَّم عليه، فقلت: وعليكم السلام ورحمة الله وبركاته ومغفرته. فقال ابن عباس: انتهِ إلى ما انتهت إليه الملائكة. ثم تلا: <q>﴿رحمت الله وبركاته عليكم أهل البيت﴾</q>{6}. (٨/١٠٢) ٣٥٩٣٥- عن عبد الله بن عباس -من طريق محمد بن عطاء-: أنّ سائلًا قام على الباب وهو عند ميمونة، فقال: السلام عليكم أهل البيت ورحمة الله وبركاته ومغفرته. فقال ابنُ عباس: انتهوا بالتحية إلى ما قال الله: <q>﴿رحمت الله وبركاته﴾</q>{7}. (٨/١٠٣) ٣٥٩٣٦- عن عطاء، قال: كنتُ عند ابن عباس، فجاء سائلٌ، فقال: السلام عليكم ورحمة الله وبركاته ومغفرته ورضوانه. فقال ابن عباس: ما هذا السلام؟ -وغَضِبَ حتى احْمَرَّت وجنتاه- إنّ الله حدَّ السلام حدًّا، ثم انتهى ونهى عمّا وراء ذلك. ثم قرأ: <q>﴿رحمت الله وبركاته عليكم أهل البيت إنه حميد مجيد﴾</q>{8}. (٨/١٠٣) ٣٥٩٣٧- عن عبد الله بن عمر -من طريق عبد الله بن بابَيْهِ- أنّ رجلًا قال له: سلامٌ عليك ورحمة الله وبركاته ومغفرته. فانتَهَرَهُ ابنُ عمر، وقال: حسبُك إذا انتهيت إلى «وبركاته»؛ إلى ما قال الله{9}. (٨/١٠٣) ",footnotes:1:أخرجه ابن جرير ١٢/٤٧٥.عزاه السيوطي إلى أبي الشيخ.أخرجه ابن أبي حاتم ٦/٢٠٥٥-٢٠٥٦.تفسير مقاتل بن سليمان ٢/٢٩١.أخرجه الطبراني في الأوسط ٨/١١٧ (٨١٤١).أخرجه ابن أبي حاتم ٦/٢٠٥٧، والحاكم ٢/٣٤٤، والبيهقي في شعب الإيمان (٨٨٧٧). وعزاه السيوطي إلى ابن المنذر.أخرجه البيهقي في شعب الإيمان (٨٨٧٨، ٨٨٧٩) بنحوه.أخرجه البيهقي في شعب الإيمان (٨٨٧٨). وعزاه السيوطي إلى أبي الشيخ.أخرجه البيهقي في شعب الإيمان (٨٨٨٠).
11,74," <q>﴿فَلَمَّا ذَهَبَ عَنۡ إِبۡرَ ٰ⁠هِیمَ ٱلرَّوۡعُ﴾</q> - تفسير ٣٥٩٣٨- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿فلما ذهب عن إبراهيم الروع﴾</q>، قال: الفَرَق{1}. (٨/١٠٤) ٣٥٩٣٩- عن قتادة بن دعامة -من طريق سعيد- <q>﴿فلما ذهب عن إبراهيم الروع﴾</q>، قال: الخوف{2}. (٨/١٠٤) ٣٥٩٤٠- قال مقاتل بن سليمان: <q>﴿فَلَمّا ذَهَبَ عَنْ إبْراهِيمَ الرَّوْعُ﴾</q>، يعني: الخوف{3}. (ز) <q>﴿وَجَاۤءَتۡهُ ٱلۡبُشۡرَىٰ﴾</q> - تفسير ٣٥٩٤١- عن عكرمة مولى ابن عباس -من طريق داود- يعني قوله: <q>﴿البشرى﴾</q>: بَشَّر بنُبُوَّته{4}. (ز) ٣٥٩٤٢- عن قتادة بن دعامة -من طريق سعيد-: <q>﴿وجآءته البشرى﴾</q> بإسحاق{5}. (٨/١٠٤) ٣٥٩٤٣- عن قتادة بن دعامة -من طريق مَعْمَر- في قوله: <q>﴿وجاءته البشرى﴾</q>، قال: حين أخبروه أنّهم أُرْسِلُوا إلى قوم لوط، وأنّهم ليسوا إيّاه يريدون{6}. (٨/١٠٤) ٣٥٩٤٤- قال مقاتل بن سليمان: <q>﴿وجاءَتْهُ البُشْرى﴾</q> في الوَلَد{3}. (ز) ٣٥٩٤٥- عن محمد بن إسحاق -من طريق سلمة-: <q>﴿فلما ذهب عن إبراهيم الروع وجاءته البشرى﴾</q> بإسحاق ويعقوب ولدًا مِن صُلْب إسحاق، وأمِن مِمّا كان يخاف؛ قال: <q>﴿الحمد لله الذي وهب لي على الكبر إسماعيل وإسحاق إن ربي لسميع الدعاء﴾</q> [إبراهيم:٣٩]. وقد قيل: معنى ذلك: وجاءته البشرى أنّهم ليسوا إيّاه يُرِيدون{8}٣٢٥٣. (ز) ٣٢٥٣ ذكر ابنُ عطية (٤/٦١٥) في <q>﴿البشرى﴾</q> احتمالين: الأول: البشرى بالولد. الثاني: البُشرى بأنّ المراد غيره. ثم رجَّح الأول بقوله: «والأوَّل أبْيَن». ولم يذكر مستندًا. <q>﴿یُجَـٰدِلُنَا فِی قَوۡمِ لُوطٍ ۝٧٤﴾</q> - تفسير ٣٥٩٤٦- عن حذيفة بن اليمان -من طريق قتادة- قال: لَمّا أُرْسِلَت الرُّسُل إلى قوم لوط ليُهِلكوهم قيل لهم: لا تُهْلِكوا قومَ لوط حتى يشهد عليهم لوطٌ ثلاث مرات. وكان طريقُهم على إبراهيم خليل الرحمن، قال: <q>﴿فلما ذهب عن إبراهيم الروع وجاءته البشرى يجادلنا في قوم لوط﴾</q>. وكانت مجادلتُه إيّاهم قال: أرأيتُم إن كان فيها خمسون مِن المؤمنين أتُهلكونهم؟ قالوا: لا. قال: فأربعون؟ قالوا: لا. حتى انتهى إلى عشرة أو خمسة{9}. (٨/١١٤) ٣٥٩٤٧- عن عبد الرحمن بن سمرة -من طريق أبي نضرة-: أنّه رأى مِن حَبَشِيَّةٍ شيئًا كَرِهَه، فأنكره، فقال لهم: أتدرون فيكم يكرهون هذا؟ قالوا: نعم. قال: فلله الحمد، إن إبراهيم ﵇ لَمّا جاءت الملائكة فجادلهم في قوم لوط كانوا أربع قريات، في كل قرية مائة ألف مقاتل، فقال لهم: أرأيتم إن كان في هؤلاء مائة يكرهون هذا، أمُهْلِكوهم أنتم؟ قالوا: لا. قال: فتسعون. قال: لا. حتى صار إلى عشرة. قال: أرأيتُم إن كان فيهم عشرةٌ يكرهون هذا أمُهْلِكوهم أنتم؟ قالوا: <q>﴿نحن أعلم بمن فيها لننجينه وأهله إلا امرأته كانت من الغابرين﴾</q> [العنكبوت:٣٢]{10}. (ز) ٣٥٩٤٨- عن عبد الله بن عباس -من طريق سعيد بن جبير- قال: لَمّا جاءت الملائكةُ إلى إبراهيم قالوا لإبراهيم: إن كان فيها خمسةٌ يُصَلُّون رُفِع عنهم العذاب{11}. (٨/١٠٥) ٣٥٩٤٩- عن عبد الله بن عباس -من طريق الضحاك- قال: لَمّا بُشِّر إبراهيم بقول الله <q>﴿فلما ذهب عن إبراهيم الروع وجاءته البشرى﴾</q> بإسحاق، <q>﴿يجادلنا في قوم لوط﴾</q>. وإنّما كان جداله أنّه قال: يا جبريل، أين تريدون؟ وإلى مَن بُعِثتم؟ قال: إلى قوم لوط، وقد أُمِرْنا بعذابهم. فقال إبراهيم: إنّ فيها لوطًا. قالوا: <q>﴿نحن أعلم بمن فيها لننجينه وأهله إلا امرأته﴾</q> [العنكبوت:٣٢]. وكانت -زعموا- تسمّى: والِقَة، فقال إبراهيم: إن كان فيهم مائة مؤمن تعذبونهم؟ قال جبريل: لا. قال: فإن كان فيهم تسعون مؤمنون تعذبونهم؟ قال جبريل: لا. قال: فإن كان فيهم ثمانون مؤمنون تعذبونهم؟ قال جبريل: لا. حتى انتهى في العدد إلى واحد مؤمن، قال جبريل: لا. فلمّا لم يذكروا لإبراهيم أنّ فيها مؤمنًا واحدًا، قال: إنّ فيها لوطًا. قالوا: <q>﴿نحن أعلم بمن فيها لننجينه وأهله إلا امرأته﴾</q> [العنكبوت:٣٢]{12}. (٨/٩٢) ٣٥٩٥٠- عن سعيد بن جبير -من طريق جعفر- في قوله: <q>﴿يجادلنا في قوم لوط﴾</q>. قال: لَمّا جاء جبريل إلى إبراهيم ﵇، وأخبره أنّه مُهلِكُ قومِ لوط؛ قال: أتُهلِك قرية فيها أربعمائة مؤمن؟ قال: لا. قال: فثلاثمائة مؤمن؟ قال: لا. قال: فمِائتا مؤمن؟ قال: لا. قال: فمائة؟ قال: لا. قال: فخمسون مؤمنًا؟ قال: لا. قال: فأربعون مؤمنًا؟ قال: لا. قال: فأربعة عشر مؤمنًا؟ قال: لا. وظنَّ إبراهيمُ أنهم أربعة عشر بامرأة لوط، وكان فيها ثلاثة عشر مؤمنًا، وقد عرف ذلك جبريلُ{13}. (٨/١٠٤) ٣٥٩٥١- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قوله: <q>﴿يجادلنا في قوم لوط﴾</q>، قال: يُخاصِمنا{14}. (٨/١٠٤) ٣٥٩٥٢- عن قتادة بن دعامة -من طريق معمر- في قوله: <q>﴿يُجادلنا في قوم لوط﴾</q>، قال: إنّه قال لهم يومئذ: أرأيتم إن كان فيهم خمسون مِن المسلمين؟ قال: إن كان فيها خمسون لم نُعَذِّبهم. قال: أربعون؟ قال: وأربعون. قال: ثلاثون؟ قال: ثلاثون. حتى بلغوا عشرة، قال: فإن كان فيهم عشرة؟ قال: ما قوم لا يكون فيهم عشرة فيهم خير. قال قتادة: إنّه كان في قرية لوط أربعة آلاف ألف إنسان، أو ما شاء الله من ذلك{15}. (٨/١٠٤) ٣٥٩٥٣- عن إسماعيل السُّدِّيّ -من طريق أسباط-: <q>﴿فلما ذهب عن إبراهيم الروع، وجاءته البشرى﴾</q>؛ <q>﴿قال فما خطبكم أيها المرسلون﴾</q>؟ [الحجر:٥٧] قالوا: إنّا أُرْسِلنا إلى قوم لوط. فجادَلَهم في قوم لوط، قال: أرأيتُم إن كان فيها مائة من المسلمين أتُهْلِكُونهم؟ قالوا: لا. فلم يزل يَحُطُّ حتى بلغ عشرة مِن المسلمين، فقالوا: لا نُعَذِّبهم إن كان فيهم عشرة من المسلمين. ثم قالوا: يا إبراهيم، أعرض عن هذا، إنّه ليس فيها إلا أهل بيت مِن المؤمنين هو لوط وأهل بيته، وهو قول الله ﷿: <q>﴿يجادلنا في قوم لوط﴾</q>. فقالت الملائكة: <q>﴿يا إبراهيم أعرض عن هذا إنه قد جاء أمر ربك وإنهم آتيهم عذاب غير مردود﴾</q>{16}. (ز) ٣٥٩٥٤- عن أبي المثنى، ومسلم أبي حسبة الأشجعي -من طريق صفوان- قالا: <q>﴿فلما ذهب عن إبراهيم الروع﴾</q> إلى آخر الآية. قال إبراهيم: أتُعذب عالما من عالمك كثيرا فيهم مائة رجل يعبدك؟ قال: لا وعزتي، ولا خمسين. قال: فأربعين؟ فثلاثين؟ حتى انتهى إلى خمسة. قال: لا، وعِزَّتي، لا أُعَذِّبهم، ولو كان فيهم خمسة يعبدونني. قال الله ﷿: <q>﴿فما وجدنا فيها غير بيت من المسلمين﴾</q> [الذاريات:٣٦] لوطًا وابنتيه. قال: فحلَّ بهم العذاب، قال الله ﷿: <q>﴿وتركنا فيها آية للذين يخافون العذاب الأليم﴾</q> [الذاريات:٣٧]. وقال: <q>﴿فلما ذهب عن إبراهيم الروع وجاءته البشرى يجادلنا﴾</q>{17}. (ز) ٣٥٩٥٥- قال مقاتل بن سليمان: <q>﴿يُجادِلُنا﴾</q> يعني: يُخاصمنا إبراهيم <q>﴿فِي قَوْمِ لُوطٍ﴾</q> كقوله في الرعد [١٣]: <q>﴿يُجادِلُونَ فِي اللَّهِ﴾</q>، ومثل قوله: <q>﴿قالُوا يا نُوحُ قَدْ جادَلْتَنا فَأَكْثَرْتَ جِدالَنا﴾</q> [هود:٣٢]. وخصومة إبراهيم ﵇ أنّه قال: يا ربِّ، أتهلكهم إن كان في قوم لوط خمسون رجلًا مؤمنين؟ قال جبريل ﵇: لا. فما زال إبراهيم ﵇ ينقص خمسة خمسة حتى انتهى إلى خمسة أبيات{3}. (ز) ٣٥٩٥٦- قال عبد الملك ابن جُرَيْج -من طريق حجّاج- قال إبراهيم: أتهلكونهم إن وجدتم فيها مائة مؤمن؟ ثم تسعين، حتى هبط إلى خمسة. قال: وكان في قرية لوط أربعة آلاف ألف{19}. (ز) ٣٥٩٥٧- عن محمد بن إسحاق -من طريق سلمة- قال: <q>﴿فلما ذهب عن إبراهيم الروع وجاءته البشرى﴾</q>، يعني: إبراهيم، جادل عن قوم لوط لِيَرُدَّ عنهم العذاب. قال: فيزعم أهل التوراة: أنّ مجادلة إبراهيم إيّاهم -حين جادلهم في قوم لوط لِيَرُدَّ عنهم العذاب- إنّما قال للرسل فيما يكلمهم به: أرأيتم إن كان فيهم مائة مؤمن أتهلكونهم؟ قالوا: لا. قال: أفرأيتم إن كانوا تسعين؟ قالوا: لا. قال: أفرأيتم إن كانوا ثمانين؟ قالوا: لا. قال: أفرأيتم إن كانوا سبعين؟ قالوا: لا. قال: أفرأيتم إن كانوا ستين؟ قالوا لا. قال: أفرأيتم إن كانوا خمسين؟ قالوا لا. قال: أفرأيتم إن كان رجلًا واحدًا مسلمًا؟ قالوا: لا. قال: فلمّا لم يذكروا لإبراهيم أنّ فيها مؤمنًا واحدًا قال: <q>﴿إن فيها لوطا﴾</q>. يدفع به عنهم العذاب، <q>﴿قالوا نحن أعلم بمن فيها لننجينه وأهله إلا امرأته كانت من الغابرين﴾</q> [العنكبوت:٣٢]. قالوا: <q>﴿يا إبراهيم أعرض عن هذا إنه قد جاء أمر ربك، وإنهم آتيهم عذاب غير مردود﴾</q>{16}٣٢٥٤. (ز) ٣٢٥٤ ذكر ابنُ عطية (٤/٦١٦) في صورة جدال إبراهيم ﵇ أنها «كانت أن قال إبراهيم ﵇: إن كان فيهم مائة مؤمن أتعذبونهم؟ قالوا لا، قال: أفَتِسْعون؟ قالوا: لا، قال: أفثمانون؟ فلم يزل كذلك حتى بلغ خمسة ووقف عند ذلك، وقد عد في بيت لوط ﵇ امرأته، فوجدهم ستة بها، فطمع في نجاتهم، ولم يشعر أنها من الكفرة، وكان ذلك من إبراهيم ﵇ حرصًا على إيمان تلك الأُمَّة ونجاتها». ثم علَّق بقوله: «وقد كثر اختلاف رواة المفسرين لهذه الأعداد في قول إبراهيم ﵇، والمعنى كله نحو مما ذكرته». ونقل عن فرقة في قوله تعالى: <q>﴿يُجادِلُنا فِي قَوْمِ لُوطٍ﴾</q> أنّ المعنى: «يجادلنا في مؤمني قوم لوط». ثم انتقده قائلًا: «وهذا ضعيف». ٣٥٩٥٨- قال معمر بن راشد -من طريق محمد بن ثور-: بلغنا: أنّه كان في قرية لوطٍ أربعةُ آلاف ألف إنسان، أو ما شاء الله من ذلك{21}. (ز) ",footnotes:1:أخرجه ابن جرير ١٢/٤٨٧، وابن أبي حاتم ٦/٢٠٥٨. وعزاه السيوطي إلى ابن المنذر، وأبي الشيخ.أخرجه ابن جرير ١٢/٤٨٦، وابن أبي حاتم ٦/٢٠٥٧. وعزاه السيوطي إلى ابن المنذر.تفسير مقاتل بن سليمان ٢/٢٩١.أخرجه ابن أبي حاتم ٦/٢٠٥٧.أخرجه ابن جرير ١٢/٤٨٨، وابن أبي حاتم ٦/٢٠٥٧. وعزاه السيوطي إلى ابن المنذر.أخرجه عبد الرزاق ١/٣٠٨-٣٠٩، وابن جرير ١٢/٤٨٦-٤٨٧. وعزاه السيوطي إلى أبي الشيخ.تفسير مقاتل بن سليمان ٢/٢٩١.أخرجه ابن جرير ١٢/٤٨٦.أخرجه عبد الرزاق ١/٣٠٧، وابن جرير ١٢/٤٩٥، ٥١٨، وفي التاريخ ١/٢٨٩، ٢٩٩، ٣٠٣، وابن أبي حاتم ٦/٢٠٦٠ من طريق جندب بن عبد الله. وعزاه السيوطي إلى ابن المنذر.أخرجه ابن أبي حاتم ٦/٢٠٥٨.أخرجه ابن جرير ١٢/٤٨٩-٤٩٠، وفي تاريخه ١/٢٩٨. وعزاه السيوطي إلى ابن المنذر.أخرجه ابن عساكر ٥٠/٣١٠، ٣١٥. وعزاه السيوطي إلى إسحاق بن بشر.أخرجه ابن جرير ١٢/٤٨٩، وابن أبي حاتم ٦/٢٠٥٨.تفسير مجاهد ص٣٨٩، وأخرجه ابن جرير ١٢/٤٨٧-٤٨٨، وابن أبي حاتم ٦/٢٠٥٨. وعزاه السيوطي إلى ابن المنذر، وأبي الشيخ.أخرجه عبد الرزاق ١/٣٠٨-٣٠٩، وابن جرير ١٢/٤٩٠. وذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٢/٣٠٠-. وعزاه السيوطي إلى أبي الشيخ.أخرجه ابن جرير ١٢/٤٩١.أخرجه ابن جرير ١٢/٤٩٢. قال الشيخ شاكر في تحقيقه لتفسير ابن جرير ١٥/٤٠٥: "وأبو المثنى كأنه يعني: مسلم بن المثني الكوفي المؤذن، روى عن ابن عمر، مترجم في التهذيب، والكبير ٤/١/٢٥٦، وابن أبي حاتم ٤/١/١٩٥. وأما أبو الحبيل الأشجعي فلست أجد من يُسَمّى هكذا، وظني أنه قد وقع في هذا الإسناد خطأ، فصوابه عندي: قال: حدثنا أبو المثنى مسلم، والحسيل الأشجعي. والحسيل الأشجعي -فيما أرجح-: الحسيل بن عبد الرحمن الأشجعي، ويقال أيضًا: حسين، روى عن سعد بن أبي وقاص، مترجم في التهذيب، وابن أبي حاتم ١/٢/٥٨. هذا، وفي النفس شيء من حقيقة هذا الإسناد.تفسير مقاتل بن سليمان ٢/٢٩١.أخرجه ابن جرير ١٢/٤٩٢.أخرجه ابن جرير ١٢/٤٩١.أخرجه ابن جرير ١٢/٤٩٠.
11,75," <q>﴿إِنَّ إِبۡرَ ٰ⁠هِیمَ لَحَلِیمٌ﴾</q> - تفسير ٣٥٩٥٩- عن عبد الله بن عباس -من طريق مجاهد- قال: الحِلْمُ يجمع لصاحبه شرفَ الدنيا والآخرة؛ ألم تسمع اللهَ وصَفَ نبيَّه ﷺ بالحِلْم، فقال: <q>﴿إن إبراهيم لحليم أواه منيب﴾</q>{1}. (٨/١٠٥) ٣٥٩٦٠- عن عبد الله بن عباس -من طريق أبي الجَوْزاء- في قوله: <q>﴿إن إبراهيم لحليم أواه منيب﴾</q>، قال: كان مِن حِلْمِه أنّه كان إذا آذاه الرجل من قومه قال له: هداك الله{2}. (ز) ٣٥٩٦١- عن عمرو بن ميمون، قال: الحليم: المُسَبِّح{3}. (٨/١٠٥) ٣٥٩٦٢- عن الحسن البصري -من طريق عبد الوهاب، عن رجل سَمّاه- في قوله: <q>﴿إن إبراهيم لحليم﴾</q>، قال: الحليم: الرَّحيم{2}. (ز) ٣٥٩٦٣- عن يونس، قال: سمعتُ الحسن يقول: ما سمعتُ اللهَ نَحَل عبادَه شيئًا أقلَّ مِن الحِلم؛ فإنّه قال: <q>﴿إنَّ إبْراهِيمَ لَحَلِيمٌ﴾</q>، وقال: <q>﴿فَبَشَّرْناهُ بِغُلامٍ حَلِيمٍ﴾</q> [الصافات:١٠١]{5}. (ز) ٣٥٩٦٤- عن ضمرة بن حبيب، قال: الحِلمُ أرفعُ مِن العَقْل؛ لأنّ الله ﷿ تَسَمّى به{3}. (٨/١٠٥) ٣٥٩٦٥- قال مقاتل بن سليمان: قال تعالى: <q>﴿إنَّ إبْراهِيمَ لَحَلِيمٌ﴾</q>، يعني: لعليم{7}. (ز) <q>﴿أَوَّ ٰ⁠هࣱ﴾</q> - تفسير ٣٥٩٦٦- عن عبد الله بن مسعود -من طريق زِر بن حُبَيْش- في قول الله: <q>﴿إنَّ إبْراهِيمَ لَحَلِيمٌ أوّاهٌ مُنِيبٌ﴾</q>، قال: الأوّاه: الدّعّاءُ{8}. (ز) ٣٥٩٦٧- عن عبد الله بن مسعود -من طريق يزيد بن أبي حبيب-: إنّ الأوّاه عند الله: الرحيم. قال يزيد: يُقال: إنّ الأوّاه الذي إذا ذكر خطيئتَه تَوَجَّع منها، ثُمَّ استغفر ربه{9}. (ز) ٣٥٩٦٨- عن كعب الأحبار -من طريق عبد الله بن رباح- في قوله: <q>﴿إن إبراهيم لحليم أواه﴾</q>، قال: كان إذا ذكر النار قال: أوَّه مِن عذاب الله، أوَّه{10}. (ز) ٣٥٩٦٩- عن عمرو بن ميمون، قال: الأواه: الرحيم. والحليم: المُسَبِّح{3}. (٨/١٠٥) ٣٥٩٧٠- عن مجاهد بن جبر -من طريق أبي يحيى- <q>﴿أواه منيب﴾</q>، قال: القانِت الرَّجّاع{12}٣٢٥٥. (ز) ٣٢٥٥ لم يذكر ابنُ جرير (١٢/٤٩٣) في معنى: <q>﴿أواَّهٌ مُنِيبٌ﴾</q> سوى قول مجاهد بن جبر. ٣٥٩٧١- عن مجاهد بن جبر -من طريق أبي يحيى- <q>﴿أواه﴾</q>، قال: فَقِيه مُوقِن{10}. (ز) ٣٥٩٧٢- عن عامر الشعبي -من طريق زكريا- قال: الأوّاه: المُسَبِّح{10}. (ز) ٣٥٩٧٣- عن عمرو بن دينار: أنّ عبيد بن عمير كان إذا ذكر النار قال: أوَّه أوَّه. وذلك قوله: <q>﴿أواه منيب﴾</q>{15}. (ز) ٣٥٩٧٤- قال مقاتل بن سليمان: <q>﴿أوّاهٌ﴾</q>، يعني: مُوقِن{7}٣٢٥٦. (ز) ٣٢٥٦ ذكر ابنُ عطية (٤/٦١٦) أنّ الأوّاه معناه: الخائِف الذي يُكْثِرُ التَّأَوُّهَ مِن خوف الله تعالى، ثم علَّق بقوله: «وللمفسرين في الأوّاه عباراتٌ، كلها ترجع إلى ما ذكرته، وتلزمه». <q>﴿مُّنِیبࣱ ۝٧٥﴾</q> - تفسير ٣٥٩٧٥- عن عبد الله بن عباس -من طريق الضَّحّاك- قال: المنيب: المُقبِل إلى طاعة الله{10}. (٨/١٠٦) ٣٥٩٧٦- عن مجاهد بن جبر= (ز) ٣٥٩٧٧- وعكرمة مولى ابن عباس -من طريق جابر- قالا: المُنيب: المُخْبِت{10}. (ز) ٣٥٩٧٨- عن الحسن البصري -من طريق عمرو بن عبيد- في قوله: <q>﴿إن إبراهيم لحليم أواه منيب﴾</q>، قال: كان إذا قال قال لله، وإذا عمِل عَمِل لله، وإذا نوى نوى لله{19}. (٨/١٠٦) ٣٥٩٧٩- عن قتادة بن دعامة، قال: المنيب: المُخْلِص{20}. (٨/١٠٦) ٣٥٩٨٠- عن قتادة بن دعامة -من طريق سعيد- قال: اللهُ يثني عليه: <q>﴿إن إبراهيم لحليم أواه منيب﴾</q>، والمنيب: التائب{10}. (ز) ٣٥٩٨١- قال مقاتل بن سليمان: <q>﴿مُنِيبٌ﴾</q>: مخلص{7}. (ز) ٣٥٩٨٢- عن عبد الرحمن بن زيد بن أسلم، قال: المنيبُ إلى الله: المُطِيع لله الذي أناب إلى طاعة الله وأمره، ورجع عن الأمور التي كان عليها قبل ذلك{20}. (٨/١٠٦) ",footnotes:1:أخرجه ابن أبي الدنيا في كتاب الحلم -موسوعة الإمام ابن أبي الدنيا ٢/٥٣ (٥٨)-. وعزاه السيوطي إلى أبي الشيخ.أخرجه ابن أبي حاتم ٦/٢٠٥٨.عزاه السيوطي إلى أبي الشيخ.أخرجه ابن أبي حاتم ٦/٢٠٥٨.أخرجه الحكيم الترمذي في نوادر الأصول (ت: إسماعيل إبراهيم عوض) ٢/٧٠٧.عزاه السيوطي إلى أبي الشيخ.تفسير مقاتل بن سليمان ٢/٢٩١.أخرجه عبد الله بن وهب في الجامع - تفسير القرآن ٢/٩٩-١٠٠ (١٩٤).أخرجه عبد الله بن وهب في الجامع - تفسير القرآن ٢/١٣٩-١٤٠ (٢٨٢).أخرجه ابن أبي حاتم ٦/٢٠٥٩.عزاه السيوطي إلى أبي الشيخ.أخرجه ابن جرير ١٢/٤٩٣.أخرجه ابن أبي حاتم ٦/٢٠٥٩.أخرجه ابن أبي حاتم ٦/٢٠٥٩.أخرجه عبد الرزاق ١/٣٠٩.تفسير مقاتل بن سليمان ٢/٢٩١.أخرجه ابن أبي حاتم ٦/٢٠٥٩.أخرجه ابن أبي حاتم ٦/٢٠٥٩.أخرجه البيهقي في شعب الإيمان (٦٨٩١).عزاه السيوطي إلى ابن أبي حاتم.أخرجه ابن أبي حاتم ٦/٢٠٥٩.تفسير مقاتل بن سليمان ٢/٢٩١.عزاه السيوطي إلى ابن أبي حاتم.
11,76," <q>﴿یَـٰۤإِبۡرَ ٰ⁠هِیمُ أَعۡرِضۡ عَنۡ هَـٰذَاۤۖ إِنَّهُۥ قَدۡ جَاۤءَ أَمۡرُ رَبِّكَۖ وَإِنَّهُمۡ ءَاتِیهِمۡ عَذَابٌ غَیۡرُ مَرۡدُودࣲ ۝٧٦﴾</q> - تفسير ٣٥٩٨٣- عن كعب الأحبار -من طريق عبد الله بن رباح- قال: فكلَّمهم إبراهيمُ في أمر قوم لوط: إن كان فيهم ...، قالوا: <q>﴿يا إبراهيم أعرض عن هذا إنه قد جاء أمر ربك﴾</q>{1}. (ز) ٣٥٩٨٤- قال محمد بن السائب الكلبي: سأل إبراهيم ربَّه ألّا يُهْلِك لوطًا وأهله، وأن يعفو عن قوم لوط، فقيل: <q>﴿يا إبراهيم أعرض عن هذا إنه قد جاء أمر ربك وإنهم آتيهم عذاب غير مردود﴾</q>{2}. (ز) ٣٥٩٨٥- قال مقاتل بن سليمان: وقال جبريلُ لإبراهيم: <q>﴿يا إبْراهِيمُ أعْرِضْ عَنْ هَذا﴾</q> الجدالَ. حين قال: أتهلُكهم إن كان فيهم كذا وكذا. ثم قال جبريل ﵇: <q>﴿إنَّهُ قَدْ جاءَ أمْرُ رَبِّكَ﴾</q> يعني: قول ربك في نزول العذاب بهم، <q>﴿وإنَّهُمْ آتِيهِمْ عَذابٌ غَيْرُ مَرْدُودٍ﴾</q> يعني: غير مدفوع عنهم، يعني: الخَسف، والحَصْب بالحجارة{3}. (ز) ",footnotes:1:أخرجه ابن أبي حاتم ٦/٢٠٥٩.ذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٢/٣٠٠-.تفسير مقاتل بن سليمان ٢/٢٩٢.
11,77," <q>﴿وَلَمَّا جَاۤءَتۡ رُسُلُنَا لُوطࣰا﴾</q> - تفسير ٣٥٩٨٦- عن وهب بن مُنَبِّه -من طريق عبد الصمد- يقول: كان أهل سدوم الذين فيهم لوط قومًا قد اسْتَغْنَوْا عن النِّساء بالرجال، فلمّا رأى اللهُ ذلك بعث الملائكةَ لِيُعَذِّبوهم، فأتوا إبراهيم، وكان مِن أمره وأمرهم ما ذكر اللهُ في كتابه، فلمّا بشَّروا سارة بالولد قاموا، وقام معهم إبراهيم يمشي، قال: أخبِروني لِمَ بُعِثْتُم؟ وما خطبكم؟ قالوا: إنّا أُرْسِلنا إلى أهل سدوم لِنُدَمِّرها، وإنّهم قوم سوء قد اسْتَغْنَوا بالرجال عن النساء. قال إبراهيم: أرأيتم إن كان فيهم خمسون رجلًا صالحًا؟ قالوا: إذن لا نُعَذِّبَهم. فجعل ينقص حتى قال: أهل البيت؟ قالوا: فإن كان فيها بيت صالح؟ قال: فلوط وأهل بيته؟ قالوا: إنّ امرأتَه هواها معهم. فلمّا يئِس إبراهيمُ انصرف، ومَضَوْا إلى أهل سدوم، فدخلوا على لوط، فلمّا رأتهم امرأته أعجبها حسنُهم وجمالهم، فأرسلت إلى أهل القرية: إنّه قد نزل بنا قوم لم يُرَ قومٌ قطُّ أحسن منهم ولا أجمل. فتسامعوا بذلك، فغشوا دار لوط مِن كل ناحية، وتَسَوَّروا عليهم الجدران، فلقيهم لوط، فقال: يا قومِ، لا تفضحوني في ضيفي، وأنا أُزَوِّجكم بناتي؛ فهُنَّ أطهر لكم. فقالوا: لو كُنّا نريد بناتك لقد عرفنا مكانهن. فقال: <q>﴿لو أن لي بكم قوة أو آوي إلى ركن شديد﴾</q>. فَوَجَدَ{1} عليه الرسل، قالوا: إنّ ركنك لشديد، <q>﴿وإنهم آتيهم عذاب غير مردود﴾</q>{2}. (٨/٩٣) ٣٥٩٨٧- عن قتادة بن دعامة -من طريق سعيد بن بشير- قال: أتَتِ الملائكةُ لوطًا وهو في مزرعةٍ له، وقال اللهُ للملائكة: إن شَهِد لوطٌ عليهم أربع شهادات فقد أذِنتُ لكم في هلكتهم. فقالوا: يا لوط، إنّا نُرِيد أن نُضيفَك الليلة. فقال: وما بلغكم مِن أمرهم؟ قالوا: وما أمرُهم؟ قال: أشهد باللهِ إنّها لَشَرُّ قريةٍ في الأرض عملًا. يقول ذلك أربع مرات، فشهد عليهم لوط أربع شهادات، فدخلوا معه منزله{3}. (ز) ٣٥٩٨٨- عن إسماعيل السُّدِّيّ -من طريق أسباط- قال: خَرَجَتِ الملائكةُ مِن عند إبراهيم نحو قريةِ لوط، فأتوها نصف النهار، فلمّا بلغوا نهر سَدُوم لقوا ابنةَ لوط تَسْتَقِي مِن الماء لأهلها، وكانت له ابنتان؛ اسم الكبرى: ريثا، والصغرى: زُغرتا، فقالوا لها: يا جارية، هل مِن منزل؟ قالت: نعم، فمكانكم لا تدخلوا حتى آتيكم. فَرِقَتْ عليهم مِن قومها، فأتت أباها، فقالت: يا أبتاه، أرادك فتيان على باب المدينة، ما رأيت وجهَ قوم أحسن منهم، لا يأخذهم قومك فيفضحوهم. وقد كان قومه نهوه أن يضيف رجلًا، فقالوا: خلِّ عنا فَلْنُضِفِ الرجال. فجاء بهم، فلم يعلم أحدٌ إلا أهلُ بيت لوط، فخرجت امرأته، فأخبرت قومها، قالت: إنّ في بيت لوط رجالًا ما رأيتُ مثل وجوههم قطُّ. فجاءه قومُه يُهْرَعون إليه{4}. (ز) <q>﴿سِیۤءَ بِهِمۡ وَضَاقَ بِهِمۡ ذَرۡعࣰا﴾</q> - تفسير ٣٥٩٨٩- عن عبد الله بن عباس -من طريق علي- في قوله: <q>﴿ولما جاءت رسلنا لوطًا سيء بهم وضاق بهم ذرعًا﴾</q>، قال: ساء ظنًّا بقومه، وضاق ذرعًا بأضيافه{5}٣٢٥٧. (٨/١٠٦) ٣٢٥٧ لم يذكر ابنُ جرير (١٢/٤٩٥) في معنى: <q>﴿سِيءَ بِهِمْ وضاقَ بِهِمْ ذَرْعًا﴾</q> سوى قول ابن عباس. ٣٥٩٩٠- عن كعب الأحبار -من طريق عبد الله بن رباح- <q>﴿سيء بهم وضاق بهم ذرعا﴾</q>: ساء مكانهم لِما رأى منهم مِن الحال{6}. (ز) ٣٥٩٩١- عن الضحاك بن مزاحم، قال: ساءه مكانهم لِما رأى بهم من الجَمال{7}. (ز) ٣٥٩٩٢- قال الحسن البصري: <q>﴿ولما جاءت رسلنا لوطا سيء بهم﴾</q>: ساءه دخولهم؛ لِما تخوف عليهم مِن قومه{8}. (ز) ٣٥٩٩٣- عن قتادة بن دعامة -من طريق مَعْمَر- في الآية، قال: ساء ظنًّا بقومه، يَتَخَوَّفُهم على أضيافه، وضاق ذرعًا بضيفه مخافةً عليهم{9}. (٨/١٠٦) ٣٥٩٩٤- قال محمد بن السائب الكلبي: <q>﴿وضاق بهم ذرعا﴾</q>، لم يَدْرِ أين يُنزِلُهم. قال: وكان قوم لوط لا يُؤْوُونَ ضيفًا بليل، وكانوا يعترضون مَن مَرَّ بالطريق نهارًا للفاحشة، فلمّا جاءت الملائكة لوطًا حين أمسوا كرِهَهم، ولم يستطع دفعهم، فقال: <q>﴿هذا يوم عصيب﴾</q>{8}. (ز) ٣٥٩٩٥- عن محمد بن إسحاق -من طريق سلمة- قال: خرجت الرُّسُل -فيما يزعم أهلُ التوراة- مِن عند إبراهيم إلى لوط بالمؤتفكة، فلمّا جاءت الرسل لوطًا <q>﴿سيء بهم وضاق بهم ذرعا﴾</q>، وذلك مِن تَخَوُّف قومه عليهم أن يفضحوه في ضيفه، فقال: <q>﴿هذا يوم عصيب﴾</q>{11}. (ز) ٣٥٩٩٦- قال مقاتل بن سليمان: قوله: <q>﴿ولَمّا جاءَتْ رُسُلُنا﴾</q> جبريل، وميكائيل، وإسرافيل، ومَلَك الموت <q>﴿لُوطًا سِيءَ بِهِمْ﴾</q> يعني: كَرِهَهم؛ لصنيع قومه بالرجال؛ مخافة أن يفضحوهم، <q>﴿وضاقَ بِهِمْ ذَرْعًا﴾</q>{12}. (ز) <q>﴿وَقَالَ هَـٰذَا یَوۡمٌ عَصِیبࣱ ۝٧٧﴾</q> - تفسير ٣٥٩٩٧- عن عبد الله بن عباس -من طريق علي- في قوله: <q>﴿وقال هذا يوم عصيب﴾</q>، يقول: شديد{13}. (٨/١٠٦) ٣٥٩٩٨- عن عبد الله بن عباس: أنّ نافع بن الأزرق قال له: أخبِرني عن قوله ﷿: <q>﴿يوم عصيب﴾</q>. قال: يوم شديد. قال: وهل تعرفُ العرب ذلك؟ قال: نعم، أما سمعت الشاعر وهو يقول: هم ضربوا قوانِسَ{14} خَيْلِ حُجْرٍ بِجَنْبِ الرَّدْهِ في يومٍ عَصيبِ وقال عدي بن زيد: فكنت لِزازَ{15} خَصمِك لم أُعرِّدْ{16} وقد سَلَكُوك في يومٍ عصيبِ{17}. (٨/١٠٧) ٣٥٩٩٩- عن كعب الأحبار -من طريق عبد الله بن رباح- <q>﴿وقال هذا يوم عصيب﴾</q>، قال: يوم سُوءٍ مِن قومي{18}. (٨/٩٠) ٣٦٠٠٠- عن مجاهد بن جبر -من طريق ابن أبي نجيح- <q>﴿وقالَ هَذا يَوْمٌ عَصِيبٌ﴾</q>: شديد{19}. (ز) ٣٦٠٠١- عن قتادة بن دعامة -من طريق مَعْمَر- في قوله تعالى: <q>﴿هذا يوم عصيب﴾</q>، قال: شديد{20}. (ز) ٣٦٠٠٢- عن إسماعيل السدي، مثل ذلك{21}. (ز) ٣٦٠٠٣- عن محمد بن كعب القُرَظِيِّ -من طريق موسى بن عبيدة- <q>﴿وقال هذا يوم عصيب﴾</q>، قال: يَعْصِبُ شَرُّهُ{6}. (ز) ٣٦٠٠٤- قال محمد بن السائب الكلبي: <q>﴿هذا يوم عصيب﴾</q>: شديد{8}. (ز) ٣٦٠٠٥- قال مقاتل بن سليمان: <q>﴿وقالَ﴾</q> جبريل: <q>﴿هَذا يَوْمٌ عَصِيبٌ﴾</q>. يعني: فظيعٌ فاشٍ شَرُّه عليهم{12}. (ز) ٣٦٠٠٦- عن محمد بن إسحاق -من طريق سلمة- قال: <q>﴿هذا يوم عصيب﴾</q>، أي: يوم بلاء وشِدَّة{25}٣٢٥٨. (ز) ٣٢٥٨ لم يذكر ابنُ جرير (١٢/٤٩٨-٤٩٩) في معنى: <q>﴿وقالَ هَذا يَوْمٌ عَصِيبٌ﴾</q> سوى قول ابن عباس، وقتادة، وابن إسحاق. ٣٦٠٠٧- عن جعفر{26} -من طريق الحسن بن عمرو بن شقيق- <q>﴿وقال هذا يوم عصيب﴾</q>، قال: يوم سيء مِن قومي{6}. (ز) ",footnotes:1:الوَجْد: الحزن. تاج العروس (وجد).أخرجه ابن جرير ١٢/٥٢٠، وفي تاريخه ١/٣٠٤. وعزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ١٢/٤٩٦.أخرجه ابن جرير ١٢/٤٩٦، وابن أبي حاتم ٦/٢٠٦٠.أخرجه ابن جرير ١٢/٤٩٥، وابن أبي حاتم ٦/٢٠٦١. وعزاه السيوطي إلى أبي الشيخ.أخرجه ابن أبي حاتم ٦/٢٠٦١.عزاه الحافظ ابن حجر في الفتح ٨/٣٥٠ إلى ابن أبي حاتم.ذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٢/٣٠١-.أخرجه عبد الرزاق ٢/٩٧. وعزاه السيوطي إلى عبد بن حميد.ذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٢/٣٠١-.أخرجه ابن جرير ١٢/٤٩٧.تفسير مقاتل بن سليمان ٢/٢٩٢.أخرجه ابن جرير ١٢/٤٩٩، وابن أبي حاتم ٦/٢٠٦١. وعزاه السيوطي إلى أبي الشيخ.قَوْنَس الفَرَس: ما بين أُذنيه، وقيل: مُقَدَّمُ رأسه. لسان العرب (قنس).يقال: جعلت فلانًا لزازًا لفلان، أي: لا يدعه يخالف ولا يعاند. لسان العرب (لزز).عرد الرجل عن قرنه: إذا أحجم ونكل. لسان العرب (عرد).أخرجه الطستي -كما في الإتقان ٢/٨٧-. وعزاه السيوطي إلى ابن الأنباري في الوقف والابتداء.أخرجه ابن أبي الدنيا في كتاب العقوبات -موسوعة الإمام ابن أبي الدنيا ٤/٤٦٤ (١٤٩)-. وعزاه السيوطي إلى عبد الله بن أحمد في زوائد الزهد.أخرجه ابن جرير ١٢/٤٩٨.أخرجه عبد الرزاق ١/٣٠٩، وابن جرير ١٢/٤٩٩. وعلَّقه ابن أبي حاتم ٦/٢٠٦١.علَّقه ابن أبي حاتم ٦/٢٠٦١أخرجه ابن أبي حاتم ٦/٢٠٦١.ذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٢/٣٠١-.تفسير مقاتل بن سليمان ٢/٢٩٢.أخرجه ابن جرير ١٢/٤٩٩.لعله جعفر بن سليمان الضبعى (ت:١٧٨)، ينظر: التاريخ الكبير للبخاري ٢/ ٣٠٠.أخرجه ابن أبي حاتم ٦/٢٠٦١.
11,78," <q>﴿وَجَاۤءَهُۥ قَوۡمُهُۥ یُهۡرَعُونَ إِلَیۡهِ﴾</q> - تفسير ٣٦٠٠٨- عن عبد الله بن عباس -من طريق علي- في قوله: <q>﴿وجاءه قومه يهرعون إليه﴾</q>، قال: يُسْرِعون{1}. (٨/١٠٧) ٣٦٠٠٩- عن عبد الله بن عباس -من طريق الضحاك- في قوله: <q>﴿وجآءه قومه يهرعون إليه﴾</q>، قال: يَسْعَوْنَ إليه{2}. (٨/١٠٨) ٣٦٠١٠- عن عبد الله بن عباس: أنّ نافع بن الأزرق قال له: أخبِرني عن قوله ﷿: <q>﴿يهرعون إليه﴾</q>. قال: يُقبِلون إليه بالغَضَب. قال: وهل تعرف العرب ذلك؟ قال: نعم، أما سمعتَ الشاعرَ وهو يقول: أتونا يهرعون وهم أُسارى سيوفهم على رغم الأُنوف{3}. (٨/١٠٨) ٣٦٠١١- عن مجاهد بن جبر -من طريق ابن أبي نجيح- في قول الله: <q>﴿يهرعون إليه﴾</q>، قال: يُهَرْوِلُون إليه، وهو الإسراع في المشي{4}. (ز) ٣٦٠١٢- عن الضحاك بن مزاحم -من طريق جُوَيْبِر- <q>﴿وجاءه قومه يهرعون إليه﴾</q>، قال: يَسْعَوْن إليه{5}. (ز) ٣٦٠١٣- قال الحسن البصري: مَشْيٌ بين مشيتين{6}. (ز) ٣٦٠١٤- عن قتادة بن دعامة -من طريق مَعْمَر- في قوله تعالى: <q>﴿يهرعون إليه﴾</q>، قال: يُسْرِعون إليه{7}. (ز) ٣٦٠١٥- عن إسماعيل السُّدِّيّ -من طريق أسباط- <q>﴿وجاءه قومه يهرعون إليه﴾</q>: يُسْرِعون إليه المشي{8}. (ز) ٣٦٠١٦- عن شمر بن عطية -من طريق حفص بن حميد- قال: أقبلوا يُسْرِعون مشيًا بين الهَرْولةِ والجَمْزِ{9}. (ز) ٣٦٠١٧- قال مقاتل بن سليمان: <q>﴿وجاءَهُ قَوْمُهُ يُهْرَعُونَ إلَيْهِ﴾</q>، يعني: يُسْرِعون إليه مُشاةً إلى لوط{10}. (ز) ٣٦٠١٨- قال سفيان الثوري: <q>﴿يهرعون إليه﴾</q>: يُسْرِعون إليه{11}. (ز) ٣٦٠١٩- عن سفيان بن عيينة -من طريق سوار بن عبد الله- في قوله: <q>﴿يهرعون إليه﴾</q>، قال: كأنّهم يدفعون{5}. (ز) <q>﴿وَمِن قَبۡلُ كَانُوا۟ یَعۡمَلُونَ ٱلسَّیِّـَٔاتِۚ﴾</q> - تفسير ٣٦٠٢٠- عن عبد الله بن عباس -من طريق علي- في قوله: <q>﴿ومن قبل كانوا يعملون السيئات﴾</q>، قال: يأتون الرِّجال{13}. (٨/١٠٧) ٣٦٠٢١- عن إسماعيل السُّدِّيّ -من طريق أسباط- في قوله: <q>﴿ومن قبل كانوا يعملون السيئات﴾</q>، يقول: يَنكِحون الرِّجال{14}. (٨/١٠٨) ٣٦٠٢٢- قال مقاتل بن سليمان: <q>﴿ومِن قَبْلُ﴾</q> أن نبعث لوطًا <q>﴿كانُوا يَعْمَلُونَ السَّيِّئاتِ﴾</q> يعني: نكاح الرجال{10}. (ز) ٣٦٠٢٣- عن عبد الملك ابن جُرَيْج -من طريق حجاج- <q>﴿ومِن قَبْلُ كانُوا يَعْمَلُونَ السَّيِّئاتِ﴾</q>، قال: يأتون الرجال{16}. (ز) <q>﴿وَمِن قَبۡلُ كَانُوا۟ یَعۡمَلُونَ ٱلسَّیِّـَٔاتِۚ﴾</q> - آثار متعلقة بالآية ٣٦٠٢٤- عن جامع بن شداد أبي صخرة -من طريق عمر بن أبي زايدة- قال: كانت اللُّوطِيَّةُ في قوم لوطٍ في النساء قبل أن تكون في الرجال بأربعين سنة{17}. (ز) <q>﴿قَالَ یَـٰقَوۡمِ هَـٰۤؤُلَاۤءِ بَنَاتِی هُنَّ أَطۡهَرُ لَكُمۡۖ﴾</q> - تفسير ٣٦٠٢٥- عن حذيفة بن اليمان -من طريق قتادة- قال: عَرَض عليهم بناتِه تزويجًا، وأراد أن يَقِي أضيافه بتزويج بناته{18}٣٢٥٩. (٨/١١٠) ٣٢٥٩ ساق ابنُ عطية (٤/٦١٩) هذا القول، ثم علَّق بقوله: «وذلك على أن كانت سُنَّتُهم جوازَ نكاح الكافر المؤمنة، أو على أنّ في ضمن كلامه أن يؤمنوا». ٣٦٠٢٦- عن عبد الله بن عباس، في قوله: <q>﴿قال يا قوم هؤلاء بناتي﴾</q>، قال: ما عَرَضَ لوطٌ ﵇ بناتِه على قومه لا سفاحًا ولا نكاحًا، إنما قال: هؤلاء بناتي نساؤُكم. لأنّ النَّبِيَّ إذا كان بين ظهري قوم فهو أبوهم، قال الله في القرآن: (وأَزْواجُهُ أُمَّهاتُهُمْ وهُوَ أبُوهُمْ) في قراءة أُبَيٍّ{19}. (٨/١٠٨) ٣٦٠٢٧- عن عبد الله بن عباس -من طريق جُوَيْبِر، ومقاتل- قال: لَمّا سَمِعت الفَسَقَة بأضياف لوط جاءوا إلى باب لوط، فأغلق لوطٌ عليهم البابَ دونهم، ثم اطَّلَع عليهم، فقال: <q>﴿هؤلاء بناتي﴾</q>. يعرض عليهم بناته بالنِّكاح والتزويج، ولم يَعرِضها عليهم للفاحشة، وكانوا كُفّارًا، وبناته مسلمات، فلمّا رأى البلاء وخاف الفضيحة عرض عليهم التَّزْوِيج، وكان اسم ابنتيه إحداهما: رعوثا، والأخرى: رميثا، ويقال: زبوثا{20}. (٨/١٠٩) ٣٦٠٢٨- عن كعب الأحبار -من طريق عبد الله بن رباح-: <q>﴿يا قوم هؤلاء بناتي هن أطهر لكم﴾</q> تَزَوَّجُوهُنَّ{21}. (٨/٩٠) ٣٦٠٢٩- عن سعيد بن جبير -من طريق أبي بشر- قال: إنّما دعاهم إلى نسائهم، وكلُّ نبيٍّ أبو أُمَّته{22}. (٨/١٠٩) ٣٦٠٣٠- عن مجاهد بن جبر -من طريق ليث- في قوله: <q>﴿هؤلاء بناتي﴾</q>، قال: لم يَكُنَّ بناتِه، ولكِن كُنَّ مِن أُمَّتِه، وكلُّ نَبِيٍّ أبو أُمَّتِه، وقال في بعض القراءة: (النَّبِيُّ أوْلى بِالمُؤْمِنِينَ مِن أنفُسِهِمْ وأَزْواجُهُ أُمَّهاتُهُمْ وهُوَ أبٌ لَّهُمْ){23}. (٨/١٠٨) ٣٦٠٣١- عن مجاهد بن جبر -من طريق ليث- في قوله: <q>﴿هؤلاء بناتي هن أطهر لكم﴾</q>، قال: كلُّ نبيٍّ أبو أُمَّتِه، فأمّا لُوطٌ فإنّه لم تكن له إلا ابنتان{24}. (ز) ٣٦٠٣٢- عن وهب بن مُنَبِّه -من طريق عبد الصمد بن معقل- قال: فدخلوا على لوط -يعني: الملائكة-، فلمّا رأتهم امرأتُه أعجبها حسنُهم وجمالُهم، فأرسلت إلى أهل القرية: إنّه قد نزل بِنا قومٌ لم يُرَ قومٌ قطُّ أحسن منهم ولا أجمل. فتسامعوا بذلك، فغشوا دار لوط مِن كل ناحية، وتسَوَّروا عليهم الجدران، فلقيهم لوط، فقال: يا قومِ، لا تفضحوني في ضيفي، وأنا أُزَوِّجكم بناتي؛ فهُنَّ أطهر لكم. فقالوا: لو كُنّا نريد بناتك لقد عرفنا مكانهن، ولكن لا بُدَّ لنا مِن هؤلاء القوم الذين نزلوا بك، خلِّ بيننا وبينهم{25}. (٨/٩٣) ٣٦٠٣٣- عن قتادة بن دعامة -من طريق معمر- في قوله: <q>﴿هؤلاء بناتي هنَّ أطهر لكم﴾</q>، قال: أمَرهم لوطٌ بتزويج النساء، وقال: <q>﴿هن أطهر لكم﴾</q>{26}. (٨/١١٠) ٣٦٠٣٤- عن معمر، قال: وبلغني هذا أيضًا عن مجاهد{27}. (ز) ٣٦٠٣٥- عن إسماعيل السدي -من طريق أسباط-: <q>﴿وجاءه قومه يهرعون إليه﴾</q> قالوا: أو لم نَنْهَك أن تضيف العالمين؟ قال: <q>﴿هؤلاء بناتي هن أطهر لكم﴾</q> إن كنتم فاعلين، <q>﴿أليس منكم رجل رشيد﴾</q>؟{28}. (ز) ٣٦٠٣٦- عن إسماعيل السدي -من طريق الحكم بن ظهير- في قوله: <q>﴿هؤلاء بناتي﴾</q>، قال: عرض عليهم نساءَ أُمَّته، كلُّ نبيٍّ فهو أبو أمته. وفي قراءة عبد الله: (النَّبِيُّ أوْلى بِالمُؤْمِنِينَ مِن أنفُسِهِمْ وهُوَ أبٌ لَّهُمْ وأَزْواجُهُ أُمَّهاتُهُمْ){29}. (٨/١٠٩) ٣٦٠٣٧- عن عبد الله بن أبي نجيح -من طريق إسماعيل بن علية- يقول في قوله: <q>﴿هن أطهر لكم﴾</q>، قال: ما عرض عليهم نكاحًا ولا سِفاحًا{30}٣٢٦٠. (ز) ٣٢٦٠ نقل ابنُ عطية (٤/٦١٩) عن أبي عبيدة أنّ قول لوط ﵇: <q>﴿هَؤُلاءِ بَناتِي هُنَّ أطْهَرُ لَكُمْ﴾</q>: إنّما كان مُدافَعةً، ولم يُرِد إمضاءه، ثم انتقده مستندًا إلى الدلالة العقلية، فقال: «وهو ضعيف، وهذا كما يُقال لِمَن ينهى عن مال الغير: الخنزير أحلُّ لك مِن هذا. وهذا التَّنَطُّع ليس مِن كلام الأنبياء -صلى الله عليهم وسلم-». ٣٦٠٣٨- عن الربيع بن أنس -من طريق أبي جعفر- في قوله: <q>﴿هؤلاء بناتي هن أطهر لكم﴾</q>، يعني: التَّزويج{31}. (ز) ٣٦٠٣٩- قال مقاتل بن سليمان: <q>﴿قالَ﴾</q> لوط: <q>﴿يا قَوْمِ هَؤُلاءِ بَناتِي﴾</q> ريثا، وزعوثا، فتزوجوهما، <q>﴿هُنَّ أطْهَرُ لَكُمْ﴾</q> يعني: أحَلُّ لكم مِن إتيان الرجال{10}. (ز) ٣٦٠٤٠- عن محمد بن إسحاق -من طريق سلمة- قال: لَمّا جاءت الرسل لوطًا أقبل قومُه إليهم حين أُخْبِروا بهم يُهْرَعون إليه، فيزعمون -والله أعلم-: أنّ امرأة لوط هي التي أخبرتهم بمكانهم، وقالت: إنّ عند لوط لَضِيفانًا ما رأيت أحسن ولا أجمل قطُّ منهم. وكانوا يأتون الرجال شهوة مِن دون النساء، فاحشة لم يسبقهم بها أحد من العالمين، فلمّا جاءوه قالوا: <q>﴿أولم ننهك عن العالمين﴾</q> [الحجر:٧٠]، أي: ألم نقل لك: لا يَقْرَبَنَّك أحدٌ، فإنّا لن نجد عندك أحدًا إلا فعلنا به الفاحشة. <q>﴿قال يا قوم هؤلاء بناتي هن أطهر لكم﴾</q>، فأنا أفدي ضيفي منكم بِهِنَّ. ولم يَدْعُهم إلّا إلى الحلال مِن النكاح{28}. (ز) <q>﴿فَٱتَّقُوا۟ ٱللَّهَ وَلَا تُخۡزُونِ فِی ضَیۡفِیۤۖ﴾</q> - تفسير ٣٦٠٤١- عن إسماعيل السُّدِّيّ: <q>﴿ولا تخزون في ضيفي﴾</q>، يقول: ولا تفضحوني{34}. (٨/١١١) ٣٦٠٤٢- قال مقاتل بن سليمان: <q>﴿فاتَّقُوا اللَّهَ﴾</q> في معصيته، <q>﴿ولا تُخْزُونِ فِي ضَيْفِي﴾</q>{10}. (ز) <q>﴿أَلَیۡسَ مِنكُمۡ رَجُلࣱ رَّشِیدࣱ ۝٧٨﴾</q> - تفسير ٣٦٠٤٣- عن عبد الله بن عباس، <q>﴿أليس منكم رجل رشيد﴾</q>، قال: يأمر بالمعروف، وينهى عن المنكر{36}. (٨/١٠٩، ١١١) ٣٦٠٤٤- عن عبد الله بن عباس -من طريق عكرمة- في قوله: <q>﴿أليس منكم رجل رشيد﴾</q>، قال: واحد يقول: لا إله إلا الله{37}. (٨/١١١) ٣٦٠٤٥- عن عكرمة مولى ابن عباس، مثله{38}. (٨/١١١) ٣٦٠٤٦- عن أبي مالك غزوان الغفاري -من طريق السدي- <q>﴿أليس منكم رجل رشيد﴾</q>، قال: رجل يأمر بمعروف، وينهى عن المنكر{18}. (٨/١١١) ٣٦٠٤٧- قال مقاتل بن سليمان: <q>﴿ألَيْسَ مِنكُمْ رَجُلٌ رَشِيدٌ﴾</q>، يقول: ما منكم رجل مُرْشِد{10}. (ز) ٣٦٠٤٨- عن محمد بن إسحاق -من طريق سلمة- <q>﴿فاتقوا الله ولا تخزون في ضيفي أليس منكم رجل رشيد﴾</q>، أي: رجل يعرف الحق، يأمر بالمعروف، وينهى عن المنكر{41}٣٢٦١. (ز) ٣٢٦١ لم يذكر ابنُ جرير (١٢/٥٠٧) في معنى: <q>﴿ألَيْسَ مِنكُمْ رَجُلٌ رَشِيدٌ﴾</q> سوى قول ابن إسحاق. ",footnotes:1:أخرجه ابن جرير ١٢/٥٠١، وابن أبي حاتم ٦/٢٠٦١. وعلَّقه البخاري في صحيحه ٤/١٧٣٦ بلفظ: مسرعين.أخرجه ابن أبي حاتم ٦/٢٠٦١. وعزاه السيوطي إلى أبي الشيخ.أخرجه الطستي -كما في الإتقان ٢/٨٦-.تفسير مجاهد ص٣٨٩، وأخرجه ابن جرير ١٢/٥٠٠، وابن أبي حاتم ٦/٢٠٦٢.أخرجه ابن جرير ١٢/٥٠٠.تفسير الثعلبي ٥/١٨١، وتفسير البغوي ٤/١٩١.أخرجه عبد الرزاق ١/٣٠٩، وابن جرير ١٢/٥٠٠.أخرجه ابن جرير ١٢/٥٠١. وعلَّقه ابن أبي حاتم ٦/٢٠٦١.أخرجه ابن جرير ١٢/٥٠١. والجَمْز: ضرب من السير سريع. النهاية (جمز).تفسير مقاتل بن سليمان ٢/٢٩٢.علَّقه ابن جرير ١٢/٥٠١.أخرجه ابن جرير ١٢/٥٠٠.عزاه السيوطي إلى ابن جرير، وابن أبي حاتم.أخرجه ابن أبي حاتم ٦/٢٠٦٢. وعزاه السيوطي إلى أبي الشيخ.تفسير مقاتل بن سليمان ٢/٢٩٢.أخرجه ابن جرير ١٢/٥٠٢.أخرجه ابن أبي حاتم ٦/٢٠٦٢.أخرجه ابن أبي حاتم ٦/٢٠٦٣.عزاه السيوطي إلى أبي الشيخ. والقراءة شاذة. انظر: مصنف عبد الرزاق ١٠/١٨١ (١٨٧٤٨)، وروح المعاني ٢١/١٥٢.أخرجه ابن عساكر ٥٠/٣١٣. وعزاه السيوطي إلى إسحاق بن بشر.أخرجه ابن أبي الدنيا في كتاب العقوبات -موسوعة الإمام ابن أبي الدنيا ٤/٤٦٤ (١٤٩)-، وابن أبي حاتم ٦/٢٠٦٢. وعزاه السيوطي إلى عبد الله بن أحمد في زوائد الزهد.أخرجه ابن جرير ١٢/٥٠٣-٥٠٤، وابن أبي حاتم ٦/٢٠٦٢.أخرجه ابن جرير ١٢/٥٠٢-٥٠٣، وابن أبي حاتم ٦/٢٠٦٢. وعزاه السيوطي إلى أبي الشيخ. والقراءة شاذة.أخرجه سفيان الثوري في تفسيره ص١٣١.أخرجه ابن جرير في تفسيره ١٢/٥٢٠، وفي تاريخه ١/٣٠٤، وابن أبي حاتم ٦/٢٠٦٣. وعزاه السيوطي إلى ابن المنذر.أخرجه عبد الزاق ١/٣٠٦، وابن جرير ١٢/٥٠٢. وذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٢/٣٠١-. وعزاه السيوطي إلى أبي الشيخ.أخرجه عبد الرزاق ١/٣٠٦، وابن جرير ١٢/٥٠٢.أخرجه ابن جرير ١٢/٥٠٤.أخرجه ابن عساكر ٥٠/٣١٧. وعزاه السيوطي إلى ابن أبي الدنيا.أخرجه ابن جرير ١٢/٥٠٣، وابن أبي حاتم ٦/٢٠٦٣.أخرجه ابن جرير ١٢/٥٠٣.تفسير مقاتل بن سليمان ٢/٢٩٢.أخرجه ابن جرير ١٢/٥٠٤.عزاه السيوطي إلى أبي الشيخ.تفسير مقاتل بن سليمان ٢/٢٩٢.عزاه السيوطي إلى أبي الشيخ. وأخرج هذا اللفظ ابن عساكر ٥٠/٣١٣ في رواية طويلة من طريق جويبر ومقاتل، وعزاها السيوطي إلى إسحاق بن بشر.أخرجه ابن أبي حاتم ٦/٢٠٦٣، والبيهقي في الأسماء والصفات (٢٠٥).عزاه السيوطي إلى أبي الشيخ. وينظر: تفسير البغوي ٤/١٩٢.أخرجه ابن أبي حاتم ٦/٢٠٦٣.تفسير مقاتل بن سليمان ٢/٢٩٢.أخرجه ابن جرير ١٢/٥٠٧.
11,79," <q>﴿قَالُوا۟ لَقَدۡ عَلِمۡتَ مَا لَنَا فِی بَنَاتِكَ مِنۡ حَقࣲّ﴾</q> - تفسير ٣٦٠٤٩- قال مقاتل بن سليمان: <q>﴿قالُوا لَقَدْ عَلِمْتَ ما لَنا فِي بَناتِكَ مِن حَقٍّ﴾</q>، يعنون: مِن حاجَةٍ{1}. (ز) ٣٦٠٥٠- عن محمد بن إسحاق -من طريق سلمة- قال: <q>﴿قالوا لقد علمت ما لنا في بناتك من حق﴾</q>، أي: مِن أزواج{2}. (ز) <q>﴿وَإِنَّكَ لَتَعۡلَمُ مَا نُرِیدُ ۝٧٩﴾</q> - تفسير ٣٦٠٥١- عن إسماعيل السُّدِّيّ -من طريق أسباط- في قوله: <q>﴿قالوا لقد علمت ما لنا في بناتك من حق وإنك لتعلم ما نريد﴾</q>، قال: إنّما نُريد الرِّجال{3}. (٨/١١١) ٣٦٠٥٢- قال مقاتل بن سليمان: <q>﴿وإنَّكَ لَتَعْلَمُ ما نُرِيدُ﴾</q> أنّهم يريدون الأضياف{1}. (ز) ٣٦٠٥٣- عن محمد بن إسحاق -من طريق سلمة- <q>﴿وإنك لتعلم ما نريد﴾</q>، أي: إنّ بُغْيَتَنا لَغَيْرُ ذلك{3}. (ز) ",footnotes:1:تفسير مقاتل بن سليمان ٢/٢٩٢.أخرجه ابن جرير ١٢/٥٠٧، وابن أبي حاتم ٦/٢٠٦٣.أخرجه ابن جرير ١٢/٥٠٨، وابن أبي حاتم ٦/٢٠٦٤.تفسير مقاتل بن سليمان ٢/٢٩٢.أخرجه ابن جرير ١٢/٥٠٨، وابن أبي حاتم ٦/٢٠٦٤.
11,80," <q>﴿قَالَ لَوۡ أَنَّ لِی بِكُمۡ قُوَّةً أَوۡ ءَاوِیۤ إِلَىٰ رُكۡنࣲ شَدِیدࣲ ۝٨٠﴾</q> - تفسير ٣٦٠٥٤- عن أبي هريرة، في قوله: <q>﴿أو ءاوي إلى ركن شديد﴾</q>، قال: قال رسول الله ﷺ: «رَحِم الله لوطًا، كان يأوي إلى ركن شديد -يعني: الله تعالى-، فما بعث اللهُ بعده نبيًّا إلا في ثَرْوَةٍ{1} مِن قومه»{2}. (٨/١١٣) ٣٦٠٥٥- عن قتادة، قال: ذُكِر لنا: أنّ نبي الله ﷺ كان إذا قرأ هذه الآية قال: «رَحِم الله لوطًا، إن كان لَيَأْوِي إلى رُكْنٍ شديد». وذُكر لنا: أنّ الله لم يبعث نبيًّا بعد لوط إلا في ثروة من قومه، حتى بعث الله نبيَّكم ﷺ في ثروة مِن قومه{3}. (٨/١١٣) ٣٦٠٥٦- عن علي بن أبي طالب أنّه خطب، فقال: عشيرةُ الرجل للرجل خيرٌ مِن الرجل لعشيرته، إنّه إن كفَّ يدَه عنهم كفَّ يدًا واحدة وكفُّوا عنه أيديًا كثيرة، مع مودَّتِهم وحِفاظِهم ونصرتِهم، حتى لَرُبَّما غَضِب الرجلُ للرجل وما يعرفه إلا بحسبه، وسأتلو عليكم بذلك آياتٍ مِن كتاب الله تعالى. فتلا هذه الآية: <q>﴿لو أن لي بكم قوة أو ءاوي إلى ركن شديد﴾</q>. قال عليٌّ: والركن الشديد: العشيرة، فلم يكن للوط ﵇ عشيرة، فوالذي لا إله غيره، ما بعث الله نبيًّا بعد لوط إلا في ثروة مِن قومه{4}. (٨/١١٢) ٣٦٠٥٧- عن عبد الله بن عباس -من طريق الضَّحّاك- في قوله: <q>﴿أو ءاوي إلى ركن شديد﴾</q>، قال: عشيرة{5}. (٨/١١١) ٣٦٠٥٨- عن عبد الله بن عباس -من طريق جُوَيْبِر، ومقاتل- قال: ... فلمّا لم يتناهوا، ولم يَرُدَّهم قوله، ولم يقبلوا شيئًا مِمّا عرض عليهم مِن أمر بناته؛ قال: <q>﴿لو أن لي بكم قوة أو ءاوي إلى ركن شديد﴾</q>. يعني: عشيرة أو شيعة تنصُرُني، لَحُلْتُ بينكم وبين هذا{6}. (٨/١٠٩) ٣٦٠٥٩- عن كعب الأحبار -من طريق عبد الله بن رباح- قال: <q>﴿لو أن لي بكم قوة أو ءاوي إلى ركن شديد﴾</q>، قال: إلى عشيرة تمنع. فبلغني: أنّه لم يُبْعَث بعد لوط رسولٌ إلا في عِزٍّ مِن قومه{7}. (٨/٩٠) ٣٦٠٦٠- عن الحسن البصري -من طريق مبارك بن فضالة- <q>﴿أو آوي إلى ركن شديد﴾</q>، قال: إلى رُكْنٍ مِن الناس{8}. (ز) ٣٦٠٦١- عن [الحسن البصري] -من طريق مبارك- في قوله: <q>﴿أو آوي إلى ركن شديد﴾</q>، قال: إلى ركن من الناس شديدٍ يمنعونه، لا واللهِ، ما جادلوه حتى قال: <q>﴿أليس منكم رجل رشيد﴾</q>{9}. (ز) ٣٦٠٦٢- قال الحسن البصري: فلم يبعث الله سبحانه بعد لوطٍ نبيًّا إلا في عِزٍّ مِن قومه، وكانت امرأةُ لوطٍ منافقةً؛ تُظْهِر الإسلام، وقلبُها على الكُفْر{10}. (ز) ٣٦٠٦٣- عن وهب بن مُنَبِّه -من طريق عبد الصمد-: قال لوط ﵇: <q>﴿لو أن لي بكم قوة أو ءاوي إلى ركن شديد﴾</q>. فوجد عليه الرسل، وقالوا: يا لوط، إنّ ركنك لَشَدِيدٌ{11}. (٨/١١٣) ٣٦٠٦٤- عن قتادة بن دعامة -من طريق سعيد- <q>﴿أو آوي إلى ركن شديد﴾</q>، قال: العشيرة{12}. (٨/١١٢) ٣٦٠٦٥- عن إسماعيل السُّدِّيّ -من طريق أسباط-: قال لوطٌ: <q>﴿لو أن لي بكم قوة أو ءاوي إلى ركن شديد﴾</q>، يقول: إلى جُندٍ شديد لَقاتَلْتُكُم{13}. (٨/١١١) ٣٦٠٦٦- قال مقاتل بن سليمان: <q>﴿قالَ لَوْ أنَّ لِي بِكُمْ قُوَّةً﴾</q> يعني: بَطْشًا، <q>﴿أوْ آوِي إلى رُكْنٍ شَدِيدٍ﴾</q> يعني: منيع، يعني: رهط، يعني: عشيرة؛ لَمَنَعْتُكم مِمّا تريدون{14}. (ز) ٣٦٠٦٧- عن محمد بن إسحاق -من طريق سلمة- قال: <q>﴿لو أن لي بكم قوة أو آوي إلى ركن شديد﴾</q>، أي: عشيرة تمنعني، أو شيعة تنصرني؛ لَحُلْتُ بينكم وبين هذا{8}. (ز) <q>﴿قَالَ لَوۡ أَنَّ لِی بِكُمۡ قُوَّةً أَوۡ ءَاوِیۤ إِلَىٰ رُكۡنࣲ شَدِیدࣲ ۝٨٠﴾</q> - آثار متعلقة بالآية ٣٦٠٦٨- عن أبي هريرة، أنّ النبي ﷺ قال: «يغفِر الله لِلُوطٍ، إن كان لَيَأْوِي إلى ركن شديد»{16}. (٨/١١٤) ٣٦٠٦٩- عن أبي بن كعب، قال: قال رسول الله ﷺ: «رَحِم الله لوطًا، إن كان لَيأوي إلى ركن شديد»{17}. (٨/١١٤) ٣٦٠٧٠- عن الحسن، أنّ هذه الآية لَمّا نزلت: <q>﴿لو أن لي بكم قوة أو ءاوي إلى ركن شديد﴾</q> قال رسول الله ﷺ: «رَحِم اللهُ أخي لوطًا، لقد كان يأوي إلى ركن شديد، فلِأَيِّ شيء استكان!»{18}٣٢٦٢. (٨/١١٢) ٣٢٦٢ علَّق ابنُ عطية (٤/٦٢١) على هذا الحديث بقوله: «هذا نقدٌ لأن يلفظ لوط ﵇ هذه الألفاظ، وإلا فحالة النبي ﷺ وقت طُرِح سَلا الجزور، ومع أهل الطائف، وفي غير موطن تقتضي مقالة لوط، لكن محمدًا ﷺ لم ينطق بشيءٍ من ذلك عزامة منه ونجدة، وإنما خشي لوط ﵇ أن يُمْهِل الله أولئك العصاة حتى يعصوه في الأضياف كما أمهلهم فيما قبل ذلك مِن معاصيهم فيمن مضى، فتمنّى ركنًا من البشر يعاجلهم به، وهو يعلم أنّ الله تعالى مِن وراء عقابهم». ٣٦٠٧١- عن عبد الله بن عباس -من طريق عكرمة- قال: ما بعث الله نبيًّا بعد لوطٍ إلا في عِزٍّ مِن قومه{19}. (٨/١١٣) ٣٦٠٧٢- عن عبد الملك ابن جُرَيْج -من طريق حجّاج- في قوله: <q>﴿أو ءاوي إلى ركن شديد﴾</q>، قال: بلغني: أنّه لم يُبعَث نبيٌّ بعد لوطٍ إلا في ثروة مِن قومه، حتى النبي ﷺ{8}. (٨/١١٢) ",footnotes:1:الثروة: العدد الكثير. النهاية (ثرا).أخرجه أحمد ١٤/٥٣٩ (٨٩٨٧)، ١٦/٥٢٤ (١٠٩٠٣)، والترمذي ٥/٣٤٧-٣٤٨ (٣٣٧٨، ٣٣٧٩) بنحوه، وابن حبان ١٤/٨٦ (٦٢٠٦)، ١٤/٨٧-٨٨ (٦٢٠٧)، والحاكم ٢/٦١١ (٤٠٥٤)، وابن جرير ١٢/٥١٠، ٥١١، ٥١٢، وابن أبي حاتم ٦/٢٠٦٤ (١١٠٧٦)، من طريق محمد بن عمرو، عن أبي سلمة، عن أبي هريرة به. قال الترمذي: «وهذا حديث حسن». وقال الحاكم: «هذا حديث صحيح، على شرط مسلم، ولم يخرجاه بهذه الزيادة، إنّما اتفقا على حديث الزهري عن سعيد وأبي عبيد عن أبي هريرة مختصرًا». وقال ابن كثير في البداية والنهاية ١/٤٧٨: «حديث مُنكَر مِن هذا الوجه». وينظر: الألباني في الصحيحة ٤/١٥٢ (١٦١٧)، ٤/٤٨٢-٤٨٥ (١٨٦٧).أخرجه ابن عساكر في تاريخه ٦٤/١٧٢ بنحوه، وعبد الرزاق في تفسيره ٢/٣٥١ (١٧٣٤، ١٧٣٥)، وابن جرير ١٢/٥١٢-٥١٣ واللفظ له.عزاه السيوطي إلى أبي الشيخ.أخرجه ابن أبي حاتم ٦/٢٠٦٤.أخرجه ابن عساكر ٥٠/٣١٣. وعزاه السيوطي إلى إسحاق بن بشر.أخرجه ابن أبي الدنيا في كتاب العقوبات -موسوعة الإمام ابن أبي الدنيا ٤/٤٦٤ (١٤٩)-، وابن أبي حاتم ٦/٢٠٦٤. وعزاه السيوطي إلى عبد الله بن أحمد في زوائد الزهد.أخرجه ابن جرير ١٢/٥٠٩.أخرجه ابن أبي حاتم ٦/٢٠٦٤، وفيه: عن الحسين. وهو تحريف.ذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٢/٣٠٢-.أخرجه ابن جرير في تفسيره ١٢/٥١٣، ٥٢٠، وفي تاريخه ١/٣٠٠.أخرجه عبد الرزاق ١/٣١١، وابن جرير ١٢/٥٠٩-٥١٠، وابن عساكر ٥٠/٣١٠. وذكر نحوه يحيى بن سلام -كما في تفسير ابن أبي زمنين ٢/٣٠٢-.أخرجه ابن جرير ١٢/٥٠٩، وابن أبي حاتم ٦/٢٠٦٤.تفسير مقاتل بن سليمان ٢/٢٩٢.أخرجه ابن جرير ١٢/٥٠٩.أخرجه البخاري ٤/١٤٨ (٣٣٧٥)، ومسلم ٤/١٨٤٠ (١٥١)، وسعيد بن منصور في التفسير من سننه ٥/٣٥٦-٣٥٧ (١٠٩٧).عزاه السيوطي إلى ابن مردويه.أخرجه ابن جرير ١٢/٥١٠.أخرجه سعيد بن منصور (١٠٩٨- تفسير). وعزاه السيوطي إلى أبي الشيخ.أخرجه ابن جرير ١٢/٥٠٩.
11,81," <q>﴿قَالُوا۟ یَـٰلُوطُ إِنَّا رُسُلُ رَبِّكَ لَن یَصِلُوۤا۟ إِلَیۡكَۖ فَأَسۡرِ بِأَهۡلِكَ بِقِطۡعࣲ مِّنَ ٱلَّیۡلِ وَلَا یَلۡتَفِتۡ مِنكُمۡ أَحَدٌ إِلَّا ٱمۡرَأَتَكَۖ إِنَّهُۥ مُصِیبُهَا مَاۤ أَصَابَهُمۡۚ إِنَّ مَوۡعِدَهُمُ ٱلصُّبۡحُۚ أَلَیۡسَ ٱلصُّبۡحُ بِقَرِیبࣲ ۝٨١﴾</q> - قراءات ٣٦٠٧٣- عن هارون، قال: في حرف ابن مسعود: (فَأَسْرِ بِأَهْلِكَ بِقِطْعٍ مِّنَ الَّليْلِ إلّا امْرَأَتَكَ){1}٣٢٦٣. (٨/١١٨) ٣٢٦٣ علَّق ابنُ جرير (١٢/٥٢٥) على هذا الأثر بقوله: «وهذا يدُلُّ على صحة القراءة في المرأة بالنصب». واختلف القرأة في قراءة قوله تعالى: <q>﴿إلا امْرَأَتَكَ﴾</q> على قراءتين: الأولى: <q>﴿إلا امرأتَكَ﴾</q> بالنصب. الثانية: ‹إلّا امْرَأتُكَ› بالرفع. وبيَّن ابنُ جرير (١٢/٥١٤-٥١٥) أنّ المعنى على القراءة الأولى: «فأَسْرِ بأهلك إلا امرأتَك، وعلى أنّ لوطًا أُمِر أن يسري بأهله سوى زوجته، فإنه نُهِيَ أن يَسْرِيَ بها، وأُمِرَ بتخليفها مع قومها». وبيَّن المعنى على القراءة الثانية بقوله: «ولا يلتفت منكم أحدٌ إلا امرأتُك، وإن لوطًا قد أخرجها معه، وأنه نُهِيَ لوطٌ ومَن معه ممن أسرى معه، أن يَلْتَفِتَ سوى زوجته، وإنها التفتت، فهَلَكَت لذلك». ووجَّه ابنُ القيم (٢/٦٠) القراءة الثانية بقوله: «الاستثناء منقطع في قراءة الرفع، ويكون ‹امْرَأتُكَ› مبتدأ، وخبره ما بعده. وهذا التوجيه أولى من أن يُجعَل الاستثناء في قراءة من نصب من قوله: <q>﴿فَأَسْرِ بِأَهْلِكَ﴾</q>، وفي قراءة من رفع مِن قوله: <q>﴿ولا يَلْتَفِتْ مِنكُمْ أحَدٌ﴾</q>، ويكون الاستثناء على هذا مِن <q>﴿فَأَسْرِ بِأَهْلِكَ﴾</q> رفعًا ونصبًا، وإنما قلنا إنّه أولى لأنّ المعنى عليه، فإنّ الله تعالى أمره أن يسري بأهله إلا امرأته، ولو كان الاستثناء مِن الالتفات لكان قد نهى المسري بهم عن الالتفات وأذن فيه لامرأته، وهذا ممتنع لوجهين: أحدهما: أنه لم يأمره أن يسرى بامرأته، ولا دخلت في أهله الذين وعد بنجاتهم. والثاني: أنه لم يكلفهم بعدم الالتفات، ويأذن فيه للمرأة». <q>﴿قَالُوا۟ یَـٰلُوطُ إِنَّا رُسُلُ رَبِّكَ لَن یَصِلُوۤا۟ إِلَیۡكَۖ﴾</q> - تفسير ٣٦٠٧٤- عن عبد الرحمن بن بشر الأنصاري، أنّ رسول الله ﷺ قال: «إنّ الناس كانوا أنذروا قومَ لوط، فجاءتهم الملائكةُ عَشِيَّةً، فمرُّوا بناديهم، فقال قوم لوط بعضُهم لبعض: لا تُنَفِّروهم. ولم يَرَوا قومًا قط أحسن مِن الملائكة، فلمّا دخلوا على لوط ﵇ راوَدُوه عن ضيفه، فلم يزل بهم حتى عرض عليهم بناته، فأبوا، فقالت الملائكة: <q>﴿إنا رسل ربك لن يصلوا إليك﴾</q>. قال: رسل ربي؟ قالوا: نعم. قال لوط: فالآن إذن{2}. (٨/١١٤) ٣٦٠٧٥- عن عبد الله بن عباس -من طريق جويبر، ومقاتل- قال: ... فلمّا لم يتناهوا، ولم يَرُدَّهم قوله، ولم يقبلوا شيئًا مِمّا عرض عليهم من أمر بناته؛ قال: <q>﴿لو أن لي بكم قوة أو ءاوي إلى ركن شديد﴾</q>. يعني: عشيرة أو شيعة تنصُرُني؛ لحُلت بينكم وبين هذا. فكسروا الباب، ودخلوا عليه، وتحوَّل جبريل في صورته التي يكون فيها في السماء، ثم قال: يا لوط، لا تخف، نحن الملائكة، لن يَصِلوا إليك، وأُمِرنا بعذابهم. فقال لوط: يا جبريل، الآن تعذبهم. وهو شديدُ الأسَف عليهم، قال جبريل: موعدُهم الصبح، أليس الصبح بقريب؟ قال ابن عباس: إنّ الله يُعَبِّي العذاب في أول الليل إذا أراد أن يُعذِّب قومًا، ثم يعذبهم في وجه الصبح. قال: فهُيِّئَت الحجارة لقوم لوطٍ في أول الليل لتُرسَل عليهم غُدْوَةً، وكذلك عُذِّبَت الأمم -عاد وثمود- بالغداة، فلما كان عند وجه الصبح عمد جبريل إلى قرى لوط بما فيها؛ من رجالها، ونسائها، وثمارها، وطيرها، فحَواها وطَواها، ثُمَّ قَلَعَها مِن تُخُومِ{3} الثَّرى{4}، ثُمَّ احتمَلها مِن تحت جناحه، ثم رفعها إلى السماء الدنيا، فسمع سكانُ سماء الدنيا أصواتَ الكلاب والطير والرجال والنساء مِن تحت جناح جبريل، ثم أرسلها منكوسة، ثم أتبعها بالحجارة، وكانت الحجارة للرُّعاة والتُّجّار ومَن كان خارِجًا عن مدائنهم{5}. (٨/١٠٩) ٣٦٠٧٦- عن كعب الأحبار -من طريق عبد الله بن رباح- قال: ... لَمّا رأت الرسلُ ما قد لَقِيَ لوطٌ في سببهم قالوا: <q>﴿يا لوط إنا رُسُلُ ربك﴾</q> إنا ملائكة، <q>﴿لن يصلوا إليك فأسر بأهلك بقطع من الليل ولا يلتفت منكم أحد إلا امرأتك﴾</q> إلى قوله: <q>﴿أليس الصبح بقريب﴾</q>. فخرج عليهم جبريل ﵇، فضرب وجوهَهم بجناحه ضربةً، فطمس أعينهم، والطمس: ذهاب الأعين، ثم احتمل جبريل وجه أرضهم حتى سمع أهل سماء الدنيا نُباح كلابهم وأصوات ديوكهم، ثم قلبها عليهم، قال: <q>﴿وأمطرنا عليهم حجارة من سجيل﴾</q>. قال: على أهل بواديهم، وعلى رعائهم، وعلى مسافرهم، فلم يبق منهم أحد{6}. (٨/٩٠) ٣٦٠٧٧- عن سعيد بن جبير -من طريق جعفر- قال: فمَضَتِ الرُّسُلُ مِن عند إبراهيم إلى لوط، فلمّا أتوا لوطًا -وكان مِن أمرهم ما ذكر الله- قال جبريل للوط: يا لوط، <q>﴿إنا مهلكو أهل هذه القرية إن أهلها كانوا ظالمين﴾</q> [العنكبوت:٣١]. فقال لهم لوط: أهلِكوهم الساعةَ. فقال له جبريل ﵇: <q>﴿إن موعدهم الصبح أليس الصبح بقريب﴾</q>؟ فأنزلت على لوط: <q>﴿أليس الصبح بقريب﴾</q>؟ قال: فأمره أن يسري بأهله بقطع من الليل، ولا يلتفت منهم أحد إلا امرأته. قال: فسار، فلمّا كانت الساعة التي أهلكوا فيها أدخل جبريل جناحَه، فرفعها حتى سمع أهل السماء صياح الديكة، ونُباح الكلاب، فجعل عاليها سافلها، وأمطر عليها حجارة من سجيل. قال: وسمعت امرأةُ لوط الهَدَّةَ{7}، فقالت: واقوماه. فأدركها حجرٌ، فقتلها{8}. (ز) ٣٦٠٧٨- عن قتادة بن دعامة -من طريق سعيد بن بشير- قال: انطلقت امرأتُه -يعني: امرأة لوط- حين رأتهم -يعني: حين رأت الرسل- إلى قومها، فقالت: إنّه قد ضافه الليلةَ قومٌ ما رأيت مثلَهم قطُّ أحسنَ وجوهًا، ولا أطيب ريحًا. فجاءوا يُهْرَعون إليه، فبادرهم لوطٌ إلى أن يَزْحَمَهم على الباب، فقال: <q>﴿هؤلاء بناتي إن كنتم فاعلين﴾</q> [الحجر:٧١]. فقالوا: <q>﴿أولم ننهك عن العالمين﴾</q> [الحجر:٧٠]. فدخلوا على الملائكة، فتناولتهم الملائكة، وطمست أعينهم، فقالوا: يا لوطُ، جئتنا بقومٍ سَحَرَةٍ سحرونا، كما أنت حتى تُصْبِح. قال: فاحتمل جبريل قُرَيّات لوط الأربع، في كل قرية مائة ألف، فرفعهم على جناحه بين السماء والأرض، حتى سمع أهل السماء الدنيا أصوات دِيَكَتِهم، ثم قَلَبَهم، فجعل الله عاليها سافلها{9}. (ز) ٣٦٠٧٩- عن محمد بن كعب القرظي -من طريق محمد بن إسحاق- قال: إنّ الرُّسُلَ عند ذلك سَفَعُوا{10} في وجوه القوم الذين جاءوا لوطًا من قومه يُراوِدُونه عن ضيفه، فرجعوا عُمْيانًا. قال: يقول الله: <q>﴿ولقد راودوه عن ضيفه فطمسنا أعينهم﴾</q> [القمر:٣٧]{11}. (ز) ٣٦٠٨٠- عن إسماعيل السُّدِّيّ -من طريق أسباط- قال: لَمّا قال لوط: <q>﴿لو أن لي بكم قوة أو آوي إلى ركن شديد﴾</q> بسط حينئذٍ جبريلُ ﵇ جناحيه، ففقأ أعينَهم، وخرجوا يدوسُ بعضُهم في أدبار بعض عميانًا، يقولون: النَّجاءَ النَّجاءَ؛ فإنّ في بيت لوط أسْحَرَ قومٍ في الأرض. فذلك قوله: <q>﴿ولقد راودوه عن ضيفه فطمسنا أعينهم﴾</q> [القمر:٣٧]. وقالوا للوط: <q>﴿إنا رسل ربك لن يصلوا إليك فأسر بأهلك بقطع من الليل ولا يلتفت منكم أحد إلا امرأتك إنه مصيبها﴾</q>، واتبع أدبار أهلك، يقول: سر بهم، <q>﴿وامضوا حيث تؤمرون﴾</q> [الحجر:٦٥]، فأخرجهم الله إلى الشام، وقال لوط: أهلِكُوهم الساعة. فقالوا: إنا لم نؤمر إلا بالصبح، أليس الصبح بقريب؟ فلمّا أن كان السَّحَر خرج لوطٌ وأهلُه مَعَه{12} امرأتُه، فذلك قوله: <q>﴿إلا آل لوط نجيناهم بسحر﴾</q> [القمر:٣٤]{13}. (ز) ٣٦٠٨١- عن شمر بن عطية -من طريق حفص بن حميد- قال: كان لوطٌ أخَذ على امرأته أن لا تُذِيع شيئًا مِن سِرِّ أضيافه. قال: فلمّا دخل عليه جبريل ومَن معه رَأَتْهم في صورةٍ لم تر مثلَها قطُّ، فانطلقت تسعى إلى قومها، فأتت الناديَ، فقالت بيدها هكذا، وأقبلوا يُهْرَعون مشيًا بين الهرولة والجَمْزِ، فلمّا انتهوا إلى لوط، وقال لهم لوطٌ ما قال الله في كتابه، قال جبريل: <q>﴿يا لوط إنا رسل ربك لن يصلوا إليك﴾</q>. قال: فقال بيده، فطَمَس أعينهم، فجعلوا يطلبونهم، يَلْمَسون الحيطان، وهم لا يُبْصِرون{14}. (ز) ٣٦٠٨٢- قال مقاتل بن سليمان: <q>﴿قالُوا يا لُوطُ﴾</q> قال جبريل للوط: <q>﴿إنّا رُسُلُ رَبِّكَ لَنْ يَصِلُوا إلَيْكَ﴾</q> بسوءٍ. لأنهم قالوا للوط: إنّا نرى معك رجالًا سحروا أبصارنا، فستعلم غدًا ما تلقى أنتَ في أهلك. فقال جبريل ﵇: <q>﴿إنّا رُسُلُ رَبِّكَ لَنْ يَصِلُوا إلَيْكَ﴾</q>{15}. (ز) ٣٦٠٨٣- عن محمد بن إسحاق -من طريق سلمة- قال: لَمّا قال لوطٌ لقومه: <q>﴿لو أن لي بكم قوة أو آوي إلى ركن شديد﴾</q> والرسل تسمع ما يقول، وما يُقال له، ويرون ما هو فيه مِن كَرْبِ ذلك، فلمّا رأوا ما بلغه؛ <q>﴿قالوا يا لوط إنا رسل ربك لن يصلوا إليك﴾</q> أي: بشيء تكرهه{16}. (ز) ٣٦٠٨٤- قال سفيان الثوري: لما جاء الرسل إلى لوط تبعهم أهل قريته، وكان لهم جمال، فلم يقولوا لهم شيئًا، فلما دخلوا على لوطٍ، ورأوا مَوْجِدَةَ{17} لوط عليهم، وما قد دخله مِن خَشْيَتِهم؛ قالوا: <q>﴿إنا رسل ربك لن يصلوا إليك﴾</q>. فلما دنوا أخذوا التراب، فرموهم به، ففَقَئُوا أعينَهم، فذلك قوله: <q>﴿فطمسنا أعينهم﴾</q>، فرجعوا إلى أصحابهم وهم يقولون: سِحْرٌ سحرونا. فقال لوط للرُّسُل: الآنَ الآنَ. يعني: هلاكهم، فقالوا: <q>﴿إن موعدهم الصبح﴾</q> -فقال ابن عباس: ثلاثة أحرف في القرآن لا يحفظون{18}، ألا ترى أنّه قول الله: <q>﴿أليس الصبح بقريب﴾</q>، والحرفان الآخران، ثم أتبعهم <q>﴿إن الملوك إذا دخلوا قرية أفسدوها وجعلوا أعزة أهلها أذله﴾</q> قال الله: <q>﴿وكذلك يفعلون﴾</q> [النمل:٣٤]. وقول ليوسف: <q>﴿ليعلم أني لم أخنه بالغيب وأن الله لا يهدي كيد الخائنين﴾</q> فقال له مَلَكٌ مِن الملائكة: ولا حين هممت قال: <q>﴿وما أبرئ نفسي﴾</q> [يوسف:٥٢] فرجع.- فرفع جبريل ﵇ القريةَ بجناحه، فدَحْدَها{19} وما فيها، حتى أسمع أهل السماء الدنيا أصواتهم، ثم قلبها، ثُمَّ تتبع مَن شَذَّ منهم بالحجارة{20}. (ز) <q>﴿فَأَسۡرِ بِأَهۡلِكَ﴾</q> - تفسير ٣٦٠٨٥- عن إسماعيل السُّدِّيّ -من طريق أسباط- في قوله: <q>﴿فأسر بأهلك﴾</q>، يقول: سِرْ بهم{21}. (٨/١١٧) ٣٦٠٨٦- قال مقاتل بن سليمان: <q>﴿فَأَسْرِ بِأَهْلِكَ﴾</q>، يعني: امرأته، وابنتيه{22}. (ز) <q>﴿بِقِطۡعࣲ مِّنَ ٱلَّیۡلِ﴾</q> - تفسير ٣٦٠٨٧- عن عبد الله بن عباس -من طريق ابن جُرَيْج- في قوله: <q>﴿بقطع من الليل﴾</q>، قال: جوف الليل{23}. (٨/١١٧) ٣٦٠٨٨- عن عبد الله بن عباس -من طريق علي- في قوله: <q>﴿بقطع﴾</q>، قال: سواد مِن الليل{24}. (٨/١١٧) ٣٦٠٨٩- عن عبد الله بن عباس -من طريق علي- في قوله: <q>﴿بقطع من الليل﴾</q>: بطائفة مِن الليل{25}. (ز) ٣٦٠٩٠- عن عبد الله بن عباس: أنّ نافع بن الأزرق قال له: أخبِرني عن قول الله: <q>﴿فأسر بأهلك بقطع من الليل﴾</q>، ما القِطْع؟ قال: آخِر الليلُ سَحَر، قال مالك بن كنانة: ونائحة تقوم بقطع ليل على رجُل أهانته شَعُوب{26}{27}. (٨/١١٨) ٣٦٠٩١- قال الضحاك بن مزاحم، في قوله: <q>﴿بقطع من الليل﴾</q>: ببَقِيَّة{28}. (ز) ٣٦٠٩٢- عن قتادة بن دعامة -من طريق معمر- في قوله: <q>﴿بقطع من الليل﴾</q>، قال: بطائِفَة من الليل{29}. (٨/١١٨) ٣٦٠٩٣- قال قتادة بن دعامة، في قوله: <q>﴿بقطع من الليل﴾</q>: بعد مُضِيِّ أوله{28}. (ز) ٣٦٠٩٤- قال قتادة بن دعامة، في قوله: <q>﴿فأسر بأهلك بقطع من الليل﴾</q>: أي: سِرْ بهم في ظُلْمَةٍ مِن الليل{31}. (ز) ٣٦٠٩٥- قال مقاتل بن سليمان: <q>﴿بِقِطْعٍ مِنَ اللَّيْلِ﴾</q>، يعني: ببعض الليل{22}. (ز) ٣٦٠٩٦- عن أبي صخر [حميد بن زياد]-من طريق المفضل بن فضالة- في قوله: <q>﴿فأسر بأهلك بقطع من الليل﴾</q>، قال: السَّحَر الأول{21}. (ز) <q>﴿وَلَا یَلۡتَفِتۡ مِنكُمۡ أَحَدٌ إِلَّا ٱمۡرَأَتَكَۖ﴾</q> - تفسير ٣٦٠٩٧- عن عبد الله بن عباس -من طريق الضحاك- في قوله: <q>﴿ولا يلتفت منكم أحد﴾</q>، قال: لا يَتَخَلَّف{21}٣٢٦٤. (٨/١١٨) ٣٢٦٤ استظهر ابنُ عطية (٤/٦٢٥) في <q>﴿يلتفت﴾</q> أنّها مِن التفات البصر، ثم نقل عن فرقة في قوله تعالى: <q>﴿يَلْتَفِتْ﴾</q>: أنها «من لَفَتَ الشيء يلفته إذا ثَناه ولواه، والمعنى: ولا يَتَثَبَّط». ثم استدرك على قولهم قائلًا: «وهذا شاذٌّ مع صِحَّته». ٣٦٠٩٨- عن مجاهد بن جبر -من طريق ابن جُرَيْج- في قوله: <q>﴿ولا يلتفت منكم أحد﴾</q>، قال: لا ينظر وراءَه أحدٌ{35}. (٨/١١٨) ٣٦٠٩٩- قال مقاتل بن سليمان: <q>﴿ولا يَلْتَفِتْ مِنكُمْ أحَدٌ﴾</q> ألْبَتَّة <q>﴿إلّا امْرَأَتَكَ﴾</q> فإنها تلتفت، يقول: لا ينظر منكم أحدٌ وراءَه. ثم استثنى: <q>﴿إلّا امْرَأَتَكَ﴾</q> تلتفت{15}. (ز) <q>﴿إِنَّهُۥ مُصِیبُهَا مَاۤ أَصَابَهُمۡۚ إِنَّ مَوۡعِدَهُمُ ٱلصُّبۡحُۚ أَلَیۡسَ ٱلصُّبۡحُ بِقَرِیبࣲ ۝٨١﴾</q> - تفسير ٣٦١٠٠- عن سعيد بن جبير -من طريق جعفر- قال: قال له لوط: أهلِكوهم الساعةَ. قال له جبريل ﵇: إنّ موعدهم الصبح، أليس الصبح بقريب؟! فأُنزِلت على لوط: <q>﴿أليس الصبح بقريب﴾</q>. قال: فأمره أن يسري بأهله بقِطْع من الليل، ولا يلتفت منهم أحد إلا امرأته، فسار، فلمّا كانت الساعةُ التي أُهلِكوا فيها أدْخَلَ جبريلُ ﵇ جناحه، فرفعها حتى سمع أهل السماء صياح الديكة ونباح الكلاب، فجعل عاليَها سافلها، وأمطر عليها حجارة من سجيل، وسمعت امرأة لوطٍ الهدَّة، فقالت: واقوماه! فأدركها حجرٌ فقتلها{37}. (٨/١١٩) ٣٦١٠١- قال قتادة بن دعامة، في قوله: <q>﴿يا لوط إنا رسل ربك لن يصلوا إليك فأسر بأهلك بقطع من الليل﴾</q> أي: سر بهم في ظُلْمَةٍ من الليل، <q>﴿ولا يلتفت منكم أحد إلا امرأتك إنه مصيبها ما أصابهم﴾</q> فقال: لا؛ بل أهلكوهم الساعةَ! فقالوا: <q>﴿إن موعدهم الصبح أليس الصبح بقريب﴾</q>. فطمس جبريلُ ﵇ أعينَهم بأحد جناحيه، فبقوا ليلتهم لا يُبْصِرون{31}. (ز) ٣٦١٠٢- عن قتادة بن دعامة -من طريق سعيد- قال: ذُكِر لنا: أنّها كانت مع لوط لَمّا خرج مِن القرية، فسمعت الصوتَ، فالتَفَتَتْ، فأرسل اللهُ عليها حجرًا، فأهلكها، فهي معلوم مكانُها شاذَّةً عن القوم، وهي في مصحف عبد الله [بن مسعود]: (ولَقَدْ وفَيْنَآ إلَيْهِ أهْلَهُ كُلَّهُمْ إلّا عَجُوزًا فِي الغبر). قال: ولَمّا قيل له: <q>﴿إن موعدهم الصبح﴾</q>. قال: إنِّي أريد أعجَلَ من ذلك. قال: <q>﴿أليس الصبح بقريب﴾</q>{39}. (٨/١١٨) ٣٦١٠٣- عن إسماعيل السُّدِّيّ -من طريق أسباط- قال: قال لوط: أهلِكوهم الساعةَ. قالوا: إنّا لم نؤمر إلا بالصبح، <q>﴿أليس الصبح بقريب﴾</q>؟!{40}. (٨/١١٩) ٣٦١٠٤- قال مقاتل بن سليمان: <q>﴿إنَّهُ مُصِيبُها﴾</q> مِن العذاب <q>﴿ما أصابَهُمْ﴾</q> يعني: قوم لوط، فالتَفَتَتْ، فأصابها حجرٌ، فقتلها. ثم قال: <q>﴿إنَّ مَوْعِدَهُمُ الصُّبْحُ﴾</q> ثم يهلكون، قال لوط لجبريل: عَجِّل عَلَيَّ بهلاكهم الآنَ. فردَّ عليه جبريل: <q>﴿ألَيْسَ الصُّبْحُ بِقَرِيبٍ﴾</q>؟!{15}. (ز) ٣٦١٠٥- عن محمد بن إسحاق -من طريق سلمة- <q>﴿إن موعدهم الصبح أليس الصبح بقريب﴾</q>، أي: إنّما ينزل بهم العذابُ مِن صبح ليلتِك هذه، فامضِ لِما تُؤْمَر{42}. (ز) ",footnotes:1:أخرجه ابن جرير ١٢/٥٢٥، وابن أبي داود في المصاحف ١/٣١٩. وعزاه السيوطي إلى أبي عبيد. (فَأَسْرِ بِأَهْلِكَ بِقِطْعٍ مِّنَ الَّليْلِ إلّا امْرَأَتَكَ) بحذف <q>﴿ولا يلتفت منكم أحد﴾</q> قراءة شاذة. <q>﴿إلّا امْرَأَتَكَ﴾</q> بالنصب قراءة متواترة، قرأ بها العشرة ما عدا ابن كثير، وأبا عمرو، وهما قرآ بالرفع. انظر: النشر ٢/٢٩٠، والإتحاف ص٣٢٥.أخرجه ابن أبي حاتم ٦/٢٠٦٠ (١١٠٥٠)، ٦/٢٠٦٦ (١١٠٩١)، ٩/٣٠٥٧ (١٧٢٨٥).التَّخْمُ: مُنتهى كل قرية أو أرض. لسان العرب (تَخَمَ).الثَّرى: التُّراب. النهاية (ثرا).أخرجه ابن عساكر ٥٠/٣١٣. وعزاه السيوطي إلى إسحاق بن بشر.أخرجه ابن أبي الدنيا في كتاب العقوبات -موسوعة الإمام ابن أبي الدنيا ٤/٤٦٤ (١٤٩)-. وعزاه السيوطي إلى عبد الله بن أحمد في زوائد الزهد.الهَدَّة: صوت شديد تسمعه من سقوط ركن أو حائط أو ناحية جبل. لسان العرب (هدد).أخرجه ابن جرير ١٢/٥١٥.أخرجه ابن جرير ١٢/٥١٧.أي: لطموا. لسان العرب (سفع).أخرجه ابن جرير ١٢/٥٢٣.ذكر محققو تفسير ابن جرير أن بعده في تاريخ ابن جرير: «إلا».أخرجه ابن جرير ١٢/٥١٩.أخرجه ابن جرير ١٢/٥١٦، وابن أبي حاتم ٦/٢٠٦٢.تفسير مقاتل بن سليمان ٢/٢٩٢-٢٩٣.أخرجه ابن جرير ١٢/٥٢٣، وابن أبي حاتم ٦/٢٠٦٥ مختصرًا.أي: غضب. النهاية (وجد).كذا في المطبوع، وظاهرٌ ما في الأثر من سقط أو تصحيف. ومراد ابن عباس هنا الموصول لفظًا المفصول معنى. ينظر: الإتقان ١/ ٣٠٩.ذكر محقق المصدر أنها كذا بالأصل.تفسير سفيان الثوري ص١٣١-١٣٢.أخرجه ابن أبي حاتم ٦/٢٠٦٥.تفسير مقاتل بن سليمان ٢/٢٩٣.أخرجه ابن جرير ١٢/٥٢٤. وعزاه السيوطي إلى ابن المنذر، وأبي الشيخ.أخرجه ابن أبي حاتم ٦/٢٠٦٥. وعزاه السيوطي إلى ابن جرير، وابن المنذر. ولفظ ابن جرير ما سيأتي.أخرجه ابن جرير ١٢/٥٢٤.شَعُوب: من أسماء المنية. النهاية (شعب).عزاه السيوطي إلى ابن الأنباري في الوقف والابتداء.تفسير البغوي ٤/١٩٣.أخرجه عبد الرزاق ١/٣٠٩، وابن جرير ١٢/٥٢٤.تفسير البغوي ٤/١٩٣.ذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٢/٣٠٢-.تفسير مقاتل بن سليمان ٢/٢٩٣.أخرجه ابن أبي حاتم ٦/٢٠٦٥.أخرجه ابن أبي حاتم ٦/٢٠٦٥.أخرجه ابن جرير ١٢/٥٢٤، وابن أبي حاتم ٦/٢٠٦٦. وعزاه السيوطي إلى ابن المنذر.تفسير مقاتل بن سليمان ٢/٢٩٢-٢٩٣.أخرجه ابن جرير في التفسير ١٢/٥١٥-٥١٦، وفي التاريخ ١/٣٠١، وابن أبي حاتم ٦/٢٠٦٧ مختصرًا. وعزاه السيوطي إلى ابن المنذر.ذكره يحيى بن سلام -كما في تفسير ابن أبي زمنين ٢/٣٠٢-.أخرجه ابن أبي حاتم ٦/٢٠٦٦ وليس فيه قراءة ابن مسعود. وعزاه السيوطي إلى أبي الشيخ. وقراءة ابن مسعود شاذة.أخرجه ابن جرير ١٢/٥١٩، وابن أبي حاتم ٦/٢٠٦٧.تفسير مقاتل بن سليمان ٢/٢٩٢-٢٩٣.أخرجه ابن جرير ١٢/٥٢٣، وابن أبي حاتم ٦/٢٠٦٧.
