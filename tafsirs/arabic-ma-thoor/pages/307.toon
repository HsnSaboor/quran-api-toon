tafsir[13]{c,v,t}:
19,26," <q>﴿فَكُلِی وَٱشۡرَبِی وَقَرِّی عَیۡنࣰاۖ﴾</q> - تفسير ٤٦٥٠٤- قال مقاتل بن سليمان: <q>﴿فكلي﴾</q> مِن النخلة، <q>﴿واشربي﴾</q> مِن الماء العَذْب، <q>﴿وقري عينا﴾</q> بالولد{1}. (ز) ٤٦٥٠٥- قال يحيى بن سلّام: <q>﴿فكلي واشربي﴾</q> فكلي مِن الرطب، واشربي من الجدول{2}. (ز) <q>﴿فَإِمَّا تَرَیِنَّ مِنَ ٱلۡبَشَرِ أَحَدࣰا فَقُولِیۤ إِنِّی نَذَرۡتُ لِلرَّحۡمَـٰنِ صَوۡمࣰا فَلَنۡ أُكَلِّمَ ٱلۡیَوۡمَ إِنسِیࣰّا ۝٢٦﴾</q> - قراءات ٤٦٥٠٦- عن الشعبي، قال: في قراءة أُبَيّ بن كعب: (إنِّي نَذَرْتُ لِلرَّحْمَنِ صَوْمًا صَمْتًا){3}. (١٠/٦٣) ٤٦٥٠٧- عن عبد الله بن عباس أنّه قرأها: (إنِّي نَذَرْتُ لِلرَّحْمَنِ صَوْمًا صَمْتًا). وقال: ليس إلا أن حَمَلَتْ فوَضَعَتْ{4}. (١٠/٦٢) ٤٦٥٠٨- عن أنس بن مالك أنّه كان يقرأ: (إنِّي نَذَرْتُ لِلرَّحْمَنِ صَوْمًا صَمْتًا){5}. (١٠/٦٢) ٤٦٥٠٩- عن قتادة بن دعامة -من طريق سعيد- <q>﴿صَوْمًا﴾</q>، قال: كانت تقرأ في الحرف الأول: (صَمْتًا){6}. (ز) <q>﴿فَإِمَّا تَرَیِنَّ مِنَ ٱلۡبَشَرِ أَحَدࣰا فَقُولِیۤ إِنِّی نَذَرۡتُ لِلرَّحۡمَـٰنِ صَوۡمࣰا فَلَنۡ أُكَلِّمَ ٱلۡیَوۡمَ إِنسِیࣰّا ۝٢٦﴾</q> - تفسير الآية ٤٦٥١٠- عن حارثة بن مُضَرِّبٍ، قال: كنت عند عبد الله بن مسعود، فجاء رجلان، فسَلَّم أحدُهما، ولم يُسَلِّم الآخر، ثم جلسا، فقال القوم: ما لِصاحبك لَم يُسَلِّم؟ قال: إنّه نذر صومًا لا يُكَلِّم اليومَ إنسيًا. فقال عبد الله: بئس ما قلتَ! إنّما كانت تلك المرأة، فقالت ذلك ليكون عذرًا لها إذا سُئِلت، وكانوا يُنكِرون أن يكون ولدٌ مِن غير زَوج إلا زِنًا، تكلَّمْ، وأْمُر بالمعروف، وانْهَ عن المنكر؛ فإنّه خير لك{7}. (١٠/٦٣) ٤٦٥١١- عن عبد الله بن عباس -من طريق عكرمة- في قوله: <q>﴿إني نذرت للرحمن صوما﴾</q>: يعني: صمتًا{8}. (ز) ٤٦٥١٢- عن عبد الله بن عباس -من طريق العوفي- في قوله: <q>﴿إني نذرت للرحمن صوما﴾</q>، قال: صَمْتًا{9}٤١٥٧. (١٠/٦٢) ٤١٥٧ وجَّهَ ابنُ عطية (٦/٢٦) هذا القول بقوله: «إذ أصل الصيام: الإمساك». ٤٦٥١٣- عن عامر الشعبي، مثله{10}. (١٠/٦٢) ٤٦٥١٤- عن سليمان التيمي، قال: سمعت أنس بن مالك يقول في هذه الآية: <q>﴿إني نذرت للرحمن صوما﴾</q>، قال: صَمْتًا{11}. (ز) ٤٦٥١٥- عن الضَّحّاك بن مُزاحِم -من طريق عبيد- في قوله: <q>﴿نذرت للرحمن صوما﴾</q>: يعني: صَمْتًا{12}. (ز) ٤٦٥١٦- عن وهب بن مُنَبِّه -من طريق ابن إسحاق، عمَّن لا يتهم-: <q>﴿فإما ترين من البشر أحدا فقولي إني نذرت للرحمن صوما فلن أكلم اليوم إنسيا﴾</q> فإنِّي سَأَكْفِيكِ الكلامَ{13}. (ز) ٤٦٥١٧- عن قتادة بن دعامة -من طريق معمر- في قوله تعالى: <q>﴿إني نذرت للرحمن صوما﴾</q>: ... وإنّك لا تشأ أن تلقى امرأةً جاهلة تقول: نذرت كما نذرت مريم؛ ألا تكلم يومًا إلى الليل، وإنما جعل الله تلك آيةً لمريم وابنها، ولا يحِلُّ لأحدٍ أن ينذر صمتَ يوم إلى الليل. وأما قوله: <q>﴿صوما﴾</q> فإنّها صامت مِن الطعام والشراب والكلام{14}. (ز) ٤٦٥١٨- عن إسماعيل السُّدِّيّ -من طريق أسباط-: <q>﴿فإما ترين من البشر أحدا﴾</q> يُكلِّمك؛ <q>﴿فقولي إني نذرت للرحمن صوما فلن أكلم اليوم إنسيا﴾</q>. فكان مَن صام في ذلك الزمان لم يتكلم حتى يمسي، فقال لها: لا تزيدي على هذا{15}. (ز) ٤٦٥١٩- قال مقاتل بن سليمان: <q>﴿فإما ترين من البشر أحدا فقولي إني نذرت للرحمن صوما﴾</q> يعني: صمتًا، <q>﴿فلن أكلم اليوم إنسيا﴾</q> في عيسى ﷺ{1}. (ز) ٤٦٥٢٠- قال عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب-: لَمّا قال عيسى لمريم: لا تحزني. قالت: وكيف لا أحزن وأنتَ معي؟! لا ذات زوج، ولا مملوكة، أيُّ شيءٍ عُذْري عند الناس؟! <q>﴿يا ليتني مت قبل هذا وكنت نسيا منسيا﴾</q>. فقال لها عيسى: أنا أكفيك الكلام، <q>﴿فإما ترين من البشر أحدا فقولي إني نذرت للرحمن صوما فلن أكلم اليوم إنسيا﴾</q>. قال: هذا كلُّه كلام عيسى لأُمِّه{17}. (ز) ٤٦٥٢١- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿إني نذرت للرحمن صوما﴾</q>، قال: كان مِن بني إسرائيل مَن إذا اجتهد صام مِن الكلام كما يصوم من الطعام، إلا مِن ذكر الله، فقال ذلك لها كذلك، فقالت: إني أصوم من الكلام كما أصوم من الطعام، إلا مِن ذكر الله. فلما كلَّموها أشارت إليه، فقالوا: <q>﴿كيف نكلم من كان في المهد صبيا﴾</q>؟! فأجابهم، فقال: <q>﴿إنِّي عَبْدُاللَّهِ آتانِيَ الكِتابَ وجَعَلَنِي نَبِيًّا (٣٠) وجَعَلَنِي مُبارَكًا أيْنَما كُنْتُ وأَوْصانِي بِالصَّلاةِ والزَّكاةِ مادُمْتُ حَيًّا (٣١) وبَرًّا بِوالِدَتِي ولَمْ يَجْعَلْنِي جَبّارًا شَقِيًّا (٣٢) والسَّلامُ عَلَيَّ يَوْمَ وُلِدْتُ ويَوْمَ أمُوتُ ويَوْمَ أُبْعَثُ حَيًّا (٣٣)﴾</q>{18}. (١٠/٦٢) ٤٦٥٢٢- عن يحيى بن سلّام، <q>﴿فلن أكلم اليوم إنسيا﴾</q>، قال: بلغني: أنّه أُذِن لها في هذا الكلام{19}٤١٥٨. (ز) ٤١٥٨ ذكر ابنُ عطية (٦/ ٢٦) أنّ هذا القول هو ظاهر الآية، وأنه قول الجمهور. وذكر أنّ هناك من قالوا: معنى [قُولي] يريد به: بالإشارة لا بالكلام، وإلا كان التناقض بيِّنًا في كلامها. وذكر (٦/٢٨) أنّه يُقَوِّيه أن مريم التزمت ما أُمِرَت به من ترك الكلام، ولم يَرد أنها نطقت بقوله: <q>﴿إني نذرت ...﴾</q> وإنما أشارت. ",footnotes:1:تفسير مقاتل بن سليمان ٢/٦٢٥.تفسير يحيى بن سلام ١/٢٢١.عزاه السيوطي إلى ابن الأنباري. وأخرجه الطبراني -كما في الفتح ٩/٤٤٠- عن أبي بن كعب على أنه تفسير له وليس قراءة. وقراءة (صَوْمًا صَمْتًا) أو (صَمْتًا) بدل <q>﴿صَوْما﴾</q> شاذَّة، تروى أولاهما عن أنس بن مالك أيضًا. انظر: مختصر ابن خالويه ص٨٧.عزاه السيوطي إلى عبد بن حميد، وابن الأنباري.أخرجه ابن جرير ١٥/٥١٧. وعلَّقه يحيى بن سلام ١/٢٢١. وعزاه السيوطي إلى الفريابي، وعبد بن حميد، وابن المنذر، وابن أبي حاتم، وابن الأنباري في المصاحف، وابن مردويه.أخرجه يحيى بن سلام ١/٢٢٢، وابن جرير ١٥/٥١٩ من طريق معمر.أخرجه ابن جرير ١٥/٥١٨. وعزاه السيوطي إلى ابن أبي حاتم.أخرجه مقاتل بن سليمان ٢/٦٢٥.أخرجه ابن جرير ١٥/٥١٧، وإسحاق البستي في تفسيره ص١٨٨ من طريق المغيرة بن عبد الله الثقفي، وابن عساكر ٧٠/٩١. وعزاه السيوطي إلى ابن مردويه، وابن المنذر.عزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ١٥/٥١٦.أخرجه ابن جرير ١٥/٥١٧، وإسحاق البستي في تفسيره ص١٨٩.أخرجه ابن جرير ١٥/٥١٩.أخرجه عبد الرزاق ٢/٧، وابن جرير ١٥/٥١٧، ٥١٩. وأخرجه يحيى بن سلام ١/٢٢١ مختصرًا من طريق سعيد.أخرجه ابن جرير ١٥/٥٢٠.تفسير مقاتل بن سليمان ٢/٦٢٥.أخرجه ابن جرير ١٥/٥١٨.أخرجه ابن جرير ١٥/٥١٧. وعزاه السيوطي إلى ابن أبي حاتم مختصرًا.تفسير يحيى بن سلام ١/٢٢٢.
19,27," <q>﴿فَأَتَتۡ بِهِۦ قَوۡمَهَا تَحۡمِلُهُۥۖ﴾</q> - تفسير ٤٦٥٢٣- عن عبد الله بن عباس -من طريق الكلبي، عن أبي صالح- في قوله: <q>﴿فأتت به قومها تحمله﴾</q>، قال: بعد أربعين يومًا، بعد ما تعالَّت مِن نِفاسها{1}. (١٠/٦٣) ٤٦٥٢٤- عن وهب بن مُنَبِّه -من طريق ابن إسحاق، عمَّن لا يتهم- قال: أنساها -يعني: مريم- كَرْبُ البلاء وخَوْفُ الناس ما كانت تسمع -يعني: ما كانت تسمع مِن الملائكة من البشارة بعيسى-، حتى إذا كلمها -يعني: عيسى- وجاءها مِصداقُ ما كان الله وعَدَها احْتَمَلَتْه، ثم أقْبَلَتْ به إلى قومها{2}. (ز) ٤٦٥٢٥- عن إسماعيل السُّدِّيّ -من طريق أسباط- قال: لَمّا ولدته ذهب الشيطان، فأخبر بني إسرائيل أنّ مريم قد ولدت، فأقبلوا يَشْتَدُّون، فَدَعَوْها، <q>﴿فأتت به قومها تحمله﴾</q>{3}. (ز) ٤٦٥٢٦- قال محمد بن السائب الكلبي: حمل يوسف النجار مريمَ وابنَها عيسى ﵉ إلى غار، ومكثت أربعين يومًا حتى طهُرَت مِن نفاسها، ثم حملته مريم ﵍ إلى قومها، فكلَّمها عيسى ﵇ في الطريق، فقال: يا أُمّاه، أبشِرِي؛ فإنِّي عبدُ الله ومسيحُه، فلمّا دخلت على أهلها ومعها الصبيُّ بَكَوا وحزنوا، وكانوا أهلَ بيت صالحين، و<q>﴿قالُوا يا مَرْيَمُ لَقَدْ جِئْتِ شَيْئًا فَرِيًّا﴾</q>{4}. (ز) ٤٦٥٢٧- قال مقاتل بن سليمان: <q>﴿فأتت به قومها﴾</q> بالولد، <q>﴿تحمله﴾</q> إلى بني إسرائيل في حِجْرِها ملفوفًا في خِرَق{5}. (ز) <q>﴿قَالُوا۟ یَـٰمَرۡیَمُ لَقَدۡ جِئۡتِ﴾</q> - قراءات ٤٦٥٢٨- عن أبي بكر بن عياش، قال: في قراءة أُبيّ [بن كعب]: (قالُواْ يا ذا المَهْدِ){6}. (١٠/٦٦) <q>﴿قَالُوا۟ یَـٰمَرۡیَمُ لَقَدۡ جِئۡتِ﴾</q> - تفسير الآية ٤٦٥٢٩- في تفسير مجاهد بن جبر= (ز) ٤٦٥٣٠- وقتادة بن دعامة، قوله: <q>﴿لقد جئت﴾</q>: لقد أتَيْتِ{7}. (ز) <q>﴿شَیۡـࣰٔا فَرِیࣰّا ۝٢٧﴾</q> - تفسير ٤٦٥٣١- عن نوف البِكالِيِّ -من طريق أبي عمران الجَوْني- قال: وخرج قومُها في طلبها، وكانت من أهل بيت نبوة وشرف، فلم يُحِسُّوا منها شيئًا، فرأوا راعي بقر، فقالوا: رأيتَ فتاةً كذا وكذا نَعْتُها؟ قال: لا، ولكني رأيتُ الليلة مِن بقري ما لم أره منها قطُّ. قالوا: وما رأيتَ؟ قال: رأيتُها سُجَّدًا نحو هذا الوادي. -قال عبد الله بن أبي زياد: وأحفظ عن سيّار أنه قال: رأيت نورًا ساطعًا-. فتوجَّهُوا حيث قال لهم، فاستقبلتهم مريم، فلمّا رأتهم قعدت، وحملت ابنها في حِجْرها، فجاءوا حتى قاموا عليها، <q>﴿قالُوا يا مَرْيَمُ لَقَدْ جِئْتِ شَيْئًا فَرِيًّا﴾</q>: أمرًا عظيمًا{8}. (١٠/٤٦) ٤٦٥٣٢- عن مجاهد بن جبر -من طريق ابن أبي نَجِيحٍ- في قوله: <q>﴿لقد جئت شيئا فريا﴾</q>، قال: عظيمًا{9}. (١٠/٦٣) ٤٦٥٣٣- عن وهب بن مُنَبِّه -من طريق ابن إسحاق، عمَّن لا يتهم- قال: لَمّا رأوها ورَأَوْهُ معها قالوا: <q>﴿يا مريم لقد جئت شيئا فريا﴾</q>، أي: الفاحشة غير المقاربة{10}. (ز) ٤٦٥٣٤- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿لقد جئت شيئا فريا﴾</q>، قال: عظيمًا{11}. (١٠/٦٣) ٤٦٥٣٥- عن إسماعيل السُّدِّيّ -من طريق أسباط- <q>﴿لقد جئت شيئا فريا﴾</q>، يقول: عظيمًا{10}. (ز) ٤٦٥٣٦- قال محمد بن السائب الكلبي: <q>﴿لَقَدْ جِئْتِ شَيْئًا فَرِيًّا﴾</q> فظيعًا منكرًا عظيمًا {4}. (ز) ٤٦٥٣٧- قال مقاتل بن سليمان: <q>﴿قالوا يامريم لقد جئت شيئا فريا﴾</q>، يقول: أتيتِ أمرًا مُنكرًا{5}. (ز) ٤٦٥٣٨- عن سفيان الثوري، في قوله: <q>﴿لقد جئت شيئا فريا﴾</q>، قال: شيئًا عظيمًا{15}. (ز) <q>﴿شَیۡـࣰٔا فَرِیࣰّا ۝٢٧﴾</q> - آثار متعلقة بالآية ٤٦٥٣٩- عن سعيد بن عبد العزيز، قال: كان في زمان بني إسرائيل في بيت المقدس عند عين سُلوان عينٌ، فكانت المرأةُ إذا قارفت أتَوْها بِها، فشَرِبَتْ منها، فإن كانت بريئةً لم تَضُرَّها، وإلا ماتت، فلما حملت مريم أتَوْها بها، وحملوها على بَغْلَةٍ، فعثَرت بها، فدعت الله أن يَعْقُمَ رحمها، فعُقِمت من يومئذ، فلمّا أتتها شربت منها، فلم تزدد إلا خيرًا، ثم دعت الله ألا يفضح بها امرأة مؤمنة، فَغارَتِ العينُ{16}. (١٠/٦٤) ",footnotes:1:أخرجه ابن عساكر ٧٠/٩٦. وعزاه السيوطي إلى سعيد ين منصور.أخرجه ابن جرير ١٥/٥٢٠.أخرجه ابن جرير ١٥/٥٢١.تفسير الثعلبي ٦/٢١٢، وتفسير البغوي ٥/٢٢٨.تفسير مقاتل بن سليمان ٢/٦٢٥.عزاه السيوطي إلى ابن أبي حاتم. وهي قراءة شاذة.علَّقه يحيى بن سلام١/٢٢٢.أخرجه ابن أبي حاتم -كما في تفسير ابن كثير ٣/٢٢٦-، وابن عساكر في تاريخ دمشق ٧٠/٨٥. وعزاه السيوطي إلى عبد الله بن أحمد في زوائد الزهد.أخرجه ابن جرير ١٥/٥٢١، وإسحاق البستي في تفسيره ص١٨٩ من طريق ابن جريج. وعلَّقه يحيى بن سلام ١/٢٢٢. وعزاه السيوطي إلى ابن أبي شيبة، وعبد بن حميد، وابن المنذر، وابن أبي حاتم.أخرجه ابن جرير ١٥/٥٢٢.أخرجه ابن جرير ١٥/٥٢٢. وعلَّقه يحيى بن سلام ١/٢٢٢. وعزاه السيوطي إلى عبد الله بن أحمد في زوائد الزهد.أخرجه ابن جرير ١٥/٥٢٢.تفسير الثعلبي ٦/٢١٢، وتفسير البغوي ٥/٢٢٨.تفسير مقاتل بن سليمان ٢/٦٢٥.تفسير الثوري ص١٨٤.عزاه السيوطي إلى ابن أبي حاتم.
19,28," <q>﴿یَـٰۤأُخۡتَ هَـٰرُونَ﴾</q> - تفسير ٤٦٥٤٠- عن المغيرة بن شعبة، قال: بعثني رسول الله ﷺ إلى أهل نجران، فقالوا: أرأيت ما تقرءون: <q>﴿يا أخت هارون﴾</q>، وموسى قبل عيسى بكذا وكذا! قال: فرجعتُ، فذكرتُ ذلك لرسول الله ﷺ، فقال: «ألا أخبرتَهم أنّهُم كانوا يُسَمُّون بالأنبياء والصالحين قبلهم»{1}٤١٥٩. (١٠/٦٤) ٤١٥٩ علَّق ابنُ كثير (٩/٢٤٠-٢٤١) على هذا الحديث بقوله: «انفرد بإخراجه مسلم، والترمذي، والنسائي، من حديث عبد الله بن إدريس، عن أبيه، عن سماك، به، وقال الترمذي: حسن صحيح غريب، لا نعرفه إلا من حديث ابن إدريس». ٤٦٥٤١- عن محمد بن سيرين، قال: نُبِّئْتُ: أنّ كعبًا قال: إنّ قوله: <q>﴿يا أخت هارون﴾</q> ليس بهارون أخي موسى. فقالت له عائشة: كذبتَ. فقال: يا أمَّ المؤمنين، إن كان النبيُّ ﷺ قاله فهو أعلمُ وخيرٌ، وإلا فإنِّي أجدُ بينهما ستمائة سنة. فسَكَتَتْ{2}٤١٦٠. (١٠/٦٦) ٤١٦٠ انتقد ابنُ كثير (٩/٢٤١) هذا التاريخ الذي في الأثر بقوله: «وفي هذا التاريخ نظر». ٤٦٥٤٢- عن نوف البِكاليّ -من طريق أبي عمران الجَوْني- قال: <q>﴿يا أُخْتَ هارُونَ﴾</q>، أي: يا شبيهة هارون في العبادة{3}. (ز) ٤٦٥٤٣- عن سعيد بن جبير، في قوله: <q>﴿يا أخت هارون﴾</q>، قال: كان هارونُ مِن قوم سوءٍ زُناة، فنسبوها إليهم{4}. (١٠/٦٦) ٤٦٥٤٤- عن مجاهد بن جبر -من طريق ابن أبي نَجِيحٍ- في قوله: <q>﴿يا أخت هارون﴾</q>، قال: رجلًا صالِحًا في بني إسرائيل، حضر جنازته أربعون ألفًا مِمَّن اسمه هارون سواه{5}. (١٠/٦٥) ٤٦٥٤٥- عن محمد بن كعب القُرَظي -من طريق أبي صخر- في قول الله ﷿: <q>﴿يا أُخْتَ هارُونَ﴾</q>، قال: هي أخت هارون لأبيه وأمه، وهي أخت موسى أخي هارون التي قَصَّت أثر موسى، <q>﴿فَبَصُرَتْ بِهِ عَنْ جُنُبٍ وهُمْ لا يَشْعُرُونَ﴾</q> [القصص:١١]{6}٤١٦١. (ز) ٤١٦١ انتقد ابنُ كثير (٩/٢٣٩-٢٤٠ بتصرف) قول القرظي مستندًا للقرآن، والسنة، والتاريخ، فقال: «وهذا القول خطأ محض؛ فإنّ الله تعالى قد ذكر في كتابه أنه قَفّى بعيسى بعد الرسل، فدلَّ على أنه آخر الأنبياء بعثًا، وليس بعده إلا محمد ﷺ؛ ولهذا ثبت عن النبي ﷺ أنه قال: «أنا أولى الناس بابن مريم، إلا أنه ليس بيني وبينه نبي». ولو كان الأمر كما زعم محمد بن كعب القرظي لم يكن متأخرًا عن الرسل سوى محمد، ولكان قبل سليمان وداود؛ فإن الله قد ذكر أن داود بعد موسى ﵉ في قوله تعالى: <q>﴿ألم تر إلى الملإ من بني إسرائيل من بعد موسى﴾</q> [البقرة:٢٤٦]، فذكر القصة، إلى أن قال: <q>﴿وقتل داود جالوت﴾</q>». ووجَّهه بقوله: «والذي جرّأ القرظي على هذه المقالة ما في التوراة بعد خروج موسى وبني إسرائيل من البحر، وإغراق فرعون وقومه، قال: وكانت مريم بنت عمران أخت موسى وهارون النبِيَّيْنِ، تضرب بالدف هي والنساء معها يُسَبِّحْنَ الله ويشكرنه على ما أنعم به على بني إسرائيل. فاعتقد القرظي أن هذه هي أمُّ عيسى». ٤٦٥٤٦- عن قتادة بن دعامة -من طريق معمر- في قوله: <q>﴿يأخت هارون﴾</q>، قال: كان رجلًا صالحًا في بني إسرائيل يُسَمّى: هارون، فشبهوها به، فقالوا: يا شبيهة هارون في الصلاح{7}٤١٦٢. (١٠/٦٥) ٤١٦٢ علَّق ابنُ عطية (٦/٢٧) على هذا القول بقوله: «فالمعنى أنّه اسمٌ وافق اسمًا». ٤٦٥٤٧- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿يا أخت هارون﴾</q> الآية، قال: كانت مِن أهل بيت يُعْرَفُون بالصلاح، ولا يُعْرَفُون بالفساد في الناس، وفي الناس مَن يُعْرَفُ بالصلاح ويتوالدون به، وآخرون يُعْرَفُون بالفساد ويتوالدون به، وكان هارون مصلحًا مُحَبَّبًا في عشيرته، وليس بهارون أخي موسى، ولكن هارون آخر. ذُكِر لنا: أنّه تبِع جنازته يوم مات أربعون ألفًا مِن بني إسرائيل، كلهم يُسَمَّوْن: هارون{8}. (١٠/٦٥) ٤٦٥٤٨- عن إسماعيل السُّدِّيّ -من طريق أسباط- قال: كانت مِن سبط هارون، فقيل لها: <q>﴿يا أخت هارون﴾</q>. فدُعِيَت إلى سِبْطِه، كالرجل يقول للرجل: يا أخا بني ليث، يا أخا بني فلان{9}. (١٠/٦٦) ٤٦٥٤٩- عن علي بن أبي طلحة، في قوله: <q>﴿يا أخت هارون﴾</q>، قال: نُسِبت إلى هارون بن عمران؛ لأنها كانت مِن سِبْطِه، كقولك: يا أخا الأنصار{4}. (١٠/٦٦) ٤٦٥٥٠- قال محمد بن السائب الكلبي: كان هارون أخا مريم مِن أبيها، وكان أمثلَ رجل في بني إسرائيل{11}. (ز) ٤٦٥٥١- قال مقاتل بن سليمان: <q>﴿يا أخت هارون﴾</q> الذى هو أخو موسى ... قال رسول الله ﷺ: «إنما عَنَوْا هارون أخا موسى؛ لأنها كانت مِن نسله»{12}. (ز) ٤٦٥٥٢- عن سفيان، في قوله: <q>﴿يا أخت هارون﴾</q>، قال: سمعنا أنّه اسمٌ وافق اسمًا{4}. (١٠/٦٥) ٤٦٥٥٣- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿يا أخت هارون﴾</q>، قال: اسم واطَأَ اسْمًا، كم بين هارون وبينهما من الأمم؟ أُمَمٌ كثيرة{14}. (ز) ٤٦٥٥٤- قال يحيى بن سلّام: أي: فقالوا: <q>﴿يا أخت هارون﴾</q> في عبادته وفضله{15}٤١٦٣. (ز) ٤١٦٣ اختُلِف في السبب الذي من أجله قيل لها: <q>﴿يا أخت هارون﴾</q>، ومَن كان هارون هذا الذي ذكره الله؟ فقال قوم: كان رجلًا صالحًا من بني إسرائيل ينسب إليه مَن يُعرَف بالصلاح. وقال آخرون: هو هارون أخو موسى فنسبت إليه؛ لأنها من ولده كما يقال: يا أخا بني فلان. وقال غيرهم: كان أخاها لأبيها وأمها. وذهب قوم: إلى أنه كان رجلًا فاسقًا مُعْلِنًا بالفسق، ونُسِبَت إليه. ورجَّح ابنُ جرير (١٥/٥٢٥ بتصرف) القول الأول الذي قاله قتادة، وكعب، والمغيرة بن شعبة مستندًا إلى السنة، فقال: «والصواب من القول في ذلك ما جاء به الخبرُ عن رسول الله ﷺ [الوارد في أول تفسير الآية]، وأنها نسبت إلى رجل من قومها». وبنحوه ابنُ كثير (٩/٢٤٠). <q>﴿مَا كَانَ أَبُوكِ ٱمۡرَأَ سَوۡءࣲ﴾</q> - تفسير ٤٦٥٥٥- قال عبد الله بن عباس: زانيًا{16}. (ز) ٤٦٥٥٦- عن السُّدِّيّ: <q>﴿ما كان أبوك امرأ سوء﴾</q> رجل سوء، يعني: ما كان زانيًا{17}. (ز) ٤٦٥٥٧- قال مقاتل بن سليمان: <q>﴿ما كان أبوك﴾</q> عمران <q>﴿امرأ سوء﴾</q> يعني: بزانٍ. كقوله سبحانه: <q>﴿مَن أرادَ بِأَهْلِكَ سُوءًا﴾</q> [يوسف:٢٥]، يعني: الزنا، وكقوله سبحانه: <q>﴿ما علمنا عليه من سوء﴾</q> [يوسف:٥١]. وكان عمران مِن عُظماء بنى إسرائيل{18}. (ز) <q>﴿وَمَا كَانَتۡ أُمُّكِ بَغِیࣰّا ۝٢٨﴾</q> - تفسير ٤٦٥٥٨- عن نوف البكاليّ -من طريق أبي عمران الجَوْني- قال: <q>﴿ما كانَ أبُوكِ امْرَأَ سَوْءٍ وما كانَتْ أُمُّكِ بَغِيًّا﴾</q>، أي: أنت مِن بيت طيِّب طاهر، معروف بالصلاح والعبادة والزهادة، فكيف صَدَرَ هذا منكِ؟!{3}. (ز) ٤٦٥٥٩- عن إسماعيل السُّدِّيّ -من طريق أسباط- <q>﴿وما كانت أمك بغيا﴾</q>، قال: زانية{20}. (ز) ٤٦٥٦٠- قال مقاتل بن سليمان: <q>﴿وما كانت أمك﴾</q> حَنَّة <q>﴿بغيا﴾</q> بزانية، فمن أين هذا الولد؟!{18}. (ز) ٤٦٥٦١- قال يحيى بن سلام: <q>﴿وما كانت أمك بغيا﴾</q>، يعني: وما كانت أمك زانية{15}. (ز) ",footnotes:1:أخرجه مسلم ٣/١٦٨٥ (٢١٣٥)، وابن جرير ١٥/٥٢٤. وأورده الثعلبي ٦/٢١٣.أخرجه ابن جرير ١٥/٥٢٤. وعزاه السيوطي إلى ابن أبي حاتم.أخرجه ابن أبي حاتم -كما في تفسير ابن كثير ٣/٢٢٦-.عزاه السيوطي إلى ابن أبي حاتم.أخرجه الخطيب ١/٣٨٢، وابن عساكر ٧٠/٩٨.أخرجه ابن أبي حاتم -كما في تفسير ابن كثير ٣/٢٢٧-.أخرجه عبد الرزاق ٢/٧-٨، وابن جرير ١٥/٥٢٣. وعزاه السيوطي إلى عبد بن حميد.أخرجه يحيى بن سلام ١/٢٢٢ مختصرًا، وابن جرير ١٥/٥٢٣. وعزاه السيوطي إلى ابن أبي حاتم.أخرجه ابن جرير ١٥/٥٢٥. وعزاه السيوطي إلى ابن أبي حاتم.عزاه السيوطي إلى ابن أبي حاتم.تفسير الثعلبي ٦/٢١٣، وتفسير البغوي ٥/٢٢٩.تفسير مقاتل بن سليمان ٢/٦٢٥-٦٢٦.عزاه السيوطي إلى ابن أبي حاتم.أخرجه ابن جرير ١٥/٥٢٤.تفسير يحيى بن سلام ١/٢٢٢.تفسير البغوي ٥/٢٢٩.علقه يحيى سلام ١/٢٢٢.تفسير مقاتل بن سليمان ٢/٦٢٦.أخرجه ابن أبي حاتم -كما في تفسير ابن كثير ٣/٢٢٦-.أخرجه ابن جرير ١٥/٥٢٥. ووقع بعده موصولًا به: «قال: <q>﴿وما كانت أمك بغيا﴾</q>. ولم يقل: بغية؛ لأنّ ذلك مِمّا يُوصَف به النساء دون الرجال، فجرى مجرى: امرأة حائض وطالق، وقد كان بعضهم يشبه ذلك بقولهم: ملحفة جديد، وامرأة قتيل». وكذلك في نسخة شاكر ١٨/١٨٨. والظاهر أن هذا من قول ابن جرير، وليس من قول السدي.تفسير مقاتل بن سليمان ٢/٦٢٦.تفسير يحيى بن سلام ١/٢٢٢.
19,29," <q>﴿فَأَشَارَتۡ إِلَیۡهِۖ﴾</q> - تفسير ٤٦٥٦٢- قال عبد الله بن مسعود: لَمّا لم تكن لها حُجَّةٌ أشارت إليه؛ ليكون كلامُه حُجَّةً لها{1}. (ز) ٤٦٥٦٣- عن عمرو بن ميمون، قال: إنّ مريم لَمّا ولدت أتت به قومها، فأخذوا لها الحجارةَ ليرموها، فأشارت إليه، فتكلَّم، فتركوها{2}. (١٠/٦٧) ٤٦٥٦٤- عن وهب بن مُنَبِّه -من طريق ابن إسحاق، عمَّن لا يتهم- <q>﴿فأشارت إليه﴾</q>، يقول: أشارت إليه أن كلِّموه{3}. (ز) ٤٦٥٦٥- عن ميمون بن مهران، قال: لَمّا قالوا لمريم: <q>﴿لَقَدْ جِئْتِ شَيْئًا فَرِيًّا﴾</q> إلخ؛ أشارت إلى عيسى أن كلِّموه، فقالوا: تأمرنا أن نكلِّم مَن هو في المهد زيادةً على ما جاءت به مِن الداهية!{4}. (ز) ٤٦٥٦٦- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿فأشارت إليه﴾</q>، قال: أمرتهم بكلامه{5}. (١٠/٦٧) ٤٦٥٦٧- عن إسماعيل السُّدِّيّ -من طريق أسباط- قال: لَمّا قالوا لها: <q>﴿ما كان أبوك امرأ سوء وما كانت أمك بغيا﴾</q>؛ قالت لهم ما أمرها الله به، فلمّا أرادوها بعد ذلك على الكلام <q>﴿فأشارت إليه﴾</q> إلى عيسى{3}. (ز) ٤٦٥٦٨- قال مقاتل بن سليمان: <q>﴿فأشارت إليه﴾</q>، يعني: إلى ابنها عيسى ﷺ أن كلِّموه{7}. (ز) ٤٦٥٦٩- عن عبد الملك ابن جُرَيْج -من طريق حجاج- في قوله: <q>﴿فأشارت إليه﴾</q>: أن كلِّموه{8}. (١٠/٦٧) ٤٦٥٧٠- عن سفيان الثوري، في قوله: <q>﴿فأشارت إليه﴾</q>، قال: إلى عيسى{9}. (ز) ٤٦٥٧١- قال يحيى بن سلّام: قوله: <q>﴿فأشارت إليه﴾</q> بيدها{10}. (ز) <q>﴿قَالُوا۟ كَیۡفَ نُكَلِّمُ مَن كَانَ فِی ٱلۡمَهۡدِ صَبِیࣰّا ۝٢٩﴾</q> - تفسير ٤٦٥٧٢- عن السُّدِّيّ: <q>﴿قالوا كيف نكلم من كان فِي المَهْدِ صَبِيًّا﴾</q>، يعني: مَن هو{11}. (ز) ٤٦٥٧٣- قال مقاتل بن سليمان: <q>﴿قالوا﴾</q> قال قومها: <q>﴿كيف نكلم من كان فِي المَهْدِ صَبِيًّا﴾</q> يعني: من هو{7}. (ز) <q>﴿فِی ٱلۡمَهۡدِ صَبِیࣰّا ۝٢٩﴾</q> - تفسير ٤٦٥٧٤- عن عكرمة مولى ابن عباس، قال: المهد: المرباة. قال إبراهيم: المرباة: المرجحة{2}. (١٠/٦٧) ٤٦٥٧٥- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿في المهد﴾</q>، قال: الحِجْر{14}. (١٠/٦٧) ٤٦٥٧٦- عن إسماعيل السُّدِّيّ -من طريق أسباط- قال: لَمّا أشارت لهم إلى عيسى غضِبوا، وقالوا: لَسُخْرِيَّتُها بنا حين تأمرنا أن نُكَلِّم هذا الصبي أشدُّ علينا مِن زناها، <q>﴿قالوا كيف نكلم من كان في المهد صبيا﴾</q>{15}. (ز) ٤٦٥٧٧- قال مقاتل بن سليمان: <q>﴿في المهد﴾</q> يعني: في حِجْر أمه ملفوفًا في خِرَق <q>﴿صبيا﴾</q>، فدنا زكريا من الصبي، فقال: تكلَّم -يا صبيُّ- بعذرك إن كان لك عذر. <q>﴿قال إني عبد الله آتاني الكتاب وجعلني نبيا * وجعلني مباركا أينما كنت وأَوْصانِي بِالصَّلاةِ والزَّكاةِ مادُمْتُ حَيًّا (٣١) وبَرًّا بِوالِدَتِي ولم يجعلني جبارا شقيا﴾</q>. فلمّا ذكر الوالدة ولم يذكر الوالد ضَمَّه زكريا إلى صدره، وقال: أشهد أنّك عبدُ الله ورسوله{16}. (ز) ",footnotes:1:تفسير البغوي ٥/٢٢٩.عزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ١٥/٥٢٦.أخرجه ابن أبي حاتم -كما في الفتح ٦/٤٧٩-.أخرجه ابن جرير ١٥/٥٢٦. وعلَّقه يحيى بن سلام ١/٢٢٢. وعزاه السيوطي إلى ابن أبي حاتم.أخرجه ابن جرير ١٥/٥٢٦.تفسير مقاتل بن سليمان ٢/٦٢٦.أخرجه ابن جرير ١٥/٥٢٦. وعزاه السيوطي إلى ابن المنذر.أخرجه الثوري في تفسيره ص١٨٤.تفسير يحيى بن سلام ١/٢٢٢.علَّقه يحيى بن سلام ١/٢٢٢.تفسير مقاتل بن سليمان ٢/٦٢٦.عزاه السيوطي إلى عبد بن حميد.أخرجه يحيى بن سلام ١/٢٢٢، وابن جرير ١٥/٥٢٧. وعزاه السيوطي إلى ابن أبي حاتم.أخرجه ابن جرير ١٥/٥٢٨.تفسير مقاتل بن سليمان ٢/٦٢٦-٦٢٧ بتصرف يسير.
19,30," <q>﴿قَالَ إِنِّی عَبۡدُ ٱللَّهِ﴾</q> - تفسير ٤٦٥٧٨- عن وهب بن مُنَبِّه -من طريق ابن إسحاق، عمَّن لا يتَّهم-: <q>﴿قالوا كيف نكلم من كان في المهد صبيا﴾</q>. فأجابهم عيسى عنها، فقال لهم: <q>﴿إني عبد الله آتاني الكتاب وجعلني نبيا﴾</q> الآية{1}. (ز) ٤٦٥٧٩- قال وهب بن مُنَبِّه: أتاها زكريا عند مناظرتها اليهود، فقال لعيسى: انطق بحجتك إن كنتَ أُمرتَ بها. فقال عند ذلك عيسى ﵇وهو ابن أربعين يومًا-: <q>﴿إني عبد الله﴾</q> أقرَّ على نفسه بالعبودية لله ﷿ أولَ ما تكلم لِئَلّا يُتَّخَذ إلَهًا{2}. (ز) ٤٦٥٨٠- قال إسماعيل السُّدِّيّ: فلمّا سمِع عيسى كلامَهم ترك الرَّضاع، وأقبل عليهم{3}. (ز) ٤٦٥٨١- قال مقاتل بن سليمان: فـ<q>﴿قال﴾</q> الصبيُّ -وهو يومئذ ولد-: <q>﴿إني عبد الله﴾</q>. وكَذَبَتِ النصارى فيما يقولون، فأول ما تكلم به الصبيُّ أنه أقرَّ لله بالعبودية{4}. (ز) <q>﴿ءَاتَىٰنِیَ ٱلۡكِتَـٰبَ وَجَعَلَنِی نَبِیࣰّا ۝٣٠﴾</q> - تفسير ٤٦٥٨٢- عن أنس بن مالك، قال: كان عيسى قد درس الإنجيل، وأحكمها في بطن أمه، فذلك قوله: <q>﴿إني عبد الله آتاني الكتاب﴾</q>{5}٤١٦٤. (١٠/٦٨) ٤١٦٤ ذكر ابنُ عطية (٦/٣١) أنّ فرقة قالت: إن عيسى أوتي الكتاب وهو في الطفولة، وأنه كان يصلي ويصوم. وانتقده بقوله: «وهذا في غاية الضعف، مصرّح بجهالة قائله». ٤٦٥٨٣- عن عكرمة مولى ابن عباس -من طريق سماك- في قوله: <q>﴿إني عبد الله آتاني الكتاب﴾</q> الآية، قال: قضى أن يؤتيني الكتاب{6}. (١٠/٦٧) ٤٦٥٨٤- عن عكرمة مولى ابن عباس -من طريق سماك- في قوله: <q>﴿آتاني الكتاب﴾</q>، قال: آتاني من قبل أن يخلقني{7}. (ز) ٤٦٥٨٥- عن الحسن البصري أنّه قال: أُلْهِمَ التوراة وهو في بطن أُمِّه{8}. (ز) ٤٦٥٨٦- قال مقاتل بن سليمان: <q>﴿آتاني الكتاب﴾</q> يعني: أعطانى الإنجيل، فعَلَّمَنِيه، <q>﴿وجعلني نبيا﴾</q>{9}٤١٦٥. (ز) ٤١٦٥ ذكر ابنُ عطية (٦/٢٩) أن الكتاب هو التوراة. ثم ذكر أنّه يحتمل أن يكون التوراة والإنجيل. ٤٦٥٨٧- قال عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿قالوا كيف نكلم من كان في المهد صبيا قال﴾</q> لهم: <q>﴿إني عبد الله آتاني الكتاب وجعلني نبيا﴾</q>. فقرأ حتى بلغ: <q>﴿ولم يجعلني جبارا شقيا﴾</q> فقالوا: إنّ هذا لَأمرٌ عظيم{1}. (ز) ",footnotes:1:أخرجه ابن جرير ١٥/٥٢٨.تفسير الثعلبي ٦/٢١٣، وتفسير البغوي ٥/٢٣٠، واللفظ له.تفسير البغوي ٥/٢٢٩.تفسير مقاتل بن سليمان ٢/٦٢٦. وقوله: «وهو يوم ولد» في تفسير الثعلبي ٦/٢١٣، وتفسير البغوي ٥/٢٣٠، منسوبًا إلى مقاتل مهملًا.عزاه السيوطي إلى ابن أبي حاتم.أخرجه عبد الرزاق ٢/٩، وابن جرير ١٥/٥٢٩. وعزاه السيوطي إلى ابن أبي شيبة، وعبد بن حميد، وابن المنذر، وابن أبي حاتم.أخرجه الثوري في تفسيره ص١٨٥.تفسير البغوي ٥/٢٣٠.تفسير مقاتل بن سليمان ٢/٦٢٦.أخرجه ابن جرير ١٥/٥٢٨.
19,31," <q>﴿وَجَعَلَنِی مُبَارَكًا أَیۡنَ مَا كُنتُ وَأَوۡصَـٰنِی﴾</q> - تفسير ٤٦٥٨٨- عن أبي هريرة، قال: قال النبي ﷺ: «قول عيسى: <q>﴿وجعلني مباركا أينما كنت﴾</q>. قال: جعلني نفّاعًا للناس أين اتَّجَهْتُ»{1}. (١٠/٦٨) ٤٦٥٨٩- عن عبد الله بن مسعود، عن النبي ﷺ: <q>﴿وجعلني مباركا أينما كنت﴾</q>، قال: «مُعَلِّمًا، ومُؤَدِّبًا»{2}. (١٠/٦٨) ٤٦٥٩٠- عن جابر -من طريق عمرو-: <q>﴿وجعلني مباركًا أينما كنت﴾</q> لعيسى بن مريم قال: مُعَلِّمًا، ومُؤَدِّبًا{3}. (ز) ٤٦٥٩١- عن مجاهد بن جبر، <q>﴿وجعلني مباركا﴾</q>، قال: هاديًا، مَهْدِيًّا{4}. (١٠/٦٨) ٤٦٥٩٢- عن مجاهد بن جبر -من طريق ليث- في قوله: <q>﴿وجعلني مباركا أينما كنت﴾</q>، قال: مُعَلِّمًا للخير{5}. (١٠/٦٨) ٤٦٥٩٣- عن مجاهد بن جبر -من طريق ليث- <q>﴿وجعلني مباركا﴾</q>، قال: نفّاعًا للناس{6}. (١٠/٦٩) ٤٦٥٩٤- عن عمرو بن قيس -من طريق أبي قبيصة- في قوله تعالى: <q>﴿وجعلني مباركا أين ما كنت﴾</q>، قال: مُؤَدِّبًا، ومُعَلِّمًا{7}. (ز) ٤٦٥٩٥- قال مقاتل بن سليمان: <q>﴿وجعلني مباركا﴾</q> يعني: مُعَلِّمًا مُؤَدِّبًا في الخير، <q>﴿أين ما كنت﴾</q> مِن الأرض{8}. (ز) ٤٦٥٩٦- عن سفيان [بن عيينة] -من طريق يونس بن عبد الأعلى- في قوله: <q>﴿وجعلني مباركا أينما كنت﴾</q>، قال: مُعَلِّمًا للخير{9}٤١٦٦. (ز) ٤١٦٦ علَّق ابنُ القيم (٢/١٧٠-١٧١) على قول سفيان بقوله: «وهذا يدُلُّ على أن تعليم الرجل الخير هو البركة التي جعلها الله فيه؛ فإنّ البركة حصول الخير ونماؤه ودوامه، وهذا في الحقيقة ليس إلا في العلم الموروث عن الأنبياء وتعليمه؛ ولهذا سمى سبحانه كتابه: مباركًا». ٤٦٥٩٧- عن أبي حفص -من طريق جابر- في قوله: <q>﴿وجعلني مباركا أينما كنت﴾</q>، قال: عيسى بن مريم، قال: مُعَلِّمًا، ومُؤَدِّبًا{10}. (ز) ٤٦٥٩٨- عن وهيب بن الورد، قال: لقي عالِمٌ عالِمًا هو فوقه في العلم، فقال له: يرحمك الله، ما الذي أُعْلِنُ من علمي؟ قال: الأمر بالمعروف، والنهي عن المنكر؛ فإنّه دين الله الذي بعث به أنبياءه إلى عباده، وقد اجتمع الفقهاء على قول الله: <q>﴿وجعلني مباركا أينما كنت﴾</q>. وقيل: ما بركته؟ قال: الأمر بالمعروف، والنهي عن المنكر أينما كان{11}. (ز) ٤٦٥٩٩- قال يحيى بن سلّام: فقال عيسى: <q>﴿وجعلني مباركا أين ما كنت﴾</q>، سمعتُ بعضَ الكوفيين يقول: أي: مُعَلِّمًا، مُؤَدِّبًا{12}٤١٦٧. (ز) ٤١٦٧ أفادت الآثارُ الاختلاف في معنى قوله: <q>﴿مباركا﴾</q>، وذكر ابنُ عطية (٦/٣٠) أنّ قوله: <q>﴿مباركا﴾</q> يَعُمُّ جميع ما ذُكر من الوجوه وغيرها. ",footnotes:1:أخرجه الإسماعيلي في معجم أسامي شيوخه ٢/٦١٥-٦١٦، وأبو نعيم في الحلية ٣/٢٥. قال أبو نعيم: «غريب من حديث يونس، تفرَّد به عن هشيم، وعنه شعيب».أخرجه ابن عدي في الكامل ٦/٢٢٨، وابن عساكر في تاريخه ٤٧/٣٦٠. قال ابن عدي: «غير محفوظ بهذا الإسناد».أخرجه ابن عساكر في تاريخ دمشق ٤٧/٣٦٠.عزاه السيوطي إلى عبد بن حميد.أخرجه ابن جرير ١٥/٥٣١. وعزاه السيوطي إلى عبد الله بن أحمد في زوائد الزهد، وابن المنذر، وابن أبي حاتم.أخرجه ابن جرير ١٥/٥٣٠، والبيهقي في الشعب (٧٦٦١)، وابن عساكر ٤٧/٣٦٠.أخرجه أبو الشيخ في طبقات المحدثين بأصبهان ٢/١٣.تفسير مقاتل بن سليمان ٢/٦٢٦.أخرجه ابن جرير ١٥/٥٣١.أخرجه ابن عدي في الكامل ٦/٢٢٨، وابن عساكر في تاريخ دمشق ٤٧/٣٦٠.أخرجه ابن أبي الدنيا في كتاب الأمر بالمعروف والنهي عن المنكر -موسوعة ابن أبي الدنيا ٢/١٩٧ (١٣)-، وابن جرير ١٥/٥٣٠ واللفظ له.تفسير يحيى بن سلام ١/٢٢٢.
19,32," <q>﴿وَأَوۡصَـٰنِی بِٱلصَّلَوٰةِ وَٱلزَّكَوٰةِ مَا دُمۡتُ حَیࣰّا ۝٣١ وَبَرَّۢا بِوَ ٰ⁠لِدَتِی﴾</q> - قراءات ٤٦٦٠٠- عن أبي نَهيك [عثمان بن نهيك] -من طريق عبد المؤمن- أنّه قرأ: (وبِرًّا بِوالِدَتِي) مِن قول عيسى ﵇. قال أبو نهيك: أوصاني بالصلاة والزكاة والبر بالوالدين، كما أوصاني بذلك{1}٤١٦٨. (ز) ٤١٦٨ وجَّهَ ابنُ جرير (١٥/٥٣٢) قراءة أبي نهيك بقوله: «فكأنّ أبا نهيك وجَّه تأويل الكلام إلى أن قوله: <q>﴿وبرا بوالدتي﴾</q> من خبر عيسى، عن وصية الله إيّاه به، كما أن قوله: <q>﴿وأوصاني بالصلاة والزكاة﴾</q> من خبره عن وصية الله إياه بذلك. فعلى هذا القول يجب أن يكون نصب البرِّ بمعنى: عمل الوصية فيه؛ لأن الصلاة والزكاة وإن كانتا مخفوضتين في اللفظ فإنهما بمعنى النصب مِن أجل أنه مفعول بهما». <q>﴿وَأَوۡصَـٰنِی بِٱلصَّلَوٰةِ وَٱلزَّكَوٰةِ مَا دُمۡتُ حَیࣰّا ۝٣١ وَبَرَّۢا بِوَ ٰ⁠لِدَتِی﴾</q> - تفسير الآية ٤٦٦٠١- عن نوف البكالي: <q>﴿وبرا بوالدتي﴾</q>، أي: ليس لي أب{2}. (١٠/٦٩) ٤٦٦٠٢- عن إسماعيل السُّدِّيّ: <q>﴿وبرا بوالدتي﴾</q>، أي: وجعلني بَرًّا بوالدتي، يعني: مُطيعًا لأمر مريم{3}. (ز) ٤٦٦٠٣- قال مقاتل بن سليمان: <q>﴿وأوصاني بـ﴾</q>إقامة <q>﴿الصلاة و﴾</q>إيتاء <q>﴿الزكاة ما دمت حيا﴾</q>، <q>﴿وبرا بوالدتي﴾</q> يقول: وأوصاني أن أكون بَرًّا بوالدتي، يعني: مُطِيعًا لأُمِّي مريم{4}. (ز) <q>﴿وَلَمۡ یَجۡعَلۡنِی جَبَّارࣰا شَقِیࣰّا ۝٣٢﴾</q> - تفسير ٤٦٦٠٤- عن عبد الله بن عباس، في قوله: <q>﴿ولم يجعلني جبارا شقيا﴾</q>، يقول: عَصِيًّا{5}. (١٠/٦٩) ٤٦٦٠٥- قال مقاتل بن سليمان: <q>﴿ولم يجعلني جبارا﴾</q> يعني: مُتَكَبِّرًا عن عبادة الله، <q>﴿شقيا﴾</q> يعني: عاصيًا لله ﷿{6}. (ز) ٤٦٦٠٦- عن سفيان بن عُيَيْنة -من طريق ابن أبي عمر- قال: الجبّار الشَّقِيُّ الذي يقتُلُ على الغضب{7}. (١٠/٦٩) ٤٦٦٠٧- قال يحيى بن سلّام: <q>﴿ولم يجعلني جبارا﴾</q> مُسْتَكْبِرًا عن عبادة الله، ولم يجعلني <q>﴿شقيا﴾</q>{8}. (ز) <q>﴿وَلَمۡ یَجۡعَلۡنِی جَبَّارࣰا شَقِیࣰّا ۝٣٢﴾</q> - آثار متعلقة بالآية ٤٦٦٠٨- عن قتادة بن دعامة -من طريق سعيد- قال: ذُكِر لنا: أنّه -يعني: عيسى- كان يقول: سَلُوني، فإنّ قلبي ليِّنٌ، وإنِّي صغير في نفسي. مِمّا أعطاه الله مِن التواضع{9}. (ز) ٤٦٦٠٩- عن قتادة بن دعامة -من طريق سعيد- <q>﴿وبرا بوالدتي ولم يجعلني جبارا شقيا﴾</q>: ذُكِر لنا: أنّ امرأةً رأت ابن مريم يُحْيِي الموتى، ويُبْرِئ الأكمه والأبرص، في آياتٍ سَلَّطه اللهُ عَلَيْهِنَّ، وأذِن له فيهنَّ. فقالت: طُوبى للبطن الذي حملك، والثدي الذي أُرضعت به. فقال نبي الله ابن مريم يجيبها: طوبى لمن تلا كتاب الله، واتبع ما فيه، ولم يكن جبارًا شقيًّا{9}. (ز) ٤٦٦١٠- عن العَوّام بن حَوْشَب، قال: إنّك لا تكاد تجد عاقًّا إلا تجده جبّارًا. ثم قرأ هذه الآية: <q>﴿وبرا بوالدتي ولم يجعلني جبارا شقيا﴾</q>{11}. (١٠/٦٩) ",footnotes:1:أخرجه ابن جرير ١٥/٥٣٢. (وبِرًّا) بكسر الباء قراءة شاذة، تروى أيضًا عن أبي مجلز. انظر: مختصر ابن خالويه ص٨٧، والمحتسب ٢/٤٢.عزاه السيوطي إلى ابن أبي حاتم.علقه يحيى بن سلام ١/٢٢٣.تفسير مقاتل بن سليمان ٢/٦٢٦.أخرجه ابن أبي حاتم -كما في الإتقان ٢/٢٦-.تفسير مقاتل بن سليمان ٢/٦٢٧.أخرجه إسحاق البستي في تفسيره ص١٩٠. وعزاه السيوطي إلى ابن أبي حاتم.تفسير يحيى بن سلام ١/٢٢٣.أخرجه ابن جرير ١٥/٥٣٣.أخرجه ابن جرير ١٥/٥٣٣.أخرجه أخرجه ابن جرير ناسبًا إيّاه إلى بعض أهل العلم ١٥/٥٣٣. وعزاه السيوطي إلى ابن أبي حاتم.
19,33," <q>﴿وَٱلسَّلَـٰمُ عَلَیَّ یَوۡمَ وُلِدتُّ وَیَوۡمَ أَمُوتُ وَیَوۡمَ أُبۡعَثُ حَیࣰّا ۝٣٣﴾</q> - تفسير ٤٦٦١١- عن عامر الشعبي، قال: فِقَراتُ{1} ابن آدم ثلاث؛ يوم وُلِد، ويوم يموت، ويوم يبعث، وهي التي ذكر عيسى في قوله: <q>﴿والسلام علي﴾</q> الآية{2}. (١٠/٦٨) ٤٦٦١٢- عن وهب بن مُنَبِّه -من طريق ابن إسحاق، عمَّن لا يتهم- <q>﴿والسلام علي يوم ولدت ويوم أموت ويوم أبعث حيا﴾</q>، قال: يُخبِرُهم في قصة خبره عن نفسه أنّه لا أب له، وأنّه سيموت ثم يبعث حيًّا، يقول الله -تبارك وتعالى-: <q>﴿ذلك عيسى ابن مريم قول الحق الذي فيه يمترون﴾</q>{3}. (ز) ٤٦٦١٣- قال مقاتل بن سليمان: <q>﴿والسلام علي يوم ولدت﴾</q> يعني: حين وُلِدت، <q>﴿ويوم أموت﴾</q> يعني: وحين أموت، <q>﴿ويوم أبعث حيا﴾</q> يعني: وحين أبعث حيًّا بعد الموت في الآخرة. ثم لم يتكلم بعد ذلك حتى كان بمنزلة غيره من الصبيان، فلما قال: <q>﴿وبرا بوالدتي﴾</q> ضمَّه زكريّا{4}. (ز) ٤٦٦١٤- قال يحيى بن سلّام: <q>﴿والسلام علي يوم﴾</q> حين <q>﴿ولدت ويوم﴾</q> وحين <q>﴿أموت ويوم أبعث حيا﴾</q> يوم القيامة. ولم يتكلم بعد ذلك بشيء حتى بلغ مبلغ الغلمان{5}. (ز) <q>﴿وَٱلسَّلَـٰمُ عَلَیَّ یَوۡمَ وُلِدتُّ وَیَوۡمَ أَمُوتُ وَیَوۡمَ أُبۡعَثُ حَیࣰّا ۝٣٣﴾</q> - آثار متعلقة بالآيات ٤٦٦١٥- عن أبي سعيد الخدري= (ز) ٤٦٦١٦- وأبي هريرة: أنّ الله أطلق لسانَ عيسى مرة أخرى في صباه، فتكلَّم ثلاث مرات، حتى بلغ ما بلغ الصبيان، يتكلَّمون فتكلَّم، فحمد الله بتحميدٍ لم تسمع الآذانُ مثلَه، حيث أنطقه طفلًا، فقال: اللهم، أنت القريبُ في عُلُوِّك، المُتعالي في دُنُوِّك، الرفيع على كل شيء مِن خلقك، أنت الذي نفذ بصرك في خلقك، وحارَتِ الأبصار دون النظر إليك، أنت الذي غُشِّيت الأبصار دونك، وشَمَخَ بك العلياء في النور، وتَشَعْشَع بك البناء الرفيع في المتباعد، أنت الذي جَليت حِندِسَ الظُّلَم{6} بنورك، أنت الذي أشرقت بضوء نورك دلادجُ الظلام، وتلَأْلَأَت بعظمتك أركان العرش نورًا، فلم يبلغ أحد بصفته صفتك، فتباركت اللهم خالق الخلق بعِزَّتك، مُقَدِّرَ الأمور بحكمتك، مبتدئ الخلق بعظمتك. ثم أمْسَك الله لسانَه حتى بلغ{7}. (١٠/٧٠) ٤٦٦١٧- عن عبد الله بن عباس -من طريق مجاهد- قال: ما تَكَلَّم عيسى إلا بالآيات التي تَكَلَّم بها حتى بلغ مبلغ الصبيان{8}. (١٠/٧٠) ٤٦٦١٨- عن الضَّحّاك بن مُزاحِم -من طريق عبيد- في قوله: <q>﴿كيف نكلم من كان في المهد صبيا قال إني عبد الله﴾</q>، قال: لم يتكلم عيسى إلا عند ذلك، حين <q>﴿قالوا كيف نكلم من كان في المهد صبيا﴾</q>{9}. (ز) ",footnotes:1:الفِقَرات -بكسر الفاء وفتح القاف-: جمع فِقَرة، الأمورُ العظام. الدر المصون في علوم الكتاب المكنون للسمين الحلبي ١/٦٢٩.عزاه السيوطي إلى ابن أبي حاتم.أخرجه ابن جرير ١٥/٥٣٤.تفسير مقاتل بن سليمان ٢/٦٢٧.تفسير يحيى بن سلام ١/٢٢٣.حِندِسَ الظلم: شديدة الظلمة. لسان العرب (حندس).أخرجه ابن عساكر ٤٧/٣٦٢.أخرجه ابن أبي شيبة ١١/٥٤٥، وابن عساكر ٤٧/٣٦٢. وعزاه السيوطي إلى ابن أبي حاتم.أخرجه ابن جرير ١٥/٥٢٨، وإسحاق البستي في تفسيره ص١٩٠.
19,34," <q>﴿ذَ ٰ⁠لِكَ عِیسَى ٱبۡنُ مَرۡیَمَۖ قَوۡلَ ٱلۡحَقِّ﴾</q> - قراءات ٤٦٦١٩- عن إبراهيم النخعي -من طريق الأعمش- قال: كانوا يقولون في هذا الحرف في قراءة عبد الله بن مسعود: (قالُ اللهِ الَّذِي فِيهِ يَمْتَرُونَ). قال: كلمة الله{1}٤١٦٩. (ز) ٤١٦٩ ساق ابنُ جرير (١٥/٥٣٥) هذا القول، ثم قال: «ولو وجّه تأويل ذلك إلى: ذلك عيسى ابن مريم القول الحق، بمعنى: ذلك القول الحق، ثم حذفت الألف واللام من القول، وأضيف إلى الحق. كما قيل: <q>﴿إن هذا لهو حق اليقين﴾</q> [الواقعة:٩٥]، وكما قيل: <q>﴿وعد الصدق الذي كانوا يوعدون﴾</q> [الأحقاف:١٦] كان تأويلًا صحيحًا». ٤٦٦٢٠- عن الأعمش: في قراءة عبد الله بن مسعود: (ذَلِكَ عِيسى ابْنُ مَرْيَمَ قالُ الحَقِّ الَّذِي فِيهِ يَمْتَرُونَ){2}٤١٧٠. (ز) ٤١٧٠ ذكر ابنُ جرير (١٥/٥٣٦) أن هذه القراءة بمعنى: قول الحقّ، مثلُ: العابِ والعيبِ، والذام والذِّيمِ. <q>﴿ذَ ٰ⁠لِكَ عِیسَى ٱبۡنُ مَرۡیَمَۖ قَوۡلَ ٱلۡحَقِّ﴾</q> - تفسير الآية ٤٦٦٢١- عن مجاهد بن جبر -من طريق ابن جريج- في قوله: <q>﴿ذلك عيسى ابن مريم قول الحق﴾</q>، قال: اللهُ الحقُّ ﷿{3}٤١٧١. (١٠/٧١) ٤١٧١ استدرك ابنُ تيمية (٤/٢٧٩-٢٨٠) على هذا القول بقوله: «فهو وإن كان معنًى صحيحًا فعادةُ القرآن إذا أضيف القول إلى الله أن يقال: قول الله، لا يقال: قول الحق، إلا إذا كان المراد: القول الحق، كما في قوله: <q>﴿قوله الحق﴾</q> [الأنعام:٧٣]». ٤٦٦٢٢- قال الحسن البصري: <q>﴿ذلك عيسى ابن مريم قول الحق﴾</q>، والحق هو الله، هو قوله{4}. (ز) ٤٦٦٢٣- قال مقاتل بن سليمان: يقول الله ﷿: <q>﴿ذلك عيسى ابن مريم قول الحق﴾</q>، يعني: هذا عيسى ابن مريم قول العدل، يعني: الصدق{5}٤١٧٢. (ز) ٤١٧٢ وجَّه ابنُ تيمية (٤/٢٧٩) هذا القول، فقال: «تسميته: قول الحق، كتسميته: كلمة الله». ورجَّح أن الأظهر أن المراد: أن القول الذي قلناه عن عيسى بن مريم هو قول الحق. <q>﴿ٱلَّذِی فِیهِ یَمۡتَرُونَ ۝٣٤﴾</q> - تفسير ٤٦٦٢٤- عن قتادة بن دعامة -من طريق سعيد- قوله: <q>﴿ذلك عيسى ابن مريم قول الحق الذي فيه يمترون﴾</q>: امْتَرَتْ فيه اليهود والنصارى، فأمّا اليهود فزعموا أنّه ساحر كذاب، وأمّا النصارى فزعموا أنه ابن الله، وثالث ثلاثة، وإله، وكذبوا كلُّهم، ولكنه عبد الله ورسوله وكلمته وروحه{6}. (ز) ٤٦٦٢٥- عن قتادة بن دعامة -من طريق معمر- في قوله: <q>﴿الذي فيه يمترون﴾</q>، قال: اجتمع بنو إسرائيل فأخرجوا منهم أربعةَ نفر، أخرج مِن كلِّ قوم عالمهم، فامتروا في عيسى حين رفع، فقال أحدهم: هو اللهُ، هبط إلى الأرض، فأحيا مَن أحيا، وأمات مَن أمات، ثم صعد إلى السماء. وهم اليعْقُوبِيَّةُ، فقالت الثلاثة: كذبتَ. ثم قال اثنان منهم للثالث: قُلْ فيه. فقال: هو ابن الله. وهم النُّسطُورِيَّة. فقال اثنان: كذبت. ثم قال أحد الاثنين للآخر: قلْ فيه. قال: هو ثالث ثلاثة؛ الله إله، وعيسى إله، وأمه إله. وهم الإسرائيلية، وهم ملوك النصارى، فقال الرابع: كذبت، هو عبد الله، ورسوله، وروحه، مِن كلمته. وهم المسلمون، فكان لكل رجل منهم أتباع على ما قال، فاقتتلوا، فظُهِر على المسلمين. فذلك قول الله: <q>﴿ويقتلون الذين يأمرون بالقسط بين الناس﴾</q> [آل عمران:٢١]. قال قتادة: وهم الذين قال الله: <q>﴿فاختلف الأحزاب من بينهم﴾</q>. قال: اختلفوا فيه، فصاروا أحزابًا، فاختصم القوم، فقال المرء المسلم: أنشدكم، هل تعلمون أنّ عيسى كان يَطْعَمُ الطعامَ، وأنّ الله لا يَطْعَم الطعام؟ قالوا: اللَّهُمَّ نعم. قال: فهل تعلمون أنّ عيسى كان ينام، وأنّ الله لا ينام؟ قالوا: اللهم نعم. فخصمهم المسلمون، فاقتتل القوم، فذُكِر لنا: أنّ اليعقوبية ظهرت يومئذ، وأصيب المسلمون، فأنزل الله في ذلك القرآن: <q>﴿فويل للذين كفروا من مشهد يوم عظيم﴾</q>{7}. (١٠/٧١) ٤٦٦٢٦- قال مقاتل بن سليمان: <q>﴿الذي فيه يمترون﴾</q>، يعني: الذي فيه يَشُكُّون في أمر عيسى ﷺ، وهم النصارى{5}. (ز) ٤٦٦٢٧- عن عبد الملك ابن جريج -من طريق حجاج- قوله: <q>﴿الذي فيه يمترون﴾</q>، قال: اختلفوا؛ فقالت فرقة: هو عبد الله ونبيُّه، فآمنوا به. وقالت فرقة: بل هو الله. وقالت فرقة: هو ابن الله. تبارك وتعالى عما يقولون عُلُوًّا كبيرًا. قال: فذلك قوله <q>﴿فاختلف الأحزاب من بينهم﴾</q>، والتي في الزخرف [٦٥]، قال: دَقْيوسُ ونُسْطُورُ وماريعقوب، قال أحدهم حين رفع اللهُ عيسى: هو الله. وقال الآخر: ابن الله. وقال الآخر: كلمة الله، وعبده. فقال المفتريان: إنّ قولي هو أشبه بقولك، وقولك بقولي، مِن قول هذا، فهلُمَّ فلنقاتلهم. فقاتلوهم، وأوطؤوهم، وغلبوهم حتى خرج النبي ﷺ، وهم مُسْلِمَةُ أهل الكتاب{9}. (ز) ",footnotes:1:أخرجه ابن جرير ١٥/٥٣٥. (قالُ اللهِ) قراءة شاذة. انظر: مختصر ابن خالويه ص٨٧.أخرجه ابن أبي داود في المصاحف ١/٣٢٢. (قالُ الحَقِّ) قراءة شاذة. انظر: مختصر ابن خالويه ص٨٧.أخرجه ابن جرير ١٥/٥٣٥، وإسحاق البستي في تفسيره ص١٩٠. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.علَّقه يحيى بن سلام ١/٢٢٣.تفسير مقاتل بن سليمان ٢/٦٢٧.أخرجه ابن جرير ١٥/٥٣٧. وعلَّقه يحيى بن سلام ١/٢٢٣ مختصرًا.أخرجه عبد الرزاق ٢/٨، وابن جرير ١٥/٥٣٧، ٥٤١ بنحوه. وأخرج يحيى بن سلام ١/٢٢٤ نحوه من طريق سعيد. وعزاه السيوطي إلى ابن أبي حاتم.تفسير مقاتل بن سليمان ٢/٦٢٧.أخرجه ابن جرير ١٥/٥٣٧.
19,35," <q>﴿مَا كَانَ لِلَّهِ أَن یَتَّخِذَ مِن وَلَدࣲۖ سُبۡحَـٰنَهُۥۤۚ﴾</q> - تفسير ٤٦٦٢٨- عن إسماعيل السُّدِّيّ: قال اللهُ: <q>﴿سبحانه﴾</q>، يُنَزِّه نفسه عما يقولون{1}. (ز) ٤٦٦٢٩- قال مقاتل بن سليمان: <q>﴿ما كان لله أن يتخذ من ولد﴾</q> يعني: عيسى ﷺ، <q>﴿سبحانه﴾</q> نزَّه نفسه ﷿{2}. (ز) <q>﴿إِذَا قَضَىٰۤ أَمۡرࣰا﴾</q> - تفسير ٤٦٦٣٠- عن السُّدِّيّ: <q>﴿إذا قضى أمرا﴾</q>، يعني: عيسى، كان في علمه أن يكون مِن غير أبٍ{1}. (ز) ٤٦٦٣١- قال مقاتل بن سليمان: <q>﴿إذا قضى أمرا﴾</q> كان في علمه، يعني: عيسى ﷺ{2}. (ز) <q>﴿فَإِنَّمَا یَقُولُ لَهُۥ كُن فَیَكُونُ ۝٣٥﴾</q> - تفسير ٤٦٦٣٢- عن عبد الله بن عباس -من طريق الضحاك- أنّه قال: <q>﴿كن فيكون﴾</q> بالفارسية، لا يثنى القول مرتين، إذا قال مرَّةً كان{5}. (ز) ٤٦٦٣٣- قال مقاتل بن سليمان: <q>﴿فإنما يقول له كن فيكون﴾</q> مرَّةً واحدة، لا يثني القول فيه مرتين{2}. (ز) ",footnotes:1:علَّقه يحيى بن سلام ١/٢٢٣.تفسير مقاتل بن سليمان ٢/٦٢٧.علَّقه يحيى بن سلام ١/٢٢٣.تفسير مقاتل بن سليمان ٢/٦٢٧.رواه مقاتل بن سليمان في تفسيره ٢/٦٢٧.تفسير مقاتل بن سليمان ٢/٦٢٧.
19,36," <q>﴿وَإِنَّ ٱللَّهَ رَبِّی وَرَبُّكُمۡ فَٱعۡبُدُوهُۚ هَـٰذَا صِرَ ٰ⁠طࣱ مُّسۡتَقِیمࣱ ۝٣٦﴾</q> - تفسير ٤٦٦٣٤- عن وهْب بن مُنَبِّه -من طريق ابن إسحاق، عمَّن لا يتهم- قال: عهد إليهم حين أخبرهم عن نفسه، ومولده، وموته، وبعثه: أنّ الله ربي وربكم فاعبدوه هذا صراط مستقيم، أي: إنِّي وإيّاكم عبيدُ الله، فاعبدوه، ولا تعبدوا غيره{1}. (ز) ٤٦٦٣٥- قال مقاتل بن سليمان: ثم قال عيسى ﷺ لبني إسرائيل: <q>﴿وإن الله ربي وربكم فاعبدوه﴾</q> يعني: فوَحِّدوه، <q>﴿هذا﴾</q> التوحيد <q>﴿صراط مستقيم﴾</q> يعني: دين الإسلام مستقيم، وغير دين الإسلام أعوجٌ ليس بمستقيم{2}. (ز) ٤٦٦٣٦- قال يحيى بن سلّام: قوله: <q>﴿وإن الله ربي وربكم فاعبدوه هذا صراط مستقيم﴾</q>، هذا قول عيسى لهم{3}. (ز) ",footnotes:1:أخرجه ابن جرير ١٥/٥٤٠.تفسير مقاتل بن سليمان ٢/٦٢٧.تفسير يحيى بن سلام ١/٢٢٣.
19,37," <q>﴿فَٱخۡتَلَفَ ٱلۡأَحۡزَابُ مِنۢ بَیۡنِهِمۡۖ﴾</q> - تفسير ٤٦٦٣٧- عن مجاهد بن جبر -من طريق ابن أبي نَجِيحٍ- في قوله: <q>﴿فاختلف الأحزاب من بينهم﴾</q>، قال: هم أهل الكتاب{1}. (١٠/٧٢) ٤٦٦٣٨- عن محمد بن كعب القرظي -من طريق موسى بن عبيدة- في قوله: <q>﴿فاختلف الأحزاب من بينهم﴾</q>، قال: في عيسى. فمِنهم مَن قال: ولد. ومنهم مَن قال: بَغِيَّة. يعني: الفرية{2}. (ز) ٤٦٦٣٩- عن قتادة بن دعامة -من طريق معمر- <q>﴿فاختلف الأحزاب من بينهم﴾</q>: اختلفوا فيه، فصاروا أحزابًا{3}. (ز) ٤٦٦٤٠- عن عبد الله بن عباس= (ز) ٤٦٦٤١- وعروة بن الزبير، قريبًا من ذلك{4}. (ز) ٤٦٦٤٢- عن إسماعيل السُّدِّيّ: قوله: <q>﴿فاختلف الأحزاب من بينهم﴾</q> في الدين، يعني: النصارى، فتجادلوا في عيسى، فقالت النُسطورية: عيسى ابن الله، تعالى ربُّنا عن ذلك. وقالت اليعقوبية: <q>﴿إن الله هو المسيح ابن مريم﴾</q> [المائدة:١٧] جل ربُّنا عن ذلك. وقال الملْكانِيُّونَ: <q>﴿إن الله ثالث ثلاثة﴾</q> [المائدة:٧٣]؛ قالوا: الله إله، وعيسى إله، ومريم إله. تعالى ربُّنا عن اتخاذ الأبناء، ومُحاوَزَةِ{5} الشركاء، وتقدَّس عن ملامسة النساء، فهو كما وصف نفسه ﷿{6}. (ز) ٤٦٦٤٣- قال مقاتل بن سليمان: <q>﴿فاختلف الأحزاب﴾</q> يعني: النصارى <q>﴿من بينهم﴾</q>، تحزَّبوا في عيسى ﷺ ثلاثَ فرق: النسطورية قالوا: عيسى ابن الله. ﷾ عما يقولون عُلُوًّا كبيرًا. والماريعقوبية قالوا: عيسى هو الله. ﷾ عما يقولون عُلُوًّا كبيرًا. والمَلْكانِيُّون قالوا: <q>﴿إن الله ثالث ثلاثة﴾</q> [المائدة:٧٣]. يقول الله: وحده لا شريك له{7}. (ز) <q>﴿فَوَیۡلࣱ لِّلَّذِینَ كَفَرُوا۟ مِن مَّشۡهَدِ یَوۡمٍ عَظِیمٍ ۝٣٧﴾</q> - تفسير ٤٦٦٤٤- عن قتادة بن دعامة -من طريق سعيد- قال الله: <q>﴿فويل للذين كفروا من مشهد يوم عظيم﴾</q>: شهِدُوا هوْلًا إذًا عظيمًا{8}. (ز) ٤٦٦٤٥- قال مقاتل بن سليمان: <q>﴿فويل للذين كفروا﴾</q> يعني: تحزَّبوا في عيسى ﷺ، <q>﴿من مشهد يوم عظيم﴾</q> لديه، يعني: يوم القيامة{9}. (ز) ",footnotes:1:أخرجه ابن جرير ١٥/٥٤١، وإسحاق البستي في تفسيره ص١٩٠ من طريق ابن جريج. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.أخرجه الثوري في تفسيره ص١٨٥.أخرجه عبد الرزاق ٢/٨، وابن جرير ١٥/٥٣٧، ٥٤١ بنحوه. وعزاه السيوطي إلى ابن أبي حاتم.ذكره ابن أبي حاتم -كما في تفسير ابن كثير ٣/٢٣١-.مُحاوَزَة: مخالطة. لسان العرب (حوز).علَّقه يحيى بن سلام ١/٢٢٣.تفسير مقاتل بن سليمان ٢/٦٢٧.أخرجه ابن جرير ١٥/٥٤٢. وعلَّقه يحيى بن سلام ١/٢٢٤ بلفظ: شهدوا مشهدًا عظيمًا.تفسير مقاتل بن سليمان ٢/٦٢٨.
19,38," <q>﴿أَسۡمِعۡ بِهِمۡ وَأَبۡصِرۡ یَوۡمَ یَأۡتُونَنَاۖ لَـٰكِنِ ٱلظَّـٰلِمُونَ ٱلۡیَوۡمَ فِی ضَلَـٰلࣲ مُّبِینࣲ ۝٣٨﴾</q> - تفسير ٤٦٦٤٦- عن عبد الله بن عباس -من طريق عطاء- <q>﴿أسمع بهم وأبصر﴾</q>، يقول: الكُفّارُ يومئذ أسْمَعُ شيءٍ وأَبْصَرُه{1}. (١٠/٧٢) ٤٦٦٤٧- عن أبي العالية الرياحي -من طريق الربيع بن أنس- قال: <q>﴿أسمع﴾</q> بحديثهم اليوم، <q>﴿وأبصر﴾</q> كيف يُصْنَع بهم <q>﴿يوم يأتوننا﴾</q>{2}. (ز) ٤٦٦٤٨- عن قتادة بن دعامة -من طريق معمر- في قوله: <q>﴿أسمع بهم وأبصر﴾</q> قال: أسْمَعُ قَوْمٍ وأَبْصَرُهُمْ، <q>﴿يوم يأتوننا﴾</q> قال: يوم القيامة{3}. (١٠/٧٢) ٤٦٦٤٩- عن قتادة بن دعامة -من طريق سعيد- في قوله: <q>﴿أسمع بهم وأبصر يوم يأتوننا﴾</q>، قال: ذلك -واللهِ- يوم القيامة، سمعوا حين لم ينفعهم السمعُ، وأبصروا حين لم ينفعهم البَصَرُ{4}. (١٠/٧٢) ٤٦٦٥٠- قال محمد بن السائب الكلبي: لا أحد يوم القيامة أسمع منهم ولا أبصر حين يقول الله تعالى لعيسى: <q>﴿أأنت قلت للناس﴾</q> الآية [المائدة:١١٦]{5}. (ز) ٤٦٦٥١- قال مقاتل بن سليمان: <q>﴿أسمع بهم وأبصر﴾</q> يقول: هم يوم القيامة أسْمَعُ قَوْمٍ، وأَبْصَرُ بما كانوا فيه من الوعيد وغيره، <q>﴿يوم يأتوننا﴾</q> في الآخرة. فذلك قوله سبحانه: <q>﴿ربنا أبصرنا وسمعنا فارجعنا نعمل صالحا إنا موقنون﴾</q> [السجدة:١٢]{6}. (ز) ٤٦٦٥٢- عن عبد الرحمن بن زيد بن أسلم -من طريق ابن وهب- في قوله: <q>﴿أسمع بهم وأبصر يوم يأتوننا﴾</q>، قال: هذا يوم القيامة، فأمّا الدنيا فلا، كانت على أبصارهم غشاوة، وفي آذانهم وقْرٌ في الدنيا، فلمّا كان يوم القيامة أبصروا وسمِعوا، فلم ينتفعوا، وقرأ: <q>﴿ربنا أبصرنا وسمعنا فارجعنا نعمل صالحا إنا موقنون﴾</q> [السجدة:١٢]{2}. (ز) <q>﴿لَـٰكِنِ ٱلظَّـٰلِمُونَ ٱلۡیَوۡمَ فِی ضَلَـٰلࣲ مُّبِینࣲ ۝٣٨﴾</q> - تفسير ٤٦٦٥٣- عن عبد الله بن عباس -من طريق عطاء- <q>﴿أسمع بهم وأبصر﴾</q>، يقول: الكُفّار يومئذ أسْمَعُ شيء وأَبْصَرُه، وهم اليوم لا يسمعون ولا يُبْصِرون{8}. (١٠/٧٢) ٤٦٦٥٤- قال مقاتل بن سليمان: ثم قال سبحانه: <q>﴿لكن الظالمون اليوم في ضلال مبين﴾</q>، يعني: المشركين اليوم في الدنيا في ضلال مبين، فلا يسمعون اليوم، ولا يُبْصِرون ما يكون في الآخرة{6}. (ز) ٤٦٦٥٥- قال يحيى بن سلّام: قال الله: <q>﴿لكن الظالمون﴾</q> أي: المشركون <q>﴿اليوم في ضلال مبين﴾</q> بيِّن{10}. (ز) ",footnotes:1:أخرجه ابن أبي حاتم -كما في تغليق التعليق ٤/٢٤٨-. وعلَّقه البخاري ٦/٩٣. وعزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ١٥/٥٤٤.أخرجه عبد الرزاق ٢/٨، وابن جرير ١٥/٥٤٣. وعزاه السيوطي إلى ابن المنذر.أخرجه ابن جرير ١٥/٥٤٣. وعلَّقه يحيى بن سلام ١/٢٢٥ مختصرًا. وعزاه السيوطي إلى ابن أبي حاتم.تفسير الثعلبي ٦/٢١٦، وتفسير البغوي ٥/٢٣٢.تفسير مقاتل بن سليمان ٢/٦٢٨.أخرجه ابن جرير ١٥/٥٤٤.أخرجه ابن أبي حاتم -كما في تغليق التعليق ٤/٢٤٨-. وعزاه السيوطي إلى ابن المنذر.تفسير مقاتل بن سليمان ٢/٦٢٨.تفسير يحيى بن سلام ١/٢٢٥.
