quran[13]{c,v,t}:
  19,26,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿فَكُلِی وَٱشۡرَبِی وَقَرِّی عَیۡنࣰاۖ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٦٥٠٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فكلي﴾</span> مِن النخلة، <span class="qpc-hafs">﴿واشربي﴾</span> مِن الماء العَذْب، <span class="qpc-hafs">﴿وقري عينا﴾</span> بالولد{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٥٠٥<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿فكلي واشربي﴾</span> فكلي مِن الرطب، واشربي من الجدول{2}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿فَإِمَّا تَرَیِنَّ مِنَ ٱلۡبَشَرِ أَحَدࣰا فَقُولِیۤ إِنِّی نَذَرۡتُ لِلرَّحۡمَـٰنِ صَوۡمࣰا فَلَنۡ أُكَلِّمَ ٱلۡیَوۡمَ إِنسِیࣰّا ۝٢٦﴾</span> - قراءات</h3></p><p><div></p><p><p><span class="item-no">٤٦٥٠٦<span class="dash">-</span></span> عن الشعبي، قال: في قراءة <span class="name-1">أُبَيّ بن كعب</span>: (إنِّي نَذَرْتُ لِلرَّحْمَنِ صَوْمًا صَمْتًا){3}. (١٠/٦٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٥٠٧<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> أنّه قرأها: (إنِّي نَذَرْتُ لِلرَّحْمَنِ صَوْمًا صَمْتًا). وقال: ليس إلا أن حَمَلَتْ فوَضَعَتْ{4}. (١٠/٦٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٥٠٨<span class="dash">-</span></span> عن <span class="name-1">أنس بن مالك</span> أنّه كان يقرأ: (إنِّي نَذَرْتُ لِلرَّحْمَنِ صَوْمًا صَمْتًا){5}. (١٠/٦٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٥٠٩<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿صَوْمًا﴾</span>، قال: كانت تقرأ في الحرف الأول: (صَمْتًا){6}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿فَإِمَّا تَرَیِنَّ مِنَ ٱلۡبَشَرِ أَحَدࣰا فَقُولِیۤ إِنِّی نَذَرۡتُ لِلرَّحۡمَـٰنِ صَوۡمࣰا فَلَنۡ أُكَلِّمَ ٱلۡیَوۡمَ إِنسِیࣰّا ۝٢٦﴾</span> - تفسير الآية</h3></p><p><div></p><p><p><span class="item-no">٤٦٥١٠<span class="dash">-</span></span> عن حارثة بن مُضَرِّبٍ، قال: كنت عند <span class="name-1">عبد الله بن مسعود</span>، فجاء رجلان، فسَلَّم أحدُهما، ولم يُسَلِّم الآخر، ثم جلسا، فقال القوم: ما لِصاحبك لَم يُسَلِّم؟ قال: إنّه نذر صومًا لا يُكَلِّم اليومَ إنسيًا. فقال عبد الله: بئس ما قلتَ! إنّما كانت تلك المرأة، فقالت ذلك ليكون عذرًا لها إذا سُئِلت، وكانوا يُنكِرون أن يكون ولدٌ مِن غير زَوج إلا زِنًا، تكلَّمْ، وأْمُر بالمعروف، وانْهَ عن المنكر؛ فإنّه خير لك{7}. (١٠/٦٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٥١١<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عكرمة- في قوله: <span class="qpc-hafs">﴿إني نذرت للرحمن صوما﴾</span>: يعني: صمتًا{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٥١٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق العوفي- في قوله: <span class="qpc-hafs">﴿إني نذرت للرحمن صوما﴾</span>، قال: صَمْتًا{9}<span class=comment-ref>٤١٥٧</span>. (١٠/٦٢)</p></p><p></div></p><p><div><span class=comment-ref>٤١٥٧</span> <span class="comment-type-1">وجَّهَ</span> <u>ابنُ عطية</u> (٦/٢٦) هذا القول بقوله: «إذ أصل الصيام: الإمساك».</div></p><p><div></p><p><p><span class="item-no">٤٦٥١٣<span class="dash">-</span></span> عن <span class="name-2">عامر الشعبي</span>، مثله{10}. (١٠/٦٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٥١٤<span class="dash">-</span></span> عن سليمان التيمي، قال: سمعت <span class="name-1">أنس بن مالك</span> يقول في هذه الآية: <span class="qpc-hafs">﴿إني نذرت للرحمن صوما﴾</span>، قال: صَمْتًا{11}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٥١٥<span class="dash">-</span></span> عن <span class="name-2">الضَّحّاك بن مُزاحِم</span> -من طريق عبيد- في قوله: <span class="qpc-hafs">﴿نذرت للرحمن صوما﴾</span>: يعني: صَمْتًا{12}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٥١٦<span class="dash">-</span></span> عن <span class="name-2">وهب بن مُنَبِّه</span> -من طريق ابن إسحاق، عمَّن لا يتهم-: <span class="qpc-hafs">﴿فإما ترين من البشر أحدا فقولي إني نذرت للرحمن صوما فلن أكلم اليوم إنسيا﴾</span> فإنِّي سَأَكْفِيكِ الكلامَ{13}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٥١٧<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- في قوله تعالى: <span class="qpc-hafs">﴿إني نذرت للرحمن صوما﴾</span>: ... وإنّك لا تشأ أن تلقى امرأةً جاهلة تقول: نذرت كما نذرت مريم؛ ألا تكلم يومًا إلى الليل، وإنما جعل الله تلك آيةً لمريم وابنها، ولا يحِلُّ لأحدٍ أن ينذر صمتَ يوم إلى الليل. وأما قوله: <span class="qpc-hafs">﴿صوما﴾</span> فإنّها صامت مِن الطعام والشراب والكلام{14}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٥١٨<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط-: <span class="qpc-hafs">﴿فإما ترين من البشر أحدا﴾</span> يُكلِّمك؛ <span class="qpc-hafs">﴿فقولي إني نذرت للرحمن صوما فلن أكلم اليوم إنسيا﴾</span>. فكان مَن صام في ذلك الزمان لم يتكلم حتى يمسي، فقال لها: لا تزيدي على هذا{15}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٥١٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فإما ترين من البشر أحدا فقولي إني نذرت للرحمن صوما﴾</span> يعني: صمتًا، <span class="qpc-hafs">﴿فلن أكلم اليوم إنسيا﴾</span> في عيسى ﷺ{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٥٢٠<span class="dash">-</span></span> قال <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب-: لَمّا قال عيسى لمريم: لا تحزني. قالت: وكيف لا أحزن وأنتَ معي؟! لا ذات زوج، ولا مملوكة، أيُّ شيءٍ عُذْري عند الناس؟! <span class="qpc-hafs">﴿يا ليتني مت قبل هذا وكنت نسيا منسيا﴾</span>. فقال لها عيسى: أنا أكفيك الكلام، <span class="qpc-hafs">﴿فإما ترين من البشر أحدا فقولي إني نذرت للرحمن صوما فلن أكلم اليوم إنسيا﴾</span>. قال: هذا كلُّه كلام عيسى لأُمِّه{17}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٥٢١<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿إني نذرت للرحمن صوما﴾</span>، قال: كان مِن بني إسرائيل مَن إذا اجتهد صام مِن الكلام كما يصوم من الطعام، إلا مِن ذكر الله، فقال ذلك لها كذلك، فقالت: إني أصوم من الكلام كما أصوم من الطعام، إلا مِن ذكر الله. فلما كلَّموها أشارت إليه، فقالوا: <span class="qpc-hafs">﴿كيف نكلم من كان في المهد صبيا﴾</span>؟! فأجابهم، فقال: <span class="qpc-hafs">﴿إنِّي عَبْدُاللَّهِ آتانِيَ الكِتابَ وجَعَلَنِي نَبِيًّا (٣٠) وجَعَلَنِي مُبارَكًا أيْنَما كُنْتُ وأَوْصانِي بِالصَّلاةِ والزَّكاةِ مادُمْتُ حَيًّا (٣١) وبَرًّا بِوالِدَتِي ولَمْ يَجْعَلْنِي جَبّارًا شَقِيًّا (٣٢) والسَّلامُ عَلَيَّ يَوْمَ وُلِدْتُ ويَوْمَ أمُوتُ ويَوْمَ أُبْعَثُ حَيًّا (٣٣)﴾</span>{18}. (١٠/٦٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٥٢٢<span class="dash">-</span></span> عن <span class="name-3">يحيى بن سلّام</span>، <span class="qpc-hafs">﴿فلن أكلم اليوم إنسيا﴾</span>، قال: بلغني: أنّه أُذِن لها في هذا الكلام{19}<span class=comment-ref>٤١٥٨</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٤١٥٨</span> <span class="comment-type-4">ذكر</span> <u>ابنُ عطية</u> (٦/ ٢٦) أنّ هذا القول هو ظاهر الآية، وأنه قول الجمهور. وذكر أنّ هناك من قالوا: معنى [قُولي] يريد به: بالإشارة لا بالكلام، وإلا كان التناقض بيِّنًا في كلامها. و<span class="comment-type-4">ذكر</span> (٦/٢٨) أنّه يُقَوِّيه أن مريم التزمت ما أُمِرَت به من ترك الكلام، ولم يَرد أنها نطقت بقوله: <span class="qpc-hafs">﴿إني نذرت ...﴾</span> وإنما أشارت.</div></p></div>",footnotes:1:تفسير مقاتل بن سليمان ٢/٦٢٥.|2:تفسير يحيى بن سلام ١/٢٢١.|3:عزاه السيوطي إلى ابن الأنباري. وأخرجه الطبراني -كما في الفتح ٩/٤٤٠- عن أبي بن كعب على أنه تفسير له وليس قراءة.</p><p>وقراءة (صَوْمًا صَمْتًا) أو (صَمْتًا) بدل <span class="qpc-hafs">﴿صَوْما﴾</span> شاذَّة، تروى أولاهما عن أنس بن مالك أيضًا. انظر: مختصر ابن خالويه ص٨٧.|4:عزاه السيوطي إلى عبد بن حميد، وابن الأنباري.|5:أخرجه ابن جرير ١٥/٥١٧. وعلَّقه يحيى بن سلام ١/٢٢١. وعزاه السيوطي إلى الفريابي، وعبد بن حميد، وابن المنذر، وابن أبي حاتم، وابن الأنباري في المصاحف، وابن مردويه.|6:أخرجه يحيى بن سلام ١/٢٢٢، وابن جرير ١٥/٥١٩ من طريق معمر.|7:أخرجه ابن جرير ١٥/٥١٨. وعزاه السيوطي إلى ابن أبي حاتم.|8:أخرجه مقاتل بن سليمان ٢/٦٢٥.|9:أخرجه ابن جرير ١٥/٥١٧، وإسحاق البستي في تفسيره ص١٨٨ من طريق المغيرة بن عبد الله الثقفي، وابن عساكر ٧٠/٩١. وعزاه السيوطي إلى ابن مردويه، وابن المنذر.|10:عزاه السيوطي إلى عبد بن حميد.|11:أخرجه ابن جرير ١٥/٥١٦.|12:أخرجه ابن جرير ١٥/٥١٧، وإسحاق البستي في تفسيره ص١٨٩.|13:أخرجه ابن جرير ١٥/٥١٩.|14:أخرجه عبد الرزاق ٢/٧، وابن جرير ١٥/٥١٧، ٥١٩. وأخرجه يحيى بن سلام ١/٢٢١ مختصرًا من طريق سعيد.|15:أخرجه ابن جرير ١٥/٥٢٠.|16:تفسير مقاتل بن سليمان ٢/٦٢٥.|17:أخرجه ابن جرير ١٥/٥١٨.|18:أخرجه ابن جرير ١٥/٥١٧. وعزاه السيوطي إلى ابن أبي حاتم مختصرًا.|19:تفسير يحيى بن سلام ١/٢٢٢.
  19,27,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿فَأَتَتۡ بِهِۦ قَوۡمَهَا تَحۡمِلُهُۥۖ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٦٥٢٣<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق الكلبي، عن أبي صالح- في قوله: <span class="qpc-hafs">﴿فأتت به قومها تحمله﴾</span>، قال: بعد أربعين يومًا، بعد ما تعالَّت مِن نِفاسها{1}. (١٠/٦٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٥٢٤<span class="dash">-</span></span> عن <span class="name-2">وهب بن مُنَبِّه</span> -من طريق ابن إسحاق، عمَّن لا يتهم- قال: أنساها -يعني: مريم- كَرْبُ البلاء وخَوْفُ الناس ما كانت تسمع -يعني: ما كانت تسمع مِن الملائكة من البشارة بعيسى-، حتى إذا كلمها -يعني: عيسى- وجاءها مِصداقُ ما كان الله وعَدَها احْتَمَلَتْه، ثم أقْبَلَتْ به إلى قومها{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٥٢٥<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- قال: لَمّا ولدته ذهب الشيطان، فأخبر بني إسرائيل أنّ مريم قد ولدت، فأقبلوا يَشْتَدُّون، فَدَعَوْها، <span class="qpc-hafs">﴿فأتت به قومها تحمله﴾</span>{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٥٢٦<span class="dash">-</span></span> قال <span class="name-3">محمد بن السائب الكلبي</span>: حمل يوسف النجار مريمَ وابنَها عيسى ﵉ إلى غار، ومكثت أربعين يومًا حتى طهُرَت مِن نفاسها، ثم حملته مريم ﵍ إلى قومها، فكلَّمها عيسى ﵇ في الطريق، فقال: يا أُمّاه، أبشِرِي؛ فإنِّي عبدُ الله ومسيحُه، فلمّا دخلت على أهلها ومعها الصبيُّ بَكَوا وحزنوا، وكانوا أهلَ بيت صالحين، و<span class="qpc-hafs">﴿قالُوا يا مَرْيَمُ لَقَدْ جِئْتِ شَيْئًا فَرِيًّا﴾</span>{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٥٢٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فأتت به قومها﴾</span> بالولد، <span class="qpc-hafs">﴿تحمله﴾</span> إلى بني إسرائيل في حِجْرِها ملفوفًا في خِرَق{5}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿قَالُوا۟ یَـٰمَرۡیَمُ لَقَدۡ جِئۡتِ﴾</span> - قراءات</h3></p><p><div></p><p><p><span class="item-no">٤٦٥٢٨<span class="dash">-</span></span> عن أبي بكر بن عياش، قال: في قراءة <span class="name-1">أُبيّ [بن كعب]</span>: (قالُواْ يا ذا المَهْدِ){6}. (١٠/٦٦)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿قَالُوا۟ یَـٰمَرۡیَمُ لَقَدۡ جِئۡتِ﴾</span> - تفسير الآية</h3></p><p><div></p><p><p><span class="item-no">٤٦٥٢٩<span class="dash">-</span></span> في تفسير <span class="name-2">مجاهد بن جبر</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٥٣٠<span class="dash">-</span></span> و<span class="name-2">قتادة بن دعامة</span>، قوله: <span class="qpc-hafs">﴿لقد جئت﴾</span>: لقد أتَيْتِ{7}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿شَیۡـࣰٔا فَرِیࣰّا ۝٢٧﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٦٥٣١<span class="dash">-</span></span> عن <span class="name-2">نوف البِكالِيِّ</span> -من طريق أبي عمران الجَوْني- قال: وخرج قومُها في طلبها، وكانت من أهل بيت نبوة وشرف، فلم يُحِسُّوا منها شيئًا، فرأوا راعي بقر، فقالوا: رأيتَ فتاةً كذا وكذا نَعْتُها؟ قال: لا، ولكني رأيتُ الليلة مِن بقري ما لم أره منها قطُّ. قالوا: وما رأيتَ؟ قال: رأيتُها سُجَّدًا نحو هذا الوادي. -قال عبد الله بن أبي زياد: وأحفظ عن سيّار أنه قال: رأيت نورًا ساطعًا-. فتوجَّهُوا حيث قال لهم، فاستقبلتهم مريم، فلمّا رأتهم قعدت، وحملت ابنها في حِجْرها، فجاءوا حتى قاموا عليها، <span class="qpc-hafs">﴿قالُوا يا مَرْيَمُ لَقَدْ جِئْتِ شَيْئًا فَرِيًّا﴾</span>: أمرًا عظيمًا{8}. (١٠/٤٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٥٣٢<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نَجِيحٍ- في قوله: <span class="qpc-hafs">﴿لقد جئت شيئا فريا﴾</span>، قال: عظيمًا{9}. (١٠/٦٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٥٣٣<span class="dash">-</span></span> عن <span class="name-2">وهب بن مُنَبِّه</span> -من طريق ابن إسحاق، عمَّن لا يتهم- قال: لَمّا رأوها ورَأَوْهُ معها قالوا: <span class="qpc-hafs">﴿يا مريم لقد جئت شيئا فريا﴾</span>، أي: الفاحشة غير المقاربة{10}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٥٣٤<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿لقد جئت شيئا فريا﴾</span>، قال: عظيمًا{11}. (١٠/٦٣)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٥٣٥<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- <span class="qpc-hafs">﴿لقد جئت شيئا فريا﴾</span>، يقول: عظيمًا{10}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٥٣٦<span class="dash">-</span></span> قال <span class="name-3">محمد بن السائب الكلبي</span>: <span class="qpc-hafs">﴿لَقَدْ جِئْتِ شَيْئًا فَرِيًّا﴾</span> فظيعًا منكرًا عظيمًا {4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٥٣٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿قالوا يامريم لقد جئت شيئا فريا﴾</span>، يقول: أتيتِ أمرًا مُنكرًا{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٥٣٨<span class="dash">-</span></span> عن <span class="name-3">سفيان الثوري</span>، في قوله: <span class="qpc-hafs">﴿لقد جئت شيئا فريا﴾</span>، قال: شيئًا عظيمًا{15}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿شَیۡـࣰٔا فَرِیࣰّا ۝٢٧﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٤٦٥٣٩<span class="dash">-</span></span> عن <span class="name-3">سعيد بن عبد العزيز</span>، قال: كان في زمان بني إسرائيل في بيت المقدس عند عين سُلوان عينٌ، فكانت المرأةُ إذا قارفت أتَوْها بِها، فشَرِبَتْ منها، فإن كانت بريئةً لم تَضُرَّها، وإلا ماتت، فلما حملت مريم أتَوْها بها، وحملوها على بَغْلَةٍ، فعثَرت بها، فدعت الله أن يَعْقُمَ رحمها، فعُقِمت من يومئذ، فلمّا أتتها شربت منها، فلم تزدد إلا خيرًا، ثم دعت الله ألا يفضح بها امرأة مؤمنة، فَغارَتِ العينُ{16}. (١٠/٦٤)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن عساكر ٧٠/٩٦. وعزاه السيوطي إلى سعيد ين منصور.|2:أخرجه ابن جرير ١٥/٥٢٠.|3:أخرجه ابن جرير ١٥/٥٢١.|4:تفسير الثعلبي ٦/٢١٢، وتفسير البغوي ٥/٢٢٨.|5:تفسير مقاتل بن سليمان ٢/٦٢٥.|6:عزاه السيوطي إلى ابن أبي حاتم.</p><p>وهي قراءة شاذة.|7:علَّقه يحيى بن سلام١/٢٢٢.|8:أخرجه ابن أبي حاتم -كما في تفسير ابن كثير ٣/٢٢٦-، وابن عساكر في تاريخ دمشق ٧٠/٨٥. وعزاه السيوطي إلى عبد الله بن أحمد في زوائد الزهد.|9:أخرجه ابن جرير ١٥/٥٢١، وإسحاق البستي في تفسيره ص١٨٩ من طريق ابن جريج. وعلَّقه يحيى بن سلام ١/٢٢٢. وعزاه السيوطي إلى ابن أبي شيبة، وعبد بن حميد، وابن المنذر، وابن أبي حاتم.|10:أخرجه ابن جرير ١٥/٥٢٢.|11:أخرجه ابن جرير ١٥/٥٢٢. وعلَّقه يحيى بن سلام ١/٢٢٢. وعزاه السيوطي إلى عبد الله بن أحمد في زوائد الزهد.|12:أخرجه ابن جرير ١٥/٥٢٢.|13:تفسير الثعلبي ٦/٢١٢، وتفسير البغوي ٥/٢٢٨.|14:تفسير مقاتل بن سليمان ٢/٦٢٥.|15:تفسير الثوري ص١٨٤.|16:عزاه السيوطي إلى ابن أبي حاتم.
  19,28,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿یَـٰۤأُخۡتَ هَـٰرُونَ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٦٥٤٠<span class="dash">-</span></span> عن المغيرة بن شعبة، قال: بعثني رسول الله ﷺ إلى أهل نجران، فقالوا: أرأيت ما تقرءون: <span class="qpc-hafs">﴿يا أخت هارون﴾</span>، وموسى قبل عيسى بكذا وكذا! قال: فرجعتُ، فذكرتُ ذلك لرسول الله ﷺ، فقال: «<b>ألا أخبرتَهم أنّهُم كانوا يُسَمُّون بالأنبياء والصالحين قبلهم</b>»{1}<span class=comment-ref>٤١٥٩</span>. (١٠/٦٤)</p></p><p></div></p><p><div><span class=comment-ref>٤١٥٩</span> <span class="comment-type-4">علَّق</span> <u>ابنُ كثير</u> (٩/٢٤٠-٢٤١) على هذا الحديث بقوله: «انفرد بإخراجه مسلم، والترمذي، والنسائي، من حديث عبد الله بن إدريس، عن أبيه، عن سماك، به، وقال الترمذي: حسن صحيح غريب، لا نعرفه إلا من حديث ابن إدريس».</div></p><p><div></p><p><p><span class="item-no">٤٦٥٤١<span class="dash">-</span></span> عن محمد بن سيرين، قال: نُبِّئْتُ: أنّ <span class="name-2">كعبًا</span> قال: إنّ قوله: <span class="qpc-hafs">﴿يا أخت هارون﴾</span> ليس بهارون أخي موسى. فقالت له <span class="name-1">عائشة</span>: كذبتَ. فقال: يا أمَّ المؤمنين، إن كان النبيُّ ﷺ قاله فهو أعلمُ وخيرٌ، وإلا فإنِّي أجدُ بينهما ستمائة سنة. فسَكَتَتْ{2}<span class=comment-ref>٤١٦٠</span>. (١٠/٦٦)</p></p><p></div></p><p><div><span class=comment-ref>٤١٦٠</span> <span class="comment-type-2">انتقد</span> <u>ابنُ كثير</u> (٩/٢٤١) هذا التاريخ الذي في الأثر بقوله: «وفي هذا التاريخ نظر».</div></p><p><div></p><p><p><span class="item-no">٤٦٥٤٢<span class="dash">-</span></span> عن <span class="name-2">نوف البِكاليّ</span> -من طريق أبي عمران الجَوْني- قال: <span class="qpc-hafs">﴿يا أُخْتَ هارُونَ﴾</span>، أي: يا شبيهة هارون في العبادة{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٥٤٣<span class="dash">-</span></span> عن <span class="name-2">سعيد بن جبير</span>، في قوله: <span class="qpc-hafs">﴿يا أخت هارون﴾</span>، قال: كان هارونُ مِن قوم سوءٍ زُناة، فنسبوها إليهم{4}. (١٠/٦٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٥٤٤<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نَجِيحٍ- في قوله: <span class="qpc-hafs">﴿يا أخت هارون﴾</span>، قال: رجلًا صالِحًا في بني إسرائيل، حضر جنازته أربعون ألفًا مِمَّن اسمه هارون سواه{5}. (١٠/٦٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٥٤٥<span class="dash">-</span></span> عن <span class="name-2">محمد بن كعب القُرَظي</span> -من طريق أبي صخر- في قول الله ﷿: <span class="qpc-hafs">﴿يا أُخْتَ هارُونَ﴾</span>، قال: هي أخت هارون لأبيه وأمه، وهي أخت موسى أخي هارون التي قَصَّت أثر موسى، <span class="qpc-hafs">﴿فَبَصُرَتْ بِهِ عَنْ جُنُبٍ وهُمْ لا يَشْعُرُونَ﴾</span> [القصص:١١]{6}<span class=comment-ref>٤١٦١</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٤١٦١</span> <span class="comment-type-2">انتقد</span> <u>ابنُ كثير</u> (٩/٢٣٩-٢٤٠ بتصرف) قول القرظي <span class="mustanad">مستندًا للقرآن، والسنة، والتاريخ</span>، فقال: «وهذا القول خطأ محض؛ فإنّ الله تعالى قد ذكر في كتابه أنه قَفّى بعيسى بعد الرسل، فدلَّ على أنه آخر الأنبياء بعثًا، وليس بعده إلا محمد ﷺ؛ ولهذا ثبت عن النبي ﷺ أنه قال: «<b>أنا أولى الناس بابن مريم، إلا أنه ليس بيني وبينه نبي</b>». ولو كان الأمر كما زعم محمد بن كعب القرظي لم يكن متأخرًا عن الرسل سوى محمد، ولكان قبل سليمان وداود؛ فإن الله قد ذكر أن داود بعد موسى ﵉ في قوله تعالى: <span class="qpc-hafs">﴿ألم تر إلى الملإ من بني إسرائيل من بعد موسى﴾</span> [البقرة:٢٤٦]، فذكر القصة، إلى أن قال: <span class="qpc-hafs">﴿وقتل داود جالوت﴾</span>». و<span class="comment-type-1">وجَّهه</span> بقوله: «والذي جرّأ القرظي على هذه المقالة ما في التوراة بعد خروج موسى وبني إسرائيل من البحر، وإغراق فرعون وقومه، قال: وكانت مريم بنت عمران أخت موسى وهارون النبِيَّيْنِ، تضرب بالدف هي والنساء معها يُسَبِّحْنَ الله ويشكرنه على ما أنعم به على بني إسرائيل. فاعتقد القرظي أن هذه هي أمُّ عيسى».</div></p><p><div></p><p><p><span class="item-no">٤٦٥٤٦<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- في قوله: <span class="qpc-hafs">﴿يأخت هارون﴾</span>، قال: كان رجلًا صالحًا في بني إسرائيل يُسَمّى: هارون، فشبهوها به، فقالوا: يا شبيهة هارون في الصلاح{7}<span class=comment-ref>٤١٦٢</span>. (١٠/٦٥)</p></p><p></div></p><p><div><span class=comment-ref>٤١٦٢</span> <span class="comment-type-4">علَّق</span> <u>ابنُ عطية</u> (٦/٢٧) على هذا القول بقوله: «فالمعنى أنّه اسمٌ وافق اسمًا».</div></p><p><div></p><p><p><span class="item-no">٤٦٥٤٧<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿يا أخت هارون﴾</span> الآية، قال: كانت مِن أهل بيت يُعْرَفُون بالصلاح، ولا يُعْرَفُون بالفساد في الناس، وفي الناس مَن يُعْرَفُ بالصلاح ويتوالدون به، وآخرون يُعْرَفُون بالفساد ويتوالدون به، وكان هارون مصلحًا مُحَبَّبًا في عشيرته، وليس بهارون أخي موسى، ولكن هارون آخر. ذُكِر لنا: أنّه تبِع جنازته يوم مات أربعون ألفًا مِن بني إسرائيل، كلهم يُسَمَّوْن: هارون{8}. (١٠/٦٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٥٤٨<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- قال: كانت مِن سبط هارون، فقيل لها: <span class="qpc-hafs">﴿يا أخت هارون﴾</span>. فدُعِيَت إلى سِبْطِه، كالرجل يقول للرجل: يا أخا بني ليث، يا أخا بني فلان{9}. (١٠/٦٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٥٤٩<span class="dash">-</span></span> عن <span class="name-3">علي بن أبي طلحة</span>، في قوله: <span class="qpc-hafs">﴿يا أخت هارون﴾</span>، قال: نُسِبت إلى هارون بن عمران؛ لأنها كانت مِن سِبْطِه، كقولك: يا أخا الأنصار{4}. (١٠/٦٦)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٥٥٠<span class="dash">-</span></span> قال <span class="name-3">محمد بن السائب الكلبي</span>: كان هارون أخا مريم مِن أبيها، وكان أمثلَ رجل في بني إسرائيل{11}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٥٥١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿يا أخت هارون﴾</span> الذى هو أخو موسى ... قال رسول الله ﷺ: «<b>إنما عَنَوْا هارون أخا موسى؛ لأنها كانت مِن نسله</b>»{12}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٥٥٢<span class="dash">-</span></span> عن <span class="name-3">سفيان</span>، في قوله: <span class="qpc-hafs">﴿يا أخت هارون﴾</span>، قال: سمعنا أنّه اسمٌ وافق اسمًا{4}. (١٠/٦٥)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٥٥٣<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿يا أخت هارون﴾</span>، قال: اسم واطَأَ اسْمًا، كم بين هارون وبينهما من الأمم؟ أُمَمٌ كثيرة{14}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٥٥٤<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: أي: فقالوا: <span class="qpc-hafs">﴿يا أخت هارون﴾</span> في عبادته وفضله{15}<span class=comment-ref>٤١٦٣</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٤١٦٣</span> اختُلِف في السبب الذي من أجله قيل لها: <span class="qpc-hafs">﴿يا أخت هارون﴾</span>، ومَن كان هارون هذا الذي ذكره الله؟ <b>فقال قوم</b>: كان رجلًا صالحًا من بني إسرائيل ينسب إليه مَن يُعرَف بالصلاح. <b>وقال آخرون</b>: هو هارون أخو موسى فنسبت إليه؛ لأنها من ولده كما يقال: يا أخا بني فلان. <b>وقال غيرهم</b>: كان أخاها لأبيها وأمها. <b>وذهب قوم</b>: إلى أنه كان رجلًا فاسقًا مُعْلِنًا بالفسق، ونُسِبَت إليه.</p><p>و<span class="comment-type-3">رجَّح</span> <u>ابنُ جرير</u> (١٥/٥٢٥ بتصرف) القول الأول الذي قاله قتادة، وكعب، والمغيرة بن شعبة <span class="mustanad">مستندًا إلى السنة</span>، فقال: «والصواب من القول في ذلك ما جاء به الخبرُ عن رسول الله ﷺ [الوارد في أول تفسير الآية]، وأنها نسبت إلى رجل من قومها».</p><p>و<span class="comment-type-4">بنحوه</span> <u>ابنُ كثير</u> (٩/٢٤٠).</div></p><p><h3><span class="qpc-hafs">﴿مَا كَانَ أَبُوكِ ٱمۡرَأَ سَوۡءࣲ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٦٥٥٥<span class="dash">-</span></span> قال <span class="name-1">عبد الله بن عباس</span>: زانيًا{16}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٥٥٦<span class="dash">-</span></span> عن <span class="name-2">السُّدِّيّ</span>: <span class="qpc-hafs">﴿ما كان أبوك امرأ سوء﴾</span> رجل سوء، يعني: ما كان زانيًا{17}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٥٥٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ما كان أبوك﴾</span> عمران <span class="qpc-hafs">﴿امرأ سوء﴾</span> يعني: بزانٍ. كقوله سبحانه: <span class="qpc-hafs">﴿مَن أرادَ بِأَهْلِكَ سُوءًا﴾</span> [يوسف:٢٥]، يعني: الزنا، وكقوله سبحانه: <span class="qpc-hafs">﴿ما علمنا عليه من سوء﴾</span> [يوسف:٥١]. وكان عمران مِن عُظماء بنى إسرائيل{18}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَمَا كَانَتۡ أُمُّكِ بَغِیࣰّا ۝٢٨﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٦٥٥٨<span class="dash">-</span></span> عن <span class="name-2">نوف البكاليّ</span> -من طريق أبي عمران الجَوْني- قال: <span class="qpc-hafs">﴿ما كانَ أبُوكِ امْرَأَ سَوْءٍ وما كانَتْ أُمُّكِ بَغِيًّا﴾</span>، أي: أنت مِن بيت طيِّب طاهر، معروف بالصلاح والعبادة والزهادة، فكيف صَدَرَ هذا منكِ؟!{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٥٥٩<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- <span class="qpc-hafs">﴿وما كانت أمك بغيا﴾</span>، قال: زانية{20}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٥٦٠<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وما كانت أمك﴾</span> حَنَّة <span class="qpc-hafs">﴿بغيا﴾</span> بزانية، فمن أين هذا الولد؟!{18}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٥٦١<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلام</span>: <span class="qpc-hafs">﴿وما كانت أمك بغيا﴾</span>، يعني: وما كانت أمك زانية{15}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه مسلم ٣/١٦٨٥ (٢١٣٥)، وابن جرير ١٥/٥٢٤. وأورده الثعلبي ٦/٢١٣.|2:أخرجه ابن جرير ١٥/٥٢٤. وعزاه السيوطي إلى ابن أبي حاتم.|3:أخرجه ابن أبي حاتم -كما في تفسير ابن كثير ٣/٢٢٦-.|4:عزاه السيوطي إلى ابن أبي حاتم.|5:أخرجه الخطيب ١/٣٨٢، وابن عساكر ٧٠/٩٨.|6:أخرجه ابن أبي حاتم -كما في تفسير ابن كثير ٣/٢٢٧-.|7:أخرجه عبد الرزاق ٢/٧-٨، وابن جرير ١٥/٥٢٣. وعزاه السيوطي إلى عبد بن حميد.|8:أخرجه يحيى بن سلام ١/٢٢٢ مختصرًا، وابن جرير ١٥/٥٢٣. وعزاه السيوطي إلى ابن أبي حاتم.|9:أخرجه ابن جرير ١٥/٥٢٥. وعزاه السيوطي إلى ابن أبي حاتم.|10:عزاه السيوطي إلى ابن أبي حاتم.|11:تفسير الثعلبي ٦/٢١٣، وتفسير البغوي ٥/٢٢٩.|12:تفسير مقاتل بن سليمان ٢/٦٢٥-٦٢٦.|13:عزاه السيوطي إلى ابن أبي حاتم.|14:أخرجه ابن جرير ١٥/٥٢٤.|15:تفسير يحيى بن سلام ١/٢٢٢.|16:تفسير البغوي ٥/٢٢٩.|17:علقه يحيى سلام ١/٢٢٢.|18:تفسير مقاتل بن سليمان ٢/٦٢٦.|19:أخرجه ابن أبي حاتم -كما في تفسير ابن كثير ٣/٢٢٦-.|20:أخرجه ابن جرير ١٥/٥٢٥. ووقع بعده موصولًا به: «قال: <span class="qpc-hafs">﴿وما كانت أمك بغيا﴾</span>. ولم يقل: بغية؛ لأنّ ذلك مِمّا يُوصَف به النساء دون الرجال، فجرى مجرى: امرأة حائض وطالق، وقد كان بعضهم يشبه ذلك بقولهم: ملحفة جديد، وامرأة قتيل». وكذلك في نسخة شاكر ١٨/١٨٨. والظاهر أن هذا من قول ابن جرير، وليس من قول السدي.|21:تفسير مقاتل بن سليمان ٢/٦٢٦.|22:تفسير يحيى بن سلام ١/٢٢٢.
  19,29,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿فَأَشَارَتۡ إِلَیۡهِۖ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٦٥٦٢<span class="dash">-</span></span> قال <span class="name-1">عبد الله بن مسعود</span>: لَمّا لم تكن لها حُجَّةٌ أشارت إليه؛ ليكون كلامُه حُجَّةً لها{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٥٦٣<span class="dash">-</span></span> عن <span class="name-2">عمرو بن ميمون</span>، قال: إنّ مريم لَمّا ولدت أتت به قومها، فأخذوا لها الحجارةَ ليرموها، فأشارت إليه، فتكلَّم، فتركوها{2}. (١٠/٦٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٥٦٤<span class="dash">-</span></span> عن <span class="name-2">وهب بن مُنَبِّه</span> -من طريق ابن إسحاق، عمَّن لا يتهم- <span class="qpc-hafs">﴿فأشارت إليه﴾</span>، يقول: أشارت إليه أن كلِّموه{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٥٦٥<span class="dash">-</span></span> عن <span class="name-2">ميمون بن مهران</span>، قال: لَمّا قالوا لمريم: <span class="qpc-hafs">﴿لَقَدْ جِئْتِ شَيْئًا فَرِيًّا﴾</span> إلخ؛ أشارت إلى عيسى أن كلِّموه، فقالوا: تأمرنا أن نكلِّم مَن هو في المهد زيادةً على ما جاءت به مِن الداهية!{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٥٦٦<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿فأشارت إليه﴾</span>، قال: أمرتهم بكلامه{5}. (١٠/٦٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٥٦٧<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- قال: لَمّا قالوا لها: <span class="qpc-hafs">﴿ما كان أبوك امرأ سوء وما كانت أمك بغيا﴾</span>؛ قالت لهم ما أمرها الله به، فلمّا أرادوها بعد ذلك على الكلام <span class="qpc-hafs">﴿فأشارت إليه﴾</span> إلى عيسى{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٥٦٨<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فأشارت إليه﴾</span>، يعني: إلى ابنها عيسى ﷺ أن كلِّموه{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٥٦٩<span class="dash">-</span></span> عن <span class="name-3">عبد الملك ابن جُرَيْج</span> -من طريق حجاج- في قوله: <span class="qpc-hafs">﴿فأشارت إليه﴾</span>: أن كلِّموه{8}. (١٠/٦٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٥٧٠<span class="dash">-</span></span> عن <span class="name-3">سفيان الثوري</span>، في قوله: <span class="qpc-hafs">﴿فأشارت إليه﴾</span>، قال: إلى عيسى{9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٥٧١<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: قوله: <span class="qpc-hafs">﴿فأشارت إليه﴾</span> بيدها{10}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿قَالُوا۟ كَیۡفَ نُكَلِّمُ مَن كَانَ فِی ٱلۡمَهۡدِ صَبِیࣰّا ۝٢٩﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٦٥٧٢<span class="dash">-</span></span> عن <span class="name-2">السُّدِّيّ</span>: <span class="qpc-hafs">﴿قالوا كيف نكلم من كان فِي المَهْدِ صَبِيًّا﴾</span>، يعني: مَن هو{11}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٥٧٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿قالوا﴾</span> قال قومها: <span class="qpc-hafs">﴿كيف نكلم من كان فِي المَهْدِ صَبِيًّا﴾</span> يعني: من هو{7}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿فِی ٱلۡمَهۡدِ صَبِیࣰّا ۝٢٩﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٦٥٧٤<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span>، قال: المهد: المرباة. قال إبراهيم: المرباة: المرجحة{2}. (١٠/٦٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٥٧٥<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿في المهد﴾</span>، قال: الحِجْر{14}. (١٠/٦٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٥٧٦<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span> -من طريق أسباط- قال: لَمّا أشارت لهم إلى عيسى غضِبوا، وقالوا: لَسُخْرِيَّتُها بنا حين تأمرنا أن نُكَلِّم هذا الصبي أشدُّ علينا مِن زناها، <span class="qpc-hafs">﴿قالوا كيف نكلم من كان في المهد صبيا﴾</span>{15}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٥٧٧<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿في المهد﴾</span> يعني: في حِجْر أمه ملفوفًا في خِرَق <span class="qpc-hafs">﴿صبيا﴾</span>، فدنا زكريا من الصبي، فقال: تكلَّم -يا صبيُّ- بعذرك إن كان لك عذر. <span class="qpc-hafs">﴿قال إني عبد الله آتاني الكتاب وجعلني نبيا * وجعلني مباركا أينما كنت وأَوْصانِي بِالصَّلاةِ والزَّكاةِ مادُمْتُ حَيًّا (٣١) وبَرًّا بِوالِدَتِي ولم يجعلني جبارا شقيا﴾</span>. فلمّا ذكر الوالدة ولم يذكر الوالد ضَمَّه زكريا إلى صدره، وقال: أشهد أنّك عبدُ الله ورسوله{16}. (ز)</p></p><p></div></p></div>",footnotes:1:تفسير البغوي ٥/٢٢٩.|2:عزاه السيوطي إلى عبد بن حميد.|3:أخرجه ابن جرير ١٥/٥٢٦.|4:أخرجه ابن أبي حاتم -كما في الفتح ٦/٤٧٩-.|5:أخرجه ابن جرير ١٥/٥٢٦. وعلَّقه يحيى بن سلام ١/٢٢٢. وعزاه السيوطي إلى ابن أبي حاتم.|6:أخرجه ابن جرير ١٥/٥٢٦.|7:تفسير مقاتل بن سليمان ٢/٦٢٦.|8:أخرجه ابن جرير ١٥/٥٢٦. وعزاه السيوطي إلى ابن المنذر.|9:أخرجه الثوري في تفسيره ص١٨٤.|10:تفسير يحيى بن سلام ١/٢٢٢.|11:علَّقه يحيى بن سلام ١/٢٢٢.|12:تفسير مقاتل بن سليمان ٢/٦٢٦.|13:عزاه السيوطي إلى عبد بن حميد.|14:أخرجه يحيى بن سلام ١/٢٢٢، وابن جرير ١٥/٥٢٧. وعزاه السيوطي إلى ابن أبي حاتم.|15:أخرجه ابن جرير ١٥/٥٢٨.|16:تفسير مقاتل بن سليمان ٢/٦٢٦-٦٢٧ بتصرف يسير.
  19,30,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿قَالَ إِنِّی عَبۡدُ ٱللَّهِ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٦٥٧٨<span class="dash">-</span></span> عن <span class="name-2">وهب بن مُنَبِّه</span> -من طريق ابن إسحاق، عمَّن لا يتَّهم-: <span class="qpc-hafs">﴿قالوا كيف نكلم من كان في المهد صبيا﴾</span>. فأجابهم عيسى عنها، فقال لهم: <span class="qpc-hafs">﴿إني عبد الله آتاني الكتاب وجعلني نبيا﴾</span> الآية{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٥٧٩<span class="dash">-</span></span> قال <span class="name-2">وهب بن مُنَبِّه</span>: أتاها زكريا عند مناظرتها اليهود، فقال لعيسى: انطق بحجتك إن كنتَ أُمرتَ بها. فقال عند ذلك عيسى ﵇وهو ابن أربعين يومًا-: <span class="qpc-hafs">﴿إني عبد الله﴾</span> أقرَّ على نفسه بالعبودية لله ﷿ أولَ ما تكلم لِئَلّا يُتَّخَذ إلَهًا{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٥٨٠<span class="dash">-</span></span> قال <span class="name-2">إسماعيل السُّدِّيّ</span>: فلمّا سمِع عيسى كلامَهم ترك الرَّضاع، وأقبل عليهم{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٥٨١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: فـ<span class="qpc-hafs">﴿قال﴾</span> الصبيُّ -وهو يومئذ ولد-: <span class="qpc-hafs">﴿إني عبد الله﴾</span>. وكَذَبَتِ النصارى فيما يقولون، فأول ما تكلم به الصبيُّ أنه أقرَّ لله بالعبودية{4}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿ءَاتَىٰنِیَ ٱلۡكِتَـٰبَ وَجَعَلَنِی نَبِیࣰّا ۝٣٠﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٦٥٨٢<span class="dash">-</span></span> عن <span class="name-1">أنس بن مالك</span>، قال: كان عيسى قد درس الإنجيل، وأحكمها في بطن أمه، فذلك قوله: <span class="qpc-hafs">﴿إني عبد الله آتاني الكتاب﴾</span>{5}<span class=comment-ref>٤١٦٤</span>. (١٠/٦٨)</p></p><p></div></p><p><div><span class=comment-ref>٤١٦٤</span> ذكر <u>ابنُ عطية</u> (٦/٣١) أنّ فرقة قالت: إن عيسى أوتي الكتاب وهو في الطفولة، وأنه كان يصلي ويصوم. و<span class="comment-type-2">انتقده</span> بقوله: «وهذا في غاية الضعف، مصرّح بجهالة قائله».</div></p><p><div></p><p><p><span class="item-no">٤٦٥٨٣<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span> -من طريق سماك- في قوله: <span class="qpc-hafs">﴿إني عبد الله آتاني الكتاب﴾</span> الآية، قال: قضى أن يؤتيني الكتاب{6}. (١٠/٦٧)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٥٨٤<span class="dash">-</span></span> عن <span class="name-2">عكرمة مولى ابن عباس</span> -من طريق سماك- في قوله: <span class="qpc-hafs">﴿آتاني الكتاب﴾</span>، قال: آتاني من قبل أن يخلقني{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٥٨٥<span class="dash">-</span></span> عن <span class="name-2">الحسن البصري</span> أنّه قال: أُلْهِمَ التوراة وهو في بطن أُمِّه{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٥٨٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿آتاني الكتاب﴾</span> يعني: أعطانى الإنجيل، فعَلَّمَنِيه، <span class="qpc-hafs">﴿وجعلني نبيا﴾</span>{9}<span class=comment-ref>٤١٦٥</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٤١٦٥</span> <span class="comment-type-4">ذكر</span> <u>ابنُ عطية</u> (٦/٢٩) أن الكتاب هو التوراة. ثم <span class="comment-type-4">ذكر</span> أنّه <b>يحتمل</b> أن يكون التوراة والإنجيل.</div></p><p><div></p><p><p><span class="item-no">٤٦٥٨٧<span class="dash">-</span></span> قال <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿قالوا كيف نكلم من كان في المهد صبيا قال﴾</span> لهم: <span class="qpc-hafs">﴿إني عبد الله آتاني الكتاب وجعلني نبيا﴾</span>. فقرأ حتى بلغ: <span class="qpc-hafs">﴿ولم يجعلني جبارا شقيا﴾</span> فقالوا: إنّ هذا لَأمرٌ عظيم{1}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ١٥/٥٢٨.|2:تفسير الثعلبي ٦/٢١٣، وتفسير البغوي ٥/٢٣٠، واللفظ له.|3:تفسير البغوي ٥/٢٢٩.|4:تفسير مقاتل بن سليمان ٢/٦٢٦. وقوله: «وهو يوم ولد» في تفسير الثعلبي ٦/٢١٣، وتفسير البغوي ٥/٢٣٠، منسوبًا إلى مقاتل مهملًا.|5:عزاه السيوطي إلى ابن أبي حاتم.|6:أخرجه عبد الرزاق ٢/٩، وابن جرير ١٥/٥٢٩. وعزاه السيوطي إلى ابن أبي شيبة، وعبد بن حميد، وابن المنذر، وابن أبي حاتم.|7:أخرجه الثوري في تفسيره ص١٨٥.|8:تفسير البغوي ٥/٢٣٠.|9:تفسير مقاتل بن سليمان ٢/٦٢٦.|10:أخرجه ابن جرير ١٥/٥٢٨.
  19,31,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَجَعَلَنِی مُبَارَكًا أَیۡنَ مَا كُنتُ وَأَوۡصَـٰنِی﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٦٥٨٨<span class="dash">-</span></span> عن أبي هريرة، قال: قال النبي ﷺ: «<b>قول عيسى</b>: <span class="qpc-hafs">﴿وجعلني مباركا أينما كنت﴾</span>. <b>قال: جعلني نفّاعًا للناس أين اتَّجَهْتُ</b>»{1}. (١٠/٦٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٥٨٩<span class="dash">-</span></span> عن عبد الله بن مسعود، عن النبي ﷺ: <span class="qpc-hafs">﴿وجعلني مباركا أينما كنت﴾</span>، قال: «<b>مُعَلِّمًا، ومُؤَدِّبًا</b>»{2}. (١٠/٦٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٥٩٠<span class="dash">-</span></span> عن <span class="name-1">جابر</span> -من طريق عمرو-: <span class="qpc-hafs">﴿وجعلني مباركًا أينما كنت﴾</span> لعيسى بن مريم قال: مُعَلِّمًا، ومُؤَدِّبًا{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٥٩١<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span>، <span class="qpc-hafs">﴿وجعلني مباركا﴾</span>، قال: هاديًا، مَهْدِيًّا{4}. (١٠/٦٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٥٩٢<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ليث- في قوله: <span class="qpc-hafs">﴿وجعلني مباركا أينما كنت﴾</span>، قال: مُعَلِّمًا للخير{5}. (١٠/٦٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٥٩٣<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ليث- <span class="qpc-hafs">﴿وجعلني مباركا﴾</span>، قال: نفّاعًا للناس{6}. (١٠/٦٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٥٩٤<span class="dash">-</span></span> عن عمرو بن قيس -من طريق أبي قبيصة- في قوله تعالى: <span class="qpc-hafs">﴿وجعلني مباركا أين ما كنت﴾</span>، قال: مُؤَدِّبًا، ومُعَلِّمًا{7}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٥٩٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وجعلني مباركا﴾</span> يعني: مُعَلِّمًا مُؤَدِّبًا في الخير، <span class="qpc-hafs">﴿أين ما كنت﴾</span> مِن الأرض{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٥٩٦<span class="dash">-</span></span> عن <span class="name-3">سفيان [بن عيينة]</span> -من طريق يونس بن عبد الأعلى- في قوله: <span class="qpc-hafs">﴿وجعلني مباركا أينما كنت﴾</span>، قال: مُعَلِّمًا للخير{9}<span class=comment-ref>٤١٦٦</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٤١٦٦</span> <span class="comment-type-4">علَّق</span> <u>ابنُ القيم</u> (٢/١٧٠-١٧١) على قول سفيان بقوله: «وهذا يدُلُّ على أن تعليم الرجل الخير هو البركة التي جعلها الله فيه؛ فإنّ البركة حصول الخير ونماؤه ودوامه، وهذا في الحقيقة ليس إلا في العلم الموروث عن الأنبياء وتعليمه؛ ولهذا سمى سبحانه كتابه: مباركًا».</div></p><p><div></p><p><p><span class="item-no">٤٦٥٩٧<span class="dash">-</span></span> عن أبي حفص -من طريق جابر- في قوله: <span class="qpc-hafs">﴿وجعلني مباركا أينما كنت﴾</span>، قال: عيسى بن مريم، قال: مُعَلِّمًا، ومُؤَدِّبًا{10}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٥٩٨<span class="dash">-</span></span> عن وهيب بن الورد، قال: لقي عالِمٌ عالِمًا هو فوقه في العلم، فقال له: يرحمك الله، ما الذي أُعْلِنُ من علمي؟ قال: الأمر بالمعروف، والنهي عن المنكر؛ فإنّه دين الله الذي بعث به أنبياءه إلى عباده، وقد اجتمع الفقهاء على قول الله: <span class="qpc-hafs">﴿وجعلني مباركا أينما كنت﴾</span>. وقيل: ما بركته؟ قال: الأمر بالمعروف، والنهي عن المنكر أينما كان{11}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٥٩٩<span class="dash">-</span></span> قال يحيى بن سلّام: فقال عيسى: <span class="qpc-hafs">﴿وجعلني مباركا أين ما كنت﴾</span>، سمعتُ بعضَ الكوفيين يقول: أي: مُعَلِّمًا، مُؤَدِّبًا{12}<span class=comment-ref>٤١٦٧</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٤١٦٧</span> أفادت الآثارُ الاختلاف في معنى قوله: <span class="qpc-hafs">﴿مباركا﴾</span>، و<span class="comment-type-4">ذكر</span> <u>ابنُ عطية</u> (٦/٣٠) أنّ قوله: <span class="qpc-hafs">﴿مباركا﴾</span> يَعُمُّ جميع ما ذُكر من الوجوه وغيرها.</div></p></div>",footnotes:1:أخرجه الإسماعيلي في معجم أسامي شيوخه ٢/٦١٥-٦١٦، وأبو نعيم في الحلية ٣/٢٥.</p><p>قال أبو نعيم: «غريب من حديث يونس، تفرَّد به عن هشيم، وعنه شعيب».|2:أخرجه ابن عدي في الكامل ٦/٢٢٨، وابن عساكر في تاريخه ٤٧/٣٦٠.</p><p>قال ابن عدي: «غير محفوظ بهذا الإسناد».|3:أخرجه ابن عساكر في تاريخ دمشق ٤٧/٣٦٠.|4:عزاه السيوطي إلى عبد بن حميد.|5:أخرجه ابن جرير ١٥/٥٣١. وعزاه السيوطي إلى عبد الله بن أحمد في زوائد الزهد، وابن المنذر، وابن أبي حاتم.|6:أخرجه ابن جرير ١٥/٥٣٠، والبيهقي في الشعب (٧٦٦١)، وابن عساكر ٤٧/٣٦٠.|7:أخرجه أبو الشيخ في طبقات المحدثين بأصبهان ٢/١٣.|8:تفسير مقاتل بن سليمان ٢/٦٢٦.|9:أخرجه ابن جرير ١٥/٥٣١.|10:أخرجه ابن عدي في الكامل ٦/٢٢٨، وابن عساكر في تاريخ دمشق ٤٧/٣٦٠.|11:أخرجه ابن أبي الدنيا في كتاب الأمر بالمعروف والنهي عن المنكر -موسوعة ابن أبي الدنيا ٢/١٩٧ (١٣)-، وابن جرير ١٥/٥٣٠ واللفظ له.|12:تفسير يحيى بن سلام ١/٢٢٢.
  19,32,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَأَوۡصَـٰنِی بِٱلصَّلَوٰةِ وَٱلزَّكَوٰةِ مَا دُمۡتُ حَیࣰّا ۝٣١ وَبَرَّۢا بِوَ ٰ⁠لِدَتِی﴾</span> - قراءات</h3></p><p><div></p><p><p><span class="item-no">٤٦٦٠٠<span class="dash">-</span></span> عن <span class="name-2">أبي نَهيك [عثمان بن نهيك]</span> -من طريق عبد المؤمن- أنّه قرأ: (وبِرًّا بِوالِدَتِي) مِن قول عيسى ﵇. قال <span class="name-2">أبو نهيك</span>: أوصاني بالصلاة والزكاة والبر بالوالدين، كما أوصاني بذلك{1}<span class=comment-ref>٤١٦٨</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٤١٦٨</span> <span class="comment-type-1">وجَّهَ</span> <u>ابنُ جرير</u> (١٥/٥٣٢) قراءة أبي نهيك بقوله: «فكأنّ أبا نهيك وجَّه تأويل الكلام إلى أن قوله: <span class="qpc-hafs">﴿وبرا بوالدتي﴾</span> من خبر عيسى، عن وصية الله إيّاه به، كما أن قوله: <span class="qpc-hafs">﴿وأوصاني بالصلاة والزكاة﴾</span> من خبره عن وصية الله إياه بذلك. فعلى هذا القول يجب أن يكون نصب البرِّ بمعنى: عمل الوصية فيه؛ لأن الصلاة والزكاة وإن كانتا مخفوضتين في اللفظ فإنهما بمعنى النصب مِن أجل أنه مفعول بهما».</div></p><p><h3><span class="qpc-hafs">﴿وَأَوۡصَـٰنِی بِٱلصَّلَوٰةِ وَٱلزَّكَوٰةِ مَا دُمۡتُ حَیࣰّا ۝٣١ وَبَرَّۢا بِوَ ٰ⁠لِدَتِی﴾</span> - تفسير الآية</h3></p><p><div></p><p><p><span class="item-no">٤٦٦٠١<span class="dash">-</span></span> عن <span class="name-2">نوف البكالي</span>: <span class="qpc-hafs">﴿وبرا بوالدتي﴾</span>، أي: ليس لي أب{2}. (١٠/٦٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٦٠٢<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span>: <span class="qpc-hafs">﴿وبرا بوالدتي﴾</span>، أي: وجعلني بَرًّا بوالدتي، يعني: مُطيعًا لأمر مريم{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٦٠٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿وأوصاني بـ﴾</span>إقامة <span class="qpc-hafs">﴿الصلاة و﴾</span>إيتاء <span class="qpc-hafs">﴿الزكاة ما دمت حيا﴾</span>، <span class="qpc-hafs">﴿وبرا بوالدتي﴾</span> يقول: وأوصاني أن أكون بَرًّا بوالدتي، يعني: مُطِيعًا لأُمِّي مريم{4}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَلَمۡ یَجۡعَلۡنِی جَبَّارࣰا شَقِیࣰّا ۝٣٢﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٦٦٠٤<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>، في قوله: <span class="qpc-hafs">﴿ولم يجعلني جبارا شقيا﴾</span>، يقول: عَصِيًّا{5}. (١٠/٦٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٦٠٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ولم يجعلني جبارا﴾</span> يعني: مُتَكَبِّرًا عن عبادة الله، <span class="qpc-hafs">﴿شقيا﴾</span> يعني: عاصيًا لله ﷿{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٦٠٦<span class="dash">-</span></span> عن <span class="name-3">سفيان بن عُيَيْنة</span> -من طريق ابن أبي عمر- قال: الجبّار الشَّقِيُّ الذي يقتُلُ على الغضب{7}. (١٠/٦٩)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٦٠٧<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿ولم يجعلني جبارا﴾</span> مُسْتَكْبِرًا عن عبادة الله، ولم يجعلني <span class="qpc-hafs">﴿شقيا﴾</span>{8}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَلَمۡ یَجۡعَلۡنِی جَبَّارࣰا شَقِیࣰّا ۝٣٢﴾</span> - آثار متعلقة بالآية</h3></p><p><div></p><p><p><span class="item-no">٤٦٦٠٨<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- قال: ذُكِر لنا: أنّه -يعني: عيسى- كان يقول: سَلُوني، فإنّ قلبي ليِّنٌ، وإنِّي صغير في نفسي. مِمّا أعطاه الله مِن التواضع{9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٦٠٩<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- <span class="qpc-hafs">﴿وبرا بوالدتي ولم يجعلني جبارا شقيا﴾</span>: ذُكِر لنا: أنّ امرأةً رأت ابن مريم يُحْيِي الموتى، ويُبْرِئ الأكمه والأبرص، في آياتٍ سَلَّطه اللهُ عَلَيْهِنَّ، وأذِن له فيهنَّ. فقالت: طُوبى للبطن الذي حملك، والثدي الذي أُرضعت به. فقال نبي الله ابن مريم يجيبها: طوبى لمن تلا كتاب الله، واتبع ما فيه، ولم يكن جبارًا شقيًّا{9}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٦١٠<span class="dash">-</span></span> عن <span class="name-2">العَوّام بن حَوْشَب</span>، قال: إنّك لا تكاد تجد عاقًّا إلا تجده جبّارًا. ثم قرأ هذه الآية: <span class="qpc-hafs">﴿وبرا بوالدتي ولم يجعلني جبارا شقيا﴾</span>{11}. (١٠/٦٩)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ١٥/٥٣٢.</p><p>(وبِرًّا) بكسر الباء قراءة شاذة، تروى أيضًا عن أبي مجلز. انظر: مختصر ابن خالويه ص٨٧، والمحتسب ٢/٤٢.|2:عزاه السيوطي إلى ابن أبي حاتم.|3:علقه يحيى بن سلام ١/٢٢٣.|4:تفسير مقاتل بن سليمان ٢/٦٢٦.|5:أخرجه ابن أبي حاتم -كما في الإتقان ٢/٢٦-.|6:تفسير مقاتل بن سليمان ٢/٦٢٧.|7:أخرجه إسحاق البستي في تفسيره ص١٩٠. وعزاه السيوطي إلى ابن أبي حاتم.|8:تفسير يحيى بن سلام ١/٢٢٣.|9:أخرجه ابن جرير ١٥/٥٣٣.|10:أخرجه ابن جرير ١٥/٥٣٣.|11:أخرجه أخرجه ابن جرير ناسبًا إيّاه إلى بعض أهل العلم ١٥/٥٣٣. وعزاه السيوطي إلى ابن أبي حاتم.
  19,33,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَٱلسَّلَـٰمُ عَلَیَّ یَوۡمَ وُلِدتُّ وَیَوۡمَ أَمُوتُ وَیَوۡمَ أُبۡعَثُ حَیࣰّا ۝٣٣﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٦٦١١<span class="dash">-</span></span> عن <span class="name-2">عامر الشعبي</span>، قال: فِقَراتُ{1} ابن آدم ثلاث؛ يوم وُلِد، ويوم يموت، ويوم يبعث، وهي التي ذكر عيسى في قوله: <span class="qpc-hafs">﴿والسلام علي﴾</span> الآية{2}. (١٠/٦٨)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٦١٢<span class="dash">-</span></span> عن <span class="name-2">وهب بن مُنَبِّه</span> -من طريق ابن إسحاق، عمَّن لا يتهم- <span class="qpc-hafs">﴿والسلام علي يوم ولدت ويوم أموت ويوم أبعث حيا﴾</span>، قال: يُخبِرُهم في قصة خبره عن نفسه أنّه لا أب له، وأنّه سيموت ثم يبعث حيًّا، يقول الله -تبارك وتعالى-: <span class="qpc-hafs">﴿ذلك عيسى ابن مريم قول الحق الذي فيه يمترون﴾</span>{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٦١٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿والسلام علي يوم ولدت﴾</span> يعني: حين وُلِدت، <span class="qpc-hafs">﴿ويوم أموت﴾</span> يعني: وحين أموت، <span class="qpc-hafs">﴿ويوم أبعث حيا﴾</span> يعني: وحين أبعث حيًّا بعد الموت في الآخرة. ثم لم يتكلم بعد ذلك حتى كان بمنزلة غيره من الصبيان، فلما قال: <span class="qpc-hafs">﴿وبرا بوالدتي﴾</span> ضمَّه زكريّا{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٦١٤<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: <span class="qpc-hafs">﴿والسلام علي يوم﴾</span> حين <span class="qpc-hafs">﴿ولدت ويوم﴾</span> وحين <span class="qpc-hafs">﴿أموت ويوم أبعث حيا﴾</span> يوم القيامة. ولم يتكلم بعد ذلك بشيء حتى بلغ مبلغ الغلمان{5}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿وَٱلسَّلَـٰمُ عَلَیَّ یَوۡمَ وُلِدتُّ وَیَوۡمَ أَمُوتُ وَیَوۡمَ أُبۡعَثُ حَیࣰّا ۝٣٣﴾</span> - آثار متعلقة بالآيات</h3></p><p><div></p><p><p><span class="item-no">٤٦٦١٥<span class="dash">-</span></span> عن <span class="name-1">أبي سعيد الخدري</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٦١٦<span class="dash">-</span></span> و<span class="name-1">أبي هريرة</span>: أنّ الله أطلق لسانَ عيسى مرة أخرى في صباه، فتكلَّم ثلاث مرات، حتى بلغ ما بلغ الصبيان، يتكلَّمون فتكلَّم، فحمد الله بتحميدٍ لم تسمع الآذانُ مثلَه، حيث أنطقه طفلًا، فقال: اللهم، أنت القريبُ في عُلُوِّك، المُتعالي في دُنُوِّك، الرفيع على كل شيء مِن خلقك، أنت الذي نفذ بصرك في خلقك، وحارَتِ الأبصار دون النظر إليك، أنت الذي غُشِّيت الأبصار دونك، وشَمَخَ بك العلياء في النور، وتَشَعْشَع بك البناء الرفيع في المتباعد، أنت الذي جَليت حِندِسَ الظُّلَم{6} بنورك، أنت الذي أشرقت بضوء نورك دلادجُ الظلام، وتلَأْلَأَت بعظمتك أركان العرش نورًا، فلم يبلغ أحد بصفته صفتك، فتباركت اللهم خالق الخلق بعِزَّتك، مُقَدِّرَ الأمور بحكمتك، مبتدئ الخلق بعظمتك. ثم أمْسَك الله لسانَه حتى بلغ{7}. (١٠/٧٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٦١٧<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق مجاهد- قال: ما تَكَلَّم عيسى إلا بالآيات التي تَكَلَّم بها حتى بلغ مبلغ الصبيان{8}. (١٠/٧٠)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٦١٨<span class="dash">-</span></span> عن <span class="name-2">الضَّحّاك بن مُزاحِم</span> -من طريق عبيد- في قوله: <span class="qpc-hafs">﴿كيف نكلم من كان في المهد صبيا قال إني عبد الله﴾</span>، قال: لم يتكلم عيسى إلا عند ذلك، حين <span class="qpc-hafs">﴿قالوا كيف نكلم من كان في المهد صبيا﴾</span>{9}. (ز)</p></p><p></div></p></div>",footnotes:1:الفِقَرات -بكسر الفاء وفتح القاف-: جمع فِقَرة، الأمورُ العظام. الدر المصون في علوم الكتاب المكنون للسمين الحلبي ١/٦٢٩.|2:عزاه السيوطي إلى ابن أبي حاتم.|3:أخرجه ابن جرير ١٥/٥٣٤.|4:تفسير مقاتل بن سليمان ٢/٦٢٧.|5:تفسير يحيى بن سلام ١/٢٢٣.|6:حِندِسَ الظلم: شديدة الظلمة. لسان العرب (حندس).|7:أخرجه ابن عساكر ٤٧/٣٦٢.|8:أخرجه ابن أبي شيبة ١١/٥٤٥، وابن عساكر ٤٧/٣٦٢. وعزاه السيوطي إلى ابن أبي حاتم.|9:أخرجه ابن جرير ١٥/٥٢٨، وإسحاق البستي في تفسيره ص١٩٠.
  19,34,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿ذَ ٰ⁠لِكَ عِیسَى ٱبۡنُ مَرۡیَمَۖ قَوۡلَ ٱلۡحَقِّ﴾</span> - قراءات</h3></p><p><div></p><p><p><span class="item-no">٤٦٦١٩<span class="dash">-</span></span> عن <span class="name-2">إبراهيم النخعي</span> -من طريق الأعمش- قال: كانوا يقولون في هذا الحرف في قراءة <span class="name-1">عبد الله بن مسعود</span>: (قالُ اللهِ الَّذِي فِيهِ يَمْتَرُونَ). قال: كلمة الله{1}<span class=comment-ref>٤١٦٩</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٤١٦٩</span> <span class="comment-type-4">ساق</span> <u>ابنُ جرير</u> (١٥/٥٣٥) هذا القول، ثم قال: «ولو وجّه تأويل ذلك إلى: ذلك عيسى ابن مريم القول الحق، بمعنى: ذلك القول الحق، ثم حذفت الألف واللام من القول، وأضيف إلى الحق. <span class="mustanad">كما قيل</span>: <span class="qpc-hafs">﴿إن هذا لهو حق اليقين﴾</span> [الواقعة:٩٥]، وكما قيل: <span class="qpc-hafs">﴿وعد الصدق الذي كانوا يوعدون﴾</span> [الأحقاف:١٦] كان تأويلًا صحيحًا».</div></p><p><div></p><p><p><span class="item-no">٤٦٦٢٠<span class="dash">-</span></span> عن الأعمش: في قراءة <span class="name-1">عبد الله بن مسعود</span>: (ذَلِكَ عِيسى ابْنُ مَرْيَمَ قالُ الحَقِّ الَّذِي فِيهِ يَمْتَرُونَ){2}<span class=comment-ref>٤١٧٠</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٤١٧٠</span> <span class="comment-type-4">ذكر</span> <u>ابنُ جرير</u> (١٥/٥٣٦) أن هذه القراءة بمعنى: قول الحقّ، مثلُ: العابِ والعيبِ، والذام والذِّيمِ.</div></p><p><h3><span class="qpc-hafs">﴿ذَ ٰ⁠لِكَ عِیسَى ٱبۡنُ مَرۡیَمَۖ قَوۡلَ ٱلۡحَقِّ﴾</span> - تفسير الآية</h3></p><p><div></p><p><p><span class="item-no">٤٦٦٢١<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن جريج- في قوله: <span class="qpc-hafs">﴿ذلك عيسى ابن مريم قول الحق﴾</span>، قال: اللهُ الحقُّ ﷿{3}<span class=comment-ref>٤١٧١</span>. (١٠/٧١)</p></p><p></div></p><p><div><span class=comment-ref>٤١٧١</span> <span class="comment-type-2">استدرك</span> <u>ابنُ تيمية</u> (٤/٢٧٩-٢٨٠) على هذا القول بقوله: «فهو وإن كان معنًى صحيحًا فعادةُ القرآن إذا أضيف القول إلى الله أن يقال: قول الله، لا يقال: قول الحق، إلا إذا كان المراد: القول الحق، <span class="mustanad">كما في قوله</span>: <span class="qpc-hafs">﴿قوله الحق﴾</span> [الأنعام:٧٣]».</div></p><p><div></p><p><p><span class="item-no">٤٦٦٢٢<span class="dash">-</span></span> قال <span class="name-2">الحسن البصري</span>: <span class="qpc-hafs">﴿ذلك عيسى ابن مريم قول الحق﴾</span>، والحق هو الله، هو قوله{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٦٢٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: يقول الله ﷿: <span class="qpc-hafs">﴿ذلك عيسى ابن مريم قول الحق﴾</span>، يعني: هذا عيسى ابن مريم قول العدل، يعني: الصدق{5}<span class=comment-ref>٤١٧٢</span>. (ز)</p></p><p></div></p><p><div><span class=comment-ref>٤١٧٢</span> <span class="comment-type-1">وجَّه</span> <u>ابنُ تيمية</u> (٤/٢٧٩) هذا القول، فقال: «تسميته: قول الحق، كتسميته: كلمة الله». و<span class="comment-type-3">رجَّح</span> أن الأظهر أن المراد: أن القول الذي قلناه عن عيسى بن مريم هو قول الحق.</div></p><p><h3><span class="qpc-hafs">﴿ٱلَّذِی فِیهِ یَمۡتَرُونَ ۝٣٤﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٦٦٢٤<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- قوله: <span class="qpc-hafs">﴿ذلك عيسى ابن مريم قول الحق الذي فيه يمترون﴾</span>: امْتَرَتْ فيه اليهود والنصارى، فأمّا اليهود فزعموا أنّه ساحر كذاب، وأمّا النصارى فزعموا أنه ابن الله، وثالث ثلاثة، وإله، وكذبوا كلُّهم، ولكنه عبد الله ورسوله وكلمته وروحه{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٦٢٥<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- في قوله: <span class="qpc-hafs">﴿الذي فيه يمترون﴾</span>، قال: اجتمع بنو إسرائيل فأخرجوا منهم أربعةَ نفر، أخرج مِن كلِّ قوم عالمهم، فامتروا في عيسى حين رفع، فقال أحدهم: هو اللهُ، هبط إلى الأرض، فأحيا مَن أحيا، وأمات مَن أمات، ثم صعد إلى السماء. وهم اليعْقُوبِيَّةُ، فقالت الثلاثة: كذبتَ. ثم قال اثنان منهم للثالث: قُلْ فيه. فقال: هو ابن الله. وهم النُّسطُورِيَّة. فقال اثنان: كذبت. ثم قال أحد الاثنين للآخر: قلْ فيه. قال: هو ثالث ثلاثة؛ الله إله، وعيسى إله، وأمه إله. وهم الإسرائيلية، وهم ملوك النصارى، فقال الرابع: كذبت، هو عبد الله، ورسوله، وروحه، مِن كلمته. وهم المسلمون، فكان لكل رجل منهم أتباع على ما قال، فاقتتلوا، فظُهِر على المسلمين. فذلك قول الله: <span class="qpc-hafs">﴿ويقتلون الذين يأمرون بالقسط بين الناس﴾</span> [آل عمران:٢١]. قال <span class="name-2">قتادة</span>: وهم الذين قال الله: <span class="qpc-hafs">﴿فاختلف الأحزاب من بينهم﴾</span>. قال: اختلفوا فيه، فصاروا أحزابًا، فاختصم القوم، فقال المرء المسلم: أنشدكم، هل تعلمون أنّ عيسى كان يَطْعَمُ الطعامَ، وأنّ الله لا يَطْعَم الطعام؟ قالوا: اللَّهُمَّ نعم. قال: فهل تعلمون أنّ عيسى كان ينام، وأنّ الله لا ينام؟ قالوا: اللهم نعم. فخصمهم المسلمون، فاقتتل القوم، فذُكِر لنا: أنّ اليعقوبية ظهرت يومئذ، وأصيب المسلمون، فأنزل الله في ذلك القرآن: <span class="qpc-hafs">﴿فويل للذين كفروا من مشهد يوم عظيم﴾</span>{7}. (١٠/٧١)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٦٢٦<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿الذي فيه يمترون﴾</span>، يعني: الذي فيه يَشُكُّون في أمر عيسى ﷺ، وهم النصارى{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٦٢٧<span class="dash">-</span></span> عن <span class="name-3">عبد الملك ابن جريج</span> -من طريق حجاج- قوله: <span class="qpc-hafs">﴿الذي فيه يمترون﴾</span>، قال: اختلفوا؛ فقالت فرقة: هو عبد الله ونبيُّه، فآمنوا به. وقالت فرقة: بل هو الله. وقالت فرقة: هو ابن الله. تبارك وتعالى عما يقولون عُلُوًّا كبيرًا. قال: فذلك قوله <span class="qpc-hafs">﴿فاختلف الأحزاب من بينهم﴾</span>، والتي في الزخرف [٦٥]، قال: دَقْيوسُ ونُسْطُورُ وماريعقوب، قال أحدهم حين رفع اللهُ عيسى: هو الله. وقال الآخر: ابن الله. وقال الآخر: كلمة الله، وعبده. فقال المفتريان: إنّ قولي هو أشبه بقولك، وقولك بقولي، مِن قول هذا، فهلُمَّ فلنقاتلهم. فقاتلوهم، وأوطؤوهم، وغلبوهم حتى خرج النبي ﷺ، وهم مُسْلِمَةُ أهل الكتاب{9}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ١٥/٥٣٥.</p><p>(قالُ اللهِ) قراءة شاذة. انظر: مختصر ابن خالويه ص٨٧.|2:أخرجه ابن أبي داود في المصاحف ١/٣٢٢.</p><p>(قالُ الحَقِّ) قراءة شاذة. انظر: مختصر ابن خالويه ص٨٧.|3:أخرجه ابن جرير ١٥/٥٣٥، وإسحاق البستي في تفسيره ص١٩٠. وعزاه السيوطي إلى ابن المنذر، وابن أبي حاتم.|4:علَّقه يحيى بن سلام ١/٢٢٣.|5:تفسير مقاتل بن سليمان ٢/٦٢٧.|6:أخرجه ابن جرير ١٥/٥٣٧. وعلَّقه يحيى بن سلام ١/٢٢٣ مختصرًا.|7:أخرجه عبد الرزاق ٢/٨، وابن جرير ١٥/٥٣٧، ٥٤١ بنحوه. وأخرج يحيى بن سلام ١/٢٢٤ نحوه من طريق سعيد. وعزاه السيوطي إلى ابن أبي حاتم.|8:تفسير مقاتل بن سليمان ٢/٦٢٧.|9:أخرجه ابن جرير ١٥/٥٣٧.
  19,35,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿مَا كَانَ لِلَّهِ أَن یَتَّخِذَ مِن وَلَدࣲۖ سُبۡحَـٰنَهُۥۤۚ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٦٦٢٨<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span>: قال اللهُ: <span class="qpc-hafs">﴿سبحانه﴾</span>، يُنَزِّه نفسه عما يقولون{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٦٢٩<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿ما كان لله أن يتخذ من ولد﴾</span> يعني: عيسى ﷺ، <span class="qpc-hafs">﴿سبحانه﴾</span> نزَّه نفسه ﷿{2}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿إِذَا قَضَىٰۤ أَمۡرࣰا﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٦٦٣٠<span class="dash">-</span></span> عن <span class="name-2">السُّدِّيّ</span>: <span class="qpc-hafs">﴿إذا قضى أمرا﴾</span>، يعني: عيسى، كان في علمه أن يكون مِن غير أبٍ{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٦٣١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿إذا قضى أمرا﴾</span> كان في علمه، يعني: عيسى ﷺ{2}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿فَإِنَّمَا یَقُولُ لَهُۥ كُن فَیَكُونُ ۝٣٥﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٦٦٣٢<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق الضحاك- أنّه قال: <span class="qpc-hafs">﴿كن فيكون﴾</span> بالفارسية، لا يثنى القول مرتين، إذا قال مرَّةً كان{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٦٣٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فإنما يقول له كن فيكون﴾</span> مرَّةً واحدة، لا يثني القول فيه مرتين{2}. (ز)</p></p><p></div></p></div>",footnotes:1:علَّقه يحيى بن سلام ١/٢٢٣.|2:تفسير مقاتل بن سليمان ٢/٦٢٧.|3:علَّقه يحيى بن سلام ١/٢٢٣.|4:تفسير مقاتل بن سليمان ٢/٦٢٧.|5:رواه مقاتل بن سليمان في تفسيره ٢/٦٢٧.|6:تفسير مقاتل بن سليمان ٢/٦٢٧.
  19,36,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿وَإِنَّ ٱللَّهَ رَبِّی وَرَبُّكُمۡ فَٱعۡبُدُوهُۚ هَـٰذَا صِرَ ٰ⁠طࣱ مُّسۡتَقِیمࣱ ۝٣٦﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٦٦٣٤<span class="dash">-</span></span> عن <span class="name-2">وهْب بن مُنَبِّه</span> -من طريق ابن إسحاق، عمَّن لا يتهم- قال: عهد إليهم حين أخبرهم عن نفسه، ومولده، وموته، وبعثه: أنّ الله ربي وربكم فاعبدوه هذا صراط مستقيم، أي: إنِّي وإيّاكم عبيدُ الله، فاعبدوه، ولا تعبدوا غيره{1}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٦٣٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثم قال عيسى ﷺ لبني إسرائيل: <span class="qpc-hafs">﴿وإن الله ربي وربكم فاعبدوه﴾</span> يعني: فوَحِّدوه، <span class="qpc-hafs">﴿هذا﴾</span> التوحيد <span class="qpc-hafs">﴿صراط مستقيم﴾</span> يعني: دين الإسلام مستقيم، وغير دين الإسلام أعوجٌ ليس بمستقيم{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٦٣٦<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: قوله: <span class="qpc-hafs">﴿وإن الله ربي وربكم فاعبدوه هذا صراط مستقيم﴾</span>، هذا قول عيسى لهم{3}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ١٥/٥٤٠.|2:تفسير مقاتل بن سليمان ٢/٦٢٧.|3:تفسير يحيى بن سلام ١/٢٢٣.
  19,37,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿فَٱخۡتَلَفَ ٱلۡأَحۡزَابُ مِنۢ بَیۡنِهِمۡۖ﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٦٦٣٧<span class="dash">-</span></span> عن <span class="name-2">مجاهد بن جبر</span> -من طريق ابن أبي نَجِيحٍ- في قوله: <span class="qpc-hafs">﴿فاختلف الأحزاب من بينهم﴾</span>، قال: هم أهل الكتاب{1}. (١٠/٧٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٦٣٨<span class="dash">-</span></span> عن <span class="name-2">محمد بن كعب القرظي</span> -من طريق موسى بن عبيدة- في قوله: <span class="qpc-hafs">﴿فاختلف الأحزاب من بينهم﴾</span>، قال: في عيسى. فمِنهم مَن قال: ولد. ومنهم مَن قال: بَغِيَّة. يعني: الفرية{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٦٣٩<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- <span class="qpc-hafs">﴿فاختلف الأحزاب من بينهم﴾</span>: اختلفوا فيه، فصاروا أحزابًا{3}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٦٤٠<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span>= (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٦٤١<span class="dash">-</span></span> و<span class="name-2">عروة بن الزبير</span>، قريبًا من ذلك{4}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٦٤٢<span class="dash">-</span></span> عن <span class="name-2">إسماعيل السُّدِّيّ</span>: قوله: <span class="qpc-hafs">﴿فاختلف الأحزاب من بينهم﴾</span> في الدين، يعني: النصارى، فتجادلوا في عيسى، فقالت النُسطورية: عيسى ابن الله، تعالى ربُّنا عن ذلك. وقالت اليعقوبية: <span class="qpc-hafs">﴿إن الله هو المسيح ابن مريم﴾</span> [المائدة:١٧] جل ربُّنا عن ذلك. وقال الملْكانِيُّونَ: <span class="qpc-hafs">﴿إن الله ثالث ثلاثة﴾</span> [المائدة:٧٣]؛ قالوا: الله إله، وعيسى إله، ومريم إله. تعالى ربُّنا عن اتخاذ الأبناء، ومُحاوَزَةِ{5} الشركاء، وتقدَّس عن ملامسة النساء، فهو كما وصف نفسه ﷿{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٦٤٣<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فاختلف الأحزاب﴾</span> يعني: النصارى <span class="qpc-hafs">﴿من بينهم﴾</span>، تحزَّبوا في عيسى ﷺ ثلاثَ فرق: النسطورية قالوا: عيسى ابن الله. ﷾ عما يقولون عُلُوًّا كبيرًا. والماريعقوبية قالوا: عيسى هو الله. ﷾ عما يقولون عُلُوًّا كبيرًا. والمَلْكانِيُّون قالوا: <span class="qpc-hafs">﴿إن الله ثالث ثلاثة﴾</span> [المائدة:٧٣]. يقول الله: وحده لا شريك له{7}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿فَوَیۡلࣱ لِّلَّذِینَ كَفَرُوا۟ مِن مَّشۡهَدِ یَوۡمٍ عَظِیمٍ ۝٣٧﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٦٦٤٤<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- قال الله: <span class="qpc-hafs">﴿فويل للذين كفروا من مشهد يوم عظيم﴾</span>: شهِدُوا هوْلًا إذًا عظيمًا{8}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٦٤٥<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿فويل للذين كفروا﴾</span> يعني: تحزَّبوا في عيسى ﷺ، <span class="qpc-hafs">﴿من مشهد يوم عظيم﴾</span> لديه، يعني: يوم القيامة{9}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن جرير ١٥/٥٤١، وإسحاق البستي في تفسيره ص١٩٠ من طريق ابن جريج. وعزاه السيوطي إلى عبد بن حميد، وابن المنذر، وابن أبي حاتم.|2:أخرجه الثوري في تفسيره ص١٨٥.|3:أخرجه عبد الرزاق ٢/٨، وابن جرير ١٥/٥٣٧، ٥٤١ بنحوه. وعزاه السيوطي إلى ابن أبي حاتم.|4:ذكره ابن أبي حاتم -كما في تفسير ابن كثير ٣/٢٣١-.|5:مُحاوَزَة: مخالطة. لسان العرب (حوز).|6:علَّقه يحيى بن سلام ١/٢٢٣.|7:تفسير مقاتل بن سليمان ٢/٦٢٧.|8:أخرجه ابن جرير ١٥/٥٤٢. وعلَّقه يحيى بن سلام ١/٢٢٤ بلفظ: شهدوا مشهدًا عظيمًا.|9:تفسير مقاتل بن سليمان ٢/٦٢٨.
  19,38,"<div class=ar lang=ar><p><h3><span class="qpc-hafs">﴿أَسۡمِعۡ بِهِمۡ وَأَبۡصِرۡ یَوۡمَ یَأۡتُونَنَاۖ لَـٰكِنِ ٱلظَّـٰلِمُونَ ٱلۡیَوۡمَ فِی ضَلَـٰلࣲ مُّبِینࣲ ۝٣٨﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٦٦٤٦<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطاء- <span class="qpc-hafs">﴿أسمع بهم وأبصر﴾</span>، يقول: الكُفّارُ يومئذ أسْمَعُ شيءٍ وأَبْصَرُه{1}. (١٠/٧٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٦٤٧<span class="dash">-</span></span> عن <span class="name-2">أبي العالية الرياحي</span> -من طريق الربيع بن أنس- قال: <span class="qpc-hafs">﴿أسمع﴾</span> بحديثهم اليوم، <span class="qpc-hafs">﴿وأبصر﴾</span> كيف يُصْنَع بهم <span class="qpc-hafs">﴿يوم يأتوننا﴾</span>{2}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٦٤٨<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق معمر- في قوله: <span class="qpc-hafs">﴿أسمع بهم وأبصر﴾</span> قال: أسْمَعُ قَوْمٍ وأَبْصَرُهُمْ، <span class="qpc-hafs">﴿يوم يأتوننا﴾</span> قال: يوم القيامة{3}. (١٠/٧٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٦٤٩<span class="dash">-</span></span> عن <span class="name-2">قتادة بن دعامة</span> -من طريق سعيد- في قوله: <span class="qpc-hafs">﴿أسمع بهم وأبصر يوم يأتوننا﴾</span>، قال: ذلك -واللهِ- يوم القيامة، سمعوا حين لم ينفعهم السمعُ، وأبصروا حين لم ينفعهم البَصَرُ{4}. (١٠/٧٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٦٥٠<span class="dash">-</span></span> قال <span class="name-3">محمد بن السائب الكلبي</span>: لا أحد يوم القيامة أسمع منهم ولا أبصر حين يقول الله تعالى لعيسى: <span class="qpc-hafs">﴿أأنت قلت للناس﴾</span> الآية [المائدة:١١٦]{5}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٦٥١<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: <span class="qpc-hafs">﴿أسمع بهم وأبصر﴾</span> يقول: هم يوم القيامة أسْمَعُ قَوْمٍ، وأَبْصَرُ بما كانوا فيه من الوعيد وغيره، <span class="qpc-hafs">﴿يوم يأتوننا﴾</span> في الآخرة. فذلك قوله سبحانه: <span class="qpc-hafs">﴿ربنا أبصرنا وسمعنا فارجعنا نعمل صالحا إنا موقنون﴾</span> [السجدة:١٢]{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٦٥٢<span class="dash">-</span></span> عن <span class="name-3">عبد الرحمن بن زيد بن أسلم</span> -من طريق ابن وهب- في قوله: <span class="qpc-hafs">﴿أسمع بهم وأبصر يوم يأتوننا﴾</span>، قال: هذا يوم القيامة، فأمّا الدنيا فلا، كانت على أبصارهم غشاوة، وفي آذانهم وقْرٌ في الدنيا، فلمّا كان يوم القيامة أبصروا وسمِعوا، فلم ينتفعوا، وقرأ: <span class="qpc-hafs">﴿ربنا أبصرنا وسمعنا فارجعنا نعمل صالحا إنا موقنون﴾</span> [السجدة:١٢]{2}. (ز)</p></p><p></div></p><p><h3><span class="qpc-hafs">﴿لَـٰكِنِ ٱلظَّـٰلِمُونَ ٱلۡیَوۡمَ فِی ضَلَـٰلࣲ مُّبِینࣲ ۝٣٨﴾</span> - تفسير</h3></p><p><div></p><p><p><span class="item-no">٤٦٦٥٣<span class="dash">-</span></span> عن <span class="name-1">عبد الله بن عباس</span> -من طريق عطاء- <span class="qpc-hafs">﴿أسمع بهم وأبصر﴾</span>، يقول: الكُفّار يومئذ أسْمَعُ شيء وأَبْصَرُه، وهم اليوم لا يسمعون ولا يُبْصِرون{8}. (١٠/٧٢)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٦٥٤<span class="dash">-</span></span> قال <span class="name-3">مقاتل بن سليمان</span>: ثم قال سبحانه: <span class="qpc-hafs">﴿لكن الظالمون اليوم في ضلال مبين﴾</span>، يعني: المشركين اليوم في الدنيا في ضلال مبين، فلا يسمعون اليوم، ولا يُبْصِرون ما يكون في الآخرة{6}. (ز)</p></p><p></div></p><p><div></p><p><p><span class="item-no">٤٦٦٥٥<span class="dash">-</span></span> قال <span class="name-3">يحيى بن سلّام</span>: قال الله: <span class="qpc-hafs">﴿لكن الظالمون﴾</span> أي: المشركون <span class="qpc-hafs">﴿اليوم في ضلال مبين﴾</span> بيِّن{10}. (ز)</p></p><p></div></p></div>",footnotes:1:أخرجه ابن أبي حاتم -كما في تغليق التعليق ٤/٢٤٨-. وعلَّقه البخاري ٦/٩٣. وعزاه السيوطي إلى ابن المنذر.|2:أخرجه ابن جرير ١٥/٥٤٤.|3:أخرجه عبد الرزاق ٢/٨، وابن جرير ١٥/٥٤٣. وعزاه السيوطي إلى ابن المنذر.|4:أخرجه ابن جرير ١٥/٥٤٣. وعلَّقه يحيى بن سلام ١/٢٢٥ مختصرًا. وعزاه السيوطي إلى ابن أبي حاتم.|5:تفسير الثعلبي ٦/٢١٦، وتفسير البغوي ٥/٢٣٢.|6:تفسير مقاتل بن سليمان ٢/٦٢٨.|7:أخرجه ابن جرير ١٥/٥٤٤.|8:أخرجه ابن أبي حاتم -كما في تغليق التعليق ٤/٢٤٨-. وعزاه السيوطي إلى ابن المنذر.|9:تفسير مقاتل بن سليمان ٢/٦٢٨.|10:تفسير يحيى بن سلام ١/٢٢٥.